quran[99]{c,v,t}:
15,1,الٓرٰ١۫ تِلْكَ اٰیٰتُ الْكِتٰبِ وَ قُرْاٰنٍ مُّبِیْنٍ الٓرٰ : الف لام را تِلْكَ : یہ اٰيٰتُ : آیتیں الْكِتٰبِ : کتاب وَ : اور قُرْاٰنٍ : قرآن مُّبِيْنٍ : واضح۔ روشن ا لر، یہ کتاب الٰہی کی آیتیں ہیں اور کھلی اور روشن قرآن کی (1)۔
15,2,رُبَمَا یَوَدُّ الَّذِیْنَ كَفَرُوْا لَوْ كَانُوْا مُسْلِمِیْنَ رُبَمَا : بسا اوقات يَوَدُّ : آرزو کریں گے الَّذِيْنَ كَفَرُوْا : وہ لوگ جو کافر ہوئے لَوْ كَانُوْا : کاش وہ ہوتے مُسْلِمِيْنَ : مسلمان وہ وقت بھی ہوگا کہ کافر اپنے مسلمان ہونے کی آرزو کریں گے (1)۔
15,3,ذَرْهُمْ یَاْكُلُوْا وَ یَتَمَتَّعُوْا وَ یُلْهِهِمُ الْاَمَلُ فَسَوْفَ یَعْلَمُوْنَ ذَرْهُمْ : انہیں چھوڑ دو يَاْكُلُوْا : وہ کھائیں وَيَتَمَتَّعُوْا : اور فائدہ اٹھالیں وَيُلْهِهِمُ : اور غفلت میں رکھے انہیں الْاَمَلُ : امید فَسَوْفَ : پس عنقریب يَعْلَمُوْنَ : وہ جان لیں گے آپ انھیں کھاتا، نفع اٹھاتا اور (جھوٹی) امیدوں میں مشغول ہوتا چھوڑ دیجئیے یہ خود بھی جان لیں گے (1)۔
15,4,وَ مَاۤ اَهْلَكْنَا مِنْ قَرْیَةٍ اِلَّا وَ لَهَا كِتَابٌ مَّعْلُوْمٌ وَمَآ : اور نہیں اَهْلَكْنَا : ہم نے ہلاک کیا مِنْ : کسی قَرْيَةٍ : بستی اِلَّا : مگر وَلَهَا : اس کے لیے كِتَابٌ : ایک لکھا ہوا مَّعْلُوْمٌ : مقررہ وقت کسی بستی کو ہم نے ہلاک نہیں کیا مگر یہ کہ اس کے لئے مقررہ نوشتہ تھا (1)
15,5,مَا تَسْبِقُ مِنْ اُمَّةٍ اَجَلَهَا وَ مَا یَسْتَاْخِرُوْنَ مَا تَسْبِقُ : نہ سبقت کرتی ہے مِنْ اُمَّةٍ : کوئی امت اَجَلَهَا : اپنا مقررہ وقت وَمَا : اور نہ يَسْتَاْخِرُوْنَ : وہ پیچھے رہتے ہیں کوئی گروہ اپنی موت سے نہ آگے بڑھتا نہ پیچھے رہتا (1)
15,6,وَ قَالُوْا یٰۤاَیُّهَا الَّذِیْ نُزِّلَ عَلَیْهِ الذِّكْرُ اِنَّكَ لَمَجْنُوْنٌؕ وَقَالُوْا : اور وہ بولے يٰٓاَيُّھَا : اے وہ الَّذِيْ نُزِّلَ : وہ جو کہ اتارا گیا عَلَيْهِ : اس پر الذِّكْرُ : یاد دہانی (قرآن) اِنَّكَ : بیشک تو لَمَجْنُوْنٌ : دیوانہ انہوں نے کہا اے وہ شخص جس پر قرآن اتارا گیا ہے یقیناً تو تو کوئی دیوانہ ہے (1)
15,7,لَوْ مَا تَاْتِیْنَا بِالْمَلٰٓئِكَةِ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ لَوْ : کیوں مَا تَاْتِيْنَا : ہمارے پاس تو نہیں لے آتا بِالْمَلٰٓئِكَةِ : فرشتوں کو اِنْ : اگر كُنْتَ : تو ہے مِنَ : سے الصّٰدِقِيْنَ : سچے اگر تو سچا ہی ہے تو ہمارے پاس فرشتوں کو کیوں نہیں لاتا (1)۔
15,8,مَا نُنَزِّلُ الْمَلٰٓئِكَةَ اِلَّا بِالْحَقِّ وَ مَا كَانُوْۤا اِذًا مُّنْظَرِیْنَ مَا نُنَزِّلُ : ہم نازل نہیں کرتے الْمَلٰٓئِكَةَ : فرشتے اِلَّا : مگر بِالْحَقِّ : حق کے ساتھ وَمَا كَانُوْٓا : اور نہ ہوں گے اِذًا : اس وقت مُّنْظَرِيْنَ : مہلت دئیے گئے ہم فرشتوں کو حق کے ساتھ ہی اتارتے ہیں اور اس وقت وہ مہلت دیئے گئے نہیں ہوتے (1)
15,9,اِنَّا نَحْنُ نَزَّلْنَا الذِّكْرَ وَ اِنَّا لَهٗ لَحٰفِظُوْنَ اِنَّا : بیشک نَحْنُ : ہم نَزَّلْنَا : ہم نے نازل کیا الذِّكْرَ : یاد دہانی (قرآن) وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَحٰفِظُوْنَ : نگہبان ہم نے ہی اس قرآن کو نازل فرمایا ہے اور ہم ہی اس کے محافظ ہیں (1)۔
15,10,وَ لَقَدْ اَرْسَلْنَا مِنْ قَبْلِكَ فِیْ شِیَعِ الْاَوَّلِیْنَ وَلَقَدْ اَرْسَلْنَا : اور یقیناً ہم نے بھیجے مِنْ : سے قَبْلِكَ : تم سے پہلے فِيْ : میں شِيَعِ : گروہ الْاَوَّلِيْنَ : پہلے ہم نے آپ سے پہلے اگلی امتوں میں بھی رسول (برابر) بھیجے۔
15,11,وَ مَا یَاْتِیْهِمْ مِّنْ رَّسُوْلٍ اِلَّا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ وَمَا يَاْتِيْهِمْ : اور نہیں آیا ان کے پاس مِّنْ رَّسُوْلٍ : کوئی رسول اِلَّا : مگر كَانُوْا : وہ تھے بِهٖ : اس سے يَسْتَهْزِءُوْنَ : استہزا کرتے اور (لیکن) جو بھی رسول آتا وہ اس کا مذاق اڑاتے (1)۔
15,12,كَذٰلِكَ نَسْلُكُهٗ فِیْ قُلُوْبِ الْمُجْرِمِیْنَۙ كَذٰلِكَ : اسی طرح نَسْلُكُهٗ : ہم اسے ڈال دیتے ہیں فِيْ : میں قُلُوْبِ : دل (جمع) الْمُجْرِمِيْنَ : مجرموں گناہگاروں کے دلوں میں ہم اسی طرح ہی رچا دیا کرتے ہیں (1)۔
15,13,لَا یُؤْمِنُوْنَ بِهٖ وَ قَدْ خَلَتْ سُنَّةُ الْاَوَّلِیْنَ لَا يُؤْمِنُوْنَ : وہ ایمان نہیں لائیں گے بِهٖ : اس پر وَقَدْ خَلَتْ : اور پڑچکی ہے سُنَّةُ : رسم۔ روش الْاَوَّلِيْنَ : پہلے وہ اس پر ایمان نہیں لاتے اور یقیناً اگلوں کا طریقہ گزرا ہوا ہے (1)۔
15,14,وَ لَوْ فَتَحْنَا عَلَیْهِمْ بَابًا مِّنَ السَّمَآءِ فَظَلُّوْا فِیْهِ یَعْرُجُوْنَۙ وَلَوْ : اور اگر فَتَحْنَا : ہم کھول دیں عَلَيْهِمْ : ان پر بَابًا : کوئی دروازہ مِّنَ : سے السَّمَآءِ : آسمان فَظَلُّوْا : وہ رہیں فِيْهِ : اس میں يَعْرُجُوْنَ : چڑھتے اور اگر ہم ان پر آسمان کا دروازہ کھول بھی دیں اور یہ وہاں چڑھنے بھی لگ جائیں۔
15,15,لَقَالُوْۤا اِنَّمَا سُكِّرَتْ اَبْصَارُنَا بَلْ نَحْنُ قَوْمٌ مَّسْحُوْرُوْنَ۠    ۧ لَقَالُوْٓا : تو کہیں گے اِنَّمَا : اس کے سوا نہیں سُكِّرَتْ : باندھ دی گئی اَبْصَارُنَا : ہماری آنکھیں بَلْ : بلکہ نَحْنُ : ہم قَوْمٌ : لوگ مَّسْحُوْرُوْنَ : سحر زدہ تب بھی یہی کہیں گے کہ ہماری نظر بندی کردی گئی ہے بلکہ ہم لوگوں پر جادو کردیا گیا ہے۔ (1)
15,16,وَ لَقَدْ جَعَلْنَا فِی السَّمَآءِ بُرُوْجًا وَّ زَیَّنّٰهَا لِلنّٰظِرِیْنَۙ وَلَقَدْ جَعَلْنَا : اور یقیناً ہم نے بنائے فِي : میں السَّمَآءِ : آسمان بُرُوْجًا : برج (جمع) وَّزَيَّنّٰهَا : اور اسے زینت دی لِلنّٰظِرِيْنَ : دیکھنے والوں کے لیے یقیناً ہم نے آسمان میں برج بنائے ہیں (1) اور دیکھنے والوں کے لئے اسے سجا دیا گیا ہے۔
15,17,وَ حَفِظْنٰهَا مِنْ كُلِّ شَیْطٰنٍ رَّجِیْمٍۙ وَحَفِظْنٰهَا : اور ہم نے حفاظت کی اس کی مِنْ : سے كُلِّ : ہر شَيْطٰنٍ : شیطان رَّجِيْمٍ : مردود اور اسے ہر مردود شیطان سے محفوظ رکھا ہے (1)
15,18,اِلَّا مَنِ اسْتَرَقَ السَّمْعَ فَاَتْبَعَهٗ شِهَابٌ مُّبِیْنٌ اِلَّا : مگر مَنِ : جو اسْتَرَقَ : چوری کرے السَّمْعَ : سننا فَاَتْبَعَهٗ : تو اس کا پیچھا کرتا ہے شِهَابٌ : شعلہ مُّبِيْنٌ : چمکتا ہوا ہاں مگر جو چوری چھپے سننے کی کوشش کرے اس کے پیچھے دھکتا ہوا (کھلا شعلہ) لگتا ہے (1)۔
15,19,وَ الْاَرْضَ مَدَدْنٰهَا وَ اَلْقَیْنَا فِیْهَا رَوَاسِیَ وَ اَنْۢبَتْنَا فِیْهَا مِنْ كُلِّ شَیْءٍ مَّوْزُوْنٍ وَالْاَرْضَ : اور زمین مَدَدْنٰهَا : ہم نے اس کو پھیلا دیا وَاَلْقَيْنَا : اور ہم نے رکھے فِيْهَا : اس میں (پر) رَوَاسِيَ : پہاڑ وَاَنْۢبَتْنَا : اور ہم نے اگائی فِيْهَا : اس میں مِنْ : سے كُلِّ شَيْءٍ : ہر شئے مَّوْزُوْنٍ : موزوں اور زمین کو ہم نے پھیلا دیا ہے اور اس پر (اٹل) پہاڑ ڈال دیئے، اور اس میں ہم نے ہر چیز ایک معین مقدار سے اگادی۔
15,20,وَ جَعَلْنَا لَكُمْ فِیْهَا مَعَایِشَ وَ مَنْ لَّسْتُمْ لَهٗ بِرٰزِقِیْنَ وَجَعَلْنَا : اور ہم نے بنائے لَكُمْ : تمہارے لیے فِيْهَا : اس میں مَعَايِشَ : سامانِ معیشت وَمَنْ : اور جو۔ جس لَّسْتُمْ : تم نہیں لَهٗ : اس کے لیے بِرٰزِقِيْنَ : رزق دینے والے اور اسی میں ہم نے تمہاری روزیاں بنادی ہیں (1) اور جنہیں تم روزی دینے والے نہیں ہو (2)۔
15,21,وَ اِنْ مِّنْ شَیْءٍ اِلَّا عِنْدَنَا خَزَآئِنُهٗ١٘ وَ مَا نُنَزِّلُهٗۤ اِلَّا بِقَدَرٍ مَّعْلُوْمٍ وَاِنْ : اور نہیں مِّنْ شَيْءٍ : کوئی چیز اِلَّا : مگر عِنْدَنَا : ہمارے پاس خَزَآئِنُهٗ : اس کے خزانے وَمَا : اور نہیں نُنَزِّلُهٗٓ : ہم اس کو اتارتے اِلَّا : مگر بِقَدَرٍ : اندازہ سے مَّعْلُوْمٍ : معلوم۔ مناسب اور جتنی بھی چیزیں ہیں ان سب کے خزانے ہمارے پاس ہیں (1) اور ہم ہر چیز کو اس کے مقررہ انداز سے اتارتے ہیں۔
15,22,وَ اَرْسَلْنَا الرِّیٰحَ لَوَاقِحَ فَاَنْزَلْنَا مِنَ السَّمَآءِ مَآءً فَاَسْقَیْنٰكُمُوْهُ١ۚ وَ مَاۤ اَنْتُمْ لَهٗ بِخٰزِنِیْنَ وَاَرْسَلْنَا : اور ہم نے بھیجیں الرِّيٰحَ : ہوائیں لَوَاقِحَ : بھری ہوئی فَاَنْزَلْنَا : پھر ہم نے اتارا مِنَ : سے السَّمَآءِ : آسمان مَآءً : پانی فَاَسْقَيْنٰكُمُوْهُ : پھر ہم نے وہ تمہیں پلایا وَمَآ : اور نہیں اَنْتُمْ : تم لَهٗ : اس کے بِخٰزِنِيْنَ : خزانہ کرنے والے اور ہم بھیجتے ہیں بوجھل ہوائیں (1) پھر آسمان سے پانی برسا کر وہ تمہیں پلاتے ہیں اور تم اس کا ذخیرہ کرنے والے نہیں ہو (2)۔
15,23,وَ اِنَّا لَنَحْنُ نُحْیٖ وَ نُمِیْتُ وَ نَحْنُ الْوٰرِثُوْنَ وَاِنَّا : اور بیشک ہم لَنَحْنُ : البتہ ہم نُحْيٖ : زندگی دیتے ہیں وَنُمِيْتُ : اور ہم مارتے ہیں وَنَحْنُ : اور ہم الْوٰرِثُوْنَ : وارث (جمع) ہم ہی جلاتے اور مارتے ہیں اور ہم ہی (بالآخر) وارث ہیں۔
15,24,وَ لَقَدْ عَلِمْنَا الْمُسْتَقْدِمِیْنَ مِنْكُمْ وَ لَقَدْ عَلِمْنَا الْمُسْتَاْخِرِیْنَ وَلَقَدْ عَلِمْنَا : اور تحقیق ہمیں معلوم ہیں الْمُسْتَقْدِمِيْنَ : آگے گزرنے والے مِنْكُمْ : تم میں سے وَلَقَدْ عَلِمْنَا : اور تحقیق ہمیں معلوم ہیں الْمُسْتَاْخِرِيْنَ : پیچھے رہ جانے والے اور تم میں سے آگے بڑھنے والے اور پیچھے ہٹنے والے بھی ہمارے علم میں ہیں۔
15,25,وَ اِنَّ رَبَّكَ هُوَ یَحْشُرُهُمْ١ؕ اِنَّهٗ حَكِیْمٌ عَلِیْمٌ۠    ۧ وَاِنَّ : اور بیشک رَبَّكَ : تیرا رب هُوَ : وہ يَحْشُرُهُمْ : انہیں جمع کرے گا اِنَّهٗ : بیشک وہ حَكِيْمٌ : حکمت والا عَلِيْمٌ : علم والا آپ کا رب سب لوگوں کو جمع کرے گا یقیناً وہ بڑی حکمتوں والا ہے۔
15,26,وَ لَقَدْ خَلَقْنَا الْاِنْسَانَ مِنْ صَلْصَالٍ مِّنْ حَمَاٍ مَّسْنُوْنٍۚ وَلَقَدْ خَلَقْنَا : اور تحقیق ہم نے پیدا کیا الْاِنْسَانَ : انسان مِنْ : سے صَلْصَالٍ : کھنکھناتا ہوا مِّنْ حَمَاٍ : سیاہ گارے سے مَّسْنُوْنٍ : سڑا ہوا یقیناً ہم نے انسان کو کالی اور سڑی ہوئی کھنکھناتی مٹی سے، پیدا فرمایا ہے (1)۔
15,27,وَ الْجَآنَّ خَلَقْنٰهُ مِنْ قَبْلُ مِنْ نَّارِ السَّمُوْمِ وَالْجَآنَّ : اور جن (جمع) خَلَقْنٰهُ : ہم نے اسے پیدا کیا مِنْ قَبْلُ : اس سے پہلے مِنْ : سے نَّارِ السَّمُوْمِ : آگ بےدھوئیں کی اس سے پہلے جنات کو ہم نے لو والی آگ (1) سے پیدا کیا۔
15,28,وَ اِذْ قَالَ رَبُّكَ لِلْمَلٰٓئِكَةِ اِنِّیْ خَالِقٌۢ بَشَرًا مِّنْ صَلْصَالٍ مِّنْ حَمَاٍ مَّسْنُوْنٍ وَاِذْ : اور جب قَالَ : کہا رَبُّكَ : تیرا رب لِلْمَلٰٓئِكَةِ : فرشتوں کو اِنِّىْ : بیشک میں خَالِقٌ : بنانے والا بَشَرًا : انسان مِّنْ : سے صَلْصَالٍ : کھنکھناتا ہوا مِّنْ : سے حَمَاٍ : سیاہ گارا مَّسْنُوْنٍ : سڑا ہوا اور جب تیرے پروردگار نے فرشتوں سے فرمایا کہ میں ایک انسان کو کالی اور سڑی ہوئی کھنکھناتی مٹی سے پیدا کرنے والا ہوں۔
15,29,فَاِذَا سَوَّیْتُهٗ وَ نَفَخْتُ فِیْهِ مِنْ رُّوْحِیْ فَقَعُوْا لَهٗ سٰجِدِیْنَ فَاِذَا : پھر جب سَوَّيْتُهٗ : میں اسے درست کرلوں وَنَفَخْتُ : اور پھونکوں فِيْهِ : اس میں مِنْ رُّوْحِيْ : اپنی روح سے فَقَعُوْا : تو گر پڑو تم لَهٗ : اس کے لیے سٰجِدِيْنَ : سجدہ کرتے ہوئے تو جب میں اسے پورا بنا چکوں اور اس میں میں اپنی روح پھونک دوں تو تم سب اس کے لئے سجدے میں گرپڑنا (1)۔
15,30,فَسَجَدَ الْمَلٰٓئِكَةُ كُلُّهُمْ اَجْمَعُوْنَۙ فَسَجَدَ : پس سجدہ کیا الْمَلٰٓئِكَةُ : فرشتوں (جمع) كُلُّهُمْ : وہ سب اَجْمَعُوْنَ : سب کے سب چناچہ تمام فرشتوں نے سب کے سب نے سجدہ کرلیا۔
15,31,اِلَّاۤ اِبْلِیْسَ١ؕ اَبٰۤى اَنْ یَّكُوْنَ مَعَ السّٰجِدِیْنَ اِلَّآ : سوائے اِبْلِيْسَ : ابلیس اَبٰٓى : اس نے انکار کیا اَنْ : کہ يَّكُوْنَ : وہ ہو مَعَ : ساتھ السّٰجِدِيْنَ : سجدہ کرنے والے مگر ابلیس کے، کہ اس نے سجدہ کرنے والوں میں شمولیت کرنے سے صاف انکار کردیا۔
15,32,قَالَ یٰۤاِبْلِیْسُ مَا لَكَ اَلَّا تَكُوْنَ مَعَ السّٰجِدِیْنَ قَالَ : اس نے فرمایا يٰٓاِبْلِيْسُ : اے ابلیس مَا لَكَ : تجھے کیا ہوا اَلَّا تَكُوْنَ : کہ تو نہ ہوا مَعَ : ساتھ السّٰجِدِيْنَ : سجدہ کرنے والے (اللہ تعالیٰ نے) فرمایا اے ابلیس تجھے کیا ہوا کہ تو سجدہ کرنے والوں میں شامل نہ ہوا ؟
15,33,قَالَ لَمْ اَكُنْ لِّاَسْجُدَ لِبَشَرٍ خَلَقْتَهٗ مِنْ صَلْصَالٍ مِّنْ حَمَاٍ مَّسْنُوْنٍ قَالَ : اس نے کہا لَمْ اَكُنْ : میں نہیں ہوں لِّاَسْجُدَ : کہ سجدہ کروں لِبَشَرٍ : انسان کو خَلَقْتَهٗ : تو نے اس کو پیدا کیا مِنْ : سے صَلْصَالٍ : کھکھناتا ہوا مِّنْ : سے حَمَاٍ : سیاہ گارا مَّسْنُوْنٍ : سڑا ہوا وہ بولا کہ میں ایسا نہیں کہ اس انسان کو سجدہ کروں جسے تو نے کالی اور سڑی ہوئی کھنکھناتی مٹی سے پیدا کیا ہے (1)۔
15,34,قَالَ فَاخْرُجْ مِنْهَا فَاِنَّكَ رَجِیْمٌۙ قَالَ : اس نے کہا فَاخْرُجْ : پس نکل جا مِنْهَا : یہاں سے فَاِنَّكَ : بیشک تو رَجِيْمٌ : مردود فرمایا اب تو بہشت سے نکل جا کیونکہ تو راندہ درگاہ ہے۔
15,35,وَّ اِنَّ عَلَیْكَ اللَّعْنَةَ اِلٰى یَوْمِ الدِّیْنِ وَّاِنَّ : اور بیشک عَلَيْكَ : تجھ پر اللَّعْنَةَ : لعنت اِلٰى : تک يَوْمِ الدِّيْنِ : روز انصاف تجھ پر میری پھٹکار ہے قیامت کے دن تک۔
15,36,قَالَ رَبِّ فَاَنْظِرْنِیْۤ اِلٰى یَوْمِ یُبْعَثُوْنَ قَالَ : اس نے کہا رَبِّ : اے میرے رب فَاَنْظِرْنِيْٓ : تو مجھے مہلت دے اِلٰى : تک يَوْمِ يُبْعَثُوْنَ : جس دن (مردے) اٹھائے جائیں کہنے لگا میرے رب ! مجھے اس دن تک کی ڈھیل دے کہ لوگ دوبارہ اٹھ کھڑے کیئے جائیں۔
15,37,قَالَ فَاِنَّكَ مِنَ الْمُنْظَرِیْنَۙ قَالَ : اس نے کہا فَاِنَّكَ : بیشک تو مِنَ : سے الْمُنْظَرِيْنَ : مہلت دئیے جانے والے فرمایا کہ اچھا تو ان میں سے ہے جنہیں مہلت ملی ہے۔
15,38,اِلٰى یَوْمِ الْوَقْتِ الْمَعْلُوْمِ اِلٰى : تک يَوْمِ : دن الْوَقْتِ : وقت الْمَعْلُوْمِ : معلوم (مقرر) روز مقرر کے وقت تک۔
15,39,قَالَ رَبِّ بِمَاۤ اَغْوَیْتَنِیْ لَاُزَیِّنَنَّ لَهُمْ فِی الْاَرْضِ وَ لَاُغْوِیَنَّهُمْ اَجْمَعِیْنَۙ قَالَ : اس نے کہا رَبِّ : اے میرے رب بِمَآ : جیسا کہ اَغْوَيْتَنِيْ : تونے مجھے گمراہ کیا لَاُزَيِّنَنَّ : تو میں ضرور آراستہ کروں گا لَهُمْ : ان کے لیے فِي الْاَرْضِ : زمین میں وَلَاُغْوِيَنَّهُمْ : اور میں ضرور گمراہ کروں گا ان کو اَجْمَعِيْنَ : سب (شیطان نے) کہا اے میرے رب ! چونکہ تو نے مجھے گمراہ کیا ہے مجھے بھی قسم ہے کہ میں بھی زمین میں ان کے لئے معاصی کو مزین کروں گا اور ان سب کو بہکاؤں گا بھی۔
15,40,اِلَّا عِبَادَكَ مِنْهُمُ الْمُخْلَصِیْنَ اِلَّا : سوائے عِبَادَكَ : تیرے بندے مِنْهُمُ : ان میں سے الْمُخْلَصِيْنَ : مخلص (جمع) سوائے تیرے ان بندوں کے جو منتخب کرلئے گئے ہیں۔
15,41,قَالَ هٰذَا صِرَاطٌ عَلَیَّ مُسْتَقِیْمٌ قَالَ : اس نے کہا ھٰذَا : یہ صِرَاطٌ : راستہ عَلَيَّ : مجھ تک مُسْتَقِيْمٌ : سیدھا ارشاد ہوا کہ ہاں یہی مجھ تک پہنچنے کی سیدھی راہ ہے (1)
15,42,اِنَّ عِبَادِیْ لَیْسَ لَكَ عَلَیْهِمْ سُلْطٰنٌ اِلَّا مَنِ اتَّبَعَكَ مِنَ الْغٰوِیْنَ اِنَّ : بیشک عِبَادِيْ : میرے بندے لَيْسَ : نہیں لَكَ : تیرے لیے (تیرا) عَلَيْهِمْ : ان پر سُلْطٰنٌ : کوئی زور اِلَّا : مگر مَنِ : جو۔ جس اتَّبَعَكَ : تیری پیروی کی مِنَ : سے الْغٰوِيْنَ : بہکے ہوئے (گمراہ) میرے بندوں پر تجھے کوئی غلبہ نہیں (1) لیکن ہاں جو گمراہ لوگ تیری پیروی کریں۔
15,43,وَ اِنَّ جَهَنَّمَ لَمَوْعِدُهُمْ اَجْمَعِیْنَ۫ۙ وَاِنَّ : اور بیشک جَهَنَّمَ : جہنم لَمَوْعِدُهُمْ : ان کے لیے وعدہ گاہ اَجْمَعِيْنَ : سب یقیناً سب کے وعدے کی جگہ جہنم ہے (1)
15,44,لَهَا سَبْعَةُ اَبْوَابٍ١ؕ لِكُلِّ بَابٍ مِّنْهُمْ جُزْءٌ مَّقْسُوْمٌ۠    ۧ لَهَا : اس کے لیے سَبْعَةُ : سات اَبْوَابٍ : دروازے لِكُلِّ بَابٍ : ہر دروازہ کے لیے مِّنْهُمْ : ان سے جُزْءٌ : ایک حصہ مَّقْسُوْمٌ : تقسیم شدہ جس کے سات دروازے ہیں۔ ہر دروازے کے لئے ان کا ایک حصہ بنا ہوا ہے (1)
15,45,اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ عُیُوْنٍؕ اِنَّ : بیشک الْمُتَّقِيْنَ : پرہیزگار فِيْ : میں جَنّٰتٍ : باغات وَّعُيُوْنٍ : اور چشمے پرہیزگار جنتی لوگ باغوں اور چشموں میں ہونگے (1)
15,46,اُدْخُلُوْهَا بِسَلٰمٍ اٰمِنِیْنَ اُدْخُلُوْهَا : تم ان میں داخل ہوجاؤ بِسَلٰمٍ : سلامتی کے ساتھ اٰمِنِيْنَ : بےخوف وخطر (ان سے کہا جائیگا) سلامتی اور امن کے ساتھ اس میں داخل ہوجاؤ۔
15,47,وَ نَزَعْنَا مَا فِیْ صُدُوْرِهِمْ مِّنْ غِلٍّ اِخْوَانًا عَلٰى سُرُرٍ مُّتَقٰبِلِیْنَ وَنَزَعْنَا : اور ہم نے کھینچ لیا مَا : جو فِيْ : میں صُدُوْرِهِمْ : ان کے سینے مِّنْ : سے غِلٍّ : کینہ اِخْوَانًا : بھائی بھائی عَلٰي : پر سُرُرٍ : تخت (جمع) مُّتَقٰبِلِيْنَ : آمنے سامنے ان کے دلوں میں جو کچھ رنجش و کینہ تھا، ہم سب کچھ نکال دیں گے (1) وہ بھائی بھائی بنے ہوئے ایک دوسرے کے آمنے سامنے تختوں پر بیٹھے ہونگے۔
15,48,لَا یَمَسُّهُمْ فِیْهَا نَصَبٌ وَّ مَا هُمْ مِّنْهَا بِمُخْرَجِیْنَ لَا يَمَسُّهُمْ : انہیں نہ چھوئے گی فِيْهَا : اس میں نَصَبٌ : کوئی تکلیف وَّمَا : اور نہ هُمْ : وہ مِّنْهَا : اس سے بِمُخْرَجِيْنَ : نکالے جائیں گے نہ تو وہاں انھیں کوئی تکلیف چھو سکتی ہے اور نہ وہاں سے کبھی نکالے جائیں گے۔
15,49,نَبِّئْ عِبَادِیْۤ اَنِّیْۤ اَنَا الْغَفُوْرُ الرَّحِیْمُۙ نَبِّئْ : خبر دیدو عِبَادِيْٓ : میرے بندے اَنِّىْٓ : کہ بیشک اَنَا : میں الْغَفُوْرُ : بخشنے والا الرَّحِيْمُ : نہایت مہربان میرے بندوں کو خبر دے دو کہ میں بہت ہی بخشنے والا اور بڑا مہربان ہوں۔
15,50,وَ اَنَّ عَذَابِیْ هُوَ الْعَذَابُ الْاَلِیْمُ وَاَنَّ : اور یہ کہ عَذَابِيْ : میرا عذاب هُوَ : وہ (ہی) الْعَذَابُ : عذاب الْاَلِيْمُ : دردناک ساتھ ہی میرے عذاب بھی نہایت دردناک ہیں۔
15,51,وَ نَبِّئْهُمْ عَنْ ضَیْفِ اِبْرٰهِیْمَۘ وَنَبِّئْهُمْ : اور انہیں خبر دو (سنا دو ) عَنْ : سے۔ کا ضَيْفِ : مہمان اِبْرٰهِيْمَ : ابراہیم انہیں ابراہیم کے مہمانوں کا (بھی) حال سنادو۔
15,52,اِذْ دَخَلُوْا عَلَیْهِ فَقَالُوْا سَلٰمًا١ؕ قَالَ اِنَّا مِنْكُمْ وَ جِلُوْنَ اِذْ : جب دَخَلُوْا : وہ داخل ہوئے ( آئے) عَلَيْهِ : اس پر (پاس) فَقَالُوْا : تو انہوں نے کہا سَلٰمًا : سلام قَالَ : اس نے کہا اِنَّا : بیشک ہم مِنْكُمْ : تم سے وَجِلُوْنَ : ڈرنے والے (ڈرتے) ہیں کہ جب انہوں نے ان کے پاس آکر سلام کہا تو انہوں نے کہا کہ ہم کو تو ڈر لگتا ہے (1)
15,53,قَالُوْا لَا تَوْجَلْ اِنَّا نُبَشِّرُكَ بِغُلٰمٍ عَلِیْمٍ قَالُوْا : انہوں نے کہا لَا تَوْجَلْ : ڈرو نہیں اِنَّا نُبَشِّرُكَ : بیشک ہم تمہیں خوشخبری دیتے ہیں بِغُلٰمٍ : ایک لڑکا عَلِيْمٍ : علم والا انہوں نے کہا ڈرو نہیں، ہم تجھے ایک صاحب علم فرزند کی بشارت دیتے ہیں۔
15,54,قَالَ اَبَشَّرْتُمُوْنِیْ عَلٰۤى اَنْ مَّسَّنِیَ الْكِبَرُ فَبِمَ تُبَشِّرُوْنَ قَالَ : اس نے کہا اَبَشَّرْتُمُوْنِيْ : کیا تم مجھے خوشخبری دیتے ہو عَلٰٓي : پر۔ میں اَنْ : کہ مَّسَّنِيَ : مجھے پہنچ گیا الْكِبَرُ : بڑھاپا فَبِمَ : سو کس بات تُبَشِّرُوْنَ : تم خوشخبری دیتے ہو کہا، کیا اس بڑھاپے کے آجانے کے بعد تم مجھے خوشخبری دیتے ہو ! یہ خوشخبری تم کیسے دے رہے ہو ؟
15,55,قَالُوْا بَشَّرْنٰكَ بِالْحَقِّ فَلَا تَكُنْ مِّنَ الْقٰنِطِیْنَ قَالُوْا : وہ بولے بَشَّرْنٰكَ : ہم نے تمہیں خوشخبری دی بِالْحَقِّ : سچائی کے ساتھ فَلَا تَكُنْ : آپ نہ ہوں مِّنَ : سے الْقٰنِطِيْنَ : مایوس ہونے والے انہوں نے کہا ہم آپ کو بالکل سچی خوشخبری سناتے ہیں آپ مایوس لوگوں میں شامل نہ ہوں (1)۔
15,56,قَالَ وَ مَنْ یَّقْنَطُ مِنْ رَّحْمَةِ رَبِّهٖۤ اِلَّا الضَّآلُّوْنَ قَالَ : اس نے کہا وَمَنْ : اور کون يَّقْنَطُ : مایوس ہوگا مِنْ : سے رَّحْمَةِ : رحمت رَبِّهٖٓ : اپنا رب اِلَّا : سوائے الضَّآلُّوْنَ : گمراہ (جمع) کہا اپنے رب تعالیٰ کی رحمت سے ناامید تو صرف گمراہ اور بہکے ہوئے لوگ ہی ہوتے ہیں (1)۔
15,57,قَالَ فَمَا خَطْبُكُمْ اَیُّهَا الْمُرْسَلُوْنَ قَالَ : اس نے کہا فَمَا خَطْبُكُمْ : پس کیا ہے تمہارا کام (مہم) اَيُّهَا : اے الْمُرْسَلُوْنَ : بھیجے ہوئے (فرشتو) پوچھا کہ اللہ کے بھیجے ہوئے (فرشتو) تمہارا ایسا کیا اہم کام ہے ؟ (1)
15,58,قَالُوْۤا اِنَّاۤ اُرْسِلْنَاۤ اِلٰى قَوْمٍ مُّجْرِمِیْنَۙ قَالُوْٓا : وہ بولے اِنَّآ : ہم بیشک اُرْسِلْنَآ : بھیجے گئے اِلٰى : طرف قَوْمٍ : ایک قوم مُّجْرِمِيْنَ : مجرم (جمع) انہوں نے جواب دیا کہ ہم مجرم قوم کی طرف بھیجے گئے ہیں۔
15,59,اِلَّاۤ اٰلَ لُوْطٍ١ؕ اِنَّا لَمُنَجُّوْهُمْ اَجْمَعِیْنَۙ اِلَّآ : سوائے اٰلَ لُوْطٍ : گھر والے لوط کے اِنَّا : ہم لَمُنَجُّوْهُمْ : البتہ ہم انہیں بچا لیں گے اَجْمَعِيْنَ : سب مگر خاندان لوط کہ ہم ان سب کو ضرور بچالیں گے
15,60,اِلَّا امْرَاَتَهٗ قَدَّرْنَاۤ١ۙ اِنَّهَا لَمِنَ الْغٰبِرِیْنَ۠    ۧ اِلَّا : سوائے امْرَاَتَهٗ : اس کی عورت قَدَّرْنَآ : ہم نے فیصلہ کرلیا ہے اِنَّهَا : بیشک وہ لَمِنَ : سے الْغٰبِرِيْنَ : پیچھے رہ جانے والے سوائے اس (لوط) کی بیوی کے کہ ہم نے اسے رکنے اور باقی رہ جانے والوں میں مقرر کردیا ہے۔
15,61,فَلَمَّا جَآءَ اٰلَ لُوْطِ اِ۟لْمُرْسَلُوْنَۙ فَلَمَّا : پس جب جَآءَ : آئے اٰلَ لُوْطِ : لوط کے گھر والے الْمُرْسَلُوْنَ : بھیجے ہوئے (فرشتے) جب بھیجے ہوئے فرشتے آل لوط کے پاس پہنچے۔
15,62,قَالَ اِنَّكُمْ قَوْمٌ مُّنْكَرُوْنَ قَالَ : س نے کہا اِنَّكُمْ : بیشک تم قَوْمٌ : لوگ مُّنْكَرُوْنَ : اوپرے (نا آشنا) تو انہوں (لوط علیہ السلام) نے کہا تم لوگ تو کچھ انجان سے معلوم ہو رہے ہو (1)۔
15,63,قَالُوْا بَلْ جِئْنٰكَ بِمَا كَانُوْا فِیْهِ یَمْتَرُوْنَ قَالُوْا : وہ بولے بَلْ : بلکہ جِئْنٰكَ : ہم آئے ہیں تمہارے پاس بِمَا : اس کے ساتھ جو كَانُوْا : وہ تھے فِيْهِ : اس میں يَمْتَرُوْنَ : شک کرتے انہوں نے کہا نہیں بلکہ ہم تیرے پاس وہ چیز لائے ہیں جس میں یہ لوگ شک شبہ کر رہے تھے (1)۔
15,64,وَ اَتَیْنٰكَ بِالْحَقِّ وَ اِنَّا لَصٰدِقُوْنَ وَاَتَيْنٰكَ : اور ہم تمہارے پاس آئے ہیں بِالْحَقِّ : حق کے ساتھ وَاِنَّا : اور ہم بیشک لَصٰدِقُوْنَ : البتہ سچے ہم تیرے پاس (صریح) حق لائے ہیں اور ہیں بھی بالکل سچے (1)۔
15,65,فَاَسْرِ بِاَهْلِكَ بِقِطْعٍ مِّنَ الَّیْلِ وَ اتَّبِعْ اَدْبَارَهُمْ وَ لَا یَلْتَفِتْ مِنْكُمْ اَحَدٌ وَّ امْضُوْا حَیْثُ تُؤْمَرُوْنَ فَاَسْرِ : پس لے نکلیں آپ بِاَهْلِكَ : اپنے گھر والوں کو بِقِطْعٍ : ایک حصہ مِّنَ : سے الَّيْلِ : رات وَاتَّبِعْ : اور خود چلیں اَدْبَارَهُمْ : ان کے پیچھے وَلَا : اور نہ يَلْتَفِتْ : پیچھے مڑ کر دیکھے مِنْكُمْ : تم میں سے اَحَدٌ : کوئی وَّامْضُوْا : اور چلے جاؤ حَيْثُ : جیسے تُؤْمَرُوْنَ : تمہیں حکم دیا گیا اب تو اپنے خاندان سمیت اس رات کے کسی حصہ میں چل دے اور آپ ان کے پیچھے رہنا (1) اور (خبردار) تم میں سے (پیچھے) مڑ کر بھی نہ دیکھے اور جہاں کا تمہیں حکم کیا جا رہا ہے وہاں چلے جانا۔
15,66,وَ قَضَیْنَاۤ اِلَیْهِ ذٰلِكَ الْاَمْرَ اَنَّ دَابِرَ هٰۤؤُلَآءِ مَقْطُوْعٌ مُّصْبِحِیْنَ وَقَضَيْنَآ : اور ہم نے فیصلہ بھیجا اِلَيْهِ : اس کی طرف ذٰلِكَ : اس الْاَمْرَ : بات اَنَّ : کہ دَابِرَ : جڑ هٰٓؤُلَآءِ : یہ لوگ مَقْطُوْعٌ : کٹی ہوئی مُّصْبِحِيْنَ : صبح ہوتے ہم نے اس کی طرف اس بات کا فیصلہ کردیا کہ صبح ہوتے ہوتے ان لوگوں کی جڑیں کاٹ دیجائیں گی (1)۔
15,67,وَ جَآءَ اَهْلُ الْمَدِیْنَةِ یَسْتَبْشِرُوْنَ وَجَآءَ : اور آئے اَهْلُ الْمَدِيْنَةِ : شہر والے يَسْتَبْشِرُوْنَ : خوشیاں مناتے اور شہر والے خوشیاں مناتے ہوئے آئے (1)۔
15,68,قَالَ اِنَّ هٰۤؤُلَآءِ ضَیْفِیْ فَلَا تَفْضَحُوْنِۙ قَالَ : اس نے کہا اِنَّ : کہ هٰٓؤُلَآءِ : یہ لوگ ضَيْفِيْ : میرے مہمان فَلَا تَفْضَحُوْنِ : پس مجھے رسوا نہ کرو تم (لوط ؑ نے) کہا یہ لوگ میرے مہمان ہیں تم مجھے رسوا نہ کرو (1)۔
15,69,وَ اتَّقُوا اللّٰهَ وَ لَا تُخْزُوْنِ وَاتَّقُوا : اور ڈرو اللّٰهَ : اللہ وَلَا تُخْزُوْنِ : اور مجھے خوار نہ کرو اللہ تعالیٰ سے ڈرو اور مجھے رسوا نہ کرو۔
15,70,قَالُوْۤا اَوَ لَمْ نَنْهَكَ عَنِ الْعٰلَمِیْنَ قَالُوْٓا : وہ بولے اَوَ : کیا لَمْ نَنْهَكَ : ہم نے تجھے منع نہیں کیا عَنِ : سے الْعٰلَمِيْنَ : سارے جہان وہ بولے کیا ہم نے تجھے دنیا بھر (کی ٹھیکیداری) سے منع نہیں کر رکھا ؟ (1)۔
15,71,قَالَ هٰۤؤُلَآءِ بَنٰتِیْۤ اِنْ كُنْتُمْ فٰعِلِیْنَؕ قَالَ : اس نے کہا هٰٓؤُلَآءِ : یہ بَنٰتِيْٓ : میری بیٹیاں اِنْ : اگر كُنْتُمْ : تم ہو فٰعِلِيْنَ : کرنیوالے (کرنا ہے) (لوط ؑ نے) کہا اگر تمہیں کرنا ہی ہے تو یہ میری بچیاں موجود ہیں (1)۔
15,72,لَعَمْرُكَ اِنَّهُمْ لَفِیْ سَكْرَتِهِمْ یَعْمَهُوْنَ لَعَمْرُكَ : تمہاری جان کی قسم اِنَّهُمْ : بیشک وہ لَفِيْ : البتہ میں سَكْرَتِهِمْ : اپنے نشہ يَعْمَهُوْنَ : مدہوش تھے تیری عمر کی قسم ! وہ تو اپنی بد مستی میں سرگرداں تھے (1)۔
15,73,فَاَخَذَتْهُمُ الصَّیْحَةُ مُشْرِقِیْنَۙ فَاَخَذَتْهُمُ : پس انہیں آلیا الصَّيْحَةُ : چنگھاڑ مُشْرِقِيْنَ : سورج پس سورج نکلتے نکلتے انھیں ایک بڑے زور کی آواز نے پکڑ لیا (1)۔
15,74,فَجَعَلْنَا عَالِیَهَا سَافِلَهَا وَ اَمْطَرْنَا عَلَیْهِمْ حِجَارَةً مِّنْ سِجِّیْلٍؕ فَجَعَلْنَا : پم ہم نے کردیا عَالِيَهَا : اس کے اوپر کا حصہ سَافِلَهَا : اس کے نیچے کا حصہ وَاَمْطَرْنَا : اور ہم نے برسائے عَلَيْهِمْ : ان پر حِجَارَةً : پتھر مِّنْ : سے سِجِّيْلٍ : سنگ گل (کھنگر) بالآخر ہم نے اس شہر کو اوپر تلے کردیا (1) اور ان لوگوں پر کنکر والے پتھر (2) برسائے۔
15,75,اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّلْمُتَوَسِّمِیْنَ اِنَّ : بیشک فِيْ : میں ذٰلِكَ : اس لَاٰيٰتٍ : نشانیاں لِّلْمُتَوَسِّمِيْنَ : غور وفکر کرنے والوں کے لیے بلاشبہ بصیرت والوں کے لئے (1) اس میں بہت سی نشانیاں ہیں۔
15,76,وَ اِنَّهَا لَبِسَبِیْلٍ مُّقِیْمٍ وَاِنَّهَا : اور بیشک وہ لَبِسَبِيْلٍ : راستہ پر مُّقِيْمٍ : سیدھا یہ بستی راہ پر ہے جو برابر چلتی رہتی (عام گزرگاہ) ہے (1)۔
15,77,اِنَّ فِیْ ذٰلِكَ لَاٰیَةً لِّلْمُؤْمِنِیْنَؕ اِنَّ : بیشک فِيْ : میں ذٰلِكَ : اس لَاٰيَةً : نشانی لِّلْمُؤْمِنِيْنَ : ایمان والوں کے لیے اور اس میں ایمان داروں کے لئے بڑی نشانی ہے۔
15,78,وَ اِنْ كَانَ اَصْحٰبُ الْاَیْكَةِ لَظٰلِمِیْنَۙ وَاِنْ : اور تحقیق كَانَ : تھے اَصْحٰبُ الْاَيْكَةِ : ایکہ (بن) والے (قوم شعیب) لَظٰلِمِيْنَ : ظالم (جمع) ایک بستی کے رہنے والے بھی بڑے ظالم تھے (1)
15,79,فَانْتَقَمْنَا مِنْهُمْ١ۘ وَ اِنَّهُمَا لَبِاِمَامٍ مُّبِیْنٍؕ۠    ۧ فَانْتَقَمْنَا : ہم نے بدلہ لیا مِنْهُمْ : ان سے وَاِنَّهُمَا : اور بیشک وہ دونوں لَبِاِمَامٍ : راستہ پر مُّبِيْنٍ : کھلے جن سے (آخر) ہم نے انتقام لے ہی لیا۔ یہ دونوں شہر کھلے (عام) راستے پر ہیں (1)
15,80,وَ لَقَدْ كَذَّبَ اَصْحٰبُ الْحِجْرِ الْمُرْسَلِیْنَۙ وَلَقَدْ كَذَّبَ : اور البتہ جھٹلایا اَصْحٰبُ الْحِجْرِ : حجر والے الْمُرْسَلِيْنَ : رسول (جمع) اور حجر والوں نے بھی رسولوں کو جھٹلایا (1)
15,81,وَ اٰتَیْنٰهُمْ اٰیٰتِنَا فَكَانُوْا عَنْهَا مُعْرِضِیْنَۙ وَاٰتَيْنٰهُمْ : اور ہم نے انہیں دیں اٰيٰتِنَا : اپنی نشانیاں فَكَانُوْا : پس وہ تھے عَنْهَا : اس سے مُعْرِضِيْنَ : منہ پھیرنے والے اور ہم نے اپنی نشانیاں بھی عطا فرمائیں (لیکن) تاہم وہ ان سے روگردانی ہی کرتے رہے (1)۔
15,82,وَ كَانُوْا یَنْحِتُوْنَ مِنَ الْجِبَالِ بُیُوْتًا اٰمِنِیْنَ وَكَانُوْا يَنْحِتُوْنَ : اور وہ تراشتے تھے مِنَ : سے الْجِبَالِ : پہاڑ (جمع) بُيُوْتًا : گھر اٰمِنِيْنَ : بےخوف وخطر یہ لوگ پہاڑوں کو تراش کر گھر بناتے تھے، بےخوف ہو کر (1)۔
15,83,فَاَخَذَتْهُمُ الصَّیْحَةُ مُصْبِحِیْنَۙ فَاَخَذَتْهُمُ : پس انہیں آلیا الصَّيْحَةُ : چنگھاڑ مُصْبِحِيْنَ : صبح ہوتے آخر انھیں بھی صبح ہوتے ہوتے چنگھاڑ نے آدبوچا (1)۔
15,84,فَمَاۤ اَغْنٰى عَنْهُمْ مَّا كَانُوْا یَكْسِبُوْنَؕ فَمَآ اَغْنٰى : تو نہ کام آیا عَنْهُمْ : ان کے مَّا : جو كَانُوْا يَكْسِبُوْنَ : وہ کمایا کرتے تھے پس ان کی کسی تدبیر و عمل نے انھیں کوئی فائدہ نہ دیا۔
15,85,وَ مَا خَلَقْنَا السَّمٰوٰتِ وَ الْاَرْضَ وَ مَا بَیْنَهُمَاۤ اِلَّا بِالْحَقِّ١ؕ وَ اِنَّ السَّاعَةَ لَاٰتِیَةٌ فَاصْفَحِ الصَّفْحَ الْجَمِیْلَ وَمَا : اور نہیں خَلَقْنَا : پیدا کیا ہم نے السَّمٰوٰتِ : آسمان (جمع) وَالْاَرْضَ : اور زمین وَمَا : اور جو بَيْنَهُمَآ : ان کے درمیان اِلَّا : مگر بِالْحَقِّ : حق کے ساتھ وَاِنَّ : اور بیشک السَّاعَةَ : قیامت لَاٰتِيَةٌ : ضرور آنیوالی فَاصْفَحِ : پس درگزر کرو الصَّفْحَ : درگزر کرنا الْجَمِيْلَ : اچھا ہم نے آسمانوں اور زمین کو اور ان کے درمیان کی سب چیزوں کو حق کے ساتھ پیدا فرمایا ہے، (1) اور قیامت ضرور ضرور آنے والی ہے۔ پس تو حسن و خوبی (اور اچھائی) سے درگزر کرلے۔
15,86,اِنَّ رَبَّكَ هُوَ الْخَلّٰقُ الْعَلِیْمُ اِنَّ : بیشک رَبَّكَ : تمہارا رب هُوَ : وہ الْخَلّٰقُ : پیدا کرنے والا الْعَلِيْمُ : جاننے والا یقیناً تیرا پروردگار ہی پیدا کرنے والا اور جاننے والا ہے۔
15,87,وَ لَقَدْ اٰتَیْنٰكَ سَبْعًا مِّنَ الْمَثَانِیْ وَ الْقُرْاٰنَ الْعَظِیْمَ وَلَقَدْ : اور تحقیق اٰتَيْنٰكَ : ہم نے تمہیں دیں سَبْعًا : سات مِّنَ : سے الْمَثَانِيْ : بار بار دہرائی جانیوالی وَالْقُرْاٰنَ : اور قرآن الْعَظِيْمَ : عظمت والا یقیناً ہم نے سات آیتیں دے رکھی ہیں (1) کہ وہ دہرائی جاتی ہیں اور عظیم قرآن بھی دے رکھا ہے۔
15,88,لَا تَمُدَّنَّ عَیْنَیْكَ اِلٰى مَا مَتَّعْنَا بِهٖۤ اَزْوَاجًا مِّنْهُمْ وَ لَا تَحْزَنْ عَلَیْهِمْ وَ اخْفِضْ جَنَاحَكَ لِلْمُؤْمِنِیْنَ لَا تَمُدَّنَّ : ہرگز نہ بڑھائیں آپ عَيْنَيْكَ : اپنی آنکھیں اِلٰى : طرف مَا مَتَّعْنَا : جو ہم نے برتنے کو دیا بِهٖٓ : اس کو اَزْوَاجًا : کئی جوڑے مِّنْهُمْ : ان کے وَلَا تَحْزَنْ : اور نہ غم کھائیں عَلَيْهِمْ : ان پر وَاخْفِضْ : اور جھکا دیں آپ جَنَاحَكَ : اپنے بازو لِلْمُؤْمِنِيْنَ : مومنوں کے لیے آپ ہرگز اپنی نظریں اس چیز کی طرف نہ دوڑائیں، جس سے ہم نے ان میں سے کئی قسم کے لوگوں کو بہرہ مند کر رکھا ہے، نہ ان پر آپ افسوس کریں اور مومنوں کے لئے اپنے بازو جھکائے رہیں (1)۔
15,89,وَ قُلْ اِنِّیْۤ اَنَا النَّذِیْرُ الْمُبِیْنُۚ وَقُلْ : اور کہ دیں اِنِّىْٓ : بیشک میں اَنَا : میں النَّذِيْرُ الْمُبِيْنُ : ڈرانے والا علانیہ اور کہہ دیجئے کہ میں تو کھلم کھلا ڈرانے والا ہوں۔
15,90,كَمَاۤ اَنْزَلْنَا عَلَى الْمُقْتَسِمِیْنَۙ كَمَآ : جیسے اَنْزَلْنَا : ہم نے نازل کیا عَلَي : پر الْمُقْتَسِمِيْنَ : تقسیم کرنے والے جیسے کہ ہم نے ان تقسیم کرنے والوں پر اتارا (1)۔
15,91,الَّذِیْنَ جَعَلُوا الْقُرْاٰنَ عِضِیْنَ الَّذِيْنَ : وہ لوگ جو جَعَلُوا : انہوں نے کردیا الْقُرْاٰنَ : قرآن عِضِيْنَ : ٹکڑے ٹکڑے جنہوں نے اس کتاب الٰہی کے ٹکڑے ٹکڑے کردیئے
15,92,فَوَرَبِّكَ لَنَسْئَلَنَّهُمْ اَجْمَعِیْنَۙ فَوَرَبِّكَ : سو تیرے رب کی قسم لَنَسْئَلَنَّهُمْ : ہم ضرور پوچھیں گے ان سے اَجْمَعِيْنَ : سب قسم ہے تیرے پالنے والے کی ! ہم ان سب سے ضرور باز پرس کریں گے۔
15,93,عَمَّا كَانُوْا یَعْمَلُوْنَ عَمَّا : اس کی بابت جو كَانُوْا يَعْمَلُوْنَ : وہ کرتے تھے ہر چیز کی جو وہ کرتے تھے۔
15,94,فَاصْدَعْ بِمَا تُؤْمَرُ وَ اَعْرِضْ عَنِ الْمُشْرِكِیْنَ فَاصْدَعْ : پس صاف صاف کہہ دیں آپ بِمَا : جس کا تُؤْمَرُ : تمہیں حکم دیا گیا وَاَعْرِضْ : اور اعراض کریں عَنِ : سے الْمُشْرِكِيْنَ : مشرک (جمع) پس آپ (1) اس حکم کو جو آپ کو کیا جارہا ہے کھول کر سنا دیجئے اور مشرکوں سے منہ پھیر لیجئے۔
15,95,اِنَّا كَفَیْنٰكَ الْمُسْتَهْزِءِیْنَۙ اِنَّا : بیشک ہم كَفَيْنٰكَ : کافی ہیں تمہارے لیے الْمُسْتَهْزِءِيْنَ : مذاق اڑانے والے آپ سے جو لوگ مسخرا پن کرتے ہیں ان کی سزا کے لئے ہم کافی ہیں۔
15,96,الَّذِیْنَ یَجْعَلُوْنَ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ١ۚ فَسَوْفَ یَعْلَمُوْنَ الَّذِيْنَ : جو لوگ يَجْعَلُوْنَ : بناتے ہیں مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا : معبود اٰخَرَ : کوئی دوسرا فَسَوْفَ : پس عنقریب يَعْلَمُوْنَ : وہ جان لیں گے جو اللہ کے ساتھ دوسرے معبود مقرر کرتے ہیں انھیں عنقریب معلوم ہوجائے گا۔
15,97,وَ لَقَدْ نَعْلَمُ اَنَّكَ یَضِیْقُ صَدْرُكَ بِمَا یَقُوْلُوْنَۙ وَلَقَدْ نَعْلَمُ : اور البتہ ہم جانتے ہیں اَنَّكَ : بیشک تم يَضِيْقُ : تنگ ہوتا ہے صَدْرُكَ : تمہارا سینہ (دل) بِمَا : اس سے يَقُوْلُوْنَ : جو وہ کہتے ہیں ہمیں خوب علم ہے کہ ان باتوں سے آپ کا دل تنگ ہوتا ہے۔
15,98,فَسَبِّحْ بِحَمْدِ رَبِّكَ وَ كُنْ مِّنَ السّٰجِدِیْنَۙ فَسَبِّحْ : تو تسبیح کریں بِحَمْدِ : حمد کے ساتھ رَبِّكَ : اپنا رب وَكُنْ : اور ہو مِّنَ : سے السّٰجِدِيْنَ : سجدہ کرنے والے آپ اپنے پروردگار کی تسبیح اور حمد بیان کرتے رہیں اور سجدہ کرنے والوں میں شامل ہوجائیں۔
15,99,وَ اعْبُدْ رَبَّكَ حَتّٰى یَاْتِیَكَ الْیَقِیْنُ۠    ۧ وَاعْبُدْ : اور عبادت کریں رَبَّكَ : اپنا رب حَتّٰى : یہانتک کہ يَاْتِيَكَ : آئے آپ کے پاس الْيَقِيْنُ : یقینی بات اور اپنے رب کی عبادت کرتے رہیں یہاں تک کہ آپ کو موت آجائے (1)۔
