tafsir[8]{c,v,t}:
  12,23,وَ رَاوَدَتْهُ الَّتِیْ هُوَ فِیْ بَیْتِهَا عَنْ نَّفْسِهٖ وَ غَلَّقَتِ الْاَبْوَابَ وَ قَالَتْ هَیْتَ لَكَ١ؕ قَالَ مَعَاذَ اللّٰهِ اِنَّهٗ رَبِّیْۤ اَحْسَنَ مَثْوَایَ١ؕ اِنَّهٗ لَا یُفْلِحُ الظّٰلِمُوْنَ وَرَاوَدَتْهُ : اور اسے پھسلایا الَّتِيْ : وہ عورت جو هُوَ : اس فِيْ : میں بَيْتِهَا : اس کا گھر عَنْ نَّفْسِهٖ : اپنے آپ کو روکنے سے وَغَلَّقَتِ : اور بند کردئیے الْاَبْوَابَ : دروازے وَقَالَتْ : اور بولی هَيْتَ لَكَ : آ جا جلدی کر قَالَ : اس نے کہا مَعَاذَ اللّٰهِ : اللہ کی پناہ اِنَّهٗ : بیشک وہ رَبِّيْٓ : میرا مالک اَحْسَنَ : بہت اچھا مَثْوَايَ : اور رہنا سہنا اِنَّهٗ : بیشک لَا يُفْلِحُ : بھلائی نہیں پاتے الظّٰلِمُوْنَ : ظالم (جمع) اس عورت نے جس کے گھر میں یوسف تھے، یوسف کو بہلانا پھسلانا شروع کیا کہ وہ اپنے نفس کی نگرانی چھوڑ دے اور دروازہ بند کر کے کہنے لگی لو آجاؤ یوسف نے کہا اللہ کی پناہ ! وہ میرا رب، مجھے اس نے بہت اچھی طرح رکھا ہے۔ بےانصافی کرنے والوں کا بھلا نہیں ہوتا (1)۔
  12,24,وَ لَقَدْ هَمَّتْ بِهٖ١ۚ وَ هَمَّ بِهَا لَوْ لَاۤ اَنْ رَّاٰ بُرْهَانَ رَبِّهٖ١ؕ كَذٰلِكَ لِنَصْرِفَ عَنْهُ السُّوْٓءَ وَ الْفَحْشَآءَ١ؕ اِنَّهٗ مِنْ عِبَادِنَا الْمُخْلَصِیْنَ وَلَقَدْ هَمَّتْ : اور بیشک اس عورت نے ارادہ کیا بِهٖ : اس کا وَهَمَّ : اور وہ ارادہ کرتے بِهَا : اس کا لَوْلَآ : اگر نہ ہوتا اَنْ : کہ رَّاٰ : وہ دیکھے بُرْهَانَ : دلیل رَبِّهٖ : اپنا رب كَذٰلِكَ : اسی طرح لِنَصْرِفَ : ہم نے پھیر دیا عَنْهُ : اس سے السُّوْٓءَ : برائی وَالْفَحْشَآءَ : اور بےحیائی اِنَّهٗ : بیشک وہ مِنْ : سے عِبَادِنَا : ہمارے بندے الْمُخْلَصِيْنَ : برگزیدہ اس عورت نے یوسف کی طرف کا قصد کیا اور یوسف اس (1) کا قصد کرتے اگر وہ اپنے پروردگار کی دلیل نہ دیکھتے (2) یونہی ہوا کہ ہم اس سے برائی اور بےحیائی دور کردیں (3) بیشک وہ ہمارے چنے ہوئے بندوں میں سے تھا۔
  12,25,وَ اسْتَبَقَا الْبَابَ وَ قَدَّتْ قَمِیْصَهٗ مِنْ دُبُرٍ وَّ اَلْفَیَا سَیِّدَهَا لَدَا الْبَابِ١ؕ قَالَتْ مَا جَزَآءُ مَنْ اَرَادَ بِاَهْلِكَ سُوْٓءًا اِلَّاۤ اَنْ یُّسْجَنَ اَوْ عَذَابٌ اَلِیْمٌ وَاسْتَبَقَا : اور دونوں دوڑے الْبَابَ : دروازہ وَقَدَّتْ : اور عورت نے پھاڑ دی قَمِيْصَهٗ : اس کی قمیص مِنْ دُبُرٍ : پیچھے سے وَّاَلْفَيَا : اور دونوں کو ملا سَيِّدَهَا : عورت کا خاوند لَدَا الْبَابِ : دروازہ کے پاس قَالَتْ : وہ کہنے لگی مَا جَزَآءُ : کیا سزا مَنْ : جو۔ جس اَرَادَ : ارادہ کیا بِاَهْلِكَ : تیری بیوی سے سُوْٓءًا : برائی اِلَّآ : سوائے اَنْ : یہ کہ يُّسْجَنَ : قید کیا جائے اَوْ : یا عَذَابٌ اَلِيْمٌ : دردناک عذاب دونوں دروازے کی طرف دوڑے (1) اور اس عورت نے یوسف کا کرتا پیچھے کی طرف سے کھینچ کر پھاڑ ڈالا اور دروازے کے پاس اس کا شوہر دونوں کو مل گیا تو کہنے لگی جو شخص تیری بیوی کے ساتھ برا ارادہ کرے بس اس کی سزا یہی ہے کہ اسے قید کردیا جائے یا اور کوئی دردناک سزادی جائے (2)۔
  12,26,قَالَ هِیَ رَاوَدَتْنِیْ عَنْ نَّفْسِیْ وَ شَهِدَ شَاهِدٌ مِّنْ اَهْلِهَا١ۚ اِنْ كَانَ قَمِیْصُهٗ قُدَّ مِنْ قُبُلٍ فَصَدَقَتْ وَ هُوَ مِنَ الْكٰذِبِیْنَ قَالَ : اس نے کہا هِىَ : اس رَاوَدَتْنِيْ : مجھے پھسلایا عَنْ : سے نَّفْسِيْ : میرا نفس وَشَهِدَ : اور گواہی دی شَاهِدٌ : ایک گواہ مِّنْ : سے اَهْلِهَا : اس کے لوگ اِنْ : اگر كَانَ : ہے قَمِيْصُهٗ : اس کی قمیص قُدَّ : پھٹی ہوئی مِنْ قُبُلٍ : آگے سے فَصَدَقَتْ : تو وہ سچی وَهُوَ : اور وہ مِنَ : سے الْكٰذِبِيْنَ : جھوٹے یوسف نے کہا یہ عورت ہی مجھے پھسلا رہی تھی (1) اور عورت کے قبیلے کے ہی کے ایک شخص نے گواہی دی (2) کہ اگر اس کا کرتہ آگے سے پھٹا ہوا ہو تو عورت سچی ہے اور یوسف جھوٹ بو لنے والوں میں سے ہے۔
  12,27,وَ اِنْ كَانَ قَمِیْصُهٗ قُدَّ مِنْ دُبُرٍ فَكَذَبَتْ وَ هُوَ مِنَ الصّٰدِقِیْنَ وَاِنْ : اور اگر كَانَ : ہے قَمِيْصُهٗ : اس کی قمیص قُدَّ : پھٹی ہوئی مِنْ دُبُرٍ : پیچھے سے فَكَذَبَتْ : تو وہ جھوٹی وَهُوَ : اور وہ مِنَ : سے الصّٰدِقِيْنَ : سچے اور اگر اس کا کرتہ پیچھے کی جانب سے پھاڑا گیا ہے تو عورت جھوٹی ہے اور یوسف سچوں میں سے ہے۔
  12,28,فَلَمَّا رَاٰ قَمِیْصَهٗ قُدَّ مِنْ دُبُرٍ قَالَ اِنَّهٗ مِنْ كَیْدِكُنَّ١ؕ اِنَّ كَیْدَكُنَّ عَظِیْمٌ فَلَمَّا : تو جب رَاٰ : دیکھا قَمِيْصَهٗ : اس کی قمیص قُدَّ : پھٹی ہوئی مِنْ دُبُرٍ : پیچھے سے قَالَ : اس نے کہا اِنَّهٗ : بیشک یہ مِنْ : سے كَيْدِكُنَّ : تم عورتوں کا فریب اِنَّ : بیشک كَيْدَكُنَّ : تمہارا فریب عَظِيْمٌ : بڑا خاوند نے جو دیکھا کہ یوسف کا کرتہ پیٹھ کی جانب سے پھاڑا گیا ہے تو صاف کہہ دیا یہ تو عورتوں کی چال بازی ہے، بیشک تمہاری چال بازی بہت بڑی ہے (1)
  12,29,یُوْسُفُ اَعْرِضْ عَنْ هٰذَا١ٚ وَ اسْتَغْفِرِیْ لِذَنْۢبِكِ١ۖۚ اِنَّكِ كُنْتِ مِنَ الْخٰطِئِیْنَ۠    ۧ يُوْسُفُ : یوسف اَعْرِضْ : جانے دے عَنْ : سے۔ کو ھٰذَا : اس وَاسْتَغْفِرِيْ : اور اے عورت بخشش مانگ لِذَنْۢبِكِ : اپنے گناہ کی اِنَّكِ : بیشک تو كُنْتِ : تو ہے مِنَ : سے الْخٰطِئِيْنَ : خطا کار (جمع) یوسف اب اس بات کو آتی جاتی کرو (1) اور (اے عورت) تو اپنے گناہ سے توبہ کر، بیشک تو گنہگاروں میں سے ہے (2)۔
  12,30,وَ قَالَ نِسْوَةٌ فِی الْمَدِیْنَةِ امْرَاَتُ الْعَزِیْزِ تُرَاوِدُ فَتٰىهَا عَنْ نَّفْسِهٖ١ۚ قَدْ شَغَفَهَا حُبًّا١ؕ اِنَّا لَنَرٰىهَا فِیْ ضَلٰلٍ مُّبِیْنٍ وَقَالَ : اور کہا نِسْوَةٌ : عورتیں فِي الْمَدِيْنَةِ : شہر میں امْرَاَتُ الْعَزِيْزِ : عزیز کی بیوی تُرَاوِدُ : پھسلا رہی ہے فَتٰىهَا : اپنا غلام عَنْ : سے نَّفْسِهٖ : اس کا نفس قَدْ شَغَفَهَا : جگہ پکڑ گئی ہے حُبًّا : اس کی محبت اِنَّا لَنَرٰىهَا : بیشک ہم اسے دیکھتی ہیں فِيْ : میں ضَلٰلٍ : گمراہی مُّبِيْنٍ : کھلی اور شہر کی عورتوں میں چرچا ہونے لگا کہ عزیز کی بیوی اپنے (جوان) غلام کو اپنا مطلب نکالنے کے لئے بہلانے پھسلانے میں لگی رہتی ہے، ان کے دل میں یوسف کی محبت بیٹھ گئی ہے، ہمارے خیال میں تو وہ صریح گمراہی میں ہے (1)۔
