quran[83]{c,v,t}:
36,1,یٰسٓۚ يٰسٓ ۚ یٰسِین (1)
36,2,وَ الْقُرْاٰنِ الْحَكِیْمِۙ وَالْقُرْاٰنِ : قسم ہے قرآن کی الْحَكِيْمِ : باحکمت قسم ہے قرآن با حکمت کی (1)
36,3,اِنَّكَ لَمِنَ الْمُرْسَلِیْنَۙ اِنَّكَ : بیشک آپ لَمِنَ الْمُرْسَلِيْنَ : رسولوں میں سے کہ بیشک آپ پیغمبروں میں سے ہیں (1)
36,4,عَلٰى صِرَاطٍ مُّسْتَقِیْمٍؕ عَلٰي : پر صِرَاطٍ : راستہ مُّسْتَقِيْمٍ : سیدھا سیدھے راستے پر ہیں (1)
36,5,تَنْزِیْلَ الْعَزِیْزِ الرَّحِیْمِۙ تَنْزِيْلَ : نازل کردہ ہے الْعَزِيْزِ الرَّحِيْم : زبردست ، رحم فرمانے والی ہستی کی طرف یہ قرآن اللہ زبردست مہربان کی طرف سے نازل کیا گیا ہے (1)
36,6,لِتُنْذِرَ قَوْمًا مَّاۤ اُنْذِرَ اٰبَآؤُهُمْ فَهُمْ غٰفِلُوْنَ لِتُنْذِرَ : تاکہ آپ ڈرائیں قَوْمًا : وہ قوم مَّآ اُنْذِرَ : نہیں ڈرائے گئے اٰبَآؤُهُمْ : ان کے باپ (دادا) فَهُمْ : پس وہ غٰفِلُوْنَ : غافل (جمع) تاکہ آپ ایسے لوگوں کو ڈرائیں جن کے باپ دادا نہیں ڈرائے گئے تھے، سو (اسی وجہ سے) یہ غافل ہیں (1)
36,7,لَقَدْ حَقَّ الْقَوْلُ عَلٰۤى اَكْثَرِهِمْ فَهُمْ لَا یُؤْمِنُوْنَ لَقَدْ حَقَّ : تحقیق ثابت ہوگئی الْقَوْلُ : بات عَلٰٓي : پر اَكْثَرِهِمْ : ان میں سے اکثر فَهُمْ : پس وہ لَا يُؤْمِنُوْنَ : ایمان نہ لائیں گے ان میں سے اکثر لوگوں پر بات ثابت ہوچکی ہے سو یہ لوگ ایمان نہ لائیں گے (1)
36,8,اِنَّا جَعَلْنَا فِیْۤ اَعْنَاقِهِمْ اَغْلٰلًا فَهِیَ اِلَى الْاَذْقَانِ فَهُمْ مُّقْمَحُوْنَ اِنَّا جَعَلْنَا : بیشک ہم نے کیے (ڈالے) فِيْٓ : میں اَعْنَاقِهِمْ : ان کی گردنیں اَغْلٰلًا : طوق فَهِىَ : پھر وہ اِلَى : تک الْاَذْقَانِ : ٹھوڑیاں فَهُمْ : تو وہ مُّقْمَحُوْنَ : سر اونچا کیے (سر الل رہے ہیں ہم نے ان کی گردنوں میں طوق ڈال دیئے ہیں پھر وہ ٹھوڑیوں تک ہیں، جس سے انکے سر اوپر الٹ گئے ہیں (1)
36,9,وَ جَعَلْنَا مِنْۢ بَیْنِ اَیْدِیْهِمْ سَدًّا وَّ مِنْ خَلْفِهِمْ سَدًّا فَاَغْشَیْنٰهُمْ فَهُمْ لَا یُبْصِرُوْنَ وَجَعَلْنَا : اور ہم نے کردی مِنْۢ : سے بَيْنِ اَيْدِيْهِمْ : ان کے آگے سَدًّا : ایک دیوار وَّمِنْ خَلْفِهِمْ : اور ان کے پیچھے سَدًّا : ایک دیوار فَاَغْشَيْنٰهُمْ : پھر ہم نے انہیں ڈھانپ دیا فَهُمْ : پس وہ لَا يُبْصِرُوْنَ : دیکھتے نہیں اور ہم نے ایک آڑ ان کے سامنے کردی اور ایک آڑ ان کے پیچھے کردی (1) جس سے ہم نے ان کو ڈھانک دیا (2) سو وہ نہیں دیکھ سکتے۔
36,10,وَ سَوَآءٌ عَلَیْهِمْ ءَاَنْذَرْتَهُمْ اَمْ لَمْ تُنْذِرْهُمْ لَا یُؤْمِنُوْنَ وَسَوَآءٌ : اور برابر عَلَيْهِمْ : ان پر۔ ان کے لیے ءَاَنْذَرْتَهُمْ : خواہ تم انہیں ڈراؤ اَمْ : یا لَمْ تُنْذِرْهُمْ : تم انہیں نہ ڈراؤ لَا يُؤْمِنُوْنَ : وہ ایمان نہ لائیں گے اور آپ ان کو ڈرائیں یا نہ ڈرائیں دونوں برابر ہیں، یہ ایمان نہیں لائیں گے۔
36,11,اِنَّمَا تُنْذِرُ مَنِ اتَّبَعَ الذِّكْرَ وَ خَشِیَ الرَّحْمٰنَ بِالْغَیْبِ١ۚ فَبَشِّرْهُ بِمَغْفِرَةٍ وَّ اَجْرٍ كَرِیْمٍ اِنَّمَا : اس کے سوا نہیں تُنْذِرُ : تم ڈراتے ہو مَنِ : جو اتَّبَعَ : پیروی کرے الذِّكْرَ : کتاب نصیحت وَخَشِيَ : اور ڈرے الرَّحْمٰنَ : رحمن (اللہ) بِالْغَيْبِ ۚ : بن دیکھے فَبَشِّرْهُ : پس اسے خوشخبری دیں بِمَغْفِرَةٍ : بخشش کی وَّاَجْرٍ : اور اجر كَرِيْمٍ : اچھا بس آپ تو صرف ایسے شخص کو ڈرا سکتے ہیں (1) جو نصیحت پر چلے اور رحمٰن سے بےدیکھے ڈرے، سو آپ اس کو مغفرت اور با وقار اجر کی خوش خبریاں سنا دیجئے۔
36,12,اِنَّا نَحْنُ نُحْیِ الْمَوْتٰى وَ نَكْتُبُ مَا قَدَّمُوْا وَ اٰثَارَهُمْ١ۣؕ وَ كُلَّ شَیْءٍ اَحْصَیْنٰهُ فِیْۤ اِمَامٍ مُّبِیْنٍ۠    ۧ اِنَّا نَحْنُ : بیشک ہم نُحْيِ : زندہ کرتے ہیں الْمَوْتٰى : مردے وَنَكْتُبُ : اور ہم لکھتے ہیں مَا قَدَّمُوْا : جو انہوں نے آگے بھیجا (عمل) وَاٰثَارَهُمْ ڳ : اور ان کے اثر (نشانات) وَكُلَّ : اور ہر شَيْءٍ : شے اَحْصَيْنٰهُ : ہم نے اسے شمار کر رکھا ہے فِيْٓ : میں اِمَامٍ مُّبِيْنٍ : کتاب روشن (لوح محفوظ بیشک ہم مردوں کو زندہ کریں گے (1) اور ہم لکھتے جاتے ہیں اور وہ اعمال بھی جن کو لوگ آگے بھیجتے ہیں اور ان کے وہ اعمال بھی جن کو پیچھے چھوڑ جاتے ہیں اور ہم نے ہر چیز کو ایک واضح کتاب میں ضبط کر رکھا ہے (2)
36,13,وَ اضْرِبْ لَهُمْ مَّثَلًا اَصْحٰبَ الْقَرْیَةِ١ۘ اِذْ جَآءَهَا الْمُرْسَلُوْنَۚ وَاضْرِبْ : اور بیان کریں آپ لَهُمْ : ان کے لیے مَّثَلًا : مثال (قصہ) اَصْحٰبَ الْقَرْيَةِ ۘ : بستی والے اِذْ : جب جَآءَهَا : ان کے پاس آئے الْمُرْسَلُوْنَ : رسول (جمع) اور آپ ان کے سامنے ایک مثال (یعنی ایک) بستی والوں کی مثال (اس وقت کا) بیان کیجئے جبکہ اس بستی میں (کئی) رسول آئے (1)
36,14,اِذْ اَرْسَلْنَاۤ اِلَیْهِمُ اثْنَیْنِ فَكَذَّبُوْهُمَا فَعَزَّزْنَا بِثَالِثٍ فَقَالُوْۤا اِنَّاۤ اِلَیْكُمْ مُّرْسَلُوْنَ اِذْ : جب اَرْسَلْنَآ : ہم نے بھیجے اِلَيْهِمُ : ان کی طرف اثْنَيْنِ : دو فَكَذَّبُوْهُمَا : تو انہوں نے جھٹلایا انہیں فَعَزَّزْنَا : پھر ہم نے تقویت دی بِثَالِثٍ : تیسرے سے فَقَالُوْٓا : پس انہوں نے کہا اِنَّآ : بیشک ہم اِلَيْكُمْ : تمہاری طرف مُّرْسَلُوْنَ : بھیجے گئے جب ہم نے ان کے پاس دو کو بھیجا سو ان لوگوں نے (اول) دونوں کو جھٹلایا پھر ہم نے تیسرے سے تائید کی سو ان تینوں نے کہا کہ ہم تمہارے پاس بھیجے گئے ہیں (1)
36,15,قَالُوْا مَاۤ اَنْتُمْ اِلَّا بَشَرٌ مِّثْلُنَا١ۙ وَ مَاۤ اَنْزَلَ الرَّحْمٰنُ مِنْ شَیْءٍ١ۙ اِنْ اَنْتُمْ اِلَّا تَكْذِبُوْنَ قَالُوْا : وہ بولے مَآ اَنْتُمْ : تم نہیں ہو اِلَّا : مگر۔ محض بَشَرٌ : آدمی مِّثْلُنَا ۙ : ہم جیسے وَمَآ : اور نہیں اَنْزَلَ : اتارا الرَّحْمٰنُ : رحمن (اللہ) مِنْ شَيْءٍ ۙ : کچھ اِنْ : نہیں اَنْتُمْ : تم اِلَّا : مگر ۔ محض تَكْذِبُوْنَ : جھوٹ بولتے ہو ان لوگوں نے کہا تم تو ہماری طرح معمولی آدمی ہو اور رحمٰن نے کوئی چیز نازل نہیں کی۔ تم نرا جھوٹ بولتے ہو۔
36,16,قَالُوْا رَبُّنَا یَعْلَمُ اِنَّاۤ اِلَیْكُمْ لَمُرْسَلُوْنَ قَالُوْا : انہوں نے کہا رَبُّنَا : ہمارا پروردگار يَعْلَمُ : جانتا ہے اِنَّآ : بیشک ہم اِلَيْكُمْ : تمہاری طرف لَمُرْسَلُوْنَ : البتہ بھیجے گئے ان (رسولوں) نے کہا ہمارا پروردگار جانتا ہے کہ بیشک ہم تمہارے پاس بھیجے گئے ہیں۔
36,17,وَ مَا عَلَیْنَاۤ اِلَّا الْبَلٰغُ الْمُبِیْنُ وَمَا : اور نہیں عَلَيْنَآ : ہم پر اِلَّا : مگر الْبَلٰغُ : پہنچا دینا الْمُبِيْنُ : صاف صاف اور ہمارے ذمہ تو صرف واضح طور پر پہنچا دینا ہے۔
36,18,قَالُوْۤا اِنَّا تَطَیَّرْنَا بِكُمْ١ۚ لَئِنْ لَّمْ تَنْتَهُوْا لَنَرْجُمَنَّكُمْ وَ لَیَمَسَّنَّكُمْ مِّنَّا عَذَابٌ اَلِیْمٌ قَالُوْٓا : وہ کہنے لگے اِنَّا تَطَيَّرْنَا : ہم نے منحوس پایا بِكُمْ ۚ : تمہیں لَئِنْ : اگر لَّمْ تَنْتَهُوْا : تم باز نہ آئے لَنَرْجُمَنَّكُمْ : ضرور ہم سنگسار کردیں گے تمہیں وَلَيَمَسَّنَّكُمْ : اور ضرور پہنچے گا تمہیں مِّنَّا : ہم سے عَذَابٌ : عذاب اَلِيْمٌ : دردناک انہوں نے کہا کہ ہم تم کو منحوس سمجھتے ہیں (1) اگر تم باز نہ آئے تو ہم پتھروں سے تمہارا کام تمام کردیں گے اور تم کو ہماری طرف سے سخت تکلیف پہنچے گی۔
36,19,قَالُوْا طَآئِرُكُمْ مَّعَكُمْ١ؕ اَئِنْ ذُكِّرْتُمْ١ؕ بَلْ اَنْتُمْ قَوْمٌ مُّسْرِفُوْنَ قَالُوْا : انہوں نے کہا طَآئِرُكُمْ : تمہاری نحوست مَّعَكُمْ ۭ : تمہارے ساتھ اَئِنْ : کیا ذُكِّرْتُمْ ۭ : تم سمجھائے گئے بَلْ : بلکہ اَنْتُمْ : تم قَوْمٌ : لوگ مُّسْرِفُوْنَ : حد سے بڑھنے والے ان رسولوں نے کہا کہ تمہاری نحوست تمہارے ساتھ ہی لگی ہوئی ہے (1) ، کیا اس کو نحوست سمجھتے ہو کہ تم کو نصیحت کی جائے بلکہ تم حد سے نکل جانے والے لوگ ہو۔
36,20,وَ جَآءَ مِنْ اَقْصَا الْمَدِیْنَةِ رَجُلٌ یَّسْعٰى قَالَ یٰقَوْمِ اتَّبِعُوا الْمُرْسَلِیْنَۙ وَجَآءَ : اور آیا مِنْ : سے اَقْصَا : پرلا سرا الْمَدِيْنَةِ : شہر رَجُلٌ : ایک آدمی يَّسْعٰى : دوڑتا ہوا قَالَ : اس نے کہا يٰقَوْمِ : اے میری قوم اتَّبِعُوا : تم پیروی کرو الْمُرْسَلِيْنَ : رسولوں کی اور ایک شخص (اس) شہر کے آخری حصے سے دوڑتا ہوا آیا کہنے لگا کہ اے میری قوم ! ان رسولوں کی راہ پر چلو (1)
36,21,اتَّبِعُوْا مَنْ لَّا یَسْئَلُكُمْ اَجْرًا وَّ هُمْ مُّهْتَدُوْنَ اتَّبِعُوْا : تم پیروی کرو مَنْ : جو لَّا يَسْئَلُكُمْ : تم سے نہیں مانگتے اَجْرًا : کوئی اجر وَّهُمْ : اور وہ مُّهْتَدُوْنَ : ہدایت یافتہ ایسے لوگوں کی راہ پر چلو جو تم سے کوئی معاوضہ نہیں مانگتے اور وہ راہ راست پر ہیں۔
36,22,وَ مَا لِیَ لَاۤ اَعْبُدُ الَّذِیْ فَطَرَنِیْ وَ اِلَیْهِ تُرْجَعُوْنَ وَمَا : اور کیا ہوا لِيَ : مجھے لَآ اَعْبُدُ : میں نہ عبادت کروں الَّذِيْ : وہ جس نے فَطَرَنِيْ : پیدا کیا مجھے وَاِلَيْهِ : اور اسی کی طرف تُرْجَعُوْنَ : تم لوٹ کر جاؤ گے اور مجھے کیا ہوگیا ہے کہ میں اس کی عبادت نہ کروں جس نے مجھے پیدا کیا اور تم سب اسی کی طرف لوٹائے جاؤ گے (1)
36,23,ءَاَتَّخِذُ مِنْ دُوْنِهٖۤ اٰلِهَةً اِنْ یُّرِدْنِ الرَّحْمٰنُ بِضُرٍّ لَّا تُغْنِ عَنِّیْ شَفَاعَتُهُمْ شَیْئًا وَّ لَا یُنْقِذُوْنِۚ ءَاَتَّخِذُ : کیا میں بنا لوں مِنْ دُوْنِهٖٓ : اس کے سوا اٰلِهَةً : ایسے معبود اِنْ : اگر يُّرِدْنِ : وہ چاہے الرَّحْمٰنُ : رحمن۔ اللہ بِضُرٍّ : کوئی نقصان لَّا تُغْنِ عَنِّىْ : نہ کام آئے میرے شَفَاعَتُهُمْ : ان کی سفارش شَيْئًا : کچھ بھی وَّلَا يُنْقِذُوْنِ : اور نہ چھڑا سکیں وہ مجھے کیا میں اسے چھوڑ کر ایسوں کو معبود بناؤں کہ اگر (اللہ) رحمٰن مجھے کوئی نقصان پہنچانا چاہے تو ان کی سفارش مجھے کچھ بھی نفع نہ پہنچا سکے اور نہ مجھے بچاسکیں (1)۔
36,24,اِنِّیْۤ اِذًا لَّفِیْ ضَلٰلٍ مُّبِیْنٍ اِنِّىْٓ : بیشک میں اِذًا : اس وقت لَّفِيْ ضَلٰلٍ : البتہ گمراہی میں مُّبِيْنٍ : کھلی پھر تو یقیناً کھلی گمراہی میں ہوں (1)۔
36,25,اِنِّیْۤ اٰمَنْتُ بِرَبِّكُمْ فَاسْمَعُوْنِؕ اِنِّىْٓ : یشک میں اٰمَنْتُ : میں ایمان لایا بِرَبِّكُمْ : تمہارے پروردگار فَاسْمَعُوْنِ : پس تم میری سنو میری سنو ! میں تو (سچے دل سے) تم سب کے رب پر ایمان لا چکا ہوں (1)
36,26,قِیْلَ ادْخُلِ الْجَنَّةَ١ؕ قَالَ یٰلَیْتَ قَوْمِیْ یَعْلَمُوْنَۙ قِيْلَ : ارشاد ہوا ادْخُلِ : تو داخل ہوجا الْجَنَّةَ ۭ : جنت قَالَ : اس نے کہا يٰلَيْتَ : اے کاش قَوْمِيْ : میری قوم يَعْلَمُوْنَ : وہ جانتی (اس سے) کہا گیا کہ جنت میں چلا جا، کہنے لگا کاش ! میری قوم کو بھی علم ہوجاتا۔
36,27,بِمَا غَفَرَ لِیْ رَبِّیْ وَ جَعَلَنِیْ مِنَ الْمُكْرَمِیْنَ بِمَا : اس بات کو غَفَرَ لِيْ : اس نے بخش دیا مجھے رَبِّيْ : میرا رب وَجَعَلَنِيْ : اور اس نے کیا مجھے مِنَ : سے الْمُكْرَمِيْنَ : نوازے ہوئے لوگ کہ مجھے رب نے بخش دیا اور مجھے با عزت لوگوں میں سے کردیا (1)۔
36,28,وَ مَاۤ اَنْزَلْنَا عَلٰى قَوْمِهٖ مِنْۢ بَعْدِهٖ مِنْ جُنْدٍ مِّنَ السَّمَآءِ وَ مَا كُنَّا مُنْزِلِیْنَ وَمَآ اَنْزَلْنَا : اور نہیں اتارا عَلٰي : پر قَوْمِهٖ : اس کی قوم مِنْۢ بَعْدِهٖ : اس کے بعد مِنْ جُنْدٍ : کوئی لشکر مِّنَ : سے السَّمَآءِ : آسمان وَمَا كُنَّا : اور نہ تھے ہم مُنْزِلِيْنَ : اتارنے والے اس کے بعد ہم نے اس کی قوم پر آسمان سے کوئی لشکر نہ اتارا (1) اور نہ اس طرح ہم اتارا کرتے ہیں (2)۔
36,29,اِنْ كَانَتْ اِلَّا صَیْحَةً وَّاحِدَةً فَاِذَا هُمْ خٰمِدُوْنَ اِنْ كَانَتْ : نہ تھی اِلَّا : مگر صَيْحَةً : چنگھاڑ وَّاحِدَةً : ایک فَاِذَا : پس اچانک هُمْ : وہ خٰمِدُوْنَ : بجھ کر رہ گئے وہ تو صرف ایک زور کی چیخ تھی کہ یکایک وہ سب کے سب بجھ بھجا گئے (1)
36,30,یٰحَسْرَةً عَلَى الْعِبَادِ١ۣۚ مَا یَاْتِیْهِمْ مِّنْ رَّسُوْلٍ اِلَّا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ يٰحَسْرَةً : ہائے حسرت عَلَي الْعِبَادِ ڱ : بندوں پر مَا يَاْتِيْهِمْ : نہیں آیا ان کے پاس مِّنْ رَّسُوْلٍ : کوئی رسول اِلَّا : مگر كَانُوْا : وہ تھے بِهٖ : اس سے يَسْتَهْزِءُوْنَ : ہنسی اڑاتے (ایسے) بندوں پر افسوس ! (1) کبھی بھی کوئی رسول ان کے پاس نہیں آیا جس کی ہنسی انہوں نے نہ اڑائی ہو۔
36,31,اَلَمْ یَرَوْا كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنَ الْقُرُوْنِ اَنَّهُمْ اِلَیْهِمْ لَا یَرْجِعُوْنَؕ اَلَمْ يَرَوْا : کیا انہوں نے نہیں دیکھا كَمْ : کتنی اَهْلَكْنَا : ہلاک کیں ہم نے قَبْلَهُمْ : ان سے قبل مِّنَ الْقُرُوْنِ : بستیاں اَنَّهُمْ : کہ وہ اِلَيْهِمْ : ان کی طرف لَا يَرْجِعُوْنَ : لوٹ کر نہیں آئیں گے وہ کیا انہوں نے نہیں دیکھا کہ ان سے پہلے بہت سی قوموں کو ہم نے غارت کردیا کہ وہ ان (1) کی طرف لوٹ کر نہیں آئیں گے۔
36,32,وَ اِنْ كُلٌّ لَّمَّا جَمِیْعٌ لَّدَیْنَا مُحْضَرُوْنَ۠    ۧ وَاِنْ : اور نہیں كُلٌّ : سب لَّمَّا : مگر جَمِيْعٌ : سب کے سب لَّدَيْنَا : ہمارے روبرو مُحْضَرُوْنَ : حاضر کیے جائیں گے اور نہیں ہے کوئی جماعت مگر یہ وہ جمع ہو کر ہمارے سامنے حاضر کی جائے گی (1)
36,33,وَ اٰیَةٌ لَّهُمُ الْاَرْضُ الْمَیْتَةُ١ۖۚ اَحْیَیْنٰهَا وَ اَخْرَجْنَا مِنْهَا حَبًّا فَمِنْهُ یَاْكُلُوْنَ وَاٰيَةٌ : ایک نشانی لَّهُمُ : ان کے لیے الْاَرْضُ : زمین الْمَيْتَةُ ښ : مردہ اَحْيَيْنٰهَا : ہم نے زندہ کیا اسے وَاَخْرَجْنَا : اور نکالا ہم نے مِنْهَا : اس سے حَبًّا : اناج فَمِنْهُ : پس اس سے يَاْكُلُوْنَ : وہ کھاتے ہیں اور ان کے لئے ایک نشانی (1) (خشک) زمین ہے جس کو ہم نے زندہ کردیا اور اس سے غلہ نکالا جس میں سے وہ کھاتے ہیں۔
36,34,وَ جَعَلْنَا فِیْهَا جَنّٰتٍ مِّنْ نَّخِیْلٍ وَّ اَعْنَابٍ وَّ فَجَّرْنَا فِیْهَا مِنَ الْعُیُوْنِۙ وَجَعَلْنَا : اور بنائے ہم نے فِيْهَا : اس میں جَنّٰتٍ : باغات مِّنْ : سے ۔ کے نَّخِيْلٍ : کھجور وَّاَعْنَابٍ : اور انگور وَّفَجَّرْنَا : اور جاری کیے ہم نے فِيْهَا : اس میں مِنَ : سے الْعُيُوْنِ : چشمے اور ہم نے اس میں کھجوروں کے اور انگور کے باغات پیدا کردیئے (1) اور جن میں ہم نے چشمے بھی جاری کردیئے ہیں۔
36,35,لِیَاْكُلُوْا مِنْ ثَمَرِهٖ١ۙ وَ مَا عَمِلَتْهُ اَیْدِیْهِمْ١ؕ اَفَلَا یَشْكُرُوْنَ لِيَاْكُلُوْا : تاکہ وہ کھائیں مِنْ ثَمَرِهٖ ۙ : اس کے پھلوں سے وَمَا : اور نہیں عَمِلَتْهُ : بنایا اسے اَيْدِيْهِمْ ۭ : ان کے ہاتھوں اَفَلَا يَشْكُرُوْنَ : تو کیا وہ شکر نہ کریں گے تاکہ (لوگ) اس کے پھل کھائیں (1) اور اس کو ان کے ہاتھوں نے نہیں بنایا (2) پھر کیوں شکر گزاری نہیں کرتے۔
36,36,سُبْحٰنَ الَّذِیْ خَلَقَ الْاَزْوَاجَ كُلَّهَا مِمَّا تُنْۢبِتُ الْاَرْضُ وَ مِنْ اَنْفُسِهِمْ وَ مِمَّا لَا یَعْلَمُوْنَ سُبْحٰنَ : پاک الَّذِيْ : وہ ذات جس نے خَلَقَ : پیدا کیے الْاَزْوَاجَ : جوڑے كُلَّهَا : ہر چیز مِمَّا : اس سے جو تُنْۢبِتُ : اگاتی ہے الْاَرْضُ : زمین وَمِنْ اَنْفُسِهِمْ : اور ان کی جانوں سے وَمِمَّا : اور اس سے جو لَا يَعْلَمُوْنَ : وہ نہیں جانتے وہ پاک ذات ہے جس نے ہر چیز کے جوڑے پیدا کیے خواہ وہ زمین کی اگائی ہوئی چیزیں ہوں، خواہ خود ان کے نفوس ہوں خواہ وہ (چیزیں) ہوں جنہیں یہ جانتے بھی نہیں (1)
36,37,وَ اٰیَةٌ لَّهُمُ الَّیْلُ١ۖۚ نَسْلَخُ مِنْهُ النَّهَارَ فَاِذَا هُمْ مُّظْلِمُوْنَۙ وَاٰيَةٌ : اور ایک نشانی لَّهُمُ : ان کے لیے الَّيْلُ ښ : رات نَسْلَخُ : ہم کھینچتے ہیں مِنْهُ : اس سے النَّهَارَ : دن فَاِذَا : تو اچانک هُمْ : وہ مُّظْلِمُوْنَ : اندھیرے میں رہ جاتے ہیں اور ان کے لئے ایک نشانی رات ہے جس سے ہم دن کو کھنچ دیتے ہیں تو یکایک اندھیرے میں رہ جاتے ہیں (1)
36,38,وَ الشَّمْسُ تَجْرِیْ لِمُسْتَقَرٍّ لَّهَا١ؕ ذٰلِكَ تَقْدِیْرُ الْعَزِیْزِ الْعَلِیْمِؕ وَالشَّمْسُ : اور سورج تَجْرِيْ : چلتا رہتا ہے لِمُسْتَقَرٍّ : ٹھکانے (مقررہ راستہ لَّهَا ۭ : اپنے ذٰلِكَ : یہ تَقْدِيْرُ : نظام الْعَزِيْزِ : غالب الْعَلِيْمِ : جاننے والا (دانا) اور سورج کے لئے جو مقررہ راہ ہے وہ اسی پر چلتا رہتا ہے یہ ہے مقرر کردہ غالب، باعلم اللہ تعالیٰ کا۔ (1)
36,39,وَ الْقَمَرَ قَدَّرْنٰهُ مَنَازِلَ حَتّٰى عَادَ كَالْعُرْجُوْنِ الْقَدِیْمِ وَالْقَمَرَ : اور چاند قَدَّرْنٰهُ : ہم نے مقرر کیں اس کو مَنَازِلَ : منزلیں حَتّٰى : یہاں تک کہ عَادَ : ہوجاتا ہے كَالْعُرْجُوْنِ : کھجور کی شاخ کی طرح الْقَدِيْمِ : پرانی اور چاند کی منزلیں مقرر کر رکھی ہیں (1) کہ وہ لوٹ کر پرانی ٹہنی کی طرح ہوجاتا ہے (2)
36,40,لَا الشَّمْسُ یَنْۢبَغِیْ لَهَاۤ اَنْ تُدْرِكَ الْقَمَرَ وَ لَا الَّیْلُ سَابِقُ النَّهَارِ١ؕ وَ كُلٌّ فِیْ فَلَكٍ یَّسْبَحُوْنَ لَا : نہ الشَّمْسُ : سورج يَنْۢبَغِيْ : لائق (مجال) لَهَآ : اس کے لیے اَنْ : کہ تُدْرِكَ : جاپکڑے وہ الْقَمَرَ : چاند وَلَا : اور نہ الَّيْلُ : رات سَابِقُ : پہلے آسکے النَّهَارِ ۭ : دن وَكُلٌّ : اور سب فِيْ فَلَكٍ : دائرہ میں يَّسْبَحُوْنَ : تیرے (گردش کرتے) ہیں نہ آفتاب کی یہ مجال ہے کہ چاند کو پکڑے (1) اور نہ رات دن پر آگے بڑھ جانے والی ہے (2) اور سب کے سب آسمان میں تیرتے پھرتے ہیں (3)۔
36,41,وَ اٰیَةٌ لَّهُمْ اَنَّا حَمَلْنَا ذُرِّیَّتَهُمْ فِی الْفُلْكِ الْمَشْحُوْنِۙ وَاٰيَةٌ : اور ایک نشانی لَّهُمْ : ان کے لیے اَنَّا : کہ ہم حَمَلْنَا : ہم نے سوار کیا ذُرِّيَّتَهُمْ : ان کی اولاد فِي الْفُلْكِ : کشتی میں الْمَشْحُوْنِ : بھری ہوئی ان کے لئے ایک نشانی (یہ بھی) ہے کہ ہم نے ان کی نسل کو بھری ہوئی کشتی میں سوار کیا (1)
36,42,وَ خَلَقْنَا لَهُمْ مِّنْ مِّثْلِهٖ مَا یَرْكَبُوْنَ وَخَلَقْنَا : اور ہم نے پیدا کیا لَهُمْ : ان کے لیے مِّنْ مِّثْلِهٖ : اس (کشتی) جیسی مَا : جو۔ جس يَرْكَبُوْنَ : وہ سوار ہوتے ہیں اور ان کے لئے اسی جیسی اور چیزیں پیدا کیں جن پر یہ سوار ہوتے ہیں (1)۔
36,43,وَ اِنْ نَّشَاْ نُغْرِقْهُمْ فَلَا صَرِیْخَ لَهُمْ وَ لَا هُمْ یُنْقَذُوْنَۙ وَاِنْ : اور اگر نَّشَاْ : ہم چاہیں نُغْرِقْهُمْ : ہم غرق کردیں انہیں فَلَا صَرِيْخَ : تو نہ فریاد رس لَهُمْ : ان کے لیے وَلَا هُمْ : اور نہ وہ يُنْقَذُوْنَ : چھڑائے جائیں اور اگر ہم چاہتے تو انہیں ڈبو دیتے۔ پھر نہ تو کوئی ان کا فریاد رس ہوتا نہ بچائے جائیں۔
36,44,اِلَّا رَحْمَةً مِّنَّا وَ مَتَاعًا اِلٰى حِیْنٍ اِلَّا : مگر رَحْمَةً : رحمت مِّنَّا : ہماری طرف سے وَمَتَاعًا : اور فائدہ دینا اِلٰى حِيْنٍ : ایک وقت معین تک لیکن ہم اپنی طرف سے رحمت کرتے ہیں اور ایک مدت تک کے لئے انہیں فائدے دے رہے ہیں۔
36,45,وَ اِذَا قِیْلَ لَهُمُ اتَّقُوْا مَا بَیْنَ اَیْدِیْكُمْ وَ مَا خَلْفَكُمْ لَعَلَّكُمْ تُرْحَمُوْنَ وَاِذَا : اور جب قِيْلَ : کہا جائے لَهُمُ : ان سے اتَّقُوْا : تم ڈرو مَا : جو بَيْنَ اَيْدِيْكُمْ : تمہارے سامنے وَمَا : اور جو خَلْفَكُمْ : تمہارے پیچھے لَعَلَّكُمْ : شاید تم تُرْحَمُوْنَ : پر رحم کیا جائے اور ان سے جب (کبھی) کہا جاتا ہے کہ اگلے پچھلے (گناہوں) سے بچو تاکہ تم پر رحم کیا جائے۔
36,46,وَ مَا تَاْتِیْهِمْ مِّنْ اٰیَةٍ مِّنْ اٰیٰتِ رَبِّهِمْ اِلَّا كَانُوْا عَنْهَا مُعْرِضِیْنَ وَمَا : اور نہیں تَاْتِيْهِمْ : ان کے پاس آتی مِّنْ اٰيَةٍ : کوئی نشانی مِّنْ اٰيٰتِ : نشانیوں میں سے رَبِّهِمْ : ان کا رب اِلَّا : مگر كَانُوْا : وہ ہیں عَنْهَا : اس سے مُعْرِضِيْنَ : روگردانی کرتے اور ان کے پاس تو ان کے رب کی نشانیوں میں سے کوئی نشانی ایسی نہیں آتی جس سے یہ بےرخی نہ برتتے ہوں (1)۔
36,47,وَ اِذَا قِیْلَ لَهُمْ اَنْفِقُوْا مِمَّا رَزَقَكُمُ اللّٰهُ١ۙ قَالَ الَّذِیْنَ كَفَرُوْا لِلَّذِیْنَ اٰمَنُوْۤا اَنُطْعِمُ مَنْ لَّوْ یَشَآءُ اللّٰهُ اَطْعَمَهٗۤ١ۖۗ اِنْ اَنْتُمْ اِلَّا فِیْ ضَلٰلٍ مُّبِیْنٍ وَاِذَا : اور جب قِيْلَ : کہا جائے لَهُمْ : ان سے اَنْفِقُوْا : خرچ کرو تم مِمَّا : اس سے جو رَزَقَكُمُ : تمہیں دیا اللّٰهُ ۙ : اللہ قَالَ : کہتے ہیں الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) لِلَّذِيْنَ اٰمَنُوْٓا : ان لوگوں سے جو ایمان لائے (مومن) اَنُطْعِمُ : کیا ہم کھلائیں مَنْ : (اس کو) جسے لَّوْ يَشَآءُ اللّٰهُ : اگر اللہ چاہتا اَطْعَمَهٗٓ ڰ : اسے کھانے کو دیتا اِنْ : نہیں اَنْتُمْ : تم اِلَّا : مگر۔ صرف فِيْ : میں ضَلٰلٍ : گمراہی مُّبِيْنٍ : کھلی اور ان سے جب کہا جاتا ہے کہ اللہ تعالیٰ کے دیئے ہوئے میں سے کچھ خرچ کرو، (1) تو یہ کفار ایمان والوں کو جواب دیتے ہیں کہ ہم انہیں کیوں کھلائیں ؟ جنہیں اگر اللہ تعالیٰ چاہتا تو خود کھلا پلا دیتا (2) تم تو ہو ہی کھلی گمراہی میں۔
36,48,وَ یَقُوْلُوْنَ مَتٰى هٰذَا الْوَعْدُ اِنْ كُنْتُمْ صٰدِقِیْنَ وَيَقُوْلُوْنَ : اور وہ کہتے ہیں مَتٰى : کب ھٰذَا الْوَعْدُ : یہ وعدہ اِنْ : اگر كُنْتُمْ : تم ہو صٰدِقِيْنَ : سچے وہ کہتے ہیں کہ یہ وعدہ کب ہوگا، سچے ہو تو بتلاؤ۔
36,49,مَا یَنْظُرُوْنَ اِلَّا صَیْحَةً وَّاحِدَةً تَاْخُذُهُمْ وَ هُمْ یَخِصِّمُوْنَ مَا يَنْظُرُوْنَ : وہ انتظار نہیں کر رہے ہیں اِلَّا : مگر صَيْحَةً : چنگھاڑ وَّاحِدَةً : ایک تَاْخُذُهُمْ : وہ انہیں آپکڑے گی وَهُمْ : اور وہ يَخِصِّمُوْنَ : باہم جھگڑ رہے ہوں گے انہیں صرف ایک چیخ کا انتظار ہے جو انہیں آپکڑے گی اور یہ باہم لڑائی جھگڑے میں ہی ہونگے (1)۔
36,50,فَلَا یَسْتَطِیْعُوْنَ تَوْصِیَةً وَّ لَاۤ اِلٰۤى اَهْلِهِمْ یَرْجِعُوْنَ۠    ۧ فَلَا يَسْتَطِيْعُوْنَ : پھر نہ کرسکیں گے تَوْصِيَةً : وصیت کرنا وَّلَآ : اور نہ اِلٰٓى : طرف اَهْلِهِمْ : اپنے گھر والے يَرْجِعُوْنَ : وہ لوٹ سکیں گے اس وقت نہ تو یہ وصیت کرسکیں گے اور نہ اپنے اہل کی طرف لوٹ سکیں گے۔
36,51,وَ نُفِخَ فِی الصُّوْرِ فَاِذَا هُمْ مِّنَ الْاَجْدَاثِ اِلٰى رَبِّهِمْ یَنْسِلُوْنَ وَنُفِخَ : اور پھونکا جائے گا فِي الصُّوْرِ : صور میں فَاِذَا هُمْ : تو یکایک وہ مِّنَ : سے الْاَجْدَاثِ : قبریں اِلٰى رَبِّهِمْ : اپنے رب کی طرف يَنْسِلُوْنَ : دوڑیں گے تو صور کے پھونکے جاتے ہی سب (1) اپنی قبروں سے اپنے پروردگار کی طرف (تیز تیز) چلنے لگیں گے۔
36,52,قَالُوْا یٰوَیْلَنَا مَنْۢ بَعَثَنَا مِنْ مَّرْقَدِنَا١ؐٚۘ هٰذَا مَا وَعَدَ الرَّحْمٰنُ وَ صَدَقَ الْمُرْسَلُوْنَ قَالُوْا : وہ کہیں گے يٰوَيْلَنَا : اے وائے ہم پر مَنْۢ بَعَثَنَا : کس نے اٹھا دیا ہمیں مِنْ : سے مَّرْقَدِنَا ۆ : ہماری قبریں ھٰذَا : یہ مَا وَعَدَ : جو وعدہ کیا الرَّحْمٰنُ : رحمن۔ اللہ وَصَدَقَ : اور سچ کہا تھا الْمُرْسَلُوْنَ : رسولوں کہیں گے ہائے ہائے ! ہمیں ہماری خواب گاہوں سے کس نے اٹھا دیا (1) یہی ہے جس کا وعدہ رحمٰن نے دیا تھا اور رسولوں نے سچ سچ کہہ دیا تھا۔
36,53,اِنْ كَانَتْ اِلَّا صَیْحَةً وَّاحِدَةً فَاِذَا هُمْ جَمِیْعٌ لَّدَیْنَا مُحْضَرُوْنَ اِنْ : نہ كَانَتْ : ہوگی اِلَّا : مگر صَيْحَةً : ایک چنگھاڑ وَّاحِدَةً : ایک فَاِذَا : پس یکایک هُمْ : وہ جَمِيْعٌ : سب لَّدَيْنَا : ہمارے سامنے مُحْضَرُوْنَ : حاضر کیے جائیں گے یہ نہیں ہے مگر ایک چیخ کہ یکایک سارے کے سارے ہمارے سامنے حاضر کردیئے جائیں گے۔
36,54,فَالْیَوْمَ لَا تُظْلَمُ نَفْسٌ شَیْئًا وَّ لَا تُجْزَوْنَ اِلَّا مَا كُنْتُمْ تَعْمَلُوْنَ فَالْيَوْمَ : پس آج لَا تُظْلَمُ : نہ ظلم کیا جائے گا نَفْسٌ : کسی شخص شَيْئًا : کچھ وَّلَا تُجْزَوْنَ : اور نہ تم بدلہ پاؤ گے اِلَّا : مگر ۔ بس مَا كُنْتُمْ تَعْمَلُوْنَ : جو تم کرتے تھے پس آج کسی شخص پر کچھ بھی ظلم نہ کیا جائے گا اور تمہیں انہیں بدلہ دیا جائے گا، مگر صرف ان ہی کاموں کا جو تم کیا کرتے تھے۔
36,55,اِنَّ اَصْحٰبَ الْجَنَّةِ الْیَوْمَ فِیْ شُغُلٍ فٰكِهُوْنَۚ اِنَّ : بیشک اَصْحٰبَ الْجَنَّةِ : اہل جنت الْيَوْمَ : آج فِيْ شُغُلٍ : ایک شغل میں فٰكِهُوْنَ : باتیں (خوش طبعی کرتے) جنتی لوگ آج کے دن اپنے (دلچسپ) مشغلوں میں ہشاش بشاش ہیں (1)
36,56,هُمْ وَ اَزْوَاجُهُمْ فِیْ ظِلٰلٍ عَلَى الْاَرَآئِكِ مُتَّكِئُوْنَ هُمْ : وہ وَاَزْوَاجُهُمْ : اور ان کی بیویاں فِيْ ظِلٰلٍ : سایوں میں عَلَي : پر الْاَرَآئِكِ : تختوں پر مُتَّكِئُوْنَ : تکیہ لگائے ہوئے وہ اور ان کی بیویاں سایوں میں مسہریوں پر تکیہ لگائے بیٹھے ہونگے۔
36,57,لَهُمْ فِیْهَا فَاكِهَةٌ وَّ لَهُمْ مَّا یَدَّعُوْنَۚۖ لَهُمْ : ان کے لیے فِيْهَا : اس میں فَاكِهَةٌ : میوہ وَّلَهُمْ : اور ان کے لیے مَّا يَدَّعُوْنَ : جو وہ چاہیں گے ان کے لئے جنت میں ہر قسم کے میوے ہوں گے اور بھی جو کچھ وہ طلب کریں۔
36,58,سَلٰمٌ١۫ قَوْلًا مِّنْ رَّبٍّ رَّحِیْمٍ سَلٰمٌ ۣ : سلام قَوْلًا : فرمایا جائے گا مِّنْ : سے رَّبٍّ رَّحِيْمٍ : مہربان، پروردگار مہربان پروردگار کی طرف سے انہیں سلام ' کہا جائے گا (1)۔
36,59,وَ امْتَازُوا الْیَوْمَ اَیُّهَا الْمُجْرِمُوْنَ وَامْتَازُوا : اور الگ ہوجاؤ تم الْيَوْمَ : آج اَيُّهَا : اے الْمُجْرِمُوْنَ : مجرمو (جمع) اے گناہ گارو ! آج تم الگ ہوجاؤ (1)۔
36,60,اَلَمْ اَعْهَدْ اِلَیْكُمْ یٰبَنِیْۤ اٰدَمَ اَنْ لَّا تَعْبُدُوا الشَّیْطٰنَ١ۚ اِنَّهٗ لَكُمْ عَدُوٌّ مُّبِیْنٌۙ اَلَمْ اَعْهَدْ : کیا میں نے حکم نہیں بھیجا تھا اِلَيْكُمْ : تمہاری طرف يٰبَنِيْٓ اٰدَمَ : اے اولاد آدم اَنْ : کہ لَّا تَعْبُدُوا : پرستش نہ کرنا الشَّيْطٰنَ ۚ : شیطان اِنَّهٗ : بیشک وہ لَكُمْ : تمہارا عَدُوٌّ مُّبِيْنٌ : دشمن کھلا اے اولاد آدم ! کیا میں نے تم سے قول قرار نہیں لیا تھا کہ تم شیطان کی عبادت نہ کرنا (1) وہ تمہارا کھلا دشمن ہے (2)
36,61,وَّ اَنِ اعْبُدُوْنِیْ١ؔؕ هٰذَا صِرَاطٌ مُّسْتَقِیْمٌ وَّ اَنِ : اور یہ کہ اعْبُدُوْنِيْ ڼ : تم میری عبادت کرنا ھٰذَا : یہی صِرَاطٌ : راستہ مُّسْتَقِيْمٌ : سیدھا اور میری عبادت کرنا (1) سیدھی راہ یہی ہے (2)
36,62,وَ لَقَدْ اَضَلَّ مِنْكُمْ جِبِلًّا كَثِیْرًا١ؕ اَفَلَمْ تَكُوْنُوْا تَعْقِلُوْنَ وَلَقَدْ اَضَلَّ : اور تحقیق گمراہ کردیا مِنْكُمْ : تم میں سے جِبِلًّا : مخلوق كَثِيْرًا ۭ : بہت سی اَفَلَمْ تَكُوْنُوْا تَعْقِلُوْنَ : سو کیا تم عقل سے کام نہیں لیتے ؟ شیطان نے تم میں سے بہت ساری مخلوق کو بہکا دیا۔ کیا تم عقل نہیں رکھتے (1)۔
36,63,هٰذِهٖ جَهَنَّمُ الَّتِیْ كُنْتُمْ تُوْعَدُوْنَ هٰذِهٖ : یہ ہے جَهَنَّمُ : جہنم الَّتِيْ : وہ جس کا كُنْتُمْ تُوْعَدُوْنَ : تم سے وعدہ کیا گیا تھا یہی وہ دوزخ ہے جس کا تمہیں وعدہ دیا جاتا تھا۔
36,64,اِصْلَوْهَا الْیَوْمَ بِمَا كُنْتُمْ تَكْفُرُوْنَ اِصْلَوْهَا : اس میں داخل ہوجاؤ الْيَوْمَ : آج بِمَا : اس کے بدلے جو كُنْتُمْ تَكْفُرُوْنَ : تم کفر کرتے تھے اپنے کفر کا بدلہ پانے کے لئے آج اس میں داخل ہوجاؤ (1)۔
36,65,اَلْیَوْمَ نَخْتِمُ عَلٰۤى اَفْوَاهِهِمْ وَ تُكَلِّمُنَاۤ اَیْدِیْهِمْ وَ تَشْهَدُ اَرْجُلُهُمْ بِمَا كَانُوْا یَكْسِبُوْنَ اَلْيَوْمَ : آج نَخْتِمُ : ہم مہر لگا دیں گے عَلٰٓي : پر اَفْوَاهِهِمْ : ان کے منہ وَتُكَلِّمُنَآ : اور ہم سے بولیں گے اَيْدِيْهِمْ : ان کے ہاتھ وَتَشْهَدُ : اور گواہی دیں گے اَرْجُلُهُمْ : ان کے پاؤں بِمَا : اس کی جو كَانُوْا : وہ تھے يَكْسِبُوْنَ : کماتے (کرتے تھے) ہم آج کے دن ان کے منہ پر مہر لگا دیں گے اور ان کے ہاتھ ہم سے باتیں کریں گے اور ان کے پاؤں گواہیاں دیں گے، ان کاموں کی جو وہ کرتے تھے۔ (1)
36,66,وَ لَوْ نَشَآءُ لَطَمَسْنَا عَلٰۤى اَعْیُنِهِمْ فَاسْتَبَقُوا الصِّرَاطَ فَاَنّٰى یُبْصِرُوْنَ وَلَوْ نَشَآءُ : اور اگر ہم چاہیں لَطَمَسْنَا : تو مٹا دیں (ملیا میٹ کردیں) عَلٰٓي : پر اَعْيُنِهِمْ : ان کی آنکھیں فَاسْتَبَقُوا : پھر وہ سبقت کریں الصِّرَاطَ : راستہ فَاَنّٰى : تو کہاں يُبْصِرُوْنَ : وہ دیکھ سکیں گے اگر ہم چاہتے تو ان کی آنکھیں بےنور کردیتے پھر یہ راستے کی طرف دوڑتے پھرتے لیکن انہیں کیسے دکھائی دیتا ؟ (1)
36,67,وَ لَوْ نَشَآءُ لَمَسَخْنٰهُمْ عَلٰى مَكَانَتِهِمْ فَمَا اسْتَطَاعُوْا مُضِیًّا وَّ لَا یَرْجِعُوْنَ۠    ۧ وَلَوْ نَشَآءُ : اور اگر ہم چاہیں لَمَسَخْنٰهُمْ : ہم مسخ کردیں انہیں عَلٰي : پر۔ میں مَكَانَتِهِمْ : اور ان کی جگہیں فَمَا اسْتَطَاعُوْا : پھر نہ کرسکیں مُضِيًّا : چلنا وَّلَا يَرْجِعُوْنَ : اور نہ وہ لوٹیں اور اگر ہم چاہتے تو ان کی جگہ ہی پر ان کی صورتیں مسخ کردیتے پھر وہ چل پھر سکتے اور نہ لوٹ سکتے (1)
36,68,وَ مَنْ نُّعَمِّرْهُ نُنَكِّسْهُ فِی الْخَلْقِ١ؕ اَفَلَا یَعْقِلُوْنَ وَمَنْ : اور جس نُّعَمِّرْهُ : ہم عمر دراز کردیتے ہیں نُنَكِّسْهُ : اوندھا کردیتے ہیں فِي الْخَلْقِ ۭ : خلقت (پیدائش) میں اَفَلَا يَعْقِلُوْنَ : تو کیا وہ سمجھتے نہیں ؟ اور جسے ہم بوڑھا کرتے ہیں اسے پیدائشی حالت کی طرف پھر الٹ دیتے ہیں (1) کیا پھر بھی وہ نہیں سمجھتے (2)
36,69,وَ مَا عَلَّمْنٰهُ الشِّعْرَ وَ مَا یَنْۢبَغِیْ لَهٗ١ؕ اِنْ هُوَ اِلَّا ذِكْرٌ وَّ قُرْاٰنٌ مُّبِیْنٌۙ وَمَا عَلَّمْنٰهُ : اور ہم نے نہیں سکاھیا اس کو الشِّعْرَ : شعر وَمَا يَنْۢبَغِيْ : اور نہیں شایان لَهٗ ۭ : اس کے لیے اِنْ : نہیں هُوَ : وہ (یہ) اِلَّا : مگر ذِكْرٌ : نصیحت وَّقُرْاٰنٌ مُّبِيْنٌ : اور قرآن واضح نہ تو ہم نے اس پیغمبر کو شعر سکھائے اور نہ یہ اس کے لائق ہے۔ وہ تو صرف نصیحت اور واضح قرآن ہے (1)
36,70,لِّیُنْذِرَ مَنْ كَانَ حَیًّا وَّ یَحِقَّ الْقَوْلُ عَلَى الْكٰفِرِیْنَ لِّيُنْذِرَ : تاکہ ( آپ) ڈرائین مَنْ : جو كَانَ : ہو حَيًّا : زندہ وَّيَحِقَّ : اور ثابت ہوجائے الْقَوْلُ : بات (حجت) عَلَي : پر الْكٰفِرِيْنَ : جمع کافر تاکہ وہ ہر شخص کو آگاہ کر دے جو زندہ ہے (1) اور کافروں پر حجت ثابت ہوجائے (2)۔
36,71,اَوَ لَمْ یَرَوْا اَنَّا خَلَقْنَا لَهُمْ مِّمَّا عَمِلَتْ اَیْدِیْنَاۤ اَنْعَامًا فَهُمْ لَهَا مٰلِكُوْنَ اَوَلَمْ يَرَوْا : یا کیا وہ نہیں دیکھتے ؟ اَنَّا خَلَقْنَا : ہم نے پیدا کیا لَهُمْ : ان کے لیے مِّمَّا : اس سے جو عَمِلَتْ اَيْدِيْنَآ : بنایا اپنے ہاتھوں (قدرت) سے اَنْعَامًا : چوپائے فَهُمْ : پس وہ لَهَا : ان کے مٰلِكُوْنَ : مالک ہیں کیا وہ نہیں دیکھتے ہم نے اپنے ہاتھوں بنائی (1) ہوئی چیزوں میں سے ان کے لئے چوپائے (2) بھی پیدا کئے جن کے کہ یہ مالک ہوگئے ہیں (3)
36,72,وَ ذَلَّلْنٰهَا لَهُمْ فَمِنْهَا رَكُوْبُهُمْ وَ مِنْهَا یَاْكُلُوْنَ وَذَلَّلْنٰهَا : اور ہم نے فرمانبردار کیا انہیں لَهُمْ : ان کے لیے فَمِنْهَا : پس ان سے رَكُوْبُهُمْ : ان کی سواری وَمِنْهَا : اور ان سے يَاْكُلُوْنَ : وہ کھاتے ہیں اور ان مویشیوں کو ہم نے ان کے تابع فرمان کردیا (1) جن میں سے بعض تو ان کی سواریاں ہیں اور بعض کا گوشت کھاتے ہیں۔
36,73,وَ لَهُمْ فِیْهَا مَنَافِعُ وَ مَشَارِبُ١ؕ اَفَلَا یَشْكُرُوْنَ وَلَهُمْ : اور ان کے لیے فِيْهَا : ان میں مَنَافِعُ : فائدے وَمَشَارِبُ ۭ : اور پینے کی چیزیں اَفَلَا يَشْكُرُوْنَ : کیا پھر وہ شکر نہیں کرتے ؟ انہیں ان میں سے اور بھی بہت سے فائدے ہیں (1) اور پینے کی چیزیں۔ کیا پھر (بھی) یہ شکر ادا نہیں کریں گے ؟
36,74,وَ اتَّخَذُوْا مِنْ دُوْنِ اللّٰهِ اٰلِهَةً لَّعَلَّهُمْ یُنْصَرُوْنَؕ وَاتَّخَذُوْا : اور انہوں نے بنا لیے مِنْ دُوْنِ اللّٰهِ : اللہ کے سوا اٰلِهَةً : اور معبود لَّعَلَّهُمْ : شاید وہ يُنْصَرُوْنَ : مدد کیے جائیں اور وہ اللہ کے سوا دوسروں کو معبود بناتے ہیں تاکہ وہ مدد کئے جائیں (1)۔
36,75,لَا یَسْتَطِیْعُوْنَ نَصْرَهُمْ١ۙ وَ هُمْ لَهُمْ جُنْدٌ مُّحْضَرُوْنَ لَا يَسْتَطِيْعُوْنَ : وہ نہیں کرسکتے نَصْرَهُمْ ۙ : ان کی مدد وَهُمْ : اور وہ لَهُمْ : ان کے لیے جُنْدٌ : لشکر مُّحْضَرُوْنَ : حاضر کیے جائیں گے (حالانکہ) ان میں ان کی مدد کی طاقت ہی نہیں، (لیکن) پھر بھی (مشرکین) ان کے لئے حاضر باش لشکری ہیں (1)
36,76,فَلَا یَحْزُنْكَ قَوْلُهُمْ١ۘ اِنَّا نَعْلَمُ مَا یُسِرُّوْنَ وَ مَا یُعْلِنُوْنَ فَلَا يَحْزُنْكَ : پس آپ کو مغموم نہ کرے قَوْلُهُمْ ۘ : ان کی بات اِنَّا نَعْلَمُ : بیشک ہم جانتے ہیں مَا يُسِرُّوْنَ : جو وہ چھپاتے ہیں وَمَا : اور جو يُعْلِنُوْنَ : وہ ظاہر کرتے ہیں پس آپ کو ان کی بات غمناک نہ کرے، ہم ان کی پوشیدہ اور اعلانیہ سب باتوں کو (بخوبی) جانتے ہیں۔
36,77,اَوَ لَمْ یَرَ الْاِنْسَانُ اَنَّا خَلَقْنٰهُ مِنْ نُّطْفَةٍ فَاِذَا هُوَ خَصِیْمٌ مُّبِیْنٌ اَوَ : کیا لَمْ يَرَ : نہیں دیکھا الْاِنْسَانُ : انسان اَنَّا خَلَقْنٰهُ : کہ ہم نے پیدا کیا اس کو مِنْ نُّطْفَةٍ : نطفہ سے فَاِذَا : پھر ناگہاں هُوَ : وہ خَصِيْمٌ : جھگڑالو مُّبِيْنٌ : کھلا کیا انسان کو اتنا بھی معلوم نہیں کہ ہم نے اسے نطفے سے پیدا کیا ہے ؟ پھر یکایک وہ صریح جھگڑالو بن بیٹھا۔
36,78,وَ ضَرَبَ لَنَا مَثَلًا وَّ نَسِیَ خَلْقَهٗ١ؕ قَالَ مَنْ یُّحْیِ الْعِظَامَ وَ هِیَ رَمِیْمٌ وَضَرَبَ : اور اس نے بیان کی لَنَا : ہمارے لیے مَثَلًا : ایک مثال وَّنَسِيَ : اور بھول گیا خَلْقَهٗ ۭ : اپنی پیدائش قَالَ : کہنے لگا مَنْ يُّحْيِ : کون پیدا کرے گا الْعِظَامَ : ہڈیاں وَهِىَ : اور جبکہ وہ رَمِيْمٌ : گل گئیں اور اس نے ہمارے لئے مثال بیان کی اور اپنی (اصل) پیدائش کو بھول گیا، کہنے لگا ان کی گلی سڑی ہڈیوں کو کون زندہ کرسکتا ہے ؟
36,79,قُلْ یُحْیِیْهَا الَّذِیْۤ اَنْشَاَهَاۤ اَوَّلَ مَرَّةٍ١ؕ وَ هُوَ بِكُلِّ خَلْقٍ عَلِیْمُۙ قُلْ : فرما دیں يُحْيِيْهَا : اسے زندہ کرے گا الَّذِيْٓ : وہ جس نے اَنْشَاَهَآ : اسے پیدا کیا اَوَّلَ مَرَّةٍ ۭ : پہلی بار وَهُوَ : اور وہ بِكُلِّ : ہر طرح خَلْقٍ : پیدا کرنا عَلِيْمُۨ : جاننے والا آپ جواب دیجئے ! کہ انہیں وہ زندہ کرے گا جس نے اول مرتبہ پیدا کیا ہے (1) جو سب طرح کی پیدائش کا بخوبی جاننے والا ہے۔
36,80,اِ۟لَّذِیْ جَعَلَ لَكُمْ مِّنَ الشَّجَرِ الْاَخْضَرِ نَارًا فَاِذَاۤ اَنْتُمْ مِّنْهُ تُوْقِدُوْنَ الَّذِيْ : جس نے جَعَلَ : پیدا کیا لَكُمْ : تمہارے لیے مِّنَ : سے الشَّجَرِ : درخت الْاَخْضَرِ : سبز نَارًا : آگ فَاِذَآ : پس اب اَنْتُمْ : تم مِّنْهُ : اس سے تُوْقِدُوْنَ : سلگاتے ہو وہی جس نے تمہارے لئے سبز درخت سے آگ پیدا کردی جس سے تم یکایک آگ سلگاتے ہو (1)۔
36,81,اَوَ لَیْسَ الَّذِیْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ بِقٰدِرٍ عَلٰۤى اَنْ یَّخْلُقَ مِثْلَهُمْ١ؐؕ بَلٰى١ۗ وَ هُوَ الْخَلّٰقُ الْعَلِیْمُ اَوَ : کیا لَيْسَ : نہیں الَّذِيْ : وہ جس نے خَلَقَ : پیدا کیا السَّمٰوٰتِ : آسمانوں وَالْاَرْضَ : اور زمین بِقٰدِرٍ : قادر عَلٰٓي : پر اَنْ : کہ يَّخْلُقَ : وہ پیدا کرے مِثْلَهُمْ ڲ : ان جیسا بَلٰى ۤ : ہاں وَهُوَ : اور وہ الْخَلّٰقُ : بڑا پیدا کرنے والا الْعَلِيْمُ : دانا جس نے آسمانوں اور زمین کو پیدا کیا ہے کیا وہ ہم جیسوں (1) کے پیدا کرنے پر قادر نہیں، بیشک قادر ہے۔ اور وہی پیدا کرنے والا دانا (بینا) ہے۔
36,82,اِنَّمَاۤ اَمْرُهٗۤ اِذَاۤ اَرَادَ شَیْئًا اَنْ یَّقُوْلَ لَهٗ كُنْ فَیَكُوْنُ اِنَّمَآ : اس کے سوا نہیں اَمْرُهٗٓ : اس کا کام اِذَآ : جب اَرَادَ شَيْئًا : وہ ارادہ کرے کسی شے کا اَنْ : کہ يَّقُوْلَ : وہ کہتا ہے لَهٗ : اس کو كُنْ : ہوجا فَيَكُوْنُ : تو وہ ہوجاتی ہے وہ جب کبھی کسی چیز کا ارادہ کرتا ہے اسے اتنا فرما دینا (کافی ہے) کہ ہوجا، تو وہ اسی وقت ہوجاتی ہے۔ (1)
36,83,فَسُبْحٰنَ الَّذِیْ بِیَدِهٖ مَلَكُوْتُ كُلِّ شَیْءٍ وَّ اِلَیْهِ تُرْجَعُوْنَ۠    ۧ فَسُبْحٰنَ : سو پاک ہے الَّذِيْ : وہ جس بِيَدِهٖ : اس کے ہاتھ میں مَلَكُوْتُ : بادشاہت كُلِّ شَيْءٍ : ہر شے وَّاِلَيْهِ : اور اسی کی طرف تُرْجَعُوْنَ : تم لوٹ کر جاؤ گے پس پاک ہے وہ اللہ جس کے ہاتھ میں ہر چیز کی بادشاہت ہے اور (1) جس کی طرف تم سب لوٹائے جاؤ گے (1)۔
