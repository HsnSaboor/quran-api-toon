tafsir[15]{c,v,t}:
  70,40,فَلَاۤ اُقْسِمُ بِرَبِّ الْمَشٰرِقِ وَ الْمَغٰرِبِ اِنَّا لَقٰدِرُوْنَۙ فَلَآ : پس نہیں اُقْسِمُ : میں قسم کھاتا ہوں بِرَبِّ الْمَشٰرِقِ : مشرقوں کے رب کی وَالْمَغٰرِبِ : اور مغربوں کے اِنَّا لَقٰدِرُوْنَ : بیشک ہم البتہ قادر ہیں پس مجھے قسم ہے مشرقوں اور مغربوں (1) کے رب کی (کہ) ہم یقیناً قادر ہیں
  70,41,عَلٰۤى اَنْ نُّبَدِّلَ خَیْرًا مِّنْهُمْ١ۙ وَ مَا نَحْنُ بِمَسْبُوْقِیْنَ عَلٰٓي : اس بات پر اَنْ نُّبَدِّلَ : کہ ہم بدل دیں خَيْرًا مِّنْهُمْ : بہتران سے وَمَا نَحْنُ : اور نہیں ہم بِمَسْبُوْقِيْنَ : سبقت لیے جانے والے اس پر ان کے عوض ان سے اچھے لوگ لے آئیں گے اور ہم عاجز نہیں ہیں (1)
  70,42,فَذَرْهُمْ یَخُوْضُوْا وَ یَلْعَبُوْا حَتّٰى یُلٰقُوْا یَوْمَهُمُ الَّذِیْ یُوْعَدُوْنَۙ فَذَرْهُمْ : تو چھوڑ دو ان کو يَخُوْضُوْا : وہ بحثیں کریں وَيَلْعَبُوْا : اور کھیل میں پڑیں۔ کھیلتے رہیں حَتّٰى يُلٰقُوْا : یہاں تک کہ وہ آ ملیں يَوْمَهُمُ : اپنے دن کو الَّذِيْ : وہ جو يُوْعَدُوْنَ : وہ وعدہ کیے جاتے ہیں پس تو انہیں جھگڑتا کھیلتا چھوڑ دے یہاں تک کہ یہ اپنے اس دن سے جا ملیں جس کا ان سے وعدہ کیا جاتا ہے۔ (1)
  70,43,یَوْمَ یَخْرُجُوْنَ مِنَ الْاَجْدَاثِ سِرَاعًا كَاَنَّهُمْ اِلٰى نُصُبٍ یُّوْفِضُوْنَۙ يَوْمَ يَخْرُجُوْنَ : جس دن وہ نکلیں گے مِنَ الْاَجْدَاثِ : قبروں سے سِرَاعًا : دوڑتے ہوئے كَاَنَّهُمْ : گویا کہ وہ اِلٰى نُصُبٍ : طرف آستانوں کے يُّوْفِضُوْنَ : دوڑتے ہیں جس دن یہ قبروں سے دوڑتے ہوئے نکلیں گے، گویا کہ وہ کسی جگہ کی طرف تیز تیز جا رہے ہیں۔ (1)
  70,44,خَاشِعَةً اَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ١ؕ ذٰلِكَ الْیَوْمُ الَّذِیْ كَانُوْا یُوْعَدُوْنَ۠    ۧ خَاشِعَةً : دبی ہوئی ہوں گی۔ جھکی ہوئی ہوں گی اَبْصَارُهُمْ : ان کی نگاہیں تَرْهَقُهُمْ : چھا رہی ہوں گی ان پر ذِلَّةٌ : ذلت ذٰلِكَ : یہ ہے الْيَوْمُ : دن الَّذِيْ : جو كَانُوْا : وہ تھے يُوْعَدُوْنَ : وعدہ کیے گئے ان کی آنکھیں جھکی ہوئی ہونگیں (1) ان پر ذلت چھا رہی ہوگی (2) یہ ہے وہ دن جس کا ان سے وعدہ کیا جاتا تھا (3)۔
  71,1,اِنَّاۤ اَرْسَلْنَا نُوْحًا اِلٰى قَوْمِهٖۤ اَنْ اَنْذِرْ قَوْمَكَ مِنْ قَبْلِ اَنْ یَّاْتِیَهُمْ عَذَابٌ اَلِیْمٌ اِنَّآ : بیشک ہم نے اَرْسَلْنَا : بھیجا ہم نے نُوْحًا : نوح کو اِلٰى قَوْمِهٖٓ : اس کی قوم کی طرف اَنْ اَنْذِرْ : کہ ڈراؤ قَوْمَكَ : اپنی قوم کو مِنْ : سے قَبْلِ : اس سے پہلے اَنْ يَّاْتِيَهُمْ : کہ آئے ان کے پاس عَذَابٌ اَلِيْمٌ : عذاب دردناک یقیناً ہم نے نوح ؑ کو ان کی قوم کی طرف (1) بھیجا کہ اپنی قوم کو ڈرا دو (اور خبردار کردو) اس سے پہلے کہ ان کے پاس دردناک عذاب آجائے (2)
  71,2,قَالَ یٰقَوْمِ اِنِّیْ لَكُمْ نَذِیْرٌ مُّبِیْنٌۙ قَالَ : اس نے کہا يٰقَوْمِ : اے میری قوم اِنِّىْ : بیشک میں لَكُمْ : بیشک میں نَذِيْرٌ مُّبِيْنٌ : ڈرانے والا ہوں کھلم کھلا (نوح ؑ نے) کہا اے میری قوم ! میں تمہیں صاف صاف ڈرانے والا ہوں۔ (1)
  71,3,اَنِ اعْبُدُوا اللّٰهَ وَ اتَّقُوْهُ وَ اَطِیْعُوْنِۙ اَنِ اعْبُدُوا اللّٰهَ : کہ عبادت کرو اللہ کی وَاتَّقُوْهُ : اور ڈرو اس سے وَاَطِيْعُوْنِ : اور اطاعت کرو میری کہ تم اللہ کی عبادت کرو (1) اور اسی سے ڈرو (2) اور میرا کہنا مانو۔ (3)
  71,4,یَغْفِرْ لَكُمْ مِّنْ ذُنُوْبِكُمْ وَ یُؤَخِّرْكُمْ اِلٰۤى اَجَلٍ مُّسَمًّى١ؕ اِنَّ اَجَلَ اللّٰهِ اِذَا جَآءَ لَا یُؤَخَّرُ١ۘ لَوْ كُنْتُمْ تَعْلَمُوْنَ يَغْفِرْ لَكُمْ : بخش دے گا تمہارے لیے مِّنْ ذُنُوْبِكُمْ : تمہارے گناہوں میں سے وَيُؤَخِّرْكُمْ : اور مہلت دے گا تم کو اِلٰٓى : تک اَجَلٍ مُّسَمًّى : مقرر وقت تک اِنَّ اَجَلَ اللّٰهِ : بیشک اللہ کا مقرر کیا ہوا وقت اِذَا جَآءَ : جب آجاتا ہے لَا يُؤَخَّرُ : تو ڈھیل نہیں دی جاتی۔ تاخیر نہیں کی جاتی لَوْ كُنْتُمْ : اگر ہو تم تَعْلَمُوْنَ : تم جانتے تو وہ خود تمہارے گناہ بخش دے گا اور تمہیں ایک وقت مقرہ تک چھوڑ دے گا یقیناً اللہ کا وعدہ جب آجاتا ہے تو مؤخر نہیں ہوتا کاش تمہیں سمجھ ہوتی۔ (1)
  71,5,قَالَ رَبِّ اِنِّیْ دَعَوْتُ قَوْمِیْ لَیْلًا وَّ نَهَارًاۙ قَالَ رَبِّ : اس نے کہا اے میرے رب اِنِّىْ : بیشک میں نے دَعَوْتُ : میں نے پکارا قَوْمِيْ : اپنی قوم کو لَيْلًا وَّنَهَارًا : رات کو اور دن کو (نوح ؑ نے) کہا اے میرے پروردگار ! میں نے اپنی قوم کو رات دن تیری طرف بلایا ہے (1)۔
  71,6,فَلَمْ یَزِدْهُمْ دُعَآءِیْۤ اِلَّا فِرَارًا فَلَمْ يَزِدْهُمْ : تو نہ زیادہ کیا ان کو دُعَآءِيْٓ : میری پکارنے اِلَّا فِرَارًا : مگر فرار میں مگر میرے بلانے سے یہ لوگ اور زیادہ بھاگنے لگے (1)۔
  71,7,وَ اِنِّیْ كُلَّمَا دَعَوْتُهُمْ لِتَغْفِرَ لَهُمْ جَعَلُوْۤا اَصَابِعَهُمْ فِیْۤ اٰذَانِهِمْ وَ اسْتَغْشَوْا ثِیَابَهُمْ وَ اَصَرُّوْا وَ اسْتَكْبَرُوا اسْتِكْبَارًاۚ وَاِنِّىْ : اور بیشک میں نے كُلَّمَا : جب کبھی دَعَوْتُهُمْ : میں نے پکارا ان کو لِتَغْفِرَ لَهُمْ : تاکہ تو بخش دے ان کو جَعَلُوْٓا : انہوں نے ڈال لیں اَصَابِعَهُمْ : اپنی انگلیاں فِيْٓ اٰذَانِهِمْ : اپنے کانوں میں وَاسْتَغْشَوْا : اور اوڑھ لیے۔ ڈھانپ لیے ثِيَابَهُمْ : کپڑے اپنے وَاَصَرُّوْا : اور انہوں نے اصرار کیا وَاسْتَكْبَرُوا : اور تکبر کیا اسْتِكْبَارًا : تکبر کرنا میں نے جب کبھی انہیں تیری بخشش کے لئے بلایا (1) انہوں نے اپنی انگلیاں اپنے کانوں میں ڈال لیں (2) اور اپنے کپڑوں کو اوڑھ لیا اور اڑ گئے (3) اور پھر بڑا تکبر کیا، (4)
  71,8,ثُمَّ اِنِّیْ دَعَوْتُهُمْ جِهَارًاۙ ثُمَّ : پھر اِنِّىْ : بیشک میں دَعَوْتُهُمْ : میں نے پکارا ان کو جِهَارًا : اعلانیہ پھر میں نے انہیں با آواز بلند بلایا۔
  71,9,ثُمَّ اِنِّیْۤ اَعْلَنْتُ لَهُمْ وَ اَسْرَرْتُ لَهُمْ اِسْرَارًاۙ ثُمَّ : پھر اِنِّىْٓ : بیشک میں نے اَعْلَنْتُ لَهُمْ : اعلانیہ (تبلیغ) کی ان کو وَاَسْرَرْتُ لَهُمْ : اور چپکے چپکے کی ان کے لیے اِسْرَارًا : تنہائی میں کرنا بیشک میں نے ان سے اعلانیہ بھی کہا اور چپکے چپکے بھی (1)۔
  71,10,فَقُلْتُ اسْتَغْفِرُوْا رَبَّكُمْ١ؕ اِنَّهٗ كَانَ غَفَّارًاۙ فَقُلْتُ : پھر میں نے کہا اسْتَغْفِرُوْا : بخشش مانگو رَبَّكُمْ : اپنے رب سے اِنَّهٗ : بیشک وہ كَانَ غَفَّارًا : بخشنے والا ہے اور میں نے کہا کہ اپنے رب سے اپنے گناہ بخشواؤ (1) (اور معافی مانگو) وہ یقیناً بڑا بخشنے والا ہے (2)
