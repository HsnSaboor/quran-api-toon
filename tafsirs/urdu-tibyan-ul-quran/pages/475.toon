tafsir[11]{c,v,t}:
  40,67,هُوَ الَّذِیْ خَلَقَكُمْ مِّنْ تُرَابٍ ثُمَّ مِنْ نُّطْفَةٍ ثُمَّ مِنْ عَلَقَةٍ ثُمَّ یُخْرِجُكُمْ طِفْلًا ثُمَّ لِتَبْلُغُوْۤا اَشُدَّكُمْ ثُمَّ لِتَكُوْنُوْا شُیُوْخًا١ۚ وَ مِنْكُمْ مَّنْ یُّتَوَفّٰى مِنْ قَبْلُ وَ لِتَبْلُغُوْۤا اَجَلًا مُّسَمًّى وَّ لَعَلَّكُمْ تَعْقِلُوْنَ هُوَ : وہ الَّذِيْ : جس نے خَلَقَكُمْ : پیدا کیا تمہیں مِّنْ تُرَابٍ : مٹی سے ثُمَّ مِنْ نُّطْفَةٍ : پھر نطفہ سے ثُمَّ مِنْ عَلَقَةٍ : پھر لوتھڑے سے ثُمَّ : پھر يُخْرِجُكُمْ : تمہیں نکالتا ہے وہ طِفْلًا : بچہ سا ثُمَّ لِتَبْلُغُوْٓا : پھر تاکہ تم پہنچو اَشُدَّكُمْ : اپنی جوانی ثُمَّ لِتَكُوْنُوْا : پھر تاکہ تم ہوجاؤ شُيُوْخًا ۚ : بوڑھے وَمِنْكُمْ : اور تم میں سے مَّنْ يُّتَوَفّٰى : جو فوت ہوجاتا ہے مِنْ قَبْلُ : اس سے قبل وَلِتَبْلُغُوْٓا : اور تاکہ پہنچو اَجَلًا مُّسَمًّى : وقت مقررہ وَّلَعَلَّكُمْ : اور تاکہ تم تَعْقِلُوْنَ : سمجھو وہ وہی ہے جس نے تمہیں مٹی سے پھر نطفے سے (1) پھر خون کے لوتھڑے سے پیدا کیا پھر تمہیں بچہ کی صورت میں نکالتا ہے، پھر (تمہیں بڑھاتا ہے کہ) تم اپنی پوری قوت کو پہنچ جاؤ پھر بوڑھے ہوجاؤ (2) تم میں سے بعض اس سے پہلے ہی فوت ہوجاتے ہیں (3) (وہ تمہیں چھوڑ دیتا ہے) تاکہ تم مدت معین تک پہنچ جاؤ (4) اور تاکہ تم سوچ سمجھ لو۔ (5)
  40,68,هُوَ الَّذِیْ یُحْیٖ وَ یُمِیْتُ١ۚ فَاِذَا قَضٰۤى اَمْرًا فَاِنَّمَا یَقُوْلُ لَهٗ كُنْ فَیَكُوْنُ۠    ۧ هُوَ : وہی ہے الَّذِيْ : جو يُحْيٖ : جِلاتا ہے وَيُمِيْتُ ۚ : اور مارتا ہے فَاِذَا : پھر جب قَضٰٓى : وہ فیصلہ کرتا ہے اَمْرًا : کسی کام کا فَاِنَّمَا : تو اس کے سوا نہیں يَقُوْلُ : وہ کہتا ہے لَهٗ : اس کے لئے كُنْ : تو ہوجا فَيَكُوْنُ : سو وہ ہوجاتا ہے وہی ہے جو جلاتا ہے اور مار ڈالتا ہے (1) پھر وہ جب کسی کام کا کرنا مقرر کرتا ہے تو اسے صرف کہتا ہے ہوجا پس وہ ہوجاتا ہے۔ (2)
  40,69,اَلَمْ تَرَ اِلَى الَّذِیْنَ یُجَادِلُوْنَ فِیْۤ اٰیٰتِ اللّٰهِ١ؕ اَنّٰى یُصْرَفُوْنَ٤ۖۛۚ اَلَمْ تَرَ : کیا نہیں دیکھا تم نے اِلَى : طرف الَّذِيْنَ : جو لوگ يُجَادِلُوْنَ : جھگڑتے ہیں فِيْٓ : میں اٰيٰتِ اللّٰهِ ۭ : اللہ کی آیات اَنّٰى : کہاں يُصْرَفُوْنَ : پھرے جاتے ہیں کیا تو نے نہیں دیکھا جو اللہ کی آیتوں میں جھگڑتے ہیں (1) وہ کہاں پھیر دئیے جاتے ہیں (2)
  40,70,الَّذِیْنَ كَذَّبُوْا بِالْكِتٰبِ وَ بِمَاۤ اَرْسَلْنَا بِهٖ رُسُلَنَا١ۛ۫ فَسَوْفَ یَعْلَمُوْنَۙ الَّذِيْنَ : جن لوگوں نے كَذَّبُوْا : جھٹلایا بِالْكِتٰبِ : کتاب کو وَبِمَآ : اور اس کو جو اَرْسَلْنَا : ہم نے بھیجا بِهٖ : اسکے ساتھ رُسُلَنَا ڕ : اپنے رسول فَسَوْفَ : پس جلد يَعْلَمُوْنَ : وہ جان لیں گے جن لوگوں نے کتاب کو جھٹلایا اور اسے بھی جو ہم نے اپنے رسولوں کے ساتھ بھیجا انہیں ابھی ابھی حقیقت حال معلوم ہوجائے گی۔
  40,71,اِذِ الْاَغْلٰلُ فِیْۤ اَعْنَاقِهِمْ وَ السَّلٰسِلُ١ؕ یُسْحَبُوْنَۙ اِذِ الْاَغْلٰلُ : جب طوق (جمع) فِيْٓ اَعْنَاقِهِمْ : ان کی گردنوں میں وَالسَّلٰسِلُ ۭ : اور زنجیریں يُسْحَبُوْنَ : وہ گھسیٹے جائیں گے جب ان کی گردنوں میں طوق ہونگے اور زنجریں ہوں گی گھسیٹے جائیں گے (1)
  40,72,فِی الْحَمِیْمِ١ۙ۬ ثُمَّ فِی النَّارِ یُسْجَرُوْنَۚ فِي : میں الْحَمِيْمِ : کھولتے ہوئے پانی ثُمَّ : پھر فِي النَّارِ : آگ میں يُسْجَرُوْنَ : وہ جھونک دئیے جائیں گے کھولتے ہوئے پانی میں اور پھر جہنم کی آگ میں جلائے جائیں گے۔
  40,73,ثُمَّ قِیْلَ لَهُمْ اَیْنَ مَا كُنْتُمْ تُشْرِكُوْنَۙ ثُمَّ : پھر قِيْلَ : کہا جائے گا لَهُمْ : ان کو اَيْنَ : کہاں مَا كُنْتُمْ : جن کو تم تھے تُشْرِكُوْنَ : شریک کرتے پھر ان سے پوچھا جائے گا کہ جنہیں تم شریک کرتے تھے وہ کہاں ہیں ؟
  40,74,مِنْ دُوْنِ اللّٰهِ١ؕ قَالُوْا ضَلُّوْا عَنَّا بَلْ لَّمْ نَكُنْ نَّدْعُوْا مِنْ قَبْلُ شَیْئًا١ؕ كَذٰلِكَ یُضِلُّ اللّٰهُ الْكٰفِرِیْنَ مِنْ دُوْنِ اللّٰهِ ۭ : اللہ کے سوا قَالُوْا : وہ کہیں گے ضَلُّوْا : وہ گم ہوگئے عَنَّا : ہم سے بَلْ لَّمْ : بلکہ نہیں نَكُنْ نَّدْعُوْا : پکارتے تھے ہم مِنْ قَبْلُ : اس سے قبل شَيْئًا ۭ : کوئی چیز كَذٰلِكَ : اسی طرح يُضِلُّ : گمراہ کرتا ہے اللّٰهُ : اللہ الْكٰفِرِيْنَ : کافروں کو جو اللہ کے سوا تھے (1) وہ کہیں گے کہ وہ تو ہم سے بہک گئے (2) بلکہ ہم تو اس سے پہلے کسی کو بھی پکارتے ہی نہ تھے (3) اللہ تعالیٰ کافروں کو اسی طرح گمراہ کرتا ہے۔ (4)
  40,75,ذٰلِكُمْ بِمَا كُنْتُمْ تَفْرَحُوْنَ فِی الْاَرْضِ بِغَیْرِ الْحَقِّ وَ بِمَا كُنْتُمْ تَمْرَحُوْنَۚ ذٰلِكُمْ : یہ بِمَا كُنْتُمْ : اس کا بدلہ جو تَفْرَحُوْنَ : تم خوش ہوتے تھے فِي الْاَرْضِ : زمین میں بِغَيْرِ الْحَقِّ : ناحق وَبِمَا : اور بدلہ اس کا جو كُنْتُمْ : تم تھے تَمْرَحُوْنَ : اتراتے یہ بدلہ ہے اس چیز کا جو تم زمین میں ناحق پھولے نہ سماتے تھے۔ اور بےجا اتراتے پھرتے تھے۔
  40,76,اُدْخُلُوْۤا اَبْوَابَ جَهَنَّمَ خٰلِدِیْنَ فِیْهَا١ۚ فَبِئْسَ مَثْوَى الْمُتَكَبِّرِیْنَ اُدْخُلُوْٓا : تم داخل ہوجاؤ اَبْوَابَ جَهَنَّمَ : جہنم کے دروازے خٰلِدِيْنَ : ہمیشہ رہنے کو فِيْهَا ۚ : اس میں فَبِئْسَ : سو بُرا مَثْوَى : ٹھکانا الْمُتَكَبِّرِيْنَ : تکبر کرنے (بڑا بننے) والوں کا اب آؤ جہنم میں ہمیشہ رہنے کے لئے (اس کے) دروازوں میں داخل ہوجاؤ کیا ہی بری جگہ ہے تکبر کرنے والوں کی (1)
  40,77,فَاصْبِرْ اِنَّ وَعْدَ اللّٰهِ حَقٌّ١ۚ فَاِمَّا نُرِیَنَّكَ بَعْضَ الَّذِیْ نَعِدُهُمْ اَوْ نَتَوَفَّیَنَّكَ فَاِلَیْنَا یُرْجَعُوْنَ فَاصْبِرْ : پس آپ صبر کریں اِنَّ وَعْدَ اللّٰهِ : بیشک اللہ کا وعدہ حَقٌّ ۚ : سچا فَاِمَّا : پس اگر نُرِيَنَّكَ : ہم آپ کو دکھادیں بَعْضَ : بعض (کچھ حصہ) الَّذِيْ : وہ جو نَعِدُهُمْ : ہم ان سے وعدہ کرتے تھے اَوْ نَتَوَفَّيَنَّكَ : یا ہم آپ کو وفات دیدیں فَاِلَيْنَا : پس ہماری طرف يُرْجَعُوْنَ : وہ لوٹائے جائیں گے پس آپ صبر کریں اللہ کا وعدہ قطعًا سچا ہے (1) انہیں ہم نے جو وعدے دے رکھے ہیں ان میں سے کچھ ہم کو دکھائیں (2) یا (اس سے پہلے) ہم آپ کو وفات دے دیں، ان کا لوٹایا جانا تو ہماری ہی طرف ہے۔ (3)
