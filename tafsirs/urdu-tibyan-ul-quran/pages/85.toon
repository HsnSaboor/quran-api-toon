quran[22]{c,v,t}:
85,1,وَ السَّمَآءِ ذَاتِ الْبُرُوْجِۙ وَالسَّمَآءِ : قسم آسمان کی ذَاتِ الْبُرُوْجِ : برجوں والا برجوں والے آسمان کی قسم (1)
85,2,وَ الْیَوْمِ الْمَوْعُوْدِۙ وَالْيَوْمِ : اور دن کی الْمَوْعُوْدِ : وعدہ کئے ہوئے وعدہ کئے ہوئے دن کی قسم ! (1)
85,3,وَ شَاهِدٍ وَّ مَشْهُوْدٍؕ وَشَاهِدٍ : اور حاضر ہونیوالا وَّمَشْهُوْدٍ : اور جہاں حاضر ہوتے ہیں حاضر ہونے والے اور حاضر کئے گئے کی قسم (1)
85,4,قُتِلَ اَصْحٰبُ الْاُخْدُوْدِۙ قُتِلَ : ہلاک کردئے گئے اَصْحٰبُ : والے الْاُخْدُوْدِ : خندق (جمع) (کہ) خندقوں والے ہلاک کئے گئے (1)
85,5,النَّارِ ذَاتِ الْوَقُوْدِۙ النَّارِ : آگ ذَاتِ الْوَقُوْدِ : ایندھن والی وہ ایک آگ تھی ایندھن والی (1)
85,6,اِذْ هُمْ عَلَیْهَا قُعُوْدٌۙ اِذْ هُمْ : جب وہ عَلَيْهَا : اس پر قُعُوْدٌ : بیٹھے تھے جبکہ وہ لوگ اس کے آس پاس بیٹھے تھے (1)
85,7,وَّ هُمْ عَلٰى مَا یَفْعَلُوْنَ بِالْمُؤْمِنِیْنَ شُهُوْدٌؕ وَّهُمْ : اور وہ عَلٰي مَا يَفْعَلُوْنَ : پر جو وہ کرتے تھے بِالْمُؤْمِنِيْنَ : مومنوں کے ساتھ شُهُوْدٌ : دیکھتے اور مسلمانوں کے ساتھ جو کر رہے تھے اس کو اپنے سامنے دیکھ رہے تھے۔
85,8,وَ مَا نَقَمُوْا مِنْهُمْ اِلَّاۤ اَنْ یُّؤْمِنُوْا بِاللّٰهِ الْعَزِیْزِ الْحَمِیْدِۙ وَمَا نَقَمُوْا : اور نہیں بدلہ لیا مِنْهُمْ : ان سے اِلَّآ : مگر اَنْ : کہ يُّؤْمِنُوْا : وہ ایمان لائے بِاللّٰهِ : اللہ پر الْعَزِيْزِ : زبردست الْحَمِيْدِ : تعریفوں والا یہ لوگ ان مسلمانوں (کے کسی اور گناہ) کا بدلہ نہیں لے رہے تھے، سوائے اس کے کہ وہ اللہ غالب لائق حمد کی ذات پر ایمان لائے تھے (1)
85,9,الَّذِیْ لَهٗ مُلْكُ السَّمٰوٰتِ وَ الْاَرْضِ١ؕ وَ اللّٰهُ عَلٰى كُلِّ شَیْءٍ شَهِیْدٌؕ الَّذِيْ : وہ جو کہ لَهٗ : اسکے لئے مُلْكُ : بادشاہت السَّمٰوٰتِ : آسمان (جمع) وَالْاَرْضِ ۭ : اور زمین وَاللّٰهُ : اور اللہ عَلٰي كُلِّ شَيْءٍ : ہر چیز پر شَهِيْدٌ : سامنے (باخبر) جس کے لئے آسمان و زمین کا ملک ہے۔ اور اللہ تعالیٰ کے سامنے ہے ہر چیز۔
85,10,اِنَّ الَّذِیْنَ فَتَنُوا الْمُؤْمِنِیْنَ وَ الْمُؤْمِنٰتِ ثُمَّ لَمْ یَتُوْبُوْا فَلَهُمْ عَذَابُ جَهَنَّمَ وَ لَهُمْ عَذَابُ الْحَرِیْقِؕ اِنَّ الَّذِيْنَ : بیشک وہ جو فَتَنُوا : تکلیفیں دیں الْمُؤْمِنِيْنَ : مومن (جمع) مرد وَالْمُؤْمِنٰتِ : مومن عورتیں ثُمَّ : پھر لَمْ يَتُوْبُوْا : انہوں نے توبہ نہ کی فَلَهُمْ : تو ان کے لئے عَذَابُ : عذاب جَهَنَّمَ : جہنم وَلَهُمْ : اور ان کے لئے عَذَابُ : عذاب الْحَرِيْقِ : جلنا بیشک جن لوگوں نے مسلمان مردوں اور عورتوں کو ستایا پھر توبہ (بھی) نہ کی تو ان کے لئے جہنم کا عذاب ہے اور جلنے کا عذاب ہے۔
85,11,اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ لَهُمْ جَنّٰتٌ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ١ۣؕ۬ ذٰلِكَ الْفَوْزُ الْكَبِیْرُؕ اِنَّ : بیشک الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کئے الصّٰلِحٰتِ : اچھے لَهُمْ : ان کے لئے جَنّٰتٌ : باغات تَجْرِيْ : جاری ہیں مِنْ تَحْتِهَا : ان کے نیچے سے الْاَنْهٰرُ ۀ : نہریں ذٰلِكَ الْفَوْزُ : یہ کامیابی الْكَبِيْرُ : بڑی بیشک ایمان قبول کرنے والوں اور نیک کام کرنے والوں کے لئے وہ باغات ہیں جن کے نیچے نہریں بہہ رہی ہیں۔
85,12,اِنَّ بَطْشَ رَبِّكَ لَشَدِیْدٌؕ اِنَّ بَطْشَ : بیشک پکڑ رَبِّكَ : تمہارا رب لَشَدِيْدٌ : بڑی سخت یقیناً تیرے رب کی پکڑ بڑی سخت ہے۔ (1)
85,13,اِنَّهٗ هُوَ یُبْدِئُ وَ یُعِیْدُۚ اِنَّهٗ : بیشک وہ هُوَ : وہی يُبْدِئُ : پہلی بار پیدا کرتا ہے وَيُعِيْدُ : اور لوٹاتا ہے وہی پہلی مرتبہ پیدا کرتا ہے وہی دوبارہ پیدا کرے گا۔ (1)
85,14,وَ هُوَ الْغَفُوْرُ الْوَدُوْدُۙ وَهُوَ الْغَفُوْرُ : اور وہ بخشنے والا الْوَدُوْدُ : محبت والا وہ بڑا بخشش کرنے والا اور بہت محبت کرنے والا ہے۔
85,15,ذُو الْعَرْشِ الْمَجِیْدُۙ ذُو الْعَرْشِ : عرش والا (مالک) الْمَجِيْدُ : بڑی شان والا عرش کا مالک عظمت والا ہے۔ (1)
85,16,فَعَّالٌ لِّمَا یُرِیْدُؕ فَعَّالٌ : کر ڈالنے والا لِّمَا يُرِيْدُ : جو وہ چاہے جو چاہے اسے کر گزرنے والا ہے (1)
85,17,هَلْ اَتٰىكَ حَدِیْثُ الْجُنُوْدِۙ هَلْ : کیا اَتٰىكَ : تجھ تک آئی (پہنچی) حَدِيْثُ : بات الْجُنُوْدِ : لشکر (جمع) تجھے لشکروں کی خبر ملی ہے ؟ (1)
85,18,فِرْعَوْنَ وَ ثَمُوْدَؕ فِرْعَوْنَ وَثَمُوْدَ : فرعون اور ثمود (یعنی) فرعون اور ثمود کی۔
85,19,بَلِ الَّذِیْنَ كَفَرُوْا فِیْ تَكْذِیْبٍۙ بَلِ : بلکہ الَّذِيْنَ : وہ جو کہ كَفَرُوْا : انہوں نے کفر کیا فِيْ تَكْذِيْبٍ : جھٹلانے میں (کچھ نہیں) بلکہ کافر جھٹلانے میں پڑے ہوئے ہیں۔
85,20,وَّ اللّٰهُ مِنْ وَّرَآئِهِمْ مُّحِیْطٌۚ وَّاللّٰهُ : اور اللہ مِنْ وَّرَآئِهِمْ : انکے ہر طرف سے مُّحِيْطٌ : گھیرے ہوئے اور اللہ تعالیٰ بھی انہیں ہر طرف سے گھیرے ہوئے ہے۔ (1)
85,21,بَلْ هُوَ قُرْاٰنٌ مَّجِیْدٌۙ بَلْ هُوَ قُرْاٰنٌ : بلکہ وہ قرآن مَّجِيْدٌ : بڑی شان والا بلکہ یہ قرآن ہے بڑی شان والا۔
85,22,فِیْ لَوْحٍ مَّحْفُوْظٍ۠    ۧ فِيْ : میں لَوْحٍ مَّحْفُوْظٍ : لوح محفوظ لوح محفوظ میں لکھا ہوا ہے (1)
