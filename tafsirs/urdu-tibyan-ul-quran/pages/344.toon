tafsir[15]{c,v,t}:
  23,28,فَاِذَا اسْتَوَیْتَ اَنْتَ وَ مَنْ مَّعَكَ عَلَى الْفُلْكِ فَقُلِ الْحَمْدُ لِلّٰهِ الَّذِیْ نَجّٰىنَا مِنَ الْقَوْمِ الظّٰلِمِیْنَ فَاِذَا : پھر جب اسْتَوَيْتَ : تم بیٹھ جاؤ اَنْتَ : تم وَمَنْ : اور جو مَّعَكَ : تیرے ساتھ (ساتھی) عَلَي : پر الْفُلْكِ : کشتی فَقُلِ : تو کہنا الْحَمْدُ : تمام تعریفیں لِلّٰهِ : اللہ کے لیے الَّذِيْ : وہ جس نے نَجّٰىنَا : ہمیں نجات دی مِنَ : سے الْقَوْمِ : قوم الظّٰلِمِيْنَ : ظالم (جمع) جب تو اور تیرے ساتھی کشتی پر باطمینان بیٹھ جاؤ تو کہنا کہ سب تعریف اللہ کے لئے ہی ہے جس نے ہمیں ظالم لوگوں سے نجات عطا فرمائی۔
  23,29,وَ قُلْ رَّبِّ اَنْزِلْنِیْ مُنْزَلًا مُّبٰرَكًا وَّ اَنْتَ خَیْرُ الْمُنْزِلِیْنَ وَقُلْ : اور کہو رَّبِّ : اے میرے رب اَنْزِلْنِيْ : مجھے اتار مُنْزَلًا : منزل مُّبٰرَكًا : مبارک وَّاَنْتَ : اور تو خَيْرُ : بہترین الْمُنْزِلِيْنَ : اتارنے والے اور کہنا کہ اے میرے رب ! 1 مجھے بابرکت اتارنا اتار اور تو ہی بہتر ہے اتارنے والوں میں 2۔
  23,30,اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ وَّ اِنْ كُنَّا لَمُبْتَلِیْنَ اِنَّ : بیشک فِيْ ذٰلِكَ : اس میں لَاٰيٰتٍ : البتہ نشانیاں وَّاِنْ كُنَّا : اور بیشک ہم ہیں لَمُبْتَلِيْنَ : آزمائش یقیناً اس میں بڑی بڑی نشانیاں ہیں 1 اور ہم بیشک آزمائش کرنے والے ہیں 2۔
  23,31,ثُمَّ اَنْشَاْنَا مِنْۢ بَعْدِهِمْ قَرْنًا اٰخَرِیْنَۚ ثُمَّ : پھر اَنْشَاْنَا : ہم نے پیدا کیا مِنْۢ بَعْدِهِمْ : ان کے بعد قَرْنًا : گروہ اٰخَرِيْنَ : دوسرا پھر ان کے بعد ہم نے ایک اور امت پیدا کی 1
  23,32,فَاَرْسَلْنَا فِیْهِمْ رَسُوْلًا مِّنْهُمْ اَنِ اعْبُدُوا اللّٰهَ مَا لَكُمْ مِّنْ اِلٰهٍ غَیْرُهٗ١ؕ اَفَلَا تَتَّقُوْنَ۠    ۧ فَاَرْسَلْنَا : پھر بھیجے ہم نے فِيْهِمْ : ان کے درمیان رَسُوْلًا : رسول (جمع) مِّنْهُمْ : ان میں سے اَنِ : کہ اعْبُدُوا : تم عبادت کرو اللّٰهَ : اللہ مَا لَكُمْ : نہیں تمہارے لیے مِّنْ اِلٰهٍ : کوئی معبود غَيْرُهٗ : اس کے سوا اَفَلَا تَتَّقُوْنَ : کیا پھر تم ڈرتے نہیں پھر ان میں خود ان میں سے (ہی) رسول بھی بھیجا 1 کہ تم سب اللہ کی عبادت کرو اس کے سوا تمہارا کوئی معبود نہیں 2 تم کیوں نہیں ڈرتے ؟
  23,33,وَ قَالَ الْمَلَاُ مِنْ قَوْمِهِ الَّذِیْنَ كَفَرُوْا وَ كَذَّبُوْا بِلِقَآءِ الْاٰخِرَةِ وَ اَتْرَفْنٰهُمْ فِی الْحَیٰوةِ الدُّنْیَا١ۙ مَا هٰذَاۤ اِلَّا بَشَرٌ مِّثْلُكُمْ١ۙ یَاْكُلُ مِمَّا تَاْكُلُوْنَ مِنْهُ وَ یَشْرَبُ مِمَّا تَشْرَبُوْنَ۪ۙ وَقَالَ : اور کہا الْمَلَاُ : سرداروں مِنْ قَوْمِهِ : اس کی قوم کے الَّذِيْنَ : وہ جنہوں نے كَفَرُوْا : کفر کیا وَكَذَّبُوْا : اور جھٹلایا بِلِقَآءِ : حاضری کو الْاٰخِرَةِ : آخرت وَاَتْرَفْنٰهُمْ : اور ہم نے انہیں عیش دیا فِي : میں الْحَيٰوةِ الدُّنْيَا : دنیا کی زندگی مَا ھٰذَآ : یہ نہیں اِلَّا : مگر بَشَرٌ : ایک بشر مِّثْلُكُمْ : تمہیں جیسا يَاْكُلُ : وہ کھاتا ہے مِمَّا : اس سے جو تَاْكُلُوْنَ : تم کھاتے ہو مِنْهُ : اس سے وَيَشْرَبُ : اور پیتا ہے مِمَّا : اس سے جو تَشْرَبُوْنَ : تم پیتے ہو اور سردار قوم 1 نے جواب دیا، جو کفر کرتے تھے اور آخرت کی ملاقات کو جھٹلاتے تھے اور ہم نے انھیں دنیاوی زندگی میں خوشحال کر رکھا تھا 2 کہ یہ تو تم جیسا ہی انسان ہے، تمہاری ہی خوراک یہ بھی کھاتا ہے اور تمہارے پینے کا پانی ہی یہ بھی پیتا ہے 3۔
  23,34,وَ لَئِنْ اَطَعْتُمْ بَشَرًا مِّثْلَكُمْ اِنَّكُمْ اِذًا لَّخٰسِرُوْنَۙ وَلَئِنْ : اور اگر اَطَعْتُمْ : تم نے اطاعت کی بَشَرًا : ایک بشر مِّثْلَكُمْ : اپنے جیسا اِنَّكُمْ : بیشک تم اِذًا : اس وقت لَّخٰسِرُوْنَ : گھاٹے میں رہو گے اگر تم نے اپنے جیسے ہی انسان کی تابعداری کرلی تو بیشک تم سخت خسارے والے ہو 1۔
  23,35,اَیَعِدُكُمْ اَنَّكُمْ اِذَا مِتُّمْ وَ كُنْتُمْ تُرَابًا وَّ عِظَامًا اَنَّكُمْ مُّخْرَجُوْنَ۪ۙ اَيَعِدُكُمْ : کیا وہ وعدہ دیتا ہے تمہیں اَنَّكُمْ : کہ تم اِذَا : جب مِتُّمْ : مرگئے وَكُنْتُمْ : اور تم ہوگئے تُرَابًا : مٹی وَّعِظَامًا : اور ہڈیاں اَنَّكُمْ : تو تم مُّخْرَجُوْنَ : نکالے جاؤگے کیا یہ تمہیں اس بات کا وعدہ کرتا ہے کہ جب تم مر کر صرف خاک اور ہڈی رہ جاؤ گے تو تم پھر زندہ کیے جاؤ گے۔
  23,36,هَیْهَاتَ هَیْهَاتَ لِمَا تُوْعَدُوْنَ۪ۙ هَيْهَاتَ : بعید ہے هَيْهَاتَ : بعید ہے لِمَا : وہ جو تُوْعَدُوْنَ : تمہیں وعدہ دیا جاتا ہے نہیں نہیں دور اور بہت دور ہے وہ جس کا تم وعدہ دیے جاتے ہو 1۔
  23,37,اِنْ هِیَ اِلَّا حَیَاتُنَا الدُّنْیَا نَمُوْتُ وَ نَحْیَا وَ مَا نَحْنُ بِمَبْعُوْثِیْنَ۪ۙ اِنْ هِىَ : نہیں اِلَّا : مگر حَيَاتُنَا : ہماری زندگی الدُّنْيَا : دنیا نَمُوْتُ : اور ہم مرتے ہیں وَنَحْيَا : اور ہم جیتے ہیں وَمَا : اور نہیں نَحْنُ : ہم بِمَبْعُوْثِيْنَ : پھر اٹھائے جانے والے (زندگی) تو صرف دنیا کی زندگی ہے ہم مرتے جیتے رہتے ہیں اور یہ نہیں کہ ہم اٹھائے جائیں گے۔
  23,38,اِنْ هُوَ اِلَّا رَجُلُ اِ۟فْتَرٰى عَلَى اللّٰهِ كَذِبًا وَّ مَا نَحْنُ لَهٗ بِمُؤْمِنِیْنَ اِنْ : نہیں هُوَ : وہ اِلَّا : مگر رَجُلُ : ایک آدمی ۨ افْتَرٰى : اس نے جھوٹ باندھا عَلَي اللّٰهِ : اللہ پر كَذِبًا : جھوٹ وَّمَا : اور نہیں نَحْنُ : ہم لَهٗ : اس پر بِمُؤْمِنِيْنَ : ایمان لانے والے یہ تو بس ایسا شخص ہے جس نے اللہ پر جھوٹ (بہتان) باندھ لیا ہے، 1 ہم تو اس پر ایمان لانے والے نہیں ہیں۔
  23,39,قَالَ رَبِّ انْصُرْنِیْ بِمَا كَذَّبُوْنِ قَالَ : اس نے عرض کیا رَبِّ : میرے رب انْصُرْنِيْ : میری مدد فرما بِمَا : اس پر جو كَذَّبُوْنِ : انہوں نے مجھے جھٹلایا نبی نے دعا کی کہ پروردگار ! ان کے جھٹلانے پر میری مدد کر 1
  23,40,قَالَ عَمَّا قَلِیْلٍ لَّیُصْبِحُنَّ نٰدِمِیْنَۚ قَالَ : اس نے فرمایا عَمَّا قَلِيْلٍ : بہت جلد لَّيُصْبِحُنَّ : وہ ضرور رہ جائیں گے نٰدِمِيْنَ : پچھتانے والے جواب ملا کہ یہ تو بہت ہی جلد اپنے کیے پر پچھتانے لگیں گے 1
  23,41,فَاَخَذَتْهُمُ الصَّیْحَةُ بِالْحَقِّ فَجَعَلْنٰهُمْ غُثَآءً١ۚ فَبُعْدًا لِّلْقَوْمِ الظّٰلِمِیْنَ فَاَخَذَتْهُمُ : پس انہیں آپکڑا الصَّيْحَةُ : چنگھاڑ بِالْحَقِّ : (وعدہ) حق کے مطابق فَجَعَلْنٰهُمْ : سو ہم نے انہیں کردیا غُثَآءً : خس و خاشاک فَبُعْدًا : دوری (مار) لِّلْقَوْمِ : قوم کے لیے الظّٰلِمِيْنَ : ظالم (جمع) بالآخر عدل کے تقاضے کے مطابق چیخ 1 نے پکڑ لیا اور ہم نے انھیں کوڑا کرکٹ کر ڈالا 2 پس ظالموں کے لئے دوری ہو۔
  23,42,ثُمَّ اَنْشَاْنَا مِنْۢ بَعْدِهِمْ قُرُوْنًا اٰخَرِیْنَؕ ثُمَّ : پھر اَنْشَاْنَا : ہم نے پیدا کیں مِنْۢ بَعْدِهِمْ : ان کے بعد قُرُوْنًا : امتیں اٰخَرِيْنَ : دوسری۔ اور ان کے بعد ہم نے اور بھی بہت سی امتیں پیدا کیں 1
