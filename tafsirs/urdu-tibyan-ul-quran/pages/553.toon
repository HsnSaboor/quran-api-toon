tafsir[8]{c,v,t}:
  62,1,یُسَبِّحُ لِلّٰهِ مَا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ الْمَلِكِ الْقُدُّوْسِ الْعَزِیْزِ الْحَكِیْمِ يُسَبِّحُ لِلّٰهِ : تسبیح کررہی ہے اللہ ہی کے لیے مَا فِي السَّمٰوٰتِ : ہر وہ چیز جو آسمان میں ہے وَمَا فِي الْاَرْضِ : اور جو زمین میں ہے الْمَلِكِ : جو بادشاہ ہے الْقُدُّوْسِ : نہایت پاکیزہ الْعَزِيْزِ : زبردست الْحَكِيْمِ : حکمت والا ساری چیزیں) جو آسمان اور زمین میں ہیں اللہ تعالیٰ کی پاکی بیان کرتی ہیں (جو) بادشاہ نہایت پاک (ہے) غالب و با حکمت ہے۔
  62,2,هُوَ الَّذِیْ بَعَثَ فِی الْاُمِّیّٖنَ رَسُوْلًا مِّنْهُمْ یَتْلُوْا عَلَیْهِمْ اٰیٰتِهٖ وَ یُزَكِّیْهِمْ وَ یُعَلِّمُهُمُ الْكِتٰبَ وَ الْحِكْمَةَ١ۗ وَ اِنْ كَانُوْا مِنْ قَبْلُ لَفِیْ ضَلٰلٍ مُّبِیْنٍۙ هُوَ الَّذِيْ : وہ اللہ وہ ذات ہے بَعَثَ : جس نے بھیجا فِي : میں الْاُمِّيّٖنَ : ان پڑھ لوگوں (میں) رَسُوْلًا مِّنْهُمْ : ایک رسول انہی میں سے يَتْلُوْا عَلَيْهِمْ : جو پڑھتا ہے ان پر اٰيٰتِهٖ : اس کی آیات وَيُزَكِّيْهِمْ : اور ان کا تزکیہ کرنا ہے وَيُعَلِّمُهُمُ الْكِتٰبَ : اور سکھاتا ہے ان کو کتاب وَالْحِكْمَةَ : اور حکمت وَاِنْ كَانُوْا : اور بیشک تھے وہ مِنْ قَبْلُ : اس سے پہلے لَفِيْ ضَلٰلٍ مُّبِيْنٍ : البتہ کھلی گھمراہی میں وہی ہے جس نے ناخواندہ لوگوں (1) میں ان ہی میں سے ایک رسول بھیجا جو انہیں اس کی آیتیں پڑھ کر سناتا ہے اور ان کو پاک کرتا ہے اور انہیں کتاب اور حکمت سکھاتا ہے۔ یقیناً یہ اس سے پہلے کھلی گمراہی میں تھے۔
  62,3,وَّ اٰخَرِیْنَ مِنْهُمْ لَمَّا یَلْحَقُوْا بِهِمْ١ؕ وَ هُوَ الْعَزِیْزُ الْحَكِیْمُ وَّاٰخَرِيْنَ مِنْهُمْ : اور کچھ دوسرے ان میں سے لَمَّا : حالانکہ (نہیں) يَلْحَقُوْا بِهِمْ : وہ ملے ان کے ساتھ وَهُوَ : اور وہ الْعَزِيْزُ الْحَكِيْمُ : زبردست ہے، حکمت والا ہے اور دوسروں کے لئے بھی انہی میں سے جو اب تک ان سے نہیں (1) ملے۔ وہی غالب با حکمت ہے۔
  62,4,ذٰلِكَ فَضْلُ اللّٰهِ یُؤْتِیْهِ مَنْ یَّشَآءُ١ؕ وَ اللّٰهُ ذُو الْفَضْلِ الْعَظِیْمِ ذٰلِكَ : یہ فَضْلُ اللّٰهِ : اللہ کا فضل ہے يُؤْتِيْهِ : دیتا ہے اسے مَنْ يَّشَآءُ : جس کو وہ چاہتا ہے وَاللّٰهُ : اور اللہ ذُو الْفَضْلِ : فضل والا ہے الْعَظِيْمِ : بڑے یہ اللہ کا فضل ہے (1) جسے چاہے اپنا فضل دے اور اللہ تعالیٰ بہت بڑے فضل کا مالک ہے۔
  62,5,مَثَلُ الَّذِیْنَ حُمِّلُوا التَّوْرٰىةَ ثُمَّ لَمْ یَحْمِلُوْهَا كَمَثَلِ الْحِمَارِ یَحْمِلُ اَسْفَارًا١ؕ بِئْسَ مَثَلُ الْقَوْمِ الَّذِیْنَ كَذَّبُوْا بِاٰیٰتِ اللّٰهِ١ؕ وَ اللّٰهُ لَا یَهْدِی الْقَوْمَ الظّٰلِمِیْنَ مَثَلُ : مثال الَّذِيْنَ : ان لوگوں کی حُمِّلُوا التَّوْرٰىةَ : جو اٹھوائے گئے تورات ثُمَّ : پھر لَمْ يَحْمِلُوْهَا : انہوں نے نہ اٹھایا اس کو كَمَثَلِ الْحِمَارِ : مانند مثال گدھے کے ہے يَحْمِلُ اَسْفَارًا : جو اٹھاتا ہے بوجھ بِئْسَ : بری ہے مَثَلُ الْقَوْمِ الَّذِيْنَ : مثال اس قوم کی جنہوں نے كَذَّبُوْا : جھٹلایا بِاٰيٰتِ اللّٰهِ : اللہ کی آیات کو وَاللّٰهُ : اور اللہ تعالیٰ لَا يَهْدِي : نہیں ہدایت دیتا الْقَوْمَ الظّٰلِمِيْنَ : ظالم قوم کو جن لوگوں کو تورات پر عمل کرنے کا حکم دیا گیا پھر انہوں نے اس پر عمل نہیں کیا ان کی مثال اس گدھے کی سی ہے جو بہت سی کتابیں لادے ہو (1) اللہ کی باتوں کو جھٹلانے والوں کی بڑی بری مثال ہے اور اللہ (ایسی) ظالم قوم کو ہدایت نہیں دیتا۔
  62,6,قُلْ یٰۤاَیُّهَا الَّذِیْنَ هَادُوْۤا اِنْ زَعَمْتُمْ اَنَّكُمْ اَوْلِیَآءُ لِلّٰهِ مِنْ دُوْنِ النَّاسِ فَتَمَنَّوُا الْمَوْتَ اِنْ كُنْتُمْ صٰدِقِیْنَ قُلْ يٰٓاَيُّهَا الَّذِيْنَ : کہہ دیجئے اے لوگو هَادُوْٓا : جو یہودی بنے ہو اِنْ زَعَمْتُمْ : اگر تم زعم رکھتے ہو۔ گھمنڈ رکھتے ہو۔ سمجھتے ہو اَنَّكُمْ اَوْلِيَآءُ : بیشک تم دوست ہو لِلّٰهِ : اللہ کے مِنْ دُوْنِ النَّاسِ : لوگوں کے سوا فَتَمَنَّوُا الْمَوْتَ : پس تم تمنا کرو موت کی اِنْ كُنْتُمْ : اگر ہو تم صٰدِقِيْنَ : سچے کہہ دیجئے کہ اے یہودیو ! اگر تمہارا دعویٰ ہے کہ تم اللہ کے دوست ہو دوسرے لوگوں کے سوا (1) تم موت کی تمنا کرو (2) اگر تم سچے ہو۔ (3)
  62,7,وَ لَا یَتَمَنَّوْنَهٗۤ اَبَدًۢا بِمَا قَدَّمَتْ اَیْدِیْهِمْ١ؕ وَ اللّٰهُ عَلِیْمٌۢ بِالظّٰلِمِیْنَ وَلَا يَتَمَنَّوْنَهٗٓ : اور نہ وہ تمنا کریں گے اس کی اَبَدًۢا : کبھی بھی بِمَا قَدَّمَتْ : بوجہ اس کے جو آگے بھیجا اَيْدِيْهِمْ : ان کے ہاتھوں نے وَاللّٰهُ : اور اللہ عَلِيْمٌۢ : جاننے والا ہے بِالظّٰلِمِيْنَ : ظالموں کو یہ کبھی بھی موت کی تمنا نہ کریں گے بوجہ ان اعمال کے جو اپنے آگے اپنے ہاتھوں بھیج رکھے ہیں (1) اور اللہ ظالموں کو خوب جانتا ہے۔
  62,8,قُلْ اِنَّ الْمَوْتَ الَّذِیْ تَفِرُّوْنَ مِنْهُ فَاِنَّهٗ مُلٰقِیْكُمْ ثُمَّ تُرَدُّوْنَ اِلٰى عٰلِمِ الْغَیْبِ وَ الشَّهَادَةِ فَیُنَبِّئُكُمْ بِمَا كُنْتُمْ تَعْمَلُوْنَ۠    ۧ قُلْ : کہہ دیجئے اِنَّ الْمَوْتَ : بیشک موت الَّذِيْ : وہ جو تَفِرُّوْنَ مِنْهُ : تم بھاگتے ہو اس سے فَاِنَّهٗ مُلٰقِيْكُمْ : تو بیشک وہ ملنے والی ہے تم سے ثُمَّ تُرَدُّوْنَ : پھر تم لوٹائے جاؤ گے اِلٰى عٰلِمِ : طرف جاننے والے الْغَيْبِ : غیب کے وَالشَّهَادَةِ : اور حاضر کے فَيُنَبِّئُكُمْ : پھر وہ بتادے گا تم کو بِمَا كُنْتُمْ تَعْمَلُوْنَ : ساتھ اس کے جو تم ، تم عمل کرتے کہہ دیجئے ! کہ جس موت سے تم بھاگتے پھرتے ہو وہ تو تمہیں پہنچ کر رہے گی پھر تم سب چھپے کھلے کے جاننے والے (اللہ) کی طرف لوٹائے جاؤ گے اور وہ تمہیں تمہارے کئے ہوئے تمام کام بتلا دے گا۔
