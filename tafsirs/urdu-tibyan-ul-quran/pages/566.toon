tafsir[18]{c,v,t}:
  68,43,خَاشِعَةً اَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ١ؕ وَ قَدْ كَانُوْا یُدْعَوْنَ اِلَى السُّجُوْدِ وَ هُمْ سٰلِمُوْنَ خَاشِعَةً : نیچی ہوں گی اَبْصَارُهُمْ : ان کی نگاہیں تَرْهَقُهُمْ : چھا رہی ہوگی ان پر ذِلَّةٌ : ذلت وَقَدْ كَانُوْا : اور تحقیق تھے وہ يُدْعَوْنَ : بلائے جاتے اِلَى السُّجُوْدِ : سجدوں کی طرف وَهُمْ سٰلِمُوْنَ : اور وہ صحیح سلامت تھے نگاہیں نیچی ہوں گی ان پر ذلت و خواری چھا رہی (1) ہوگی حالانکہ یہ سجدے کے لئے (اس وقت بھی) بلائے جاتے تھے جبکہ صحیح سلامت تھے (2)
  68,44,فَذَرْنِیْ وَ مَنْ یُّكَذِّبُ بِهٰذَا الْحَدِیْثِ١ؕ سَنَسْتَدْرِجُهُمْ مِّنْ حَیْثُ لَا یَعْلَمُوْنَۙ فَذَرْنِيْ : پس چھوڑدو مجھ کو وَمَنْ يُّكَذِّبُ : اور جو کوئی جھٹلاتا ہے بِهٰذَا : اس الْحَدِيْثِ : بات کو سَنَسْتَدْرِجُهُمْ : عنقریب ہم آہستہ آہستہ کھینچیں گے ان کو مِّنْ حَيْثُ : جہاں سے لَا يَعْلَمُوْنَ : وہ جانتے نہ ہوں گے پس مجھے اور اس کلام کو جھٹلانے والے کو چھوڑ دے ہم انہیں اس طرح آہستہ آہستہ کھینچیں گے کہ انہیں معلوم بھی نہ ہوگا (1)
  68,45,وَ اُمْلِیْ لَهُمْ١ؕ اِنَّ كَیْدِیْ مَتِیْنٌ وَ : اور اُمْلِيْ لَهُمْ : میں ڈھیل دے رہا ہوں ان کے لیے اِنَّ : بیشک كَيْدِيْ : میری چال مَتِيْنٌ : بہت پختہ ہے اور میں انہیں ڈھیل دونگا، بیشک میری تدبیر بڑی مضبوط ہے۔
  68,46,اَمْ تَسْئَلُهُمْ اَجْرًا فَهُمْ مِّنْ مَّغْرَمٍ مُّثْقَلُوْنَۚ اَمْ تَسْئَلُهُمْ : یا تم سوال کرتے ہو ان سے اَجْرًا : کسی اجر کا فَهُمْ : تو وہ مِّنْ مَّغْرَمٍ : تاوان سے مُّثْقَلُوْنَ : دبے جاتے ہوں کیا تو ان سے کوئی اجرت چاہتا ہے جس کے تاوان سے یہ دبے جاتے ہوں (1)
  68,47,اَمْ عِنْدَهُمُ الْغَیْبُ فَهُمْ یَكْتُبُوْنَ اَمْ : یا عِنْدَهُمُ : ان کے پاس الْغَيْبُ : کوئی غیب ہے فَهُمْ يَكْتُبُوْنَ : تو وہ لکھ رہے ہیں ان کے پاس علم غیب ہے جسے وہ لکھتے ہوں۔ (1)
  68,48,فَاصْبِرْ لِحُكْمِ رَبِّكَ وَ لَا تَكُنْ كَصَاحِبِ الْحُوْتِ١ۘ اِذْ نَادٰى وَ هُوَ مَكْظُوْمٌؕ فَاصْبِرْ : پس صبر کرو لِحُكْمِ رَبِّكَ : اپنے رب کے حکم کے لیے وَلَا تَكُنْ : اور نہ تم ہو كَصَاحِبِ الْحُوْتِ : مانند مچھلی والے کے اِذْ نَادٰى : جب اس نے پکارا وَهُوَ مَكْظُوْمٌ : اور وہ غم سے بھرا ہوا تھا بس تو اپنے رب کے حکم کا صبر سے انتظار کر اور مچھلی والے کی طرح نہ ہوجا جب (1) کہ اس نے غم کی حالت میں دعا کی (1)
  68,49,لَوْ لَاۤ اَنْ تَدٰرَكَهٗ نِعْمَةٌ مِّنْ رَّبِّهٖ لَنُبِذَ بِالْعَرَآءِ وَ هُوَ مَذْمُوْمٌ لَوْلَآ : اگر نہ ہوتی یہ بات اَنْ تَدٰرَكَهٗ : کہ پالیا اس کو نِعْمَةٌ : ایک نعمت نے مِّنْ رَّبِّهٖ : اس کے رب کی طرف سے لَنُبِذَ : البتہ پھینک دیا جاتا بِالْعَرَآءِ : چٹیل میدان میں وَهُوَ : اور وہ مَذْمُوْمٌ : مذموم ہوتا اگر اسے اس کے رب کی نعمت نہ پالیتی تو یقیناً وہ برے حالوں میں چٹیل میدان میں ڈال دیا جاتا (1)۔
  68,50,فَاجْتَبٰىهُ رَبُّهٗ فَجَعَلَهٗ مِنَ الصّٰلِحِیْنَ فَاجْتَبٰىهُ : تو چن لیا اس کو رَبُّهٗ : اس کے رب نے فَجَعَلَهٗ : تو بنادیا اس کو مِنَ الصّٰلِحِيْنَ : صالح لوگوں میں سے اس کے رب نے پھر نوازا اور اسے نیک کاروں میں کردیا (1)
  68,51,وَ اِنْ یَّكَادُ الَّذِیْنَ كَفَرُوْا لَیُزْلِقُوْنَكَ بِاَبْصَارِهِمْ لَمَّا سَمِعُوا الذِّكْرَ وَ یَقُوْلُوْنَ اِنَّهٗ لَمَجْنُوْنٌۘ وَاِنْ يَّكَادُ : اور بیشک قریب ہے کہ الَّذِيْنَ كَفَرُوْا : وہ لوگ جنہوں نے کفر کیا لَيُزْلِقُوْنَكَ : البتہ پھیلا دیں گے آپ کو بِاَبْصَارِهِمْ : اپنی نگاہوں سے لَمَّا سَمِعُوا : جب وہ سنتے ہیں الذِّكْرَ : ذکر کو وَيَقُوْلُوْنَ : اور وہ کہتے ہیں اِنَّهٗ لَمَجْنُوْنٌ : بیشک وہ البتہ مجنون ہے اور قریب ہے کہ کافر اپنی تیز نگاہوں سے آپ کو پھسلا دیں (1) جب کبھی قرآن سنتے ہیں اور کہہ دیتے ہیں یہ تو ضرور دیوانہ ہے (2)
  68,52,وَ مَا هُوَ اِلَّا ذِكْرٌ لِّلْعٰلَمِیْنَ۠    ۧ وَمَا هُوَ : اور نہیں ہے وہ اِلَّا ذِكْرٌ لِّلْعٰلَمِيْنَ : مگر ایک نصیحت جہانوں کے لیے در حقیقت یہ (قرآن) تو تمام جہان والوں کے لئے سراسر نصیحت ہے (1)
  69,1,اَلْحَآقَّةُۙ اَلْحَآقَّةُ : سچ مچ ہونیوالی (قیامت) ثابت ہونے والی (1)
  69,2,مَا الْحَآقَّةُۚ مَا الْحَآقَّةُ : کیا ہے قیامت ثابت ہونے والی کیا ہے ؟ (1)
  69,3,وَ مَاۤ اَدْرٰىكَ مَا الْحَآقَّةُؕ وَمَآ اَدْرٰىكَ : اور کیا تم سمجھے مَا الْحَآقَّةُ : کیا ہے قیامت تجھے کیا معلوم کہ وہ ثابت شدہ کیا ہے ؟ (1)
  69,4,كَذَّبَتْ ثَمُوْدُ وَ عَادٌۢ بِالْقَارِعَةِ كَذَّبَتْ : جھٹلایا ثَمُوْدُ : ثمود نے وَعَادٌۢ : اور عاد نے بِالْقَارِعَةِ : کھڑکا دینے والی کو اس کھڑکا دینے والی کو ثمود اور عاد نے جھٹلا دیا تھا (1)
  69,5,فَاَمَّا ثَمُوْدُ فَاُهْلِكُوْا بِالطَّاغِیَةِ فَاَمَّا : تو رہے ثَمُوْدُ : ثمود فَاُهْلِكُوْا : پس وہ ہلاک کہے گئے بِالطَّاغِيَةِ : اونچی آواز سے (جس کے نتیجے میں) ثمود تو بیحد خوفناک (اور اونچی) آواز سے ہلاک کردیئے گئے (1)
  69,6,وَ اَمَّا عَادٌ فَاُهْلِكُوْا بِرِیْحٍ صَرْصَرٍ عَاتِیَةٍۙ وَاَمَّا عَادٌ : اور رہے عاد فَاُهْلِكُوْا : پس وہ ہلاک کیے گئے بِرِيْحٍ : ساتھ ایک ہوا کے صَرْصَرٍ : پالے والی۔ تند عَاتِيَةٍ : سرکش ۔ حد سے نکلنے والی اور عاد بیحد تیز و تند ہوا سے غارت کردیئے گئے (1)
  69,7,سَخَّرَهَا عَلَیْهِمْ سَبْعَ لَیَالٍ وَّ ثَمٰنِیَةَ اَیَّامٍ١ۙ حُسُوْمًا١ۙ فَتَرَى الْقَوْمَ فِیْهَا صَرْعٰى١ۙ كَاَنَّهُمْ اَعْجَازُ نَخْلٍ خَاوِیَةٍۚ سَخَّرَهَا : مسلط کردیا اس کو عَلَيْهِمْ : ان پر سَبْعَ لَيَالٍ : ساتھ راتوں تک وَّثَمٰنِيَةَ : اور آٹھ اَيَّامٍ : دن حُسُوْمًا : پے درپے۔ مسلسل فَتَرَى الْقَوْمَ : تو تم دیکھتے لوگوں کو۔ قوم کو فِيْهَا صَرْعٰى : اس میں گرے ہوئے ہیں كَاَنَّهُمْ : گویا کہ وہ اَعْجَازُ : تنے ہیں نَخْلٍ : کھجور کے درخت کے خَاوِيَةٍ : خالی۔ کھوکھلے جسے ان پر سات رات اور آٹھ دن تک (اللہ نے) مثلت رکھا (1) پس تم دیکھتے کہ یہ لوگ زمین پر اس طرح گرگئے جیسے کھجور کے کھوکھلے تنے ہوں۔
  69,8,فَهَلْ تَرٰى لَهُمْ مِّنْۢ بَاقِیَةٍ فَهَلْ تَرٰى : تو کیا تم دیکھتے ہو لَهُمْ : ان کے لیے مِّنْۢ : کوئی بَاقِيَةٍ : باقی بچا ہوا کیا ان میں سے کوئی بھی تجھے باقی نظر آرہا ہے۔
