tafsir[9]{c,v,t}:
  12,70,فَلَمَّا جَهَّزَهُمْ بِجَهَازِهِمْ جَعَلَ السِّقَایَةَ فِیْ رَحْلِ اَخِیْهِ ثُمَّ اَذَّنَ مُؤَذِّنٌ اَیَّتُهَا الْعِیْرُ اِنَّكُمْ لَسٰرِقُوْنَ فَلَمَّا : پھر جب جَهَّزَهُمْ : انہیں تیار کردیا بِجَهَازِهِمْ : ان کا سامان جَعَلَ : رکھ دیا السِّقَايَةَ : پینے کا پیالہ فِيْ : میں رَحْلِ : سامان اَخِيْهِ : اپنا بھائی ثُمَّ : پھر اَذَّنَ : اعلان کیا مُؤَذِّنٌ : منادی کرنیوالا اَيَّتُهَا الْعِيْرُ : اے قافلے والو اِنَّكُمْ : بیشک تم لَسٰرِقُوْنَ : البتہ چور ہو پھر جب انھیں ان کا سامان اسباب ٹھیک ٹھاک کر کے دیا تو اپنے بھائی کے اسباب میں پانی پینے کا پیالہ (1) رکھوا دیا پھر ایک آواز دینے والے نے پکار کر کہا کہ اے قافلے والو ! (2) تم لوگ تو چور ہو (3)۔
  12,71,قَالُوْا وَ اَقْبَلُوْا عَلَیْهِمْ مَّا ذَا تَفْقِدُوْنَ قَالُوْا : وہ بولے وَاَقْبَلُوْا : اور انہوں نے منہ کیا عَلَيْهِمْ : ان کی طرف مَّاذَا : کیا ہے جو تَفْقِدُوْنَ : تم گم کر بیٹھے انہوں نے ان کی طرف منہ پھیر کر کہا تمہاری کیا چیز کھو گئی ہے ؟
  12,72,قَالُوْا نَفْقِدُ صُوَاعَ الْمَلِكِ وَ لِمَنْ جَآءَ بِهٖ حِمْلُ بَعِیْرٍ وَّ اَنَا بِهٖ زَعِیْمٌ قَالُوْا : انہوں نے کہا نَفْقِدُ : ہم گم کر بیٹھے (نہیں پاتے) صُوَاعَ : پیمانہ الْمَلِكِ : بادشاہ وَلِمَنْ : اور اس کے لیے جَآءَ بِهٖ : جو وہ لائے حِمْلُ : بوجھ بَعِيْرٍ : ایک اونٹ وَّاَنَا : اور میں بِهٖ : اس کا زَعِيْمٌ : ضامن جواب دیا کہ شاہی پیمانہ گم ہے جو اسے لے آئے اسے ایک اونٹ کے بوجھ کا غلہ ملے گا۔ اس وعدے کا میں ضامن ہوں (1)
  12,73,قَالُوْا تَاللّٰهِ لَقَدْ عَلِمْتُمْ مَّا جِئْنَا لِنُفْسِدَ فِی الْاَرْضِ وَ مَا كُنَّا سٰرِقِیْنَ قَالُوْا : وہ بولے تَاللّٰهِ : اللہ کی قسم لَقَدْ عَلِمْتُمْ : تم خوب جانتے ہو مَّا جِئْنَا : ہم نہیں آئے لِنُفْسِدَ : کہ ہم فساد کریں فِي الْاَرْضِ : زمین (ملک) میں وَمَا كُنَّا : اور ہم نہیں سٰرِقِيْنَ : چور (جمع) انہوں نے کہا اللہ کی قسم ! تم کو خوب علم ہے کہ ہم ملک میں فساد پھیلانے کے لئے نہیں آئے اور نہ ہم چور ہیں۔
  12,74,قَالُوْا فَمَا جَزَآؤُهٗۤ اِنْ كُنْتُمْ كٰذِبِیْنَ قَالُوْا : انہوں نے کہا فَمَا : پھر کیا جَزَآؤُهٗٓ : سزا اس کی اِنْ : اگر كُنْتُمْ : تم ہو كٰذِبِيْنَ : جھوٹے انہوں نے کہا اچھا چور کی کیا سزا اگر تم جھوٹے ہو ؟ (1)
  12,75,قَالُوْا جَزَآؤُهٗ مَنْ وُّجِدَ فِیْ رَحْلِهٖ فَهُوَ جَزَآؤُهٗ١ؕ كَذٰلِكَ نَجْزِی الظّٰلِمِیْنَ قَالُوْا : کہنے لگے وہ جَزَآؤُهٗ : اس کی سزا مَنْ : جو۔ جس وُّجِدَ : پایا جائے فِيْ رَحْلِهٖ : اس کے سامان میں فَهُوَ : پس وہی جَزَآؤُهٗ : اس کا بدلہ كَذٰلِكَ : اسی طرح نَجْزِي : ہم سزا دیتے ہیں الظّٰلِمِيْنَ : ظالموں کو جواب دیا اس کی سزا یہی ہے کہ جس کے اسباب میں سے پایا جائے وہی اس کا بدلہ ہے (1) ہم تو ایسے ظالموں کو یہی سزا دیا کرتے ہیں (2)۔
  12,76,فَبَدَاَ بِاَوْعِیَتِهِمْ قَبْلَ وِعَآءِ اَخِیْهِ ثُمَّ اسْتَخْرَجَهَا مِنْ وِّعَآءِ اَخِیْهِ١ؕ كَذٰلِكَ كِدْنَا لِیُوْسُفَ١ؕ مَا كَانَ لِیَاْخُذَ اَخَاهُ فِیْ دِیْنِ الْمَلِكِ اِلَّاۤ اَنْ یَّشَآءَ اللّٰهُ١ؕ نَرْفَعُ دَرَجٰتٍ مَّنْ نَّشَآءُ١ؕ وَ فَوْقَ كُلِّ ذِیْ عِلْمٍ عَلِیْمٌ فَبَدَاَ : پس شروع کیا بِاَوْعِيَتِهِمْ : ان کی خرجیوں (بوروں) سے قَبْلَ : پہلے وِعَآءِ : کر جی (بورا) اَخِيْهِ : اپنا بھائی ثُمَّ : پھر اسْتَخْرَجَهَا : اس کو نکالا مِنْ : سے وِّعَآءِ : بورا اَخِيْهِ : اپنا بھائی كَذٰلِكَ : اسی طرح كِدْنَا : ہم نے تدبیر کی لِيُوْسُفَ : یوسف کے لیے مَا كَان : نہ تھا لِيَاْخُذَ : وہ لے سکتا اَخَاهُ : اپنا بھائی فِيْ : میں دِيْنِ الْمَلِكِ : بادشاہ کا دین اِلَّآ : مگر اَنْ : یہ کہ يَّشَآءَ اللّٰهُ : اللہ چاہے نَرْفَعُ : ہم بلند کرتے ہیں دَرَجٰتٍ : درجے مَّنْ : جو۔ جس نَّشَآءُ : چاہیں ہم وَفَوْقَ : اور اوپر كُلِّ : ہر ذِيْ عِلْمٍ : صاحب علم عَلِيْمٌ : ایک علم والا پس یوسف نے ان کے سامان کی تلاشی شروع کی، اپنے بھائی کے سامان کی تلاشی سے پہلے، پھر اس پیمانہ کو اپنے بھائی کے سامان (زنبیل) سے نکالا (1) ہم نے یوسف کے لئے اسی طرح یہ تدبیر کی (2) اس بادشاہ کی قانون کی رو سے یہ اپنے بھائی کو نہ لے جاسکتا تھا (3) مگر یہ کہ اللہ کو منظور ہو ہم جس کے چاہیں درجے بلند کردیں (4) ہر ذی علم پر فوقیت رکھنے والا دوسرا ذی علم موجود ہے (5)۔
  12,77,قَالُوْۤا اِنْ یَّسْرِقْ فَقَدْ سَرَقَ اَخٌ لَّهٗ مِنْ قَبْلُ١ۚ فَاَسَرَّهَا یُوْسُفُ فِیْ نَفْسِهٖ وَ لَمْ یُبْدِهَا لَهُمْ١ۚ قَالَ اَنْتُمْ شَرٌّ مَّكَانًا١ۚ وَ اللّٰهُ اَعْلَمُ بِمَا تَصِفُوْنَ قَالُوْٓا : بولے اِنْ : اگر يَّسْرِقْ : اس نے چرایا فَقَدْ سَرَقَ : تو چوری کی تھی اَخٌ لَّهٗ : اس کا بھائی مِنْ قَبْلُ : اس سے قبل فَاَسَرَّهَا : پس اسے چھپایا يُوْسُفُ : یوسف فِيْ نَفْسِهٖ : اپنے دل میں وَلَمْ يُبْدِهَا : اور وہ ظاہر نہ کیا لَهُمْ : ان پر قَالَ : کہا اَنْتُمْ : تم شَرٌّ : بدتر مَّكَانًا : درجہ میں وَاللّٰهُ : اور اللہ اَعْلَمُ : خوب جانتا ہے بِمَا تَصِفُوْنَ : جو تم بیان کرتے ہو انہوں نے کہا اگر اس نے چوری کی (تو کوئی تعجب کی بات نہیں) اس کا بھائی بھی پہلے چوری کرچکا ہے (1) یوسف ؑ نے اس بات کو اپنے دل میں رکھ لیا اور ان کے سامنے بالکل ظاہر نہ کیا۔ کہا کہ تم بدتر جگہ میں ہو (2) اور جو تم بیان کرتے ہو اسے اللہ ہی خوب جانتا ہے۔
  12,78,قَالُوْا یٰۤاَیُّهَا الْعَزِیْزُ اِنَّ لَهٗۤ اَبًا شَیْخًا كَبِیْرًا فَخُذْ اَحَدَنَا مَكَانَهٗ١ۚ اِنَّا نَرٰىكَ مِنَ الْمُحْسِنِیْنَ قَالُوْا : کہنے لگے يٰٓاَيُّهَا : اے الْعَزِيْزُ : عزیز اِنَّ : بیشک لَهٗٓ : اس کا اَبًا : باپ شَيْخًا : بوڑھا كَبِيْرًا : بڑی عمر کا فَخُذْ : پس لے (رکھ لے) اَحَدَنَا : ہم میں سے ایک مَكَانَهٗ : اس کی جگہ اِنَّا نَرٰىكَ : ہم دیکھتے ہیں بیشک تجھے مِنَ : سے الْمُحْسِنِيْنَ : احسان کرنے والے انہوں نے کہا اے عزیز مصر ! (1) اس کے والد بہت بڑی عمر کے بالکل بوڑھے شخص ہیں آپ اس کے بدلے ہم میں سے کسی کو لے لیجئے، ہم دیکھتے ہیں کہ آپ بڑے نیک نفس ہیں (2)۔
