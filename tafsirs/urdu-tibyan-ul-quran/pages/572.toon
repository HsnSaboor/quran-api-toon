tafsir[13]{c,v,t}:
  72,1,قُلْ اُوْحِیَ اِلَیَّ اَنَّهُ اسْتَمَعَ نَفَرٌ مِّنَ الْجِنِّ فَقَالُوْۤا اِنَّا سَمِعْنَا قُرْاٰنًا عَجَبًاۙ قُلْ : آپ فرمادیں اُوْحِيَ : مجھے وحی کی گئی اِلَيَّ : میری طرف اَنَّهُ اسْتَمَعَ : کہ اسے سنا نَفَرٌ : ایک جماعت مِّنَ : سے، کی الْجِنِّ : جنات فَقَالُوْٓا : تو انہوں نے کہا اِنَّا : بیشک ہم سَمِعْنَا : ہم نے سنا قُرْاٰنًا : قرآن عَجَبًا : ایک عجیب آپ کہہ دیں کہ مجھے وحی کی گئی ہے کہ جنوں کی ایک جماعت (1) نے (قرآن) سنا اور کہا کہ ہم نے عجب قرآن سنا ہے۔
  72,2,یَّهْدِیْۤ اِلَى الرُّشْدِ فَاٰمَنَّا بِهٖ١ؕ وَ لَنْ نُّشْرِكَ بِرَبِّنَاۤ اَحَدًاۙ يَّهْدِيْٓ : وہ رہنمائی کرتا ہے اِلَى الرُّشْدِ : ہدایت کی طرف فَاٰمَنَّا : تو ہم ایمان لائے بِهٖ ۭ : اس پر وَلَنْ نُّشْرِكَ : اور ہم ہرگز شریک نہ ٹھہرائیں گے بِرَبِّنَآ : اپنے رب کے ساتھ اَحَدًا : کسی کو جو راہ راست کی طرف راہنمائی کرتا ہے (1) ہم اس پر ایمان لا چکے (اب) ہم ہرگز کسی کو بھی اپنے رب کا شریک نہ بنائیں گے۔
  72,3,وَّ اَنَّهٗ تَعٰلٰى جَدُّ رَبِّنَا مَا اتَّخَذَ صَاحِبَةً وَّ لَا وَلَدًاۙ وَّاَنَّهٗ : اور یہ کہ تَعٰلٰى : برتر جَدُّ : شان رَبِّنَا : ہمارا رب مَا اتَّخَذَ : اس نے نہیں بنایا صَاحِبَةً : بیوی وَّلَا : اور نہ وَلَدًا : اولاد اور بیشک ہمارے رب کی شان بڑی بلند ہے نہ اس نے کسی کو (اپنی) بیوی بنایا ہے نہ بیٹا (1)
  72,4,وَّ اَنَّهٗ كَانَ یَقُوْلُ سَفِیْهُنَا عَلَى اللّٰهِ شَطَطًاۙ وَّاَنَّهٗ كَانَ يَقُوْلُ : اور یہ کہ کہتے تھے سَفِيْهُنَا : ہم میں سے بیوقوف عَلَي اللّٰهِ : اللہ پر شَطَطًا : بڑھاکر باتیں اور یہ کہ ہم میں ایک بیوقوف اللہ کے بارے میں خلاف حق باتیں کہا کرتا تھا (1)
  72,5,وَّ اَنَّا ظَنَنَّاۤ اَنْ لَّنْ تَقُوْلَ الْاِنْسُ وَ الْجِنُّ عَلَى اللّٰهِ كَذِبًاۙ وَّاَنَّا : اور یہ کہ ہم ظَنَنَّآ : ہم نے گمان کیا اَنْ : کہ لَّنْ تَقُوْلَ : ہرگز نہ کہیں گے الْاِنْسُ : انسان وَالْجِنُّ : اور جن عَلَي اللّٰهِ : اللہ پر كَذِبًا : جھوٹ اور ہم تو یہی سمجھتے رہے کہ ناممکن ہے کہ انسان اور جنات اللہ پر جھوٹی باتیں لگائیں (1)
  72,6,وَّ اَنَّهٗ كَانَ رِجَالٌ مِّنَ الْاِنْسِ یَعُوْذُوْنَ بِرِجَالٍ مِّنَ الْجِنِّ فَزَادُوْهُمْ رَهَقًاۙ وَّاَنَّهٗ : اور یہ کہ كَانَ رِجَالٌ : تھے کچھ آدمی مِّنَ الْاِنْسِ : انسانوں میں سے يَعُوْذُوْنَ : پناہ لیتے (تھے) بِرِجَالٍ : لوگوں سے مِّنَ الْجِنِّ : جنات سے فَزَادُوْهُمْ : تو انہوں نے (جنات) کو بڑھا دیا رَهَقًا : تکبر میں بات یہ ہے کہ چند انسان بعض جنات سے پناہ طلب کیا کرتے تھے جس سے جنات اپنی سرکشی میں اور بڑھ گئے (1)
  72,7,وَّ اَنَّهُمْ ظَنُّوْا كَمَا ظَنَنْتُمْ اَنْ لَّنْ یَّبْعَثَ اللّٰهُ اَحَدًاۙ وَّاَنَّهُمْ : اور یہ کہ وہ ظَنُّوْا : انہوں نے گمان کیا كَمَا : جیسے ظَنَنْتُمْ : تم نے گمان کیا تھا اَنْ : کہ لَّنْ يَّبْعَثَ : ہرگز نہ (رسول بناکر) بھیجے گا اللّٰهُ : اللہ اَحَدًا : کسی کو اور (انسانوں) نے بھی تم جنوں کی طرح گمان کرلیا تھا کہ اللہ کسی کو نہ بھیجے گا (یا کسی کو دوبارہ زندہ نہ کرے گا)
  72,8,وَّ اَنَّا لَمَسْنَا السَّمَآءَ فَوَجَدْنٰهَا مُلِئَتْ حَرَسًا شَدِیْدًا وَّ شُهُبًاۙ وَّاَنَّا : اور یہ کہ ہم لَمَسْنَا : ہم نے چھوا (ٹٹولا) السَّمَآءَ : آسمان فَوَجَدْنٰهَا : تو ہم نے اسے پایا مُلِئَتْ : بھرا ہوا حَرَسًا : پہریدار شَدِيْدًا : سخت وَّشُهُبًا : اور شعلے اور ہم نے آسمان کو ٹٹول کر دیکھا تو اسے سخت چوکیداروں اور سخت شعلوں سے پر پایا (1)
  72,9,وَّ اَنَّا كُنَّا نَقْعُدُ مِنْهَا مَقَاعِدَ لِلسَّمْعِ١ؕ فَمَنْ یَّسْتَمِعِ الْاٰنَ یَجِدْ لَهٗ شِهَابًا رَّصَدًاۙ وَّاَنَّا : اور یہ کہ ہم كُنَّا نَقْعُدُ : ہم بیٹھا کرتے تھے مِنْهَا : اس کے مَقَاعِدَ : ٹھکانے لِلسَّمْعِ ۭ : سننے کے لئے فَمَنْ : پس جو يَّسْتَمِعِ : سنتا ہے الْاٰنَ : اب يَجِدْ لَهٗ : وہ وہاں پاتا ہے شِهَابًا : شعلہ رَّصَدًا : گھات لگایا ہوا اس سے پہلے ہم باتیں سننے کے لئے آسمان میں جگہ جگہ بیٹھ جایا کرتے تھے (1) اب جو بھی کان لگاتا ہے وہ ایک شعلے کو اپنی تاک میں پاتا ہے (1)
  72,10,وَّ اَنَّا لَا نَدْرِیْۤ اَشَرٌّ اُرِیْدَ بِمَنْ فِی الْاَرْضِ اَمْ اَرَادَ بِهِمْ رَبُّهُمْ رَشَدًاۙ وَّاَنَّا : اور یہ کہ ہم لَا نَدْرِيْٓ : ہم نہیں جانتے اَشَرٌّ : آیا بُرائی اُرِيْدَ : ارادہ کیا گیا بِمَنْ : ان کے ساتھ فِي : میں الْاَرْضِ : جو زمین اَمْ : یا اَرَادَ : ارادہ فرمایا ہے بِهِمْ : ان سے رَبُّهُمْ : ان کا رب رَشَدًا : ہدایت ہم نہیں جانتے کہ زمین والوں کے ساتھ کسی برائی کا ارادہ کیا گیا ہے یا ان کے رب کا ارادہ ان کے ساتھ بھلائی کا ہے (1)
  72,11,وَّ اَنَّا مِنَّا الصّٰلِحُوْنَ وَ مِنَّا دُوْنَ ذٰلِكَ١ؕ كُنَّا طَرَآئِقَ قِدَدًاۙ وَّاَنَّا : اور یہ کہ ہم مِنَّا : ہم میں سے الصّٰلِحُوْنَ : نیکو کار (جمع) وَمِنَّا : اور ہم میں سے دُوْنَ ذٰلِكَ ۭ : اسکے علاوہ كُنَّا : ہم تھے طَرَآئِقَ : راہیں قِدَدًا : مختلف اور یہ کہ (بیشک) بعض تو ہم میں نیکوکار ہیں اور بعض اس کے برعکس بھی ہیں، ہم مختلف طریقوں سے بٹے ہوئے ہیں۔
  72,12,وَّ اَنَّا ظَنَنَّاۤ اَنْ لَّنْ نُّعْجِزَ اللّٰهَ فِی الْاَرْضِ وَ لَنْ نُّعْجِزَهٗ هَرَبًاۙ وَّاَنَّا : اور یہ کہ ہم ظَنَنَّآ : ہم نے گمان کیا اَنْ لَّنْ نُّعْجِزَ اللّٰهَ : کہ ہم ہرگز نہ ہراسکیں گے اللہ کو فِي الْاَرْضِ : زمین میں وَلَنْ نُّعْجِزَهٗ : اور ہم اسکو ہرگز نہ ہراسکیں گے هَرَبًا : بھاگ کر اور ہم نے سمجھ لیا کہ ہم اللہ تعالیٰ کو زمین میں ہرگز عاجز نہیں کرسکتے اور نہ بھاگ کر اسے ہرا سکتے ہیں۔
  72,13,وَّ اَنَّا لَمَّا سَمِعْنَا الْهُدٰۤى اٰمَنَّا بِهٖ١ؕ فَمَنْ یُّؤْمِنْۢ بِرَبِّهٖ فَلَا یَخَافُ بَخْسًا وَّ لَا رَهَقًاۙ وَّاَنَّا : اور یہ کہ لَمَّا : جب سَمِعْنَا : ہم نے سنی الْهُدٰٓى : ہدایت اٰمَنَّا : ہم ایمان لے آئے بِهٖ ۭ : اس پر فَمَنْ يُّؤْمِنْۢ : سو جو ایمان لائے بِرَبِّهٖ : اپنے رب پر فَلَا يَخَافُ : تو اسے خوف نہ ہوگا بَخْسًا : کسی نقصان وَّلَا رَهَقًا : اور نہ کسی ظلم ہم تو ہدایت کی بات سنتے ہیں اس پر ایمان لا چکے ہیں اور جو بھی اپنے رب پر ایمان لائے گا نہ کسی نقصان کا اندیشہ ہے نہ ظلم و ستم کا (1)
