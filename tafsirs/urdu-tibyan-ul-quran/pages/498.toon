tafsir[20]{c,v,t}:
  44,40,اِنَّ یَوْمَ الْفَصْلِ مِیْقَاتُهُمْ اَجْمَعِیْنَۙ اِنَّ يَوْمَ الْفَصْلِ : بیشک فیصلے کا دن مِيْقَاتُهُمْ : ان کی میعاد ہے اَجْمَعِيْنَ : سب کی یقیناً فیصلے کا دن ان سب کا طے شدہ وقت ہے۔ (1)
  44,41,یَوْمَ لَا یُغْنِیْ مَوْلًى عَنْ مَّوْلًى شَیْئًا وَّ لَا هُمْ یُنْصَرُوْنَۙ يَوْمَ : جس دن لَا يُغْنِيْ : نہ کام آئے گا مَوْلًى : کوئی عزیز۔ قریب عَنْ مَّوْلًى : عزیز کو۔ قریب کو شَيْئًا : کچھ بھی وَّلَا هُمْ : اور نہ وہ يُنْصَرُوْنَ : مددئیے جائیں گے اس دن کوئی دوست کسی دوست کے کچھ کام بھی نہ آئے گا اور نہ ان کی امداد کی جائے گی۔
  44,42,اِلَّا مَنْ رَّحِمَ اللّٰهُ١ؕ اِنَّهٗ هُوَ الْعَزِیْزُ الرَّحِیْمُ۠    ۧ اِلَّا : مگر مَنْ رَّحِمَ اللّٰهُ : جس پر رحم فرمائے اللہ اِنَّهٗ : یقینا وہ هُوَ : وہی الْعَزِيْزُ الرَّحِيْمُ : غالب ہے ، رحم فرمانے والا ہے مگر جس پر اللہ کی مہربانی ہوجائے وہ زبردست اور رحم کرنے والا ہے۔
  44,43,اِنَّ شَجَرَتَ الزَّقُّوْمِۙ اِنَّ : بیشک شَجَرَتَ الزَّقُّوْمِ : درخت زقوم کا بیشک زقوم (تھوہر) کا درخت۔
  44,44,طَعَامُ الْاَثِیْمِ٤ۖۛۚ طَعَامُ : کھانا ہے الْاَثِيْمِ : گناہ گاروں کا گنہگار کا کھانا ہے۔
  44,45,كَالْمُهْلِ١ۛۚ یَغْلِیْ فِی الْبُطُوْنِۙ كَالْمُهْلِ : گلے ہوئے تانبے کی طرح يَغْلِيْ : جوش کھائے گا فِي الْبُطُوْنِ : پیٹوں میں جو مثل تلچھٹ (1) کے ہے اور پیٹ میں کھولتا رہتا ہے۔
  44,46,كَغَلْیِ الْحَمِیْمِ كَغَلْيِ : مانند جوش کھانے الْحَمِيْمِ : کھولتے پانی مثل تیز گرم پانی کے (1)
  44,47,خُذُوْهُ فَاعْتِلُوْهُ اِلٰى سَوَآءِ الْجَحِیْمِۗۖ خُذُوْهُ : کہا جائے گا) پکڑو اس کو فَاعْتِلُوْهُ : پس گھسیٹو اس کو اِلٰى : طرف سَوَآءِ الْجَحِيْمِ : جہنم کے وسط میں اسے پکڑ لو پھر گھسیٹتے ہوئے بیچ جہنم تک پہنچاؤ (1)
  44,48,ثُمَّ صُبُّوْا فَوْقَ رَاْسِهٖ مِنْ عَذَابِ الْحَمِیْمِؕ ثُمَّ صُبُّوْا : پھر انڈیل دو فَوْقَ رَاْسِهٖ : اس کے سر کے اوپر مِنْ عَذَابِ الْحَمِيْمِ : کھولتے پانی کے عذاب سے پھر اس کے سر پر سخت گرم پانی کا عذاب بہاؤ۔
  44,49,ذُقْ١ۙۚ اِنَّكَ اَنْتَ الْعَزِیْزُ الْكَرِیْمُ ذُقْ : (کہا جائے گا) چکھو اِنَّكَ : بیشک تم اَنْتَ الْعَزِيْزُ الْكَرِيْمُ : تم زبردست تھے، عزت والے تھے (اس سے کہا جائے گا) چکھتا جا تو تو بڑا ذی عزت اور بڑے اکرام والا تھا (1)۔
  44,50,اِنَّ هٰذَا مَا كُنْتُمْ بِهٖ تَمْتَرُوْنَ اِنَّ : بیشک ھٰذَا : یہ مَا كُنْتُمْ بِهٖ : وہ ہے جو تھے تم ساتھ اس کے تَمْتَرُوْنَ : تم شک کرتے تھے یہی وہ چیز ہے جس میں تم شک کیا کرتے تھے۔
  44,51,اِنَّ الْمُتَّقِیْنَ فِیْ مَقَامٍ اَمِیْنٍۙ اِنَّ الْمُتَّقِيْنَ : بیشک متقی لوگ فِيْ مَقَامٍ : جگہ پر ہوں گے اَمِيْنٍ : امن والی بیشک (اللہ سے) ڈرنے والے امن چین کی جگہ میں ہونگے۔
  44,52,فِیْ جَنّٰتٍ وَّ عُیُوْنٍۚۙ فِيْ جَنّٰتٍ : باغوں میں وَّعُيُوْنٍ : اور چشموں میں باغوں اور چشموں میں۔
  44,53,یَّلْبَسُوْنَ مِنْ سُنْدُسٍ وَّ اِسْتَبْرَقٍ مُّتَقٰبِلِیْنَۚۙ يَّلْبَسُوْنَ : پہنیں گے وہ مِنْ سُنْدُسٍ : باریک ریشم میں سے وَّاِسْتَبْرَقٍ : اور موٹا ریشم مُّتَقٰبِلِيْنَ : آمنے سامنے بیٹھنے والے باریک اور ریشم کے لباس پہنے ہوئے آمنے سامنے بیٹھے ہونگے (1)۔
  44,54,كَذٰلِكَ١۫ وَ زَوَّجْنٰهُمْ بِحُوْرٍ عِیْنٍؕ كَذٰلِكَ : اسی طرح وَزَوَّجْنٰهُمْ : اور بیاہ دیں گے ہم انکو بِحُوْرٍ عِيْنٍ : موٹی آنکھوں والی سفید عورتوں سے یہ اسی طرح ہے (1) اور ہم بڑی بڑی آنکھوں والی حوروں سے ان کا نکاح کردیں گے (2)۔
  44,55,یَدْعُوْنَ فِیْهَا بِكُلِّ فَاكِهَةٍ اٰمِنِیْنَۙ يَدْعُوْنَ : وہ طلب کریں گے فِيْهَا : اس میں بِكُلِّ : ہر قسم کے فَاكِهَةٍ : پھل اٰمِنِيْنَ : امن سے رہنے والے دل جمعی کے ساتھ وہاں ہر طرح کے میووں کی فرمائشیں کرتے ہونگے (1)
  44,56,لَا یَذُوْقُوْنَ فِیْهَا الْمَوْتَ اِلَّا الْمَوْتَةَ الْاُوْلٰى١ۚ وَ وَقٰىهُمْ عَذَابَ الْجَحِیْمِۙ لَا يَذُوْقُوْنَ : نہ وہ چکھیں گے فِيْهَا الْمَوْتَ : اس میں موت کو اِلَّا الْمَوْتَةَ الْاُوْلٰى : مگر پہلی موت وَوَقٰىهُمْ : اور بچا لے گا ان کو عَذَابَ الْجَحِيْمِ : جہنم کے عذاب سے وہاں وہ موت چکھنے کے نہیں ہاں پہلی موت (1) (جو وہ مرچکے) انہیں اللہ تعالیٰ نے دوزخ کی سزا سے بچا دیا۔
  44,57,فَضْلًا مِّنْ رَّبِّكَ١ؕ ذٰلِكَ هُوَ الْفَوْزُ الْعَظِیْمُ فَضْلًا : فضل ہوگا مِّنْ رَّبِّكَ : تیرے رب کی طرف سے ذٰلِكَ : یہی هُوَ الْفَوْزُ : وہ کامیابی الْعَظِيْمُ : بہت بڑی یہ صرف تیرے رب کا فضل ہے (1) یہی ہے بڑی کامیابی۔
  44,58,فَاِنَّمَا یَسَّرْنٰهُ بِلِسَانِكَ لَعَلَّهُمْ یَتَذَكَّرُوْنَ فَاِنَّمَا : پس بیشک يَسَّرْنٰهُ : آسان کردیا ہم نے اس کو بِلِسَانِكَ : تیری زبان پر لَعَلَّهُمْ يَتَذَكَّرُوْنَ : شاید کہ وہ نصیحت پکڑیں ہم نے اس (قرآن) کو تیری زبان میں آسان کردیا تاکہ وہ نصیحت حاصل کریں۔
  44,59,فَارْتَقِبْ اِنَّهُمْ مُّرْتَقِبُوْنَ۠    ۧ فَارْتَقِبْ : پس انتظار کرو اِنَّهُمْ مُّرْتَقِبُوْنَ : بیشک وہ انتظار کرنے والے ہیں اب تو منتظر رہ یہ بھی منتظر ہیں (1)
