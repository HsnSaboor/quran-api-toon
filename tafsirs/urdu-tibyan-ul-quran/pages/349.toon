tafsir[14]{c,v,t}:
  23,105,اَلَمْ تَكُنْ اٰیٰتِیْ تُتْلٰى عَلَیْكُمْ فَكُنْتُمْ بِهَا تُكَذِّبُوْنَ اَلَمْ تَكُنْ : کیا نہ تھیں اٰيٰتِيْ : میری آیتیں تُتْلٰى : پڑھی جاتیں عَلَيْكُمْ : تم پر فَكُنْتُمْ : پس تم تھے بِهَا : انہیں تُكَذِّبُوْنَ : تم جھٹلاتے تھے کیا میری آیتیں تمہارے سامنے تلاوت نہیں کی جاتی تھیں ؟ پھر بھی تم انھیں جھٹلاتے تھے۔
  23,106,قَالُوْا رَبَّنَا غَلَبَتْ عَلَیْنَا شِقْوَتُنَا وَ كُنَّا قَوْمًا ضَآلِّیْنَ قَالُوْا : وہ کہیں گے رَبَّنَا : اے ہمارے رب غَلَبَتْ : غالب آگئی عَلَيْنَا : ہم پر شِقْوَتُنَا : ہماری بدبختی وَكُنَّا : اور ہم تھے قَوْمًا : لوگ ضَآلِّيْنَ : راستہ سے بھٹکے ہوئے کہیں گے کہ اے پروردگار ! ہماری بدبختی ہم پر غالب آگئی (واقعی) ہم تھے ہی گمراہ۔
  23,107,رَبَّنَاۤ اَخْرِجْنَا مِنْهَا فَاِنْ عُدْنَا فَاِنَّا ظٰلِمُوْنَ رَبَّنَآ : اے ہمارے رب اَخْرِجْنَا : ہمیں نکال لے مِنْهَا : اس سے فَاِنْ : پھر اگر عُدْنَا : دوبارہ کیا ہم نے فَاِنَّا : تو بیشک ہم ظٰلِمُوْنَ : ظالم (جمع) اے پروردگار ! ہمیں یہاں سے نجات دے اگر اب بھی ہم ایسا ہی کریں تو بیشک ہم ظالم ہیں۔
  23,108,قَالَ اخْسَئُوْا فِیْهَا وَ لَا تُكَلِّمُوْنِ قَالَ : فرمائے گا اخْسَئُوْا : پھٹکارے ہوئے پڑے رہو فِيْهَا : اس میں وَلَا تُكَلِّمُوْنِ : اور کلام نہ کرو مجھ سے اللہ تعالیٰ فرمائے گا پھٹکارے ہوئے یہیں پڑے رہو اور مجھ سے کلام نہ کرو۔
  23,109,اِنَّهٗ كَانَ فَرِیْقٌ مِّنْ عِبَادِیْ یَقُوْلُوْنَ رَبَّنَاۤ اٰمَنَّا فَاغْفِرْ لَنَا وَ ارْحَمْنَا وَ اَنْتَ خَیْرُ الرّٰحِمِیْنَۚۖ اِنَّهٗ : بیشک وہ كَانَ : تھا فَرِيْقٌ : ایک گروہ مِّنْ عِبَادِيْ : میرے بندوں کا يَقُوْلُوْنَ : وہ کہتے تھے رَبَّنَآ : اے ہمارے رب اٰمَنَّا : ہم ایمان لائے فَاغْفِرْ لَنَا : سو ہمیں بخشدے وَارْحَمْنَا : اور ہم پر رحم فرما وَاَنْتَ : اور تو خَيْرُ : بہترین الرّٰحِمِيْنَ : رحم کرنے والے میرے بندوں کی ایک جماعت تھی جو برابر یہی کہتی رہی کہ اے ہمارے پروردگار ! ہم ایمان لا چکے ہیں تو ہمیں بخش اور ہم پر رحم فرما تو سب مہربانوں سے زیادہ مہربان ہے۔
  23,110,فَاتَّخَذْتُمُوْهُمْ سِخْرِیًّا حَتّٰۤى اَنْسَوْكُمْ ذِكْرِیْ وَ كُنْتُمْ مِّنْهُمْ تَضْحَكُوْنَ فَاتَّخَذْتُمُوْهُمْ : پس تم نے انہیں بنا لیا سِخْرِيًّا : ٹھٹھا ﱑ : یہاں تک کہ اَنْسَوْكُمْ : انہوں نے بھلا دیا تمہیں ذِكْرِيْ : میری یاد وَكُنْتُمْ : اور تم تھے مِّنْهُمْ : ان سے تَضْحَكُوْنَ : ہنسی کیا کرتے تھے (لیکن) تم انھیں مذاق ہی اڑاتے رہے یہاں تک کہ (اس مشغلے نے) تم کو میری یاد (بھی) بھلا دی اور تم ان سے مذاق کرتے رہے۔
  23,111,اِنِّیْ جَزَیْتُهُمُ الْیَوْمَ بِمَا صَبَرُوْۤا١ۙ اَنَّهُمْ هُمُ الْفَآئِزُوْنَ اِنِّىْ : بیشک میں جَزَيْتُهُمُ : میں نے جزا دی انہیں الْيَوْمَ : آج بِمَا : اس کے بدلے صَبَرُوْٓا : انہوں نے صبر کیا اَنَّهُمْ : بیشک وہ هُمُ : وہی الْفَآئِزُوْنَ : مراد کو پہنچنے والے میں نے آج انھیں ان کے اس صبر کا بدلہ دے دیا ہے کہ وہ خاطر خواہ اپنی مراد کو پہنچ چکے ہیں۔ 1
  23,112,قٰلَ كَمْ لَبِثْتُمْ فِی الْاَرْضِ عَدَدَ سِنِیْنَ قٰلَ : فرمائے گا كَمْ لَبِثْتُمْ : کتنی مدت رہے تم فِي الْاَرْضِ : زمین (دنیا) میں عَدَدَ : شمار (حساب) سِنِيْنَ : سال (جمع) اللہ تعالیٰ دریافت فرمائے گا کہ زمین میں باعتبار برسوں کی گنتی کے کس قدر رہے ؟
  23,113,قَالُوْا لَبِثْنَا یَوْمًا اَوْ بَعْضَ یَوْمٍ فَسْئَلِ الْعَآدِّیْنَ قَالُوْا : وہ کہیں گے لَبِثْنَا : ہم رہے يَوْمًا : ایک دن اَوْ : یا بَعْضَ يَوْمٍ : ایک دن کا کچھ حصہ فَسْئَلِ : پس پوچھ لے الْعَآدِّيْنَ : شمار کرنے والے وہ کہیں گے ایک دن یا ایک دن سے بھی کم، گنتی گننے والوں سے بھی پوچھ لیجئے 1
  23,114,قٰلَ اِنْ لَّبِثْتُمْ اِلَّا قَلِیْلًا لَّوْ اَنَّكُمْ كُنْتُمْ تَعْلَمُوْنَ قٰلَ : فرمائے گا اِنْ لَّبِثْتُمْ : نہیں تم رہے اِلَّا : مگر (صرف) قَلِيْلًا : تھوڑا (عرصہ) لَّوْ : کاش اَنَّكُمْ : کہ تم كُنْتُمْ تَعْلَمُوْنَ : جانتے ہوئے اللہ تعالیٰ فرمائے گا فی الواقع تم وہاں بہت ہی کم رہے ہو اے کاش ! تم اسے پہلے ہی جان لیتے ؟ 1
  23,115,اَفَحَسِبْتُمْ اَنَّمَا خَلَقْنٰكُمْ عَبَثًا وَّ اَنَّكُمْ اِلَیْنَا لَا تُرْجَعُوْنَ اَفَحَسِبْتُمْ : کیا تم خیال کرتے ہو اَنَّمَا : کہ خَلَقْنٰكُمْ : ہم نے تمہیں پیدا کیا عَبَثًا : عبث (بیکار) وَّاَنَّكُمْ : اور یہ کہ تم اِلَيْنَا : ہماری طرف لَا تُرْجَعُوْنَ : نہیں لوٹائے جاؤگے کیا تم یہ گمان کئے ہوئے ہو کہ ہم نے تمہیں یونہی بیکار پیدا کیا ہے اور یہ کہ تم ہماری طرف لوٹائے ہی نہ جاؤ گے۔
  23,116,فَتَعٰلَى اللّٰهُ الْمَلِكُ الْحَقُّ١ۚ لَاۤ اِلٰهَ اِلَّا هُوَ١ۚ رَبُّ الْعَرْشِ الْكَرِیْمِ فَتَعٰلَى : پس بلند تر اللّٰهُ : اللہ الْمَلِكُ : بادشاہ الْحَقُّ : حقیقی لَآ : نہیں اِلٰهَ : کوئی معبود اِلَّا هُوَ : اس کے سوا رَبُّ : مالک الْعَرْشِ الْكَرِيْمِ : عزت والا عرش اللہ تعالیٰ سچا بادشاہ ہے وہ بڑی بلندی والا ہے 1 اس کے سوا کوئی معبود نہیں، وہی بزرگ عرش کا مالک ہے 2
  23,117,وَ مَنْ یَّدْعُ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ١ۙ لَا بُرْهَانَ لَهٗ بِهٖ١ۙ فَاِنَّمَا حِسَابُهٗ عِنْدَ رَبِّهٖ١ؕ اِنَّهٗ لَا یُفْلِحُ الْكٰفِرُوْنَ وَ : اور مَنْ يَّدْعُ : جو پکارے مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا اٰخَرَ : کوئی اور معبود لَا بُرْهَانَ : نہیں کوئی سند لَهٗ : اس کے پاس بِهٖ : اس کے لیے فَاِنَّمَا : سو، تحقیق حِسَابُهٗ : اس کا حساب عِنْدَ رَبِّهٖ : اس کے رب کے پاس اِنَّهٗ : بیشک وہ لَا يُفْلِحُ : فلاح (کامیابی) نہیں پائینگے الْكٰفِرُوْنَ : کافر (جمع) جو شخص اللہ کے ساتھ کسی دوسرے معبود کو پکارے جس کی کوئی دلیل اس کے پاس نہیں، پس اس کا حساب تو اس کے رب کے اوپر ہی ہے۔ بیشک کافر لوگ نجات سے محروم ہیں 1۔
  23,118,وَ قُلْ رَّبِّ اغْفِرْ وَ ارْحَمْ وَ اَنْتَ خَیْرُ الرّٰحِمِیْنَ۠    ۧ وَقُلْ : اور آپ کہیں رَّبِّ : اے میرے رب اغْفِرْ : بخش دے وَارْحَمْ : اور رحم فرما وَاَنْتَ : اور تو خَيْرُ الرّٰحِمِيْنَ : بہترین رحم کرنے والا ہے اور کہو کہ اے میرے رب ! تو بخش اور رحم کر اور تو سب مہربانوں سے بہتر مہربانی کرنے والا ہے۔
