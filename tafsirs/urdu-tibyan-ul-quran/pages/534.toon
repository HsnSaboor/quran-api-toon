tafsir[27]{c,v,t}:
  55,68,فِیْهِمَا فَاكِهَةٌ وَّ نَخْلٌ وَّ رُمَّانٌۚ فِيْهِمَا فَاكِهَةٌ : ان دونوں میں پھل ہیں وَّنَخْلٌ : اور کھجور کے درخت وَّرُمَّانٌ : اور انار ان دونوں میں میوے اور کھجور اور انار ہوں گے (1)
  55,69,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,70,فِیْهِنَّ خَیْرٰتٌ حِسَانٌۚ فِيْهِنَّ خَيْرٰتٌ : ان میں اچھی عورتیں ہیں۔ بہترین عورتیں ہیں حِسَانٌ : خوبصورت ان میں نیک سیرت خوبصورت عورتیں ہیں (1)
  55,71,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,72,حُوْرٌ مَّقْصُوْرٰتٌ فِی الْخِیَامِۚ حُوْرٌ : حوریں مَّقْصُوْرٰتٌ : ٹھہرائی ہوئیں۔ روکی ہوئیں فِي الْخِيَامِ : خیموں میں (گوری رنگت کی) حوریں جنتی خیموں میں رہنے والیاں ہیں (1)
  55,73,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,74,لَمْ یَطْمِثْهُنَّ اِنْسٌ قَبْلَهُمْ وَ لَا جَآنٌّۚ لَمْ يَطْمِثْهُنَّ : نہیں چھوا ہوگا ان کو اِنْسٌ : کسی انسان نے قَبْلَهُمْ : ان سے پہلے وَلَا جَآنٌّ : اور نہ کسی جن نے ان کو ہاتھ نہیں لگایا کسی انسان یا جن نے اس سے قبل۔
  55,75,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,76,مُتَّكِئِیْنَ عَلٰى رَفْرَفٍ خُضْرٍ وَّ عَبْقَرِیٍّ حِسَانٍۚ مُتَّكِئِيْنَ : تکیہ لگائے ہوئے ہوں گے عَلٰي رَفْرَفٍ : مسندوں پر خُضْرٍ : سبز وَّعَبْقَرِيٍّ : اور نادر حِسَانٍ : نفیس سبز مسندوں اور عمدہ فرشوں پر تکیہ لگائے ہوئے ہوں گے (1)
  55,77,فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ فَبِاَيِّ اٰلَآءِ : تو ساتھ کون سی نعمتوں کے رَبِّكُمَا : اپنے رب کی تم دونوں تُكَذِّبٰنِ : تم دونوں جھٹلاؤ گے پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے ؟
  55,78,تَبٰرَكَ اسْمُ رَبِّكَ ذِی الْجَلٰلِ وَ الْاِكْرَامِ۠    ۧ تَبٰرَكَ اسْمُ : بہت بابرکت ہے نام رَبِّكَ : تیرے رب کا ذِي الْجَلٰلِ : جو صاحب جلال ہے وَالْاِكْرَامِ : اور کریم ہے۔ صاحب اکرام ہے تیرے پروردگار کا نام بابرکت ہے (1) جو عزت و جلال والا ہے۔
  56,1,اِذَا وَقَعَتِ الْوَاقِعَةُۙ اِذَا وَقَعَتِ : جب واقع ہوجائے گی الْوَاقِعَةُ : واقع ہونے والی (قیامت) جب قیامت قائم ہوجائے گی (1)
  56,2,لَیْسَ لِوَقْعَتِهَا كَاذِبَةٌۘ لَيْسَ لِوَقْعَتِهَا : نہیں ہے اس کا واقعہ ہونا كَاذِبَةٌ : کوئی جھوٹ جس کے واقع ہونے میں کوئی جھوٹ نہیں۔
  56,3,خَافِضَةٌ رَّافِعَةٌۙ خَافِضَةٌ : پست کرنے والی ہے رَّافِعَةٌ : اونچا کرنے والی ہے وہ پست کرنے والی اور بلند کرنے والی ہوگی (1)
  56,4,اِذَا رُجَّتِ الْاَرْضُ رَجًّاۙ اِذَا رُجَّتِ الْاَرْضُ : جب ہلائی جائے گی زمین رَجًّا : ہلایا جانا جبکہ زمین زلزلہ کے ساتھ ہلا دی جائے گی۔
  56,5,وَّ بُسَّتِ الْجِبَالُ بَسًّاۙ وَّبُسَّتِ الْجِبَالُ : اور اڑا دیئے جائیں گے پہاڑ بَسًّا : اڑا دیا جانا اور پہاڑ بالکل ریزہ ریزہ کردیئے جائیں گے (1)۔
  56,6,فَكَانَتْ هَبَآءً مُّنْۢبَثًّاۙ فَكَانَتْ : تو ہوجائیں گے هَبَآءً : باریک خاک۔ گرد و غبار مُّنْۢبَثًّا : منتشر۔ پراگندہ۔ اڑتا ہوا پھر وہ مثل پراگندہ غبار کے ہوجائیں گے۔
  56,7,وَّ كُنْتُمْ اَزْوَاجًا ثَلٰثَةًؕ وَّكُنْتُمْ : اور ہوجاؤ گے تم اَزْوَاجًا : جماعتوں میں۔ گروہوں میں ثَلٰثَةً : تین اور تم تین جماعتوں میں ہوجاؤ گے۔
  56,8,فَاَصْحٰبُ الْمَیْمَنَةِ١ۙ۬ مَاۤ اَصْحٰبُ الْمَیْمَنَةِؕ فَاَصْحٰبُ الْمَيْمَنَةِ : پس دائیں ہاتھ والے مَآ : کیا ہیں اَصْحٰبُ الْمَيْمَنَةِ : دائیں ہاتھ والے پس داہنے ہاتھ والے کیسے اچھے ہیں (1)
  56,9,وَ اَصْحٰبُ الْمَشْئَمَةِ١ۙ۬ مَاۤ اَصْحٰبُ الْمَشْئَمَةِؕ وَاَصْحٰبُ الْمَشْئَمَةِ : اور بائیں ہاتھ والے مَآ اَصْحٰبُ الْمَشْئَمَةِ : کیا ہیں بائیں ہاتھ والے اور بائیں ہاتھ والوں کا کیا حال ہے بائیں ہاتھ والوں کا (1)
  56,10,وَ السّٰبِقُوْنَ السّٰبِقُوْنَۚۙ وَالسّٰبِقُوْنَ : اور آگے بڑھنے والے السّٰبِقُوْنَ : آگے بڑھنے والے ہیں اور جو آگے والے ہیں وہ تو آگے والے ہیں (1)
  56,11,اُولٰٓئِكَ الْمُقَرَّبُوْنَۚ اُولٰٓئِكَ الْمُقَرَّبُوْنَ : یہی نزدیکی حاصل کرنے والے ہیں۔ یہی لوگ قرب حاصل کرنے والے ہیں وہ بالکل نزدیکی حاصل کئے ہوئے ہیں۔
  56,12,فِیْ جَنّٰتِ النَّعِیْمِ فِيْ جَنّٰتِ النَّعِيْمِ : نعمتوں والے باغوں میں نعمتوں والی جنتوں میں ہیں۔
  56,13,ثُلَّةٌ مِّنَ الْاَوَّلِیْنَۙ ثُلَّةٌ : ایک بڑا گروہ ہیں مِّنَ الْاَوَّلِيْنَ : اگلے لوگوں میں سے (بہت بڑا) گروہ اگلے لوگوں میں سے ہوگا۔
  56,14,وَ قَلِیْلٌ مِّنَ الْاٰخِرِیْنَؕ وَقَلِيْلٌ : اور تھوڑے ہیں مِّنَ الْاٰخِرِيْنَ : پچھلوں میں سے اور تھوڑے سے پچھلے لوگوں میں سے (1)
  56,15,عَلٰى سُرُرٍ مَّوْضُوْنَةٍۙ عَلٰي سُرُرٍ : اوپر تختوں کے ہوں گے مَّوْضُوْنَةٍ : سونے کی تاروں سے بنے ہوئے۔ بنے ہوئے یہ لوگ سونے کی تاروں سے بنے ہوئے تختوں پر۔
  56,16,مُّتَّكِئِیْنَ عَلَیْهَا مُتَقٰبِلِیْنَ مُّتَّكِئِيْنَ عَلَيْهَا : تکیہ لگائے ہوئے ہوں گے ان پر مُتَقٰبِلِيْنَ : آمنے سامنے ایک دوسرے کے سامنے تکیہ لگائے بیٹھے ہونگے۔
