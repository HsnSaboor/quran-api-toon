quran[38]{c,v,t}:
47,1,اَلَّذِیْنَ كَفَرُوْا وَ صَدُّوْا عَنْ سَبِیْلِ اللّٰهِ اَضَلَّ اَعْمَالَهُمْ اَلَّذِيْنَ : جو لوگ كَفَرُوْا : کافر ہوئے وَصَدُّوْا : اور انہوں نے روکا عَنْ : سے سَبِيْلِ اللّٰهِ : اللہ کا راستہ اَضَلَّ : اکارت کردئیے گئے اَعْمَالَهُمْ : ان کے اعمال جن لوگوں نے کفر کیا اور اللہ کی راہ سے روکا (1) اللہ نے ان کے اعمال برباد کردیئے۔ (2)
47,2,وَ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ وَ اٰمَنُوْا بِمَا نُزِّلَ عَلٰى مُحَمَّدٍ وَّ هُوَ الْحَقُّ مِنْ رَّبِّهِمْ١ۙ كَفَّرَ عَنْهُمْ سَیِّاٰتِهِمْ وَ اَصْلَحَ بَالَهُمْ وَالَّذِيْنَ : اور جو لوگ اٰمَنُوْا : ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کئے الصّٰلِحٰتِ : اچھے وَاٰمَنُوْا : اور وہ ایمان لائے بِمَا نُزِّلَ : اس پر جو نازل کیا گیا عَلٰي مُحَمَّدٍ : محمد پر وَّهُوَ : اور وہ الْحَقُّ : حق مِنْ رَّبِّهِمْ ۙ : ان کے رب سے كَفَّرَ : اس نے دور کردئیے عَنْهُمْ : ان سے سَيِّاٰتِهِمْ : ان کی بُرائیاں (گناہ) وَاَصْلَحَ : اور درست کردیا بَالَهُمْ : ان کا حال اور جو لوگ ایمان لائے اور اچھے کام کئے اور اس پر بھی ایمان لائے جو محمد ﷺ پر اتاری گئی (1) ہے اور دراصل ان کے رب کی طرف سے سچا (دین) بھی وہی ہے، اللہ نے ان کے گناہ دور کردیئے (2) اور ان کے حال کی اصلاح کردی۔ (3)
47,3,ذٰلِكَ بِاَنَّ الَّذِیْنَ كَفَرُوا اتَّبَعُوا الْبَاطِلَ وَ اَنَّ الَّذِیْنَ اٰمَنُوا اتَّبَعُوا الْحَقَّ مِنْ رَّبِّهِمْ١ؕ كَذٰلِكَ یَضْرِبُ اللّٰهُ لِلنَّاسِ اَمْثَالَهُمْ ذٰلِكَ : یہ بِاَنَّ : اس لئے کہ الَّذِيْنَ : جن لوگوں نے كَفَرُوا : کفر کیا اتَّبَعُوا : انہوں نے پیروی کی الْبَاطِلَ : باطل کی وَاَنَّ الَّذِيْنَ : اور یہ کہ جو لوگ اٰمَنُوا : ایمان لائے اتَّبَعُوا : انہوں نے پیروی کی الْحَقَّ : حق کی مِنْ : سے رَّبِّهِمْ ۭ : اپنا رب كَذٰلِكَ : اسی طرح يَضْرِبُ اللّٰهُ : اللہ بیان کرتا ہے لِلنَّاسِ : لوگوں کے لئے اَمْثَالَهُمْ : ان کی مثالیں یہ اس لئے کہ (1) کافروں نے باطل کی پیروی کی اور مومنوں نے اس دین حق کی اتباع کی جو ان کے اللہ کی طرف ہے، اللہ تعالیٰ لوگوں کو ان کے احوال اسی طرح بتاتا ہے (2)۔
47,4,فَاِذَا لَقِیْتُمُ الَّذِیْنَ كَفَرُوْا فَضَرْبَ الرِّقَابِ١ؕ حَتّٰۤى اِذَاۤ اَثْخَنْتُمُوْهُمْ فَشُدُّوا الْوَثَاقَ١ۙۗ فَاِمَّا مَنًّۢا بَعْدُ وَ اِمَّا فِدَآءً حَتّٰى تَضَعَ الْحَرْبُ اَوْزَارَهَا١ۛ۫ۚ۬ ذٰؔلِكَ١ۛؕ وَ لَوْ یَشَآءُ اللّٰهُ لَانْتَصَرَ مِنْهُمْ وَ لٰكِنْ لِّیَبْلُوَاۡ بَعْضَكُمْ بِبَعْضٍ١ؕ وَ الَّذِیْنَ قُتِلُوْا فِیْ سَبِیْلِ اللّٰهِ فَلَنْ یُّضِلَّ اَعْمَالَهُمْ فَاِذَا : پھر جب تم لَقِيْتُمُ : بھڑ جاؤ الَّذِيْنَ : جن لوگوں نے كَفَرُوْا : کفر کیا (کافر) فَضَرْبَ : تو مارو الرِّقَابِ ۭ : گردنیں حَتّىٰٓ : یہاں تک کہ اِذَآ : جب اَثْخَنْتُمُوْهُمْ : خوب خونریزی کرچکو ان کی فَشُدُّوا : تو مضبوط کرلو الْوَثَاقَ ڎ : قید فَاِمَّا مَنًّۢا : پس یا احسان کرو بَعْدُ : اس کے بعد وَاِمَّا فِدَآءً : اور یا معاوضہ حَتّٰى : یہاں تک تَضَعَ : رکھ دے الْحَرْبُ : لڑائی (لڑنے والے) اَوْزَارَهَاڃ : اپنے ہتھیار ذٰ۩لِكَ ړ : یہ وَلَوْ يَشَآءُ اللّٰهُ : اور اگر اللہ چاہتا لَانْتَصَرَ : ضرور انتقام لیتا مِنْهُمْ : ان سے وَلٰكِنْ : اور لیکن لِّيَبْلُوَا۟ : تاکہ آزمائے بَعْضَكُمْ : تم سے بعض کو بِبَعْضٍ ۭ : بعض سے وَالَّذِيْنَ : اور جو لوگ قُتِلُوْا : مارے گئے فِيْ سَبِيْلِ اللّٰهِ : اللہ کے راستے میں فَلَنْ : تو ہرگز نہ يُّضِلَّ : ضائع کرے گا اَعْمَالَهُمْ : ان کے عمل تو جب کافروں سے تمہاری مڈ بھیڑ ہو تو گردنوں پر وار مارو۔ (1) اور جب ان کو اچھی طرح کچل ڈالو تو اب خوب مضبوط قیدو بند سے گرفتار کرو (2) (پھر اختیار ہے) کہ خواہ احسان رکھ کر چھوڑ دو یا فدیہ (3) لے کر چھوڑ دو یہی حکم ہے اور (4) اگر اللہ چاہتا تو (خود) ہی ان سے بدلہ لے لیتا (5) لیکن اس کا منشا یہ ہے کہ تم میں سے لے لے، (6) جو لوگ اللہ کی راہ میں شہید کردیے جاتے ہیں اللہ ان کے اعمال ہرگز ضائع نہ کرے گا۔ (7)
47,5,سَیَهْدِیْهِمْ وَ یُصْلِحُ بَالَهُمْۚ سَيَهْدِيْهِمْ : وہ جلد ان کو ہدایت دے گا وَيُصْلِحُ : اور سنوارے گا بَالَهُمْ : ان کا حال انہیں راہ دکھائے گا اور ان کے حالات کی اصلاح کر دے گا (1)
47,6,وَ یُدْخِلُهُمُ الْجَنَّةَ عَرَّفَهَا لَهُمْ وَيُدْخِلُهُمُ الْجَنَّةَ : اور داخل کرے گا انہیں جنت میں عَرَّفَهَا : اس نے اس سے شناسا کردیا ہے لَهُمْ : انہیں اور انہیں اس جنت میں لے جائے گا جس سے انہیں شناسا کردیا ہے (1)
47,7,یٰۤاَیُّهَا الَّذِیْنَ اٰمَنُوْۤا اِنْ تَنْصُرُوا اللّٰهَ یَنْصُرْكُمْ وَ یُثَبِّتْ اَقْدَامَكُمْ يٰٓاَيُّهَا : اے الَّذِيْنَ : جو لوگ اٰمَنُوْٓا : ایمان لائے اِنْ تَنْصُرُوا : اگر تم مدد کروگے اللّٰهَ : اللہ کی يَنْصُرْكُمْ : وہ مدد کریگا تمہاری وَيُثَبِّتْ : اور جمادے گا اَقْدَامَكُمْ : تمہارے قدم اے ایمان والو ! اگر تم اللہ (کے دین) کی مدد کرو گے تو وہ تمہاری مدد کرے گا (1) اور تمہیں ثابت قدم رکھے گا۔ (2)
47,8,وَ الَّذِیْنَ كَفَرُوْا فَتَعْسًا لَّهُمْ وَ اَضَلَّ اَعْمَالَهُمْ وَالَّذِيْنَ : اور جن لوگوں نے كَفَرُوْا : کفر کیا فَتَعْسًا : تو تباہی ہے لَّهُمْ : ان کے لئے وَاَضَلَّ : اور اس نے ضائع کردئیے اَعْمَالَهُمْ : ان کے عمل اور جو لوگ کافر ہوئے ان پر ہلاکت ہو اللہ ان کے اعمال غارت کر دے گا۔
47,9,ذٰلِكَ بِاَنَّهُمْ كَرِهُوْا مَاۤ اَنْزَلَ اللّٰهُ فَاَحْبَطَ اَعْمَالَهُمْ ذٰلِكَ : یہ بِاَنَّهُمْ : اس لئے کہ انہوں نے كَرِهُوْا : ناپسند کیا مَآ اَنْزَلَ : جو نازل کیا اللّٰهُ : اللہ نے فَاَحْبَطَ : تو اکارت کردئیے اَعْمَالَهُمْ : ان کے عمل یہ اس لئے کہ وہ اللہ کی نازل کردہ چیز سے ناخوش ہوئے (1) پس اللہ تعالیٰ نے (بھی) ان کے اعمال ضائع کردیئے۔ (2)
47,10,اَفَلَمْ یَسِیْرُوْا فِی الْاَرْضِ فَیَنْظُرُوْا كَیْفَ كَانَ عَاقِبَةُ الَّذِیْنَ مِنْ قَبْلِهِمْ١ؕ دَمَّرَ اللّٰهُ عَلَیْهِمْ١٘ وَ لِلْكٰفِرِیْنَ اَمْثَالُهَا اَفَلَمْ : کیا نہیں يَسِيْرُوْا : وہ چلے پھرے فِي الْاَرْضِ : زمین میں فَيَنْظُرُوْا : تو وہ دیکھ لیتے كَيْفَ كَانَ : کیسا ہوا عَاقِبَةُ : انجام الَّذِيْنَ : ان لوگوں کا جو مِنْ قَبْلِهِمْ ۭ : ان سے پہلے دَمَّرَ اللّٰهُ : تباہی ڈالدی اللہ نے عَلَيْهِمْ ۡ : ان پر وَلِلْكٰفِرِيْنَ : اور کافروں کے لئے اَمْثَالُهَا : ان کے مانند کیا ان لوگوں نے زمین میں چل پھر کر اس کا معائنہ نہیں کیا کہ ان سے پہلے کے لوگوں کا کیا نتیجہ ہوا ؟ (1) اللہ نے انہیں ہلاک کردیا اور کافروں کے لئے اس طرح کی سزائیں ہیں (2)
47,11,ذٰلِكَ بِاَنَّ اللّٰهَ مَوْلَى الَّذِیْنَ اٰمَنُوْا وَ اَنَّ الْكٰفِرِیْنَ لَا مَوْلٰى لَهُمْ۠    ۧ ذٰلِكَ : یہ بِاَنَّ اللّٰهَ : اس لئے کہ اللہ مَوْلَى : کارساز الَّذِيْنَ : ان لوگوں کا جو اٰمَنُوْا : ایمان لائے وَاَنَّ الْكٰفِرِيْنَ : اور یہ کہ کافروں لَا مَوْلٰى : کوئی کارساز نہیں لَهُمْ : ان کے لئے وہ اس لئے کہ ایمان والوں کا کارساز خود اللہ تعالیٰ ہے اور اس لئے کہ کافروں کا کوئی کارساز نہیں۔ (1)
47,12,اِنَّ اللّٰهَ یُدْخِلُ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ جَنّٰتٍ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ١ؕ وَ الَّذِیْنَ كَفَرُوْا یَتَمَتَّعُوْنَ وَ یَاْكُلُوْنَ كَمَا تَاْكُلُ الْاَنْعَامُ وَ النَّارُ مَثْوًى لَّهُمْ اِنَّ اللّٰهَ : بیشک اللہ يُدْخِلُ : داخل کرتا ہے الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کئے الصّٰلِحٰتِ : نیک جَنّٰتٍ : باغات تَجْرِيْ : بہتی ہیں مِنْ تَحْتِهَا : ان کے نیچے الْاَنْهٰرُ ۭ : نہریں وَالَّذِيْنَ : اور جن لوگوں نے كَفَرُوْا : کفر کیا يَتَمَتَّعُوْنَ : وہ فائدہ اٹھاتے ہیں وَيَاْكُلُوْنَ : اور وہ کھاتے ہیں كَمَا : جیسے تَاْكُلُ : کھاتے ہیں الْاَنْعَامُ : چوپائے وَالنَّارُ : اور آگ مَثْوًى : ٹھکانا لَّهُمْ : ان کیلئے جو لوگ ایمان لائے اور انہوں نے نیک اعمال کئے انہیں اللہ تعالیٰ یقیناً ایسے باغوں میں داخل کرے گا جن کے نیچے نہریں جاری ہیں اور جو لوگ کافر ہوئے وہ (دنیا ہی کا) فائدہ اٹھا رہے ہیں اور مثل چوپایوں کے کھا رہے ہیں (1) ان کا اصل ٹھکانا جہنم ہے۔
47,13,وَ كَاَیِّنْ مِّنْ قَرْیَةٍ هِیَ اَشَدُّ قُوَّةً مِّنْ قَرْیَتِكَ الَّتِیْۤ اَخْرَجَتْكَ١ۚ اَهْلَكْنٰهُمْ فَلَا نَاصِرَ لَهُمْ وَكَاَيِّنْ : اور بہت سی مِّنْ قَرْيَةٍ : بستیاں هِىَ اَشَدُّ : وہ بہت ہی سخت قُوَّةً : قوت میں مِّنْ قَرْيَتِكَ : آپ کی بستی سے الَّتِيْٓ : وہ جس اَخْرَجَتْكَ ۚ : آپ کو نکال دیا اَهْلَكْنٰهُمْ : ہم نے ہلاک کردیا انہیں فَلَا : تو نہ نَاصِرَ : کوئی مدد کرنے والا لَهُمْ : ان کے لئے ہم نے کتنی بستیوں کو جو طاقت میں تیری اس بستی سے زیادہ تھیں جس سے تجھے نکالا گیا ہم نے انہیں ہلاک کردیا جن کا مددگار کوئی نہ اٹھا۔
47,14,اَفَمَنْ كَانَ عَلٰى بَیِّنَةٍ مِّنْ رَّبِّهٖ كَمَنْ زُیِّنَ لَهٗ سُوْٓءُ عَمَلِهٖ وَ اتَّبَعُوْۤا اَهْوَآءَهُمْ اَفَمَنْ : پس کیا جو كَانَ : ہے عَلٰي بَيِّنَةٍ : روشن (راستہ) پر مِّنْ رَّبِّهٖ : اپنے رب سے، کے كَمَنْ : اس کی طرح زُيِّنَ : آراستہ دکھائے گئے لَهٗ : اس کو سُوْٓءُ : بُرے عَمَلِهٖ : اس کے عمل وَاتَّبَعُوْٓا : اور انہوں نے پیروی کی اَهْوَآءَهُمْ : اپنی خواہشات کیا ' پس وہ شخص جو اپنے پروردگار کی طرف سے دلیل پر ہو اس شخص جیسا ہوسکتا ہے ؟ جس کے لئے اس کا برا کام مزین کردیا گیا ہو اور وہ اپنی نفسانی خواہشوں کا پیرو ہو (1)
47,15,مَثَلُ الْجَنَّةِ الَّتِیْ وُعِدَ الْمُتَّقُوْنَ١ؕ فِیْهَاۤ اَنْهٰرٌ مِّنْ مَّآءٍ غَیْرِ اٰسِنٍ١ۚ وَ اَنْهٰرٌ مِّنْ لَّبَنٍ لَّمْ یَتَغَیَّرْ طَعْمُهٗ١ۚ وَ اَنْهٰرٌ مِّنْ خَمْرٍ لَّذَّةٍ لِّلشّٰرِبِیْنَ١ۚ۬ وَ اَنْهٰرٌ مِّنْ عَسَلٍ مُّصَفًّى١ؕ وَ لَهُمْ فِیْهَا مِنْ كُلِّ الثَّمَرٰتِ وَ مَغْفِرَةٌ مِّنْ رَّبِّهِمْ١ؕ كَمَنْ هُوَ خَالِدٌ فِی النَّارِ وَ سُقُوْا مَآءً حَمِیْمًا فَقَطَّعَ اَمْعَآءَهُمْ مَثَلُ : مثال (کیفیت) الْجَنَّةِ : جنت الَّتِيْ : وہ جو وُعِدَ : وعدہ کی گئی الْمُتَّقُوْنَ ۭ : پرہیزگاروں فِيْهَآ : اس میں اَنْهٰرٌ : نہریں مِّنْ مَّآءٍ : پانی کی غَيْرِ اٰسِنٍ ۚ : بدبو نہ کرنے والے وَاَنْهٰرٌ : اور نہریں مِّنْ لَّبَنٍ : دودھ کی لَّمْ يَتَغَيَّرْ : نہ متغیر ہونے والا طَعْمُهٗ ۚ : اس کا ذائقہ وَاَنْهٰرٌ : اور نہریں مِّنْ خَمْرٍ : شراب کی لَّذَّةٍ : سراسر لذت لِّلشّٰرِبِيْنَ ڬ : پینے والوں کے لئے وَاَنْهٰرٌ : اور نہریں مِّنْ عَسَلٍ : شہد کی مُّصَفًّى ۭ : مصفی وَلَهُمْ : اور انکے لئے فِيْهَا : اس میں مِنْ كُلِّ الثَّمَرٰتِ : ہر قسم کے پھل وَمَغْفِرَةٌ : اور بخشش مِّنْ رَّبِّهِمْ ۭ : ان کے رب سے كَمَنْ هُوَ : اس کی طرح جو وہ خَالِدٌ : ہمیشہ رہنے والا فِي النَّارِ : آگ میں وَسُقُوْا : اور انہیں پلایاجائیگا مَآءً : پانی حَمِيْمًا : گرم فَقَطَّعَ : ٹکڑے ٹکڑے کرڈالے گا اَمْعَآءَهُمْ : ان کی انتڑیاں اس جنت کی صفت جس کا پرہیزگاروں سے وعدہ کیا گیا ہے، یہ ہے کہ اس میں پانی کی نہریں ہیں جو بدبو کرنے والا نہیں (1) اور دودھ کی نہریں ہیں جن کا مزہ نہیں بدلہ (2) اور شراب کی نہریں ہیں جن میں پینے والوں کے لئے بڑی لذت ہے (3) اور نہریں ہیں شہد کی جو بہت صاف ہیں (4) ان کے لئے ہر قسم کے میوے ہیں اور ان کے رب کی طرف سے مغفرت ہے، کیا یہ مثل اس کے ہیں جو ہمیشہ آگ میں رہنے والا ہے ؟ اور جنہیں گرم کھولتا ہوا پانی پلایا جائے گا جو ان کی آنتوں کو ٹکڑے ٹکڑے کر دیگا (5)
47,16,وَ مِنْهُمْ مَّنْ یَّسْتَمِعُ اِلَیْكَ١ۚ حَتّٰۤى اِذَا خَرَجُوْا مِنْ عِنْدِكَ قَالُوْا لِلَّذِیْنَ اُوْتُوا الْعِلْمَ مَا ذَا قَالَ اٰنِفًا١۫ اُولٰٓئِكَ الَّذِیْنَ طَبَعَ اللّٰهُ عَلٰى قُلُوْبِهِمْ وَ اتَّبَعُوْۤا اَهْوَآءَهُمْ وَمِنْهُمْ : اور ان میں سے مَّنْ يَّسْتَمِعُ : جو سنتا ہے اِلَيْكَ ۚ : آپ کی طرف حَتّىٰٓ : یہاں تک کہ اِذَا خَرَجُوْا : جب وہ نکلتے ہیں مِنْ عِنْدِكَ : آپ کے پاس سے قَالُوْا : وہ کہتے ہیں لِلَّذِيْنَ : ان لوگوں کو جنہیں اُوْتُوا الْعِلْمَ : علم دیا گیا (اہل علم) مَاذَا : کیا قَالَ : اس نے کہا اٰنِفًا ۣ : ابھی اُولٰٓئِكَ : یہی لوگ الَّذِيْنَ : وہ جو طَبَعَ : مہر کردی اللّٰهُ : اللہ نے عَلٰي قُلُوْبِهِمْ : ان کے دلوں پر وَاتَّبَعُوْٓا : اور انہوں نے پیروی کی اَهْوَآءَهُمْ : اپنی خواہشات اور ان میں بعض ایسے بھی ہیں کہ تیری طرف کان لگاتے ہیں، یہاں تک کہ جب تیرے پاس سے جاتے ہیں تو اہل علم سے پوچھتے ہیں کہ اس نے ابھی کیا کہا تھا ؟ (1) یہی لوگ ہیں جن کے دلوں پر اللہ نے مہر کردی اور وہ اپنی خواہشوں کی پیروی کرتے ہیں۔
47,17,وَ الَّذِیْنَ اهْتَدَوْا زَادَهُمْ هُدًى وَّ اٰتٰىهُمْ تَقْوٰىهُمْ وَالَّذِيْنَ : اور وہ لوگ جنہوں نے اهْتَدَوْا : ہدایت پائی زَادَهُمْ : اور زیادہ دی انہیں هُدًى : ہدایت وَّاٰتٰىهُمْ : اور انہیں عطا کی تَقْوٰىهُمْ : ان کی پرہیزگاری اور جو لوگ ہدایت یافتہ ہیں اللہ نے انہیں ہدایت میں بڑھا دیا ہے اور انہیں ان کی پرہیزگاری عطا فرمائی ہے (1)
47,18,فَهَلْ یَنْظُرُوْنَ اِلَّا السَّاعَةَ اَنْ تَاْتِیَهُمْ بَغْتَةً١ۚ فَقَدْ جَآءَ اَشْرَاطُهَا١ۚ فَاَنّٰى لَهُمْ اِذَا جَآءَتْهُمْ ذِكْرٰىهُمْ فَهَلْ : پس نہیں وہ يَنْظُرُوْنَ : منتظر اِلَّا السَّاعَةَ : مگر قیامت اَنْ تَاْتِيَهُمْ : کہ آجائے ان پر بَغْتَةً ۚ : اچانک فَقَدْ جَآءَ : سو آچکی ہیں اَشْرَاطُهَا ۚ : اسکی علامات فَاَنّٰى لَهُمْ : تو کہاں ان کیلئے، کو اِذَا : جب جَآءَتْهُمْ : وہ آگئی ان کے پاس ذِكْرٰىهُمْ : ان کا نصیحت (قبول کرنا) تو کیا یہ قیامت کا انتطار کر رہے ہیں کہ ان کے پاس اچانک آجائے یقیناً اس کی علامتیں تو آچکی ہیں (1) پھر جبکہ ان کے پاس قیامت آجائے انہیں نصیحت کرنا کہاں ہوگا (2)
47,19,فَاعْلَمْ اَنَّهٗ لَاۤ اِلٰهَ اِلَّا اللّٰهُ وَ اسْتَغْفِرْ لِذَنْۢبِكَ وَ لِلْمُؤْمِنِیْنَ وَ الْمُؤْمِنٰتِ١ؕ وَ اللّٰهُ یَعْلَمُ مُتَقَلَّبَكُمْ وَ مَثْوٰىكُمْ۠    ۧ فَاعْلَمْ : سو جان لو اَنَّهٗ : یہ کہ لَآ اِلٰهَ : نہیں کوئی معبود اِلَّا اللّٰهُ : اللہ کے سوا وَاسْتَغْفِرْ : اور بخشش مانگیں آپ لِذَنْۢبِكَ : اپنے ذنب (اپنے اوپر لگائے گئے الزام) کیلئے وَلِلْمُؤْمِنِيْنَ : اور مومن مردوں کیلئے وَالْمُؤْمِنٰتِ ۭ : اور مومن عورتوں وَاللّٰهُ : اور اللہ يَعْلَمُ : جانتا ہے مُتَقَلَّبَكُمْ : تمہارا چلنا پھرنا وَمَثْوٰىكُمْ : اور تمہارے رہنے سہنے کا مقام سو (اے نبی !) آپ یقین کرلیں کہ اللہ کے سوا کوئی معبود نہیں (1) اور اپنے گناہوں کی بخشش مانگا کریں اور مومن مردوں اور مومن عورتوں کے حق میں بھی (2) اللہ تم لوگوں کے آمد ورفت کی اور رہنے سہنے کی جگہ کو خوب جانتا ہے۔ (3)
47,20,وَ یَقُوْلُ الَّذِیْنَ اٰمَنُوْا لَوْ لَا نُزِّلَتْ سُوْرَةٌ١ۚ فَاِذَاۤ اُنْزِلَتْ سُوْرَةٌ مُّحْكَمَةٌ وَّ ذُكِرَ فِیْهَا الْقِتَالُ١ۙ رَاَیْتَ الَّذِیْنَ فِیْ قُلُوْبِهِمْ مَّرَضٌ یَّنْظُرُوْنَ اِلَیْكَ نَظَرَ الْمَغْشِیِّ عَلَیْهِ مِنَ الْمَوْتِ١ؕ فَاَوْلٰى لَهُمْۚ وَيَقُوْلُ : اور وہ کہتے ہیں الَّذِيْنَ : وہ لوگ جو اٰمَنُوْا : ایمان لائے لَوْلَا نُزِّلَتْ : کیوں نہ اتاری گئی سُوْرَةٌ ۚ : ایک سورة فَاِذَآ : سو جب اُنْزِلَتْ : اتاری جاتی ہے سُوْرَةٌ : سورة مُّحْكَمَةٌ : صاف صاف معانی والی وَّذُكِرَ : اور ذکر کیا جاتا ہے فِيْهَا : اس میں الْقِتَالُ ۙ : جنگ رَاَيْتَ الَّذِيْنَ : تم دیکھوگے وہ لوگ فِيْ قُلُوْبِهِمْ : ان کے دلوں میں مَّرَضٌ : بیماری يَّنْظُرُوْنَ : وہ دیکھتے ہیں اِلَيْكَ : آپ کی طرف نَظَرَ : دیکھنا الْمَغْشِيِّ : بیہوشی طاری ہوگئی عَلَيْهِ : اس پر مِنَ الْمَوْتِ ۭ : موت کی فَاَوْلٰى : سو خرابی لَهُمْ : ان کے لئے اور جو لوگ ایمان لائے اور کہتے ہیں کوئی سورت کیوں نازل نہیں کی گئی ؟ (1) پھر جب کوئی صاف مطلب والی سورت (2) نازل کی جاتی ہے اور اس میں قتال کا ذکر کیا جاتا ہے تو آپ دیکھتے ہیں کہ جن لوگوں کے دلوں میں بیماری ہے وہ آپ کی طرف اس طرح دیکھتے ہیں جیسے اس شخص کی نظر ہوتی ہے جس پر موت کی بیہوشی طاری ہو (3) پس بہت بہتر تھا ان کے لئے۔
47,21,طَاعَةٌ وَّ قَوْلٌ مَّعْرُوْفٌ١۫ فَاِذَا عَزَمَ الْاَمْرُ١۫ فَلَوْ صَدَقُوا اللّٰهَ لَكَانَ خَیْرًا لَّهُمْۚ طَاعَةٌ : اطاعت وَّقَوْلٌ : اور بات مَّعْرُوْفٌ ۣ : معقول فَاِذَا : پھر جب عَزَمَ الْاَمْرُ ۣ : پختہ ہوجائے کام فَلَوْ صَدَقُوا : تو اگر وہ سچے ہوتے اللّٰهَ : اللہ لَكَانَ خَيْرًا لَّهُمْ : البتہ ہوتا بہتر ان کیلئے فرمان کا بجا لانا اور اچھی بات کا کہنا پھر جب کام مقرر ہوجائے (1) تو اگر اللہ کے ساتھ سچے رہیں (2) تو ان کے لئے بہتری ہے (3)۔
47,22,فَهَلْ عَسَیْتُمْ اِنْ تَوَلَّیْتُمْ اَنْ تُفْسِدُوْا فِی الْاَرْضِ وَ تُقَطِّعُوْۤا اَرْحَامَكُمْ فَهَلْ عَسَيْتُمْ : سو تم اسکے نزدیک اِنْ تَوَلَّيْتُمْ : اگر تم والی (حاکم) ہوجاؤ اَنْ : کہ تُفْسِدُوْا : تم فساد مچاؤ فِي الْاَرْضِ : زمین میں وَتُقَطِّعُوْٓا : اور تم کاٹو (توڑ ڈالو) اَرْحَامَكُمْ : اپنے رشتے اور تم سے یہ بھی بعید نہیں کہ اگر تم کو حکومت مل جائے تو تم زمین میں فساد برپا کردو (1) اور رشتے ناتے توڑ ڈالو۔
47,23,اُولٰٓئِكَ الَّذِیْنَ لَعَنَهُمُ اللّٰهُ فَاَصَمَّهُمْ وَ اَعْمٰۤى اَبْصَارَهُمْ اُولٰٓئِكَ : یہی ہیں الَّذِيْنَ : وہ لوگ جن پر لَعَنَهُمُ اللّٰهُ : اللہ نے لعنت کی فَاَصَمَّهُمْ : پھر ان کو بہرا کردیا وَاَعْمٰٓى : اور اندھا کردیا اَبْصَارَهُمْ : ان کی آنکھیں یہ وہی لوگ ہیں جن پر اللہ کی پھٹکار ہے اور جن کی سماعت اور آنکھوں کی روشنی چھین لی ہے (1)۔
47,24,اَفَلَا یَتَدَبَّرُوْنَ الْقُرْاٰنَ اَمْ عَلٰى قُلُوْبٍ اَقْفَالُهَا اَفَلَا يَتَدَبَّرُوْنَ : تو کیا وہ غور نہیں کرتے الْقُرْاٰنَ : قرآن اَمْ : کیا عَلٰي : پر قُلُوْبٍ : دلوں اَقْفَالُهَا : ان کے تالے کیا یہ قرآن میں غورو فکر نہیں کرتے ؟ یا ان کے دلوں پر ان کے تالے لگ گئے ہیں (1)۔
47,25,اِنَّ الَّذِیْنَ ارْتَدُّوْا عَلٰۤى اَدْبَارِهِمْ مِّنْۢ بَعْدِ مَا تَبَیَّنَ لَهُمُ الْهُدَى١ۙ الشَّیْطٰنُ سَوَّلَ لَهُمْ١ؕ وَ اَمْلٰى لَهُمْ اِنَّ الَّذِيْنَ : بیشک جو لوگ ارْتَدُّوْا : پلٹ گئے عَلٰٓي اَدْبَارِهِمْ : اپنی پشت پر مِّنْۢ بَعْدِ : اس کے بعد مَا تَبَيَّنَ : جب واضح ہوگئی لَهُمُ : ان کے لئے الْهُدَى ۙ : ہدایت الشَّيْطٰنُ : شیطان سَوَّلَ : آراستہ کر دکھایا لَهُمْ ۭ : ان کے لئے وَاَمْلٰى : اور ڈھیل دی لَهُمْ : ان کو جو لوگ اپنی پیٹھ کے بل الٹے پھرگئے اس کے بعد کہ ان کے لئے ہدایت واضح (1) ہوچکی یقیناً شیطان نے ان کے لئے (ان کے فعل کو) مزین کردیا ہے اور انہیں ڈھیل دے رکھی ہے۔ (2)
47,26,ذٰلِكَ بِاَنَّهُمْ قَالُوْا لِلَّذِیْنَ كَرِهُوْا مَا نَزَّلَ اللّٰهُ سَنُطِیْعُكُمْ فِیْ بَعْضِ الْاَمْرِ١ۖۚ وَ اللّٰهُ یَعْلَمُ اِسْرَارَهُمْ ذٰلِكَ : یہ بِاَنَّهُمْ : اس لئے کہ وہ قَالُوْا : انہوں نے کہا لِلَّذِيْنَ : ان لوگوں سے جنہوں نے كَرِهُوْا : انہوں نے ناپسند کیا مَا نَزَّلَ اللّٰهُ : جو نازل کیا اللہ نے سَنُطِيْعُكُمْ : عنقریب ہم تمہارا کہنا مان لیں گے فِيْ بَعْضِ الْاَمْرِ ښ : بعض کاموں میں وَاللّٰهُ : اور اللہ يَعْلَمُ : جانتا ہے اِسْرَارَهُمْ : ان کی خفیہ باتیں یہ (1) اس لئے کہ انہوں نے ان لوگوں سے جنہوں نے اللہ کی نازل کردہ وحی کو برا سمجھا (2) کہ ہم بھی عنقریب بعض کاموں (3) میں تمہارا کہا مانیں گے، اور اللہ ان کی پوشیدہ باتیں خوب جانتا ہے۔ (4)
47,27,فَكَیْفَ اِذَا تَوَفَّتْهُمُ الْمَلٰٓئِكَةُ یَضْرِبُوْنَ وُجُوْهَهُمْ وَ اَدْبَارَهُمْ فَكَيْفَ : پس کیسا اِذَا تَوَفَّتْهُمُ : جب ان کی روح قبض کریں گے الْمَلٰٓئِكَةُ : فرشتے يَضْرِبُوْنَ : وہ مارتے ہیں وُجُوْهَهُمْ : ان کے چہروں وَاَدْبَارَهُمْ : اور ان کی پیٹھوں پس ان کی کیسی (درگت) ہوگی جبکہ فرشتے ان کی روح قبض کرتے ہوئے ان کے چہروں اور ان کی سروں پر ماریں گے (1)۔
47,28,ذٰلِكَ بِاَنَّهُمُ اتَّبَعُوْا مَاۤ اَسْخَطَ اللّٰهَ وَ كَرِهُوْا رِضْوَانَهٗ فَاَحْبَطَ اَعْمَالَهُمْ۠    ۧ ذٰلِكَ : یہ بِاَنَّهُمُ : اس لئے کہ انہوں نے اتَّبَعُوْا : پیروی کی مَآ اَسْخَطَ : جس نے ناراض کیا اللّٰهَ : اللہ کو وَكَرِهُوْا : اور انہوں نے پسند نہ کیا رِضْوَانَهٗ : اس کی رضا فَاَحْبَطَ : تو اس نے اکارت کردئیے اَعْمَالَهُمْ : ان کے اعمال یہ اس بنا پر کہ یہ وہ راہ چلے جس سے انہوں نے اللہ کو ناراض کردیا اور انہوں نے اس کی رضامندی کو برا جانا، تو اللہ نے ان کے اعمال اکارت کردیئے۔
47,29,اَمْ حَسِبَ الَّذِیْنَ فِیْ قُلُوْبِهِمْ مَّرَضٌ اَنْ لَّنْ یُّخْرِجَ اللّٰهُ اَضْغَانَهُمْ اَمْ حَسِبَ : کیا گمان کرتے ہیں الَّذِيْنَ : (وہ لوگ) جن فِيْ قُلُوْبِهِمْ : ان کے دلوں میں مَّرَضٌ : روگ اَنْ : کہ لَّنْ يُّخْرِجَ : ہرگز ظاہر نہ کرے گا اللّٰهُ : اللہ اَضْغَانَهُمْ : ان کے دل کی عداوتیں کیا ان لوگوں نے جن کے دلوں میں بیماری ہے یہ سمجھ رکھا ہے کہ اللہ ان کے حسد اور کینوں کو ظاہر ہی نہ کر دے (1) ،
47,30,وَ لَوْ نَشَآءُ لَاَرَیْنٰكَهُمْ فَلَعَرَفْتَهُمْ بِسِیْمٰىهُمْ١ؕ وَ لَتَعْرِفَنَّهُمْ فِیْ لَحْنِ الْقَوْلِ١ؕ وَ اللّٰهُ یَعْلَمُ اَعْمَالَكُمْ وَلَوْ : اور اگر نَشَآءُ : ہم چاہیں لَاَرَيْنٰكَهُمْ : تو تمہیں دکھادیں وہ لوگ فَلَعَرَفْتَهُمْ : سو البتہ تم انہیں پہچان لو بِسِيْمٰهُمْ ۭ : انکے چہروں سے وَلَتَعْرِفَنَّهُمْ : اور تم ضرور پہچان لوگے انہیں فِيْ : میں، سے لَحْنِ الْقَوْلِ ۭ : طرزِ کلام وَاللّٰهُ يَعْلَمُ : اور اللہ جانتا ہے اَعْمَالَكُمْ : تمہارے اعمال اور اگر ہم چاہتے تو ان سب کو تجھے دکھا دیتے پس تو انہیں ان کے چہروں سے ہی پہچان لیتا (1) اور یقیناً تو انہیں ان کی بات کے ڈھب سے پہچان لے گا۔ (2) تمہارے سب کام اللہ کو معلوم ہیں۔
47,31,وَ لَنَبْلُوَنَّكُمْ حَتّٰى نَعْلَمَ الْمُجٰهِدِیْنَ مِنْكُمْ وَ الصّٰبِرِیْنَ١ۙ وَ نَبْلُوَاۡ اَخْبَارَكُمْ وَلَنَبْلُوَنَّكُمْ : اور ہم ضرور آزمائیں گے تمہیں حَتّٰى : یہاں تک کہ نَعْلَمَ : ہم جان لیں الْمُجٰهِدِيْنَ : مجاہدوں کو مِنْكُمْ : تم میں سے وَالصّٰبِرِيْنَ ۙ : اور صبر کرنے والے وَنَبْلُوَا۟ : اور ہم جانچ لیں اَخْبَارَكُمْ : تمہاری خبریں (حالات) یقیناً ہم تمہارا امتحان کریں گے تاکہ تم میں سے جہاد کرنے والوں اور صبر کرنے والوں کو ظاہر کردیں اور ہم تمہاری حالتوں کی بھی جانچ کرلیں (1)۔
47,32,اِنَّ الَّذِیْنَ كَفَرُوْا وَ صَدُّوْا عَنْ سَبِیْلِ اللّٰهِ وَ شَآقُّوا الرَّسُوْلَ مِنْۢ بَعْدِ مَا تَبَیَّنَ لَهُمُ الْهُدٰى١ۙ لَنْ یَّضُرُّوا اللّٰهَ شَیْئًا١ؕ وَ سَیُحْبِطُ اَعْمَالَهُمْ اِنَّ الَّذِيْنَ كَفَرُوْا : بیشک جن لوگوں نے کفر کیا وَصَدُّوْا : اور انہوں نے روکا عَنْ سَبِيْلِ اللّٰهِ : اللہ کے راستے سے وَشَآقُّوا الرَّسُوْلَ : اور انہوں نے مخالفت کی رسول کی مِنْۢ بَعْدِ مَا : اس کے بعد تَبَيَّنَ : جب واضح ہوگئی لَهُمُ : ان پر الْهُدٰى ۙ : ہدایت لَنْ يَّضُرُّوا اللّٰهَ : وہ ہرگز نہ بگاڑ سکیں گے اللہ کا شَيْئًا ۭ : کچھ بھی وَسَيُحْبِطُ : اور وہ جلد اکارت کردئیے گئے اَعْمَالَهُمْ : ان کے اعمال یقیناً جن لوگوں نے کفر کیا اور اللہ کی راہ سے لوگوں کو روکا اور رسول کی مخالفت کی اس کے بعد کہ ان کے لئے ہدایت ظاہر ہوچکی یہ ہرگز ہرگز اللہ کا کچھ نقصان نہ کریں گے (1) عنقریب ان کے اعمال وہ غارت کر دے گا (2)۔
47,33,یٰۤاَیُّهَا الَّذِیْنَ اٰمَنُوْۤا اَطِیْعُوا اللّٰهَ وَ اَطِیْعُوا الرَّسُوْلَ وَ لَا تُبْطِلُوْۤا اَعْمَالَكُمْ يٰٓاَيُّهَا : اے الَّذِيْنَ : جو لوگ اٰمَنُوْٓا : ایمان لائے اَطِيْعُوا اللّٰهَ : اطاعت کرو اللہ کی وَاَطِيْعُوا : اور اطاعت کرو الرَّسُوْلَ : رسول کی وَلَا تُبْطِلُوْٓا : اور باطل نہ کرو اَعْمَالَكُمْ : اپنے اعمال اے ایمان والو ! اللہ کی اطاعت کرو اور رسول کا کہا مانو اور اپنے اعمال کو غارت نہ کرو۔ (1)
47,34,اِنَّ الَّذِیْنَ كَفَرُوْا وَ صَدُّوْا عَنْ سَبِیْلِ اللّٰهِ ثُمَّ مَاتُوْا وَ هُمْ كُفَّارٌ فَلَنْ یَّغْفِرَ اللّٰهُ لَهُمْ اِنَّ الَّذِيْنَ كَفَرُوْا : بیشک جن لوگوں نے کفر کیا وَصَدُّوْا : اور انہوں نے روکا عَنْ سَبِيْلِ اللّٰهِ : اللہ کے راستے سے ثُمَّ مَاتُوْا : پھر وہ مرگئے وَهُمْ كُفَّارٌ : اور وہ کافر ہی فَلَنْ يَّغْفِرَ : تو ہرگز نہیں بخشے گا اللّٰهُ : اللہ لَهُمْ : ان کو جن لوگوں نے کفر کیا اور اللہ کی راہ سے اوروں کو روکا پھر کفر کی حالت میں ہی مرگئے (یقین کرلو) کہ اللہ انہیں ہرگز نہ بخشے گا۔
47,35,فَلَا تَهِنُوْا وَ تَدْعُوْۤا اِلَى السَّلْمِ١ۖۗ وَ اَنْتُمُ الْاَعْلَوْنَ١ۖۗ وَ اللّٰهُ مَعَكُمْ وَ لَنْ یَّتِرَكُمْ اَعْمَالَكُمْ فَلَا تَهِنُوْا : پس تم سستی نہ کرو وَتَدْعُوْٓا : اور نہ بلاؤ اِلَى السَّلْمِ ڰ : صلح کی طرف وَاَنْتُمُ الْاَعْلَوْنَ ڰ : اور تم ہی غالب وَاللّٰهُ : اور اللہ مَعَكُمْ : تمہارے ساتھ وَلَنْ يَّتِرَكُمْ : اور وہ ہرگز کمی نہ کریگا اَعْمَالَكُمْ : تمہارے اعمال میں پس تم بودے بن کر صلح کی درخواست پر نہ اتر آؤ جبکہ تم ہی بلندو غالب رہو گے (1) اور اللہ تمہارے ساتھ ہے (2) ناممکن ہے کہ وہ تمہارے اعمال ضائع کر دے (3)۔
47,36,اِنَّمَا الْحَیٰوةُ الدُّنْیَا لَعِبٌ وَّ لَهْوٌ١ؕ وَ اِنْ تُؤْمِنُوْا وَ تَتَّقُوْا یُؤْتِكُمْ اُجُوْرَكُمْ وَ لَا یَسْئَلْكُمْ اَمْوَالَكُمْ اِنَّمَا : اس کے سوا نہیں الْحَيٰوةُ الدُّنْيَا : دنیا کی زندگی لَعِبٌ : کھیل وَّلَهْوٌ ۭ : اور کود وَاِنْ : اور اگر تُؤْمِنُوْا : ایمان لے آؤ وَتَتَّقُوْا : اور تقوی اختیار کرو يُؤْتِكُمْ : وہ تمہیں دے گا اُجُوْرَكُمْ : تمہارے اجر وَلَا يَسْئَلْكُمْ : اور نہ طلب کرے گا تم سے اَمْوَالَكُمْ : تمہارے مال واقعی زندگانی دنیا صرف کھیل کود ہے (1) اور اگر تم ایمان لے آؤ گے اور تقوٰی اختیار کرو گے تو اللہ تمہیں تمہارے اجر دے گا اور تم سے تمہارے مال نہیں مانگتا (2)
47,37,اِنْ یَّسْئَلْكُمُوْهَا فَیُحْفِكُمْ تَبْخَلُوْا وَ یُخْرِجْ اَضْغَانَكُمْ اِنْ : اگر يَّسْئَلْكُمُوْهَا : وہ تم سے (مال) طلب کرے فَيُحْفِكُمْ : پھر تم سے چمٹ جائے تَبْخَلُوْا : تم بخل کرو وَيُخْرِجْ : اور ظاہر ہوجائیں اَضْغَانَكُمْ : تمہاری عداوتیں اگر وہ تم سے تمہارا مال مانگے اور زور دے کر مانگے تو تم اس سے بخیلی کرنے لگو گے اور تمہارے کینے ظاہر کر دے گا (1)
47,38,هٰۤاَنْتُمْ هٰۤؤُلَآءِ تُدْعَوْنَ لِتُنْفِقُوْا فِیْ سَبِیْلِ اللّٰهِ١ۚ فَمِنْكُمْ مَّنْ یَّبْخَلُ١ۚ وَ مَنْ یَّبْخَلْ فَاِنَّمَا یَبْخَلُ عَنْ نَّفْسِهٖ١ؕ وَ اللّٰهُ الْغَنِیُّ وَ اَنْتُمُ الْفُقَرَآءُ١ۚ وَ اِنْ تَتَوَلَّوْا یَسْتَبْدِلْ قَوْمًا غَیْرَكُمْ١ۙ ثُمَّ لَا یَكُوْنُوْۤا اَمْثَالَكُمْ۠    ۧ هٰٓاَنْتُمْ : یہ تم ہو هٰٓؤُلَآءِ : ہاں ! وہ لوگ تُدْعَوْنَ : تمہیں پکارا جاتا ہے لِتُنْفِقُوْا : کہ تم خرچ کرو فِيْ سَبِيْلِ اللّٰهِ ۚ : اللہ کے راستے میں فَمِنْكُمْ : پھر تم میں سے مَّنْ : کوئی ایسا ہے کہ يَّبْخَلُ ۚ : بخل کرتا ہے وَمَنْ : اور جو يَّبْخَلْ : بخل کرتا ہے فَاِنَّمَا : تو اس کے سوا نہیں يَبْخَلُ : وہ بخل کرتا ہے عَنْ نَّفْسِهٖ ۭ : اپنے آپ سے وَاللّٰهُ : اور اللہ الْغَنِيُّ : بےنیاز وَاَنْتُمُ الْفُقَرَآءُ ۚ : اور تم محتاج (جمع) وَاِنْ : اور اگر تَتَوَلَّوْا : تم روگردانی کروگے يَسْتَبْدِلْ : وہ بدل دے گا قَوْمًا : دوسری قوم غَيْرَكُمْ ۙ : تمہارے سوا ثُمَّ : پھر لَا يَكُوْنُوْٓا : وہ نہ ہوں گے اَمْثَالَكُمْ : تمہارے جیسے خبردار ! تم وہ لوگ ہو کہ اللہ کی راہ میں خرچ کرنے کے لئے بلائے جاتے (1) ہو تو تم بخیلی کرنے لگتے ہو اور جو بخل کرتا ہے وہ تو دراصل اپنی جان سے بخیلی کرتا ہے (2) اللہ تعالیٰ غنی ہے اور تم فقیر اور محتاج ہو (3) اور اگر تم روگردان ہوجاؤ (4) تو وہ تمہارے بدلے تمہارے سوا اور لوگوں کو لائے گا جو پھر تم جیسے نہ ہونگے۔ (5)
