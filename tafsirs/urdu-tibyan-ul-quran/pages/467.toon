tafsir[8]{c,v,t}:
  39,75,وَ تَرَى الْمَلٰٓئِكَةَ حَآفِّیْنَ مِنْ حَوْلِ الْعَرْشِ یُسَبِّحُوْنَ بِحَمْدِ رَبِّهِمْ١ۚ وَ قُضِیَ بَیْنَهُمْ بِالْحَقِّ وَ قِیْلَ الْحَمْدُ لِلّٰهِ رَبِّ الْعٰلَمِیْنَ۠    ۧ وَتَرَى : اور آپ دیکھیں گے الْمَلٰٓئِكَةَ : فرشتے حَآفِّيْنَ : حلقہ باندھے مِنْ : سے حَوْلِ الْعَرْشِ : عرش کے گرد يُسَبِّحُوْنَ : پاکیزگی بیان کرتے ہوئے بِحَمْدِ : تعریف کے ساتھ رَبِّهِمْ ۚ : اپنا رب وَقُضِيَ : اور فیصلہ کردیا جائے گا بَيْنَهُمْ : ان کے درمیان بِالْحَقِّ : حق کے ساتھ وَقِيْلَ : اور کہا جائے گا الْحَمْدُ : تمام تعریفیں لِلّٰهِ : اللہ کے لیے رَبِّ : پروردگار الْعٰلَمِيْنَ : سارے جہان (جمع) اور تو فرشتوں کو اللہ کے عرش کے ارد گرد حلقہ باندھے ہوئے اپنے رب کی حمد و تسبیح کرتے ہوئے دیکھے گا (1) اور ان میں انصاف کا فیصلہ کیا جائے گا اور کہہ دیا جائے گا کہ ساری خوبی اللہ ہی کے لئے ہے جو تمام جہانوں کا پالنہار ہے (2)۔
  40,1,حٰمٓۚ حٰمٓ : حا۔ میم حم
  40,2,تَنْزِیْلُ الْكِتٰبِ مِنَ اللّٰهِ الْعَزِیْزِ الْعَلِیْمِۙ تَنْزِيْلُ : اتارا جانا الْكِتٰبِ : کتاب (قرآن) مِنَ اللّٰهِ : اللہ سے الْعَزِيْزِ : غالب الْعَلِيْمِ : ہر چیز کا جاننے والا اس کتاب کا نازل فرمانا (1) اس اللہ کی طرف سے ہے جو غالب اور دانا ہے (2)
  40,3,غَافِرِ الذَّنْۢبِ وَ قَابِلِ التَّوْبِ شَدِیْدِ الْعِقَابِ١ۙ ذِی الطَّوْلِ١ؕ لَاۤ اِلٰهَ اِلَّا هُوَ١ؕ اِلَیْهِ الْمَصِیْرُ غَافِرِ : بخشنے والا الذَّنْۢبِ : گناہ (جمع) وَقَابِلِ : اور قبول کرنے والا التَّوْبِ : توبہ شَدِيْدِ الْعِقَابِ ۙ : شدید عذاب والا ذِي الطَّوْلِ ۭ : بڑے فضل والا لَآ : نہیں کوئی اِلٰهَ : معبود اِلَّا هُوَ ۭ : اس کے سوا اِلَيْهِ : اسی کی طرف الْمَصِيْرُ : لوٹ کر جانا گناہ کو بخشنے والا اور توبہ قبول فرمانے والا (1) سخت عذاب والا، انعام وقدرت والا (2) جس کے سوا کوئی معبود نہیں، اسی کی طرف واپس لو ٹنا ہے۔ (3)
  40,4,مَا یُجَادِلُ فِیْۤ اٰیٰتِ اللّٰهِ اِلَّا الَّذِیْنَ كَفَرُوْا فَلَا یَغْرُرْكَ تَقَلُّبُهُمْ فِی الْبِلَادِ مَا يُجَادِلُ : وہ نہیں جھگڑتے فِيْٓ : میں اٰيٰتِ اللّٰهِ : اللہ کی آیات اِلَّا : مگر الَّذِيْنَ كَفَرُوْا : وہ لوگ جنہوں نے کفر کیا فَلَا يَغْرُرْكَ : سو تمہیں دھوکہ میں ڈال دے تَقَلُّبُهُمْ : ان کا چلنا پھرنا فِي الْبِلَادِ : شہروں میں اللہ تعالیٰ کی آیتوں میں وہی لوگ جھگڑتے ہیں (1) جو کافر ہیں پس ان لوگوں کا شہروں میں چلنا پھرنا آپ کو دھوکے میں نہ ڈالے (2)۔
  40,5,كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوْحٍ وَّ الْاَحْزَابُ مِنْۢ بَعْدِهِمْ١۪ وَ هَمَّتْ كُلُّ اُمَّةٍۭ بِرَسُوْلِهِمْ لِیَاْخُذُوْهُ وَ جٰدَلُوْا بِالْبَاطِلِ لِیُدْحِضُوْا بِهِ الْحَقَّ فَاَخَذْتُهُمْ١۫ فَكَیْفَ كَانَ عِقَابِ كَذَّبَتْ : جھٹلایا قَبْلَهُمْ : ان سے قبل قَوْمُ نُوْحٍ : نوح کی قوم وَّالْاَحْزَابُ : اور گروہ (جمع) مِنْۢ بَعْدِهِمْ ۠ : ان کے بعد وَهَمَّتْ : اور ارادہ باندھا كُلُّ اُمَّةٍۢ : ہر امت بِرَسُوْلِهِمْ : اپنے رسول کے متعلق لِيَاْخُذُوْهُ : کہ وہ اسے پکڑ لیں وَجٰدَلُوْا : اور جھگڑا کریں بِالْبَاطِلِ : ناحق لِيُدْحِضُوْا : تاکہ ناچیز کردیں بنیادیں بِهِ : اس سے الْحَقَّ : حق فَاَخَذْتُهُمْ ۣ : تو میں نے انہیں پکڑ لیا فَكَيْفَ : سو کیسا كَانَ : ہوا عِقَابِ : میرا عذاب قوم نوح نے اور ان کے بعد کے گروہوں نے بھی جھٹلایا تھا۔ اور ہر امت نے اپنے رسول کو گرفتار کرلینے کا ارادہ کیا (1) اور باطل کے ذریعے جھوٹے بحث مباحثے کئے تاکہ ان سے حق کو بگاڑ دیں (2) پس میں نے انہیں پکڑ لیا، سو میری طرف سے کیسی سزا ہوئی (3)۔
  40,6,وَ كَذٰلِكَ حَقَّتْ كَلِمَتُ رَبِّكَ عَلَى الَّذِیْنَ كَفَرُوْۤا اَنَّهُمْ اَصْحٰبُ النَّارِۘؔ وَكَذٰلِكَ : اور اسی طرح حَقَّتْ كَلِمَتُ : ثابت ہوگئی بات رَبِّكَ : تمہارے رب کی عَلَي : پر الَّذِيْنَ : جن لوگوں نے كَفَرُوْٓا : کفر کیا اَنَّهُمْ : کہ وہ اَصْحٰبُ النَّارِ : دوزخ والے اور اسی طرح آپ کے رب کا حکم کافروں پر ثابت ہوگیا کہ وہ دوزخی ہیں۔ (1)
  40,7,اَلَّذِیْنَ یَحْمِلُوْنَ الْعَرْشَ وَ مَنْ حَوْلَهٗ یُسَبِّحُوْنَ بِحَمْدِ رَبِّهِمْ وَ یُؤْمِنُوْنَ بِهٖ وَ یَسْتَغْفِرُوْنَ لِلَّذِیْنَ اٰمَنُوْا١ۚ رَبَّنَا وَسِعْتَ كُلَّ شَیْءٍ رَّحْمَةً وَّ عِلْمًا فَاغْفِرْ لِلَّذِیْنَ تَابُوْا وَ اتَّبَعُوْا سَبِیْلَكَ وَ قِهِمْ عَذَابَ الْجَحِیْمِ اَلَّذِيْنَ : وہ جو (فرشتے) يَحْمِلُوْنَ : اٹھائے ہوئے ہیں الْعَرْشَ : عرش وَمَنْ حَوْلَهٗ : اور جو اسکے ارد گرد يُسَبِّحُوْنَ : وہ پاکیزگی بیان کرتے ہیں بِحَمْدِ : تعریف کے ساتھ رَبِّهِمْ : اپنے رب کی وَيُؤْمِنُوْنَ : اور ایمان لاتے ہیں بِهٖ : اس پر وَيَسْتَغْفِرُوْنَ : اور مغفرت مانگتے ہیں لِلَّذِيْنَ : ان کے لئے جو اٰمَنُوْا ۚ : وہ ایمان لائے رَبَّنَا : اے ہمارے رب وَسِعْتَ : سمولیا ہے كُلَّ شَيْءٍ : ہر شے رَّحْمَةً : رحمت وَّعِلْمًا : اور علم فَاغْفِرْ : سو تو بخشدے لِلَّذِيْنَ : وہ لوگ جنہوں نے تَابُوْا : توبہ کی وَاتَّبَعُوْا : اور انہوں نے پیروی کی سَبِيْلَكَ : تیرا راستہ وَقِهِمْ : انہیں بچالے عَذَابَ : عذاب الْجَحِيْمِ : جہنم عرش کے اٹھانے والے اور اس کے پاس کے فرشتے اپنے رب کی تسبیح و حمد کے ساتھ ساتھ کرتے ہیں اور اس پر ایمان رکھتے ہیں اور ایمان والوں کے لئے استغفار کرتے ہیں، کہتے ہیں کہ اے ہمارے پروردگار ! تو نے ہر چیز کو اپنی بخشش اور علم سے گھیر رکھا ہے، پس انہیں بخش دے جو توبہ کریں اور تیری راہ کی پیروی کریں اور تو انہیں دوزخ کے عذاب سے بھی بچا لے۔ (1)
