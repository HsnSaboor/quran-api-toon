tafsir[9]{c,v,t}:
  41,30,اِنَّ الَّذِیْنَ قَالُوْا رَبُّنَا اللّٰهُ ثُمَّ اسْتَقَامُوْا تَتَنَزَّلُ عَلَیْهِمُ الْمَلٰٓئِكَةُ اَلَّا تَخَافُوْا وَ لَا تَحْزَنُوْا وَ اَبْشِرُوْا بِالْجَنَّةِ الَّتِیْ كُنْتُمْ تُوْعَدُوْنَ اِنَّ : بیشک الَّذِيْنَ : وہ جنہوں نے قَالُوْا : انہوں نے کہا رَبُّنَا اللّٰهُ : ہمارا رب اللہ ثُمَّ : پھر اسْتَقَامُوْا : وہ ثابت قدم رہے تَتَنَزَّلُ : اترتے ہیں عَلَيْهِمُ : ان پر الْمَلٰٓئِكَةُ : فرشتے اَلَّا تَخَافُوْا : کہ نہ تم خوف کھاؤ وَلَا تَحْزَنُوْا : اور نہ غمگین ہو وَاَبْشِرُوْا : اور تم خوش ہو بِالْجَنَّةِ : جنت پر الَّتِيْ : وہ جو كُنْتُمْ تُوْعَدُوْنَ : تمہیں وعدہ دیاجاتا تھا (واقعی) جن لوگوں نے کہا ہمارا پروردگار اللہ ہے (1) اور پھر اسی پر قائم رہے (2) ان کے پاس فرشتے (یہ کہتے ہوئے) آتے ہیں (4) کہ تم کچھ بھی اندیشہ اور غم نہ کرو (3) (بلکہ) اس جنت کی بشارت سن لو جس کا تم وعدہ دیئے گئے ہو (5)۔
  41,31,نَحْنُ اَوْلِیٰٓؤُكُمْ فِی الْحَیٰوةِ الدُّنْیَا وَ فِی الْاٰخِرَةِ١ۚ وَ لَكُمْ فِیْهَا مَا تَشْتَهِیْۤ اَنْفُسُكُمْ وَ لَكُمْ فِیْهَا مَا تَدَّعُوْنَؕ نَحْنُ : ہم اَوْلِيٰٓؤُكُمْ : تمہارے رفیق فِي الْحَيٰوةِ : زندگی میں الدُّنْيَا : دنیا وَفِي الْاٰخِرَةِ ۚ : اور آخرت میں وَلَكُمْ : اور تمہارے لئے فِيْهَا : اس میں مَا تَشْتَهِيْٓ : جو چاہیں اَنْفُسُكُمْ : تمہارے دل وَلَكُمْ : اور تمہارے لئے فِيْهَا : اس میں مَا تَدَّعُوْنَ : جو تم مانگو گے تمہاری دنیاوی زندگی میں بھی ہم تمہارے رفیق تھے اور آخرت میں بھی رہیں گے (1) جس چیز کو تمہارا جی چاہے اور جو کچھ تم مانگو سب تمہارے لئے (جنت میں موجود) ہے۔
  41,32,نُزُلًا مِّنْ غَفُوْرٍ رَّحِیْمٍ۠    ۧ نُزُلًا : ضیافت مِّنْ : سے غَفُوْرٍ : بخشنے والا رَّحِيْمٍ : مہربان غفور و رحیم (معبود) کی طرف سے یہ سب کچھ بطور مہمانی کے ہے۔
  41,33,وَ مَنْ اَحْسَنُ قَوْلًا مِّمَّنْ دَعَاۤ اِلَى اللّٰهِ وَ عَمِلَ صَالِحًا وَّ قَالَ اِنَّنِیْ مِنَ الْمُسْلِمِیْنَ وَمَنْ : اور کس اَحْسَنُ : بہترین قَوْلًا : بات مِّمَّنْ : اس سے جو دَعَآ : بلائے اِلَى اللّٰهِ : اللہ کی طرف وَعَمِلَ : اور عمل کرے صَالِحًا : اچھے وَّقَالَ : اور وہ کہے اِنَّنِيْ : بیشک میں مِنَ : سے الْمُسْلِمِيْنَ : مسلمانوں اور اس سے زیادہ اچھی بات والا کون ہے جو اللہ کی طرف بلائے اور نیک کام کرے اور کہے کہ میں یقیناً مسلمانوں میں سے ہوں (1)
  41,34,وَ لَا تَسْتَوِی الْحَسَنَةُ وَ لَا السَّیِّئَةُ١ؕ اِدْفَعْ بِالَّتِیْ هِیَ اَحْسَنُ فَاِذَا الَّذِیْ بَیْنَكَ وَ بَیْنَهٗ عَدَاوَةٌ كَاَنَّهٗ وَلِیٌّ حَمِیْمٌ وَلَا تَسْتَوِي : اور برابر نہیں ہوتی الْحَسَنَةُ : نیکی وَلَا السَّيِّئَةُ ۭ : اور نہ بُرائی اِدْفَعْ : دور کردیں بِالَّتِيْ : اس سے جو هِىَ اَحْسَنُ : وہ بہترین فَاِذَا الَّذِيْ : تو یکایک وہ جو شخص بَيْنَكَ : آپ کے درمیان وَبَيْنَهٗ : اور اس کے درمیان عَدَاوَةٌ : عداوت كَاَنَّهٗ وَلِيٌّ : گویا کہ وہ دوست حَمِيْمٌ : قرابتی (جگری) نیکی اور بدی برابر نہیں ہوتی (1) برائی کو بھلائی سے دفع کرو پھر وہی جس کے اور تمہارے درمیان دشمنی ہے ایسا ہوجائے گا جیسے دلی دوست۔ (2)
  41,35,وَ مَا یُلَقّٰىهَاۤ اِلَّا الَّذِیْنَ صَبَرُوْا١ۚ وَ مَا یُلَقّٰىهَاۤ اِلَّا ذُوْ حَظٍّ عَظِیْمٍ وَمَا يُلَقّٰىهَآ : اور نہیں ملتی یہ اِلَّا : مگر الَّذِيْنَ : وہ جنہوں نے صَبَرُوْا ۚ : صبر کیا وَمَا يُلَقّٰىهَآ : اور نہیں ملتی یہ اِلَّا : مگر ذُوْ حَظٍّ : نصیب والے عَظِيْمٍ : بڑے اور یہ بات انہیں نصیب ہوتی ہے جو صبر کریں (1) اور اسے سوائے بڑے نصیبے والوں کے کوئی نہیں پاسکتا (2)
  41,36,وَ اِمَّا یَنْزَغَنَّكَ مِنَ الشَّیْطٰنِ نَزْغٌ فَاسْتَعِذْ بِاللّٰهِ١ؕ اِنَّهٗ هُوَ السَّمِیْعُ الْعَلِیْمُ وَاِمَّا يَنْزَغَنَّكَ : اور اگر تمہیں وسوسہ آئے۔ مِنَ : سے الشَّيْطٰنِ : شیطان نَزْغٌ : کوئی وسوسہ فَاسْتَعِذْ باللّٰهِ ۭ : تو پناہ چاہیں اللہ کی اِنَّهٗ : بیشک وہ هُوَ السَّمِيْعُ : وہی سننے والا الْعَلِيْمُ : جاننے والا اور اگر شیطان کی طرف سے کوئی وسوسہ آئے تو اللہ کی پناہ طلب کرو (1) یقیناً وہ بہت ہی سننے والا جاننے والا ہے (2)
  41,37,وَ مِنْ اٰیٰتِهِ الَّیْلُ وَ النَّهَارُ وَ الشَّمْسُ وَ الْقَمَرُ١ؕ لَا تَسْجُدُوْا لِلشَّمْسِ وَ لَا لِلْقَمَرِ وَ اسْجُدُوْا لِلّٰهِ الَّذِیْ خَلَقَهُنَّ اِنْ كُنْتُمْ اِیَّاهُ تَعْبُدُوْنَ وَمِنْ اٰيٰتِهِ : اور اس کی نشانیوں میں سے ہے الَّيْلُ : رات وَالنَّهَارُ : اور دن وَالشَّمْسُ : اور سورج وَالْقَمَرُ ۭ : اور چاند لَا تَسْجُدُوْا : اور نہ سجدہ کرو لِلشَّمْسِ : سورج کو وَلَا لِلْقَمَرِ : اور نہ چاند کو وَاسْجُدُوْا : اور تم سجدہ کرو لِلّٰهِ : اللہ کو الَّذِيْ : وہ جس نے خَلَقَهُنَّ : پیدا کیا انہیں اِنْ كُنْتُمْ : اگر تم ہو اِيَّاهُ : اس کی تَعْبُدُوْنَ : عبادت کرتے اور دن رات اور سورج چاند بھی (اسی کی) نشانیوں میں سے ہیں (1) تم سورج کو سجدہ نہ کرو نہ چاند کو (2) بلکہ سجدہ اس اللہ کے لئے کرو جس نے سب کو پیدا کیا ہے (3) اگر تمہیں اس کی عبادت کرنی ہے تو۔
  41,38,فَاِنِ اسْتَكْبَرُوْا فَالَّذِیْنَ عِنْدَ رَبِّكَ یُسَبِّحُوْنَ لَهٗ بِالَّیْلِ وَ النَّهَارِ وَ هُمْ لَا یَسْئَمُوْنَ۩  ۞ فَاِنِ : پس اگر وہ اسْتَكْبَرُوْا : تکبر کریں فَالَّذِيْنَ : سو وہ جو عِنْدَ رَبِّكَ : آپ کے رب کے نزدیک يُسَبِّحُوْنَ : وہ تسبیح کرتے ہیں لَهٗ بالَّيْلِ : اس کی رات وَالنَّهَارِ : اور دن وَهُمْ : اور وہ لَا يَسْئَمُوْنَ : نہیں اکتاتے پھر بھی اگر یہ کبر و غرور کریں تو وہ (فرشتے) جو آپ کے رب کے نزدیک ہیں وہ تو رات دن اس کی تسبیح بیان کر رہے ہیں اور (کسی وقت بھی) نہیں اکتاتے۔
