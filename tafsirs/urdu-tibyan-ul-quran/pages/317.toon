tafsir[11]{c,v,t}:
  20,77,وَ لَقَدْ اَوْحَیْنَاۤ اِلٰى مُوْسٰۤى١ۙ۬ اَنْ اَسْرِ بِعِبَادِیْ فَاضْرِبْ لَهُمْ طَرِیْقًا فِی الْبَحْرِ یَبَسًا١ۙ لَّا تَخٰفُ دَرَكًا وَّ لَا تَخْشٰى وَلَقَدْ اَوْحَيْنَآ : اور تحقیق ہم نے وحی کی اِلٰى : طرف۔ کو مُوْسٰٓى : موسیٰ اَنْ اَسْرِ : کہ راتوں رات لے جا بِعِبَادِيْ : میرے بندے فَاضْرِبْ : پس بنا لینا لَهُمْ : ان کے لیے طَرِيْقًا : راستہ فِي الْبَحْرِ : دریا میں يَبَسًا : خشک لَّا : نہ تَخٰفُ : خوف ہوگا دَرَكًا : پکڑنا وَّلَا تَخْشٰى : اور نہ ڈر ہم نے موسیٰ ؑ کی طرف وحی نازل فرمائی کہ تو راتوں رات میرے بندوں کو لے چل (1) پھر نہ تجھے کسی کے آپکڑنے کا خطرہ ہوگا نہ ڈر (2)۔
  20,78,فَاَتْبَعَهُمْ فِرْعَوْنُ بِجُنُوْدِهٖ فَغَشِیَهُمْ مِّنَ الْیَمِّ مَا غَشِیَهُمْؕ فَاَتْبَعَهُمْ : پھر ان کا پیچھا کیا فِرْعَوْنُ : فرعون بِجُنُوْدِهٖ : اپنے لشکر کے ساتھ فَغَشِيَهُمْ : انہیں ڈھانپ لیا مِّنَ الْيَمِّ : دریا سے مَا غَشِيَهُمْ : جیسا کہ ان کو ڈھانپ لیا فرعون نے اپنے لشکروں سمیت ان کا تعاقب کیا پھر تو دریا ان سب پر چھا گیا جیسا کچھ چھا جانے والا تھا (1)
  20,79,وَ اَضَلَّ فِرْعَوْنُ قَوْمَهٗ وَ مَا هَدٰى وَاَضَلَّ : اور گمراہ کیا فِرْعَوْنُ : فرعون قَوْمَهٗ : اپنی قوم وَمَا هَدٰى : اور نہ ہدایت دی فرعون نے اپنی قوم کو گمراہی میں ڈال دیا اور سیدھا راستہ نہ دکھایا (1)
  20,80,یٰبَنِیْۤ اِسْرَآءِیْلَ قَدْ اَنْجَیْنٰكُمْ مِّنْ عَدُوِّكُمْ وَ وٰعَدْنٰكُمْ جَانِبَ الطُّوْرِ الْاَیْمَنَ وَ نَزَّلْنَا عَلَیْكُمُ الْمَنَّ وَ السَّلْوٰى يٰبَنِيْٓ اِسْرَآءِيْلَ : اے بنی اسرائیل قَدْ : تحقیق اَنْجَيْنٰكُمْ : ہم نے تمہیں نجات دی مِّنْ : سے عَدُوِّكُمْ : تمہارا دشمن وَوٰعَدْنٰكُمْ : اور ہم نے تم سے وعدہ کیا جَانِبَ : جانب الطُّوْرِ الْاَيْمَنَ : کوہ طور دائیں وَنَزَّلْنَا : اور ہم نے اتارا عَلَيْكُمُ : تم پر الْمَنَّ : من وَالسَّلْوٰى : اور سلوی اے بنی اسرائیل ! دیکھو ہم نے تمہیں تمہارے دشمن سے نجات دی اور تم سے کوہ طور کی دائیں طرف کا وعدہ (1) اور تم پر من وسلویٰ اتارا (2)
  20,81,كُلُوْا مِنْ طَیِّبٰتِ مَا رَزَقْنٰكُمْ وَ لَا تَطْغَوْا فِیْهِ فَیَحِلَّ عَلَیْكُمْ غَضَبِیْ١ۚ وَ مَنْ یَّحْلِلْ عَلَیْهِ غَضَبِیْ فَقَدْ هَوٰى كُلُوْا : تم کھاؤ مِنْ : سے طَيِّبٰتِ : پاکیزہ چیزیں مَا رَزَقْنٰكُمْ : جو ہم نے تمہیں دیا وَ : اور لَا تَطْغَوْا : نہ سرکشی کرو فِيْهِ : اس میں فَيَحِلَّ : کہ اترے گا عَلَيْكُمْ : تم پر غَضَبِيْ : میرا غضب وَمَنْ : اور جو يَّحْلِلْ : اترا عَلَيْهِ : اس پر غَضَبِيْ : میرا غضب فَقَدْ هَوٰى : تو وہ گرا (نیست ونابود ہوا) تم ہماری دی ہوئی پاکیزہ روزی کھاؤ، اور اس میں حد سے آگے نہ بڑھو (1) ورنہ تم پر میرا غضب نازل ہوگا، اور جس پر میرا غضب نازل ہوجائے وہ یقیناً تباہ ہوا (2)۔
  20,82,وَ اِنِّیْ لَغَفَّارٌ لِّمَنْ تَابَ وَ اٰمَنَ وَ عَمِلَ صَالِحًا ثُمَّ اهْتَدٰى وَاِنِّىْ : اور بیشک میں لَغَفَّارٌ : بڑا بخشنے والا لِّمَنْ : اس کو۔ جو جس تَابَ : توبہ کی وَاٰمَنَ : اور وہ ایمان لایا وَعَمِلَ : اور اس نے عمل کیا صَالِحًا : نیک ثُمَّ : پھر اهْتَدٰى : ہدایت پر رہا ہاں بیشک میں انھیں بخش دینے والا ہوں جو توبہ کریں ایمان لائیں نیک عمل کریں اور راہ راست پر بھی رہیں (1)
  20,83,وَ مَاۤ اَعْجَلَكَ عَنْ قَوْمِكَ یٰمُوْسٰى وَمَآ : اور کیا (چیز) اَعْجَلَكَ : تجھے جلد لائی عَنْ قَوْمِكَ : اپنی قوم سے يٰمُوْسٰى : اے موسیٰ اے موسٰی ! تجھے اپنی قوم سے (غافل کرکے) کون سی چیز جلدی لے آئی ؟
  20,84,قَالَ هُمْ اُولَآءِ عَلٰۤى اَثَرِیْ وَ عَجِلْتُ اِلَیْكَ رَبِّ لِتَرْضٰى قَالَ : اس نے کہا هُمْ : وہ اُولَآءِ : یہ ہیں عَلٰٓي اَثَرِيْ : میرے پیچھے وَعَجِلْتُ : اور میں نے جلدی کی اِلَيْكَ : تیری طرف رَبِّ : اے میرے رب لِتَرْضٰى : تا کہ تو راضی ہو کہا کہ وہ لوگ بھی میرے پیچھے ہی پیچھے ہیں، اور میں نے اے رب ! تیری طرف جلدی اس لئے کی کہ تو خوش ہوجائے (1)۔
  20,85,قَالَ فَاِنَّا قَدْ فَتَنَّا قَوْمَكَ مِنْۢ بَعْدِكَ وَ اَضَلَّهُمُ السَّامِرِیُّ قَالَ : اس نے کہا فَاِنَّا : پس ہم نے قَدْ : تحقیق فَتَنَّا : آزمائش میں ڈالا قَوْمَكَ : تیری قوم مِنْۢ بَعْدِكَ : تیرے بعد وَاَضَلَّهُمُ : اور انہیں گمراہ کیا السَّامِرِيُّ : سامری فرمایا ! ہم نے تیری قوم کو تیرے پیچھے آزمائش میں ڈال دیا اور انھیں سامری نے بہکا دیا ہے (1)
  20,86,فَرَجَعَ مُوْسٰۤى اِلٰى قَوْمِهٖ غَضْبَانَ اَسِفًا١ۚ۬ قَالَ یٰقَوْمِ اَلَمْ یَعِدْكُمْ رَبُّكُمْ وَعْدًا حَسَنًا١ؕ۬ اَفَطَالَ عَلَیْكُمُ الْعَهْدُ اَمْ اَرَدْتُّمْ اَنْ یَّحِلَّ عَلَیْكُمْ غَضَبٌ مِّنْ رَّبِّكُمْ فَاَخْلَفْتُمْ مَّوْعِدِیْ فَرَجَعَ : پس لوٹا مُوْسٰٓى : موسیٰ اِلٰى قَوْمِهٖ : اپنی قوم غَضْبَانَ : غصہ مٰں بھرا ہوا اَسِفًا : افسوس کرتا قَالَ : اس نے کہا يٰقَوْمِ : اے میری قوم اَلَمْ يَعِدْكُمْ : کیا تم سے وعدہ نہیں کیا تھا رَبُّكُمْ : تمہارا رب وَعْدًا حَسَنًا : اچھا وعدہ اَفَطَالَ : کیا طویل ہوگئی عَلَيْكُمُ : تم پر الْعَهْدُ : مدت اَمْ اَرَدْتُّمْ : یا تم نے چاہا اَنْ يَّحِلَّ : کہ اترے عَلَيْكُمْ : تم پر غَضَبٌ : غضب مِّنْ : سے۔ کا رَّبِّكُمْ : تمہارا رب فَاَخْلَفْتُمْ : پھر تم نے خلاف کیا مَّوْعِدِيْ : میرا وعدہ پس موسیٰ ؑ سخت غضبناک ہو کر رنج کے ساتھ واپس لوٹے، اور کہنے لگے کہ اے میری قوم والو ! کیا تم سے تمہارے پروردگار نے نیک وعدہ نہیں کیا (1) تھا ؟ کیا اس کی مدت تمہیں لمبی معلوم ہوئی ؟ (2) بلکہ تمہارا ارادہ ہی یہ ہے کہ تم پر تمہارے پروردگار کا غضب نازل ہو ؟ کہ تم نے میرے وعدے کے خلاف کیا (3)
  20,87,قَالُوْا مَاۤ اَخْلَفْنَا مَوْعِدَكَ بِمَلْكِنَا وَ لٰكِنَّا حُمِّلْنَاۤ اَوْزَارًا مِّنْ زِیْنَةِ الْقَوْمِ فَقَذَفْنٰهَا فَكَذٰلِكَ اَلْقَى السَّامِرِیُّۙ قَالُوْا : وہ بولے مَآ اَخْلَفْنَا : ہم نے خلاف نہیں کیا مَوْعِدَكَ : تمہارا وعدہ بِمَلْكِنَا : اپنے اختیار سے وَلٰكِنَّا : اور لیکن (بلکہ) حُمِّلْنَآ : ہم پر لادا گیا اَوْزَارًا : بوجھ مِّنْ : سے۔ کا زِيْنَةِ الْقَوْمِ : قوم کا زیور فَقَذَفْنٰهَا : تو ہم نے اسے ڈالدیا فَكَذٰلِكَ : پھر اسی طرح اَلْقَي : ڈالا السَّامِرِيُّ : سامری انہوں نے جواب دیا کہ ہم نے اپنے اختیار سے آپ کے ساتھ وعدے کے خلاف نہیں کیا (1) بلکہ ہم پر زیورات قوم کے جو بوجھ لاد دیئے گئے تھے، انھیں ہم نے ڈال دیا، اور اسی طرح سامری نے بھی ڈال دیئے۔
