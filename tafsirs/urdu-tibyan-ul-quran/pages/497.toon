tafsir[21]{c,v,t}:
  44,19,وَّ اَنْ لَّا تَعْلُوْا عَلَى اللّٰهِ١ۚ اِنِّیْۤ اٰتِیْكُمْ بِسُلْطٰنٍ مُّبِیْنٍۚ وَّاَنْ لَّا : اور یہ کہ نہ تَعْلُوْا : تم سرکشی کرو عَلَي اللّٰهِ : اللہ کے مقابلے پر اِنِّىْٓ : بیشک میں اٰتِيْكُمْ : لایا ہوں تمہارے پاس بِسُلْطٰنٍ مُّبِيْنٍ : کھلی دلیل اور تم اللہ تعالیٰ کے سامنے سرکشی نہ کرو (1) میں تمہارے پاس کھلی دلیل لانے والا ہوں (2)۔
  44,20,وَ اِنِّیْ عُذْتُ بِرَبِّیْ وَ رَبِّكُمْ اَنْ تَرْجُمُوْنِ٘ وَاِنِّىْ : اور بیشک میں عُذْتُ : میں پناہ لے چکا بِرَبِّيْ : اپنے رب کی وَرَبِّكُمْ : اور تمہارے رب کی اَنْ تَرْجُمُوْنِ : کہ تم سنگسار کرو مجھے اور میں اپنے اور تمہارے رب کی پناہ میں آتا ہوں اس سے کہ تم مجھے سنگسار کردو (1)۔
  44,21,وَ اِنْ لَّمْ تُؤْمِنُوْا لِیْ فَاعْتَزِلُوْنِ وَاِنْ لَّمْ : اور اگر نہیں تُؤْمِنُوْا لِيْ : تم مانو گے میری بات فَاعْتَزِلُوْنِ : تو چھوڑ دو مجھ کو اور اگر تم مجھ پر ایمان نہیں لاتے تو مجھ سے الگ ہی رہو (1)۔
  44,22,فَدَعَا رَبَّهٗۤ اَنَّ هٰۤؤُلَآءِ قَوْمٌ مُّجْرِمُوْنَ فَدَعَا رَبَّهٗٓ : تو اس نے پکارا اپنے رب کو اَنَّ هٰٓؤُلَآءِ : بیشک یہ قَوْمٌ : لوگ مُّجْرِمُوْنَ : مجرم ہیں پھر انہوں نے اپنے رب سے دعا کی کہ یہ سب گنہگار لوگ ہیں (1)۔
  44,23,فَاَسْرِ بِعِبَادِیْ لَیْلًا اِنَّكُمْ مُّتَّبَعُوْنَۙ فَاَسْرِ بِعِبَادِيْ : تو لے چل میرے بندوں کو لَيْلًا : راتوں رات اِنَّكُمْ : بیشک تم مُّتَّبَعُوْنَ : تم پیچھا کیے جانے والے ہو (ہم نے کہہ دیا) کہ راتوں رات تو میرے بندوں کو لے کر نکل، یقیناً تمہارا (1) پیچھا کیا جائے گا۔
  44,24,وَ اتْرُكِ الْبَحْرَ رَهْوًا١ؕ اِنَّهُمْ جُنْدٌ مُّغْرَقُوْنَ وَاتْرُكِ الْبَحْرَ : اور چھوڑ دو سمندر کو رَهْوًا : ساکن اِنَّهُمْ : بیشک وہ جُنْدٌ مُّغْرَقُوْنَ : لشکر ہے غرق ہونے والا تو دریا کو ساکن چھوڑ کر چلا جا (1) بلاشبہ یہ لشکر غرق کردیا جائے گا۔
  44,25,كَمْ تَرَكُوْا مِنْ جَنّٰتٍ وَّ عُیُوْنٍۙ كَمْ تَرَكُوْا : کتنے ہی وہ چھوڑ گئے مِنْ جَنّٰتٍ : باغات میں سے وَّعُيُوْنٍ : اور چشمے وہ بہت سے باغات اور چشمے چھوڑ گئے۔
  44,26,وَّ زُرُوْعٍ وَّ مَقَامٍ كَرِیْمٍۙ وَّزُرُوْعٍ : اور کھیتیاں وَّ : اور مَقَامٍ كَرِيْمٍ : مقام عمدہ اور کھتیاں اور راحت بخش ٹھکانے۔
  44,27,وَّ نَعْمَةٍ كَانُوْا فِیْهَا فٰكِهِیْنَۙ وَّنَعْمَةٍ : اور نعمتیں۔ آرام کی چیزیں كَانُوْا : تھے وہ فِيْهَا فٰكِهِيْنَ : اس میں عیش کرنے والے اور آرام کی چیزیں جن میں عیش کر رہے تھے۔
  44,28,كَذٰلِكَ١۫ وَ اَوْرَثْنٰهَا قَوْمًا اٰخَرِیْنَ كَذٰلِكَ : اسی طرح وَاَوْرَثْنٰهَا : اور وارث بنادیا ہم نے ان کا قَوْمًا اٰخَرِيْنَ : دوسری قوم کو اسی طرح ہوگیا (1) اور ہم نے ان سب کا وارث دوسری قوم کو بنادیا (1)
  44,29,فَمَا بَكَتْ عَلَیْهِمُ السَّمَآءُ وَ الْاَرْضُ وَ مَا كَانُوْا مُنْظَرِیْنَ۠    ۧ فَمَا : تو نہ بَكَتْ : رویا عَلَيْهِمُ السَّمَآءُ : ان پر آسمان وَالْاَرْضُ : اور زمین وَمَا كَانُوْا : اور نہ تھے وہ مُنْظَرِيْنَ : مہلت دئیے جانے والے سو ان پر نہ تو آسمان و زمین (1) روئے اور نہ انہیں مہلت ملی۔
  44,30,وَ لَقَدْ نَجَّیْنَا بَنِیْۤ اِسْرَآءِیْلَ مِنَ الْعَذَابِ الْمُهِیْنِۙ وَلَقَدْ نَجَّيْنَا : اور البتہ تحقیق نجات دی ہم نے بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل کو مِنَ : سے الْعَذَابِ الْمُهِيْنِ : رسوا کن عذاب (سے) اور بیشک ہم نے (ہی) بنی اسرائیل کو (سخت) رسوا کن سزا سے نجات دی۔
  44,31,مِنْ فِرْعَوْنَ١ؕ اِنَّهٗ كَانَ عَالِیًا مِّنَ الْمُسْرِفِیْنَ مِنْ فِرْعَوْنَ : فرعون سے اِنَّهٗ كَانَ : بیشک تھا وہ عَالِيًا مِّنَ الْمُسْرِفِيْنَ : بلند درجے والا، حد سے بڑھنے والوں میں سے (جو) فرعون کی طرف سے (ہو رہی) تھی۔ فی الواقع وہ سرکش اور حد سے گزر جانے والوں میں تھا۔
  44,32,وَ لَقَدِ اخْتَرْنٰهُمْ عَلٰى عِلْمٍ عَلَى الْعٰلَمِیْنَۚ وَلَقَدِ : اور البتہ تحقیق اخْتَرْنٰهُمْ : ترجیح دی تھی ہم نے ان کو عَلٰي : باوجود عِلْمٍ : علم کے عَلَي الْعٰلَمِيْنَ : جہان والوں پر ہم نے دانستہ طور پر بنی اسرائیل کو دنیا جہان والوں پر فوقیت دی (1)۔
  44,33,وَ اٰتَیْنٰهُمْ مِّنَ الْاٰیٰتِ مَا فِیْهِ بَلٰٓؤٌا مُّبِیْنٌ وَاٰتَيْنٰهُمْ : اور دیں ہم نے ان کو مِّنَ الْاٰيٰتِ : نشانیوں میں سے مَا : جو فِيْهِ : اس میں بَلٰٓؤٌا مُّبِيْنٌ : آزمائش تھی کھلی اور ہم نے انہیں ایسی نشانیاں دیں جن میں صریح آزمائش تھی۔
  44,34,اِنَّ هٰۤؤُلَآءِ لَیَقُوْلُوْنَۙ اِنَّ : بیشک هٰٓؤُلَآءِ : یہ لوگ لَيَقُوْلُوْنَ : البتہ کہتے ہیں یہ لوگ تو یہی کہتے ہیں (1)
  44,35,اِنْ هِیَ اِلَّا مَوْتَتُنَا الْاُوْلٰى وَ مَا نَحْنُ بِمُنْشَرِیْنَ اِنْ هِىَ : نہیں یہ اِلَّا مَوْتَتُنَا الْاُوْلٰى : مگر ہماری موت پہلی وَمَا نَحْنُ : اور نہیں ہم بِمُنْشَرِيْنَ : اٹھائے جانے والے کہ (آخری چیز) یہی ہمارا پہلی بار (دنیا سے) مرجانا اور ہم (1) دوبارہ اٹھائے نہیں جائیں گے۔
  44,36,فَاْتُوْا بِاٰبَآئِنَاۤ اِنْ كُنْتُمْ صٰدِقِیْنَ فَاْتُوْا : پس لے آؤ بِاٰبَآئِنَآ : ہمارے باپ دادا کو اِنْ كُنْتُمْ : اگر ہو تم صٰدِقِيْنَ : سچے اگر تم سچے ہو تو ہمارے باپ دادوں کو لے آؤ (1)
  44,37,اَهُمْ خَیْرٌ اَمْ قَوْمُ تُبَّعٍ١ۙ وَّ الَّذِیْنَ مِنْ قَبْلِهِمْ١ؕ اَهْلَكْنٰهُمْ١٘ اِنَّهُمْ كَانُوْا مُجْرِمِیْنَ اَهُمْ خَيْرٌ : کیا وہ اچھے ہیں اَمْ قَوْمُ تُبَّعٍ : یا تبع کی قوم وَّالَّذِيْنَ : اور وہ لوگ مِنْ قَبْلِهِمْ : جو ان سے پہلے تھے اَهْلَكْنٰهُمْ : ہلاک کردیا ہم نے ان کو ۡ اِنَّهُمْ : بیشک وہ كَانُوْا مُجْرِمِيْنَ : مجرم تھے کیا یہ لوگ بہتر ہیں یا تمہاری قوم کے لوگ اور جو ان سے بھی پہلے تھے ہم نے ان سب کو ہلاک کردیا یقیناً وہ گنہگار تھے (1)
  44,38,وَ مَا خَلَقْنَا السَّمٰوٰتِ وَ الْاَرْضَ وَ مَا بَیْنَهُمَا لٰعِبِیْنَ وَمَا : اور نہیں خَلَقْنَا : پیدا کیا ہم نے السَّمٰوٰتِ : آسمانوں کو وَالْاَرْضَ : اور زمین کو وَمَا بَيْنَهُمَا : اور جو ان دونوں کے درمیان ہے لٰعِبِيْنَ : کھیل تماشے کے طور پر۔ کھیلنے والے ہو کر ہم نے زمین اور آسمانوں اور ان کے درمیان کی چیزوں کو کھیل کے طور پر پیدا نہیں کیا (1)
  44,39,مَا خَلَقْنٰهُمَاۤ اِلَّا بِالْحَقِّ وَ لٰكِنَّ اَكْثَرَهُمْ لَا یَعْلَمُوْنَ مَا خَلَقْنٰهُمَآ : نہیں پیدا کیا ہم نے ان دونوں کو اِلَّا بالْحَقِّ : مگر حق کے ساتھ وَلٰكِنَّ اَكْثَرَهُمْ : لیکن ان میں سے اکثر لَا : نہیں يَعْلَمُوْنَ : علم رکھتے بلکہ ہم نے انہیں درست تدبیر کے ساتھ ہی پیدا کیا (1) ہے لیکن ان میں سے اکثر لوگ نہیں جانتے۔
