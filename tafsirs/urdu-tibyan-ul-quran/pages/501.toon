tafsir[10]{c,v,t}:
  45,23,اَفَرَءَیْتَ مَنِ اتَّخَذَ اِلٰهَهٗ هَوٰىهُ وَ اَضَلَّهُ اللّٰهُ عَلٰى عِلْمٍ وَّ خَتَمَ عَلٰى سَمْعِهٖ وَ قَلْبِهٖ وَ جَعَلَ عَلٰى بَصَرِهٖ غِشٰوَةً١ؕ فَمَنْ یَّهْدِیْهِ مِنْۢ بَعْدِ اللّٰهِ١ؕ اَفَلَا تَذَكَّرُوْنَ اَفَرَءَيْتَ : کیا پھر تم نے دیکھا مَنِ اتَّخَذَ : جس نے بنا لیا اِلٰهَهٗ : اپنا الہ هَوٰىهُ : اپنی خواہش نفس کو وَاَضَلَّهُ اللّٰهُ : اور بھٹکا دیا اس کو اللہ نے عَلٰي عِلْمٍ : علم کے باوجود وَّخَتَمَ : اور مہر لگا دی عَلٰي سَمْعِهٖ : اس کے کان پر وَقَلْبِهٖ : اور اس کے دل پر وَجَعَلَ : اور اس نے ڈال دیا عَلٰي بَصَرِهٖ : اس کی آنکھ پر غِشٰوَةً : ایک پردہ فَمَنْ يَّهْدِيْهِ : تو کون ہدایت دے گا اس کو مِنْۢ بَعْدِ اللّٰهِ : اللہ کے بعد اَفَلَا : کیا بھلا نہیں تَذَكَّرُوْنَ : تم نصیحٹ پکڑتے کیا آپ نے اسے بھی دیکھا ؟ جس نے اپنی خواہش نفس کو اپنا معبود بنا رکھا ہے اور باوجود سمجھ بوجھ کے اللہ نے اسے گمراہ کردیا (1) ہے اور اس کے کان اور دل پر مہر لگا دی ہے اور اس کی آنکھ پر بھی پردہ ڈال دیا (2) ہے اب ایسے شخص کو اللہ کے بعد کون ہدایت دے سکتا ہے۔
  45,24,وَ قَالُوْا مَا هِیَ اِلَّا حَیَاتُنَا الدُّنْیَا نَمُوْتُ وَ نَحْیَا وَ مَا یُهْلِكُنَاۤ اِلَّا الدَّهْرُ١ۚ وَ مَا لَهُمْ بِذٰلِكَ مِنْ عِلْمٍ١ۚ اِنْ هُمْ اِلَّا یَظُنُّوْنَ وَقَالُوْا : اور انہوں نے کہا مَا هِىَ : نہیں ہے یہ اِلَّا حَيَاتُنَا : مگر ہماری زندگی الدُّنْيَا : دنیا کی نَمُوْتُ : ہم مریں گے وَنَحْيَا : اور ہم جئیں گے وَمَا يُهْلِكُنَآ : اور ہلاک کرتا ہم کو اِلَّا الدَّهْرُ : مگر زمانہ وَمَا لَهُمْ : اور نہیں ان کے لیے بِذٰلِكَ : اس کا مِنْ عِلْمٍ : کوئی علم اِنْ هُمْ : نہیں وہ اِلَّا : مگر يَظُنُّوْنَ : وہ گمان کرتے ہیں کیا اب بھی تم نصیحت نہیں پکڑتے انہوں نے کہا کہ ہماری زندگی تو صرف دنیا کی زندگی ہی ہے۔ ہم مرتے ہیں اور جیتے ہیں اور ہمیں صرف زمانہ ہی مار ڈالتا ہے (1) (دراصل) انہیں اس کا علم ہی نہیں یہ تو صرف قیاس آرائیاں ہیں اور اٹکل سے ہی کام لے رہے ہیں۔
  45,25,وَ اِذَا تُتْلٰى عَلَیْهِمْ اٰیٰتُنَا بَیِّنٰتٍ مَّا كَانَ حُجَّتَهُمْ اِلَّاۤ اَنْ قَالُوا ائْتُوْا بِاٰبَآئِنَاۤ اِنْ كُنْتُمْ صٰدِقِیْنَ وَاِذَا تُتْلٰى : اور جب پڑھی جاتی ہیں عَلَيْهِمْ : ان پر اٰيٰتُنَا : ہماری آیات ۔ نشانیاں بَيِّنٰتٍ : روشن مَّا كَانَ : نہیں ہوتی حُجَّتَهُمْ : ان کی حجت اِلَّآ : مگر اَنْ قَالُوا : یہ کہ وہ کہتے ہیں ائْتُوْا : لاؤ بِاٰبَآئِنَآ : ہمارے باپ دادا کو اِنْ كُنْتُمْ : اگر ہو تم صٰدِقِيْنَ : سچے اور جب ان کے سامنے ہماری واضح اور روشن آیتوں کی تلاوت کی جاتی ہے تو ان کے پاس اس قول کے سوا کوئی دلیل نہیں ہوتی کہ اگر تم سچے ہو تو ہمارے باپ دادوں کو لاؤ (1)
  45,26,قُلِ اللّٰهُ یُحْیِیْكُمْ ثُمَّ یُمِیْتُكُمْ ثُمَّ یَجْمَعُكُمْ اِلٰى یَوْمِ الْقِیٰمَةِ لَا رَیْبَ فِیْهِ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ۠    ۧ قُلِ اللّٰهُ : کہہ دیجئے اللہ يُحْيِيْكُمْ : زندہ کرتا ہے تم کو ثُمَّ يُمِيْتُكُمْ : پھر موت دے گا تم کو ثُمَّ يَجْمَعُكُمْ : پھر جمع کرے گا تم کو اِلٰى يَوْمِ : دن تک الْقِيٰمَةِ : قیامت کے لَا رَيْبَ فِيْهِ : نہیں کوئی شک اس میں وَلٰكِنَّ : لیکن اَكْثَرَ النَّاسِ : اکثر لوگ لَا يَعْلَمُوْنَ : علم نہیں رکھتے آپ کہہ دیجئے ! اللہ ہی تمہیں زندہ کرتا ہے پھر تمہیں مار ڈالتا ہے پھر تمہیں قیامت کے دن جمع کرے گا جس میں کوئی شک نہیں لیکن اکثر لوگ نہیں سمجھتے۔
  45,27,وَ لِلّٰهِ مُلْكُ السَّمٰوٰتِ وَ الْاَرْضِ١ؕ وَ یَوْمَ تَقُوْمُ السَّاعَةُ یَوْمَئِذٍ یَّخْسَرُ الْمُبْطِلُوْنَ وَلِلّٰهِ : اور اللہ ہی کے لیے ہے مُلْكُ السَّمٰوٰتِ : بادشاہت آسمانوں کی وَالْاَرْضِ : اور زمین کی وَيَوْمَ : اور جس دن تَقُوْمُ السَّاعَةُ : قائم ہوگی قیامت يَوْمَئِذٍ : اس دن يَّخْسَرُ الْمُبْطِلُوْنَ : خسارہ پاجائیں گے باطل پرست اور آسمانوں اور زمین کی بادشاہی اللہ ہی کی ہے اور جس دن قیامت قائم ہوگی اس دن اہل باطل بڑے نقصان میں پڑیں گے۔
  45,28,وَ تَرٰى كُلَّ اُمَّةٍ جَاثِیَةً١۫ كُلُّ اُمَّةٍ تُدْعٰۤى اِلٰى كِتٰبِهَا١ؕ اَلْیَوْمَ تُجْزَوْنَ مَا كُنْتُمْ تَعْمَلُوْنَ وَتَرٰى : اور تم دیکھو گے كُلَّ اُمَّةٍ : ہر امت کو جَاثِيَةً : گھٹنوں پر گری ہوئی۔ زانوؤں پر گری ہوئی كُلُّ اُمَّةٍ : ہر امت تُدْعٰٓى : بلائی جائے گی اِلٰى كِتٰبِهَا : طرف اپنے اعمال نامے کے اَلْيَوْمَ : آج تُجْزَوْنَ : تم جزا دئیے جاؤ گے مَا كُنْتُمْ : جو تھے تم تَعْمَلُوْنَ : تم عمل کرتے اور آپ دیکھیں گے کہ ہر امت گھٹنوں کے بل گری ہوئی ہوگی (1) ہر گروہ اپنے نامہ اعمال کی طرف بلایا جائے گا آج تمہیں اپنے کئے کا بدلہ دیا جائے گا۔
  45,29,هٰذَا كِتٰبُنَا یَنْطِقُ عَلَیْكُمْ بِالْحَقِّ١ؕ اِنَّا كُنَّا نَسْتَنْسِخُ مَا كُنْتُمْ تَعْمَلُوْنَ ھٰذَا كِتٰبُنَا : یہ ہے کتاب ہماری يَنْطِقُ : بولے گی عَلَيْكُمْ : تم پر بِالْحَقِّ : حق کے ساتھ اِنَّا : بیشک ہم كُنَّا نَسْتَنْسِخُ : لکھواتے تھے ہم مَا كُنْتُمْ : جو تھے تم تَعْمَلُوْنَ : تم عمل کرتے یہ ہماری کتاب جو تمہارے بارے میں سچ سچ بول رہی ہے ہم تمہارے اعمال لکھواتے جاتے تھے (1)۔
  45,30,فَاَمَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ فَیُدْخِلُهُمْ رَبُّهُمْ فِیْ رَحْمَتِهٖ١ؕ ذٰلِكَ هُوَ الْفَوْزُ الْمُبِیْنُ فَاَمَّا : تو رہے الَّذِيْنَ : وہ لوگ اٰمَنُوْا : جو ایمان لائے وَعَمِلُوا الصّٰلِحٰتِ : اور انہوں نے عمل کیے اچھے فَيُدْخِلُهُمْ : تو داخل کرے گا ان کو رَبُّهُمْ : ان کا رب فِيْ رَحْمَتِهٖ : اپنی رحمت میں ذٰلِكَ : یہ ہے هُوَ الْفَوْزُ : وہ کامیابی الْمُبِيْنُ : جو کھلی۔ صریح ہے پس لیکن جو لوگ ایمان لائے اور انہوں نے نیک کام (1) کئے تو ان کو ان کا رب اپنی رحمت تلے لے لے گا یہی صریح کامیابی ہے۔
  45,31,وَ اَمَّا الَّذِیْنَ كَفَرُوْا١۫ اَفَلَمْ تَكُنْ اٰیٰتِیْ تُتْلٰى عَلَیْكُمْ فَاسْتَكْبَرْتُمْ وَ كُنْتُمْ قَوْمًا مُّجْرِمِیْنَ وَاَمَّا الَّذِيْنَ : اور ہے وہ لوگ كَفَرُوْا : جنہوں نے کفر کیا اَفَلَمْ : کیا پھر نہ تَكُنْ اٰيٰتِيْ : تھیں میری آیات تُتْلٰى : پڑھی جاتیں عَلَيْكُمْ : تم پر فَاسْتَكْبَرْتُمْ : تو تکبر کیا تم نے وَكُنْتُمْ : اور تھے تم قَوْمًا مُّجْرِمِيْنَ : مجرم لوگ لیکن جن لوگوں نے کفر کیا تو (میں ان سے کہوں گا) کیا میری آیتیں تمہیں سنائی نہیں جاتی تھیں (1) پھر بھی تم تکبر کرتے رہے اور تم تھے ہی گناہ گار لوگ (2)
  45,32,وَ اِذَا قِیْلَ اِنَّ وَعْدَ اللّٰهِ حَقٌّ وَّ السَّاعَةُ لَا رَیْبَ فِیْهَا قُلْتُمْ مَّا نَدْرِیْ مَا السَّاعَةُ١ۙ اِنْ نَّظُنُّ اِلَّا ظَنًّا وَّ مَا نَحْنُ بِمُسْتَیْقِنِیْنَ وَاِذَا قِيْلَ : اور جب کہا جاتا اِنَّ وَعْدَ اللّٰهِ : بیشک وعدہ اللہ کا حَقٌّ : سچا ہے وَّالسَّاعَةُ : اور قیامت لَا رَيْبَ فِيْهَا : نہیں کوئی شک اس میں قُلْتُمْ : کہا تم نے مَّا نَدْرِيْ : ہم نہیں جانتے مَا السَّاعَةُ : قیامت کیا ہوتی ہے اِنْ نَّظُنُّ : نہیں ہم سمجھتے اِلَّا ظَنًّا : مگر ایک گمان وَّمَا نَحْنُ : اور نہیں ہیں ہم بِمُسْتَيْقِنِيْنَ : یقین کرنے والے اور جب کبھی کہا جاتا ہے کہ اللہ کا وعدہ یقیناً سچا ہے اور قیامت کے آنے میں کوئی شک نہیں تو تم جواب دیتے تھے کہ ہم نہیں جانتے قیامت کیا چیز ہے ؟ ہمیں کچھ یوں ہی سا خیال ہوجاتا ہے لیکن ہمیں یقین نہیں (1)
