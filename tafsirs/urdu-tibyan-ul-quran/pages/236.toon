tafsir[10]{c,v,t}:
  12,5,قَالَ یٰبُنَیَّ لَا تَقْصُصْ رُءْیَاكَ عَلٰۤى اِخْوَتِكَ فَیَكِیْدُوْا لَكَ كَیْدًا١ؕ اِنَّ الشَّیْطٰنَ لِلْاِنْسَانِ عَدُوٌّ مُّبِیْنٌ قَالَ : اس نے کہا يٰبُنَيَّ : اے میرے بیٹے لَا تَقْصُصْ : نہ بیان کرنا رُءْيَاكَ : اپنا خواب عَلٰٓي : پر (سے) اِخْوَتِكَ : اپنے بھائی فَيَكِيْدُوْا : وہ چال چلیں گے لَكَ : تیرے لیے كَيْدًا : کوئی چال اِنَّ : بیشک الشَّيْطٰنَ : شیطان لِلْاِنْسَانِ : انسان کے لیے (کا) عَدُوٌّ : دشمن مُّبِيْنٌ : کھلا یعقوب نے کہا پیارے بچے ! اپنے اس خواب کا ذکر اپنے بھائیوں سے نہ کرنا۔ ایسا نہ ہو کہ وہ تیرے ساتھ کوئی فریب کاری کریں (1) شیطان تو انسان کا کھلا دشمن ہے (2)۔
  12,6,وَ كَذٰلِكَ یَجْتَبِیْكَ رَبُّكَ وَ یُعَلِّمُكَ مِنْ تَاْوِیْلِ الْاَحَادِیْثِ وَ یُتِمُّ نِعْمَتَهٗ عَلَیْكَ وَ عَلٰۤى اٰلِ یَعْقُوْبَ كَمَاۤ اَتَمَّهَا عَلٰۤى اَبَوَیْكَ مِنْ قَبْلُ اِبْرٰهِیْمَ وَ اِسْحٰقَ١ؕ اِنَّ رَبَّكَ عَلِیْمٌ حَكِیْمٌ۠    ۧ وَكَذٰلِكَ : اور اسی طرح يَجْتَبِيْكَ : چن لے گا تجھے رَبُّكَ : تیرا رب وَيُعَلِّمُكَ : اور سکھائے گا تجھے مِنْ : سے تَاْوِيْلِ : انجام نکالنا الْاَحَادِيْثِ : باتیں وَيُتِمُّ : اور مکمل کرے گا نِعْمَتَهٗ : اپنی نعمت عَلَيْكَ : تجھ پر وَ : اور عَلٰٓي : پر اٰلِ يَعْقُوْبَ : یعقوب کے گھر والے كَمَآ : جیسے اَتَمَّهَا : اس نے اسے پورا کیا عَلٰٓي : پر اَبَوَيْكَ : تیرے باپ دادا مِنْ قَبْلُ : اس سے پہلے اِبْرٰهِيْمَ : ابراہیم وَاِسْحٰقَ : اور اسحق اِنَّ : بیشک رَبَّكَ : تیرا رب عَلِيْمٌ : علم والا حَكِيْمٌ : حکمت والا اور اسی طرح تجھے (1) تیرا پروردگار برگزیدہ کرے گا اور تجھے معاملہ فہمی (یا خوابوں کی تعبیر) بھی سکھائے گا اور اپنی نعمت تجھے بھرپور عطا فرمائے گا (2) اور یعقوب کے گھر والوں کو بھی (3) جیسے کہ اس نے پہلے تیرے دادا پردادا یعنی ابراہیم و اسحاق کو بھی بھرپور اپنی رحمت دی، یقیناً تیرا رب بہت بڑے علم والا اور زبردست حکمت والا ہے۔
  12,7,لَقَدْ كَانَ فِیْ یُوْسُفَ وَ اِخْوَتِهٖۤ اٰیٰتٌ لِّلسَّآئِلِیْنَ لَقَدْ كَانَ : بیشک میں فِيْ : میں يُوْسُفَ : یوسف وَاِخْوَتِهٖٓ : اور اس کے بھائی اٰيٰتٌ : نشانیاں لِّلسَّآئِلِيْنَ : پوچھنے والوں کے لیے یقیناً یوسف اور اس کے بھائیوں میں دریافت کرنے والوں کے لئے (بڑی) نشانیاں (1) ہیں۔
  12,8,اِذْ قَالُوْا لَیُوْسُفُ وَ اَخُوْهُ اَحَبُّ اِلٰۤى اَبِیْنَا مِنَّا وَ نَحْنُ عُصْبَةٌ١ؕ اِنَّ اَبَانَا لَفِیْ ضَلٰلٍ مُّبِیْنِۚۖ اِذْ : جب قَالُوْا : انہوں نے کہا لَيُوْسُفُ : ضرور یوسف وَاَخُوْهُ : اور اس کا بھائی اَحَبُّ : زیادہ پیارا اِلٰٓي : طرف (کو) اَبِيْنَا : ہمارا باپ مِنَّا : ہم سے وَنَحْنُ : جبکہ ہم عُصْبَةٌ : ایک جماعت اِنَّ : بیشک اَبَانَا : ہمارے باپ لَفِيْ ضَلٰلٍ : البتہ غلطی میں مُّبِيْنِ : صریح جب کہ انہوں نے کہا کہ یوسف اور اس کا بھائی (1) بہ نسبت ہمارے، باپ کو بہت زیادہ پیارے ہیں حالانکہ ہم (طاقتور) جماعت (2) ہیں، کوئی شک نہیں کہ ہمارے ابا صریح غلطی میں ہیں۔
  12,9,اِ۟قْتُلُوْا یُوْسُفَ اَوِ اطْرَحُوْهُ اَرْضًا یَّخْلُ لَكُمْ وَجْهُ اَبِیْكُمْ وَ تَكُوْنُوْا مِنْۢ بَعْدِهٖ قَوْمًا صٰلِحِیْنَ اقْتُلُوْا : مار ڈالو يُوْسُفَ : یوسف اَوِ : یا اطْرَحُوْهُ : اسے ڈال آؤ اَرْضًا : کسی سرزمین يَّخْلُ : خالی ہوجائے لَكُمْ : تمہارے لیے وَجْهُ : منہ (توجہ) اَبِيْكُمْ : تمہارے باپ وَتَكُوْنُوْا : اور تم ہوجاؤ مِنْ : سے بَعْدِهٖ : اس کے بعد قَوْمًا : لوگ صٰلِحِيْنَ : نیک (جمع) یوسف کو مار ہی ڈالو اسے کسی (نامعلوم) جگہ پھینک دو کہ تمہارے والد کا رخ صرف تمہاری طرف ہی ہوجائے۔ اس کے بعد تم نیک ہوجانا (1)۔
  12,10,قَالَ قَآئِلٌ مِّنْهُمْ لَا تَقْتُلُوْا یُوْسُفَ وَ اَلْقُوْهُ فِیْ غَیٰبَتِ الْجُبِّ یَلْتَقِطْهُ بَعْضُ السَّیَّارَةِ اِنْ كُنْتُمْ فٰعِلِیْنَ قَالَ : کہا قَآئِلٌ : ایک کہنے والا مِّنْهُمْ : ان سے لَا تَقْتُلُوْا : نہ قتل کرو يُوْسُفَ : یوسف وَاَلْقُوْهُ : اور اسے ڈال آؤ فِيْ : میں غَيٰبَتِ : اندھا (گہرا) الْجُبِّ : کنواں يَلْتَقِطْهُ : اٹھالے اس کو بَعْضُ : کوئی السَّيَّارَةِ : چلتا (مسافر) اِنْ : اگر كُنْتُمْ فٰعِلِيْنَ : تم کرنیوالے ہو (کرنا ہی ہے) ان میں سے ایک نے کہا یوسف کو قتل نہ کرو بلکہ اسے کسی اندھے کنوئیں (کی تہ) میں ڈال آؤ کہ (1) اسے کوئی (آتا جاتا) قافلہ اٹھا لے جائے اگر تمہیں کرنا ہی ہے تو یوں کرو (2)۔
  12,11,قَالُوْا یٰۤاَبَانَا مَا لَكَ لَا تَاْمَنَّا عَلٰى یُوْسُفَ وَ اِنَّا لَهٗ لَنٰصِحُوْنَ قَالُوْا : کہنے لگے يٰٓاَبَانَا : اے ہمارے آبا مَالَكَ : کیا ہوا تجھے لَا تَاْمَنَّا : تو ہمارا اعتبار نہیں کرتا عَلٰي : پر (بارہ میں) يُوْسُفَ : یوسف وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَنٰصِحُوْنَ : البتہ خیر خواہ انہوں نے کہا ابا ! آخر آپ یوسف ؑ کے بارے میں ہم پر اعتبار کیوں نہیں کرتے ہم تو اس کے خیر خواہ ہیں (1)۔
  12,12,اَرْسِلْهُ مَعَنَا غَدًا یَّرْتَعْ وَ یَلْعَبْ وَ اِنَّا لَهٗ لَحٰفِظُوْنَ اَرْسِلْهُ : اسے بھیجدے مَعَنَا : ہمارے ساتھ غَدًا : کل يَّرْتَعْ : وہ کھائے وَيَلْعَبْ : اور کھیلے کودے وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَحٰفِظُوْنَ : البتہ محافظ کل آپ اسے ضرور ہمارے ساتھ بھیج دیجئے کہ خوب کھائے پیئے اور کھیلے (1) اس کی حفاظت کے ہم ذمہ دار ہیں۔
  12,13,قَالَ اِنِّیْ لَیَحْزُنُنِیْۤ اَنْ تَذْهَبُوْا بِهٖ وَ اَخَافُ اَنْ یَّاْكُلَهُ الذِّئْبُ وَ اَنْتُمْ عَنْهُ غٰفِلُوْنَ قَالَ : اس نے کہا اِنِّىْ : بیشک مجھے لَيَحْزُنُنِيْٓ : غمگین کرتا ہے اَنْ : کہ تَذْهَبُوْا : تم لے جاؤ بِهٖ : اسے وَاَخَافُ : اور میں ڈرتا ہوں اَنْ : کہ يَّاْكُلَهُ : اسے کھاجائے الذِّئْبُ : بھیڑیا وَاَنْتُمْ : اور تم عَنْهُ : اس سے غٰفِلُوْنَ : بیخبر (جمع) (یعقوب ؑ نے کہا) اسے تمہارا لے جانا مجھے تو سخت صدمہ دے گا اور مجھے یہ بھی کھٹکا لگا رہے گا کہ تمہاری غفلت میں اس بھیڑیا کھاجائے۔
  12,14,قَالُوْا لَئِنْ اَكَلَهُ الذِّئْبُ وَ نَحْنُ عُصْبَةٌ اِنَّاۤ اِذًا لَّخٰسِرُوْنَ قَالُوْا : وہ بولے لَئِنْ : اگر اَكَلَهُ : اسے کھاجائے الذِّئْبُ : بھیڑیا وَنَحْنُ : اور ہم عُصْبَةٌ : ایک جماعت اِنَّآ : بیشک ہم اِذًا : اس صورت میں لَّخٰسِرُوْنَ : زیاں کار انہوں نے جواب دیا کہ ہم جیسی (زور آور) جماعت کی موجودگی میں بھی اگر اسے بھیڑیا کھاجائے تو ہم بالکل نکمے ہی (1) ہوئے۔
