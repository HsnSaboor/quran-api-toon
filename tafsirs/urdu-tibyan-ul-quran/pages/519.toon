tafsir[20]{c,v,t}:
  50,16,وَ لَقَدْ خَلَقْنَا الْاِنْسَانَ وَ نَعْلَمُ مَا تُوَسْوِسُ بِهٖ نَفْسُهٗ١ۖۚ وَ نَحْنُ اَقْرَبُ اِلَیْهِ مِنْ حَبْلِ الْوَرِیْدِ وَلَقَدْ : اور تحقیق خَلَقْنَا : ہم نے پیدا کیا الْاِنْسَانَ : انسان وَنَعْلَمُ : اور ہم جانتے ہیں مَا تُوَسْوِسُ : جو وسوسے گزرتے ہیں بِهٖ : اس کے نَفْسُهٗ ښ : اس کا جی وَنَحْنُ : اور ہم اَقْرَبُ : بہت قریب اِلَيْهِ : اس کے مِنْ : سے حَبْلِ الْوَرِيْدِ : رگِ گردن (جان) ہم نے انسان کو پیدا کیا اور اس کے دل میں جو خیالات اٹھتے ہیں ان سے ہم واقف ہیں (1) اور ہم اس کی رگ جان سے بھی زیادہ اس سے قریب ہیں (2)
  50,17,اِذْ یَتَلَقَّى الْمُتَلَقِّیٰنِ عَنِ الْیَمِیْنِ وَ عَنِ الشِّمَالِ قَعِیْدٌ اِذْ يَتَلَقَّى : جب لیتے (لکھ لیتے) ہیں الْمُتَلَقِّيٰنِ : دولینے (لکھ لینے) والے عَنِ الْيَمِيْنِ : دائیں سے وَعَنِ الشِّمَالِ : اور بائیں سے قَعِيْدٌ : بیٹھا ہوا جس وقت دو لینے والے جا لیتے ہیں ایک دائیں طرف اور ایک بائیں طرف بیٹھا ہوا ہے۔
  50,18,مَا یَلْفِظُ مِنْ قَوْلٍ اِلَّا لَدَیْهِ رَقِیْبٌ عَتِیْدٌ مَا : اور نہیں يَلْفِظُ : نکالتا مِنْ : کوئی قَوْلٍ : بات اِلَّا : مگر لَدَيْهِ : اس کے پاس رَقِيْبٌ : ایک نگہبان عَتِيْدٌ : تیار بیٹھا ہوا (انسان) منہ سے کوئی لفظ نکال نہیں پاتا مگر اس کے پاس نگہبان تیار ہے (1)۔
  50,19,وَ جَآءَتْ سَكْرَةُ الْمَوْتِ بِالْحَقِّ١ؕ ذٰلِكَ مَا كُنْتَ مِنْهُ تَحِیْدُ وَجَآءَتْ : اور آگئی سَكْرَةُ الْمَوْتِ : موت کی بیہوشی بِالْحَقِّ ۭ : حق کے ساتھ ذٰلِكَ : یہ مَا كُنْتَ : جس سے تو تھا مِنْهُ : اس سے تَحِيْدُ : بھاگتا (بدکتا) اور موت کی بےہوشی حق لے کر پہنچی یہی ہے جس سے تو بدکتا پھرتا تھا (1)
  50,20,وَ نُفِخَ فِی الصُّوْرِ١ؕ ذٰلِكَ یَوْمُ الْوَعِیْدِ وَنُفِخَ : اور پھونکا گیا فِي الصُّوْرِ ۭ : صور میں ذٰلِكَ : یہ يَوْمُ الْوَعِيْدِ : وعید کا دن اور صور پھونک دیا جائے گا۔ وعدہ عذاب کا دن یہی ہے۔
  50,21,وَ جَآءَتْ كُلُّ نَفْسٍ مَّعَهَا سَآئِقٌ وَّ شَهِیْدٌ وَجَآءَتْ : اور آئیگا (حاضر ہوگا ) كُلُّ : ہر نَفْسٍ : شخص مَّعَهَا : اس کے ساتھ سَآئِقٌ : ایک چلانے والا وَّشَهِيْدٌ : اور ایک گواہی دینے والا اور ہر شخص اس طرح آئے گا کہ اس کے ساتھ ایک لانے والا ہوگا اور ایک گواہی دینے والا (1)
  50,22,لَقَدْ كُنْتَ فِیْ غَفْلَةٍ مِّنْ هٰذَا فَكَشَفْنَا عَنْكَ غِطَآءَكَ فَبَصَرُكَ الْیَوْمَ حَدِیْدٌ لَقَدْ كُنْتَ : تحقیق تو تھا فِيْ غَفْلَةٍ : غفلت میں مِّنْ ھٰذَا : اس سے فَكَشَفْنَا : تو ہم نے ہٹادیا عَنْكَ : تجھ سے غِطَآءَكَ : تیرا پردہ فَبَصَرُكَ : پس تیری نظر الْيَوْمَ حَدِيْدٌ : آج بڑی تیز یقیناً تو اس سے غفلت میں تھا لیکن ہم نے تیرے سامنے سے پردہ ہٹا دیا پس آج تیری نگاہ بہت تیز ہے۔
  50,23,وَ قَالَ قَرِیْنُهٗ هٰذَا مَا لَدَیَّ عَتِیْدٌؕ و َقَالَ : اور کہے گا قَرِيْنُهٗ : اس کا ہم نشین ھٰذَا مَا لَدَيَّ : یہ جو میرے پاس عَتِيْدٌ : حاضر اس کا ہم نشین (فرشتہ) کہے گا یہ حاضر ہے جو کہ میرے پاس تھا (1)۔
  50,24,اَلْقِیَا فِیْ جَهَنَّمَ كُلَّ كَفَّارٍ عَنِیْدٍۙ اَلْقِيَا : تم دونوں ڈال دو فِيْ جَهَنَّمَ : جہنم میں كُلَّ كَفَّارٍ : ہر ناشکرا عَنِيْدٍ : سرکش ڈال دو جہنم میں ہر کافر سرکش کو۔
  50,25,مَّنَّاعٍ لِّلْخَیْرِ مُعْتَدٍ مُّرِیْبِۙ مَّنَّاعٍ : منع کرنے و الا لِّلْخَيْرِ : مال کے لئے مُعْتَدٍ : حد سے گزرنے والا مُّرِيْبِۨ : شبہات ڈالنے والا جو نیک کام سے روکنے والا حد سے گزر جانے والا اور شک کرنے والا تھا۔
  50,26,اِ۟لَّذِیْ جَعَلَ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ فَاَلْقِیٰهُ فِی الْعَذَابِ الشَّدِیْدِ الَّذِيْ : وہ جس جَعَلَ : ٹھہرایا مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا اٰخَرَ : معبود دوسرا فَاَلْقِيٰهُ : پس اسے ڈال دو فِي : میں الْعَذَابِ : عذاب الشَّدِيْدِ : سخت جس نے اللہ کے ساتھ دوسرا معبود بنا لیا تھا پس اسے سخت عذاب میں ڈال دو۔ (1)
  50,27,قَالَ قَرِیْنُهٗ رَبَّنَا مَاۤ اَطْغَیْتُهٗ وَ لٰكِنْ كَانَ فِیْ ضَلٰلٍۭ بَعِیْدٍ قَالَ قَرِيْنُهٗ : کہے گا اس کا ہم نشین رَبَّنَا : اے ہمارے رب مَآ اَطْغَيْتُهٗ : میں نے اسے سرکش نہیں بنایا وَلٰكِنْ : اور لیکن وہ كَانَ : تھا فِيْ ضَلٰلٍۢ : گمراہی میں بَعِيْدٍ : پرلے درجے کی اس کا ہم نشین (شیطان) کہے گا اے ہمارے رب ! میں نے اسے گمراہ نہیں کیا تھا بلکہ یہ خود ہی دور دراز کی گمراہی میں تھا (1)
  50,28,قَالَ لَا تَخْتَصِمُوْا لَدَیَّ وَ قَدْ قَدَّمْتُ اِلَیْكُمْ بِالْوَعِیْدِ قَالَ : ارشاد ہوگا لَا : نہ تَخْتَصِمُوْا : تم جھگڑو لَدَيَّ : میرے پاس، سامنے وَقَدْ قَدَّمْتُ : اور میں پہلے بھیج چکا ہوں اِلَيْكُمْ : تمہاری طرف بِالْوَعِيْدِ : وعدۂ عذاب حق تعالیٰ فرمائے گا بس میرے سامنے جھگڑے کی بات مت کرو میں تو پہلے ہی تمہاری طرف وعید (وعدہ عذاب) بھیج چکا تھا (1)۔
  50,29,مَا یُبَدَّلُ الْقَوْلُ لَدَیَّ وَ مَاۤ اَنَا بِظَلَّامٍ لِّلْعَبِیْدِ۠    ۧ مَا : نہیں يُبَدَّلُ : بدلی جاتی الْقَوْلُ : بات لَدَيَّ : میرے پاس، ہاں وَمَآ : اور نہیں اَنَا : میں بِظَلَّامٍ : ظلم کرنے والا لِّلْعَبِيْدِ : بندوں پر میرے ہاں بات بد لتی نہیں (1) نہ میں اپنے بندوں پر ذرا بھی ظلم کرنے والا ہوں۔
  50,30,یَوْمَ نَقُوْلُ لِجَهَنَّمَ هَلِ امْتَلَاْتِ وَ تَقُوْلُ هَلْ مِنْ مَّزِیْدٍ يَوْمَ : جس دن نَقُوْلُ : ہم کہیں گے لِجَهَنَّمَ : جہنم سے هَلِ : کیا امْتَلَاْتِ : کیا تو بھر گئی وَتَقُوْلُ : اور وہ کہے گی هَلْ : کیا مِنْ مَّزِيْدٍ : کچھ مزید ہے جس دن ہم دوزخ سے پوچھیں گے کیا تو بھر چکی ؟ وہ جواب دے گی کیا کچھ اور زیادہ بھی ہے ؟ (1)۔
  50,31,وَ اُزْلِفَتِ الْجَنَّةُ لِلْمُتَّقِیْنَ غَیْرَ بَعِیْدٍ وَاُزْلِفَتِ : اور نزدیک کردی جائے گی الْجَنَّةُ : جنت لِلْمُتَّقِيْنَ : پرہیزگاروں کیلئے غَيْرَ بَعِيْدٍ : نہ دور اور جنت پرہیز گاروں کے لئے بالکل قریب کردی جائے گی ذرا بھی دور نہ ہوگی۔ (1)
  50,32,هٰذَا مَا تُوْعَدُوْنَ لِكُلِّ اَوَّابٍ حَفِیْظٍۚ ھٰذَا : یہ مَا : جو تُوْعَدُوْنَ : تم سے وعدہ کیا جاتا تھا لِكُلِّ اَوَّابٍ : ہر رجوع کرنے والے کیلئے حَفِيْظٍ : نگہداشت کرنے والا یہ جس کا تم سے وعدہ کیا جاتا تھا ہر اس شخص کے لئے جو رجوع کرنے والا اور پابندی کرنے والا ہو (1)
  50,33,مَنْ خَشِیَ الرَّحْمٰنَ بِالْغَیْبِ وَ جَآءَ بِقَلْبٍ مُّنِیْبِۙ مَنْ : جو خَشِيَ : ڈرا الرَّحْمٰنَ : رحمٰن (اللہ) سے بِالْغَيْبِ : بن دیکھے وَجَآءَ : اور آیا بِقَلْبٍ : دل کے ساتھ مُّنِيْبِۨ : رجوع کرنے والے جو رحمان کا غائبانہ خوف رکھتا ہو اور توجہ والا دل لایا ہو (1)
  50,34,اِ۟دْخُلُوْهَا بِسَلٰمٍ١ؕ ذٰلِكَ یَوْمُ الْخُلُوْدِ ادْخُلُوْهَا : اس میں داخل ہوجاؤ بِسَلٰمٍ ۭ : سلامتی کے ساتھ ذٰلِكَ : یہ يَوْمُ الْخُلُوْدِ : ہمیشہ رہنے کا دن تم اس جنت میں سلامتی کے ساتھ داخل ہوجاؤ یہ ہمیشہ رہنے کا دن ہے۔
  50,35,لَهُمْ مَّا یَشَآءُوْنَ فِیْهَا وَ لَدَیْنَا مَزِیْدٌ لَهُمْ : ان کیلئے مَّا : جو يَشَآءُوْنَ فِيْهَا : وہ چاہیں گے اس میں وَلَدَيْنَا : اور ہمارے پاس مَزِيْدٌ : اور بھی زیادہ یہ وہاں جو چاہیں انہیں ملے گا (بلکہ) ہمارے پاس اور بھی زیادہ ہے۔ (4)
