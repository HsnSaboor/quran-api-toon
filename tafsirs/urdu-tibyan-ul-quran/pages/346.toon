tafsir[15]{c,v,t}:
  23,60,وَ الَّذِیْنَ یُؤْتُوْنَ مَاۤ اٰتَوْا وَّ قُلُوْبُهُمْ وَجِلَةٌ اَنَّهُمْ اِلٰى رَبِّهِمْ رٰجِعُوْنَۙ وَالَّذِيْنَ : اور جو لوگ يُؤْتُوْنَ : دیتے ہیں مَآ اٰتَوْا : جو وہ دیتے ہیں وَّقُلُوْبُهُمْ : اور ان کے دل وَجِلَةٌ : ڈرتے ہیں اَنَّهُمْ : کہ وہ اِلٰى : طرف رَبِّهِمْ : اپنا رب رٰجِعُوْنَ : لوٹنے والے اور جو لوگ دیتے ہیں جو کچھ دیتے ہیں اور ان کے دل کپکپاتے ہیں کہ وہ اپنے رب کی طرف لوٹنے والے ہیں 1۔
  23,61,اُولٰٓئِكَ یُسٰرِعُوْنَ فِی الْخَیْرٰتِ وَ هُمْ لَهَا سٰبِقُوْنَ اُولٰٓئِكَ : یہی لوگ يُسٰرِعُوْنَ : جلدی کرتے ہیں فِي الْخَيْرٰتِ : بھلائیوں میں وَهُمْ : اور وہ لَهَا : ان کی طرف سٰبِقُوْنَ : سبقت لے جانیوالے ہیں یہی ہیں جو جلدی جلدی بھلائیاں حاصل کر رہے ہیں اور یہی ہیں جو ان کی طرف دوڑ جانے والے ہیں۔
  23,62,وَ لَا نُكَلِّفُ نَفْسًا اِلَّا وُسْعَهَا وَ لَدَیْنَا كِتٰبٌ یَّنْطِقُ بِالْحَقِّ وَ هُمْ لَا یُظْلَمُوْنَ وَلَا نُكَلِّفُ : اور ہم تکلیف نہیں دیتے نَفْسًا : کسی کو اِلَّا : مگر وُسْعَهَا : اس کی طاقت کے مطابق وَلَدَيْنَا : اور ہمارے پاس كِتٰبٌ : ایک کتاب (رجسٹر) يَّنْطِقُ : وہ بتلاتا ہے بِالْحَقِّ : ٹھیک ٹھیک وَهُمْ : اور وہ (ان) لَا يُظْلَمُوْنَ : ظلم نہ کیے جائیں گے (ظلم نہ ہوگا) ہم کسی نفس کو اس کی طاقت سے زیادہ تکلیف نہیں دیتے 1 اور ہمارے پاس ایسی کتاب ہے جو حق کے ساتھ بولتی ہے، ان کے اوپر کچھ بھی ظلم نہ کیا جائے گا۔
  23,63,بَلْ قُلُوْبُهُمْ فِیْ غَمْرَةٍ مِّنْ هٰذَا وَ لَهُمْ اَعْمَالٌ مِّنْ دُوْنِ ذٰلِكَ هُمْ لَهَا عٰمِلُوْنَ بَلْ : بلکہ قُلُوْبُهُمْ : ان کے دل فِيْ غَمْرَةٍ : غفلت میں مِّنْ ھٰذَا : اس سے وَلَهُمْ : اور ان کے اَعْمَالٌ : اعمال (جمع) مِّنْ دُوْنِ : علاوہ ذٰلِكَ : اس هُمْ لَهَا : وہ انہیں عٰمِلُوْنَ : کرتے رہتے ہیں بلکہ ان کے دل اس طرف سے غفلت میں ہیں اور ان کے لئے اس کے سوا بھی بہت سے اعمال ہیں 1 جنہیں وہ کرنے والے ہیں۔
  23,64,حَتّٰۤى اِذَاۤ اَخَذْنَا مُتْرَفِیْهِمْ بِالْعَذَابِ اِذَا هُمْ یَجْئَرُوْنَؕ حَتّيٰٓ اِذَآ : یہاں تک کہ جب اَخَذْنَا : ہم نے پکڑا مُتْرَفِيْهِمْ : ان کے خوشحال لوگ بِالْعَذَابِ : عذاب میں اِذَا هُمْ : اس وقت وہ يَجْئَرُوْنَ : فریاد کرنے لگے یہاں تک کہ جب ہم نے ان کے آسودہ حال لوگوں کو عذاب میں پکڑ لیا 1 تو بلبلانے لگے۔
  23,65,لَا تَجْئَرُوا الْیَوْمَ١۫ اِنَّكُمْ مِّنَّا لَا تُنْصَرُوْنَ لَا تَجْئَرُوا : تم فریاد نہ کرو الْيَوْمَ : آج اِنَّكُمْ : بیشک تم مِّنَّا : ہم سے لَا تُنْصَرُوْنَ : تم مدد نہ دئیے جاؤگے آج مت بلبلاؤ یقیناً تم ہمارے مقابلہ پر مدد نہ کئے جاؤ گے 1۔
  23,66,قَدْ كَانَتْ اٰیٰتِیْ تُتْلٰى عَلَیْكُمْ فَكُنْتُمْ عَلٰۤى اَعْقَابِكُمْ تَنْكِصُوْنَۙ قَدْ كَانَتْ : البتہ تھیں اٰيٰتِيْ : میری آیتیں تُتْلٰى : پڑھی جاتی تھیں عَلَيْكُمْ : تم پر فَكُنْتُمْ : تو تم تھے عَلٰٓي اَعْقَابِكُمْ : اپنی ایڑیوں کے بل تَنْكِصُوْنَ : پھرجاتے میری آیتیں تو تمہارے سامنے پڑھی جاتی تھیں 1 پھر بھی تم اپنی ایڑیوں کے بل الٹے بھاگتے تھے 2
  23,67,مُسْتَكْبِرِیْنَ١ۖۗ بِهٖ سٰمِرًا تَهْجُرُوْنَ مُسْتَكْبِرِيْنَ : تکبر کرتے ہوئے بِهٖ : اس کے ساتھ سٰمِرًا : افسانہ کوئی کرتے ہوئے تَهْجُرُوْنَ : بیہودہ بکواس کرتے ہوئے اکڑتے اینٹھتے 1 افسانہ گوئی کرتے اسے چھوڑ دیتے تھے 2۔
  23,68,اَفَلَمْ یَدَّبَّرُوا الْقَوْلَ اَمْ جَآءَهُمْ مَّا لَمْ یَاْتِ اٰبَآءَهُمُ الْاَوَّلِیْنَ٘ اَفَلَمْ يَدَّبَّرُوا : کیا پس انہوں نے غور نہیں کیا الْقَوْلَ : کلام اَمْ : یا جَآءَهُمْ : ان کے پاس آیا مَّا : جو لَمْ يَاْتِ : نہیں آیا اٰبَآءَهُمُ : ان کے باپ دادا الْاَوَّلِيْنَ : پہلے کیا انہوں نے اس بات میں غور و فکر ہی نہیں کیا 1 بلکہ ان کے پاس وہ آیا جو ان کے اگلے باپ دادوں کے پاس نہیں آیا تھا 2۔
  23,69,اَمْ لَمْ یَعْرِفُوْا رَسُوْلَهُمْ فَهُمْ لَهٗ مُنْكِرُوْنَ٘ اَمْ : یا لَمْ يَعْرِفُوْا : انہوں نے نہیں پہچانا رَسُوْلَهُمْ : اپنے رسول فَهُمْ : تو وہ لَهٗ : اس کے مُنْكِرُوْنَ : منکر ہیں یا انہوں نے اپنے پیغمبر کو پہچانا نہیں کہ اس کے منکر ہو رہے ہیں 1۔
  23,70,اَمْ یَقُوْلُوْنَ بِهٖ جِنَّةٌ١ؕ بَلْ جَآءَهُمْ بِالْحَقِّ وَ اَكْثَرُهُمْ لِلْحَقِّ كٰرِهُوْنَ اَمْ : یا يَقُوْلُوْنَ : وہ کہتے ہیں بِهٖ : اس کو جِنَّةٌ : دیوانگی بَلْ : بلکہ جَآءَهُمْ : وہ آیا ان کے پاس بِالْحَقِّ : ساتح حق بات وَاَكْثَرُهُمْ : اور ان میں سے اکثر لِلْحَقِّ : حق سے كٰرِهُوْنَ : نفر رکھنے والے یا یہ کہتے ہیں کہ اسے جنون ہے 1 بلکہ وہ تو ان کے پاس حق لایا ہے۔ ہاں ان میں اکثر حق سے چڑنے والے ہیں 2۔
  23,71,وَ لَوِ اتَّبَعَ الْحَقُّ اَهْوَآءَهُمْ لَفَسَدَتِ السَّمٰوٰتُ وَ الْاَرْضُ وَ مَنْ فِیْهِنَّ١ؕ بَلْ اَتَیْنٰهُمْ بِذِكْرِهِمْ فَهُمْ عَنْ ذِكْرِهِمْ مُّعْرِضُوْنَؕ وَلَوِ : اور اگر اتَّبَعَ : پیروی کرتا الْحَقُّ : حق (اللہ) اَهْوَآءَهُمْ : ان کی خواہشات لَفَسَدَتِ : البتہ درہم برہم ہوجاتا السَّمٰوٰتُ : آسمان (جمع) وَالْاَرْضُ : اور زمین وَمَنْ : اور جو فِيْهِنَّ : ان کے درمیان بَلْ : بلکہ اَتَيْنٰهُمْ : ہم لائے ہیں ان کے پاس بِذِكْرِهِمْ : ان کی نصیحت فَهُمْ : پھر وہ عَنْ ذِكْرِهِمْ : اپنی نصیحت سے مُّعْرِضُوْنَ : روگردانی کرنے والے ہیں اگر حق ہی ان کی خواہشوں کا پیرو ہوجائے تو زمین و آسمان اور ان کے درمیان کی ہر چیز درہم برہم ہوجائے 1 حق تو یہ ہے کہ ہم نے انھیں ان کی نصیحت پہنچا دی ہے لیکن وہ اپنی نصیحت سے منہ موڑنے والے ہیں۔
  23,72,اَمْ تَسْئَلُهُمْ خَرْجًا فَخَرَاجُ رَبِّكَ خَیْرٌ١ۖۗ وَّ هُوَ خَیْرُ الرّٰزِقِیْنَ اَمْ تَسْئَلُهُمْ : کیا تم ان سے مانگتے ہو خَرْجًا : اجر فَخَرَاجُ : تو اجر رَبِّكَ : تمہارا رب خَيْرٌ : بہتر وَّهُوَ : اور وہ خَيْرُ الرّٰزِقِيْنَ : بہترین روزی دہندہ ہے کیا آپ ان سے کوئی اجرت چاہتے ہیں ؟ یاد رکھئے کہ آپ کے رب کی اجرت بہت ہی بہتر ہے اور وہ سب سے بہتر روزی رساں ہے۔
  23,73,وَ اِنَّكَ لَتَدْعُوْهُمْ اِلٰى صِرَاطٍ مُّسْتَقِیْمٍ وَاِنَّكَ : اور بیشک تم لَتَدْعُوْهُمْ : انہیں بلاتے ہو اِلٰى : طرف صِرَاطٍ : راہ راستہ مُّسْتَقِيْمٍ : سیدھا۔ راستہ یقیناً آپ انھیں راہ راست کی طرف بلا رہے ہیں۔
  23,74,وَ اِنَّ الَّذِیْنَ لَا یُؤْمِنُوْنَ بِالْاٰخِرَةِ عَنِ الصِّرَاطِ لَنٰكِبُوْنَ وَاِنَّ : اور بیشک الَّذِيْنَ : جو لوگ لَا يُؤْمِنُوْنَ : ایمان نہیں لاتے بِالْاٰخِرَةِ : آخرت پر عَنِ : سے الصِّرَاطِ : راہ (حق) لَنٰكِبُوْنَ : البتہ ہٹے ہوئے ہیں بیشک جو لوگ آخرت پر یقین نہیں رکھتے وہ سیدھے راستے سے مڑ جانے والے ہیں 1۔
