tafsir[21]{c,v,t}:
  26,207,مَاۤ اَغْنٰى عَنْهُمْ مَّا كَانُوْا یُمَتَّعُوْنَؕ مَآ اَغْنٰى : کیا کام ٓئے گا عَنْهُمْ : ان کے مَّا : جو (جس سے) كَانُوْا يُمَتَّعُوْنَ : وہ فائدہ اٹھاتے تھے تو جو کچھ بھی یہ برتتے رہے اس میں سے کچھ بھی فائدہ نہ پہنچا سکے گا 1۔
  26,208,وَ مَاۤ اَهْلَكْنَا مِنْ قَرْیَةٍ اِلَّا لَهَا مُنْذِرُوْنَ٥ۗۛۖ وَ : اور مَآ اَهْلَكْنَا : نہیں ہلاک کیا ہم نے مِنْ قَرْيَةٍ : کسی بستی کو اِلَّا : مگر لَهَا : اس کے لیے مُنْذِرُوْنَ : ڈرانے والے ہم نے کسی بستی کو ہلاک نہیں کیا ہے مگر اسی حال میں کہ اس کے لئے ڈرانے والے تھے۔
  26,209,ذِكْرٰى١ۛ۫ وَ مَا كُنَّا ظٰلِمِیْنَ ذِكْرٰي : نصیحت کے لیے وَمَا كُنَّا : اور نہ تھے ہم ظٰلِمِيْنَ : ظلم کرنے والے نصیحت کے طور پر اور ہم ظلم کرنے والے نہیں ہیں 1
  26,210,وَ مَا تَنَزَّلَتْ بِهِ الشَّیٰطِیْنُ وَ : اور مَا تَنَزَّلَتْ : نہیں اترے بِهِ : اسے لے کر الشَّيٰطِيْنُ : شیطان (جمع) اس قرآن کو شیطان نہیں لائے۔
  26,211,وَ مَا یَنْۢبَغِیْ لَهُمْ وَ مَا یَسْتَطِیْعُوْنَؕ وَمَا يَنْۢبَغِيْ : اور سزاوار نہیں لَهُمْ : ان کو وَمَا يَسْتَطِيْعُوْنَ : اور نہ وہ کرسکتے ہیں نہ وہ اس قابل ہیں، نہ انھیں اس کی طاقت ہے۔
  26,212,اِنَّهُمْ عَنِ السَّمْعِ لَمَعْزُوْلُوْنَؕ اِنَّهُمْ : بیشک وہ عَنِ : سے السَّمْعِ : سننا لَمَعْزُوْلُوْنَ : دور کردئیے گئے ہیں بلکہ وہ سننے سے محروم کردیئے گئے ہیں 1
  26,213,فَلَا تَدْعُ مَعَ اللّٰهِ اِلٰهًا اٰخَرَ فَتَكُوْنَ مِنَ الْمُعَذَّبِیْنَۚ فَلَا تَدْعُ : پس نہ پکارو مَعَ اللّٰهِ : اللہ کے ساتھ اِلٰهًا اٰخَرَ : کوئی دوسرا معبود فَتَكُوْنَ : کہ ہوجاؤ مِنَ : سے الْمُعَذَّبِيْنَ : مبتلائے عذاب پس تو اللہ کے ساتھ کسی اور معبود کو نہ پکار کہ تو بھی سزا پانے والوں میں سے ہوجائے
  26,214,وَ اَنْذِرْ عَشِیْرَتَكَ الْاَقْرَبِیْنَۙ وَاَنْذِرْ : اور تم ڈراؤ عَشِيْرَتَكَ : اپنے رشتہ دار الْاَقْرَبِيْنَ : قریب ترین اپنے قریبی رشتہ والوں کو ڈرا دے 1
  26,215,وَ اخْفِضْ جَنَاحَكَ لِمَنِ اتَّبَعَكَ مِنَ الْمُؤْمِنِیْنَۚ وَ : اور اخْفِضْ : جھکاؤ جَنَاحَكَ : اپنا بازو لِمَنِ : اس کے لیے جس نے اتَّبَعَكَ : تمہاری پیروی کی مِنَ : سے الْمُؤْمِنِيْنَ : مومنوں اس کے ساتھ نرمی سے پیش آ، جو بھی ایمان لانے والا ہو کہ تیری تابعداری کرے۔
  26,216,فَاِنْ عَصَوْكَ فَقُلْ اِنِّیْ بَرِیْٓءٌ مِّمَّا تَعْمَلُوْنَۚ فَاِنْ : پھر اگر عَصَوْكَ : وہ تمہاری نافرمانی کریں فَقُلْ : تو کہ دیں اِنِّىْ بَرِيْٓءٌ : بیشک میں بیزار ہوں مِّمَّا : اس سے جو تَعْمَلُوْنَ : تم کرتے ہو اگر یہ لوگ تیری نافرمانی کریں تو اعلان کر دے کہ میں ان کاموں سے بیزار ہوں جو تم کر رہے ہو۔
  26,217,وَ تَوَكَّلْ عَلَى الْعَزِیْزِ الرَّحِیْمِۙ وَتَوَكَّلْ : اور بھروسہ کرو عَلَي : پر الْعَزِيْزِ : غالب الرَّحِيْمِ : نہایت مہربان اپنا پورا بھروسہ غالب مہربان اللہ پر رکھ۔
  26,218,الَّذِیْ یَرٰىكَ حِیْنَ تَقُوْمُۙ الَّذِيْ : وہ جو يَرٰىكَ : تمہیں دیکھتا ہے حِيْنَ : جب تَقُوْمُ : تم کھڑے ہوتے ہو جو تجھے دیکھتا رہتا ہے جبکہ تو کھڑا ہوتا ہے۔
  26,219,وَ تَقَلُّبَكَ فِی السّٰجِدِیْنَ وَتَقَلُّبَكَ : اور تمہارا پھرنا فِي : میں السّٰجِدِيْنَ : سجدہ کرنے والے (نمازی) اور سجدہ کرنے والوں کے درمیان تیرا گھومنا پھرنا بھی 1
  26,220,اِنَّهٗ هُوَ السَّمِیْعُ الْعَلِیْمُ اِنَّهٗ : بیشک وہ هُوَ : وہی السَّمِيْعُ : سننے والا الْعَلِيْمُ : جاننے والا وہ بڑا ہی سننے والا اور خوب ہی جاننے والا ہے۔
  26,221,هَلْ اُنَبِّئُكُمْ عَلٰى مَنْ تَنَزَّلُ الشَّیٰطِیْنُؕ هَلْ : کیا اُنَبِّئُكُمْ : میں تمہیں بتاؤں عَلٰي مَنْ : کسی پر تَنَزَّلُ : اترتے ہیں الشَّيٰطِيْنُ : شیطان (جمع) کیا میں تمہیں بتاؤں کہ شیطان کس پر اترتے ہیں۔
  26,222,تَنَزَّلُ عَلٰى كُلِّ اَفَّاكٍ اَثِیْمٍۙ تَنَزَّلُ : وہ اترتے ہیں عَلٰي : پر كُلِّ : ہر اَفَّاكٍ : بہتان لگانے والا اَثِيْمٍ : گنہگار وہ ہر جھوٹے گنہگار پر اترتے ہیں 1
  26,223,یُّلْقُوْنَ السَّمْعَ وَ اَكْثَرُهُمْ كٰذِبُوْنَؕ يُّلْقُوْنَ : ڈالدیتے ہیں السَّمْعَ : سنی سنائی بات وَاَكْثَرُهُمْ : اور ان میں اکثر كٰذِبُوْنَ : جھوٹے ہیں (اچٹتی) ہوئی سنی سنائی پہنچا دیتے ہیں اور ان میں سے اکثر جھوٹے ہیں 1
  26,224,وَ الشُّعَرَآءُ یَتَّبِعُهُمُ الْغَاوٗنَؕ وَالشُّعَرَآءُ : اور شاعر (جمع يَتَّبِعُهُمُ : ان کی پیروی کرتے ہیں الْغَاوٗنَ : گمراہ لوگ شاعروں کی پیروی وہ کرتے ہیں جو بہکے ہوئے ہوں۔
  26,225,اَلَمْ تَرَ اَنَّهُمْ فِیْ كُلِّ وَادٍ یَّهِیْمُوْنَۙ اَلَمْ تَرَ : کیا تم نے نہیں دیکھا اَنَّهُمْ فِيْ كُلِّ وَادٍ : کہ وہ ہر ادی میں يَّهِيْمُوْنَ : سرگرداں پھرتے ہیں کیا آپ نے نہیں دیکھا کہ شاعر ایک ایک بیابان میں سر ٹکراتے پھرتے ہیں۔
  26,226,وَ اَنَّهُمْ یَقُوْلُوْنَ مَا لَا یَفْعَلُوْنَۙ وَاَنَّهُمْ : اور یہ کہ وہ يَقُوْلُوْنَ : وہ کہتے ہیں مَا : جو لَا يَفْعَلُوْنَ : وہ کرتے نہیں اور وہ کہتے ہیں جو کرتے نہیں 1
  26,227,اِلَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ وَ ذَكَرُوا اللّٰهَ كَثِیْرًا وَّ انْتَصَرُوْا مِنْۢ بَعْدِ مَا ظُلِمُوْا١ؕ وَ سَیَعْلَمُ الَّذِیْنَ ظَلَمُوْۤا اَیَّ مُنْقَلَبٍ یَّنْقَلِبُوْنَ۠    ۧ اِلَّا : مگر الَّذِيْنَ : جو لوگ اٰمَنُوْا : ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : اچھے وَذَكَرُوا اللّٰهَ : اور اللہ کو یاد کیا كَثِيْرًا : بکثرت وَّانْتَصَرُوْا : اور انہوں نے بدلہ لیا مِنْۢ بَعْدِ : اس کے بعد مَا ظُلِمُوْا : کہ ان پر ظلم ہوا وَسَيَعْلَمُ : اور عنقریب جان لیں گے الَّذِيْنَ : وہ لوگ جنہوں نے ظَلَمُوْٓا : ظلم کیا اَيَّ : کس مُنْقَلَبٍ : لوٹنے کی جگہ (کروٹ) يَّنْقَلِبُوْنَ : وہ الٹتے ہیں (انہیں لوٹ کر جانا ہے سوائے ان کے جو ایمان لائے 1 اور نیک عمل کئے اور بکثرت اللہ تعالیٰ کا ذکر کیا اور اپنی مظلومی کے بعد انتقام لیا 2 جنہوں نے ظلم کیا ہے وہ بھی ابھی جان لیں گے کہ کس کروٹ الٹتے ہیں 3
