quran[60]{c,v,t}:
51,1,وَ الذّٰرِیٰتِ ذَرْوًاۙ وَالذّٰرِيٰتِ : قسم ہے پراگندہ کرنیوالی ( ہواؤں) ذَرْوًا : اڑاکر قسم ہے بکھیرنے والیوں کی اڑا کر (1)۔
51,2,فَالْحٰمِلٰتِ وِقْرًاۙ فَالْحٰمِلٰتِ : پھر اٹھانے والی وِقْرًا : بوجھ پھر اٹھانے والیاں بوجھ کو (1)۔
51,3,فَالْجٰرِیٰتِ یُسْرًاۙ فَالْجٰرِيٰتِ : لیکر چلنے والی يُسْرًا : نرمی سے پھر چلنے والی نرمی سے (1)
51,4,فَالْمُقَسِّمٰتِ اَمْرًاۙ فَالْمُقَسِّمٰتِ : پھر تقسیم کرنیوالے اَمْرًا : حکم سے پھر کام کو تقسیم کرنے والیاں (1)۔
51,5,اِنَّمَا تُوْعَدُوْنَ لَصَادِقٌۙ اِنَّمَا : اس کے سوا نہیں تُوْعَدُوْنَ : تمہیں وعدہ دیاجاتا ہے لَصَادِقٌ : البتہ سچ ہے یقین مانو کہ تم سے جو وعدے کئے جاتے ہیں (سب) سچے ہیں
51,6,وَّ اِنَّ الدِّیْنَ لَوَاقِعٌؕ وَّاِنَّ : اور بیشک الدِّيْنَ : جزا وسزا لَوَاقِعٌ : البتہ واقع ہونیوالی اور بیشک انصاف ہونے والا ہے۔
51,7,وَ السَّمَآءِ ذَاتِ الْحُبُكِۙ وَالسَّمَآءِ : اور قسم ہے آسمانوں کی ذَاتِ الْحُبُكِ : راستوں والے قسم ہے راہوں والے آسمان کی (1)
51,8,اِنَّكُمْ لَفِیْ قَوْلٍ مُّخْتَلِفٍۙ اِنَّكُمْ : بیشک تم لَفِيْ : البتہ میں قَوْلٍ مُّخْتَلِفٍ : بات جھگڑنے والی یقیناً تم مختلف بات میں پڑے ہوئے ہو (1)
51,9,یُّؤْفَكُ عَنْهُ مَنْ اُفِكَؕ يُّؤْفَكُ : پھیرا جاتا ہے عَنْهُ : اس سے مَنْ اُفِكَ : جو پھیرا جاتا ہے اس سے وہی باز رکھا جاتا ہے (1) جو پھیر دیا گیا ہو۔
51,10,قُتِلَ الْخَرّٰصُوْنَۙ قُتِلَ : مارے گئے الْخَرّٰصُوْنَ : اٹکل دوڑانے والے بےسند باتیں کرنے والے غارت کردیئے گئے۔
51,11,الَّذِیْنَ هُمْ فِیْ غَمْرَةٍ سَاهُوْنَۙ الَّذِيْنَ هُمْ : وہ جو وہ فِيْ غَمْرَةٍ : غفلت میں سَاهُوْنَ : بھولے ہوئے ہیں جو غفلت میں ہیں اور بھولے ہوئے ہیں۔
51,12,یَسْئَلُوْنَ اَیَّانَ یَوْمُ الدِّیْنِؕ يَسْئَلُوْنَ : وہ پوچھتے ہیں اَيَّانَ : کب يَوْمُ الدِّيْنِ : جزا وسزا کا دن پوچھتے ہیں کہ یوم جزا کب ہوگا ؟
51,13,یَوْمَ هُمْ عَلَى النَّارِ یُفْتَنُوْنَ يَوْمَ هُمْ : اس دن وہ عَلَي النَّارِ : آگ پر يُفْتَنُوْنَ : الٹے سیدھے پڑینگے ہاں یہ وہ دن ہے کہ یہ آگ پر تپائے جائیں گے (1)
51,14,ذُوْقُوْا فِتْنَتَكُمْ١ؕ هٰذَا الَّذِیْ كُنْتُمْ بِهٖ تَسْتَعْجِلُوْنَ ذُوْقُوْا : تم چکھو فِتْنَتَكُمْ ۭ : اپنی شرارت ھٰذَا الَّذِيْ : یہ وہ جو كُنْتُمْ بِهٖ : تم تھے اس کی تَسْتَعْجِلُوْنَ : جلدی کرتے اپنی فتنہ پردازی کا مزہ چکھو (1) یہی ہے جس کی تم جلدی مچا رہے تھے۔
51,15,اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ عُیُوْنٍۙ اِنَّ الْمُتَّقِيْنَ : بیشک متقی (جمع) فِيْ جَنّٰتٍ : باغات میں وَّعُيُوْنٍ : اور چشمے بیشک تقوٰی والے لوگ بہشتوں اور چشموں میں ہونگے۔
51,16,اٰخِذِیْنَ مَاۤ اٰتٰىهُمْ رَبُّهُمْ١ؕ اِنَّهُمْ كَانُوْا قَبْلَ ذٰلِكَ مُحْسِنِیْنَؕ اٰخِذِيْنَ : لینے والے مَآ اٰتٰىهُمْ رَبُّهُمْ ۭ : جو دیا انہیں انکا رب اِنَّهُمْ كَانُوْا : بیشک وہ تھے قَبْلَ ذٰلِكَ : اس سے قبل مُحْسِنِيْنَ : نیکوکار ان کے رب نے جو کچھ انہیں عطا فرمایا اسے لے رہے ہونگے وہ تو اس سے پہلے ہی نیکوکار تھے۔
51,17,كَانُوْا قَلِیْلًا مِّنَ الَّیْلِ مَا یَهْجَعُوْنَ كَانُوْا : وہ تھے قَلِيْلًا : تھوڑا مِّنَ الَّيْلِ : رات سے، میں مَا يَهْجَعُوْنَ : وہ سوتے وہ رات کو بہت کم سویا کرتے تھے (1)
51,18,وَ بِالْاَسْحَارِ هُمْ یَسْتَغْفِرُوْنَ وَبِالْاَسْحَارِ : اور وقت صبح هُمْ : وہ يَسْتَغْفِرُوْنَ : استغفار کرتے اور صبح کے وقت استغفار کیا کرتے تھے۔ (1)
51,19,وَ فِیْۤ اَمْوَالِهِمْ حَقٌّ لِّلسَّآئِلِ وَ الْمَحْرُوْمِ وَفِيْٓ اَمْوَالِهِمْ : اور انکے مالوں میں حَقٌّ لِّلسَّآئِلِ : حق سوالی کے لئے وَالْمَحْرُوْمِ : اور تنگدست (غیرسوالی) اور ان کے مال میں مانگنے والوں اور سوال سے بچنے والوں کا حق تھا (1)
51,20,وَ فِی الْاَرْضِ اٰیٰتٌ لِّلْمُوْقِنِیْنَۙ وَفِي الْاَرْضِ : اور زمین میں اٰيٰتٌ : نشانیاں لِّلْمُوْقِنِيْنَ : یقین کرنے والوں کیلئے اور یقین والوں کے لئے تو زمین میں بہت سی نشانیاں ہیں۔
51,21,وَ فِیْۤ اَنْفُسِكُمْ١ؕ اَفَلَا تُبْصِرُوْنَ وَفِيْٓ : اور میں اَنْفُسِكُمْ ۭ : تمہاری ذات اَفَلَا : تو کیا نہیں تُبْصِرُوْنَ : تم دیکھتے اور خود تمہاری ذات میں بھی، تو کیا تم دیکھتے نہیں ہو۔
51,22,وَ فِی السَّمَآءِ رِزْقُكُمْ وَ مَا تُوْعَدُوْنَ وَفِي السَّمَآءِ : اور آسمانوں میں رِزْقُكُمْ : تمہارا رزق ہے وَمَا تُوْعَدُوْنَ : اور جو تم سے وعدہ کیا جاتا ہے اور تمہاری روزی اور جو تم سے وعدہ کیا جاتا ہے سب آسمان میں ہے (1)۔
51,23,فَوَرَبِّ السَّمَآءِ وَ الْاَرْضِ اِنَّهٗ لَحَقٌّ مِّثْلَ مَاۤ اَنَّكُمْ تَنْطِقُوْنَ۠    ۧ فَوَرَبِّ : قسم ہے رب کی السَّمَآءِ : آسمانوں وَالْاَرْضِ : اور زمین اِنَّهٗ : بیشک یہ لَحَقٌّ : حق ہے مِّثْلَ : جیسے مَآ اَنَّكُمْ : جو تم تَنْطِقُوْنَ : بولتے ہو آسمانوں اور زمین کے پروردگار کی قسم ! کہ یہ (1) بالکل برحق ہے ایسا ہی جیسے کہ تم باتیں کرتے ہو۔
51,24,هَلْ اَتٰىكَ حَدِیْثُ ضَیْفِ اِبْرٰهِیْمَ الْمُكْرَمِیْنَۘ هَلْ اَتٰىكَ : کیا آئی تمہارے پاس حَدِيْثُ : بات (خبر) ضَيْفِ اِبْرٰهِيْمَ : ابراہیم کے مہمان الْمُكْرَمِيْنَ : معزز کیا تجھے ابراہیم ؑ کے معزز مہمانوں کی خبر بھی پہنچی ہے (1) ؟
51,25,اِذْ دَخَلُوْا عَلَیْهِ فَقَالُوْا سَلٰمًا١ؕ قَالَ سَلٰمٌ١ۚ قَوْمٌ مُّنْكَرُوْنَۚ اِذْ دَخَلُوْا : جب وہ آئے عَلَيْهِ : اس کے پاس فَقَالُوْا : تو انہوں نے کہا سَلٰمًا ۭ : سلام قَالَ : اس نے کہا سَلٰمٌ ۚ : سلام قَوْمٌ : لوگ مُّنْكَرُوْنَ : ناشناسا وہ جب ان کے ہاں آئے تو سلام کیا، ابراہیم نے جواب سلام دیا (اور کہا یہ تو) اجنبی لوگ ہیں (1)
51,26,فَرَاغَ اِلٰۤى اَهْلِهٖ فَجَآءَ بِعِجْلٍ سَمِیْنٍۙ فَرَاغَ : پھر وہ متوجہ ہوا اِلٰٓى : طرف اَهْلِهٖ : اپنے اہل خانہ فَجَآءَ بِعِجْلٍ : پس لایا بچھڑا سَمِيْنٍ : فربہ پھر (چپ چاپ جلدی جلدی) اپنے گھر والوں کی طرف گئے اور ایک فربہ بچھڑے (کا گوشت) لائے۔
51,27,فَقَرَّبَهٗۤ اِلَیْهِمْ قَالَ اَلَا تَاْكُلُوْنَ٘ فَقَرَّبَهٗٓ : پھر وہ سامنے رکھا اِلَيْهِمْ : ان کے قَالَ : کہا اَلَا تَاْكُلُوْنَ : کیا تم کھاتے نہیں اور اسے ان کے پاس رکھا اور کہا آپ کھاتے کیوں نہیں۔ (1)
51,28,فَاَوْجَسَ مِنْهُمْ خِیْفَةً١ؕ قَالُوْا لَا تَخَفْ١ؕ وَ بَشَّرُوْهُ بِغُلٰمٍ عَلِیْمٍ فَاَوْجَسَ : تو اس نے محسوس کیا مِنْهُمْ : ان سے خِيْفَةً ۭ : ڈر قَالُوْا : وہ بولے لَا تَخَفْ ۭ : تم ڈرو نہیں وَبَشَّرُوْهُ : اور انہوں نے بشارت دی بِغُلٰمٍ : ایک بیٹے کی عَلِيْمٍ : دانش مند پھر تو دل ہی دل میں ان سے خوف زدہ ہوگئے (1) انہوں نے کہا آپ خوف نہ کیجئے (2) اور انہوں نے اس (حضرت ابراہیم) کو ایک علم والے لڑکے کی بشارت دی۔
51,29,فَاَقْبَلَتِ امْرَاَتُهٗ فِیْ صَرَّةٍ فَصَكَّتْ وَجْهَهَا وَ قَالَتْ عَجُوْزٌ عَقِیْمٌ فَاَقْبَلَتِ : پھر آگے آئی امْرَاَتُهٗ : اس کی بیوی فِيْ صَرَّةٍ : حیرت سے بولتی ہوئی فَصَكَّتْ : اس نے ہاتھ مارا وَجْهَهَا : اپنا چہرہ وَقَالَتْ : اور بولی عَجُوْزٌ : بڑھیا عَقِيْمٌ : بانجھ پس ان کی بیوی آگے بڑھی اور حیرت (1) میں آکر اپنے منہ پر مار کر کہا کہ میں تو بڑھیا ہوں اور ساتھ ہی بانجھ۔
51,30,قَالُوْا كَذٰلِكِ١ۙ قَالَ رَبُّكِ١ؕ اِنَّهٗ هُوَ الْحَكِیْمُ الْعَلِیْمُ قَالُوْا : انہوں نے کہا كَذٰلِكِ ۙ : یونہی قَالَ : فرمایا رَبُّكِ ۭ : تیرا رب اِنَّهٗ : بیشک هُوَ : وہ الْحَكِيْمُ : حکمت والا الْعَلِيْمُ : جاننے والا انہوں نے کہا ہاں تیرے پروردگار نے اسی طرح فرمایا ہے، بیشک وہ حکیم وعلیم ہے (1)۔
51,31,قَالَ فَمَا خَطْبُكُمْ اَیُّهَا الْمُرْسَلُوْنَ قَالَ : کہا فَمَا خَطْبُكُمْ : تو کیا قصہ ہے تمہارا اَيُّهَا الْمُرْسَلُوْنَ : اے فرشتو۔ بھیجے ہوؤں حضرت ابراہیم ؑ نے کہا کہ اللہ کے بھیجے ہوئے (فرشتو !) تمہارا کیا مقصد ہے (1)
51,32,قَالُوْۤا اِنَّاۤ اُرْسِلْنَاۤ اِلٰى قَوْمٍ مُّجْرِمِیْنَۙ قَالُوْٓا : انہوں نے کہا اِنَّآ : بیشک ہم اُرْسِلْنَآ : بھیجے گئے ہم اِلٰى : طرف قَوْمٍ مُّجْرِمِيْنَ : مجرم قوم کے انہوں نے جواب دیا کہ ہم گناہگار قوم کی طرف بھیجے گئے ہیں (1)
51,33,لِنُرْسِلَ عَلَیْهِمْ حِجَارَةً مِّنْ طِیْنٍۙ لِنُرْسِلَ : تاکہ ہم بھیجیں عَلَيْهِمْ : ان پر حِجَارَةً : پتھر مِّنْ طِيْنٍ : مٹی سے تاکہ ہم ان پر مٹی کے کنکر برسائیں۔ (1)
51,34,مُّسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِیْنَ مُّسَوَّمَةً : نشان لگے ہوئے ہیں عِنْدَ رَبِّكَ : تیرے رب کے ہاں لِلْمُسْرِفِيْنَ : حد سے بڑھنے والوں کے لیے جو تیرے رب کی طرف سے نشان زدہ ہیں ان حد سے گزر جانے والوں کے لئے۔ (1)
51,35,فَاَخْرَجْنَا مَنْ كَانَ فِیْهَا مِنَ الْمُؤْمِنِیْنَۚ فَاَخْرَجْنَا : تو نکال لیا ہم نے مَنْ كَانَ فِيْهَا : جو کوئی اس میں تھا مِنَ الْمُؤْمِنِيْنَ : مومنوں میں سے پس جتنے ایمان دار وہاں تھے ہم نے انہیں نکال لیا (1)
51,36,فَمَا وَجَدْنَا فِیْهَا غَیْرَ بَیْتٍ مِّنَ الْمُسْلِمِیْنَۚ فَمَا : تو نہ وَجَدْنَا فِيْهَا : پایا ہم نے اس میں غَيْرَ بَيْتٍ : سوائے ایک گھر کے مِّنَ الْمُسْلِمِيْنَ : مسلمانوں میں سے اور ہم نے وہاں مسلمانوں کا صرف ایک ہی گھر پایا (1)
51,37,وَ تَرَكْنَا فِیْهَاۤ اٰیَةً لِّلَّذِیْنَ یَخَافُوْنَ الْعَذَابَ الْاَلِیْمَؕ وَتَرَكْنَا : اور چھوڑ دی ہم نے فِيْهَآ : اس میں اٰيَةً لِّلَّذِيْنَ : ایک نشانی ان لوگوں کے لیے يَخَافُوْنَ : جو ڈرتے ہیں الْعَذَابَ الْاَلِيْمَ : دردناک عذاب سے اور ہم نے ان کے لئے جو دردناک عذاب کا ڈر رکھتے ہیں ایک (کامل) علامت چھوڑی (1)
51,38,وَ فِیْ مُوْسٰۤى اِذْ اَرْسَلْنٰهُ اِلٰى فِرْعَوْنَ بِسُلْطٰنٍ مُّبِیْنٍ وَفِيْ مُوْسٰٓى : اور موسیٰ میں اِذْ اَرْسَلْنٰهُ : جب بھیجا ہم نے اس کو اِلٰى فِرْعَوْنَ : فرعون کی طرف بِسُلْطٰنٍ : ایک دلیل کے ساتھ مُّبِيْنٍ : کھلی موسٰی (علیہ السلام کے قصے) میں (بھی ہماری طرف سے تنبیہ ہے) کہ ہم نے فرعون کی طرف کھلی دلیل دے کر بھیجا۔
51,39,فَتَوَلّٰى بِرُكْنِهٖ وَ قَالَ سٰحِرٌ اَوْ مَجْنُوْنٌ فَتَوَلّٰى : تو وہ پھر گیا بِرُكْنِهٖ : اپنی قوت کے ساتھ وَقَالَ سٰحِرٌ : اور کہنے لگا ایک جادوگر ہے اَوْ مَجْنُوْنٌ : یا مجنون ہے پس اس نے اپنے بل بوتے پر منہ موڑا (1) اور کہنے لگا یہ جادوگر ہے یا دیوانہ ہے۔
51,40,فَاَخَذْنٰهُ وَ جُنُوْدَهٗ فَنَبَذْنٰهُمْ فِی الْیَمِّ وَ هُوَ مُلِیْمٌؕ فَاَخَذْنٰهُ : تو پکڑ لیا ہم نے اس کو وَجُنُوْدَهٗ : اور اس کے لشکروں کو فَنَبَذْنٰهُمْ : تو پھینک دیا ہم نے ان کو فِي الْيَمِّ : سمندر میں وَهُوَ مُلِيْمٌ : اور وہ ملامت زدہ تھا بالآخر ہم نے اسے اور اس کے لشکروں کو اپنے عذاب میں پکڑ کر دریا میں ڈال دیا وہ تھا ملامت کے قابل (1)۔
51,41,وَ فِیْ عَادٍ اِذْ اَرْسَلْنَا عَلَیْهِمُ الرِّیْحَ الْعَقِیْمَۚ وَفِيْ عَادٍ : اور عاد میں اِذْ اَرْسَلْنَا : جب بھیجا ہم نے عَلَيْهِمُ : ان پر الرِّيْحَ الْعَقِيْمَ : بےنفع ہوا کو۔ بیخبر ہوا کو۔ بانجھ ہوا کو اسی طرح عادیوں میں (1) بھی (ہماری طرف سے تنبیہ ہے) جب کہ ہم نے ان پر خیر و برکت سے (2) خالی آندھی بھیجی۔
51,42,مَا تَذَرُ مِنْ شَیْءٍ اَتَتْ عَلَیْهِ اِلَّا جَعَلَتْهُ كَالرَّمِیْمِؕ مَا : نہ تَذَرُ مِنْ شَيْءٍ : چھوڑتی تھی کسی چیز کو اَتَتْ عَلَيْهِ : آئی جس پر اِلَّا جَعَلَتْهُ كَالرَّمِيْمِ : مگر اس نے کردیا اس کو بوسیدہ ہڈیوں کی طرح وہ جس چیز پر گرتی تھی اسے بوسیدہ ہڈی کی طرح (چورا چورا) کردیتی تھی۔ (1)
51,43,وَ فِیْ ثَمُوْدَ اِذْ قِیْلَ لَهُمْ تَمَتَّعُوْا حَتّٰى حِیْنٍ وَفِيْ ثَمُوْدَ : اور ثمود میں اِذْ قِيْلَ لَهُمْ : جب کہا گیا ان سے تَمَتَّعُوْا : فائدے اٹھا لو حَتّٰى حِيْنٍ : ایک وقت تک اور ثمود (کے قصے) میں بھی (عبرت) ہے جب ان سے کہا گیا کہ تم کچھ دنوں تک فائدہ اٹھالو (1)
51,44,فَعَتَوْا عَنْ اَمْرِ رَبِّهِمْ فَاَخَذَتْهُمُ الصّٰعِقَةُ وَ هُمْ یَنْظُرُوْنَ فَعَتَوْا : تو انہوں نے سرکشی کی عَنْ اَمْرِ رَبِّهِمْ : اپنے رب کے حکم سے فَاَخَذَتْهُمُ الصّٰعِقَةُ : تو پکڑ لیا ان کو ایک کڑک نے وَهُمْ يَنْظُرُوْنَ : اور وہ دیکھ رہے تھے لیکن انہوں نے اپنے رب کے حکم سے سرتابی کی جس پر ان کے دیکھتے دیکھتے (تیز تند) کڑاکے (1) نے ہلاک کردیا۔
51,45,فَمَا اسْتَطَاعُوْا مِنْ قِیَامٍ وَّ مَا كَانُوْا مُنْتَصِرِیْنَۙ فَمَا اسْتَطَاعُوْا : تو نہ ان کو استطاعت تھی مِنْ قِيَامٍ : کھڑے ہونے کی وَّمَا كَانُوْا : اور نہ تھے وہ مُنْتَصِرِيْنَ : بدلہ لینے والے پس نہ تو کھڑے ہو سکے (1) اور نہ بدلہ لے سکے (2)
51,46,وَ قَوْمَ نُوْحٍ مِّنْ قَبْلُ١ؕ اِنَّهُمْ كَانُوْا قَوْمًا فٰسِقِیْنَ۠    ۧ وَقَوْمَ نُوْحٍ : اور قوم نوح مِّنْ قَبْلُ ۭ : اس سے قبل اِنَّهُمْ كَانُوْا : بیشک وہ تھے قَوْمًا فٰسِقِيْنَ : فاسق لوگ اور نوح ؑ کی قوم کا بھی اس سے پہلے (یہی حال ہوچکا تھا) وہ بھی بڑے نافرمان تھے۔ (1)
51,47,وَ السَّمَآءَ بَنَیْنٰهَا بِاَیْىدٍ وَّ اِنَّا لَمُوْسِعُوْنَ وَالسَّمَآءَ : اور آسمان بَنَيْنٰهَا : بنایا ہم نے اس کو بِاَيْىدٍ : اپنی قوت۔ ہاتھ سے وَّاِنَّا لَمُوْسِعُوْنَ : اور بیشک ہم البتہ وسعت دینے والے ہیں آسمان کو ہم نے (اپنے) ہاتھوں سے بنایا (1) اور یقیناً ہم کشادگی کرنے والے ہیں (2)
51,48,وَ الْاَرْضَ فَرَشْنٰهَا فَنِعْمَ الْمٰهِدُوْنَ وَالْاَرْضَ : اور زمین کو فَرَشْنٰهَا : بچھایا ہم نے اس کو فَنِعْمَ الْمٰهِدُوْنَ : تو کتنے اچھے بچھانے والے ہیں۔ ہموار کرنے والے ہیں اور زمین کو ہم نے فرش بنادیا (1) پس ہم بہت ہی اچھے بچھانے والے ہیں۔
51,49,وَ مِنْ كُلِّ شَیْءٍ خَلَقْنَا زَوْجَیْنِ لَعَلَّكُمْ تَذَكَّرُوْنَ وَمِنْ كُلِّ شَيْءٍ : اور ہر چیز میں سے خَلَقْنَا : بنائے ہم نے زَوْجَيْنِ : جوڑے لَعَلَّكُمْ : تاکہ تم تَذَكَّرُوْنَ : تم نصیحت پکڑو ہر چیز کو ہم نے جوڑا جوڑا پیدا کیا ہے (1) تاکہ تم نصیحت حاصل کرو (2)
51,50,فَفِرُّوْۤا اِلَى اللّٰهِ١ؕ اِنِّیْ لَكُمْ مِّنْهُ نَذِیْرٌ مُّبِیْنٌۚ فَفِرُّوْٓا اِلَى : پس دوڑو طرف اللّٰهِ ۭ : اللہ کی اِنِّىْ لَكُمْ : بیشک میں تمہارے لیے مِّنْهُ : اس کی طرف سے نَذِيْرٌ : ڈرانے والا ہوں مُّبِيْنٌ : کھلم کھلا پس تم اللہ کی طرف دوڑ بھاگ (یعنی رجوع) کرو (1) یقیناً میں تمہیں اس کی طرف سے صاف صاف تنبیہ کرنے والا ہوں۔
51,51,وَ لَا تَجْعَلُوْا مَعَ اللّٰهِ اِلٰهًا اٰخَرَ١ؕ اِنِّیْ لَكُمْ مِّنْهُ نَذِیْرٌ مُّبِیْنٌۚ وَلَا تَجْعَلُوْا : اور نہ تم بناؤ مَعَ : ساتھ اللّٰهِ : اللہ کے اِلٰهًا اٰخَرَ ۭ : کوئی دوسرا الہ اِنِّىْ لَكُمْ : بیشک میں تمہارے لیے مِّنْهُ : اس کی طرف سے نَذِيْرٌ مُّبِيْنٌ : ڈرانے والا ہوں کھلم کھلا اور اللہ کے ساتھ کسی اور کو معبود نہ ٹھہراؤ بیشک میں تمہیں اس کی طرف سے کھلا ڈرانے والا ہوں۔ (1)
51,52,كَذٰلِكَ مَاۤ اَتَى الَّذِیْنَ مِنْ قَبْلِهِمْ مِّنْ رَّسُوْلٍ اِلَّا قَالُوْا سَاحِرٌ اَوْ مَجْنُوْنٌۚ كَذٰلِكَ : اسی طرح مَآ اَتَى الَّذِيْنَ : نہیں آیا ان لوگوں کے پاس مِنْ قَبْلِهِمْ : جو ان سے پہلے تھے مِّنْ رَّسُوْلٍ : کوئی رسول اِلَّا قَالُوْا : مگر انہوں نے کہا سَاحِرٌ : جادوگر اَوْ مَجْنُوْنٌ : یا مجنون اس طرح جو لوگ ان سے پہلے گزرے ہیں ان کے پاس جو بھی رسول آیا انہوں نے کہہ دیا کہ یا تو یہ جادوگر ہے یا دیوانہ ہے۔
51,53,اَتَوَاصَوْا بِهٖ١ۚ بَلْ هُمْ قَوْمٌ طَاغُوْنَۚ اَتَوَاصَوْا بِهٖ ۚ : کیا وہ ایک دوسرے کو اس کے س اتھ نصیحت کر گئے بَلْ هُمْ : بلکہ وہ قَوْمٌ طَاغُوْنَ : لوگ ہیں سرکش کیا یہ اس بات کی ایک دوسرے کو وصیت کرتے گئے ہیں (1)
51,54,فَتَوَلَّ عَنْهُمْ فَمَاۤ اَنْتَ بِمَلُوْمٍ٢ۗ٘ فَتَوَلَّ عَنْهُمْ : پس منہ موڑ لو ان سے فَمَآ اَنْتَ : پس نہیں آپ بِمَلُوْمٍ : جن پر ملامت کی جائے نہیں بلکہ یہ سب کے سب سرکش (1) ہیں تو آپ ان سے منہ پھیر لیں آپ پر کوئی ملامت نہیں۔
51,55,وَّ ذَكِّرْ فَاِنَّ الذِّكْرٰى تَنْفَعُ الْمُؤْمِنِیْنَ وَّذَكِّرْ : اور نصیحت کیجیے فَاِنَّ الذِّكْرٰى : پس بیشک نصیحت تَنْفَعُ الْمُؤْمِنِيْنَ : فائدہ دیتی ہے مومنوں کو اور نصیحت کرتے رہیں یقیناً یہ نصیحت ایمانداروں کو نفع دے گی۔ (1)
51,56,وَ مَا خَلَقْتُ الْجِنَّ وَ الْاِنْسَ اِلَّا لِیَعْبُدُوْنِ وَمَا : اور نہیں خَلَقْتُ الْجِنَّ : پیدا کیا میں نے جنوں کو وَالْاِنْسَ : اور انسانوں کو اِلَّا : مگر لِيَعْبُدُوْنِ : اس لیے تاکہ وہ میری عبادت کریں میں نے جنات اور انسانوں کو محض اس لئے پیدا کیا ہے کہ وہ صرف میری عبادت کریں۔ (1)
51,57,مَاۤ اُرِیْدُ مِنْهُمْ مِّنْ رِّزْقٍ وَّ مَاۤ اُرِیْدُ اَنْ یُّطْعِمُوْنِ مَآ اُرِيْدُ : نہیں میں چاہتا مِنْهُمْ : ان سے مِّنْ رِّزْقٍ : کوئی رزق وَّمَآ اُرِيْدُ : اور نہیں میں چاہتا اَنْ : کہ يُّطْعِمُوْنِ : وہ کھلائیں مجھ کو نہ میں ان سے روزی چاہتا ہوں اور نہ میری یہ چاہت ہے کہ مجھے کھلائیں (1)
51,58,اِنَّ اللّٰهَ هُوَ الرَّزَّاقُ ذُو الْقُوَّةِ الْمَتِیْنُ اِنَّ اللّٰهَ : بیشک اللہ تعالیٰ هُوَ الرَّزَّاقُ : وہی رزاق ہے ذُو الْقُوَّةِ : قوت والا ہے الْمَتِيْنُ : زبردست ہے اللہ تعالیٰ تو خود ہی سب کا روزی رساں توانائی والا اور زور آور ہے۔
51,59,فَاِنَّ لِلَّذِیْنَ ظَلَمُوْا ذَنُوْبًا مِّثْلَ ذَنُوْبِ اَصْحٰبِهِمْ فَلَا یَسْتَعْجِلُوْنِ فَاِنَّ لِلَّذِيْنَ : تو بیشک ان لوگوں کے لیے ظَلَمُوْا : جنہوں نے ظلم کیا ذَنُوْبًا مِّثْلَ : حصہ ہے، مانند ذَنُوْبِ : حصے کے اَصْحٰبِهِمْ : ان کے ساتھیوں کے فَلَا يَسْتَعْجِلُوْنِ : پس نہ وہ جلدی کریں مجھ سے پس جن لوگوں نے ظلم کیا ہے انہیں بھی ان کے ساتھیوں کے حصہ کے مثل حصہ ملے گا (1) لہذا وہ مجھ سے جلدی طلب نہ کریں (2)
51,60,فَوَیْلٌ لِّلَّذِیْنَ كَفَرُوْا مِنْ یَّوْمِهِمُ الَّذِیْ یُوْعَدُوْنَ۠    ۧ فَوَيْلٌ : پس ہلاکت ہے لِّلَّذِيْنَ كَفَرُوْا : ان لوگوں کے لیے جنہوں نے کفر کیا مِنْ يَّوْمِهِمُ : ان کے اس دن سے الَّذِيْ : وہ جو يُوْعَدُوْنَ : وہ وعدہ کیے جاتے ہیں پس خرابی ہے منکروں کو ان کے اس دن کی جس کا وعدہ دیئے جاتے ہیں۔
