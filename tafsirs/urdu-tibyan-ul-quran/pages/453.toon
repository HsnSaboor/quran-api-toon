tafsir[16]{c,v,t}:
  38,1,صٓ وَ الْقُرْاٰنِ ذِی الذِّكْرِؕ صٓ : صاد وَالْقُرْاٰنِ : قرآن کی قسم ذِي الذِّكْرِ : نصیحت دینے والے ص ! اس نصیحت والے قرآن کی قسم (1)
  38,2,بَلِ الَّذِیْنَ كَفَرُوْا فِیْ عِزَّةٍ وَّ شِقَاقٍ بَلِ : بلکہ الَّذِيْنَ كَفَرُوْا : جن لوگوں نے کفر کیا (کافر) فِيْ عِزَّةٍ : گھمنڈ میں وَّشِقَاقٍ : اور مخالفت بلکہ کفار غرور و مخالفت میں پڑے ہوئے ہیں (1)۔
  38,3,كَمْ اَهْلَكْنَا مِنْ قَبْلِهِمْ مِّنْ قَرْنٍ فَنَادَوْا وَّ لَاتَ حِیْنَ مَنَاصٍ كَمْ : کتنی ہی اَهْلَكْنَا : ہم نے ہلاک کردیں مِنْ قَبْلِهِمْ : ان سے قبل مِّنْ قَرْنٍ : امتیں فَنَادَوْا : تو وہ فریاد کرنے لگے وَّلَاتَ : اور نہ تھا حِيْنَ : وقت مَنَاصٍ : چھٹکارا ہم نے ان سے پہلے بھی بہت سی امتوں کو تباہ کر ڈالا (1) انہوں نے ہرچند چیخ پکار کی لیکن وہ وقت چھٹکارے کا نہ تھا۔
  38,4,وَ عَجِبُوْۤا اَنْ جَآءَهُمْ مُّنْذِرٌ مِّنْهُمْ١٘ وَ قَالَ الْكٰفِرُوْنَ هٰذَا سٰحِرٌ كَذَّابٌۖۚ وَعَجِبُوْٓا : اور انہوں نے تعجب کیا اَنْ : کہ جَآءَهُمْ : ان کے پاس آیا مُّنْذِرٌ : ایک ڈرانے والا مِّنْهُمْ ۡ : ان میں سے وَقَالَ : اور کہا الْكٰفِرُوْنَ : (جمع) کافر ھٰذَا سٰحِرٌ : یہ جادوگر كَذَّابٌ : جھوٹا اور کافروں کو اس بات پر تعجب ہوا کہ ان ہی میں سے ایک انہیں ڈرانے والا آگیا (1) اور کہنے لگے کہ یہ تو جادوگر اور جھوٹا ہے۔
  38,5,اَجَعَلَ الْاٰلِهَةَ اِلٰهًا وَّاحِدًا١ۖۚ اِنَّ هٰذَا لَشَیْءٌ عُجَابٌ اَجَعَلَ : کیا اس نے بنادیا الْاٰلِهَةَ : (جمع) معبود اِلٰهًا : معبود وَّاحِدًا ښ : ایک اِنَّ ھٰذَا : بیشک یہ لَشَيْءٌ : ایک شے (بات) عُجَابٌ : بڑی عجیب کیا اس نے اتنے سارے معبودوں کا ایک ہی معبود کردیا واقعی یہ بہت ہی عجیب بات ہے (1)
  38,6,وَ انْطَلَقَ الْمَلَاُ مِنْهُمْ اَنِ امْشُوْا وَ اصْبِرُوْا عَلٰۤى اٰلِهَتِكُمْ١ۖۚ اِنَّ هٰذَا لَشَیْءٌ یُّرَادُۖۚ وَانْطَلَقَ : اور چل پڑے الْمَلَاُ : سردار مِنْهُمْ : ان کے اَنِ : کہ امْشُوْا : چلو وَاصْبِرُوْا : اور جمے رہو عَلٰٓي اٰلِهَتِكُمْ ښ : اپنے معبودوں پر اِنَّ ھٰذَا : بیشک یہ لَشَيْءٌ : کوئی شے (بات) يُّرَادُ : ارادہ کی ہوئی (مطلب کی) ان کے سردار یہ کہتے ہوئے چلے کہ چلو جی اور اپنے معبودوں پر جمے رہو (1) یقیناً اس بات میں تو کوئی غرض ہے (2)
  38,7,مَا سَمِعْنَا بِهٰذَا فِی الْمِلَّةِ الْاٰخِرَةِ١ۖۚ اِنْ هٰذَاۤ اِلَّا اخْتِلَاقٌۖۚ مَا سَمِعْنَا : ہم نے نہیں سنا بِھٰذَا : ایسی فِي : میں الْمِلَّةِ : مذہب الْاٰخِرَةِ ښ : پچھلا اِنْ : نہیں ھٰذَآ : یہ اِلَّا : مگر۔ محض اخْتِلَاقٌ : من گھڑت ہم نے تو یہ بات پچھلے دین میں بھی نہیں سنی (1) کچھ نہیں یہ تو صرف گھڑنت ہے (2)
  38,8,ءَاُنْزِلَ عَلَیْهِ الذِّكْرُ مِنْۢ بَیْنِنَا١ؕ بَلْ هُمْ فِیْ شَكٍّ مِّنْ ذِكْرِیْ١ۚ بَلْ لَّمَّا یَذُوْقُوْا عَذَابِؕ ءَاُنْزِلَ : کیا نازل کیا گیا عَلَيْهِ : اس پر الذِّكْرُ : ذکر (کلام) مِنْۢ بَيْنِنَا ۭ : ہم میں سے بَلْ : بلکہ هُمْ : وہ فِيْ شَكٍّ : شک میں مِّنْ ذِكْرِيْ ۚ : میری نصیحت سے بَلْ : بلکہ لَّمَّا : نہیں يَذُوْقُوْا : چکھا انہوں نے عَذَابِ : میرا عذاب کیا ہم سب میں سے اسی پر کلام الٰہی کیا گیا ہے ؟ (1) دراصل یہ لوگ میری وحی کی طرف سے شک میں ہیں (2) بلکہ (صحیح یہ ہے کہ) انہوں نے اب تک میرا عذاب چکھا ہی نہیں۔
  38,9,اَمْ عِنْدَهُمْ خَزَآئِنُ رَحْمَةِ رَبِّكَ الْعَزِیْزِ الْوَهَّابِۚ اَمْ : کیا عِنْدَهُمْ : ان کے پاس خَزَآئِنُ : خزانے رَحْمَةِ رَبِّكَ : تمہارے رب کی رحمت الْعَزِيْزِ : غالب الْوَهَّابِ : بہت عطا کرنے والا یا کیا ان کے پاس تیرے زبردست فیاض رب کی رحمت کے خزانے ہیں (1)
  38,10,اَمْ لَهُمْ مُّلْكُ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا١۫ فَلْیَرْتَقُوْا فِی الْاَسْبَابِ اَمْ لَهُمْ : کیا ان کے لیے مُّلْكُ السَّمٰوٰتِ : بادشاہت آسمانوں وَالْاَرْضِ : اور زمین وَمَا بَيْنَهُمَا ۣ : اور جو ان دونوں کے درمیان فَلْيَرْتَقُوْا : تو وہ چڑھ جائیں فِي الْاَسْبَابِ : رسیوں میں (رسیاں تان کر) یا کیا آسمان و زمین اور ان کے درمیان کی ہر چیز کی بادشاہت ان ہی کی ہے، تو پھر رسیاں تان کر چڑھ جائیں (1)
  38,11,جُنْدٌ مَّا هُنَالِكَ مَهْزُوْمٌ مِّنَ الْاَحْزَابِ جُنْدٌ : ایک لشکر مَّا : جو هُنَالِكَ : یہاں مَهْزُوْمٌ : شکست خوردہ مِّنَ الْاَحْزَابِ : گروہوں میں سے یہ بھی (بڑے بڑے) لشکروں میں سے شکست پایا ہوا (چھوٹا سا) لشکر ہے (1)
  38,12,كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوْحٍ وَّ عَادٌ وَّ فِرْعَوْنُ ذُو الْاَوْتَادِۙ كَذَّبَتْ : جھٹلایا قَبْلَهُمْ : ان سے پہلے قَوْمُ : قوم نُوْحٍ : نوح وَّعَادٌ : اور عاد وَّفِرْعَوْنُ : اور فرعون ذُوالْاَوْتَادِ : میخوں والا ان سے پہلے بھی قوم نوح اور عاد اور میخوں والے فرعون (1) نے جھٹلایا تھا۔
  38,13,وَ ثَمُوْدُ وَ قَوْمُ لُوْطٍ وَّ اَصْحٰبُ لْئَیْكَةِ١ؕ اُولٰٓئِكَ الْاَحْزَابُ ثَمُوْدُ : اور ثمود وَقَوْمُ لُوْطٍ : اور قوم لوط وَّاَصْحٰبُ لْئَيْكَةِ ۭ : اور ایکہ والے اُولٰٓئِكَ : یہی وہ الْاَحْزَابُ : گروہ اور ثمود نے اور قوم لوط نے اور أیکہ کے رہنے والوں نے بھی یہی (بڑے) تھے (1)
  38,14,اِنْ كُلٌّ اِلَّا كَذَّبَ الرُّسُلَ فَحَقَّ عِقَابِ۠    ۧ اِنْ : نہیں كُلٌّ : سب اِلَّا : مگر كَذَّبَ : جھٹلایا الرُّسُلَ : رسولوں فَحَقَّ : پس آپڑا عِقَابِ : عذاب ان میں سے ایک بھی ایسا نہ تھا جس نے رسولوں کو نہیں جھٹلایا پس میری سزا ان پر ثابت ہوگئی۔
  38,15,وَ مَا یَنْظُرُ هٰۤؤُلَآءِ اِلَّا صَیْحَةً وَّاحِدَةً مَّا لَهَا مِنْ فَوَاقٍ وَمَا يَنْظُرُ : اور وہ انتظار نہیں کرتے هٰٓؤُلَآءِ : یہ لوگ اِلَّا : مگر صَيْحَةً : چنگھاڑ وَّاحِدَةً : ایک مَّا لَهَا : جس کے لیے نہیں مِنْ : کوئی فَوَاقٍ : ڈھیل انہیں صرف ایک چیخ کا انتظار (1) ہے جس میں کوئی توقف (اور ڈھیل) نہیں ہے (2)
  38,16,وَ قَالُوْا رَبَّنَا عَجِّلْ لَّنَا قِطَّنَا قَبْلَ یَوْمِ الْحِسَابِ وَقَالُوْا : اور انہوں نے کہا رَبَّنَا : اے ہمارے رب عَجِّلْ : جلدی دے لَّنَا : ہمیں قِطَّنَا : ہمارا حصہ قَبْلَ : پہلے يَوْمِ الْحِسَابِ : روز حساب اور انہوں نے کہا کہ اے ہمارے رب ! ہماری سر نوشت تو ہمیں روز حساب سے پہلے ہی دے دے (1)
