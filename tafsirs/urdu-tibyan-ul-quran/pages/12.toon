quran[111]{c,v,t}:
12,1,الٓرٰ١۫ تِلْكَ اٰیٰتُ الْكِتٰبِ الْمُبِیْنِ۫ الٓرٰ : الف لام را تِلْكَ : یہ اٰيٰتُ : آیتیں الْكِتٰبِ : کتاب الْمُبِيْنِ : روشن یہ روشن کتاب کی آیتیں ہیں۔
12,2,اِنَّاۤ اَنْزَلْنٰهُ قُرْءٰنًا عَرَبِیًّا لَّعَلَّكُمْ تَعْقِلُوْنَ اِنَّآ : بیشک ہم نے اَنْزَلْنٰهُ : اسے نازل کیا قُرْءٰنًا : قرآن عَرَبِيًّا : عربی لَّعَلَّكُمْ : تاکہ تم تَعْقِلُوْنَ : سمجھو یقیناً ہم نے اس قرآن کو عربی زبان میں نازل فرمایا ہے کہ تم سمجھ سکو (1)
12,3,نَحْنُ نَقُصُّ عَلَیْكَ اَحْسَنَ الْقَصَصِ بِمَاۤ اَوْحَیْنَاۤ اِلَیْكَ هٰذَا الْقُرْاٰنَ١ۖۗ وَ اِنْ كُنْتَ مِنْ قَبْلِهٖ لَمِنَ الْغٰفِلِیْنَ نَحْنُ : ہم نَقُصُّ : بیان کرتے ہیں عَلَيْكَ : تم پر اَحْسَنَ : بہت اچھا الْقَصَصِ : قصہ بِمَآ : اس لیے کہ اَوْحَيْنَآ : ہم نے بھیجا اِلَيْكَ : تمہاری طرف ھٰذَا : یہ الْقُرْاٰنَ : قرآن وَاِنْ : اور تحقیق كُنْتَ : تو تھا مِنْ قَبْلِهٖ : اس سے قبل لَمِنَ : البتہ۔ سے الْغٰفِلِيْنَ : بیخبر (جمع) ہم آپ کے سامنے بہترین بیان (1) پیش کرتے ہیں اس وجہ سے کہ ہم نے آپ کی جانب یہ قرآن وحی کے ذریعے نازل کیا اور یقیناً آپ اس سے پہلے بیخبروں میں تھے (2)۔
12,4,اِذْ قَالَ یُوْسُفُ لِاَبِیْهِ یٰۤاَبَتِ اِنِّیْ رَاَیْتُ اَحَدَ عَشَرَ كَوْكَبًا وَّ الشَّمْسَ وَ الْقَمَرَ رَاَیْتُهُمْ لِیْ سٰجِدِیْنَ اِذْ : جب قَالَ : کہا يُوْسُفُ : یوسف لِاَبِيْهِ : اپنے باپ سے يٰٓاَبَتِ : اے میرے باپ اِنِّىْ : بیشک میں رَاَيْتُ : میں نے دیکھا اَحَدَ عَشَرَ : گیا رہ كَوْكَبًا : ستارے وَّالشَّمْسَ : اور سورج وَالْقَمَرَ : اور چاند رَاَيْتُهُمْ : میں نے انہیں دیکھا لِيْ : اپنے لیے سٰجِدِيْنَ : سجدہ کرتے جب کہ یوسف (1) نے اپنے باپ سے ذکر کیا کہ ابا جان میں نے گیارہ ستاروں کو اور سورج چاند کو (2) دیکھا کہ وہ سب مجھے سجدہ کر رہے ہیں۔
12,5,قَالَ یٰبُنَیَّ لَا تَقْصُصْ رُءْیَاكَ عَلٰۤى اِخْوَتِكَ فَیَكِیْدُوْا لَكَ كَیْدًا١ؕ اِنَّ الشَّیْطٰنَ لِلْاِنْسَانِ عَدُوٌّ مُّبِیْنٌ قَالَ : اس نے کہا يٰبُنَيَّ : اے میرے بیٹے لَا تَقْصُصْ : نہ بیان کرنا رُءْيَاكَ : اپنا خواب عَلٰٓي : پر (سے) اِخْوَتِكَ : اپنے بھائی فَيَكِيْدُوْا : وہ چال چلیں گے لَكَ : تیرے لیے كَيْدًا : کوئی چال اِنَّ : بیشک الشَّيْطٰنَ : شیطان لِلْاِنْسَانِ : انسان کے لیے (کا) عَدُوٌّ : دشمن مُّبِيْنٌ : کھلا یعقوب نے کہا پیارے بچے ! اپنے اس خواب کا ذکر اپنے بھائیوں سے نہ کرنا۔ ایسا نہ ہو کہ وہ تیرے ساتھ کوئی فریب کاری کریں (1) شیطان تو انسان کا کھلا دشمن ہے (2)۔
12,6,وَ كَذٰلِكَ یَجْتَبِیْكَ رَبُّكَ وَ یُعَلِّمُكَ مِنْ تَاْوِیْلِ الْاَحَادِیْثِ وَ یُتِمُّ نِعْمَتَهٗ عَلَیْكَ وَ عَلٰۤى اٰلِ یَعْقُوْبَ كَمَاۤ اَتَمَّهَا عَلٰۤى اَبَوَیْكَ مِنْ قَبْلُ اِبْرٰهِیْمَ وَ اِسْحٰقَ١ؕ اِنَّ رَبَّكَ عَلِیْمٌ حَكِیْمٌ۠    ۧ وَكَذٰلِكَ : اور اسی طرح يَجْتَبِيْكَ : چن لے گا تجھے رَبُّكَ : تیرا رب وَيُعَلِّمُكَ : اور سکھائے گا تجھے مِنْ : سے تَاْوِيْلِ : انجام نکالنا الْاَحَادِيْثِ : باتیں وَيُتِمُّ : اور مکمل کرے گا نِعْمَتَهٗ : اپنی نعمت عَلَيْكَ : تجھ پر وَ : اور عَلٰٓي : پر اٰلِ يَعْقُوْبَ : یعقوب کے گھر والے كَمَآ : جیسے اَتَمَّهَا : اس نے اسے پورا کیا عَلٰٓي : پر اَبَوَيْكَ : تیرے باپ دادا مِنْ قَبْلُ : اس سے پہلے اِبْرٰهِيْمَ : ابراہیم وَاِسْحٰقَ : اور اسحق اِنَّ : بیشک رَبَّكَ : تیرا رب عَلِيْمٌ : علم والا حَكِيْمٌ : حکمت والا اور اسی طرح تجھے (1) تیرا پروردگار برگزیدہ کرے گا اور تجھے معاملہ فہمی (یا خوابوں کی تعبیر) بھی سکھائے گا اور اپنی نعمت تجھے بھرپور عطا فرمائے گا (2) اور یعقوب کے گھر والوں کو بھی (3) جیسے کہ اس نے پہلے تیرے دادا پردادا یعنی ابراہیم و اسحاق کو بھی بھرپور اپنی رحمت دی، یقیناً تیرا رب بہت بڑے علم والا اور زبردست حکمت والا ہے۔
12,7,لَقَدْ كَانَ فِیْ یُوْسُفَ وَ اِخْوَتِهٖۤ اٰیٰتٌ لِّلسَّآئِلِیْنَ لَقَدْ كَانَ : بیشک میں فِيْ : میں يُوْسُفَ : یوسف وَاِخْوَتِهٖٓ : اور اس کے بھائی اٰيٰتٌ : نشانیاں لِّلسَّآئِلِيْنَ : پوچھنے والوں کے لیے یقیناً یوسف اور اس کے بھائیوں میں دریافت کرنے والوں کے لئے (بڑی) نشانیاں (1) ہیں۔
12,8,اِذْ قَالُوْا لَیُوْسُفُ وَ اَخُوْهُ اَحَبُّ اِلٰۤى اَبِیْنَا مِنَّا وَ نَحْنُ عُصْبَةٌ١ؕ اِنَّ اَبَانَا لَفِیْ ضَلٰلٍ مُّبِیْنِۚۖ اِذْ : جب قَالُوْا : انہوں نے کہا لَيُوْسُفُ : ضرور یوسف وَاَخُوْهُ : اور اس کا بھائی اَحَبُّ : زیادہ پیارا اِلٰٓي : طرف (کو) اَبِيْنَا : ہمارا باپ مِنَّا : ہم سے وَنَحْنُ : جبکہ ہم عُصْبَةٌ : ایک جماعت اِنَّ : بیشک اَبَانَا : ہمارے باپ لَفِيْ ضَلٰلٍ : البتہ غلطی میں مُّبِيْنِ : صریح جب کہ انہوں نے کہا کہ یوسف اور اس کا بھائی (1) بہ نسبت ہمارے، باپ کو بہت زیادہ پیارے ہیں حالانکہ ہم (طاقتور) جماعت (2) ہیں، کوئی شک نہیں کہ ہمارے ابا صریح غلطی میں ہیں۔
12,9,اِ۟قْتُلُوْا یُوْسُفَ اَوِ اطْرَحُوْهُ اَرْضًا یَّخْلُ لَكُمْ وَجْهُ اَبِیْكُمْ وَ تَكُوْنُوْا مِنْۢ بَعْدِهٖ قَوْمًا صٰلِحِیْنَ اقْتُلُوْا : مار ڈالو يُوْسُفَ : یوسف اَوِ : یا اطْرَحُوْهُ : اسے ڈال آؤ اَرْضًا : کسی سرزمین يَّخْلُ : خالی ہوجائے لَكُمْ : تمہارے لیے وَجْهُ : منہ (توجہ) اَبِيْكُمْ : تمہارے باپ وَتَكُوْنُوْا : اور تم ہوجاؤ مِنْ : سے بَعْدِهٖ : اس کے بعد قَوْمًا : لوگ صٰلِحِيْنَ : نیک (جمع) یوسف کو مار ہی ڈالو اسے کسی (نامعلوم) جگہ پھینک دو کہ تمہارے والد کا رخ صرف تمہاری طرف ہی ہوجائے۔ اس کے بعد تم نیک ہوجانا (1)۔
12,10,قَالَ قَآئِلٌ مِّنْهُمْ لَا تَقْتُلُوْا یُوْسُفَ وَ اَلْقُوْهُ فِیْ غَیٰبَتِ الْجُبِّ یَلْتَقِطْهُ بَعْضُ السَّیَّارَةِ اِنْ كُنْتُمْ فٰعِلِیْنَ قَالَ : کہا قَآئِلٌ : ایک کہنے والا مِّنْهُمْ : ان سے لَا تَقْتُلُوْا : نہ قتل کرو يُوْسُفَ : یوسف وَاَلْقُوْهُ : اور اسے ڈال آؤ فِيْ : میں غَيٰبَتِ : اندھا (گہرا) الْجُبِّ : کنواں يَلْتَقِطْهُ : اٹھالے اس کو بَعْضُ : کوئی السَّيَّارَةِ : چلتا (مسافر) اِنْ : اگر كُنْتُمْ فٰعِلِيْنَ : تم کرنیوالے ہو (کرنا ہی ہے) ان میں سے ایک نے کہا یوسف کو قتل نہ کرو بلکہ اسے کسی اندھے کنوئیں (کی تہ) میں ڈال آؤ کہ (1) اسے کوئی (آتا جاتا) قافلہ اٹھا لے جائے اگر تمہیں کرنا ہی ہے تو یوں کرو (2)۔
12,11,قَالُوْا یٰۤاَبَانَا مَا لَكَ لَا تَاْمَنَّا عَلٰى یُوْسُفَ وَ اِنَّا لَهٗ لَنٰصِحُوْنَ قَالُوْا : کہنے لگے يٰٓاَبَانَا : اے ہمارے آبا مَالَكَ : کیا ہوا تجھے لَا تَاْمَنَّا : تو ہمارا اعتبار نہیں کرتا عَلٰي : پر (بارہ میں) يُوْسُفَ : یوسف وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَنٰصِحُوْنَ : البتہ خیر خواہ انہوں نے کہا ابا ! آخر آپ یوسف ؑ کے بارے میں ہم پر اعتبار کیوں نہیں کرتے ہم تو اس کے خیر خواہ ہیں (1)۔
12,12,اَرْسِلْهُ مَعَنَا غَدًا یَّرْتَعْ وَ یَلْعَبْ وَ اِنَّا لَهٗ لَحٰفِظُوْنَ اَرْسِلْهُ : اسے بھیجدے مَعَنَا : ہمارے ساتھ غَدًا : کل يَّرْتَعْ : وہ کھائے وَيَلْعَبْ : اور کھیلے کودے وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَحٰفِظُوْنَ : البتہ محافظ کل آپ اسے ضرور ہمارے ساتھ بھیج دیجئے کہ خوب کھائے پیئے اور کھیلے (1) اس کی حفاظت کے ہم ذمہ دار ہیں۔
12,13,قَالَ اِنِّیْ لَیَحْزُنُنِیْۤ اَنْ تَذْهَبُوْا بِهٖ وَ اَخَافُ اَنْ یَّاْكُلَهُ الذِّئْبُ وَ اَنْتُمْ عَنْهُ غٰفِلُوْنَ قَالَ : اس نے کہا اِنِّىْ : بیشک مجھے لَيَحْزُنُنِيْٓ : غمگین کرتا ہے اَنْ : کہ تَذْهَبُوْا : تم لے جاؤ بِهٖ : اسے وَاَخَافُ : اور میں ڈرتا ہوں اَنْ : کہ يَّاْكُلَهُ : اسے کھاجائے الذِّئْبُ : بھیڑیا وَاَنْتُمْ : اور تم عَنْهُ : اس سے غٰفِلُوْنَ : بیخبر (جمع) (یعقوب ؑ نے کہا) اسے تمہارا لے جانا مجھے تو سخت صدمہ دے گا اور مجھے یہ بھی کھٹکا لگا رہے گا کہ تمہاری غفلت میں اس بھیڑیا کھاجائے۔
12,14,قَالُوْا لَئِنْ اَكَلَهُ الذِّئْبُ وَ نَحْنُ عُصْبَةٌ اِنَّاۤ اِذًا لَّخٰسِرُوْنَ قَالُوْا : وہ بولے لَئِنْ : اگر اَكَلَهُ : اسے کھاجائے الذِّئْبُ : بھیڑیا وَنَحْنُ : اور ہم عُصْبَةٌ : ایک جماعت اِنَّآ : بیشک ہم اِذًا : اس صورت میں لَّخٰسِرُوْنَ : زیاں کار انہوں نے جواب دیا کہ ہم جیسی (زور آور) جماعت کی موجودگی میں بھی اگر اسے بھیڑیا کھاجائے تو ہم بالکل نکمے ہی (1) ہوئے۔
12,15,فَلَمَّا ذَهَبُوْا بِهٖ وَ اَجْمَعُوْۤا اَنْ یَّجْعَلُوْهُ فِیْ غَیٰبَتِ الْجُبِّ١ۚ وَ اَوْحَیْنَاۤ اِلَیْهِ لَتُنَبِّئَنَّهُمْ بِاَمْرِهِمْ هٰذَا وَ هُمْ لَا یَشْعُرُوْنَ فَلَمَّا : پھر جب ذَهَبُوْا : وہ لے گئے بِهٖ : اس کو وَاَجْمَعُوْٓا : اور انہوں نے اتفاق کرلیا اَنْ : کہ يَّجْعَلُوْهُ : اسے ڈال دیں فِيْ : میں غَيٰبَتِ : اندھا الْجُبِّ : کنواں وَاَوْحَيْنَآ : اور ہم نے وحی بھیجی اِلَيْهِ : اس کی طرف لَتُنَبِّئَنَّهُمْ : کہ تو انہیں ضرور جتائے گا بِاَمْرِهِمْ : ان کا کام ھٰذَا : اس وَهُمْ : اور وہ لَا يَشْعُرُوْنَ : نہ جانتے ہوں گے پھر جب اسے لے چلے اور سب نے ملکر ٹھان لیا اسے غیر آباد گہرے کنوئیں کی تہ میں پھینک دیں، ہم نے یوسف ؑ کی طرف وحی کی کہ یقیناً (وقت آرہا ہے کہ) تو انھیں اس ماجرا کی خبر اس حال میں دے گا کہ وہ جانتے ہی نہ ہوں (1)
12,16,وَ جَآءُوْۤ اَبَاهُمْ عِشَآءً یَّبْكُوْنَؕ وَجَآءُوْٓا : اور وہ آئے اَبَاهُمْ : اپنے باپ کے پاس عِشَآءً : اندھیرا پڑے يَّبْكُوْنَ : روتے ہوئے اور عشاء کے وقت (وہ سب) اپنے باپ کے پاس روتے ہوئے پہنچے۔
12,17,قَالُوْا یٰۤاَبَانَاۤ اِنَّا ذَهَبْنَا نَسْتَبِقُ وَ تَرَكْنَا یُوْسُفَ عِنْدَ مَتَاعِنَا فَاَكَلَهُ الذِّئْبُ١ۚ وَ مَاۤ اَنْتَ بِمُؤْمِنٍ لَّنَا وَ لَوْ كُنَّا صٰدِقِیْنَ قَالُوْا : وہ بولے يٰٓاَبَانَآ : اے ابا جان اِنَّا : ہم ذَهَبْنَا : دوڑنے گئے نَسْتَبِقُ : آگے نکلنے وَتَرَكْنَا : اور ہم نے چھوڑ دیا يُوْسُفَ : یوسف عِنْدَ : پاس مَتَاعِنَا : اپنا اسباب فَاَكَلَهُ : تو اسے کھا گیا الذِّئْبُ : بھیڑیا وَمَآ : اور نہیں اَنْتَ : تو بِمُؤْمِنٍ : باور کرنے والا لَّنَا : ہم پر وَلَوْ كُنَّا : اور خواہ ہوں ہم صٰدِقِيْنَ : سچے اور کہنے لگے ابا جان ہم تو آپس میں دوڑ میں لگ گئے اور یوسف ؑ کو ہم نے اسباب کے پاس چھوڑا تھا پس اسے بھیڑیا کھا گیا، آپ تو ہماری بات نہٰ مانیں گے، گو ہم بالکل سچے ہی ہوں (1)
12,18,وَ جَآءُوْ عَلٰى قَمِیْصِهٖ بِدَمٍ كَذِبٍ١ؕ قَالَ بَلْ سَوَّلَتْ لَكُمْ اَنْفُسُكُمْ اَمْرًا١ؕ فَصَبْرٌ جَمِیْلٌ١ؕ وَ اللّٰهُ الْمُسْتَعَانُ عَلٰى مَا تَصِفُوْنَ وَجَآءُوْ : اور وہ آئے (لائے) عَلٰي : پر قَمِيْصِهٖ : اس کی قمیص بِدَمٍ : خون کے ساتھ كَذِبٍ : جھوٹا قَالَ : اس نے کہا بَلْ : بلکہ سَوَّلَتْ : بنا لی لَكُمْ : تمہارے لیے اَنْفُسُكُمْ : تمہارے دل اَمْرًا : ایک کام فَصَبْرٌ : پس صبر جَمِيْلٌ : اچھا وَاللّٰهُ : اور اللہ الْمُسْتَعَانُ : مدد چاہتا ہوں عَلٰي : پر مَا تَصِفُوْنَ : جو تم بیان کرتے ہو اور یوسف کے کرتے کو جھوٹ موٹ کے خون سے خون آلود بھی کر لائے تھے، باپ نے کہا یوں نہیں، بلکہ تم نے اپنے دل ہی میں سے ایک بات بنالی ہے۔ پس صبر ہی بہتر ہے، اور تمہاری بنائی ہوئی باتوں پر اللہ ہی سے مدد کی طلب ہے۔
12,19,وَ جَآءَتْ سَیَّارَةٌ فَاَرْسَلُوْا وَارِدَهُمْ فَاَدْلٰى دَلْوَهٗ١ؕ قَالَ یٰبُشْرٰى هٰذَا غُلٰمٌ١ؕ وَ اَسَرُّوْهُ بِضَاعَةً١ؕ وَ اللّٰهُ عَلِیْمٌۢ بِمَا یَعْمَلُوْنَ وَجَآءَتْ : اور آیا سَيَّارَةٌ : ایک قافلہ فَاَرْسَلُوْا : پس انہوں نے بھیجا وَارِدَهُمْ : اپنا پانی بھرنے والا فَاَدْلٰى : پس اس نے ڈالا دَلْوَهٗ : اپنا ڈول قَالَ : اس نے کہا يٰبُشْرٰي : آہا۔ خوشی کی بات ھٰذَا : یہ غُلٰمٌ : ایک لڑکا وَاَسَرُّوْهُ : اور اسے چھپالیا بِضَاعَةً : مال تجارت سمجھ کر وَاللّٰهُ : اور اللہ عَلِيْمٌ : جاننے والا بِمَا : اسے جو يَعْمَلُوْنَ : وہ کرتے تھے اور ایک قافلہ آیا اور انہوں نے اپنے پانی لانے والے کو بھیجا اس نے اپنا ڈول لٹکا دیا، کہنے لگا واہ واہ خوشی کی بات ہے یہ تو ایک لڑکا ہے (1) انہوں نے اسے مال تجارت قرار دے کر چھپالیا (2) اور اللہ تعالیٰ اس سے باخبر تھا جو وہ کر رہے تھے۔
12,20,وَ شَرَوْهُ بِثَمَنٍۭ بَخْسٍ دَرَاهِمَ مَعْدُوْدَةٍ١ۚ وَ كَانُوْا فِیْهِ مِنَ الزَّاهِدِیْنَ۠    ۧ وَشَرَوْهُ : اور انہوں نے اسے بیچ دیا بِثَمَنٍ : دام بَخْسٍ : کھوٹے دَرَاهِمَ : درہم مَعْدُوْدَةٍ : گنتی کے وَكَانُوْا : اور وہ تھے فِيْهِ : اس میں مِنَ : سے الزَّاهِدِيْنَ : بےرغبت، بےزار انہوں نے (1) اسے بہت ہی ہلکی قیمت پر گنتی کے چند درہموں پر بیچ ڈالا، وہ تو یوسف کے بارے میں بہت ہی بےرغبت تھے (2)
12,21,وَ قَالَ الَّذِی اشْتَرٰىهُ مِنْ مِّصْرَ لِامْرَاَتِهٖۤ اَكْرِمِیْ مَثْوٰىهُ عَسٰۤى اَنْ یَّنْفَعَنَاۤ اَوْ نَتَّخِذَهٗ وَلَدًا١ؕ وَ كَذٰلِكَ مَكَّنَّا لِیُوْسُفَ فِی الْاَرْضِ١٘ وَ لِنُعَلِّمَهٗ مِنْ تَاْوِیْلِ الْاَحَادِیْثِ١ؕ وَ اللّٰهُ غَالِبٌ عَلٰۤى اَمْرِهٖ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ وَقَالَ : اور بولا الَّذِي : وہ جو، جس اشْتَرٰىهُ : اسے خریدا مِنْ : سے مِّصْرَ : مصر لِامْرَاَتِهٖٓ : اپنی عورت کو اَكْرِمِيْ مَثْوٰىهُ : اسے عزت و اکرام سے رکھ عَسٰٓى : شاید اَنْ : کہ يَّنْفَعَنَآ : ہم کو نفع پہنچائے اَوْ : یا نَتَّخِذَهٗ : ہم اسے بنالیں وَلَدًا : بیٹا وَكَذٰلِكَ : اور اس طرح مَكَّنَّا : ہم نے جگہ دی لِيُوْسُفَ : یوسف کو فِي : میں الْاَرْضِ : زمین (ملک) وَلِنُعَلِّمَهٗ : اور تاکہ ہم اسے سکھائیں مِنْ : سے تَاْوِيْلِ : انجام نکالنا الْاَحَادِيْثِ : باتیں وَاللّٰهُ : اور اللہ غَالِبٌ : غالب عَلٰٓي اَمْرِهٖ : اپنے کام پر وَلٰكِنَّ : اور لیکن اَكْثَرَ : اکثر النَّاسِ : لوگ لَا يَعْلَمُوْنَ : نہیں جانتے مصر والوں میں سے جس نے اسے خریدا تھا اس نے اپنی بیوی (1) سے کہا کہ اسے بہت عزت و احترام کے ساتھ رکھو، بہت ممکن ہے کہ یہ ہمیں فائدہ پہنچائے یا اسے ہم اپنا بیٹا ہی بنالیں، یوں ہم نے مصر کی سرزمین پر یوسف کا قدم جما دیا (2) ، کہ ہم اسے خواب کی تعبیر کا کچھ علم سکھا دیں۔ اللہ اپنے ارادے پر غالب ہے لیکن اکثر لوگ بےعلم ہوتے ہیں۔
12,22,وَ لَمَّا بَلَغَ اَشُدَّهٗۤ اٰتَیْنٰهُ حُكْمًا وَّ عِلْمًا١ؕ وَ كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ وَلَمَّا : اور جب بَلَغَ : پہنچ گیا اَشُدَّهٗٓ : اپنی قوت اٰتَيْنٰهُ : ہم نے اسے عطا کیا حُكْمًا : حکم وَّعِلْمًا : اور علم وَكَذٰلِكَ : اور اسی طرح نَجْزِي : ہم جزا دیتے ہیں الْمُحْسِنِيْنَ : نیکی کرنے والے جب (یوسف) پختگی کی عمر کو پہنچ گئے ہم نے اسے قوت فیصلہ اور علم دیا (1) ہم نیکوں کاروں کو اسی طرح بدلہ دیتے ہیں۔
12,23,وَ رَاوَدَتْهُ الَّتِیْ هُوَ فِیْ بَیْتِهَا عَنْ نَّفْسِهٖ وَ غَلَّقَتِ الْاَبْوَابَ وَ قَالَتْ هَیْتَ لَكَ١ؕ قَالَ مَعَاذَ اللّٰهِ اِنَّهٗ رَبِّیْۤ اَحْسَنَ مَثْوَایَ١ؕ اِنَّهٗ لَا یُفْلِحُ الظّٰلِمُوْنَ وَرَاوَدَتْهُ : اور اسے پھسلایا الَّتِيْ : وہ عورت جو هُوَ : اس فِيْ : میں بَيْتِهَا : اس کا گھر عَنْ نَّفْسِهٖ : اپنے آپ کو روکنے سے وَغَلَّقَتِ : اور بند کردئیے الْاَبْوَابَ : دروازے وَقَالَتْ : اور بولی هَيْتَ لَكَ : آ جا جلدی کر قَالَ : اس نے کہا مَعَاذَ اللّٰهِ : اللہ کی پناہ اِنَّهٗ : بیشک وہ رَبِّيْٓ : میرا مالک اَحْسَنَ : بہت اچھا مَثْوَايَ : اور رہنا سہنا اِنَّهٗ : بیشک لَا يُفْلِحُ : بھلائی نہیں پاتے الظّٰلِمُوْنَ : ظالم (جمع) اس عورت نے جس کے گھر میں یوسف تھے، یوسف کو بہلانا پھسلانا شروع کیا کہ وہ اپنے نفس کی نگرانی چھوڑ دے اور دروازہ بند کر کے کہنے لگی لو آجاؤ یوسف نے کہا اللہ کی پناہ ! وہ میرا رب، مجھے اس نے بہت اچھی طرح رکھا ہے۔ بےانصافی کرنے والوں کا بھلا نہیں ہوتا (1)۔
12,24,وَ لَقَدْ هَمَّتْ بِهٖ١ۚ وَ هَمَّ بِهَا لَوْ لَاۤ اَنْ رَّاٰ بُرْهَانَ رَبِّهٖ١ؕ كَذٰلِكَ لِنَصْرِفَ عَنْهُ السُّوْٓءَ وَ الْفَحْشَآءَ١ؕ اِنَّهٗ مِنْ عِبَادِنَا الْمُخْلَصِیْنَ وَلَقَدْ هَمَّتْ : اور بیشک اس عورت نے ارادہ کیا بِهٖ : اس کا وَهَمَّ : اور وہ ارادہ کرتے بِهَا : اس کا لَوْلَآ : اگر نہ ہوتا اَنْ : کہ رَّاٰ : وہ دیکھے بُرْهَانَ : دلیل رَبِّهٖ : اپنا رب كَذٰلِكَ : اسی طرح لِنَصْرِفَ : ہم نے پھیر دیا عَنْهُ : اس سے السُّوْٓءَ : برائی وَالْفَحْشَآءَ : اور بےحیائی اِنَّهٗ : بیشک وہ مِنْ : سے عِبَادِنَا : ہمارے بندے الْمُخْلَصِيْنَ : برگزیدہ اس عورت نے یوسف کی طرف کا قصد کیا اور یوسف اس (1) کا قصد کرتے اگر وہ اپنے پروردگار کی دلیل نہ دیکھتے (2) یونہی ہوا کہ ہم اس سے برائی اور بےحیائی دور کردیں (3) بیشک وہ ہمارے چنے ہوئے بندوں میں سے تھا۔
12,25,وَ اسْتَبَقَا الْبَابَ وَ قَدَّتْ قَمِیْصَهٗ مِنْ دُبُرٍ وَّ اَلْفَیَا سَیِّدَهَا لَدَا الْبَابِ١ؕ قَالَتْ مَا جَزَآءُ مَنْ اَرَادَ بِاَهْلِكَ سُوْٓءًا اِلَّاۤ اَنْ یُّسْجَنَ اَوْ عَذَابٌ اَلِیْمٌ وَاسْتَبَقَا : اور دونوں دوڑے الْبَابَ : دروازہ وَقَدَّتْ : اور عورت نے پھاڑ دی قَمِيْصَهٗ : اس کی قمیص مِنْ دُبُرٍ : پیچھے سے وَّاَلْفَيَا : اور دونوں کو ملا سَيِّدَهَا : عورت کا خاوند لَدَا الْبَابِ : دروازہ کے پاس قَالَتْ : وہ کہنے لگی مَا جَزَآءُ : کیا سزا مَنْ : جو۔ جس اَرَادَ : ارادہ کیا بِاَهْلِكَ : تیری بیوی سے سُوْٓءًا : برائی اِلَّآ : سوائے اَنْ : یہ کہ يُّسْجَنَ : قید کیا جائے اَوْ : یا عَذَابٌ اَلِيْمٌ : دردناک عذاب دونوں دروازے کی طرف دوڑے (1) اور اس عورت نے یوسف کا کرتا پیچھے کی طرف سے کھینچ کر پھاڑ ڈالا اور دروازے کے پاس اس کا شوہر دونوں کو مل گیا تو کہنے لگی جو شخص تیری بیوی کے ساتھ برا ارادہ کرے بس اس کی سزا یہی ہے کہ اسے قید کردیا جائے یا اور کوئی دردناک سزادی جائے (2)۔
12,26,قَالَ هِیَ رَاوَدَتْنِیْ عَنْ نَّفْسِیْ وَ شَهِدَ شَاهِدٌ مِّنْ اَهْلِهَا١ۚ اِنْ كَانَ قَمِیْصُهٗ قُدَّ مِنْ قُبُلٍ فَصَدَقَتْ وَ هُوَ مِنَ الْكٰذِبِیْنَ قَالَ : اس نے کہا هِىَ : اس رَاوَدَتْنِيْ : مجھے پھسلایا عَنْ : سے نَّفْسِيْ : میرا نفس وَشَهِدَ : اور گواہی دی شَاهِدٌ : ایک گواہ مِّنْ : سے اَهْلِهَا : اس کے لوگ اِنْ : اگر كَانَ : ہے قَمِيْصُهٗ : اس کی قمیص قُدَّ : پھٹی ہوئی مِنْ قُبُلٍ : آگے سے فَصَدَقَتْ : تو وہ سچی وَهُوَ : اور وہ مِنَ : سے الْكٰذِبِيْنَ : جھوٹے یوسف نے کہا یہ عورت ہی مجھے پھسلا رہی تھی (1) اور عورت کے قبیلے کے ہی کے ایک شخص نے گواہی دی (2) کہ اگر اس کا کرتہ آگے سے پھٹا ہوا ہو تو عورت سچی ہے اور یوسف جھوٹ بو لنے والوں میں سے ہے۔
12,27,وَ اِنْ كَانَ قَمِیْصُهٗ قُدَّ مِنْ دُبُرٍ فَكَذَبَتْ وَ هُوَ مِنَ الصّٰدِقِیْنَ وَاِنْ : اور اگر كَانَ : ہے قَمِيْصُهٗ : اس کی قمیص قُدَّ : پھٹی ہوئی مِنْ دُبُرٍ : پیچھے سے فَكَذَبَتْ : تو وہ جھوٹی وَهُوَ : اور وہ مِنَ : سے الصّٰدِقِيْنَ : سچے اور اگر اس کا کرتہ پیچھے کی جانب سے پھاڑا گیا ہے تو عورت جھوٹی ہے اور یوسف سچوں میں سے ہے۔
12,28,فَلَمَّا رَاٰ قَمِیْصَهٗ قُدَّ مِنْ دُبُرٍ قَالَ اِنَّهٗ مِنْ كَیْدِكُنَّ١ؕ اِنَّ كَیْدَكُنَّ عَظِیْمٌ فَلَمَّا : تو جب رَاٰ : دیکھا قَمِيْصَهٗ : اس کی قمیص قُدَّ : پھٹی ہوئی مِنْ دُبُرٍ : پیچھے سے قَالَ : اس نے کہا اِنَّهٗ : بیشک یہ مِنْ : سے كَيْدِكُنَّ : تم عورتوں کا فریب اِنَّ : بیشک كَيْدَكُنَّ : تمہارا فریب عَظِيْمٌ : بڑا خاوند نے جو دیکھا کہ یوسف کا کرتہ پیٹھ کی جانب سے پھاڑا گیا ہے تو صاف کہہ دیا یہ تو عورتوں کی چال بازی ہے، بیشک تمہاری چال بازی بہت بڑی ہے (1)
12,29,یُوْسُفُ اَعْرِضْ عَنْ هٰذَا١ٚ وَ اسْتَغْفِرِیْ لِذَنْۢبِكِ١ۖۚ اِنَّكِ كُنْتِ مِنَ الْخٰطِئِیْنَ۠    ۧ يُوْسُفُ : یوسف اَعْرِضْ : جانے دے عَنْ : سے۔ کو ھٰذَا : اس وَاسْتَغْفِرِيْ : اور اے عورت بخشش مانگ لِذَنْۢبِكِ : اپنے گناہ کی اِنَّكِ : بیشک تو كُنْتِ : تو ہے مِنَ : سے الْخٰطِئِيْنَ : خطا کار (جمع) یوسف اب اس بات کو آتی جاتی کرو (1) اور (اے عورت) تو اپنے گناہ سے توبہ کر، بیشک تو گنہگاروں میں سے ہے (2)۔
12,30,وَ قَالَ نِسْوَةٌ فِی الْمَدِیْنَةِ امْرَاَتُ الْعَزِیْزِ تُرَاوِدُ فَتٰىهَا عَنْ نَّفْسِهٖ١ۚ قَدْ شَغَفَهَا حُبًّا١ؕ اِنَّا لَنَرٰىهَا فِیْ ضَلٰلٍ مُّبِیْنٍ وَقَالَ : اور کہا نِسْوَةٌ : عورتیں فِي الْمَدِيْنَةِ : شہر میں امْرَاَتُ الْعَزِيْزِ : عزیز کی بیوی تُرَاوِدُ : پھسلا رہی ہے فَتٰىهَا : اپنا غلام عَنْ : سے نَّفْسِهٖ : اس کا نفس قَدْ شَغَفَهَا : جگہ پکڑ گئی ہے حُبًّا : اس کی محبت اِنَّا لَنَرٰىهَا : بیشک ہم اسے دیکھتی ہیں فِيْ : میں ضَلٰلٍ : گمراہی مُّبِيْنٍ : کھلی اور شہر کی عورتوں میں چرچا ہونے لگا کہ عزیز کی بیوی اپنے (جوان) غلام کو اپنا مطلب نکالنے کے لئے بہلانے پھسلانے میں لگی رہتی ہے، ان کے دل میں یوسف کی محبت بیٹھ گئی ہے، ہمارے خیال میں تو وہ صریح گمراہی میں ہے (1)۔
12,31,فَلَمَّا سَمِعَتْ بِمَكْرِهِنَّ اَرْسَلَتْ اِلَیْهِنَّ وَ اَعْتَدَتْ لَهُنَّ مُتَّكَاً وَّ اٰتَتْ كُلَّ وَاحِدَةٍ مِّنْهُنَّ سِكِّیْنًا وَّ قَالَتِ اخْرُجْ عَلَیْهِنَّ١ۚ فَلَمَّا رَاَیْنَهٗۤ اَكْبَرْنَهٗ وَ قَطَّعْنَ اَیْدِیَهُنَّ وَ قُلْنَ حَاشَ لِلّٰهِ مَا هٰذَا بَشَرًا١ؕ اِنْ هٰذَاۤ اِلَّا مَلَكٌ كَرِیْمٌ فَلَمَّا : پھر جب سَمِعَتْ : اس نے سنا بِمَكْرِهِنَّ : ان کا فریب اَرْسَلَتْ : دعوت بھیجی اِلَيْهِنَّ : ان کی طرف وَاَعْتَدَتْ : اور تیار کی لَهُنَّ : ان کے لیے مُتَّكَاً : ایک محفل وَّاٰتَتْ : اور دی كُلَّ وَاحِدَةٍ : ہر ایک کو مِّنْهُنَّ : ان میں سے سِكِّيْنًا : ایک ایک چھری وَّقَالَتِ : اور کہا اخْرُجْ : نکل آ عَلَيْهِنَّ : ان پر (ان کے سامنے) فَلَمَّا : پھر جب رَاَيْنَهٗٓ : انہوں نے اسے دیکھا اَكْبَرْنَهٗ : ان پر اس کا رعب چھا گیا وَقَطَّعْنَ : اور انہوں نے کاٹ لیے اَيْدِيَهُنَّ : اپنے ہاتھ وَقُلْنَ : اور کہنے لگیں حَاشَ : پناہ لِلّٰهِ : اللہ کی مَا ھٰذَا : نہیں یہ بَشَرًا : بشر اِنْ : نہیں ھٰذَآ : یہ اِلَّا : مگر مَلَكٌ : فرشتہ كَرِيْمٌ : بزرگ اس نے جب ان کی اس فریب پر غیبت کا حال سنا تو انھیں بلوا بھیجا (1) اور ان کے لئے ایک مجلس مرتب کی (2) اور ان میں سے ہر ایک کو چھری دی۔ اور کہا اے یوسف ان کے سامنے چلے آؤ (3) ان عورتوں نے جب اسے دیکھا تو بہت بڑا جانا اور اپنے ہاتھ کاٹ لئے (4) اور زبانوں سے نکل گیا کہ ما شاء اللہ ! یہ انسان تو ہرگز نہیں، یہ تو یقیناً کوئی بہت ہی بزرگ فرشتہ ہے۔
12,32,قَالَتْ فَذٰلِكُنَّ الَّذِیْ لُمْتُنَّنِیْ فِیْهِ١ؕ وَ لَقَدْ رَاوَدْتُّهٗ عَنْ نَّفْسِهٖ فَاسْتَعْصَمَ١ؕ وَ لَئِنْ لَّمْ یَفْعَلْ مَاۤ اٰمُرُهٗ لَیُسْجَنَنَّ وَ لَیَكُوْنًا مِّنَ الصّٰغِرِیْنَ قَالَتْ : وہ بولی فَذٰلِكُنَّ : سو یہ وہی ہے الَّذِيْ : جو کہ لُمْتُنَّنِيْ : تم نے ملامت کی مجھے فِيْهِ : اس میں وَلَقَدْ رَاوَدْتُّهٗ : اور میں نے اسے پھسلایا عَنْ : سے نَّفْسِهٖ : اس کا نفس فَاسْتَعْصَمَ : تو اس نے بچالیا وَلَئِنْ : اور اگر لَّمْ يَفْعَلْ : اس نے نہ کیا مَآ : جو اٰمُرُهٗ : میں کہتی ہوں اسے لَيُسْجَنَنَّ : البتہ قید کردیا جائیگا وَلَيَكُوْنًا : اور البتہ ہوجائے گا مِّنَ : سے الصّٰغِرِيْنَ : بےعزت (جمع) اس وقت عزیز مصر کی بیوی نے کہا، یہی ہیں جن کے بارے میں تم مجھے طعنے دے رہی تھیں (1) میں نے ہرچند اس سے اپنا مطلب حاصل کرنا چاہا، لیکن یہ بال بال بچا رہا، اور جو کچھ میں اسے کہہ رہی ہوں اگر یہ نہ کرے گا تو یقیناً یہ قید کردیا جائے گا اور بیشک یہ بہت ہی بےعزت ہوگا (2)۔
12,33,قَالَ رَبِّ السِّجْنُ اَحَبُّ اِلَیَّ مِمَّا یَدْعُوْنَنِیْۤ اِلَیْهِ١ۚ وَ اِلَّا تَصْرِفْ عَنِّیْ كَیْدَهُنَّ اَصْبُ اِلَیْهِنَّ وَ اَكُنْ مِّنَ الْجٰهِلِیْنَ قَالَ : اس نے کہا رَبِّ : اے میرے رب السِّجْنُ : قید اَحَبُّ : زیادہ پسند اِلَيَّ : مجھ کو مِمَّا : اس سے جو يَدْعُوْنَنِيْٓ : مجھے بلاتی ہیں اِلَيْهِ : اس کی طرف وَ : اور اِلَّا تَصْرِفْ : اگر نہ پھیرا عَنِّيْ : مجھ سے كَيْدَهُنَّ : ان کا فریب اَصْبُ : مائل ہوجاؤں گا اِلَيْهِنَّ : ان کی طرف وَاَكُنْ : اور میں ہوں گا مِّنَ : سے الْجٰهِلِيْنَ : جاہل (جمع) یوسف نے دعا کی اے میرے پروردگار ! جس بات کی طرف یہ عورت مجھے بلا رہی ہے اس سے تو مجھے جیل خانہ بہت پسند ہے، اگر تو نے ان کا فن فریب مجھ سے دور نہ کیا تو میں ان کی طرف مائل ہوجاؤں گا اور بالکل نادانوں میں جا ملوں گا (1)۔
12,34,فَاسْتَجَابَ لَهٗ رَبُّهٗ فَصَرَفَ عَنْهُ كَیْدَهُنَّ١ؕ اِنَّهٗ هُوَ السَّمِیْعُ الْعَلِیْمُ فَاسْتَجَابَ : سو قبول کرلی لَهٗ : اس کی (دعا) رَبُّهٗ : اس کا رب فَصَرَفَ : پس پھیر دیا عَنْهُ كَيْدَهُنَّ : ان کا فریب اِنَّهٗ : بیشک وہ هُوَ : وہ السَّمِيْعُ : سننے والا الْعَلِيْمُ : جاننے والا اس کے رب نے اس کی دعا قبول کرلی اور ان عورتوں کے داؤ پیچ اس سے پھیر دیئے، یقیناً وہ سننے والا جاننے والا ہے۔
12,35,ثُمَّ بَدَا لَهُمْ مِّنْۢ بَعْدِ مَا رَاَوُا الْاٰیٰتِ لَیَسْجُنُنَّهٗ حَتّٰى حِیْنٍ۠    ۧ ثُمَّ : پھر بَدَا لَهُمْ : انہیں سوجھا مِّنْۢ بَعْدِ : اس کے بعد مَا رَاَوُا : جب انہوں نے دیکھیں الْاٰيٰتِ : نشانیاں لَيَسْجُنُنَّهٗ : اسے ضرور قید میں ڈالیں حَتّٰي حِيْنٍ : ایک مدت تک پھر ان تمام نشانیوں کے دیکھ لینے کے بعد بھی انھیں یہی مصلحت معلوم ہوئی کہ یوسف کو کچھ مدت کے لئے قید خانہ میں رکھیں (1)۔
12,36,وَ دَخَلَ مَعَهُ السِّجْنَ فَتَیٰنِ١ؕ قَالَ اَحَدُهُمَاۤ اِنِّیْۤ اَرٰىنِیْۤ اَعْصِرُ خَمْرًا١ۚ وَ قَالَ الْاٰخَرُ اِنِّیْۤ اَرٰىنِیْۤ اَحْمِلُ فَوْقَ رَاْسِیْ خُبْزًا تَاْكُلُ الطَّیْرُ مِنْهُ١ؕ نَبِّئْنَا بِتَاْوِیْلِهٖ١ۚ اِنَّا نَرٰىكَ مِنَ الْمُحْسِنِیْنَ وَدَخَلَ : اور داخل ہوئے مَعَهُ : اس کے ساتھ السِّجْنَ : قید خانہ فَتَيٰنِ : دوجوان قَالَ : کہا اَحَدُهُمَآ : ان میں سے ایک اِنِّىْٓ : بیشک اَرٰىنِيْٓ : بیشک میں دیکھتا ہوں اَعْصِرُ : نچوڑ رہا ہوں خَمْرًا : شراب وَقَالَ : اور کہا الْاٰخَرُ : دوسرا اِنِّىْٓ اَرٰىنِيْٓ : میں دیکھتا ہوں اَحْمِلُ : اٹھائے ہوئے ہوں فَوْقَ : اوپر رَاْسِيْ : اپنا سر خُبْزًا : روٹی تَاْكُلُ : کھا رہے ہیں الطَّيْرُ : پرندے مِنْهُ : اس سے نَبِّئْنَا : ہمیں بتلائیے بِتَاْوِيْلِهٖ : اس کی تعبیر اِنَّا نَرٰىكَ : بیشک ہم تجھے دیکھتے ہیں مِنَ : سے الْمُحْسِنِيْنَ : نیکو کار (جمع) اس کے ساتھ ہی دو اور جوان بھی جیل خانے میں داخل ہوئے، ان میں سے ایک نے کہا کہ میں نے خواب میں اپنے آپ کو شراب نچوڑتے دیکھا ہے، اور دوسرے نے کہا میں نے اپنے آپ کو دیکھا ہے کہ میں اپنے سر پر روٹی اٹھائے ہوئے ہوں جسے پرندے کھا رہے ہیں، ہمیں آپ اس کی تعبیر بتائیے، ہمیں تو آپ خوبیوں والے شخص دکھائی دیتے ہیں (1)۔
12,37,قَالَ لَا یَاْتِیْكُمَا طَعَامٌ تُرْزَقٰنِهٖۤ اِلَّا نَبَّاْتُكُمَا بِتَاْوِیْلِهٖ قَبْلَ اَنْ یَّاْتِیَكُمَا١ؕ ذٰلِكُمَا مِمَّا عَلَّمَنِیْ رَبِّیْ١ؕ اِنِّیْ تَرَكْتُ مِلَّةَ قَوْمٍ لَّا یُؤْمِنُوْنَ بِاللّٰهِ وَ هُمْ بِالْاٰخِرَةِ هُمْ كٰفِرُوْنَ قَالَ : اس نے کہا لَا يَاْتِيْكُمَا : تمہارے پاس نہیں آئیگا طَعَامٌ : کھانا تُرْزَقٰنِهٖٓ : جو تمہیں دیا جاتا ہے اِلَّا : مگر نَبَّاْتُكُمَا : میں تمہیں بتلا دوں گا بِتَاْوِيْلِهٖ : اس کی تعبیر قَبْلَ : قبل اَنْ : کہ يَّاْتِيَكُمَا : وہ آئے تمہارے پاس ذٰلِكُمَا : یہ مِمَّا : اس سے جو عَلَّمَنِيْ : مجھے سکھایا رَبِّيْ : میرا رب اِنِّىْ : بیشک میں تَرَكْتُ : میں نے چھوڑا مِلَّةَ : دین قَوْمٍ : وہ قوم لَّا يُؤْمِنُوْنَ : وہ ایمان نہیں لاتے بِاللّٰهِ : اللہ پر وَهُمْ : اور وہ بِالْاٰخِرَةِ : آخرت سے هُمْ : وہ كٰفِرُوْنَ : انکار کرتے ہیں یوسف نے کہا تمہیں جو کھانا دیا جاتا ہے اس کے تمہارے پاس پہنچنے سے پہلے ہی میں تمہیں اس کی تعبیر بتلا دوں گا یہ سب اس علم کی بدولت ہے جو میرے رب نے سکھایا ہے، (1) میں نے ان لوگوں کا مذہب چھوڑ دیا ہے جو اللہ پر ایمان نہیں رکھتے اور آخرت کے بھی منکر ہیں 20)۔
12,38,وَ اتَّبَعْتُ مِلَّةَ اٰبَآءِیْۤ اِبْرٰهِیْمَ وَ اِسْحٰقَ وَ یَعْقُوْبَ١ؕ مَا كَانَ لَنَاۤ اَنْ نُّشْرِكَ بِاللّٰهِ مِنْ شَیْءٍ١ؕ ذٰلِكَ مِنْ فَضْلِ اللّٰهِ عَلَیْنَا وَ عَلَى النَّاسِ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَشْكُرُوْنَ وَاتَّبَعْتُ : اور میں نے پیروی کی مِلَّةَ : دین اٰبَآءِيْٓ : اپنے باپ دادا اِبْرٰهِيْمَ : ابراہیم وَاِسْحٰقَ : اور اسحق وَيَعْقُوْبَ : اور یعقوب مَا كَانَ : نہیں ہے لَنَآ : ہمارے لیے اَنْ : کہ نُّشْرِكَ : ہم شریک ٹھہرائیں بِاللّٰهِ : اللہ کا مِنْ شَيْءٍ : کوئی کسی شے ذٰلِكَ : یہ مِنْ : سے فَضْلِ اللّٰهِ : اللہ کا فضل عَلَيْنَا : ہم پر وَ : اور عَلَي النَّاسِ : لوگوں پر وَلٰكِنَّ : اور لیکن اَكْثَرَ : اکثر النَّاسِ : لوگ لَا يَشْكُرُوْنَ : شکر ادا نہیں کرتے میں اپنے باپ دادوں کے دین کا پابند ہوں، یعنی ابراہیم و اسحاق اور یعقوب کے دین کا (1) ہمیں ہرگز یہ سزاوار نہیں کہ ہم اللہ تعالیٰ کے ساتھ کسی کو بھی شریک کریں (2) ہم پر اور تمام اور لوگوں پر اللہ تعالیٰ کا یہ خاص فضل ہے، لیکن اکثر لوگ ناشکری کرتے ہیں۔
12,39,یٰصَاحِبَیِ السِّجْنِ ءَاَرْبَابٌ مُّتَفَرِّقُوْنَ خَیْرٌ اَمِ اللّٰهُ الْوَاحِدُ الْقَهَّارُؕ يٰصَاحِبَيِ السِّجْنِ : اے میرے قید کے ساتھیو ! ءَاَرْبَابٌ : کیا کئی معبود مُّتَفَرِّقُوْنَ : جدا جدا خَيْرٌ : بہتر اَمِ اللّٰهُ : یا اللہ الْوَاحِدُ : ایک، یکتا الْقَهَّارُ : زبردست۔ غالب اے میرے قید خانے کے ساتھیو ! (1) کیا متفرق کئی ایک پروردگار بہتر ہیں ؟ (2) یا ایک اللہ زبردست طاقتور۔
12,40,مَا تَعْبُدُوْنَ مِنْ دُوْنِهٖۤ اِلَّاۤ اَسْمَآءً سَمَّیْتُمُوْهَاۤ اَنْتُمْ وَ اٰبَآؤُكُمْ مَّاۤ اَنْزَلَ اللّٰهُ بِهَا مِنْ سُلْطٰنٍ١ؕ اِنِ الْحُكْمُ اِلَّا لِلّٰهِ١ؕ اَمَرَ اَلَّا تَعْبُدُوْۤا اِلَّاۤ اِیَّاهُ١ؕ ذٰلِكَ الدِّیْنُ الْقَیِّمُ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ مَا : نہیں تَعْبُدُوْنَ : تم پوجتے مِنْ دُوْنِهٖٓ : اس کے سوا اِلَّآ : مگر اَسْمَآءً : نام سَمَّيْتُمُوْهَآ : تم نے رکھ لیے ہیں اَنْتُمْ : تم وَاٰبَآؤُكُمْ : اور تمہارے باپ دادا مَّآ : نہیں اَنْزَلَ اللّٰهُ : اللہ نے اتاری بِهَا : اس کے لیے مِنْ سُلْطٰنٍ : کوئی سند اِنِ : نہیں الْحُكْمُ : حکم اِلَّا : مگر لِلّٰهِ : اللہ کا اَمَرَ : اس نے حکم دیا اَلَّا : کہ نہ تَعْبُدُوْٓا : عبادت کرو تم اِلَّآ : مگر اِيَّاهُ : صرف اس کی ذٰلِكَ : یہ الدِّيْنُ الْقَيِّمُ : سیدھا دین وَلٰكِنَّ : اور لیکن اَكْثَرَ النَّاسِ : اکثر لوگ لَا يَعْلَمُوْنَ : نہیں جانتے اس کے سوا تم جن کی پوجا پاٹ کر رہے ہو وہ سب نام ہی نام ہیں جو تم نے اور تمہارے باپ دادوں نے خود ہی گھڑ لئے ہیں۔ اللہ تعالیٰ نے ان کی کوئی دلیل نازل نہیں فرمائی (1) فرمانروائی صرف اللہ تعالیٰ کی ہے، اس کا فرمان ہے کہ تم سب سوائے اس کے کسی اور کی عبادت نہ کرو، یہی دین درست ہے (2) لیکن اکثر لوگ نہیں جانتے (3)۔
12,41,یٰصَاحِبَیِ السِّجْنِ اَمَّاۤ اَحَدُكُمَا فَیَسْقِیْ رَبَّهٗ خَمْرًا١ۚ وَ اَمَّا الْاٰخَرُ فَیُصْلَبُ فَتَاْكُلُ الطَّیْرُ مِنْ رَّاْسِهٖ١ؕ قُضِیَ الْاَمْرُ الَّذِیْ فِیْهِ تَسْتَفْتِیٰنِؕ يٰصَاحِبَيِ : اے میرے ساتھیو ! السِّجْنِ : قید خانہ اَمَّآ : جو اَحَدُكُمَا : تم میں سے ایک فَيَسْقِيْ : سو وہ پلائے گا رَبَّهٗ : اپنا مالک خَمْرًا : شراب وَاَمَّا : اور جو الْاٰخَرُ : دوسرا فَيُصْلَبُ : تو سولی دیا جائے گا فَتَاْكُلُ : پس کھائیں گے الطَّيْرُ : پرندے مِنْ رَّاْسِهٖ : اس کے سر سے قُضِيَ : فیصلہ ہوچکا الْاَمْرُ : کام۔ بات الَّذِيْ : وہ جو فِيْهِ : اس میں تَسْتَفْتِيٰنِ : تم پوچھتے تھے اے میرے قید خانے کے رفیقو ! (1) تم دونوں میں سے ایک تو اپنے بادشاہ کو شراب پلانے پر مقرر ہوجائے گا (2) لیکن دوسرا سولی پر چڑھایا جائے گا اور پرندے اس کا سر نوچ نوچ کر کھائیں گے (3) تم دونوں جس کے بارے میں تحقیق کر رہے تھے اس کام کا فیصلہ کردیا گیا ہے (4)۔
12,42,وَ قَالَ لِلَّذِیْ ظَنَّ اَنَّهٗ نَاجٍ مِّنْهُمَا اذْكُرْنِیْ عِنْدَ رَبِّكَ١٘ فَاَنْسٰىهُ الشَّیْطٰنُ ذِكْرَ رَبِّهٖ فَلَبِثَ فِی السِّجْنِ بِضْعَ سِنِیْنَؕ۠    ۧ وَقَالَ : اور کہا لِلَّذِيْ : اس سے جس ظَنَّ : اس نے گمان کیا اَنَّهٗ : کہ بیشک وہ نَاجٍ : بچے گا وہ مِّنْهُمَا : ان دونوں سے اذْكُرْنِيْ : میرا ذکر کرنا عِنْدَ : پاس رَبِّكَ : اپنا مالک فَاَنْسٰىهُ : پس اس کو بھلا دیا الشَّيْطٰنُ : شیطان ذِكْرَ رَبِّهٖ : اپنے مالک سے ذکر کرنا فَلَبِثَ : تو رہا فِي السِّجْنِ : قید میں بِضْعَ سِنِيْنَ : چند برس اور جس کی نسبت یوسف کا گمان تھا کہ ان دونوں میں سے یہ چھوٹ جائے گا اس سے کہا کہ اپنے بادشاہ سے میرا ذکر بھی کردینا پھر اسے شیطان نے اپنے بادشاہ سے ذکر کرنا بھلا دیا اور یوسف نے کئی سال قید خانے میں ہی کاٹے (1)۔
12,43,وَ قَالَ الْمَلِكُ اِنِّیْۤ اَرٰى سَبْعَ بَقَرٰتٍ سِمَانٍ یَّاْكُلُهُنَّ سَبْعٌ عِجَافٌ وَّ سَبْعَ سُنْۢبُلٰتٍ خُضْرٍ وَّ اُخَرَ یٰبِسٰتٍ١ؕ یٰۤاَیُّهَا الْمَلَاُ اَفْتُوْنِیْ فِیْ رُءْیَایَ اِنْ كُنْتُمْ لِلرُّءْیَا تَعْبُرُوْنَ وَقَالَ : اور کہا الْمَلِكُ : بادشاہ اِنِّىْٓ : کہ وہ اَرٰي : میں دیکھتا ہوں سَبْعَ : سات بَقَرٰتٍ : گائیں سِمَانٍ : موٹی تازی يَّاْكُلُهُنَّ : وہ کھاتی ہیں سَبْعٌ : سات عِجَافٌ : دبلی پتلی وَّسَبْعَ : اور سات سُنْۢبُلٰتٍ : خوشے خُضْرٍ : سبز وَّاُخَرَ : اور دوسرے يٰبِسٰتٍ : خشک يٰٓاَيُّهَا الْمَلَاُ : اے میرے سردارو اَفْتُوْنِيْ : بتلاؤ مجھے تعبیر فِيْ : میں (کی) رُءْيَايَ : میرے خواب اِنْ : اگر كُنْتُمْ : ہو تم لِلرُّءْيَا : خواب کی تَعْبُرُوْنَ : تعبیر دینے والے بادشاہ نے کہا، میں نے خواب دیکھا ہے سات موٹی تازی فربہ گائے ہیں جن کو سات لاغر دبلی پتلی گائیں کھا رہی ہیں اور سات بالیاں ہیں ہری ہری اور دوسری سات بالکل خشک۔ اے درباریو ! میرے اس خواب کی تعبیر بتلاؤ اگر تم خواب کی تعبیر دے سکتے ہو۔
12,44,قَالُوْۤا اَضْغَاثُ اَحْلَامٍ١ۚ وَ مَا نَحْنُ بِتَاْوِیْلِ الْاَحْلَامِ بِعٰلِمِیْنَ قَالُوْٓا : انہوں نے کہا اَضْغَاثُ : پریشان اَحْلَامٍ : خواب وَمَا : اور نہیں نَحْنُ : ہم بِتَاْوِيْلِ : تعبیر دینا الْاَحْلَامِ : خواب (جمع) بِعٰلِمِيْنَ : جاننے والے انہوں نے جواب دیا یہ تو اڑتے اڑاتے پریشان خواب ہیں اور ایسے شوریدہ پریشان خوابوں کی تعبیر جاننے والے ہم نہیں (1)۔
12,45,وَ قَالَ الَّذِیْ نَجَا مِنْهُمَا وَ ادَّكَرَ بَعْدَ اُمَّةٍ اَنَا اُنَبِّئُكُمْ بِتَاْوِیْلِهٖ فَاَرْسِلُوْنِ وَقَالَ : اور اس نے کہا الَّذِيْ : وہ جو نَجَا : بچا مِنْهُمَا : ان دو سے وَادَّكَرَ : اور اسے یاد آیا بَعْدَ : بعد اُمَّةٍ : ایک مدت اَنَا اُنَبِّئُكُمْ : میں بتلاؤں گا تمہیں بِتَاْوِيْلِهٖ : اس کی تعبیر فَاَرْسِلُوْنِ : سو مجھے بھیج دو ان دو قیدیوں میں سے جو رہا ہوا تھا اسے مدت کے بعد یاد آگیا اور کہنے لگا میں تمہیں اس کی تعبیر بتادوں گا مجھے جانے کی اجازت دیجئے (1)۔
12,46,یُوْسُفُ اَیُّهَا الصِّدِّیْقُ اَفْتِنَا فِیْ سَبْعِ بَقَرٰتٍ سِمَانٍ یَّاْكُلُهُنَّ سَبْعٌ عِجَافٌ وَّ سَبْعِ سُنْۢبُلٰتٍ خُضْرٍ وَّ اُخَرَ یٰبِسٰتٍ١ۙ لَّعَلِّیْۤ اَرْجِعُ اِلَى النَّاسِ لَعَلَّهُمْ یَعْلَمُوْنَ يُوْسُفُ : اے یوسف اَيُّهَا الصِّدِّيْقُ : اے بڑے سچے اَفْتِنَا : ہمیں بتا فِيْ : میں سَبْعِ : سات بَقَرٰتٍ : گائیں سِمَانٍ : موٹی تازی يَّاْكُلُهُنَّ : وہ کھا رہی ہیں سَبْعٌ : سات عِجَافٌ : دبلی پتلی وَّسَبْعِ : اور سات سُنْۢبُلٰتٍ : خوشے خُضْرٍ : سبز وَّاُخَرَ : اور دوسرے يٰبِسٰتٍ : خشک لَّعَلِّيْٓ : تاکہ میں اَرْجِعُ : میں لوٹوں اِلَى النَّاسِ : لوگوں کی طرف (پاس) لَعَلَّهُمْ : شاید وہ يَعْلَمُوْنَ : آگاہ ہوں اے یوسف ! اے بہت بڑے سچے یوسف ! آپ ہمیں اس خواب کی تعبیر بتلایئے کہ سات موٹی تازی گائیں ہیں جنہیں سات دبلی پتلی گائیں کھا رہی ہیں اور سات سبز خوشے ہیں اور سات ہی دوسرے بھی بالکل خشک ہیں، تاکہ میں واپس جا کر ان لوگوں سے کہوں کہ وہ سب جان لیں۔
12,47,قَالَ تَزْرَعُوْنَ سَبْعَ سِنِیْنَ دَاَبًا١ۚ فَمَا حَصَدْتُّمْ فَذَرُوْهُ فِیْ سُنْۢبُلِهٖۤ اِلَّا قَلِیْلًا مِّمَّا تَاْكُلُوْنَ قَالَ : اس نے کہا تَزْرَعُوْنَ : کھیتی باڑی کروگے سَبْعَ : سات سِنِيْنَ : سال دَاَبًا : لگاتار فَمَا : پھر جو حَصَدْتُّمْ : تم کاٹو فَذَرُوْهُ : تو اسے چھوڑ دو فِيْ سُنْۢبُلِهٖٓ : اس کے خوشہ میں اِلَّا : مگر قَلِيْلًا : تھوڑا جتنا مِّمَّا : سے۔ جو تَاْكُلُوْنَ : تم کھالو یوسف نے جواب دیا کہ تم سات سال تک پے درپے لگاتار حسب عادت غلہ بویا کرنا، اور فصل کاٹ کر اسے بالیوں سمیت ہی رہنے دینا سوائے اپنے کھانے کی تھوڑی سی مقدار کے۔
12,48,ثُمَّ یَاْتِیْ مِنْۢ بَعْدِ ذٰلِكَ سَبْعٌ شِدَادٌ یَّاْكُلْنَ مَا قَدَّمْتُمْ لَهُنَّ اِلَّا قَلِیْلًا مِّمَّا تُحْصِنُوْنَ ثُمَّ : پھر يَاْتِيْ : آئیں گے مِنْۢ بَعْدِ ذٰلِكَ : اس کے بعد میں سَبْعٌ : سات شِدَادٌ : سخت يَّاْكُلْنَ : کھا جائیں گے وہ مَا : جو قَدَّمْتُمْ : تم نے رکھا لَهُنَّ : ان کے لیے اِلَّا : سوائے قَلِيْلًا : تھوڑا سا مِّمَّا : سے۔ جو تُحْصِنُوْنَ : تم بچاؤ گے اس کے بعد سات سال نہایت سخت قحط کے آئیں گے وہ اس غلے کو کھا جائیں گے، جو تم نے ان کے لئے ذخیرہ رکھ چھوڑا تھا (1) سوائے اس تھوڑے سے کے جو تم روک رکھتے ہو (2)۔
12,49,ثُمَّ یَاْتِیْ مِنْۢ بَعْدِ ذٰلِكَ عَامٌ فِیْهِ یُغَاثُ النَّاسُ وَ فِیْهِ یَعْصِرُوْنَ۠    ۧ ثُمَّ : پھر يَاْتِيْ : آئے گا مِنْۢ بَعْدِ ذٰلِكَ : اس کے بعد عَامٌ : ایک سال فِيْهِ : اس میں يُغَاثُ : بارش برسائی جائیگی النَّاسُ : لوگ وَفِيْهِ : اور اس میں يَعْصِرُوْنَ : وہ نچوڑیں گے اس کے بعد جو سال آئے گا اس میں لوگوں پر خوب بارش برسائی جائے گی اور اس میں (شیرہ انگور بھی) خوب نچوڑیں گے (1)
12,50,وَ قَالَ الْمَلِكُ ائْتُوْنِیْ بِهٖ١ۚ فَلَمَّا جَآءَهُ الرَّسُوْلُ قَالَ ارْجِعْ اِلٰى رَبِّكَ فَسْئَلْهُ مَا بَالُ النِّسْوَةِ الّٰتِیْ قَطَّعْنَ اَیْدِیَهُنَّ١ؕ اِنَّ رَبِّیْ بِكَیْدِهِنَّ عَلِیْمٌ وَقَالَ : اور کہا الْمَلِكُ : بادشاہ ائْتُوْنِيْ : میرے پاس لے آؤ بِهٖ : ساتھ اس کے فَلَمَّا : پس جب جَآءَهُ : اس کے پاس آیا الرَّسُوْلُ : قاصد قَالَ : اس نے کہا ارْجِعْ : لوٹ جا اِلٰي : طرف (پاس) رَبِّكَ : اپنا مالک فَسْئَلْهُ : پس اس سے پوچھو مَا بَالُ : کیا حال ؟ النِّسْوَةِ : عورتیں الّٰتِيْ : وہ جو قَطَّعْنَ : انہوں نے کاٹے اَيْدِيَهُنَّ : اپنے ہاتھ اِنَّ : بیشک رَبِّيْ : میرا رب بِكَيْدِهِنَّ : ان کا فریب عَلِيْمٌ : واقف اور بادشاہ نے کہا یوسف کو میرے پاس لاؤ (1) جب قاصد یوسف کے پاس پہنچا تو انہوں نے کہا، اپنے بادشاہ کے پاس واپس جا اور اس سے پوچھ کہ ان عورتوں کا حقیقی واقعہ کیا ہے جنہوں نے اپنے ہاتھ کاٹ لئے (2) تھے ؟ ان کے حیلے کو (صحیح طور پر) جاننے والا میرا پروردگار ہی ہے۔
12,51,قَالَ مَا خَطْبُكُنَّ اِذْ رَاوَدْتُّنَّ یُوْسُفَ عَنْ نَّفْسِهٖ١ؕ قُلْنَ حَاشَ لِلّٰهِ مَا عَلِمْنَا عَلَیْهِ مِنْ سُوْٓءٍ١ؕ قَالَتِ امْرَاَتُ الْعَزِیْزِ الْئٰنَ حَصْحَصَ الْحَقُّ١٘ اَنَا رَاوَدْتُّهٗ عَنْ نَّفْسِهٖ وَ اِنَّهٗ لَمِنَ الصّٰدِقِیْنَ قَالَ : اس نے کہا مَا خَطْبُكُنَّ : کیا حال تھا تمہارا اِذْ : جب رَاوَدْتُّنَّ : تم نے پھسلایا يُوْسُفَ : یوسف عَنْ : سے نَّفْسِهٖ : اس کا نفس قُلْنَ : وہ بولیں حَاشَ : پناہ لِلّٰهِ : اللہ کی مَا : نہیں عَلِمْنَا : ہم نے معلوم کی عَلَيْهِ : اس پر (میں) مِنْ سُوْٓءٍ : کوئی برائی قَالَتِ : بولی امْرَاَتُ : عورت الْعَزِيْزِ : عزیز الْئٰنَ : اب حَصْحَصَ : ظاہر ہوگئی الْحَقُّ : حقیقت اَنَا : میں رَاوَدْتُّهٗ : اسے پھسلایا میں نے عَنْ : سے نَّفْسِهٖ : اس کا نفس وَاِنَّهٗ : اور وہ بیشک لَمِنَ : البتہ۔ سے الصّٰدِقِيْنَ : سچے بادشاہ نے پوچھا اے عورتو ! اس وقت کا صحیح واقعہ کیا ہے جب تم داؤ فریب کرکے یوسف کو اس کی دلی منشا سے بہکانہ چاہتی تھیں انہوں نے صاف جواب دیا کہ معاذاللہ ہم نے یوسف میں کوئی برائی نہیں (1) پائی، پھر تو عزیز کی بیوی بھی بول اٹھی کہ اب تو سچی بات نتھر آئی میں نے ہی اسے ورغلایا تھا، اس کے جی سے، اور یقیناً وہ سچوں میں سے ہے (2)۔
12,52,ذٰلِكَ لِیَعْلَمَ اَنِّیْ لَمْ اَخُنْهُ بِالْغَیْبِ وَ اَنَّ اللّٰهَ لَا یَهْدِیْ كَیْدَ الْخَآئِنِیْنَ ذٰلِكَ : یہ لِيَعْلَمَ : تاکہ وہ جان لے اَنِّىْ : بیشک میں لَمْ اَخُنْهُ : نہیں اس کی خیانت کی بِالْغَيْبِ : پیٹھ پیچھے وَاَنَّ اللّٰهَ : اور بیشک اللہ لَايَهْدِيْ : نہیں چلنے دیتا كَيْدَ : فریب الْخَآئِنِيْنَ : دغا باز (جمع) (یوسف ؑ نے کہا) یہ اس واسطے کہ (عزیز) جان لے کہ میں نے اس کی پیٹھ پیچھے اس کی خیانت نہیں کی (2) ہے اور یہ بھی کہ اللہ دغا بازوں کے ہتھکنڈے چلنے نہیں دیتا (3)
12,53,وَ مَاۤ اُبَرِّئُ نَفْسِیْ١ۚ اِنَّ النَّفْسَ لَاَمَّارَةٌۢ بِالسُّوْٓءِ اِلَّا مَا رَحِمَ رَبِّیْ١ؕ اِنَّ رَبِّیْ غَفُوْرٌ رَّحِیْمٌ وَ : اور مَآ اُبَرِّئُ : پاک، بےقصور نہیں کہتا نَفْسِيْ : اپنا نفس اِنَّ : بیشک النَّفْسَ : نفس لَاَمَّارَةٌ : سکھانے والا بِالسُّوْٓءِ : برائی اِلَّا : مگر مَارَحِمَ : جس پر رحم کیا رَبِّيْ : میرا رب اِنَّ : بیشک رَبِّيْ : میرا رب غَفُوْرٌ : بخشنے والا رَّحِيْمٌ : نہایت مہربان میں اپنے نفس کی پاکیزگی بیان نہیں کرتا (1) بیشک نفس تو برائی پر ابھارنے والا ہی ہے (2) مگر یہ کہ میرا پروردگار ہی اپنا رحم کے (3) یقیناً میرا رب پالنے والا بڑی بخشش کرنے والا اور بہت مہربانی فرمانے والا ہے۔
12,54,وَ قَالَ الْمَلِكُ ائْتُوْنِیْ بِهٖۤ اَسْتَخْلِصْهُ لِنَفْسِیْ١ۚ فَلَمَّا كَلَّمَهٗ قَالَ اِنَّكَ الْیَوْمَ لَدَیْنَا مَكِیْنٌ اَمِیْنٌ وَقَالَ : اور کہا الْمَلِكُ : بادشاہ ائْتُوْنِيْ : لے آؤ میرے پاس بِهٖٓ : اس کو اَسْتَخْلِصْهُ : اس کو خاص کروں لِنَفْسِيْ : اپنی ذات کے لیے فَلَمَّا : پھر جب كَلَّمَهٗ : اس سے بات کی قَالَ : اس نے کہا اِنَّكَ : بیشک تم الْيَوْمَ : آج لَدَيْنَا : ہمارے پاس مَكِيْنٌ : باوقار اَمِيْنٌ : امین بادشاہ نے کہا کہ اسے میرے پاس لاؤ کہ میں اسے اپنے خاص کاموں کے لئے مقرر کرلوں (1) پھر جب اس سے بات چیت کی تو کہنے لگا کہ آپ ہمارے ہاں ذی عزت اور امانت دار ہیں (2)
12,55,قَالَ اجْعَلْنِیْ عَلٰى خَزَآئِنِ الْاَرْضِ١ۚ اِنِّیْ حَفِیْظٌ عَلِیْمٌ قَالَ : اس نے کہا اجْعَلْنِيْ : مجھے کردے عَلٰي : پر خَزَآئِنِ : خزانے الْاَرْضِ : زمین (ملک) اِنِّىْ : بشیک میں حَفِيْظٌ : حفاظت کرنیوالا عَلِيْمٌ : علم والا (یوسف) نے کہا آپ مجھے ملک کے خزانوں پر معمور کر دیجئے (1) میں حفاظت کرنے والا اور باخبر ہوں (2)
12,56,وَ كَذٰلِكَ مَكَّنَّا لِیُوْسُفَ فِی الْاَرْضِ١ۚ یَتَبَوَّاُ مِنْهَا حَیْثُ یَشَآءُ١ؕ نُصِیْبُ بِرَحْمَتِنَا مَنْ نَّشَآءُ وَ لَا نُضِیْعُ اَجْرَ الْمُحْسِنِیْنَ وَكَذٰلِكَ : اور اسی طرح مَكَّنَّا : ہم نے قدرت دی لِيُوْسُفَ : یوسف کو فِي الْاَرْضِ : زمین میں (ملک پر) يَتَبَوَّاُ : وہ رہتے مِنْهَا : اس سے (میں) حَيْثُ : جہاں يَشَآءُ : وہ چاہتے نُصِيْبُ : ہم پہنچا دیتے ہیں بِرَحْمَتِنَا : اپنی رحمت سے مَنْ نَّشَآءُ : جس کو ہم چاہتے ہیں وَلَا نُضِيْعُ : اور ہم ضائع نہیں کرتے اَجْرَ : بدلہ الْمُحْسِنِيْنَ : نیکی کرنے والے اسی طرح ہم نے یوسف ؑ کو ملک کا قبضہ دے دیا کہ وہ جہاں کہیں چاہے رہے سہے (1) ہم جسے چاہیں اپنی رحمت پہنچا دیتے ہیں۔ ہم نیکوکاروں کا ثواب ضائع نہیں کرتے (2)۔
12,57,وَ لَاَجْرُ الْاٰخِرَةِ خَیْرٌ لِّلَّذِیْنَ اٰمَنُوْا وَ كَانُوْا یَتَّقُوْنَ۠    ۧ وَلَاَجْرُ الْاٰخِرَةِ : اور آخرت کا بدلہ البتہ خَيْرٌ : بہتر لِّلَّذِيْنَ : ان کے لیے جو اٰمَنُوْا : ایمان لائے وَكَانُوْا : اور تھے وہ يَتَّقُوْنَ : پرہیزگاری کرتے یقیناً ایمان داروں اور پرہیزگاروں کا اخروی اجر بہت ہی بہتر ہے۔
12,58,وَ جَآءَ اِخْوَةُ یُوْسُفَ فَدَخَلُوْا عَلَیْهِ فَعَرَفَهُمْ وَ هُمْ لَهٗ مُنْكِرُوْنَ وَجَآءَ : اور آئے اِخْوَةُ : بھائی يُوْسُفَ : یوسف فَدَخَلُوْا : پس وہ داخل ہوئے عَلَيْهِ : اس کے پاس فَعَرَفَهُمْ : تو اس نے انہیں پہچان لیا وَهُمْ : اور وہ لَهٗ : اس کو مُنْكِرُوْنَ : وہ نہ پہچانے یوسف کے بھائی آئے اور یوسف کے پاس گئے تو اس نے انھیں پہچان لیا اور انہوں نے اسے نہ پہچانا (1)
12,59,وَ لَمَّا جَهَّزَهُمْ بِجَهَازِهِمْ قَالَ ائْتُوْنِیْ بِاَخٍ لَّكُمْ مِّنْ اَبِیْكُمْ١ۚ اَلَا تَرَوْنَ اَنِّیْۤ اُوْفِی الْكَیْلَ وَ اَنَا خَیْرُ الْمُنْزِلِیْنَ وَلَمَّا : اور جب جَهَّزَهُمْ : جب انہیں تیار کردیا بِجَهَازِهِمْ : ان کا سامان قَالَ : کہا اس نے ائْتُوْنِيْ : لاؤ میرے پاس بِاَخٍ : بھائی لَّكُمْ : تمہارا (اپنا) مِّنْ اَبِيْكُمْ : تمہارے باپ سے اَلَا تَرَوْنَ : کیا تم نہیں دیکھتے اَنِّىْٓ : کہ میں اُوْفِي : پورا کرتا ہوں الْكَيْلَ : پیمانہ وَاَنَا : اور میں خَيْرُ : بہترین الْمُنْزِلِيْنَ : اتارنے والا (مہمان نواز) جب انھیں ان کا اسباب مہیا کردیا تو کہا کہ تم میرے پاس اپنے اس بھائی کو بھی لانا جو تمہارے باپ سے ہے، کیا تم نے نہیں دیکھا کہ میں پورا ناپ کردیتا ہوں اور میں ہوں بھی بہترین میزبانی کرنے والوں میں (1)
12,60,فَاِنْ لَّمْ تَاْتُوْنِیْ بِهٖ فَلَا كَیْلَ لَكُمْ عِنْدِیْ وَ لَا تَقْرَبُوْنِ فَاِنْ : پھر اگر لَّمْ تَاْتُوْنِيْ : میرے پاس نہ لائے بِهٖ : اس کو فَلَا كَيْلَ : تو کوئی ناپ نہیں لَكُمْ : تمہارے لیے عِنْدِيْ : میرے پاس وَلَا تَقْرَبُوْنِ : اور نہ آنا میرے پاس پس اگر تم اسے لے کر نہ آئے تو میری طرف سے تمہیں کوئی ناپ بھی نہ ملے گا بلکہ تم میرے قریب بھی نہ پھٹکنا (1)
12,61,قَالُوْا سَنُرَاوِدُ عَنْهُ اَبَاهُ وَ اِنَّا لَفٰعِلُوْنَ قَالُوْا : وہ بولے سَنُرَاوِدُ : ہم خواہش کریں گے عَنْهُ : اس کے متعلق اَبَاهُ : اس کا باپ وَاِنَّا : اور ہم لَفٰعِلُوْنَ : ضرور کرنیوالے ہیں (کرنا ہے) انہوں نے کہا ہم اس کے باپ کو اس کی بابت پھسلائیں گے اور پوری کوشش کریں گے (1)۔
12,62,وَ قَالَ لِفِتْیٰنِهِ اجْعَلُوْا بِضَاعَتَهُمْ فِیْ رِحَالِهِمْ لَعَلَّهُمْ یَعْرِفُوْنَهَاۤ اِذَا انْقَلَبُوْۤا اِلٰۤى اَهْلِهِمْ لَعَلَّهُمْ یَرْجِعُوْنَ وَقَالَ : اور اس نے کہا لِفِتْيٰنِهِ : اپنے خدمتگاروں کو اجْعَلُوْا : اور تم رکھدو بِضَاعَتَهُمْ : ان کی پونجی فِيْ رِحَالِهِمْ : ان کے بوروں میں لَعَلَّهُمْ : شاید وہ يَعْرِفُوْنَهَآ : اس کو معلوم کرلیں اِذَا انْقَلَبُوْٓا : جب وہ لوٹیں اِلٰٓى : طرف اَهْلِهِمْ : اپنے لوگ لَعَلَّهُمْ : شاید وہ يَرْجِعُوْنَ : پھر آجائیں اپنے خدمت گاروں سے کہا کہ (1) ان کی پونجی انہی کی بوریوں میں رکھ دو (2) کہ جب لوٹ کر اپنے اہل و عیال میں جائیں اور پونجیوں کو پہچان لیں تو بہت ممکن ہے کہ پھر لوٹ کر آئیں۔
12,63,فَلَمَّا رَجَعُوْۤا اِلٰۤى اَبِیْهِمْ قَالُوْا یٰۤاَبَانَا مُنِعَ مِنَّا الْكَیْلُ فَاَرْسِلْ مَعَنَاۤ اَخَانَا نَكْتَلْ وَ اِنَّا لَهٗ لَحٰفِظُوْنَ فَلَمَّا : پس جب رَجَعُوْٓا : وہ لوٹے اِلٰٓى : طرف اَبِيْهِمْ : اپنا باپ قَالُوْا : وہ بولے يٰٓاَبَانَا : اے ہمارے ابا مُنِعَ : روک دیا گیا مِنَّا : ہم سے الْكَيْلُ : ناپ فَاَرْسِلْ : پس بھیجدیں مَعَنَآ : ہمارے ساتھ اَخَانَا : ہمارے بھائی کو نَكْتَلْ : ناپ (غلہ) لائیں وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَحٰفِظُوْنَ : نگہبان ہیں جب یہ لوگ لوٹ کر اپنے والد کے پاس گئے تو کہنے لگے کہ ہم سے تو غلہ کا ناپ روک لیا گیا (1) اب آپ ہمارے ساتھ بھائی کو بھیجئے کہ ہم پیمانہ بھر کر لائیں ہم اس کی نگہبانی کے ذمہ دار ہیں۔
12,64,قَالَ هَلْ اٰمَنُكُمْ عَلَیْهِ اِلَّا كَمَاۤ اَمِنْتُكُمْ عَلٰۤى اَخِیْهِ مِنْ قَبْلُ١ؕ فَاللّٰهُ خَیْرٌ حٰفِظًا١۪ وَّ هُوَ اَرْحَمُ الرّٰحِمِیْنَ قَالَ : اس نے کہا هَلْ اٰمَنُكُمْ : کیا میں تمہارا اعتبار کروں عَلَيْهِ : اس کے متعلق اِلَّا : مگر كَمَآ : جیسے اَمِنْتُكُمْ : میں نے تمہارا اعتبار کیا عَلٰٓي اَخِيْهِ : اس کے بھائی کے متعلق مِنْ قَبْلُ : اس سے پہلے فَاللّٰهُ : سو اللہ خَيْرٌ : بہتر حٰفِظًا : نگہبان وَّهُوَ : اور وہ اَرْحَمُ الرّٰحِمِيْنَ : تمام مہربانوں سے بڑا مہربانی کرنیوالا ہے (یعقوب ؑ نے) کہا مجھے تو اس کی بابت تمہارا بس ویسا ہی اعتبار ہے، جیسا اس سے پہلے اس کے بھائی کے بارے میں تھا (1) بس اللہ ہی بہترین محافظ ہے اور وہ سب مہربانوں سے بڑا مہربان ہے۔ 2
12,65,وَ لَمَّا فَتَحُوْا مَتَاعَهُمْ وَجَدُوْا بِضَاعَتَهُمْ رُدَّتْ اِلَیْهِمْ١ؕ قَالُوْا یٰۤاَبَانَا مَا نَبْغِیْ١ؕ هٰذِهٖ بِضَاعَتُنَا رُدَّتْ اِلَیْنَا١ۚ وَ نَمِیْرُ اَهْلَنَا وَ نَحْفَظُ اَخَانَا وَ نَزْدَادُ كَیْلَ بَعِیْرٍ١ؕ ذٰلِكَ كَیْلٌ یَّسِیْرٌ وَلَمَّا : اور جب فَتَحُوْا : انہوں نے کھولا مَتَاعَهُمْ : اپنا سامان وَجَدُوْا : انہوں نے پائی بِضَاعَتَهُمْ : اپنی پونجی رُدَّتْ : واپس کردی گئی اِلَيْهِمْ : ان کی طرف (انہیں) قَالُوْا : بولے يٰٓاَبَانَا : اے ہمارے ابا مَا نَبْغِيْ : کیا چاہتے ہیں ہم هٰذِهٖ : یہ بِضَاعَتُنَا : ہماری پونجی رُدَّتْ : لوٹا دی گئی اِلَيْنَا : ہماری طرف وَنَمِيْرُ : اور ہم غلہ لائینگے اَهْلَنَا : اپنے گھر وَنَحْفَظُ : اور ہم حفاظت کرینگے اَخَانَا : اپنا بھائی وَنَزْدَادُ : اور زیادہ لیں گے كَيْلَ : بوجھ بَعِيْرٍ : ایک اونٹ ذٰلِكَ : یہ كَيْلٌ : بوجھ (غلہ) يَّسِيْرٌ : آسان (تھوڑا) جب انہوں نے اپنا اسباب کھولا تو اپنا سرمایا موجود پایا جو ان کی جانب لوٹا دیا گیا تھا کہنے لگے اے ہمارے باپ ہمیں اور کیا چاہیے (1) دیکھئے تو ہمارا سرمایا بھی واپس لوٹا دیا گیا ہے، ہم اپنے خاندان کو رسد لا دیں گے اور اپنے بھائی کی نگرانی رکھیں گے اور ایک اونٹ کے بوجھ کا غلہ زیادہ لائیں گے (1) یہ ناپ تو بہت آسان ہے (3)۔
12,66,قَالَ لَنْ اُرْسِلَهٗ مَعَكُمْ حَتّٰى تُؤْتُوْنِ مَوْثِقًا مِّنَ اللّٰهِ لَتَاْتُنَّنِیْ بِهٖۤ اِلَّاۤ اَنْ یُّحَاطَ بِكُمْ١ۚ فَلَمَّاۤ اٰتَوْهُ مَوْثِقَهُمْ قَالَ اللّٰهُ عَلٰى مَا نَقُوْلُ وَكِیْلٌ قَالَ : اس نے کہا لَنْ اُرْسِلَهٗ : ہرگز نہ بھیجوں گا اسے مَعَكُمْ : تمہارے ساتھ حَتّٰى : یہانتک تُؤْتُوْنِ : تم دو مجھے مَوْثِقًا : پختہ عہد مِّنَ اللّٰهِ : اللہ کی طرف سے لَتَاْتُنَّنِيْ بِهٖٓ : تم لے آؤ گے ضرور میرے پاس اس کو اِلَّآ : مگر اَنْ : یہ کہ يُّحَاطَ : گھیر لیا جائے بِكُمْ : تمہیں فَلَمَّآ : پھر جب اٰتَوْهُ : انہوں نے اسے دیا مَوْثِقَهُمْ : اپنا پختہ عہد قَالَ : کہا اس نے اللّٰهُ : اللہ عَلٰي : پر مَا نَقُوْلُ : جو ہم کہتے ہیں وَكِيْلٌ : نگہبان (ضامن) یعقوب ؑ نے کہا ! میں تو اسے ہرگز ہرگز تمہارے ساتھ نہ بھیجوں گا جب تک کہ تم اللہ کو بیچ میں رکھ کر مجھے قول وقرار نہ دو کہ تم اسے میرے پاس پہنچا دو گے، سوائے اس ایک صورت کے کہ تم سب گرفتار کر لئے جاؤ (1) جب انہوں نے پکا قول قرار دے دیا تو انہوں نے کہا کہ ہم جو کچھ کہتے ہیں اللہ اس پر نگہبان ہے۔
12,67,وَ قَالَ یٰبَنِیَّ لَا تَدْخُلُوْا مِنْۢ بَابٍ وَّاحِدٍ وَّ ادْخُلُوْا مِنْ اَبْوَابٍ مُّتَفَرِّقَةٍ١ؕ وَ مَاۤ اُغْنِیْ عَنْكُمْ مِّنَ اللّٰهِ مِنْ شَیْءٍ١ؕ اِنِ الْحُكْمُ اِلَّا لِلّٰهِ١ؕ عَلَیْهِ تَوَكَّلْتُ١ۚ وَ عَلَیْهِ فَلْیَتَوَكَّلِ الْمُتَوَكِّلُوْنَ وَقَالَ : اور اس نے کہا يٰبَنِيَّ : اے میرے بیٹو لَا تَدْخُلُوْا : تم نہ داخل ہونا مِنْ : سے بَابٍ وَّاحِدٍ : ایک دروازہ وَّادْخُلُوْا : اور داخل ہونا مِنْ : سے اَبْوَابٍ : دروازے مُّتَفَرِّقَةٍ : جدا جدا وَمَآ اُغْنِيْ : اور میں نہیں بچا سکتا عَنْكُمْ : تم سے (کو) مِّنَ : سے (کی) اللّٰهِ : اللہ مِنْ شَيْءٍ : کیس چیز (بات) سے اِنِ : نہیں الْحُكْمُ : حکم اِلَّا : سوا لِلّٰهِ : اللہ کا عَلَيْهِ : اس پر تَوَكَّلْتُ : میں نے بھرسہ کیا وَعَلَيْهِ : اور اس پر فَلْيَتَوَكَّلِ : پس چاہیے بھروسہ کریں الْمُتَوَكِّلُوْنَ : بھروسہ کرنے والے اور (یعقوب علیہ السلام) نے کہا اے میرے بچو ! تم سب ایک دروازے سے نہ جانا بلکہ کئی جدا جدا دروازوں میں سے داخل ہونا (1) میں اللہ کی طرف سے آنے والی کسی چیز کو تم سے ٹال نہیں سکتا حکم صرف اللہ ہی کا چلتا ہے (2) میرا کامل بھروسہ اسی پر ہے اور ہر ایک بھروسہ کرنے والے کو اسی پر بھروسہ کرنا چاہیئے۔
12,68,وَ لَمَّا دَخَلُوْا مِنْ حَیْثُ اَمَرَهُمْ اَبُوْهُمْ١ؕ مَا كَانَ یُغْنِیْ عَنْهُمْ مِّنَ اللّٰهِ مِنْ شَیْءٍ اِلَّا حَاجَةً فِیْ نَفْسِ یَعْقُوْبَ قَضٰىهَا١ؕ وَ اِنَّهٗ لَذُوْ عِلْمٍ لِّمَا عَلَّمْنٰهُ وَ لٰكِنَّ اَكْثَرَ النَّاسِ لَا یَعْلَمُوْنَ۠    ۧ وَلَمَّا : اور جب دَخَلُوْا : وہ داخل ہوئے مِنْ حَيْثُ : جہاں سے اَمَرَهُمْ : انہیں حکم دیا اَبُوْهُمْ : ان کا باپ مَا كَانَ : نہیں تھا يُغْنِيْ : وہ بچا سکتا عَنْهُمْ : ان سے (انہیں) مِّنَ : سے (کی) اللّٰهِ : اللہ مِنْ : سے شَيْءٍ : کسی چیز (بات) اِلَّا : مگر حَاجَةً : ایک خواہش فِيْ : میں نَفْسِ : دل يَعْقُوْبَ : یعقوب قَضٰىهَا : وہ اسنے پوری کرلی وَاِنَّهٗ : اور بیشک وہ لَذُوْ عِلْمٍ : صاحب علم لِّمَا : اس کا جو عَلَّمْنٰهُ : ہم نے اسے سکھایا وَلٰكِنَّ : اور لیکن اَكْثَرَ : اکثر النَّاسِ : لوگ لَا يَعْلَمُوْنَ : نہیں جانتے جب وہ انھیں راستوں سے جن کا حکم ان کے والد نے انھیں دیا تھا گئے۔ کچھ نہ تھا کہ اللہ نے جو بات مقرر کردی ہے وہ اس سے انھیں ذرا بھی بچا لے۔ مگر یعقوب ؑ کے دل میں ایک خیال پیدا ہوا جسے اس نے پورا کرلیا (1) بلاشبہ وہ ہمارے سکھلائے ہوئے علم کا عالم تھا لیکن اکثر لوگ نہیں جانتے (2)
12,69,وَ لَمَّا دَخَلُوْا عَلٰى یُوْسُفَ اٰوٰۤى اِلَیْهِ اَخَاهُ قَالَ اِنِّیْۤ اَنَا اَخُوْكَ فَلَا تَبْتَئِسْ بِمَا كَانُوْا یَعْمَلُوْنَ وَلَمَّا : اور جب دَخَلُوْا : وہ داخل ہوئے عَلٰي يُوْسُفَ : یوسف کے پاس اٰوٰٓى : اس نے جگہ دی اِلَيْهِ : اپنے پاس اَخَاهُ : اپنا بھائی قَالَ : اس نے کہا اِنِّىْٓ : بیشک میں اَنَا اَخُوْكَ : میں تیرا بھائی فَلَا تَبْتَئِسْ : سو تو غمگین نہ ہو بِمَا : اس پر جو كَانُوْا : وہ کرتے تھے يَعْمَلُوْنَ : وہ کرتے تھے یہ سب جب یوسف کے پاس پہنچ گئے تو اس نے اپنے بھائی کو اپنے پاس بٹھا لیا اور کہا کہ میں تیرا بھائی (یوسف) ہوں پس یہ جو کچھ کرتے رہے اس کا کچھ رنج نہ کر (1)۔
12,70,فَلَمَّا جَهَّزَهُمْ بِجَهَازِهِمْ جَعَلَ السِّقَایَةَ فِیْ رَحْلِ اَخِیْهِ ثُمَّ اَذَّنَ مُؤَذِّنٌ اَیَّتُهَا الْعِیْرُ اِنَّكُمْ لَسٰرِقُوْنَ فَلَمَّا : پھر جب جَهَّزَهُمْ : انہیں تیار کردیا بِجَهَازِهِمْ : ان کا سامان جَعَلَ : رکھ دیا السِّقَايَةَ : پینے کا پیالہ فِيْ : میں رَحْلِ : سامان اَخِيْهِ : اپنا بھائی ثُمَّ : پھر اَذَّنَ : اعلان کیا مُؤَذِّنٌ : منادی کرنیوالا اَيَّتُهَا الْعِيْرُ : اے قافلے والو اِنَّكُمْ : بیشک تم لَسٰرِقُوْنَ : البتہ چور ہو پھر جب انھیں ان کا سامان اسباب ٹھیک ٹھاک کر کے دیا تو اپنے بھائی کے اسباب میں پانی پینے کا پیالہ (1) رکھوا دیا پھر ایک آواز دینے والے نے پکار کر کہا کہ اے قافلے والو ! (2) تم لوگ تو چور ہو (3)۔
12,71,قَالُوْا وَ اَقْبَلُوْا عَلَیْهِمْ مَّا ذَا تَفْقِدُوْنَ قَالُوْا : وہ بولے وَاَقْبَلُوْا : اور انہوں نے منہ کیا عَلَيْهِمْ : ان کی طرف مَّاذَا : کیا ہے جو تَفْقِدُوْنَ : تم گم کر بیٹھے انہوں نے ان کی طرف منہ پھیر کر کہا تمہاری کیا چیز کھو گئی ہے ؟
12,72,قَالُوْا نَفْقِدُ صُوَاعَ الْمَلِكِ وَ لِمَنْ جَآءَ بِهٖ حِمْلُ بَعِیْرٍ وَّ اَنَا بِهٖ زَعِیْمٌ قَالُوْا : انہوں نے کہا نَفْقِدُ : ہم گم کر بیٹھے (نہیں پاتے) صُوَاعَ : پیمانہ الْمَلِكِ : بادشاہ وَلِمَنْ : اور اس کے لیے جَآءَ بِهٖ : جو وہ لائے حِمْلُ : بوجھ بَعِيْرٍ : ایک اونٹ وَّاَنَا : اور میں بِهٖ : اس کا زَعِيْمٌ : ضامن جواب دیا کہ شاہی پیمانہ گم ہے جو اسے لے آئے اسے ایک اونٹ کے بوجھ کا غلہ ملے گا۔ اس وعدے کا میں ضامن ہوں (1)
12,73,قَالُوْا تَاللّٰهِ لَقَدْ عَلِمْتُمْ مَّا جِئْنَا لِنُفْسِدَ فِی الْاَرْضِ وَ مَا كُنَّا سٰرِقِیْنَ قَالُوْا : وہ بولے تَاللّٰهِ : اللہ کی قسم لَقَدْ عَلِمْتُمْ : تم خوب جانتے ہو مَّا جِئْنَا : ہم نہیں آئے لِنُفْسِدَ : کہ ہم فساد کریں فِي الْاَرْضِ : زمین (ملک) میں وَمَا كُنَّا : اور ہم نہیں سٰرِقِيْنَ : چور (جمع) انہوں نے کہا اللہ کی قسم ! تم کو خوب علم ہے کہ ہم ملک میں فساد پھیلانے کے لئے نہیں آئے اور نہ ہم چور ہیں۔
12,74,قَالُوْا فَمَا جَزَآؤُهٗۤ اِنْ كُنْتُمْ كٰذِبِیْنَ قَالُوْا : انہوں نے کہا فَمَا : پھر کیا جَزَآؤُهٗٓ : سزا اس کی اِنْ : اگر كُنْتُمْ : تم ہو كٰذِبِيْنَ : جھوٹے انہوں نے کہا اچھا چور کی کیا سزا اگر تم جھوٹے ہو ؟ (1)
12,75,قَالُوْا جَزَآؤُهٗ مَنْ وُّجِدَ فِیْ رَحْلِهٖ فَهُوَ جَزَآؤُهٗ١ؕ كَذٰلِكَ نَجْزِی الظّٰلِمِیْنَ قَالُوْا : کہنے لگے وہ جَزَآؤُهٗ : اس کی سزا مَنْ : جو۔ جس وُّجِدَ : پایا جائے فِيْ رَحْلِهٖ : اس کے سامان میں فَهُوَ : پس وہی جَزَآؤُهٗ : اس کا بدلہ كَذٰلِكَ : اسی طرح نَجْزِي : ہم سزا دیتے ہیں الظّٰلِمِيْنَ : ظالموں کو جواب دیا اس کی سزا یہی ہے کہ جس کے اسباب میں سے پایا جائے وہی اس کا بدلہ ہے (1) ہم تو ایسے ظالموں کو یہی سزا دیا کرتے ہیں (2)۔
12,76,فَبَدَاَ بِاَوْعِیَتِهِمْ قَبْلَ وِعَآءِ اَخِیْهِ ثُمَّ اسْتَخْرَجَهَا مِنْ وِّعَآءِ اَخِیْهِ١ؕ كَذٰلِكَ كِدْنَا لِیُوْسُفَ١ؕ مَا كَانَ لِیَاْخُذَ اَخَاهُ فِیْ دِیْنِ الْمَلِكِ اِلَّاۤ اَنْ یَّشَآءَ اللّٰهُ١ؕ نَرْفَعُ دَرَجٰتٍ مَّنْ نَّشَآءُ١ؕ وَ فَوْقَ كُلِّ ذِیْ عِلْمٍ عَلِیْمٌ فَبَدَاَ : پس شروع کیا بِاَوْعِيَتِهِمْ : ان کی خرجیوں (بوروں) سے قَبْلَ : پہلے وِعَآءِ : کر جی (بورا) اَخِيْهِ : اپنا بھائی ثُمَّ : پھر اسْتَخْرَجَهَا : اس کو نکالا مِنْ : سے وِّعَآءِ : بورا اَخِيْهِ : اپنا بھائی كَذٰلِكَ : اسی طرح كِدْنَا : ہم نے تدبیر کی لِيُوْسُفَ : یوسف کے لیے مَا كَان : نہ تھا لِيَاْخُذَ : وہ لے سکتا اَخَاهُ : اپنا بھائی فِيْ : میں دِيْنِ الْمَلِكِ : بادشاہ کا دین اِلَّآ : مگر اَنْ : یہ کہ يَّشَآءَ اللّٰهُ : اللہ چاہے نَرْفَعُ : ہم بلند کرتے ہیں دَرَجٰتٍ : درجے مَّنْ : جو۔ جس نَّشَآءُ : چاہیں ہم وَفَوْقَ : اور اوپر كُلِّ : ہر ذِيْ عِلْمٍ : صاحب علم عَلِيْمٌ : ایک علم والا پس یوسف نے ان کے سامان کی تلاشی شروع کی، اپنے بھائی کے سامان کی تلاشی سے پہلے، پھر اس پیمانہ کو اپنے بھائی کے سامان (زنبیل) سے نکالا (1) ہم نے یوسف کے لئے اسی طرح یہ تدبیر کی (2) اس بادشاہ کی قانون کی رو سے یہ اپنے بھائی کو نہ لے جاسکتا تھا (3) مگر یہ کہ اللہ کو منظور ہو ہم جس کے چاہیں درجے بلند کردیں (4) ہر ذی علم پر فوقیت رکھنے والا دوسرا ذی علم موجود ہے (5)۔
12,77,قَالُوْۤا اِنْ یَّسْرِقْ فَقَدْ سَرَقَ اَخٌ لَّهٗ مِنْ قَبْلُ١ۚ فَاَسَرَّهَا یُوْسُفُ فِیْ نَفْسِهٖ وَ لَمْ یُبْدِهَا لَهُمْ١ۚ قَالَ اَنْتُمْ شَرٌّ مَّكَانًا١ۚ وَ اللّٰهُ اَعْلَمُ بِمَا تَصِفُوْنَ قَالُوْٓا : بولے اِنْ : اگر يَّسْرِقْ : اس نے چرایا فَقَدْ سَرَقَ : تو چوری کی تھی اَخٌ لَّهٗ : اس کا بھائی مِنْ قَبْلُ : اس سے قبل فَاَسَرَّهَا : پس اسے چھپایا يُوْسُفُ : یوسف فِيْ نَفْسِهٖ : اپنے دل میں وَلَمْ يُبْدِهَا : اور وہ ظاہر نہ کیا لَهُمْ : ان پر قَالَ : کہا اَنْتُمْ : تم شَرٌّ : بدتر مَّكَانًا : درجہ میں وَاللّٰهُ : اور اللہ اَعْلَمُ : خوب جانتا ہے بِمَا تَصِفُوْنَ : جو تم بیان کرتے ہو انہوں نے کہا اگر اس نے چوری کی (تو کوئی تعجب کی بات نہیں) اس کا بھائی بھی پہلے چوری کرچکا ہے (1) یوسف ؑ نے اس بات کو اپنے دل میں رکھ لیا اور ان کے سامنے بالکل ظاہر نہ کیا۔ کہا کہ تم بدتر جگہ میں ہو (2) اور جو تم بیان کرتے ہو اسے اللہ ہی خوب جانتا ہے۔
12,78,قَالُوْا یٰۤاَیُّهَا الْعَزِیْزُ اِنَّ لَهٗۤ اَبًا شَیْخًا كَبِیْرًا فَخُذْ اَحَدَنَا مَكَانَهٗ١ۚ اِنَّا نَرٰىكَ مِنَ الْمُحْسِنِیْنَ قَالُوْا : کہنے لگے يٰٓاَيُّهَا : اے الْعَزِيْزُ : عزیز اِنَّ : بیشک لَهٗٓ : اس کا اَبًا : باپ شَيْخًا : بوڑھا كَبِيْرًا : بڑی عمر کا فَخُذْ : پس لے (رکھ لے) اَحَدَنَا : ہم میں سے ایک مَكَانَهٗ : اس کی جگہ اِنَّا نَرٰىكَ : ہم دیکھتے ہیں بیشک تجھے مِنَ : سے الْمُحْسِنِيْنَ : احسان کرنے والے انہوں نے کہا اے عزیز مصر ! (1) اس کے والد بہت بڑی عمر کے بالکل بوڑھے شخص ہیں آپ اس کے بدلے ہم میں سے کسی کو لے لیجئے، ہم دیکھتے ہیں کہ آپ بڑے نیک نفس ہیں (2)۔
12,79,قَالَ مَعَاذَ اللّٰهِ اَنْ نَّاْخُذَ اِلَّا مَنْ وَّجَدْنَا مَتَاعَنَا عِنْدَهٗۤ١ۙ اِنَّاۤ اِذًا لَّظٰلِمُوْنَ۠    ۧ قَالَ : اس نے کہا مَعَاذَ اللّٰهِ : اللہ کی پناہ اَنْ : کہ نَّاْخُذَ : ہم پکڑیں اِلَّا : سوا مَنْ : جس کو وَّجَدْنَا : ہم نے پایا مَتَاعَنَا : اپنا سامان عِنْدَهٗٓ : اس کے پاس اِنَّآ اِذًا : بیشک ہم جب لَّظٰلِمُوْنَ : البتہ ظالموں سے یوسف ؑ نے کہا ہم نے جس کے پاس اپنی چیز پائی ہے اس کے سوا دوسرے کی گرفتاری کرنے سے اللہ کی پناہ چاہتے ہیں، ایسا کرنے سے تو ہم یقیناً ناانصافی کرنے والے ہوجائیں گے (1)۔
12,80,فَلَمَّا اسْتَیْئَسُوْا مِنْهُ خَلَصُوْا نَجِیًّا١ؕ قَالَ كَبِیْرُهُمْ اَلَمْ تَعْلَمُوْۤا اَنَّ اَبَاكُمْ قَدْ اَخَذَ عَلَیْكُمْ مَّوْثِقًا مِّنَ اللّٰهِ وَ مِنْ قَبْلُ مَا فَرَّطْتُّمْ فِیْ یُوْسُفَ١ۚ فَلَنْ اَبْرَحَ الْاَرْضَ حَتّٰى یَاْذَنَ لِیْۤ اَبِیْۤ اَوْ یَحْكُمَ اللّٰهُ لِیْ١ۚ وَ هُوَ خَیْرُ الْحٰكِمِیْنَ فَلَمَّا : پھر جب اسْتَيْئَسُوْا : وہ مایوس ہوگئے مِنْهُ : اس سے خَلَصُوْا : اکیلے ہو بیٹھے نَجِيًّا : مشورہ کیا قَالَ : کہا كَبِيْرُهُمْ : ان کا بڑا اَلَمْ تَعْلَمُوْٓا : کیا تم نہیں جانتے اَنَّ : کہ اَبَاكُمْ : تمہارا باپ قَدْ اَخَذَ : لیا ہے عَلَيْكُمْ : تم سے مَّوْثِقًا : پختہ عہد مِّنَ : سے (کام) اللّٰهِ : اللہ وَ : اور مِنْ قَبْلُ : اس سے قبل مَا فَرَّطْتُّمْ : جو تقصیر کی تم نے فِيْ : بارہ میں يُوْسُفَ : یوسف فَلَنْ : پس ہرگز نہ اَبْرَحَ : ٹلوں گا الْاَرْضَ : زمین حَتّٰى : یہاں تک يَاْذَنَ : اجازت دے لِيْٓ : مجھے اَبِيْٓ : میرا باپ اَوْ : یا يَحْكُمَ اللّٰهُ لِيْ : حکم دے (تدبیر نکالے اللہ) میرے لیے وَهُوَ : اور وہ خَيْرُ الْحٰكِمِيْنَ : سب سے بہتر فیصلہ کرنے والا جب یہ اس سے مایوس ہوگئے تو تنہائی میں بیٹھ کر مشورہ کرنے لگے (1) ان میں جو سب سے بڑا تھا اس نے کہا تمہیں معلوم نہیں کہ تمہارے والد نے تم سے اللہ کی قسم لے کر پختہ قول قرار لیا ہے اور اس سے پہلے یوسف کے بارے میں تم کوتاہی کرچکے ہو۔ پس میں تو اس سرزمین سے نہ ٹلوں گا جب تک کہ والد صاحب خود مجھے اجازت نہ دیں (2) یا اللہ تعالیٰ میرے اس معاملے کا فیصلہ کر دے، وہی بہترین فیصلہ کرنے والا ہے۔
12,81,اِرْجِعُوْۤا اِلٰۤى اَبِیْكُمْ فَقُوْلُوْا یٰۤاَبَانَاۤ اِنَّ ابْنَكَ سَرَقَ١ۚ وَ مَا شَهِدْنَاۤ اِلَّا بِمَا عَلِمْنَا وَ مَا كُنَّا لِلْغَیْبِ حٰفِظِیْنَ اِرْجِعُوْٓا : لوٹ جاؤ تم اِلٰٓى : طرف (پاس) اَبِيْكُمْ : اپنا باپ فَقُوْلُوْا : پس کہو يٰٓاَبَانَآ : اے ہمارے باپ اِنَّ : بیشک ابْنَكَ : تمہارا بیٹا سَرَقَ : چوری کی وَمَا شَهِدْنَآ : اور نہیں گواہی دی ہم نے اِلَّا : مگر بِمَا : جو عَلِمْنَا : ہمیں معلوم تھا وَمَا كُنَّا : اور ہم نہ تھے لِلْغَيْبِ : غیب کے حٰفِظِيْنَ : نگہبان تم سب والد صاحب کی خدمت میں واپس جاؤ اور کہو کہ ابا جی ! آپ کے صاحب زادے نے چوری کی اور ہم نے وہی گواہی دی تھی جو ہم جانتے تھے (1) ہم کچھ غیب کی حفاظت کرنے والے نہ تھے (2)۔
12,82,وَ سْئَلِ الْقَرْیَةَ الَّتِیْ كُنَّا فِیْهَا وَ الْعِیْرَ الَّتِیْۤ اَقْبَلْنَا فِیْهَا١ؕ وَ اِنَّا لَصٰدِقُوْنَ وَسْئَلِ : اور پوچھ لیں آپ الْقَرْيَةَ : بستی الَّتِيْ : جو جس كُنَّا : ہم تھے فِيْهَا : اس میں وَالْعِيْرَ : اور قافلہ الَّتِيْٓ : جو۔ جس اَقْبَلْنَا : ہم آئے فِيْهَا : اس میں وَاِنَّا : اور بیشک ہم لَصٰدِقُوْنَ : سچے آپ اس شہر کے لوگوں سے دریافت فرما لیں جہاں ہم تھے اور اس قافلہ سے بھی پوچھ لیں جس کے ساتھ ہم آئے ہیں۔ اور یقیناً ہم بالکل سچے ہیں (1)۔
12,83,قَالَ بَلْ سَوَّلَتْ لَكُمْ اَنْفُسُكُمْ اَمْرًا١ؕ فَصَبْرٌ جَمِیْلٌ١ؕ عَسَى اللّٰهُ اَنْ یَّاْتِیَنِیْ بِهِمْ جَمِیْعًا١ؕ اِنَّهٗ هُوَ الْعَلِیْمُ الْحَكِیْمُ قَالَ : اس نے کہا بَلْ : بلکہ سَوَّلَتْ : بنا لی ہے لَكُمْ : تمہارے لیے اَنْفُسُكُمْ : تمہارا دل اَمْرًا : ایک بات فَصَبْرٌ : پس صبر جَمِيْلٌ : اچھا عَسَى : شاید اللّٰهُ : اللہ اَنْ يَّاْتِيَنِيْ : کہ میرے پاس لے آئے بِهِمْ : انہیں جَمِيْعًا : سب کو اِنَّهٗ : بیشک وہ هُوَ : وہ الْعَلِيْمُ : جاننے والا الْحَكِيْمُ : حکمت والا (یعقوب علیہ السلام) نے کہا یہ تو نہیں، بلکہ تم نے اپنی طرف سے بات بنا لی (1) پس اب صبر ہی بہتر ہے۔ قریب ہے کہ اللہ تعالیٰ ان سب کو میرے پاس ہی پہنچا دے (2) وہی علم و حکمت والا ہے۔
12,84,وَ تَوَلّٰى عَنْهُمْ وَ قَالَ یٰۤاَسَفٰى عَلٰى یُوْسُفَ وَ ابْیَضَّتْ عَیْنٰهُ مِنَ الْحُزْنِ فَهُوَ كَظِیْمٌ وَتَوَلّٰى : اور منہ پھیرلیا عَنْهُمْ : ان سے وَقَالَ : اور کہا يٰٓاَسَفٰى : ہائے افسوس عَلٰي : پر يُوْسُفَ : یوسف وَابْيَضَّتْ : اور سفید ہوگئیں عَيْنٰهُ : اس کی آنکھیں مِنَ : سے الْحُزْنِ : غم فَهُوَ : پس وہ كَظِيْمٌ : گھونٹ رہا تھا پھر ان سے منہ پھیرلیا اور کہا ہائے یوسف ! (1) ان کی آنکھیں بوجہ رنج و غم کے سفید ہوچکی تھیں (2) اور وہ غم کو دبائے ہوئے تھے۔
12,85,قَالُوْا تَاللّٰهِ تَفْتَؤُا تَذْكُرُ یُوْسُفَ حَتّٰى تَكُوْنَ حَرَضًا اَوْ تَكُوْنَ مِنَ الْهٰلِكِیْنَ قَالُوْا : وہ بولے تَاللّٰهِ : اللہ کی قسم تَفْتَؤُا : تو ہمیشہ رہے گا تَذْكُرُ : یاد کرتا يُوْسُفَ : یوسف حَتّٰى : یہانتک کہ تَكُوْنَ : تم ہوجاؤ حَرَضًا : بیمار اَوْ تَكُوْنَ : یا ہوجاؤ مِنَ : سے الْهٰلِكِيْنَ : ہلاک ہونے والے بیٹوں نے کہا واللہ ! آپ ہمیشہ یوسف کی یاد ہی میں لگے رہیں گے یہاں تک کہ گھل جائیں یا ختم ہی ہوجائیں (1)۔
12,86,قَالَ اِنَّمَاۤ اَشْكُوْا بَثِّیْ وَ حُزْنِیْۤ اِلَى اللّٰهِ وَ اَعْلَمُ مِنَ اللّٰهِ مَا لَا تَعْلَمُوْنَ قَالَ : اس نے کہا اِنَّمَآ : میں تو صرف اَشْكُوْا : بیان کرتا ہوں بَثِّيْ : اپنی بیقراری وَحُزْنِيْٓ : اور اپنا غم اِلَى : طرف سامنے اللّٰهِ : اللہ وَاَعْلَمُ : اور جانتا ہوں مِنَ : سے اللّٰهِ : اللہ مَا : جو لَا تَعْلَمُوْنَ : تم نہیں جانتے انہوں نے کہا کہ میں تو اپنی پریشانیوں اور رنج کی فریاد اللہ ہی سے کر رہا ہوں مجھے اللہ کی طرف سے وہ باتیں معلوم ہیں جو تم نہیں جانتے (1)۔
12,87,یٰبَنِیَّ اذْهَبُوْا فَتَحَسَّسُوْا مِنْ یُّوْسُفَ وَ اَخِیْهِ وَ لَا تَایْئَسُوْا مِنْ رَّوْحِ اللّٰهِ١ؕ اِنَّهٗ لَا یَایْئَسُ مِنْ رَّوْحِ اللّٰهِ اِلَّا الْقَوْمُ الْكٰفِرُوْنَ يٰبَنِيَّ : اے میرے بیٹو اذْهَبُوْا : تم جاؤ فَتَحَسَّسُوْا : پس کھوج نکالو مِنْ : سے (کا يُّوْسُفَ : یوسف وَاَخِيْهِ : اور اس کا بھائی وَلَا تَايْئَسُوْا : اور نہ مایوس ہو مِنْ : سے رَّوْحِ اللّٰهِ : اللہ کی رحمت اِنَّهٗ : بیشک وہ لَا يَايْئَسُ : مایوس نہیں ہوتے مِنْ : سے رَّوْحِ اللّٰهِ : اللہ کی رحمت اِلَّا : مگر الْقَوْمُ : لوگ الْكٰفِرُوْنَ : کافر (جمع) میرے پیارے بچو ! تم جاؤ اور یوسف ؑ کی اور اس کے بھائی کی پوری طرح تلاش کرو (1) اور اللہ کی رحمت سے ناامید نہ ہو۔ یقیناً رب کی رحمت سے ناامید وہی ہوتے ہیں جو کافر ہوتے ہیں (2)۔
12,88,فَلَمَّا دَخَلُوْا عَلَیْهِ قَالُوْا یٰۤاَیُّهَا الْعَزِیْزُ مَسَّنَا وَ اَهْلَنَا الضُّرُّ وَ جِئْنَا بِبِضَاعَةٍ مُّزْجٰىةٍ فَاَوْفِ لَنَا الْكَیْلَ وَ تَصَدَّقْ عَلَیْنَا١ؕ اِنَّ اللّٰهَ یَجْزِی الْمُتَصَدِّقِیْنَ فَلَمَّا : پھر جب دَخَلُوْا : وہ داخل ہوئے عَلَيْهِ : اس پر۔ سامنے قَالُوْا : انہوں نے کہا يٰٓاَيُّهَا : اے الْعَزِيْزُ : عزیز مَسَّنَا : ہمیں پہنچی وَاَهْلَنَا : اور ہمارے گھر الضُّرُّ : سختی وَجِئْنَا : اور ہم آئے بِبِضَاعَةٍ : پونچی کے ساتھ (لے کر) مُّزْجٰىةٍ : نکمی (ناقص) فَاَوْفِ : پس پوری دیں لَنَا : ہمیں الْكَيْلَ : ناپ (غلہ) وَتَصَدَّقْ : صدقہ کریں عَلَيْنَا : ہم پر (ہمیں) اِنَّ اللّٰهَ : بیشک اللہ يَجْزِي : جزا دیتا ہے الْمُتَصَدِّقِيْنَ : صدقہ کرنے والے پھر جب یہ لوگ یوسف ؑ کے پاس پہنچے (1) تو کہنے لگے کہ اے عزیز ! ہم کو اور ہمارے خاندان کو دکھ پہنچا ہے (2) ہم حقیر پونجی لائے ہیں پس آپ ہمیں پورے غلے کا ناپ دیجئے (3) اور ہم پر خیرات کیجئے (4) اللہ تعالیٰ خیرات کرنے والوں کو بدلہ دیتا ہے۔
12,89,قَالَ هَلْ عَلِمْتُمْ مَّا فَعَلْتُمْ بِیُوْسُفَ وَ اَخِیْهِ اِذْ اَنْتُمْ جٰهِلُوْنَ قَالَ : کہا هَلْ عَلِمْتُمْ : کیا تمہیں خبر ہے مَّا فَعَلْتُمْ : کیا تم نے کیا ہے بِيُوْسُفَ : یوسف کے ساتھ وَاَخِيْهِ : اور اس کا بھائی اِذْ اَنْتُمْ : جب تم جٰهِلُوْنَ : نادان یوسف نے کہا جانتے بھی ہو کہ تم نے یوسف اور اس کے بھائی کے ساتھ اپنی نادانی کی حالت میں کیا کیا (1) ؟
12,90,قَالُوْۤا ءَاِنَّكَ لَاَنْتَ یُوْسُفُ١ؕ قَالَ اَنَا یُوْسُفُ وَ هٰذَاۤ اَخِیْ١٘ قَدْ مَنَّ اللّٰهُ عَلَیْنَا١ؕ اِنَّهٗ مَنْ یَّتَّقِ وَ یَصْبِرْ فَاِنَّ اللّٰهَ لَا یُضِیْعُ اَجْرَ الْمُحْسِنِیْنَ قَالُوْٓا : وہ بولے ءَاِنَّكَ : کیا تم ہی لَاَنْتَ : تم ہی يُوْسُفُ : یوسف قَالَ : اس نے کہا اَنَا يُوْسُفُ : میں یوسف وَهٰذَآ : اور یہ اَخِيْ : میرا بھائی قَدْ مَنَّ : البتہ احسان کیا ہے اللّٰهُ : اللہ عَلَيْنَا : ہم پر اِنَّهٗ : بیشک وہ مَنْ يَّتَّقِ : جو ڈرتا ہے وَيَصْبِرْ : اور صبر کرتا ہے فَاِنَّ اللّٰهَ : تو بیشک اللہ لَا يُضِيْعُ : ضائع نہیں کرتا اَجْرَ : اجر الْمُحْسِنِيْنَ : نیکی کرنے والے انہوں نے کہا کیا (واقعی) تو ہی یوسف ؑ ہے (1) جواب دیا کہ ہاں میں یوسف ؑ ہوں اور یہ میرا بھائی ہے اللہ نے ہم پر فضل و کرم کیا بات یہ ہے کہ جو بھی پرہیزگاری اور صبر کرے تو اللہ تعالیٰ کسی نیکوکار کا اجر ضائع نہیں کرتا (2)۔
12,91,قَالُوْا تَاللّٰهِ لَقَدْ اٰثَرَكَ اللّٰهُ عَلَیْنَا وَ اِنْ كُنَّا لَخٰطِئِیْنَ قَالُوْا : کہنے لگے تَاللّٰهِ : اللہ کی قسم لَقَدْ اٰثَرَكَ : تجھے پسند کیا (فضیلت دی) اللّٰهُ : اللہ عَلَيْنَا : ہم پر وَاِنْ : اور بیشک كُنَّا : ہم تھے لَخٰطِئِيْنَ : خطا کار انہوں نے کہا اللہ کی قسم ! اللہ تعالیٰ نے تجھے ہم پر برتری دی ہے اور یہ بھی بالکل سچ ہے کہ ہم خطا کار تھے (1)
12,92,قَالَ لَا تَثْرِیْبَ عَلَیْكُمُ الْیَوْمَ١ؕ یَغْفِرُ اللّٰهُ لَكُمْ١٘ وَ هُوَ اَرْحَمُ الرّٰحِمِیْنَ قَالَ : اس نے کہا لَا تَثْرِيْبَ : نہیں کوئی ملامت عَلَيْكُمُ : تم پر الْيَوْمَ : آج يَغْفِرُ : بخشے اللّٰهُ : اللہ لَكُمْ : تم کو وَهُوَ : اور وہ اَرْحَمُ : سب سے زیادہ مہربان الرّٰحِمِيْنَ : مہربانی کرنے والے جواب دیا آج تم پر کوئی ملامت نہیں ہے (1) اللہ تمہیں بخشے، وہ سب مہربانوں سے بڑا مہربان ہے۔
12,93,اِذْهَبُوْا بِقَمِیْصِیْ هٰذَا فَاَلْقُوْهُ عَلٰى وَجْهِ اَبِیْ یَاْتِ بَصِیْرًا١ۚ وَ اْتُوْنِیْ بِاَهْلِكُمْ اَجْمَعِیْنَ۠    ۧ اِذْهَبُوْا : تم جاؤ بِقَمِيْصِيْ : میری قمیص لے کر هٰذَا : یہ فَاَلْقُوْهُ : پس اس کو ڈالو عَلٰي : پر وَجْهِ : چہرہ اَبِيْ : میرے باپ يَاْتِ : آئے گا بَصِيْرًا : بینا ہوکر وَاْتُوْنِيْ : اور میرے پاس آؤ (لے آؤ) بِاَهْلِكُمْ : اپنے گھروالوں کو اَجْمَعِيْنَ : تمام (سارے) میرا یہ کرتا تم لے جاؤ اور اسے میرے والد کے منہ پر ڈال دو کہ وہ دیکھنے لگیں (1) اور آجائیں اور اپنے تمام خاندان کو میرے پاس لے آؤ (2)۔
12,94,وَ لَمَّا فَصَلَتِ الْعِیْرُ قَالَ اَبُوْهُمْ اِنِّیْ لَاَجِدُ رِیْحَ یُوْسُفَ لَوْ لَاۤ اَنْ تُفَنِّدُوْنِ وَلَمَّا : اور جب فَصَلَتِ : جدا جدا (روانہ ہو) الْعِيْرُ : قافلہ قَالَ : کہا اَبُوْهُمْ : ان کا باپ اِنِّىْ : بیشک میں لَاَجِدُ : البتہ پاتا ہوں رِيْحَ : ہوا (خوشبو) يُوْسُفَ : یوسف لَوْلَآ : اگر نہ اَنْ : کہ تُفَنِّدُوْنِ : مجھے بہک گیا جانو جب یہ قافلہ جدا ہوا تو ان کے والد نے کہا کہ مجھے تو یوسف کی خوشبو آرہی ہے اگر تم مجھے سٹھیایا ہوا قرار نہ دو (1)
12,95,قَالُوْا تَاللّٰهِ اِنَّكَ لَفِیْ ضَلٰلِكَ الْقَدِیْمِ قَالُوْا : وہ کہنے لگے تَاللّٰهِ : اللہ کی قسم اِنَّكَ : بیشک تو لَفِيْ : میں ضَلٰلِكَ : اپنا وہم الْقَدِيْمِ : پرانا وہ کہنے لگے کہ واللہ آپ اپنے اسی پرانے خبط (1) میں مبتلا ہیں۔
12,96,فَلَمَّاۤ اَنْ جَآءَ الْبَشِیْرُ اَلْقٰىهُ عَلٰى وَجْهِهٖ فَارْتَدَّ بَصِیْرًا١ۚ قَالَ اَلَمْ اَقُلْ لَّكُمْ١ۙۚ اِنِّیْۤ اَعْلَمُ مِنَ اللّٰهِ مَا لَا تَعْلَمُوْنَ فَلَمَّآ : پھر جب اَنْ : کہ جَآءَ : آیا الْبَشِيْرُ : خوشخبری دینے والا اَلْقٰىهُ : اس نے وہ (کرتہ) ڈالا عَلٰي : پر وَجْهِهٖ : اس کا منہ فَارْتَدَّ : تو لوٹ کر ہوگیا بَصِيْرًا : دیکھنے والا قَالَ : بولا اَلَمْ اَقُلْ : کیا میں نے تمہیں کہا تھا لَّكُمْ : تم سے اِنِّىْٓ اَعْلَمُ : بیشک میں جانتا ہوں مِنَ : (طرف) سے اللّٰهِ : اللہ مَا : جو لَا تَعْلَمُوْنَ : تم نہیں جانتے جب خوشخبری دینے والے نے پہنچ کر ان کے منہ پر وہ کرتا ڈالا اسی وقت پھر بینا ہوگئے (1) کہا ! کیا میں تم سے نہ کہا کرتا تھا کہ میں اللہ کی طرف سے وہ باتیں جانتا ہوں جو تم نہیں جانتے (2)۔
12,97,قَالُوْا یٰۤاَبَانَا اسْتَغْفِرْ لَنَا ذُنُوْبَنَاۤ اِنَّا كُنَّا خٰطِئِیْنَ قَالُوْا : وہ بولے يٰٓاَبَانَا : اے ہمارے باپ اسْتَغْفِرْ لَنَا : ہمارے لیے بخشش مانگ ذُنُوْبَنَآ : ہمارے گناہ اِنَّا : بیشک ہم كُنَّا : تھے خٰطِئِيْنَ : خطا کار (جمع) انہوں نے کہا ابا جی آپ ہمارے لئے گناہوں کی بخشش طلب کیجئے بیشک ہم قصور وار ہیں۔
12,98,قَالَ سَوْفَ اَسْتَغْفِرُ لَكُمْ رَبِّیْ١ؕ اِنَّهٗ هُوَ الْغَفُوْرُ الرَّحِیْمُ قَالَ : اس نے کہا سَوْفَ : جلد اَسْتَغْفِرُ : میں بخشش مانگوں گا لَكُمْ : تمہارے لیے رَبِّيْ : اپنا رب اِنَّهٗ : بشیک وہ هُوَ : وہ الْغَفُوْرُ : بخشنے والا الرَّحِيْمُ : نہایت مہربان کہا اچھا میں جلد ہی تمہارے لئے اپنے پروردگار سے بخشش مانگوں گا (1) وہ بہت بڑا بخشنے والا اور نہایت مہربانی کرنے والا ہے۔
12,99,فَلَمَّا دَخَلُوْا عَلٰى یُوْسُفَ اٰوٰۤى اِلَیْهِ اَبَوَیْهِ وَ قَالَ ادْخُلُوْا مِصْرَ اِنْ شَآءَ اللّٰهُ اٰمِنِیْنَؕ فَلَمَّا : پھر جب دَخَلُوْا : وہ داخل ہوئے عَلٰي يُوْسُفَ : یوسف پر (پاس) اٰوٰٓى : اس نے ٹھکانہ دیا اِلَيْهِ : اپنے پاس اَبَوَيْهِ : اپنے ماں باپ وَقَالَ : اور کہا ادْخُلُوْا : تم داخل ہو مِصْرَ : مصر اِنْ : اگر شَآءَ اللّٰهُ : اللہ نے چاہا اٰمِنِيْنَ : امن (دلجمعی) کے ساتھ جب یہ سارا گھرانہ یوسف کے پاس پہنچ گیا تو یوسف نے اپنے ماں باپ کو اپنے پاس جگہ دی (1) اور کہا کہ اللہ کو منظور ہے تو آپ سب امن وامان کے ساتھ مصر میں آؤ۔
12,100,وَ رَفَعَ اَبَوَیْهِ عَلَى الْعَرْشِ وَ خَرُّوْا لَهٗ سُجَّدًا١ۚ وَ قَالَ یٰۤاَبَتِ هٰذَا تَاْوِیْلُ رُءْیَایَ مِنْ قَبْلُ١٘ قَدْ جَعَلَهَا رَبِّیْ حَقًّا١ؕ وَ قَدْ اَحْسَنَ بِیْۤ اِذْ اَخْرَجَنِیْ مِنَ السِّجْنِ وَ جَآءَ بِكُمْ مِّنَ الْبَدْوِ مِنْۢ بَعْدِ اَنْ نَّزَغَ الشَّیْطٰنُ بَیْنِیْ وَ بَیْنَ اِخْوَتِیْ١ؕ اِنَّ رَبِّیْ لَطِیْفٌ لِّمَا یَشَآءُ١ؕ اِنَّهٗ هُوَ الْعَلِیْمُ الْحَكِیْمُ وَرَفَعَ : اور اونچا بٹھایا اَبَوَيْهِ : اپنے ماں باپ عَلَي : پر الْعَرْشِ : تخت وَخَرُّوْا : اور وہ گرگئے لَهٗ : اس کے لیے ( آگے) سُجَّدًا : سجدہ میں وَقَالَ : اور اس نے کہا يٰٓاَبَتِ : اے میرے ابا هٰذَا : یہ تَاْوِيْلُ : تعبیر رُءْيَايَ : میرا خواب مِنْ قَبْلُ : اس سے پہلے قَدْ جَعَلَهَا : اس کو کردیا رَبِّيْ : میرا رب حَقًّا : سچا وَ : اور قَدْ اَحْسَنَ : بیشک اس نے احسان کیا بِيْٓ : مجھ پر اِذْ : جب اَخْرَجَنِيْ : مجھے نکالا مِنَ : سے السِّجْنِ : قید خانہ وَجَآءَ : اور لے آیا بِكُمْ : تم سب کو مِّنَ : سے الْبَدْوِ : گاؤں مِنْۢ بَعْدِ : اس کے بعد اَنْ : کہ نَّزَغَ : جھگڑا ڈالدیا الشَّيْطٰنُ : شیطان بَيْنِيْ : میرے درمیان وَبَيْنَ اِخْوَتِيْ : اور میرے بھائیوں کے درمیان اِنَّ : بیشک رَبِّيْ : میرا رب لَطِيْفٌ : عمدہ تدبیر کرنیوالا لِّمَا يَشَآءُ : جس کے لیے چاہے اِنَّهٗ : بیشک وہ هُوَ : وہ الْعَلِيْمُ : جانے والا الْحَكِيْمُ : حکمت والا اور اپنے تخت پر اپنے ماں باپ (2) کو اونچا بٹھایا اور سب اسکے سامنے سجدے میں گرگئے (2) تب کہا ابا جی ! یہ میرے پہلے کے خواب کی تعبیر ہے (3) میرے رب نے اسے سچا کر دکھایا، اس نے میرے ساتھ بڑا احسان کیا جب کہ مجھے جیل خانے سے نکالا (4) اور آپ لوگوں کو صحرا سے لے آیا (5) اس اختلاف کے بعد جو شیطان نے مجھ میں اور میرے بھائیوں میں ڈال دیا تھا (6) میرا رب جو چاہے اس کے لئے بہترین تدبیر کرنے والا ہے اور وہ بہت علم و حکمت والا ہے۔
12,101,رَبِّ قَدْ اٰتَیْتَنِیْ مِنَ الْمُلْكِ وَ عَلَّمْتَنِیْ مِنْ تَاْوِیْلِ الْاَحَادِیْثِ١ۚ فَاطِرَ السَّمٰوٰتِ وَ الْاَرْضِ١۫ اَنْتَ وَلِیّٖ فِی الدُّنْیَا وَ الْاٰخِرَةِ١ۚ تَوَفَّنِیْ مُسْلِمًا وَّ اَلْحِقْنِیْ بِالصّٰلِحِیْنَ رَبِّ : اے میرے رب قَدْ اٰتَيْتَنِيْ : تونے مجھے عطا کیا مِنَ : سے۔ ایک الْمُلْكِ : ملک وَعَلَّمْتَنِيْ : اور مجھے سکھایا مِنْ : سے تَاْوِيْلِ : انجام نکالنا (تعبیر) الْاَحَادِيْثِ : باتیں (خواب) فَاطِرَ : پیدا کرنے والا السَّمٰوٰتِ : آسمان (جمع) وَالْاَرْضِ : اور زمین اَنْتَ : تو وَلِيّٖ : میرا کارساز فِي الدُّنْيَا : دنیا میں وَالْاٰخِرَةِ : آخرت تَوَفَّنِيْ : مجھے اٹھا مُسْلِمًا : فرمانبرداری کی حالت میں وَّاَلْحِقْنِيْ : اور مجھے ملا بِالصّٰلِحِيْنَ : صالح (نیک بندوں) کے ساتھ اے میرے پروردگار ! تو نے مجھے ملک عطا فرمایا (1) اور تو نے مجھے خواب کی تعبیر سکھلائی (2) اے آسمان و زمین کے پیدا کرنے والے تو دنیا و آخرت میں میرا ولی (دوست) اور کارساز ہے، تو مجھے اسلام کی حالت میں فوت کر اور نیکوں میں ملا دے۔
12,102,ذٰلِكَ مِنْ اَنْۢبَآءِ الْغَیْبِ نُوْحِیْهِ اِلَیْكَ١ۚ وَ مَا كُنْتَ لَدَیْهِمْ اِذْ اَجْمَعُوْۤا اَمْرَهُمْ وَ هُمْ یَمْكُرُوْنَ ذٰلِكَ : یہ مِنْ : سے اَنْۢبَآءِ الْغَيْبِ : غیب کی خبریں نُوْحِيْهِ : ہم وہ وحی کرتے ہیں اِلَيْكَ : تمہاری طرف وَمَا كُنْتَ : اور تم نہ تھے لَدَيْهِمْ : ان کے پاس اِذْ : جب اَجْمَعُوْٓا : انہوں نے جمع کیا (پختہ کیا) اَمْرَهُمْ : اپنا کام وَهُمْ : اور وہ يَمْكُرُوْنَ : چال چل رہے تھے یہ غیب کی خبروں میں سے جس کی ہم آپ کی طرف وحی کر رہے ہیں۔ آپ ان کے پاس نہ تھے جب کہ انہوں نے اپنی بات ٹھان لی تھی اور وہ فریب کرنے لگے تھے (1)
12,103,وَ مَاۤ اَكْثَرُ النَّاسِ وَ لَوْ حَرَصْتَ بِمُؤْمِنِیْنَ وَمَآ : اور نہیں اَكْثَرُ النَّاسِ : اکثر لوگ وَلَوْ : اگرچہ حَرَصْتَ : تم چاہو بِمُؤْمِنِيْنَ : ایمان لانے والے گو آپ لاکھ چاہیں۔ لیکن اکثر لوگ ایماندار نہ ہیں نہ ہونگے (1)۔
12,104,وَ مَا تَسْئَلُهُمْ عَلَیْهِ مِنْ اَجْرٍ١ؕ اِنْ هُوَ اِلَّا ذِكْرٌ لِّلْعٰلَمِیْنَ۠    ۧ وَمَا تَسْئَلُهُمْ : اور تم نہیں مانگتے ان سے عَلَيْهِ : اس پر مِنْ اَجْرٍ : کوئی اجر اِنْ هُوَ : یہ نہیں اِلَّا : مگر ذِكْرٌ : نصیحت لِّلْعٰلَمِيْنَ : سارے جہانوں کے لیے آپ ان سے اس پر کوئی اجرت طلب نہیں کر رہے ہیں (1) یہ تو تمام دنیا کے لئے نری نصیحت ہی نصیحت ہے (2)
12,105,وَ كَاَیِّنْ مِّنْ اٰیَةٍ فِی السَّمٰوٰتِ وَ الْاَرْضِ یَمُرُّوْنَ عَلَیْهَا وَ هُمْ عَنْهَا مُعْرِضُوْنَ وَكَاَيِّنْ : اور کتنی ہی مِّنْ اٰيَةٍ : نشانیاں فِي السَّمٰوٰتِ : آسمانوں میں وَالْاَرْضِ : اور زمین يَمُرُّوْنَ : وہ گزرتے ہیں عَلَيْهَا : ان پر وَهُمْ : لیکن وہ عَنْهَا : اس سے مُعْرِضُوْنَ : منہ پھیرنے والے آسمانوں اور زمین میں بہت سی نشانیاں ہیں، جن سے یہ منہ موڑے گزر جاتے ہیں (1)۔
12,106,وَ مَا یُؤْمِنُ اَكْثَرُهُمْ بِاللّٰهِ اِلَّا وَ هُمْ مُّشْرِكُوْنَ وَمَا يُؤْمِنُ : اور ایمان نہیں لاتے اَكْثَرُهُمْ : ان میں اکثر بِاللّٰهِ : اللہ پر اِلَّا : مگر وَهُمْ : اور وہ مُّشْرِكُوْنَ : مشرک (جمع) ان میں سے اکثر لوگ باوجود اللہ پر ایمان رکھنے کے بھی مشرک ہی ہیں (1)
12,107,اَفَاَمِنُوْۤا اَنْ تَاْتِیَهُمْ غَاشِیَةٌ مِّنْ عَذَابِ اللّٰهِ اَوْ تَاْتِیَهُمُ السَّاعَةُ بَغْتَةً وَّ هُمْ لَا یَشْعُرُوْنَ اَفَاَمِنُوْٓا : پس کیا وہ بےخوف ہوگئے اَنْ تَاْتِيَهُمْ : کہ ان پر آئے غَاشِيَةٌ : چھا جانیوالی ( آفت) مِّنْ : سے عَذَابِ اللّٰهِ : اللہ کا عذاب اَوْ : یا تَاْتِيَهُمُ : ان پر آجائے السَّاعَةُ : گھڑی (قیامت) بَغْتَةً : اچانک وَّهُمْ : اور وہ لَا يَشْعُرُوْنَ : انہیں خبر نہ ہو کیا وہ اس بات سے بےخوف ہوگئے ہیں کہ ان کے پاس اللہ کے عذابوں میں سے کوئی عام عذاب آجائے یا ان پر اچانک قیامت ٹوٹ پڑے اور وہ بیخبر ی میں ہوں۔
12,108,قُلْ هٰذِهٖ سَبِیْلِیْۤ اَدْعُوْۤا اِلَى اللّٰهِ١ؔ۫ عَلٰى بَصِیْرَةٍ اَنَا وَ مَنِ اتَّبَعَنِیْ١ؕ وَ سُبْحٰنَ اللّٰهِ وَ مَاۤ اَنَا مِنَ الْمُشْرِكِیْنَ قُلْ : آپ کہ دیں هٰذِهٖ : یہ سَبِيْلِيْٓ : میرا راستہ اَدْعُوْٓا : میں بلاتا ہوں اِلَى اللّٰهِ : اللہ کی طرف عَلٰي بَصِيْرَةٍ : دانائی پر (سمجھ بوجھ کے مطابق) اَنَا : میں وَمَنِ : اور جو۔ جس اتَّبَعَنِيْ : میری پیروی کی وَسُبْحٰنَ اللّٰهِ : اور اللہ پاک ہے وَمَآ اَنَا : اور میں نہیں مِنَ : سے الْمُشْرِكِيْنَ : مشرک (جمع) آپ کہہ دیجئے میری راہ یہی ہے، میں اور پیروکار اللہ کی طرف بلا رہے ہیں، پورے یقین اور اعتماد کے ساتھ (1) اور اللہ پاک ہے (2) اور میں مشرکوں میں نہیں۔
12,109,وَ مَاۤ اَرْسَلْنَا مِنْ قَبْلِكَ اِلَّا رِجَالًا نُّوْحِیْۤ اِلَیْهِمْ مِّنْ اَهْلِ الْقُرٰى١ؕ اَفَلَمْ یَسِیْرُوْا فِی الْاَرْضِ فَیَنْظُرُوْا كَیْفَ كَانَ عَاقِبَةُ الَّذِیْنَ مِنْ قَبْلِهِمْ١ؕ وَ لَدَارُ الْاٰخِرَةِ خَیْرٌ لِّلَّذِیْنَ اتَّقَوْا١ؕ اَفَلَا تَعْقِلُوْنَ وَ : اور مَآ اَرْسَلْنَا : ہم نے نہیں بھیجا مِنْ قَبْلِكَ : تم سے پہلے اِلَّا : مگر۔ صرف رِجَالًا : مرد نُّوْحِيْٓ : ہم وحی بھیجتے تھے اِلَيْهِمْ : ان کی طرف مِّنْ : سے اَهْلِ الْقُرٰى : بستیوں والے اَ : کیا فَلَمْ يَسِيْرُوْا : پس انہوں نے سیر نہیں کی فِي الْاَرْضِ : زمین (ملک) میں فَيَنْظُرُوْا : پس وہ دیکھتے كَيْفَ : کیسا۔ کیا كَانَ : ہوا عَاقِبَةُ : انجام الَّذِيْنَ : وہ لوگ جو مِنْ قَبْلِهِمْ : ان سے پہلے وَلَدَارُ الْاٰخِرَةِ : اور البتہ آخرت کا گھر خَيْرٌ : بہتر لِّلَّذِيْنَ : ان کے لیے جو اتَّقَوْا : انہوں نے پرہیز کیا اَفَلَا تَعْقِلُوْنَ : پس کیا تم سمجھتے نہیں آپ سے پہلے ہم نے بستی والوں میں جتنے رسول بھیجے ہیں سب مرد ہی تھے جن کی طرف ہم وحی نازل فرماتے گئے (1) کیا زمین میں چل پھر کر انہوں نے دیکھا نہیں کہ ان سے پہلے لوگوں کا کیسا کچھ انجام ہوا ؟ یقیناً آخرت کا گھر پر ہیزگاروں کے لئے بہت ہی بہتر ہے، کیا پھر تم نہیں سمجھتے۔
12,110,حَتّٰۤى اِذَا اسْتَیْئَسَ الرُّسُلُ وَ ظَنُّوْۤا اَنَّهُمْ قَدْ كُذِبُوْا جَآءَهُمْ نَصْرُنَا فَنُجِّیَ مَنْ نَّشَآءُ١ؕ وَ لَا یُرَدُّ بَاْسُنَا عَنِ الْقَوْمِ الْمُجْرِمِیْنَ حَتّٰٓي : یہاں تک اِذَا : جب اسْتَيْئَسَ : مایوس ہونے لگے الرُّسُلُ : رسول (جمع) وَظَنُّوْٓا : اور انہوں نے گمان کیا اَنَّهُمْ : کہ وہ قَدْ كُذِبُوْا : ان سے جھوٹ کہا گیا جَآءَهُمْ : ان کے پاس آئی نَصْرُنَا : ہماری مدد فَنُجِّيَ : پس بچا دئیے گئے مَنْ : جنہیں نَّشَآءُ : ہم نے چاہا وَ : اور لَا يُرَدُّ : نہیں پھیرا جاتا بَاْسُنَا : ہمارا عذاب عَنِ : سے الْقَوْمِ : قوم الْمُجْرِمِيْنَ : مجرم (جمع) یہاں تک کہ جب رسول ناامید ہونے لگے (1) اور وہ (قوم کے لوگ) خیال کرنے لگے کہ انھیں جھوٹا کہا گیا (2) فوراً ہی ہماری مدد ان کے پاس آپہنچی (3) جسے ہم نے چاہا اسے نجات دی گئی (4) بات یہ ہے کہ ہمارا عذاب گناہ گاروں سے واپس نہیں کیا جاتا۔
12,111,لَقَدْ كَانَ فِیْ قَصَصِهِمْ عِبْرَةٌ لِّاُولِی الْاَلْبَابِ١ؕ مَا كَانَ حَدِیْثًا یُّفْتَرٰى وَ لٰكِنْ تَصْدِیْقَ الَّذِیْ بَیْنَ یَدَیْهِ وَ تَفْصِیْلَ كُلِّ شَیْءٍ وَّ هُدًى وَّ رَحْمَةً لِّقَوْمٍ یُّؤْمِنُوْنَ۠    ۧ لَقَدْ : البتہ كَانَ : ہے فِيْ : میں قَصَصِهِمْ : ان کے قصے عِبْرَةٌ : عبرت (نصیحت) لِّاُولِي الْاَلْبَابِ : عقلمندوں کے لیے مَا كَانَ : نہیں ہے حَدِيْثًا : بات يُّفْتَرٰى : بنائی ہوئی وَلٰكِنْ : اور لیکن (بلکہ) تَصْدِيْقَ : تصدیق الَّذِيْ : وہ جو بَيْنَ يَدَيْهِ : اس (اپنے سے) پہلی وَتَفْصِيْلَ : اور تفصیل (بیان) كُلِّ : ہر شَيْءٍ : بات وَّهُدًى : اور ہدایت وَّرَحْمَةً : اور رحمت لِّقَوْمٍ : لوگوں کے لیے يُّؤْمِنُوْنَ : جو ایمان لاتے ہیں ان کے بیان میں عقل والوں کے لئے یقیناً نصیحت اور عبرت ہے، یہ قرآن جھوٹ بنائی ہوئی بات نہیں بلکہ یہ تصدیق ہے، ان کتابوں کی جو اس سے پہلے کی ہیں، کھول کھول کر بیان کرنے والا ہے ہر چیز کو اور ہدایت اور رحمت ہے ایمان دار لوگوں کے لئے (1)۔
