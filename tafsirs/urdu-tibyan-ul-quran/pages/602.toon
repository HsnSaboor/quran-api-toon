tafsir[14]{c,v,t}:
  106,1,لِاِیْلٰفِ قُرَیْشٍۙ لِاِيْلٰفِ : مانوس کرنے کے سبب قُرَيْشٍ : قریش قریش کے مانوس کرنے کے لئے
  106,2,اٖلٰفِهِمْ رِحْلَةَ الشِّتَآءِ وَ الصَّیْفِۚ اٖلٰفِهِمْ : ان کا مانوس کرنا رِحْلَةَ : سفر الشِّتَآءِ : سردی وَ : اور الصَّيْفِ : گرمی یعنی انہیں سردی اور گرمی کے سفر سے مانوس کرنے کے لئے۔ (1)
  106,3,فَلْیَعْبُدُوْا رَبَّ هٰذَا الْبَیْتِۙ فَلْيَعْبُدُوْا : پس چاہیے وہ عبادت کریں رَبَّ هٰذَا الْبَيْتِ : اس گھرکے رب کی پس انہیں چاہیے کہ اسی گھر کے رب کی عبادت کرتے رہیں۔
  106,4,الَّذِیْۤ اَطْعَمَهُمْ مِّنْ جُوْعٍ١ۙ۬ وَّ اٰمَنَهُمْ مِّنْ خَوْفٍ۠    ۧ الَّذِيْٓ : جو، جس اَطْعَمَهُمْ : انہیں کھانا دیا مِّنْ جُوْعٍ : بھوک سے وَّاٰمَنَهُمْ : اور انہیں امن دیا مِّنْ خَوْفٍ : خوف سے، میں جس نے انہیں بھوک میں کھانا دیا (1) اور ڈر (اور خوف) میں امن وامان دیا (2)۔
  107,1,اَرَءَیْتَ الَّذِیْ یُكَذِّبُ بِالدِّیْنِؕ اَرَءَيْتَ : کیا تم نے دیکھا الَّذِيْ : وہ جو کہ يُكَذِّبُ : جھٹلاتا ہے بِالدِّيْنِ : روز جزا وسزا کو کیا تو نے دیکھا جو (روز) جزا کو جھٹلاتا ہے (1)۔
  107,2,فَذٰلِكَ الَّذِیْ یَدُعُّ الْیَتِیْمَۙ فَذٰلِكَ : یہی ہے وہ الَّذِيْ : جو کہ يَدُعُّ : دھکے دیتا ہے الْيَتِيْمَ : یتیم کو یہی وہ ہے جو یتیم کو دھکے دیتا ہے۔ (1)
  107,3,وَ لَا یَحُضُّ عَلٰى طَعَامِ الْمِسْكِیْنِؕ وَلَا : اور نہیں يَحُضُّ : رغبت دلاتا عَلٰي طَعَامِ : کھانے پر الْمِسْكِيْنِ : مسکین اور مسکین کو کھلانے کے لئے ترغیب نہیں دیتا (1)
  107,4,فَوَیْلٌ لِّلْمُصَلِّیْنَۙ فَوَيْلٌ : پس خرابی لِّلْمُصَلِّيْنَ : نمازیوں کیلئے ان نمازیوں کے لئے افسوس (اور ویل نامی جہنم کی جگہ) ہے۔
  107,5,الَّذِیْنَ هُمْ عَنْ صَلَاتِهِمْ سَاهُوْنَۙ الَّذِيْنَ : جو کہ هُمْ : وہ عَنْ صَلَاتِهِمْ : اپنی نمازوں سے سَاهُوْنَ : غافل (جمع) جو اپنی نماز سے غافل ہیں (1)
  107,6,الَّذِیْنَ هُمْ یُرَآءُوْنَۙ الَّذِيْنَ : جو کہ هُمْ : وہ يُرَآءُوْنَ : دکھاوا کرتے ہیں جو ریاکاری کرتے ہیں۔ (1)
  107,7,وَ یَمْنَعُوْنَ الْمَاعُوْنَ۠    ۧ وَيَمْنَعُوْنَ : روکتے ہیں (نہیں دیتے) الْمَاعُوْنَ : عام ضرورت کی چیز اور برتنے کی چیز روکتے ہیں (1)
  108,1,اِنَّاۤ اَعْطَیْنٰكَ الْكَوْثَرَؕ اِنَّآ اَعْطَيْنٰكَ الْكَوْثَرَ : بیشک ہم نے آپ کو عطا کیا۔ کوثر یقیناً ہم نے تجھے (حوض) کوثر (اور بہت کچھ) دیا ہے (1)
  108,2,فَصَلِّ لِرَبِّكَ وَ انْحَرْؕ فَصَلِّ : پس نماز پڑھو لِرَبِّكَ : اپنے رب کیلئے وَانْحَرْ : اور قربانی دو پس تو اپنے رب کے لئے نماز پڑھ اور قربانی کر۔ (1)
  108,3,اِنَّ شَانِئَكَ هُوَ الْاَبْتَرُ۠    ۧ اِنَّ شَانِئَكَ : بیشک آپ کا دشمن هُوَ : وہ الْاَبْتَرُ : دم کٹا، نامراد یقیناً تیرا دشمن ہی لا وارث اور بےنام و نشان ہے (1)
