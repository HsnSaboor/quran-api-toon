tafsir[8]{c,v,t}:
  12,96,فَلَمَّاۤ اَنْ جَآءَ الْبَشِیْرُ اَلْقٰىهُ عَلٰى وَجْهِهٖ فَارْتَدَّ بَصِیْرًا١ۚ قَالَ اَلَمْ اَقُلْ لَّكُمْ١ۙۚ اِنِّیْۤ اَعْلَمُ مِنَ اللّٰهِ مَا لَا تَعْلَمُوْنَ فَلَمَّآ : پھر جب اَنْ : کہ جَآءَ : آیا الْبَشِيْرُ : خوشخبری دینے والا اَلْقٰىهُ : اس نے وہ (کرتہ) ڈالا عَلٰي : پر وَجْهِهٖ : اس کا منہ فَارْتَدَّ : تو لوٹ کر ہوگیا بَصِيْرًا : دیکھنے والا قَالَ : بولا اَلَمْ اَقُلْ : کیا میں نے تمہیں کہا تھا لَّكُمْ : تم سے اِنِّىْٓ اَعْلَمُ : بیشک میں جانتا ہوں مِنَ : (طرف) سے اللّٰهِ : اللہ مَا : جو لَا تَعْلَمُوْنَ : تم نہیں جانتے جب خوشخبری دینے والے نے پہنچ کر ان کے منہ پر وہ کرتا ڈالا اسی وقت پھر بینا ہوگئے (1) کہا ! کیا میں تم سے نہ کہا کرتا تھا کہ میں اللہ کی طرف سے وہ باتیں جانتا ہوں جو تم نہیں جانتے (2)۔
  12,97,قَالُوْا یٰۤاَبَانَا اسْتَغْفِرْ لَنَا ذُنُوْبَنَاۤ اِنَّا كُنَّا خٰطِئِیْنَ قَالُوْا : وہ بولے يٰٓاَبَانَا : اے ہمارے باپ اسْتَغْفِرْ لَنَا : ہمارے لیے بخشش مانگ ذُنُوْبَنَآ : ہمارے گناہ اِنَّا : بیشک ہم كُنَّا : تھے خٰطِئِيْنَ : خطا کار (جمع) انہوں نے کہا ابا جی آپ ہمارے لئے گناہوں کی بخشش طلب کیجئے بیشک ہم قصور وار ہیں۔
  12,98,قَالَ سَوْفَ اَسْتَغْفِرُ لَكُمْ رَبِّیْ١ؕ اِنَّهٗ هُوَ الْغَفُوْرُ الرَّحِیْمُ قَالَ : اس نے کہا سَوْفَ : جلد اَسْتَغْفِرُ : میں بخشش مانگوں گا لَكُمْ : تمہارے لیے رَبِّيْ : اپنا رب اِنَّهٗ : بشیک وہ هُوَ : وہ الْغَفُوْرُ : بخشنے والا الرَّحِيْمُ : نہایت مہربان کہا اچھا میں جلد ہی تمہارے لئے اپنے پروردگار سے بخشش مانگوں گا (1) وہ بہت بڑا بخشنے والا اور نہایت مہربانی کرنے والا ہے۔
  12,99,فَلَمَّا دَخَلُوْا عَلٰى یُوْسُفَ اٰوٰۤى اِلَیْهِ اَبَوَیْهِ وَ قَالَ ادْخُلُوْا مِصْرَ اِنْ شَآءَ اللّٰهُ اٰمِنِیْنَؕ فَلَمَّا : پھر جب دَخَلُوْا : وہ داخل ہوئے عَلٰي يُوْسُفَ : یوسف پر (پاس) اٰوٰٓى : اس نے ٹھکانہ دیا اِلَيْهِ : اپنے پاس اَبَوَيْهِ : اپنے ماں باپ وَقَالَ : اور کہا ادْخُلُوْا : تم داخل ہو مِصْرَ : مصر اِنْ : اگر شَآءَ اللّٰهُ : اللہ نے چاہا اٰمِنِيْنَ : امن (دلجمعی) کے ساتھ جب یہ سارا گھرانہ یوسف کے پاس پہنچ گیا تو یوسف نے اپنے ماں باپ کو اپنے پاس جگہ دی (1) اور کہا کہ اللہ کو منظور ہے تو آپ سب امن وامان کے ساتھ مصر میں آؤ۔
  12,100,وَ رَفَعَ اَبَوَیْهِ عَلَى الْعَرْشِ وَ خَرُّوْا لَهٗ سُجَّدًا١ۚ وَ قَالَ یٰۤاَبَتِ هٰذَا تَاْوِیْلُ رُءْیَایَ مِنْ قَبْلُ١٘ قَدْ جَعَلَهَا رَبِّیْ حَقًّا١ؕ وَ قَدْ اَحْسَنَ بِیْۤ اِذْ اَخْرَجَنِیْ مِنَ السِّجْنِ وَ جَآءَ بِكُمْ مِّنَ الْبَدْوِ مِنْۢ بَعْدِ اَنْ نَّزَغَ الشَّیْطٰنُ بَیْنِیْ وَ بَیْنَ اِخْوَتِیْ١ؕ اِنَّ رَبِّیْ لَطِیْفٌ لِّمَا یَشَآءُ١ؕ اِنَّهٗ هُوَ الْعَلِیْمُ الْحَكِیْمُ وَرَفَعَ : اور اونچا بٹھایا اَبَوَيْهِ : اپنے ماں باپ عَلَي : پر الْعَرْشِ : تخت وَخَرُّوْا : اور وہ گرگئے لَهٗ : اس کے لیے ( آگے) سُجَّدًا : سجدہ میں وَقَالَ : اور اس نے کہا يٰٓاَبَتِ : اے میرے ابا هٰذَا : یہ تَاْوِيْلُ : تعبیر رُءْيَايَ : میرا خواب مِنْ قَبْلُ : اس سے پہلے قَدْ جَعَلَهَا : اس کو کردیا رَبِّيْ : میرا رب حَقًّا : سچا وَ : اور قَدْ اَحْسَنَ : بیشک اس نے احسان کیا بِيْٓ : مجھ پر اِذْ : جب اَخْرَجَنِيْ : مجھے نکالا مِنَ : سے السِّجْنِ : قید خانہ وَجَآءَ : اور لے آیا بِكُمْ : تم سب کو مِّنَ : سے الْبَدْوِ : گاؤں مِنْۢ بَعْدِ : اس کے بعد اَنْ : کہ نَّزَغَ : جھگڑا ڈالدیا الشَّيْطٰنُ : شیطان بَيْنِيْ : میرے درمیان وَبَيْنَ اِخْوَتِيْ : اور میرے بھائیوں کے درمیان اِنَّ : بیشک رَبِّيْ : میرا رب لَطِيْفٌ : عمدہ تدبیر کرنیوالا لِّمَا يَشَآءُ : جس کے لیے چاہے اِنَّهٗ : بیشک وہ هُوَ : وہ الْعَلِيْمُ : جانے والا الْحَكِيْمُ : حکمت والا اور اپنے تخت پر اپنے ماں باپ (2) کو اونچا بٹھایا اور سب اسکے سامنے سجدے میں گرگئے (2) تب کہا ابا جی ! یہ میرے پہلے کے خواب کی تعبیر ہے (3) میرے رب نے اسے سچا کر دکھایا، اس نے میرے ساتھ بڑا احسان کیا جب کہ مجھے جیل خانے سے نکالا (4) اور آپ لوگوں کو صحرا سے لے آیا (5) اس اختلاف کے بعد جو شیطان نے مجھ میں اور میرے بھائیوں میں ڈال دیا تھا (6) میرا رب جو چاہے اس کے لئے بہترین تدبیر کرنے والا ہے اور وہ بہت علم و حکمت والا ہے۔
  12,101,رَبِّ قَدْ اٰتَیْتَنِیْ مِنَ الْمُلْكِ وَ عَلَّمْتَنِیْ مِنْ تَاْوِیْلِ الْاَحَادِیْثِ١ۚ فَاطِرَ السَّمٰوٰتِ وَ الْاَرْضِ١۫ اَنْتَ وَلِیّٖ فِی الدُّنْیَا وَ الْاٰخِرَةِ١ۚ تَوَفَّنِیْ مُسْلِمًا وَّ اَلْحِقْنِیْ بِالصّٰلِحِیْنَ رَبِّ : اے میرے رب قَدْ اٰتَيْتَنِيْ : تونے مجھے عطا کیا مِنَ : سے۔ ایک الْمُلْكِ : ملک وَعَلَّمْتَنِيْ : اور مجھے سکھایا مِنْ : سے تَاْوِيْلِ : انجام نکالنا (تعبیر) الْاَحَادِيْثِ : باتیں (خواب) فَاطِرَ : پیدا کرنے والا السَّمٰوٰتِ : آسمان (جمع) وَالْاَرْضِ : اور زمین اَنْتَ : تو وَلِيّٖ : میرا کارساز فِي الدُّنْيَا : دنیا میں وَالْاٰخِرَةِ : آخرت تَوَفَّنِيْ : مجھے اٹھا مُسْلِمًا : فرمانبرداری کی حالت میں وَّاَلْحِقْنِيْ : اور مجھے ملا بِالصّٰلِحِيْنَ : صالح (نیک بندوں) کے ساتھ اے میرے پروردگار ! تو نے مجھے ملک عطا فرمایا (1) اور تو نے مجھے خواب کی تعبیر سکھلائی (2) اے آسمان و زمین کے پیدا کرنے والے تو دنیا و آخرت میں میرا ولی (دوست) اور کارساز ہے، تو مجھے اسلام کی حالت میں فوت کر اور نیکوں میں ملا دے۔
  12,102,ذٰلِكَ مِنْ اَنْۢبَآءِ الْغَیْبِ نُوْحِیْهِ اِلَیْكَ١ۚ وَ مَا كُنْتَ لَدَیْهِمْ اِذْ اَجْمَعُوْۤا اَمْرَهُمْ وَ هُمْ یَمْكُرُوْنَ ذٰلِكَ : یہ مِنْ : سے اَنْۢبَآءِ الْغَيْبِ : غیب کی خبریں نُوْحِيْهِ : ہم وہ وحی کرتے ہیں اِلَيْكَ : تمہاری طرف وَمَا كُنْتَ : اور تم نہ تھے لَدَيْهِمْ : ان کے پاس اِذْ : جب اَجْمَعُوْٓا : انہوں نے جمع کیا (پختہ کیا) اَمْرَهُمْ : اپنا کام وَهُمْ : اور وہ يَمْكُرُوْنَ : چال چل رہے تھے یہ غیب کی خبروں میں سے جس کی ہم آپ کی طرف وحی کر رہے ہیں۔ آپ ان کے پاس نہ تھے جب کہ انہوں نے اپنی بات ٹھان لی تھی اور وہ فریب کرنے لگے تھے (1)
  12,103,وَ مَاۤ اَكْثَرُ النَّاسِ وَ لَوْ حَرَصْتَ بِمُؤْمِنِیْنَ وَمَآ : اور نہیں اَكْثَرُ النَّاسِ : اکثر لوگ وَلَوْ : اگرچہ حَرَصْتَ : تم چاہو بِمُؤْمِنِيْنَ : ایمان لانے والے گو آپ لاکھ چاہیں۔ لیکن اکثر لوگ ایماندار نہ ہیں نہ ہونگے (1)۔
