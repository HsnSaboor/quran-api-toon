tafsir[15]{c,v,t}:
  15,1,الٓرٰ١۫ تِلْكَ اٰیٰتُ الْكِتٰبِ وَ قُرْاٰنٍ مُّبِیْنٍ الٓرٰ : الف لام را تِلْكَ : یہ اٰيٰتُ : آیتیں الْكِتٰبِ : کتاب وَ : اور قُرْاٰنٍ : قرآن مُّبِيْنٍ : واضح۔ روشن ا لر، یہ کتاب الٰہی کی آیتیں ہیں اور کھلی اور روشن قرآن کی (1)۔
  15,2,رُبَمَا یَوَدُّ الَّذِیْنَ كَفَرُوْا لَوْ كَانُوْا مُسْلِمِیْنَ رُبَمَا : بسا اوقات يَوَدُّ : آرزو کریں گے الَّذِيْنَ كَفَرُوْا : وہ لوگ جو کافر ہوئے لَوْ كَانُوْا : کاش وہ ہوتے مُسْلِمِيْنَ : مسلمان وہ وقت بھی ہوگا کہ کافر اپنے مسلمان ہونے کی آرزو کریں گے (1)۔
  15,3,ذَرْهُمْ یَاْكُلُوْا وَ یَتَمَتَّعُوْا وَ یُلْهِهِمُ الْاَمَلُ فَسَوْفَ یَعْلَمُوْنَ ذَرْهُمْ : انہیں چھوڑ دو يَاْكُلُوْا : وہ کھائیں وَيَتَمَتَّعُوْا : اور فائدہ اٹھالیں وَيُلْهِهِمُ : اور غفلت میں رکھے انہیں الْاَمَلُ : امید فَسَوْفَ : پس عنقریب يَعْلَمُوْنَ : وہ جان لیں گے آپ انھیں کھاتا، نفع اٹھاتا اور (جھوٹی) امیدوں میں مشغول ہوتا چھوڑ دیجئیے یہ خود بھی جان لیں گے (1)۔
  15,4,وَ مَاۤ اَهْلَكْنَا مِنْ قَرْیَةٍ اِلَّا وَ لَهَا كِتَابٌ مَّعْلُوْمٌ وَمَآ : اور نہیں اَهْلَكْنَا : ہم نے ہلاک کیا مِنْ : کسی قَرْيَةٍ : بستی اِلَّا : مگر وَلَهَا : اس کے لیے كِتَابٌ : ایک لکھا ہوا مَّعْلُوْمٌ : مقررہ وقت کسی بستی کو ہم نے ہلاک نہیں کیا مگر یہ کہ اس کے لئے مقررہ نوشتہ تھا (1)
  15,5,مَا تَسْبِقُ مِنْ اُمَّةٍ اَجَلَهَا وَ مَا یَسْتَاْخِرُوْنَ مَا تَسْبِقُ : نہ سبقت کرتی ہے مِنْ اُمَّةٍ : کوئی امت اَجَلَهَا : اپنا مقررہ وقت وَمَا : اور نہ يَسْتَاْخِرُوْنَ : وہ پیچھے رہتے ہیں کوئی گروہ اپنی موت سے نہ آگے بڑھتا نہ پیچھے رہتا (1)
  15,6,وَ قَالُوْا یٰۤاَیُّهَا الَّذِیْ نُزِّلَ عَلَیْهِ الذِّكْرُ اِنَّكَ لَمَجْنُوْنٌؕ وَقَالُوْا : اور وہ بولے يٰٓاَيُّھَا : اے وہ الَّذِيْ نُزِّلَ : وہ جو کہ اتارا گیا عَلَيْهِ : اس پر الذِّكْرُ : یاد دہانی (قرآن) اِنَّكَ : بیشک تو لَمَجْنُوْنٌ : دیوانہ انہوں نے کہا اے وہ شخص جس پر قرآن اتارا گیا ہے یقیناً تو تو کوئی دیوانہ ہے (1)
  15,7,لَوْ مَا تَاْتِیْنَا بِالْمَلٰٓئِكَةِ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ لَوْ : کیوں مَا تَاْتِيْنَا : ہمارے پاس تو نہیں لے آتا بِالْمَلٰٓئِكَةِ : فرشتوں کو اِنْ : اگر كُنْتَ : تو ہے مِنَ : سے الصّٰدِقِيْنَ : سچے اگر تو سچا ہی ہے تو ہمارے پاس فرشتوں کو کیوں نہیں لاتا (1)۔
  15,8,مَا نُنَزِّلُ الْمَلٰٓئِكَةَ اِلَّا بِالْحَقِّ وَ مَا كَانُوْۤا اِذًا مُّنْظَرِیْنَ مَا نُنَزِّلُ : ہم نازل نہیں کرتے الْمَلٰٓئِكَةَ : فرشتے اِلَّا : مگر بِالْحَقِّ : حق کے ساتھ وَمَا كَانُوْٓا : اور نہ ہوں گے اِذًا : اس وقت مُّنْظَرِيْنَ : مہلت دئیے گئے ہم فرشتوں کو حق کے ساتھ ہی اتارتے ہیں اور اس وقت وہ مہلت دیئے گئے نہیں ہوتے (1)
  15,9,اِنَّا نَحْنُ نَزَّلْنَا الذِّكْرَ وَ اِنَّا لَهٗ لَحٰفِظُوْنَ اِنَّا : بیشک نَحْنُ : ہم نَزَّلْنَا : ہم نے نازل کیا الذِّكْرَ : یاد دہانی (قرآن) وَاِنَّا : اور بیشک ہم لَهٗ : اس کے لَحٰفِظُوْنَ : نگہبان ہم نے ہی اس قرآن کو نازل فرمایا ہے اور ہم ہی اس کے محافظ ہیں (1)۔
  15,10,وَ لَقَدْ اَرْسَلْنَا مِنْ قَبْلِكَ فِیْ شِیَعِ الْاَوَّلِیْنَ وَلَقَدْ اَرْسَلْنَا : اور یقیناً ہم نے بھیجے مِنْ : سے قَبْلِكَ : تم سے پہلے فِيْ : میں شِيَعِ : گروہ الْاَوَّلِيْنَ : پہلے ہم نے آپ سے پہلے اگلی امتوں میں بھی رسول (برابر) بھیجے۔
  15,11,وَ مَا یَاْتِیْهِمْ مِّنْ رَّسُوْلٍ اِلَّا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ وَمَا يَاْتِيْهِمْ : اور نہیں آیا ان کے پاس مِّنْ رَّسُوْلٍ : کوئی رسول اِلَّا : مگر كَانُوْا : وہ تھے بِهٖ : اس سے يَسْتَهْزِءُوْنَ : استہزا کرتے اور (لیکن) جو بھی رسول آتا وہ اس کا مذاق اڑاتے (1)۔
  15,12,كَذٰلِكَ نَسْلُكُهٗ فِیْ قُلُوْبِ الْمُجْرِمِیْنَۙ كَذٰلِكَ : اسی طرح نَسْلُكُهٗ : ہم اسے ڈال دیتے ہیں فِيْ : میں قُلُوْبِ : دل (جمع) الْمُجْرِمِيْنَ : مجرموں گناہگاروں کے دلوں میں ہم اسی طرح ہی رچا دیا کرتے ہیں (1)۔
  15,13,لَا یُؤْمِنُوْنَ بِهٖ وَ قَدْ خَلَتْ سُنَّةُ الْاَوَّلِیْنَ لَا يُؤْمِنُوْنَ : وہ ایمان نہیں لائیں گے بِهٖ : اس پر وَقَدْ خَلَتْ : اور پڑچکی ہے سُنَّةُ : رسم۔ روش الْاَوَّلِيْنَ : پہلے وہ اس پر ایمان نہیں لاتے اور یقیناً اگلوں کا طریقہ گزرا ہوا ہے (1)۔
  15,14,وَ لَوْ فَتَحْنَا عَلَیْهِمْ بَابًا مِّنَ السَّمَآءِ فَظَلُّوْا فِیْهِ یَعْرُجُوْنَۙ وَلَوْ : اور اگر فَتَحْنَا : ہم کھول دیں عَلَيْهِمْ : ان پر بَابًا : کوئی دروازہ مِّنَ : سے السَّمَآءِ : آسمان فَظَلُّوْا : وہ رہیں فِيْهِ : اس میں يَعْرُجُوْنَ : چڑھتے اور اگر ہم ان پر آسمان کا دروازہ کھول بھی دیں اور یہ وہاں چڑھنے بھی لگ جائیں۔
  15,15,لَقَالُوْۤا اِنَّمَا سُكِّرَتْ اَبْصَارُنَا بَلْ نَحْنُ قَوْمٌ مَّسْحُوْرُوْنَ۠    ۧ لَقَالُوْٓا : تو کہیں گے اِنَّمَا : اس کے سوا نہیں سُكِّرَتْ : باندھ دی گئی اَبْصَارُنَا : ہماری آنکھیں بَلْ : بلکہ نَحْنُ : ہم قَوْمٌ : لوگ مَّسْحُوْرُوْنَ : سحر زدہ تب بھی یہی کہیں گے کہ ہماری نظر بندی کردی گئی ہے بلکہ ہم لوگوں پر جادو کردیا گیا ہے۔ (1)
