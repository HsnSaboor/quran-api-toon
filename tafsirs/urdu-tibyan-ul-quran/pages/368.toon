tafsir[20]{c,v,t}:
  26,20,قَالَ فَعَلْتُهَاۤ اِذًا وَّ اَنَا مِنَ الضَّآلِّیْنَؕ قَالَ : موسیٰ نے کہا فَعَلْتُهَآ : میں وہ کیا تھا اِذًا : جب وَّاَنَا : اور میں مِنَ : سے الضَّآلِّيْنَ : راہ سے بیخبر (جمع) (حضرت) موسیٰ ؑ نے جواب دیا کہ میں نے اس کام کو اس وقت کیا تھا جبکہ میں راہ بھولے ہوئے لوگوں میں سے تھا 1
  26,21,فَفَرَرْتُ مِنْكُمْ لَمَّا خِفْتُكُمْ فَوَهَبَ لِیْ رَبِّیْ حُكْمًا وَّ جَعَلَنِیْ مِنَ الْمُرْسَلِیْنَ فَفَرَرْتُ : تو میں بھاگ گیا مِنْكُمْ : تم سے لَمَّا خِفْتُكُمْ : جب میں ڈرا تم سے فَوَهَبَ لِيْ : پس عطا کیا مجھے رَبِّيْ : میرا رب حُكْمًا : حکم وَّ : اور جَعَلَنِيْ : مجھے بنایا مِنَ : سے الْمُرْسَلِيْنَ : رسول (جمع) پھر تم سے خوف کھا کر میں تم میں سے بھاگ گیا، پھر مجھے میرے رب نے حکم و علم عطا فرمایا اور مجھے پیغمبروں میں سے کردیا 1
  26,22,وَ تِلْكَ نِعْمَةٌ تَمُنُّهَا عَلَیَّ اَنْ عَبَّدْتَّ بَنِیْۤ اِسْرَآءِیْلَؕ وَتِلْكَ : اور یہ نِعْمَةٌ : کوئی نعمت تَمُنُّهَا عَلَيَّ : تو اس کا احسان رکھتا ہے مجھ پر اَنْ عَبَّدْتَّ : کہ تونے غلام بنایا بَنِيْٓ اِسْرَآءِيْلَ : بنی اسرائیل مجھ پر تیرا کیا یہی وہ احسان ہے ؟ جسے تو جتلا رہا ہے کہ تو نے بنی اسرائیل کو غلام بنا رکھا ہے 1
  26,23,قَالَ فِرْعَوْنُ وَ مَا رَبُّ الْعٰلَمِیْنَؕ قَالَ فِرْعَوْنُ : فرعون نے کہا وَمَا : اور کیا ہے رَبُّ : رب الْعٰلَمِيْنَ : سارے جہان فرعون نے کہا رب العالمین کیا (چیز) ہے ؟ 1
  26,24,قَالَ رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا١ؕ اِنْ كُنْتُمْ مُّوْقِنِیْنَ قَالَ : اس نے کہا رَبُّ السَّمٰوٰتِ : رب ہے آسمانوں کا وَالْاَرْضِ : اور زمین وَمَا بَيْنَهُمَا : اور جو ان کے درمیان اِنْ : اگر كُنْتُمْ : تم ہو مُّوْقِنِيْنَ : یقین کرنے والے (حضرت) موسیٰ ؑ نے فرمایا وہ آسمانوں اور زمین اور ان کے درمیان کی تمام چیزوں کا رب ہے، اگر تم یقین رکھنے والے ہو۔
  26,25,قَالَ لِمَنْ حَوْلَهٗۤ اَلَا تَسْتَمِعُوْنَ قَالَ : اس نے کہا لِمَنْ : انہیں جو حَوْلَهٗٓ : اس کے اردگرد اَلَا تَسْتَمِعُوْنَ : کیا تم سنتے نہیں فرعون نے اپنے گرد والوں سے کہا کیا تم سن نہیں رہے ؟ 1
  26,26,قَالَ رَبُّكُمْ وَ رَبُّ اٰبَآئِكُمُ الْاَوَّلِیْنَ قَالَ : (موسی) نے کہا رَبُّكُمْ : تمہارا رب وَرَبُّ : اور رب اٰبَآئِكُمُ : تمہارے باپ دادا الْاَوَّلِيْنَ : پہلے (حضرت موسیٰ ؑ نے فرمایا وہ تمہارا اور تمہارے اگلے باپ دادوں کا پروردگار ہے۔
  26,27,قَالَ اِنَّ رَسُوْلَكُمُ الَّذِیْۤ اُرْسِلَ اِلَیْكُمْ لَمَجْنُوْنٌ قَالَ : فرعون بولا اِنَّ : بیشک رَسُوْلَكُمُ : تمہارا رسول الَّذِيْٓ : وہ جو اُرْسِلَ : بھیجا گیا اِلَيْكُمْ : تمہاری طرف لَمَجْنُوْنٌ : البتہ دیوانہ فرعون نے کہا (لوگو !) تمہارا یہ رسول جو تمہاری طرف بھیجا گیا ہے یہ تو یقیناً دیوانہ ہے۔
  26,28,قَالَ رَبُّ الْمَشْرِقِ وَ الْمَغْرِبِ وَ مَا بَیْنَهُمَا١ؕ اِنْ كُنْتُمْ تَعْقِلُوْنَ قَالَ : (موسی) نے کہا رَبُّ : رب الْمَشْرِقِ : مشرق وَالْمَغْرِبِ : اور مغرب وَمَا : اور جو بَيْنَهُمَا : ان دونوں کے درمیان اِنْ : اگر كُنْتُمْ تَعْقِلُوْنَ : تم سمجھتے ہو (حضرت) موسیٰ ؑ نے فرمایا مشرق و مغرب کا اور ان کے درمیان کی تمام چیزوں کا رب 1 ہے، اگر تم عقل رکھتے ہو۔
  26,29,قَالَ لَئِنِ اتَّخَذْتَ اِلٰهًا غَیْرِیْ لَاَجْعَلَنَّكَ مِنَ الْمَسْجُوْنِیْنَ قَالَ : وہ بولا لَئِنِ : البتہ اگر اتَّخَذْتَ : تونے بنایا اِلٰهًا : کوئی معبود غَيْرِيْ : میرے سوا لَاَجْعَلَنَّكَ : تو میں ضرور کردوں گا تجھے مِنَ : سے الْمَسْجُوْنِيْنَ : قیدی (جمع) فرعون کہنے لگا سن لے ! اگر تو نے میرے سوا کسی اور کو معبود بنایا تو میں تجھے قیدیوں میں ڈال دونگا 1
  26,30,قَالَ اَوَ لَوْ جِئْتُكَ بِشَیْءٍ مُّبِیْنٍۚ قَالَ : (موسی) نے کہا اَوَلَوْ جِئْتُكَ : خواہ میں لاؤں تیرے پاس بِشَيْءٍ مُّبِيْنٍ : ایک شے (معجزہ) واضح مو سٰی ؑ نے کہا اگرچہ میں تیرے پاس کوئی کھلی چیز لے آؤں ؟ 1
  26,31,قَالَ فَاْتِ بِهٖۤ اِنْ كُنْتَ مِنَ الصّٰدِقِیْنَ قَالَ : وہ بولا فَاْتِ بِهٖٓ : تو لے آ اسے اِنْ كُنْتَ : اگر تو ہے مِنَ : سے الصّٰدِقِيْنَ : سچے فرعوں نے کہا اگر تو سچوں میں سے ہے تو اسے پیش کر۔
  26,32,فَاَلْقٰى عَصَاهُ فَاِذَا هِیَ ثُعْبَانٌ مُّبِیْنٌۚۖ فَاَلْقٰى : پس موسیٰ نے ڈالا عَصَاهُ : اپنا عصا فَاِذَا هِىَ : تو اچانک وہ ثُعْبَانٌ : اژدہا مُّبِيْنٌ : کھلا (نمایاں آپ نے (اسی وقت) اپنی لاٹھی ڈال دی جو اچانک کھلم کھلا (زبردست) اژدھا بن گئی 1
  26,33,وَّ نَزَعَ یَدَهٗ فَاِذَا هِیَ بَیْضَآءُ لِلنّٰظِرِیْنَ۠    ۧ وَّنَزَعَ : اور اس نے کھینچا (نکالا) يَدَهٗ : اپنا ہاتھ فَاِذَا هِىَ : تو ناگاہ وہ بَيْضَآءُ : چمکتا ہوا لِلنّٰظِرِيْنَ : دیکھنے والوں کے لیے اور اپنا ہاتھ کھینچ نکالا تو وہ بھی اسی وقت دیکھنے والے کو سفید چمکیلا نظر آنے لگا 1
  26,34,قَالَ لِلْمَلَاِ حَوْلَهٗۤ اِنَّ هٰذَا لَسٰحِرٌ عَلِیْمٌۙ قَالَ : فرعون نے کہا لِلْمَلَاِ : سرداروں سے حَوْلَهٗٓ : اپنے گرد اِنَّ ھٰذَا : بیشک یہ لَسٰحِرٌ : جادوگر عَلِيْمٌ : دانا، ماہر فرعون اپنے آس پاس کے سرداروں سے کہنے لگا بھئی یہ تو کوئی بڑا دانا جادوگر ہے 1
  26,35,یُّرِیْدُ اَنْ یُّخْرِجَكُمْ مِّنْ اَرْضِكُمْ بِسِحْرِهٖ١ۖۗ فَمَا ذَا تَاْمُرُوْنَ يُّرِيْدُ : وہ چاہتا ہے اَنْ : کہ يُّخْرِجَكُمْ : تمہیں نکال دے مِّنْ : سے اَرْضِكُمْ : تمہاری سرزمین بِسِحْرِهٖ : اپنے جادو سے فَمَاذَا : تو کیا تَاْمُرُوْنَ : تم حکم (مشورہ) دیتے ہو یہ تو چاہتا ہے کہ اپنے جادو کے زور سے تمہیں تمہاری سرزمین سے ہی نکال دے، بتاؤ اب تم کیا حکم دیتے ہو 1۔
  26,36,قَالُوْۤا اَرْجِهْ وَ اَخَاهُ وَ ابْعَثْ فِی الْمَدَآئِنِ حٰشِرِیْنَۙ قَالُوْٓا : وہ بولے اَرْجِهْ : مہلت دے اسے وَاَخَاهُ : اور اس کے بھائی کو وَابْعَثْ : اور بھیج فِي : میں الْمَدَآئِنِ : شہروں (جمع) حٰشِرِيْنَ : اکٹھا کرنے والے (نقیب) ان سب نے کہا آپ اسے اور اس کے بھائی کو مہلت دیجئے اور تمام شہروں میں ہر کارے بھیج دیجئے۔
  26,37,یَاْتُوْكَ بِكُلِّ سَحَّارٍ عَلِیْمٍ يَاْتُوْكَ : لے آئیں تیرے پاس بِكُلِّ سَحَّارٍ : تمام بڑے جادوگر عَلِيْمٍ : ماہر جو آپ کے پاس ذی علم جادوگروں کو لے آئیں 1
  26,38,فَجُمِعَ السَّحَرَةُ لِمِیْقَاتِ یَوْمٍ مَّعْلُوْمٍۙ فَجُمِعَ : پس جمع کیے گئے السَّحَرَةُ : جادوگر لِمِيْقَاتِ : مقررہ وقت پر يَوْمٍ : ایک دن مَّعْلُوْمٍ : جانے پہچانے (معین) پھر ایک مقرر دن کے وعدے پر تمام جادوگر جمع کئے گئے 1
  26,39,وَّ قِیْلَ لِلنَّاسِ هَلْ اَنْتُمْ مُّجْتَمِعُوْنَۙ وَّقِيْلَ : اور کہا گیا لِلنَّاسِ : لوگوں سے هَلْ : کیا اَنْتُمْ : تم مُّجْتَمِعُوْنَ : جمع ہونے ہو (جمع ہوگے) اور عام لوگوں سے بھی کہہ دیا گیا کہ تم بھی مجمع میں حاضر ہوجاؤ گے ؟ 1
