tafsir[15]{c,v,t}:
  19,96,اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ سَیَجْعَلُ لَهُمُ الرَّحْمٰنُ وُدًّا اِنَّ : بیشک الَّذِيْنَ اٰمَنُوْا : جو لوگ ایمان لائے وَعَمِلُوا : اور انہوں نے عمل کیے الصّٰلِحٰتِ : نیک سَيَجْعَلُ : پیدا کردے گا لَهُمُ : ان کے لیے الرَّحْمٰنُ : رحمن وُدًّا : محبت بیشک جو ایمان لائے ہیں اور جنہوں نے شائستہ اعمال کیے ہیں ان کے لئے اللہ رحمٰن محبت پیدا کر دے گا (1)
  19,97,فَاِنَّمَا یَسَّرْنٰهُ بِلِسَانِكَ لِتُبَشِّرَ بِهِ الْمُتَّقِیْنَ وَ تُنْذِرَ بِهٖ قَوْمًا لُّدًّا فَاِنَّمَا : پس اس کے سوا نہیں يَسَّرْنٰهُ : ہم نے اسے آسان کردیا ہے بِلِسَانِكَ : آپ کی زبان پر لِتُبَشِّرَ بِهِ : تاکہ آپ خوشخبری دیں اس کے ساتھ الْمُتَّقِيْنَ : پرہیزگاروں وَتُنْذِرَ بِهٖ : اور ڈرائیں اس سے قَوْمًا لُّدًّا : جھگڑالو لوگ ہم نے اس قرآن کو تیری زبان میں بہت ہی آسان کردیا ہے (1) کہ تو اس کے ذریعہ سے پرہیزگاروں کو خوشخبری دے اور جھگڑالو (2) کو ڈرا دے۔
  19,98,وَ كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنْ قَرْنٍ١ؕ هَلْ تُحِسُّ مِنْهُمْ مِّنْ اَحَدٍ اَوْ تَسْمَعُ لَهُمْ رِكْزًا۠    ۧ وَكَمْ : اور کتنے ہی اَهْلَكْنَا : ہم نے ہلاک کردئیے قَبْلَهُمْ : ان سے قبل مِّنْ : سے قَرْنٍ : گروہ هَلْ : کیا تُحِسُّ : تم دیکھتے ہو مِنْهُمْ : ان سے مِّنْ اَحَدٍ : کوئی۔ کسی کو اَوْ تَسْمَعُ : یا تم سنتے ہو لَهُمْ : ان کی رِكْزًا : آہٹ ہم نے اس سے پہلے بہت سی جماعتیں تباہ کردیں ہیں، کیا ان میں سے ایک بھی آہٹ تو پاتا ہے یا ان کی آواز کی بھنک بھی تیرے کان میں پڑتی ہے ؟ (1)۔
  20,1,طٰهٰۚ طٰهٰ : طہ طٰہٰ
  20,2,مَاۤ اَنْزَلْنَا عَلَیْكَ الْقُرْاٰنَ لِتَشْقٰۤىۙ مَآ اَنْزَلْنَا : ہم نے نازل نہیں کیا عَلَيْكَ : تم پر الْقُرْاٰنَ : قرآن لِتَشْقٰٓي : تاکہ تم مشقت میں پڑجاؤ ہم نے یہ قرآن تجھ پر اس لئے نہیں اتارا کہ تو مشقت میں پڑجائے۔ (1)
  20,3,اِلَّا تَذْكِرَةً لِّمَنْ یَّخْشٰىۙ اِلَّا : مگر تَذْكِرَةً : یاد دہانی لِّمَنْ : اس کے لیے جو يَّخْشٰى : ڈرتا ہے بلکہ اس کی نصیحت کے لئے جو اللہ سے ڈرتا ہے۔
  20,4,تَنْزِیْلًا مِّمَّنْ خَلَقَ الْاَرْضَ وَ السَّمٰوٰتِ الْعُلٰىؕ تَنْزِيْلًا : نازل کیا ہوا مِّمَّنْ : سے۔ جس خَلَقَ : بنایا الْاَرْضَ : زمین وَالسَّمٰوٰتِ : اور آسمان (جمع) الْعُلٰى : اونچے اس کا اتارنا اس کی طرف سے ہے جس نے زمین کو اور بلند آسمان کو پیدا کیا ہے۔
  20,5,اَلرَّحْمٰنُ عَلَى الْعَرْشِ اسْتَوٰى اَلرَّحْمَنُ : رحمن عَلَي الْعَرْشِ : عرش پر اسْتَوٰى : قائم جو رحمٰن ہے، عرش پر قائم ہے (1)
  20,6,لَهٗ مَا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ وَ مَا بَیْنَهُمَا وَ مَا تَحْتَ الثَّرٰى لَهٗ مَا : اس کے لیے جو فِي السَّمٰوٰتِ : آسمانوں میں وَمَا : اور جو فِي الْاَرْضِ : زمین میں وَمَا : اور جو بَيْنَهُمَا : ان دونوں کے درمیان وَمَا : اور جو تَحْتَ : نیچے الثَّرٰى : گیلی مٹی جس کی ملکیت آسمانوں اور زمین اور ان دونوں کے درمیان اور (کرہ خاک) کے نیچے کی ہر ایک چیز پر ہے (1)۔
  20,7,وَ اِنْ تَجْهَرْ بِالْقَوْلِ فَاِنَّهٗ یَعْلَمُ السِّرَّ وَ اَخْفٰى وَاِنْ : اور اگر تَجْهَرْ : تو پکار کر کہے بِالْقَوْلِ : بات فَاِنَّهٗ : تو بیشک وہ يَعْلَمُ : جانتا ہے السِّرَّ : بھید وَاَخْفٰي : اور نہایت پوشیدہ اگر تو اونچی بات کہے تو وہ تو ہر ایک پوشیدہ، بلکہ پوشیدہ سے پوشیدہ تر بات کو بھی بخوبی جانتا ہے
  20,8,اَللّٰهُ لَاۤ اِلٰهَ اِلَّا هُوَ١ؕ لَهُ الْاَسْمَآءُ الْحُسْنٰى اَللّٰهُ : اللہ لَآ اِلٰهَ : نہیں کوئی معبود اِلَّا هُوَ : اس کے سوا لَهُ : اسی کے لیے الْاَسْمَآءُ : سب نام الْحُسْنٰى : اچھے وہی اللہ ہے جس کے سوا کوئی معبود نہیں، بہترین نام اسی کے ہیں (1)۔
  20,9,وَ هَلْ اَتٰىكَ حَدِیْثُ مُوْسٰىۘ وَهَلْ : اور کیا اَتٰىكَ : تمہارے پاس آئی حَدِيْثُ : بات۔ خبر مُوْسٰى : موسیٰ تجھے موسیٰ ؑ کا قصہ بھی معلوم ہے۔
  20,10,اِذْ رَاٰ نَارًا فَقَالَ لِاَهْلِهِ امْكُثُوْۤا اِنِّیْۤ اٰنَسْتُ نَارًا لَّعَلِّیْۤ اٰتِیْكُمْ مِّنْهَا بِقَبَسٍ اَوْ اَجِدُ عَلَى النَّارِ هُدًى اِذْ رَاٰ : جب اس نے دیکھی نَارًا : آگ فَقَالَ : تو کہا لِاَهْلِهِ : اپنے گھروالوں کو امْكُثُوْٓا : تم ٹھہرو اِنِّىْٓ : بیشک میں نے اٰنَسْتُ : دیکھی ہے نَارًا : آگ لَّعَلِّيْٓ : شاید میں اٰتِيْكُمْ : تمہارے پاس لاؤں مِّنْهَا : اس سے بِقَبَسٍ : چنگاری اَوْ : یا اَجِدُ : میں پاؤں عَلَي النَّارِ : آگ پر۔ کے هُدًى : راستہ جبکہ اس نے آگ دیکھ کر اپنے گھر والوں سے کہا کہ تم ذرا سی دیر ٹھہر جاؤ مجھے آگ دکھائی دی ہے۔ بہت ممکن ہے کہ میں اس کا کوئی انگارا تمہارے پاس لاؤں یا آگ کے پاس سے راستے کی اطلاع پاؤں (1)۔
  20,11,فَلَمَّاۤ اَتٰىهَا نُوْدِیَ یٰمُوْسٰىؕ فَلَمَّآ : پس جب اَتٰىهَا : وہ وہاں آئے نُوْدِيَ : آواز آئی يٰمُوْسٰى : اے موسیٰ جب وہ وہاں پہنچے تو آواز دی گئی (1) اے موسٰی۔
  20,12,اِنِّیْۤ اَنَا رَبُّكَ فَاخْلَعْ نَعْلَیْكَ١ۚ اِنَّكَ بِالْوَادِ الْمُقَدَّسِ طُوًىؕ اِنِّىْٓ : بیشک میں اَنَا : میں رَبُّكَ : تمہارا رب فَاخْلَعْ : سو اتار لو نَعْلَيْكَ : اپنی جوتیاں اِنَّكَ : بیشک تم بِالْوَادِ الْمُقَدَّسِ : میدان پاک طُوًى : طوی یقیناً میں تیرا پروردگار ہوں تو اپنی جوتیاں اتار دے، (1) کیونکہ تو پاک میدان طویٰ میں ہے (2)۔
