quran[25]{c,v,t}:
  26,112,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالَ وما عِلْمِي﴾</span> وأيُّ شَيْءٍ عِلْمِي <span class="qpc-hafs">﴿بِما كانُوا يَعْمَلُونَ﴾</span> مِنَ الصِناعاتِ إنَّما أطْلُبُ مِنهُمُ الإيمانَ وقِيلَ إنَّهم طَعَنُوا مَعَ اسْتِرْذالِهِمْ في إيمانِهِمْ وقالُوا إنَّ الَّذِينَ آمَنُوا بِكَ لَيْسَ في قُلُوبِهِمْ ما يُظْهِرُونَهُ فَقالَ ما عَلَيَّ إلّا اعْتِبارُ الظَواهِرِ دُونَ التَفْتِيشِ عَنِ السَرائِرِ.</p></div>"
  26,113,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنْ حِسابُهم إلا عَلى رَبِّي لَوْ تَشْعُرُونَ﴾</span> أنَّ اللهَ يُحاسِبُهم عَلى ما في قُلُوبِهِمْ.</p></div>"
  26,114,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما أنا بِطارِدِ المُؤْمِنِينَ﴾</span> أيْ: لَيْسَ مِن شَأْنِي أنْ أتَّبِعَ شَهَواتِكم بِطَرْدِ المُؤْمِنِينَ طَمَعًا في إيمانِكُمْ.</p></div>"
  26,115,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنْ أنا إلا نَذِيرٌ مُبِينٌ﴾</span> ما عَلَيَّ إلّا أنْ أُنْذِرَكم إنْذارًا بَيِّنًا بِالبُرْهانِ الصَحِيحِ الَّذِي يَتَمَيَّزُ بِهِ الحَقُّ مِنَ الباطِلِ ثُمَّ أنْتُمْ أعْلَمُ بِشَأْنِكُمْ.</p></div>"
  26,116,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالُوا لَئِنْ لَمْ تَنْتَهِ يا نُوحُ﴾</span> عَمّا تَقُولُ <span class="qpc-hafs">﴿لَتَكُونَنَّ مِنَ المَرْجُومِينَ﴾</span> مِنَ المَقْتُولِينَ بِالحِجارَةِ.</p></div>"
  26,117,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالَ رَبِّ إنَّ قَوْمِي كَذَّبُونِ﴾</span> لَيْسَ هَذا إخْبارًا بِالتَكْذِيبِ لِعِلْمِهِ أنَّ عالِمَ الغَيْبِ والشَهادَةِ أعْلَمُ ولَكِنَّهُ أرادَ أنَّهم كَذَّبُونِي في وحْيِكَ ورِسالَتِكَ.</p></div>"
  26,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فافْتَحْ بَيْنِي وبَيْنَهم فَتْحًا﴾</span> أيْ: فاحْكم بَيْنِي وبَيْنَهم حُكْمًا، والفَتاحَةَ: الحُكُومَةُ، والفَتّاحَ الحاكِمُ، لِأنَّهُ يَفْتَحُ المُسْتَغْلَقِ كَما سُمِّيَ فَيْصَلًا، لِأنَّهُ يَفْصِلُ بَيْنَ الخُصُوماتِ <span class="qpc-hafs">﴿وَنَجِّنِي ومَن مَعِيَ﴾</span> حَفْصٌ <span class="qpc-hafs">﴿مِنَ المُؤْمِنِينَ﴾</span> مِن عَذابِ عَمَلِهِمْ (p-٥٧٤)</p></div>"
  26,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأنْجَيْناهُ ومَن مَعَهُ في الفُلْكِ﴾</span> الفُلْكُ السَفِينَةُ وجَمْعُهُ فُلُكٌ فالواحِدُ بِوَزْنِ قُفْلٍ والجَمْعُ بِوَزْنِ أُسُدٍ <span class="qpc-hafs">﴿المَشْحُونِ﴾</span> المَمْلُوءِ ومِنهُ شِحْنَةُ البَلَدِ أيِ الَّذِي يَمْلَؤُهُ كِفايَةً.</p></div>"
  26,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ أغْرَقْنا بَعْدُ﴾</span> أيْ: بَعْدَ إنْجاءِ نُوحٍ ومَن آمَنَ <span class="qpc-hafs">﴿الباقِينَ﴾</span> مِن قَوْمِهِ.</p></div>"
  26,121,""
  26,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإنَّ رَبَّكَ لَهو العَزِيزُ﴾</span> المُنْتَقِمُ بِإهانَةِ مَن جَحَدَ وأصَرَّ <span class="qpc-hafs">﴿الرَحِيمُ﴾</span> المُنْعِمُ بِإعانَةِ مَن وحَّدَ وأقَرَّ.</p></div>"
  26,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَّبَتْ عادٌ المُرْسَلِينَ﴾</span> هي قَبِيلَةٌ وفي الأصْلِ اسْمُ رَجُلٍ هو أبُو القَبِيلَةِ.</p></div>"
  26,124,""
  26,125,""
  26,126,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاتَّقُوا اللهَ﴾</span> في تَكْذِيبِ الرَسُولِ الأمِينِ <span class="qpc-hafs">﴿وَأطِيعُونِ﴾</span></p></div>"
  26,127,""
  26,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أتَبْنُونَ بِكُلِّ رِيعٍ﴾</span></p><p>مَكانٍ مُرْتَفِعٍ <span class="qpc-hafs">﴿آيَةً﴾</span> بُرْجَ حَمامٍ أوْ بِناءً يَكُونُ لِارْتِفاعِهِ كالعَلامَةِ يَسْخَرُونَ بِمَن مَرَّ بِهِمْ <span class="qpc-hafs">﴿تَعْبَثُونَ﴾</span> تَلْعَبُونَ.</p></div>"
  26,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَتَّخِذُونَ مَصانِعَ﴾</span> مَآخِذَ الماءِ أوْ قُصُورًا مُشَيَّدَةً أوْ حُصُونًا <span class="qpc-hafs">﴿لَعَلَّكم تَخْلُدُونَ﴾</span> تَرْجُونَ الخُلُودَ في الدُنْيا.</p></div>"
  26,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإذا بَطَشْتُمْ﴾</span> أخَذْتُمْ أخْذَ العُقُوبَةِ <span class="qpc-hafs">﴿بَطَشْتُمْ جَبّارِينَ﴾</span> قَتْلًا بِالسَيْفِ وضَرْبًا بِالسَوْطِ، والجَبّارُ الَّذِي يَقْتُلُ ويَضْرِبُ عَلى الغَضَبِ.</p></div>"
  26,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاتَّقُوا اللهَ﴾</span> في البَطْشِ <span class="qpc-hafs">﴿وَأطِيعُونِ﴾</span> فِيما أدْعُوكم إلَيْهِ.</p></div>"
  26,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿واتَّقُوا الَّذِي أمَدَّكم بِما تَعْلَمُونَ﴾</span> مِنَ النِعَمِ ثُمَّ عَدَّدَها عَلَيْهِمْ فَقالَ (p-٥٧٥)</p></div>"
  26,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أمَدَّكم بِأنْعامٍ وبَنِينَ﴾</span> قَرَنَ البَنِينَ بِالأنْعامِ، لِأنَّهم يُعِينُونَهم عَلى حِفْظِها والقِيامِ عَلَيْها.</p></div>"
  26,134,""
  26,135,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنِّي أخافُ عَلَيْكم عَذابَ يَوْمٍ عَظِيمٍ﴾</span> إنْ عَصَيْتُمُونِي.</p></div>"
  26,136,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالُوا سَواءٌ عَلَيْنا أوَعَظْتَ أمْ لَمْ تَكُنْ مِنَ الواعِظِينَ﴾</span> أيْ: لا يُقْبَلُ كَلامُكَ ودَعْوَتُكَ وعَظْتَ أمْ سَكَتَّ ولَمْ يَقُلْ أمْ لَمْ تَعِظْ لِرُءُوسِ الآيِ.</p></div>"