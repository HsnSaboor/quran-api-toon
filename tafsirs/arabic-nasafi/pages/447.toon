quran[27]{c,v,t}:
  37,25,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ما لَكم لا تَناصَرُونَ﴾</span> أيْ: لا يَنْصُرُ بَعْضُكم بَعْضًا، وهَذا تَوْبِيخٌ لَهم بِالعَجْزِ عَنِ التَناصُرِ، بَعْدَما كانُوا مُتَناصِرِينَ في الدُنْيا، وقِيلَ: هو جَوابٌ لِأبِي جَهْلٍ، حَيْثُ قالَ يَوْمَ "بَدْرٍ": <span class="qpc-hafs">﴿نَحْنُ جَمِيعٌ مُنْتَصِرٌ﴾</span> [القمر: ٤٤] وهو في مَوْضِعِ النَصْبِ عَلى الحالِ، أيْ: "ما لَكم غَيْرَ مُتَناصِرِينَ".</p></div>"
  37,26,"<div class=ar lang=ar><p>(p-١٢١)<span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span>، مُنْقادُونَ، أوْ قَدْ أسْلَمَ بَعْضُهم بَعْضًا، وخَذَلَهُ عَنْ عَجْزٍ، فَكُلُّهم مُسْتَسْلِمٌ غَيْرُ مُنْتَصِرٍ.</p></div>"
  37,27,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأقْبَلَ بَعْضُهم عَلى بَعْضٍ﴾</span> أيْ: اَلتّابِعُ عَلى المَتْبُوعِ،</p><p><span class="qpc-hafs">﴿يَتَساءَلُونَ﴾</span>، يَتَخاصَمُونَ.</p></div>"
  37,28,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالُوا﴾</span> أيْ: الأتْباعُ لِلْمَتْبُوعِينَ،</p><p><span class="qpc-hafs">﴿إنَّكم كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span>، عَنِ القُوَّةِ، والقَهْرِ، إذِ اليَمِينُ مَوْصُوفَةٌ بِالقُوَّةِ، وبِها يَقَعُ البَطْشُ، أيْ: إنَّكم تَحْمِلُونَنا عَلى الضَلالِ وتَقْسِرُونَنا عَلَيْهِ.</p></div>"
  37,29,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالُوا﴾</span> أيْ: اَلرُّؤَساءُ،</p><p><span class="qpc-hafs">﴿بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</span> أيْ: بَلْ أبَيْتُمْ أنْتُمُ الإيمانَ، وأعْرَضْتُمْ عَنْهُ، مَعَ تَمَكُّنِكم مِنهُ، مُخْتارِينَ لَهُ عَلى الكُفْرِ، غَيْرَ مُلْجَئِينَ.</p></div>"
  37,30,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما كانَ لَنا عَلَيْكم مِن سُلْطانٍ﴾</span>، تَسَلُّطٍ نَسْلُبُكم بِهِ تَمَكُّنَكُمْ، واخْتِيارَكُمْ،</p><p><span class="qpc-hafs">﴿بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span>، بَلْ كُنْتُمْ قَوْمًا مُخْتارِينَ الطُغْيانَ.</p></div>"
  37,31,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا﴾</span>، فَلَزِمَنا جَمِيعًا،</p><p><span class="qpc-hafs">﴿قَوْلُ رَبِّنا إنّا لَذائِقُونَ﴾</span>، يَعْنِي وعِيدُ اللهِ، بِأنّا ذائِقُونَ لِعَذابِهِ، لا مَحالَةَ، لِعِلْمِهِ بِحالِنا، ولَوْ حَكى الوَعِيدَ كَما هو لَقالَ: "إنَّكم لَذائِقُونَ"، ولَكِنَّهُ عَدَلَ بِهِ إلى لَفْظِ المُتَكَلِّمِ، لِأنَّهم مُتَكَلِّمُونَ بِذَلِكَ عَنْ أنْفُسِهِمْ، ونَحْوُهُ قَوْلُهُ:</p><p>؎ فَقَدْ زَعَمَتْ هَوازِنُ قَلَّ مالِي..........................</p><p>وَلَوْ حَكى قَوْلَها لَقالَ: "قَلَّ مالُكَ".</p></div>"
  37,32,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأغْوَيْناكُمْ﴾</span>، فَدَعَوْناكم إلى الغَيِّ،</p><p><span class="qpc-hafs">﴿إنّا كُنّا غاوِينَ﴾</span>، فَأرَدْنا إغْواءَكُمْ، لِتَكُونُوا أمْثالَنا.</p></div>"
  37,33,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإنَّهُمْ﴾</span>، فَإنَّ الأتْباعَ والمَتْبُوعِينَ جَمِيعًا،</p><p><span class="qpc-hafs">﴿يَوْمَئِذٍ﴾</span>، يَوْمَ القِيامَةِ،</p><p><span class="qpc-hafs">﴿فِي العَذابِ مُشْتَرِكُونَ﴾</span>، كَما كانُوا مُشْتَرِكِينَ في الغَوايَةِ.</p></div>"
  37,34,"<div class=ar lang=ar><p>(p-١٢٢)<span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span> أيْ: بِالمُشْرِكِينَ، إنّا مِثْلَ ذَلِكَ الفِعْلِ نَفْعَلُ بِكُلِّ مُجْرِمٍ.</p></div>"
  37,35,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّهم كانُوا إذا قِيلَ لَهم لا إلَهَ إلا اللهُ يَسْتَكْبِرُونَ﴾</span>، إنَّهم كانُوا إذا سَمِعُوا بِكَلِمَةِ التَوْحِيدِ اسْتَكْبَرُوا وأبَوْا إلّا الشِرْكَ.</p></div>"
  37,36,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَيَقُولُونَ أإنّا﴾</span>، بِهَمْزَتَيْنِ، "شامِيٌّ وكُوفِيٌّ"،</p><p><span class="qpc-hafs">﴿لَتارِكُو آلِهَتِنا لِشاعِرٍ مَجْنُونٍ﴾</span>، يَعْنُونَ مُحَمَّدًا - ﷺ.</p></div>"
  37,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَلْ جاءَ بِالحَقِّ﴾</span>، رَدٌّ عَلى المُشْرِكِينَ،</p><p><span class="qpc-hafs">﴿وَصَدَّقَ المُرْسَلِينَ﴾</span>، كَقَوْلِهِ: <span class="qpc-hafs">﴿مُصَدِّقًا لِما بَيْنَ يَدَيْهِ﴾</span> [البقرة: ٩٧]</p></div>"
  37,38,"<div class=ar lang=ar></div>"
  37,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما تُجْزَوْنَ إلا ما كُنْتُمْ تَعْمَلُونَ﴾</span>، بِلا زِيادَةٍ.</p></div>"
  37,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إلا عِبادَ اللهِ المُخْلَصِينَ﴾</span>، بِفَتْحِ اللامِ، "كُوفِيٌّ ومَدَنِيٌّ"، وكَذا ما بَعْدَهُ، أيْ: "لَكِنَّ عِبادَ اللهِ"، عَلى الِاسْتِثْناءِ المُنْقَطِعِ.</p></div>"
  37,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أُولَئِكَ لَهم رِزْقٌ مَعْلُومٌ﴾</span> <span class="qpc-hafs">﴿فَواكِهُ﴾</span>، فَسَّرَ الرِزْقَ المَعْلُومَ بِالفَواكِهِ، وهي كُلُّ ما يُتَلَذَّذُ بِهِ، ولا يُتَقَوَّتُ، لِحِفْظِ الصِحَّةِ، يَعْنِي أنَّ رِزْقَهم كُلَّهُ فَواكِهُ، لِأنَّهم مُسْتَغْنُونَ عَنْ حِفْظِ الصِحَّةِ بِالأقْواتِ، لِأنَّ أجْسادَهم مُحْكَمَةٌ، مَخْلُوقَةٌ لِلْأبَدِ، فَما يَأْكُلُونَهُ لِلتَّلَذُّذِ، ويَجُوزُ أنْ يُرادَ "رِزْقٌ مَعْلُومٌ مَنعُوتٌ بِخَصائِصِ خُلِقَ عَلَيْها، مِن طِيبِ طَعْمٍ، ورائِحَةٍ، ولَذَّةٍ، وحُسْنِ مَنظَرٍ"، وقِيلَ: مَعْلُومُ الوَقْتِ، كَقَوْلِهِ: <span class="qpc-hafs">﴿وَلَهم رِزْقُهم فِيها بُكْرَةً وعَشِيًّا﴾</span> [مريم: ٦٢]، والنَفْسُ إلَيْهِ أسْكَنُ،</p><p><span class="qpc-hafs">﴿وَهم مُكْرَمُونَ﴾</span>، مُنَعَّمُونَ.</p></div>"
  37,42,"37:41"
  37,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي جَنّاتِ النَعِيمِ﴾</span>، يَجُوزُ أنْ يَكُونَ ظَرْفًا، وأنْ يَكُونَ حالًا، وأنْ يَكُونَ خَبَرًا بَعْدَ خَبَرٍ، وكَذا:</p></div>"
  37,44,"<div class=ar lang=ar><p>(p-١٢٣)<span class="qpc-hafs">﴿عَلى سُرُرٍ مُتَقابِلِينَ﴾</span>، اَلتَّقابُلُ أتَمُّ لِلسُّرُورِ، وآنَسُ.</p></div>"
  37,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُطافُ عَلَيْهِمْ بِكَأْسٍ﴾</span>، بِغَيْرِ هَمْزٍ، "أبُو عَمْرٍو وحَمْزَةُ"، في الوَقْفِ، وغَيْرُهُما بِالهَمْزَةِ، يُقالُ لِلزُّجاجَةِ فِيها الخَمْرُ: "كَأْسٌ"، وتُسَمّى الخَمْرُ نَفْسُها "كَأْسًا"، وعَنِ الأخْفَشِ: كُلُّ كَأْسٍ في القُرْآنِ فَهي الخَمْرُ، وكَذا في تَفْسِيرِ ابْنِ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما -،</p><p><span class="qpc-hafs">﴿مِن مَعِينٍ﴾</span>، مِن شَرابٍ مَعِينٍ، أوْ مِن نَهْرٍ مَعِينٍ، وهو الجارِي عَلى وجْهِ الأرْضِ، الظاهِرُ لِلْعُيُونِ، وُصِفَ بِما وُصِفَ بِهِ الماءُ، لِأنَّهُ يَجْرِي في الجَنَّةِ في أنْهارٍ، كَما يَجْرِي الماءُ، قالَ اللهُ (تَعالى): <span class="qpc-hafs">﴿وَأنْهارٌ مِن خَمْرٍ﴾</span> [محمد: ١٥]</p></div>"
  37,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بَيْضاءَ﴾</span>، صِفَةٌ لِلْكَأْسِ،</p><p><span class="qpc-hafs">﴿لَذَّةٍ﴾</span>، وُصِفَتْ بِاللَذَّةِ، كَأنَّها نَفْسُ اللَذَّةِ، وعَيْنُها، أوْ "ذاتُ لَذَّةٍ"،</p><p><span class="qpc-hafs">﴿لِلشّارِبِينَ﴾</span></p></div>"
  37,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لا فِيها غَوْلٌ﴾</span> أيْ: لا تَغْتالُ عُقُولَهُمْ، كَخُمُورِ الدُنْيا، وهو مِن "غالَهُ، يَغُولُهُ، غَوْلًا"، إذا أهْلَكَهُ، وأفْسَدَهُ،</p><p><span class="qpc-hafs">﴿وَلا هم عَنْها يُنْـزَفُونَ﴾</span>، يَسْكَرُونَ، مِن "نَزَفَ الشارِبُ"، إذا ذَهَبَ عَقْلُهُ، ويُقالُ لِلسَّكْرانِ: "نَزِيفٌ"، و"مَنزُوفٌ"، "يُنْزِفُونَ"، "عَلِيٌّ وحَمْزَةُ"، أيْ: لا يَسْكَرُونَ، أوْ لا يَنْزِفُ شَرابُهُمْ، مِن "أنْزَفَ الشارِبُ"، إذا ذَهَبَ عَقْلُهُ، أوْ شَرابُهُ.</p></div>"
  37,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَعِنْدَهم قاصِراتُ الطَرْفِ﴾</span>، قَصَرْنَ أبْصارَهُنَّ عَلى أزْواجِهِنَّ، لا يَمْدُدْنَ طَرْفًا إلى غَيْرِهِمْ،</p><p><span class="qpc-hafs">﴿عِينٌ﴾</span>، جَمْعُ "عَيْناءُ"، أيْ: نَجْلاءُ واسِعَةٌ العَيْنِ.</p></div>"
  37,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأنَّهُنَّ بَيْضٌ مَكْنُونٌ﴾</span>، مَصُونٌ، شَبَّهَهُنَّ بِبَيْضِ النَعامِ المَكْنُونِ في الصَفاءِ، وبِها تُشَبِّهُ العَرَبُ النِساءَ، وتُسَمِّيهِنَّ: "بَيْضاتُ الخُدُورِ"، وعُطِفَ.</p></div>"
  37,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأقْبَلَ بَعْضُهُمْ﴾</span>، يَعْنِي أهْلَ الجَنَّةِ،</p><p><span class="qpc-hafs">﴿عَلى بَعْضٍ يَتَساءَلُونَ﴾</span>، عَلى (p-١٢٤)"يُطافُ عَلَيْهِمْ"، والمَعْنى: "يَشْرَبُونَ، ويَتَحادَثُونَ عَلى الشَرابِ، كَعادَةِ الشُرْبِ"، قالَ:</p><p>؎ وما بَقِيَتْ مِنَ اللَذّاتِ إلّا... أحادِيثُ الكِرامِ عَلى المُدامِ</p><p>فَيُقْبِلُ بَعْضُهم عَلى بَعْضٍ يَتَساءَلُونَ عَمّا جَرى لَهُمْ، وعَلَيْهِمْ، في الدُنْيا، إلّا أنَّهُ جِيءَ بِهِ ماضِيًا، عَلى ما عُرِفَ في أخْبارِهِ.</p></div>"
  37,51,"<div class=ar lang=ar></div>"