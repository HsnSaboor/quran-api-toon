tafsir[31]{c,v,t}:
77,20," <q>﴿ألَمْ نَخْلُقْكم مِن ماءٍ مَهِينٍ﴾</q>، حَقِيرٍ، وهو النُطْفَةُ. "
77,21," <q>﴿فَجَعَلْناهُ﴾</q> أيْ: اَلْماءَ، <q>﴿فِي قَرارٍ مَكِينٍ﴾</q>، مَقَرٍّ يَتَمَكَّنُ فِيهِ، وهو الرَحِمُ، ومَحَلُّ. "
77,22," <q>﴿إلى قَدَرٍ مَعْلُومٍ﴾</q>، اَلْحالُ، أيْ: مُؤَخَّرًا إلى مِقْدارٍ مِنَ الوَقْتِ مَعْلُومٍ، قَدْ عَلِمَهُ اللهُ، وحَكَمَ بِهِ، وهو تِسْعَةُ أشْهُرٍ، أوْ ما فَوْقَها، أوْ ما دُونَها. "
77,23," <q>﴿فَقَدَرْنا﴾</q>، فَقَدَرْناهُ ذَلِكَ تَقْدِيرًا، <q>﴿فَنِعْمَ القادِرُونَ﴾</q>، فَنِعْمَ المُقَدِّرُونَ لَهُ نَحْنُ! أوْ فَقَدَرْنا عَلى ذَلِكَ، فَنِعْمَ القادِرُونَ عَلَيْهِ نَحْنُ! والأوَّلُ أحَقُّ، لِقِراءَةِ نافِعٍ وعَلِيٍّ بِالتَشْدِيدِ، ولِقَوْلِهِ: <q>﴿مِن نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾</q> [عبس: ١٩] "
77,24," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِنِعْمَةِ الفِطْرَةِ. "
77,25," <q>﴿ألَمْ نَجْعَلِ الأرْضَ كِفاتًا﴾</q>، وهو مِن "كَفَتَ الشَيْءَ"، إذا ضَمَّهُ، وجَمَعَهُ، وهو اسْمُ ما يَكْفِتُ، كَقَوْلِهِمْ: "اَلضِّمامُ"، لِما يَضُمُّ، وبِهِ انْتَصَبَ. "
77,26," <q>﴿أحْياءً وأمْواتًا﴾</q>، كَأنَّهُ قِيلَ: "كافِتَةً أحْياءً وأمْواتًا"، أوْ بِفِعْلٍ مُضْمَرٍ، يَدُلُّ عَلَيْهِ "كِفاتًا"، وهو "تَكْفِتُ"، أيْ: تَكْفِتُ أحْياءً عَلى ظَهْرِها، وأمْواتًا في بَطْنِها، والتَنْكِيرُ فِيهِما لِلتَّفْخِيمِ، أيْ: "تَكْفِتُ أحْياءً لا يُعَدُّونَ، وأمْواتًا لا يُحْصَرُونَ. "
77,27," <q>﴿وَجَعَلْنا فِيها رَواسِيَ﴾</q>، جِبالًا ثَوابِتَ، <q>﴿شامِخاتٍ﴾</q>، عالِياتٍ، <q>﴿وَأسْقَيْناكم ماءً فُراتًا﴾</q>، عَذْبًا. "
77,28," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِهَذِهِ النِعْمَةِ. "
77,29," <q>﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾</q> أيْ: يُقالُ لِلْكافِرِينَ يَوْمَ القِيامَةِ: سِيرُوا إلى النارِ الَّتِي كُنْتُمْ بِها تُكَذِّبُونَ. "
77,30," (p-٥٨٧)<q>﴿انْطَلِقُوا﴾</q>، تَكْرِيرٌ لِلتَّوْكِيدِ، <q>﴿إلى ظِلٍّ﴾</q>، دُخانِ جَهَنَّمَ، <q>﴿ذِي ثَلاثِ شُعَبٍ﴾</q>، يَتَشَعَّبُ لِعِظَمِهِ ثَلاثَ شُعَبٍ، وهَكَذا الدُخانُ العَظِيمُ يَتَفَرَّقُ ثَلاثَ فِرَقٍ. "
77,31," <q>﴿لا ظَلِيلٍ﴾</q>، نَعْتُ "ظَلٍّ"، أيْ: "لا مُظِلٍّ مِن حَرِّ ذَلِكَ اليَوْمِ، وحَرِّ النارِ، <q>﴿وَلا يُغْنِي﴾</q>، في مَحَلِّ الجَرِّ، أيْ: وغَيْرُ مُغْنٍ عَنْهُمْ، <q>﴿مِنَ اللهَبِ﴾</q>، مِن حَرِّ اللهَبِ شَيْئًا. "
77,32," <q>﴿إنَّها﴾</q> أيْ: اَلنّارُ، <q>﴿تَرْمِي بِشَرَرٍ﴾</q>، هو ما تَطايَرَ مِنَ النارِ، <q>﴿كالقَصْرِ﴾</q>، في العِظَمِ، وقِيلَ: هو الغَلِيظُ مِنَ الشَجَرِ، الواحِدَةُ "قَصْرَةٌ". "
77,33," <q>﴿كَأنَّهُ جِمالَتٌ﴾</q>، "كُوفِيٌّ غَيْرَ أبِي بَكْرٍ "، جَمْعُ "جَمَلٌ"، "جِمالاتٌ"، غَيْرُهُمْ، جَمْعُ الجَمْعِ، "صُفْرٌ": جَمْعُ "أصْفَرُ"، أيْ: سُودٌ، تَضْرِبُ إلى الصُفْرَةِ، وشَبَّهَ الشَرَرَ بِالقُصُورِ، لِعِظَمِهِ، وارْتِفاعِهِ، وبِالجِمالِ، لِلْعِظَمِ والطُولِ واللَوْنِ. "
77,34," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِأنَّ هَذِهِ صِفَتُها. "
77,35," <q>﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾</q>، وقُرِئَ بِنَصْبِ اليَوْمِ، أيْ: هَذا الَّذِي قُصَّ عَلَيْكم واقِعٌ يَوْمَئِذٍ، وسُئِلَ ابْنُ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما - عَنْ هَذِهِ الآيَةِ، وعَنْ قَوْلِهِ: <q>﴿ثُمَّ إنَّكم يَوْمَ القِيامَةِ عِنْدَ رَبِّكم تَخْتَصِمُونَ﴾</q> [الزمر: ٣١]، فَقالَ: "فِي ذَلِكَ اليَوْمِ مَواقِفُ، في بَعْضِها يَخْتَصِمُونَ، وفي بَعْضِها لا يَنْطِقُونَ"، أوْ لا يَنْطِقُونَ بِما يَنْفَعُهُمْ، فَجُعِلَ نُطْقُهم كَـ "لا نُطْقَ". "
77,36," <q>﴿وَلا يُؤْذَنُ لَهُمْ﴾</q>، في الِاعْتِذارِ، <q>﴿فَيَعْتَذِرُونَ﴾</q>، عَطْفٌ عَلى "يُؤْذَنُ"، مُنْخَرِطٌ في سِلْكِ النَفْيِ، أيْ: لا يَكُونُ لَهم إذَنٌ واعْتِذارٌ. "
77,37," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِهَذا اليَوْمِ. "
77,38," <q>﴿هَذا يَوْمُ الفَصْلِ﴾</q>، بَيْنَ المُحِقِّ، والمُبْطِلِ، والمُحْسِنِ، والمُسِيءِ، بِالجَزاءِ، (p-٥٨٨)<q>﴿جَمَعْناكُمْ﴾</q>، يا مُكَذِّبِي مُحَمَّدٍ، <q>﴿والأوَّلِينَ﴾</q>، والمُكَذِّبِينَ قَبْلَكم. "
77,39," <q>﴿فَإنْ كانَ لَكم كَيْدٌ﴾</q>، حِيلَةٌ في دَفْعِ العَذابِ، <q>﴿فَكِيدُونِ﴾</q>، فاحْتالُوا عَلَيَّ بِتَخْلِيصِ أنْفُسِكم مِنَ العَذابِ، و"اَلْكَيْدُ"، مُتَّعَدٍ، تَقُولُ: "كِدْتُ فُلانًا"، إذا احْتَلْتَ عَلَيْهِ. "
77,40," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِالبَعْثِ. "
77,41," <q>﴿إنَّ المُتَّقِينَ﴾</q>، مِن عَذابِ اللهِ، <q>﴿فِي ظِلالٍ﴾</q>، جَمْعُ "ظِلٌّ"، <q>﴿وَعُيُونٍ﴾</q>، جارِيَةٍ في الجَنَّةِ. "
77,42," <q>﴿وَفَواكِهَ مِمّا يَشْتَهُونَ﴾</q> أيْ: لَذِيذَةٍ مُشْتَهاةٍ. "
77,43," <q>﴿كُلُوا واشْرَبُوا﴾</q>، في مَوْضِعِ الحالِ مِن ضَمِيرِ "اَلْمُتَّقِينَ"، في الظَرْفِ الَّذِي هو "فِي ظِلالٍ"، أيْ: هم مُسْتَقِرُّونَ في ظِلالٍ، مَقُولًا لَهم ذَلِكَ، <q>﴿هَنِيئًا بِما كُنْتُمْ تَعْمَلُونَ﴾</q>، في الدُنْيا. "
77,44," <q>﴿إنّا كَذَلِكَ نَجْزِي المُحْسِنِينَ﴾</q>، فَأحْسِنُوا، تُجْزَوْا بِهَذا. "
77,45," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِالجَنَّةِ. "
77,46," <q>﴿كُلُوا وتَمَتَّعُوا﴾</q>، كَلامٌ مُسْتَأْنَفٌ، خِطابٌ لِلْمُكَذِّبِينَ في الدُنْيا، عَلى وجْهِ التَهْدِيدِ، كَقَوْلِهِ: <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q> [فصلت: ٤٠] <q>﴿قَلِيلا﴾</q>، لِأنَّ مَتاعَ الدُنْيا قَلِيلٌ، <q>﴿إنَّكم مُجْرِمُونَ﴾</q>، كافِرُونَ، أيْ: إنَّ كُلَّ مُجْرِمٍ يَأْكُلُ ويَتَمَتَّعُ أيّامًا قَلائِلَ، ثُمَّ يَبْقى في الهَلاكِ الدائِمِ. "
77,47," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِالنِعَمِ. "
77,48," <q>﴿وَإذا قِيلَ لَهُمُ ارْكَعُوا﴾</q>، اِخْشَعُوا لِلَّهِ، وتَواضَعُوا إلَيْهِ بِقَبُولِ وحْيِهِ، واتِّباعِ دِينِهِ، ودَعُوا هَذا الِاسْتِكْبارَ، <q>﴿لا يَرْكَعُونَ﴾</q>، لا يَخْشَعُونَ، ولا يَقْبَلُونَ ذَلِكَ، ويُصِرُّونَ عَلى اسْتِكْبارِهِمْ، وإذا قِيلَ لَهُمْ: صَلُّوا، لا يُصَلُّونَ. "
77,49," <q>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</q>، بِالأمْرِ، والنَهْيِ. "
77,50," <q>﴿فَبِأيِّ حَدِيثٍ بَعْدَهُ﴾</q>، بَعْدَ القُرْآنِ، <q>﴿يُؤْمِنُونَ﴾</q> أيْ: إنْ لَمْ يُؤْمِنُوا بِالقُرْآنِ، مَعَ أنَّهُ آيَةٌ مُبْصِرَةٌ، ومُعْجِزَةٌ باهِرَةٌ، مِن بَيْنِ الكُتُبِ السَماوِيَّةِ، فَبِأيِّ كِتابٍ بَعْدَهُ يُؤْمِنُونَ؟! "
