quran[27]{c,v,t}:
55,41," <q>﴿يُعْرَفُ المُجْرِمُونَ بِسِيماهُمْ﴾</q>، بِسَوادِ وُجُوهِهِمْ، وزُرْقَةِ عُيُونِهِمْ، <q>﴿فَيُؤْخَذُ بِالنَواصِي والأقْدامِ﴾</q> أيْ: يُؤْخَذُ تارَةً بِالنَواصِي، وتارَةً بِالأقْدامِ. "
55,42," <q>﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> [الرحمن: ٤٠] "
55,43," <q>﴿هَذِهِ جَهَنَّمُ الَّتِي يُكَذِّبُ بِها المُجْرِمُونَ﴾</q> <q>﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</q>، ماءٍ حارٍّ، قَدِ انْتَهى حَرُّهُ، أيْ: يُعاقَبُ عَلَيْهِمْ بَيْنَ التَصْلِيَةِ بِالنارِ وبَيْنَ شُرْبِ الحَمِيمِ. "
  55,44,"55:43"
55,45," <q>﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> [الرحمن: ٤٢]، والنِعْمَةُ في هَذا نَجاةُ الناجِي مِنهُ، بِفَضْلِهِ ورَحْمَتِهِ، وما في الإنْذارِ بِهِ مِنَ التَنْبِيهِ. "
55,46," <q>﴿وَلِمَن خافَ مَقامَ رَبِّهِ﴾</q>، مَوْقِفَهُ الَّذِي يَقِفُ فِيهِ العِبادُ لِلْحِسابِ يَوْمَ القِيامَةِ، فَيَتْرُكُ المَعاصِي، أوْ فَأدّى الفَرائِضَ، وقِيلَ: هو مُقْحَمٌ، كَقَوْلِهِ: "وَنَفَيْتُ عَنْهُ مَقامَ الذِئْبِ"، أيْ: "وَنَفَيْتُ عَنْهُ الذِئْبَ"، <q>﴿جَنَّتانِ﴾</q>، جَنَّةُ الإنْسِ، وجَنَّةُ الجِنِّ، لِأنَّ الخِطابَ لِلثَّقَلَيْنِ، وكَأنَّهُ قِيلَ: "لِكُلِّ خائِفَيْنِ مِنكُما جَنَّتانِ، جَنَّةٌ لِلْخائِفِ الإنْسِيِّ، وجَنَّةٌ لِلْخائِفِ الجِنِّيِّ". "
55,47," "
55,48," <q>﴿ذَواتا أفْنانٍ﴾</q>، أغْصانٍ، جَمْعُ "فَنَنٌ"، وخَصَّ الأفْنانَ لِأنَّها هي الَّتِي تُورِقُ، وتُثْمِرُ، فَمِنها تَمْتَدُّ الظِلالُ، ومِنها تُجْتَنى الثِمارُ، أوْ "ألْوانٍ"، جَمْعُ "فَنٌّ"، أيْ: لَهُ فِيها ما تَشْتَهِي الأنْفُسُ، وتَلَذُّ الأعْيُنُ، قالَ: ؎ ومِن كُلِّ أفْنانِ اللَذاذَةِ والصِبا... لَهَوْتُ بِهِ والعَيْشُ أخْضَرُ ناضِرُ. "
55,49," "
55,50," <q>﴿فِيهِما﴾</q>، في الجَنَّتَيْنِ، <q>﴿عَيْنانِ تَجْرِيانِ﴾</q>، حَيْثُ شاؤُوا، في الأعالِي والأسافِلِ، وعَنِ الحَسَنِ: "تَجْرِيانِ بِالماءِ الزُلالِ، إحْداهُما التَسْنِيمُ، والأُخْرى السَلْسَبِيلُ ". "
55,51," "
55,52," <q>﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</q>، صِنْفانِ، صِنْفٌ مَعْرُوفٌ، وصِنْفٌ غَرِيبٌ. "
55,53," <q>﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> [الرحمن: ٥١] "
55,54," <q>﴿مُتَّكِئِينَ﴾</q>، نُصِبَ عَلى المَدْحِ لِلْخائِفِينَ، أوْ حالٌ مِنهُمْ، لِأنَّ "مَن خافَ"، في مَعْنى الجَمْعِ، <q>﴿عَلى فُرُشٍ﴾</q>، جَمْعُ "فِراشٌ"، <q>﴿بَطائِنُها﴾</q>، جَمْعُ "بِطانَةٌ"، <q>﴿مِن إسْتَبْرَقٍ﴾</q>، دِيباجٍ ثَخِينٍ، وهو مُعَرَّبٌ، قِيلَ: "ظَهائِرُها مِن سُنْدُسٍ"، وقِيلَ: لا يَعْلَمُها إلّا اللهُ، <q>﴿وَجَنى الجَنَّتَيْنِ دانٍ﴾</q>، وثَمَرُها قَرِيبٌ، يَنالُهُ القائِمُ والقاعِدُ والمُتَّكِئُ. "
55,55," "
55,56," <q>﴿فِيهِنَّ﴾</q>، في الجَنَّتَيْنِ، لِاشْتِمالِهِما عَلى أماكِنَ وقُصُورٍ ومَجالِسَ، أوْ في هَذِهِ الآلاءِ المَعْدُودَةِ، مِنَ الجَنَّتَيْنِ، والعَيْنَيْنِ، والفاكِهَةِ، والفُرُشِ، والجَنى، <q>﴿قاصِراتُ الطَرْفِ﴾</q>، نِساءٌ قَصَرْنَ أبْصارَهُنَّ عَلى أزْواجِهِنَّ، لا يَنْظُرْنَ إلى غَيْرِهِمْ، <q>﴿لَمْ يَطْمِثْهُنَّ﴾</q>، بِكَسْرِ المِيمِ: " اَلدُّورِيُّ "، و" عَلِيٌّ ": بِضَمِّ المِيمِ، و"اَلطَّمْثُ": اَلْجِماعُ بِالتَدْمِيَةِ، <q>﴿إنْسٌ قَبْلَهم ولا جانٌّ﴾</q>، وهَذا دَلِيلٌ عَلى أنَّ الجِنَّ يَطْمِثُونَ كَما يَطْمِثُ الإنْسُ. "
55,57," "
55,58," <q>﴿كَأنَّهُنَّ الياقُوتُ﴾</q>، صَفاءً، <q>﴿والمَرْجانُ﴾</q>، بَياضًا، فَهو أبْيَضُ مِنَ اللُؤْلُؤِ. "
55,59," "
55,60," <q>﴿هَلْ جَزاءُ الإحْسانِ﴾</q>، في العَمَلِ، <q>﴿إلا الإحْسانُ﴾</q>، في الثَوابِ، وقِيلَ: ما جَزاءُ مَن قالَ: "لا إلَهَ إلّا اللهُ"، إلّا الجَنَّةُ؟! وعَنْ إبْراهِيمَ الخَواصِّ فِيهِ: "هَلْ جَزاءُ الإسْلامِ إلّا دارُ السَلامِ؟!". "
55,61," "
55,62," <q>﴿وَمِن دُونِهِما﴾</q>، ومِن دُونِ تَيْنِكَ الجَنَّتَيْنِ المَوْعُودَتَيْنِ لِلْمُقَرَّبِينَ، <q>﴿جَنَّتانِ﴾</q>، لِمَن دُونُهم مِنَ أصْحابِ اليَمِينِ. "
55,63," "
55,64," <q>﴿مُدْهامَّتانِ﴾</q>، سَوْداوانِ مِن شِدَّةِ الخُضْرَةِ، قالَ الخَلِيلُ: "اَلدُّهْمَةُ": اَلسَّوادُ. "
55,65," "
55,66," <q>﴿فِيهِما عَيْنانِ نَضّاخَتانِ﴾</q>، فَوّارَتانِ بِالماءِ، لا تَنْقَطِعانِ. "
55,67," <q>﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> [الرحمن: ٦٩] "
