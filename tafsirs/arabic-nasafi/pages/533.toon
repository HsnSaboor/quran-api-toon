quran[27]{c,v,t}:
  55,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يُعْرَفُ المُجْرِمُونَ بِسِيماهُمْ﴾</span>، بِسَوادِ وُجُوهِهِمْ، وزُرْقَةِ عُيُونِهِمْ،</p><p><span class="qpc-hafs">﴿فَيُؤْخَذُ بِالنَواصِي والأقْدامِ﴾</span> أيْ: يُؤْخَذُ تارَةً بِالنَواصِي، وتارَةً بِالأقْدامِ.</p></div>"
  55,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> [الرحمن: ٤٠]</p></div>"
  55,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَذِهِ جَهَنَّمُ الَّتِي يُكَذِّبُ بِها المُجْرِمُونَ﴾</span> <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span>، ماءٍ حارٍّ، قَدِ انْتَهى حَرُّهُ، أيْ: يُعاقَبُ عَلَيْهِمْ بَيْنَ التَصْلِيَةِ بِالنارِ وبَيْنَ شُرْبِ الحَمِيمِ.</p></div>"
  55,44,"55:43"
  55,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> [الرحمن: ٤٢]، والنِعْمَةُ في هَذا نَجاةُ الناجِي مِنهُ، بِفَضْلِهِ ورَحْمَتِهِ، وما في الإنْذارِ بِهِ مِنَ التَنْبِيهِ.</p></div>"
  55,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلِمَن خافَ مَقامَ رَبِّهِ﴾</span>، مَوْقِفَهُ الَّذِي يَقِفُ فِيهِ العِبادُ لِلْحِسابِ يَوْمَ القِيامَةِ، فَيَتْرُكُ المَعاصِي، أوْ فَأدّى الفَرائِضَ، وقِيلَ: هو مُقْحَمٌ، كَقَوْلِهِ: "وَنَفَيْتُ عَنْهُ مَقامَ الذِئْبِ"، أيْ: "وَنَفَيْتُ عَنْهُ الذِئْبَ"،</p><p><span class="qpc-hafs">﴿جَنَّتانِ﴾</span>، جَنَّةُ الإنْسِ، وجَنَّةُ الجِنِّ، لِأنَّ الخِطابَ لِلثَّقَلَيْنِ، وكَأنَّهُ قِيلَ: "لِكُلِّ خائِفَيْنِ مِنكُما جَنَّتانِ، جَنَّةٌ لِلْخائِفِ الإنْسِيِّ، وجَنَّةٌ لِلْخائِفِ الجِنِّيِّ".</p></div>"
  55,47,"<div class=ar lang=ar></div>"
  55,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذَواتا أفْنانٍ﴾</span>، أغْصانٍ، جَمْعُ "فَنَنٌ"، وخَصَّ الأفْنانَ لِأنَّها هي الَّتِي تُورِقُ، وتُثْمِرُ، فَمِنها تَمْتَدُّ الظِلالُ، ومِنها تُجْتَنى الثِمارُ، أوْ "ألْوانٍ"، جَمْعُ "فَنٌّ"، أيْ: لَهُ فِيها ما تَشْتَهِي الأنْفُسُ، وتَلَذُّ الأعْيُنُ، قالَ:</p><p>؎ ومِن كُلِّ أفْنانِ اللَذاذَةِ والصِبا... لَهَوْتُ بِهِ والعَيْشُ أخْضَرُ ناضِرُ.</p></div>"
  55,49,"<div class=ar lang=ar></div>"
  55,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِما﴾</span>، في الجَنَّتَيْنِ،</p><p><span class="qpc-hafs">﴿عَيْنانِ تَجْرِيانِ﴾</span>، حَيْثُ شاؤُوا، في الأعالِي والأسافِلِ، وعَنِ الحَسَنِ: "تَجْرِيانِ بِالماءِ الزُلالِ، إحْداهُما التَسْنِيمُ، والأُخْرى السَلْسَبِيلُ ".</p></div>"
  55,51,"<div class=ar lang=ar></div>"
  55,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِما مِن كُلِّ فاكِهَةٍ زَوْجانِ﴾</span>، صِنْفانِ، صِنْفٌ مَعْرُوفٌ، وصِنْفٌ غَرِيبٌ.</p></div>"
  55,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> [الرحمن: ٥١]</p></div>"
  55,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُتَّكِئِينَ﴾</span>، نُصِبَ عَلى المَدْحِ لِلْخائِفِينَ، أوْ حالٌ مِنهُمْ، لِأنَّ "مَن خافَ"، في مَعْنى الجَمْعِ،</p><p><span class="qpc-hafs">﴿عَلى فُرُشٍ﴾</span>، جَمْعُ "فِراشٌ"،</p><p><span class="qpc-hafs">﴿بَطائِنُها﴾</span>، جَمْعُ "بِطانَةٌ"،</p><p><span class="qpc-hafs">﴿مِن إسْتَبْرَقٍ﴾</span>، دِيباجٍ ثَخِينٍ، وهو مُعَرَّبٌ، قِيلَ: "ظَهائِرُها مِن سُنْدُسٍ"، وقِيلَ: لا يَعْلَمُها إلّا اللهُ،</p><p><span class="qpc-hafs">﴿وَجَنى الجَنَّتَيْنِ دانٍ﴾</span>، وثَمَرُها قَرِيبٌ، يَنالُهُ القائِمُ والقاعِدُ والمُتَّكِئُ.</p></div>"
  55,55,"<div class=ar lang=ar></div>"
  55,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِنَّ﴾</span>، في الجَنَّتَيْنِ، لِاشْتِمالِهِما عَلى أماكِنَ وقُصُورٍ ومَجالِسَ، أوْ في هَذِهِ الآلاءِ المَعْدُودَةِ، مِنَ الجَنَّتَيْنِ، والعَيْنَيْنِ، والفاكِهَةِ، والفُرُشِ، والجَنى،</p><p><span class="qpc-hafs">﴿قاصِراتُ الطَرْفِ﴾</span>، نِساءٌ قَصَرْنَ أبْصارَهُنَّ عَلى أزْواجِهِنَّ، لا يَنْظُرْنَ إلى غَيْرِهِمْ،</p><p><span class="qpc-hafs">﴿لَمْ يَطْمِثْهُنَّ﴾</span>، بِكَسْرِ المِيمِ: " اَلدُّورِيُّ "، و" عَلِيٌّ ": بِضَمِّ المِيمِ، و"اَلطَّمْثُ": اَلْجِماعُ بِالتَدْمِيَةِ،</p><p><span class="qpc-hafs">﴿إنْسٌ قَبْلَهم ولا جانٌّ﴾</span>، وهَذا دَلِيلٌ عَلى أنَّ الجِنَّ يَطْمِثُونَ كَما يَطْمِثُ الإنْسُ.</p></div>"
  55,57,"<div class=ar lang=ar></div>"
  55,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَأنَّهُنَّ الياقُوتُ﴾</span>، صَفاءً،</p><p><span class="qpc-hafs">﴿والمَرْجانُ﴾</span>، بَياضًا، فَهو أبْيَضُ مِنَ اللُؤْلُؤِ.</p></div>"
  55,59,"<div class=ar lang=ar></div>"
  55,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَلْ جَزاءُ الإحْسانِ﴾</span>، في العَمَلِ،</p><p><span class="qpc-hafs">﴿إلا الإحْسانُ﴾</span>، في الثَوابِ، وقِيلَ: ما جَزاءُ مَن قالَ: "لا إلَهَ إلّا اللهُ"، إلّا الجَنَّةُ؟! وعَنْ إبْراهِيمَ الخَواصِّ فِيهِ: "هَلْ جَزاءُ الإسْلامِ إلّا دارُ السَلامِ؟!".</p></div>"
  55,61,"<div class=ar lang=ar></div>"
  55,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمِن دُونِهِما﴾</span>، ومِن دُونِ تَيْنِكَ الجَنَّتَيْنِ المَوْعُودَتَيْنِ لِلْمُقَرَّبِينَ،</p><p><span class="qpc-hafs">﴿جَنَّتانِ﴾</span>، لِمَن دُونُهم مِنَ أصْحابِ اليَمِينِ.</p></div>"
  55,63,"<div class=ar lang=ar></div>"
  55,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مُدْهامَّتانِ﴾</span>، سَوْداوانِ مِن شِدَّةِ الخُضْرَةِ، قالَ الخَلِيلُ: "اَلدُّهْمَةُ": اَلسَّوادُ.</p></div>"
  55,65,"<div class=ar lang=ar></div>"
  55,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِيهِما عَيْنانِ نَضّاخَتانِ﴾</span>، فَوّارَتانِ بِالماءِ، لا تَنْقَطِعانِ.</p></div>"
  55,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> [الرحمن: ٦٩]</p></div>"