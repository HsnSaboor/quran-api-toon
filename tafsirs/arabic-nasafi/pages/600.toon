quran[21]{c,v,t}:
  100,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَحُصِّلَ ما في الصُدُورِ﴾</span>، مُيِّزَ ما فِيها مِنَ الخَيْرِ، والشَرِّ.</p></div>"
  100,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ رَبَّهم بِهِمْ يَوْمَئِذٍ لَخَبِيرٌ﴾</span>، لَعالِمٌ، فَيُجازِيهِمْ عَلى أعْمالِهِمْ، مِنَ الخَيْرِ، والشَرِّ، وخُصَّ "يَوْمَئِذٍ"، بِالذِكْرِ، وهو عالِمٌ بِهِمْ في جَمِيعِ الأزْمانِ، لِأنَّ الجَزاءَ يَقَعُ يَوْمَئِذٍ.</p></div>"
  101,1,"<div class=ar lang=ar><p>(p-٦٧٣)سُورَةُ "اَلْقارِعَةِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿القارِعَةُ﴾</span>، مُبْتَدَأٌ.</p></div>"
  101,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ما﴾</span>، مُبْتَدَأٌ ثانٍ،</p><p><span class="qpc-hafs">﴿القارِعَةُ﴾</span>، خَبَرُهُ، والجُمْلَةُ خَبَرُ المُبْتَدَإ الأوَّلِ، وكانَ حَقُّهُ: "ما هِيَ"، وإنَّما كَرَّرَ تَفْخِيمًا لِشَأْنِها.</p></div>"
  101,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما أدْراكَ ما القارِعَةُ﴾</span> أيْ: أيّ شَيْءٍ أعْلَمَكَ ما هِيَ؟! ومِن أيْنَ عَلِمْتَ ذَلِكَ؟!</p></div>"
  101,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ﴾</span>، نُصِبَ بِمُضْمَرٍ، دَلَّتْ عَلَيْهِ "اَلْقارِعَةُ"، أوْ: تَقْرَعُ يَوْمَ <span class="qpc-hafs">﴿يَكُونُ الناسُ كالفَراشِ المَبْثُوثِ﴾</span>، شَبَّهَهم بِالفَراشِ في الكَثْرَةِ، والِانْتِشارِ، والضَعْفِ، والذِلَّةِ، والتَطايُرِ إلى الداعِي مِن كُلِّ جانِبٍ، كَما يَتَطايَرُ الفَراشُ إلى النارِ، وسُمِّيَ "فَراشًا"، لِتَفَرُّشِهِ وانْتِشارِهِ.</p></div>"
  101,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَكُونُ الجِبالُ كالعِهْنِ المَنفُوشِ﴾</span>، وشَبَّهَ الجِبالَ بِالعِهْنِ، وهو الصُوفُ المُصَبَّغُ ألْوانًا، لِأنَّها ألْوانٌ،</p><p><span class="qpc-hafs">﴿وَمِنَ الجِبالِ جُدَدٌ بِيضٌ وحُمْرٌ مُخْتَلِفٌ ألْوانُها﴾</span> [فاطر: ٢٧]، وبِالمَنفُوشِ مِنهُ، لِتَفَرُّقِ أجْزائِها.</p></div>"
  101,6,"<div class=ar lang=ar><p>(p-٦٧٤)<span class="qpc-hafs">﴿فَأمّا مَن ثَقُلَتْ مَوازِينُهُ﴾</span>، بِاتِّباعِهِمُ الحَقَّ، وهي جَمْعُ "مَوْزُونٌ"، وهو العَمَلُ الَّذِي لَهُ وزْنٌ وخَطَرٌ عِنْدَ اللهِ، أوْ جَمْعُ "مِيزانٌ"، وثِقْلُها: رُجْحانُها.</p></div>"
  101,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَهُوَ في عِيشَةٍ راضِيَةٍ﴾</span>، ذاتِ رِضًا، أوْ: مَرْضِيَّةٍ.</p></div>"
  101,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأمّا مَن خَفَّتْ مَوازِينُهُ﴾</span>، بِاتِّباعِهِمُ الباطِلَ.</p></div>"
  101,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأُمُّهُ هاوِيَةٌ﴾</span>، فَمَسْكَنُهُ ومَأْواهُ النارُ، وقِيلَ لِلْمَأْوى: "أُمٌّ"، عَلى التَشْبِيهِ، لِأنَّ الأُمَّ مَأْوى الوَلَدِ ومَفْزَعُهُ.</p></div>"
  101,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما أدْراكَ ما هِيَهْ﴾</span></p><p>١٠. - <span class="qpc-hafs">﴿وَما أدْراكَ ما هِيَهْ﴾</span>، اَلضَّمِيرُ يَعُودُ إلى "هاوِيَةٌ"، والهاءُ لِلسَّكْتِ، ثُمَّ فَسَّرَها، فَقالَ:</p></div>"
  101,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نارٌ حامِيَةٌ﴾</span>، بَلَغَتِ النِهايَةَ في الحَرارَةِ.</p></div>"
  102,1,"<div class=ar lang=ar><p>(p-٦٧٥)سُورَةُ "اَلتَّكاثُرِ"</p><p>بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ</p><p><span class="qpc-hafs">﴿ألْهاكُمُ التَكاثُرُ﴾</span>، شَغَلَكُمُ التَبارِي في الكَثْرَةِ، والتَناهِي بِها، في الأمْوالِ، والأوْلادِ، عَنْ طاعَةِ اللهِ.</p></div>"
  102,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حَتّى زُرْتُمُ المَقابِرَ﴾</span>، حَتّى أدْرَكَكُمُ المَوْتُ عَلى تِلْكَ الحالِ، أوْ حَتّى زُرْتُمُ المَقابِرَ وعَدَدْتُمْ مَن في المَقابِرِ مِن مَوْتاكم.</p></div>"
  102,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، رَدْعٌ وتَنْبِيهٌ عَلى أنَّهُ لا يَنْبَغِي لِلنّاظِرِ لِنَفْسِهِ أنْ تَكُونَ الدُنْيا جَمِيعَ هَمِّهِ، ولا يَهْتَمَّ بِدِينِهِ،</p><p><span class="qpc-hafs">﴿سَوْفَ تَعْلَمُونَ﴾</span>، عِنْدَ النَزْعِ، سُوءَ عاقِبَةِ ما كُنْتُمْ عَلَيْهِ.</p></div>"
  102,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ كَلا سَوْفَ تَعْلَمُونَ﴾</span>، في القُبُورِ.</p></div>"
  102,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَلا﴾</span>، تَكْرِيرُ الرَدْعِ لِلْإنْذارِ والتَخْوِيفِ،</p><p><span class="qpc-hafs">﴿لَوْ تَعْلَمُونَ﴾</span>، جَوابُ "لَوْ"، مَحْذُوفٌ، أيْ: لَوْ تَعْلَمُونَ ما بَيْنَ أيْدِيكُمْ،</p><p><span class="qpc-hafs">﴿عِلْمَ اليَقِينِ﴾</span>، عِلْمَ الأمْرِ اليَقِينِ، أيْ: كَعِلْمِكم ما تَسْتَيْقِنُونَهُ مِنَ الأُمُورِ، لَما ألْهاكُمُ التَكاثُرُ، أوْ: لَفَعَلْتُمْ ما لا يُوصَفُ، ولَكِنَّكم ضُلّالٌ جَهَلَةٌ.</p></div>"
  102,6,"<div class=ar lang=ar><p>(p-٦٧٦)<span class="qpc-hafs">﴿لَتَرَوُنَّ الجَحِيمَ﴾</span>، هو جَوابُ قَسَمٍ مَحْذُوفٍ، والقَسَمُ لِتَوْكِيدِ الوَعِيدِ، "لَتُرَوُنَّ"، بِضَمِّ التاءِ، "شامِيٌّ وعَلِيٌّ".</p></div>"
  102,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ لَتَرَوُنَّها﴾</span>، كَرَّرَهُ مَعْطُوفًا بِـ "ثُمَّ"، تَغْلِيظًا في التَهْدِيدِ، وزِيادَةً في التَهْوِيلِ، أوِ الأوَّلُ بِالقَلْبِ، والثانِي بِالعَيْنِ،</p><p><span class="qpc-hafs">﴿عَيْنَ اليَقِينِ﴾</span> أيْ: اَلرُّؤْيَةَ الَّتِي هي نَفْسُ اليَقِينِ، وخالِصَتُهُ.</p></div>"
  102,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ لَتُسْألُنَّ يَوْمَئِذٍ عَنِ النَعِيمِ﴾</span>، عَنِ الأمْنِ، والصِحَّةِ، فِيمَ أفْنَيْتُمُوهُما؟ عَنِ ابْنِ مَسْعُودٍ - رَضِيَ اللهُ عَنْهُ -، وقِيلَ: عَنِ التَنَعُّمِ الَّذِي شَغَلَكم الِالتِذاذُ بِهِ عَنِ الدِينِ، وتَكالِيفِهِ، وعَنِ الحَسَنِ: "ما سِوى كِنٍّ يُؤْوِيهِ، وثَوْبٍ يُوارِيهِ، وكِسْرَةٍ تُقَوِّيهِ"، وقَدْ رُوِيَ مَرْفُوعًا.</p></div>"