quran[25]{c,v,t}:
  37,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَقُولُ أإنَّكَ﴾</span>، بِهَمْزَتَيْنِ "شامِيٌّ وكُوفِيٌّ"،</p><p><span class="qpc-hafs">﴿لَمِنَ المُصَدِّقِينَ﴾</span>، بِيَوْمِ الدِينِ.</p></div>"
  37,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَدِينُونَ﴾</span>، لَمَجْزِيُّونَ، مِن "اَلدَّيْنُ"، وهو الجَزاءُ.</p></div>"
  37,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالَ﴾</span>، ذَلِكَ القائِلُ،</p><p><span class="qpc-hafs">﴿هَلْ أنْتُمْ مُطَّلِعُونَ﴾</span>، إلى النارِ، لِأُرِيَكم ذَلِكَ القَرِينَ، قِيلَ: إنَّ في الجَنَّةِ كُوًى يَنْظُرُ أهْلُها مِنها إلى أهْلِ النارِ، أوْ قالَ اللهُ (تَعالى) لِأهْلِ الجَنَّةِ: "هَلْ أنْتُمْ مُطَّلِعُونَ إلى النارِ فَتَعْلَمُوا أيْنَ مَنزِلَتُكم مِن مَنزِلَةِ أهْلِ النارِ؟".</p></div>"
  37,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فاطَّلَعَ﴾</span>، اَلْمُسْلِمُ،</p><p><span class="qpc-hafs">﴿فَرَآهُ﴾</span> أيْ: قَرِينَهُ،</p><p><span class="qpc-hafs">﴿فِي سَواءِ الجَحِيمِ﴾</span>، في وسَطِها.</p></div>"
  37,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالَ تاللهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span>، "إنْ"، مُخَفَّفَةٌ مِنَ الثَقِيلَةِ، وهي تَدْخُلُ عَلى "كادَ"، كَما تَدْخُلُ عَلى "كانَ"، واللامُ هي الفارِقَةُ بَيْنَها وبَيْنَ النافِيَةِ، و"اَلْإرْداءُ": اَلْإهْلاكُ، وبِالياءِ، في الحالَيْنِ، "يَعْقُوبُ".</p></div>"
  37,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوْلا نِعْمَةُ رَبِّي﴾</span>، وهي العِصْمَةُ، والتَوْفِيقُ في الِاسْتِمْساكِ بِعُرْوَةِ الإسْلامِ،</p><p><span class="qpc-hafs">﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</span>، مِنَ الَّذِينَ أُحْضِرُوا العَذابَ، كَما أُحْضِرْتَهُ أنْتَ، وأمْثالُكَ.</p></div>"
  37,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ﴾</span> <span class="qpc-hafs">﴿إلا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ﴾</span>، اَلْفاءُ لِلْعَطْفِ عَلى مَحْذُوفٍ، تَقْدِيرُهُ: "أنْحَنُ مُخَلَّدُونَ مُنَعَّمُونَ فَما نَحْنُ بِمَيِّتِينَ (p-١٢٥)وَلا مُعَذَّبِينَ؟!"، والمَعْنى أنَّ هَذِهِ حالُ المُؤْمِنِينَ، وهو ألّا يَذُوقُوا إلّا المَوْتَةَ الأُولى، بِخِلافِ الكُفّارِ، فَإنَّهم فِيما يَتَمَنَّوْنَ فِيهِ المَوْتَ كُلَّ ساعَةٍ، وقِيلَ لِحَكِيمٍ: ما شَرٌّ مِنَ المَوْتِ؟! قالَ: "اَلَّذِي يُتَمَنّى فِيهِ المَوْتُ"، وهَذا قَوْلٌ يَقُولُهُ المُؤْمِنُ، تَحَدُّثًا بِنِعْمَةِ اللهِ، بِمَسْمَعٍ مِن قَرِينِهِ، لِيَكُونَ تَوْبِيخًا لَهُ وزِيادَةَ تَعْذِيبٍ، و"مَوْتَتَنا"، نَصْبٌ عَلى المَصْدَرِ، والِاسْتِثْناءُ مُتَّصِلٌ، تَقْدِيرُهُ: "وَلا نَمُوتُ إلّا مَرَّةً"، أوْ مُنْقَطِعٌ، وتَقْدِيرُهُ: "لَكِنِ المَوْتَةَ الأُولى قَدْ كانَتْ في الدُنْيا"، ثُمَّ قالَ لِقَرِينِهِ - تَقْرِيعًا لَهُ -:</p></div>"
  37,59,"37:58"
  37,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ هَذا﴾</span> أيْ: اَلْأمْرَ الَّذِي نَحْنُ فِيهِ،</p><p><span class="qpc-hafs">﴿لَهُوَ الفَوْزُ العَظِيمُ﴾</span>، ثُمَّ قالَ اللهُ - عَزَّ وجَلَّ -:</p></div>"
  37,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</span>، وقِيلَ: هو أيْضًا مِن كَلامِهِ.</p></div>"
  37,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أذَلِكَ خَيْرٌ نُـزُلا﴾</span>، تَمْيِيزٌ،</p><p><span class="qpc-hafs">﴿أمْ شَجَرَةُ الزَقُّومِ﴾</span> أيْ: نَعِيمُ الجَنَّةِ، وما فِيها مِنَ اللَذّاتِ، والطَعامِ، والشَرابِ، خَيْرٌ نُزُلًا، أمْ شَجَرَةُ الزَقُّومِ خَيْرٌ نُزُلًا؟! و"اَلنُّزُلُ": ما يُقامُ لِلنّازِلِ بِالمَكانِ مِنَ الرِزْقِ، و"اَلزَّقُّومُ": شَجَرٌ مُرٌّ يَكُونُ بِتِهامَةَ.</p></div>"
  37,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</span>، مِحْنَةً، وعَذابًا لَهم في الآخِرَةِ، أوِ ابْتِلاءً لَهم في الدُنْيا، وذَلِكَ أنَّهم قالُوا: كَيْفَ يَكُونُ في النارِ شَجَرَةٌ، والنارُ تَحْرِقُ الشَجَرَ؟! فَكُذِّبُوا.</p></div>"
  37,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ في أصْلِ الجَحِيمِ﴾</span>، قِيلَ: مَنبَتُها في قَعْرِ جَهَنَّمَ، وأغْصانُها تَرْتَفِعُ إلى دَرَكاتِها.</p></div>"
  37,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَلْعُها كَأنَّهُ رُءُوسُ الشَياطِينِ﴾</span>، "اَلطَّلْعُ"، لِلنَّخْلَةِ، فاسْتُعِيرَ لِما طَلَعَ مِن شَجَرَةِ الزَقُّومِ، مِن حَمْلِها، وشُبِّهَ بِرءوس الشَياطِينِ لِلدَّلالَةِ عَلى تَناهِيهِ في الكَراهَةِ وقُبْحِ المَنظَرِ، لِأنَّ الشَيْطانَ مَكْرُوهٌ، مُسْتَقْبَحٌ في طِباعِ الناسِ، لِاعْتِقادِهِمْ أنَّهُ شَرٌّ مَحْضٌ، وقِيلَ: "اَلشَّيْطانُ": حَبَّةٌ عَرْفاءُ، قَبِيحَةُ المَنظَرِ، هائِلَةٌ جِدًّا.</p></div>"
  37,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَإنَّهم لآكِلُونَ مِنها﴾</span>، مِنَ الشَجَرَةِ، أيْ: مِن طَلْعِها،</p><p><span class="qpc-hafs">﴿فَمالِئُونَ مِنها البُطُونَ﴾</span>، (p-١٢٦)فَمالِئُو بُطُونِهُمْ، لِما يَغْلِبُهم مِنَ الجُوعِ الشَدِيدِ.</p></div>"
  37,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ إنَّ لَهم عَلَيْها﴾</span>، عَلى أكْلِهِمْ،</p><p><span class="qpc-hafs">﴿لَشَوْبًا﴾</span>، لَخَلْطًا ولَمِزاجًا،</p><p><span class="qpc-hafs">﴿مِن حَمِيمٍ﴾</span>، ماءٍ حارٍّ، يَشْوِي وُجُوهَهُمْ، ويُقَطِّعُ أمْعاءَهُمْ، كَما قالَ - في صِفَةِ شَرابِ أهْلِ الجَنَّةِ -: <span class="qpc-hafs">﴿وَمِزاجُهُ مِن تَسْنِيمٍ﴾</span> [المطففين: ٢٧]، والمَعْنى: ثُمَّ إنَّهم يَمْلَؤُونَ البُطُونَ مِن شَجَرَةِ الزَقُّومِ، وهو حارٌّ، يَحْرِقُ بُطُونَهُمْ، ويُعَطِّشُهُمْ، فَلا يُسْقَوْنَ إلّا بَعْدَ مَلِيٍّ، تَعْذِيبًا لَهم بِذَلِكَ العَطَشِ، ثُمَّ يُسْقَوْنَ ما هو أحَرُّ، وهو الشَرابُ المَشُوبُ بِالحَمِيمِ.</p></div>"
  37,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهم لإلى الجَحِيمِ﴾</span> أيْ: إنَّهم يَذْهَبُ بِهِمْ عَنْ مَقارِّهِمْ ومَنازِلِهِمْ في الجَحِيمِ، وهي الدَرَكاتُ الَّتِي أُسْكِنُوها، إلى شَجَرَةِ الزَقُّومِ، فَيَأْكُلُونَ، إلى أنْ يَمْتَلِئُوا، ويُسْقَوْنَ بَعْدَ ذَلِكَ، ثُمَّ يُرْجَعُونَ إلى دَرَكاتِهِمْ، ومَعْنى التَراخِي في ذَلِكَ ظاهِرٌ.</p></div>"
  37,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّهم ألْفَوْا آباءَهم ضالِّينَ﴾</span> <span class="qpc-hafs">﴿فَهم عَلى آثارِهِمْ يُهْرَعُونَ﴾</span>، عَلَّلَ اسْتِحْقاقَهم لِلْوُقُوعِ في تِلْكَ الشَدائِدِ بِتَقْلِيدِ الآباءِ في الدِينِ، واتِّباعِهِمْ إيّاهم في الضَلالِ، وتَرْكِ اتِّباعِ الدَلِيلِ، و"اَلْإهْراعُ": اَلْإسْراعُ الشَدِيدُ، كَأنَّهم يُحَثُّونَ حَثًّا.</p></div>"
  37,70,"37:69"
  37,71,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ ضَلَّ قَبْلَهُمْ﴾</span>، قَبْلَ قَوْمِكَ قُرَيْشٍ،</p><p><span class="qpc-hafs">﴿أكْثَرُ الأوَّلِينَ﴾</span>، يَعْنِي الأُمَمَ الخالِيَةَ، بِالتَقْلِيدِ، وتَرْكِ النَظَرِ والتَأمُّلِ.</p></div>"
  37,72,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ أرْسَلْنا فِيهِمْ مُنْذِرِينَ﴾</span>، أنْبِياءَ، حَذَّرُوهُمُ العَواقِبَ.</p></div>"
  37,73,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</span> أيْ: اَلَّذِينَ أُنْذِرُوا، وحُذِّرُوا أيْ: أُهْلِكُوا جَمِيعًا.</p></div>"
  37,74,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إلا عِبادَ اللهِ المُخْلَصِينَ﴾</span> أيْ: إلّا الَّذِينَ آمَنُوا مِنهُمْ، وأخْلَصُوا لِلَّهِ دِينَهُمْ، أوْ أخْلَصَهُمُ اللهُ لِدِينِهِ، عَلى القِراءَتَيْنِ.</p></div>"
  37,75,"<div class=ar lang=ar><p>وَلَمّا ذَكَرَ إرْسالَ المُنْذِرِينَ في الأُمَمِ الخالِيَةِ، وسُوءَ عاقِبَةِ المُنْذَرِينَ، أتْبَعَ (p-١٢٧)ذَلِكَ ذِكْرَ نُوحٍ، ودُعاءَهُ إيّاهُ، حِينَ أيِسَ مِن قَوْمِهِ، بِقَوْلِهِ: <span class="qpc-hafs">﴿وَلَقَدْ نادانا نُوحٌ﴾</span>، دَعانا لِنُنْجِيَهُ مِنَ الغَرَقِ، وقِيلَ: أُرِيدُ بِهِ قَوْلُهُ: <span class="qpc-hafs">﴿أنِّي مَغْلُوبٌ فانْتَصِرْ﴾</span> [القمر: ١٠] <span class="qpc-hafs">﴿فَلَنِعْمَ المُجِيبُونَ﴾</span>، اَللّامُ الداخِلَةُ عَلى "نِعْمَ"، جَوابُ قَسَمٍ مَحْذُوفٍ، والمَخْصُوصُ بِالمَدْحِ مَحْذُوفٌ، وتَقْدِيرُهُ: "وَلَقَدْ نادانا نُوحٌ فَواللهِ لَنِعْمَ المُجِيبُونَ نَحْنُ"، والجَمْعُ دَلِيلُ العَظَمَةِ والكِبْرِياءِ، والمَعْنى: إنّا أجَبْناهُ أحْسَنَ الإجابَةِ، ونَصَرْناهُ عَلى أعْدائِهِ، وانْتَقَمْنا مِنهُمْ، بِأبْلَغِ ما يَكُونُ.</p></div>"
  37,76,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَجَّيْناهُ وأهْلَهُ﴾</span>، ومَن آمَنَ بِهِ، وأوْلادَهُ،</p><p><span class="qpc-hafs">﴿مِنَ الكَرْبِ العَظِيمِ﴾</span>، وهو الغَرَقُ.</p></div>"