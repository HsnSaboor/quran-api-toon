quran[23]{c,v,t}:
  26,137,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنْ هَذا إلا خُلُقُ الأوَّلِينَ﴾</span> ما هَذا الَّذِي نَحْنُ عَلَيْهِ مِنَ الحَياةِ والمَوْتِ واتِّخاذِ الِابِتَناءِ إلّا عادَةُ الأوَّلِينَ أوْ ما نَحْنُ عَلَيْهِ دِينُ الأوَّلِينَ " إلّا خَلْقَ الأوَّلِينَ" مَكِّيٌّ وبَصْرِيٌّ ويَزِيدُ وعَلِيٌّ، أيْ: ما جِئْتَ بِهِ اخْتِلاقُ الأوَّلِينَ وكَذِبُ المُتَنَبِّئِينَ قَبْلَكَ، كَقَوْلِهِمْ <span class="qpc-hafs">﴿أساطِيرُ الأوَّلِينَ﴾</span> [الأنفال: ٣١] أوْ خَلْقُنا كَخَلْقِ الأوَّلِينَ نَمُوتُ ونَحْيا كَما حَيُوا.</p></div>"
  26,138,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَما نَحْنُ بِمُعَذَّبِينَ﴾</span> في الدُنْيا ولا بَعْثَ ولا حِسابَ.</p></div>"
  26,139,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَكَذَّبُوهُ﴾</span> أيْ: هُودًا <span class="qpc-hafs">﴿فَأهْلَكْناهُمْ﴾</span> بِرِيحٍ صَرْصَرٍ عاتِيَةٍ <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآيَةً وما كانَ أكْثَرُهم مُؤْمِنِينَ﴾</span></p></div>"
  26,140,"<div class=ar lang=ar></div>"
  26,141,"26:140"
  26,142,"26:140"
  26,143,"26:140"
  26,144,"26:140"
  26,145,"26:140"
  26,146,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أتُتْرَكُونَ﴾</span> إنْكارٌ لِأنْ يُتْرَكُوا خالِدِينَ في نَعِيمِهِمْ لا يُزالُونَ عَنْهُ <span class="qpc-hafs">﴿فِي ما ها هُنا﴾</span> في الَّذِي اسْتَقَرَّ في هَذا المَكانِ مِنَ النَعِيمِ <span class="qpc-hafs">﴿آمِنِينَ﴾</span> مِنَ العَذابِ والزَوالِ والمَوْتِ ثُمَّ فَسَّرَهُ بِقَوْلِهِ (p-٥٧٦)</p></div>"
  26,147,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي جَنّاتٍ وعُيُونٍ﴾</span> وهَذا أيْضًا إجْمالٌ ثُمَّ تَفْصِيلٌ.</p></div>"
  26,148,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَزُرُوعٍ ونَخْلٍ﴾</span> وعُطِفَ نَخْلٌ عَلى جَنّاتٍ مَعَ أنَّ الجَنَّةَ تَتَناوَلُ النَخْلَ أوَّلَ شَيْءٍ تَفْضِيلًا لِلنَّخْلِ عَلى سائِرِ الشَجَرِ <span class="qpc-hafs">﴿طَلْعُها﴾</span> هو ما يَخْرُجُ مِنَ النَخْلِ كَنَصْلِ السَيْفِ <span class="qpc-hafs">﴿هَضِيمٌ﴾</span> لَيِّنٌ نَضِيجٌ كَأنَّهُ قالَ ونَخْلٌ قَدْ أُرْطِبَ ثَمَرُهُ.</p></div>"
  26,149,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَتَنْحِتُونَ﴾</span> تُنَقِّبُونَ <span class="qpc-hafs">﴿مِنَ الجِبالِ بُيُوتًا فارِهِينَ﴾</span> شامِيٌّ وكُوفِيٌّ، حاذِقِينَ: حالٌ، وغَيْرُهم "فَرِهِينَ" أشِرِينَ والفَراهَةُ الكَيْسُ والنَشاطُ.</p></div>"
  26,150,"<div class=ar lang=ar></div>"
  26,151,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا تُطِيعُوا أمْرَ المُسْرِفِينَ﴾</span> الكافِرِينَ أوِ التِسْعَةِ الَّذِينَ عَقَرُوا الناقَةَ جَعَلَ الأمْرَ مُطاعًا عَلى المَجازِ الحُكْمِيِّ والمُرادُ الآمْرُ، وهو كُلُّ جُمْلَةٍ أخْرَجْتَ الحُكْمَ المُفادَ بِها عَنْ مَوْضُوعِهِ في العَقْلِ لِضَرْبٍ مِنَ التَأوُّلِ كَقَوْلِهِمْ أنْبَتَ الرَبِيعُ البَقْلَ.</p></div>"
  26,152,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الَّذِينَ يُفْسِدُونَ في الأرْضِ﴾</span> بِالظُلْمِ والكُفْرِ <span class="qpc-hafs">﴿وَلا يُصْلِحُونَ﴾</span> بِالإيمانِ والعَدْلِ والمَعْنى: أنَّ فَسادَهم مُصْمَتٌ لَيْسَ مَعَهُ شَيْءٌ مِنَ الصَلاحِ كَما تَكُونُ حالُ بَعْضِ المُفْسِدِينَ مَخْلُوطَةً بِبَعْضِ الصَلاحِ.</p></div>"
  26,153,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالُوا إنَّما أنْتَ مِنَ المُسَحَّرِينَ﴾</span> المُسَحَّرُ الَّذِي سُحِرَ كَثِيرًا حَتّى غُلِبَ عَلى عَقْلِهِ وقِيلَ هو مِنَ السَحْرِ: الرِئَةِ، وأنَّهُ بَشَرٌ.</p></div>"
  26,154,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ما أنْتَ إلا بَشَرٌ مِثْلُنا فَأْتِ بِآيَةٍ إنْ كُنْتَ مِنَ الصادِقِينَ﴾</span> في دَعْوى الرِسالَةِ.</p></div>"
  26,155,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالَ هَذِهِ ناقَةٌ لَها شِرْبٌ﴾</span> نَصِيبٌ مِنَ الماءِ فَلا تُزاحِمُوها فِيهِ <span class="qpc-hafs">﴿وَلَكم شِرْبُ يَوْمٍ مَعْلُومٍ﴾</span> لا تُزاحِمُكم هي فِيهِ رُوِيَ: أنَّهم قالُوا نُرِيدُ ناقَةً عُشَراءَ تَخْرُجُ (p-٥٧٧)مِن هَذِهِ الصَخْرَةِ فَتَلِدُ سَقْبًا فَجَعَلَ صالِحٌ يَتَفَكَّرُ فَقالَ لَهُ جِبْرِيلُ صَلِّ رَكْعَتَيْنِ واسْألْ رَبَّكَ الناقَةَ فَفَعَلَ فَخَرَجَتِ الناقَةُ ونَتَجَتْ سَقْبًا مِثْلَها في العِظَمِ وصَدْرُها سِتُّونَ ذِراعًا وإذا كانَ يَوْمُ شِرْبِها شَرِبَتْ ماءَهم كُلَّهُ وإذا كانَ يَوْمُ شِرْبِهِمْ لا تَشْرَبُ فِيهِ الماءَ وهَذا دَلِيلٌ عَلى جَوازِ المُهايَأةِ، لِأنَّ قَوْلَهُ <span class="qpc-hafs">﴿لَها شِرْبٌ ولَكم شِرْبُ يَوْمٍ مَعْلُومٍ﴾</span> مِنَ المُهايَآتِ.</p></div>"
  26,156,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلا تَمَسُّوها بِسُوءٍ﴾</span> بِضَرْبٍ أوْ عَقْرٍ أوْ غَيْرِ ذَلِكَ <span class="qpc-hafs">﴿فَيَأْخُذَكم عَذابُ يَوْمٍ عَظِيمٍ﴾</span> عَظَّمَ اليَوْمَ لِحُلُولِ العَذابِ فِيهِ ووَصْفُ اليَوْمِ بِهِ أبْلَغُ مِن وصْفِ العَذابِ، لِأنَّ الوَقْتَ إذا عُظِّمَ بِسَبَبِهِ كانَ مَوْقِعُهُ مِنَ العِظَمِ أشَدَّ.</p></div>"
  26,157,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَعَقَرُوها﴾</span> عَقَرَها قُدارٌ ولَكِنَّهم راضُونَ بِهِ فَأُضِيفَ إلَيْهِمْ رُوِيَ: أنْ عاقِرَها قالَ لا أعْقِرُها حَتّى تَرْضَوْا أجْمَعِينَ فَكانُوا يَدْخُلُونَ عَلى المَرْأةِ في خِدْرِها فَيَقُولُونَ أتَرْضَيْنَ فَتَقُولُ نَعَمْ وكَذَلِكَ صِبْيانُهم <span class="qpc-hafs">﴿فَأصْبَحُوا نادِمِينَ﴾</span> عَلى عَقْرِها خَوْفًا مِن نُزُولِ العَذابِ بِهِمْ نَدَمَ تَوْبَةٍ أوْ نَدِمُوا حِينَ لا يَنْفَعُ النَدَمُ وذَلِكَ عِنْدَ مُعايَنَةِ العَذابِ أوْ عَلى تَرْكِ الوَلَدِ.</p></div>"
  26,158,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَأخَذَهُمُ العَذابُ﴾</span> المُقَدَّمُ ذِكْرُهُ <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآيَةً وما كانَ أكْثَرُهم مُؤْمِنِينَ﴾</span></p></div>"
  26,159,"<div class=ar lang=ar></div>"