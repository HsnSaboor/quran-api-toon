quran[28]{c,v,t}:
74,48," <q>﴿فَما تَنْفَعُهم شَفاعَةُ الشافِعِينَ﴾</q>، مِنَ المَلائِكَةِ والنَبِيِّينَ والصالِحِينَ، لِأنَّها لِلْمُؤْمِنِينَ دُونَ الكافِرِينَ، وفِيهِ دَلِيلُ ثُبُوتِ الشَفاعَةِ لِلْمُؤْمِنِينَ، في الحَدِيثِ: « "إنَّ مِن أُمَّتِي مَن يَدْخُلُ الجَنَّةَ بِشَفاعَتِهِ أكْثَرُ مِن رَبِيعَةَ ومُضَرَ ». "
74,49," <q>﴿فَما لَهم عَنِ التَذْكِرَةِ﴾</q>، عَنِ التَذْكِيرِ، وهو العِظَةُ، أيْ: اَلْقُرْآنِ، <q>﴿مُعْرِضِينَ﴾</q>، مُوَلِّينَ، حالٌ مِنَ الضَمِيرِ، نَحْوَ: "ما لَكَ قائِمًا". "
74,50," <q>﴿كَأنَّهم حُمُرٌ﴾</q> أيْ: حُمُرُ الوَحْشِ، حالٌ مِنَ الضَمِيرِ في "مُعْرِضِينَ"، <q>﴿مُسْتَنْفِرَةٌ﴾</q>، شَدِيدَةُ النِفارِ، كَأنَّها تَطْلُبُ النِفارَ مِن نُفُوسِها، وبِفَتْحِ (p-٥٦٩)الفاءِ "مَدَنِيٌّ وشامِيٌّ"، أيْ: اِسْتَنْفَرَها غَيْرُها. "
74,51," <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، حالٌ، و"قَدْ"، مَعَها مُقَدَّرَةٌ، و"اَلْقَسْوَرَةُ": اَلرُّماةُ، أوِ الأسَدُ، "فَعْلَةٌ"، مِن "اَلْقَسْرُ"، وهو القَهْرُ والغَلَبَةُ، شُبِّهُوا في إعْراضِهِمْ عَنِ القُرْآنِ، واسْتِماعِ الذِكْرِ بِحُمُرٍ جَدَّتْ في نِفارِها. "
74,52," <q>﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهم أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</q>، قَراطِيسَ تُنْشَرُ، وتُقْرَأُ، وذَلِكَ أنَّهم قالُوا لِرَسُولِ اللهِ ﷺ: لَنْ نَتَّبِعَكَ حَتّى تَأْتِيَ كُلَّ واحِدٍ مِنّا بِكُتُبٍ مِنَ السَماءِ، عُنْوانُها: مِن رَبِّ العالَمِينَ إلى فُلانِ بْنِ فُلانٍ، نُؤْمَرُ فِيها بِاتِّباعِكَ، ونَحْوُهُ قَوْلُهُ: <q>﴿وَلَنْ نُؤْمِنَ لِرُقِيِّكَ حَتّى تُنَـزِّلَ عَلَيْنا كِتابًا نَقْرَؤُهُ﴾</q> [الإسراء: ٩٣]، وقِيلَ: قالُوا: إنْ كانَ مُحَمَّدٌ صادِقًا فَلْيُصْبِحْ عِنْدَ رَأْسِ كُلِّ رَجُلٍ مِنّا صَحِيفَةٌ فِيها بَراءَتُهُ وأمْنُهُ مِنَ النارِ. "
74,53," <q>﴿كَلا﴾</q>، رَدْعٌ لَهم عَنْ تِلْكَ الإرادَةِ، وزَجْرٌ عَنِ اقْتِراحِ الآياتِ، ثُمَّ قالَ: <q>﴿بَلْ لا يَخافُونَ الآخِرَةَ﴾</q>، فَلِذَلِكَ أعْرَضُوا عَنِ التَذْكِرَةِ، لا لِامْتِناعِ إيتاءِ الصُحُفِ. "
74,54," <q>﴿كَلا إنَّهُ تَذْكِرَةٌ﴾</q>، رَدَعَهم عَنْ إعْراضِهِمْ عَنِ التَذْكِرَةِ، وقالَ: إنَّ القُرْآنَ تَذْكِرَةٌ بَلِيغَةٌ كافِيَةٌ. "
74,55," <q>﴿فَمَن شاءَ ذَكَرَهُ﴾</q> أيْ: فَمَن شاءَ أنْ يَذْكُرَهُ، ولا يَنْساهُ، فَعَلَ، فَإنَّ نَفْعَ ذَلِكَ عائِدٌ إلَيْهِ. "
74,56," <q>﴿وَما يَذْكُرُونَ﴾</q>، وبِالتاءِ " نافِعٌ ويَعْقُوبُ "، <q>﴿إلا أنْ يَشاءَ اللهُ﴾</q>، إلّا وقْتَ مَشِيئَةِ اللهِ، أوْ إلّا بِمَشِيئَةِ اللهِ، <q>﴿هُوَ أهْلُ التَقْوى وأهْلُ المَغْفِرَةِ﴾</q>، في الحَدِيثِ: "هُوَ أهْلٌ أنْ يُتَّقى، وأهْلٌ أنْ يَغْفِرَ لِمَنِ اتَّقاهُ". "
75,1," (p-٥٧٠)سُورَةُ "اَلْقِيامَةِ" بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q> أيْ: أُقْسِمُ، عَنِ ابْنِ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما -: و"لا"، صِلَةٌ، كَقَوْلِهِ: <q>﴿لِئَلا يَعْلَمَ﴾</q> [الحديد: ٢٩]، وقَوْلِهِ: فِي بِئْرِ لاحُورٍ سَرى وما شَعَرْ وَكَقَوْلِهِ: ؎ تَذَكَّرْتُ لَيْلى فاعْتَرَتْنِي صَبابَةٌ... وكادَ ضَمِيرُ القَلْبِ لا يَتَقَطَّعُ وَعَلَيْهِ الجُمْهُورُ، وعَنِ الفَرّاءِ: "لا"، رَدٌّ لِإنْكارِ المُشْرِكِينَ البَعْثَ، كَأنَّهُ قِيلَ: لَيْسَ الأمْرُ كَما تَزْعُمُونَ، ثُمَّ قِيلَ: "أُقْسِمُ بِيَوْمِ القِيامَةِ"، وقِيلَ: أصْلُهُ: "لَأُقْسِمُ"، كَقِراءَةِ ابْنِ كَثِيرٍ، عَلى أنَّ اللامَ لِلِابْتِداءِ، و"أُقْسِمُ"، خَبَرُ مُبْتَدَإٍ مَحْذُوفٍ، أيْ: "لَأنا أُقْسِمُ"، ويُقَوِّيهِ أنَّهُ في الإمامِ بِغَيْرِ الألِفِ، ثُمَّ أُشْبِعَ، فَظَهَرَ مِنَ الإشْباعِ ألِفٌ، وهَذا اللامُ يَصْحَبُهُ نُونُ التَأْكِيدِ في الأغْلَبِ، وقَدْ يُفارِقُهُ. "
75,2," <q>﴿وَلا أُقْسِمُ بِالنَفْسِ اللَوّامَةِ﴾</q>، اَلْجُمْهُورُ عَلى أنَّهُ قَسَمٌ أخَرُ، عَنِ الحَسَنِ: "أقْسَمَ بِيَوْمِ القِيامَةِ، ولَمْ يُقْسِمْ بِالنَفْسِ اللَوّامَةِ، فَهي صِفَةُ ذَمٍّ"، وعَلى القَسَمِ صِفَةُ (p-٥٧١)مَدْحٍ، أيْ: اَلنَّفْسِ المُتَّقِيَةِ، الَّتِي تَلُومُ عَلى التَقْصِيرِ في التَقْوى، وقِيلَ: هي نَفْسُ آدَمَ، لَمْ تَزَلْ تَلُومُ عَلى فِعْلِها الَّتِي خَرَجَتْ بِهِ مِنَ الجَنَّةِ، وجَوابُ القَسَمِ مَحْذُوفٌ، أيْ: لَتُبْعَثُنَّ، دَلِيلُهُ: "
75,3," <q>﴿أيَحْسَبُ الإنْسانُ﴾</q> أيْ: اَلْكافِرُ المُنْكِرُ لِلْبَعْثِ، <q>﴿ألَّنْ نَجْمَعَ عِظامَهُ﴾</q>، بَعْدَ تَفَرُّقِها، ورُجُوعِها رُفاتًا مُخْتَلِطًا بِالتُرابِ. "
75,4," <q>﴿بَلى﴾</q>، أوْجَبَتْ ما بَعْدَ النَفْيِ، أيْ: بَلى نَجْمَعُها، <q>﴿قادِرِينَ﴾</q>، حالٌ مِنَ الضَمِيرِ في "نَجْمَعَ"، أيْ: نَجْمَعُها قادِرِينَ عَلى جَمْعِها، وإعادَتِها كَما كانَتْ، <q>﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، أصابِعَهُ، كَما كانَتْ في الدُنْيا، بِلا نُقْصانٍ وتَفاوُتٍ، مَعَ صِغَرِها، فَكَيْفَ بِكِبارِ العِظامِ؟! "
75,5," <q>﴿بَلْ يُرِيدُ الإنْسانُ﴾</q>، عَطْفٌ عَلى "أيَحْسَبُ"، فَيَجُوزُ أنْ يَكُونَ - مِثْلَهُ - اسْتِفْهامًا، <q>﴿لِيَفْجُرَ أمامَهُ﴾</q>، لِيَدُومَ عَلى فُجُورِهِ فِيما يَسْتَقْبِلُهُ مِنَ الزَمانِ. "
75,6," <q>﴿يَسْألُ أيّانَ﴾</q>، مَتى، <q>﴿يَوْمُ القِيامَةِ﴾</q>، سُؤالَ مُتَعَنِّتٍ، مُسْتَبْعِدٍ لِقِيامِ الساعَةِ. "
75,7," <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q>، تَحَيَّرَ فَزَعًا، وبِفَتْحِ الراءِ "مَدَنِيٌّ"، شَخَصَ. "
75,8," <q>﴿وَخَسَفَ القَمَرُ﴾</q>، وذَهَبَ ضَوْؤُهُ، أوْ غابَ، مِن قَوْلِهِ: <q>﴿فَخَسَفْنا بِهِ﴾</q> [القصص: ٨١]، وقَرَأ أبُو حَيْوَةَ بِضَمِّ الخاءِ. "
75,9," <q>﴿وَجُمِعَ الشَمْسُ والقَمَرُ﴾</q> أيْ: جُمِعَ بَيْنَهُما في الطُلُوعِ مِنَ المَغْرِبِ، أوْ جُمِعا في ذَهابِ الضَوْءِ، أوْ يُجْمَعانِ فَيُقْذَفانِ في البَحْرِ، فَيَكُونُ نارَ اللهِ الكُبْرى. "
75,10," <q>﴿يَقُولُ الإنْسانُ﴾</q>، اَلْكافِرُ، <q>﴿يَوْمَئِذٍ أيْنَ المَفَرُّ﴾</q>، هو مَصْدَرٌ، أيْ: اَلْفِرارُ مِنَ النارِ، أوِ المُؤْمِنُ أيْضًا مِنَ الهَوْلِ، وقَرَأ الحَسَنُ بِكَسْرِ الفاءِ، وهو يَحْتَمِلُ المَكانَ، والمَصْدَرَ. "
75,11," <q>﴿كَلا﴾</q>، رَدْعٌ عَنْ طَلَبِ المَفَرِّ، <q>﴿لا وزَرَ﴾</q>، لا مَلْجَأ. "
75,12," <q>﴿إلى رَبِّكَ﴾</q>، خاصَّةً، <q>﴿يَوْمَئِذٍ المُسْتَقَرُّ﴾</q>، مُسْتَقَرُّ العِبادِ، أوْ مَوْضِعُ قَرارِهِمْ، مِن جَنَّةٍ، أوْ نارٍ، مُفَوَّضٌ ذَلِكَ لِمَشِيئَتِهِ، مَن شاءَ أدْخَلَهُ الجَنَّةَ، ومَن شاءَ أدْخَلَهُ النارَ. "
75,13," <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ﴾</q>، يُخْبَرُ، <q>﴿بِما قَدَّمَ﴾</q>، مِن عَمَلٍ عَمِلَهُ، <q>﴿وَأخَّرَ﴾</q>، ما لَمْ يَعْمَلْهُ. "
75,14," (p-٥٧٢)<q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q>، شاهِدٌ، والهاءُ لِلْمُبالَغَةِ، كَـ "عَلّامَةٌ"، أوْ أنَّثَهُ لِأنَّهُ أرادَ بِهِ جَوارِحَهُ، إذْ جَوارِحُهُ تَشْهَدُ عَلَيْهِ، أوْ هو حُجَّةٌ عَلى نَفْسِهِ، والبَصِيرَةُ: اَلْحُجَّةُ، قالَ اللهُ (تَعالى): <q>﴿قَدْ جاءَكم بَصائِرُ مِن رَبِّكُمْ﴾</q> [الأنعام: ١٠٤]، وتَقُولُ لِغَيْرِكَ: "أنْتَ حُجَّةٌ عَلى نَفْسِكَ"، و"بَصِيرَةٌ"، رَفْعٌ بِالِابْتِداءِ، وخَبَرُهُ: "عَلى نَفْسِهِ"، تَقَدَّمَ عَلَيْهِ، والجُمْلَةُ خَبَرُ "اَلْإنْسانُ"، كَقَوْلِكَ: "زَيْدٌ عَلى رَأْسِهِ عِمامَةٌ"، و"اَلْبَصِيرَةُ"، عَلى هَذا، يَجُوزُ أنْ يَكُونَ المَلَكَ المُوَكَّلَ عَلَيْهِ. "
75,15," <q>﴿وَلَوْ ألْقى مَعاذِيرَهُ﴾</q>، أرْخى سُتُورَهُ، و"اَلْمِعْذارُ": اَلسِّتْرُ، وقِيلَ: ولَوْ جاءَ بِكُلِّ مَعْذِرَةٍ، ما قُبِلَتْ مِنهُ، فَعَلَيْهِ مَن يُكَذِّبُ عُذْرَهُ، و"اَلْمَعاذِيرُ"، لَيْسَ بِجَمْعِ "مَعْذِرَةٌ"، لِأنَّ جَمْعَها "مَعاذِرُ"، بَلْ هي اسْمُ جَمْعٍ لَها، ونَحْوُهُ: "اَلْمَناكِيرُ"، في "اَلْمُنْكَرُ". "
75,16," <q>﴿لا تُحَرِّكْ بِهِ﴾</q>، بِالقُرْآنِ، <q>﴿لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>، بِالقُرْآنِ، وكانَ ﷺ يَأْخُذُ في القِراءَةِ قَبْلَ فَراغِ جِبْرِيلَ، كَراهَةَ أنْ يَتَفَلَّتَ مِنهُ، فَقِيلَ لَهُ: لا تُحَرِّكْ لِسانَكَ بِقِراءَةِ الوَحْيِ، ما دامَ جِبْرِيلُ يَقْرَأُ، لِتَعْجَلَ بِهِ، لِتَأْخُذَهُ عَلى عَجَلَةٍ، ولِئَلّا يَتَفَلَّتَ مِنكَ، ثُمَّ عَلَّلَ النَهْيَ عَنِ العَجَلَةِ بِقَوْلِهِ: "
75,17," <q>﴿إنَّ عَلَيْنا جَمْعَهُ﴾</q>، في صَدْرِكَ، <q>﴿وَقُرْآنَهُ﴾</q>، وإثْباتُ قِراءَتِهِ في لِسانِكَ، و"اَلْقُرْآنُ": اَلْقِراءَةُ، ونَحْوُهُ: <q>﴿وَلا تَعْجَلْ بِالقُرْآنِ مِن قَبْلِ أنْ يُقْضى إلَيْكَ وحْيُهُ﴾</q> [طه: ١١٤] "
75,18," <q>﴿فَإذا قَرَأْناهُ﴾</q> أيْ: قَرَأهُ عَلَيْكَ جِبْرِيلُ، فَجَعَلَ قِراءَةَ جِبْرِيلَ قِراءَتَهُ، <q>﴿فاتَّبِعْ قُرْآنَهُ﴾</q> أيْ: قِراءَتَهُ عَلَيْكَ. "
75,19," <q>﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</q>، إذا أشْكَلَ عَلَيْكَ شَيْءٌ مِن مَعانِيهِ. "
