tafsir[42]{c,v,t}:
80,1," (p-٦٠١)سُورَةُ "عَبَسَ" بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ <q>﴿عَبَسَ﴾</q>، كَلَحَ، أيْ: اَلنَّبِيُّ ﷺ، <q>﴿وَتَوَلّى﴾</q>، أعْرَضَ. "
80,2," <q>﴿أنْ جاءَهُ﴾</q>، "لِأنْ جاءَهُ"، ومَحَلُّهُ نَصْبٌ، لِأنَّهُ مَفْعُولٌ لَهُ، والعامِلُ فِيهِ: "عَبَسَ"، أوْ: "تَوَلّى"، عَلى اخْتِلافِ المَذْهَبَيْنِ، <q>﴿الأعْمى﴾</q>، عَبْدُ اللهِ بْنُ أُمِّ مَكْتُومٍ، و"أُمُّ مَكْتُومٍ "، أُمُّ أبِيهِ، وأبُوهُ شُرَيْحُ بْنُ مالِكٍ، «أتى النَبِيَّ ﷺ وهو يَدْعُو أشْرافَ قُرَيْشٍ إلى الإسْلامِ، فَقالَ: يا رَسُولَ اللهِ، عَلِّمْنِي مِمّا عَلَّمَكَ اللهُ، وكَرَّرَ ذَلِكَ، وهو لا يَعْلَمُ تَشاغُلَهُ بِالقَوْمِ، فَكَرِهَ رَسُولُ اللهِ ﷺ قَطْعَهُ لِكَلامِهِ، وعَبَسَ، وأعْرَضَ عَنْهُ، فَنَزَلَتْ، فَكانَ رَسُولُ اللهِ ﷺ يُكْرِمُهُ بَعْدَها، ويَقُولُ: "مَرْحَبًا بِمَن عاتَبَنِي فِيهِ رَبِّي" »، واسْتَخْلَفَهُ عَلى المَدِينَةِ مَرَّتَيْنِ. "
80,3," <q>﴿وَما يُدْرِيكَ﴾</q>، وأيُّ شَيْءٍ يَجْعَلُكَ دارِيًا بِحالِ هَذا الأعْمى؟! <q>﴿لَعَلَّهُ يَزَّكّى﴾</q>، لَعَلَّ الأعْمى يَتَطَهَّرُ بِما يَسْمَعُ مِنكَ مِن دَنَسِ الجَهْلِ، وأصْلُهُ "يَتَزَكّى"، فَأُدْغِمَتِ التاءُ في الزايِ، وكَذا: "
80,4," <q>﴿أوْ يَذَّكَّرُ﴾</q>، يَتَّعِظُ، <q>﴿فَتَنْفَعَهُ﴾</q>، نَصْبُهُ " عاصِمٌ غَيْرَ الأعْشى"، جَوابًا لِـ "لَعَلَّ"، وغَيْرُهُ رَفَعَهُ، عَطْفًا عَلى "يَذَّكَّرُ"، <q>﴿الذِكْرى﴾</q>، ذِكْراكَ، أيْ: (p-٦٠٢)مَوْعِظَتُكَ، أيْ: إنَّكَ لا تَدْرِي ما هو مُتَرَقَّبٌ مِنهُ، مِن تَزَكٍّ، أوْ تَذَكُّرٍ، ولَوْ دَرَيْتَ لَما فَرَطَ ذَلِكَ مِنكَ. "
80,5," <q>﴿أمّا مَنِ اسْتَغْنى﴾</q> أيْ: مَن كانَ غَنِيًّا بِالمالِ. "
80,6," <q>﴿فَأنْتَ لَهُ تَصَدّى﴾</q>، تَتَعَرَّضُ بِالإقْبالِ عَلَيْهِ، حِرْصًا عَلى إيمانِهِ، "تَصَّدّى"، بِإدْغامِ التاءِ في الصادِ "حِجازِيٌّ". "
80,7," <q>﴿وَما عَلَيْكَ ألا يَزَّكّى﴾</q>، ولَيْسَ عَلَيْكَ بَأْسٌ في ألّا يَتَزَكّى بِالإسْلامِ، إنْ عَلَيْكَ إلّا البَلاغُ. "
80,8," <q>﴿وَأمّا مَن جاءَكَ يَسْعى﴾</q>، يُسْرِعُ في طَلَبِ الخَيْرِ. "
80,9," <q>﴿وَهُوَ يَخْشى﴾</q>، اَللَّهَ، أوِ الكُفّارَ، أيْ: أذاهم في إتْيانِكَ، أوِ الكَبْوَةَ، كَعادَةِ العُمْيانِ. "
80,10," <q>﴿فَأنْتَ عَنْهُ تَلَهّى﴾</q>، تَتَشاغَلُ، وأصْلُهُ: "تَتَلَهّى"، ورُوِيَ أنَّهُ ما عَبَسَ بَعْدَها في وجْهِ فَقِيرٍ قَطُّ، ولا تَصَدّى لِغَنِيٍّ، ورُوِيَ أنَّ الفُقَراءَ في مَجْلِسِ الشُورى كانُوا أُمَراءَ. "
80,11," <q>﴿كَلا﴾</q>، رَدْعٌ، أيْ: لا تَعُدْ إلى مِثْلِهِ، <q>﴿إنَّها﴾</q>، إنَّ السُورَةَ، أوِ الآياتِ، <q>﴿تَذْكِرَةٌ﴾</q>، مَوْعِظَةٌ يَجِبُ الِاتِّعاظُ بِها، والعَمَلُ بِمُوجِبِها. "
80,12," <q>﴿فَمَن شاءَ ذَكَرَهُ﴾</q>، فَمَن شاءَ اللهُ أنْ يَذْكُرَهُ، أوْ ذَكَرَ الضَمِيرَ، لِأنَّ التَذْكِرَةَ في مَعْنى الذِكْرِ والوَعْظِ، والمَعْنى: فَمَن شاءَ الذِكْرَ ألْهَمَهُ اللهُ (تَعالى) إيّاهُ. "
80,13," <q>﴿فِي صُحُفٍ﴾</q>، صِفَةٌ لِـ "تَذْكِرَةٌ"، أيْ: إنَّها مُثْبَتَةٌ في صُحُفٍ مُنْتَسَخَةٌ مِنَ اللَوْحِ، أوْ خَبَرُ مُبْتَدَإٍ مَحْذُوفٍ، أيْ: "هِيَ في صُحُفٍ"، <q>﴿مُكَرَّمَةٍ﴾</q>، عِنْدَ اللهِ. "
80,14," <q>﴿مَرْفُوعَةٍ﴾</q>، في السَماءِ، أوْ مَرْفُوعَةِ القَدْرِ، والمَنزِلَةِ، <q>﴿مُطَهَّرَةٍ﴾</q>، عَنْ مَسِّ غَيْرِ المَلائِكَةِ، أوْ عَمّا لَيْسَ مِن كَلامِ اللهِ (تَعالى). "
80,15," <q>﴿بِأيْدِي سَفَرَةٍ﴾</q>، كَتَبَةٍ، جَمْعُ "سافِرٌ"، أيْ: اَلْمَلائِكَةُ يَنْتَسِخُونَ الكُتُبَ مِنَ اللَوْحِ. "
80,16," <q>﴿كِرامٍ﴾</q>، عَلى اللهِ، أوْ عَنِ المَعاصِي، <q>﴿بَرَرَةٍ﴾</q>، أتْقِياءَ، جَمْعُ "بارٌّ". "
80,17," <q>﴿قُتِلَ الإنْسانُ﴾</q>، لُعِنَ الكافِرُ، أوْ هو أُمَيَّةُ، أوْ عُتْبَةُ، <q>﴿ما أكْفَرَهُ﴾</q>، اِسْتِفْهامُ تَوْبِيخٍ، أيْ: أيُّ شَيْءٍ حَمَلَهُ عَلى الكُفْرِ؟! أوْ هو تَعَجُّبٌ، أيْ: ما أشَدَّ كُفْرَهُ! "
80,18," (p-٦٠٣)<q>﴿مِن أيِّ شَيْءٍ خَلَقَهُ﴾</q>، مِن أيِّ حَقِيرٍ خَلَقَهُ؟! وهو اسْتِفْهامٌ، ومَعْناهُ التَقْرِيرُ، ثُمَّ بَيَّنَ ذَلِكَ الشَيْءَ، فَقالَ: "
80,19," <q>﴿مِن نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾</q>، عَلى ما يَشاءُ مِن خِلْقَةٍ. "
80,20," <q>﴿ثُمَّ السَبِيلَ يَسَّرَهُ﴾</q>، نُصِبَ "اَلسَّبِيلَ"، بِإضْمارِ "يَسَّرَ"، أيْ: ثُمَّ سَهَّلَ لَهُ سَبِيلَ الخُرُوجِ مِن بَطْنِ أُمِّهِ، أوْ بَيَّنَ لَهُ سَبِيلَ الخَيْرِ والشَرِّ. "
80,21," <q>﴿ثُمَّ أماتَهُ فَأقْبَرَهُ﴾</q>، جَعَلَهُ ذا قَبْرٍ يُوارى فِيهِ، لا كالبَهائِمِ، كَرامَةً لَهُ، "قَبَرَ المَيِّتَ": دَفَنَهُ، و"أقْبَرَ المَيِّتَ"، أمَرَهُ أنْ يُقْبِرَهُ، ومَكَّنَهُ مِنهُ. "
80,22," <q>﴿ثُمَّ إذا شاءَ أنْشَرَهُ﴾</q>، أحْياهُ بَعْدَ مَوْتِهِ. "
80,23," <q>﴿كَلا﴾</q>، رَدْعٌ لِلْإنْسانِ عَنِ الكُفْرِ، <q>﴿لَمّا يَقْضِ ما أمَرَهُ﴾</q>، لَمْ يَفْعَلْ هَذا الكافِرُ ما أمَرَهُ اللهُ بِهِ مِنَ الإيمانِ، ولَمّا عَدَّدَ النِعَمَ في نَفْسِهِ، مِنَ ابْتِداءِ حُدُوثِهِ، إلى أنِ انْتَهى، أتْبَعَهُ ذِكْرَ النِعَمِ فِيما يَحْتاجُ إلَيْهِ، فَقالَ: "
80,24," <q>﴿فَلْيَنْظُرِ الإنْسانُ إلى طَعامِهِ﴾</q>، اَلَّذِي يَأْكُلُهُ، ويَحْيا بِهِ، كَيْفَ دَبَّرْنا أمْرَهُ. "
80,25," <q>﴿أنّا﴾</q>، بِالفَتْحِ "كُوفِيٌّ"، عَلى أنَّهُ بَدَلُ اشْتِمالٍ مِنَ الطَعامِ، وبِالكَسْرِ، عَلى الِاسْتِئْنافِ، غَيْرُهُمْ، <q>﴿صَبَبْنا الماءَ صَبًّا﴾</q>، يَعْنِي المَطَرَ، مِنَ السَحابِ. "
80,26," <q>﴿ثُمَّ شَقَقْنا الأرْضَ شَقًّا﴾</q>، بِالنَباتِ. "
80,27," <q>﴿فَأنْبَتْنا فِيها حَبًّا﴾</q>، كالبُرِّ، والشَعِيرِ، وغَيْرِهِما مِمّا يُتَغَذّى بِهِ. "
80,28," <q>﴿وَعِنَبًا﴾</q>، ثَمَرَةُ الكَرْمِ، أيْ: اَلطَّعامَ، والفاكِهَةَ، <q>﴿وَقَضْبًا﴾</q>، رُطَبَةٌ، سُمِّيَ بِمَصْدَرِ "قَضَبَهُ"، أيْ: قَطَعَهُ، لِأنَّهُ يُقْضَبُ مَرَّةً بَعْدَ مَرَّةٍ. "
80,29," "
80,30," <q>﴿وَحَدائِقَ﴾</q>، وبَساتِينَ، <q>﴿غُلْبًا﴾</q>، غِلاظَ الأشْجارِ، جَمْعُ "غَلْباءُ". "
80,31," <q>﴿وَفاكِهَةً﴾</q>، لَكُمْ، <q>﴿وَأبًّا﴾</q>، مَرْعًى لِدَوابِّكم. "
80,32," <q>﴿مَتاعًا﴾</q>، مَصْدَرٌ أيْ: مَنفَعَةً، <q>﴿لَكم ولأنْعامِكُمْ﴾</q> "
80,33," <q>﴿فَإذا جاءَتِ الصاخَّةُ﴾</q>، صَيْحَةُ القِيامَةِ، لِأنَّها تَصُخُّ الآذانَ، أيْ: (p-٦٠٤)تَصِمُّها، وجَوابُهُ مَحْذُوفٌ، لِظُهُورِهِ. "
80,34," <q>﴿يَوْمَ يَفِرُّ المَرْءُ مِن أخِيهِ﴾</q> <q>﴿وَأُمِّهِ وأبِيهِ﴾</q>، لِتَبِعاتٍ بَيْنَهُ وبَيْنَهُمْ، أوْ لِاشْتِغالِهِ بِنَفْسِهِ. "
  80,35,"80:34"
80,36," <q>﴿وَصاحِبَتِهِ﴾</q>، وزَوْجَتِهِ، <q>﴿وَبَنِيهِ﴾</q>، بَدَأ بِالأخِ، ثُمَّ بِالأبَوَيْنِ، لِأنَّهُما أقْرَبُ مِنهُ، ثُمَّ بِالصاحِبَةِ، والبَنِينَ، لِأنَّهم أحَبُّ، قِيلَ: أوَّلُ مَن يَفِرُّ مِن أخِيهِ: هابِيلُ، ومِن أبَوَيْهِ: إبْراهِيمُ، ومِن صاحِبَتِهِ: نُوحٌ ولُوطٌ، ومِنَ ابْنِهِ: نُوحٌ. "
80,37," <q>﴿لِكُلِّ امْرِئٍ مِنهم يَوْمَئِذٍ شَأْنٌ﴾</q>، في نَفْسِهِ، <q>﴿يُغْنِيهِ﴾</q>، يَكْفِيهِ في الِاهْتِمامِ بِهِ، ويَشْغَلُهُ عَنْ غَيْرِهِ. "
80,38," <q>﴿وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ﴾</q>، مُضِيئَةٌ، مِن قِيامِ اللَيْلِ، أوْ مِن آثارِ الوُضُوءِ. "
80,39," <q>﴿ضاحِكَةٌ مُسْتَبْشِرَةٌ﴾</q> أيْ: أصْحابُ هَذِهِ الوُجُوهِ، وهُمُ المُؤْمِنُونَ، ضاحِكُونَ، مَسْرُورُونَ. "
80,40," <q>﴿وَوُجُوهٌ يَوْمَئِذٍ عَلَيْها غَبَرَةٌ﴾</q>، غُبارٌ. "
80,41," <q>﴿تَرْهَقُها قَتَرَةٌ﴾</q>، يَعْلُو الغُبارَ سَوادٌ كالدُخانِ، ولا تَرى أوْحَشَ مِنَ اجْتِماعِ الغَبَرَةِ والسَوادِ في الوَجْهِ. "
80,42," <q>﴿أُولَئِكَ﴾</q>، أهْلُ هَذِهِ الحالَةِ، <q>﴿هُمُ الكَفَرَةُ﴾</q>، في حُقُوقِ اللهِ، <q>﴿الفَجَرَةُ﴾</q>، في حُقُوقِ العِبادِ، ولَمّا جَمَعُوا الفُجُورَ إلى الكُفْرِ، جُمِعَ إلى سَوادِ وُجُوهِهِمُ الغَبَرَةُ. "
