quran[10]{c,v,t}:
  58,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا ناجَيْتُمُ الرَسُولَ﴾</span>، إذا أرَدْتُمْ مُناجاتَهُ،</p><p><span class="qpc-hafs">﴿فَقَدِّمُوا بَيْنَ يَدَيْ نَجْواكم صَدَقَةً﴾</span> أيْ: قَبْلَ نَجْواكُمْ، هي اسْتِعارَةٌ مِمَّنْ لَهُ يَدانِ، كَقَوْلِ عُمَرَ - رَضِيَ اللهُ عَنْهُ -: "مِن أفْضَلِ ما أُوتِيَتِ العَرَبُ الشِعْرُ، يُقَدِّمُهُ الرَجُلُ أمامَ حاجَتِهِ، فَيَسْتَمْطِرُ بِهِ الكَرِيمَ، ويَسْتَنْزِلُّ بِهِ اللَئِيمَ"، يُرِيدُ: "قَبْلَ حاجَتِهِ "،</p><p><span class="qpc-hafs">﴿ذَلِكَ﴾</span>، اَلتَّقْدِيمُ،</p><p><span class="qpc-hafs">﴿خَيْرٌ لَكُمْ﴾</span>، في دِينِكُمْ،</p><p><span class="qpc-hafs">﴿وَأطْهَرُ﴾</span>، لِأنَّ الصَدَقَةَ طُهْرَةٌ،</p><p><span class="qpc-hafs">﴿وَأطْهَرُ فَإنْ لَمْ تَجِدُوا﴾</span>، ما تَتَصَدَّقُونَ بِهِ،</p><p><span class="qpc-hafs">﴿فَإنَّ اللهَ غَفُورٌ رَحِيمٌ﴾</span>، في تَرْخِيصِ المُناجاةِ مِن غَيْرِ صَدَقَةٍ، قِيلَ: كانَ ذَلِكَ عَشْرَ لَيالٍ، ثُمَّ نُسِخَ، وقِيلَ: ما كانَ إلّا ساعَةً مِن نَهارٍ، ثُمَّ نُسِخَ، «وَقالَ عَلِيٌّ - رَضِيَ اللهُ عَنْهُ -: هَذِهِ آيَةٌ مِن كِتابِ اللهِ ما عَمِلَ بِها أحَدٌ قَبْلِي، ولا يَعْمَلُ بِها أحَدٌ بَعْدِي، كانَ لِي دِينارٌ فَصَرَفْتُهُ، فَكُنْتُ إذا ناجَيْتُهُ تَصَدَّقْتُ بِدِرْهَمٍ، وسَألْتُ رَسُولَ اللهِ ﷺ عَشْرَ مَسائِلَ، فَأجابَنِي عَنْها، قُلْتُ: يا رَسُولَ اللهِ، ما الوَفاءُ؟ قالَ: "اَلتَّوْحِيدُ، وشَهادَةُ أنْ لا إلَهَ إلّا اللهُ"، قُلْتُ: وما الفَسادُ؟ قالَ: "اَلْكُفْرُ، والشِرْكُ بِاللهِ"، قُلْتُ: وما الحَقُّ؟ قالَ: "اَلْإسْلامُ، والقُرْآنُ، والوَلايَةُ إذا انْتَهَتْ إلَيْكَ"، قُلْتُ: وما الحِيلَةُ: قالَ: "تَرْكُ الحِيلَةِ"، قُلْتُ: وما عَلَيَّ؟ قالَ: "طاعَةُ اللهِ، وطاعَةُ رَسُولِهِ"، قُلْتُ: وكَيْفَ أدْعُو اللهَ (تَعالى)؟ قالَ: "بِالصِدْقِ، واليَقِينِ"، قُلْتُ: وماذا (p-٤٥١)أسْألُ اللهَ؟ قالَ: "اَلْعافِيَةَ"، قُلْتُ: وما أصْنَعُ لِنَجاةِ نَفْسِي؟ قالَ: "كُلْ حَلالًا، وقُلْ صِدْقًا"، قُلْتُ: وما السُرُورُ؟ قالَ: "اَلْجَنَّةُ"، قُلْتُ: وما الراحَةُ؟ قالَ: "لِقاءُ اللهِ"، فَلَمّا فَرَغْتُ مِنها نَزَلَ نَسْخُها ».</p></div>"
  58,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أأشْفَقْتُمْ أنْ تُقَدِّمُوا بَيْنَ يَدَيْ نَجْواكم صَدَقاتٍ﴾</span>، أخِفْتُمْ تَقْدِيمَ الصَدَقاتِ، لِما فِيهِ مِنَ الإنْفاقِ الَّذِي تَكْرَهُونَهُ؟! <span class="qpc-hafs">﴿فَإذْ لَمْ تَفْعَلُوا﴾</span>، ما أُمِرْتُمْ بِهِ، وشَقَّ عَلَيْكُمْ،</p><p><span class="qpc-hafs">﴿وَتابَ اللهُ عَلَيْكُمْ﴾</span> أيْ: خَفَّفَ عَنْكُمْ، وأزالَ عَنْكُمُ المُؤاخَذَةَ بِتَرْكِ تَقْدِيمِ الصَدَقَةِ عَلى المُناجاةِ، كَما أزالَ المُؤاخَذَةَ بِالذَنْبِ عَنِ التائِبِ عَنْهُ،</p><p><span class="qpc-hafs">﴿فَأقِيمُوا الصَلاةَ وآتُوا الزَكاةَ وأطِيعُوا اللهَ ورَسُولَهُ﴾</span> أيْ: فَلا تُفَرِّطُوا في الصَلاةِ، والزَكاةِ، وسائِرِ الطاعاتِ،</p><p><span class="qpc-hafs">﴿واللهُ خَبِيرٌ بِما تَعْمَلُونَ﴾</span>، وهَذا وعْدٌ، ووَعِيدٌ.</p></div>"
  58,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألَمْ تَرَ إلى الَّذِينَ تَوَلَّوْا قَوْمًا غَضِبَ اللهُ عَلَيْهِمْ﴾</span>، كانَ المُنافِقُونَ يَتَوَلَّوْنَ اليَهُودَ، وهُمُ الَّذِينَ غَضِبَ اللهُ عَلَيْهِمْ في قَوْلِهِ: <span class="qpc-hafs">﴿مَن لَعَنَهُ اللهُ وغَضِبَ عَلَيْهِ﴾</span> [المائدة: ٦٠]، ويَنْقُلُونَ إلَيْهِمْ أسْرارَ المُؤْمِنِينَ،</p><p><span class="qpc-hafs">﴿ما هم مِنكُمْ﴾</span>، يا مُسْلِمُونَ،</p><p><span class="qpc-hafs">﴿وَلا مِنهُمْ﴾</span>، ولا مِنَ اليَهُودِ، كَقَوْلِهِ: <span class="qpc-hafs">﴿مُذَبْذَبِينَ بَيْنَ ذَلِكَ لا إلى هَؤُلاءِ ولا إلى هَؤُلاءِ﴾</span> [النساء: ١٤٣] <span class="qpc-hafs">﴿وَيَحْلِفُونَ عَلى الكَذِبِ﴾</span> أيْ: يَقُولُونَ: واللهِ إنّا لَمُسْلِمُونَ، لا مُنافِقُونَ،</p><p><span class="qpc-hafs">﴿وَهم يَعْلَمُونَ﴾</span>، أنَّهم كاذِبُونَ، مُنافِقُونَ.</p></div>"
  58,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أعَدَّ اللهُ لَهم عَذابًا شَدِيدًا﴾</span>، نَوْعًا مِنَ العَذابِ، مُتَفاقِمًا،</p><p><span class="qpc-hafs">﴿إنَّهم ساءَ ما كانُوا يَعْمَلُونَ﴾</span>، كانُوا في الزَمانِ الماضِي مُصِرِّينَ عَلى سُوءِ العَمَلِ، وهي حِكايَةُ ما يُقالُ لَهم في الآخِرَةِ.</p></div>"
  58,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿اتَّخَذُوا أيْمانَهُمْ﴾</span>، اَلْكاذِبَةَ،</p><p><span class="qpc-hafs">﴿جُنَّةً﴾</span>، وِقايَةً دُونَ دِمائِهِمْ، وأمْوالِهِمْ، (p-٤٥٢)<span class="qpc-hafs">﴿فَصَدُّوا﴾</span>، اَلنّاسَ في خِلالِ أمْنِهِمْ، وسَلامَتِهِمْ،</p><p><span class="qpc-hafs">﴿عَنْ سَبِيلِ اللهِ﴾</span>، عَنْ طاعَتِهِ، والإيمانِ بِهِ،</p><p><span class="qpc-hafs">﴿فَلَهم عَذابٌ مُهِينٌ﴾</span>، وعَدَهُمُ العَذابَ المُخْزِيَ لِكُفْرِهِمْ، وصَدِّهِمْ، كَقَوْلِهِ: <span class="qpc-hafs">﴿الَّذِينَ كَفَرُوا وصَدُّوا عَنْ سَبِيلِ اللهِ زِدْناهم عَذابًا فَوْقَ العَذابِ﴾</span> [النحل: ٨٨]</p></div>"
  58,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لَنْ تُغْنِيَ عَنْهم أمْوالُهم ولا أوْلادُهم مِنَ اللهِ﴾</span>، مِن عَذابِ اللهِ،</p><p><span class="qpc-hafs">﴿شَيْئًا﴾</span>، قَلِيلًا، مِن "اَلْإغْناءُ"،</p><p><span class="qpc-hafs">﴿أُولَئِكَ أصْحابُ النارِ هم فِيها خالِدُونَ﴾</span></p></div>"
  58,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَوْمَ يَبْعَثُهُمُ اللهُ جَمِيعًا فَيَحْلِفُونَ لَهُ﴾</span> أيْ: لِلَّهِ، في الآخِرَةِ، أنَّهم كانُوا مُخْلِصِينَ في الدُنْيا، غَيْرَ مُنافِقِينَ،</p><p><span class="qpc-hafs">﴿كَما يَحْلِفُونَ لَكُمْ﴾</span>، في الدُنْيا عَلى ذَلِكَ،</p><p><span class="qpc-hafs">﴿وَيَحْسَبُونَ أنَّهُمْ﴾</span>، في الدُنْيا،</p><p><span class="qpc-hafs">﴿عَلى شَيْءٍ﴾</span>، مِنَ النَفْعِ، أوْ يَحْسَبُونَ أنَّهم عَلى شَيْءٍ مِنَ النَفْعِ بِأيْمانِهِمُ الكاذِبَةِ، كَما انْتَفَعُوا هَهُنا،</p><p><span class="qpc-hafs">﴿ألا إنَّهم هُمُ الكاذِبُونَ﴾</span>، حَيْثُ اسْتَوَتْ حالُهم في الدُنْيا، والآخِرَةِ.</p></div>"
  58,19,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿اسْتَحْوَذَ عَلَيْهِمُ الشَيْطانُ﴾</span>، اِسْتَوْلى عَلَيْهِمْ،</p><p><span class="qpc-hafs">﴿فَأنْساهم ذِكْرَ اللهِ﴾</span>، قالَ شاهُ الكِرْمانِيُّ: "عَلامَةُ اسْتِحْواذِ الشَيْطانِ عَلى العَبْدِ أنْ يَشْغَلَهُ بِعِمارَةٍ ظاهِرِهِ، مِنَ المَآكِلِ والمَشارِبِ، والمَلابِسِ، ويَشْغَلُ قَلْبَهُ عَنِ التَفَكُّرِ في آلاءِ اللهِ ونَعْمائِهِ، والقِيامِ بِشُكْرِها، ويَشْغَلُ لِسانَهُ عَنْ ذِكْرِ رَبِّهِ، بِالكَذِبِ، والغِيبَةِ، والبُهْتانِ، ويَشْغَلُ لُبَّهُ عَنِ التَفَكُّرِ والمُراقَبَةِ بِتَدْبِيرِ الدُنْيا وجَمْعِها"،</p><p><span class="qpc-hafs">﴿أُولَئِكَ حِزْبُ الشَيْطانِ﴾</span>، جُنْدُهُ،</p><p><span class="qpc-hafs">﴿ألا إنَّ حِزْبَ الشَيْطانِ هُمُ الخاسِرُونَ﴾</span></p></div>"
  58,20,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ الَّذِينَ يُحادُّونَ اللهَ ورَسُولَهُ أُولَئِكَ في الأذَلِّينَ﴾</span>، في جُمْلَةِ مَن هو أذَلُّ خَلْقِ اللهِ (تَعالى)، لا تَرى أحَدًا أذَلَّ مِنهم.</p></div>"
  58,21,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَتَبَ اللهُ﴾</span>، في اللَوْحِ،</p><p><span class="qpc-hafs">﴿لأغْلِبَنَّ أنا ورُسُلِي﴾</span>، بِالحُجَّةِ والسَيْفِ، أوْ بِأحَدِهِما،</p><p><span class="qpc-hafs">﴿إنَّ اللهَ قَوِيٌّ﴾</span>، لا يَمْتَنِعُ عَلَيْهِ ما يُرِيدُ،</p><p><span class="qpc-hafs">﴿عَزِيزٌ﴾</span>، غالِبٌ، غَيْرُ مَغْلُوبٍ.</p></div>"