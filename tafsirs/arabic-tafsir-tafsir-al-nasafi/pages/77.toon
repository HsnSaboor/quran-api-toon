tafsir[50]{c,v,t}:
  77,1,"(p-٥٨٤)سُورَةُ ""اَلْمُرْسَلاتِ""بِسْمِ اللهِ الرَحْمَنِ الرَحِيمِ﴿والمُرْسَلاتِ عُرْفًا﴾ ﴿فالعاصِفاتِ عَصْفًا﴾ ﴿والناشِراتِ نَشْرًا﴾ ﴿فالفارِقاتِ فَرْقًا﴾ ﴿فالمُلْقِياتِ ذِكْرًا﴾ ﴿عُذْرًا أوْ نُذْرًا﴾، أقْسَمَ - سُبْحانَهُ وتَعالى - بِطَوائِفَ مِنَ المَلائِكَةِ، أرْسَلَهُنَّ بِأوامِرِهِ، فَعَصَفْنَ في مُضِيِّهِنَّ، وبِطَوائِفَ مِنهم نَشَرْنَ أجْنِحَتَهُنَّ في الجَوِّ عِنْدَ انْحِطاطِهِنَّ بِالوَحْيِ، أوْ نَشَرْنَ الشَرائِعَ في الأرْضِ، أوْ نَشَرْنَ النُفُوسَ المَوْتى بِالكُفْرِ والجَهْلِ بِما أوْحَيْنَ فَفَرَقْنَ بَيْنَ الحَقِّ، والباطِلِ، فَألْقَيْنَ ذِكْرًا إلى الأنْبِياءِ - عَلَيْهِمُ السَلامُ -، عُذْرًا لِلْمُحِقِّينَ، أوْ نُذُرًا لِلْمُبْطِلِينَ، أوْ: أقْسَمَ بِرِياحِ عَذابٍ، أرْسَلَهُنَّ فَعَصَفْنَ، وبِرِياحِ رَحْمَةٍ نَشَرْنَ السَحابَ في الجَوِّ، فَفَرَقْنَ بَيْنَهُ، كَقَوْلِهِ: ﴿وَيَجْعَلُهُ كِسَفًا﴾ [الروم: ٤٨]، فَألْقَيْنَ ذِكْرًا، إمّا عُذْرًا لِلَّذِينِ يَعْتَذِرُونَ إلى اللهِ بِتَوْبَتِهِمْ، واسْتِغْفارِهِمْ، إذا رَأوْا نِعْمَةَ اللهِ في الغَيْثِ، ويَشْكُرُونَها، وإمّا نُذْرًا لِلَّذِينِ لا يَشْكُرُونَ، ويَنْسُبُونَ ذَلِكَ إلى الأنْواءِ، وجُعِلْنَ مُلْقِياتِ الذِكْرِ بِاعْتِبارِ السَبَبِيَّةِ، ""عُرْفًا""، حالٌ، أيْ: مُتَتابِعَةً، كَعُرْفِ الفَرَسِ، يَتْلُو بَعْضُهُ بَعْضًا، أوْ مَفْعُولٌ لَهُ، أيْ: أُرْسِلْنَ لِلْإحْسانِ، والمَعْرُوفِ، و""عَصْفًا""، و""نَشْرًا""، مَصْدَرانِ، ""أوْ نُذْرًا""، "" أبُو عَمْرٍو وكُوفِيٌّ غَيْرَ أبِي بَكْرٍ وحَمّادٌ""، و""اَلْعُذْرُ""، و""اَلنُّذْرُ""، مَصْدَرانِ مِن ""عَذَرَ""، إذا مَحا الإساءَةَ، ومِن ""أنْذَرَ""، إذا خَوَّفَ عَلى فِعْلٍ، كَـ ""اَلْكُفْرُ""، و""اَلشُّكْرُ""، (p-٥٨٥)وانْتِصابُهُما عَلى البَدَلِ مِن ""ذِكْرًا""، أوْ عَلى المَفْعُولِ لَهُ."
  77,2,"77:1"
  77,3,"77:1"
  77,4,"77:1"
  77,5,"77:1"
  77,6,"77:1"
  77,7,"﴿إنَّما تُوعَدُونَ﴾، إنَّ الَّذِي تُوعَدُونَهُ مِن مَجِيءِ يَوْمِ القِيامَةِ،﴿لَواقِعٌ﴾، لَكائِنٌ، نازِلٌ، لا رَيْبَ فِيهِ، وهو جَوابُ القَسَمِ، ولا وقْفَ إلى هُنا، لِوَصْلِ الجَوابِ بِالقَسَمِ."
  77,8,"﴿فَإذا النُجُومُ طُمِسَتْ﴾، مُحِيَتْ، أوْ ذُهِبَ بِنُورِها، وجَوابُ ""فَإذا""، مَحْذُوفٌ، والعامِلُ فِيها جَوابُها، وهو وُقُوعُ الفَصْلِ ونَحْوِهِ، و""اَلنُّجُومُ""، فاعِلُ فِعْلٍ يُفَسِّرُهُ ""طُمِسَتْ""."
  77,9,"﴿وَإذا السَماءُ فُرِجَتْ﴾، فُتِحَتْ، فَكانَتْ أبْوابًا."
  77,10,"﴿وَإذا الجِبالُ نُسِفَتْ﴾، قُلِعَتْ مِن أماكِنِها."
  77,11,"﴿وَإذا الرُسُلُ أُقِّتَتْ﴾ أيْ: وُقِّتَتْ، كَقِراءَةِ أبِي عَمْرٍو، وأُبْدِلَتِ الهَمْزَةُ مِنَ الواوِ، ومَعْنى تَوْقِيتِ الرُسُلِ: تَبْيِينُ وقْتِها الَّذِي يَحْضُرُونَ فِيهِ لِلشَّهادَةِ عَلى أُمَمِهِمْ."
  77,12,"﴿لأيِّ يَوْمٍ أُجِّلَتْ﴾، أُخِّرَتْ، وأُمْهِلَتْ، وفِيهِ تَعْظِيمٌ لِلْيَوْمِ، وتَعْجِيبُ مِن هَوْلِهِ، والتَأْجِيلُ مِن ""اَلْأجَلُ""، كَـ ""اَلتَّوْقِيتُ""، مِن ""اَلْوَقْتُ""."
  77,13,"﴿لِيَوْمِ الفَصْلِ﴾، بَيانٌ لِيَوْمِ التَأْجِيلِ، وهو اليَوْمُ الَّذِي يُفْصَلُ فِيهِ بَيْنَ الخَلائِقِ."
  77,14,"﴿وَما أدْراكَ ما يَوْمُ الفَصْلِ﴾، تَعْجِيبٌ آخَرُ وتَعْظِيمٌ لِأمْرِهِ."
  77,15,"﴿وَيْلٌ﴾ [المرسلات: ١٩]، مُبْتَدَأٌ، وإنْ كانَ نَكِرَةً، لِأنَّهُ في أصْلِهِ مَصْدَرٌ مَنصُوبٌ سادٌّ مَسَدَّ فِعْلِهِ، ولَكِنَّهُ عُدِلَ بِهِ إلى الرَفْعِ، لِلدَّلالَةِ عَلى مَعْنى ثَباتِ الهَلاكِ، ودَوامِهِ لِلْمَدْعُوِّ عَلَيْهِ، ونَحْوُهُ: ﴿سَلامٌ عَلَيْكُمْ﴾ [الرعد: ٢٤] ﴿يَوْمَئِذٍ﴾، ظَرْفُهُ،﴿لِلْمُكَذِّبِينَ﴾، بِذَلِكَ اليَوْمِ، خَبَرُهُ."
  77,16,"﴿ألَمْ نُهْلِكِ الأوَّلِينَ﴾، اَلْأُمَمَ الخالِيَةَ المُكَذِّبَةَ."
  77,17,"﴿ثُمَّ نُتْبِعُهُمُ الآخِرِينَ﴾، مُسْتَأْنَفٌ بَعْدَ وقْفٍ، وهو وعِيدٌ لِأهْلِ مَكَّةَ، أيْ: (p-٥٨٦)ثُمَّ نَفْعَلُ بِأمْثالِهِمْ مِنَ الآخِرِينَ مِثْلَما فَعَلْنا بِالأوَّلِينَ، لِأنَّهم كَذَّبُوا مِثْلَ تَكْذِيبِهِمْ."
  77,18,"﴿كَذَلِكَ﴾، مِثْلُ ذَلِكَ الفِعْلِ الشَنِيعِ،﴿نَفْعَلُ بِالمُجْرِمِينَ﴾، بِكُلِّ مَن أجْرَمَ."
  77,19,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِما أوْعَدْنا."
  77,20,"﴿ألَمْ نَخْلُقْكم مِن ماءٍ مَهِينٍ﴾، حَقِيرٍ، وهو النُطْفَةُ."
  77,21,"﴿فَجَعَلْناهُ﴾ أيْ: اَلْماءَ،﴿فِي قَرارٍ مَكِينٍ﴾، مَقَرٍّ يَتَمَكَّنُ فِيهِ، وهو الرَحِمُ، ومَحَلُّ."
  77,22,"﴿إلى قَدَرٍ مَعْلُومٍ﴾، اَلْحالُ، أيْ: مُؤَخَّرًا إلى مِقْدارٍ مِنَ الوَقْتِ مَعْلُومٍ، قَدْ عَلِمَهُ اللهُ، وحَكَمَ بِهِ، وهو تِسْعَةُ أشْهُرٍ، أوْ ما فَوْقَها، أوْ ما دُونَها."
  77,23,"﴿فَقَدَرْنا﴾، فَقَدَرْناهُ ذَلِكَ تَقْدِيرًا،﴿فَنِعْمَ القادِرُونَ﴾، فَنِعْمَ المُقَدِّرُونَ لَهُ نَحْنُ! أوْ فَقَدَرْنا عَلى ذَلِكَ، فَنِعْمَ القادِرُونَ عَلَيْهِ نَحْنُ! والأوَّلُ أحَقُّ، لِقِراءَةِ نافِعٍ وعَلِيٍّ بِالتَشْدِيدِ، ولِقَوْلِهِ: ﴿مِن نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ﴾ [عبس: ١٩]"
  77,24,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِنِعْمَةِ الفِطْرَةِ."
  77,25,"﴿ألَمْ نَجْعَلِ الأرْضَ كِفاتًا﴾، وهو مِن ""كَفَتَ الشَيْءَ""، إذا ضَمَّهُ، وجَمَعَهُ، وهو اسْمُ ما يَكْفِتُ، كَقَوْلِهِمْ: ""اَلضِّمامُ""، لِما يَضُمُّ، وبِهِ انْتَصَبَ."
  77,26,"﴿أحْياءً وأمْواتًا﴾، كَأنَّهُ قِيلَ: ""كافِتَةً أحْياءً وأمْواتًا""، أوْ بِفِعْلٍ مُضْمَرٍ، يَدُلُّ عَلَيْهِ ""كِفاتًا""، وهو ""تَكْفِتُ""، أيْ: تَكْفِتُ أحْياءً عَلى ظَهْرِها، وأمْواتًا في بَطْنِها، والتَنْكِيرُ فِيهِما لِلتَّفْخِيمِ، أيْ: ""تَكْفِتُ أحْياءً لا يُعَدُّونَ، وأمْواتًا لا يُحْصَرُونَ."
  77,27,"﴿وَجَعَلْنا فِيها رَواسِيَ﴾، جِبالًا ثَوابِتَ،﴿شامِخاتٍ﴾، عالِياتٍ،﴿وَأسْقَيْناكم ماءً فُراتًا﴾، عَذْبًا."
  77,28,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِهَذِهِ النِعْمَةِ."
  77,29,"﴿انْطَلِقُوا إلى ما كُنْتُمْ بِهِ تُكَذِّبُونَ﴾ أيْ: يُقالُ لِلْكافِرِينَ يَوْمَ القِيامَةِ: سِيرُوا إلى النارِ الَّتِي كُنْتُمْ بِها تُكَذِّبُونَ."
  77,30,"(p-٥٨٧)﴿انْطَلِقُوا﴾، تَكْرِيرٌ لِلتَّوْكِيدِ،﴿إلى ظِلٍّ﴾، دُخانِ جَهَنَّمَ،﴿ذِي ثَلاثِ شُعَبٍ﴾، يَتَشَعَّبُ لِعِظَمِهِ ثَلاثَ شُعَبٍ، وهَكَذا الدُخانُ العَظِيمُ يَتَفَرَّقُ ثَلاثَ فِرَقٍ."
  77,31,"﴿لا ظَلِيلٍ﴾، نَعْتُ ""ظَلٍّ""، أيْ: ""لا مُظِلٍّ مِن حَرِّ ذَلِكَ اليَوْمِ، وحَرِّ النارِ،﴿وَلا يُغْنِي﴾، في مَحَلِّ الجَرِّ، أيْ: وغَيْرُ مُغْنٍ عَنْهُمْ،﴿مِنَ اللهَبِ﴾، مِن حَرِّ اللهَبِ شَيْئًا."
  77,32,"﴿إنَّها﴾ أيْ: اَلنّارُ،﴿تَرْمِي بِشَرَرٍ﴾، هو ما تَطايَرَ مِنَ النارِ،﴿كالقَصْرِ﴾، في العِظَمِ، وقِيلَ: هو الغَلِيظُ مِنَ الشَجَرِ، الواحِدَةُ ""قَصْرَةٌ""."
  77,33,"﴿كَأنَّهُ جِمالَتٌ﴾، ""كُوفِيٌّ غَيْرَ أبِي بَكْرٍ ""، جَمْعُ ""جَمَلٌ""، ""جِمالاتٌ""، غَيْرُهُمْ، جَمْعُ الجَمْعِ، ""صُفْرٌ"": جَمْعُ ""أصْفَرُ""، أيْ: سُودٌ، تَضْرِبُ إلى الصُفْرَةِ، وشَبَّهَ الشَرَرَ بِالقُصُورِ، لِعِظَمِهِ، وارْتِفاعِهِ، وبِالجِمالِ، لِلْعِظَمِ والطُولِ واللَوْنِ."
  77,34,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِأنَّ هَذِهِ صِفَتُها."
  77,35,"﴿هَذا يَوْمُ لا يَنْطِقُونَ﴾، وقُرِئَ بِنَصْبِ اليَوْمِ، أيْ: هَذا الَّذِي قُصَّ عَلَيْكم واقِعٌ يَوْمَئِذٍ، وسُئِلَ ابْنُ عَبّاسٍ - رَضِيَ اللهُ عَنْهُما - عَنْ هَذِهِ الآيَةِ، وعَنْ قَوْلِهِ: ﴿ثُمَّ إنَّكم يَوْمَ القِيامَةِ عِنْدَ رَبِّكم تَخْتَصِمُونَ﴾ [الزمر: ٣١]، فَقالَ: ""فِي ذَلِكَ اليَوْمِ مَواقِفُ، في بَعْضِها يَخْتَصِمُونَ، وفي بَعْضِها لا يَنْطِقُونَ""، أوْ لا يَنْطِقُونَ بِما يَنْفَعُهُمْ، فَجُعِلَ نُطْقُهم كَـ ""لا نُطْقَ""."
  77,36,"﴿وَلا يُؤْذَنُ لَهُمْ﴾، في الِاعْتِذارِ،﴿فَيَعْتَذِرُونَ﴾، عَطْفٌ عَلى ""يُؤْذَنُ""، مُنْخَرِطٌ في سِلْكِ النَفْيِ، أيْ: لا يَكُونُ لَهم إذَنٌ واعْتِذارٌ."
  77,37,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِهَذا اليَوْمِ."
  77,38,"﴿هَذا يَوْمُ الفَصْلِ﴾، بَيْنَ المُحِقِّ، والمُبْطِلِ، والمُحْسِنِ، والمُسِيءِ، بِالجَزاءِ، (p-٥٨٨)﴿جَمَعْناكُمْ﴾، يا مُكَذِّبِي مُحَمَّدٍ،﴿والأوَّلِينَ﴾، والمُكَذِّبِينَ قَبْلَكم."
  77,39,"﴿فَإنْ كانَ لَكم كَيْدٌ﴾، حِيلَةٌ في دَفْعِ العَذابِ،﴿فَكِيدُونِ﴾، فاحْتالُوا عَلَيَّ بِتَخْلِيصِ أنْفُسِكم مِنَ العَذابِ، و""اَلْكَيْدُ""، مُتَّعَدٍ، تَقُولُ: ""كِدْتُ فُلانًا""، إذا احْتَلْتَ عَلَيْهِ."
  77,40,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِالبَعْثِ."
  77,41,"﴿إنَّ المُتَّقِينَ﴾، مِن عَذابِ اللهِ،﴿فِي ظِلالٍ﴾، جَمْعُ ""ظِلٌّ""،﴿وَعُيُونٍ﴾، جارِيَةٍ في الجَنَّةِ."
  77,42,"﴿وَفَواكِهَ مِمّا يَشْتَهُونَ﴾ أيْ: لَذِيذَةٍ مُشْتَهاةٍ."
  77,43,"﴿كُلُوا واشْرَبُوا﴾، في مَوْضِعِ الحالِ مِن ضَمِيرِ ""اَلْمُتَّقِينَ""، في الظَرْفِ الَّذِي هو ""فِي ظِلالٍ""، أيْ: هم مُسْتَقِرُّونَ في ظِلالٍ، مَقُولًا لَهم ذَلِكَ،﴿هَنِيئًا بِما كُنْتُمْ تَعْمَلُونَ﴾، في الدُنْيا."
  77,44,"﴿إنّا كَذَلِكَ نَجْزِي المُحْسِنِينَ﴾، فَأحْسِنُوا، تُجْزَوْا بِهَذا."
  77,45,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِالجَنَّةِ."
  77,46,"﴿كُلُوا وتَمَتَّعُوا﴾، كَلامٌ مُسْتَأْنَفٌ، خِطابٌ لِلْمُكَذِّبِينَ في الدُنْيا، عَلى وجْهِ التَهْدِيدِ، كَقَوْلِهِ: ﴿اعْمَلُوا ما شِئْتُمْ﴾ [فصلت: ٤٠] ﴿قَلِيلا﴾، لِأنَّ مَتاعَ الدُنْيا قَلِيلٌ،﴿إنَّكم مُجْرِمُونَ﴾، كافِرُونَ، أيْ: إنَّ كُلَّ مُجْرِمٍ يَأْكُلُ ويَتَمَتَّعُ أيّامًا قَلائِلَ، ثُمَّ يَبْقى في الهَلاكِ الدائِمِ."
  77,47,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِالنِعَمِ."
  77,48,"﴿وَإذا قِيلَ لَهُمُ ارْكَعُوا﴾، اِخْشَعُوا لِلَّهِ، وتَواضَعُوا إلَيْهِ بِقَبُولِ وحْيِهِ، واتِّباعِ دِينِهِ، ودَعُوا هَذا الِاسْتِكْبارَ،﴿لا يَرْكَعُونَ﴾، لا يَخْشَعُونَ، ولا يَقْبَلُونَ ذَلِكَ، ويُصِرُّونَ عَلى اسْتِكْبارِهِمْ، وإذا قِيلَ لَهُمْ: صَلُّوا، لا يُصَلُّونَ."
  77,49,"﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾، بِالأمْرِ، والنَهْيِ."
  77,50,"﴿فَبِأيِّ حَدِيثٍ بَعْدَهُ﴾، بَعْدَ القُرْآنِ،﴿يُؤْمِنُونَ﴾ أيْ: إنْ لَمْ يُؤْمِنُوا بِالقُرْآنِ، مَعَ أنَّهُ آيَةٌ مُبْصِرَةٌ، ومُعْجِزَةٌ باهِرَةٌ، مِن بَيْنِ الكُتُبِ السَماوِيَّةِ، فَبِأيِّ كِتابٍ بَعْدَهُ يُؤْمِنُونَ؟!"
