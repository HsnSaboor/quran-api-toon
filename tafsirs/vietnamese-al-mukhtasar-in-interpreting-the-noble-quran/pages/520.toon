tafsir[4]{c,v,t}:
  51,1,"Allah thề bởi những cơn gió thổi cát bụi bay đi."
  51,2,"Allah thề bởi những đám mây chứa nước mưa."
  51,4,"Allah thề bởi các vị Thiên Thần được giao nhiệm vụ phân phối theo mệnh lệnh của Ngài."
  51,6,"Quả thật việc phán xử các bề tôi vào Ngày Phục Sinh là điều chắc chắn xảy ra."