tafsir[13]{c,v,t}:
  103,1,"Đấng Hiển Vinh thề bởi thời gian của buổi chiều."
  103,2,"Rằng con người chắc chắn sẽ bị thất bại và hủy diệt."
  103,3,"Ngoại trừ những người có đức tin nơi Allah và Thiên Sứ của Ngài rồi làm việc thiện tốt và khuyên bảo nhau giữ gìn và duy trì Chân Lý cũng như khuyên bảo nhau kiên nhẫn trong việc tuân lệnh Ngài. Những người với các mô tả nay là những người thành công ở trần gian và Đời Sau."
  104,1,"Những kẻ vu khống và nói xấu người khác sẽ bị nguyền rủa và sẽ bị trừng phạt."
  104,2,"Kẻ chỉ biết lo toan cho việc thu nhặt tiền tài và chỉ biết đếm tiền để xem được bao nhiêu rồi."
  104,5,"Điều gì cho Ngươi biết - hỡi Thiên Sứ - sự thật về Hutamah?"
  104,6,"Đó là ngọn lửa của Allah được đốt cháy lên rất dữ dội."
  104,7,"Để thiêu đốt thân thể đến tận trái tim."
  104,8,"Lửa sẽ bao vây xung quanh chúng."
  104,9,"Và chúng sẽ bị nhốt bên trong các cột lửa không thể thoát ra được."
  105,3,"Ngài gởi đến họ từng đàn chim nối tiếp nhau."
  105,4,"Gắp những viên đá được đun nóng tiếp nối nhau thả xuống họ."
  105,5,"Allah tiêu diệt họ toàn bộ và họ nằm la liệt giống như những cọng rạ khô cho súc vật ăn và sau khi bị giẫm đạp."