quran[27]{c,v,t}:
  55,68,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمَا﴾</span></span> ضمير، غائب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَٰكِهَةٌ﴾</span></span> اسم، من مادّة <root>فكه</root>، مؤنث، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿نَخْلٌ﴾</span></span> اسم، من مادّة <root>نخل</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رُمَّانٌ﴾</span></span> اسم، من مادّة <root>رمن</root>، مذكر، نكرة، مرفوع.</p></div>"
  55,69,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَىِّ﴾</span></span> استفهامية، من مادّة <root>أيي</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَالَآءِ﴾</span></span> اسم، من مادّة <root>ألو</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمَا﴾</span></span> ضمير، مخاطب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مخاطب، مثنى، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿انِ﴾</span></span> ضمير، مخاطب، مثنى.</p></div>"
  55,70,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَيْرَٰتٌ﴾</span></span> اسم، من مادّة <root>خير</root>، مؤنث، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حِسَانٌ﴾</span></span> اسم، من مادّة <root>حسن</root>، مذكر، جمع، نكرة، مرفوع، نعت.</p></div>"
  55,71,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَىِّ﴾</span></span> استفهامية، من مادّة <root>أيي</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَالَآءِ﴾</span></span> اسم، من مادّة <root>ألو</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمَا﴾</span></span> ضمير، مخاطب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مخاطب، مثنى، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿انِ﴾</span></span> ضمير، مخاطب، مثنى.</p></div>"
  55,72,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿حُورٌ﴾</span></span> اسم، من مادّة <root>حور</root>، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّقْصُورَٰتٌ﴾</span></span> اسم، من مادّة <root>قصر</root>، مؤنث، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿خِيَامِ﴾</span></span> اسم، من مادّة <root>خيم</root>، مؤنث، جمع، مجرور.</p></div>"
  55,73,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَىِّ﴾</span></span> استفهامية، من مادّة <root>أيي</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَالَآءِ﴾</span></span> اسم، من مادّة <root>ألو</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمَا﴾</span></span> ضمير، مخاطب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مخاطب، مثنى، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿انِ﴾</span></span> ضمير، مخاطب، مثنى.</p></div>"
  55,74,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَطْمِثْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>طمث</root>، غائب، مذكر، مفرد، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنسٌ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَبْلَ﴾</span></span> ظرف زمان، من مادّة <root>قبل</root>، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَآنٌّ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>جنن</root>، مذكر، نكرة، مرفوع.</p></div>"
  55,75,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَىِّ﴾</span></span> استفهامية، من مادّة <root>أيي</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَالَآءِ﴾</span></span> اسم، من مادّة <root>ألو</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمَا﴾</span></span> ضمير، مخاطب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مخاطب، مثنى، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿انِ﴾</span></span> ضمير، مخاطب، مثنى.</p></div>"
  55,76,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مُتَّكِـِٔينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وكأ</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَفْرَفٍ﴾</span></span> اسم، من مادّة <root>رفرف</root>، مؤنث، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خُضْرٍ﴾</span></span> اسم، من مادّة <root>خضر</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عَبْقَرِىٍّ﴾</span></span> اسم، من مادّة <root>عبقر</root>، مؤنث، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حِسَانٍ﴾</span></span> اسم، من مادّة <root>حسن</root>، مذكر، جمع، نكرة، مجرور، نعت.</p></div>"
  55,77,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَىِّ﴾</span></span> استفهامية، من مادّة <root>أيي</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَالَآءِ﴾</span></span> اسم، من مادّة <root>ألو</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمَا﴾</span></span> ضمير، مخاطب، مثنى.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، مخاطب، مثنى، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿انِ﴾</span></span> ضمير، مخاطب، مثنى.</p></div>"
  55,78,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿تَبَٰرَكَ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>برك</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱسْمُ﴾</span></span> اسم، من مادّة <root>سمو</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِى﴾</span></span> اسم، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَلَٰلِ﴾</span></span> اسم، من مادّة <root>جلل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِكْرَامِ﴾</span></span> مصدر مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>كرم</root>، مذكر، مجرور.</p></div>"
  56,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَقَعَتِ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وقع</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وَاقِعَةُ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>وقع</root>، مؤنث، مرفوع.</p></div>"
  56,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَيْسَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ليس</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿وَقْعَتِ﴾</span></span> اسم، من مادّة <root>وقع</root>، مؤنث، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَاذِبَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كذب</root>، مؤنث، نكرة، مرفوع.</p></div>"
  56,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿خَافِضَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>خفض</root>، مؤنث، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّافِعَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>رفع</root>، مؤنث، نكرة، مرفوع.</p></div>"
  56,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رُجَّتِ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>رجج</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضُ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَجًّا﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>رجج</root>، مذكر، نكرة، منصوب.</p></div>"
  56,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿بُسَّتِ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>بسس</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جِبَالُ﴾</span></span> اسم، من مادّة <root>جبل</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَسًّا﴾</span></span> اسم، من مادّة <root>بسس</root>، مذكر، نكرة، منصوب.</p></div>"
  56,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿كَانَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَبَآءً﴾</span></span> اسم، من مادّة <root>هبو</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّنۢبَثًّا﴾</span></span> اسم، من مادّة <root>بثث</root>، مذكر، نكرة، منصوب، نعت.</p></div>"
  56,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَزْوَٰجًا﴾</span></span> اسم، من مادّة <root>زوج</root>، مذكر، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ثَلَٰثَةً﴾</span></span> اسم، من مادّة <root>ثلث</root>، مؤنث، نكرة، منصوب.</p></div>"
  56,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أَصْحَٰبُ﴾</span></span> اسم، من مادّة <root>صحب</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَيْمَنَةِ﴾</span></span> اسم، من مادّة <root>يمن</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَصْحَٰبُ﴾</span></span> اسم، من مادّة <root>صحب</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَيْمَنَةِ﴾</span></span> اسم، من مادّة <root>يمن</root>، مؤنث، مجرور.</p></div>"
  56,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَصْحَٰبُ﴾</span></span> اسم، من مادّة <root>صحب</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَشْـَٔمَةِ﴾</span></span> اسم، من مادّة <root>شأم</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَصْحَٰبُ﴾</span></span> اسم، من مادّة <root>صحب</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَشْـَٔمَةِ﴾</span></span> اسم، من مادّة <root>شأم</root>، مؤنث، مجرور.</p></div>"
  56,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّٰبِقُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>سبق</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّٰبِقُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>سبق</root>، مذكر، جمع، مرفوع.</p></div>"
  56,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أُو۟لَٰٓئِ﴾</span></span> اسم اشارة، جمع، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُقَرَّبُونَ﴾</span></span> اسم مفعول مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قرب</root>، مذكر، جمع، مرفوع.</p></div>"
  56,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَنَّٰتِ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّعِيمِ﴾</span></span> اسم، من مادّة <root>نعم</root>، مذكر، مجرور.</p></div>"
  56,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُلَّةٌ﴾</span></span> اسم، من مادّة <root>ثلل</root>، مؤنث، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَوَّلِينَ﴾</span></span> اسم، من مادّة <root>أول</root>، مذكر، جمع، مجرور.</p></div>"
  56,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قَلِيلٌ﴾</span></span> اسم، من مادّة <root>قلل</root>، مذكر، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ءَاخِرِينَ﴾</span></span> اسم، من مادّة <root>أخر</root>، مذكر، جمع، مجرور.</p></div>"
  56,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُرُرٍ﴾</span></span> اسم، من مادّة <root>سرر</root>، مذكر، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّوْضُونَةٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>وضن</root>، مؤنث، نكرة، مجرور، نعت.</p></div>"
  56,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّتَّكِـِٔينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وكأ</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُتَقَٰبِلِينَ﴾</span></span> اسم فاعل مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>قبل</root>، مذكر، جمع، منصوب.</p></div>"