quran[26]{c,v,t}:
  92,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَصْلَىٰ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>صلي</root>، غائب، مذكر، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هَآ﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَشْقَى﴾</span></span> اسم، من مادّة <root>شقو</root>، مذكر، مفرد، مرفوع.</p></div>"
  92,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَذَّبَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَوَلَّىٰ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ولي</root>، غائب، مذكر، مفرد.</p></div>"
  92,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿يُجَنَّبُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>جنب</root>، غائب، مذكر، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَتْقَى﴾</span></span> اسم، من مادّة <root>وقي</root>، مذكر، مفرد، مرفوع.</p></div>"
  92,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُؤْتِى﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَالَ﴾</span></span> اسم، من مادّة <root>مول</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَزَكَّىٰ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>زكو</root>، غائب، مذكر، مفرد، مرفوع.</p></div>"
  92,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَحَدٍ﴾</span></span> اسم، من مادّة <root>أحد</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نِّعْمَةٍ﴾</span></span> اسم، من مادّة <root>نعم</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُجْزَىٰٓ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>جزي</root>، غائب، مؤنث، مفرد، مرفوع.</p></div>"
  92,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة استثناء.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱبْتِغَآءَ﴾</span></span> مصدر مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>بغي</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَجْهِ﴾</span></span> اسم، من مادّة <root>وجه</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَعْلَىٰ﴾</span></span> اسم، من مادّة <root>علو</root>، مذكر، مجرور، نعت.</p></div>"
  92,21,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿سَوْفَ﴾</span></span> حرف استقبال.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَرْضَىٰ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رضو</root>، غائب، مذكر، مفرد، مرفوع.</p></div>"
  93,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ضُّحَىٰ﴾</span></span> اسم، من مادّة <root>ضحو</root>، مذكر، مجرور.</p></div>"
  93,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلَّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يْلِ﴾</span></span> اسم، من مادّة <root>ليل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَجَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>سجو</root>، غائب، مذكر، مفرد.</p></div>"
  93,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَدَّعَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>ودع</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَلَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>قلي</root>، غائب، مذكر، مفرد.</p></div>"
  93,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ءَاخِرَةُ﴾</span></span> اسم، من مادّة <root>أخر</root>، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَيْرٌ﴾</span></span> اسم، من مادّة <root>خير</root>، مذكر، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُولَىٰ﴾</span></span> اسم، من مادّة <root>أول</root>، مؤنث، مجرور.</p></div>"
  93,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿سَوْفَ﴾</span></span> حرف استقبال.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُعْطِي﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>عطو</root>، غائب، مذكر، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَرْضَىٰٓ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رضو</root>، مخاطب، مذكر، مفرد، مرفوع.</p></div>"
  93,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَجِدْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وجد</root>، غائب، مذكر، مفرد، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتِيمًا﴾</span></span> اسم، من مادّة <root>يتم</root>، مذكر، مفرد، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ـَٔاوَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أوي</root>، غائب، مذكر، مفرد.</p></div>"
  93,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وَجَدَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وجد</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ضَآلًّا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>ضلل</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿هَدَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>هدي</root>، غائب، مذكر، مفرد.</p></div>"
  93,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وَجَدَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وجد</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَآئِلًا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عيل</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَغْنَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>غني</root>، غائب، مذكر، مفرد.</p></div>"
  93,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أَمَّا﴾</span></span> حرف تفصيل.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يَتِيمَ﴾</span></span> اسم، من مادّة <root>يتم</root>، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَقْهَرْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قهر</root>، مخاطب، مذكر، مفرد، مجزوم.</p></div>"
  93,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَمَّا﴾</span></span> حرف تفصيل.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّآئِلَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>سأل</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَنْهَرْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>نهر</root>، مخاطب، مذكر، مفرد، مجزوم.</p></div>"
  93,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَمَّا﴾</span></span> حرف تفصيل.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿نِعْمَةِ﴾</span></span> اسم، من مادّة <root>نعم</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿حَدِّثْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>حدث</root>، مخاطب، مذكر، مفرد.</p></div>"
  94,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَشْرَحْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شرح</root>، متكلم، جمع، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَدْرَ﴾</span></span> اسم، من مادّة <root>صدر</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p></div>"
  94,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿وَضَعْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>وضع</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَن﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وِزْرَ﴾</span></span> اسم، من مادّة <root>وزر</root>، مؤنث، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p></div>"
  94,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِىٓ﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنقَضَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نقض</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ظَهْرَ﴾</span></span> اسم، من مادّة <root>ظهر</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p></div>"
  94,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رَفَعْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رفع</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِكْرَ﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>ذكر</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p></div>"
  94,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَعَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عُسْرِ﴾</span></span> اسم، من مادّة <root>عسر</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُسْرًا﴾</span></span> اسم، من مادّة <root>يسر</root>، مذكر، نكرة، منصوب.</p></div>"
  94,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَعَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عُسْرِ﴾</span></span> اسم، من مادّة <root>عسر</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُسْرًا﴾</span></span> اسم، من مادّة <root>يسر</root>، مذكر، نكرة، منصوب.</p></div>"
  94,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَرَغْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>فرغ</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿ٱنصَبْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>نصب</root>، مخاطب، مذكر، مفرد.</p></div>"
  94,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱرْغَب﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>رغب</root>، مخاطب، مذكر، مفرد.</p></div>"