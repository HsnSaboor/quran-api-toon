quran[14]{c,v,t}:
  106,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿إِيلَٰفِ﴾</span></span> مصدر مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>ألف</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُرَيْشٍ﴾</span></span> علم، من مادّة <root>قرش</root>، جمع.</p></div>"
  106,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِۦلَٰفِ﴾</span></span> مصدر مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>ألف</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رِحْلَةَ﴾</span></span> اسم، من مادّة <root>رحل</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿شِّتَآءِ﴾</span></span> اسم، من مادّة <root>شتو</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صَّيْفِ﴾</span></span> اسم، من مادّة <root>صيف</root>، مذكر، مجرور.</p></div>"
  106,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span> لام الامر، <span class="hlt"><span class="qpc-hafs">﴿يَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، غائب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَٰ﴾</span></span> حرف تنبيه، <span class="hlt"><span class="qpc-hafs">﴿ذَا﴾</span></span> اسم اشارة، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَيْتِ﴾</span></span> اسم، من مادّة <root>بيت</root>، مذكر، مجرور.</p></div>"
  106,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِىٓ﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَطْعَمَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>طعم</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جُوعٍ﴾</span></span> اسم، من مادّة <root>جوع</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ءَامَنَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَوْفٍۭ﴾</span></span> اسم، من مادّة <root>خوف</root>، مذكر، نكرة، مجرور.</p></div>"
  107,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿رَءَيْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رأي</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُكَذِّبُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كذب</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دِّينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مجرور.</p></div>"
  107,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَدُعُّ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>دعع</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يَتِيمَ﴾</span></span> اسم، من مادّة <root>يتم</root>، مذكر، مفرد، منصوب.</p></div>"
  107,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَحُضُّ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>حضض</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿طَعَامِ﴾</span></span> اسم، من مادّة <root>طعم</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مِسْكِينِ﴾</span></span> اسم، من مادّة <root>سكن</root>، مذكر، مفرد، مجرور.</p></div>"
  107,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿وَيْلٌ﴾</span></span> اسم، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُصَلِّينَ﴾</span></span> اسم فاعل مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>صلو</root>، مذكر، جمع، مجرور.</p></div>"
  107,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَلَاتِ﴾</span></span> اسم، من مادّة <root>صلو</root>، مؤنث، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَاهُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>سهو</root>، مذكر، جمع، مرفوع.</p></div>"
  107,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُرَآءُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فاعَلَ)، من مادّة <root>رأي</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  107,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يَمْنَعُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>منع</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَاعُونَ﴾</span></span> اسم، من مادّة <root>عون</root>، مذكر، منصوب.</p></div>"
  108,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿آ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْطَيْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>عطو</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَوْثَرَ﴾</span></span> اسم، من مادّة <root>كثر</root>، مذكر، منصوب.</p></div>"
  108,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿صَلِّ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>صلو</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱنْحَرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>نحر</root>، مخاطب، مذكر، مفرد.</p></div>"
  108,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَانِئَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>شنأ</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَبْتَرُ﴾</span></span> اسم، من مادّة <root>بتر</root>، مذكر، مرفوع.</p></div>"