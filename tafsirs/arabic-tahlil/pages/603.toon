quran[14]{c,v,t}:
  109,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قول</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَٰٓ﴾</span></span> حرف نداء، <span class="hlt"><span class="qpc-hafs">﴿أَيُّ﴾</span></span> اسم، من مادّة <root>أيي</root>، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> حرف تنبيه.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَٰفِرُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كفر</root>، مذكر، جمع، مرفوع.</p></div>"
  109,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  109,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَٰبِدُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عبد</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، مفرد، مرفوع.</p></div>"
  109,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَا۠﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَابِدٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عبد</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَبَد﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عبد</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُّمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  109,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَٰبِدُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>عبد</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، مفرد، مرفوع.</p></div>"
  109,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دِينُ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ىَ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دِينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿—﴾</span></span> ضمير، متكلم، مفرد.</p></div>"
  110,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جيأ</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَصْرُ﴾</span></span> اسم، من مادّة <root>نصر</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فَتْحُ﴾</span></span> اسم، من مادّة <root>فتح</root>، مذكر، مرفوع.</p></div>"
  110,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رَأَيْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رأي</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسَ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَدْخُلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>دخل</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دِينِ﴾</span></span> اسم، من مادّة <root>دين</root>، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَفْوَاجًا﴾</span></span> اسم، من مادّة <root>فوج</root>، جمع، نكرة، منصوب.</p></div>"
  110,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿سَبِّحْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سبح</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حَمْدِ﴾</span></span> اسم، من مادّة <root>حمد</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱسْتَغْفِرْ﴾</span></span> فعل أمر من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>غفر</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَوَّابًۢا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>توب</root>، مذكر، مفرد، نكرة، منصوب.</p></div>"
  111,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿تَبَّتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>تبب</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَدَآ﴾</span></span> اسم، من مادّة <root>يدي</root>، مؤنث، مثنى، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَبِى﴾</span></span> اسم، من مادّة <root>أبو</root>، مذكر، مفرد، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَهَبٍ﴾</span></span> اسم، من مادّة <root>لهب</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَبَّ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>تبب</root>، غائب، مذكر، مفرد.</p></div>"
  111,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَغْنَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>غني</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَالُ﴾</span></span> اسم، من مادّة <root>مول</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَسَبَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كسب</root>، غائب، مذكر، مفرد.</p></div>"
  111,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿يَصْلَىٰ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>صلي</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَارًا﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَاتَ﴾</span></span> اسم، مؤنث، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَهَبٍ﴾</span></span> اسم، من مادّة <root>لهب</root>، مذكر، نكرة، مجرور.</p></div>"
  111,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱمْرَأَتُ﴾</span></span> اسم، من مادّة <root>مرأ</root>، مؤنث، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَمَّالَةَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>حمل</root>، مؤنث، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَطَبِ﴾</span></span> اسم، من مادّة <root>حطب</root>، مذكر، مجرور.</p></div>"
  111,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جِيدِ﴾</span></span> اسم، من مادّة <root>جيد</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَبْلٌ﴾</span></span> اسم، من مادّة <root>حبل</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّسَدٍۭ﴾</span></span> اسم، من مادّة <root>مسد</root>، مذكر، نكرة، مجرور.</p></div>"