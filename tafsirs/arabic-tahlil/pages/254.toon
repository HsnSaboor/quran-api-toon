quran[8]{c,v,t}:
  13,35,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّثَلُ﴾</span></span> اسم، من مادّة <root>مثل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَنَّةِ﴾</span></span> علم، من مادّة <root>جنن</root>، مؤنث.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّتِى﴾</span></span> اسم موصول، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وُعِدَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>وعد</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُتَّقُونَ﴾</span></span> اسم فاعل مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وقي</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَجْرِى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>جري</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَحْتِ﴾</span></span> اسم، من مادّة <root>تحت</root>، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَنْهَٰرُ﴾</span></span> اسم، من مادّة <root>نهر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُكُلُ﴾</span></span> اسم، من مادّة <root>أكل</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دَآئِمٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>دوم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ظِلُّ﴾</span></span> اسم، من مادّة <root>ظلل</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تِ﴾</span></span> اسم اشارة، مؤنث، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عُقْبَى﴾</span></span> اسم، من مادّة <root>عقب</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱتَّقَ﴾</span></span> فعل ماض مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وقي</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَّ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عُقْبَى﴾</span></span> اسم، من مادّة <root>عقب</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَٰفِرِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كفر</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّارُ﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، مرفوع.</p></div>"
  13,36,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَاتَيْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كِتَٰبَ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَفْرَحُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>فرح</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُنزِلَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، لم يسمّ فاعله، من مادّة <root>نزل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَحْزَابِ﴾</span></span> اسم، من مادّة <root>حزب</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُنكِرُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نكر</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْضَ﴾</span></span> اسم، من مادّة <root>بعض</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قول</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> حرف كاف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُمِرْ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>أمر</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنْ﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعْبُدَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، متكلم، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهَ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُشْرِكَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>شرك</root>، متكلم، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦٓ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْعُوا۟﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>دعو</root>، متكلم، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَـَٔابِ﴾</span></span> اسم، من مادّة <root>أوب</root>، مذكر، مجرور.</p></div>"
  13,37,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنزَلْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نزل</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حُكْمًا﴾</span></span> اسم، من مادّة <root>حكم</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَرَبِيًّا﴾</span></span> اسم، من مادّة <root>عرب</root>، مذكر، مفرد، نكرة، منصوب، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿ئِنِ﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱتَّبَعْ﴾</span></span> فعل ماض مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>تبع</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَهْوَآءَ﴾</span></span> اسم، من مادّة <root>هوي</root>، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْدَ﴾</span></span> ظرف زمان، من مادّة <root>بعد</root>، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جيأ</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عِلْمِ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَلِىٍّ﴾</span></span> اسم، من مادّة <root>ولي</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَاقٍ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>وقي</root>، مذكر، نكرة، مجرور.</p></div>"
  13,38,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَرْسَلْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رسل</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رُسُلًا﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَبْلِ﴾</span></span> اسم، من مادّة <root>قبل</root>، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جَعَلْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَزْوَٰجًا﴾</span></span> اسم، من مادّة <root>زوج</root>، مذكر، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ذُرِّيَّةً﴾</span></span> اسم، من مادّة <root>ذرر</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَسُولٍ﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَأْتِىَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أتي</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ـَٔايَةٍ﴾</span></span> اسم، من مادّة <root>أيي</root>، مؤنث، مفرد، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿إِذْنِ﴾</span></span> اسم، من مادّة <root>أذن</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُلِّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَجَلٍ﴾</span></span> اسم، من مادّة <root>أجل</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كِتَابٌ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، نكرة، مرفوع.</p></div>"
  13,39,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَمْحُوا۟﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>محو</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَشَآءُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يُثْبِتُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>ثبت</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>، <span class="hlt"><span class="qpc-hafs">﴿هُۥٓ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُمُّ﴾</span></span> اسم، من مادّة <root>أمم</root>، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كِتَٰبِ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، مجرور.</p></div>"
  13,40,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> حرف زائد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُرِيَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رأي</root>، متكلم، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَّ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْضَ﴾</span></span> اسم، من مادّة <root>بعض</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَعِدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وعد</root>، متكلم، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَوْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَتَوَفَّيَ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>وفي</root>، متكلم، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَّ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف كاف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَلَٰغُ﴾</span></span> اسم، من مادّة <root>بلغ</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حِسَابُ﴾</span></span> مصدر مزيد الرباعي باب (فاعَلَ)، من مادّة <root>حسب</root>، مذكر، مرفوع.</p></div>"
  13,41,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف زائد، <span class="hlt"><span class="qpc-hafs">﴿لَمْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَرَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رأي</root>، غائب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿وْا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَأْتِى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أتي</root>، متكلم، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضَ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَنقُصُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>نقص</root>، متكلم، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَطْرَافِ﴾</span></span> اسم، من مادّة <root>طرف</root>، مذكر، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَحْكُمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>حكم</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُعَقِّبَ﴾</span></span> اسم فاعل مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>عقب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿حُكْمِ﴾</span></span> اسم، من مادّة <root>حكم</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَرِيعُ﴾</span></span> اسم، من مادّة <root>سرع</root>، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حِسَابِ﴾</span></span> مصدر مزيد الرباعي باب (فاعَلَ)، من مادّة <root>حسب</root>، مذكر، مجرور.</p></div>"
  13,42,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَكَرَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>مكر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَبْلِ﴾</span></span> اسم، من مادّة <root>قبل</root>، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَكْرُ﴾</span></span> اسم، من مادّة <root>مكر</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَمِيعًا﴾</span></span> اسم، من مادّة <root>جمع</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَكْسِبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كسب</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُلُّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَفْسٍ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كُفَّٰرُ﴾</span></span> اسم، من مادّة <root>كفر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عُقْبَى﴾</span></span> اسم، من مادّة <root>عقب</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿دَّارِ﴾</span></span> اسم، من مادّة <root>دور</root>، مؤنث، مفرد، مجرور.</p></div>"