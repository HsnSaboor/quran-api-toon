quran[26]{c,v,t}:
  53,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّجْمِ﴾</span></span> اسم، من مادّة <root>نجم</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَوَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>هوي</root>، غائب، مذكر، مفرد.</p></div>"
  53,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ضَلَّ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ضلل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَاحِبُ﴾</span></span> اسم، من مادّة <root>صحب</root>، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَوَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>غوي</root>، غائب، مذكر، مفرد.</p></div>"
  53,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَنطِقُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>نطق</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنِ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿هَوَىٰٓ﴾</span></span> اسم، من مادّة <root>هوي</root>، مذكر، مجرور.</p></div>"
  53,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَحْىٌ﴾</span></span> اسم، من مادّة <root>وحي</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُوحَىٰ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، لم يسمّ فاعله، من مادّة <root>وحي</root>، غائب، مذكر، مفرد، منصوب.</p></div>"
  53,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَّمَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>علم</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَدِيدُ﴾</span></span> اسم، من مادّة <root>شدد</root>، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قُوَىٰ﴾</span></span> اسم، من مادّة <root>قوي</root>، جمع، مجرور.</p></div>"
  53,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ذُو﴾</span></span> اسم، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِرَّةٍ﴾</span></span> اسم، من مادّة <root>مرر</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱسْتَوَىٰ﴾</span></span> فعل ماض مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>سوي</root>، غائب، مذكر، مفرد.</p></div>"
  53,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف حال، <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُفُقِ﴾</span></span> اسم، من مادّة <root>أفق</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَعْلَىٰ﴾</span></span> اسم، من مادّة <root>علو</root>، مذكر، مرفوع.</p></div>"
  53,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿دَنَا﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>دنو</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَدَلَّىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>دلو</root>، غائب، مذكر، مفرد.</p></div>"
  53,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَابَ﴾</span></span> اسم، من مادّة <root>قوب</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَوْسَيْنِ﴾</span></span> اسم، من مادّة <root>قوس</root>، مذكر، مثنى، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَوْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْنَىٰ﴾</span></span> اسم، من مادّة <root>دنو</root>، مذكر، مفرد، منصوب.</p></div>"
  53,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أَوْحَىٰٓ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>وحي</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَبْدِ﴾</span></span> اسم، من مادّة <root>عبد</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَوْحَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>وحي</root>، غائب، مذكر، مفرد.</p></div>"
  53,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَذَبَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كذب</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فُؤَادُ﴾</span></span> اسم، من مادّة <root>فأد</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَأَىٰٓ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رأي</root>، غائب، مذكر، مفرد.</p></div>"
  53,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف زائد، <span class="hlt"><span class="qpc-hafs">﴿تُمَٰرُ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>مري</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَرَىٰ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رأي</root>، غائب، مذكر، مفرد، منصوب.</p></div>"
  53,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَءَا﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رأي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَزْلَةً﴾</span></span> اسم، من مادّة <root>نزل</root>، مؤنث، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُخْرَىٰ﴾</span></span> اسم، من مادّة <root>أخر</root>، مؤنث، مفرد، مرفوع.</p></div>"
  53,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سِدْرَةِ﴾</span></span> اسم، من مادّة <root>سدر</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُنتَهَىٰ﴾</span></span> اسم مفعول مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>نهي</root>، مذكر، مجرور.</p></div>"
  53,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَنَّةُ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَأْوَىٰٓ﴾</span></span> اسم، من مادّة <root>أوي</root>، مذكر، مجرور.</p></div>"
  53,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذْ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَغْشَى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>غشو</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سِّدْرَةَ﴾</span></span> اسم، من مادّة <root>سدر</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَغْشَىٰ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>غشو</root>، غائب، مذكر، مفرد، مرفوع.</p></div>"
  53,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿زَاغَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>زيغ</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿بَصَرُ﴾</span></span> اسم، من مادّة <root>بصر</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿طَغَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>طغي</root>، غائب، مذكر، مفرد.</p></div>"
  53,18,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَأَىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رأي</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَايَٰتِ﴾</span></span> اسم، من مادّة <root>أيي</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كُبْرَىٰٓ﴾</span></span> اسم، من مادّة <root>كبر</root>، مؤنث، منصوب، نعت.</p></div>"
  53,19,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف زائد، <span class="hlt"><span class="qpc-hafs">﴿رَءَيْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>رأي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمُ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّٰتَ﴾</span></span> علم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْعُزَّىٰ﴾</span></span> علم، من مادّة <root>عزز</root>.</p></div>"
  53,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَنَوٰةَ﴾</span></span> علم، من مادّة <root>مني</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ثَّالِثَةَ﴾</span></span> اسم، من مادّة <root>ثلث</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُخْرَىٰٓ﴾</span></span> اسم، من مادّة <root>أخر</root>، مؤنث، مفرد، مرفوع.</p></div>"
  53,21,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمُ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ذَّكَرُ﴾</span></span> اسم، من مادّة <root>ذكر</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُنثَىٰ﴾</span></span> اسم، من مادّة <root>أنث</root>، مؤنث، مرفوع.</p></div>"
  53,22,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿تِ﴾</span></span> اسم اشارة، مؤنث، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِذًا﴾</span></span> حرف جواب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قِسْمَةٌ﴾</span></span> اسم، من مادّة <root>قسم</root>، مؤنث، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ضِيزَىٰٓ﴾</span></span> اسم، من مادّة <root>ضيز</root>، مؤنث، مرفوع، نعت.</p></div>"
  53,23,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هِىَ﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّآ﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَسْمَآءٌ﴾</span></span> اسم، من مادّة <root>سمو</root>، مذكر، جمع، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَمَّيْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سمو</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمُو﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هَآ﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ءَابَآؤُ﴾</span></span> اسم، من مادّة <root>أبو</root>، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنزَلَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نزل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُلْطَٰنٍ﴾</span></span> اسم، من مادّة <root>سلط</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَّبِعُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>تبع</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ظَّنَّ﴾</span></span> اسم، من مادّة <root>ظنن</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَهْوَى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>هوي</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَنفُسُ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جيأ</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿هُدَىٰٓ﴾</span></span> اسم، من مادّة <root>هدي</root>، مذكر، مجرور.</p></div>"
  53,24,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿إِنسَٰنِ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمَنَّىٰ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>مني</root>، غائب، مذكر، مفرد.</p></div>"
  53,25,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ءَاخِرَةُ﴾</span></span> اسم، من مادّة <root>أخر</root>، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أُولَىٰ﴾</span></span> اسم، من مادّة <root>أول</root>، مؤنث، مرفوع.</p></div>"
  53,26,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كَم﴾</span></span> اسم، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّلَكٍ﴾</span></span> اسم، من مادّة <root>ملك</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿سَّمَٰوَٰتِ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُغْنِى﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>غني</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَفَٰعَتُ﴾</span></span> اسم، من مادّة <root>شفع</root>، مؤنث، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَيْـًٔا﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنۢ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْدِ﴾</span></span> اسم، من مادّة <root>بعد</root>، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَأْذَنَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>أذن</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَشَآءُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>شيأ</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يَرْضَىٰٓ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رضو</root>، غائب، مذكر، مفرد، منصوب.</p></div>"