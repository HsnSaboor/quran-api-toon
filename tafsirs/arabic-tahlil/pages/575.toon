quran[18]{c,v,t}:
  73,20,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَقُومُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قوم</root>، مخاطب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْنَىٰ﴾</span></span> ظرف زمان، من مادّة <root>دنو</root>، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُلُثَىِ﴾</span></span> اسم، من مادّة <root>ثلث</root>، مذكر، مثنى، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يْلِ﴾</span></span> اسم، من مادّة <root>ليل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿نِصْفَ﴾</span></span> ظرف زمان، من مادّة <root>نصف</root>، مذكر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ثُلُثَ﴾</span></span> ظرف زمان، من مادّة <root>ثلث</root>، مذكر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿طَآئِفَةٌ﴾</span></span> اسم، من مادّة <root>طوف</root>، مؤنث، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَعَ﴾</span></span> ظرف مكان، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُقَدِّرُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قدر</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يْلَ﴾</span></span> اسم، من مادّة <root>ليل</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّهَارَ﴾</span></span> اسم، من مادّة <root>نهر</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلِمَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّن﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُحْصُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حصي</root>، مخاطب، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف سببية، <span class="hlt"><span class="qpc-hafs">﴿تَابَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>توب</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱقْرَءُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قرأ</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَيَسَّرَ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>يسر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قُرْءَانِ﴾</span></span> علم، من مادّة <root>قرأ</root>، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلِمَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَن﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿يَكُونُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّرْضَىٰ﴾</span></span> اسم، من مادّة <root>مرض</root>، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ءَاخَرُونَ﴾</span></span> اسم، من مادّة <root>أخر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَضْرِبُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>ضرب</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضِ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَبْتَغُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>بغي</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَضْلِ﴾</span></span> اسم، من مادّة <root>فضل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ءَاخَرُونَ﴾</span></span> اسم، من مادّة <root>أخر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُقَٰتِلُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فاعَلَ)، من مادّة <root>قتل</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَبِيلِ﴾</span></span> اسم، من مادّة <root>سبل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱقْرَءُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قرأ</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَيَسَّرَ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>يسر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَقِيمُ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>قوم</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صَّلَوٰةَ﴾</span></span> اسم، من مادّة <root>صلو</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ءَاتُ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿زَّكَوٰةَ﴾</span></span> اسم، من مادّة <root>زكو</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَقْرِضُ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>قرض</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهَ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَرْضًا﴾</span></span> اسم، من مادّة <root>قرض</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَسَنًا﴾</span></span> اسم، من مادّة <root>حسن</root>، مذكر، مفرد، نكرة، منصوب، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُقَدِّمُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>قدم</root>، مخاطب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿أَنفُسِ﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَيْرٍ﴾</span></span> اسم، من مادّة <root>خير</root>، مذكر، مفرد، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَجِدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وجد</root>، مخاطب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَيْرًا﴾</span></span> اسم، من مادّة <root>خير</root>، مذكر، مفرد، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَعْظَمَ﴾</span></span> اسم، من مادّة <root>عظم</root>، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَجْرًا﴾</span></span> اسم، من مادّة <root>أجر</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱسْتَغْفِرُ﴾</span></span> فعل أمر من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>غفر</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهَ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهَ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَفُورٌ﴾</span></span> اسم، من مادّة <root>غفر</root>، مذكر، مفرد، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّحِيمٌۢ﴾</span></span> اسم، من مادّة <root>رحم</root>، مذكر، مفرد، نكرة، مرفوع.</p></div>"
  74,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَٰٓ﴾</span></span> حرف نداء، <span class="hlt"><span class="qpc-hafs">﴿أَيُّ﴾</span></span> اسم، من مادّة <root>أيي</root>، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> حرف تنبيه.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُدَّثِّرُ﴾</span></span> اسم فاعل مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>دثر</root>، مذكر، مرفوع.</p></div>"
  74,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿قُمْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>قوم</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَنذِرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نذر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رَبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كَبِّرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كبر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ثِيَابَ﴾</span></span> اسم، من مادّة <root>ثوب</root>، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿طَهِّرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>طهر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿رُّجْزَ﴾</span></span> اسم، من مادّة <root>رجز</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱهْجُرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>هجر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمْنُن﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>منن</root>، مخاطب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَسْتَكْثِرُ﴾</span></span> فعل مضارع من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>كثر</root>، مخاطب، مذكر، مفرد، مرفوع.</p></div>"
  74,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱصْبِرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>صبر</root>، مخاطب، مذكر، مفرد.</p></div>"
  74,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُقِرَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>نقر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاقُورِ﴾</span></span> اسم، من مادّة <root>نقر</root>، مذكر، مجرور.</p></div>"
  74,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿ذَٰ﴾</span></span> اسم اشارة، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام البعد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف خطاب، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمٌ﴾</span></span> اسم، من مادّة <root>يوم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَسِيرٌ﴾</span></span> اسم، من مادّة <root>عسر</root>، مذكر، مفرد، نكرة، مرفوع، نعت.</p></div>"
  74,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿كَٰفِرِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>كفر</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿غَيْرُ﴾</span></span> اسم، من مادّة <root>غير</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَسِيرٍ﴾</span></span> اسم، من مادّة <root>يسر</root>، مذكر، مفرد، نكرة، مجرور.</p></div>"
  74,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ذَرْ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>وذر</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿نِى﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَحِيدًا﴾</span></span> اسم، من مادّة <root>وحد</root>، مذكر، مفرد، نكرة، منصوب.</p></div>"
  74,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جَعَلْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَالًا﴾</span></span> اسم، من مادّة <root>مول</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّمْدُودًا﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>مدد</root>، مذكر، نكرة، منصوب، نعت.</p></div>"
  74,13,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿بَنِينَ﴾</span></span> اسم، من مادّة <root>بني</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شُهُودًا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>شهد</root>، مذكر، جمع، نكرة، منصوب، نعت.</p></div>"
  74,14,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَهَّد﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>مهد</root>، متكلم، مفرد، <span class="hlt"><span class="qpc-hafs">﴿تُّ﴾</span></span> ضمير، متكلم، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَمْهِيدًا﴾</span></span> مصدر مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>مهد</root>، مذكر، نكرة، منصوب.</p></div>"
  74,15,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَطْمَعُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>طمع</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنْ﴾</span></span> حرف مصدري.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَزِيدَ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>زيد</root>، متكلم، مفرد، منصوب.</p></div>"
  74,16,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّآ﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ءَايَٰتِ﴾</span></span> اسم، من مادّة <root>أيي</root>، مؤنث، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنِيدًا﴾</span></span> اسم، من مادّة <root>عند</root>، مذكر، مفرد، نكرة، منصوب.</p></div>"
  74,17,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿أُرْهِقُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رهق</root>، متكلم، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَعُودًا﴾</span></span> اسم، من مادّة <root>صعد</root>، مذكر، نكرة، منصوب.</p></div>"