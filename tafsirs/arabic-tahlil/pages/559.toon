quran[7]{c,v,t}:
  65,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَسْكِنُ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>سكن</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَيْثُ﴾</span></span> ظرف مكان، من مادّة <root>حيث</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَكَن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>سكن</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وُجْدِ﴾</span></span> اسم، من مادّة <root>وجد</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نهي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تُضَآرُّ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فاعَلَ)، لم يسمّ فاعله، من مادّة <root>ضرر</root>، مخاطب، مذكر، جمع، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام التعليل، <span class="hlt"><span class="qpc-hafs">﴿تُضَيِّقُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>ضيق</root>، مخاطب، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مؤنث، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُو۟لَٰتِ﴾</span></span> اسم، مؤنث، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَمْلٍ﴾</span></span> اسم، من مادّة <root>حمل</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿أَنفِقُ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نفق</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَتَّىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَضَعْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وضع</root>، غائب، مؤنث، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَمْلَ﴾</span></span> اسم، من مادّة <root>حمل</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَرْضَعْ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رضع</root>، غائب، مؤنث، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿ـَٔاتُ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿و﴾</span></span> ضمير، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُجُورَ﴾</span></span> اسم، من مادّة <root>أجر</root>، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أْتَمِرُ﴾</span></span> فعل أمر من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>أمر</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَيْنَ﴾</span></span> ظرف مكان، من مادّة <root>بين</root>، <span class="hlt"><span class="qpc-hafs">﴿كُم﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَعْرُوفٍ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>عرف</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعَاسَرْ﴾</span></span> فعل ماض مزيد الخماسي باب (تَفاعَلَ)، من مادّة <root>عسر</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿تُرْضِعُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رضع</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥٓ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أُخْرَىٰ﴾</span></span> اسم، من مادّة <root>أخر</root>، مؤنث، مفرد، مرفوع.</p></div>"
  65,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام الامر، <span class="hlt"><span class="qpc-hafs">﴿يُنفِقْ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نفق</root>، غائب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذُو﴾</span></span> اسم، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَعَةٍ﴾</span></span> اسم، من مادّة <root>وسع</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَعَتِ﴾</span></span> اسم، من مادّة <root>وسع</root>، مؤنث، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قُدِرَ﴾</span></span> فعل ماض ثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>قدر</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رِزْقُ﴾</span></span> اسم، من مادّة <root>رزق</root>، مذكر، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿لْ﴾</span></span> لام الامر، <span class="hlt"><span class="qpc-hafs">﴿يُنفِقْ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نفق</root>، غائب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَّآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَاتَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُكَلِّفُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>كلف</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَفْسًا﴾</span></span> اسم، من مادّة <root>نفس</root>، مؤنث، مفرد، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة استثناء.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَاتَىٰ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أتي</root>، متكلم، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَ﴾</span></span> حرف استقبال، <span class="hlt"><span class="qpc-hafs">﴿يَجْعَلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>جعل</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَعْدَ﴾</span></span> ظرف زمان، من مادّة <root>بعد</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عُسْرٍ﴾</span></span> اسم، من مادّة <root>عسر</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُسْرًا﴾</span></span> اسم، من مادّة <root>يسر</root>، مذكر، نكرة، منصوب.</p></div>"
  65,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿كَأَيِّن﴾</span></span> اسم، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَرْيَةٍ﴾</span></span> اسم، من مادّة <root>قري</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَتَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عتو</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْرِ﴾</span></span> اسم، من مادّة <root>أمر</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿رُسُلِ﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف سببية، <span class="hlt"><span class="qpc-hafs">﴿حَاسَبْ﴾</span></span> فعل ماض مزيد الرباعي باب (فاعَلَ)، من مادّة <root>حسب</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حِسَابًا﴾</span></span> مصدر مزيد الرباعي باب (فاعَلَ)، من مادّة <root>حسب</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَدِيدًا﴾</span></span> اسم، من مادّة <root>شدد</root>، مذكر، مفرد، نكرة، منصوب، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عَذَّبْ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>عذب</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَٰ﴾</span></span> ضمير، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابًا﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نُّكْرًا﴾</span></span> اسم، من مادّة <root>نكر</root>، مذكر، مفرد، نكرة، منصوب، نعت.</p></div>"
  65,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ذَاقَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ذوق</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَبَالَ﴾</span></span> اسم، من مادّة <root>وبل</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْرِ﴾</span></span> اسم، من مادّة <root>أمر</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿كَانَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَٰقِبَةُ﴾</span></span> اسم، من مادّة <root>عقب</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْرِ﴾</span></span> اسم، من مادّة <root>أمر</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خُسْرًا﴾</span></span> اسم، من مادّة <root>خسر</root>، مذكر، نكرة، منصوب.</p></div>"
  65,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَعَدَّ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>عدد</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَذَابًا﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَدِيدًا﴾</span></span> اسم، من مادّة <root>شدد</root>، مذكر، مفرد، نكرة، منصوب، نعت.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿ٱتَّقُ﴾</span></span> فعل أمر من مزيد الخماسي باب (افْتَعَلَ)، من مادّة <root>وقي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهَ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَٰٓ﴾</span></span> حرف نداء، <span class="hlt"><span class="qpc-hafs">﴿أُو۟لِى﴾</span></span> اسم، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَلْبَٰبِ﴾</span></span> اسم، من مادّة <root>لبب</root>، مذكر، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَامَنُ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنزَلَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نزل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِكْرًا﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>ذكر</root>، مذكر، نكرة، منصوب.</p></div>"
  65,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّسُولًا﴾</span></span> اسم، من مادّة <root>رسل</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتْلُوا۟﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>تلو</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَايَٰتِ﴾</span></span> اسم، من مادّة <root>أيي</root>، مؤنث، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُبَيِّنَٰتٍ﴾</span></span> اسم، من مادّة <root>بين</root>، مؤنث، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِّ﴾</span></span> لام التعليل، <span class="hlt"><span class="qpc-hafs">﴿يُخْرِجَ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>خرج</root>، غائب، مذكر، مفرد، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِينَ﴾</span></span> اسم موصول، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ءَامَنُ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿عَمِلُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>عمل</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صَّٰلِحَٰتِ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صلح</root>، مؤنث، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ظُّلُمَٰتِ﴾</span></span> اسم، من مادّة <root>ظلم</root>، مؤنث، جمع، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نُّورِ﴾</span></span> اسم، من مادّة <root>نور</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُؤْمِنۢ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>أمن</root>، غائب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿يَعْمَلْ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عمل</root>، غائب، مذكر، مفرد، مجزوم.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَٰلِحًا﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صلح</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُدْخِلْ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دخل</root>، غائب، مذكر، مفرد، مجزوم، <span class="hlt"><span class="qpc-hafs">﴿هُ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جَنَّٰتٍ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، جمع، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَجْرِى﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>جري</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَحْتِ﴾</span></span> اسم، من مادّة <root>تحت</root>، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَنْهَٰرُ﴾</span></span> اسم، من مادّة <root>نهر</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَٰلِدِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>خلد</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِي﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هَآ﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَبَدًا﴾</span></span> ظرف زمان، من مادّة <root>أبد</root>، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَحْسَنَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حسن</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رِزْقًا﴾</span></span> اسم، من مادّة <root>رزق</root>، مذكر، نكرة، منصوب.</p></div>"
  65,12,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهُ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلَّذِى﴾</span></span> اسم موصول، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَلَقَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خلق</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَبْعَ﴾</span></span> اسم، من مادّة <root>سبع</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَمَٰوَٰتٍ﴾</span></span> اسم، من مادّة <root>سمو</root>، مؤنث، جمع، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مِنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَرْضِ﴾</span></span> اسم، من مادّة <root>أرض</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِثْلَ﴾</span></span> اسم، من مادّة <root>مثل</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَتَنَزَّلُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>نزل</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَمْرُ﴾</span></span> اسم، من مادّة <root>أمر</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَيْنَ﴾</span></span> ظرف مكان، من مادّة <root>بين</root>، <span class="hlt"><span class="qpc-hafs">﴿هُنَّ﴾</span></span> ضمير، غائب، مؤنث، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> لام التعليل، <span class="hlt"><span class="qpc-hafs">﴿تَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، مخاطب، مذكر، جمع، منصوب، <span class="hlt"><span class="qpc-hafs">﴿وٓا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهَ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُلِّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَىْءٍ﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدِيرٌ﴾</span></span> اسم، من مادّة <root>قدر</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهَ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَحَاطَ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حوط</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُلِّ﴾</span></span> اسم، من مادّة <root>كلل</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿شَىْءٍ﴾</span></span> اسم، من مادّة <root>شيأ</root>، مذكر، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِلْمًۢا﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، نكرة، منصوب.</p></div>"