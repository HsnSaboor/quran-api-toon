quran[29]{c,v,t}:
  37,154,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَيْفَ﴾</span></span> استفهامية، من مادّة <root>كيف</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَحْكُمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>حكم</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  37,155,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف زائد، <span class="hlt"><span class="qpc-hafs">﴿لَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَذَكَّرُ﴾</span></span> فعل مضارع من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ذكر</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  37,156,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَمْ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سُلْطَٰنٌ﴾</span></span> اسم، من مادّة <root>سلط</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مُّبِينٌ﴾</span></span> اسم فاعل مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بين</root>، مذكر، نكرة، مرفوع.</p></div>"
  37,157,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أْتُ﴾</span></span> فعل أمر من الثلاثي مجرد، من مادّة <root>أتي</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿كِتَٰبِ﴾</span></span> اسم، من مادّة <root>كتب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كُن﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَٰدِقِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صدق</root>، مذكر، جمع، منصوب.</p></div>"
  37,158,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿جَعَلُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>جعل</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بَيْنَ﴾</span></span> ظرف مكان، من مادّة <root>بين</root>، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿بَيْنَ﴾</span></span> ظرف مكان، من مادّة <root>بين</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جِنَّةِ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَسَبًا﴾</span></span> اسم، من مادّة <root>نسب</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلِمَتِ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>علم</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جِنَّةُ﴾</span></span> اسم، من مادّة <root>جنن</root>، مؤنث، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿مُحْضَرُونَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>حضر</root>، مذكر، جمع، مرفوع.</p></div>"
  37,159,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿سُبْحَٰنَ﴾</span></span> اسم، من مادّة <root>سبح</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَصِفُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وصف</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  37,160,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِبَادَ﴾</span></span> اسم، من مادّة <root>عبد</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُخْلَصِينَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>خلص</root>، مذكر، جمع، منصوب، نعت.</p></div>"
  37,161,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿كُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْبُدُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>عبد</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  37,162,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنتُمْ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَيْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿فَٰتِنِينَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>فتن</root>، مذكر، جمع، مجرور.</p></div>"
  37,163,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَالِ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صلي</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَحِيمِ﴾</span></span> اسم، من مادّة <root>جحم</root>، مؤنث، مجرور.</p></div>"
  37,164,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> حرف نفي.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِنَّ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿آ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة حصر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَقَامٌ﴾</span></span> اسم، من مادّة <root>قوم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَّعْلُومٌ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>علم</root>، مذكر، نكرة، مرفوع.</p></div>"
  37,165,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿نَحْنُ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صَّآفُّونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>صفف</root>، مذكر، جمع، مرفوع.</p></div>"
  37,166,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿ا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿نَحْنُ﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُسَبِّحُونَ﴾</span></span> اسم فاعل مزيد الرباعي باب (فَعَّلَ)، من مادّة <root>سبح</root>، مذكر، جمع، مرفوع.</p></div>"
  37,167,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَانُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿يَقُولُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>قول</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  37,168,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَوْ﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِندَ﴾</span></span> ظرف مكان، من مادّة <root>عند</root>، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ذِكْرًا﴾</span></span> مصدر الثلاثي مجرد، من مادّة <root>ذكر</root>، مذكر، نكرة، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مِّنَ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أَوَّلِينَ﴾</span></span> اسم، من مادّة <root>أول</root>، مذكر، جمع، مجرور.</p></div>"
  37,169,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿كُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كون</root>، متكلم، جمع، <span class="hlt"><span class="qpc-hafs">﴿نَّا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِبَادَ﴾</span></span> اسم، من مادّة <root>عبد</root>، مذكر، جمع، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱللَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُخْلَصِينَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>خلص</root>، مذكر، جمع، منصوب، نعت.</p></div>"
  37,170,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿كَفَرُ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>كفر</root>، غائب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿وا۟﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِۦ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿سَوْفَ﴾</span></span> حرف استقبال.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  37,171,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَبَقَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>سبق</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلِمَتُ﴾</span></span> اسم، من مادّة <root>كلم</root>، مؤنث، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿عِبَادِ﴾</span></span> اسم، من مادّة <root>عبد</root>، مذكر، جمع، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُرْسَلِينَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رسل</root>، مذكر، جمع، مجرور، نعت.</p></div>"
  37,172,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَنصُورُونَ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>نصر</root>، مذكر، جمع، مرفوع.</p></div>"
  37,173,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿جُندَ﴾</span></span> اسم، من مادّة <root>جند</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمُ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿غَٰلِبُونَ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>غلب</root>، مذكر، جمع، مرفوع.</p></div>"
  37,174,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿تَوَلَّ﴾</span></span> فعل أمر من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ولي</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَتَّىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حِينٍ﴾</span></span> اسم، من مادّة <root>حين</root>، مذكر، نكرة، مجرور.</p></div>"
  37,175,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَبْصِرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بصر</root>، مخاطب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿سَوْفَ﴾</span></span> حرف استقبال.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُبْصِرُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بصر</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  37,176,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَ﴾</span></span> استفهامية، <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف زائد، <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿عَذَابِ﴾</span></span> اسم، من مادّة <root>عذب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿نَا﴾</span></span> ضمير، متكلم، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَسْتَعْجِلُ﴾</span></span> فعل مضارع من مزيد السداسي باب (اسْتَفْعَلَ)، من مادّة <root>عجل</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  37,177,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿نَزَلَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>نزل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿سَاحَتِ﴾</span></span> اسم، من مادّة <root>سوح</root>، مؤنث، مجرور، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿سَآءَ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>سوأ</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿صَبَاحُ﴾</span></span> اسم، من مادّة <root>صبح</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُنذَرِينَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>نذر</root>، مذكر، جمع، مجرور.</p></div>"
  37,178,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿تَوَلَّ﴾</span></span> فعل أمر من مزيد الخماسي باب (تَفَعَّلَ)، من مادّة <root>ولي</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنْ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَتَّىٰ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حِينٍ﴾</span></span> اسم، من مادّة <root>حين</root>، مذكر، نكرة، مجرور.</p></div>"
  37,179,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَبْصِرْ﴾</span></span> فعل أمر من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بصر</root>، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿سَوْفَ﴾</span></span> حرف استقبال.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يُبْصِرُ﴾</span></span> فعل مضارع من مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>بصر</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  37,180,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿سُبْحَٰنَ﴾</span></span> اسم، من مادّة <root>سبح</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عِزَّةِ﴾</span></span> اسم، من مادّة <root>عزز</root>، مؤنث، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿مَّا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَصِفُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>وصف</root>، غائب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، غائب، مذكر، جمع.</p></div>"
  37,181,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿سَلَٰمٌ﴾</span></span> اسم، من مادّة <root>سلم</root>، مذكر، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَلَى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مُرْسَلِينَ﴾</span></span> اسم مفعول مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>رسل</root>، مذكر، جمع، مجرور.</p></div>"
  37,182,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿حَمْدُ﴾</span></span> اسم، من مادّة <root>حمد</root>، مذكر، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿لَّهِ﴾</span></span> علم، من مادّة <root>أله</root>.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبِّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عَٰلَمِينَ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، جمع، مجرور.</p></div>"