quran[21]{c,v,t}:
  100,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿حُصِّلَ﴾</span></span> فعل ماض مزيد الرباعي باب (فَعَّلَ)، لم يسمّ فاعله، من مادّة <root>حصل</root>، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> اسم موصول.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿صُّدُورِ﴾</span></span> اسم، من مادّة <root>صدر</root>، مذكر، جمع، مجرور.</p></div>"
  100,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف نصب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَبَّ﴾</span></span> اسم، من مادّة <root>ربب</root>، مذكر، منصوب، <span class="hlt"><span class="qpc-hafs">﴿هُم﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿بِ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿هِمْ﴾</span></span> ضمير، غائب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَّ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿خَبِيرٌۢ﴾</span></span> اسم، من مادّة <root>خبر</root>، مذكر، مفرد، نكرة، مرفوع.</p></div>"
  101,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قَارِعَةُ﴾</span></span> اسم، من مادّة <root>قرع</root>، مؤنث، مرفوع.</p></div>"
  101,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قَارِعَةُ﴾</span></span> اسم، من مادّة <root>قرع</root>، مؤنث، مرفوع.</p></div>"
  101,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْرَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دري</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿قَارِعَةُ﴾</span></span> اسم، من مادّة <root>قرع</root>، مؤنث، مرفوع.</p></div>"
  101,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، مذكر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَكُونُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كون</root>، غائب، مذكر، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّاسُ﴾</span></span> اسم، من مادّة <root>أنس</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فَرَاشِ﴾</span></span> اسم، من مادّة <root>فرش</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَبْثُوثِ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>بثث</root>، مذكر، مجرور، نعت.</p></div>"
  101,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿تَكُونُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>كون</root>، غائب، مؤنث، مفرد، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جِبَالُ﴾</span></span> اسم، من مادّة <root>جبل</root>، مذكر، جمع، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> حرف جر، <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿عِهْنِ﴾</span></span> اسم، من مادّة <root>عهن</root>، مذكر، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَنفُوشِ﴾</span></span> اسم مفعول الثلاثي مجرد، من مادّة <root>نفش</root>، مذكر، مجرور، نعت.</p></div>"
  101,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف استئنافية، <span class="hlt"><span class="qpc-hafs">﴿أَمَّا﴾</span></span> حرف تفصيل.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ثَقُلَتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>ثقل</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَوَٰزِينُ﴾</span></span> اسم، من مادّة <root>وزن</root>، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  101,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿فِى﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِيشَةٍ﴾</span></span> اسم، من مادّة <root>عيش</root>، مؤنث، نكرة، مجرور.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿رَّاضِيَةٍ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>رضو</root>، مؤنث، نكرة، مجرور، نعت.</p></div>"
  101,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أَمَّا﴾</span></span> حرف تفصيل.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿خَفَّتْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>خفف</root>، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَوَٰزِينُ﴾</span></span> اسم، من مادّة <root>وزن</root>، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p></div>"
  101,9,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿فَ﴾</span></span> حرف واقع في جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿أُمُّ﴾</span></span> اسم، من مادّة <root>أمم</root>، مؤنث، مفرد، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿هُۥ﴾</span></span> ضمير، غائب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هَاوِيَةٌ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>هوي</root>، مؤنث، نكرة، مرفوع.</p></div>"
  101,10,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿وَ﴾</span></span> حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿مَآ﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿أَدْرَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>دري</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كَ﴾</span></span> ضمير، مخاطب، مذكر، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿مَا﴾</span></span> استفهامية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿هِيَهْ﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p></div>"
  101,11,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿نَارٌ﴾</span></span> اسم، من مادّة <root>نور</root>، مؤنث، نكرة، مرفوع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿حَامِيَةٌۢ﴾</span></span> اسم فاعل الثلاثي مجرد، من مادّة <root>حمي</root>، مؤنث، نكرة، مرفوع، نعت.</p></div>"
  102,1,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿أَلْهَىٰ﴾</span></span> فعل ماض مزيد الرباعي باب (أَفْعَلَ)، من مادّة <root>لهو</root>، غائب، مذكر، مفرد، <span class="hlt"><span class="qpc-hafs">﴿كُمُ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿تَّكَاثُرُ﴾</span></span> مصدر مزيد الرباعي باب (فاعَلَ)، من مادّة <root>كثر</root>، مذكر، مرفوع.</p></div>"
  102,2,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿حَتَّىٰ﴾</span></span> حرف ابتداء.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿زُرْ﴾</span></span> فعل ماض ثلاثي مجرد، من مادّة <root>زور</root>، مخاطب، مذكر، جمع، <span class="hlt"><span class="qpc-hafs">﴿تُمُ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿مَقَابِرَ﴾</span></span> اسم، من مادّة <root>قبر</root>، مذكر، جمع، منصوب.</p></div>"
  102,3,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَوْفَ﴾</span></span> حرف استقبال.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  102,4,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿سَوْفَ﴾</span></span> حرف استقبال.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p></div>"
  102,5,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَوْ﴾</span></span> شرطية.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿تَعْلَمُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>علم</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿ونَ﴾</span></span> ضمير، مخاطب، مذكر، جمع.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عِلْمَ﴾</span></span> اسم، من مادّة <root>علم</root>، مذكر، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يَقِينِ﴾</span></span> اسم، من مادّة <root>يقن</root>، مذكر، مفرد، مجرور.</p></div>"
  102,6,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿تَرَوُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رأي</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَّ﴾</span></span> لام التوكيد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿جَحِيمَ﴾</span></span> اسم، من مادّة <root>جحم</root>، مؤنث، منصوب.</p></div>"
  102,7,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿تَرَوُ﴾</span></span> فعل مضارع من الثلاثي مجرد، من مادّة <root>رأي</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَّ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿هَا﴾</span></span> ضمير، غائب، مؤنث، مفرد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَيْنَ﴾</span></span> اسم، من مادّة <root>عين</root>، مؤنث، منصوب.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱلْ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿يَقِينِ﴾</span></span> اسم، من مادّة <root>يقن</root>، مذكر، مفرد، مجرور.</p></div>"
  102,8,"<div class=ar lang=ar><p>• <span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿لَ﴾</span></span> لام التوكيد، <span class="hlt"><span class="qpc-hafs">﴿تُسْـَٔلُ﴾</span></span> فعل مضارع من الثلاثي مجرد، لم يسمّ فاعله، من مادّة <root>سأل</root>، مخاطب، مذكر، جمع، مرفوع، <span class="hlt"><span class="qpc-hafs">﴿نَّ﴾</span></span> لام التوكيد.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان، من مادّة <root>يوم</root>، <span class="hlt"><span class="qpc-hafs">﴿ئِذٍ﴾</span></span> ظرف زمان.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿عَنِ﴾</span></span> حرف جر.</p><p>• <span class="hlt"><span class="qpc-hafs">﴿ٱل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿نَّعِيمِ﴾</span></span> اسم، من مادّة <root>نعم</root>، مذكر، مجرور.</p></div>"