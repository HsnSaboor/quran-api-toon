tafsir[5]{c,v,t}:
  97,1,"ہم نے اُسکو اتارا شب قدر میں",footnotes:88877:1
  97,2,"اور تو نے کیا سمجھا کہ کیا ہے شب قدر"
  97,3,"شب قدر بہتر ہے ہزار مہینے سے",footnotes:88878:1
  97,4,"اترتے ہیں فرشتے اور روح اُس میں اپنے رب کے حکم سے ہر کام پر",footnotes:88879:12
  97,5,"امان ہے وہ رات صبح کے نکلنے تک",footnotes:88881:12
