tafsir[27]{c,v,t}:
  95,1,""قسم انجیر کی اور زیتون کی",footnotes:88855:1"
  95,2,""اور طور سینین کی""
  95,3,""اور اُس شہر امن والے کی",footnotes:88856:1"
  95,4,""ہم نے بنایا آدمی خوب سے اندازے پر",footnotes:88857:1"
  95,5,""پھر پھینک دیا اُسکو نیچوں سے نیچے",footnotes:88858:1"
  95,6,""مگر جو یقین لائے اور عمل کئے اچھے سو اُنکے لئے ثواب ہے بے انتہا",footnotes:88859:1"
  95,7,""پھر تو اُسکے پیچھے کیوں جھٹلائے بدلا ملنے کو",footnotes:88860:1"
  95,8,""کیا نہیں ہے اللہ سب حاکموں سے بڑا حاکم",footnotes:88861:1"
  96,1,""پڑھ اپنے رب کے نام سے جو سب کا بنانے والا ہے",footnotes:88862:12"
  96,2,""بنایا آدمی کو جمے ہوئے لہو سے",footnotes:88864:1"
  96,3,""پڑھ اور تیرا رب بڑا کریم ہے",footnotes:88865:1"
  96,4,""جس نے علم سکھایا قلم سے",footnotes:88866:1"
  96,5,""سکھلایا آدمی کو جو وہ نہ جانتا تھا",footnotes:88867:1"
  96,6,""کوئی نہیں آدمی سر چڑھتا ہے اس سے""
  96,7,""کہ دیکھے اپنے آپکو بے پروا",footnotes:88868:1"
  96,8,""بیشک تیرے رب کی طرف پھر جانا ہے",footnotes:88869:1"
  96,9,""تو نے دیکھا اُسکو جو منع کرتا ہے""
  96,10,""ایک بندہ کو جب وہ نماز پڑھے",footnotes:88870:1"
  96,11,""بھلا دیکھ تو اگر ہوتا نیک راہ پر""
  96,12,""یا سکھلاتا ڈر کے کام""
  96,13,""بھلا دیکھ تو اگر جھٹلایا اور منہ موڑا",footnotes:88871:1"
  96,14,""یہ نہ جانا کہ اللہ دیکھتا ہے",footnotes:88872:1"
  96,15,""کوئی نہیں اگر باز نہ آئے گا ہم گھسیٹیں گے چوٹی پکڑ کر",footnotes:88873:1"
  96,16,""کیسی چوٹی جھوٹی گنہگار",footnotes:88874:1"
  96,17,""اب بلا لیوے اپنے مجلس والوں کو""
  96,18,""ہم بھی بلاتے ہیں پیادے سیاست کرنے کو",footnotes:88875:1"
  96,19,""کوئی نہیں مت مان اُسکا کہا اور سجدہ کر اور نزدیک ہو",footnotes:88876:1"
