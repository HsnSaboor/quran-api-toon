tafsir[15]{c,v,t}:
  23,60,""اور جو لوگ کہ دیتے ہیں جو کچھ دیتے ہیں وہ اور اُنکے دل ڈر رہے ہیں اس لئے کہ انکو  اپنے رب کی طرف لوٹ کر جانا ہے",footnotes:85406:1"
  23,61,""وہ لوگ دوڑ دوڑ کر لیتے ہیں بھلائیاں اور وہ ان پر پہنچے سب سے آگے",footnotes:85407:1"
  23,62,""اور ہم کسی پر بوجھ نہیں ڈالتے مگر اسکی گنجائش کے موافق اور ہمارے پاس لکھا ہوا ہے جو بولتا ہے سچ اور ان پر ظلم نہ ہو گا",footnotes:85408:1"
  23,63,""کوئی نہیں انکے دل بیہوش ہیں اس طرف اور انکو اور کام لگ رہے ہیں اسکے سوائے کہ وہ انکو کر رہے ہیں",footnotes:85409:1"
  23,64,""یہاں تک کہ جب پکڑیں گے ہم اُنکے آسودہ لوگوں کو آفت میں تبھی وہ لگیں گے چلانے""
  23,65,""مت چلاؤ آج کے دن تم ہم سے چھوٹ نہ سکو گے",footnotes:85410:1"
  23,66,""تم کو سنائی جاتی تھیں میری آیتیں تو تم ایڑیوں پر الٹے بھاگتے تھے۔""
  23,67,""اس سے تکبر کر کے ایک قصہ گو کو چھوڑ کر چلے گئے",footnotes:85411:12"
  23,68,""سو کیا انہوں نے دھیان نہیں کیا اس کلام میں یا آئی ہے ان کے پاس ایسی چیز جو نہ تھی ان کے پہلے باپ دادوں کے پاس",footnotes:85413:12"
  23,69,""یا پہچانا نہیں انہوں نے اپنے پیغام لانے والوں کو سو وہ اس کو اوپرا سمجھتے ہیں",footnotes:85415:1"
  23,70,""یا کہتے ہیں ان کو سودا ہے کوئی نہیں وہ تو لایا ہے ان کے پاس سچی باتے اور ان بہتوں کو سچی بات بری لگتی ہے",footnotes:85416:1"
  23,71,""اور اگر سچا رب چلے ان کی خوشی پر تو خراب ہو جائیں آسمان اور زمین اور جو کوئی ان میں ہے کوئی نہیں ہم"
  23,72,""یا تو ان سے مانگتا ہے کچھ محصول سو محصول تیرے رب کا بہتر ہے اور وہ ہے بہتر روزی دینے والا",footnotes:85420:1"
  23,73,""اور تو تو بلاتا ہے ان کو سیدھی راہ پر""
  23,74,""اور جو لوگ نہیں مانتے آخرت کو راہ سے ٹیڑھے ہو گئے ہیں",footnotes:85421:1"
