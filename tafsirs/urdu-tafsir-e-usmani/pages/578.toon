tafsir[26]{c,v,t}:
  75,20,""کوئی نہیں پر تم چاہتے ہو جو جلد آئے""
  75,21,""اور چھوڑتے ہو جو دیر میں آئے",footnotes:88456:1"
  75,22,""کتنے منہ اس دن تازہ ہیں""
  75,23,""اپنے رب کی طرف دیکھنے والے",footnotes:88457:1"
  75,24,""اور کتنے منہ اُس دن اداس ہیں",footnotes:88458:1"
  75,25,""خیال کرتے ہیں کہ اُن پر وہ آئے جس سے ٹوٹے کمر",footnotes:88459:1"
  75,26,""ہرگز نہیں جس وقت جان پہنچے ہانس تک",footnotes:88460:1"
  75,27,""اور لوگ کہیں کون ہے جھاڑنے والا",footnotes:88461:1"
  75,28,""اور وہ سمجھا  کہ اب آیا وقت جدائی کا",footnotes:88462:1"
  75,29,""اور لپٹ گئ پنڈلی پر پنڈلی",footnotes:88463:1"
  75,30,""تیرے رب کی طرف ہے اُس دن کھنچ کر چلا جانا",footnotes:88464:1"
  75,31,""پھر نہ یقین لایا اور نہ نماز پڑھی""
  75,32,""پھر جھٹلایا اور منہ موڑا""
  75,33,""پھر گیا اپنے گھر کو اکڑتا ہوا",footnotes:88465:1"
  75,34,""خرابی تیری خرابی پر خرابی تیری""
  75,35,""پھر خرابی تیری خرابی پر خرابی تیری",footnotes:88466:1"
  75,36,""کیا خیال رکھتا ہے آدمی کہ چھوٹا رہے گا بے قید",footnotes:88467:1"
  75,37,""بھلا نہ تھا وہ ایک بوند منی کی جو ٹپکی",footnotes:88468:1"
  75,38,""پھر تھا لہو جما ہوا پھر اُس نے بنایا اور ٹھیک کر اٹھایا""
  75,39,""پھر کیا اُس میں جوڑا نر اور مادہ""
  75,40,""کیا یہ خدا زندہ نہیں کر سکتا مردوں کو",footnotes:88469:1"
  76,1,""کبھی گذرا ہے انسان پر ایک وقت زمانے میں کہ نہ تھا وہ کوئی چیز جو زبان پر آتی",footnotes:88470:1"
  76,2,""ہم نے بنایا آدمی کو ایک دو  رنگی بوند سے ہم پلٹتے رہے اُسکو پھر کر دیا اُسکو ہم نے سننے والا دیکھنے والا",footnotes:88471:12"
  76,3,""ہم نے اُسکو سجھائی راہ یا حق مانتا ہے اور یا ناشکری کرتا ہے",footnotes:88473:1"
  76,4,""ہم نے تیار کر رکھی ہیں منکروں کے واسطے زنجیریں اور طوق اور آگ دہکتی",footnotes:88474:1"
  76,5,""البتہ نیک لوگ پیتے ہیں پیالہ جس کی ملونی ہے کافور""
