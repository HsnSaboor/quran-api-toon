tafsir[5]{c,v,t}:
  111,1,"ٹوٹ گئے ہاتھ ابی لہب کے اور ٹوٹ گیا وہ آپ",footnotes:88951:1
  111,2,"کام نہ آیا اُسکو مال اُسکا اور نہ جو اُس نے کمایا",footnotes:88952:1
  111,3,"ڈیگ مارتی آگ میں",footnotes:88953:1
  111,4,"اور اُسکی جورو جو سر پر لئے پھرتی ہے ایندھن",footnotes:88954:1
  111,5,"اُسکی گردن میں رسی ہے مونجھ کی",footnotes:88955:1
