tafsir[34]{c,v,t}:
  56,17,"لئے پھرتے ہیں اُنکے پاس لڑکے سدا رہنے والے",footnotes:87836:1
  56,18,"آبخورے اور کوزے اور پیالہ نتھری شراب کا"
  56,19,"جس سے نہ سر دکھے اور نہ بکواس لگے",footnotes:87837:1
  56,20,"اور میوہ جونسا پسند کر لیں"
  56,21,"اور گوشت اڑتے جانوروں کا جس قسم کو جی چاہے",footnotes:87838:1
  56,22,"اور عورتیں گوری بڑی آنکھوں والیاں"
  56,23,"جیسے موتی کے دانے اپنے غلاف کے اندر",footnotes:87839:1
  56,24,"بدلہ اُن کاموں کا جو کرتے تھے"
  56,25,"نہیں سنیں گے وہاں بکواس اور گناہ کی بات"
  56,26,"مگر ایک بولنا سلام سلام",footnotes:87840:1
  56,27,"اور داہنے والے کیا کہنے داہنے والوں کے"
  56,28,"رہتے ہیں بیری کے درختوں میں جن میں کانٹا نہیں",footnotes:87841:1
  56,29,"اور کیلے تہہ پر تہہ"
  56,30,"اور سایہ لنبا",footnotes:87842:1
  56,31,"اور پانی بہتا ہوا"
  56,32,"اور میوہ بہت"
  56,33,"نہ اُس میں سے ٹوٹا اور نہ روکا ہوا",footnotes:87843:1
  56,34,"اور بچھونے اونچے",footnotes:87844:1
  56,35,"ہم نے اٹھایا اُن عورتوں کو ایک اچھے اٹھان پر"
  56,36,"پھر کیا اُنکو کنواریاں"
  56,37,"پیار  دلانے والیاں ہم عمر"
  56,38,"واسطے داہنے والوں کے",footnotes:87845:1
  56,39,"انبوہ ہے پہلوں میں سے"
  56,40,"اور انبوہ ہے پچھلوں میں سے",footnotes:87846:1
  56,41,"اور بائیں والے کیسے بائیں والے"
  56,42,"تیز بھاپ میں اور جلتے پانی میں"
  56,43,"اور سایہ میں دھوئیں کے"
  56,44,"نہ ٹھنڈا اور نہ عزت کا",footnotes:87847:1
  56,45,"وہ لوگ تھے اس سے پہلے خوشحال"
  56,46,"اور ضد کرتے تھے اُس بڑے گناہ پر",footnotes:87848:1
  56,47,"اور کہا کرتے تھے کیا جب ہم مر گئے اور ہو چکے مٹی اور ہڈیاں کیا ہم پھر اٹھائے جائیں گے"
  56,48,"اور کیا ہمارے اگلے باپ دادے بھی",footnotes:87849:1
  56,49,"تو کہہ دے کہ اگلے اور پچھلے"
  56,50,"سب اکٹھے ہونے والے ہیں ایک دن مقرر کے وقت پر",footnotes:87850:1
