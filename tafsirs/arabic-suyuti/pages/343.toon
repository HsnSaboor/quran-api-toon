quran[10]{c,v,t}:
  23,18,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿وأنْزَلْنا مِنَ السَّماءِ ماءً بِقَدَرٍ﴾</span> الآيَةَ.</p><p>أخْرَجَ ابْنُ مَرْدُوَيْهِ، والخَطِيبُ بِسَنَدٍ ضَعِيفٍ، عَنِ ابْنِ عَبّاسٍ، عَنِ النَّبِيِّ ﷺ قالَ: «أنْزَلَ اللَّهُ مِنَ الجَنَّةِ إلى الأرْضِ خَمْسَةَ أنْهارٍ، سَيْحُونَ وهو نَهْرُ الهِنْدِ، وجَيْحُونَ وهو نَهْرُ بَلْخٍ، ودِجْلَةَ والفُراتَ وهُما نَهْرا العِراقِ، والنِّيلَ وهو نَهْرُ مِصْرَ، أنْزَلَها اللَّهُ مِن عَيْنٍ واحِدَةٍ مِن عُيُونِ الجَنَّةِ، مِن أسْفَلِ دَرَجَةٍ مِن دَرَجاتِها، عَلى جَناحَيْ جِبْرِيلَ، فاسْتَوْدَعَها الجِبالَ وأجْراها في الأرْضِ، وجَعَلَها مَنافِعَ لِلنّاسِ في أصْنافِ مَعايِشِهِمْ، فَذَلِكَ قَوْلُهُ: <span class="qpc-hafs">﴿وأنْزَلْنا مِنَ السَّماءِ ماءً بِقَدَرٍ فَأسْكَنّاهُ في الأرْضِ﴾</span> فَإذا كانَ عِنْدَ خُرُوجِ يَأْجُوجَ ومَأْجُوجَ أرْسَلَ اللَّهُ جِبْرِيلَ فَرَفَعَ مِنَ الأرْضِ القُرْآنَ، والعِلْمَ كُلَّهُ، والحَجَرَ مِن رُكْنِ البَيْتِ، ومَقامَ إبْراهِيمَ وتابُوتَ مُوسى بِما فِيهِ، وهَذِهِ الأنْهارَ الخَمْسَةَ، فَيَرْفَعُ كُلَّ ذَلِكَ إلى السَّماءِ، فَذَلِكَ قَوْلُهُ: <span class="qpc-hafs">﴿وإنّا عَلى ذَهابٍ بِهِ لَقادِرُونَ﴾</span> فَإذا رُفِعَتْ هَذِهِ الأشْياءُ مِنَ الأرْضِ فَقَدَ أهْلُها خَيْرَ الدُّنْيا والآخِرَةِ» .</p><p>(p-٥٨٢)وأخْرَجَ ابْنُ أبِي حاتِمٍ، عَنْ أبِي عَطّافٍ قالَ: إنَّ اللَّهَ أنْزَلَ أرْبَعَةَ أنْهارٍ؛ دِجْلَةَ والفُراتَ وسَيْحُوُنَ وجَيْحُونَ وهو الماءُ الَّذِي قالَ اللَّهُ: <span class="qpc-hafs">﴿وأنْزَلْنا مِنَ السَّماءِ ماءً بِقَدَرٍ﴾</span> الآيَةَ.</p><p>وأخْرَجَ ابْنُ أبِي حاتِمٍ عَنِ السُّدِّيِّ: <span class="qpc-hafs">﴿فَأنْشَأْنا لَكم بِهِ جَنّاتٍ﴾</span> قالَ: هي البَساتِينُ.</p></div>"
  23,19,"23:18"
  23,20,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿وشَجَرَةً﴾</span> الآيَةَ.</p><p>أخْرَجَ ابْنُ جَرِيرٍ، وابْنُ أبِي حاتِمٍ عَنِ الضَّحّاكِ في قَوْلِهِ: <span class="qpc-hafs">﴿مِن طُورِ سَيْناءَ﴾</span> قالَ الطُّورُ الجَبَلُ بِالنَّبَطِيَّةِ، وسِيناءُ بِالنَّبَطِيَّةِ الحَسَنُ.</p><p>وأخْرَجَ ابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ عَنِ ابْنِ عَبّاسٍ قالَ: طُورُ سَيْناءَ هو الجَبَلُ الَّذِي نُودِيَ مِنهُ مُوسى.</p><p>وأخْرَجَ عَبْدُ الرَّزّاقِ، وعَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنْ قَتادَةَ في قَوْلِهِ: <span class="qpc-hafs">﴿وشَجَرَةً تَخْرُجُ﴾</span> قالَ: هي الزَّيْتُونُ ( <span class="qpc-hafs">﴿مِن طُورِ سَيْناءَ﴾</span> ) (p-٥٨٣)قالَ: جَبَلٌ حَسَنٌ: <span class="qpc-hafs">﴿تَنْبُتُ بِالدُّهْنِ وصِبْغٍ لِلآكِلِينَ﴾</span> قالَ: جَعَلَ اللَّهُ فِيها دُهْنًا وأدَمًا.</p><p>وأخْرَجَ ابْنُ أبِي شَيْبَةَ، وعَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ عَنْ مُجاهِدٍ: <span class="qpc-hafs">﴿مِن طُورِ سَيْناءَ﴾</span> قالَ: المُبارَكِ: <span class="qpc-hafs">﴿تَنْبُتُ بِالدُّهْنِ﴾</span> قالَ: تُثْمِرُ الزَّيْتَ.</p><p>وأخْرَجَ ابْنُ أبِي حاتِمٍ عَنِ الرَّبِيعِ بْنِ أنَسٍ: <span class="qpc-hafs">﴿وشَجَرَةً تَخْرُجُ مِن طُورِ سَيْناءَ﴾</span> قالَ: هي الزَّيْتُونُ.</p><p>وأخْرَجَ ابْنُ أبِي حاتِمٍ عَنِ السُّدِّيِّ: <span class="qpc-hafs">﴿وشَجَرَةً تَخْرُجُ﴾</span> الآيَةَ قالَ: هي شَجَرَةُ الزَّيْتُونِ تَنْبُتُ بِالزَّيْتِ، فَهو دُهْنٌ يُدَّهَنُ بِهِ، وهو صِبْغٌ لِلْآكِلِينَ يَأْكُلُهُ النّاسُ.</p><p>وأخْرَجَ ابْنُ أبِي حاتِمٍ عَنْ عَطِيَّةَ العَوْفِيِّ قالَ: سَيْناءُ اسْمُ أرْضٍ.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ عَنْ مُجاهِدٍ قالَ: الطَّوْرُ الجَبَلُ، وسَيْناءُ الحِجارَةُ، وفي لَفْظٍ: وسَيْناءُ الشَّجَرُ.</p><p>وأخْرَجَ عَبْدُ الرَّزّاقِ، وابْنُ المُنْذِرِ عَنِ الكَلْبِيِّ: <span class="qpc-hafs">﴿طُورِ سَيْناءَ﴾</span> قالَ: جَبَلٌ ذُو شَجَرٍ.</p><p>(p-٥٨٤)وأخْرَجَ ابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنِ ابْنِ عَبّاسٍ في قَوْلِهِ: <span class="qpc-hafs">﴿تَنْبُتُ بِالدُّهْنِ﴾</span> قالَ: هو الزَّيْتُ يُؤْكَلُ ويُدَّهَنُ بِهِ.</p><p>وأخْرَجَ ابْنُ جَرِيرٍ، وابْنُ أبِي حاتِمٍ، عَنِ ابْنِ زَيْدٍ في قَوْلِهِ: <span class="qpc-hafs">﴿تَنْبُتُ بِالدُّهْنِ وصِبْغٍ لِلآكِلِينَ﴾</span> قالَ: يَأْتَدِمُونَ بِهِ ويَصْطَبِغُونَ بِهِ.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ عَنْ عاصِمٍ أنَّهُ قَرَأ: <span class="qpc-hafs">﴿مِن طُورِ سَيْناءَ﴾</span> بِنَصْبِ السِّينِ مَمْدُودَةً مَهْمُوزَةَ الألِفِ: ”تَنْبُتُ“ بِنَصْبِ التّاءِ ورَفْعِ الباءِ.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ عَنْ سُلَيْمانَ بْنِ عَبْدِ المَلِكِ أنَّهُ كانَ يَقْرَأُ: <span class="qpc-hafs">﴿تَنْبُتُ بِالدُّهْنِ﴾</span> بِنَصْبِ التّاءِ ورَفْعِ الباءِ.</p></div>"
  23,21,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿وإنَّ لَكم في الأنْعامِ﴾</span> الآيَتَيْنِ.</p><p>أخْرَجَ ابْنُ أبِي حاتِمٍ عَنْ مُجاهِدٍ: <span class="qpc-hafs">﴿وإنَّ لَكم في الأنْعامِ﴾</span> قالَ: الإبِلِ والبَقَرِ والضَّأْنِ والمَعِزِ: <span class="qpc-hafs">﴿ولَكم فِيها مَنافِعُ﴾</span> قالَ: ما تُنْتَجُ، ومِنها مَرْكَبٌ ولَبَنٌ ولَحْمٌ.</p><p>(p-٥٨٥)وأخْرَجَ ابْنُ أبِي حاتِمٍ عَنْ أبِي صالِحٍ في قَوْلِهِ: <span class="qpc-hafs">﴿وعَلى الفُلْكِ﴾</span> قالَ: السُّفُنِ.</p></div>"
  23,22,"23:21"
  23,23,"<div class=ar lang=ar></div>"
  23,24,"<div class=ar lang=ar></div>"
  23,25,"<div class=ar lang=ar></div>"
  23,26,"<div class=ar lang=ar></div>"
  23,27,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿فاسْلُكْ فِيها﴾</span> الآيَةَ.</p><p>أخْرَجَ ابْنُ جَرِيرٍ، وابْنُ أبِي حاتِمٍ، عَنِ ابْنِ عَبّاسٍ في قَوْلِهِ: <span class="qpc-hafs">﴿فاسْلُكْ فِيها﴾</span> يَقُولُ: اجْعَلْ مَعَكَ في السَّفِينَةِ مِن كُلٍّ زَوْجَيْنِ اثْنَيْنِ.</p></div>"