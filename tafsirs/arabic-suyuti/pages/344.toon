quran[15]{c,v,t}:
  23,28,"<div class=ar lang=ar></div>"
  23,29,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿وقُلْ رَبِّ أنْزِلْنِي﴾</span> الآيَةَ.</p><p>أخْرَجَ ابْنُ أبِي شَيْبَةَ، وعَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنْ مُجاهِدٍ: <span class="qpc-hafs">﴿وقُلْ رَبِّ أنْزِلْنِي مُنْزَلا مُبارَكًا﴾</span> قالَ: لِنُوحٍ حِينَ أُنْزِلَ مِنَ السَّفِينَةِ.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ عَنْ عاصِمٍ أنَّهُ قَرَأ: ( أنْزِلْنِي مَنزِلًا ) بِنَصْبِ المِيمِ وخَفْضِ الزّايِ.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنْ قَتادَةَ: <span class="qpc-hafs">﴿وقُلْ رَبِّ أنْزِلْنِي مُنْزَلا مُبارَكًا وأنْتَ خَيْرُ المُنْزِلِينَ﴾</span> قالَ: يُعَلِّمُكم كَيْفَ تَقُولُونَ إذا رَكِبْتُمْ، وكَيْفَ تَقُولُونَ إذا نَزَلْتُمُ، أمّا عِنْدَ الرُّكُوبِ: (p-٥٨٦)فَـ <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</span> [الزخرف: ١٣] <span class="qpc-hafs">﴿وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span> [الزخرف: ١٤] [ الزُّخْرُفِ: ١٣ ]، <span class="qpc-hafs">﴿بِسْمِ اللَّهِ مَجْراها ومُرْساها إنَّ رَبِّي لَغَفُورٌ رَحِيمٌ﴾</span> [هود: ٤١] [هُودٍ: ٤١] وعِنْدَ النُّزُولِ: <span class="qpc-hafs">﴿رَبِّ أنْزِلْنِي مُنْزَلا مُبارَكًا وأنْتَ خَيْرُ المُنْزِلِينَ﴾</span> .</p></div>"
  23,30,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآياتٍ﴾</span> الآيَةَ.</p><p>أخْرَجَ عَبْدُ بْنُ حُمَيْدٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنْ قَتادَةَ: <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآياتٍ وإنْ كُنّا لَمُبْتَلِينَ﴾</span> قالَ: ابْتَلى اللَّهُ النّاسَ قَبْلَكم.</p></div>"
  23,31,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿ثُمَّ أنْشَأْنا مِن بَعْدِهِمْ قَرْنًا﴾</span> .</p><p>أخْرَجَ ابْنُ أبِي حاتِمٍ عَنْ أبِي مالِكٍ في قَوْلِهِ: <span class="qpc-hafs">﴿قَرْنًا﴾</span> قالَ: أُمَّةً.</p></div>"
  23,32,"<div class=ar lang=ar></div>"
  23,33,"<div class=ar lang=ar></div>"
  23,34,"<div class=ar lang=ar></div>"
  23,35,"<div class=ar lang=ar></div>"
  23,36,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿هَيْهاتَ هَيْهاتَ لِما تُوعَدُونَ﴾</span> .</p><p>أخْرَجَ ابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنِ ابْنِ عَبّاسٍ في قَوْلِهِ: <span class="qpc-hafs">﴿هَيْهاتَ هَيْهاتَ﴾</span> قالَ: بَعِيدٌ بَعِيدٌ.</p><p>وأخْرَجَ عَبْدُ الرَّزّاقِ، وعَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنْ قَتادَةَ: ( <span class="qpc-hafs">﴿هَيْهاتَ هَيْهاتَ لِما تُوعَدُونَ﴾</span> ) قالَ: تَباعَدَ ذَلِكَ في أنْفُسِهِمْ؛ يَعْنِي: البَعْثَ بَعْدَ المَوْتِ.</p></div>"
  23,37,"<div class=ar lang=ar></div>"
  23,38,"<div class=ar lang=ar></div>"
  23,39,"<div class=ar lang=ar></div>"
  23,40,"<div class=ar lang=ar></div>"
  23,41,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿فَجَعَلْناهم غُثاءً﴾</span> .</p><p>أخْرَجَ ابْنُ جَرِيرٍ، عَنِ ابْنِ عَبّاسٍ في قَوْلِهِ: <span class="qpc-hafs">﴿فَجَعَلْناهم غُثاءً﴾</span> قالَ: جُعِلُوا (p-٥٨٧)كالشَّيْءِ المَيِّتِ البالِي مِنَ الشَّجَرِ.</p><p>وأخْرَجَ عَبْدُ الرَّزّاقِ، وعَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، عَنْ قَتادَةَ: <span class="qpc-hafs">﴿فَجَعَلْناهم غُثاءً﴾</span> قالَ: هو الشَّيْءُ البالِي.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ عَنْ مُجاهِدٍ: <span class="qpc-hafs">﴿فَجَعَلْناهم غُثاءً﴾</span> قالَ: كالرَّمِيمِ الهامِدِ الَّذِي يَحْتَمِلُ السَّيْلُ؛ ثَمُودُ احْتُمِلُوا كَذَلِكَ.</p></div>"
  23,42,"<div class=ar lang=ar></div>"