quran[9]{c,v,t}:
  30,42,"<div class=ar lang=ar></div>"
  30,43,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿فَأقِمْ وجْهَكَ لِلدِّينِ﴾</span> الآياتِ.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنْ قَتادَةَ: <span class="qpc-hafs">﴿فَأقِمْ وجْهَكَ لِلدِّينِ القَيِّمِ﴾</span> قالَ: الإسْلامِ، <span class="qpc-hafs">﴿مِن قَبْلِ أنْ يَأْتِيَ يَوْمٌ لا مَرَدَّ لَهُ مِنَ اللَّهِ﴾</span> [الشورى: ٤٧] قالَ: يَوْمُ القِيامَةِ، <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span> قالَ: فَرِيقٌ في الجَنَّةِ، وفَرِيقٌ في السَّعِيرِ.</p><p>وأخْرَجَ ابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنِ ابْنِ عَبّاسٍ في قَوْلِهِ: <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span> قالَ: يَتَفَرَّقُونَ.</p><p>وأخْرَجَ ابْنُ جَرِيرٍ، وابْنُ أبِي حاتِمٍ، عَنِ ابْنِ زَيْدٍ في قَوْلِهِ: <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span> قالَ: يَتَفَرَّقُونَ، وقَرَأ: <span class="qpc-hafs">﴿فَأمّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ فَهم في رَوْضَةٍ يُحْبَرُونَ﴾</span> [الروم: ١٥] <span class="qpc-hafs">﴿وأمّا الَّذِينَ كَفَرُوا وكَذَّبُوا بِآياتِنا ولِقاءِ الآخِرَةِ فَأُولَئِكَ في العَذابِ مُحْضَرُونَ﴾</span> [الروم: ١٦] [الرُّومِ: ١٥، ١٦] . قالَ: هَذا حِينَ يَصَّدَّعُونَ، يَتَفَرَّقُونَ إلى الجَنَّةِ وإلى النّارِ.</p><p>وأخْرَجَ الفِرْيابِيُّ، وابْنُ أبِي شَيْبَةَ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، وأبُو نُعَيْمٍ في ”الحِلْيَةِ“، والبَيْهَقِيُّ في ”عَذابِ القَبْرِ“، عَنْ مُجاهِدٍ في قَوْلِهِ: <span class="qpc-hafs">﴿فَلأنْفُسِهِمْ يَمْهَدُونَ﴾</span> قالَ: يُسَوُّونَ المَضاجِعَ في القَبْرِ.</p><p>(p-٦٠٨)وأخْرَجَ الفِرْيابِيُّ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، وابْنُ أبِي حاتِمٍ، عَنْ مُجاهِدٍ في قَوْلِهِ: <span class="qpc-hafs">﴿ومِن آياتِهِ أنْ يُرْسِلَ الرِّياحَ مُبَشِّراتٍ﴾</span> قالَ: بِالمَطَرِ، <span class="qpc-hafs">﴿ولِيُذِيقَكم مِن رَحْمَتِهِ﴾</span> قالَ: المَطَرِ، <span class="qpc-hafs">﴿ولِتَجْرِيَ الفُلْكُ بِأمْرِهِ﴾</span> قالَ: السُّفُنُ في البِحارِ، <span class="qpc-hafs">﴿ولِتَبْتَغُوا مِن فَضْلِهِ﴾</span> قالَ: التِّجارَةِ في السُّفُنِ.</p></div>"
  30,44,"30:43"
  30,45,"30:43"
  30,46,"30:43"
  30,47,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</span> .</p><p>أخْرَجَ ابْنُ أبِي حاتِمٍ، والطَّبَرانِيُّ، وابْنُ مَرْدُوَيْهِ، عَنْ أبِي الدَّرْداءِ قالَ: سَمِعْتُ رَسُولَ اللَّهِ ﷺ يَقُولُ: ««ما مِنِ امْرِئٍ مُسْلِمٍ يَرُدُّ عَنْ عِرْضِ أخِيهِ، إلّا كانَ حَقًّا عَلى اللَّهِ أنْ يَرُدَّ عَنْهُ نارَ جَهَنَّمَ يَوْمَ القِيامَةِ» . ثُمَّ تَلا: «<span class="qpc-hafs">﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</span> [الروم»: ٤٧]» .</p></div>"
  30,48,"<div class=ar lang=ar><p>قَوْلُهُ تَعالى: <span class="qpc-hafs">﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ﴾</span> الآياتِ.</p><p>أخْرَجَ أبُو الشَّيْخِ في ”العَظَمَةِ“ عَنِ السُّدِّيِّ قالَ: يُرْسِلُ اللَّهُ الرِّيحَ فَتَأْتِي بِالسَّحابِ مِن بَيْنِ الخافِقَيْنِ طَرَفَ السَّماءِ والأرْضِ حِينَ يَلْتَقِيانِ، فَتُخْرِجُهُ ثُمَّ تَنْشُرُهُ، فَيَبْسُطُهُ في السَّماءِ كَيْفَ يَشاءُ، فَيَسِيلُ الماءُ عَلى السَّحابِ، ثُمَّ يُمْطِرُ السَّحابُ بَعْدَ ذَلِكَ.</p><p>(p-٦٠٩)وأخْرَجَ ابْنُ أبِي حاتِمٍ عَنِ ابْنِ عَبّاسٍ قالَ: يُرْسِلُ اللَّهُ الرِّيحَ فَتَحْمِلُ الماءَ مِنَ السَّحابِ، فَتَمُرُّ بِهِ السَّحابُ، فَتَدِرُّ كَما تَدِرُّ النّاقَةُ، وثَجّاجٌ مِثْلُ العَزالِي غَيْرَ أنَّهُ مُتَفَرِّقٌ.</p><p>وأخْرَجَ ابْنُ جَرِيرٍ، وابْنُ أبِي حاتِمٍ، عَنْ قَتادَةَ في قَوْلِهِ: <span class="qpc-hafs">﴿فَيَبْسُطُهُ في السَّماءِ﴾</span> قالَ: يَجْمَعُهُ <span class="qpc-hafs">﴿ويَجْعَلُهُ كِسَفًا﴾</span> قالَ: قِطَعًا.</p><p>وأخْرَجَ أبُو يَعْلى، وابْنُ المُنْذِرِ، عَنِ ابْنِ عَبّاسٍ في قَوْلِهِ: <span class="qpc-hafs">﴿ويَجْعَلُهُ كِسَفًا﴾</span> قالَ: قِطَعًا يَجْعَلُ بَعْضَها فَوْقَ بَعْضٍ، <span class="qpc-hafs">﴿فَتَرى الوَدْقَ﴾</span> قالَ: المَطَرَ، <span class="qpc-hafs">﴿يَخْرُجُ مِن خِلالِهِ﴾</span> قالَ: مِن بَيْنِهِ.</p><p>وأخْرَجَ الفِرْيابِيُّ عَنْ مُجاهِدٍ في قَوْلِهِ: <span class="qpc-hafs">﴿فَتَرى الوَدْقَ﴾</span> قالَ: القَطْرَ.</p><p>وأخْرَجَ ابْنُ أبِي حاتِمٍ عَنِ الضَّحّاكِ في قَوْلِهِ: <span class="qpc-hafs">﴿ويَجْعَلُهُ كِسَفًا﴾</span> قالَ: سَماءً دُونَ سَماءٍ. وفي قَوْلِهِ: <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span> قالَ: لَقَنِطِينَ.</p><p>وأخْرَجَ عَبْدُ بْنُ حُمَيْدٍ، وابْنُ جَرِيرٍ، وابْنُ المُنْذِرِ، عَنْ قَتادَةَ في قَوْلِهِ: <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span> قالَ: لَقَنِطِينَ.</p><p>(p-٦١٠)</p></div>"
  30,49,"30:48"
  30,50,"<div class=ar lang=ar></div>"