tafsir[13]{c,v,t}:
  55,18,"Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?"
  55,21,"Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?"
  55,22,"Iz ova dva mora vade se veliki i mali biseri."
  55,23,"Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?"
  55,24,"Samo On jedini upravlja lađama koje morem plove poput planina."
  55,25,"Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?"
