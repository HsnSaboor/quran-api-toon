tafsir[11]{c,v,t}:
  80,1,"[انظر الآية ١٥ من النازعات]"
  80,2,"[انظر الآية ١٥ من النازعات]"
  80,3,"[انظر الآية ١٥ من النازعات]"
  80,4,"[انظر الآية ١٥ من النازعات](واخْتَلَفُوا) فِي: ﴿فَتَنْفَعَهُ﴾ فَقَرَأ عاصِمٌ بِنَصْبِ العَيْنِ، وقَرَأ الباقُونَ بِرَفْعِها."
  80,5,"[انظر الآية ١٥ من النازعات]"
  80,6,"[انظر الآية ١٥ من النازعات](واخْتَلَفُوا) فِي: ﴿لَهُ تَصَدّى﴾ فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ بِتَشْدِيدِ الصادِ، وقَرَأ الباقُونَ بِتَخْفِيفِها"
  80,7,"[انظر الآية ١٥ من النازعات]"
  80,8,"[انظر الآية ١٥ من النازعات]"
  80,9,"[انظر الآية ١٥ من النازعات]"
  80,10,"[انظر الآية ١٥ من النازعات]وَتَقَدَّمَ ﴿عَنْهُ تَّلَهّى﴾ في تاءاتِ البَزِّيِّ مِنَ البَقَرَةِ."
  80,25,"(واخْتَلَفُوا) فِي: ﴿أنّا صَبَبْنا﴾ فَقَرَأ الكُوفِيُّونَ بِفَتْحِ الهَمْزَةِ، وافَقَهم رُوَيْسٌ وصْلًا، وقَرَأ الباقُونَ بِكَسْرِ الهَمْزَةِ، ووافَقَهم رُوَيْسٌ في الِابْتِداءِ، وانْفَرَدَ ابْنُ مِهْرانَ عَنْ هِبَةِ اللَهِ عَنِ التَمّارِ عَنْهُ بِالكَسْرِ في الحالَيْنِ."
