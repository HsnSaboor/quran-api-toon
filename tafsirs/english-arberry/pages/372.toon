tafsir[6]{c,v,t}:
  26,114,"I would not drive away the believers;"
  26,115,"'I am naught but a plain warner.'"
  26,120,"then afterwards We drowned the rest."
  26,123,"Ad cried lies to the Envoys"
  26,127,"I ask of you no wage for this; my wage falls only upon the Lord of all Being."
  26,134,"gardens and fountains."