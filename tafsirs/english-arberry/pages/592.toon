tafsir[13]{c,v,t}:
  87,19,"the scrolls of Abraham and Moses."
  88,1,"Hast thou received the story of the Enveloper?"
  88,6,"no food for them but cactus thorn"
  88,11,"hearing there no babble;"
  88,13,"therein uplifted couches"
  88,14,"and goblets set forth"
  88,15,"and cushions arrayed"
  88,16,"and carpets outspread."
  88,20,"how the earth was outstretched?"
  88,21,"Then remind them! Thou art only a reminder;"
  88,22,"thou art not charged to oversee them."
  88,24,"God shall chastise him with the greatest chastisement."
  88,26,"then upon Us shall rest their reckoning."