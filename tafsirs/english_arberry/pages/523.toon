tafsir[12]{c,v,t}:
  51,54,"So turn thou from them; thou wilt not be reproached."
  51,55,"And remind; the Reminder profits the believers."
  51,56,"I have not created jinn and mankind except to serve Me."
  52,1,"By the Mount"
  52,2,"and a Book inscribed"
  52,4,"by the House inhabited"
  52,5,"and the roof uplifted"
  52,7,"surely thy Lord's chastisement is about to fall;"
  52,8,"there is none to avert it."
  52,9,"Upon the day when heaven spins dizzily"
  52,13,"the day when they shall be pitched into the fire of Gehenna:"
  52,14,"'This is the fire that you cried lies to!"