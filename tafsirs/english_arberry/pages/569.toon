tafsir[10]{c,v,t}:
  70,18,"who amassed and hoarded."
  70,22,"save those that pray"
  70,24,"those in whose wealth is a right known"
  70,26,"who confirm the Day of Doom"
  70,27,"and go in fear of the chastisement of their Lord"
  70,28,"(from their Lord's chastisement none feels secure)"
  70,29,"and guard their private parts"
  70,34,"and who observe their prayers."
  70,37,"towards thee on the right hand and on the left hand in knots?"
  70,39,"Not so; for We have created them of what they know."