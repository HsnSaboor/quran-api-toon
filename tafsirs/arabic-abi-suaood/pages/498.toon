quran[20]{c,v,t}:
  44,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ يَوْمَ الفَصْلِ﴾</span> أيْ: فَصْلِ الحَقِّ عَنِ الباطِلِ وتَمْيِيزِ المُحِقِّ مِنَ المُبْطِلِ أوْ فَصْلِ الرَّجُلِ عَنْ أقارِبِهِ وأحِبّائِهِ.</p><p><span class="qpc-hafs">﴿مِيقاتُهُمْ﴾</span> وقْتَ مَوْعِدِهِمْ.</p><p><span class="qpc-hafs">﴿أجْمَعِينَ﴾</span> وقُرِئَ "مِيقاتَهُمْ" بِالنَّصْبِ عَلى أنَّهُ اسْمٌ إنَّ و"يَوْمَ الفَصْلِ" خَبَرُها أيْ: إنَّ مِيعادَ حِسابِهِمْ وجَزاءَهم في يَوْمِ الفَصْلِ.</p></div>"
  44,41,"<div class=ar lang=ar><p>(p-65)<span class="qpc-hafs">﴿يَوْمَ لا يُغْنِي﴾</span> بَدَلٌ مِن "يَوْمِ الفَصْلِ" أوْ صِفَةٌ لِـ"مِيقاتُهُمْ" أوْ ظَرْفٌ لِما دَلَّ عَلَيْهِ الفَصْلُ لا لِنَفْسِهِ.</p><p><span class="qpc-hafs">﴿مَوْلًى﴾</span> مِن قَرابَةٍ أوْ غَيْرِها.</p><p><span class="qpc-hafs">﴿عَنْ مَوْلًى﴾</span> أيَّ مَوْلًى كانَ.</p><p><span class="qpc-hafs">﴿شَيْئًا﴾</span> أيْ: شَيْئًا مِنَ الإغْناءِ.</p><p><span class="qpc-hafs">﴿وَلا هم يُنْصَرُونَ﴾</span> الضَّمِيرُ لِـ"مَوْلًى" الأوَّلُ بِاعْتِبارِ المَعْنى لِأنَّهُ عامٌّ.</p></div>"
  44,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إلا مَن رَحِمَ اللَّهُ﴾</span> بِالعَفْوِ عَنْهُ وقَبُولِ الشَّفاعَةِ في حَقِّهِ، ومَحَلُّهُ الرَّفْعُ عَلى البَدَلِ مِنَ الواوِ أوِ النَّصْبُ عَلى الِاسْتِثْناءِ.</p><p><span class="qpc-hafs">﴿إنَّهُ هو العَزِيزُ﴾</span> الَّذِي لا يُنَصَرُ مَن أرادَ تَعْذِيبَهُ.</p><p><span class="qpc-hafs">﴿الرَّحِيمُ﴾</span> لِمَن أرادَ أنْ يَرْحَمَهُ.</p></div>"
  44,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</span> وقُرِئَ بِكَسْرِ الشِّينِ وقَدْ مَرَّ مَعْنى الزَّقُّومِ في سُورَةِ الصّافّاتِ.</p></div>"
  44,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿طَعامُ الأثِيمِ﴾</span> أيِ: الكَثِيرُ الآثامِ، والمُرادُ بِهِ: الكافِرُ لِدَلالَةِ ما قَبْلَهُ وما بَعْدَهُ عَلَيْهِ.</p></div>"
  44,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كالمُهْلِ﴾</span> وهو ما يُمْهَلُ في النّارِ حَتّى يَذُوبَ، وقِيلَ: هو دُرْدِيُّ الزَّيْتِ.</p><p><span class="qpc-hafs">﴿يَغْلِي في البُطُونِ﴾</span> وقُرِئَ بِالتّاءِ عَلى إسْنادِ الفِعْلِ إلى الشَّجَرَةِ.</p></div>"
  44,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَغَلْيِ الحَمِيمِ﴾</span> غَلَيانًا كَغَلْيِهِ.</p></div>"
  44,47,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿خُذُوهُ﴾</span> عَلى إرادَةِ القَوْلِ والخِطابُ لِلزَّبانِيَةِ.</p><p><span class="qpc-hafs">﴿فاعْتِلُوهُ﴾</span> أيْ: جُرُّوهُ والعَتْلُ: الأخْذُ بِمَجامِعِ الشَّيْءِ وجَرُّهُ بِقَهْرٍ وعُنْفٍ، وقُرِئَ بِضَمِ التّاءِ وهي لُغَةٌ فِيهِ.</p><p><span class="qpc-hafs">﴿إلى سَواءِ الجحيم﴾</span> أيْ: وسَطِهِ.</p></div>"
  44,48,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ مِن عَذابِ الحَمِيمِ﴾</span> كانَ الأصْلُ يُصَبُّ مِن فَوْقِ رُؤُوسِهِمُ الحَمِيمُ، فَقِيلَ: يُصَبُّ مِن فَوْقِ رُؤُوسِهِمْ عَذابٌ هو الحَمِيمُ لِلْمُبالَغَةِ ثُمَّ أُضِيفَ العَذابُ إلى الحَمِيمِ لِلتَّخْفِيفِ وزِيدَ مِن لِلدَّلالَةِ عَلى أنَّ المَصْبُوبَ بَعْضُ هَذا النَّوْعِ.</p></div>"
  44,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span> أيْ: وقُولُوا لَهُ ذَلِكَ اسْتِهْزاءً بِهِ وتَقْرِيعًا لَهُ عَلى ما كانَ يَزْعُمُهُ. رُوِيَ أنَّ أبا جَهْلٍ قالَ لِرَسُولِ اللَّهِ ﷺ: ما بَيْنَ جَبَلَيْها أعَزُّ ولا أكْرَمُ مِنِّي فَواللَّهِ ما تَسْتَطِيعُ أنْتَ ولا رَبُّكَ أنْ تَفْعَلا بِي شَيْئًا. وقُرِئَ بِالفَتْحِ أيْ: لِأنَّكَ أوْ عَذابُ أنَّكَ.</p></div>"
  44,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ هَذا﴾</span> أيِ: العَذابَ.</p><p><span class="qpc-hafs">﴿ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</span> تَشُكُّونَ وتُمارُونَ فِيهِ والجَمْعُ بِاعْتِبارِ المَعْنى لِأنَّ (p-66)المُرادَ جِنْسُ الأثِيمِ.</p></div>"
  44,51,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنَّ المُتَّقِينَ﴾</span> أيْ: عَنِ الكُفْرِ والمَعاصِي.</p><p><span class="qpc-hafs">﴿فِي مَقامٍ﴾</span> في مَوْضِعِ قِيامٍ، والمُرادُ: المَكانُ عَلى الإطْلاقِ فَإنَّهُ مِنَ الخاصِّ الَّذِي شاعَ اسْتِعْمالُهُ في مَعْنى العُمُومِ، وقُرِئَ بِضَمِّ المِيمِ وهو مَوْضِعُ إقامَةٍ.</p><p><span class="qpc-hafs">﴿أمِينٍ﴾</span> يَأْمَنُ صاحِبُهُ الآفاتِ والِانْتِقالَ عَنْهُ وهو مِنَ الأمْنِ الَّذِي هو ضِدُّ الخِيانَةِ وُصِفَ بِهِ المَكانُ بِطَرِيقِ الِاسْتِعارَةِ كَأنَّ المَكانَ المُخِيفَ يَخُونُ صاحِبَهُ لِما يَلْقى فِيهِ مِنَ المَكارِهِ.</p></div>"
  44,52,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فِي جَنّاتٍ وعُيُونٍ﴾</span> بَدَلٌ مِن مَقامٍ جِيءَ بِهِ دَلالَةً عَلى نَزاهَتِهِ واشْتِمالِهِ عَلى طَيِّباتِ المَآكِلِ والمَشارِبِ.</p></div>"
  44,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَلْبَسُونَ مِن سُنْدُسٍ وإسْتَبْرَقٍ﴾</span> إمّا خَبَرٌ ثانٍ أوْ حالٌ مِنَ الضَّمِيرِ في الجارِّ أوِ اسْتِئْنافٌ والسُّنْدُسُ: ما رَقَّ مِنَ الحَرِيرِ، والإسْتَبْرَقُ: ما غَلُظَ مِنهُ مُعَرَّبٌ.</p><p><span class="qpc-hafs">﴿مُتَقابِلِينَ﴾</span> في المَجالِسِ لِيَسْتَأْنِسَ بَعْضُهم بِبَعْضٍ.</p></div>"
  44,54,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَذَلِكَ﴾</span> أيِ: الأمْرُ كَذَلِكَ أوْ كَذَلِكَ أثَبْناهم.</p><p><span class="qpc-hafs">﴿وَزَوَّجْناهم بِحُورٍ عِينٍ﴾</span> عَلى الوَصْفِ، وقُرِئَ بِالإضافَةِ أيْ: قَرَنّاهم بِهِنَّ، والحُورُ: جَمْعُ الحَوْراءِ وهي البَيْضاءُ، والعِينُ: جَمْعُ العَيْناءِ وهي العَظِيمَةُ العَيْنَيْنِ واخْتُلِفَ في أنَّهُنَّ نِساءُ الدُّنْيا أوْ غَيْرُها.</p></div>"
  44,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ﴾</span> أيْ: يَطْلُبُونَ ويَأْمُرُونَ بِإحْضارِ ما يَشْتَهُونَهُ مِنَ الفَواكِهِ لا يَتَخَصَّصُ شَيْءٌ مِنها بِمَكانٍ ولا زَمانٍ.</p><p><span class="qpc-hafs">﴿آمِنِينَ﴾</span> مِن كُلِّ ما يَسُوؤُهم.</p></div>"
  44,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها المَوْتَ إلا المَوْتَةَ الأُولى﴾</span> بَلْ يَسْتَمِرُّونَ عَلى الحَياةِ أبَدًا والِاسْتِثْناءُ مُنْقَطِعٌ أوْ مُتَّصِلٌ عَلى أنَّ المُرادَ: بَيانُ اسْتِحالَةِ ذَوْقِ المَوْتِ فِيها عَلى الإطْلاقِ كَأنَّهُ قِيلَ: لا يَذُوقُونَ فِيها المَوْتَ إلّا إذا أمْكَنَ ذَوْقُ المَوْتَةِ الأُولى حِينَئِذٍ.</p><p><span class="qpc-hafs">﴿وَوَقاهم عَذابَ الجحيم﴾</span> وقُرِئَ مُشَدَّدًا لِلْمُبالَغَةِ في الوِقايَةِ.</p></div>"
  44,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَضْلا مِن رَبِّكَ﴾</span> أيْ: أُعْطُوا ذَلِكَ كُلَّهُ عَطاءً وتَفْضِيلًا مِنهُ تَعالى، وقُرِئَ بِالرَّفْعِ أيْ: ذَلِكَ فَضْلٌ.</p><p><span class="qpc-hafs">﴿ذَلِكَ هو الفَوْزُ العَظِيمُ﴾</span> الَّذِي لا فَوْزَ وراءَهُ إذْ هو خَلاصٌ عَنْ جَمِيعِ المَكارِهِ ونِيلٌ لِكُلِّ المَطالِبِ.</p></div>"
  44,58,"<div class=ar lang=ar><p>وَقَوْلُهُ تَعالى: <span class="qpc-hafs">﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ لَعَلَّهم يَتَذَكَّرُونَ﴾</span> فَذْلَكَةٌ لِلسُّورَةِ الكَرِيمَةِ أيْ: إنَّما أنْزَلْنا الكِتابَ المُبِينَ بِلُغَتِكَ كىْ يَفْهَمَهُ قَوْمُكَ ويَتَذَكَّرُوا ويَعْمَلُوا بِمُوجِبِهِ وإذا لَمْ يَفْعَلُوا ذَلِكَ</p></div>"
  44,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فارْتَقِبْ﴾</span> (p-67)فانْتَظِرْ ما يَحُلُّ بِهِمْ.</p><p><span class="qpc-hafs">﴿إنَّهم مُرْتَقِبُونَ﴾</span> ما يَحُلُّ بِكَ. رُوِيَ عَنِ النَّبِيِّ ﷺ « "مَن قَرَأ "حَم" الدُّخانَ لَيْلَةَ الجُمْعَةِ أصْبَحَ مَغْفُورًا لَهُ".»</p></div>"