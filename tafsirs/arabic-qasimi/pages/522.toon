quran[21]{c,v,t}:
  51,31,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٣١ - ٣٧] <span class="qpc-hafs">﴿قالَ فَما خَطْبُكم أيُّها المُرْسَلُونَ﴾</span> <span class="qpc-hafs">﴿قالُوا إنّا أُرْسِلْنا إلى قَوْمٍ مُجْرِمِينَ﴾</span> [الذاريات: ٣٢] <span class="qpc-hafs">﴿لِنُرْسِلَ عَلَيْهِمْ حِجارَةً مِن طِينٍ﴾</span> [الذاريات: ٣٣] <span class="qpc-hafs">﴿مُسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span> [الذاريات: ٣٤] <span class="qpc-hafs">﴿فَأخْرَجْنا مَن كانَ فِيها مِنَ المُؤْمِنِينَ﴾</span> [الذاريات: ٣٥] <span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span> [الذاريات: ٣٦] <span class="qpc-hafs">﴿وتَرَكْنا فِيها آيَةً لِلَّذِينَ يَخافُونَ العَذابَ الألِيمَ﴾</span> [الذاريات: ٣٧]</p><p><span class="qpc-hafs">﴿قالَ﴾</span> أيْ: إبْراهِيمُ لِضَيْفِهِ <span class="qpc-hafs">﴿فَما خَطْبُكُمْ﴾</span> أيْ: أمْرُكم وشَأْنُكم <span class="qpc-hafs">﴿أيُّها المُرْسَلُونَ﴾</span> <span class="qpc-hafs">﴿قالُوا إنّا أُرْسِلْنا إلى قَوْمٍ مُجْرِمِينَ﴾</span> [الذاريات: ٣٢] أيْ: مُؤاخَذَتُهُمْ؛ <span class="qpc-hafs">﴿لِنُرْسِلَ عَلَيْهِمْ حِجارَةً مِن طِينٍ﴾</span> [الذاريات: ٣٣] أيْ: رَجْمًا عَلى فِعْلِهِمُ الفاحِشَةَ.</p><p><span class="qpc-hafs">﴿مُسَوَّمَةً﴾</span> [الذاريات: ٣٤] أيْ: مُرْسَلَةً، أوْ مُعَلَّمَةً <span class="qpc-hafs">﴿عِنْدَ رَبِّكَ لِلْمُسْرِفِينَ﴾</span> [الذاريات: ٣٤] أيِ: المُتَعَدِّينَ حُدُودَ اللَّهِ، الكافِرِينَ بِهِ.</p><p><span class="qpc-hafs">﴿فَأخْرَجْنا مَن كانَ فِيها﴾</span> [الذاريات: ٣٥] أيْ: في تِلْكَ القَرْيَةِ مِنَ المُؤْمِنِينَ أيْ: بِإيحاءِ الخُرُوجِ إلَيْهِمْ عَلى لِسانِ المَلائِكَةِ، وهم لُوطٌ وابْنَتاهُ عَلَيْهِمُ السَّلامُ.</p><p><span class="qpc-hafs">﴿فَما وجَدْنا فِيها غَيْرَ بَيْتٍ مِنَ المُسْلِمِينَ﴾</span> [الذاريات: ٣٦] يَعْنِي بَيْتَ قَوْمِ لُوطٍ عَلَيْهِ السَّلامُ.</p><p><span class="qpc-hafs">﴿وتَرَكْنا فِيها﴾</span> [الذاريات: ٣٧] أيْ: في تِلْكَ القَرْيَةِ <span class="qpc-hafs">﴿آيَةً﴾</span> [الذاريات: ٣٧] أيْ: عَلامَةً تَدُلُّ عَلى إهْلاكِهِمُ الدُّنْيَوِيِّ الدّالِّ عَلى الأُخْرَوِيِّ <span class="qpc-hafs">﴿لِلَّذِينَ يَخافُونَ العَذابَ الألِيمَ﴾</span> [الذاريات: ٣٧] أيْ: في الآخِرَةِ، وقَوْلُهُ تَعالى:</p><p>(p-٥٥٣٣)</p></div>"
  51,32,""
  51,33,""
