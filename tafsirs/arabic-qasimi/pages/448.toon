quran[25]{c,v,t}:
  37,52,"37:51"
  37,53,"37:51"
  37,54,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٤ ] <span class="qpc-hafs">﴿قالَ هَلْ أنْتُمْ مُطَّلِعُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿قالَ﴾</span> أيْ: ذَلِكَ اَلْقائِلُ: <span class="qpc-hafs">﴿هَلْ أنْتُمْ مُطَّلِعُونَ﴾</span> أيْ: إلى أهْلِ اَلنّارِ مِن كُوى اَلْجَنَّةِ، ومَطالِّها، لِأُرِيَكم ذَلِكَ اَلْقَرِينَ.</p></div>"
  37,55,"<div class=ar lang=ar><p>(p-٥٠٣٩)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٥ - ٥٧ ] <span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ في سَواءِ الجَحِيمِ﴾</span> <span class="qpc-hafs">﴿قالَ تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span> [الصافات: ٥٦] <span class="qpc-hafs">﴿ولَوْلا نِعْمَةُ رَبِّي لَكُنْتُ مِنَ المُحْضَرِينَ﴾</span> [الصافات: ٥٧] .</p><p><span class="qpc-hafs">﴿فاطَّلَعَ فَرَآهُ في سَواءِ الجَحِيمِ﴾</span> أيْ: في وسَطِهِ: <span class="qpc-hafs">﴿قالَ تاللَّهِ إنْ كِدْتَ لَتُرْدِينِ﴾</span> [الصافات: ٥٦] أيْ: لَتُهْلِكُنِي بِالإغْواءِ: <span class="qpc-hafs">﴿ولَوْلا نِعْمَةُ رَبِّي﴾</span> [الصافات: ٥٧] أيْ: بِالهِدايَةِ، واللُّطْفِ بِي: <span class="qpc-hafs">﴿لَكُنْتُ مِنَ المُحْضَرِينَ﴾</span> [الصافات: ٥٧] أيْ: مَعَكَ في اَلنّارِ. وقَوْلُهُ:</p></div>"
  37,56,"37:55"
  37,57,"37:55"
  37,58,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٨، ٥٩ ] <span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ﴾</span> <span class="qpc-hafs">﴿إلا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ﴾</span> [الصافات: ٥٩] .</p><p><span class="qpc-hafs">﴿أفَما نَحْنُ بِمَيِّتِينَ﴾</span> <span class="qpc-hafs">﴿إلا مَوْتَتَنا الأُولى وما نَحْنُ بِمُعَذَّبِينَ﴾</span> [الصافات: ٥٩] مِن تَتِمَّةِ كَلامِهِ لِقَرِينِهِ، تَقْرِيعًا لَهُ، أوْ مُعاوَدَةً عَلى مُحادَثَةِ جُلَسائِهِ، تَحَدُّثًا بِنِعْمَةِ اَللَّهِ تَعالى.</p></div>"
  37,59,"37:58"
  37,60,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٦٠، ٦١ ] <span class="qpc-hafs">﴿إنَّ هَذا لَهو الفَوْزُ العَظِيمُ﴾</span> <span class="qpc-hafs">﴿لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</span> [الصافات: ٦١] .</p><p><span class="qpc-hafs">﴿إنَّ هَذا لَهو الفَوْزُ العَظِيمُ﴾</span> <span class="qpc-hafs">﴿لِمِثْلِ هَذا فَلْيَعْمَلِ العامِلُونَ﴾</span> [الصافات: ٦١] أيْ: لِنَيْلِ مِثْلِهِ، فَلْيُجِدَّ اَلْمُجِدُّونَ، ولَمّا وصَفَ مَلاذَّ أهْلِ اَلْجَنَّةِ، تَأثَّرَهُ بِمَطاعِمِ أهْلِ اَلنّارِ، بِقَوْلِهِ سُبْحانَهُ:</p></div>"
  37,61,"37:60"
  37,62,"<div class=ar lang=ar><p>(p-٥٠٤٠)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٦٢ ] <span class="qpc-hafs">﴿أذَلِكَ خَيْرٌ نُـزُلا أمْ شَجَرَةُ الزَّقُّومِ﴾</span> .</p><p><span class="qpc-hafs">﴿أذَلِكَ خَيْرٌ نُـزُلا أمْ شَجَرَةُ الزَّقُّومِ﴾</span> وهي شَجَرَةٌ كَرِيهَةُ اَلْمَنظَرِ والطَّعْمِ، كَما سَتُذْكَرُ صِفَتُها.</p></div>"
  37,63,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٦٣ - ٦٥ ] <span class="qpc-hafs">﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</span> <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ في أصْلِ الجَحِيمِ﴾</span> [الصافات: ٦٤] <span class="qpc-hafs">﴿طَلْعُها كَأنَّهُ رُءُوسُ الشَّياطِينِ﴾</span> [الصافات: ٦٥] .</p><p><span class="qpc-hafs">﴿إنّا جَعَلْناها فِتْنَةً﴾</span> أيْ: مِحْنَةً وعَذابًا: <span class="qpc-hafs">﴿لِلظّالِمِينَ﴾</span> <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ في أصْلِ الجَحِيمِ﴾</span> [الصافات: ٦٤] <span class="qpc-hafs">﴿طَلْعُها﴾</span> [الصافات: ٦٥] أيْ: حَمْلُها: <span class="qpc-hafs">﴿كَأنَّهُ رُءُوسُ الشَّياطِينِ﴾</span> [الصافات: ٦٥] أيْ: مِثْلُ ما يُتَخَيَّلُ ويُتَوَهَّمُ مِن قُبْحِ رُؤُوسِ اَلشَّياطِينِ، فَهي قَبِيحَةُ اَلْأصْلِ، والثَّمَرِ، والمَنظَرِ، والمَلْمَسِ. قالَ اَلزَّمَخْشَرِيُّ: وشُبِّهَ بِرُؤُوسِ اَلشَّياطِينِ دَلالَةً عَلى تَناهِيهِ في اَلْكَراهِيَةِ، وقُبْحِ اَلْمَنظَرِ؛ لِأنَّ اَلشَّيْطانَ مَكْرُوهٌ مُسْتَقْبَحٌ في طِباعِ اَلنّاسِ، لِاعْتِقادِهِمْ أنَّهُ شَرٌّ مَحْضٌ لا يَخْلِطُهُ خَيْرٌ، فَيَقُولُونَ في اَلْقَبِيحِ اَلصُّورَةِ: (كَأنَّهُ وجْهُ شَيْطانٍ)، ( كَأنَّهُ رَأْسُ شَيْطانٍ). وإذا صَوَّرَهُ اَلْمُصَوِّرُونَ جاءُوا بِصُورَتِهِ عَلى أقْبَحِ ما يُقَدَّرُ، وأهْوَلِهِ. كَما أنَّهُمُ اِعْتَقَدُوا في اَلْمَلَكِ أنَّهُ خَيْرٌ مَحْضٌ لا شَرَّ فِيهِ. فَشَبَّهُوا بِهِ اَلصُّورَةَ اَلْحَسَنَةَ. قالَ اللَّهُ تَعالى: <span class="qpc-hafs">﴿ما هَذا بَشَرًا إنْ هَذا إلا مَلَكٌ كَرِيمٌ﴾</span> [يوسف: ٣١] وهَذا تَشْبِيهٌ تَخْيِيلِيٌّ. اِنْتَهى. أيْ: لِأمْرٍ مَرْكُوزٍ في اَلْخَيالِ. وبِهِ يَنْدَفِعُ ما يُقالُ إنَّهُ تَشْبِيهٌ بِما لا يُعْرَفُ، وذَلِكَ لِأنَّهُ لا يُشْتَرَطُ أنْ يَكُونَ مَعْرُوفًا في اَلْخارِجِ. بَلْ يَكْفِي كَوْنُهُ مَرْكُوزًا في اَلذِّهْنِ والخَيالِ (p-٥٠٤١)، ألا تَرى اِمْرَأ اَلْقَيْسِ - وهو مَلِكُ اَلشُّعَراءِ - يَقُولُ:</p><p>؎ومَسْنُونَةٌ زُرْقٌ كَأنْيابِ أغْوالِ</p><p>وهُوَ لَمْ يَرَ اَلْغُولَ، والغُولُ نَوْعٌ مِنَ اَلشَّياطِينِ؛ لِأنَّهُ في خَيالِ كُلِّ أحَدٍ مُرْتَسِمٌ بِصُورَةٍ قَبِيحَةٍ، وإنْ كانَ قابِلًا لِلتَّشَكُّلِ.</p></div>"
  37,64,"37:63"
  37,65,"37:63"
  37,66,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٦٦ ] <span class="qpc-hafs">﴿فَإنَّهم لآكِلُونَ مِنها فَمالِئُونَ مِنها البُطُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿فَإنَّهم لآكِلُونَ مِنها﴾</span> أيْ: مِن طَلْعِها: <span class="qpc-hafs">﴿فَمالِئُونَ مِنها البُطُونَ﴾</span> أيْ: لِغَلَبَةِ اَلْجُوعِ، أوِ اَلْإكْراهِ عَلى أكْلِها.</p></div>"
  37,67,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٦٧ ] <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهم عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span> .</p><p><span class="qpc-hafs">﴿ثُمَّ إنَّ لَهم عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span> أيْ: لَشَرابًا كالصَّدِيدِ، أوِ اَلْغَسّاقِ، مَمْزُوجًا مِن ماءٍ مُتَناهٍ في اَلْحَرارَةِ، يُقَطِّعُ أمْعاءَهم.</p></div>"
  37,68,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٦٨ ] <span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهم لإلى الجَحِيمِ﴾</span> .</p><p><span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهُمْ﴾</span> أيْ: مَصِيرَهُمْ: <span class="qpc-hafs">﴿لإلى الجَحِيمِ﴾</span> أيْ: إلى دَرَكاتِها، أوْ إلى نَفْسِها (p-٥٠٤٢)لا مَفَرَّ لَهم ولا مَحِيصَ كَيْفَما تَحَوَّلُوا. قالَ اِبْنُ كَثِيرٍ: أيْ: ثُمَّ إنَّ مَرَدَّهم بَعْدَ هَذا اَلْفَصْلِ لَإلى نارٍ تَتَأجَّجُ وسَعِيرٍ تَتَوَهَّجُ، فَتارَةً في هَذا، وتارَةً في هَذا. كَما قالَ تَعالى: <span class="qpc-hafs">﴿يَطُوفُونَ بَيْنَها وبَيْنَ حَمِيمٍ آنٍ﴾</span> [الرحمن: ٤٤] هَكَذا تَلا قَتادَةُ هَذِهِ اَلْآيَةَ عِنْدَ هَذِهِ اَلْآيَةِ. وهو تَفْسِيرٌ حَسَنٌ قَوِيٌّ. اِنْتَهى.</p><p>ومِن لَطائِفِ اَلْإشاراتِ في هَذِهِ اَلْآيَةِ، ما قالَهُ اَلْقاشانِيُّ، وعِبارَتُهُ: <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ في أصْلِ الجَحِيمِ﴾</span> [الصافات: ٦٤] وهي شَجَرَةُ اَلنَّفْسِ اَلْخَبِيثَةِ اَلْمَحْجُوبَةُ اَلنّابِتَةُ في قَعْرِ جَهَنَّمَ اَلْمُتَشَعِّبَةُ أغْصانُها في دَرَكاتِها اَلْقَبِيحَةِ اَلْهائِلَةُ ثَمَراتُها مِنَ اَلرَّذائِلِ والخَبائِثِ، كَأنَّها مِن غايَةِ اَلْقُبْحِ والتَّشَوُّهِ والخُبْثِ بِالتَّنَفُّرِ: <span class="qpc-hafs">﴿رُءُوسُ الشَّياطِينِ﴾</span> [الصافات: ٦٥] أيْ: تَنْشَأُ مِنها اَلدَّواعِي اَلْمُهْلِكَةُ، والنَّوازِعُ اَلْمُرْدِيَةُ اَلْباعِثَةُ عَلى اَلْأفْعالِ اَلْقَبِيحَةِ، والأعْمالِ اَلسَّيِّئَةِ، فَتِلْكَ أُصُولُ اَلشَّيْطَنَةِ، ومَبادِئُ اَلشَّرِّ والمَفْسَدَةِ، فَكانَتْ رُؤُوسَ اَلشَّياطِينِ: <span class="qpc-hafs">﴿فَإنَّهم لآكِلُونَ مِنها﴾</span> [الصافات: ٦٦] يَسْتَمِدُّونَ مِنها ويَتَغَذَّوْنَ ويَتَقَوَّوْنَ، فَإنَّ اَلْأشْرارَ غِذاؤُهم مِنَ اَلشُّرُورِ، ولا يَتَلَذَّذُونَ إلّا بِها: <span class="qpc-hafs">﴿فَمالِئُونَ مِنها البُطُونَ﴾</span> [الصافات: ٦٦] بِالهَيْئاتِ اَلْفاسِقَةِ، والصِّفاتِ اَلْمُظْلِمَةِ، كالمُمْتَلِئِ غَضَبًا، وحِقْدًا، وحَسَدًا، وقْتَ هَيَجانِها: <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهم عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span> [الصافات: ٦٧] اَلْأهْواءِ اَلطَّبِيعِيَّةِ، والمُنى اَلسَّيِّئَةِ اَلرَّدِيئَةِ، ومُحِبّاتِ اَلْأُمُورِ اَلسُّفْلِيَّةِ، وقُصُورِ اَلشُّرُورِ اَلْمُوبِقَةِ، اَلَّتِي تَكْسِرُ بَعْضَ غَلَّةِ اَلْأشْرارِ: <span class="qpc-hafs">﴿ثُمَّ إنَّ مَرْجِعَهم لإلى الجَحِيمِ﴾</span> لِغَلَبَةِ اَلْحِرْصِ والشَّرَهِ، بِالشَّهْوَةِ، والحِقْدِ، والبُغْضِ وأمْثالِها، واسْتِيلاءِ دَواعِيها مَعَ اِمْتِناعِ حُصُولِ مَباغِيها. اِنْتَهى.</p><p>وهَذِهِ اَلْإشاراتُ مِنَ اَلْمَجازاتِ اَلَّتِي تَتَّسِعُ لَها اَللُّغَةُ؛ لِأنَّها لا تَنْحَصِرُ في اَلْحَقِيقَةِ، ولا يُقالُ إنَّها اَلْمُرادَةُ هُنا، لِنُبُوِّها عَنْ نَظائِرِها مِن آياتِ اَلْوَعِيدِ، واللَّهُ أعْلَمُ.</p><p>وقَوْلُهُ تَعالى:</p></div>"
  37,69,"<div class=ar lang=ar><p>(p-٥٠٤٣)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٦٩، ٧٠ ] <span class="qpc-hafs">﴿إنَّهم ألْفَوْا آباءَهم ضالِّينَ﴾</span> <span class="qpc-hafs">﴿فَهم عَلى آثارِهِمْ يُهْرَعُونَ﴾</span> [الصافات: ٧٠] .</p><p><span class="qpc-hafs">﴿إنَّهم ألْفَوْا آباءَهم ضالِّينَ﴾</span> <span class="qpc-hafs">﴿فَهم عَلى آثارِهِمْ يُهْرَعُونَ﴾</span> [الصافات: ٧٠] تَعْلِيلٌ لِاسْتِحْقاقِهِمْ تِلْكَ اَلشَّدائِدَ بِتَقْلِيدِ اَلْآباءِ في اَلضَّلالِ. (والإهْراعُ): اَلْإسْراعُ اَلشَّدِيدُ كَأنَّهم يُزْعَجُونَ عَلى اَلْإسْراعِ عَلى آثارِهِمْ، وفِيهِ إشْعارٌ بِأنَّهم بادَرُوا إلى ذَلِكَ مِن غَيْرِ نَظَرٍ وبَحْثٍ، بَلْ مُجَرَّدُ تَقْلِيدٍ وتَرْكِ اِتِّباعِ دَلِيلٍ. قالَ الرّازِيُّ: ولَوْ لَمْ يُوجَدْ في اَلْقُرْآنِ آيَةٌ غَيْرُ هَذِهِ اَلْآيَةِ في ذَمِّ اَلتَّقْلِيدِ، لَكَفى.</p></div>"
  37,70,"37:69"
  37,71,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٧١، ٧٢ ] <span class="qpc-hafs">﴿ولَقَدْ ضَلَّ قَبْلَهم أكْثَرُ الأوَّلِينَ﴾</span> <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا فِيهِمْ مُنْذِرِينَ﴾</span> [الصافات: ٧٢] .</p><p><span class="qpc-hafs">﴿ولَقَدْ ضَلَّ قَبْلَهم أكْثَرُ الأوَّلِينَ﴾</span> <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا فِيهِمْ مُنْذِرِينَ﴾</span> [الصافات: ٧٢] أيْ: أنْبِياءَ حَذَّرُوهُمُ اَلْعَواقِبَ.</p></div>"
  37,72,"37:71"
  37,73,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٧٣ ] <span class="qpc-hafs">﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُنْذَرِينَ﴾</span> أيِ: اَلَّذِينَ أُنْذِرُوا وخُوِّفُوا، فَقَدْ أُهْلِكُوا جَمِيعًا.</p></div>"
  37,74,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٧٤ ] <span class="qpc-hafs">﴿إلا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿إلا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> أيِ: اَلَّذِينَ أخْلَصُوا دِينَهم لِلَّهِ، أوِ اَلَّذِينَ أخْلَصَهم تَعالى لِدِينِهِ، عَلى اَلْقِراءَتَيْنِ؛ أيْ: فَإنَّهُ تَعالى نَصَرَهم وجَعَلَ اَلْعاقِبَةَ لَهم. ثُمَّ أشارَ تَعالى إلى أنْبائِهِمْ، تَثْبِيتًا لِفُؤادِهِ صَلَواتُ اَللَّهِ عَلَيْهِ، وتَبْشِيرًا لِأتْباعِهِ، بِقَوْلِهِ:</p></div>"
  37,75,"<div class=ar lang=ar><p>(p-٥٠٤٤)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٧٥ - ٧٧ ] <span class="qpc-hafs">﴿ولَقَدْ نادانا نُوحٌ فَلَنِعْمَ المُجِيبُونَ﴾</span> <span class="qpc-hafs">﴿ونَجَّيْناهُ وأهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</span> [الصافات: ٧٦] <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span> [الصافات: ٧٧] .</p><p><span class="qpc-hafs">﴿ولَقَدْ نادانا نُوحٌ﴾</span> أيْ: بِقَوْلِهِ: <span class="qpc-hafs">﴿رَبِّ لا تَذَرْ عَلى الأرْضِ مِنَ الكافِرِينَ دَيّارًا﴾</span> [نوح: ٢٦] <span class="qpc-hafs">﴿فَلَنِعْمَ المُجِيبُونَ﴾</span> أيْ: نَحْنُ بِهَلاكِ قَوْمِهِ؛ لِأنَّهُ لا يُجِيبُ اَلْمُضْطَرَّ غَيْرُهُ: <span class="qpc-hafs">﴿ونَجَّيْناهُ وأهْلَهُ مِنَ الكَرْبِ العَظِيمِ﴾</span> [الصافات: ٧٦] أيْ: مِنَ اَلْغَرَقِ والطُّوفانِ. والمُرادُ بِأهْلِهِ، مَن آمَنَ مَعَهُ: <span class="qpc-hafs">﴿وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ﴾</span> [الصافات: ٧٧] أيْ: في اَلْأرْضِ بَعْدَ هَلاكِ قَوْمِهِ.</p></div>"
  37,76,"37:75"