quran[27]{c,v,t}:
  37,127,""
  37,128,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٢٨ - ١٣٠ ] <span class="qpc-hafs">﴿إلا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ في الآخِرِينَ﴾</span> [الصافات: ١٢٩] <span class="qpc-hafs">﴿سَلامٌ عَلى إلْ ياسِينَ﴾</span> [الصافات: ١٣٠] .</p><p><span class="qpc-hafs">﴿إلا عِبادَ اللَّهِ المُخْلَصِينَ﴾</span> أيِ: اَلَّذِينَ آمَنُوا بِهِ واتَّبَعُوهُ: <span class="qpc-hafs">﴿وتَرَكْنا عَلَيْهِ في الآخِرِينَ﴾</span> [الصافات: ١٢٩] <span class="qpc-hafs">﴿سَلامٌ عَلى إلْ ياسِينَ﴾</span> [الصافات: ١٣٠] بِكَسْرِ اَلْهَمْزَةِ وسُكُونِ اَللّامِ مَوْصُولَةً بِـ: (ياسِينَ). وقُرِئَ آلِ ياسِينَ بِإضافَةِ آلِ – (بِمَعْنى أهْلٍ) إلَيْهِ. وكُلُّهُ مِنَ اَلتَّصَرُّفِ في اَلْعَلَمِ اَلْأصْلِيِّ، اَلَّذِي هو (إيلِيا) عَلى قاعِدَةِ اَلْعَرَبِ في اَلْأعْلامِ اَلْعَجَمِيَّةِ، إذا أرادَتْ أنْ تَلْفِظَها في اَلِاسْتِعْمالِ، وتُخَفِّفَها عَلى اَلْألْسِنَةِ.</p></div>"
  37,129,""
  37,130,""
  37,131,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٣١ - ١٣٤ ] <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَجْزِي المُحْسِنِينَ﴾</span> <span class="qpc-hafs">﴿إنَّهُ مِن عِبادِنا المُؤْمِنِينَ﴾</span> [الصافات: ١٣٢] <span class="qpc-hafs">﴿وإنَّ لُوطًا لَمِنَ المُرْسَلِينَ﴾</span> [الصافات: ١٣٣] <span class="qpc-hafs">﴿إذْ نَجَّيْناهُ وأهْلَهُ أجْمَعِينَ﴾</span> [الصافات: ١٣٤] .</p><p>(p-٥٠٦١)<span class="qpc-hafs">﴿إنّا كَذَلِكَ نَجْزِي المُحْسِنِينَ﴾</span> <span class="qpc-hafs">﴿إنَّهُ مِن عِبادِنا المُؤْمِنِينَ﴾</span> [الصافات: ١٣٢] <span class="qpc-hafs">﴿وإنَّ لُوطًا لَمِنَ المُرْسَلِينَ﴾</span> [الصافات: ١٣٣] أيْ: لِلدُّعاءِ إلى اَللَّهِ، والنَّهْيِ عَنِ اَلْفَواحِشِ: <span class="qpc-hafs">﴿إذْ نَجَّيْناهُ وأهْلَهُ أجْمَعِينَ﴾</span> [الصافات: ١٣٤] أيْ: مِن عَذابِ قَوْمِهِ اَلْمُنْذَرِينَ.</p></div>"
  37,132,""
  37,133,""
  37,134,""
  37,135,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٣٥ ] <span class="qpc-hafs">﴿إلا عَجُوزًا في الغابِرِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿إلا عَجُوزًا﴾</span> وهي اِمْرَأتُهُ، فَإنَّها وإنْ خَرَجَتْ عَنْ مَكانِ عَذابِهِمْ، كانَتْ: <span class="qpc-hafs">﴿فِي الغابِرِينَ﴾</span> أيْ: في حُكْمِ اَلْباقِينَ في اَلْعَذابِ، لِكَوْنِها عَلى دِينِ قَوْمِها.</p></div>"
  37,136,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٣٦ ] <span class="qpc-hafs">﴿ثُمَّ دَمَّرْنا الآخَرِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿ثُمَّ دَمَّرْنا﴾</span> أيْ: أهْلَكْنا: <span class="qpc-hafs">﴿الآخَرِينَ﴾</span> بِجَعْلِ قَرْيَتِهِمْ عالِيَها سافِلَها، وإمْطارِ حِجارَةٍ مِن سِجِّيلٍ عَلَيْهِمْ.</p></div>"
  37,137,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٣٧ - ١٣٩ ] <span class="qpc-hafs">﴿وإنَّكم لَتَمُرُّونَ عَلَيْهِمْ مُصْبِحِينَ﴾</span> <span class="qpc-hafs">﴿وبِاللَّيْلِ أفَلا تَعْقِلُونَ﴾</span> [الصافات: ١٣٨] <span class="qpc-hafs">﴿وإنَّ يُونُسَ لَمِنَ المُرْسَلِينَ﴾</span> [الصافات: ١٣٩] .</p><p><span class="qpc-hafs">﴿وإنَّكُمْ﴾</span> أيْ: يا أهْلَ مَكَّةَ: <span class="qpc-hafs">﴿لَتَمُرُّونَ عَلَيْهِمْ مُصْبِحِينَ﴾</span> <span class="qpc-hafs">﴿وبِاللَّيْلِ﴾</span> [الصافات: ١٣٨] أيْ: فَتَرَوْنَ دائِمًا عَلاماتِ مُؤاخَذَتِهِمْ: <span class="qpc-hafs">﴿أفَلا تَعْقِلُونَ﴾</span> [الصافات: ١٣٨] <span class="qpc-hafs">﴿وإنَّ يُونُسَ لَمِنَ المُرْسَلِينَ﴾</span> [الصافات: ١٣٩] أيْ: إلى أهْلِ نِينَوى لِلتَّوْحِيدِ، والزَّجْرِ عَنِ اِرْتِكابِ اَلْمَآثِمِ.</p></div>"
  37,138,""
  37,139,""
  37,140,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٠ ] <span class="qpc-hafs">﴿إذْ أبَقَ إلى الفُلْكِ المَشْحُونِ﴾</span> .</p><p>(p-٥٠٦٢)<span class="qpc-hafs">﴿إذْ أبَقَ﴾</span> أيْ: بِغَيْرِ إذْنٍ عَنْ قَوْمِهِ اَلْمُرْسَلِ إلَيْهِمْ: <span class="qpc-hafs">﴿إلى الفُلْكِ المَشْحُونِ﴾</span> أيِ: اَلسَّفِينَةِ اَلْمَمْلُوءَةِ، لِيَرْكَبَ مِنها إلى بَلَدٍ آخَرَ. رُوِيَ أنَّهُ نَزَلَ مِن يافا، ورَكِبَ اَلْفُلْكَ إلى تَرْسِيسَ، فَهَبَّتْ رِياحٌ شَدِيدَةٌ كادَتْ تُغْرِقُهُمْ، فاقْتَرَعُوا لِيَعْلَمُوا بِسَبَبِ مَن أصابَهم هَذا اَلْبَلاءُ، فَوَقَعَتْ عَلى يُونُسَ، فَألْقَوْهُ في اَلْبَحْرِ. وهو مَعْنى قَوْلِهِ تَعالى:</p></div>"
  37,141,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤١ ] <span class="qpc-hafs">﴿فَساهَمَ فَكانَ مِنَ المُدْحَضِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿فَساهَمَ﴾</span> أيْ: قارَعَ: <span class="qpc-hafs">﴿فَكانَ مِنَ المُدْحَضِينَ﴾</span> أيِ: اَلْمَغْلُوبِينَ بِالقُرْعَةِ. وأصْلُهُ اَلزَّلَقُ عَنِ اَلظَّفَرِ.</p></div>"
  37,142,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٢ ] <span class="qpc-hafs">﴿فالتَقَمَهُ الحُوتُ وهو مُلِيمٌ﴾</span> .</p><p><span class="qpc-hafs">﴿فالتَقَمَهُ الحُوتُ﴾</span> أيِ: اِبْتَلَعَهُ: <span class="qpc-hafs">﴿وهُوَ مُلِيمٌ﴾</span> أيْ: آتٍ بِما يُلامُ عَلَيْهِ مِنَ اَلسَّفَرِ بِغَيْرِ أمْرِ رَبِّهِ.</p></div>"
  37,143,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٣ ] <span class="qpc-hafs">﴿فَلَوْلا أنَّهُ كانَ مِنَ المُسَبِّحِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿فَلَوْلا أنَّهُ كانَ مِنَ المُسَبِّحِينَ﴾</span> أيِ: اَلذّاكِرِينَ اَللَّهَ بِالتَّسْبِيحِ، والإنابَةِ، والتَّوْبَةِ، في بَطْنِ اَلْحُوتِ.</p></div>"
  37,144,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٤ ] <span class="qpc-hafs">﴿لَلَبِثَ في بَطْنِهِ إلى يَوْمِ يُبْعَثُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿لَلَبِثَ في بَطْنِهِ إلى يَوْمِ يُبْعَثُونَ﴾</span> أيْ: لَكانَ بَطْنُهُ قَبْرًا لَهُ إلى يَوْمِ اَلْقِيامَةِ؛ أيْ: لَكِنْ رَحِمْناهُ بِتَسْبِيحِهِ.</p></div>"
  37,145,"<div class=ar lang=ar><p>(p-٥٠٦٣)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٥ ] <span class="qpc-hafs">﴿فَنَبَذْناهُ بِالعَراءِ وهو سَقِيمٌ﴾</span> .</p><p><span class="qpc-hafs">﴿فَنَبَذْناهُ بِالعَراءِ﴾</span> أيْ: حَمَلْنا اَلْحُوتَ عَلى طَرْحِهِ بِاليُبْسِ مِنَ اَلشَّطِّ: <span class="qpc-hafs">﴿وهُوَ سَقِيمٌ﴾</span> أيْ: مِمّا نالَهُ مِن هَذا اَلْمَحْبِسِ اَلَّذِي يَأْخُذُ بِالخِناقِ.</p></div>"
  37,146,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٦ ] <span class="qpc-hafs">﴿وأنْبَتْنا عَلَيْهِ شَجَرَةً مِن يَقْطِينٍ﴾</span> .</p><p><span class="qpc-hafs">﴿وأنْبَتْنا عَلَيْهِ شَجَرَةً مِن يَقْطِينٍ﴾</span> أيْ: لِتَقِيَهُ مِنَ اَلذُّبابِ والشَّمْسِ.</p></div>"
  37,147,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٧ ] <span class="qpc-hafs">﴿وأرْسَلْناهُ إلى مِائَةِ ألْفٍ أوْ يَزِيدُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿وأرْسَلْناهُ﴾</span> أيْ: بَعْدَ ذَلِكَ، بِأنْ أمَرْناهُ ثانِيَةً بِالذَّهابِ: <span class="qpc-hafs">﴿إلى مِائَةِ ألْفٍ أوْ يَزِيدُونَ﴾</span> وهم قَوْمُهُ اَلْمُرْسَلُ إلَيْهِمُ، اَلَّذِينَ أبَقَ عَنِ اَلذَّهابِ إلَيْهِمْ أوَّلًا، و(" أوْ ") لِلْإضْرابِ، أوْ بِمَعْنى اَلْواوِ لِلشَّكِّ بِالنِّسْبَةِ إلى مَرْأى اَلنّاظِرِ؛ أيْ: إذا رَآها اَلرّائِي قالَ: هي مِائَةُ ألْفٍ أوْ أكْثَرُ. والغَرَضُ اَلْوَصْفُ بِالكَثْرَةِ.</p></div>"
  37,148,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٨ ] <span class="qpc-hafs">﴿فَآمَنُوا فَمَتَّعْناهم إلى حِينٍ﴾</span> .</p><p><span class="qpc-hafs">﴿فَآمَنُوا﴾</span> أيْ: فَسارَ إلَيْهِمْ ودَعاهم إلى اَللَّهِ، وأنْذَرَهم عَذابَهُ إنْ لَمْ يَرْجِعُوا عَنِ اَلْكُفْرِ، والغَيِّ، والضَّلالِ، والفَسادِ، والإفْسادِ. فَأشْفَقُوا مِن إنْذارِهِ واسْتَكانُوا لِدَعْوَتِهِ وآمَنُوا مَعَهُ: <span class="qpc-hafs">﴿فَمَتَّعْناهم إلى حِينٍ﴾</span> أيْ: حِينِ اِنْقِضاءِ آجالِهِمْ بِالعَيْشِ اَلْهَنِيِّ، والمَقامِ اَلْأمِينِ، بِبَرَكَةِ اَلْإيمانِ والعَمَلِ اَلصّالِحِ، وإنَّما لَمْ يَخْتِمْ قِصَّتَهُ وقِصَّةَ لُوطٍ بِما خَتَمَ بِهِ سائِرَ اَلْقَصَصِ مِن قَوْلِهِ: { وتَرَكْنا عَلَيْهِ } إلَخْ اِكْتِفاءً بِالتَّسْلِيمِ اَلشّامِلِ لِكُلِّ اَلرُّسُلِ اَلْمَذْكُورِينَ في آخِرِ اَلسُّورَةِ.</p></div>"
  37,149,"<div class=ar lang=ar><p>(p-٥٠٦٤)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٤٩ ] <span class="qpc-hafs">﴿فاسْتَفْتِهِمْ ألِرَبِّكَ البَناتُ ولَهُمُ البَنُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿فاسْتَفْتِهِمْ﴾</span> أيْ: قُرَيْشًا اَلْمُنْذِرِينَ بِأنْباءِ اَلرُّسُلِ وقَوْمِهِمْ: <span class="qpc-hafs">﴿ألِرَبِّكَ البَناتُ ولَهُمُ البَنُونَ﴾</span> أيْ سَلْهم عَنْ وجْهِ اَلْقِسْمَةِ اَلضِّيزى اَلَّتِي قَسَمُوها. جَعَلُوا لِلَّهِ اَلْإناثَ ولِأنْفُسِهِمُ اَلذُّكُورَ، في قَوْلِهِمُ: اَلْمَلائِكَةُ بَناتُ اَللَّهِ. مَعَ كَراهَتِهِمُ اَلشَّدِيدَةِ لَهُنَّ، ووَأْدِهِمْ واسْتِنْكافِهِمْ مِن ذِكْرِهِنَّ.</p></div>"
  37,150,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٥٠ ] <span class="qpc-hafs">﴿أمْ خَلَقْنا المَلائِكَةَ إناثًا وهم شاهِدُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿أمْ خَلَقْنا المَلائِكَةَ إناثًا وهم شاهِدُونَ﴾</span> أيْ: حاضِرُونَ، حَتّى فاهُوا بِتِلْكَ اَلْعَظِيمَةِ.</p></div>"
  37,151,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٥١، ١٥٢ ] <span class="qpc-hafs">﴿ألا إنَّهم مِن إفْكِهِمْ لَيَقُولُونَ﴾</span> <span class="qpc-hafs">﴿ولَدَ اللَّهُ وإنَّهم لَكاذِبُونَ﴾</span> [الصافات: ١٥٢] .</p><p><span class="qpc-hafs">﴿ألا إنَّهم مِن إفْكِهِمْ لَيَقُولُونَ﴾</span> <span class="qpc-hafs">﴿ولَدَ اللَّهُ﴾</span> [الصافات: ١٥٢] أيْ: صَدَرَ مِنهُ اَلْوَلَدُ، مَعَ أنَّ اَلْوِلادَةَ مِن خَواصِّ اَلْأجْسامِ اَلْقابِلَةِ لِلْفَسادِ: <span class="qpc-hafs">﴿وإنَّهم لَكاذِبُونَ﴾</span> [الصافات: ١٥٢] أيْ: في مَقالَتِهِمْ.</p></div>"
  37,152,""
  37,153,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٥٣ ] <span class="qpc-hafs">﴿أصْطَفى البَناتِ عَلى البَنِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿أصْطَفى البَناتِ﴾</span> أيِ: اِخْتارَ اَلْإناثَ: <span class="qpc-hafs">﴿عَلى البَنِينَ﴾</span> أيِ: اَلذُّكُورِ.</p></div>"