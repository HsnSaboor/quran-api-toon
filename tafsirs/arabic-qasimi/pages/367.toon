quran[19]{c,v,t}:
  26,1,"<div class=ar lang=ar><p>(p-٤٦٠٤)بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</p><p>سُورَةُ الشُّعَراءِ</p><p>وهِيَ مَكِّيَّةٌ، إلّا قَوْلَهُ تَعالى: <span class="qpc-hafs">﴿والشُّعَراءُ يَتَّبِعُهُمُ الغاوُونَ﴾</span> [الشعراء: ٢٢٤] إلى آخِرِها. وقَوْلُهُ: <span class="qpc-hafs">﴿أوَلَمْ يَكُنْ لَهم آيَةً أنْ يَعْلَمَهُ عُلَماءُ بَنِي إسْرائِيلَ﴾</span> [الشعراء: ١٩٧] فَقَدْ رُوِيَ أنَّهُما نَزَلَتا بِالمَدِينَةِ، وكانَ شُعَراؤُهُ ﷺ بِالمَدِينَةِ، حَسّانَ وكَعْبَ بْنَ مالِكٍ وابْنَ رَواحَةَ، رَضِيَ اللَّهُ عَنْهم.</p><p>وقالَ الدّانِي: رُوِيَ بِسَنَدٍ صَحِيحٍ أنَّها نَزَلَتْ في شاعِرَيْنِ تَهاجَيا في الجاهِلِيَّةِ، مَعَ كُلِّ واحِدٍ مِنهم جَماعَةٌ. فالسُّورَةُ عَلى هَذا كُلُّها مَكِّيَّةٌ. انْتَهى.</p><p>وقالَ المَهايِمِيُّ: سُمِّيَتْ هَذِهِ السُّورَةُ بِها، لِاخْتِصاصِها بِتَمْيِيزِ الرُّسُلِ عَنِ الشُّعَراءِ، لِأنَّ الشّاعِرَ، إنْ كانَ كاذِبًا فَهو رَئِيسُ الغُواةِ لا يُتَصَوَّرُ مِنهُ الهِدايَةُ، وإنْ كانَ صادِقًا لا يُتَصَوَّرُ مِنهُ الِافْتِراءُ عَلى اللَّهِ تَعالى، وهَذا مِن أعْظَمِ مَقاصِدِ القُرْآنِ، انْتَهى.</p><p>يُشِيرُ إلى أنَّ ذِكْرَ الشُّعَراءِ فِيها، لِبَيانِ أنَّهم في مَعْزِلٍ عَنِ الرِّسالَةِ وتَبْرِئَةِ مَقامِ الرَّسُولِ صَلَواتُ اللَّهِ عَلَيْهِ. عَمّا افْتَرَوْا عَلَيْهِ مِن أنَّهُ شاعِرٌ، فالسُّورَةُ عَلى هَذا كُلُّها مَكِّيَّةٌ، رَدًّا لِفِرْيَتِهِمْ.</p><p>ولَمّا كانَ لَفْظُ (الشُّعَراءِ) عامًّا، جازَ حَمْلُهُ عَلى ما حَكَوْهُ لِشُمُولِهِ لَهُ، لا أنَّهُ نَزَلَ فِيهِ خاصَّةً دُونَ غَيْرِهِ. وسَيَأْتِي، إنْ شاءَ اللَّهُ تَعالى، إيضاحُ ذَلِكَ وهي مِائَتانِ وسَبْعٌ وعِشْرُونَ آيَةً. قالَ ابْنُ كَثِيرٍ: وقَعَ في تَفْسِيرِ مالِكٍ المَرْوِيِّ عَنْهُ، تَسْمِيَتُها (الجامِعَةَ).</p><p>(p-٤٦٠٥)بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</p><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[١] <span class="qpc-hafs">﴿طسم﴾</span> .</p><p>"طسم" سَبَقَ في سُورَةِ البَقَرَةِ الأقْوالُ في هَذِهِ الفَواتِحِ، وأنَّ الأكْثَرَ عَلى أنَّها اسْمٌ لِلسُّورَةِ، فَمَحَلُّهُ الرَّفْعُ عَلى أنَّهُ خَبَرٌ لِمَحْذُوفٍ، وهو أظْهَرُ مِن رَفْعِهِ عَلى الِابْتِداءِ، أوِ النَّصْبُ بِتَقْدِيرِ: اقْرَأْ ونَحْوَهُ.</p></div>"
  26,2,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٢] <span class="qpc-hafs">﴿تِلْكَ آياتُ الكِتابِ المُبِينِ﴾</span></p><p><span class="qpc-hafs">﴿تِلْكَ آياتُ الكِتابِ المُبِينِ﴾</span> الإشارَةُ إلى السُّورَةِ، وما فِيها مِن مَعْنى البُعْدِ لِلتَّفْخِيمِ، ومَحَلُّهُ الرَّفْعُ عَلى الِابْتِداءِ، خَبَرُهُ ما بَعْدَهُ أوْ بَدَلٌ مِمّا قَبْلَهُ. والمُرادُ بِـ(الكِتابِ) القُرْآنُ. وبِـ(المُبِينِ) الظّاهِرُ إعْجازُهُ وآيَتُهُ وبُرْهانُهُ. ومِن (أبانَ) بِمَعْنى: بانَ - أوِ المُبَيِّنِ لِلْحَقِّ مِنَ الباطِلِ.</p></div>"
  26,3,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٣] <span class="qpc-hafs">﴿لَعَلَّكَ باخِعٌ نَفْسَكَ ألا يَكُونُوا مُؤْمِنِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿لَعَلَّكَ باخِعٌ﴾</span> أيْ: قاتِلٌ: <span class="qpc-hafs">﴿نَفْسَكَ ألا يَكُونُوا مُؤْمِنِينَ﴾</span> أيْ: لِعَدَمِ إيمانِهِمْ. و(لَعَلَّ) لِلْإشْفاقِ. أيْ: أشْفِقْ عَلى نَفْسِكَ أنْ تَقْتُلَها حَسْرَةً عَلى عَدَمِ إيمانِهِمْ.</p></div>"
  26,4,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٤] <span class="qpc-hafs">﴿إنْ نَشَأْ نُنَـزِّلْ عَلَيْهِمْ مِنَ السَّماءِ آيَةً فَظَلَّتْ أعْناقُهم لَها خاضِعِينَ﴾</span></p><p><span class="qpc-hafs">﴿إنْ نَشَأْ نُنَـزِّلْ عَلَيْهِمْ مِنَ السَّماءِ آيَةً﴾</span> أيْ: مُلْجِئَةً لَهم إلى الإيمانِ، قاسِرَةً عَلَيْهِ: <span class="qpc-hafs">﴿فَظَلَّتْ (p-٤٦٠٦)أعْناقُهم لَها خاضِعِينَ﴾</span> أيْ: مُنْقادِينَ، والجُمْلَةُ مُسْتَأْنِفَةٌ لِتَعْلِيلِ ما يُفْهَمُ مِنَ الكَلامِ مِنَ النَّهْيِ عَنِ التَّحَسُّرِ المَذْكُورِ، بِبَيانِ أنَّ إيمانَهم لَيْسَ مِمّا تَعَلَّقَتْ بِهِ مَشِيئَةُ اللَّهِ تَعالى حَتْمًا، فَلا وجْهَ لِلطَّمَعِ فِيهِ، والتَّألُّمِ مِن فَواتِهِ. قالَهُ أبُو السُّعُودِ.</p></div>"
  26,5,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٥] <span class="qpc-hafs">﴿وما يَأْتِيهِمْ مِن ذِكْرٍ مِنَ الرَّحْمَنِ مُحْدَثٍ إلا كانُوا عَنْهُ مُعْرِضِينَ﴾</span></p><p><span class="qpc-hafs">﴿وما يَأْتِيهِمْ مِن ذِكْرٍ مِنَ الرَّحْمَنِ مُحْدَثٍ إلا كانُوا عَنْهُ مُعْرِضِينَ﴾</span> أيْ: مُكَذِّبِينَ، اسْتِهْزاءٌ وإصْرارٌ عَلى ما كانُوا عَلَيْهِ مِنَ الكُفْرِ. وتَقَدَّمَ نَظِيرُ الآيَةِ في أوَّلِ سُورَةِ الأنْبِياءِ، وتَحْقِيقُ مَعْنى قَوْلِهِ تَعالى: "مُحْدَثٍ" فَتَذَكَّرْ.</p></div>"
  26,6,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٦] <span class="qpc-hafs">﴿فَقَدْ كَذَّبُوا فَسَيَأْتِيهِمْ أنْباءُ ما كانُوا بِهِ يَسْتَهْزِئُونَ﴾</span></p><p><span class="qpc-hafs">﴿فَقَدْ كَذَّبُوا فَسَيَأْتِيهِمْ أنْباءُ ما كانُوا بِهِ يَسْتَهْزِئُونَ﴾</span> أيْ: أحْوالُهُ الباهِرَةُ وشُؤُونُهُ القاهِرَةُ، وظُهُورُ أعْلامِهِ، وبَقاءُ أيّامِهِ، وفِيهِ وعِيدٌ لَهم بِحُلُولِ الذُّلِّ بِهِمْ، ونُزُولِ الصِّغارِ وقْتَئِذٍ بِدارِهِمْ.</p></div>"
  26,7,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٧] <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا إلى الأرْضِ كَمْ أنْبَتْنا فِيها مِن كُلِّ زَوْجٍ كَرِيمٍ﴾</span> .</p><p><span class="qpc-hafs">﴿أوَلَمْ يَرَوْا إلى الأرْضِ كَمْ أنْبَتْنا فِيها مِن كُلِّ زَوْجٍ كَرِيمٍ﴾</span> أيْ: صِنْفٍ مُرْضِي كَثِيرِ المَنافِعِ.</p></div>"
  26,8,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٨] <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآيَةً وما كانَ أكْثَرُهم مُؤْمِنِينَ﴾</span></p><p>(p-٤٦٠٧)<span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآيَةً وما كانَ أكْثَرُهم مُؤْمِنِينَ﴾</span> لِصَرْفِهِمُ اخْتِيارَهم إلى جانِبِ الكُفْرِ، في هَذِهِ الآياتِ.</p></div>"
  26,9,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٩] <span class="qpc-hafs">﴿وإنَّ رَبَّكَ لَهو العَزِيزُ الرَّحِيمُ﴾</span></p><p><span class="qpc-hafs">﴿وإنَّ رَبَّكَ لَهو العَزِيزُ الرَّحِيمُ﴾</span> أيْ: فَهو القادِرُ عَلى الِانْتِقامِ مِنهم بِلا مُمانِعٍ، والرَّحِيمُ بِإمْهالِهِ وحِلْمِهِ عَنْهُمْ، فَلْيَنْتَبِهُوا قَبْلَ أنْ يَحِلَّ بِهِمْ ما حَلَّ بِفِرْعَوْنَ وقَوْمِهِ، ولِذا اسْتَأْنَفَ نَبَأ مُوسى عَلَيْهِ السَّلامُ مَعَهُ، بِقَوْلِهِ تَعالى:</p></div>"
  26,10,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[١٠ - ١٣] <span class="qpc-hafs">﴿وإذْ نادى رَبُّكَ مُوسى أنِ ائْتِ القَوْمَ الظّالِمِينَ﴾</span> <span class="qpc-hafs">﴿قَوْمَ فِرْعَوْنَ ألا يَتَّقُونَ﴾</span> [الشعراء: ١١] <span class="qpc-hafs">﴿قالَ رَبِّ إنِّي أخافُ أنْ يُكَذِّبُونِ﴾</span> [الشعراء: ١٢] <span class="qpc-hafs">﴿ويَضِيقُ صَدْرِي ولا يَنْطَلِقُ لِسانِي فَأرْسِلْ إلى هارُونَ﴾</span> [الشعراء: ١٣]</p><p><span class="qpc-hafs">﴿وإذْ نادى رَبُّكَ مُوسى أنِ ائْتِ القَوْمَ الظّالِمِينَ﴾</span> <span class="qpc-hafs">﴿قَوْمَ فِرْعَوْنَ ألا يَتَّقُونَ﴾</span> [الشعراء: ١١] <span class="qpc-hafs">﴿قالَ رَبِّ إنِّي أخافُ أنْ يُكَذِّبُونِ﴾</span> [الشعراء: ١٢] <span class="qpc-hafs">﴿ويَضِيقُ صَدْرِي ولا يَنْطَلِقُ لِسانِي﴾</span> [الشعراء: ١٣] أيْ: في أداءِ الرِّسالَةِ، في بَسْطَةٍ مِنَ المَقالِ: <span class="qpc-hafs">﴿فَأرْسِلْ إلى هارُونَ﴾</span> [الشعراء: ١٣] أيْ: لِيُوازِرَنِي ويَشُدُّ بِهِ عَضُدِي. والمَفْعُولُ مَحْذُوفٌ، أيْ: مَلَكًا أوْ جِبْرِيلَ.</p></div>"
  26,11,"26:10"
  26,12,"26:10"
  26,13,"26:10"
  26,14,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[١٤ - ١٥] <span class="qpc-hafs">﴿ولَهم عَلَيَّ ذَنْبٌ فَأخافُ أنْ يَقْتُلُونِ﴾</span> <span class="qpc-hafs">﴿قالَ كَلا فاذْهَبا بِآياتِنا إنّا مَعَكم مُسْتَمِعُونَ﴾</span> [الشعراء: ١٥]</p><p>(p-٤٦٠٨)<span class="qpc-hafs">﴿ولَهم عَلَيَّ ذَنْبٌ﴾</span> وهو قَتْلُ القِبْطِيِّ، المَبْسُوطُ في غَيْرِ هَذِهِ السُّورَةِ: <span class="qpc-hafs">﴿فَأخافُ أنْ يَقْتُلُونِ﴾</span> <span class="qpc-hafs">﴿قالَ كَلا﴾</span> [الشعراء: ١٥] أيْ: لا تَخَفْ إنَّكَ مِنَ الآمِنِينَ: <span class="qpc-hafs">﴿فاذْهَبا بِآياتِنا إنّا مَعَكم مُسْتَمِعُونَ﴾</span> [الشعراء: ١٥] مَزِيدُ تَسْلِيَةٍ لَهُما، بِكَمالِ الحِفْظِ والنُّصْرَةِ.</p><p>قالَ أبُو السُّعُودِ: مَثَّلَ حالَهُ تَعالى بِحالِ ذِي شَوْكَةٍ قَدْ حَضَرَ مُجادَلَةَ قَوْمٍ يَسْتَمِعُ ما يَجْرِي بَيْنَهُمْ، لِيَمُدَّ أوْلِياءَهُ ويُظْهِرَهم عَلى أعْدائِهِمْ، مُبالَغَةً في الوَعِيدِ بِالإعانَةِ. انْتَهى.</p><p>ولَوْ قِيلَ هو كِنايَةٌ عَنْ ذَلِكَ، كانَ أوْلى. لِجَوازِ بَقاءِ المَعْنى الحَقِيقِيِّ مَعَها، وهو هُنا كَذَلِكَ فَهو تَعالى مُسْتَمِعٌ لَهُما وحافِظٌ وناصِرٌ.</p></div>"
  26,15,"26:14"
  26,16,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[١٦ - ١٧] <span class="qpc-hafs">﴿فَأْتِيا فِرْعَوْنَ فَقُولا إنّا رَسُولُ رَبِّ العالَمِينَ﴾</span> <span class="qpc-hafs">﴿أنْ أرْسِلْ مَعَنا بَنِي إسْرائِيلَ﴾</span> [الشعراء: ١٧]</p><p><span class="qpc-hafs">﴿فَأْتِيا فِرْعَوْنَ فَقُولا إنّا رَسُولُ رَبِّ العالَمِينَ﴾</span> <span class="qpc-hafs">﴿أنْ أرْسِلْ مَعَنا بَنِي إسْرائِيلَ﴾</span> [الشعراء: ١٧] لِيَتَحَرَّرُوا مِن عُبُودِيَّتِكَ وعَذابِكَ المُهِينِ.</p></div>"
  26,17,"26:16"
  26,18,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[١٨ - ١٩] <span class="qpc-hafs">﴿قالَ ألَمْ نُرَبِّكَ فِينا ولِيدًا ولَبِثْتَ فِينا مِن عُمُرِكَ سِنِينَ﴾</span> <span class="qpc-hafs">﴿وفَعَلْتَ فَعْلَتَكَ الَّتِي فَعَلْتَ وأنْتَ مِنَ الكافِرِينَ﴾</span> [الشعراء: ١٩] .</p><p><span class="qpc-hafs">﴿قالَ ألَمْ نُرَبِّكَ فِينا ولِيدًا ولَبِثْتَ فِينا مِن عُمُرِكَ سِنِينَ﴾</span> <span class="qpc-hafs">﴿وفَعَلْتَ فَعْلَتَكَ الَّتِي فَعَلْتَ﴾</span> [الشعراء: ١٩] يَعْنِي قَتْلَ القِبْطِيِّ <span class="qpc-hafs">﴿وأنْتَ مِنَ الكافِرِينَ﴾</span> [الشعراء: ١٩] أيْ: بِنِعْمَتِي.</p></div>"
  26,19,"26:18"