quran[23]{c,v,t}:
  26,61,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٦١ - ٦٣] <span class="qpc-hafs">﴿فَلَمّا تَراءى الجَمْعانِ قالَ أصْحابُ مُوسى إنّا لَمُدْرَكُونَ﴾</span> <span class="qpc-hafs">﴿قالَ كَلا إنَّ مَعِيَ رَبِّي سَيَهْدِينِ﴾</span> [الشعراء: ٦٢] <span class="qpc-hafs">﴿فَأوْحَيْنا إلى مُوسى أنِ اضْرِبْ بِعَصاكَ البَحْرَ فانْفَلَقَ فَكانَ كُلُّ فِرْقٍ كالطَّوْدِ العَظِيمِ﴾</span> [الشعراء: ٦٣]</p><p><span class="qpc-hafs">﴿فَلَمّا تَراءى الجَمْعانِ﴾</span> أيْ: تَقارَبا رَأى واحِدٌ مِنهُما الآخَرَ: <span class="qpc-hafs">﴿قالَ أصْحابُ مُوسى إنّا لَمُدْرَكُونَ﴾</span> أيْ: لَمُلْحَقُونَ: <span class="qpc-hafs">﴿قالَ كَلا﴾</span> [الشعراء: ٦٢] أيْ: لَنْ يُدْرِكُوكم فَإنَّ اللَّهَ وعَدَكم بِالخَلاصِ مِنهُمْ: <span class="qpc-hafs">﴿إنَّ مَعِيَ رَبِّي سَيَهْدِينِ﴾</span> [الشعراء: ٦٢] أيْ: لِطَرِيقِ النَّجاةِ مِنهم <span class="qpc-hafs">﴿فَأوْحَيْنا إلى مُوسى أنِ (p-٤٦٢٠)اضْرِبْ بِعَصاكَ البَحْرَ فانْفَلَقَ﴾</span> [الشعراء: ٦٣] أيْ: فَضَرَبَهُ فانْفَلَقَ: <span class="qpc-hafs">﴿فَكانَ كُلُّ فِرْقٍ كالطَّوْدِ العَظِيمِ﴾</span> [الشعراء: ٦٣] أيْ: كُلُّ جُزْءٍ مُتَفَرِّقٍ مِنهُ كالجَبَلِ الكَبِيرِ.</p></div>"
  26,62,""
  26,63,""
  26,64,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٦٤ - ٦٨] <span class="qpc-hafs">﴿وأزْلَفْنا ثَمَّ الآخَرِينَ﴾</span> <span class="qpc-hafs">﴿وأنْجَيْنا مُوسى ومَن مَعَهُ أجْمَعِينَ﴾</span> [الشعراء: ٦٥] <span class="qpc-hafs">﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</span> [الشعراء: ٦٦] <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآيَةً وما كانَ أكْثَرُهم مُؤْمِنِينَ﴾</span> [الشعراء: ٦٧] <span class="qpc-hafs">﴿وإنَّ رَبَّكَ لَهو العَزِيزُ الرَّحِيمُ﴾</span> [الشعراء: ٦٨] .</p><p><span class="qpc-hafs">﴿وأزْلَفْنا﴾</span> أيْ: قَرَّبْنا: <span class="qpc-hafs">﴿ثَمَّ﴾</span> أيْ: حَيْثُ انْفَلَقَ البَحْرُ: <span class="qpc-hafs">﴿الآخَرِينَ﴾</span> يَعْنِي فِرْعَوْنَ، أيْ: قَدَّمْناهم إلى البَحْرِ حَتّى دَخَلُوا عَلى أثَرِ بَنِي إسْرائِيلَ: <span class="qpc-hafs">﴿وأنْجَيْنا مُوسى ومَن مَعَهُ أجْمَعِينَ﴾</span> [الشعراء: ٦٥] أيْ: بِحِفْظِ البَحْرِ عَلى تِلْكَ الهَيْئَةِ إلى أنْ عَبَرُوا <span class="qpc-hafs">﴿ثُمَّ أغْرَقْنا الآخَرِينَ﴾</span> [الشعراء: ٦٦] أيْ: بِإطْباقِهِ عَلَيْهِمْ: <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآيَةً﴾</span> [الشعراء: ٦٧] أيْ: لَعِبْرَةً: <span class="qpc-hafs">﴿وما كانَ أكْثَرُهم مُؤْمِنِينَ﴾</span> [الشعراء: ٦٧] أيْ: مَعَ مُشاهَدَةِ هَذِهِ الآيَةِ العُظْمى الَّتِي تُوجِبُ تَصْدِيقَهُ بَعْدَها في كُلِّ ما جاءَ بِهِ. مِنهم مَن بَقِيَ عَلى كُفْرِهِ كَبَقِيَّةِ القِبْطِ. ومِنهم مَن عَصاهُ واقْتَرَحَ عَلَيْهِ ما اقْتَرَحَ كَبَعْضِ بَنِي إسْرائِيلَ. وفِيهِ تَسْلِيَةٌ لِلنَّبِيِّ صَلَواتُ اللَّهِ عَلَيْهِ. ووَعْدٌ لَهُ ووَعِيدٌ لِمَن عَصاهُ.</p></div>"
  26,65,""
  26,66,""
  26,67,""
  26,68,""
  26,69,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٦٩ - ٧٤] <span class="qpc-hafs">﴿واتْلُ عَلَيْهِمْ نَبَأ إبْراهِيمَ﴾</span> <span class="qpc-hafs">﴿إذْ قالَ لأبِيهِ وقَوْمِهِ ما تَعْبُدُونَ﴾</span> [الشعراء: ٧٠] <span class="qpc-hafs">﴿قالُوا نَعْبُدُ أصْنامًا فَنَظَلُّ لَها عاكِفِينَ﴾</span> [الشعراء: ٧١] (p-٤٦٢١)<span class="qpc-hafs">﴿قالَ هَلْ يَسْمَعُونَكم إذْ تَدْعُونَ﴾</span> [الشعراء: ٧٢] <span class="qpc-hafs">﴿أوْ يَنْفَعُونَكم أوْ يَضُرُّونَ﴾</span> [الشعراء: ٧٣] <span class="qpc-hafs">﴿قالُوا بَلْ وجَدْنا آباءَنا كَذَلِكَ يَفْعَلُونَ﴾</span> [الشعراء: ٧٤] .</p><p><span class="qpc-hafs">﴿واتْلُ عَلَيْهِمْ﴾</span> أيْ: عَلى مُشْرِكِي العَرَبِ: <span class="qpc-hafs">﴿نَبَأ إبْراهِيمَ﴾</span> <span class="qpc-hafs">﴿إذْ قالَ لأبِيهِ وقَوْمِهِ ما تَعْبُدُونَ﴾</span> [الشعراء: ٧٠] أيْ: ما الَّذِي تَدْعُونَهُ وتَلْجَئُونَ إلَيْهِ. وكانَ عَلَيْهِ السَّلامُ يَعْلَمُ أنَّهم عَبَدَةُ أصْنامٍ، ولَكِنَّهُ سَألَهم لِيُرِيَهُمْ، أنَّ ما يَعْبُدُونَهُ لَيْسَ مِنِ اسْتِحْقاقِ العِبادَةِ في شَيْءٍ: <span class="qpc-hafs">﴿قالُوا نَعْبُدُ أصْنامًا فَنَظَلُّ لَها عاكِفِينَ﴾</span> [الشعراء: ٧١] أيْ: مُقِيمِينَ عَلى عِبادَتِها لا نَتَخَطّاها إلى غَيْرِها <span class="qpc-hafs">﴿قالَ هَلْ يَسْمَعُونَكم إذْ تَدْعُونَ﴾</span> [الشعراء: ٧٢] <span class="qpc-hafs">﴿أوْ يَنْفَعُونَكم أوْ يَضُرُّونَ﴾</span> [الشعراء: ٧٣] <span class="qpc-hafs">﴿قالُوا بَلْ وجَدْنا آباءَنا كَذَلِكَ يَفْعَلُونَ﴾</span> [الشعراء: ٧٤] أيْ: مِثْلَ عِبادَتِنا، فَقَلَّدْناهم.</p><p>قالَ أبُو السُّعُودِ: اعْتَرَفُوا بِأنَّها بِمَعْزِلٍ مِمّا ذُكِرَ مِنَ السَّمْعِ والمَنفَعَةِ والمَضَرَّةِ بِالمَرَّةِ. واضْطُرُّوا إلى إظْهارِ أنْ لا سَنَدَ لَهم سِوى التَّقْلِيدِ.</p></div>"
  26,70,""
