quran[27]{c,v,t}:
  37,25,"<div class=ar lang=ar><p>(p-٥٠٣٤)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٢٥ ] <span class="qpc-hafs">﴿ما لَكم لا تَناصَرُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿ما لَكم لا تَناصَرُونَ﴾</span> أيْ لا يَنْصُرُ بَعْضُكم بَعْضًا، وقَدْ كانَ شَأْنُكُمُ اَلتَّعاضُدُ في اَلْحَياةِ اَلْأُولى. وهو تَوْبِيخٌ لَهم وتَقْرِيعٌ.</p></div>"
  37,26,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٢٦ ] <span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿بَلْ هُمُ اليَوْمَ مُسْتَسْلِمُونَ﴾</span> أيْ: مُنْقادُونَ مَخْذُولُونَ.</p></div>"
  37,27,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٢٧، ٢٨ ] <span class="qpc-hafs">﴿وأقْبَلَ بَعْضُهم عَلى بَعْضٍ يَتَساءَلُونَ﴾</span> <span class="qpc-hafs">﴿قالُوا إنَّكم كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span> [الصافات: ٢٨] .</p><p><span class="qpc-hafs">﴿وأقْبَلَ بَعْضُهم عَلى بَعْضٍ يَتَساءَلُونَ﴾</span> <span class="qpc-hafs">﴿قالُوا إنَّكم كُنْتُمْ تَأْتُونَنا عَنِ اليَمِينِ﴾</span> [الصافات: ٢٨] أيْ: عَنِ اَلْقَهْرِ والغَلَبَةِ؛ أيْ: كُنْتُمْ تَضْطَرُّونا إلى ما تَدْعُونا إلَيْهِ، كَما في آيَةِ: <span class="qpc-hafs">﴿وقالَ الَّذِينَ اسْتُضْعِفُوا لِلَّذِينَ اسْتَكْبَرُوا بَلْ مَكْرُ اللَّيْلِ والنَّهارِ إذْ تَأْمُرُونَنا أنْ نَكْفُرَ بِاللَّهِ ونَجْعَلَ لَهُ أنْدادًا﴾</span> [سبإ: ٣٣] وقِيلَ عَنِ اَلْحِلْفِ والقِسْمِ. وقِيلَ عَنْ جِهَةِ اَلْخَيْرِ وناحِيَةِ اَلْحَقِّ، مِنَ (اَلْيَمَنِ) ضِدَّ اَلشُّؤْمِ؛ أيْ: تُوهِمُونا وتَخْدَعُونا؛ أنَّ ما أنْتُمْ عَلَيْهِ أمْرٌ مَيْمُونٌ فِيهِ اَلْخَيْرُ والفَوْزُ، فَأيْنَ مِصْداقُهُ وقَدْ نَزَلَ ما نَزَلَ؟</p></div>"
  37,28,"37:27"
  37,29,"<div class=ar lang=ar><p>(p-٥٠٣٥)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٢٩ - ٣٥ ] <span class="qpc-hafs">﴿قالُوا بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</span> <span class="qpc-hafs">﴿وما كانَ لَنا عَلَيْكم مِن سُلْطانٍ بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span> [الصافات: ٣٠] <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا إنّا لَذائِقُونَ﴾</span> [الصافات: ٣١] <span class="qpc-hafs">﴿فَأغْوَيْناكم إنّا كُنّا غاوِينَ﴾</span> [الصافات: ٣٢] <span class="qpc-hafs">﴿فَإنَّهم يَوْمَئِذٍ في العَذابِ مُشْتَرِكُونَ﴾</span> [الصافات: ٣٣] <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span> [الصافات: ٣٤] <span class="qpc-hafs">﴿إنَّهم كانُوا إذا قِيلَ لَهم لا إلَهَ إلا اللَّهُ يَسْتَكْبِرُونَ﴾</span> [الصافات: ٣٥] .</p><p><span class="qpc-hafs">﴿قالُوا بَلْ لَمْ تَكُونُوا مُؤْمِنِينَ﴾</span> <span class="qpc-hafs">﴿وما كانَ لَنا عَلَيْكم مِن سُلْطانٍ بَلْ كُنْتُمْ قَوْمًا طاغِينَ﴾</span> [الصافات: ٣٠] <span class="qpc-hafs">﴿فَحَقَّ عَلَيْنا قَوْلُ رَبِّنا إنّا لَذائِقُونَ﴾</span> [الصافات: ٣١] <span class="qpc-hafs">﴿فَأغْوَيْناكم إنّا كُنّا غاوِينَ﴾</span> [الصافات: ٣٢] <span class="qpc-hafs">﴿فَإنَّهم يَوْمَئِذٍ في العَذابِ مُشْتَرِكُونَ﴾</span> [الصافات: ٣٣] <span class="qpc-hafs">﴿إنّا كَذَلِكَ نَفْعَلُ بِالمُجْرِمِينَ﴾</span> [الصافات: ٣٤] <span class="qpc-hafs">﴿إنَّهم كانُوا إذا قِيلَ لَهم لا إلَهَ إلا اللَّهُ يَسْتَكْبِرُونَ﴾</span> [الصافات: ٣٥] أيْ: عَنِ اَلِاسْتِجابَةِ لِلدّاعِي إلَيْها.</p></div>"
