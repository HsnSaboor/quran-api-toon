quran[7]{c,v,t}:
  28,71,"28:69"
  28,72,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٧٢ - ٧٦] <span class="qpc-hafs">﴿قُلْ أرَأيْتُمْ إنْ جَعَلَ اللَّهُ عَلَيْكُمُ النَّهارَ سَرْمَدًا إلى يَوْمِ القِيامَةِ مَن إلَهٌ غَيْرُ اللَّهِ يَأْتِيكم بِلَيْلٍ تَسْكُنُونَ فِيهِ أفَلا تُبْصِرُونَ﴾</span> <span class="qpc-hafs">﴿ومِن رَحْمَتِهِ جَعَلَ لَكُمُ اللَّيْلَ والنَّهارَ لِتَسْكُنُوا فِيهِ ولِتَبْتَغُوا مِن فَضْلِهِ ولَعَلَّكم تَشْكُرُونَ﴾</span> [القصص: ٧٣] <span class="qpc-hafs">﴿ويَوْمَ يُنادِيهِمْ فَيَقُولُ أيْنَ شُرَكائِيَ الَّذِينَ كُنْتُمْ تَزْعُمُونَ﴾</span> [القصص: ٧٤] (p-٤٧٢٥)<span class="qpc-hafs">﴿ونَـزَعْنا مِن كُلِّ أُمَّةٍ شَهِيدًا فَقُلْنا هاتُوا بُرْهانَكم فَعَلِمُوا أنَّ الحَقَّ لِلَّهِ وضَلَّ عَنْهم ما كانُوا يَفْتَرُونَ﴾</span> [القصص: ٧٥] <span class="qpc-hafs">﴿إنَّ قارُونَ كانَ مِن قَوْمِ مُوسى فَبَغى عَلَيْهِمْ وآتَيْناهُ مِنَ الكُنُوزِ ما إنَّ مَفاتِحَهُ لَتَنُوءُ بِالعُصْبَةِ أُولِي القُوَّةِ إذْ قالَ لَهُ قَوْمُهُ لا تَفْرَحْ إنَّ اللَّهَ لا يُحِبُّ الفَرِحِينَ﴾</span> [القصص: ٧٦]</p><p><span class="qpc-hafs">﴿قُلْ أرَأيْتُمْ إنْ جَعَلَ اللَّهُ عَلَيْكُمُ النَّهارَ سَرْمَدًا إلى يَوْمِ القِيامَةِ مَن إلَهٌ غَيْرُ اللَّهِ يَأْتِيكم بِلَيْلٍ تَسْكُنُونَ فِيهِ أفَلا تُبْصِرُونَ﴾</span> أيْ: هَذِهِ المَنفَعَةَ فَتَقُومُوا بِشُكْرِها: <span class="qpc-hafs">﴿ومِن رَحْمَتِهِ جَعَلَ لَكُمُ اللَّيْلَ والنَّهارَ لِتَسْكُنُوا فِيهِ﴾</span> [القصص: ٧٣] أيْ: في اللَّيْلِ: <span class="qpc-hafs">﴿ولِتَبْتَغُوا مِن فَضْلِهِ﴾</span> [القصص: ٧٣] أيْ: في النَّهارِ: <span class="qpc-hafs">﴿ولَعَلَّكم تَشْكُرُونَ﴾</span> [القصص: ٧٣] أيْ: نِعَمَهُ الظّاهِرَةَ والباطِنَةَ، والجُسْمانِيَّةَ والرُّوحانِيَّةَ، بِاسْتِعْمالِها فِيما وجَبَ مِن طاعَتِهِ. وذَلِكَ فِيما خُلِقَتْ لَهُ.</p><p><span class="qpc-hafs">﴿ويَوْمَ يُنادِيهِمْ فَيَقُولُ أيْنَ شُرَكائِيَ الَّذِينَ كُنْتُمْ تَزْعُمُونَ﴾</span> [القصص: ٧٤] <span class="qpc-hafs">﴿ونَـزَعْنا﴾</span> [القصص: ٧٥] أيْ: وأخْرَجْنا: <span class="qpc-hafs">﴿مِن كُلِّ أُمَّةٍ شَهِيدًا﴾</span> [القصص: ٧٥] أيْ: نَبِيًّا يَشْهَدُ عَلَيْهِمْ بِما كانُوا عَلَيْهِ. كَقَوْلِهِ تَعالى: <span class="qpc-hafs">﴿فَكَيْفَ إذا جِئْنا مِن كُلِّ أُمَّةٍ بِشَهِيدٍ﴾</span> [النساء: ٤١] <span class="qpc-hafs">﴿فَقُلْنا﴾</span> [القصص: ٧٥] أيْ: لِكُلِّ أُمَّةٍ مِن تِلْكَ الأُمَمِ: <span class="qpc-hafs">﴿هاتُوا بُرْهانَكُمْ﴾</span> [القصص: ٧٥] أيْ: عَلى ما أنْتُمْ عَلَيْهِ. أحَقٌّ هو أمْ لا؟ فَعَجَزُوا عَنْ آخِرِهِمْ. وظَهَرَ بُرْهانُ النَّبِيِّ، كَما قالَ تَعالى: <span class="qpc-hafs">﴿فَعَلِمُوا أنَّ الحَقَّ لِلَّهِ﴾</span> [القصص: ٧٥] أيْ: في الأُلُوهِيَّةِ، لا يُشارِكُهُ فِيها أحَدٌ: <span class="qpc-hafs">﴿وضَلَّ عَنْهُمْ﴾</span> [القصص: ٧٥] أيْ: غابَ عَنْهم غَيْبَةَ الضّائِعِ: <span class="qpc-hafs">﴿ما كانُوا يَفْتَرُونَ﴾</span> [القصص: ٧٥] أيْ: مِنَ الباطِلِ والمَذاهِبِ المُخْتَلِفَةِ، والطُّرُقِ المُتَشَعِّبَةِ المُتَفَرِّقَةِ.</p><p><span class="qpc-hafs">﴿إنَّ قارُونَ كانَ مِن قَوْمِ مُوسى﴾</span> [القصص: ٧٦] أيْ: مِن شاكِلَتِهِمْ في الكُفْرِ والطُّغْيانِ. وقَوْمُ مُوسى، جَماعَتُهُ الَّذِينَ أُرْسِلَ إلَيْهِمْ، وهُمُ القِبْطُ وطاغِيَتُهم فِرْعَوْنُ: <span class="qpc-hafs">﴿فَبَغى عَلَيْهِمْ﴾</span> [القصص: ٧٦] أيْ: بِالكِبْرِ والِاسْتِطالَةِ عَلَيْهِمْ لَمّا غَلَبَ عَلَيْهِ الحِرْصُ ومَحَبَّةُ الدُّنْيا، لِغُرُورِهِ وتَعَزُّزِهِ بِرُؤْيَةِ زِينَةِ نَفْسِهِ:<span class="qpc-hafs">﴿وآتَيْناهُ مِنَ الكُنُوزِ﴾</span> [القصص: ٧٦] أيْ: مِنَ الأمْوالِ (p-٤٧٢٦)المُدَّخَرَةِ: <span class="qpc-hafs">﴿ما إنَّ مَفاتِحَهُ﴾</span> [القصص: ٧٦] أيْ: مَفاتِيحَ صَنادِيقِهِ. عَلى حَذْفِ مُضافٍ. أوِ الإضافَةِ لِأدْنى مُلابَسَةٍ. وقِيلَ خَزائِنُهُ: <span class="qpc-hafs">﴿لَتَنُوءُ﴾</span> [القصص: ٧٦] أيْ: تَثْقُلُ: <span class="qpc-hafs">﴿بِالعُصْبَةِ﴾</span> [القصص: ٧٦] أيِ: الجَماعَةِ الكَثِيرَةِ مِنَ الرِّجالِ أوِ البِغالِ: <span class="qpc-hafs">﴿أُولِي القُوَّةِ إذْ قالَ لَهُ قَوْمُهُ لا تَفْرَحْ﴾</span> [القصص: ٧٦] أيْ: بِزَخارِفِ الدُّنْيا فَرَحًا يَشْغَلُكَ عَنِ الشُّكْرِ فِيها والقِيامِ بِحَقِّها: <span class="qpc-hafs">﴿إنَّ اللَّهَ لا يُحِبُّ الفَرِحِينَ﴾</span> [القصص: ٧٦] أيْ: هَذا الفَرَحَ، لِما فِيهِ مِن إيثارِها عَنِ الآخِرَةِ، والرِّضا بِها عَنْها، والإخْلادِ إلَيْها. وذَلِكَ أصْلُ كُلِّ شَرٍّ ومَبْعَثُ كُلِّ فَسادٍ.</p></div>"
  28,73,"28:72"
  28,74,"28:72"
  28,75,"28:72"
  28,76,"28:72"
  28,77,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٧٧ - ٧٨] <span class="qpc-hafs">﴿وابْتَغِ فِيما آتاكَ اللَّهُ الدّارَ الآخِرَةَ ولا تَنْسَ نَصِيبَكَ مِنَ الدُّنْيا وأحْسِنْ كَما أحْسَنَ اللَّهُ إلَيْكَ ولا تَبْغِ الفَسادَ في الأرْضِ إنَّ اللَّهَ لا يُحِبُّ المُفْسِدِينَ﴾</span> <span class="qpc-hafs">﴿قالَ إنَّما أُوتِيتُهُ عَلى عِلْمٍ عِنْدِي أوَلَمْ يَعْلَمْ أنَّ اللَّهَ قَدْ أهْلَكَ مِن قَبْلِهِ مِنَ القُرُونِ مَن هو أشَدُّ مِنهُ قُوَّةً وأكْثَرُ جَمْعًا ولا يُسْألُ عَنْ ذُنُوبِهِمُ المُجْرِمُونَ﴾</span> [القصص: ٧٨] .</p><p><span class="qpc-hafs">﴿وابْتَغِ فِيما آتاكَ اللَّهُ﴾</span> أيِ: اطْلُبْ مِنَ الغَنِيِّ الَّذِي تَفَضَّلَ اللَّهُ بِهِ عَلَيْكَ، بَعْدَ الفاقَةِ: <span class="qpc-hafs">﴿الدّارَ الآخِرَةَ﴾</span> أيْ: بِأنْ تَفْعَلَ فِيهِ أفْعالَ الخَيْرِ مِن أصْنافِ الواجِبِ والمَندُوبِ. وتَجْعَلُهُ زادَكَ إلى الآخِرَةِ: <span class="qpc-hafs">﴿ولا تَنْسَ نَصِيبَكَ مِنَ الدُّنْيا﴾</span> وهو أنْ تَأْخُذَ مِنهُ ما يُصْلِحُكَ ويُرَفِّهُكَ: <span class="qpc-hafs">﴿وأحْسِنْ﴾</span> أيْ: إلى النّاسِ. أوِ افْعَلِ الإحْسانَ مِن وُجُوهِهِ المَعْرُوفَةِ: <span class="qpc-hafs">﴿كَما أحْسَنَ اللَّهُ إلَيْكَ ولا تَبْغِ الفَسادَ في الأرْضِ﴾</span> أيْ: بِهَذا المالِ الَّذِي جَعَلَهُ سَبَبَ صَلاحِها: <span class="qpc-hafs">﴿إنَّ اللَّهَ لا يُحِبُّ المُفْسِدِينَ﴾</span> <span class="qpc-hafs">﴿قالَ إنَّما أُوتِيتُهُ عَلى عِلْمٍ عِنْدِي﴾</span> [القصص: ٧٨] أيْ: بِطُرُقِ التِّجارَةِ أوِ المَكاسِبِ: <span class="qpc-hafs">﴿أوَلَمْ يَعْلَمْ﴾</span> [القصص: ٧٨] أيْ: مِمّا سَمِعَ بِالتَّواتُرِ: <span class="qpc-hafs">﴿أنَّ اللَّهَ قَدْ أهْلَكَ مِن قَبْلِهِ مِنَ القُرُونِ﴾</span> [القصص: ٧٨] أيِ: الكَثِيرَةِ، بِحَيْثُ صارَتْ سُنَّةً لَهُ: <span class="qpc-hafs">﴿مَن هو أشَدُّ مِنهُ قُوَّةً﴾</span> [القصص: ٧٨] أيْ: بِالأمْوالِ والأتْباعِ: <span class="qpc-hafs">﴿وأكْثَرُ جَمْعًا ولا يُسْألُ عَنْ ذُنُوبِهِمُ (p-٤٧٢٧)المُجْرِمُونَ﴾</span> [القصص: ٧٨] أيْ: لا يَتَوَقَّفُ إهْلاكُهُ إيّاهم عَلى سُؤالٍ، لِيَعْتَذِرُوا عَنْها. بَلْ مَتى حَقَّ عَلَيْها القَوْلُ بِفِسْقِهِمْ، أهْلَكَهم بَغْتَةً بِلا مُعاتَبَةٍ وطَلَبِ عُذْرٍ. ثُمَّ أشارَ تَعالى إلى أنَّ قارُونَ لَمْ يَعْتَبِرْ بِذَلِكَ، ولا بِنَصِيحَةِ قَوْمِهِ، بِقَوْلِهِ سُبْحانَهُ:</p></div>"