quran[9]{c,v,t}:
  40,17,"40:16"
  40,18,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٨] <span class="qpc-hafs">﴿وأنْذِرْهم يَوْمَ الآزِفَةِ إذِ القُلُوبُ لَدى الحَناجِرِ كاظِمِينَ ما لِلظّالِمِينَ مِن حَمِيمٍ ولا شَفِيعٍ يُطاعُ﴾</span> .</p><p><span class="qpc-hafs">﴿وأنْذِرْهم يَوْمَ الآزِفَةِ﴾</span> أيِ: الواقِعَةِ القَرِيبَةِ: <span class="qpc-hafs">﴿إذِ القُلُوبُ لَدى الحَناجِرِ﴾</span> أيْ: مِن أهْوالِهِ تَرْتَفِعُ القُلُوبُ عَنْ مَقارِّها، فَتَصِيرُ لَدى الحُلُوقِ: <span class="qpc-hafs">﴿كاظِمِينَ﴾</span> أيْ: مُمْتَلِئِينَ غَمًّا، بِما أفْرَطُوا مِنَ الظُّلْمِ: <span class="qpc-hafs">﴿ما لِلظّالِمِينَ مِن حَمِيمٍ﴾</span> أيْ: قَرِيبٍ يَهْتَمُّ لِشَأْنِهِمْ، فَيُخَفِّفُ عَنْهم غُمُومَهُمْ: <span class="qpc-hafs">﴿ولا شَفِيعٍ يُطاعُ﴾</span> أيْ: مَن يَشْفَعُ في تَخْفِيفِها عَنْهُمْ؛ إذْ لا تُقْبَلُ شَفاعَةٌ فِيهِمْ.</p></div>"
  40,19,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ١٩ - ٢٥] <span class="qpc-hafs">﴿يَعْلَمُ خائِنَةَ الأعْيُنِ وما تُخْفِي الصُّدُورُ﴾</span> <span class="qpc-hafs">﴿واللَّهُ يَقْضِي بِالحَقِّ والَّذِينَ يَدْعُونَ مِن دُونِهِ لا يَقْضُونَ بِشَيْءٍ إنَّ اللَّهَ هو السَّمِيعُ البَصِيرُ﴾</span> [غافر: ٢٠] <span class="qpc-hafs">﴿أوَلَمْ يَسِيرُوا في الأرْضِ فَيَنْظُرُوا كَيْفَ كانَ عاقِبَةُ الَّذِينَ كانُوا مِن قَبْلِهِمْ كانُوا هم أشَدَّ مِنهم قُوَّةً وآثارًا في الأرْضِ فَأخَذَهُمُ اللَّهُ بِذُنُوبِهِمْ وما كانَ لَهم مِنَ اللَّهِ مِن واقٍ﴾</span> [غافر: ٢١] <span class="qpc-hafs">﴿ذَلِكَ بِأنَّهم كانَتْ تَأْتِيهِمْ رُسُلُهم بِالبَيِّناتِ فَكَفَرُوا فَأخَذَهُمُ اللَّهُ إنَّهُ قَوِيٌّ شَدِيدُ العِقابِ﴾</span> [غافر: ٢٢] <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا مُوسى بِآياتِنا وسُلْطانٍ مُبِينٍ﴾</span> [غافر: ٢٣] <span class="qpc-hafs">﴿إلى فِرْعَوْنَ وهامانَ وقارُونَ فَقالُوا ساحِرٌ كَذّابٌ﴾</span> [غافر: ٢٤] <span class="qpc-hafs">﴿فَلَمّا جاءَهم بِالحَقِّ مِن عِنْدِنا قالُوا اقْتُلُوا أبْناءَ الَّذِينَ آمَنُوا مَعَهُ واسْتَحْيُوا نِساءَهم وما كَيْدُ الكافِرِينَ إلا في ضَلالٍ﴾</span> [غافر: ٢٥] (p-٥١٦٢)<span class="qpc-hafs">﴿يَعْلَمُ خائِنَةَ الأعْيُنِ﴾</span> أيْ: نَظَراتِها الخائِنَةَ، وهي المُمْتَدَّةُ إلى ما لا يَحِلُّ: <span class="qpc-hafs">﴿وما تُخْفِي الصُّدُورُ﴾</span> أيْ: تُكِنُّهُ مِنَ الضَّمائِرِ والأسْرارِ: <span class="qpc-hafs">﴿واللَّهُ يَقْضِي بِالحَقِّ﴾</span> [غافر: ٢٠] أيْ: بِالعَدْلِ: <span class="qpc-hafs">﴿والَّذِينَ يَدْعُونَ مِن دُونِهِ لا يَقْضُونَ بِشَيْءٍ﴾</span> [غافر: ٢٠] أيْ: لِأنَّهم لا يَقْدِرُونَ عَلى شَيْءٍ: <span class="qpc-hafs">﴿إنَّ اللَّهَ هو السَّمِيعُ البَصِيرُ﴾</span> [غافر: ٢٠] <span class="qpc-hafs">﴿أوَلَمْ يَسِيرُوا في الأرْضِ فَيَنْظُرُوا كَيْفَ كانَ عاقِبَةُ الَّذِينَ كانُوا مِن قَبْلِهِمْ كانُوا هم أشَدَّ مِنهم قُوَّةً وآثارًا في الأرْضِ﴾</span> [غافر: ٢١] يَعْنِي حُصُونَهم وقُصُورَهم وعُدَدَهُمْ: <span class="qpc-hafs">﴿فَأخَذَهُمُ اللَّهُ بِذُنُوبِهِمْ وما كانَ لَهم مِنَ اللَّهِ مِن واقٍ﴾</span> [غافر: ٢١] <span class="qpc-hafs">﴿ذَلِكَ بِأنَّهم كانَتْ تَأْتِيهِمْ رُسُلُهم بِالبَيِّناتِ فَكَفَرُوا فَأخَذَهُمُ اللَّهُ إنَّهُ قَوِيٌّ شَدِيدُ العِقابِ﴾</span> [غافر: ٢٢] <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا مُوسى بِآياتِنا وسُلْطانٍ مُبِينٍ﴾</span> [غافر: ٢٣] <span class="qpc-hafs">﴿إلى فِرْعَوْنَ وهامانَ وقارُونَ فَقالُوا ساحِرٌ كَذّابٌ﴾</span> [غافر: ٢٤] <span class="qpc-hafs">﴿فَلَمّا جاءَهم بِالحَقِّ﴾</span> [غافر: ٢٥] أيْ: بِآياتِ نُبُوَّتِهِ: <span class="qpc-hafs">﴿مِن عِنْدِنا قالُوا اقْتُلُوا أبْناءَ الَّذِينَ آمَنُوا مَعَهُ واسْتَحْيُوا نِساءَهُمْ﴾</span> [غافر: ٢٥] أيْ: قالُوا: أعِيدُوا عَلَيْهِمُ القَتْلَ، كالَّذِي كانَ أوَّلًا، واسْتَبْقُوا نِساءَهم لِلْخِدْمَةِ: <span class="qpc-hafs">﴿وما كَيْدُ الكافِرِينَ إلا في ضَلالٍ﴾</span> [غافر: ٢٥] أيْ: وما مَكْرُهم في دَفْعِ ما أرادَ اللَّهُ مِن ظُهُورِ دِينِهِ، إلّا في ضَياعٍ؛ إذْ هو كالغُثاءِ الَّذِي يَقْذِفُهُ تَيّارُ الحَقِّ.</p></div>"
