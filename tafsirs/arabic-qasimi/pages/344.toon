  23,28,"23:26"
  23,29,"23:26"
  23,30,"23:26"
  23,31,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٣١] <span class="qpc-hafs">﴿ثُمَّ أنْشَأْنا مِن بَعْدِهِمْ قَرْنًا آخَرِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿ثُمَّ أنْشَأْنا مِن بَعْدِهِمْ قَرْنًا آخَرِينَ﴾</span> هم عادٌ أوْ ثَمُودُ. قالَ الشِّهابُ: لَيْسَ في الآيَةِ تَعْيِينٌ لِهَؤُلاءِ. لَكِنَّ الأوَّلَ مَأْثُورٌ عَنِ ابْنِ عَبّاسٍ رَضِيَ اللَّهُ عَنْهُما. وأيَّدَهُ في (الكَشْفِ ") بِمَجِيءِ قِصَّتِهِمْ بَعْدَ قِصَّةِ نُوحٍ في سُورَةِ الأعْرافِ وهُودٍ وغَيْرِهِما. وعَلَيْهِ أكْثَرُ المُفَسِّرِينَ. ومَن ذَهَبَ إلى أنَّهم ثَمُودُ قَوْمُ صالِحٍ عَلَيْهِ السَّلامُ، اسْتَدَلَّ بِذِكْرِ الصَّيْحَةِ لِأنَّهُمُ المُهْلَكُونَ بِها. كَما صَرَّحَ بِهِ في هَذِهِ السُّورَةِ.</p></div>"
  23,32,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[٣٢ - ٤١] <span class="qpc-hafs">﴿فَأرْسَلْنا فِيهِمْ رَسُولا مِنهم أنِ اعْبُدُوا اللَّهَ ما لَكم مِن إلَهٍ غَيْرُهُ أفَلا تَتَّقُونَ﴾</span> <span class="qpc-hafs">﴿وقالَ المَلأُ مِن قَوْمِهِ الَّذِينَ كَفَرُوا وكَذَّبُوا بِلِقاءِ الآخِرَةِ وأتْرَفْناهم في الحَياةِ الدُّنْيا ما هَذا إلا بَشَرٌ مِثْلُكم يَأْكُلُ مِمّا تَأْكُلُونَ مِنهُ ويَشْرَبُ مِمّا تَشْرَبُونَ﴾</span> [المؤمنون: ٣٣] <span class="qpc-hafs">﴿ولَئِنْ أطَعْتُمْ بَشَرًا مِثْلَكم إنَّكم إذًا لَخاسِرُونَ﴾</span> [المؤمنون: ٣٤] <span class="qpc-hafs">﴿أيَعِدُكم أنَّكم إذا مِتُّمْ وكُنْتُمْ تُرابًا وعِظامًا أنَّكم مُخْرَجُونَ﴾</span> [المؤمنون: ٣٥] (p-٤٣٩٩)<span class="qpc-hafs">﴿هَيْهاتَ هَيْهاتَ لِما تُوعَدُونَ﴾</span> [المؤمنون: ٣٦] <span class="qpc-hafs">﴿إنْ هي إلا حَياتُنا الدُّنْيا نَمُوتُ ونَحْيا وما نَحْنُ بِمَبْعُوثِينَ﴾</span> [المؤمنون: ٣٧] <span class="qpc-hafs">﴿إنْ هو إلا رَجُلٌ افْتَرى عَلى اللَّهِ كَذِبًا وما نَحْنُ لَهُ بِمُؤْمِنِينَ﴾</span> [المؤمنون: ٣٨] <span class="qpc-hafs">﴿قالَ رَبِّ انْصُرْنِي بِما كَذَّبُونِ﴾</span> [المؤمنون: ٣٩] <span class="qpc-hafs">﴿قالَ عَمّا قَلِيلٍ لَيُصْبِحُنَّ نادِمِينَ﴾</span> [المؤمنون: ٤٠] <span class="qpc-hafs">﴿فَأخَذَتْهُمُ الصَّيْحَةُ بِالحَقِّ فَجَعَلْناهم غُثاءً فَبُعْدًا لِلْقَوْمِ الظّالِمِينَ﴾</span> [المؤمنون: ٤١] .</p><p><span class="qpc-hafs">﴿فَأرْسَلْنا فِيهِمْ رَسُولا مِنهم أنِ اعْبُدُوا اللَّهَ ما لَكم مِن إلَهٍ غَيْرُهُ أفَلا تَتَّقُونَ﴾</span> <span class="qpc-hafs">﴿وقالَ المَلأُ مِن قَوْمِهِ الَّذِينَ كَفَرُوا وكَذَّبُوا بِلِقاءِ الآخِرَةِ وأتْرَفْناهُمْ﴾</span> [المؤمنون: ٣٣] أيْ: نَعَّمْناهم: <span class="qpc-hafs">﴿فِي الحَياةِ الدُّنْيا ما هَذا إلا بَشَرٌ مِثْلُكم يَأْكُلُ مِمّا تَأْكُلُونَ مِنهُ ويَشْرَبُ مِمّا تَشْرَبُونَ﴾</span> [المؤمنون: ٣٣] <span class="qpc-hafs">﴿ولَئِنْ أطَعْتُمْ بَشَرًا مِثْلَكم إنَّكم إذًا لَخاسِرُونَ﴾</span> [المؤمنون: ٣٤] أيْ: لِعِزَّةِ أنْفُسِكم، بِالتَّذَلُّلِ لِمِثْلِكم: <span class="qpc-hafs">﴿أيَعِدُكم أنَّكم إذا مِتُّمْ وكُنْتُمْ تُرابًا وعِظامًا أنَّكم مُخْرَجُونَ﴾</span> [المؤمنون: ٣٥] أيْ مِنَ الأجْداثِ أحْياءً كَما كُنْتُمْ: <span class="qpc-hafs">﴿هَيْهاتَ هَيْهاتَ لِما تُوعَدُونَ﴾</span> [المؤمنون: ٣٦] تَكْرِيرٌ لِتَأْكِيدِ البُعْدِ. أيْ: بَعْدَ الوُقُوعِ أوِ الصِّحَّةِ لِما تُوعَدُونَ مِنَ البَعْثِ: <span class="qpc-hafs">﴿إنْ هي إلا حَياتُنا الدُّنْيا نَمُوتُ ونَحْيا﴾</span> [المؤمنون: ٣٧] أيْ: يَمُوَتُ بَعْضٌ ويُولَدُ بَعْضٌ. لِيَنْقَرِضَ قَرْنٌ ويَأْتِيَ قَرْنٌ آخَرُ <span class="qpc-hafs">﴿وما نَحْنُ بِمَبْعُوثِينَ﴾</span> [المؤمنون: ٣٧] <span class="qpc-hafs">﴿إنْ هو إلا رَجُلٌ افْتَرى عَلى اللَّهِ كَذِبًا وما نَحْنُ لَهُ بِمُؤْمِنِينَ﴾</span> [المؤمنون: ٣٨] <span class="qpc-hafs">﴿قالَ رَبِّ انْصُرْنِي بِما كَذَّبُونِ﴾</span> [المؤمنون: ٣٩] <span class="qpc-hafs">﴿قالَ عَمّا قَلِيلٍ لَيُصْبِحُنَّ نادِمِينَ﴾</span> [المؤمنون: ٤٠] <span class="qpc-hafs">﴿فَأخَذَتْهُمُ الصَّيْحَةُ﴾</span> [المؤمنون: ٤١] أيِ: العُقُوبَةُ الهائِلَةُ، أوْ صَيْحَةُ مَلَكٍ: <span class="qpc-hafs">﴿بِالحَقِّ فَجَعَلْناهم غُثاءً﴾</span> [المؤمنون: ٤١] أيْ: كَغُثاءِ السَّيْلِ: <span class="qpc-hafs">﴿فَبُعْدًا لِلْقَوْمِ الظّالِمِينَ﴾</span> [المؤمنون: ٤١] أيْ: هَلاكًا لَهم. إخْبارٌ أوْ دُعاءٌ.</p></div>"
