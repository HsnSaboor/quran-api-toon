tafsir[20]{c,v,t}:
44,40," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٤٠ - ٤٢] <q>﴿إنَّ يَوْمَ الفَصْلِ مِيقاتُهم أجْمَعِينَ﴾</q> <q>﴿يَوْمَ لا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا ولا هم يُنْصَرُونَ﴾</q> [الدخان: ٤١] <q>﴿إلا مَن رَحِمَ اللَّهُ إنَّهُ هو العَزِيزُ الرَّحِيمُ﴾</q> [الدخان: ٤٢] . <q>﴿إنَّ يَوْمَ الفَصْلِ﴾</q> أيْ: فَصْلِ اللَّهِ بَيْنَ الخَلائِقِ وقَضائِهِ عَلَيْهِمْ، لِيَجْزِيَهم بِما أسْلَفُوا (p-٥٣١٣)مِن خَيْرٍ أوْ شَرٍّ: <q>﴿مِيقاتُهم أجْمَعِينَ﴾</q> <q>﴿يَوْمَ لا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا﴾</q> [الدخان: ٤١] أيْ مِن إثابَةٍ، أوْ تَحَمُّلِ عِقابٍ: <q>﴿ولا هم يُنْصَرُونَ﴾</q> [الدخان: ٤١] <q>﴿إلا مَن رَحِمَ اللَّهُ﴾</q> [الدخان: ٤٢] أيْ: بِأنْ وفَّقَهُ لِلْإيمانِ والعَمَلِ الصّالِحِ: <q>﴿إنَّهُ هو العَزِيزُ﴾</q> [الدخان: ٤٢] أيِ: الغالِبُ في انْتِقامِهِ مِن أعْدائِهِ: <q>﴿الرَّحِيمُ﴾</q> [الدخان: ٤٢] أيْ: بِأوْلِيائِهِ وأهْلِ طاعَتِهِ. "
  44,41,""
  44,42,""
44,43," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٤٣] <q>﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</q> . <q>﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</q> أيِ: الَّتِي هي أخْبَثُ شَجَرَةٍ مَعْرُوفَةٍ في البادِيَةِ. "
44,44," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٤٤] <q>﴿طَعامُ الأثِيمِ﴾</q> . <q>﴿طَعامُ الأثِيمِ﴾</q> أيِ: الفاجِرِ الكَثِيرِ الآثامِ. "
44,45," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٤٥، ٤٦] <q>﴿كالمُهْلِ يَغْلِي في البُطُونِ﴾</q> <q>﴿كَغَلْيِ الحَمِيمِ﴾</q> [الدخان: ٤٦] . <q>﴿كالمُهْلِ﴾</q> وهو دُرْدِيُّ الزَّيْتِ، أيْ: عَكِرُهُ في قَعْرِهِ: <q>﴿يَغْلِي في البُطُونِ﴾</q> أيْ: يَضْطَرِبُ فِيها مِن شِدَّةِ الحَرارَةِ فَيُقْلِقُ القُلُوبَ ويُحْرِقُها. وقَوْلُهُ: <q>﴿كَغَلْيِ الحَمِيمِ﴾</q> [الدخان: ٤٦] أيِ: الماءِ الحارِّ الَّذِي انْتَهى غَلَيانُهُ. وقَوْلُهُ: <q>﴿فِي البُطُونِ﴾</q> كَقَوْلِهِ: <q>﴿نارُ اللَّهِ المُوقَدَةُ﴾</q> [الهمزة: ٦] <q>﴿الَّتِي تَطَّلِعُ عَلى الأفْئِدَةِ﴾</q> [الهمزة: ٧] وهَذِهِ الآيَةُ كَآيَةِ الصّافّاتِ: <q>﴿أذَلِكَ خَيْرٌ نُـزُلا أمْ شَجَرَةُ الزَّقُّومِ﴾</q> [الصافات: ٦٢] <q>﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</q> [الصافات: ٦٣] <q>﴿إنَّها شَجَرَةٌ تَخْرُجُ في أصْلِ الجَحِيمِ﴾</q> [الصافات: ٦٤] <q>﴿طَلْعُها كَأنَّهُ رُءُوسُ الشَّياطِينِ﴾</q> [الصافات: ٦٥] <q>﴿فَإنَّهم لآكِلُونَ مِنها فَمالِئُونَ مِنها البُطُونَ﴾</q> [الصافات: ٦٦] <q>﴿ثُمَّ إنَّ لَهم عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</q> [الصافات: ٦٧] "
  44,46,""
44,47," (p-٥٣١٤)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٤٧] <q>﴿خُذُوهُ فاعْتِلُوهُ إلى سَواءِ الجَحِيمِ﴾</q> . <q>﴿خُذُوهُ فاعْتِلُوهُ﴾</q> أيِ: ادْفَعُوهُ بِعُنْفٍ: <q>﴿إلى سَواءِ الجَحِيمِ﴾</q> أيْ: وسَطِها ومُعْظَمِها. "
44,48," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٤٨] <q>﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ مِن عَذابِ الحَمِيمِ﴾</q> . <q>﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ مِن عَذابِ الحَمِيمِ﴾</q> أيْ: لِتَسْتَوْفِيَ جَمِيعَ أجْزاءِ بَدَنِهِ تُصِيبُها. "
44,49," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٤٩] <q>﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</q> . <q>﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</q> أيْ: يُقالُ لَهُ ذَلِكَ، عَلى سَبِيلِ الهُزُؤِ والتَّهَكُّمِ، فَيَتِمُّ لَهُ، مَعَ العَذابِ الأوَّلِ -وهُوَ الحِسِّيُّ- العَذابُ العَقْلِيُّ. "
44,50," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٥٠] <q>﴿إنَّ هَذا ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</q> . <q>﴿إنَّ هَذا﴾</q> أيِ: العَذابَ أوِ الأمْرَ: <q>﴿ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</q> أيْ: تَشُكُّونَ، مَعَ ظُهُورِ دَلائِلِهِ، أوْ تَتَمارَوْنَ وتَتَلاحَقُونَ. "
44,51," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٥١] <q>﴿إنَّ المُتَّقِينَ في مَقامٍ أمِينٍ﴾</q> . <q>﴿إنَّ المُتَّقِينَ في مَقامٍ أمِينٍ﴾</q> أيْ: يَأْمَنُ صاحِبُهُ مِنَ الخَوْفِ والفَزَعِ. "
44,52," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٥٢، ٥٣] <q>﴿فِي جَنّاتٍ وعُيُونٍ﴾</q> <q>﴿يَلْبَسُونَ مِن سُنْدُسٍ وإسْتَبْرَقٍ مُتَقابِلِينَ﴾</q> [الدخان: ٥٣] . (p-٥٣١٥)<q>﴿فِي جَنّاتٍ وعُيُونٍ﴾</q> <q>﴿يَلْبَسُونَ مِن سُنْدُسٍ وإسْتَبْرَقٍ﴾</q> [الدخان: ٥٣] أيْ: ما رَقَّ مِنَ الحَرِيرِ وكَثُفَ: <q>﴿مُتَقابِلِينَ﴾</q> [الدخان: ٥٣] أيْ: في مَجالِسِهِمْ، أوْ أماكِنِهِمْ؛ لِحُسْنِ تَرْتِيبِ الغُرَفِ، وتَصْفِيفِ مَنازِلِهِمْ. "
  44,53,""
44,54," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٥٤] <q>﴿كَذَلِكَ وزَوَّجْناهم بِحُورٍ عِينٍ﴾</q> . <q>﴿كَذَلِكَ وزَوَّجْناهم بِحُورٍ عِينٍ﴾</q> أيْ: قَرَنّاهم بِما فِيهِ قُرَّةِ أعْيُنِهِمْ، واسْتِئْناسِ قُلُوبِهِمْ، لِوُصُولِهِمْ بِمَحْبُوبِهِمْ، وحُصُولِهِمْ عَلى كَمالِ مُرادِهِمْ. "
44,55," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٥٥] <q>﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ آمِنِينَ﴾</q> . <q>﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ آمِنِينَ﴾</q> أيْ: يَطْلُبُونَ ويَأْمُرُونَ بِإحْضارِ ما يَشْتَهُونَ مِنَ الفَواكِهِ، آمِنِينَ مِن كُلِّ ضَرَرٍ. "
44,56," القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى: [ ٥٦ - ٥٩] <q>﴿لا يَذُوقُونَ فِيها المَوْتَ إلا المَوْتَةَ الأُولى ووَقاهم عَذابَ الجَحِيمِ﴾</q> <q>﴿فَضْلا مِن رَبِّكَ ذَلِكَ هو الفَوْزُ العَظِيمُ﴾</q> [الدخان: ٥٧] <q>﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ لَعَلَّهم يَتَذَكَّرُونَ﴾</q> [الدخان: ٥٨] <q>﴿فارْتَقِبْ إنَّهم مُرْتَقِبُونَ﴾</q> [الدخان: ٥٩] . <q>﴿لا يَذُوقُونَ فِيها المَوْتَ إلا المَوْتَةَ الأُولى﴾</q> قالَ ابْنُ جَرِيرٍ: أيْ: لا يَذُوقُ هَؤُلاءِ المُتَّقُونَ في الجَنَّةِ، المَوْتَ بَعْدَ المَوْتَةِ الأُولى، الَّتِي ذاقُوها في الدُّنْيا. (p-٥٣١٦)وكانَ بَعْضُ أهْلِ العَرَبِيَّةِ يُوَجِّهُ: { إلّا } هُنا بِمَعْنى (سِوى)؛ أيْ: سِوى المَوْتَةِ الأُولى. انْتَهى. يَعْنِي أنَّ الِاسْتِثْناءَ مُنْقَطِعٌ، أيْ: لَكِنَّ المَوْتَةَ الأُولى قَدْ ذاقُوها في الدُّنْيا: <q>﴿ووَقاهم عَذابَ الجَحِيمِ﴾</q> <q>﴿فَضْلا مِن رَبِّكَ ذَلِكَ هو الفَوْزُ العَظِيمُ﴾</q> [الدخان: ٥٧] <q>﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</q> [الدخان: ٥٨] أيْ: سَهَّلْناهُ حَيْثُ أنْزَلْناهُ بِلُغَتِكَ، وهو فَذْلَكَةٌ لِلسُّورَةِ: <q>﴿لَعَلَّهم يَتَذَكَّرُونَ﴾</q> [الدخان: ٥٨] أيْ: يَتَّعِظُونَ بِعِبَرِهِ وعِظاتِهِ وحُجَجِهِ، فَيُنِيبُوا إلى طاعَةِ رَبِّهِمْ ويُذْعِنُوا لِلْحَقِّ: <q>﴿فارْتَقِبْ﴾</q> [الدخان: ٥٩] أيْ: ما يَحِلُّ بِهِمْ مِن زُهُوقِ باطِلِهِمْ: <q>﴿إنَّهم مُرْتَقِبُونَ﴾</q> [الدخان: ٥٩] أيْ: مُنْتَظِرُونَ عِنْدَ أنْفُسِهِمْ غَلَبَتَكَ، أوْ هو قَوْلُهُمْ: <q>﴿نَتَرَبَّصُ بِهِ رَيْبَ المَنُونِ﴾</q> [الطور: ٣٠] وهَذا وعْدٌ لَهُ ﷺ بِالنُّصْرَةِ والفَتْحِ عَلَيْهِمْ، وتَسْلِيَةٌ ووَعِيدٌ لَهم. وقَدْ أنْجَزَ اللَّهُ وعْدَهُ، كَما قالَ سُبْحانَهُ: <q>﴿كَتَبَ اللَّهُ لأغْلِبَنَّ أنا ورُسُلِي﴾</q> [المجادلة: ٢١] وقَوْلِهِ تَعالى: <q>﴿إنّا لَنَنْصُرُ رُسُلَنا والَّذِينَ آمَنُوا في الحَياةِ الدُّنْيا ويَوْمَ يَقُومُ الأشْهادُ﴾</q> [غافر: ٥١] "
  44,57,""
  44,58,""
  44,59,""
