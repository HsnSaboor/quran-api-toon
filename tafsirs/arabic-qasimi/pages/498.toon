quran[20]{c,v,t}:
  44,40,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٤٠ - ٤٢] <span class="qpc-hafs">﴿إنَّ يَوْمَ الفَصْلِ مِيقاتُهم أجْمَعِينَ﴾</span> <span class="qpc-hafs">﴿يَوْمَ لا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا ولا هم يُنْصَرُونَ﴾</span> [الدخان: ٤١] <span class="qpc-hafs">﴿إلا مَن رَحِمَ اللَّهُ إنَّهُ هو العَزِيزُ الرَّحِيمُ﴾</span> [الدخان: ٤٢] .</p><p><span class="qpc-hafs">﴿إنَّ يَوْمَ الفَصْلِ﴾</span> أيْ: فَصْلِ اللَّهِ بَيْنَ الخَلائِقِ وقَضائِهِ عَلَيْهِمْ، لِيَجْزِيَهم بِما أسْلَفُوا (p-٥٣١٣)مِن خَيْرٍ أوْ شَرٍّ: <span class="qpc-hafs">﴿مِيقاتُهم أجْمَعِينَ﴾</span> <span class="qpc-hafs">﴿يَوْمَ لا يُغْنِي مَوْلًى عَنْ مَوْلًى شَيْئًا﴾</span> [الدخان: ٤١] أيْ مِن إثابَةٍ، أوْ تَحَمُّلِ عِقابٍ: <span class="qpc-hafs">﴿ولا هم يُنْصَرُونَ﴾</span> [الدخان: ٤١] <span class="qpc-hafs">﴿إلا مَن رَحِمَ اللَّهُ﴾</span> [الدخان: ٤٢] أيْ: بِأنْ وفَّقَهُ لِلْإيمانِ والعَمَلِ الصّالِحِ: <span class="qpc-hafs">﴿إنَّهُ هو العَزِيزُ﴾</span> [الدخان: ٤٢] أيِ: الغالِبُ في انْتِقامِهِ مِن أعْدائِهِ: <span class="qpc-hafs">﴿الرَّحِيمُ﴾</span> [الدخان: ٤٢] أيْ: بِأوْلِيائِهِ وأهْلِ طاعَتِهِ.</p></div>"
  44,41,""
  44,42,""
  44,43,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٤٣] <span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</span> .</p><p><span class="qpc-hafs">﴿إنَّ شَجَرَتَ الزَّقُّومِ﴾</span> أيِ: الَّتِي هي أخْبَثُ شَجَرَةٍ مَعْرُوفَةٍ في البادِيَةِ.</p></div>"
  44,44,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٤٤] <span class="qpc-hafs">﴿طَعامُ الأثِيمِ﴾</span> .</p><p><span class="qpc-hafs">﴿طَعامُ الأثِيمِ﴾</span> أيِ: الفاجِرِ الكَثِيرِ الآثامِ.</p></div>"
  44,45,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٤٥، ٤٦] <span class="qpc-hafs">﴿كالمُهْلِ يَغْلِي في البُطُونِ﴾</span> <span class="qpc-hafs">﴿كَغَلْيِ الحَمِيمِ﴾</span> [الدخان: ٤٦] .</p><p><span class="qpc-hafs">﴿كالمُهْلِ﴾</span> وهو دُرْدِيُّ الزَّيْتِ، أيْ: عَكِرُهُ في قَعْرِهِ: <span class="qpc-hafs">﴿يَغْلِي في البُطُونِ﴾</span> أيْ: يَضْطَرِبُ فِيها مِن شِدَّةِ الحَرارَةِ فَيُقْلِقُ القُلُوبَ ويُحْرِقُها. وقَوْلُهُ: <span class="qpc-hafs">﴿كَغَلْيِ الحَمِيمِ﴾</span> [الدخان: ٤٦] أيِ: الماءِ الحارِّ الَّذِي انْتَهى غَلَيانُهُ. وقَوْلُهُ: <span class="qpc-hafs">﴿فِي البُطُونِ﴾</span> كَقَوْلِهِ: <span class="qpc-hafs">﴿نارُ اللَّهِ المُوقَدَةُ﴾</span> [الهمزة: ٦] <span class="qpc-hafs">﴿الَّتِي تَطَّلِعُ عَلى الأفْئِدَةِ﴾</span> [الهمزة: ٧] وهَذِهِ الآيَةُ كَآيَةِ الصّافّاتِ: <span class="qpc-hafs">﴿أذَلِكَ خَيْرٌ نُـزُلا أمْ شَجَرَةُ الزَّقُّومِ﴾</span> [الصافات: ٦٢] <span class="qpc-hafs">﴿إنّا جَعَلْناها فِتْنَةً لِلظّالِمِينَ﴾</span> [الصافات: ٦٣] <span class="qpc-hafs">﴿إنَّها شَجَرَةٌ تَخْرُجُ في أصْلِ الجَحِيمِ﴾</span> [الصافات: ٦٤] <span class="qpc-hafs">﴿طَلْعُها كَأنَّهُ رُءُوسُ الشَّياطِينِ﴾</span> [الصافات: ٦٥] <span class="qpc-hafs">﴿فَإنَّهم لآكِلُونَ مِنها فَمالِئُونَ مِنها البُطُونَ﴾</span> [الصافات: ٦٦] <span class="qpc-hafs">﴿ثُمَّ إنَّ لَهم عَلَيْها لَشَوْبًا مِن حَمِيمٍ﴾</span> [الصافات: ٦٧]</p></div>"
  44,46,""
  44,47,"<div class=ar lang=ar><p>(p-٥٣١٤)القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٤٧] <span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ إلى سَواءِ الجَحِيمِ﴾</span> .</p><p><span class="qpc-hafs">﴿خُذُوهُ فاعْتِلُوهُ﴾</span> أيِ: ادْفَعُوهُ بِعُنْفٍ: <span class="qpc-hafs">﴿إلى سَواءِ الجَحِيمِ﴾</span> أيْ: وسَطِها ومُعْظَمِها.</p></div>"
  44,48,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٤٨] <span class="qpc-hafs">﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ مِن عَذابِ الحَمِيمِ﴾</span> .</p><p><span class="qpc-hafs">﴿ثُمَّ صُبُّوا فَوْقَ رَأْسِهِ مِن عَذابِ الحَمِيمِ﴾</span> أيْ: لِتَسْتَوْفِيَ جَمِيعَ أجْزاءِ بَدَنِهِ تُصِيبُها.</p></div>"
  44,49,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٤٩] <span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span> .</p><p><span class="qpc-hafs">﴿ذُقْ إنَّكَ أنْتَ العَزِيزُ الكَرِيمُ﴾</span> أيْ: يُقالُ لَهُ ذَلِكَ، عَلى سَبِيلِ الهُزُؤِ والتَّهَكُّمِ، فَيَتِمُّ لَهُ، مَعَ العَذابِ الأوَّلِ -وهُوَ الحِسِّيُّ- العَذابُ العَقْلِيُّ.</p></div>"
  44,50,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٠] <span class="qpc-hafs">﴿إنَّ هَذا ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</span> .</p><p><span class="qpc-hafs">﴿إنَّ هَذا﴾</span> أيِ: العَذابَ أوِ الأمْرَ: <span class="qpc-hafs">﴿ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</span> أيْ: تَشُكُّونَ، مَعَ ظُهُورِ دَلائِلِهِ، أوْ تَتَمارَوْنَ وتَتَلاحَقُونَ.</p></div>"
  44,51,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥١] <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ في مَقامٍ أمِينٍ﴾</span> .</p><p><span class="qpc-hafs">﴿إنَّ المُتَّقِينَ في مَقامٍ أمِينٍ﴾</span> أيْ: يَأْمَنُ صاحِبُهُ مِنَ الخَوْفِ والفَزَعِ.</p></div>"
  44,52,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٢، ٥٣] <span class="qpc-hafs">﴿فِي جَنّاتٍ وعُيُونٍ﴾</span> <span class="qpc-hafs">﴿يَلْبَسُونَ مِن سُنْدُسٍ وإسْتَبْرَقٍ مُتَقابِلِينَ﴾</span> [الدخان: ٥٣] .</p><p>(p-٥٣١٥)<span class="qpc-hafs">﴿فِي جَنّاتٍ وعُيُونٍ﴾</span> <span class="qpc-hafs">﴿يَلْبَسُونَ مِن سُنْدُسٍ وإسْتَبْرَقٍ﴾</span> [الدخان: ٥٣] أيْ: ما رَقَّ مِنَ الحَرِيرِ وكَثُفَ: <span class="qpc-hafs">﴿مُتَقابِلِينَ﴾</span> [الدخان: ٥٣] أيْ: في مَجالِسِهِمْ، أوْ أماكِنِهِمْ؛ لِحُسْنِ تَرْتِيبِ الغُرَفِ، وتَصْفِيفِ مَنازِلِهِمْ.</p></div>"
  44,53,""
  44,54,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٤] <span class="qpc-hafs">﴿كَذَلِكَ وزَوَّجْناهم بِحُورٍ عِينٍ﴾</span> .</p><p><span class="qpc-hafs">﴿كَذَلِكَ وزَوَّجْناهم بِحُورٍ عِينٍ﴾</span> أيْ: قَرَنّاهم بِما فِيهِ قُرَّةِ أعْيُنِهِمْ، واسْتِئْناسِ قُلُوبِهِمْ، لِوُصُولِهِمْ بِمَحْبُوبِهِمْ، وحُصُولِهِمْ عَلى كَمالِ مُرادِهِمْ.</p></div>"
  44,55,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٥] <span class="qpc-hafs">﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ آمِنِينَ﴾</span> .</p><p><span class="qpc-hafs">﴿يَدْعُونَ فِيها بِكُلِّ فاكِهَةٍ آمِنِينَ﴾</span> أيْ: يَطْلُبُونَ ويَأْمُرُونَ بِإحْضارِ ما يَشْتَهُونَ مِنَ الفَواكِهِ، آمِنِينَ مِن كُلِّ ضَرَرٍ.</p></div>"
  44,56,"<div class=ar lang=ar><p>القَوْلُ في تَأْوِيلِ قَوْلِهِ تَعالى:</p><p>[ ٥٦ - ٥٩] <span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها المَوْتَ إلا المَوْتَةَ الأُولى ووَقاهم عَذابَ الجَحِيمِ﴾</span> <span class="qpc-hafs">﴿فَضْلا مِن رَبِّكَ ذَلِكَ هو الفَوْزُ العَظِيمُ﴾</span> [الدخان: ٥٧] <span class="qpc-hafs">﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ لَعَلَّهم يَتَذَكَّرُونَ﴾</span> [الدخان: ٥٨] <span class="qpc-hafs">﴿فارْتَقِبْ إنَّهم مُرْتَقِبُونَ﴾</span> [الدخان: ٥٩] .</p><p><span class="qpc-hafs">﴿لا يَذُوقُونَ فِيها المَوْتَ إلا المَوْتَةَ الأُولى﴾</span> قالَ ابْنُ جَرِيرٍ: أيْ: لا يَذُوقُ هَؤُلاءِ المُتَّقُونَ في الجَنَّةِ، المَوْتَ بَعْدَ المَوْتَةِ الأُولى، الَّتِي ذاقُوها في الدُّنْيا.</p><p>(p-٥٣١٦)وكانَ بَعْضُ أهْلِ العَرَبِيَّةِ يُوَجِّهُ: { إلّا } هُنا بِمَعْنى (سِوى)؛ أيْ: سِوى المَوْتَةِ الأُولى. انْتَهى.</p><p>يَعْنِي أنَّ الِاسْتِثْناءَ مُنْقَطِعٌ، أيْ: لَكِنَّ المَوْتَةَ الأُولى قَدْ ذاقُوها في الدُّنْيا: <span class="qpc-hafs">﴿ووَقاهم عَذابَ الجَحِيمِ﴾</span> <span class="qpc-hafs">﴿فَضْلا مِن رَبِّكَ ذَلِكَ هو الفَوْزُ العَظِيمُ﴾</span> [الدخان: ٥٧] <span class="qpc-hafs">﴿فَإنَّما يَسَّرْناهُ بِلِسانِكَ﴾</span> [الدخان: ٥٨] أيْ: سَهَّلْناهُ حَيْثُ أنْزَلْناهُ بِلُغَتِكَ، وهو فَذْلَكَةٌ لِلسُّورَةِ: <span class="qpc-hafs">﴿لَعَلَّهم يَتَذَكَّرُونَ﴾</span> [الدخان: ٥٨] أيْ: يَتَّعِظُونَ بِعِبَرِهِ وعِظاتِهِ وحُجَجِهِ، فَيُنِيبُوا إلى طاعَةِ رَبِّهِمْ ويُذْعِنُوا لِلْحَقِّ: <span class="qpc-hafs">﴿فارْتَقِبْ﴾</span> [الدخان: ٥٩] أيْ: ما يَحِلُّ بِهِمْ مِن زُهُوقِ باطِلِهِمْ: <span class="qpc-hafs">﴿إنَّهم مُرْتَقِبُونَ﴾</span> [الدخان: ٥٩] أيْ: مُنْتَظِرُونَ عِنْدَ أنْفُسِهِمْ غَلَبَتَكَ، أوْ هو قَوْلُهُمْ: <span class="qpc-hafs">﴿نَتَرَبَّصُ بِهِ رَيْبَ المَنُونِ﴾</span> [الطور: ٣٠] وهَذا وعْدٌ لَهُ ﷺ بِالنُّصْرَةِ والفَتْحِ عَلَيْهِمْ، وتَسْلِيَةٌ ووَعِيدٌ لَهم. وقَدْ أنْجَزَ اللَّهُ وعْدَهُ، كَما قالَ سُبْحانَهُ: <span class="qpc-hafs">﴿كَتَبَ اللَّهُ لأغْلِبَنَّ أنا ورُسُلِي﴾</span> [المجادلة: ٢١] وقَوْلِهِ تَعالى: <span class="qpc-hafs">﴿إنّا لَنَنْصُرُ رُسُلَنا والَّذِينَ آمَنُوا في الحَياةِ الدُّنْيا ويَوْمَ يَقُومُ الأشْهادُ﴾</span> [غافر: ٥١]</p></div>"
  44,57,""
  44,58,""
  44,59,""