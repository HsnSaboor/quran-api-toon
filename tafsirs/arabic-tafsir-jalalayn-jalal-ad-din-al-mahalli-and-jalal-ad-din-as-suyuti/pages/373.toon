tafsir[23]{c,v,t}:
  26,137,"﴿إنْ﴾ ما ﴿هَذا﴾ الَّذِي خَوَّفْتنا بِهِ ﴿إلّا خُلُق الأَوَّلِينَ﴾ اخْتِلاقهمْ وكَذِبهمْ وفِي قِراءَة بِضَمِّ الخاء واللّام أيْ ما هَذا الَّذِي نَحْنُ عَلَيْهِ مِن إنْكار لِلْبَعْثِ إلّا خَلْق الأَوَّلِينَ أيْ طَبِيعَتهمْ وعادَتهمْ"
  26,138,""
  26,139,"﴿فَكَذَّبُوهُ﴾ بِالعَذابِ ﴿فَأَهْلَكْناهُمْ﴾ فِي الدُّنْيا بِالرِّيحِ"
  26,140,""
  26,141,"26:140"
  26,142,"26:140"
  26,143,"26:140"
  26,144,"26:140"
  26,145,"﴿وما أسْأَلكُمْ عَلَيْهِ مِن أجْر إنْ﴾ ما"
  26,146,"﴿أتُتْرَكُونَ فِي ما هاهُنا﴾ مِن الخَيْرات"
  26,147,""
  26,148,"﴿وزُرُوع ونَخْل طَلْعها هَضِيم﴾ لَطِيف لَيِّن"
  26,149,"﴿وتَنْحِتُونَ مِن الجِبال بُيُوتًا فارِهِينَ﴾ بَطِرِينَ وفِي قِراءَة فارِهِينَ حاذِقِينَ"
  26,150,"﴿فاتَّقُوا اللَّه وأَطِيعُونِ﴾ فِيما أمَرْتُكُمْ بِهِ"
  26,151,""
  26,152,"﴿الَّذِينَ يُفْسِدُونَ فِي الأَرْض﴾ بِالمَعاصِي ﴿ولا يُصْلِحُونَ﴾ بِطاعَةِ اللَّه"
  26,153,"﴿قالُوا إنّما أنْتَ مِن المُسَحَّرِينَ﴾ الَّذِينَ سَحَرُوا كَثِيرًا حَتّى غَلَبَ عَلى عَقْلهمْ"
  26,154,"﴿ما أنْتَ﴾ أيْضًا ﴿إلّا بَشَر مِثْلنا فَأْتِ بِآيَةٍ إنْ كُنْت مِن الصّادِقِينَ﴾ فِي رِسالَتك"
  26,155,"﴿قالَ هَذِهِ ناقَة لَها شِرْب﴾ نَصِيب مِن الماء"
  26,156,"﴿ولا تَمَسُّوها بِسُوءٍ فَيَأْخُذكُمْ عَذاب يَوْم عَظِيم﴾ بِعِظَمِ العَذاب"
  26,157,"﴿فَعَقَرُوها﴾ عَقَرَها بَعْضهمْ بِرِضاهُمْ ﴿فَأَصْبَحُوا نادِمِينَ﴾ عَلى عَقْرها"
  26,158,"﴿فَأَخَذَهُمْ العَذاب﴾ المَوْعُود بِهِ فَهَلَكُوا"
  26,159,""