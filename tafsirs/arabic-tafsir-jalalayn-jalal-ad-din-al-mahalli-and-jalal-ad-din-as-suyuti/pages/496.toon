tafsir[18]{c,v,t}:
  44,1,"سُورَة الدُّخان [ مَكِّيَّة إلّا آيَة ١٥ وآياتها ٥٦ أوْ ٥٧ أوْ ٥٩ ]﴿حم﴾ اللَّه أعْلَم بِمُرادِهِ بِهِ"
  44,2,"﴿والكِتاب﴾ القُرْآن ﴿المُبِين﴾ المُظْهِر الحَلال مِن الحَرام"
  44,3,"﴿إنّا أنْزَلْناهُ فِي لَيْلَة مُبارَكَة﴾ هِيَ لَيْلَة القَدْر أوْ لَيْلَة النِّصْف مِن شَعْبان نَزَلَ فِيها مِن أُمّ الكِتاب مِن السَّماء السّابِعَة إلى سَماء الدُّنْيا ﴿إنّا كُنّا مُنْذِرِينَ﴾ مُخَوِّفِينَ بِهِ"
  44,4,"﴿فِيها﴾ أيْ فِي لَيْلَة القَدْر أوْ لَيْلَة النِّصْف مِن شَعْبان ﴿يُفْرَق﴾ يُفْصَل ﴿كُلّ أمْر حَكِيم﴾ مُحَكَّم مِن الأَرْزاق والآجال وغَيْرهما الَّتِي تَكُون فِي السَّنَة إلى مِثْل تِلْكَ اللَّيْلَة"
  44,5,"﴿أمْرًا﴾ فَرْقًا ﴿مِن عِنْدنا إنّا كُنّا مُرْسِلِينَ﴾ الرُّسُل مُحَمَّدًا ومَن قَبْله"
  44,6,"﴿رَحْمَة﴾ رَأْفَة بِالمُرْسَلِ إلَيْهِمْ ﴿مِن رَبّك إنّهُ هُوَ السَّمِيع﴾ لِأَقْوالِهِمْ ﴿العَلِيم﴾ بِأَفْعالِهِمْ"
  44,7,"﴿رَبّ السَّمَوات والأَرْض وما بَيْنهما﴾ بِرَفْعِ رَبّ خَبَر ثالِث وبِجَرِّهِ بَدَل مِن رَبّك ﴿إنْ كُنْتُمْ﴾ يا أهْل مَكَّة ﴿مُوقِنِينَ﴾ بِأَنَّهُ تَعالى رَبّ السَّماوات والأَرْض فَأَيْقَنُوا بِأَنَّ مُحَمَّدًا رَسُوله"
  44,8,""
  44,9,"﴿بَلْ هُمْ فِي شَكّ﴾ مِن البَعْث ﴿يَلْعَبُونَ﴾ اسْتِهْزاء بِك يا مُحَمَّد فَقالَ: \"اللَّهُمَّ أعِنِّي عَلَيْهِمْ بِسَبْعٍ كَسَبْعِ يُوسُف\""
  44,10,"﴿فارْتَقِبْ يَوْم تَأْتِي السَّماء بِدُخانٍ مُبِين﴾ فَأَجْدَبَتْ الأَرْض واشْتَدَّ بِهِمْ الجُوع إلى أنْ رَأَوْا مِن شِدَّته كَهَيْئَةِ الدُّخان بَيْن السَّماء والأَرْض"
  44,11,"﴿يَغْشى النّاس﴾ فَقالُوا ﴿هَذا عَذاب ألِيم﴾"
  44,12,"﴿رَبّنا اكْشِفْ عَنّا العَذاب إنّا مُؤْمِنُونَ﴾ مُصَدِّقُونَ نَبِيّك"
  44,13,"﴿أنّى لَهُمْ الذِّكْرى﴾ أيْ لا يَنْفَعهُمْ الإيمان عِنْد نُزُول العَذاب ﴿وقَدْ جاءَهُمْ رَسُول مُبِين﴾ بَيِّن الرِّسالَة"
  44,14,"﴿ثُمَّ تَوَلَّوْا عَنْهُ وقالُوا مُعَلَّم﴾ أيْ يُعَلِّمهُ القُرْآن بَشَر"
  44,15,"﴿إنّا كاشِفُوا العَذاب﴾ أيْ الجُوع عَنْكُمْ زَمَنًا ﴿قَلِيلًا﴾ فَكَشَفَ عَنْهُمْ ﴿إنّكُمْ عائِدُونَ﴾ إلى كُفْركُمْ فَعادُوا إلَيْهِ"
  44,16,"اُذْكُرْ ﴿يَوْم نَبْطِش البَطْشَة الكُبْرى﴾ هُوَ يَوْم بَدْر والبَطْش الأَخْذ بِقُوَّةٍ ﴿إنّا مُنْتَقِمُونَ﴾ مِنهُمْ"
  44,17,"﴿ولَقَدْ فَتَنّا﴾ بَلَوْنا ﴿قَبْلهمْ قَوْم فِرْعَوْن﴾ مَعَهُ ﴿وجاءَهُمْ رَسُول﴾ هُوَ مُوسى عَلَيْهِ السَّلام ﴿كَرِيم﴾ عَلى اللَّه تَعالى"
  44,18,"﴿أنْ﴾ أيْ بِأَنْ ﴿أدُّوا إلَيَّ﴾ ما أدْعُوكُمْ إلَيْهِ مِن الإيمان أيْ أظْهِرُوا إيمانكُمْ لِي يا ﴿عِباد اللَّه إنِّي لَكُمْ رَسُول أمِين﴾ عَلى ما أُرْسِلْت بِهِ"