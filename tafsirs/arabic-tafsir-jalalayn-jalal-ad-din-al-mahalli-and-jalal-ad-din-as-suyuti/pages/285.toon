tafsir[11]{c,v,t}:
  17,28,"﴿وإمّا تُعْرِضَنَّ عَنْهُمْ﴾ أيْ المَذْكُورِينَ مِن ذِي القُرْبى وما بَعْدهمْ فَلَمْ تُعْطِهِمْ ﴿ابْتِغاء رَحْمَة مِن رَبّك تَرْجُوها﴾ أيْ لِطَلَبِ رِزْق تَنْتَظِرهُ يَأْتِيك فَتُعْطِيهِمْ مِنهُ ﴿قَوْلًا مَيْسُورًا﴾ لَيِّنًا سَهْلًا بِأَنْ تَعِدهُمْ بِالإعْطاءِ عِنْد مَجِيء الرِّزْق"
  17,29,"﴿ولا تَجْعَل يَدك مَغْلُولَة إلى عُنُقك﴾ أيْ لا تُمْسِكها عَنْ الإنْفاق كُلّ المَسْك ﴿ولا تَبْسُطها﴾ فِي الإنْفاق ﴿كُلّ البَسْط فَتَقْعُد مَلُومًا﴾ راجِع لِلْأَوَّلِ ﴿مَحْسُورًا﴾ مُنْقَطِعًا لا شَيْء عِنْدك راجِع لِلثّانِي"
  17,30,"﴿إنّ رَبّك يَبْسُط الرِّزْق﴾ يُوَسِّعهُ ﴿ويَقْدِر﴾ يُضَيِّقهُ لِمَن يَشاء ﴿إنّهُ كانَ بِعِبادِهِ خَبِيرًا بَصِيرًا﴾ عالِمًا بِبَواطِنِهِمْ وظَواهِرهمْ فَيَرْزُقهُمْ عَلى حَسَب مَصالِحهمْ"
  17,31,"﴿ولا تَقْتُلُوا أوْلادكُمْ﴾ بِالوَأْدِ ﴿خَشْيَة﴾ مَخافَة ﴿إمْلاق﴾ فَقْر ﴿خِطْئًا﴾ إثْمًا ﴿كَبِيرًا﴾ عَظِيمًا"
  17,32,"﴿تَقْرَبُوا﴾ أبْلَغ مِن لا تَأْتُوهُ ﴿فاحِشَة﴾ قَبِيحًا ﴿وساءَ﴾ بِئْسَ ﴿سَبِيلًا﴾ طَرِيقًا هُوَ"
  17,33,"﴿لِوَلِيِّهِ﴾ لِوارِثِهِ ﴿سُلْطانًا﴾ تَسَلُّطًا عَلى القاتِل ﴿فَلا يُسْرِف﴾ يَتَجاوَز الحَدّ ﴿فِي القَتْل﴾ بِأَنْ يَقْتُل غَيْر قاتِله أوْ بِغَيْرِ ما قُتِلَ بِهِ"
  17,34,"﴿وأَوْفُوا بِالعَهْدِ﴾ إذا عاهَدْتُمْ اللَّه أوْ النّاس ﴿مَسْئُولًا﴾ مَسْئُولًا عَنْهُ"
  17,35,"﴿وأَوْفُوا الكَيْل﴾ أتِمُّوهُ ﴿بِالقِسْطاسِ المُسْتَقِيم﴾ المِيزان السَّوِيّ ﴿ذَلِكَ خَيْر وأَحْسَن تَأْوِيلًا﴾ مَآلًا"
  17,36,"﴿ولا تَقْفُ﴾ تَتْبَع والفُؤاد القَلْب ﴿كُلّ أُولَئِكَ كانَ عَنْهُ مَسْئُولًا﴾ مَسْئُولًا عَنْهُ صاحِبه ماذا فَعَلَ بِهِ"
  17,37,"﴿ولا تَمْشِ فِي الأَرْض مَرَحًا﴾ أيْ ذا مَرَح بِالكِبْرِ والخُيَلاء ﴿إنّك لَنْ تَخْرِق الأَرْض﴾ تَثْقُبها حَتّى تَبْلُغ آخِرها بِكِبْرِك ﴿ولَنْ تَبْلُغ الجِبال طُولًا﴾ المَعْنى أنَّك لا تَبْلُغ هَذا المَبْلَغ فَكَيْفَ تَخْتال"
  17,38,"﴿كُلّ ذَلِكَ﴾ المَذْكُور"