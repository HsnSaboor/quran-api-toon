tafsir[11]{c,v,t}:
  17,39,"﴿ذَلِكَ مِمّا أوْحى إلَيْك﴾ يا مُحَمَّد ﴿الحِكْمَة﴾ المَوْعِظَة ﴿مَدْحُورًا﴾ مَطْرُودًا عَنْ رَحْمَة اللَّه"
  17,40,"﴿أفَأَصْفاكُمْ﴾ أخْلَصَكُمْ يا أهْل مَكَّة ﴿إناثًا﴾ بَنات لِنَفْسِهِ بِزَعْمِكُمْ ﴿إنّكُمْ لَتَقُولُونَ﴾ لَتَقُولُونَ بِذَلِكَ"
  17,41,"﴿ولَقَدْ صَرَّفْنا﴾ بَيَّنّا ﴿فِي هَذا القُرْآن﴾ مِن الأَمْثال والوَعْد والوَعِيد ﴿لِيَذَّكَّرُوا﴾ يَتَّعِظُوا ﴿وما يَزِيدهُمْ﴾ ما يَزِيدهُمْ ذَلِكَ ﴿إلّا نُفُورًا﴾ عَنْ الحَقّ"
  17,42,"﴿قُلْ﴾ لَهُمْ ﴿لَوْ كانَ مَعَهُ﴾ أيْ اللَّه ﴿لابْتَغَوْا﴾ طَلَبُوا ﴿إلى ذِي العَرْش﴾ أيْ اللَّه ﴿سَبِيلًا﴾ لِيُقاتِلُوهُ"
  17,43,"﴿سُبْحانه﴾ تَنْزِيهًا لَهُ ﴿وتَعالى عَمّا يَقُولُونَ﴾ مِن الشُّرَكاء"
  17,44,"﴿تُسَبِّح لَهُ﴾ تُنَزِّههُ ﴿وإنْ﴾ ما ﴿مِن شَيْء﴾ مِن المَخْلُوقات ﴿إلّا يُسَبِّح﴾ مُتَلَبِّسًا بِحَمْدِهِ ﴿بِحَمْدِهِ﴾ أيْ يَقُول سُبْحان اللَّه وبِحَمْدِهِ ﴿ولَكِنْ لا تَفْقَهُونَ﴾ تَفْهَمُونَ ﴿تَسْبِيحهمْ﴾ لِأَنَّهُ لَيْسَ بِلُغَتِكُمْ ﴿إنّهُ كانَ حَلِيمًا غَفُورًا﴾ حَيْثُ لَمْ يُعاجِلكُمْ بِالعُقُوبَةِ"
  17,45,"﴿مَسْتُورًا﴾ أيْ ساتِرًا لَك عَنْهُمْ فَلا يَرَوْنَك نَزَلَ فِيمَن أرادَ الفَتْك بِهِ ﷺ"
  17,46,"﴿أكِنَّة﴾ أغْطِيَة ﴿أنْ يَفْقَهُوهُ﴾ مِن أنْ يَفْهَمُوا القُرْآن أيْ فَلا يَفْهَمُونَهُ ﴿وفِي آذانهمْ وقْرًا﴾ ثِقَلًا فَلا يَسْمَعُونَهُ ﴿نُفُورًا﴾ نُفُورًا عَنْهُ"
  17,47,"﴿بِهِ﴾ بِسَبَبِهِ مِن الهُزْء ﴿إذْ يَسْتَمِعُونَ إلَيْك﴾ إلى قِراءَتك ﴿وإذْ هُمْ نَجْوى﴾ يَتَناجَوْنَ بَيْنهمْ أيْ يَتَحَدَّثُونَ ﴿إذْ﴾ بَدَل مِن إذْ قَبْله ﴿يَقُول الظّالِمُونَ﴾ فِي تَناجِيهمْ ﴿إنْ﴾ ما ﴿مَسْحُورًا﴾ مَخْدُوعًا مَغْلُوبًا عَلى عَقْله"
  17,48,"﴿اُنْظُرْ كَيْفَ ضَرَبُوا لَك الأَمْثال﴾ بِالمَسْحُورِ والكاهِن والشّاعِر ﴿فَضَلُّوا﴾ بِذَلِكَ عَنْ الهُدى ﴿فَلا يَسْتَطِيعُونَ سَبِيلًا﴾ طَرِيقًا إلَيْهِ"
  17,49,"﴿وقالُوا﴾ مُنْكِرِينَ لِلْبَعْثِ"