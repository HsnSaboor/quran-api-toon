tafsir[27]{c,v,t}:
  55,41,"﴿يُعْرَف المُجْرِمُونَ بِسِيماهُمْ﴾ سَواد الوُجُوه وزُرْقَة العُيُون ﴿فَيُؤْخَذ بِالنَّواصِي والأَقْدام﴾ ﴿فَبِأَيِّ آلاء رَبّكُما تُكَذِّبانِ﴾ تُضَمّ ناصِيَة كُلّ مِنهُمْ إلى قَدَمَيْهِ مِن خَلْف أوْ قُدّام ويُلْقى فِي النّار ويُقال لَهُمْ: ﴿هَذِهِ جَهَنَّم الَّتِي يُكَذِّب بِها المُجْرِمُونَ﴾"
  55,42,""
  55,43,"55:42"
  55,44,"﴿يَطُوفُونَ﴾ يَسْعَوْنَ ﴿بَيْنها وبَيْن حَمِيم﴾ ماء حارّ ﴿آنٍ﴾ شَدِيد الحَرارَة يُسْقَوْنَهُ إذا اسْتَغاثُوا مِن حَرّ النّار وهُوَ مَنقُوص كَقاضٍ"
  55,45,""
  55,46,"﴿ولِمَن خافَ﴾ أيْ لِكُلٍّ مِنهُمْ أوْ لِمَجْمُوعِهِمْ ﴿مَقام رَبّه﴾ قِيامه بَيْن يَدَيْهِ لِلْحِسابِ فَتَرَكَ مَعْصِيَته"
  55,47,""
  55,48,"﴿ذَواتا﴾ تَثْنِيَة ذَوات عَلى الأَصْل ولامها ياء ﴿أفْنان﴾ أغْصان جَمْع فَنَن كَطَلَلٍ"
  55,49,""
  55,50,"55:49"
  55,51,"55:49"
  55,52,"﴿فِيهِما مِن كُلّ فاكِهَة﴾ فِي الدُّنْيا أوْ كُلّ ما يُتَفَكَّه بِهِ ﴿زَوْجانِ﴾ نَوْعانِ رَطْب ويابِس والمُرّ مِنهُما فِي الدُّنْيا كالحَنْظَلِ حُلْو"
  55,53,""
  55,54,"﴿مُتَّكِئِينَ﴾ حال عامِله مَحْذُوف أيْ يَتَنَعَّمُونَ ﴿عَلى فُرُش بَطائِنها مِن إسْتَبْرَق﴾ ما غَلُظَ مِن الدِّيباج وخَشُنَ والظَّهائِر مِن السُّنْدُس ﴿وجَنى الجَنَّتَيْنِ﴾ ثَمَرهما ﴿دانٍ﴾ قَرِيب يَنالهُ القائِم والقاعِد والمُضْطَجِع"
  55,55,""
  55,56,"﴿فِيهِنَّ﴾ فِي الجَنَّتَيْنِ وما اشْتَمَلَتا عَلَيْهِ مِن العَلالِيّ والقُصُور ﴿قاصِرات الطَّرْف﴾ العَيْن عَلى أزْواجهنَّ المُتَّكِئِينَ مِن الإنْس والجِنّ ﴿لَمْ يَطْمِثهُنَّ﴾ يَفْتَضّهُنَّ وهُنَّ مِن الحُور أوْ مِن نِساء الدُّنْيا المُنْشَآت"
  55,57,""
  55,58,"﴿كَأَنَّهُنَّ الياقُوت﴾ مِن صَفاء ﴿والمَرْجان﴾ اللُّؤْلُؤ بَياضًا"
  55,59,""
  55,60,"﴿هَلْ﴾ ما ﴿جَزاء الإحْسان﴾ بِالطّاعَةِ ﴿إلّا الإحْسان﴾ بِالنَّعِيمِ"
  55,61,""
  55,62,"﴿ومِن دُونهما﴾ مِن دُون الجَنَّتَيْنِ المَذْكُورَتَيْنِ ﴿جَنَّتانِ﴾ أيْضًا لِمَن خافَ مَقام رَبّه"
  55,63,""
  55,64,"﴿مُدْهامَّتانِ﴾ سَوْداوانِ مِن شِدَّة خُضْرَتهما"
  55,65,""
  55,66,"﴿فِيهِما عَيْنانِ نَضّاخَتانِ﴾ فَوّارَتانِ بِالماءِ"
  55,67,""