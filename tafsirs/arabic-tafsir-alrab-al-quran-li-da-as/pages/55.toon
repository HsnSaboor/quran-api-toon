tafsir[78]{c,v,t}:
  55,1,"﴿الرَّحْمنُ﴾ مبتدأ ﴿عَلَّمَ الْقُرْآنَ﴾ ماض ومفعوله والفاعل مستتر والجملة خبر المبتدأ ﴿خَلَقَ الْإِنْسانَ﴾ ماض ومفعوله والفاعل مستتر والجملة خبر ثان ﴿عَلَّمَهُ الْبَيانَ﴾ ماض ومفعوله والفاعل مستتر والبيان مفعوله الثاني والجملة خبر ثالث."
  55,2,"55:1"
  55,3,"55:1"
  55,4,"55:1"
  55,5,"﴿الشَّمْسُ﴾ مبتدأ ﴿وَالْقَمَرُ﴾ معطوف عليه ﴿بِحُسْبانٍ﴾ خبر المبتدأ والجملة استئنافية لا محل لها."
  55,6,"﴿وَالنَّجْمُ﴾ مبتدأ ﴿وَالشَّجَرُ﴾ معطوف عليه ﴿يَسْجُدانِ﴾ مضارع مرفوع والألف فاعله والجملة الفعلية خبر المبتدأ والجملة الاسمية معطوفة على ما قبلها."
  55,7,"﴿وَالسَّماءَ﴾ حرف عطف ومفعول به لفعل محذوف يفسره المذكور ﴿رَفَعَها﴾ ماض ومفعوله والفاعل مستتر والجملة الفعلية تفسيرية لا محل لها والجملة المقدرة معطوفة على ما قبلها ﴿وَوَضَعَ الْمِيزانَ﴾ معطوف على ما قبله."
  55,8,"﴿أَلَّا﴾ أن حرف مصدري ونصب ولا نافية، ﴿تَطْغَوْا﴾ مضارع منصوب بأن والواو فاعله ﴿فِي الْمِيزانِ﴾ متعلقان بالفعل وأن وما بعدها في تأويل مصدر في محل جر بحرف جر مقدر والجار والمجرور متعلقان بوضع."
  55,9,"﴿وَأَقِيمُوا﴾ أمر مبني على حذف النون والواو فاعله ﴿الْوَزْنَ﴾ مفعول به ﴿بِالْقِسْطِ﴾ متعلقان بالفعل والجملة معطوفة على ما قبلها ﴿وَلا تُخْسِرُوا﴾ الواو حرف عطف ومضارع مجزوم بلا الناهية والواو فاعله ﴿الْمِيزانَ﴾ مفعول به والجملة معطوفة على ما قبلها."
  55,10,"﴿وَالْأَرْضَ﴾ مفعول به لفعل محذوف يفسره المذكور والجملة المقدرة معطوفة على ما قبلها ﴿وَضَعَها﴾ ماض ومفعوله والفاعل مستتر ﴿لِلْأَنامِ﴾ متعلقان بالفعل والجملة تفسيرية لا محل لها."
  55,11,"﴿فِيها﴾ خبر مقدم ﴿فاكِهَةٌ﴾ مبتدأ مؤخر والجملة استئنافية لا محل لها ﴿وَالنَّخْلُ﴾ معطوف على فاكهة ﴿ذاتُ﴾ صفة ﴿الْأَكْمامِ﴾ مضاف إليه."
  55,12,"﴿وَالْحَبُّ﴾ معطوف على فاكهة ﴿ذُو﴾ صفة ﴿الْعَصْفِ﴾ مضاف إليه ﴿وَالرَّيْحانُ﴾ معطوف على ما قبله."
  55,13,"﴿فَبِأَيِّ﴾ الفاء الفصيحة وبأي متعلقان بتكذبان ﴿آلاءِ﴾ مضاف إليه ﴿رَبِّكُما﴾ مضاف إليه ﴿تُكَذِّبانِ﴾ مضارع مرفوع والألف فاعله والجملة جواب شرط مقدر لا محل لها."
  55,14,"﴿خَلَقَ الْإِنْسانَ﴾ ماض ومفعوله والفاعل مستتر والجملة استئنافية لا محل لها ﴿مِنْ صَلْصالٍ﴾ متعلقان بالفعل ﴿كَالْفَخَّارِ﴾ متعلقان بمحذوف صفة صلصال."
  55,15,"﴿وَخَلَقَ الْجَانَّ مِنْ مارِجٍ﴾ إعرابها كسابقتها ﴿مِنْ نارٍ﴾ صفة مارج والجملة معطوفة على ما قبلها."
  55,16,"انظر الآية- 13-."
  55,17,"﴿رَبُّ﴾ خبر لمبتدأ محذوف مضاف إلى المشرقين ﴿الْمَشْرِقَيْنِ﴾ مضاف إليه ﴿وَرَبُّ الْمَغْرِبَيْنِ﴾ معطوف على ما قبله والجملة استئنافية لا محل لها."
  55,18,"انظر الآية- 13-."
  55,19,"﴿مَرَجَ الْبَحْرَيْنِ﴾ ماض ومفعوله والفاعل مستتر والجملة استئنافية ﴿يَلْتَقِيانِ﴾ مضارع مرفوع والألف فاعله والجملة حال."
  55,20,"﴿بَيْنَهُما بَرْزَخٌ﴾ خبر مقدم ومبتدأ مؤخر والجملة استئنافية لا محل لها ﴿لا﴾ نافية و ﴿يَبْغِيانِ﴾ مضارع مرفوع والألف فاعله والجملة حال."
  55,21,"انظر الآية- 13-."
  55,22,"﴿يَخْرُجُ﴾ مضارع مرفوع ﴿مِنْهُمَا﴾ متعلقان بالفعل ﴿اللُّؤْلُؤُ﴾ فاعل مرفوع ﴿وَالْمَرْجانُ﴾ معطوف على اللؤلؤ والجملة استئنافية لا محل لها."
  55,23,"انظر الآية- 13-."
  55,24,"﴿وَلَهُ﴾ خبر مقدم ﴿الْجَوارِ﴾ مبتدأ مؤخر مرفوع بالضمة المقدرة على الياء المحذوفة والجملة الاسمية استئنافية لا محل لها ﴿الْمُنْشَآتُ﴾ صفة الجوار ﴿فِي الْبَحْرِ﴾ متعلقان بالمنشئات ﴿كَالْأَعْلامِ﴾ متعلقان بمحذوف حال."
  55,25,"انظر الآية- 13-."
  55,26,"﴿كُلُّ مَنْ﴾ مبتدأ مضاف إلى اسم الموصول واسم الموصول مضاف إليه و ﴿عَلَيْها﴾ متعلقان بمحذوف صلة الموصول ﴿فانٍ﴾ خبر المبتدأ مرفوع بالضمة على الياء المحذوفة وهو اسم منقوص والجملة استئنافية لا محل لها."
  55,27,"﴿وَيَبْقى وَجْهُ﴾ مضارع وفاعله ﴿رَبِّكَ﴾ مضاف إليه ﴿ذُو﴾ صفة وجه مضاف ﴿الْجَلالِ﴾ مضاف إليه ﴿وَالْإِكْرامِ﴾ معطوف على الجلال والجملة معطوفة على ما قبلها."
  55,28,"انظر الآية- 13-."
  55,29,"﴿يَسْئَلُهُ﴾ مضارع ومفعوله ﴿مَنْ﴾ فاعله ﴿فِي السَّماواتِ﴾ متعلقان بمحذوف صلة الموصول ﴿وَالْأَرْضِ﴾ معطوف على السموات والجملة استئنافية لا محل لها. ﴿كُلَّ﴾ ظرف مضاف ﴿يَوْمٍ﴾ مضاف إليه ﴿هُوَ﴾ مبتدأ ﴿فِي شَأْنٍ﴾ خبر."
  55,30,"انظر الآية- 13-."
  55,31,"﴿سَنَفْرُغُ﴾ السين للاستقبال ومضارع فاعله مستتر والجملة استئنافية لا محل لها ﴿لَكُمْ﴾ متعلقان بالفعل ﴿أَيُّهَ﴾ منادى نكرة مقصودة ﴿الثَّقَلانِ﴾ بدل وجملة النداء استئنافية لا محل لها."
  55,32,"انظر الآية- 13-."
  55,33,"﴿يا مَعْشَرَ﴾ منادى مضاف ﴿الْجِنِّ﴾ مضاف إليه ﴿وَالْإِنْسِ﴾ معطوف عليه والجملة استئنافية لا محل لها ﴿إِنِ اسْتَطَعْتُمْ﴾ إن حرف شرط وماض في محل جزم فعل الشرط والتاء فاعله والجملة ابتدائية لا محل لها ﴿أَنْ تَنْفُذُوا﴾ مضارع منصوب بأن وعلامة نصبه حذف النون والواو فاعله والمصدر المؤول من أن وما بعدها في محل نصب مفعول به لاستطعتم ﴿مِنْ أَقْطارِ﴾ متعلقان بالفعل ﴿السَّماواتِ﴾ مضاف إليه ﴿وَالْأَرْضِ﴾ معطوف على السموات ﴿فَانْفُذُوا﴾ الفاء واقعة في جواب الشرط وأمر وفاعله والجملة في محل جزم جواب الشرط ﴿لا﴾ نافية ﴿تَنْفُذُونَ﴾ مضارع مرفوع والواو فاعله والجملة استئنافية لا محل لها ﴿إِلَّا﴾ حرف حصر ﴿بِسُلْطانٍ﴾ متعلقان بالفعل."
  55,34,"سبق إعرابها."
  55,35,"﴿يُرْسَلُ﴾ مضارع مبني للمجهول ﴿عَلَيْكُما﴾ متعلقان بالفعل ﴿شُواظٌ﴾ نائب فاعل والجملة استئنافية لا محل لها ﴿مِنْ نارٍ﴾ صفة شواظ ﴿وَنُحاسٌ﴾ معطوف على شواظ ﴿فَلا﴾ الفاء حرف عطف ولا نافية ﴿تَنْتَصِرانِ﴾ مضارع مرفوع والألف فاعله والجملة معطوفة على ما قبلها."
  55,36,"سبق إعرابها."
  55,37,"﴿فَإِذَا﴾ الفاء حرف استئناف وإذا ظرفية شرطية غير جازمة ﴿انْشَقَّتِ السَّماءُ﴾ ماض وفاعله والجملة في محل جر بالإضافة ﴿فَكانَتْ﴾ الفاء حرف عطف وماض ناقص اسمه مستتر ﴿وَرْدَةً﴾ خبره والجملة معطوفة على ما قبلها ﴿كَالدِّهانِ﴾ صفة وردة."
  55,38,"سبق إعرابها."
  55,39,"﴿فَيَوْمَئِذٍ﴾ الفاء واقعة في جواب الشرط ويومئذ ظرف زمان مضاف إلى إذ ﴿لا﴾ نافية ﴿يُسْئَلُ﴾ مضارع مبني للمجهول ﴿عَنْ ذَنْبِهِ﴾ متعلقان بالفعل ﴿إِنْسٌ﴾ نائب فاعل والجملة الفعلية جواب الشرط ﴿وَلا جَانٌّ﴾ معطوف على إنس."
  55,40,"سبق إعرابها."
  55,41,"﴿يُعْرَفُ الْمُجْرِمُونَ﴾ مضارع مبني للمجهول ونائب فاعل مرفوع بالواو والجملة استئنافية لا محل لها ﴿بِسِيماهُمْ﴾ متعلقان بالفعل. ﴿فَيُؤْخَذُ﴾ مضارع مبني للمجهول ﴿بِالنَّواصِي﴾ جار ومجرور بمنزلة نائب الفاعل ﴿وَالْأَقْدامِ﴾ معطوف على النواصي والجملة معطوفة على ما قبلها."
  55,42,"سبق إعرابها."
  55,43,"﴿هذِهِ جَهَنَّمُ﴾ مبتدأ وخبره والجملة مقول القول لقول محذوف ﴿الَّتِي﴾ صفة جهنم ﴿يُكَذِّبُ﴾ مضارع ﴿بِهَا﴾ متعلقان بالفعل ﴿الْمُجْرِمُونَ﴾ فاعل مرفوع بالواو والجملة صلة."
  55,44,"﴿يَطُوفُونَ﴾ مضارع مرفوع والواو فاعله والجملة حال ﴿بَيْنَها﴾ ظرف مكان ﴿وَبَيْنَ﴾ معطوف على بينها ﴿حَمِيمٍ﴾ مضاف إليه ﴿آنٍ﴾ صفة حميم مجرور بالكسرة المقدرة على الياء المحذوفة."
  55,45,"سبق إعرابها."
  55,46,"﴿وَلِمَنْ﴾ الواو استئنافية وخبر مقدم ﴿خافَ﴾ ماض فاعله مستتر ﴿مَقامَ﴾ مفعول به ﴿رَبِّهِ﴾ مضاف إليه ﴿جَنَّتانِ﴾ مبتدأ مؤخر والجملة الفعلية صلة من والجملة الاسمية استئنافية لا محل لها."
  55,47,"سبق إعرابها."
  55,48,"﴿ذَواتا﴾ صفة جنتان ﴿أَفْنانٍ﴾ مضاف إليه."
  55,49,"سبق إعرابها."
  55,50,"﴿فِيهِما﴾ خبر مقدم ﴿عَيْنانِ﴾ مبتدأ مؤخر والجملة الاسمية لا محل لها ﴿تَجْرِيانِ﴾ مضارع مرفوع والألف فاعله والجملة صفة عينان."
  55,51,"﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾ سبق إعرابها."
  55,52,"﴿فِيهِما﴾ خبر مقدم ﴿مِنْ كُلِّ﴾ متعلقان بمحذوف حال ﴿فاكِهَةٍ﴾ مضاف إليه ﴿زَوْجانِ﴾ مبتدأ مؤخر والجملة الاسمية استئنافية لا محل لها."
  55,53,"سبق إعرابها."
  55,54,"﴿مُتَّكِئِينَ﴾ حال منصوبة بالياء ﴿عَلى فُرُشٍ﴾ متعلقان بما قبلهما ﴿بَطائِنُها﴾ مبتدأ ﴿مِنْ إِسْتَبْرَقٍ﴾ خبر والجملة صفة فرش ﴿وَجَنَى﴾ الواو حالية ومبتدأ مضاف ﴿الْجَنَّتَيْنِ﴾ مضاف إليه ﴿دانٍ﴾ خبر والجملة حالية."
  55,55,"سبق إعرابها."
  55,56,"﴿فِيهِنَّ﴾ خبر مقدم ﴿قاصِراتُ﴾ مبتدأ مؤخر مضاف ﴿الطَّرْفِ﴾ مضاف إليه ﴿لَمْ يَطْمِثْهُنَّ﴾ مضارع مجزوم بلم والهاء مفعوله ﴿إِنْسٌ﴾ فاعله والجملة الفعلية حال ﴿قَبْلَهُمْ﴾ ظرف زمان ﴿وَلا جَانٌّ﴾ معطوف على إنس."
  55,57,"سبق إعرابها."
  55,58,"﴿كَأَنَّهُنَّ﴾ كأن واسمها ﴿الْياقُوتُ﴾ خبرها ﴿وَالْمَرْجانُ﴾ معطوف على الياقوت والجملة حال."
  55,59,"سبق إعرابها."
  55,60,"﴿هَلْ﴾ حرف استفهام ﴿جَزاءُ الْإِحْسانِ﴾ مبتدأ مضاف إلى الإحسان ﴿إِلَّا﴾ حرف حصر ﴿الْإِحْسانِ﴾ خبر والجملة استئنافية لا محل لها."
  55,61,"سبق إعرابها."
  55,62,"﴿وَمِنْ دُونِهِما﴾ خبر مقدم ﴿جَنَّتانِ﴾ مبتدأ مؤخر والجملة استئنافية لا محل لها."
  55,63,"سبق إعرابها."
  55,64,"صفة جنتان."
  55,65,"سبق إعرابها."
  55,66,"ِيهِما»خبر مقدمَ يْنانِ»مبتدأ مؤخرَضَّاخَتانِ»صفة عينان والجملة استئنافية لا محل لها."
  55,67,"سبق إعرابها."
  55,68,"﴿فِيهِما﴾ خبر مقدم ﴿فاكِهَةٌ﴾ مبتدأ مؤخر ﴿وَنَخْلٌ وَرُمَّانٌ﴾ معطوفان على ما قبلهما والجملة استئنافية لا محل لها."
  55,69,"سبق إعرابها."
  55,70,"﴿فِيهِنَّ﴾ خبر مقدم ﴿خَيْراتٌ﴾ مبتدأ مؤخر ﴿حِسانٌ﴾ صفة خيرات والجملة استئنافية لا محل لها."
  55,71,"سبق إعرابها."
  55,72,"﴿حُورٌ﴾ بدل من خيرات ﴿مَقْصُوراتٌ﴾ صفة حور ﴿فِي الْخِيامِ﴾ متعلقان بمقصورات والجملة استئنافية لا محل لها."
  55,73,"تقدم إعرابها."
  55,74,"انظر الآية- 56-."
  55,75,"سبق إعرابها."
  55,76,"﴿مُتَّكِئِينَ﴾ حال ﴿عَلى رَفْرَفٍ﴾ متعلقان بما قبلهما ﴿خُضْرٍ﴾ صفة رفرف ﴿وَعَبْقَرِيٍّ﴾ معطوف على رفرف ﴿حِسانٍ﴾ صفة عبقري."
  55,77,"سبق إعرابها."
  55,78,"﴿تَبارَكَ اسْمُ﴾ ماض وفاعله ﴿رَبِّكَ﴾ مضاف إليه ﴿ذِي﴾ صفة ربك مضاف ﴿الْجَلالِ﴾ مضاف إليه ﴿وَالْإِكْرامِ﴾ معطوف على الجلال والجملة استئنافية لا محل لها."
