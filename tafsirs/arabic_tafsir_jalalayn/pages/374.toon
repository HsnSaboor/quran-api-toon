tafsir[24]{c,v,t}:
  26,160,"26:159"
  26,161,"26:159"
  26,162,"26:159"
  26,163,"26:159"
  26,164,"﴿وما أسْأَلكُمْ عَلَيْهِ مِن أجْر إنْ﴾ ما"
  26,165,"﴿العالَمِينَ﴾ النّاس"
  26,166,"﴿وتَذَرُونَ ما خَلَقَ لَكُمْ رَبّكُمْ مِن أزْواجكُمْ﴾ أيْ أقْبالهنَّ ﴿بَلْ أنْتُمْ قَوْم عادُونَ﴾ مُتَجاوِزُونَ الحَلال إلى الحَرام"
  26,167,"﴿قالُوا لَئِنْ لَمْ تَنْتَهِ يا لُوط﴾ عَنْ إنْكارك عَلَيْنا ﴿لَتَكُونَن مِن المُخْرَجِينَ﴾ مِن بَلْدَتنا"
  26,168,"﴿قالَ﴾ لُوط ﴿إنِّي لِعَمَلِكُمْ مِن القالِينَ﴾ المُبْغَضِينَ"
  26,169,"﴿رَبّ نَجِّنِي وأَهْلِي مِمّا يَعْمَلُونَ﴾ أيْ مِن عَذابه"
  26,170,""
  26,171,"﴿إلّا عَجُوزًا﴾ امْرَأَته ﴿فِي الغابِرِينَ﴾ الباقِينَ أهْلَكْناها"
  26,172,"﴿ثُمَّ دَمَّرْنا الآخَرِينَ﴾ أهْلَكْناهُمْ"
  26,173,"﴿وأَمْطَرْنا عَلَيْهِمْ مَطَرًا﴾ حِجارَة مِن جُمْلَة الإهْلاك ﴿فَساءَ مَطَر المُنْذَرِينَ﴾ مَطَرهمْ"
  26,174,""
  26,175,"26:174"
  26,176,"﴿كَذَّبَ أصْحاب الأَيْكَة﴾ وفِي قِراءَة بِحَذْفِ الهَمْزَة وإلْقاء حَرَكَتها عَلى اللّام وفَتْح الهاء: هِيَ غَيْضَة شَجَر قُرْب مَدْيَن"
  26,177,"﴿إذْ قالَ لَهُمْ شُعَيْب﴾ لَمْ يَقُلْ أخُوهُمْ لِأَنَّهُ لَمْ يَكُنْ مِنهُمْ"
  26,178,""
  26,179,"26:178"
  26,180,"﴿وما أسْأَلكُمْ عَلَيْهِ مِن أجْر إنْ﴾ ما"
  26,181,"﴿أوْفُوا الكَيْل﴾ أتِمُّوهُ ﴿ولا تَكُونُوا مِن المُخْسِرِينَ﴾ النّاقِصِينَ"
  26,182,"﴿وزِنُوا بِالقِسْطاسِ المُسْتَقِيم﴾ المِيزان السَّوِيّ"
  26,183,"﴿ولا تَبْخَسُوا النّاس أشْياءَهُمْ﴾ لا تُنْقِصُوهُمْ مِن حَقّهمْ شَيْئًا ﴿ولا تَعْثَوْا فِي الأَرْض مُفْسِدِينَ﴾ بِالقَتْلِ وغَيْره مِن عَثِيَ بِكَسْرِ المُثَلَّثَة أفْسَدَ ومُفْسِدِينَ حال مُؤَكِّدَة لِمَعْنى عامِلها"