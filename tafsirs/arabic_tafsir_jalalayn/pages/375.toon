tafsir[23]{c,v,t}:
  26,184,"﴿واتَّقُوا الَّذِي خَلَقَكُمْ والجِبِلَّة﴾ الخَلِيقَة"
  26,185,""
  26,186,"﴿وما أنْتَ إلّا بَشَر مِثْلنا وإنْ﴾ مُخَفَّفَة مِن الثَّقِيلَة واسْمها مَحْذُوف أيْ إنّهُ"
  26,187,"﴿فَأَسْقِطْ عَلَيْنا كِسَفًا﴾ بِسُكُونِ السِّين وفَتْحها قِطَعًا ﴿مِن السَّماء إنْ كُنْت مِن الصّادِقِينَ﴾ فِي رِسالَتك"
  26,188,"﴿قالَ رَبِّي أعْلَم بِما تَعْمَلُونَ﴾ فَيُجازِيكُمْ بِهِ"
  26,189,"﴿فَكَذَّبُوهُ فَأَخَذَهُمْ عَذاب يَوْم الظُّلَّة﴾ هِيَ سَحابَة أظَلَّتْهُمْ بَعْد حَرّ شَدِيد أصابَهُمْ فَأَمْطَرَتْ عَلَيْهِمْ نارًا فاحْتَرَقُوا"
  26,190,""
  26,191,"26:190"
  26,192,"﴿وإنَّهُ﴾ أيْ القُرْآن"
  26,193,"﴿نَزَلَ بِهِ الرُّوح الأَمِين﴾ جِبْرِيل"
  26,194,""
  26,195,"﴿بِلِسانٍ عَرَبِيّ مُبِين﴾ بَيِّن وفِي قِراءَة بِتَشْدِيدِ نَزَلَ ونَصْب الرُّوح والفاعِل اللَّه"
  26,196,"﴿وإنَّهُ﴾ ذِكْر القُرْآن المُنَزَّل عَلى مُحَمَّد ﴿لَفِي زُبُر﴾ كُتُب ﴿الأَوَّلِينَ﴾ كالتَّوْراةِ والإنْجِيل"
  26,197,"﴿أوَلَمْ يَكُنْ لَهُمْ﴾ لِكُفّارِ مَكَّة ﴿آيَة﴾ عَلى ذَلِكَ ويَكُنْ بالتحتانية ونَصْب آيَة وبالفوقانية ورَفْع آيَة ﴿أنْ يَعْلَمهُ عُلَماء بَنِي إسْرائِيل﴾ كَعَبْدِ اللَّه بْن سَلام وأَصْحابه مِن الَّذِينَ آمَنُوا يُخْبِرُونَ بِذَلِكَ"
  26,198,"﴿ولَوْ نَزَّلْناهُ عَلى بَعْض الأَعْجَمِينَ﴾ جَمْع أعْجَم"
  26,199,"﴿فَقَرَأَهُ عَلَيْهِمْ﴾ كُفّار مَكَّة ﴿ما كانُوا بِهِ مُؤْمِنِينَ﴾ أنَفَة مِن اتِّباعه"
  26,200,"﴿كَذَلِكَ﴾ أيْ مِثْل إدْخالنا التَّكْذِيب بِهِ بِقِراءَةِ الأَعْجَمِيّ ﴿سَلَكْناهُ﴾ أدْخَلْنا التَّكْذِيب بِهِ ﴿فِي قُلُوب المُجْرِمِينَ﴾ كُفّار مَكَّة بِقِراءَةِ النَّبِيّ"
  26,201,""
  26,202,"26:201"
  26,203,"﴿فَيَقُولُوا هَلْ نَحْنُ مُنْظَرُونَ﴾ لِنُؤْمِن فَيُقال لَهُمْ: لا، قالُوا: مَتى هَذا العَذاب"
  26,204,""
  26,205,"﴿أفَرَأَيْت﴾ أخْبِرْنِي"
  26,206,"﴿ثُمَّ جاءَهُمْ ما كانُوا يُوعَدُونَ﴾ مِن العَذاب"