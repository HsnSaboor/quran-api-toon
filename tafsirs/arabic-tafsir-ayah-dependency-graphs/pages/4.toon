  4,23,"حُرِّمَتْ-->فعل-->عَلَيْ‍‍كُمْ-->حرف جر-->ضمير-->أُمَّهَٰتُ‍‍كُمْ-->اسم-->ضمير-->وَبَنَاتُ‍‍كُمْ-->حرف عطف-->اسم-->ضمير-->جار ومجرور-->-->-->-->-->-->-->مجرور-->متعلق-->نائب فاعل-->مضاف إليه-->معطوف-->مضاف إليه-->-->(-->وَبَنَاتُ‍‍كُمْ-->)-->حرف عطف-->اسم-->ضمير-->وَأَخَوَٰتُ‍‍كُمْ-->حرف عطف-->اسم-->ضمير-->وَعَمَّٰتُ‍‍كُمْ-->حرف عطف-->اسم-->ضمير-->وَخَٰلَٰتُ‍‍كُمْ-->حرف عطف-->اسم-->ضمير-->-->-->-->-->-->-->-->مضاف إليه-->معطوف-->مضاف إليه-->معطوف-->مضاف إليه-->معطوف-->مضاف إليه-->-->(-->وَخَٰلَٰتُ‍‍كُمْ-->)-->حرف عطف-->اسم-->ضمير-->وَبَنَاتُ-->حرف عطف-->اسم-->ٱلْ‍‍أَخِ-->اسم-->وَبَنَاتُ-->حرف عطف-->اسم-->ٱلْ‍‍أُخْتِ-->اسم-->-->-->-->-->-->مضاف إليه-->معطوف-->مضاف إليه-->معطوف-->مضاف إليه-->-->(-->وَبَنَاتُ-->)-->حرف عطف-->اسم-->وَأُمَّهَٰتُ‍‍كُمُ-->حرف عطف-->اسم-->ضمير-->ٱلَّٰتِىٓ-->اسم موصول-->أَرْضَعْ‍‍نَ‍‍كُمْ-->فعل-->ضمير-->ضمير-->جملة فعلية-->-->-->-->-->-->-->معطوف-->مضاف إليه-->صفة-->فاعل-->مفعول به-->صلة-->-->(-->وَأُمَّهَٰتُ‍‍كُمُ-->)-->حرف عطف-->اسم-->ضمير-->وَأَخَوَٰتُ‍‍كُم-->حرف عطف-->اسم-->ضمير-->(*)-->اسم-->مِّنَ-->حرف جر-->ٱل‍‍رَّضَٰعَةِ-->اسم-->جار ومجرور-->-->-->-->-->-->-->مضاف إليه-->معطوف-->مضاف إليه-->حال-->مجرور-->متعلق-->-->(-->وَأَخَوَٰتُ‍‍كُم-->)-->حرف عطف-->اسم-->ضمير-->وَأُمَّهَٰتُ-->حرف عطف-->اسم-->نِسَآئِ‍‍كُمْ-->اسم-->ضمير-->-->-->-->-->مضاف إليه-->معطوف-->مضاف إليه-->مضاف إليه-->-->(-->وَأُمَّهَٰتُ-->)-->حرف عطف-->اسم-->وَرَبَٰٓئِبُ‍‍كُمُ-->حرف عطف-->اسم-->ضمير-->ٱلَّٰتِى-->اسم موصول-->(*)-->اسم-->فِى-->حرف جر-->حُجُورِكُم-->اسم-->ضمير-->مِّن-->حرف جر-->نِّسَآئِ‍‍كُمُ-->اسم-->ضمير-->ٱلَّٰتِى-->اسم موصول-->دَخَلْ‍‍تُم-->فعل-->ضمير-->بِ‍‍هِنَّ-->حرف جر-->ضمير-->جار ومجرور-->جار ومجرور-->جار ومجرور-->جملة فعلية-->-->-->-->-->-->-->-->-->-->-->-->-->-->-->-->معطوف-->مضاف إليه-->صفة-->صلة-->مجرور-->متعلق-->مضاف إليه-->مجرور-->متعلق-->مضاف إليه-->صفة-->فاعل-->مجرور-->متعلق-->صلة-->-->فَ‍‍إِن-->حرف استئنافية-->شرطية-->لَّمْ-->حرف نفي-->تَكُونُ‍‍وا۟-->فعل-->ضمير-->دَخَلْ‍‍تُم-->فعل-->ضمير-->بِ‍‍هِنَّ-->حرف جر-->ضمير-->جار ومجرور-->جملة فعلية-->جملة اسمية-->-->-->-->-->-->-->-->نفي-->اسم «تكون»-->فاعل-->مجرور-->متعلق-->خبر «تكون»-->شرط-->-->(-->فَ‍‍إِن-->)-->حرف استئنافية-->شرطية-->فَ‍‍لَا-->حرف واقع في جواب الشرط-->حرف نفي-->جُنَاحَ-->اسم-->(*)-->اسم-->عَلَيْ‍‍كُمْ-->حرف جر-->ضمير-->جار ومجرور-->جملة اسمية-->-->-->-->-->-->اسم «لا»-->خبر «لا»-->مجرور-->متعلق-->جواب شرط-->-->(-->وَرَبَٰٓئِبُ‍‍كُمُ-->)-->حرف عطف-->اسم-->ضمير-->وَحَلَٰٓئِلُ-->حرف عطف-->اسم-->أَبْنَآئِ‍‍كُمُ-->اسم-->ضمير-->ٱلَّذِينَ-->اسم موصول-->(*)-->اسم-->مِنْ-->حرف جر-->أَصْلَٰبِ‍‍كُمْ-->اسم-->ضمير-->جار ومجرور-->-->-->-->-->-->-->-->-->-->مضاف إليه-->معطوف-->مضاف إليه-->مضاف إليه-->صفة-->صلة-->مجرور-->متعلق-->مضاف إليه-->-->(-->وَحَلَٰٓئِلُ-->)-->حرف عطف-->اسم-->وَأَن-->حرف عطف-->حرف مصدري-->تَجْمَعُ‍‍وا۟-->فعل-->ضمير-->بَيْنَ-->ظرف مكان-->ٱلْ‍‍أُخْتَيْنِ-->اسم-->جملة فعلية-->مصدر مؤول-->-->-->-->-->-->فاعل-->متعلق-->مضاف إليه-->صلة-->معطوف-->-->إِلَّا-->أداة استثناء-->مَا-->اسم موصول-->قَدْ-->حرف تحقيق-->سَلَفَ-->فعل-->(-->هُوَ-->)-->ضمير-->جملة فعلية-->-->-->-->-->مستثني-->تحقيق-->فاعل-->صلة-->-->إِنَّ-->حرف نصب-->ٱللَّهَ-->علم-->كَانَ-->فعل-->(-->هُوَ-->)-->ضمير-->غَفُورًا-->اسم-->رَّحِيمًا-->نعت-->جملة اسمية-->-->-->-->-->-->اسم «ان»-->اسم «كان»-->خبر «كان»-->صفة-->خبر «ان»-->-->

