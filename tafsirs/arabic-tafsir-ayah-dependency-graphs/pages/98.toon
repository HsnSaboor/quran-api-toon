tafsir[8]{c,v,t}:
  98,1,"لَمْ-->حرف نفي-->يَكُنِ-->فعل-->ٱلَّذِينَ-->اسم موصول-->كَفَرُوا۟-->فعل-->ضمير-->(*)-->اسم-->مِنْ-->حرف جر-->أَهْلِ-->اسم-->ٱلْ‍‍كِتَٰبِ-->اسم-->وَٱلْ‍‍مُشْرِكِينَ-->حرف عطف-->اسم-->مُنفَكِّينَ-->اسم-->جار ومجرور-->جملة فعلية-->-->-->-->-->-->-->-->-->-->-->نفي-->اسم «يكن»-->فاعل-->حال-->مجرور-->متعلق-->مضاف إليه-->معطوف-->صلة-->خبر «يكن»-->-->حَتَّىٰ-->حرف جر-->تَأْتِيَ‍‍هُمُ-->فعل-->ضمير-->ٱلْ‍‍بَيِّنَةُ-->اسم-->جملة فعلية-->-->-->-->مفعول به-->فاعل-->مجرور-->-->

