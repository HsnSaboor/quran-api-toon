tafsir[3]{c,v,t}:
  110,1,"إِذَا-->ظرف زمان-->جَآءَ-->فعل-->نَصْرُ-->اسم-->ٱللَّهِ-->علم-->وَٱلْ‍‍فَتْحُ-->حرف عطف-->اسم-->جملة فعلية-->-->-->-->-->فاعل-->مضاف إليه-->معطوف-->شرط-->-->

.tree-bank-container {
  direction: ltr;
}
.tree-bank-container [font-family=""hafs""] {
  font-family: 'hafs-qc'
}
.tree-bank-container [font-family=""Times New Roman""] {
  font-family: 'Kitab'
}
@font-face {
  font-family: 'hafs-qc';
  src: url('https://fonts.nuqayah.com/hafs-qc.woff2');
}"
  110,2,"وَرَأَيْ‍‍تَ-->حرف عطف-->فعل-->ضمير-->ٱل‍‍نَّاسَ-->اسم-->يَدْخُلُ‍‍ونَ-->فعل-->ضمير-->فِى-->حرف جر-->دِينِ-->اسم-->ٱللَّهِ-->علم-->أَفْوَاجًا-->اسم-->جار ومجرور-->-->-->-->-->-->-->-->-->فاعل-->مفعول به-->حال-->فاعل-->مجرور-->متعلق-->مضاف إليه-->حال-->-->

.tree-bank-container {
  direction: ltr;
}
