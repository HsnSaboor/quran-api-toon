tafsir[8]{c,v,t}:
  102,1,"أَلْهَىٰ‍‍كُمُ-->فعل-->ضمير-->ٱل‍‍تَّكَاثُرُ-->اسم-->حَتَّىٰ-->حرف ابتداء-->زُرْتُمُ-->فعل-->ضمير-->ٱلْ‍‍مَقَابِرَ-->اسم-->-->-->-->-->-->مفعول به-->فاعل-->ابتداء-->فاعل-->مفعول به-->-->

.tree-bank-container {
  direction: ltr;
}
.tree-bank-container [font-family=""hafs""] {
  font-family: 'hafs-qc'
}
.tree-bank-container [font-family=""Times New Roman""] {
  font-family: 'Kitab'
}
@font-face {
  font-family: 'hafs-qc';
  src: url('https://fonts.nuqayah.com/hafs-qc.woff2');
}"
  102,2,"102:1"
  102,3,"كَلَّا-->حرف ردع-->سَوْفَ-->حرف استقبال-->تَعْلَمُ‍‍ونَ-->فعل-->ضمير-->(*)-->اسم-->ثُمَّ-->حرف عطف-->كَلَّا-->حرف ردع-->سَوْفَ-->حرف استقبال-->تَعْلَمُ‍‍ونَ-->فعل-->ضمير-->(*)-->اسم-->جملة فعلية-->جملة فعلية-->-->-->-->-->-->-->-->-->-->استقبال-->ردع-->فاعل-->مفعول به-->استقبال-->ردع-->فاعل-->مفعول به-->معطوف-->-->

