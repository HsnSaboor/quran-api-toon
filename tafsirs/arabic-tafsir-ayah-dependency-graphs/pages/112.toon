tafsir[4]{c,v,t}:
  112,1,"قُلْ-->فعل-->(-->أَنتَ-->)-->ضمير-->هُوَ-->ضمير-->ٱللَّهُ-->علم-->أَحَدٌ-->اسم-->جملة اسمية-->-->-->-->-->فاعل-->خبر-->بدل-->مفعول به-->-->

.tree-bank-container {
  direction: ltr;
}
.tree-bank-container [font-family=""hafs""] {
  font-family: 'hafs-qc'
}
.tree-bank-container [font-family=""Times New Roman""] {
  font-family: 'Kitab'
}
@font-face {
  font-family: 'hafs-qc';
  src: url('https://fonts.nuqayah.com/hafs-qc.woff2');
}"
