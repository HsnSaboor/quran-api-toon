tafsir[75]{c,v,t}:
  8,1,"يَسْـَٔلُ‍‍ونَ‍‍كَ-->فعل-->ضمير-->ضمير-->عَنِ-->حرف جر-->ٱلْ‍‍أَنفَالِ-->اسم-->جار ومجرور-->-->-->-->-->فاعل-->مفعول به-->مجرور-->متعلق-->-->قُلِ-->فعل-->(-->أَنتَ-->)-->ضمير-->ٱلْ‍‍أَنفَالُ-->اسم-->(*)-->اسم-->لِ‍‍لَّهِ-->حرف جر-->علم-->وَٱل‍‍رَّسُولِ-->حرف عطف-->اسم-->جار ومجرور-->جملة اسمية-->-->-->-->-->-->-->فاعل-->خبر-->مجرور-->متعلق-->معطوف-->مفعول به-->-->فَ‍‍ٱتَّقُ‍‍وا۟-->حرف استئنافية-->فعل-->ضمير-->ٱللَّهَ-->علم-->وَأَصْلِحُ‍‍وا۟-->حرف عطف-->فعل-->ضمير-->ذَاتَ-->اسم-->بَيْنِ‍‍كُمْ-->اسم-->ضمير-->-->-->-->-->-->-->-->فاعل-->مفعول به-->معطوف-->فاعل-->مفعول به-->مضاف إليه-->مضاف إليه-->-->(-->وَأَصْلِحُ‍‍وا۟-->)-->حرف عطف-->فعل-->ضمير-->وَأَطِيعُ‍‍وا۟-->حرف عطف-->فعل-->ضمير-->ٱللَّهَ-->علم-->وَرَسُولَ‍‍هُۥٓ-->حرف عطف-->اسم-->ضمير-->-->-->-->-->-->-->فاعل-->معطوف-->فاعل-->مفعول به-->معطوف-->مضاف إليه-->-->إِن-->شرطية-->كُن‍‍تُم-->فعل-->ضمير-->مُّؤْمِنِينَ-->اسم-->جملة اسمية-->-->-->-->اسم «كن»-->خبر «كن»-->شرط-->-->

