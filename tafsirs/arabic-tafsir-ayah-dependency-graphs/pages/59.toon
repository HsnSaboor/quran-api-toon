tafsir[24]{c,v,t}:
  59,1,"سَبَّحَ-->فعل-->لِ‍‍لَّهِ-->حرف جر-->علم-->مَا-->اسم موصول-->(*)-->اسم-->فِى-->حرف جر-->ٱل‍‍سَّمَٰوَٰتِ-->اسم-->وَمَا-->حرف عطف-->اسم موصول-->(*)-->اسم-->فِى-->حرف جر-->ٱلْ‍‍أَرْضِ-->اسم-->جار ومجرور-->جار ومجرور-->جار ومجرور-->-->-->-->-->-->-->-->-->-->-->مجرور-->متعلق-->فاعل-->صلة-->مجرور-->متعلق-->معطوف-->صلة-->مجرور-->متعلق-->-->وَهُوَ-->حرف استئنافية-->ضمير-->ٱلْ‍‍عَزِيزُ-->اسم-->ٱلْ‍‍حَكِيمُ-->نعت-->-->-->خبر-->صفة-->-->

