tafsir[3]{c,v,t}:
  103,1,"(*)-->فعل-->وَٱلْ‍‍عَصْرِ-->حرف جر-->اسم-->إِنَّ-->حرف نصب-->ٱلْ‍‍إِنسَٰنَ-->اسم-->(*)-->اسم-->لَ‍‍فِى-->لام (أو نون المثقلة؟) التوكيد-->حرف جر-->خُسْرٍ-->اسم-->جار ومجرور-->جار ومجرور-->-->-->-->-->-->-->-->مجرور-->متعلق-->اسم «ان»-->خبر «ان»-->توكيد-->مجرور-->متعلق-->-->

.tree-bank-container {
  direction: ltr;
}
.tree-bank-container [font-family=""hafs""] {
  font-family: 'hafs-qc'
}
.tree-bank-container [font-family=""Times New Roman""] {
  font-family: 'Kitab'
}
@font-face {
  font-family: 'hafs-qc';
  src: url('https://fonts.nuqayah.com/hafs-qc.woff2');
}"
