tafsir[6]{c,v,t}:
  109,1,"قُلْ-->فعل-->(-->أَنتَ-->)-->ضمير-->يَٰٓ‍‍أَيُّهَا-->حرف نداء-->اسم-->ٱلْ‍‍كَٰفِرُونَ-->اسم-->لَآ-->حرف نفي-->أَعْبُدُ-->فعل-->(-->أَنَا-->)-->ضمير-->مَا-->اسم موصول-->تَعْبُدُونَ-->فعل-->ضمير-->جملة فعلية-->جملة فعلية-->-->-->-->-->-->-->-->-->-->فاعل-->منادي-->بدل-->نفي-->فاعل-->مفعول به-->فاعل-->صلة-->مفعول به-->-->

.tree-bank-container {
  direction: ltr;
}
.tree-bank-container [font-family=""hafs""] {
  font-family: 'hafs-qc'
}
.tree-bank-container [font-family=""Times New Roman""] {
  font-family: 'Kitab'
}
@font-face {
  font-family: 'hafs-qc';
  src: url('https://fonts.nuqayah.com/hafs-qc.woff2');
}"
