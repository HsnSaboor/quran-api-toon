tafsir[12]{c,v,t}:
  65,1,"يَٰٓ‍‍أَيُّهَا-->حرف نداء-->اسم-->ٱل‍‍نَّبِىُّ-->اسم-->-->-->منادي-->بدل-->-->إِذَا-->ظرف زمان-->طَلَّقْ‍‍تُمُ-->فعل-->ضمير-->ٱل‍‍نِّسَآءَ-->اسم-->فَ‍‍طَلِّقُ‍‍وهُنَّ-->حرف واقع في جواب الشرط-->فعل-->ضمير-->ضمير-->لِ‍‍عِدَّتِ‍‍هِنَّ-->حرف جر-->اسم-->ضمير-->جملة فعلية-->جار ومجرور-->جملة فعلية-->-->-->-->-->-->-->-->-->-->فاعل-->مفعول به-->شرط-->فاعل-->مفعول به-->مجرور-->متعلق-->مضاف إليه-->جواب شرط-->-->(-->فَ‍‍طَلِّقُ‍‍وهُنَّ-->)-->حرف واقع في جواب الشرط-->فعل-->ضمير-->ضمير-->وَأَحْصُ‍‍وا۟-->حرف عطف-->فعل-->ضمير-->ٱلْ‍‍عِدَّةَ-->اسم-->-->-->-->-->-->فاعل-->مفعول به-->معطوف-->فاعل-->مفعول به-->-->وَٱتَّقُ‍‍وا۟-->حرف عطف-->فعل-->ضمير-->ٱللَّهَ-->علم-->رَبَّ‍‍كُمْ-->اسم-->ضمير-->-->-->-->-->فاعل-->مفعول به-->بدل-->مضاف إليه-->-->لَا-->حرف نهي-->تُخْرِجُ‍‍وهُنَّ-->فعل-->ضمير-->ضمير-->مِنۢ-->حرف جر-->بُيُوتِ‍‍هِنَّ-->اسم-->ضمير-->جار ومجرور-->-->-->-->-->-->-->نهي-->فاعل-->مفعول به-->مجرور-->متعلق-->مضاف إليه-->-->(-->لَا-->)-->حرف نهي-->وَلَا-->حرف عطف-->حرف نهي-->يَخْرُجْ‍‍نَ-->فعل-->ضمير-->إِلَّآ-->أداة استثناء-->أَن-->حرف مصدري-->يَأْتِي‍‍نَ-->فعل-->ضمير-->بِ‍‍فَٰحِشَةٍ-->حرف جر-->اسم-->مُّبَيِّنَةٍ-->نعت-->جار ومجرور-->جملة فعلية-->-->-->-->-->-->-->-->-->-->معطوف-->نهي-->فاعل-->مستثني-->فاعل-->مجرور-->متعلق-->صفة-->صلة-->-->وَتِلْكَ-->حرف استئنافية-->اسم إشارة-->حُدُودُ-->اسم-->ٱللَّهِ-->علم-->-->-->خبر-->مضاف إليه-->-->وَمَن-->حرف استئنافية-->شرطية-->يَتَعَدَّ-->فعل-->(-->هُوَ-->)-->ضمير-->حُدُودَ-->اسم-->ٱللَّهِ-->علم-->فَ‍‍قَدْ-->حرف واقع في جواب الشرط-->حرف تحقيق-->ظَلَمَ-->فعل-->(-->هُوَ-->)-->ضمير-->نَفْسَ‍‍هُۥ-->اسم-->ضمير-->جملة فعلية-->جملة فعلية-->-->-->-->-->-->-->-->-->-->فاعل-->مفعول به-->مضاف إليه-->شرط-->تحقيق-->فاعل-->مفعول به-->مضاف إليه-->جواب شرط-->-->لَا-->حرف نفي-->تَدْرِى-->فعل-->(-->أَنتَ-->)-->ضمير-->لَعَلَّ-->حرف نصب-->ٱللَّهَ-->علم-->يُحْدِثُ-->فعل-->(-->هُوَ-->)-->ضمير-->بَعْدَ-->ظرف زمان-->ذَٰلِكَ-->اسم إشارة-->أَمْرًا-->اسم-->جملة فعلية-->جملة اسمية-->-->-->-->-->-->-->-->-->-->نفي-->فاعل-->اسم «لعل»-->فاعل-->متعلق-->مضاف إليه-->مفعول به-->خبر «لعل»-->مفعول به-->-->

.tree-bank-container {
  direction: ltr;
