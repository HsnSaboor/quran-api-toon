quran[27]{c,v,t,f}:
  74,34,"اور صبح کی جب کہ روشن ہو جائے."
  74,35,"کہ (یقیناً وه جہنم) بڑی چیزوں میں سے ایک ہے.{1}.",footnotes:1:یہ جواب قسم ہے کُبَر، کُبْرَیٰ کی جمع ہے تین نہایت اہم چیزوں کی قسموں کے بعد اللہ نے جہنم کی بڑائی اور ہولناکی کو بیان کیا ہے جس سے اس کی بڑائی میں کوئی شک نہیں رہتا۔
  74,36,"بنی آدم کو ڈرانے والی."
  75,31,"اس نے نہ تو تصدیق کی نہ نماز ادا کی.{1}.",footnotes:1:یعنی اس انسان نے رسول اور قرآن کی تصدیق کی اور نہ نماز پڑھی یعنی اللہ کی عبادت نہیں کی۔
  75,32,"بلکہ جھٹلایا اور روگردانی کی.{1}.",footnotes:1:یعنی رسول کو جھٹلایا اور ایمان و اطاعت سے روگردانی کی۔
  75,33,"پھر اپنے گھر والوں کے پاس اتراتا ہوا گیا.{1}.",footnotes:1:یَتَمَطَّیٰ اتراتا اور اکڑاتا ہوا۔
  76,25,"اور اپنے رب کے نام کا صبح وشام ذکر کیا کر.{1}.",footnotes:1:صبح و شام سے مراد ہے، تمام اوقات میں اللہ کا ذکر کر۔ یا صبح سے مراد فجر کی نماز اور شام سے عصر کی نماز ہے۔
  76,26,"اور رات کے وقت اس کے سامنے سجدے کر اور بہت رات تک اس کی تسبیح کیا کر.{1}.",footnotes:1:رات کو سجدہ کر سے مراد بعض نے مغرب وعشاء کی نمازیں مراد لی ہیں اور تسبیح کا مطلب جو باتیں اللہ کے لائق نہیں ہیں ان سے اس کی پاکیزگی بیان کر، بعض کے نزدیک اس سے رات کی نفلی نمازیں یعنی تہجد ہے امر ندب واستحباب کے لیے ہے۔
  76,27,"بیشک یہ لوگ جلدی ملنے والی (دنیا) کو چاہتے ہیں{1} اور اپنے پیچھے ایک بڑے بھاری دن کو چھوڑے دیتے ہیں.{2}",footnotes:1:یعنی کفار مکہ اور ان جیسے دوسرے لوگ دنیا کی محبت میں گرفتار ہیں اور ساری توجہ اسی پر ہے۔,footnotes:2:- یعنی قیامت کو، اس کی شدتوں اور ہولناکیوں کی وجہ سے اسے بھاری دن کہا اور چھوڑنے کا مطلب ہے کہ اس کے لئے تیاری نہیں کرتے اور اس کی پروا نہیں کرتے۔
  77,22,"ایک مقرره وقت تک.{1}.",footnotes:1:یعنی مدت حمل تک نو یا چھ مہینے۔
  77,23,"پھر ہم نے اندازه کیا{1} اور ہم کیا خوب اندازه کرنے والے ہیں..",footnotes:1:یعنی رحم مادر میں جسمانی ساخت و ترکیب و صحیح اندازہ کیا کہ دونوں آنکھوں، دونوں ہاتھوں اور دونوں پیروں اور دونوں کانوں کے درمیان اور دیگر اعضا کا ایک دوسرے کے درمیان کتنا فاصلہ رہنا چاہیئے۔
  77,24,"اس دن تکذیب کرنے والوں کی خرابی ہے."
  78,19,"اور آسمان کھول دیا جائے گا تو اس میں دروازے ہی دروازے ہو جائیں گے.{1}.",footnotes:1:یعنی فرشتوں کے نزول کے لئے راستے بن جائیں گے اور وہ زمین پر اتر آئیں گے۔
  78,20,"اور پہاڑ چلائے جائیں گے پس وه سراب ہو جائیں گے.{1}.",footnotes:1:سَرَابٌ، وہ ریت جو دور سے پانی محسوس ہوتی ہو۔ پہاڑ بھی سراب کی طرح صرف دور سے نظر آنے والی چیز بن کر رہ جائیں گے۔ اور اس کے بعد بالکل ہی معدوم ہو جائیں گے، ان کا کوئی نشان باقی نہیں رہے گا۔ بعض کہتے ہیں کہ قرآن میں پہاڑوں کی مختلف حالتیں بیان کی گئی ہیں، جن میں جمع وتطبیق کی صورت یہ ہے کہ پہلے انہیں ریزہ ریزہ کر دیا جائے گا فَدُكَّتَا دَكَّةً وَاحِدَةً (الحاقة: 14 ) 2- وہ دھنی ہوئی روئی کی طرح ہو جائیں گے۔ كَالْعِهْنِ الْمَنْفُوشِ ( القارعة: 5) 3- وہ گرد وغبار ہو جائیں گے۔ فَكَانَتْ هَبَاءً مُنْبَثًّا (  الواقعة :6)۔ 4- ان کو اڑا دیا جائے گا يَنْسِفُهَا رَبِّي نَسْفًا ( طه:105) اور پانچویں حالت یہ ہے کہ وہ سراب ہو جائیں گے۔ یعنی لا شَيْءَ جیسا کہ اس مقام پر ہے۔ ( فتح القدیر ) ۔
  78,21,"بیشک دوزخ گھات میں ہے.{1}.",footnotes:1:گھات ایسی جگہ کو کہتے ہیں، جہاں چھپ کر دشمن کا انتظار کیا جاتا ہے تاکہ وہاں سے گزرے تو فوراً اس پر حملہ کر دیا جائے۔ جہنم کے داروغے بھی جہنمیوں کے انتظار میں اسی طرح بیٹھے ہیں یا خود جہنم اللہ کے حکم سے کفار کے لئے گھات لگائے بیٹھی ہے۔
  79,13,"(معلوم ہونا چاہئے) وه تو صرف ایک (خوفناک) ڈانٹ ہے."
  79,14,"کہ (جس کے ظاہر ہوتے ہی) وه ایک دم میدان میں جمع ہو جائیں گے.{1}.",footnotes:1:سَاهِرَةٌ سےمراد زمین کی سطح یعنی میدان ہے۔ سطح زمین کو سَاهِرَةٌ اس لئےکہا گیا ہے کہ تمام جانداروں کا سونا اور بیدار ہونا، اسی زمین پر ہوتا ہے، بعض کہتے ہیں کہ چٹیل میدانوں اور صحراوں میں خوف کی وجہ سےانسان کی نیند اڑ جاتی ہےاور وہاں بیدار رہتاہے، اس لئے سَاهِرَةٌ کہا جاتا ہے۔ ( فتح القدیر ) بہرحال یہ قیامت کی منظر کشی ہے کہ ایک ہی نفخے سے سب لوگ ایک میدان میں جمع ہو جائیں گے۔
  79,15,"کیا موسیٰ (علیہ السلام) کی خبر تمہیں پہنچی ہے؟"
  80,10,"تو اس سے بےرخی برتتا ہے.{1}.",footnotes:1:یعنی ایسے لوگوں کی تو قدر افزائی کی ضرورت ہے نہ کہ ان سے بےرخی برتنے کی۔ ان آیات سے یہ بات معلوم ہوئی کہ دعوت وتبلیغ میں کسی کو خاص نہیں کرنا چاہئے بلکہ اصحاب حیثیت اور بےحیثیت، امیر اور غریب، آقا وغلام، مرد اور عورت، چھوٹے اور بڑے سب کو یکساں حیثیت دی جائے اور سب کو مشترکہ خطاب کیا جائے۔ اللہ تعالیٰ جس کو چاہے گا اپنی حکمت بالغہ کے تحت، ہدایت سے نواز دے گا۔ ( ابن کثیر ) ۔
  80,11,"یہ ٹھیک نہیں{1} قرآن تو نصیحت (کی چیز) ہے..",footnotes:1:یعنی غریب سے یہ اعراض اور اصحاب حیثیت کی طرف خصوصی توجہ، یہ ٹھیک نہیں۔ مطلب ہے کہ آئندہ اس کا اعادہ نہ ہو۔
  80,12,"جو چاہے اس سے نصیحت لے.{1}.",footnotes:1:یعنی جو اس میں رغبت کرے، وہ اس سے نصیحت حاصل کرے، اسے یاد کرے اور اس کے موجبات پر عمل کرے۔ اور جو اس اعراض سے کرے اور بے رخی برتے، جیسے اشراف قریش نے کیا، تو ان کی فکر کرنے کی ضرورت نہیں ہے۔
  81,7,"اور جب جانیں (جسموں سے) ملا دی جائیں گی.{1}.",footnotes:1:اس کے کئی مفہوم بیان کئے گئے ہیں۔ زیادہ قرین قیاس یہ معلوم ہوتاہے کہ ہر انسان کو اس کے ہم مذہب وہم مشرب کےساتھ ملا دیا جائے گا۔ مومن کو مومنوں کےساتھ اور بدکو بدوں کے ساتھ، یہودی کو یہودیوں کے ساتھ اور عیسائی کو عیسائیوں کے ساتھ، وَعَلَى هَذَا الْقِيَاسِ ۔
  81,8,"اور جب زنده گاڑی ہوئی لڑکی سے سوال کیا جائے گا."
  81,9,"کہ کس گناه کی وجہ سے وه قتل کی گئی؟{1}.",footnotes:1:اس طرح دراصل قاتل کو سرزنش کی جائے گی کیونکہ اصل مجرم تو وہی ہوگا نہ کہ موءدۃ جس سے بظاہر سوال ہوگا۔
  82,1,"جب آسمان پھٹ جائے گا.{1}.",footnotes:1:یعنی اللہ کے حکم اور اس کی ہیبت سےپھٹ جائے گا اور فرشتے نیچے اتر آئیں گے۔
  82,2,"اور جب ستارے جھڑ جائیں گے."
  82,3,"اور جب سمندر بہہ نکلیں گے.{1}.",footnotes:1:اور سب کا پانی ایک ہی سمندر میں جمع ہو جائے گا، پھر اللہ تعالیٰ پچھمی ہوا بھیجے گا۔ جو اس میں آگ بھڑ کا دے گی جس سے فلک شگاف شعلے بلند ہوں گے۔