quran[6{c,v,t}:
7,52,اور ہم تو ان (منکرین) کے پاس ایک ایسی کتاب لے آئے ہیں جس میں ہم نے (اپنے) علم کی بنا پر (دین حق کی تمام باتوں کو) کھول کھول کر بیان کردیا ہے اور جو ایمان لانے والوں کے لئے ہدایت و رحمت ہے۔
7,53,پھر) کال یہ (منکرین) اس (کتاب کی با ن کی ہوئی) حققت( کے (ظہور کے) منتظر ہں تو (وہ جان رکھںھ کہ) جس دن یہ حققتح پشت آجائے گی تو جو لوگ اسے پہلے سے بھولے (بٹھے ) تھے وہ بول اٹھں گے کہ واقعی ہمارے رب کے پغمبر حق بات لے کر آئے تھے (مگر افسوس ہم نے انہں جھٹلایا)پھر کاے ہں کوئی ہمارے سفارشی کہ (آج) ہماری سفارش کریں ؟ یا ہمں (دناو مںہ) پھر لوٹا دیا جائے تاکہ جو کام ہم (پہلے) کاا کرتے تھے اس کے برخلاف (نیک) عمل کریں۔ بلاشبہ ان لوگوں نے اپنے آپ کو خسارے مںق ڈال دیا اور (دنام مں() جو کچھ افترا پردازیاں وہ کرتے تھے وہ (سب آج) ان سے گم ہوگئںک۔
7,54,لوگو، ) تمہارا رب تو اللہ ہی ہے جس نے آسمانوں اور زمین کو چھ دنوں میں پیدا کیا پھر عرش (بریں) پر متمکن ہوگیا۔ وہی رات کو دن پر ڈھانک دیتا ہے (گویا) رات (ہے کہ) دن کے پیچھے لپکی چلی آ رہی ہے اور سورج اور چاند اور ستارے (سب) اس کے حکم کے تابع ہیں۔ (لوگو، جان لو کہ) اسی کے لئے (خاص) ہے پیدا کرنا اور حکم دینا۔ بڑا ہی بابرکت ہے اللہ رب العالمین۔
7,55,لوگو، ) اپنے رب سے گڑگڑا (گڑگڑا) کر اور چپکے چپکے دعا کیا کرو (کیونکہ) وہ حد سے گزرنے والوں کو یقینا پسند نہیں کرتا۔
7,56,اور (دیکھو، ) زمین کی اصلاح کے بعد اس میں فساد برپا نہ کرو اور اللہ سے دعا مانگتے رہو (اس کے عذاب کے) ڈر سے اور (اس کی رحمت سے) امید رکھتے ہوئے۔ بیشک اللہ کی رحمت نیکو کاروں سے قریب ہے۔
7,57,اور وہ اللہ ہی ہے جو (باران) رحمت سے آگے (آگے) ہواؤں کو (بارش کی) خوشخبری لئے ہوئے بھیجتا ہے۔ پھر جب وہ (پانی سے لدے ہوئے) بھاری (بوجھل) بادل اٹھا لیتی ہیں تو کسی خشک سرزمین کی طرف ان (بادلوں) کو ہانک لے جاتا ہے، پھر وہاں ان سے پانی برساتا ہے، پھر اس (مردہ زمین) سے ہر طرح کے پھل نکالتا ہے۔ اسی طرح ہم (قیامت کے دن) مردوں کو زندہ کریں گے تاکہ تم نصیحت پکڑو۔
