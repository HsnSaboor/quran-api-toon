quran[27{c,v,t}:
55,68,ان (باغوں) میں میوے (ہوں گے) ، اور کھجوریں (ہوں گی) ، اور انار (ہوں گے) ۔
55,69,تو (اے جن و انس، ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ؟
55,70,ان میں نیک سیرت اور خوبصورت (حوریں) ہوں گی۔
55,71,تو (اے جن و انس، ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ؟
55,72,وہ) حوریں (اپنے رہنے کے) خیموں میں بند (بیٹھی) ہیں (کہ ان کو باہر کی ہوا بھی نہیں لگنے پاتی) ۔
55,73,تو (اے جن و انس، ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ؟
55,74,ان (جنتیوں) سے پہلے نہ تو کسی انسان نے انہیں ہاتھ لگایا ہوگا اور نہ کسی جن نے،
55,75,تو (اے جن و انس، ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ؟
55,76,جنّتی ان باغوں میں) سبز چاندنیوں اور نفیس و نادر فرشوں پر تکیے لگائے (بیٹھے) ہوں گے۔
55,77,تو (اے جن و انس، ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ؟
55,78,اے پیغمبر، ) بڑا ہی بابرکت نام ہے تمہارے رب جلیل و کریم کا۔
56,1,جب وہ ہونے والا واقعہ پیش آجائے گا
56,2,اور) اس کے واقع ہونے میں کچھ بھی جھوٹ نہیں۔
56,3,بعضوں کو وہ) پست کر دے گی (اور بعضوں کے درجے) بلند کرے گی۔
56,4,اور) جب زمین بڑے زور سے ہلا دی جائے گی
56,5,اور پہاڑ بالکل ریزہ ریزہ کر دئیے جائیں گے۔
56,6,پھر وہ پراگندہ غبار بن جائیں گے۔
56,7,اور (اس وقت) تم لوگ تین قسم کے (گروہ میں تقسیم) ہوجاؤ گے۔
56,8,ایک گروہ) تو دائیں بازو والے، سو دائیں بازو والوں (کی خوش نصیبی) کا کیا کہنا۔
56,9,اور (ایک گروہ) بائیں بازو والے، (سو) بائیں بازو والوں کی (بدنصیبی) کا کیا ٹھکانا۔
56,10,اور (رہے) سابقون (سو وہ تو) سبقت کرنے والے (لوگ ہی) ہیں۔
56,11,وہی (بارگاہِ الٰہی کے) مقرب ہیں۔
56,12,وہ) عیش (وآرام) کے باغوں میں (ہوں گے) ۔
56,13,وہ) اگلوں میں سے بہت
56,14,اور پچھلوں میں سے کم (ہوں گے) ۔
56,15,یہ مقربین) جڑاؤ تختوں پر تکیے لگائے ہوئے
56,16,آمنے سامنے بیٹھے ہوں گے۔
