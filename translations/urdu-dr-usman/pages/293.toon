quran[11{c,v,t}:
17,105,اور (دیکھو، ) اس (قرآن) کو ہم نے سچائی کے ساتھ نازل کیا ہے اور سچائی ہی کے ساتھ یہ نازل بھی ہوا ہے۔ اور (اے پیغمبر، ) ہم نے تمہیں بس (ایمان و عمل صالح کے نتائج کی) خوشخبری دینے والا اور (انکار و بدعملی کے نتائج سے) خبردار کرنے والا بنا کر بھیجا ہے (اس لئے تم پر کسی کے ایمان لانے نہ لانے کی ذمہ داری نہیں) ۔
17,106,اور ہم نے قرآن کو (الگ الگ ٹکڑوں میں) منقسم کردیا تاکہ تم ٹھہر ٹھہر کر لوگوں کو سناتے رہو اور (یہی وجہ ہے کہ) ہم نے اسے بتدریج اتارا ہے۔
17,107,اے پیغمبر، ان لوگوں سے) کہہ دو کہ تم اس (قرآن) کو (کلام الٰہی) مانو یا نہ مانو (لیکن) جن لوگوں کو اس سے پہلے (آسمانی کتابوں کا) علم دیا گیا ہے (ان کا تو یہ حال ہے کہ) جب یہ ان کے سامنے پڑھا جاتا ہے تو وہ (بے اختیار) ٹھوڑیوں کے بل سجدے میں گر پڑتے ہیں
17,108,اور پکار اٹھتے ہیں کہ پاک ہے ہمارا رب، بیشک ہمارے رب کا وعدہ تو پورا ہونا ہی تھا۔
17,109,اور وہ ٹھوڑیوں کے بل روتے ہوئے گر جاتے ہیں اور یہ (قرآن) ان کی عاجزی اور زیادہ کردیتا ہے۔
17,110,اے پیغمبر ان لوگوں سے) کہو کہ تم اللہ (کہہ کر) پکارو یا رحمن (کہہ کر) ، جس (نام) سے بھی پکارو، اس کے (سارے) نام اچھے (ہی اچھے) ہیں۔ اور (اے پیغمبر، ) نہ تو اپنی نماز بہت بلند آواز سے پڑھو اور نہ ہی بالکل چپکے چپکے بلکہ ان (دونوں) کے درمیان ایک (متوسط) طریقہ اختیار کرو۔
17,111,اور کہو کہ ساری تعریف اللہ ہی کے لئے ہے جو نہ اولاد رکھتا ہے اور نہ حکومت میں اس کا کوئی شریک ہے اور نہ اس سبب سے کہ وہ کمزور ہے کوئی اس کا مددگار ہے۔ (وہ ان ساری باتوں سے بےنیاز ہے) ۔ اور اس کی بڑائی بیان کرو، کمال درجے کی بڑائی۔
18,1,ساری تعریف اللہ ہی کے لئے ہے جس نے اپنے بندے پر کتاب نازل کی اور اس میں (کسی طرح کی) کجی نہیں رکھی۔
18,2,بالکل سیدھی بات (کہنے والی کتاب، ہر طرح کے پیچ و خم سے پاک، اور اس لئے نازل کی) تاکہ اللہ کی طرف سے (جو) عذاب شدید (کافروں پر نازل ہونے والا ہے لوگوں کو اس) سے خبردار کر دے اور جو ایمان والے ہیں اور نیک عمل (بھی) کرتے ہیں ان کو (اس بات کی) خوشخبری دے دے کہ (اللہ کے ہاں) ان کے لئے (بڑا) اچھا اجر ہے۔
18,3,یعنی بہشت) جس میں وہ ہمیشہ (ہمیشہ) رہیں گے۔
18,4,نیز) ان لوگوں کو (اللہ کے عذاب سے) ڈرا دے جو کہتے ہیں اللہ (بھی) اولاد رکھتا ہے۔
