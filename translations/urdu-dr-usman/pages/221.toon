quran[8{c,v,t}:
10,107,اور اگر اللہ تجھے کوئی تکلیف پہنچائے تو اس کے سوا کوئی اس (تکلیف) کا دور کرنے والا نہیں، اور اگر وہ تجھے (کسی قسم کا) فائدہ پہنچانا چاہے تو اس کے فضل کو رد کرنے والا (بھی) کوئی نہیں۔ وہ اپنے بندوں میں سے جس پر چاہے فضل کرے وہ اللہ تو (بڑا ہی) بخشنے والا (اور) ہمیشہ رحم کرنے والا ہے۔
10,108,اے پیغمبر، ) کہہ دو کہ لوگو، تمہارے رب کی طرف سے حق تمہارے پاس آ چکا ہے پس جو ہدایت کی راہ اختیار کرے گا تو اپنے ہی بھلے کے لئے کرے گا اور جو گمراہ رہے گا تو اس کی گمراہی (کا وبال) اسی پر ہے۔ اور میں تمہارے اوپر داروغہ تو ہوں نہیں (کہ زبردستی کسی راہ میں کھینچ لے جاؤں اور پھر اس سے نکلنے نہ دوں) ۔
10,109,اور (اے پیغمبر، ) تم اس (ہدایت) کی پیروی کئے جاؤ جو تم پر وحی کی جا رہی ہے اور (منکرین کی ایذا رسانی پر) صبر کرو یہاں تک کہ اللہ فیصلہ کردے اور وہی (سب) فیصلہ کرنے والوں میں بہتر فیصلہ کرنے والا ہے۔
11,1,الف۔ لام۔ را۔ یہ (قرآن ایک ایسی) کتاب ہے جس کی آیتیں (اپنے مطالب و دلائل میں) پختہ ہیں، پھر (اس کے ساتھ) کھول کر (بھی) بیان کی گئی ہیں۔ (یہ) ایک حکمت والی باخبر ہستی کی طرف سے (ہے) ۔
11,2,اس کا اعلان کیا ہے ؟ یہ، ) کہ اللہ کے سوا کسی کی عبادت نہ کرو۔ میں اس کی طرف سے تمہیں (انکار و سرکشی کے نتائج سے) خبردار کرنے والا اور ایمان و نیک عملی کی کامرانیوں کی) خوشخبری دینے والا ہوں۔)
11,3,اور (نیز) یہ کہ اپنے رب سے (اپنے گناہوں کی) معافی مانگو اور اس کی طرف لوٹ آؤ۔ (ایسا کرو گے تو) وہ تمہیں ایک وقت مقرر تک اچھا سامان (زندگی) دے گا اور ہر فضل والے کو اس کا فضل عطا کرے گا۔ لیکن اگر تم نے روگردانی کی تو مجھے تمہارے لئے ایک بڑے (سخت) دن کے عذاب کا اندیشہ ہے۔
11,4,کیونکہ) تم (سب) کو اللہ کی طرف لوٹنا ہے اور وہ ہر چیز پر قادر ہے۔
11,5,دیکھو، یہ لوگ (جھک جھک کر) اپنے سینوں کو دوہرا کئے دیتے ہیں تاکہ اس سے چھپ جائیں، (مگر) دیکھو، جب یہ کپڑوں سے اپنے (آپ) کو ڈھانپ لیتے ہیں (اس وقت بھی) اللہ جانتا ہے جو کچھ وہ چھپاتے ہیں اور جو کچھ وہ ظاہر کرتے ہیں۔ وہ تو دلوں کے بھید تک کا جاننے والا ہے۔
