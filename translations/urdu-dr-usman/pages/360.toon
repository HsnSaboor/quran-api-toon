quran[9{c,v,t}:
25,3,باوجود اللہ کے ایسے یکتا ہونے کے مشرکین نے) اسے چھوڑ کر (ایسے) معبود بنا لئے ہیں جو کسی چیز کو پیدا نہیں کرتے بلکہ خود پیدا کئے جاتے ہیں اور خود اپنے لئے بھی نہ کسی نقصان کا اختیار رکھتے ہیں اور نہ کسی نفع کا، نہ (کسی کی) موت کا اختیار رکھتے ہیں اور نہ (کسی کی) زندگی کا اور نہ (کسی کو) دوبارہ زندہ کرنے کا۔
25,4,اور جن لوگوں نے کفر (کا راستہ اختیار) کیا ہے وہ (قرآن کے بارے میں) کہتے ہیں کہ یہ تو نرا جھوٹ ہے جس کو اس شخص نے گھڑ لیا ہے اور دوسرے لوگوں نے اس میں اس کی مدد کی ہے۔ (یہ بات کہہ کر) یہ لوگ (بڑے ہی) ظلم اور (سرتاسر) جھوٹ پر اتر آئے ہیں۔
25,5,اور وہ (یہ بھی) کہتے ہیں کہ یہ (قرآن) تو اگلوں کی کہانیاں ہیں جن کو اس (شخص) نے کسی سے لکھوا لیا ہے اور وہی صبح و شام اسے پڑھ پڑھ کر سنائی (اور یاد کرائی) جاتی ہیں۔
25,6,اے پیغمبر، ان لوگوں سے) کہو کہ یہ (قرآن تو) اس (ہستی) نے نازل کیا ہے جو آسمانوں اور زمین کے تمام راز جانتا ہے۔ بلاشبہ وہ (بڑا) بخشنے والا (اور) ہمیشہ رحم کرنے والا ہے (کہ تم کو اس بہتان کی فوراً سزا نہیں دیتا) ۔
25,7,اور (یہ لوگ) کہتے ہیں کہ یہ کیسا رسول ہے جو کھانا کھاتا ہے اور بازاروں میں چلتا (پھرتا) ہے۔ کیوں نہ اس کے پاس کوئی فرشتہ بھیجا گیا جو اس کے ساتھ رہ کر (لوگوں کو عذاب الٰہی سے) ڈراتا،
25,8,یا غیب سے کوئی خزانہ اس کے پاس اترتا، یا (زیادہ نہیں تو) اس کے پاس (ایک) باغ (ہی) ہوتا جس سے یہ کھاتا پیتا اوریہ ظالم (مسلمانوں سے) کہتے ہیں کہ تم لوگ تو بس ایک سحرزدہ آدمی کی پیروی کر رہے ہو
25,9,اے پیغمبر، ) دیکھو (تو سہی یہ لوگ) تمہارے بارے میں کیسی کیسی باتیں بناتے ہیں۔ پس یہ ایسے گمراہ ہوئے ہیں کہ (کسی طرح) راہ پر نہیں آسکتے۔
25,10,اے پیغمبر، اللہ کے ہاں کسی چیز کی بھی کمی نہیں) ۔ وہ بڑی برکت والا ہے اگر وہ چاہے تو (ایک باغ کیا) اس سے بڑھ چڑھ کر (بہتیرے) باغ تمہارے لئے (مہیا) کر دے جن کے نیچے نہریں بہ رہی ہوں اور (باغوں کے علاوہ) تمہارے لئے (بہت سے) محل (بھی) بنا دے۔
25,11,بلکہ یہ لوگ قیامت کو جھوٹ سمجھتے ہیں اور جو قیامت کو جھوٹ سمجھے اس کے لئے ہم نے دوزخ تیار کر رکھی ہے۔
