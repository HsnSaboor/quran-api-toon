quran[9{c,v,t}:
21,73,اور ہم نے انھیں (لوگوں کا) امام بنا دیا جو ہمارے حکم سے (لوگوں کی) رہنمائی کرتے تھے۔ اور ہم نے ان کی طرف نیک کام کرنے، نماز قائم کرنے اور زکوٰۃ ادا کرنے کی وحی بھیجی، اور وہ ہماری ہی عبادت کرنے والے تھے۔
21,74,اور (اسی طرح) ہم نے لوط کو بھی حکم اور علم عطا کیا اور اسے اس بستی سے نجات دی جو بدکاریاں کرتی تھی۔ اس میں شک نہیں کہ وہ (بڑی ہی) بری فاسق قوم تھی۔
21,75,اس طرح) ہم نے لوط کو اپنی رحمت (کی پناہ) میں لے لیا، یقینا وہ صالح لوگوں میں سے تھا
21,76,اور (اے پیغمبر، لوگوں کو) نوح (کا واقعہ بھی یاد دلاؤ) جب اس نے (ہمیں) پکارا تھا (اور یہ زمانہ ابراہیم سے بہت) پہلے (کا واقعہ ہے) تو ہم نے اس کی (دعا) سن لی اور اسے اور اس کے گھر والوں کو کرب عظیم سے نجات دی
21,77,اور اس قوم کے مقابلے میں جس نے ہماری آیتوں کو جھٹلایا تھا اس کی مدد کی۔ (بڑے ہی) برے تھے وہ لوگ، پس ہم نے ان سب کو غرق کردیا۔
21,78,اور (اے پیغمبر، لوگوں کو) داؤد اور سلیمان (کا واقعہ بھی یاد دلاؤ) جب کہ وہ دونوں ایک کھیت (کے مقدمے) میں فیصلہ کر رہے تھے جس میں لوگوں کی بکریاں رات کے وقت جا پڑی تھیں (اور کھیت کو چر گئی تھیں) اور ہم لوگوں سے متعلق (ان کے) فیصلے کو دیکھ رہے تھے
21,79,پس ہم نے (صحیح) فیصلہ سلیمان کو سمجھا دیا حالانکہ حکم اور علم ہم نے دونوں ہی کو عطا کیا تھا۔ نیز ہم نے پہاڑوں اور پرندوں کو داؤد کے تابع کردیا تھا جو (اس کے ساتھ) تسبیح (و تقدیس) کیا کرتے تھے اور (اس کے) کرنے والے ہم تھے
21,80,اور ہم نے داؤد کو تمہارے لئے زرہ کا بنانا بھی سکھا دیا تھا تاکہ تمہیں (لڑائی میں ایک دوسرے کی) زد سے بچائے تو (اے لوگو، ) کیا تم (ہماری اس نعمت کا بھی) شکر کرو گے (یا نہیں) ؟
21,81,اور (دیکھو، ) ہم نے سلیمان کے لئے تیز ہوا کو مسخر کردیا تھا جو اس کے حکم سے اس سرزمین کے رخ پر چلتی تھی جس میں ہم نے برکتیں رکھی تھیں اور ہم تو ہر چیز کا علم رکھتے ہیں۔(
