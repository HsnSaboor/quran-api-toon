quran[9{c,v,t}:
25,12,جب وہ ان کو دور سے دیکھے گی تو (دیکھتے ہی جوش مارے گی اور یہ دور ہی سے) اس کا جوش و خروش سنیں گے۔
25,13,اور جب وہ اس میں کسی تنگ جگہ مشکیں باندھ کر ڈال دئیے جائیں گے تو وہاں موت (ہی موت) پکاریں گے
25,14,ان سے کہا جائے گا کہ) ایک موت کو نہ پکارو بلکہ بہت سی موتوں کو پکارو۔
25,15,(اے پیغمبر، ان لوگوں سے) پوچھو کہ یہ (دوزخ) بہتر ہے یا وہ ابدی جنت جس کا وعدہ متقیوں سے کیا گیا ہے۔ وہ ان (کی اطاعت) کا صلہ ہوگی اور (ان کا) آخری ٹھکانا۔
25,16,جو چیز وہ چاہیں گے ان کے لئے وہاں (موجود) ہوگی اور وہ (اس میں) ہمیشہ (ہمیشہ) رہیں گے۔ (اے پیغمبر، ) یہ (ایک) وعدہ ہے (جس کا پورا کرنا) تمہارے رب پر (لازم ہے اور یہ) قابل درخواست ہے۔
25,17,اور جس دن ( اللہ) ان لوگوں کو اور (ان معبودوں کو) جن کو (یہ لوگ) اللہ کو چھوڑ کر پوجتے ہیں (اپنے حضور میں) جمع کرے گا، پھر وہ (ان کے معبودوں سے) پوچھے گا۔ '' کیا میرے ان بندوں کو تم نے گمراہ کیا تھا یا یہ (خود ہی) راہ (راست) سے بھٹک گئے تھے ؟''
25,18,وہ عرض کریں گے، '' تو پاک (ذات) ہے، (ہم تو خود بندے تھے، ) ہمیں تو یہ بات بھی کسی طرح زیبا نہ تھی کہ تیرے سوا کسی اور کو اپنا کارساز بناتے، (تو ہم ان کے کارساز بننے کا کیونکر دعویٰ کرسکتے تھے، ) مگر (بات یہ ہوئی کہ) تو نے ان کو اور ان کے باپ دادوں کو (خوب) سامان زندگی دیا یہاں تک کہ یہ (تیری) یاد کو بھلا بیٹھے اور یہ لوگ خود ہی برباد ہوئے ''
25,19,اس وقت اللہ مشرکین سے فرمائے گا، ) '' پس انہوں نے تم کو تمہاری باتوں میں جھوٹا ٹھہرا دیا تو نہ (ہمارے عذاب کو اپنے اوپر سے) ٹال سکتے ہو اور نہ (کسی سے) مدد لے سکتے ہو۔ اور جو (کوئی) تم میں ظالم ہوگا ہم اس کو بڑے (سخت) عذاب (کامزا) چکھائیں گے ''۔
25,20,اور (اے پیغمبر، ) ہم نے تم سے پہلے جتنے رسول بھیجے وہ کھانا بھی کھاتے تھے اور بازاروں میں (بھی) چلتے (پھرتے) تھے۔ اور (بات یہ ہے کہ) ہم نے تم لوگوں کو ایک دوسرے کے لئے آزمائش (کا ذریعہ) بنا دیا ہے۔ تو (مسلمانو، ) تم (اب بھی کافروں کی ایذا رسانیوں پر) صبر کرو گے (یا نہیں) ؟ اور (اے پیغمبر، ) تمہارا رب سب کچھ دیکھ رہا ہے۔
