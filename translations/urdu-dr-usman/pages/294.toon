quran[11{c,v,t}:
18,5,اس (دعوے) پر کوئی دلیل نہ تو ان کے پاس ہے نہ ان کے باپ دادوں کے پاس (تھی) ۔ بڑی (ہی سخت) بات ہے جو ان کے منہ سے نکلتی ہے۔ وہ محض جھوٹ بکتے ہیں۔
18,6,اے پیغمبر، ) اگر (یہ لوگ) اس تعلیم پر ایمان نہ لائے تو تم مارے غم کے ان کے پیچھے اپنی جان ہلاک کر ڈالو گے۔
18,7,واقعہ یہ ہے کہ جو کچھ (روئے) زمین پر ہے اس کو ہم نے زمین کی زینت بنایا ہے تاکہ لوگوں کو آزمائیں کہ ان میں کون عمل کے لحاظ سے بہتر ہے۔
18,8,اور (پھر ایک دن) ہم تمام چیزوں کو جو (روئے) زمین پر ہیں (نابود کر کے زمین کو) چٹیل میدان بنا دینے والے ہیں۔
18,9,اے پیغمبر، ) کیا تم خیال کرتے ہو کہ غار اور کتبے والے ہماری (قدرت کی) نشانیوں میں سے (ایک) عجیب (نشانی) تھے ؟
18,10,جب (ایسا ہوا تھا کہ) چند نوجوان غار میں جا بیٹھے تھے اور انہوں نے دعا کی تھی کہ اے ہمارے رب، ہم پر اپنی جناب سے رحمت نازل فرما اور ہمارے کام میں درستی کا سامان مہیا کردے،
18,11,تو ہم نے اس غار میں ان کے کانوں پر سالہا سال تک (نیند کا) پردہ ڈال رکھا۔
18,12,پھر ہم نے انھیں اٹھا کھڑا کیا تاکہ ہم دیکھ لیں کہ (ان کے) دو گروہوں میں سے کون سا (گروہ غار میں) رہنے کی مدت (کا ٹھیک) شمار کرتا ہے۔
18,13,اے پیغمبر، اب) ہم ان کا حال ٹھیک ٹھیک تم سے بیان کرتے ہیں۔ وہ چند نوجوان تھے جو اپنے رب پر ایمان لے آئے تھے اور ہم نے ان کو ہدایت میں ترقی دی تھی۔
18,14,اور ہم نے ان کے دلوں کی (صبر و استقامت میں) بندش کردی۔ وہ جب (راہ حق میں) کھڑے ہوئے تو انہوں نے (صاف صاف) کہہ دیا کہ ہمارا رب (تو وہی ہے جو) آسمانوں اور زمین کا رب ہے۔ ہم اس کے سوا (اپنی حاجت روائی کے لئے) کسی (دوسرے) معبود کو پکارنے والے نہیں۔ اگر ہم ایسا کریں تو ہم نے بڑی ہی بےجا بات کہی۔
18,15,یہ ہماری قوم کے لوگ ہیں جو اللہ کے سوا (دوسرے) معبودوں کو پکڑے بیٹھے ہیں۔ (یہ لوگ) ان (کے معبود ہونے) کی کوئی واضح دلیل کیوں نہیں پیش کرتے ؟ پھر اس شخص سے بڑھ کر ظالم اور کون ہے جو اللہ پر جھوٹ تہمت لگائے۔
