quran[9{c,v,t}:
34,23,اور اللہ کے حضور (کسی کی) سفارش بھی (کسی کے کچھ) کام نہیں آسکتی مگر (ہاں) اس کے لئے جس کے حق میں اللہ (شافع کو) اجازت دے۔ (ان فرشتوں کا تو یہ حال ہے کہ جب کوئی حکم اللہ کے ہاں سے نازل ہوتا ہے تو مارے ہیبت کے گھبرا اٹھتے ہیں) یہاں تک کہ جب گھبراہٹ ان کے دلوں سے دور ہوتی ہے تو ( ایک دوسرے سے) پوچھتے ہیں کہ تمہارے رب نے کیا حکم فرمایا ؟ (اس پر جو زیادہ مقرب ہیں) وہ جواب دیتے ہیں کہ حق (بات کا حکم) فرمایا اور (واقعی) وہ نہایت عالی مقام اور سب سے بڑا ہے۔
34,24,اے پیغمبر، ان لوگوں سے) پوچھو کہ بھلا تم کو آسمان اور زمین سے کون روزی دیتا ہے ؟ (یہ تو اس کا کیا جواب دیں گے تم ہی ان سے) کہو کہ اللہ۔ اب لامحالہ ہم یا تم یا تو ہدایت پر ہیں یا کھلی گمراہی میں۔
34,25,(ان سے) کہو کہ نہ تو ہمارے گناہوں کی تم سے بازپرس ہوگی اور نہ تمہارے اعمال کی ہم سے جواب طلبی کی جائے گی۔
34,26,(اور ان سے یہ بھی) کہہ دو کہ ہمارا رب (قیامت کے دن) ہم (دونوں فریقوں) کو جمع کرے گا پھر وہ ہمارے (تمہارے) درمیان ٹھیک ٹھیک فیصلہ کر دے گا اور وہ بڑا (ٹھیک) فیصلہ کرنے والا (اور) بڑا علم والا ہے۔
34,27,اے پیغمبر، ان لوگوں سے) کہو کہ جن کو تم نے شریک بنا کر اللہ کے ساتھ ملا رکھا ہے (ذرا ایک نظر) انھیں مجھے (بھی تو) دکھاؤ۔ ہرگز (اس کا کوئی شریک) نہیں، بلکہ زبردست (اور) حکمت والا تو بس وہی (ایک) اللہ ہے۔
34,28,اور (اے پیغمبر، ) ہم نے تم کو تمام انسانوں کے لئے (ایمان و نیک عمل کے نتائج کی) خوشخبری سنانے والا اور (انکار و بدعملی کے نتائج سے) خبردار کرنے والا بنا کر بھیجا ہے مگر اکثر لوگ نہیں سمجھتے۔
34,29,اور (یہ منکریں) پوچھتے ہیں کہ (بھلا) اگر تم سچے ہو تو (بتلاؤ کہ) یہ (قیامت کا) وعدہ کب پورا ہوگا ؟
34,30,اے پیغمبر، ان سے) کہو کہ تمہارے ساتھ جس دن کا وعدہ ہے تم اس سے نہ ایک گھڑی پیچھے رہ سکو گے اور نہ آگے بڑھ سکو گے۔
34,31,اور یہ کفار (مکہ) کہتے ہیں کہ ہم ہرگز اس قرآن پر ایمان نہ لائیں گے اور نہ ان پہلی (کتابوں) پر جو اس سے پہلے تھیں۔ (اے پیغمبر، ) کاش تم دیکھو (ان کا حال) جب (قیامت کے دن یہ) ظالم اپنے رب کے حضور میں کھڑے کئے جائیں گے (اور اس وقت) وہ ایک دوسرے پر الزام دھریں گے۔ جو لوگ (دنیا میں) دبا کر رکھے گئے تھے وہ بڑے بننے والوں سے کہیں گے کہ اگر تم نہ ہوتے تو ہم ضرور ایمان لائے ہوتے۔
