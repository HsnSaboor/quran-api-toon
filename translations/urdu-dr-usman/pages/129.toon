quran[10{c,v,t}:
6,9,اور اگر ہم کسی فرشتہ کو رسول بنا کر بھیجتے تو اس کو بھی آدمی ہی (کی شکل میں) بناتے اور جو شبے (یہ لوگ اب) کر رہے ہیں وہی شبے ہم (اس وقت بھی) ان (کے دلوں) پر (طاری) کردیتے۔
6,10,اور (اے پیغمبر، ) یہ واقعہ ہے کہ تم سے پہلے بھی پیغمبروں کا مذاق اڑایا گیا، تو جن لوگوں نے مذاق اڑایا تھا ان کو اس (عذاب) نے آگھیرا جس کا وہ مذاق اڑاتے تھے۔
6,11,ان (لوگوں) سے کہو کہ زمین میں چل پھر کر (گزری ہوئی قوموں کے آثارپر) نظر ڈالو اور دیکھو کہ (پیغمبروں کو) جھٹلانے والوں کا کیا انجام ہوا۔
6,12,اے پیغمبر، ان لوگوں سے) پوچھو کہ آسمانوں اور زمین میں جو کچھ ہے وہ کس کا ہے ؟ (پھر ان کے جواب کا منتظر رہنا ضروری نہیں، تم آپ ہی) کہہ دو کہ یہ (سب کچھ) اللہ ہی کا ہے۔ اس نے رحم (و کرم کا شیوہ) اپنے اوپر لازم کرلیا ہے۔ وہ قیامت کے دن جس کے آنے میں کوئی شک نہیں تم لوگوں کو ضرور جمع کر کے رہے گا (مگر اے پیغمبر، تم کتنا ہی سمجھاؤ) جو لوگ (اپنے ہاتھوں) اپنا نقصان کر رہے ہیں وہ کبھی ایمان نہ لائیں گے۔
6,13,اور (دیکھو، ) جو کچھ رات (کی تاریکی) اور دن (کے اجالے) میں (روئے زمین پر) بستا ہے وہ (سب) اسی ( اللہ) کا ہے۔ وہ بڑا سننے والا (اور) جاننے والا ہے۔
6,14,(اے پیغمبر، ان لوگوں سے) کہو، کیا (تم چاہتے ہو کہ) میں اللہ کو چھوڑ کر جو آسمانوں اور زمین کو پیدا کرنے والا ہے، جو روزی دیتا ہے اور (کسی سے) روزی لیتا نہیں ہے، کسی (اور) کو کار ساز بنا لوں ؟ (اے پیغمبر، ) تم کہہ دو کہ مجھے تو یہی حکم دیا گیا ہے کہ سب سے پہلے میں (اللہ کا) فرمانبردار (بندہ) بنوں اور (مجھے تاکید کی گئی ہے کہ کوئی شرک کرتا ہے تو کرے) تم بہرحال مشرکوں میں (شامل) نہ ہونا۔
6,15,اے پیغمبر، ) تم کہو کہ اگر میں اپنے رب کی نافرمانی کروں تو اس بڑے دن کے عذاب سے ڈرتا ہوں۔
6,16,اس دن جس (کے سر پر) سے عذاب ٹل گیا تو اس پر اللہ نے (بڑا ہی) رحم کیا اور یہی صریح کامیابی ہے۔
6,17,اے انسان، ) اگر اللہ تجھے دکھ پہنچائے تو اس کے سوا کوئی اس کا ٹالنے والا نہیں اور اگر وہ تجھے بھلائی پہنچائے تو وہ ہر چیز پر قادر ہے۔
6,18,اور وہی اپنے بندوں پر غالب ہے اور وہی حکمت والا (اور) باخبر ہے۔
