quran[9{c,v,t}:
2,49,اور (اس وقت کو یاد کرو) جب ہم نے تم کو فرعون والوں سے نجات دی جو تم کو سخت ایذا پہنچاتے تھے، تمہارے لڑکوں کو قتل کرتے تھے اور تمہاری لڑکیوں کو زندہ رہنے دیتے تھے۔ اور اس میں تمہارے رب کی طرف سے تمہاری بڑی آزمائش تھی۔
2,50,اور (وہ وقت بھی یاد کرو) جب ہم نے تمہارے لئے سمندر کو پھاڑ دیا تھا، پھر ہم نے تم کو تو نجات دی اور فرعون والوں کو تمہارے دیکھتے (دیکھتے) غرق کردیا۔
2,51,اور (وہ وقت بھی یاد کرو) جب ہم نے موسیٰ سے چالیس راتوں والا وعدہ کیا تھا تو تم اس کے پیچھے (پرستش کے لئے) بچھڑے کو لے بیٹھے اور تم (سخت) ظالم تھے۔
2,52,مگر اس کے بعد بھی ہم نے تمہیں معاف کردیا تاکہ تم شکر گزار بنو۔
2,53,اور (وہ وقت بھی یاد کرو) جب ہم نے موسیٰ کو کتاب (تورات) اور فرقان عطا کی تاکہ تم ہدایت پاؤ
2,54,اور (وہ وقت بھی یاد کرو) جب موسیٰ نے اپنی قوم سے کہا کہ اے میری قوم (کے لوگو) تم نے بچھڑے (کی پرستش) کے اختیار کرنے سے اپنے اوپر (بڑا ہی) ظلم کیا ہے لہذا (اب) اپنے خالق کی جناب میں توبہ کرو اور اپنے اشخاص کو قتل کرو۔ اس میں تمہارے خالق کے نزدیک تمہاری بہتری ہے۔ چنانچہ اس نے تمہاری توبہ قبول کرلی۔ بیشک وہ بڑا توبہ قبول کرنے والا (اور) ہمیشہ رحم فرمانے والا ہے۔
2,55,اور (وہ وقت بھی یاد کرو) جب تم نے موسیٰ سے کہا تھا کہ ہم تمہارے کہنے کا ہرگز یقین نہ کریں گے جب تک کہ ہم کھلم کھلا اللہ کو (تم سے کلام کرتا ہوا) نہ دیکھ لیں، اس پر تم کو بجلی نے آدبوچا اور تم دیکھتے (کے دیکھتے) رہ گئے۔
2,56,پھر تمہارے مر جانے کے بعد ہم نے تم کو زندہ کیا تاکہ تم شکرگزار بنو۔
2,57,اور ہم نے تم پر ابر کا سایہ کیا اور من وسلویٰ بھی اتارا (اور کہا کہ) جو پاک چیزیں ہم نے تم کو دی ہیں انہیں کھاؤ اور انہوں نے ہمارا کچھ نہیں بگاڑا بلکہ اپنی ہی جانوں پر ظلم کرتے رہے۔
