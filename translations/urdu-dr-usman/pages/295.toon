quran[5{c,v,t}:
18,16,اور (پھر وہ آپس میں کہنے لگے کہ) جب تم نے ان (لوگوں) سے اور اللہ کے سوا جن (معبودوں) کی یہ لوگ پرستش کرتے ہیں ان سے کنارہ کشی کرلی ہے تو (چلو فلاں) غار میں چل کر پناہ لو۔ تمہارا رب اپنی رحمت (کا سایہ) تم پر پھیلا دے گا اور تمہارے کام میں سہولت (کے سامان) مہیا کردے گا۔
18,17,اور (اے پیغمبر، وہ جس غار میں جا کر بیٹھے وہ اس طرح واقع ہوا ہے کہ) جب سورج نکلے تو تم دیکھو کہ وہ ان کے داہنے جانب سے ہٹا ہوا رہتا ہے اور جب ڈوبے تو بائیں جانب کترا کر نکل جاتا ہے اور وہ غار کے اندر ایک کشادہ جگہ میں (لیٹے) ہیں۔ یہ (بھی) اللہ کی (قدرت کی) نشانیوں میں سے ایک نشانی ہے۔ جسے اللہ ہدایت دے وہی ہدایت پاتا ہے اور جسے بھٹکا دے تو (اے پیغمبر، ) اس کے لئے تم کوئی کارساز، راہ بتانے والا نہ پاؤ گے۔
18,18,اور تم (انہیں دیکھتے تو) سمجھتے کہ وہ جاگ رہے ہیں حالانکہ وہ سوئے ہوئے تھے اور ہم انھیں دائیں بائیں کروٹیں دلواتے رہتے تھے اور ان کا کتا چوکھٹ پر اپنے دونوں بازو پھیلائے (بیٹھا) تھا۔ اگر تم انھیں جھانک کر دیکھتے تو ضرور الٹے پاؤں بھاگ کھڑے ہوتے اور تم پر (اس منظر سے) دہشت چھا جاتی۔
18,19,اور (دیکھو، جس طرح ہم نے انھیں اپنی قدرت سے سلا دیا تھا) اسی طرح ہم نے انھیں اٹھا کھڑا کیا تاکہ آپس میں پوچھ گچھ کریں۔ (چنانچہ) ان میں سے ایک بولنے والا بول اٹھا، '' (کیوں بھئی، ) بھلا (اس غار میں) کتنی مدت رہے ہوگے ؟'' وہ بولے، '' ہم (بہت) رہے (ہوں گے تو) ایک دن یا ایک دن سے بھی کم۔ (پھر جب ٹھیک ٹھیک مدت معلوم نہ کرسکے تو) بولے کہ ہمارا رب ہی بہتر جانتا ہے کہ کتنی مدت (غار میں) رہے۔ اچھا اب اپنے میں سے ایک آدمی کو چاندی کا یہ سکہ دے کر شہر بھیجو کہ وہ (جا کر) دیکھے کہ کسی کے ہاں اچھا کھانا (مل سکتا) ہے تو وہاں سے (تھوڑا بہت) کھانا لے آئے اور (سب کام) خوش تدبیری سے کرے اور کسی کو تمہاری خبر نہ ہونے دے۔
18,20,بیشک اگر لوگوں نے تمہاری خبر پا لی تو وہ تمہیں سنگسار کر ڈالیں گے یا (زبردستی) تمہیں اپنے دین میں واپس لے جائیں گے اور ایسا ہوا تو پھر تم کبھی فلاح نہ پا سکو گے۔
