quran[17{c,v,t}:
52,15,تو (بتلاؤ) کیا یہ بھی جادو ہے یا تمہیں (اب بھی) سجھائی نہیں دیتا ؟۔
52,16,چلے جاؤ اس کے اندر، پھر صبر کرو یا نہ کرو تمہارے حق میں (سب) برابر ہے۔ (آج) تم کو ویسا ہی بدلہ دیا جا رہا ہے جیسے عمل تم (دنیا میں) کرتے رہے۔
52,17,رہے) متقی لوگ (تو وہ) بلاشبہ (بہشت کے) باغوں اور نعمتوں میں ہوں گے،
52,18,خوش ہو رہے ہوں گے ان (نعمتوں) سے جو ان کے رب نے انہیں دی ہوں گی اور ان کا رب انہیں عذاب دوزخ سے محفوظ رکھے گا۔
52,19,ان سے کہا جائے گا) کھاؤ اور پیو خوب مزے سے ان (نیکیوں) کے بدلے میں جو تم (دنیا میں) کرتے رہے۔
52,20,وہ بچھے ہوئے تختوں پر تکیے لگائے (بیٹھے) ہوں گے اور ہم بڑی بڑی آنکھوں والی حوروں سے ان کو بیاہ دیں گے۔
52,21,اور جو لوگ ایمان لائے اور ان کی اولاد بھی، ایمان کے ساتھ ان کی پیروی کرتی رہی (گو اعمال میں وہ اپنے آباء کے رتبے کو نہ پہنچے لیکن جنتیوں کے اکرام اور ان کو خوش کرنے کے لئے) ان کی (اس) اولاد کو (بھی) ہم (جنت میں) ان کے ساتھ ملا دیں گے اور (اس کے بدلے میں) ہم ان (جنتیوں) کے اعمال (کے صلے) میں سے کچھ بھی کم نہیں کریں گے۔ (لیکن اولاد نیک نہیں ہے تو اس کا اپنے مومنین آباء کے ساتھ الحاق نہیں ہوسکتا کیونکہ) ہر شخص اپنے عمل کے بدلے میں رہن ہے۔
52,22,اور جس میوے اور گوشت کو ان (جنتیوں) کا جی چاہے گا ہم ان کے لئے اس کی ریل پیل کردیں گے
52,23,(اور بطور خوش طبعی کے) وہ آپس میں جام (شراب) پر چھینا جھپٹی بھی کریں گے۔ اس (شراب) میں نہ یا وہ گوئی ہوگی اور نہ بدکرداری۔
52,24,اور (ان کی خدمت کے لئے ایسے خوبصورت) لڑکے ان کے پاس آئیں جائیں گے کہ گویا وہ چھپا کر رکھے ہوئے موتی ہیں۔
52,25,اور (یہ جنتی) ایک دوسرے کی طرف متوجہ ہو کر آپس میں باتیں کریں گے۔
52,26,اور (اثنائے گفتگو میں) کہیں گے کہ ہم (اس سے) پہلے اپنے گھر والوں میں (انجام کار سے) ڈرتے (ہوئے زندگی بسر کرتے) تھے۔
52,27,آخرکار اللہ نے ہم پر (بڑا ہی) فضل کیا اور ہمیں (دوزخ کی جھلسا دینے والی) لو کے عذاب سے بچا لیا۔
52,28,بیشک (اس سے) پہلے ہم اس سے دعائیں مانگا کرتے تھے۔ واقعی وہ بڑا احسان کرنے والا (اور) ہمیشہ رحم کرنے والا ہے۔
52,29,پس (اے پیغمبر، تم ان لوگوں کو) نصیحت کئے جاؤ کیونکہ تم اپنے رب کے فضل سے نہ تو کاہن ہو اور نہ دیوانے (جیسا کہ یہ مشرکین کہتے ہیں) ۔
52,30,اے پیغمبر، ) کیا یہ لوگ (تمہاری نسبت) کہتے ہیں کہ یہ شاعر ہے (اور) ہم اس کے حق میں گردش ایام کا انتظار کر رہے ہیں ؟
52,31,تم ان سے) کہو، (بہت اچھا) انتظار کرو، میں بھی تمہارے ساتھ انتظار کرتا ہوں۔
