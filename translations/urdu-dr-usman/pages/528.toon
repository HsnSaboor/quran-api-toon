quran[24{c,v,t}:
53,45,اور یہ کہ وہی نر اور مادہ کا جوڑا پیدا کرتا ہے
53,46,ایک بوند سے جب وہ ٹپکائی جاتی ہے
53,47,اور یہ کہ دوبارہ (جِلا) اٹھانا بھی اسی کے ذمے ہے۔
53,48,اور یہ کہ وہی (لوگوں کو) مال دار اور سرمایہ دار کرتا ہے،
53,49,اور یہ کہ وہی شعرا کا رب ہے،
53,50,اور یہ کہ اس نے عاد اوّل کو ہلاک کیا۔
53,51,اور ثمود کو بھی، پس کسی کو باقی نہیں چھوڑا۔
53,52,اور (ان سے) پہلے نوح کی قوم کو (ہلاک کیا تھا) کیونکہ وہ تھے ہی ظالم اور سرکش لوگ۔
53,53,اور اس نے الٹی ہوئی بستیوں کو بھی اٹھا پھینکا۔
53,54,اور پھر چھا دیا ان پر جو کچھ چھادیا۔
53,55,پس (اے انسان، ) تو اپنے رب کے کن کن کرشموں میں شک کرے گا ؟۔
53,56,یہ (پیغمبر، ) بھی اگلے خبردار کرنے والوں میں سے ایک خبردار کرنے والا ہے۔
53,57,قیامت) جو آنے والی ہے قریب آپہنچی۔
53,58,اللہ کے سوا کوئی اس کو ٹالنے والا نہیں۔
53,59,تو کیا تم لوگ اس بات پر تعجب کرتے ہو ؟۔
53,60,اور ہنستے ہو اور روتے نہیں ہو۔
53,61,اور (خواب) غفلت میں پڑے ہوئے ہو ؟۔
53,62,ہوش میں آؤ، ) اللہ کے آگے جھک جاؤ اور (اسی کی) عبادت کرو۔
54,1,قیامت نزدیک آپہنچی اور چاند شق ہوگیا۔
54,2,اور اگر (یہ منکرین) کوئی نشانی دیکھ لیں گے تو (اس سے) اعراض ہی کریں گے اور کہیں گے کہ یہ تو جادو ہے جو پہلے سے چلا آ رہا ہے۔
54,3,اور انہوں نے (پیغمبر کو) جھٹلا دیا اور اپنی (نفسانی) خواہشوں کی پیروی کی۔ اور ہر کام قرار پا چکا ہے۔
54,4,اور یقینا ان لوگوں کے پاس (پچھلی قوموں کے) حالات پہنچ چکے ہیں جن میں (کافی) سامان عبرت ہے۔
54,5,اور) انتہائی درجہ دانائی (کی باتیں بھی) مگر ڈرانا ان پر کارگر نہیں ہوتا۔
54,6,پس (اے پیغمبر، ) تم ان لوگوں سے رخ پھیر لو (اور اس دن کا انتظار کرو) جس دن پکارنے والا ان کو ایک (سخت) ناگوار چیز کی طرف پکارے گا۔
