quran[27{c,v,t}:
37,127,مگر ان لوگوں نے اسے جھٹلایا سو یہ لوگ (قیامت میں) ضرور گرفتار (عذاب) ہوں گے۔
37,128,مگر جو اللہ کے برگزیدہ بندے ہیں (وہ عذاب سے محفوظ رہیں گے) ۔
37,129,اور ہم نے (الیاس کے بعد) آنے والی امتوں میں اس کا ذکر خیر باقی رکھا۔
37,130,کہ سارے جہان میں ہر طرف سے) سلام ہے الیاسین پر۔
37,131,بیشک ہم نیکوکاروں کو ایسا ہی صلہ دیا کرتے ہیں۔
37,132,بلاشبہ وہ ہمارے مومن بندوں میں سے تھا۔
37,133,اور بلاشبہ لوط بھی پیغمبروں میں سے تھا۔
37,134,اے پیغمبر، وہ وقت یاد کرو) جب ہم نے اس کو اور اس کے سب گھر والوں کو نجات دی تھی
37,135,بجز ایک بڑھیا کے کہ وہ پیچھے رہ جانے والوں میں تھی۔
37,136,پھر (ان کے نکل جانے کے بعد) ہم نے اوروں کو ہلاک کر مارا
37,137,اور تم لوگ تو صبح ہوتے ان (کی اجڑی ہوئی بستیوں) پر سے گزرا کرتے ہو۔
37,138,اور رات کو بھی، کیا تم لوگ عقل سے (اتنا بھی) کام نہیں لیتے (کہ ان کو دیکھ کر عبرت پکڑو) ؟
37,139,اور بلاشبہ یونس بھی پیغمبروں میں سے تھا۔
37,140,اے پیغمبر، وہ وقت یاد کرو) جب وہ بھاگ کر ایک بھری ہوئی کشتی کے پاس پہنچا۔
37,141,پھر وہ قرعہ اندازی میں شریک ہوا تو مجرم قرار پایا (اور آخرکار دریا میں پھینک دیا گیا)
37,142,تو مچھلی نے اسے (ثابت) نگل لیا اور وہ اپنے کو ملامت کر رہا تھا۔
37,143,سو اگر وہ (اس وقت اللہ کی) تسبیح (وتقدیس) کرنے والوں میں سے نہ ہوتا
37,144,تو روز قیامت تک مچھلی کے پیٹ میں (پڑا) رہتا۔
37,145,پھر ہم نے اسے (مچھلی کے پیٹ سے نکال کر) ایک چٹیل میدان میں ڈال دیا اور وہ (بہت ہی) نڈھال (ہو گیا) تھا۔
37,146,اور ہم نے اس پر ایک بیل دار درخت اگا دیا۔
37,147,اور ہم نے اسے ایک لاکھ (آبادی) کی طرف (پیغمبر بنا کر) بھیجا بلکہ (ایک حساب سے وہ لاکھ سے بھی) زیادہ تھے۔
37,148,پھر وہ لوگ (اس پر) ایمان لائے تو ہم نے ان کو ایک وقت (خاص) تک (سامان زیست سے) بہرہ مندہ کیا۔
37,149,تو (اے پیغمبر، ذرا) ان لوگوں سے پوچھو کہ تمہارے رب کے لئے تو بیٹیاں ہوں اور ان کے لئے بیٹے ؟
37,150,کیا ہم نے فرشتوں کو عورت بنایا تھا اور یہ دیکھ رہے تھے۔
37,151,خوب سن لو، وہ یہ بات اپنے دل سے بنا بنا کر کہتے ہیں
37,152,کہ اللہ کے اولاد ہے اور وہ یقینا جھوٹے ہیں۔
37,153,کیا (اللہ نے) بیٹوں پر (بیٹیوں کو ترجیح دے کر) بیٹیاں (اپنے لئے) پسند کیں ؟
