quran[24{c,v,t}:
37,103,پھر جب دونوں (باپ بیٹے) تعمیل حکم (الٰہی) پر آمادہ ہوگئے اور باپ نے بیٹے کو ماتھے کے بل (زمین پر) گرا دیا
37,104,تو ہماری رحمت جوش میں آئی) اور ہم نے آواز دی، '' اے ابراہیم
37,105,واقعی تو نے خواب سچ کر دکھایا (اب ہم تجھے بڑے بڑے مراتب دیں گے اور) نیکوکاروں کو ہم ایسا ہی صلہ دیا کرتے ہیں،''
37,106,حقیقت میں یہ تھی بھی ایک کھلی ہوئی آزمائش۔
37,107,اور ہم نے ایک بڑی قربانی اس (بچے) کے بدلے میں دے دی۔
37,108,اور (ابراہیم کے بعد) آنے والی امتوں میں اس کا ذکر خیر باقی رکھا
37,109,کہ (سارے جہان میں ہر طرف سے) سلام ہے ابراہیم پر۔
37,110,ہم نیکو کاروں کو ایسا ہی صلہ دیا کرتے ہیں۔
37,111,بلاشبہ وہ ہمارے مومن بندوں میں تھا۔
37,112,اور ہم نے ابراہیم کو (ایک دوسرے فرزند) اسحاق نبی کی خوشخبری دی جو نیک بندوں میں سے ہوگا
37,113,اور ہم نے اس پر اور اسحاق پر (اپنی) برکتیں نازل فرمائیں اور (اب) ان دونوں کی نسل میں (بعض) نیکوکار ہیں اور (بعض نافرمانیاں کر کے) اپنی جانوں پر صریح ظلم کر رہے ہیں۔
37,114,اور (دیکھو، ) ہم نے موسیٰ اور ہارون پر (بھی بہت سے) احسانات کئے
37,115,اور ان دونوں کو اور ان کی قوم کو کرب عظیم سے نجات دی۔
37,116,اور (فرعون کے مقابلے میں) ان کی مدد کی تو (آخرکار) یہی لوگ غالب رہے۔
37,117,اور ان دونوں کو صحیح واضح کتاب (تورات) عطا کی۔
37,118,اور ان دونوں کو (دین کا) سیدھا راستہ دکھایا
37,119,اور (ان کے بعد) آنے والی امتوں میں ان کا ذکر خیر باقی رکھا
37,120,کہ (سارے جہان میں ہر طرف سے) سلام ہے موسیٰ اور ہارون پر۔
37,121,بیشک ہم نیکوکاروں کو ایسا ہی صلہ دیا کرتے ہیں۔
37,122,بلاشبہ وہ دونوں ہمارے مومن بندوں میں سے تھے۔
37,123,اور بلاشبہ الیاس (بھی) پیغمبروں میں سے تھا۔
37,124,اے پیغمبر، وہ وقت یاد کرو) جب اس نے اپنی قوم سے کہا، '' کیا تم لوگ (اللہ سے) نہیں ڈرتے ؟
37,125,کیا تم بعل کو پکارتے ہو اور ( اللہ) احسن الخالقین کو چھوڑ بیٹھے ہو،
37,126,اس) اللہ کو جو تمہارا بھی رب ہے اور تمہارے اگلے باپ دادوں کا (بھی) رب ؟
