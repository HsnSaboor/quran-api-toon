quran[18{c,v,t}:
52,32,کیا ان کی عقلیں ان کو یہ باتیں سکھاتی ہیں یا یہ ہیں ہی سرکش لوگ ؟
52,33,کیا یہ کہتے ہیں کہ اس شخص نے (قرآن خود) گھڑ لیا ہے ؟ (یہ بات نہیں، ) بلکہ (یہ بات وہ اس وجہ سے کہتے ہیں کہ) یہ لوگ ایمان ہی لانا نہیں چاہتے
52,34,اچھا) تو یہ لوگ اسی طرح کا کلام (بنا کر) لے آئیں اگر ( اپنے دعوے میں) سچے ہیں
52,35,کیا یہ لوگ کسی (خالق) کے بغیر (خود) پیدا ہوگئے ہیں یا یہ خود (اپنے) خالق ہیں ؟
52,36,کیا زمین اور آسمان کو انہوں نے پیدا کیا ہے ؟ (نہیں، ) بلکہ (بات یہ ہے کہ) یہ لوگ (اللہ پر) یقین ہی نہیں رکھتے۔
52,37,اے پیغمبر، ) کیا تمہارے رب کے خزانے ان کے قبضے میں ہیں یا وہ (خود) حاکم ہیں ؟
52,38,کیا ان کے پاس کوئی سیڑھی ہے کہ (اس پر چڑھ کر عالم بالا کی باتیں) سن آیا کرتے ہیں ؟ تو ان میں سے جو سن آیا ہو لائے (اپنے دعوے پر) کھلی دلیل۔
52,39,کیا اللہ کے لئے تو بیٹیاں ہیں اور تم لوگوں کے لئے بیٹے ؟
52,40,(اے پیغمبر، ) کیا تم ان لوگوں سے (تبلیغ رسالت کا کوئی) معاوضہ طلب کرتے ہو کہ یہ (اس) چٹی (کے بوجھ) سے دبے جاتے ہیں ؟
52,41,کیا ان کے پاس (علم) غیب ہے (جس کی بناء پر) یہ لکھ لیا کرتے ہیں ؟
52,42,کیا یہ (ہمارے پیغمبر کے ساتھ کچھ) برائی کا ارادہ رکھتے ہیں ؟ تو (جان لیں کہ) اس برائی (کے وبال) میں خود (کافر) ہی گرفتارہوں گے۔
52,43,کیا اللہ کے سوا ان کا کوئی (اور) معبود ہے ؟ اللہ (کی ذات) پاک ہے اس شرک سے جو یہ لوگ کر رہے ہیں۔
52,44,اور اگر یہ آسمان کا کوئی ٹکڑا گرتا ہوا (بھی) دیکھ لیں تو کہہ دیں گے کہ یہ تو تہہ در تہہ (جما ہوا) بادل ہے۔
52,45,پس (اے پیغمبر، ) ان لوگوں کو (ان کی حالت پر) چھوڑ دو یہاں تک کہ ان کو اپنے اس دن سے سابقہ پیش آجائے جس میں ان کے ہوش اڑ جائیں گے۔
52,46,اس دن ان کے مکر (وفریب) ان کے کچھ بھی کام نہ آئیں گے اور نہ (کہیں سے) ان کو مدد ملے گی۔
52,47,اور بیشک ان ظالموں کو اس (دن کے آنے) سے پہلے بھی (دنیا میں) عذاب (ہونے والا) ہے مگر ان میں سے اکثر جانتے نہیں۔
52,48,اے پیغمبر، ) اپنے رب کا فیصلہ آنے تک صبر کرو، تم ہماری آنکھوں کے سامنے (اور ہماری حفاظت میں) ہو۔ جس وقت اٹھا کرو اپنے رب کی حمد (وثنا) کے ساتھ اس کی تسبیح (وتقدیس) کیا کرو،
52,49,اور رات کے ایک حصے میں بھی اس کی تسبیح (وتقدیس) کیا کرو اور ستاروں (کے غروب ہونے) کے بعد بھی۔
