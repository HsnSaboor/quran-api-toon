quran[11{c,v,t}:
7,1,الف۔ لام۔ میم۔ صاد۔
7,2,اے پیغمبر، یہ) کتاب تم پر (اس لئے) نازل کی گئی ہے کہ اس کے ذریعے سے تم (لوگوں کو انکار و بد عملی کے نتائج سے) ڈراؤ اور ایمان والوں کو نصیحت ہو۔ پس اس (کتاب) کی وجہ سے (کسی طرح کی) تمہارے دل میں تنگی (پیدا) نہ ہو۔
7,3,لوگو، ) جو کچھ تمہارے رب کی طرف سے تم پر نازل ہوا ہے اس کی پیروی کرو اور اللہ کے سوا (اپنے ٹھہرائے ہوئے) سرپرستوں کی پیروی نہ کرو (مگر) تم لوگ کم ہی نصیحت قبول کرتے ہو۔
7,4,اور (دیکھو، ) کتنی ہی بستیاں ہیں جنہیں ہم نے (انکار و بدعملی کی پاداش میں) ہلاک کردیا۔ ان پر ہمارا عذاب رات کے وقت ٹوٹ پڑا یا دوپہر کے وقت آپہنچا جب کہ وہ آرام میں تھے۔
7,5,پھر جب ہمارا عذاب آیا تو ان کی (زبان پر) اس کے سوا کوئی صدا نہ تھی کہ بلاشبہ ہم ہی ظالم (و خطاکار) تھے۔
7,6,تو (دیکھو، قیامت کے دن) ہم ان لوگوں سے ضرور باز پرس کریں گے جن کی طرف پیغمبر بھیجے گئے تھے (کہ وہ پیغمبروں کی نصیحت پر کاربند ہوئے تھے یا نہیں) اور پیغمبروں سے بھی ہم ضرور پوچھیں گے (کہ انہوں نے فرض رسالت ادا کیا تھا یا نہیں) ۔
7,7,پھر یقینا (ان کے اعمال کی سرگزشت) ہم انہیں اپنے علم سے سنا دیں گے، آخر ہم (ان کے عمل کے وقت) غائب تو نہ تھے۔
7,8,اور اس دن (اعمال کا) تولنا برحق ہے۔ پھر جن (کی نیکیوں) کے پلے بھاری ہوں گے وہی فلاح پانے والے ہوں گے
7,9,اور جن کے پلے ہلکے ہوں گے تو یہ وہ لوگ ہیں جنہوں نے اپنا نقصان آپ کیا کیونکہ وہ ہماری آیتوں سے ناانصافی کرتے تھے۔
7,10,اور ہم نے تمہیں زمین میں (قدرت و اختیار کے ساتھ) بسایا اور اس میں تمہارے لئے سامان زندگی (فراہم) کیا، (مگر) تم لوگ کم ہی شکرگزار ہوتے ہو۔
7,11,اور (دیکھو، یہ ہماری کارفرمائی ہے کہ) ہم نے تم کو پیدا کیا پھر تمہاری صورت بنائی، پھر فرشتوں کو حکم دیا کہ آدم کو سجدہ کرو تو (سب نے) سجدہ کیا مگر ابلیس سجدہ کرنے والوں میں (شامل) نہ ہوا۔
