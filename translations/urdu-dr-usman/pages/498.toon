quran[20{c,v,t}:
44,40,یقینا ان سب (کے اٹھائے جانے) کا وقت مقرر فیصلے کا دن ہے۔
44,41,جس دن کوئی دوست کسی دوست کے کچھ کام نہ آئے گا اور نہ (کہیں سے) انہیں مدد پہنچے گی۔
44,42,مگر جس پر اللہ رحم فرمائے (تو اس کا بیڑا پار ہے) ۔ بیشک وہ زبردست ہے (اور) رحیم (بھی) ۔
44,43,بیشک (آخرت میں) زقوم کا درخت۔
44,44,مجرموں کا کھانا ہوگا،
44,45,تیل کی تلچھٹ جیسا۔ وہ پیٹ میں ایسا کھولے گا
44,46,جیسے گرم پانی کھولتا ہے۔
44,47,اور فرشتوں کو حکم ہوگا کہ) اسے پکڑو اور گھسیٹتے ہوئے جہنم کے بیچوں بیچ تک لے جاؤ۔
44,48,پھر اس کے سر پر کھولتے پانی کا عذاب انڈیل دو۔
44,49,چکھ (اس عذاب کا مزا) تو بڑا زبردست (اور) عزت دار ہے نا۔
44,50,بیشک یہی تو وہ (چیز) ہے جس کے بارے میں تم لوگ شک کیا کرتے تھے۔
44,51,بیشک متقین امن کی جگہ میں ہوں گے،
44,52,یعنی) باغوں اور چشموں میں
44,53,رشیم کی باریک اور دبیز پوشاکیں پہنے ہوئے (ایک دوسرے کے) آمنے سامنے بیٹھے ہوں گے۔
44,54,ایسی ہی ہوگی (ان کی شان) اور ہم گوری گوری آہو چشم عورتیں ان کی زوجیت میں دے دیں گے۔
44,55,وہاں وہ اطمینان سے ہر طرح کے میوے منگا (منگا کر کھا) رہے ہوں گے۔
44,56,اور) پہلی (دفعہ کی) موت کے سوا (جو دنیا میں آچکی) وہاں ان کو موت (کی تلخی) کبھی چکھنی نہ پڑے گی اور اللہ انہیں دوزخ کے عذاب سے محفوظ رکھے گا۔
44,57,اے پیغمبر، یہ سب) تمہارے رب کے فضل سے ہوگا۔ یہی بڑی کامیابی ہے۔
44,58,پس (اے پیغمبر، ) ہم نے اس (قرآن) کو تمہاری زبان میں آسان کردیا ہے تاکہ یہ (اہل عرب اس کے مضامین سمجھ کر) نصیحت پکڑیں۔
44,59,سردست) تو (تم بھی نتیجے کا) انتظار کرو، یہ بھی منتظر ہیں۔
