quran[42]{c,v,t}:
  80,1,"O √Īir…ďanii o ruŇčtii."
  80,2,"Sabu arde e mum bum…óo."
  80,3,"Hol ko anndin ma yaama o laa…ďa."
  80,4,"Wolla o waajito waajo nafa …óum."
  80,5,"Si tawi ko oon jondanii…óo o hoore mum."
  80,6,"Aan noon ha…óa …óum falo."
  80,7,"Ala ko fawi ma si o laa…ďaani."
  80,8,"Si tawi ko oon gar…óo e ma hombo yaha."
  80,9,"Te hombo huli Alla."
  80,10,"Aan ha…óa sokliri …óum gaa e wo…ď…ďe."
  80,11,"Alah …óum …óoon ko ciftanirgol."
  80,12,"Ko kala paalaa…óo jaŇčtoo …óum."
  80,13,"E ndeer …óeri teddinaa…ói."
  80,14,"∆Āamtaa…ói ceninaa…ói."
  80,15,"Hi…ói e juu…óe maleykaaji en."
  80,16,"Teddu…ói keew…ói …óiggere."
  80,17,"Hu…óaama ne…ó…óo ala ko …ďuri …óum he'efarin'de."
  80,18,"E honde hu'unde o tagri …óum."
  80,19,"E to…ď…ďere o tagri …óum o e…ď…ďi …óum."
  80,20,"Refti o newnani …óum laawol."
  80,21,"Refti o wari mbo o naatni …óum yenaande."
  80,22,"Refti si o faalaama o ummina mbo."
  80,23,"Ala o wa…óaani ko Alla yamiri …óum."
  80,24,"Yo ne…ó…óo ndaar √Īaamdu mum."
  80,25,"Min njuppii ndiyam …óam kala juppugol."
  80,26,"Refti Min ceeki leydi ndi kala ce'ekgol."
  80,27,"Min pu…óni e hendi gabbe ne."
  80,28,"E inab e √Īaayka ngam daabe."
  80,29,"E(nebam) oliv e tamara."
  80,30,"E gese keew…óe le…ó…óe (cukku…óe)."
  80,31,"E muuyanteeje yo hu…óo ngam daabe."
  80,32,"Ngam wona nafoore mon e ku'ule mon."
  80,33,"Si ha'acaango ngo ari."
  80,34,"√Īande ne…ó…óo dogi musi…ó…óo mum."
  80,35,"E neene mum e baaba mum."
  80,36,"E debbo mum e …ďi…ď…ďe mum."
  80,37,"Kala ne…ó…óo e mum en √Īande heen na jogii ko yoni …óum ."
  80,38,"Je'ece malaabe √Īande heen na fooyni."
  80,39,"He…óe njala he…óe mbeltii."
  80,40,"Je'ece goo na e dow mum en punndi-sollaaru-."
  80,41,"Ina hippa…óe ni…ďre."
  80,42,"Ko …ďeen ngoni he'efaree…ďe faajiree…ďe."