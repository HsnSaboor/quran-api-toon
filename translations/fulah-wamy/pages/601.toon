quran[17]{c,v,t}:
  103,1,"Mi wooЙ—ndirii waqtu asri."
  103,2,"Pellet neЙ—Й—o hina woni ko e perte."
  103,3,"Si wona Й“een gooЕӢЙ—inЙ“e Й“e ngolli golle moЖҙЖҙe Й—e, hino woodani Й“e njoЙ“di ndi taЖҙondirtaa."
  104,1,"Lepte ngoodanii Й“iiГұoowo sanne e ЕӢooЙ“oowo sanne."
  104,2,"Oon denndin'Й—o jawdi o limi ndi."
  104,3,"Hombo sikka jawdi mum ndi saasnat Й—um."
  104,4,"Ala maЙ“e werne e jayngol moolatngol."
  104,5,"Ko ho Й—um anndinat maa ko woni jayngol keltoowol ?"
  104,6,"Ko jayngol Alla kuЙ“Й“at ngol."
  104,7,"Ngol woni julatngol keeГұe."
  104,8,"Ngool de ko ngol sokangol e dow maЙ“Й“e."
  104,9,"Hongol doosЙ—e pooЙ—tiiЙ—e."
  105,1,"Mbele ayiaani na joom ma waЙ—i joom Гұiiwa ba."
  105,2,"Mbele o waЙ—aani peeje mu'en e majjere."
  105,3,"O neli e mu'en ndiwri abaa biila."
  105,4,"HoЙ—ii mberlooЙ“e kaaЖҙe loope jo'orЙ—e."
  105,5,"O waЙ—i Й—umen hono Гұaayka Гұaamaaka."