quran[21]{c,v,t}:
  100,10,"Yaltine ko woni ko e ɓerɗe he."
  100,11,"Joom mu'en ñande heen ko o kumpatiiɗo."
  101,1,"Darnga ngo konngoowo ɓerɗe."
  101,2,"Hol ko woni qari*a."
  101,3,"Hol ko anndinat ma qari'a."
  101,4,"Ñande yimɓe mba'i no mbeɗoñ Alla carikoñ."
  101,5,"Pelle ɗeen mba'oya no hottolle kardaako,"
  101,6,"Si tawi ko oon mbo pe'esirɗe mum nisi."
  101,7,"Hara himo e nguurndam mbelɗam :"
  101,8,"Si tawi ko oon mbo pe'esirɗe mum koyi."
  101,9,"Hoɗorde mum ko jahannama."
  101,10,"Ko holɗum anndinat maa ko woni ngeen?"
  101,11,"Ko nge jayngol wulnge."
  102,1,"Soklinii on wasandirde ɓura heewde ngalu e sukaaɓe."
  102,2,"Ha njuuriɗon genaale ɗe."
  102,3,"Ala arma nganndon."
  102,4,"Refti arma on nganndu."
  102,5,"Ko goongo ma on nganndoy ganndal yananeede."
  102,6,"Pellet ma on njii jayngol."
  102,7,"Refti ma on njii'ru ngol gite yananeede."
  102,8,"Refti ma on naamne ñande heen ne'ema."