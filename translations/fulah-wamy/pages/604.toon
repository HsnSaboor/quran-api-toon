quran[15]{c,v,t}:
  112,1,"Wi ko KaŇčko woni Alla go'oto."
  112,2,"Alla pa'andatee…óo."
  112,3,"O jibinaani o jinaaka."
  112,4,"O ala pasa hay go'oto."
  113,1,"Maaku mbi…óo moolo e joom subaka."
  113,2,"Immorde bone ko o tagi."
  113,3,"E bone jehma ni…ď…ďu…óo si mo ni…ď…ďi."
  113,4,"E bone …ďeen wuttoo…ďe e pi…ďlee."
  113,5,"E bone a√Īaan si o a√Īani."
  114,1,"Wi mbi…óo moolo e joom yim…ďe …ďe."
  114,2,"Laam…óo yim…ďe …ďe."
  114,3,"Dewetee…óo yim…ďe …ďe."
  114,4,"E bone seytaaneeji cikkinooji."
  114,5,"OOn cikkinoowo e …ďer…óe yim…ďe …ďe."
  114,6,"Ummaade e jinneeji e yim…ďe …ďe."