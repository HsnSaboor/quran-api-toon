quran[7]{c,v,t}:
  107,1,"Mbele a anndii oon jeddoowo njoɓdi ñande daranga"
  107,2,"E Ko oon duñoowo alyatiime."
  107,3,"O reerɗintaa e ñammiingol miskiina(wa'asɓe)."
  107,4,"Halkaare woodanii juulooɓe ɓeen."
  107,5,"Ɓeen welsandiiɓe ndeer juulde maɓɓe."
  107,6,"Ɓeen yi'inatooɓe."
  107,7,"Heɓe kaɗa ngenndukoñ."
