quran[29]{c,v,t}:
  81,1,"Si ka kammu hofaama."
  81,2,"Si koode ɗe caami."
  81,3,"Si ka pelle ɗe nawaama."
  81,4,"Si geloobi cowiiɗi ɗi dutnaama."
  81,5,"Si ku'ule ladde ndenndinaama."
  81,6,"Si maaje ɗe ne kuɓɓaama."
  81,7,"Si ka pittaali cinndindiraama."
  81,8,"Si bingel ubbangel na wuuri naamnaama."
  81,9,"Hol bakkaat ngel wardano.?"
  81,10,"Si ɗereeji ca'aktaama."
  81,11,"Si kammu o hu'uftaama"
  81,12,"Si jayngol huɓɓaama."
  81,13,"Si aljanna o ɓatlinaama."
  81,14,"Fittaandu ndu annda ko ndu addi."
  81,15,"Mbiɗa wooɗndira koode birniiɗe."
  81,16,"Dogooje je birnatooɗe."
  81,17,"Mi woondarii jehma si o arii e niɓɓidde."
  81,18,"E subaka o si annoore mum feeñi."
  81,19,"Won'de pellet, [Alqur'aana] ko konngol nulaaɗo tedduɗo."
  81,20,"jom semmbe to joom arsi dokkaaɗo daraja."
  81,21,"Ɗoftaaɗo toon koolaaɗo."
  81,22,"Gondiijo mon o wona kaangaaka ."
  81,23,"Ko goongo o yiii mbo to jookli laaɓtuɗi."
  81,24,"O wona ɗawoowo yottinde on mbirniindi."
  81,25,"Alquraana wona konngol seytaani diddaaɗo yurmeende oon."
  81,26,"Hoɗo njahaton?"
  81,27,"Ndee [alqur’aanaare] wonaani, si wonaa waajo winndere nde."
  81,28,"Kala paalaaɗo e mon fo'occaade."
  81,29,"On paaletaake fo'occaade si wona Alla haaje ɗuum jom binnde oon."
