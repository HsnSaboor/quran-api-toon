quran[9]{c,v,t}:
  104,1,"Lepte ngoodanii ɓiiñoowo sanne e ŋooɓoowo sanne."
  104,2,"Oon denndin'ɗo jawdi o limi ndi."
  104,3,"Hombo sikka jawdi mum ndi saasnat ɗum."
  104,4,"Ala maɓe werne e jayngol moolatngol."
  104,5,"Ko ho ɗum anndinat maa ko woni jayngol keltoowol ?"
  104,6,"Ko jayngol Alla kuɓɓat ngol."
  104,7,"Ngol woni julatngol keeñe."
  104,8,"Ngool de ko ngol sokangol e dow maɓɓe."
  104,9,"Hongol doosɗe pooɗtiiɗe."
