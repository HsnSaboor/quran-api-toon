quran[19]{c,v,t}:
  87,1,"Senin innde joom ma ɓurnde toowde."
  87,2,"Oon takɗo o fotndi."
  87,3,"OOn koddirɗo refti o feewni."
  87,4,"Oon jaltinɗo durngol ngol."
  87,5,"O waɗi ngol joongol bayliingol;"
  87,6,"Ma min njanngin ma A yejjittah."
  87,7,"Si wona ko Alla haaji pellet hombo anndi ko feeñi e ko wirnii."
  87,8,"Min newnan ma na newori."
  87,9,"Siftinir ɗoon ɗo ciftanirgol hina nafa."
  87,10,"Ma siftor oon kulɗo Alla."
  87,11,"Woɗɗitoo ɗum ɓurɗo hiiteede."
  87,12,"Oon naatoowo jayngol manngol ngol."
  87,13,"Refti o maayata toon o wuurata."
  87,14,"Malaama de oon laaɓɗo e sirku."
  87,15,"O jaŋtii Innde joom mum o juuli."
  87,16,"Ko woni, ko hoɗon ɓurna nguurndam adunaoon."
  87,17,"Ko La'akara ɓuri moƴƴude e heddaade."
  87,18,"ɗum hiina e ɗereeji gadiiɗi ɗi."
  87,19,"Ɗereeji Ibraahiima e Muusa."
