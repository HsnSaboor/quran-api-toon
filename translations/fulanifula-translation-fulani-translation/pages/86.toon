quran[17]{c,v,t}:
  86,1,"Mi wooɗndirii kammu e hoodere fuɗoore jehma."
  86,2,"Hol ko anndinat ma ko woni hoodere feeñoore jehma."
  86,3,"Hoodere nde fooynunde."
  86,4,"Alaa fittaandu si wona ina e dow mayru deenoowo."
  86,5,"Yo neɗɗo ndaar ko o takraa ko."
  86,6,"O tagaama ko e ndiyam nduñotoɗam."
  86,7,"Ɗam yalta ke'eci gorko e ƴi'e ɓernde debba."
  86,8,"Homo hattani ruttude ɗum ."
  86,9,"Ñande cuuɗiiɗi kuñcaa."
  86,10,"Alana ɗum semmbe wona balloowo."
  86,11,"Mi wooɗndirii kammu joom ɗate ngun !"
  86,12,"Mi wooɗndirii lesdi mbaɗndi petti ."
  86,13,"Pellet o alquraana kombo ceerndoowol."
  86,14,"Mbo wona gaajaaɗe."
  86,15,"Pellet kamɓe heɓe pewja peeje."
  86,16,"Miɗo fewja fehre."
  86,17,"Muñan he'eferɓe muñangol seeɗa."
