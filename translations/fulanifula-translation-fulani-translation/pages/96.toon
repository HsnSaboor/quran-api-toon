quran[19]{c,v,t}:
  96,1,"janngu e innde joo ma oon takɗo."
  96,2,"Takɗo neɗɗo e heɗɗere."
  96,3,"Janngu e joom ma ɓurɗo o teddude."
  96,4,"Oon ganndanirɗo kuɗol."
  96,5,"O anndini neɗɗo ko o anndaana."
  96,6,"Kono woni ko neɗɗo na bewa."
  96,7,"Si o yi'i o yondaniima."
  96,8,"Pellet ko e jooma woni ruttorde nde."
  96,9,"Mbele a yi'i oon kaɗoowo."
  96,10,"Maccuɗo si o juulde"
  96,11,"A yi'ii si o laatiima e peewal."
  96,12,"Ma ɗum o yamiri kulol Alla."
  96,13,"Mbele a yi'i si o yeddii o ruŋtii."
  96,14,"Mbele o annda won'de Alla na yi'a."
  96,15,"Ala si o accaani ma min nanngu mbo e tiin tiinol min mbeddoo mbo e jayngol."
  96,16,"Tiin tiinol peŋngol goopngol."
  96,17,"Yo o noddu won'diiɓe mum."
  96,18,"Ma min noddu sokooɓe jahannama."
  96,19,"Ala woto ɗofto ɗum sujju ɓattaɗa."
