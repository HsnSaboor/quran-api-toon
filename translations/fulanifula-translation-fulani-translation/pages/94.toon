quran[8]{c,v,t}:
  94,1,"Mbele min n njaacnaani ma ɓernde ma."
  94,2,"Min ngittan ma bakkatuuji ma."
  94,3,"OOn nisnuɗo ke'eci ma."
  94,4,"Min ɓamtan ma innde ma."
  94,5,"Pellet kala saɗteende na won'di e newaare."
  94,6,"Pellet saɗteende kala na won'di e yaajeende."
  94,7,"Si a hantinii e (dewe alla)tampu."
  94,8,"E fa'ade joom ma reerɗu."
