quran[26]{c,v,t}:
  88,1,"Taw si arii e maaɗa Yeewtere fii darnga ngo."
  88,2,"Je'ece ñande heen na koyi."
  88,3,"Gollooje nih tampuɗe."
  88,4,"Heɗe naata jayngol gulngol."
  88,5,"Heɗe nkarnee e sewnde wulnde sanne."
  88,6,"Ɓe ngala ñaamdu si wona puɗi darii."
  88,7,"Ɗi paynata ɗi nafa e heege."
  88,8,"Je'ece malaabe ñande heen na pooyni."
  88,9,"Heɗe mbelaa golle mu'en."
  88,10,"E ndeer Aljanna toowɗo"
  88,11,"A nanata heen bolle mehre."
  88,12,"Hona e hembo sewnde iloore."
  88,13,"Hina e hembo le'ece ɓamtaaɗe."
  88,14,"E ka'aeeje keblaaɗe ngam yarde."
  88,15,"E gaflaaje potndaaɗe."
  88,16,"E mbettudi na sara kala baŋŋge."
  88,17,"Mbele ɓe ndaaraani na ngelooba tagira."
  88,18,"E feewde e kammu hono mbo ɓamtira."
  88,19,"E feewde pelle hono ɗe ndarnira."
  88,20,"E feewde leydi ndi hono ndi wertira."
  88,21,"Waajo aan ka a baajatooɗo."
  88,22,"A wona baawnoowo ɓe."
  88,23,"Si wona oon dunttiɗo o yeddi."
  88,24,"Alla lepta ɗi lepte ɓurɗe mawɗe."
  88,25,"Pellet ko to amen woni ruttorde maɓɓe."
  88,26,"Refti ko e amen woni haasboore mu'en."
