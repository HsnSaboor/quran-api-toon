quran[21]{c,v,t}:
  100,10,Wa Ĥuşşila Mā Fī Aş-Şudūri
  100,11,Inna Rabbahum Bihim Yawma'idhin Lakhabīrun
  101,1,Al-Qāri`ahu
  101,2,Mā Al-Qāri`ahu
  101,3,Wa Mā 'Adrāka Mā Al-Qāri`ahu
  101,4,Yawma Yakūnu An-Nāsu Kālfarāshi Al-Mabthūthi
  101,5,Wa Takūnu Al-Jibālu Kāl`ihni Al-Manfūshi
  101,6,Fa'ammā Man Thaqulat Mawāzīnuhu
  101,7,Fahuwa Fī `Īshatin Rāđiyahin
  101,8,Wa 'Ammā Man Khaffat Mawāzīnuhu
  101,9,Fa'ummuhu Hāwiyahun
  101,10,Wa Mā 'Adrāka Mā Hiyah
  101,11,Nārun Ĥāmiyahun
  102,1,Alhākumu At-Takāthuru
  102,2,Ĥattá Zurtumu Al-Maqābira
  102,3,Kallā Sawfa Ta`lamūna
  102,4,Thumma Kallā Sawfa Ta`lamūna
  102,5,Kallā Law Ta`lamūna `Ilma Al-Yaqīni
  102,6,Latarawunna Al-Jaĥīma
  102,7,Thumma Latarawunnahā `Ayna Al-Yaqīni
  102,8,Thumma Latus'alunna Yawma'idhin `Ani An-Na`īmi