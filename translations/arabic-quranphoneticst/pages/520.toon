quran[16]{c,v,t}:
  50,36,Wa Kam 'Ahlaknā Qablahum Min Qarnin Hum 'Ashaddu Minhum Baţshāan Fanaqqabū Fī Al-Bilādi Hal Min Maĥīşin
  50,37,Inna Fī Dhālika Ladhikrá Liman Kāna Lahu Qalbun 'Aw 'Alqá As-Sam`a Wa Huwa Shahīdun
  50,38,Wa Laqad Khalaqnā As-Samāwāti Wa Al-'Arđa Wa Mā Baynahumā Fī Sittati 'Ayyāmin Wa Mā Massanā Min Lughūbin
  50,39,Fāşbir `Alá Mā Yaqūlūna Wa Sabbiĥ Biĥamdi Rabbika Qabla Ţulū`i Ash-Shamsi Wa Qabla Al-Ghurūbi
  50,40,Wa Mina Al-Layli Fasabbiĥhu Wa 'Adbāra As-Sujūdi
  50,41,Wa Astami` Yawma Yunādi Al-Munādi Min Makānin Qarībin
  50,42,Yawma Yasma`ūna Aş-Şayĥata Bil-Ĥaqqi Dhālika Yawmu Al-Khurūji
  50,43,Innā Naĥnu Nuĥyī Wa Numītu Wa 'Ilaynā Al-Maşīru
  50,44,Yawma Tashaqqaqu Al-'Arđu `Anhum Sirā`āan Dhālika Ĥashrun `Alaynā Yasīrun
  50,45,Naĥnu 'A`lamu Bimā Yaqūlūna Wa Mā 'Anta `Alayhim Bijabbārin Fadhakkir Bil-Qur'āni Man Yakhāfu Wa`īdi
  51,1,Wa Adh-Dhāriyāti Dharwan
  51,2,Fālĥāmilāti Wiqrāan
  51,3,Fāljāriyāti Yusrāan
  51,4,Fālmuqassimāti 'Amrāan
  51,5,Innamā Tū`adūna Laşādiqun
  51,6,Wa 'Inna Ad-Dīna Lawāqi`un