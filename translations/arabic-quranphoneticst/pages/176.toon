quran[11]{c,v,t}:
  7,196,Inna Walīyiya Allāhu Al-Ladhī Nazzala Al-Kitāba Wa Huwa Yatawallá Aş-Şāliĥīna
  7,197,Wa Al-Ladhīna Tad`ūna Min Dūnihi Lā Yastaţī`ūna Naşrakum Wa Lā 'Anfusahum Yanşurūna
  7,198,Wa 'In Tad`ūhum 'Ilá Al-Hudá Lā Yasma`ū Wa Tarāhum Yanžurūna 'Ilayka Wa Hum Lā Yubşirūna
  7,199,Khudhi Al-`Afwa Wa 'Mur Bil-`Urfi Wa 'A`riđ `Ani Al-Jāhilīna
  7,200,Wa 'Immā Yanzaghannaka Mina Ash-Shayţāni Nazghun Fāsta`idh Billāhi 'Innahu Samī`un `Alīmun
  7,201,Inna Al-Ladhīna Attaqaw 'Idhā Massahum Ţā'ifun Mina Ash-Shayţāni Tadhakkarū Fa'idhā Hum Mubşirūna
  7,202,Wa 'Ikhwānuhum Yamuddūnahum Fī Al-Ghayyi Thumma Lā Yuqşirūna
  7,203,Wa 'Idhā Lam Ta'tihim Bi'āyatin Qālū Lawlā Ajtabaytahā Qul 'Innamā 'Attabi`u Mā Yūĥá 'Ilayya Min Rabbī Hādhā Başā'iru Min Rabbikum Wa Hudáan Wa Raĥmatun Liqawmin Yu'uminūna
  7,204,Wa 'Idhā Quri'a Al-Qur'ānu Fāstami`ū Lahu Wa 'Anşitū La`allakum Turĥamūna
  7,205,Wa Adhkur Rabbaka Fī Nafsika Tađarru`āan Wa Khīfatan Wa Dūna Al-Jahri Mina Al-Qawli Bil-Ghudūwi Wa Al-'Āşāli Wa Lā Takun Mina Al-Ghāfilīna
  7,206,Inna Al-Ladhīna `Inda Rabbika Lā Yastakbirūna `An `Ibādatihi Wa Yusabbiĥūnahu Wa Lahu Yasjudūna