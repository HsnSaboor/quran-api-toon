quran[9]{c,v,t}:
  30,16,Wa 'Ammā Al-Ladhīna Kafarū Wa Kadhabū Bi'āyātinā Wa Liqā'i Al-'Ākhirati Fa'ūlā'ika Fī Al-`Adhābi Muĥđarūna
  30,17,Fasubĥāna Allāhi Ĥīna Tumsūna Wa Ĥīna Tuşbiĥūna
  30,18,Wa Lahu Al-Ĥamdu Fī As-Samāwāti Wa Al-'Arđi Wa `Ashīyāan Wa Ĥīna Tužhirūna
  30,19,Yukhriju Al-Ĥayya Mina Al-Mayyiti Wa Yukhriju Al-Mayyita Mina Al-Ĥayyi Wa Yuĥyī Al-'Arđa Ba`da Mawtihā Wa Kadhalika Tukhrajūna
  30,20,Wa Min 'Āyātihi 'An Khalaqakum Min Turābin Thumma 'Idhā 'Antum Basharun Tantashirūna
  30,21,Wa Min 'Āyātihi 'An Khalaqa Lakum Min 'Anfusikum 'Azwājāan Litaskunū 'Ilayhā Wa Ja`ala Baynakum Mawaddatan Wa Raĥmatan 'Inna Fī Dhālika La'āyātin Liqawmin Yatafakkarūna
  30,22,Wa Min 'Āyātihi Khalqu As-Samāwāti Wa Al-'Arđi Wa Akhtilāfu 'Alsinatikum Wa 'Alwānikum 'Inna Fī Dhālika La'āyātin Lil`ālimīna
  30,23,Wa Min 'Āyātihi Manāmukum Bil-Layli Wa An-Nahāri Wa Abtighā'uukum Min Fađlihi 'Inna Fī Dhālika La'āyātin Liqawmin Yasma`ūna
  30,24,Wa Min 'Āyātihi Yurīkumu Al-Barqa Khawfāan Wa Ţama`āan Wa Yunazzilu Mina As-Samā'i Mā'an Fayuĥyī Bihi Al-'Arđa Ba`da Mawtihā 'Inna Fī Dhālika La'āyātin Liqawmin Ya`qilūna