quran[5]{c,v,t}:
  105,1,"Эй Паёмбар, оё надонистӣ, ки Парвардигорат бо Асҳоби Фил[3115] чӣ кард? Онҳое, ки мехостанд, ки хонаи Каъбаро вайрон кунанд.",footnotes:309561:1
  105,2,"Оё макрашонро ботил насохт?"
  105,3,"Ва бар сари онҳо паррандагони гурӯҳ-гурӯҳ фиристод,"
  105,4,"то онҳоро бо сиҷҷил[3116] сангборон карданд.",footnotes:309567:1
  105,5,"Пас, ононро чун коҳи хӯрдашуда гардонид."
