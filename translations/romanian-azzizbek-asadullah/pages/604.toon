quran[15]{c,v,t}:
  112,1,"Spune: „El este Allah, Cel Unic!"
  112,2,"Allah-us-Samad!"
  112,3,"El nu zămislește și nu este născut"
  112,4,"Și El nu are pe nimeni egal!”"
  113,1,"Spune: „Eu caut adăpost la Stăpânul revărsatului zorilor"
  113,2,"Împotriva răului [venind] de la ceea ce El a creat"
  113,3,"Și împotriva răului întunericului care se așterne"
  113,4,"Și împotriva răului vrăjitoarelor care suflă în noduri"
  113,5,"Și împotriva răului pizmuitorului, când pizmuiește.”"
  114,1,"Spune: „Eu caut adăpost la Domnul oamenilor,"
  114,2,"Stăpânul oamenilor,"
  114,3,"Dumnezeul oamenilor"
  114,4,"Împotriva răului ademenitorului fugar"
  114,5,"Care șoptește în piepturile oamenilor,"
  114,6,"Dintre djinni și oameni.”"