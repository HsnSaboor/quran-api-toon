quran[7{c,v,t}:
8,46,اور اللّٰہ اور اس کے رسول کی اطاعت کرو، اور آپس میں ایک دوسرے کے ساتھ تنازعہ نہ رکھو ورنہ کم ہمت ہو جاؤ گے اور (دشمن کے سامنے) تمہاری ہوا اکھڑ جائے گی، صبر سے کام لو ،بے شک اللّٰہ صبر کرنے والوں کے ساتھ ہے ۔
8,47,ان لوگوں کی وضع قطع اختیار نہ کرو جو اتراتے ہوئے اور خود نمائی کرتے ہوئے گھروں سے نکلے اور روش ان کی یہ تھی کہ (لوگوں کو) اللّٰہ کے راستے سے روکتے تھے ،اللّٰہ کی قدرت ان کے تمام اعمال پر محیط ہے۔
8,48,اور جب شیطان نے ان لوگوں کے اعمال ان کی آنکھوں میں بہت دلکش اور خوشنما بنا رکھے تھے اور ان کو یقین دلا رکھا تھا کہ لوگوں میں سے آج کوئی تم پر غالب نہیں آسکتا اور یہ بھی کہ میں تمہارے ساتھ ہوں، مگر جب دونوں گروہ (بدر میں) آمنے سامنے صف آرا ہوئے تو وہ الٹے پاؤں بھاگ گیا اور کہنے لگا :میرا تم سے کوئی تعلق نہیں ہے، میں وہ کچھ دیکھ رہا ہوں جو تم نہیں دیکھ سکتے ،مجھے اللّٰہ کا خوف ہے، اللّٰہ سخت سزا دینے والا ہے۔
8,49,جب منافق کہہ رہے تھے اور وہ لوگ جن کے دلوں میں روگ تھا (یعنی آپ کے دشمن) وہ بھی کہہ رہے تھے کہ ان لوگوں کو تو ان کے دین نے بس دھوکے میں مبتلا کر رکھا ہے ،حالانکہ جو کوئی اللّٰہ پر بھروسہ کرے (اُسے اور کیا چاہیے)، پس اللّٰہ بہت زبردست، حکمت والا ہے ۔
8,50,کاش آپ اس کیفیت کو دیکھتے جب فرشتے کافروں کی روحیں قبض کر رہے تھے وہ ان کے چہروں او رکولہوں پر گرز مار مار کر کہہ رہے تھے:اب دہکتی ہوئی آگ میں جلنے کا عذاب چکھو۔
8,51,یہ سب کچھ اس کمائی کا بدلہ ہے جو تمہارے ہاتھوں نے (برے اعمال کی صورت میں) آگے بھیج رکھی تھی ،ورنہ اللّٰہ تو اپنے بندوں پر ذرہ بھی ظلم کرنے والا نہیں۔
8,52,یہ سارا معاملہ ان کےساتھ اُسی طرح پیش آیا جس طرح آل فرعون اور اُن سے پہلے لوگوں کے ساتھ پیش آتا رہا ،انہوں نے بھی اللّٰہ کی آیات کو ماننے سے انکار کیا تھا ،اللّٰہ نے پھر ان کے گناہوں کے سبب اُن کو پکڑ لیا، بے شک اللّٰہ بڑی قوت والا ہے، سخت سزا دینے والا بھی ہے۔
