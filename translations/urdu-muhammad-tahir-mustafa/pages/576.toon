quran[30{c,v,t}:
74,18,اس نے سوچا اور بات بنانے کی کوشش کی۔
74,19,اس پر اللّٰہ کی مار، کس طرح کی بات بنائی۔
74,20,پھر اس پر اللّٰہ کی مار، کیسی بات سوچی۔
74,21,پھر (لوگوں کی طرف) دیکھا۔
74,22,پھر ماتھے پہ بل ڈالتےہوئے منہ بنایا ۔
74,23,پھر پیٹھ پھیری اور تکبر کیا ۔
74,24,پھر کہا: یہ تو ایک جادو ہے جو پہلے سے چلا آرہا ہے۔
74,25,پھر بولا: یہ تو محض ایک انسانی کلام ہے۔
74,26,میں عنقریب اسے سقر میں ڈال دوں گا۔
74,27,تمہیں کیا معلوم سقر کیا ہے؟
74,28,(یہ وہ جہنم ہے) جو نہ تو زندہ رہنے دیتی ہے نہ چھوڑتی ہے ۔
74,29,انسانی کھال کو جھلسا دینے والی۔
74,30,اس میں اُنّیس (فرشتے) مقرر ہیں ۔
74,31,ہم نے جہنم کے داروغے یہ فرشتے بنائے ہیں، اور ان کی تعداد کو کافروں کے لیے ایک الجھن بنادیا ہے تاکہ اہل کتاب کو یقین آجائے، اور ایمان والوں کے ایمان میں مزید اضافہ ہو، اور اہل کتاب اور مومنین شک میں مبتلا نہ ہوں، اور جن کے دلوں میں نافرمانی کا روگ ہے اور وہ کافر یہ کہیں کہ بھلا اس بیان سے اللّٰہ کی کیا مراد ہے، اس طرح اللّٰہ جسے چاہتا ہے گمراہ کر دیتا ہے اور جسے چاہتا ہے ہدایت سے سرفراز کر دیتا ہے، اور آپ کے رب کے لشکروں کو خود اس کے سوا کوئی نہیں جانتا، اور اس (سقر) جہنم کا ذکر تو محض اس لیے ہے کہ انسانوں کو نصیحت ہو۔
74,32,ہرگز نہیں، قسم ہے چاند کی۔
74,33,اور رات کی کہ جب وہ اپنے اختتام کو پہنچے ۔
74,34,اور صبح کی کہ جب وہ روشن ہو جائے۔
74,35,یقیناً جہنم بھی ایک بڑی آفت ہے۔
74,36,کہ انسان کو ڈرا کے رکھ دے۔
74,37,اب تم میں سے جو چاہے آگے بڑھے اور جو چاہے پیچھے ہٹے ۔
74,38,ہر ذی روح اپنے اعمال کے بدلے رہن (گروی) ہے۔
74,39,سوائے دائیں ہاتھ والے۔
74,40,کہ وہ جنت میں سوال کریں گے۔
74,41,گناہ گاروں سے۔
74,42,تمہیں سقر(جہنم) میں کس چیز نے ڈالا؟
74,43,وہ جواب دیں گے: ہم نماز نہیں پڑھتے تھے۔
74,44,اور ہم مسکینوں کو کھانا نہیں کھلاتے تھے۔
74,45,اور (حق کے خلاف بحث کرنےو الوں کےساتھ) ہم بھی ان کے ساتھ بحث کرتے تھے
74,46,اور ہم روزِ جزا کو جھٹلاتے تھے۔
74,47,یہاں تک کہ ہمیں اس یقینی چیز (موت) سے واسطہ پیش آگیا۔
