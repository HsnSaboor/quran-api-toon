quran[56]{c,v,t}:
  74,1,"اے کپڑے میں لپٹنے والے"
  74,2,"اُٹھ اور لوگوں کو ڈرا"
  74,3,"اور اپنے رب کی بڑائی بیان کر"
  74,4,"اور اپنے کپڑے کو پاک رکھ"
  74,5,"اور گندگی کو چھوڑدے"
  74,6,"اور ایسا نہ کرو کہ احسان کرو اور بہت بدلہ چاہو"
  74,7,"اور اپنے رب کے لیے صبر کرو"
  74,8,"پھر جب صور پھونکا جائے گا"
  74,9,"تو وہ بڑا سخت دن ہوگا"
  74,10,"منکروں پر آسان نہ ہوگا"
  74,11,"چھوڑدو مجھ کو اور اس شخص کو جس کو میں نے پیدا کیا اکیلا"
  74,12,"اور اس کو بہت سامال دیا"
  74,13,"اور پاس رہنے والے بیٹے"
  74,14,"اور سب طرح کاسامان اس کے لیے مہیا کردیا"
  74,15,"پھر وہ طمع رکھتا ہے کہ میں اس کو اور زیادہ دوں"
  74,16,"ہر گز نہیں ، وہ ہماری آیتوں کا مخالف ہے"
  74,17,"عنقریب میں اس کو ایک سخت چڑھائی چڑھاؤں گا"
  74,18,"اس نے سوچا اور بات بنائی"
  74,19,"پس وہ ہلاک ہوا، اس نے کیسی بات بنائی"
  74,20,"پھر وہ ہلاک ہو، اس نے کیسی بات بنائی"
  74,21,"پھر اس نے دیکھا"
  74,22,"پھر اس نے تیور چڑھائے اور منہ بنایا"
  74,23,"پھر پیٹھ پھیری اور تکبر کیا"
  74,24,"پھر بولا یہ تو محض ایک جادو ہے جو پہلے سے چلا آرہا ہے"
  74,25,"یہ تو بس آدمی کا کلام ہے"
  74,26,"میں اس کو عنقریب دوزخ میں داخل کروں گا"
  74,27,"اور تم کیاجانو کہ کیا ہے دوزخ"
  74,28,"نہ باقی رہنے دے گی اور نہ چھوڑے گی"
  74,29,"کھال جھلس دینے والی"
  74,30,"اس پر  فرشتے ہیں"
  74,31,"اور ہم نے دوزخ کے کارکن صرف فرشتے بنائے ہیں اور ہم نے ان کی جو گنتی رکھی ہے وہ صرف منکروں  کو جانچنے کے لیے، تاکہ یقین حاصل کریں وہ لوگ جن کو کتاب عطا ہوئیاور ایمان والے اپنے ایمان کو بڑھائیں اور اہل کتاب اور مومنین شک نہ کریں ،اور تاکہ جن لوگوں کے دلوں میں مرض ہے اور منکر لوگ کہیں کہ اس سے اللہ کی کیا مراد ہےاس طرح اللہ گمراہ کرتا ہے جس کو چاہتا ہے اور ہدایت دیتا ہے جس کو چاہتا ہے، اور تیرے رب کے لشکر کو صرف وہی جانتا ہے، اور یہ تو صرف سمجھانا ہے لوگوں کے واسطے"
  74,32,"ہرگز نہیں ، قسم ہے چاند کی"
  74,33,"اور رات کی جب کہ وہ جانے لگے"
  74,34,"اور صبح کی جب وہ روشن ہوجائے"
  74,35,"یقیناًدوزخ بڑی چیزوں میں سے ہے"
  74,36,"انسان کے لیے ڈراوا"
  74,37,"ان کے لیے جو تم میں سے آگے کی طرف بڑھے یا پیچھے کی طرف ہٹے"
  74,38,"وہ شخص اپنے اعمال کے بدلے میں رہن ہے"
  74,39,"دائیں والوں کے سوا"
  74,40,"وہ باغوں میں ہوں گے، پوچھتے ہوں گے"
  74,41,"مجرموں سے"
  74,42,"تم کو کیا چیز دوزخ میں لے گئی"
  74,43,"وہ کہیں گے،ہم نماز پڑھنے والوں میں سے نہ تھے"
  74,44,"اور ہم غریبوں کو کھانا نہیں کھلاتے تھے"
  74,45,"اور ہم بحث کرنے والوں کے ساتھ بحث کرتے تھے"
  74,46,"اور ہم انصاف کے دن کو جھٹلاتے تھے"
  74,47,"یہاں تک کہ وہ یقینی بات ہم پر آگئی"
  74,48,"تو ان کو شفاعت کرنے والوں کی شفاعت کچھ فائدہ نہ دے گی"
  74,49,"پھر ان کو کیا ہوگیا ہے کہ وہ نصیحت سے روگردانی کرتے ہیں"
  74,50,"گویا کہ وہ وحشی گدھے ہیں"
  74,51,"جوشیر سے بھاگے جارہے ہیں"
  74,52,"بلکہ ان میں سے ہر شخص یہ چاہتا ہے کہ اس کو کھلے ہوئے نوشتے دئے جائیں"
  74,53,"ہرگز نہیں ،بلکہ یہ لوگ آخرت سے نہیں ڈرتے"
  74,54,"ہرگز نہیں یہ تو ایک نصیحت ہے"
  74,55,"پس جس کا جی چاہے ،اس سے نصیحت حاصل کرے"
  74,56,"اور وہ اس سے نصیحت حاصل نہیں کریں گے مگر یہ کہ اللہ چاہے وہی ہے جس سے ڈرنا چاہيے اور وہی ہے بخشنے کے لائق"
