quran[19]{c,v,t}:
  96,1,"پڑھ اپنے رب کے نام سے جس نے پیدا کیا"
  96,2,"پیدا کیا انسان کو علق سے"
  96,3,"پڑھ اور تیرا رب بڑا کریم ہے"
  96,4,"جس نے علم سکھایا قلم سے"
  96,5,"انسان کو وہ کچھ سکھایا جووہ جانتا نہ تھا"
  96,6,"ہرگز نہیں ،انسان سرکشی کرتا ہے"
  96,7,"اس بنا پر کہ وہ اپنے کو بے نیاز دیکھتا ہے"
  96,8,"بے شک تیرے رب ہی کی طرف لوٹنا ہے"
  96,9,"کیا تم نے دیکھا اس شخص کو جو منع کرتا ہے"
  96,10,"ایک بندہ کو جب وہ نماز پڑھتا ہو"
  96,11,"تمھارا کیا خیال ہے، اگر وہ ہدایت پر ہو"
  96,12,"یا ڈر کی بات سکھاتاہو"
  96,13,"تمھارا کیا خیال ہے،اگر اس نے جھٹلایا اور روگردانی کی"
  96,14,"کیا اس نے نہیں جانا کہ اللہ دیکھ رہا ہے"
  96,15,"ہرگز نہیں ، اگر وہ باز نہ آیا تو ہم پیشانی کے بال پکڑکر اس کوکھینچیں گے"
  96,16,"اس پیشانی کو جو جھوٹی، گناہ گار ہے"
  96,17,"اب وہ بلالے اپنے حامیوں کو"
  96,18,"ہم بھی دوزخ کے فرشتوں کو بلائیں گے"
  96,19,"ہرگز نہیں ، اس کی بات نہ مان اور سجدہ کر اور قریب ہوجا"
