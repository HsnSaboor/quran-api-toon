quran[15]{c,v,t}:
  112,1,Maaku ko Kanko woni Alla gooto
  112,2,Alla paandatee…óo
  112,3,O jibinaani O jinaaka
  112,4,O alah pasa hay gooto
  113,1,Maaku mb…óa moolo e jom subaka
  113,2,E bone ko o tagi
  113,3,E bone jemma ni…ì…ìa kunu
  113,4,E bone wuttoo…ìe e pi…ìlee. @Corrected
  113,5,E bone haaside si o haasidiima
  114,1,Maaku mbe…óa moolo e jom yim…ìe
  114,2,Laam…óo yim…ìe
  114,3,Dewetee…óo yim…ìe
  114,4,E bone seytaaneeli cikkinooji
  114,5,Oon cikkinoowo e …ìer…óe yim…ìe…ì…ój
  114,6,Ummaade e jinneji e yim…ìe
