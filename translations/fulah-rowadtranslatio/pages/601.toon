quran[17]{c,v,t}:
  103,1,E waqtu asri
  103,2,Pellet neЙ—Й—o woni ko e perte
  103,3,"Si wonah Й“een gomЙ—imЙ“e Й“e golli golle moЖҙЖҙ Й—e, hino woodani Й“e njoЙ“di ndi taЖҙondirtaa"
  104,1,Woyli woodanii Гұo*oowo sanne e juwoowo sanne
  104,2,Oon denndinЙ—o jawdi o limi ndi
  104,3,Hombo sikka jawdi makko ndi saasnat mbo
  104,4,Alah maЙ“e mberle e yiite morГұatnge
  104,5,Ko honЙ—um anndin maa ko woni yiite heltoowe
  104,6,Ko yiite Alla huЙ“Й“atnge
  104,7,Ngeen woni yulatnge keeГұe
  104,8,Ngeen de ko nge sokaange e dow maЙ“Й“e
  104,9,E nge doosЙ—e pooЙ—tiiЙ—e
  105,1,Mbela a yi*aani na joom ma waЙ—i jom Гұiiwa
  105,2,Mbela O waЙ—aani peeje ko e majjere
  105,3,O neli e mum en ndiwri abaa biila
  105,4,Hondi werlooЙ“e kaaЖҙe loope joorЙ—e
  105,5,O waЙ—i Й“e hono Гұaayka Гұaamaaka
