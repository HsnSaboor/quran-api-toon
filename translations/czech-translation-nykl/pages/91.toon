quran[15]{c,v,t}:
  91,1,"Při SLUNCI a polední záři jeho,"
  91,2,"a při měsíci, když je následuje;"
  91,3,"a při dnu, když je odhaluje;"
  91,4,"a při noci, když je zahaluje;"
  91,5,"při nebi a tom, jenž zbudoval je;"
  91,6,"a při zemi a tom, jenž rozprostřel ji"
  91,7,"při duši a tom, jenž urovnal ji,"
  91,8,"a hříšnost i bohabojnost vnukl jí:"
  91,9,"dobře povede se tomu, jenž čistou udržuje si ji;"
  91,10,"a ztroskotá ten, jenž kazí si ji."
  91,11,"(Kmen) Tsemúd lhářem nazval (proroka) ve svévoli své;"
  91,12,"když nejbídnější vyvstal z nich;"
  91,13,"tu řekl prorok boží jim: „Velbloudice boží to; nechte ji píti!“"
  91,14,"Však lhářem nazvali jej a žíly podřízli jí; i zahladil je Pán jejich za jejich vinu, rovným způsobem"
  91,15,"aniž se bojí (toho) následků."
