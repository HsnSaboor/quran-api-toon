quran[25]{c,v,t}:
  78,31,"پرهیزګاران به بې له شکه بریمن وي."
  78,32,"باغونه او انګور به وي."
  78,33,"او د یو عمر تنکۍ پیغلې."
  78,34,"او ډک جامونه."
  78,35,"نه به پکې بابیزه او چټیات اوري او نه درواغ."
  78,36,"دا بدله د هغوی د کړنو په رڼا کې ستا د رب لورینه ده."
  78,37,"داسمانونو او ځمکې او د دوی په مینځ کې د ټولو څيزونو پالونکی او مهربان دی.چې د هغه په وړاندې هیڅوک د خبرو واک نه لري."
  78,38,"په کومه ورځ چې:جبرائیل او ملایکې کتار،کتار ودریږي پرته له هغو چې مهربان ذات اجازه ورکړي او په دنیا کې یې د توحید روغه کلمه ویلي وي بل به هیڅوک څه نشي ویلی."
  78,39,"دا ورځ رښتیني ده د چا چې خوښه وي نو د خپل رب په لور ورتلونکې لار دې خپله کړي."
  78,40,"مونږ تاسې له نژدې راتلونکې عذاب څخه ډاروو.له هغې ورځې چې هر سړی به د خپلو لاسونو وړاندې لیږلې کړنې وویني او کافر به وایې کاشکې زه خاورې وای[۱]"
  79,1,"قسم په هغو ملایکو چې روحونه په سختۍ وباسي."
  79,2,"او په هغو چې په اسانۍ یې وباسي."
  79,3,"او په خورا چټکتیا غوټې وهي."
  79,4,"او بوه له بلې څخه وړاندې ځي."
  79,5,"نو د کارونو سرپرستي په لاس کې اخلي."
  79,6,"او هغه ورځ چې ولړزیږي لزړیدونکي."
  79,7,"ورپسې وي بله پیښه."
  79,8,"په دي ورځ به زړونه په ډاروي."
  79,9,"سترګې به ښکته او پریوتې وي."
  79,10,"کافران وايي:ایا مونږ بیرته لومړني حال ته ګرځول کیږو؟"
  79,11,"سره له دې چې مونږ به وراسته هډوکي وو؟"
  79,12,"دوی وایې:که کار همداسې وو نو دا خورا زیانمن کار دی."
  79,13,"الله پاک وایې:بیرته راژوندي کول یوازې یو پوکی دی."
  79,14,"نو ټول به په میدان کې ژوندي ولاړ وي."
  79,15,"ایا د موسې(علیه السلام)له کیسې خبریې؟"