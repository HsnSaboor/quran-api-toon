quran[52]{c,v,t}:
  69,1,"پیښیدونکې."
  69,2,"څه ده هغه پیښیدونکې."
  69,3,"او ته څه پوه کړې چي پيښیدونکې پيښه څه ده."
  69,4,"ثمودیانو او عادیانو زړه ټکوونکې ورځ درواغ وګڼله."
  69,5,"نو ځکه ثمودیان په یوه تندري کړیکه هلاک کړای شول."
  69,6,"او عادیان په غږ لرونکي تیزه سیلۍ هلاک شول."
  69,7,"اووه شپې او اته ورځې يي په پرله پسې توګه په هغوی راالوزولې وه(که ته هلته وای)نو تا به لیدلي وو چې ټول خلک د خرما د ورستو ډډونو په څير مړه پراته وو."
  69,8,"ایا اوس درته د هغوی څه شی پاتې ښکاري؟"
  69,9,"فرعون،او له هغه نه وړاندې خلکو او د چپه کړی شوو کلیو خلکو هم ورانی کړی و."
  69,10,"ټولو د خپل رب له استازي نه سر غړولی ؤ نو ځکه يي په خورا سختۍ سره ونیول."
  69,11,"او اوبه چې توفاني شوې نو مونږ تاسې(د نوح)په کښتۍ کې سپاره کړئ."
  69,12,"تر څو يي ستاسې لپاره پند وګرځوو او یاد لرونکي غوږونه يي په یاد ولري."
  69,13,"نو کله چې په شپيلۍ کې یو پو کی وشي."
  69,14,"ځمکه او غرونه(له خپلو خایونو)پورته او په یو ځل میده میده کړای شي."
  69,15,"نو پدې ورځ به لویه پیښه مینځ ته راشي."
  69,16,"اسمان به وچوي او پدې ورځ به خورا کمزوری وي."
  69,17,"ملایکې به یې په څنډوکې وي.پدې ورځ به ستا د رب عرش اتو ملایکو پورته کړی وي."
  69,18,"تاسو به اللله ته وړاندې کړای شئ او هیڅ به مو پټ نه وي."
  69,19,"نو هر چاته چې خپل برخه لیک په ښي لاس ور کړای شو نو(په خوښۍ به)وایي:راشئ او زما برخه لیک ولولئ."
  69,20,"زما باور ؤ چې زه به له حساب سره مخ کیږم."
  69,21,"نو هغه به په خوښ ژوند کې وي."
  69,22,"په عالیشان جنت کې."
  69,23,"چې میوې به يي خورا نژدې وي."
  69,24,"او اعلان به وشي چې:ښه په مزه خوراک او څښاک کوئ ځکه چې تاسو په تیرو ورځو کې دلته ښه کارونه رالیږلي دي."
  69,25,"او چاته چې برخه لیک په کیڼ لاس ورکړای شي نو وايي به:کاشکې چې ماته برخه لیک نه وای را کړای شوی."
  69,26,"او نه وای پوه شوي چې زما حساب څه دی؟"
  69,27,"دریغه چې زما مرګ له مینځه وړونکی وای."
  69,28,"مال مې هیڅ په کار رانغی."
  69,29,"او واک مې له مینځه ولاړ."
  69,30,"وبه ویل شي ویي نیسئ او ويي تړئ."
  69,31,"بیا يي په اور کې ورننه باسئ."
  69,32,"په(اویا)ګزیزه ځنځیر يي تړلی جهنم ته ورننه باسئ.ځکه چې په الله(جل جلاله)ئې ایمان نه راووړ."
  69,33,"ځکه چې په الله جل جلاله يي ایمان نه راووړ."
  69,34,"او نه يې څوک بې وسو ته د خوراک په ورکولو هڅول."
  69,35,"نو ځکه يي نن دلته هیڅ دوست نشته."
  69,36,"او نه پرته له زووبل خوراک."
  69,37,"چې پرته له وران کارو به یي بل څوک نه خوري."
  69,38,"نونه:قسم په هغو شیانو چې تاسې يي وینئ."
  69,39,"او په هغو شیانو چې تاسې يي نه وینئ."
  69,40,"چې بیشکه دا د یو عزتمن استازي وینا ده."
  69,41,"د کوم شاعر وینا نده ستاسې ډیرکم(خلک) ایمان راوړی."
  69,42,"او نه د کوم کاهن وینا ده تاسې ډیر لږ غور کوئ."
  69,43,"د رب العالمین له لورې نازله شوې ده."
  69,44,"که پیغمبر زمونږ کومه خبره تړلې وای."
  69,45,"نو مونږ به په ښي(لاس)نیولای وای."
  69,46,"بیا به مو د هغه شارګ پرې کړای وای."
  69,47,"ستاسو هیڅوک به له هغه نه منع کوونکی نه و."
  69,48,"او بیشکه چې قران د پرهیزګارانو لپاره پند دی."
  69,49,"او مونږ پوهیږو چې ستاسې ځیني درواغ ګڼونکي دي."
  69,50,"خو دا د کافرانو لپاره پښیمانتیا ده."
  69,51,"قران پرته له شک څخه یقیني حق دی."
  69,52,"نو د خپل لوی رب نوم په پاکۍ ستایه."
