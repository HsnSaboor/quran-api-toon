quran[96]{c,v,t}:
  56,1,"کله چې پیښیدونکې،پیښه شي."
  56,2,"هیڅوک به یي درواغ نه ګڼي."
  56,3,"هغه به ښکته کوونکې[۱۵]او لوړوونکې پیښه وي."
  56,4,"کله چې ځمکه په بشپړ ډول ولړزول شي."
  56,5,"او غرونه ټوټه،ټوټه او میده کړای شي."
  56,6,"ته به وايې چې الوتونکی ګرد او وړانګې دي."
  56,7,"نو تاسې به درې ډلي واست."
  56,8,"نو د ښي لاس خاوندان.[۱۶]او څومره غوره دي د ښي لاس خاوندان."
  56,9,"او د کیڼ لاس خاوندان.څومره به دي د کیڼ لاس خاوندان."
  56,10,"او لومړني[۱۷]لومړني دي."
  56,11,"همدوی الله ته نژدې کړي شوي دي."
  56,12,"له نعمتونو په ډکو جنتونو کې به اوسیږي."
  56,13,"لومړني[۱۸]به زیات وي."
  56,14,"او وروستي به لږ."
  56,15,"د سرو او سپینو زرو په تارونو او بدل شوو تختونو."
  56,16,"یو بله ته مخامخ به یې تکیه کړې وي."
  56,17,"په یو عمر او یو رنګ تل پاتې هلکان به پرې ګرځي راګرځي."
  56,18,"د بهیدونکو صافو شرابو له ډکو ګیلاسونو،جکونو او کاسو سره."
  56,19,"ته به یي سردرد ترې پيدا کیږي او نه نیشه او بې خودي."
  56,20,"او د هغوی د خوښې ډول ډول میوې به ور وړاندې کیږي."
  56,21,"او د زړونو د غوښتنې په رڼا کې یې د مارغانو غوښې."
  56,22,"او هم د ښکلو او غټو سترګو حورې."
  56,23,"لکه پوښل شوې ملغلرې."
  56,24,"دا د هغو کړنو بدل دی چې په دنیا کې یې کړي دي."
  56,25,"هلته به نه چټي خبرې اوري او نه د ګناه خبرې."
  56,26,"مګر یوازې یو پر بل به[۱۹]سلام اوري."
  56,27,"او د ښي لاس خاوندان.څومره غوره دي د ښي لاس خاوندان."
  56,28,"په بي اغزیو بیرو."
  56,29,"او یو پر بل سپرو کیلو."
  56,30,"او ترې لرې اوږدوشو سیورو."
  56,31,"او هر وخت به لوښو او ویالو کې اچول شوو اوبو."
  56,32,"او په پریمانه میوو."
  56,33,"چې نه پاي ته رسي او نه بندیږي."
  56,34,"او په لوړو او هسکو فرشونو کې به وي."
  56,35,"بې له شکه چې:مونږ دغه حورې او جنتي ښځې نوي په نوي سنګار پیدا کړي."
  56,36,"پیغلې مو ګرځولي."
  56,37,"له میړونو سره مینه او محبت کوونکي هم عمره دي."
  56,38,"دا هرڅه د ښي لاسو خلکو لپاره دي."
  56,39,"دا خلک په لومړیو کې یوه لویه ډله."
  56,40,"او په وروستیو کې هم لویه ډله ده."
  56,41,"او د کیڼ لاس خاوندان.څومره بد دي د کیڼ لاس خاوندان."
  56,42,"په سوزوونکي اور او خوټیدونکو ګرمو اوبو کې به وي."
  56,43,"د تور لوګي تر سیورې لاندې به وي."
  56,44,"نه به سوړ وي او نه دمه ورکوونکی."
  56,45,"خکه چې په دنیا کې په ښو نعمتونو کې وو."
  56,46,"او په لویه ګناه[۲۰]یې خورا ټینګار کاو."
  56,47,"او ویل به یې چې:مونږ مړه شو او بیا خاورې او هډوکي نو بیا به هم بیرته پاڅول کیږو؟"
  56,48,"زمونږ پخواني پلرونه او نیکونه به هم راپاڅول کیږي؟"
  56,49,"ای محمده ووایه چي لومړي او وروستي."
  56,50,"ټول به خامخا د معلومې ورځې غونډې ته راټولولای شي."
  56,51,"بیا به تاسې ای لار ورکو درواغجنو!"
  56,52,"خامخا به د زقوم له ونې څخه خوراک کوئ."
  56,53,"او خیټې به مو ترې ډکوئ."
  56,54,"او د پاسه به پرې ګرمې خوټیدونکې اوبه څښئ."
  56,55,"په شان د څښلو د جل وهلي اوښ[۲۱]"
  56,56,"دا يې د حساب د ورځې میلمستیا ده."
  56,57,"یوازې مونږ تاسې پیدا کړي یې نو بیا ولې زمونږ خبره نه منئ."
  56,58,"ستاسې دغورزولې نطفې په هکله مې پوه کړئ؟"
  56,59,"ایا تاسې ترې کوچنی پیدا کوئ او که پیدا کوونکي مونږ یو؟"
  56,60,"مونږ ستاسې په مینځ کې مرګ اندازه کړی او مونږ بې وسه کیدای نشو."
  56,61,"چې ستاسې پر ځای نور خلک راولو او تاسې په هغه شکل پورته کړو چې تاسې پرې نه پوهیږئ."
  56,62,"تاسې ته خو لومړنی پیدایښت ښه څرګند شوی دی.نو ولې پند نه اخلئ؟"
  56,63,"په دې مې پوه کړئ چې کوم څه تاسې کرئ."
  56,64,"ایا تاسې یې رازرغونوئ؟که مونږ یې زرغونوونکي یو؟"
  56,65,"که مونږ وغواړو نو ستاسې کښت به وچ یې ګټې واښه وګرځوو.بیا به نو تاسې هک پک پاتې یې."
  56,66,"او وايي به چې مونږ له تاوان سره مخ شو."
  56,67,"بلکې له هر څه څخه بې برخې."
  56,68,"او د هغو اوبو په هکله هم معلومات راکړئ چې تاسې یې څښئ."
  56,69,"ایا تاسې له وریځو نه راښکته کړی دي؟که راښکته کوونکي مونږ یو؟"
  56,70,"که مونږ وغواړو نو تروې مالګینې به یې وګرځوو.نو تاسې ولې شکر نه باسئ؟"
  56,71,"او د هغه اور په هکله هم معلومات راکړئ چې تاسې یې بلوئ."
  56,72,"ایا تاسې یې ونه پيدا کړې ده؟که پیدا کوونکي یې مونږ یو؟"
  56,73,"مونږ اور ستاسې لپاره یو پند او د ټولو اړو خلکو لپاره ګټه او څوری ګرځولی دی."
  56,74,"نو د خپل رب چې له هر څه لوی دی د پاک نامه ستاینه وکړه."
  56,75,"نو نه .... زما دې د ستورو پر ځایونو قسم وي."
  56,76,"که تاسې پوهیږئ،نو دا خورا لوی قسم دی."
  56,77,"چې بې شکه پر تا نازل د عزت والا قران دی."
  56,78,"هغه د لوح محفوظ په پوښل شوي کتاب کې ښکل دی."
  56,79,"پرته له پاکو[۲۲]کړو شوو بل څوک یې نشي مسه کولی."
  56,80,"د ټول عالم د رب له لورې نازل شوی دی."
  56,81,"نو ایا له دغه کلام سره تاسې سپکوونکې معامله کوئ؟"
  56,82,"او تاسې ته د در کړې شوې روزۍ شکریه به مو همدا وي چې:تاسې قرآن درواغ ګڼئ."
  56,83,"نو ولې نه شئ کولای چې: د یو چاه ساه تر ستوني ورسي."
  56,84,"او تاسې په رډو،رډو ورته ګورئ."
  56,85,"او مونږ ورته له تاسې نه خورا ډیر نژدی یو خو تاسې یې نه وینئ."
  56,86,"نو ولې نشئ کولای که رښتیا هم تاسې ته کومه جزا نه در کول کیږي."
  56,87,"چې همدا ساه بیرته ور وګرځوئ،که تاسې رښتیني یاست؟"
  56,88,"نو که مړ شوی انسان خدای ته له نژدې خلکو څخه وو."
  56,89,"نو هوسايي،ښکلی ژوند،او د نعمتونو ډک جنت یې په برخه دی."
  56,90,"او که د ښي لاس له خاوندانو څخه ؤ."
  56,91,"نو د ښي لاس له خاوندانو څخه بالکل بې غم اوسه."
  56,92,"او که له درواغجنو لار ورکو څخه وو."
  56,93,"نو د ګرمو خوټیدونکو اوبو میلمستیا ورته تیاره ده."
  56,94,"او د دوزخ اور ته یې ننویستل دي."
  56,95,"او بې له شکه همدا هر څه بیخي حق دي."
  56,96,"نو د خپل رب چې له هر څه نه لوی دی د پاک نامه ستاینه وکړه."
