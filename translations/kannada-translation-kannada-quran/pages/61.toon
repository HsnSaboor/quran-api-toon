quran[14]{c,v,t}:
  61,1,"ಆಕಾಶ-ಭೂಮಿಗಳಲ್ಲಿರುವ ಪ್ರತಿಯೊಂದು ವಸ್ತುವೂ ಅಲ್ಲಾಹನ ಪರಿಶುದ್ಧತೆಯನ್ನು ಕೊಂಡಾ ಡಿವೆ. ಅವನು ಅಜೇಯನೂ ಯುಕ್ತಿವಂತನೂ ಆಗಿರುವನು."
  61,2,"ಓ ಸತ್ಯವಿಶ್ವಾಸಿಗಳೇ, ನೀವು ಮಾಡದ್ದನ್ನು ಆಡುತ್ತೀರೇಕೆ ?"
  61,3,"ನೀವು ಮಾಡದ್ದನ್ನು ಆಡುವುದು ಅಲ್ಲಾಹನ ಬಳಿ ಬಹಳ ಕ್ರೋಧದ ವಿಚಾರವಾಗಿದೆ.",footnotes:207935:1
  61,4,"(ಕಲ್ಲುಗಳನ್ನು) ಪರಸ್ಪರ ಬಂಧಿಸಿ ನಿರ್ಮಿಸಲ್ಪಟ್ಟ ಒಂದು ಕಟ್ಟಡದಂತೆ ಪಂಕ್ತಿಬದ್ಧರಾಗಿ ತನ್ನ ಮಾರ್ಗದಲ್ಲಿ ಹೋರಾಡುವವರನ್ನು ಅಲ್ಲಾಹನು ಖಂಡಿತ ಮೆಚ್ಚುತ್ತಾನೆ.",footnotes:207936:1
  61,5,"ಮೂಸಾ, ತಮ್ಮ ಜನಾಂಗದೊಡನೆ ಹೇಳಿದ ಸಂದರ್ಭ (ಸ್ಮರಿಸಿರಿ) “ನನ್ನ ಜನಾಂಗದವರೇ, ನಾನು ನಿಮ್ಮ ಕಡೆಗೆ ಕಳುಹಿಸಲ್ಪಟ್ಟ ಅಲ್ಲಾಹನ ದೂತನೆಂದು ನಿಮಗೆ ಚೆನ್ನಾಗಿ ತಿಳಿದಿದ್ದರೂ ನೀವು ನನ್ನನ್ನೇಕೆ ಹಿಂಸಿಸುತ್ತೀರಿ?” ತರುವಾಯ ಅವರು ಸತ್ಯದಿಂದ ತಪ್ಪಿ ಹೋದಾಗ ಅಲ್ಲಾಹನು ಅವರ ಹೃದಯಗಳನ್ನು ತಪ್ಪಿಸಿ ಬಿಟ್ಟನು. ಅಲ್ಲಾಹನು ಧಿಕ್ಕಾರಿಗಳಾದ ಜನತೆಗೆ ಮಾರ್ಗದರ್ಶನ ನೀಡಲಾರನು."
  61,6,"ಮರ್ಯಮರ ಪುತ್ರ ಈಸಾ ಹೇಳಿದ ಸಂದರ್ಭ (ಸ್ಮರಿಸಿರಿ) “ಇಸ್ರಾಈಲ್ ಸಂತತಿಗಳೇ, ನಾನು, ನನಗಿಂತ ಮೊದಲು ಬಂದಿರುವ ತೌರಾತನ್ನು ದೃಢೀಕರಿಸುವವನಾಗಿಯೂ ನನ್ನ ಬಳಿಕ ಬರಲಿರುವ ಅಹ್ಮದ್ ಎಂಬ ಹೆಸರಿನ ಓರ್ವ ದೂತರ ಕುರಿತು ಸುವಾರ್ತೆ ನೀಡುವವನಾಗಿಯೂ ನಿಮ್ಮ ಕಡೆಗೆ ಅಲ್ಲಾಹನಿಂದ ಕಳುಹಿಸಲಾದ ದೂತನಾಗಿರುತ್ತೇನೆ”. ಅಂತೆಯೇ, ಅವರು ಸುಸ್ಪಷ್ಟ ನಿದರ್ಶನದೊಂದಿಗೆ ಅವರ ಬಳಿಗೆ ಹೋದಾಗ ‘ಇದು ಸ್ಪಷ್ಟ ಜಾಲ ವಿದ್ಯೆ’ ಎಂದು ಅವರು ಹೇಳಿ ಬಿಟ್ಟರು.",footnotes:207937:1|207938:2|207939:3
  61,7,"ಒಬ್ಬನನ್ನು ಇಸ್ಲಾಮಿನೆಡೆಗೆ ಕರೆಯಲಾದಾಗ ಅವನು ಅಲ್ಲಾಹನ ಮೇಲೆ ಸುಳ್ಳಾರೋಪ ಹೊರಿಸಿದರೆ ಅವನಿಗಿಂತ ದೊಡ್ಡ ಅಕ್ರಮಿ ಯಾರಿದ್ದಾನೆ? ಅಕ್ರಮಿಗಳಾದ ಜನತೆಗೆ ಅಲ್ಲಾಹನು ಮಾರ್ಗದರ್ಶನ ನೀಡಲಾರನು."
  61,8,"ಅವರು ಅಲ್ಲಾಹನ ಪ್ರಕಾಶವನ್ನು ತಮ್ಮ ಬಾಯಿಂದ ಊದಿ ನಂದಿಸಲಿಚ್ಚಿಸುತ್ತಾರೆ. ಸತ್ಯನಿಷೇಧಿಗಳಿಗೆ ಅಪ್ರಿಯವಾಗಿದ್ದರೂ ಅಲ್ಲಾಹನು ತನ್ನ ಪ್ರಕಾಶವನ್ನು ಪೂರ್ತಿಮಾಡುವನು.",footnotes:207940:1
  61,9,"ಸನ್ಮಾರ್ಗ ಮತ್ತು ಸತ್ಯಧರ್ಮದೊಂದಿಗೆ ಉಳಿದ ಧರ್ಮಗಳಿಗಿಂತ ಅದನ್ನು ಮೇಲಾಗಿ ಬೆಳಕಿಗೆತರುವ ಸಲುವಾಗಿ ತನ್ನ ದೂತನನ್ನು ಕಳುಹಿಸಿರುವವನು ಅವನೇ. ಬಹುದೇವ ವಿಶ್ವಾಸಿಗಳಿಗೆ ಇದು ಎಷ್ಟೇ ಅಪ್ರಿಯವಾದರೂ ಸರಿಯೇ."
  61,10,"ಸತ್ಯವಿಶ್ವಾಸಿಗಳೇ, ನಿಮ್ಮನ್ನು ವೇದನಾಜನಕ ಶಿಕ್ಷೆಯಿಂದ ರಕ್ಷಿಸುವಂತಹ ಒಂದು ವ್ಯಾಪಾರದ ಬಗ್ಗೆ ನಿಮಗೆ ತಿಳಿಸಿಕೊಡಲೇ?",footnotes:207941:1
  61,11,"(ಅದೇನೆಂದರೆ) ಅಲ್ಲಾಹು ಮತ್ತು ಅವನ ಸಂದೇಶ ವಾಹಕರಲ್ಲಿ ವಿಶ್ವಾಸವಿರಿಸುವುದು, ನಿಮ್ಮ ಸಂಪತ್ತುಗಳಿಂದಲೂ ಶರೀರಗಳಿಂದಲೂ ಅಲ್ಲಾಹನ ಮಾರ್ಗದಲ್ಲಿ ಹೋರಾಡುವುದು. ನಿಮ್ಮ ಪಾಲಿಗೆ ಅದು ಅತಿ ಉತ್ತಮವಾಗಿದೆ. ನೀವು ತಿಳುವಳಿಕೆಯುಳ್ಳವರಾಗಿದ್ದರೆ."
  61,12,"(ಹಾಗಾದರೆ) ಅಲ್ಲಾಹನು ನಿಮ್ಮ ಪಾಪಗಳನ್ನು ಕ್ಷಮಿಸುವನು ಮತ್ತು ತಳಭಾಗದಲ್ಲಿ ಕಾಲುವೆಗಳು ಹರಿಯುತ್ತಿರುವ ಸ್ವರ್ಗೋದ್ಯಾನಗಳಲ್ಲಿ ಮತ್ತು ಸ್ಥಿರವಾಸಕ್ಕಿರುವ ಸ್ವರ್ಗಧಾಮಗಳಲ್ಲಿಯ ವಿಶಿಷ್ಟ ವಸತಿಗಳಲ್ಲಿ ಅವನು ನಿಮ್ಮನ್ನು ಪ್ರವೇಶಗೊಳಿಸುವನು. ಅದುವೇ ದಿಗ್ವಿಜಯ."
  61,13,"ನೀವು ಇಷ್ಟಪಡುವ ಇನ್ನೊಂದು ವಸ್ತುವನ್ನೂ (ನಿಮಗೆ ಕೊಡುವನು.) ಅಂದರೆ (ಅದು) ಅಲ್ಲಾ ಹನ ಕಡೆಯಿಂದ ಸಹಾಯ ಮತ್ತು ಆಸನ್ನವಾದ ವಿಜಯ. (ನಬಿಯರೇ,) ಸತ್ಯವಿಶ್ವಾಸಿಗಳಿಗೆ (ಇದರ) ಸುವಾರ್ತೆ ನೀಡಿರಿ."
  61,14,"ಸತ್ಯವಿಶ್ವಾಸಿಗಳೇ, ನೀವು ಅಲ್ಲಾಹನ ಸಹಾಯಕರಾಗಿರಿ, ಮರ್ಯಮರ ಪುತ್ರ ಈಸಾ ಹವಾರಿಗಳೊಡನೆ (ಶಿಷ್ಯರೊಂದಿಗೆ) ‘ಅಲ್ಲಾಹನ ಕಡೆಗೆ ಕರೆ ನೀಡುವಲ್ಲಿ ನನ್ನ ಸಹಾಯಕರು ಯಾರಿದ್ದಾರೆ?’ ಎಂದು ಹೇಳಿದ್ದಂತೆ. ಹವಾರಿಗಳು ಹೇಳಿದರು; ನಾವು ಅಲ್ಲಾಹನ ಸಹಾಯಕರು. ಆಗ ಇಸ್ರಾಈಲ ಸಂತತಿಗಳ ಪೈಕಿ ಒಂದು ವಿಭಾಗ ಸತ್ಯವಿಶ್ವಾಸವನ್ನು ಸ್ವೀಕರಿಸಿತು ಮತ್ತು ಇನ್ನೊಂದು ವಿಭಾಗವು ನಿರಾಕರಿಸಿತು. ತರುವಾಯ ನಾವು ಸತ್ಯವಿಶ್ವಾಸಿಗಳಿಗೆ ಅವರ ಶತ್ರುಗಳ ವಿರುದ್ಧ ಬಲ ನೀಡಿದೆವು. ಹಾಗೆ ಅವರು ವಿಜಯಿಗಳಾಗಿ ಬಿಟ್ಟರು.",footnotes:207942:1
