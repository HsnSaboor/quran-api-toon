quran[6]{c,v,t}:
  109,1,"(ಪ್ರವಾದಿಯವರೇ) ಹೇಳಿರಿ, ಓ ಸತ್ಯನಿಷೇಧಿಗಳೇ,",footnotes:208143:1
  109,2,"ನೀವು ಆರಾಧಿಸುತ್ತಿರುವುದನ್ನು ನಾನು ಆರಾಧಿಸುತ್ತಿಲ್ಲ.",footnotes:208144:1
  109,3,"ನಾನು ಆರಾಧಿಸುತ್ತಿರುವುದನ್ನು ನೀವೂ ಆರಾಧಿಸುತ್ತಿಲ್ಲ.",footnotes:208145:1
  109,4,"ನೀವು ಆರಾಧಿಸುತ್ತಿರುವುದನ್ನು ನಾನು ಆರಾಧಿಸಲಾರೆ.",footnotes:208146:1
  109,5,"ನಾನು ಆರಾಧಿಸುತ್ತಿರುವುದನ್ನು ನೀವು (ಮುಂದೆಯೂ) ಆರಾಧಿಸುವವರಲ್ಲ."
  109,6,"ನಿಮ್ಮ ಧರ್ಮ ನಿಮಗೆ. ನನ್ನ ಧರ್ಮ ನನಗೆ.",footnotes:208147:1
