quran[62]{c,v,t}:
  53,1,"قَسم ہے روشن ستارے (محمد صلی اللہ علیہ وآلہ وسلم) کی جب وہ (چشمِ زدن میں شبِ معراج اوپر جا کر) نیچے اترے"
  53,2,"تمہیں (اپنی) صحبت سے نوازنے والے (رسول صلی اللہ علیہ وآلہ وسلم جنہوں نے تمہیں اپنا صحابی بنایا) نہ (کبھی) راہ بھولے اور نہ (کبھی) راہ سے بھٹکے"
  53,3,"اور وہ (اپنی) خواہش سے کلام نہیں کرتے"
  53,4,"اُن کا ارشاد سَراسَر وحی ہوتا ہے جو انہیں کی جاتی ہے"
  53,5,"ان کو بڑی قوّتوں و الے رب نے (براہِ راست) علمِ (کامل) سے نوازا"
  53,6,"جو حسنِ مُطلَق ہے، پھر اُس نے (اپنے) ظہور کا ارادہ فرمایا"
  53,7,"اور وہ (محمد صلی اللہ علیہ وآلہ وسلم شبِ معراج عالمِ مکاں کے) سب سے اونچے کنارے پر تھے (یعنی عالَمِ خلق کی انتہاء پر تھے)"
  53,8,"پھر وہ (ربّ العزّت اپنے حبیب محمد صلی اللہ علیہ وآلہ وسلم سے) قریب ہوا پھر اور زیادہ قریب ہوگیا٭o٭ یہ معنی امام بخاری نے حضرت انس رضی اللہ عنہ سے الجامع الصحیح میں روایت کیا ہے، مزید حضرت عبد اﷲ بن عباس، امام حسن بصری، امام جعفر الصادق، محمد بن کعب القرظی التابعی، ضحّاک رضی اللہ عنہم اور دیگر کئی ائمہِ تفسیر کا قول بھی یہی ہے"
  53,9,"پھر (جلوۂ حق اور حبیبِ مکرّم صلی اللہ علیہ وآلہ وسلم میں صرف) دو کمانوں کی مقدار فاصلہ رہ گیا یا (انتہائے قرب میں) اس سے بھی کم (ہو گیا)"
  53,10,"پس (اُس خاص مقامِ قُرب و وصال پر) اُس (اللہ) نے اپنے عبدِ (محبوب) کی طرف وحی فرمائی جو (بھی) وحی فرمائی"
  53,11,"(اُن کے) دل نے اُس کے خلاف نہیں جانا جو (اُن کی) آنکھوں نے دیکھا"
  53,12,"کیا تم ان سے اِس پر جھگڑتے ہو کہ جو انہوں نے دیکھا"
  53,13,"اور بیشک انہوں نے تو اُس (جلوۂ حق) کو دوسری مرتبہ (پھر) دیکھا (اور تم ایک بار دیکھنے پر ہی جھگڑ رہے ہو)٭o٭ یہ معنی ابن عباس، ابوذر غفاری، عکرمہ التابعی، حسن البصری التابعی، محمد بن کعب القرظی التابعی، ابوالعالیہ الریاحی التابعی، عطا بن ابی رباح التابعی، کعب الاحبار التابعی، امام احمد بن حنبل اور امام ابوالحسن اشعری رضی اللہ عنہم اور دیگر ائمہ کے اَقوال پر ہے"
  53,14,"سِدرۃ المنتہٰی کے قریب"
  53,15,"اسی کے پاس جنت الْمَاْوٰى ہے"
  53,16,"جب نورِ حق کی تجلیّات سِدرَۃ (المنتہٰی) کو (بھی) ڈھانپ رہی تھیں جو کہ (اس پر) سایہ فگن تھیں٭o٭ یہ معنی بھی امام حسن بصری رضی اللہ عنہ و دیگر ائمہ کے اقوال پر ہے"
  53,17,"اُن کی آنکھ نہ کسی اور طرف مائل ہوئی اور نہ حد سے بڑھی (جس کو تکنا تھا اسی پر جمی رہی)"
  53,18,"بیشک انہوں نے (معراج کی شب) اپنے رب کی بڑی نشانیاں دیکھیں"
  53,19,"کیا تم نے لات اور عزٰی (دیویوں) پر غور کیا ہے"
  53,20,"اور اُس تیسری ایک اور (دیوی) منات کو بھی (غور سے دیکھا ہے؟ تم نے انہیں اللہ کی بیٹیاں بنا رکھا ہے؟)"
  53,21,"(اے مشرکو!) کیا تمہارے لئے بیٹے ہیں اور اس (اللہ) کے لئے بیٹیاں ہیں"
  53,22,"(اگر تمہارا تصور درست ہے) تب تو یہ تقسیم بڑی ناانصافی ہے"
  53,23,"مگر (حقیقت یہ ہے کہ) وہ (بت) محض نام ہی نام ہیں جو تم نے اور تمہارے باپ دادا نے رکھ لئے ہیں۔ اللہ نے ان کی نسبت کوئی دلیل نہیں اتاری، وہ لوگ محض وہم و گمان کی اور نفسانی خواہشات کی پیروی کر رہے ہیں حالانکہ اُن کے پاس اُن کے رب کی طرف سے ہدایت آچکی ہے"
  53,24,"کیا انسان کے لئے وہ (سب کچھ) میسّر ہے جس کی وہ تمنا کرتا ہے"
  53,25,"پس آخرت اور دنیا کا مالک تو اللہ ہی ہے"
  53,26,"اور آسمانوں میں کتنے ہی فرشتے ہیں (کہ کفّار و مشرکین اُن کی عبادت کرتے اور ان سے شفاعت کی امید رکھتے ہیں) جِن کی شفاعت کچھ کام نہیں آئے گی مگر اس کے بعد کہ اللہ جسے چاہتا ہے اور پسند فرماتا ہے اُس کے لئے اِذن (جاری) فرما دیتا ہے"
  53,27,"بیشک جو لوگ آخرت پر ایمان نہیں رکھتے وہ فرشتوں کو عورتوں کے نام سے موسوم کر دیتے ہیں"
  53,28,"اور انہیں اِس کا کچھ بھی علم نہیں ہے، وہ صرف گمان کے پیچھے چلتے ہیں، اور بیشک گمان یقین کے مقابلے میں کسی کام نہیں آتا"
  53,29,"سو آپ اپنی توجّہ اس سے ہٹا لیں جو ہماری یاد سے رُوگردانی کرتا ہے اور سوائے دنیوی زندگی کے اور کوئی مقصد نہیں رکھتا"
  53,30,"اُن لوگوں کے علم کی رسائی کی یہی حد ہے، بیشک آپ کا رب اس شخص کو (بھی) خوب جانتا ہے جو اُس کی راہ سے بھٹک گیا ہے اور اس شخص کو (بھی) خوب جانتا ہے جِس نے ہدایت پا لی ہے"
  53,31,"اور اللہ ہی کے لئے ہے جو کچھ آسمانوں اور جو کچھ زمین میں ہے تاکہ جن لوگوں نے برائیاں کیں انہیں اُن کے اعمال کا بدلہ دے اور جن لوگوں نے نیکیاں کیں انہیں اچھا اجر عطا فرمائے"
  53,32,"جو لوگ چھوٹے گناہوں (اور لغزشوں) کے سوا بڑے گناہوں اور بے حیائی کے کاموں سے پرہیز کرتے ہیں، بیشک آپ کا رب بخشش کی بڑی گنجائش رکھنے والا ہے، وہ تمہیں خوب جانتا ہے جب اس نے تمہاری زندگی کی ابتداء اور نشو و نما زمین (یعنی مٹی) سے کی تھی اور جبکہ تم اپنی ماؤں کے پیٹ میں جَنیِن (یعنی حمل) کی صورت میں تھے، پس تم اپنے آپ کو بڑا پاک و صاف مَت جتایا کرو، وہ خوب جانتا ہے کہ (اصل) پرہیزگار کون ہے"
  53,33,"کیا آپ نے اس شخص کو دیکھا جس نے (حق سے) منہ پھیر لیا"
  53,34,"اور اس نے (راہِ حق میں) تھوڑا سا (مال) دیا اور (پھر ہاتھ) روک لیا"
  53,35,"کیا اس کے پاس غیب کا علم ہے کہ وہ دیکھ رہا ہے"
  53,36,"کیا اُسے اُن (باتوں) کی خبر نہیں دی گئی جو موسٰی (علیہ السلام) کے صحیفوں میں (مذکور) تھیں"
  53,37,"اور ابراہیم (علیہ السلام) کے (صحیفوں میں تھیں) جنہوں نے (اللہ کے ہر امر کو) بتمام و کمال پورا کیا"
  53,38,"کہ کوئی بوجھ اٹھانے والا کسی دوسرے (کے گناہوں) کا بوجھ نہیں اٹھائے گا"
  53,39,"اور یہ کہ انسان کو (عدل میں) وہی کچھ ملے گا جس کی اُس نے کوشش کی ہوگی (رہا فضل اس پر کسی کا حق نہیں وہ محض اللہ کی عطاء و رضا ہے جس پر جتنا چاہے کر دے)"
  53,40,"اور یہ کہ اُس کی ہر کوشش عنقریب دکھا دی جائے گی (یعنی ظاہر کر دی جائے گی)"
  53,41,"پھر اُسے (اُس کی ہر کوشش کا) پورا پورا بدلہ دیا جائے گا"
  53,42,"اور یہ کہ (بالآخر سب کو) آپ کے رب ہی کی طرف پہنچنا ہے"
  53,43,"اور یہ کہ وہی (خوشی دے کر) ہنساتا ہے اور (غم دے کر) رُلاتا ہے"
  53,44,"اور یہ کہ وہی مارتا ہے اور جِلاتا ہے"
  53,45,"اور یہ کہ اُسی نے نَر اور مادہ دو قِسموں کو پیدا کیا"
  53,46,"نطفہ (ایک تولیدی قطرہ) سے جبکہ وہ (رَحمِ مادہ میں) ٹپکایا جاتا ہے"
  53,47,"اور یہ کہ (مرنے کے بعد) دوبارہ زندہ کرنا (بھی) اسی پر ہے"
  53,48,"اور یہ کہ وہی (بقدرِ ضرورت دے کر) غنی کر دیتا ہے اور وہی (ضرورت سے زائد دے کر) خزانے بھر دیتا ہے"
  53,49,"اور یہ کہ وہی شِعرٰی (ستارے) کا رب ہے (جس کی دورِ جاہلیت میں پوجا کی جاتی تھی)"
  53,50,"اور یہ کہ اسی نے پہلی (قومِ) عاد کو ہلاک کیا"
  53,51,"اور (قومِ) ثمود کو (بھی)، پھر (ان میں سے کسی کو) باقی نہ چھوڑا"
  53,52,"اور اس سے پہلے قومِ نوح کو (بھی ہلاک کیا)، بیشک وہ بڑے ہی ظالم اور بڑے ہی سرکش تھے"
  53,53,"اور (قومِ لُوط کی) الٹی ہوئی بستیوں کو (اوپر اٹھا کر) اُسی نے نیچے دے پٹکا"
  53,54,"پس اُن کو ڈھانپ لیا جس نے ڈھانپ لیا (یعنی پھر اُن پر پتھروں کی بارش کر دی گئی)"
  53,55,"سو (اے انسان!) تو اپنے پروردگار کی کن کن نعمتوں میں شک کرے گا"
  53,56,"یہ (رسولِ اکرم صلی اللہ علیہ وآلہ وسلم بھی) اگلے ڈر سنانے والوں میں سے ایک ڈر سنانے والے ہیں"
  53,57,"آنے والی (قیامت کی گھڑی) قریب آپہنچی"
  53,58,"اللہ کے سوا اِسے کوئی ظاہر (اور قائم) کرنے والا نہیں ہے"
  53,59,"پس کیا تم اس کلام سے تعجب کرتے ہو"
  53,60,"اور تم ہنستے ہو اور روتے نہیں ہو"
  53,61,"اور تم (غفلت کی) کھیل میں پڑے ہو"
  53,62,"سو اللہ کے لئے سجدہ کرو اور (اُس کی) عبادت کرو"
