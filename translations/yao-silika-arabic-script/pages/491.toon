quran[27]{c,v,t,f}:
  74,34,"Ni kumasikusiku ndema jakukulanguka."
  74,35,"Chisimu Walakwe (Motowo) uŵele limpepe (m’makungu) gekulungwa nnope."
  74,36,"Chitetelo kwa ŵandu."
  75,31,"Mwanti (kafili) nganijukunda (chikulupi) soni (namuno swala) nganijuswali."
  75,32,"Nambo jwakaaniile ni kunyosya."
  75,33,"Kaneka jwapite kwiŵasa lyakwe (juli nkwenda) mwakutwanga."
  76,25,"Soni likumbuchilani lina lya Ambuje ŵenu kundaŵi ni kwigulo (pakuswali swala sya Fajr, Dhuhr ni Asr)."
  76,26,"Soni chilo munsujudilani (pakuswali swala sya Maghrib ni Isha), ni munswejesyeje chilo ndema jelewu."
  76,27,"Chisimu ŵanganyaŵa akunonyelwa umi wachitema (wa duniya), ni akulileka munyuma mwao Lisiku lya usito."
  77,22,"Kwikanila ndema jakumanyika."
  77,23,"Basi ni twapimiile (ndema jakupagwila mwanache), Uwwetu niŵambone nnope mwa akupimila (ichindu)."
  77,24,"Ipotesi lyele lisikulyo taachiipata ŵakanila."
  78,19,"Ni lichiugulidwa liwunde, mwanti lichiŵa milango-milango."
  78,20,"Nombe matumbi gachityosyedwa m’mangwakwe, mwanti gachiŵa lunyisinyisi."
  78,21,"Chisimu Jahannama jikuŵa nkwajembecheya (ŵakulemwa)."
  79,13,"Chisimu walakweo ni n'gumiilo umpepe."
  79,14,"Basi ajile sayi ŵanganyao tachigamba kuona ali pachanya petaka."
  79,15,"Ana jinyyiche abali ja Musa?"
  80,10,"Basi ya jwalakwejo mmwe ni nkuikwanjila;"
  80,11,"Ngwamba (ngasintenda iyyo)! Chisimu galakwe (ma Ȃyaga) gaŵele chikumbusyo."
  80,12,"Basi jwaakusaka talikumbusye najo (Qur’anijo)."
  81,7,"Ni ndema jajichilumbikanyisyidwa mitima (ku ilu yakwe)."
  81,8,"Ni ndema jachachiwusyidwa mwanache jwankwongwe jwaŵasichidwe ali jwaumi."
  81,9,"Kuti ŵawulajidwe ni ulemwachi?"
  82,1,"Pandema jalichipasuka liwunde."
  82,2,"Ni ndema jasichilakatika ndondwa."
  82,3,"Ni ndema jasichigumuchila mbwani."