quran[3]{c,v,t}:
  114,0,شروع اللہ دے نام نال نہایت ترس کرن والا بہت مہر کرن والا
  114,1,توں آکھ میں پناہ وچ آیا لوکاں دے رَب دی
  114,2,لوکاں دے بادشاہ دی
  114,3,لوکاں دے مَعبود دی
  114,4,بِدی توں مَندے کَم د اخیال پانے والے لُک جان والے دی
  114,5,جہڑا مَندے کَم دا خیال پاندا اے لوکاں دے دِلاں وچ
  114,6,جِنَّاں تے آدمیاں وِچّوں
