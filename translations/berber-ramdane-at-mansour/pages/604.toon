quran[15]{c,v,t}:
  112,1,"Ini: \"Neppa, Ă–ebbi Yiwen"
  112,2,"Ă–ebbi, ur T ippissin yiwen"
  112,3,"Ur Iuriw, ur T uriwen"
  112,4,"Ur illi, d nned iS, yiwen"
  113,1,"Ini: \"ad iyi IĂ»Ă»eĂ´, Mass n wanqaĂ´"
  113,2,Si lhemm n wayen Ixelq
  113,3,si lhemm n tillas ma ssant
  113,4,si lhemm n tid ipĂ»uvun di tyersiwin
  113,5,"si lhemm um$ecci, ma iusem"
  114,1,"Ini: \"ad iyi IĂ»Ă»eĂ´, Mass n yimdanen"
  114,2,Agellid n yimdanen
  114,3,Ă–ebbi n yimdanen
  114,4,si lhemm u$way n win ipfezwin
  114,5,i i$ewwun idmaren n yimdanen
  114,6,si leonun u seg yimdanen
