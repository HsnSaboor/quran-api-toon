quran[8]{c,v,t,f}:
  104,7,"kylanti link širdžių."
  104,8,"Iš tiesų, tai (t. y. Pragaras) bus užvertas virš jų"
  104,9,"nusidriekusiomis kolonomis."
  105,4,"daužančiais juos kieto molio akmenimis."
  105,5,"Ir Jis pavertė juos panašiais į nuvalgytus šiaudus (kurių grūdai buvo nuvalgyti galvijų)."
  106,1,"(Didelė malonė iš Allaho) dėl Kuraišų apsaugos"
  106,2,"jų kasdienio saugumo karavanų (metu) žiemą ir vasarą, ",footnotes:1:t. y. prekybos karavanai, kurie žiemą keliavo į pietus, o vasarą į šiaurę.
  106,3,"lai jie garbina šio Namo (Kaabos Mekkoje) Viešpatį,"