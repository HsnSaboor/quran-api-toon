quran[11]{c,v,t,f}:
  96,16,"melagingo, nuodėmingo kuokšto."
  96,17,"Tada lai jis kviečiasi savo sąjungininkus,"
  96,18,"Mes pakviesime Pragaro angelus."
  99,7,"Tad, kas darė mažos skruzdės svorio gėrį, pamatys tai,"
  99,8,"ir kas darė mažos skruzdės svorio blogį – pamatys tai."
  100,4,"sukeliančiais tuo dulkių (debesis),"
  100,5,"drauge taip atvykstančiais į vidurį (t. y. prasiskverbiančiais į priešų gretas netikėto puolimo metu)."
  100,6,"Iš tiesų, žmogus savo Viešpačiui yra nedėkingas,"
  101,1,"Pribloškianti Neganda!"
  101,2,"Kas yra Pribloškianti Neganda?"
  101,3,"Ir kas tau paaiškins, kas yra Pribloškianti Neganda?"