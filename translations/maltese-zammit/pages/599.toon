quran[18]{c,v,t}:
  98,8,"Ħlashom għand Sidhom: il-Gonna ta' l-Għeden bix- xmajjar jigru taħthom; fihom jgħammru għal. dejjem. Huwa jithenna bihom, u huma jithennew bih. Dak (il- ħlas) għal min jibza' minn Sidu"
  99,1,"Meta l-art tithezzez bit-thezziza (qawwija) tagħha"
  99,2,"u l-art tferra' t-toqol tagħha (minn gewwa fiha)"
  99,3,"il-bniedem jgħid: 'X'għandha"
  99,4,"Dakinhar hija tħabbar l-aħbar tagħha"
  99,5,"għaliex Sidek nebbaħha"
  99,6,"Dakinhar in-nies joħorgu, imxerrdin, biex jintwerew (lilhom) l-għemejjel tagħhom (u jieħdu l-ħlas mistħoqq)"
  99,7,"U min jagħmel b'toqol ta' atomu gid, jarah"
  99,8,"umin jagħmel b'toqol ta' atomu deni, jarahl"
  100,1,"(Naħilfu) fuq iz-zwiemel lebbieta meta jilhgu"
  100,2,"ujtajru x-xrar (fil-giri kbir tagħhom)"
  100,3,"u jaħbtu (għall-għadu) mas-sebħ"
  100,4,"ujqanqlu bih (bil-giri) għabra kbira"
  100,5,"ubih jidħlu f'nofs ta' gemgħa (minn ta' l-għadu)"
  100,6,"(naħilfir) li l-bniedem tabilħaqq ingrat lejn Sidu"
  100,7,"uhuwa tabilħaqq xhud għal dan"
  100,8,"uhuwa tabilħaqq qalil fl-imħabba tal-gid (vsarerjaliji)"
  100,9,"Mela ma jafx li meta jixxerred dak li hemm fl-oqbra"