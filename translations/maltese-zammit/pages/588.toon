quran[28]{c,v,t}:
  83,7,"Le (ħazin qegħdin jaħsbu)t Ktieb il-ħziena jinsab tabilħaqq f'Siggin"
  83,8,"U x'inhu li jgħarrfek (Muħammad) x'inhu Siggar"
  83,9,"Huwa ktieb minqux (bl-għemejjel kollha tal-ħziena)"
  83,10,"Kastig qalil dakinhar għal dawk li jgiddbu"
  83,11,"lijiddbu Jum il-Ħaqql"
  83,12,"U ħadd ma jgiddbu, ħlief kull midneb ħati"
  83,13,"Meta jinqrawlu l-versi tagħna, jgħid: ''Stejjer tal-qedemi"
  83,14,"(Lefmhux hekk, imma) saddad fuq qlubhom dak (il-ħazen) li kienu jiksbu (b'għemilhom)"
  83,15,"Le(mhux kif qegħdin jgħidujl Dakinhar huma tabilħaqq ma jitħallewx jaraw lil Sidhom)"
  83,16,"Imbagħad huma tassew jinxtwew fin-Nar iħeggegt"
  83,17,"Imbagħad jingħad: 'Dan huwa (il-kastig) li kontu tgiddbul"
  83,18,"Lesfmhux tassew li t-tajbin u l-ħziena huma l-istessji Ktieb it-tajbin jinsab tabilħaqq f'Għizlijin"
  83,19,"U x'inhu li jgħarrfek (Muħammad) x'inhu Għillijian"
  83,20,"Ktieb minqux (bl-għemejjel kollha tat-tajbin)"
  83,21,"lijixhdu għalih dawk (l-angli) li jitqarrbu (/ejn Alla)"
  83,22,"l-gusti tabilħaqq jinsabu fil-hena"
  83,23,"iħarsu minn fuq id-divani (lejn dak kollu li tħejja għalihom)"
  83,24,"tagħraf f'ucuħhom id-dija ta' l-hena"
  83,25,"Huma jinsqew inbid safi, issigillat"
  83,26,"is-sigill tiegħu il-misk. Ħalli. lill-ħabrieka jikkompetu (bejniethom) għal dan (l-hena fil-Genna)"
  83,27,"Imħallat (dak l-inbid safi) ma' (ilma mill-għajn msejħa) Tasnim"
  83,28,"għajn li minnha jixorbu dawk li jitqarrbu (/ejn AZa)"
  83,29,"Tabilħaqq li dawk li għamlu l-ħazen kienu jidħku b'dawk li emmnu"
  83,30,"umeta kienu jgħaddu minn ħdejhom kienu jegħmzu lil xulxin"
  83,31,"u meta kienu jmorru lejn nieshom, (arahom) jerggħu lura biz- zufjett"
  83,32,"Meta kienu jarawhom (lil dawk li emmnu), kienu jgħidu: 'Dawn tabilħaqq mitlufini"
  83,33,"Izda huma (il-ħziena) ma ntbagħtux għassiesa fuqhom (fieq it-tajbin)"
  83,34,"U llum dawk li jemmnu jidħku b'dawk li ma jemmnux"