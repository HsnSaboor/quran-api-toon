quran[27{c,v,t}:
55,68,ان میں میوے ہیں اور کھجوریں اور انار ف ٨
55,69,پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے
55,70,ان سب باغوں میں اچھی عورتیں ہیں خوب صورت ف ٩
55,71,پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے
55,72,حوریں رکی رہنے والیاں خیموں میں ف ١٠
55,73,پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے
55,74,نہیں ہاتھ لگایا ان کو کسی آدمی نے ان سے پہلے اور نہ کسی جن نے
55,75,پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے
55,76,تکیہ لگائے بیٹھے سبز مسندوں پر اور قیمتی بچھونے نفیس پر
55,77,پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے
55,78,بڑی برکت ہے نام کو تیرے رب کی جو بڑائی والا اور عظمت والا ہے ف ١
56,1,جب ہو پڑے ہو پڑنے والی
56,2,نہیں ہے اس کے ہو پڑنے میں کچھ جھوٹ ف ٢
56,3,پست کرنے والی ہے بلند کرنے والی ف ٣
56,4,جب لرزے زمین کپکپا کر
56,5,اور ریزہ ریزہ ہوں پہاڑ ٹوٹ پھوٹ کر
56,6,پھر ہوجائیں غبار اڑتا ہوا ف ٤
56,7,اور تم ہوجاؤ تین قسم پر ف ٥
56,8,پھر داہنے والے کیا خوب ہیں داہنے والے ف ٦
56,9,اور بائیں والے کیا برے لوگ ہیں بائیں والے ف ٧
56,10,اور اگاڑی والے تو اگاڑی والے
56,11,وہ لوگ ہیں مقرب
56,12,باغوں میں نعمت کے ف ٨
56,13,انبوہ ہے پہلوں میں سے
56,14,اور تھوڑے ہیں پچھلوں میں سے ف ٩
56,15,بیٹھے ہیں جڑاؤ تختوں پر ف ١
56,16,تکیہ لگائے ان پر ایک دوسرے کے سامنے ف ٢
