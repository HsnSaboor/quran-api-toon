quran[30{c,v,t}:
74,18,اس نے فکر کیا اور دل میں ٹھہرا لیا
74,19,سو مارا جائیو کیسا ٹھہرایا
74,20,پھر مارا جائیو کیساٹھہرایا ف ٨
74,21,پھر نگاہ کی
74,22,پھر تیوری چڑھائی اور منہ تھتھایا
74,23,پھر پیٹھ پھیری اور غرور کیا
74,24,پھر بولا اور کچھ نہیں یہ جادو ہے چلا آتا
74,25,اور کچھ نہیں یہ کہا ہوا ہے آدمی کا ف ٩
74,26,اب اس کو ڈالوں گا آگ میں ف ١٠
74,27,اور تو کیا سمجھا کیسی ہے آگ
74,28,نہ باقی رکھے اور نہ چھوڑے ف ١١
74,29,جلا دینے والی ہے آدمیوں کو ف ١٢
74,30,اس پر مقرر ہیں انیس فرشتے ف ١٣
74,31,اور ہم نے جو رکھے ہیں دوزخ پر دروغہ وہ فرشتے ہی ہیں ف ١٤ اور ان کو جو گنتی رکھی ہے سو جانچنے کو منکروں کے ف ١٥ تاکہ یقین کرلیں وہ لوگ جن کو ملی ہے کتاب اور بڑھے ایمانداروں کا ایمان اور دھوکا نہ کھائیں جن کو ملی ہے کتاب اور مسلمان ف ١٦ اور تاکہ کہیں وہ لوگ جن کے دل میں روگ ہے اور منکرف ١ کیا غرض تھی اللہ کو اس مثل سے ف ٢ یوں بچلاتا ہے جس کو چاہتا ہے اور راہ دیتا ہے جس کو چاہتا ہے ف ٣ اور کوئی نہیں جانتا تیرے رب کے لشکر کو مگر خود ہی ف ٤ وہ تو سمجھاتا ہے لوگوں کے واسطے۔
74,32,سچ کہتا ہوں اور قسم ہے چاند کی،
74,33,اور رات کی جب پیٹھ پھیرے،
74,34,اور صبح کی جب روشن ہو وے
74,35,وہ ایک ہے بڑی چیزوں میں کی ف ٦
74,36,ڈرانے والی ہے لوگوں کو
74,37,جو کوئی چاہے تم میں سے کہ آگے بڑھے یا پیچھے رہے ف ٧
74,38,ہر ایک جی اپنے کیے کاموں میں پھنسا ہوا ہے
74,39,مگر داہنی طرف والے
74,40,باغوں میں ہیں مل کر پوچھتے ہیں
74,41,گناہ گاروں کا حال ف ٨
74,42,تم کا ہے سے جا پڑے دوزخ میں ف ٩
74,43,وہ بولے ہم نہ تھے نماز پڑھتے
74,44,اور نہ تھے کھانا کھلاتے محتاج کو
74,45,اور ہم تھے باتوں میں دھنستے دھسنے والوں کے ساتھ
74,46,اور ہم تھے جھٹلاتے انصاف کے دن کو
74,47,یہاں تک کہ آپہنچی ہم پر وہ یقینی بات ف ١٠
