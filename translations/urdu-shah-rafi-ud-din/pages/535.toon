quran[34{c,v,t}:
56,17,لیے پھرتے ہیں ان کے پاس لڑکے سدا رہنے والے ف ٣
56,18,آبخورے اور کوزے اور پیالہ نتھری شراب کا
56,19,جس سے نہ سر دکھے اور نہ بکواس لگے ف ٤
56,20,اور میوہ جونسا پسند کرلیں
56,21,اور گوشت اڑتے جانوروں کا جس قسم کا جی چاہے ف ٥
56,22,اور عورتیں گوری بڑی آنکھوں والیاں
56,23,جیسے موتی کے دانے اپنے غلاف کے اندر ف ٦
56,24,بدلہ ان کاموں کا جو کرتے تھے
56,25,نہیں سنیں گے وہاں بکواس اور نہ گناہ کی بات
56,26,مگر ایک بولنا سلام سلام ف ٧
56,27,اور داہنے والے کیا کہنے داہنے والوں کے
56,28,رہتے ہیں بیری کے درختوں میں جن کا کانٹا نہیں ف ٨
56,29,اور کیلے تہہ پر تہہ
56,30,اور سایہ لمبا ف ٩
56,31,اور پانی بہتا ہوا
56,32,اور میوہ بہت
56,33,نہ اس میں سے ٹوٹا اور نہ روکا ہوا ف ١٠
56,34,اور بچھونے اونچے ف ١١
56,35,ہم نے اٹھایا ان عورتوں کو ایک اچھی اٹھان پر
56,36,پھر کیا ان کو کنواریاں
56,37,پیار دلانے والیاں ہم عمر واسطے
56,38,داہنے والوں کے ف ١٢
56,39,انبوہ ہے پہلوں میں سے
56,40,اور انبوہ ہے پچھلوں میں سے ف ١٣
56,41,اور بائیں والے کیسے بائیں والے
56,42,تیز بھاپ میں اور جلتے پانی میں
56,43,اور سایہ میں دھوئیں کے
56,44,نہ ٹھنڈا اور نہ عزت کا ف ١
56,45,وہ لوگ تھے اس سے پہلے خوش حال
56,46,اور ضد کرتے تھے اس بڑے گناہ پر ف ٢
56,47,اور کہا کرتے تھے کیا جب ہم مر گئے اور ہوچکے مٹی اور ہڈیاں کیا ہم پھر اٹھائے جائیں گا
56,48,اور کیا ہمارے اگلے باپ دادے بھی ف ٣
56,49,تو کہہ دے کہ اگلے اور پچھلے
56,50,سب اکٹھے ہونے والے ہیں ایک دن مقرر کے وقت پر ف ٤
