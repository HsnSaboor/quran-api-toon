quran[21{c,v,t}:
100,10,اور تحقیق ہو وے جو کچھ کہ جیوں میں ہے ف ٨
100,11,بیشک ان کے رب کو ان کی اس دن سب خبر ہے ف ٩
101,1,وہ کھڑ کھڑا ڈالنے والی
101,2,کیا ہے وہ کھڑ کھڑا ڈالنے والی
101,3,اور تو کیا سمجھا کیا ہے وہ کھڑ کھڑ ڈالنے والی ف ١٠
101,4,جس دن ہویں لوگ جیسے پتنگے بکھرے ہوئے ف ١
101,5,اور ہو ویں پہاڑ جیسے رنگی ہوئی اون دھنی ہوئی ف ٢
101,6,سو جس کی بھاری ہوئیں تولیں
101,7,تو وہ رہے گا من مانتے گزران میں ف ٣
101,8,اور جس کی ہلکی ہوئیں تولیں
101,9,تو اس کا ٹھکانا گڑھا ہے
101,10,اور تو کیا سمجھا وہ کیا ہے
101,11,آگ ہے دہکتی ہوئی ف ٤
102,1,غفلت میں رکھا تم کو بہتات کی حرص نے
102,2,یہاں تک کہ جا دیکھیں قبریں ف ٥
102,3,کوئی نہیں آگے جان لو گے
102,4,پھر بھی کوئی نہیں آگے جان لو گے ف ٦
102,5,کوئی نہیں اگر جانو تم یقین کر کے ف ٧
102,6,بیشک تم کو دیکھنا ہے دوزخ
102,7,پھر دیکھنا ہے اس کو یقین کی آنکھ سے ف ٨
102,8,پھر پوچھیں گے تم سے اس دن آرام کی حقیقت ف ٩
