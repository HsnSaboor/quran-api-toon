quran[26{c,v,t}:
56,51,پھر تم جو ہو اے بہکے ہوؤ جھٹلانے والو
56,52,البتہ کھاؤ گے ایک درخت سینڈھ کے سے
56,53,پھر بھرو گے اس سے پیٹ ف ٥
56,54,پھر پیو گے اس پر ایک جلتا پانی
56,55,پھر پیو گے جیسے پئیں اونٹ تون سے ہوئے ف ٦
56,56,یہ مہمانی ہے ان کی انصاف کے دن ف ٧
56,57,ہم نے تم کو بنایا پھر کیوں نہیں سچ مانتے ف ٨
56,58,بھلا دیکھو تو جو پانی تم ٹپکاتے ہو
56,59,اب تم اس کو بناتے ہو یا ہم ہیں بنانے والے ف ٩
56,60,ہم ٹھہرا چکے تم میں مرنا ف ١٠ اور ہم عاجز نہیں
56,61,اس بات سے کہ بدلے میں لے آئیں تمہاری طرح کے لوگ اور اٹھا کھڑا کریں تم کو وہاں جہاں تم نہیں جانتے ف ١١
56,62,اور تم جان چکے ہو پہلا اٹھان پھر کیوں نہیں یاد کرتے ف ١٢
56,63,بھلا دیکھو تو جو تم بوتے ہو
56,64,کیا تم اس کو کرتے ہو کھیتی یا ہم ہیں کھیتی کردینے والے ف ١
56,65,اگر ہم چاہیں تو کر ڈالیں اس کو روندا ہوا گھانس پھر تم سارے دن رہو باتیں بناتے
56,66,ہم تو قرض دار رہ گئے
56,67,بلکہ ہم بےنصیب ہوگئے ف ٢
56,68,بھلا دیکھو تو پانی کو جو تم پیتے ہو
56,69,کیا تم نے اتارا اس کو بادل سے یا ہم ہیں اتارنے والے ف ٣
56,70,اگر ہم چاہیں کردیں اس کو کھارا پھر کیوں نہیں احسان مانتے ف ٤
56,71,بھلا دیکھو تو آگ جس کو تم سلگاتے ہو
56,72,کیا تم نے پیدا کیا اس کو درخت یا ہم ہیں پیدا کرنے والے ف ٥
56,73,ہم نے ہی تو بنایا وہ درخت یاد دلانے کو ف ٦ اور برتنے کو جنگل والوں کے ف ٧
56,74,سو بول پاکی اپنے رب کے نام کی جو سب سے بڑا ف ٨
56,75,سو میں قسم کھاتا ہوں تاروں کے ڈوبنے کی ف ٩
56,76,اور یہ قسم ہے اگر سمجھو تو بڑی قسم
