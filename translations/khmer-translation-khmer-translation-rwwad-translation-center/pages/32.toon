quran[30]{c,v,t}:
  32,1,"អាលីហ្វ ឡាម មីម (តួអក្សរទាំងនេះ គឺបានបកស្រាយរួចមកហើយនៅដើមសូរ៉ោះមុន(សូរ៉ោះអាល់ហ្ពាក៏រ៉ោះ)។"
  32,2,"ការបញ្ចុះគម្ពីរ(គួរអាន) គឺមកពីព្រះជាម្ចាស់នៃពិភពទាំងអស់ដោយគ្មានការមន្ទិលសង្ស័យចំពោះវាឡើយ។"
  32,3,"ឬមួយពួកគេ(ពួកប្រឆាំង)និយាយថា៖ គេ(ព្យាការីមូហាំម៉ាត់)បានប្រឌិតកុហកវា(គម្ពីរគួរអាន)ឡើង។ ផ្ទុយទៅវិញ វាជាការពិតពីព្រះជាម្ចាស់របស់អ្នកដើម្បីឱ្យអ្នកដាស់តឿនព្រមានក្រុមមួយដែលមិនធ្លាប់មានអ្នកដាស់តឿនព្រមានណាម្នាក់មុនអ្នកបានទៅដល់ពួកគេនោះឡើយ។ សង្ឃឹមថា ពួកគេនឹងទទួលបានការចង្អុលបង្ហាញ។"
  32,4,"អល់ឡោះគឺជាអ្នកដែលបានបង្កើតមេឃជាច្រើនជាន់និងផែនដី ព្រមទាំងអ្វីៗដែលនៅចន្លោះវាទាំងពីរក្នុងរយៈពេលប្រាំមួយថ្ងៃ។ បន្ទាប់មក ទ្រង់គង់លើអារ៉ស្ហ។ សម្រាប់ពួកអ្នក(ឱមនុស្សលោក) គឺគ្មានអ្នកគាំពារ និងគ្មានអ្នកជួយអន្តរាគមន៍ណាក្រៅពីទ្រង់ឡើយ។ ដូច្នេះ តើពួកអ្នកមិនគិតពិចារណាទេឬ?"
  32,5,"ទ្រង់ចាត់ចែងកិច្ចការទាំងឡាយពីលើមេឃដល់ផែនដី។ បន្ទាប់មក (កិច្ចការទាំងនោះ)វានឹងឡើងទៅកាន់ទ្រង់វិញនៅថ្ងៃមួយដែលរយៈពេលរបស់វាស្មើនឹងមួយពាន់ឆ្នាំតាមអ្វីដែលពួកអ្នកគណនា(ក្នុងលោកិយ)។"
  32,6,"នោះគឺជាអ្នកដែលដឹងបំផុតនូវប្រការអាថ៌កំបាំង និងប្រការដែលលាតត្រដាង ជាអ្នកដែលមហាខ្លាំងពូកែ មហាអាណិតស្រលាញ់។"
  32,7,"ទ្រង់ជាអ្នកដែលបង្កើតអ្វីៗទាំងអស់ឲ្យមានភាពល្អឥតខ្ចោះ។ ហើយទ្រង់បានចាប់ផ្តើមបង្កើតមនុស្ស(ព្យាការីអាហ្ទាំ)អំពីដីឥដ្ឋ។"
  32,8,"បន្ទាប់មក ទ្រង់បានបង្កើតកូនចៅរបស់គេអំពីទឹកកាមដែលគ្មានតម្លៃ។"
  32,9,"បន្ទាប់មក ទ្រង់បានបង្កើតគេឱ្យមានលក្ខណៈពេញលេញ ហើយទ្រង់បានផ្លុំព្រលឹងទៅក្នុងខ្លួនរបស់គេ។ ហើយទ្រង់បានបង្កើតឱ្យពួកអ្នក(ឱមនុស្សលោក)នូវសោតវិញ្ញាណ ចក្ខុវិញ្ញាណ និងដួងចិត្ត។ អ្វីដែលពួកអ្នកដឹងគុណ(អល់ឡោះ) គឺតិចតួចបំផុត។"
  32,10,"ហើយពួកគេ(ពួកមុស្ហរីគីន)បាននិយាយថា៖ តើនៅពេលដែលពួកយើង(ស្លាប់)កប់ទៅក្នុងដីហើយនោះ តើពួកយើងនឹងត្រូវបានគេបង្កើត(ឱ្យរស់ឡើងវិញ)សាជាថ្មីឬ? ផ្ទុយទៅវិញ ពួកគេគឺជាពួកដែលគ្មានជំនឿចំពោះការជួបនឹងព្រះជាម្ចាស់របស់ពួកគេឡើយ។"
  32,11,"ចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)ពោលថា៖ ម៉ាលីគុលម៉ោតដែលទទួលបន្ទុកខាងដកយកជីវិត នឹងមកដកយកជីវិតពួកអ្នក។ បន្ទាប់មក ពួកអ្នកនឹងត្រូវគេនាំត្រឡប់មកកាន់ព្រះជាម្ចាស់របស់ពួកអ្នកវិញ។"
  32,12,"ហើយប្រសិនបើអ្នកបានឃើញ នៅពេលដែលពួកឧក្រិដ្ឋជនទាំងឡាយឱនក្បាលរបស់ពួកគេចុះនៅចំពោះមុខព្រះជាម្ចាស់របស់ពួកគេ។ (ហើយពួកគេពោលថា៖) បរពិត្រព្រះជាម្ចាស់នៃយើងខ្ញុំ! យើងខ្ញុំបានឃើញ និងបានឮហើយ។ ហេតុនេះ សូមព្រះអង្គមេត្តាឱ្យយើងខ្ញុំត្រឡប់(ទៅកាន់ជីវិតលោកិយវិញម្តងទៀត)ដើម្បីឱ្យយើងខ្ញុំអាចសាងទង្វើកុសលវិញ។ ពិតប្រាកដណាស់ (ពេលនេះ)យើងខ្ញុំ គឺជាអ្នកដែលជឿជាក់យ៉ាងពិតប្រាកដ។"
  32,13,"ហើយប្រសិនបើយើងមានចេតនា យើងនឹងផ្តល់ឱ្យបុគ្គលគ្រប់រូបនូវការចង្អុលបង្ហាញជាមិនខាន។ ប៉ុន្តែបន្ទូលរបស់យើងបានសម្រេចអំពីយើងរួចទៅហើយថា៖ យើងពិតជានឹងបំពេញនរកជើហាន់ណាំពីពពួកជិន និងមនុស្សលោកទាំងអស់។"
  32,14,"(មានគេនិយាយទៅកាន់ពួកទាំងនោះថា៖) ចូរពួកអ្នកភ្លក់ចុះ(នូវរសជាតិនៃទណ្ឌកម្ម) ដោយសារតែពួកអ្នកភ្លេចពីជំនួបនៅថ្ងៃរបស់ពួកអ្នក(នៅថ្ងៃបរលោក)នេះ។ ពិតប្រាកដណាស់ (នៅថ្ងៃនេះ)យើងក៏បំភ្លេចពួកអ្នកដូចគ្នា។ ហើយចូរពួកអ្នកភ្លក់ចុះនូវទណ្ឌកម្មដ៏អមតៈដោយសារតែអ្វីដែលពួកអ្នកធ្លាប់បានប្រព្រឹត្ត។"
  32,15,"ជាការពិតណាស់ អ្នកដែលមានជំនឿនឹងបណ្តាវាក្យខណ្ឌទាំងឡាយរបស់យើង នៅពេលណាគេរំលឹកពួកគេនឹងវាក្យខណ្ឌទាំងនោះ គឺពួកគេលំឱនកាយស៊ូជោត និងលើកតម្កើងដោយការកោតសរសើរចំពោះព្រះជាម្ចាស់របស់ពួកគេ ហើយពួកគេមិនក្រអឺតក្រទមឡើយ។"
  32,16,"ខ្នងរបស់ពួកគេបានក្រោកចេញពីកន្លែងគេង។ ពួកគេបួងសួងសុំពីព្រះជាម្ចាស់របស់ពួកគេដោយការបារម្ភខ្លាច(ទណ្ឌកម្ម) និងក្តីប្រាថ្នា(ចង់បានផលបុណ្យ) ហើយពួកគេបរិច្ចាគមួយចំនួនអំពីអ្វីដែលយើងបានប្រទានជាលាភសក្ការៈដល់ពួកគេ។"
  32,17,"ជាការពិតណាស់ គ្មានបុគ្គលណាម្នាក់ដឹងនោះទេនូវអ្វីដែលគេបានរក្សាទុកសម្រាប់ពួកគេ(អ្នកមានជំនឿ)អំពីអ្វីដែលធ្វើឱ្យពួកគេគាប់ចិត្តនោះ ជាការតបស្នងចំពោះអ្វីដែលពួកគេបានប្រព្រឹត្ត(ក្នុងលោកិយ)។"
  32,18,"ដូច្នេះ តើអ្នកដែលមានជំនឿ ដូចគ្នានឹងអ្នកដែលប្រព្រឹត្តល្មើសឬ? ពួកគេគឺមិនដូចគ្នាឡើយ។"
  32,19,"រីឯបណ្តាអ្នកដែលមានជំនឿ និងបានសាងទង្វើកុសល ពិតណាស់ សម្រាប់ពួកគេគឺឋានសួគ៌ជាកន្លែងស្នាក់នៅ ជាកិត្តិយស(ពីអល់ឡោះចំពោះពួកគេ) និងជាការតបស្នងចំពោះអ្វីដែលពួកគេធ្លាប់បានប្រព្រឹត្ត។"
  32,20,"ចំណែកឯពួកដែលប្រព្រឹត្តល្មើសវិញនោះ កន្លែងស្នាក់នៅរបស់ពួកគេ គឺឋាននរក។ រាល់ពេលដែលពួកគេចង់ចេញអំពីវា ពួកគេត្រូវបានគេបញ្ជូនឱ្យត្រឡប់ទៅនៅក្នុងវាវិញ។ ហើយមានគេពោលទៅកាន់ពួកគេថា៖ ចូរពួកអ្នកភ្លក់ចុះនូវទណ្ឌកម្មភ្លើងនរកដែលពួកអ្នកធ្លាប់បានបដិសេធ(មិនជឿ)ចំពោះវា។"
  32,21,"ហើយយើងប្រាកដជានឹងឱ្យពួកទាំងនោះភ្លក់នូវទណ្ឌកម្មកម្រិតស្រាល(ក្នុងលោកិយ)មុននឹងទណ្ឌកម្មធ្ងន់ធ្ងរបំផុត(នៅថ្ងៃបរលោក)។ សង្ឃឹមថា ពួកគេនឹងវិលត្រឡប់។"
  32,22,"ហើយគ្មាននរណាដែលបំពានជាងពួកដែលត្រូវបានគេទូន្មានដោយវាក្យខណ្ឌទាំងឡាយរបស់ព្រះជាម្ចាស់របស់គេ ក្រោយមក គេបែរជាងាកចេញពីវាទៅវិញនោះឡើយ។ ពិតប្រាកដណាស់ យើងគឺជាអ្នកផ្តន្ទាទោសដល់ពួកឧក្រិដ្ឋជនទាំងឡាយ។"
  32,23,"ហើយពិតប្រាកដណាស់ យើងបានប្រទានឱ្យព្យាការីមូសានូវគម្ពីរ(តាវរ៉ត)។ ដូច្នេះ ចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)កុំមានការមន្ទិលសង្ស័យចំពោះការជួបនឹងព្យាការីមូសា(នៅយប់អ៊ីសរ៉កនិងមៀករ៉ច)ឱ្យសោះ។ ហើយយើងបានចាត់ទុកវា(គម្ពីរតាវរ៉ត) ជាការចង្អុលបង្ហាញដល់អម្បូរអ៊ីស្រាអែល។"
  32,24,"ហើយយើងបានឱ្យពួកគេមួយចំនួន(អម្បូរអ៊ីស្រាអែល)ក្លាយទៅជាមេដឹកនាំដែលចង្អុលបង្ហាញ(ទៅកាន់ការពិត)ទៅតាមបទបញ្ជារបស់យើងនៅពេលដែលពួកគេបានអត់ធ្មត់។ ហើយពួកគេបានជឿជាក់យ៉ាងពិតប្រាកដចំពោះវាក្យខណ្ឌទាំងឡាយរបស់យើង។"
  32,25,"ពិតប្រាកដណាស់ ព្រះជាម្ចាស់របស់អ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់) ទ្រង់នឹងកាត់សេចក្តីរវាងពួកគេនៅថ្ងៃបរលោកចំពោះអ្វីដែលពួកគេធ្លាប់បានខ្វែងគំនិតគ្នាចំពោះវា។"
  32,26,"តើវាមិនទាន់បានបញ្ជាក់ច្បាស់ដល់ពួកទាំងនោះទៀតឬ ថាតើមានប្រជាជាតិជំនាន់មុនពួកគេប៉ុន្មានហើយដែលយើងបានបំផ្លាញ ដែលពួកទាំងនោះក៏បានដើរកាត់លំនៅដ្ឋានរបស់ពួកគេផងដែរនោះ? ពិតប្រាកដណាស់ នៅក្នុងរឿងនោះ គឺជាសញ្ញាភស្តុតាង។ តើពួកគេមិនស្តាប់ឮទេឬ?"
  32,27,"តើពួកទាំងនោះមិនបានឃើញទេឬថា ពិតប្រាកដណាស់ យើងបានបញ្ជូនទឹកភ្លៀងទៅកាន់ដីដែលស្ងួតហួតហែង។ ពេលនោះ តាមរយៈទឹកភ្លៀងនោះ យើងបានបញ្ចេញនូវដំណាំសម្រាប់សត្វពាហនៈរបស់ពួកគេ និងខ្លួនពួកគេផ្ទាល់ទទួលទាន។ តើពួកគេមិនបានឃើញទេឬ?"
  32,28,"ហើយពួកគេថែមទាំងនិយាយថា៖ តើពេលណាទើបការកាត់សេចក្តីនេះមកដល់ ប្រសិនបើពួកអ្នកជាអ្នកទៀងត្រង់មែននោះ?"
  32,29,"ចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)ពោលថា៖ ថ្ងៃកាត់សេចក្តីនោះ ការមានជំនឿរបស់ពួកប្រឆាំង(នៅលើលោកិយ) គឺគ្មានផលប្រយោជន៍អ្វីដល់ពួកគេឡើយ ហើយពួកគេក៏មិនត្រូវបានគេពន្យារពេលឲ្យនោះដែរ។"
  32,30,"ដូច្នេះ ចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)ងាកចេញពីពួកគេ ហើយរង់ចាំមើលចុះ។ ពិតប្រាកដណាស់ ពួកគេក៏ជាអ្នកដែលរង់ចាំមើលដែរ។"
