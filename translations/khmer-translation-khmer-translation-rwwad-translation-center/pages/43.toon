quran[89]{c,v,t}:
  43,1,"ហាមីម (តួអក្សរទាំងនេះ គឺបានបកស្រាយរួចមកហើយនៅដើមសូរ៉ោះមុន(សូរ៉ោះអាល់ហ្ពាក៏រ៉ោះ)។"
  43,2,"(អល់ឡោះទ្រង់)ស្បថនឹងគម្ពីរ(គួរអាន)ដ៏ច្បាស់លាស់។"
  43,3,"ពិតប្រាកដណាស់ យើងបានបញ្ចុះគម្ពីរគួរអានជាភាសាអារ៉ាប់ សង្ឃឹមថាពួកអ្នកចេះគិតពិចារណា។"
  43,4,"ហើយពិតប្រាកដណាស់ វា(គម្ពីរគួរអាន)គឺស្ថិតនៅក្នុងសៀវភៅកំណត់ត្រា(ឡាវហ៊ុលម៉ះហ្វ៊ូស)ដែលនៅជាមួយនឹងយើងដែលមានលក្ខណៈខ្ពង់ខ្ពស់ និងប្រកបដោយគតិបណ្ឌិត។"
  43,5,"ដូច្នេះ តើយើងត្រូវបញ្ឈប់ការបញ្ចុះគម្ពីរគួរអានទៅកាន់ពួកអ្នកដោយសារតែពួកអ្នកជាក្រុមដែលបំពានឬ?"
  43,6,"មានព្យាការីជាច្រើននាក់ហើយដែលយើងបានបញ្ជូនទៅកាន់អ្នកជំនាន់មុនៗ។"
  43,7,"ប៉ុន្តែគ្មានព្យាការីណាម្នាក់បានមកដល់ពួកគេនោះឡើយ លើកលែងតែពួកគេចំអកឡកឡឺយចំពោះព្យាការីនោះ។"
  43,8,"ដូច្នេះ យើងក៏បានបំផ្លាញពួកដែលមានកម្លាំងខ្លាំងក្លាជាងពួកទាំងនោះ(ពួកមុស្ហរីគីន)ទៅទៀត។ ហើយគំរូ(នៃការបំផ្លាញអ្នកជំនាន់មុន)ក៏បានកើតឡើងរួចទៅហើយ។"
  43,9,"ហើយប្រសិនបើអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)សួរពួកគេ(ពួកមុស្ហរីគីន)ថា៖ តើអ្នកណាដែលបានបង្កើតមេឃជាច្រើនជាន់និងផែនដី ប្រាកដជាពួកគេនឹងឆ្លើយថា៖ អ្នកដែលបានបង្កើតពួកវា(មេឃនិងផែនដី) គឺព្រះជាម្ចាស់ដ៏មហាខ្លាំងពូកែ មហាដឹងបំផុត។"
  43,10,"(ទ្រង់)ជាអ្នកដែលបានបង្កើតផែនដីឱ្យមានសណ្ឋានលាតសន្ធឹងសម្រាប់ពួកអ្នក ហើយទ្រង់បានបង្កើតនូវផ្លូវជាច្រើននៅលើវាសម្រាប់ពួកអ្នក សង្ឃឹមថាពួកអ្នកនឹងទទួលបានការចង្អុលបង្ហាញ។"
  43,11,"ហើយ(ទ្រង់)ជាអ្នកដែលបានបញ្ចុះទឹកភ្លៀងពីលើមេឃតាមបរិមាណ(ដែលចាំបាច់)។ ហើយតាមរយៈទឹកភ្លៀងនេះ យើងបានធ្វើឱ្យដីដែលហួតហែងមានជីជាតិឡើងវិញ។ ក៏ដូច្នោះដែរ គេនឹងបញ្ចេញពួកអ្នក(ពីផ្នូររបស់ពួកអ្នក)មកវិញ។"
  43,12,"ហើយ(ទ្រង់)ក៏ជាអ្នកដែលបានបង្កើតរាល់អ្វីៗទាំងអស់ឱ្យមានជាគូៗ។ ហើយទ្រង់បានបង្កើតសម្រាប់ពួកអ្នកនូវសំពៅ និងសត្វពាហនៈដែលពួកអ្នកអាចជិះវាបាន។"
  43,13,"ដើម្បីឲ្យពួកអ្នកអាចជិះលើខ្នងរបស់ពួកវា។ បន្ទាប់មក ពួកអ្នកនឹកឃើញនូវឧបការគុណនៃព្រះជាម្ចាស់របស់ពួកអ្នកនៅពេលដែលពួកអ្នកបានជិះលើខ្នងរបស់វា ហើយពួកអ្នកពោលថា៖ ទ្រង់មហាស្អាតស្អំដែលបានសម្រួលដល់ពួកយើងនូវប្រការនេះ ហើយពួកយើងពុំមែនជាអ្នកដែលមានសមត្ថភាព(ក្នុងការទទួលបានវានោះឡើយ)។"
  43,14,"ហើយពិតណាស់ ពួកយើងពិតជានឹងត្រូវវិលត្រឡប់ទៅកាន់ព្រះជាម្ចាស់របស់ពួកយើង(តែមួយគត់)។"
  43,15,"ហើយពួកគេ(ពួកមុស្ហរីគីន)បានចាត់ទុកបណ្តាខ្ញុំបម្រើរបស់ទ្រង់មួយចំនួន(ម៉ាឡាអ៊ីកាត់) ជាចំណែកមួយសម្រាប់ទ្រង់។ ពិតប្រាកដណាស់ មនុស្សលោក គឺពិតជារមិលគុណយ៉ាងច្បាស់លាស់។"
  43,16,"តើ(ពួកអ្នកគិតថា)ទ្រង់ជ្រើសយកបុត្រីពីអ្វីដែលទ្រង់បានបង្កើត(សម្រាប់ខ្លួនទ្រង់) ហើយទ្រង់ជ្រើសរើសកូនប្រុសសម្រាប់ពួកអ្នកឬ?"
  43,17,"ហើយនៅពេលដែលគេផ្តល់ដំណឹងដល់នរណាម្នាក់ក្នុងចំណោមពួកគេនូវអ្វី(កូនស្រី)ដែលគេបានចោទប្រកាន់ទៅលើព្រះជាម្ចាស់ដ៏មហាសប្បុរស មុខរបស់គេប្រែជាពណ៌ខ្មៅ ហើយរូបគេពោរពេញទៅដោយទុក្ខព្រួយ។"
  43,18,"តើ(ពួកគេភ្ជាប់ទៅកាន់ទ្រង់)អ្នកដែលត្រូវគេចិញ្ចឹមក្នុងលក្ខណៈតុបតែង ហើយពេលដែលជជែកដេញដោល ក៏មិនចេះយកហេតុផលច្បាស់លាស់(មកបញ្ជាក់)ផងនោះឬ?"
  43,19,"ហើយពួកគេចាត់ទុកម៉ាឡាអ៊ីកាត់ទាំងឡាយដែលជាខ្ញុំបម្រើរបស់ព្រះជាម្ចាស់ដ៏មហាសប្បុរស ថាជាភេទស្រី។ តើពួកទាំងនោះមានវត្តមាននៅពេលដែលទ្រង់បានបង្កើតពួកគេ(ម៉ាឡាអ៊ីកាត់)ឬ? គេនឹងកត់ត្រាទុកនូវការអះអាងរបស់ពួកទាំងនោះ ហើយពួកទាំងនោះនឹងត្រូវគេសួរ។"
  43,20,"ហើយពួកគេបាននិយាយថា៖ ប្រសិនបើព្រះជាម្ចាស់ដ៏មហាសប្បុរសមានចេតនា ពួកយើងក៏មិនគោរពសក្ការៈទៅចំពោះពួកគេដែរ។ ពួកគេគ្មានចំណេះដឹងអ្វីអំពីរឿងនោះឡើយ។ ពួកគេគ្មានអ្វីក្រៅពីការភូតកុហកនោះឡើយ។"
  43,21,"ឬមួយយើង(អល់ឡោះ)បានប្រទាននូវគម្ពីរណាមួយទៅឱ្យពួកគេមុនវា(គម្ពីរគួរអាន) ហើយពួកគេជាអ្នកដែលប្រកាន់ខ្ជាប់នឹងគម្ពីរនោះ?"
  43,22,"ផ្ទុយទៅវិញ ពួកគេបាននិយាយថា៖ ពិតប្រាកដណាស់ ពួកយើងបានឃើញជីដូនជីតារបស់ពួកយើងស្ថិតនៅលើសាសនាមួយ។ ហើយពិតប្រាកដណាស់ ពួកយើងជាអ្នកដែលត្រូវបានគេចង្អុលបង្ហាញឲ្យដើរតាមលំអានរបស់ពួកគេ។"
  43,23,"ក៏ដូច្នោះដែរ យើងមិនបានបញ្ជូនអ្នកដាស់តឿនព្រមានមុនអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់) ទៅកាន់ភូមិស្រុកណាមួយនោះឡើយ លើកលែងតែពួកដែលមានទ្រព្យសម្បត្តិស្តុកស្តម្ភនៃស្រុកភូមិនោះតែងតែនិយាយថា៖ ពិតប្រាកដណាស់ ពួកយើងបានឃើញជីដូនជីតារបស់ពួកយើងស្ថិតនៅលើសាសនាមួយ។ ហើយពិតប្រាកដណាស់ ពួកយើងជាអ្នកដែលដើរតាមលំអាន(មាគ៌ា)របស់ពួកគេ។"
  43,24,"គេ(អ្នកដាស់តឿនព្រមាន)បាននិយាយថា៖ តើបើទោះជាខ្ញុំបាននាំមកឱ្យពួកអ្នកនូវអ្វីដែលល្អប្រសើរជាងអ្វីដែលពួកអ្នកបានឃើញជីដូនជីតារបស់ពួកអ្នកប្រកាន់ខ្ជាប់ក៏ដោយឬ? ពួកគេបានតបថា៖ ពិតប្រាកដណាស់ ពួកយើងជាអ្នកដែលប្រឆាំងនឹងអ្វីដែលគេបញ្ជូនពួកអ្នកឲ្យនាំវាមក។"
  43,25,"ហេតុនេះ យើងក៏បានផ្តន្ទាទោសពួកគេ។ ដូច្នេះ ចូរអ្នកពិនិត្យមើលចុះ ថាតើលទ្ធផលចុងក្រោយរបស់ពួកដែលបដិសេធនោះទៅជាយ៉ាងណា?"
  43,26,"ហើយ(ចូរអ្នករំលឹក)នៅពេលព្យាការីអ៊ីព្រហ៊ីមបាននិយាយទៅកាន់ឪពុករបស់គាត់ និងក្រុមរបស់គាត់ថា៖ ពិតប្រាកដណាស់ ខ្ញុំមិនពាក់ព័ន្ធជាមួយនឹងអ្វីដែលពួកអ្នកគោរពសក្ការៈនោះឡើយ។"
  43,27,"លើកលែងអ្នកដែលបានបង្កើតខ្ញុំ(អល់ឡោះ)ប៉ុណ្ណោះ។ ពិតប្រាកដណាស់ ទ្រង់នឹងចង្អុលបង្ហាញដល់ខ្ញុំ។"
  43,28,"ហើយគាត់បានធ្វើឲ្យវា(ពាក្យ لا إله إلا الله)ក្លាយជាពាក្យមួយដែលនៅគង់វង្ស(សម្រាប់អ្នកជំនាន់ក្រោយ)។ សង្ឃឹមថា ពួកគេនឹងវិលត្រឡប់។"
  43,29,"ផ្ទុយទៅវិញ យើងបានឲ្យពួកទាំងនោះ និងជីដូនជីតារបស់ពួកគេបានសោយសុខ រហូតដល់សេចក្តីពិត(គម្ពីរគួរអាន) និងអ្នកនាំសារដ៏ច្បាស់លាស់ម្នាក់(ព្យាការីមូហាំម៉ាត់)បានមកដល់ពួកគេ។"
  43,30,"តែនៅពេលដែលសេចក្តីពិត(គម្ពីរគួរអាន)បានមកដល់ពួកគេ ពួកគេបែរជានិយាយថា៖ “នេះគឺជាមន្តអាគម ហើយពិតប្រាកដណាស់ ពួកយើងគឺជាអ្នកដែលប្រឆាំងនឹងវា”ទៅវិញ។"
  43,31,"ហើយពួកគេបាននិយាយទៀតថា៖ ហេតុអ្វីបានជាគេមិនបញ្ចុះគម្ពីរគួរអាននេះទៅឲ្យបុរសដ៏ថ្កុំថ្កើងម្នាក់ដែលមកពីភូមិស្រុកពីរនេះ(ម៉ាក្កះ ឬតអ៊ីហ្វ)ទៅ?"
  43,32,"តើពួកគេបែងចែកក្តីមេត្តាករុណានៃព្រះជាម្ចាស់អ្នកឬ? យើង(អល់ឡោះ)ទេដែលបែងចែកការរស់នៅរវាងពួកគេនៅក្នុងជីវិតលោកិយនេះ ហើយយើងបានលើកឋានៈអ្នកមួយចំនួននៃពួកគេលើអ្នកមួយចំនួនទៀត ដើម្បីឱ្យពួកគេទាញយកប្រយោជន៍ពីគ្នាទៅវិញទៅមក។ ហើយក្តីមេត្តាករុណានៃព្រះជាម្ចាស់របស់អ្នក គឺល្អប្រសើរជាងអ្វី(លាភសំណាងលោកិយ)ដែលពួកគេខិតខំប្រមូលទៅទៀត។"
  43,33,"ហើយប្រសិនបើមនុស្សលោកមិនមែនស្ថិតនៅជាប្រជាជាតិតែមួយ(ដែលគ្មានជំនឿ)ទេនោះ យើងប្រាកដជានឹងឱ្យគេហដ្ឋានទាំងឡាយរបស់ពួកគ្មានជំនឿមានដំបូល និងជណ្តើរធ្វើអំពីប្រាក់ដែលពួកគេអាចឡើងបានជាមិនខាន។"
  43,34,"ហើយ(យើងនឹងឱ្យ)គេហឋានទាំងឡាយរបស់ពួកគេមានទ្វារ និងគ្រែជាច្រើនដែលពួកគេអាចទម្រេតខ្លួនលើវាបាន។"
  43,35,"ព្រមទាំងមាសផងដែរ។ ហើយរាល់របស់ទាំងនោះគ្រាន់តែជាការត្រេកត្រអាលនៃជីវិតលោកិយប៉ុណ្ណោះ។ រីឯ(ការសោយសុខ)នៅថ្ងៃបរលោកដែលនៅឯព្រះជាម្ចាស់របស់អ្នក គឺសម្រាប់បណ្តាអ្នកដែលកោតខ្លាច(អល់ឡោះ)។"
  43,36,"ហើយជនណាដែលងាកចេញពីការរំលឹកនៃព្រះជាម្ចាស់ដ៏មហាសប្បុរស(គម្ពីរគួរអាន)យើងនឹងឱ្យស្ហៃតនពង្វក់រូបគេ ហើយវានឹងក្លាយជាគូកនសម្រាប់រូបគេ។"
  43,37,"ហើយពិតប្រាកដណាស់ ពួកវានឹងរារាំងពួកគេពីមាគ៌ា(ត្រឹមត្រូវ) ទាំងដែលពួកគេគិតស្មានថា ពិតណាស់ ពួកគេជាអ្នកដែលទទួលបានការចង្អុលបង្ហាញ។"
  43,38,"លុះនៅពេលដែលជននោះបានមកជួបយើង(នៅថ្ងៃបរលោក) គេក៏និយាយថា៖ ឱអនិច្ចា! គួរណាស់តែរវាងខ្ញុំ និងអ្នក(ស្ហៃតន)នៅឃ្លាតឆ្ងាយពីគ្នាដូចទិសខាងកើត និងទិសខាងលិច។ ពិតណាស់ (អ្នក)ជាគូកនដ៏អាក្រក់បំផុត។"
  43,39,"តែវាមិនបានផ្តល់ជាប្រយោជន៍អ្វីឡើយដល់ពួកអ្នកនៅក្នុងថ្ងៃនេះ ខណៈដែលពួកអ្នកបានបំពាន។ ជាការពិតណាស់ ពួកអ្នកស្ថិតនៅក្នុងទណ្ឌកម្មរួមជាមួយគ្នា។"
  43,40,"ដូច្នេះ តើអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)អាចធ្វើឱ្យអ្នកថ្លង់ស្តាប់ឮ ឬអាចចង្អុលបង្ហាញដល់អ្នកខ្វាក់ និងអ្នកដែលស្ថិតនៅក្នុងភាពវង្វេងយ៉ាងច្បាស់បានដែរឬ?"
  43,41,"ហើយបើទោះបីជាយើងឱ្យអ្នកស្លាប់(មុន)ក៏ដោយ ក៏យើងនៅតែជាអ្នកដែលផ្តន្ទាទោសពួកគេដែរ។"
  43,42,"ឬក៏យើងបង្ហាញឱ្យអ្នកបានឃើញនូវអ្វី(ទណ្ឌកម្ម)ដែលយើងបានសន្យាចំពោះពួកគេក៏ដោយ ក៏យើង(នៅតែ)ជាអ្នកដែលសមត្ថភាពលើពួកគេដដែល។"
  43,43,"ដូច្នេះ ចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)ប្រកាន់ខ្ជាប់នូវអ្វីដែលគេបានផ្តល់វ៉ាហ៊ីទៅកាន់អ្នកចុះ។ ពិតប្រាកដណាស់ អ្នកស្ថិតនៅលើមាគ៌ាដ៏ត្រឹមត្រូវ។"
  43,44,"ហើយពិតប្រាកដណាស់ វា(គម្ពីរគួរអាន) គឺពិតជាភាពថ្កុំថ្កើងសម្រាប់អ្នក និងសម្រាប់ក្រុមរបស់អ្នកផងដែរ។ ហើយពួកអ្នកនឹងត្រូវគេសួរជាមិនខាន។"
  43,45,"ហើយចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)សួរទៅកាន់អ្នកនាំសារទាំងឡាយរបស់យើងដែលយើងបានបញ្ជូនមុនអ្នកថា៖ តើយើងធ្លាប់បានបង្កើតព្រះនានាឱ្យពួកគេគោរពសក្ការៈផ្សេងពីព្រះជាម្ចាស់ដ៏មហាសប្បុរសដែរឬទេ?"
  43,46,"ហើយជាការពិតណាស់ យើងបានបញ្ជូនព្យាការីមូសាដោយនាំមកនូវសញ្ញាភស្តុតាងទាំងឡាយរបស់យើងទៅកាន់ហ្វៀរអោននិងមន្ត្រីទាំងឡាយរបស់គេ ដោយគាត់(ព្យាការីមូសា)បាននិយាយថា៖ ពិតប្រាកដណាស់ ខ្ញុំគឺជាអ្នកនាំសាររបស់ព្រះជាម្ចាស់នៃពិភពទាំងឡាយ។"
  43,47,"តែនៅពេលដែលគាត់បាននាំមកនូវសញ្ញាភស្តុតាងជាច្រើនរបស់យើងទៅកាន់ពួកគេ ស្រាប់តែពួកគេបែរជាសើចចំអកឡកឡឺយចំពោះវាទៅវិញ។"
  43,48,"ហើយយើង(អល់ឡោះ)មិនបានបង្ហាញឲ្យពួកគេបានឃើញនូវសញ្ញាភស្តុតាងណាមួយឡើយ លើកលែងតែសញ្ញាភស្តុតាងនោះមានលក្ខណៈធំធេងជាងសញ្ញាភស្តុតាងមុនៗ។ ហើយយើងបានដាក់ទណ្ឌកម្មពួកគេ(ក្នុងលោកិយ) សង្ឃឹមថាពួកគេនឹងវិលត្រឡប់។"
  43,49,"ហើយពួកគេបាននិយាយ(ទៅកាន់ព្យាការីមូសា)ថា៖ ឱគ្រូមន្តអាគម! សូមអ្នកបួងសួងសុំពីព្រះជាម្ចាស់របស់អ្នកនូវអ្វីដែលទ្រង់បានសន្យានឹងអ្នក(ថានឹងដកយកទណ្ឌកម្មពីពួកយើង)។ ពិតប្រាកដណាស់ ពួកយើងពិតជាអ្នកដែលទទួលបានការចង្អុលបង្ហាញជាមិនខាន។"
  43,50,"តែនៅពេលដែលយើងបានដកយកនូវទណ្ឌកម្មចេញពីពួកគេ ស្រាប់តែពួកគេបែរជាក្បត់(សម្តីខ្លួនឯង)ទៅវិញ។"
  43,51,"ហើយហ្វៀរអោនបានស្រែកប្រកាសនៅក្នុងក្រុមរបស់គេដោយពោលថា៖ ឱក្រុមរបស់យើង! តើយើងមិនមែនជាស្តេចគ្រប់គ្រងប្រទេសអេហ្ស៊ីប ហើយទន្លេទាំងនេះហូរកាត់ពីក្រោមយើងទេឬ? តើពួកអ្នកមិនបានឃើញទេឬ?"
  43,52,"ផ្ទុយទៅវិញ យើងល្អប្រសើរជាងបុគ្គលម្នាក់នេះ(ព្យាការីមូសា)ដែលជាមនុស្សទន់ខ្សោយ ហើយនិយាយមិនទាំងសូវច្បាស់ផងនោះ។"
  43,53,"ដូចនេះ ហេតុអ្វីបានជាគេមិនបំពាក់កងដៃអំពីមាសទៅឱ្យរូបគេ ឬឱ្យម៉ាឡាអ៊ីកាត់រួមដំណើរមកជាមួយគេទៅ។"
  43,54,"ហ្វៀរអោនបានធ្វើឲ្យក្រុមរបស់គេឡប់សតិ។ ដូច្នេះ ពួកគេក៏បានគោរពតាមគេ។ ពិតប្រាកដណាស់ ពួកគេធ្លាប់ជាក្រុមដែលប្រព្រឹត្តល្មើស។"
  43,55,"ហើយនៅពេលដែលពួកគេធ្វើឱ្យយើងខឹងសម្បា យើងក៏បានផ្តន្ទាទោសពួកគេដោយឱ្យពួកគេទាំងអស់គ្នាលិចលង់(ក្នុងសមុទ្រ)។"
  43,56,"ហើយយើងបានយកពួកគេធ្វើជាគំរូសម្រាប់អ្នកជំនាន់មុន និងជាមេរៀនសម្រាប់អ្នកផ្សេងទៀត។"
  43,57,"នៅពេលដែលគេបានលើកយកកូនប្រុសរបស់ម៉ារយ៉ាំ(ព្យាការីអ៊ីសា)ធ្វើជាឧទាហរណ៍ ស្រាប់តែក្រុមរបស់អ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)នាំគ្នាស្រែកហ៊ោកញ្ជ្រៀវ។"
  43,58,"ហើយពួកគេនិយាយថា៖ តើព្រះទាំងឡាយរបស់ពួកយើងល្អជាង ឬគាត់(ព្យាការីអ៊ីសា)ល្អជាង? អ្វីដែលពួកគេលើកយកគាត់មកប្រៀបធៀបសម្រាប់អ្នកបែបនេះ គឺគ្មានអ្វីក្រៅពីការប្រកែកដេញដោលនោះឡើយ។ ផ្ទុយទៅវិញ ពួកគេគឺជាក្រុមដែល(ចូលចិត្ត)ឈ្លោះប្រកែក។"
  43,59,"រូបគេ(ព្យាការីអ៊ីសា) គ្មានអ្វីក្រៅតែពីជាខ្ញុំបម្រើម្នាក់ដែលយើងបានប្រទានឧបការគុណដល់គេ និងបានយកគេជាមេរៀនសម្រាប់អម្បូរអ៊ីស្រាអែលឡើយ។"
  43,60,"ហើយប្រសិនបើយើងមានចេតនា ហើយយើងនឹងបង្កើតម៉ាឡាអ៊ីកាត់ឱ្យគ្រប់គ្រងផែនដីជំនួសពួកអ្នកជាមិនខាន។"
  43,61,"ហើយពិតប្រាកដណាស់វា(ការចុះមករបស់ព្យាការីអ៊ីសាមុនថ្ងៃបរលោកកើតឡើង) គឺពិតជាសញ្ញាមួយនៃថ្ងៃបរលោក។ ហេតុនេះ ពួកអ្នកមិនត្រូវមានការមន្ទិលសង្ស័យចំពោះវាឡើយ។ ហើយចូរពួកអ្នកប្រតិបត្តិតាមខ្ញុំ(ព្យាការីមូហាំម៉ាត់)។ នេះហើយជាមាគ៌ាដ៏ត្រឹមត្រូវ។"
  43,62,"ហើយចូរពួកអ្នកកុំឱ្យស្ហៃតនរារាំងពួកអ្នក(ពីមាគ៌ាដ៏ត្រឹមត្រូវ)ឲ្យសោះ។ ពិតប្រាកដណាស់ វាជាសត្រូវយ៉ាងច្បាស់លាស់សម្រាប់ពួកអ្នក។"
  43,63,"ហើយនៅពេលដែលព្យាការីអ៊ីសាបានមកដល់ដោយនាំមកនូវសញ្ញាភស្តុតាងយ៉ាងច្បាស់លាស់ គាត់បានពោលថា៖ ពិតប្រាកដណាស់ ខ្ញុំបាននាំមកកាន់ពួកអ្នកនូវគតិបណ្ឌិត ហើយខ្ញុំប្រាកដជានឹងបញ្ជាក់ប្រាប់ពួកអ្នកនូវរឿងរ៉ាវមួយចំនួនដែលពួកអ្នកមានការខ្វែងគំនិតគ្នាចំពោះវា។ ហេតុនេះ ចូរពួកអ្នកកោតខ្លាចអល់ឡោះ និងប្រតិបត្តិតាមខ្ញុំ។"
  43,64,"ពិតប្រាកដណាស់ អល់ឡោះ ទ្រង់គឺជាព្រះជាម្ចាស់របស់ខ្ញុំ និងជាព្រះជាម្ចាស់របស់ពួកអ្នក។ ហេតុនេះ ចូរពួកអ្នកគោរពសក្កាៈចំពោះទ្រង់(តែមួយគត់)។ នេះហើយជាមាគ៌ាដ៏ត្រឹមត្រូវ។"
  43,65,"ហើយក្រុមជាច្រើនបានខ្វែងគំនិតគ្នារវាងពួកគេ(ក្នុងរឿងព្យាការីអ៊ីសា)។ ដូច្នេះ ភាពវិនាសអន្តរាយដោយទណ្ឌកម្មនៅថ្ងៃដ៏ឈឺចាប់បំផុត គឺសម្រាប់ពួកដែលបំពាន។"
  43,66,"តើពួកទាំងនោះគ្មានរង់ចាំអ្វីក្រៅពីថ្ងៃបរលោកដែលមកដល់ពួកគេភ្លាមៗ ខណៈដែលពួកគេមិនដឹងខ្លួននោះឬ?"
  43,67,"មិត្តជិតស្និទ្ធទាំងឡាយនៅក្នុងថ្ងៃនោះ(ថ្ងៃបរលោក) នឹងក្លាយជាសត្រូវនឹងគ្នាទៅវិញទៅមក លើកលែងតែបណ្តាអ្នកដែលកោតខ្លាច(អល់ឡោះ)ប៉ុណ្ណោះ។"
  43,68,"(ទ្រង់នឹងមានបន្ទូលទៅកាន់ពួកគេថា៖) ឱខ្ញុំបម្រើទាំងឡាយរបស់យើង! គ្មានការភ័យខ្លាចអ្វីឡើយចំពោះពួកអ្នកនៅក្នុងថ្ងៃនេះ ហើយពួកអ្នកក៏គ្មានទុក្ខព្រួយអ្វីនោះដែរ។"
  43,69,"បណ្តាអ្នកដែលមានជំនឿចំពោះសញ្ញាភស្តុតាងទាំងឡាយរបស់យើង ហើយពួកគេជាអ្នកដែលប្រគល់ខ្លួននោះ"
  43,70,"(មានគេនិយាយទៅកាន់ពួកគេថា៖) ចូរពួកអ្នក និងបណ្តាអ្នកដែលមានជំនឿដូចពួកអ្នក ចូលទៅក្នុងឋានសួគ៌ដោយក្តីរីករាយចុះ។"
  43,71,"មានគេចាំបម្រើជុំវិញពួកគេជាមួយនឹងថាសអាហារ និងពែងធ្វើអំពីមាស។ នៅក្នុងឋានសួគ៌នោះមានអ្វីគ្រប់យ៉ាងតាមដែលគេប្រាថ្នា និង(គយគន់មើលយ៉ាង)គាប់នេត្រាផងដែរ។ ហើយពួកអ្នកស្ថិតនៅក្នុងឋានសួគ៌នេះជាអមតៈ។"
  43,72,"នោះហើយជាឋានសួគ៌ដែលគេបានប្រទានវាជាមរតកដល់ពួកអ្នកដោយសារតែអ្វីដែលពួកអ្នកធ្លាប់បានប្រព្រឹត្ត។"
  43,73,"នៅក្នុងឋានសួគ៌នោះ មានផ្លែឈើជាច្រើនសម្រាប់ពួកអ្នកទទួលទានអំពីវា។"
  43,74,"ពិតប្រាកដណាស់ ពួកឧក្រិដ្ឋជនទាំងឡាយ គឺស្ថិតក្នុងទណ្ឌកម្មនៃនរកជើហាន់ណាំជាអមតៈ។"
  43,75,"គេមិនបន្ធូរបន្ថយ(ទណ្ឌកម្ម)ដល់ពួកគេឡើយ ហើយពួកគេស្ថិតនៅក្នុងវាដោយក្តីអស់សង្ឃឹម។"
  43,76,"ហើយយើងមិនបានបំពានលើពួកគេឡើយ ប៉ុន្តែពួកគេទៅវិញទេដែលធ្លាប់ជាពួកបំពាននោះ។"
  43,77,"ហើយពួកគេបានស្រែកហៅ(ឆ្មាំនរក)ថា៖ ឱម៉ាលិក! សូមឱ្យព្រះជាម្ចាស់របស់អ្នកបញ្ចប់ជីវិតពួកយើងចុះ។ គេបានតបវិញថា៖ ពិតប្រាកដណាស់ ពួកអ្នកនឹងត្រូវស្ថិតនៅ(ក្នុងនរកនេះ)ជារៀងរហូត។"
  43,78,"ជាការពិតណាស់ យើងបាននាំមកកាន់ពួកអ្នកនូវសេចក្តីពិត។ ក៏ប៉ុន្តែភាគច្រើននៃពួកអ្នកមិនពេញចិត្តនឹងសេចក្តីពិតនោះឡើយ។"
  43,79,"ផ្ទុយទៅវិញ ពួកគេបានរៀបចំល្បិចកល តែយើងទៅវិញទេដែលជាអ្នករៀបចំល្បិចកល(ខ្លាំងជាងនោះ)ទៅទៀត។"
  43,80,"ឬមួយក៏ពួកគេគិតស្មានថា ជាការពិតណាស់ យើងមិនឮរឿងសម្ងាត់របស់ពួកគេ និងការខ្សឹបខ្សៀវរបស់ពួកគេឬ? មិនដូច្នោះឡើយ។ ហើយអ្នកនាំសារ(ម៉ាឡាអ៊ីកាត់)របស់យើងដែលនៅជាមួយពួកគេ គឺកំពុងតែកត់ត្រា(នូវអ្វីដែលពួកគេបានធ្វើ)។"
  43,81,"ចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)ពោលថា៖ ប្រសិនបើព្រះជាម្ចាស់ដ៏មហាសប្បុរសទ្រង់មានបុត្រ ពិតណាស់ ខ្ញុំគឺជាអ្នកដែលគោរពសក្ការៈ(ចំពោះបុត្រនោះ)ដំបូងគេបង្អស់។"
  43,82,"ព្រះជាម្ចាស់នៃមេឃជាច្រើនជាន់និងផែនដី និងជាព្រះជាម្ចាស់នៃអារ៉ស្ហនោះទ្រង់មហាស្អាតស្អំបំផុតអំពីអ្វីដែលពួកគេចោទប្រកាន់។"
  43,83,"ដូច្នេះ ចូរអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)បណ្តោយឱ្យពួកគេវង្វេង និងលេងសើចចុះ រហូតដល់ពួកគេបានជួបនឹងថ្ងៃដែលគេបានសន្យាចំពោះពួកគេ(ថ្ងៃបរលោក)។"
  43,84,"ហើយទ្រង់ជាព្រះជាម្ចាស់ដែលត្រូវគេគោរពសក្ការៈ(តែមួយគត់)នៅលើមេឃ និងជាព្រះជាម្ចាស់ដែលត្រូវគេគោរពសក្ការៈ(តែមួយគត់)នៅលើផែនដី។ ហើយទ្រង់មហាគតិបណ្ឌិត មហាដឹងបំផុត។"
  43,85,"ទ្រង់មហាឧត្តុង្គត្តមដែលការគ្រប់គ្រងមេឃជាច្រើនជាន់និងផែនដី ហើយនិងអ្វីៗដែលនៅចន្លោះរវាងវាទាំងពីរ គឺជាកម្មសិទ្ធិរបស់ទ្រង់(តែមួយគត់)។ ហើយចំណេះដឹងនៃថ្ងៃបរលោក គឺនៅឯទ្រង់។ ហើយពួកអ្នកនឹងត្រូវគេនាំត្រឡប់ទៅកាន់ទ្រង់វិញ។"
  43,86,"ហើយអ្នកដែលពួកគេកំពុងតែគោរពសក្ការៈ(ចំពោះវា)ផ្សេងពីទ្រង់នោះ គឺគ្មានអំណាចអ្វីក្នុងការជួយអន្តរាគមន៍នោះឡើយ លើកលែងតែអ្នកដែលបានធ្វើសាក្សីចំពោះការពិត ហើយពួកគេបានដឹង។"
  43,87,"ហើយប្រសិនបើអ្នកសួរពួកគេថា៖ តើនរណាជាអ្នកដែលបានបង្កើតពួកគេ ប្រាកដជាពួកគេឆ្លើយថា៖ គឺអល់ឡោះ។ ដូច្នេះ តើពួកគេត្រូវបានគេបង្វែរចេញយ៉ាងដូចម្តេច?"
  43,88,"ហើយគាត់(ព្យាការីមូហាំម៉ាត់)បានពោលទៅកាន់ទ្រង់ថា៖ បរពិត្រព្រះជាម្ចាស់! ពិតប្រាកដណាស់ ពួកទាំងនោះ គឺជាក្រុមដែលគ្មានជំនឿនោះឡើយ។"
  43,89,"ដូច្នេះ ចូរអ្នកងាកចេញពីពួកគេចុះ ហើយពោលថា៖ សាឡាម។ ពិតប្រាកដណាស់ ពួកគេគង់តែនឹងដឹងជាមិនខាន។"
