quran[8]{c,v,t}:
  99,1,"Yer titrəyib lərzəyə gələcəyi zaman;"
  99,2,"Yer öz yükünü bayıra atacağı"
  99,3,"və insan: “Ona nə olub?”– deyəcəyi zaman –"
  99,4,"həmin gün yer öz əhvalatlarını danışacaqdır."
  99,5,"Çünki Rəbbin ona vəhy edəcəkdir."
  99,6,"O gün insanlar əməllərinin onlara göstərilməsi üçün dəstə-dəstə gələcəklər."
  99,7,"Zərrə qədər yaxşılıq edən əvəzini alacaqdır."
  99,8,"Zərrə qədər pislik edən də əvəzini alacaqdır."
