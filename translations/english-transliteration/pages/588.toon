quran[28]{c,v,t}:
  83,7,"Kalla inna kitaba alfujjarilafee sijjeen"
  83,8,"Wama adraka ma sijjeen"
  83,9,"Kitabun marqoom"
  83,10,"Waylun yawma-ithin lilmukaththibeen"
  83,11,"Allatheena yukaththiboonabiyawmi addeen"
  83,12,"Wama yukaththibu bihi illakullu muAAtadin atheem"
  83,13,"Itha tutla AAalayhi ayatunaqala asateeru al-awwaleen"
  83,14,"Kalla bal rana AAalaquloobihim ma kanoo yaksiboon"
  83,15,"Kalla innahum AAan rabbihim yawma-ithinlamahjooboon"
  83,16,"Thumma innahum lasaloo aljaheem"
  83,17,"Thumma yuqalu hatha allatheekuntum bihi tukaththiboon"
  83,18,"Kalla inna kitaba al-abrarilafee AAilliyyeen"
  83,19,"Wama adraka maAAilliyyoon"
  83,20,"Kitabun marqoom"
  83,21,"Yashhaduhu almuqarraboon"
  83,22,"Inna al-abrara lafee naAAeem"
  83,23,"AAala al-ara-iki yanthuroon"
  83,24,"TaAArifu fee wujoohihim nadrata annaAAeem"
  83,25,"Yusqawna min raheeqin makhtoom"
  83,26,"Khitamuhu miskun wafee thalikafalyatanafasi almutanafisoon"
  83,27,"Wamizajuhu min tasneem"
  83,28,"AAaynan yashrabu biha almuqarraboon"
  83,29,"Inna allatheena ajramoo kanoomina allatheena amanoo yadhakoon"
  83,30,"Wa-itha marroo bihim yataghamazoon"
  83,31,"Wa-itha inqalaboo ila ahlihimuinqalaboo fakiheen"
  83,32,"Wa-itha raawhum qaloo inna haola-iladalloon"
  83,33,"Wama orsiloo AAalayhim hafitheen"
  83,34,"Falyawma allatheena amanoomina alkuffari yadhakoon"
