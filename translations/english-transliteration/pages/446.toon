quran[24]{c,v,t}:
  37,1,"Wassaffati saffa"
  37,2,"Fazzajirati zajra"
  37,3,"Fattaliyati thikra"
  37,4,"Inna ilahakum lawahid"
  37,5,"Rabbu assamawati wal-ardiwama baynahuma warabbu almashariq"
  37,6,"Inna zayyanna assamaaaddunya bizeenatin alkawakib"
  37,7,"Wahifthan min kulli shaytaninmarid"
  37,8,"La yassammaAAoona ila almala-ial-aAAla wayuqthafoona min kulli janib"
  37,9,"Duhooran walahum AAathabun wasib"
  37,10,"Illa man khatifa alkhatfatafaatbaAAahu shihabun thaqib"
  37,11,"Fastaftihim ahum ashaddu khalqan amman khalaqna inna khalaqnahum min teeninlazib"
  37,12,"Bal AAajibta wayaskharoon"
  37,13,"Wa-itha thukkiroo la yathkuroon"
  37,14,"Wa-itha raaw ayatanyastaskhiroon"
  37,15,"Waqaloo in hatha illasihrun mubeen"
  37,16,"A-itha mitna wakunnaturaban waAAithaman a-innalamabAAoothoon"
  37,17,"Awa abaona al-awwaloon"
  37,18,"Qul naAAam waantum dakhiroon"
  37,19,"Fa-innama hiya zajratun wahidatunfa-itha hum yanthuroon"
  37,20,"Waqaloo ya waylana hathayawmu addeen"
  37,21,"Hatha yawmu alfasli allatheekuntum bihi tukaththiboon"
  37,22,"Ohshuroo allatheena thalamoowaazwajahum wama kanoo yaAAbudoon"
  37,23,"Min dooni Allahi fahdoohum ilasirati aljaheem"
  37,24,"Waqifoohum innahum masooloon"
