quran[7]{c,v,t}:
  37,1,"Wassaffati saffa"
  37,2,"Fazzajirati zajra"
  37,3,"Fattaliyati thikra"
  37,4,"Inna ilahakum lawahid"
  37,5,"Rabbu assamawati wal-ardiwama baynahuma warabbu almashariq"
  37,6,"Inna zayyanna assamaaaddunya bizeenatin alkawakib"
  37,7,"Wahifthan min kulli shaytaninmarid"
  37,8,"La yassammaAAoona ila almala-ial-aAAla wayuqthafoona min kulli janib"
  37,9,"Duhooran walahum AAathabun wasib"
  37,10,"Illa man khatifa alkhatfatafaatbaAAahu shihabun thaqib"