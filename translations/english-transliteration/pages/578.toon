quran[26]{c,v,t}:
  75,20,"Kalla bal tuhibboona alAAajila"
  75,21,"Watatharoona al-akhira"
  75,22,"Wujoohun yawma-ithin nadira"
  75,23,"Ila rabbiha nathira"
  75,24,"Wawujoohun yawma-ithin basira"
  75,25,"Tathunnu an yufAAala bihafaqira"
  75,26,"Kalla itha balaghati attaraqiy"
  75,27,"Waqeela man raq"
  75,28,"Wathanna annahu alfiraq"
  75,29,"Waltaffati assaqu bilssaq"
  75,30,"Ila rabbika yawma-ithin almasaq"
  75,31,"Fala saddaqa wala salla"
  75,32,"Walakin kaththaba watawalla"
  75,33,"Thumma thahaba ila ahlihiyatamatta"
  75,34,"Awla laka faawla"
  75,35,"Thumma awla laka faawla"
  75,36,"Ayahsabu al-insanu an yutrakasuda"
  75,37,"Alam yaku nutfatan min manayyin yumna"
  75,38,"Thumma kana AAalaqatan fakhalaqafasawwa"
  75,39,"FajaAAala minhu azzawjayni aththakarawal-ontha"
  75,40,"Alaysa thalika biqadirin AAalaan yuhyiya almawta"
  76,1,"Hal ata AAala al-insani heenunmina addahri lam yakun shay-an mathkoora"
  76,2,"Inna khalaqna al-insanamin nutfatin amshajin nabtaleehi fajaAAalnahusameeAAan baseera"
  76,3,"Inna hadaynahu assabeelaimma shakiran wa-imma kafoora"
  76,4,"Inna aAAtadna lilkafireenasalasila waaghlalan wasaAAeera"
  76,5,"Inna al-abrara yashraboona min ka/sinkana mizajuha kafoora"
