quran[30]{c,v,t}:
  87,16,"Bal tu/thiroona alhayata addunya"
  87,17,"Wal-akhiratu khayrun waabqa"
  87,18,"Inna hatha lafee assuhufial-oola"
  87,19,"Suhufi ibraheema wamoosa"
  88,1,"Hal ataka hadeethu alghashiyat"
  88,2,"Wujoohun yawma-ithin khashiAAa"
  88,3,"AAamilatun nasiba"
  88,4,"Tasla naran hamiya"
  88,5,"Tusqa min AAaynin aniya"
  88,6,"Laysa lahum taAAamun illamin dareeAA"
  88,7,"La yusminu wala yughnee minjooAA"
  88,8,"Wujoohun yawma-ithin naAAima"
  88,9,"LisaAAyiha radiya"
  88,10,"Fee jannatin AAaliya"
  88,11,"La tasmaAAu feeha laghiya"
  88,12,"Feeha AAaynun jariya"
  88,13,"Feeha sururun marfooAAa"
  88,14,"Waakwabun mawdooAAa"
  88,15,"Wanamariqu masfoofa"
  88,16,"Wazarabiyyu mabthootha"
  88,17,"Afala yanthuroona ilaal-ibili kayfa khuliqat"
  88,18,"Wa-ila assama-i kayfarufiAAat"
  88,19,"Wa-ila aljibali kayfa nusibat"
  88,20,"Wa-ila al-ardi kayfa sutihat"
  88,21,"Fathakkir innama anta muthakkir"
  88,22,"Lasta AAalayhim bimusaytir"
  88,23,"Illa man tawalla wakafar"
  88,24,"FayuAAaththibuhu Allahu alAAathabaal-akbar"
  88,25,"Inna ilayna iyabahum"
  88,26,"Thumma inna AAalayna hisabahum"
