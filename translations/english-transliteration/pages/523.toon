quran[23]{c,v,t}:
  51,52,"Kathalika ma ata allatheenamin qablihim min rasoolin illa qaloo sahirunaw majnoon"
  51,53,"Atawasaw bihi bal hum qawmun taghoon"
  51,54,"Fatawalla AAanhum fama anta bimaloom"
  51,55,"Wathakkir fa-inna aththikratanfaAAu almu/mineen"
  51,56,"Wama khalaqtu aljinna wal-insailla liyaAAbudoon"
  51,57,"Ma oreedu minhum min rizqin wamaoreedu an yutAAimoon"
  51,58,"Inna Allaha huwa arrazzaquthoo alquwwati almateen"
  51,59,"Fa-inna lillatheena thalamoothanooban mithla thanoobi as-habihimfala yastaAAjiloon"
  51,60,"Fawaylun lillatheena kafaroo minyawmihimu allathee yooAAadoon"
  52,1,"Wattoor"
  52,2,"Wakitabin mastoor"
  52,3,"Fee raqqin manshoor"
  52,4,"Walbayti almaAAmoor"
  52,5,"Wassaqfi almarfooAA"
  52,6,"Walbahri almasjoor"
  52,7,"Inna AAathaba rabbika lawaqiAA"
  52,8,"Ma lahu min dafiAA"
  52,9,"Yawma tamooru assamao mawra"
  52,10,"Wataseeru aljibalu sayra"
  52,11,"Fawaylun yawma-ithin lilmukaththibeen"
  52,12,"Allatheena hum fee khawdinyalAAaboon"
  52,13,"Yawma yudaAAAAoona ila narijahannama daAAAAa"
  52,14,"Hathihi annaru allateekuntum biha tukaththiboon"
