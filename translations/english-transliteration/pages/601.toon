quran[7]{c,v,t}:
  103,1,"WalAAasr"
  103,2,"Inna al-insana lafee khusr"
  103,3,"Illa allatheena amanoowaAAamiloo assalihati watawasaw bilhaqqiwatawasaw bissabr"
  104,1,"Waylun likulli humazatin lumaza"
  104,2,"Allathee jamaAAa malanwaAAaddadah"
  104,3,"Yahsabu anna malahu akhladah"
  104,4,"Kalla layunbathanna fee alhutama"
  104,5,"Wama adraka ma alhutama"
  104,6,"Naru Allahi almooqada"
  104,7,"Allatee tattaliAAu AAalaal-af-ida"
  104,8,"lnnaha AAalayhim mu/sada"
  104,9,"Fee AAamadin mumaddada"
  105,1,"Alam tara kayfa faAAala rabbuka bi-as-habialfeel"
  105,2,"Alam yajAAal kaydahum fee tadleel"
  105,3,"Waarsala AAalayhim tayran ababeel"
  105,4,"Tarmeehim bihijaratin minsijjeel"
  105,5,"FajaAAalahum kaAAasfin ma/kool"