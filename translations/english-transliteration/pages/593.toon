quran[23]{c,v,t}:
  89,1,"Walfajr"
  89,2,"Walayalin AAashr"
  89,3,"WashshafAAi walwatr"
  89,4,"Wallayli itha yasr"
  89,5,"Hal fee thalika qasamun lithee hijr"
  89,6,"Alam tara kayfa faAAala rabbuka biAAad"
  89,7,"Irama thati alAAimad"
  89,8,"Allatee lam yukhlaq mithluha fee albilad"
  89,9,"Wathamooda allatheena jaboo assakhrabilwad"
  89,10,"WafirAAawna thee al-awtad"
  89,11,"Allatheena taghaw fee albilad"
  89,12,"Faaktharoo feeha alfasad"
  89,13,"Fasabba AAalayhim rabbuka sawtaAAathab"
  89,14,"Inna rabbaka labilmirsad"
  89,15,"Faamma al-insanu itha maibtalahu rabbuhu faakramahu wanaAAAAamahu fayaqoolu rabbeeakraman"
  89,16,"Waamma itha ma ibtalahufaqadara AAalayhi rizqahu fayaqoolu rabbee ahanan"
  89,17,"Kalla bal la tukrimoonaalyateem"
  89,18,"Wala tahaddoona AAala taAAamialmiskeen"
  89,19,"Wata/kuloona atturatha aklanlamma"
  89,20,"Watuhibboona almala hubbanjamma"
  89,21,"Kalla itha dukkati al-ardudakkan dakka"
  89,22,"Wajaa rabbuka walmalaku saffansaffa"
  89,23,"Wajee-a yawma-ithin bijahannamayawma-ithin yatathakkaru al-insanu waannalahu aththikra"
