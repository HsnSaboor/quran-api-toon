quran[7]{c,v,t}:
  89,1,"Walfajr"
  89,2,"Walayalin AAashr"
  89,3,"WashshafAAi walwatr"
  89,4,"Wallayli itha yasr"
  89,5,"Hal fee thalika qasamun lithee hijr"
  89,6,"Alam tara kayfa faAAala rabbuka biAAad"
  89,7,"Irama thati alAAimad"
  89,8,"Allatee lam yukhlaq mithluha fee albilad"
  89,9,"Wathamooda allatheena jaboo assakhrabilwad"
  89,10,"WafirAAawna thee al-awtad"