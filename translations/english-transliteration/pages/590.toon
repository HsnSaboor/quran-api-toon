quran[22]{c,v,t}:
  85,1,"Wassama-i thatialburooj"
  85,2,"Walyawmi almawAAood"
  85,3,"Washahidin wamashhood"
  85,4,"Qutila as-habu alukhdood"
  85,5,"Annari thati alwaqood"
  85,6,"Ith hum AAalayha quAAood"
  85,7,"Wahum AAala ma yafAAaloona bilmu/mineenashuhood"
  85,8,"Wama naqamoo minhum illa anyu/minoo billahi alAAazeezi alhameed"
  85,9,"Allathee lahu mulku assamawatiwal-ardi wallahu AAala kullishay-in shaheed"
  85,10,"Inna allatheena fatanoo almu/mineenawalmu/minati thumma lam yatooboo falahum AAathabujahannama walahum AAathabu alhareeq"
  85,11,"Inna allatheena amanoowaAAamiloo assalihati lahum jannatuntajree min tahtiha al-anharu thalikaalfawzu alkabeer"
  85,12,"Inna batsha rabbika lashadeed"
  85,13,"Innahu huwa yubdi-o wayuAAeed"
  85,14,"Wahuwa alghafooru alwadood"
  85,15,"Thoo alAAarshi almajeed"
  85,16,"FaAAAAalun lima yureed"
  85,17,"Hal ataka hadeethu aljunood"
  85,18,"FirAAawna wathamood"
  85,19,"Bali allatheena kafaroo fee taktheeb"
  85,20,"Wallahu min wara-ihimmuheet"
  85,21,"Bal huwa qur-anun majeed"
  85,22,"Fee lawhin mahfooth"
