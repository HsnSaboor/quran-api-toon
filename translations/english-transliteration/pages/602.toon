quran[7]{c,v,t}:
  106,1,"Li-eelafi quraysh"
  106,2,"Eelafihim rihlata ashshita-iwassayf"
  106,3,"FalyaAAbudoo rabba hatha albayt"
  106,4,"Allathee atAAamahum min jooAAinwaamanahum min khawf"
  107,1,"Araayta allathee yukaththibu biddeen"
  107,2,"Fathalika allathee yaduAAAAualyateem"
  107,3,"Wala yahuddu AAalataAAami almiskeen"
  107,4,"Fawaylun lilmusalleen"
  107,5,"Allatheena hum AAan salatihimsahoon"
  107,6,"Allatheena hum yuraoon"
  107,7,"WayamnaAAoona almaAAoon"
  108,1,"Inna aAAtaynakaalkawthar"
  108,2,"Fasalli lirabbika wanhar"
  108,3,"Inna shani-aka huwa al-abtar"