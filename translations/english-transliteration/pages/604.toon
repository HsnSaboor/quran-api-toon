quran[7]{c,v,t}:
  112,1,"Qul huwa Allahu ahad"
  112,2,"Allahu assamad"
  112,3,"Lam yalid walam yoolad"
  112,4,"Walam yakun lahu kufuwan ahad"
  113,1,"Qul aAAoothu birabbi alfalaq"
  113,2,"Min sharri ma khalaq"
  113,3,"Wamin sharri ghasiqin ithawaqab"
  113,4,"Wamin sharri annaffathatifee alAAuqad"
  113,5,"Wamin sharri hasidin itha hasad"
  114,1,"Qul aAAoothu birabbi annas"
  114,2,"Maliki annas"
  114,3,"Ilahi annas"
  114,4,"Min sharri alwaswasi alkhannas"
  114,5,"Allathee yuwaswisu fee sudoori annas"
  114,6,"Mina aljinnati wannas"