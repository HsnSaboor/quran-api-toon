quran[27]{c,v,t}:
  37,127,"Fakaththaboohu fa-innahum lamuhdaroon"
  37,128,"Illa AAibada Allahialmukhlaseen"
  37,129,"Watarakna AAalayhi fee al-akhireen"
  37,130,"Salamun AAala il yaseen"
  37,131,"Inna kathalika najzee almuhsineen"
  37,132,"Innahu min AAibadinaalmu/mineen"
  37,133,"Wa-inna lootan lamina almursaleen"
  37,134,"Ith najjaynahu waahlahuajmaAAeen"
  37,135,"Illa AAajoozan fee alghabireen"
  37,136,"Thumma dammarna al-akhareen"
  37,137,"Wa-innakum latamurroona AAalayhim musbiheen"
  37,138,"Wabillayli afala taAAqiloon"
  37,139,"Wa-inna yoonusa lamina almursaleen"
  37,140,"Ith abaqa ila alfulki almashhoon"
  37,141,"Fasahama fakana mina almudhadeen"
  37,142,"Faltaqamahu alhootu wahuwamuleem"
  37,143,"Falawla annahu kana minaalmusabbiheen"
  37,144,"Lalabitha fee batnihi ilayawmi yubAAathoon"
  37,145,"Fanabathnahu bilAAara-iwahuwa saqeem"
  37,146,"Waanbatna AAalayhi shajaratan minyaqteen"
  37,147,"Waarsalnahu ila mi-ati alfinaw yazeedoon"
  37,148,"Faamanoo famattaAAnahum ilaheen"
  37,149,"Fastaftihim alirabbika albanatuwalahumu albanoon"
  37,150,"Am khalaqna almala-ikata inathanwahum shahidoon"
  37,151,"Ala innahum min ifkihim layaqooloon"
  37,152,"Walada Allahu wa-innahum lakathiboon"
  37,153,"Astafa albanati AAalaalbaneen"
