quran[29]{c,v,t}:
  70,11,"Yubassaroonahum yawaddu almujrimu lawyaftadee min AAathabi yawmi-ithin bibaneeh"
  70,12,"Wasahibatihi waakheeh"
  70,13,"Wafaseelatihi allatee tu/weeh"
  70,14,"Waman fee al-ardi jameeAAan thummayunjeeh"
  70,15,"Kalla innaha latha"
  70,16,"NazzaAAatan lishshawa"
  70,17,"TadAAoo man adbara watawalla"
  70,18,"WajamaAAa faawAAa"
  70,19,"Inna al-insana khuliqa halooAAa"
  70,20,"Itha massahu ashsharrujazooAAa"
  70,21,"Wa-itha massahu alkhayru manooAAa"
  70,22,"Illa almusalleen"
  70,23,"Allatheena hum AAala salatihimda-imoon"
  70,24,"Wallatheena fee amwalihimhaqqun maAAloom"
  70,25,"Lissa-ili walmahroom"
  70,26,"Wallatheena yusaddiqoonabiyawmi addeen"
  70,27,"Wallatheena hum min AAathabirabbihim mushfiqoon"
  70,28,"Inna AAathaba rabbihim ghayru ma/moon"
  70,29,"Wallatheena hum lifuroojihim hafithoon"
  70,30,"Illa AAala azwajihim awma malakat aymanuhum fa-innahum ghayru maloomeen"
  70,31,"Famani ibtagha waraa thalikafaola-ika humu alAAadoon"
  70,32,"Wallatheena hum li-amanatihimwaAAahdihim raAAoon"
  70,33,"Wallatheena hum bishahadatihimqa-imoon"
  70,34,"Wallatheena hum AAala salatihimyuhafithoon"
  70,35,"Ola-ika fee jannatin mukramoon"
  70,36,"Famali allatheena kafarooqibalaka muhtiAAeen"
  70,37,"AAani alyameeni waAAani ashshimaliAAizeen"
  70,38,"AyatmaAAu kullu imri-in minhum anyudkhala jannata naAAeem"
  70,39,"Kalla inna khalaqnahummimma yaAAlamoon"
