quran[7]{c,v,t}:
  82,1,"Itha assamao infatarat"
  82,2,"Wa-itha alkawakibu intatharat"
  82,3,"Wa-itha albiharu fujjirat"
  82,4,"Wa-itha alqubooru buAAthirat"
  82,5,"AAalimat nafsun ma qaddamatwaakhkharat"
  82,6,"Ya ayyuha al-insanu magharraka birabbika alkareem"
  82,7,"Allathee khalaqaka fasawwakafaAAadalak"
  82,8,"Fee ayyi sooratin ma shaarakkabak"
  82,9,"Kalla bal tukaththiboona biddeen"
  82,10,"Wa-inna AAalaykum lahafitheen"
  83,1,"Waylun lilmutaffifeen"
  83,2,"Allatheena itha iktalooAAala annasi yastawfoon"
  83,3,"Wa-itha kaloohum aw wazanoohumyukhsiroon"
  83,4,"Ala yathunnu ola-ikaannahum mabAAoothoon"
  83,5,"Liyawmin AAatheem"
  83,6,"Yawma yaqoomu annasu lirabbialAAalameen"