quran[7]{c,v,t}:
  1,1,"Bismi Allahi arrahmani arraheem"
  1,2,"Alhamdu lillahi rabbi alAAalameen"
  1,3,"Arrahmani arraheem"
  1,4,"Maliki yawmi addeen"
  1,5,"Iyyaka naAAbudu wa-iyyaka nastaAAeen"
  1,6,"Ihdina assirata almustaqeem"
  1,7,"Sirata allatheena anAAamta AAalayhim ghayri almaghdoobi AAalayhim wala addalleen"