quran[22]{c,v,t}:
  54,28,"Wanabbi/hum anna almaa qismatunbaynahum kullu shirbin muhtadar"
  54,29,"Fanadaw sahibahum fataAAatafaAAaqar"
  54,30,"Fakayfa kana AAathabee wanuthur"
  54,31,"Inna arsalna AAalayhim sayhatanwahidatan fakanoo kahasheemi almuhtathir"
  54,32,"Walaqad yassarna alqur-ana liththikrifahal min muddakir"
  54,33,"Kaththabat qawmu lootin binnuthur"
  54,34,"Inna arsalna AAalayhim hasibanilla ala lootin najjaynahum bisahar"
  54,35,"NiAAmatan min AAindina kathalikanajzee man shakar"
  54,36,"Walaqad antharahum batshatanafatamaraw binnuthur"
  54,37,"Walaqad rawadoohu AAan dayfihifatamasna aAAyunahum fathooqoo AAathabeewanuthur"
  54,38,"Walaqad sabbahahum bukratanAAathabun mustaqirr"
  54,39,"Fathooqoo AAathabee wanuthur"
  54,40,"Walaqad yassarna alqur-ana liththikrifahal min muddakir"
  54,41,"Walaqad jaa ala firAAawna annuthur"
  54,42,"Kaththaboo bi-ayatinakulliha faakhathnahum akhthaAAazeezin muqtadir"
  54,43,"Akuffarukum khayrun min ola-ikumam lakum baraatun fee azzubur"
  54,44,"Am yaqooloona nahnu jameeAAun muntasir"
  54,45,"Sayuhzamu aljamAAu wayuwalloona addubur"
  54,46,"Bali assaAAatu mawAAiduhum wassaAAatuadha waamar"
  54,47,"Inna almujrimeena fee dalalinwasuAAur"
  54,48,"Yawma yushaboona fee annariAAala wujoohihim thooqoo massa saqar"
  54,49,"Inna kulla shay-in khalaqnahubiqadar"
