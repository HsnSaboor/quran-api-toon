quran[27]{c,v,t}:
  83,35,"AAala al-ara-iki yanthuroon"
  83,36,"Hal thuwwiba alkuffaru ma kanooyafAAaloon"
  84,1,"Itha assamao inshaqqat"
  84,2,"Waathinat lirabbiha wahuqqat"
  84,3,"Wa-itha al-ardu muddat"
  84,4,"Waalqat ma feeha watakhallat"
  84,5,"Waathinat lirabbiha wahuqqat"
  84,6,"Ya ayyuha al-insanuinnaka kadihun ila rabbika kadhanfamulaqeeh"
  84,7,"Faama man ootiya kitabahubiyameenih"
  84,8,"Fasawfa yuhasabu hisabanyaseera"
  84,9,"Wayanqalibu ila ahlihi masroora"
  84,10,"Waamma man ootiya kitabahu waraathahrih"
  84,11,"Fasawfa yadAAoo thuboora"
  84,12,"Wayasla saAAeera"
  84,13,"Innahu kana fee ahlihi masroora"
  84,14,"Innahu thanna an lan yahoor"
  84,15,"Bala inna rabbahu kana bihi baseera"
  84,16,"Fala oqsimu bishshafaq"
  84,17,"Wallayli wama wasaq"
  84,18,"Walqamari itha ittasaq"
  84,19,"Latarkabunna tabaqan AAan tabaq"
  84,20,"Fama lahum la yu/minoon"
  84,21,"Wa-itha quri-a AAalayhimu alqur-anula yasjudoon"
  84,22,"Bali allatheena kafaroo yukaththiboon"
  84,23,"Wallahu aAAlamu bimayooAAoon"
  84,24,"Fabashshirhum biAAathabin aleem"
  84,25,"Illa allatheena amanoowaAAamiloo assalihati lahum ajrun ghayrumamnoon"
