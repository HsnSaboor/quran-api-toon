quran[7]{c,v,t}:
  84,1,"Itha assamao inshaqqat"
  84,2,"Waathinat lirabbiha wahuqqat"
  84,3,"Wa-itha al-ardu muddat"
  84,4,"Waalqat ma feeha watakhallat"
  84,5,"Waathinat lirabbiha wahuqqat"
  84,6,"Ya ayyuha al-insanuinnaka kadihun ila rabbika kadhanfamulaqeeh"
  84,7,"Faama man ootiya kitabahubiyameenih"
  84,8,"Fasawfa yuhasabu hisabanyaseera"
  84,9,"Wayanqalibu ila ahlihi masroora"
  84,10,"Waamma man ootiya kitabahu waraathahrih"