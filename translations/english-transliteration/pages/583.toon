quran[25]{c,v,t}:
  78,31,"Inna lilmuttaqeena mafaza"
  78,32,"Hada-iqa waaAAnaba"
  78,33,"WakawaAAiba atraba"
  78,34,"Waka/san dihaqa"
  78,35,"La yasmaAAoona feeha laghwanwala kiththaba"
  78,36,"Jazaan min rabbika AAataan hisaba"
  78,37,"Rabbi assamawati wal-ardiwama baynahuma arrahmani layamlikoona minhu khitaba"
  78,38,"Yawma yaqoomu arroohu walmala-ikatusaffan la yatakallamoona illa man athinalahu arrahmanu waqala sawaba"
  78,39,"Thalika alyawmu alhaqqu famanshaa ittakhatha ila rabbihi maaba"
  78,40,"Inna antharnakum AAathabanqareeban yawma yanthuru almaro ma qaddamatyadahu wayaqoolu alkafiru ya laytanee kuntuturaba"
  79,1,"WannaziAAati gharqa"
  79,2,"Wannashitati nashta"
  79,3,"Wassabihati sabha"
  79,4,"Fassabiqati sabqa"
  79,5,"Falmudabbirati amra"
  79,6,"Yawma tarjufu arrajifa"
  79,7,"TatbaAAuha arradifa"
  79,8,"Quloobun yawma-ithin wajifa"
  79,9,"Absaruha khashiAAa"
  79,10,"Yaqooloona a-inna lamardoodoona feealhafira"
  79,11,"A-itha kunna AAithamannakhira"
  79,12,"Qaloo tilka ithan karratun khasira"
  79,13,"Fa-innama hiya zajratun wahida"
  79,14,"Fa-itha hum bissahira"
  79,15,"Hal ataka hadeethu moosa"
