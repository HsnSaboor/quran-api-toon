quran[15]{c,v,t}:
  15,91,"Allatheena jaAAaloo alqur-anaAAideen"
  15,92,"Fawarabbika lanas-alannahum ajmaAAeen"
  15,93,"AAamma kanoo yaAAmaloon"
  15,94,"FasdaAA bima tu/maruwaaAArid AAani almushrikeen"
  15,95,"Inna kafaynaka almustahzi-een"
  15,96,"Allatheena yajAAaloona maAAa Allahiilahan akhara fasawfa yaAAlamoon"
  15,97,"Walaqad naAAlamu annaka yadeequ sadrukabima yaqooloon"
  15,98,"Fasabbih bihamdi rabbika wakunmina assajideen"
  15,99,"WaAAbud rabbaka hattaya/tiyaka alyaqeen"
  16,1,"Ata amru Allahi falatastaAAjiloohu subhanahu wataAAala AAammayushrikoon"
  16,2,"Yunazzilu almala-ikata birroohimin amrihi AAala man yashao min AAibadihi ananthiroo annahu la ilaha illa anafattaqoon"
  16,3,"Khalaqa assamawati wal-ardabilhaqqi taAAala AAammayushrikoon"
  16,4,"Khalaqa al-insana min nutfatinfa-itha huwa khaseemun mubeen"
  16,5,"Wal-anAAama khalaqahalakum feeha dif-on wamanafiAAu waminhata-kuloon"
  16,6,"Walakum feeha jamalun heenatureehoona waheena tasrahoon"
