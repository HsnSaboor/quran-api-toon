quran[32]{c,v,t}:
  86,1,"Wassama-i wattariq"
  86,2,"Wama adraka ma attariq"
  86,3,"Annajmu aththaqib"
  86,4,"In kullu nafsin lamma AAalayha hafith"
  86,5,"Falyanthuri al-insanumimma khuliq"
  86,6,"Khuliqa min ma-in dafiq"
  86,7,"Yakhruju min bayni assulbi wattara-ib"
  86,8,"Innahu AAala rajAAihi laqadir"
  86,9,"Yawma tubla assara-ir"
  86,10,"Fama lahu min quwwatin wala nasir"
  86,11,"Wassama-i thati arrajAA"
  86,12,"Wal-ardi thati assadAA"
  86,13,"Innahu laqawlun fasl"
  86,14,"Wama huwa bilhazl"
  86,15,"Innahum yakeedoona kayda"
  86,16,"Waakeedu kayda"
  86,17,"Famahhili alkafireena amhilhum ruwayda"
  87,1,"Sabbihi isma rabbika al-aAAla"
  87,2,"Allathee khalaqa fasawwa"
  87,3,"Wallathee qaddara fahada"
  87,4,"Wallathee akhraja almarAAa"
  87,5,"FajaAAalahu ghuthaan ahwa"
  87,6,"Sanuqri-oka fala tansa"
  87,7,"Illa ma shaa Allahuinnahu yaAAlamu aljahra wama yakhfa"
  87,8,"Wanuyassiruka lilyusra"
  87,9,"Fathakkir in nafaAAati aththikra"
  87,10,"Sayaththakkaru man yakhsha"
  87,11,"Wayatajannabuha al-ashqa"
  87,12,"Allathee yasla annaraalkubra"
  87,13,"Thumma la yamootu feeha walayahya"
  87,14,"Qad aflaha man tazakka"
  87,15,"Wathakara isma rabbihi fasalla"
