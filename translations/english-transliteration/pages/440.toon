quran[7]{c,v,t}:
  36,1,"Ya-seen"
  36,2,"Walqur-ani alhakeem"
  36,3,"Innaka lamina almursaleen"
  36,4,"AAala siratin mustaqeem"
  36,5,"Tanzeela alAAazeezi arraheem"
  36,6,"Litunthira qawman ma onthiraabaohum fahum ghafiloon"
  36,7,"Laqad haqqa alqawlu AAalaaktharihim fahum la yu/minoon"
  36,8,"Inna jaAAalna fee aAAnaqihimaghlalan fahiya ila al-athqani fahummuqmahoon"
  36,9,"WajaAAalna min bayni aydeehim saddanwamin khalfihim saddan faaghshaynahum fahum la yubsiroon"
  36,10,"Wasawaon AAalayhim aanthartahumam lam tunthirhum la yu/minoon"