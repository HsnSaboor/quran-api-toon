quran[27]{c,v,t}:
  68,16,"Sanasimuhu AAala alkhurtoom"
  68,17,"Inna balawnahum kamabalawna as-haba aljannati ith aqsamoolayasrimunnaha musbiheen"
  68,18,"Wala yastathnoon"
  68,19,"Fatafa AAalayha ta-ifunmin rabbika wahum na-imoon"
  68,20,"Faasbahat kassareem"
  68,21,"Fatanadaw musbiheen"
  68,22,"Ani ighdoo AAala harthikum inkuntum sarimeen"
  68,23,"Fantalaqoo wahum yatakhafatoon"
  68,24,"An la yadkhulannaha alyawmaAAalaykum miskeen"
  68,25,"Waghadaw AAala hardin qadireen"
  68,26,"Falamma raawha qalooinna ladalloon"
  68,27,"Bal nahnu mahroomoon"
  68,28,"Qala awsatuhum alam aqul lakumlawla tusabbihoon"
  68,29,"Qaloo subhana rabbinainna kunna thalimeen"
  68,30,"Faaqbala baAAduhum AAala baAAdinyatalawamoon"
  68,31,"Qaloo ya waylana innakunna tagheen"
  68,32,"AAasa rabbuna an yubdilanakhayran minha inna ila rabbina raghiboon"
  68,33,"Kathalika alAAathabu walaAAathabual-akhirati akbaru law kanoo yaAAlamoon"
  68,34,"Inna lilmuttaqeena AAinda rabbihim jannatiannaAAeem"
  68,35,"AfanajAAalu almuslimeena kalmujrimeen"
  68,36,"Ma lakum kayfa tahkumoon"
  68,37,"Am lakum kitabun feehi tadrusoon"
  68,38,"Inna lakum feehi lama takhayyaroon"
  68,39,"Am lakum aymanun AAalayna balighatunila yawmi alqiyamati inna lakum lama tahkumoon"
  68,40,"Salhum ayyuhum bithalika zaAAeem"
  68,41,"Am lahum shurakao falya/too bishuraka-ihimin kanoo sadiqeen"
  68,42,"Yawma yukshafu AAan saqin wayudAAawnaila assujoodi fala yastateeAAoon"
