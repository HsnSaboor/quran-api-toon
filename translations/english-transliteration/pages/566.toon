quran[7]{c,v,t}:
  69,1,"Alhaqqa"
  69,2,"Ma alhaqqa"
  69,3,"Wama adraka ma alhaqqa"
  69,4,"Kaththabat thamoodu waAAadun bilqariAAa"
  69,5,"Faamma thamoodu faohlikoo bittaghiya"
  69,6,"Waamma AAadun faohlikoo bireehinsarsarin AAatiya"
  69,7,"Sakhkharaha AAalayhim sabAAa layalinwathamaniyata ayyamin husooman fataraalqawma feeha sarAAa kaannahum aAAjazunakhlin khawiya"
  69,8,"Fahal tara lahum min baqiya"