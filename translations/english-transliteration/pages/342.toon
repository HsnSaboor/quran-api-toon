quran[17]{c,v,t}:
  23,1,"Qad aflaha almu/minoon"
  23,2,"Allatheena hum fee salatihimkhashiAAoon"
  23,3,"Wallatheena hum AAani allaghwimuAAridoon"
  23,4,"Wallatheena hum lizzakatifaAAiloon"
  23,5,"Wallatheena hum lifuroojihim hafithoon"
  23,6,"Illa AAala azwajihim awma malakat aymanuhum fa-innahum ghayru maloomeen"
  23,7,"Famani ibtagha waraa thalikafaola-ika humu alAAadoon"
  23,8,"Wallatheena hum li-amanatihimwaAAahdihim raAAoon"
  23,9,"Wallatheena hum AAala salawatihimyuhafithoon"
  23,10,"Ola-ika humu alwarithoon"
  23,11,"Allatheena yarithoona alfirdawsa humfeeha khalidoon"
  23,12,"Walaqad khalaqna al-insana minsulalatin min teen"
  23,13,"Thumma jaAAalnahu nutfatan feeqararin makeen"
  23,14,"Thumma khalaqna annutfataAAalaqatan fakhalaqna alAAalaqata mudghatanfakhalaqna almudghata AAithamanfakasawna alAAithama lahmanthumma ansha/nahu khalqan akhara fatabarakaAllahu ahsanu alkhaliqeen"
  23,15,"Thumma innakum baAAda thalikalamayyitoon"
  23,16,"Thumma innakum yawma alqiyamatitubAAathoon"
  23,17,"Walaqad khalaqna fawqakum sabAAa tara-iqawama kunna AAani alkhalqi ghafileen"
