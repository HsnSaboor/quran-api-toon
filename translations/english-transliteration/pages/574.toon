quran[19]{c,v,t}:
  73,1,"Ya ayyuha almuzzammil"
  73,2,"Qumi allayla illa qaleela"
  73,3,"Nisfahu awi onqus minhu qaleela"
  73,4,"Aw zid AAalayhi warattili alqur-anatarteela"
  73,5,"Inna sanulqee AAalayka qawlan thaqeela"
  73,6,"Inna nashi-ata allayli hiya ashaddu wat-anwaaqwamu qeela"
  73,7,"Inna laka fee annahari sabhantaweela"
  73,8,"Wathkuri isma rabbikawatabattal ilayhi tabteela"
  73,9,"Rabbu almashriqi walmaghribi lailaha illa huwa fattakhithhu wakeela"
  73,10,"Wasbir AAala mayaqooloona wahjurhum hajran jameela"
  73,11,"Watharnee walmukaththibeenaolee annaAAmati wamahhilhum qaleela"
  73,12,"Inna ladayna ankalan wajaheema"
  73,13,"WataAAaman tha ghussatinwaAAathaban aleema"
  73,14,"Yawma tarjufu al-ardu waljibaluwakanati aljibalu katheeban maheela"
  73,15,"Inna arsalna ilaykum rasoolanshahidan AAalaykum kama arsalna ilafirAAawna rasoola"
  73,16,"FaAAasa firAAawnu arrasoolafaakhathnahu akhthan wabeela"
  73,17,"Fakayfa tattaqoona in kafartum yawmanyajAAalu alwildana sheeba"
  73,18,"Assamao munfatirunbihi kana waAAduhu mafAAoola"
  73,19,"Inna hathihi tathkiratun famanshaa ittakhatha ila rabbihi sabeela"
