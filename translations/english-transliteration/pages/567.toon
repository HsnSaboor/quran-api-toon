quran[26]{c,v,t}:
  69,9,"Wajaa firAAawnu waman qablahu walmu/tafikatubilkhati-a"
  69,10,"FaAAasaw rasoola rabbihim faakhathahumakhthatan rabiya"
  69,11,"Inna lamma taghaalmao hamalnakum fee aljariya"
  69,12,"LinajAAalaha lakum tathkiratanwataAAiyaha othunun waAAiya"
  69,13,"Fa-itha nufikha fee assoorinafkhatun wahida"
  69,14,"Wahumilati al-ardu waljibalufadukkata dakkatan wahida"
  69,15,"Fayawma-ithin waqaAAati alwaqiAAa"
  69,16,"Wanshaqqati assamaofahiya yawma-ithin wahiya"
  69,17,"Walmalaku AAala arja-ihawayahmilu AAarsha rabbika fawqahum yawma-ithin thamaniya"
  69,18,"Yawma-ithin tuAAradoona latakhfa minkum khafiya"
  69,19,"Faamma man ootiya kitabahubiyameenihi fayaqoolu haomu iqraoo kitabiyah"
  69,20,"Innee thanantu annee mulaqinhisabiyah"
  69,21,"Fahuwa fee AAeeshatin radiya"
  69,22,"Fee jannatin AAaliya"
  69,23,"Qutoofuha daniya"
  69,24,"Kuloo washraboo hanee-an bimaaslaftum fee al-ayyami alkhaliya"
  69,25,"Waamma man ootiya kitabahubishimalihi fayaqoolu ya laytanee lam oota kitabiyah"
  69,26,"Walam adri ma hisabiyah"
  69,27,"Ya laytaha kanati alqadiya"
  69,28,"Ma aghna AAannee maliyah"
  69,29,"Halaka AAannee sultaniyah"
  69,30,"Khuthoohu faghullooh"
  69,31,"Thumma aljaheema sallooh"
  69,32,"Thumma fee silsilatin tharAAuhasabAAoona thiraAAan faslukooh"
  69,33,"Innahu kana la yu/minu billahialAAatheem"
  69,34,"Wala yahuddu AAalataAAami almiskeen"
