quran[24]{c,v,t}:
  26,160,"Kaththabat qawmu lootinalmursaleen"
  26,161,"Ith qala lahum akhoohum lootunala tattaqoon"
  26,162,"Innee lakum rasoolun ameen"
  26,163,"Fattaqoo Allaha waateeAAoon"
  26,164,"Wama as-alukum AAalayhi min ajrin inajriya illa AAala rabbi alAAalameen"
  26,165,"Ata/toona aththukranamina alAAalameen"
  26,166,"Watatharoona ma khalaqa lakumrabbukum min azwajikum bal antum qawmun AAadoon"
  26,167,"Qaloo la-in lam tantahi yalootu latakoonanna mina almukhrajeen"
  26,168,"Qala innee liAAamalikum mina alqaleen"
  26,169,"Rabbi najjinee waahlee mimmayaAAmaloon"
  26,170,"Fanajjaynahu waahlahu ajmaAAeen"
  26,171,"Illa AAajoozan fee alghabireen"
  26,172,"Thumma dammarna al-akhareen"
  26,173,"Waamtarna AAalayhim mataranfasaa mataru almunthareen"
  26,174,"Inna fee thalika laayatan wamakana aktharuhum mu/mineen"
  26,175,"Wa-inna rabbaka lahuwa alAAazeezu arraheem"
  26,176,"Kaththaba as-habual-aykati almursaleen"
  26,177,"Ith qala lahum shuAAaybun alatattaqoon"
  26,178,"Innee lakum rasoolun ameen"
  26,179,"Fattaqoo Allaha waateeAAoon"
  26,180,"Wama as-alukum AAalayhi min ajrin inajriya illa AAala rabbi alAAalameen"
  26,181,"Awfoo alkayla wala takoonoo minaalmukhsireen"
  26,182,"Wazinoo bilqistasialmustaqeem"
  26,183,"Wala tabkhasoo annasaashyaahum wala taAAthaw fee al-ardimufsideen"
