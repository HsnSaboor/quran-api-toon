quran[28]{c,v,t}:
  26,84,"WajAAal lee lisana sidqinfee al-akhireen"
  26,85,"WajAAalnee min warathati jannati annaAAeem"
  26,86,"Waghfir li-abee innahu kanamina addalleen"
  26,87,"Wala tukhzinee yawma yubAAathoon"
  26,88,"Yawma la yanfaAAu malun walabanoon"
  26,89,"Illa man ata Allahabiqalbin saleem"
  26,90,"Waozlifati aljannatu lilmuttaqeen"
  26,91,"Waburrizati aljaheemu lilghaween"
  26,92,"Waqeela lahum ayna ma kuntumtaAAbudoon"
  26,93,"Min dooni Allahi hal yansuroonakumaw yantasiroon"
  26,94,"Fakubkiboo feeha hum walghawoon"
  26,95,"Wajunoodu ibleesa ajmaAAoon"
  26,96,"Qaloo wahum feeha yakhtasimoon"
  26,97,"Tallahi in kunna lafeedalalin mubeen"
  26,98,"Ith nusawweekum birabbi alAAalameen"
  26,99,"Wama adallana illaalmujrimoon"
  26,100,"Fama lana min shafiAAeen"
  26,101,"Wala sadeeqin hameem"
  26,102,"Falaw anna lana karratan fanakoonamina almu/mineen"
  26,103,"Inna fee thalika laayatan wamakana aktharuhum mu/mineen"
  26,104,"Wa-inna rabbaka lahuwa alAAazeezu arraheem"
  26,105,"Kaththabat qawmu noohinalmursaleen"
  26,106,"Ith qala lahum akhoohum noohunala tattaqoon"
  26,107,"Innee lakum rasoolun ameen"
  26,108,"Fattaqoo Allaha waateeAAoon"
  26,109,"Wama as-alukum AAalayhi min ajrin inajriya illa AAala rabbi alAAalameen"
  26,110,"Fattaqoo Allaha waateeAAoon"
  26,111,"Qaloo anu/minu laka wattabaAAakaal-arthaloon"
