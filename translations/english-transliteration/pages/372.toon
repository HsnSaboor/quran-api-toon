quran[25]{c,v,t}:
  26,112,"Qala wama AAilmee bimakanoo yaAAmaloon"
  26,113,"In hisabuhum illa AAalarabbee law tashAAuroon"
  26,114,"Wama ana bitaridialmu/mineen"
  26,115,"In ana illa natheerunmubeen"
  26,116,"Qaloo la-in lam tantahi yanoohu latakoonanna mina almarjoomeen"
  26,117,"Qala rabbi inna qawmee kaththaboon"
  26,118,"Faftah baynee wabaynahum fathanwanajjinee waman maAAiya mina almu/mineen"
  26,119,"Faanjaynahu waman maAAahu feealfulki almashhoon"
  26,120,"Thumma aghraqna baAAdu albaqeen"
  26,121,"Inna fee thalika laayatan wamakana aktharuhum mu/mineen"
  26,122,"Wa-inna rabbaka lahuwa alAAazeezu arraheem"
  26,123,"Kaththabat AAadun almursaleen"
  26,124,"Ith qala lahum akhoohumhoodun ala tattaqoon"
  26,125,"Innee lakum rasoolun ameen"
  26,126,"Fattaqoo Allaha waateeAAoon"
  26,127,"Wama as-alukum AAalayhi min ajrin inajriya illa AAala rabbi alAAalameen"
  26,128,"Atabnoona bikulli reeAAin ayatantaAAbathoon"
  26,129,"Watattakhithoona masaniAAalaAAallakum takhludoon"
  26,130,"Wa-itha batashtum batashtumjabbareen"
  26,131,"Fattaqoo Allaha waateeAAoon"
  26,132,"Wattaqoo allathee amaddakumbima taAAlamoon"
  26,133,"Amaddakum bi-anAAamin wabaneen"
  26,134,"Wajannatin waAAuyoon"
  26,135,"Innee akhafu AAalaykum AAathabayawmin AAatheem"
  26,136,"Qaloo sawaon AAalaynaawaAAathta am lam takun mina alwaAAitheen"
