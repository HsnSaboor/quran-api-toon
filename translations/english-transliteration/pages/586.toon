quran[29]{c,v,t}:
  81,1,"Itha ashshamsu kuwwirat"
  81,2,"Wa-itha annujoomu inkadarat"
  81,3,"Wa-itha aljibalu suyyirat"
  81,4,"Wa-itha alAAisharu AAuttilat"
  81,5,"Wa-itha alwuhooshu hushirat"
  81,6,"Wa-itha albiharu sujjirat"
  81,7,"Wa-itha annufoosu zuwwijat"
  81,8,"Wa-itha almawoodatu su-ilat"
  81,9,"Bi-ayyi thanbin qutilat"
  81,10,"Wa-itha assuhufunushirat"
  81,11,"Wa-itha assamao kushitat"
  81,12,"Wa-itha aljaheemu suAAAAirat"
  81,13,"Wa-itha aljannatu ozlifat"
  81,14,"AAalimat nafsun ma ahdarat"
  81,15,"Fala oqsimu bilkhunnas"
  81,16,"Aljawari alkunnas"
  81,17,"Wallayli itha AAasAAas"
  81,18,"Wassubhi ithatanaffas"
  81,19,"Innahu laqawlu rasoolin kareem"
  81,20,"Thee quwwatin AAinda theealAAarshi makeen"
  81,21,"MutaAAin thamma ameen"
  81,22,"Wama sahibukum bimajnoon"
  81,23,"Walaqad raahu bilofuqialmubeen"
  81,24,"Wama huwa AAala alghaybi bidaneen"
  81,25,"Wama huwa biqawli shaytaninrajeem"
  81,26,"Faayna tathhaboon"
  81,27,"In huwa illa thikrun lilAAalameen"
  81,28,"Liman shaa minkum an yastaqeem"
  81,29,"Wama tashaoona illa anyashaa Allahu rabbu alAAalameen"
