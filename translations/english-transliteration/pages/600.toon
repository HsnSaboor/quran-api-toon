quran[7]{c,v,t}:
  100,10,"Wahussila ma fee assudoor"
  101,1,"AlqariAAa"
  101,2,"Ma alqariAAa"
  101,3,"Wama adraka ma alqariAAa"
  101,4,"Yawma yakoonu annasu kalfarashialmabthooth"
  101,5,"Watakoonu aljibalu kalAAihnialmanfoosh"
  101,6,"Faamma man thaqulat mawazeenuh"
  101,7,"Fahuwa fee AAeeshatin radiya"
  101,8,"Waamma man khaffat mawazeenuh"
  101,9,"Faommuhu hawiya"
  101,10,"Wama adraka ma hiya"
  102,1,"Alhakumu attakathur"
  102,2,"Hatta zurtumu almaqabir"
  102,3,"Kalla sawfa taAAlamoon"
  102,4,"Thumma kalla sawfa taAAlamoon"
  102,5,"Kalla law taAAlamoona AAilma alyaqeen"
  102,6,"Latarawunna aljaheem"
  102,7,"Thumma latarawunnaha AAayna alyaqeen"
  102,8,"Thumma latus-alunna yawma-ithin AAaniannaAAeem"