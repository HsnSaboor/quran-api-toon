quran[31]{c,v,t}:
  77,20,"Alam nakhluqkum min ma-in maheen"
  77,21,"FajaAAalnahu fee qararinmakeen"
  77,22,"Ila qadarin maAAloom"
  77,23,"Faqadarna faniAAma alqadiroon"
  77,24,"Waylun yawma-ithin lilmukaththibeen"
  77,25,"Alam najAAali al-arda kifata"
  77,26,"Ahyaan waamwata"
  77,27,"WajaAAalna feeha rawasiyashamikhatin waasqaynakum maan furata"
  77,28,"Waylun yawma-ithin lilmukaththibeen"
  77,29,"Intaliqoo ila ma kuntumbihi tukaththiboon"
  77,30,"Intaliqoo ila thillinthee thalathi shuAAab"
  77,31,"La thaleelin walayughnee mina allahab"
  77,32,"Innaha tarmee bishararin kalqasr"
  77,33,"Kaannahu jimalatun sufr"
  77,34,"Waylun yawma-ithin lilmukaththibeen"
  77,35,"Hatha yawmu la yantiqoon"
  77,36,"Wala yu/thanu lahum fayaAAtathiroon"
  77,37,"Waylun yawma-ithin lilmukaththibeen"
  77,38,"Hatha yawmu alfasli jamaAAnakumwal-awwaleen"
  77,39,"Fa-in kana lakum kaydun fakeedoon"
  77,40,"Waylun yawma-ithin lilmukaththibeen"
  77,41,"Inna almuttaqeena fee thilalinwaAAuyoon"
  77,42,"Wafawakiha mimma yashtahoon"
  77,43,"Kuloo washraboo hanee-an bimakuntum taAAmaloon"
  77,44,"Inna kathalika najzee almuhsineen"
  77,45,"Waylun yawma-ithin lilmukaththibeen"
  77,46,"Kuloo watamattaAAoo qaleelan innakummujrimoon"
  77,47,"Waylun yawma-ithin lilmukaththibeen"
  77,48,"Wa-itha qeela lahumu irkaAAoo layarkaAAoon"
  77,49,"Waylun yawma-ithin lilmukaththibeen"
  77,50,"Fabi-ayyi hadeethin baAAdahuyu/minoon"
