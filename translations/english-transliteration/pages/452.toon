quran[29]{c,v,t}:
  37,154,"Ma lakum kayfa tahkumoon"
  37,155,"Afala tathakkaroon"
  37,156,"Am lakum sultanun mubeen"
  37,157,"Fa/too bikitabikum in kuntum sadiqeen"
  37,158,"WajaAAaloo baynahu wabayna aljinnatinasaban walaqad AAalimati aljinnatu innahum lamuhdaroon"
  37,159,"Subhana Allahi AAammayasifoon"
  37,160,"Illa AAibada Allahialmukhlaseen"
  37,161,"Fa-innakum wama taAAbudoon"
  37,162,"Ma antum AAalayhi bifatineen"
  37,163,"Illa man huwa sali aljaheem"
  37,164,"Wama minna illa lahumaqamun maAAloom"
  37,165,"Wa-inna lanahnu assaffoon"
  37,166,"Wa-inna lanahnu almusabbihoon"
  37,167,"Wa-in kanoo layaqooloon"
  37,168,"Law anna AAindana thikranmina al-awwaleen"
  37,169,"Lakunna AAibada Allahialmukhlaseen"
  37,170,"Fakafaroo bihi fasawfa yaAAlamoon"
  37,171,"Walaqad sabaqat kalimatuna liAAibadinaalmursaleen"
  37,172,"Innahum lahumu almansooroon"
  37,173,"Wa-inna jundana lahumu alghaliboon"
  37,174,"Fatawalla AAanhum hatta heen"
  37,175,"Waabsirhum fasawfa yubsiroon"
  37,176,"AfabiAAathabina yastaAAjiloon"
  37,177,"Fa-itha nazala bisahatihimfasaa sabahu almunthareen"
  37,178,"Watawalla AAanhum hatta heen"
  37,179,"Waabsir fasawfa yubsiroon"
  37,180,"Subhana rabbika rabbi alAAizzatiAAamma yasifoon"
  37,181,"Wasalamun AAala almursaleen"
  37,182,"Walhamdu lillahirabbi alAAalameen"
