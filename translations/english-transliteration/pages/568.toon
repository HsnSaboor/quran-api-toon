quran[28]{c,v,t}:
  69,35,"Falaysa lahu alyawma hahuna hameem"
  69,36,"Wala taAAamun illamin ghisleen"
  69,37,"La ya/kuluhu illa alkhati-oon"
  69,38,"Fala oqsimu bima tubsiroon"
  69,39,"Wama la tubsiroon"
  69,40,"Innahu laqawlu rasoolin kareem"
  69,41,"Wama huwa biqawli shaAAirinqaleelan ma tu/minoon"
  69,42,"Wala biqawli kahinin qaleelanma tathakkaroon"
  69,43,"Tanzeelun min rabbi alAAalameen"
  69,44,"Walaw taqawwala AAalayna baAAdaal-aqaweel"
  69,45,"Laakhathna minhu bilyameen"
  69,46,"Thumma laqataAAna minhualwateen"
  69,47,"Fama minkum min ahadin AAanhu hajizeen"
  69,48,"Wa-innahu latathkiratun lilmuttaqeen"
  69,49,"Wa-inna lanaAAlamu anna minkum mukaththibeen"
  69,50,"Wa-innahu lahasratun AAala alkafireen"
  69,51,"Wa-innahu lahaqqu alyaqeen"
  69,52,"Fasabbih bismi rabbika alAAatheem"
  70,1,"Saala sa-ilun biAAathabin waqiAA"
  70,2,"Lilkafireena laysa lahu dafiAA"
  70,3,"Mina Allahi thee almaAAarij"
  70,4,"TaAAruju almala-ikatu warroohuilayhi fee yawmin kana miqdaruhu khamseena alfasana"
  70,5,"Fasbir sabran jameela"
  70,6,"Innahum yarawnahu baAAeeda"
  70,7,"Wanarahu qareeba"
  70,8,"Yawma takoonu assamao kalmuhl"
  70,9,"Watakoonu aljibalu kalAAihn"
  70,10,"Wala yas-alu hameemun hameema"
