quran[24]{c,v,t}:
  51,7,"Wassama-i thati alhubuk"
  51,8,"Innakum lafee qawlin mukhtalif"
  51,9,"Yu/faku AAanhu man ofik"
  51,10,"Qutila alkharrasoon"
  51,11,"Allatheena hum fee ghamratin sahoon"
  51,12,"Yas-aloona ayyana yawmu addeen"
  51,13,"Yawma hum AAala annariyuftanoon"
  51,14,"Thooqoo fitnatakum hatha allatheekuntum bihi tastaAAjiloon"
  51,15,"Inna almuttaqeena fee jannatinwaAAuyoon"
  51,16,"Akhitheena ma atahumrabbuhum innahum kanoo qabla thalika muhsineen"
  51,17,"Kanoo qaleelan mina allayli mayahjaAAoon"
  51,18,"Wabil-ashari humyastaghfiroon"
  51,19,"Wafee amwalihim haqqun lissa-iliwalmahroom"
  51,20,"Wafee al-ardi ayatunlilmooqineen"
  51,21,"Wafee anfusikum afala tubsiroon"
  51,22,"Wafee assama-i rizqukum wamatooAAadoon"
  51,23,"Fawarabbi assama-i wal-ardiinnahu lahaqqun mithla ma annakum tantiqoon"
  51,24,"Hal ataka hadeethu dayfiibraheema almukrameen"
  51,25,"Ith dakhaloo AAalayhi faqaloosalaman qala salamun qawmun munkaroon"
  51,26,"Faragha ila ahlihi fajaabiAAijlin sameen"
  51,27,"Faqarrabahu ilayhim qala alata/kuloon"
  51,28,"Faawjasa minhum kheefatan qaloo latakhaf wabashsharoohu bighulamin AAaleem"
  51,29,"Faaqbalati imraatuhu fee sarratin fasakkatwajhaha waqalat AAajoozun AAaqeem"
  51,30,"Qaloo kathaliki qalarabbuki innahu huwa alhakeemu alAAaleem"
