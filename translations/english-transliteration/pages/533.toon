quran[27]{c,v,t}:
  55,41,"YuAArafu almujrimoona biseemahumfayu/khathu binnawasee wal-aqdam"
  55,42,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,43,"Hathihi jahannamu allatee yukaththibubiha almujrimoon"
  55,44,"Yatoofoona baynaha wabayna hameeminan"
  55,45,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,46,"Waliman khafa maqama rabbihijannatan"
  55,47,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,48,"Thawata afnan"
  55,49,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,50,"Feehima AAaynani tajriyan"
  55,51,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,52,"Feehima min kulli fakihatinzawjan"
  55,53,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,54,"Muttaki-eena AAala furushin bata-inuhamin istabraqin wajana aljannatayni dan"
  55,55,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,56,"Feehinna qasiratu attarfilam yatmithhunna insun qablahum wala jan"
  55,57,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,58,"Kaannahunna alyaqootu walmarjan"
  55,59,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,60,"Hal jazao al-ihsani illaal-ihsan"
  55,61,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,62,"Wamin doonihima jannatan"
  55,63,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,64,"Mudhammatan"
  55,65,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,66,"Feehima AAaynani naddakhatan"
  55,67,"Fabi-ayyi ala-i rabbikumatukaththiban"
