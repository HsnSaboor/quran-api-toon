quran[27]{c,v,t}:
  89,24,"Yaqoolu ya laytanee qaddamtu lihayatee"
  89,25,"Fayawma-ithin la yuAAaththibuAAathabahu ahad"
  89,26,"Wala yoothiqu wathaqahu ahad"
  89,27,"Ya ayyatuha annafsualmutma-inna"
  89,28,"IrjiAAee ila rabbiki radiyatanmardiyya"
  89,29,"Fadkhulee fee AAibadee"
  89,30,"Wadkhulee jannatee"
  90,1,"La oqsimu bihatha albalad"
  90,2,"Waanta hillun bihatha albalad"
  90,3,"Wawalidin wama walad"
  90,4,"Laqad khalaqna al-insana feekabad"
  90,5,"Ayahsabu an lan yaqdira AAalayhi ahad"
  90,6,"Yaqoolu ahlaktu malan lubada"
  90,7,"Ayahsabu an lam yarahu ahad"
  90,8,"Alam najAAal lahu AAaynayn"
  90,9,"Walisanan washafatayn"
  90,10,"Wahadaynahu annajdayn"
  90,11,"Fala iqtahama alAAaqaba"
  90,12,"Wama adraka maalAAaqaba"
  90,13,"Fakku raqaba"
  90,14,"Aw itAAamun fee yawmin theemasghaba"
  90,15,"Yateeman tha maqraba"
  90,16,"Aw miskeenan tha matraba"
  90,17,"Thumma kana mina allatheena amanoowatawasaw bissabri watawasaw bilmarhama"
  90,18,"Ola-ika as-habualmaymana"
  90,19,"Wallatheena kafaroo bi-ayatinahum as-habu almash-ama"
  90,20,"AAalayhim narun mu/sada"
