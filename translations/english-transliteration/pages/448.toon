quran[25]{c,v,t}:
  37,52,"Yaqoolu a-innaka lamina almusaddiqeen"
  37,53,"A-itha mitna wakunnaturaban waAAithaman a-innalamadeenoon"
  37,54,"Qala hal antum muttaliAAoon"
  37,55,"FattalaAAa faraahu feesawa-i aljaheem"
  37,56,"Qala tallahi in kidtalaturdeen"
  37,57,"Walawla niAAmatu rabbee lakuntu minaalmuhdareen"
  37,58,"Afama nahnu bimayyiteen"
  37,59,"Illa mawtatana al-oolawama nahnu bimuAAaththabeen"
  37,60,"Inna hatha lahuwa alfawzu alAAatheem"
  37,61,"Limithli hatha falyaAAmali alAAamiloon"
  37,62,"Athalika khayrun nuzulan am shajaratuazzaqqoom"
  37,63,"Inna jaAAalnahafitnatan liththalimeen"
  37,64,"Innaha shajaratun takhruju fee aslialjaheem"
  37,65,"TalAAuha kaannahu ruoosu ashshayateen"
  37,66,"Fa-innahum laakiloona minhafamali-oona minha albutoon"
  37,67,"Thumma inna lahum AAalayha lashawbanmin hameem"
  37,68,"Thumma inna marjiAAahum la-ila aljaheem"
  37,69,"Innahum alfaw abaahum dalleen"
  37,70,"Fahum AAala atharihimyuhraAAoon"
  37,71,"Walaqad dalla qablahum aktharual-awwaleen"
  37,72,"Walaqad arsalna feehim munthireen"
  37,73,"Fanthur kayfa kanaAAaqibatu almunthareen"
  37,74,"Illa AAibada Allahialmukhlaseen"
  37,75,"Walaqad nadana noohunfalaniAAma almujeeboon"
  37,76,"Wanajjaynahu waahlahu mina alkarbialAAatheem"
