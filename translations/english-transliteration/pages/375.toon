quran[23]{c,v,t}:
  26,184,"Wattaqoo allathee khalaqakumwaljibillata al-awwaleen"
  26,185,"Qaloo innama anta mina almusahhareen"
  26,186,"Wama anta illa basharunmithluna wa-in nathunnuka lamina alkathibeen"
  26,187,"Faasqit AAalayna kisafan minaassama-i in kunta mina assadiqeen"
  26,188,"Qala rabbee aAAlamu bimataAAmaloon"
  26,189,"Fakaththaboohu faakhathahumAAathabu yawmi aththullati innahu kanaAAathaba yawmin AAatheem"
  26,190,"Inna fee thalika laayatan wamakana aktharuhum mu/mineen"
  26,191,"Wa-inna rabbaka lahuwa alAAazeezu arraheem"
  26,192,"Wa-innahu latanzeelu rabbi alAAalameen"
  26,193,"Nazala bihi arroohu al-ameen"
  26,194,"AAala qalbika litakoona mina almunthireen"
  26,195,"Bilisanin AAarabiyyin mubeen"
  26,196,"Wa-innahu lafee zuburi al-awwaleen"
  26,197,"Awa lam yakun lahum ayatan anyaAAlamahu AAulamao banee isra-eel"
  26,198,"Walaw nazzalnahu AAala baAAdial-aAAjameen"
  26,199,"Faqaraahu AAalayhim ma kanoobihi mu/mineen"
  26,200,"Kathalika salaknahu feequloobi almujrimeen"
  26,201,"La yu/minoona bihi hattayarawoo alAAathaba al-aleem"
  26,202,"Faya/tiyahum baghtatan wahum layashAAuroon"
  26,203,"Fayaqooloo hal nahnu muntharoon"
  26,204,"AfabiAAathabina yastaAAjiloon"
  26,205,"Afaraayta in mattaAAnahum sineen"
  26,206,"Thumma jaahum ma kanooyooAAadoon"
