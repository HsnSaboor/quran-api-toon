quran[21]{c,v,t}:
  54,7,"KhushshaAAan absaruhum yakhrujoonamina al-ajdathi kaannahum jaradun muntashir"
  54,8,"MuhtiAAeena ila addaAAiyaqoolu alkafiroona hatha yawmun AAasir"
  54,9,"Kaththabat qablahum qawmu noohinfakaththaboo AAabdana waqaloo majnoonun wazdujir"
  54,10,"FadaAAa rabbahu annee maghloobun fantasir"
  54,11,"Fafatahna abwaba assama-ibima-in munhamir"
  54,12,"Wafajjarna al-arda AAuyoonanfaltaqa almao AAala amrin qad qudir"
  54,13,"Wahamalnahu AAala thatialwahin wadusur"
  54,14,"Tajree bi-aAAyunina jazaanliman kana kufir"
  54,15,"Walaqad taraknaha ayatanfahal min muddakir"
  54,16,"Fakayfa kana AAathabee wanuthur"
  54,17,"Walaqad yassarna alqur-ana liththikrifahal min muddakir"
  54,18,"Kaththabat AAadun fakayfa kanaAAathabee wanuthur"
  54,19,"Inna arsalna AAalayhim reehansarsaran fee yawmi nahsin mustamirr"
  54,20,"TanziAAu annasa kaannahumaAAjazu nakhlin munqaAAir"
  54,21,"Fakayfa kana AAathabee wanuthur"
  54,22,"Walaqad yassarna alqur-ana liththikrifahal min muddakir"
  54,23,"Kaththabat thamoodu binnuthur"
  54,24,"Faqaloo abasharan minna wahidannattabiAAuhu inna ithan lafee dalalinwasuAAur"
  54,25,"Aolqiya aththikru AAalayhimin baynina bal huwa kaththabun ashir"
  54,26,"SayaAAlamoona ghadan mani alkaththabual-ashir"
  54,27,"Inna mursiloo annaqatifitnatan lahum fartaqibhum wastabir"
