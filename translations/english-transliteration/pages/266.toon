quran[20]{c,v,t}:
  15,71,"Qala haola-i banateein kuntum faAAileen"
  15,72,"LaAAamruka innahum lafee sakratihimyaAAmahoona"
  15,73,"Faakhathat-humu assayhatumushriqeen"
  15,74,"FajaAAalna AAaliyaha safilahawaamtarna AAalayhim hijaratan minsijjeel"
  15,75,"Inna fee thalika laayatinlilmutawassimeen"
  15,76,"Wa-innaha labisabeelin muqeem"
  15,77,"Inna fee thalika laayatanlilmu/mineen"
  15,78,"Wa-in kana as-habual-aykati lathalimeen"
  15,79,"Fantaqamna minhum wa-innahumalabi-imamin mubeen"
  15,80,"Walaqad kaththaba as-habualhijri almursaleen"
  15,81,"Waataynahum ayatinafakanoo AAanha muAArideen"
  15,82,"Wakanoo yanhitoona mina aljibalibuyootan amineen"
  15,83,"Faakhathat-humu assayhatumusbiheen"
  15,84,"Fama aghna AAanhum ma kanooyaksiboon"
  15,85,"Wama khalaqna assamawatiwal-arda wama baynahuma illabilhaqqi wa-inna assaAAata laatiyatunfasfahi assafhaaljameel"
  15,86,"Inna rabbaka huwa alkhallaqualAAaleem"
  15,87,"Walaqad ataynaka sabAAan minaalmathanee walqur-ana alAAatheem"
  15,88,"La tamuddanna AAaynayka ila mamattaAAna bihi azwajan minhum wala tahzanAAalayhim wakhfid janahaka lilmu/mineen"
  15,89,"Waqul innee ana annatheerualmubeen"
  15,90,"Kama anzalna AAalaalmuqtasimeen"
