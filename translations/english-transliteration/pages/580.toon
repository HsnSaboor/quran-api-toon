quran[25]{c,v,t}:
  76,26,"Wamina allayli fasjud lahu wasabbihhulaylan taweela"
  76,27,"Inna haola-i yuhibboonaalAAajilata wayatharoona waraahum yawmanthaqeela"
  76,28,"Nahnu khalaqnahum washadadnaasrahum wa-itha shi/na baddalna amthalahumtabdeela"
  76,29,"Inna hathihi tathkiratun famanshaa ittakhatha ila rabbihi sabeela"
  76,30,"Wama tashaoona illa anyashaa Allahu inna Allaha kanaAAaleeman hakeema"
  76,31,"Yudkhilu man yashao fee rahmatihiwaththalimeena aAAadda lahum AAathabanaleema"
  77,1,"Walmursalati AAurfa"
  77,2,"FalAAasifati AAasfa"
  77,3,"Wannashirati nashra"
  77,4,"Falfariqati farqa"
  77,5,"Falmulqiyati thikra"
  77,6,"AAuthran aw nuthra"
  77,7,"Innama tooAAadoona lawaqiAA"
  77,8,"Fa-itha annujoomu tumisat"
  77,9,"Wa-itha assamao furijat"
  77,10,"Wa-itha aljibalu nusifat"
  77,11,"Wa-itha arrusulu oqqitat"
  77,12,"Li-ayyi yawmin ojjilat"
  77,13,"Liyawmi alfasl"
  77,14,"Wama adraka ma yawmualfasl"
  77,15,"Waylun yawma-ithin lilmukaththibeen"
  77,16,"Alam nuhliki al-awwaleen"
  77,17,"Thumma nutbiAAuhumu al-akhireen"
  77,18,"Kathalika nafAAalu bilmujrimeen"
  77,19,"Waylun yawma-ithin lilmukaththibeen"
