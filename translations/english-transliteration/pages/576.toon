quran[30]{c,v,t}:
  74,18,"Innahu fakkara waqaddar"
  74,19,"Faqutila kayfa qaddar"
  74,20,"Thumma qutila kayfa qaddar"
  74,21,"Thumma nathar"
  74,22,"Thumma AAabasa wabasar"
  74,23,"Thumma adbara wastakbar"
  74,24,"Faqala in hatha illa sihrunyu/thar"
  74,25,"In hatha illa qawlu albashar"
  74,26,"Saosleehi saqar"
  74,27,"Wama adraka ma saqar"
  74,28,"La tubqee wala tathar"
  74,29,"Lawwahatun lilbashar"
  74,30,"AAalayha tisAAata AAashar"
  74,31,"Wama jaAAalna as-habaannari illa mala-ikatan wamajaAAalna AAiddatahum illa fitnatan lillatheenakafaroo liyastayqina allatheena ootoo alkitabawayazdada allatheena amanoo eemananwala yartaba allatheena ootoo alkitabawalmu/minoona waliyaqoola allatheena feequloobihim maradun walkafiroona mathaarada Allahu bihatha mathalan kathalikayudillu Allahu man yashao wayahdee man yashaowama yaAAlamu junooda rabbika illa huwa wamahiya illa thikra lilbashar"
  74,32,"Kalla walqamar"
  74,33,"Wallayli ith adbar"
  74,34,"Wassubhi ithaasfar"
  74,35,"Innaha la-ihda alkubar"
  74,36,"Natheeran lilbashar"
  74,37,"Liman shaa minkum an yataqaddama awyataakhkhar"
  74,38,"Kullu nafsin bima kasabat raheena"
  74,39,"Illa as-haba alyameen"
  74,40,"Fee jannatin yatasaaloon"
  74,41,"AAani almujrimeen"
  74,42,"Ma salakakum fee saqar"
  74,43,"Qaloo lam naku mina almusalleen"
  74,44,"Walam naku nutAAimu almiskeen"
  74,45,"Wakunna nakhoodu maAAa alkha-ideen"
  74,46,"Wakunna nukaththibu biyawmi addeen"
  74,47,"Hatta atanaalyaqeen"
