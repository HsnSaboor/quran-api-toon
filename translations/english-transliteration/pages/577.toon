quran[28]{c,v,t}:
  74,48,"Fama tanfaAAuhum shafaAAatu ashshafiAAeen"
  74,49,"Fama lahum AAani attathkiratimuAArideen"
  74,50,"Kaannahum humurun mustanfira"
  74,51,"Farrat min qaswara"
  74,52,"Bal yureedu kullu imri-in minhum an yu/tasuhufan munashshara"
  74,53,"Kalla bal la yakhafoonaal-akhira"
  74,54,"Kalla innahu tathkira"
  74,55,"Faman shaa thakarah"
  74,56,"Wama yathkuroona illaan yashaa Allahu huwa ahlu attaqwawaahlu almaghfirat"
  75,1,"La oqsimu biyawmi alqiyamat"
  75,2,"Wala oqsimu binnafsi allawwamat"
  75,3,"Ayahsabu al-insanu allannajmaAAa AAithamah"
  75,4,"Bala qadireena AAala annusawwiya bananah"
  75,5,"Bal yureedu al-insanu liyafjura amamah"
  75,6,"Yas-alu ayyana yawmu alqiyama"
  75,7,"Fa-itha bariqa albasar"
  75,8,"Wakhasafa alqamar"
  75,9,"WajumiAAa ashshamsu walqamar"
  75,10,"Yaqoolu al-insanu yawma-ithinayna almafar"
  75,11,"Kalla la wazar"
  75,12,"Ila rabbika yawma-ithinalmustaqar"
  75,13,"Yunabbao al-insanu yawma-ithinbima qaddama waakhkhar"
  75,14,"Bali al-insanu AAala nafsihibaseera"
  75,15,"Walaw alqa maAAatheerah"
  75,16,"La tuharrik bihi lisanakalitaAAjala bih"
  75,17,"Inna AAalayna jamAAahu waqur-anah"
  75,18,"Fa-itha qara/nahu fattabiAAqur-anah"
  75,19,"Thumma inna AAalayna bayanah"
