quran[42]{c,v,t}:
  80,1,"AAabasa watawalla"
  80,2,"An jaahu al-aAAma"
  80,3,"Wama yudreeka laAAallahu yazzakka"
  80,4,"Aw yaththakkaru fatanfaAAahu aththikra"
  80,5,"Amma mani istaghna"
  80,6,"Faanta lahu tasadda"
  80,7,"Wama AAalayka alla yazzakka"
  80,8,"Waamma man jaaka yasAAa"
  80,9,"Wahuwa yakhsha"
  80,10,"Faanta AAanhu talahha"
  80,11,"Kalla innaha tathkira"
  80,12,"Faman shaa thakarah"
  80,13,"Fee suhufin mukarrama"
  80,14,"MarfooAAatin mutahhara"
  80,15,"Bi-aydee safara"
  80,16,"Kiramin barara"
  80,17,"Qutila al-insanu ma akfarah"
  80,18,"Min ayyi shay-in khalaqah"
  80,19,"Min nutfatin khalaqahu faqaddarah"
  80,20,"Thumma assabeela yassarah"
  80,21,"Thumma amatahu faaqbarah"
  80,22,"Thumma itha shaa ansharah"
  80,23,"Kalla lamma yaqdi maamarah"
  80,24,"Falyanthuri al-insanuila taAAamih"
  80,25,"Anna sababna almaasabba"
  80,26,"Thumma shaqaqna al-arda shaqqa"
  80,27,"Faanbatna feeha habba"
  80,28,"WaAAinaban waqadba"
  80,29,"Wazaytoonan wanakhla"
  80,30,"Wahada-iqa ghulba"
  80,31,"Wafakihatan waabba"
  80,32,"MataAAan lakum wali-anAAamikum"
  80,33,"Fa-itha jaati assakhkha"
  80,34,"Yawma yafirru almaro min akheeh"
  80,35,"Waommihi waabeeh"
  80,36,"Wasahibatihi wabaneeh"
  80,37,"Likulli imri-in minhum yawma-ithinsha/nun yughneeh"
  80,38,"Wujoohun yawma-ithin musfira"
  80,39,"Dahikatun mustabshira"
  80,40,"Wawujoohun yawma-ithin AAalayhaghabara"
  80,41,"Tarhaquha qatara"
  80,42,"Ola-ika humu alkafaratu alfajara"
