quran[7]{c,v,t}:
  74,1,"Ya ayyuha almuddaththir"
  74,2,"Qum faanthir"
  74,3,"Warabbaka fakabbir"
  74,4,"Wathiyabaka fatahhir"
  74,5,"Warrujza fahjur"
  74,6,"Wala tamnun tastakthir"
  74,7,"Walirabbika fasbir"
  74,8,"Fa-itha nuqira fee annaqoor"
  74,9,"Fathalika yawma-ithin yawmunAAaseer"
  74,10,"AAala alkafireena ghayruyaseer"