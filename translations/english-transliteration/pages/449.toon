quran[26]{c,v,t}:
  37,77,"WajaAAalna thurriyyatahu humualbaqeen"
  37,78,"Watarakna AAalayhi fee al-akhireen"
  37,79,"Salamun AAala noohinfee alAAalameen"
  37,80,"Inna kathalika najzee almuhsineen"
  37,81,"Innahu min AAibadinaalmu/mineen"
  37,82,"Thumma aghraqna al-akhareen"
  37,83,"Wa-inna min sheeAAatihi la-ibraheem"
  37,84,"Ith jaa rabbahu biqalbinsaleem"
  37,85,"Ith qala li-abeehi waqawmihi mathataAAbudoon"
  37,86,"A-ifkan alihatan doona Allahitureedoon"
  37,87,"Fama thannukum birabbialAAalameen"
  37,88,"Fanathara nathratanfee annujoom"
  37,89,"Faqala innee saqeem"
  37,90,"Fatawallaw AAanhu mudbireen"
  37,91,"Faragha ila alihatihimfaqala ala ta/kuloon"
  37,92,"Ma lakum la tantiqoon"
  37,93,"Faragha AAalayhim darban bilyameen"
  37,94,"Faaqbaloo ilayhi yaziffoon"
  37,95,"Qala ataAAbudoona ma tanhitoon"
  37,96,"Wallahu khalaqakum wamataAAmaloon"
  37,97,"Qaloo ibnoo lahu bunyananfaalqoohu fee aljaheem"
  37,98,"Faaradoo bihi kaydan fajaAAalnahumual-asfaleen"
  37,99,"Waqala innee thahibun ilarabbee sayahdeen"
  37,100,"Rabbi hablee mina assaliheen"
  37,101,"Fabashsharnahu bighulamin haleem"
  37,102,"Falamma balagha maAAahu assaAAyaqala ya bunayya innee ara fee almanamiannee athbahuka fanthur mathatara qala ya abati ifAAal ma tu/marusatajidunee in shaa Allahu mina assabireen"
