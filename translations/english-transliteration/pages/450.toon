quran[24]{c,v,t}:
  37,103,"Falamma aslama watallahuliljabeen"
  37,104,"Wanadaynahu an ya ibraheem"
  37,105,"Qad saddaqta arru/yainna kathalika najzee almuhsineen"
  37,106,"Inna hatha lahuwa albalaoalmubeen"
  37,107,"Wafadaynahu bithibhinAAatheem"
  37,108,"Watarakna AAalayhi fee al-akhireen"
  37,109,"Salamun AAala ibraheem"
  37,110,"Kathalika najzee almuhsineen"
  37,111,"Innahu min AAibadinaalmu/mineen"
  37,112,"Wabashsharnahu bi-ishaqanabiyyan mina assaliheen"
  37,113,"Wabarakna AAalayhi waAAalaishaqa wamin thurriyyatihima muhsinunwathalimun linafsihi mubeen"
  37,114,"Walaqad mananna AAala moosawaharoon"
  37,115,"Wanajjaynahuma waqawmahumamina alkarbi alAAatheem"
  37,116,"Wanasarnahum fakanoohumu alghalibeen"
  37,117,"Waataynahuma alkitabaalmustabeen"
  37,118,"Wahadaynahuma assirataalmustaqeem"
  37,119,"Watarakna AAalayhima fee al-akhireen"
  37,120,"Salamun AAala moosawaharoon"
  37,121,"Inna kathalika najzee almuhsineen"
  37,122,"Innahuma min AAibadinaalmu/mineen"
  37,123,"Wa-inna ilyasa lamina almursaleen"
  37,124,"Ith qala liqawmihi alatattaqoon"
  37,125,"AtadAAoona baAAlan watatharoona ahsanaalkhaliqeen"
  37,126,"Allaha rabbakum warabba aba-ikumual-awwaleen"
