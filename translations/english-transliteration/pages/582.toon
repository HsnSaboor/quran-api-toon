quran[30]{c,v,t}:
  78,1,"AAamma yatasaaloon"
  78,2,"AAani annaba-i alAAatheem"
  78,3,"Allathee hum feehi mukhtalifoon"
  78,4,"Kalla sayaAAlamoon"
  78,5,"Thumma kalla sayaAAlamoon"
  78,6,"Alam najAAali al-arda mihada"
  78,7,"Waljibala awtada"
  78,8,"Wakhalaqnakum azwaja"
  78,9,"WajaAAalna nawmakum subata"
  78,10,"WajaAAalna allayla libasa"
  78,11,"WajaAAalna annaharamaAAasha"
  78,12,"Wabanayna fawqakum sabAAan shidada"
  78,13,"WajaAAalna sirajan wahhaja"
  78,14,"Waanzalna mina almuAAsiratimaan thajjaja"
  78,15,"Linukhrija bihi habban wanabata"
  78,16,"Wajannatin alfafa"
  78,17,"Inna yawma alfasli kana meeqata"
  78,18,"Yawma yunfakhu fee assoorifata/toona afwaja"
  78,19,"Wafutihati assamao fakanatabwaba"
  78,20,"Wasuyyirati aljibalu fakanatsaraba"
  78,21,"Inna jahannama kanat mirsada"
  78,22,"Littagheena maaba"
  78,23,"Labitheena feeha ahqaba"
  78,24,"La yathooqoona feehabardan wala sharaba"
  78,25,"Illa hameeman waghassaqa"
  78,26,"Jazaan wifaqa"
  78,27,"Innahum kanoo la yarjoona hisaba"
  78,28,"Wakaththaboo bi-ayatinakiththaba"
  78,29,"Wakulla shay-in ahsaynahu kitaba"
  78,30,"Fathooqoo falan nazeedakum illaAAathaba"
