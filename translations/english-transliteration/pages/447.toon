quran[27]{c,v,t}:
  37,25,"Ma lakum la tanasaroon"
  37,26,"Bal humu alyawma mustaslimoon"
  37,27,"Waaqbala baAAduhum AAala baAAdinyatasaaloon"
  37,28,"Qaloo innakum kuntum ta/toonanaAAani alyameen"
  37,29,"Qaloo bal lam takoonoo mu/mineen"
  37,30,"Wama kana lanaAAalaykum min sultanin bal kuntum qawman tagheen"
  37,31,"Fahaqqa AAalayna qawlu rabbinainna latha-iqoon"
  37,32,"Faaghwaynakum inna kunnaghaween"
  37,33,"Fa-innahum yawma-ithin fee alAAathabimushtarikoon"
  37,34,"Inna kathalika nafAAalu bilmujrimeen"
  37,35,"Innahum kanoo itha qeela lahumla ilaha illa Allahu yastakbiroon"
  37,36,"Wayaqooloona a-inna latarikoo alihatinalishaAAirin majnoon"
  37,37,"Bal jaa bilhaqqi wasaddaqaalmursaleen"
  37,38,"Innakum latha-iqoo alAAathabial-aleem"
  37,39,"Wama tujzawna illa makuntum taAAmaloon"
  37,40,"Illa AAibada Allahialmukhlaseen"
  37,41,"Ola-ika lahum rizqun maAAloom"
  37,42,"Fawakihu wahum mukramoon"
  37,43,"Fee jannati annaAAeem"
  37,44,"AAala sururin mutaqabileen"
  37,45,"Yutafu AAalayhim bika/sin min maAAeen"
  37,46,"Baydaa laththatin lishsharibeen"
  37,47,"La feeha ghawlun walahum AAanha yunzafoon"
  37,48,"WaAAindahum qasiratu attarfiAAeen"
  37,49,"Kaannahunna baydun maknoon"
  37,50,"Faaqbala baAAduhum AAala baAAdinyatasaaloon"
  37,51,"Qala qa-ilun minhum innee kanalee qareen"
