quran[24]{c,v,t}:
  55,17,"Rabbu almashriqayni warabbu almaghribayn"
  55,18,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,19,"Maraja albahrayni yaltaqiyan"
  55,20,"Baynahuma barzakhun la yabghiyan"
  55,21,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,22,"Yakhruju minhuma allu/luo walmarjan"
  55,23,"Fabi-ayyi ala-i rabbikumatukaththibani"
  55,24,"Walahu aljawari almunshaatufee albahri kal-aAAlam"
  55,25,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,26,"Kullu man AAalayha fan"
  55,27,"Wayabqa wajhu rabbika thooaljalali wal-ikram"
  55,28,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,29,"Yas-aluhu man fee assamawatiwal-ardi kulla yawmin huwa fee sha/n"
  55,30,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,31,"Sanafrughu lakum ayyuha aththaqalan"
  55,32,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,33,"Ya maAAshara aljinni wal-insiini istataAAtum an tanfuthoo min aqtari assamawatiwal-ardi fanfuthoo la tanfuthoonailla bisultan"
  55,34,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,35,"Yursalu AAalaykuma shuwathunmin narin wanuhasun fala tantasiran"
  55,36,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,37,"Fa-itha inshaqqati assamaofakanat wardatan kaddihan"
  55,38,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,39,"Fayawma-ithin la yus-alu AAan thanbihiinsun wala jan"
  55,40,"Fabi-ayyi ala-i rabbikumatukaththiban"
