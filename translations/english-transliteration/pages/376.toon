quran[21]{c,v,t}:
  26,207,"Ma aghna AAanhum ma kanooyumattaAAoon"
  26,208,"Wama ahlakna min qaryatin illalaha munthiroon"
  26,209,"Thikra wama kunnathalimeen"
  26,210,"Wama tanazzalat bihi ashshayateen"
  26,211,"Wama yanbaghee lahum wamayastateeAAoon"
  26,212,"Innahum AAani assamAAilamaAAzooloona"
  26,213,"Fala tadAAu maAAa Allahi ilahanakhara fatakoona mina almuAAaththabeen"
  26,214,"Waanthir AAasheerataka al-aqrabeen"
  26,215,"Wakhfid janahakalimani ittabaAAaka mina almu/mineen"
  26,216,"Fa-in AAasawka faqul innee baree-onmimma taAAmaloon"
  26,217,"Watawakkal AAala alAAazeezi arraheem"
  26,218,"Allathee yaraka heenataqoom"
  26,219,"Wataqallubaka fee assajideen"
  26,220,"Innahu huwa assameeAAu alAAaleem"
  26,221,"Hal onabbi-okum AAala man tanazzaluashshayateen"
  26,222,"Tanazzalu AAala kulli affakinatheem"
  26,223,"Yulqoona assamAAa waaktharuhum kathiboon"
  26,224,"WashshuAAaraoyattabiAAuhumu alghawoon"
  26,225,"Alam tara annahum fee kulli wadinyaheemoon"
  26,226,"Waannahum yaqooloona ma layafAAaloon"
  26,227,"Illa allatheena amanoowaAAamiloo assalihati wathakaroo Allahakatheeran wantasaroo min baAAdi ma thulimoowasayaAAlamu allatheena thalamoo ayyamunqalabin yanqaliboon"
