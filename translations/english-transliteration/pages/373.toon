quran[23]{c,v,t}:
  26,137,"In hatha illa khuluqual-awwaleen"
  26,138,"Wama nahnu bimuAAaththabeen"
  26,139,"Fakaththaboohu faahlaknahuminna fee thalika laayatan wama kanaaktharuhum mu/mineen"
  26,140,"Wa-inna rabbaka lahuwa alAAazeezu arraheem"
  26,141,"Kaththabat thamoodu almursaleen"
  26,142,"Ith qala lahum akhoohum salihunala tattaqoon"
  26,143,"Innee lakum rasoolun ameen"
  26,144,"Fattaqoo Allaha waateeAAoon"
  26,145,"Wama as-alukum AAalayhi min ajrin inajriya illa AAala rabbi alAAalameen"
  26,146,"Atutrakoona fee ma hahunaamineen"
  26,147,"Fee jannatin waAAuyoon"
  26,148,"WazurooAAin wanakhlin talAAuhahadeem"
  26,149,"Watanhitoona mina aljibalibuyootan fariheen"
  26,150,"Fattaqoo Allaha waateeAAoon"
  26,151,"Wala tuteeAAoo amraalmusrifeen"
  26,152,"Allatheena yufsidoona fee al-ardiwala yuslihoon"
  26,153,"Qaloo innama anta mina almusahhareen"
  26,154,"Ma anta illa basharun mithlunafa/ti bi-ayatin in kunta mina assadiqeena"
  26,155,"Qala hathihi naqatunlaha shirbun walakum shirbu yawmin maAAloom"
  26,156,"Wala tamassooha bisoo-infaya/khuthakum AAathabu yawmin AAatheem"
  26,157,"FaAAaqarooha faasbahoonadimeen"
  26,158,"Faakhathahumu alAAathabu innafee thalika laayatan wama kanaaktharuhum mu/mineen"
  26,159,"Wa-inna rabbaka lahuwa alAAazeezu arraheem"
