quran[22]{c,v,t}:
  54,50,"Wama amruna illa wahidatunkalamhin bilbasar"
  54,51,"Walaqad ahlakna ashyaAAakumfahal min muddakir"
  54,52,"Wakullu shay-in faAAaloohu fee azzubur"
  54,53,"Wakullu sagheerin wakabeerin mustatar"
  54,54,"Inna almuttaqeena fee jannatinwanahar"
  54,55,"Fee maqAAadi sidqin AAinda maleekinmuqtadir"
  55,1,"Arrahman"
  55,2,"AAallama alqur-an"
  55,3,"Khalaqa al-insan"
  55,4,"AAallamahu albayan"
  55,5,"Ashshamsu walqamaru bihusban"
  55,6,"Wannajmu washshajaru yasjudan"
  55,7,"Wassamaa rafaAAahawawadaAAa almeezan"
  55,8,"Alla tatghaw fee almeezan"
  55,9,"Waaqeemoo alwazna bilqisti walatukhsiroo almeezan"
  55,10,"Wal-arda wadaAAahalil-anam"
  55,11,"Feeha fakihatun wannakhluthatu al-akmam"
  55,12,"Walhabbu thoo alAAasfiwarrayhan"
  55,13,"Fabi-ayyi ala-i rabbikumatukaththiban"
  55,14,"Khalaqa al-insana min salsalinkalfakhkhar"
  55,15,"Wakhalaqa aljanna min marijinmin nar"
  55,16,"Fabi-ayyi ala-i rabbikumatukaththiban"
