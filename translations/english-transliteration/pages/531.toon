quran[7]{c,v,t}:
  55,1,"Arrahman"
  55,2,"AAallama alqur-an"
  55,3,"Khalaqa al-insan"
  55,4,"AAallamahu albayan"
  55,5,"Ashshamsu walqamaru bihusban"
  55,6,"Wannajmu washshajaru yasjudan"
  55,7,"Wassamaa rafaAAahawawadaAAa almeezan"
  55,8,"Alla tatghaw fee almeezan"
  55,9,"Waaqeemoo alwazna bilqisti walatukhsiroo almeezan"
  55,10,"Wal-arda wadaAAahalil-anam"