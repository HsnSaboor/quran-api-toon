quran[21]{c,v,t}:
  51,31,"Qala fama khatbukumayyuha almursaloon"
  51,32,"Qaloo inna orsilna ilaqawmin mujrimeen"
  51,33,"Linursila AAalayhim hijaratanmin teen"
  51,34,"Musawwamatan AAinda rabbika lilmusrifeen"
  51,35,"Faakhrajna man kana feehamina almu/mineen"
  51,36,"Fama wajadna feehaghayra baytin mina almuslimeen"
  51,37,"Watarakna feeha ayatanlillatheena yakhafoona alAAathaba al-aleem"
  51,38,"Wafee moosa ith arsanahuila firAAawna bisultanin mubeen"
  51,39,"Fatawalla biruknihi waqala sahirunaw majnoon"
  51,40,"Faakhathnahu wajunoodahufanabathnahum fee alyammi wahuwa muleem"
  51,41,"Wafee AAadin ith arsalnaAAalayhimu arreeha alAAaqeem"
  51,42,"Ma tatharu min shay-in atatAAalayhi illa jaAAalat-hu karrameem"
  51,43,"Wafee thamooda ith qeela lahumtamattaAAoo hatta heen"
  51,44,"FaAAataw AAan amri rabbihim faakhathat-humuassaAAiqatu wahum yanthuroon"
  51,45,"Fama istataAAoo min qiyaminwama kanoo muntasireen"
  51,46,"Waqawma noohin min qablu innahum kanooqawman fasiqeen"
  51,47,"Wassamaa banaynahabi-aydin wa-inna lamoosiAAoon"
  51,48,"Wal-arda farashnahafaniAAma almahidoon"
  51,49,"Wamin kulli shay-in khalaqna zawjaynilaAAallakum tathakkaroon"
  51,50,"Fafirroo ila Allahi inneelakum minhu natheerun mubeen"
  51,51,"Wala tajAAaloo maAAa Allahi ilahanakhara innee lakum minhu natheerun mubeen"
