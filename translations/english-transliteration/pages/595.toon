quran[7]{c,v,t}:
  91,1,"Washshamsi waduhaha"
  91,2,"Walqamari itha talaha"
  91,3,"Wannahari itha jallaha"
  91,4,"Wallayli itha yaghshaha"
  91,5,"Wassama-i wama banaha"
  91,6,"Wal-ardi wama tahaha"
  91,7,"Wanafsin wama sawwaha"
  91,8,"Faalhamaha fujooraha wataqwaha"
  91,9,"Qad aflaha man zakkaha"
  91,10,"Waqad khaba man dassaha"
  92,1,"Wallayli itha yaghsha"
  92,2,"Wannahari itha tajalla"
  92,3,"Wama khalaqa aththakarawal-ontha"
  92,4,"Inna saAAyakum lashatta"
  92,5,"Faamma man aAAta wattaqa"
  92,6,"Wasaddaqa bilhusna"
  92,7,"Fasanuyassiruhu lilyusra"
  92,8,"Waamma man bakhila wastaghna"
  92,9,"Wakaththaba bilhusna"
  92,10,"Fasanuyassiruhu lilAAusra"