quran[29]{c,v,t}:
  91,1,"Wa&lt;b&gt;al&lt;/b&gt;shshamsi wa&lt;u&gt;d&lt;/u&gt;u&lt;u&gt;ha&lt;/u&gt;h&lt;u&gt;a&lt;/u&gt;"
