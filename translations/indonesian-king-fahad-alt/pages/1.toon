quran[7]{c,v,t}:
  1,1,"Dengan menyebut nama Allah Yang Maha Pemurah lagi Maha Penyayang.",footnotes:326420:1
  1,2,"Segala puji30993&gt;1 bagi Allah, Tuhan3 semesta alam.",footnotes:&lt;sup:2
  1,3,"Maha Pemurah lagi Maha Penyayang."
  1,4,"Yang menguasai hari pembalasan.",footnotes:326423:1|326424:2
  1,5,"Hanya kepada Engkau-lah kami menyembah dan hanya kepada Engkau-lah kami memohon pertolongan.",footnotes:326425:1|326426:2
  1,6,"Tunjukilah kami jalan yang lurus,",footnotes:326427:1
  1,7,"(yaitu) jalan orang-orang yang telah Engkau anugerahkan nikmat kepada mereka; bukan (jalan) mereka yang dimurkai dan bukan (pula jalan) mereka yang sesat.",footnotes:326428:1
