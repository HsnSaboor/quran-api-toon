quran[4]{c,v,t}:
  106,1,"Since the Quraysh became accustomed,",footnotes:182851:1
  106,2,"accustomed to the journey of winter and summer,",footnotes:182852:1
  106,3,"therefore, let them worship the Lord of this House;",footnotes:182853:1
  106,4,"Who fed them against hunger, and secured them against fear.",footnotes:182854:1|182855:2
