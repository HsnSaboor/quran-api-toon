quran[7]{c,v,t}:
  1,1,"In the name of Allah, the Merciful, the Compassionate",footnotes:176997:1
  1,2,"Praise be to Allah, the Lord of the entire universe.",footnotes:176998:1|176999:2
  1,3,"The Merciful, the Compassionate",footnotes:177000:1
  1,4,"The Master of the Day of Recompense.",footnotes:177001:1
  1,5,"You alone do we worship, and You alone do we turn for help",footnotes:177002:1|177003:2
  1,6,"Direct us on to the Straight Way,",footnotes:177004:1
  1,7,"The way of those whom You have favoured, who did not incur Your wrath, who are not astray.",footnotes:177005:1|177006:2
