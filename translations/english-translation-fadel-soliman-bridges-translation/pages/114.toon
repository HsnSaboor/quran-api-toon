quran[6]{c,v,t}:
  114,1,"Saysg, “I seek refuge with the Lord of mankind,"
  114,2,"the King of mankind,"
  114,3,"the God of mankind,"
  114,4,"from the evil of the sneaky whisperer"
  114,5,"who whispers into the chests of mankind—"
  114,6,"(from the whisperers) among the race of unseen beings and mankind.”",footnotes:366540:1
