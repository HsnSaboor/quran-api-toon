quran[8]{c,v,t}:
  99,1,"Ntango mabele ekoningana na koningana moko ya makasi,"
  99,2,"Mpe sima mabele ekobimisa mikumba na yango."
  99,3,"Mpe moto akoloba ete oyo nini boye?"
  99,4,"Mokolo wana mabele ekosakola basango na yango."
  99,5,"Pamba te mpo Nkolo nayo asili komonisa yango."
  99,6,"Mokolo wana bato bakobima bipai na bipai mpo ete bamonisa bango misala na bango."
  99,7,"Moto oyo asalaki bolamu moke lokola mbuma zelo akomona yango."
  99,8,"Na oyo mpe asalaki mabe moke lokola mbuma zelo akomona yango."
