quran[11]{c,v,t}:
  93,1,"S tafat n tûebêit!"
  93,2,"S yiv, ma irked!"
  93,3,"Ur k Iooi Mass ik, ur k Ikrih."
  93,4,"Tudert taneggarut ik, a ppif tamezwarut ik."
  93,5,"A k tôavi tikci, deqqal, n Mass ik."
  93,6,"Day ur k id Iufa ara d agujil, Isduri k?"
  93,7,"Iufa k id d utlif, Inha k."
  93,8,"Iufa k id d igellil, I$at ik."
  93,9,"Ihi, ur qehheô agujil."
  93,10,"Ur ppara amappar."
  93,11,"Wanag, $ef l$it n Mass ik, xas eêku."
