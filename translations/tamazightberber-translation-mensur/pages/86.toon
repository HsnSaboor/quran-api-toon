quran[17]{c,v,t}:
  86,1,"S igenni, akked yitri n yiv!"
  86,2,"W ara k imlen d acu t itri n yiv?"
  86,3,"Ipôeôiq itri n yiv."
  86,4,"Yal iman fellas amêareb."
  86,5,"Ad iwali umdan seg wacu ipwaxleq."
  86,6,"Ipwaxleq s waman id ifin."
  86,7,"Ff$en ed ger tgeééal akked tgwejda."
  86,8,"Ih, Izmer a t id Issker, Neppa."
  86,9,"Ass ideg lesrar ur drigen ara."
  86,10,"Ur isâi kra n tezmert ne$ n tallalt."
  86,11,"S igenni bab n tririt!"
  86,12,"S tmurt ipceqqiqen!"
  86,13,"Ar neppa d awal ifeûûlen."
  86,14,"Ur illi d urar waya."
  86,15,"Atnan, ih, ppandin ticeôkep."
  86,16,"Ad Andi$ ticeôkep."
  86,17,"I ijehliyen eoo lmudda, eoo asen cwiî lmudda."
