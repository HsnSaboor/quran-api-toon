quran[8]{c,v,t}:
  102,1,"Tem$weô tessedha kwen,"
  102,2,"armi trezfem ar iéekwan."
  102,3,"Xaîi! Deqqal a ppissinem."
  102,4,"Da$en, xaîi! Deqqal a ppissinem."
  102,5,"Xaîi! Lemmer, s tussna itebbten, ara tissinem,"
  102,6,"war ccekk, times, a p twalim."
  102,7,"D$a, s tiî utebbet, ara p twalim."
  102,8,"D$a, assen, war ccekk, fellawen asteqsi $ef lhawiyyat."
