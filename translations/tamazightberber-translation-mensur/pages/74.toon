quran[56]{c,v,t}:
  74,1,"A win ipwadlen!"
  74,2,"Ekker, endeô!"
  74,3,"Mass ik, ssem$weô!"
  74,4,"Iceîîiven ik, zzizdeg!"
  74,5,"Timenqas janeb!"
  74,6,"Ur ppak ma tuôoiv kteô!"
  74,7,"I Mass ik, eûbeô!"
  74,8,"Ma ûuven di lbuq,"
  74,9,"assen, ihi, d ass uwâiô."
  74,10,"Ur ippili d yiser, i ijehliyen."
  74,11,"Eooet iyI, akked win Xelqe$ d afôid."
  74,12,"Fki$ as ayla iwerrken,"
  74,13,"akked tarwa d imsaâfen."
  74,14,"Ssehle$ as, ad istumen."
  74,15,"Sinna issarem ad Rnu$."
  74,16,"Xaîi! Atan, issekniyen nne£, inkeô iten."
  74,17,"Ad êeppme$ fellas ssxev."
  74,18,"Ih, ixemmem, d$a iseyya."
  74,19,"Ipwasxev f akken iseyya."
  74,20,"Da$en, ipwasxev f akken iseyya."
  74,21,"Sinna, imuqel."
  74,22,"Sinna, ikres tagwenza, innu$ben."
  74,23,"Sinna, izzux, ibren."
  74,24,"D$a inna: ""wagi d ssêur kan ippulemden."
  74,25,"Ayagi d awal kan n umdan""."
  74,26,"A t Fke$ i tmes iôeqqen."
  74,27,"W ara k imlen, d acu p tmes iôeqqen?"
  74,28,"Ur teppaooa, ur tessagwar."
  74,29,"Tesseô$a igwelman."
  74,30,"Nnig es mrawtza."
  74,31,"D lmalayek kan i Nerra d imawlan n tmes. Nefka d kan amvan nnsent, iwakken ad hewwlen wid ijehlen; ad pputebbten wid iwumi teppunefk Tezmamt; ad innerni liman n wid iumnen; ur ippili ccekk ar wid iwumi teppunefk Tezmamt, akked lmumnin; akken ad inin at wul iblan, akked ijehliyen: ""acu i Ib$a Öebbi s umedya agi""? Akka, Itellif Öebbi win i S ihwan, Inehhu win i S ihwan. Iâsekôiwen n Mass ik, siwa Neppa iten Issnen. Wagi d asmekti kan i imdanen."
  74,32,"Xaîi! S waggur!"
  74,33,"S yiv ma isahel!"
  74,34,"S tafrara ma tecâal!"
  74,35,"Ar neppat d tabarart."
  74,36,"D aâggen i medden."
  74,37,"I win ib$an, segwen, ad iqeddem, ne$ ad iwexxeô."
  74,38,"Yal iman d ameôhun n wayen ixdem."
  74,39,"Kkes ed iyeffusen."
  74,40,"Di Loennet pmesteqsayen"
  74,41,"af ibe$wviyen:"
  74,42,"""ar tmes acu i kwen ibbwin""?"
  74,43,"A d inin: ""ur nelli seg wid iéullen."
  74,44,"Ur necceççay aéawali."
  74,45,"Nella nepjuôu akked imjuôen."
  74,46,"Nella d inekkaôen n wass iqeîîiyen,"
  74,47,"armi d iusa i a$ itebbten""."
  74,48,"Ur ten tenfaâ ccafuâa imcafâen."
  74,49,"Mi ugin asmekti, d acu ten iu$en?"
  74,50,"Cuban i$wyal ixelâan,"
  74,51,"i irewlen i izem."
  74,52,"Zi$ yal yiwen degsen ib$a ad as d asen isebtar ifesren."
  74,53,"Xaîi! Laxeôt, ur p ugaden."
  74,54,"Xaîi! Wagi, war ccekk, d asmekti."
  74,55,"Win ib$an, a t ismekti."
  74,56,"Siwa ma Ib$a Öebbi ara d smektayen. D Neppa ay d Bab uêezzeb, d Bab n ssmaê."
