quran[8]{c,v,t}:
  99,1,"Mara tezlez tmurt zzelzla s,"
  99,2,"U tessuffe$ ed d tmurt, tiâakkwemin is,"
  99,3,"amdan ad yini: ""d acu p iu$en""?"
  99,4,"A d teêku tidyanin is, assen;"
  99,5,"akken i s Iweêêa Mass ik."
  99,6,"Assen, a d asen imdanen, d igrawen, ar usnaâti igiten nnsen."
  99,7,"Win ixedmen taéeyt ubelkim n lxiô, a t iéeô."
  99,8,"Win ixedmen taéeyt ubelkim n cceôô, a t iéeô."
