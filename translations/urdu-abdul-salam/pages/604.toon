quran[15]{c,v,t}:
  112,1,"کہہ دے وہ اللہ ایک ہے۔"
  112,2,"اللہ ہی بے نیاز ہے۔"
  112,3,"نہ اس نے کسی کو جنا اور نہ وہ جنا گیا۔"
  112,4,"اور نہ کبھی کوئی ایک اس کے برابر کا ہے۔"
  113,1,"تو کہہ میں مخلوق کے رب کی پناہ پکڑتا ہوں۔"
  113,2,"اس چیز کے شر سے جو اس نے پیدا کی۔"
  113,3,"اور اندھیری رات کے شر سے جب وہ چھا جائے۔"
  113,4,"اور گرہوں میں پھونکنے والیوں کے شر سے۔"
  113,5,"اور حسد کرنے والے کے شر سے جب وہ حسد کرے۔"
  114,1,"تو کہہ میں پناہ پکڑتا ہوں لوگوں کے رب کی۔"
  114,2,"لوگوں کے بادشاہ کی۔"
  114,3,"لوگوں کے معبود کی۔"
  114,4,"وسوسہ ڈالنے والے کے شر سے، جو ہٹ ہٹ کر آنے والا ہے۔"
  114,5,"وہ جو لوگوں کے سینوں میں وسوسہ ڈالتا ہے۔"
  114,6,"جنوں اور انسانوں میں سے۔"
