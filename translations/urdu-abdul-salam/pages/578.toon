quran[26]{c,v,t}:
  75,20,"ہرگز نہیں، بلکہ تم جلدی ملنے والی کو پسند کرتے ہو۔"
  75,21,"اور بعد میں آنے والی کو چھوڑ دیتے ہو۔"
  75,22,"اس دن کئی چہرے ترو تازہ ہوں گے۔"
  75,23,"اپنے رب کی طرف دیکھنے والے۔"
  75,24,"اور کئی چہرے اس دن بگڑے ہوئے ہوں گے۔"
  75,25,"وہ یقین کریں گے کہ ان کے ساتھ کمر توڑنے والی(سختی) کی جائے گی۔"
  75,26,"ہرگز نہیں، ( وہ وقت یاد کرو) جب (جان) ہنسلیوں تک پہنچ جائے گی۔"
  75,27,"اور کہا جائے گا کون ہے دم کرنے والا؟"
  75,28,"اوروہ یقین کرلے گا کہ یہ جدائی ہے۔"
  75,29,"اور پنڈلی، پنڈلی کے ساتھ لپٹ جائے گی۔"
  75,30,"اس دن تیرے رب ہی کی طرف روانگی ہے۔"
  75,31,"سو نہ اس نے سچ مانا اور نہ نماز ادا کی۔"
  75,32,"اور لیکن اس نے جھٹلایا اور منہ پھیرا۔"
  75,33,"پھر اکڑتا ہوا اپنے گھر والوں کی طرف چلا۔"
  75,34,"یہی تیرے لائق ہے، پھر یہی لائق ہے ۔"
  75,35,"پھر تیرے لائق یہی ہے، پھر یہی لائق ہے۔"
  75,36,"کیا انسان گمان کرتا ہے کہ اسے بغیر پوچھے ہی چھوڑ دیا جائے گا؟"
  75,37,"کیا وہ منی کا ایک قطرہ نہیں تھا جو گرایا جاتا ہے۔"
  75,38,"پھر وہ جما ہوا خون بنا، پھر اس نے پیدا کیا، پس درست بنا دیا۔"
  75,39,"پھر اس نے اس سے دو قسمیں نر اور مادہ بنائیں۔"
  75,40,"کیا وہ اس پر قادر نہیں کہ مردوں کو زندہ کر دے؟"
  76,1,"کیا انسان پر زمانے میں سے کوئی ایسا وقت گزرا ہے کہ وہ کوئی ایسی چیز نہیں تھا جس کا (کہیں) ذکر ہوا ہو؟"
  76,2,"بلاشبہ ہم نے انسان کو ایک ملے جلے قطرے سے پیدا کیا، ہم اسے آزماتے ہیں، سو ہم نے اسے خوب سننے والا، خوب دیکھنے والا بنا دیا۔"
  76,3,"بلاشبہ ہم نے اسے راستہ دکھا دیا، خواہ وہ شکر کرنے والا بنے اور خواہ نا شکرا۔"
  76,4,"یقینا ہم نے کافروں کے لیے زنجیریں اور طوق اور بھڑکتی ہوئی آگ تیار کی ہے۔"
  76,5,"بلاشبہ نیک لوگ ایسے جام سے پییں گے جس میں کافور ملا ہوا ہو گا۔"
