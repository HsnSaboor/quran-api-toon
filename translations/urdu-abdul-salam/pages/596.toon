quran[26]{c,v,t}:
  92,15,"جس میں اس بڑے بدبخت کے سوا کوئی داخل نہیں ہوگا۔"
  92,16,"جس نے جھٹلایا اور منہ موڑا۔"
  92,17,"اور عنقریب اس سے وہ بڑا پرہیز گار دور رکھا جائے گا۔"
  92,18,"جو اپنامال (اس لیے) دیتا ہے کہ پاک ہو جائے۔"
  92,19,"حالانکہ اس کے ہاں کسی کا کوئی احسان نہیں ہے کہ اس کا بدلہ دیا جائے۔"
  92,20,"مگر ( وہ تو صرف) اپنے اس رب کا چہرہ طلب کرنے کے لیے (د یتا ہے)جو سب سے بلند ہے۔"
  92,21,"اور یقینا عنقریب وہ راضی ہو جائے گا۔"
  93,1,"قسم ہے دھوپ چڑھنے کے وقت کی!"
  93,2,"اور رات کی جب وہ چھا جائے!"
  93,3,"نہ تیرے رب نے تجھے چھوڑا اور نہ وہ ناراض ہوا۔"
  93,4,"اور یقینا پیچھے آنے والی حالت تیرے لیے پہلی سے بہتر ہے۔"
  93,5,"اور یقینا عنقریب تیرا رب تجھے عطا کرے گا، پس تو راضی ہو جائے گا۔"
  93,6,"کیا اس نے تجھے یتیم نہیں پایا، پس جگہ دی۔"
  93,7,"اور اس نے تجھے راستے سے ناواقف پایا تو راستہ دکھا دیا۔"
  93,8,"اور اس نے تجھے تنگدست پایا تو غنی کر دیا۔"
  93,9,"پس لیکن یتیم، پس (اس پر) سختی نہ کر۔"
  93,10,"اور لیکن سائل ، پس (اسے) مت جھڑک۔"
  93,11,"اور لیکن اپنے رب کی نعمت، پس (اسے) بیان کر۔"
  94,1,"کیا ہم نے تیرے لیے تیرا سینہ نہیں کھول دیا۔"
  94,2,"اور ہم نے تجھ سے تیرا بوجھ اتار دیا۔"
  94,3,"وہ جس نے تیری پیٹھ توڑ دی۔"
  94,4,"اور ہم نے تیرے لیے تیرا ذکر بلند کر دیا۔"
  94,5,"پس بے شک ہر مشکل کے ساتھ ایک آسانی ہے۔"
  94,6,"بے شک اسی مشکل کے ساتھ ایک اور آسانی ہے۔"
  94,7,"تو جب تو فارغ ہو جائے تو محنت کر۔"
  94,8,"اور اپنے رب ہی کی طرف پس رغبت کر۔"
