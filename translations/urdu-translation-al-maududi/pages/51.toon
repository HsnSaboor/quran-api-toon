quran[60]{c,v,t}:
  51,1,"قسم ہے اُن ہواؤں کی جو گرد اڑانے والی ہیں"
  51,2,"پھر پانی سے لدے ہوئے بادل اٹھانے والی ہیں۔",footnotes:187437:1
  51,3,"پھر سبک رفتاری کے ساتھ چلنے والی ہیں"
  51,4,"پھر ایک بڑے کام (بارش) کی تقسیم کرنے والی ہیں،",footnotes:187438:1
  51,5,"حق یہ ہے کہ جس چیز کا تمہیں خوف دلایا جارہا ہے وہ سچی ہے",footnotes:187439:1
  51,6,"اور جزائے اعمال ضرور پیش آنی ہے۔",footnotes:187440:1
  51,7,"قسم ہے متفرق شکلوں والے آسمان کی،",footnotes:187441:1
  51,8,"(آخرت کے بارے میں) تمہاری بات ایک دوسرے سےمختلف ہے۔",footnotes:187442:1
  51,9,"اس سے وہی بر گشتہ ہوتا ہے جو حق سے پِھرا ہوا ہے۔",footnotes:187443:1
  51,10,"مارے گئے قیاس و گمان سے حکم لگانے والے،",footnotes:187444:1
  51,11,"جو جہالت میں غرق اور غفلت میں مدہوش ہیں۔",footnotes:187445:1
  51,12,"پوچھتے ہیں آخر وہ روز جزاء کب آئے گا؟"
  51,13,"وہ اُس روز آئے گا جب یہ لوگ آگ پر تپائے  جائیں گے۔",footnotes:187446:1
  51,14,"(اِن سے کہا جائےگا) اب چکھو مزا اپنے فتنے کا۔ یہ وہی چیز ہےجس کے لیے تم جلدی مچارہے تھے۔",footnotes:187447:1|187448:2
  51,15,"البتہ متّقی لوگ اُس روز باغوں اور چشموں میں ہوں گے",footnotes:187449:1
  51,16,"جو کچھ ان کا رب انہیں دے گا اسے خوشی خوشی لے رہے ہوں گے۔ وہ اُس دن کے آنے سے پہلے نیکو کار تھے",footnotes:187450:1
  51,17,"راتوں کو کم ہی سوتے تھے۔",footnotes:187451:1
  51,18,"پھر وہی رات کے پچھلے پہروں میں معافی مانگتے تھے،",footnotes:187452:1
  51,19,"اور ان کے مالوں میں حق تھا سائل اور محروم کے لیے۔",footnotes:187453:1
  51,20,"زمین میں بہت سی نشانیاں ہیں یقین لانے والوں کے لیے،",footnotes:187454:1
  51,21,"اور خود تمہارے اپنے وجود میں ہیں۔ کیا تم کو سُوجھتا نہیں؟",footnotes:187455:1
  51,22,"آسمان ہی میں ہے تمہارا رزق بھی اور وہ چیز بھی جس کاتم سے وعدہ کیا جا رہا ہے۔",footnotes:187456:1
  51,23,"پس قسم ہے آسمان اور زمین کے مالک کی، یہ بات حق ہے، ایسی ہی یقینی جیسے تم بول رہے ہو"
  51,24,"اے نبی ؐ ، ابراہیم ؑ کے معزز مہمانوں کی حکایت بھی تمہیں پہنچی ہے؟",footnotes:171563:1|171564:2
  51,25,"جب وہ اُس کے ہاں آئے تو کہا آپ کو سلام ہے۔ اُس نے کہا ”آپ لوگوں کو بھی سلام ہے۔۔۔۔ کچھ ناآشنا سے لوگ ہیں۔“",footnotes:187457:1
  51,26,"پھر وہ چپکے سے اپنے گھر والوں کے پاس گیا، اور ایک موٹا تازہ بچھڑالاکر",footnotes:187458:1|187459:2
  51,27,"مہمانوں کے آگے پیش کیا اُس نے کہا آپ حضرات کھاتے نہیں؟"
  51,28,"پھر وہ اپنے دل میں ان سے ڈرا۔ انہوں نےکہا ڈریے نہیں، اور اُسے ایک ذی علم لڑکے کی پیدائش کا مژدہ سنایا۔",footnotes:187460:1|187461:2
  51,29,"یہ سُن کر اُس کی بیوی چیختی ہوئی آگے بڑھی اور اس نے اپنا منہ پِیٹ لیا اور کہنے لگی ، ”بوڑھی، بانجھ!“",footnotes:187463:1
  51,30,"انہوں نے کہا”یہی کچھ فرمایا ہے تیرے رب نے، وہ حکیم ہے اور سب کچھ جانتا ہے۔“",footnotes:187464:1
  51,31,"ابراہیم ؑ نے کہا ، اے فرستادگانِ الہٰی ، کیا مہم آپ کو درپیش ہے؟",footnotes:187465:1
  51,32,"انہوں نے کہا”ہم ایک مجرم قوم کی طرف بھیجے گئے ہیں",footnotes:187466:1
  51,33,"تاکہ اُس پر پکی ہوئی مٹی کے پتھر برسا دیں"
  51,34,"جو آپ کے رب کے ہاں حد سے گزر جانے والوں کے لیے نشان زدہ ہیں“",footnotes:187467:1
  51,35,"پھر ہم نے ان سب لوگوں کو نکال لیا جو اس بستی میں مومن تھے",footnotes:171565:1
  51,36,"اور وہاں ہم نے ایک گھر کےسوا مسلمانوں کا کوئی گھر نہ پایا۔",footnotes:187468:1
  51,37,"اس کے بعد ہم  نے وہاں بس ایک نشانی ان لوگوں کے لیے چھوڑ دی جو درد ناک عذاب سے ڈرتے ہوں۔",footnotes:187469:1
  51,38,"اور(تمہارے لیے نشانی ہے) موسیٰؑ کے قصے ہیں۔ جب ہم نے اسے صریح سَنَد کے ساتھ فرعون کے پاس بھیجا",footnotes:187470:1
  51,39,"تو وہ اپنے بل بوتے پر اکڑ گیا اور بولا یہ جادوگر ہے یا مجنون ہے۔",footnotes:187471:1
  51,40,"آخر کار ہم نے اُسے اور اس کے لشکروں  کو پکڑا اور سب کو سمندر میں پھینک دیا  اور وہ ملامت زدہ ہو کر رہ گیا۔",footnotes:187472:1
  51,41,"اور (تمہارے لیے نشانی ہے) عاد میں، جبکہ ہم نے ان پر ایک ایسی بے خیر ہوا بھیج دی"
  51,42,"کہ جس چیز پر بھی وہ گزر گئی اسے بوسیدہ کر کے رکھ دیا۔",footnotes:187473:1
  51,43,"اور (تمہارے لیے نشانی ہے) ثمود میں ، جب ان سے کہا گیا تھا کہ ایک خاص وقت تک مزے کر لو۔",footnotes:187474:1
  51,44,"مگر اس تنبیہ پر بھی انہوں نے اپنے رب کےحکم سے سرتابی کی۔ آخر کار ان کے دیکھتے دیکھتےایک اچانک ٹوٹ پڑنے والے عذاب نے ان کو آلیا۔",footnotes:187475:1
  51,45,"پھر نہ ان میں اٹھنے کی سکت تھی اور نہ وہ اپنا بچاؤ کر سکتے تھے۔",footnotes:187476:1
  51,46,"اور ان سب سے پہلے ہم نے نوحؑ کی قوم کو ہلاک کیا کیونکہ وہ فاسق لوگ تھے"
  51,47,"آسمان کو ہم نے اپنے زور سے بنایا ہے اور ہم اس کی قدرت رکھتے ہیں۔",footnotes:171566:1|171567:2
  51,48,"زمین کو ہم نے بچھایا ہے اور ہم بڑے اچھے ہموار کرنے والے ہیں۔",footnotes:187477:1
  51,49,"اور ہر چیز کے ہم نے جوڑے بنائے ہیں، شاید کہ تم اس سے سبق لو۔",footnotes:187478:1|187479:2
  51,50,"تو دوڑو اللہ کی طرف، میں تمہارے لیے اس کی طرف سے صاف صاف خبردار کرنے والا ہوں"
  51,51,"اور نہ بناؤ اللہ کے ساتھ کوئی دوسرا معبود، میں تمہارے لیے اس کی طرف سے صاف صاف خبردار کرنے والا ہوں۔",footnotes:187480:1
  51,52,"یونہی ہو تا رہا ہے، ان سے پہلے کی قوموں کے پاس بھی کوئی رسول ایسا نہیں آیا جسے انہوں نے یہ نہ کہا ہو کہ یہ ساحر ہے یا مجنون",footnotes:187481:1
  51,53,"کیا ان سب نے آپس میں اس پر کوئی سمجھوتہ کر لیا ہے؟ نہیں، بلکہ یہ سب سر کش لوگ ہیں۔",footnotes:187482:1
  51,54,"پس اے نبی ؐ ، ان سے رخ پھیر لو، تم پر کچھ ملامت نہیں",footnotes:187483:1
  51,55,"البتہ نصیحت کرے رہو، کیونکہ نصیحت ایمان لانے والوں کے لیے نافع ہے۔",footnotes:187484:1
  51,56,"میں نے جِنّ اور انسانوں کو اس کے سوا کسی کام کے لیے پیدا نہیں کیا ہے کہ وہ میری بندگی کریں",footnotes:187485:1
  51,57,"میں ان سے کوئی رزق نہیں چاہتا اور نہ یہ چاہتا ہوں کہ وہ مجھے کھلائیں۔",footnotes:187486:1
  51,58,"اللہ تو خود ہی رزّاق ہےبڑی قوت والا اور زبردست۔",footnotes:187487:1
  51,59,"پس جن لوگوں نے ظلم کیا ہے ان کے حصے کا بھی ویسا ہی عذاب تیار ہے جیسا اِنہی جیسے لوگوں کو اُن کے حصے کا مل چکا ہے، اس کے لیے یہ لوگ جلدی نہ مچائیں۔",footnotes:187488:1|187489:2
  51,60,"آخر کو تباہی ہے کفر کرنے والوں کے لیے اُس روز جس کا انہیں خوف دلایا جا رہا ہے"
