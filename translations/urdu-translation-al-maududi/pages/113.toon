quran[5]{c,v,t}:
  113,1,"کہو، میں پناہ مانگتا ہوں صبح کے ربّ کی",footnotes:188652:1|188653:2|188654:3
  113,2,"ہر اُس چیز کے شر سے جو اُس نے پیدا کی ہے",footnotes:188655:1
  113,3,"اور رات کی تاریکی کے شر سے جب کہ وہ چھا جائے،",footnotes:188656:1
  113,4,"اور گِرہوں میں پُھونکنے والوں (یا والیوں)کے شر سے،",footnotes:188657:1
  113,5,"اور حاسد کے شر سے جب کہ وہ حسد کرے۔",footnotes:188658:1
