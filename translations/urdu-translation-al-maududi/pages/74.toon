quran[56]{c,v,t}:
  74,1,"اے اوڑھ لپیٹ کر لیٹنے والے،",footnotes:188169:1
  74,2,"اُٹھو اور خبر دار کرو۔",footnotes:188170:1
  74,3,"اور اپنے ربّ کی بڑائی کا اعلان کرو۔",footnotes:188171:1
  74,4,"اور اپنے کپڑے پاک رکھو۔",footnotes:188172:1
  74,5,"اور گندگی سے دُور رہو۔",footnotes:188173:1
  74,6,"اور احسان نہ کرو زیادہ حاصل کرنے کے لیے۔",footnotes:188174:1
  74,7,"اور اپنے ربّ کی خاطر صبر کرو۔",footnotes:188175:1
  74,8,"اچھا، جب صور میں پھونک ماری جائے گی"
  74,9,"وہ دن بڑا ہی سخت دن ہوگا،",footnotes:188176:1
  74,10,"کافروں کے لیے ہلکا نہ ہوگا۔",footnotes:188177:1
  74,11,"چھوڑ دو مجھے اور اُس شخص کو جسے میں نے اکیلا پیدا کیا،",footnotes:188178:1|188179:2
  74,12,"بہت سا مال اُس کو دیا"
  74,13,"اس کے ساتھ حاضر رہنے والے بیٹے دیے،",footnotes:188180:1
  74,14,"اور اس کے لیے ریاست کی راہ ہموار کی"
  74,15,"پھر وہ طمع رکھتا ہے کہ میں اسے اور زیادہ دُوں۔",footnotes:188181:1
  74,16,"ہرگز نہیں، وہ ہماری آیات سے عناد رکھتا ہے"
  74,17,"میں تو اسے عنقریب ایک کٹھن چڑھائی چڑھواؤں گا"
  74,18,"اس نے سوچا اور کچھ بات بنانے کی کوشش کی"
  74,19,"تو خدا کی مار اس پر، کیسی بات بنانے کی کوشش کی"
  74,20,"ہاں، خدا کی مار اُس پر، کیسی بات بنانے کی کوشش کی"
  74,21,"پھر (لوگوں کی طرف) دیکھا"
  74,22,"پھر پیشانی سیکڑی اور منہ بنایا"
  74,23,"پھر پلٹا اور تکبر میں پڑ گیا"
  74,24,"آخرکار بولا کہ یہ کچھ نہیں ہے مگر ایک جادو جو پہلے سے چلا آ رہا ہے"
  74,25,"یہ تو ایک انسانی کلام ہے۔",footnotes:188168:1
  74,26,"عنقریب میں اسے دوزخ میں جھونک دوں گا"
  74,27,"اور تم کیا جانو کہ کیا ہے وہ دوزخ؟"
  74,28,"نہ باقی رکھے نہ چھوڑے۔",footnotes:186846:1
  74,29,"کھال جھُلس دینے والی۔",footnotes:186939:1
  74,30,"اُنّیس کارکن اُس پر مقرر ہیں۔۔۔۔",footnotes:188182:1
  74,31,"ہم نے دوزخ کے یہ کارکن فرشتے بنائے ہیں، اور ان کی تعداد کو کافروں کے لیے فتنہ بنا دیا ہے، تاکہ اہلِ کتاب کو یقین آجائے اور ایمان لانے والوں کا ایمان بڑھے، اور اہلِ کتاب اور مومنین کسی شک میں نہ رہیں، اور دل کے بیمار اور کفّار یہ کہیں کہ بھلا اللہ کا اِس عجیب بات سے کیا مطلب ہوسکتا ہے۔ اِس طرح اللہ جسے چاہتا ہے گمراہ کر دیتا ہے اور جسے چاہتا ہے ہدایت بخش دیتا ہے۔ اور تیرے ربّ کے لشکروں کو خود اُس کے سوا کوئی نہیں جانتا۔۔۔۔ اور اس دوزخ کا ذکر اِس کے سوا کسی غرض کے لیےنہیں کیا گیا کہ لوگوں کو اس سے نصیحت ہو۔",footnotes:188183:1|188184:2|188185:3|188186:4|188187:5|188188:6|188189:7|188190:8|188191:9
  74,32,"ہرگز نہیں، قسم ہے چاند کی",footnotes:171623:1
  74,33,"اور رات کی جبکہ وہ پلٹتی ہے"
  74,34,"اور صبح کی جبکہ وہ روشن ہوتی ہے"
  74,35,"یہ دوزخ بھی بڑی چیزوں میں سے ایک ہے،",footnotes:188192:1
  74,36,"انسانوں کے لیے ڈراوا"
  74,37,"تم میں سے ہر اُس شخص کے لیے ڈراوا جو آگے بڑھنا چاہے یا پیچھے رہ جانا چاہے۔",footnotes:188193:1
  74,38,"ہر متنفّس اپنے کسب کے بدلے رہن ہے،",footnotes:188194:1
  74,39,"دائیں بازو والوں کے سوا،",footnotes:188195:1
  74,40,"جو جنتوں میں ہوں گے وہاں وہ،"
  74,41,"مجرموں سے پوچھیں گے",footnotes:188196:1
  74,42,"""تمہیں کیا چیز دوزخ میں لے گئی؟"""
  74,43,"وہ کہیں گے”ہم نماز پڑھنے والوں میں سے  نہ تھے،",footnotes:188197:1
  74,44,"اور مسکین کو کھانا نہیں کھلاتے تھے،",footnotes:188198:1
  74,45,"اور حق کے خلاف باتیں بنانے والوں کے ساتھ مل کر ہم بھی باتیں بنانے لگتے تھے"
  74,46,"اور روز جزا کو جھوٹ قرار دیتے تھے"
  74,47,"یہاں تک کہ ہمیں اُس یقینی چیز سے سابقہ پیش آگیا۔“",footnotes:188199:1
  74,48,"اُس وقت سفارش کرنے والوں کی سفارش ان کے کسی کام نہ آئے گی۔",footnotes:188200:1
  74,49,"آخر اِن لوگوں کو کیا ہو گیا ہے کہ یہ اِس نصیحت سے منہ موڑ رہے ہیں"
  74,50,"گویا یہ جنگلی گدھے ہیں"
  74,51,"جو شیر سے ڈر کر بھاگ پڑے ہیں۔",footnotes:188201:1
  74,52,"بلکہ اِن میں سے تو ہر ایک یہ چاہتا ہے کہ اُس کے نام کُھلے خط بھیجے جائیں۔",footnotes:188202:1
  74,53,"ہر گز نہیں، اصل بات یہ ہے کہ یہ آخرت کا خوف نہیں رکھتے۔",footnotes:188203:1
  74,54,"ہر گز نہیں، یہ تو ایک نصیحت ہے",footnotes:188204:1
  74,55,"اب جس کا جی چاہے اس سے سبق حاصل کر لے"
  74,56,"اور یہ کوئی سبق حاصل نہ کریں گے اِلّا یہ کہ اللہ ہی ایسا چاہے۔ وہ اس کا حق دار ہے کہ اُس سے تقویٰ کیا جائے اور وہ اس کا اہل ہے کہ (تقویٰ کرنے والوں کو) بخش دے۔",footnotes:188205:1|188206:2|188207:3
