quran[46]{c,v,t}:
  79,1,"قسم ہے اُن (فرشتوں کی) جو ڈوب کر کھینچتے ہیں"
  79,2,"اور آہستگی سے نکال لے جاتے ہیں"
  79,3,"اور (اُن فرشتوں کی جو کائنات میں) تیزی سے تیرتے پھرتے ہیں"
  79,4,"پھر (حکم بجا لانے میں) سبقت کرتے ہیں"
  79,5,"پھر (احکامِ الٰہی کے مطابق)معاملات کا انتظام چلاتے ہیں۔",footnotes:188313:1
  79,6,"جس روز ہلا مارے گا زلزلے کا جھٹکا"
  79,7,"اور اس کے پیچھے ایک اور جھٹکا پڑے گا،",footnotes:188314:1
  79,8,"کچھ دل ہوں گے جو اُس روز خوف سے کانپ رہے ہوں گے،",footnotes:188315:1
  79,9,"نگاہیں اُن کی سہمی ہوئی ہوں گی"
  79,10,"یہ لوگ کہتے ہیں ""کیا واقعی ہم پلٹا کر پھر واپس لائے جائیں گے؟"
  79,11,"کیا جب ہم کھوکھلی بوسیدہ ہڈیاں بن چکے ہوں گے؟"""
  79,12,"کہنے لگے”یہ واپسی تو پھر بڑے گھاٹے کی ہوگی!“",footnotes:188316:1
  79,13,"حالانکہ یہ بس اتنا کام ہے کہ ایک زور کی ڈانٹ پڑے گی"
  79,14,"اور یکایک یہ کُھلے میدان میں موجود ہوں گے۔",footnotes:188317:1
  79,15,"کیا تمہیں مُوسیٰؑ کے قصّے کی خبر پہنچی ہے؟",footnotes:171631:1
  79,16,"جب اس کے ربّ نے اُسے طُویٰ کی مقدّس وادی میں پُکارا تھا",footnotes:188318:1
  79,17,"کہ ""فرعون کے پاس جا، وہ سرکش ہو گیا ہے"
  79,18,"اور اس سے کہہ کیا تو اِس کے لیے تیار ہے کہ پاکیزگی اختیار کرے"
  79,19,"اور میں تیرے ربّ کی طرف تیری رہنمائی کروں تو (اُس کا)خوف تیرے اندر پیدا ہو؟“",footnotes:188319:1
  79,20,"پھر موسیٰؑ نے (فرعون کے پاس جا کر)اُس کی بڑی نشانی دکھائی،",footnotes:188320:1
  79,21,"مگر اُس نے جھٹلا دیا اور نہ مانا"
  79,22,"پھر چالبازیاں کرنے کے لیے پلٹا",footnotes:188321:1
  79,23,"اور لوگوں کو جمع کر کے اس نے پکار کر کہا"
  79,24,"میں تمہارا سب سے بڑا ربّ ہوں“",footnotes:188322:1
  79,25,"آخرکار اللہ نے اسے آخرت اور دنیا کے عذاب میں پکڑ لیا"
  79,26,"در حقیقت اِس میں بڑی عبرت ہے ہر اُس شخص کے لیے جو ڈرے۔",footnotes:188323:1
  79,27,"کیا تم لوگوں کی تخلیق زیادہ سخت کام ہے یا آسمان کی؟ اللہ نے اُس کو بنایا",footnotes:171632:1|171633:2
  79,28,"اُس کی چھت خوب اونچی اٹھائی پھر اُس کا توازن قائم کیا"
  79,29,"اور اُس کی رات ڈھانکی اور اُس کا دن نکالا۔",footnotes:188324:1
  79,30,"اِس کے بعد زمین کو اس نے بچھایا،",footnotes:188325:1
  79,31,"اُس کے اندر اُس کا پانی اور چارہ نکالا،",footnotes:188326:1
  79,32,"اور پہاڑ اس میں گاڑ دیے"
  79,33,"سامانِ زیست کے طور پر تمہارے لیے اور تمہارے مویشیوں کے لیے۔",footnotes:188327:1
  79,34,"پھر جب وہ ہنگامہٴِ عظیم برپا ہوگا،",footnotes:188328:1
  79,35,"جس روز انسان اپنا سب کیا دھرا یاد کرے گا،",footnotes:188329:1
  79,36,"اور ہر دیکھنے والے کے سامنے دوزخ کھول کر رکھ دی جائے گی"
  79,37,"تو جس نے سرکشی کی تھی"
  79,38,"اور دنیا کی زندگی کو ترجیح دی تھی"
  79,39,"دوزخ ہی اس کا ٹھکانا ہوگی"
  79,40,"اور جس نے اپنے رب کے سامنے کھڑے ہونے کا خوف کیا تھا اور نفس کو بری خواہشات سے باز رکھا تھا"
  79,41,"جنّت اس کا ٹھکانا ہوگی۔",footnotes:188330:1
  79,42,"یہ لوگ تم سے پوچھتے ہیں کہ”آخر وہ گھڑی کب آکر ٹھہرے گی؟“",footnotes:188331:1
  79,43,"تمہارا کیا کام کہ اس کا وقت بتاؤ"
  79,44,"اس کا علم تو اللہ پر ختم ہے"
  79,45,"تم صرف خبردار کرنے والے ہو ہر اُس شخص کو جو اُس کا خوف کرے"
  79,46,"جس روز یہ لوگ اُسے دیکھ لیں گے تو انہیں یوں محسوس ہو گا کہ (یہ دنیا میں یا حالتِ موت میں) بس ایک دن کے پچھلے پہر یا اگلے پہر تک ٹھہرے ہیں۔",footnotes:188332:1|188333:2
