quran[7]{c,v,t}:
  18,1,"All praise be to Allah, Who sent down the Scripture upon His servant and has not made therein any crookedness;"
  18,2,"most upright, to warn of a severe chastisement from Himself, and<i class=""s"">(to) </i>give glad tidings to the believers who do righteous deeds that for them is an excellent reward,"
  18,3,"wherein they stay forever;"
  18,4,"and<i class=""s"">(to) </i>warn those who have said, “Allah has taken<i class=""s"">(for Himself) </i>offspring.”"
