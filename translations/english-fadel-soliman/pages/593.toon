quran[7]{c,v,t}:
  89,1,"By the dawn."
  89,2,"By the ten nights."
  89,3,"By the even and the odd."
  89,4,"By the night as it passes—"
  89,5,"is there in that a sworn oath for whoever has a mind{1}?",footnotes:1:[A rational person.]
  89,6,"Have you<sup>sg </sup>not seen what your Lord did to ʻĀd{1}—",footnotes:1:[The pagan tribe of Prophet Hûd.]
  89,7,"Iram,<i>(the city) </i>of the pillars"
  89,8,"whose like has never been created in the lands;"
  89,9,"and Thamûd{1}, who carved the rocks in the valley;",footnotes:1:[The pagan tribe of Prophet Salih.]
  89,10,"and Pharaoh of the stakes?"
