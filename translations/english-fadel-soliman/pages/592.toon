quran[7]{c,v,t}:
  88,1,"Has there come to you<sup>sg </sup>the news of the Overwhelming<i>(event) </i>{1}?",1:[The Day of Judgment.]
  88,2,"Some faces on that day are<i>(subdued) </i>in reverence,"
  88,3,"toiling, exhausted,"
  88,4,"roasting{1}in a hot fire,",1:[Qira’at: Abu ‘Amr, Shu’ba and Ya’qub read it as: “…made to roast in a hot fire,”]
  88,5,"given to drink from a boiling spring."
  88,6,"They have no food except of a thorny bush"
  88,7,"which neither nourishes nor satisfies hunger."
  88,8,"Some faces on that day are blissful,"
  88,9,"well pleased with their endeavor,"
  88,10,"in a lofty Garden:"
