quran[7]{c,v,t}:
  76,6,"a spring from which Allah’s servants drink, making it gush abundantly."
  76,7,"They fulfill<i class=""s"">(their) </i>vows and fear a day of widespread evil,"
  76,8,"and they feed—for the love of Him—<i class=""s"">(any) </i>destitute person and<i class=""s"">(any) </i> orphan and<i class=""s"">(any) </i>captive."
  76,9,"“Indeed, we only feed you<a class=""sup""><sup>pl </sup></a>for the sake of Allah; We want from you neither repayment nor thankfulness."
  76,10,"Indeed, we fear from our Lord a frowning, grim day.”"
