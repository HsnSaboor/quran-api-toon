quran[9]{c,v,t}:
  2,49,"اور (یاد کرو) جب ہم نے تم کو فرعون والوں سے نجات بخشی کہ وہ تم پر برا عذاب کرتے تھے تمہارے بیٹوں کو ذبح کرتے اور تمہاری بیٹیوں کو زندہ رکھتے اور اس میں تمہارے رب کی طرف سے بڑی بلا تھی (یا بڑا انعام)"
  2,50,"اور جب ہم نے تمہارے لئے دریا پھاڑ دیا تو تمہیں بچالیا اور فرعون والوں کو تمہاری آنکھوں کے سامنے ڈبو دیا -"
  2,51,"اور جب ہم نے موسیٰ سے چالیس رات کا وعدہ فرمایا پھر اس کے پیچھے تم نے بچھڑے کی پوجا شروع کردی اور تم ظالم تھے -"
  2,52,"پھر اس کے بعد ہم نے تمہیں معافی دی کہ کہیں تم احسان مانو -"
  2,53,"اور جب ہم نے موسیٰ کو کتاب عطا کی اور حق و باطل میں تمیز کردینا کہ کہیں تم راہ آؤ -"
  2,54,"اور جب موسیٰ نے اپنی قوم سے کہا اے میری قوم تم نے بچھڑا بناکر اپنی جانوں پر ظلم کیا تو اپنے پیدا کرنے والے کی طرف رجوع لاؤ تو آپس میں ایک دوسرے کو قتل کردو یہ تمہارے پیدا کرنے والے کے نزدیک تمہارے لیے بہتر ہے تو اس نے تمہاری توبہ قبول کی بیشک وہی ہے بہت توبہ قبول کرنے والا مہربان -"
  2,55,"اور جب تم نے کہا اے موسیٰ ہم ہرگز تمہارا یقین نہ لائیں گے جب تک اعلانیہ خدا کو نہ دیکھ لیں تو تمہیں کڑک نے آلیا اور تم دیکھ رہے تھے ۔"
  2,56,"پھر مرے پیچھے ہم نے تمہیں زندہ کیا کہ کہیں تم احسان مانو-"
  2,57,"اور ہم نے ابر کو تمہارا سائبان کیا اور تم پر من اور سلویٰ اتارا کھاؤ ہماری دی ہوئی ستھری چیزیں اور انہوں نے کچھ ہمارا نہ بگاڑا ہاں اپنی ہی جانوں کو بگاڑ کرتے تھے- اور جب ہم نے فرمایا اس بستی میں جاؤ -"
