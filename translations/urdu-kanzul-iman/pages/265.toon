quran[19]{c,v,t}:
  15,52,"جب وہ اس کے پاس آئے تو بولے سلام کہا ہمیں تم سے ڈر معلوم ہوتا ہے،"
  15,53,"انہوں نے کہا ڈریے نہیں ہم آپ کو ایک علم والے لڑکے کی بشارت دیتے ہیں،"
  15,54,"کہا کیا اس پر مجھے بشارت دیتے ہو کہ مجھے بڑھاپا پہنچ گیا اب کاہے پر بشارت دیتے ہو،"
  15,55,"کہا ہم نے آپ کو سچی بشارت دی ہے آپ ناامید نہ ہوں،"
  15,56,"کہا اپنے رب کی رحمت سے کون ناامید ہو مگر وہی جو گمراہ ہوئے، ف۶۱)"
  15,57,"کہا پھر تمہارا کیا کام ہے اے فرشتو!"
  15,58,"بولے ہم ایک مجرم قوم کی طرف بھیجے گئے ہیں،"
  15,59,"مگر لوط کے گھر والے، ان سب کو ہم بچالیں گے،"
  15,60,"مگر اس کی عورت ہم ٹھہراچکے ہیں کہ وہ پیچھے رہ جانے والوں میں ہے، ف۶۵)"
  15,61,"تو جب لوط کے گھر فرشتے آئے، ۶۶)"
  15,62,"کہا تم تو کچھ بیگانہ لوگ ہو، ف۶۷)"
  15,63,"کہا بلکہ ہم تو آپ کے پاس وہ لائے ہیں جس میں یہ لوگ شک کرتے تھے،"
  15,64,"اور ہم آپ کے پاس سچا حکم لائے ہیں اور ہم بیشک سچے ہیں،"
  15,65,"تو اپنے گھر والوں کو کچھ رات رہے لے کر باہر جایے اور آپ ان کے پیچھے چلئے اور تم میں کوئی پیچھے پھر کر نہ دیکھے اور جہاں کو حکم ہے سیدھے چلے جایئے،"
  15,66,"اور ہم نے اسے اس حکم کا فیصلہ سنادیا کہ صبح ہوتے ان کافروں کی جڑ کٹ جائے گی،"
  15,67,"اور شہر والے خوشیاں مناتے آئے،"
  15,68,"لوط نے کہا یہ میرے مہمان ہیں مجھے فضیحت (رُسوا) نہ کرو، ف۷۵)"
  15,69,"اور اللہ سے ڈرو اور مجھے رسوا نہ کرو،"
  15,70,"بولے کیا ہم نے تمہیں منع نہ کیا تھا کہ اوروں کے معاملہ میں دخل نہ دو،"
