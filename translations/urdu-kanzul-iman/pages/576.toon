quran[30]{c,v,t}:
  74,18,"بیشک وہ سوچا اور دل میں کچھ بات ٹھہرائی"
  74,19,"تو اس پر لعنت ہو کیسی ٹھہرائی،"
  74,20,"پھر اس پر لعنت ہو کیسی ٹھہرائی،"
  74,21,"پھر نظر اٹھا کر دیکھا،"
  74,22,"پھر تیوری چڑھائی اور منہ بگاڑا،"
  74,23,"پھر پیٹھ پھیری اور تکبر کیا،"
  74,24,"پھر بولا یہ تو وہی جادو ہے اگلوں سے سیکھا،"
  74,25,"یہ نہیں مگر آدمی کا کلام"
  74,26,"کوئی دم جاتا ہے کہ میں اسے دوزخ میں دھنساتا ہوں،"
  74,27,"اور تم نے کیا جانا دوزخ کیا ہے،"
  74,28,"نہ چھوڑے نہ لگی رکھے"
  74,29,"آدمی کی کھال اتار لیتی ہے"
  74,30,"اس پر اُنیس داروغہ ہیں"
  74,31,"اور ہم نے دوزخ کے داروغہ نہ کیے مگر فرشتے، اور ہم نے ان کی یہ گنتی نہ رکھی مگر کافروں کی جانچ کو اس لیے کہ کتاب والوں کو یقین آئے اور ایمان والوں کا ایمان بڑھے اور کتاب والوں اور مسلمانوں کو کوئی شک نہ رہے اور دل کے روگی (مریض) اور کافر کہیں اس اچنبھے کی بات میں اللہ کا کیا مطلب ہے، یونہی اللہ گمراہ کرتا ہے جسے چاہے اور ہدایت فرماتا ہے جسے چاہے، اور تمہارے رب کے لشکروں کو اس کے سوا کوئی نہیں جانتا، اور وہ تو نہیں مگر آدمی کے لیے نصیحت،"
  74,32,"ہاں ہاں چاند کی قسم،"
  74,33,"اور رات کی جب پیٹھ پھیرے،"
  74,34,"اور صبح کی جب اجا لا ڈالے"
  74,35,"بیشک دوزخ بہت بڑی چیزوں میں کی ایک ہے،"
  74,36,"آدمیوں کو ڈراؤ،"
  74,37,"اسے جو تم میں چاہے، کہ آگے آئے یا پیچھے رہے"
  74,38,"ہر جان اپنی کرنی (اعمال) میں گروی ہے،"
  74,39,"مگر دہنی طرف والے"
  74,40,"باغوں میں پوچھتے ہیں،"
  74,41,"مجرموں سے،"
  74,42,"تمہیں کیا بات دوزخ میں لے گئی،"
  74,43,"وہ بولے ہم نماز نہ پڑھتے تھے،"
  74,44,"اور مسکین کو کھانا نہ دیتے تھے"
  74,45,"اور بیہودہ فکر والوں کے ساتھ بیہودہ فکریں کرتے تھے،"
  74,46,"اور ہم انصاف کے دن کو جھٹلاتے رہے،"
  74,47,"یہاں تک کہ ہمیں موت آئی،"
