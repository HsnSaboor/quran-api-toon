quran[13]{c,v,t}:
  72,1,"تم فرماؤ مجھے وحی ہوئی کہ کچھ جنوں نے میرا پڑھنا کان لگا کر سنا تو بولے ہم نے ایک عجیب قرآن سنا"
  72,2,"کہ بھلائی کی راہ بتا تا ہے تو ہم اس پر ایمان لائے، اور ہم ہرگز کسی کو اپنے رب کا شریک نہ کریں گے،"
  72,3,"اور یہ کہ ہمارے رب کی شان بہت بلند ہے نہ اس نے عورت اختیار کی اور نہ بچہ"
  72,4,"اور یہ کہ ہم میں کا بے وقوف اللہ پر بڑھ کر بات کہتا تھا"
  72,5,"اور یہ کہ ہمیں خیال تھا کہ ہرگز آدمی اور جِن اللہ پر جھوٹ نہ باندھیں گے"
  72,6,"اور یہ کہ آدمیوں میں کچھ مرد جنوں کے کچھ مردوں کے پناہ لیتے تھے تو اس سے اور بھی ان کا تکبر بڑھا،"
  72,7,"اور یہ کہ انہوں نے گمان کیا جیسا تمہیں گمان ہے کہ اللہ ہرگز کوئی رسول نہ بھیجے گا،"
  72,8,"اور یہ کہ ہم نے آسمان کو چھوا تو اسے پایا کہ سخت پہرے اور آگ کی چنگاریوں سے بھردیا گیا ہے"
  72,9,"اور یہ کہ ہم پہلے آسمان میں سننے کے لیے کچھ موقعوں پر بیٹھا کرتے تھے، پھر اب جو کوئی سنے وہ اپنی تاک میں آگ کا لُوکا (لپٹ) پائے"
  72,10,"اور یہ کہ ہمیں نہیں معلوم کہ زمین والوں سے کوئی برائی کا ارادہ فرمایا گیا ہے یا ان کے نے کوئی بھلائی چاہی ہے،"
  72,11,"اور یہ کہ ہم میں کچھ نیک ہیں اور کچھ دوسری طرح کے ہیں، ہم کئی راہیں پھٹے ہوئے ہیں"
  72,12,"اور یہ کہ ہم کو یقین ہوا کہ ہر گز زمین اللہ کے قابو سے نہ نکل سکیں گے اور نہ بھاگ کر اس کے قبضہ سے باہر ہوں،"
  72,13,"اور یہ کہ ہم نے جب ہدایت سنی اس پر ایمان لائے، تو جو اپنے رب پر ایمان لائے اسے نہ کسی کمی کا خوف اور نہ زیادگی کا"
