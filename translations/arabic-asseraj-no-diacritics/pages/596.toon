quran[26]{c,v,t}:
  92,15,"لا يصلىها الا الاشقى (لا يصلاها: لا يدخلها، ويقاسي حرها)"
  92,16,الذي كذب وتولى
  92,17,"وسيجنبها الاتقى (وسيجنبها: سيبعد عنها)"
  92,18,الذي يوتي ماله يتزكى
  92,19,"وما لاحد عنده من نعمة تجزى (تجزى: تكافا؛ فليس انفاقه مكافاة لمن احسن اليه)"
  92,20,الا ابتغاء وجه ربه الاعلى
  92,21,ولسوف يرضى
  93,1,"والضحى (والضحى: قسم باول النهار، او كله)"
  93,2,"واليل اذا سجى (سجى: غطى الكون بظلامه، وسكن)"
  93,3,"ما ودعك ربك وما قلى (ما ودعك: ما تركك, وما قلى: ما ابغضك عندما ابطا عليك الوحي)"
  93,4,وللاخرة خير لك من الاولى
  93,5,ولسوف يعطيك ربك فترضى
  93,6,"الم يجدك يتيما فاوى (فاوى: فاواك، ورعاك)"
  93,7,"ووجدك ضالا فهدى (ضالا: لا تدري الوحي، ولا تعلم القران)"
  93,8,"ووجدك عايلا فاغنى (عايلا: فقيرا)"
  93,9,"فاما اليتيم فلا تقهر (فلا تقهر: لا تسي معاملته، وتاخذ ماله)"
  93,10,"واما السايل فلا تنهر (السايل: الفقير الذي يسال، وطالب العلم, فلا تنهر: لا تزجر)"
  93,11,واما بنعمة ربك فحدث
  94,1,"الم نشرح لك صدرك (الم نشرح: قد وسعنا بنور الاسلام بعد الحيرة والضيق)"
  94,2,"ووضعنا عنك وزرك (ووضعنا: حططنا، وغفرنا, وزرك: ذنبك)"
  94,3,"الذي انقض ظهرك (انقض: اثقل)"
  94,4,ورفعنا لك ذكرك
  94,5,فان مع العسر يسرا
  94,6,ان مع العسر يسرا
  94,7,"فاذا فرغت فانصب (فرغت: من اشغال الدنيا, فانصب: فجد في العبادة)"
  94,8,"والى ربك فارغب (فارغب: فتوجه، واطلب، وتضرع)"