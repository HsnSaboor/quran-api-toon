quran[25]{c,v,t}:
  79,1,"Vennaziﾂｴati ﾄ歛rken"
  79,2,"Vennaﾅ殃tati neﾅ殳an"
  79,3,"Vessabihati sebhan"
  79,4,"Fessabikati sebkan"
  79,5,"Felmudebbirati emren"
  79,6,"Yevme tercufurracifetu"
  78,31,"ﾄｰnne lilmuttekﾄｱyne mefazen"
  78,32,"Hadaika ve aﾂｴnaben"
  78,33,"Ve kevaﾂｴﾄｱbe etraben"
  78,34,"Ve keﾂｴsen dihakan"
  78,35,"La yesmeﾂｴune fiyha laﾄ殼en ve la kizzaben"
  78,36,"Cezaen min rabbike ﾂｴataen hﾄｱsaben"
  78,37,"Rabbissemavati velﾂｴardﾄｱ ve ma beynehumerrahmani la yemlikune minhu hﾄｱtaben"
  78,38,"Yevme yekumurruhu velmelaiketu saffen la yetekellemune illa men ezine lehurrahmanu ve kale savaben"
  78,39,"Zalikelyevmulhakku femen ﾅ歛ettehaze ila rabbihi meaben"
  78,40,"ﾄｰnna enzernakum ﾂｴazaben kariyben yevme yenzurulmerﾂｴu ma kaddemet yedahu ve yekululkafiru ya leyteniy kuntu turaben"
  79,7,"Tetbeﾂｴuherradifetu"
  79,8,"Kulubun yevmeizin vacifetun"
  79,9,"Ebsaruha haﾅ殃ﾂｴatun"
  79,10,"Yekulune einna lemerdudune fiylhafireti"
  79,11,"Eiza kunna ﾂｴﾄｱzamen nehﾄｱreten"
  79,12,"Kalu tilke izen kerretun hasiretun"
  79,13,"Feinnema hiye zecretun vahﾄｱdetun"
  79,14,"Feiza hum bissahireti"
  79,15,"Hel etake hadiysu musa"
