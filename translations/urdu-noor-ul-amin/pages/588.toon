quran[28]{c,v,t,f}:
 83,7,"ہمارے پاس بیڑیاں ہیں اور جہنم بھی"
 83,8,"اور گلے میں پھنس جانے والاکھانا اور دردناک عذاب بھی"
 83,9,"جس دن زمین او ر پہاڑ لرزنے لگیں گے اور پہاڑبھربھری ریت کے پھسلتے ہوئے تودے بن جائیں گے"
 83,10,"بلاشبہ ہم نے تمہارے پاس ایک رسول تم پر گواہ بناکربھیجا ہے ، جیسے ہم نے فرعون کے پاس ایک رسول بھیجا تھا"
 83,11,"پھرفرعون نے رسول کی بات نہ مانی توہم نے اسے بڑی سختی کے ساتھ پکڑلیا"
 83,12,"اب اگرتم نے ( اس رسول کا ) انکار کر دیا تواس دن ( کی سختی ) سے کیسے بچوگےجو دن بچوں کو بوڑھابنادے گا"
 83,13,"جس دن آسمان پھٹ جائے گااللہ تعالیٰ کا وعدہ پوراہوکررہیگا"
 83,14,"یہ ( قرآن ) یقینانصیحت ہےجو چاہےاپنے رب کی طرف ( جانے والی ) راہ اختیارکرلے"
 83,15,"تیرارب بخوبی جانتا ہے کہ تو اور تیرے ساتھ کے لوگوں کی ایک جماعت قریباًدوتہائی رات اور کبھی آدھی اور کبھی ایک تہائی رات ( تہجدکی نماز کے لئے ) کھڑے ہوتے ہیں اور رات دن کا پورااندازہ اللہ تعالیٰ کو ہی ہے ، اسے معلوم ہے کہ تم اوقات کا ٹھیک شمارنہیں کرسکو گے ، اسلئے تم کو ( رات کے لمبے قیام سے چھوٹ دے کر ) مہربانی فرمادی ، پس اب جتنا قرآن آسانی سے پڑھ سکوپڑھ لیاکرو ، اسے معلوم ہے کہ تم میں سے کچھ بیمار ہوں گے ، کچھ دوسرے اللہ تعالیٰ کے فضل ( یعنی رزق ) کی تلاش میں سفرکرتے ہیں ، اور کچھ دوسرے اللہ تعالیٰ کی راہ میں جہادکرتے ہیں ، لہٰذ ا جتنا قرآن آسانی سے پڑھ سکوپڑھ لیاکرو ، اور نمازقائم کرو اور زکوۃادا کیا کرواوراللہ کو اچھا قرض ( یعنی ا للہ کی راہ میں مال ) دیتے رہو ، اورجو کچھ بھی تم اپنے لئے آگے بھیجوگے تو اسے اللہ کے ہاں اس حال میں پا ئو گے کہ وہ ( اصل عمل ) سے بہترہے اور اجرکے لحاظ سے بہت زیادہ ہوگا اور اللہ تعالیٰ سے معافی مانگتے رہو ، اللہ یقینابڑابخشنے والا ہے ، رحم کرنے والا ہے"
 83,16,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 83,17,"اے ( محمد ) کمبل اوڑھے سورہے ہو"
 83,18,"اٹھئے اور ( لوگوں کو ان کے رب سے ) ڈرائیے"
 83,19,"اور اپنے رب کی بڑائی بیان کیجئے"
 83,20,"اوراپنے کپڑے پاک رکھئے"
 83,21,"اور گندگی سے دوررہیے"
 83,22,"اور زیادہ حاصل کرنے کے لئے احسان نہ کیجئے"
 83,23,"اوراپنے رب کی خاطر صبر کیجئے"
 83,24,"پس جب صور پھونکاجائے گا"
 83,25,"تویہ دن بڑا کٹھن ہوگا"
 83,26,"کافروں کے لئے آسان نہ ہوگا"
 83,27,"آپ مجھے اور اس آدمی ( ولیدبن مغیرہ ) کوچھوڑدیجئے ، جسے میں نے ( اس کی ماں کے پیٹ سے ) اکیلاپیدا کیا ہے"
 83,28,"اوراسے لمباچوڑامال عطا کیا ہے"
 83,29,"اور ہروقت موجودرہنے واے بیٹے دئیے"
 83,30,"اور میں نے اسے بہت کچھ کشادگی سے دے رکھاتھا"
 83,31,"پھروہ طمع رکھتا ہے کہ میں اسے اور دوں"
 83,32,"ہر گز نہیں کیونکہ وہ ہماری آیات کامخالف ہے"
 83,33,"میں عنقریب اسے ایک سخت چڑھائی چڑھائوں گا"
 83,34,"اسنے غور کیا اور ایک بات دل میں طے کرلی"