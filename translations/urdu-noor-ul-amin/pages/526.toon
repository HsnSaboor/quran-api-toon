quran[26]{c,v,t,f}:
 53,1,"( اور ) مجرم لوگ عذاب جہنم میں ہوں گے جہاں وہ ہمیشہ ہمیشہ رہیں گے"
 53,2,"ان سے عذاب کم نہ کیا جائے گا اور وہ اس میں نجات سے مایوس پڑے رہیں گے"
 53,3,"اور ہم نے ان پر ظلم نہیں کیا بلکہ یہ خودہی ظالم تھے"
 53,4,"وہ پکاریں گے ’’اے مالک ( داروغہ جہنم ) تمہارارب ہماراکام تمام کردے ( تواچھا ہے ) وہ کہے گاتم ہمیشہ یہیں رہو گے"
 53,5,"ہم تمہارے پاس حق لے کرآئے تھے لیکن تم میں سے اکثر حق سے نفرت کرتے تھے‘‘"
 53,6,"یاان لوگوں نے کوئی اقدام کافیصلہ کیا ہے توہم بھی فیصلہ کئے دیتے ہیں"
 53,7,"یاوہ یہ خیال کرتے ہیں کہ ہم ان کے رازاور مشورے سن نہیں رہے کیوں نہیں بلکہ ہمارے فرشتے ان کے پاس ہی لکھتے رہتے ہیں"
 53,8,"آپ کہہ دیجئے کہ اگر رحمن کاکوئی بیٹاہوتا تو سب سے پہلے میں اس کی عبادت کرنے والا ہوتا"
 53,9,"وہ آسمانوں اور زمین کا اور عرش کا مالک ہے اور ان سب باتوں سے پاک ہےجو یہ بیان کرتے ہیں"
 53,10,"آپ انہیں اسی بحث مباحثہ اور کھیل کو د میں چھوڑ دیجئے یہاں تک کہ وہ دن دیکھ لیں جس کاوعدہ کیا جاتا ہے"
 53,11,"آسمانوں میں بھی وہی معبودہے اور زمین میں بھی وہی قابل عبادت ہے اور وہ حکمت والا اور سب کچھ جاننے والا ہے"
 53,12,"بابرکت ہے وہ ذات جس کی آسمانوں اور زمین اورجو ان کے درمیان موجودہیں ، سب پر حکومت ہے قیامت کاعلم اسی کو ہے اور تم سب اسی کی طرف لوٹائے جائوگے"
 53,13,"یہ لوگ اللہ کو چھوڑ کرجنہیں پکارتے ہیں وہ سفارش کا اختیارنہیں رکھتے ہاں ( شفاعت کی اجازت ان کو ملے گی ) جنہوں نے حق ( یعنی توحید ) کوجان کر اس کی گواہی دی"
 53,14,"اور اگرآپ ان سے پوچھیں گے کہ انہیں کس نے پیدا کیا تویقیناکہیں گے کہ’’اللہ نے‘‘پھرانہیں کہاں سے دھوکہ لگتا ہے"
 53,15,"اور ( اللہ کو اپنے رسول کی اس بات کی بھی خبرہے ) جب ا س نے کہاکہ اے میرے رب!بے شک یہ وہ لوگ ہیںجو ایمان نہیں لائینگے"
 53,16,"لہٰذاان سے درگزر کیجئے اور کہہ دیجئے کہ تمہیں سلام کرتاہوں عنقریب انہیں ( سب ) معلوم ہوجائے گا"
 53,17,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 53,18,"حم"
 53,19,"قسم ہے اس کتاب ( قرآن ) کی جو ہربات کو بیان کرنے والی ہے"
 53,20,"بیشک ہم نے اسے ایک خیروبرکت والی رات ( یعنی شب قدر ) میں نازل کیا ہے کیونکہ ہمیں بلاشبہ اس کے ذریعے ( انسانوں کو ) ڈرانا مقصود تھا"
 53,21,"اسی رات میں ہرایک مضبوط کام کا فیصلہ کیا جاتا ہے"
 53,22,"وہ فیصلے ہمارے ہوتے ہیں بیشک ہم ہی رسولوں کو بھیجتے رہتے ہیں"
 53,23,"یہ آپ کے رب کی ( انسانوں پر ) رحمت ہے بلاشبہ وہ سننے والا اور جاننے والا ہے"
 53,24,"وہ آسمانوں اور زمین اورجو کچھ ان کے درمیان موجودہے سب چیزوں کارب ہے اگر تم واقعی یقین کرنے والے ہو"
 53,25,"اس کے سواکوئی معبودنہیں وہی زندہ کرتاا ورمارتا ہے وہ تمہارا رب ہے اور تمہارے پہلے باپ دادوں کابھی"
 53,26,"مگر وہ ( کافر ) شک میں پڑے کھیل رہے ہیں"