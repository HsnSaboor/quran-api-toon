quran[7]{c,v,t,f}:
 3,71,"اورہم جزاکے دن کوجھٹلاتےتھے۔"
 3,72,"یہاں تک کہ ہمیں موت آگئی"
 3,73,"( اس وقت ) سفارش کرنیوالوں کی سفارش انہیں کچھ فائدہ نہ دیگی"
 3,74,"پھر انہیں کیا ہوگیا ہے کہ نصیحت سے منہ موڑتے رہے ہیں"
 3,75,"جیسے وہ بدکے ہوئے گدھے ہوں"
 3,76,"جو ( شیرکے ڈر ) سے بھاگ کھڑے ہوں"
 3,77,"بلکہ ان میں سے ہرایک یہ چاہتا ہے کہ اسے کھلی ہوئی کتاب دی جائے"