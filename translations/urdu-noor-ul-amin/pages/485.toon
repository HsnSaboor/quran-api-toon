quran[7]{c,v,t,f}:
 42,16,"تو ( ابراہیم نے ) کہاکہ میری طبیعت خراب ہے ( میں میلے میں نہیں جاسکتا )"
 42,17,"چنانچہ وہ انہیں پیچھے چھوڑگئے"
 42,18,"تو ابراہیم چپکے سے ان کے معبودوں کی طرف جاگھسے ا ور کہا:تم کھاتے کیوں نہیں ؟"
 42,19,"تمہیں کیا ہوگیا تم بولتے نہیں"
 42,20,"پھر وہ ان پر پل پڑے اور دائیں ہاتھ سے ضربیں لگائیں"
 42,21,"پھر وہ دوڑے ہوئے ابراہیم کے پاس آئے"
 42,22,"ابراہیم نے کہا: کیا تم ان کی عبادت کرتے ہوجنہیں اپنے ہاتھوں سے تراشتے ہو"