quran[7]{c,v,t,f}:
 4,38,"اور دن کی جب وہ ( سورج کو ) نمایاں کردے"
 4,39,"اور رات کی قسم جب وہ ( سورج کو ) چھپالیتی ہے"
 4,40,"اور آسمان کی اور اس ذات کی قسم جس نے اسے بنایا"
 4,41,"اور زمین کی اور اس ذات کی قسم جس نے اسے بچھایا"
 4,42,"اور نفس کی اور اس ذات کی قسم جس نے اسے درست کرکے ٹھیک بنایا"
 4,43,"پھرسمجھ دی اس کو برائی کی اور بچ کرچلنے کی"
 4,44,"یقیناوہ شخص کامیاب ہوگاجس نے اپنے نفس کو گناہوں سے پاک کیا"