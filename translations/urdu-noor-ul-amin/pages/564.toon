quran[19]{c,v,t,f}:
 67,27,"قادرمطلق بادشاہ کے پاس عزت کے مقام میں ( ہوں گے )"
 67,28,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 67,29,"نہایت مہربا ن اللہ ہے"
 67,30,"( جس نے ) قرآن سکھلایا"
 68,1,"انسان کو پیدا کیا"
 68,2,"( پھر ) اسے بولنا سکھلایا"
 68,3,"سورج اور چاند ایک مقرر حساب سے ہیں"
 68,4,"اور ستارے اور درخت ( اپنے رب کو ) سجدہ کرتے ہیں"
 68,5,"اور آسمان کو ( چھت بناکر ) اونچا کیا اور ترازو بنایا"
 68,6,"تاکہ تم تولنے میں زیادتی نہ کرو"
 68,7,"اور وزن کو انصاف سے تولو اور ترازو میں ڈنڈی نہ مارو"
 68,8,"اور زمین کو اس نے ساری مخلوق کے لئے بنایا"
 68,9,"جس میں میوے ہیں اور خوشوں میں لپٹے کھجور والے درخت ہیں"
 68,10,"اور بھوسے والااناج ( یعنی جانوروں اور انسانوں کی خوراک ) اور خوشبودارپھول ہیں"
 68,11,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,12,"اس نے انسان کو سڑی مٹی سے پیدا کیا ہےجو ٹھیکری کی طرح تھی"
 68,13,"اور جنوں کو آگ کے شعلے سے پیدا کیا"
 68,14,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,15,"وہ دونوں مشرقوں کابھی رب ہے اور دونوں مغربوں کا بھی"