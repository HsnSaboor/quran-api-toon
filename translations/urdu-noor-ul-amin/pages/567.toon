quran[26]{c,v,t,f}:
 69,9,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 69,10,"یہ دونوں نہایت سرسبز ہوں گی"
 69,11,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 69,12,"ان دونوں میں دوچشمے ( فوارہ کی طرح ) ابلتے ہوئے ہوں گے"
 69,13,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 69,14,"دونوں میں پھل ، کھجوریں اور انارہوں گے"
 69,15,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے؟"
 69,16,"ان میں خوب سیرت اور خوبصورت عورتیں ہوں گی"
 69,17,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 69,18,"( گوری رنگت کی ) حوریں خیموں میں ٹھہرائی ہوئی ہوں گی"
 69,19,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے؟"
 69,20,"انہیں پہلے کسی انسان یاجن نے چھوا نہ ہوگا"
 69,21,"پس ( اے جن وانس ) تم اپنے ربکی کن کن نعمتوں کو جھٹلائوگے؟"
 69,22,"جنتی لوگ سبز قالینوں اور عمدہ فرشوں پر تکیہ لگائے ہوں گے"
 69,23,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے؟"
 69,24,"بہت ہی بابرکت ہے آپ کے اس رب کانام جو جلال اور عزت والا ہے"
 69,25,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 69,26,"جب ( قیامت ) قائم ہوجائے گی"
 69,27,"توکوئی چیزاس کے وقوع پذیرہونے کو جھٹلانے والی نہیں ہوگی"
 69,28,"یہ تہہ وبالاکرنے والی ہوگی"
 69,29,"جس دن زمین پوری شدت کے ساتھ ہلادی جائے گی"
 69,30,"اور پہاڑاس طرح ریزہ ریزہ کر دئیے جائیں گے"
 69,31,"پس وہ غبار بن کراڑنے لگیں گے"
 69,32,"لوگو!اس وقت تم تین گروہ بن جائوگے"
 69,33,"( ایک تو ) دائیں ہاتھ والے ہوں گے ، کیا ہی ( خوش قسمت ) ہوں گے داہنے ہاتھ والے"
 69,34,"اور ( دوسرے ) بائیں ہاتھ والے ہوں گے ، کیا ہی ( بدقسمت ) ہوں گے بائیں ہاتھ والے"