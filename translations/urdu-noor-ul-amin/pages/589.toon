quran[27]{c,v,t,f}:
 83,35,"پس وہ ہلاک ہو اس نے کیسی بات سوچی"
 83,36,"پھروہ ہلاک ہواس نے کیسی بات سوچی"
 84,1,"پھراس نے دیکھا"
 84,2,"پھراس نے پیشانی پکڑی اور براسامنہ بنایا"
 84,3,"پھروہاں سے چلا گیا اور تکبر میں آگیا"
 84,4,"آخرکاریہ کہایہ تومحض جادوہےجو نقل درنقل چلاآرہا ہے"
 84,5,"یہ محض کسی انسان ہی کاقول ہے"
 84,6,"جلد ہی میں اسے جہنم میں جھونک دونگا"
 84,7,"اور آپ کیا جانیں کہ جہنم کیا ہے"
 84,8,"وہ نہ کسی چیزکوباقی رکھے گی اور نہ چھوڑے گی"
 84,9,"کھال کو جھلس دینے والی ہوگی"
 84,10,"اس پر اُنیس فرشتے مقررہیں"
 84,11,"ہم نے جہنم کے محافظ فرشتوں کو ہی بنایا ہے اور ہم نے ان کی تعدادصرف کافروں کی آزمائش کے لئے مقررکی ہے تاکہ اہل کتاب کو یقین آجائے اور ایمانداروں کا ایمان زیادہ ہو اور اہل کتاب اور ایماندار کسی شک میں نہ رہیں اور تاکہ دل کے مریض اور کافریہ نہ کہیں کہ: بھلااللہ کا اس مثال سے کیا مطلب؟اسی طرح اللہ جسے چاہےگمراہ کردیتا ہے اور جسے چاہےہدایت دیتا ہے اور آپ کے رب کے لشکروں کو خوداس کے سواکوئی نہیں جانتا اور یہ ( ذکر جہنم ) صرف اسلئے ہے کہ لوگوں کو نصیحت ہو"
 84,12,"چاندکی قسم مگریہ ہر گز نہیں مانیں گے"
 84,13,"اور رات کی ( قسم ) جب وہ جانے لگے"
 84,14,"اور صبح کی جب وہ روشن ہوجائے"
 84,15,"بیشک جہنم بڑی خطرناک چیزوں میں سے ایک ہے"
 84,16,"وہ لوگوں کے لئے بڑی ڈرانے والی چیز ہے"
 84,17,"جوتم میں سے بھلائی کی طرف آگے بڑھنا یاپیچھے رہناچاہے"
 84,18,"ہرشخص اپنے اعمال کے بدلے گروی ہے"
 84,19,"سوائے دائیں ہاتھ والوں کے"
 84,20,"وہ جنتوں میں ہوں گے ، پوچھیں گے"
 84,21,"مجرموں سے"
 84,22,"’’تمہیں کیا چیزجہنم میں لے گئی؟‘‘"
 84,23,"وہ کہیں گے:’’ہم نماز ادانہیں کرتے تھے"
 84,24,"اور نہ مسکینوں کو کھاناکھلاتے تھے"
 84,25,"اور بیہودہ شکوک وشبہات پیدا کرنے والوں کے ساتھ ہم بھی لگے رہتے تھے"