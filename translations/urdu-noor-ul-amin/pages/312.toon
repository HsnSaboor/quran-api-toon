quran[15]{c,v,t,f}:
 19,96,"اتنے میں شہر والے خوشی خوشی لوط کے ہاں آپہنچے"
 19,97,"لوط نے ان سے کہا:’’یہ میرے مہمان ہیں لہٰذامجھے ذلیل نہ کرو"
 19,98,"اللہ سے ڈرو اور مجھے رسوانہ کرو‘‘"
 20,1,"وہ کہنے لگے: کیا ہم نے تجھے منع نہیں کیا تھاکہ تم دنیا جہاں کی حمایت نہ کیا کرو‘‘"
 20,2,"لوط نے کہا: ’’اگرتمہیں کچھ کرناہی ہے تویہ میری بیٹیاں ہیں ‘‘ ( یعنی ان سے نکاح کرسکتے ہو )"
 20,3,"( اے نبی ) آپ کی جان کی قسم!اس وقت وہ اپنی مستی میں دیوانے ہورہے تھے"
 20,4,"آخرسورج نکلنے کے وقت انہیں زبردست دھماکہ نے آ لیا"
 20,5,"پھرہم نے اس بستی کے اوپرکے حصہ کو نیچے کردیا اور ان پر کنکر یلے پتھروں کی بارش کردی"
 20,6,"بلاشبہ اس واقع میں عبرت حاصل کرنے والوں کے لئے کئی نشانیاں ہیں"
 20,7,"اور وہ بستی بالکل شارع عام پر واقع ہے"
 20,8,"بلاشبہ اس میں ایمان لانے والوں کے لئے نشانی ہے"
 20,9,"اورایکہ والے ( یعنی قوم شعیب کے لوگ ) بھی یقیناظالم تھے"
 20,10,"چنانچہ ہم نے اس سے ( بھی ) انتقام لے لیا اور یہ دونوں ہی بستیاں شاہراہ پر واقع تھیں"
 20,11,"اور وادی حجرکے لوگوں نے ( بھی ) ہمارے رسولوں کو جھٹلایاتھا"
 20,12,"ہم نے انہیں اپنی نشانیاں دیں مگر انہوں نے ان سے منہ موڑ لیا"