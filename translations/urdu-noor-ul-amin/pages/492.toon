quran[14]{c,v,t,f}:
 43,34,"( فرشتے کہتے ہیں ) کہ ہم میں سے ہرایک کادرجہ مقررہے ( جس سے ہم تجاوز نہیں کرتے )"
 43,35,"اور بیشک ہم ( اللہ کے حضور ) صف باندھے رہتے ہیں"
 43,36,"اور اسی کی تسبیح کرنیوالے ہیں"
 43,37,"اور یہ ( مشرکین ) لوگ توکہا کر تے تھے کہ"
 43,38,"اگر ہمارے پاس پہلے لوگوں کی طرح کتا ب ِالٰہی آئی ہوتی"
 43,39,"تو ہم بھی اللہ کے مخلص بندے ہوتے"
 43,40,"توانہوں نے انکار کیا ، جلدہی انہیں معلوم ہوگا"
 43,41,"البتہ ہمارا وعدہ پہلے ہی اپنے رسولوں کے حق میں صادر ہو چکا ہے"
 43,42,"کہ یقیناان کی مدد کی جائے گی"
 43,43,"اور یقیناہمارا لشکرہی غالب رہیگا"
 43,44,"پس آپ کچھ مدت تک ان سے اپنی توجہ ہٹالیجئے"
 43,45,"اورانہیں دیکھتے رہیے ، پس یہ جلدہی اپنا انجام دیکھ لیں گے"
 43,46,"کیا یہ ہمارے عذاب کی جلدی مچارہے ہیں"
 43,47,"جب وہ ان کے صحن میں اترے گاتو وہ صبح ڈرائے جانے والوں کے لئے بہت بری ہوگی"