quran[10]{c,v,t,f}:
 58,12,"طور ( پہاڑ ) کی قسم"
 58,13,"اور لکھی ہوئی کتاب کی قسم"
 58,14,"جوکھلے ہوئے صفحات میں ہے"
 58,15,"اور آبادگھرکی قسم"
 58,16,"اور اونچی چھت ( یعنی آسمان ) کی قسم"
 58,17,"اورجو ش مارتے ہوئے سمندرکی قسم"
 58,18,"کہ آپ کے رب کا عذاب واقع ہو کے رہیگا"
 58,19,"اسے کوئی روکنے والانہیں"
 58,20,"جس دن آسمان تیزی سے لرزنے لگے گا"
 58,21,"اور پہاڑتیزی سے اڑتے پھریں گے"