quran[8]{c,v,t,f}:
 3,158,"پھراس میں نہ وہ مرے گا اور نہ زندہ رہیگا"
 3,159,"یقیناوہ شخص کامیاب ہوگاجو ( کفروشرک سے ) پاک ہو گیا"
 3,160,"اور اپنے رب کانام لیتارہا ، پھر نمازاداکی"
 3,161,"بلکہ تم تودنیاکی زندگی کو ترجیح دیتے ہو"
 3,162,"حالانکہ آخرت بہتر اور ہمیشہ باقی رہنے والی ہے"
 3,163,"یہی بات پہلے صحیفوں میں ( لکھی گئی تھی )"
 3,164,"( یعنی ) ابراہیم اور موسیٰ کے صحیفوں میں"
 3,165,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"