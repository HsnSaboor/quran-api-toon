quran[7]{c,v,t,f}:
 4,80,"اور آپ اپنے رب کی نعمتوں کاذکرکرتے رہیے"
 4,81,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 4,82,"کیا ہم نے ( اسلام کے لئے ) آپ کاسینہ نہیں کھول دیا"
 4,83,"اور ہم نے آپ کے دل سے وہ بو جھ اتاردیا"
 4,84,"جوآپ کی کمرتوڑرہاتھا"
 4,85,"اورآپ کے لئے آپ کاذکربلند کیا"
 4,86,"بلاشبہ ہر مشکل کے ساتھ آسانی ہے"