quran[7]{c,v,t,f}:
 4,27,"وہ ہے کسی گردن کو غلامی سے چھڑانا"
 4,28,"یافاقہ کے دنوں میں کھاناکھلانا"
 4,29,"کسی رشتہ دار اور یتیم کو"
 4,30,"یامٹی میں پڑے کسی مسکین کو"
 4,31,"پھروہ ان میں سے ہوجو ایمان لائے اور جنہوں نے ایک دوسرے کو ( راہ حق میں ) صبر اور رحم دلی کی نصیحت کی"
 4,32,"یہی لوگ ( روزقیامت ) دائیں جانب والے ہوں گے"
 4,33,"اور جنہوں نے ہماری آیتوں سے انکار کیا وہی لوگ بائیں جانب والے ہیں"