quran[7]{c,v,t,f}:
 63,5,"کیا اسے خبر نہیںجو موسیٰ کے صحیفوں میں ہیں"
 63,6,"اور ابراہیم ( کے صحیفوں میں بھی ) جس نے ( اپنے رب کے ساتھ ) وفاکی"
 63,7,"کہ’’ ( قیامت کے دن ) کوئی بوجھ اٹھانے والادوسرے کا بوجھ نہیں اٹھائے گا"
 63,8,"اور یہ کہ انسا ن کے لئے وہی کچھ ہےجو اس نے کوشش کی"
 63,9,"اور یہ کہ اس کاعمل اسے دکھایاجائے گا"
 63,10,"پھراسے اس کا پورا پورا بدلہ دیا جائے گا"
 63,11,"اور یہ کہ ہرایک کو بالآخر آپ کے رب کے پاس پہنچنا ہے"