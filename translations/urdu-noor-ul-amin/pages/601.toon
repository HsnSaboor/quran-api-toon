quran[17]{c,v,t,f}:
 103,1,"اور ( اے کفارمکہ ) تمہاراصاحب مجنون نہیں ہے"
 103,2,"اوراس نے اس ( جبریل ) کو روشن افق پر دیکھا ہے"
 103,3,"اور وہ غیب کی باتوں کو ( لوگوں تک ) پہنچانے میں بخیل نہیں ہے"
 104,1,"اور نہ یہ ( قرآن ) کسی شیطان مردودکاقول ہے"
 104,2,"پھرتم کہا ں جارہے ہو؟"
 104,3,"یہ تو سارے جہان والوں کے لئے ایک نصیحت ہے"
 104,4,"تم میں سےجو بھی سیدھا چلناچاہتا ہو"
 104,5,"اور تم چاہ نہیں سکتے مگروہی سب کچھ جو اللہ رب العالمین چاہتا ہو"
 104,6,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 104,7,"جب آسمان پھٹ جائے گا"
 104,8,"اور ستارے ( ٹوٹ کر ) بکھر پڑیں گے"
 104,9,"اور سمندر پھاڑ دیئے جائینگے"
 105,1,"اورقبریں زیروزبرکردی جائینگی"
 105,2,"( اس دن ) ہرشخص جان لے گا کہ اس نے آگے کیا ( عمل ) بھیجا اور پیچھے کیا چھوڑا"
 105,3,"اے انسان!تجھے اپنے رب کریم سے کس چیزنے دھوکے میں ڈالے رکھا؟"
 105,4,"جس نے تجھے پیدا کیا پھر درست کیا پھر متوازن ( انسان ) بنایا"
 105,5,"( اور ) جس شکل میں بھی چاہاتیرے جسم کی ترکیب کی"