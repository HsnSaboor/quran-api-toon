quran[8]{c,v,t,f}:
 3,187,"آپ ان پر محاسب نہیں ہیں ( یعنی انکاحساب اللہ کے ذمہ ہے )"
 3,188,"البتہ جو شخص منہ موڑے گا اور کفر کرے گا"
 3,189,"تواللہ اسے بہت بڑی سزادے گا"
 3,190,"بلا شبہ انہیں ہماری طرف ہی واپس آنا ہے"
 3,191,"پھرانکاحساب لیناہمارے ہی ذمہ ہے"
 3,192,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 3,193,"فجرکے وقت کی قسم"
 3,194,"اور ( ذی الحجہ کی ابتدائی ) دس راتوں کی قسم"