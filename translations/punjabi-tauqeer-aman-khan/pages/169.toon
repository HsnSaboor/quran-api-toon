quran[6{c,v,t}:
7,150,فیر جدوں واپس لوٹے موسیٰ،ؑاپنی قوم ول غضب ناک تے افسردہ سن فرمایا بہت بری جانشینی کیتی اے تُسی میرے بعد،کی جلدبازی کیتی اے تُسی اپنےرَب دا حکم (آن توں پہلے ہی) تے سُٹ دِتیاں تختیاں (رب دے حکم دیاں) تے پھڑ لیا سر (دے وَال)اپنے بھائی دے کھچدے ہوئےاپنے ول۔ او بولے میری ماں جائے، بے شک اُنہاں لوکاں نےمینوں کمزور سمجھیا تے قریب سی کہ قتل کر دیندے مینوں، سو خوش نہ کرمیرے دشمناں نوں تے نہ مینوں کر شامل ظالم لوکاں دے نال
7,151,موسیٰ،ؑ نے) فرمایا اے میرےرَب بخش دے مینوں تے میرے بھائی نوں تے داخل فرما سانوںاپنی رحمت وچ،تے توں تے سب توں وڈا رحم کرن والا ایں
7,152,بے شک جنہاں نے بنا لِتَّا سی وچھے (نوںرَب) عنقریب پہنچے گا اُنہاں نوں غضب اپنےرَب دا تے ذلیل ہون گےدنیاوی زندگی وچ۔ تے ایسی ہی سزا اسی دینے آں بہتان بنھن والیاں نوں
7,153,تے جنہاں لوکاں نے برے عمل کیتے فیر توبہ کر لئی ایس توں بعدتے ایمان لے آئے بے شک تیرارَب ایس (توبہ) توں بعد معاف کرن والا تے رحم کرن والا اے
7,154,تے جدوں ٹھنڈا ہویا موسیٰ،ؑ دا غصہ تے چُکیاں تختیاں (تورات دیاں)تے اودھی تحریر وچ ھدایت تے رحمت سی اُنہاں لوکاں لئی جیہڑے اپنےرَب توں ڈردے سن
7,155,تے چن لئے موسیٰ،ؑ نےاپنی قوم دے ستر بندےساڈے مقررہ وقت تے ملاقات لئی فیر جدوں اُنہاں نوں پھڑ لیا زلزلے نے تے عرض کیتی (موسیٰ،ؑ نے) اے میرےرَب جے توں چاہنداتے ہلاک کر دیندا اُنہاں نوں ایس توں پہلے تے مینوں وی۔ کی توں ہلاک کریں گا سانوں جو کہ فعل کیتا اےچند) بے وقوفاں نے ساڈے وچوں؟ نئیں اے مگر آزمائش تیرے ولوں۔ توں گمراہ کریں ایس توں جس نوںچاہویں تے ھدایت دیویں جس نوں چاہویں۔ توں ای ساڈا کارساز ایں، سو بخش دے سانوں تے رحم فرما ساڈے اُتے تے توں بہترین بخشن والا ایں
