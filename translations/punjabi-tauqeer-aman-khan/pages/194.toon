quran[7{c,v,t}:
9,41,نکلو تُسی خواہ ہلکے او یا بھاری تے جہاد کرواپنے مالاں نال تےاپنی جاناں نال اللہ دی راہ وچ۔ اے بہتر اے تہاڈے لئی جے تُسی علم رکھدے او
9,42,جے ہوندا مال غنیمت لینا آسان تے سفر آسان تے ضرور تہاڈے پیچھے ہوندے لیکن بڑا مشکل سی انہاں لئی اے رستہ۔ تے ہُن قسماں کھاون گے اللہ دیاں کہ جے ہو سکدا ساڈے توں تے ضرور نکلدے تہاڈے نال، ہلاکت وچ پا رہے نیں اےاپنی جاناں نوں تے اللہ جاندا اے کہ اے بے شک بہت جھوٹے نیں
9,43,معاف کرے اللہ تہانوں (اے نبیؑ)کیوں تُسی اجازت دِتی انہاں نوں حتی کہ ظاہر ہو جائے تہاڈے اُتے اولوک جیہڑےسچے نیں تے جان لیندے تُسی جھوٹیاں نوں
9,44,نئیں منگدے رخصت تہاڈے توںاو جیہڑے ایمان رکھدے نیں اللہ اُتے تے یوم آخرت اُتے۔ (ایس تے) کہ جہاد کرناپنے مالاں نال تےاپنی جاناں نال۔ تے اللہ جاندا اےاودھے کُولوں ڈرن والیاں نوں
9,45,بے شک جو رخصت طلب کردے نیں تہاڈے توں او نے جیہڑے نئیں ایمان رکھدے اللہ اُتے تے یوم آخرت اُتے تے شک وچ نیں انہاں دے دل سو او اپنے شک وچ بھٹک رہے نیں
9,46,تے جے او ارادہ کردے نکلن دا (جہاد لئی) تے ضرور تیار کردے اودھے لئی ساز و سامان لیکن ناپسند سی اللہ نوں انہاں دا اُٹھنا تے نکلنا سو انہاں نوں کاہل کر دِتا تے کہہ دِتا کہ بیٹھے رہو (عورتاں تے بچیاں نال) بیٹھن والیاں دے نال
9,47,جے او نکلدے تہاڈے نال تے اضافہ نہ کردے تہاڈا بلکہ خرابی وَدھاندے تے نسدے پھردے تہاڈے درمیان فتنہ پھیلان لئی تہاڈے لئی،تے تہاڈے درمیان جاسوس نیں انہاں دے۔ تے اللہ خوب جاندا اے انہاں ظالماں نوں
