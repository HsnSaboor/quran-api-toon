quran[8{c,v,t}:
2,62,بیشک جولوک ایمان والے نیں تے جولوک یہودی نیں تے عیسائی تے صابی۔ تے جو اللہ پاک تے ایمان لے آیا تے یوم آخرت تےتے نیک کم کیتے اُنہاں لئی بہترین اجر اےاپنےرَب کولوں۔تے نہ کوئی خوف اے اُنہاں نوں تے نہ او غمگین ہون گے
2,63,تے جدوں اسی لِتَّاتہاڈے کولوںوعدہ چُک کے تہاڈے سراں تے پہاڑ (ڈرا کے) کہ پھڑو اللہ دی کتاب نوںمضبوطی نال تے ذکر کرواپنےرَب دا جو اُس وچ اے تاں جے تُسی عذاب توں بچ سکو
2,64,فیر تُسی مُکر گئے ایس وعدے توں تے جے اللہ دا فضل نہ ہوندا تُہاڈے نال تے اودھی رحمت تے تُسی تباہ و بربَّاد ہو جانا سی
2,65,تے البتہ تُسی جاندے اوجنہاں لوکاں نے توڑیا سی تہاڈے وچوں ہفتے دا قانون تے اللہ نے اُنہاں نوں کیہاکہ تُسی بن جاؤ بندر ذلیل
2,66,تے بنا دِتا اسی دھشت جولو ک موجود سن تے جو آن والے سن تے نصیحت نیک لوکاں لئی اے
2,67,تے جدوں کہیا موسیٰ،ؑ نےاپنی قوم نوں کہ بیشک اللہ تُہانوں حکم دیندا اے کہ ذبح کرو اک گاں۔ تے او کہن لگے کہ توں ساڈے نال مزاق کرنا ایں۔ موسیٰ،ؑ نے کہیا میں پناہ منگناں واں اللہ توں کہ میں ہوواں جاہلاں وچوں
2,68,او بولے کہ دعا کرو ساڈے لئیاپنےرَب کولوں کہ سانوں کھوَلک ے دسّے (گاں) دے بارے۔ موسیٰ نے کہیا بیشک اللہ فرماندے نیں کہ او گاں نہ بُڈھی ہوئے تے نہ بچی۔ جوان درمیانی عمر دی۔ تے پورا کرواو حکم جیہڑا دِتا جاوئے
2,69,او بولے کہ دعا کرو ساڈے لئی اپنے کولوں کہ دسے سانوں اودھا رنگ کیسا ہووے۔ تے کہیا بیشک اللہ فرماندے نیں کہ او گاں پیلے رنگ دی ہووے۔ایسے شوخ رنگ دی کہ ویکھن والیاں نوں چنگی لگے
