quran[7{c,v,t}:
9,123,اے ایمان والیو جنگ کرو انہاں نال جو تہاڈے قریب نیں کافراں وچوں تے چاہیے کہ او پاؤن تہاڈے وچ سختی۔ تےجان لو کہ اللہ متقیاں دے نال اے
9,124,تے جدوں وی نازل ہوندی اےکوئی سورۃ تے انہاں وچوں بعض کہندے نیں کہ تہاڈے وچوں کس دا ودھایا اے ایس اُتے ایمان،سو او لوک جیہڑے ایمان والے نیں انہاں لئی تے اضافہ ہویا اے ایمان وچ تے اوخوشیاں مناندے نیں
9,125,تے اولوک جنہاں دے دلاں وچ کوئی بیماری اےتے اضافہ ہوندا اے انہاں لئی کندگی دا انہاں دی گندگی وچ تے او مردے وی کفر دی حالت وچ نیں
9,126,کی نئیں ویکھدے اے کہ انہاں نوں آزمایا جاندا اے ہر سال اک واری یا ں د و واری فیر وی اے توبہ نئیں کردے تے نہ اے نصیحت پھڑدے نیں
9,127,تے جدوں کوئی نازل ہوندی اے سورۃ تے ویکھن لگدے نیں اک دوجے نوں۔کی تہانوں کوئی ویکھدا اے کوئی فیر او پھِر جاندے نیں۔ پھیر دِتا اے اللہ نےانہاں دے دلاں نوں کیونکہ اولوک سمجھ نئیں رکھدے
9,128,البتہ تہاڈے کوَل آیا اےاک رسوَل تہاڈےای وچوں ناگوار اے اودھے لئی کہ تہانوں تکلیف پہنچےتے لالچ اے تہاڈے لئی (بھلائی دا) تے مومناں لئی بڑا شفیق تے مہربَّان
9,129,فیر جے اے منہ پھیر دے نیں تے کہہ دیو کافی اے میرے لئی اللہ نئیں اے کوئی معبود سوائے اودھےتے اوسے اُتے میں بھروسہ کیتا اے تے او مالک اے عرشِ عظیم دا
