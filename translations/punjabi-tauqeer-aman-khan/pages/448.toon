quran[25{c,v,t}:
37,52,کہندا ہوندا سی کہ توں وی (یوم حساب نوں) سچ مننا ایں
37,53,کی جدوںاسی مرگئے تے ہو گئے مٹی تے ہڈیاں کی سانوں جزا سزا ملے گی
37,54,اوتھے کوئی) کہے گا کہ تُوں جھانک کے (جہنم وچ) ویکھ لے
37,55,سو او جھانکیا تے ویکھیا اوس نوں جہنم دے درمیان وچ
37,56,فوراً) بولیا اللہ دی قسم قریب سی کہ توں مینوں بربَّاد کر دیندا
37,57,تے جے نہ ہوندا فضل میرےرَب داتے میں وی ہوندا اے پھڑے ہوئے لوکاں وانگ
37,58,کی ہُن سانوں موت نئیں آئے گی
37,59,مگراوہی موت جو سانوں پلے آئی سی تے نہ ہی سانوں عذاب دِتا جائے گا
37,60,بے شک ایہوہی اے بڑی وڈی کامیابی
37,61,ایسیاں (نعمتاں) چیزاں لئی چاہی دا اے عمل کرنا (نیک) عمل کرن والیاں نوں
37,62,کی اے بہتر اے مہمانی یا زقوم دا درخت
37,63,اسی بنایا اے (سب کجھ)آزمائش لئی ظالماں واسطے
37,64,بے شک او درخت نکلدا اے جڑ وچوں جہنم دی
37,65,اوس دے خوشے گویا کہ او سِر نیں شیطاناں دے
37,66,بے شک انہاں نوںکھانا ہوئے گا ایس وچوں فیر بھرنے ہون گے ایسے نال اپنے ڈھڈ ( پیٹ)
37,67,فیر بے شک انہاں لئی ایدھے وچ ملے گا پین لئی کھولدا ہویا پانی
37,68,فیر بے شک انہاں سب دا لوٹناجہنم وَل ای ہوئے گا
37,69,بے شک انہاں نے پایااپنے باپ دادا نوں گمراہ
37,70,سو او انہاں ہی دے نقشِ قدم ا ُتےچلے جاندے نیں
37,71,تے بے شک گمراہ ہو گئے انہاں توں پہلے بہت سارے پہلےلوک
37,72,تےبے شک بھیجے نیں اسی انہاں وچ ڈر سُنان والے
37,73,سو ویکھو کیسا ہویاانجام جنہاں نوں ڈرایا گیا سی
37,74,سوائے اللہ دے بندیاں توں جو خالص چنے ہوئے نیں
37,75,تے بے شک پکاریا سی سانوں نوح،ؑ نے سو بڑی چنگی اسی دعا قبوَل کرنے والے آں
37,76,تے نجات دِتی اوس نوں تےاودھے گھر والیاں نوں اسی بڑی وڈی مصیبت توں
