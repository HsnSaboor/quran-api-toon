quran[27{c,v,t}:
55,41,پہچانے جان گے مجرم گنہگاراپنے چہریاں توں فیر گھسیٹیا جائے گا پیشانی دے والاں توں تے پیراں توں پھڑکے
55,42,فیراپنےرَب دی کس کس قدرت دا انکار کرو گے تُسی
55,43,اے او جہنم اے جس نوں جھٹلاندے سن اے مجرم لوک
55,44,چکر لان گے او (مجرم) اگ تے کھولدے پانی دے درمیان
55,45,فیراپنےرَب دی کس کس قدرت دا انکار کرو گے تُسی
55,46,تے جو کوئی ڈریااپنےرَب دے سامنے کھڑا ہون توں دو جنتاں نیں (اودھے لئی)
55,47,فیراپنےرَب دی کس کس نعمت نوں تُسی جھٹلاؤ گے
55,48,ہری بھری ڈاہلاں والی (جنت)
55,49,فیراپنےرَب دی کس کس نعمت نوں تُسی جھٹلاؤ گے
55,50,انہاں دوناں (جنتاں) وچ دو چشمے وگدے ہون گے
55,51,فیراپنےرَب دیکس کس نعمت نوں تُسی جھٹلاؤ گے
55,52,انہاں دوناں (جنتاں) وچ ہر قسم دے پھلاں دیاں دو دو قسماں ہون گئیاں
55,53,فیراپنےرَب دی کس کس رحمت نوں تُسی جھٹلاؤ گے
55,54,تکیہ لائے بیٹھے ہون گےفرشاں اُتے جنہاں دے استر (قالین) موٹے ریشم دے ہون گے تے میوے (پھل) دوناں جنتاں دےجھکے ہوئے ہون گے
55,55,فیراپنےرَب دی کس کس نعمت نوں تُسی جھٹلاؤ گے
55,56,انہاں وچ شرمیلی نگاہاں والیاں، ہرگز نہ چھویا ہوئے گا انہاں نوں کسے انسان نے انہاں توں پہلے تے نہ ہی کسے جن نے
55,57,فیراپنےرَب دیکس کس مہربَّانی نوں تُسی جھٹلاؤ گے
55,58,حسن انہاں دا یاقوت تے مرجان جیویں (ہوئے گا)
55,59,فیراپنےرَب دی کس کس نعمت نوں تُسی جھٹلاؤ گے
55,60,کی بدلہ ہوئے گا احسان دا صرف احسان ہی احسان
55,61,فیراپنےرَب دے کس کس احسان نوں تُسی جھٹلاؤ گے
55,62,تے انہاں دوناں (جنتاں) توں علاوہ دو جنتاں ہور نیں
55,63,فیراپنےرَب دی کس کس نعمت نوں تُسی جھٹلاؤ گے
55,64,(باغات) سرسبز گھنے سیاہ
55,65,فیراپنےرَب دی کس کس نعمت نوں تُسی جھٹلاؤ گے
55,66,انہاں دوناں وچ چشمے نیں ابلدے ہوئے
55,67,فیراپنےرَب دی کس کس نعمت نوں تُسی جھٹلاؤ گے
