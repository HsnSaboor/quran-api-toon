quran[8{c,v,t}:
16,65,تے اللہ ای نازل کردا اےآسماناں توں پانی فیر زندہ کیتا ایس توں زمین نوں بنجر ہون توں بعد بے شک ایدھے وچ بڑی نشانیاں نیں انہاں لوکاں لئی جیہڑے سُندے نیں
16,66,بے شک تہاڈے لئی چوپایاں وچ وی اک سبق اے۔ پلانیں آں اسی تہانوں اوس توں جو انہاں دے پیٹ دےدرمیان گوبر تے خون وچوں دودھ (نکلدا اے) خالص تے خوشگوار پین والیاں لئی
16,67,تے پھلاں وچوں کھجور تے انگور (دے رس نال) تُسی بناندے او اوس توں شراب تے بہترین رزق۔ بے شک ایدھے وچ نشانی اےانہاں لوکاں لئی جیہڑے عقل رکھدے نیں
16,68,تے وحی کیتی تیرےرَب نے شہید دی مکھی وَل کہتو بنالے پہاڑاں وچ اپنے گھر (چھتے) تے درختاں اُتے تے اوتھےجتھے بلند چھتاں نیں
16,69,فیر کھا پی ہر طرح دے پھلاں توں فیر چل پھررستیاں اُتےاپنےرَب دے نرم تے ہموار۔ نکلدا اے انہاں دے پیٹ وچوں اک مشروب مختلف اودھے رنگ نیں اودھے وچ شفا اے انساناں لئی۔ بے شک ایدھےوچ اک نشانی اے غوروفکر کرن والے لوکاں لئی
16,70,تے اللہ ای نے پیدا کیتا اے تہانوںفیر اوہی تہانوں موت دیندا اے، تے تہاڈے وچوں بعض جیہڑے پہنچ جاندے نیں بڑھاپے دی عمر نوں تاں جے او نہ جان سکن سب کجھ جانن توں بعد کجھ وی، بے شک اللہ سب کجھ جانن والاتے طاقت ور اے
16,71,تے اللہ نے نے فضیلت دِتی تہاڈے وچوں بعض اُتے بعض نوںرزق وچ، سو جنہاں لوکاں نوں فضیلت دِتی اے (ہرگز ایسے نئیں) کہ ونڈ لین اپنا رزق اپنےغلاماں وچ تاں جے او وی اودھے وچ برابر دے (حصہ دار) بن جان۔ تے فیر وی اےاللہ دیاں نعمتاں دا انکار کردے نیں
16,72,تے اللہ ای نے بنایا اے تہاڈے لئی تہاڈے ہی وچوں تہاڈا جوڑا تے بنائے (پیدا کیتے) تہاڈے لئی تہاڈے جوڑیاں وچوں بیٹے تے پوتےتے رزق دِتا تہانوں پاکیزہ مزیدار۔ سو کی اے باطل تے ایمان رکھدے نیں تےاللہ دیاں نعمتاں دا او انکار کردے نیں
