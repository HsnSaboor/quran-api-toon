quran[5{c,v,t}:
9,107,تے او جنہاں نے بنائی اے اک مسجد ضررار (مشرکاں لئی)کفر کرن لئی تے تفرقہ پان لئی اہل ایمان دے درمیان تے گھات دی جگہ بنان لئی اودھے لئی جو جنگ کر چکیا ہوئے اللہ تے اودھے رسوَل نال ایس توں پہلے۔ تے ضرور قسماں کھان گےکہ ساڈا ارادہ سوائے بھلائی دے (کجھ نئیں) تے اللہ گواہی دیندا اے کہ اے صرف جھوٹے نیں
9,108,نہ کھڑے ہونا تُسی ایدھے وچ کدی وی۔ تے جس مسجد دی بنیادتقویٰ تے رکھی ہوئے پہلے دن توں زیادہ مستحق اے کہ کھڑے ہو وہ تُسی اودھے وچ۔اودھے وچ ایسےلوک نیں جیہڑے پسند کردے نیں کہ او ہمیشہ پاک رہن۔ تے اللہ پسند کردا اےپاک رہن والیاں نوں
9,109,سو کی او جس نے بنیاد رکھی اپنی عمارت دی اللہ دےخوف اُتے تے اودھی رضامندی تے بھلائی لئی بہتر ہے یا او (شخص) جس نے بنیاد رکھی اپنی عمارت دی کنارے تے کھائی دے جو ڈگن والی ہوئے تے لے ڈگے اوس نوں دوزخ دی اگ وچ۔تے اللہ نئیں ھدایت دیندا ظالم قوم نوں
9,110,ہمیشہ رہے گی (ذلت وچ)انہاں دی عمارت جس دی بنیاد شک تے رکھی، انہاں دے دلاں وچ مگر اے کہ ٹکڑے ٹکڑے ہو جان ا نہاں دے دل۔ تے اللہ جانن والا تے حکمت والا اے
9,111,بے شک اللہ نے خرید لئیاں نیں مومناں دیاں جاناں انہاں توں تے انہاں دے مال ایس دے بدلے کہ انہاں نوں ملے جنت۔(اے مومن) جنگ کردے نیں اللہ دی راہ وچ فیر قتل کردے نیں تے شہید ہوندے نیں۔اے وعدہ اللہ دے ذمے اے تے سچا اے تورات وچ تے انجیل وچ تے قرآن وچ۔تے کون شخص اے زیادہ پورا کرن والااَپنا وعدہ اللہ نال سو خوشیاں مناؤاپنے سودے تےجو کہ تُسی کیتا اے اللہ نال۔ تے اے بہت وڈی کامیابی اے
