quran[18{c,v,t}:
53,27,بے شک جولوک نئیں ایمان رکھدےآخرت اُتے او نام رکھدے نیں فرشتیاں دے زنانے ناں
53,28,تے نئیں انہاں کول ایدھے بارے کوئی علم۔ نئیں پیروی کردے او مگر وہم و گمان دی، تے بے شک وہم و گمان نئیں فائدہ دے سکدا حق دے مقابلے وچ ذرا وی
53,29,تے (اے نبی) منہ پھیر لو، جو منہ پھیردا اے ساڈےذکر توں ، او اے جیہڑا دنیا وی زندگی توں سوا کجھ نہ چاہندا ہوئے
53,30,تے ایہی اے انتہا انہاں لوکاں دےعلم دی۔ بے شک تیرارَب ہی خوب جاندا اے اوس نوں جو گمراہ ہویاسدھے رستے توں، تے اوہی جاندا اے اوس نوں جو ہدایت اُتے وے
53,31,تے اللہ لئی اے جو کجھ آسماناں وچ اے تے جو کجھ زمین وچ اے، تاں جے بدلہ دے انہاں نوں جنہاں نے برے کم کیتے ا نہاں دےاعمال دا تے بدلہ دیوے جنہاں نے نیک کم کیتے نیک بدلہ
53,32,جولوک بچدے نیں کبیرہ گناہاں توں تے کھلی بے حیائی توں سوائے کوئی بُھل چک توں۔ بے شک تہاڈےرَب دی بخشش وچ بڑی وسعت اے۔ او خوب جاندا اے تہانوں جدوں پیدا کیتا تہانوں زمین وچ تے جدوں تُسی بچے سواپنی ماں دے پیٹ وچ،سو مت کرو اپنی پاکیزگی دے دعوے۔ او بہتر جاندا اے کہ کون متقی اے
53,33,فیر تُسی ویکھیا اےجس نے منہ موڑ لِتَّا اے (حق توں)
53,34,تے دِتا اوس نے تھوڑا (جہیا مال) تے ہتھ روک لیا (نیکی توں)
53,35,کی ایدھے کول علم غیب اے کہ او ویکھ رہیا اے (سب کجھ)
53,36,کی نئیں خبر آئی اودھے کوَل جو کجھ صحیفے وچ اے موسیٰ،ؑ دے
53,37,تے ابراہیم،ؑ جنہاں نے وفا دا حق ادا کر دِتا
53,38,تے نئیں چکدا کوئی بوجھ چکن والا کسے دوسرے دا بوجھ
53,39,تے اے کہ نئیں ملدا انسان نوں مگر جو اوس نے کمایا ہوئے
53,40,تے اے کہ اودھی کمائی اوس نوں ضرور ویکھائی جائے گی
53,41,فیر بدلہ ملے گا اوس نون پورا پورا بدلہ
53,42,تے اے کہ تیرےرَب تک سب نوں پہنچنا اے
53,43,تے اے کہ اوہی ہساندا اے تے روَاندا اے
53,44,تے اے کہ اوہی ماردا اے تے زندہ کردا اے
