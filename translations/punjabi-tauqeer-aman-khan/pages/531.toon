quran[22{c,v,t}:
54,50,تے نئیں ہوندا ساڈا حکم مگراک (اشارہ) جیویں اَکھ دا جھپکنا
54,51,تے بے شک اسی ہلاک کر چکے آں تہاڈے جئے کئی (گروپ) سو ہے کوئی(ایس توں) نصیحت لین والا
54,52,تے ہر (شے) کم جو وی عمل انہاں نے کیتا درج اے نامہ اعمال وچ
54,53,تے ہرچھوٹی گل تے وڈی چیز لکھی ہوئی اے
54,54,بے شک متقی لوک جنتاں وچ تے نہراں (دے کوَل ہون گے)
54,55,سچی تے عزت دی جگہ وچ بادشاہ دے کوَل جو صاحب اقتدار اے
55,1,بڑا وڈا مہربان (پیار کرن والا)
55,2,قرآن سیکھان والا
55,3,انسان پیدا کرن والا
55,4,(انسان نوں) سکھایا بولنا
55,5,سورج تے چَن اک حساب نال (گردش کردے نیں)
55,6,تے ستارے تے درخت وی سجدہ کردے نیں
55,7,تے آسمان نوں بلند کر دِتا تے قائم کر دِتا انصاف (ہر شے وچ)
55,8,تاں جے تُسی وی ڈنڈی نہ مارو تولن لگے (انصاف کرن لگے)
55,9,تے قائم کرنا تولن لگے انصاف تے ہرگز نہ نقصان پہنچانا (کسے نوں جدوں) تولن لگو (انصاف کرن لگو)
55,10,تے زمین نوں وَچھایا مخلوقات لئی
55,11,ایدھے و چ میوے نیں تے کھجوراں غلاف وچ لپٹیاں ہویاں
55,12,تے اناج پُھس والا،تے خوشبودار پُھل
55,13,فیر کن کن نعمتاں نوں جو تہاڈےرَب دیاں نیں تُسی جھٹلاؤ گے (اے جِن و انسان)
55,14,پیدا کیتا اے انسان نوں کھنکھناندی ہوئی مٹی ٹھیکری جہی نال
55,15,تے پیدا کیتا اے جنات نوں شعلہ ماردی اگ دے نال
55,16,فیراپنےرَب دی کیہڑی کیہڑی نعمتاں نوں تسی جھٹلاؤ گے
