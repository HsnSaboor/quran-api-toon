quran[7]{c,v,t,f}:
  1,1,"In the name of Allah, the Merciful, the Compassionate"{1},footnotes:1:1
  1,2,"Praise be to Allah, the Lord of the entire universe."{1}{2},footnotes:1:1,footnotes:2:2
  1,3,"The Merciful, the Compassionate"{1},footnotes:1:1
  1,4,"The Master of the Day of Recompense."{1},footnotes:1:1
  1,5,"You alone do we worship, and You alone do we turn for help"{1}{2},footnotes:1:1,footnotes:2:2
  1,6,"Direct us on to the Straight Way,"{1},footnotes:1:1
  1,7,"The way of those whom You have favoured, who did not incur Your wrath, who are not astray."{1}{2},footnotes:1:1,footnotes:2:2