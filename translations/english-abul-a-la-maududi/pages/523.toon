quran[7]{c,v,t,f}:
  52,1,"By the Mount,"{1},footnotes:1:1
  52,2,"and the Book inscribed"
  52,3,"on fine parchment;"{1},footnotes:1:1
  52,4,"by the much-frequented House,"{1},footnotes:1:1
  52,5,"by the elevated canopy;"{1},footnotes:1:1
  52,6,"and by the swelling sea:"{1},footnotes:1:1
  52,7,"verily your Lord's chastisement shall come to pass,"
  52,8,"none can avert that."{1},footnotes:1:1
  52,9,"(It shall come to pass) on the Day when the heaven will convulse in a great convulsion,"{1},footnotes:1:1
  52,10,"and the mountains shall violently fly about."{1},footnotes:1:1