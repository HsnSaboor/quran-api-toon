quran[7]{c,v,t,f}:
  81,1,"When the sun shall be folded up,"{1},footnotes:1:1
  81,2,"when the stars shall scatter away,"{1},footnotes:1:1
  81,3,"when the mountains shall be set in motion,"{1},footnotes:1:1
  81,4,"when the ten-months pregnant camels shall be abandoned,"{1},footnotes:1:1
  81,5,"when the savage beasts shall be brought together,"{1},footnotes:1:1
  81,6,"when the seas shall be set boiling,"{1},footnotes:1:1
  81,7,"when the souls shall be rejoined (with their bodies),"{1}{2},footnotes:1:1,footnotes:2:2
  81,8,"and when the girl-child buried alive shall be asked:"
  81,9,"for what offence was she killed?"{1},footnotes:1:1
  81,10,"and when the scrolls of (men's) deeds shall be unfolded,"