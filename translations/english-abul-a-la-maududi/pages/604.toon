quran[7]{c,v,t,f}:
  112,1,"Say: “He is Allah, the One and Unique;",footnotes:182885:1,footnotes:182886:2,footnotes:182887:3
  112,2,"Allah, Who is in need of none and of Whom all are in need;",footnotes:182888:1
  112,3,"He neither begot any nor was He begotten,",footnotes:182889:1
  112,4,"and none is comparable to Him.”",footnotes:182890:1
  113,1,"Say: “I seek refuge with the Lord of the rising day;",footnotes:182891:1,footnotes:182892:2,footnotes:182893:3
  113,2,"from the evil of all that He created;",footnotes:182894:1
  113,3,"from the evil of night's darkness when it spreads around;",footnotes:182895:1
  113,4,"from the evil of the women who blow on knots;",footnotes:182896:1
  113,5,"and from the evil of the envier when he envies.”",footnotes:182897:1
  114,1,"Say: “I seek refuge with the Lord of mankind;"
  114,2,"the King of mankind,"
  114,3,"the True God of mankind,",footnotes:182898:1
  114,4,"from the mischief of the whispering, elusive prompter who returns again and again,",footnotes:182899:1
  114,5,"who whispers in the hearts of people;"
  114,6,"whether he be from the jinn or humans.”",footnotes:182900:1