quran[7]{c,v,t,f}:
  112,1,"Say: “He is Allah, the One and Unique;"{1}{2}{3},footnotes:1:1,footnotes:2:2,footnotes:3:3
  112,2,"Allah, Who is in need of none and of Whom all are in need;"{1},footnotes:1:1
  112,3,"He neither begot any nor was He begotten,"{1},footnotes:1:1
  112,4,"and none is comparable to Him.”"{1},footnotes:1:1
  113,1,"Say: “I seek refuge with the Lord of the rising day;"{1}{2}{3},footnotes:1:1,footnotes:2:2,footnotes:3:3
  113,2,"from the evil of all that He created;"{1},footnotes:1:1
  113,3,"from the evil of night's darkness when it spreads around;"{1},footnotes:1:1
  113,4,"from the evil of the women who blow on knots;"{1},footnotes:1:1
  113,5,"and from the evil of the envier when he envies.”"{1},footnotes:1:1
  114,1,"Say: “I seek refuge with the Lord of mankind;"
  114,2,"the King of mankind,"
  114,3,"the True God of mankind,"{1},footnotes:1:1
  114,4,"from the mischief of the whispering, elusive prompter who returns again and again,"{1},footnotes:1:1
  114,5,"who whispers in the hearts of people;"
  114,6,"whether he be from the jinn or humans.”"{1},footnotes:1:1