quran[17]{c,v,t}:
  86,1,"Tako mi neba i noćnog posjetioca!"
  86,2,"A znaš li ti što je to noćni posjetilac?"
  86,3,"Zvijezda prodiruća!"
  86,4,"Nema čovjeka nad kojim netko ne bdije."
  86,5,"Neka čovjek pogleda od čega je stvoren!"
  86,6,"Stvoren je od tekućine koja izbija u mlazu,"
  86,7,"koja između kičme i grudi izlazi,"
  86,8,"i On ga je, zaista, kadar ponovno stvoriti,"
  86,9,"onaj dan kada tajne budu otkrivene,"
  86,10,"kada čovjek ni snage ni pomagača neće imati."
  86,11,"I tako mi neba punog kiše koja se vraća."
  86,12,"i Zemlje pune raspuknuća,"
  86,13,"Kuran je, doista, govor koji rastavlja Istinu od neistine,"
  86,14,"lakrdija nikakva nije."
  86,15,"Oni, zbilja, prave zamke,"
  86,16,"pa i Ja njima zamke pravim."
  86,17,"Zato nevjernicima još vremena daj, još koji trenutak ih ostavi."
