quran[11]{c,v,t}:
  93,1,"Tako mi jutra"
  93,2,"i noći kad se utiša,"
  93,3,"Gospodar tvoj nije te ni napustio ni omrznuo!"
  93,4,"Onaj svijet je, zaista, bolji za tebe od ovog svijeta,"
  93,5,"a Gospodar tvoj će tebi, sigurno, dati, pa ćeš zadovoljan biti."
  93,6,"Zar te siročetom ne nađe, pa ti utočište dade,"
  93,7,"i zalutalim te nađe, pa te uputi,"
  93,8,"i siromahom te nađe, pa te bogatim učini?"
  93,9,"Zato, siroče ne ucvili,"
  93,10,"i onoga tko traži ne odbij,"
  93,11,"i o blagodati Gospodara svoga kazuj!"
