quran[6]{c,v,t}:
  109,1,"Reci: ""O vi nevjernici,"
  109,2,"ja ne obožavam ono što vi obožavate,"
  109,3,"niti ste vi obožavaoci Onoga Koga ja obožavam,"
  109,4,"niti sam ja obožavalac onoga što vi obožavate,"
  109,5,"niti ste vi obožavaoci Onoga Koga ja obožavam,"
  109,6,"vama vaša vjera, a meni moja."
