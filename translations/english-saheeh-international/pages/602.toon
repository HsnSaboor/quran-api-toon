quran[7]{c,v,t,f}:
  106,1,"For the accustomed security of the Quraysh<sup foot_note=197820>1</sup> -",footnotes:197820:1
  106,2,"Their accustomed security [in] the caravan of winter and summer<sup foot_note=197821>1</sup> -",footnotes:197821:1
  106,3,"Let them worship the Lord of this House,<sup foot_note=197822>1</sup>",footnotes:197822:1
  106,4,"Who has fed them, [saving them] from hunger and made them safe, [saving them] from fear."
  107,1,"Have you seen the one who denies the Recompense?"
  107,2,"For that is the one who drives away the orphan"
  107,3,"And does not encourage the feeding of the poor."
  107,4,"So woe to those who pray"
  107,5,"[But] who are heedless of their prayer<sup foot_note=197823>1</sup> -",footnotes:197823:1
  107,6,"Those who make show [of their deeds]"
  107,7,"And withhold [simple] assistance."
  108,1,"Indeed, We have granted you, [O Muḥammad], al-Kawthar."
  108,2,"So pray to your Lord and offer sacrifice [to Him alone]."
  108,3,"Indeed, your enemy is the one cut off.<sup foot_note=197824>1</sup>",footnotes:197824:1