quran[7]{c,v,t,f}:
  52,1,"By the mount"
  52,2,"And [by] a Book inscribed<sup foot_note=197428>1</sup>",footnotes:197428:1
  52,3,"In parchment spread open"
  52,4,"And [by] the frequented House<sup foot_note=197429>1</sup>",footnotes:197429:1
  52,5,"And [by] the ceiling [i.e., heaven] raised high"
  52,6,"And [by] the sea set on fire,<sup foot_note=197430>1</sup>",footnotes:197430:1
  52,7,"Indeed, the punishment of your Lord will occur."
  52,8,"Of it there is no preventer."
  52,9,"On the Day the heaven will sway with circular motion"
  52,10,"And the mountains will pass on, departing<sup foot_note=197431>1</sup> -",footnotes:197431:1