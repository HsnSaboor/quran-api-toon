quran[7]{c,v,t,f}:
  79,1,"By those [angels] who extract with violence<sup foot_note=197684>1</sup>",footnotes:197684:1
  79,2,"And [by] those who remove with ease<sup foot_note=197685>1</sup>",footnotes:197685:1
  79,3,"And [by] those who glide [as if] swimming<sup foot_note=197686>1</sup>",footnotes:197686:1
  79,4,"And those who race each other in a race<sup foot_note=197687>1</sup>",footnotes:197687:1
  79,5,"And those who arrange [each] matter,<sup foot_note=197688>1</sup>",footnotes:197688:1
  79,6,"On the Day the blast [of the Horn] will convulse [creation],"
  79,7,"There will follow it the subsequent [one]."
  79,8,"Hearts,<sup foot_note=197689>1</sup> that Day, will tremble,",footnotes:197689:1
  79,9,"Their eyes<sup foot_note=197690>1</sup> humbled.",footnotes:197690:1
  79,10,"They are [presently] saying, "Will we indeed be returned to [our] former state [of life]?"