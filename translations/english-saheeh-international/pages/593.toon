quran[7]{c,v,t,f}:
  89,1,"By the dawn"
  89,2,"And [by] ten nights<sup foot_note=197754>1</sup>",footnotes:197754:1
  89,3,"And [by] the even [number] and the odd"
  89,4,"And [by] the night when it passes,"
  89,5,"Is there [not] in [all] that an oath [sufficient] for one of perception?<sup foot_note=197755>1</sup>",footnotes:197755:1
  89,6,"Have you not considered how your Lord dealt with ʿAad -"
  89,7,"[With] Iram<sup foot_note=197757>1</sup> - who had lofty pillars,<sup foot_note=197756>2</sup>",footnotes:197757:1,footnotes:197756:2
  89,8,"The likes of whom had never been created in the land?"
  89,9,"And [with] Thamūd, who carved out the rocks in the valley?"
  89,10,"And [with] Pharaoh, owner of the stakes?<sup foot_note=197758>1</sup>",footnotes:197758:1