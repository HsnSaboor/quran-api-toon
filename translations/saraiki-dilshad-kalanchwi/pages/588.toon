quran[28{c,v,t}:
83,7,کوئی وَجّہ نھیں، بیشک بَد کِرداراں دَا اَعمالنامہ سجّین (رجسٹر) وِچ لِکھیا ہویا ہے(٧)
83,8,اَتے تَیں کیا سَمجھا ہے جو او سِجّین (لِکھیا ہویا رجسٹر) کیا ہے(٨)۔
83,9,او ہِک لِکھیا ہوئیا رِیکارڈ (دَفتر) ہے(٩)
83,10,اُوں ݙِین٘ہ کُوں کُوڑ آکھݨ والیاں دِی شَامت آئی ہوئی ہوسی(١٠)
83,11,اُنھاں دِی جِہڑے جو سَزا دے ݙین٘ہ کُوں کُوڑ اَکھیندِن(١١)
83,12,پر اُوکُوں کوئی کُوڑ نھیں آہدا سِوائے اُوندے جِہڑا جو حَد کنُوں وَدّھ تے گُنہگار ہے(١٢)
83,13,ڄَݙاں اَساݙِیاں آیاتاں اُوکُوں پَڑھ تے سُݨائیاں ویندِن تاں اَکھیندے جو اِیہ تاں پہلے وَقتاں دے لوکاں دِی کہاݨیاں ہِن(١٣)۔
83,14,اِیں ہرگز کائے نھیں، اُنھاں دے دِلّیں اُتے دَاغ لَا ݙِتے، اُنھاں عَملاں دَا جِہڑے او کریندِن(١٤)۔
83,15,اِیں کائے نھیں، بلکہ او آپݨیں رَبّ کنُوں وِی اُوں ݙِین٘ہ پَرے کِیتے ہوئے ہوسن(١٥)
83,16,وَل یقیناً او سارے دَوزخ وِچ وَڑ ویسِن(١٦)۔
83,17,وَل اُنھاں کُوں آکھیا ویسے جو اِیہ تاں اُوپو کُجھ ہے، جِیکُوں تُساں کُوڑ آہدے ہاوے(١٧)۔
83,18,اِیں کائے نھیں، ! تحقیق نیک لوکاں دے اَعمال نامے اُچّے رُتبے والے لوکاں دے رجسٹر (عِلّیین) وِچ ہوسن(١٨)
83,19,اَتے تیکُوں کیا پَتہ جو او اُچّے دَرجے والے لوکاں دا رجسٹر (علیّون) کیا ہے؟(١٩)
83,20,او ہِک لِکّھی ہوئی کِتاب ہے(٢٠)۔
83,21,جِیندی گواہی اَللہ دے قُرب والے فَرشتے ݙیندِن(٢١)۔
83,22,یقیناً نیک بَندے نعمتاں والی جاء وِچ ہوسن(٢٢)
83,23,تختاں اُتّے بیٹھے نظارے کریندے پئے ہوسن(٢٣)
83,24,تُوں اُنھاں دے مُونھاں اُتّے نعمتاں والی رونق ݙیکھسیں(٢٤)
83,25,اُنھاں کُوں مُہر بَند خالص پِیوݨ والی شَئے پِلائی ویسی(٢٥)۔
83,26,اُوندے اُتّے مُشک دِی مہر لڳی ہوئی ہوسی، اَتے اِیں سِلسلے وِچ اُوندی رَغبت رَکھݨ والے ہِک ٻئے کنُوں نِسنگ اَڳُوں وَدھ وَن٘ڄݨ دِی کوشش پَے کرن(٢٦)۔
83,27,اَتے اُوندے وِچ تسنیم دا سَواد وِی آسی(٢٧)
83,28,تحقیق او لوک جِہڑے گُنہگار ہِن اُنھاں لوکاں دے نال جِہڑے اِیمان گِھن آئِن کِھلَّاں مَذاقاں کریندے ہَن(٢٩)
83,29,اَتے جِہڑے ویلے اُنھاں دے کولھُوں لَنگھدے ہِن تاں آپس وچ اَکّھیں مریندے ہَن(٣٠)۔
83,30,اَتے ڄَݙاں آپݨیں گَھر والیاں دو وَل آوِن، تاں وِی کِھلَّاں مَذاقاں کریندے آندے ہَن(٣١)
83,31,بلکہ ڄَݙاں وِی اِنھاں کُوں ݙیکھدے ہَن، تاں آہدے ہَن اِیہ تاں اَصلُوں گُمراہ لوک ہِن(٣٢)
83,32,حالانکہ اِنھاں کُوں اُنھاں اُتے پَہرے دار بَݨا تے نَہ بھیڄیا ڳیا ہَا(٣٣)
83,33,ٻَس اَڄ دے ݙین٘ہ تَاں اِیمان گِھن آوَݨ والے لوک کافراں اُتے کِھلَّاں مَذاقاں پَے کریسِن(٣٤)۔
83,34,آپݨیاں تَختَاں اُتّے ٻیٹھے ہوئیں سارے حالات ݙیکھدے پَے ہوسن(٣٥)
