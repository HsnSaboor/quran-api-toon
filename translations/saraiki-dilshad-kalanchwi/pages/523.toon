quran[23{c,v,t}:
51,52,اِیں طرح انھاں لوکاں دو اُنھاں کنُوں پہلے کوئی وِی اِہجے رسول نہیں آئے جِنہاں کُوں اُنہاں جادوگر یا پاڳل نہ سَݙیا ہووے (٥٢)۔
51,53,کیا اِیہ لوک (ہِک ٻئے کُوں) اِیہا وَصیّت کریندے آندے رِیہن؟ بلکہ اِیہ تاں ہن وِی نافرمان (سرکش قوم) (٥٣)۔
51,54,پس اَے رسول انھاں کنُوں مُن٘ہ پھیر گِھن، ٻس تیکُوں کوئی ملامت نہ کِیتی ویسی! (٥٤)۔
51,55,اَتے نصیحت کِیتی رَکّھ، بیشک نصیحت مومن لوکاں کُوں فائدہ ݙیندی ہے (٥٥)۔
51,56,اَتے مَیں جِنّاں کُوں تے اِنساناں کُوں اِیویں پَیدا نھیں کر چھوڑیا، سِوائے اِیندے جو او میݙی عِبادت (تے اِطاعت) کِیتی رَکِّھن (٥٦)۔
51,57,مَیں اُنھاں کنُوں رِزق نھیں مَنگدا، اَتے نہ مَیں چَہنداں جو او میکُوں کھواوِن پِلاوِن (٥٧)۔
51,58,اِیندے وِچ کوئی شَک کائے نھیں جو اَللہ اِی رِزق ݙیوݨ والا ہے، ٻَہُوں مضبوط تے پُوری قُدرت دا مالک ہے (٥٨)۔
51,59,ٻَس یقیناً جِنھاں لوکاں ظُلم کِیتے، اُنھاں دے نصیب وِچ وِی اُوہو کُجھ (عذاب) ہے جِہڑا اُنھاں دے سَنگتیاں ساتھیاں کُوں مِلیے، ٻَس او میݙی طرفُوں اُٻَہل نہ کرواوِن (٥٩)۔
51,60,آخر تباہی ہے، اُنھاں لوکاں دِی جِنھاں کُفر اِختیار کِیتے اُوں ݙین٘ہ، جِیندا اُنھاں نال وَعدہ کِیتا ویندے (٦٠)۔
52,1,قسم ہے طُور (پہاڑ) دِی (١)۔
52,2,اَتے اُوں لِکّھی ہوئی کِتاب دِی (٢)۔
52,3,جِہڑی پَتلی کَھلّ اُتے کُھلّی ہوئی دَرج ہے (٣)۔
52,4,اَتے ٻَہُوں آباد گھر دِی (٤)۔
52,5,اَتے اُچّی چَڑھائی ہوئی چَھت (اَسمان) دِی (٥)۔
52,6,اَتے ٹَھاٹَھاں مریندے سَمندر دِی (٦)۔
52,7,یقیناً تیݙے رَبّ دَا عَذاب ضرور آ تے رَہسی (٧)۔
52,8,جیکُوں ٹَالݨ وَالا کوئی وِی کائے نھیں (٨)۔
52,9,اِیہ (اُوں ݙین٘ہ) ہوسی ڄَݙاں اَسمان کَن٘بݨ پَے ویسی، جِیویں کَن٘بݨ دا حَق ہوندے (٩)۔
52,10,اَتے پَہاڑ چَلدے پِھردے وَدّے ہوسِن، جِتّی چَلَݨ پِھرݨ تِھی سَڳدے (١٠)۔
52,11,اُوں ݙین٘ہ شَامت ہے، حقیقت کُوں کُوڑا آکھݨ والیاں کِیتے (١١)۔
52,12,جِہڑے جو کُوڑ (باطِل) پِچُّھوں جُپّے وَدّے ہِن (١٢)۔
52,13,جِہڑے ݙین٘ہ اُنھاں کُوں دِھکّے ݙے ݙے تے دَوزخ دِی بھا دو ہَکلیا ویسی (١٣)۔
52,14,(تاں آکھیا ویسی) جو اِیہ اُوہَا بھا ہے، جیکُوں تُساں کُوڑا آہدے وے (١٤)۔
