quran[19{c,v,t}:
26,1,طٰسٓمٓ (١)۔
26,2,اِیہ روشن تے واضَح کِتاب دِیاں آیاتاں ہِن(٢)۔
26,3,(اَے رسول) شاید تُوں ٻَہُوں جان کَھپَاوَݨ لَڳیں جو لوک اِیمان کِیُوں نھیں گِھن آندے(٣)۔
26,4,جیکر اَساں چَہوُوں تاں اُنھاں اُتے اَسمان کنُوں اِہجی نِشانی نازل کر ݙیوُوں، ٻَس جِیندے اَڳُوں اُنھاں دِیاں ڳِچّیاں جِھکّیاں تِھی وَن٘ڄِن(٤)۔
26,5,اَتے اُنھاں کولھ رحمان (ٻَہُوں مہربان اَللہ) دِی طرفُوں کوئی تازہ نصیحت اِہجی نھیں آندی، جیں کنُوں اُنھاں مُن٘ہ نَہ پھیریا ہووے(٥)۔
26,6,ٻَس تحقیق اِیہ تاں کُوڑا آکھ چُکئِن، اَجھو اُنھاں کُوں اُوں ڳالھ دِی خَبر لَڳ ویسی، جِیندیاں اِیہ مَذاقاں کریندے ہن(٦)۔
26,7,کیا اُنھاں لوکاں زمین دو کݙَاہِیں نھیں ݙِٹَّھا جو اَساں اُوندے وِچُوں ہَر قِسم دِیاں چَن٘ڳیاں تے وافر شَئیں پَیدا کِیتیاں ہِن(٧)۔
26,8,بیشک اِیندے وِچ وی نِشانی موجود ہے، پَر اُنھاں دے ڈھیر بَندے اِیمان گِھن آوَݨ والے کائے نھیں(٨)۔
26,9,اَتے بیشک تیݙا رَبّ تاں اُوہو ہے جِہڑا ساریاں اُتّے غالب ہے ہمیشہ رحمت کَرݨ والا ہے(٩)۔
26,10,اَتے ڄَݙاں (اَے رسول) تیݙے رَبّ نے مُوسیٰ کُوں سَݙیا، جو تُوں ظالم لوکاں دِی قَوم کولھ وَن٘ڄ(١٠)۔
26,11,فِرعون دِی قَوم (کولھ) ! کیا او ݙَرسِن کائے نَہ(١١)۔
26,12,مُوسیٰ آکھیا، میݙے رَبّ آ، اَلبتہ مَیں ݙَرداں جو او میکُوں کُوڑا چَا اَکھیسِن(١٢)۔
26,13,اَتے میݙا سِینہ وِی ݙُکھدے، تے میݙی زبان وِی پُورا نھیں ٻول سَڳدی، ٻَس ہارون کولھ ( میݙے نال ڄُلَّݨ دا حُکم) بھیڄ ݙے(١٣)۔
26,14,ٻِیا اِیہ جو میݙے اُتے اُنھاں نال کِیتا ہُوئیا ہِک جُرم وِی ہے ٻَس مَیں ݙَرداں جو او میکُوں مار گَھتیسِن(١٤)۔
26,15,(اَللہ) آکھیا، اَصلُوں کوئے نَہ ! ٻَس تُساں ݙُوہائیں میݙیاں نِشانیاں گِھن تے وَن٘ڄُو، یقیناً اَساں تُہاݙے نال ہَیں، سَب کُجھ سُݨݨ والے(١٥)۔
26,16,ٻَس تُساں ݙُوہائیں فِرعون کولھ وَن٘ڄو، ٻَس اُوکُوں آکھو، جو اِیندے وِچ شَک نَہ کر، جو اَساں سارے جہاناں دے رَبّ دے رسول ہَیں(١٦)۔
26,17,ٻَس تُوں بَنی اِسرائیل کُوں (آزاد کر تے) اَساݙے نال ٹور ݙے(١٧)۔
26,18,فِرعون آکھیا، کیا اَساں تیکُوں اَپݨیں وِچ رَکّھ تے ٻال وَانگیں نھیں پالیا، اَتے اِیں طرح اَساݙے وِچ اَپݨِیں عُمر دے کئی سال نھیں گُزارے(١٨)۔
26,19,ٻَس تَیں کر ݙِیکھایا، او کَمّ جِہڑا تَیں کرݨاں ہَا، تے کِیتا وِی ہَاوی اَتے تُوں تاں نا شُکریاں وِچُّوں بَݨ ڳئیں(١٩)۔
