quran[10{c,v,t}:
45,33,اَتے اُنھاں اُتے او ساریاں بُرائیاں ظاہر تِھی ویسِن جِہڑیاں او کریندے ہَن، اَتے اُنھاں کُوں وَلھیٹ گِھدّا اُوں (عذاب) جِیندا اِیہ مَذاقاں کریندے ہَن (٣٣)۔
45,34,اَتے آکھیا ویسی جو جیں طرح تُساں اِیں ݙین٘ہ دِی مُلاقات کُوں وِسار چھوڑیا ہَا، اُوویں اَڄ اَساں وِی تُہاکُوں (رحمت کرݨ ویلے) وِسار ݙیسُوں، اَتے تُہاݙا ٹِکاݨاں (دَوزخ دِی) بَھا ہے، اَتے تُہاݙا کوئی مَددگار وِی نہ ہوسی (٣٤)۔
45,35,اِیہ اَنجام اِیں ڳالھُوں ہے جو تُساں اَللہ دِیاں نِشانیاں (آیاتاں) کُوں مَذاق سَمجھ گِھدّا ہَا، اَتے دُنیاوی زِندگی تُہاکُوں دَھوکے وِچ سَٹیا ہوئیا ہَا، ٻَس اِیں ݙین٘ہ اِیہ اُوندے وِچُوں کائے نہ کڈھے ویسِن، اَتے نہ اُنھاں دا کوئی عُذر قبول کِیتا ویسی (٣٥)۔
45,36,ٻَس اَللہ کِیتے ہِن ساریاں تعریفاں ! جِہڑا اَسماناں دا رَبّ ہے، زمین دا رَبّ ہے، تے سارے جہاناں دا وِی رَبّ ہے (٣٦)۔
45,37,اَتے محض ہُوندے کِیتے ہے اَسماناں تے زمین وِچ دِی وَݙائی ، اَتے او ٻَہُوں زَبردست وَݙی دَانائی دَا مالک ہے (٣٧)۔
46,1,حٰمٓ (١)۔
46,2,اِیں کِتاب دَا نازِل تِھیوݨ اَللہ دِی طرفُوں ہے جِہڑا ٻَہُوں زبردست ہے، وَݙی حکمت (دانائی) والا ہے (٢)۔
46,3,اَساں اَسماناں کُوں، تے زمین کُوں، تے جو کُجھ اُنھاں دے وِچکار ہے، اُوکُوں (اِیویں) پَیدا نھیں کِیتا، بلکہ حقیقت (حکمت) دے طور تے پَیدا کِیتے، اَتے او وِی ہِک مُقرر مُدّت تَئیں کِیتے، اَتے جِنھاں لوکاں کُفر اِختیار کِیتا ہوئے اُنھاں کُوں جِہڑی شَئے کنُوں ݙَرایا چِتایا ویندے اُوں کنُوں او مُنہ پھیر گِھندِن (٣)۔
46,4,(اَے رسول) آکھ، کیا تُساں (اَکّھیں کھول تے) اُنھاں کُوں ݙِٹھے جِنھاں کُوں تُساں اَللہ کُوں چھوڑ تے سَݙیندے وے، او میکُوں وِی ݙیکھاؤ تاں سَہی، اُنھاں زمین وِچُوں کِہڑی شَئے پَیدا کِیتی ہے، یا اَسماناں وِچ اُنھاں دا کوئی ساںجھ کھاتہ ہے، اِیں کنُوں پہلے دِی آئی کوئی کتاب تاں میݙے کولھ گِھن آؤ، یا کوئی عِلمی دلیل اِی گِھن آؤ، جیکر تُساں سَچّ وَدّے اَہدو (٤)۔
46,5,اَتے اُوں شخص کنُوں کوݨ زیادہ گُمراہ ہے، جِہڑا اَللہ کُوں چھوڑ تے کِنھائیں اِہجیاں کُوں سݙیندے، جِہڑے اُوکُوں قیامت دے ݙین٘ہ تَئیں جواب وِی نھیں ݙے سڳدے، اَتے اُنھاں کُوں اِنھاں دِیاں دُعائیں دَا اَصلُوں پَتہ اِی نہ لَڳے (٥)۔
