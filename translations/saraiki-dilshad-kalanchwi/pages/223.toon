quran[7{c,v,t}:
11,13,کیا اِیہ لوک اِیہو اَہدِن، جو اِیکوں آپوں گھڑ گِھدا ڳئے، تُوں آکھ ݙے، تُساں تاں اِیں طرح دِیاں ݙاہ سُورتاں بݨا تے گِھن آؤ، اَتے اَللہ دے سِوا جیکوں مَدد کِیتے سَݙ سَڳدو سَݙ گِھن آؤ، جیکر تُساں (اَپݨِیں دعوے دے) سَچّے ہِیوے تاں (١٣)۔
11,14,ٻَس جیکر اِیہ معبود تُہاݙی مَدد کُوں نہ آوِن، تاں وَل سمجھ گِھنو جو اِیہ (قرآن) اَللہ دے علم نال نازِل تھئے اَتے اُوندے سِوا ٻِیا کوئی معبُود کائے نھیں، وَت کیا تُساں فرمانبرداری کرݨ والے بݨدو؟ (١٤)۔
11,15,وَت جِہڑا شخص اِیں دُنیاوی زِندگی تے اِیندی سَڄ دَھڄ چَہندے، تاں اِیں دُنیا وِچ اِی اَساں اُنھاں دے عَملاں دِی جزا ݙیسوں، اَتے اُنھاں نال کوئی کَمی ٻیشی نہ کِیتی وِیسی (١٥)۔
11,16,اِیہے او لوک ہِن ، جنھاں کِیتے آخرت وِچ کُجھ کائے نھیں، سوائے (دوزخ دِی) بَھا دے، اَتے انھاں دُنیا وِچ جِہڑا کَمائے بݨائے ڳل پِھل ڳِیا ، اَتے جِہڑے کُجھ عمل کِیتے ہِینیں، بیکار ڳئے (١٦)۔
11,17,کیا اِنھاں وان٘گُوں ہِن او شَخص جِہڑے آپݨِیں رَبّ دِی طرفوں ہِک روشن دَلیل اُتے قائم ہووِن، اَتے اُوندے پِچھُّوں ہِک ڳواہ وِی اُوندی طرفوں ہووے بلکہ اِیں کنُوں پہلے موسیٰ کولھ وِی کتاب آ چُکی ہووے، جِہڑی جو ہِک رہنما تے رحمت وِی ہووے، اِیہے لوک تاں ہِن اِیندے اُتے اِیمان گِھن آوَݨ والے، البتہ جِہڑے کوئی ٻِنھاں انسانی ٹولیاں وِچوں اِیندا اِنکار کریندِن، اُنھاں کِیتے تاں دوزخ دِی بَھا دا وَعدہ کِیتا ڳیا ہے، ٻَس تُوں اِیندے متعلق شک وِچ نہ پو، بیشک اِیہ تیݙے رَبّ دِی طرفوں حق ہے، پر ڈھیر سارے اِیندے اُتے اِیمان نھیں گِھن آندے (١٧)۔
11,18,اَتے اُوں شخص کنُوں زیادہ ظالم کوݨ تِھی سَڳدے، جِہڑا اَللہ اُتے کُوڑے بُہتاں ٻَدھے، اِیہے تاں او لوک ہِن جِہڑے آپݨِیں رَبّ دے سامݨیں پیش کِیتے وِیسِن، اَتے ڳواہ اَکھیسِن، جو اِیہے او لوک ہِن جِہڑے آپݨِیں رَبّ اُتے کُوڑیاں ڳالھیں کریندے ہَن، سُݨ گِھنّو، جو ظالم لوکاں اُتے اَللہ دِی لعنت ہوندی ہے (١٨)۔
11,19,جِہڑے شخص لوکاں کُوں اَللہ دے رَاہ کنُوں روکیندِن، اَتے اِیندے وِچ وِی وَل پھیر گَتھݨ چَہندِن، اَتے اِیہے آخرت کنُوں وِی اِنکاری ہِن (١٩)۔
