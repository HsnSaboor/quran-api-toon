quran[26{c,v,t}:
75,20,۔ اِیہا ڳالھ نَہ ہَئی، بلکہ تُساں تَاں جلدی جَلدی حاصِل تِھی وَن٘ڄݨ والی شَئے (یعنی دُنیا) کُوں پَسند کریندو (٢٠)۔
75,21,اَتے تُساں آخرت دِی پَرواہ وِی نھیں کریندے (٢١)۔
75,22,اُوں ݙین٘ہ کُجھ شکلاں تاں رونقاں والیاں ہوسِن (٢٢)۔
75,23,او اَپݨیں رَبّ دا دِیدار کریندیاں پِیاں ہوسِن (٢٣)۔
75,24,اَتے اُوں ݙین٘ہ کُجھ شَکلاں مُون٘جھیاں مُون٘جھیاں وِی ہوسِن (٢٤)۔
75,25,او گُمان کریسِن، جو اَساݙے اُتّے چیل تروڑ ݙیوݨ والی کوئی مُصیبت آوݨ لڳی ہے (٢٥)۔
75,26,اِیں ہَرگز کائے نھیں، جیں ویلے سَاہ (رُوح) نرگھٹ توڑِیں آویسے (٢٦)۔
75,27,تاں آکھیا ویسی، ہے کوئی دَم کرݨ والا (پُھوکے شُوکے مَارݨ والا) (٢٧)۔
75,28,اَتے آدمی سَمجھ گِھنسے جو ہُݨ اِتُّھوں ٹُر ڄُلَّݨ دا وَقت آڳے (٢٨)۔
75,29,اَتے پِنّی نال پِنّی چِمبڑ ویسی (٢٩)۔
75,30,اِیہُو ہے تیݙے رَبّ دو ہَکلیئے وَن٘ڄݨ دا ݙین٘ہ (٣٠)۔
75,31,ٻَس اُوکُوں (حقیقت کُوں) نَہ مَنّیا ، تے نہ نَماز پَڑھی (٣١)۔
75,32,بلکہ (حقیقت کُوں) کُوڑا آکھیا تے مُن٘ہ پھیر گِھدّا (٣٢)۔
75,33,وَل او اَکڑیندا ہویا آپݨیں گَھر والیاں دو چَلیا ڳِیا (٣٣)۔
75,34,تیکُوں تاں کَمبختی چِمبڑ ڳئی ہے کَمبختی (٣٤)۔
75,35,ٻَس تیکُوں تاں کَمبختی چِمبڑ ڳئی ہے کَمبختی (٣٥)۔
75,36,کیا اِنسان اِیہُو کُجھ گُمان کریندے جو اُوکُوں اِیویں نِکمّا چھوڑ ݙِتا ڳئے (٣٦)۔
75,37,کیا او ہِک نُطفہ (تریڑا) نَہ ہَا ، جیکُوں پیٹ وِچ گَھتّیا ویندے (٣٧)۔
75,38,وَل او ہِک گوشت دا لَٻّر جیہا بَݨ ڳیا، وَل اُوندا جُسّہ بݨایا ڳیا، وَل اُوندا ہِک ہِک جوڑ ٹِھیک کر تے پَیدا کر ݙِتا ڳیا (٣٨)۔
75,39,وَل اُوندیاں ݙُوں قِسماں بݨائیاں ڳئیاں ، نَر تے مادی (٣٩)۔
75,40,کیا او اِیندے اُتّے قُدرت نھیں رَکھیندا جو مُردیاں کُوں وَلا چَا جِیواوے(٤٠)۔
76,1,کیا او اِیندے اُتّے قُدرت نھیں رَکھیندا جو مُردیاں کُوں وَلا چَا جِیواوے(٤
76,2,یقیناً اَساں اِنسان کُوں رَلئے مِلئے نُطفے وِچُوں پَیدا کِیتے، تاں جو اَساں اُوندی اَزمائش کروں، ٻَس اِیں واسطے اَساں اُوکُوں سُݨݨ والا، تے ݙیکھݨ والا بݨائے (٢)۔
76,3,اَساں اُوکُوں سِدّھا رَستہ وِی ݙِیکھائے (ہُݨ) چاہے او شُکر کرݨ والا بݨے اَتے چاہے کُفر کرݨ والا بݨے (٣)۔
76,4,یقیناً اَساں کافراں کِیتے جَولان (زنجیراں) ڳلاویں (طوق) تے بَھڑکے کھاندی بَھا (دَوزخ) تیّار کر رَکھی ہے (٤)۔
76,5,بیشک نیک لوک (پاک شراب دے) اِہجے پیالے پیسِن، جِنھاں وِچ کافُور (دے ٹَھڈھے پاݨِیں) دِی رَلاوٹ وِی ہوسی (٥)۔
