quran[13{c,v,t}:
19,26,تُوں (پِن٘ڈُوں) کَھا ، اَتے (پاݨِیں) پِی، اَتے اَکّھیں ٹَھار ٻَس جیکر کہیں بنی بشر کُوں (اِعتراض کریندا) ݙیکھیں، تاں آکھیں، جو بے شَک مَیں ٻَہُوں مہربان اَللہ کِیتے روزے دِی نیّت رَکھ گِھدّی ہے، ٻَس مَیں اَڄ کہیں اِنسان نال وِی ڳالھ نہ کریساں (٢٦)۔
19,27,وَل او (اُوں ٻال) کُوں چَا تے اَپݨِیں قوم دو گِھن ڳئی، اُنھاں آکھیا اَے مَریم! تُوں تاں نویکلی شَئے چَا آئی ہِیں (٢٧)۔
19,28,ہارون دِی بھیݨ ہیں ! نہ تیݙا پِیو کُوئی بُرا شَخص ہَا، اَتے نہ تیݙی مَا بدکردار ہَئی (٢٨)۔
19,29,(جواب وِچ) اُوں مَئی ٻال دو اِشارہ چَا کِیتا تاں او لوک آکھݨ لڳے، جو اَساں اِیندے نال کِیویں ڳالھ کروں، اِیہ تاں اَڄݨ جھولی دا ٻال ہے (٢٩)۔
19,30,اُوں (ٻال) آکھیا، مَیں وِی اَللہ دا بَندہ ہَاں ! اُوں میکُوں کِتاب وِی ݙِتی ہے اَتے میکُوں نبی وِی بݨایا ہِس (٣٠)۔
19,31,اَتے میکُوں، مَیں جِتّھاں وِی ہُوواں برکتاں والا بݨایا ہِس، اُوں میکُوں نماز پَڑھݨ تے زکوٰۃ کڈھݨ دا حُکم کِیتا ہوئے جے توڑِیں وِی مَیں جِیندا رَہواں (٣١)۔
19,32,اَتے میکُوں آپݨِیں مَاء نال چَن٘ڳا سلوک کرݨ والا بݨایا ہِس، اَتے اُوں میکُوں مَغریا ہویا تے بَد بخت نھیں بݨایا (٣٢)۔
19,33,اَتے سلامتی ہے میݙے اُتّے جِہڑے ݙین٘ہ مَیں ڄَمیا ہَم، اَتے جِہڑے ݙین٘ہ مَیں مَرساں، اَتے جِہڑے ݙین٘ہ میکُوں وَلا جِیوا کھڑایا ویسی (٣٣)۔
19,34,اِیہُو کُجھ ہَا عیسیٰ پُتر مَریم دا ! اَتے اِیہا اَصل ڳالھ ہے جِیندے وِچ لوک شَک کریندے پَے ہِن (٣٤)۔
19,35,اَللہ دِی شان اِیندے وِچ کائے نھیں جو کہیں کُوں آپݨاں پُتر بݨاوے، او تاں (انھاں ڳالھِیں کنُوں) پاک ہے، ڄَݙاں وِی کوئی کَم چَہندے چَھڑا اَکھیندے جو تِھی وَن٘ڄ تے او تِھی ویندے (٣٥)۔
19,36,اَتے بیشک اَللہ میݙا وِی پالَݨ ہَار ہے، تے تُہاݙا وِی ! ٻَس ہُوندی عِبادت کِیتی کرو، اِیہُو سِدّھا رَاہ ہے (٣٦)۔
19,37,پَر مختلف فِرقیْاں آپس وِچ اِختلاف گَھت ݙِتّے، ٻَس ٻَہُوں خرابی تے بربادی ہے اُنھاں لوکاں دِی، جِنھاں نھیں مَنیا (قیامت والے) وݙے ݙین٘ہ دے آوَن٘ڄݨ کُوں (٣٧)۔
19,38,تَݙاں او ٻَہُوں کُجھ سُݨ گِھنسِن تے ٹِھیک ٹِھیک ݙیکھ گِھنسِن، جِہڑے ݙین٘ہ جو اَساݙے کولھ آسِن، پَر اُوں ݙین٘ہ ظالم لوک کُھلّی گُمراہی وِچ ہوسِن (٣٨)۔
