quran[3]{c,v,t}:
  20,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  20,1,طٰہٰ (١)۔
  20,2,(اَے رسول) اَساں تیݙے اُتّے قرآن اِیں واسطے نازِل نھیں کِیتا جو تُوں اَوکھا تِھیویں (٢)۔
  20,3,بلکہ اِیہ اُوں شَخص کُوں نصیحت کرݨ کِیتے ہے جِہڑا جو (اَللہ کنُوں) ݙَردا وِی ہے (٣)۔
  20,4,اِیہ نازِل کِیتا ڳیا ہے اُوں ہَستی دِی طرفُوں ، جَیں زمین تے اُچّے اُچّے اَسماناں کُوں بݨائے (٤)۔
  20,5,او اَللہ ٻَہُوں مہربان ہے، جَیں عرش اُتے قرار پکڑیا ہوئے (٥)۔
  20,6,اُوندے واسطے اِی ہے جِہڑا کُجھ اَسماناں وِچ ہے جِہڑا کُجھ زمین تے ہے، جِہڑا کُجھ انھاں ݙُوہائیں دے اَدّھ وِچ ہے، اَتے جِہڑا کُجھ اَصلُوں زمین دے تَلّے تَئیں ہے (٦)۔
  20,7,اَتے جیکر تُوں زور دِی ڳالھ کریں تاں وِی بلکہ راز دِی ڳالھ وِی، اَتے لُکا تے کِیتی ہوئی ڳالھ وِی (او سَب کُجھ) ڄاݨ ویندے (٧)۔
  20,8,اَللہ اِی ہے اُوندے سِوا کوئی عبادت دے ݙَا دا کائے نھیں، اُوندے کِیتے اِی ہِن، سارے سوہݨیں سوہݨیں ناں (٨)۔
  20,9,اَتے تَیں کنیں مُوسیٰ دِی کوئی ڳالھ وِی آئی ہے (٩)۔
  20,10,ڄَݙاں اُوں ہِک جاء بَھا ݙِٹّھی، تاں گَھر والیاں کُوں آکھیُس ، تُساں اِتھائیں کَھڑو، مَیں بِلا شَک بَھا ٻَلدی ݙِٹھی ہے، شاید مَیں تُہاݙے کِیتے اُوندے وِچُوں کوئی بَکھدا اَنڳارہ چَا آواں، یا بَھا توڑِیں دے رَاہ دَا پَتہ کر آواں (١٠)۔
  20,11,ڄَݙاں او بھا کولھ پُڄیا تاں سَݙّ ماریا ڳِیا، اَے مُوسیٰ (١١)۔
  20,12,مَیں تیݙا رَبّ اِی ہَاں! اَپݨیں جُتّی لَہا چا، کیُوں جو تُوں پاک مَیدان طُویٰ وِچ آیا کھڑیں (١٢)۔
  20,13,اَتے مَیں تیکُوں اَپݨیں کِیتے چُݨ گِھدے، ٻَس تُوں سُݨ جِہڑا کُجھ تَیں دو وحی کِیتا ویندے (١٣)۔
  20,14,بیشک مَیں اِی اَللہ ہَاں، میݙے سِوا ٻِیا کوئی معبود (یعنی عبادت دے ݙَا دا) کائے نھیں، ٻَس میݙی عِبادت کِیتی کر، اَتے میݙے ذِکر دِی خاطر نماز قائم کِیتی رَکّھ (١٤)۔
  20,15,قیامت (دِی گھڑی) ضرور آوَݨ والی ہے، مَیں اَڄݨ اُوندا وَقت کہیں کُوں نھیں ݙَسیندا بہر حال جو کوئی جو کُجھ وِی کرے اُوندی جَزا پاوے (١٥)۔
  20,16,ٻَس کوئی اِہجا شَخص تیکُوں (اِیندی فِکر کنُوں) ہَٹا نہ گِھنّے، جِہڑا جو خود اِیندے اُتے اِیمان وِی نھیں گِھن آندا، اَتے اَپݨیں خواہش تے چَلدے ݙیکھیں تُوں کِتھائیں ہَلاکت وِچ نہ پَے وَن٘ڄیں (١٦)۔
  20,17,اَتے اَے مُوسیٰ ! تیݙے سَڄّے ہَتّھ وِچ اِیہ کیا ہے؟ (١٧)۔
  20,18,اُوں آکھیا، اِیہ میݙی سوٹی ہے، مَیں اِیندا سَہارا گِھنداں اَتے اِیندے نال اَپݨیاں ٻَکریاں کِیتے پَتر جَھن٘بھین٘داں، اَتے اِیندے وِچ میݙے کِیتے ٻَے کئی فائدے وِی ہِن (١٨)۔
  20,19,اَللہ) آکھیا، اَے مُوسیٰ ! اِیکُوں سَٹ ݙے (١٩)۔
  20,20,ٻَس اُوں ایکُوں سَٹیا تَاں او ہُوں ویلے ٹُردا بھڄدا نان٘گ بَݨ ڳئی (٢٠)۔
  20,21,اَللہ) آکھیا اِیکُوں پَکڑ گِھن ݙَر نہ پِیا، اَساں اَجھو اِیکُوں پہلی حالت وِچ گِھن آندُوں (٢١)۔
  20,22,اَتے اَپݨاں ہَتّھ کَچّھ وِچ چَا ݙے، او بغیر کہیں خَرابی دے چِٹَّا کَھنبُور نِکل آسے، اِیہ ݙُوڄِھی نِشانی ہے (٢٢)۔
  20,23,اِیں طرح تیکُوں اَپݨیاں وَݙیاں وَݙیاں نِشانیاں ݙِیکھا ݙِیوُں (٢٣)۔
  20,24,(ہُݨ) فِرعون کولھ پِیا وَن٘ڄ، کیُوں جو او اَصلُوں پِھٹ ڳئے (نافرمان تِھی ڳئے) (٢٤)۔
  20,25,اُوں آکھیا، میݙے رَبّ آ! میݙے کِیتے میݙا دِل (حوصلہ) وَدھا ݙے (٢٥)۔
  20,26,اَتے میݙے کِیتے میݙا کَمّ سَوکھا چَا کر (٢٦)۔
  20,27,اَتے میݙی زبان دِی ڳَنڈھ (دِیاں تَندُوں) کھول ݙے (٢٧)۔
  20,28,تاں جو او لوک میݙی ڳالھ سَمجھ گِھنّن (٢٨)۔
  20,29,اَتے میݙے کُنبے وِچُوں ہِک کُوں میݙا بار چاوَݨ والا (وزیر) مُقرر کر ݙے (٢٩)۔
  20,30,میݙے بِھرا ہارون کُوں (٣٠)۔
  20,31,اُوندے ہَتُّھوں میݙے ہَتّھ تَکڑے چَا کر (٣١)۔
  20,32,تے اُوکُوں میݙے کَمّ وِچ شریک چَا بݨا (٣٢)۔
  20,33,تاں جو تیݙے (ہَر ڳالھُوں) پاک ہُووَݨ کُوں خوب بیان کِیتی رَکھوں (٣٣)۔
  20,34,اَتے تیݙا ڈھیر سارا ذِکر کِیتا کرُوں (٣٤)۔
  20,35,بیشک تُوں اَساݙِی خُوب ݙیکھ بَھال رَکھݨ والا ہیں (٣٥)۔
  20,36,اَللہ) آکھیا، اَے مُوسیٰ! تَیں جِہڑا کُجھ مَن٘گے تیکُوں ݙے ݙِتّیسے (٣٦)۔
  20,37,اَتے تحقیق اَساں تیݙے اُتّے ہِکُّو واری ٻِیا وِی اِحسان کِیتا (٣٧)۔
  20,38,ڄَݙاں اَساں تیݙی مَاء دے دِلّ وِچ ہِک ڳالھ سَٹّی جِہڑی جو وَحی دے ذریعے سَٹّی ڳئی (٣٨)۔
  20,39,او اِیہ جو تُوں اِیں (ٻال) کُوں صَندوق وِچ گَھت چا، وَل اِیکُوں دَریا وِچ سَٹ ݙے، وَل اِیں صندوق کُوں دَریا آپݨیں مَݨ تے سَٹ ݙیسے، اِیکُوں میݙا دُشمن ، جِہڑا اِیندا وِی دُشمن ہے چَا گِھنسی، اَتے مَیں اَپݨِیں طرفُوں تیݙے اُتّے محبت (کِیتے وَن٘ڄݨ دِی چادر) پا ݙِتی تاں جو تُوں میݙے سامݨیں پَلدا رَہیں (٣٩)۔
  20,40,(یاد کر) جو تیݙی بھیݨ وَدّی ہَئی، اُوں جَھٹ وَن٘ڄ آکھیا کیا مَیں تُہاکُوں اِہجا بَندہ ݙَساں جِہڑا اِیکُوں چَن٘ڳی طرح پالے سان٘بھے، ٻَس اِیں طرح تیکُوں آپݨِیں ماء دے کولھ وَلا پُچا ݙِتّوسے، تاں جو اُوندیاں اَکّھیں ٹَھردِیاں رَہِن، تے او مُونجھی نہ تِھیوے، اَتے تَیں ہِک بندے کُوں قَتل کر چھوڑیا، تاں وِی اَساں تیکُوں اِیں مُصیبت کنُوں بَچا گِھدّا، اَتے اَساں تیݙیاں ݙَاڈھیاں اَزمائشاں کِیتیاں، وَل تُوں کئی سال مَدین والیْاں وِچ ٹِکیا رِیہُوں، وَل اَے مُوسیٰ ، تُوں ہِک اَندازے اُتّے آ پُڄّوں (٤٠)۔
  20,41,اَتے مَیں تیکُوں اَپݨیں کِیتے تَیّار کر گِھدے (٤١)۔
  20,42,ہُݨ تُوں تے تیݙا بِھرا میݙیاں نِشانیاں گِھن تے وَن٘ڄو، پَر میݙے ذِکر کرݨ وِچ اَسلیٹ نہ کراہے (٤٢)۔
  20,43,ݙُوہائیں فِرعون کولھ وَن٘ڄو، بیشک او ٻَہُوں مَغریج (پِھٹ) ڳیا ہے (٤٣)۔
  20,44,پَر اُوندے نال نَرمی نال ڳالھ کراہے، مَتاں او نَصیحت مَن گِھنّے یا ݙَر وَن٘ڄے (٤٤)۔
  20,45,ݙُوہائیں آکھیا، جو کِتھائیں او اَساݙے اُتے زِیادتی نہ کرے، یا ٻِیا وِی مَغریج نہ وَن٘ڄے (٤٥)۔
  20,46,اَللہ آکھیا، ݙَرو نہ پَے، بیشک مَیں تُہاݙے نال ہَاں، اَتے سَب کُجھ سُݨدا تے ݙِہدا وَدّاں (٤٦)۔
  20,47,اُوندے کولھ لَنگھ وَن٘ڄو، ٻَس اَکھاہے جو بیشک اَساں تیݙے رَبّ دے بھیڄے ہوئے (رسول) ہَیں، ٻَس بَنی اِسرائیل کُوں اَساݙے نال بھیڄ ݙے، اَتے اِنھاں کُوں عذاب نہ ݙِتّی رَکھ، تحقیق اَساں تیݙے رَبّ دِی طرفُوں نِشانی گِھن تے آئے ہَیں، اَتے اُوندے اُتّے سَلامتی ہے جِہڑا ہِدایت اُتے عَمل چَا کرے (٤٧)۔
  20,48,تحقیق ساݙے کولھ وَحی آئی ہے، جِیندے وِچ کوئی شَک کائے نھیں، جَیں کہیں سَچ کُوں کُوڑا آکھئے تے مُن٘ہ وِی پھیر گِھدّے اُوندے کِیتے عَذاب تَیّار ہے (٤٨)۔
  20,49,(فِرعون) پُچّھیا، جو اَے مُوسیٰ تُساں ݙُوہائیں دَا رَبّ کُوݨ ہے؟ (٤٩)۔
  20,50,مُوسیٰ آکھیا، اَساݙا رَبّ تاں او ہے جَیں اَپݨیں مَخلوق کُوں اُوندی شکل صورت ݙِتی ہے، تے سِدّھے رَاہ تے لائِس (٥٠)۔
  20,51,فِرعون پُچّھیا ، جو پَہلیاں قَوماں دَا کیا حال تِھیا ہَا (٥١)۔
  20,52,مُوسیٰ) آکھیا، اُنھاں دے متعلّق سارا عِلم (حال وغیرہ) میݙے رَبّ کولھ کِتاب وِچ لِکھیا ہوئے میݙا رَبّ نہ بُھلدے چُکدے تے نہ وِسر ویندے (٥٢)۔
  20,53,جَیں تُہاݙے کِیتے زمین کُوں فَرش بَݨائے، اَتے تُہاݙے کِیتے اِیندے اُتّے رَستے کَڈھے ہِن، اَتے اَسماناں کَنُوں مِینہ وَسائے، اِیندے نال قسم قسم دے ٻَچیاں ٻُوٹیاں دے مختلف جَوڑے ڄمائِن (٥٣)۔
  20,54,خُود وِی کھاؤ تے اَپݨیں جانوراں کُوں وِی چَراؤ چُڳاؤ، بیشک اِیندے وِچ عَقل والیاں کِیتے نِشانیاں ہِن (٥٤)۔
  20,55,اِیں مِٹّی وِچُوں اَساں تُہاکُوں پَیدا کِیتے تے اِیں وِچ تُہاکُوں وَلا پُچا ݙیندے ہَیں تے ہِیندے وِچُوں ݙُوجھی واری کَڈھ کَھڑیسُوں (٥٥)۔
  20,56,تحقیق اَساں اُوکُوں اَپݨیاں ساریاں نِشانیاں ݙِکھائیاں، پَر او اُنھاں کُوں کُوڑا اَکھیند رِیہا، تے اُنھاں دے مَنَّݨ کنُوں اِنکار کریندا رِیہا (٥٦)۔
  20,57,اُوں آکھیا، اَے مُوسیٰ کیا تُوں اَساݙے کولھ اِیں واسطے آئیں جو اَساکوں اَساݙے مُلک وِچُوں اَپݨیں جادو دے زور نال کَڈھ چھوڑیں (٥٧)۔
  20,58,ٻَس اَساں وِی تیݙے مقابلے وِچ اِیہُو جیہا جادُو کر ݙیکھیندے ہَیں تُوں اَساݙے تے اَپݨیں دَرمیان ہِک وَقت مقرر چا کر، وَل نہ اَساں پِھرسُوں اَتے نہ تُوں پِھریں اَتے اِیہ مُقابلہ برابر دے موقعیاں والے کُھلے میدان وِچ تِھیسے (٥٨)۔
  20,59,مُوسیٰ آکھیا، تُہاݙے نال جَشن والے ݙین٘ہ دَا وَعدہ تِھی ڳِیا، اَتے (اُوں ݙین٘ہ) لوک ݙین٘ہ چَڑھے کُوں کَٹّھے تِھی وَن٘ڄِن (٥٩)۔
  20,60,ٻَس فِرعون واپس ڳیا تاں اُوں اَپݨیں مَکَّر دا سامان کَٹّھا کرݨ دِی کِیتی تے وَل مقابلے تے نِکل آیا (٦٠)۔
  20,61,مُوسیٰ اُنھاں کُوں آکھیا، تُہاݙی شَامت تاں نھیں آڳئی تُساں اَللہ اُتے بُہتان نہ ٻَدّھو، نہ تاں او عَذاب بھیڄ تے تُہاکُوں فَنا کر ݙیسے، اَتے او ضرور نا مُراد تِھی تے رَہسی جَیں اَللہ اُتے کُوڑی تُہمت لائی (٦١)۔
  20,62,وَت اُنھاں وِچ آپس دا اِختلاف پَیدا تِھی ڳیا اُنھاں آپس وِچ کُھس پُھسّ کِیتی (٦٢)۔
  20,63,اُنھاں آکھیا، اِیہ ݙُوہائیں جادُوگر ہِن، اِنھاں دا اِرادہ ہے جو اَپݨیں جادُو نال تُہاکُوں تُہاݙے مُلک وِچُوں کَڈھ چھوڑِن اَتے تُہاݙے زِندگی دے پَسندیدہ طریقے (مَذہب) کُوں مِٹا چھوڑِن (٦٣)۔
  20,64,ٻَس تُساں اَپݨیاں ساریاں تَدبیراں کَٹھیاں چَا کرو، وَل ہِک مُٹّھ تِھی تے سامݨیں آوَن٘ڄو، اَڄ دے ݙین٘ہ اُوہُو کامیاب رَہسی، جِہڑا ٻَئے تے چَڑھ ویسی (٦٤)۔
  20,65,اُنھاں آکھیا، مُوسیٰ یا تاں تُوں اَپݨاں جادُو سامݨیں گِھنّ آ، یَا وَت پہلے اَساں سامݨیں سَٹ ݙیندُوں (٦٥)۔
  20,66,اُوں آکھیا، کوئے نہ، تُساں چَا سَٹّو، وَل تاں اُنھاں دِیاں کھیڑیاں تے ݙَن٘گُورِیاں اُنھاں دے جادو دے زور تے مُوسیٰ دے خیال وِچ اِیویں لڳِیاں جِیویں جو او چَلدیاں سُردیاں وَدّیاں ہُووِن (٦٦)۔
  20,67,ٻَس مُوسیٰ کُوں دِلّ وِچ ݙَر لَڳَݨ پَے ڳِیا (٦٧)۔
  20,68,اَساں اُوکُوں آکھیا، ݙَر نہ پِیا بیشک تیݙا ہَتّھ اُتُّوں رَہسی (٦٨)۔
  20,69,اَتے سَٹ گَھت جِہڑا کُجھ تیݙے سَڄّے ہَتّھ وِچ ہے، تاں جو جِہڑا کُجھ اُنھاں بݨا سَٹیئے، اِیہ ساریاں کُوں نِڳل چھوڑے، بیشک جو کُجھ اُنھاں بݨا سَٹیئے، اِیہ تاں جادُوگر دا محض ہِک فریب ہے اَتے جادُوگر کَݙائیں وِی کامیاب نھیں تِھیندا توڑے جو اُتُّوں لَہ آوے (٦٩)۔
  20,70,ٻَس جادُوگر تاں سِجدے وِچ ڈھے پَے، آکھݨ لڳیے، اَساں ہارون تے مُوسیٰ دے رَبّ اُتے اِیمان گِھن آئے ہَیں (٧٠)۔
  20,71,فِرعون آکھیا، تُساں تاں اِیمان وِی گِھن آئیوے اِیں کنُوں پہلے جو مَیں تُہاکُوں اِجازت ݙینداں! او تُہاݙا کوئی وَݙا اُستاد ہے جَیں تُہاکُوں جادُو سِکھایا ہوئے ٻَس مَیں تُہاݙا ہِک پَیر تے ہِک ہَتّھ سَڄّے پاسُوں تے ہِک کَھٻّے پاسُوں کَپوا ݙینداں اَتے کَھڄّیاں نال سُولی چَڑھا ݙینداں اَتے اُوں ویلے تُہاکُوں پَتہ لڳسی جو کِیندا عَذاب زیادہ سَخت اَتے دیر تَئیں رَہݨ والا ہے (٧١)۔
  20,72,اِنھاں آکھیا، جو اَساں تیکُوں وَدّھ اَصلُوں نِسے سَمجھدے انھاں روشن نِشانیاں کنُوں جِہڑیاں اَساݙے کولھ آئِن، تے اُوں کنُوں جَیں اَساکُوں پَیدا کِیتے، جِہڑا تَیں فیصلہ (حُکم) کرݨیں کر چھوڑ، تیݙا حُکم تاں ٻس محض اِیں دُنیاوی زِندگی تے چَل سَڳدے (٧٢)۔
  20,73,بیشک اَساں اَپݨیں رَبّ تے اِیمان گِھن آئے تاں جو او اَساݙے گُناہ بَخش ݙیوے، اَتے اُوں جادو کُوں وِی جِہڑا تَیں اَساں کنُوں زبردستی کروائے، اَتے اَللہ تاں سَب تُوں چَن٘ڳا ہے ہمیشہ باقی رَہݨ والا ہے (٧٣)۔
  20,74,بیشک جِہڑا کوئی اَپݨیں رَبّ دے سامݨیں گُنہگار تِھی تے آسئے تاں ٻَس اُوندے کِیتے دَوزخ ہے، جِیندے وِچ او نہ مَرسے نے جِیسے (٧٤)۔
  20,75,اَتے جِہڑا اُوندے سامݨیں مُومن بَݨ تے آسے، اَتے عَمل وِی نیک کِیتے ہوسِسّ، تاں اِہجے آدمیاں کِیتے بُلند دَرجات ہِن (٧٥)۔
  20,76,ہَمیشہ پَھیلئے پَھیلئے رَہݨ والے باغ ہِن، جِنھاں تَلّے نہراں وَہندیاں وَڳدِیاں پِیاں ہوسِن، او ہمیشہ اُنھاں وِچ رَہسِن، اَتے اِیہ اُوں شَخص دا بَدلہ ہے جِہڑا پاک رِیہے (٧٦)۔
  20,77,اَتے تحقیق اَساں مُوسیٰ کولھ وَحی بھیڄی، جو تُوں میݙیاں بَندیاں کُوں رَات و رَات کَڈھ وَن٘ڄ، وَل اُنھاں کِیتے سَمندر وِچ سوٹی مار تے سُکّا رَاہ بݨا گِھن، نہ تیکُوں پَکڑیج پُووَݨ دا ݙَر ہوسی، اَتے نہ کہیں قِسم دا خدشہ (خطرہ)! (٧٧)۔
  20,78,اِݙُوں فِرعون اَپݨیں لَشکر نال لَا تے انھاں دے پِچُّھوں ڳیا، پَر اُنھاں اُتے سَمندر دا پاݨِیں چَڑھ آیا، تے اُنھاں کُوں چَن٘ڳی طرح ٻوڑ چھوڑیا (٧٨)۔
  20,79,اَتے فِرعون اَپݨِیں قَوم کُوں گُمراہ کر چھوڑیا، اَتے سِدّھے رَاہ نہ لایا (٧٩)۔
  20,80,اَے بنی اِسرائیل تحقیق اَساں تُہاکُوں تُہاݙے دُشمن کنُوں نِجات ݙِیوائی اَتے تُہاݙے نال کوہِ طُور دے سَڄّے پاسُوں دَا وَعدہ کِیتا، اَتے اَساں تُہاݙے کِیتے اُتُّوں مَن تے سَلویٰ (سلُوݨ تے مِٹّھاج) لَہایا (٨٠)۔
  20,81,اَللہ آکھیا، جو پاک صاف شَئیں کھاؤ، جِہڑیاں اَساں تُہاکُوں ݙِتِّیاں ہِن، اَتے حَد کنُوں باہر نہ نِکل وَن٘ڄائے، نہ تاں تُہاݙے اُتّے میݙا غضب ڈھہسے اَتے جِیندے اُتے میݙا غضب ݙَٹَّھا، ٻَس او بَرباد تِھی ڳیا(٨١)۔
  20,82,اَتے مَیں اُوندے کِیتے بَخشݨ ہار ہَاں، جِہڑا تَوبہ تائب تِھی ویسے، اَتے اِیمان گِھن آسے اَتے نیک عَمل کریسے، وَل سِدّھی رَاہ تے وِی چَلسے(٨٢)۔
  20,83,اَتے اَے مُوسیٰ تیکُوں اَپݨِیں قَوم کنُوں اَڳُوں کِہڑی شَئے گِھن آئی ہے (٨٣)۔
  20,84,اُوں آکھیا، او وِی میݙے پِچُّھوں لڳے آندے ہِن، اَتے میݙے رَبّ آ ! مَیں تَیں دو جلدی اِیں ڳالھُوں کِیتی ہے، جو تُوں راضی تِھی وَن٘ڄیں (٨٤)۔
  20,85,اَللہ آکھیا، ٻَس اَساں تیݙی قَوم کُوں تیݙے پِچُّھوں ہِک اَزمائش وِچ گَھت ݙِتّے، اَتے سامری اُنھاں کُوں گُمراہ کر گِھدّے (٨٥)۔
  20,86,ٻَس مُوسیٰ آپݨِیں قَوم دو وَل آیا، کَاوَڑیا ہوئیا تے مُونجھا مُونجھا ! آکھیُس جو اَے میݙی قَوم! کیا تُہاݙے رَبّ تُہاݙے نال وَعدہ نہ کِیتا ہوئیا ہَا وَعدہ وِی سُوہݨاں جیہا، کیا تُہاݙے کِیتے وَعدے دِی میعاد لمبی تِھی ڳئی ہَئی، یا تُساں چَہندے ہَاوے جو تُہاݙے اُتّے تُہاݙے رَبّ دا غضب ڈھہوے، اِیں ڳالھُوں تُساں میݙے نال کِیتے ہوئے وَعدے دِی خلاف وَرزی کر چھوڑی ہے (٨٦)۔
  20,87,اُنھاں آکھیا، اَساں آپݨِیں اِختیار نال تیݙے نال وَعدہ خِلافی نھیں کِیتی، بَلکہ اَساکُوں اَپݨِیں قَوم دے ڳہݨیاں دَا بار چَوا ݙِتّا ڳِیا ہَا، ٻَس اَساں اُنھاں کُوں (بھا وِچ) سَٹ گھتیا، پَر اِہجی تجویز سامری ݙَسّی ہَئی (٨٧)۔
  20,88,وَل اُوں اُنھاں کِیتے ہِک وَچّھے دا بوتا کَڈھ کَھڑایا، او ݙَان٘د وان٘گُوں اَوازاں کَڈھیندا ہَا، ٻَس لوکاں آکھیا، جو اِیہ تاں (اَساݙی عِبادت دے ݙَا دَا) معبود ہے، اَتے مُوسیٰ دَا معبود وِی ہے پَر اُوں اِیکُوں وِسار چھوڑے (٨٨)۔
  20,89,کیا اُنھاں لوکاں نہ ݙِٹَّھا ہَا، جو او نہ تاں اُنھاں دِی کہیں ڳالھ دا جواب ݙیندے اَتے نہ اُنھاں کُوں کوئی نفع یا نُقصان ݙیوݨ دا اِختیار رَکھیندے (٨٩)۔
  20,90,اَتے تحقیق ہارون اُنھاں کُوں پہلے کنُوں چِتا وِی ݙِتّا ہَا، جو اَے میݙی قَوم! حقیقت اِیہ ہے، جو اِیندے نال تُہاݙی اَزمائش کِیتی ویندی پَئی ہے، اَتے بیشک تُہاݙا رَبّ ٻَہُوں مہربان ہے، ٻَس تُساں میݙی پَیروی کرو ! اَتے میݙے آکھیئے تے چَلُّو (٩٠)۔
  20,91,او آکھݨ لڳے اَساں تاں اِیندی بَندگی وِچ لڳئے رَہسُوں، جے توڑِیں جو مُوسیٰ اَساݙے کولھ نہ وَل آسے (٩١)۔
  20,92,مُوسیٰ آکھیا، اَے ہارون ڄَݙاں جو تَیں اُنھاں کُوں گُمراہ تِھیندا ݙِٹَّھا وِی ہَا تاں تیکُوں کَیں روکی رَکھیا ہَا(٩٢)۔
  20,93,میݙے طریقے تے چَلَّݨ کنُوں، کیا تَیں میݙے آکھیئے دے خِلاف نھیں کِیتا (٩٣)۔
  20,94,اُوں آکھیا، میݙی مَاء دے پُتر آ ! نَہ میݙی ݙَاڑھی پَکڑ اَتے نہ میݙے سِر (دے وال) پَٹ، مَیں تاں اِیں ڳالھ کنُوں ݙَریا ہَم، جو کِتَھائیں تُوں آ تے نہ آکھیں جو تَیں بَنی اِسرائیل وِچ فَرق گَھت ݙِتِن، اَتے میݙی ڳالھ دَا خیال وِی نہ رَکھیا (٩٤)۔
  20,95,وَت مُوسیٰ آکھیا، سامری آ ! تیݙی کیا ڳالھ ہے (٩٥)۔
  20,96,اُوں آکھیا، مَیں او کُجھ ݙیکھ گِھدّا ہَا، جِہڑا کُجھ اِیہ نہ ݙیکھ سَڳئے ہَن، ٻَس مَیں رسول دے پَیراں تَلے دِی مِٹّی دِی ہِک مُٹّھ بَھر گِھدّی، تے اُوکُوں اِیں (وَچّھے) وِچ گَھت ݙِتُّم اَتے اِیں طرح میݙے نَفس کُوں اِیہ ڳالھ چَن٘ڳی لَڳی (٩٦)۔
  20,97,مُوسیٰ آکھیا، ٻَس تُوں (اِتُّھوں) چَلیا وَن٘ڄ ! تیݙے کِیتے ساری زِندگی اِیہا (سَزا) ہے جو تُوں (لوکاں کُوں) اَکھیسیں وَدَّا جو میکُوں ہَتّھ نہ لَواہے اَتے تیݙے کِیتے ہِک میعاد ہے پُچّھ پَرتیت دِی، جِہڑی اَصلُوں نہ ٹَلسے، اَتے تُوں اَپݨیں اُوں معبود دو ݙیکھ، جِیندی پُوجا تُوں ݙَاڈھی سِک نال کریندا ہَاویں، اَجھو اَساں اُوکُوں ساڑ چھوڑیسُوں، وَل (اُوندی سُوا کُوں) اُݙا تے دَریا وِچ کِھن٘ڈا پُن٘ڈا ݙیسُوں (٩٧)۔
  20,98,بیشک تُہاݙا معبود (عبادت دے ݙَا دا) اُوہُو اَللہ اِی ہے، جِیندے سِوا ٻِیا کوئی معبود کائے نھیں، اُوں ہَر شَئے کُوں اَپݨیں عِلم وِچ رَکھیا ہوئیا ہے(٩٨)۔
  20,99,(اَے رسول) اِیں طرح اَساں تیکُوں او حالات بیان کریندے ہَیں جِہڑے گُزر چُکیئے ہِن، اَتے تحقیق اَساں تیکُوں اَپݨیں طرفُوں ہِک نصیحت (دِی کتاب) عَطا کِیتی ہے (٩٩)۔
  20,100,جِہڑا شَخص اِیں کنُوں مُن٘ہ پِھریسے، تاں بیشک اُوکُوں قیامت دے ݙین٘ہ ٻَہُوں سَخت بار چاوَݨاں پُوسے (١٠٠)۔
  20,101,(اِہجے لوک) اُوں عَذاب وِچ ہمیشہ پَھسّے رَہسِن، اَتے قیامت دے ݙین٘ہ اِیہ بار اُنھاں کِیتے ٻَہُوں سَخت ہوسے (١٠١)۔
  20,102,اُوں ݙین٘ہ صُور پُھوکیا ویسے اَتے گُنہگاراں کُوں (اِہجی حالت وِچ) کَٹَّھا کِیتا ویسے جو اُوں ݙین٘ہ اُنھاں دِیاں اَکّھیں پُٹّھیاں تِھیاں وَدّیاں ہوسِن (١٠٢)۔
  20,103,او آپس وِچ کُھسّ پُھسّ کریسِن، جو تُساں تاں ٻَس ݙَاہ ݙین٘ہ (دُنیا وِچ) رِیہے ہوسے (١٠٣)۔
  20,104,اَساں خُوب ڄاݨدے ہِیسے، جِہڑا کُجھ او اَکھیندے وَدّے ہَن، اُوں وَقت ساریاں کنُوں چَن٘ڳا اَندازہ لَاوَݨ والا ݙَسیسے، جو کوئے نہ! تُساں تاں محض ہِک ݙین٘ہ رِیہے ہِیوے (١٠٤)۔
  20,105,اَتے تَیں کنُوں پَہاڑاں دے متعلّق پُچھدِن، ٻَس آکھ ݙے جو میݙا رَبّ (اُوں ݙین٘ہ) اُنھاں کُوں اُݙا پُݙَا ݙیسے (١٠٥)۔
  20,106,اَصلُوں چِٹ پدّھر بݨا چھوڑیسے (١٠٦)۔
  20,107,جِیندے اُتّے نہ ݙِن٘گی پِھن٘گی جاء نَظرسے، اَتے نہ کوئی ٹِٻہ شِٻَّہ (١٠٧)۔
  20,108,اُوں ݙین٘ہ سارے لوک ہِک سَݙݨ والے دے پِچُّھوں لَڳ پُوسِن تے اُوندے اَڳُوں کوئی نہ اَکڑِیسے، اَتے ٻَہُوں مہربان اَللہ دے اَڳُوں سَب دِیاں آوازاں دَبِیج ویسِن، ٻَس تُوں چَھڑے کھسکار دے سِوا کوئی آواز نہ سُݨسیں (١٠٨)۔
  20,109,اُوں ݙین٘ہ کوئی سِفارِش کہیں کَمّ نہ آسی، سِوائے اُوں شَخص (دِی سِفارِش دے) جیکُوں ٻَہُوں مہربان اَللہ اِجازت ݙیسے، اَتے جِیندی ڳالھ اُوکُوں بھاسے (١٠٩)۔
  20,110,او ڄاݨدا کھڑے جِہڑا کُجھ اُنھاں لوکاں دے سامݨیں ہے، اَتے جِہڑا کُجھ اُنھاں کنُوں پہلے تِھی چُکئیے، لوکاں دا عِلم تاں اِیں ڳالھ دا کوئی اَحاطہ نھیں کر سَڳدا(١١٠)۔
  20,111,اَتے ہمیش جِیوݨ والی تے قائم رَہݨ والی ہَستی دے سامݨیں اُنھاں دے سِر جُھک ویسِن، اَتے تحقیق جَیں ظُلم دِی ڳَنڈھڑی چَا گِھدّی اُوہُو نا مُراد رَہسی (١١١)۔
  20,112,اَتے جِہڑا شَخص نیک کَمّ کریسے، اَتے مُومِن وِی ہوسے، تاں اُوکُوں نہ کَہیں ظُلم دا ݙَر ہوسے اَتے نہ اُوندی کوئی حَق تَلفی ہوسے(١١٢)۔
  20,113,اَتے اِیں طرح اَساں قرآن کُوں عَربی وِچ نازِل کِیتے اَتے اِیندے وِچ دے کئی ݙَراوے وَلا بَھں٘وا تے بیان کِیتے ہِن، تاں جو لوک پَرہیزگار بَݨ وَن٘ڄݨ یا اُنھاں کِیتے ہوش (نصیحت) دا باعث بݨِݨ (١١٣)۔
  20,114,ٻَس اَللہ ٻَہُوں اُچّے دَرجے والا، تے حقیقی بادشاہ ہے، (اَے رسول) قرآن دے بارے جَلدی نہ کِیتی کر، جے توڑِیں جو تَیں دو وَحی پُوری نہ آون٘ڄے، اَتے دُعا مَن٘گی کر جو میݙے رَبّ آ ، میݙے عِلم کُوں ٻِیا وِی وَدھا (١١٤)۔
  20,115,اَتے اَساں اِیں کنُوں پہلے آدَم کنُوں یقیناً قَول گِھدّا ہَا، پَر اُوں وِسار ݙِتا، اَتے اَساں اُوکُوں پَکّے اِرادے والا نہ ݙِٹَّھا(١١٥)۔
  20,116,اَتے ڄَݙاں اَساں فرشتیاں کُوں آکھیا ہَا، جو آدم کُوں سجدہ کرو، تاں اُنھاں ساریاں سجدہ کِیتا سِوائے اِبلیس دے، جَیں اِنکار چَا کِیتا ہَا (١١٦)۔
  20,117,اَساں آدم کُوں آکھیا، جو بیشک اِیہ تیݙا اَتے تیݙی ذال دَا دُشمن ہے، کِتَھائیں تُہاکُوں بَہشت وِچُوں کَڈھوا نہ چھوڑے، وَل مُصیبتاں وِچ نہ آوَن٘ڄو (١١٧)۔
  20,118,بیشک نہ تُوں اِتَّھاں بُکھا رَہندیں اَتے نہ تَن کنُوں نَنگا(١١٨)۔
  20,119,اَتے بیشک اتھاں نہ تیکُوں تریھ لڳدی ہے تے نہ تیکُوں دُھپ لَڳدی ہے (١١٩)۔
  20,120,پَر شیطان اُوکُوں وِسواس وِچ گَھت ݙِتَّا ، آکھیُس، کیا مَیں تیکُوں اِہجا دَرخت (اَن) ݙَساواں جِہڑا تیݙے ہمیش جِیندے رَہݨ دا سَبب بَݨ وَن٘ڄے، اَتے اہجی بادشاہی وِی ݙَساواں جو کݙاہِیں نہ کھسِیجے (١٢٠)۔
  20,121,ٻَس ݙُوہائِیں اُوں وَݨ دَا پَھل کَھادا تاں ہِک ٻئے اُتّے اُنھاں دے نن٘گیج ظاہر تِھی ڳئے، اَتے بَہشت دے پَتراں نال اَپݨیں نَن٘گیج کُوں کَڄݨ لَڳ پَے، اَتے آدَم نے اَپݨیں رَبّ دِی نافرمانی چَا کِیتی، ٻَس او سِدّھے رَاہ کنُوں تِھڑک ڳیا(١٢١)۔
  20,122,وَل اُوندے رَبّ اُوندے اُتّے مہربانی چَا کِیتی، اُوندی تَوبہ قبول کر گِھدّی تے سِدّھی رَاہ چَا لائیا (١٢٢)۔
  20,123,اَللہ آکھیا، تُساں ݙُوہائیں کَٹّھے اِتُّھوں تَلّے لَہ وَن٘ڄُو، تُہاݙے وِچُوں بعضے بعضیاں دے دُشمن تِھی رَہسُو، ٻَس جِہڑا میݙی ہِدایت اُتے چَلسے تاں او نہ گُمراہ تِھیسے اَتے نہ مُصیبت وِچ پَوسے (١٢٣)۔
  20,124,اَتے جَیں میݙی نصیحت (ذِکر) کنُوں مُن٘ہ پھیر گِھدّا، تاں اُوندی زِندگی اَوکھی گُزرسی، اَتے قیامت دے ݙِین٘ہ اَندّھا کر تے اُٹَھایا ویسے(١٢٤)۔
  20,125,او اَکھیسے، میݙے رَبّ آ ! میکُوں اَندھا کر تے کِیُوں اُٹَھائی، مَیں تَاں چَن٘ڳا بَھلا ݙیکھدا بَھلیندا وَدَّا ہَم (١٢٥)۔
  20,126,اَللہ اَکھیسے جِیویں جو میݙیاں آیاتاں تیݙے کولھ آئیاں ہَن، تاں تَیں اُنھاں کُوں وِسار ݙِتا ہَا، اِیویں اِی اَڄ تیکُوں وِسار ݙِتا ڳے (١٢٦)۔
  20,127,اَتے اُوکُوں وِی اِیویں جَزا ݙیسُوں، جِہڑا حَد کنُوں نِکل ویسے، اَتے جِہڑا اَپݨیں رَبّ دِیاں آیاتاں اُتّے اِیمان نہ گِھن آسے، اَتے آخرت دَا عَذاب ٻَہُوں سَخت ہے اَتے ہمیش رَہݨ والا ہے(١٢٧)۔
  20,128,کیا اُنھاں کِیتے اِیں ڳالھ وِچ کوئی ہِدایت نہ ہَئی، جو ڄَݙاں اَساں اُنھاں کنُوں پہلے کئی قَوماں کُوں تَباہ کر ݙِتے، جِنھاں دِیاں وَستیاں (ٹِکاݨیاں) وِچ اِیہ ٹُردے پِھردے وَدِّن، بیشک اِیندے وِچ عقل والیاں کِیتے نِشانیاں ہِن(١٢٨)۔
  20,129,اَتے جیکر تیݙے رَبّ دِی طرفُوں پہلے کنُوں ہِک ڳالھ مُکّی ہوئی نہ ہُوندی تاں اُنھاں اُتّے لازمی عَذاب آڳیا ہوندا، ٻِیا اِیہ جو جیکر اُنھاں کِیتے اَجل (میعاد) وِی مقرر نہ تِھی چُکّی ہُوندی(١٢٩)۔
  20,130,ٻَس جو کُجھ اِیہ اَکھیندِن اُوندے اُتّے صَبر چَا کر، اَتے اَپݨیں رَبّ دِیاں تعریفاں نال اُوندی تسبیح پَڑھی کِیتی کر، سِجھ نِکلݨ کنُوں پہلے، اُوندے لَہ وَن٘ڄݨ کنُوں پہلے، ٻِیا اِیہ جو رَات دے کُجھ ویلیاں وِچ وِی تَسبیح پَڑھی رَکّھ، اَتے ݙین٘ہ دے اِݙُّوں، اُݙُّوں (کِناریاں تے) وِی! اِیں طرح تُوں خُوش رَہسیں(١٣٠)۔
  20,131,اَتے اَکّھیں بَھن٘وا تے وِی نہ ݙیکھ اُنھاں وِچُوں دے لوکاں کُوں، جِنھاں کُوں اَساں زِندگی دے ٹَھاٹھ ٻَاٹھ نال رَڄایا ہوئے، اِیہ تاں اُنھاں کُوں اَزمائِش وِچ سَٹَّݨ ہے اَتے تیݙے رَبّ دا رِزق ٻَہُوں چَن٘ڳا تے ہمیش کِیتے ہے(١٣١)۔
  20,132,اَتے اَپݨیاں لوکاں کُوں نماز کِیتے حُکم ݙے اَتے اِیندا پابند تِھی تے رَہ، اَساں تَیں کنُوں رِزق نِسّے مَن٘گدے، بَلکہ خُود اَساں اِی تیکُوں رِزق ݙیندے ہَیں، اَتے پرہیزگاراں دا تاں چَن٘ڳا اَنجام ہے (١٣٢)۔
  20,133,اَتے اَہدِن جو اِیہ آپݨیں رَبّ کنُوں اَساݙے کِیتے کوئی نِشانی (معجزہ) کِیُوں نھیں گِھن آندا، بَھلا کیا انھاں کولھ پہلیاں کِتاباں دے وِچ وی روشن دَلیل نھیں آ چُکّی (١٣٣)۔
  20,134,اَتے جیکر اَساں اُنھاں کُوں اِیں کنُوں پہلے کَہیں عَذاب وِچ تَباہ کر چھوڑیندے، تاں اَکھیندے جو اَساݙے رَبّ آ ! تَیں اَساں دو کوئی رسول کِیُوں نھیوی بھیڄیا تاں جو اَساں ذلیل تے خُوار تِھیوَݨ کنُوں پہلے اِی تیݙیاں آیاتاں دِی پَیروی کر گِھندے(١٣٤)۔
  20,135,(اَے رسول) آکھ ݙے جو ہَر کوئی عَملاں دے نتیجیاں دِی اِنتظار وِچ ہے، ٻَس تُساں وِی اِنتظار کرو، اَجھو تُہاکُوں پَتہ لَڳ ویسے جو کوݨ (دِین دے) سِدّھے رَاہ تے چَلَّݨ والا ہے، اَتے کَیں ہِدایت پَا گِھدّی ہے(١٣٥)۔
