quran[16{c,v,t}:
7,105,میݙے اُتے واجب ہے جو اَللہ دا ناں گِھن تے جِہڑا کُجھ وِی آکھاں سَچ سَچ آکھاں، لہٰذا مَیں تُہاݙے کولھ تُہاݙے رَبّ دِی طرفوں کُھلی (واضح) نشانی گِھن تے آیاں، ہُݨ اسرائیل والیاں کُوں میݙے نال وَن٘ڄݨ ݙے (١٠٥)۔
7,106,فرعون آکھیا، جیکر تُوں کوئی نشانی گِھن آئیں تاں او سامݨیں گِھن آ (١٠٦)۔
7,107,ٻَس (موسیٰ نے) آپݨِیں سوٹی اَڳوں سَٹ گھتی، تاں او ہُوں ویلے ہِک جیندا جاگدا وَݙا سارا نان٘گ ٻَݨ ڳیا (١٠٧)۔
7,108,وَت اُوں آپݨاں ہَتھ ظاہر کِیتا، تاں او ہُوں ویلے ݙیکھݨ والیاں کُوں عانے وان٘گوں چِٹّا نظر آیا (١٠٨)۔
7,109,فرعون دِی قوم دے سرداراں آپس وِچ آکھیا، جو اِیہ تاں کوئی وَݙا ماہر جادوگر ہے (١٠٩)۔
7,110,اِیندا اِرادہ ہے جو تُہاکوں تُہاݙے مُلک وِچوں کڈھ چھوڑے، ہُݨ ݙَسُو، کیا صلاح ݙیندے وے (١١٠)۔
7,111,انھاں جواب ݙِتا، جو (حالی) موسیٰ تے اُوندے بِھرا دے معاملے کُوں رَہݨ ݙیو، اَتے بندے کَٹھے کر آوَݨ والیاں کُوں شہراں وِچ بھیڄ ݙیو (١١١)۔
7,112,تاں جو سارے دانا تے ماہر جادوگراں کُوں تیݙے کولھ گِھن آوِن (١١٢)۔
7,113,چنانچہ جادوگر فرعون دے کولھ آڳئے، اُنھاں پُچھیا، اَساکوں اِیندا اَجر تاں ضرور ݙِتا ویسی، جیکر اَساں (موسیٰ اُتے) غالب تِھی ڳیوسے تاں؟ (١١٣)۔
7,114,اُوں آکھیا، ہَا (ضرور ݙیساں) ٻِیا اِیہ ڄو تُساں بیشک میݙے نیڑے رَہݨ والیاں وِچوں تِھی ویسو (١١٤)۔
7,115,وَل جادوگراں آکھیا، اَے موسیٰ! یا تاں تُوں پہلے جادو دِی کوئی شَئے ساریْاں دے سامݨیں سَٹ یَا وَل اَساں (پہلے) سَٹݨ والے بݨدے ہَیں (١١٥)۔
7,116,موسیٰ آکھیا، چلو تُساں سَٹو، ٻَس ڄَݙاں اُنھاں آپݨیاں جادوئی سوٹیاں رَسیاں وَغیرہ سٹیاں تاں اُنھاں لوکاں دِیاں اَکھیاں مُندر گِھدیاں، اَتے انھاں کُوں ݙرا ݙِتا اَتے ہِک وَݙے جادو دا سامان کر ݙِکھایا (١١٦)۔
7,117,اَتے اَساں موسیٰ کول وَحی بھیڄی، جو تُوں وِی آپݨِیں سوٹی سَٹ ݙے (انھاں سَٹی ) تاں او فوراً اُنھاں شَئیں کُوں جِہڑیاں انھاں سَٹیاں ہوئیاں ہن، نِڳل چھوڑیا (١١٧)۔
7,118,اِیں (طرح) حق حق ثابت تِھی ڳیا، اَتے جِہڑا کُجھ عَمل (فرعونی) کریندے ہَن، سب کُوڑے ثابت تِھی ڳئے (١١٨)۔
7,119,(فرعون تے جادوگر) ہُوں ویلے ہار ڳئے، تے ذلیل تے خوار تِھی ڳئے (١١٩)۔
7,120,اَتے جادوگر سِجدے وِچ ڈھیہ پَے (١٢٠)۔
