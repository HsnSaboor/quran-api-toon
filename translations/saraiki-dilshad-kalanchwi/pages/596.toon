quran[26{c,v,t}:
92,15,اِیندے وِچ کوئی داخل نہ تِھیسے، سِوائے وَݙے بَد بَخت دے(١٥)
92,16,جَیں حقیقت کُوں کُوڑ آکھیا، تے مُن٘ہ چَا وَٹایا(١٦)
92,17,اَتے اُوں شَخص کُوں ضرور (اِیں کنُوں) پَرے رَکھیا ویسی، جِہڑا وَݙا پَرہیزگار ہوسی(١٧)
92,18,جِہڑے آپݨاں مال اَللہ دے رَاہ تے ݙیندِن نیک پَاک رَہݨ کِیتے (١٨)
92,19,اَتے اُوندے اُتّے کہیں دا کوئی اِحسان کائے نھیں، جِیندا بَدلہ اُوکُوں لَہاوَݨاں ہُووے(١٩)
92,20,او تاں ٻَس آپݨیں بلند و بَرتر رَبّ دِی خُوشی حاصل کرݨ چَہندے(٢٠)
92,21,تے اُوں کنُوں اَجھو خُوش تِھی ویسی(٢١)۔
93,1,قَسم ہے ݙِین٘ہ چَڑھیے دِی(١)۔
93,2,قَسم ہے رات دِی ڄَݙاں (او ہَر شَئے) کُوں کَڄ گِھنّے(٢)
93,3,اَے رسول) تیݙے رَبّ تیکُوں اَصلُوں نھیں چھوڑیا، اَتے نہ ناراض تَھئے(٣)
93,4,واقعی تیݙے کِیتے آخرت دَا دَور تیݙے پہلے (دُنیاوی) دَور کنُوں بہتر ہے(٤)۔
93,5,اَتے اَجھو تیݙا رَبّ تیکُوں او کُجھ ݙیسی، جو تُوں خُوش تِھی ویسیں(٥)۔
93,6,کیا اُوں تیکُوں یتیمی وِچ نھیں پَیدا کِیتا، وَت اُوں تیکُوں پَناہ چَا ݙِتّی(٦)
93,7,اَتے تیکُوں ہِدایت کنُوں پَرے ݙِٹَّھا تاں ہِدایت دَا رَاہ چَا ݙِیکھایا(٧)
93,8,اَتے تیکُوں غریب ݙِٹَّھا تاں مالدار چَا بَݨایا(٨)
93,9,ٻَس جِہڑا کوئی یتیم ہُووے تاں اُوندے اُتّے سَختی نہ کِیتی کر(٩)
93,10,اَتے جِہڑا کوئی مَنگݨ والا ہُووے تاں اُوکُوں جِھڑکیاں نہ ݙِتّیاں کر(١٠)
93,11,اَتے آپݨیں رَبّ دِیاں جِہڑیاں نعمتاں ہِن اُنھاں کُوں بیان کِیتی رَکّھ(١١)۔
94,1,اَے رسول) کیا اَساں تیݙے کِیتے تیݙے سِینے کُوں کھول نھیں ݙِتَّا(١)
94,2,اَتے تَیں کنُوں تیݙے سِینے دَا او بار لَہا نھیں چھوڑیا(٢)۔
94,3,جَیں تیݙی چیل کُٻّی کِیتی ہوئی ہے(٣)۔
94,4,اَتے اَساں تیݙے کِیتے تیݙے ذِکر دَا غوغا مَچوا ݙِتّا(٤)
94,5,ٻَس یقیناً ہَر سَختی دے نال آسانی ہُوندی ہے(٥)
94,6,بیشک ہَر سَختی دے نال آسانی ہُوندی ہے(٦
94,7,ٻَس جِہڑے ویلے تُوں فارغ ہُوویں، تاں وَت وِی جُہت کِیتی رَکھیں(٧)
94,8,اَتے آپݨیں رَبّ دو پُوری رَغبت رَکّھی رَکّھ(٨)
