quran[16{c,v,t}:
43,74,اِیہ حقیقت ہے جو مجرم لوک ہمیشہ کِیتے دَوزخ دا عذاب بھوڳیندے رَہسِن (٧٤)۔
43,75,اُنھاں دا عذاب ذری وِی نہ گھٹایا ویسے اَتے او اُوندے وِچ بے آس تَھئے رَہسِن (٧٥)۔
43,76,اَتے اَساں اُنھاں اُتے کوئی زِیادتی نھیں کِیتی بلکہ او تاں خُود آپݨیں آپ اُتے ظلم کرݨ والے ہَن (٧٦)۔
43,77,اَتے او (داروغے دا ناں گِھن تے) اَکھیسِن، اَے مالک ! تیݙا رَبّ تاں اَساکُوں موت چَا ݙیوے، او اَکھیسی تحقیق تُساں تاں ہمیشہ ہِیں حالت وِچ اِی رَہسُو (٧٧)۔
43,78,تحقیق اَساں تُہاݙے کولھ حَق گِھن اَیُوسے، پَر تُساں وِچُوں ڈھیر سارے لوک حق کنُوں کریہت (نفرت) کریندے ہَن (٧٨)۔
43,79,کیا انھاں کوئی ڳالھ طَے کر گِھدّی ہے (٧٩)۔
43,80,ٻَس وَل اَساں وِی اَپݨِیں ڳالھ طَے کرݨ والے ہَیں کیا او اِیہُو خیال کریندِن جو اَساں اُنھاں دِیاں ڳالھیں، تے کنّاں وِچ کُھس پُھس ، نِسّے سُݨ سَڳدے، کِیوں نِسّے سُݨدے! اَتے اَساݙے بھیجے ہوئے فرشتے انھاں دے کولھ رہ تے سَب کُجھ لکھیندے رَہندِن (٨٠)۔
43,81,(اَے رسول) تُوں اُنھاں کُوں آکھ ݙے، جو جیکر ٻَہُوں مہربان اَللہ دا کوئی پُتر ہوندا تاں ساریاں کنُوں پہلے مَیں اُوندی بَندگی کریندا (٨١)۔
43,82,اَسماناں دا تے زمین دا تے عرش دا مالک انھاں ڳالھیں کنُوں تاں پاک ہے جِہڑیاں اِیہ (اُوندے متعلّق) سُݨیندے وَدّے ہَن (٨٢)۔
43,83,ٻَس تُوں اُنھاں کُوں پَرے کر، اِیہ اَپݨیاں بحثاں تے بے ہُودہ حرکتاں کریندے رِہّن، او توڑِیں جو او ݙین٘ہ سامݨیں آ وَن٘ڄنیں، جیندا انھاں نال وَعدہ کِیتا ویندے (٨٣)۔
43,84,اَتے اُوہو ہِکّو اَسماناں وِچ معبود ہے، تے زمین تے وِی معبود ہے اَتے او وَݙی دانائی والا سَب کُجھ ڄاݨݨ والا ہے (٨٤)۔
43,85,اَتے ٻَہُوں برکتاں والا ہے جِیندی بادشاہی ہے، اَسماناں اُتے تے زمین اُتے، اَتے جو کُجھ اُنھاں دے اَدّھ وِچ ہے، اَتے (قیامت دِی) گھڑی دا عِلم وِی ہُوکُوں ہے، اَتے ہُوندو اِی تُساں وَل وَن٘ڄݨیں (٨٥)۔
43,86,اَتے او تاں سِفارش کرݨ دا اِختیار وِی نھیں رَکھیندے جِنھاں کُوں اِیہ لوک اُوکُوں چھوڑ تے سݙیندِن، سِوائے اُوندے جِہڑا حق دِی گواہی ݙیوے، اَتے او ڄاݨدا سَمجھدا وِی ہووے (٨٦)۔
43,87,اَتے جیکر تُوں اُنھاں کنُوں پُچّھیں جو اُنھاں کُوں کَیں پَیدا کِیتے تاں او آکھ ݙیندِن جو اللہ نے ! وَل اِیہ کِتُّھوں دھوکا کھاندے ہِن (٨٧)۔
43,88,قسم ہے (رسول) دے اِیں آکھیے دِی، جو میݙے رَبّ آ بیشک اِیہَا قوم ہے، جِہڑی اِیمان گِھن آوَݨ والی نظردی کائے نھیں (٨٨)۔
43,89,ٻَس (اَے رسول) تُوں اُنھاں کنُوں مُن٘ہ پھیر گِھنّ، اَتے آکھ جو میݙے سَت سلام ہِن، ٻَس ٻَہُوں جَلدی اُنھاں کُوں (اَنجام دا) پَتہ لڳ ویسے (٨٩)۔
