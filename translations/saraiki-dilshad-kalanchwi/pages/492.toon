quran[14{c,v,t}:
43,34,اَتے انھاں دے گھراں دے دروازے تے تخت، جِنھاں اُتے او ٹیک لا تے ٻَہندِن، انھاں کُوں وِی (چاندی دے بݨا ݙیندے ) تے سونے دے (ڳہݨیں) وِی! (٣٤)۔
43,35,پَر اِیہ ساریاں شَئیں تاں محض دُنیا دِی حیاتی وِچ وَرتݨ دِیاں شَئیں ہِن، اَتے پرہیزگار لوکاں کِیتے تیݙے رَبّ دے کولھ آخرت (دِیاں شَئیں ہِن) (٣٥)۔
43,36,اَتے جِہڑا ٻَہُوں مہربان اَللہ دِی یاد کنُوں لَا پَرواہی کریندے، تاں اَساں اُوندے کِیتے ہِک شیطان مقرر کر ݙیندے ہَیں، اَتے او اِیندا گھاٹا یار بݨیا رَاہندے (٣٦)۔
43,37,اَتے یقیناً (اِیہ شیطان) انھاں کُوں (سِدّھے) رَاہ کنُوں رُوکیندے، پَر اِیہ لوک سَمجھدِن، جو اَساں تاں سِدّھے رَاہ تے ہَیں (٣٧)۔
43,38,اِیہ توڑِیں جو ڄَݙاں او اَساݙے کولھ آسی، تاں (شیطان کُوں) آکھسی جو اِیویں ہوندا جو میݙے تے تیݙے اَدّھ وِچ سِجھ اُبھار تے ݙین٘ہ لَہا والی وِتّھی ہوندی، ٻَس اِیہ گھاٹا یار تاں ٻَہُوں خراب نِکلیئے ! (٣٨)۔
43,39,اَتے اَڄ تُہاکُوں کوئی شَئے نفع نہ ݙیسی، ڄَݙاں جو تُساں ظُلم (زیادتی) کر چُکیئے وے، بیشک تُساں تے (تُہاݙے شیطان) تاں عذاب وِچ وِی ہِک ٻے دے برابر دے شریک (حِصّے دار) ہِیوے (٣٩)۔
43,40,تاں کیا تُوں ٻوڑیاں کُوں سُݨیسیں، یا اَندھیاں کُوں سِدّھا رَاہ ݙیکھیسیں، اَتے انھاں کُوں وِی جِہڑے کُھلی گُمراہی وِچ ہِن (٤٠)۔
43,41,بھاویں جو اَساں تیکُوں (اِتُّھوں) چَا گِھنُّوں، وَل وِی اَساں انھاں کنُوں انتقام (بدلہ) گِھن تے رَہسُوں (٤١)۔
43,42,یا اَساں (تیݙے جِیندیں) تیکُوں او شَئے ݙیکھا ݙیوُوں جِیندا انھاں نال وَعدہ کِیتا ہوئے، بیشک اَساں اُنھاں اُتے پُوری قدرت (قابو) رَکھیندے ہَیں (٤٢)۔
43,43,ٻَس (اَے رسول) تُوں اُوکُوں تکڑا پَکڑی رَکّھ جو کُجھ تَیں دو وحی کِیتا ڳئے، اِیندے وِچ کوئی شَک کائے نھیں جو تُوں سِدّھے رَاہ اُتے ہیں (٤٣)۔
43,44,اَتے بیشک اِیہ (قرآن) تیݙے کِیتے تے تیݙی قوم کِیتے ہِک پیغام (نصیحت) ہے (٤٤)۔
43,45,اَتے (لُوکو! ) اَجھو تُساں کنُوں پُچّھ پَرتیت کِیتی ویسی، اَتے (اَے رسول) انھاں دا حال پُچّھ ݙیکھو جِنھاں کُوں اَساں تَیں کنُوں پہلے آپݨیاں رسُولاں وِچُوں بھیڄیا ہے، کیا اَساں رحمٰن (ٻَہُوں مہربان) کنُوں سِوا کِنھائیں ٻِنھاں کُوں معبود بݨائے جو انھاں دِی بندگی کِیتی وَن٘ڄے (٤٥)۔
43,46,اَتے تحقیق اَساں مُوسیٰ کُوں آپݨیاں نشانیاں ݙے تے فرعون تے اُوندے سرداراں کولھ بھیڄیا، ٻَس اُوں اُنھاں کُوں آکھیا جو، مَیں سارے جہاناں دے رَبّ دِی طرفُوں رَسُول ہَاں (٤٦)۔
43,47,ٻَس ڄَݙاں اَساݙیاں نِشانیاں گِھن تے اُنھاں کُولھ آیا تاں ہُوں ویلے اُوندیاں مذاقاں کرݨ لڳ پَے (٤٧)۔
