quran[3]{c,v,t}:
  69,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  69,1,سَچ مُچّ تِھی وَن٘ڄݨ والی (١)۔
  69,2,اِیہ کیا ہے سَچ مُچ تِھی وَن٘ڄݨ والی؟ (٢)۔
  69,3,اَتے (اَے رسول) تُوں کیا ڄاݨدیں جو اِیہ سَچ مُچّ تِھی وَن٘ڄݨ والی ہے کیا شَئے؟ (٣)۔
  69,4,ثمود تے عاد نے تاں اُچّے کڑکاٹ گَھتّݨ والی آفت کُوں کُوڑا آکھیا (٤)۔
  69,5,ٻَس جِہڑا ثمود ہَا، اُوکُوں تاں سَخت کڑکاٹ والے حادثے وِچ مار گَھتّیا ڳیا (٥)۔
  69,6,اَتے جِہڑا عَاد ہَا اُوکُوں ہِک تیز گُھلَّݨ والی زور دِی اَندھاری وِچ ہَلاک کر ݙِتا ڳیا (٦)۔
  69,7,اُوں سَت راتیں تے اَٹھ ݙین٘ہاں تَئیں اُوں ڄَڑھاں پَٹ گَھتَّݨ والی اَندھاری کُوں گھولی رَکھیا، ٻَس تُوں اُوں قَوم کُوں اِیں طرح ڈٹھیں ہوئیں ݙیکھدا جِیویں جو او کھوکھلی پولی کَھڄّی دے مُنڈھ ہُووِن (٧)۔
  69,8,ٻَس کیا تُوں اُنھاں وِچُوں کہیں کُوں باقی بَچیا ہویا ݙیکھدیں (٨)۔
  69,9,اَتے فِرعون تے جِہڑے اُوں کنُوں پہلے تِھی گُزرئِن تے او جِہڑے پُٹّھیاں کر ݙِتیاں وَن٘ڄݨ والیاں وَستیاں وِچ آباد ہن، او سارے گُناہاں والے کَم کریندے ہَن (٩)۔
  69,10,ٻَس اُنھاں آپݨیں رَبّ دے رسول دِی نافرمانی کِیتی، وَت اُنھاں کُوں وَݙی آفت وِچ پَکڑ گِھدّا ڳیا (١٠)۔
  69,11,بیشک ڄَݙاں پاݨِیں دا طوفان حَد کنُوں وَدّھ ڳیا تاں اَساں، تُساں لوکاں کُوں ٻیڑی وِچ سوار کر گِھدا ہَا (١١)۔
  69,12,تاں جو اَساں اِیں واقعے کُوں تُہاݙے کِیتے نصیحت دا ذریعہ بݨاؤں، اَتے یاد رَکھݨّ والے کَنّ اِیکُوں یاد رَکّھن (١٢)۔
  69,13,ٻَس جِہڑے ویلے صُور کُوں ہِکّی پُھوک نال پُھوکیا ویسے (١٣)۔
  69,14,اَتے زمین تے پہاڑاں کُوں ہَلایا ویسے، ٻَس اُنھاں کُوں ہِکّے دَھک نال بَھن تَروڑ تے ہِکّو جیہا کر ݙِتا ویسے (١٤)۔
  69,15,اُوں ݙین٘ہ تِھی وَن٘ڄݨ والا واقعہ تِھی تے رَہسی (١٥)۔
  69,16,اَتے اَسمان پَھٹ ویسِن، ٻَس او اُوں ݙین٘ہ ڈھِلّے پِھلّےتِھی ویسِن (١٦)۔
  69,17,اَتے فرشتے انھاں دِیاں کنیاں تے آکھڑسِن، ٻِیا اِیہ جو اُوں ݙین٘ہ اَٹّھ فرشتیاں تیݙے رَبّ دے عرش (تخت) کُوں آپݨیں اُتّے چَایا ہوسی (١٧)۔
  69,18,اُوں ݙین٘ہ تُساں اَللہ دے سامݨیں پیش کِیتے ویسو، اَتے تُہاݙی کوئی ڳالھ لُکّی ہوئی نہ رَہسی (١٨)۔
  69,19,ٻَس جیکُوں اُوندا اَعمالنامہ اُوندے سَڄّے ہَتّھ وِچ پَکڑایا ویسی (١٩)۔
  69,20,ٻَس او اَکھیندا وَدّا ہوسے گِھنُّو پَڑھ گِھنُّو میݙا اَعمالنامہ! (٢٠)۔
  69,21,یقیناً مَیں تاں سَمجھداں وِی ہَم جو میکُوں میݙا حِساب ڈھیڄݨیں، ٻَس او شخص دِل چَہیاں موجاں وِچ ہوسی (٢١)۔
  69,22,اُچّے باغ وِچ (٢٢)۔
  69,23,جِیندے میوے جِھکّے جِھکّے جُھکیئے ہوئے ہوسِن (٢٣)۔
  69,24,مَزّے نال) کھاؤ پِیؤو، ٻَہُوں چَنڳا بَدلہ ہے، تُہاݙے عَملاں دا، جِہڑے تُساں گزریے ݙین٘ہاں (پِچھلی دُنیا وِچ) کِیتے ہَن (٢٤)۔
  69,25,تے اَلبتہ جیں شَخص دا اعمالنامہ اُوندے کَھٻّے ہَتّھ وِچ پَکڑایا ویسے، ٻَس او اَکھیسے، جو ہائے میݙی شَامت، میکُوں تاں میݙا اَعمالنامہ پَکڑایا وِی نہ وَن٘ڄے ہَا (٢٥)
  69,26,۔ اَتے میکُوں ݙَسایا ، چِتایا وِی نہ ویندا، جو میݙے عَملاں دا حِساب کیا کُجھ ہے (٢٦)۔
  69,27,ہائے میݙی شَامت! میکُوں تاں اُوہَا (دُنیاوی) مَوت اِی ہِکّے واری مُکا چُھوڑیندی (٢٧)۔
  69,28,میݙا مال وِی میݙے کہیں کَمّ نھیں آیا (٢٨)۔
  69,29,مَیں کنُوں تاں میݙا اِقتدار وِی ویندا رِیہے (٢٩)۔
  69,30,حُکم تِھیسی) پَکڑ گِھنُّو اِیکُوں، ٻَس اِیندی ڳِچّی وِچ طوق پَوا ݙیوو (٣٠)۔
  69,31,وَل اِیکُوں دَوزخ وِچ بُھکا سَٹّو (٣١)۔
  69,32,وَل اِیکُوں اِہجی زنجیر نال ٻَدھ تے ٹورو، جِیندی لَمبائی سَتّر ٧٠ ہَتّھ ہووے (٣٢)۔
  69,33,تحقیق او سَب تُوں وَݙیاں عظمتاں والے اَللہ اُتّے اِیمان نہ گِھن آندا ہَا (٣٣)۔
  69,34,اَتے او فقیر مسکین کُوں روٹی ٹُکر کھواوَݨ دِی ترغیب وِی کہیں کُوں نہ ݙیندا ہَا (٣٤)۔
  69,35,لَہٰذا (اَڄ) اُوندا اِیں جاء تے کوئی وِی وَݙا حمائتی یار کائے نھیں (٣٥)۔
  69,36,اَتے نہ کوئی کھاݨاں ہے، سوائے زخماں پَھٹاں دے دھو (رَت پُوں) والے پاݨِیں دے (٣٦)۔
  69,37,جیکُوں گُنہگاراں دے عِلاوہ ٻِیا کوئی کَھاسی وِی کائے نہ (٣٧)۔
  69,38,ٻَس مَیں قَسم چینداں اُنھاں شَئیں دِی، جِنھاں کُوں تُساں ݙیکھدے وَدّے ہِیوے (٣٨)۔
  69,39,اَتے اُنھاں شَئیں دِی جِنھاں کُوں تُساں ݙیکھ وِی نہیں سَڳدے (٣٩)۔
  69,40,جو تحقیق اِیہ (قرآن) ہِک عِزّتاں والے رسول دا آکھیا ہویا ہے (٤٠)۔
  69,41,وَت اِیہ کہیں شاعر دا قَول وِی کائے نھیں، پَر تُساں اِیندے اُتے ٻَہُوں تھوڑا اِیمان گِھن آندے وے (٤١)۔
  69,42,اَتے نہ اِیہ کہیں نجومی دا قَول ہے، پَر تُساں اِیں کنُوں ٻَہُوں تھوڑی نصیحت حاصل کریندے وے (٤٢)۔
  69,43,بلکہ اِیہ تاں سارے جہاناں دے رَبّ دِی طرفُوں نازِل کِیتا ہویا ہے (٤٣)۔
  69,44,اَتے جیکر او اَساݙے متعلّق کُجھ ڳالھِیں آپُوں گَھڑ تے گِھن آندا (٤٤)۔
  69,45,تاں اَساں ضرور اُوکُوں سَڄّے ہَتّھ کنُوں پَکڑ گِھندے (٤٥)۔
  69,46,وَل اَساں اُوندی ڳِچّی دِی رَڳ کَپ چھوڑیندے (٤٦)۔
  69,47,ٻَس تُہاݙے وِچُوں کوئی ہِک وِی بَچاوَݨ والا نہ ہوندا (٤٧)۔
  69,48,اَتے یقیناً اِیہ (قرآن) پَرہیزگاراں کِیتے ہِک نصیحت ہے (٤٨)۔
  69,49,اَتے یقیناً اَساں ڄَاݨدے ہَیں جو تُہاݙے وِچُوں بعضے اِیکُوں کُوڑا آکھݨ والے ہِن (٤٩)۔
  69,50,اَتے تحقیق اِیہ (قرآن) کافراں کِیتے پَچھتاوے (حسرت دا) سبب ہے (٥٠)۔
  69,51,اَتے بیشک اِیہ بالکل حقّی طور تے یقین کرَݨ دے قابِل ہے (٥١)۔
  69,52,ٻَس وَت تسبیح پَڑھ آپݨے وَݙیاں عَظمتاں والے رَبّ دے ناں دِی (٥٢)۔
