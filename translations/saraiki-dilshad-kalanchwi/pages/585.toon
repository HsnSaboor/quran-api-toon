quran[42{c,v,t}:
80,1,اُوں مَتّھے تے وَٹّ گَھتیا تے مُن٘ہ پھیر گِھدّا (١)
80,2,اِیں ڳالھُوں جو اُوندے کولھ ہِک اَندھا آ ڳیا ہَا(٢)
80,3,اَتے (اَے رسول) تیکُوں کیا پَتہ جو شاید او نیک بَندہ بَݨ ون٘ڄے ہَا(٣)
80,4,یا جیکر نصیحت کُوں غور نال سُݨدا تاں اِیہ اُوکُوں فائدہ ݙیندی(٤)
80,5,اَلبتہ جِہڑا کوئی لا پَرواہی کریندے(٥)
80,6,ٻَس تُوں اُوندو تاں توّجہ کریندیں(٦)
80,7,تیݙے اُتّے کوئی ذِمّے داری کائے نھیں جیکر او نیک بَندہ نھیں بݨدا(٧)
80,8,اَتے جِہڑا شَخص تیں دو بَھڄدا آندے(٨)۔
80,9,اَتے او ݙَردا وِی ہے(٩)
80,10,تُوں اُوں دو مُن٘ہ وِی نھیں کریندا(١٠)
80,11,اِیں نہ! یقیناً اِیہ ہِک نصیحت ہے (١١)۔
80,12,ٻَس جِہڑا شَخص چَہوے نصیحت حاصل کر گِھنّے(١٢)۔
80,13,اِیہ نصیحت اِہجیاں چھوٹیاں کِتاباں (صحیفیاں) وِچ دَرج ہے جِہڑیاں جو عِزّت والیاں ہن(١٣)۔
80,14,اُچّے رُتبے والیاں ہِن، اَتے پاک صاف ہِن(١٤)۔
80,15,اَتے اُنھاں لِکھݨ والیاں دے ہَتّھ وِچ رَہندِن(١٥)
80,16,جِہڑے جو عِزّتاں والے ہِن، نیک ہِن(١٦)
80,17,ٻَس ماریا ڳیا اِنسان! اِیہ کِہجا نَا شُکرا ہے(١٧)
80,18,اِیکُوں کِہجی شَئے کنُوں پَیدا کِیتا ڳئے؟ (١٨)
80,19,نُطفے (تریڑے) کنُوں اُوکُوں پَیدا کِیتا ڳئے، ٻَس اُوکُوں ہِک اَنداز دَا بݨائے(١٩)
80,20,وَل اُوندے کِیتے (زِندگی دا) رَاہ سِدَّھا سَوَّلا بݨائے(٢٠)
80,21,وَل اُوکُوں مَوت ݙِتی ہے، وَل قَبر وِچ پُور ݙِتا ڳیا(٢١)
80,22,وَل ڄَݙاں چَہسی اُوکُوں اُٹھا کھڑیسی(٢٢)
80,23,حالی نہ، اَڄݨ اُوں او فَرض پُورا نھیں کِیتا جِیندا اُوکُوں حُکم ݙِتا ڳِیا ہَا(٢٣)
80,24,ٻَس اِنسان کُوں اُپݨیں کھاݨیں کُوں غور نال ݙیکھݨاں چاہیدا ہے(٢٤)۔
80,25,بیشک اَساں اُتُّوں خُوب پاݨِیں وَسائے(٢٥)
80,26,وَل اَساں زمین کُوں چَن٘ڳی طرح ݙالیے پاڑیئے(٢٦)
80,27,ٻَس اُوندے وِچُّوں اَنْ ڄَمائے(٢٧)۔
80,28,اَتے اَنگُور، تے ترکاری(٢٨)
80,29,اَتے زیتون، تے کھڄّیاں(٢٩)۔
80,30,اَتے گھاٹے گھاٹے باغ(٣٠)
80,31,اَتے میوے، تے گَھا پَٹَّھا(٣١)
80,32,اِیہ تُہاݙے کِیتے اَتے تُہاݙے ڈھان٘ڈیاں (جانوراں) کِیتے کھاوَݨ پِیوَݨ دا مال متال ہے(٣٢)۔
80,33,ٻَس ڄَݙاں کَنّ پاڑَݨ والی (آواز) آسی(٣٣)
80,34,اُوں ݙِین٘ہ آدمی آپݨیں بِھرا تَئیں کنُوں پَرے بَھڄسے! (٣٤)۔
80,35,اَتے آپݨِیں مَاء کنُوں اَتے آپݨیں پِیؤ کنُوں(٣٥)۔
80,36,ذال کنُوں تے آپݨیاں ٻالاں کنُوں(٣٦)
80,37,اُوں ݙِین٘ہ اُنھاں وِچُّوں ہر کہیں دِی آپݨیں حالت، اِیہ ہوسی جو ٻئے دا ہوش نہ ہوسسّ(٣٧)
80,38,کُجھ لوکاں دے مُن٘ہ چَمکدے پَے ہوسن(٣٨)
80,39,کِھلدے ہَسدے تے خُوش خُرَّم ہوسن۔! (٣٩)
80,40,اَتے کُجھ دے مُونھاں اُتّے دُھدِّھڑ ہوسی(٤٠)
80,41,اُنھاں کُوں کالوِݨ لَڳی ہوئی ہوسی(٤١)
80,42,اِیہے اِی ہِن کُفر کَرݨ والے بَد کِردار(٤٢)
