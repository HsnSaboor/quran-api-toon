quran[13{c,v,t}:
27,23,سَچّ پِیا اَہداں، جو مَیں ہِک ذال ݙِٹّھی ہے، جِہڑی اُنھاں اُتے حکومت کریندی ہے، اَتے ہَر طرح دِی شَئے اُوکُوں بَخشی ڳئی ہے، اَتے اُوندا تَخت وِی ٻَہُوں وَݙا ہے(٢٣)۔
27,24,اَتے مَیں اُوکُوں تے اُوندی قَوم کُوں ݙِٹّھے، جو اَللہ کُوں چھوڑ تے سِجھ کُوں سجدے کریندِن، اَتے شیطان نے (اُنھاں دِیاں نَظراں وِچ) اُنھاں دے کرتُوتاں کُوں سوہݨاں کر تے ݙیکھایا ہوئے، وَل اُوں اُنھاں کُوں سِدّھے رَستے کنُوں روک گِھدّے، ٻَس اُنھاں کُوں سِدّھے رَاہ تے نِھیں لایا ڳیا(٢٤)۔
27,25,بھلا او کِیُوں نَہ اَللہ کُوں سَجدہ کرِن، جِہڑا جو اَسماناں تے زمین دِیاں لُکیاں ہُوئیاں شَئیں کُوں کَڈھیندے، اَتے سَب کُجھ ڄاݨدے جِہڑا کُجھ تُساں لُک تے کریندو، اَتے جِہڑا کُجھ ݙِکھا تے کریندو(٢٥)۔
27,26,اَللہ تاں او ہے جِیندے سِوا ٻِیا کوئی معبود کائے نھیں، او وَݙِیاں عَظمتاں والے عَرش دَا مالِک ہے(٢٦)۔
27,27,سُلیمان آکھیا، اَساں اَجھو ݙیکھ گِھندُوں جو کیا تَیں سَچ آکھیئے یا کوڑیاں وِچُوں ہِیں(٢٧)۔
27,28,تُوں میݙا اِیہ خَط گِھن تے چَلیا وَن٘ڄ، اَتے اُنھاں کولھ وَن٘ڄ سَٹ، وَل اُنھاں کنُوں وَل آ، ٻَس ݙیکھ آ جو او کیا کریندِن(٢٨)۔
27,29,اُوں ذال آکھیا، میݙے قَوم دے سَردارو، اِیہ سَچّ ہے، جو میݙے کولھ ہِک عِزّتاں والا خَط سَٹیا ڳئے(٢٩)۔
27,30,"بیشک او سُلیمان کنُوں آئے، او بالکل اِیں ہے "" شُروع کرینداں ٻَہُوں مہربان تے ہمیشہ رحمت کرݨ والے اللہ دے ناں نال"" (٣٠)۔"
27,31,تُساں میݙے خِلاف کوئی گُستاخی نَہ کرو، بَلکہ فرمانبردار (مسلمان) بَݨ تے مَیں دو لڳئیے آؤ(٣١)۔
27,32,وَل آکھݨ لڳی، جو میݙے قَوم دے سَردارو! میکُوں اِیں معاملے وِچ صَلاح ݙیوُو، مَیں تَاں کُوئی معاملہ طَے وِی نھیں کریندی، جے توڑِیں تُساں شامل نَہ ہُووُو(٣٢)۔
27,33,سَرداراں آکھیا، اَساں طاقت والے ہَیں، اَتے سَخت جَنگاں لَڑݨ والے ہَیں پَر حُکم ݙیوَݨ تیݙے ہَتّھ وِچ ہے، تُوں آپ ݙیکھ گِھنّ جو کیا جواب ݙِیویڄے(٣٣)۔
27,34,اُوں آکھیا، دَراَصل بادشاہ جِہڑے وِی مُلک وِچ داخِل تِھیندِن تاں اُوکُوں چَن٘ڳی طَرح اُڄاڑ ݙیندِن اَتے اُوندے عِزّت دار لوکاں کُوں ذلیل تے خُوار کر چھوڑیندِن اَتے اِیویں تِھیندا آندے(٣٤)۔
27,35,(اِیں ڳالھُوں پہلے) مَیں اُوندے کولھ ہِک تُحفہ ضرور بھیڄیندی ہَاں اَتے ݙیکھدی ہَاں، جو میݙے بَندے کِہجا جواب گِھن آندِن(٣٥)۔
