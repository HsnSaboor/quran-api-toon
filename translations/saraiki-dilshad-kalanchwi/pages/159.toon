quran[6{c,v,t}:
7,68,مَیں تاں تُہاکوں اَپݨیں رَبّ دے سنیہے (احکامات) پُچینداں، اَتے مَیں تاں تُہاݙا قابلِ اعتماد خیر خواہ ہاں (٦٨)۔
7,69,کیا تُہاکوں اِیں ڳالھ تے تعجّب تِھیندے ، جو تُہاݙے کولھ تُہاݙی قوم وِچوں ہِک ڄݨاں تُہاݙے رَبّ دِی طرفوں نصیحت (تنبیہ) گِھن تے آئے (جیندے نال) او تُہاکوں چِتاوے (ݙراوے)، اَتے یاد کرو ڄَݙاں اُوں نوح دِی قوم دے بعد تُہاکوں آپݨاں خلیفہ بݨایا، تُہاکوں وَدھایا، پَھلایا چا، (خوب تکڑا کِیتا چا) ٻَس یاد کرو اَللہ دِیاں نعمتاں کُوں ! تاں جو تُساں فلاح (نجات) حاصل کر سَڳو (٦٩)۔
7,70,انھاں آکھیا، کیا تُوں اَساݙے کولھ اِیں ڳالھوں آئیں جو اَساں محض ہِکّے اَللہ دِی بندگی کروں، اَتے انھاں کُوں چھوڑ ݙیوں، جِنھاں دِی بندگی اَساݙے پِیو ݙاݙے کریندے ہِن، گِھن آ بیشک اُوں عذاب کُوں جَیں کنُوں اَساکوں ݙریندیں، جیکر تُوں سَچ آکھݨ والیاں وِچوں پِیا بݨدیں تاں (٧٠)۔
7,71,"(ھُود) آکھیا، جو تُہاݙے رَبّ دِی طرفوں تُہاݙے اُتے پِھٹکار تے غضب جُڑ ڳئے تُساں کیوں میݙے نال ("" مشکل کُشا"" ، "" داتا "" جیہے خالی خولی) نان٘واں دِی خاطر لڑدے جھڳڑدے ہِیوے، جہڑے جو تُساں تے تُہاݙے وَݙکیاں آپݨِیں طرفوں رَکھ چھوڑے ہِن، جِنھاں دے متعلق اَللہ نے معبود ہووَݨ دِی کوئی دَلیل (سَند) نازِل نھیں کِیتی، ٻَس ہُݨ (نتیجے دِی) اِنتظار کرو، تُساں وِی تے بیشک مَیں وِی تُہاݙے نال اِنتظار کرینداں (٧١)۔"
7,72,ٻَس اَساں اُوکوں تے انھاں لوکاں کُوں جِہڑے اُوندے نال ہَن، آپݨِیں رَحمت دے طفیل بچا گِھدا، اَتے انھاں لوکاں دی ڄَڑھ پَٹ چھوڑی، جِہڑے اَساݙیاں آیاتاں (نشانیاں) کُوں کُوڑا اَکھیندے ہَن، او تاں اِیمان گِھن آوَݨ والے بݨدے وِی نہ ہَن (٧٢)۔
7,73,اَتے قومِ ثمود دے پاسے انھاں دا ہِک بِھرا صالح (پَٹھیا ڳیا) اُوں (اُنھاں کُوں) آکھیا، جو اَے میݙی قوم فقط اَللہ دِی بندگی کرو، تُہاݙے کِیتے اُوندے سِوا ٻِیا کوئی معبود ہے وِی کائے نہ، بیشک! تُہاݙے رَبّ دِی طرفوں ہِک کُھلی نشانی آچکی ہے، اِیہ ہے اَللہ دِی ݙاچی، تُہاݙے کِیتے ہِک نشانی ! اِیکوں چھوڑی رَکھو تاں جو اِیہ اَللہ دِی زمین تے چَردی پِھردی رَہوے، تے اِیکوں تُساں کوئی تکلیف نہ پُچاہے، نہ تاں تُہاکوں اَللہ دا دَرد ناک عذاب آن پکڑیسی (٧٣)۔
