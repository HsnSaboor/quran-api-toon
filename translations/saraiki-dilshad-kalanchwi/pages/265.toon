quran[19{c,v,t}:
15,52,ڄَݙاں جو او اِبراہیم دے کولھ آئے، انھاں آکھیا، شالا سَلامتی رَہوی ! اُوں آکھیا، پَر میکوں تاں تُساں کنُوں ݙر پِیا لڳدے (٥٢)۔
15,53,انھاں آکھیا ݙر نہ پِیا، بیشک اَساں تیکوں ہِک اِہجے پُتر دِی خوشخبری ݙیندوں جِہڑا وَݙا دانا ہوسی (٥٣)۔
15,54,اُوں آکھیا، تُساں ہُݨ میکوں خوشخبری سݨاوَݨ آئے وے، ڄَݙاں جو میکوں ٻُڈھیپا وَلھیٹ ڳئے، ٻَس ہُݨ کہیں خوشخبری ݙیندو (٥٤)۔
15,55,انھاں آکھیا، اَساں تیکوں واقعی سَچّی خوشخبری سُݨیندے پَے ہَیں تُوں بے آس لوکاں وِچُوں نہ پِیا تِھی (٥٥)۔
15,56,اُوں اکھیا بَھلا کِہڑا شخص آپݨیں رَبّ دِی رحمت کنُوں بے آس تِھیندے، اَلبتہ گُمراہ لوکاں دِی ڳالھ ٻَئی ہے (٥٦)۔
15,57,اُوں پُچھیا جو اَللہ دے بھیڄے ہوئے فرشتو ! تُساں کِتھ کِیتے بھیڄے ڳئے وے؟ (٥٧)۔
15,58,اُنھاں ݙَسیا جو اَساکوں گُنہگاراں دِی قوم دو بھیڄا ڳئے (٥٨)۔
15,59,سِوائے لُوط دے لوکاں دے، بیشک اَساں انھاں ساریاں کُوں بَچا گِھنسُوں (٥٩)۔
15,60,پَر سِوائے اُوندی ذال دے کیوں جو اَساں اُوندا مُقدر اِیہو جیہا بݨائے جو او پِچُّھوں رہ وَن٘ڄݨ والیاں نال رَل ویسی (٦٠)۔
15,61,وَل جِہڑے ویلے (اَللہ دے) بھیڄے ہوئے فرشتے لُوط دے بندیاں کولھ ڳئے (٦١)۔
15,62,تاں اُوں اکھیا، سَچّی ڳالھ ہے تُساں اُوپرے لوک لڳدے وے (٦٢)۔
15,63,اُنھاں آکھیا، اَساں اِتھاں اُوں حقیقت کُوں گِھن تےآئے ہَیں، جیندے وِچ شَک کریندے ہِن (٦٣)۔
15,64,کیوں جو اَساں تیݙے کولھ بالکل سَچ مُچ تِھی وَن٘ڄݨ والی شَئے گِھن آئے ہَیں اِیندے وِچ کوئی شَک نہ کر، اَساں بالکل سَچ پَے اَکھیندے ہَیں (٦٤)۔
15,65,رات ڈھلّݨ دے بعد تُوں آپݨیاں کُوں گِھن تے نِکل وَن٘ڄ، اَتے خود اُنھاں کُوں پِچُّھوں ہَکلی وَن٘ڄ، اَتے تُہاݙے وِچُوں کوئی وِی (کھڑ تے) پِچُّھوں دو نہ ݙیکھے بلکہ اُتھوں وَڳئے چَلاہے جِݙے دا تُہاکوں حُکم ݙِتا ڳئے (٦٥)۔
15,66,اَتے اَساں اُوکُوں اِیہ فیصلہ سُݨا ݙِتا، جو بیشک سَویر تِھیوݨ نال اِنھاں دِی ڄَڑھ پَٹ چھوڑی ویسی (٦٦)۔
15,67,(اِتنی دیر وِچ) شہر دے لوک (پاڳلاں وان٘گیں، بدنیّتی دِیاں) خوشیاں مَنیندے سئیں آ تھئے (٦٧)۔
15,68,لُوط آکھیا، بیشک اِیہ میݙے مہمان ہِن ٻَس تُساں میکوں (انھاں اَڳوں) ذلیل نہ کرو (٦٨)۔
15,69,اَتے اَللہ کنُوں ݙرو، اَتے میکوں انھاں کنُوں شرمسار وی نہ کرو (٦٩)۔
15,70,انھاں آکھیا، کیا اَساں تیکوں سارے جہان دے لوکاں دِی طرفداری کرݨ کنُوں مَنع نہ کِیتا ہوئیا ہَا (٧٠)۔
