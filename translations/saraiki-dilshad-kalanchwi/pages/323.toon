quran[14{c,v,t}:
21,11,اَتے اَساں کِتنیاں وَستیاں کُوں پِیھ تے رَکّھ ݙِتا، جِہڑیاں جو ظالم ہَن، تے اِیندے بعد کہیں ٻَئی قَوم کُوں پَیدا کر کَھڑایا(١١)۔
21,12,ٻَس ڄَݙاں اُنھاں اَساݙے عَذاب کُوں آن٘دا محسوس کِیتا، تاں اِیں کنُوں بھڄݨ لڳ پَے؟(١٢)۔
21,13,بھڄّو نَہ پَے، ٻَس وَل آؤُو، اُوں عَیش آرام دو جِہڑا تُہاکُوں حاصِل ہے، تے آپݨیاں گَھراں دو، تاں جو تُساں کنُوں کوئی پُچّھ پرتیت کِیتی وَن٘ڄے(١٣)۔
21,14,او آکھݨ لڳیے، ہائے شامت اَساݙی! بیشک اَساں تاں ظالم اِی ہَاسے(١٤)۔
21,15,ٻَس اِیں طرح او اَکھیندے سَݙیندے رِیہے، اِیہ توڑِیں جو اَساں اُنھاں کُوں کَپّی ٹُکّی رَڑھ (فصل) وانگُوں تے وِسمدی ہوئی سُواء وانگُوں کر چھوڑیا(١٥)۔
21,16,اَتے اَساں اَسمان تے زمین کُوں اَتے جو کُجھ اُنھاں دے اَدّھ وِچ ہے، اِیویں خُواہ مَخواہ نھیں پَیدا کِیتا(١٦)۔
21,17,جیکر اَساں چَہندے جو مشغلے دِی کوئی شَئے بݨاؤں تاں ضرور اَساں اُوکُوں اَپݨِیں طرفُوں کہیں شَئے کنُوں بݨا گِھندے جیکر اَساکُوں کُجھ کرݨاں ہوندے تاں اَساں کر ڄاݨدے ہَیں(١٧)۔
21,18,بلکہ اَساں حَقّی ڳالھ کُوں کُوڑ دے اُتّے اِیویں بھُکا مَریندے ہَیں، جو ٻَس اُوندا بھیڄا کَڈھ سَٹیندے ہَیں، ٻَس او اُوں ہیں ویلے خَتم تِھی تے رَہ ویندے، اَتے تُہاݙی شامت ہے وِی اُنھاں ڳالھُوں جِہڑیاں تُساں گَھڑ گِھندے ہِیوے(١٨)۔
21,19,اَتے اُوں ہِیں دا ہے جو کُجھ اَسماناں وِچ ہے تے زمین دے تَلّے اُتّے ہے اَتے جِہڑے (فرشتے) اُوندے کولھ رَہندِن، نہ تاں او اُوندی عِبادت کر تے مَغریج ویندِن تے نہ او تَھکدے ہِن(١٩)۔
21,20,رات ݙین٘ہ اُوندی تَسبیح پَڑھدے رَہندِن تے سَہی وِی نھیں کَڈھیندے(٢٠)۔
21,21,کیا اُنھاں زمین اُتّے اِہجے ٻَے معبود بݨا گِھدِّن جِہڑے (موئے ہوئیاں کُوں) جِیوا کَھڑیسِن(٢١)۔
21,22,جیکر اَسمان تے زمین اَندر اَللہ دے علاوہ کوئی ٻَئے معبود وِی ہوندے تاں (سارے اِنتظام وِچ) خَلل (فَساد) پَے ویندا، ٻَس اَللہ جِہڑا عَرش دَا رَبّ ہے اُنھاں ڳالھِیں کنُوں پاک ہے جِہڑیاں اِیہ گَھڑیندے وَدّے ہِن(٢٢)۔
21,23,او جِہڑا کَمّ کریندے اُوندی کوئی پُچّھ ڳُچّھ نھیں ہُوندی، پَر ٻِنھاں کنُوں ضرور پُچّھ کِیتی ویندی ہے(٢٣)۔
21,24,کیا لوکاں اُوکُوں چھوڑ تے کوئی ٻئے معبود بݨَا گِھدّن (اَے رسول) آکھ ݙے جو تُساں کوئی تاں پَکّی دلیل گِھن آؤُو، اِیہا نصیحت (کِتاب) میݙے تے میݙے نال والیاں کِیتے وِی ہے، اَتے مَیں تُوں پہلے گُزر وَن٘ڄݨ والیاں کولھ وِی آئی ہَئی، پَر اُنھاں دے ڈھیر لوک اِیں حقیقت کُوں نھیں ڄاݨدے ٻَس اِیں کنُوں مُن٘ہ پھیری وَدّے ہِن(٢٤)۔
