quran[3]{c,v,t}:
  25,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  25,1,ٻَہُوں بَرکتاں والا ہے، او جَیں اَپݨیں بَندے اُتّے (سَچّ کُوڑ نِکھیڑݨ والا) قرآن نازِل کِیتے، تاں جو او سارے جہاناں والیاں کِیتے ݙَراوَݨ والا تِھی سَڳے(١)۔
  25,2,او تاں او ہے جیندے کِیتے بادشاہی ہے اَسماناں دِی تے زمین دِی اَتے اُوں کہیں کُوں آپݨیں اَولاد نھیں بݨایا، اَتے نَہ کوئی بادشاہی وِچ اُوندا شَریک ہے تے اُوں ہَر شَئے کُوں پَیدا کِیتے، وَل اُوندا ہِک مُناسِب اَندازہ مُقرر کِیتا ہِس(٢)۔
  25,3,وَت وِی لوکاں اُوکُوں چھوڑ تے ٻَئے معبود بݨا گِھدِّن، جِہڑے کوئی وِی شَئے پَیدا نھیں کر سَڳدے، بلکہ او خُود پَیدا کِیتے ہوئے ہِن، جِہڑے خُود اَپݨیں کِیتے کہیں نقصان تے یا نفعے تے کوئی اِختیار نھیں رَکھیندے، اَتے نَہ موت اُتے تے نَہ حیاتی اُتے تے نَہ مُردیاں کُوں وَلا اُٹَھا کَھڑاوَݨ اُتے اُنھاں کُوں کوئی اِختیار حاصل ہے(٣)۔
  25,4,اَتے جِنھاں لوکاں کُفر اِختیار کِیتے او اَہدِن اِیہ تاں محض اِیندیاں گَھڑیاں ڳالھِیں ہِن، اَتے ٻِنھاں لوکاں وِی اِیندی مَدد کِیتی ہے، سَچّ تاں اِیہ ہے جو اِیہ ظُلم تے کُوڑ اُتّے تُل ڳئے ہِن(٤)۔
  25,5,اَتے اِیہ وِی اَہدِن، جو اِیہ تاں پَہلے لوکاں دِیاں کَہاݨِیاں ہِن، جِنھاں کُوں اُوں لِکّھ چھوڑیے، ٻَس اِیہ صبح شام وَلا وَلا سُݨائیاں ویندِن(٥)۔
  25,6,(اَے رسول) آکھ ݙے، جو اِیں (قرآن) کُوں تاں اُوں نازِل کِیتے جِہڑا اَسماناں دے تے زمین دے بھیداں کُوں خُوب ڄاݨدے، بیشک او بَخشَݨ ہار تے ہمیشہ رحمت کرݨ والا ہے(٦)۔
  25,7,اَتے اِیہ لوک اَہدِن جو اِیہ رسول کہجیا ہے جو روٹی ٹِکّی کَھاندے، اَتے بازاراں وِچ ٹُردا پِھردا رَہندے، بَھلا اِیں دُو فرشتہ کِیُوں نھیں بھیڄیا ڳیا، تاں جو اِیندے نال رَل تے لوکاں کُوں ݙَریندا سَمجھیندا(٧)۔
  25,8,یا اِیں دو کوئی خَزانہ سَٹ ݙِتّا ویندا، یا اِیندے کِیتے کوئی باغ ہوندا جِیندے پَھل (اِیہ مَزّے نال) کَھاندا اَتے ظالم لوک اَہدِن، جو تُساں تاں محض ہِک اِہجے آدمی دی پَیروی کریندے پَیْوے، جِیندے اُتّے جادُو کر ݙِتا ڳئے(٨)۔
  25,9,تُوں ݙیکھ گِھنّ، جو اِیہ لوک تیݙے متعلّق کہجیاں کہجیاں مِثالاں ݙیندے وَدّے ہِن، اِیہ تاں گُمراہ تِھی ڳئِن، اَتے سِدَّھا رَاہ وِی نَہ لَبھ سَڳسِن(٩)۔
  25,10,ٻَہُوں برکتاں والا ہے جِہڑا جیکر چاہے تاں تیݙے کِیتے اِیں کنُوں وِی چَن٘ڳے باغ بݨا ݙیوے، جِنھاں تَلّے نہراں وَہندیاں وَڳدِیاں پِیاں ہووݨ، اَتے تیݙے کِیتے محل بݨا ݙیوے(١٠)۔
  25,11,بلکہ اِیہ لوک تاں قیامت دِی گَھڑی کُوں وِی کُوڑ اَکھیندِن، پَر جِہڑا کوئی قیامت دِی گَھڑی کُوں کُوڑا اَکھیندے، اَساں اُوندے کِیتے دَوزخ دِی تِکّھی بھا تیار کر رَکّھی ہے(١١)۔
  25,12,ڄَݙاں اُوں (بھا) اُنھاں کُوں پَرے کنُوں ݙِٹَّھا، تاں وَت اِیہ اُوندی کاوِڑ دے شُکارے تے شُوں شَاں دِیاں اَوازاں سُݨ گِھنسِن(١٢)۔
  25,13,اَتے ڄَݙاں ہَتّھ پَیر ٻَدھ تے اُنھاں کُوں (دَوزخ دِی) کہیں سوڑی جاء سَٹ ݙِتّا ویسے تاں اُوں ڄَاء او آپݨیں مَوت کُوں سَݙ مریسِن(١٣)۔
  25,14,(آکھیا ویسی)، اَڄ دے ݙین٘ہ تاں ہِک مَوت کُوں سَݙیندو کَٹّھیاں ڈھیر ساریاں مَوتاں کُوں پَے سَݙُو(١٤)۔
  25,15,(اَے رسول) آکھ ݙے، کیا اِیہ اَنجام زیادہ چَن٘ڳا ہے یا ہمیش رَہݨ واسطے جَنّت چَن٘ڳی ہے، جِیندا وَعدہ پَرہیزگار لوکاں نال کِیتا ہوئے، اِیہ اُنھاں (دے عَملاں) دِی جَزا وِی ہے تے آخری ٹِکاݨاں وِی(١٥)۔
  25,16,اُنھاں کِیتے اِیندے وِچ او سَب کُجھ موجود ہے جِہڑا کُجھ اِیندے وِچ رَہݨ والے چَہسِن، اِیہ تیݙے رَبّ دَا ہِک وَعدہ ہے، جِیندے پُورا کرݨ دِی ذِمّے واری خُود اُوندے اُتّے ہے(١٦)۔
  25,17,اَتے ہِک ݙین٘ہ او وِی ہوسی ڄَݙاں اُنھاں کُوں کَٹَّھا کریسے، اَتے اُنھاں (معبوداں) کُوں وِی، جِنھاں دِی او اَللہ کُوں چھوڑ تے بَندگی کریندے پَئیِن، ٻَس (اَللہ) اَکھیسے جو کیا تُساں میݙے اُنھاں بَندیاں کُوں گُمراہ کِیتا ہَا، یا اِیہ لوک خُود سِدّھے رَاہ کنُوں تِھڑک ڳئے ہَن(١٧)۔
  25,18,او اَکھیسِن، تیݙی ذات پاک ہے اَساکُوں تاں اِیہ مَجال نَہ ہَئی، جو اَساں تَیں کنُوں سِوا کہیں ٻَے کُوں آپݨاں کارساز بݨاؤں ہَا، اَلبتہ تَیں انھاں کُوں اَتے انھاں دے پِیؤ ݙاݙیاں کُوں ٻَہُوں کُجھ مَال مَتال ݙِتَّا ہَا، اِیہ توڑِیں جو اِیہ تیکُوں یاد کرَݨ وِی بھُل ڳئے، اَتے اِیہ برباد تِھی وَن٘ڄݨ والی قَوم بَݨ ڳئے(١٨)۔
  25,19,ٻَس یقیناً تُہاݙے اُنھاں معبوداں تُہاکُوں اِیندے وِچ کُوڑا کر ݙِتّے، جِہڑا کُجھ تُساں اَکھیندے پَے ہِیوے، ٻَس نَہ تاں تُہاکُوں عَذاب کنُوں ہَٹا سَڳݨ دِی مَجال ہے، اَتے نَہ کوئی مَدد حاصل کر سڳسُو! اَتے تُہاݙے وِچُّوں جِہڑا کوئی وِی ظُلم کرے، تاں اَساں اُوکُوں سَخت عَذاب دَا مَزّہ چَکھیسُوں(١٩)۔
  25,20,اَتے (اَے رسول) اَساں تَیں کنُوں پہلے وِی جِتّی رسُول بھیڄے ہِن، بیشک او روٹی ٹِکّی وِی کھاندے ہِن، اَتے بازاراں وِچ ٹُردے پِھردے وِی ہَن، اَتے اَساں تُہاݙے وِچُوں بعضیاں کُوں بعضیاں کِیتے اَزمائِش دَا سَبب بݨا ݙِتے، کیا تُساں (نتیجے کِیتے) صَبر کریندو، اَتے تیݙا رَبّ سَب کُجھ ݙیکھݨ والا ہے(٢٠)۔
  25,21,اَتے جِہڑے اَساݙے اَڳُوں پیش تِھیوݨ دَا ݙَر اِی نَھیں رَکھیندے اُنھاں آکھئے، جو اَساݙے اُتّے فرشتے کِیُوں نھیں نازِل کِیتے ویندے یا اَساں اَپݨیں رَبّ کُوں کِیُوں نھیں ݙیکھ گِھندے تحقیق اِیہ اَپݨیں دِل وِچ وَݙائی کریندِن، اَتے سَرکشی کِیتی ہِینے، تے او وِی ٻَہُوں ساری(٢١)۔
  25,22,جِہڑے ݙِین٘ہ او فرشتیاں کُوں خُود ݙیکھ گِھنسِن، تاں اُوں ݙِین٘ہ اُنھاں کِیتے کوئی خُوشخبری نَہ ہوسی اَتے اَکھیسِن جو کوئی اوٹ ہُووے ہَا اَساکُوں پَرے رَکھݨ کِیتے(٢٢)۔
  25,23,اَتے جو کُجھ عَمل اُنھاں کِیتے ہوسِن، اَساݙے اَڳُوں آسِن، تاں ٻَس اُنھاں کُوں دُھدِّھڑ وَانگُوں کِھن٘ڈا پُھن٘ڈا ݙیسُوں(٢٣)۔
  25,24,اُوں ݙِین٘ہ جَنّت والے لوک ݙَاڈھی چَن٘ڳی جاء تے اَتے وَݙے آرام وِچ ہوسِن(٢٤)۔
  25,25,اَتے جِہڑے ݙِین٘ہ اَسمان جھڑّاں نال پَھڑیج ویسی، تاں فَرشتے نازِل کِیتے ویسِن، قطاراں لَا لَا تے(٢٥)۔
  25,26,اُوں ݙِین٘ہ صَداقت تے حقیقت والی بادشاہی ٻَہُوں مہربان رَبّ دِی ہوسے، اَتے او ݙِین٘ہ کافراں کِیتے ݙَاڈھا اَوکھا ہوسے(٢٦)۔
  25,27,اَتے اُوں ݙِین٘ہ ظالم شَخص اَپݨیں ہَتّھ پَٹیسی، چِتّھیسی، اَتے اَکھیسی وَݙا اَرمان ہے اِیویں ہوندا جو مَیں وِی رسول دے نال دَا، رَاہ اِختیار کِیتا ہوندا(٢٧)۔
  25,28,ہائے میݙی کَم بَختی، جو فلاݨیں کُوں آپݨاں یار نَہ بݨیندا(٢٨)۔
  25,29,پیغام (قرآن) دے میݙے کولھ پُڄ وَںڄݨ دے بعد اِیں (یار) میکُوں گُمراہ کر چھوڑیے، اَتے شیطان تاں اِنسان کُوں دَغا ݙیوݨ والا ہے(٢٩)۔
  25,30,اَتے رسول اَکھیسے، میݙے رَبّ آ، بیشک میݙی قَوم اِہجے قرآن کُوں ٻَس اِیویں ہِی سَمجھ رَکھیا ہَا(٣٠)۔
  25,31,اَتے اِیں طرح اَساں ہَر نبی کِیتے گُنہڳاراں وِچُوں دُشمن بݨائے، اَتے (اَے رسول) تیݙا رَبّ تیکُوں ہِدایت ݙیوݨ تے تیݙی مَدد کرݨ کِیتے کافی ہے(٣١)۔
  25,32,اَتے جِنھاں لوکاں کُفر اِختیار کِیتا ہوئے اَکھیندِن جو اِیندے اُتے قرآن کَٹَّھا ہِکّے واری کِیُوں نازِل نھیں کِیتا، اِیہ تاں اِیں ڳالھُوں ہے تاں جو اَساں اِیندے ذریعے تیݙے دِل کُوں تَکڑا کِیتی رَکّھوں، اَتے اَساں اِیکُوں رُک رُک تے لَہیندے پَڑھیندے رِیہے ہِیسے، تے اِیویں لَہاوݨاں وِی چَاہِیدا ہے(٣٢)۔
  25,33,اَتے (ڄَݙاں کَݙائِیں) اِیہ تیݙے کولھ کوئی مِثال (مسئلہ) گِھن آے، تاں اَساں وِی تیݙے کولھ حَقّ والا جَواب بھیڄ چھوڑے، تے اُوکُوں واضح طور تے بیان کر ݙِتّے(٣٣)۔
  25,34,جِہڑے لوک آپݨیں مُن٘ہ دے بھار دَوزخ دو کَٹّھے کِیتے ویسِن، اُنھاں دا ٹِکاݨاں وِی ٻَہُوں بھیڑا ہے تے سِدّھے رَاہ کنُوں وِی ٻَہُوں تھڑکیئے ہوئِن(٣٤)۔
  25,35,اَتے تحقیق اَساں مُوسیٰ کُوں کِتاب ݙِتّی، تے اُوندے بِھرا ہَارون کُوں اُوندا مَددگار بݨا تے اُوندے نال کر چھوڑیا(٣٥)۔
  25,36,ٻَس اَساں آکھیا، جو تُساں ݙُوہائیں اُوں قَوم کولھ وَن٘ڄو، جَئیں اَساݙِیاں آیاتاں (نِشانیاں) کُوں کُوڑا آکھیئے، ٻَس اَساں اُنھاں کُوں غَارت کر چھوڑیا، جیں طرح غارت کرݨاں چَاہِیدا ہَا(٣٦)۔
  25,37,اَتے نُوح دِی قَوم ڄَݙاں رسولاں کُوں کُوڑا آکھیا تاں اَساں اُنھاں کُوں غرق کر ݙِتّا، اَتے اَساں لوکاں کِیتے اُنھاں کُوں ہِک (عِبرت دِی) نِشانی چَا بݨایا، اَتے اَساں ظالم لوکاں کِیتے ہِک دَرد ناک عَذاب تیار کِیتا ہوئے(٣٧)۔
  25,38,اَتے عاد، تے ثمود تے رَسّ (اندّھے کُھوہ) والے لوکاں کُوں تے اُنھاں دے وِچالے دِیاں صَدیاں والیاں ٻَہُوں قَوماں کُوں (وِی تَباہ کِیتا ڳیا(٣٨)۔
  25,39,اَتے ہَر ہِک کُوں اَساں مِثالاں ݙے تے سَمجھایا (نَہ مَنیئے تاں) ہَر کہیں کُوں اِیں طرح بَرباد کِیتا جِیویں برباد کرݨاں چَاہِیدا ہَا(٣٩)۔
  25,40,اَتے تحقیق اِیہ لوک اُوں وَستّی کنُوں وِی لَنگھئن جِیندے اُتّے بَد ترین قِسم دا مِین٘ہ وَسایا ڳیا، کیا اِیہ اُوکُوں ݙیکھدے نَہ ہوسِن، بلکہ اِیہ تاں مَرݨ دے بعد وَلا اُٹّھی کَھڑݨ دِی توقع وِی نھیں رَکھیندے(٤٠)۔
  25,41,اَتے ڄَݙاں تیکُوں ݙیکھدے ہِن، ٻَس تیݙے اُتّے مَذاقاں کریندِن، جو کیا اِیہُو او جُوان ہے جِیکُوں اَللہ رسول بݨا بھیڄے(٤١)۔
  25,42,اِیہ تاں اَجھّو اَساکُوں اَساݙے معبوداں کنُوں وِی ہَٹَا گِھنّے ہَا، جیکر اَساں اُنھاں (دِی بَندگی) اُتّے قابو نَہ تَھئے رَہندے، اَتے جیں ویلے عَذاب کُوں ݙیکھسِن، تاں جَلدی پَتہ لڳ ویسنیں جو کَوݨ سِدّھے رَاہ کنُوں ٻَہُوں تُھڑکیا ہُوئیا ہَا(٤٢)۔
  25,43,کیا تَیں (اَے رسول) اُوں شَخص کُوں وِی ݙِٹّھے، جیں نفسانی خُواہِش کُوں آپݨاں معبود بݨایا ہوئے، کیا تُوں اُوندا ذِمّے وار بَݨ سَڳدیں(٤٣)۔
  25,44,کیا تُوں اِیہ خیال کریندیں جو بیشک اُنھاں وِچُّوں ڈھیر لوک سُݨدے یا سَمجھدے ہِن، اِیہ تاں ٻَس جانوراں وانگُوں ہِن، بلکہ سِدّھے رَاہ تُوں اُنھاں کنُوں وِی ڈھیر تُھڑکیئے ہوئے ہِن(٤٤)۔
  25,45,کیا تَیں آپݨیں رَبّ دو نھیں ݙِٹَّھا، جو کِیں طرح پِچھاویں کُوں لَمبا کر ݙیندے، جیکر او چَہندا تَاں اُوکُوں ہِکّی جاء کَھڑا کِیتی رَکھیندا وَل اَساں سِجّھ کُوں اِیندے کِیتے ہِکّ دلیل (ٹورݨ والا) بݨائے(٤٥)۔
  25,46,وَل اَساں اِیکُوں آپ دو وَلھیٹ گِھندے ہَیں، ہولے ہولے کر تے(٤٦)۔
  25,47,اَتے او تاں اُوہو ہے جیں تُہاݙے کِیتے رَات کُوں ہِک پَردہ بݨائے، اَتے نِندر کُوں آرام، اَتے ݙِین٘ہ کُوں (نِندر کنُوں) اُٹّھی کَھڑے تِھیوݨ دَا وَقت بݨائے(٤٧)۔
  25,48,اَتے اُوہو تاں ہے جِہڑا ہَوائیں کُوں خُوشخبری بݨا تے اَپݨِیں رحمت کنُوں پہلے بھیڄ ݙیندے، اَتے اَسمان کنُوں صاف سُتھرا (کرݨ والا) پاݨِیں نازِل کریندے(٤٨)۔
  25,49,ٻَس اِیندے نال موئی ہوئی وَستی کُوں جِیوا ݙیندُوں، تے اَساں اَپݨیں پَیدا کِیتے ہوئے ڈھیر سارے جانوراں تے اِنساناں کُوں پِلیندے وِی ہَیں(٤٩)۔
  25,50,اَتے تحقیق اَساں (اِیں کرشمے کُوں) وَل وَل بیان کریندُوں، تاں جو اَساݙا ذِکر کِیتی رَکّھن، تے سَبق گِھنَّن، وَت وِی اَکثر لوکاں اِنکار کرݨ کنُوں سِوا ٻِیا کُجھ مَنیّا وِی نھیں(٥٠)۔
  25,51,اَتے جیکر اَساں چَہندے تاں ہَر ہِک وَستی وِچ ݙَراوَݨ والا (چِتاوَݨ والا) اُٹھا کھڑیندے(٥١)۔
  25,52,ٻَس کافراں دَا آکھیا نَہ مَنّ، اَتے اُنھاں نال (اِیں قرآن دے) زور تے جہاد کر، جہاد وِی وَݙا زور دَا(٥٢)۔
  25,53,اَتے اُوہو تاں ہے جیں ݙُوں سمندراں کُوں مِلا ݙِتّے، ہِک مِٹّھے پاݨِیں دا تریْہ لَہاوَݨ والا، تے ہِک کَھارے پاݨِیں دَا سِینہ سَاڑَݨ والا اَتے اُنھاں دے اَدّھ وِچ ہِک آڑ (رُکاوَٹ) ہے، اَتے ہِک قِسم دا بَندھ ٻَدھیا ہوئے(٥٣)۔
  25,54,اَتے (اَللہ) اُوہو تاں ہے جیں پاݨِیں وِچُوں بَشر کُوں پَیدا کِیتے، تے اُوندے جَدّی پُشتی سَکّے تے ساہورے وِی بݨائِن، اَتے تیݙا رَبّ تاں ہَر طرح دِی قُدرت رَکھݨ والا ہے(٥٤)۔
  25,55,اَتے (کافر) اَللہ کُوں چھوڑ تے اُوندی بَندگی کریندِن، جِہڑا نَہ اُنھاں کُوں کوئی نَفع پُچا سَڳدے، اَتے نَہ اُنھاں کُوں کوئی نُقصان ݙے سَڳدے، ٻِیا اِیہ جو کافر اَپݨیں رَبّ (دے مخالف دی) مَدد وِچ لَڳیا ہُوئے(٥٥)۔
  25,56,اَتے (اَے رسول) اَساں تیکُوں خُوشخبری سُݨاوَݨ والا تے عَذاب کنُوں ݙَراوَݨ والا بَݨا تے بھیڄے(٥٦)۔
  25,57,آکھ ݙے، جو مَیں تُساں کنُوں (اِیں کَم دا) کُوئی اَجر نھیں مَنگدا، سِوائے اِیندے جو جِیندا دِلّ چَہوے ٻَس او اَپݨیں رَبّ دو پُچاوَݨ والے دَڳ کُوں پَکڑ گِھنّے(٥٧)۔
  25,58,اَتے اُوں ہمیشہ زِندہ رَہݨ والے اُتّے توکّل رَکّھ، جیں اَصلُوں کَݙاہِیں نھیں مَرݨاں، اَتے اُوندی تعریف دے نال اُوندا پاک ہُووَݨ بیان کِیتی رَکّھ، اَتے اَپݨیں بندیاں دے گُناہاں دا پُورا پَتہ رَکھݨ کِیتے ٻَس او خُود کافی ہے(٥٨)۔
  25,59,جیں اَسماناں تے زمین اَتے جو کُجھ اِنھاں دے وِچالے ہے ساریاں کُوں چِھی ݙِین٘ہاں وِچ تیّار کر کھڑائے، وَل عَرش اُتے تکڑی حکومت وَن٘ڄ سَنبھالی جِہڑا ٻَہُوں مہربان ہے، ٻَس اُوندی شان کہیں ڄاݨݨ والے کنُوں پُچّھ ݙیکھ(٥٩)۔
  25,60,اَتے ڄَݙاں اُنھاں کُوں آکھیا ویندے جو آپݨیں ٻَہُوں مہربان اَللہ کُوں سَجدہ کرو، تاں (کافر) اَکھیندِن کیا اَساں اُوکُوں سَجدہ کروں جِیندے ناں تُوں اَساکُوں آکھیں، ٻَس اِیہ ڳالھ اُنھاں کُوں اَللہ کنُوں ٻِیا وِی پَرے بھڄیندی ہے(٦٠)۔
  25,61,ٻَہُوں بَرکتاں والا ہے، او جیں اَسماناں وِچ بُرج بݨائِن، تے اُنھاں وِچ ݙِیوا (سِجھ) رَکھیئے، اَتے چمَکݨاں چَندر وِی(٦١)۔
  25,62,اَتے (اَللہ) تاں اُوہو ہے جیں اُوں بَندے کِیتے رَات تے ݙِین٘ہ کُوں ہِک ٻئے دے پِچُّھوں آوَݨ وَن٘ڄݨ والا بݨائے، جِہڑا اُنھاں کنُوں سَبق (نصیحت) گِھنَّݨ چَاہے یا جِہڑا اُوندی شُکر گُزاری کرݨ چاہے(٦٢)۔
  25,63,اَتے ٻَہُوں مہربان اَللہ دے (اَصل) بَندے او ہِن، جِہڑے زمین اُتے تَھرام نال ٹُردِن، اَتے ڄَݙاں جاہل (بدتمیز) لوک اُنھاں کُوں بُرا بَھلا اَکھیندِن تاں اُنھاں کُوں سَلام آکھ تے ٹُر ویندِن(٦٣)۔
  25,64,اَتے اِیہے لوک اَپݨیں رَبّ دے اَڳُوں سَجدے کر کر تے، اَتے کَھڑے تِھی تے رات گُزریندِن(٦٤)۔
  25,65,اَتے اِیہے لوک دُعا مَنگدے رَہندِن، جو اَساݙے رَبّ آ! اَساں کنُوں دَوزخ دے عَذاب کُوں پَرے رَکّھیں، اِیندا عَذاب تاں ٻَس جان کُوں لَڳ تے رَہ وَن٘ڄݨ والا ہے(٦٥)۔
  25,66,بیشک اِیہ تھوڑی دیر کِیتے یا اَصلُوں رَہݨ کِیتے ٻَہُوں گَندی جاء ہے(٦٦)۔
  25,67,اَتے اِیہے لوک ڄَݙاں خَرچ کرݨ لڳدِن، تاں نَہ او فَضول خَرچی کریندِن، اَتے نَہ بُخل! بلکہ او دَرمیانے حِساب نال خَرچ کریندِن(٦٧)۔
  25,68,اَتے اِیہے لوک اَللہ دے نال ٻئے معبود کُوں نھیں سَݙیندے، اَتے کہیں اِہجی جان کُوں، سِوائے حَق حَاصل ہُووَݨ دے، قَتل وِی نھیں کریندے، جِیکُوں اَللہ حَرام کر ݙِتَّا ہُووے، اَتے زَنا وِی نھیں کریندے اَتے جِہڑا وِی اِیویں کریسے او سَخت گُناہ کرَݨ والا تِھی ویسے(٦٨)۔
  25,69,قیامت دے ݙِین٘ہ اُوندے کِیتے ݙُوڑا عَذاب ہوسے، اَتے او اُوندے وِچ ہمیشہ کِیتے ذلیل و خُوار تِھی تے رَہسی(٦٩)۔
  25,70,پَر جِہڑے شَخص تَوبہ چَا کِیتی، اَتے اِیمان گِھن آیا، اَتے نیک کَمّ کِیتے ٻَس اُنھاں کِیتے اَللہ اُنھاں دے گُناہاں کُوں نیکیاں وِچ بَدلا ݙیسے، اَتے اَللہ تاں ٻَہُوں بخشݨ ہَار تے وَݙا مہربان ہے(٧٠)۔
  25,71,اَتے جِہڑا تَوبہ چَا کریندے، اَتے نیک کَمّ وِی کریندے، تاں او اَللہ دو رجوع وِی کریندے، جِیویں جو کرݨاں چاہِیدا ہے(٧١)۔
  25,72,اَتے اِیہے لوک کُوڑی گُواہی وِی نھیں ݙیندے، اَتے ڄَݙاں کہیں بیہُودہ شَئے نالوں لنگھدِن، تاں عِزّت والیاں بَندیاں وانگُوں لَنگھ ویندِن(٧٢)۔
  25,73,اَتے ڄَݙاں اُنھاں کُوں اُنھاں دے رَبّ دِیاں آیاتاں (سُݨا تے) نصیحت کِیتی ویندی ہے، تاں او اُنھاں اُتّے اَندھے ٻوڑے بَݨ تے نھیں رَہ ویندے(٧٣)۔
  25,74,اَتے جِہڑے لوک اَکھیندِن جو ساݙے رَبّ آ! اَساݙِیاں ذالیں تے آل اَولاد نال اَساݙیاں اَکّھیں ٹَھاری رَکّھ، اَتے اَساکُوں پَرہیزگار لوکاں دَا اِمام چَا بَݨا(٧٤)۔
  25,75,اِیہے او لوک ہِن، جِنھاں کُوں اَجر دے طور تے اُچّیاں ماڑیاں ݙِتّیاں ویسِن کِیُوں جو اُنھاں صَبر اِختیار کِیتا ہُوئیا ہَا، اَتے اُنھاں وِچ اُنھاں کُوں (ہَر پاسُوں) سَلام دُعا (جِی آیاں کُوں) آکھیا ویسی(٧٥)۔
  25,76,او اُنھاں وِچ ہمیشہ رَہسِن، اِیہ ٻَہُوں سوہݨِیں ٹِک تے رَہݨ دِی جاء وِی ہے، تے عارضی رَہݨ دِی جاء وِی(٧٦)۔
  25,77,(اَے رسول) آکھ ݙے جو میݙے رَبّ کُوں تُہاݙی پَرواہ کائے نھیں، جیکر تُساں اُوکُوں نَہ سَݙُو تاں وِی، کُوڑا آکھیئے تاں وِی، اَجھو تُہاݙا سَارا کُجھ کِیتا کرایا، تُہاݙِی ڳِچّی وِچ پُوسی(٧٧)۔
