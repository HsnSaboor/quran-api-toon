quran[3]{c,v,t}:
  44,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  44,1,حٰمٓ (١)۔
  44,2,قَسم ہے اِیں صاف بیان کر ݙیوَݨ والی کتاب دِی (٢)۔
  44,3,بیشک اَساں اِیکُوں ہِک بَرکتاں والی رَات وِچ نازِل کِیتے، بیشک اَساں (بُرے اَنجام کنُوں) ݙراوݨ چِتاوَݨ والے ہَیں (٣)۔
  44,4,اِیں رات وِچ ہَر معاملہ وݙی حکمت نال طَے کِیتا ویندے (٤)۔
  44,5,جِیندا حُکم اَساݙی طرفُوں تِھیندے، بیشک اَساں اِی (رسول) بھیڄݨ والے ہَیں (٥)۔
  44,6,اِیہ تیݙے رَبّ دِی طرفُوں رحمت دے طور تے ہِن، بیشک او چَن٘ڳی طرح سُݨݨ والا سَب کُجھ ڄاݨݨ والا ہے (٦)۔
  44,7,او اَسماناں دا مالک ہے، زمین دا وِی، تے جو کُجھ اُنھاں دے اَدّھ وِچ ہے، اُوندا وِی! شَرط اِیہ ہے جو تُساں واقعی یقین کرݨ والے ہووُو! (٧)۔
  44,8,کوئی ٻِیا معبود کائے نھیں سِوائے اُوندے، او تاں جِیویندا وِی ہے تے مار وِی چھوڑیندے، اُوہُو تُہاݙا وِی رَبّ ہے تُہاݙے پہلے والے پِیو ݙاݙیاں دا وِی رَبّ ہے (٨)۔
  44,9,بیشک او شَک وِچ کُݙاکڑیاں (ٹَپولیاں) وَدّے مریندِن (٩)۔
  44,10,اَچھا اُوں ݙین٘ہ دا اِنتظار کرو، ڄَݙاں جو اَسمان کنُوں ظاہر ظہور دُھوں مَچ آسی(١٠)۔
  44,11,جِہڑا لوکاں کُوں وَلھیٹ گِھنسِی، ٻَس اِیہ ہِک دَرد ناک عذاب ہے (١١)۔
  44,12,(اَکھیسِن) اَساݙے رَبّ آ ! تُوں اَساں کنُوں اِیں عذاب کُوں ہَٹا گِھن یقینی طور تے اَساں اِیمان گِھن آوَݨ والے ہَیں (١٢)۔
  44,13,پَر اُنھاں کُوں نصیحت کِتُّھوں فائدہ ݙیوݨ لڳی ہے حالانکہ اُنھاں کولھ صاف صاف بیان کرݨ والا پیغمبر وِی آچُکیئے (١٣)۔
  44,14,وَل اُوں کنُوں وِی پِھر ڳئے اَتے آکھݨ لڳئیے، جو اِیہ تاں سِکھیا پڑھیا ہویا کوئی پاڳل ہے (١٤)۔
  44,15,تحقیق اَساں تھوڑا جیہا عذاب ہَٹا ݙیوُوں، تاں وِی تُساں وَل پہلی حالت تے آویسُو (١٥)۔
  44,16,جِہڑے ݙین٘ہ ٻَہُوں وَݙی پَکڑ وِچ گِھن آسُوں، تاں اَساں تُساں کنُوں اَصلُوں اِنتقام گِھنّݨ والے بݨ ویسُوں (١٦)۔
  44,17,اَتے تحقیق اَساں انھاں کنُوں پہلے فِرعون دِی قوم کُوں آزما چُکئے ہَاسے، اُنھاں کولھ وَݙیاں عِزّتاں، کرامتاں والا رسول وِی آیا (١٧)۔
  44,18,(آکھیُس) جو اَللہ دے بندیاں کُوں میݙے حوالے کر ݙیوُو، بیشک مَیں تُہاݙے کِیتے وَݙا اَمانت دار رسول ہَاں (١٨)۔
  44,19,اَتے تُساں اَللہ دے مقابلے وِچ سِر نہ چَاؤ، بیشک مَیں تُہاکُوں ہِک کُھلّی دلیل پیش کرݨ لڳاں (١٩)۔
  44,20,اَتے مَیں آپݨیں رَبّ دِی ، تے تُہاݙے رَبّ دِی پَناہ مَنگی ہے، اِیں ڳالھ کنُوں جو تُساں میکُوں پَتھر مار مار تے مار نہ گَھتُّو (٢٠)۔
  44,21,اَتے جیکر تُساں میݙے اُتے اِیمان نھیں گِھن آندے تاں وَل میں کنُوں پَرے ہَٹ وَن٘ڄو (٢١)۔
  44,22,اخیر اُوں آپݨیں رَبّ کنُوں دُعا مَنگی جو (اَساکُوں بَچا) کیوں جو اِیہ ہِک مجرم لوکاں دِی قوم ہے (٢٢)۔
  44,23,(جواب ݙِتا ڳیا) ٻَس رات و رات میݙے بندے آپݨیں نال کر تے اِتُّھوں چَلیا وَن٘ڄ، اِیہ تُہاݙے پَکڑݨ کِیتے ضرور پِچُّھوں آسِن (٢٣)۔
  44,24,اَتے سُکّے سَمندر کُوں (اِیویں دا اِیویں) چھوڑی وَن٘ڄیں، یقیناً انھاں دا لشکر غرق تِھی تے رَہسی (٢٤)۔
  44,25,او کِتنا کُجھ چھوڑ تے مریے، باغ تے چَشمے! (٢٥)۔
  44,26,اَتے رَڑِھیں (فَصلاں) تے عِزّتاں والی جائیں (٢٦)۔
  44,27,اَتے نعمتاں جِنھاں وِچ او عَیش پَے کریندے ہَن (٢٧)۔
  44,28,اِیں طرح تِھیا (اُنھاں داَنجام) اَتے اَساں اُنھاں دا وارث ہِک ٻَئی قوم کُوں بݨا ݙِتا(٢٨)۔
  44,29,ٻَس انھاں اُتے نہ اَسمان تے زمین رُنّے، اَتے نہ اُنھاں کُوں کوئی مُہلت ݙِتی ڳئی (٢٩)۔
  44,30,اَتے تحقیق اَساں بنی اِسرائیل کُوں ٻَہُوں ذلیل قسم دے عذاب کنُوں بَچا گِھدّا (٣٠)۔
  44,31,فِرعون دے (عذاب کنُوں) بیشک او حَد کنُوں ٹَپ وَن٘ڄݨ والیاں وِچُوں اُچّے دَرجے دَا ہَا (٣١)۔
  44,32,اَتے تحقیق اَساں اُنھاں (بَنی اِسرائیل کُوں) سَب کُجھ ڄاݨ سَمجھ تے سارے جہاناں دے مقابلے وِچ چُݨ گِھدّا (٣٢)۔
  44,33,اَتے انھاں کُوں آپݨیاں نِشانیاں ݙیکھائیاں جِنھاں وِچ صاف صاف آزمائش ہَئی (٣٣)۔
  44,34,بِلا شُبہ اِیہ (جِہڑے ہِن) اِیہ تاں اِیہ اَکھیندِن (٣٤)۔
  44,35,جو ٻَس اَساݙی موت دے بعد ٻِیا کُجھ وِی کائے نھیں، اَتے اَساں وَلا کائے نہ جِیوائے ویسُوں (٣٥)۔
  44,36,جیکر تُساں سَچ آہدے وے تاں وَل گِھن آؤ جِیوا تے اَساݙے پِیو ݙاݙیاں کُوں (٣٦)۔
  44,37,کیا اِیہے لوک چَن٘ڳے ہِن، یا تُبِعّ دِی قوم، اَتے او لوک وِی جِہڑے جو انھاں کنُوں پہلے تِھی گُزرے ہِن، اَساں انھاں کُوں تَباہ کر چھوڑیا کیُوں جو او بِلا شُبہ گُنہگار لوک ہَن (٣٧)۔
  44,38,اَتے اَساں اَسماناں کُوں، تے زمین کُوں، تے جو کُجھ اُنھاں دے وِچکار ہے، اِیویں شُغل دے طور تے پَیدا نھیں کِیتا (٣٨)۔
  44,39,اَتے اَساں انھاں ݙوہائیں کُوں بَر حق (حکمت نال) بݨائے، پَر اُنھاں دے ڈھیر لوک حقیقت کُوں نِھیں ڄاݨدے (٣٩)۔
  44,40,یقینی طور تے فیصلے دا ݙین٘ہ اُنھاں ساریاں دے اُٹّھی کھڑݨ کِیتے مقرر تِھی چُکیئے (٤٠)۔
  44,41,اُوں ݙین٘ہ کوئی گھاٹا یار وِی، آپݨیں گھاٹے یار دے کہیں وِی کَمّ نہ آسَڳسِی، اَتے نہ اُنھاں دِی کِتھاؤں مَدد کِیتی ویسی (٤١)۔
  44,42,سِوائے اُوندے جِیندے اُتّے اَللہ رحم چَا کرے، بیشک او تاں ٻَہُوں زبردست بے حد رحمت کرݨ والا ہے (٤٢)۔
  44,43,یقیناً تھوہر دا وَݨ (٤٣)۔
  44,44,گُنہگار دِی غِذا ہوسے (٤٤)۔
  44,45,جِہڑی تیل دِی گدمیل ( ڳلے ہوئے ترامے) وَان٘گُوں اُوندے ݙِڈھ وِچ پَئی اُٻلسی (٤٥)۔
  44,46,جِیویں جو ٻَہُوں گَرم پاݨِیں ٻَڑکدے(٤٦)۔
  44,47,آکھیا ویسی، اِکُوں پَکڑ گِھنُّو، اَتے گِھیل تے دَوزخ دے اَدّھ وِچ گِھن وَن٘ڄو! (٤٧)۔
  44,48,اُوں دے سِر اُتے ٻَڑکدے پاݨِیں دا عذَاب سَٹّو (٤٨)۔
  44,49,چَکھ ہُݨ ! تُوں تاں طاقتور تے عِزّت والا بݨدا ہاویں (٤٩)۔
  44,50,یقیناً اِیہ اُوہَا (دوزخ) تاں ہے جِیندے متعلّق تُساں شَک کِیتی رَکھدے ہاوے (٥٠)۔
  44,51,بیشک پرہیزگار لوک ٻَہُوں اَمن والی جاء وِچ ہوسِن (٥١)۔
  44,52,بہشتی باغاں وِچ تے چَشمیاں دے کناریاں تے (٥٢)۔
  44,53,باریک تے موٹے ریشم دِیاں پُوشاکاں پاتے آمݨیں سامݨیں ٻیٹھے ہوسِن (٥٣)۔
  44,54,اِہجی ہوسی (اُنھاں دِی شان) تے اَساں (گورے رَنگ تے) سوہݨیں اَکّھیں والیاں ذالیں کُوں اُنھاں دا جُٹ بݨا ݙیسُوں (٥٤)۔
  44,55,اُوندے وِچ ہر قسم دے میوے اَپݨِیں مَرضی تے مَوج نال من٘گسِن (تے کھاسِن) (٥٥)۔
  44,56,اُوندے وِچ او مَوت دا مَزہ وِی نہ چَکھسِن سِوائے اُوں پہلی مَوت دے، اَتے اَللہ اُنھاں کُوں دَوزخ دے عذاب کنُوں بچائی رکھسے (٥٦)۔
  44,57,تیݙے رَبّ دِی طرفُوں اِیہ وَݙا فضل ہوسی اِیہا ہے ٻَہُوں وَݙی کامیابی (٥٧)۔
  44,58,(اَے رسول) بیشک اَساں اِیں (قرآن) کُوں تیݙی زبان وِچ سَوکھا کر ݙِتے، تاں جو اِیہ لوک نصیحت پَکڑِن (٥٨)۔
  44,59,ٻَس تُوں وِی اِنتظار وِچ رَہ، بیشک اِیہ لوک وِی اِنتظار وِچ ہِن (٥٩)۔
