quran[3]{c,v,t}:
  51,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  51,1,قَسم ہے اُنھاں ہَوائیں دِی! جِہڑیاں ذَرّات تے آبی بخارات کُوں اِݙّے اُݙّے اُݙائی رَکھدیاں ہِن (١)۔
  51,2,وَل اُنھاں ہَوائیں دِی وِی! جِہڑیاں مِین٘ہ وَساوَݨ والے بَدّلاں کُوں چاتی وَدیاں رَہندِن (٢)۔
  51,3,وَل اُنھاں ہَوائیں دِی، جِہڑیاں آرام آرام نال گُھلدیاں رَہندِن(٣)۔
  51,4,وَل اُنھاں ہَوائیں دِی جِہڑیاں اَللہ دے حُکم نال ساریاں شَئیں (مِین٘ہ وَغیرہ) تقسیم کریندیاں رَہندِن (٤)۔
  51,5,تحقیق جِہڑا وَعدہ تُہاݙے نال کِیتا ویندے اَصلُوں سَچّا ہے (٥)۔
  51,6,اَتے بیشک جَزا ضرور ݙِتی ویسی (٦)۔
  51,7,اَتے اَسمان دِی قَسم! جِیندے وِچ کَئی رَاہِیں ہِن (٧)۔
  51,8,تُساں یقیناً ہِک اِختلاف والی ڳالھ وِچ پَھتّھے ہوئے ہِیوے (٨)۔
  51,9,اِیں ڳالھ کنُوں اُوہو شَخص پِھر ویندے جیں پِھرݨاں ہوندے (٩)۔
  51,10,اَٹکل پَچُّو لَڑاوَݨ والے تَباہ تِھیوِن (١٠)۔
  51,11,اِیہ تاں او لوک ہِن، جِہڑے غفلت وِچ پے تے (حقیقت کُوں) بُھل چُکیئے ہِن (١١)۔
  51,12,اِیہ پُچّھدِن جو جَزا سَزا وَالا ݙین٘ہ کَݙاں آسی (١٢)۔
  51,13,اُوں ݙین٘ہ (آسی) ڄݙاں اُنھاں کُوں (دَوزخ دِی بھا) اُتّے سیک ݙِتا ویسی (١٣)۔
  51,14,(آکھیا ویسی) ہُݨ چَکُّھو مَزّہ آپݨیں فِتنے (دے عذاب) دَا ، اُوہو عذاب جِیندے متعلّق تُساں ݙَاڈھے اُٻَہلے ہَاوے (١٤)۔
  51,15,بیشک پَرہیزگار لوک بَہشتی باغاں وِچ ہوسِن تے چَشمیاں اُتّے رَہسِن (١٥)۔
  51,16,انھاں نعمتاں کُوں گِھن تے خوش تِھیندے رَہسِن، جِہڑیاں اُنھاں دا رَبّ اُنھاں کُوں ݙیندا ویسی، یقیناً او اِیں کنُوں پہلے نیک کَمّ کرݨ والے ہَن (١٦)۔
  51,17,او رات کُوں ٻَہُوں تھوڑی دیر سُمھدے ہِن (١٧)۔
  51,18,اَتے دَھمّی ویلے گُناہاں دِی بخشش مَنگدے ہن (١٨)۔
  51,19,اَتے اُنھاں دے مال متال وِچ مَن٘گ تے گِھنّݨ والیاں دا تے محرومی دے شِکار تِھی وَن٘ڄݨ والیاں دَا حق وِی ہوندا ہَا (١٩)۔
  51,20,اَتے زمین وِچ نِشانیاں ہِن یقین کرݨ والیاں کِیتے (٢٠)۔
  51,21,اَتے خود تُہاݙے اَندر وِی! وَل وِی تُساں ݙیکھدے کِیُوں نھیں؟ (٢١)۔
  51,22,اَتے اَسمان وِچ ہے تُہاݙا رِزق ، اَتے او کُجھ وِی جِیندا تُہاݙے نال وَعدہ کِیتا ویندے (٢٢)۔
  51,23,ٻَس اَسماناں تے زمین دے رَبّ دِی قسم! جو بیشک اِیہ (قرآن) بَرحق ہے بالکل اُوویں جیں طرح جو تُساں ٻولیندے پَے ہِیوے (٢٣)۔
  51,24,(اَے رسول) کیا تیݙے کولھ اِبراہیم دے عزّتاں والیاں مہماناں دِی ڳالھ پُنّی ہے (٢٤)۔
  51,25,ڄَݙاں جو او اُوندے کولھ آئے، ٻَس اَکھیُونے، تیکُوں سلام ہووے اُوں وِی آکھیا (تُہاکُوں وِی) سَلام ہووے (٢٥)۔
  51,26,(پَر اِیہ) اَݨ سُونھیں نظریے، وَل وِی او (چُپ کر تے) آپݨیاں گَھراں والیاں دو وَل ڳیا (٢٦)۔
  51,27,ٻَس ہِک موٹا تازہ بُھنّیا تَلیا ہویا گابا چَوا تے آ ڳیا (٢٧)۔
  51,28,ٻَس او اُنھاں کنُوں دِل وِچ ݙَرݨ لَڳیا، اُنھاں آکھیا، (اَساں کنُوں) نہ پِیا ݙَر، اَتے اُوکُوں ہِک ٻَہُوں عِلم والے پُتر دِی بشارت ݙِتی (٢٨)۔
  51,29,ٻَس اُوندی، ذال ٻَہُوں حیران تِھی تے اَڳُوں تے تَھئی، وَل اَپݨیں مَتّھے تے زور دا ہَتھ ماریا اَتے آکھیُس (مَیں تاں) ٻُڈھی سنڈھ (ذال) ہَاں (٢٩)۔
  51,30,اُنھاں آکھیا، اِیویں تِھیسے، اِیہ تاں میݙے رَبّ آکھیئے، بیشک او ٻَہُوں حِکمت (دانائی) والا ہے سَب کُجھ ڄاݨݨ والا ہے (٣٠)۔
  51,31,اُوں آکھیا ، اَے بھیڄے ہوئے ہو (فرشتو! ) تُہاݙے آوَݨ دَا وَݙا مَقصد کِیا ہے؟ (٣١)۔
  51,32,اُنھاں آکھیا، اَساکُوں گُنہگاراں دِی ہِک قوم دو بھیڄیا ڳئے (٣٢)۔
  51,33,تاں جو اَساں اُنھاں اُتّے کھنگری مِٹی دے پَتھر روڑے وَساؤُوں (٣٣)۔
  51,34,تیݙے رَبّ دے نزدیک حَد تُوں ٹَپ وَن٘ڄݨ والیاں کیتے نِشان لائے ہوئے ہَن (٣٤)۔
  51,35,ٻَس اَساں اُوں وَستی وِچُوں جِتنے مومن لوک ہَن، اُنھاں کُوں کَڈھ گِھدّا (٣٥)۔
  51,36,ٻَس اَساں اُوں (وَستی) وِچ کُجھ نہ لدّھا، سِوائے مسلماناں (فرمانبرداراں) دے ہِک گَھر دے (٣٦)۔
  51,37,(اِیں طرح) اَساں اُوں وَستی وِچ آپݨِیں ہِک نِشانی چھوڑی، انھاں لوکاں کِیتے جِہڑے جو دَرد ناک عذاب کنُوں ݙَردے رَہندے ہَن (٣٧)۔
  51,38,اَتے مُوسیٰ دے واقعے وِچ عِبرت دِی جاء ہے، ڄَݙاں اَساں اُوکُوں ہِک صاف سُتھری دلیل ݙے تے فِرعون دو بھیڄیا ٻَس او (فِرعون) آپݨِیں طاقت تے شان و شوکت دِی تَݙ گِھن تے پِھر ڳیا (٣٨)۔
  51,39,اَتے آکھیُس (اِیہ تاں) کُوئی جادُوگر ہے یا پاگل! (٣٩)۔
  51,40,ٻَس اَساں وِی اُوکُوں تے اُوندے لَشکریاں کُوں پَکڑ گِھدّا، ٻَس اَساں اُنھاں کُوں سَمندر وِچ سَٹ گَھتّیا، اَتے او تاں ہا وِی ملامت والے کَم کرݨ والا! (٤٠)۔
  51,41,اَتے عاد دے واقعے وِچ وِی (عِبرت دِی جاء ہے) ڄَݙاں اَساں اُنھاں اُتے اصلُوں نَفع نہ ݙیوݨ والی تیز ہَوا بھیڄی (٤١)۔
  51,42,او کوئی شَئے وِی نہ چھوڑیندی ہَئی، جِیندے اُتُّوں لَنگھدی ہَئی، ٻَس اُوکُوں بُتّھی بُھرڑی ہَݙی وانگوں (چِیݨا چِیݨا) کر ݙیندی ہَئی (٤٢)۔
  51,43,اَتے ثمُود دے واقعے وِچ وِی (عِبرت دِی نِشانی ہے) ڄَݙاں اُنھاں آکُوں آکھیا ڳیا، تُساں ٻَس ہِک مقرر وَقت تَئیں فائدے چَا گِھنّو (٤٣)۔
  51,44,پَر اُنھاں اَللہ دے حُکم کنُوں سِر چَا چَاتا، ٻَس اُنھاں کُوں بجلی دے کڑکاٹ (والے عذاب) آ پَکڑیا، اَتے او (ہَکّے ٻَکّے تِھی تے) ݙیکھدے رَہ ڳئے (٤٤)۔
  51,45,ٻَس اُنھاں وِچ نہ کھڑے تِھیوݨ دِی طاقت رَہی، اَتے نہ او ہِک ٻئے دِی کوئی مَدد کر سڳیئے (٤٥)۔
  51,46,اَتے اُوں کنُوں پہلے نُوح دِی قوم (دَا حَشر وِی ݙیکھو! ) یقیناً او تَاں اَصلُوں نافرمان لوکاں دِی قوم ہَئی (٤٦)۔
  51,47,اَتے اَساں اَسمان کُوں آپݨِیں قُدرت نال بݨایا، اَتے اَساں بے حد وُسعت تے اختیار والے ہَیں (٤٧)۔
  51,48,اَتے زمین کُوں اَساں ہِک فرش وانگیں تَلّے وِچھا ݙِتے، اَتے اَساں سوہݨاں وِچھاوَݨ والے ہَیں (٤٨)۔
  51,49,اَتے اَساں ہَر شَئے دے جوڑے جوڑے بݨائِن، تاں جو تُساں (اِیں ڳالھ تے) غور تے فِکر کرو (٤٩)۔
  51,50,ٻَس تُساں اَللہ والے پاسے بَھڄ تے آؤو، یقیناً مَیں اُوندی طرفُوں تُہاݙے کِیتے کُھلّے طور تے ݙَراوَݨ چِتاوَݨ آیاں(٥٠)۔
  51,51,اَتے اَللہ دے نال ٻئے کہیں رَبُوبݨے کُوں نہ رَلاؤو، یقیناً مَیں اُوندی طرفُوں تُہاݙے کِیتے کُھلّے طور تے ݙَراوَݨ چِتاوَݨ آیاں (٥١)۔
  51,52,اِیں طرح انھاں لوکاں دو اُنھاں کنُوں پہلے کوئی وِی اِہجے رسول نہیں آئے جِنہاں کُوں اُنہاں جادوگر یا پاڳل نہ سَݙیا ہووے (٥٢)۔
  51,53,کیا اِیہ لوک (ہِک ٻئے کُوں) اِیہا وَصیّت کریندے آندے رِیہن؟ بلکہ اِیہ تاں ہن وِی نافرمان (سرکش قوم) (٥٣)۔
  51,54,پس اَے رسول انھاں کنُوں مُن٘ہ پھیر گِھن، ٻس تیکُوں کوئی ملامت نہ کِیتی ویسی! (٥٤)۔
  51,55,اَتے نصیحت کِیتی رَکّھ، بیشک نصیحت مومن لوکاں کُوں فائدہ ݙیندی ہے (٥٥)۔
  51,56,اَتے مَیں جِنّاں کُوں تے اِنساناں کُوں اِیویں پَیدا نھیں کر چھوڑیا، سِوائے اِیندے جو او میݙی عِبادت (تے اِطاعت) کِیتی رَکِّھن (٥٦)۔
  51,57,مَیں اُنھاں کنُوں رِزق نھیں مَنگدا، اَتے نہ مَیں چَہنداں جو او میکُوں کھواوِن پِلاوِن (٥٧)۔
  51,58,اِیندے وِچ کوئی شَک کائے نھیں جو اَللہ اِی رِزق ݙیوݨ والا ہے، ٻَہُوں مضبوط تے پُوری قُدرت دا مالک ہے (٥٨)۔
  51,59,ٻَس یقیناً جِنھاں لوکاں ظُلم کِیتے، اُنھاں دے نصیب وِچ وِی اُوہو کُجھ (عذاب) ہے جِہڑا اُنھاں دے سَنگتیاں ساتھیاں کُوں مِلیے، ٻَس او میݙی طرفُوں اُٻَہل نہ کرواوِن (٥٩)۔
  51,60,آخر تباہی ہے، اُنھاں لوکاں دِی جِنھاں کُفر اِختیار کِیتے اُوں ݙین٘ہ، جِیندا اُنھاں نال وَعدہ کِیتا ویندے (٦٠)۔
