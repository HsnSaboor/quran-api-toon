quran[3]{c,v,t}:
  77,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  77,1,قَسم ہے اُنھاں ہَوائیں دِی جِہڑیاں ہَولے ہَولے گُھلدِن (١)۔
  77,2,وَت (ہَر شَئے کُوں اُݙاوَݨ کِیتے) زور گَھت آندِن (٢)
  77,3,تے (بَدّلاں کُوں) پَرے تَئیں کِھن٘ڈا ݙیندِن(٣)۔
  77,4,ٻَس وَل اُنھاں کُوں اَنج اَنج کر ݙیندِن(٤)۔
  77,5,اِیں طرح اَللہ دِی یاد دِلّاں وِچ گَھتیندِن (٥)۔
  77,6,عُذر لَہاوَݨ کِیتے یا ݙَراوے دے طور تے(٦)۔
  77,7,بیشک تُہاݙے نال جِہڑی شَئے دا وَعدہ کِیتا ہوئے او ضرور پُوری تِھی تے رَہسی(٧)۔
  77,8,ٻَس جِہڑے ویلے تارے ٻُݙَݨ پَے ویسِن(٨)۔
  77,9,اَتے ڄَݙاں اَسمان پَھاڑ ݙِتّا ویسی(٩)۔
  77,10,اَتے پَہاڑا کُوں پَٹ تے اُݙا ݙِتا ویسی (١٠)۔
  77,11,اَتے ڄَݙاں رسول مقرر وقت اُتّے کَٹّھے کِیتے ویسِن (١١)۔
  77,12,بَھلا کِہڑے ݙین٘ہ کِیتے اِیں ڳالھ وِچ دیر کِیتی ڳئی ہے(١٢)۔
  77,13,فیصلے والے ݙین٘ہ کِیتے(١٣)۔
  77,14,اَتے تُہاکُوں کِتُّھوں پَتہ لَڳسے جو فیصلہ دَا ݙین٘ہ کِیہو جیہا ہے (١٤)۔
  77,15,اُوں ݙین٘ہ (حَق کُوں) کُوڑا آکھݨ والیاں کِیتے شامت (تَباہی ہے) (١٥)۔
  77,16,کیا اَساں پہلے لوکاں کُوں تَباہ نھیں کر چھوڑیا (١٦)۔
  77,17,وَل اَساں بعد والیاں کُوں وِی اُنھاں دے پِچُّھوں بھیڄ ݙیندُوں(١٧)۔
  77,18,اَساں گُنہگاراں نال اِیہُو جیہا کَمّ کریندے ہَیں(١٨)۔
  77,19,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شَامت (تَباہی) ہے(١٩)۔
  77,20,کیا اَساں تُہاکُوں ہِک گَندے پاݨِیں (نُطفے) کنُوں پَیدا نھیں کِیتا(٢٠)۔
  77,21,ٻَس اَساں اُوکُوں ہِک محفوظ جاء تے جَھلّی رَکھیئے(٢١)۔
  77,22,ہِک معلوم وَقت توڑِیں(٢٢)۔
  77,23,ٻَس اَساں اُوندا ہِک اَندازہ مُقرر کِیتے، ٻَس اَساں تاں ہَیں وِی ٻَہُوں چَنڳا اَندازہ لَاوَݨ والے(٢٣)۔
  77,24,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شامت (تباہی) ہے(٢٤)۔
  77,25,کیا اَساں زمین کُوں اُوندے اَپݨیں اَندر گَھت گِھنَّݨ والی نھیں بݨایا(٢٥)۔
  77,26,جِیندے ہوئیاں کُوں وِی، تے مُوئیاں کُوں وِی (٢٦)۔
  77,27,اَتے اَساں اُوندے اُتّے اُچّے اُچّے پہاڑ قابو کر کھَڑائِن، اَتے اَساں تُہاکُوں تَریْہ لَہاوَݨ
  77,28,والا مِٹَّھا پاݨِیں پِلائے(٢٧)۔ اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شامت (تباہی) ہے(٢٨)۔
  77,29,ہُݨ) اُوکُوں ڄُل ݙیکھو، جِیکُوں تُساں کُوڑ اَکھیندے ہَاوے(٢٩)۔
  77,30,ڄُلُّو اُوں چَھاں دو جِہڑی تَرائے پاسیاں دو کِھن٘ڈی ہوئی ہے(٣٠)۔
  77,31,نہ ٹھاڈھل ݙیوݨ والی ہے، تے نہ بَھا دے شُعلیاں کنُوں بَچاوَݨ والی ہے(٣١)۔
  77,32,بیشک او بَھا وَݙیاں وَݙیاں چِنڳاریاں سَٹیندی ہے، جِہڑیاں اِیویں نظر آسِن جو او کوئی محل ماڑیاں ہووِن(٣٢)۔
  77,33,جِیویں جو او پِیلے رَنگ والے اُٹّھ ہووِن(٣٣)۔
  77,34,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شامت (تَباہی) ہے(٣٤)۔
  77,35,اِیہ او ݙین٘ہ ہے، ڄَݙاں او کُجھ وِی نہ آکھ سَڳسِن(٣٥)۔
  77,36,اَتے نہ اِی اُنھاں کُوں اِجازت ݙِتّی ویسی جو او کوئی عُذر بَہانہ پیش کرِن(٣٦)۔
  77,37,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی (شَامت) تَباہی آئی ہوسی(٣٧)۔
  77,38,اِیہو فیصلے دَا ݙین٘ہ ہے، اَساں تُہاکُوں تے تُساں کنُوں پہلے والیاں کُوں کَٹَّھا کر گِھنسُوں(٣٨)۔
  77,39,جیکر تُہاݙے کولھ کوئی چال (دَاء) ہے، تاں میݙے اُتّے چَلا ݙیکھاؤ(٣٩)۔
  77,40,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شَامت (تَباہی) آئی ہوئی ہوسی(٤٠)۔
  77,41,یقیناً پَرہیزگار لوک چَھائیں وِچ ہوسِن، تے چَشمیاں اُتّے رَہسِن(٤١)۔
  77,42,اَتے (اُتَّھاں) سَب اُوہے پَھل ہوسِن جِنھاں کِیتے اُنھاں دَا دِل مَنگسے(٤٢)۔
  77,43,مَزّے نال کھاؤ، تے پِیؤُو، اِیہ ہے اُنھاں عَملاں دا بَدلہ جِہڑے تُساں کریندے ہَاوے(٤٣)۔
  77,44,بیشک اَساں نیک کَمّ کرݨ والیاں کُوں اِیں طرح بَدلہ ݙیندے ہَیں(٤٤)۔
  77,45,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شامت (تَباہی) آئی ہوئی ہوسی(٤٥)۔
  77,46,کُجھ ݙین٘ہ کھاؤ تے کُجھ فائدے وِی چَا گِھنُّو، حَقیت وِچ تُساں تَاں ہِیوے وِی گُنہگار(٤٦)۔
  77,47,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شَامت آئی ہُوئی ہوسی(٤٧)۔
  77,48,اَتے ڄَݙاں اُنھاں کُوں آکھیا ویندے جو (اَللہ دے اَڳُوں) رَکوع کرو، ڄُھکّو، تاں نھیں جُھکدے(٤٨)۔
  77,49,اُوں ݙین٘ہ (حَق کُوں) کُوڑ آکھݨ والیاں دِی شَامت (تَباہی) آئی ہُوئی ہوسی(٤٩)۔
  77,50,بَھلا اِیں (قرآن دے) بعد او کِہڑی شَئے ہے جیندے اُتّے اِیمان گِھن آسِن(٥٠)۔
