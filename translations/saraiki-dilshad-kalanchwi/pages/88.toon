quran[6{c,v,t}:
4,60,کیا تَیں انھاں لوکاں کوں ݙِٹھے، جِہڑے اِیں زُعم وِچ ہِن، جو اُوندے اُتے اِیمان رَکھیندِن جِہڑا کُجھ تیݙے اُتے نازل کِیتا ڳئے، اَتے جِہڑا کُجھ تَیں کنُوں پہلے نازل کِیتا ڳئے، پر انھاں دے اِرادے اِیہ ہِن، جو آپݨیں معاملے دا فیصلہ کہیں سرکش شیطان کنُوں کراوِن، حالانکہ انھاں کُوں حکم ݙِتا ڳئے جو اُوندے اُتے یقین نہ کرن، کیوں جو شیطان تاں اِیہ چہندے جو اُنھاں کُوں گمراہی وِچ پَھساوے تے او وِی ٻَہُوں وَݙی گُمراہی وِچ (٦٠)۔
4,61,اَتے ڄَݙاں اُنھاں کُوں آکھیا ویندے جو جِہڑا کُجھ اَللہ دِی طرفوں نازل تَھئے، اُوندو رجوع کرو، اَتے رسول والے پاسے دو آؤ، تاں منافقاں کوں ݙیکھدیں، جو تَیں کنُوں پَرے تِھی تے رَہندِن، بلکہ ٻَہُوں پَرے (٦١)۔
4,62,ٻَس اُوں ویلے کیا حال کیا ہوندنیں، ڄݙاں اُنھاں اُتے کوئی مصیبت آندی ہے، بہ سبب اُوندے جِہڑا کُجھ اُنھاں آپݨیاں ہتھاں نال اَڳوں کِیتے بھیڄا ہوندے، وَل تاں تیݙے کولھ بَھنّے آندِن، اَللہ دِیاں قَسماں چیندِن جو اَساں تاں سوائے بَھلائی تے صلح صفائی دے کُجھ نھیں چہندے (٦٢)۔
4,63,اِیہ او لوک ہِن جِنھاں دے دِلاں وِچ جِہڑا کُجھ ہے اَللہ ڄاݨدا کھڑے تُوں اُنھاں کنُوں مُن٘ہ وَٹا چا، تے انھاں کوں نصیحت کر اَتے انھاں کوں او ڳالھ آکھ، جِہڑی جو اُنھاں دے دِلاں وِچ اَثر وَن٘ڄ کرے (٦٣)۔
4,64,اَتے اَساں جِہڑا رسول وِی بھیڄے، اِیں واسطے بھیڄے جو اَللہ دے فرمان دے مطابق اُوندی پَیروی کِیتی وَن٘ڄے، اَتے ڄَݙاں اِیہ لوک اپݨیں حق وِچ ظلم کر کھڑے ہَن، جیکر تیݙے کولھ آ ویندے ٻَس اَللہ کنُوں بخشش دِی دُعا منگدے، اَتے رسول وِی انھاں کِیتے بخشش دِی دُعا منگدا، تاں اَللہ کُوں معاف کر ݙیوݨ والا تے وَݙے رَحم والا پیندے (٦٤)۔
4,65,ٻَس تیݙے رَبّ دِی قسم! جو اِیہ لوک اِیمان کائے نہ گِھن آسِن، جے توڑیں اِیہ اپݨیاں جھیڑیاں جھگڑیاں وِچ تُہاکوں آپݨاں مُنصِف نہ بݨاوِن، وَل جِہڑا فیصلہ تُوں کر ݙیویں، اُوندے وِچ آپݨاں کوئی حَرج نہ سَمجھِن ، بلکہ اُوکوں دل نال مَن گِھنّن (٦٥)۔
