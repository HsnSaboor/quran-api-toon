quran[29{c,v,t}:
70,11,حالانکہ او ہِک ٻئے کُوں ݙیکھالے وِی ویسِن، ہَر گُنہگار اِیہ چَہسے جو اُوں ݙین٘ہ دے عذاب کنُوں بَچَݨ دِی خاطر او فِدیہ (بدلہ) ݙے ݙیوے آپݨیاں پُتراں کُوں (١١)
70,12,اَتے آپݨیں زال کُوں، تے آپݨیں بِھرا کُوں (١٢)۔
70,13,اَتے آپݨیں کُن٘بے کُوں جِیندے وِچ او آرام نال رَہندا رِیہا (١٣)۔
70,14,اَتے جو کوئی زمین تے ہے، سارے دے سارے، فِدیہ (بدلہ وِچ) ݙے ݙیوے تاں جو اُوکُوں نِجات مِل وَن٘ڄے (١٤)۔
70,15,پَر اِیں نہ تِھیسی، یقیناً او ہِک لَمبیاں شُعلیاں والی بَھا ہوسی (١٥)۔
70,16,او مُن٘ہ اُتُّوں چَم کُوں زور نال اُدھیڑ گِھنسی (١٦)۔
70,17,او ہَر اُوں شَخص کُوں سَݙیسی، جیں (حَق کنُوں) کَن٘ڈ وَلائی تے مُن٘ہ پھیر گِھدا (١٧)۔
70,18,اَتے مال کَٹّھا کر تے رَکّھی رَکھیا (١٨)۔
70,19,یقیناً اِنسان کُوں بے صَبرا بَݨا تے پَیدا کِیتا ڳئے (١٩)۔
70,20,ڄَݙاں اُوکُوں کوئی ݙُکھ تِھیندے تاں گَھبرا ویندے (٢٠)۔
70,21,اَتے ڄَݙاں اُوکُوں سُکھ مِلدے تاں کنجوسی کرݨ لَڳ پَوندے (٢١)۔
70,22,سِوائے اُنھاں دے جِہڑے نمازاں پَڑھدِن (٢٢)۔
70,23,جِہڑے آپݨیاں نمازاں دے ہمیشہ پَابَند تَھئے رَہندِن (٢٣)۔
70,24,اَتے جِنھاں دِی مَال مَݙی وِچ کِنھائیں دَا حِصہ مقرر ہوندے (٢٤)۔
70,25,چاہے او مَنگݨ والے ہِن، چاہے (کہیں ڳالھُوں) نھیں مَنگدے (٢٥)۔
70,26,اَتے جِہڑے جَزا سَزا دے ݙین٘ہ دِی تصدیق کریندِن (مَنیندِن) (٢٦)۔
70,27,اَتے جِہڑے اَپݨیں رَبّ دے عذاب کنُوں ݙَردے رَہندِن (٢٧)۔
70,28,تحقیق اَپݨیں رَبّ دے عذاب کنُوں کوئی وِی بے خَوفا کائے نھیں (٢٨)۔
70,29,اَتے جِہڑے اَپݨیں ننڳیج دِی پُوری پُوری حِفاظت کریندِن (٢٩)۔
70,30,سِوائے آپݨیاں ذالیں دے یا جِہڑیاں اُنھاں دِی ملکیت وِچ ہُووِن، وَت اِیں ڳالھ وِچ تحقیق اُنھاں اُتے کوئی وِی ملامت کائے نھیں (٣٠)
70,31,ٻَس جِہڑے اُنھاں کنُوں کہیں ٻئی کنُوں چَہوِن، تاں اِہجے لوک اِی حَد کنُوں ٹَپ وَن٘ڄݨ والے ہِن (٣١)۔
70,32,اَتے جِہڑے آپݨیں کولھ رَکّھیاں ہوئیاں اَمانتاں دا تے (ٻِنھاں نال) کِیتے ہوئے وَعدیاں دا خیال رَکھیندِن (٣٢)۔
70,33,اَتے جِہڑے اَپݨیاں گواہیاں اُتّے پَکّے تِھی رَہندِن (٣٣)۔
70,34,اَتے جِہڑے آپݨیاں نمازاں دَا پُورا پُورا خیال رَکھی رَکھدِن (٣٤)۔
70,35,اِیہے لوک اِی او ہِن جِہڑے وَݙیاں عِزّتاں نال بَہشتی باغاں وِچ رَہسِن (٣٥)۔
70,36,اَے رسول) انھاں لوکاں کُوں کیا تِھی ڳئے، جِنھاں کُفر اِختیار کِیتا ہوئے جو او تیݙے کولھ بَھڄ بَھڄ تے آندے پِیئِن (٣٦)۔
70,37,سَڄّے پاسُوں وِی تے کَھٻّے پاسُوں وِی، ٹولیاں دِیاں ٹولیاں تِھی تے (٣٧)۔
70,38,کیا انھاں وِچُوں ہَر کوئی اِیہو طَمع رَکھیندے جو اُوکُوں نعمتاں والے باغ وِچ دَاخل کِیتا وَںڄے (٣٨)۔
70,39,ہَرگز کوئے نہ! اَساں اُوکُوں جیں شَئے وِچُوں پَیدا کِیتے اُوکُوں او (چَنڳی طرح) ڄاݨدے (٣٩)۔
