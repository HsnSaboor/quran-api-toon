quran[3]{c,v,t}:
  27,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  27,1,طٓسٓ، اِیہ آیاتاں ہِن، قرآن دِیاں جِہڑی جو صاف صاف بیان کر ݙیوݨ والی کِتاب ہے(١)۔
  27,2,اَتے ہِدایت ہے تے خُوشخبری ہے اُنھاں مومن لوکاں کِیتے(٢)۔
  27,3,جِہڑے جو نماز کُوں قائِم کِیتی رَکھدِن، اَتے زَکوٰۃ ݙِتّی رَکھیندِن رَہندِن، اَتے آخرت اُتے یقین وِی رَکھیندے ہِن(٣)۔
  27,4,بیشک جِہڑے لوک آخرت اُتّے اِیمان نھیں رَکھیندے تاں اَساں اُنھاں دے کرتُوت اُنھاں (دے دِماغ وِچ) سوہݨیں کر تے ݙکھائِن ٻَس او اِݙّے اُݙّے تُھڑکئیے تے وٻلیے وَدّے ہِن(٤)۔
  27,5,اَتے اِیہے او لوک ہِن جِنھاں کِیتے ٻَہُوں سَخت عَذاب ہے، اَتے اِیہے آخرت کُوں وِی ٻَہُوں گھاٹے وِچ رَہسِن(٥)۔
  27,6,اَتے بیشک اِیہ قرآن تیکُوں ݙِتّا ویندا پَے، اُوندی طرفُوں جِہڑا جو سَب توں زیادہ حِکمت والا تے سَب کُجھ ڄاݨݨ والا ہے(٦)۔
  27,7,ہِک وَقت مُوسیٰ اَپݨیں گَھر والیاں کُوں آکھیا، جو مَیں کوئی بھا ݙِٹّھی ہے، اَجھو مَیں اُتّھوں رَستے دَا پَتہ شَتہ کر آنداں، یا وَت اُتُّھوں تُہاݙے کِیتے کوئی ٻَکھدا ہُوئیا اَن٘ڳارہ چَا آنداں، تاں جو تُساں بھا سیکُو(٧)۔
  27,8,ٻَس ڄَݙاں او اُوندے کولھ ڳیا، تاں (غیب کنُوں) آواز آئی جو مُبارک ہے جِہڑا تیکُوں اِیندے وِچ نَظردے تے بھاویں اِیندے اِݙُّوں اُݙُّوں ہے، اَتے پاک ہے اَللہ جِہڑا سارے جہاناں دَا پَالݨ ہَار ہے(٨)۔
  27,9,اَے مُوسیٰ، بیشک اِیہ مَیں ہَاں، اَللہ ! ٻَہُوں زَبردست تے وَݙی دانائی والا(٩)۔
  27,10,اَتے اَپݨِیں سوٹی سَٹ (تے ݙیکھ)، ٻَس جِہڑے ویلے اُوں ݙِٹَّھا، جو او ہَلدا ڄُلدا نان٘گ ہے، تاں کَن٘ڈ وَلا تے بھڄ پِیا، اَتے پِچُّھوں تے وِی نہ ݙِٹُّھس، اَے مُوسی! نَہ پِیا ݙَر، بیشک میݙے کولھ آ، تے رسول ݙَردے کائے نھیں(١٠)۔
  27,11,اَلبتہ جیں کَہیں زیادتی کِیتی، وَل بُرائی کرَݨ دے بعد اُوکُوں نیکی وِچ بَدل گِھدّے، تاں وَل بیشک مَیں بَخشݨ ہار تے ہمیشہ رحمت کرݨ والا ہَاں(١١)۔
  27,12,اَتے اَپݨاں ہَتّھ آپݨیں گِروان وِچ گَھتّ ݙیکھ، تاں چَمکدا ہُوئیا نِکلسے بغیر کہیں عیب دے! اِہجیاں نَوں ٩ نِشانیاں فِرعون تے اُوندی قَوم کِیتے (ہِن)، بیشک اِیہ لوک ہِک بَد کردار قَوم بَݨ ڳئیِن(١٢)۔
  27,13,ٻَس ڄَݙاں اَساݙِیاں اَکّھیں کھول ݙیوݨ والیاں نِشانیاں اُنھاں کولھ آئیاں تاں اَکھیُونے، جو اِیہ تاں کُھلّا ݙُلّا جادُو ہے(١٣)۔
  27,14,اَتے زیادتی تے گَھمن٘ڈ وِچ آ تے اُنھاں کنُوں اِنکار کر چھوڑیا، بھاویں جو اُنھاں دے دِلّ اُنھاں کُوں مَنّ چُکئیے ہَن، ٻَس ݙیکھ گِھن، فَسادی لوکاں دَا اَنجام کِہجا تِھیندے(١٤)۔
  27,15,اَتے تحقیق اَساں داؤد تے سُلیمان کُوں عِلم بَخشیا اَتے اُنھاں ݙُوہائیں آکھیا، سَب تعریفاں اَللہ کِیتے ہِن، جیں اَساکُوں آپݨیں ٻَہُوں سارے مومن بَندیاں اُتے فضیلت بخشی ہے(١٥)۔
  27,16,اَتے سُلیمان دَاؤد دَا وَارث بݨیا، اَتے اُوں آکھیا، لوکو! میکُوں پَکّھیاں دِی ٻولی سِکھائی ڳئی ہے، اَتے ہَر طرح دِی شَئے ݙِتّی ڳئی ہے، بیشک اِیہُو اُوندا کُھلَّم کُھلّا فضل ہے(١٦)۔
  27,17,اَتے سُلیمان کِیتے جِنّاں دے، اِنساناں دے تے پَکّھیاں دے لَشکر کَٹّھے کِیتے ڳئے، ٻَس اُنھاں کُوں پُورے ضابطے وِچ رَکھیا ویندا ہَا(١٧)۔
  27,18,ہِک وَقت آیا، ڄَݙاں جو او کَوِیلیاں والے عِلاقے وِچُوں لَنگھیا، تاں ہِک کویلی آکھیا، جو کویلیُو، آپݨیاں آپݨیاں کُھݙاں وِچ وَڑ وَن٘ڄُو، اِیہ نَہ تِھیوے جو سُلیمان تے اُوندے لَشکر تُہاکُوں لَتاڑ چھوڑِن، اَتے اُنھاں کُوں پَتہ وِی نَہ لڳے(١٨)۔
  27,19,ٻَس (سُلیمان کُوں) اُوندی ڳالھ دا مَزّہ آیا، تے کِھلّ پِیا، اَتے آکھݨ لڳیا، جو میݙے رَبّ آ ! میکُوں توفیق ݙے جو مَیں تیݙیاں نعمتاں دَا شُکر اَدا کراں، جِہڑیاں تَیں میکُوں تے میݙے پِیؤ مَاء کُوں بَخشیاں ہِن، اَتے اِہجے نیک عَمل کر سَڳاں جو تُوں راضی تِھی وَن٘ڄیں اَتے میکُوں آپݨِیں رحمت نال آپݨیں نیک بَندیاں وِچ داخل چَا کر(١٩)۔
  27,20,اَتے (ہِکّ واری) اُوں پَکّھیاں کُوں سَنبھالیا، تاں آکھݨ لڳیا، کیا ڳالھ ہے، جو دَرکھاݨ پَکّھی کُوں نھیں پِیا ݙہدا، کیا او کِتھائیں غائب تِھی وَن٘ڄݨ والیاں وِچ تاں نھیں وَن٘ڄ رَلیا(٢٠)۔
  27,21,مَیں اُوکُوں ٻَہُوں سَزا ݙیساں، یا کُوہ گَھتیساں، یا او میݙے سامݨیں آپݨاں کوئی عُذر پیش آ کرے(٢١)۔
  27,22,کوئی زیادہ دیر نَہ تَھئی جو دَرکھاݨ پَکّھی آݨ آکھیا، جو میکُوں اِہجیاں ڳالھِیں دَا پَتہ لڳے، جِنھاں دی تُہاکُوں وِی خبر کائے نھیں، اَتے مَیں تُہاݙے کِیتے سَبا (قَوم) دِی پَکّی خبر گِھن آیاں(٢٢)۔
  27,23,سَچّ پِیا اَہداں، جو مَیں ہِک ذال ݙِٹّھی ہے، جِہڑی اُنھاں اُتے حکومت کریندی ہے، اَتے ہَر طرح دِی شَئے اُوکُوں بَخشی ڳئی ہے، اَتے اُوندا تَخت وِی ٻَہُوں وَݙا ہے(٢٣)۔
  27,24,اَتے مَیں اُوکُوں تے اُوندی قَوم کُوں ݙِٹّھے، جو اَللہ کُوں چھوڑ تے سِجھ کُوں سجدے کریندِن، اَتے شیطان نے (اُنھاں دِیاں نَظراں وِچ) اُنھاں دے کرتُوتاں کُوں سوہݨاں کر تے ݙیکھایا ہوئے، وَل اُوں اُنھاں کُوں سِدّھے رَستے کنُوں روک گِھدّے، ٻَس اُنھاں کُوں سِدّھے رَاہ تے نِھیں لایا ڳیا(٢٤)۔
  27,25,بھلا او کِیُوں نَہ اَللہ کُوں سَجدہ کرِن، جِہڑا جو اَسماناں تے زمین دِیاں لُکیاں ہُوئیاں شَئیں کُوں کَڈھیندے، اَتے سَب کُجھ ڄاݨدے جِہڑا کُجھ تُساں لُک تے کریندو، اَتے جِہڑا کُجھ ݙِکھا تے کریندو(٢٥)۔
  27,26,اَللہ تاں او ہے جِیندے سِوا ٻِیا کوئی معبود کائے نھیں، او وَݙِیاں عَظمتاں والے عَرش دَا مالِک ہے(٢٦)۔
  27,27,سُلیمان آکھیا، اَساں اَجھو ݙیکھ گِھندُوں جو کیا تَیں سَچ آکھیئے یا کوڑیاں وِچُوں ہِیں(٢٧)۔
  27,28,تُوں میݙا اِیہ خَط گِھن تے چَلیا وَن٘ڄ، اَتے اُنھاں کولھ وَن٘ڄ سَٹ، وَل اُنھاں کنُوں وَل آ، ٻَس ݙیکھ آ جو او کیا کریندِن(٢٨)۔
  27,29,اُوں ذال آکھیا، میݙے قَوم دے سَردارو، اِیہ سَچّ ہے، جو میݙے کولھ ہِک عِزّتاں والا خَط سَٹیا ڳئے(٢٩)۔
  27,30,"بیشک او سُلیمان کنُوں آئے، او بالکل اِیں ہے "" شُروع کرینداں ٻَہُوں مہربان تے ہمیشہ رحمت کرݨ والے اللہ دے ناں نال"" (٣٠)۔"
  27,31,تُساں میݙے خِلاف کوئی گُستاخی نَہ کرو، بَلکہ فرمانبردار (مسلمان) بَݨ تے مَیں دو لڳئیے آؤ(٣١)۔
  27,32,وَل آکھݨ لڳی، جو میݙے قَوم دے سَردارو! میکُوں اِیں معاملے وِچ صَلاح ݙیوُو، مَیں تَاں کُوئی معاملہ طَے وِی نھیں کریندی، جے توڑِیں تُساں شامل نَہ ہُووُو(٣٢)۔
  27,33,سَرداراں آکھیا، اَساں طاقت والے ہَیں، اَتے سَخت جَنگاں لَڑݨ والے ہَیں پَر حُکم ݙیوَݨ تیݙے ہَتّھ وِچ ہے، تُوں آپ ݙیکھ گِھنّ جو کیا جواب ݙِیویڄے(٣٣)۔
  27,34,اُوں آکھیا، دَراَصل بادشاہ جِہڑے وِی مُلک وِچ داخِل تِھیندِن تاں اُوکُوں چَن٘ڳی طَرح اُڄاڑ ݙیندِن اَتے اُوندے عِزّت دار لوکاں کُوں ذلیل تے خُوار کر چھوڑیندِن اَتے اِیویں تِھیندا آندے(٣٤)۔
  27,35,(اِیں ڳالھُوں پہلے) مَیں اُوندے کولھ ہِک تُحفہ ضرور بھیڄیندی ہَاں اَتے ݙیکھدی ہَاں، جو میݙے بَندے کِہجا جواب گِھن آندِن(٣٥)۔
  27,36,ٻَس جِہڑے ویلے سفیر (سَنہڑُو) سُلیمان کولھ آیا، تاں سُلیمان آکھیا، کیا تُساں آپݨیں مال دولت نال میݙی مَدد کرݨ چَہندو، پر جو کُجھ اَللہ میکُوں ݙِتّا ہوئے، او اُوں کنُوں بہتر ہے، جِہڑا کُجھ تُہاکُوں ݙِتّا ہِس، ٻَس تُہاݙی اِیہ سوکھڑی (تحفہ) تُہاکُوں مُبارک رَہے(٣٦)۔
  27,37,تُوں اُنھاں کُوں وَن٘ڄ آکھ، ٻَس اَساں اُنھاں اُتّے اِہجے لَشکراں نال چَڑھائی کر تے آسُوں جِنھاں نال او مُقابلہ وِی نَہ کر سَڳسِن، اَتے اَساں اُنھاں کُوں اُتُّھوں ذلیل و خُوار کر تے کَڈھ چھوڑیسُوں، اَتے او بے قَدرے تِھی ویسِن(٣٧)۔
  27,38,(سُلیمان) آکھیا، اَے سردارو، تُہاݙے وِچُوں کوئی اِہجا ہے جو اُوں ذال دَا تخت میݙے کولھ چَا گِھن آوے، اِیں کنُوں وِی پہلے جو او فَرمانبردار بَݨ تے میݙے پیش آ تِھیوِن(٣٨)۔
  27,39,جِنّاں وِچُوں ہِک موٹے تَکڑے جِنّ آکھیا، مَیں اُوکُوں تُہاݙے کولھ چَا گِھن آنداں اِیں کنُوں وِی پَہلے جو تُساں اَپݨیں کونسل (گَدّی) کنُوں اُٹّھو، اَتے مَیں اِیں کَمّ کِیتے کافی زور وِی رَکھینداں، اَتے اَمانتدار وِی ہَاں(٣٩)۔
  27,40,جِہڑے شَخص کولھ کِتاب دے عِلم (دا زور) ہَا، اُوں آکھیا، جو مَیں اُوں (تخت) کُوں تیݙے کولھ چا آنداں اِیں کنُوں وِی پہلے جو تیݙی اَکّھ جھُمکے! ٻَس جِہڑے ویلے اُوں تخت کُوں اَصلُوں آپݨیں کولھ رَکھیا ہوئیا ݙِٹَّھا، تاں آکھیُس، جو اِیہ سَب کُجھ میݙے رَبّ دے فضل نال تَھئے تاں جو او میکُوں اَزماوے، جو کیا مَیں اُوندا شُکر اَدا کرینداں، یا نَا شُکری کرینداں، اَتے جِہڑا کوئی شُکر اَدا کریندے تاں ٻَس او آپݨیں فائدے کِیتے شُکر اَدا کریندے، جِہڑا نا شُکری کریندے، تاں یقیناً میݙا رَبّ بے پَروا تے ڈھیر کُجھ ݙیوݨ والا ہے(٤٠)۔
  27,41,(سُلیمان) آکھیا، اُوکُوں اَزماوَݨ کِیتے اُوندے تخت دِی شکل بَدلو چَا، وَل اَساں ݙیکھدے ہَیں جو اُوکُوں سُن٘ڄاݨ ہے یا او وِی اُنھاں لوکاں وِچُوں ہے ، جِنھاں کُوں کوئی سُدّھ سَمجھ نھیں ݙِتّی ڳئی(٤١)۔
  27,42,ٻَس جِہڑے ویلے او آڳئی تاں پُچّھیا ڳیا، جو کیا تیݙا تَخت وِی اِیویں ہے، اُوں آکھیا، اِیہ تاں ہُوبَہُو اُوہو ہے، اَتے اَساکُوں پہلے کنُوں اِیندا عِلم بخش ݙِتّا ڳیا ہَا، اَتے اَساں فرمانبردار تِھی ڳئے ہِیسے(٤٢)۔
  27,43,اَتے اُوں اُوکُوں اُوں شَئے کنُوں روکیا، جِیندی او اَللہ کُوں چھوڑ تے بَندگی کریندی ہَئی، کِیُوں جو او کافراں دِی قَوم وِچُّوں ہَئی(٤٣)۔
  27,44,اُوکُوں آکھیا ڳیا، جو محل وِچ وَڑ ڄُلّ، ٻَس جِہڑے ویلے اُوں (اُوندے فرش کُوں) ݙِٹَّھا، تاں سَمجھیُس جو اِتَّھاں پاݨِیں دَا کوئی حَوض جیہا ہے، اوں آپݨیاں پِنّیاں کنُوں کَپڑے کُوں اُچّا چَا کِیتا، سُلیمان آکھیا، اِیہ ہِک اِہجا محل ہے جِیندے وِچ شِیشہ جَڑیا ہوئے، اُوں ذال آکھیا، میݙے رَبّ آ، مَیں تاں اَپݨیں اُتّے ظُلم کریندی رَہ ڳئی ہَاں اَتے مَیں سُلیمان نال تِھی تے سارے جہاناں دے پالَݨ ہار، اَللہ دِی فرمانبردار تِھی ویندی ہَاں(٤٤)۔
  27,45,اَتے تحقیق اَساں ثمود دِی قَوم کولھ اُنھاں دے (بِرادری دے) بِھرا صالح کُوں بھیڄیا، جو تُساں اَللہ دِی عِبادت کرو، پَر او ہُوں ویلے ݙُوں ٹولے تِھی تے آپس وِچ لَڑݨ جَھڳڑݨ پَے ڳئے(٤٥)۔
  27,46,صالح آکھیا، اَے میݙی قَوم! تُساں بَھلائی کنُوں پہلے بُرائی کِیتے کِیُوں جَلدی پَے کریندو، اَللہ کنُوں بخشش کِیُوں نھیں مَنگدے تاں جو تُہاݙے اُتّے رحم کِیتا وَن٘ڄے(٤٦)۔
  27,47,اُنھاں آکھیا، جو اَساں تاں تیکُوں تے تیݙے نال والیاں کُوں اَپݨیں کِیتے بَد شَگُونا (منحوس) سَمجھدے ہَیں (صالح) آکھیا تُہاݙی بَد شگُونی (نحوست) تاں اَللہ کولھ ہے بلکہ تُساں تَاں اَزمائش وِچ سَٹّی وَن٘ڄݨ والی قَوم ہِیوے(٤٧)۔
  27,48,اَتے شہر وِچ نَوں( ٩) اِہجے بَندے ہِن، جِہڑے زمین اُتے فَساد مَچائی رَکھیندے ہِن، اَتے اِصلاح دِی کوئی ڳالھ نھیں کریندے(٤٨)۔
  27,49,اُنھاں (آپس وِچ) آکھیا، اَساں اِیں ڳالھ دِی اَللہ دِی قَسم چاؤں، جو اَساں اِیندے تے اِیندے گَھر والیاں اَتے رات کُوں چوری چوری حَملہ کر ݙیسُوں، وَل اِیندے وَلّی وارث کُوں آکھ ݙیسُوں جو اَساں تاں اُنھاں دے گَھر والیاں دِی تَباہی دے موقع تے موجود اِی نَہ ہَاسے(٤٩)۔
  27,50,اَتے اُنھاں ہِک چال چَلّی، تاں اَساں وِی ہِک چَال چَلّی، جِیندی اُنھاں کُوں خَبر وِی نَہ پئی(٥٠)۔
  27,51,ٻَس تُوں (اَے رسول) ݙیکھ گِھنّ، اُنھاں دِی چال دا کِیہو جیہا اَنجام تِھیا، ساریْاں کُوں غارت کر چھوڑیا(٥١)۔
  27,52,ٻَس اِیہ گَھر ہِن، اُنھاں دے جِہڑے سُن٘ڄ تَھئے پِیئن، کِیُوں جو او ظُلم کریندے ہَن، بیشک اِیندے وِچ ہِک نِشانی ہے، اُوں قَوم کِیتے جِہڑی ڄاݨدی سَمجھدی ہے(٥٢)۔
  27,53,اَتے اَساں اُنھاں کُوں بَچا گِھدّا جِہڑے اِیمان گِھن آئے ہن، تے پَرہیزگار تِھی ڳئے ہن(٥٣)۔
  27,54,اَتے لُوط! (اُوندی ڳالھ اِیہ ہے) جو ڄَݙاں اُوں اَپݨِیں قَوم کُوں آکھیا جو تُساں بَدکاری دو کِیُوں آندو حالانکہ تُساں خُود سَمجھدار ہِیوے(٥٤)۔
  27,55,کیا تُساں ذالیں کُوں چھوڑ تے جواناں نال شَہوت ضرور مٹیسو، بلکہ تُساں تاں احمقاں والے کَمّ کرݨ والی قَوم ہِیوے(٥٥)۔
  27,56,ٻَس اُوندی قَوم دَا جواب کُجھ نَہ ہَا سِوائے اِیندے جو اُنھاں آکھیا جو لوط دے گَھر والیاں کُوں اَپݨِیں وَستّی وِچُوں کَڈھ چھوڑو، یقیناً اِیہ لوک وَݙّے پاکباز بݨݨ لڳئِن(٥٦)۔
  27,57,ٻَس اَساں اُوکُوں تے اُوندے گَھر والیاں کُوں بَچا گِھدّا سِوائے اُوندی ذال دے کِیُوں جو اُوندے مُقدر وِچ پِچُّھوں رَہ وَن٘ڄݨ والیاں وِچُوں تِھی وَن٘ڄݨاں ہَا(٥٧)۔
  27,58,اَتے اَساں اُنھاں لوکاں اُتے (ہِک قِسم دا) مِین٘ہ وَسایا، ٻَس اِیہ چِتائے ہُوئیاں بَندیاں کِیتے ٻَہُوں سَخت مِین٘ہ ہَا(٥٨)۔
  27,59,(اَے رسول آکھ ݙے جو سَب تعریفاں اَللہ کِیتے دِیاں ہِن، اَتے سَلامتی ہے اُوندی اُنھاں بندیاں کِیتے جِنھاں کُوں اُوں (اَپݨِیں کَمّ کِیتے) چُݨ گِھدّے، بَھلا کیا اَللہ بہتر ہے یا او جِنھاں کُوں اِیہ (اُونداشریک بݨیندِن(٥٩)۔
  27,60,بَھلا او کوݨ ہے؟ جیں اَسماناں تے زمین کُوں پَیدا کِیتے، اَتے تُہاݙے کِیتے اَسمان کنُوں پاݨِیں وَسائے، وَل اُوندے نال رونقاں والے باغ ڄَمائِن، تُہاݙے کِیتے تاں ممکن نَہ ہَا، جو تُساں اُنھاں دَرختاں کُوں ڄَمیندے، وَل کیا اَللہ دے نال کوئی ٻِیا معبود وِی ہے (کوئے نہ) بلکہ اِیہ تاں سِدّھے رَاہ کنُوں تُھڑکی ہوئی قَوم ہے(٦٠)۔
  27,61,بَھلا او کَوݨ ہے جیں زمین کُوں رَہݨ ٻَہݨ دِی جاء بݨائے، اَتے اِیندے وِچ نہراں بݨائِن، اَتے اِیندے (تھرام) کِیتے پَہاڑ بݨائِن، اَتے ݙُوں (قِسم دے) سمندراں دے اَدّھ وِچ ہِک حَد ٻَنّاں (اوٹ) بݨائے کیا اَللہ دے نال کوئی ٻِیا معبود وِی ہے؟ (کوئے نہ) بلکہ انھاں دے ڈھیر تاں کوئی کُجھ ڄاݨدے وِی کائے نھیں(٦١)۔
  27,62,بَھلا او کُوݨ ہے جِہڑا بے چین آدمی دِی دُعا قبول کریندے، ڄَݙاں جو او اُوکُوں سَݙیندے، اَتے اُوندے ݙُکھ دَرد کُوں پَرّے ہَٹیندے، اَتے تُہاکُوں زمین اُتے آپݨاں خلیفہ بݨائے، کیا اَللہ دے نال ٻِیا کوئی معبود وِی ہے تُساں تاں اِیں ڳالھ تے ٻَہُوں گَھٹ غور کریندو(٦٢)۔
  27,63,بَھلا او کُوݨ ہے، جِہڑا تُہاکُوں خُشکی تے تَری دے اَندھاریاں وِچ رَاہ ݙِیکھیندے، اَتے اَپݨِیں رحمت (دے مِین٘ہ) کنُوں پہلے ہَوائیں کُوں خُوشخبری ݙے تے بھیڄیندے، کیا اَللہ دے نال ٻِیا کوئی معبود وِی ہے (کوئے نہ) اُوندی شان تاں اُوں کنُوں ٻَہُوں اُچّی ہے، جیکوں اِیہ لوک (اُوندا) شریک بݨیندِن(٦٣)۔
  27,64,بَھلا او کَوݨ ہے جِہڑا پہلی واری خلقت کُوں پَیدا کریندے، تے وَلا وِی جِیوا کھڑا کریسے، اَتے کَوݨ ہے جِہڑا اَسمان کنُوں تے زمین وِچُوں رِزق ݙیندے، کیا اَللہ دے نال کوئی ٻِیا معبود وِی ہے؟ (اَے رسول) آکھ ݙے، تُساں سَچّے ہِیوے، تاں کوئی دلیل گِھن آؤ(٦٤)۔
  27,65,آکھ ݙے جو کوئی ڄاݨدے اَسماناں تے زمین دے وِچ دِیاں اَݨ ݙِٹّھیاں شَئیں کُوں، سِوائے اَللہ دے، اَتے نہ اُنھاں لوکاں کُوں کوئی پَتہ ہے، جو کَݙاں اُٹَھا کھڑے کِیتے ویسِن(٦٥)۔
  27,66,بلکہ اُنھاں دا عِلم آخرت دے متعلّق کُجھ ݙَسا وِی نھیں سَڳدا، او تاں اِیندے متعلّق شَک وِچ ہِن، بلکہ اُوندی (حقیقت کنُوں) اَصلُوں اَندھے ہِن(٦٦)۔
  27,67,اَتے جِہڑے جو (حَقّ کنُوں) اِنکار کر چُکیئے ہِن، اَکھیندِن جو ڄَݙاں اَساں تے اَساݙے پِیؤ ݙاݙے مِٹّی تِھی چُکیئے ہوسُوں، کیا وَل وِی اَساں (قَبراں وِچُوں) ضرور کَڈھیے ویسُوں(٦٧)۔
  27,68,اَلبتہ تحقیق اِیہ وَعدے اِیں کنُوں پہلے وِی اَساکُوں تے اَساݙے پِیؤ ݙاݙیاں کُوں وِی ݙِتّے ویندے رِیہن، اِیہ تاں محض پہلے گُزرے ہوئے لوکاں دِیاں کَہاݨیاں ہِن(٦٨)۔
  27,69,(اَے رسول) آکھ ݙے، جو زمین تے ٹُرّو پِھرّو اَتے ݙیکھو جو گُنہگاراں دِی عاقبت کِیویں (خوار) تھئی ہے (٦٩)۔
  27,70,اَتے تُوں اُنھاں دے (حال تے) غَم نَہ کر، اَتے نہ دِل وِچ اَوکھا پِیا تِھی، اُنھاں چالاں تے، جِہڑیاں ایہ چَلدے پِیئن(٧٠)۔
  27,71,اَتے اِیہ لوک اَکھیندِن، جو ݙَساؤ جو اِیہ وَعدہ کَݙاں پُورا آ تِھیسی جیکر تُساں سَچّ آہدے وے تاں(٧١)۔
  27,72,آکھ ݙے، جو شاید اُوں شَئے دا کُجھ حِصّہ تُہاݙی کَن٘ڈ پِچُّھوں آیا کھڑا ہُووے جِیندی تُساں جَلدی پَے کریندے وے(٧٢)۔
  27,73,اَتے بیشک تیݙا رَبّ تاں لوکاں اُتے ٻَہُوں فضل کریندا رَہندے پَر اُنھاں وِچُوں ڈھیر کوئی شُکر نھیں کریندے(٧٣)۔
  27,74,اَتے بیشک تیݙا رَبّ او سَب کُجھ ڄاݨدے، جِہڑا کُجھ او اَپݨِیں دِلّ وِچ لُکیندِن، اَتے جِہڑا کُجھ او ظاہر طور تے کریندِن(٧٤)۔
  27,75,اَتے اَسمان تے زمین وِچ اَݨ ݙِٹّھی کوئی اِہجی شَئے کائے نھیں، جِہڑی جو واضح کِتاب وِچ (لِکّھی ہوئی) نَہ ہُووے(٧٥)۔
  27,76,بیشک اِیہ قرآن بَنی اِسرائیل کُوں اَکثر او ڳالھِیں ݙَسیندے جِنھاں وِچ او لُڑھ مَریندے ہِن(٧٦)۔
  27,77,اَتے بیشک اِیہ مومناں واسطے ہِدایت تے رحمت ہے(٧٧)۔
  27,78,بیشک تیݙا رَبّ انھاں وِچ آپݨیں حُکم نال فیصلہ کر ݙیسی، اَتے او ٻَہُوں زبردست تے سَب کُجھ ڄاݨݨ والا ہے(٧٨)۔
  27,79,ٻَس اَللہ اُتّے توکّل کر، بیشک تُوں کُھلّی حقیقت اُتے قائِم ہیں(٧٩)۔
  27,80,بیشک تُوں آپݨاں سَݙ (پیغام) (مُردیاں کُوں) نھیں سُݨا سَڳدا، اَتے نہ ٻُوڑیاں کُوں سُݨا سَڳدیں، جِہڑے ویلے او کَن٘ڈ وَلا تے پِچَّھاں وِی ہَٹ ویندِن(٨٠)۔
  27,81,اَتے نَہ تُوں اَندھیاں کُوں اُنھاں دِی گُمراہی وِچُوں کَڈھ تے سِدّھے رَاہ تے گِھن آسَڳسیں، اَلبتہ تُوں اُنھاں کُوں ضرور سُݨا سَڳدیں جِہڑے جو ساݙے آیاتاں اُتّے اِیمان گِھن آندِن، وَل تاں اِیہ فرمانبردار وِی تِھی ویندِن(٨١)۔
  27,82,اَتے ڄَݙاں اِیہ ڳالھ (حُجّت) اُنھاں اُتے پُوری تِھیوَݨ لڳسِی، تاں اَساں اُنھاں کِیتے زمین وِچُوں ہِک جانور کَڈھیسُوں، جِہڑا اُنھاں نال ڳالھ کریسی، کِیُوں جو او اَساݙیاں آیاتاں اُتے اِیمان نَہ گِھن آندے ہَن(٨٢)۔
  27,83,اَتے ہِک ݙین٘ہ اَساں ہَر اُمّت وِچُوں ٹولے دے ٹولے اِہجے بَندیاں دے کَٹّھے چَا کریسُوں، جِہڑے اَساݙیاں آیاتاں کُوں کُوڑا اَکھیندے ہَن، ٻَس اُنھاں دِی دَرجہ وار جماعت بندی کر ݙِتی ویسی(٨٣)۔
  27,84,اِیہ توڑِیں جو ڄَݙاں سارے آ ویسِن تاں اَللہ پُچّھسے، کیا تُساں میݙیاں آیاتاں کُوں کُوڑا نَہ آہدے ہاوے، حالانکہ تُساں اَپݨیں عِلم دے مطابق انھاں دِی حقیقت کُوں سَمجھ وِی نہ سَڳے ہاوے، تُساں اِیہ کِیتا کِیا ہَا(٨٤)۔
  27,85,اَتے اُوں (عَذاب دا) حُکم اُنھاں اُتے اُنھاں دے ظلم دِی وَجہ کنُوں پُورا تِھی تے رَہسی، اَتے او کُجھ وِی نہ آکھ سَڳسِن(٨٥)۔
  27,86,کیا اُنھاں نھیں ݙِٹَّھا جو اَساں رَات کُوں اِیں واسطے بݨائے تاں جو اِیندے وِچ سکون تے اَرام حاصل کرِن، اَتے ݙین٘ہ ݙیکھݨ بھالَݨ کِیتے ہِک سوجھلا ہے، بیشک اِیں ڳالھ وِچ نِشانیاں ہِن مومن لوکاں کِیتے(٨٦)۔
  27,87,اَتے جِہڑے ݙین٘ہ صُور پُھوکیا ویسے، ٻَس جو کُجھ اَسماناں وِچ تے زمین دے اُتّے تَلّے ہے، سارے ݙَر ویسِن، سِوائے اُنھاں دے جِنھاں کُوں اَللہ پُڄاوَݨ چَہسی، اَتے سارے عاجزی دِی حالت وِچ اُوندے کولھ لڳیے آسِن (٨٧)۔
  27,88,اَتے (اَے رسول) تُوں پَہاڑاں کُوں ݙیکھدیں تاں اِیویں لڳدِن، جِیویں جو او (آپݨیں جَاء تے) ٹھکیئے کَھڑے ہِن، پر (اُوں ݙین٘ہ) بدّلاں وانگُوں اُݙدے پِھردے وَدّے ہوسِن، اِیہ اَللہ دِی قُدرت دَا کرشمہ ہوسی، جیں ہَر شَئے کُوں ٹِھیک بݨا جُوڑ کَھڑائے، بیشک او اُوں کنُوں ٻَہُوں با خَبر ہے، جِہڑا کُجھ تُساں کریندے وَدّے ہِیوے(٨٨)۔
  27,89,جِہڑے کوئی نیکی کَما تے آسِن، تاں اُنھاں کُوں اُوں کنُوں بہتر بَدلہ ݙِتّا ویسے، اَتے اِیہ لوک (اُوں ݙین٘ہ) ہَر قِسم دے ݙَر ݙُکَّل کنُوں اَصلُوں بے خَوفے ہوسِن(٨٩)۔
  27,90,اَتے جِہڑے کوئی بُرائی کَما تے آسِن، ٻَس اُنھاں کُوں مُن٘ہ دے بَھرنے بھا وِچ سَٹ ݙِتَّا ویسے، تُہاکُوں کیا مِلسے، سِوائے اُنھاں عَملاں دِی جَزا دے، جِہڑے تُساں کریندے رِیہے ہِیوے(٩٠)۔
  27,91,بیشک میکُوں اِیں ڳالھ دا حُکم تَھئے، جو مَیں اِیں شَہر دے رَبّ دِی عِبادت کِیتی رَکّھاں، جیں اِیکُوں عِزّتاں والا بݨائے، اَتے ہَر شَئے دَا مالک وِی اُوہو ہے، اَتے اِیہ وِی حُکم تَھئے جو مَیں اُوندے فرمانبرداراں (مسلماناں) وِچُوں بَݨ تے رَہاں (٩١)۔
  27,92,اَتے اِیہ وِی جو مَیں قُرآن پَڑھ تے سُݨینداں رَہواں، جیں ہدایت پا گِھدّی تاں بیشک اُوں آپݨیں آپ کِیتے ہدایت پاتی، اَتے جِہڑا گُمراہ تِھی ڳیا، تاں آکھ ݙے جو بیشک مَیں تاں محض نصیحت کرݨ والیاں وِچُوں ہَاں(٩٢)۔
  27,93,اَتے آکھ ݙے جو ساریاں تعریفاں اَللہ کِیتے ہِن، اَجھو او تُہاکُوں آپݨیاں نِشانیاں ݙیکھیسے، وَت تُہاکُوں چَن٘ڳی طرح اُنھاں دِی سَمجھ پوسے، اَتے تیݙا رَبّ انھاں کنُوں غافِل کائے نھیں جِہڑے کَمّ تُساں کریندے وَدّے ہِیوے(٩٣)۔
