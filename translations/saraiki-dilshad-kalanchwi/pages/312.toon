quran[15{c,v,t}:
19,96,بیشک جِہڑے لوک اِیمان گِھن آئے، اَتے نیک عَمل کِیتُونے، تاں اَجّھو ٻَہُوں مہربان اَللہ اُنھاں کِیتے محبّت پَیدا کر گِھنسے (٩٦)۔
19,97,بیشک اَساں اِیں (قرآن) کُوں تیݙی زبان وِچ اَسان کر ݙِتے، تاں جو تُوں اِیندے ذریعے پرہیزگار لوکاں کُوں خوشخبری ݙیویں، اَتے جھِیڑے گَھتَّݨ والی قَوم کُوں اِیندے نال ݙَراویں (٩٧)۔
19,98,اَتے اَساں انھاں کنُوں پہلے ڈھیر قَوماں کُوں تَباہ کر چھوڑے، کیا تَیں اِنھاں وِچُوں کہیں کُوں ݙِٹّھے یا انھاں دِی کوکِڑوا سُݨی ہے (٩٨)۔
20,1,طٰہٰ (١)۔
20,2,(اَے رسول) اَساں تیݙے اُتّے قرآن اِیں واسطے نازِل نھیں کِیتا جو تُوں اَوکھا تِھیویں (٢)۔
20,3,بلکہ اِیہ اُوں شَخص کُوں نصیحت کرݨ کِیتے ہے جِہڑا جو (اَللہ کنُوں) ݙَردا وِی ہے (٣)۔
20,4,اِیہ نازِل کِیتا ڳیا ہے اُوں ہَستی دِی طرفُوں ، جَیں زمین تے اُچّے اُچّے اَسماناں کُوں بݨائے (٤)۔
20,5,او اَللہ ٻَہُوں مہربان ہے، جَیں عرش اُتے قرار پکڑیا ہوئے (٥)۔
20,6,اُوندے واسطے اِی ہے جِہڑا کُجھ اَسماناں وِچ ہے جِہڑا کُجھ زمین تے ہے، جِہڑا کُجھ انھاں ݙُوہائیں دے اَدّھ وِچ ہے، اَتے جِہڑا کُجھ اَصلُوں زمین دے تَلّے تَئیں ہے (٦)۔
20,7,اَتے جیکر تُوں زور دِی ڳالھ کریں تاں وِی بلکہ راز دِی ڳالھ وِی، اَتے لُکا تے کِیتی ہوئی ڳالھ وِی (او سَب کُجھ) ڄاݨ ویندے (٧)۔
20,8,اَللہ اِی ہے اُوندے سِوا کوئی عبادت دے ݙَا دا کائے نھیں، اُوندے کِیتے اِی ہِن، سارے سوہݨیں سوہݨیں ناں (٨)۔
20,9,اَتے تَیں کنیں مُوسیٰ دِی کوئی ڳالھ وِی آئی ہے (٩)۔
20,10,ڄَݙاں اُوں ہِک جاء بَھا ݙِٹّھی، تاں گَھر والیاں کُوں آکھیُس ، تُساں اِتھائیں کَھڑو، مَیں بِلا شَک بَھا ٻَلدی ݙِٹھی ہے، شاید مَیں تُہاݙے کِیتے اُوندے وِچُوں کوئی بَکھدا اَنڳارہ چَا آواں، یا بَھا توڑِیں دے رَاہ دَا پَتہ کر آواں (١٠)۔
20,11,ڄَݙاں او بھا کولھ پُڄیا تاں سَݙّ ماریا ڳِیا، اَے مُوسیٰ (١١)۔
20,12,مَیں تیݙا رَبّ اِی ہَاں! اَپݨیں جُتّی لَہا چا، کیُوں جو تُوں پاک مَیدان طُویٰ وِچ آیا کھڑیں (١٢)۔
