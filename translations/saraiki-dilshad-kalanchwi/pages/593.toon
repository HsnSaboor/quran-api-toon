quran[23{c,v,t}:
89,1,قَسم ہے فَجر دے وَقت دِی(١)
89,2,اَتے ݙَاہ راتِیں دِی(٢)۔
89,3,اَتے جوڑے جوڑے دِی، تے ہِک ہِک دِی(٣)
89,4,اَتے رَات دِی ڄَݙاں او ڈھلَّݨ پَے وَن٘ڄے(٤)
89,5,کیا اںھاں وِچُوں عَقلمنداں کِیتے قَسم کھاوَݨ دے لائق کوئی شَئے ہے(٥)
89,6,کیا تَیں ݙِٹّھے جو تیݙے رَبّ نے عاد نال کیا حَشر کِیتے(٦)۔
89,7,اُچّے تَھمبیاں والیاں جائیں والی اِرم دِی اَولاد نال (کیا تِھیا)(٧)
89,8,جِنھاں وانگوں سارے عِلاقیاں وِچ کوئی پَیدا نہ کِیتا ڳیا ہَا! (٨)
89,9,اَتے ثمود نال (کیا تِھیا) جِنھاں وادی وِچ پَتھراں کُوں گھڑ گھڑ تے جائیں بݨائیاں ہَن(٩)۔
89,10,اَتے میخاں دِی شہرت والے فِرعون نال وِی(١٠)
89,11,اُنھاں ساریاں، سَبھے عِلاقیاں وِچ بغاوتاں کھڑیاں کر گِھدّیاں(١١)۔
89,12,ٻَس اُنھاں اِنھاں عِلاقیاں (مُلکاں) وِچ ٻَہُوں فَساد مَچایا ہوئیا ہَا(١٢)
89,13,ٻَس تیݙے رَبّ اُنھاں اُتّے عَذاب دا ہِک چَابک وَسایا(١٣)۔
89,14,تحقیق تیݙا رَبّ تاڑ وِچ ہے(١٤)
89,15,ہر اِنسان دا تاں اِیہ حال ہے، جو ڄَݙاں اُوندا رَبّ اُوکُوں کہیں آزمائش وِچ سَٹیندے تاں اُوکُوں عِزّتاں چَا ݙیندے، تے نعمتاں چَا بَخشیندے، وَت اَکھیندے جو میݙے رَبّ میکُوں ٻَہُوں عِزّتاں چَا بَخشئِن(١٥)۔
89,16,وَت ڄَݙاں کݙائیں اُوکُوں (ٻَئی طرح دِی) اَزمائِش وِچ چَا گَھتیندے، ٻَس اُوندے رِزق کُوں اُوندے کِیتے تَنگ کر ݙیندے، تاں وَل او اَہدے جو میݙے رَبّ میکُوں ذلیل کر چھوڑے(١٦)۔
89,17,اَصل ڳالھ اِیں کائے نھیں، تُساں یتیماں نال کوئی عِزّت والا سلوک وِی نھیں کریندے(١٧)
89,18,اَتے مسکین فقیر کُوں کھاݨاں کھواوَݨ کِیتے ہِک ٻَئے کُوں کوئی ترغیب وِی نھیں ݙیندے(١٨)۔
89,19,اَتے وراثت دا مال تاں اِݙُّوں اُݙُّوں چِھک چِھک تے کَھادِی اِی رَکھدے وے(١٩)
89,20,اَتے تُساں مال نال وَدّھ وَدّھ تے محبت کریندے وے(٢٠)
89,21,کوئی ڳالھ نھیں! جِہڑے ویلے زمین بھنّ تروڑ تے کَٹ پَھٹ سَٹّی ویسی(٢١)
89,22,اَتے تیݙا رَبّ آسے اَتے فرشتیاں صَفّاں دِیاں صَفّاں ٻَدھیاں ہوئیاں ہوسن(٢٢)۔
89,23,اُوں ݙین٘ہ دَوزخ سامݨیں گِھن آئی ویسی، ٻَس اُوں ݙین٘ہ اِنسان نصیحت حاصل کرݨ چَہسی پَر (ہُݨ) نصیحت اُوکُوں کِتُّھوں فائدہ ݙیسی(٢٣)
