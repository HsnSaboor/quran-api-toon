quran[19{c,v,t}:
19,77,(اَے رسول) کیا تَیں اُوں شَخص کُوں وِی ݙِٹّھے، جِہڑا اَساݙِیاں نِشانیاں کُوں نھیں مَنیندا، اَتے اَکھیندے جو اِیہے مال متال تے آل اَولاد اِیویں ݙِتی ویندی رَہسی (٧٧)۔
19,78,کیا اُوں غیب دا پَتہ لَا گِھدّے یا ٻَہُوں رحمت والے اَللہ کنُوں کوئی وَعدہ گِھن آئے (٧٨)۔
19,79,اَصلُوں کائے نہ ! اَساں جلدی اُوکُوں لِکّھ گِھندے ہَیں، جِہڑا کُجھ او اَکھیندے، اَتے ہولے ہولے اُوندا عَذاب وَدھیندے ویندُوں (٧٩)۔
19,80,اَساݙے کولھ آ ویسِن جِہڑیاں شَئیں دے متعلّق اِیہ ڳالھِیں کریندے اَتے اَساݙے سامݨیں خالی ہَتّھ کَلھّا آ کَھڑسے (٨٠)۔
19,81,اَتے اُنھاں لوکاں اَللہ کنُوں سِوا ٻئے معبود بݨا گِھدّے ہِن، تاں جو او اُنھاں کِیتے طاقت تے وَقار وَدھاوَݨ دا باعث بݨِن (٨١)۔
19,82,اِیں نہ تِھیسی! بلکہ او انھاں دِیاں عبادتاں دَا وِی اِنکار کر ݙیسِن، اُلٹا اِنھاں دے سخت مخالف تِھی ویسِن (٨٢)۔
19,83,کیا تَیں نھیں ݙِٹّھا، جو بیشک اَساں شیطاناں کُوں کافراں اُتے لائیا ہوئیا ہے، او اُنھاں کُوں ٻَہُوں وَرغلائی رَکھیندے ہِن (٨٣)۔
19,84,ٻَس تُوں اُنھاں کِیتے (عذاب دِی) اُٻَہل نہ کَر، بیشک اَساں اُنھاں دے ݙین٘ہاڑے ڳِݨیے ہوئے ہِن (٨٤)۔
19,85,ہِک ݙین٘ہ اَساں پَرہیزگاراں کُوں ٻَہُوں مہربان اَللہ کولھ مہماناں وان٘گُوں کَٹھے کریسُوں (٨٥)۔
19,86,پَر گُنہگاراں کُوں تریہے(تسے) جانوراں وان٘گُوں دَوزخ دو ہَکّل ݙیسُوں (٨٦)۔
19,87,(کہیں کُوں) سِفارش دا اِختیار نہ ہوسی سِوائے اُوندے جَیں ٻَہُوں مہربان اَللہ کنُوں اِجازت گِھن گِھدّی ہوسی (٨٧)۔
19,88,اَتے اَہدے ہِن جو ٻَہُوں مہربان اَللہ نے (کہیں کُوں) پُتر بݨا گِھدّا ہے (٨٨)۔
19,89,تحقیق تُساں ٻَہُوں گَندی ڳالھ گھڑ تے گِھن آئیوے (٨٩)۔
19,90,ہُݨ تِھی سڳدے جو اَسمان چِریج پَڑیج پُووِن، زمین ݙلیج پِھلیج وَن٘ڄے، تے پَہاڑ تُرٹ بھڄ تے ڈھے پُووِن (٩٠)۔
19,91,اِیں ڳالھُوں جو اُنھاں ٻَہُوں مہربان اَللہ کِیتے پُتر ہُووَݨ دا دَعویٰ کِیتے (٩١)۔
19,92,پَر ہُوں مہربان اَللہ کُوں اِیہ نھیں ٹَھہندا جو او کہیں کُوں پُتر بݨاوے (٩٢)۔
19,93,اَسماناں تے زمین اُتّے اِہجا کوئی وِی نھیں جِہڑا ٻَہُوں مہربان اَللہ کولھ ٻانھاں بَݨ تے نہ آسے (٩٣)۔
19,94,تحقیق اُوں اُنھاں کُوں اَپݨِیں وَکّڑ وِچ گَھتّیا، اَتے ہِک ہِک کُوں ڳِݨ گِھدّا ہوئے (٩٤)۔
19,95,اَتے اُنھاں دا ہَر کوئی قیامت دے ݙین٘ہ کَلھم کَلّھا آ کَھڑا تِھیسے (٩٥)۔
