quran[21{c,v,t}:
100,10,اَتے جو کُجھ سینیاں وِچ ہے اُوکُوں (جان٘چَݨ پَرکھݨ کِیتے) ٻاہر کَڈھیا ویسے(١٠)
100,11,یقیناً اُنھاں دا رَبّ اُوں ݙین٘ہ اُنھاں کنُوں پُوری طرح باخبر ہوسی(١١)
101,1,او وَݙے کَڑکاٹ والی (قیامت)(١)
101,2,او وَݙے کَڑکاٹ والی کیا ہے؟(٢)۔
101,3,اَے رسول) تیکُوں کیا پَتہ جو او وَݙے کَڑکاٹ والی کیا ہے؟(٣)
101,4,اُوں ݙِین٘ہ لوک کِھن٘ڈے پُھن٘ڈے کھنبھوٹیاں (بھمبھوٹاں) وانگوں وَدّے ہوسن(٤)۔
101,5,اَتے پہاڑ تُن٘بی ہوئی رنگیل اُن وانگوں تِھی ویسِن(٥)
101,6,ٻَس جِیندی (عَملاں والی) ترکڑی دَا پَاسا بارا ہوسی(٦)
101,7,او آپݨِیں پَسند والے عیش وِچ ہوسی(٧)
101,8,اَتے جِیندی (عَملاں والی) تَرکڑی دا پاسا ہَلکا ہوسی(٨)۔
101,9,ٻَس اُوندا ٹِکاݨاں ہاویہ ہوسی(٩)۔
101,10,اَتے تیکُوں کیا پَتہ جو او کیا ہے(١٠)۔
101,11,اِیہ تاں ہِک بھڑکدی ہوئی بھا ہے(١١)۔
102,1,تُہاکُوں ڈھیر مَال مَݙی دِی ݙَاڈھی خُواہِش اَصلُوں اَندھا کر چھوڑے(١)
102,2,اِیہ توڑِیں جو تُساں قَبراں دَا مُن٘ہ وَن٘ڄ ݙیکھسُو! (٢)
102,3,کائے نھیں، اَجھو تُہاکُوں اَصل پَتہ لَڳ ویسے(٣)۔
102,4,وَل وِی اِیں کائے نھیں، اَجھو تُہاکُوں اَصل پَتہ لَڳ ویسے(٤)
102,5,اَللہ اِیویں کریندا، جو تُساں یقینی طور تے ڄاݨ گِھدّا ہُوندا(٥)۔
102,6,ضرور دَوزخ کُوں وَن٘ڄ ݙیکھسُو(٦)
102,7,وَل وِی سُݨ گِھنُّو ، تُساں ضرور یقینی طور تے اُوکُوں ݙیکھ گِھنسُو(٧)۔
102,8,وَل (اُوں ݙِین٘ہ) تُساں کنُوں نعمتاں دے متعلّق ضرور پُچھیا ڳُچّھیا ویسی(٨)
