quran[9{c,v,t}:
41,12,ٻَس اُوں سَتّے اَسمان ݙُوں ݙِین٘ہاں وِچ بݨا ݙِتے، اَتے ہر اَسمان کِیتے آپݨیں حُکم (قانون) چَلا چھوڑے، اَتے اَساں دُنیا والے اَسمان کُوں ݙِیویاں (تاریاں) نال رونق بَخشی، اَتے اُوکُوں ہَر طرح محفوظ کر چھوڑیا، اِیہ اندازے ہِن زبردست تے سَب کُجھ ڄاݨݨ والے دے! (١٢)۔
41,13,ٻَس جیکر وَت وِی اِیہ مُن٘ہ وَلا ویندِن، تاں آکھ ݙے، جو مَیں تاں تُہاکوں ہِک اِہجے اَسمانی کڑکاٹ (عذاب) کنُوں ݙرینداں چِتوینداں، جِیویں جو عاد تے ثمود اُتے تِھیا ہا (١٣)۔
41,14,ڄݙاں وِی اُنھاں دے رَسُولاں جِہڑے جو اُنھاں دے اَڳوں تے اُنھاں دے پِچُّھوں (ہَر پاسُوں) آئے ہن، آکھیا، جو کہں ٻے دِی عبادت نہ کرو، سِوائے اَللہ دے، تاں اُنھاں آکھیا، جو جیکر اَساݙا رَبّ چَہندا، تاں اَساں دو فرشتے لَہا بھیڄیندا، بہرحال جو کُجھ وِی تُہاکوں ݙے تے بھیڄیا ڳئے اَساں اُوکُوں مَنّݨ کنُوں اِنکار کریندے ہَیں (١٤)۔
41,15,ٻَس عاد دِی ڳالھ اِیہ ہے جو اُنھاں زَمین اُتے (حق دے مقابلے تے) وَݙائی شُروع کر ݙِتی، اَتے اَکھیُونے جو اَساں کنُوں طاقت وِچ زیادہ کوݨ تِھی سَڳدے، بَھلا کیا اُنھاں نھیں ݙِٹھا جو بیشک اَللہ جَیں خُود اُنھاں کُوں پَیدا کِیتے، اُنھاں کنُوں ڈھیر طاقت والا ہے، پَر او اَساݙیاں نشانیاں مَنّݨ کنُوں اِنکار کریندے رِیہے (١٥)۔
41,16,ٻَس اَساں اُنھاں اُتے اُنھاں دے کُجھ منحوس ݙین٘ہاں وِچ ٻَہُوں تیز اَندھاری بھیڄی، تاں جو اَساں اُنھاں کُوں دُنیاوی زِندگی وِچ ذلیل کر ݙیوݨ والا عذاب چَکھاؤں، اَتے آخرت دا عذاب ٻَہُوں ذلیل تے خُوار کرݨ والا ہے، اَتے اُنھاں دِی کوئی مَدد وِی نہ کِیتی ویسی (١٦)۔
41,17,اَتے ثمود (دِی ڳالھ اِیہ ہے) جو ٻَس اَساں تاں اُنھاں کُوں سِدّھا رَاہ ݙِیکھایا ہَا، پَر اُنھاں اِیں ہدایت دے مقابلے وِچ اَندّھے تِھی رَہݨ کُوں زیادہ پَسند کِیتا، ٻَس جِہڑا کُجھ او کریندے کماندے رِیہے ہن، اُوندی وَجہ کنُوں اُنھاں کُوں رُسوا کر ݙیوݨ والے اَسمانی کڑکاٹ دے عذاب آ وَلھیٹیا (١٧)۔
41,18,اَتے اَساں بَچا گِھدّا، اِیمان گِھن آوَݨ والیاں کُوں ، تے متّقی لوکاں کُوں وِی (١٨)۔
41,19,اَتے اُوں ݙین٘ہ ڄݙاں جو اَللہ دے دُشمناں کُوں (دوزخ دِی) بھا دو کَٹھا کِیتے ویسے تاں انھاں کُوں اَڳُوں تے وَدّھݨ کنُوں روکیا ویسے (١٩)۔
41,20,اِیہ توڑِیں جو سارے لوک اُوں توڑِیں پُڄ ویسِن تاں اُنھاں دے کَنّ، اُنھاں دِیاں اَکّھیں، تے اُنھاں دے چَم اُنھاں اُتے گواہی ݙیسِن جو او کیا کیا کریندے رَہ ڳئِن (٢٠)۔
