quran[3]{c,v,t}:
  103,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  103,1,قَسم ہے زَمانے دِی(١)
  103,2,بیشک اِنسان گَھاٹے وِچ ہے(٢)
  103,3,سِوائے اُنھاں لوکاں دے جِہڑے اِیمان گِھن آئِن، اَتے نیک عَمل کِیتے ہِینے، اَتے ہِک ٻئے کُوں حَقّ دِی نصیحت کریندے ریہن، اَتے ہِک ٻَئے کُوں صَبر دِی تلقین کریندے رِیہن(٣)۔
