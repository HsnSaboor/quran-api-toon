quran[30{c,v,t}:
78,1,اِیہ لوک کِہڑی شَئے دے متعلّق پُچّھدے پَئین؟(١)
78,2,اُوں ٻَہُوں وَݙِی خَبر (دے متعلّق)؟(٢)
78,3,جِیندے وِچ اُنھاں ٻَہُوں وَݙا لُڑ گَھتّیا ہوئے(٣)
78,4,اِیہ اِیویں کائے نھیں! اَجّھو اُنھاں کُوں خود پَتہ لڳ ویسی(٤)
78,5,وَل وِی اِیہ اِیویں کائے نھیں، اَجّھو اُنھاں کُوں خود پَتہ لڳ ویسے(٥)
78,6,کیا اَساں زمین کُوں وِچھاوݨاں (فَرش) نھیں بݨایا ہویا؟(٦)
78,7,اَتے پَہاڑاں کُوں اُوندے کِیتے میخاں بݨا تے ٹھوکیا ہوئے(٧)
78,8,اَتے اَساں تُہاکُوں (ذال مَرد دا) جَوڑا بݨا تے پَیدا کِیتے(٨)
78,9,اَتے اَساں نِندر کُوں تُہاݙے اَرام کِیتے بݨائے (٩)۔
78,10,اَساں رَات کُوں تُہاݙے کِیتے ہِک پَردے دِی شَئے بݨائے(١٠)
78,11,اَتے ݙِین٘ہ روزِی کَماوَݨ کِیتے بݨائے(١١)
78,12,اَتے اَساں تُہاݙے اُتّے سَتّ مضبوط اَسمان (طبق) بݨا چھوڑئِن(١٢)
78,13,اَتے اَساں ہِک اُچّا ٻَلدا گَرم ݙِیوا وِی بݨائے(١٣)
78,14,اَتے اَساں پاݨِیں نِچڑیندے بَدّلاں وِچُّوں زور دَا مِینہ نازِل کِیتے(١٤)
78,15,تاں ڄو اَساں اِیندے ذریعے اَنْ تے سَبزِیاں پَیدا کروں(١٥)
78,16,اَتے ساوے گھاٹے باغ وِی(١٦)
78,17,تحقیق فیصلے دے ݙِین٘ہ دَا ہِک وقت مُقرر ہے(١٧)۔
78,18,اُوں ݙِین٘ہ صُور وِچ پُھوکا ماریا ویسے، ٻَس تُساں ٹولیاں دِیاں ٹولیاں نِکل تے آ ویسُو(١٨)
78,19,اَتے اَسمان کُوں کھول ݙیسُوں جو او دَروازے اِی دَروازے بَݨ ویسے(١٩) ا
78,20,َتے پہاڑ اِیں طرح ہَلائے ڄُلائے ویسِن، جو ٻَس ریت اِی ریت (سَراب) بَݨ ویسِن(٢٠)
78,21,یقیناً دَوزخ اُنھاں دِی تَاڑ وِچ ہے(٢١)
78,22,کِیُوں جو اُوہا نافرمان لوکاں کِیتے ہِک ٹِکاݨاں ہے(٢٢)
78,23,جِیندے وِچ او صَدیاں دِیاں صَدیاں تَئیں رَہندے رَہسِن(٢٣)
78,24,او لوک اُوندے وِچ نہ کہیں ٹَھاݙِل دَا مَزّہ گِھن سَڳسِن، تے نہ پِیوَݨ دے ݙَا دِی کہیں اِہجی شَئے دا(٢٤)
78,25,سِوائے اُٻَلدے پاݨِیں دے، تے ٹَھڈھی وَہندی پُوں دے(٢٥)
78,26,اِیہ اُنھاں کِیتے ہِک پُورا پُورا اِنصافی بَدلہ ہے (٢٦)
78,27,یقیناً او (آخرت کُوں) کہیں حِساب دے تِھیوَݨ دِی توقّع نہ رَکھیندے ہَن(٢٧)
78,28,اَتے اَساݙیاں آیاتاں کُوں کُوڑ اِی کُوڑ آکھ ݙِتا ہَانیں(٢٨)
78,29,حالانکہ اَساں وِی ہَر شَئے کُوں لِکّھ تے محفوظ کر گِھدّا ہَا(٢٩)
78,30,ٻَس چَکُّھو مَزّہ! اَساں تُہاݙے کِیتے سِوائے عَذاب دے ٻَئی کُوئی شَئے زیادہ نہ کریسُوں(٣٠)
