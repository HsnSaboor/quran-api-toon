quran[3]{c,v,t}:
  50,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  50,1,قٓ، قَسم ہے شاناں والے قرآن دِی (١)۔
  50,2,بلکہ انھاں کُوں تاں تعجّب تَھئے، جو انھاں کولھ خود اُنھائیں وِچُوں ہِک ݙَراوَݨ چِتاوَݨ والا آڳئے ، ٻَس کُفر اِختیار کرݨ والے آکھݨ لڳئے، جو اِیہ ڳالھ تاں عجب جہی لڳدِی ہے (٢)۔
  50,3,بَھلا ڄݙاں اَساں مَر ویسُوں، اَتے مَٹی تِھی ویسُوں (وَلا جِیوا کھڑا کرݨ) تاں عقل سَمجھ کنُوں پَرے دِی ڳالھ ہے (٣)۔
  50,4,تحقیق اَساکُوں پَتہ ہے، جو اُنھاں وِچُوں دے کِتنے کُجھ زمین کھاندی گھٹیندی ویندِی ہے، اَتے اَساݙے کولھ کِتاب ہے جِیندے وِچ سَب کُجھ لِکھیا ہویا محفوظ ہے (٤)۔
  50,5,اُنھاں اُوکُوں کُوڑا آکھیئے، ڄݙاں وِی حق اُنھاں کولھ آئے، ٻَس اِیہ خود ہِک گُنجڑی ہوئی ڳالھ وِچ پَھس ڳئے ہن (٥)۔
  50,6,بَھلا اِیہ آپݨیں اُتّوں اَسمان کُوں نھیں ݙیہدے، اَساں اُوکُوں کِیویں بݨائے اَتے کِیویں سَن٘واریے، اَتے اِیندے وِچ کوئی بَج (خرابی) وِی کائے نھیں (٦)۔
  50,7,اَتے اَساں زمین کُوں دگھیریے چَا، اَتے اُوندے وِچُوں تکڑے پہاڑ کھڑے کر ݙِتے ہِن، اَتے اُوندے وِچوں ہر قسم دے سوہݨِیں پودیاں دے جوڑے ڄَمائے ہِن (٧)۔
  50,8,(اِیہ سب شَئیں) اَکّھیں کھول ݙیوݨ والیاں تے نصیحت قبول کراوݨ والیاں ہِن، پر اُوں بندے کِیتے جِہڑا اَللہ دو رجوع کریندے (٨)۔
  50,9,اَتے اَسمان کنُوں برکتاں والا پاݨِیں بھیڄے، ٻَس اُوندے نال اَساں ڄما ݙِتے ہِن، باغ تے اَن دیاں کپیڄݨ کٹیڄݨ والیاں رَڑِھیں (٩)۔
  50,10,اَتے کھڄیاں ہِن، اُچّیاں اُچّیاں اُنھاں دے گوشے تلے اُتے (پن٘ڈ نال) لَݙیے ہوئے ہِن (١٠)۔
  50,11,اِیہ بندیاں کِیتے رِزق ہِن، اَتے اَساں اِیں (پاݨِیں) نال موئی ہوئی زمین والے علاقے کُوں ساوَا (زِندہ) کر ݙیندے ہَیں، اِیں طرح (قبراں وِچُوں) بندے وِی کڈھیے ویسِن (١١)۔
  50,12,اُنھاں کنُوں پہلے وِی نُوح دِی قوم، تے کھوہ والے لوکاں، تے ثمود نے کُجھ نہ مَنّیا (١٢)۔
  50,13,اَتے عاد اَتے فرعون، اَتے لُوط دے بِھرا (١٣)۔
  50,14,اَتے جنگل (ایکہ) والے، اَتے تُبَّع دِی قوم نے وِی! ہر کہیں رسُولاں کُوں کُوڑا آکھیا، آخر (عذاب دا) وَعدہ سَچّا تِھی تے رِیہا (١٤)۔
  50,15,تاں کیا اَساں پہلی واری پَیدا کر تے تَھک ڳئے ہَیں؟ بلکہ اِیہ لوک تاں نویں سِروں دِی پَیدائش دے متعلّق وِی شَک وِچ پَئے ڳئِن (١٥)۔
  50,16,اَتے یقیناً اَساں اِنسان کُوں پَیدا کِیتے، اَتے اَساں ڄاݨدے ہَیں جو اِیندے متعلّق کیا کُجھ وسوسے اُوندے دِل وِچ پوندِن، اَتے اَساں تاں اِیندی ڳچّی دِی رگ کنُوں وِی زیادہ اِیندے کولھوں ہَیں (١٦)۔
  50,17,ڄݙاں جو اِیندے سَڄّے پاسُوں تے کھٻّے پاسُوں موجود ݙوں نوٹ کرݨ (لِکّھݨ) والے (سَب کُجھ) نوٹ کر گِھندِن (١٧)۔
  50,18,او کوئی اِہجی ڳالھ نھیں کریندا جِیندی تاڑ وِچ لِکّھݨ (نوٹ کرݨ) والے نہ لڳئے ٻیٹھے ہووِن (١٨)۔
  50,19,اَخیر موت دِی سَکرات حقیقت بݨ تے آ ڳئی، اِیہا او حالت ہے جیں کنُوں تُوں پَرے بھڄدا ہاویں (١٩)۔
  50,20,اَتے صُور (سنکھ) پُھوکیا ڳیا، تاں اُوہو عذاب دے وَعدے دا ݙین٘ہ ہوسی! (٢٠)۔
  50,21,اَتے ہر جان اِیں حالت وِچ آسی، جو اُوندے نال ہِک ہکلݨ والا وِی ہوسی، تے ہِک (اُوندے عَملاں دی) گواہی ݙیوݨ والا وِی (٢١)۔
  50,22,تُوں یقیناً اِیں کنُوں غفلت وِچ وَدّا ہاویں، ٻَس اَساں تَیں کنُوں تیݙی غفلت دا پَردہ ہَٹا ݙِتے، ٻَس اَڄ تاں تیݙی نظر ٹِھیک ٹِھیک ݙیہدِی پَئی ہے (٢٢)۔
  50,23,اَتے اُوندے نال والا اَکھیسی، اِیہ موجود میݙے کولھ (اِیندے عَملاں دا کُھلا چٹّھا! ) (٢٣)۔
  50,24,تُساں ݙوہائیں رَل تے سرکشی کرݨ والے ناشُکرے کُوں دَوزخ وِچ سَٹ ݙیوُو (٢٤)۔
  50,25,بَھلائی کرݨ کنُوں روکݨ والے کُوں ، حَد کنُوں ٹَپ وَن٘ڄݨ والے کُوں، شَک کرݨ والے کُوں (٢٥)۔
  50,26,جیں اَللہ دے نال ٻئے رَبوبݨے وِی بݨا گِھدّے ہووِن، ٻَس تُساں ݙوہائِیں کُوں سَخت عذاب وِچ گھت ݙیوُو (٢٦)۔
  50,27,اُوندا سَنگتی (شیطان) اَکھیسی اَساݙے رَبّ آ! مَیں اِیکُوں حَدُوں ٹَپ وَن٘ڄݨ والا نھیں بݨایا بلکہ اِیہ خُود اِی پَرلے دَرجے دِی گُمراہی وِچ پِیا ہویا ہَا (٢٧)۔
  50,28,اَللہ اَکھیسی، تُساں میݙے کولھ (آپس وِچ) جھیڑا نہ پَے گَھتّو! تحقیق مَیں تاں تُہاݙے کِیتے عذاب دا وَعدہ پہلے بھیڄ چُکیا ہَاں (٢٨)۔
  50,29,میݙے سامݨیں کوئی ڳالھ نھیں بَدلائی ویندی، اَتے نہ اَساں بندیاں اُتّے کوئی ظلم کرݨ والے ہَیں (٢٩)۔
  50,30,ہِک ݙین٘ہ دَوزخ کنُوں پُچّھیا ویسے، کیا تُوں بھریج رڄیج ڳئی ہیں، پَر او اَکھیسے، کیا ٻیا کُجھ وِی بَچیا ہویا ہے (٣٠)۔
  50,31,اَتے بہشت پَرہیزگاراں دے نزدیک کر ݙِتی ویسی، اَصلُوں پَرے کائے نہ ہوسی (٣١)۔
  50,32,اِیہا ہے جِیندا وَعدہ تُساں وِچُوں ہَر اُوں شخص نال کِیتا ڳِیا ہَا، جِہڑا ٻَہُوں رَجوع کرݨ والا، ہر طرح دا خیال رَکھݨ والا ہے (٣٢)۔
  50,33,جِہڑا شخص ٻَہُوں مہربان (اَللہ) کنُوں بغیر ݙِٹھیں ݙَردا رِیہے، اَتے ٻَہُوں رجوع کرݨ والا دِلّ گِھن تے آئے (٣٣)۔
  50,34,(آکھیا ویسی) اِیندے وِچ اَمن تے سَلامتی نال لَنگھ وَن٘ڄ اِیہُو ݙین٘ہاڑا ہمیشہ کِیتے قائم رَہݨ والا ہے (٣٤)۔
  50,35,اِیندے وِچ اُنھاں کِیتے جو کُجھ وِی او چَہسِن، سَب موجود ہوسی (٣٥)۔
  50,36,اَتے اَساں اُنھاں کنُوں پہلے دِیاں کئی اُمتّاں تَباہ کر چھوڑیاں، جِہڑیاں اُنھاں کنُوں طاقت وِچ وَدّھ تے ہَن اُنھاں تاں شَہراں کُوں چھاݨیا لَتاڑیا ہویا ہا، کیا کوئی جَاء تِھی سڳدِی ہے (اَللہ کنُوں) بھڄّ وَن٘ڄݨ کِیتے (٣٦)۔
  50,37,یقیناً اِیندے وِچ ہر اُوں شخص کِیتے نصیحت ہے جِہڑا سَچّا دِل رَکھیندا ہووے، یا سَب کُجھ توّجہ نال سُݨدا ہووے اَتے حقیقت کُوں خود غور نال ݙیکھدا ہووے (٣٧)۔
  50,38,اَتے اَلبتہ اَساں اَسماناں کُوں، تے زمین کُوں، اَتے جِہڑا کُجھ اُنھاں دے وِچکار ہے، سب کُجھ چِھی ݙین٘ہاں (مرحلیاں) وِچ تیار کر چھوڑیا، اَتے اَساکُوں کوئی تھکیڑا وِی اَصلُوں محسوس نہ تِھیا (٣٨)۔
  50,39,ٻَس (اَے رسول) جو کُجھ اِیہ لوک اَکھیندے وَدّے ہِن، اُوندے اُتّے صبر کر ڳیا کر، اَتے اَللہ دِی تعریف سمیت اُوندے پاک ہُووَݨ کُوں بیان کِیتی رَکھ (٣٩)۔
  50,40,اَتے سَجدے کرݨ (نمازاں پَڑھݨ) دے بعد وِی (٤٠)۔
  50,41,اَتے سُݨاہے، جِہڑے ݙین٘ہ سَݙ مارݨ والا کولھُوں دِی جَاء کنُوں سَݙ مَریسی (٤١)۔
  50,42,جِہڑے ݙین٘ہ سارے لوک یقینی طور ہِک اُچّی کڑکاٹ سُݨسِن اِیہ (قَبراں وِچُوں) نِکلݨ دا ݙین٘ہ ہوسی (٤٢)۔
  50,43,دَراَصل اَساں جِیویندے وِی ہَیں، تے اَساں مَریندے وی ہَیں اَتے اَساں دو ساریاں وَل آوݨیں (٤٣)۔
  50,44,اُوں ݙین٘ہ زمین اُنھاں (مُردیاں) دے اُتّے چریج ویسی، تے او جَلدی نکل تے آویسِن، اِیں طرح (بندیاں کُوں) کَٹّھا کرݨ اَساݙے کِیتے ٻَہُوں سَوکھا کَمّ ہے (٤٤)۔
  50,45,اَساں چَن٘ڳی طرح ڄاݨدے ہَیں جِہڑا کُجھ اِیہ لوک اَہدے وَدّے ہِن، اَتے تُوں انھاں اُتے جَبر کرݨ کِیتے نھیں لایا ڳیا، ٻَس تُوں قرآن دے ذریعے اُوں شخص کُوں نصیحت کر جِہڑا جو میݙے (عذاب) کنُوں ݙراوَݨ نال ݙر ویندے (٤٥)۔
