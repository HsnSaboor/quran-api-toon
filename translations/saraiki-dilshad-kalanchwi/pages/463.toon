quran[7{c,v,t}:
39,41,بیشک اَساں لوکاں کِیتے تیݙے اُتے حقّی طور تے کِتاب نازِل کِیتی ہے ٻَس جِہڑا ہدایت حاصل کریندے، او اُوندے آپݨیں بَھلے کِیتے ہے، اَتے جِہڑا گُمراہ تِھی ویندے، ٻَس اُوندی گُمراہی دِی شامت اُوندے اُتے ہے اَتے تُوں انھاں اُتے کوئی دَاروغہ نھیں لڳیا ہویا (٤١)۔
39,42,اَللہ اِی ہے جِہڑا انھاں دے مَرݨ دے وقت رُوحاں کُوں قَبض کر گِھندے، جِہڑیاں جاناں نھیں مرݨاں ہوندا اُنھاں کُوں نِندر وِچ قبض کر گِھندے، جیندے کیتے موت دا حکم ہوندے انہاں دیاں رُوحاں کوں آپݨے کول روک گھندے، اَتے ٻِنھاں جاناں کُوں ہِک مقرر وقت تَئیں واپس (جاناں وِچ) بھیڄ ݙیندے، بیشک اِیندے وِچ اُوں قوم کِیتے نِشانیاں ہِن، جِہڑی جو غور تے فِکر کریندی ہے (٤٢)۔
39,43,کیا انھاں اَللہ کُوں چھوڑ تے ٻِنھاں کُوں آپݨاں سِفارشی بݨا گِھدّے، (اَے رسول) آکھ ݙے او تاں خود کہیں شَئے تے کوئی اختیار وِی نھیں رَکھیندے، اَتے نہ عَقل رَکھیندِن (٤٣)۔
39,44,آکھ ݙے جو ساری شفاعت تاں اَللہ دے کولھ ہے، بلکہ اُوندے کِیتے ہے اَسماناں تے زمین دِی بادشاہی ! وَل تُساں اُوں دو وَلائے وِی ویسو (٤٤)۔
39,45,اَتے ڄݙَاں ہِک دے ہِک اَللہ دا ذِکر کِیتا ویندے، تاں اُنھاں لوکاں دے دِلّ کُڑھدِن، جِہڑے آخرت اُتے اِیمان وِی نھیں گِھن آندے، اَتے ڄݙاں اُوں کنُوں عَلاوہ ٻِنھاں دا ناں گِھدّا وَن٘ڄے تاں وَل ݙیکھو تاں سَہی کیویں خُوش تِھی ویندِن (٤٥)۔
39,46,آکھ، جو اَے میݙے اَللہ! اَسماناں تے زمین کُوں پَیدا کرݨ والے ! غیب کُوں تے ظاہر کُوں ڄاݨݨ والے ! تُوں اِی آپݨیاں بَندیاں وِچ اُنھاں ڳالھیں دا فیصلہ کر ݙیسیں، جیندے وِچ او اِختلاف کریندے رَہندِن (٤٦)۔
39,47,اَتے جِنھاں لوکاں ظلم کِیتے اُنھاں کِیتے توڑے او سارا کُجھ ہووِے جِہڑا کُجھ زمین دے تَلّے اُتّے ہے، بلکہ اُوندے نال اِیہُو جتّی ٻِیا وِی ہووے، تاں وِی اِیندے عوض اِیہ لوک قیامت دے ݙین٘ہ دے گندے عذاب کنُوں خود کُوں نھیں چُھڑا سَڳدے، اُنھاں اُتے اَللہ دِی طرفوں او سَب کُجھ ظاہر کر ݙِتا ویسے، جیندا اُنھاں کُوں گُمان وِی کݙائیں نہ تِھیا ہوسے (٤٧)۔
