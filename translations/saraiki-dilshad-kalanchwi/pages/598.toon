quran[12{c,v,t}:
97,1,یقیناً اَساں اِیں قرآن کُوں وَݙیاں قَدراں والی رات کُوں نازِل کِیتے(١)
97,2,اَتے تیکُوں پَتہ ہے جو اِیہ وَݙیاں قَدراں والی رَات کیا ہے؟(٢)۔
97,3,وَݙیاں قَدراں والی رات تاں ہَزار مہینیاں کنُوں وِی ٻَہُوں وَدھائی ہے(٣)۔
97,4,اِیندے وِچّ فرشتے اَتے رُوح (جِبریل) ہَر کَم کِیتے آپݨیں رَبّ دے حُکم نال نازِل تِھیندِن(٤)
97,5,اِیں رات) سَلامتی اِی سَلامتی ہے، او توڑِیں جو وَݙا ویلا تِھی ویندے(٥)۔
98,1,اِہلِ کتاب وِچُوں تے مشرکاں وِچُوں جِنھاں کُفر اِختیار کِیتا، او ہَرگز باز رَہݨ والے نَہ ہَن، ڄے توڑِیں جو اُنھاں کولھ ہِک کُھلّی دلیل نہ آویندی(١)
98,2,یعنی) اَللہ دِی طرفُوں ہِک رسول، جِہڑا اِہجے پاک صحیفے پَڑھ تے سُݨیندے(٢)
98,3,جِنھاں وِچ ہمیشہ قائم رَہݨ والے دُرست احکام دَرج ہِن(٣)
98,4,اَتے لوک فِرقے فِرقے بَݨ ڳئے، جِنھاں کُوں کِتاب ݙِتی ڳئی او وِی اِیندے بعد جو اُنھاں کولھ کُھلّی دلیل وِی آچُکی ہَئی(٤)
98,5,اَتے اُنھاں کُوں ٻِیا کوئی حُکم نہ ݙِتا ڳیا، سِوائے اِیندے جو اَللہ دِی عبادت کِیتی کرِن او وِی آپݨیں دِین کُوں اُوندے کِیتے خالص کر تے محض ہُوندے خاص تِھی تے، اَتے نماز قائم رَکِّھن، زکوٰۃ ݙِتّی رَکِّھن، اَتے اِیہُو ٻَہُوں صحیح دِین (نِظام زندگی) ہے(٥)
98,6,تحقیق جِنھاں لوکاں اِہلِ کِتاب وِچُوں تے مُشرکاں وِچُوں تِھی تے وِی کُفر اِختیار کِیتے او دَوزخ دِی بھا وِچ ویسِن، ہمیشہ اُوندے وِچ رَہسِن، ٻَہسِن، اِیہے لوک بَد ترین خلقت ہِن(٦)
98,7,تحقیق جِہڑے لوک اِیمان گِھن آئِن، نیک عَمل کِیتے ہِینے اِیہے لوک بہترین خَلقت ہِن(٧)
