quran[3]{c,v,t}:
  54,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  54,1,(قیامت دِی) گَھڑی کولھُوں آڳئی ہے، اَتے چَندر ݙُوں ٹوٹے تِھی ڳئے (١)۔
  54,2,اَتے جیکر کوئی نِشان ݙیکھدِن، تاں مُن٘ہ پھیر گِھندِن، اَتے اَکھیندِن جو اِیہ تاں جادُو ہے، جِہڑا پہلے کنُوں تِھیندا آئے (٢)۔
  54,3,اَتے اِنھاں (حقیقت کُوں) کُوڑا آکھیئے، اَتے آپݨیاں خواہشاں دے پِچُّھوں لڳ پِئین، پَر ہَر معاملے دا ہِک وَقت مقرر ہے(٣)۔
  54,4,اَتے یقیناً انھاں کولھ اِہجیاں خَبراں آ چُکئِن جِنھاں وِچ کافی عِبرت دَا سامان ہے (٤)۔
  54,5,اَتے آپݨاں نتیجہ ݙیکھاوَݨ والی حِکمت (دانائی) وِی ہے، پَر ݙَراوَݨ والے اُنھاں اُتے کوئی اَثر نھیں سَٹ سڳیئے (٥)۔
  54,6,(اَے رسول) تُوں اُنھاں کنُوں مُن٘ہ پھیر گِھن، ہِک ݙین٘ہ سَݙّݨ والا ہِک دَرد ناک اَݨ ݙِٹّھی شَئے دو سَݙیسی (٦)۔
  54,7,انھاں دِیاں نظراں تَلّے جُھکّیاں ہوئیاں ہوسِن، او قَبراں وِچُوں اِیویں نِکل آسِن، جِیویں جو او کِھن٘ڈیاں پُھن٘ڈِیاں مکڑیاں ہووِن (٧)۔
  54,8,سَݙݨ والے دو بَھڄدے (ویندے ہوسِن) خود اِیکُوں نہ مَنّݨ والے اَکھیسِن اِیہ تاں کوئی ٻَہُوں سَخت ݙین٘ہ آڳئے (٨)۔
  54,9,اِنھاں کنُوں پہلے نُوح دِی قوم وِی کُوڑ آکھ چُکی ہَئی، ٻَس اُنھاں اَساݙے بَندے کُوں وِی کُوڑا آکھیا، اَتے اُوکُوں دِیوانہ سَݙیا، تے ݙَرا ݙرُو تے بھڄا کڈھیا (٩)۔
  54,10,ٻَس اُوں آپݨیں رَبّ کنُوں دُعا مَنگی، جو انھاں تاں میکُوں اَصلُوں ݙَہا چھوڑیے ، ٻَس انھاں کنُوں میݙا بَدلہ گِھن (١٠)۔
  54,11,ٻَس اَساں اَسمان دے دروازے زور دے وَسَݨ والے مِینہ کِیتے کھول ݙِتے (١١)۔
  54,12,اَتے اَساں زمین وِچُوں چَشمیں وَہا کڈھیے، وَل اِیہ (ݙُوہیں) پاݨِیں ہِک اِہجے معاملے کِیتے کَٹھے تِھی ڳئے، جِہڑا پہلے کنُوں مُقدر بَݨ چُکیا ہَا (١٢)۔
  54,13,اَتے اَساں تختاں تے میخاں والی (ٻیڑی) اُتے اُوکُوں سوار کر چھوڑیا (١٣)۔
  54,14,جِہڑی اَساݙیاں اَکّھیں دے اَڳُوں ٹِھلدی َتردی رَہی ، اِیہ ہَا اُوں ڳالھ دا اِنتقام جیکُوں اُنھاں نہ مَنیا ہَا (١٤)۔
  54,15,اَتے اَساں اِیکُوں ہِک (عِبرت دِی) نِشانی بݨا چھوڑیا ٻس ہے کوئی نصیحت حاصل کرݨ والا (١٥)۔
  54,16,ݙیکھ گِھنّو! کِیویں رِیہا میݙا عَذاب تے میݙا ݙراوا (١٦)۔
  54,17,اَتے یقیناً اَساں قرآن کُوں نصیحت دِی خاطر ٻَہُوں سَوکھا بݨائے! وَل کیا کوئی ہے نصیحت حاصل کرݨ والا (١٧)۔
  54,18,عاد نے وِی حَق کُوں کُوڑا آکھیا، ݙیکھ گِھنّو کِیویں رِیہا میݙا عذاب تے میݙا ݙَراوا (١٨)۔
  54,19,دَراَصل اَساں اُنھاں اُتّے لَگا تار نحوست والے ݙین٘ہ زور دِی اَندھاری گھولی (١٩)۔
  54,20,او لوکاں کُوں چَا چَا تے اِیں طرح سَٹ گَھتیندی ہَئی، جِیویں جو او کَھڄّی دے اُکھڑے ہوئے مُنڈھ ہووِن (٢٠)۔
  54,21,ݙیکھ گِھنّو ، کِیویں رِیہا میݙا عَذاب تے میݙا ݙَراوا (٢١)۔
  54,22,اَتے تحقیق اَساں قرآن کُوں نصیحت حاصل کرݨ دِی خاطر سَوکھا بݨائے وَل کیا کوئی ہے نصیحت حاصل کرݨ والا (٢٢)۔
  54,23,ثمود (دِی قوم) وِی ݙَراوَݨ چِتاوَݨ والیاں کُوں کُوڑا آکھیا(٢٣)۔
  54,24,بلکہ اُنھاں آکھیا، جو کیا جِہڑا شَخص اَساݙے وِچُوں ہِک کَلّھا بَشر ہے، اُوندی پَیروی کروں، اِیں طرح تاں اَساں اَلبتہ ہِک گُمراہی وِچ ہوسُوں، تے ڳالھے تَھئے وَدّے ہوسُوں (٢٤)۔
  54,25,کیا اِیہ نصیحت اَساݙے وِچُوں محض اِیندے کولھ بھیڄی ڳئی ہے بلکہ اِیہ تاں وَݙا کُوڑا تے آکَڑ باز ہے (٢٥)۔
  54,26,اَڄُھو کل کُوں ڄاݨ گِھنسِن، جو کوݨ وَݙا کُوڑا اَتے آکَڑ باز ہے (٢٦)۔
  54,27,یقیناً اَساں اُنھاں دِی اَزمائش (فِتنے) کِیتے ہِک ݙاچی بھڄیندے پَے ہَیں، ٻَس تُوں اُنھاں کُوں ݙیکھدا رہ اَتے صبر نال کَم گِھن (٢٧)۔
  54,28,اَتے اُنھاں کُوں ݙَسا ݙے جو اُنھاں دے درمیان (پاݨِیں) وَن٘ڈا ݙِتا ویندے ، ہر کوئی آپݨیں پیوَݨ دِی واری تے آندا رَہسی (٢٨)۔
  54,29,ٻَس اُنھاں آپݨیں سَنگتی (سردار) کُوں سَݙیا، جیں اُوکُوں زبردستی پَکڑیا، وَل اُوندیاں خُچّاں کَپ چھوڑیاں (٢٩)۔
  54,30,ݙیکھ گِھنّو، جو کِہجا (خوفناک) رِیہا میݙا عَذاب تے میݙا ݙَراوا (٣٠)۔
  54,31,تحقیق اَساں اُنھاں اُتے ہِکّو سَخٹ کڑکاٹ (دھماکے) وَالا عَذاب بھیڄیا، ٻَس او ڳہائے ہوئے بُھوں وانگیں تِھی ڳئے (٣١)۔
  54,32,اَتے یقیناً اَساں قرآن کُوں نصیحت دِی خاطر آسان بݨائے، ٻَس ہے کوئی نصیحت حاصل کرݨ والا (٣٢)۔
  54,33,لُوط دِی قوم وِی ݙَراوݨ چِتاوَݨ والیاں کُوں کُوڑا آکھیا (٣٣)۔
  54,34,اَساں اُنھاں اُتے پَتھراں دا مِینہ چَا بھیڄیا، سِوائے لُوط والیاں دے اَساں اُنھاں کُوں دَھمّی ویلے بَچا گِھدّا (٣٤)۔
  54,35,اِیہ اَساݙی طرفُوں فضل (نعمت) ہَئی، اِیں طرح اَساں جَزا ݙیندے ہَیں جِہڑا کوئی وِی شُکر کریندا رَہندے (٣٥)۔
  54,36,اَتے تحقیق اُوں اُنھاں کُوں اَساݙی پَکڑ کنُوں ݙَرایا وِی ہَا، پَر او ݙراوَݨ والیاں نال شَک دے ماروں، لڑیے جَھڳڑیے (٣٦)۔
  54,37,اَتے تحقیق اُنھاں (لُوط نال) اَپݨیں مہماناں کُوں ݙے ݙیوَݨ دا ݙَاڈھا تَقاضا کِیتا، ٻَس اَساں وِی اُنھاں دِیاں اَکّھیں مِٹا چھوڑیُوسے، ہُݨ میݙے عَذاب دا، تے میݙے ݙراوے دا مَزہ چَکّھو (٣٧)۔
  54,38,اَتے اُنھاں اُتے وَݙے ویلھے (صبح سویرے) ہِی شدید عذاب آ پُڄیا (٣٨)۔
  54,39,ہُݨ میݙے عذاب دا، تے میݙے ݙراوے دَا مَزہ چَکُّھو(٣٩)۔
  54,40,اَتے تحقیق اَساں قرآن کُوں نصیحت دِی خاطر ہِک سَوکھا ذریعہ بݨائے، ٻَس ہے کوئی نصیحت گِھنݨ والا (٤٠)۔
  54,41,اَتے یقیناً فِرعون والیاں لوکاں کولھ وِی ݙَراوَݨ والے (رسول) آئے ہَن (٤١)۔
  54,42,اُنھاں اَساݙیاں نِشانیاں کُوں کُوڑا آکھیا، ٻَس اَساں اُنھاں کُوں ہِک ٻَہُوں زَبردست تے پُوری قُدرت رَکھݨ والے دِی پَکڑ والی پَکڑ وِچ گِھن گِھدّا (٤٢)۔
  54,43,کیا تُہاݙے کافِر لوک انھاں ساریاں کنُوں چَن٘ڳے ہِن، یا تُہاݙے کِیتے اَسمانی کِتاباں وِچ کوئی خلاصی (بَرّیت) لِکھ ݙِتی ڳئی ہے (٤٣)۔
  54,44,کیا او اِیہُو سَمجھدِن جو اَساں تاں ہِک بَدلہ گِھن سَڳݨ والی تَکڑی جماعت ہِیسے (٤٤)۔
  54,45,اَجھو اِیں جماعت کُوں شِکست ݙِتی ویسی، اَتے او کَن٘ڈ وَلا تے بَھڄ ویسِن (٤٥)۔
  54,46,بلکہ او (قیامت دِی) گَھڑی تاں انھاں کِیتے اَصل وَعدے والا وَقت ہے، تے اِیہ گَھڑی ٻَہُوں سَخت ہے، اَتے ٻَہُوں کَوڑی ہے (٤٦)۔
  54,47,بیشک گَنہگار لوک ٻَہُوں گُمراہی وِچ ہِن، تے وِٻلے وَدّے ہِن (٤٧)۔
  54,48,اُوں ݙین٘ہ اِیہ آپݨیاں مُونھاں دے بَھر گِھیل تے بھا وِچ سٹیے ویسِن، (آکھیا ویسی) ہُݨ چَکّھو دَوزَخ دے سیک دا مَزّہ (٤٨)۔
  54,49,یقیناً اَساں ہَر شَئے کُوں ہِک مُقرر اندازے دے مطابق پَیدا کِیتے (٤٩)۔
  54,50,اَتے اَساݙا حُکم ہِکّے وقت پُورا تِھی ویندے، اَکّھ جھمکَݨ وِچ (٥٠)۔
  54,51,اَتے تحقیق اَساں تُہاݙے وانگوں دِیاں کئی ٹولیاں کُوں بَرباد کر چُکئیے ہَیں ٻَس ہے کوئی نصیحت گِھنّݨ والا (٥١)۔
  54,52,اَتے ہر ہِک کَمّ جِہڑا جو اُنھاں کِیتے، اَسمانی کتاباں (اعمال نامیاں) وِچ َدرج ہے(٥٢)۔
  54,53,اَتے ہَر چھوٹی وَݙی شَئے (اُوندے وِچ) لِکّھی ہوئی ہے (٥٣)۔
  54,54,بیشک پَرہیزگار لوک بَہشتی باغاں وِچ تے بَہشتی نَہریں اُتّے رَہسِن (٥٤)۔
  54,55,او سَچّی عِزّت والی جاء تے، وَݙیاں قدرتاں والے بادشاہ دے کولھ ہوسِن (٥٥)۔
