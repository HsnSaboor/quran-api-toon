quran[7{c,v,t}:
6,53,اَتے اِیں طرح اَساں بعض لوکاں دِی اَزمائش ٻِنھاں لوکاں نال کیتی رَکھی تاں جو او آکھ سڳِن، جو کیا اَساں وِچوں اِیہے (غریب) لبھے نِس جِنھاں تے اَللہ فضل تے کَرم کِیتے بَھلا ݙسو اَللہ شکر کرݨ والیاں کُوں چَن٘ڳی طرح نھیں ڄاݨدا کھڑا (٥٣)۔
6,54,اَتے ڄَݙاں تیݙے کولھ اِہجے لوک آوِن جِہڑے اَساݙیاں آیاتاں کُوں مَنیندِن تاں اُنھاں کُوں آکھ جو تُہاݙے اُتے سلامتی ہووے، تُہاݙے رَبّ نے آپݨِیں طرفوں رحم و کرم کرݨ لازِم کر گِھدے، جیکر تُہاݙے وِچوں کوئی نادانی دِی وَجہ کنُوں کوئی بُرا کَم کر ٻَہے تے اُوندے بعد تَوبہ چا کرے، اَتے سُدّھِر وَن٘ڄے تاں اَللہ تاں بخشݨ ہار تے ٻَہُوں رحم والا ہے (٥٤)۔
6,55,اَتے اِیں طرح مَیں آپݨِیاں نشانیاں کھول کھول تے ݙسینداں، تاں جو گُنہگاراں دِی ہر (چال) دَا وِی صاف صاف پَتہ لڳ وَن٘ڄے (٥٥)۔
6,56,آکھ ݙے، جو میکوں ہَٹکیا ڳئے جو مَیں انھاں دِی عبادت نہ کراں، جِنھاں کُوں تُساں اَللہ دے سِوا (مدد کِیتے) سݙیندے وے، آکھ ݙے مَیں، تُہاݙیاں بیہودہ خواہشاں اُتے نھیں چَل سڳدا، نہ تاں مَیں ضرور گُنہگار تِھی ویساں، تے وَل مَیں ہدایت پاوݨ والیاں لوکاں وِچوں وِی نہ ڳِݨیا وَن٘ڄ سَڳساں (٥٦)۔
6,57,(اَے رسول) آکھ ݙے، جو مَیں آپݨیں رَبّ دِی طرفوں (بھیڄی ہوئی) ہِک روشن دَلیل اُتے قائِم ہاں، پَر تُساں اُوکوں کُوڑ آکھی رَکھدے وے، میݙے اِختیار وِچ او شَئے کائے نھیں جِیندے کِیتے تُساں ٻَہُوں اُٻٰہلے وے، کہیں وِی حُکم کرݨ دا پُورا اختیار تاں اَللہ کولھ ہے او تاں حقّی ڳالھ کوں بیان کریندے اَتے اُوہُو ساریاں کنُوں وَدھ فیصلے کرݨ والا ہے (٥٧)۔
6,58,(اِیہ وِی) آکھ ݙے جو تُساں جِہڑی شَئے کِیتے اُٻٰہلے وے، او میݙے وَس وِچ ہوندی تاں تُہاݙے تے میݙے درمیان (کݙاں دا) فیصلہ تِھی ڳیا ہووِے ہا، اَتے اَللہ ظالماں کُوں چن٘ڳی طرح ڄاݨدا کھڑے (٥٨)۔
6,59,اَتے اُوندے کولھ وِی غیب دِیاں کُنجیاں ہِن، جِنھاں (دے خزانیاں) کُوں اُوندے سِوا کوئی نھیں ڄاݨدا، اَتے او تاں جوکُجھ خشکی تے ہے، تے جوکُجھ پاݨیں وِچ ہے خوب ڄاݨدا کھڑے، اَتے کوئی پَتر اِیویں کائے نھیں ڈہن٘دا جیندا اُوکوں پَتہ نہ ہووے، اَتے نہ کوئی اِہجا داݨاں زمین دِیاں اُوڑاں (اَندھاریاں) وِچ ہوندے، اَتے نہ کوئی اِہجی سِنّی یا سُکّی شَئے ہے، جِہڑی اُوندی ہِک روشن کتاب وِچ دَرج نہ ہوسے (٥٩)۔
