quran[3]{c,v,t}:
  81,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  81,1,ڄَݙاں سِڄّھ کُوں وَلھیٹ گِھدّا ویسی(١)
  81,2,ڄَݙاں تارے پِھکّے پَے ویسِن(٢)
  81,3,اَتے پَہاڑ ہَلائے ٹُرائے ویسِن(٣)۔
  81,4,اَتے ڄَݙاں آپݨیاں ݙَاہ مہیناں دِیاں ڳَبھݨ ݙاچِیاں دَا وِی دھیان نہ رَہسی(٤)
  81,5,اَتے وحشی ڈھان٘ڈیاں (جانوراں) کُوں کَٹَّھا کر گِھدّا ویسے(٥)
  81,6,اَتے سمندر اُٻَلݨ پَے ویسِن(٦)
  81,7,اَتے ڄَݙاں رُوحاں جاناں نال جوڑ ݙِتِّیاں ویسِن(٧)
  81,8,اَتے جِیندا جِیندا دَفنا ݙیوݨ والی دِھی کنُوں پُچّھیا ویسے(٨)
  81,9,جو اُوکُوں کِہڑے جُرم وِچ قَتل کِیتا ڳیا ہَا(٩)
  81,10,اَتے جِہڑے ویلے اَعمال نامے کھول تے رَکّھ ݙِتّے ویسِن! (١٠)
  81,11,اَتے اَسمان دِی کَھلّ لَہا گِھدّی ویسی(١١)
  81,12,اَتے دَوزخ دِی بھا کُوں بَھڑکا ݙِتا ویسی(١٢)
  81,13,اَتے جِہڑے ویلے بہشت کُوں کُولھُوں گِھن آیا ویسی! (١٣)۔
  81,14,تاں ہَر نفس (بَندہ) ڄاݨ گِھنسی جو او کِیا گِھن تے پیش آ تھئے(١٤)
  81,15,ٻَس وَت میکُوں قَسم ہے، پِچُّھوں تِھی وَن٘ڄݨ تے لَہ وَن٘ڄݨ والیاں تاریاں دِی(١٥)
  81,16,سِدّھے رَاہ تے چَلݨ والیاں دِی ٻُݙ وَن٘ڄݨ والیاں دِی(١٦)
  81,17,اَتے رَات دِی، جِہڑے ویلے او ویندی پَئی ہُوندی ہے(١٧)
  81,18,اَتے صبح دِی جِہڑے ویلے او سَاہ گِھنَّݨ شروع کر ݙیندی ہے(١٨)
  81,19,بیشک اِیہ ہِک عِزّتاں والے رسول دا آکھݨ (قَول) ہے(١٩)
  81,20,اَتے او طاقتاں والا ہے، عَرش والے دے کولھُوں دے رُتبے والا ہے(٢٠)
  81,21,اُوندا آکھیا مَنّیا ویندے، وَل او اَمانتدار وِی ہے(٢١)
  81,22,ٻَس تُہاݙا سَنگتی (سَردار) پاڳل اَملک کائے نھیں(٢٢)۔
  81,23,اَتے تحقیق اُوں اُوکُوں اُوں روشن جاء تے ݙِٹّھے ، جِتَّھاں اَسمان زمین مِلدے نظردِن(٢٣)
  81,24,اَتے او لُکیاں ڳالھِیں ݙَسَّݨ وِچ کنجوسی وِی نھیں کریندا(٢٤)۔
  81,25,اَتے اِیہ قول (آکھݨ) کہیں شیطان مَردود دَا اَصلُوں کائے نھیں(٢٥)
  81,26,وَت تُساں کِݙے لنگھیے ویندے وے(٢٦)
  81,27,اِیہ تاں ہِک عَام نصیحت ہے سارے جہاناں کِیتے ہے(٢٧)
  81,28,تُہاݙے وِچُوں اُوندے کِیتے ہے جِہڑا وِی سِدّھے رَاہ تے چَلݨ چَہندے(٢٨)
  81,29,اَتے تُہاݙے چَہوݨ نال کُجھ نھیں تِھی سَڳدا، سِوائے اُوں شَئے دے جِیکُوں ساریاں جہاناں دا پَالݨ والا اَللہ چَہوے(٢٩)۔
