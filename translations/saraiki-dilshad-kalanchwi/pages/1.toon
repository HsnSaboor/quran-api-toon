quran[3]{c,v,t}:
  1,1,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  1,2,خاص تعریف تاں اللہ کِیتے ہے، جِہڑا ساریاں جہاناں کُوں پالَݨ والا ہے (١)
  1,3,جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے (٢)
  1,4,قیامت دے ݙین٘ہ دا مالک ہے (٣)
  1,5,اَساں تیݙی ای عبادت کرین٘دے ہیں اَتے تَیں کنُوں اِی مَدد منگدے ہیں (٤)
  1,6,اَساکوں سِدھا رَستہ ݙِکھا(٥)
  1,7,رَستہ اُنھاں لوکاں دا جِنہاں اُتے تَیں آپݨیاں نعمتاں بھیڄِن (٦) نہ کہ جِنھاں اُتے تیݙا غضب رِیہے، اَتے نہ کہ جِہڑے گُمراہ ہِن(٧)
