quran[26{c,v,t}:
56,51,وَل یقیناً اَے گُمراہ لوکو! کُوڑ آکھݨ والو (٥١)۔
56,52,تُساں واقعی تھوہر دے وَݨ وِچُوں کَھاسُو (٥٢)۔
56,53,ٻَس اِیندے نال اَپݨیں ڈھڈھ بَھریسو (٥٣)۔
56,54,وَت اِیندے اُتُّوں، ٻَڑکدا پاݨِیں پِیسو (٥٤)۔
56,55,ٻَس پِیسو وِی تاں اِیویں پِیسو جِیویں ہَر دَم تریہے رَہݨ والے اُٹّھ پِیندِن (٥٥)۔
56,56,جَزا (بدلے) والے ݙین٘ہ اِیہا اُنھاں کِیتے مہمانی ہوسی (٥٦)۔
56,57,اَساں اِی تُہاکُوں پَیدا کِیتے، وَت تُساں سَچّ کُوں سَچّ کِیُوں نھیں مَنیندے (٥٧)۔
56,58,کیا بَھلا تُساں کݙائیں سوچے جو جِہڑا تریڑا تُساں پیٹ (رحم) وِچ گَھتیندے وے (٥٨)۔
56,59,کیا تُساں (اُوندے وِچُوں ٻال) پَیدا کریندے وے، یا اَساں پَیدا کرݨ والے ہَیں (٥٩)۔
56,60,اَساں تُہاݙی مَوت مقرر کِیتی ہوئی ہے، اَتے اَساں اَصلُوں عاجز نِسّے تِھی سَڳدے (٦٠)۔
56,61,جو اَساں تُہاݙے بدلے ٻئے لوک گِھن آؤں اَتے تُہاکُوں اِیں طرح کر چھوڑوں جو تُہاکُوں پَتہ وِی نہ لَڳے (٦١)۔
56,62,اَتے تُساں پہلے والی پَیدائش کُوں تاں چَن٘ڳی طرح ڄاݨدے ہِیوے، وَل تُساں نصیحت کیُوں نھیں حاصل کریندے (٦٢)۔
56,63,کیا تُساں کݙائیں اِیکُوں وِی سوچئیے، جو جِہڑا بِج تُساں وَہیندے وے (٦٣)۔
56,64,کیا تُساں اُوکُوں ڄَمیندے ہِیوے، یا اَساں اُوکُوں ڄَمیندے ہَیں (٦٤)۔
56,65,جیکر اَساں چَہوُوں تاں اُوکُوں کُٹا (بُھوں ٻکّل) کر چھوڑوں، تُساں تاں ٻَس کئی کئی ڳالھیں بݨیندے رَہ ون٘ڄو (٦٥)۔
56,66,جو بیشک اَساکُوں تاں چٹّی پَے ڳئی ہے (٦٦)۔
56,67,بلکہ اَساں تاں اَصلُوں محروم کر ݙِتے ڳئے ہَیں (٦٧)۔
56,68,بَھلا تُساں اُوں پاݨِیں کُوں غور نال ݙِٹّھے، جیکُوں تُساں پِیندے ہِیوے (٦٨)۔
56,69,کیا تُساں اُوکُوں بدلاں وِچُوں تَلّے لَہیندے وے، یا اَساں اُوکُوں وَسیندے ہَیں (٦٩)۔
56,70,جیکر اَساں چَہوُوں تاں اِیکُوں اَصلُوں کُوڑا بݨا چھوڑوں، ٻَس تُساں شُکر کِیوں نھیں اَدا کریندے (٧٠)۔
56,71,بَھلا تُساں اُوں بَھا کُوں غور نال ݙِٹّھے ، جیکُوں تُساں ٻَلیندے رَہندے وے (٧١)۔
56,72,کیا اُوندے ٻالݨ والے وَݨ تُساں پَیدا کِیتے ہِن یا اَساں اُنھاں کُوں پَیدا کرݨ والے ہَیں (٧٢)۔
56,73,اَساں اِیکُوں نصیحت (یادگیری) دے طور تے بݨا چھوڑے اَتے بُھکیاں، ضرورت مَنداں، دے ورتݨ دِی شَئے بݨائے (٧٣)۔
56,74,ٻَس آپݨیں عظمتاں والے رَبّ دے ناں سمیت اُوندا پاک ہووَݨ بیان کریندے رَہوو (٧٤)۔
56,75,ٻَس مَیں قسم چینداں تاریاں دے تُرٹݨ ݙَہݨ والیاں جائیں دِی (٧٥)۔
56,76,بیشک اِیہ تاں ٻَہُوں وَݙی قَسم ہے جیکر تُساں سَمجھ گِھندے (٧٦)۔
