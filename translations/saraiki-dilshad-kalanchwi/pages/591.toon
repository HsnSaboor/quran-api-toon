quran[32{c,v,t}:
86,1,قَسم ہے آسمان دِی، اَتے رات کُوں اُبھرݨ والے دِی(١)۔
86,2,اَتے تیکُوں کیا پَتہ، جو رات کُوں اُبھرݨ والا کیا ہے؟ (٢)
86,3,او ہِک چَمکدار تَارہ ہے(٣)۔
86,4,اِیں ڳالھ دِی) جو کوئی جِی اِہجا کائے نھیں، جِیندے اُتّے کوئی رَکھوالا( پَہرے دار) مُقرر نہ ہُووے(٤)۔
86,5,ٻَس اِنسان کُوں اِیہ تاں ݙیکھݨاں چاہیدا ہے جو او کِہڑی شَئے کنُوں پَیدا کِیتا ڳئے(٥)۔
86,6,او ہِک اُچَّھل پُووَݨ والے پاݨِیں (تَریڑے) کنُوں پَیدا کِیتا ڳیا ہے(٦)
86,7,جِہڑا جو کَن٘ڈ تے سِینے دِیاں ہَݙیاں پَسلیاں دے وِچکاروں نِکلدا ہے(٧)
86,8,یقیناً او (اَللہ) اُوندے وَلا جِیوا کھڑا کرݨ اُتّے پُوری قُدرت رکھیندا ہے(٨)
86,9,جِہڑے ݙین٘ہ دِلّاں دے بھید کھولیے ویسِن(٩)
86,10,ٻَس اُوندا نہ خُود دَا کوئی زور چَلسی، تے نہ کوئی ٻِیا مَددگار ہوسسّ(١٠)
86,11,قَسم ہے مِین٘ہ وَساوَݨ والے اَسمان دِی(١١)
86,12,اَتے چِریڄ وَن٘ڄݨ والی زمین دِی(١٢)۔
86,13,اِیں ڳالھ دِی) جو یقیناً اِیہ (حَق تے نا حق کُوں) نِکھیڑݨ والا قَول ہے(١٣)
86,14,اَتے اِیہ کوئی مَخول کائے نھیں(١٤)
86,15,یقیناً او سارے آپݨیں کوئی وَݙی تدبیر (چالاکی) کَرݨ لڳئیِن(١٥)
86,16,اَتے مَیں وِی ہِک تَدبیر کریندا پِیاں(١٦)
86,17,ٻَس (اَے رسول) کافراں کُوں تھوڑی جہی مُہلت ݙَے چا (١٧)
87,1,اَے رسول) تُوں سَب تُوں اُچّے شاناں والے رَبّ دے ناں دِی تَسبیح (اُوندا پَاک ہُووَݨ) پَڑھی رَکّھ(١)
87,2,جَیں پَیدا کِیتے، وَت ٹِھیک ٹَھاک (اُشناک) بݨا کھڑائے(٢)
87,3,اَتے جَیں اُوندا ہِک اَندازہ مُقرر کِیتے، ٻَس اُوکُوں سِدّھی رَاہ تے ٹوریس(٣)
87,4,اَتے جَیں (زمین وِچُّوں) گھا شَا ڄمایا(٤)
87,5,ٻَس وَل اُوکُوں بھوں ٻُکّل (کُٹا) بݨا چھوڑیا(٥)۔
87,6,اَجھو اَساں تیکُوں اِیں پَڑھیسُوں، جو وَل بُھلا وِی نَہ سَڳسیں(٦)
87,7,سِوائے اُوں شَئے دے جِہڑی اَللہ بُھلواوَݨ چَہسے، یقیناً او ظاہر کُوں وِی ڄاݨدا ہے، تے لُکّی ہوئی شَئے کُوں وِی(٧)
87,8,اَساں تیݙے کِیتے (اَسانی) پَیدا کر ݙیندُوں(٨)
87,9,ٻَس نصیحت کر جیکر تیݙی نصیحت کنُوں کوئی فائدہ چَاوَݨ چَہندے(٩)
87,10,اَلبتہ او شَخص ضرور نصیحت حاصل کر سَڳسِی، جِہڑا ݙَردے(١٠)
87,11,اَصلُوں بَد بَخت اِنسان اِیں نصیحت کنُوں پَرے بھَڄدے(١١)
87,12,او ہِک ٻَہُوں وَݙی بھا وِچ داخِل کِیتا ویسے(١٢)
87,13,وَل نہ اُوندے کِیتے اُوندے وِچ مَوت ہوسی، اَتے نَہ جِیوَݨ ہوسے(١٣)
87,14,تحقیق او شَخص کامیاب (مرادوَند) تِھی ڳِیا جَیں نیک کِردار ہُووَݨ دِی کوشش کِیتی(١٤)۔
87,15,اَتے جِہڑا آپݨیں رَبّ دا نَاں گِھندا (ذِکر کریندا) رِیہا، اَتے او نماز پَڑھدا رِیہا(١٥)
