quran[18{c,v,t}:
98,8,اُنھاں دے رَبّ دے نزدیک انھاں کِیتے جَزا ہے ہمیشہ قائم رَہݨ والیاں بَہشتاں، جِنھاں تَلّے نہراں وہندیاں وَڳدیاں پِیاں ہوسن، او ہمیشہ اُنھاں وِچ رَہسِن ٻَہسِن، للہ اُنھاں کنُوں خُوش او اَللہ کنُوں خوش، اِیہ ہے جَزا اُوندے کِیتے، جِہڑا آپݨیں رَبّ کنُوں ݙَردے(٨)
99,1,جِہڑے ویلے زمین کُوں اُوندا بھوئیں ہَںب (زلزلہ) پُوری طرح ہَلا ݙیسی(١)۔
99,2,اَتے زمین آپݨیں اَندر دے سارے بار باہر کَڈھ سَٹیسی(٢)۔
99,3,اَتے اِنسان اَکھیسے، اِیہ اِیکُوں کیا پِیا تِھیندے؟ (٣)۔
99,4,اُوں ݙین٘ہ (اُو) آپݨیں حالات بیان کریسے(٤)
99,5,کِیُوں جو تیݙے رَبّ اُوکُوں اِیویں حُکم ݙِتا ہویا ہوسی(٥)
99,6,اُوں ݙین٘ہ لوک ٹولیاں ٹولیاں بَݨ تے آسِن تاں جو اُنھاں کُوں اُنھاں دے اَعمال ݙِکھائے وَن٘ڄِن(٦)۔
99,7,ٻَس جَیں وِی ذری برابر چَن٘ڳا عَمل کِیتا ہویا ہوسے، او اُوکُوں ݙیکھ گِھنسے(٧)
99,8,اَتے جَیں وِی ذَری برابر بَدی کِیتی ہوسی، او اُوکُوں ݙیکھ گِھنسے(٨)
100,1,قَسم ہے اُنھاں گھوڑیاں دِی، جِہڑے سَہکدے سَہکدے وِی زور دے بَھڄدِن(١)
100,2,ٻَس پَتھراں اُتے (نعل مار تے) بھا دِیاں چِن٘ڳاریاں کَڈھیندِن(٢)
100,3,وَت وَݙے ویلے چھاپا چَا مریندِن(٣)
100,4,ٻَس اِیں طرح دُھدھڑ مِٹّی اُݙیندِن(٤)
100,5,ٻَس سارے اِیں حالت وِچ دُشمن دے لشکر وِچ وَڑ ویندِن(٥)۔
100,6,بیشک اِنسان آپݨیں رَبّ د اٻَہُوں نَا شُکرا ہے (٦)۔
100,7,اَتے یقیناً او خُود وِی اِیں (حقیقت) کنُوں باخَبر ہے(٧)
100,8,اَتے یقیناً او مال متال دِی محبت وِچ ٻَہُوں پَھسیا ہویا ہے(٨)۔
100,9,کیا او (اُوں وقت کُوں) نھیں ڄاݨدا ڄَݙاں جو قَبراں وچ جو کُجھ ہے اُوکُوں ٻاہر اُٹَھا کَھڑا کِیتا ویسی(٩)
