quran[11{c,v,t}:
21,102,او اِیندا کِھسکار تَئیں نہ سُݨ سَڳسِن، اَتے او آپݨیں پَسند دِیاں جائیں وِچ ہمیشہ کِیتے رَہسِن(١٠٢)۔
21,103,اُوں ٻَہُوں گَھبراہَٹ ویلے وِی، او اَصلُوں پریشان نَہ تِھیسِن، اَتے فرشتے بَھڄ تے آ مِلسِن (اَکھیسِن) اِیہ ہے تُہاݙا او ݙین٘ہ جِیندا تُہاݙے نال وَعدہ کِیتا ویندا ہَا(١٠٣)۔
21,104,جِہڑے ݙین٘ہ اَساں اَسمان کُوں اِیویں وَلھیٹ گِھنسُوں جِیویں لِکھیاں ہوئیاں کانگاں کُوں وَلھیٹ گِھدّا ویندے، اَساں جَیں طرح پہلے پہلے مخلوقات کُوں پَیدا کِیتا ہَا، اِیویں اُوکُوں وَلا پَیدا کر ݙیسُوں، اِیہ وَعدہ اَساکُوں پُورا کرݨیں، بیشک اَساں ضرور پُورا کرݨ والے ہَیں(١٠٤)۔
21,105,اَتے اَساں نصیحت والی کِتاب (توریت) دے بعد زُبور وِچ لِکھ ݙِتا ہَاسے جو بیشک میݙے نیک بَندے زمین دے وارث ہوسِن(١٠٥)۔
21,106,بیشک اِیں (قرآن) وِچ عِبادت کرݨ والے بَندیاں کِیتے ہِک سَنیہا پُچایا ڳئے(١٠٦)۔
21,107,اَتے (اَے رسول) اَساں تیکُوں سارے جہاناں کِیتے رحمت بَݨا تے بھیڄے(١٠٧)۔
21,108,آکھ ݙے جو میݙے کولھ اِیہا وَحی کِیتی ڳئی ہے، جو بیشک تُساں ساریْاں دا معبود اُوہو ہِکّو معبود ہے، وَل کیا تُساں اُوندے فرمانبردار (مسلمان) بݨئے ہوئے ہِیوے(١٠٨)۔
21,109,جیکر اِیہ مُن٘ہ پھیر گِھنّن، تاں آکھ ݙے، جو مَیں تاں تُساں ساریاں کُوں ٹِھیک ٹِھیک خَبردار کر ݙِتے، پَر میکُوں اِیہ پَتہ کائے نھیں، جو جِہڑی شَئے دَا تُہاݙے نال وَعدہ کِیتا ہوئے، او کُولھُوں آڳئی ہے، یا اَڄَݨّ پَرے ہے(١٠٩)۔
21,110,بیشک او چَن٘ڳی طَرح ڄاݨدے، جِہڑی کوئی ڳالھ اُچّی آواز وِچ ٻُلیندے وے اَتے اُوکُوں وِی ڄاݨدے جِہڑی لُک تے کریندے وے(١١٠)۔
21,111,پَر مَیں اِیہ نھیں ڄاݨدا جو شاید اِیہ تُہاݙے کِیتے کوئی اَزمائش ہُووے، اَتے کُجھ وَقت تَئیں دُنیاوی مَزّے کرݨ دَا موقع ݙِتا ویندا پِیا ہُووے(١١١)۔
21,112,آخر آکھیُس، میݙے رَبّ آ ! تُوں حَقّی فیصلہ کر چھوڑ (اَے لوکو) اَساݙا رَبّ سَب تُوں زیادہ مہربان ہے، جہڑا اَساݙی مَدد کریندے انھاں ڳالھیں دے خلاف جِہڑیاں تُساں کریندے وَدّے وے(١١٢)۔
