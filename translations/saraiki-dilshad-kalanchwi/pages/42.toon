quran[3]{c,v,t}:
  42,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  42,1,حٰمٓ (١)۔
  42,2,عٓسٓقٓ (٢)۔
  42,3,اِیں طرح تَیں دو وَحی بھیڄی ڳئی ہے، اَتے اُنھاں دو وَحی بھیڄی ڳئی ہئی جِہڑے تَیں کنُوں پہلے گُزر چُکئِن اَللہ تاں ٻَہُوں زبردست ہے، وَݙی دانائی والا ہے (٣)۔
  42,4,ہُوندا اِی ہے جِہڑا کُجھ اَسماناں وِچ ہے، تے جِہڑا کُجھ زمین دے تَلّے اُتّے ہے، اَتے اُوہو ساریاں تُوں وَݙیاں قَدراں والا ہے، ٻَہُوں وَݙا ہے (٤)۔
  42,5,اِیویں لڳدے جو اَسمان اُتے کنُوں پڑیج پوسِن، اَتے فرشتے آپݨیں رَبّ دِیاں تعریفاں کریندیں ہوئیں اُوندے پاک ہووݨ کُوں بیان کریندِن، اَتے زمین والیاں کِیتے بخشش مَنگدِن، پَتہ ہُووِیہے، جو بیشک اَللہ اِی بخشݨ ہار ہے ہمیشہ رحمت کرݨ والا ہے (٥)۔
  42,6,اَتے جِنھاں لوکاں اُوکُوں چھوڑ تے ٻِنھاں کُوں آپݨیں کارساز بݨا گِھدّے اَللہ انھاں کُوں آپݨیں نظر وِچ رَکھیا ہوئے، اَتے (اَے رسول) تُوں انھاں اُتے کوئی دارُوغہ کائے نِھیویں (٦)۔
  42,7,اَتے اِیں طرح اَساں تَیں دو قرآن کُوں عَربی وِچ وحی کِیتا ہے تاں جو تُوں ساریاں وَستیاں دِی مَاء (مَکّے) اَتے اُوندے آسُوں پاسُوں دے رَہݨ والیاں کُوں ݙَرا، اَتے کٹھے تِھیوݨ والے ݙین٘ہ کنُوں وِی ݙرا، جیندے وِچ کوئی شَک کائے نھیں (اُوں ݙین٘ہ) ہِک ٹولی تاں بہشت وِچ ہوسے، تے ہِک ٹولی دَوزخ وِچ ہوسے! (٧)۔
  42,8,اَتے جیکر اَللہ چَہندا تاں انھاں ساریاں لوکاں کُوں ہِکّا اُمّت بݨا چھوڑیندا، پَر او جیکُوں چَہندے آپݨیں رحمت وِچ گِھن آندے، اَتے جِہڑے ظالم ہِن نہ انھاں کِیتے کوئی کارساز ہے ، تے نہ کوئی مَددگار ہے (٨)۔
  42,9,کیا اُنھاں اُوکُوں چھوڑ تے ٻِنھاں کُوں آپݨاں کارساز نھیں بݨا گِھدّا؟ حالانکہ چَھڑا اَللہ کارساز وِی ہے تے مُردیاں کُوں جِیواوَݨ والا وِی! اَتے اُوہو ہر شَئے اَتے قُدرت (پُورا قابو) رَکھݨ والا وِی (٩)۔
  42,10,اَتے تُساں جِہڑی شَئے دے متعلق وِی کوئی اِختلاف کریندو، تاں اُوندا فیصلہ اَللہ دے کولھ ہے، اِیہُو اَللہ میݙے پَالݨ والا ہے، مَیں اُوندے اُتّے توکّل کرینداں اَتے اُوندی طرف رجوع وِی کرینداں (١٠)۔
  42,11,او اَسماناں دا تے زمین دا پَیدا کرݨ والا ہے، اُوں تُہاݙے کِیتے تُہاݙی جِنس دے جُٹ (نر مادی) بݨائِن، اَتے جانوراں دے جْٹ بݨائِن، اِیں طرح تُہاکُوں وَدھیندا پَھلیندا ہے، کوئی وِی شَئے اُوں وان٘گُوں کائے نھیں تے او خُوب سُݨݨ والا، چَن٘ڳی طرح ݙیکھݨ والا ہے (١١)۔
  42,12,اُوندے کولھ ہِن، کُنجیاں اَسماناں دِیاں، تے زمین دِیاں، وَدھا ݙیندے رِزق جِیندا چَہندے، تے پُورا سُورا وِی کر ݙیندے، بیشک او ہَر شَئے کُوں چَن٘ڳی طرح ڄاݨݨ والا ہے (١٢)۔
  42,13,اُوں تُہاݙے کِیتے دِین دا اوہو طور طریق مقرر کر ݙِتے، جِیندا حُکم اُوں نُوح کُوں کِیتا ہَا، اَتے جِیندی وَحی اَساں تَیں دو وِی بھیڄی ہے، اَتے جِیندا حُکم اَساں اِبراہیم ، تے مُوسیٰ، تے عیسیٰ کُوں وِی ݙِتا ہَا، جو اِیں دِین کُوں قائِم کِیتی رَکھݨاں اَتے اِیندے وِچ کوئی فِرقے پَیدا نہ کرݨاں، مُشرک لوکاں کُوں او شَئے ٻَہُوں کَوڑی (اَوکھی) لڳدِی ہے، جیں دو تُوں انھاں کُوں سݙیندیں، اَللہ اُوکُوں آپݨاں بݨا گِھندے جیکوں چَہندے، اَتے اُوکُوں آپ دو ہدایت وِی ݙے ݙیندے، جِہڑا جو اُوں دو رجوع کریندے (١٣)۔
  42,14,اَتے او فرقیاں وِچ وَںڈیج ڳئِن، او وِی اُوں ویلے ڄݙاں جو انھاں کولھ عِلم پُڄ ڳیا ہَا، اِیہ وِی محض آپس دِی ضِد وِچ آ تے ون٘ڈیے ڳئن، اَتے جیکر تیݙے رَبّ دِی طرفُوں ہِک ڳالھ ہِک خاص مُدّت کِیتے پہلے کنُوں طَے نہ ہوندی، تاں انھاں دے درمیان فیصلہ کر ݙِتا ویندا، اَتے بیشک اَڳلے لوکاں دے بعد اَساں جِنھاں کُوں کِتاب دا وارث بݨائے او ہِک اِہجے شَک وِچ پَئے ڳئِن، جِیندی وَجہ کنُوں ٻَوّے (پریشان) تھئے وَدِّن (١٤)۔
  42,15,ٻَس (اَے رسول) انھاں کُوں (اُوں دِین دُو) سَݙی رَکھ، اَتے اُوں ڳالھ تے قائِم رَہ، جِیندا تیکُوں حُکم ݙِتا ڳئے، اَتے انھاں دِیاں خواہشاں دِی پَیروی نہ کریں، بلکہ آکھ ݙے، جو مَیں تاں محض اُوندے اُتے اِیمان گِھن آیاں جِہڑا کُجھ اَللہ کتاب وِچ نازِل کِیتے، اَتے میکُوں اِیہ حُکم وِی ݙِتا ڳئے، جو مَیں تُہاݙے درمیان اِنصافی فیصلے کراں، اَللہ تاں او ہے جِہڑا اَساݙا وِی پالݨ ہار ہے تے تُہاݙا وِی پالݨ ہار ہے، اَساݙے عَمل ساݙے کیتے ہن تے تہاݙے عمل تہاݙے کیتے ہن، اَساݙے درمیان تے تُہاݙے درمیان کوئی حُجّت بازی (جھیڑے) دِی ڳالھ کائے نھیں، اَللہ اَساں ساریاں کُوں آپس وِچ کَٹھا کریسی، اَتے ہُوں دو وَلائے وِی ویسُو (١٥)۔
  42,16,اَتے جِہڑے لوک اَللہ دے متعلّق حُجّت بازی کریندِن، ڄݙاں جو اُوکُوں قبول وِی کر گِھدّا ڳئے انھاں دِی حُجّت انھاں دے رَبّ دے نزدیک بالکل فضول ہے، بلکہ انھاں اُتے (اَللہ دا) غضب ہے ، اَتے اُنھاں کِیتے ٻَہُوں سخت عذاب ہے (١٦)۔
  42,17,اَللہ تاں او ہے جیں کتاب کُوں برحق نازِل کِیتے، اَتے (نیکی بَدی دی) ترکڑی کُوں وِی! اَتے (اَے رسول) تیکُوں کیا پَتہ جو (قیامت دِی) گھڑی کولھوں آ ڳئی ہُووِے (١٧)۔
  42,18,اِیندے آوَݨ دِی جلدی اُوہے پَے کریندِن جِہڑے جو اِیندے اُتّے یقین وِی نھیں رَکھیندے، اَتے جِہڑے اِیمان گِھن آئِن او اِیں کنُوں ݙَردے رَہندِن، اَتے او ڄاݨدِن جو بیشک اِیہ برحق ہے، سُݨ گِھنّو جِہڑے لوک قیامت دِی گھڑی دے متعلّق جھیڑے گَھتّی رَکھدِن، او واقعی گُمراہی وِچ ٻَہُوں پَرے توڑِیں پُڄ ڳئِن (١٨)۔
  42,19,اَللہ تاں آپݨیاں ٻانھیاں اُتے ٻَہُوں مہربان ہے، جیکُوں جِتّی چَہندے رِزق ݙے ݙیندے، اَتے او ٻَہُوں زور والا ہے، ساریاں اُتے غالب ہے (١٩)۔
  42,20,جِہڑا کوئی آخرت دِی فَصل چَہندے اَساں اُوندی فَصل وَدّھا پَھلا ݙیندے ہَیں، اَتے جِہڑا کوئی اِیں دُنیا دِی فصل چَہندے، تاں اُوکُوں اُوندے وِچ اِی ݙے چھوڑیندے ہَیں، پَر آخرت کُوں اُوندے نصیب وِچ کُجھ وِی نہ ہوسی (٢٠)۔
  42,21,کیا اِنھاں کولھ اِہجے وِی شریک ہِن، جِنھاں اُنھاں کِیتے اِہجا دِین (طور طریقہ) مقرر کر ݙِتے، جِیندی اِجازت اَللہ ݙِتی وِی کائے نھیں جیکر فیصلے (دے ݙین٘ہ) والی ڳالھ طَے نہ تِھی چُکّی ہوندی تاں انھاں دَا ٹَنݨَا مُکا ݙِتا ڳیا ہوندا، اَتے یقیناً جِہڑے ظالم ہِن، انھاں کِیتے دَردناک عذاب ہے (٢١)۔
  42,22,تُوں ݙیکھسیں جو ظالم ݙَردے پَے ہوسِن (اُوندی) شامت کنُوں جِہڑا کُجھ انھاں کھٹیا کمایا ہوسے اَتے اِیہ (شامت) انھاں اُتے آ تے رَہسی، اَتے جِہڑے لوک اِیمان گِھن آئِن تے نیک عَمل کِیتے ہِینے او بَہشتی باغاں وِچ ہوسِن، انھاں کِیتے اُنھاں دے رَبّ دے کولھ او سَب کُجھ ہوسی جِہڑا کُجھ او چَہسِن اِیہُو ٻَہُوں وَݙا فَضل ہے (٢٢)۔
  42,23,اِیہا او شَئے ہے جِیندی خوشخبری اَللہ آپݨیاں اُنھاں بَندیاں کُوں ݙیندے جِہڑے جو اِیمان گِھن آندِن، تے نیک عَمل کریندِن، (اَے رسول) اُنھاں لوکاں کُوں آکھ ݙے، جو مَیں تُساں کنُوں اِیں کَم دا کوئی معاوضہ نھیں مَنگدا، سِوائے اِیندے جو تُساں قریبی تعلّق والیاں نال پیار محبّت رَکھو! اَتے جیکر کوئی نیکی کریسی، تاں اُوندے کِیتے اُوندے ثواب کُوں وَدّھا چھوڑیسُوں، بیشک اَللہ ٻَہُوں بخشݨ ہار، ڈھیر قدر کرݨ والا ہے (٢٣)۔
  42,24,کیا اِیہ لوک اِیہُو اَہدِن جو اِیں (رسول) اَللہ اُتّے کُوڑا بُہتان گھڑ گِھدّے، جیکر اَللہ چَہندا تاں خود تیݙے دِل اُتے وِی مُہر لا ݙیندا، پَر اَللہ باطل (کُوڑ) کُوں مِٹیندے، اَتے حق کُوں آپݨیاں اُصولاں نال حق ثابت کر ݙیکھیندے بیشک او سِینیاں دے وِچ دِیاں ڳالھیں خُوب ڄاݨݨ والا ہے (٢٤)۔
  42,25,او تاں اُوہو ہے جِہڑا آپݨیاں ٻانھیاں دِی توبہ قبول کر گِھندے اَتے قصُور معاف کر ݙیندے، اَتے جِہڑا کُجھ تُساں کریندے وے خوب ڄاݨدے (٢٥)۔
  42,26,اَتے انھاں دِیاں دُعائیں قبول کر گِھندے، جِہڑے جو اِیمان گِھن آئِن تے نیک عَمل کریندِن، اَتے اُنھاں اُتّے آپݨاں فَضل وَدھائی رَکھدے پر جِہڑے کافِر ہِن انھاں کِیتے ٻَہُوں سخت عذاب ہے (٢٦)۔
  42,27,اَتے جیکر اَللہ آپݨیاں بَندیاں دے رِزق کُوں اَصلُوں کُھلّا کر ݙیوے تاں او زمین اُتے فساد چا کھڑا کرِن، پر او جِتّی چَہندے اُوں اندازے دے مطابق نازِل کر ݙیندے، بیشک او آپݨیاں بندیاں کُوں خُوب ڄاݨݨ والا انھاں تے نظر رَکھݨ والا ہے (٢٧)۔
  42,28,اَتے او اُوہو ہے جِہڑا لوکاں تے مِینہ چَا وَسیندے، ڄݙاں جو او اَصلُوں نا اُمید تِھی چُکئے ہوندِن، تے آپݨیں رحمت چَا کِھن٘ڈیندے اَتے اُوہو ہے تعریفاں دے ݙا والا کارساز (٢٨)۔
  42,29,اَتے اُوندیاں نِشانیاں وِچُوں ہے، اَسماناں تے زمین دا پَیدا کرݨ، تے انھاں وِچ جانوراں کُوں کِھن٘ڈا ݙیوݨ، ٻِیا اِیہ جو ڄݙاں چَہوے اُنھاں کُوں وَلا کَٹھا کر گِھنّݨ دِی پُوری قوت رَکھیندے (٢٩)۔
  42,30,اَتے تُہاݙے اُتّے جِہڑی کوئی وِی مصیبت آندِی ہے، او تُہاݙے آپݨیں ہَتّھاں دِی کَمائی دِی وَجہ کنُوں ہُوندی ہے اَتے او تاں ڈھیر سارے قصور اُووِیں وِی معاف کر ݙیندے (٣٠)۔
  42,31,اَتے تُساں اُوکُوں زمین اُتے عاجز کر گِھنّݨ والے تِھی وِی نھیں سَڳدے، اَتے سِوائے اَللہ دے نہ تُہاݙا کوئی کارساز ہے، اَتے نہ کوئی مَددگار (٣١)۔
  42,32,اَتے اُوندیاں نِشانیاں وِچُوں ہِن، سَمندر وِچ، پہاڑاں وان٘گوں نظر آوَݨ والے جہاز (٣٢)۔
  42,33,جیکر او چَہوے تاں ہَوا کُوں بَند کر ݙیوے، ٻَس اِیہ سمندر اُتے اَصلُوں کھڑ وَن٘ڄن، بے شَک اِیندے وِچ (اُوندی قُدرت دِیاں) نِشانیاں ہِن، صَبر کرݨ والے، تے شُکر اَدا کرݨ والے کِیتے (٣٣)۔
  42,34,یا اُنھاں کُوں اُنھاں دے آپݨیں کِیتے عَملاں دِی وَجّہ کنُوں تباہ کر چھوڑے اَتے ٻَہُوں سارے قصور معاف کر ݙیوے (٣٤)۔
  42,35,تاں جو جِہڑے لوک اَساݙیاں نشانیاں دے متعلّق جھیڑے گَھتّی وَدِّن، ڄاݨ گِھنّن جو اِنھاں کِیتے تاں کوئی پَناہ دِی جاء وِی کائے نھیں (٣٥)۔
  42,36,ٻَس تُہاکُوں جِہڑی کوئی شَئے ݙِتی ڳئی ہے، او تاں اِیں دُنیاوی زِندگی دے فائدے کِیتے ہے اَتے جِہڑا کُجھ (اَجر) اَللہ کولھ ہے او تاں ٻَہُوں چَن٘ڳا وِی ہے، تے ہمیشہ باقی رَہݨ والا وِی، اَتے آپݨیں رَبّ اُتے توکّل کریندِن (٣٦)۔
  42,37,اَتے جِہڑے لوک وَݙے وَݙے گُناہاں کنُوں تے بے حیائی دے کَمّاں کنُوں پَرہیز کریندِن، اَتے ڄݙاں کاوِڑ آندی ہے تاں بخش ݙیندِن (٣٧)۔
  42,38,اَتے جِہڑے لوک آپݨیں رَبّ دے حکم کُوں مَن گِھندِن، اَتے نماز قائِم کِیتی رَکھدِن، اَتے آپݨیں معاملے آپس دے صلاح مَشورے نال طَے کر گِھندِن، اَتے جو کُجھ رِزق اَساں انھاں کُوں ݙِتا ہوئے، اُوندے وِچُوں اِی خرچ کریندِن (٣٨)۔
  42,39,اَتے جِنھاں لوکاں اُتے کوئی زیادتی تِھی ویندی ہے، تاں اُوندا بَدلہ گِھن گِھندِن (٣٩)۔
  42,40,اَتے کہیں بُرائی دا بدلہ خُود اُوں بُرائی دے برابر ہے، ٻَس جِہڑا کوئی معاف کر ݙیوے، تے معاملہ ٹِھیک کر گھنّے، تاں اُوندا اَجر اَللہ دے ذِمّے ہے بیشک او زیادتی کرݨ والیاں کُوں پَسند نھیں کریندا (٤٠)۔
  42,41,اَتے جِہڑا کوئی آپݨیں اُتّے ظلم تِھیوݨ دے بعد بَدلہ گِھن گِھنّے، تاں ٻَس اُنھاں اُتے کوئی مَلامت کائے نھیں (٤١)۔
  42,42,بیشک ملامت تاں اُنھاں اُتے ہے، جِہڑے اِنساناں اُتے زیادتی کریندِن اَتے زمین اُتے نا حق فَساد مچیندِن، اِیہے او لوک ہِن جِنھاں کِیتے ہِک دَرد ناک عذاب ہے (٤٢)۔
  42,43,اَتے جیں صبر اختیار کِیتا، اَتے معاف کر ݙِتا، تاں اِیہ تاں ٻَس وَݙی ہِمّت والے کَمّاں وِچُوں ہے (٤٣)۔
  42,44,اَتے جیکوں اَللہ گُمراہ کر ݙیوے، تاں (اَللہ) دے علاوہ اُوں شخص دا کوئی کارساز کائے نھیں، اَتے تُوں ظالماں کُوں ݙیکھسیں جو او عذاب کُوں ݙیکھسِن تاں پُچھّݨ لڳ پوسِن، جو کیا وَل وَن٘ڄݨ کِیتے کوئی رَاہ وِی ہے؟ (٤٤)۔
  42,45,اَتے (اَے رسول) تُوں اُنھاں (ظالماں) کُوں ݙیکھسیں جو او جِہڑے ویلے (دَوزخ دے) عذاب دے سامݨیں گِھن آئے ویسِن تاں ذِلّت تے خواری کنُوں کُٻّے تِھئے وَدّے ہوسِن، تے جِھکّیاں نظراں کر تے اُوکُوں ݙیکھسِن، اَتے جِہڑے لوک اِیمان گِھن آئے ہوسِن، او اَکھیسِن جو بیشک گھاٹا چاوَݨ والے اُوہے لوک ہِن جِنھاں قیامت دے ݙین٘ہ آپݨیں آپ کُوں وِی گھاٹے وچ پاتا تے آپݨیاں لوکاں کُوں وِی ، سُݨ گِھنُّو جو ظالم لوک ضرور ہمیشہ دے عذاب وِچ رَہسِن (٤٥)۔
  42,46,اَتے اَللہ دے سِوا انھاں دے کوئی یار وِی نہ ہوسِن، جِہڑے اُنھاں کُوں مَدد ݙیوِن، بلکہ جیکُوں اَللہ گُمراہ رَہݨ ݙیوے تاں اُوندے کِیتے (ہدایت دا) کوئی رَاہ کائے نھیں (٤٦)۔
  42,47,تُساں آپݨیں رَبّ دا حُکم اِیں کنُوں پہلے مَن گِھنّو جو او ݙین٘ہ آوَںڄے جِہڑا اَللہ دِی طرفُوں کائے نہ ٹلسی، اُوں ݙین٘ہ تُہاݙے کِیتے کوئی پَناہ دِی جاء نہ ہوسے، اَتے نہ تُہاݙے (گُناہاں کنُوں) اِنکار دِی گُنجائش ہوسے (٤٧)۔
  42,48,انھاں ڳالھیں دے باوجود جیکر اِیہ مُن٘ہ پھیر وَن٘ڄن تاں (اَے رسول) اساں تیکُوں اُنھاں اُتے دَاروغہ بݨا تے نھیں بھیڄیا، تیݙا کَم تاں محض سِنیہا (پیغام) پُچا ݙیون ہے، دَراَصل ڄَݙاں اَساں انسان کُوں آپݨِیں رحمت دا مَزّہ چَکھیندے ہَیں، تاں ٻَہُوں خوش تِھی ویندے، پَر ڄَݙاں اُنھاں اُتے کوئی مصیبت (سختی) آ وَن٘ڄے، او وِی محض انھاں دے آپݨیاں ہَتّھاں نال پہلے کنُوں بھیجے ہوئے کرتُوتاں دِی وَجہ کنُوں، تاں وِی تحقیق اِنسان اَصلُوں نا شُکرا بَݨ ویندے ! (٤٨)۔
  42,49,اَللہ دِی ہے بادشاہی اَسماناں دِی تے زمین دِی وِی! جو کُجھ چَہندے پَیدا کر چھوڑیندے، جیکوں چَہندے دِھیّاں ݙے ݙیندے، تے جیکُوں چَہندے پُتر ݙے ݙیندے (٤٩)۔
  42,50,یا انھاں کُوں دِھیّاں پُتر رَلا مِلا تے ݙیندے، اَتے جیکوں چَہندے سَنڈھ بݨا چھوڑیندے، بیشک او تاں سَب ڄاݨݨ والا وَݙی قُدرت والا ہے (٥٠)۔
  42,51,اَتے کہیں بَشر دِی اِیہ شان کائے نھیں، جو اَللہ اُوندے نال ڳالھیں کرے، اِیہ تِھی سَڳدے جو کہیں دے دِلّ وِچ گھت ݙیوے، یا کہیں پَردے دے اُݙُوں اِشارہ کرے، یا کوئی رسول بھیڄے، او جو کُجھ اَللہ چَہندے اُوندے حُکم نال لوکاں توڑِیں پُچیندے بیشک او اَصلُوں اُچّا ہے، وَݙی حکمت والا ہے (٥١)۔
  42,52,اَتے اِیں طرح اَساں (اَے رسول) آپݨیں حُکم نال تَیں دو رُوح بھیڄی ہے تُوں نہ ڄاݨدا ہاویں، جو اِیہ کتاب کِیا ہے، اَتے اِیہ اِیمان کِیا ہے، پَر اَساں اِیکُوں نُور بݨا ݙِتے، آپݨیاں ٻانھیاں وِچُوں جیکُوں چَہندے اِیندے نال سِدّھا رَستہ ݙیکھا ݙیندے ہَیں، اَتے یقیناً تُوں وِی سِدّھا رَستہ ݙیکھیندیں (٥٢)۔
  42,53,رَستہ اُوں اَللہ دا، جِیندے ہَتّھ وِچ سارا کُجھ ہے جو کُجھ اَسماناں وِچ ہے تے جو کُجھ زمین دے تَلّے اُتّے ہے، سُݨ گِھنّو! جو سارے معاملے اَللہ دو پھیرے وَن٘ڄݨِن (٥٣)۔
