quran[21{c,v,t}:
44,19,اَتے تُساں اَللہ دے مقابلے وِچ سِر نہ چَاؤ، بیشک مَیں تُہاکُوں ہِک کُھلّی دلیل پیش کرݨ لڳاں (١٩)۔
44,20,اَتے مَیں آپݨیں رَبّ دِی ، تے تُہاݙے رَبّ دِی پَناہ مَنگی ہے، اِیں ڳالھ کنُوں جو تُساں میکُوں پَتھر مار مار تے مار نہ گَھتُّو (٢٠)۔
44,21,اَتے جیکر تُساں میݙے اُتے اِیمان نھیں گِھن آندے تاں وَل میں کنُوں پَرے ہَٹ وَن٘ڄو (٢١)۔
44,22,اخیر اُوں آپݨیں رَبّ کنُوں دُعا مَنگی جو (اَساکُوں بَچا) کیوں جو اِیہ ہِک مجرم لوکاں دِی قوم ہے (٢٢)۔
44,23,(جواب ݙِتا ڳیا) ٻَس رات و رات میݙے بندے آپݨیں نال کر تے اِتُّھوں چَلیا وَن٘ڄ، اِیہ تُہاݙے پَکڑݨ کِیتے ضرور پِچُّھوں آسِن (٢٣)۔
44,24,اَتے سُکّے سَمندر کُوں (اِیویں دا اِیویں) چھوڑی وَن٘ڄیں، یقیناً انھاں دا لشکر غرق تِھی تے رَہسی (٢٤)۔
44,25,او کِتنا کُجھ چھوڑ تے مریے، باغ تے چَشمے! (٢٥)۔
44,26,اَتے رَڑِھیں (فَصلاں) تے عِزّتاں والی جائیں (٢٦)۔
44,27,اَتے نعمتاں جِنھاں وِچ او عَیش پَے کریندے ہَن (٢٧)۔
44,28,اِیں طرح تِھیا (اُنھاں داَنجام) اَتے اَساں اُنھاں دا وارث ہِک ٻَئی قوم کُوں بݨا ݙِتا(٢٨)۔
44,29,ٻَس انھاں اُتے نہ اَسمان تے زمین رُنّے، اَتے نہ اُنھاں کُوں کوئی مُہلت ݙِتی ڳئی (٢٩)۔
44,30,اَتے تحقیق اَساں بنی اِسرائیل کُوں ٻَہُوں ذلیل قسم دے عذاب کنُوں بَچا گِھدّا (٣٠)۔
44,31,فِرعون دے (عذاب کنُوں) بیشک او حَد کنُوں ٹَپ وَن٘ڄݨ والیاں وِچُوں اُچّے دَرجے دَا ہَا (٣١)۔
44,32,اَتے تحقیق اَساں اُنھاں (بَنی اِسرائیل کُوں) سَب کُجھ ڄاݨ سَمجھ تے سارے جہاناں دے مقابلے وِچ چُݨ گِھدّا (٣٢)۔
44,33,اَتے انھاں کُوں آپݨیاں نِشانیاں ݙیکھائیاں جِنھاں وِچ صاف صاف آزمائش ہَئی (٣٣)۔
44,34,بِلا شُبہ اِیہ (جِہڑے ہِن) اِیہ تاں اِیہ اَکھیندِن (٣٤)۔
44,35,جو ٻَس اَساݙی موت دے بعد ٻِیا کُجھ وِی کائے نھیں، اَتے اَساں وَلا کائے نہ جِیوائے ویسُوں (٣٥)۔
44,36,جیکر تُساں سَچ آہدے وے تاں وَل گِھن آؤ جِیوا تے اَساݙے پِیو ݙاݙیاں کُوں (٣٦)۔
44,37,کیا اِیہے لوک چَن٘ڳے ہِن، یا تُبِعّ دِی قوم، اَتے او لوک وِی جِہڑے جو انھاں کنُوں پہلے تِھی گُزرے ہِن، اَساں انھاں کُوں تَباہ کر چھوڑیا کیُوں جو او بِلا شُبہ گُنہگار لوک ہَن (٣٧)۔
44,38,اَتے اَساں اَسماناں کُوں، تے زمین کُوں، تے جو کُجھ اُنھاں دے وِچکار ہے، اِیویں شُغل دے طور تے پَیدا نھیں کِیتا (٣٨)۔
44,39,اَتے اَساں انھاں ݙوہائیں کُوں بَر حق (حکمت نال) بݨائے، پَر اُنھاں دے ڈھیر لوک حقیقت کُوں نِھیں ڄاݨدے (٣٩)۔
