quran[3]{c,v,t}:
  19,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  19,1,کٓھٰیٰعٓصٓ، (١)۔
  19,2,اِیہ زکریا اُتے تیݙے رَبّ دِی کِیتی ہوئی رحمت والا بیان ہے (٢)۔
  19,3,ڄَݙاں اُوں اَپݨیں رَبّ کُوں ہُولے ہُولے سَݙیا (٣)۔
  19,4,آکھیُس جو میݙے رَبّ آ! میݙیاں ہَݙیاں کَمزور تِھی ڳئیِن اَتے ٻُڈھیپے کنُوں میݙے سِر دے چِٹّے وال بَکّھݨ لڳ پیئِن، اَتے میݙے رَبّ آ ! مَیں تَیں کنُوں مَن٘گ تے کݙاہِیں خالی ہَتّھ نھیں وَلیا (٤)۔
  19,5,اَتے مَیں آپݨیاں وَلی وارثاں (دِیاں بُرائیاں) کنُوں ݙَردا ہَاں ، اَتے میݙی ذال سَنڈھ ہے، ٻَس میکُوں خاص کر آپݨِیں طرفُوں ہِک وارث چَا بَخش (٥)۔
  19,6,جِہڑا میݙا وارث وِی بݨے، تے یعقوب دِی اَولاد دا وِی، اَتے میݙے رَبّ آ ! اُوکُوں خُود آپݨِیں رَضا تے چَلݨ والا بَݨاویں (٦)۔
  19,7,اَے زکریا ! بیشک اَساں تیکُوں ہِک چُھوہَر دِی خوشخبری ݙیندُوں، اُوندا ناں یَحییٰ ہوسی، اَساں اُوں کنوں پہلے اِیں ناں والا کوئی شَخص پَیدا نھیں کِیتا (٧)۔
  19,8,اُوں آکھیا، میݙے رَبّ آ ! میکُوں پُتر کِیویں ڈھہیسے؟ ڄَݙاں جو میݙی ذال سَنڈھ ہے، اَتے مَیں اَپݨیں ٻُڈھیپے دے آخیر توڑِیں پُڄیا وَدّاں (٨)۔
  19,9,آکھیا ڳیا جو، اِیویں ہُووݨِیں، تیݙے رَبّ آکھیئے جو میݙے کِیتے اِیہ سَوکھا کَم ہے، اَتے اِیں کنُوں پہلے تیکُوں وِی تاں پَیدا کِیتا ہَم، ڄَݙاں جو تُوں کُجھ وِی نہ ہَاویں (٩)۔
  19,10,اُوں آکھیا، میݙے رَبّ آ ! میکُوں اِیندی کوئی نِشانی ݙَسا، اُوں آکھیا تیݙے کِیتے نِشانی اِیہ ہے جو تُوں لوکاں نال تَرائے راتِیں تَئیں صَحیح سلامت ہُووَݨ تے وِی اَلا ٻُول نہ سَڳسیں (١٠)۔
  19,11,وَل او اَپݨیں حُجرے وِچُوں باہر آپݨِیں قَوم دو آیا، تاں اُنھاں کُوں سَمجھا سَمجُھو تے آکھیا جو صَبح شام اَللہ دے پاک ہُووَݨ کُوں بیان کِیتی رَکّھو (١١)۔
  19,12,پُتر یحییٰ ! میݙی کِتاب کُوں قابو پَکڑی رَکّھ، اَتے اَساں اُوکُوں چُھرَپّے وِچ اِی دَانائی ݙے ݙِتی (١٢)۔
  19,13,اَتے آپݨِیں طرفُوں اُوکُوں تَرس کھاوَݨ تے پاکیزہ رَہوَݨ وِی سِکھا ݙِتا، اَتے او وَݙا پَرہیزگار بَݨیا (١٣)۔
  19,14,اَتے اَپݨیں پِیؤ مَاء نال چَن٘ڳا سلوک کرݨ والا ہَا، اَتے مغریا ہوئیا تے نافرمان نہ ہَا (١٤)۔
  19,15,اَتے اُوندے اُتّے سَلامتی ہے اُوندے ڄَمَݨّ والے ݙین٘ہ وِی، مَرَݨ والے ݙین٘ہ وِی، تے وَلا جِی اُٹَّھݨ والے ݙین٘ہ وِی (١٥)۔
  19,16,اَتے (اَے رسول) کِتاب وِچُوں مَریم دا حال وِی سُݨا ڄَݙاں جو او آپݨیاں لوکاں کنُوں اَنج تِھی تے سِجھ اُبھار دو ہِک جاء وَن٘ڄ رَہی (١٦)۔
  19,17,اَتے اُوں اُنّھاں کنُوں آپݨیں آپ کُوں لُکا گِھدّا، ٻَس اَساں اُوندے کولھ آپݨاں رُوح (فرشتہ) بھیڄا، جِہڑا جو اُوندے سامݨیں ہر لحاظ نال اِنسان بَݨ تے ظاہر تِھیا (١٧)۔
  19,18,(مَریم) آکھیا، ہر حالت وِچ مَیں تَیں کنُوں ٻَہُوں مہربان رَبّ دِی پَناہ مَن٘گدِی ہَاں، جیکر تُوں پَرہیزگار ہِیں تاں (ہَٹ وَن٘ڄ) (١٨)۔
  19,19,اُوں آکھیا، یقین کر جو مَیں تیݙے رَبّ دا بھیڄیا ہوئیاں، تیکُوں ہِک نیک پَاک پُتر (دِی اِطلاع) ݙیوݨ آیا ہَاں (١٩)۔
  19,20,مَریم آکھیا، میݙا پُتر کِیویں ڄَم سَڳدے، کِیُوں جو میکُوں کہیں بنی بَشر ہَتّھ وِی نِھیں لَایا، اَتے مَیں کوئی بَدکارِݨ وِی کائے نھیں (٢٠)۔
  19,21,فِرشتے) آکھیا، اِیویں تِھی تے رَہسی کِیُوں جو تیݙے رَبّ آکھئے جو میݙے کِیتے اِیہ ٻَہُوں سَوکھا کَمّ ہے، اِیں واسطے وِی جو اَساں اُوکُوں لوکاں کِیتے ہِک نِشانی بݨاوَݨ لڳے ہَیں، اَتے اَپݨِیں طرفُوں ہِک رَحمت وِی اَتے اِیہ سَب کجھ طَے تِھی چُکیا ہے (٢١)۔
  19,22,ٻَس اُوکُوں اِیویں پیٹ تِھی ڳیا، وَل او اُوں پیٹ نال ہِک پروبھری جاء تے چَلی ڳئی (٢٢)۔
  19,23,ٻَس اُوکُوں ویاوَݨ دِیاں پِیڑاں کھڄّیاں دے مُنڈھ وِچ گِھن آیاں، آکھݨ لڳی خُدا تَاں اِیویں چَا کرے ہَا جو مَیں اِیں ڳالھ کنُوں پہلے اِی مَر ویندی، اَتے مَیں (ساریاں کُوں) اَصلُوں بُھل بُھلا ویندی (٢٣)۔
  19,24,ٻَس اُوں تلے کھڑیں ہوئیں مَریم کُوں سَݙ تے آکھیا، جو تُوں مُونجھی نہ تِھی، تیݙے رَبّ تیݙے کنُوں جِھکّی جَاء تے ہِک چَشمہ وَہا ݙتے (٢٤)۔
  19,25,اَتے تُوں کَھڄّی دَا ٻوجھا پَکڑ تے آپ دو ہِلا، تیݙے اُتے تازہ پَکیاں پِن٘ڈُوں کِر پُوسِن (٢٥)۔
  19,26,تُوں (پِن٘ڈُوں) کَھا ، اَتے (پاݨِیں) پِی، اَتے اَکّھیں ٹَھار ٻَس جیکر کہیں بنی بشر کُوں (اِعتراض کریندا) ݙیکھیں، تاں آکھیں، جو بے شَک مَیں ٻَہُوں مہربان اَللہ کِیتے روزے دِی نیّت رَکھ گِھدّی ہے، ٻَس مَیں اَڄ کہیں اِنسان نال وِی ڳالھ نہ کریساں (٢٦)۔
  19,27,وَل او (اُوں ٻال) کُوں چَا تے اَپݨِیں قوم دو گِھن ڳئی، اُنھاں آکھیا اَے مَریم! تُوں تاں نویکلی شَئے چَا آئی ہِیں (٢٧)۔
  19,28,ہارون دِی بھیݨ ہیں ! نہ تیݙا پِیو کُوئی بُرا شَخص ہَا، اَتے نہ تیݙی مَا بدکردار ہَئی (٢٨)۔
  19,29,(جواب وِچ) اُوں مَئی ٻال دو اِشارہ چَا کِیتا تاں او لوک آکھݨ لڳے، جو اَساں اِیندے نال کِیویں ڳالھ کروں، اِیہ تاں اَڄݨ جھولی دا ٻال ہے (٢٩)۔
  19,30,اُوں (ٻال) آکھیا، مَیں وِی اَللہ دا بَندہ ہَاں ! اُوں میکُوں کِتاب وِی ݙِتی ہے اَتے میکُوں نبی وِی بݨایا ہِس (٣٠)۔
  19,31,اَتے میکُوں، مَیں جِتّھاں وِی ہُوواں برکتاں والا بݨایا ہِس، اُوں میکُوں نماز پَڑھݨ تے زکوٰۃ کڈھݨ دا حُکم کِیتا ہوئے جے توڑِیں وِی مَیں جِیندا رَہواں (٣١)۔
  19,32,اَتے میکُوں آپݨِیں مَاء نال چَن٘ڳا سلوک کرݨ والا بݨایا ہِس، اَتے اُوں میکُوں مَغریا ہویا تے بَد بخت نھیں بݨایا (٣٢)۔
  19,33,اَتے سلامتی ہے میݙے اُتّے جِہڑے ݙین٘ہ مَیں ڄَمیا ہَم، اَتے جِہڑے ݙین٘ہ مَیں مَرساں، اَتے جِہڑے ݙین٘ہ میکُوں وَلا جِیوا کھڑایا ویسی (٣٣)۔
  19,34,اِیہُو کُجھ ہَا عیسیٰ پُتر مَریم دا ! اَتے اِیہا اَصل ڳالھ ہے جِیندے وِچ لوک شَک کریندے پَے ہِن (٣٤)۔
  19,35,اَللہ دِی شان اِیندے وِچ کائے نھیں جو کہیں کُوں آپݨاں پُتر بݨاوے، او تاں (انھاں ڳالھِیں کنُوں) پاک ہے، ڄَݙاں وِی کوئی کَم چَہندے چَھڑا اَکھیندے جو تِھی وَن٘ڄ تے او تِھی ویندے (٣٥)۔
  19,36,اَتے بیشک اَللہ میݙا وِی پالَݨ ہَار ہے، تے تُہاݙا وِی ! ٻَس ہُوندی عِبادت کِیتی کرو، اِیہُو سِدّھا رَاہ ہے (٣٦)۔
  19,37,پَر مختلف فِرقیْاں آپس وِچ اِختلاف گَھت ݙِتّے، ٻَس ٻَہُوں خرابی تے بربادی ہے اُنھاں لوکاں دِی، جِنھاں نھیں مَنیا (قیامت والے) وݙے ݙین٘ہ دے آوَن٘ڄݨ کُوں (٣٧)۔
  19,38,تَݙاں او ٻَہُوں کُجھ سُݨ گِھنسِن تے ٹِھیک ٹِھیک ݙیکھ گِھنسِن، جِہڑے ݙین٘ہ جو اَساݙے کولھ آسِن، پَر اُوں ݙین٘ہ ظالم لوک کُھلّی گُمراہی وِچ ہوسِن (٣٨)۔
  19,39,اَتے اُنھاں کُوں اُوں پَچھتاوے والے ݙین٘ہ کنُوں ݙَرا، ڄَݙاں جو ہَر مُعاملہ چُکا ݙِتا ویسی، پَر اِیہ غفلت وِچ وَدِّن، اَتے اِیمان وِی نھیں انین٘دے (٣٩)۔
  19,40,بیشک اَساں اِیں زمین دے ، اُتّے جو کُجھ اِیندے اُتّے ہِن ساریاں شَئیں دے وارث ہَیں، اَتے انھاں ساری٘اں اَساں دو وَل آوݨیں (٤٠)۔
  19,41,اَتے اِیں کِتاب وِچُوں اِبراہیم دا حال وِی ݙَسا، بیشک او ٻَہُوں سَچّا نبی ہا (٤١)۔
  19,42,اُوں آپݨیں پِیؤ کُوں آکھیا، جو اَبّا ! تُوں اِہجی شَئے دِی بَندگی کِیُوں کریندیں جِہڑی جو نہ کُجھ سُݨ سَڳدِی ہے تے نہ کُجھ ݙیکھ سَڳدی ہے، اَتے نہ تیݙے کَہیں کَمّ آسَڳدِی ہے (٤٢)۔
  19,43,میݙے پِیؤ آ، بیشک میکُوں اِہجا عِلم مِلیا ہے جِہڑا تیکُوں نھیں ݙِتا ڳیا، ٻَس تُوں میݙی پَیروی چَا کر، مَیں تیکُوں سِدّھی رَاہ تے ٹُوریساں (٤٣)۔
  19,44,میݙے پِیؤ آ ، شیطان دِی بندگی نہ کِیتی کر، بیشک شیطان تاں آپݨیں ٻَہُوں مہربان اَللہ دَا وِی نافرمان ہے (٤٤)۔
  19,45,میݙے پِیؤ آ، میکوں ݙَر ہے، جو کِتھائیں تیکُوں اَپݨیں مہربان اَللہ دا عَذاب نہ آ پَکڑے، تے تُوں شیطان دا سَن٘گتی نہ تِھی وَن٘ڄیں (٤٥)۔
  19,46,اُوں آکھیا، اِبراہیم آں ! کِیا تُوں میݙے معبُوداں کنُوں مُن٘ہ پِھریندیں جیکر تُوں اِیں ڳالھ کنُوں باز نہ آیُوں تاں مَیں تیکُوں پَتھر مار مار تے مار گَھتیساں، ٻَس تُوں مَیں کنُوں ڈھیر مدّت توڑِیں پَرے تِھی وَن٘ڄ (٤٦)۔
  19,47,(اِبراہیم) آکھیا، تیݙے اُتے سَلامتی ہُووے، ٻَس مَیں تیݙے کِیتے آپݨیں رَبّ کنُوں بخشش دِی دُعا مَن٘گساں بیشک او میݙے اُتّے ٻَہُوں مہربان ہے (٤٧)۔
  19,48,اَتے میں تُساں ساریاں کنُوں اَتے اَللہ کنُوں سِوا جِنھاں، کُوں تُساں سَݙیندے وے، اُنھاں کنُوں ہِک پاسے تِھی وینداں، اَتے آپݨیں رَبّ کُوں سَݙینداں، توقع ہے جو مَیں آپݨیں رَبّ کنُوں دُعا مَن٘گ تے خالی ہَتّھ نہ رَہساں (٤٨)۔
  19,49,ٻَس ڄَݙاں اُنھاں کنُوں، اَتے اَللہ کنُوں سِوا جِنھاں دِی او بَندگی کریندے ہِن، اُنھاں کنُوں پَرے ہَٹ ڳیا، تاں اَساں اُوکُوں اِسحاق تے یعقوب ݙِتے، اَتے ہَر ہِک کُوں اَساں نبی بݨا ݙِتا (٤٩)۔
  19,50,اَتے اَساں اُنھاں کُوں آپݨیں رحمت وِچُوں ٻَہُوں کُجھ ݙِتا، اَتے اَساں اُنھاں کُوں سَچّی ناموری نصیب کِیتی (٥٠)۔
  19,51,اَتے (اَے رسول) اِیں کِتاب وِچ دا مُوسیٰ دَا حال وِی ݙَسا، بیشک او ہِک چُݨیا ہوئیا خاصہ بَندہ ہَا، او وَݙے مُقدّر والا رسُول وِی ہَا تے نبی وِی (٥١)۔
  19,52,اَتے اَساں اُوکُوں کُوہِ طُور دے سَڄے پاسُوں سَݙیا، اَتے اُوکُوں راز دِیاں ڳالھِیں کِیتے کولھُوں کر گِھدّا (٥٢)۔
  19,53,اَتے اُوندے کِیتے آپݨیں رحمت نال اوندے بِھرا ہَارون کُوں نبی بݨا ݙِتا (٥٣)۔
  19,54,اَتے (اَے رسول) اِیں کِتاب وِچ دا اِسماعیل دا حال وِی ݙَسا بے شَک او وَعدے دا ݙَاڈھا پَکّا ہَا، اَتے او وَݙی قَدر والا رسول ہَا تے نبی ہَا (٥٤)۔
  19,55,اَتے آپݨیاں لوکاں کُوں نَماز اَتے زَکوٰۃ کِیتے حُکم ݙیندا ہَا، بیشک او آپݨیں رَبّ دا ٻَہُوں پَسند کِیتا ہوئیا ہَا (٥٥)۔
  19,56,اَتے اِیں کِتاب وِچ دَا اِدریس دَا حال وِی ݙَسا، بے شک او ہِک سَچّا نَبی ہَا (٥٦)۔
  19,57,اَتے اَساں اُوکُوں اُچّے مرتبے توڑِیں پُچا ݙِتا ہَا (٥٧)۔
  19,58,اِیہے او لوک ہِن، جِنھاں اُتے اَللہ نعمت بھیڄی، او نبیّاں وِچُوں ہَن، آدم دِی اَولاد وِچُوں ہَن، اَتے اُنھاں وِچُوں ہَن جِنھاں کُوں اَساں نُوح نال سوار کر گِھدّا ہَا، اَتے اَپݨیں کِیتے چُݨ گِھدّا ہَا، ڄَݙاں اُنھاں کُوں وَݙے مہربان اَللہ دِیاں آیاتاں پَڑھ تے سُݨائیاں ویندیاں ہَن، تاں او سَجدے وِچ ڈھے پوندے ہَن، تے روندے ہَن (٥٨)۔
  19,59,وَل اُنھاں دے گَندے لوک اُنھاں دے جانشین بَݨ ڳئے، جِنھاں نماز کُوں چھوڑ ݙِتا ہَا، اَتے نفسانی خُواہشاں پِچُّھوں لَڳ پَے ہَن، وَت ٻَہُوں جلدی گُمراہی دے اَنجام کُوں ݙیکھ گِھنسِن (٥٩)۔
  19,60,سِوائے اُنھاں دے جِہڑے تَوبہ چَا کریندِن، اَتے اِیمان گِھن آندِن، اَتے نیک عَمل کریندِن، ٻَس اِیہے لوک ہِن جِہڑے جَنّت وِچ داخِل تِھیسِن اَتے اُنھاں اُتّے کوئی وِی ظُلم نہ کِیتا ویسے (٦٠)۔
  19,61,ہمیش رَہݨ والے باغاں دا وَعدہ ہے جہڑا جو ٻَہُوں مہربان اَللہ نے غائبانہ طور تے اَپݨیں بَندیاں نال کِیتا ہوئے، بیشک اُوندا وَعدہ ضرور پُورا تِھی تے رَہݨ والا ہے (٦١)۔
  19,62,اُنھاں وِچ واہیات ڳالھِیں نہ سُݨیسِن، سِوائے سَلامتی دِیاں ڳالھِیں دے، اَتے اُنھاں کِیتے اُوندے وِچ سَنجھ صَباحِیں دِی روزی (رِزق) تَیّار مِلسے (٦٢)۔
  19,63,اِیہا ہے او بہشت جِیندا وَارث اَساں آپݨیاں بَندیاں وِچُوں اِہجیاں شَخصاں کُوں بَݨیسُوں جِہڑے جو ٻَہُوں پَرہیزگار ہوسِن (٦٣)۔
  19,64,اَتے اَساں (فَرشتے) نِسّے نازِل تِھیندے تیݙے رَبّ دے حُکم کنُوں سِوا، ہُوندا ہے جِہڑا کُجھ اَساݙے سامݨیں ہے جِہڑا کُجھ اَساݙی کَنڈ پِچُّھوں ہے، اَتے جِہڑا کُجھ اِیندے وِچالے ہے، اَتے تیݙا رَبّ بُھلَݨ والا اَصلُوں کائے نھیں (٦٤)۔
  19,65,اَسماناں دا، تے زمین دا، اَتے جِہڑا کُجھ اُنھاں دے اَدّھ وِچ ہے، اُنھاں ساریْاں دا جِہڑا رَبّ ہے، ٻَس ہُوندی عِبادت کِیتی کرو، کیا تُساں کہیں ٻَے کُوں ڄاݨدے وے جِہڑا اِہجے ناں (صِفاتاں) والا ہُووے(٦٥)۔
  19,66,اَتے اِنسان اَکھیندے، کیا ڄَݙاں جو مَیں مَر ویساں تَاں کیا وَلا جِیوا تے ٻاہر کڈھیا ویساں؟ (٦٦)۔
  19,67,کیا اِنسان کُوں یاد نھیں آندا، جو بیشک اَساں اُوکُوں اِیں کنُوں پہلے وِی پَیدا کِیتا ہَاسے، ڄَݙاں، جو او کوئی شَئے وِی نہ ہَا؟ (٦٧)۔
  19,68,ٻَس تیݙے رَبّ دِی قَسم ! جو اَساں اُنھاں کُوں کَٹّھا کریسُوں، تے شیطاناں کُوں وِی! وَل اَساں اُنھاں کُوں دَوزخ دے چارے پاسُوں گوݙیاں دے بَھرنے کَھڑیسُوں (٦٨)۔
  19,69,وَل اَساں اُنھاں دِی ہَر ٹولی وِچُوں اِہجے لوکاں کُوں ٻاہر کَڈھ گِھنسُوں جِہڑے ٻَہُوں مہربان اَللہ دے اَصلُوں نافرمان تَھئے ہوئے ہوسِن (٦٩)۔
  19,70,وَل اَساں اُنھاں لوکاں کُوں وِی خُوب ڄاَݨدے ہَیں، جِہڑے اَصلُوں اُوندے وِچ سَٹَّݨ دے ݙَا دے ہِن (٧٠)۔
  19,71,اَتے تُہاݙے وِچُوں کوئی اِہجا شخص کائے نھیں، جِہڑا اِیں (دَوزخ) تُوں ضرور لَنگھ تے نہ ویسی! اِیہ تیݙے رَبّ کِیتے حتمی ڳالھ ہے جِہڑی تِھی تے رَہسی (٧١)۔
  19,72,وَل اَساں پَرہیزگاراں کُوں بَچا گِھنسُوں اَتے ظالماں کُوں اُوندے وِچ ڳُوݙیاں دے بَھرنے سَٹ چھوڑیسُوں (٧٢)۔
  19,73,اَتے ڄَݙاں جو اُنھاں کُوں اَساݙیاں کُھلیاں آیاتاں پَڑھ تے سُݨائیاں ویندیاں ہِن، تاں جِہڑے اُنھاں کُوں مَنّݨ کنُوں اِنکار کریندِن، اِیمان گِھن آوَݨ والیاں کنُوں پُچھدِن، جو اَساں ݙوہائیں وِچُوں کِیندا جاء ٹِکاݨاں وَدھایا ہے تے کِیندی مَجلس زیادہ شاندار ہے؟ (٧٣)۔
  19,74,اَتے اَساں اِنھاں کنُوں پہلے دِیاں کئی اِہجیاں اُمتّاں کُوں برباد کر چھوڑے، جِہڑیاں اِنھاں کنُوں مال متال وِچ تے نک نموز وِچ وَدھیاں ہوئیاں ہَن (٧٤)۔
  19,75,(اَے رسول) آکھ ݙے جو جِہڑا شَخص گُمراہی وِچ پَے ویندے تاں عام رحمت والا اَللہ اُوکُوں مُہلت ݙیندا ویندے، اِیں توڑِیں جو او اُوں شَئے کُوں ݙیکھ گِھنسِن جِیندا وَعدہ اُنھاں نال کِیتا ہوئیا ہے، چاہے او عَذاب دے متعلّق ہے، چاہے قیامت دِی گھڑی دے متعلّق ہے، ٻَس جلدی اُنھاں کُوں پَتہ لَڳ ویسے جو کِیندا جاء ٹِکاݨاں بَد تَر ہے، تے کِیندا لَشکر ٻَہُوں کَمزور ہے (٧٥)۔
  19,76,اَتے اَللہ اُنھاں کُوں ٻئی وِی ہدایت ݙِتّی رَکھدے جِہڑے جو ہدایت تے آ ویندِن، اَتے باقی رہ وَن٘ڄݨ والیاں نیکیاں تیݙے رَبّ دے نزدیک بہتر ہِن، ثواب دے لحاظ نال وِی تے اَنجام دے طور تے وِی (٧٦)۔
  19,77,(اَے رسول) کیا تَیں اُوں شَخص کُوں وِی ݙِٹّھے، جِہڑا اَساݙِیاں نِشانیاں کُوں نھیں مَنیندا، اَتے اَکھیندے جو اِیہے مال متال تے آل اَولاد اِیویں ݙِتی ویندی رَہسی (٧٧)۔
  19,78,کیا اُوں غیب دا پَتہ لَا گِھدّے یا ٻَہُوں رحمت والے اَللہ کنُوں کوئی وَعدہ گِھن آئے (٧٨)۔
  19,79,اَصلُوں کائے نہ ! اَساں جلدی اُوکُوں لِکّھ گِھندے ہَیں، جِہڑا کُجھ او اَکھیندے، اَتے ہولے ہولے اُوندا عَذاب وَدھیندے ویندُوں (٧٩)۔
  19,80,اَساݙے کولھ آ ویسِن جِہڑیاں شَئیں دے متعلّق اِیہ ڳالھِیں کریندے اَتے اَساݙے سامݨیں خالی ہَتّھ کَلھّا آ کَھڑسے (٨٠)۔
  19,81,اَتے اُنھاں لوکاں اَللہ کنُوں سِوا ٻئے معبود بݨا گِھدّے ہِن، تاں جو او اُنھاں کِیتے طاقت تے وَقار وَدھاوَݨ دا باعث بݨِن (٨١)۔
  19,82,اِیں نہ تِھیسی! بلکہ او انھاں دِیاں عبادتاں دَا وِی اِنکار کر ݙیسِن، اُلٹا اِنھاں دے سخت مخالف تِھی ویسِن (٨٢)۔
  19,83,کیا تَیں نھیں ݙِٹّھا، جو بیشک اَساں شیطاناں کُوں کافراں اُتے لائیا ہوئیا ہے، او اُنھاں کُوں ٻَہُوں وَرغلائی رَکھیندے ہِن (٨٣)۔
  19,84,ٻَس تُوں اُنھاں کِیتے (عذاب دِی) اُٻَہل نہ کَر، بیشک اَساں اُنھاں دے ݙین٘ہاڑے ڳِݨیے ہوئے ہِن (٨٤)۔
  19,85,ہِک ݙین٘ہ اَساں پَرہیزگاراں کُوں ٻَہُوں مہربان اَللہ کولھ مہماناں وان٘گُوں کَٹھے کریسُوں (٨٥)۔
  19,86,پَر گُنہگاراں کُوں تریہے(تسے) جانوراں وان٘گُوں دَوزخ دو ہَکّل ݙیسُوں (٨٦)۔
  19,87,(کہیں کُوں) سِفارش دا اِختیار نہ ہوسی سِوائے اُوندے جَیں ٻَہُوں مہربان اَللہ کنُوں اِجازت گِھن گِھدّی ہوسی (٨٧)۔
  19,88,اَتے اَہدے ہِن جو ٻَہُوں مہربان اَللہ نے (کہیں کُوں) پُتر بݨا گِھدّا ہے (٨٨)۔
  19,89,تحقیق تُساں ٻَہُوں گَندی ڳالھ گھڑ تے گِھن آئیوے (٨٩)۔
  19,90,ہُݨ تِھی سڳدے جو اَسمان چِریج پَڑیج پُووِن، زمین ݙلیج پِھلیج وَن٘ڄے، تے پَہاڑ تُرٹ بھڄ تے ڈھے پُووِن (٩٠)۔
  19,91,اِیں ڳالھُوں جو اُنھاں ٻَہُوں مہربان اَللہ کِیتے پُتر ہُووَݨ دا دَعویٰ کِیتے (٩١)۔
  19,92,پَر ہُوں مہربان اَللہ کُوں اِیہ نھیں ٹَھہندا جو او کہیں کُوں پُتر بݨاوے (٩٢)۔
  19,93,اَسماناں تے زمین اُتّے اِہجا کوئی وِی نھیں جِہڑا ٻَہُوں مہربان اَللہ کولھ ٻانھاں بَݨ تے نہ آسے (٩٣)۔
  19,94,تحقیق اُوں اُنھاں کُوں اَپݨِیں وَکّڑ وِچ گَھتّیا، اَتے ہِک ہِک کُوں ڳِݨ گِھدّا ہوئے (٩٤)۔
  19,95,اَتے اُنھاں دا ہَر کوئی قیامت دے ݙین٘ہ کَلھم کَلّھا آ کَھڑا تِھیسے (٩٥)۔
  19,96,بیشک جِہڑے لوک اِیمان گِھن آئے، اَتے نیک عَمل کِیتُونے، تاں اَجّھو ٻَہُوں مہربان اَللہ اُنھاں کِیتے محبّت پَیدا کر گِھنسے (٩٦)۔
  19,97,بیشک اَساں اِیں (قرآن) کُوں تیݙی زبان وِچ اَسان کر ݙِتے، تاں جو تُوں اِیندے ذریعے پرہیزگار لوکاں کُوں خوشخبری ݙیویں، اَتے جھِیڑے گَھتَّݨ والی قَوم کُوں اِیندے نال ݙَراویں (٩٧)۔
  19,98,اَتے اَساں انھاں کنُوں پہلے ڈھیر قَوماں کُوں تَباہ کر چھوڑے، کیا تَیں اِنھاں وِچُوں کہیں کُوں ݙِٹّھے یا انھاں دِی کوکِڑوا سُݨی ہے (٩٨)۔
