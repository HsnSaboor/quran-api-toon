quran[3]{c,v,t}:
  55,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  55,1,اَلرحمٰن (ٻَہُوں مہربان اَللہ) (١)۔
  55,2,اُوں قرآن دِی تعلیم ݙِتّی ہے (٢)۔
  55,3,اِنسان کُوں پَیدا کِیتا ہِس (٣)۔
  55,4,اِیکُوں ٻولَݨ سِکھایا ہِس (٤)۔
  55,5,سِجھ تے چَندر (آپݨیں کَمّ وِچ) ہِک حِساب دے مطابق پابند ہِن (٥)۔
  55,6,اَتے وَلھِیں ٻوٹے تے دَرخت سَجدے وِچ رَہندِن (٦)۔
  55,7,اَتے اَسمان کُوں اُچّا کِیتا ہِس، اَتے توازن قائم کِیتا ہِس (٧)۔
  55,8,ٻَس تُساں وِی توازن وِچ کوئی گڑ بڑ نہ کِیتی کرو (٨)۔
  55,9,اَتے تُساں وَزن کُوں ٹِھیک ٹِھیک رَکھیا کرو، اَتے تول وِچ اَصلُوں کَمتی نہ کِیتی کرو (٩)۔
  55,10,اَتے زمین کُوں، ساری جی جان والی مخلوقات کِیتے بݨائِس (١٠)۔
  55,11,اُوندے وِچ میوے ہِن، اَتے کَھجّیاں ہِن، جِنھاں دے میوے اُتّے غِلاف چَڑھیا ہویا ہوندے (١١)۔
  55,12,اَتے چِھلَّڑ (چھاݨ) والے اَن ہِن، اَتے خوشبوئی پُھلّاں والے ٻُوٹے (وَلھِیں) ہِن (١٢)۔
  55,13,بھلا تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(١٣)۔
  55,14,اِنسان کُوں پَید اکِیتا ہِس، ٹِھکری وانگیں کھڑکݨ والی ہِک سُکّے گارے دِی مِٹی کنُوں (١٤)۔
  55,15,اَتے جِنّاں کُوں پَیدا کِیتا ہِس بھا دے شُعلیاں وِچُوں (١٥)۔
  55,16,بھلا تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(١٦)۔
  55,17,او ݙُوہائیں مشرقاں والے تے ݙوہائیں مغرباں والے پاسیاں دَا مالِک ہے (١٧)۔
  55,18,بھلا تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(١٨)۔
  55,19,اُوں ݙُوں اِہجے سَمندر بݨا چھوڑے ہِن، جِہڑے ہِک ٻئے نال رَلیے ہوئِن (١٩)۔
  55,20,پَر اُنھاں دے اَدّھ وِچکار ہِک رُکاوَٹ ہے ، ٻَس او ہِک ٻئے دے پاسے نھیں چَڑھدے (٢٠)۔
  55,21,بھلا تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢١)۔
  55,22,اَتے اُنھاں وِچُوں سچّے موتی تے کُوڑے موتی (گھونگھے سِپّیاں) نِکلدِن (٢٢)۔
  55,23,ٻَس تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢٣)۔
  55,24,اَتے ہُوندیاں ہِن سَمندر وِچ (پہاڑاں وَانگُوں) اُچّے بادباناں والیاں ٻیڑیاں (٢٤)۔
  55,25,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢٥)۔
  55,26,اِیں (زمین) اُتّے جو کُجھ وِی ہے او فَنا تِھی وَن٘ڄݨ والا ہے (٢٦)۔
  55,27,اَتے تیݙے رَبّ دِی ذات اِی باقی رَہسی، جِہڑا ٻَہُوں بُزرگی والا تے وݙی عِزّت والا ہے (٢٧)۔
  55,28,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢٨)۔
  55,29,سارے ہُوں کنُوں مَنگدِن، جِہڑے کوئی وِی اَسماناں وِچ ہِن تے زمین دے تَلّے اُتّے ہِن، اَتے او ہَر ݙین٘ہ نویں شان وِچ ہوندے (٢٩)۔
  55,30,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٠)۔
  55,31,اَے (زمین دَا بار بݨی ہوئی) مخلوقاتو اَجھو اَساں تُہاݙے حِساب کتاب گِھنّݨ کِیتے فارغ تِھی ویسُوں (٣١)۔
  55,32,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٢)۔
  55,33,اے جِنّاں تے اِنساناں دِیاں ٹولیاں! جیکر تُساں اِیہ طاقت رَکھیندو جو تُساں اَسماناں تے زمین دِیاں حَدّاں بنّیاں کنُوں ٹَپ تے کِتھائیں نِکل سڳدو، تاں وَل نِکل ݙیکھالو! تُساں تاں نِکل وِی نھیں سڳدے، سِوائے کہیں وَݙے زور (غلبے) دے (٣٣)۔
  55,34,ٻَس تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٤)۔
  55,35,تُساں ݙُوہائیں اُتّے بَھا دے شُعلے سَٹّیے ویسِن، تے (ڳچّی گُھٹّݨ والا) دُھوں (ہوسی) اَتے تُساں ݙُوہائیں مقابلہ وِی نہ کر سَڳسو (٣٥)۔
  55,36,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٦)۔
  55,37,بھلا ڄَݙاں اَسمان چِریج ویسے، وَت رَتّے رَنگ والے چَم وانگیں تِھی ویسے (او ہولناک ݙین٘ہ ہوسے) (٣٧)۔
  55,38,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٨)۔
  55,39,بھلا اُوں ݙین٘ہ اُنھاں دے گُناہاں دے متعلّق پُچھݨ دِی ضرورت وِی نہ پوسی، نہ اِنساناں کنُوں تے نہ جِنّاں کنُوں (٣٩)۔
  55,40,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٤٠)۔
  55,41,گُنہگار لوک آپݨیں شِکلاں کنُوں سُن٘ڄاݨ گِھدّے ویسِن، اَتے اُنھاں کُوں مَتّھے دے والاں کنُوں تے پَیراں کنُوں پَکڑ گِھدّا ویسے (٤١)۔
  55,42,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٤٢)۔
  55,43,اِیہا ہے او دَوزخ جیکُوں گُنہگار لوک کُوڑا اَکھیندے ہِن (٤٣)۔
  55,44,اِیندے وِچ ٻَڑکدے پاݨِیں تَئیں وَل وَل پھردے رَہسِن (٤٤)۔
  55,45,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٤٥)۔
  55,46,اَتے جِہڑا شَخص اَپݨیں رَبّ دے سامݨیں کھڑے آ تِھیوݨ کنُوں ݙَردے اُوندے کِیتے ݙُوں قِسم دے بَہشتی باغ ہِن (٤٦)۔
  55,47,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٤٧)۔
  55,48,اُنھاں ݙُوہائیں بَہشتی باغاں وِچ مختلف قِسم دِیاں ٹینگلیاں والے وَݨ ہوسِن (٤٨)۔
  55,49,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٤٩)۔
  55,50,اُنھاں ݙُوہائیں بہشتی باغاں وِچ ݙُوں چَشمے وَہندے پِیئن (٥٠)۔
  55,51,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٥١)۔
  55,52,اُنھاں ݙوہائیں باغاں وِچ ݙُوں ݙُوں سَواداں والے میوے لڳے ہوسِن (٥٢)۔
  55,53,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٥٣)۔
  55,54,اِیہ لوک اِہجیاں قالیناں اُتّے تکیہ لا تے ٻیٹھے ہوسِن، جِنھاں دے اَستر ݙورے ریشم (تافتے) دے ہِن ، اَتے انھاں ݙوہائیں بہشتی باغاں دے میوے انھاں دے کولھُوں کولھُوں (جِھکّے جِھکّے) لٹکیے کھڑے ہوسِن (٥٤)۔
  55,55,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٥٥)۔
  55,56,انھاں وِچ جِھکّی اَکّھ رَکھݨ والیاں (شرمیلیاں) ذالیں ہوسِن، جِنھاں کُوں پہلے کنُوں نہ کہیں اِنسان نے ہَتّھ لایا ہوسی، اَتے نہ کہیں جِنّ نے (٥٦)۔
  55,57,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٥٧)۔
  55,58,اِیہ اِیویں لڳسِن جِیویں کوئی یاقوت تے مَرجان (ہِیرے موتی) ہووِن (٥٨)۔
  55,59,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٥٩)۔
  55,60,کیا نیکی دا بَدلہ نیکی کنُوں وَدّھ کوئی ٻِیا وِی تِھی سڳدے (٦٠)۔
  55,61,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٦١)۔
  55,62,اُنھاں ݙوہائیں بہشتی باغاں دے علاوہ ݙُوں ٻئے باغ وِی ہِن (٦٢)۔
  55,63,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٦٣)۔
  55,64,او (باغ) گھاٹے، سَاوے کچُوچ ہِن (٦٤)۔
  55,65,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٦٥)۔
  55,66,اُنھاں ݙُوہائیں وِچ زور نال وَہندے ݙُوں چَشمے وِی ہِن (٦٦)۔
  55,67,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٦٧)۔
  55,68,اُنھاں ݙُوہائیں وِچ میوے ہِن، پِن٘ڈُوں ہِن، تے اَنار ہِن (٦٨)۔
  55,69,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٦٩)۔
  55,70,اُنھاں وِچ ٻَہُوں چَن٘ڳیاں تے سُوہݨِیں ذالیں ہوسِن (٧٠)۔
  55,71,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٧١)۔
  55,72,(چِٹّیاں ڳوریاں) حُوراں ہِن، جِہڑیاں تَنبُوآں وِچ (مَستوراں وانگیں) ٻَہلایاں ہویاں ہِن (٧٢)۔
  55,73,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٧٣)۔
  55,74,پہلے کنُوں اُنھاں کُوں کہیں اِنسان یا کہیں جِن ہَتّھ وِی نہ لَایا ہوسی (٧٤)۔
  55,75,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٧٥)۔
  55,76,اِیہ بہشتی لوک ساویاں قالیناں اُتّے نفیس تکیئے لا تے ٻیٹھے ہوسِن (٧٦)۔
  55,77,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٧٧)۔
  55,78,تیݙے وَݙیاں شاناں والے تے اُچّیاں عِزّتاں والے رَبّ دا ناں ٻَہُوں بَرکتاں والا ہے (٧٨)۔
