quran[20{c,v,t}:
44,40,یقینی طور تے فیصلے دا ݙین٘ہ اُنھاں ساریاں دے اُٹّھی کھڑݨ کِیتے مقرر تِھی چُکیئے (٤٠)۔
44,41,اُوں ݙین٘ہ کوئی گھاٹا یار وِی، آپݨیں گھاٹے یار دے کہیں وِی کَمّ نہ آسَڳسِی، اَتے نہ اُنھاں دِی کِتھاؤں مَدد کِیتی ویسی (٤١)۔
44,42,سِوائے اُوندے جِیندے اُتّے اَللہ رحم چَا کرے، بیشک او تاں ٻَہُوں زبردست بے حد رحمت کرݨ والا ہے (٤٢)۔
44,43,یقیناً تھوہر دا وَݨ (٤٣)۔
44,44,گُنہگار دِی غِذا ہوسے (٤٤)۔
44,45,جِہڑی تیل دِی گدمیل ( ڳلے ہوئے ترامے) وَان٘گُوں اُوندے ݙِڈھ وِچ پَئی اُٻلسی (٤٥)۔
44,46,جِیویں جو ٻَہُوں گَرم پاݨِیں ٻَڑکدے(٤٦)۔
44,47,آکھیا ویسی، اِکُوں پَکڑ گِھنُّو، اَتے گِھیل تے دَوزخ دے اَدّھ وِچ گِھن وَن٘ڄو! (٤٧)۔
44,48,اُوں دے سِر اُتے ٻَڑکدے پاݨِیں دا عذَاب سَٹّو (٤٨)۔
44,49,چَکھ ہُݨ ! تُوں تاں طاقتور تے عِزّت والا بݨدا ہاویں (٤٩)۔
44,50,یقیناً اِیہ اُوہَا (دوزخ) تاں ہے جِیندے متعلّق تُساں شَک کِیتی رَکھدے ہاوے (٥٠)۔
44,51,بیشک پرہیزگار لوک ٻَہُوں اَمن والی جاء وِچ ہوسِن (٥١)۔
44,52,بہشتی باغاں وِچ تے چَشمیاں دے کناریاں تے (٥٢)۔
44,53,باریک تے موٹے ریشم دِیاں پُوشاکاں پاتے آمݨیں سامݨیں ٻیٹھے ہوسِن (٥٣)۔
44,54,اِہجی ہوسی (اُنھاں دِی شان) تے اَساں (گورے رَنگ تے) سوہݨیں اَکّھیں والیاں ذالیں کُوں اُنھاں دا جُٹ بݨا ݙیسُوں (٥٤)۔
44,55,اُوندے وِچ ہر قسم دے میوے اَپݨِیں مَرضی تے مَوج نال من٘گسِن (تے کھاسِن) (٥٥)۔
44,56,اُوندے وِچ او مَوت دا مَزہ وِی نہ چَکھسِن سِوائے اُوں پہلی مَوت دے، اَتے اَللہ اُنھاں کُوں دَوزخ دے عذاب کنُوں بچائی رکھسے (٥٦)۔
44,57,تیݙے رَبّ دِی طرفُوں اِیہ وَݙا فضل ہوسی اِیہا ہے ٻَہُوں وَݙی کامیابی (٥٧)۔
44,58,(اَے رسول) بیشک اَساں اِیں (قرآن) کُوں تیݙی زبان وِچ سَوکھا کر ݙِتے، تاں جو اِیہ لوک نصیحت پَکڑِن (٥٨)۔
44,59,ٻَس تُوں وِی اِنتظار وِچ رَہ، بیشک اِیہ لوک وِی اِنتظار وِچ ہِن (٥٩)۔
