quran[9{c,v,t}:
7,96,جیکر انھاں وَستیاں (آبادیاں) دے لوک اِیمان گِھن آندے تے پرہیزگار بَݨ ویندے، تاں اَساں اُنھاں اُتے اَسمان کنُوں اَتے زمین وِچوں برکتاں دے دروازے کھول ݙیندے، پر اُنھاں تاں (ہر ڳالھ کُوں) کُوڑ اِی آکھیا، ٻَس جِہڑا کُجھ او کریندے کماندے ہِن اُوندی وَجہ کنُوں اَساں اُنھاں کُوں آپݨِیں پَکڑ وِچ گِھن اَیوسے (٩٦)۔
7,97,کیا آبادیاں دے رَہݨ والے لوک اِیں ڳالھ کنُوں اَمان وِچ آڳئِن جو اَساݙا عذاب اُنھاں اُتے رات کوں وِی نہ آ سَڳسِی، ڄݙاں جو او سُتّے پَے ہوندِن (٩٧)۔
7,98,کیا وَستیاں (آبادیاں) دے رَہݨ والے اِیں ڳالھ کنُوں اَمان وِچ آ ڳئِن، جو اُنھاں اُتے اَساݙا عذاب ݙین٘ہ چڑھیے کُوں وِی نہ آ سَڳسِی، جݙاں جو او کھیݙݨ کُݙݨ وِچ لڳئے ہوئے ہوںدِن (٩٨)۔
7,99,کیا او اَللہ دے داء (منصوبے) کنُوں وِی اَمان وِچ آڳئِن، (سَمجھ گِھنو) جو اَللہ دے داء کنُوں اُوہے لوک بے خوف تِھی سَڳدِن، جِہڑے جو گھاٹا چاوݨ والے ہوندِن (٩٩)۔
7,100,کیا اِیہ ڳالھ اُنھاں لوکاں دِی ہدایت ڄوگی کائے نھیں، جِہڑے جو پہلے اِتھاں رَہݨ والیاں دے بعد زمین دے وارث بݨائے ویندِن، جو جیکر اَساں چاہوں تاں اُنھاں دے گُناہاں دے سَبّبُوں مصیبتاں وِچ چَا گھتُوں تے اُنھاں دے دِلاں اُتے مُہراں چا لاؤں تاں جو او (ہدایت دِی ڳالھ) سُݨ وِی نہ سَڳِن (١٠٠)۔
7,101,اِیہے او آبادیاں (وَستیاں) ہَن جنھاں دے کُجھ حال تیکوں سُݨیندے پَے ہَیں، تحقیق اُنھاں کولھ اُنھاں دے رسول نشانیاں (دَلیلاں) گِھن تے آئے ہَن، پر او اِہجے نہ ہَن جو او اُنھاں تے اِیمان گِھن آوِن ہا، جیکوں پہلے کُوڑا آکھ چُکیئے ہَن، اِیں طرح اَللہ کافراں دے دِلّاں اُتے مُہر لَا ݙیندے (١٠١)۔
7,102,اَتے اَساں اِنھاں وِچوں اکثر بندیاں کُوں وَعدہ پُورا کریندا نھیں ݙِٹھا، بلکہ اِنھاں دے اَکثر بندیاں کُوں نافرماناں (بدکاراں) وِچوں پاتے (١٠٢)۔
7,103,وَل اَساں انھاں قوماں دے بعد موسیٰ کُوں آپݨیاں نشانیاں ݙے تے فرعون تے اُوندے مشیراں دو بھیڄا، تاں اُنھاں وِی نشانیاں کنُوں ظالمانہ طور تے اِنکار کِیتا، ٻَس ݙیکھ گِھن، جو فسادی لوکاں دا اَنجام کِیں طرح تِھیندے؟ (١٠٣)۔
7,104,اَتے موسیٰ نے آکھیا، اَے فرعون! مَیں سارے جہاناں دے رَبّ دِی طرفوں رسول بݨا تے بھیڄا ڳِیاں (١٠٤)۔
