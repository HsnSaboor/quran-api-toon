quran[19{c,v,t}:
67,27,ٻَس ڄَݙاں او ݙیکھ گِھنسِن جو او (وَعدہ) کولھُوں آڳئے تاں اُنھاں لوکاں دے جِنھاں کُفر اِختیار کِیتا ہوئے مُن٘ہ لَہہ (وِڳڑ) ویسِن، وَت (اُنھاں کُوں) آکھیا ویسے جو اِیہا تاں ہے او شَئے جیندا تُساں تقاضا کریندے ہاوے (٢٧)۔
67,28,آکھ ݙے کیا تُساں سوچے جو بھاویں اَللہ میکُوں تے میݙے نال والیاں کُوں مار گَھتّے، بھاویں اَساݙے اُتّے رحم چَا کرے، پَر تُساں کافراں کُوں دَرد ناک عذاب کنُوں بَچاوَݨ والا کوݨ ہوسی (٢٨)۔
67,29,آکھ ݙے جو او تاں ٻَہُوں مہربان ہے جِیندے اُتے اَساں اِیمان گِھن آئے ہَیں، اَتے اُوندے اِی اُتّے توکّل کریندے ہَیں، ٻَس اَجھو تُہاکُوں پَتہ لڳ ویسے، جو کوݨ کُھلّی گُمراہی وِچ ہے (٢٩)۔
67,30,آکھ ݙے، بَھلا تُساں غور کِیتے جو جیکر تُہاݙا پاݨِیں سُکّ وَن٘ڄے تاں کُوݨ تُہاݙے کِیتے تازے پاݨِیں دا چَشمہ وَہا آسے (٣٠)۔
68,1,نٓ، قَسم ہے قلم دِی، تے اُوندی جِہڑا کُجھ (قَلم والے) لِکھدے پئِن (١)۔
68,2,جو تُوں اَپݨیں رَبّ دے فضل نال پاڳل اَصلُوں کائے نِھیں (٢)۔
68,3,اَتے بیشک تیݙے کِیتے نہ مُکّݨ والا اَجر ہے (٣)۔
68,4,اَتے بیشک تُوں ٻَہُوں وَݙے تے سوہݨیں خلق والا ہیں (٤)۔
68,5,اَتے بیشک تُوں وِی ݙیکھسیں تے اِیہ (کافر وِی) ݙیکھ گِھنسِن (٥)۔
68,6,جو تُہاݙے وِچُّوں کوݨ پاڳل ہے (٦)۔
68,7,بیشک تیݙا رَبّ تاں اُوکُوں وِی خُوب ڄاݨدے جِہڑا اُوندے رَاہ کنُوں تِھڑک ڳئے تے اُنھاں کُوں وِی خُوب ڄاݨدے جِہڑے ہدایت والے رَاہ تے چَلدے وَدّے ہِن (٧)۔
68,8,ٻَس کُوڑ آکھݨ والیاں دِی ڳالھ اَصلُوں نہ مَنّیں (٨)۔
68,9,اَتے اِیہ لوک چَہندِن جو ، تُوں (مَذہب وِچ) کُجھ ڈھل ݙے، تاں او وِی کُجھ ڈھلّے تِھی ویسِن (٩)۔
68,10,اَتے کہیں اِہجے شخص دے آکھیے وِی نہ لڳݨاں، جِہڑا ٻَہُوں قَسماں چاوَݨ دا عادی ہووے، تے ذلیل شخص ہووے (١٠)۔
68,11,طعنے ݙیوݨ والا ہووے، چُغلیاں لیندا وَدّا ہووے (١١)۔
68,12,بَھلائی کرݨ کنُوں مَنع کرݨ والا ہووے حَد کنُوں وَدّھ بَدکردار ہووے (١٢)۔
68,13,بے دَردی، بد خلقا ہووے، اَتے اِیندے عِلاوہ بَد ذات ہووے (١٣)۔
68,14,اِیہ اِیں واسطے ہے جو او مال والا ہے تے پُتراں والا ہے (١٤)۔
68,15,ڄَݙاں اُوکُوں اَساݙیاں آیاتاں پَڑھ تے سُݨائیاں ویندِن تاں اَہدے جو اِیہ تاں اَڳلے وقتاں دے لوکاں دِیاں کہاݨیاں ہِن (١٥)۔
