quran[3]{c,v,t}:
  38,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  38,1,صٓ! قَسم ہے قرآن دِی، جِہڑا نصیحت اِی نصیحت ہے (١)۔
  38,2,بلکہ جِنھاں لوکاں کُفر اِختیار کِیتا ہوئے او گھمن٘ڈ وِچ تے سخت مخالفت وِچ لڳئے ہوئے ہِن (٢)۔
  38,3,اَساں انھاں کنُوں پہلے والیاں کتنیاں ساریاں اُمتّاں کُوں ڄَڑھوں پَٹ چھوڑیا ، ٻَس فریاداں کریندے رَہ ڳئے رِہائی ݙیوݨ دا وقت وِی نہ رِیہا (٣)۔
  38,4,اَتے انھاں کُوں ٻَہُوں تعجّب تِھیا، جو اُنھاں کولھ ݙراوَݨ چِتاوَݨ والا خود انھائیں وِچُوں آئے، اَتے کافِر آکھݨ لڳ پَے جو اِیہ تاں ہِک جادوگر ہے اَصلُوں کُوڑا ہے (٤)۔
  38,5,کیا اِیں ساریاں معبوداں دِی بجائے ہِک دا ہِک معبود نھیں بݨا گِھدّا؟ اِیہ تاں واقعی ہِک عجب جہی ڳالھ ہے (٥)۔
  38,6,اَتے انھاں وِچُوں جِہڑے معتبر ہَن، اِیہ اَہدے ہوئیں چَل پَے جو (اِتُّھوں) ٹُر ڄُلُو ٻَس تُساں آپݨیاں معبوداں نال ڈٹیے رَہوُو، بیشک اِیہ تاں کوئی اِہجی شَئے ہے، جیندے وِچ کوئی خاص غرض نظردِی ہے (٦)۔
  38,7,اَساں پِچھلی مِلّت وِچ اِیہوں جہی ڳالھ کائے نہ سُݨی ہاسے، یقیناً اِیہ اِیندی آپُوں گَھڑی ہوئی ڳالھ ہے (٧)۔
  38,8,کیا اَساݙے وِچُوں محض ہِیں شخص اُتے ذِکر (نصیحت) نازِل تِھیوݨِیں ہَئی؟ دَراصل اِیہ تاں میݙے ذِکر (سنیہے) دے متعلّق وِی شَک وِچ پَئے ہوئے ہِن، (کیُوں جو) انھاں اَڄّݨ میݙا عَذاب چَکھیا کائے نھیں (٨)۔
  38,9,کیا انھاں کولھ تیݙے رَبّ دِی رحمت دے خزانے ہِن (او تاں) ٻَہُوں غَلبے والا، ٻَہُوں کُجھ ݙیوَݨ والا ہے (٩)۔
  38,10,کیا اِیہ لوک اَسماناں اُتے زمین اُتے، تے جو کُجھ انھاں دے درمیان ہے سَب کُجھ اُتے اِختیار رَکھیندِن؟ بَھلا رَسّے پوڑیاں لا تے اُتے چَڑھ کیوں نھیں ویندے (١٠)۔
  38,11,اِیہ لوک تاں وَݙے لشکراں وِچُّوں ہِک لشکر ہِن، پر اِیہ اِتُّھوں شِکست کھاوَݨ والے ہِن (١١)۔
  38,12,اِنھاں کنُوں پہلے نوح دِی قوم نے، عاد، تے میخاں والے فِرعون نے وِی کُوڑا آکھیا ہَا (١٢)۔
  38,13,اَتے ثمود، تے لُوط دِی قوم نے، تے ایکہ (جنگل) دے رَہݨ والیں وِی کُوڑا آکھیا، اِیہ اِیہے وݙیاں وݙیاں ٹولیاں ہَن (١٣)۔
  38,14,انھاں ساریاں ٻَس رسُولاں کُوں کُوڑا اِی آکھیا، ٻَس انھاں کُوں میݙا عذاب آ چِمبڑیا (١٤)۔
  38,15,اَتے اِیہ کہیں شَئے دا اِنتظار نھیں پَے کریندے، سِوائے ہِک وَݙے کرکاٹ دے، جیندے وِچ کوئی سَہی نہ کڈھی ویسی (١٥)۔
  38,16,اَتے اِیہ اَہدے ہِن، جو اَساݙے رَبّ آ ! اَساکُوں حساب کتاب والے ݙین٘ہ کنُوں پہلے اِی اَساݙا حِصّہ جلدی ݙے ݙے (١٦)۔
  38,17,(اَے رسول) جو کُجھ اِیہ لوک اَکھیندے وَدّے ہِن، اِیندے اُتے صَبر چَا کر، اَتے انھاں دے سامݨیں اَساݙے بندے داؤد دِی ڳالھ چول ݙیکھ جِہڑا وَݙی حفاظت والا ہَا ، اَتے یقیناً اَساں دو رجوع کریندا ہَا (١٧)۔
  38,18,بیشک اَساں پہاڑاں کُوں اُوندے ماتحت کرݙِتا، او شام کُوں تے سِجھ اُبھرݨ ویلے اُوندے نال رَل تے اَساݙی تسبیح پڑھدے رَہندے ہَن (١٨)۔
  38,19,اَتے پَکّھی وِی کٹھے تِھیے رَہندے ہَن سارے اُوندے نال (اَللہ دو) رجوع کِیتی رَکھدے ہَن (١٩)۔
  38,20,اَتے اَساں اُوندی بادشاہی کُوں تکڑا کر چھوڑیا اَتے اُوکُوں حکمت (دانائی) ݙِتی اَتے سوہݨیں فیصلے کرݨ والیاں ڳالھیں وِی سِکھایاں (٢٠)۔
  38,21,اَتے (اَے رسول) تیݙے کولھ انھاں جھیڑے گھتّن والیاں دِی کوئی خبر وِی آئی ہے، جِہڑے جو کَندھی ٹَپ تے اَندر آ ڳئے ہِن (٢١)۔
  38,22,جِہڑے ویلے او داؤد دے سِر تے آڳئے، تاں او انھاں کنُوں گَھبرا ڳیا انھاں آکھیا ݙر نہ پِیا اَساں ݙوہائیں جھیڑا گھتیا ہوئے، اَساݙے وِچُوں ہِک نے ٻئے اُتے زیادتی کر رَکھی ہے، ٻَس تُساں اَساݙے وِچ حقّی طور تے فیصلہ کر ݙیوُو، تے بے اِنصافی اَصلُوں نہ کراہے، اَتے اَساکوں سِدّھے رَاہ تے وِی لَاوُو (٢٢)۔
  38,23,(ہِک آکھیا) دَراَصل اِیہ میݙا بِھرا ہے اِیندے کولھ وَدھانوے٩٩ دُمبیاں ہِن تے میݙے کولھ ہِکّا دُمبی ہے، وَل وِی اِیہ اَہدے جو اِیہ وِی میݙے حوالے کر چَا اَتے بحثا بحثی وِچ میکوں ہَرا ݙِتُس (٢٣)۔
  38,24,(دَاؤد) آکھیا بیشک اِیہ تیݙے اُتے ظلم ہے جو اِیہ تیݙی دُمبی وِی آپݨیاں وِچ رَلا گِھنݨ چَہندے، اَتے بیشک اَکثر سانجھ کھاتہ رَکھݨ والے ہِک ٻئے اُتے زیادتی کریندے رَہندِن، سِوائے انھاں دے، جِہڑے جو اِیمان گِھن آندِن، تے نیک عَمل کریندِن، پر اِہجے لوک ٻَہُوں تھوڑے ہِن، اَتے داؤد کُوں گُمان پِیا، جو (اِیں مقدمے وِچ) اَساں اُوکُوں اَزمایا ہے، تاں اُوں آپݨیں رَبّ کنُوں بخشش مَنگی اَتے رکُوع کریندیں ہوئیں، ڈھے پِیا، اَتے (اَللہ دو) رَجُوع کِیتُس (٢٤)۔
  38,25,بیشک اَساں اِی اُوکُوں بخش ݙِتا، اَتے اُوں (اِیں ڳالھُوں) ضرور اَساݙے نال دا سَوڑا مَرتبہ حاصِل کر گِھدّا تے وَل آوَݨ دِی جاء وِی سوہݨِیں ہِس (٢٥)۔
  38,26,اَے دَاؤد! بیشک اَساں تیکوں زمین اُتے خلیفہ بݨا ݙتے، ٻَس لوکاں وِچ اِنصافی فیصلے کِیتی رَکّھ، تے (اَپݨیں نفس دِیاں) خواہشاں اُتے نہ چَلݨاں، نہ تاں تیکُوں اَللہ دے رَاہ کنُوں تھڑکا ݙیسِن، واقعی جِہڑے لوک اَللہ دے رَاہ کنُوں تِھڑک ویندِن، اُنھاں کِیتے سَخت عذاب ہے، او تاں حساب کتاب والے ݙین٘ہ کُوں وِی وِسار چھوڑیندِن (٢٦)۔
  38,27,اَتے اَساں اَسمان کُوں تے زمین کُوں، تے جِہڑا کُجھ اُنھاں دے درمیان ہے، فضول نھیں بݨایا، اِیہ اُنھاں لوکاں دا گُمان ہے جِنھاں کُفر اختیار کر گِھدّے، اَفسوس ہے، جو کُفر کرݨ والے لوکاں کِیتے دوزخ (دا عذاب) ہے (٢٧)۔
  38,28,بَھلا کیا اَساں انھاں لوکاں کُوں جِہڑے جو اِیمان گِھن آندِن، تے نیک عَمل کریندے رَہندِن اِنھاں جیہا بݨا ݙیسُوں، جِہڑے جو زمین اُتے فساد مَچائی رَکھدِن یا پرہیزگاراں کُوں بدکار لوکاں وانگُوں بݨا ݙیسُوں (٢٨)۔
  38,29,اِیہ کتاب جِہڑی اَساں تَیں دو نازِل کِیتی ہے، وَݙیاں برکتاں والی ہے، تاں جو لوک اِیندیاں آیاتاں اُتے غور تے فِکر کرِن، تے عقل سَمجھ والے اِیں کنُوں نصیحت پکڑِن (٢٩)۔
  38,30,اَتے اَساں داؤد کُوں سلیمان (جیہا پُتر) ݙِتا، او ٻَہُوں چَن٘ڳا ٻانھاں ہَا (٣٠)۔
  38,31,بیشک او (اَللہ دو) رَجُوع کرݨ والا ہَا (ہِک دَفعہ) ڄَݙاں اُوندے سامݨیں شام کُوں ٻَہُوں تِکّھے تے خاصے گھوڑے پیش کِیتے ڳئے (٣١)۔
  38,32,تاں اُوں آکھیا، مَیں دَراَصل آپݨیں رَبّ دے ذِکر کرݨ دے سَببُوں انھاں چَن٘ڳیاں شَئیں نال وِی محبت کرینداں پِیاں اِیہ توڑیں جو او اَکّھیں کنُوں اُوڈھر تِھی ڳئے (٣٢)۔
  38,33,آکھیُس جو انھاں کُوں میݙے کولھ ذَری وَلا گِھن آؤ، ٻَس اُوں اُنھاں دِیاں ڄَنگھاں تے ڳِچّیاں اُتے ہَتھ پھیریا (٣٣)۔
  38,34,اَتے تحقیق اَساں سلیمان کُوں اَزمایا، اَتے اُوندے (اقتدار دِی) کُرسی تے بے جان جُسہ جیہا ٻَہلا ݙِتا، وَل تاں اُوں (اَللہ دو) پُورا رَجوع کِیتا (٣٤)۔
  38,35,دُعا مَنگی، جو میݙے رَبّ آ، میکوں بخش ݙے، اَتے میکوں اِہجی حکومت ݙے چا، جِہڑی جو میݙے بعد کہیں ٻئے کُوں نہ چھَک سَڳے، بیشک تُوں سَب کُجھ ݙیوݨ والا ہیں (٣٥)۔
  38,36,ٻَس اَساں ہوا کُوں اُوندے ماتحت کر ݙِتا، جِہڑی اُوندے حُکم نال تھرام نال گُھلدی ہَئی، ڄݙے وِی اُوکُوں وَن٘ڄݨاں ہوندا (٣٦)۔
  38,37,اَتے جِنّاں کُوں وِی اُساری کرݨ والیاں کُوں وِی، تے ٹُٻّی مار تے شَئیں کڈھ آوَݨ والیاں کُوں وِی (٣٧)۔
  38,38,اَتے جِنّاں کُوں وِی جِنھاں کُوں جُولان مارے ہوئے ہوندے ہَن (٣٨)
  38,39,(اَللہ آکھیا) اِیہ ہِن اَساݙیاں بخشیشاں! چاہے تُوں لوکاں اُتے ، انھاں نال احسان کِیتی رَکّھ یا چَہویں تاں ہَتّھ جَھل رَکھ، اِیندی کُوئی پُچّھ پرتیت نہ کِیتی ویسے (٣٩)۔
  38,40,اَتے بیشک اُوندے کِیتے تاں اَساݙے ٻَہُوں نال ٻَہݨ دا مَرتبہ ہے، تے ٻَہُوں چَن٘ڳا اَنجام ہے (٤٠)۔
  38,41,اَتے اَساݙے ٻانھیں اَیوب دِی ڳالھ وِی چول، ڄَݙاں اُوں آپݨیں رَبّ کُوں سَݙیا، جو شیطان نے میکُوں تکلیف وِچ تے عذاب وِچ سَٹیا ہوئے (٤١)۔
  38,42,تُوں آپݨاں پَیر زمین تے مار، اِیہ ہے ٹھڈا پاݨِیں، ٻَس دَھاوَݨ کِیتے وِی تے پِیوَݨ کِیتے وِی (٤٢)۔
  38,43,اَتے اَساں اُوکُوں اُوندے بندے وِی وَلا آ ݙِتے، اَتے انھاں جِتّی ٻئے وِی اِیہ اَساݙی رحمت ہَئی، اَتے آپݨیں ہَتھ وِچ تیلیاں دِی مُٹھ چَا گِھن (٤٣)۔
  38,44,اَتے اُوندے نال اُوکُوں مار تے (قسم پُوری کر) قسم نہ پِیا تروڑ، بیشک اَساں اُوکُوں صَبر کرݨ والا چَن٘ڳا ٻانھاں پاتا، بیشک او (رَبّ دو) رَجُوع کرݨ والا ہَا (٤٤)۔
  38,45,اَتے (اَے رسول) تُوں اَساݙے ٻانھیاں اِبراہیم، اِسحٰق تے یعقوب دا ذِکر وِی چلا، جِہڑے جو تَکڑے ہَتّھاں والے تے ݙُونگھیاں نَظراں وَالے ہَن (٤٥)۔
  38,46,بیشک اَساں انھاں کُوں آخرت دے گھر کُوں یاد رَکّھݨ دا پیغام پُچاوَݨ کِیتے خاص کر گِھدّا (٤٦)۔
  38,47,اَتے یقیناً او اَساݙے کِیتے چُݨے ہوئے نیک بندیاں وِچُوں ہِن (٤٧)۔
  38,48,اَتے اِسمٰعیل، اَلیَسَعَ تے ذُوالکِفل دِی یاد وِی تازہ کر، جو او سارے نیک بندیاں وِچُوں ہِن (٤٨)۔
  38,49,اِیہ ہِک نصیحت ہے بیشک پرہیزگاراں کِیتے، ٻَہُوں سوہݨِیں جاء ہے (٤٩)۔
  38,50,سَدا بہار بہشتی باغ! جِنھاں دے دروازے انھاں کِیتے کُھلے رَہسِن (٥٠)۔
  38,51,انھاں وِچ تَکیئے دِی ٹیک لَا تے ٻیٹھے ہوسِن، اَتے اُتّھاں ڈھیر قِسم دے میوے تے پِیوَݨ دِیاں شَئیں مَنگویسِن ٻیٹھے (٥١)۔
  38,52,اَتے انھاں کولھ ذالیں ہوسِن جِھکیاں نَظراں والیاں، اُنھاں دِیاں سینگیاں (٥٢)۔
  38,53,اِیہُو کُجھ ہے، جِیندا تُہاݙے نال حِساب کِتاب والے ݙین٘ہ وَعدہ کِیتا ویندے (٥٣)۔
  38,54,یقیناً اِیہُو اَساݙا ݙِتا رِزق ہے، جِیندے وِچ کوئی کَمی نہ آسی (٥٤)۔
  38,55,اِیہ تاں انھاں کِیتے ہے پَر یقیناً سَرکش (نافرمان) لوکاں کِیتے وَلا وَن٘ڄ رَہݨ دِی ٻَہُوں گَندی جاء ہے (٥٥)۔
  38,56,او دوزخ ہے! جِیندے وِچ اِیہ وَڑسِن، ٻَس او ٻَہُوں گَندہ ٹِکاݨاں ہے (٥٦)۔
  38,57,اِیہ گِھنّو، ٻَس اُٻَلدا پاݨِیں، تے رَتّ پُوں دے مَزّے چَکّھو! (٥٧)۔
  38,58,اَتے اِیں طرح اُنھاں دے ݙا، دِیاں ٻِیاں سزائیں وِی ہوسِن (٥٨ )۔
  38,59,اِیہ ہِک جماعت ہے جِہڑی تُہاݙے نال داخِل تِھیوَݨ والی ہے اِنھاں کُوں کوئی مَرحبا (جِی آیاں کُوں) آکھݨ والا کائے نھیں ، او بھا وِچ ضرور داخِل تِھیوَݨ والے ہِن (٥٩)۔
  38,60,او (گُمراہ کرݨ والیاں کُوں) اَکھیسِن، اِیہ تاں تُساں اِی ہِیوے جِنھاں کِیتے تاں کوئی خوشی وِی نہ ہووے، تُساں اِی (اِیہ مصیبت) اَساݙے کِیتے پہلے کنُوں تیار کر گِھدّی ہے، اِیہ تاں رَہݨ کِیتے ٻَہُوں گَندی جاء ہے (٦٠)۔
  38,61,او اَکھیسِن ، اَساݙے رَبّ آ! جَیں پہلے اِی اَساݙے کِیتے اِیہ مصیبت کھڑی کِیتی ہے، اُوندے کِیتے تاں دوزخ دے عذاب کُوں ݙوڑا کر تے وَدھا ݙے (٦١)۔
  38,62,اَتے اکھیسِن جو اَساکوں تِھی کیا ڳئے جو اَساں اُنھاں جُواناں کُوں کِتھائیں نھیں پَے ݙیکھدے جِنھاں کُوں اَساں گَندے لوکاں وِچُوں ڳِݨدے ہاسے(٦٣)۔+H4075
  38,63,کیا اَساں اِیویں اُنھاں کُوں گَھٹیا سَمجھیا ہویا ہَا یا اَساݙیاں اَکّھیں اُنھاں اُتے وِٻل ڳیاں ہِن (٦٢)۔
  38,64,بیشک دوزخ دِی بھا والیاں دا جھیڑا بالکل حقیقت ہے (٦٤)۔
  38,65,اَے رسولؐ آکھ ݙے جو حقیقت وِچ مَیں تاں محض ݙَراوَݨ چِتاوَݨ والا ہَاں جو کوئی وِی معبود کائے نھیں سِوائے اَللہ دے جِہڑا ہِک دا ہِک ہے تے وَݙے قَہر وَساوَݨ والا ہے (٦٥)۔
  38,66,او مالک ہے اَسماناں تے زمین دا، تے جِہڑا کُجھ انھاں دے اَدھ وِچ ہے او زبردست وِی ہے تے اَصلُوں بخش ݙیوَݨ والا وِی (٦٦)۔
  38,67,آکھ ݙے جو اِیہ ہِک ٻَہُوں وَݙی خبر ہے (٦٧)۔
  38,68,جَیں کنُوں تُساں آپݨاں مُن٘ہ پھیر گِھندے وے (٢٨)۔
  38,69,میکُوں تاں وَݙیاں سرداراں دِی مجلس دا کوئی عِلم وِی کائے نھیں ڄَݙاں جو او بحثاں وِچ لڳئے ہوئے ہِن (٦٩)۔
  38,70,میݙے کولھ تاں وَحی اِیں ڳالھ دِی بھیڄی ڳئی ہے، جو دَراَصل میں کُھلا ݙُلا ݙَراوَݨ چِتاوَݨ والا ہَاں (٧٠)۔
  38,71,(یاد کر) ڄَݙاں تیݙے رَبّ فرشتیاں کُوں آکھیا، جو مَیں مِٹی (دے گارے) کنُوں بَشر بݨاوَݨ والا ہَاں (٧١)۔
  38,72,ٻَس جِہڑے ویلے اُوکُوں ٹِھیک ٹھاک بݨا گِھنّاں ، تے اُوندے وِچ اَپݨیں رُوح دا پُھوکا مار گِھنّاں، تاں اُوندے اَڳوں سَجدے کِیتے ڈھے پُووَاہے (٧+H4073)۔
  38,73,ٻَس سارے دے سارے فرشتیاں سَجدہ کِیتا (٧٣)۔
  38,74,سِوائے اِبلیس (شیطان) دے ، اُوں وَݙائی (پُھوت) ݙیکھائی تے او کافراں وِچُوں تِھی ڳیا (٧٤)۔
  38,75,اَللہ آکھیا، اِبلیس آ ! تیکوں کِہڑی شَئے روکیے جو تَیں اُوکُوں سَجدہ نھیں کِیتا؟ اُوکُوں جیکوں مَیں آپݨیاں ہَتّھاں نال جوڑے بݨائے، تُوں کہیں وݙائی وِچ آ ڳئیں یا تُوں کوئی اُچّے مرتبے والیاں وِچُوں تِھی ڳئیں (٧٥)۔
  38,76,اُوں آکھیا، مَیں اِیں کنُوں وَدّھ ہَاں، تَیں میکوں بَھا وِچُوں پَیدا کِیتے، اَتے اِیکُوں مِٹی گارے وِچُوں پَیدا کِیتے (٧٦)۔
  38,77,(اَللہ) آکھیا، ٻَس نِکل وَن٘ڄ اِتُّھوں تُوں تاں اَصلُوں مَردود ہیں (٧٧)۔
  38,78,اَتے یقیناً تیݙے اُتے قیامت دے ݙین٘ہ توڑیں میݙی لعنت وَسدی رَہسی (٧٨)۔
  38,79,اُوں آکھیا، میݙے رَبّ آ ! ٻَس میکُوں لوکاں دے وَلا اُٹھا کرݨ والے ݙین٘ہ توڑیں مُہلت چَا ݙے؟ (٧٩)۔
  38,80,(اَللہ) آکھیا ، چَلو، بالکل تُوں مُہلت ݙِتے ڳیاں وِچُوں تِھی ڳیُوں ! (٨٠)۔
  38,81,اُوں ݙین٘ہ توڑِیں ، جیندا وَقت مقرر ہے (٨١)۔
  38,82,اِبلیس آکھیا تیݙی عِزّت تے عظمت دِی قَسم مَیں انھاں ساریاں کُوں گُمراہ کر ݙیکھیْساں (٨٢)۔
  38,83,ٻَس سِوائے تیݙے اُنھاں ٻانھیاں دے جہڑے تیݙے چُݨے ہوئے ہِن (٨٣)۔
  38,84,اَللہ آکھیا ٻَس اِیہ حق دِی ڳالھ ہے تے مَیں حق دِی ڳالھ کریندا رَہنداں (٨٤)۔
  38,85,جو مَیں تیْکوں اَتے جِہڑے تیݙی پَیروی کریْسِن انھاں ساریاں نال دوزخ کُوں بَھر ݙیساں (٨٥)۔
  38,86,اَے رسول آکھ ݙے، جو مَیں نہ اِیں (قرآنی تبلیغ) دِی مَزدُوری تُساں کنُوں گِھنداں، تے نہ مَیں کوئی وَل پھیر کرݨ والیاں وِچُّوں ہَاں! (٨٦)۔
  38,87,اِیہ تاں کُل جہاناں والیاں کِیتے محض نصیحت ہے (٨٧)۔
  38,88,اَتے اَلبتہ کُجھ مُدّت دے بعد تُہاکُوں اِیندا اَصل پَتہ لڳ ویسے (٨٨)۔
