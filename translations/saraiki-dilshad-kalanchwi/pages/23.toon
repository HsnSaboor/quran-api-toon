quran[3]{c,v,t}:
  23,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  23,1,تحقیق اِیمان گِھن آوَݨ والے اِی کامیاب تِھی ڳئے(١)۔
  23,2,جِہڑے جو نماز وِچ عاجزی تے جھِکّ نوائی کریندے ہِن(٢)۔
  23,3,اَتے جِہڑے جو بیہودہ ڳالھِیں کنُوں مُن٘ہ پھیری رَہندِن(٣)۔
  23,4,اَتے جِہڑے جو زکوٰۃ یعنی تَزکیئے والے کَمّاں کُوں وِی کِیتی رَکھدِن(٤)۔
  23,5,اَتے جِہڑے جو اَپݨیں ننگیج کُوں بَچائی رَکھدِن(٥)۔
  23,6,سِوائے آپݨیں ذالیں دے یا جِہڑیاں (لون٘ڈیاں) اُنھاں دِی مِلک ہُوندِن، ٻَس اُنھاں دے معاملے وِچ اُنھاں اُتّے کوئی مَلامت کائے نھیں(٦)۔
  23,7,جیکر انھاں کنُوں علاوہ اَڳُوں تے وَدّھدِن تاں وَل او زیادتی کرݨ والے ہِن(٧)۔
  23,8,اَتے جِہڑے آپݨیاں اَمانتاں اَتے آپݨیاں وعدیاں دَا دِھیان رَکھی رَکھدِن(٨)۔
  23,9,اَتے جِہڑے آپݨیاں نمازاں پُوری اِحتیاط نال اَدا کریندِن(٩)۔
  23,10,اُنھائیں لوکاں کُوں وِراثت مِلسے(١٠)۔
  23,11,اِیہے بَہشت (فِردوس) دے وارث ہوسِن، اَتے ہَمیشہ کِیتے اُوندے وِچ رَہسِن(١١)۔
  23,12,اَتے تحقیق اَساں اِنسان کُوں مِٹّی دے سَت کنُوں پَیدا کِیتے(١٢)۔
  23,13,وَل اَساں اُوکُوں ہِک نُطفے دِی شَکل وِچ ہِک محفوظ جاء تے رَکھیا(١٣)۔
  23,14,وَل اِیں نُطفے کنُوں ڄَمّے ہوئے لَہُو دِی لوتھ بݨائی وَل اِیں ڄَمئے ہوئے لَہُو دِی لوتھ کنُوں ٻوٹِی جہی بݨائی، وَل اِیں ٻوٹی دِیاں ہَݙیاں وِی بݨائیاں، وَل اُنھاں ہَݙیاں اُتّے گوشت (ماس) مَڑھ چھوڑیا، آخر اُوکُوں ہِک ٻَئے بندے (مخلوق) دِی شکل وِچ بݨا چھوڑیا، ٻَس اَللہ ٻَہُوں بَرکتاں والا تے ساریْاں کنُوں بہتر پَیدا کرݨ والا ہے(١٤)۔
  23,15,اِیندے بعد وَل تُساں ضرور مَر ویندُو(١٥)۔
  23,16,بیشک تُہاکُوں قیامت دے ݙین٘ہ وَلا جِیوا کَھڑایا ویسے(١٦)۔
  23,17,اَتے تحقیق اَساں تُہاݙے اُتّے سَت رَستے (طبق) بݨا چھوڑے ہِن، اَتے اَساں آپݨیں مخلوق (دے تقاضیاں) کنُوں غافِل کائے نِسّے(١٧)۔
  23,18,اَتے اَساں اَسمان کنُوں آپݨیں اندازے دے مطابق پاݨِیں نازِل کِیتا ٻَس اَساں اُوکُوں زمین وِچ کَھڑا چھوڑے، اَتے بیشک اَساں اُوکُوں اُݙَا پُݙَا (سُکّا) چھوڑَݨ تے وِی پُوری قُدرت رَکھیندے ہَیں(١٨)۔
  23,19,وَل اَساں تُہاݙے کِیتے اِیں پاݨِیں نال کَھڄّیاں دے، تے انگوراں دے باغ تیار کر ݙِتّے، اُنھاں وِچ تُہاݙے کِیتے ٻَہُوں سارے مَزیدار میوے ہِن، اَتے تُساں اُنھاں وِچُوں کَھاندے وِی رَہندے وے(١٩)۔
  23,20,اَتے او دَرخت (زیتون) وِی پَیدا کِیتا، جِہڑا جو طورِ سِینا وِچُوں ڄَمّ پَوندے، اَتے کھاوَݨ والیاں کِیتے تِھندھاج تے چَہراری جہی شَئے آپݨیں وِچُوں کَڈھیندا رَہندے(٢٠)۔
  23,21,اَتے بیشک تُہاݙے کِیتے ڈھان٘ڈیاں (جانوراں) وِچ وِی سَبق یعنی عِبرت دِی جاء ہے، اَساں اُنھاں دے ڈھڈھ وِچُوں ہِک شَئے تُہاکُوں پِلیندُوں، اَتے تُہاݙے کِیتے اُنھاں وِچ ٻَہُوں سارے فائدے وِی ہِن، اَتے اُنھاں (دے گوشت) کُوں وِی تُساں کھاندے ہِیوے(٢١)۔
  23,22,اَتے اُنھاں اُتّے تے ٻیڑیاں اُتّے تُہاکُوں سوار وِی کِیتا ویندے(٢٢)۔
  23,23,اَتے تحقیق اَساں نُوح کُوں اُوندی قَوم دو بھیڄیا، ٻَس اُوں آکھیا، اَے میݙی قَوم! محض اَللہ دِی عبادت کرو، تُہاݙے کِیتے اُوں کنُوں سِوا کوئی معبود کائے نھیں، کیا تُساں (شِرک کنُوں) ݙَردے وِی نھیوے؟(٢٣)۔
  23,24,ٻَس اُنھاں لوکاں دِی قَوم دے سرداراں، جِنھاں (اِیمان گِھن آوَݨ کنُوں) اِنکار کِیتا ہوئیا ہَا، آکھیا اِیہ تاں کُجھ وِی کائے نھیں، ٻَس تُساں جیہا ہِک معمولی بَشر ہے، اِیہ چَہندے جو تُساݙے اُتّے آپݨیں وَݙائی (سرداری) قائِم کر گِھنّے، اَتے جیکر اَللہ بھیڄݨ چَہندا تاں فرشتے اِی بھیڄ ݙیوے ہَا، اَساں اَڳلے وَقت دے آپݨیاں پِیؤ ݙاݙیاں کنُوں اِیہُو جہی ڳالھ سُݨی وِی کائے نھیں(٢٤)۔
  23,25,اِیہ تاں ہِک جوان ہے، جنُونی دا ماریا! ٻَس تُساں کُجھ ݙین٘ہاڑے اِنتظار کر تے ݙیکھ گِھنُّو(٢٥)۔
  23,26,(نوح) آکھیا، میݙے رَبّ آ، میݙی مَدد کر انھاں تاں میکُوں کُوڑا آکھ چھوڑے(٢٦)۔
  23,27,ٻَس اَساں اُوندے کولھ وَحی بھیڄی جو اَساݙے سامݨیں اَتے اَساݙے حُکم دے مطابق ہِک ٻیڑی بݨا، وَل ڄَݙاں اَساݙا حُکم تِھی وَن٘ڄے، تے تنور وِچُوں پاݨِیں نِکلݨ پَے وَن٘ڄے تاں اِیں ٻیڑی وِچ ہَر قِسم دے جانوراں وِچُوں نَر مادہ دَا ہِک ہِک جوڑا ٻیڑی وِچ ٻَہلا گِھنیں، اَتے گَھر والیاں کُوں وِی سوائے اُنھاں دے جِنھاں دے مُتعلّق پہلے کنُوں فیصلہ تِھی چُکیا ہے، اَتے جِنھاں لوکاں (میکُوں نَہ مَن تے) خُود اَپݨیں اُتّے ظُلم کِیتے اُنھاں دے متعلّق میکُوں کُجھ نَہ آکھیں، او تاں ضرور غَرق کر ݙِتّے ویسِن(٢٧)۔
  23,28,ٻَس جِہڑے ویلے تُوں اَپݨیں نال دے بندیاں سمیت ٻیڑی تے ٻَہ وَن٘ڄیں، تاں آکھیں جو ساریاں تعریفاں اَللہ کِیتے دِیاں ہِن، جیں اَساکُوں ظالم لوکاں دِی قَوم کنُوں نِجات ݙِتّی ہے(٢٨)۔
  23,29,اَتے اِیہ وِی آکھیں جو رَبّ آ! میکُوں کہیں برکتاں والی جاء تے لَہاویں، تُوں تاں ساریْاں تُوں چَن٘ڳا لَہا ٻَہلاوَݨ والا ہیں(٢٩)۔
  23,30,بیشک اِیں (قِصّے) وِچ اَساݙِیاں نشانیاں ہِن، اَتے اَساں تاں (انھاں دے ذریعے) آزمائشاں کریندے رَہندے ہَیں(٣٠)۔
  23,31,وَل انھاں دے بعد اَساں ہِک ٻَئی جماعت کَھڑی کر کھڑائی (٣١)۔
  23,32,ٻَس اَساں اُنھاں وِچ اُنھاں وِچُوں دا ہِک رسول بھیڄیا، (جیں آکھیا) جو محض اَللہ دِی اِی عِبادت کِیتی کرو، تُہاݙے کِیتے اُوں کنُوں سِوا ٻِیا کوئی معبود کائے نھیں،کیا اَڄݨ وِی (شِرک کَرݨ کنُوں) نِھیوے ݙَردے(٣٢)۔
  23,33,اَتے اُوں قَوم دے سَرداراں، جِہڑے جو اِیمان گِھن آوَݨ کنُوں اِنکار کَر چُکئیے ہَن، اَتے آخرت دے آوَݨ کُوں وِی کُوڑا آکھ چُکیئے ہَن، ٻِیا اِیہ جو اَساں اُنھاں کُوں دُنیاوی حَیاتی وِچ وِی ٻَہُوں سَوکھا رَکھیا ہوئیا ہَا، آکھݨ لَڳے، اِیہ شخص تَاں کوئی شَئے کائے نھیں، سِوائے اِیندے جو تُہاݙے وانگُوں ہِک معمولی جیہا بَشر ہے، اِیہ وِی اُوہو کُجھ کَھاندے جِہڑا کُجھ تُساں کھاندے وے، تے اِیہ وِی اُوہو کُجھ پِیندے جِہڑا کُجھ تُساں پِیندے وے(٣٣)۔
  23,34,اَتے جیکر تُساں واقعی اَپݨیں جیہے بَشر دِی پَیروی کریندے وے تاں بیشک تُساں گھاٹا چَاوَݨ والے تِھی ویسُو(٣٤)۔
  23,35,کیا او تُہاݙے نال اِیہ پَکّی کریندے، جو ڄَݙاں تُساں مَر ویسو، اَتے مِٹّی تِھی ویسُو، تے ہَݙیاں رَہ ویسُو، کیا وَت وِی تُساں زمین وِچُوں اُٹَھا کھڑے کِیتے ویسُو؟(٣٥)۔
  23,36,ٻَہُوں پَرے ہے، ٻَہُوں پَرے ہے، حقیقت کنُوں جِہڑی ڳالھ دَا تُہاݙے نال وَعدہ کِیتا ویندا پَے(٣٦)۔
  23,37,اَساݙی زِندگی تاں ٻَس اِیہا دُنیاوی زِندگی اِی ہے، جِتَّھاں اَساں مَردے وِی ہَیں تے ڄَمدے وِی ہَیں، اَتے اَساں وَلا جِیوا تے کَھڑے کائے نَہ کِیتے ویسُوں(٣٧)۔
  23,38,اِیہ تاں ہِک اِہجا جُوان ہے، جیں اَللہ اُتّے کُوڑا بُہتان چا ٻَدّھے، اَساں اِیکُوں مَنَّݨ والے کائے نِسّے(٣٨)۔
  23,39,(رسول) آکھیا، میݙے رَبّ آ! میݙی مَدد چَا کر، اُنھاں تاں میکُوں کُوڑا چَا آکھیئے(٣٩)۔
  23,40,اَللہ آکھیا، اِیہ لوک ٻَہُوں جَلدی اَرمانی تِھی تے رَہ ویسِن(٤٠)۔
  23,41,اُنھاں کُوں اِنصافی طور تے زور دے ہِک کَڑکاٹ آن پَکڑیا، اَساں اُنھاں کُوں ٻُھوں ٻَکل کر چھوڑیا، ٻَس ظلم کَرݨ والی قَوم اُتّے لعنت ہے(٤١)۔
  23,42,وَل اَساں اُنھاں دے بعد ٻِیاں قَوماں کُوں اُٹَھا کَھڑایا(٤٢)۔
  23,43,کوئی قَوم اَپݨیں وَقت کنُوں پہلے نہ کَݙاہِیں خَتم تَھئی ہے، تے نہ اُوندے بعد رَہ سَڳی ہے(٤٣)۔
  23,44,وَل اَساں ہِک ٻَئے دے پِچُّھوں کَئی رَسول بھیڄے ڄَݙاں کَݙاہِیں کَہیں اُمّت دے کولھ اُوندا رسول آندا ہَا، تاں او اُوکُوں کُوڑا چَا اَکھیندے ہِن، ٻَس اَساں وِی ہِک دے بعد ٻَئی قَوم کُوں تَباہ تے برباد کر ݙیندے رِیہے ، اِیہ توڑِیں جو اُنھاں دِیاں کَہاݨیاں اِی باقی رَہ ڳِیاں، ٻَس جِہڑے لوک اِیمان نھیں گِھن آندے اُنھاں اُتّے لعنت ہے(٤٤)۔
  23,45,وَل اَساں مُوسیٰ تے اُوندے بِھرا ہَارون کُوں بھیڄیا، اُنھاں کولھ اَساݙِیاں نِشانیاں وِی ہَن، تے ہِک کُھلّی دلیل وِی(٤٥)۔
  23,46,اِیہ فِرعون تے اُوندے سَرداراں کولھ ڳئے، پَر اُنھاں پَروا نَہ کِیتی، اَتے او سَرکَش قَوم ٻَݨ ڳئے(٤٦)۔
  23,47,ٻَس آکھݨ لڳئیے کیا اَساں اَپݨیں سَن٘وّیں ݙُوں آدمیاں اُتّے اِیمان گِھن آؤں حالانکہ اُنھاں دِی قَوم دے بَندے تَاں اَساݙے غُلام ہِن(٤٧)۔
  23,48,ٻَس اُنھاں اُنھاں ݙُوہائیں کُوں کُوڑا چَا آکھیا اِیں ڳالھُوں او تَباہ تِھی وَن٘ڄݨ والیاں وِچُوں تِھی ڳئے(٤٨)۔
  23,49,اَتے تحقیق اَساں مُوسیٰ کُوں کِتاب (تورات) ݙِتی، مَتاں او لوک ہِدایت تے آوَن٘ڄِن(٤٩)۔
  23,50,اَتے اَساں مَریم دے پُتر تے خُود اُوندی مَاء کُوں ہِک نِشانی چَا بݨایا، اَتے اُنھاں کُوں ہِک اُچّی جاء تے پَناہ ݙے ݙِتّی، جِہڑی جو رَہݨ دے ݙَا دِی ہَئی اَتے جِتَّھاں پاݨِیں وِی وَہندا پِیا ہَا(٥٠)۔
  23,51,اَتے رسولو! تُساں پاک صاف شَئیں وِچُوں کھاؤ پِیؤُو، تے اِصلاح دے کَمّ کِیتی رَکّھو، بیشک جِہڑا کُجھ تُساں کریندے وَدّے وے، مَیں چَںڳی طرح اُوکُوں ڄاݨدا کَھڑاں(٥١)۔
  23,52,اَتے بیشک اِیہا تُہاݙی اُمّت اِی ساری ہِکّا کُجھ ہے، تے مَیں تُہاݙا پاَلَݨ ہَار ہَاں، ٻَس تُساں مَیں کنُوں ݙردے رَہوُو(٥٢)۔
  23,53,پر لوکاں آپس وِچ آپݨیں مُعاملے (دِین) دے حِصّے بَخرے کر گِھدّے تے ہَر ہِک ٹولی جِہڑا کُجھ آپݨاں بݨا گِھدّے اُوندے اُتّے خُوش ہے(٥٣)۔
  23,54,ٻَس (اَے رسول) اُنھاں کُوں کُجھ مُدّت کِیتے غفلت دے دَریا دے وِچ غوطے کھاندا چھوڑ ݙے (٥٤)۔
  23,55,کیا اِیہ لوک اِیہُو خیال کریندِن، جو کیُوں جو اَساں اُنھاں کُوں مال مَتال تے ٻَالاں ٻَچیاں نال وَدّھایا پَھلایا ہے(٥٥)۔
  23,56,تے اِیں طَرح اَساں اُنھاں نال دَبا دَب بَھلائیاں کریندے رَہسُوں، کوئے نہ! اُنھاں کُوں تاں اَصلُوں سَمجھ وِی نھیں پَئی آندی(٥٦)۔
  23,57,اَصل تاں اُوہے لوک ہِن، جِہڑے اَپݨیں رَبّ دے عَذاب کنُوں ݙَردے رَہندِن(٥٧)۔
  23,58,اَتے جِہڑے اَپݨیں رَبّ دِیاں نِشانیاں تے اِیمان رَکھیندِن(٥٨)۔
  23,59,اَتے جِہڑے کہیں ٻَئے کُوں اَپݨیں رَبّ دا شریک نہیں بݨیندے(٥٩)۔
  23,60,اَتے جِہڑے جو کُجھ ݙیوݨ جوگے ہِن، ݙِتّی رَہندے ہِن، اَتے اںھاں دے دِل اِیں ڳالھُوں کَن٘بدے رَہندِن جو او اَپݨیں رَبّ دو ضرور وَل وَن٘ڄݨ والے ہِن(٦٠)۔
  23,61,اِیہے لوک بَھلائی دے کَمَّاں وِچ جَلدی کریندِن، اَتے اِیہے اِہجِیْاں کَمّاں وِچ اَڳُوں لَنگھ وَن٘ڄݨ والے ہِن(٦١)۔
  23,62,اَتے اَساں کہیں شَخص کُوں اُوندی وُسکت (وسعت) کنُوں زیادہ کوئی تَکلیف نِسّے ݙیندے، اَتے اَساݙے کولھ ہِک کتاب (رِیکارݙ) ہے، جِہڑی ٹِھیک ٹِھیک حال ݙَسیندی ہے، اَتے انھاں لوکاں اُتے ہرگز ظُلم نَہ کِیتا ویسے(٦٢)۔
  23,63,بلکہ اُنھاں دے دِلّ اِیں حقیقت کنُوں غفلت (دے دَریا) وِچ غوطے کَھاندے وَدّے ہن، اَتے انھاں دے عَمل جِہڑے جو اِیہ کریندے وَدّے ہِن، اِنھاں دے خِلاف وِی تاں ہِن(٦٣)۔
  23,64,اِیہ ٻَس او توڑِیں ہِن، ڄَݙاں جو اَساں اُنھاں وِچُوں دے عَیش کرَݨ والیْاں کُوں، عَذاب وِچ پَکڑ گِھنسُوں، تَݙاں او فوراً چِیکَݨ پَے ویسِن(٦٤)
  23,65,اَڄ دے ݙین٘ہ رُوِݨ پِٹَّݨ بیْکار ہے، کِیُوں جو تُہاکُوں اَساں کنُوں کوئی مَدد اَصلُوں نَہ مِلسے(٦٥)۔
  23,66,تحقیق میݙیاں آیاتاں تُہاکُوں پَڑھ تے سُݨائیاں ویندِیاں ہَن، پَر تُساں سُݨ تے اَپݨیں وَلدے پَیریں بھڄ ویندے ہَاوے(٦٦)۔
  23,67,وَݙِائیاں ݙیکھیندے ہَاوے، اَتے تُساں (راتیں کُوں) بیہُودہ بَکواس ٻَہ مریندے ہاوے(٦٧)۔
  23,68,کیا اُنھاں اِیں کَلام اُتّے غور نھیں کِیتا، یا اُنھاں کولھ کوئی اِہجی شَئے آڳئی ہے جِہڑی جو اُنھاں دے پہلے والے پِیؤ ݙاݙیاں کولھ کَݙائِیں نَہ آئی ہَئی(٦٨)۔
  23,69,کیا او اَپݨیں رسول کُوں ڄاݨڈے سُن٘ڄاݨدے کائے نھیں، کِیُوں جو اُنھاں کُوں نھیں مَنیندے(٦٩)
  23,70,یَا وَت اِیہُو آہدِن، جو اِیکُوں جِنّ ہَن، حالانکہ او تاں اُنھاں کولھ سَچّ گِھن تے آئے، پَر اِنھاں دے ڈھیر لوک حَق کنُوں وِی کریہت (نفرت) کریندے ہَن(٧٠)۔
  23,71,اَتے جیکر حَق اُنھاں دِیاں خُواہِشاں دے مطابق کَمّ کرے تاں واقعی اَسماناں تے زمین تے اَتے جِہڑا کُجھ اُنھاں وِچ ہے اُوندے متعلّق دے سارے اِنتظام وِچ گڑبڑ تِھی وَن٘ڄے، بلکہ اَساں تاں اُنھاں کولھ اُنھاں دِی آپݨِیں ذِکر (نصیحت والی کِتاب) بھیڄی ہے، پَر او اَپݨیں اِیں (نصیحت والی کِتاب) کنُوں مُن٘ہ پھیر گِھندِن(٧١)۔
  23,72,کیا تُوں اُنھاں کنُوں کوئی عِوضاݨاں (صِلّہ) مَن٘گدیں، حالانکہ تیݙے رَبّ دا ݙِتّا ہویا صِلّہ ٻَہُوں چَن٘ڳا ہے، اَتے رِزق ݙیوݨ والیاں ساریاں کنُوں او زیادہ چَن٘ڳا ہے(٧٢)۔
  23,73,اَتے بیشک تُوں تاں اُنھاں کُوں سِدّھے رَاہ تے چَلَّݨ کُوں اَکھیندیں(٧٣)۔
  23,74,اَتے بیشک جِہڑے لوک آخرت اُتے اِیمان نھیں گِھن آندے، او سِدّھے رَاہ کنُوں ضرور ہَٹّے ہوئے ہِن (٧٤)۔
  23,75,اَتے جیکر اَساں اُنھاں اُتے رحم کروں، اَتے اُنھاں کنُوں او تکلیف پَرے کر گِھنُّوں، تاں او برابر آپݨِیں نافرمانی وِچ لَڳئے ہوئے سِر وَدّے مریسِن(٧٥)۔
  23,76,اَتے تحقیق اَساں اُنھاں کُوں عَذاب وِچ پَکڑ گِھدّا، تاں وِی نَہ او اَپݨیں رَبّ دے اَڳُوں نِویے، اَتے نہ (اُوندے اَڳُوں) عاجزی کِیتی ہِینے(٧٦)۔
  23,77,اَلبتہ ڄَݙاں اَساں اُنھاں اُتّے عَذاب دَا دَروازہ کھول ݙِتّا، تاں او اُوں ویلے اِیں سَختی وِچ ہَر پاسُوں نا اُمید تِھی تے رَہ ویسِن(٧٧)۔
  23,78,اَتے او تاں او ہَستی ہے جیں تُہاکُوں سُݨݨ تے ݙیکھݨ دِی طاقت ݙِتّی ہے، اَتے (سوچَݨ سَمجھݨ کِیتے) دِلّ ݙِتّے، پَر تُساں اُوندا ٻَہُوں تھوڑا شُکر اَدا کریندے وے(٧٨)۔
  23,79,اَتے او تَاں اُوہو ہے جیں تُہاکُوں زمین اُتّے وَدھائے کِھن٘ڈائے اَتے تُساں اُوں دو کَٹّھے کِیتے ویسُو(٧٩)۔
  23,80,اَتے او تاں او ہے، جِہڑا حَیاتی وِی ݙیندے تے مار وِی چھوڑیندے، اَتے رَات تے ݙین٘ہ دَا آپس وِچ اَدلَݨ بَدلَݨ بالکل اُوندے اِختیار وِچ ہے کیا تُساں اِتّی ڳالھ وِی نھیں سَمجھ سَڳدے(٨٠)۔
  23,81,بلکہ اِیہ لوک وِی اُوویں اَکھیندِن جِیویں اُنھاں کنُوں پہلے دے لوکاں آکھیا ہَا(٨١)۔
  23,82,اِیہ اَکھیندِن، کیا ڄَݙاں اَساں مَر ویسُوں، اَتے مِٹّی تِھی ویسُوں اَتے ہَݙیاں رَہ ویسُوں، کیا وَل وِی اَساں کھڑے کر کھڑائے ویسُوں(٨٢)۔ ت
  23,83,حقیق اِیہ وَعدہ اَساݙے نال وِی ہے، اَتے اِیں کنُوں پہلے اَساݙے پِیؤ ݙاݙیاں نال وِی تِھیندا رِیہے، اِیہ تاں ٻَس اَڳلے وَقتاں دے لوکاں دِیاں کہاݨِیاں ہِن(٨٣)۔
  23,84,(اَے رسول) آکھ جو زمین اَتے جِہڑا کُجھ اِیندے وِچ ہے کِیندا ہے، جیکر تُساں ٹِھیک ٹِھیک ڄاݨدے وے تاں ݙَسّو(٨٤)۔
  23,85,ہُݨیں آکھ ݙیسِن جو سَب کُجھ اَللہ دَا ہے، آکھ ݙے جو وَل تُساں (اِیں ڳالھ کنُوں) نصیحت حاصل کِیُوں نھیں کریندے(٨٥)۔
  23,86,(انھاں کنُوں پُچّھ) جو سَتّے اَسماناں دَا مالک کوݨ ہے؟ اَتے عَرش والا کُوݨ ہے؟(٨٦)۔
  23,87,ہُݨیں آکھ ݙیسِن، جو اَللہ ہے! آکھ جو وَل تُساں اُوں کنُوں ݙَردے کِیُوں نِھیوے(٨٧)۔
  23,88,(انھاں کنُوں) پُچّھ، جو کِیندے ہَتّھ وِچ ہے بادشاہی ہَر شَئے دِی! (او کُوݨ ہے) جِہڑا پَناہ ݙیندے، تے جِیکُوں پَناہ دِی کوئی لوڑ وِی کائے نھیں، جِیکر تُہاکُوں پَتہ ہے (تَاں ݙسُّو! )(٨٨)۔
  23,89,ٻَس ہُݨیں آکھ ݙیسِن جو (بادشاہی تاں) اَللہ دِی ہے، آکھ ݙے، جو وَل تُہاݙے اُتّے کِیہا جادُو تِھی ڳئے؟(٨٩)۔
  23,90,بلکہ اَساں اُنھاں کولھ حَق بھیڄے، اَتے بیشک اِیہ لوک اُوکُوں کوڑا آہدِن(٩٠)۔
  23,91,اَللہ نَہ تاں کہیں کُوں اَپݨیں اَولاد بݨائے اَتے نَہ کوئی اُوندے نال ٻِیا معبود ہے، جیکر اِیویں ہوندا تاں ہَر معبود اَپݨِیں اَپݨِیں مخلوق کُوں گِھن تے اَن٘ج تِھی ویندا، اَتے اُنھاں وِچُوں بعضے (معبود) بعضیاں اُتّے چَڑھ ویندے، (ݙَہا چھوڑیندے) اَللہ تاں پاک ہے، انھاں ڳالھِیں کنُوں جِہڑیاں اُوندے اُتے کریندے وَدّے وے(٩١)۔
  23,92,او غیب (لُکّی شَئے) کُوں وِی ڄاݨدے، تے ظاہر کُوں وِی، ٻَس اُوندی شان اُوں کنُوں ٻَہُوں اُچّی ہے، جِیکُوں اِیہ شریک بَݨیندِن(٩٢)۔
  23,93,(اَے رسول) آکھ جو میݙے رَبّ آ ، میکُوں او سَب کُجھ ݙے جِیندا انھاں نال وَعدہ کِیتا ہوئے(٩٣)۔
  23,94,میݙے رَبّ آ، بَہر حال میکُوں ظالماں دِی قَوم وِچ شامل نَہ کریں(۹٤)۔
  23,95,اَتے بیشک اَساں تیکُوں ݙِیکھا وِی سَڳدُوں، جِیندا اُنھاں نال وَعدہ کریندے ہَیں، اَساں اِیں ڳالھ دِی پُوری قُدرت رَکھیندے ہَیں(٩٥)۔
  23,96,(اَے رسول) گَندی ڳالھ کُوں چَن٘ڳے طریقے نال ہَٹا ݙِتَّا کر، اَساں خُوب ڄاݨدے ہَیں جِہڑیاں ڳالھِیں (تیݙے اُتّے) کریندے وَدّے ہِن(٩٦)۔
  23,97,اَتے آکھ جو میݙے رَبّ آ، مَیں شیطان دے وَسوسیاں کنُوں تیݙی پَناہ مَن٘گداں(٩٧)۔
  23,98,اَتے اِیں ڳالھ دِی وِی تیݙی پَناہ مَن٘گداں مَتاں او میݙے کولھ نَہ آوَن٘ڄِن(٩٨)۔
  23,99,ڄَݙاں اُنھاں وِچُوں کہیں ہِک کُوں مَوت آویندی ہے تاں اَکھیندے جو میݙے رَبّ آ میکُوں (اُوں دُنیا تے) وَلا بھیڄ چَا(٩٩)۔
  23,100,تاں جو جِیکُوں مَیں چھوڑ آیا ہَاں اُوندے وِچ نیک عَمل وَن٘ڄ کَراں، پَر کوئے نَہ، ٻَس اِیویں اِی او آکھ چھوڑیندِن، اَتے انھاں دے پِچھُوں ہِک پَردہ (رُکاوَٹ) ہے، اُوں ݙین٘ہ تَئیں ڄَݙاں جو او وَلا اُٹَھا کھڑائے ویسِن(١٠٠)۔
  23,101,ٻَس جِہڑے ویلے صُور پُھوکیا ویسے، تاں اُوں ݙین٘ہ اُنھاں وِچ نَہ سکْوَتاں (قرابتیں) رَہسِن، تے نَہ کَہیں کُوں کوئی ٻُلوا سَڳسِی(١٠١)۔
  23,102,ٻَس جِنھاں دے عَملاں دِی ڳَنڈھڑی باری ہوسی، ٻَس او ہے لوک کامیاب تِھی ویسِن(١٠٢)۔
  23,103,اَتے جِنھاں دِی ڳَنڈھڑی ہَلکی ہوسی، ٻَس او آپ آپݨاں گھاٹا چَا کھڑسِن، او دَوزخ وِچ ہَمیشہ کِیتے رَہسِن(١٠٣)۔
  23,104,بھا اُنھاں دے مُونھاں دَا چَمّ سَاڑ چھوڑیسے، او (اِیویں لَڳسِن) جِیویں جو اُنھاں دِی سِرّی بُھنّ ݙِتّی ڳئی ہُووے(١٠٤)۔
  23,105,کیا تُہاکُوں میݙیاں آیاتاں پَڑھ تے نَہ سُݨائیاں ویندیاں ہَن، ٻَس تُساں تَاں اُنھاں کُوں کُوڑا آکھ چھوڑیندے ہَاوے(١٠٥)۔
  23,106,او آکھیسِن، اَساݙے رَبّ آ! اَساݙے اُتّے اَساݙِی بَد بَختی غالب آڳئی ہَئی، اَساں وَاقعی گُمراہ قَوم وِچُوں تِھی ڳئے ہَاسے(١٠٦)۔
  23,107,اَساݙے رَبّ آ ، اَساکُوں اِیندے وِچُوں کَڈھ! جیکر اَساں وَلا وِی اِیویں کروں، تاں اَساں واقعی قصور وار ہوسُوں(١٠٧)۔
  23,108,اَللہ آکھیسے، ٻَس اِیندے وِچ پَرے ݙَٹّھے پَے رَہوُو، اَتے میݙے نال کوئی ڳالھ وِی نَہ کراہے(١٠٨)۔
  23,109,بیشک میݙے بَندیاں وِچُوں ہِک ٹولی اِیہُو جہی ہَئی، جِہڑی اَکھیندی رَہندی ہَئی، جو اَساݙے رَبّ آ! اَساں اِیمان گِھن آئے ہَیں، ٻَس اَساکُوں بَخش چَا، اَتے اَساݙے اُتّے رَحم چَا کر، اَتے تُوں سارے رحم کرݨ والیاں تُوں وَدّھ رحم کرݨ والا ہیں(١٠٩)۔
  23,110,پَر تُساں اُنھاں نال اِتنیاں مَذاقاں کریندے رِیہے وے جو تُساں میکُوں یاد کرݨ دِی بُھل ڳِیُوہے، ٻَس تُساں تاں اُنھاں اُتے کِھلَّاں اِی کریندے رَہ ڳِیُوہے(١١٠)۔
  23,111,بیشک اَڄ مَیں انھاں کُوں جَزا ݙِتی ہے کِیُوں جو اُنھاں صَبر چَا کِیتا ہَا، بیشک اِیہے مُراداں پاوَݨ والے ہِن(١١١)۔
  23,112,اَللہ) اَکھیسے، تُساں زمین اُتّے کِتّی سال رِیہے ہِیوے(١١٢)۔
  23,113,او اَکھیسِن، ٻَس ہِک ݙین٘ہ یا ہِک ݙین٘ہ دَا کُجھ حِصّہ اُتَّھاں رِیہے ہِیسے، ٻَس گنتری کِیتی رَکھݨ والیاں کنُوں پُچّھ گِھنُّو(١١٣)۔
  23,114,اَللہ اَکھیسے، تُساں تھوڑی دیر اِی اُتَّھاں رِیہے وے، اَفسُوس تُساں اُوں ویلے اِی اِیں ڳالھ کُوں ڄاݨدے ہوندے(١١٤)۔
  23,115,کیا تُساں اِیہ سَمجھ گِھدّا ہَا، جو واقعی اَساں تُہاکُوں خُواہ مَخُواہ پَیدا کِیتا ہے، اَتے تُساں اَساں دو اَصلُوں وَلݨاں وِی کائے نھیں(١١٥)۔
  23,116,ٻَس اَللہ اِی اُچّے مرتبے والا ہے، اُوہو بادشاہ ہے، اُوہو حَق ہے، اُوندے سِوا ٻِیا کوئی معبود کائے نھیں، او ٻَہُوں عِزّتاں والے عَرش دا مالک ہے(١١٦)۔
  23,117,اَتے جِہڑا شَخص اَللہ دے نال نال کہیں ٻئے معبود کُوں وِی سَݙیندے، جِیندے مُتعلّق کوئی وِی دَلیل اُوندے کولھ کائے نھیں، ٻَس بیشک اُوندا حِساب اُوندے رَبّ کولھ ہے، بیشک اِہجے کافراں کِیتے کوئے چُھٹکارا (فلاح) کائے نھیں(١١٧)۔
  23,118,اَتے (اَے رسول) آکھ جو میݙے رَبّ آ، میکُوں بَخش ݙے، اَتے میݙے اُتّے رحم چَا کر اَتے تُوں ساریاں کنُوں اصلُوں وَدّھ تے رحم کرݨ والا ہیں(١١٨)۔
