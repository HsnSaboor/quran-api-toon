quran[8{c,v,t}:
2,146,جِنہاں لوکاں کُوں اَساں کتاب ݙے چکیئے ہیں او اِیکوں سُن٘ڄݨیندِن جیویں آپݨیاں پُتراں کُوں سُن٘ڄݨیندِن اَتے بیشک اُنھاں وِچوں ہِک ٹولا حقی ڳالھ کُوں لُکیندے ڄَݙاں جو او ڄاݨدے وِی ہِن (١٤٦)۔
2,147,اِیہ تیݙے رَبّ دِی طرفوں حقی ڳالھ (اَمرِ حق) ہے، تݙاہُوں تُوں شک کرݨ والیاں وِچوں نہ تھی (١٤٧)۔
2,148,اَتے ہر ٹولے (فرقے) کِیتے ہِک قِبلہ ہے جِݙے او مُن٘ہ پھیر کھڑدے، بہر حال تُساں نیک کماں وِچ اَڳوں نِکلݨ دِی کرو، تُساں جِتھاں کِتھائیں وِی ہوسو، تاں اللہ تُساں ساریاں کُوں کٹھا کر گِھنسی، بیشک اللہ ہر شئے اُتے قدرت رَکھیندے (١٤٨)۔
2,149,اَتے تُساں جِہڑے پاسے وِی نِکلو، آپݨاں مُن٘ہ مسجد الحرام (خانہ کعبہ) والے پاسے پھیر گِھدّا کرو، بے شک اِیہ تیݙے رَبّ دِی طرفوں ہِک حقی ڳالھ (اَمرِ حق) ہے اَتے تُساں جو کُجھ وَدے کریندو، اللہ اُوں کنُوں بے خبر کائے نھیں (١٤٩)۔
2,150,اَتے تُساں جِتھاں وِی وَدّے ہووُو، نماز کِیتے آپݨاں مُن٘ہ مسجد الحرام (خانہ کعبہ) دو پھیر گِھدا کرو، اَتے (مسلمانو) تُساں وِی جِتھاں کتھائیں ہووُو، اُوں پاسے مُن٘ہ کر گِھدا کرو، تاں جو تُہاݙے اُتے لوکاں کُوں کُوئی حُجّت (جھیڑے دِی ڳالھ) نہ رَہوے، سِوائے اُنھاں دے جِہڑے اُنھاں وِچوں (آپݨیں کِیتے وِی) ظالم ہِن، ٻَس اُنھاں کَنُوں نہ ݙَرو، اَتے مَیں کنُوں ݙَردے رَہوائے، تاں جو تُہاݙے اُتے آپݨیاں نعمتاں مُکا چھوڑاں، اَتے تُساں ہدایت پا گِھنّو (١٥٠)۔
2,151,جیویں جو اَساں تُہاݙے کِیتے تُہاݙے وِچوں ہِک رسول بھیجے جِہڑا تُہاکوں اَساݙیاں آیاتاں پڑھ سُݨیندے (گندیاں ڳالھیں کنُوں) تُہاکوں پاک کِیتی رَکھدے، اَتے تُہاکوں کتاب اَتے دانائی دِیاں ڳالھیں سکھائی رَکھدے، اَتے تُہاکوں اِیہو جِیہا عِلم سکھیندے جِہڑا جو تُساں پہلے نہ ڄاݨدے ہاوے (١٥١)۔
2,152,ٻَس تُساں میݙا ذِکر کیتا کرو، اَتے میں تُہاکوں یاد رَکھی رَکھساں، اَتے میݙے شُکر گزار بݨے رہائے، اَتے نا شکری (کُفر) نہ کرائے (١٥٢)۔
2,153,اَے لوکو، جِہڑے اِیمان گِھن آئیوے، ثابت قدمی تے نماز دے حوالے نال اِمداد حاصل کِیتی رَکھو، بیشک اللہ ثابت قدم رَہݨ والیاں دے رَلّے ہوندے (١٥٣)۔
