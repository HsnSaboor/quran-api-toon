quran[3]{c,v,t}:
  79,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  79,1,قَسم ہے اُنھاں دِی جِہڑے ٹُٻِّی مار تے کَڈھ آندِن(١)
  79,2,اَتے جِہڑے اَسانی نال رُکاوَٹاں تے مُشکلاں دِی ڳَنڈھ کُھول گِھندِن(٢)
  79,3,اَتے اُنھاں دِی جِہڑے تیزی نال اِݙّے اُݙّے تَردے وَدے ہُوندِن(٣)
  79,4,وَل ہِک ٻئے کنُوں اَڳُوں لَنگھ ویندے ہِن(٤)
  79,5,وَل دُنیاوی معاملات دے اِنتظام وِچ لڳ ویندے ہِن(٥)۔
  79,6,ہِک ݙِین٘ہ بُھوئیں ہَن٘ب (زَلزلہ) سَب کُجھ ہَلا چھوڑیسے(٦)۔
  79,7,اُوندے پِچُّھوں ہِک ٻِیا بھوئیں ہَن٘ب (زلزلہ) وِی آ ویسے(٧)۔
  79,8,اُوں ݙِین٘ہ لوکاں دِے دِلّ کَن٘ب ویسِن(٨)
  79,9,اَتے اُنھاں دِیاں اَکّھیں جِھکیاں تِھیاں ہوئیاں ہوسن (٩)
  79,10,او اَکھیسِن، کیا وَاقعی اَساں پہلی حالت وِچ وَلائے ویسُوں (١٠)
  79,11,کیا او وِی اُوں ویلے ڄَݙاں اَساں بُتھیاں ہَݙیاں بَݨ چُکیئے ہوسُوں(١١)
  79,12,اَکھیسِن جو اِیہ تاں وَݙا گھاٹا ݙیوݨ والی واپسی ہے(١٢)
  79,13,اَصل وِچ اِیہ تاں محض ہِک قِسم دا کھڑکا پَٹیسی(١٣)
  79,14,وَت فوراً او ہِک مَیدان وِچ آویسِن (١٤)
  79,15,کیا تیݙے کولھ مُوسیٰ والی ڳالھ پُنّی ہے (١٥)
  79,16,ڄَݙاں جو اُوکُوں اُوندے رَبّ پاک وَادی وِچ سَݙایا ہَا طویٰ دِی(١٦)
  79,17,جو تُوں فِرعون کولھ چَلیا وَن٘ڄ، بیشک او اَصلُوں باغِی تِھی ڳئے (١٧)
  79,18,ٻَس وَن٘ڄ آکھیُس جو کیا توں چَہندیں جو نیک پَاک بَندہ بَݨ وَن٘ڄیں(١٨)
  79,19,اَتے مَیں تیکُوں تیݙے رَبّ دے رَاہ تے چَلاواں، تاں جو توں اُوں کنُوں ݙَرݨ لَڳ پُوویں(١٩)
  79,20,ٻَس اُوکُوں اُوں نے آپݨیں وَݙّی دلیل (نشانی) وِی ݙِتّی(٢٠)
  79,21,پر اُوں اُوکُوں کُوڑ چَا آکھیا، تے نافرمانی چَا کِیتُس(٢١)
  79,22,وَل کَن٘ڈ چَا وَلایُس، تَدبیریں کرَݨ لَڳ پِیا(٢٢)
  79,23,ٻَس اُوں لوکاں کُوں کَٹَّھا چَا کِیتا(٢٣)
  79,24,اعلان کِیتُس، آکھیُس جو مَیں اِی تُہاݙا سَب تُوں وَݙا رَبّ ہَاں(٢٤)
  79,25,اِیں واسطے اَللہ اُوکُوں پَکڑ وِچ گِھن آیا، آخرت کِیتے وِی تے اِیں دُنیا کِیتے وِی، عِبرت دِی ہِک شَئے بݨا چُھوڑیُس(٢٥)
  79,26,واقعی اِیندے وِچ عِبرت دِی جاء ہے، اُوں شَخص کِیتے جِہڑا جو ݙَردے(٢٦)
  79,27,کیا تُہاݙا بَݨاوَݨ زیادہ اَوکھا ہے یا آسمان دا؟ اُوکُوں وِی تاں اُوں اِی بݨائے(٢٧)۔
  79,28,اُوندی چَھت کُوں اُچّا کِیتُس، وَت اُوکُوں ٹِھیک ٹَھاک کر کَھڑائِس(٢٨)۔
  79,29,اَتے اُوکُوں رات نال کَڄّیُس اَتے اُوندی دُھپ وِی کِھن٘ڈیندے(٢٩)۔
  79,30,وَل اِیندے بَعد زَمین کُوں وِچَھا دِرگھا چھوڑیُس (٣٠)۔
  79,31,اَتے اِیندے وِچُّوں اُوندا پاݨِیں کَڈھیُس، وَت اُوندے نال گَھا چَارہ کَڈھیُس(٣١)
  79,32,وَل اُوں اُوندے اُتّے پَہاڑ پُور کَھڑائِن(٣٢)
  79,33,اِیہ تُہاݙے کِیتے، تے تُہاݙے ڈھان٘ڈِھیاں کِیتے وَرتَݨ کھاوَݨ دِیاں شَئیں ہِن(٣٣)
  79,34,ٻَس ڄَݙاں ٻَہُوں وَݙِی آفت آویسی ! (٣٤)
  79,35,اُوں ݙِین٘ہ اِنسان یاد کریسی، جِہڑا کُجھ وِی اُوں کِیتا ہویا ہوسے(٣٥)
  79,36,اَتے دَوزخ کھول ݙِتی ویسی، اُوندے سامݨیں جِہڑا اُوکُوں ݙیکھݨ چَہسے(٣٦)۔
  79,37,ٻَس جَیں وِی نافرمانی کِیتی(٣٧)۔
  79,38,اَتے دُنیاوِی زِندگی کُوں چَن٘ڳا سَمجھیا ہَس(٣٨)
  79,39,ٻَس یقیناً اُوندا ٹِکاݨاں دَوزخ اِی ہے(٣٩)۔
  79,40,اَتے جِہڑا کوئی اَللہ دے اَڳُوں کَھڑا ہُووَݨ کنُوں ݙَردے، اَتے اَپݨِیں رُوح (نَفس) کُوں خُواہِشاں کنُوں ہَٹکیندے(٤٠)
  79,41,اُوندا ٹِکاݨاں بَہشت ہے(٤١)۔
  79,42,تَیں کنُوں لوک پُچھدے ہِن، جو قیامت دِی گھڑی کَݙاں قائم آ تِھیسے (٤٢)
  79,43,اَے رسول) اُوندا ݙَسَݨ تیݙا کَم کائے نھیں(٤٣)
  79,44,تیݙے رَبّ کولھ ہے اُوندی آخری ڳالھ(٤٤)
  79,45,یقیناً تُوں تاں محض اُوکُوں ݙَراوَݨ وَالا ہَیں، جِہڑا اِیں کنُوں ݙَردے(٤٥)
  79,46,جِہڑے ݙِین٘ہ او اِیکُوں ݙیکھسِن، تاں خیال کریسِن، جو او تاں محض ہِک شَام رِیہن یَا اُوندی ہِک صبح رِیہن(٤٦)
