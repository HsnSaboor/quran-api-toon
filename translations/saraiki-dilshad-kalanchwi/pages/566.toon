quran[18{c,v,t}:
68,43,شرم کنُوں) اُنھاں دِیاں اَکّھیں جِھکیاں تِھی ویسِن، ذِلّت اُنھاں کُوں ویڑھ گِھنسی، اَتے تحقیق اُنھاں کُوں تاں (دُنیا وِچ وِی) سَجدے کِیتے سَݙیا ویندا ہَا، ڄَݙاں جو اِیہ کَم کرݨ جوگے ٹِھیک ٹَھاک وِی ہِن (٤٣)۔
68,44,اَے رسول) ٻَس تُوں میݙا تے اُوندا معاملہ میݙے اُتّے چھوڑ ݙے، جِہڑا جو اِیں کلام کُوں کُوڑا اَکھیندے اَجھو مَیں اُنھاں کُوں ہَولے ہولے جیں طرح (عذاب دو) گِھن آساں ، اُنھاں کُوں پَتہ وِی کائے نھیں (٤٤)۔
68,45,اَتے مَیں اُنھاں کُوں مُہلت وِی ݙِتی آنداں، پَر میݙی تدبیر تاں کافِی زبردست ہے (٤٥)۔
68,46,کیا تُوں اُنھاں کنُوں کوئی اَجر مَنگدیں جو او کہیں چَٹّی (تاوان) دے بار تَلے کُٻّے تَھئے ویندِن (٤٦)۔
68,47,یا اُنھاں کولھ غیب دا عِلم آڳئے، جیکوں او لِکھ گِھندِن (٤٧)۔
68,48,ٻَس تُوں آپݨیں رَبّ دے حُکم کِیتے (تھوڑی دیر) صَبر چَا کر، اَتے مَچّھی دے (ڈھڈھ وِچ رَہݨ والے یُونس) وانگوں نہ تِھی وَن٘ڄ، اُوں تاں ڄَݙاں سَݙ ماریا ہَا تاں ݙُکھ (غم) نال ٻَہُوں بَھریا ہویا ہا (٤٨)۔
68,49,جیکر اُوندے رَبّ دِی نعمت اُوں توڑِیں نہ پُڄ ویندی، تاں او کُرّ (سُکّے میدان) اُتے سَٹ ݙِتا ویندا، اُوندی حالت ٻَہُوں خَراب تِھی ویندی (٤٩)
68,50,۔ ٻَس اُوندے رَبّ نے اُوکُوں (آپݨیں کِیتے) چُݨ گِھدّا، وَت اُوکُوں آپݨیں نیک بَندیاں وِچ رَلا چھوڑیا (٥٠)۔
68,51,اَتے تحقیق جِنھاں کُفر اِختیار کِیتا ہوئے اِیویں لڳدِن اَکّھیں پوڑ پوڑ تے (زِچّ کر کر تے) آپݨیں مقام کنُوں تِلکا چھوڑیسِن، ڄَݙاں جو او قرآن (ذِکر) کُوں سُݨدِن، تے اَکھیندِن جو بِلا شَک اِیہ تاں پاڳل ہے (٥١)۔
68,52,حالانکہ اِیہ تاں ٻِیا کُجھ وِی نھیں، سِوائے اِیندے جو اِیہ سارے جہاناں کِیتے ہِک نصیحت ہے (٥٢)۔
69,1,سَچ مُچّ تِھی وَن٘ڄݨ والی (١)۔
69,2,اِیہ کیا ہے سَچ مُچ تِھی وَن٘ڄݨ والی؟ (٢)۔
69,3,اَتے (اَے رسول) تُوں کیا ڄاݨدیں جو اِیہ سَچ مُچّ تِھی وَن٘ڄݨ والی ہے کیا شَئے؟ (٣)۔
69,4,ثمود تے عاد نے تاں اُچّے کڑکاٹ گَھتّݨ والی آفت کُوں کُوڑا آکھیا (٤)۔
69,5,ٻَس جِہڑا ثمود ہَا، اُوکُوں تاں سَخت کڑکاٹ والے حادثے وِچ مار گَھتّیا ڳیا (٥)۔
69,6,اَتے جِہڑا عَاد ہَا اُوکُوں ہِک تیز گُھلَّݨ والی زور دِی اَندھاری وِچ ہَلاک کر ݙِتا ڳیا (٦)۔
69,7,اُوں سَت راتیں تے اَٹھ ݙین٘ہاں تَئیں اُوں ڄَڑھاں پَٹ گَھتَّݨ والی اَندھاری کُوں گھولی رَکھیا، ٻَس تُوں اُوں قَوم کُوں اِیں طرح ڈٹھیں ہوئیں ݙیکھدا جِیویں جو او کھوکھلی پولی کَھڄّی دے مُنڈھ ہُووِن (٧)۔
69,8,ٻَس کیا تُوں اُنھاں وِچُوں کہیں کُوں باقی بَچیا ہویا ݙیکھدیں (٨)۔
