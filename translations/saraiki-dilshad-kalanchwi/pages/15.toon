quran[3]{c,v,t}:
  15,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  15,1,اَلف، لام، را، اِیہ آیاتاں ہِن ہِک خاص کتاب دِیاں، صاف صاف بیان کرݨ والے قُرآن دِیاں (١)۔
  15,2,کافر لوک وَل وَل اِیہ خواہش کریسِن، جو کِتّی چن٘ڳا ہوندا، جو اَساں وِی مُسلمان ہوندے (٢)۔
  15,3,انھاں کُوں کلھا چھوڑ ݙے، کھا پِی گِھنّݨ اَتے مزّے کر گِھنݨ، اَصل وِچ او کُوڑیاں اُمیداں وِچ رُدّھے وَدِّن، ٻَہُوں جَلدی انھاں کُوں سارا پَتہ لڳ ویسے (٣)۔
  15,4,اَتے اَساں کوئی وَستی اِیویں تَباہ تے برباد نھیں کِیتی، اَلبتہ اُوندے کِیتے پہلے کنُوں ہِک وَقت لِکھیا وَن٘ڄ چُکیا ہوندے (٤)۔
  15,5,کوئی اُمّت نہ آپݨیں اَجل کنُوں پہلے تباہ کِیتی ویندی ہے، اَتے نہ اُوکُوں ڈھِل ݙِتی ویندی ہے (٥)۔
  15,6,اَتے (کافر) اَکھیندِن وُوئے ڄݨے آں ! (توڑے جو) تیݙے اُتے نصیحت (والی کتاب) لَتّھی ہے پَر تُوں تاں پاڳل ہِیں (٦)۔
  15,7,بَھلا کیوں نھیں گِھن آندا، فرشتیاں کُوں اَساݙے کولھ، جیکر تُوں سَچّے لوکاں وِچُوں ہئیں تاں (٧)۔
  15,8,اَساں فرشتیاں کُوں اِیویں نِسے لَہیندے، کہیں حقیقی وَجہ نال لَہائے ویندِن (لَہ آوِن تاں وَل) کوئی مُہلت نھیں ݙِتی ویندی (٨)۔
  15,9,بیشک اِیہ ذکر (قرآن) اَساں لَہایا ہے، اَتے اَساں اِی اِیندی حفاظت کِیتی رَکھسُوں (٩)۔
  15,10,اَتے تحقیق اَساں تَیں کنُوں پہلے والیاں اُمتّاں وِچ وِی رسول بھیڄے ہِن (١٠)۔
  15,11,پَر اِنھاں کولھ کوئی اِہجا رسول نہ آیا ہا، جیندے نال او مذاقاں نہ کرِن ہَا (١١)۔
  15,12,اِیں طرح اَساں گُنہگار لوکاں دے دِلّیں وِچ اِہجی ڳالھ گَھت ݙیندے ہَیں (١٢)۔
  15,13,پَر او کݙاہِیں اُوندے اُتے اِیمان نھیں گِھن آندے اَتے پہلے والے لوکاں دا دستور وِی اِیہو رِیہے (١٣)۔
  15,14,اَتے جیکر انھاں اُتے اَسمان دا کوئی دروازہ کھول ݙیندے، اَتے اِیں دو چڑھݨ وِی پَے ویندے (١٤)۔
  15,15,تاں وِی اِیہو کُجھ اَکھیندے، جو اَساݙیاں اَکّھیں مُندر ݙِتیاں ڳئین، بلکہ اَساݙی قوم اُتے جادو کر ݙِتا ڳئے (١٥)۔
  15,16,تحقیق اَساں اِی اَسماناں وِچ بُرج (قلعے) بݨائے ہوئِن اَتے ݙیکھݨ والیاں کِیتے انھاں کُوں سوہݨاں بݨا چھوڑے (١٦)۔
  15,17,اَتے انھاں کُوں ہر مَردود شَیطان کنُوں محفوظ کر گِھدے (١٧)۔
  15,18,اِیہ ٻَئی ڳالھ ہے، جو کوئی لُک چُھپ تے اُتُّھوں کُجھ سُݨ تے (بھَڄ آوے) تاں وِی ہِک بَکھدا ہوئیا اَنڳارہ اُوندے پِچُّھوں پَے ویندے (١٨)۔
  15,19,اَتے اَساں زمین کُوں دگھیر چھوڑے اَتے اِیندے اُتے پہاڑ کھڑے کر ݙِتِن، اَتے اِیندے وِچُوں پُوری ضرورت دِی ہَر شَئے ڄَمائی ہے (١٩)۔
  15,20,اَتے اَساں اِیندے وِچُوں تُہاݙے کِیتے اَتے جِنھاں دِی روزی تُہاݙے ہَتّھ کائے نھیں، اُنھاں کِیتے کھاوَݨ پِیوَݨ دِیاں شَئیں ڄَمائِن (٢٠)۔
  15,21,اَتے کوئی شَئے اِہجی کائے نھیں جِیندے خزانے اَساݙے کولھ نہ ہووِن، اَتے انھاں کُوں ہِک ڳِݨِی مُنجی مِقدار وِچ لَہیندے رَہندے ہَیں (٢١)۔
  15,22,اَتے اَساں (آبی بخارات نال) لݙئیاں ہوئیاں ہَوائیں گھولیندے ہَیں، وَل اَساں اَسماناں کنُوں مِین٘ہ وَسیندے ہَیں، اَتے اِیندے وِچُوں پِلیندے ہَیں، پَر تُساں اِتی سارے پاݨِیں کُوں کَٹھا کر تے نھیں رَکھ سَڳدے (٢٢)۔
  15,23,اَتے اَساں اِی حیاتی ݙیندے ہَیں اَتے اَساں اِی مَریندے ہَیں، اَتے اَساں تُہاݙے وارث ہَیں (٢٣)۔
  15,24,اَتے تحقیق اَساں انھاں کُوں ڄاݨدے سَمجھدے ہَیں جِہڑے تُساں کنُوں پہلے گُزر ڳئِن اَتے تحقیق اَساں ڄاݨدے ہَیں پِچُّھوں آوَݨ والیاں کُوں وِی (٢٤)۔
  15,25,اَتے بیشک اِیہ تیݙا رَبّ اِی ہے، جِہڑا انھاں ساریاں کوں کٹھا کریسے، بیشک او ٻَہُوں دانا تے چن٘ڳی طرح ڄاݨݨ والا ہے (٢٥)۔
  15,26,اَتے تحقیق اَساں اِنسان کُوں سَڑیے ہوئے گارے (ڳَس) دِی سُکّی کھڑکݨِیں مِٹّی کنُوں پَیدا کِیتے (٢٦)۔
  15,27,اَتے اِیں کنُوں پہلے اَساں جِنّاں کُوں تیز سِیک والی بَھا وِچُوں پَیدا کِیتے (٢٧)۔
  15,28,اَتے (یاد کر) ڄَݙاں تیݙے رَبّ فرشتیاں کُوں آکھیا جو مَیں سَڑے ہوئے گارے (ڳَس) دِی سُکّی کھڑکݨِیں مِٹی وِچُوں اِنسان کُوں پَیدا کرݨ لڳیا ہَاں (٢٨)۔
  15,29,ٻَس ڄَݙاں مَیں اُوکُوں بݨا سن٘وار گِھنّاں اَتے آپݨِیں رُوح کنُوں اُوندے وِچ پُھوکا مار چھوڑاں تاں اُوندے اَڳوں سجدے وِچ ڈھے پووݨاں (٢٩)۔
  15,30,ٻَس فرشتے تاں سارے دے سارے سجدے وِچ ڈھے پَئے (٣٠)۔
  15,31,سِوائے اِبلیس دے! اُوں سَجدہ کرݨ والیاں نال رَلَّݨ کنُوں اِنکار کر ݙِتا (٣١)۔
  15,32,اَللہ) آکھیا، اِبلیس آ، تیکوں کیا تِھی ڳئے جو تُوں سَجدہ کرݨ والیاں نال نھیں رَلیا (٣٢)۔
  15,33,اُوں آکھیا، مَیں اِہجا کائے نھیں، جو بَشر کُوں سَجدہ کراں جیکوں تَیں سَڑے ہوئے گارے والی سُکّی کرکݨِیں مِٹّی وِچُوں پَیدا کِیتے (٣٣)۔
  15,34,اَللہ آکھیا، تاں وَل اِتُّھوں نِکل وَن٘ڄ، تُوں تاں اَصلُوں مَردود ثابِت تِھیئیں (٣٤)۔
  15,35,اَتے بیشک تیݙے اُتے قیامت دے ݙین٘ہ توڑِیں لعنت وَسدی رَہسی (٣٥)۔
  15,36,اُوں آکھیا، میݙے رَبّ آ ! وَل میکوں مُہلت چَا ݙے اُوں ݙین٘ہ توڑِیں ڄَݙاں سارے لوک (مَرݨ دے بعد) زِندہ کِیتے ویسن (٣٦)۔
  15,37,اَللہ) آکھیا چَلو تیکوں مُہلت والیْاں وِچُوں بݨا گِھدا ویندے (٣٧)۔
  15,38,اُوں ݙین٘ہ توڑِیں جیندے ویلے دا (اَساکوں) پَتہ ہے (٣٨)۔
  15,39,اُوں آکھیا، میݙے رَبّ آ ، جیں طرح تَیں میکوں سِدّھے رَاہ کنُوں ہَٹا گِھدّے، مَیں وِی انھاں لوکاں کِیتے زمین اُتے (گُناہاں کُوں) سوہݨِیں لذتّاں والا بݨا تے ݙیکھیساں اَتے انھاں ساریاں کُوں سِدّھے رَاہ کنُوں ہَٹا گِھنساں (٣٩)۔
  15,40,سِوائے انھاں بندیاں دے جِہڑے خاص تیݙے بݨے ہوئِن (٤٠)۔
  15,41,اَللہ آکھیا، انھائیں والا رَاہ تاں ہے سِدّھا مَیں توڑیں پُڄݨ دا (٤١)۔
  15,42,بیشک میݙے بَندے ہِن انھاں اُتے تیݙا کوئی وَسّ نہ چَلسے سِوائے اُنھاں دے جِہڑے بَد رَاہ تِھی تے تیݙے پِچُّھوں لڳ پوسِن (٤٢)۔
  15,43,اَتے بیشک انھاں ساریاں کِیتے دوزخ ہے جِیندا اُنھاں نال وَعدہ ہے (٤٣)۔
  15,44,اُوندے سَت دروازے ہِن، ہَر دروازہ (انھاں دے گُناہاں دے مطابق) انھاں کِیتے اَنج اَنج وَنڈیا ہوئے (٤٤)۔
  15,45,بیشک پرہیزگار لوک باغاں وِچ تے چَشمیاں (دے کِنارے) اُتے رَہسِن (٤٥)۔
  15,46,آکھیا ویسے جو انھاں وِچ وَڑ ڄُلو، سَلامتی نال تے اَمن چَین نال(٤٦)۔
  15,47,اَتے انھاں دے دِلّیں وِچ جِہڑا کھوٹ کِینہ ہوسے کَڈھ ݙِتا ویسے، ٻَس بِھرا ٻَݨ تے ہِک ٻَئے دے آمݨیں سامݨیں عِزّتاں والے تختاں اُتے ٻیٹھے ہوسِن (٤٧)۔
  15,48,نہ اُنھاں کُوں اُتھاں کہیں قِسم دا تھکیڑا ہوسی، اَتے نہ او اُتھوں کڈھے ویسِن (٤٨)۔
  15,49,(اَے رسول) میݙیاں بندیاں کُوں ݙَس ݙے بیشک مَیں ٻَہُوں بخشݨ ہار تے ہمیش کِیتے مہربان ہَاں (٤٩)۔
  15,50,اَتے بیشک میݙا عذاب وِی ہِک وَݙا دَرد ناک عذاب ہے (٥٠)۔
  15,51,اَتے انھاں کُوں ابراہیم دے مہماناں دا حال وِی سُݨا ݙے (٥١)۔
  15,52,ڄَݙاں جو او اِبراہیم دے کولھ آئے، انھاں آکھیا، شالا سَلامتی رَہوی ! اُوں آکھیا، پَر میکوں تاں تُساں کنُوں ݙر پِیا لڳدے (٥٢)۔
  15,53,انھاں آکھیا ݙر نہ پِیا، بیشک اَساں تیکوں ہِک اِہجے پُتر دِی خوشخبری ݙیندوں جِہڑا وَݙا دانا ہوسی (٥٣)۔
  15,54,اُوں آکھیا، تُساں ہُݨ میکوں خوشخبری سݨاوَݨ آئے وے، ڄَݙاں جو میکوں ٻُڈھیپا وَلھیٹ ڳئے، ٻَس ہُݨ کہیں خوشخبری ݙیندو (٥٤)۔
  15,55,انھاں آکھیا، اَساں تیکوں واقعی سَچّی خوشخبری سُݨیندے پَے ہَیں تُوں بے آس لوکاں وِچُوں نہ پِیا تِھی (٥٥)۔
  15,56,اُوں اکھیا بَھلا کِہڑا شخص آپݨیں رَبّ دِی رحمت کنُوں بے آس تِھیندے، اَلبتہ گُمراہ لوکاں دِی ڳالھ ٻَئی ہے (٥٦)۔
  15,57,اُوں پُچھیا جو اَللہ دے بھیڄے ہوئے فرشتو ! تُساں کِتھ کِیتے بھیڄے ڳئے وے؟ (٥٧)۔
  15,58,اُنھاں ݙَسیا جو اَساکوں گُنہگاراں دِی قوم دو بھیڄا ڳئے (٥٨)۔
  15,59,سِوائے لُوط دے لوکاں دے، بیشک اَساں انھاں ساریاں کُوں بَچا گِھنسُوں (٥٩)۔
  15,60,پَر سِوائے اُوندی ذال دے کیوں جو اَساں اُوندا مُقدر اِیہو جیہا بݨائے جو او پِچُّھوں رہ وَن٘ڄݨ والیاں نال رَل ویسی (٦٠)۔
  15,61,وَل جِہڑے ویلے (اَللہ دے) بھیڄے ہوئے فرشتے لُوط دے بندیاں کولھ ڳئے (٦١)۔
  15,62,تاں اُوں اکھیا، سَچّی ڳالھ ہے تُساں اُوپرے لوک لڳدے وے (٦٢)۔
  15,63,اُنھاں آکھیا، اَساں اِتھاں اُوں حقیقت کُوں گِھن تےآئے ہَیں، جیندے وِچ شَک کریندے ہِن (٦٣)۔
  15,64,کیوں جو اَساں تیݙے کولھ بالکل سَچ مُچ تِھی وَن٘ڄݨ والی شَئے گِھن آئے ہَیں اِیندے وِچ کوئی شَک نہ کر، اَساں بالکل سَچ پَے اَکھیندے ہَیں (٦٤)۔
  15,65,رات ڈھلّݨ دے بعد تُوں آپݨیاں کُوں گِھن تے نِکل وَن٘ڄ، اَتے خود اُنھاں کُوں پِچُّھوں ہَکلی وَن٘ڄ، اَتے تُہاݙے وِچُوں کوئی وِی (کھڑ تے) پِچُّھوں دو نہ ݙیکھے بلکہ اُتھوں وَڳئے چَلاہے جِݙے دا تُہاکوں حُکم ݙِتا ڳئے (٦٥)۔
  15,66,اَتے اَساں اُوکُوں اِیہ فیصلہ سُݨا ݙِتا، جو بیشک سَویر تِھیوݨ نال اِنھاں دِی ڄَڑھ پَٹ چھوڑی ویسی (٦٦)۔
  15,67,(اِتنی دیر وِچ) شہر دے لوک (پاڳلاں وان٘گیں، بدنیّتی دِیاں) خوشیاں مَنیندے سئیں آ تھئے (٦٧)۔
  15,68,لُوط آکھیا، بیشک اِیہ میݙے مہمان ہِن ٻَس تُساں میکوں (انھاں اَڳوں) ذلیل نہ کرو (٦٨)۔
  15,69,اَتے اَللہ کنُوں ݙرو، اَتے میکوں انھاں کنُوں شرمسار وی نہ کرو (٦٩)۔
  15,70,انھاں آکھیا، کیا اَساں تیکوں سارے جہان دے لوکاں دِی طرفداری کرݨ کنُوں مَنع نہ کِیتا ہوئیا ہَا (٧٠)۔
  15,71,(لوط) آکھیا، میݙیاں دِھیاں حاضِر ہِن کوئی شادی کرݨِیں ہے، تاں انھاں نال کر گِھنّو (٧١)۔
  15,72,(اَے رسول) تیݙی حیاتی دِی قسم ! او لوک آپݨیں بَدمستی وِچ اَندھے تَھئے وَدّے ہِن (٧٢)۔
  15,73,ٻَس انھاں کُوں سِجھ دے نِکلدیں ہِک سخت کڑکاٹ آن پکڑیا (٧٣)۔
  15,74,ٻَس اَساں اُنھاں دِی وَستی کُوں تَلّے اُتے کر چھوڑیا، اَتے اَساں انھاں اُتے گھنکری مٹّی دے پَتھریلے روڑے وَسا چھوڑیئے (٧٤)۔
  15,75,یقیناً اِیندے وِچ عقل سَمجھ والیاں کِیتے نشانیاں ہِن (٧٥)۔
  15,76,اَتے بیشک او وَستی ہِک عام شاہراہ اُتے واقع ہے (٧٦)۔
  15,77,بہر حال اِیندے وِچ مؤمِن لوکاں کِیتے نشانی ہے (٧٧)۔
  15,78,اَتے بیشک ایکہ (شہر) والے لوک وِی وݙے ظالم ہَن (٧٨)۔
  15,79,اَساں اُنھاں کنُوں وِی انتقام گِھدا، اَتے بیشک اِیہ ݙوہِیں وَستیاں عام کُھلی شاہراہ اُتے واقع ہِن (٧٩)۔
  15,80,اَتے یقیناً ، حِجر دے رَہݨ والیاں اَساݙے بھیڄے ہوئے پیغمبراں کُوں کُوڑا آکھیا (٨٠)۔
  15,81,اَتے اَساں اُنھاں کولھ آپݨیاں نشانیاں بھیڄیاں، پر اُنھاں لوکاں اِنھاں کنُوں وِی مُن٘ہ پِھیری رَکھیا (٨١)۔
  15,82,اَتے پہاڑاں کُوں گَھڑ گَھڑ تے گھر بَݨیندے رِیہے ہِن تاں جو کہیں پَکڑ وِچ نہ آسَڳِن (٨٢)۔
  15,83,ٻَس انھاں کُوں وِی سویرے سویرے ہِک سخت کڑکاٹ آن پَکڑیا (٨٣)۔
  15,84,ٻَس انھاں دے کہیں کَم نہ آ سَڳیا جِہڑا کُجھ انھاں کَمتّا ہوئیا ہا (٨٤)۔
  15,85,اَتے اَساں آسماناں تے زمین کُوں، تے جِہڑا کُجھ انھاں وِچ ہے ہر شَئے کُوں ہِک حقیقت دے طور تے بݨایا ہوئیا ہے، اَتے بیشک (قیامت دِی) گھڑی تاں ضرور آوَݨ والی ہے ٻَس انھاں لوکاں کُوں سوہݨیں طریقے نال ٹالی رَکھو (٨٥)۔
  15,86,بیشک تیݙا رَبّ اِی سَب کُجھ پَیدا کرݨ والا تے چن٘ڳی طرح ڄاݨݨ والا ہے (٨٦)۔
  15,87,اَتے اَساں تیکوں (اَے رسول) سَت اِہجیاں آیاتاں ݙِتِّن جِہڑیاں (نماز وِچ) وَل وَل پڑھیاں ویندِن، اَتے وَݙیاں شاناں والا قرآن ݙِتے (٨٧)۔
  15,88,اَتے اَکّھ چَا تے وِی نہ ݙیکھ اُوں مال متال کُوں، جِہڑا اَساں انھاں وِچُوں دِیاں مختلف جماعتاں کُوں ݙِتے، اَتے نہ انھاں دے حال اُتے مُونجھا تِھی، اَتے مومناں دِی خاطرداری تے انھاں نال نرمائی کِیتی رَکھ (٨٨)۔
  15,89,اَتے آکھ ݙے جو مَیں وَڄ وَڄا تے تُہاکوں ݙراوَݨ (تنبیہ کرݨ) والا ہَاں (٨٩)۔
  15,90,(اِیہ تنبیہ اُوں طرح دِی ہے) جیں طرح اَساں انھاں اُتے نازِل کِیتی ہَئی، جِنھاں آپݨِیں مرضی نال) کُجھ مَن نہ مَن تے اُوندا وَنڈارا کر چھوڑیا (٩٠)۔
  15,91,اَتے اِیہے لوک ہَن جِنھاں آپݨیاں منشاء دے مطابق قرآن دے حصّے بخرے کر ݙِتے ہِن (٩١)۔
  15,92,تیݙے رَبّ دِی قسم ! جو اَساں انھاں ساریْاں کنُوں ضرور پُچھ گِھنسُوں (٩٢)۔
  15,93,اُنھاں کَمّاں دے متعلق جِہڑے او کریندے رِیہے ہَن (٩٣)۔
  15,94,ٻَس چن٘ڳی طرح سݨا ݙے جِہڑا حُکم تیکوں ݙتا ڳئے اَتے مُشرکاں دِی پَرواہ اِی نہ کِیتی کر (٩٤)۔
  15,95,بیشک اَساں تیݙے کِیتے کافی ہَیں، انھاں لوکاں دِی خبر گِھنّݨ کِیتے جِہڑے تیݙے اُتّے کِھلّاں کریندِن (٩٥)۔
  15,96,اِیہ لوک تاں اَللہ دے نال ٻئے معبود جوڑی رَکھدِن، ٻَس اَجھو انھاں کُوں (آپݨیں اَنجام دا) پَتہ لڳ ویسے (٩٦)۔
  15,97,اَتے تحقیق اَساں ڄاݨدے ہَیں، جو بیشک تیݙا دِل انھاں ڳالھیں تے مُونجھا تِھیندے جِہڑیاں اِیہ کریندے رَہندِن (٩٧)۔
  15,98,ٻَس آپݨیں رَبّ دِی تعریف نال اُوندی تسبیح پڑھی رَکھ، اَتے سَجدہ کرݨ والیاں نال رَلیا رَہ (٩٨)۔
  15,99,اَتے (اُوں آخری) گھڑی تَئیں رَبّ دِی فرمانبرداری کِیتی رَکھ جِیندا آوَݨ یقینی ہے (٩٩)۔
