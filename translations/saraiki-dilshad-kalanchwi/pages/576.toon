quran[30{c,v,t}:
74,18,یقیناً اُوں سوچے، تے کوئی تجویز سوچی ہِسّ (١٨)۔
74,19,اَللہ دِی) مار پووِسّ، اُوں کِہجی تجویز سوچی ہے (١٩)۔
74,20,وَل وِی مَار پووِسّ ، بَھلا اُوں کِہجی تجویز سوچی ہے (٢٠)
74,21,وَل اُوں کُجھ دیر اِݙّے اُݙّے ݙِٹّھا (٢١)۔
74,22,وَل مَتّھے تے تریڈھی گَھتِّی ، اَتے آپݨاں مُن٘ہ چِٻَّا کِیتا (٢٢)۔
74,23,وَل اُوں کَن٘ڈ چَا وَلائی، ٻَس وَݙائی وِچ آ ڳیا (٢٣)۔
74,24,آخر آکھیُس، اِیہ تاں کُجھ نِھیں سِوائے اِہجے جادُو دے، جِہڑا پہلے کنُوں آندا پَے (٢٤)۔
74,25,اِیہ تاں کُجھ نھیں محض ہِک بنی بَشر دا کلام ہے (٢٥)۔
74,26,اَجُّھو مَیں تاں اِہجے کُوں دَوزخ وِچ سَٹ گَھتیساں (٢٦)۔
74,27,اَتے تُوں نِھیں ڄاݨدا جو او دَوزخ کِہجی بلا ہے (٢٧)۔
74,28,او نہ تاں کوئی شَئے باقی رَکھیندی ہے، تے نہ او کہیں کُوں چھوڑیندی ہے (٢٨)۔
74,29,بنی بَشر دا تاں مُن٘ہ سَاڑ گَھتیندِی ہے (٢٩)۔
74,30,اُوندے اُتّے اُنویھ ١٩ فرِشتے (بطورِ داروغے) مقرر ہِن(٣٠)۔
74,31,اَتے اَساں دَوزخ دے داروغے محض فرشتیاں کُوں بݨائے اَتے اَساں اُنھاں دِی تعداد کُوں اُنھاں لوکاں کِیتے اَزمائش دا باعث بݨایا ہوئے، جِہڑے کُفر اِختیار کریندِن، تاں جو او لوک یقین کر گِھنِّن ، جِنھاں کُوں کِتاب وِی ݙِتی ڳئی ہے، اَتے اُنھاں دا اِیمان زیادہ پَکّا تِھی وَن٘ڄے، جِہڑے اِیمان گِھن آندِن، اَتے کِتاب والے تے مُومن لوک وِی کہیں شَک وچ نہ پَے پووِن، اَتے او لوک جِنھاں دے دِلّاں وِچ کھوٹ ہے، تے جِہڑے کافر ہِن او آکھ سَڳسِن جو اِیں مِثال دے بیان کرݨ وِچ اَللہ کیا چَہندے، اِیں ڳالھُوں اَللہ جیکُوں چَہندے گُمراہ تِھیوَݨ ݙیندے اَتے ہِدایت ݙے ݙیندے جِیکُوں چَہندے، اَتے کوئی وِی نھیں ڄاݨدا تیݙے رَبّ دے لَشکراں کُوں سِوائے خُود اُوندے آپ دے، اَتے اِیہ تاں کُجھ کائے نِھیں محض بَنی بَشر کِیتے ہِک نصیحت ہے (٣١)۔
74,32,کوئے نہ! اَساکُوں تاں قَسم ہے چَندر دِی (٣٢)۔
74,33,قَسم ہے رَات دِی، جِہڑے ویلے ڈھلدِی ویندی ہوندی ہے (٣٣)۔
74,34,اَتے قَسم ہے صبح دِی ڄَݙاں سُوجھلا تِھی ویندے (٣٤)۔
74,35,یقیناً (دَوزخ وِی) زَبردست شَئیں وِچُوں ہِک ہے (٣٥)۔
74,36,ہَر بَنی بَشر کُوں ݙَراوَݨ والی ہے (٣٦)۔
74,37,تُہاݙے وِچُوں ہَر اُوں شَخص کِیتے، جِہڑا چَہندے جو (بَھلائی کِیتے) اَڳُوں تے وَدّھے یا پِچُّھوں تے ہَٹ تے رَہے (٣٧)۔
74,38,ہر شَخص جِہڑے جِہڑے عَمل اُوں کِیتِن اُنھاں دے بَدلے رَہݨ رَکّھیا ہویا ہوندے (٣٨)۔
74,39,سِوائے سَڄّے پاسے والیاں دے (٣٩)۔
74,40,جِہڑے جو بَہشتی باغاں وِچ ہوسِن ، او پُچّھسِن ڳُچّھسِن (٤٠)۔
74,41,گُنہگاراں کنُوں (٤١)۔
74,42,جو تُہاکُوں کِہڑی شَئے دَوزخ وِچ گِھن آئی ہے (٤٢)۔
74,43,او آکھسِن، اَساں نماز پَڑھݨ والیاں وِچُوں کائے نہ ہَاسے (٤٣)
74,44,اَتے فَقیراں مِسکیناں کُوں کَھاݨاں نہ کَھویندے ہَاسے (٤٤)۔
74,45,اَتے اَساں بیہُودہ ڳالھِیں کَرݨ والیاں نال بیہُودہ ڳالھِیں کریندے ہَاسے (٤٥)۔
74,46,اَتے اَساں جَزا سَزا والے ݙین٘ہ کُوں کُوڑا اَہدے ہَاسے (٤٦)۔
74,47,اِیہ توڑِیں جو ہِیں حال وِچ اَساݙے کولھ یقینی طور تے آوَن٘ڄݨ والی آ ڳئی (٤٧)۔
