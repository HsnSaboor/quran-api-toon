quran[20{c,v,t}:
76,6,اِیہ ہِک اِہجا چَشمہ ہوسی، جِیندے وِچُّوں اَللہ دے بندے پِیسِن، او اُوں چَشمے دا پاݨِیں جِتَّھاں چَہسِن مَوج نال وَہا گِھن ویسِن (٦)۔
76,7,او لوک آپݨیاں مَنوتِیاں پُوریاں کریندِن، اَتے اُوں ݙین٘ہ کنُوں ݙَردِن جِیندی مُصیبت ہَر پَاسے کِھن٘ڈی ہوئی ہے (٧)۔
76,8,اَتے او لوک اُوندی (اَللہ دِی) محبت دِی وَجہ کنُوں مسکیناں فقیراں یتیماں تے قیدیاں کُوں کھاݨاں کھویندِن (٨)۔
76,9,(اَکھیندِن) دَراَصل اَساں تُہاکُوں محض اَللہ دِی رَضَا مَندی کِیتے کھاݨاں کھویندے ہَیں، اَساں تُساں کنُوں نِسّے چَہندے کوئی حَرجاݨاں (بَدلہ) تے نہ کوئی شُکرانہ (٩)۔
76,10,تحقیق اَساں آپݨیں رَبّ دِی طرفُوں اُوں ݙین٘ہ کنُوں ݙَردے ہَیں، جِہڑا ݙَاڈھا ݙَراکلا ہے، تے ٻَہُوں پریشان کرݨ والا ہے (١٠)۔
76,11,ٻَس اَللہ اُنھاں کُوں اُوں ݙین٘ہ دے شَر کنُوں بَچا گِھنسے، اَتے اُنھاں دے مُونھاں کُوں رونقاں تے دِلّاں کُوں خوشیاں نصیب کریسے (١١)۔
76,12,اَتے اُنھاں کُوں اُنھاں دے صَبر (ثابت قَدم رَہݨ) دے بدلے وِچ بَہشتی باغ ݙِتّا ویسی، تے ریشمی کَپڑے پَوائے ویسِن (١٢)۔
76,13,او اُوندے وِچّ اُچّیاں جائیں تے تَکیے لَا تے بیٹھے ہوسِن، نہ اُتّھاں سِجھ دِی تیز دُھپ ہوسی، تے نہ ٻَہُوں سَخت سَردی (١٣)۔
76,14,تے اُنھاں اُتّے اُوں (بَہشتی باغ) دِی چَھاں کِیتی ہوئی ہوسی، تے اُوندے میوے اُنھاں دے ہَتَّھاں توڑِیں جِھکّے تَھئے ہوئے ہوسِن، جِتّی جِھکّے تِھی سَڳدِن (١٤)۔
76,15,اَتے اُنھاں دے اَڳُوں چَاندی دے تَھاں، تے شیشے دے پیالے پیش کِیتے ویندے رَہسِن (١٥)۔
76,16,شِیشہ وِی او جِہڑا چَاندی دِی قِسم دا ہوسی، جِنھاں کُوں خاص اَندازے دے مطابق بݨایا ہویا ہوسی (١٦)۔
76,17,اُتَّھاں اُنھاں کُوں پیالیاں وِچ اِہجا شَربت پِلایا ویسے، جِیندے وِچ سُنڈھ دَا سَواد رَلایا ہویا ہوسے(١٧)۔
76,18,اُوندے وِچ ہِک چَشمہ ہوسی، جِیندا نَاں سَلسبیل رَکھیا ہویا ہے (١٨)۔
76,19,اَتے اُنھاں دے اَڳُوں ہمیشہ نِینگر رَہ وَن٘ڄݨ والے چُھوہَر، چَکر مریندے رَہسِن، جِہڑے ویلے تُوں اُنھاں کُوں ݙیکھسیں تاں اِیویں لَڳسِن، جِیویں کِھن٘ڈے ہوئے موتی ہووِن (١٩)۔
76,20,اَتے تُوں اُتَّھاں ڄِݙے وِی ݙیکھسیں، تاں اُوں جاء ڈھیر ساریاں نعمتاں تے ٻَہُوں وَݙی سلطنت دَا اِنتظام نظر آسی (٢٠)۔
76,21,اُنھاں کَپڑے پاتے ہوئے ہوسِن، ساوے باریک ریشم دے تے موٹے ریشم دے، اَتے اُنھاں کُوں چاندی دے کَنڳݨ پَوائے ویسِن، اَتے اُنھاں کُوں اُنھاں دَا رَبّ ٻَہُوں پاک شَراب پِلیسی (٢١)۔
76,22,تحقیق اِیہو ہے تُہاݙا بَدلہ، اَتے تُہاݙِیاں محنتاں دِی قَدر کِیتی ڳئی ہے (٢٢)۔
76,23,اَے رسول) یقیناً اَساں اِی تیݙے اُتّے قرآن نازِل کِیتا ہے، تھوڑا تھوڑا کر تے، جِیویں مُناسب سَمجھے (٢٣)۔
76,24,ٻَس تُوں آپݨیں رَبّ دے حُکم اُتّے ثابت قَدم رَہ، اَتے اُنھاں دے کَہیں بَد کردار یا کُفر کَرݨ والے دے آکھیے نہ لَڳیں (٢٤)۔
76,25,اَتے آپݨیں رَبّ دے نَاں دَا ذِکر کِیتی رَکّھ، فَجر ویلے وِی تے ݙین٘ہ لَتّھے وِی (٢٥)۔
