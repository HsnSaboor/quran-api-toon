quran[13{c,v,t}:
18,98,اُوں آکھیا، اِیہ میݙے رَبّ دِی طرفُوں ہِک رَحمت ہے ڄَݙاں میݙے رَبّ دا وَعدہ پُورا تِھیوݨاں ہوسی تاں او اِیکُوں زمین برابر کر ݙیسے اَتے میݙے رَبّ دا وَعدہ بالکل سَچّا ہے (٩٨)۔
18,99,اَتے اُوں ݙین٘ہ اَساں اُنھاں دے بعض لوکاں کُوں بعضیاں وِچ سِیڑھیاں وانگُوں رَل مِل وَن٘ڄݨ کِیتے چھوڑ ݙیسُوں، اَتے صُور (سَنکھ) پُھوکیا ویسے ٻَس اَساں اُنھاں ساریاں کُوں کَٹّھا کر گِھنسُوں (٩٩)۔
18,100,اَتے اُوں ݙین٘ہ اَساں دَوزخ کُوں کافراں دے سامݨیں آ کھڑیسُوں (١٠٠)۔
18,101,اُنھاں لوکاں دِیاں اَکّھیں تے تاں میݙے ذِکر کنُوں پَردہ پِیا ہوئیا ہَا، اَتے نہ او کُجھ سُݨݨ کِیتے تَیّار ہِن (١٠١)۔
18,102,کیا جِنھاں کُفر اِختیار کِیتا ہوئے اِیہُو گُمان کریندِن جو او اَساݙیْاں بندیاں کُوں مَیں کنُوں اَن٘ج آپݨاں کارساز (مَددگار) بݨا گِھنسِن، بیشک اَساں تاں کافراں دِی مہمانی کِیتے دَوزَخ تَیار کِیتی ہوئی ہے (١٠٢)۔
18,103,(اَے رسول) آکھ ݙے جو مَیں تُہاکُوں ݙَسا ݙیوَاں جو کِہڑے لوک عَملاں دے لحاظ نال ٻَہُوں ڳَھاٹے وِچ ہِن (١٠٣)۔
18,104,اِیہ او ہِن، جِنھاں دِیاں کوششاں تے محنتاں دُنیاوی زِندگی وِچ ضائع تِھی تے رہ ڳئِن اَتے او سَمجھدے رِیہن جو او دَراَصل چَن٘ڳے کَمّ کریندے وَدّے ہِن (١٠٤)۔
18,105,اِیہے او لوک ہِن جِنھاں آپݨیں رَبّ دِیاں آیاتاں کنُوں اِنکار کِیتے اَتے اُوندے اَڳُوں پیش تِھیوَݨ کُوں وِی نَھیں مَنّیا، ٻَس او اَپݨیاں عَملاں کُوں غارت کر کھڑِن، اِیں حَد تئیں جو قیامت دے ݙین٘ہ اُنھاں کِیتے انھاں عَملاں دَا کوئی وَزن وِی نہ سَمجھسُوں (١٠٥)۔
18,106,اُنھاں دِی جَزا (بَدلہ) اِیہا دَوزخ اِی ہے اِیں ڳالھ دے بدلے جو اُنھاں کُفر اِختیار کِیتا ہَا، اَتے اَساݙِیاں آیاتاں، اَتے اَساݙے رَسُولاں کُوں مَذاق سَمجھ گِھدّا ہَانے (١٠٦)۔
18,107,بیشک جِہڑے لوک اِیمان گِھن آئے تے اُنھاں نیک عَمل کِیتے تاں اُنھاں دِی مہمانی کِیتے بَہشتی باغ ہوسِن (١٠٧)۔
18,108,اِیہ اُنھاں وِچ ہمیش رَہسِن، اَتے اُتُّھوں کہیں ٻئی جاء وَن٘ڄݨ دَا رُوح وِی نہ کریسے نے (١٠٨)۔
18,109,(اَے رسول) آکھ ݙے، جو جیکر سَمندر مَس بَݨ وَن٘ڄے تاں جو مَیں اَپݨیں رَبّ دِیاں ڳالھیں لِکّھ سَڳاں، تَاں وِی سَمندر مُک ویسے اِیں کنُوں پہلے جو مَیں آپݨیں رَبّ دِیاں ڳالھیں مُکا سَڳاں، توڑے جو اُوں وان٘گُوں ہِک ٻِیا (سمندر) وِی اُوندی مَدد کِیتے کِیُوں نہ گِھن آواں (١٠٩)۔
18,110,آکھ ݙے، جو بیشک مَیں تاں تُہاݙے وان٘گیں بَشر اِی ہَاں، ٻَس میݙے کولھ وَحی آندی ہے، (اِیں ڳالھ دِی) جو تُہاݙا اُوہُو ہِکُّو معبود ہے، ٻَس جِہڑا کوئی آپݨیں رَبّ دِی مُلاقات دِی خواہش رَکھیندے تاں اُوکُوں نیک عَمل کرݨیں چاہِیدے ہِن، اَتے اَپݨیں رَبّ دِی عبادت وِچ ٻئے کہیں ہِک کُوں وِی شریک نہ کرے (١١٠)۔
