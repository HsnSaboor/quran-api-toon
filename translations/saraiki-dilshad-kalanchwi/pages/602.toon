quran[14{c,v,t}:
106,1,قریش کُوں ہِک ٻَئے نال گُھلا مِلا ݙِتا ڳے(١)۔
106,2,اُنھاں کُوں گَرمی تے سَردی دے سَفراں کِیتے ہیلکا کر ݙِتا ڳے(٢)
106,3,ٻَس چاہیئے جو او اِیں گَھر دے رَبّ دِی عِبادت کرِن(٣)
106,4,جَیں اُنھاں کُوں بُھک ویلے کھاݨاں کھَوایا، اَتے ہَر طرح دے ݙَر ݙُکَّل کنُوں اَمان وِچ رَکھیا(٤)۔
107,1,اَے رسول) کیا تَیں اُوں شَخص کُوں ݙِٹّھے، جِہڑا آخرت دِی جَزا سَزا کُوں کُوڑ اَکھیندے(١)
107,2,ٻَس او اِیہُو تاں ہے جِہڑا یتیم کُوں دِھکّے ݙیندے(٢)۔
107,3,اَتے مسکین فقیر کُوں کھاݨاں کھواوَݨ دِی کوئی ترغیب وِی نھیں ݙیویندا(٣)
107,4,ٻَس شامت ہے، اُنھاں نمازیاں دِی(٤)
107,5,جِہڑے جو آپݨیاں نمازاں کنُوں خُود کُوں غافِل کر ݙیندِن(٥)
107,6,جِہڑے محض ݙیکھاوا کریندِن(٦)۔
107,7,اَتے عَام وَرتݨ دِیاں شَئیں وِی مَانگویاں ݙیوݨ کنُوں ہَٹکیندے(٧)۔
108,1,اَے رسول) یقیناً اَساں تیکُوں بے حِسابیاں نعمتاں ݙِتِّن(١)۔
108,2,ٻَس آپݨیں رَبّ دِی نماز پَڑھ ، تے قربانی کِیتی کر(٢)۔
108,3,یقیناً تیݙا دُشمن اِی اَوترک (بے اولادا) ہے(٣)۔
