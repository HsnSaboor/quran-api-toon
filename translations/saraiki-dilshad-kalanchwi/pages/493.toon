quran[13{c,v,t}:
43,48,حالانکہ جِہڑی کوئی نِشانی اُنھاں کُوں ݙیکھیندے ہَاسے او آپݨیں بھیݨ (پہلے والی نِشانی) کنُوں وَݙی ہوندی ہَئی وَت اَساں اُنھاں کُوں عذاب وِچ گَھت ݙِتا تاں جو او باز آ وَن٘ڄِن (٤٨)۔
43,49,اَتے او آکھݨ لڳ پَے، جو اَے جادوگر ! اَساݙے کِیتے آپݨیں رَبّ کنُوں اُوں شَئے دِی دُعا مَنگ جِیندا تیݙے نَال وعدہ کِیتا ڳئے، یقیناً اَساں سِدّھے رَاہ تے آویسُوں (٤٩)۔
43,50,ٻَس ڄَݙاں اَساں اُنھاں کنُوں عذاب ہَٹا گِھدّا تاں جَھٹ پَٹ او آپݨیں وَعدے کنُوں پِھر ڳئے (٥٠)۔
43,51,اَتے فِرعون آپݨِیں قوم کُوں اِعلان کر تے آکھیا، اَے میݙی قوم ! کیا اِیہ مِصر دِی حکومت میݙے کولھ کائے نھیں؟ اَتے کیا اِیہ نَہراں وِی (میݙیاں کائے نھیں) جِہڑیاں میݙے پیراں تَلّے وَہندیاں پَئین، کیا تُہاکُوں کُجھ وِی نظر نھیں پِیا آندا؟ (٥١)۔
43,52,کیا مَیں اِیں شخص کنُوں چَن٘ڳا نِمہیں، جِہڑا ٻَہُوں گھٹیا ہے، اَتے ڳالھ کُوں صاف صاف آکھ وِی نھیں سَڳدا (٥٢)۔
43,53,بَھلا اِیکُوں سونے دے کنگݨ کیوں نھیں پَوائے ڳئے، یا اِیندے نال فرشتے جھمگھٹا لا تے کیوں نھیں آئے (٥٣)۔
43,54,پر اُوں آپݨِیں قوم کُوں نِکمّی آکھ تے وِندلا گِھدّا، ٻَس انھاں اُوندی فرمانبرداری اختیار کر گِھدّی، دَراَصل او ہَئی وِی نافرماناں دِی قوم! (٥٤)۔
43,55,ٻَس ڄَݙاں اُنھاں اَساکوں ݙَاڈھی کاوِڑ چَڑھائی تاں اَساں اُنھاں کنُوں اِنتقام گِھدّا ٻَس ساریاں کُوں کٹھا غرق کر چھوڑیا (٥٥)۔
43,56,ٻَس اَساں انھاں کُوں ڳئے گُزرے لوکاں وِچ ڳِݨا چھوڑیا، تے پِچُّھوں آوَݨ والیاں کِیتے ہِک (عبرت دِی) مثال قائم کر ݙِتی (٥٦)۔
43,57,اَتے ڄَݙاں مَریم دے پُتر دِی مِثال سُݨائی ڳئی، تاں اُونہہ ویلے تیݙی قوم کِھل ہاسیاں وِچ شور مَچا ݙِتا (٥٧)۔
43,58,اَتے آکَھݨ لڳیے، جو کیا اَساݙے معبود چَن٘ڳے ہِن، یا او ! انھاں لوکاں تیکُوں اِیں واسطے اِیہ آکھیئے تاں جو تیݙے نال بحثا بحثی کرِن، دَراَصل اِیہ تاں اِیہ ہِک جھڳڑیل قوم ہَن (٥٨)۔
43,59,او (مَریم دا پُتر) تاں اَساݙا ٻانہاں ہَا، اَساں اُوندے اُتّے ٻَہُوں فَضل کِیتا، اَتے اُوکُوں اِسرائیل دے لوکاں (بنی اِسرائیل) کِیتے ہِک مِثال (قُدرت دا نمونہ) بݨا چھوڑیا (٥٩)۔
43,60,اَتے جیکر چَہوُوں تاں اَساں تُہاݙے وِچُوں فرشتے بݨا چھوڑوں، جِہڑے زمین اُتے تُہاݙے وَلی وارث (جانشین) بݨدے رَہوِن (٦٠)۔
