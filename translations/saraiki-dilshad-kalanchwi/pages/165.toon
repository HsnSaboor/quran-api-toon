quran[10{c,v,t}:
7,121,آکھݨ لڳیئے، جو اَساں مَن گِھدے سارے جہاناں دے پالݨ ہار کُوں (١٢١)۔
7,122,جِہڑا جو موسیٰ تے ہارون دا رَبّ وِی ہے (١٢٢)۔
7,123,(فرعون) آکھیا، تُساں تاں اِیں کنُوں وِی پہلے اِیمان گِھن آئے وے جو مَیں تُہاکوں اِیندی اِجازت ݙیواں ہا، بیشک اِیہ کوئی مکر (دھوکا) ہے جِہڑا تُساں مِل تے شہر والیْاں نال کر ݙیکھائے تاں جو تُساں شہر والیْاں کُوں اِیندے وِچوں کڈھ چھوڑو، تُہاکوں ہُݨیں جلدی اِیندے انجام دا پَتہ لڳ ویندے (١٢٣)۔
7,124,مَیں پہلے تاں تُہاݙے ہِک پاسے دا ہَتھ تے ٻَے پاسے دا پیر کَپ ݙیساں وَل تُساں ساریاں کُوں سُولی تے چَڑھا ݙیساں (١٢٤)۔
7,125,اُنھاں (فرعون کُوں) آکھیا جو اَساں تَاں آپݨِیں رَبّ دو بالکل وَلیے ویندے ہَیں (١٢٥)۔
7,126,بَھلا تیکوں (اَساݙی کِہڑی ڳالھ) انتقام گِھنّݨ تے اُبھارئیے، ٻَس اِیہا جو اَساں آپݨِیں رَبّ دِیاں آیاتاں اُتے اِیمان گِھن آئے ہَیں جو او اَساݙے کولھ آ ڳئین، اَساݙے رَبّ آ! اَساکوں ڈھیر سارا صَبر چا ݙے، اَتے اَساکوں ماریں تاں اِیمان اُتے ماریں (١٢٦)۔
7,127,اَتے فرعون دِی قوم دے سرداراں پُچھیا جو کیا تُوں موسیٰ تے اُوندی قوم کُوں آزاد چھوڑ ݙیسیں تاں جو او زمین اُتے فساد مَچاوِن وَدّے، اَتے تیکوں تے تیݙے معبوداں کُوں چھوڑ وَن٘ڄن، (فرعون) آکھیا، جو اَساں ہُݨیں اُنھاں دے پُتراں کُوں تاں ضرور قتل کر چھوڑیندے ہَیں، تے انھاں دِیاں زنانیاں کُوں جیندا رَہݨ ݙیندوں اَساں تاں انھاں اُتے قہر وَساوَݨ والے ہَیں (١٢٧)۔
7,128,مُوسیٰ اَپݨِیں قوم کُوں آکھیا، اَللہ کنُوں مَدد من٘گو، تے تکڑے تھیئے رَہو، یقیناً اِیہ زمین اَللہ دِی ہے، او آپݨیاں بندیاں وِچوں جِنھاں کُوں چَہندے اِیندا وارِث بݨا ݙیندے آخر تے وِی بھلائی (کامیابی) تاں اَللہ کنُوں ݙرݨ والیاں کِیتے ہے (١٢٨)۔
7,129,اُنھاں آکھیا، تیݙے آوَݨ کنُوں پہلے اَساکوں اَذیّتاں ݙِتیاں ویندیاں ہن، اَتے تیݙے آون٘ڄݨ دے بعد وِی ݙتیاں ویندیاں پیئن، اُوں آکھیا، ٻَہُوں جَلدی تہاݙا پالݨ ہار تُہاݙے دُشمناں کُوں برباد کر چھوڑیسی، اَتے تُہاکوں زمین اُتے خلیفہ ٻݨا ݙیسی تاں جو ݙیکھ گِھنے، جو تُساں کِہجے عمل کریندو (١٢٩)۔
7,130,وَل اَساں پَھسا چھوڑیا، فرعون دِی قوم کُوں کئی سالاں دے قحط وِچ، تے میویاں دِی کَمی تِھی وَن٘ڄݨ وِچ! جو شاید (اِیں طرح) نصیحت (عبرت) وِی حاصِل کرن (١٣٠)۔
