quran[8{c,v,t}:
5,24,ٻَس اُنھاں اِیہو جواب ݙِتا جو اَے موسیٰ اَساں کݙائیں وِی اُوں وِچ داخل نھیں تِھیوݨ لڳے، جے توڑیں جو او اِتھاں ݙیٹے کھڑن، ٻَس تُوں تے تیݙا رَبّ ݙوہیں وَن٘ڄ لَڑو، اَساں تاں اِتھائیں ٻیٹھے ہَیں (٢٤)۔
5,25,موسیٰ آکھیا، میݙے رَبّ آ! میݙا تاں کہیں اُتے کوئی اختیار کائے نھیں، سِوائے آپݨیں آپ اُتے، تے اَپݨیں بِھرا اُتے، ٻَس تُوں اَساکوں اِنھاں فتوری لوکاں وِچوں نِکھیڑ گِھن (٢٥)۔
5,26,اَللہ آکھیا، چلو او (ملک) اِنھاں اُتے چالیھ سالاں تَئیں حرام کِیتا ویندے، تے اِیہ زمین اُتے رُلدے مَردے رَہسِن، تُوں اِیں نافرمان قوم دے حال تے کوئی اَرمان نہ کر (٢٦)۔
5,27,اَتے انھاں کُوں آدم دے ݙوں پُتراں (ہابیل تے قابیل) دے حال دِی حقیقت پڑھ سُݨاؤ، ڄݙاں جو اُنھاں ݙوہائیں قربانی کِیتی، چُنانچہ اُنھاں وِچوں ہِک (ہابیل) دِی قربانی قبول تِھی ڳئی تے ݙوجھے دِی قبول نہ تِھی سڳی، تاں (قابیل) آکھیا جو مَیں تیکوں قتل کر چھوڑیساں پر اُوں (ہابیل) آکھیا، جو اَللہ تاں پرہیزگاراں دِی قربانی قبول کریندے (٢٧)۔
5,28,جیکر تُوں میکوں قتل کرݨ کِیتے ہَتھ اَڳوں تے وَدھیندے، وَدھا پَر مَیں آپݨاں ہَتھ تیݙے اُتے اَصلوں نہ وَدھیساں، جو تیکوں قتل کراں، کیوں جو مَیں سارے جہاناں دے پالݨ والے رَبّ کنُوں ݙرداں (٢٨)۔
5,29,مَیں چَہنداں جو تُوں (اِیں طرح) میݙا گُناہ تے آپݨاں گُناہ (ݙوہائیں) اَپݨیں ذِمے لا گِھن، ٻَس وَل (دوزخ دِی) بَھا وِچ رَہݨ والیاں نال وَن٘ڄ رَل، کیوں جو ظالم لوکاں دِی جزا اِیہا کُجھ ہوندی ہے (٢٩)۔
5,30,پَر اُوں (قابیل) دے نفس (امارہ) اُوکوں بِھرا دے قتل اُتے تیار کر گِھدا، تے اُوں آپݨیں بِھرا کُوں قتل کر چھوڑیا، تے گھاٹا چاوݨ والیاں وِچوں تِھی ڳیا (٣٠)۔
5,31,اَللہ ہِک کاں کُوں بھیڄا، جِہڑا زَمین کھٹݨ لڳ پِیا، تاں جو اُوکوں ݙِکھاوے جو او اَپݨیں بِھرا دِی لاش کِیوِیں پُور ݙیوے، (تَݙاں) او آکھݨ لڳا اَفسوس ہے میݙے اُتے جو مَیں اِیں کَاں جیہا وِی نمہیں، جو اَپݨیں بِھرا دِی لاش پورݨ جوگا تِھی سڳدا، ٻَس او ٻَہُوں شرمسار تِھیا (٣١)۔
