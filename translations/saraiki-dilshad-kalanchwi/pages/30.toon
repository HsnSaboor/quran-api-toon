quran[3]{c,v,t}:
  30,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  30,1,الف لام میم (١)۔
  30,2,رومی لوک مغلوب تِھی ڳِن (٢)۔
  30,3,آپݨیں کولھوں دے ہِک ملک وِچ، اَتے او اَپݨیں ہَریج وَن٘ڄݨ دے بعد ٻَہُوں جلدی جیت ویسن (٣)۔
  30,4,تھوڑے سالاں وِچ! اَللہ دا حُکم سب تُوں پہلے وِی چَلدا آئے اَتے بعد وِچ وِی چَلدا رَہسی اَتے اُوں ݙین٘ہ ایمان والے لوک ٻَہُوں خُوش ہوسِن (٤)۔
  30,5,اَللہ دِی ݙتی فتح اُتے! او جیکوں چَہندے ، فتح ݙیندے، اَتے او ٻَہُوں زبردست تے وَݙی رحمت کرݨ والا ہے (٥)۔
  30,6,اِیہ اَللہ دا وَعدہ ہے، اَللہ آپݨیں وعدے کنُوں اَصلوں نھیں پِھردا، پَر ڈھیر لوک اِیہ ڄاݨدے وِی نھیں (٦)۔
  30,7,اِیہ لوک دُنیاوی ظاہروی زِندگی کُوں تاں ڄاݨدِن پَر او آخرت کنُوں اَصلُوں غافِل ہِن (٧)۔
  30,8,کیا انھاں آپݨیں دِل وِچ غور نھیں کِیتا، جو کیا اَللہ اِی پَیدا نھیں کِیتا اَسماناں کُوں تے زمین کُوں اَتے جو کُجھ اُنھاں دے درمیان ہے، او وِی حقّی طور تے اَتے ہِک مقرر وقت تائیں! اَتے بیشک انھاں لوکاں وِچُوں ڈھیر کوئی آپݨیں رَبّ کُوں وَن٘ڄ ملݨ کُوں منیندے وِی نھیں (٨)۔
  30,9,کیا اِیہ لوک زمین اُتے ٹُریے پِھریے کائے نھیں، شاید جو انھاں ݙیکھ گِھدا ہووے جو انھاں کنُوں پہلے دے لوکاں دِی عاقبت کِہجی تِھی چُکی ہے حالانکہ او لوک اُنھاں کنُوں طاقت وِچ زیادہ ہَن، اَتے انھاں زمین کُوں خوب جُتیا وَہایا، اُنھاں اِیکوں اِتی زیادہ آباد کر چھوڑیا جتّی جو اِنھاں وی نھیں کِیتا، اَتے انھاں دے رسول اُنھاں کولھ کُھلیاں نشانیاں گِھن تے آئے، اَللہ تاں اِہجا کائے نھیں جو انھاں اُتے ظلم کرے بلکہ او تاں خود آپݨیں آپ اُتے ظلم کریندِن (٩)۔
  30,10,وَل انھاں لوکاں دِی عاقبت ٻَہُوں خَراب تَھئی جِہڑے جو گندے کَم کریندے ہن، کیوں جو انھاں اَللہ دِیاں آیاتاں کُوں کُوڑا آکھیا، اَتے انھاں اُتے کِھلّاں کریندے رِیہے (١٠)۔
  30,11,اَللہ تاں پہلی واری وِی (مخلوق کُوں) پَیدا کریندے اَتے وَلا وِی اُوکوں پَیدا کریسے ، وَل تُساں سارے اُوں دو وَلائے ویسو! (١١)۔
  30,12,اَتے جِہڑے ݙین٘ہ قیامت دِی گھڑی آویسی، تاں مجرم (قصور وار) لوک ہَکّے ٻَکّے تِھی تے رہ ویسِن (١٢)۔
  30,13,اَتے انھاں دے خُدا دے شریک بݨائے ہوئیاں وِچُوں کوئی وِی انھاں دِی سفارش کرݨ والا کائے نہ ہوسی، اَتے او تاں خود وِی اَپݨیں بݨائے ہوئے (خُدا دے) شریکاں کُوں منّݨ کنُوں پِھر ویسن (١٣)۔
  30,14,اَتے جِہڑے ݙین٘ہ قیامت دِی گھڑی آ ویسی اُوں ݙین٘ہ سارے اَن٘ج اَن٘ج کر ݙِتے ویسِن (١٤)۔
  30,15,ٻَس اَلبتہ جِہڑے لوک اِیمان گِھن آئے تے نیک عَمل وِی کِیتی رَکھئے، ٻَس او بہشتی باغ وِچ ( ٹِکا تے) خوش کر ݙِتے ویسن (١٥)۔
  30,16,اَتے جِنھاں لوکاں کُفر اِختیار کِیتا ہوئے اَتے اَساݙیاں آیاتاں کُوں تے آخرت دِی مُلاقات کُوں کُوڑا آکھیئے تاں اِیہے لوک عذاب دے پابند رَکھیئے ویسن (١٦)۔
  30,17,ٻَس اَللہ دِی تسبیح (اُوندے پاک ہووݨ کُوں) پڑھی رَکّھو، ڄَݙاں جو شام تِھی وَن٘ڄے، اَتے تُہاکوں وݙا ویلا تِھی وَن٘ڄے (١٧)۔
  30,18,اَتے سب تعریف اُوندے کِیتے ہے، اَسماناں وِچ وِی تے زمین تے وِی، اتے تریجھے پہر اَتے جِہڑے ویلے ظہر تِھی وَن٘ڄے اُوں ویلے وِی تسبیح (نماز) پڑھو (١٨)۔
  30,19,او زِندہ (جاندار) شَئے کُوں مُردہ (بے جان) شَئے وِچُّوں کڈھیندے چا، اَتے مُردہ شَئے وِچُّوں جِیندی ہوئی شَئے کُوں کڈھیندے چا، اَتے زمین کُوں وِی اُوندے سَڑ سُک وَن٘ڄݨ دے بعد جیوا چھوڑیندے، اَتے اِیویں تُساں وِی کَڈھے ویسُو (١٩)۔
  30,20,اَتے اِیہ وِی اُوندیاں نِشانیاں وِچُوں ہے جو اُوں تُہاکوں مِٹی وِچُّوں پَیدا کِیتے ٻَس تُساں ٻَہُوں جَلدی انسان بݨ ویندو، ہر پاسے کِھنڈدے وِیندو (٢٠)۔
  30,21,اَتے اِیہ وِی اُوندیاں نشانیاں وِچُوں ہے، جو اُوں تُہاݙے آپݨیاں وِچُوں تُہاݙے کِیتے ذالیں پَیدا کِیتئِن، تاں جو تُساں اُنھاں نال سُکھ سکون نال رَہو، اَتے اُوں تُہاݙے درمیان محبت تے مہربانی پَیدا کر ݙِتی ہے بیشک اِیندے وِچ نِشانیاں ہِن، اِنھاں لوکاں کِیتے جِہڑے غور فکر کریندِن (٢١)۔
  30,22,اَتے اِیہ وِی اُوندیاں نشانیاں وِچُوں ہے، جو اُوں اَسماناں کُوں تے زمین کُوں پَیدا کِیتے، اَتے تُہاݙے ٻولیاں وِچ فرق گھت ݙِتے، تے تُہاݙے رَنگاں وِچ وِی، بیشک انھاں وِچ وِی نشانیاں ہِن ڄاݨݨ والیاں کِیتے (٢٢)۔
  30,23,اَتے اِیہ وِی اُوندیاں نِشانیاں وِچُوں ہے، جو تُہاݙا سَمھݨ ہے راتیں کُوں تے ݙین٘ہ کُوں وِی، اَتے اُوندا فضل (رِزق) ڳولھݨ وِی ہے، بیشک اِیندے وِچ اُنھاں لوکاں کِیتے نشانیاں ہِن، جِہڑے سُݨدے سَمجھدے ہِن (٢٣)۔
  30,24,اَتے اِیہ وِی اُوندیاں نِشانیاں وِچُوں ہے جو او تُہاکوں بجلی چَمکدی ݙیکھیندے جیندے وِچ تُساں ݙردے وِی ہِیوے، تے طمع وِی رَکھیندے وے، اَتے اسمان کنُوں پاݨِیں بھیڄیندے، ٻَس اُوندے نال زمین ساوِی (زِندہ) کر چھوڑیندے، اُوندے سُک سَڑ وَن٘ڄݨ دے بعد، بیشک اِیندے وِچ نِشانیاں ہِن اُنھاں لوکاں کِیتے جِہڑے عَقل کنُوں کَم گِھندِن (٢٤)۔
  30,25,اَتے اِیہ وِی اُوندیاں نِشانیاں وِچُوں ہے، جو اُوں قائم کر کھڑائے اَسمان کُوں تے زمین کُوں اَپݨیں حُکم نال، وَل ڄَݙاں اُوں تُہاکوں ہِک واری زمین وِچُوں سݙیا تاں ٻَس تُساں جھٹ پَٹ نِکل آسو (٢٥)۔
  30,26,اَتے اُوندا اِی ہے جو کُجھ اَسماناں وِچ تے زمین دے تَلے اُتے ہے سارے اُوندی فرمانبرداری کرݨ والے ہِن (٢٦)۔
  30,27,اَتے اُوہو اِی ہے، جِہڑا پہلی واری خلقت کُوں پَیدا کریندے وَلا ݙوجھی واری وِی اِیویں چا کریسی، اَسماناں وِچ تے زمین وِ چ تاں اُوندی شان ٻَہُوں اُچّی ہے، اَتے او زبردست ہے وَݙی دانائی والا ہے (٢٧)۔
  30,28,اُوں تُہاݙے کِیتے خود تُہاݙے آپݨیں وِچُوں ہِک مثال ݙِتی ہے جو کیا، جِنھاں دے مالک تُہاݙے سَڄّے ہَتھ ہن، انھاں وِچُوں کوئی اِہجے وِی ہِن، جِہڑے تُہاݙے شریک ہووِن اُوں رِزق وِچ جِہڑا اَساں تُہاکوں ݙِتا ہے؟ اِیں طرح تُساں اُنھاں دے برابر دے حِصّے دار تِھی وَن٘ڄو! تُساں تاں انھاں کنُوں ݙردے وِی اِیویں ہِیوے، جیویں تُساں آپس وِچ ݙردے وے؟ اِیں طرح اَساں آیاتاں کُوں انھاں کِیتے کھول کھول تے بیان کریندے ہَیں (٢٨)۔
  30,29,جِہڑے جو عقل کنُوں کَم گِھندِن، بلکہ جِہڑے لوک بے انصافی کریندِن، او بغیر کہیں عِلم دے آپݨیاں خیالاں خواہشاں دِی پَیروی کریندِن بَھلا اُنھاں کُوں کوݨ سِدّھا رَاہ ݙِیکھا سَڳدے جِنھاں کُوں اَللہ گُمراہ چَا کرے، اَتے انھاں کُوں مدد ݙیوݨ والا وِی کوئی کائے نھیں (٢٩)۔
  30,30,ٻَس تُساں آپݨاں رُخ خاص کر تے اِیں دین دو قائم کِیتی رَکّھو، اَللہ دِی اُوں فطرت اُتے وِی قائم تِھی رَہوو، جِیندے اُتے اُوں انسان کُوں پَیدا کِیتے، اَللہ دِی بݨائی فطرت وِچ تبدیلی کائے نھیں، اِیہو پِکّا تے سِدّھا دِین ہے، پَر لوکاں وِچوں ڈھیر کوئی نھیں ڄاݨدے (٣٠)۔
  30,31,اُوں دو رجوع کِیتی رَکھو، اَتے اُوں کنُوں ݙردے رَہوو، اَتے نماز قائم کِیتی رَکھو، اَتے شِرک کرݨ والیاں وِچُوں ہرگز نہ تِھی وَن٘ڄݨاں (٣١)۔
  30,32,انھاں وِچُوں (وِی نہ) جِنھاں اَپݨیں دِین کُوں ٹوٹے ٹوٹے کر گِھدے اَتے فِرقے فِرقے تِھی ڳیئِن، ہر ہِک فرقہ جو کُجھ اُوندے کولھ ہے اُوندے اُتے مَست ہے (٣٢)۔
  30,33,اَتے ڄَݙاں لوکاں کُوں کوئی تکلیف تِھیندی ہے، تاں او اَپݨیں رَبّ کنُوں اُوندو پُورا رَجوع کر تے دُعا منگدِن (سݙیندِن) ، وَل ڄَݙاں انھاں کُوں آپݨیں رَحمت دا مَزہ چَکھا ݙیندے تاں انھاں وِچُوں کوئی ٹولی تاں جَھٹ پَٹ اَپݨیں رَبّ دا شریک ٻݨاوَݨ لڳ پوندی ہے (٣٣)۔
  30,34,تاں جو او ناشُکری کرن اُوندی جو کُجھ اَساں انھاں کُوں ݙِتے ، چلو مَزّے کر گِھنّو ٻَس ٻَہُوں جلدی تُہاکوں (اِیندے اَنجام دا) پَتہ لڳ ویسی (٣٤)۔
  30,35,کیا اَساں انھاں کولھ کوئی اِہجی دلیل نازِل کِیتی ہے جِہڑی جو انھاں کُوں ݙسیندی ہے اُوں شَئے دے بارے وِچ جیکوں او اَللہ دا شریک ٻݨیندِن (٣٥)۔
  30,36,اَتے ڄݙاں اَساں انساناں کُوں آپݨِیں رحمت دا مَزہ چَکھیندے ہَیں، تاں او اُوندے اُتے پُھن٘ڈ ویندِن، اَتے جیکر انھاں کُوں کوئی ݙُکھ پہنچے، او وِی اُوندی وَجہ کنُوں جِہڑا کُجھ اُنھاں آپݨیں ہَتھیں نال اَڳلے جہان کِیتے بھیڄیا ہے (٣٦)۔
  30,37,تاں او جلدی نا اُمید تِھی ویندے ہِن، کیا انھاں نھیں ݙِٹھا جو بیشک اَللہ اِی اُوندا رِزق کُھلا کر ݙیندے جِیندے کِیتے چَہندے اَتے تنگ وِی کر ݙیندے، بیشک اِیندے وِچ نشانیاں ہِن اُوں قوم کِیتے جِہڑی اِیمان گِھن آندی ہے (٣٧)۔
  30,38,تُوں آپݨیاں قریبی سکّیاں کُوں انھاں دا حق اَدا کر، اَتے مِسکین دا وِی تے مُسافر دا وِی، اِیہ انھاں لوکاں کِیتے چَن٘ڳی ڳالھ ہے جِہڑے اَللہ دِی رَضا مَندی چَہندِن، اَتے اِیہے ہِن مُراداں پاوَݨ والے (٣٨)۔
  30,39,اَتے جِہڑا سُود تُساں اِیں کِیتے ݙیندو جو لوکاں دا مال وَدّھ وَن٘ڄے، تاں او اَللہ دے نزدیک اَصلُوں نھیں وَدھدا، اَتے جِہڑا کُجھ تُساں زکوٰۃ دے طور تے اَللہ دِی رَضا مَندی کِیتے ݙیندے وے ٻَس اِیہے او لُوک ہِن جِہڑے اَپݨیں مال کُوں ݙوڑا چوڑا کرݨ والے ہِن (٣٩)۔
  30,40,اَتے اَللہ تاں او ہے، جَیں تُہاکوں پَیدا کِیتے، وَل تُہاکوں رِزق ݙتے، وَل تُہاکوں موت چا ݙیسی، وَل تُہاکوں جِیوا کھڑا کریسی، کیا تُہاݙے ٻݨائے ہوئے شریکاں وِچُوں کوئی اِہجا ہے، جو انھاں کَمّاں وِچُوں کوئی ہِک وِی کریندا ہووے؟ او (اَللہ) تاں (ہر شَئے کنُوں) پَاک ہے، اَتے او اُنھاں شَئیں کنُوں ٻَہُوں اُچّا ہے، جِنھاں کُوں اُوندا شریک بݨیندے ہِن (٤٠)۔
  30,41,خشکی تے تری اُتے اُوں کنُوں فساد پَیدا تِھی ڳئے جِہڑا کُجھ لوکاں آپݨیں ہَتّھیں نال کمائے ، تاں جو اَللہ اُنھاں کُوں مَزہ چَکھاوے، بعضے عملاں دا جِہڑے انھاں کِیتئِن، شاید او (سِدّھی رَاہ تے) وَل آوِن (٤١)۔
  30,42,آکھ جو زمین اُتے ٹُرو پِھرو ٻَس ݙیکھو جو تُساں کنُوں پہلے والے لوکاں دِی عاقبت کِہجی تَھئی ہَئی، انھاں وِچُوں ڈھیر کوئی تاں مُشرک اِی ہِن (٤٢)۔
  30,43,ٻَس آپݨاں رُخ درست تے سِدّھے دِین دو کِیتی رَکھ اِیں کنُوں پہلے جو او ݙین٘ہ آوَن٘ڄے، جیندے ٹَل وَن٘ڄݨ دِی اَللہ دِی طرفوں کوئی وَجہ کائے نھیں اُوں ݙین٘ہ لوک اَن٘ج و اَن٘ج تِھی ویسن (٤٣)۔
  30,44,جَیں کُفر اِختیار چا کِیتا تاں اُوندے کُفر دَا وَٻال اُوندے سِر تے ہے، اَتے جَیں نیک عَمل کِیتے او اَپݨیں کِیتے چَن٘ڳائی دی جاء ٻَݨیندے (٤٤)۔
  30,45,او انھاں لوکاں کُوں جِہڑے جو اِیمان گِھن آئِن اَتے نیک عَمل وِی کِیتے ہِنیں اَپݨیں فضل وِچُوں بَدلہ ݙیسے، بیشک او کافر لوکاں کُوں پَسند نھیں کریندا (٤٥)۔
  30,46,اَتے اُوندیاں نِشانیاں وِچُوں ہِک اِیہ وِی ہے، جو او ہوائیں کُوں خوشخبری ݙیوݨ والیاں بݨا تے بھیڄیندے تاں جو او آپݨِیں رحمت دا تُہاکوں مَزہ چَکھاوے تے ٻیڑیاں وِی اُوندے حُکم نال ٹھلدیاں تردیاں رہون، اَتے اِیہ اِیں واسطے ہے جو تُساں اُوندے فَضل کُوں حاصل کرو، تے تاں جو تُساں شُکر اَدا کرو (٤٦)۔
  30,47,اَتے تحقیق اَساں تیں کنوں پہلے وی انہاں دی آپݨی قوم دو رسول بھیڄے، ٻس او انہاں کول صاف صاف نشانیاں گھن آئے، تے ٻس جنہاں جُرم کیتی رکھیے، تاں اساں انھاں کنُوں بَدلہ گِھن چھوڑیا، ٻَس مومناں کُوں مَدد ݙیوݨ اَساݙے اُتے لازِم ہَا (٤٧)۔
  30,48,اَللہ تاں او ہے، جِہڑا ہوائیں کُوں گھولیندے جِہڑیاں بَدّلاں کُوں ٻِیا وِی اُچّا کر ݙیندِن، ٻَس او انھاں کُوں اَسمان تے کھن٘ڈا ݙیندے، جَیں طرح چَہندے، اَتے انھاں دِیاں تَہیں بݨا ݙیندے، وَل تُوں مِین٘ہ کُوں ݙیکھدیں جو کیویں انھاں وِچُوں نکلݨ پَے ویندے، ٻَس ڄَݙاں او وَسا ݙیندے آپݨیاں بندیاں وِچُوں انھاں اُتے جِنھاں کُوں چَہندے تاں وَت او یَکدم خوشیاں منیندِن (٤٨)۔
  30,49,حالانکہ اِیں کنُوں پہلے جو مِین٘ہ اُنھاں اُتے لہایا وَن٘ڄے او اِیں کنُوں وِی پہلے نا اُمید تَھئے ہوئے ہوندِن (٤٩)۔
  30,50,ٻَس اَللہ دِی رحمت دِیاں نشانیاں کُوں ݙیکھ جو کَیں طرح زمین کُوں ساوِی (زندہ) کر ݙیندے اُوندے سُک سَڑ وَن٘ڄݨ (مَرن) دے بعد، بیشک او اِیویں مُردیاں کُوں جِیوا کھڑا کریسی، اَتے او ہَر شَئے اُتے پُوری قدرت رَکھیندے (٥٠)۔
  30,51,اَتے جیکر اَساں ہِک اِہجی ہَوا بھیڄ ݙیوُوں جو او اَپݨیں رڑھ (کھیتی) کُوں سُک تے پِیلا تھیا ݙیکھن تاں اُوندے بعد ضرور ناشُکری کرݨ لڳ پوندِن (٥١)۔
  30,52,ٻس بیشک تُوں نہ تاں مُردیاں کُوں سُݨا سَڳدیں اَتے نہ ٻوڑیاں کُوں سُݨا سَڳدیں آپݨاں سَݙا! ڄݙاں جو او کن٘ڈ وَلا تے ٹُر پووِن (٥٢)۔
  30,53,اَتے نہ تُوں اَندھیاں کُوں اُنھاں دِی گُمراہی دے بعد ہدایت اُتے گِھن آسَڳدیں، تُوں تاں ٻَس انھاں کُوں سُݨا سَڳدیں، جِہڑے اَساݙیاں آیاتاں اُتے اِیمان گِھن آندِن، ٻَس اِیہے لوک مسلمان (فرمانبردار) ہِن (٥٣)۔
  30,54,اَللہ تاں او ہے جَیں تُہاکوں ٻَہُوں بے قوتی دِی حالت وِچ پَیدا کِیتے، وَل اُوں اِیں بے قوتی دے بعد تُہاکوں طاقت ݙے ݙِتی، وَل اِیں طاقت دے بعد بے طاقتی ݙے ݙِتی، تے ٻڈھیپا وِی! او پَیدا کر ݙیندے جو کُجھ چَہندے، او چَن٘ڳی طرح ڄاݨݨ والا قُدرت والا ہے (٥٤)۔
  30,55,اَتے جِہڑے ݙین٘ہ (قیامت دِی) گھڑی آویسی، تاں گُنہگار قَسماں چاوَݨ لڳ پوسِن جو او تاں ہِک گھڑی کنُوں زیادہ (دُنیا وِچ) رِیہے وِی کائے نھیں! اِیویں او پُٹھے چَل پوندے ہن (٥٥)۔
  30,56,اَتے جِنھاں لوکاں کُوں عِلم تے اِیمان ݙِتا ڳیا ہَا، او اَکھیسِن جو تُساں اَللہ دِی کتاب وِچ لکھئے دے مطابق تاں حشر دے ݙین٘ہ تَئیں رِیہے ہِیوے، ٻَس اِیہُو تاں ہے حشر (وَلا جِی اُٹھݨ) دا ݙین٘ہ، پَر تُساں تاں اِیکُوں ڄاݨدے سَمجھدے وِی کُجھ نہ ہاوے (٥٦)۔
  30,57,ٻَس اِیں ݙین٘ہ ظالم لوکاں کُوں انھاں دا بَہانہ (عُذر) کوئی فائدہ نہ ݙیسے، تے نہ اُنھاں کُوں معافی منگݨ کُوں آکھیا ویسے (٥٧)۔
  30,58,اَتے تحقیق اَساں، لوکاں کِیتے اِیں قرآن وِچ ہر طرح دِی مثال بیان کِیتی ہے، اَتے واقعی جیکر تُوں انھاں دے کولھ کوئی نشانی گِھن آویں، تاں وِی او لوک جِنھاں مَنّݨ کنُوں اِنکار کِیتا ہوئے، ضرور آکھ ݙیسن، جو تُساں تَاں اَصلُوں کُوڑے ہِیوے (٥٨)۔
  30,59,اِیں طرح اِنھاں لوکاں دے دِلّیں اُتے مُہر (ٹَھپّہ) لَا ݙیندے ہَیں، جِہڑے جو کُجھ وِی نھیں ڄاݨدے سمجھدے (٥٩)۔
  30,60,ٻَس (اَے رسول) تُوں صبر کر تے ثابت قَدم رَہ، کیوں جو یقیناً اَللہ دا وعدہ پَکّا تے برحق ہے اَتے او لوک تیݙا دِل نہ گھٹا ݙیون، جِنھاں کُوں یقین وِی نھیں آندا (٦٠)۔
