quran[12{c,v,t}:
43,11,اَتے جیں اَسمان کنُوں ہِک اندازے دے مطابق پاݨِیں نازِل کِیتے ٻَس اَساں اُوندے نال سُکیے سَڑیے علاقے (موئی ہوئی وَستی) کُوں زِندہ (سرسبز) کر کھڑایا، اِیں طرح تُہاکُوں وِی (زمین وِچُوں) کڈھیا ویسے (١١)۔
43,12,اَتے جیں ہَر ہِک قسم دے جوڑے (جُٹ) پَیدا کِیتِن اَتے تُہاݙے کِیتے، ٻیڑیاں بݨائِن اَتے چار پیرڑے جانور ہِن، جِنھاں اُتے تُساں چَڑھدے ہِیوے (١٢)۔
43,13,تاں جو تُساں اُنھاں دِی کن٘ڈ تے اَرام نال ٻَہ سَڳُو، جِہڑے ویلے ٻَہ وَن٘ڄو تاں وَل آپݨیں رَبّ دِی نعمت کُوں یاد کرو، اَتے آکھو جو پاک ہے او ہَستی جیں انھاں کُوں اَساݙے ماتحت کر ݙِتے، اَتے اَساں تاں انھاں کُوں قابو وِچ رَکھݨ دِی طاقت وِی نہ رَکھیندے ہاسے (١٣)۔
43,14,اَتے یقیناً اَساں آپݨیں رَبّ دو وَل وَن٘ڄݨ والے ہِیسے! (١٤)۔
43,15,اَتے انھاں لوکاں اُوندے بَندیاں وِچُوں (کِنھائیں کُوں) اُوندا ہِک حِصّہ (اَولاد) بݨا گِھدّے ، بیشک انسان تاں کُھلّا ݙُلّا نَا شُکرا ہے (١٥)۔
43,16,کیا جِہڑا کُجھ اُوں پَیدا کِیتے اُوندے وِچُوں ٻَس دِھیّاں چُݨ گِھدئِن اَتے تُہاکُوں پُتر نکھیڑ ݙتے ہِینس (١٦)۔
43,17,اَتے جِہڑے ویلے اُنھاں وِچُوں کہیں کُوں بشارت ݙِتی ویندی ہے، اُوں شَئے دِی جیکُوں او ٻَہُوں مہربان (اَللہ) دے نال رَلا چُکیئے، تاں اُوندا مُن٘ہ کالا نِیلا تِھی ویندے، اَتے او غَم وِچ ٻُݙ ویندے (١٧)۔
43,18,کیا (اَللہ دے حِصّے وِچ) اُوہَا ہے، جِہڑی ڳہݨیاں وِچ پَلّی سَنبھلی ہے، اَتے او کہیں جَھپِیڑ وِچ آ تے آپݨیں کوئی ڳالھ وِی ٹھیک طور تے نھیں کر سَڳدی (١٨)۔
43,19,اَتے انھاں فرشتیاں کُوں جِہڑے جو ٻَہُوں مہربان اَللہ دے بَندے ہِن، ذالیں بݨا ݙِتے، کیا اِیہ اُنھاں دِی پَیدائش ویلے ݙیکھدے کھڑے ہَن انھاں دِی اِہجی گواہی وِی لکھ گِھدّی ویسی، اَتے انھاں کنُوں پُچّھ پَرتیت کِیتی ویسی (١٩)۔
43,20,اَتے اِیہ اَہدِن جو جیکر ٻَہُوں مہربان اَللہ چَہندا تاں اساں انھاں (رَبوبݨیاں) دِی پُوجا نہ کریندے، انھاں کوں تاں اُنھاں دا کوئی پَتہ وِی کائے نھیں، او تاں ٻَس بے تُکّیاں ڳالھیں کرݨ ڄوگے ہِن (٢٠)۔
43,21,کیا اَساں اِیں کنُوں پہلے انھاں کُوں کوئی کتاب ݙِتی ہے جِہڑی جو (آپݨیں سَند دے طور تے) انھاں تکڑی پکڑی ہوئی ہے (٢١)۔
43,22,بلکہ اِیہ اَکھیندِن جو تحقیق اَساں آپݨیں پِیو ݙاݙیاں کُوں ہِک دِین (طور طریقے) تے چَلدا ݙِٹھا ہَا، اَتے بیشک اَساں اُنھاں دے قَدماں تے چَلدے پَئے ہَیں (٢٢)۔
