quran[3]{c,v,t}:
  68,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  68,1,نٓ، قَسم ہے قلم دِی، تے اُوندی جِہڑا کُجھ (قَلم والے) لِکھدے پئِن (١)۔
  68,2,جو تُوں اَپݨیں رَبّ دے فضل نال پاڳل اَصلُوں کائے نِھیں (٢)۔
  68,3,اَتے بیشک تیݙے کِیتے نہ مُکّݨ والا اَجر ہے (٣)۔
  68,4,اَتے بیشک تُوں ٻَہُوں وَݙے تے سوہݨیں خلق والا ہیں (٤)۔
  68,5,اَتے بیشک تُوں وِی ݙیکھسیں تے اِیہ (کافر وِی) ݙیکھ گِھنسِن (٥)۔
  68,6,جو تُہاݙے وِچُّوں کوݨ پاڳل ہے (٦)۔
  68,7,بیشک تیݙا رَبّ تاں اُوکُوں وِی خُوب ڄاݨدے جِہڑا اُوندے رَاہ کنُوں تِھڑک ڳئے تے اُنھاں کُوں وِی خُوب ڄاݨدے جِہڑے ہدایت والے رَاہ تے چَلدے وَدّے ہِن (٧)۔
  68,8,ٻَس کُوڑ آکھݨ والیاں دِی ڳالھ اَصلُوں نہ مَنّیں (٨)۔
  68,9,اَتے اِیہ لوک چَہندِن جو ، تُوں (مَذہب وِچ) کُجھ ڈھل ݙے، تاں او وِی کُجھ ڈھلّے تِھی ویسِن (٩)۔
  68,10,اَتے کہیں اِہجے شخص دے آکھیے وِی نہ لڳݨاں، جِہڑا ٻَہُوں قَسماں چاوَݨ دا عادی ہووے، تے ذلیل شخص ہووے (١٠)۔
  68,11,طعنے ݙیوݨ والا ہووے، چُغلیاں لیندا وَدّا ہووے (١١)۔
  68,12,بَھلائی کرݨ کنُوں مَنع کرݨ والا ہووے حَد کنُوں وَدّھ بَدکردار ہووے (١٢)۔
  68,13,بے دَردی، بد خلقا ہووے، اَتے اِیندے عِلاوہ بَد ذات ہووے (١٣)۔
  68,14,اِیہ اِیں واسطے ہے جو او مال والا ہے تے پُتراں والا ہے (١٤)۔
  68,15,ڄَݙاں اُوکُوں اَساݙیاں آیاتاں پَڑھ تے سُݨائیاں ویندِن تاں اَہدے جو اِیہ تاں اَڳلے وقتاں دے لوکاں دِیاں کہاݨیاں ہِن (١٥)۔
  68,16,اَجھو اَساں اُوندے نَکّ کُوں (ذِلّت دا) ٹَھنبھ ݙیوݨ والے ہَیں (١٦)۔
  68,17,اَساں اُنھاں دِی اِیں طرح اَزمائش کِیتی، جیں طرح اَساں باغ والیاں دِی اَزمائش کِیتی ہَئی، ڄَݙاں اُنھاں قَسماں چَا چَا تے آکھیا، جو اَساں سویلے سویلے اِیندے پَھل تروڑ گِھنسُوں (١٧)۔
  68,18,اِتّے یقین ہَا جو) انشاء اَللہ وِی نہ اَکھیُونے (١٨)۔
  68,19,ٻَس تیݙے رَبّ دِی طرفُوں اُوندے اُتُّوں ہِک پِھر وَن٘ڄݨ والی آفت آ تے پِھر ڳئی، پَر او اَڄَݨ سُتّے پَے ہَن (١٩)۔
  68,20,ٻَس او (باغ) اِیویں تِھی ڳیا، جِیویں کہیں فصل کُوں ڄَڑھُوں پَٹ سَٹیا ہووے (٢٠)۔
  68,21,ٻَس سویل تِھیوݨ تے او ہِک ٻئے کُوں سَݙݨ لَڳ پَئے (٢١)۔
  68,22,جو تُساں سویلے سویلے اَپݨیں باغ دِی پار دو پُڄ ڄُلّو، جیکر تُساں پَھل تروڑَݨ چَہندو (٢٢)۔
  68,23,ٻَس او ٹُر پَئے ، اَتے آپس وِچ ہولے ہولے ڳالھِیں کریندے ویندے ہَن (٢٣)۔
  68,24,جو اَڄ دے ݙین٘ہ کوئی مسکین فقیر باغ وِچ تُہاݙے نیڑے وِی نہ آسَڳے (٢٤)۔
  68,25,اَتے ہَر کوئی بخیل بَݨ تے سَویرے سویرے ٹُر پِیا اِیہ سَمجھ تے جو سَب کُجھ اُوندے ہَتّھ وِچ ہے (٢٥)۔
  68,26,پَر ڄَݙاں اُنھاں اُوکُوں وَن٘ڄ ݙِٹّھا، تاں آکھݨ لَڳ پَے ، اَساں تاں کِتھائیں رَاہ بُھل تے آڳئے ہَیں (٢٦)۔
  68,27,کوئے نہ، اَساں تاں اصلُوں بد نصیبے تِھی تے رَہ ڳئے ہَیں، (٢٧)۔
  68,28,اُنھاں دے ہِک اِنصافی آکھیا، کَیا مَیں تُہاکُوں آکھیا نہ ہَم، جو تُساں تسبیح (یعنی اَللہ دا پاک ہووَݨ) کیُوں نھیں مَنیندے (٢٨)۔
  68,29,وَت اُنھاں آکھیا، اَساݙا رَبّ تاں پاک ہے، بیشک اَساں خُود قصور وار تِھی ڳے ہَاسے (٢٩)۔
  68,30,ٻَس بعضے بعضیاں کُوں ہِک ٻئے دے مُن٘ہ مقابلے تِھی تے مَلامت کرݨ لڳ پَے (٣٠)۔
  68,31,اُنھاں آکھیا، ہائے شَامت اَساݙِی، اَساں تاں اَصلُوں نافرمان تِھی ڳئے ہَاسے (٣١)۔
  68,32,تِھی سَڳدے اَساݙا رَبّ اِیندے بدلے اَساکُوں اِیں کنُوں کَہیں چَنڳی حالت وِچ کر ݙیوے، بیشک اَساں تاں آپݨیں رَبّ دو رغبت کریندے ہَیں (٣٢)۔
  68,33,اِیویں تاں آندے عَذاب (اِیں دُنیا تے) اَتے آخرت دا عذاب تاں کِتھائیں وَدّھ تے ہے، اِیویں ہوندا جو او اِیں ڳالھ کُوں ڄاݨ گِھندے (٣٣)۔
  68,34,تحقیق مُتّقی لوکاں کِیتے اُنھاں دے رَبّ دے کولھ نعمتاں بھرے باغ ہِن (٣٤)۔
  68,35,کیا اَساں فرمانبردار (مسلماناں) کُوں گُنہگار لوکاں وَانگوں سَمجھسُوں (٣٥)۔
  68,36,تُہاکُوں تِھی کیا ڳئے ؟ کِہجے واہیات فیصلے چَا کریندے وے (٣٦)۔
  68,37,یا تُہاݙے کولھ کوئی اِہجی کِتاب ہے جِیندے وِچُوں اِیہ ڳالھِیں پَڑھدے ہِیوے (٣٧)۔
  68,38,بغیر کہیں شَک دے اُوندے وِچ تُہاݙے کِیتے اُوہو کُجھ ہے جیکُوں تُساں پَسند کریندے وے (٣٨)۔
  68,39,کیا تیݙے کولھ اَساݙِی طرفُوں اِہجیاں قَسماں چاتیاں ہوئیاں ہِن، جِہڑیاں قیامت دے ݙین٘ہ توڑِیں قائم رہسِن، جو بیشک ہَر او شَئے تُہاکُوں مِل ویندی رَہسی جِیندا حُکم کریندے رَہسو (٣٩)۔
  68,40,اُنھاں کنُوں پُچُّھو جو اُنھاں وِچُّوں کوݨ اِیں (قسم) دِی ذمے داری چیندے (٤٠)۔
  68,41,یا اِیں (سِلسلے وِچ ) اُنھاں دے بݨائے ہوئے شریک وِی ہِن وَل تاں آپݨیاں شریکاں کُوں گِھن آوِن، جیکر اِیہ سَچّے ہِن (٤١)۔
  68,42,جِہڑے ݙین٘ہ ٻَہُوں اَوکھا وَقت آڳیا تے سَجدے کِیتے سَݙیا ڳِیا، تاں اُنھاں کُوں (سَجدے دِی) توفیق وِی حاصل نہ تِھی سَڳسی (٤٢)۔
  68,43,شرم کنُوں) اُنھاں دِیاں اَکّھیں جِھکیاں تِھی ویسِن، ذِلّت اُنھاں کُوں ویڑھ گِھنسی، اَتے تحقیق اُنھاں کُوں تاں (دُنیا وِچ وِی) سَجدے کِیتے سَݙیا ویندا ہَا، ڄَݙاں جو اِیہ کَم کرݨ جوگے ٹِھیک ٹَھاک وِی ہِن (٤٣)۔
  68,44,اَے رسول) ٻَس تُوں میݙا تے اُوندا معاملہ میݙے اُتّے چھوڑ ݙے، جِہڑا جو اِیں کلام کُوں کُوڑا اَکھیندے اَجھو مَیں اُنھاں کُوں ہَولے ہولے جیں طرح (عذاب دو) گِھن آساں ، اُنھاں کُوں پَتہ وِی کائے نھیں (٤٤)۔
  68,45,اَتے مَیں اُنھاں کُوں مُہلت وِی ݙِتی آنداں، پَر میݙی تدبیر تاں کافِی زبردست ہے (٤٥)۔
  68,46,کیا تُوں اُنھاں کنُوں کوئی اَجر مَنگدیں جو او کہیں چَٹّی (تاوان) دے بار تَلے کُٻّے تَھئے ویندِن (٤٦)۔
  68,47,یا اُنھاں کولھ غیب دا عِلم آڳئے، جیکوں او لِکھ گِھندِن (٤٧)۔
  68,48,ٻَس تُوں آپݨیں رَبّ دے حُکم کِیتے (تھوڑی دیر) صَبر چَا کر، اَتے مَچّھی دے (ڈھڈھ وِچ رَہݨ والے یُونس) وانگوں نہ تِھی وَن٘ڄ، اُوں تاں ڄَݙاں سَݙ ماریا ہَا تاں ݙُکھ (غم) نال ٻَہُوں بَھریا ہویا ہا (٤٨)۔
  68,49,جیکر اُوندے رَبّ دِی نعمت اُوں توڑِیں نہ پُڄ ویندی، تاں او کُرّ (سُکّے میدان) اُتے سَٹ ݙِتا ویندا، اُوندی حالت ٻَہُوں خَراب تِھی ویندی (٤٩)
  68,50,۔ ٻَس اُوندے رَبّ نے اُوکُوں (آپݨیں کِیتے) چُݨ گِھدّا، وَت اُوکُوں آپݨیں نیک بَندیاں وِچ رَلا چھوڑیا (٥٠)۔
  68,51,اَتے تحقیق جِنھاں کُفر اِختیار کِیتا ہوئے اِیویں لڳدِن اَکّھیں پوڑ پوڑ تے (زِچّ کر کر تے) آپݨیں مقام کنُوں تِلکا چھوڑیسِن، ڄَݙاں جو او قرآن (ذِکر) کُوں سُݨدِن، تے اَکھیندِن جو بِلا شَک اِیہ تاں پاڳل ہے (٥١)۔
  68,52,حالانکہ اِیہ تاں ٻِیا کُجھ وِی نھیں، سِوائے اِیندے جو اِیہ سارے جہاناں کِیتے ہِک نصیحت ہے (٥٢)۔
