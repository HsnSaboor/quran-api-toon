quran[3]{c,v,t}:
  26,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  26,1,طٰسٓمٓ (١)۔
  26,2,اِیہ روشن تے واضَح کِتاب دِیاں آیاتاں ہِن(٢)۔
  26,3,(اَے رسول) شاید تُوں ٻَہُوں جان کَھپَاوَݨ لَڳیں جو لوک اِیمان کِیُوں نھیں گِھن آندے(٣)۔
  26,4,جیکر اَساں چَہوُوں تاں اُنھاں اُتے اَسمان کنُوں اِہجی نِشانی نازل کر ݙیوُوں، ٻَس جِیندے اَڳُوں اُنھاں دِیاں ڳِچّیاں جِھکّیاں تِھی وَن٘ڄِن(٤)۔
  26,5,اَتے اُنھاں کولھ رحمان (ٻَہُوں مہربان اَللہ) دِی طرفُوں کوئی تازہ نصیحت اِہجی نھیں آندی، جیں کنُوں اُنھاں مُن٘ہ نَہ پھیریا ہووے(٥)۔
  26,6,ٻَس تحقیق اِیہ تاں کُوڑا آکھ چُکئِن، اَجھو اُنھاں کُوں اُوں ڳالھ دِی خَبر لَڳ ویسی، جِیندیاں اِیہ مَذاقاں کریندے ہن(٦)۔
  26,7,کیا اُنھاں لوکاں زمین دو کݙَاہِیں نھیں ݙِٹَّھا جو اَساں اُوندے وِچُوں ہَر قِسم دِیاں چَن٘ڳیاں تے وافر شَئیں پَیدا کِیتیاں ہِن(٧)۔
  26,8,بیشک اِیندے وِچ وی نِشانی موجود ہے، پَر اُنھاں دے ڈھیر بَندے اِیمان گِھن آوَݨ والے کائے نھیں(٨)۔
  26,9,اَتے بیشک تیݙا رَبّ تاں اُوہو ہے جِہڑا ساریاں اُتّے غالب ہے ہمیشہ رحمت کَرݨ والا ہے(٩)۔
  26,10,اَتے ڄَݙاں (اَے رسول) تیݙے رَبّ نے مُوسیٰ کُوں سَݙیا، جو تُوں ظالم لوکاں دِی قَوم کولھ وَن٘ڄ(١٠)۔
  26,11,فِرعون دِی قَوم (کولھ) ! کیا او ݙَرسِن کائے نَہ(١١)۔
  26,12,مُوسیٰ آکھیا، میݙے رَبّ آ، اَلبتہ مَیں ݙَرداں جو او میکُوں کُوڑا چَا اَکھیسِن(١٢)۔
  26,13,اَتے میݙا سِینہ وِی ݙُکھدے، تے میݙی زبان وِی پُورا نھیں ٻول سَڳدی، ٻَس ہارون کولھ ( میݙے نال ڄُلَّݨ دا حُکم) بھیڄ ݙے(١٣)۔
  26,14,ٻِیا اِیہ جو میݙے اُتے اُنھاں نال کِیتا ہُوئیا ہِک جُرم وِی ہے ٻَس مَیں ݙَرداں جو او میکُوں مار گَھتیسِن(١٤)۔
  26,15,(اَللہ) آکھیا، اَصلُوں کوئے نَہ ! ٻَس تُساں ݙُوہائیں میݙیاں نِشانیاں گِھن تے وَن٘ڄُو، یقیناً اَساں تُہاݙے نال ہَیں، سَب کُجھ سُݨݨ والے(١٥)۔
  26,16,ٻَس تُساں ݙُوہائیں فِرعون کولھ وَن٘ڄو، ٻَس اُوکُوں آکھو، جو اِیندے وِچ شَک نَہ کر، جو اَساں سارے جہاناں دے رَبّ دے رسول ہَیں(١٦)۔
  26,17,ٻَس تُوں بَنی اِسرائیل کُوں (آزاد کر تے) اَساݙے نال ٹور ݙے(١٧)۔
  26,18,فِرعون آکھیا، کیا اَساں تیکُوں اَپݨیں وِچ رَکّھ تے ٻال وَانگیں نھیں پالیا، اَتے اِیں طرح اَساݙے وِچ اَپݨِیں عُمر دے کئی سال نھیں گُزارے(١٨)۔
  26,19,ٻَس تَیں کر ݙِیکھایا، او کَمّ جِہڑا تَیں کرݨاں ہَا، تے کِیتا وِی ہَاوی اَتے تُوں تاں نا شُکریاں وِچُّوں بَݨ ڳئیں(١٩)۔
  26,20,مُوسیٰ آکھیا، ہَا مَیں اِہجا کَمّ کِیتا ہَا، پَر اُوں ویلے مَیں بے سَمجھ لوکاں وِچُّوں ہَم(٢٠)۔
  26,21,ٻَس مَیں تُساں لوکاں کنُوں بھڄ ڳیا ہَم، ڄَݙاں تُساں کنُوں ݙَر لڳیا ہَم، ہُݨ میݙے رَبّ نے میکُوں عَقلمندی تے اِختیار ݙِتّے، اَتے میکُوں رسولاں وِچ شامل کر گِھدّا ہِس(٢١)۔
  26,22,اَتے اِیہ (میکُوں پالَݨ دا) اِحسان جِہڑا تُوں چِتویندا پَئیں، (محض اِیں وَجّہ کنُوں ہے) جو تَیں بَنی اِسرائیل کُوں غُلام بَݨایا ہُوئیا ہَئی(٢٢)۔
  26,23,فِرعون آکھیا، بَھلا اِیہ سارے جَہاناں دَا پَالݨ والا ہے کُوݨ؟(٢٣)۔
  26,24,مُوسیٰ آکھیا، او تاں آسماناں تے زمین دا، اَتے جو کُجھ اُنھاں وِچالے ہے سَب دے پَالَݨ والا ہے، پَر تُساں لوک یقین کرݨ والے بݨدے وِی نِھیوے! (٢٤)۔
  26,25,فِرعون نے اُنھاں کُوں جِہڑے اُوندے آسُوں پاسُوں کھڑے ہَن، آکھیا، کیا تُساں نھیں پَے سُݨدے؟(٢٥)۔
  26,26,مُوسیٰ (اِیہ وِی) آکھیا، جو تیݙا رَبّ تے تیݙے پہلے پِیؤ ݙاݙیاں دَا رَبّ وِی (اُوہو ہے)(٢٦)۔
  26,27,فِرعون (لوکاں کُوں) آکھیا، سَچّی ڳالھ اِیہ ہے جو تُہاݙا رَسول جِیکُوں تُہاݙے کول بھیڄیا ڳئے، او تاں پَاڳل نظردے(٢٧)۔
  26,28,مُوسیٰ آکھیا، ٻِیا اِیہ جو او مَشرق تے مغرب دَا وِی رَبّ ہے، اَتے جِہڑا کُجھ اِنھاں دے وِچالے ہے اُوندا وِی! جیکر تُساں سَمجھو تاں! (٢٨)۔
  26,29,(فِرعون) آکھیا، جیکر تَیں مَیں کنُوں کَہیں ٻَے کُوں آپݨاں معبود بݨایا، تاں مَیں تیکُوں قَیدیاں رَلّے ڈھک ݙیساں(٢٩)۔
  26,30,مُوسیٰ آکھیا، جیکر مَیں کوئی روشن تے مَنَّݨ والی شَئے گِھن آواں (تاں وَل ؟) (٣٠)۔
  26,31,اُوں آکھیا، بَھلا گِھن آ ݙِیکھا! جیکر تُوں واقعی سَچ ٻولݨ والیاں وِچُوں ہیں تاں(٣١)۔
  26,32,ٻَس مُوسیٰ آپݨیں سوٹی سَٹ گَھتّی ، تاں او ہُوں ویلے ہِک ظاہر ظہور اَژدھا (وَݙا سارا نَان٘گ) بَݨ ڳیا(٣٢)۔
  26,33,اَتے اُوں (کَچّھ وِچُوں) اَپݨاں ہَتّھ ٻَاہِر کَڈھیا تَاں ہُوں ویلے ݙیکھݨ والیاں کِیتے چَمکَݨ لڳ پِیا ہَا(٣٣)۔
  26,34,فِرعون کولھوں کَھڑے ہُوئے اَپݨیں دَرباریاں کُوں آکھیا، سَچّ پِیا آہداں، جو اِیہ تَاں کوئی سِیاݨاں جادوگر ہے(٣٤)۔
  26,35,اِیہ چَہندے جو آپݨیں جادُو نال تُہاکُوں تُہاݙے مُلک وِچُوں کَڈھ ݙیوے، ہُݨ تُساں کیا صَلاح ݙیندے وے(٣٥)۔
  26,36,اُنھاں آکھیا، جو تُوں اِیکُوں تے اِیندے بِھرا کُوں کُجھ مُہلت چَا ݙے، اَتے شہراں وِچُوں کَٹّھے کر آوَݨ والیاں کُوں بھیڄ ݙے(٣٦)۔
  26,37,تاں جو او تیݙے کولھ ساریاں سِیاݨیاں جادُوگراں کُوں کَٹھا کر آوِن(٣٧)۔
  26,38,ٻَس او جادُوگر ہِک مقرر ݙِین٘ہ دِی میعاد دے مطابق کَٹّھے کر گِھدّے ڳئے(٣٨)۔
  26,39,اَتے ساریْاں لوکاں کُوں آکھ ݙِتّا ڳیا، کیا تُساں وِی کَٹّھے تِھی ویسُو نَا(٣٩)۔
  26,40,تاں جو اَساں اِنھاں جادُوگراں دِی پَیروی کروں، جیکر او غالب آوَن٘ڄِن تاں(٤٠)۔
  26,41,ٻَس ڄَݙاں جادوگر حاضِر تِھی ڳئے، تاں اُنھاں فِرعون کوں آکھیا، جو اَساݙے کِیتے کوئی اِنعام وِی ہوسی، جیکر اَساں غالب آوَن٘ڄُوں تَاں(٤١)۔
  26,42,فِرعون آکھیا، بالکل ہوسی، اَتے تُساں اُوں ویلے میݙے سَوڑے تعلّق والے بَݨ ویسُو(٤٢)۔
  26,43,مُوسیٰ نے (جادوگراں) کُوں آکھیا، سَٹُّو، جِہڑی شَئے تُساں سَٹݨِیں ہے(٤٣)۔
  26,44,ٻَس اُنھاں آپݨیاں رَسّیاں تے آپݨیاں سوٹِیاں سَٹِّیاں ، اَتے اَکھیُونے جو فِرعون دے زور تے اَساں ضرور غالب آویسُوں(٤٤)۔
  26,45,ٻَس مُوسیٰ اَپݨِیں سوٹی سَٹّی، تاں او فوراً جِہڑیاں اُنھاں کُوڑیاں شَئیں بَݨا سَٹِّیاں ہِن، اُنھاں کُوں نِڳلَݨ لَڳ پَئی(٤٥)۔
  26,46,وَل تاں سارے جادُوگر سِجدے وِچ ڈھے پَے (٤٦)۔
  26,47,اَتے آکھݨ لڳئے اَساں سارے جہاناں دے رَبّ اُتے اِیمان گِھن آئے ہَیں(٤٧)۔
  26,48,جِہڑا جو مُوسیٰ تے ہارون دَا رَبّ ہے(٤٨)۔
  26,49,(فِرعون) آکھیا، کیا تُساں اِیندی ڳالھ تے اِیمان گِھن آئیوے؟، ٻِیا اِیہ جو اِیں کنُوں وِی پہلے جو مَیں تُہاکُوں اِجازت ݙیواں ہَا، یقیناً اِیہ تُہاݙا کوئی وَݙیرا ہے، جیں تُہاکُوں وِی جَادُو سِکھایا ہُوئے، ٻَس اَجھو تُہاکُوں پَتہ لَڳ ویندے، مَیں تُہاݙے ہِک پاسے دَا ہَتّھ تے ٻَے پاسے دا پَیر کَپوا چھوڑینداں، اَتے تُساں ساریْاں کُوں سُولی تے چَڑھا ݙیسَاں(٤٩)۔
  26,50,جادوگراں) آکھیا، کوئی پَروا نھیں، اَساں تاں بیشک اَپݨیں رَبّ دو وَل وَن٘ڄݨیں(٥٠)۔
  26,51,بیشک اَساں اُمید رَکھیندے ہَیں جو اَساݙا رَبّ اَساکُوں اَساݙے گُناہ بَخش ݙیسے، کِیُوں جو اَساں ساریاں تُوں پہلے اِیمان گِھن آوَݨ والے ہَیں(٥١)۔
  26,52,اَتے اَساں مُوسیٰ دو وَحی بھیڄی، جو میݙے بَندیاں کُوں رَاتُو رَات کَڈھ وَن٘ڄ، (ٻِیا اِیہ جو) تیݙا پِیچھا وِی ضرور کِیتا ویسے(٥٢)۔
  26,53,ٻَس فِرعون نے شہراں وِچُوں لوکاں کُوں کَٹَّھا کرݨ والے آپݨیں بَندے بھیڄ ݙِتّے(٥٣)۔
  26,54,یقیناً اِیہ (لوک) ہِک چھوٹی جہی ٹولی ہِن(٥٤)۔
  26,55,اَتے بیشک او اَساݙے اُتے کاوڑیے وَدِّن(٥٥)۔
  26,56,اَتے اَساں یقیناً سارے محتاط (پھرکدے وَدّے) ہَیں(٥٦)۔
  26,57,وَل اَساں اُنھاں کُوں باغاں تے چَشمیاں وِچُوں کَڈھ چھوڑیا(٥٧)۔
  26,58,اَتے خَزانیاں تے عِزّت والیاں جائیں کنُوں وِی(٥٨)۔
  26,59,اِیہ تاں اِیں تِھیا، وَت اَساں بَنی اِسرائیل کُوں وَارث بݨا چھوڑیا(٥٩)۔
  26,60,ٻَس او سِجھ اُبھرَݨ نال اُنھاں دے پِچُّھوں لَڳ پَے(٦٠)۔
  26,61,ٻَس ڄَݙاں ݙُوہاہِیں ٹولیاں ہِک ٻئی دے سامݨیں تِھیاں تاں مُوسیٰ دے سَنگتی آکھݨ لڳے سَچّ مُچّ اَساں تَاں پَکڑے ڳیُوسے(٦١)۔
  26,62,مُوسیٰ آکھیا، ہَرگز کوئے نَہ! بیشک رَبّ میݙے نال ہے، او اَجھو (بَچّ وَن٘ڄݨ دَا) رَاہ ݙِیکھیسی(٦٢)۔
  26,63,ٻَس اَساں مُوسیٰ دو وَحی بھیڄی، جو تُوں اَپݨِیں سوٹی سَمندر تے مار، ٻَس سمندر ݙُوں حِصّے تِھی ڳیا، اُوندا ہَر ہِک حِصّہ ہِک وَݙے پَہاڑ وانگُوں اُچّا تِھی ڳیا(٦٣)۔
  26,64,وَل اَساں ݙُوڄِھی ٹولی کُوں وِی (اُتھاں) گِھن آیُوسے(٦٤)۔
  26,65,اَتے اَساں مُوسیٰ تے اُوندے نال والیاں کُوں بَچا گِھدّا(٦٥)۔
  26,66,پَر ݙُوڄِھیاں کُوں غَرق کر چھوڑیا(٦٦)۔
  26,67,بیشک اِیں (واقعے) وِچ ہِک نِشانی ہے پَر اُنھاں وِچُوں ڈھیر اِیمان گِھن آوَݨ والے کائے نھیں(٦٧)۔
  26,68,اَتے بیشک تیݙا رَبّ اِی غالب تے ہمیشہ رحمت کرݨ والا ہے(٦٨)۔
  26,69,اَتے (اَے رسول) اُنھاں کُوں اِبراہیم دَا قِصّہ سُݨا چَا(٦٩)۔
  26,70,ڄَݙاں جو اُوں اَپݨیں پِیؤ کنُوں تے اَپݨِیں قَوم کنُوں پُچّھیا، جو تُساں کِیندی بندگی پَے کریندو(٧٠)۔
  26,71,اُنھاں آکھیا، جو اَساں تَاں بُتَّاں دِی بَندگی کریندے ہَیں، اَتے اُنھاں دِی بَندگی وِچ لڳیئے رَہندے ہَیں(٧١)۔
  26,72,(اِبراہیم) آکھیا، کیا اِیہ تُہاکُوں سُݨ سَڳدِن، ڄَݙاں جو اُنھاں کُوں سَݙیندے وے(٧٢)۔
  26,73,یا اِیہ تُہاکُوں نفع ݙے سَڳدِن، یا کوئی نُقصان پُچا سَڳدِن(٧٣)۔
  26,74,اُنھاں آکھیا بلکہ اَساں تاں آپݨیاں پِیؤ ݙاݙیاں کُوں اِیویں اِی کریندا ݙِٹَّھا ہے(٧٤)۔
  26,75,(اِبراہیم) آکھیا، کیا تُساں (غور نال) ݙِٹَّھا وِی ہے جو تُساں کِیندی بَندگی کریندے رَہندے وے(٧٥)۔
  26,76,تُساں وِی اَتے تُہاݙے اَڳلے پِیؤ ݙاݙیاں وِی (کَݙاہِیں غور کِیتا)(٧٦)۔
  26,77,ٻَس تحقیق اِیہ سارے میݙے دُشمن ہِن، سِوائے ساریاں جہاناں دے رَبّ دے(٧٧)۔
  26,78,جیں میکُوں پَیدا کِیتے، اَتے جِہڑا میکُوں رَاہ لیندے(٧٨)۔
  26,79,اَتے اُوہو میکُوں کَھویندے تے پِلیندے(٧٩)۔
  26,80,اَتے ڄَݙاں بیمار تِھی وینداں تاں میکُوں شِفا ݙیندے(٨٠)۔
  26,81,اَتے او میکُوں مَار سَٹیسے، تے وَل جِیوا وِی ݙیسے(٨١)۔
  26,82,اَتے جیں ذَات نال مَیں اُمید وِی رَکھینداں او قیامت دے ݙِین٘ہ میݙیاں خَطاواں بَخش ݙیسے(٨٢)۔
  26,83,میݙے رَبّ آ، میکُوں فیصلہ کرݨ دِی سَمجھ ݙے، اَتے میکُوں نیک لوکاں نال رَلا ݙے(٨٣)۔
  26,84,اَتے میݙے بَعد آوَݨ والیاں کُوں میݙے متعلّق ݙَسݨ والی سَچّی زبان ݙے(٨٤)۔
  26,85,اَتے میکُوں نعمتاں والے باغ دے وارثاں وِچ شامل چَا کر(٨٥)۔
  26,86,اَتے میݙے پِیؤ کُوں بَخش ݙے کِیُوں جو بیشک او گُمراہ لوکاں وِچُّوں ہے(٨٦)۔
  26,87,اَتے میکُوں اُوں ݙِین٘ہ ذلیل خُوار نَہ کریں ڄَݙاں مُردیاں کُوں جِیوا کَھڑایا ویسے(٨٧)۔
  26,88,جِہڑے ݙِین٘ہ نَہ مَال کہیں کَمّ آسے اَتے نَہ پُتر (کَم آسِن) (٨٨)۔
  26,89,سِوائے اُوندے جِہڑا جو اَللہ کولھ نیک پَاک دِلّ گِھن تے آسے(٨٩)۔
  26,90,اَتے بَہشت پَرہیزگاراں دے اَصلُوں کولھُوں کر ݙِتّی ویسی(٩٠)۔
  26,91,اَتے دَوزخ گُمراہ لوکاں دے سامݨیں کر ݙِتّی ویسی(٩١)۔
  26,92,اَتے اُنھاں کنُوں پُچّھیا ویسے، جو تُساں جِنھاں دِی بَندگی کریندے ہاوے او ہُݨ کِتّھ ہِن(٩٢)۔
  26,93,اَللہ کنُوں عِلاوہ! کیا او تُہاݙی مَدد کر سَڳدِن یا خُود اَپݨیں اِی کوئی مَدد کر سَڳدِن(٩٣)۔
  26,94,ٻَس اِیندے وِچ مُوندھے ہِک ٻے پِچُّھوں سَٹ ݙِتّے ویسِن، او (معبود) وِی اَتے گُمراہ لوک وِی(٩٤)۔
  26,95,اَتے اِبلیس دے لَشکر وِی سارے دے سارے (٩٥)۔
  26,96,اَتے ڄَݙاں اِیندے وِچ اُنھاں جِھیڑا گَھتّیا ہُوئیا ہوسی، اَکھیسِن(٩٦)۔
  26,97,اَللہ دِی قَسم، اَساں تاں کُھلّی گُمراہی وِچ پَے ڳے ہَاسے(٩٧)۔
  26,98,ڄَݙاں جو اَساں تُہاکُوں سارے جہاناں دے پَالݨ ہَار دے برابر مَنّ گِھدّا ہَاسے(٩٨)۔
  26,99,اَتے اَساکُوں تاں ٻَس اُنھاں مُجرماں گُمراہ کر چھوڑیا ہَا(٩٩)۔
  26,100,ٻَس اَساݙے کِیتے نَہ کوئی سِفارشی ہے(١٠٠)۔
  26,101,اَتے نَہ کُوئی یار ہے غَم خُوار(١٠١)۔
  26,102,ٻَس جیکر اَساکُوں ݙُوجھا موقع ݙِتّا وَن٘ڄے تاں اَساں ضرور اِیمان گِھن آوَݨ والے بَݨ وَن٘ڄُوں(١٠٢)۔
  26,103,بیشک اِیندے وِچ ہِک نِشانی ہے، پَر اُنھاں وِچُوں ڈھیر کوئی اِیمان گِھن آوَݨ والے کائے نھیں(١٠٣)۔
  26,104,اَتے بیشک تیݙا رَبّ تاں ٻَہُوں زَبردست تے ہمیشہ رحمت کرݨ والا ہے(١٠٤)۔
  26,105,نُوح دِی قَوم نے رسُولاں کُوں وِی کُوڑا آکھیا(١٠٥)۔
  26,106,(یاد کرو) ڄَݙاں اُنھاں کُوں اُنھاں دے بِھرا نُوح آکھیا، جو کیا تُہاکُوں کوئی ݙَر نھیں لَڳدا(١٠٦)۔
  26,107,سَچّی ڳالھ آہداں، مَیں تُہاݙے کِیتے ہَر طرح قابِل اِعتبار (اَمانت دار) رسول ہَاں(١٠٧)۔
  26,108,ٻَس تُساں اَللہ کنُوں ݙَرو، اَتے میݙا آکھیا، مَنیندے رَہوُو(١٠٨)۔
  26,109,اَتے مَیں تُساں کنُوں اِیں کَمّ دَا کوئی اَجر نھیں مَنگدا، کِیُوں جو میݙا اَجر تاں سارے جہاناں دے پَالݨ ہار دے کولھ ہے(١٠٩)۔
  26,110,ٻَس اَللہ کنُوں ݙَرو، اَتے میݙا آکھیا مَنّیا کِیتا کرو(١١٠)۔
  26,111,اُنھاں آکھیا، کیا اَساں تیݙے اُتّے اِیمان گِھن آؤں، تیݙی فَرمانبرداری تاں رَذیل لوک کریندِن(١١١)۔
  26,112,(نُوح) آکھیا، مَیں نھیں ڄاݨدا جو او کیا کُجھ کریندے رَہندِن(١١٢)۔
  26,113,تحقیق اُنھاں دَا حِساب کِتاب تاں میݙے رَبّ دے سِوا، ٻَئے کہیں کولھ کائے نھیں، چَن٘ڳا تَاں اِیہُو ہَا جو تُساں اِیں ڳالھ کُوں سَمجھدے(١١٣)۔
  26,114,میݙا اِیہ کَمّ کائے نھیں، جو مَیں اِیمان گِھن آوَݨ والیاں کُوں بھڄا کَڈھاں(١١٤)۔
  26,115,بیشک مَیں تاں محض صاف صاف چِتاوَݨ ڈراوݨ والا ہَاں(١١٥)۔
  26,116,لوکاں) آکھیا، اَے نُوح ! جیکر تُوں اَپݨیں اِیں وَطیرے کنُوں باز نَہ آیُوں، تاں ضرور تیکُوں سَن٘گسَار کر ݙِتا ویسے(١١٦)۔
  26,117,نُوح) آکھیا، میݙے رَبّ آ، بیشک میݙی قَوم (دے لوکاں) میکُوں کُوڑا آکھ ݙِتّے(١١٧)۔
  26,118,ٻَس میݙے تے اُنھاں دے وِچالے اَصلُوں ہِک ہِکڑی چَا کر، اَتے میکُوں تے اِیمان گِھن آوَݨ والیاں وِچُوں جِہڑے میݙے نال ہِن، اُنھاں کُوں ٻَچا گِھن(١١٨)۔
  26,119,ٻَس اَساں اُوکُوں نِجات ݙے ݙِتّی، اَتے اُوندے نال بَھریئے ہوئے ٻیڑے وِچ چَڑھے ہُوئیاں کُوں وِی(١١٩)۔
  26,120,وَت اَساں اُنھاں کُوں غَرق کر چھوڑیا، جِہڑے پِچُّھوں باقی رَہ ڳئے ہَن(١٢٠)۔
  26,121,بیشک اِیندے وِچ ہِک نِشانی ہے، پَر اُنھاں وِچُوں ڈھیر کوئی اِیمان گِھن آوَݨ والے کائے نَہ ہَن(١٢١)۔
  26,122,اَتے بیشک تیݙا رَبّ تاں ٻَہُوں طاقت والا اَتے ہمیشہ رحمت کرݨ والا ہے(١٢٢)۔
  26,123,عاد (دِی قَوم) وِی رسُولاں کُوں کُوڑا آکھیا(١٢٣)۔
  26,124,ہِک وَقت اُنھاں دے (برادری دے) بِھرا ہُود نے اُنھاں کُوں آکھیا، کیا تُساں (اَللہ کنُوں) ݙَردے نِھیوے(١٢٤)۔
  26,125,بیشک مَیں تُہاݙے کِیتے ہِک اَمانتدار (قابِل اِعتبار) رسول ہَاں(١٢٥)۔
  26,126,ٻَس اَللہ کنُوں ݙرو اَتے میݙی پَیروی کرو(١٢٦)۔
  26,127,اَتے مَیں تُساں کنُوں اِیندا کوئی اَجر وِی نھیں مَنگدا! کِیُوں جو میݙا اَجر تاں سارے جہاں دے پالݨ ہار کولھ ہے(١٢٧)۔
  26,128,کیا ہے جو تُساں ہَر اُچّی جاء تے یادگیری والیاں عِمارتاں بݨیندے ویندُو(١٢٨)۔
  26,129,اَتے وَݙے وَݙے محل اُساری ویندو، جِیویں جو تُہاکُوں ہمیش رَہوݨاں ہُووے(١٢٩)۔
  26,130,اَتے ڄَݙاں کݙائیں کَہیں کُوں تُساں غارت کرݨ چَہندو تاں ٻَہُوں جَبر کرݨ والے بَݨ تے غارت کریندو(١٣٠)۔
  26,131,ٻَس تُساں اَللہ کنُوں ݙَرو، اَتے میݙا آکھیا مَنُّو(١٣١)۔
  26,132,اَتے ݙَرو اُوں کنُوں جیں تُہاݙی مَدد اِہجیاں شَئیں نال کِیتی ہے جِنھاں کُوں تُساں خُوب ڄاݨدے ہِیوے(١٣٢)۔
  26,133,اُوں تُہاݙی مَدد کِیتی ہے، جانوراں نَال اَتے پُتراں نال(١٣٣)۔
  26,134,اَتے باغاں نال، اَتے چَشمیاں نال وِی(١٣٤)۔
  26,135,سَچّی ڳالھ ہے جو مَیں ݙَرداں جو تُہاݙے اُتّے (قیامت والے سَخت ݙین٘ہ دا) عَذاب نَہ آوَن٘ڄے(١٣٥)۔
  26,136,اُنھاں آکھیا، اَساݙے کِیتے تاں برابر ہے، بھاویں تُوں نصیحت کریں یا اَصلُوں نصیحت کرݨ والیاں وِچُوں بَݨیں وِی نَہ(١٣٦)۔
  26,137,کِیُوں جو اِیہ ڳالھِیں اَڳلے لوک وِی کریندے رِیہِن(١٣٧)۔
  26,138,اَتے اَساں او نِسّے جِنھاں کُوں کوئی وِی عَذاب ݙِتا ویسے(١٣٨)۔
  26,139,ٻَس اُنھاں اُوکُوں کُوڑا آکھیا، تاں اَساں وِی اُنھاں کُوں غارت کر چھوڑیا، بیشک اِیندے وِچ وِی ہِک نِشانی ہے، پَر اُنھاں دے ڈھیر کوئی اِیمان نھیں گِھن آندے(١٣٩)۔
  26,140,اَتے بیشک تیݙا رَبّ تاں ٻَہُوں زبردست ہے تے ہمیشہ رحمت کرݨ والا ہے(١٤٠)۔
  26,141,ثمود (دِی قَوم) وِی رَسُولاں کُوں کُوڑا آکھیا(١٤١)۔
  26,142,ہِک وَقت اُنھاں دے (بِرادری دے) بِھرا صالح اُنھاں کُوں آکھیا، کیا تُساں (اَللہ کنُوں) ݙَردے نِھیوے(١٤٢)۔
  26,143,بیشک مَیں تُہاݙے کِیتے ہِک اَمانت دار (قابِل اِعتبار) رسول ہَاں(١٤٣)۔
  26,144,ٻَس اَللہ کنُوں ݙَرو، اَتے میݙے آکھیئے تے چَلّو(١٤٤)۔
  26,145,اَتے مَیں تُساں کنُوں کوئی اَجر وِی نھیں مَنگدا، میݙا اَجر سارے جہاناں دے پالَݨ ہار کولھ ہے(١٤٥)۔
  26,146,کیا تُساں اُنھاں شَئیں وِچ جِہڑیاں جو تُہاکُوں مِلیاں ہوئیاں ہَن، اِیویں عَیش وِچ چھوڑ ݙِتّے ویسو(١٤٦)۔
  26,147,اَتے اُنھاں باغاں وِچ، اَتے اُنھاں چَشمیاں وِچ(١٤٧)۔
  26,148,اَتے رَڑھِیں وِچ، اَتے کَھڄّیاں وِچ، جِنھاں دے غوشے بار کنُوں لٹکیئے پِئن(١٤٨)۔
  26,149,اَتے تُساں پَہاڑا کُوں گَھڑ گَھڑ تے فخر دے قابِل گَھر بݨا گِھندُو(١٤٩)۔
  26,150,ٻَس اَللہ کنُوں ݙرو، اَتے میݙا آکھیا مَنّیا کرو(١٥٠)۔
  26,151,اَتے انھاں حَد کنُوں وَدّھ وَن٘ڄݨ والیاں دا آکھیا نَہ مَنّو(١٥١)۔
  26,152,جِہڑے جو زمین اُتّے فَساد مَچائی رکھدِن، اَتے اِصلاح دِی کوئی ڳالھ نھیں کریندے(١٥٢)۔
  26,153,او آکھݨ لڳے جو اَصل وِچ تیݙے اُتّے تاں کُوئی جادُو کِیتا ہوئے(١٥٣)۔
  26,154,تُوں تاں کُجھ نِھیوی، محض ہِک بَشر ہیں، اَساں وانگُوں، بَھلا کوئی نِشانی گِھن آ، جیکر تُوں سَچّ بولݨ والیاں وِچُوں ہِیں تاں(١٥٤)۔
  26,155,(صالح) آکھیا، اِیہ ہِک ݙاچی ہے، اِیندے کِیتے پاݨِیں پِیوَݨ دَا ہِک ݙِین٘ہ مُقرر ہے، اَتے تُہاݙے کِیتے پاݨِیں دَا ݙُوجھا ݙِین٘ہ مُقرر ہے(١٥٥)۔
  26,156,اَتے اِیکُوں کوئی تکلیف پُچاوَݨ دِی نِیّت نال ہَتّھ وِی نَہ لَواہے نَہ تاں تُہاکُوں وَݙے ݙِین٘ہ دا عَذاب پَکڑ گِھنسے(١٥٦)۔
  26,157,اُنھاں تاں ٻَس اِیں ݙاچِی دِیاں خُچَّاں ڄَنگھاں کَپّ چھوڑیاں، اَتے شَرمسار وِی تَھئے(١٥٧)۔
  26,158,پَر اُنھاں کُوں عَذاب آن پَکڑیا، بیشک اِیندے وِچ نِشانی ہے، اَتے اُنھاں وِچُوں ڈھیر تاں اِیمان گِھن وِی نھیں آندے(١٥٨)۔
  26,159,اَتے بیشک تیݙا رَبّ اُوہو ہے جِہڑا ٻَہُوں زبردست اَتے ہمیشہ رحمت کرݨ والا ہے(١٥٩)۔
  26,160,لُوط (دِی قَوم) وِی رسولاں کُوں کُوڑا آکھیا(١٦٠)۔
  26,161,ہِک وَقت اُنھاں دے (برادری دے) بِھرا لُوط اُنھاں کُوں آکھیا، کیا تُساں پَرہیزگار نھیں بَݨ ویندے(١٦١)۔
  26,162,یقیناً مَیں تُہاݙے کِیتے اَمانتدار (قابِل اِعتبار) رسول ہَاں(١٦٢)۔
  26,163,ٻَس اَللہ کنُوں ݙَرو، اَتے میݙی فَرمانبرداری کِیتی رَکّھو(١٦٣)۔
  26,164,اَتے مَیں تُساں کنُوں اِیں کَمّ دا کوئی اَجر نھیں مَنگدا، میݙا اَجر تاں سارے جہاناں دے پالَݨ ہار کولھ ہے(١٦٤)۔
  26,165,کِیا تُساں ساری مخلوقات وِچُوں ٻَس چھوہراں جُواناں کولھ ویندے وے(١٦٥)۔
  26,166,اَتے اَپݨیاں ذالیں کُوں جِنھاں کوں تُہاݙے رَبّ تُہاݙے کِیتے پَیدا کِیتے چھوڑ ݙیندے وے، تُساں تاں حَد کنُوں ٹَپ وَن٘ڄݨ والی قَوم ہِیوے(١٦٦)۔
  26,167,اُنھاں آکھیا، اَے لُوط! جیکر تَیں آپݨیں وَطیرے کُوں نَہ چھوڑیا، تاں تُوں وِی (وَستّی وِچُوں) کَڈھ ݙِتّے ڳِیاں وِچُوں تِھی ویسیں(١٦٧)۔
  26,168,اُوں آکھیا، بیشک مَیں تُہاݙے کرتُوتاں کُوں سَخت نا پَسند کرݨ والیاں وِچُوں ہَاں(١٦٨)۔
  26,169,میݙے رَبّ آ، میکُوں اَتے میݙے گَھر والیاں کُوں انھاں کرتُوتاں کنُوں بَچائی رَکھ، جِہڑے اِیہ کریندے وَدّے ہِن(١٦٩)۔
  26,170,ٻَس اَساں اُوکُوں تے اُوندے گَھر والیاں کُوں ساریاں کوں بَچا گِھدّا(١٧٠)۔
  26,171,سِوا ہِک ٻُڈھِّڑ دے، جِہڑی جو پِچُّھوں رَہ وَن٘ڄݨ والیاں نال رَل ڳئی ہَئی(١٧١)۔
  26,172,وَل اَساں باقی لوکاں کُوں پُوری طرح غارت کر چھوڑیا(١٧٢)۔
  26,173,اَتے اَساں اُنھاں اُتے پَتھراں دَا مِین٘ہ وَسایا، اَتے او ݙَرائے چِتائے ڳیاں کِیتے ٻَہُوں سَخت مِین٘ہ ہَا(١٧٣)۔
  26,174,یقیناً اِیندے وِچ ہِک نِشانی ہے، پَر اُنھاں وِچُوں ڈھیر کوئی اِیمان نھیں گِھن آندے(١٧٤)۔
  26,175,اَتے بیشک تیݙا رَبّ اُوہو ہے جِہڑا زَبردست تے ہمیشہ رحمت کرݨ والا ہے(١٧٥)۔
  26,176,ائیکہ دے لوکاں وِی رسولاں کُوں کُوڑا آکھیا(١٧٦)۔
  26,177,ڄَݙاں اُنھاں کُوں شعیب آکھیا، کیا تُساں تقویٰ اِختیار نھیں کریندے(١٧٧)۔
  26,178,بیشک مَیں تُہاݙے کِیتے اَمانتدار (قابِل اِعتبار) رسُول ہَاں(١٧٨)۔
  26,179,ٻَس اَللہ کنُوں ݙَرو تے میݙی فرمانبرداری کرو(١٧٩)۔
  26,180,اَتے مَیں تُساں کنُوں اِیں کَم دا کوئی اَجر وِی نھیں مَنگدا، کِیُوں جو اَجر تاں سارے جہاناں دے پالݨ ہار کولھ ہے(١٨٠)۔
  26,181,پُورا پُورا کَچّھ کُچّھ تے ݙِتَّا کرو، اَتے گھاٹا ݙیوݨ والیاں نَال نَہ رَلّ وَن٘ڄو(١٨١)۔
  26,182,اَتے تُولو تَاں تَرکڑی (دِی ݙَن٘ڈی) سِدّھی رَکّھ تے تُولو(١٨٢)۔
  26,183,اَتے (لوکاں کُوں) اُنھاں دِیاں شَئیں گَھٹ کر تے نَہ ݙیوُو، اَتے زمین اُتے فَساد نَہ مَچائی رَکھو(١٨٣)۔
  26,184,اَتے اُوں کنُوں ݙَردے رَہوُو، جیں تُہاکُوں اَتے پہلے والی خَلقت کُوں پَیدا کِیتے(١٨٤)۔
  26,185,اُنھاں آکھیا، جو تُوں تاں محض جادُو کِیتے ہوئے لوکاں وِچُوں ہیں(١٨٥)۔
  26,186,اَتے تُوں تاں کُجھ نِھیوی، ٻَس اَساں جیہاں بَنی بَشر ہیں، اَتے اَساں تاں تیکُوں اَصلُوں کُوڑیْاں بَندیْاں وِچُوں سَمجھدے ہَیں(١٨٦)۔
  26,187,بَھلا اَساݙے اُتے اَسمان دَا کوئی ٹوٹا پَٹ آ سَٹ، جیکر تُوں سَچّے لوکاں وِچُوں ہِیں تَاں(١٨٧)۔
  26,188,(شُعیب) آکھیا، میݙا رَبّ تاں سَب کُجھ ڄاݨدا کَھڑے جِہڑا کُجھ تُساں کریندے وَدّے وے(١٨٨)۔
  26,189,ٻَس اُنھاں اُوکُوں کُوڑا آکھیا، تاں اُنھاں کوں (ݙُکَّھاں والے) چَھتر تَݨیے ہوئے ݙِین٘ہ دے عَذاب آ پَکڑیا، بیشک او ہِک سَخت ݙِین٘ہ والا عَذاب ہَا(١٨٩)۔
  26,190,بیشک اِیندے وِچ ہِک نِشانی ہے، اَتے اُنھاں وِچُوں ڈھیر کوئی اِیمان گِھن آوَݨ والے نَہ ہَن(١٩٠)۔
  26,191,اَتے بیشک تیݙا رَبّ اُوہو ہے جِہڑا ٻَہُوں زبردست اَتے ہمیشہ رحمت کرݨ والا ہے(١٩١)۔
  26,192,اَتے بیشک اِیہ (قرآن) سارے جہاناں دے رَبّ دا بھیجیا ہوئیا ہے(١٩٢)۔
  26,193,اِیکُوں رُوح الاَمین (جِبرائیل) گِھن تے لَتّھے(١٩٣)۔
  26,194,تیݙے دِل اُتّے ! تاں جو تُوں ݙَراوَݨ سَمجھاوَݨ والیاں وِچُوں تِھی وَن٘ڄیں(١٩٤)۔
  26,195,اِیہ صاف صاف عَربی زبان وِچ (ہے)(١٩٥)۔
  26,196,اَتے بیشک اِیہ اَللہ دِیاں پہلیاں کِتاباں وِچ وِی ہے(١٩٦)۔
  26,197,کیا اُنھاں کِیتے اِیہ نِشانی کافی کائے نھیں، جو اِیکُوں تاں بَنی اِسرائیل دے عالم وِی سَچّا ڄاݨدے سَمجھدے ہِن(١٩٧)۔
  26,198,اَتے جیکر اَساں اِیکُوں عجمیاں وِچُوں کہیں اُتے نازِل کریندے(١٩٨)۔
  26,199,اَتے او اُنھاں کُوں پَڑھ سُݨیندا، تاں وِی اِیہ لوک اِیندے اُتّے اِیمان ہَرگز نَہ گِھن آندے(١٩٩)۔
  26,200,اَساں تاں اِیں طرح مُجرم لوکاں دے دِلّاں وِچ اِیں (اِنکار) کُوں گَھتّیا ہوئیا ہے(٢٠٠)۔
  26,201,اِیہ لوک کَݙائِیں وِی اِیندے اُتے اِیمان نَہ گِھن آسِن، جیتوڑِیں جو دَرد ناک عَذاب کُوں نَہ ݙیکھ گِھنسِن(٢٠١)۔
  26,202,ٻَس او اُنھاں اُتّے اَچا چیت آویسے، اَتے اُنھاں کُوں خَبر وِی نَہ پوسی(٢٠٢)۔
  26,203,ٻَس اِیہُو کُجھ اَکھیسِن، کیا اَساکُوں کُجھ مُہلت مِل سَڳدِی ہے(٢٠٣)۔
  26,204,بَھلا اِیہ اَساݙے عَذاب کِیتے کَہیں جَلدی پَے کریندِن(٢٠٤)۔
  26,205,(اَے رسول) کیا تَیں غور کِیتے، جو جیکر اَساں اُنھاں کُوں کُجھ سالاں تَئیں مَوڄاں کرا ݙیوُوں(٢٠٥)۔
  26,206,وَل اُوہَا شَئے اُنھاں اُتّے آوَن٘ڄے، جِیندا اُنھاں نال وَعدہ کِیتا وَن٘ڄے(٢٠٦)۔
  26,207,تاں اُنھاں دے کہیں کَمّ وِی نہ آسِن، جِہڑے فائدے او (زِندگی وِچ) چا کَھڑسِن(٢٠٧)۔
  26,208,اَتے اَساں کہیں وَستی کُوں وِی تَباہ نھیں کِیتا، جے توڑِیں جو اُوندے کِیتے ݙَراوَݨ والے نَہ بھیڄے ہُووِن(٢٠٨)۔
  26,209,نصیحت وِی کریندوں، اَساں تاں ظُلم کَرݨ والے کائے نِسّے(٢٠٩)۔
  26,210,اَتے اِیکُوں شَیطان گِھن تے نَھیں لَتّھے(٢١٠)۔
  26,211,او اِیں لائق ہِن وِی کائے نَہ، اَتے نَہ او اِیہ کَمّ کر سَڳدِن(٢١١)۔
  26,212,بیشک اُنھاں کُوں اِیندے سُݨݨ کنُوں وِی ہِک پاسے کر ݙِتا ڳئے(٢١٢)۔
  26,213,ٻَس (اَے رسول) اَللہ دے نال کہیں ٻئے کُوں اَصلُوں نَہ سَݙ نَہ تاں تُوں وِی عَذاب وِچ آوَںڄݨ والیاں وِچُوں تِھی ویسیں(٢١٣)۔
  26,214,اَتے اَپݨیں سَوڑے سَکّیاں کُوں ݙَرا سَمجھا(٢١٤)۔
  26,215,اَتے اُنھاں نال چَن٘ڳا خُلق وَن٘ڈی رَکّھ، جِنھاں اِیمان گِھن آوَݨ والیاں وِچُوں تیݙی پَیروی اِختیار کِیتی ہوئی ہے(٢١٥)۔
  26,216,ٻَس جیکر او تیݙی نافرمانی کرِن، تاں آکھ ݙے، جو میݙا ذِمّہ کائے نھیں جو تُساں کریندے وَدّے وے(٢١٦)۔
  26,217,اَتے ہُوندے اُتّے توکّل کر، جِہڑا جو ٻَہُوں زَبردست تے ہمیشہ رحمت وَساوَݨ والا ہے(٢١٧)۔
  26,218,جِہڑا تیکُوں ݙیکھدا کَھڑے جیں ویلے (نَماز کِیتے) کَھڑا تِھی کَھڑدیں(٢١٨)۔
  26,219,اَتے سَجدے کرَݨ والیاں وِچ تیݙے پھیرے مارݨ کُوں وِی(٢١٩)۔
  26,220,بیشک او سَب کُجھ سُݨݨ والا تے چَن٘ڳی طرح ڄاݨݨ والا ہے(٢٢٠)۔
  26,221,کیا مَیں تُہاکُوں ݙَساواں جو شیطان کِیندے اُتّے لَہندِن(٢٢١)۔
  26,222,اِیہ تاں ہَر کُوڑ مارݨ والے بَد کردار اُتّے لَہندِن(٢٢٢)۔
  26,223,اِیہ سُݨیاں سُݨائیاں ڳالھیں اُنھاں کُوں آ ݙَسیندِن، اَتے اُنھاں دے ڈھیر کُوڑ مارَݨ والے ہِن(٢٢٣)۔
  26,224,اَتے شاعر؟ انھاں دِی پَیروی تاں گُمراہ لوک اِی کریندِن(٢٢٤)۔
  26,225,کیا تَیں نھیں ݙِٹَّھا جو او (خیالاں) دِی ہَر وادی وِچ سِر مریندے وَدّے ہِن(٢٢٥)۔
  26,226,اَتے دَراصل او اُوہو کُجھ اَکھیندِن جِہڑا کریندے وِی نھیں(٢٢٦)۔
  26,227,سِوائے اُنھاں لوکاں دے جِہڑے جو اِیمان گِھن آئِن اَتے نیک عَمل کِیتئن، اَتے اَللہ دَا ذِکر وِی ٻَہُوں کریندے رِیہِن، اَتے بَدلہ گِھدّے تاں او وِی اَپݨیں اُتّے ظلم تِھی وَن٘ڄݨ دے بعد، اَتے اَجھو پَتہ لَڳ ویسے اُنھاں لوکاں کُوں جِنھاں ظلم کِیتے، جو او کِہجی وَل وَن٘ڄݨ والی سَخت جاء تے وَل ویسِن(٢٢٧)۔
