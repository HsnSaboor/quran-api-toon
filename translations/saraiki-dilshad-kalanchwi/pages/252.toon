quran[10{c,v,t}:
13,19,بَھلا جِہڑا شَخص ڄاݨدے جو جو کُجھ تیݙے رَبّ دِی طرفوں تیں دو نازِل کِیتا ڳئے او بالکل سَچ ہے، بَھلا او اُوں شخص وان٘گُوں تِھی سَڳدے جِہڑا (اِیں حقیقت کنُوں) اَندھا ہووے؟ بیشک عقل سَمجھ والے لوک اِی نصیحت حاصل کریندِن (١٩)۔
13,20,اِیہے (نیک) لوک اَللہ نال کِیتے ہوئے قول قرار کُوں پُورا کریندِن اَتے اُوکوں نھیں تُرڑیندے (٢٠)۔
13,21,اَتے اِیہ لوک سکوت (رابطیاں) کوں مِلائی رَکھدِن جیندے کِیتے اَللہ مِلائی رَکھݨ دا حُکم ݙِتا ہوئے، اَتے اَپݨیں رَبّ کنُوں ݙردے رَہندِن، اَتے گندے عذاب کنُوں کَن٘بدے تھڑکدے رَہندِن (٢١)۔
13,22,اَتے جِہڑے لوک (مصیبت ویلے) اَللہ دِی خوشنودی حاصل کرݨ دِی خاطر صَبر اختیار کریندِن، اَتے نماز کُوں قائم رَکھیندِن اَتے خرچ کریندِن جِہڑا کُجھ اَساں انھاں کُوں رِزق دے طور تے لُکا تے ݙیندے ہَیں یا ساریاں دے سامݨیں ݙیندے ہَیں، اَتے نیکی نال بَدی کُوں دَفع کریندے ہَیں، اِیہے او لوک ہِن جِنھاں کِیتے آخرت دا سوہݨاں گھر ہے (٢٢)۔
13,23,اُتھاں ہمیشہ کِیتے (خوشیاں دے) باغ ہِن جِنھاں وِچ او وَڑ ویسِن، اَتے جِہڑے کوئی نیک ہوسِن اُنھاں دے پِیو ݙاݙیاں وِچُوں، انھاں دِیاں ذالیں (ٹٻریاں) وِچُوں، تے انھاں دِی اَولاد (دِھیاں پُتراں) وِچُوں او وِی اُݙائیں ویسن، اَتے فرشتے (اُنھاں کِیتے) ہر دروازے کنُوں داخل آ تِھیسِن (٢٣)۔
13,24,(اَکھیسن جو) سلامتی ہے تُہاݙے اُتے کیوں جو تُساں (ہر مصیبت اُتے) صبر کِیتی رَکھیا ہَا، ٻَس (اِیندے بدلے وِچ) آخرت دا گھر تاں ٻَہُوں چَن٘ڳا ہے (٢٤)۔
13,25,اَتے جِہڑے لوک اَللہ دے نال دے قول اقرار کُوں پَکا کر تے وِی تَروڑ ݙیندِن، اَتے اَللہ جِہڑی (سکوت) کُوں جوڑی رَکھݨ دا حُکم ݙِتا ہوئے اُوکوں وِی قائم نھیں رَکھیندے، اَتے زمین اُتے فساد مچائی رَکھدِن، اِیہے لوک ہِن جِنھاں کِیتے لعنت ہے، اَتے اُنھاں کِیتے گَندہ ٹِکاݨاں ہے (٢٥)۔
13,26,اَللہ جیندے کِیتے چَہندے رِزق کُھلا کر ݙیندے، بھانویں قدر دے مطابق ݙیندے، اَتے او دُنیاوی زندگی وِچ اِی خوش وَدّے ہِن، حالانکہ دُنیاوی زندگی آخرت دے مقابلے وِچ تھوڑے جیہے فائدے دے سِوا کُجھ وِی کائے نھیں (٢٦)۔
13,27,اَتے جِنھاں لوکاں کُفر اختیار کِیتے، او اَہدِن جو اَللہ دِی طرفوں اِیندے اُتے کوئی نِشانی کیوں نھیں نازِل تھئی، (اَے رسول) آکھ ݙے جو بیشک اَللہ جیکوں چَہندے گُمراہ کر ݙیندے اَتے جِہڑا اُوں دو رجوع کرے اُوکوں آپݨاں سِدّھا رَاہ ݙیکھیندے (٢٧)۔
13,28,اِہجے لوک اِیمان گِھن آندِن اَتے اُنھاں دے دِل وِی اَللہ دے ذکر نال اِطمینان حاصل کر گِھندِن پَتہ ہووے جو اَللہ دے ذکر نال دِلّاں کُوں اِطمینان ضرور حاصل تِھیندے (٢٨)۔
