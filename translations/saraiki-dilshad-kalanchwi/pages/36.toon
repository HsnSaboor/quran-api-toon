quran[3]{c,v,t}:
  36,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  36,1,یٰسٓ (١)۔
  36,2,قسم ہے قرآن دِی جِہڑا حکمت نال بھریا ہوئے (٢)۔
  36,3,(اَے رسول) بیشک تُوں بھیڄے ہوئے رسُولاں وِچُوں ہیں (٣)۔
  36,4,سِدّھے رَاہ تے ہیں (٤)۔
  36,5,اِیں (قرآن) کُوں ٻَہُوں زبردست تے ہمیشہ رحمت کرݨ والے نازِل کِیتے (٥)۔
  36,6,تاں جو تُوں اِہجی قوم کُوں ݙراویں، جِنھاں دے پِیو ݙاݙیاں کُوں نھیں ݙرایا چِتایا ڳیا، اِیں ڳالھوں او غفلت وِچ ہِن (٦)۔
  36,7,تحقیق انھاں وِچُوں اکثر دے اُتے اَللہ دا قول ثابت تِھی چُکیئے ٻَس او اِیمان نھیں گِھن آندے (٧)۔
  36,8,بیشک اَساں انھاں دِیاں ڳِچّیاں وِچ ڳلاویں (طوق) گھت ݙِتے ہِن، اَتے او کھاݙی توڑِیں پَھسّے ہوئے ہِن، اِیں طرح اِنھاں دے سِر وِی اُچّے کَسّے ہوئے ہِن (٨)۔
  36,9,اَتے اَساں ہِک کَندِھی اِنھاں دے اَڳوں اُسار چھوڑی تے ہِک کَندھی اِنھاں دے پِچُّھوں وِی، ٻَس اُنھاں کُوں کَڄ چھوڑیے، او تاں ݙیکھ وِی نھیں سَڳدے (٩)۔
  36,10,اَتے انھاں کِیتے برابر ہے چاہے، تُوں اُنھاں کُوں نصیحت کریں یا نہ کریں، او اَصلُوں اِیمان نہ گِھن آسِن (١٠)۔
  36,11,بیشک تُوں محض اُوکُوں ݙرا سَڳدیں، جِہڑا جو تیݙی نصیحت اُتے چَلدے اَتے ٻَہُوں مہربان رَبّ کنُوں بغیر ݙِٹھیں ݙَردے، ٻَس اُوکُوں خوشخبری سُݨا ݙے بخشش دِی، تے وَݙی عِزّت والے ثواب (اَجر) دِی (١١)۔
  36,12,بیشک اَساں موئیاں کُوں جِیوا ݙیوَݨ والے ہَیں، اَتے لِکھ گِھندے ہَیں، جو کُجھ او اَڳُوں کِیتے بِھیڄیندے ہِن، اَتے جو کُجھ پِچُّھوں نشانیاں دے طور چھوڑ ویندِن، اَتے اَساں ہر شَئے کُوں روشن کِتاب وِچ لِکھ رَکھیا ہے (١٢)۔
  36,13,اَتے (اَے رسول) اُنھاں کُوں اُوں وَستی والے لوکاں دِی مثال وِی سُݨا، ڄَݙاں جو اُنھاں کولھ اَساݙے رسول آئے ہَن (١٣)۔
  36,14,(یعنی) ڄَݙَاں اَساں انھاں کولھ ݙُوں رسول بھیڄے، ٻَس انھاں ݙوہاہِیں کُوں کُوڑا آکھیا، اَساں تریجھے کُوں وِی بھیڄ تے انھاں دِی مَدد کِیتی انھاں آکھیا، جو اَساں تُہاݙے کولھ (رسول بݨا تے) بھیڄے ڳئے ہَیں (١٤)۔
  36,15,لوکاں آکھیا، تُساں ہِیوے کیا؟ ٻَس اَساں جیہے بَشر تاں ہِیوے، اَتے ٻَہُوں مہربان اَللہ نے تاں کوئی شَئے وِی نازِل نھیں کِیتی، تُساں تاں اَصلُوں کُوڑ مریندے وے (١٥)۔
  36,16,انھاں آکھیا، اَساݙا رَبّ ڄاݨدا کھڑے جو بیشک تُہاݙے کولھ اِی بھیڄے ڳئے ہَیں (١٦)۔
  36,17,اَتے اَساݙے ذِمّے تاں ٻَس صاف صاف پُچا ݙیوݨ ہے، جو کُجھ او آکھݨ چَہندے (١٧)۔
  36,18,لوکاں آکھیا، اَساں تاں تُہاکوں منحوس سَمجھدے ہَیں جیکر تُساں باز نہ آئے، تاں اَساں تُہاکوں پَتھر مار مار تے مار گھتیسُوں اَتے تُہاکوں اَساݙی طرفوں ہِک ݙُکھ ݙیوݨ والا عذاب وِی آ چِمبڑسے(١٨)۔
  36,19,انھاں آکھیا، جو تُہاݙی نحوست تُہاکوں نصیب رَہے (اِیکوں وِی نحوست سَمجھدے وے) جو تُہاکوں نصیحت کِیتی ڳئی ہے، بلکہ تُساں تاں اَصلُوں حد کنُوں ٹَپ وَن٘ڄݨ والی قوم ہِیوے (١٩)۔
  36,20,اَتے شہر دے اَصلُوں پرلے پاسُوں ہِک آدمی بَھڄدا ہویا آیا، تے آکھیُس، جو اَے میݙی قوم! تُساں انھاں رسولاں دِی پَیروی اختیار کر گِھنّو (٢٠)۔
  36,21,اِہجیاں دِی پَیروی! جِہڑے تُساں کنُوں کوئی اَجر (مُعاوَضہ) وِی نھیں مَنگدے، اَتے خود ہدایت حاصل کر چُکے ہوئِن (٢١)۔
  36,22,اَتے میکوں کیا تِھی ڳئے جو اُوندی عبادت نہ کراں، جَیں میکوں پَیدا کِیتے، اَتے جَیں دو تُساں ساریاں وَل وَن٘ڄݨیں (٢٢)۔
  36,23,کیا مَیں اُوکوں چھوڑ تے ٻِنھاں کُوں معبود بݨاواں، جیکر ٻَہُوں مہربان اَللہ میکوں کوئی تکلیف پُچاوَݨاں چَہوے، تاں اُنھاں دِی سفارش میݙے کہیں وِی کَم نھیں آسَڳدی، اَتے نہ او میکوں چُھڑا سَڳسِن (٢٣)۔
  36,24,اِیں کراں تاں بیشک مَیں کُھلی گُمراہی وِ چ پَے ڳیُم (٢٤)۔
  36,25,بیشک مَیں تُہاݙے رَبّ اُتے اِیمان گِھن آیاں، ٻَس میݙی ڳالھ (غور نال) سُݨ گِھنُّو (٢٥)۔
  36,26,(آخر) حُکم تِھیا جو بہشت وِچ داخل تِھی وَن٘ڄ، اُوں آکھیا، اِیویں ہوندا جو میݙی قوم وِی اِیں ڳالھ کُوں ڄاݨ گِھندی (٢٦)۔
  36,27,کیوں جو میکوں میݙے رَبّ بخش ݙِتے اَتے میکوں عزّت والیاں نال رَلا گِھدے (٢٧)۔
  36,28,اَتے اَساں اِیندے بعد اُوندی قوم اُتے آسمان کنُوں نہ کوئی لشکر لَہایا، اَتے نہ اَساکوں لَہاوݨ دِی ضرورت پَئی (٢٨)۔
  36,29,اُنھاں اُتے تاں محض ہِک کَڑکاٹ تِھیا، ٻَس او ہُوں ویلے وِسِمّ تے رَہ ڳئے (٢٩)۔
  36,30,اِہجیاں بندیاں اُتے افسوس تھیندے جِنہاں کولھ، جِہڑا کوئی رَسول آئے، تاں اُنھاں اُوں تے کِھلّاں کر چھوڑئِن (٣٠)۔
  36,31,کیا اُنھاں نھیں ݙِٹھا جو اَساں اُنھاں کنُوں پہلے والیاں کِتنیاں قوماں تباہ تے برباد کر چھوڑئِن، بیشک او اُنھاں دو وَل تے نھیں آئے (٣١)۔
  36,32,اَتے انھاں ساریاں کوں کٹھا کر تے اَساݙے کولھ حاضر کِیتا ویسے (٣٢)۔
  36,33,اَتے اُنھاں کِیتے سُکّی سَڑی (موئی ہوئی) زمین وِی ہِک نشانی ہے ڄَݙاں وِی اَساں اُوکُوں جِیوا ݙِتا، تاں اُوندے وِچُوں داݨیں پَیدا کر چھوڑے، ٻَس اِیہ اُنھاں کُوں کھاندے رَہندے ہَن (٣٣)۔
  36,34,اَتے اَساں اِیندے اُتے کھجِّیاں تے انگوراں دے باغ لا ݙِتِن، اَتے اُوندے وِچُوں کئی چَشمے وَہا چھوڑئِن (٣٤)۔
  36,35,تاں جو اِیہ اُوندے پھل کھاوِن، اَتے اِیہ سَب کُجھ انھاں دے ہَتّھاں نِھیں پَیدا کِتا، بَھلا وَل وِی شُکر اَدا نھیں کریندے (٣٥)۔
  36,36,او تاں پَاک ہے، جَیں اُوندے جوڑے جوڑے بݨائِن جِہڑا کُجھ وِی زمین وِچُوں ڄَمدے، اَتے خود انھاں (انساناں) دے آپ دے وِی، اَتے انھاں شَئیں دے وِی جِنھاں کُوں اِیہ ڄاݨدے وِی کائے نھیں (٣٦)۔
  36,37,اَتے ہِک نشانی انھاں کِیتے رات دِی وِی ہے اُوندے وِچُوں ݙین٘ہ کُوں کڈھ گِھندے ہَیں، ٻَس اُنھاں اُتے اندھارا تِھی ویندے (٣٧)۔
  36,38,اَتے سِجھ آپݨیں مقرر رَستے اُتے ٹُردا رَہندے، اِیہ سَب تُوں ݙاڈھے تے سَب کُجھ ڄاݨݨ والے دے حکم (اندازے) دے مطابق تِھیندا پَئے (٣٨)۔
  36,39,اَتے اَساں چَندر دِیاں مَنزلاں مقرر کرݙِتِن، اِیہ توڑِیں جو (گھٹدیں گھٹدیں) کھجّی دے پُراݨیں کھمبݨے وانگے تِھی ویندے (٣٩)۔
  36,40,اَتے نہ تاں سِجھ، اِیں قابل ہے جو چَندر کُوں پَکڑ گِھنّے اَتے نہ رَات اِیں قابِل ہے جو ݙین٘ہ کنُوں پہلے آ وَن٘ڄے، اَتے اِیہ سارے آپݨیں آپݨیں دائرے (مدار) وِچ تَردے وَدّے رَہندِن (٤٠)۔
  36,41,اَتے ہِک نشانی انھاں کِیتے اِیہ وِی ہے جو بیشک اَساں اُنھاں دِی اولاد کُوں بَھری ہوئی ٻیڑی وِچ سوار کر گِھدا ہَا (٤١)۔
  36,42,اَتے انھاں کِیتے اُوہو جیہاں ٻِیاں شَئیں وِی پَیدا چَا کِیتن، جِنہاں اُتے اِیہ چَڑھدے رَہندِن (٤٢)۔
  36,43,اَتے جیکر اَساں چَہوُوں، تاں اُنھاں کُوں غرق کر چھوڑوں، وَل نہ تاں کوئی اِنھاں دِی فریاد سُݨ سَڳے اتے نہ اُنھاں کُوں بچایا وَن٘ڄ سَڳے (٤٣)۔
  36,44,اِیہ تاں ٻَس اَساݙی رحمت ہے جو ہِک مقرر معیاد تائیں انھاں کِیتے فائدے پُچاوݨ والیاں شَئیں موجود ہِن (٤٤)۔
  36,45,اَتے ڄَݙاں اُنھاں کُوں آکھیا ویندے، جو ݙَرو (اُوں انجام کنُوں) جِہڑا تُہاݙے اَڳوں آندا پَے، اَتے جِہڑا تُساں کنُوں پہلے گُزر چُکئے، تاں جو تُہاݙے اُتے رَحم کِیتا وَن٘ڄے (٤٥)۔
  36,46,انھاں کولھ انھاں دے رَبّ دِی طرفوں اُوندیاں نشانیاں وِچُوں کوئی وِی نشانی اِہجی نھیں آئی، جَیں کنُوں اُنھاں مُن٘ہ نہ پھیریا ہووے (٤٦)۔
  36,47,اَتے ڄَݙاں انھاں کُوں آکھیا ویندے جو جِہڑا کُجھ رِزق اَللہ تُہاکوں ݙِتے، اُوندے وِچُوں (اُوندی رَاہ تے وِی کُجھ) خرچ کرو، تاں جِہڑے لوکاں کُفر اختیار کِیتا ہوئے او اُنھاں کُوں جہڑے جو اِیمان گِھن آئِن اَکھیندِن جو بَھلا اَساں انھاں کُوں کھاݨاں کھواؤں جِنھاں کُوں اَللہ چَہندا تاں خود آپ وِی کَھوا ݙیندا، تُساں تاں اَصلُوں تِھڑِک ڳئے وے (٤٧)۔
  36,48,اَتے اَہدِن جو جیکر تُساں سَچّے ہِیوے، تاں (ݙَساؤ) اِیہ وَعدہ (قیامت آوݨ دا) کݙاں توڑِیں پُورا تِھیسے؟ (٤٨)۔
  36,49,اِیہ تاں ٻَس ہِک کڑکاٹ دِی انتظار وِچ رَہن، او اُنھاں کُوں اُوں ویلے آپکڑیسی ڄَݙاں جو اِیہ آپس وِچ کوئی نہ کوئی جھیڑا گَھتّی کھڑے ہوسِن (٤٩)۔
  36,50,ٻَس نہ تاں او کوئی نصیحت کر سڳسِن، اَتے نہ آپݨیں گھر والیاں دو واپس وَل سڳسِن (٥٠)۔
  36,51,اَتے جِہڑے ویلے صُور پُھوکیا ویسے، اِیہ قبراں وِچُّوں (نِکل تے) آپݨیں رَبّ دو بَھڄّدے لڳے آسِن (٥١)۔
  36,52,اَکھیسِن، ہائے ہائے! اَساکوں اَساݙیاں نِندر دِیاں جائیں کنُوں کیٔں اُٹھا کھڑائے، اِیہ اُوہو کُجھ تاں ہے جیندا وعدہ ٻَہُوں مہربان اَللہ کِیتا ہَا اَتے رسولاں وِی اِیکُوں سَچّا آکھیا ہَا (٥٢)۔
  36,53,ٻَس ہِکّو کڑکاٹ تھیسے، ہُوں ویلے سارے دے سارے کٹھے اَساݙے اَڳوں حاضر کر ݙِتے ویسن (٥٣)۔
  36,54,اُوں ݙین٘ہ کہیں نال ذری وِی بے انصافی نہ کِیتی ویسے، اَتے تُہاکوں اُوندا اَجر وِی تاں مِلسے جِہڑا کُجھ تُساں کریندے رِیہے ہاوے (٥٤)۔
  36,55,بیشک بہشت وِچ رَہݨ والے اَڄ دے ݙین٘ہ خوش کر ݙیوݨ والے شُغلاں وِچ وَدّے ہوسِن (٥٥)۔
  36,56,او تے اُنھاں دِیاں ذالیں، چھاں وِچ آپݨیں تخت پوشاں اُتے (تکئیے نال) ٹیک لا تے ٻیٹھے ہوسِن (٥٦)۔
  36,57,اُوندے وِچ اُنھاں کِیتے میوے ہِن اَتے اُنھاں کِیتے او سَب کُجھ ہے جِہڑا کُجھ او مَن٘ڳسِن (٥٧)۔
  36,58,"اُنھاں اُتے "" سلام"" ہوسے، ہَمیشہ رحمت کرݨ والے رَبّ دِی طرفوں! (٥٨)۔"
  36,59,اَتے گُنہگارو! تُساں تاں اَڄ ہِک پاسے نِکھڑ کھڑوُو! (٥٩)۔
  36,60,اَے آدم دِی اَولاد ! کیا تُساں کنُوں وَعدہ نہ گِھدّا ڳِیا ہَا، جو شیطان دِی بندگی اَصلُوں نہ کرݨاں دَراصل او تُہاݙا کُھلا دُشمن ہے (٦٠)۔
  36,61,اَتے اِیہ وِی جو چَھڑی میݙی عِبادت کِیتی رَکھݨاں، اِیہو اِی سِدّھا رَستہ ہے (٦١)۔
  36,62,پَر تحقیق اُوں تُہاݙے وِچُوں ڈھیر کنھائیں کُوں گُمراہ کر ݙِتے، کیا تُہاکوں سَمجھ ںہ آئی! (٦٢)۔
  36,63,اِیہا دوزخ ہے، جَیں کنُوں تُہاکُوں ݙَرایا چِتایا ویندا رِیہا ہَا (٦٣)۔
  36,64,اَڄ اُوندے وِچ وَڑ وَن٘ڄو، اُوں ڳالھ پِچُّھوں جِیندا تُساں اِنکار کریندے ہاوے (٦٤)۔
  36,65,اَڄ دے ݙین٘ہ انھاں دے مُونھاں تے مُہر لا ݙیسوں، اَتے انھاں دے ہَتّھ اَساکوں ݙَس ݙیسِن تے اُنھاں دے پَیروی گواہی ݙیسِن، جو اِیہ کیا کُجھ کریندے کماندے رِیہے ہِن (٦٥)
  36,66,اَتے جیکر اَساں چَہوُوں، تاں انھاں دِیاں اَکّھیں میٹ ݙیوُں، وَل او رَاہ دو ویندے وِی سَہی، تاں کِیویں ݙیکھدے (٦٦)۔
  36,67,اَتے جیکر اَساں چہوُوں تاں اِیہ جِتّھاں ہِن اُتھائیں انھاں دِیاں شَکلاں وِڳاڑ ݙیوُوں، ٻَس او نہ اِݙے اُݙے وَن٘ڄ سَڳسِن، تے نہ پِچُّھوں تے وَل آ سڳسِن (٦٧)۔
  36,68,اَتے جیکوں اَساں لمبی عُمر ݙیندے ہَیں، تاں اُوندی حالت بدل ݙیندے ہَیں، کیا او اِیہ ڳالھ وِی نھیں سَمجھدے (٦٨)۔
  36,69,اَتے اَساں اِیں (نبی) کُوں شعر آکھݨ نھیں سِکھایا، اِیہ اِیکوں ہرگز نھیں ٹَھہندا، اِیہ تاں محض ہِک نصیحت ہے تے صاف صاف بیان کر ݙیوݨ والا قرآن ہے (٦٩)۔
  36,70,تاں جو انھاں کُوں چِتاوے ݙراوے، جِہڑے جِیندے وَدّے ہِن، اَتے کافراں اُتے وِی حُجّت پُوری تِھی وَن٘ڄے (٧٠)۔
  36,71,کیا اُنھاں نِھیں ݙِٹھا، جو اَساں اُنھاں کِیتے کیا کیا پَیدا کِیتے ہِن، جو کُجھ اَساݙے ہَتّھاں بݨائے، اُنھاں وِچ چار پیرڑے جانور وِی ہِن، ٻَس اِیہ اُنھاں دے مالِک ہِن (٧١)۔
  36,72,اَتے اُنھاں کُوں انھاں دے قبضے وِچ کر ݙِتے، ٻَس اُنھاں وِچُوں کُجھ تاں اِنھاں کِیتے سواری دے طور تے ہِن، تے انھاں وِچُوں کُجھ کُوں کھاندے وِی ہِن (٧٢)۔
  36,73,اَتے انھاں کِیتے اِنھاں وِچ ٻئے فائدے وِی ہِن، اَتے پِیوݨ دِیاں شَئیں وِی ہِن، تاں وِی اِیہ شُکر اَدا کیوں نھیں کریندے؟ (٧٣)۔
  36,74,اَتے اَللہ کُوں چھوڑ تے انھاں رَبُوبݨے (کُوڑے خُدا) بݨا گِھدّے ہِن، تاں جو او اُنھاں دِی مَدد کرِن (٧٤)۔
  36,75,پر او اُنھاں کُوں مَدد ݙیوݨ دِی طاقت نھیں رَکھیندے، بلکہ اِیہ خُود اُنھاں کِیتے لشکر دی شَکل وِچ حاضر تھئے رَہندِن (٧٥)۔
  36,76,ٻَس اُنھاں دِیاں ڳالھیں تیکوں مُونجھا نہ کرِن اَساں چَن٘ڳی طرح ڄاݨدے کھڑے ہَیں، اِیہ جو کُجھ لُکا تے کریندِن تے جو کُجھ ظاہر طور تے کریندے وَدِّن (٧٦)۔
  36,77,کیا انسان نے اِیہ نھیں ݙِٹھا جو دراَصل اَساں اُوکوں ہِک تریڑے (نُطفے) وِچُوں پَیدا کِیتے، ٻَس وَلا کُھلے طور تے جھیڑاکِل ٻَݨ ڳئے (٧٧)۔
  36,78,اَتے اَساݙے متعلّق مثالاں ݙیوݨ لڳ پَے اَتے اَپݨیں اَصل (پَیدائش) کُوں بُھل ڳئے تے آکھݨ لڳ پَے جو انھاں ہَݙیاں کُوں کوݨ جِیوا کھڑا کریسے، ڄَݙاں جو او اَصلُوں بُھر شُر ڳیاں ہووِن (٧٨)۔
  36,79,(اَے رسول) آکھ ݙے جو انھاں کُوں او جِیوا کھڑا کریسی، جَیں انھاں کُوں پہلی واری پَیدا کِیتا ہَا، اَتے او ہَر شَئے دے پَیدا کرݨ کُوں چَن٘ڳی طرح ڄاݨدے (٧٩)۔
  36,80,جَیں تُہاݙے کِیتے ساوے درخت وِچُوں بَھا پَیدا کر ݙِتی، ٻَس تُساں (رَگڑ تے) اُوندے وِچُوں بَھا دُکھا گِھندے وے (٨٠)۔
  36,81,کیا جَیں اَسماناں کُوں تے زمین کُوں پَیدا کِیتے، اِیں ڳالھ دِی قُدرت نھیں رَکھیندا جو انھاں جیہے وَلا وِی پَیدا کر ݙیوے، بَھلا کیوں نھیں (رَکھیندا) اَتے او تاں سَب تُوں وَدّھ پَیدا کرݨ والا، اُوندا عِلم رَکھݨ والا ہے (٨١)۔
  36,82,بیشک اُوندا حُکم اِی چَلدے، جو جِہڑے ویلے کہیں شَئے (دے پَیدا کرݨ) دا اِرادہ کریندے تاں اُوندے کِیتے اَکھیندے تِھی وَن٘ڄ، ٻَس او تِھی ویندی ہے (٨٢)۔
  36,83,او تاں پاک ہے جیندے ہَتھ وِچ ہَر شَئے دِی بادشاہی وِی ہے اَتے اُوں دو تُہاکوں وَل وَن٘ڄݨیں! (٨٣)۔
