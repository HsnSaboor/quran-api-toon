quran[3]{c,v,t}:
  21,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  21,1,لوکاں کنُوں پُچّھ پَرتیت (حِساب کِتاب) دَا وَقت قریب آندا ویندے، پَر او لَا پَروا تِھی تے مُن٘ہ پھیری وَدّے ہِن(١)۔
  21,2,اُنھاں کولھ اُنھاں دے رَبّ دِی طرفُوں جِہڑی کوئی نویں نصیحت آندی ہے، اُوکُوں او سُݨدے وِی ہِن تاں وِی او اِیکُوں کِھل ہَاسہ چَا سَمجھدے ہِن(٢)۔
  21,3,اُنھاں دے دِلّ غفلت والیاں ڳالھِیں وِچ لڳئے ہوئِن، اَتے اِیہ ظلم کرݨ والے لوک آپس وِچ کُھسّ پُھسّ کریندے ہِن، جو کیا اِیہ شَخص تُہاݙے وانگُوں ہِک بَشر جیہا کائے نھیں؟ پَر وَل وِی تُساں جادُو دِی وَلھیٹ وِچ کِیُوں لَڳے ویندے وے؟ ڄَݙاں جو تُساں چَن٘ڳی طرح ݙیکھدے بَھلیندے وِی وَدّے ہِیوے۔ (٣)۔
  21,4,(رسول) آکھیا، میݙا رَبّ ڄاݨ ویندے جِہڑی ڳالھ تُساں اَسمان وِچ تے زمین وِچ کریندے وے، او سَب تُوں زیادہ سُݨݨ والا تے ڄاݨݨ والا ہے(٤)۔
  21,5,پر لوک اَہدِن جو اِیہ تاں خواباں خیالاں والیاں ڳالھِیں ہِن، بلکہ اُوں اَپݨِیں طرفُوں گَھڑ گِھدّیاں ہِن، اِیہ تاں کوئی شاعر ای ہے، چَلُّو اَساݙے کولھ نِشانی تاں گِھن آوے، پہلے رسول وِی تاں نِشانی ݙے تے بھیڄے ویندے رِیہے ہِن(٥)۔
  21,6,اُنھاں کنُوں پہلے جِہڑی وِی وَستی والے اِیمان نھیں گِھن آئے تاں اَساں اُنھاں کُوں تَباہ کر چھوڑے، بھلا کیا اِیہ اِیمان گِھن آوَݨ والے ہِن؟ (٦)۔
  21,7,اَتے اَساں تَیں کنُوں پہلے کہیں ٻَے کُوں رسول بݨا تے نھیں بھیڄیا، سِوائے کہیں جُوان دے! اُنھاں دے کولھ وَحی بھیڄیندے ہَاسے، بیشک اَللہ دِی کتاب والیْاں کنُوں پُچّھ گِھنُّو، جیکر تُساں خُود نِھیوے ڄاݨدے؟ (٧)۔
  21,8,اَتے اَساں اُنھاں دے ڄُثّے اِیں طرح نہ بݨائے ہِن، جو او کھاݨاں وِی نہ کھاوِن ہَا، اَتے او ہمیش زِندہ رَہوݨ والے وِی نَہ ہَن(٨)۔
  21,9,وَل اَساں اُنھاں نال کِیتے ہوئے ہَر وَعدے کُوں سَچّا کر ݙِیکھائے، ٻَس اُنھاں کُوں اَتے جیکُوں اَساں چاہیا، بَچا گِھدّا، اَتے حَد کنُوں نِکل وَن٘ڄݨ والیاں کُوں اَساں تَباہ کر ݙِتا(٩)۔
  21,10,اَتے تحقیق اَساں تُہاݙے کولھ اِہجی کِتاب نازِل کِیتی ہے، جِیندے وِچ تُہاݙے کِیتے نصیحت ہے، کیا تُساں وَل وِی نِھیوے سَمجھدے؟(١٠)۔
  21,11,اَتے اَساں کِتنیاں وَستیاں کُوں پِیھ تے رَکّھ ݙِتا، جِہڑیاں جو ظالم ہَن، تے اِیندے بعد کہیں ٻَئی قَوم کُوں پَیدا کر کَھڑایا(١١)۔
  21,12,ٻَس ڄَݙاں اُنھاں اَساݙے عَذاب کُوں آن٘دا محسوس کِیتا، تاں اِیں کنُوں بھڄݨ لڳ پَے؟(١٢)۔
  21,13,بھڄّو نَہ پَے، ٻَس وَل آؤُو، اُوں عَیش آرام دو جِہڑا تُہاکُوں حاصِل ہے، تے آپݨیاں گَھراں دو، تاں جو تُساں کنُوں کوئی پُچّھ پرتیت کِیتی وَن٘ڄے(١٣)۔
  21,14,او آکھݨ لڳیے، ہائے شامت اَساݙی! بیشک اَساں تاں ظالم اِی ہَاسے(١٤)۔
  21,15,ٻَس اِیں طرح او اَکھیندے سَݙیندے رِیہے، اِیہ توڑِیں جو اَساں اُنھاں کُوں کَپّی ٹُکّی رَڑھ (فصل) وانگُوں تے وِسمدی ہوئی سُواء وانگُوں کر چھوڑیا(١٥)۔
  21,16,اَتے اَساں اَسمان تے زمین کُوں اَتے جو کُجھ اُنھاں دے اَدّھ وِچ ہے، اِیویں خُواہ مَخواہ نھیں پَیدا کِیتا(١٦)۔
  21,17,جیکر اَساں چَہندے جو مشغلے دِی کوئی شَئے بݨاؤں تاں ضرور اَساں اُوکُوں اَپݨِیں طرفُوں کہیں شَئے کنُوں بݨا گِھندے جیکر اَساکُوں کُجھ کرݨاں ہوندے تاں اَساں کر ڄاݨدے ہَیں(١٧)۔
  21,18,بلکہ اَساں حَقّی ڳالھ کُوں کُوڑ دے اُتّے اِیویں بھُکا مَریندے ہَیں، جو ٻَس اُوندا بھیڄا کَڈھ سَٹیندے ہَیں، ٻَس او اُوں ہیں ویلے خَتم تِھی تے رَہ ویندے، اَتے تُہاݙی شامت ہے وِی اُنھاں ڳالھُوں جِہڑیاں تُساں گَھڑ گِھندے ہِیوے(١٨)۔
  21,19,اَتے اُوں ہِیں دا ہے جو کُجھ اَسماناں وِچ ہے تے زمین دے تَلّے اُتّے ہے اَتے جِہڑے (فرشتے) اُوندے کولھ رَہندِن، نہ تاں او اُوندی عِبادت کر تے مَغریج ویندِن تے نہ او تَھکدے ہِن(١٩)۔
  21,20,رات ݙین٘ہ اُوندی تَسبیح پَڑھدے رَہندِن تے سَہی وِی نھیں کَڈھیندے(٢٠)۔
  21,21,کیا اُنھاں زمین اُتّے اِہجے ٻَے معبود بݨا گِھدِّن جِہڑے (موئے ہوئیاں کُوں) جِیوا کَھڑیسِن(٢١)۔
  21,22,جیکر اَسمان تے زمین اَندر اَللہ دے علاوہ کوئی ٻَئے معبود وِی ہوندے تاں (سارے اِنتظام وِچ) خَلل (فَساد) پَے ویندا، ٻَس اَللہ جِہڑا عَرش دَا رَبّ ہے اُنھاں ڳالھِیں کنُوں پاک ہے جِہڑیاں اِیہ گَھڑیندے وَدّے ہِن(٢٢)۔
  21,23,او جِہڑا کَمّ کریندے اُوندی کوئی پُچّھ ڳُچّھ نھیں ہُوندی، پَر ٻِنھاں کنُوں ضرور پُچّھ کِیتی ویندی ہے(٢٣)۔
  21,24,کیا لوکاں اُوکُوں چھوڑ تے کوئی ٻئے معبود بݨَا گِھدّن (اَے رسول) آکھ ݙے جو تُساں کوئی تاں پَکّی دلیل گِھن آؤُو، اِیہا نصیحت (کِتاب) میݙے تے میݙے نال والیاں کِیتے وِی ہے، اَتے مَیں تُوں پہلے گُزر وَن٘ڄݨ والیاں کولھ وِی آئی ہَئی، پَر اُنھاں دے ڈھیر لوک اِیں حقیقت کُوں نھیں ڄاݨدے ٻَس اِیں کنُوں مُن٘ہ پھیری وَدّے ہِن(٢٤)۔
  21,25,اَتے اَساں تَیں کنُوں پہلے کوئی اِہجا رسول نھیں بھیڄیا، جِیندے کولھ اِیہ وَحی نہ بھیڄی ہووے جو میݙے سِوائے کوئی معبود کائے نھیں، ٻَس میݙی عِبادت کِیتی کرو(٢٥)۔
  21,26,اَتے اِیہ اَہدِن ٻَہُوں مہربان اَللہ نے پُتر بݨایا ہوئے او تاں اِنھاں ڳالھِیں کنُوں پَاک ہے، بلکہ اِیہ (فرشتے) تاں اُوندے عزّتاں والے خادِم ہِن(٢٦)۔
  21,27,اِیہ اُوں کنُوں اَڳُوں کہیں ڳالھ وِچ (ذَری وِی) نھیں وَدھ سَڳدے، ٻَس اُوندے حُکم تے عَمل کریندِن(٢٧)۔
  21,28,او ڄاݨدا کھڑے، جو کُجھ اُنھاں دے اَڳُوں تِھیندا پَے، تے جو کُجھ اُنھاں کنُوں اُوڈھر تِھیندا پَے، اَتے سِفارش وِی نھیں کر سَڳدے، سِوائے اُوندے جِیندے کنُوں اَللہ راضی ہُووے، اَتے اِیہ اُوندی دہشت کنُوں ݙَردے رَہندِن(٢٨)۔
  21,29,اَتے اُنھاں وِچُوں جِہڑا وِی آکھے، جو مَیں وِی اُوں کنُوں عِلاوہ ہِک ٻِیا معبود ہَاں، ٻَس اُوکُوں دَوزخ دِی سَزا ݙیسُوں، اِیویں ظالماں کُوں سَزا ݙیندے رَہندے ہَیں(٢٩)۔
  21,30,کیا انھاں لوکاں نھیں ݙِٹّھا جِہڑے حَق کنُوں اِنکار کریندِن جو بیشک سَارے اَسمان تے زمین آپس وِچ ہِکُّو کُجھ ہَن، وَل اَساں اُنھاں کُوں اَن٘ج اَنج کر ݙِتا، اَتے اَساں ہَر شَئے پاݨِیں نال پَیدا کِیتی، بَھلا اِیہ اِیمان کِیُوں نھیں گِھن آندے(٣٠)۔
  21,31,اَتے اَساں زمین وِچ پَہاڑ کھڑے کر ݙِتے ہِن، تاں جو زمین اُنھاں دے بار دے سَبب ہَلّے ڄُلّے نہ! وَل اَساں انھاں وِچ موکلے موکلے رَستے (دَرّے) بݨائِن، تاں جو او ٹِھیک رَاہ تے ٹُرِن(٣١)۔
  21,32,اَتے اَسمان کُوں اَساں تَکڑی جہی چَھت بَݨائے، پَر اِیہ لوک اُنھاں نِشانیاں کنُوں مُن٘ہ پھیر گِھندِن(٣٢)۔
  21,33,اَتے اُوہو اِی ہے جَیں رات تے ݙین٘ہ ، تے سِجھ تے چَندر بݨائِن، اُنھاں وِچُوں ہَر کوئی اَپݨیں اَپݨیں دائرے وِچ تَردا وَدّے(٣٣)۔
  21,34,اَتے (اَے رسول) تَیں کنُوں پہلے توڑِیں اَساں کَہیں کوں ہمیشہ دِی زِندگی نھیں ݙِتّی، بَھلا تُوں مَر ڳیُوں تاں کیا اِیہ ہمیشہ جِیندے رَہسِن(٣٤)۔
  21,35,ہَر سَاہ گِھنَّݨ والے مَوت دَا سَواد چَکھݨیں، اَتے اَساں تُہاکُوں بَھلائی تے بُرائی وِچ اَزمیندے ہَیں، اَتے تُساں اَساں دو ضرور وَل آوݨیں(٣٥)۔
  21,36,اَتے جِنھاں لوکاں کُفر اِختیار کِیتا ہوئے، ڄَݙاں وِی او تیکُوں ݙیکھدے ہِن، تاں تیݙے نال مخول کریندِن، (اَکھیندِن) کیا اِیہُو او شَخص ہے جِہڑا تُہاݙے معبوداں دا ذِکر (بُرائی نال) کریندے، حالانکہ اِیہے لوک خُود اَپݨیں سَب تُوں مہربان اَللہ دے ذِکر کرݨ وِچ وِی کُفر بَکدے رَہندِن(٣٦)۔
  21,37,اِنسان کُوں اُٻَہل کرݨ والا بݨایا ڳئے، مَیں وِی اَجھو تُہاکُوں نِشانیاں ݙیکھینداں، ٻَس تُساں مَیں کنُوں اُٻَہل نہ کراؤ(٣٧)۔
  21,38,اَتے پُچّھدے ہِن جو او وَعدہ (ݙراوا) کَݙاں پُورا تِھیسے، جیکر تُساں (عَذاب دے متعلّق) سَچ اَکھیندے وے تاں(٣٨)۔
  21,39,اَللہ اِیویں کرے ہَا جو جِنھاں جِنھاں کُفر اِختیار کِیتا ہوئے اُنھاں کُوں اُوں وَقت دَا کُجھ پَتہ لَڳ وَن٘ڄے ہَا، جِہڑے ویلے او اَپݨیں مُونھاں کُوں تے اَپݨیاں کَن٘ڈاں کُوں دَوزخ دِی بھا کنُوں نَہ بَچا سَڳسِن، اَتے نہ اُنھاں دِی کوئی مَدد کِیتی ویسی(٣٩)۔
  21,40,بلکہ اِیہ اُنھاں اُتّے اَٻَڑغُت آویسے، تے اُنھاں کُوں وَلھیٹ گِھنسے، اِیہ اُوکُوں ہَٹا وِی نہ سَڳسِن، اَتے نَہ خُود اِنھاں کُوں کوئی مُہلت ݙِتی ویسے(٤٠)۔
  21,41,تے (اَے رسول) تَیں کنُوں پہلے وِی رسولاں نال مَسخریاں تے مَذاقاں تِھیندیاں رِیہِن، ٻَس انھاں دے جِہڑے لوک (رسولاں نال) مَخول کریندے ہَن، خُود اُوں شَئے اُنھاں کُوں گھیر گِھدّا، جِیندیاں اُوں کِھلّاں مَذاقاں کریندے ہَن(٤١)۔
  21,42,آکھ ݙے جو رَات ویلے تے ݙین٘ہ کُوں ٻَہُوں مہربان اَللہ (دِی پَکڑ) کنُوں تُہاکُوں کَوݨ بَچا سَڳدے، وَل وِی اِیہ اَپݨیں رَبّ دے ذِکر کنُوں مُن٘ہ پھیر گِھندِن(٤٢)۔
  21,43,کیا اَساکُوں چھوڑ تے اُنھاں دے اِہجے معبود وِی ہِن، جِہڑے اُنھاں کُوں بَچا سَڳِن، او تاں اَپݨیں آپ کُوں مَدد ݙیوݨ دِی وسکت (طاقت) وِی نھیں رَکھیندے، اَتے نہ اَساݙے مقابلے وِچ اُنھاں دے رَلّے کوئی تِھیندے(٤٣)۔
  21,44,بلکہ اَساں تاں اُنھاں کُوں تے اُنھاں دے پِیؤ ݙاݙیاں کُوں ٻَہُوں فائدے پُچائے ہِن، اِیہ توڑِیں جو اُنھاں دِیاں عُمراں وِی گُزر ڳِیاں، بَھلا کیا اِیہ نھیں ݙیکھدے وَدّے، جو اَساں زمین کُوں اُوندے ٻَنّیاں سرحداں کنُوں ڳَھٹیندے آندے ہَیں، بَھلا کیا وَت وِی اِیہ لوک غَلبہ پا سَڳسِن(٤٤)۔
  21,45,آکھ ݙے، جو مَیں تُہاکُوں وَحی دے مطابق ݙَریندا ہَاں، پَر ٻوڑے لوک سَݙ سنیہے کُوں چَھڑا سُݨ وِی نھیں سَڳدے، ڄَݙاں کݙَائیں وِی اُنھاں کُوں ݙَرایا ویندے(٤٥)۔
  21,46,اَتے جیکر اُنھاں کُوں تیݙے (رَبّ دے عَذاب) دا ہِکّ پُھوکا وِی آ لَڳے، تاں آکھݨ لڳ پوسِن، جو ہائے اَساݙی شَامت! اَساں تاں واقعی گُناہ کریندے رِیہے ہَیں(٤٦)۔
  21,47,اَتے اَساں قیامت دے ݙین٘ہ اِنصاف دے پَلڑے (ترکڑیاں) رَکّھ ݙیسُوں، ٻَس کہیں شَخص تے ذَرّی وِی ظُلم نہ کِیتا ویسے، اَتے جیکر کہیں سرہیوں (رائی) دے داݨیں دے برابر وِی کوئی عَمل کِیتے تاں وِی اَساں اِنصاف کرݨ کِیتے کافی ہَیں (٤٧)۔
  21,48,اَتے تحقیق اَساں مُوسیٰ تے ہارون کُوں کُوڑ سَچ دے نکھیڑݨ والی، روشنی تے نصیحت والی شَئے (توریت) عَطا کِیتی، اُنھاں پرہیزگاراں کِیتے(٤٨)۔
  21,49,جِہڑے جو اَپݨیں رَبّ کنُوں ݙِٹھیئں بغیر وِی ݙَردے رَہندِن، اَتے او (قیامت دِی) گَھڑی دَا وِی ݙَر رَکھیندے ہِن(٤٩)۔
  21,50,اَتے اِیہ بَرکت والی نصیحت (کِتاب) ہے جِیکُوں اَساں نازِل کِیتے، کیا وَل وِی تُساں اِیں کنُوں اِنکار کریندے وے(٥٠)
  21,51,اَتے تحقیق اَساں اِبراہیم کُوں عَقل تے ہوش ݙِتا ہَا، اَتے اَساں اُوکُوں خُوب ڄاݨدے ہَاسے(٥١)۔
  21,52,ڄَݙاں اُوں اَپݨیں پِیؤ کنُوں اَتے اَپݨِیں قَوم کنُوں پُچھیا جو اِیہ مُورتیاں (بوتے) کیا ہِن، جِنھاں دِی پُوجا وِچ ݙَاڈھا دِلّ لائی ٻیٹھے رَہندو؟ (٥٢)۔
  21,53,اُنھاں آکھیا، اَساں اَپݨیں پِیؤ ݙاݙیاں کُوں اِنھاں دِی پُوڄا کریندیں ݙِٹّھے(٥٣)۔
  21,54,(اِبراہیم) آکھیا، تحقیق تُساں وِی کُھلی گُمراہی وِچ ہِیوے، تے تُہاݙے پِیؤ ݙاݙے وِی ہَن(٥٤)۔
  21,55,اُنھاں آکھیا، کیا تُوں اَساݙے کولھ حقیقت گِھن تے آئیں، یا تُوں اَساݙے نال کوئی مَذاق پِیا کریندیں(٥٥)۔
  21,56,اُوں آکھیا، بلکہ تُہاݙا رَبّ تاں اَسماناں تے زمین دَا رَبّ وِی ہے، جَیں اُنھاں کُوں پَیدا کِیتے، تے مَیں (اِیں ڳالھ دے) گواہاں وِچُوں ہَاں(٥٦)۔
  21,57,اَتے اَللہ دِی قَسم! مَیں تاں تُہاݙے بُتَّاں نال ہِک کَوا کرݨ لڳیْاں جِہڑے ویلے جو تُساں کَن٘ڈ وَلا تے چَلیے ویسو(٥٧)۔
  21,58,ٻَس اُوں اُنھاں کُوں ٹوٹے ٹوٹے کر چھوڑیا سوائے اُنھاں دے ساریْاں تُوں وَݙے (بُت) دے، تاں جو او اُوں کَنّے رجوع (پُچھ ڳُچّھ) کرݨ(٥٨)۔
  21,59,(اُنھاں ݙِٹَّھا) تاں اَکھیُونیں، اَساݙے خُداواں نال اِیہ حَرکت کَیں کِیتی ہے، بیشک او کوئی ظالماں وِچُوں اِی ہَا(٥٩)۔
  21,60,لوکاں آکھیا، اَساں ہِک ڳَبھرُو جُوان کُوں اِنھاں دے متعلّق ڳالھ شالھ کریندیں سُݨیے اُوکُوں اِبراہیم سَݙیندِن(٦٠)۔
  21,61,اُنھاں آکھیا، اُوکُوں لوکاں دِیاں اَکّھیں دے سامݨیں گِھن آؤ، تاں جو اُوکُوں (ݙیکھ تے) اِیہ گَواہ بَݨ سڳئِن(٦١)۔
  21,62,اُنھاں آکھیا، اِبراہیم آں! اَساݙے خُداواں نال اِیہ حَرکت تَیں کِیتی ہے؟(٦٢)۔
  21,63,اُوں آکھیا، بلکہ اِیہ حَرکت اِیں کِیتی ہے، جِہڑا ساریاں تُوں وَݙا ہے، تُساں انھاں کنُوں پُچّھ گِھنّو ، جیکر اِیہ ٻول سَڳدِن(٦٣)۔
  21,64,ٻَس اُنھاں اَپݨیں دِلّ وِچ سوچیا، تے (ساریاں کُوں) اَکھیُونیں، جو بیشک تُساں خود اِی بے اِنصافے (ظالم) ہِیوے(٦٤)۔
  21,65,وَل (شَرم کنُوں) اُنھاں دے سِر جُھک ڳئے، اَکھیُونیں تحقیق تیکُوں تاں پَتہ ہے، جو اِیہ نھیں ٻولیندے(٦٥)۔
  21,66,(اِبراہیم) آکھیا، وَل تُساں اَللہ کُوں چھوڑ تے انھاں شَئیں دِی پُوجا کِیُوں کریندے وے جِہڑیاں جو نَہ تُہاکُوں کوئی فائدہ ݙے سَڳدِئِن، اَتے نہ تُہاکُوں کوئی نُقصان پُچا سَڳدِئِن(٦٦)۔
  21,67,وَݙا اَفسوس ہے، تُہاݙے اُتّے تے انھاں اُتّے جِنھاں دِی اَللہ کُوں چھوڑ تے تُساں پُوجا کریندے وے، کیا تُہاکُوں اِیہ عَقل سَمجھ وِی کائے نھیں(٦٧)۔
  21,68,لوک آکھݨ لڳے، جو اِیکُوں سَاڑ گَھتُّو، اَتے اَپݨیں خُداواں دِی مَدد کرو جیکر تُہاکُوں کُجھ کرݨیں تاں(٦٨)۔
  21,69,اَساں حُکم ݙِتا، اَے بھا تُوں وِسم تے ٹَھر وَن٘ڄ، اَتے اِبراہیم کِیتے سلامتی دَا باعث بَݨ وَن٘ڄ(٦٩)۔
  21,70,اَتے اںھاں لوکاں اُوندے نال کوئی چَا چَلݨیں چَاہی پَر اَساں خود اُنھائیں کُوں ڳَھاٹے وِچ سَٹ ݙِتَّا(٧٠)۔
  21,71,اَتے اُوکُوں تے لُوط کُوں اُوں عِلاقے دو کَڈھ ڳیُوسے جِہڑے وِچ دُنیا جَہان والیاں کِیتے بَرکت کِھن٘ڈائی ہُوئی ہَئی(٧١)۔
  21,72,اَتے اُوکُوں اِسحاق ݙِتُوسے تے اُوندے عِلاوہ یعقوب ݙِتُوسے تے ہَر کہیں کُوں نیک بَݨا چھوڑیا(٧٢)۔
  21,73,اَتے اُنھاں کُوں اَساں اِمام بَݨایا، کِیُوں جو او اَساݙے حُکم دے مطابق ہِدایت کریندے ہَن، اَتے اُنھاں کولھ وَحی بھیڄی چَن٘ڳے کَم کَرݨ کِیتے، نماز دے قائم رَکھݨ کِیتے، اَتے زَکوٰۃ ݙیوݨ کِیتے، اَتے او اَساݙی عِبادت کرَݨ والے ہَن(٧٣)۔
  21,74,اَتے لوط (دا واقعہ اِیہ) ہے جو اَساں اُوکُوں حکومت تے عِلم بَخشیا، اَتے اُوکُوں اُوں وَستی وِچُوں کَڈھ گِھدّا، جِنھاں دے لوک بے حیائی دے کَمّ کریندے ہِن، بیشک او بَدکار تے نافرمان قوم ہَئی(٧٤)۔
  21,75,اَتے اُوکُوں اَپݨِیں رحمت وِچ داخل کر گِھدّا بیشک او ٻَہُوں نیک لوکاں وِچُوں ہَا(٧٥)۔
  21,76,اَتے نوح (دا قِصّہ اِیہ) ہے جو اِیں کنُوں وِی پہلے اُوں اَساں کنُوں دُعا مَن٘گی، تاں اَساں اُوندی دُعا قبول کر گِھدّی، ٻَس اُوکُوں تے اُوندے گَھر والیاں کُوں ہِک وَݙی مصیبت کنُوں نِجات ݙے ݙِتی(٧٦)۔
  21,77,اَتے اَساں اُوں قَوم دے خِلاف اُوندی مَدد کِیتی، جِہڑی اَساݙیاں نِشانیاں کُوں کُوڑا اَکھیندی ہَئی، بیشک او ٻَہُوں گَندی قَوم ہَئی، ٻَس اَساں اُنھاں ساریاں کُوں غَرق کر چھوڑیا(٧٧)۔
  21,78,اَتے دَاؤد تے سلیمان (دِی ڳالھ اِیں ہے) جو ڄَݙاں او ہِک رَڑھ (فصل) دے متعلّق فیصلہ کرݨ لڳے ہَن، جیکُوں (رات کُوں) ٻِنھاں لوکاں دِیاں بکریاں چَر ڳیاں ہِن، تاں اَساں اُنھاں دے فیصلے کُوں ݙیکھدے کَھڑے ہَاسے(٧٨)۔
  21,79,ٻَس اَساں سُلیمان کُوں فیصلہ سَمجھا ݙِتا، اَتے اَساں ݙُوہائیں کُوں حُکم چَلاوَݨ تے کہیں شَئے کُوں ڄاݨ گِھنَّݨ دِی طاقت (صلاحیت) وِی ݙِتّی ہُوئی ہَئی، اَتے اَساں پَہاڑاں کُوں تے پَکھیاں کُوں وِی تاں جو داؤد نال اَللہ دِی تسبیح پڑھدے رَہوِن، اَتے اَساں اِہجے کَم کر گِھندے ہَیں(٧٩)۔
  21,80,اَتے اَساں اُوکُوں تُہاݙے فائدے کِیتے ہِک قِسم دِی پُوشاک (زِرہ) بݨاوَݨ دَا ڈھنگ وِی سِکھایا، تاں جو تُہاکُوں لَڑائی دے دھک پَھٹ کنُوں بَچاوے، وَت کیا تُساں شُکر کرݨ والے ہِیوے(٨٠)۔
  21,81,اَتے اَساں تیز ہَوا کُوں سلیمان دے تابع کر ݙِتا، جِہڑی جو اُوندے حُکم نال اُوں مُلک وِچ گُھلدی رَہندی ہَئی، جِیکُوں اَساں برکتاں والا بݨایا ہَا، تے اَساں ہر شَئے کُوں چَںڳی طرح ڄاݨݨ والے ہَیں(٨١)۔
  21,82,اَتے بعضے شیطان اُوندے کِیتے پاݨِیں وِچ ٹُٻِیاں مریندے ہِن، اَتے اِیندے سِوا ٻَئے کَم وِی کریندے ہَن، اَتے اَساں اُنھاں دِی حِفاظت کریندے ہَاسے(٨٢)۔
  21,83,اَتے اَیُوب (دِی ڳالھ اِیں ہے) جو ڄَݙاں اُوں اَپݨیں رَبّ کُوں سَݙیا جو میکُوں مصیبتاں گھیریا ہوئے، اَتے تُوں تاں ساریاں کنُوں وَدّھ تے رحم کرݨ والا ہیں(٨٣)۔
  21,84,ٻَس اَساں اُوندی دُعا قبول کر گِھدّی اَتے اُوکُوں جِہڑیاں مُصیبتاں گھیریا ہوئیا ہا، اُنھاں کُوں ہَٹا ݙِتّا، اَتے اُوکُوں اُوندے گَھر والے (وَلا) ݙِتے، اَتے اُوہو جِتّی ٻئے وِی ݙِتے، اَساݙی طرفُوں اِیہ ہِک مہربانی ہَئی، اَتے اِیہ عبادت کرݨ والیاں کِیتے یاد رَکھݨ دِی ڳالھ ہے(٨٤)۔
  21,85,اَتے اِسمٰعیل تے ادریس تے ذوالکفل (دِی ڳالھ اِیں ہے) جو اِیہ سارے ثابت قَدم رَہݨ والیاں وِچُوں ہَن(٨٥)۔
  21,86,اَتے اَساں انھاں کُوں اَپݨیں رحمت وِچ داخل کر گِھدّا بیشک او ٻَہُوں نیک لوکاں وِچُوں ہِن(٨٦)۔
  21,87,اَتے مَچّھی والے (یُونس) دِی ڳالھ اِیں ہے، جو ڄَݙاں او کَوڑِیج تے چَلیا ڳیا، اُوں سَمجھیا، جو اَساں اُوندے اُتّے کوئی پَکڑ نہ کریسُوں، ٻَس وَل اُوں اَندھارے (مَچّھی دے پیٹ) وِچُوں سَݙ ماریا جو بیشک کوئی عِبادت دے ݙا دَا کائے نھیں، سِوائے تیݙے، کِیُوں جو تُوں (عیبُوں) پاک ہیں، بیشک مَیں وَݙا قصور کرَݨ والیاں وِچُوں ہَاں(٨٧)۔
  21,88,ٻَس اَساں اُوندی دُعا قبول کر گِھدّی اَتے اُوکُوں غَم کنُوں نِجات ݙے ݙِتی، اَتے اِیویں اَساں اِیمان والیاں کُوں بَچا گِھندے ہَیں(٨٨)۔
  21,89,اَتے زِکریا (دِی ڳالھ اِیں ہے) جو ڄَݙاں اُوں آپݨیں رَبّ کُوں سَݙیا، جو میݙے رَبّ آ، میکُوں کَلّھا (لاوارثا) نہ چھوڑ، تُوں تاں ساریاں کنُوں چَن٘ڳا وَلی وارث ہیں(٨٩)۔
  21,90,ٻَس اَساں اُوندی دُعا وِی قبول کر گِھدّی، اَتے اَساں اُوکُوں یحیٰی ݙِتا، اَتے اُوندی ذال کُوں اُوندے کِیتے ٹِھیک ٹَھاک کر ݙِتا، بیشک اِیہ لوک نیکی دے کَمّاں کُوں بھڄ دُھرک تے کریندے ہَن، اَتے اَساکُوں اُمیداں نال تے خُوف نال وِی سَݙیندے ہَن، اَتے اَساݙے اَڳُوں عاجزی کریندے ہِن(٩٠)۔
  21,91,اَتے اُوں مَئی (مَریم) (دِی ڳالھ اِیں ہے) جو اُوں اَپݨِیں حَیا (ننگیج) دِی ٻَہُوں حِفاظت کِیتی رَکّھی ہَئی، تاں اَساں اُوندے اَندر اَپݨِیں روح دَا پُھوکا ماریا، وَل اُوکُوں اَتے اُوندے پُتر کُوں دُنیا جہاں دے لوکاں کِیتے ہِک نِشانی بَݨایا(٩١)۔
  21,92,بیشک تُہاݙی اِیہا اُمّت اِی ہِکّی اُمّت ہے، اَتے مَیں تُہاݙا سَب دَا پالَݨ ہَار ہَاں، ٻَس میݙی عِبادت کِیتی کرو(٩٢)۔
  21,93,اُنھاں لوکاں خود آپݨیں ہِک ہُووݨ کُوں آپس وِچ ٹوٹے ٹوٹے کر ݙِتا، اَتے ہَر کوئی اَساں دو رَجوع کرݨ (وَل آوَݨ) والا ہے(٩٣)۔
  21,94,ٻَس جِہڑا شَخص نیک عَمل کریسے، اَتے او اِیمان والا وِی ہوسے، تاں اُوندی (نیکی دی) کوشش دِی بے قَدری نہ تِھیسے، اَتے بیشک اَساں اُوندے ناں لِکھدے ویندے ہَیں(٩٤)۔
  21,95,اَتے اِیہ مُمکن کوئے نھیں، جو جِہڑی وَستی (آبادی) کُوں اَساں برباد کر چھوڑے او ضرور وَل آوے(٩٥)۔
  21,96,اِیہ توڑِیں جو یاجُوج تے ماجُوج کُوں کُھول ݙِتا ویسے، اَتے او ہَر اُچّی جا کنُوں بَھڄ تے نِکل آسِن(٩٦)۔
  21,97,اَتے سَچے وعدے دا وقت نیڑے لڳݨ پُوسے، تاں اَچا چیت اُنھاں لوکاں دِیاں اَکّھیں جِنھاں کُفر اِختیار کِیتے (ݙَر کنُوں) پُٹّھیاں تِھی ویسِن، اَکھیسِن، ہائے شَامت اَساݙِی! جو تحقیق اَساں اِیں کنُوں غافِل تِھی ڳئے ہَاسے بلکہ اَساں اَپݨیں آپ اُتے ظلم کِیتی رَکھیئے(٩٧)۔
  21,98,بیشک تُساں اَللہ کُوں چھوڑ تے جِنھاں دِی بَندگی کریندو، او سارے دَوزخ دَا ٻَل بݨسُو، تُساں اِیندے وِچ داخِل تِھی رَہسُو(٩٨)۔
  21,99,جیکر اِیہے خُدا ہُوندے تاں دَوزخ وِچ اَصلُوں نہ ویندے، اَتے سارے اُوندے وِچ ہمیشہ رَہسِن(٩٩)۔
  21,100,اُوندے وِچ اُنھاں دا چِیکَݨ ٻَاکَݨ اِتّی ہوسی، جو او کُجھ وِی نہ سُݨ سَڳسِن(١٠٠)۔
  21,101,بیشک او لوک جِنھاں دے متعلق اَساݙِی طرفُوں پہلے بَھلائی دَا فیصلہ تِھی چُکیا ہوسی، اِیں (دَوزخ) کنُوں پَرے رَکھیئے ویسِن(١٠١)۔
  21,102,او اِیندا کِھسکار تَئیں نہ سُݨ سَڳسِن، اَتے او آپݨیں پَسند دِیاں جائیں وِچ ہمیشہ کِیتے رَہسِن(١٠٢)۔
  21,103,اُوں ٻَہُوں گَھبراہَٹ ویلے وِی، او اَصلُوں پریشان نَہ تِھیسِن، اَتے فرشتے بَھڄ تے آ مِلسِن (اَکھیسِن) اِیہ ہے تُہاݙا او ݙین٘ہ جِیندا تُہاݙے نال وَعدہ کِیتا ویندا ہَا(١٠٣)۔
  21,104,جِہڑے ݙین٘ہ اَساں اَسمان کُوں اِیویں وَلھیٹ گِھنسُوں جِیویں لِکھیاں ہوئیاں کانگاں کُوں وَلھیٹ گِھدّا ویندے، اَساں جَیں طرح پہلے پہلے مخلوقات کُوں پَیدا کِیتا ہَا، اِیویں اُوکُوں وَلا پَیدا کر ݙیسُوں، اِیہ وَعدہ اَساکُوں پُورا کرݨیں، بیشک اَساں ضرور پُورا کرݨ والے ہَیں(١٠٤)۔
  21,105,اَتے اَساں نصیحت والی کِتاب (توریت) دے بعد زُبور وِچ لِکھ ݙِتا ہَاسے جو بیشک میݙے نیک بَندے زمین دے وارث ہوسِن(١٠٥)۔
  21,106,بیشک اِیں (قرآن) وِچ عِبادت کرݨ والے بَندیاں کِیتے ہِک سَنیہا پُچایا ڳئے(١٠٦)۔
  21,107,اَتے (اَے رسول) اَساں تیکُوں سارے جہاناں کِیتے رحمت بَݨا تے بھیڄے(١٠٧)۔
  21,108,آکھ ݙے جو میݙے کولھ اِیہا وَحی کِیتی ڳئی ہے، جو بیشک تُساں ساریْاں دا معبود اُوہو ہِکّو معبود ہے، وَل کیا تُساں اُوندے فرمانبردار (مسلمان) بݨئے ہوئے ہِیوے(١٠٨)۔
  21,109,جیکر اِیہ مُن٘ہ پھیر گِھنّن، تاں آکھ ݙے، جو مَیں تاں تُساں ساریاں کُوں ٹِھیک ٹِھیک خَبردار کر ݙِتے، پَر میکُوں اِیہ پَتہ کائے نھیں، جو جِہڑی شَئے دَا تُہاݙے نال وَعدہ کِیتا ہوئے، او کُولھُوں آڳئی ہے، یا اَڄَݨّ پَرے ہے(١٠٩)۔
  21,110,بیشک او چَن٘ڳی طَرح ڄاݨدے، جِہڑی کوئی ڳالھ اُچّی آواز وِچ ٻُلیندے وے اَتے اُوکُوں وِی ڄاݨدے جِہڑی لُک تے کریندے وے(١١٠)۔
  21,111,پَر مَیں اِیہ نھیں ڄاݨدا جو شاید اِیہ تُہاݙے کِیتے کوئی اَزمائش ہُووے، اَتے کُجھ وَقت تَئیں دُنیاوی مَزّے کرݨ دَا موقع ݙِتا ویندا پِیا ہُووے(١١١)۔
  21,112,آخر آکھیُس، میݙے رَبّ آ ! تُوں حَقّی فیصلہ کر چھوڑ (اَے لوکو) اَساݙا رَبّ سَب تُوں زیادہ مہربان ہے، جہڑا اَساݙی مَدد کریندے انھاں ڳالھیں دے خلاف جِہڑیاں تُساں کریندے وَدّے وے(١١٢)۔
