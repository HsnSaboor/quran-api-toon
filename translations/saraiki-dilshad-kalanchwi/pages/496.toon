quran[18{c,v,t}:
44,1,حٰمٓ (١)۔
44,2,قَسم ہے اِیں صاف بیان کر ݙیوَݨ والی کتاب دِی (٢)۔
44,3,بیشک اَساں اِیکُوں ہِک بَرکتاں والی رَات وِچ نازِل کِیتے، بیشک اَساں (بُرے اَنجام کنُوں) ݙراوݨ چِتاوَݨ والے ہَیں (٣)۔
44,4,اِیں رات وِچ ہَر معاملہ وݙی حکمت نال طَے کِیتا ویندے (٤)۔
44,5,جِیندا حُکم اَساݙی طرفُوں تِھیندے، بیشک اَساں اِی (رسول) بھیڄݨ والے ہَیں (٥)۔
44,6,اِیہ تیݙے رَبّ دِی طرفُوں رحمت دے طور تے ہِن، بیشک او چَن٘ڳی طرح سُݨݨ والا سَب کُجھ ڄاݨݨ والا ہے (٦)۔
44,7,او اَسماناں دا مالک ہے، زمین دا وِی، تے جو کُجھ اُنھاں دے اَدّھ وِچ ہے، اُوندا وِی! شَرط اِیہ ہے جو تُساں واقعی یقین کرݨ والے ہووُو! (٧)۔
44,8,کوئی ٻِیا معبود کائے نھیں سِوائے اُوندے، او تاں جِیویندا وِی ہے تے مار وِی چھوڑیندے، اُوہُو تُہاݙا وِی رَبّ ہے تُہاݙے پہلے والے پِیو ݙاݙیاں دا وِی رَبّ ہے (٨)۔
44,9,بیشک او شَک وِچ کُݙاکڑیاں (ٹَپولیاں) وَدّے مریندِن (٩)۔
44,10,اَچھا اُوں ݙین٘ہ دا اِنتظار کرو، ڄَݙاں جو اَسمان کنُوں ظاہر ظہور دُھوں مَچ آسی(١٠)۔
44,11,جِہڑا لوکاں کُوں وَلھیٹ گِھنسِی، ٻَس اِیہ ہِک دَرد ناک عذاب ہے (١١)۔
44,12,(اَکھیسِن) اَساݙے رَبّ آ ! تُوں اَساں کنُوں اِیں عذاب کُوں ہَٹا گِھن یقینی طور تے اَساں اِیمان گِھن آوَݨ والے ہَیں (١٢)۔
44,13,پَر اُنھاں کُوں نصیحت کِتُّھوں فائدہ ݙیوݨ لڳی ہے حالانکہ اُنھاں کولھ صاف صاف بیان کرݨ والا پیغمبر وِی آچُکیئے (١٣)۔
44,14,وَل اُوں کنُوں وِی پِھر ڳئے اَتے آکھݨ لڳئیے، جو اِیہ تاں سِکھیا پڑھیا ہویا کوئی پاڳل ہے (١٤)۔
44,15,تحقیق اَساں تھوڑا جیہا عذاب ہَٹا ݙیوُوں، تاں وِی تُساں وَل پہلی حالت تے آویسُو (١٥)۔
44,16,جِہڑے ݙین٘ہ ٻَہُوں وَݙی پَکڑ وِچ گِھن آسُوں، تاں اَساں تُساں کنُوں اَصلُوں اِنتقام گِھنّݨ والے بݨ ویسُوں (١٦)۔
44,17,اَتے تحقیق اَساں انھاں کنُوں پہلے فِرعون دِی قوم کُوں آزما چُکئے ہَاسے، اُنھاں کولھ وَݙیاں عِزّتاں، کرامتاں والا رسول وِی آیا (١٧)۔
44,18,(آکھیُس) جو اَللہ دے بندیاں کُوں میݙے حوالے کر ݙیوُو، بیشک مَیں تُہاݙے کِیتے وَݙا اَمانت دار رسول ہَاں (١٨)۔
