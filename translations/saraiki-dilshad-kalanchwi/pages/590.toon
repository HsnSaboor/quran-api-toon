quran[22{c,v,t}:
85,1,قَسم ہے بُرجاں والے اَسمان دِی(١)
85,2,اَتے اُوں ݙِین٘ہ دِی جِیندا وَعدہ کِیتا ہویا ہے(٢)۔
85,3,اَتے ݙیکھݨ والے دِی، اَتے جو ݙِٹَّھا ویسے، اُوندی وِی(٣)
85,4,ماریے ڳئے بھا دَا ٹویا کَھٹَّݨ والے(٤)
85,5,جِیندے وِچ ڈھیر سارے ٻالݨ نال بَھڑکدی ہوئی بھا ہے(٥)
85,6,جِہڑے ویلے او بَھا دے ٹویے اُتُّوں ٻیٹھے ہوئے ہن(٦)
85,7,اَتے او جِہڑا کُجھ اِیمان والیاں نال کریندے پَے ہَن، اُوکُوں خُود سامݨیں ݙیکھدے پَے ہِن(٧)۔
85,8,اَتے اُنھاں دِی دُشمنی ٻَئی کہیں وَجّہ کنُوں کائے نَہ ہَئی، سِوائے اِیندے جو او اَللہ تے اِیمان گِھن آئے ہن، جِہڑا ٻَہُوں زبردست ہے، سَب تعریفاں والا ہے(٨)
85,9,او تاں اُوپو ہے جِیندی بادشاہی ہے اَسماناں دِی تے زمین دِی، اَتے اَللہ ہَر شَئے اُتّے حاضر ناظر ہے(٩)
85,10,تحقیق جِنھاں لوکاں مومن جُواناں تے مومن ذالیں کُوں ٻَہُوں ݙُکھ ݙِتّے ہِن، وَت تَوبہ وِی نھیں کِیتی، ٻَس اُنھاں کِیتے دَوزخ دَا عَذاب وِی ہے، اَتے سَڑدے رَہݨ دا ذاب وِی(١٠)عَ
85,11,بیشک جِہڑے لوک اِیمان گِھن آئِن، اَتے نیک عَمل کِیتے ہِینے اُنہاں کیتے بَہشتی باغ ہِن جِنھاں تَلّے نہراں وَہندیاں وَڳدِیاں پِیاں ہوسن، اِیہا تاں ہے، وَݙّی کامیابی(١١)۔
85,12,یقیناً تیݙے رَبّ دِی پَکڑ ݙَاڈھی سخت ہے(١٢)
85,13,یقیناً اُوپو پہلی واری وِی پَیدا کریندے، تے وَلا وِی جِیوا کَھڑا کریندے(١٣)۔
85,14,اُوپو ہے بَخشݨ ہار، ݙَاڈھا پِیار رَکھݨ والا(١٤)
85,15,او عَرش دا مالک ہے، وَݙیاں شاناں والے دا(١٥)۔
85,16,ٻَس کر چھوڑیندے جو کُجھ چَہندے(١٦)
85,17,کیا تیݙے کولھ لَشکراں دِی خَبر پُنّی ہے(١٧)
85,18,فرعون دِیاں وِی، تے ثمود دِیاں وِی(١٨)۔
85,19,بلکہ جِنھاں لوکاں کُفر اِختیار کِیتے، او کُوڑ آکھݨ وِچ لڳئے ہوئے ہِن(١٩)
85,20,اَتے اَللہ اُنھاں کُوں پِچُّھوں کنُوں گھیرے وِچ گَھتّیا ہوئے(٢٠)
85,21,بلکہ اِیہ قرآن تاں وَݙیاں شاناں والا ہے(٢١)۔
85,22,جِہڑا اُوں لوح وِچ موجود ہے جِہڑی ٻَہُوں محفوظ ہے(٢٢)۔
