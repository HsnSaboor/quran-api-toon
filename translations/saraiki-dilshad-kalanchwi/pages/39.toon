quran[8{c,v,t}:
2,238,اَتے آپݨیاں نمازاں دِی پابندی کرو، خاص کر درمیانی نماز (عصر) دِی، اَتے اللہ دے سامݨیں عاجزی تے فرمانبرداری نال کھڑے تھیئے کرو (٢٣٨)۔
2,239,جیکر تُہاکوں کوئی ݙر ݙُکّل ہووے، تاں پیدل یا سواری دی حالت وِچ (نماز پڑھ گِھدّی کرو) وَل جِہڑے ویلے اَمن تے اطمینان دِی حالت وِچ ہووُو، تاں اللہ دا ذکر اُوں طرح کِیتا کرو جَئیں طرح تُہاکُوں سکھایا ڳئے ، پر جیکوں تُساں (پہلے) نہ ڄاݨدے ہاوے (٢٣٩)۔
2,240,اَتے او لوک جِہڑے تُہاݙے وِچوں مَر وَن٘ڄݨ تے آپݨیاں ذالیں پِچھُّوں چھوڑ وَن٘ڄن، آپݨیاں ذالیں کِیتے سال کھن دا خرچ خیال ݙیوݨ تے گھروں نہ کݙّھݨ دِی وصیت کر وَن٘ڄݨ، پر اُوویں او گھروں چلیاں وَن٘ڄن ، تے آپݨیں کِیتے عام دستور (شرع) دے مطابق کوئی چن٘ڳا کَم کر گِھنّن تاں تُہاݙے اُتے کوئی ذمہ داری کائے نھیں، اللہ ٻَہُوں زبردست تے وَݙی دانائی والا ہے (٢٤٠)۔
2,241,اَتے مطلقہ (چُھٹِّل) ذالیں کُوں مناسب طور تے خرچ خیال ݙیوݨاں چاہیدا ہے، متقی لوکاں اُتے اِیہ وِی ہِک حق (فرض) بݨدے (٢٤١)۔
2,242,اِیں طرح اللہ تُہاݙے کِیتے آپݨیں اَحکامات کھول پاڑ تے بیان کریندے تاں جو تُساں سَمجھݨ والے بݨو (٢٤٢)۔
2,243,کیا تُساں اُنھاں لوکاں کوں نھیں ݙٹھا جِہڑے محض موت دے ݙر کنُوں آپݨیاں گھراں وِچوں نِکل ڳئے ہَن، اَتے او ہَن وِی ہزاراں دِی تعداد وِچ ! ٻَس اللہ اُنہاں کِیتے آکھیا! جو تُساں مر اِی وَن٘ڄو ! وَل اُنھاں کُوں جِیوا وِی چھوڑیا، بے شک اللہ لوکاں اُتے ٻَہُوں فضل کرݨ والا ہے پر ڈھیر سارے لوک اُوندے نا شُکرے ہِن (٢٤٣)۔
2,244,اَتے تُساں اللہ دِی راہ وِچ جہاد (جنگ) کرو، اَتے ڄاݨ گِھنو، جو اللہ ہر ڳالھ دے سُݨݨ والا تے ڈھیر کُجھ ڄاݨݨ والا ہے (٢٤٤)۔
2,245,ہے کوئی اِہجیا شخص جِہڑا اللہ کُوں کوئی سوہݨاں قرضہ ݙیوے، تاں جو او اُوندے کِیتے اُوکوں کئی واری وَدھا چڑھا چھوڑے اَتے اللہ اِی روزی کُوں ٻَدھ گِھندے، تے کھول ݙیندے، اَتے تُساں ہُوں دو وَلائے ویسو (٢٤٥)۔
