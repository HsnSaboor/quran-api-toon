quran[9{c,v,t}:
40,41,اَتے اَے میݙی قوم! میکوں سَمجھ نھیں پَئی آندی، جو مَیں تاں تُہاکُوں نِجات والے پاسے سݙینداں، اَتے تُساں میکُوں (دَوزخ دِی) بھا والے پاسے سݙیندے وے (٤١)۔
40,42,تُساں میکوں اِیں ڳالھ دِی دعوت ݙیندو، جو مَیں اَللہ دا اِنکار چَا کراں، اَتے اُنھاں کُوں اُوندا شریک چَا بݨاواں، جِنھاں دا میکُوں کوئی عِلم وِی کائے نھیں، حالانکہ مَیں تُہاکوں ٻَہُوں زبردست تے بیحد بخشݨ ہار دو سݙیندا پِیاں (٤٢)۔
40,43,بِلا شَک تُساں میکُوں اِہجے دو سݙیندے وے جِہڑے کُوں نہ اِیں دُنیا وِچ تے نہ آخرت وِچ سَݙݨ دِی کوئی جاء (مناسبت) ہے، اَتے بیشک اَساں اَللہ دو وَل وَن٘ڄݨیں، تے بیشک حد کنُوں ٹَپ وَن٘ڄݨ والے دوزخ دِی بھا وِچ رَہݨ والے ہِن (٤٣)۔
40,44,ٻَس البتہ تُساں یاد کریسو، جِہڑا کُجھ مَیں تُہاکُوں اَہدا پِیاں، مَیں اَپݨاں معاملہ اَللہ دے حوالے کر ݙینداں بیشک اَللہ آپݨیاں ٻانھیاں دا خیال رَکھݨ والا ہے (٤٤)۔
40,45,ٻَس اَللہ (مُوسیٰ) کُوں بچا گِھدّا اُنھاں بُرائیاں (مصیبتاں) کنُوں جِہڑیاں وی او چال چَلدے ہَن، اَتے فرعون دِی قوم کُوں ٻَہُوں گندے عذاب وَلھیٹ گِھدّا (٤٥)۔
40,46,او عذاب ہِک اِہجی بھا ہے، جِیندے سامݨیں اُنھاں کُوں سویر کُوں وِی تے شام کُوں وِی پیش کِیتا ویندا رَہسے، اَتے قیامت دے قائِم تِھیوَݨ والے ݙین٘ہ وِی! (حُکم تِھیسے جو) فِرعون دِی قوم کُوں سخت عذاب وِچ سَٹ ݙیوُو (٤٦)۔
40,47,اَتے (خیال کرو) ڄݙاں او (دَوزخ دِی) بھا وِچ ہِک ٻئے نال تکرار بازی کریسِن، ٻَس ہیݨیں لوک وَݙائیاں کرݨ والے لوکاں کُوں اَکھیسِن، بِلا شَک اَساں تُہاݙی پَیروی کریندے ہاسے، کیا اَساݙے نال بھا دا کُجھ حِصّہ وَن٘ڈا گِھندے وے (٤٧)۔
40,48,جِہڑے جو مَغریے ہوئے ہِن، او اَکھیسِن (ݙیکھدے نِھیوے جو) اَساں تُساں سارے اِیں عذاب وِچ ہَیں، دَر اَصل اَللہ آپݨیاں بَندیاں دے درمیان فیصلہ کر چھوڑے (٤٨)۔
40,49,اَتے جِہڑے (دوزخ دِی) بھا وِچ ہوسِن، او دَوزخ دے چوکیداراں کُوں اَکھیسِن، جو آپݨیں رَبّ کنُوں دُعا مَنگو، جو اَساں کنُوں عذاب دا ݙِینہ تاں گَھٹا ݙیوے (٤٩)۔
