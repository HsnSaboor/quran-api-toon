quran[28{c,v,t}:
74,48,ٻَس نہ نفع ݙے سَڳی اُنھاں کُوں سِفارش کرݨ والیاں دِی سِفارش (٤٨)۔
74,49,آخر اِنھاں لوکاں کُوں کِیا تِھی ڳئے جو او نصیحت کنُوں مُن٘ہ پھِریندِن چَا (٤٩)۔
74,50,اِیویں لَڳدے جو او چَھرکے ہوئے ڳَݙاں ہِن (٥٠)
74,51,جِہڑے شِین٘ہ کنُوں (ݙَر تے) ٻَھڄ پَیئِن (٥١)۔
74,52,بلکہ اِنھاں وِچُوں ہَر شَخص اِیہ چَہندے جو اُوندے ہَتّھ وِچ کُھلّے ہوئے صَحیفے (کِتابچے) ݙے ݙِتے وَن٘ڄِن (٥٢)
74,53,۔ اَصلُوں کائے نہ، بلکہ او تاں آخرت کنُوں وِی نِھیں ݙَردے (٥٣)
74,54,اَصلُوں کائے نہ! اِیہ تاں ہِک نصیحت ہے (٥٤)۔
74,55,لَہٰذا جو کوئی چَہوے اِیں کنُوں نصیحت حاصل کرے (٥٥)۔
74,56,بلکہ اِیں کنُوں کوئی نصیحت حاصل نہ کریسِن، سِوائے اُنھاں دے جِنھاں دے اَللہ چَہسی، اُوہو تاں ہے جیں کنُوں ݙَریا وَن٘ڄے تے جِہڑا بَخش ݙیوݨ والا ہے (٥٦)۔
75,1,ڳالھ اِیں کائے نھیں، مَیں قَسم چینداں قیامت دے ݙین٘ہ دِی (١)۔
75,2,وَت وِی ڳالھ اِیں کائے نھیں، مَیں قَسم چینداں مَلامت کرݨ والے نَفس دِی (٢)۔
75,3,کیا اِنسان اِیہ سَمجھدے جو اَساں (اُوندے مَرݨ دے بعد) اُوندیاں ہَݙّیاں وَلا کائے نہ جوڑ سَڳسُوں (٣)۔
75,4,کِیُوں کائے نہ! بلکہ اَساں تاں اِیں ڳالھ دِی قُدرت وِی رَکھیندے ہَیں جو اُوندیاں اَنگلیں دے ݙوݙے تَیئں کُوں جوڑ تے ٹِھیک چَا کریسُوں (٤)۔
75,5,بلکہ اِنسان تاں اِیہ چَہندے جو او آئندہ وِی بَد عَملیاں کریندا رَہے (٥)۔
75,6,او تاں پُچھدے جو قیامت دا ݙین٘ہ آسی کَݙاں؟ (٦)۔
75,7,ٻَس ڄَݙاں عانیں اُپتریج (پُٹّھے تِھی) ویسِن (٧)۔
75,8,چَندر دَا سوجھلا نَہ رَہسی (٨)۔
75,9,اَتے سِجھ تے چَندر کُوں کَٹھا کر گِھدّا ویسی (٩)۔
75,10,اُوں ݙین٘ہ اِنسان پُچّھسے وَدَّا جو بَھڄَݨ دا رَاہ وِی ہے کِتھاؤں؟(١٠)۔
75,11,ہَر گز کائے نہ، پَناہ دِی کوئی جَاء نَہ لَبھسی(١١)۔
75,12,اُوں ݙین٘ہ ٻَس تیݙے رَبّ کولھ اِی جاء ٹِکاݨاں لَبھسی (١٢)۔
75,13,اُوں ݙین٘ہ اِنسان کُوں ݙَسا ݙِتا ویسی، جِہڑا کُجھ اُوں اَڳُوں کِیتے بھیڄیا ہوئے، اَتے جِہڑا کُجھ (اَثرات) چھوڑ آئے (١٣)۔
75,14,بلکہ اِنسان تاں خُود اِی اَپݨیں آپ کُوں چَنڳی طَرح ڄاݨدا ہے (١٤)۔
75,15,چاہے او عُذر بہانے کِیُوں نہ پیش کرے (١٥)۔
75,16,اَے رسول) تُوں اِیں واسطے آپݨیں زبان کُوں اِتنی نَہ پِیا چول جو تُوں اِیں (وحی) کُوں جَلدی جَلدی یاد کر گِھنّیں (١٦)۔
75,17,بیشک اَساݙے ذِمّے ہے اِیندا کَٹَّھا کر تے جوڑَن، تے اِیندا پَڑھاوَݨ (١٧)۔
75,18,ٻَس ڄَݙاں اَساں اِیکُوں پَڑھُوں تاں تُوں وِی اِیکُوں اُوویں پَڑھیا کر (١٨)۔
75,19,وَل بیشک اِیندا مَطلب کھول تے بیان کر ݙیوݨ وِی اَساݙے ذِمّے ہے (١٩)
