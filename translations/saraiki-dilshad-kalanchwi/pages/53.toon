quran[3]{c,v,t}:
  53,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  53,1,قَسم ہے تارے دِی ڄَݙاں او لَہ ویندے (١)۔
  53,2,نہ تُہاݙا سَنگتی رَاہ وَن٘ڄائی وَدّے، اَتے نہ او رَاہ کنُوں تھڑکیا ہویا ہے (٢)۔
  53,3,اَتے نہ اَپݨِیں مرَضی دے مطابق ٻُولیندے (٣)۔
  53,4,اِیہ تاں محض ہِک وَحی ہے، جہڑی اُوندے اُتّے نازِل تِھیندی ہے (٤)۔
  53,5,اُوکُوں ٻَہُوں قُوّت والے سِیکھائے (٥)۔
  53,6,او وَݙی شان تے سَمجھ والا ہے ٻَس او اَصلُوں سامݨیں آ کھڑے (٦)۔
  53,7,اَتے او اَسمان دِی اُچّی کَنّی تے ہَا (٧)۔
  53,8,او نزدیک آیا، وَت اَصلُوں نزدیک تِھی ڳیا (٨)۔
  53,9,او ݙُوں کماناں دے فاصلے جِتّی کولھوں آڳیا، یا اُوں کنُوں وِی گَھٹ (٩)۔
  53,10,اِیں طرح ٻَس اُوں آپݨیں بندے دو وَحی پُچائی، جِہڑی وِی پُچاوݨِیں ہَئی (١٠)۔
  53,11,ٻَس اُوندے دِلّ وِچ تاں کوئی کُوڑ نھیں رَلایا (١١)
  53,12,اِیہُو ہے جو کُجھ اُوں ݙِٹّھے جِہڑا کُجھ اُوں اَکّھیں نال ݙِٹّھے، کیا تُساں اُوندے وِچ وِی جھیڑا گَھتیندے وے (١٢)۔
  53,13,اَتے تحقیق اُوں اُوکُوں ہِک واری لَہݨ ویلے وَلا وِی ݙِٹّھے (١٣)۔
  53,14,اُوں ٻیر دے کولھ جِہڑی پَرلی حَد اُتّے ہَئی (١٤)۔
  53,15,اُوندے کولھُوں (آرام نال) رَہݨ کِیتے بہشت ہے (١٥)۔
  53,16,ڄَݙاں جو اِیں ٻیر کُوں اُوں شَئے کَڄیا ہوئیا ہَا ، جِہڑی شَئے کَڄیندی ہے (١٦)۔
  53,17,اُوندی نَظر وِچ نہ کوئی پھیر گھیر ہَا، اَتے نہ او اَپݨِیں حَد کنُوں اَڳُوں تے وَدّھی ہَئی (١٧)۔
  53,18,تحقیق اُوں آپݨیں رَبّ دِیاں وَݙیاں وَݙیاں نِشانیاں ݙِٹھیاں (١٨)۔
  53,19,کیا بَھلا تُساں لات تے عُزّی کُوں (غور نال) ݙِٹّھے (١٩)۔
  53,20,اَتے انھاں دے اَخیر والے تریجھے منات کُوں وِی (٢٠)۔
  53,21,کیا تُہاݙے کِیتے پُتر ہِن، تے اُوندے کِیتے دِھیّاں ہِن (٢١)۔
  53,22,اِیہ وَن٘ڈارا تاں ٻَہُوں بے اِنصافی والا ہے (٢٢)۔
  53,23,اِیہ تاں اِیویں ناں اِی ناں ہِن، جِہڑے تُساں تے تُہاݙے پِیؤ ݙاݙیاں رَکّھ گِھدّن، جِنھاں دے متعلّق اَللہ تاں کوئی سَند (دلیل) نھیں بھیڄی، اِیہ لوک پَیروی کریندِن تاں محض وَہم دِی کریندِن، اَتے جِہڑا کُجھ اُنھاں دا جِی چَہندے اُوندی، تے تحقیق اُنھاں کولھ اُنھاں دے رَبّ دِی طرفُوں ہِدایت وِی آچُکی ہے (٢٣)۔
  53,24,کیا اِنسان واسطے ہُوں شَئے دا حق ہے، جِہڑی وِی او چَہوے (٣٤)۔
  53,25,ٻَس اَللہ دے ہَتّھ وِچ ہے آخرت تے دُنیا جہان (٢٥)۔
  53,26,اَتے اَسماناں وِچ کِتنے سارے فرشتے ہِن، پَر اُنھاں دِی سِفارش کُجھ وِی فائدہ نھیں ݙے سَڳدی، ٻَس سِوائے اُوندے جیکُوں اَللہ چَہوے اِجازت ݙیوے، تے راضی وِی ہُووے (٢٦)۔
  53,27,بیشک جِہڑے لوک آخرت اُتّے اِیمان نھیں گِھن آندے او فرشتیاں دے ناں ذالیں (دیویاں) دے نان٘واں اُتّے رَکھ گِھندِن (٢٧)۔
  53,28,حالانکہ اُنھاں کُوں اِیندے متعلّق کوئی عِلم وِی کائے نھیں او تاں محض آپݨیں وہم گُمان دِی پَیروی کریندے رَہندِن، اَتے اَصل وِچ وَہم و گُمان حق دے مقابلے وِچ کہیں شَئے دا فائدہ نھیں ݙیندا (٢٨)۔
  53,29,ٻَس تُوں مُن٘ہ پھیر گِھن اُوں کنُوں جِہڑا جو اَساݙے ذِکر (نصیحت) کنُوں مُن٘ہ پھیر گِھندے، اَتے او ٻِیا کُجھ نھیں چَہندا سِوائے دُنیاوی زندگی دے (٢٩)۔
  53,30,اِیہا کُجھ ہے اُنھاں دے عِلم دِی آخری حَد! بیشک تیݙا رَبّ چَن٘ڳی طرح ڄاݨدے اُوں شَخص کُوں جِہڑا اُوندے رَاہ کنُوں تُھڑک ویندے، اَتے اُوکُوں وِی چَن٘ڳی طرح ڄاݨدے، جِہڑا ہِدایت اُتّے ہے (٣٠)۔
  53,31,اَتے اَللہ دا اِی ہے جِہڑا ہِدایت اُتّے ہے، اَتے اَللہ دا اِی ہے، جِہڑا کُجھ اَسماناں وِچ تے زمین دے تَلّے اُتّے ہے، تاں جو جِہڑے لوک بُرائیاں کریندِن اُنھاں کُوں اُنھاں دے عَملاں دے مُطابق بَدلہ ݙیوے، اَتے جِہڑے لوک نیکیاں کریندِن، اُنھاں کُوں ٻَہُوں چَن٘ڳا بَدلہ ݙیوے (٣١)۔
  53,32,جِہڑے لوک وَݙے وَݙے گُناہاں کنُوں تے بے حیائی دِیاں ڳالھِیں کنُوں پَرے تَھئے رَہندِن، سِوائے چھوٹیاں خطائیں (غلطیاں) دے! بیشک (اُنھاں کِیتے) تیݙا رَبّ بخشش وِچ وَݙا مکلاݨ رَکھیندے، او تُہاکُوں اُوں وَقت کنُوں چَن٘ڳی طرح ڄاݨدے ڄَݙاں اُوں تُہاکُوں زمین (مِٹی) کنُوں پَیدا کِیتا، اَتے ڄَݙاں تُساں اَڄݨ آپݨیاں ماواں دے پیٹ وِچ لُکیئے وَدّے ہاوے، ٻَس تُساں آپݨیں آپ کُوں پاک صاف نہ پَے آکھو، او تاں چَن٘ڳی طرح ڄاݨدے جو پَرہیزگار کوݨ ہے (٣٢)۔
  53,33,(اَے رسول) کیا تَئیں اُوں شخص کُوں (غور نال) ݙِٹّھے، جِہڑا جو (اَللہ کنُوں) مُن٘ہ پھیر ڳئے (٣٣)۔
  53,34,جیں تھوڑا جیہا (مال) ݙے، تے ہَتھ روکیے چا (٣٤)۔
  53,35,کیا اُوندے کولھ غیب دا عِلم ہے، جو او (حَق کُوں) ݙیکھ گِھندے (٣٥)۔
  53,36,کیا اُوکوں (اُنھاں ڳالھیں دِی) خبر نھیں ݙِتی ڳئی جِہڑیاں مُوسیٰ دِیاں صحیفیاں (چھوٹیاں کِتاباں) وِچ ہَن (٣٦)۔
  53,37,اَتے اِبراہیم دِی خبر وِی! جیں آپݨاں کَمّ پُورا کر ݙیکھالئے (٣٧)۔
  53,38,کوئی بار چاوَݨ والا کہیں ٻئے دا بار اَصلُوں نھیں چیندا (٣٨)۔
  53,39,اَتے اِیہ جو اِنسان کِیتے کُجھ وِی کائے نھیں، سِوائے اُوندے جِیندے کِیتے او محنت کریندے (٣٩)۔
  53,40,اَتے اِیہ جو ٻَہُوں جَلدی اُوندی محنت کُوں جَانچیا پَرکھیا ویسی (٤٠)۔
  53,41,وَل اُوکُوں اُوندا پُورا پُورا بَدلہ ݙِتا ویسی (٤١)۔
  53,42,اَتے بیشک آخیر تیݙے رَبّ دے کولھ اِی پُڄݨیں (٤٢)۔
  53,43,اَتے بیشک او کِھلویندا وِی ہے، تے رُوویندا وِی ہے (٤٣)۔
  53,44,اَتے بیشک اُوہو مریندا وِی ہے، تے جِیویندا وِی ہے (٤٤)۔
  53,45,اَتے یقیناً اُوں نَر تے مادی دے جوڑے پَیدا کِیتے ہِن (٤٥)۔
  53,46,ہِک نُطفے (تریڑے) کنُوں جِہڑا جو گھتیا ویندے (٤٦)۔
  53,47,اَتے بیشک ݙُوجھی واری وَلا پَیدا کرݨ وِی اُوندے ذِمّے ہے (٤٧)۔
  53,48,اَتے یقیناً اُوہو (کہیں کُوں) دولتمند بݨیندے تے پُوری طرح رَڄا ݙیندے (٤٨)۔
  53,49,اَتے بیشک اُوہو شعریٰ (تارے) دَا رَبّ ہے (٤٩)۔
  53,50,اَتے بیشک اُوں عَاد دِی پہلی قَوم کُوں تباہ کر چھوڑیا (٥٠)۔
  53,51,اَتے ثمود کُوں وِی! ٻَس اُوندا کُجھ وِی باقی نہ چھوڑیس (٥١)۔
  53,52,اَتے اِیں کنُوں پہلے نُوح دِی قَوم کُوں وِی! دَراَصل او ٻَہُوں ظالم تے وَݙے سَرکش ہَن (٥٢)۔
  53,53,اَتے مُوندِھیاں ݙَہݨ والیاں وَستیاں کُوں وِی چَا ماریُس (٥٣)۔
  53,54,ٻَس اُنھاں کُوں اُوں شَئے کَڄ گِھدّا، جیں کَڄݨاں ہَا (٥٤)۔
  53,55,وَل تُوں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت دے متعلق لَڑدا جَھگڑدا رَہسیں (٥٥)۔
  53,56,اِیہ وِی ہِک ݙَراوَݨ چِتاوَݨ والا ہے، پہلے والے ݙَراوَݨ چِتاوَݨ والیاں وِچُوں (٥٦)۔
  53,57,کولھوں آ وَن٘ڄݨ والی کولھوں آڳئی ہے (٥٧)۔
  53,58,اَللہ دے سِوا ٻِیا کوئی اِیکُوں نھیں ٹَال سَڳدا (٥٨)۔
  53,59,کیا وَل وِی تُساں اِیں کلام اُتّے تعجب کریندے وے (٥٩)۔
  53,60,اَتے کِھلّاں کریندے وے، روندے نِھیوے (٦٠)۔
  53,61,ڳِچّی اَکڑا تے (غفلت وِچ) وَدّے ہِیوے (٦١)۔
  53,62,ٻَس سَجدے کرو اَللہ اَڳُوں ، اَتے اُوندی عِبادت کِیتی کرو (٦٢)۔
