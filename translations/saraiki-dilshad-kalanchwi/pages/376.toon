quran[21{c,v,t}:
26,207,تاں اُنھاں دے کہیں کَمّ وِی نہ آسِن، جِہڑے فائدے او (زِندگی وِچ) چا کَھڑسِن(٢٠٧)۔
26,208,اَتے اَساں کہیں وَستی کُوں وِی تَباہ نھیں کِیتا، جے توڑِیں جو اُوندے کِیتے ݙَراوَݨ والے نَہ بھیڄے ہُووِن(٢٠٨)۔
26,209,نصیحت وِی کریندوں، اَساں تاں ظُلم کَرݨ والے کائے نِسّے(٢٠٩)۔
26,210,اَتے اِیکُوں شَیطان گِھن تے نَھیں لَتّھے(٢١٠)۔
26,211,او اِیں لائق ہِن وِی کائے نَہ، اَتے نَہ او اِیہ کَمّ کر سَڳدِن(٢١١)۔
26,212,بیشک اُنھاں کُوں اِیندے سُݨݨ کنُوں وِی ہِک پاسے کر ݙِتا ڳئے(٢١٢)۔
26,213,ٻَس (اَے رسول) اَللہ دے نال کہیں ٻئے کُوں اَصلُوں نَہ سَݙ نَہ تاں تُوں وِی عَذاب وِچ آوَںڄݨ والیاں وِچُوں تِھی ویسیں(٢١٣)۔
26,214,اَتے اَپݨیں سَوڑے سَکّیاں کُوں ݙَرا سَمجھا(٢١٤)۔
26,215,اَتے اُنھاں نال چَن٘ڳا خُلق وَن٘ڈی رَکّھ، جِنھاں اِیمان گِھن آوَݨ والیاں وِچُوں تیݙی پَیروی اِختیار کِیتی ہوئی ہے(٢١٥)۔
26,216,ٻَس جیکر او تیݙی نافرمانی کرِن، تاں آکھ ݙے، جو میݙا ذِمّہ کائے نھیں جو تُساں کریندے وَدّے وے(٢١٦)۔
26,217,اَتے ہُوندے اُتّے توکّل کر، جِہڑا جو ٻَہُوں زَبردست تے ہمیشہ رحمت وَساوَݨ والا ہے(٢١٧)۔
26,218,جِہڑا تیکُوں ݙیکھدا کَھڑے جیں ویلے (نَماز کِیتے) کَھڑا تِھی کَھڑدیں(٢١٨)۔
26,219,اَتے سَجدے کرَݨ والیاں وِچ تیݙے پھیرے مارݨ کُوں وِی(٢١٩)۔
26,220,بیشک او سَب کُجھ سُݨݨ والا تے چَن٘ڳی طرح ڄاݨݨ والا ہے(٢٢٠)۔
26,221,کیا مَیں تُہاکُوں ݙَساواں جو شیطان کِیندے اُتّے لَہندِن(٢٢١)۔
26,222,اِیہ تاں ہَر کُوڑ مارݨ والے بَد کردار اُتّے لَہندِن(٢٢٢)۔
26,223,اِیہ سُݨیاں سُݨائیاں ڳالھیں اُنھاں کُوں آ ݙَسیندِن، اَتے اُنھاں دے ڈھیر کُوڑ مارَݨ والے ہِن(٢٢٣)۔
26,224,اَتے شاعر؟ انھاں دِی پَیروی تاں گُمراہ لوک اِی کریندِن(٢٢٤)۔
26,225,کیا تَیں نھیں ݙِٹَّھا جو او (خیالاں) دِی ہَر وادی وِچ سِر مریندے وَدّے ہِن(٢٢٥)۔
26,226,اَتے دَراصل او اُوہو کُجھ اَکھیندِن جِہڑا کریندے وِی نھیں(٢٢٦)۔
26,227,سِوائے اُنھاں لوکاں دے جِہڑے جو اِیمان گِھن آئِن اَتے نیک عَمل کِیتئن، اَتے اَللہ دَا ذِکر وِی ٻَہُوں کریندے رِیہِن، اَتے بَدلہ گِھدّے تاں او وِی اَپݨیں اُتّے ظلم تِھی وَن٘ڄݨ دے بعد، اَتے اَجھو پَتہ لَڳ ویسے اُنھاں لوکاں کُوں جِنھاں ظلم کِیتے، جو او کِہجی وَل وَن٘ڄݨ والی سَخت جاء تے وَل ویسِن(٢٢٧)۔
