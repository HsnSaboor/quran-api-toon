quran[24{c,v,t}:
51,7,اَتے اَسمان دِی قَسم! جِیندے وِچ کَئی رَاہِیں ہِن (٧)۔
51,8,تُساں یقیناً ہِک اِختلاف والی ڳالھ وِچ پَھتّھے ہوئے ہِیوے (٨)۔
51,9,اِیں ڳالھ کنُوں اُوہو شَخص پِھر ویندے جیں پِھرݨاں ہوندے (٩)۔
51,10,اَٹکل پَچُّو لَڑاوَݨ والے تَباہ تِھیوِن (١٠)۔
51,11,اِیہ تاں او لوک ہِن، جِہڑے غفلت وِچ پے تے (حقیقت کُوں) بُھل چُکیئے ہِن (١١)۔
51,12,اِیہ پُچّھدِن جو جَزا سَزا وَالا ݙین٘ہ کَݙاں آسی (١٢)۔
51,13,اُوں ݙین٘ہ (آسی) ڄݙاں اُنھاں کُوں (دَوزخ دِی بھا) اُتّے سیک ݙِتا ویسی (١٣)۔
51,14,(آکھیا ویسی) ہُݨ چَکُّھو مَزّہ آپݨیں فِتنے (دے عذاب) دَا ، اُوہو عذاب جِیندے متعلّق تُساں ݙَاڈھے اُٻَہلے ہَاوے (١٤)۔
51,15,بیشک پَرہیزگار لوک بَہشتی باغاں وِچ ہوسِن تے چَشمیاں اُتّے رَہسِن (١٥)۔
51,16,انھاں نعمتاں کُوں گِھن تے خوش تِھیندے رَہسِن، جِہڑیاں اُنھاں دا رَبّ اُنھاں کُوں ݙیندا ویسی، یقیناً او اِیں کنُوں پہلے نیک کَمّ کرݨ والے ہَن (١٦)۔
51,17,او رات کُوں ٻَہُوں تھوڑی دیر سُمھدے ہِن (١٧)۔
51,18,اَتے دَھمّی ویلے گُناہاں دِی بخشش مَنگدے ہن (١٨)۔
51,19,اَتے اُنھاں دے مال متال وِچ مَن٘گ تے گِھنّݨ والیاں دا تے محرومی دے شِکار تِھی وَن٘ڄݨ والیاں دَا حق وِی ہوندا ہَا (١٩)۔
51,20,اَتے زمین وِچ نِشانیاں ہِن یقین کرݨ والیاں کِیتے (٢٠)۔
51,21,اَتے خود تُہاݙے اَندر وِی! وَل وِی تُساں ݙیکھدے کِیُوں نھیں؟ (٢١)۔
51,22,اَتے اَسمان وِچ ہے تُہاݙا رِزق ، اَتے او کُجھ وِی جِیندا تُہاݙے نال وَعدہ کِیتا ویندے (٢٢)۔
51,23,ٻَس اَسماناں تے زمین دے رَبّ دِی قسم! جو بیشک اِیہ (قرآن) بَرحق ہے بالکل اُوویں جیں طرح جو تُساں ٻولیندے پَے ہِیوے (٢٣)۔
51,24,(اَے رسول) کیا تیݙے کولھ اِبراہیم دے عزّتاں والیاں مہماناں دِی ڳالھ پُنّی ہے (٢٤)۔
51,25,ڄَݙاں جو او اُوندے کولھ آئے، ٻَس اَکھیُونے، تیکُوں سلام ہووے اُوں وِی آکھیا (تُہاکُوں وِی) سَلام ہووے (٢٥)۔
51,26,(پَر اِیہ) اَݨ سُونھیں نظریے، وَل وِی او (چُپ کر تے) آپݨیاں گَھراں والیاں دو وَل ڳیا (٢٦)۔
51,27,ٻَس ہِک موٹا تازہ بُھنّیا تَلیا ہویا گابا چَوا تے آ ڳیا (٢٧)۔
51,28,ٻَس او اُنھاں کنُوں دِل وِچ ݙَرݨ لَڳیا، اُنھاں آکھیا، (اَساں کنُوں) نہ پِیا ݙَر، اَتے اُوکُوں ہِک ٻَہُوں عِلم والے پُتر دِی بشارت ݙِتی (٢٨)۔
51,29,ٻَس اُوندی، ذال ٻَہُوں حیران تِھی تے اَڳُوں تے تَھئی، وَل اَپݨیں مَتّھے تے زور دا ہَتھ ماریا اَتے آکھیُس (مَیں تاں) ٻُڈھی سنڈھ (ذال) ہَاں (٢٩)۔
51,30,اُنھاں آکھیا، اِیویں تِھیسے، اِیہ تاں میݙے رَبّ آکھیئے، بیشک او ٻَہُوں حِکمت (دانائی) والا ہے سَب کُجھ ڄاݨݨ والا ہے (٣٠)۔
