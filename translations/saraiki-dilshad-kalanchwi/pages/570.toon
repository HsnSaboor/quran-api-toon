quran[15{c,v,t}:
70,40,مَیں (اَللہ) مَشرق تے مغرب والے ساریْاں پاسیْاں دے رَبّ دِی قَسم چَا تے اَکھینداں، جو واقعی اَساں اِیں ڳالھ تے قَادر ہَیں جو (٤٠)۔
70,41,انھاں دِی جاء تے انھاں کنُوں چَنڳے لوک گِھن آؤں، اَتے اَساکُوں بے وَسّ اَصلُوں نھیں کِیتا وَن٘ڄ سَڳدا (٤١)۔
70,42,ٻَس تُوں اُنھاں کُوں چھوڑیندا کر، تاں جو او فضول ڳالھِیں تے کھیݙ کھوݙ وِچ لڳئے رہِن، او توڑِیں جو اِیہ آپݨاں او ݙین٘ہ ݙیکھ گِھنِّن،! جِیندا اِنھاں نال وَعدہ کِیتا ویندا ہے (٤٢)۔
70,43,اُوں ݙین٘ہ اِیہ آپݨیاں قَبراں وِچُوں جَلدی جَلدی نِکل تے اِیں طرح ٻَھڄسِن جِیویں جو او اَپݨیاں بُتاں دے ٹِکاݨیاں دو بَھڄدے ویندے ہووِن (٤٣)۔
70,44,اُنھاں دِیاں نَظراں جِھکّیاں تھیاں ہوسِن، ذلّت اُنھاں کُوں وَلھیٹیا ہویا ہوسے، اِیہُو ہے او ݙین٘ہ جِیندا اُنھاں نال وَعدہ کِیتا ویندا رَہندے (٤٤)۔
71,1,یقیناً اَساں نُوح کُوں اُوندی قَوم دو بھیڄیا جو آپݨیں قَوم کُوں خَبردار کر ݙے اِیں کنُوں پہلے جو اُنھاں اُتّے دَرد ناک عَذاب آ وَن٘ڄے (١)۔
71,2,اُوں آکھیا اَے میݙی قَوم! یقیناً مَیں تُہاݙے کِیتے صاف صاف ݙَراوَݨ چِتاوَݨ والا ہَاں (٢)۔
71,3,اِیہ جو اَللہ دِی عبادت کِیتی رَکّھو ، اَتے اُوں کنُوں ݙَردے رَہوو، تے میݙا آکھیا مَنّیا کرو (٣)۔
71,4,او تُہاݙے کِیتے تُہاݙے گُناہاں کُوں بَخش ݙیس ے اَتے تُہاکُوں (مَوت دے) مقررہ وَقت توڑِیں مُہلت ݙِتّی رَکھسے (مَوت والا) مقررہ وَقت ڄَݙاں آویندے تاں وَت اُوندے وِچ دیر نھیں کِیتی ویندی اِیویں ہوندا جو تُساں اِیں ڳالھ کُوں ڄاݨدے ہوندے (٤)۔
71,5,اُوں آکھیا، میݙے رَبّ آ، یقیناً مَیں آپݨیں قَوم کُوں رَات کُوں وِی تے ݙین٘ہ دَا وِی سَݙی رَکھیئے (٥)۔
71,6,پَر میݙے سݙیے نے اُنھاں اُتے ٻِیا کوئی اَثر نھیں کِیتا سِوائے اِیں ڳالھ دے جو او (دِین کنُوں) ٻِیا وِی پَرے بَھڄ وَن٘ڄِن (٦)۔
71,7,اَتے تحقیق مَیں ڄَݙاں وِی اُنھاں کُوں سَݙیے (جو تَیں دو آوِن) تاں جو تُوں اُنھاں کُوں بَخش ݙیویں، اُنھاں تاں آپݨیاں اَنگلیں کَنّاں وِچ ݙے ݙِتیاں اَتے آپݨیاں کَپڑیاں کُوں (مُن٘ہ) تے وَلھیٹ گِھدّا وَݙی ضِد کِیتی اَتے تکبّر وِی کِیتا تاں او وِی ٻَہُوں وَݙا جیہا کِیتا (٧)۔
71,8,وَل تحقیق مَیں اُنھاں کُوں سَݙݨ وِچ زور لائی رَکھیا (٨)۔
71,9,وَل وی تحقیق مَیں اُنھاں کُوں کُھلّے بندیاں سمجھایا تے اُوڈھر کر تے وِی اُنھاں کُوں آکھیا، جِیویں اُوڈھر کر تے اَکھیندے (٩)۔
71,10,ٻَس مَیں آکھیا، جو تُساں آپݨیں رَبّ کنُوں بخشش مَنگو، تحقیق او تاں ٻَہُوں بَخشݨ ہار ہے (١٠)۔
