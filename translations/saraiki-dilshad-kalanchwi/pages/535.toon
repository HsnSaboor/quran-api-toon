quran[34{c,v,t}:
56,17,اُنھاں دے اِیݙُوں اُوݙُوں ہمیشہ نینگر رَہݨ والے چُھوہَر، ٹُردے پِھردے ہوسِن (١٧)۔
56,18,اُنھاں کولھ آبخورے (مِٹی دے بغیر دَستے دے برتن) تے صُراحیاں ہوسِن، اَتے وَہندے ہوئے شراب دے چَشمیاں وِچُوں ہَتّھ وِچ بھرے ہوئے پِیالے ہوسِن (١٨)۔
56,19,نہ اِیندی وَجّہ کنُوں اُنھاں دے سِر چَکراسِن، تے نہ اُنھاں دے عقل وِچ کوئی فتُور آسے (١٩)۔
56,20,اُتے اُوہو جیہے میوے ہوسِن، جیہو جیہے او چَہسِن (٢٠)۔
56,21,اَتے اُنھاں پَکّھیاں دا گوشت ہوسی، جِہڑے اُنھاں کُوں بھاسِن (٢١)۔
56,22,اَتے سُوہݨِیاں اَکّھیں والیاں حُوراں ہوسِن (٢٢)۔
56,23,جہڑیاں لُکا تے رَکھئے ہوئے موتیاں وَانگُوں ہوسِن (٢٣)۔
56,24,اِیہ بَدلہ ہوسی اُنھاں دے عَملاں دَا جِہڑے او کریندے رِیہے ہوسِن (٢٤)۔
56,25,اَتے او اُتّھاں کوئی بیہُودہ ڳالھ تے کوئی گُناہ والی ڳالھ نہ سُݨسِن (٢٥)۔
56,26,سِوائے (ہِک ٻئے کُوں) سَلام، سَلام آکھݨ دے (٢٦)۔
56,27,اَتے سَڄّے پاسُوں والے صاحباں (کیا سَمجھدے وے) او کیا ہوسِن (٢٧)۔
56,28,اُنھاں کِیتے بغیر کَن٘ڈیاں والیں ٻیریں ہوسِن (٢٨)۔
56,29,اَتے ہِک ٻئے نال سَتّھئے ہوئے کیلے (٢٩)۔
56,30,اَتے لمبے لمبے پِچھاویں(٣٠)۔
56,31,اَتے وَہندا وَڳدا پاݨِیں (٣١)۔
56,32,اَتے ڈھیر سارے میوے (٣٢)۔
56,33,جِہڑے خَتم تِھیوݨ کُوں نہ آسِن اَتے نہ اُنھاں کنُوں رُوکیا ویسے (٣٣)۔
56,34,اَتے اُچّے دَرجیاں والے وِچھاوݨیں (فرش) ہوسِن (٣٤)۔
56,35,یقیناً اَساں ذالیں وِی پَیدا کِیتِن، چَن٘ڳی طرح بݨا سَنوار تے (٣٥)۔
56,36,ٻَس اَساں اُنھاں کُوں کنواریاں رَکھیے (٣٦)۔
56,37,پیاں دِیاں پیاریاں تے ہِکّو ڄیݙی عُمراں والیاں (٣٧)۔
56,38,اِیہ سَڄّے پاسے دو رَہݨ والیْاں کِیتے ہِن (٣٨)۔
56,39,انھاں دِی ہِک وَݙّی ٹولی پہلیْاں وچُوں ہوسی (٣٩)۔
56,40,اَتے ہِک وَݙّی ٹولی پِچھلیْاں وِچُوں ہوسی (٤٠)۔
56,41,اَتے کَھٻّے پاسے والے لوک (شامت دے ماریے) کَھٻّے پاسے والیْاں دِی کیا حالت ہوسی (٤١)۔
56,42,او تَتّی لُو وِچ رَہسِن، اُنھاں کِیتے گَرم پاݨِیں ہوسی (٤٢)۔
56,43,اُتّھاں کالے دُھوں والے پِچھاویں ہوسِن (٤٣)۔
56,44,نہ کوئی ٹَھاڈل ہوسی، نہ کوئی عِزّت تے آرام ہوسی (٤٤)۔
56,45,یقیناً او اِیں کنُوں پہلے سَوکھے سَوّلّے پَلدے رِیہن (٤٥)۔
56,46,تے وَݙے وَݙے گُناہاں وِچ جُتّے ہوئے رِیہن (٤٦)۔
56,47,اَتے اِیہ اَکھیندے ہَن، جو کیا ڄَݙاں اَساں مَر ویسُوں تے مِٹی تے ہَݙیاں تِھی تے رَہ ویسُوں، تاں کیا یقیناً اَساں وَت اُٹھا کھڑے کِیتے ویسُوں (٤٧)۔
56,48,اَتے کیا اَساݙے پہلے والے پِیو ݙاݙے وِی (اُٹھا کھڑے) کِیتے ویسِن (٤٨)۔
56,49,(اَے رسول) آکھ ݙے جو بیشک پہلے والے تے آخر والے سارے دے سارے (٤٩)۔
56,50,ہِک مقرر تَھئے ہوئے ݙین٘ہ دے موقع تے کَٹّھے کِیتے ویسِن (٥٠)۔
