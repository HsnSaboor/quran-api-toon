quran[27{c,v,t}:
89,24,او اَکھیسے، ہائے میݙی شَامت اَللہ اِیویں کرے ہَا جو مَیں آپݨِیں اِیں زِندگی کِیتے وِی پہلے کنُوں کُجھ بھیڄیا ہوندا(٢٤)۔
89,25,ٻَس اُوں ݙین٘ہ نہ کوئی اُوں جیہاں عَذاب ݙیسی، نہ اُوں جیہا کوئی ٻِیا عذاب ݙیوݨ والا ہوسی(٢٥)۔
89,26,اَتے نہ اُوں جیہا پَکّڑ وِچ گِھن آوَݨ والا ٻِیا کوئی ہے(٢٦)
89,27,وُوئے اِطمینان (تَسلَّا) ݙِیواوَݨ وَالا نَفس آ (٢٧)
89,28,تُوں آپݨیں رَبّ دو وَل ڄُلّ، توں اُوندے نال راضی تھی او تیݙے نال راضی تھیسے(٢٨)
89,29,وَت تُوں میݙیاں نیک بندیاں وِچ ڄُل رَہ(٢٩)
89,30,اَتے میݙی بَہشت وِچ وَڑ ڄُلّ(٣٠)
90,1,ڳالھ اِیں کائے نھیں! مَیں قَسم چینداں اِیں شہر دِی1١
90,2,اَتے تُوں اِیں شہر دا شہری ہیں(٢)
90,3,اَتے قَسم ہے، پِیؤ دِی اَتے اُوندی جِہڑی اَولاد اُوں ڄَݨی(٣)
90,4,تحقیق اَساں اِنسان کُوں تکلیفاں اَوکھائیاں وِچ ڄَمائے(٤)
90,5,پَر کیا او سَمجھدے جو اُوں (سَخت جان) اُتّے کوئی قابو نہ پاَ سڳسِی(٥)
90,6,او آہدے جو مَیں مال دے ڈھڳ دے ڈھڳ لُٹا چُھوڑئِن(٦)
90,7,کیا او خَیال کریندے جو اُوکُوں کوئی وِی نھیں ݙِہدا کَھڑا(٧)
90,8,کیا اَساں اُوندے کِیتے ݙُوں اَکّھیں نھیں بَݨائیاں(٨)
90,9,اَتے زبان اَتے ݙُوں ہُوٹھ(٩)
90,10,اَتے اَساں اُوکُوں ݙُوہائیں (خَیر تے شَر دے) رَستے ݙِیکھا ݙَسا ݙِتِّن(١٠)۔
90,11,ٻَس اُوں گھاٹی اُتُّوں چَڑھ تے لَنگھݨ دِی ہِمّت نھیں کِیتی(١١)
90,12,اَتے تیکُوں کیا پَتہ جو او گھاٹی (تے چَڑھݨ والی رَاہ) کیا ہے(١٢)
90,13,اِیہ غُلامی کنُوں کہیں دِی گَردن چُھڑاوَݨ ہے(١٣)
90,14,یا بھک دے ݙین٘ہ کہیں کُوں روٹی کَھواوَݨ ہے(١٤)۔
90,15,کہیں یتیم کُوں جِہڑا سَکّا وِی ہُووے(١٥)
90,16,یا کہیں مِٹی دھوڑ تَھئے ہوئے مِسکین فقیر کُوں(١٦)
90,17,تَݙاں او شَخص اُنھاں لوکاں نال وَںڄ رَلسے جِہڑے اِیمان گِھن آئِن، اَتے ہِک ٻئے کُوں نصیحت کریندِن ثابت قَدم رَہݨ دِی، اَتے وَصیّت کریندِن ٻِنھاں تے رَحم کرݨ دِی(١٧)۔
90,18,-اِیہے لوک ہِن، سَڄّے پاسے والے (نیک بَخت( ١٨ ۔
90,19,اَتے جِنہاں لوکاں اَساݙیاں آیاتاں کنُوں اِنکار کر ݙِتے، اِیہے لوک ہِن، بَد بَخت (شامت دے ماریے)(١٩))۔
90,20,اُنھاں اُتّے ہَر پاسُوں موری بَند کِیتی ہوئی بھا ہوسی! (٢٠)۔
