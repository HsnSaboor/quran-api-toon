quran[11{c,v,t}:
41,1,حٰمٓ (١)۔
41,2,اِیہ ٻَہُوں مہربان تے ہَمیشہ رحمت کرݨ والے اَللہ دِی طرفُوں لَتّھی ہوئی (کتاب) ہے (٢)۔
41,3,اِیں کتاب دِیاں آیاتاں کھول کھول تے بیان کِیتیاں ڳیاں ہِن، اِیہ عربی زبان وِچ دا قرآن ہے، اُوں قوم کِیتے جِہڑی جو کُجھ عقل رَکھیندی ہے (٣)۔
41,4,خوشخبری ݙیوݨ والا وِی ہے تے ݙراوَݨ، چِتاوَݨ والا وِی! ٻَس انھاں وِچُوں ڈھیر کنھائیں اِیں کنُوں مُن٘ہ پھیر گِھدّے، بلکہ او اِیکُوں سُݨدے وِی نھیں (٤)۔
41,5,اَتے انھاں اِیہ آکھیا، جو اَساݙے دِل اُوں شَئے کنُوں غلافاں وِچ وَلھیٹے ہوئے ہِن، جَیں دو تُوں اَساکوں سݙیندیں، اَتے اَساݙے کَنّاں وِچ ٻوڑ ہے، اَتے اَساݙے تیݙے درمیان ہِک پَردہ سَٹیا ہوئے، ٻَس تُوں آپݨاں عَمل کر، اَساں وِی آپݨاں عَمل کریندے ہَیں (٥)۔
41,6,(اَے رسول) آکھ ݙے جو مَیں تُساں وَانگُوں بشر ہاں، مَیں دو وحی آئی ہے جو بیشک تُہاݙا معبود تاں ہِک دا ہِک ہے، ٻَس اُوندے سِدّھے رَاہ تے قائم رَہُو، اَتے ہُوں کنُوں بخشش مَن٘ڳو، اَتے شامت ہے شِرک کرݨ والیاں تے (٦)۔
41,7,جِہڑے جو زکوٰۃ وِی نھیں ݙیندے تے آخرت دا وِی انکار کریندِن (٧)۔
41,8,بیشک جِہڑے لوک اِیمان گِھن آئِن تے نیک عَمل وِی کِیتے ہِینے اُنھاں کِیتے نہ مُکّݨ والا اَجر (بدلہ) ہے (٨)۔
41,9,(اَے رسول) آکھ ݙے، جو کیا تُساں اُوں ہَستی دَا اِنکار کریندو، جَیں زمین ݙوں ݙِین٘ہاں وِچ پَیدا کِیتی، اَتے تُساں اُوندے شریک بݨیندے وے، او تاں ساریاں جہاناں دا مالک ہے (٩)۔
41,10,تے اُوں زمین اُتے اِیں کنُوں اُچّے پہاڑ بݨا کھڑائِن، اَتے اِیندے وِچ برکت گَھت ݙِتی ہِس، تے اِیندیاں پَیداواری صلاحیتاں (قوّتاں) محض چار ݙین٘ہاں وِچ مقرر کر گِھدئِن، جِہڑیاں ضرورت والیاں کِیتے پُوریاں پُوریاں ہِن (١٠)۔
41,11,وَل اُوں اَسمان والے پاسے توجہ کِیتی جِہڑا اُوں وقت محض دُھوں ہَا، ٻَس اُوں اُوکُوں تے زمین کُوں آکھیا، تُساں ݙوہائیں وجود وِچ آوَن٘ڄُو، بھاویں چَہوُو تے بھاویں نہ چَہوُو! ݙُوہائیں آکھیا، اَساں ݙوہائیں فرمانبردار بݨ تے آ ڳئے ہَیں (١١)۔
