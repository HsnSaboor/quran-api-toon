quran[24{c,v,t}:
55,17,او ݙُوہائیں مشرقاں والے تے ݙوہائیں مغرباں والے پاسیاں دَا مالِک ہے (١٧)۔
55,18,بھلا تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(١٨)۔
55,19,اُوں ݙُوں اِہجے سَمندر بݨا چھوڑے ہِن، جِہڑے ہِک ٻئے نال رَلیے ہوئِن (١٩)۔
55,20,پَر اُنھاں دے اَدّھ وِچکار ہِک رُکاوَٹ ہے ، ٻَس او ہِک ٻئے دے پاسے نھیں چَڑھدے (٢٠)۔
55,21,بھلا تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢١)۔
55,22,اَتے اُنھاں وِچُوں سچّے موتی تے کُوڑے موتی (گھونگھے سِپّیاں) نِکلدِن (٢٢)۔
55,23,ٻَس تُساں ݙوہائیں (جِنُّو تے اِنسانو) آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢٣)۔
55,24,اَتے ہُوندیاں ہِن سَمندر وِچ (پہاڑاں وَانگُوں) اُچّے بادباناں والیاں ٻیڑیاں (٢٤)۔
55,25,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢٥)۔
55,26,اِیں (زمین) اُتّے جو کُجھ وِی ہے او فَنا تِھی وَن٘ڄݨ والا ہے (٢٦)۔
55,27,اَتے تیݙے رَبّ دِی ذات اِی باقی رَہسی، جِہڑا ٻَہُوں بُزرگی والا تے وݙی عِزّت والا ہے (٢٧)۔
55,28,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٢٨)۔
55,29,سارے ہُوں کنُوں مَنگدِن، جِہڑے کوئی وِی اَسماناں وِچ ہِن تے زمین دے تَلّے اُتّے ہِن، اَتے او ہَر ݙین٘ہ نویں شان وِچ ہوندے (٢٩)۔
55,30,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٠)۔
55,31,اَے (زمین دَا بار بݨی ہوئی) مخلوقاتو اَجھو اَساں تُہاݙے حِساب کتاب گِھنّݨ کِیتے فارغ تِھی ویسُوں (٣١)۔
55,32,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٢)۔
55,33,اے جِنّاں تے اِنساناں دِیاں ٹولیاں! جیکر تُساں اِیہ طاقت رَکھیندو جو تُساں اَسماناں تے زمین دِیاں حَدّاں بنّیاں کنُوں ٹَپ تے کِتھائیں نِکل سڳدو، تاں وَل نِکل ݙیکھالو! تُساں تاں نِکل وِی نھیں سڳدے، سِوائے کہیں وَݙے زور (غلبے) دے (٣٣)۔
55,34,ٻَس تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٤)۔
55,35,تُساں ݙُوہائیں اُتّے بَھا دے شُعلے سَٹّیے ویسِن، تے (ڳچّی گُھٹّݨ والا) دُھوں (ہوسی) اَتے تُساں ݙُوہائیں مقابلہ وِی نہ کر سَڳسو (٣٥)۔
55,36,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٦)۔
55,37,بھلا ڄَݙاں اَسمان چِریج ویسے، وَت رَتّے رَنگ والے چَم وانگیں تِھی ویسے (او ہولناک ݙین٘ہ ہوسے) (٣٧)۔
55,38,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٣٨)۔
55,39,بھلا اُوں ݙین٘ہ اُنھاں دے گُناہاں دے متعلّق پُچھݨ دِی ضرورت وِی نہ پوسی، نہ اِنساناں کنُوں تے نہ جِنّاں کنُوں (٣٩)۔
55,40,بھلا تُساں ݙوہائیں آپݨیں رَبّ دِی کِہڑی کِہڑی نعمت کُوں کُوڑا اَکھیسو(٤٠)۔
