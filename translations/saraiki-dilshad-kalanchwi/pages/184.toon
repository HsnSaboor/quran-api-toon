quran[9{c,v,t}:
8,53,اِیہ (اِیں ڳالھوں وِی) ہے جو در حقیقت اَللہ کہیں نعمت کُوں نھیں بدلیندا، جِہڑی اُوں کہیں قوم کُوں ݙِتی ہوندی ہے جے توڑیں او خُود آپݨیں آپ کُوں نہ بَدل چھوڑن اَتے بیشک اَللہ سَب کُجھ سُݨݨ والا تے ڄاݨݨ والا ہے (٥٣)۔
8,54,فرعون دِی قوم وان٘گوں اَتے انھاں لوکاں وان٘گوں جِہڑے جو انھاں کنُوں پہلے تِھی گزرے ہِن، انھاں وِی آپݨیں رَبّ دِیاں آیاتاں کُوں کُوڑا آکھیئے ٻَس انھاں کُوں انھاں دے گناہاں دِی وجہ کنُوں مِٹا چھوڑیا اَتے فرعون دِی قوم کُوں غرق کر چھوڑیا، اَتے او سارے ظلم کرݨ والے لوک ہَن (٥٤)۔
8,55,بیشک اَللہ دے نزدیک زمین تے چَلݨ والی ساری مخلوقات وِچوں بَد ترین او لوک ہِن جِنھاں کُفر اِختیار کِیتے وَل او اِیمان وِی نھیں گِھن آندے (٥٥)۔
8,56,(خاص کر) او لوک جِنھاں نال تَیں معاہدہ کِیتے، ہر واری اَپݨیں معاہدے کنُوں پِھر ویندِن، اَتے او (اِیں ڳالھ کنُوں) ݙردے وِی نھیں (٥٦)۔
8,57,جیکر تُوں انھاں کُوں جنگ وِچ قابو کر گِھنّیں، تاں انھاں کُوں او مار ݙیوُو، جو بعد دے آوَݨ والیاں کُوں وِی ݙرا بھڄا ݙیوے، تے او عِبرت (نصیحت) حاصل کرن (٥٧)۔
8,58,اَتے جیکر تیکوں معاہدے وِچ کہیں قوم دے ہیر پھیر کرݨ دا ݙر لڳئے، تاں انھاں دا معاہدہ برابری دے طور تے (اِعلانیہ) انھاں دے مُن٘ہ تے مارو ، بیشک اَللہ دَغا بازی کرݨ والیاں کُوں پَسند نھیں کریندا (٥٨)۔
8,59,اَتے او لوک جِنھاں کُفر اختیار کِیتے، اِیہ خیال نہ کرِن جو او اَڳوں تِھی ڳئِن، بیشک او اَپݨیاں چالاں نال اَساکوں عاجز نھیں کر سَڳدے (٥٩)۔
8,60,اَتے تُساں جِتّی تِھی سڳے، اپݨیں قوت، اَتے ٻَدھے کھڑے تیار گھوڑیاں دے لحاظ نال انھاں دے مقابلے کِیتے تیاری کِیتی رَکھو، تاں جو تُساں اِنھاں نال اَللہ دے دشمناں کُوں تے اَپݨیں دشمناں کُوں اَتے انھاں کنُوں علاوہ کوں وِی ݙرا سَڳو، تُساں تاں اِنھاں کُوں نھیں ڄاݨدے، اَللہ تاں انھاں کُوں خُوب ڄاݨدے، اَتے اَللہ دے رَاہ تے جِہڑا کُجھ وی خرچ کریسو، تُہاکوں اُوندا پُورا پُورا اَجر ݙِتا ویسی، اَتے تُہاݙا حق نہ ماریا ویسی (٦٠)۔
8,61,اَتے جیکر او صلح کرݨ دو جُھک آوِن، تاں تُوں وِی صُلح کِیتے جُھک وَن٘ڄ اَتے اللہ اُتے بھروسہ کر، بیشک او چَن٘ڳی طرح سُݨݨ والا تے ڄاݨݨ والا ہے (٦١)۔
