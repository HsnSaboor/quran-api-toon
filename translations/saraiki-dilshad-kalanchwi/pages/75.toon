quran[3]{c,v,t}:
  75,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  75,1,ڳالھ اِیں کائے نھیں، مَیں قَسم چینداں قیامت دے ݙین٘ہ دِی (١)۔
  75,2,وَت وِی ڳالھ اِیں کائے نھیں، مَیں قَسم چینداں مَلامت کرݨ والے نَفس دِی (٢)۔
  75,3,کیا اِنسان اِیہ سَمجھدے جو اَساں (اُوندے مَرݨ دے بعد) اُوندیاں ہَݙّیاں وَلا کائے نہ جوڑ سَڳسُوں (٣)۔
  75,4,کِیُوں کائے نہ! بلکہ اَساں تاں اِیں ڳالھ دِی قُدرت وِی رَکھیندے ہَیں جو اُوندیاں اَنگلیں دے ݙوݙے تَیئں کُوں جوڑ تے ٹِھیک چَا کریسُوں (٤)۔
  75,5,بلکہ اِنسان تاں اِیہ چَہندے جو او آئندہ وِی بَد عَملیاں کریندا رَہے (٥)۔
  75,6,او تاں پُچھدے جو قیامت دا ݙین٘ہ آسی کَݙاں؟ (٦)۔
  75,7,ٻَس ڄَݙاں عانیں اُپتریج (پُٹّھے تِھی) ویسِن (٧)۔
  75,8,چَندر دَا سوجھلا نَہ رَہسی (٨)۔
  75,9,اَتے سِجھ تے چَندر کُوں کَٹھا کر گِھدّا ویسی (٩)۔
  75,10,اُوں ݙین٘ہ اِنسان پُچّھسے وَدَّا جو بَھڄَݨ دا رَاہ وِی ہے کِتھاؤں؟(١٠)۔
  75,11,ہَر گز کائے نہ، پَناہ دِی کوئی جَاء نَہ لَبھسی(١١)۔
  75,12,اُوں ݙین٘ہ ٻَس تیݙے رَبّ کولھ اِی جاء ٹِکاݨاں لَبھسی (١٢)۔
  75,13,اُوں ݙین٘ہ اِنسان کُوں ݙَسا ݙِتا ویسی، جِہڑا کُجھ اُوں اَڳُوں کِیتے بھیڄیا ہوئے، اَتے جِہڑا کُجھ (اَثرات) چھوڑ آئے (١٣)۔
  75,14,بلکہ اِنسان تاں خُود اِی اَپݨیں آپ کُوں چَنڳی طَرح ڄاݨدا ہے (١٤)۔
  75,15,چاہے او عُذر بہانے کِیُوں نہ پیش کرے (١٥)۔
  75,16,اَے رسول) تُوں اِیں واسطے آپݨیں زبان کُوں اِتنی نَہ پِیا چول جو تُوں اِیں (وحی) کُوں جَلدی جَلدی یاد کر گِھنّیں (١٦)۔
  75,17,بیشک اَساݙے ذِمّے ہے اِیندا کَٹَّھا کر تے جوڑَن، تے اِیندا پَڑھاوَݨ (١٧)۔
  75,18,ٻَس ڄَݙاں اَساں اِیکُوں پَڑھُوں تاں تُوں وِی اِیکُوں اُوویں پَڑھیا کر (١٨)۔
  75,19,وَل بیشک اِیندا مَطلب کھول تے بیان کر ݙیوݨ وِی اَساݙے ذِمّے ہے (١٩)
  75,20,۔ اِیہا ڳالھ نَہ ہَئی، بلکہ تُساں تَاں جلدی جَلدی حاصِل تِھی وَن٘ڄݨ والی شَئے (یعنی دُنیا) کُوں پَسند کریندو (٢٠)۔
  75,21,اَتے تُساں آخرت دِی پَرواہ وِی نھیں کریندے (٢١)۔
  75,22,اُوں ݙین٘ہ کُجھ شکلاں تاں رونقاں والیاں ہوسِن (٢٢)۔
  75,23,او اَپݨیں رَبّ دا دِیدار کریندیاں پِیاں ہوسِن (٢٣)۔
  75,24,اَتے اُوں ݙین٘ہ کُجھ شَکلاں مُون٘جھیاں مُون٘جھیاں وِی ہوسِن (٢٤)۔
  75,25,او گُمان کریسِن، جو اَساݙے اُتّے چیل تروڑ ݙیوݨ والی کوئی مُصیبت آوݨ لڳی ہے (٢٥)۔
  75,26,اِیں ہَرگز کائے نھیں، جیں ویلے سَاہ (رُوح) نرگھٹ توڑِیں آویسے (٢٦)۔
  75,27,تاں آکھیا ویسی، ہے کوئی دَم کرݨ والا (پُھوکے شُوکے مَارݨ والا) (٢٧)۔
  75,28,اَتے آدمی سَمجھ گِھنسے جو ہُݨ اِتُّھوں ٹُر ڄُلَّݨ دا وَقت آڳے (٢٨)۔
  75,29,اَتے پِنّی نال پِنّی چِمبڑ ویسی (٢٩)۔
  75,30,اِیہُو ہے تیݙے رَبّ دو ہَکلیئے وَن٘ڄݨ دا ݙین٘ہ (٣٠)۔
  75,31,ٻَس اُوکُوں (حقیقت کُوں) نَہ مَنّیا ، تے نہ نَماز پَڑھی (٣١)۔
  75,32,بلکہ (حقیقت کُوں) کُوڑا آکھیا تے مُن٘ہ پھیر گِھدّا (٣٢)۔
  75,33,وَل او اَکڑیندا ہویا آپݨیں گَھر والیاں دو چَلیا ڳِیا (٣٣)۔
  75,34,تیکُوں تاں کَمبختی چِمبڑ ڳئی ہے کَمبختی (٣٤)۔
  75,35,ٻَس تیکُوں تاں کَمبختی چِمبڑ ڳئی ہے کَمبختی (٣٥)۔
  75,36,کیا اِنسان اِیہُو کُجھ گُمان کریندے جو اُوکُوں اِیویں نِکمّا چھوڑ ݙِتا ڳئے (٣٦)۔
  75,37,کیا او ہِک نُطفہ (تریڑا) نَہ ہَا ، جیکُوں پیٹ وِچ گَھتّیا ویندے (٣٧)۔
  75,38,وَل او ہِک گوشت دا لَٻّر جیہا بَݨ ڳیا، وَل اُوندا جُسّہ بݨایا ڳیا، وَل اُوندا ہِک ہِک جوڑ ٹِھیک کر تے پَیدا کر ݙِتا ڳیا (٣٨)۔
  75,39,وَل اُوندیاں ݙُوں قِسماں بݨائیاں ڳئیاں ، نَر تے مادی (٣٩)۔
  75,40,کیا او اِیندے اُتّے قُدرت نھیں رَکھیندا جو مُردیاں کُوں وَلا چَا جِیواوے(٤٠)۔
