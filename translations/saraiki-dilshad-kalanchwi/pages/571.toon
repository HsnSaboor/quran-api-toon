quran[18{c,v,t}:
71,11,او تُہاݙے اُتے اَسمان کنُوں خُوب مِین٘ہ وَسیندا رَہسی (١١)۔
71,12,اَتے تُہاݙی اِمداد کریسی، مال مَݙی نال وِی، تے (ڈھیر ساے) پُتراں نال وِی، اَتے تُہاݙے کِیتے باغ لا ݙیسی، اَتے تُہاݙے کِیتے نہراں وَہا ݙیسی (١٢)۔
71,13,تُہاکُوں کیا تِھی ڳئے، جو تُساں اَللہ دے وَقار (بزُرگی تے عظمت) اُتے اصلُوں یقین نھیں گِھن آندے (١٣)۔
71,14,اَتے تحقیق اُوں تُہاکُوں کئی کئی حالتاں وِچ گِھن آ تے بݨائے (١٤)۔
71,15,کیا تُساں نھیں ݙِٹّھا جو اَللہ نے سَتّ اَسمان ہِک ٻئے دے تَلّے اُتّے (طبقاں وِچ) بݨائِن (١٥)۔
71,16,اَتے اِنھاں وِچ چَندر کُوں نُور بݨائے، اَتے سِجھ کُوں ٻَلدا ݙِیوا بݨائے (١٦)۔
71,17,اَتے اَللہ تُہاکُوں زمین وِچُوں اُوں طرح پَیدا کِیتے جیں طَرح ڄَماوَݨ دا حَق ہوندے (١٧)۔
71,18,وَل آخر تُہاکُوں اِیندے وِچ وَلا وَڑا چھوڑیسے، اَتے تُہاکُوں کَڈھ کَھڑا کریسے، جِیویں کَڈھݨ دا حَق بݨدے (١٨)۔
71,19,اَتے اَللہ نے تُہاݙے کِیتے زمین کُوں (ہِک قِسم دا) فَرش بݨائے (١٩)۔
71,20,تاں جو تُساں اِیندے کُھلّیاں راہِیں اُتّے ٹُرو پِھرّو (٢٠)۔
71,21,او نہ مَنیے تاں) نُوح آکھیا، میݙے رَب آ، بیشک انھاں میݙا آکھیا اَصلُوں نھیں مَنیا، اَتے اُوندی پَیروی کِیتی ہے جِیندے مال وِچ تے جِیندی اَولاد وِچ کوئی وَادھا نھیں تِھیا ، تَھئے تاں گَھاٹا اِی تَھئے (٢١)۔
71,22,اَتے اُنھاں ہِک تدبیر وِی کِیتی تے تدبیر وِی وَݙی کنُوں وَݙی (٢٢)۔
71,23,ہِک ٻئے کُوں) اَکھیُونیں، جو تُساں اَپݨیاں رَبُوبݨیاں کُوں اَصلُوں نہ چھوڑاہے، اَتے وَدّ کُوں، تے سَواع کُوں نہ چھوڑاہے، اَتے یغوث تے یعوق تے نسر کُوں وِی نہ چُھوڑاہے (٢٣)۔
71,24,اَتے تحقیق اُنھاں ٻَہُوں سارے لوکاں کُوں گُمراہ کِیتا ہوئے، اَتے تُوں وِی ظالماں دِی گُمراہی وِچ وَدھارا کِیتی رَکّھ (٢٤)۔
71,25,اُنھاں لوکاں کُوں اُنھاں دِیاں خَطائیں دِی وَجّہ کنُوں غَرق کر ݙِتا ڳیا، وَت او (دَوزَخ دِی) بَھا وِچ گَھت ݙِتے ڳئے، اُنھاں کُوں اَللہ کنُوں سِوا ٻِیا کوئی وِی مَدد کرݨ والا نہ مِلیا (٢٥)۔
71,26,اَتے نُوح آکھیا، میݙے رَبّ آ! کافراں وِچُوں کہیں ہِک کُوں وِی نہ چھوڑیں زمین تے رَہݨ وَسݨ کِیتے (٢٦)۔
71,27,بیشک جیکر تَیں انھاں کُوں چھوڑ ݙِتا، تاں اِیہ تیݙے ٻانھیاں کُوں گُمراہ کِیتی رَکھسِن، اَتے کُفر اِختیار کر گِھنّݨ والے بَد کرداراں کنُوں سِوا ٻِیا کہیں کُوں جݨیسِن پلیسن کائے نہ (٢٧)۔
71,28,میݙے رَبّ آ، میکُوں تے میݙے پِیؤ مَاء کُوں بخش ݙے، اَتے ہَر اُوں شَخص کُوں وِی جِہڑا
