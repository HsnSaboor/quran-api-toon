quran[23{c,v,t}:
26,137,کِیُوں جو اِیہ ڳالھِیں اَڳلے لوک وِی کریندے رِیہِن(١٣٧)۔
26,138,اَتے اَساں او نِسّے جِنھاں کُوں کوئی وِی عَذاب ݙِتا ویسے(١٣٨)۔
26,139,ٻَس اُنھاں اُوکُوں کُوڑا آکھیا، تاں اَساں وِی اُنھاں کُوں غارت کر چھوڑیا، بیشک اِیندے وِچ وِی ہِک نِشانی ہے، پَر اُنھاں دے ڈھیر کوئی اِیمان نھیں گِھن آندے(١٣٩)۔
26,140,اَتے بیشک تیݙا رَبّ تاں ٻَہُوں زبردست ہے تے ہمیشہ رحمت کرݨ والا ہے(١٤٠)۔
26,141,ثمود (دِی قَوم) وِی رَسُولاں کُوں کُوڑا آکھیا(١٤١)۔
26,142,ہِک وَقت اُنھاں دے (بِرادری دے) بِھرا صالح اُنھاں کُوں آکھیا، کیا تُساں (اَللہ کنُوں) ݙَردے نِھیوے(١٤٢)۔
26,143,بیشک مَیں تُہاݙے کِیتے ہِک اَمانت دار (قابِل اِعتبار) رسول ہَاں(١٤٣)۔
26,144,ٻَس اَللہ کنُوں ݙَرو، اَتے میݙے آکھیئے تے چَلّو(١٤٤)۔
26,145,اَتے مَیں تُساں کنُوں کوئی اَجر وِی نھیں مَنگدا، میݙا اَجر سارے جہاناں دے پالَݨ ہار کولھ ہے(١٤٥)۔
26,146,کیا تُساں اُنھاں شَئیں وِچ جِہڑیاں جو تُہاکُوں مِلیاں ہوئیاں ہَن، اِیویں عَیش وِچ چھوڑ ݙِتّے ویسو(١٤٦)۔
26,147,اَتے اُنھاں باغاں وِچ، اَتے اُنھاں چَشمیاں وِچ(١٤٧)۔
26,148,اَتے رَڑھِیں وِچ، اَتے کَھڄّیاں وِچ، جِنھاں دے غوشے بار کنُوں لٹکیئے پِئن(١٤٨)۔
26,149,اَتے تُساں پَہاڑا کُوں گَھڑ گَھڑ تے فخر دے قابِل گَھر بݨا گِھندُو(١٤٩)۔
26,150,ٻَس اَللہ کنُوں ݙرو، اَتے میݙا آکھیا مَنّیا کرو(١٥٠)۔
26,151,اَتے انھاں حَد کنُوں وَدّھ وَن٘ڄݨ والیاں دا آکھیا نَہ مَنّو(١٥١)۔
26,152,جِہڑے جو زمین اُتّے فَساد مَچائی رکھدِن، اَتے اِصلاح دِی کوئی ڳالھ نھیں کریندے(١٥٢)۔
26,153,او آکھݨ لڳے جو اَصل وِچ تیݙے اُتّے تاں کُوئی جادُو کِیتا ہوئے(١٥٣)۔
26,154,تُوں تاں کُجھ نِھیوی، محض ہِک بَشر ہیں، اَساں وانگُوں، بَھلا کوئی نِشانی گِھن آ، جیکر تُوں سَچّ بولݨ والیاں وِچُوں ہِیں تاں(١٥٤)۔
26,155,(صالح) آکھیا، اِیہ ہِک ݙاچی ہے، اِیندے کِیتے پاݨِیں پِیوَݨ دَا ہِک ݙِین٘ہ مُقرر ہے، اَتے تُہاݙے کِیتے پاݨِیں دَا ݙُوجھا ݙِین٘ہ مُقرر ہے(١٥٥)۔
26,156,اَتے اِیکُوں کوئی تکلیف پُچاوَݨ دِی نِیّت نال ہَتّھ وِی نَہ لَواہے نَہ تاں تُہاکُوں وَݙے ݙِین٘ہ دا عَذاب پَکڑ گِھنسے(١٥٦)۔
26,157,اُنھاں تاں ٻَس اِیں ݙاچِی دِیاں خُچَّاں ڄَنگھاں کَپّ چھوڑیاں، اَتے شَرمسار وِی تَھئے(١٥٧)۔
26,158,پَر اُنھاں کُوں عَذاب آن پَکڑیا، بیشک اِیندے وِچ نِشانی ہے، اَتے اُنھاں وِچُوں ڈھیر تاں اِیمان گِھن وِی نھیں آندے(١٥٨)۔
26,159,اَتے بیشک تیݙا رَبّ اُوہو ہے جِہڑا ٻَہُوں زبردست اَتے ہمیشہ رحمت کرݨ والا ہے(١٥٩)۔
