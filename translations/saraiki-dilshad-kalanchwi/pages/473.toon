quran[9{c,v,t}:
40,50,او اکھیسِن، کیا تُہاݙے رَسُول تُہاݙے کولھ کُھلیاں نِشانیاں گِھن تے نہ آئے ہَن، اِیہ اَکھیسِن ضرور آئے ہَن چوکیدار اَکھیسِن، وَل تاں تُساں خود اِی دُعا مَن٘ڳو، اَتے کافر جِہڑی وِی دُعا مَنگدِن، بے اَثر (بیکار) تِھی تے رَہ ویندی ہے (٥٠)۔
40,51,بیشک اَساں آپݨیاں رَسُولاں دِی اَتے جِہڑے لوک اِیمان گِھن آندِن اُنھاں دِی مَدد کریندے ہَیں، اِیں دُنیا دِی زندگی وِچ وِی ! اَتے جِہڑے ݙین٘ہ گواہی ݙیوݨ والے وِی موجود آکھڑسِن (٥١)۔
40,52,اُوں ݙین٘ہ ظالم لوکاں کُوں اُنھاں دا کوئی عُذر بَہانہ کوئی فائدہ نہ ݙیسے، اَتے اُنھاں اُتے لَعنت ہے تے اُنھاں (دے رَہݨ کِیتے) ٻَہُوں گَندا گَھر ہے (٥٢)۔
40,53,اَتے تحقیق اَساں مُوسیٰ کُوں سِدّھی رَاہ تے لَا ݙِتا، اَتے بنی اِسرائیل کُوں اُوں کِتاب دا وارِث چَا بݨایا (٥٣)۔
40,54,جِہڑی عَقل سَمجھ والے لوکاں کِیتے ہدایت تے نصیحت دِی شَئے ہے (٥٤)۔
40,55,ٻَس صبر کِیتی رَکّھو، بیشک اَللہ دا وَعدہ سَچّا ہے، اَتے آپݨیں گُناہاں دِی بخشش مَنگی رَکّھو، اَتے آپݨیں رَبّ دِیاں تعریفاں کریندے ہوئیں اُوندا پاک ہُووَݨ بیان کِیتی رَکّھو، تریجھے پہر (شام کُوں) وِی تے فجر ویلے وِی! (٥٥)۔
40,56,بیشک جِہڑے لوک اَللہ دِیاں نشانیاں دے متعلق بغیر کہیں اِہجی دلیل دے جِہڑی جو انھاں کولھ آئی وِی ہووے، مخالفت کِیتی رَکھدِن، انھاں دے سِینیاں وِچ ٻِیا کُجھ نھیں، سِوائے وَݙائی (مغرائی) دے، پَر او تاں کہیں توڑِیں پُڄ وِی نھیں سَڳدے ٻَس اَللہ کنُوں پَناہ مَنگی رَکّھو، بیشک اُوہو خُوب سُݨݨ تے خوب ݙیکھݨ والا ہے (٥٦)۔
40,57,اَسماناں تے زمین کُوں پَیدا کرݨ، لوکاں دے پَیدا کرݨ کنُوں وَݙا کَمّ ہے، پَر ڈھیر لوک اِیکُوں نھیں ڄاݨدے (٥٧)۔
40,58,اَتے اَندھا تے سُڄاکا ہِکّو جیہے نھیں تِھی سڳدے، اَتے جِہڑے لوک اِیمان گِھن آئِن اَتے نیکی دے کَمّ وِی کِیتی رَکھیئے ہِینے، او گَندے کَمّ کرݨ والیاں سَن٘وّیں نھیں تِھی سڳدے، تُساں ٻَہُوں تھوڑے غور و فِکر کریندے وے (٥٨)۔
