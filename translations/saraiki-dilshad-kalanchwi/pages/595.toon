quran[29{c,v,t}:
91,1,قَسم ہے سِجّھ دِی! اَتے اُوندی دُھپ دِی(١)
91,2,اَتے قَسم ہے چَندر دِی، ڄَݙاں جو او اُوندے پِچُّھوں نِکلدے(٢)
91,3,اَتے ݙین٘ہ دِی، ڄَݙاں جو سِجّھ کُوں خُوب چَمکا ݙیندے(٣)
91,4,اَتے رات دِی! جِہڑے ویلے او (سِجھ کُوں) لُکا گِھندی ہے(٤)
91,5,اَتے اسمان دِی اتے اوں ذات دی جَیں اُوکُوں کَھڑا کر کَھڑائے(٥)۔
91,6,اَتے زمین دِی تے اُوں ذات دِی جیں اوں کوں کھن٘ڈائے (٦)۔
91,7,تے اُوں نفس (ذات) دِی تے جَیں اُوکُوں ٹِھیک ٹَھاک (اُشناک) بَݨا چھوڑے(٧)۔
91,8,ٻَس اُوکُوں اُوندے فِسق فجور (کنُوں بَچَّݨ) دِی تے پَرہیزگاری (کرݨ) دِی سَمجھ ݙِتی ہِسّ(٨)
91,9,تحقیق اُوں شَخص آپݨِیں مُراد حاصل کِیتی، جَیں آپݨیں نَفس کُوں صاف سُتھرا رَکھیا(٩)۔
91,10,اَتے تحقیق او شَخص نا مُراد رِیہا، جَیں اُوکُوں گَندگی وِچ لَتھیڑ ݙِتّا(١٠)
91,11,ثمود دِی قَوم نے نافرمانی کر تے حقیقت کُوں کُوڑ آکھیا(١١)
91,12,جِہڑے ویلے اُنھاں دا ساریاں تُوں وَݙا بَد بَخت اُٹّھی کَھڑا(١٢)۔
91,13,تاں اَللہ دے رسول اُنھاں کُوں آکھیا، جو خبردار اِیہ اَللہ دِی ݙاچی ہے، اِیندے پاݨِیں پِیوَݨ دِی (واری تے) کوئی روک ٹوک نَہ ہُووے(١٣)۔
91,14,پَر اُنھاں اُوکُوں کُوڑ آکھیا، وَت اُوندیاں خُچَّاں کَپ چھوڑیاں، ٻَس اُنھاں دے رَبّ نے اُنھاں اُتّے اُنھاں دے گُناہاں دے سَبب اِہجی آفت بھیڄی، جَیں اُنھاں کُوں مِٹی بَرابر پُور ݙِتا(١٤)
91,15,اَتے (اَللہ کُوں) اُوں قَوم دے بَدلہ گِھنَّݨ دَا کوئی ݙَر وِی کائے نھیں(١٥)۔
92,1,قَسم ہے رَات دِی، ڄَݙاں ہَر شَئے کُوں کَڄ گِھنّے(١)
92,2,اَتے قَسم ہے ݙِین٘ہ دِی ڄَݙاں چَن٘ڳی طَرح سوجھلا تِھی وَن٘ڄے(٢)
92,3,اَتے اُوندی جَیں نَر تے مادی پَیدا کِیتے(٣)۔
92,4,اِیں ڳالھ دِی جو) دَر حقیقت تُہاݙِیاں کارگُزاریاں مختلف قِسم دِیاں ہِن(٤)۔
92,5,ٻَس جِہڑے شَخص (اَللہ دے رَاہ تے) مال خرچ کِیتا، اَتے اُوں پَرہیزگاری وِی اِختیار کِیتی(٥)۔
92,6,اَتے بَھلائی دِی ڳالھ کُوں سَچ آکھیا(٦)
92,7,تاں اَساں اُوکُوں بَھلائی دے رَستّے تے چَلَّݨ دِیاں سہولتاں ݙیسُوں(٧)
92,8,اَتے جَیں بُخیلی کِیتی(اَللہ کنُوں) لَا پَروا تِھی ڳیا(٨)
92,9,اَتے بَھلائی دِی ڳالھ کُوں کُوڑ آکھیا(٩)
92,10,تاں اَساں اُوکُوں سَختی والے رَستے دو سہولتاں ݙیسُوں(١٠)
92,11,اُوندا مَال اُوکُوں کوئی فائدہ نَہ ݙیسی، جِہڑے ویلے او سِر دے بَھرنے آ ڈَہسی(١١)
92,12,بیشک اَساݙے ذِمّے تاں ٻَس رَاہ ݙِیکھا ݙیوݨ ہے(١٢)۔
92,13,اَتے ہَر شَئے دِی اَخیر (آخرت) تے ہَر شَئے دا مُنڈھ (دُنیا) اَساݙے ہَتّھ وِچ ہے(١٣)
92,14,ٻَس مَیں تُہاکُوں بَھڑکدی بھا کنُوں ݙَرا چِتا ݙِتّے(١٤)
