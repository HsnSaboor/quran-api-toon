quran[13{c,v,t}:
19,52,اَتے اَساں اُوکُوں کُوہِ طُور دے سَڄے پاسُوں سَݙیا، اَتے اُوکُوں راز دِیاں ڳالھِیں کِیتے کولھُوں کر گِھدّا (٥٢)۔
19,53,اَتے اُوندے کِیتے آپݨیں رحمت نال اوندے بِھرا ہَارون کُوں نبی بݨا ݙِتا (٥٣)۔
19,54,اَتے (اَے رسول) اِیں کِتاب وِچ دا اِسماعیل دا حال وِی ݙَسا بے شَک او وَعدے دا ݙَاڈھا پَکّا ہَا، اَتے او وَݙی قَدر والا رسول ہَا تے نبی ہَا (٥٤)۔
19,55,اَتے آپݨیاں لوکاں کُوں نَماز اَتے زَکوٰۃ کِیتے حُکم ݙیندا ہَا، بیشک او آپݨیں رَبّ دا ٻَہُوں پَسند کِیتا ہوئیا ہَا (٥٥)۔
19,56,اَتے اِیں کِتاب وِچ دَا اِدریس دَا حال وِی ݙَسا، بے شک او ہِک سَچّا نَبی ہَا (٥٦)۔
19,57,اَتے اَساں اُوکُوں اُچّے مرتبے توڑِیں پُچا ݙِتا ہَا (٥٧)۔
19,58,اِیہے او لوک ہِن، جِنھاں اُتے اَللہ نعمت بھیڄی، او نبیّاں وِچُوں ہَن، آدم دِی اَولاد وِچُوں ہَن، اَتے اُنھاں وِچُوں ہَن جِنھاں کُوں اَساں نُوح نال سوار کر گِھدّا ہَا، اَتے اَپݨیں کِیتے چُݨ گِھدّا ہَا، ڄَݙاں اُنھاں کُوں وَݙے مہربان اَللہ دِیاں آیاتاں پَڑھ تے سُݨائیاں ویندیاں ہَن، تاں او سَجدے وِچ ڈھے پوندے ہَن، تے روندے ہَن (٥٨)۔
19,59,وَل اُنھاں دے گَندے لوک اُنھاں دے جانشین بَݨ ڳئے، جِنھاں نماز کُوں چھوڑ ݙِتا ہَا، اَتے نفسانی خُواہشاں پِچُّھوں لَڳ پَے ہَن، وَت ٻَہُوں جلدی گُمراہی دے اَنجام کُوں ݙیکھ گِھنسِن (٥٩)۔
19,60,سِوائے اُنھاں دے جِہڑے تَوبہ چَا کریندِن، اَتے اِیمان گِھن آندِن، اَتے نیک عَمل کریندِن، ٻَس اِیہے لوک ہِن جِہڑے جَنّت وِچ داخِل تِھیسِن اَتے اُنھاں اُتّے کوئی وِی ظُلم نہ کِیتا ویسے (٦٠)۔
19,61,ہمیش رَہݨ والے باغاں دا وَعدہ ہے جہڑا جو ٻَہُوں مہربان اَللہ نے غائبانہ طور تے اَپݨیں بَندیاں نال کِیتا ہوئے، بیشک اُوندا وَعدہ ضرور پُورا تِھی تے رَہݨ والا ہے (٦١)۔
19,62,اُنھاں وِچ واہیات ڳالھِیں نہ سُݨیسِن، سِوائے سَلامتی دِیاں ڳالھِیں دے، اَتے اُنھاں کِیتے اُوندے وِچ سَنجھ صَباحِیں دِی روزی (رِزق) تَیّار مِلسے (٦٢)۔
19,63,اِیہا ہے او بہشت جِیندا وَارث اَساں آپݨیاں بَندیاں وِچُوں اِہجیاں شَخصاں کُوں بَݨیسُوں جِہڑے جو ٻَہُوں پَرہیزگار ہوسِن (٦٣)۔
19,64,اَتے اَساں (فَرشتے) نِسّے نازِل تِھیندے تیݙے رَبّ دے حُکم کنُوں سِوا، ہُوندا ہے جِہڑا کُجھ اَساݙے سامݨیں ہے جِہڑا کُجھ اَساݙی کَنڈ پِچُّھوں ہے، اَتے جِہڑا کُجھ اِیندے وِچالے ہے، اَتے تیݙا رَبّ بُھلَݨ والا اَصلُوں کائے نھیں (٦٤)۔
