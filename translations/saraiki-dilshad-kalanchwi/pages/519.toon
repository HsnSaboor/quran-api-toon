quran[20{c,v,t}:
50,16,اَتے یقیناً اَساں اِنسان کُوں پَیدا کِیتے، اَتے اَساں ڄاݨدے ہَیں جو اِیندے متعلّق کیا کُجھ وسوسے اُوندے دِل وِچ پوندِن، اَتے اَساں تاں اِیندی ڳچّی دِی رگ کنُوں وِی زیادہ اِیندے کولھوں ہَیں (١٦)۔
50,17,ڄݙاں جو اِیندے سَڄّے پاسُوں تے کھٻّے پاسُوں موجود ݙوں نوٹ کرݨ (لِکّھݨ) والے (سَب کُجھ) نوٹ کر گِھندِن (١٧)۔
50,18,او کوئی اِہجی ڳالھ نھیں کریندا جِیندی تاڑ وِچ لِکّھݨ (نوٹ کرݨ) والے نہ لڳئے ٻیٹھے ہووِن (١٨)۔
50,19,اَخیر موت دِی سَکرات حقیقت بݨ تے آ ڳئی، اِیہا او حالت ہے جیں کنُوں تُوں پَرے بھڄدا ہاویں (١٩)۔
50,20,اَتے صُور (سنکھ) پُھوکیا ڳیا، تاں اُوہو عذاب دے وَعدے دا ݙین٘ہ ہوسی! (٢٠)۔
50,21,اَتے ہر جان اِیں حالت وِچ آسی، جو اُوندے نال ہِک ہکلݨ والا وِی ہوسی، تے ہِک (اُوندے عَملاں دی) گواہی ݙیوݨ والا وِی (٢١)۔
50,22,تُوں یقیناً اِیں کنُوں غفلت وِچ وَدّا ہاویں، ٻَس اَساں تَیں کنُوں تیݙی غفلت دا پَردہ ہَٹا ݙِتے، ٻَس اَڄ تاں تیݙی نظر ٹِھیک ٹِھیک ݙیہدِی پَئی ہے (٢٢)۔
50,23,اَتے اُوندے نال والا اَکھیسی، اِیہ موجود میݙے کولھ (اِیندے عَملاں دا کُھلا چٹّھا! ) (٢٣)۔
50,24,تُساں ݙوہائیں رَل تے سرکشی کرݨ والے ناشُکرے کُوں دَوزخ وِچ سَٹ ݙیوُو (٢٤)۔
50,25,بَھلائی کرݨ کنُوں روکݨ والے کُوں ، حَد کنُوں ٹَپ وَن٘ڄݨ والے کُوں، شَک کرݨ والے کُوں (٢٥)۔
50,26,جیں اَللہ دے نال ٻئے رَبوبݨے وِی بݨا گِھدّے ہووِن، ٻَس تُساں ݙوہائِیں کُوں سَخت عذاب وِچ گھت ݙیوُو (٢٦)۔
50,27,اُوندا سَنگتی (شیطان) اَکھیسی اَساݙے رَبّ آ! مَیں اِیکُوں حَدُوں ٹَپ وَن٘ڄݨ والا نھیں بݨایا بلکہ اِیہ خُود اِی پَرلے دَرجے دِی گُمراہی وِچ پِیا ہویا ہَا (٢٧)۔
50,28,اَللہ اَکھیسی، تُساں میݙے کولھ (آپس وِچ) جھیڑا نہ پَے گَھتّو! تحقیق مَیں تاں تُہاݙے کِیتے عذاب دا وَعدہ پہلے بھیڄ چُکیا ہَاں (٢٨)۔
50,29,میݙے سامݨیں کوئی ڳالھ نھیں بَدلائی ویندی، اَتے نہ اَساں بندیاں اُتّے کوئی ظلم کرݨ والے ہَیں (٢٩)۔
50,30,ہِک ݙین٘ہ دَوزخ کنُوں پُچّھیا ویسے، کیا تُوں بھریج رڄیج ڳئی ہیں، پَر او اَکھیسے، کیا ٻیا کُجھ وِی بَچیا ہویا ہے (٣٠)۔
50,31,اَتے بہشت پَرہیزگاراں دے نزدیک کر ݙِتی ویسی، اَصلُوں پَرے کائے نہ ہوسی (٣١)۔
50,32,اِیہا ہے جِیندا وَعدہ تُساں وِچُوں ہَر اُوں شخص نال کِیتا ڳِیا ہَا، جِہڑا ٻَہُوں رَجوع کرݨ والا، ہر طرح دا خیال رَکھݨ والا ہے (٣٢)۔
50,33,جِہڑا شخص ٻَہُوں مہربان (اَللہ) کنُوں بغیر ݙِٹھیں ݙَردا رِیہے، اَتے ٻَہُوں رجوع کرݨ والا دِلّ گِھن تے آئے (٣٣)۔
50,34,(آکھیا ویسی) اِیندے وِچ اَمن تے سَلامتی نال لَنگھ وَن٘ڄ اِیہُو ݙین٘ہاڑا ہمیشہ کِیتے قائم رَہݨ والا ہے (٣٤)۔
50,35,اِیندے وِچ اُنھاں کِیتے جو کُجھ وِی او چَہسِن، سَب موجود ہوسی (٣٥)۔
