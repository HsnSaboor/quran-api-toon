quran[3]{c,v,t}:
  73,0,شروع ہے اللہ دے ناں نال جِہڑا ٻَہُوں مہربان تے وَݙے رحم والا ہے
  73,1,اُتّے کَپڑے گَھتَّݨ والے آ (١)۔
  73,2,رات کُوں (عبادت وِچ) کَھڑا ریہا کر، ٻَس تھوڑا تھوڑا (٢)۔
  73,3,اِیندا وِی اَدّھا ، یا اِیں کنُوں وِی تھوڑا جیہا گَھٹا تے (٣)۔
  73,4,بھاویں اِیں کنُوں کُجھ وَدھا ݙِتا کر، اَتے قرآن کُوں تَھرام نال صاف صاف پَڑھیا کر (٤)۔
  73,5,یقیناً اَساں تیݙے اُتّے ہِک بارا کلام نازِل کرݨ والے ہَیں (٥)۔
  73,6,دَراَصل رَات کُوں اُٹَّھݨ نَفس کُوں قابُو وِچ رَکھݨ کِیتے فَائدہ ݙیندے، اَتے کلام دِی پَکاوت کِیتے وِی ٹِھیک ہے (٦)۔
  73,7,بیشک ݙین٘ہ کُوں تیݙے کِیتے ڈھیر سارے مشغلے ہِن (٧)۔
  73,8,اَتے تُوں آپݨیں رَبّ دے ناں دا ذِکر وِی کِیتی رَکّھ، اَتے ہَر پاسُوں چَنڳی طرح ہَٹ تے اُوندو جُھکیا رِیہا کر (٨)۔
  73,9,او مَشرق تے مغرب دا رَبّ ہے، کوئی وِی ٻِیا معبود (عبادت دے لائق) کائے نھیں، سِوائے اُوندے، ٻَس ہُوکُوں آپݨاں کارساز بݨائی رَکّھ (٩)۔
  73,10,اَتے صَبر چَا کِیتا جِہڑا کُجھ او اَکھیندے رَہندِن اَتے سوہݨیں طریقے نال اُنھاں کنُوں اَںج تِھی تے رہ (١٠)۔
  73,11,اَتے میکُوں تے کُوڑ مارݨ والے خوشحال لوکاں کُوں کَلّھا چھوڑ ݙے اَتے اُنھاں کُوں تھوڑی جیہی مُہلت وِی ݙے ݙے (١١)۔
  73,12,یقیناً اَساݙے کولھ (بارے بارے) جولان ہِن، اَتے (بھڑکاٹے مریندی) بھا ہے (١٢)۔
  73,13,اَتے سَنگھ وِچ پَھسّ وَن٘ڄݨ والا کَھاݨاں ہے ، اَتے دَرد ناک عَذاب ہے (١٣)۔
  73,14,ہِک ݙین٘ہ اِیہ زمین تے اَسمان کَن٘بݨ لڳ پوسِن، اَتے اِیہ پَہاڑ بُھر بُھرے ٹِٻے بَݨ تے تَلّے گِھردے ویسِن (١٤)۔
  73,15,تحقیق اَساں تُہاݙے کولھ ہِک رسول کُوں تُہاݙے اُتّے اُووِیں گواہ بݨا تے بھیڄا ہے، جِیویں اَساں فِرعون کولھ ہِک رسول بھیڄیا ہَا (١٥)۔
  73,16,ٻَس فِرعون نے رسُول دِی نافرمانی کِیتی، ٻَس اُوکُوں اَساں ٻَہُوں سَخت عَذاب وِچ پَکڑ گِھدّا (١٦)۔
  73,17,جیکر تُساں اُوندا اِنکار کِیتی رَکھیا، تاں تُساں کِیں طرح بَچ سَڳسُو اُوں ݙین٘ہ کنُوں جِہڑا جو ٻالاں کُوں وِی ٻُڈھا کر چھوڑیسے (١٧)۔
  73,18,جِیندی وَجّہ کنُوں اَسمان پَھڑیج ویسے، اَللہ دا وَعدہ تاں ضرور پُورا تِھی تے رَہسی (١٨)۔
  73,19,یقیناً اِیہ تاں ہِک نصیحت ہے، ٻَس جِیندا دِل کرے آپݨیں رَبّ والا سِدّھا رَاہ اِختیار کر گِھنّے (١٩)۔
  73,20,اَے رسول) بیشک تیݙا رَبّ خُوب ڄاݨدے، جو تُوں (نماز وِچ) کَھڑا رَہندیں ݙُوں تریہائی رَات دے قریب تَئیں (کَݙائیں) اُوندی آدِھل تَئیں، اَتے (کَݙائیں) محض تریہائی تَئیں! اَتے اُنھاں لوکاں دِی ہِک ٹولی وِی (اِیویں کَھڑی رَہندی ہے) جِہڑے تیݙے نال تِھی ڳئِین، اَتے اَللہ نے رات تے ݙین٘ہ دے اَندازے مُقرر کِیتے ہوئے ہِن، او ڄاݨدے جو تُساں انھاں دِی گِنتری پُوری نھیں رَکھ سَڳدے، ٻَس اُوں تُہاݙے اُتّے مہربانی کِیتی ہے، ہُݨ قرآن وِچُّوں جِتّی تُساں اَسانی نال پَڑھ سَڳدو، اُوہو کُجھ پَڑھیا کرو، اُوکُوں پَتہ ہے جو تُہاݙے وِچُوں کُجھ لوک بیمار وِی ہوندِن، اَتے کُجھ ٻئے زمین اُتے سَفر کریندے وَدّے ہوندِن تاں جو اَللہ دا فضل (روزی) حاصل کر گِھنِّن، اَتے کُجھ ٻئے وِی ہوندِن جِہڑے اَللہ دے رَاہ تے لَڑدے وَدّے ہوندِن، اِیندے وِچُوں ٻَس اُوہو جِتِّی پَڑھو، جِتِّی اَسانی نال پَڑھ سَڳدو، اَتے نماز قائم کِیتی رَ کھو، اَتے زَکوٰۃ ݙِتّی کِیتی کرو، اَتے اَللہ کُوں دِل نال سُوہݨاں جیہا قَرضہ وِی ݙِتا کرو، اَتے آپݨیں آپ دِی خاطر ڄِہڑی کُجھ نیکی اَڳُوں کِیتے بھیڄیا کریسو، ٻَس اَللہ دے کولھ ضرور موجود ݙیکھسو، تُہاݙے کِیتے او ٻَہُوں چَنڳی رَہسی، اَتے اُوندا اَجر وِی ٻَہُوں وَݙا ہے، ٻَس اَللہ کنُوں بخشش مَنگی کرو، بیشک اَللہ ٻَہُوں بَخشݨ ہار ہے، ہمیشہ رحمت کِیتی رَکھݨ والا ہے (٢٠)۔
