quran[24]{c,v,t}:
  51,7,"Nditsuba khulikulu lili nende tsinjila,"
  51,8,"Toto enywe muli mumakhuwa kawukhaane."
  51,9,"Ukalukhanibwa okhurula khubwatoto akalukhanibwa."
  51,10,"Abachishi balisishibwa."
  51,11,"Balia bakoyanila mubusilu."
  51,12,"Barebanga mbu: “Ni lina inyanga yomurungo?”"
  51,13,"Inyanga eyo balinyoola eshinyasio shiomulilo."
  51,14,"“Pile eshinyasio shienyu shino eshamwayungubalilanga.”"
  51,15,"Toto balia baria Nyasaye baliba mumikunda chomwikulu nende tsisebele."
  51,16,"Ne balibukula ka Nyasaye abahele, toto imbeli awo abo bali abakholi bamalayi."
  51,17,"Bakonanga hatiti eshilo."
  51,18,"Ne eshilo nishitsia okhushia, balamanga nibasaba eshileshelo."
  51,19,"Ne mumiandu chiabu omukabo kwa abasabi nende balasabanga kwalimwo."
  51,20,"Ne khushialo biliwo ebimanyisio khubasuubila toto."
  51,21,"Nende khumibili chienyu. Koo, shimulolangakhwo tawe?"
  51,22,"Ne mwikulu kuliyo omukabo kwenyu, nende kamulakungwa."
  51,23,"Kho, nditsuba khu Nyasaye Omulesi welikulu nende eshialo, mbu toto kano nikahabwene shinga enywe muboolanga."
  51,24,"Koo, lwakhuulilakhwo olukano lwa abacheni ba Ibrahim boluyali?"
  51,25,"Olwa benjila ewuwe nibaboola mbu: “Mulembe.” Naye nabakalusia mbu: “Mulembe muno Abandu bengorerwe.”"
  51,26,"Natsia khubandu be, niyetsa nende eshimosi shianera."
  51,27,"Nabasitilia hambi eshiakhulia, nabareba mbu: “Shimulitsanga tawe?”"
  51,28,"Naba noburi khubo, nibamuboolela mbu: “Olaria tawe.” Ne nibamubolera komwikhoyo koomusiani wobumanyi po."
  51,29,"Nilwa omukhasi wuwe yabachoma, nawuka, niyepama obweni, naboola mbu: “Esie omushiele mana omukumba ndakhebula endie?”"
  51,30,"Nibaboola mbu: “Endio nilwa kali, nilwa Nyasaye wuwo Omulesi aboolele. Toto niye Owamachesi muno, Omumanyi po.”"