quran[15]{c,v,t}:
  112,1,"Boola mbu, “Ye ni Nyasaye mulala yenyene."
  112,2,"Nyasaye owisikungwa."
  112,3,"Shiyebula nohomba shiyebulwa tawe."
  112,4,"Ne abulaho uyelana ninaye kata mulala.""
  113,1,"Boola mbu, “Ndishinga khu Nyasaye Omulesi owa amabwibwi."
  113,2,"Okhurulana nende obubii obwa bilia ebia yaloonga."
  113,3,"Nende okhurulana nende obubii bwa eshilima shia eshilo olwashinjilanga."
  113,4,"Nende okhurulana nende obubii bwa balia abeshikhasi bafuririranga muno mumafundikho."
  113,5,"Nende okhurulana nende obubii bwa weshikhalikhali olwaaba nakhola eshikhalikhali.""
  114,1,"Bola mbu, “Ndishiinganga khu Nyasaye, Omulesi wa Abandu."
  114,2,"Omwami wa Abandu."
  114,3,"Nyasaye wa Abandu."
  114,4,"Okhurulana nende obubii bwa (Shetani) ureranga obuyendi, owikhunanga muno."
  114,5,"Uretsanga obuyendi mubilifu bia Abandu,"
  114,6,"Okhurula mu Majini nende Abandu.""