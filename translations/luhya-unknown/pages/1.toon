quran[7]{c,v,t}:
  1,1,"(Enjaka) khulira lia Nyasaye, Omunji wetsimbabaasi, Owobukoosia muno."
  1,2,"Okhwitsomibwa khwoosi ni khwa Nyasaye, Omulesi webiloonje bioosi,"
  1,3,"Omunji wetsimbabaasi, Owobukoosia muno,"
  1,4,"Omwami wa Inyanga yomurungo."
  1,5,"Newesa wa khulamaanga, ne ninewesa wa khwenyangakhwo obukhoonyi."
  1,6,"Khulunjisie khunjila ingololofu,"
  1,7,"Injila ya balia abawahelesia tsimbabaasi, ilali ya balia abasinyishilwa nohomba ya balia abakora tawe."