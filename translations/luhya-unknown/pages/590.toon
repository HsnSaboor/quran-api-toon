quran[22]{c,v,t}:
  85,1,"Nditsuba khulikulu lili nende ameeshelo ketsing’ining’ini tsikhongo!"
  85,2,"Nende khuinyanga yalakwa!"
  85,3,"Nende khumuloli nende shikholelwa obuloli!"
  85,4,"Basishibwa Abandu ba Omutaro."
  85,5,"Omulilo kwetsikhwi tsinyinji."
  85,6,"Olwa bali nibekhale awo (khumulilo)."
  85,7,"Nabo nibo abaloli khu kalia kabakholelanga Abasuubili."
  85,8,"Nabo shibalolakhwo khubo obubii bwosibwosi tawe habula okhusuubila khwabu khu Nyasaye, Owamaani, Owitsomibungwa muno."
  85,9,"Uli nende obwami bwomwikulu nende khushialo, ne Nyasaye nomuloli muno wabuli eshindu."
  85,10,"Toto balia bara Abasuubili Abasatsa nende Abasuubili Abakhasi mumarechekho, mana nibalekanila tawe, abo balinyoola eshinyasio shiomulilo kwa Jahannam, ne balinyoola eshinyasio eshiokhusambwa."
  85,11,"Toto bwene balia basuubila mana nibakhola amalayi, balinyoola emikunda chiburangamwo emialo hasi wachio, ne okho nikho okhubura okhukhongo."
  85,12,"Toto bwene eshinyasio shia Nyasaye wuwo Omulesi neshilulu."
  85,13,"Toto Ye aranjilisinjia, khandi niye ukalusinjia."
  85,14,"Naye niwobulesheli po, owobuyanzi muno."
  85,15,"Oweshifumbi shia obwami, Owoluyali."
  85,16,"Owukholanga muno akayenya."
  85,17,"Koo, wawulilakhwo olukano lwa abalwani beliyie?"
  85,18,"Aba Firauni nende Thamudi?"
  85,19,"Halali abakhayi bali mukhukatsula butswa."
  85,20,"Ne Nyasaye yabaterera munyuma mwabu."
  85,21,"Halali ino ni Ikurani yoluyali."
  85,22,"Ili khulupao lwalindwa."