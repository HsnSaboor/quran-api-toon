quran[40]{c,v,t}:
  78,1,"(مۇشرىكلار ئۆزئارا نېمە توغرۇلۇق) سورىشىدۇ؟"
  78,2,"ئۇلار چوڭ بىر خەۋەر (يەنى قىيامەت توغرۇلۇق) سورىشىدۇ."
  78,3,"ئۇلار شۇ (يەنى قىيامەت) توغرىسىدا ئىختىلاپ قىلىشقۇچىلاردۇر."
  78,4,"ھەرگىز ئۇنداق ئەمەس (قىيامەت ئۇلارنىڭ ئويلىغىنىدەك يالغان ئەمەس)، ئۇلار (ھەقىقىي ئەھۋالنى) كەلگۈسىدە بىلىدۇ."
  78,5,"ھەرگىز ئۇنداق ئەمەس، ئۇلار (بېشىغا كەلگەن ئازابنى) كەلگۈسىدە بىلىدۇ."
  78,6,"(زېمىننىڭ ئۈستىدە مۇقىملىشىشىڭلار ۋە كەڭ تۈزلەڭلىكلەرگە زىرائەت تېرىپ پايدىلىنىشىڭلار ئۈچۈن) زېمىننى بىسات قىلمىدۇقمۇ؟"
  78,7,"(زېمىننىڭ تەۋرەپ كەتمەسلىكى ئۈچۈن) تاغلارنى قوزۇق قىلمىدۇقمۇ؟"
  78,8,"سىلەرنى ئەر ـ ئايال قىلىپ ياراتتۇق."
  78,9,"ئۇيقۇنى سىلەرنىڭ (بەدىنىڭلار ئۈچۈن) راھەت قىلدۇق."
  78,10,"كېچىنى لىباس قىلدۇق."
  78,11,"كۈندۈزنى (سىلەر) تىرىكچىلىك قىلىدىغان (ۋاقىت) قىلدۇق."
  78,12,"ئۈستۈڭلاردا مۇستەھكەم يەتتە ئاسماننى بىنا قىلدۇق."
  78,13,"(سىلەر ئۈچۈن) يېنىپ تۇرغان چىراغنى (قۇياشنى) ياراتتۇق."
  78,14,"ئاشلىقلارنى، ئوت ـ چۆپلەرنى، دەرەخلىرى قويۇق باغچىلارنى ئۆستۈرۈش ئۈچۈن بۇلۇتلاردىن مول يامغۇر ياغدۇرۇپ بەردۇق[14ـ16]."
  78,15,"ئاشلىقلارنى، ئوت ـ چۆپلەرنى، دەرەخلىرى قويۇق باغچىلارنى ئۆستۈرۈش ئۈچۈن بۇلۇتلاردىن مول يامغۇر ياغدۇرۇپ بەردۇق[14ـ16]."
  78,16,"ئاشلىقلارنى، ئوت ـ چۆپلەرنى، دەرەخلىرى قويۇق باغچىلارنى ئۆستۈرۈش ئۈچۈن بۇلۇتلاردىن مول يامغۇر ياغدۇرۇپ بەردۇق[14ـ16]."
  78,17,"قىيامەت كۈنى ھەقىقەتەن (مۇكاپاتلاش ۋە جازالاش) ۋاقتىدۇر."
  78,18,"ئۇ كۈنى سۇر چېلىنىدۇ، سىلەر توپ ـ توپ بولۇپ كېلىسىلەر."
  78,19,"ئاسمان ئېچىلىپ نۇرغۇن ئىشىكلەر پەيدا بولىدۇ."
  78,20,"تاغلار ھەرىكەتلەندۈرۈلۈپ سەرابتەك بولۇپ قالىدۇ (يەنى تاغلار توزۇپ يىراقتىن قارىغۇچىغا سۇدەك تۇيۇلىدۇ)."
  78,21,"جەھەننەم ھەقىقەتەن (كۇففارلارنى) كۈتۈپ تۇرىدۇ."
  78,22,"جەھەننەم، شۈبھىسىزكى، گۇناھكارلارنىڭ جايىدۇر."
  78,23,"ئۇلار جەھەننەمدە ئۇزاق مۇددەت قالىدۇ."
  78,24,"ئۇلار جەھەننەمدە (جەھەننەمنىڭ ھارارىتىنى يىنىكلىتىلگەن) بىرەر سۆرۈنلۈككە ۋە (تەشنالىقنى قاندۇرىدىغان) بىرەر ئىچىملىككە ئېرىشەلمەيدۇ."
  78,25,"ئۇلارنىڭ ئېرىشىدىغىنى پەقەت يۇقىرى ھارارەتلىك قايناقسۇ ۋە يىرىڭدىنلا ئىبارەت بولىدۇ."
  78,26,"بۇ ئۇلارغا بېرىلىدىغان مۇۋاپىق جازادۇر."
  78,27,"چۈنكى ئۇلار (قىلمىشلىرىدىن) ھېساب ئېلىنىشتىن قورقمايتتى"
  78,28,"ھەمدە بىزنىڭ ئايەتلىرىمىزنى قاتتىق ئىنكار قىلاتتى."
  78,29,"ھەر نەرسىنى تولۇق خاتىرىلەپ قويغان ئىدۇق."
  78,30,"(ئۇلارغا ئېيتىمىزكى) «تېتىڭلار! سىلەرگە پەقەت ئازابنىلا زىيادە قىلىمىز»."
  78,31,"شۈبھىسىزكى، تەقۋادارلار نېمەتكە ئېرىشىدۇ."
  78,32,"(ئۇ نېمەت) باغلار، ئۈزۈملەردۇر."
  78,33,"تەڭتۇش قىزلاردۇر."
  78,34,"(شاراب بىلەن) تولدۇرۇلغان جاملاردۇر."
  78,35,"ئۇلار جەننەتتە يالغان سۆز، بىھۇدە سۆز ئاڭلىمايدۇ."
  78,36,"(ئەنە شۇلار) پەرۋەردىگارىڭنىڭ بەرگەن مۇكاپاتى، يېتەرلىك ئاتاسىدۇر."
  78,37,"ئۇ ئاسمانلارنىڭ، زېمىننىڭ ۋە ئۇلارنىڭ ئارىسىدىكى شەيئىلەرنىڭ پەرۋەردىگارىدۇر. ناھايىتى شەپقەتلىكتۇر. (ئۇ كۈندە ھېچ كىشى) ئۇنىڭغا سۆز قىلىشقا قادىر بولالمايدۇ."
  78,38,"جىبرىئىل ۋە پەرىشتىلەر سەپ بولۇپ تۇرۇپ كېتىدىغان كۈندە (يەنى قىيامەتتە)، ئۇلار(نىڭ ئارىسىدا) مېھرىبان ئاللاھنىڭ ئىزنىگە ئېرىشكەن ۋە توغرا سۆزنى قىلغانلاردىن باشقا ھېچ ئەھەدىنىڭ سۆز قىلىشىغا بولمايدۇ."
  78,39,"ئەنە شۇ چوقۇم بولىدىغان كۈندۇر. كىمكى (ئىمان بىلەن، ياخشى ئەمەل بىلەن) پەرۋەردىگارىغا قايتىدىغان يولنى تۇتۇشنى خالىسا (تۇتسۇن)."
  78,40,"بىز سىلەرنى ھەقىقەتەن (يۈز بېرىشى) يېقىن ئازابتىن (يەنى ئاخىرەت ئازابىدىن) ئاگاھلاندۇردۇق، ئۇ كۈندە كىشى ئىلگىرى قىلغان ئەمەللىرىنى كۆرىدۇ. كاپىر: «كاشكى مەن تۇپراق بولۇپ كەتكەن بولسامچۇ!» دەيدۇ."
