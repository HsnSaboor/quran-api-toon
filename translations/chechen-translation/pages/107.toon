quran[7]{c,v,t}:
  107,1,"Хьуна гиний /хIай Мухьаммад/ и дин харцдеш верг?"
  107,2,"Иза ву бобер (беда) шен хьакъах (бакъонах) духатухуш верг."
  107,3,"Мискачунна даа хIума дала /нахана/ дага ца доуьйту цо. (Ша муххале а ца ло).",footnotes:114484:1
  107,4,"Боккха бāла бу ламаз дечарна‚"
  107,5,"Шаьш дечу ламазах терго еш боцчу‚",footnotes:114485:1
  107,6,"Шаьш /нахана/ гайтархьама /ламазаш деш/ болчу‚"
  107,7,"Шаьш /нахе ханна пайдаэца/ цIера салпаляла магош боцчу.",footnotes:114486:1
