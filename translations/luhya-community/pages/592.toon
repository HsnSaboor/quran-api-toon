quran[30]{c,v,t}:
  87,16,"Halali enywe mwayanza mana nimuranjilisia muno obulamu bwokhushialo!"
  87,17,"Ne obulamu bwomwikulu nobulayi ne nibwokhutong'a muno."
  87,18,"Toto kano kali mubitabo bia imbeli."
  87,19,"Ebitabu bia Ibrahim nende Musa."
  88,1,"Koo, kamala okhukhwitsila amacheni kamasila kalifundesia Abandu?"
  88,2,"Obweni inyanga eyo bulihotselesia."
  88,3,"Bukholele emilimo buchoonyele."
  88,4,"Bulinjila mumulilo kwakhanga."
  88,5,"Bulinywesibwa amatsi keyisebele karabachilanga."
  88,6,"Shibalinyolamwo eshiakhulia tawe halali shiamawa."
  88,7,"Sishikhomesinjia ta ne sishimalanga inzala tawe."
  88,8,"Inyanga eyo obweni bundi buliba nibunula."
  88,9,"Buliba nibuchamiile okhukhalabana khwabwo."
  88,10,"Baliba mumikunda chomwikulu chia hekulu choluyali."
  88,11,"Shonyala okhuwulilamwo akeshifwabi tawe."
  88,12,"Mukariomo ilimwo isebele ikhulukusinjia."
  88,13,"Ebifumbi bilimwo bia hekulu."
  88,14,"Nende tsigilasi tsiarebwa khulala."
  88,15,"Nende emitoo olunyaali olunyaali."
  88,16,"Nende emikeka chiaalwa."
  88,17,"Koo, shibahengangakhwo ingamia shingala yaloongwa tawe?"
  88,18,"Nende likulu shingala liachingulwa?"
  88,19,"Nende tsingulu shingala tsiatisibwa hasi?"
  88,20,"Nende liloba shingala liakwalasibwa?"
  88,21,"Kho itsulisia! Katoto ewe oli Omwitsulisi butswa."
  88,22,"Ewe sholi wokhubanichilisia tawe."
  88,23,"Halali ulia ukalukha inyuma nakhaya."
  88,24,"Kho Nyasaye alimuhelesia eshinyasio eshikhongo muno!"
  88,25,"Toto ewefu niwo wamakalushilo kabu."
  88,26,"Mana khandi toto okhubalilwa amakhuwa kabu khuli khwifwe!"