quran[14]{c,v,t}:
  109,1,"Boola mbu: “Enywe Abakhayi!"
  109,2,"Shelaamanga shiamulaamanga tawe."
  109,3,"Ne enywe shimulaamanga owelaamanga tawe."
  109,4,"Ne esie shindililaama shiamulaamanga tawe."
  109,5,"Ne enywe shimulaamanga owelaamanga tawe."
  109,6,"Enywe muli nende idini yenyu, nasi endi nende idini yanje.”"
  110,1,"Olwa obuhabini bwa Nyasaye nende obwikuli buliitsa,"
  110,2,"Ne nolola Abandu nibenjila mudini ya Nyasaye mumikanda."
  110,3,"Awo tswenula Nyasaye wuwo Omulesi khutsifumia tsitsie tsindayi, ne omusabe eshileshelo. Toto bwene niye Omulesheli muno."
  111,1,"Chiasikha emikhono chibili chia Abu Lahab, naye mwene nasikha."
  111,2,"Omwandu kukwe shikwamukhoonya tawe nohomba ebiayakhalabanila."
  111,3,"Aliinjila mumulilo kupupuchilanga."
  111,4,"Nende Omukhasi wuwe omuchinji muno wetsikhwi."
  111,5,"Mwikosi mumwe alirebwamwo omukoye kwaborolwa."