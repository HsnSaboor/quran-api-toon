quran[42]{c,v,t}:
  80,1,"Yakhulusia obweni mana nafutara."
  80,2,"Mbu omuwofu yamwitsila!"
  80,3,"Ne nishina shikhumanyia ye awundi anyala okhwitswenula?"
  80,4,"Nohomba aletsulisibwa mana ametsulisio kamukhoonye?"
  80,5,"Ne ulia wilola neshileka."
  80,6,"Nawe niye oworeerekhwo eshinani?"
  80,7,"Shikali khwiwe tawe nakhaya okhutswenukha."
  80,8,"Ne ulia ukhwitsila neshinani."
  80,9,"Naye naririre."
  80,10,"Niye woshulila likosi?"
  80,11,"Shikali kario tawe! Toto kano nametsulisio."
  80,12,"Ulia uchama, akeetsulile."
  80,13,"Kali mutsimbapulo tsioluyali."
  80,14,"Tsiachingulwa hekulu, tsinzwenufu."
  80,15,"Tsili mumikhono chia Abamalaika Abahandichi."
  80,16,"Boluyali, abalayi muno."
  80,17,"Omundu yasikha! Nishina shimukholanga naba omukhayi?"
  80,18,"Yamulongwa okhurula khushina?"
  80,19,"Okhurulana nende indonyande ya amaatsi kolwibulo, yamuloonga mana namupangila amakhuwa ke."
  80,20,"Mana namwanguyilisilia Injila."
  80,21,"Mana namufwisia, mana namura mushilindwa."
  80,22,"Mana nalichama, alimulamusia."
  80,23,"Tawe! Ashili okhumala kayamulomesia."
  80,24,"Kho Omundu ahenjekhwo eshilibwa shishie."
  80,25,"Toto efwe khwayomboola amatsi buyomboola."
  80,26,"Ne nikhwaarula liloba bwaarula."
  80,27,"Ne nikhumesiamwo imele."
  80,28,"Nende tsizabibu nende eliani liamasafu."
  80,29,"Nende emizaituna nende mitende."
  80,30,"Nende emikunda chiemisala chiasitanakhwo obulayi."
  80,31,"Nende ebiamo, nende olwayilo lwemiruko."
  80,32,"Khulwa okhwisangasia khwenyu nende ebiruche bienyu."
  80,33,"Mana shingala omwayukho kulia kuliitsa."
  80,34,"Inyanga yomundu alimwilukha omusiani wabu."
  80,35,"Nende nyinamwana nende samwana."
  80,36,"Nende omukhaye wuwe nende abana be."
  80,37,"Buli shiamulala aliba nende akeke kamuyela."
  80,38,"Inyanga eyo obweni bundi buling’enang’ena."
  80,39,"Bulitsekha nibusangalile."
  80,40,"Ne obweni bundi inyanga eyo buliba nende olufu."
  80,41,"Eshilima tititi shilibufunikha."
  80,42,"Abo nibo Abakhayi abakholi betsimbi."