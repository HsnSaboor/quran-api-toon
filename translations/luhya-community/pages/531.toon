quran[22]{c,v,t}:
  54,50,"Ne likhuwa liefu nililala butswa, shinga okhulimba nende okhulimbula tsimoni."
  54,51,"Ne toto khwasishia abashienywe, kho alikho mwinywe witsulilanga?"
  54,52,"Ne koosi kabakhola kali mubitabu."
  54,53,"Ne liosiliosi lititi nende likhonga liahandikwa."
  54,54,"Toto balia baria Nyasaye baliba mumikunda chomwikulu nende emialo."
  54,55,"Mushikhalo shiatoto, ewa Omwami, Omunyali muno."
  55,1,"Owetsimbabaasi tsinyinji."
  55,2,"Yechesia Ikurani."
  55,3,"Yaloonga Omundu."
  55,4,"Namwechesia okhwinoosia."
  55,5,"Eliuba nende Omwesi bichendanga khubise (Nyasaye yabiraho kho abandu bamanye khubio ebise, tsinyanga, amawichi nende emyaka)."
  55,6,"Ne emilandula nende emisaala binamilanga Nyasaye."
  55,7,"Ne yachingula likulu (nalikhola okhuba eshitsafu shye eshialo) ne naraho eshichelo."
  55,8,"Kho mulatutuyia eshichelo tawe."
  55,9,"Ne muchele habwene, ne mulaleemia eshichelo tawe."
  55,10,"Ne eshialo yashiraho khulwa ebiloonje."
  55,11,"Shilimwo ebiamo nende emitende chili nende ebibuli."
  55,12,"Nende imele yamakhoba nende amasafu ka raihan (kawunyanga obulayi)."
  55,13,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,14,"Yaloonga Omundu okhurula khwiloba shinga liokhuloonjela tsinyungu."
  55,15,"Ne naloonga Al-Jan (papa wa amajini) okhurula khumulilo kubula omwosi."
  55,16,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"