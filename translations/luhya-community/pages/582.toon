quran[30]{c,v,t}:
  78,1,"Barebananga hekulu wa shina?"
  78,2,"Hekulu wa amacheni amakhongo ako."
  78,3,"Kalia akabawukhanangamwo."
  78,4,"Tawe! Lekha butswa. Ahambi hano baletsa okhumanya."
  78,5,"Mana khandi tawe lekha butswa. Ahambi hano baletsa okhumanya."
  78,6,"Shikhwakhola liloba okhuba shinga obulili?"
  78,7,"Ne efikulu okhuba tsisiilo?"
  78,8,"Ne ni khubaloonga tsimbia tsibili (eshisatsa neshikhasi)?"
  78,9,"Ne nikhukhola okhukona khwenyu okhuba okhuwuluukha?"
  78,10,"Ne nikhukhola eshilo okhuba eshifwalo?"
  78,11,"Ne nikhukhola eshitere okhuba shiokhukhalabanila obulamu?"
  78,12,"Ne nikhumbakha hekulu wenyu amakulu saba aka amaani."
  78,13,"Ne nikhukasia itaa yobulafu obunji (eliuba)."
  78,14,"Ne nikhwishia amatsi karulanga mubunji okhurula mumaleesi."
  78,15,"Kho khurusie khuko imele nende emimela."
  78,16,"Nende emikunda chiemisala chiatilana."
  78,17,"Toto inyanga yobwaukhasi yarebwaho khubise."
  78,18,"Inyanga yolwika lulifurwamwo, nanyu muliitsa mumikanda."
  78,19,"Ne likulu liliikulwa liaba shinga emiliango."
  78,20,"Ne efikulu filisiulwa fiaba shinga amaweruweru."
  78,21,"Toto Jahannamu iliindanga muno!"
  78,22,"Ni habundu wokhumenya wa Ababura eshichelo (shia Nyasaye)."
  78,23,"Balimenyamwo tsinyanga netsinyanga."
  78,24,"Shibalipilamwo shiosishiosi eshinyifu nohomba eshinywebwa tawe."
  78,25,"Halali amatsi kayile pa nende amafila."
  78,26,"Nomurungo kubayela."
  78,27,"Toto bo shibasubilanga mbu khuliba nende inyanga yokhurebwa ebikhole tawe."
  78,28,"Ne bakatsulanga muno ebimanyisio biefu."
  78,29,"Ne buli eshindu khwashimanya obulai muno mubuhandiche."
  78,30,"Kho pile! Shikhulabameta shiosishiosi tawe halali eshinyasio!"