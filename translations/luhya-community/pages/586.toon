quran[29]{c,v,t}:
  81,1,"Olwa eliuba lilifumbwafubwa."
  81,2,"Ne olwa tsing’ining’ini tsilikwa."
  81,3,"Ne olwa tsingulu tsilirusibwaho."
  81,4,"Ne olwa tsingamia tsili inda tsililekhwa."
  81,5,"Ne olwa tsisolo tsiomwiswa tsilikhung’asibwa."
  81,6,"Ne olwa tsinyanza tsiliakha omulilo."
  81,7,"Ne olwa emioyo chililimasibwa."
  81,8,"Ne olwa omukhana wayabilwa omulamu alireebwa."
  81,9,"Khulibii shina liayererwa?"
  81,10,"Ne olwa Ebitabu bilisaalasibwa."
  81,11,"Ne olwa likulu lilirusibwaho."
  81,12,"Ne olwa omulilo kwa Jahannamu kulimetwa omwakho (khukutsiririre okhwaakha)."
  81,13,"Ne olwa omukunda kwomwikulu kulisitibwa ahambi."
  81,14,"Buli omundu alimanya shiayakhola."
  81,15,"Nditsuba khutsing’ining’ini tsikalukhanga inyuma."
  81,16,"Tsitsitsanga, mana khandi tsifisa."
  81,17,"Ne olweshilo shitsitsanga nishichelela."
  81,18,"Ne eshialo nishitsia okhushia."
  81,19,"Toto kano ni amakhuwa komurumwa woluyali."
  81,20,"Owamaani, owa ingasi yoluyali, ewa Mwene Eshisala shiobwami."
  81,21,"Uwuwulilungwa eyo mana khandi omwisikwa."
  81,22,"Ne owashienywe uno shali omulalu tawe."
  81,23,"Ne toto bwene yamulola (Jibril) netsimoni tsie elubeka wa hekulu muno welikulu lia hasi ili habulafu."
  81,24,"Naye shali omwimani khumakhuwa kefisa tawe."
  81,25,"Ne kano shikali amakhuwa ka Shetani walondwa tawe."
  81,26,"Kho mutsitsanga yena?"
  81,27,"Ikurani ino ni eshitsulisio butswa khubiloonje bioosi."
  81,28,"Khu yesiyesi mwinywe wenyanga okhulunjikha."
  81,29,"Ne enywe shimulenya tawe halali okhuula Nyasaye yenye, Omulesi webiloonje bioosi."