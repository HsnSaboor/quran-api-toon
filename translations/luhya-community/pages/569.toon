quran[29]{c,v,t}:
  70,11,"Balilolesibwa balolane. Omwononi yakhekombe okhwinunula okhurulana nende eshinyasio shieyinyanga eyo khulwokhuyinia Abana be."
  70,12,"Nende omukhaye wuwe, nende Omusiani wabu."
  70,13,"Nende abeekho baye abamukhonyanga."
  70,14,"Nende bioosi bili mushialo, mana elo limuhonokosie."
  70,15,"Shikali kario tawe! Toto oko ni omulilo omululu."
  70,16,"Kunyibululanga muno lisero lyomurwe."
  70,17,"Kulilaanga buli wafutara mana natsia."
  70,18,"Wabunjelesinjia omwandu naakubiikha."
  70,19,"Toto Omundu yaloongwa nokhuyungubala."
  70,20,"Nanyoolwa namasila, yetswulikania."
  70,21,"Ne nanyoolwa na amalayi, yemana po."
  70,22,"Okhuiniakhwo abalamanga (iswala)."
  70,23,"Balia bakholelanga eshinani amalaamo kabu (iswala) obulachweya tawe."
  70,24,"Nende balia bomumwandu kwabu kulimwo omukabo omulobole."
  70,25,"Khu usaba nende khu uritsanga okhusaba."
  70,26,"Nende balia basuubilanga inyanga yomurungo."
  70,27,"Nende balia baritsanga muno eshinyasio shia Nyasaye wabu Omulesi."
  70,28,"Toto eshinyasio shia Nyasaye wabu Omulesi sishili shawakhasuubila okhuhonokokhamwo tawe."
  70,29,"Nende balia abalindanga ebiekenyi biabu."
  70,30,"Okhuyiniakhwo khubakhaye baabu, nohomba balia babaruka bali mumikhono chiabu emisatsa. Toto abo shibafunanibwa tawe."
  70,31,"Ne balia abokhwenya kalali kano tawe. Abo nibo babura eshichelo."
  70,32,"Nende balia balindanga obulayi obwisikwa nende indakano yabu."
  70,33,"Nende balia bemanga shilunji khubuloli bwabu."
  70,34,"Nende balia balindanga iswala yabu."
  70,35,"Abo nibo balihelesibwa oluyali nende amalayi mumikunda chomwikulu."
  70,36,"Bali barie abakhayi, abakhwitsilanga mubunji nibakhunga’nga’lilakhwo butswa."
  70,37,"Emikanda nemikanda, na mukhono musatsa nende namukhono mukhasi."
  70,38,"Koo, buli yesiyesi yekombanga mbu alinjila mumukunda kwomwikulu kwobwokholo?"
  70,39,"Shikali kario tawe! Toto efwe khwabalonga okhurulana nende eshiabamanyile."