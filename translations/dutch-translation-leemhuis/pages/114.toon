quran[6]{c,v,t}:
  114,1,"Zeg: ""Ik zoek bescherming bij de Heer van de mensen,"
  114,2,"de koning van de mensen,"
  114,3,"de god van de mensen,"
  114,4,"tegen het kwaad van de stiekeme influisteraar"
  114,5,"die de mensen in hun binnenste influistert,"
  114,6,"of hij nu tot de djinn of tot de mensen behoort."""
