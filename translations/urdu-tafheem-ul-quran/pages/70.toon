quran[12]{c,v,t,f}:
  2,205,"جب اسے اقتدار حاصل ہو جاتا ہے{1}، تو زمین میں اس کی ساری دوڑ دھوپ اس لیے ہو تی ہےکہ فساد پھیلائے، کھیتوں کو غارت کرے اور نسل ِ انسانی کو تباہ کرے۔۔۔۔حالانکہ اللہ (جسے وہ گواہ بنا رہاتھا) فساد کو ہر گز پسند نہیں کرتا.",footnotes:1:[”ِذَا تَوَلّٰی“کے دو مطلب ہو سکتے ہیں۔ ایک وہ جو ہم نے متن میں  اختیا ر کیا ہے اور دُوسرا مطلب  یہ بھی  نکلتا ہے کہ یہ مزے مزے کی دل لبھانے والی باتیں بنا کر”جب وہ پلٹتا ہے“، تو عملاً  یہ کرتُوت دکھاتا ہے۔]
  2,206,"اور جب اس سے کہا جاتا ہے کہ اللہ سے ڈر، تو اپنے وقار کا خیال اُس کو گناہ پر جما دیتا ہے ایسے شخص کے لیے تو بس جہنم ہی کافی ہے اور وہ بہت برا ٹھکانا ہے"
  2,207,"دوسری طرف انسانوں ہی میں کوئی ایسا بھی ہے، جو رضا ئے الٰہی کی طلب میں اپنی جان کھپا دیتا ہے اور ایسے بندوں پر اللہ بہت مہربان ہے"
  3,145,"کوئی ذی رُوح اللہ کے اذن کے بغیر نہیں مر سکتا۔ موت کا وقت تو لکھا ہوا ہے۔{1} جو شخص ثواب دنیا کے ارادہ سے کا م کر ے گا اس کو ہم دنیا ہی میں سے دیں گے، اور جو ثواب آخرت{2} کے ارادہ سے کام کرے گا وہ آخرت کا ثواب پائے گا اور شکر کرنے والوں{3} کو ہم ان کی جزا ضرور عطا کریں گے.",footnotes:1:[اس سے,],footnotes:2:[یہ,],footnotes:3:[بات]
  3,146,"اس سے پہلے کتنے ہی نبی ایسے گز ر چکے ہیں جن کے ساتھ مل کر بہت سے خدا پرستوں نے جنگ کی۔ اللہ کی راہ میں جو مصیبتیں ان پر پڑیں ان سے وہ دل شکستہ نہیں ہوئے، انہوں نے کمزوری نہیں دکھائی ، وہ (باطل کے آگے )سرنگوں نہیں ہوئے۔{1} ایسے ہی صابروں کو اللہ پسند کرتا ہے.",footnotes:1:[یعنی اپنی قلتِ]
  3,147,"ان کی دعا بس یہ تھی کہ، "
  4,85,"جو بھلائی کی سفارش کریگا وہ اس میں سے حصّہ پائے گا اور جو برائی کی سفارش کرے گا وہ اس میں سے حصّہ پائے گا، {1} اوراللہ ہر چیز پر نظر رکھنے والا ہے.",footnotes:1:[یعنی یہ اپنی]
  4,86,"اور جب کوئی احترام کے ساتھ تمہیں سلام کرے تو اس کو اس سے بہتر طریقہ کے ساتھ جواب دو یا کم از کم اسی طرح ،{1} اللہ ہر چیز کا حساب لینے والا ہے.",footnotes:1:[اُس وقت]
  4,87,"اللہ وہ ہے جس کےسوا کوئی خدا نہیں ہے، وہ تم سب کو اس قیامت کے دن جمع کرے گا جس کے آنے میں کوئی شبہہ نہیں، اور اللہ کی بات سے بڑھ کر سچی بات اور کس کی ہو سکتی ہے۔{1}.",footnotes:1:[یعنی کافر اور مشرک اور ملحد اور دہریے جو کچھ کر رہے]
  5,22,"انہوں نے جواب دیا "
  5,23,"اُن ڈرنے والوں میں دو شخص ایسے بھی تھے{1} جن کو اللہ نے اپنی نعمت سے نوازا تھا۔ انہوں نے کہا کہ ”اِن جبّاروں کے مقابلہ میں دروازے کے اندر گُھس جاوٴ، جب تم اندر پہنچ جاوٴ گے تو تم ہی غالب رہوگے۔ اللہ پر بھروسہ رکھو اگر تم مومن ہو“.",footnotes:1:[قَالَ]
  5,24,"لیکن اُنہوں نے پھر یہی کہا کہ "