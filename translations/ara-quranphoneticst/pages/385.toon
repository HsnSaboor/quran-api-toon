quran[10]{c,v,t}:
  27,89,Man Jā'a Bil-Ĥasanati Falahu Khayrun Minhā Wa Hum Min Faza`in Yawma'idhin 'Āminūna
  27,90,Wa Man Jā'a Bis-Sayyi'ati Fakubbat Wujūhuhum Fī An-Nāri Hal Tujzawna 'Illā Mā Kuntum Ta`malūna
  27,91,Innamā 'Umirtu 'An 'A`buda Rabba Hadhihi Al-Baldati Al-Ladhī Ĥarramahā Wa Lahu Kullu Shay'in Wa 'Umirtu 'An 'Akūna Mina Al-Muslimīna
  27,92,Wa 'An 'Atluwa Al-Qur'āna Famani Ahtadá Fa'innamā Yahtadī Linafsihi Wa Man Đalla Faqul 'Innamā 'Anā Mina Al-Mundhirīna
  27,93,Wa Quli Al-Ĥamdu Lillāhi Sayurīkum 'Āyātihi Fata`rifūnahā Wa Mā Rabbuka Bighāfilin `Ammā Ta`malūna
  28,1,Ţā-Sīn-Mīm
  28,2,Tilka 'Āyātu Al-Kitābi Al-Mubīni
  28,3,Natlū `Alayka Min Naba'i Mūsá Wa Fir`awna Bil-Ĥaqqi Liqawmin Yu'uminūna
  28,4,Inna Fir`awna `Alā Fī Al-'Arđi Wa Ja`ala 'Ahlahā Shiya`āan Yastađ`ifu Ţā'ifatan Minhum Yudhabbiĥu 'Abnā'ahum Wa Yastaĥyī Nisā'ahum 'Innahu Kāna Mina Al-Mufsidīna
  28,5,Wa Nurīdu 'An Namunna `Alá Al-Ladhīna Astuđ`ifū Fī Al-'Arđi Wa Naj`alahum 'A'immatan Wa Naj`alahumu Al-Wārithīna