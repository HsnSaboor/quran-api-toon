quran[6]{c,v,t}:
  109,1,"Proclaim, (O dear prophet Mohammed – peace and blessings be upon him), “O disbelievers!”"
  109,2,"Neither do I worship what you worship."
  109,3,"Nor do you worship Whom I worship."
  109,4,"And neither will I ever worship what you worship."
  109,5,"Nor will you worship Whom I worship."
  109,6,"For you is your religion, and for me is mine."
