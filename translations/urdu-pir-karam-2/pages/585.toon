quran[42]{c,v,t}:
  80,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  80,2,"چیں بہ جبیں ہوئے اور منہ پھیر لیا ( 1 ) ۔"
  80,3,"۔( اس وجہ سے کہ ) ان کے پاس ایک نابینا آیا ( 2 ) ۔"
  80,4,"اور آپ کیا جانیں شاید وہ پاکیزہ تر ہو جاتا ( 3 ) ۔"
  80,5,"یا وہ غور و فکر کرتا تو نفع پہنچاتی اسے یہ نصیحت ( 4 ) ۔"
  80,6,"لیکن وہ جو پروا نہیں کرتا ۔"
  80,7,"آپ اس کی طرف تو توجہ کرتے ہیں ۔"
  80,8,"اور آپ پر کوئی ضرر نہیں اگر وہ نہ سدھرے ۔"
  80,9,"اور جو آپ کے پاس آیا ہے دوڑتا ہوا ۔"
  80,10,"اور وہ ڈر بھی رہا ہے ۔"
  80,11,"تو آپ اس سے بے رخی برتتے ہیں ( 5 ) ۔"
  80,12,"ایسا نہ چاہیے یہ تو نصیحت ہے ۔"
  80,13,"سو جس کا جی چاہے اسے قبول کر لے ( 6 ) ۔"
  80,14,"یہ ایسے صحیفوں میں ( ثبت ) ہے جو معزز ہیں ۔"
  80,15,"جو بلند مرتبہ پاکیزہ ہیں ( 7 ) ۔"
  80,16,"ایسے کاتبوں کے ہاتھوں سے لکھے ہیں ۔"
  80,17,"جو بڑے بزرگ اور نیکوکار ہیں ( 8 ) ۔"
  80,18,"غارت ہو ( منکر ) انسان ! ( 9 ) وہ کتنا احسان فراموش ہے ( 10 ) ۔"
  80,19,"کسی چیز سے اللہ نے اسے پیدا کیا ۔"
  80,20,"ایک بوند سے اسے پیدا کیا پھر اس کی ہر چیز اندازہ سے بنائی ( 11 ) ۔"
  80,21,"پھر زندگی کی راہ اس پر آسان کر دی ( 12 ) ۔"
  80,22,"پھر اسے موت دی اور اسے قبر میں پہنچا دیا ( 13 ) ۔"
  80,23,"پھر جب چاہے گا اسے دوبارہ زندہ کر دے گا ( 14 ) ۔"
  80,24,"یقیناً وہ بجا نہ لایا جو اللہ نے اسے حکم دیا تھا ( 15 ) ۔"
  80,25,"پھر ذرا انسان غور سے دیکھے اپنی غذا کو ۔"
  80,26,"بیشک ہم نے زور سے پانی برسایا ۔"
  80,27,"پھر اچھی طرح پھاڑا زمین کو ۔"
  80,28,"پھر ہم نے اگایا اس میں غلہ ۔"
  80,29,"اور انگور اور ترکاریاں ۔"
  80,30,"اور زیتون اور کھجوریں ۔"
  80,31,"اور گھنے باغات ۔"
  80,32,"اور ( طرح طرح کے ) پھل اور گھاس ۔"
  80,33,"سامان زیست تمہارے لیے اور تمہارے مویشیوں کے لیے ( 16 ) ۔"
  80,34,"پھر جب کان بہرا کرنے والا شور اٹھے گا ( 17 ) ۔"
  80,35,"اس دن آدمی بھاگے گا اپنے بھائی سے ۔"
  80,36,"اور اپنی ماں سے اور اپنے باپ سے ۔"
  80,37,"اور اپنی بیوی سے اور اپنے بچوں سے ۔"
  80,38,"ہر شخص کو ان میں سے اس دن ایسی فکر لاحق ہو گی جو اسے ( سب سے ) بے پروا کر دے گی ( 18 ) ۔"
  80,39,"کتنے ہی چہرے اس دن ( نور ایمان سے ) چمک رہے ہوں گے ۔"
  80,40,"ہنستے ہوئے خوش و خرم ( 19 ) ۔"
  80,41,"اور کئی منہ اس دن غبار آلود ہوں گے ۔"
  80,42,"ان پر کالک لگی ہو گی ۔"
