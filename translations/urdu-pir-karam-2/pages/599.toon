quran[18]{c,v,t}:
  98,8,"ان کی جزا ان کے پروردگار کے ہاں ہمیشگی کی جنتیں ہیں ، رواں ہوں گی جن کے نیچے نہریں ۔ وہ ان میں تا ابد رہیں گے ( 9 ) اللہ تعالیٰ ان سے راضی اور وہ اس سے راضی ( 10 ) یہ ( سعادت ) اس کو ملتی ہے جو اپنے رب سے ڈرتا ہے ( 11 ) ۔"
  99,1,"جب تھرتھرانے لگے گی زمین پوری شدت سے ( 1 ) ۔"
  99,2,"اور باہر پھینک دے گی زمین اپنے بوجھوں ( یعنی دفینوں ) کو ( 2 ) ۔"
  99,3,"اور انسان ( حیران ہو کر ) کہے گا اسے کیا ہو گیا ( 3 ) ۔"
  99,4,"اس روز وہ بیان کر دے گی اپنے سارے حالات ( 4 ) ۔"
  99,5,"کیونکہ آپ کے رب نے اسے ( یونہی ) حکم بھیجا ہے ( 5 ) ۔"
  99,6,"اس روز پلٹ کر آئیں گے لوگ گروہ در گروہ ( 6 ) تاکہ انھیں دکھا دیے جائیں ان کے اعمال ۔"
  99,7,"پس جس نے ذرہ برابر بھی نیکی کی ہو گی وہ اسے دیکھ لے گا ۔"
  99,8,"اور جس نے ذرہ برابر برائی کی ہو گی وہ ( بھی ) اسے دیکھ لے گا ( 7 ) ۔"
  100,1,"قسم ہے تیز دوڑنے والے گھوڑوں کی جب وہ سینہ سے آواز نکالتے ہیں ۔"
  100,2,"پھر پتھروں سے آگ نکالتے ہیں سم مار کر ۔"
  100,3,"پھر اچانک حملہ کرتے ہیں صبح کے وقت ۔"
  100,4,"پھر اس سے گرد و غبار اڑاتے ہیں ۔"
  100,5,"پھر اسی وقت ( دشمن کے ) لشکر میں گھس جاتے ہیں ( 1 ) ۔"
  100,6,"بیشک انسان اپنے رب کا بڑا ناشکر گزار ہے ( 2 ) ۔"
  100,7,"اور وہ اس پر ( خود ) گواہ ہے ( 3 ) ۔"
  100,8,"اور بلاشبہ وہ مال کی محبت میں بڑا سخت ہے ( 4 ) ۔"
  100,9,"کیا وہ اس وقت کو نہیں جانتا جب نکال لیا جائے گا جو کچھ قبروں میں ہے ( 5 ) ۔"
