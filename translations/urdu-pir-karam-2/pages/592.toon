quran[30]{c,v,t}:
  87,16,"اور اپنے رب کے نام کا ذکر کرتا رہا اور نماز پڑھتا رہا ۔"
  87,17,"البتہ تم لوگ دنیوی زندگی کو ترجیح دیتے ہو ( 13 ) ۔"
  87,18,"حالانکہ آخرت کہیں بہتر ہے اس سے اور باقی رہنے والی ہے ۔"
  87,19,"یقیناً یہ ( سب کچھ ) اگلے صحیفوں میں لکھا ہوا ہے ۔"
  88,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  88,2,"کیا پہنچی ہے آپ کو چھا جانے والی آفت کی خبر ( 1 ) ۔"
  88,3,"کتنے ہی چہرے اس دن ذلیل و خوار ہوں گے ( 2 ) ۔"
  88,4,"مشقت میں مبتلا ، تھکے ماندے ۔"
  88,5,"داخل ہوں گے دہکتی ہوئی آگ میں ۔"
  88,6,"انھیں پلایا جائے گا کھولتے ہوئے چشمہ سے ( 3 ) ۔"
  88,7,"انھیں کوئی کھانا نہ ملے گا بجز خاردار جھاڑ کے ( 4 ) ۔"
  88,8,"جو نہ فربہ کرے گا اور نہ بھوک دور کرے گا ( 5 ) ۔"
  88,9,"کتنے ہی چہرے اس دن با رونق ہوں گے ( 6 ) ۔"
  88,10,"اپنی کاوشوں پر خوش ہوں گے ۔"
  88,11,"عالی شان جنت میں ۔"
  88,12,"نہ سنیں گے وہاں کوئی لغو بات ۔"
  88,13,"اس میں چشمہ جاری ہو گا ۔"
  88,14,"اس میں اونچے اونچے تخت ( بچھے ) ہوں گے ۔"
  88,15,"اور ساغر ( قرینے سے ) رکھے ہوں گے ۔"
  88,16,"اور گاؤ تکیے قطار در قطار لگے ہوں گے ۔"
  88,17,"اور قیمتی قالین بچھے ہوں گے ۔"
  88,18,"کیا یہ لوگ ( غور سے ) اونٹ کو نہیں دیکھتے کہ اسے کیسے ( عجیب طرح ) پیدا کیا گیا ہے ( 7 ) ۔"
  88,19,"اور آسمان کی طرف نہیں دیکھتے کہ اسے کیسے بلند کیا گیا ہے ( 8 ) ۔"
  88,20,"اور پہاڑوں کی طرف کہ انھیں کیسے نصب کیا گیا ہے ۔"
  88,21,"اور زمین کی طرف کہ اسے کیسے بچھایا گیا ہے ۔"
  88,22,"پس آپ انھیں سمجھاتے رہا کریں ، آپ کا کام تو سمجھانا ہی ہے ( 9 ) ۔"
  88,23,"آپ ان کو جبر سے منوانے والے تو نہیں ہیں ۔"
  88,24,"مگر جس نے روگردانی کی اور کفر کیا ۔"
  88,25,"تو اللہ اس کو سخت عذاب دے گا ( 10 ) ۔"
  88,26,"بیشک انھیں ( آخر ) ہمارے پاس ہی لوٹ کر آنا ہے ۔"
