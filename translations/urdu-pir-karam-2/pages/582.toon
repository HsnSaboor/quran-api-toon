quran[30]{c,v,t}:
  78,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  78,2,"وہ کس چیز کے بارے میں ایک دوسرے سے پوچھ رہے ہیں ۔"
  78,3,"کیا وہ اس بڑی اور اہم خبر کے بارے میں پوچھ رہے ہیں ( 1 ) ۔"
  78,4,"جس میں وہ اختلاف کرتے رہتے ہیں ( 2 ) ۔"
  78,5,"یقینا وہ اسے جان لیں گے ۔"
  78,6,"پھر یقینا وہ اسے جان لیں گے ( کہ قیامت برحق ہے ) ( 3 ) ۔"
  78,7,"کیا ہم نے نہیں بنا دیا زمین کو بچھونا ( 4 ) ۔"
  78,8,"اور پہاڑوں کو میخیں ( 5 ) ۔"
  78,9,"اور ہم نے پیدا کیا ہے تمہیں جوڑا جوڑا ( 6 ) ۔"
  78,10,"اور ہم نے بنا دیا ہے تمہاری نیند کو باعث آرام ( 7 ) ۔"
  78,11,"نیز ہم نے بنا دیا رات کو پردہ پوش ( 8 ) ۔"
  78,12,"اور ہم نے دن کو روزی کمانے کے لیے بنایا ( 9 ) ۔"
  78,13,"اور ہم نے بنائے تمہارے اوپر سات مضبوط ( آسمان ) ( 10 ) ۔"
  78,14,"اور ہم نے ہی ایک نہایت روشن چراغ بنایا ( 11 ) ۔"
  78,15,"اور ہم نے برسایا بادلوں سے موسلا دھار پانی ( 12 ) ۔"
  78,16,"تاکہ ہم اگائیں اس کے ذریعہ اناج اور سبزی ۔"
  78,17,"نیز گھنے باغات ( 13 ) ۔"
  78,18,"بیشک فیصلہ کا دن ایک معین وقت ہے ( 14 ) ۔"
  78,19,"جس روز صور پھونکا جائے گا تو تم چلے آؤ گے فوج در فوج ( 15 ) ۔"
  78,20,"اور کھول دیا جائے گا آسمان تو وہ دروازے ہی دروازے بن کر رہ جائے گا ( 16 ) ۔"
  78,21,"اور حرکت دی جائے گی پہاڑوں کو تو وہ سراب بن جائیں گے ( 17 ) ۔"
  78,22,"درحقیقت جہنم ایک گھات ہے ( 18 ) ۔"
  78,23,"۔( یہ ) سرکشوں کا ٹھکانا ہے ( 19 ) ۔"
  78,24,"پڑے رہیں گے اس میں عرصہ دراز ( 20 ) ۔"
  78,25,"وہ نہیں چکھیں گے اس میں کوئی ٹھنڈی چیز اور نہ پانی ۔"
  78,26,"بجز کھولتے پانی اور گرم پیپ کے ( 21 ) ۔"
  78,27,"۔( ان کے گناہوں کی ) پوری سزا ۔"
  78,28,"یہ لوگ ( روز ) حساب کی توقع ہی نہیں رکھتے تھے ۔"
  78,29,"اور انھوں نے ہماری آیتوں کو سختی سے جھٹلایا ( 22 ) ۔"
  78,30,"حالانکہ ہر چیز کو ہم نے گن گن کر لکھ لیا تھا ۔"
