quran[28]{c,v,t}:
  74,48,"یہاں تک کہ ہمیں موت نے آ لیا ۔"
  74,49,"پس انھیں کوئی فائدہ نہ پہنچائے گی شفاعت کرنے والوں کی شفاعت ( 31 ) ۔"
  74,50,"پس انھیں کیا ہو گیا ہے کہ وہ اس نصیحت سے روگرداں ہیں ۔"
  74,51,"گویا وہ بھڑکے ہوئے جنگلی گدھے ہیں ۔"
  74,52,"جو بھاگے جا رہے ہیں شیر سے ( 32 ) ۔"
  74,53,"بلکہ ان میں سے ہر شخص چاہتا ہے کہ ان کو کھلے ہوئے صحیفے دیے جائیں ( 33 ) ۔"
  74,54,"ایسا ہرگز نہیں ہو گا ، دراصل وہ آخرت سے ڈرتے ہی نہیں ( 34 ) ۔"
  74,55,"ہاں ہاں یہ قرآن تو نصیحت ہے ( 35 ) ۔"
  74,56,"پس جس کا جی چاہے نصیحت حاصل کرے ۔"
  75,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  75,2,"میں قسم کھاتا ہوں روز قیامت کی ( 1 ) ۔"
  75,3,"اور میں قسم کھاتا ہوں نفس لوامہ کی ( کہ حشر ضرور ہو گا ) ( 2 ) ۔"
  75,4,"کیا انسان یہ خیال کرتا ہے کہ ہم ہرگز جمع نہ کریں گے اس کی ہڈیوں کو ۔"
  75,5,"کیوں نہیں ہم اس پر بھی قادر ہیں کہ ہم اس کی انگلیوں کی پور پور درست کر دیں ( 4 ) ۔"
  75,6,"بلکہ انسان کی خواہش تو یہ ہے کہ آئندہ بھی بدکاریاں کرتا رہے ( 5 ) ۔"
  75,7,"۔( ازراہ تمسخر ) وہ پوچھتا ہے قیامت کب آئے گی ( 6 ) ۔"
  75,8,"پھر جب آنکھ خیرہ ہو جائے گی ( 7 ) ۔"
  75,9,"اور چاند بے نور ہو جائے گا ( 8 ) ۔"
  75,10,"اور ( بے نوری میں ) سورج اور چاند یکساں ہو جائیں گے ۔"
  75,11,"۔( اس روز ) انسان کہے گا کہ بھاگنے کی جگہ کہاں ہے ( 9 ) ۔"
  75,12,"ہرگز نہیں ، وہاں کوئی پناہ گاہ نہیں ۔"
  75,13,"صرف آپ کے رب کے پاس ہی اس روز ٹھکانا ہو گا ۔"
  75,14,"آگاہ کر دیا جائے گا انسان کو اس روز جو عمل اس نے پہلے بھیجے اور جو ( اثرات ) وہ پیچھے چھوڑ آیا ( 10 ) ۔"
  75,15,"بلکہ انسان خود بھی اپنے نفس کے احوال پر نظر رکھتا ہے ۔"
  75,16,"خواہ وہ ( زبان سے ہزار ) بہانے بناتا رہے ( 11 ) ۔"
  75,17,"۔( اے حبیب ! ) آپ حرکت نہ دیں اپنی زبان کو اس کے ساتھ تاکہ آپ جلدی یاد کر لیں اس کو ( 12 ) ۔"
  75,18,"ہمارے ذمہ ہے اس کو ( سینہ مبارک میں ) جمع کرنا اور اس کو پڑھانا ۔"
  75,19,"پس جب ہم اسے پڑھیں تو آپ اتباع کریں اسی پڑھنے کا ۔"
