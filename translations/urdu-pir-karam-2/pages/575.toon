quran[18]{c,v,t}:
  73,20,"یقینا یہ ( قرآن ) نصیحت ہے ( 17 ) پس اب جس کا جی چاہے اختیار کر لے اپنے رب کی طرف سیدھا راستہ ۔"
  74,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  74,2,"اے چادر لپیٹنے والے ( 1 ) ۔"
  74,3,"اٹھیے اور ( لوگوں کو ) ڈرائیے ( 2 ) ۔"
  74,4,"اور اپنے پروردگار کی بڑائی بیان کیجیے ( 3 ) ۔"
  74,5,"اور اپنے لباس کو پاک رکھیے ( 4 ) ۔"
  74,6,"اور بتوں سے ( حسب سابق ) دور رہیے ( 5 ) ۔"
  74,7,"اور کسی پر احسان نہ کیجیے زیادہ لینے کی نیت سے ( 6 ) ۔"
  74,8,"اور اپنے رب ( کی رضا ) کے لیے صبر کیجیے ( 7 ) ۔"
  74,9,"پھر جب صور پھونکا جائے گا ( 8 ) ۔"
  74,10,"تو وہ دن بڑا سخت دن ہو گا ۔"
  74,11,"کفار پر آسان نہ ہو گا ۔"
  74,12,"آپ چھوڑ دیجیے مجھے اور جس کو میں نے تنہا پیدا کیا ہے ( 9 ) ۔"
  74,13,"اور دے دیا ہے اس کو مال کثیر ۔"
  74,14,"اور بیٹے دیے ہیں جو پاس رہنے والے ہیں ۔"
  74,15,"اور مہیا کر دیا ہے اسے ہر قسم کا سامان ( 10 ) ۔"
  74,16,"پھر طمع کرتا ہے کہ میں اسے مزید عطا کروں ( 11 ) ۔"
  74,17,"ہرگز نہیں ( 12 ) وہ ہماری آیتوں کا سخت دشمن ہے ۔"
