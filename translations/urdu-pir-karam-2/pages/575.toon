quran[18]{c,v,t}:
  73,20,"بیشک آپ کا رب جانتا ہے کہ آپ ( نماز میں ) قیام کرتے ہیں کبھی دو تہائی رات کے قریب ، کبھی نصف رات اور کبھی تہائی رات اور ایک جماعت ان سے جو آپ کے ساتھ ہیں ، وہ بھی ( یونہی قیام کرتے ہیں ) ( 18 ) اور اللہ تعالیٰ ہی چھوٹا بڑا کرتا رہتا ہے رات اور دن کو ۔ وہ یہ بھی جانتا ہے کہ تم اس کی طاقت نہیں رکھتے تو اس نے تم پر مہربانی فرمائی ۔ پس تم اتنا قرآن پڑھ لیا کرو جتنا تم آسانی سے پڑھ سکتے ہو ( 19 ) وہ یہ بھی جانتا ہے کہ تم میں سے کچھ بیمار ہوں گے اور کچھ سفر کرتے ہوں گے زمین میں ، تلاش کر رہے ہوں گے اللہ کے فضل ( رزق حلال ) کو ( 20 ) اور کچھ لوگ اللہ کی راہ میں لڑتے ہوں گے ۔ تو پڑھ لیا کرو قرآن سے جتنا آسان ہو ( 21 ) اور نماز قائم کرو اور زکوۃ ادا کرو ( 22 ) اور اللہ کو قرض حسنہ دیتے رہا کرو ( 23 ) اور جو ( نیکی ) تم آگے بھیجو گے اپنے لیے ( 24 ) تو اسے اللہ کے پاس موجود پاؤ گے ، یہی بہتر ہے اور ( اس کا ) اجر بہت بڑا ہو گا ( 25 ) اور مغفرت طلب کیا کرو اللہ تعالیٰ سے ( 26 ) بیشک اللہ تعالیٰ غفور رحیم ہے ۔"
  74,1,"اے چادر لپیٹنے والے ( 1 ) ۔"
  74,2,"اٹھیے اور ( لوگوں کو ) ڈرائیے ( 2 ) ۔"
  74,3,"اور اپنے پروردگار کی بڑائی بیان کیجیے ( 3 ) ۔"
  74,4,"اور اپنے لباس کو پاک رکھیے ( 4 ) ۔"
  74,5,"اور بتوں سے ( حسب سابق ) دور رہیے ( 5 ) ۔"
  74,6,"اور کسی پر احسان نہ کیجیے زیادہ لینے کی نیت سے ( 6 ) ۔"
  74,7,"اور اپنے رب ( کی رضا ) کے لیے صبر کیجیے ( 7 ) ۔"
  74,8,"پھر جب صور پھونکا جائے گا ( 8 ) ۔"
  74,9,"تو وہ دن بڑا سخت دن ہو گا ۔"
  74,10,"کفار پر آسان نہ ہو گا ۔"
  74,11,"آپ چھوڑ دیجیے مجھے اور جس کو میں نے تنہا پیدا کیا ہے ( 9 ) ۔"
  74,12,"اور دے دیا ہے اس کو مال کثیر ۔"
  74,13,"اور بیٹے دیے ہیں جو پاس رہنے والے ہیں ۔"
  74,14,"اور مہیا کر دیا ہے اسے ہر قسم کا سامان ( 10 ) ۔"
  74,15,"پھر طمع کرتا ہے کہ میں اسے مزید عطا کروں ( 11 ) ۔"
  74,16,"ہرگز نہیں ( 12 ) وہ ہماری آیتوں کا سخت دشمن ہے ۔"
  74,17,"میں اسے مجبور کروں گا کہ وہ کٹھن چڑھائی چڑھے ( 13 ) ۔"
