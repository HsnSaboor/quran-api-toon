quran[17]{c,v,t}:
  103,1,"قسم ہے زمانہ کی ( 1 ) ۔"
  103,2,"یقیناً ہر انسان خسارہ میں ہے ( 2 ) ۔"
  103,3,"بجز ان ( خوش نصیبوں ) کے جو ایمان لے آئے اور نیک عمل کرتے رہے ( 3 ) نیز ایک دوسرے کو حق کی تلقین کرتے رہے اور ایک دوسرے کو صبر کی تاکید کرتے رہے ( 4 ) ۔"
  104,1,"ہلاکت ہے ہر اس شخص کے لیے جو ( روبرو ) طعنے دیتا ہے ( پیٹھ پیچھے ) عیب جوئی کرتا ہے ( 1 ) ۔"
  104,2,"جس نے مال جمع کیا اور اسے گن گن کر رکھتا ہے ( 2 ) ۔"
  104,3,"وہ یہ خیال کرتا ہے کہ اس کے مال نے اسے لافانی بنا دیا ہے ( 3 ) ۔"
  104,4,"ہرگز نہیں وہ یقیناً حطمہ میں پھینک دیا جائے گا ( 4 ) ۔"
  104,5,"اور تم کیا جانو کہ حطمہ کیا ہے ۔"
  104,6,"وہ اللہ کی آگ ہے خوب بھڑکائی ہوئی ( 5 ) ۔"
  104,7,"جو دلوں تک جا پہنچے گی ( 6 ) ۔"
  104,8,"بیشک وہ ( آگ ) ان پر بند کر دی جائے گی ( 7 ) ۔"
  104,9,"۔( اس کے شعلے ) لمبے لمبے ستونوں کی صورت میں ہوں گے ( 8 ) ۔"
  105,1,"کیا آپ نے ملاحظہ نہیں کیا کہ آپ کے رب نے ( 1 ) ہاتھی والوں کے ساتھ کیسا سلوک کیا ( 2 ) ۔"
  105,2,"کیا اللہ تعالیٰ نے ان کے مکر و فریب کو ناکام نہیں بنا دیا ( 3 ) ۔"
  105,3,"اور ( وہ یوں کہ ) بھیج دیے ان پر ہر سمت سے پرندے ، ڈاروں کے ڈار ۔"
  105,4,"جو برساتے تھے ان پر کنکر کی پتھریاں ( 4 ) ۔"
  105,5,"پس بنا ڈالا ان کو جیسے کھایا ہوا بھوسہ ( 5 ) ۔"
