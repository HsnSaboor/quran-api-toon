quran[17]{c,v,t}:
  103,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  103,2,"قسم ہے زمانہ کی ( 1 ) ۔"
  103,3,"یقیناً ہر انسان خسارہ میں ہے ( 2 ) ۔"
  104,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  104,2,"ہلاکت ہے ہر اس شخص کے لیے جو ( روبرو ) طعنے دیتا ہے ( پیٹھ پیچھے ) عیب جوئی کرتا ہے ( 1 ) ۔"
  104,3,"جس نے مال جمع کیا اور اسے گن گن کر رکھتا ہے ( 2 ) ۔"
  104,4,"وہ یہ خیال کرتا ہے کہ اس کے مال نے اسے لافانی بنا دیا ہے ( 3 ) ۔"
  104,5,"ہرگز نہیں وہ یقیناً حطمہ میں پھینک دیا جائے گا ( 4 ) ۔"
  104,6,"اور تم کیا جانو کہ حطمہ کیا ہے ۔"
  104,7,"وہ اللہ کی آگ ہے خوب بھڑکائی ہوئی ( 5 ) ۔"
  104,8,"جو دلوں تک جا پہنچے گی ( 6 ) ۔"
  104,9,"بیشک وہ ( آگ ) ان پر بند کر دی جائے گی ( 7 ) ۔"
  105,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  105,2,"کیا آپ نے ملاحظہ نہیں کیا کہ آپ کے رب نے ( 1 ) ہاتھی والوں کے ساتھ کیسا سلوک کیا ( 2 ) ۔"
  105,3,"کیا اللہ تعالیٰ نے ان کے مکر و فریب کو ناکام نہیں بنا دیا ( 3 ) ۔"
  105,4,"اور ( وہ یوں کہ ) بھیج دیے ان پر ہر سمت سے پرندے ، ڈاروں کے ڈار ۔"
  105,5,"جو برساتے تھے ان پر کنکر کی پتھریاں ( 4 ) ۔"
