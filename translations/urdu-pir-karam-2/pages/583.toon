quran[25]{c,v,t}:
  78,31,"بلاشبہ پرہیزگاروں کے لیے کامیابی ( ہی کامیابی ) ہے ۔"
  78,32,"۔( ان کے لیے ) باغات اور انگوروں ( کی بیلیں ) ہیں ۔"
  78,33,"اور جواں سال ہم عمر لڑکیاں ۔"
  78,34,"اور چھلکتا ہوا جام ( 24 ) ۔"
  78,35,"نہ سنیں گے وہاں کوئی بیہودہ بات اور نہ جھوٹ ۔"
  78,36,"یہ بدلہ ہے آپ کے رب کی طرف سے بڑا کافی انعام ( 25 ) ۔"
  78,37,"جو پروردگار ہے آسمانوں کا اور زمین کا اور جو کچھ ان کے درمیان ہے ، بے حد مہربان ( 26 ) انھیں طاقت نہ ہو گی کہ ( بغیر اجازت ) اس سے بات بھی کہہ سکیں ( 27 ) ۔"
  78,38,"جس روز روح اور فرشتے پرے باندھ کر کھڑے ہوں گے ( 28 ) کوئی نہ بول سکے گا بجز اس کے جس کو رحمن اذن دے اور وہ ٹھیک بات کرے ( 29 ) ۔"
  78,39,"یہ دن برحق ہے ، سو جس کا جی چاہے بنا لے اپنے رب کے جوار رحمت میں اپنا ٹھکانا ( 30 ) ۔"
  78,40,"بیشک ہم نے ڈرا دیا ہے تمہیں جلد آنے والے عذاب سے ۔ اس دن دیکھ لے گا ہر شخص ( ان عملوں کو ) جو اس نے آگے بھیجے تھے اور کافر ( بصد حسرت ) کہے گا کاش ! میں خاک ہوتا ( 31 ) ۔"
  79,1,"قسم ہے ( فرشتوں کی ) جو غوطہ لگا کر ( جان ) کھینچنے والے ہیں ( 1 ) ۔"
  79,2,"اور بند آسانی سے کھولنے والے ہیں ( 2 ) ۔"
  79,3,"اور تیزی سے پیرنے والے ہیں ( 3 ) ۔"
  79,4,"پھر ( تعمیل ارشاد میں ) جو دوڑ کر سبقت لے جانے والے ہیں ( 4 ) ۔"
  79,5,"پھر ( حسب حکم ) ہر کام کا انتظام کرنے والے ہیں ( 5 ) ۔"
  79,6,"جس روز تھرتھرائے گی تھرتھرانے والی ( 6 ) ۔"
  79,7,"اس کے پیچھے ایک اور جھٹکا ہو گا ( 7 ) ۔"
  79,8,"کتنے دل اس روز ( خوف سے ) کانپ رہے ہوں گے ۔"
  79,9,"ان کی آنکھیں ( ڈر سے ) جھکی ہوں گی ( 8 ) ۔"
  79,10,"کافر کہتے ہیں کیا ہم پلٹائے جائیں گے الٹے پاؤں ( 9 ) ۔"
  79,11,"۔( یعنی جب ) ہم بوسیدہ ہڈیاں بن چکے ہوں گے ( 10 ) ۔"
  79,12,"بولے یہ واپسی تو بڑے گھاٹے کی ہو گی ( 11 ) ۔"
  79,13,"۔( پس اس واپسی کے لیے ) تو فقط ایک جھڑک کافی ہے ۔"
  79,14,"پھر وہ فوراً کھلے میدان میں جمع ہو جائیں گے ( 12 ) ۔"
  79,15,"۔( اے حبیب ! ) کیا پہنچی ہے آپ کو موسیٰ کی خبر ؟"
