quran[27]{c,v,t}:
  55,68,"پس تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,69,"ان میں میوے ہوں گے اور کھجوریں اور انار ہوں گے ۔"
  55,70,"پس تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,71,"ان میں اچھی سیرت والیاں اچھی صورت والیاں ہوں گی ( 45 ) ۔"
  55,72,"پس ( اے جن و انس ! ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,73,"یہ حوریں ، پردہ دار خیموں میں ( 46 ) ۔"
  55,74,"پس ( اے جن و انس ! ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,75,"ان کو بھی اب تک نہ کسی انسان نے چھوا ہو گا اور نہ کسی جن نے ۔"
  55,76,"پس تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,77,"وہ تکیہ لگائے بیٹھے ہوں گے سبز مسند پر جو ازحد نفیس ، بہت خوبصورت ہو گی ( 47 ) ۔"
  55,78,"پس ( اے انسانو اور جنو ! ) تم دونوں اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  56,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  56,2,"جب قیامت برپا ہو جائے گی ( 1 ) ۔"
  56,3,"نہیں ہو گا جب یہ برپا ہو گی ( اسے ) کوئی جھٹلانے والا ( 2 ) ۔"
  56,4,"کسی کو پست کرنے والی کسی کو بلند کرنے والی ( 3 ) ۔"
  56,5,"جب زمین تھر تھر کانپے گی ( 4 ) ۔"
  56,6,"اور ٹوٹ پھوٹ کر پہاڑ ریزہ ریزہ ہو جائیں گے ۔"
  56,7,"پھر غبار بن کر بکھر جائیں گے ( 5 ) ۔"
  56,8,"اور تم لوگ تین گروہوں میں بانٹ دیے جاؤ گے ( 6 ) ۔"
  56,9,"پس ( ایک گروہ ) دائیں ہاتھ والوں کا ہو گا ، کیا شان ہو گی دائیں ہاتھ والوں کی ۔"
  56,10,"اور ( دوسرا گرو ) بائیں ہاتھ والوں کا ہو گا ، کیا ( خستہ ) حال ہو گا بائیں ہاتھ والوں کا ۔"
  56,11,"اور ( تیسرا گروہ ہر کار خیر میں ) آگے رہنے والوں کا ، وہ ( اس روز بھی ) آگے آگے ہوں گے ۔"
  56,12,"وہی مقرب بارگاہ ہیں ۔"
  56,13,"عیش و سرور کے باغوں میں ۔"
  56,14,"ایک بڑی جماعت پہلوں سے ( 7 ) ۔"
  56,15,"اور قلیل تعداد پچھلوں سے ( 8 ) ۔"
  56,16,"ان پلنگوں پر جو سونے کی تاروں سے بنے ہوں گے ( 9 ) ۔"
