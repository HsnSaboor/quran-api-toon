quran[20]{c,v,t}:
  15,71,"آپ نے کہا یہ میری ( قوم کی ) بچیاں ہیں اگر تم کچھ کرنا چاہتے ہو ( تو ان سے نکاح کر لو ) ( 45 ) ۔"
  15,72,"۔( اے محبوب ) آپ کی زندگی کی قسم ( 46 ) یہ ( اپنی طاقت کے نشہ میں ) مست ہیں ( اور ) بہکے بہکے پھر رہے ہیں ۔"
  15,73,"پس آ لیا ان کو ایک سخت کڑک نے جب سورج نکل رہا تھا ( 47 ) ۔"
  15,74,"پس ہم نے ان کی بستی کو زیر و زبر کر دیا اور ہم نے برسائے ان پر کھنگر کے پتھر ۔"
  15,75,"بیشک اس واقعہ میں ( عبرت کی ) نشانیاں ہیں غور و فکر کرنے والوں کے لیے ( 48 ) ۔"
  15,76,"اور بیشک یہ بستی ایک آباد راستہ پر واقع ہے ( 49 ) ۔"
  15,77,"یقیناً اس میں نشانی ہے اہل ایمان کے لیے ۔"
  15,78,"اور بیشک ایکہ کے باشندے بھی بڑے ظالم تھے ( 50 ) ۔"
  15,79,"پس ہم نے ان سے بھی انتقام لیا اور یہ دونوں بستیاں کھلی شاہراہ پر واقع ہیں ( 51 ) ۔"
  15,80,"اور بیشک جھٹلایا اہل حجر نے ( اللہ تعالیٰ کے ) رسولوں کو ( 52 ) ۔"
  15,81,"اور ہم نے عطا کیں انھیں اپنی نشانیاں ( 53 ) مگر وہ ان سے روگردانی ہی کرتے رہے ۔"
  15,82,"اور وہ کھود کر بنایا کرتے تھے پہاڑوں کو اپنے گھر ( اور ) وہ بے خوف و خطر رہا کرتے تھے ۔"
  15,83,"پس پکڑ لیا انھیں ایک خوفناک چنگھاڑ نے جب وہ صبح اٹھ رہے تھے ۔"
  15,84,"پس نہ فائدہ پہنچایا انھیں اس ( مال ) نے جو وہ کمایا کرتے تھے ( 54 ) ۔"
  15,85,"اور نہیں پیدا فرمایا ہم نے آسمانوں اور زمین کو نیز جو کچھ ان کے درمیان ہے ، مگر حق کے ساتھ ( 55 ) اور بیشک قیامت آنے ہی والی ہے پس ( اے حبیب ! ) ( 56 ) آپ درگزر فرمایا کیجیے ان سے عمدگی کے ساتھ ۔"
  15,86,"یقیناً آپ کا رب ہی سب کا خالق ( اور ) سب کچھ جاننے والا ہے ۔"
  15,87,"اور بیشک ہم نے عطا فرمائی ہیں آپ کو سات آیتیں جو بار بار پڑھی جاتی ہیں ( 57 ) اور قرآن عظیم بھی ۔"
  15,88,"اپنی آنکھ اٹھا کر بھی نہ دیکھئے ان ( اموال ) کی طرف جن سے ہم نے لطف اندوز کیا ہے ان کے مختلف طبقوں کو ( 58 ) اور رنجیدہ خاطر بھی نہ ہوں ان ( کی گمراہی ) پر ( 59 ) اور نیچے کیجیے اپنے پروں کو مومنوں کے لیے ( 60 ) ۔"
  15,89,"اور فرمائیے کہ میں تو بلاشبہ ایسے عذاب سے کھلا ڈرانے والا ہوں ( 61 ) ۔"
  15,90,"جیسے ہم نے اتارا ان بانٹنے والوں پر ( 62 ) ۔"
