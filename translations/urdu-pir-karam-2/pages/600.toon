quran[21]{c,v,t}:
  100,10,"کیا وہ اس وقت کو نہیں جانتا جب نکال لیا جائے گا جو کچھ قبروں میں ہے ( 5 ) ۔"
  100,11,"اور ظاہر کر دیا جائے گا جو سینوں میں ( پوشیدہ ) ہے ( 6 ) ۔"
  101,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  101,2,"۔( دل دہلا دینے والی ) کڑک ۔"
  101,3,"یہ ( زہرہ گداز ) کڑک کیا ہے ؟"
  101,4,"اور آپ کو کیا معلوم کہ یہ کڑک کیا ہے ( 1 ) ۔"
  101,5,"جس دن لوگ بکھرے ہوئے پروانوں کی طرح ہوں گے ( 2 ) ۔"
  101,6,"اور پہاڑ رنگ برنگی دھنکی ہوئی اون کی مانند ہوں گے ( 3 ) ۔"
  101,7,"پھر جس کے ( نیکیوں کے ) پلڑے بھاری ہوں گے ( 4 ) ۔"
  101,8,"تو وہ دل پسند عیش ( و مسرت ) میں ہو گا ۔"
  101,9,"اور جس کے ( نیکیوں کے ) پلڑے ہلکے ہوں گے ( 5 ) ۔"
  101,10,"تو اس کا ٹھکانا ہاویہ ہو گا ۔"
  101,11,"اور آپ کو کیا معلوم کہ وہ ہاویہ کیا ہے ؟"
  102,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  102,2,"غافل رکھا تمہیں زیادہ سے زیادہ مال جمع کرنے کی ہوس نے ( 1 ) ۔"
  102,3,"یہاں تک کہ تم قبروں میں جا پہنچے ( 2 ) ۔"
  102,4,"ہاں ہاں تم جلد جان لو گے ( 3 ) ۔"
  102,5,"پھر ہاں ہاں ! تمہیں ( اپنی کوششوں کا انجام ) جلد معلوم ہو جائے گا ( 4 ) ۔"
  102,6,"ہاں ! ہاں ! اگر تم ( اس انجام کو ) یقینی طور سے جانتے ( تو ایسا ہرگز نہ کرتے ) ( 5 ) ۔"
  102,7,"تم دیکھ کر رہو گے دوزخ کو ۔"
  102,8,"پھر آخرت میں تم دوزخ کو یقین کی آنکھ سے دیکھ لو گے ( 6 ) ۔"
