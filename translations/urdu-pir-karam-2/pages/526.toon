quran[26]{c,v,t}:
  53,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  53,2,"قسم ہے اس ( تابندہ ) ستارے کی جب وہ نیچے اترا ( 1 ) ۔"
  53,3,"تمہارا ( زندگی بھر کا ) ساتھی نہ راہ حق سے بھٹکا اور نہ بہکا ( 2 ) ۔"
  53,4,"اور وہ تو بولتا ہی نہیں اپنی خواہش سے ( 3 ) ۔"
  53,5,"نہیں ہے یہ مگر وحی جو ان کی طرف کی جاتی ہے ۔ ( 4 )"
  53,6,"انھیں سکھایا ہے زبردست قوتوں والے نے ۔ ( 5 )"
  53,7,"بڑے دانا نے ۔ ( 6 ) پھر اس نے ( بلندیوں کا ) قصد کیا ۔ ( 7 ) ۔"
  53,8,"اور وہ سب سے اونچے کنارہ پر تھا ( 8 ) ۔"
  53,9,"پھر وہ قریب ہوا ، اور قریب ہوا ۔ ( 9 )"
  53,10,"یہاں تک کہ صرف دو کمانوں کے برابر بلکہ اس سے بھی کم فاصلہ رہ گیا ۔ ( 10 )"
  53,11,"پس وحی کی اللہ نے اپنے ( محبوب ) بندے کی طرف جو وحی کی ۔ ( 11 )"
  53,12,"نہ جھٹلایا دل نے جو دیکھا ( چشم مصطفی ) نے ۔ ( 12 )"
  53,13,"کیا تم جھگڑتے ہو ان سے اس پر جو انھوں نے دیکھا ۔ ( 13 )"
  53,14,"اور انھوں نے تو اسے دوبارہ بھی دیکھا ۔ ( 14 )"
  53,15,"سدرۃ المنتہیٰ کے پاس ۔ ( 15 )"
  53,16,"اس کے پاس ہی جنت الماوی ہے ۔ ( 16 )"
  53,17,"جب سدرہ پر چھا رہا تھا جو چھا رہا تھا ۔ ( 17 )"
  53,18,"نہ درماندہ ہوئی چشم ( مصطفی ) اور نہ ( حد ادب سے ) آگے بڑھی ۔ ( 18 )"
  53,19,"یقیناً انھوں نے اپنے رب کی بڑی بڑی نشانیاں دیکھیں ۔ ( 19 )"
  53,20,"۔( اے کفار ! ) کبھی تم نے غور کیا لات و عزی کے بارے میں ۔ ( 20 )"
  53,21,"اور مناۃ کے بارے میں جو تیسری ہے ۔"
  53,22,"کیا تمہارے لیے تو بیٹے ہیں اور اللہ کے لیے نری بیٹیاں ۔"
  53,23,"یہ تقسیم تو بڑی ظالمانہ ہے ۔ ( 21 )"
  53,24,"نہیں ہیں یہ مگر محض نام جو رکھ لیے ہیں تم نے اور تمہارے باپ دادا نے ، نہیں نازل کی اللہ نے ان کے بارے میں کوئی سند ۔ ( 22 ) ۔ نہیں پیروی کر رہے یہ لوگ مگر گمان کی اور جسے ان کے نفس چاہتے ہیں ۔ ( 23 ) حالانکہ آ گئی ہے ان کے پاس ان کے رب کی طرف سے ہدایت ۔ ( 24 )"
  53,25,"کیا انسان کو ہر وہ چیز مل جاتی ہے جس کی وہ تمنا کرتا ہے ۔"
  53,26,"پس اللہ کے دست قدرت میں ہے آخرت اور دنیا ۔ ( 25 )"
