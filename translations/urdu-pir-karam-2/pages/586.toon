quran[29]{c,v,t}:
  81,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  81,2,"۔( یاد کرو ) جب سورج لپیٹ دیا جائے گا ( 1 ) ۔"
  81,3,"اور جب ستارے بکھر جائیں گے ( 2 ) ۔"
  81,4,"اور جب پہاڑوں کو اکھیڑ دیا جائے گا ( 3 ) ۔"
  81,5,"اور جب دس ماہ کی گابھن اونٹنیاں چھٹی پھریں گی ( 4 ) ۔"
  81,6,"اور جب وحشی جانور یکجا کر دیے جائیں گے ( 5 ) ۔"
  81,7,"اور جب سمندر بھڑکا دیے جائیں گے ( 6 ) ۔"
  81,8,"اور جب جانیں ( جسموں سے ) جوڑی جائیں گی ( 7 ) ۔"
  81,9,"اور جب زندہ درگور کی ہوئی ( بچی ) سے پوچھا جائے گا ( 8 ) ۔"
  81,10,"کہ وہ کس گناہ کے باعث ماری گئی ۔"
  81,11,"اور جب اعمال نامے کھولے جائیں گے ۔"
  81,12,"اور جب آسمان کی کھال ادھیڑ لی جائے گی ( 9 ) ۔"
  81,13,"اور جب جہنم دہکائی جائے گی ۔"
  81,14,"اور جب جنت قریب کر دی جائے گی ۔"
  81,15,"۔( تو اس دن ) ہر شخص جان لے گا کہ وہ کیا لے کر آیا ہے ( 10 ) ۔"
  81,16,"پھر میں قسم کھاتا ہوں پیچھے ہٹ جانے والے تاروں کی ۔"
  81,17,"۔( اور قسم کھاتا ہوں ) سیدھے چلنے والے ، رکے رہنے والے تاروں کی ( 11 ) ۔"
  81,18,"اور رات کی جب وہ رخصت ہونے لگے ( 12 ) ۔"
  81,19,"اور صبح کی جب وہ سانس لے ( 13 ) ۔"
  81,20,"کہ یہ ( قرآن ) ایک معزز قاصد کا ( لایا ہوا ) قول ہے ( 14 ) ۔"
  81,21,"جو قوت والا ہے مالک عرش کے ہاں عزت والا ہے ۔"
  81,22,"۔( سب فرشتوں کا ) سردار اور وہاں کا امین ہے ۔"
  81,23,"اور تمہارا یہ ساتھی کوئی مجنون تو نہیں ( 15 ) ۔"
  81,24,"اور بلاشبہ اس نے اس قاصد کو دیکھا ہے روشن کنارے پر ( 16 ) ۔"
  81,25,"اور یہ نبی غیب بتانے میں ذرا بخیل نہیں ( 17 ) ۔"
  81,26,"اور یہ ( قرآن ) کسی شیطان مردود کا قول نہیں ( 18 ) ۔"
  81,27,"پھر تم ( منہ اٹھائے ) کدھر چلے جا رہے ہو ( 19 ) ۔"
  81,28,"نہیں ہے یہ مگر نصیحت سب اہل جہان کے لیے ( 20 ) ۔"
  81,29,"۔( لیکن ہدایت وہی پاتا ہے ) جو تم میں سے سیدھی راہ چلنا چاہے ۔"
