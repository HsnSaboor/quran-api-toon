quran[24]{c,v,t}:
  55,17,"پس ( اے انس و جاں ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ( 16 ) ۔"
  55,18,"وہی دونوں مشرقوں کا رب ہے اور دونوں مغربوں کا رب ہے ( 17 ) ۔"
  55,19,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,20,"اس نے رواں کیا ہے دونوں دریاؤں کو جو آپس میں مل رہے ہیں ۔"
  55,21,"ان کے درمیان آڑ ہے ، آپس میں گڈ مڈ نہیں ہوتے ( 18 ) ۔"
  55,22,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,23,"نکلتے ہیں ان سے موتی اور مرجان ( 19 ) ۔"
  55,24,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,25,"اور اسی کے زیر فرمان ہیں وہ جہاز جو سمندر میں پہاڑوں کی مانند بلند نظر آتے ہیں ( 20 ) ۔"
  55,26,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ( 21 ) ۔"
  55,27,"جو کچھ زمین پر ہے فنا ہونے والا ہے ۔"
  55,28,"اور باقی رہے گی آپ کے رب کی ذات جو بڑی عظمت اور احسان والی ہے ( 22 ) ۔"
  55,29,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ( 23 ) ۔"
  55,30,"مانگ رہے ہیں اس سے ( اپنی حاجتیں ) سب آسمان والے اور زمین والے ( 24 ) ہر روز وہ ایک نئی شان سے تجلی فرماتا ہے ( 25 ) ۔"
  55,31,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,32,"ہم عنقریب توجہ فرمائیں گے تمہاری طرف اے جن و انس ( 26 ) ۔"
  55,33,"پس تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,34,"اے گروہ جن و انس ! اگر تم میں طاقت ہے کہ تم نکل بھاگو آسمانوں اور زمین کی سرحدوں سے تو نکل کر بھاگ جاؤ ۔ ( سنو ) تم نہیں نکل سکتے بجز سلطان کے ( اور وہ تم میں مفقود ہے ) ( 27 ) ۔"
  55,35,"پس تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,36,"بھیجا جائے گا تم پر آگ کا شعلہ اور دھواں ( 28 ) پھر تم اپنا بچاؤ بھی نہ کر سکو گے ( 29 ) ۔"
  55,37,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ( 30 ) ۔"
  55,38,"پھر جب پھٹ جائے گا آسمان تو سرخ ہو جائے گا جیسے رنگا ہوا سرخ چمڑا ( 31 ) ۔"
  55,39,"پس تم اپنے رب کی کن کن نعمتوں کو جھٹلاؤ گے ۔"
  55,40,"تو اس روز کسی انسان اور جن سے اس کے گناہ کے بارے میں نہ پوچھا جائے گا ( 32 ) ۔"
