quran[23]{c,v,t}:
  56,77,"اور اگر تم سمجھو تو یہ بہت بڑی قسم ہے ۔"
  56,78,"بیشک یہ قرآن ہے بڑی عزت والا ۔"
  56,79,"ایک کتاب میں جو محفوظ ہے ( 33 ) ۔"
  56,80,"اس کو نہیں چھوتے مگر وہی جو پاک ہیں ( 34 ) ۔"
  56,81,"یہ اتارا گیا ہے رب العالمین کی طرف سے ۔"
  56,82,"کیا تم اس قرآن کے بارے میں کوتاہی کرتے ہو ( 35 ) ۔"
  56,83,"اور ( اس کی بے پایاں برکتوں سے ) تم نے اپنا یہی نصیب لیا ہے کہ تم اس کو جھٹلاتے رہو گے ( 36 ) ۔"
  56,84,"پس تم کیوں لوٹا نہیں دیتے جب روح حلق تک پہنچ جاتی ہے ۔"
  56,85,"اور تم اس وقت ( پاس بیٹھے ) دیکھ رہے ہوتے ہو ( 37 ) ۔"
  56,86,"اور ہم ( اس وقت بھی ) تم سے زیادہ مرنے والے کے قریب ہوتے ہیں البتہ تم دیکھ نہیں سکتے ( 38 ) ۔"
  56,87,"پس اگر تم کسی کے پابند حکم نہیں ہو"
  56,88,"تو پھر کیوں نہیں لوٹا دیتے ( مرنے والے کی روح ) اگر تم سچے ہو ( 39 ) ۔"
  56,89,"پس وہ ( مرنے والا ) اگر اللہ کے مقرب بندوں سے ہو گا"
  56,90,"تو اس کے لیے راحت ، خوشبو دار غذائیں اور سرور والی جنت ہو گی ( 40 ) ۔"
  56,91,"اور اگر وہ اصحاب یمین ( کے گروہ ) سے ہو گا"
  56,92,"تو ( اسے کہا جائے گا ) تمہیں سلام ہو اصحاب یمین کی طرف سے ۔"
  56,93,"اور اگر ( وہ مرنے والا ) جھٹلانے والے گمراہوں سے ہو گا"
  56,94,"تو اس کی مہمانی کھولتے پانی سے ہو گی ۔"
  56,95,"اور داخل ہونا پڑے گا اسے بھڑکتے دوزخ میں ۔"
  56,96,"بیشک ( جو بیان ہوا ) یہ یقینا حق ہے ۔"
  57,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  57,2,"اللہ تعالیٰ کی تسبیح کہہ رہی ہے ہر چیز جو آسمانوں اور زمین میں ہے ( 1 ) اور وہی سب پر غالب ، بڑا دانا ہے ( 2 ) ۔"
  57,3,"اسی کے لیے ہے بادشاہی آسمانوں اور زمین کی ۔ وہی زندہ کرتا ہے اور مارتا ہے اور وہ ہر چیز پر پوری قدرت رکھتا ہے ( 3 ) ۔"
