quran[32]{c,v,t}:
  86,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  86,2,"قسم ہے آسمان کی اور رات کو نمودار ہونے والے کی ۔"
  86,3,"اور آپ کو کیا معلوم یہ رات کو آنے والا کیا ہے ؟"
  86,4,"ایک تارا نہایت تاباں ( 1 ) ۔"
  86,5,"کوئی شخص ایسا نہیں جس پر کوئی محافظ نہ ہو ( 2 ) ۔"
  86,6,"سو انسان کو دیکھنا چاہیے کہ وہ کس چیز سے پیدا کیا گیا ہے ( 3 ) ۔"
  86,7,"اسے پیدا کیا گیا ہے اچھلتے پانی سے ۔"
  86,8,"جو ( مرد و زن کی ) پیٹھ اور سینے کی ہڈیوں کے درمیان سے نکلتا ہے ( 4 ) ۔"
  86,9,"بیشک وہ اس کو پھر واپس لانے پر قادر ہے ( 5 ) ۔"
  86,10,"یاد کرو اس دن کو جب سب راز فاش کر دیے جائیں گے ( 6 ) ۔"
  86,11,"پس نہ خود اس میں زور ہو گا اور نہ کوئی ( دوسرا ) مددگار ہو گا ( 7 ) ۔"
  86,12,"قسم ہے آسمان کی جس سے بارش برستی ہے ۔"
  86,13,"اور زمین کی جو ( بارش سے ) پھٹ جاتی ہے ( 8 ) ۔"
  86,14,"بلاشبہ یہ قرآن قول فیصل ہے ( 9 ) ۔"
  86,15,"اور یہ ہنسی مذاق نہیں ہے ۔"
  86,16,"یہ لوگ طرح طرح کی تدبیریں کر رہے ہیں ( 10 ) ۔"
  86,17,"اور میں بھی تدبیر فرما رہا ہوں ۔"
  87,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  87,2,"۔( اے حبیب ! ) آپ پاکی بیان کریں ( 1 ) اپنے رب کے نام کی جو سب سے برتر ہے ( 2 ) ۔"
  87,3,"جس نے ( ہر چیز کو ) پیدا کیا ( 3 ) پھر ( ظاہری اور باطنی قوتیں دے کر ) درست کیا ( 4 ) ۔"
  87,4,"اور جس نے ( ہر چیز کا ) اندازہ مقرر کیا پھر اسے راہ دکھائی ( 5 ) ۔"
  87,5,"اور جس نے زمین سے چارا نکالا ( 6 ) ۔"
  87,6,"پھر اسے بنا دیا کوڑا سیاہی مائل ۔"
  87,7,"ہم خود آپ کو پڑھائیں گے پس آپ ( اسے ) نہ بھولیں گے ( 7 ) ۔"
  87,8,"بجز اس کے جو اللہ چاہے ( 8 ) بیشک وہ جانتا ہے ظاہر کو اور جو چھپی ہوتی ہے ۔"
  87,9,"اور ہم سہل بنا دیں گے آپ کے لیے اس آسان ( شریعت ) پر عمل ( 9 ) ۔"
  87,10,"پس آپ نصیحت کرتے رہیے اگر نصیحت فائدہ مند ہو ( 10 ) ۔"
  87,11,"سمجھ جائے گا جس کے دل میں ( خدا کا ) خوف ہو گا ( 11 ) ۔"
  87,12,"اور دور رہے گا اس سے بدبخت ۔"
  87,13,"جو ( بالآخر ) بڑی آگ میں داخل ہو گا ۔"
  87,14,"پھر نہ وہ وہاں مرے گا اور نہ جیے گا ۔"
  87,15,"بیشک اس نے فلاح پائی جس نے اپنے آپ کو پاک کیا ( 12 ) ۔"
