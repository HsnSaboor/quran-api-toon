quran[32]{c,v,t}:
  86,1,"قسم ہے آسمان کی اور رات کو نمودار ہونے والے کی ۔"
  86,2,"اور آپ کو کیا معلوم یہ رات کو آنے والا کیا ہے ؟"
  86,3,"ایک تارا نہایت تاباں ( 1 ) ۔"
  86,4,"کوئی شخص ایسا نہیں جس پر کوئی محافظ نہ ہو ( 2 ) ۔"
  86,5,"سو انسان کو دیکھنا چاہیے کہ وہ کس چیز سے پیدا کیا گیا ہے ( 3 ) ۔"
  86,6,"اسے پیدا کیا گیا ہے اچھلتے پانی سے ۔"
  86,7,"جو ( مرد و زن کی ) پیٹھ اور سینے کی ہڈیوں کے درمیان سے نکلتا ہے ( 4 ) ۔"
  86,8,"بیشک وہ اس کو پھر واپس لانے پر قادر ہے ( 5 ) ۔"
  86,9,"یاد کرو اس دن کو جب سب راز فاش کر دیے جائیں گے ( 6 ) ۔"
  86,10,"پس نہ خود اس میں زور ہو گا اور نہ کوئی ( دوسرا ) مددگار ہو گا ( 7 ) ۔"
  86,11,"قسم ہے آسمان کی جس سے بارش برستی ہے ۔"
  86,12,"اور زمین کی جو ( بارش سے ) پھٹ جاتی ہے ( 8 ) ۔"
  86,13,"بلاشبہ یہ قرآن قول فیصل ہے ( 9 ) ۔"
  86,14,"اور یہ ہنسی مذاق نہیں ہے ۔"
  86,15,"یہ لوگ طرح طرح کی تدبیریں کر رہے ہیں ( 10 ) ۔"
  86,16,"اور میں بھی تدبیر فرما رہا ہوں ۔"
  86,17,"پس آپ کفار کو ( تھوڑی سی ) مہلت اور دے دیں ( 11 ) کچھ وقت انھیں کچھ نہ کہیں ( 12 ) ۔"
  87,1,"۔( اے حبیب ! ) آپ پاکی بیان کریں ( 1 ) اپنے رب کے نام کی جو سب سے برتر ہے ( 2 ) ۔"
  87,2,"جس نے ( ہر چیز کو ) پیدا کیا ( 3 ) پھر ( ظاہری اور باطنی قوتیں دے کر ) درست کیا ( 4 ) ۔"
  87,3,"اور جس نے ( ہر چیز کا ) اندازہ مقرر کیا پھر اسے راہ دکھائی ( 5 ) ۔"
  87,4,"اور جس نے زمین سے چارا نکالا ( 6 ) ۔"
  87,5,"پھر اسے بنا دیا کوڑا سیاہی مائل ۔"
  87,6,"ہم خود آپ کو پڑھائیں گے پس آپ ( اسے ) نہ بھولیں گے ( 7 ) ۔"
  87,7,"بجز اس کے جو اللہ چاہے ( 8 ) بیشک وہ جانتا ہے ظاہر کو اور جو چھپی ہوتی ہے ۔"
  87,8,"اور ہم سہل بنا دیں گے آپ کے لیے اس آسان ( شریعت ) پر عمل ( 9 ) ۔"
  87,9,"پس آپ نصیحت کرتے رہیے اگر نصیحت فائدہ مند ہو ( 10 ) ۔"
  87,10,"سمجھ جائے گا جس کے دل میں ( خدا کا ) خوف ہو گا ( 11 ) ۔"
  87,11,"اور دور رہے گا اس سے بدبخت ۔"
  87,12,"جو ( بالآخر ) بڑی آگ میں داخل ہو گا ۔"
  87,13,"پھر نہ وہ وہاں مرے گا اور نہ جیے گا ۔"
  87,14,"بیشک اس نے فلاح پائی جس نے اپنے آپ کو پاک کیا ( 12 ) ۔"
  87,15,"اور اپنے رب کے نام کا ذکر کرتا رہا اور نماز پڑھتا رہا ۔"
