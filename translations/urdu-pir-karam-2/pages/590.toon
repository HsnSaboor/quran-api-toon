quran[22]{c,v,t}:
  85,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  85,2,"قسم ہے آسمان کی جو برجوں والا ہے ( 1 ) ۔"
  85,3,"اور اس دن کی جس کا وعدہ کیا گیا ہے ( 2 ) ۔"
  85,4,"اور حاضر ہونیوالے دن کی اور اس کی جس کے پاس حاضر ہوں گے ( 3 ) ۔"
  85,5,"مارے گئے کھائی کھودنے والے ( 4 ) ۔"
  85,6,"۔( جس میں ) آگ تھی بڑے ایندھن والی ( 5 ) ۔"
  85,7,"جب وہ اس ( کے کنارہ ) پر بیٹھے تھے ۔"
  85,8,"اور وہ جو کچھ اہل ایمان کے ساتھ سلوک کر رہے تھے اسے دیکھ رہے تھے ( 6 ) ۔"
  85,9,"اور نہیں ناپسند کیا تھا انھوں نے مسلمانوں سے بجز اس کے کہ وہ ایمان لائے تھے اللہ پر جو سب پر غالب ، سب خوبیوں سراہا ہے ( 7 ) ۔"
  85,10,"جس کے قبضہ میں آسمانوں اور زمین کی بادشاہی ہے ( 8 ) اور اللہ تعالیٰ ہر چیز کو دیکھنے والا ہے ۔"
  85,11,"بیشک جن لوگوں نے ایذا دی مومن مردوں اور مومن عورتوں کو ، پھر توبہ بھی نہ کی تو ان کے لیے جہنم کا عذاب ہے اور ان کے لیے جلائے جانے کی سزا ہے ( 9 ) ۔"
  85,12,"جو لوگ ایمان لے آئے اور نیک عمل کرتے رہے ان کے لیے باغات ہیں جن کے نیچے نہریں جاری ہیں ۔ یہی بڑی کامیابی ہے ۔"
  85,13,"بیشک آپ کے رب کی پکڑ بہت سخت ہے ( 10 ) ۔"
  85,14,"بیشک وہی پہلی مرتبہ پیدا کرتا ہے اور وہی دوبارہ پیدا کرے گا ۔"
  85,15,"اور وہی بہت بخشنے والا ، بہت محبت کرنے والا ہے ( 11 ) ۔"
  85,16,"عرش کا مالک ہے ، بڑی شان والا ۔"
  85,17,"کرتا ہے جو کچھ چاہتا ہے ( 12 ) ۔"
  85,18,"کیا پہنچی ہے آپ کے پاس لشکروں کی خبر ۔"
  85,19,"۔( یعنی ) فرعون اور ثمود ( کے لشکروں ) کی ( 13 ) ۔"
  85,20,"بلکہ یہ کفار جھٹلانے میں مصروف ہیں ۔"
  85,21,"حالانکہ اللہ تعالیٰ ان کو ہر طرف سے گھیرے ہوئے ہے ۔"
  85,22,"بلکہ وہ کمال شرف والا قرآن ہے ( 14 ) ۔"
