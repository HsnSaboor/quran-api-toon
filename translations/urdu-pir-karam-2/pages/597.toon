quran[27]{c,v,t}:
  95,1,"قسم ہے انجیر اور زیتون کی ( 1 ) ۔"
  95,2,"اور قسم ہے طور سینا کی ( 2 ) ۔"
  95,3,"اور اس امن والے شہر ( مکہ مکرمہ ) کی ( 3 ) ۔"
  95,4,"بیشک ہم نے انسان کو پیدا کیا ہے ( عقل و شکل کے اعتبار سے ) بہترین اعتدال پر ۔"
  95,5,"پھر ہم نے لوٹا دیا اس کو پست ترین حالت کی طرف ( 5 ) ۔"
  95,6,"بجز ان لوگوں کے جو ایمان لائے اور نیک عمل کرتے رہے تو ان کے لیے نہ ختم ہونے والا اجر ہے ( 6 ) ۔"
  95,7,"پس کون جھٹلا سکتا ہے آپ کو اس کے بعد جزا و سزا کے معاملہ میں ( 7 ) ۔"
  95,8,"کیا نہیں ہے اللہ تعالیٰ سب حاکموں سے بڑا حاکم ( 8 ) ۔"
  96,1,"آپ پڑھیے اپنے رب کے نام کے ساتھ جس نے ( سب کو ) پیدا فرمایا ( 1 ) ۔"
  96,2,"پیدا کیا انسان کو جمے ہوئے خون سے ( 2 ) ۔"
  96,3,"پڑھیے آپ کا رب بڑا کریم ہے ( 3 ) ۔"
  96,4,"جس نے علم سکھایا قلم کے واسطہ سے ( 4 ) ۔"
  96,5,"اسی نے سکھایا انسان کو جو وہ نہیں جانتا تھا ( 5 ) ۔"
  96,6,"ہاں ہاں ! بیشک انسان سرکشی کرنے لگتا ہے ( 6 ) ۔"
  96,7,"اس بنا پر کہ وہ اپنے آپ کو مستغنی دیکھتا ہے ۔"
  96,8,"۔( اے غافل ! ) یقیناً تجھے اپنے رب کی طرف ہی پلٹنا ہے ۔"
  96,9,"۔( اے حبیب ! ) آپ نے دیکھا اسے جو منع کرتا ہے ( 7 ) ۔"
  96,10,"ایک بندے کو جب وہ نماز پڑھتا ہے ۔"
  96,11,"بھلا دیکھیے تو اگر وہ ہدایت پر ہوتا ( 8 ) ۔"
  96,12,"یا پرہیزگاری کا حکم دیتا ( تو اس کے لیے کتنا بہتر ہوتا ) ۔"
  96,13,"آپ نے دیکھ لیا اگر اس نے جھٹلایا اور روگردانی کی ۔"
  96,14,"کیا نہیں جانتا کہ اللہ تعالیٰ ( اسے ) دیکھ رہا ہے ۔"
  96,15,"خبردار اگر وہ ( اپنی روش سے ) باز نہ آیا تو ہم ضرور ( اسے ) گھسیٹیں گے اس کے پیشانی کے بالوں سے ۔"
  96,16,"وہ پیشانی جو جھوٹی ( اور ) خطاکار ہے ( 9 ) ۔"
  96,17,"پس وہ بلا لے اپنے ہم نشینوں کو ( اپنی مدد کے لیے ) ۔"
  96,18,"ہم بھی جہنم کے فرشتوں کو بلائیں گے ۔"
  96,19,"ہاں ہاں ! اس کی ایک نہ سنیے ( اے حبیب ! ) سجدہ کیجیے اور ( ہم سے اور ) قریب ہو جائیے ( 10 ) ۔"
