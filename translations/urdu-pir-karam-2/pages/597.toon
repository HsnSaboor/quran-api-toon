quran[27]{c,v,t}:
  95,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  95,2,"قسم ہے انجیر اور زیتون کی ( 1 ) ۔"
  95,3,"اور قسم ہے طور سینا کی ( 2 ) ۔"
  95,4,"اور اس امن والے شہر ( مکہ مکرمہ ) کی ( 3 ) ۔"
  95,5,"بیشک ہم نے انسان کو پیدا کیا ہے ( عقل و شکل کے اعتبار سے ) بہترین اعتدال پر ۔"
  95,6,"پھر ہم نے لوٹا دیا اس کو پست ترین حالت کی طرف ( 5 ) ۔"
  95,7,"بجز ان لوگوں کے جو ایمان لائے اور نیک عمل کرتے رہے تو ان کے لیے نہ ختم ہونے والا اجر ہے ( 6 ) ۔"
  95,8,"پس کون جھٹلا سکتا ہے آپ کو اس کے بعد جزا و سزا کے معاملہ میں ( 7 ) ۔"
  96,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  96,2,"آپ پڑھیے اپنے رب کے نام کے ساتھ جس نے ( سب کو ) پیدا فرمایا ( 1 ) ۔"
  96,3,"پیدا کیا انسان کو جمے ہوئے خون سے ( 2 ) ۔"
  96,4,"پڑھیے آپ کا رب بڑا کریم ہے ( 3 ) ۔"
  96,5,"جس نے علم سکھایا قلم کے واسطہ سے ( 4 ) ۔"
  96,6,"اسی نے سکھایا انسان کو جو وہ نہیں جانتا تھا ( 5 ) ۔"
  96,7,"ہاں ہاں ! بیشک انسان سرکشی کرنے لگتا ہے ( 6 ) ۔"
  96,8,"اس بنا پر کہ وہ اپنے آپ کو مستغنی دیکھتا ہے ۔"
  96,9,"۔( اے غافل ! ) یقیناً تجھے اپنے رب کی طرف ہی پلٹنا ہے ۔"
  96,10,"۔( اے حبیب ! ) آپ نے دیکھا اسے جو منع کرتا ہے ( 7 ) ۔"
  96,11,"ایک بندے کو جب وہ نماز پڑھتا ہے ۔"
  96,12,"بھلا دیکھیے تو اگر وہ ہدایت پر ہوتا ( 8 ) ۔"
  96,13,"یا پرہیزگاری کا حکم دیتا ( تو اس کے لیے کتنا بہتر ہوتا ) ۔"
  96,14,"آپ نے دیکھ لیا اگر اس نے جھٹلایا اور روگردانی کی ۔"
  96,15,"کیا نہیں جانتا کہ اللہ تعالیٰ ( اسے ) دیکھ رہا ہے ۔"
  96,16,"خبردار اگر وہ ( اپنی روش سے ) باز نہ آیا تو ہم ضرور ( اسے ) گھسیٹیں گے اس کے پیشانی کے بالوں سے ۔"
  96,17,"وہ پیشانی جو جھوٹی ( اور ) خطاکار ہے ( 9 ) ۔"
  96,18,"پس وہ بلا لے اپنے ہم نشینوں کو ( اپنی مدد کے لیے ) ۔"
  96,19,"ہم بھی جہنم کے فرشتوں کو بلائیں گے ۔"
