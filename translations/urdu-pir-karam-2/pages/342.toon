quran[17]{c,v,t}:
  23,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  23,2,"بیشک دونوں جہان میں بامراد ہو گئے ایمان والے ( 1 ) ۔"
  23,3,"وہ ایمان والے جو اپنی نماز میں عجز و نیاز کرتے ہیں ( 2 ) ۔"
  23,4,"اور وہ جو ہر بیہودہ امر سے منہ پھیرے ہوئے ہیں ( 3 ) ۔"
  23,5,"اور وہ جو زکوۃ ادا کرتے ہیں ( 4 ) ۔"
  23,6,"اور وہ جو اپنی شرمگاہوں کی حفاظت کرنے والے ہیں ( 5 ) ۔"
  23,7,"بجز اپنی بیویوں کے اور ان کنیزوں کے جو ان کے ہاتھوں کی ملکیت ہیں تو بیشک انھیں ملامت نہ کی جائے گی ۔"
  23,8,"اور جس نے خواہش کی ان دو کے ماسوا تو یہی لوگ حد سے بہت زیادہ تجاوز کرنے والے ہیں نیز وہ ( مومن بامراد ہیں ) ۔"
  23,9,"جو اپنی امانتوں اور اپنے وعدوں کی پاسداری کرنے والے ہیں ( 6 ) ۔"
  23,10,"اور وہ جو اپنی نمازوں کی پوری حفاظت کرتے ہیں ۔"
  23,11,"یہی لوگ وارث ہیں ( 7 ) ۔"
  23,12,"جو وارث بنیں گے فردوس ( بریں ) کے ، وہ اس میں ہمیشہ رہیں گے ۔"
  23,13,"اور بیشک ہم نے پیدا کیا انسان کو مٹی کے جوہر سے ( 8 ) ۔"
  23,14,"پھر ہم نے رکھا اسے پانی کی بوند بنا کر ایک محفوظ مقام میں ۔"
  23,15,"پھر ہم نے بنا دیا نطفہ کو خون کا لوتھڑا ، پھر ہم نے بنا دیا اس لوتھڑے کو گوشت کی بوٹی ، پھر ہم نے پیدا کر دیں اس بوٹی سے ہڈیاں ، پھر ہم نے پہنا دیا ان ہڈیوں کو گوشت ۔ پھر ( روح پھونک کر ) ہم نے اسے دوسری مخلوق بنا دیا ( 9 ) پس بڑا بابرکت ہے اللہ جو سب سے بہتر بنانے والا ہے ۔"
  23,16,"پھر یقیناً تم ان مرحلوں سے گزرنے کے بعد مرنے والے ہو ( 10 ) ۔"
  23,17,"پھر بلاشبہ تمہیں روز قیامت ( قبروں سے ) اٹھایا جائے گا ۔"
