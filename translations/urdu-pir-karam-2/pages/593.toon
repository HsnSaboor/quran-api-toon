quran[23]{c,v,t}:
  89,1,"قسم ہے اس صبح کی ۔"
  89,2,"اور ان ( مقدس ) دس راتوں کی ۔"
  89,3,"اور قسم ہے جفت اور طاق ( راتوں ) کی ( 1 ) ۔"
  89,4,"اور رات کی جب گزرنے لگے ( 2 ) ۔"
  89,5,"یقینا اس میں قسم ہے عقلمند کے لیے ( 3 ) ۔"
  89,6,"کیا آپ نے ملاحظہ نہ کیا کہ آپ کے رب نے کیا کیا عاد ( 4 ) ۔"
  89,7,"ارم کے ساتھ جو اونچے ستونوں والے تھے ( 5 ) ۔"
  89,8,"نہیں پیدا کیا گیا جن کا مثل ( دنیا کے ) ملکوں میں ( 6 ) ۔"
  89,9,"اور ثمود کے ساتھ ( کیا کیا ) جنہوں نے کاٹا تھا چٹانوں کو وادی میں ( 7 ) ۔"
  89,10,"اور ( کیا کیا ) فرعون کے ساتھ جو میخوں والا تھا ( 8 ) ۔"
  89,11,"جنہوں نے سرکشی کی تھی ( اپنے اپنے ) ملکوں میں ۔"
  89,12,"پھر ان میں بکثرت فساد برپا کر دیا تھا ۔"
  89,13,"پس آپ کے رب نے ان پر عذاب کا کوڑا برسایا ( 9 ) ۔"
  89,14,"بیشک آپ کا رب ( سرکشوں اور مفسدوں کی ) تاک میں ہے ۔"
  89,15,"مگر انسان ( بھی عجب شے ہے ) کہ جب آزماتا ہے اسے اس کا رب یعنی اس کو عزت دیتا ہے اور اس پر انعام فرماتا ہے تو وہ کہتا ہے میرے رب نے مجھے عزت بخشی ۔"
  89,16,"اور جب اس کو ( یوں ) آزماتا ہے کہ اس پر روزی تنگ کر دیتا ہے تو کہنے لگتا ہے کہ میرے رب نے مجھے ذلیل کر دیا ( 10 ) ۔"
  89,17,"ایسا نہیں ہے ( 11 ) بلکہ ( اس کی وجہ یہ ہے کہ ) تم یتیم کی عزت نہیں کرتے ( 12 ) ۔"
  89,18,"اور نہ تم ترغیب دیتے ہو مسکین کو کھانا کھلانے کی ( 13 ) ۔"
  89,19,"اور چٹ کر جاتے ہو میراث کا سارا مال ( 14 ) ۔"
  89,20,"اور دولت سے حد درجہ محبت کرتے ہو ( 15 ) ۔"
  89,21,"یقیناً جب زمین کو کوٹ کر ریزہ ریزہ کر دیا جائے گا ۔"
  89,22,"اور جب آپ کا رب جلوہ فرما ہو گا اور فرشتے قطار در قطار حاضر ہوں گے ۔"
  89,23,"اور ( سامنے ) لائی جائے گی اس دن جہنم ۔ اس روز انسان کو سمجھ آئے گی لیکن اس سمجھنے کا کیا فائدہ ( 16 ) ۔"
