quran[15]{c,v,t}:
  112,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  112,2,"۔( اے حبیب ! فرما دیجیے وہ اللہ ہے ، یکتا ( 1 ) ۔"
  112,3,"اللہ صمد ہے ( 2 ) ۔"
  112,4,"نہ اس نے کسی کو جنا اور نہ وہ جنا گیا ( 3 ) ۔"
  113,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  113,2,"آپ عرض کیجیے میں پناہ لیتا ہوں صبح کے پروردگار کی ( 1 ) ۔"
  113,3,"ہر اس چیز کے شر سے جس کو اس نے پیدا کیا ( 2 ) ۔"
  113,4,"اور ( خصوصاً ) رات کی تاریکی کے شر سے جب وہ چھا جائے ( 3 ) ۔"
  113,5,"اور ان کے شر سے جو پھونکے مارتی ہیں گرھوں میں ( 4 ) ۔"
  114,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  114,2,"۔( اے حبیب ! ) عرض کیجیے میں پناہ لیتا ہوں سب انسانوں کے پروردگار کی ۔"
  114,3,"سب انسانوں کے بادشاہ کی ۔"
  114,4,"سب انسانوں کے معبود کی ( 1 ) ۔"
  114,5,"بار بار وسوسہ ڈالنے والے ، بار بار پسپا ہونے والے کے شر سے ( 2 ) ۔"
  114,6,"جو وسوسہ ڈالتا رہتا ہے لوگوں کے دلوں میں ۔"
