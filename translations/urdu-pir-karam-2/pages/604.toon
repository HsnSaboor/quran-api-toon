quran[15]{c,v,t}:
  112,1,"۔( اے حبیب ! فرما دیجیے وہ اللہ ہے ، یکتا ( 1 ) ۔"
  112,2,"اللہ صمد ہے ( 2 ) ۔"
  112,3,"نہ اس نے کسی کو جنا اور نہ وہ جنا گیا ( 3 ) ۔"
  112,4,"اور نہ ہی اس کا کوئی ہمسر ہے ( 4 ) ۔"
  113,1,"آپ عرض کیجیے میں پناہ لیتا ہوں صبح کے پروردگار کی ( 1 ) ۔"
  113,2,"ہر اس چیز کے شر سے جس کو اس نے پیدا کیا ( 2 ) ۔"
  113,3,"اور ( خصوصاً ) رات کی تاریکی کے شر سے جب وہ چھا جائے ( 3 ) ۔"
  113,4,"اور ان کے شر سے جو پھونکے مارتی ہیں گرھوں میں ( 4 ) ۔"
  113,5,"اور ( میں پناہ مانگتا ہوں ) حسد کرنے والے کے شر سے جب وہ حسد کرے ( 5 ) ۔"
  114,1,"۔( اے حبیب ! ) عرض کیجیے میں پناہ لیتا ہوں سب انسانوں کے پروردگار کی ۔"
  114,2,"سب انسانوں کے بادشاہ کی ۔"
  114,3,"سب انسانوں کے معبود کی ( 1 ) ۔"
  114,4,"بار بار وسوسہ ڈالنے والے ، بار بار پسپا ہونے والے کے شر سے ( 2 ) ۔"
  114,5,"جو وسوسہ ڈالتا رہتا ہے لوگوں کے دلوں میں ۔"
  114,6,"خواہ وہ جنات میں سے ہو یا انسانوں سے ( 3 ) ۔"
