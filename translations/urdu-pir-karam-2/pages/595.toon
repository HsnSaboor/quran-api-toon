quran[29]{c,v,t}:
  91,1,"قسم ہے آفتاب کی اور اس کی دھوپ کی ۔"
  91,2,"اور قسم ہے مہتاب کی ( 1 ) جب وہ ( غروب ) آفتاب کے بعد آوے ( 2 ) ۔"
  91,3,"اور قسم ہے دن کی جب آفتاب کو روشن کر دے ( 3 ) ۔"
  91,4,"اور رات کی جب وہ اسے چھپا لے ( 4 ) ۔"
  91,5,"اور قسم ہے آسمان کی اور اسے بنانے والے کی ( 5 ) ۔"
  91,6,"اور زمین کی اور اس کو بچھانے والے کی ( 6 ) ۔"
  91,7,"قسم ہے نفس کی اور اس کو درست کرنے والے کی ( 7 ) ۔"
  91,8,"پھر اس کے دل میں ڈال دیا اس کی نافرمانی اور اس کی پارسائی کو ( 8 ) ۔"
  91,9,"یقیناً فلاح پا گیا جس نے ( اپنے ) نفس کو پاک کر لیا ( 9 ) ۔"
  91,10,"اور یقیناً نامراد ہوا جس نے اس کو خاک میں دبا دیا ( 10 ) ۔"
  91,11,"جھٹلایا قوم ثمود نے ( اپنے پیغمبر کو ) اپنی سرکشی کے باعث ۔"
  91,12,"جب اٹھ کھڑا ہوا ان میں سے ایک بڑا بدبخت ( 11 ) ۔"
  91,13,"تو کہا انھیں اللہ کے رسول نے کہ ( خبردار رہنا ) اللہ کی اونٹنی اور اس کی پانی کی باری سے ( 12 ) ۔"
  91,14,"پھر بھی انھوں نے جھٹلایا رسول کو اور اونٹنی کی کونچیں کاٹ دیں ۔ پس ہلاک کر دیا انھیں ان کے رب نے ان کے گناہ ( عظیم ) کے باعث اور سب کو پیوند خاک کر دیا ( 13 ) ۔"
  91,15,"اور کوئی ڈر نہیں اللہ کو ان کے ( تباہ کن ) انجام کا ( 14 ) ۔"
  92,1,"قسم ہے رات کی جب وہ ( ہر چیز پر ) چھا جائے ۔"
  92,2,"اور قسم ہے دن کی جب وہ خوب چمک اٹھے ۔"
  92,3,"اور اس کی قسم جس نے پیدا کیا نر اور مادہ کو ( 1 ) ۔"
  92,4,"بیشک تمہاری کوششیں مختلف نوعیت کی ہیں ( 2 ) ۔"
  92,5,"پھر جس نے ( راہ خدا میں اپنا ) مال دیا اور ( اس سے ) ڈرتا رہا ۔"
  92,6,"اور ( جس نے ) اچھی بات کی تصدیق کی ( 3 ) ۔"
  92,7,"تو ہم آسان کر دیں گے اس کے لیے آسان راہ ( 4 ) ۔"
  92,8,"اور جس نے بخل کیا اور بے پروا بنا رہا ۔"
  92,9,"اور اچھی بات کو جھٹلایا ( 5 ) ۔"
  92,10,"تو ہم آسان کر دیں گے اس کے لیے مشکل راہ ( 6 ) ۔"
  92,11,"اور اس کے کسی کام نہ آئے گا اس کا مال جب وہ ہلاکت ( کے گڑھے ) میں گرے گا ( 7 ) ۔"
  92,12,"بیشک ہمارے ذمہ ( کرم پر ) ہے رہنمائی کرنا ( 8 ) ۔"
  92,13,"یقیناً آخرت اور دنیا کے ہم ہی مالک ہیں ۔"
  92,14,"پس میں نے خبردار کر دیا ہے تمہیں ایک بھڑکتی آگ سے ۔"
