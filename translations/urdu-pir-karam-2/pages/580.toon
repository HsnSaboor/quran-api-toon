quran[25]{c,v,t}:
  76,26,"اور یاد کرتے رہا کرو اپنے رب کے نام کو صبح بھی اور شام بھی ( 26 ) ۔"
  76,27,"اور رات ( کی تنہائیوں میں ) بھی اس کو سجدہ کیا کیجیے اور رات کافی وقت اس کی تسبیح کیا کیجیے ۔"
  76,28,"بیشک یہ لوگ دنیا سے محبت کرتے ہیں اور پس پشت ڈال رکھا ہے انھوں نے بڑے سخت دن کو ۔"
  76,29,"ہم نے ہی ان کو پیدا کیا ہے اور ان کے جوڑ بند مضبوط کیے ہیں ( 27 ) اور جب ہم چاہیں تو ان کی شکلوں کو بدل کر رکھ دیں ( 28 ) ۔"
  76,30,"بیشک یہ ایک نصیحت ہے ۔ پس جس کا جی چاہے اختیار کر لے اپنے رب کے قرب کا راستہ ( 29 ) ۔"
  76,31,"اور ( اے لوگو ! ) تم کچھ بھی نہیں چاہ سکتے بجز اس کے کہ اللہ خود چاہے ( 30 ) بیشک اللہ تعالیٰ علیم ہے ، حکیم ہے ( 31 ) ۔"
  77,1,"اللہ کے نام سے شروع کرتا ہوں جو بہت ہی مہربان ہمیشہ رحم کرنے والا ہے ۔"
  77,2,"۔( ان ہواؤں کی ) قسم جو پے در پے بھیجی جاتی ہیں ( 1 ) ۔"
  77,3,"پھر ان کی ( قسم ) جو تند و تیز ہیں ۔"
  77,4,"اور ان کی قسم جو بادلوں کو پھیلانے والی ہیں ۔"
  77,5,"پھر ان کی جو بادلوں کو پارہ پارہ کرنے والی ہیں ۔"
  77,6,"پھر ان کی قسم جو ( دلوں میں ) ذکر کا القاء کرنے والی ہیں ۔"
  77,7,"حجت تمام کرنے کے لیے یا ڈرانے کے لیے ۔"
  77,8,"بیشک جس بات کا تم سے وعدہ کیا گیا ہے وہ ضرور ہو کر رہے گی ۔"
  77,9,"پس اس وقت جب ستارے بے نور کر دیے جائیں گے ۔"
  77,10,"اور جب آسمان میں شگاف پڑ جائیں گے ( 2 ) ۔"
  77,11,"اور جب پہاڑ ( خاک بنا کر ) اڑا دیے جائیں گے ۔"
  77,12,"اور جب رسولوں کو وقت مقررہ پر اکٹھا کیا جائے گا ۔"
  77,13,"۔( تمہیں علم ہے ) کس دن کے لیے یہ ملتوی کیا گیا ہے ؟ ( 3 )"
  77,14,"فیصلہ کے دن کے لیے ۔"
  77,15,"۔( اے مخاطب ! ) تجھے کیا علم کہ فیصلے کا دن کیسا ہے ۔"
  77,16,"تباہی ہو گی اس روز جھٹلانے والوں کے لیے ( 4 ) ۔"
  77,17,"کیا ہم نے ہلاک نہیں کر دیا جو ان سے پہلے تھے ( 5 ) ۔"
  77,18,"پھر ہم ان کے پیچھے پیچھے بھیج دیں گے بعد میں آنے والوں کو ۔"
  77,19,"گناہ گاروں کے ساتھ ہم ایسا ہی سلوک کیا کرتے ہیں ۔"
