quran[22]{c,v,t}:
  58,1,"۔خُدا ین پوٗز تس خا توٗنہِ ہٕنز کتھ یۅسہٕ پننِس خا ندار سٕندِس معا ملس منٛز تۅہیہِ سٍتۍ تکرار چھےٚ کران، تہٕ خُدا یس چھےٚ فر یاد کران ﴿ یِم آیات ٲسۍ أکِس خا توٗنہِ خَو لَہ بنتِ ثعلَبہَ سٕندِس معا ملس منٛز نٲزِل سپدِ مٕتۍ یَس سٍتۍ تٔمۍ سٕندۍ خا ندارن ظِہا ر کوٚر مُت اوس، تہٕ سۅ ٲس حضور صلی اللہ علیہ وسلمن نِشہِ پٕر ژھنہٕ آمٕژ زِ اسلامَس منٛز کیا حُکم چُھ اَمِیُک ۔ چو نکہ اَتھ وقتس تام اوس نہٕ اللہ تعالیٰ سٕندِ طر فہٕ اتھ معا ملس منٛز  کانٛہہ حُکم نٲزِل سپُد مُت ، لھٰذا چِھ حضور صلی اللہ علیہ وسلم فر ماوان زِ مےٚ چُھ باسان زِ ژٕ گٔیکھ پننِس خا ندارس پٮ۪ٹھ حرام ۔ اَتھ پٮ۪ٹھ چھےٚ سۅ فر یاد کران زِ میٲ نۍ تہٕ میا نیٚن شُر ٮ۪ن ہٕنز زند گی گژِھ تباہ۔أتھۍ حا لتس منٛز ییٚلہِ سۅ وَدان وَدان حضو ر صلی اللہ علیہ وسلمن عر ض ٲس کران زِ کانٛہہ تِژھ صورت فر مٲوِ تَو ییٚمہِ سٍتۍ میو ن گھرٕ برباد گژھنہٕ نِشہِ بچہِ ، اللہ تعالیٰ سٕندِ طر فہٕ چھےٚ وَحی سپدان نٲزِل تہٕ امہِ مسلُک حُکم چُھ بیان کر نہٕ یِوان ۔ ﴾"
  58,2,"۔تہٕ سُہ چُھ سورُے کینٛہہ بوزن وول تہٕ وُچھن وول۔تۅہیہِ منٛزٕ یِم لُکھ پننیٚن خا ندارِ نیٚن سٍتۍ ظِہا ر چِھ کران ﴿ عر بس منٛز ٲس کُنہِ وِزِ یہِ صور ت پیش یِوان زِ ییٚلہِ خا ندارس تہٕ خا ندار نہِ بکو اس گژھان ، خاندار اوس شرارتس منٛز یِتھ ونان زِ ""ژٕ چھکھ مےٚ پٮ۪ٹھ تِژھ زَنتہٕ میانہِ ماجہِ ہُند کمر"" اَمِیُک اصلی مفہو م چُھ یہِ زِ "" ژےٚ سٍتۍ ہرگاہ مُبا شرت کرٕ زنتہٕ کرٕ ماجہِ سٍتۍ۔"" اَز تہِ چِھ واریاہ نادان لُکھ خا ندارنہِ سٍتۍ ژُوان ژُوان تس ماجہِ ، بیٚنہِ، کورِ سٍتۍ ہِشر دِوان ییٚمیُک صاف  مطلب یہِ آسان چُھ زِ انسان چُھنہٕ وۅ نۍ تس خا ندارِ نۍ بلکہ چُھس تِمن مستوٗراتن ہٕندۍ پٲٹھۍ سمجھان یِمہٕ تَس پٮ۪ٹھ حرام چھےٚ۔أتھۍ چِھ ""ظِہا ر "" ونان۔ جٲہلیت کِس زمانس  اوس یہِ اہلِ عر بن منٛز طلا ق ، بلکہ امہِ کھۅ تہٕ تہِ زیادٕہ سد ید تعلق ژٹنُک اعلان یِوان ماننہٕ ۔﴾ تِہنزٕ خا ندارنہِ چَھنہٕ تِہنزٕ ماجہِ کینٛہہ،تِہنزٕ ماجہِ چھےٚ تِمے یِمو تِمن زنم چُھ دِیُتمُت۔یِم لُکھ چِھ اکھ سخت نا پسند یدٕہ تہٕ اَپٕز کتھ ونان ،تہٕ حقیقت چھےٚ یہِ زِ اللہ تعالیٰ چُھ سٮ۪ٹھاہ معا ف کر ن وول تہٕ در گُزر کر ن وول۔﴿ یعنی یہِ حر کت چھےٚ تِژھ زِ اتھ پٮ۪ٹھ گوٚژھ اِنسا نس سٮ۪ٹھاہ سخت سزا میلُن  ،مگر اللہ تعالیٰ سٕنز چھےٚ یہِ مہر بٲنی زِ اوّل بچٲ و تٔمۍ ظِہا ر کِس معا ملس منٛز جٲہلیتُک قا نو ن منسو خ کٔرِ تھ تُہٕنز خا نگی زند گی تبٲ ہی نِشہِ ، دوٚ یُم کوٚرُن امہِ غلطی ہُند ارتکا ب کر ن والیٚن خٲطرٕ سُہ سزا تجو یز یُس امہِ جُر مُک لۅ تہِ کھۅ تہٕ لوٚت سزا ہیٚکہِ ہے ٲسِتھ﴾"
  58,3,"۔یِم لُکھ پننیٚن خا ندارِ نیٚن سٍتۍ ظِہار کرن، پتہٕ کر ن پننہِ تتھ کتھہِ کُن رجوع یۅسہٕ تِمو ؤنِمٕژ ٲس۔﴿اتھ ہیٚکن زٕ مفہو م ٲسِتھ۔اکھ یہِ تمہِ کتھہِ ہُند یژھن تدارُک کرُن یۅسہٕ تِمو ؤنِمٕژ ٲس۔بیاکھ یہِ زِ سُہ زچیز یژھن پا نس خٲطرٕ حلال کرُن یُس یہِ کتھ ؤنِتھ تِمو حرام اوس یوٚژھمُت کرُن ۔ ﴾ تیٚلہِ آسہِ اَمہِ برونٛہہ زِ تِم دۅشوے لا گن اکھ أکِس اَتھہٕ ، اکھ غلا م آزاد کرُن ۔ امہِ سٍتۍ چَھو یِوان تۅہیہِ نصیحت کر نہٕ ،تہٕ یِکینژھا ہ توٚہۍ کران چِھو اللہ تعالیٰ چُھ تمہِ نِشہِ با خبر۔﴿ یعنی اگر اِنسا ن ژوٗرِ پٲٹھۍ گھر س منٛز پننہِ خا ندارِنہِ سٍتۍ ظِہا ر کرِ ،تہٕ پتہٕ روزن کفّارٕ ہ دِنہٕ ورٲے خا ندارس تہٕ خا ندارنہِ در میان پرٲنۍ پٲٹھۍ زوجیتٕکۍ تعلقا ت پکان،دُنیا منٛز مَتہٕ ٲسِتن کٲنٛسہِ تہِ اَمِچ خبر ، خُدا یس چھےٚ بہر حال اَمِچ خبر ۔ اللہ تعالیٰ سٕنزِ پٕرٛژٕھہ گا رِ نِشہِ بچُن چُھنہٕ تِہِندِ خٲ طرٕ کُنہِ پٲٹھۍ تہِ ممکن۔﴾"
  58,4,"۔تہٕ یُس شخصس غلا م آسہِ نہٕ ، سُہ تھٲوِ ن دۅ ن ریٚتن ہیٚتھٕے روزٕہ۔اَمہِ برونٛہہ زِ دۅشو ے لا گن اکھ أکِس اتھہٕ۔﴿ یعنی دۅ ن ریٚتن در میان گژِھہ نہٕ کانٛہہ دۅ ہ پُھٹُن﴾ تہٕ یَس نہٕ امیُک تہِ  طا قت آسہِ ، سُہ کِھیٲوِ ن شیٹھن مِسکینن کھیٚن۔ ﴿یعنی دۅ ن وقتن ہُند یڈ بٔرِتھ کھیٚن گژِھہ دِنہٕ یُن ،سُہ ٲسِتن رٔنِتھ یا ٲسِتن خۅراک چہِ شکلہٕ منٛز، شیٹھن ﴿60﴾ نفر یِیہِ تن اَکی دۅہ کھیا و نہٕ یا یِیہِ تن اکھ نفر شیٹھن دۅہن کھیا و نہٕ ﴾۔ 	یہِ حُکم چُھ امہِ موجو ب دِنہٕ یِوان زِ توٚہۍ أنِو خُدا یس تہٕ تٔمۍ سٕندِس رسولس صلی اللہ علیہ وسلمس پٮ۪ٹھ ایمان ۔ ﴿ یتھ جا یہِ چُھ "" ایمان اننہٕ "" نِشہِ مُراد پٔزِس تہٕ مخلص مو من سُند ہیوٗ رٔوِیہِ اختیار کرُن ﴾۔ یِم چھِ اللہ تعالیٰ سٕندۍ مُقرر کر نہٕ آمٕتۍ حَد، تہٕ کٲفر ن خٲطرٕ چُھ دگ تُلہٕ وُن عذاب۔"
  58,5,"۔ یِم لُکھ اللہ تعالیٰ سٕنز تہٕ رسول صلی اللہ علیہ وسلمن ہٕنز مخا لفت چِھ کران، تِم یِن تِتھے پٲٹھۍ ذلیل خوار کر نہٕ یِتھہٕ پٲٹھۍ یِمن بروٗنٹھِم لُکھ چِھ آمٕتۍ ذلیل و خوار کر نہٕ ۔اَسہِ چِھ صا ف صا ف آیات نٲزِل کٔر مٕتۍ، تہٕ کٲفر ن خٲطرٕ چُھ ذِ لّتُک عذاب۔"
  58,6,"۔تمہِ دۅہ چُھ یہِ ﴿ ذِ لّتُک عذا ب سپد ن وول ﴾ ییٚلہِ اللہ تعالیٰ یِمن سارِ نٕے نوِ سرٕ زند ہ کٔرِتھ تُلہِ، تہٕ یِمن وَنہِ زِ یِم کیا کینژھا ہ کٔرِتھ چِھ آمٕتۍ۔ تِمن چُھ مٔشِتھ  گوٚ مُت مگر خُداین چُھ یُہُند سورُے کوٚر مُت کرٛ وومُت گٔنزٕرۍ گٔنزٕرۍ محفوظ کٔرِتھ تھو ومُت، تہٕ اللہ تعالیٰ چُھ أکِس أکِس چیز س پٮ۪ٹھ شٲہِد ۔ ع"
  58,7,"۔کیا تۅ ہیہِ چَھو نا خبر ، زمین تہٕ آسمانن ہٕندِ پرٛتھ چیزُک علم چُھ خُدایس؟ ﴿ ییٚتہِ پٮ۪ٹھہٕ چھےٚ آیت 10 ہَس تام مُسلسل مُنا فقن ہٕندِس تَتھ طر زِ عملس پٮ۪ٹھ گرفت کر نہٕ آمٕژ یُس تِمو تَمہِ وقتہٕ مُسلم معا شر س منٛز اختیار اوس کوٚر مُت۔ تِم ٲسۍ بظٲہر مُسلمانن ہٕندِس جما عتس منٛز شٲمِل ،مگر أندٕ رۍ أنٕدرۍ اوس تِمو اہلِ ایمانن نِشہِ الگ پنُن اکھ دوٚر بنو و مُت۔ مُسلمان ییٚلہِ تہِ تِمن وُچھان ٲسۍ، تِم ٲسۍ وُچھان زِ تِم چِھ کلہٕ تہٕ کلہٕ رَلٲوِتھ کنہٕ پھِسرا ے کران ۔یِمنٕے ژۅین منٛز ٲسۍ تِم مُسلمانن منٛز پھا ٹوَن واد تُلنہٕ تہٕ فتنہٕ بر پا کر نہٕ خٲطرٕ تہٕ خو ف پٔھہلا و نہٕ خٲطرٕ رنگہٕ رنگہٕ منصو بہٕ بناوان تہٕ نَوِ نَوِ افواہ ٲسۍ تُھران﴾ زانٛہہ چُھنہٕ سپدان زِ تر ٮ۪ن نفر ن در میان سپدِ کانٛہہ کنہٕ شیٚچھ، تہٕ تِمن در میان آسہِ نہٕ ژوٗرِ م اللہ تعالیٰ،یا پانژن نفر ن منٛز سپدِ شیٚچھ تہٕ تِمن منٛز آسہِ نہٕ شیٚیُم اللہ تعالیٰ۔خُفیہ کتھ کرن وٲلۍ ٲسِتن امہِ کھۅتہٕ کم زیا دٕہ، یتھ جا یہِ تہِ تِم آسن ، اللہ تعالیٰ چُھ تِمن سٍتۍ آسان، پتہٕ وَنہِ سُہ قیا مت کہ دۅ ہ تِمن زِ تِمو کیا کینژھاہ چُھ کوٚ ر مُت ۔خُدا یس چُھ پرٛتھ چیزُک علم۔"
  58,8,"۔کیا تۅہیہِ وُچھوٗکھ نا تِم لُکھ یِمن کنہٕ شیٚچھہِ کر نہٕ نِشہِ ٹھا کھ اوس آمُت کر نہٕ ۔ امہِ پتہٕ تہِ تِم سۅ ے حر کت کران ییٚمہِ نِشہِ تِمن ٹھا کھ اوس آمُت کر نہٕ ؟"
  58,9,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت، ییٚلہِ توٚہۍ پانہٕ وٲنۍ سِرٕ کتھ کٔرِو، تیٚلہِ مَہ کٔرِو گنا ہ تہٕ زیا د تی تہٕ رسول صلی اللہ علیہ وسلمن سٕنزِ نا فر مٲ نی ہٕنزٕ کتھہٕ ،
بلکہِ کٔرِ و نیکی تہٕ تقویٰ چہِ کتھہٕ، تہٕ تس خُدایس روٗزِ و کھۅژان ییٚمۍ سٕندِس خدمتس منٛز تۅہیہِ حشر س منٛز پیش چُھو سپدُن۔"
  58,10,"۔کنہٕ پھِسر اے چھےٚ اکھ شیطٲ نی کٲم ، تہٕ سۅ چھےٚ امہِ مو جو ب یِوان کر نہٕ زِ ایمان اَنن وٲلۍ گٔژھۍ تمہِ سٍتۍ غمگین سپدٕنۍ حا لا نکہ اللہ تعالیٰ  سٕندِ اِذنہٕ ورٲے ہیٚکہِ نہٕ سۅ تِمن رَژھ تہِ نقصا ن وا تنٲوِتھ، تہٕ مو نن پرِ اللہ تعالیٰ سٕے پٮ۪ٹھ بھر و سہٕ تھا وُن۔"
  58,11,"۔ اے لوٗکو یِمو ایمان چُھو اوٚنمُت، ییٚلہِ تۅہیہِ وننہٕ یِیَو پننٚین مجلِسَن منٛز کٔرِ و کُشا د گی پٲدٕ تیٚلہِ ٲسِو جا ے کران کُشا دٕ ہ۔ اللہ تعالیٰ بخشَو تۅہیہِ کُشاد گی۔﴿ اللہ تعالیٰ تہٕ رسول صلی اللہ علیہ وسلمو یِم آداب اہلِ اسلام ہیٚچِھنٲ وِ مٕتۍ چِھ تِمو منٛزٕ چھےٚ اکھ کتھ یِتہِ زِ ییٚلہِ کُنہِ مجلِسہِ منٛز گۅڈ پٮ۪ٹھٕے کینٛہہ لُکھ بِہِتھ آسن تہٕ پتہٕ یِن بیٚیہِ کینٛہہ لُکھ، تیٚلہِ گژِھہ یہِ تہذ یب گۅڈٕ نٮ۪تھ بیٖٹھۍ مٕتیٚن لُکن منٛز آسُن زِ تِم گژھن پا نے نوٮ۪ن یِنہٕ وا لیٚن جا ے تراوٕ نۍ تہٕ حتی الا مکان گژھن پنُن پان اورٕ یور ؤٹِتھ تِہندِ خٲطرٕ کُشا د گی پٲدٕ کرٕ نۍ،تہٕ تیوٗت تہذیب تہٕ شٲ یستگی گژھہ پتہٕ یِنہٕ والیٚن منٛز آسٕنۍ زِ تِم گژھن نہٕ زبردستی یِمن منٛز اَژٕ نۍ تہٕ کانٛہہ شخص گژِھہ نہٕ کٲنٛسہِ زبردستی تھوٚد تُلِتھ تٔمۍ سٕنزِ جایہِ بِہُن﴾ تہٕ ییٚلہِ تۅہیہِ وَننہٕ یِیہِ ؤتھِو تیٚلہِ گژِھہ وۅتُھن نہٕ لٲرِتھ روزُن﴾تۅہیہ، منٛز یِم لُکھ ایمان تھا ون وٲلۍ چِھ تہٕ یِمن علم چُھ بخشنہٕ آمُت ، اللہ تعالیٰ کرِ تِمن بُلند در جہِ عطا، تہٕ یِکینژھاہ توٚہۍ کران چِھو خُدایس چھےٚ تمِچ خبر۔"
  58,12,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت،ییٚلہِ توٚہۍ رسول صلی اللہ علیہ وسلمن سٍتۍ خلوَکھ کتھ کٔرِ و ،تیٚلہِ دِیِو کتھ کر نہٕ برونٛہہ کینٛہہ صد قہٕ ۔﴿ حضرت عبد اللہ بن عبا س رضی اللہ عنہ چِھ امہ، حُکمُک وجہ بیان کران زِ لُکو ٲسۍ واریاہ زیادٕہ تہٕ بِلا ضرورت خلوَکھ مُلا قا تَو خٲطرٕ درخواست لٲگِمٕتۍ کرٕ نۍ ۔﴾ یہِ چُھ تُہندِ خٲطرٕ بہتر تہٕ پٲکیزٕ ہ تر۔البتہ اگر تۅہیہِ صدقہٕ دِنہٕ خٲطرٕ کِہِنۍ اوسنہٕ ، تیٚلہِ چُھ اللہ تعالیٰ بخشن وول تہٕ رحم کر ن وول ۔"
  58,13,"۔کیا توٚہۍ کھوٚژِوٕ اَتھ کتھہِ زِ خلوَکھ کتھ با تھ کر نہٕ برونٛہہ پیٚنَو تۅہیہِ صد قا ت دِ نۍ ؟ اچھا ،اگر توٚہۍ یہِ کٔرِ و نہٕ ۔ تہٕ خُدا ین کوٚر نَو امہِ نِشہِ تۅہیہِ معا ف ۔ تیٚلہِ روٗزِ ونماز کران قٲیِم ، زکواتہ روٗزِ و دِوان، بیٚیہ، روٗزِ و اللہ تعالیٰ سٕنز تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم اطا عت کران ۔توٚہۍ یِکینژھاہ کران چِھو اللہ تعالیٰ چُھ تمہِ نِشہِ با خبر ۔ع ﴿ یہِ دوٚ یُم حُکم سپُد پٮ۪ٹھہٕ کنہِ کہ حُکمہٕ پتے کینٛہہ کال گٔژِھتھ نٲزِل تہٕ أمۍ کوٚر صد قُک و جو ب منسوح ۔اتھ کتھہِ منٛز چُھ اختلا ف زِ صد قُک یہِ حُکم کٍتِس کا لس روٗد۔ قتا دَہ چِھ ونان زِ اکہِ دۅہ کھۅتہٕ تہِ کم کالس روٗد تہٕ پتہٕ آو منسو ح کر نہٕ ۔ مُقا تِل بن حیّان چِھ ونان زِ یہِ حکم روٗد دَہَن دۅہن۔﴾"
  58,14,"۔کیا تۅہیہِ وُچُھو کھہٕ تِم لُکھ یِمو دوست چُھ بنو و مُت تِیُتھ اکھ دوٚ ر یَس پٮ۪ٹھ خدا ین غضب چُھ کوٚر مُت؟تِم نَہ چِھ تُہٕندۍ تہٕ نَہ چِھ تِہندۍ، تہٕ تِم چِھ زٲنِتھ مٲنِتھ اَپزِ کتھہِ پٮ۪ٹھ قسم کھیٚوان۔"
  58,15,"۔خُداین چُھ تِہندِ خٲطرٕ سخت عذا ب تیا ر تھو و مُت، سٮ۪ٹھاہ بُرٕ کر توٗت چِھ ، یِم تِم کران چِھ ۔"
  58,16,"۔تِمو  چِھ پنٕنۍ قسم بنٲوِ مٕتۍ  سِپر،یتھ منٛز با گ تھٲوِتھ تِم لُکن چِھ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ رُکاوان۔اتھ پٮ۪ٹھ چُھ تِہنٛدِ خٲطرٕ ذِلّتُک عذاب۔"
  58,17,"۔خُدایس نِشہِ بچا و نہٕ خٲطرٕ  نہ یِن تِہِندۍ مال بکار تہٕ نَہ تِہِندۍ اولاد۔تِم چِھ جہنمٕکۍ یار،أتھۍ منٛز روزن تِم ہمیشہ ۔"
  58,18,"۔ییٚمہِ دۅہ اللہ تعالیٰ تِمن سارِ نٕے تُلہِ، تس برونٛٹھہٕ کنہِ تہِ کھیٚن تِم تِتھے پٲٹھۍ قسم یِتھہٕ پٲٹھۍ  تۅہیہِ برونٛہہ کنہِ چِھ کھیٚوان، تہٕ تِمن با سہِ یہِ ازمہِ سٍتۍ یِیہِ یِمن کانٛہہ فٲید ہ ۔ وارٕ زٲنِو ،تِم چِھ سارِ وے کھۅتہٕ ؤسِتھ أسِتھ ا؟پزِ یٲرۍ۔"
  58,19,"۔شیطا ن چُھ تِمن پٮ۪ٹھ مُسلّط سپُد مُت ۔تہٕ تٔمۍ چھےٚ اللہ تعالیٰ سٕنز یاد تِہندِ دِلہٕ منٛزٕ مٔشرٲومٕژ۔تِم چِھ شیطا ن سٕنز پا رٹی ہٕندۍ لُکھ۔خبردار روٗزِ و، شیطا ن سٕنزِ پا رٹی ہٕندی لُکھ چِھ خسارس منٛز روزن وٲلۍ۔"
  58,20,"۔پٔز پٲٹھی چِھ ذلیل تر ین مخلو قو منٛزٕ تِم یِم اللہ تعالیٰ  تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سُند مقا بلہٕ چِھ کران،"
  58,21,"۔خُداین چُھ لیٚو کھمُت زِ بہٕ تہٕ میو رسولٕے صلی اللہ علیہ وسلم روٗزَو غٲلب سپدِ تھ۔ پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ زبردست تہٕ زور آور۔"
  58,22,"۔تۅہۍ وُچِھو نہٕ یہِ زانٛہہ زِ یِم لُکھ خُدا یس ٲخرتس پٮ۪ٹھ ایمان چِھ تھا وان ، تِم آسن تِمن سٍتۍ محبت کران یِمو خُدایس تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز مُخا لفت چھےٚ کٔرمٕژ، خواہ تِم تِہندۍ مٲلۍ  ٲسِتن ، یا ٲستن تِہِندۍ نیٚچو ۍ ، یا ٲستن تِہِندۍ بٲے ، نَتہٕ ٲسِتن تِہندِ خا ندا نٕکۍ لُکھ ۔ یِم چِھ تِم لُکھ یِہندٮ۪ن دِلن منٛز خُدا ین چُھ ایمان کوٚر مُت ثبت، تہٕ پننہِ طر فہٕ چُھنکھ اکھ رُو ح عطا کٔرِتھ طا قت بخُشمُت ۔ سُہ کرِ تِمن تِتھیٚن جنّتن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکا ن ۔یِمن منٛز روزن تِم ہمیشہ۔خداے سپُد تِمن رٲضی تہٕ تِم سپٕدۍ خُدا یس۔ تِم چِھ اللہ تعالیٰ سٕنزِ پارٹی ہٕندۍ لُکھ ۔خبردار، اللہ تعالیٰ سٕنزِ پا رٹی ہٕندی لُکھ چِھ فلا ح لبن وٲلۍ۔ع"
