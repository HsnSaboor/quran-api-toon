quran[52]{c,v,t}:
  68,1,"۔ن۔ قلمُک قسم بیٚیہِ تمہِ چیزُک قسم ییٚمہِ سٍتۍ لیٚکھن وٲلۍ لیکھان چِھ ، ﴿امام تفسیر مجا ہد چِھ فرماوان زِ قلم چُھ مُراد سُہ قلم ییٚمہِ سٍتۍ ذکر،یعنی قرآن اوس لیکھنہٕ یِوان۔اَمہِ نِشہِ چُھ پٲنۍ پانے یہِ نتیجہِ نیران زِ سُہ چیز یُس لیٚکھنہٕ اوس یِوان،تمہِ نِشہِ چُھ مُراد قرآن مجید﴾"
  68,2,"۔پننہِ ربّ سٕنٛدِ فضل سٍتۍ چِھو نہٕ توٚہۍ مجنو ن۔﴿یتھ جایہِ چُھ خطاب بظا ہر رسول اللہ صلی اللہ علیہ وسلمن کُن مگر اصلی مقصد چُھ کُفّارِ مکن تِہندِ تمہِ بہتا نُک جواب دِیُن زِ تِم ٲسۍ حضور صلی اللہ علیہ وسلمن مجنو ن وَنان۔مطلب چُھ یہِ زِ یہِ قرآن یُس وَحی ہٕند یو کٲتِبو ہٕند یو اَتھو لیٚکھنہٕ چُھ یِوان چھُ بجا ے خۅد تِہندِ اَمہِ بہتا ن کہ تر دیدٕ خٲطرٕ کٲفی۔﴾"
  68,3,"۔تہٕ یقیناً چُھ تُہندِ خٲطرٕ تِیُتھ اجر ییٚمُک سِلسلہ زانٛہہ چُھنہٕ ختم سپدن وول۔﴿یعنی تُہندِ خٲطرٕ چُھ اَتھ کتھہِ پٮ۪ٹھ بے حسا ب تہٕ لا زوال اجر زِ یِمہٕ کوٗششہِ توٚہۍ صلی اللہ علیہ وسلم اللہ تعالیٰ سٕنٛدٮ۪ن خلقن ہٕنٛدِ ہدا یت خٲ طرٕ کران چِھو،تمہِ کِس جوابس منٛز چَھو تۅہیہِ تِژٕھہ تکلیف دِنہٕ واجِنہِ کتھہٕ پیٚوان بوزنہِ مگر توتہِ چِھو توٚہۍ پنُن یہِ فر ض انجام دِوان پکان۔﴾"
  68,4,"۔تہٕ بے شک چِھو توٚہۍ اخلا ق کِس تھدِس مرتبس پٮ۪ٹھ۔﴿ یعنی قرآن علا وٕہ چِھ تُہٕندۍ بلند اخلا ق تہِ اَمہِ کتھہِ ہٕندۍ ٹا کارٕہ ثبوت زِ کُفّار یۅسہٕ دیوانگی ہٕنٛز تہمت حضور  صلی اللہ علیہ وسلمن پٮ۪ٹھ لاگان ٲسۍ سۅ چھےٚ سراسر اَپٕز،تِکیازِ اخلا قُک تھزر تہٕ دیوانگی دۅشو ے ہیٚکن نہٕ أکۍ سٕے جایہِ جمع سپدِتھ﴾"
  68,5,"۔عن قر یب وُچِھو توٚہۍ تہِ تہٕ تِم تہِ وُچھن زِ ،"
  68,6,"۔تۅہیہِ منٛز کُس چُھ جنو نس مبتلا۔"
  68,7,"۔ تُہُند ربّ چُھ تِمن لُکن تہِ وارٕپٲٹھۍ زانان یِم تٔمۍ سٕنزِ وَتہِ نِشہِ ڈٔلِتھ چھِ،تہٕ سُے چُھ تِمن تہِ زانان یِم سیٚزِ  وَتہِ پٮ۪ٹھ چِھ۔"
  68,8,"۔لہٰذا مَہ یِیِو توٚہۍ یِمن بُتھۍ پھِر ٮ۪ن ہٕندِس دَباوس منٛز ہر گز۔"
  68,9,"۔یِم چِھ یژھان زِ توٚہۍ گٔژِھو نر می کرٕنۍ تیٚلہِ کر ہن یِم تہِ نر می۔﴿یعنی توٚہۍ ترٲوِو اسلام کِس تبلیغس منٛز ڈیٚجر تیٚلہِ کرن یِم تہِ تُہندِس مخا لفتس منٛز ہنا نَر می ،یا گٔژِھو توٚہۍ تِہنزن گُمر ٲہِیَن ہٕنٛز رعایت کٔرِتھ پننِس دینس منٛز ہنا تر میم کر نس پٮ۪ٹھ آمادٕہ ،تیٚلہِ کرن تِم تۅہیہِ سٍتۍ مصا لحت﴾"
  68,10,"۔ہر گز مَہ دٔبِو تس شخصس نِشہِ یُس سٮ۪ٹھا ہ زیادٕہ قسم کھیٚنہٕ وول بے وُقعت انسان چُھ،"
  68,11,"۔طعنہٕ چُھ دِوان ،چُغلہِ کھیٚوان چُھ پھیران،"
  68,12,"۔نیکی نِشہِ چُھ رُکاوان، ظُلمس تہٕ زیادتی منٛز چُھ حدٕ نیر ن وول، سخت بد اعمال چُھ،"
  68,13,"۔ستم گر چُھ تہٕ یِمو سارِوٕے عیبو سان چُھ بد اصل،"
  68,14,"۔اَتھ بِناہس پٮ۪ٹھ زِ تس چُھ واریاہ مال تہٕ اولاد۔﴿ یتھ ہیٚکہِ پیٹِھمِس کلام کِس سلسلس سٍتۍ تہِ تعلق ٲسِتھ تہٕ اَمہِ پتہٕ کِس تہِ۔گۅڈنِکِس صوٗرتس منٛز ہیٚکیس یہِ مطلب ٲسِتھ زِ یِتھِس نفرٕ سُند دباو مَہ کٔرِ واَتھ بِنا ہس پٮ۪ٹھ قبول زِ تس چُھ سٮ۪ٹھاہ مال تہٕ اولاد۔دوٚ یِمِس صوٗرتس منٛز چُھس معنی زِ سٮ۪ٹھاہ مال تہٕ اولاد آسنہٕ مو جو ب چُھ یہِ مغرور گوٚ مُت﴾"
  68,15,"۔ییٚلہِ سٲنۍ آیات چِھ تس بو زناونہٕ یِوان تیٚلہِ چُھ ونان زِ یِم چِھ بروٗنٹھمہِ وقتٕکۍ افسا نہٕ۔"
  68,16,"۔عن قر یب لگا وَو أسۍ أمۍ سٕنٛزِ ۂسۍ نستہِ پٮ۪ٹھ داغ ۔ع ۔﴿چو نکہ سُہ چُھ پننِس پانس تھزِ نستہِ وول سمجھان امہِ موجو ب چُھ تٔمۍ سٕنٛزِ نستہِ ۂسۍ نَس وَننہٕ آمُت۔ تہٕ نستہِ پٮ۪ٹھ داغ لگا و نہٕ نِشہِ چُھ مُراد تذلیل۔یعنی أسۍ کرون سُہ دُنیا ہس تہٕ ٲخرتس منٛز تِیُتھ ذلیل و خوار زِ اَندس تام روزِ یہِ عیب تس پتے۔﴾"
  68,17,"۔اَسہِ چِھ یِم ﴿اہلِ مکّہ﴾ تِتھے پٲٹھۍ آزمٲیشہِ منٛز ترٲوِ مٕتۍ یِتھہٕ پٲٹھۍ اکہِ باغٕکۍ مٲلِک ٲسۍ اسہِ آزما یشہِ منٛز ترٲوِ مٕتۍ،ییٚلہِ تِمو قسم کھیٚو و زِ پگا ہ صُبحٲے والَو أسۍ پننِس باغس ضرور میوٕہ،"
  68,18,"۔تہٕ تِم ٲسۍ نہٕ کانٛہہ استثنا ﴿ ان شا ٔاللہ ﴾ کران۔﴿یعنی تِمن اوس پننِس طا قتس تہٕ اختیارس پٮ۪ٹھ تِیُتھ بھروسہٕ زِ قسم کھیٚتھ ووٚنُکھ بے تکلف زِ أسۍ والَو پگا ہ ضروٗر پننِس باغس میوٕہ تہٕ یہِ وننٕچ ضرورت ٲس نہٕ تِمن باسان زِ اگر خُداین یوٚژھ تیٚلہِ سپدِ یہِ کٲم﴾"
  68,19,"۔رٲتھۍ کِیُت ٲسۍ تِم شۅ نگِتھ زِ تُہندِس ربّ سٕندِ طر فہٕ پھیٖر تتھ باغس اکھ بلا ے،"
  68,20,"۔تہٕ تتھ سپُد سُہ حال زنتہٕ لوٗنمُت فصل اوس۔"
  68,21,"۔صُبحٲے چِھ تِم اکھ أکِس آلَو کران زِ ،"
  68,22,"۔اگر میوٕہ چُھو والُن تیٚلہِ نیرِ و سُلہِ سُلہِ پننِس زمینس کُن۔"
  68,23,"۔چنا نچہِ درٚاے تِم تہٕ پانہٕ وٲنۍ ٲسۍ ژوٗرِ ژوٗرِ وَنان،"
  68,24,"۔زِ یِنہٕ اَز کانٛہہ مسکین تُہندِس باغس نکھہٕ یِیہِ۔"
  68,25,"۔تِم درٛاے کینٛہہ نَہ دِنُک فٲصلہٕ کٔرِتھ جلد ی جلد ی سُلی تِتھہٕ پٲٹھۍ تور زَنتہٕ تِم ﴿ میوٕہ والنس پٮ۪ٹھ ﴾قدر ت چِھ تھا وان۔"
  68,26,"۔مگر ییٚلہِ باغ وُچُھکھ،تِم لٔگۍ وَننہِ "" اَسہِ چھےٚ وَتھ گٔمٕژ مٔشِتھ،"
  68,27,"نَہ ،بلکہ چِھ أسۍ محروم روٗدِمٕتۍ۔"
  68,28,""" تِمو منٛزٕ یُس سارِوٕے کھۅتہٕ بہتر شخص اوس تٔمۍ ووٚن،""مےٚ اوسمَو نا تۅہیہِ ووٚنمُت زِ توٚہۍ کیازِ چِھو نہٕ تسبیح کران؟""﴿یعنی اللہ تعالیٰ کیازِ چھوٗن نہٕ یاد کران ؟ تِکیازِ یہِ کتھ چَھو مٔشِتھ گٔمٕژِ زِ پٮ۪ٹھہٕ کنہِ چُھ پاک پروردگار موجود؟﴾"
  68,29,"تِمو دِژ کریٚکھ ""پاک چُھ سون ربّ ،پزی ٲسۍ أسۍ گناہ گار۔"""
  68,30,"پتہٕ لٲج تِمو اکھ أکِس ملا مت کرٕنۍ۔"
  68,31,"۔پوٚتُس ووٚن تِمو "" افسوس سٲنِس حالس پٮ۪ٹھ ،بے شک ٲسۍ أسۍ بُتھۍ پھِرۍ گٔمٕتۍ۔"
  68,32,"۔دوٗر چُھنہٕ زِ سون ربّ دِیہِ اَسہِ اَمہِ کھۅتہٕ بہتر باغ۔أسۍ چِھ پننِس ربّس کُن رجوع کران۔"""
  68,33,"۔ یُتھ چُھ آسان عذاب،تہٕ ٲخرتُک عذاب چُھ اَمہِ کھۅتہٕ تہِ بوٚڈ،کاش زانہَن یِم لُکھ اَتھ ۔ع"
  68,34,"۔پٔزِ پٲٹھۍ چِھ خُدا ترس لُکن خٲطرٕ تِہندِس ربّس نِشہِ نعمتن ہٕنٛدۍ جنّت ﴿مکٕکۍ بٔڑۍ بٔڑۍ سردار ٲسۍ مُسلمانن ونان زِ یِمہٕ نعمت اَسہِ دُنیا ہس منٛز میلان چھےٚ ،یہِ چھےٚ علا مت اَمہِ کتھہِ ہٕنٛز زِ أسۍ چِھ خُدایس نِشہِ مقبول،تہٕ یتھ بد حٲ لی منٛز توٚہۍ چِھو مبتلا،یہِ چھےٚ اَمہِ کتھِ ہٕنٛز دٔلیل زِ تۅہیہِ پٮ۪ٹھ چُھ اللہ تعالیٰ سُند غضب۔لہٰذا اگر کانٛہہ ٲخرت اوس تہِ،یِتھہٕ پٲٹھۍ زَن توٚہۍ وَنان چِھو،أسۍ کرَو تَتہِ تہِ عیش،عذاب آسیو تۅہیہِ، نہ کہ اَسہِ۔امِیُک جواب چُھ یِمن آیا تن منٛز دِنہٕ آمُت﴾"
  68,35,"۔ أسۍ کر وٕہ فر مان بردارن ہُند حال مُجر من ہُند ہیوٗ،"
  68,36,"۔تۅہیہِ لُکن کیا چُھو گوٚ مُت،توٚہۍ کِتھۍ حُکم چِھو لگا وان۔"
  68,37,"۔کیا تۅہیہِ نِشہِ چھا کانٛہہ کتاب۔ ﴿یعنی اللہ تعالیٰ سٕنز سوز نہٕ آمٕژ کانٛہہ کتاب ﴾ یتھ منٛز توٚہۍ یہِ پران چِھو زِ ،"
  68,38,"۔تُہندِ خٲطرٕ چُھ تَتہِ ضروٗرتی کینٛژھاہ یِکینٛژھاہ توٚہۍ پننہِ خٲطرٕ چِھو پسند کران؟"
  68,39,"۔کِنہٕ تُہندِ خٲطرٕ چِھ قیا مت کِس دۅہس تام اسہِ پٮ۪ٹھ کینٛہہ عہدو پیمان ثٲبت زِ تۅہیہِ میلیو تی کینٛژھاہ ،ییٚمیُک توٚہۍ حکم لگٲوِو؟"
  68,40,"۔یِمن پٔرٛ ژِ ھو تۅہیہِ منٛز کُس چُھ اَمیُک ضٲمِن؟"
  68,41,"۔کِنہٕ یِہِندۍ کینٛہہ ٹھٔہراونہٕ آمٕتۍ شر یک چِھ ﴿ یِمو اَمیُک ذِمہٕ آسہِ روٚٹمُت﴾؟اگر یہِ کتھ چھےٚ تیٚلہِ أنِن پننیٚن شر یکن اگر یِم پٔزِیٲرۍ چِھ۔"
  68,42,"۔ییٚمہِ دۅ ہ سخت وقت واتہِ، تہٕ لُکھ یِن سجدٕہ کر نہٕ خٲ طرٕ بُلا ونہٕ،یِم لُکھ ہیٚکن نہٕ سجدٕہ کٔرِتھ،"
  68,43,"۔یِہنٛزٕ نظرٕ آسن بۅ ن کُن،یِمن پٮ۪ٹھ آسہِ ذّلت وَسان۔ییٚلہِ یِم صحیح وسالم ٲسۍ تمہِ ساعتہٕ ٲسۍ یِم سجدٕہ خٲطرٕ بُلا و نہٕ یِوان ﴿تہٕ یِم ٲسۍ انکار کران ﴾"
  68,44,"۔لہٰذا ،اے نبی صلی اللہ علیہ وسلم،توٚہۍ ترٲوِو اَتھ کلا مس انکار کر ن والیٚن ہُند معا ملہٕ مےٚ پٮ۪ٹھ۔أسۍ نِمو کھ یِم تمہِ طر یقہٕ در جہ پتہٕ در جہ تبٲہی کُن زِ یِمن لگہِ نہٕ خبر تہِ۔"
  68,45,"۔بہٕ چُھس یِہٕنز رَز ڈیٚج ترٛاوان،میٲنۍ چال چھےٚ بٔڑِزبردست۔"
  68,46,"۔کیا توٚہۍ چِھوٕ ہ یِمن نِشہِ کانٛہہ اجر طلب کران زِ ،یِم آسن اَتھ چیٚٹہِ ہٕندِس بارس تل دٔبِتھ گژھان؟"
  68,47,"۔ کیا یِمن نِشہِ غیبُک علم ییٚمہِ سٍتۍ یِم لیٚکھان آسن ؟"
  68,48,"۔اچھا ،کٔرِو پننِس ربّ سُنٛد فٲصلہٕ صٲدِر سپد نس تام صبر۔ تہٕ گاڈِ وٲلۍ ﴿ یو نس علیہ السلام﴾ سٕنٛدۍ پٲٹھۍ یِنہٕ بٔنِو، ﴿ یعنی یونس علیہ السلامن ہٕنٛدۍ پٲٹھۍ ہے زیٚو نہٕ بے صبر ی کٲم ، یِم پننہِ بے صبر ی ہٕنٛدِ وجہ کِنۍ گاڈِ ہٕنٛدِس شکمس منٛز واتناو نہٕ ٲسۍ آمٕتۍ﴾ییٚلہِ تٔمۍ ناد اوس لویمُت تہٕ سُہ اوس غمہٕ ہوٚت۔"
  68,49,"۔ اگر تٔمۍ سٕنٛدِس ربّ سٕنٛز مہر بٲ نی تس شٲ ملِ حال سپدِ ہے نہٕ، تیٚلہِ یِیہِ ہے سُہ ہموار مٲدانس منٛز چھکنہٕ تہٕ سُہ آسِہے ملا مت زدٕہ ﴿ ابتر حا لتس منٛز﴾۔"
  68,50,"۔ ٲخر کار کوٚر سُہ تٔمۍ سٕنٛدۍ ربّن بر گُز یدٕہ،تہٕ سُہ کوٚرُن صالح  بند ن منٛز شٲ مِل۔"
  68,51,"۔ییٚلہِ یِم کٲ فر نصیحتُک کلا م﴿قرآن ﴾ چِھ بوزان، تیٚلہِ چِھو تۅہیہِ تِمو نظرو سٍتۍ وُچھان زِ زَنتہٕ تُہٕنٛدۍ قد م موٗلے کڑن،بیٚیہِ چِھ ونان زِ یہِ چُھ ضرور دیوانہٕ،"
  68,52,"۔حالانکہ سارِنٕے دُنیا والیٚن خٲطرٕ چُھ یہِ اکھ نصیحت۔ ع"
