quran[73]{c,v,t}:
  33,1,"۔اے نبی صلی اللہ علیہ وسلم ! خُدایس کھوٚژِو، بیٚیہِ مَہ کٔرِو کُفّار ن تہٕ مُنا فقن ہٕنز اطا عت،۔در حقیقت چُھ زانن وول تہٕ حکمت وول اللہ تعالیٰ ہٕے۔"
  33,2,"۔پیروی کٔرِو تمہِ کتھہِ ہٕنز ییٚمیُک اِشا رٕ ہ تُہٕندِس ربّ سٕندِ طر فہٕ تۅہیہِ کر نہٕ چُھو یِوان ، اللہ تعالیٰ چُھ پرٛتھ تمہِ کتھہِ نِشہِ با خبر ، یہِ توٚہۍ لُکھ کرا ن چِھو۔"
  33,3,"۔خُدا یس پٮ۪ٹھ کٔرِو تو کّل، اللہ تعالیٰ ہٕے چُھ کار ساز آسنہٕ خٲطرٕ کٲفی۔"
  33,4,"۔ خُدا ین چِھنہٕ کٲنٛسہِ شخصہٕ سٕندِس وَچَھس منٛز زٕ ہ دل تھٲوِ مٕتۍ، نہٕ چھےٚ تٔمۍ تۅہیہِ لُکن ہٕنزٕ تمہِ خا ندا رِ نہِ یِمن سٍتۍ توٚہۍ ظِہا ر چِھو کران۔ تُہٕنزٕ ماجہِ بنا وِ مَژٕ، ﴿ظِہا رُک مطلب چُھ خا ندارِنہِ دِ نۍ ما جہِ سٍتۍ تشبیہ﴾تہٕ نہ چِھ تٔمۍ تُہٕندۍ منگتہٕ نیچو ی تُہٕندۍ اصلی نیچو ۍ بنٲوِ مٕتۍ۔یِمہٕ چھےٚ تِمہٕ کتھہٕ ، یِمہٕ توٚہۍ لُکھ پننہِ چا نٹہِ کڑا ن چِھو، مگر اللہ چُھ سۅ کتھ ونان یۅسہٕ حقیقتس پٮ۪ٹھ مبنی چھےٚ، تہٕ سُے  چُھ صحیح طر یقس کُن رہنمٲیی کران۔"
  33,5,"۔منگتہٕ نیچو ٮ۪ن کٔرِو تِہند ٮ۪ن ما لیٚن ہٕندِ نسبت سٍتۍ آلو، یہِ چھےٚ خُدا یس نز دیک زیا دہ مُنصفا نہٕ کتھ۔ تہٕ اگر تۅہیہِ پے آسیٚو نہٕ زِ تِہِندۍ مٲلۍ کم چِھ ، تیٚلہِ چِھو تِم تۅہیہِ دینی بٲے تہٕ رفیق۔ یۅسہٕ کتھ توٚہۍ نا دٲنستہٕ پٲٹھۍ ؤنِو ، تمہِ خٲطرٕچَھنہٕ تۅہیہِ پٮ۪ٹھ کانٛہہ گر فت ، البتہ اتھ کتھہِ پٮ۪ٹھ چھےٚ ضرور گرفت ییٚمیُک توٚہۍ دِلہٕ سان اردإہ کٔرِو۔ اللہ تعالیٰ چُھ در گُز ر کر ن وول تہٕ مہر بان ۔"
  33,6,"۔بے شک چِھ نبی صلی اللہ علیہ وسلم اہلِ ایمانن  خٲطرٕ تِہندِس پننِس ذا تس پٮ۪ٹھ مقدّم ﴿یعنی زیا دہ حقدار تہٕ سر س ﴾، تہٕ نبی صلی اللہ علیہ وسلمن ہٕنزٕ خا ندارِ نہٕ چھےٚ تِہنزٕ ماجہِ ، مگر اللہ تعالیٰ سٕنزِ کتا بہِ کِنۍ چِھ عا م مو منن تہٕ مہا جر ن ہٕندِ نسبت رشتہٕ دار اکھ أکۍ سٕندۍ زیادہ حقدار ، البتہ اگر پننیٚن رفیقن سٍتۍ توٚہۍ رٕژر ﴿ کرُن ییٚژِھو تیٚلہِ ﴾ ہیٚکِو کٔرِ تھ۔ یہِ حُکم چُھ اللہ تعالیٰ سٕنزِ کتا بہِ  منٛز لیٚکھِتھ۔"
  33,7,"تہٕ ﴿ اے نبی صلی اللہ علیہ وسلم ﴾ یاد تھٲوِ و سُہ عہد و پیمان ، یُس اسہِ سارِ نٕے پیغمبرن چُھ ہیوٚتمُت، تۅہیہِ تہِ ، تہٕ نو ح علیہ السلامس تہِ ، تہٕ ابرا ہیم علیہ السلامس تہٕ مو سیٰ  علیہ السلام تہٕ عیسیٰ ابنِ مر یم علیہ السلامس تہِ۔ سارِ نٕے چُھ اسہِ پۅختہٕ عہد ہیوٚتمُت۔ ﴿ یتھ آیتس منٛز چُھ اللہ تعالیٰ نبی صلی اللہ علیہ وسلمس یہِ کتھ یا د پاوان زِ تمام انبیا علیھُم السلامن ہٕندۍ پٲٹھۍ چُھ تۅہیہِ  تہِ خُدا ین اکھ پۅ ختہٕ عہد ہیوٚتمُت ییٚمِچ تۅہیہِ سختی سان پا بند ی پزِ کرٕ نۍ۔ ہیرِ پٮ۪ٹھہٕ یُس کلا مُک سلسلہٕ پکا ن چُھ، اتھ پٮ۪ٹھ غور کر نہٕ سٍتۍ چُھ صا ف پے لگا ن زِ امہِ نِشہِ چُھ مُراد یہِ عہد زِ پیغمبر کرِ اللہ تعالیٰ سٕندِ پرٛتھ حکمٕچ پانہٕ اطا عت ، بیٚیہِ کر ناوِ با قین تہِ ۔ اللہ تعالیٰ سٕنزٕ کتھہٕ و اتنا وِ کا نٹھ چھا نٹھہٕ ورٲے ، تہٕ یِمہٕ عملاً نٲفذ کر نہٕ چہِ کو ششہِ تہٕ جدوجہد س منٛز کر نہٕ کانٛہہ ہِرا سہٕ۔ قرآن مجیدس منٛز چھےٚ امہِعہدٕ چ ذکر واریاہن جا ین کر نہٕ آمٕژ۔ مثلاً البقرہ آیت 83، آلِ عمرا ن آیت 187۔ المایدہ آیت 7۔ الا عرا ف آیات 169۔ 171، الشوریٰ آیت 13۔﴾"
  33,8,"تا کہِ پٔزِ یٲرٮ۪ن کرِ ﴿ تُہِند رب﴾ تِہنزِ سچٲیی متعلق سوال، تہٕ کا فر ن خٲطرٕ چُھ تٔمۍ دگ تُلہٕ وُن عذا ب دستیا ب تھوو مُتُے۔ ع"
  33,9,"اے لوٗکو ،یِمو ایمان چُھو اوٚ نمُت۔ ﴿ ییٚتہِ پٮ۪ٹھہٕ چھےٚ آیت 27 ہس تام غزوۂ احزا ب تہٕ غزوۂ نبی قر یظ ہٕچ ذکر کر نہٕ آمٕژ۔ ﴾ یا د کٔرِو اللہ تعالیٰ سُند احسا ن، یُس تٔمۍ ﴿ حال حا لٕے ﴾ تۅہیہِ پٮ۪ٹھ چُھ کوٚر مُت۔ ییٚلہِ لشکر و تۅہیہِ پٮ۪ٹھ حملہٕ کوٚر ، پتہٕ سوٗز اَسہِ تِمن پٮ۪ٹھ اکھ سخت وُنل، تہٕ تِتھۍ فو ج کٔر ۍ روا نہٕ ، یِم تۅہیہِ اتھہِ ٲسِو نہٕ یِوان ۔ ﴿ یعنی فر شتن ہٕندۍ فو ج ﴾ اللہ تعالیٰ اوس تہِ سورُے وُچھا ن یہِ توٚہۍ تمہِ ساعتہٕ کرا ن ٲسِو"
  33,10,"۔ییٚلہِ دشمن پیٚٹھۍ کِنۍ تہٕ بٔنۍ کِنۍ تۅہیہِ حملہٕ ٲسِو کرا ن، ییٚلہِ خو فہٕ سٍتۍ أچھ لجہِ دَرس ، وٲنِجہِ لَجہِ ٲسہٕ کِنۍ کھسنہِ۔تہٕ تۅہیہِ لُکو لٲگِو اللہ تعالیٰ سٕندِ س با رس منٛز رنگہٕ رنگہٕ گُما ن کرٕ نۍ ۔"
  33,11,"۔ تمہِ وقتہٕ آے ایمان انن وٲلۍ وارٕ پٲٹھۍ آز ماو نہٕ ، تہٕ سخت پٲٹھۍ آے دٕنہٕ وَنہٕ ۔"
  33,12,"۔یاد کٔرِو سُہ وقت ییٚلہِ منا فقین تہٕ تِم سٲر ی لُکھ یِہند ٮ۪ن دِلن منٛزبیمارۍ ٲس صاف صاف ٲسۍ ونان زِخداین تہٕ تٔمۍ سٕندۍ رسول صلی اللہ علیہ وسلمن یِم وعدٕہ اسہِ سٍتۍ کٔرِ مٕتۍ ٲسۍ، تِم ٲسۍ نہٕ فریب ورٲے کِہِنۍ۔"
  33,13,"۔ییٚلہِ تِمو منٛزٕ أکۍ دٔرۍ ووٚ ن زِ ،  اے یثر ب کیو لوٗکو، تُہندِ خٲطرٕ چُھنہٕ وۅ نۍ ٹھہر نُک کانٛہہ مو قع، پھیٖرِ و پوٚت ۔  ییٚلہِ تِہُند اکھ فر یق  نبی صلی اللہ علیہ وسلمس یہِ ؤنِتھ رخصت اوس منگا ن زِ ، سٲنۍ گھرٕ چِھ خطر س منٛز۔ حالانکہ ٲسۍ نہٕ تِم خطر س منٛز،  در اصل ٲسۍ تِم ﴿جنگ کہ محا ذٕ نِشہِ ﴾ ژلُن یژھان ۔"
  33,14,"۔اگر شہرٕ کیٚو اَنَد و کِنۍ دشمن آسہن ژا مٕتۍ، تہٕ تمہِ وقتہٕ یِیہِ ہے یِمن فِتنس کُن دعوت دِنہٕ ، تیٚلہِ یِہَن یِم تتھ منٛز ہیٚنہٕ ، تہٕ مُشکلنٕے آسہِ ہے یِمن فِتنس منٛز شر یک سپد نس منٛز کانٛہہ حر ج۔"
  33,15,"۔یِمو لُکو اوس امہِ برونٛہہ خُدا یس سٍتۍ عہد کوٚر مُت زِ یِم پھِرَن نہٕ شا نہٕ ، تہٕ خُدا یس سٍتۍ کر نہٕ آمتہِ عہدٕ چ پرٕژھگٲر ٲس سپد ن واجِنی۔"
  33,16,"۔ اے نبی صلی اللہ علیہ وسلم ، یِمن ؤنِو اگر توٚہۍ موت یا قتل نِشہِ ژٔلِو ، یہِ ژلُن آسہِ نہٕ تُہندِ خٲطرٕ رَژھ تہِ نفع بخش۔ امہِ پتہٕ ہیٚکیَو  زند گی ہٕندۍ مزٕ ہ لوٗٹنک کمٕے مو قع پیٖلِتھ۔"
  33,17,"۔ یِمن ؤنِو ، کُس چُھ یُس تۅہیہِ خُدا یس نِشہِ بچٲوِتھ ہیٚکہِ اگرسُہ تۅہیہِ نقصان وا تنا وُن ییژِھہ ؟تہٕ کُس ہیٚکہِ تٔمۍ سٕندِس رحمتس رُکٲوِتھ اگر سُہ تۅہیہِ پٮ۪ٹھ مہربٲنی ییٚژِھہ کرٕنۍ ؟ اللہ تعالیٰ سٕندِس مُقا بلس منٛز ہیٚکن نہٕ یِم لُکھ کانٛہہ حٲمی تہٕ مدد گا ر لٔبِتھ۔"
  33,18,"۔اللہ تعالیٰ چُھ تۅہیہِ منٛزٕ تِمن لُکن وارٕ پٲٹھۍ زانان یِم ﴿جنگ چہِ کامہِ منٛز ﴾ رُکا وٹہٕ ترا وَن وٲلۍ چِھ ، یِم پننیٚن با ین چِھ ونان زِ  ؤلِو اَسہِ کُن ۔ یِم لڑا یہِ منٛز حصّہٕ تہِ نِوا ن چِھ مگر بس ناو گٕنز راونہٕ موجوٗب،"
  33,19,"۔ یِم  تۅہیہِ ساتھ دِ نس منٛز سٮ۪ٹھاہ بخیل چِھ ۔  خطرُک وقت ییٚلہِ  واتان چُھ، تیٚلہِ چھِ تِتھہٕ پٲٹھۍ أچھ پھرۍ پھرۍ تۅہیہِ کُن وُچھان زنتہٕ کٲنٛسہِ مر ن وٲلِس آسہِ بے ہوشی طٲری سپدان، مگر ییٚلہِ خطرٕ ہ دوٗر چُھ گژھان، تیٚلہِ چِھ یِمے لُکھ فٲید ن ہٕندۍ حر یص بٔنِتھ قینچی ہٕندۍ پٲٹھۍ چلن وا جِنہِ زیٚوٕ ہیٚتھ تُہٕندِ استقبا لہٕ خٲطرٕ یِوان ۔ یِمو لُکو اوٚ ن نہٕ ہر گز ایمان، اَمی موجو ب کٔرۍ خُدا ین یِہِندۍ سٲر ی اعمال ضا یع۔ تہٕ یہِ کرُن چُھ اللہ تعالیٰ سٕندِ خٲطرٕ واریاہ آسان۔"
  33,20,"۔یِم چِھ سمجھان زِ حملہٕ کر ن وٲلۍ چِھنہٕ وُنہِ گٔمٕتۍ۔ تہٕ  اگر تِم بیٚیہِ حملہٕ آوَر سپدن، تیٚلہِ چُھ یِمن دل ونان زِ اَتھ مو قعس پٮ۪ٹھ بیٚہَن یِم صحرا وَس منٛز صحرٲوۍ لُکن منٛز با گ ،تہٕ تَتی پٮ۪ٹھہٕ روزن تُہٕندۍ حالات پٕرٛژھان ۔ تاہم اگر یِم تۅہیہِ در میان روٗز ن تہِ ، تیٚلہِ ﴿ تہِ ﴾ نِن لڑا یہِ منٛز کمٕے پہن حصّہٕ ۔ع"
  33,21,"۔ در حقیقت اوس تۅہیہِ لُکن خٲطرٕ اللہ تعالیٰ سٕندِس  رسول صلی اللہ علیہ وسلمس اندر اکھ بہتر ین نمو نہٕ ، ﴿ دوٚ یُم تر جمہٕ ہیٚکٮ۪س یِتہِ سپدِ تھ زِ بہتر ین نمو نہٕ چُھ﴾ پرٛتھ تس شخصہٕ سٕندِ خٲطرِ  یُس اللہ تعالیٰ تہٕ ٲخرت کہ دۅ ہُک اُمید وار آسہِ، تہٕ کثر ت سان کرِ خُدا یس یاد۔"
  33,22,"۔تہٕ پز ٮ۪ن مو منن ﴿ ہُند حال اوس تمہِ وقتہٕ یہِ زِ ﴾ ییٚلہِ تِمو حملہٕ آور لشکر وُچھ، تِمو دِژ کر یکھ زِ یہِ چُھ سُے چیز، ییٚمیُک وعدٕہ خدا ین تہٕ تٔمۍ سٕندۍ رسول صلی اللہ علیہ وسلمن اسہِ سٍتۍ اوس کوٚر مُت ، اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلمن ہٕنز کتھ ٲس بالکل پٔز۔أمۍ وا قعن کوٚر تِہندِس ایمانس تہٕ تِہنزِ سپُردگی وارے اضا فہٕ﴿ یعنی تُہِنٛد ایمان تہٕ فر مان بردٲر ی ہُنٛد جز بہٕ ہُرِ یا و ز یادے﴾۔"
  33,23,"۔ایمان انن والیٚن منٛز چِھ تِتھۍ لُکھ مو جو د یِمو خُدا یس سٍتۍ کر نہٕ آمُت عہد پوٚز بنٲوِتھ ہو و۔یِمو منٛزٕ کٔر کٲنٛسہِ پنٕنۍ نذ ر پوٗرٕ ، تہٕ کانٛہہ چُھ یِمَو منٛزٕ وقتس پراران۔یِمو کٔر نہٕ پننِس رٔوِّیس منٛز کانٛہہ تبدیلی۔ ﴿ یہِ سورُے کینٛہہ سپُد امہِ موجوٗب﴾"
  33,24,"۔تا کہ اللہ تعالیٰ دِیہِ پٔزِ یا رٮ۪ن تِہندِ پزرُک جز اتہٕ اگر منا فقن ییٚژِھہ تِمن دِیہِ سزا، تہٕ اگر ییٚژِھہ تیٚلہِ کرِ تِہُند تو بہٕ قبو ل، بے شک چُھ اللہ تعالیٰ غفور ورحیم۔"
  33,25,"۔ خُدا ین پھِیرُ کُفّارن ہُند بُتھ، تِم پھیٖرۍ کانٛہہ فٲیدٕ ہ حٲصل کر نہٕ ورٲے پننہِ دِلُک دَزُن ہیٚتھ ژھرِ وٕے اَتھو وا پس، تہٕ مو منن ہٕندِ طر فہٕ سپُد اللہ تعالیٰ ہٕے لڑ نہٕ خٲطرٕ کٲفی، اللہ تعالیٰ چُھ سٮ۪ٹھاہ قُوّت وول تہٕ زبردست۔"
  33,26,"۔ اہلِ کتا بو منٛزٕ یِمو لُکو پتہٕ تِمن حملہٕ کر ن والیٚن ساتھ دِیتمُت اوس، ﴿ یعنی یہو د بنی قر یظ﴾ خداین وٲلۍ تِم تِہند یو قلعَو پٮ۪ٹھہٕ ، تہٕ تِہند ٮ۪ن دِلن منٛز تر وو تٔمۍ تِیُتھ بیٖم زِ ، اَز چِھو توٚہۍ تِمو   منٛزٕ اکھ دوٚر قتل کران تہٕ بیا کھ دوٚر چھوٗن قٲد کران۔"
  33,27,"۔تٔمۍ بنٲوِ نَو توٚہۍ تِہندِ زمینٕکۍ تہٕ تِہند ٮ۪ن گھر ن تہٕ تِہند ٮ۪ن مالن ہٕندۍ وٲرث ، تہٕ سُہ علا قہٕ دُیتنَو تۅہیہِ یَتھ منٛز نہٕ تۅہیہِ زانٛہہ قد م اوسُو ترٛوو مُت۔ اللہ تعالیٰ  چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھا وان۔ ع"
  33,28,"۔اے نبی صلی اللہ علیہ وسلم ، پننیٚن خا ندارِ نیٚن ؤنِو، اگر توٚہۍ دُنیا تہٕ اَمِچ زینت چَھو یژھان، ؤلِو تیٚلہِ ، بہٕ کٔرو کینٛہہ دِتھ توٚہۍ رٕتۍ پٲٹھۍ رخصت۔ ﴿ یہِ آ یت ٲس تمہِ وقتہٕ نٲزِل گٔمٕژ ییٚلہِ رسول صلی اللہ علیہ وسلمن ہٕندِ گھرِ فا قن پٮ۪ٹھ فا قہٕ  لٔگِتھ دۅہ ٲسۍ نیران تہٕ ازوا جِ مطہرا ت آسہٕ سخت پر یشا ن ﴾"
  33,29,"۔تہٕ اگر توٚہۍ  اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم تہٕ ٲخرت کہ گھر چہِ طٲلب چَھو، تیٚلہِ زٲنِو زِ تۅہیہِ منٛزٕ یِمہٕ نیکو کار چھےٚ، خدا ین چُھ تِہندِ خٲطرٕ بوٚڈ اجر دستیا ب تھو و مُت۔"
  33,30,"۔ اے نبی صلی اللہ علیہ وسلمن ہٕنز و خا ندارِ نیو ، تۅہیہِ منٛزٕ یۅسہٕ کُنہِ ٹا کارٕ فحش حر کتُک ارتکا ب کرِ ، تس یِیہِ دۅ گنہٕ عذا ب دِنہٕ ۔ ﴿ اَمیُک چُھنہٕ یہِ مطلب زِ ازواجِ مطہر اتَو نِشہِ کیا اوس معا ذ اللہ  کُنہِ فحش حر کتُک اندیشہِ ، بلکہ اوس مقصد تِمن یہِ احساس دِیُن زِ توٚہۍ چَھو سار ی امّت چہ ماجہِ ، اَمہِ موجوٗب کٔرِ زیٚو نہٕ پننہِ مر تبہٕ نِشہِ ؤسِتھ کانٛہہ کٲم۔ ﴾ خدا یس خٲطرٕ چھےٚ یہِ کٲم سٮ۪ٹھاہ سہل۔"
  33,31,"۔تہٕ تۅہیہِ منٛزٕ یۅسہٕ اللہ تعالیٰ سٕنٛز تہٕ رسول صلی اللہ علیہ وسلم سٕنز اطا عت کرِ ، تہٕ بیٚیہِ کرِ نیک عمل، تس دِمَو أسۍ دۅ گنہٕ اجر، تہٕ اَسہِ چُھ تس خٲطرٕ رزقِ کریم ﴿عز تُک رزق ﴾ تیار  تھو و مُت۔"
  33,32,"۔نبی صلی اللہ علیہ وسلمن ہٕنز و خا ندارِ نیو ، توٚہۍ چَھو نہٕ عا م مستوٗراتن ہٕندۍ پٲٹھۍ۔ اگر توٚہۍ خدا یس کھۅژن وا جِنہِ چَھو تیٚلہِ مَہ ٲسِو وُٹھو تٔلۍ کتھ کران﴿یعنی میٹھہِ اندازٕ ہ مَہ ٲسِو کتھ کرا ن﴾،زِ دل چہِ خرٲبی ہُند مبتلا کانٛہہ شخص پیٚیہِ لا لچہِ منٛز، بلکہ کٔرِو صا ف سیوٚد کتھ۔"
  33,33,"۔پننیٚن گھر ن منٛز روٗزِ و قرار کٔرِ تھ، تہٕ پٔتمہِ دورِ جہا لتُک بنا و سنگار ہا وان مَہ پھیٖرِ و، نماز کٔرِ و قٲیِم ،تہٕ زکواتہ دِیِو، بیٚیہِ کٔرِو اللہ تعالیٰ  تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز اطا عت۔ اللہ تعالیٰ چُھ یہِ یژھان زِ تۅہیہِ نبی صلی اللہ علیہ وسلمن ہٕند یو اہلِ بَیتَو نِشہِ کرِ گند گی دوٗر، تہٕ تۅہیہِ کر یوٚ پوٗرٕ پٲٹھۍ پاک۔"
  33,34,"۔یاد تھٲوِ و اللہ تعالیٰ سٕندۍ آیات تہٕ حکمت چہِ تِمہٕ کتھہٕ یِمہٕ تُہٕندٮ۪ن گھر ن منٛز بو ز ناو نہٕ چھےٚ یِوان ۔ بے شک چُھ اللہ تعالیٰ لطیف ﴿ یعنی پوشیدہ کھۅ تہٕ پو شیدہ کتھ زانن وول ﴾ تہٕ با خبر ۔ ع"
  33,35,"۔بے شک یِم مر د تہٕ یِمہٕ مستوٗراتہٕ مُسلم چِھ ، یِم مر د تہٕ یِمہٕ مستوراتہٕ مو من چِھ ، یِم مر د تہٕ یِمہٕ مستوٗراتہٕ فر ماں بردار چِھ ، یِم مر د تہٕ یِمہٕ مستوٗراتہٕ پٔزیٲرۍ چِھ ، یِم مر د تہٕ یِمہٕ مستوٗراتہٕ صٲبر چِھ ، یِم مر د تہٕ یِمہٕ مستوٗراتہٕ خدا یس بر ونٛہہ کنہِ عٲجز ی سان نمن وٲلۍ چِھ ، یِم مرد تہٕ یِمہٕ مستوٗراتہٕ صد قہٕ دِنہٕ وٲلۍ چِھ ، یِم مردتہٕ یِمہٕ مستوٗراتہٕ روزٕ ہ تھا و ن وٲلۍ چِھ ، یِم مر د تہٕ یِمہٕ مستوٗراتہٕ پننیٚن شر مگا ہن حفا ظت کر ن وٲلۍ چِھ ، یِم مر د تہٕ مستوٗراتہٕ خُدا یس کثر ت سان یاد کر ن وٲلۍ چِھ ، خُدا ین چھےٚ تِہندِ خٲطرٕ مغفر ت تہٕ بوٚڈ اجر دستیا ب تھو و مُت۔"
  33,36,"۔کٲنٛسہِ مو من مردس تہٕ کٲنٛسہِ مو من خا تو نہ چُھنہٕ یہِ حق زِ ، ییٚلہِ اللہ تعالیٰ تہٕ تٔمۍ سُند رسو ل صلی اللہ علیہ وسلم کُنہِ معا ملُک فٲصلہٕ کر ن، تہٕ پتہٕ روزِ تس پننِس تتھ معا ملس منٛز خۅد فٲصلہِ کر نُک کانٛہہ اختیارحٲصل۔ تہٕ یُس اکھا ہ اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز نا فر مٲنی کرِ ، تیٚلہِ پیوٚ و سُہ ٹا کارٕ ہ گُمرٲہی منٛز۔"
  33,37,"۔اے نبی صلی اللہ علیہ وسلم ، یا د کٔرِ و سُہ مو قع ییٚلہِ توٚہۍ تس شخصس ٲسِو ونان یس پٮ۪ٹھ خُدا ین تہٕ تۅ ہیہِ احسا ن اوسُو کوٚر مُت زِ، پنٕنۍ خا ندارِ نۍ مَہ ترا وُن تہٕ خُدا یس کھۅژ۔ ﴿ تس شخصس نِشہِ چُھ مُراد حضر ت زید بن حا رثہ رضی اللہ عنہ یِم رسول اللہ صلی اللہ علیہ وسلمن ہٕندۍ آزاد کر نہٕ آمٕتۍ غلا م تہٕ تِہندۍ منگتہٕ نیچِو ۍ ٲسۍ۔تہٕ تِہنزِ خا ندار نہِ نِشہِ چُھ مُراد حضر ت زینب رضی اللہ عنہا یۅسہٕ حضور صلی اللہ علیہ وسلمن ہٕنز پۅ پھتٕر بیٚنہِ ٲس ، تہٕ حضو رصلی اللہ علیہ وسلمن اوس تِہُند نکا ح حضر ت زید رضی اللہ تعالیٰ عنہ ہس سٍتۍ کوٚر مُت۔ مگر دۅ شوٕ نۍ ٲس نہٕ پانہٕ وٲنۍ برابری یِوان تہٕ حضرت زید رضی اللہ عنہ ٲسۍ تِمن طلا ق یژھان دِیُن ﴾تمہِ وقتہٕ  ٲسِو توٚہۍ سۅ کتھ دِلس منٛز چُھپٲوِتھ یۅسہٕ اللہ تعالیٰ اوس ظٲہر  کرٕ نۍ یژھان، توٚہۍ ٲسِو لُکن کھۅژان، حا لانکہ اللہ تعالیٰ چُھ اَمِیُک زیا دہ حقدار زِ توٚہۍ کھوٚژِ و تس ﴿ یعنی اللہ  تعالیٰ سٕنز مر ضی ٲس یہِ زِ ییٚلہِ حضر ت زید رضی اللہ عنہ حضر ت زینب رضی اللہ عنہا ہس طلا ق دِ ہن ، پتہٕ پھُٹرا وہن رسول اللہ صلی اللہ  علیہ وسلم خۅد تِمن سٍتۍ نکاح کٔرِ تھ عر بُک سُہ پرٛ و ن رسم، ییٚمہِ کِنۍ منگتہٕ نیٚچواصلی نیٚچواوس سمجھنہٕ یِوان ۔ مگر حضو ر صلی اللہ علیہ وسلم  ٲسۍ امہِ اندیشہِ کِنۍ اتھ آز مٲیشہِ منٛز ہیٚنہٕ یِنہٕ نِشہِ بچُن یژھان زِ اہلِ عر ب کر ن سخت نکتہٕ چینی۔اَمی مو جو ب چِھ حضور صلی اللہ علیہ وسلم کو شش فر ماوان زِ زید رضی اللہ عنہ گٔژھۍ نہٕ پننہِ خا ندارِ طلا ق دِنۍ۔  پتہٕ ییٚلہِ زید رضی اللہ عنہ چُھ تس نِشہِ پنُن حا جت پوٗرٕ کران ﴿ یعنی طلا ق دِنٕچ خو ٲہش یۅسہٕ تِمن ٲس سۅ کٔر تِمو پوٗرٕ، تہٕ پننہِ طلا ق دِنہٕ آمژِ خا ندارِ نہِ سٍتۍ روٗد نہٕ تِمن کانٛہہ رشتہٕ با قی﴾پتہٕ کوٚر اسہِ تس ﴿ طلا ق دِنہٕ آمژِ خا تونہِ ﴾ ہُند نکا ح تۅہیہِ سٍتۍ،تاکہ مو نن پٮ۪ٹھ روزِ نہٕ پننیٚن منگتہٕ نیچو ٮ۪ن ہٕنز ن خا ندارِ نیٚن ہٕندِس معا ملس منٛز کانٛہہ تنگی، ییٚلہِ زَ ن تِمو تِمن نِشہِ پنُن حا جت پوٗرٕ آسہِ کوٚر مُت۔ تہٕ اللہ تعالیٰ سٕندِس حُکمس اوس بہر  حال عملہِ منٛز یُن۔"
  33,38,"۔نبی صلی اللہ علیہ وسلمس پٮ۪ٹھ چَھنہٕ کُنہِ تِژِھہ کامہِ منٛز کانٛہہ رُکا وٹ یۅسہٕ خُدا ین تٔمۍ سٕندِ خٲطرٕ مُقرر آسہِ کٔرمٕژ۔یۅ ہے اللہ تعالیٰ سُند سُنّت چُھ تِمن سارِ نٕے انبیا ہن علیھم السلامن ہٕندِس معا ملس منٛز روٗد مُت یِم گۅڈٕ چِھ گُزر یمٕتۍ، تہٕ اللہ تعالیٰ سُند حُکم چُھ اکھ قطعی طے سپُدمُت فٲ صلہٕ آسان ۔﴿ یہِ چُھ اللہ تعالی سُند سنّت تِمن لُکن خٲطرٕ ﴾"
  33,39,"۔یِم اللہ تعالیٰ سٕندۍ پیغا مات وا تنا وان چِھ تہٕ تٔسۍ چِھ کھۅژان، تہٕ أکِس خُدا یس ورٲے چِھنہٕ کٲنٛسہِ کھۅژان، تہٕ محا سبہٕ خٲطرٕ چُھ بس اللہ تعالیٰ ہٕے کٲفی۔"
  33,40,"۔﴿لوٗکو ﴾ محمد صلی اللہ علیہ وسلم چِھنہٕ تُہند یٚو مردَو منٛزٕ کٲنٛسہِ ہٕندۍ مٲلۍ ، مگر یِم چِھ اللہ تعالیٰ سٕندۍ رسول صلی اللہ علیہ وسلم بیٚیہِ چِھ خا تم النبیّن ، تہٕ اللہ تعالیٰ چُھ پرٛتھ چیزُک علم تھا و ن وول۔ع۔ ﴿ یتھ أکِس کتھہِ منٛز چُھ تِمن تمام اعتراضن موٗل آمُت ژٹنہٕ یِم اعترا ض مخا لف ٲسۍ نبی صلی اللہ علیہ وسلمن ہٕندِس اتھ نکاحس پٮ۪ٹھ کرا ن ۔ تِہُند گۅٚنِیُک اعتراض اوس یہِ زِ تِمو صلی اللہ علیہ وسلم کوٚر پننہِ نۅ شہِ سٍتۍ نکا ح۔امہِ کِس جوا بس منٛز چُھ فر ما و نہٕ آمُت زِ  محمد صلی اللہ علیہ وسلم چِھنہٕ تُہند یٚو مردَو منٛزٕ کٲنٛسہِ ہٕندۍ مٲلۍ۔ یعنی ییٚلہِ سُہ نیچُو ے اوس نہٕ تیٚلہِ  کِتھہٕ پٲٹھۍ ہیٚکہِ ہے تٔمۍ سٕنزِ مطلّقہ ہس سٍتۍ نکا ح حرا م ٲسِتھ؟ دوٚ یُم اعترا ض اوس یہِ زِ اگر منگتہٕ نیچُو اصلی نیچُو چُھنہٕ ، تمہِ پتہٕ تہِ اوس نہٕ تٔمۍ سٕنزِ ترا و نہٕ آمٕژِ زَنہِ سٍتۍ نکا ح کرُن ضرور ی کینٛہہ۔ امہِ کِس جوا بس منٛز آو فر ما و نہٕ مگر تِم چِھ اللہ تعالیٰ سٕندۍ رسول  ، یعنی رسول آسنہٕ کہ حیثیت اوس تِمن پٮ۪ٹھ یہِ فر ض عٲید سپدان زِ یُس حلال چیز تُہٕند یٚو رسمو خوا ہ مخوا ہ حرا م چُھ کوٚر مُت، تمہِ کِس با رس منٛز کر ن تمام تعصبّا تن خٲتمہ ، تہٕ امہِ کِس حلال آسنہٕ کِس معا ملس منٛز گژھن نہٕ کُنہِ شکٕچ گُنجٲ یش پتھ کُن تھا وٕنۍ۔ پتہٕ آو مز ید تٲکیدٕ خٲطرٕ فر ما و نہٕ  تہٕ تِم صلی اللہ علیہ وسلم چِھ خا تم النبیّن، یعنی تِمن پتہٕ چُھنہٕ کانٛہہ رسولٕے یِنہٕ وول تہٕ کانٛہہ نبی ینٕچ چَھنہٕ کتھٕے زِ اگر قا نو ن تہٕ معا شرُک کانٛہہ اِصلا ح تِہندِس زمانس منٛز نا فذ کٔر نہٕ نِشہِ روزِ ، تیٚلہِ کرِ امہِ پتہٕ یِنہٕ وول نبی یہِ کسر پوٗرٕ ، لہٰذا اوس یہِ بیٚیہِ تہِ ضرور ی بنیو مُت زِ امہِ جا ہلیت کہ رسمُک خٲتِمہٕ کر ہَن تِم پا نے۔ امہِ پتہٕ آو مز ید زور دِتھ فر ما و نہٕ زِ  اللہ تعالیٰ چُھ پرٛتھ چیزُک علم تھا وان۔ یعنی خُدا یس چھےٚ پے زِ امہِ ساعتہٕ کیا زِ اوس محمد صلی اللہ علیہ وسلمن ہٕند ذریعہِ یہِ جا ہلیتُک رسم ختم کرُن ضروری ، تہٕ یہِ رسم ختم نہ کر نس منٛز کیا قبا حت ٲس۔﴾"
  33,41,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ، اللہ تعالیٰ  کٔرِ یوٗن کثر ت سان یاد،"
  33,42,"۔تہٕ صُبح و شا م روٗزِ و تٔمۍ سٕنٛز تسبیح کران۔"
  33,43,"۔ سُے چُھ یُس تۅہیہِ پٮ۪ٹھ رحمت چُھ فر ماوان تہٕ تٔمۍ سٕندۍ ملٲیِک چِھ تُہٕندِ خٲطرٕ رحمتُک دُعا کرا ن، تاکہ سُہ اَنیو تۅہیہِ اَنہِ گٹَو منٛزٕ گا شس کُن کٔڑِ تھ، سُہ چُھ مو نن پٮ۪ٹھ سٮ۪ٹھاہ مہر بان۔"
  33,44,"ییٚمہِ دۅ ہ تِم تَس سمکھن ، تِہُنٛد استقبال سپدِ سلامہِ سٍتۍ، تہٕ تِہندِ خٲطرٕ چُھ خدا ین بوٚڈ با عزت اجر تیا ر تھو و مُت"
  33,45,"اے نبی صلی اللہ علیہ وسلم ، اَسہِ چِھو توٚہۍ سوٗزِ مٕتۍ گواہ بنٲوِ تھ، بشارت دِنہٕ وٲلۍ تہٕ کھۅژناون وٲلۍ بنٲوِ تھ"
  33,46,"اللہ تعالیٰ سٕندِ اجا زتہٕ تَس کُن دعوت دِ نہٕ وٲلۍ بنٲوِ تھ ، تہٕ گا شدار ژو نگ بنٲوِ تھ"
  33,47,"بشا رت دِیِو تِمن لُکن یِمو ﴿ تۅہیہِ پٮ۪ٹھ ﴾ ایمان چُھ اوٚ نمُت زِ تِہندِ خٲطرٕ چُھ اللہ تعالیٰ سٕندِ طر فہٕ بوٚڈ فضل"
  33,48,"تہٕ ہر گز مَہ دٔبِو کُفا ر ن تہٕ منا فقن نِشہِ ، کانٛہہ پرواہ مَہ کٔرِ و تِہِندِ تکلیف واتنا ونُک ﴿ یعنی تِمن کتھن ہُنٛد یِمہٕ  یِم لُکھ اَتھ نِکا حس پٮ۪ٹھ کرا ن چِھ ﴾ تہٕ بھر وسہٕ کٔرِ و خدا یس پٮ۪ٹھ، اللہ تعالیٰ ہٕے چُھ اَتھ خٲطرٕ کٲفی زِ انسان پُشر اوِ پنٕنۍ معا ملات تس"
  33,49,"اے لوٗ کو یِمَو ایمان چُھو اوٚ نمُت، ییٚلہِ توٚہۍ مو من مستوٗراتن سٍتۍ نکا ح کٔرِو، تہٕ پتہٕ دِیِو تِمن اتھہٕ لا گنہٕ برونٛہہ طلا ق، تیٚلہِ چَھنہٕ تُہندِ طر فہٕ تِمن پٮ۪ٹھ کانٛہہ عِدّت لٲزِ م ییٚمہِ کہ پوٗرٕ سپد نُک توٚہۍ مُطا لبہٕ کٔرِ تھ ہیٚکِو۔ لہٰذا دِیِو تِمن کینٛہہ مال تہٕ کٔرِو یوٗکھ جا ن طر یقہٕ رخصت"
  33,50,"۔اے نبی صلی اللہ علیہ وسلم ، اسہِ کرِ حلال تُہٕندِ خٲطرٕ تُہنزٕ تمہٕ خا ندارِ نہِ یِہِندۍ مہر تۅہیہِ ادا چِھو کٔرِ مٕتۍ، ﴿ یہِ چُھ در اصل جواب تِمن لُکن ہٕندِ اعتراضُک یِم ونان ٲسۍ زِ محمد صلی اللہ علیہ وسلم چِھ دوٚ یِمیٚن لُکن خٲطرٕ بیک وقت ژور خا ندارِ نہِ تھا ونس ممنو ع قرار دِوان ، مگر پانہٕ کِتھہٕ پٲٹھۍ  کٔر تِمو  یہِ پونژِ م خا ندارِ نۍ ؟ وا ضح گژِھہ روزُن زِ تمہِ وقتہٕ آسہٕ حضور صلی اللہ علیہ وسلمن ہٕندِ گھرِ ژور  خا ندارِنہِ ٛحضرت عا یشہ رضی اللہ عنہا، حضر ت سودہ رضی اللہ عنہا، حضر ت حفصہ رضی اللہ عنہا تہٕ حضر ت اُمِّ سلمہ رضی اللہ عنہا گۅڈے مو جو د ﴾ بیٚیہِ تِمہٕ مستوٗراتہٕ یِمہٕ اللہ تعالیٰ سٕندِ طر فہٕ عطا کر نہٕ آمژ و لونڈِ یَو منٛزٕ تُہٕندِس مِلکِیتَس منٛز یِن ، بیٚیہِ تُہنزٕ تِمہٕ پِترِ تہٕ پۅ پھتٕر بیٚنہِ، تہٕ ما متٕرِ تہِ ما ستٕرِ بیٚنہِ یِمو تۅہیہِ سٍتۍ ہجر ت چھےٚ کٔر مٕژ، بیٚیہِ سۅ مو من خا تو ن ییٚمۍ پنُن پان نبی صلی اللہ علیہ وسلم سٕندِ خٲطرٕ  ہِبہٕ آسہِ کوٚر مُت،  اگر نبی صلی اللہ علیہ وسلم تس نکا حس منٛز رٹُن ییٚژِھہ۔ ﴿ یعنی یِمو پا نژو خا ندارِ نیو علا وٕہ آو مز ید یِمن قسمن ہٕنز ن مستوٗراتن تہِ پننِس زوجیتس منٛز اَننُک اجا زت حضور صلی اللہ علیہ وسلمس دِ نہٕ ، یِہِنٛز ذکر یَتھ آیتس منٛز چھےٚ ﴾ یہِ رعا یت چھےٚ صرف تُہٕندِ خٲطرٕ ، با قی مو نن خٲطرٕ چَھنہٕ اسہِ چُھ معلو م زِ عا م مو نن پٮ۪ٹھ کیا حدود چِھ اسہِ تِہنز ن خا ندارِ نیٚن تہٕ لونڈِ یَن ہٕندِس با رس منٛز عٲید کٔرِ مٕتۍ۔﴿ توٚہۍ چِھو اسہِ تِمو حدودو نِشہِ امہِ مو جو ب مستثنیٰ کٔرِ مٕتۍ ﴾ تا کہ تۅہیہِ پٮ۪ٹھ روزِ نہٕ کانٛہہ تنگی ۔ تہٕ اللہ تعالیٰ  چُھ مغفر ت کر ن وول تہٕ مہر بان ۔"
  33,51,"۔تۅہیہِ چُھو اختیا ر یِوان دِنہٕ زِ پننیٚو خا ندارِ نیو منٛزٕ یۅسہٕ ییٚژِھیوٗن سۅ تھٲوِ یوٗن پا نس نِشہِ الگ، یۅسہٕ ییژِھیوٗن سۅ تھٲوِ یوٗن پا نس سٍتۍ، تہٕ یۅ سہٕ ییٚژھیوٗن الگ تھا و نہٕ پتہٕ بُلٲوِ یوٗن سۅ پا نس نِشہِ ۔اتھ معا ملس منٛز چُھنہٕ تۅہیہِ پٮ۪ٹھ حر ج، یِتھہٕ پٲٹھۍ چُھ زیا دہ تو قع زِ تِہنزٕ أچھ روزن ٹھنڈٕ تہٕ تِمہٕ سپد ن نہٕ غمگین، تہٕ یِکینژھاہ تہِ توٚہۍ تِمن دِیِو تتھ پٮ۪ٹھ روزَ ن تِمہٕ سار ے رٲضۍ۔۔اللہ تعالیٰ چُھ زانان یِکینژھاہ تُہٕندٮ۪ن دِلن منٛز چُھ، تہٕ اللہ تعالیٰ چُھ زانن وول تہٕ بُردبار۔"
  33,52,"۔امہِ پتہٕ چَھنہٕ تُہندِ خٲطرٕ با قی مستوٗراتہٕ حلال، تہٕ نَہ چُھ امِیُک اجازت زِتِہنزِ جا یہِ أنیوٗکھ بیٚیہِ خا ندارِ نہِ، خواہ تِہُند حُسن تۅہیہِ کۅ تا ہ تہِ پسند آسیو، ﴿ ییٚمہِ ارشادٕ کۍ چِھ زٕ ہ مطلب ۔ اکھ یہِ زِ یِمہٕ مستوٗراتہٕ پٮ۪ٹھ کنہِ  آیت 50/ ہس منٛز حضور صلی اللہ علیہ وسلمن خٲطرٕ حلال چھےٚ کر نہٕ آمٕژ، تِمو ورٲے چَھنہٕ وۅ نۍ دوٚ یِم کانٛہہ خا تو ن تُہندِ   خٲطرٕ حلال۔دوٚ یُم یہِ زِ ییٚلہِ تُہنزٕ ازواجِ مطہرا ت امہِ کتھہِ خٲطرٕ رٲضۍ چھےٚ گٔمژٕ زِ تنگی تہٕ سختی منٛز دِ ن ،تِمہٕ تۅہیہِ ساتھ، تہٕ ٲخرت خٲطرٕ دِن دُنیا ہس لتھ ، تہٕ اتھ پٮ۪ٹھ تہِ چھےٚ خۅش زِ توٚہۍ یُس برتاو تہِ تِمن سٍتۍ  ییٚژِھو سُہ کٔرِو ، تیٚلہِ چُھنہٕ وۅ نۍ تُہندِ خٲطرٕ یہِ حلال زِ یِمومنٛزٕ  دِیو توٚہۍ کٲنٛسہِ طلا ق تہٕ پتہٕ أنیوٗن تٔمۍ سٕنزِ جا یہِ بیا کھ خا ندارِنۍ۔ ﴾ البتہ لو نڈ ین ہُند چُھو تۅہیہِ اجازت۔ ﴿ یہِ آیت چھےٚ امہِ کتھہِ ہٕنز وضا حت  کرا ن زِ منکو حہ خا ندا رِ نیو علا وٕہ چُھ مملو کہ مستوٗراتن سٍتۍ تہِ تمتّع ہُک اجا زت تہٕ تِہندِ خٲطرٕ چُھنہٕ تعدادُک کانٛہہ قٲد۔ اَمی مضمو نٕچ وضا حت چھےٚ سو رۂ نسا آیت 3، سورۂ مو منو ن آیت6، تہٕ سورۂ معا رج آیت 30 ہس منٛز تہِ کر نہٕ آمٕژ۔﴾ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ نگران۔ ع"
  33,53,"۔ اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، نبی صلی اللہ علیہ وسلمن ہٕند ٮ۪ن گھر ن منٛز مَہ ٲسِو اِجا زت ورٲے اَژان۔نہ مَہ روٗزِ و کھیٚن تیا ر گژھنس پراران۔آ، اگر توٚ ہۍ کھیٚنس پٮ۪ٹھ بُلا و نہٕ یِیِو، تیٚلہِ یِیِو ضرور ۔ مگر ییٚلہِ کھیٚن کھیٚیِو ، تیٚلہِ نیٖرِ و پتہٕ ،کتھہٕ کر نہِ مَہ روٗزِ و۔ تُہنزٕ یِمہٕ حر کتہٕ چھےٚ نبی صلی اللہ علیہ وسلمس تکلیف دِوان، مگر تِم چِھنہٕ شر مہِ ہِندِ و جہ کِنۍ کِہِنۍ وَنان تہٕ اللہ تعالیٰ چُھنہٕ پٔز کتھ وَننس منٛز مند چھا ن۔نبی صلی اللہ علیہ وسلمن ہٕنز ن خا نادرِ نیٚن اگر تۅہیہِ کینٛہہ منگُن آسیو، تیٚلہِ ٲسِو پردٕہ پٔتۍ کِنۍ منگا ن، یہِ چُھ تُہند ٮ۪ن تہٕ تِہندٮ۪ن دِلن ہٕنزِ پا کیز گی خٲطرٕ زیا دہ مُنا سِب طر یقہ۔ تُہندِ خٲطرٕ چُھنہٕ یہِ ہر گز جٲیز زِ اللہ تعالیٰ سٕندِ س رسول صلی اللہ علیہ وسلمس دِیِو تکلیف، تہٕ نہ چُھ یہِ جٲیز زِ تِہندِ پتہٕ کٔرِ و تِہنز ن خا ندارِ نیٚن سٍتۍ نکا ح،یہِ چُھ خدا یس نز دیک سٮ۪ٹھاہ بوڈ گنا ہ ۔"
  33,54,"۔توٚہۍ کٔرۍ تو خوا ہ کانٛہہ کتھ ظٲہر یا چُھپٲوِ تَو، خُدا یس چُھ پرٛتھ کتھہِ ہُند علم ۔"
  33,55,"۔ نبی صلی اللہ علیہ وسلمن ہٕنز ن ازوا جن خٲطرٕ چُھنہٕ اتھ منٛز کانٛہہ حر ج زِ تِہِندۍ مٲلۍ، تِہِندۍ نیچِو ۍ، تِہندۍ بٲے ،تِہندۍ با پتھٕر، تِہِندۍ بیٚنتھٕر، تِہنزٕ تِمہٕ مستوٗراتہٕ یِمن سٍتۍ وۅ تھُن  بِہُن آسیٚکھ، تہٕ تِہندۍ مملو ک یِن گھر ن منٛز ۔ ﴿ اے مستوٗراتو ﴾ تۅہیہِ پز یو اللہ تعالیٰ سٕنزِ نا فر مٲنی نِشہِ پر ہیز کرُن۔ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ نظر تھا وان ۔"
  33,56,"۔ اللہ تعالیٰ تہٕ تٔمۍ سٕندۍ ملا یکہ چِھ نبی صلی اللہ علیہ وسلمس پٮ۪ٹھ دروٗدٕ سوزان، اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، توٚہۍ تہِ سوٗزِ و تِمن پٮ۪ٹھ دروٗدٕ۔ ﴿ اللہ تعالیٰ سٕندِ طر فہٕ چُھ پننِس نبی صلی اللہ علیہ وسلمس پٮ۪ٹھ صلوا تُک مطلب یہِ زِ سُہ چُھ تِمن صلی اللہ علیہ وسلمن پٮ۪ٹھ بے حد مہر بان ، تِہِندۍ صلی اللہ علیہ وسلمن تعر یف چُھ کران، تِہنز ن صلی اللہ علیہ وسلم کامیٚن منٛز چُھ بر کت دِوان، تِہُنٛدناو چُھ بُلند کران تہٕ تِمن صلی اللہ علیہ وسلمن پٮ۪ٹھ چُھ پننیٚن رحمتن ہٕنز بٲرش فر ماوان۔ ملٲیکن ہٕندِ طر فہٕ تِمن پٮ۪ٹھ صلوا تُک مطلب چُھ یہِ تِم چِھ  تِمن صلی اللہ علیہ وسلمن سٍتۍ انتہٲیی در جُک محبت تھا وان تہٕ تِہندِس حقس منٛز چِھ خُدا یس دُعا منگا ن زِ سُہ کٔرِ ن تِمن صلی اللہ علیہ وسلمن زیا دہ کھۅتہٕ زیادہ بُلند مر تبہ عطا ۔ اہلِ ایمانن ہٕندِ طر فہٕ تِمن صلی اللہ علیہ وسلمن پٮ۪ٹھ  صلوا تُک مطلب چُھ یہِ زِ تِم تہِ کٔرِن تِہِندِس حقس منٛز خُدا یس دُعا زِ سُہ کٔرِ ن تِمن  صلی اللہ علیہ وسلمن پٮ۪ٹھ پننہِ رحمتہٕ نٲزِل ۔﴾"
  33,57,"۔ یِم لُکھ خُدا یس تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلمس تکلیف چِھ دِوان، تِمن پٮ۪ٹھ چھےٚ خُدا ین دنیا ہس تہٕ ٲخرتس منٛز لعنت فر مٲومٕژ، تہٕ تِہندِ خٲطرٕ چُھن رُسوا کر ن وول عذا ب تیا ر تھو و مُت۔"
  33,58,"۔تہٕ یِم لُکھ مو من مردن تہٕ مو من مستوٗراتن بے قصور تکلیف چِھ دِوان ، تِمو چُھ اکہِ بڈِ بہتا نُک تہٕ ٹا کارٕ ہ گنا ہُک وبا ل پننِس کلس کھو لمُت۔ ع"
  33,59,"۔اے نبی صلی اللہ علیہ وسلم، پننیٚن خا ندارِ نیٚن تہٕ کورٮ۪ن تہٕ اہلِ ایمانن ہٕنز ن مستوٗراتن ؤنِو زِ ، پننِس پا نس پٮ۪ٹھ ٲسِن پننیٚن ژادرن ہِنزٕ لونچہِ  تھا وان۔ ﴿ یعنی ژادر ؤلِتھ ٲسِن پا نس مۅ ہر تھا وان ، با لفا ظ دیگر بُتھ یلہٕ تھٲوِ تھ مَہ ٲسِن  پکا ن﴾ یہِ چُھ زیا دہ مُنا سب طر یقہٕ تاکہ تِم یِن پرٛزنا و نہٕ، تہٕ ستا و نہٕ یِن نہٕ۔ ﴿ یِن پرٛزنا و نہٕ  نِشہِ چُھ مُراد یہِ زِ  اَتھ سا دہ تہٕ حیا دار لبا سس منٛز تِمن وُچِھتھ زانہِ پرٛتھ کانٛہہ وُچھن وول زِ تِمہٕ چھےٚ شر یف تہٕ با عصمت مستوٗراتہٕ ، آوا رٕہ تہٕ بد کار چَھنہٕ زِ کانٛہہ بد کردار انسان ہیٚکہِ تِمن نِشہِ پننہِ دِلُک تمنا پوٗرٕ کر نٕچ اُمید کٔرِ تھ۔ ستا و نہٕ یِن نہٕ  نِشہِ چُھ مُراد یہِ زِ تِمن گژِھہ نہٕ کانٛہہ ہیٚکُن اتھہٕ لٲگِتھ ، تِمن برونٛہہ کُن گژِھہ نہٕ کانٛہہ ہیٚکُن یِتھ ﴾ اللہ تعالیٰ چُھ مغفر ت کر ن وول تہٕ مہر بان ۔"
  33,60,"۔اگر پننیو حر کتو نِشہِ با ز آے نہٕ منا فقین، تہٕ تِم لُکھ یِہند ٮ۪ن دِلن منٛز خرٲبی چھےٚ، بیٚیہِ تِم یِم مد ینس منٛز اَپزِ افوا ہ پھہلاون وٲلۍ چِھ ، تیٚلہِ کر و أسۍ تِمن خلا ف کا ر وٲیی کر نہٕ خٲطرٕ توٚہۍ کھڑا ، پتہٕ ہیٚکن تِم یتھ شہر س منٛز تۅہیہِ سٍتۍ مُشکلنٕے روٗزِ تھ۔"
  33,61,"۔ تِمن پٮ۪ٹھ سپدِ پرٛتھ طر یفہٕ لعنتُک پھٹکار۔ ییٚتہِ تہِ وُچِھنہٕ یِن تَتہِ یِن رَٹنہٕ، تہٕ بُرٕ پٲٹھۍ یِن مار نہٕ ۔"
  33,62,"۔ یہِ چُھ اللہ تعالیٰ سُند سُنّت یُس یِتھیٚن لُکن ہٕندِس معا ملس منٛز گۅڈٕ پٮ۪ٹھے چُھ پکا ن یِوان ، تہٕ توٚہۍ وُچِھو نہٕ اللہ تعالیٰ سٕندِس سُنّتس منٛز کانٛہہ تبد یلی۔"
  33,63,"۔لُکھ چِھو تۅہیہِ پرٕ ژھان زِ قیا متٕچ گٔر کر یِیہِ ؟ ؤنِو ، تمِیُک علم چُھ اللہ تعالیٰ سٕے ۔ تۅہیہِ کیا خبر چَھو ، بنان چُھ زِ سۅ ﴿ گٔر ﴾ آسہِ نکھے۔"
  33,64,"۔بہر حال چُھ یہِ پوٚز زِ خُدا ین چھےٚ کٲفر ن پٮ۪ٹھ لعنت کٔر مٕژ، تہٕ تِہندِ خٲطرٕ چُھن شعلہٕ وُن نار تیا ر تھو و مُت،"
  33,65,"۔ یتھ منٛز تِم ہمیشہ روزن ، کانٛہہ حٲمی تہٕ مددگار لبن نہٕ۔"
  33,66,"۔ییٚمہِ دۅہ تِہِند ٮ۪ن بُتھیٚن نارس پٮ۪ٹھ یِیہِ تِلُک پٮ۪ٹھ کر نہٕ ، تمہِ وقتہٕ ونن تِم زِ  کا ش آسِہے اسہِ اللہ تعالیٰ سٕنز تہٕ رسول صلی اللہ علیہ وسلم سٕنز اطا عت کٔرمٕژ۔"
  33,67,"۔بیٚیہِ ونن  اے سا نہِ ربّہ ، اسہِ کٔر پننیٚن سردارن تہٕ پننیٚن زٕ ٹھیٚن ہٕنز اطا عت، تہٕ تِمو کٔرۍ أسۍ راہِ راست نِشہِ بے راہ۔"
  33,68,"۔ اے ربّ ،یِمن دِ دۅ گنہٕ عذا ب، تہٕ یِمن پٮ۪ٹھ کر سخت لعنت۔ ع"
  33,69,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، تِمن لُکن ہٕندۍ پٲٹھۍ مَہ بٔنِو ، یِمو مو سیٰ علیہ السلامس  تکلیف ٲسۍ دِ تِمٕتۍ، پتہٕ کوٚر خُدا ین تِہنز و بنا و نہٕ آمژ و کتھو نِشہِ سُہ بٔری، تہٕ سُہ اوس خُدا یس نز دیک با عزت۔"
  33,70,"۔ اے ایمان انَن والیو، خُدا یس کھوٚژِ و ، تہٕ سیٚود کتھ ٲسِو  ونان ۔"
  33,71,"۔اللہ تعالیٰ کرِ تُہٕندۍ اعما ل دُرست، تہٕ تُہٕندٮ۪ن قصُورن کرِ در گز ر ۔ یُس شخص اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم اطا عت کرِ ، تٔمۍ کٔر بٔڑ کا میٲبی حٲصل ۔"
  33,72,"۔اسہِ کوٚر یہِ امانت آسما نن تہٕ زمینس تہٕ پہا ڑن برونٛہہ کنہِ پیش ، تِم سپٕدۍ نہٕ یہِ تُلنہٕ خٲطرٕ تیا ر تہٕ کھوٚژۍ اَتھ ﴿ امانت نِشہِ چُھ مُراد تِمن ذمہٕ دٲرِ یَن ہُند با ر یُس خُدا ین پننِس زمینس منٛز اختیارات تہٕ عقل دِ تھ انسانس پٮ۪ٹھ تر و و مُت چُھ﴾، مگر انسانن تُل یہِ ، بے شک چُھ سُہ بوٚڈ ظٲلِم تہٕ جٲہِل ﴿ یعنی امہِ بارِ امانتُک حٲمِل ٲسِتھ تہِ چُھنہٕ پننہِ ذمہٕ دٲر ی محسو س کرا ن تہٕ خیا نت کٔرِ تھ چُھ پانہٕ پا نس پٮ۪ٹھ ظُلم کران۔﴾"
  33,73,"۔﴿ یہِ بارِ امانت تُلنُک لٲزمی نتیجہ چُھ یہِ ﴾ تا کہ اللہ تعالیٰ دِیہِ منا فق مردن تہٕ زنانن ، تہٕ مُشر ک مردن تہٕ زنانن سزا، تہٕ مو من مستوٗراتن ہُند تو بہٕ کرِ قبو ل، اللہ تعالیٰ چُھ در گز ر فر ماون وول تہٕ رحیم ۔ ع"
