quran[29]{c,v,t}:
  48,1,"۔اے نبی صلی اللہ علیہ وسلم،اسہِ کٔرٕو تۅہیہِ ٹا کارٕہ فتح عطا ، ﴿صلح حُدیبیہ پتہٕ ییٚلہِ فتح ہٕچ یہِ خۅش خبر بوز نا و نہٕ آیہِ، لُکھ ٲسۍ حٲران زِ یتھ صلحس کِتھہٕ پٲٹھۍ یِیہِ ٲخر فتح وَننہٕ یتھ منٛز بظٲہر اَسہِ تِم تمام شرٲیط مٲنۍ یِم کُفار ٲسۍ اسہِ نِشہِ مَنوٕ نۍ یژھان ۔ مگر کینٛہہ کالہٕ پتے چُھ پے لگان زِ یہِ صلح اوس در حقیقت اکھ بٔڈ فتح ۔﴾"
  48,2,"۔تاکہِ اللہ تعالیٰ کرِ تُہنزِ پٔتمہِ بروٚنہِمہِ پرٛتھ کوٗتٲہی نِشہِ در گُز ر۔﴿یتھ مو قع محلس پٮ۪ٹھ یہِ کتھ ارشاد چھےٚ سپٕژ مٕژ، اگر یہِ در نظرتھا وون تیٚلہِ چُھ صا ف باسان زِ یتھ جا یہِ یِمَو کوتٲہِیَو نِشہِ در گُز ر کر نٕچ ذکر چھےٚ تِمو نِشہِ چُھ مُراد تِمہٕ خٲمیہِ اسلام چہِ کا میٲبی تہٕ سر بُلند ی خٲطرٕ کٲم کران کران تتھ جدو جہد س منٛز روز مژٕ آسہٕ یۅسہٕ جدو جہد رسول اللہ صلی اللہ علیہ وسلمن ہٕندِس قیا دتس منٛز مُسلمان ٲسۍ پٔتِمیٚو کُنوُ ہَو ﴿19﴾ ؤرِ یَو پٮ۪ٹھہٕ کران روٗدِ مٕتۍ۔یِمہٕ خٲمیہِ چَھنہٕ کٲنٛسہِ  انسانس پے،بلکہ چھےٚ انسٲنی عقل امہِ جدوجہدٕ منٛزٕ کانٛہہ نقص ژھا نڈ نہٕ نِشہِ قطی عٲجز۔مگر اللہ تعالیٰ سٕنز ن نظر ن منٛز یُس کما لُک بُلند تر ین معیار چُھ، تمہِ لحا ظہٕ آسہٕ اتھ منٛز کینٛہہ تِژٕھہ خٲمیہِ یِہندِ وجہ کِنۍ مُسلمانن ہیٚکہِ ہے نہٕ یوٗتاہ جلد ی عرب کیٚن مُشر کن پٮ۪ٹھ فٲصلہٕ کُن فتح حٲصل سپدِ تھ ۔اللہ تعالیٰ سٕندِ ارشادُک مطلب چُھ یہِ زِ یِمو خٲمیو سان اگر توٚہۍ جدوجہد روٗزِ ہِو کران تیٚلہِ اوس عر ب مُسخر سپد نس منٛز وُنہِ واریا ہ کال در کار، مگر اسہِ کٔر یِمن سارِ نٕے کمزوٗرِین تہٕ کوتٲہِیَن نِشہِ در گُزر کٔرِتھ محض پننہِ فضلہٕ سٍتۍ یِہنز تلٲفی تہٕ حد یبیہ چہِ جایہِ مٕژ روو تُہندِ خٲطرٕامہِ فتحُک تہٕ کا میٲ بی ہُند دروازٕہ یۅسہٕ معمو ل مطٲبق تۅہیہِ پننیو  کوٗششو سٍتۍ نصیب ہیٚکہِ ہے نہٕ سپدِتھ۔﴾تہٕ تۅہیہِ پٮ۪ٹھ کرِ پننہِ نعمتُک تکمیل، تہٕ تۅہیہِ ہا و یٚو سیٚز وَتھ۔﴿یتھ جایہِ چُھ رسول اللہ صلی اللہ علیہ وسلمن سیٚز وَتھ ہا ونُک مطلب تِمن فتح تہٕ کا مرٲنی ہٕنز وَتھ ہا وٕنۍ۔﴾"
  48,3,"۔تہٕ تۅہیہِ کرَ یٚو زبردست نُصرت عطا ۔"
  48,4,"۔سُے چُھ ییٚمۍمو منن ہٕند ٮ۪ن دِلن منٛز سکینت کٔر نٲزِل ۔﴿سکینت نِشہِ چُھ مُراد سکو ن تہٕ دِلُک اطمینان۔ مطلب چُھ یہِ زِ صلح حد یبیہ کِس موقعس پٮ۪ٹھ یِم تہِ اشتعال انگیز حالات پیش آے تِمن سارِنٕے پٮ۪ٹھ مُسلمانن ہُند صبر کرُن تہٕ رسول اللہ صلی اللہ علیہ وسلمن ہٕندِس قیا دتس پٮ۪ٹھ مکمل اعتماد کران کران تِمو منٛزٕ بخیر یت نیرُن اوس اللہ تعالیٰ سٕندِ فضلُک نتیجہِ ، نتہٕ ہیٚکہِ ہے اَمہِ وقتہٕ اکھ غلطی پیوٗنت سٲرٕ ے کام خراب کٔرِتھ۔﴾ تاکہ پننِس ایمانس سٍتۍ ہیٚکن تِم بیٚیہِ اکھ ایمان بڑھٲوِتھ، زمین تہٕ آسمانن ہٕندۍ سٲری لشکر چِھ اللہ تعالیٰ سٕندِس قدرت کِس قبضس منٛز، تہٕ سُہ چُھ زانن وول تہٕ حکمت وول۔ ﴿تٔمۍ کٔر یہِ کٲم امہِ موجوٗب﴾"
  48,5,"۔تاکہ مو من مردَن تہٕ مو من مستوٗراتن کرِ ہمیشہِ خٲطرٕ تِتھیٚن جنّتن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅلہٕ آسن پکان،تہٕ تِہنزٕ بُرٲیِیہِ کرِ تِمن نِشہِ دوٗر۔"
  48,6,"تہٕ تِمن مُنا فق مردَن تہٕ زنانن تہٕ مشر ک مَردن تہٕ زنانن دِیہِ سزا، یِمن خُدایس متعلق بُرٕ گُمان ٲسۍ۔بُرٲیی ہٕندِس پھیرس منٛز آے تِم پانے، اللہ تعالیٰ سُند غضب سپُد تِمن پٮ۪ٹھ تہٕ تٔمۍ کٔر تِمن پٮ۪ٹھ لعنت،تہٕ تِہندِ خٲطرٕ کوٚرُن جہنم تیار یُس سٮ۪ٹھہٕے خراب ٹھکا نہٕ چُھ"
  48,7,"۔زمین تہٕ آسما نن ہٕندۍ لشکر چِھ اللہ تعالیٰ سٕندِسٕے قدرت کِس قبضس منٛز، تہٕ سُہ چُھ زبردست تہٕ حکمت وول۔"
  48,8,"۔اے نبی صلی اللہ علیہ وسلم،اسہِ چِھو توٚہۍ شہا دت دِنہٕ وٲلۍ، بشارت دِنہٕ وٲلۍتہٕ خبردار کرن وٲلۍ بنٲوِتھ سوٗزِ مٕتۍ،﴿ شاہ ولی اللہ صٲبن چُھ شٲہد لفظُک تر جمہٕاظہار حق کُنندہ کوٚر مُت ۔ یعنی حقٕچ شہا دت دِنہٕ وول۔﴾"
  48,9,"۔تاکہ اے لوٗکو ،توٚہۍ أنِو خُدایس تہٕ تٔمۍ سٕندِس رسولس پٮ۪ٹھ ایمان، تہٕ تَس ﴿یعنی رسولس ﴾ دِیو ساتھ،تٔمۍ سُند تعظیم و تو قیر کٔرِو،تہٕ صبح و شام روٗز و خُدا ے سٕنز تسبیح کران۔"
  48,10,"۔اے نبی صلی اللہ علیہ وسلم ، یِم لُکھ تۅہیہِ سٍتۍ بیعت کران ٲسۍ۔﴿ اشارہ چُھ تتھ بیعتس کُن یۅسہِ صحا بہ کرا من رضی اللہ عنہم  مکہ معظمس منٛز حضر ت عثما ن رضی اللہ عنہ سٕنز شہا دتٕچ خبر بوٗزِ تھ رسول اللہ صلی اللہ وسلمو حُد یبیہ نٲوۍ جا یہِ ہیژ مٕژ ٲس ۔ یہِ بیعت ٲس اَتھ کتھہِ ہیٚنہٕ آمٕژ زِ اگر حضر ت عثما ن رضی اللہ عنہ سٕندِ شہا دتٕچ خبر صحیح ٲس،تیٚلہِ کرن مُسلمان أتھۍ جایہِ تِمن سٍتۍ جنگ خوا ہ امہِ کِس نتیجہ ہَس منٛز کونہٕ پیٚیہِ سارِ نٕے مَرُن۔﴾ تِم ٲسۍ در اصل خُدایس سٍتۍ بیعت کران۔ تِہندِس اتھس پٮ۪ٹھ اوس اللہ تعالیٰ سُند اَتھہٕ ۔ ﴿ یعنی یتھ اَتھَس پٮ۪ٹھ لُکھ تَمہِ ساعتہٕ بیعت کران ٲسۍ، سُہ اوس نہٕ شخصِ رسول سُند اَتھہٕ بلکہ اوس اللہ تعالیٰ سٕندِس نما یندٕہ سُند اتھہٕ ، تہٕ یہِ بیعت ٲس رسول صلی اللہ علیہ وسلمن ہٕندِ واسطہٕ در حقیقت خُدایس سٍتۍ سپدان۔﴾ وۅ نۍ یُس یہِ عہد پُھٹر اوِ ، تٔمۍ سٕنزِ عہد شکنی ہُند وَبال آسہِ تس پننہِ سٕے ذاتس پیٹھ  تہٕ یُس اَتھ عہدس وفا کرِ یُس تٔمۍ خدایس سٍتۍ کوٚر مُت چُھ، اللہ تعالیٰ کرِ عنقر یب تس سٮ۪ٹھاہ اجر عطا ۔ع"
  48,11,"۔اے نبی صلی اللہ علیہ وسلم،اعرا بِیَو ﴿دِ یہٲتی لُکو ﴾ منٛزٕ یِم لُکھ پتھ ٲسۍ تراو نہٕ آمٕتۍ۔﴿یہِ چھےٚ تِمن لُکن ہٕنز ذکر  یِم مد ینس أندۍ پٔکۍ روزان ٲسۍ،تِمن ٲس عمرٕ چ تیاری شروع کر نہٕ وقتہٕ رسول اللہ صلی اللہ علیہ وسلمو پا نس سٍتۍ ینٕچ دعوت دِژ مٕژ،مگر تِم ٲسۍ نہٕ ایمانُک دعویٰ کر نہٕ باو جود صرف امہِ موجوٗب پننیو گھرو منٛزٕ درٛ امٕتۍ،تِکیازِ تِمن اوس پنُن زُوٹو تھ۔تِم ٲسۍ سمجھان زِ اتھ مو قعس  پٮ۪ٹھ قر یشن ہٕندِس گھرس منٛز أژِتھ عمرہ کرُن گوٚو موت کِس ٲسس منٛز اَژُن۔﴾ وو نۍ یِن یِم تۅہیہِ نِش تہٕ وَنن ضرور زِ ، أسۍ ٲسۍ پننیو مالَو تہٕ شُر یو بٲژَو ہٕنزِ فکرِ تھٲوِمٕتۍ آوٕرۍ کٔرِتھ،توٚہۍ کٔرِ و سانہِ خٲطرٕ مغفر تُک دُعا۔ یِم لُکھ چِھ پننیو زبا نَو تِمہٕ کتھہٕ ونان یِمہٕ یِہندٮ۪ن دِلن منٛز آسان چَھنہٕ۔ یِمن ؤنۍ زیٚو اچھا ،اگر یٔہے کتھ چھےٚ تیٚلہِ کمِس چُھ تُہندِس معا ملس منٛز اللہ تعالیٰ سُند فٲصلہٕ رُکا ونُک کانٛہہ تہِ اختیار، ہرگاہ سُہ تۅہیہِ نقصا ن ییٚژِھہ واتنا وُن یا نفح ییژِھہ بخشُن؟ تُہٕند یٚو اعما لو نِشہِ چُھ اللہ تعالیٰ ہٕے با خبر۔"
  48,12,"۔﴿مگر اصلی کتھ چَھنہٕ سۅ یۅسہٕ توٚہۍ ونا ن چِھو﴾ بلکہ زونَو تۅہیہِ یہِ زِ رسول صلی اللہ علیہ وسلم تہٕ مو منین ہیٚکن نہٕ ہر گز تہِ پننیٚن گھر ن منٛز واپس پھیٖرِتھ یِتھ،تہٕ یہِ خیال با سیاو تُہٕندٮ۪ن دِلن سٮ۪ٹھاہ جان، تہٕ تۅہیہِ کٔرِ و سٮ۪ٹھاہ بُرٕ گُمان، تہٕ توٚہۍ چِھو سخت بد بٲطن لُکھ۔"
  48,13,"۔یِمن لُکن خُدایس تہٕ تٔمۍ سٕندِ س رسول صلی اللہ علیہ وسلمس پٮ۪ٹھ ایمان آسہِ نہٕ ، تِتھیٚن کٲفر ن خٲطرٕ چُھ اسہِ شعلہٕ وُن نا ر تیا ر تھو و مُت۔"
  48,14,"۔ آسمانن تہٕ زمین چہِ با دشٲہی ہُند مٲلِک چُھ بس اللہ تعالیٰ ، یس ییژِھہ تس کرِ معا ف تہٕ یس ییژِھہ تس دِیہِ سزا،تہٕ سُہ چُھ بخشن وول تہٕ مہر بان۔"
  48,15,"۔ییٚلہِ توٚہۍ مالِ غنیمت حٲصل کر نہٕ خٲطرٕ گژُھن ہیٚیِو ، یِم پتھ کُن تراونہٕ آمٕتۍ لُکھ وَننَو تۅہیہِ ضروٗر زِ اسہِ تہِ دِیِو پا نس سٍتۍ پکنہٕ ۔ ﴿یعنی عنقر یب چُھ سُہ وقت واتن وول ییٚلہِ یِمے لُکھ یِمن اَز خطرٕ چہِ مُہِمہِ پٮ۪ٹھ تۅہیہِ سٍتۍ نیرنس وۅ ندٕ اوس نہٕ آمُت ، وُچھنَو تۅہیہِ أکِس تِژِھہ مُہمہِ پٮ۪ٹھ نیران یتھ منٛز یِمن سہل فتح تہٕ واریاہ مالِ غنیمت کہ حٲصل سپدنُک اِمکان باسہِ، تمہِ وقتہٕ یِن یِم پا نے دَوان دَوان تہٕ وَنن اَسہِ تہِ نِیِو پا نس سٍتۍ۔ ﴾ یِم چِھ یژھان زِ اللہ تعالیٰ سُند فر مان بدلا و ہن، یِمن ؤنۍ زیو صا ف زِ  توٚہۍ ہیکِو نہٕ ہر گز اسہِ سٍتۍ یِتھ، خُداین چُھ گۅڈے یہِ فر مو و مُت۔ یِم وَنن زِ  نَہ ، بلکہ چِھو توٚہۍ لُکھ اسہِ سٍتۍ حسد کران۔ ﴿حالانکہ کتھ چَھنہٕ حسدٕچ﴾ بلکہ چِھ یِم لُکھ صحیح کتھ کٕمے پہن سمجھان۔"
  48,16,"۔یِمن پتھ کُن تراو نہٕ آمتیٚن اعرٲبیٚن ﴿دیہا تیٚن ﴾ ؤنۍ زیوزِ ، عن قر یب یِیِو توٚہۍ تِتھیٚن لُکن سٍتۍ لڑ نہٕ خٲطرٕ بُلا و نہٕ یِم سٮ۪ٹھاہ زور آور چِھ۔تۅہیہِ آسیو تِمن سٍتۍ جنگ کرُن نَتہٕ سپدن تِم مُطیع ﴿یعنی آن مان ﴾، تمہِ وقتہٕ اگر تۅہیہِ جہا د کہ حُکمٕچ اطا عت کٔرٕو  ،تیٚلہِ دِیَو اللہ تعالیٰ تۅہیہِ رُت اجر،تہٕ اگر توٚہۍ بیٚیہِ تِتھے پٲٹھۍ پوٚت پھیرِ ویتھہٕ پٲٹھۍ گۅڈٕ ہ ٲسِو پوٚت پھیرِمٕتۍ، تیٚلہِ دِ یو اللہ تعالیٰ تۅہیہِ درد ناک سزا۔"
  48,17,"۔ہرگاہ اوٚن تہٕ لوٚ نگ تہٕ مریض جہا دس یِیہِ نہٕ ، تیٚلہِ چُھنہٕ کانٛہہ حر ج۔ یُس کانٛہہ اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز اطا عت کرِ،اللہ تعالیٰ کرِ تس تِمن جنّتن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان، تہٕ یُس پوٚت پھیرِ ،تس دِیہِ سُہ درد ناک عذا ب ۔ ع"
  48,18,"۔اللہ تعالیٰ سپُد مو منن خۅش، ییٚلہِ تِم کُلِس تلہٕ کنہِ تۅہیہِ سٍتۍ بیعت کران ٲسۍتِہِندٮ۪ن دِلن ہُند حال اوس تس معلو م ،امہِ موجوٗب کٔر تٔمی تِمن پٮ۪ٹھ سکینت نٲزِل ، ﴿یتھ جایہِ چُھ سکینت مُراد دِلٕچ سۅ کیفیت ییٚمہِ کِس بِنا ہس پٮ۪ٹھ اکھ شخص کُنہِ عظیم مقصدٕ خٲطرٕ ٹھنڈٕ دِلہٕ سان پوٗرٕ سکو ن و اطمینانہٕ سان پنُن پان خطرٕ ہ کِس ٲسس منٛز چُھ چھکان، تہٕ کُنہِ خو فہٕ یا گھبرا ہٹہٕ ورٲے چُھ فٲصلہٕ کران زِ یہِ کٲم چھےٚ بہر حال کرٕ نۍ خوا ہ نتیجہ ٲسِتن کینٛہہ تہِ ۔ ﴾ تِمن کٔرٕ ن بطور انعام قر یبی فتح عطا،"
  48,19,"۔تہٕ واریاہ مالِ غنیمت کوٚرُن تِمن عطا یتھ تِم ﴿ عنقر یب﴾ کرن حٲصل ۔﴿یہِ اشارہ چُھ فتح خبیر تہٕ تمہِ کِس مالِ غنیمتس کُن﴾اللہ تعالیٰ چُھ غٲلب تہٕ حکمت وول۔"
  48,20,"۔اللہ تعالیٰ چُھ تۅہیہِ سٍتۍ بکثرت اموالِ غنیمتُک وعدہ کران یِم توٚہۍ حٲصل کرِو۔﴿امہِ نِشہِ چُھ مُراد تِم با قی فتوحات یِم خیبر پتہٕ مُسلمانن مُسلسل حٲصل سپدان روٗدۍ﴾ فوری طور کٔر نو تٔمۍ تۅہیہِ یہِ فتح عطا ﴿امہِ نِشہِ چُھ مُراد صلح حدیبیہ یتھ سُورٕ کِس آغا زس منٛز فتح مُبین چُھ وَننہٕ آمُت﴾ تہٕ لُکن ہٕندۍ اتھہٕ آے تۅہیہِ خلا ف وۅ تھنہٕ نِشہِ رُکا ونہٕ ﴿ یعنی تٔمۍ دِژ نہٕ کُفارِ قر یشن یہِ ہمت زِ حد یبیہ کِس مقا مس پٮ۪ٹھ کیا کرہن تِم تۅہیہِ سٍتۍ لڑٲے ، حالانکہ تمام ظٲہری حالاتو لحا ظہٕ ٲسۍ تِم واریاہ زیا دہ  بہتر پوزیشنس منٛز تہٕ جنگی نقطہ نظر کِنۍ اوس تُہُند پوتُر تِہندِس مقا بلس منٛز واریاہ کمزور اَتھہٕ یِوان۔﴾ تاکہِ یہِ بنہِ مو منن خٲطرٕ اکھ نِشٲنی، تہٕ اللہ تعالیٰ بخشیو تۅہیہِ سیٚزِ وَتہِ کُن ہدا یت۔"
  48,21,"۔اَمہِ علا وہ چُھ سُہ تۅہیہِ سٍتۍ دوٚ یمیٚن غنیمتن ہُند تہِ وعدہ کران یِمن پٮ۪ٹھ وُنہِ تۅہیہِ دسترس چَھو نہٕ حٲصل گٔمٕژ،تہٕ خُداین چِھ تِم گھیرس منٛز رٔٹِمٕتۍ، ﴿اغلب چُھ یہِ زِ یہِ اشارہ چُھ فتح مکس کُن۔یعنی وُنہِ چُھنہٕ مکّہ تُہندِس قا بووَس منٛز آمُت مگر خُداین چُھ سُہ گھیرس منٛز رٔٹِتھ تھو و مُت،تہٕ حدیبیہ کہ ییٚمہِ فتح کِس نتیجس منٛز یِیہِ سُتہِ تُہندِس قبضس منٛز۔﴾ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھا وان۔"
  48,22,"۔یِمو کٲفر لُکو اگر تمہِ وقتہٕ تۅہیہِ سٍتۍ لوٚڈمُت آسِہے، تیٚلہِ آسہن یِمَو پٔزِ پٲٹھۍ شا نہٕ پھِر ۍ مٕتۍ۔ تہٕ کانٛہہ حٲمی تہٕ مدد گار  لبہن نہٕ ۔"
  48,23,"۔یہِ چھُ اللہ تعالیٰ سُنٛد یُس پتہٕ  پٮ۪ٹھہٕ چُھ پکا ن یِوان تہٕ توٚہۍ وُچھِو نہٕ اللہ تعالیٰ سٕندِس سُنّتس منٛز کانٛہہ تبد یلی۔"
  48,24,"۔سُے چُھ  ییٚمۍ مکّہ چہِ وٲدی منٛزٕ تِہِندۍ اتھہٕ تۅہیہِ نِشہِ تہٕ تُہٕندۍ اتھہٕ تِمن نِشہِ پتھ رٔٹۍ۔،حالا نکہ تٔمۍ اوسنو تۅہیہِ تِمن پٮ۪ٹھ غلبہٕ عطا کوٚر مُت،تہٕ یِکینٛژھا توٚہۍ کران ٲسِو اللہ تعالیٰ اوس تتھ وُچھان۔"
  48,25,"۔تِمے لُکھ چِھ یِمو کُفر کوٚر تہٕ توٚہۍ رُکٲوِ ہَو مسجدِ حرام نِشہِ ، تہٕ ہَدِی ہٕندٮ۪ن اوٗنٹن نہٕ تِہنزِ قربٲنی ہٕنزِ جایہِ واتنہٕ۔اگر ﴿مکّس منٛز ﴾ تِتھۍ مو من مرد تہٕ مستوٗراتہٕ موجوٗد آسہن نہٕ یِم نہٕ توٚہۍ زانان ٲسِہوٗکھ ،تہٕ یہِ خطرٕ ہ آسِہے نہٕ زِ نادٲنستگی منٛز کٔرِیوٗکھ توٚہۍ تِم پا مال ،تہٕ امہِ سٍتۍ یِیہِ تۅہیہِ پٮ۪ٹھ حر ف ﴿تیٚلہِ یِیہِ ہے نہٕ جنگ رُکا و نہٕ ۔جنگ آو امہِ موجوٗب رُکا و نہٕ ﴾ تاکہ اللہ تعالیٰ یس ییژِھہ تس کرِ پننِس رحمتس منٛز دٲخل۔تِم مو من آسہن الگ سپٕدِ مٕتۍ،﴿اہلِ مکّو منٛزٕ ﴾ یِم کٲفر ٲسۍ ،تِمن دِمہَو أسۍ ضروٗر سخت سزا۔﴿ یہِ ٲس سۅ مصلحت ییٚمہِ کِس بِنا ہس پٮ۪ٹھ خُدا ین دِیُت نہٕ حد یبیہ ہس منٛز جنگ سپد نہٕ ۔مکّہ معظّمہ ہس منٛز ٲسۍ تمہِ ساعتہٕ واریاہ مُسلمان مرد تہٕ مستوٗراتہٕ تِتھۍ موجو د یِمَو پنُن ایمان ژوٗرِ اوس تھو ومُت۔یا یُہُند ایمان پے اوس مگر پننہِ بے بسی کِنۍ ٲسۍ نہٕ تِم ہجرت ہیٚکان کٔرِ تھ تہٕ ظُلم وستمٕکۍ شکار ٲسۍ سپدان ۔اتھ حالتس منٛز اگر جنگ سپد ہے تہٕ مُسلمان سپد ہن کفا رن متھا ن متھان مکّہ معظّمس منٛز دٲخل ،تیٚلہِ یِہَن کٲفر ن سٍتۍ سٍتۍ یِم مُسلمان تہِ نادانستگی منٛز مُسلمانن ہٕندیٚو اَتھو مار نہٕ۔ دوٚ یُم پہلو اوس امہِ مصلحتُک یہِ زِ اللہ تعالیٰ اوس نہٕ قر یشن أکِس خو نریز جنگس منٛز شکست دِتھ مکہ یژھان فتح کر ناوُن، بلکہ اوس تس پیش نظر یہِ زِ دۅ ن ؤرِ ین منٛز کرِ تِمن پرٛتھ طر فہٕ گھیرٕ کٔرِتھ تِتھہٕ پٲٹھۍ بے بس زِ تِم گژھن کُنہِ مز احمت ورٲے مغلو ب گژٕھنۍ ،تہٕ پتہٕ گژِھہ اند ہیٚتھ سورُے قبیلہٕ اسلام قبول کٔرِ تھ اللہ تعالیٰ سٕندِس رحمتس منٛز دٲخل ،یِتھہٕ پٲٹھۍ زن فتح مکہ کِس مو قعس پٮ۪ٹھ سپُد ۔ ﴾ ﴿یۅ ہے وَجہ چُھ زِ ﴾"
  48,26,"۔ییٚلہِ یِمو کٲفر و پننیٚن دِلن منٛز جٲہلا نہٕ حمیّت بیہٚنٲو، خُداین کٔر پننِس رسول صلی اللہ علیہ وسلمس تہٕ مو منن پٮ۪ٹھ سکینت نٲزِل ۔ ﴿ یتھ جایہِ چُھ سکینت مُراد صبر تہٕ وقار ییٚمہِ سٍتۍ نبی صلی اللہ علیہ وسلمو تہٕ مُسلمانو کُفا رن ہٕندِ امہِ جٲہلا نہٕ حمیّتُک مقا بلہٕ کوٚر ۔ تِمن کھوٚت نہٕ تِہٕنز یہِ ہٹ دھر می تہٕ ٹا کارٕہ زیا دتی وُچھِتھ شرارت ،تہٕ تِہِندِس جوا بس منٛز کٔر نہٕ تِمو کانٛہہ تِژھہ کتھ یوسہٕ حق نِشہِ ڈٔلِتھ آسِہے ،تہٕ راستی خلا ف آسِہے یا ییٚمہِ سٍتۍ معا ملہٕ سُلجھنہٕ بجا ے وارے تَتھ کُھر یِیہِ ہے۔﴾ تہٕ مومِن تھٲوۍ تقویٰ چہِ کتھہِ ہٕندۍ پا بند، تِکیازِ تِمَے ٲسۍ اَمِکۍ زیادہ حقدار تہٕ اَمِکۍ اہل، اللہ تعالیٰ چُھ پرٛتھ چیزُک علم تھاوان۔ع"
  48,27,"۔پٔزۍ پٲٹھی اوس خُداین پننِس رسول صلی اللہ علیہ وسلمس پوٚز خواب ہو و مُت یُس ٹھیک ٹھیک حق مُطا بق اوس۔﴿ یہِ چُھ تمہِ سوا لُک جواب یُس بار بار مُسلمانن ہٕندٮ۪ن دِلن کوٗران اوس۔ تِم ٲسۍ ونان زِرسول اللہ صلی اللہ علیہ وسلمو ہَے خوا بس منٛز یہِ وُچھمُت اوس زِ تِم صلی اللہ علیہ وسلم چِھ مسجدِ حرا مَس منٛز دٲخل سپِد مٕتۍ تہٕ بیت اللہ ہُک طوا ف چُھکھ کوٚر مُت،پتہٕ کیا سپُد یہِ زِ أسۍ چِھ عمر ہ کر نہٕ ورٲے واپس گژھان۔﴾ اِن شا ٔاللہ سپدِ و توٚہۍ ضروٗر مسجدِ حرا مَس منٛز پوٗرٕ امن سان دٲخل۔ ﴿ یہِ وعدٕہ سپُد برونٛٹھس ذی القعدہ 7 ھ منٛز پوٗرٕ۔ تواریخس منٛز چُھ ، یہِ عمر ہ  عمر تہ القضا ٔ کہ ناوٕ مشہور۔ ﴾ پننیٚن کلن کٲسِو مَس تہٕ مستس کٔرِ و کٹٲے، تہٕ تۅہیہِ آسیٚو نہٕ کانٛہہ خو ف۔ سُہ اوس تتھ کتھہِ زانان یوسہٕ نہٕ توٚہۍ زانان ٲسِو، امہِ موجوٗب کٔر نَو تٔمۍ تۅہیہِ سُہ خوا ب پوٗرٕ سپٕد نہٕ برونٛہہ یہِ قر یبی فتح عطا۔"
  48,28,"۔سُہ اللہ تعالیٰ ہٕے ییٚمۍ پنُن رسول صلی اللہ علیہ وسلم ہدا یت تہٕ دین حق سا ن سوٗز مُت چُھ، تا کہ تتھ کرِ تمام دینن پٮ۪ٹھ غٲلب ۔تہٕ اتھ پٮ۪ٹھ چھےٚ اللہ تعالیٰ سٕنز گوٲہی کٲفی﴿ یتھ جایہِ چُھ یہِ کتھ ارشاد فر ما و نُک وجہ یہِ زِ ییٚلہِ حد یبیہ ہس منٛز صلحُک معا ہد ہ لیکھُن اوسُکھ لوگمُت،تمہ وقتہٕ اوس کُفا رِ مکّو حضو رصلی اللہ علیہ وسلمن ہٕندِس مُبا رک ناوس سٍتۍ رسول اللہ ہُک لفظ لیکھنس پٮ۪ٹھ اعتراض کوٚر مُت ۔ اَتھ پٮ۪ٹھ آو فر ما و نہٕ زِ رسول سُند رسول آسُن چھےٚ اکھ حقیقت یتھ منٛز کٲنٛسہِ ہٕندِ ماننہٕ یا نہ ماننہٕ سٍتۍ کانٛہہ فرق چَھنہٕ پیٚوان ۔اتھ اگر کینٛہہ لُکھ مانان چِھنہٕ متہٕ مٲنۍ تن ۔ امہِ کِس حقیقت آسنس پٮ۪ٹھ چھےٚ صر ف اللہ تعالیٰ سٕنز شہا دت کٲفی۔﴾"
  48,29,"۔محمد صلی اللہ علیہ اللہ وسلم چھِ اللہ تعالیٰ سٕندۍ رسول،تہٕ یِم لُکھ یِمن سٍتۍ چِھ تِم چِھ کُفّا رن پٮ۪ٹھ سخت،﴿ عر بی زبٲنۍ منٛز چِھ ونان ،فلا ن شدید علیہ،فلٲنۍ شخص چُھ اتھ پٮ۪ٹھ سخت ، یعنی سُہ دبا وُن یا نر ماوُن یا پننہِ مطلب خٲطرٕ رٲضۍ کرُن  چھُ مشکل ۔صحابہ کرامن ہُنٛد کفارن پیٹھ سخت آسنُخ مطلب چھُ یہِ زِ تِم چھِنہٕ  ٲٹۍ دۅگل زِ یپٲرۍ کفاریژھن تپٲرۍ دِنکھ مانڈ۔تِم چِھنہٕ کیلہِ ہٕندۍ پٲٹھۍ زِ ژٲپھ دِنہٕ ورٲے نینگلا ونکھ کٲفر ۔یِم ہیکو کھ نہٕ کُنہِ خو فہٕ سٍتۍ دبٲوِتھ۔ یِم ہیکو کھ نہٕ کُنہِ تر غیب سٍتۍ موٚ لۍ ہیٚتھ۔ کٲفر ن منٛز چُھنہٕ یہِ طا قت زِ تِمن ہٹا ون امہِ عظیم مقصدٕ نِشہِ ییٚمہِ خٲطرٕ تِم موٚنڈِس پٮ۪ٹھ گردن تھٲوِتھ محمد صلی اللہ علیہ وسلمس ساتھ دِنہٕ خٲطرٕ ووٚتھمٕتۍ چِھ۔ ﴾ تہٕ پانہٕ وٲنۍ چِھ رحم دل ۔﴿ یعنی تِہنزٕ سختی یِکینژھاہ تہِ چھےٚ سۅ چھےٚ دین کیٚن دشمن خٲطرٕ۔اہلِ ایمانن خٲطرٕ نہٕ کینٛہہ ،اہلِ ایمانن خٲطرٕ چِھ تِم نر م ،رحیم تہٕ شفیق، ہمدر تہٕ غمگسار۔اصو لٕکۍ تہٕ مقصدٕ کۍ اتحا دن چُھ تِمن منٛز اکھ أکۍ سٕندِ خٲطرٕ محبت تہٕ ہم رنگی تہٕ ساز گٲری پٲدٕ کٔر مٕژ﴾ توٚہۍ ییٚلہِ وُچِھو ،تِم وُچھوٗکھ رکوع تہٕ سجودن،تہٕ اللہ تعالیٰ سٕندِس فضلس تہٕ تٔمۍ سٕنزِ خۅ شنو دی ہٕندِس طلبس منٛز مشغو ل۔سجد ن ہٕندۍ اثرت چِھ تِہند ٮ۪ن بتھیٚن پٮ۪ٹھ موجوٗد ،یِمو سٍتۍ تِم الگ چِھ یِوان پرٛزنا و نہٕ۔ ﴿اَمہِ نِشہِ چُھنہٕ مُراد ڈیٚکُک سُہ داغ یُس سجدٕہ کر نہٕ سٍتۍ کینژھن نما ز پر ن والیٚن آسان چُھ، بلکہ چُھ امہِ نِشہِ مُراد خدا تر سی، کر یم النفسی ،شرافت تہٕ حُسن اخلا قٕکۍ تِم آثا ر یِم خدایس برونٛہہ کنہِ نمنہٕ کہ وجہ سٍتۍ فطر تاً انسان سٕندِس بُتھِس پٮ۪ٹھ چِھ نٔنۍ نیرا ن۔ اللہ تعالیٰ سٕندِ ارشادُک منشہِ چُھ یہِ زِ محمد صلی اللہ علیہ وسلمن ہٕندۍ سٲتھۍ چِھ تِتھۍ زِ تِمن کُن نظر تراوٲنۍ چُھ پے لگان زِ تِم چِھ تمام خلا یقو منٛز رٕ تۍ خلق، تِکیازِ خُدا پرستی ہُند نوٗر چُھ تِہند یو بُتھیو پٮ۪ٹھہٕ چمکا ن ﴾ یہِ چُھ تِہُند صفت توراتس منٛز۔ تہٕ انجیلس منٛز چھےٚ تِہٕنز مثا ل یِتھہٕ پٲٹھۍ دِنہٕ آمٕژ کہ، زنتہٕ اکھ کھیتی ﴿فصل ﴾ چُھ ییٚمۍ گۅڈٕ ہ کوٚٹ کوٚڑ، پتہٕ دِژٕ ن اتھ تقو یّت ،پتہٕ گٔیہِ سۅ پۅ ختہٕ ،پتہٕ گٔیہِ سۅ پننیٚن گۅڈن پٮ۪ٹھ کھڑا، کا شت کر ن والیٚن چھےٚ سۅ خۅ ش کران تا کہ کُفّار دَزن تِہندِس پھا نپھلنس پٮ۪ٹھ۔ امہِ دَرِکۍ لُکھ یِمو ایمان چُھ اوٚ نمُت تہٕ یِمو نیک عملہٕ چھےٚ کرِ مژٕ، خُداین چُھ تِمن سٍتۍ مغفرتُک تہٕ عظیم اجرُک وعدہ کوٚر مُت ۔ ع"
