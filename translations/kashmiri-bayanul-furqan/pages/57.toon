quran[29]{c,v,t}:
  57,1,"۔اللہ تعالیٰ سٕنز تسبیح چھےٚ کٔرمٕژ پرٛتھ تٔمۍ چیز ن یُس زمینس تہٕ آسما نس منٛز چُھ،سُے چُھ غٲلب تہٕ حکمت وول ۔"
  57,2,"۔زمین و آسمانن ہٕندِ سلطنتُک مٲلِک چُھ سُے،زند گی چُھ بخشا ن تہٕ موت چُھ دِوان، تہٕ پرٛتھ چیز س پٮ۪ٹھ چُھ قدرت تھاوان ۔"
  57,3,"۔سُے چُھ اوّل تہِ تہٕ ٲخر تہِ، تہٕ ظٲہر تہِ چُھ تہٕ بٲطن تہِ، ﴿یعنی ییٚلہِ کِہِنۍ اوس نہٕ تیٚلہِ اوس سُے ، تہٕ ییٚلہِ کِہٕنۍ روزِ نہٕ تیٚلہِ روزِ سُے۔ سُہ چُھ سارِ وٕے ظٲہر و کھۅتہٕ کھٔسِتھ ظٲہر، تِکیازِ دُنیا ہس منٛز یِکینژھاہ تہِ ظہور چُھ، سُہ چُھ تٔمۍ سٕندِ نٕے صفا تن تہٕ افعا لن ہُند تہٕ تٔمۍ سٕندی نوٗرُک ظہور،تہٕ سُہ چُھ پرٛتھ بٲطن کھۅتہٕ کھٔسِتھ بٲطن،تِکیازِ حوا سَو سٍتۍ تٔمۍ سٕنز ذات محسو س کرٕنۍ چُھ در کنار، عقل و فکر تہٕ خیال تام ہیٚکہِ نہٕ تٔمۍ سٕنز حقیقت تہٕ طر ز لٔبِتھ﴾تہٕ تس چُہ پرٛتھ چیزُک علم۔"
  57,4,"۔سُے چُھ ییٚمۍ سٲری آسمان تہٕ زمین شیٚن دۅ ہن منٛز پٲدٕ کٔرۍ، تہٕ پتہٕ سپُد عر شس پٮ۪ٹھ جلو ہ گر۔ تٔمۍ سٕندِس عِلمس منٛز چُھ، یِکینژھاہ زمینس منٛز گژھان چُھ تہٕ یِکینژھاہ امہِ منٛزٕ نیران چُھ، تہٕ یِکینژھاہ آسما نہٕ پٮ۪ٹھہٕ وسان چُھ تہٕ یِکینژھاہ اَتھ منٛز کھسان چُھ۔ ﴿دوٚ یِمیٚن لفظن منٛز وَنو زِ سُہ چُھنہٕ محض کُلیا تن ہُندُے یوت عٲلم کینٛہہ بلکہ چُھس جُز یاتن ہُند تہِ علم ۔اکھ اکھ دا نہٕ یُس تہن تل گژھان چُھ، اکھ اکھ ؤتھٕر تہٕ کوٚٹ یُس زمین منٛزٕ پھٹا ن چُھ، روٗدُک اکھ اکھ قطرٕ ہ یُس آسما نہٕ وَسان چُھ تہٕ بُخار اتن ہُند پرٛتھ مقدار یُس سمندرَو تہٕ جھِیٖلَو پٮ۪ٹھہٕ ؤتھِتھ آسمانس کُن کھسان چُھ، چُھ تس در نظر ۔تس چھےٚ پے زِ کُس دانہٕ کتھ جایہِ چُھ زمینس  منٛز،توَے چُھ سُہ تتھ پھا ٹوِتھ کوٚٹ کڑان تہٕ تتھ چُھ پرورش کٔرِ تھ پھا نپھلاوان۔تس چھےٚ پے زِ بخا ر اتن ہُند کوٗتاہ مقدار کمہِ جایہِ پٮ۪ٹھہٕ چُھ ووٚتھمُت تہٕ کوٚت چُھ ووتمُت،تیٚلی چُھ سُہ تِمن سارِ نٕے جمع کٔرِ تھ اوٚبُر بناوان تہٕ زمین کیٚن مختلف حِصّن منٛز بٲگرٲوِتھ چُھ پرٛتھ جایہِ حسا بہٕ سان روٗد تراوان۔﴾سُہ چُھ تۅہیہِ سٍتۍ ییٚتہِ توٚہۍ چِھو۔ یۅسہٕ کٲم تہِ کران چِھو تتھ چُھ سُہ وچھان۔"
  57,5,"۔سُے چُھ زمین تہٕ آسمانن ہٕنزِ بادشٲہی ہُند مٲلِک،تہٕ سٲر ی معالات چِھ فٲصلہٕ خٲطرٕ تٔسۍ کُن رجوع یِوان کر نہٕ۔"
  57,6,"۔سُے چُھ رٲژ کران دۅہس منٛز تہٕ دۅہس کران رٲژ منٛز دٲخل، تہٕ دِلن منٛز پوشیدٕ راز تام چُھ زانان۔"
  57,7,"۔ایمان أنِو خُدایس تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلمس پٮ۪ٹھ ۔﴿یتھ جایہِ چُھنہٕ ایمان اَننہٕ نِشہِ مُراد محض زبٲنۍ زبٲنۍ اسلامُک اقرار بلکہ چُھ پزِ دِلہٕ ایمان اَنُن﴾تہٕ خر چ کٔرِو تِمو چیز و منٛزٕ یِمن پٮ۪ٹھ تٔمۍ توٚہۍ خلیفہٕ چِھنَو بنٲوِ مٕتۍ۔یِم لُکھ تۅہیہِ منٛزٕ ایمان اَنن بیٚیہِ کر ن مال خرٕچ ،تِہندِ خٲطرٕ چُھ بوٚڈ اَجر۔"
  57,8,"۔تۅہیہِ کیا چُھو گوٚ مُت زِ توٚہۍ چِھو نہٕ خُدایس پٮ۪ٹھ ایمان انان حالانکہ رسول صلی اللہ علیہ وسلم چُھو تۅہیہِ پننِس ربّس پٮ۪ٹھ ایمان اَنٕنچ دعوت دِوان۔﴿یتھ جایہِ تہِ چُھ ایمان اننہٕ نِشہِ مُراد پزِ دِلہٕ ایمان اَنُن ﴾ تہٕ تٔمۍ چُھنَو تۅہیہِ عہد ہیوٚتمُت، ﴿یعنی اطا عتُک وعدٕہ﴾ اگر توٚہۍ پٔزِ پٲٹھۍ مانن وٲلۍ چِھو۔"
  57,9,"۔سُہ چُھ اللہ تعالیٰ ہٕے یُس پننِس بند س پٮ۪ٹھ چُھ صا ف صا ف آیا ت نٲزِل کران ۔ تاکہِ تۅہیہِ اَنیو اَنہِ گٹو منٛزٕ کٔڑِتھ گا شس کُن،تہٕ حقیقت چھےٚ یہِ زِ اللہ تعالیٰ چُھ تۅہیہِ پٮ۪ٹھ سٮ۪ٹھاہ شفیق تہٕ مہر بان ۔"
  57,10,"۔ٲخر کیا و جہ چُھ زِ توٚہۍ چِھو نہٕ اللہ تعالیٰ سٕنزِ وَتہِ منٛز خر چ کران ، حالانکہ زمینُک تہٕ آسما نن ہُند میراث چُھ خُداے سٕندِی خٲطرٕ۔ ﴿ اتھ چِھ زٕہ مطلب ۔ اکھ یہِ زِ مال چُھنہٕ ہمیشہ تۅہیہِ نِشہِ روزن وول، اکہِ دۅہ چُھو لازِ ماً تۅہیہِ یہِ ترٲوِ تھ گژُھن تہٕ اللہ تعالیٰ ہٕے چُھ اَمِیُک وٲرث بنن وول۔بیا کھ مطلب چُھس یہِ زِ اللہ تعالیٰ سٕنزِ وَتہِ منٛز گژھیو نہٕ تۅہیہِ مال خر چ کر نہٕ وِزِ کُنہِ غر یبی تہٕ تنگ دستی ہُند اندیشہ لا حق گژُھن، تِکیازِ یَس خُداے سٕندِ خٲطرٕ توٚہۍ یہِ خر چ کٔرِو سُہ چُھ زمین و آسمان کیٚن تمام خزا نن ہُند مٲلِک، تس نِشہِ اوسنہٕ تۅہیہِ دِنہٕ خٲطرٕ بس یُتُے کینٛہہ یُس تۅہیہِ تٔمۍ دِیمُت چُھنَو،بلکہ ہیٚکیو سُہ تۅہیہِ پگا ہ امہِ کھۅتہٕ واریاہ زیادٕہ دِتھ﴾ تۅہیہِ منٛزٕ یِم لُکھ فتح حٲصل سپدَنہٕ پتہٕ خر چاو ن تہٕ جہا د کر ن ، تِم ہیٚکن نہٕ زانٛہہ تِمن لُکن برابر سپدِتھ یِمو فتح حٲصل گژھنہٕ برونٛہہ خر چو و مُت تہٕ جہا د کوٚر مُت چُھ۔ تِہُند در جہ چُھ تِمو کھۅتہٕ کھٔسِتھ یِمو پوٚتُس خرچوو تہٕ جہاد کوٚر،اگر چہ خداین چھِ دۅشوٕنۍ سٍتۍرٕتۍ وعدٕہ کٔرِمٕتۍ﴿اَمہِ نِشہِ سپُد معلو م زِ ییٚلہِ تہِ زانٛہہ اسلامس پٮ۪ٹھ سُہ وقت یِیہِ یتھ منٛز کُفر تہٕ کٲفر ن ہُند پوتُر گوٚ ب آسہِ تہٕ بظٲہر آسن نہٕ اسلام کہ غلبٕکۍ آثا ر دوٗر دوٗر تام نظرِ گژھان، اَمہِ وقتہٕ یِم لُکھ اسلام کہ حما یت خٲطرٕ پنُن جان موٚنڈِس پٮ۪ٹھ تھا ون بیٚیہِ کرن مال خر چ ، یِہندِس مرتبس واتن نہٕ تِم لُکھ یِم کفر و اسلام کہِ کشمکشُک فٲصلہٕ اسلام کِس حقس منٛز سپد نہٕ پتہٕ قر بٲنیہِ دِن ﴾ یِکینٛژھاہ توٚہۍ کران چِھو اللہ تعالیٰ چُھ تمہِ نِشہِ با خبر ۔ع"
  57,11,"۔ کُس چُھ یُس خُدا یس دِیہِ قر ض؟ رُت قر ض، تاکہ اللہ تعالیٰ دِیہِ اتھ کینٛہہ گو نہٕ اضا فہٕ کٔرِتھ واپس ،تہٕ تس خٲطرٕ چُھ بہتر ین اجر ۔ ﴿ یہِ چھےٚ اللہ تعالیٰ سٕنزِ کر یمی ہٕنز شان زِ اگر انسان تٔمۍ سُند عطا کر نہٕ آمُت مال تٔمۍ سٕنز ی وَتہِ منٛز خر چاوِ ، تیٚلہِ چُھ سُہ تتھ پننہِ ذمہٕ قر ض دِوان قرار، بشر طیکہ سُہ آسہِ قر ضِ حسن﴿ رُت قر ض ﴾ یعنی خٲلص نیّت سان یِیہِ کُنہِ غرضہٕ ورٲے دِنہٕ۔اَتھ قرضس متعلق چھِ اللہ تعالیٰ سٕندۍ زٕہ وعدٕہ ،اکھ یہِ زِ سُہ دِیہِ کینٛہہ گۅنہٕ ہُررٲوِتھ سُہ واپس،بیاکھ یہِ زِ سُہ کرِ اَتھ پیٹھ پننہِ طرفہٕ  بہتر ین اجر تہِ عطا﴾"
  57,12,"۔ تمہِ دۅہ ییٚلہِ توٚہۍ مو من مر د تہٕ مو من مستوٗراتہٕ وُچھوٗکھ،زِ تِہُند نوٗر چُھ تِمن برونٛہہ برونٛہہ تہٕ تِہندِ دٔچِھنہِ طر فہٕ دَوان،﴿ یتھ جایہِ ہیٚکہِ اکھ سوال أکِس شخصہٕ سٕندِس ذہنس منٛز شک پٲدٕ کٔرِ تھ ۔ سُہ چُھ یہِ زِ برونٛہہ برونٛہہ نوٗرُک پکُن چُھ فِکرِ تران مگر نوٗرُک صرف دٔچِھنہِ اَندِ دَو نُک مطلب کیا چُھ؟ کیا تِہندِ کھۅ ورِ طر فہٕ آسیا انہِ گوٚٹ؟ اَمِیُک جوا ن چُھ یہِ زِا گرا کھ شخص پننِس دٔچِھنِس اتھس کیٚتھ گاش ہیتھ پکان آسہِ،اَمہِ گاشہِ گژِھہ کھۅوُر اند تہِ روشن مگر حقیقت چھےٚ یہِ زِ گاش چھُ أمِس دٔچھِنِس اتھس کیتھ﴾۔ ﴿ تِمن یِیہِ وَننہٕ زِ ﴾ "" از چھےٚ بشارت تُہندِ خٲطرٕ ۔"" جنّت آسن ،یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان، یِمن منٛز تِم ہمیشہِ روزن۔یٔہے چھےٚ بٔڑ کامیٲبی۔"
  57,13,"۔تمہِ دۅہ آسہِ منا فق مردن تہٕ مُنا فق زنانن ہُند یہِ حال زِ تِم وَنن مو مِنن، "" ہے اَسہِ کُن وُچِھتو تاکہ أسۍ تُلہَو تُہندِس نوٗرس کینٛہہ فٲیدٕہ۔"" مگر تِمن یِیہِ وننہٕ "" پتھ ۂٹِو ، پنُن نوٗر ژھٲنڈِ و بیٚیہِ کُنہِ جایہِ ۔"" پتہٕ یِیہِ تِمن منٛز باگ اکھ دیوار کھڑا کر نہٕ یتھ منٛز اکھ دروازٕہ آسہِ ۔ تتھ دروازس اندر آسہِ رحمت، تہٕ نیٚبرٕ آسیٚس عذا ب ۔"
  57,14,"۔تِم وَنن آلو کٔر ۍ کٔرۍ مو منن "" کیا أسۍ ٲسۍ نا تۅہیہِ سٍتۍ ؟"" مو مِن دِن جواب،"" آ ، مگر تۅہیہِ ترووُو پنُن پان پانہٕ فِتنس منٛز، مو قع پر ستی کٔرِو ، شکس منٛز روٗدِو ، تہٕ اپٕز ۍ تو قعات روٗدِو تۅہیہِ فر یب دِوان، یوٚت تام زن اللہ تعالیٰ سُند فٲصلہٕ آو، تہٕ ٲخر ی وقتس تام روٗدُو تۅہیہِ سُہ بوٚڈ دو کھہٕ باز﴿شیطا ن ﴾ خُداے سٕندِس معا ملس منٛز دو کھہٕ دِوان۔
۔ لہٰذا، نَہ یِیہِ اَز تۅہیہِ نِشہِ کانٛہہ فِدِیہِ قبول کر نہٕ، تہٕ نَہ تِمن لُکن نِشہِ یِمو ٹا کارٕ کفراوس کوٚر مُت۔ تُہُند ٹھکا نہٕ چُھ جہنم، سُے چُھو تۅہیہِ خبر ہیٚنہٕ وول تہٕ یہِ چُھ بد تر ین انجام۔"""
  57,15,"۔ لہٰذا، نَہ یِیہِ اَز تۅہیہِ نِشہِ کانٛہہ فِدِیہِ قبول کر نہٕ، تہٕ نَہ تِمن لُکن نِشہِ یِمو ٹا کارٕ کفراوس کوٚر مُت۔ تُہُند ٹھکا نہٕ چُھ جہنم، سُے چُھو تۅہیہِ خبر ہیٚنہٕ وول تہٕ یہِ چُھ بد تر ین انجام۔"""
  57,16,"۔کیا ایمان اَنن والیٚن خٲطرٕ ووت ناوُنہِ سُہ وقت۔ ﴿ یتھ جایہِ چُھنہٕ "" ایمان اَنن والیٚن خٲطرٕ "" مُراد تمام مُسلمانن کینٛہہ۔بلکہ چُھ مُسلمانن ہُند سُہ خا ص دوٚر یُس ایمانُک اقرار کٔرِ تھ رسول اللہ صلی اللہ علیہ وسلمن ہٕندٮ۪ن مانن والیٚن منٛز شٲمِل اوس گوٚ مُت تہٕ امہِ باوجود ٲس نہٕ تِہندِس دِلس منٛز اسلامٕچ دگ۔﴾زِ تِہندۍ دِل پِگلن اللہ تعالیٰ سٕنزِ ذکر سٍتۍ، تہٕ تٔمۍ سٕندِس نٲزِل کر نہٕ آمتِس حقس برونٛہہ کنہِ نمَن، تہٕ تِم گژھن نہٕ تِمن لُکن ہٕندۍ پٲٹھۍ بَنٕنۍ یِمن برونٛہہ کتا ب ٲس دِنہٕ آمٕژ،پتہٕ گُزر یا و اَکھ زیوٗٹھ کال تِمن پٮ۪ٹھ تہٕ تِہندۍ دِل سپٕدۍ سخت، تہٕ اَز چِھ تِمو منٛزٕ اکثر فا سق بٔنِتھ؟"
  57,17,"۔ وارٕ پٲٹھۍ زٲنِو زِ اللہ تعالیٰ چُھ زمینس اَمہِ کہ مو ت پتہٕ زند گی بخشا ن ﴿یَتھ جایہِ ییٚمہِ منا سبت کِنۍ یہِ کتھ ارشاد چھےٚ سپٕز مٕژ،سۅ پَزِ ٹھیک پٲٹھۍ سمجھِنۍ۔ قرآن مجیدس منٛز چُھ واریاہن جاین نبوّتس تہٕ کتا ب نٲزِل سپد نس روٗدچن بر کتن سٍتۍ  ہِشر دِنہٕ آمُت تِکیازِ انسٲنیتس پٮ۪ٹھ چِھ اَمِکۍ تِمَے اثرات مُرتب سپدان یِم زمینس چِھ روٗدٕ سٍتۍ سپدان۔یتھ زمینس منٛز وۅ پونٕچ رَژھ تہِ صلٲحیت چھےٚ آسان، سۅ چھےٚ پھۅ لان، البتہٕ بنجر زمین چھےٚ بنجرٕ ے روزان۔﴾اسہِ چَھو نِشٲنِیہِ تۅہیہِ صا ف صاف ہاوِ مژٕ، بنان چُھ زِ توٚہۍ ہیٚیِو عقلہِ کٲم۔"
  57,18,"۔مردن تہٕ مستوٗراتن منٛز یِم لُکھ صد قات دِنہٕ وٲلۍ چِھ ﴿صَدقہ چُھ اُردو زبٲنۍ منٛز سٮ۪ٹھاہ بُرٕ معنِیَن منٛز بولنہٕ یِوان مگر اسلام کِس اصطلا حس منٛز چِھ یہِ تتھ عطیس ونان یُس پزِ دِلہٕ تہٕ خٲلِص نیّت سان محض خُداے سٕنزِ خۅ شنو دی خٲطرٕ دِنہٕ یِیہِ تہٕ یتھ منٛز کانٛہہ ریا کٲری آسہِ نہٕ، تہٕ نہ یِیہِ کٲنٛسہِ مِنتھ تھا و نہٕ ۔ کٲشِر زبٲنۍ منٛز تہِ چُھ اتھ یۅہے معنی ﴾ تہٕ یِمو خُدایس قرضِ حَسَن چُھ دِ یتُمُت، تِمن یِیہِ یقیناً کینٛہہ گۅ نہٕ ہُر رٲوِتھ دِنہٕ ، تہٕ تِہندِ خٲطرٕ چُھ بہتر ین اجر۔"
  57,19,"۔تہٕ یِمو لُکو اللہ تعالیٰ تہٕ تٔمۍ سٕندٮ۪ن رسولن پٮ۪ٹھ ایمان چُھ اوٚنمُت،تِمے چِھ پننِس ربّس نزدیک صدیق تہٕ شہید۔﴿صد یق چُھ صد قُک مبا لغہ۔صا دِ ق گوٚو پٔزِ یو ر تہٕ صد یق گوٚو سٮ۪ٹھاہ پٔزِ یور۔مُراد چُھ تِیُتھ راست باز انسان یَس منٛز نہٕ کانٛہہ کھۅ چر آسہِ، یُس نہٕ زانٛہہ آسہِ حق نِشہِ تہٕ سیٚزِ رٕنِشہِ ڈوٚ لمُت، یس نِشہِ نہٕ یہِ توقع ہٕے یِیہِ کر نہٕ زِ سُہ وَنہِ زانٛہہ پننِس ضمیرس خلا ف کانٛہہ کتھ، ییٚمۍ کانٛہہ کتھ مٲنِمٕژ آسہِ تہٕ سۅ آسیٚن پوٗرٕ خلو صہٕ سان مٲنِمٕژ ، تمہِ کہ وفا دٲر ی ہُند آسیٚن حق کوٚر مُت ادا ،تہٕ پننہِ عملہِ سٍتۍ آسیٚن ثٲبِت دِیتمُت کٔرِ تھ زِ سُہ چُھ پٔزِ پٲٹھۍ تِیُتُھے مانن وول یُتھ أکِس مانن وٲلِس پزِ آسُن، "" شہید"" چُھ یتھ جایہِ مُراد سُہ شخص یُس پننہِ قول و عملہِ سٍتۍ حقٕچ شہا دت دِیہِ۔﴾تِہندِ خٲطرٕ چُھ تِہُند اجر تہٕ تِہُند نوٗر،تہٕ یِمو لُکو کُفر چُھ کوٚر مُت تہٕ سا نیٚن آیا تن چُھکھ بُتھ پھِیٚر مُت، تِم چِھ جہنمی ۔ ع"
  57,20,"۔وارٕپٲٹھۍ زٲنِو زِ یہِ دُنیا ہٕچ زند گی چَھنہٕ امہِ ورٲے کِہِنۍ زِ اکھ کھیل تہٕ دل رنز وُن بیٚیہِ زینت ﴿ظٲہر ی ٹیپ ٹا پ ﴾، تہٕ تُہُند پانہٕ وٲنۍ اکھ أکِس تھیٚکُن بیٚیہِ مال واولادن منٛز اکھ أکِس برونٛہہ نیرنٕچ کوٗشش کرٕنۍ۔اَمِچ مثا ل چھےٚ تِژھہ زَنتہٕ اکھ بٲرش سپٕز، امہِ نِشہِ پٲدٕ سپدن وٲلۍ پیداوار وُچِھتھ سپٕدۍ کاشت کار خۅ ش۔ پتہٕ چُھ یۅہے پیداوارپپان تہٕ توٚہۍ چِھو وُچھان زِ یہِ سپُد زرد﴿ یعنی اَتھ ژاو ہَرُد﴾ پتہٕ چُھ یہِ بوٚس بٔنِتھ روزان۔اتھ بر عکس چھےٚ ٲخرت سۅ جا ے ییٚتہِ سخت عذا ب چُھ، بیٚیہِ چھےٚ اللہ تعالیٰ سٕندِ طر فہٕ مغفر ت تہٕ خۅ شنودی۔دُنیا ہٕچ زند گی چَھنہٕ ژھل ﴿یعنی دو کھہٕ دِنہٕ والہِ ﴾ سامانہٕ ورٲے بیٚیہِ کِہِنۍ۔"
  57,21,"۔دوٗرِ و تہٕ کٔرِ واکھ أکِس برونٛہہ نیر نٕچ کوٗشش ربّ سٕندِس مغفرتس تہٕ تتھ جنّتس کُن، ییٚمِچ وُسعت آسمان و زمینس ہِش چھےٚ۔ ﴿ یہِ آیت ییٚلہِ سورۂ آل عمرا ن کِس آیت 133 ،ہس  سٍتۍ پران چِھ تیٚلہِ چُھ تِیُتھ تصّور ذہنس منٛز یِوان زِ یِم با غ تہٕ محل أکِس انسانس جنّتس منٛز میلن تِم آسن صرف أمۍ سٕندِ قیا مہٕ خٲطرٕ مگر در حقیقت آسہِ سٲرٕ ے کاینات أمۍ سٕنز سٲل گاہ۔﴾ یُس فرا ہم چُھ کر نہٕ آمُت تِمن لُکن خٲطرٕ یِمو خُدایس تہٕ تٔمۍ سٕندٮ۪ن رسولن پٮ۪ٹھ آسہِ  ایمان اوٚ نمُت۔یہِ چُھ اللہ تعالیٰ سُند فضل ،یَس یژھان چُھ تس چُھ عطا فر ماوان، تہٕ اللہ تعالیٰ چُھ سٮ۪ٹھا ہ فضلہٕ وول ۔"
  57,22,"۔کانٛہہ مُصیبت چُھنہٕ تِیُتھ یُس زمینس منٛز یا تُہندِس پننِس نفسس پٮ۪ٹھ نٲزِل آسہِ سپدان ، تہٕ اسہِ آسہِ نہٕ سُہ تمہِ کہ پٲدٕ کر نہٕ برونٛہہ أکِس کتا بہِ﴿ یعنی تقدیر کِس نوِشتس﴾ منٛز لیٚکھِتھ تھو و مُت۔یہِ کرُن چُھ اللہ تعالیٰ سٕندِ خٲطرٕ سٮ۪ٹھاہ سہل کٲم۔﴿یہِ سورُے کینٛہہ چُھ امہِ موجو ب ﴾"
  57,23,"۔ تاکہ یِکینژھاہ نقصان تۅہیہِ سپد یو تتھ پٮ۪ٹھ گٔژِھو نہٕ توٚہۍ غمگین سپدٕنۍ ،تہٕ یِکینژھاہ اللہ تعالیٰ تۅہیہِ عطا فرماوِ تتھ پٮ۪ٹھ گٔژھیو نہٕ تۅہیہِ بوش کھسُن۔ اللہ تعالیٰ چُھنہٕ تِتھیٚن لُکن پسند کران یِم پنُن پان بوٚڈ چِھ سمجھان بیٚیہِ چِھ تھیٚکان،"
  57,24,"۔یِم پانہٕ بخُل چِھ کران بیٚیہِ چِھ با قین بخُل کر نس پٮ۪ٹھ ہس دِوان، وۅ نۍ اگر کانٛہہ رُو گردٲنی کران چُھ تیٚلہِ چُھ اللہ تعالیٰ بے نیا ز تہٕ تعر یف کر نہٕ آمُت۔"
  57,25,"۔اسہِ سوٗزۍ پنٕنۍ رسول ٹاکارٕہ نِشٲنیَو تہٕ ہدا یتو سان، تہٕ تِمن  سٍتۍ کٔر کتا ب تہٕ میزان نٲزِل ،تاکہِ لُکھ سپدن انصافس پٮ۪ٹھ قٲیِم ﴿یتھ مختصر کتھہِ منٛز چُھ انبیا علیھمُاالسلامن ہٕندِ مِشنُک پوٗرٕ لُبِ لُبا ب بیان کر نہٕ آمُت۔ خُداے  سٕندۍ طر فہٕ ییٖتاہ تہِ رسول دُنیا ہس منٛز آے تِم سٲری ٲسۍ ترےٚ چیز ہیٚتھ آمٕتۍ﴿1﴾ بَیّنات، یعنی کُھلہٕ کُھلہٕ نِشٲنِیہِ ، روشن دلٲیل تہٕ وا ضح ہدایات۔﴿2﴾ کتاب، یتھ منٛز تِم سٲری تعلیمات لیٚکھنہٕ آمٕتۍ ٲسۍ یِم اِنسانن ہٕندِ ہدایت خٲطرٕ درکار ٲسۍ تاکہ لُکھ ہیٚکن رہنمٲیی خٲطرٕ یِمن کُن رجوع کٔرِ تھ ﴿3﴾ میزان ، یعنی حق و بٲ طلُک سُہ معیا ر یُس ٹھیک ٹھیک ترٛ کرِ توٗلۍ توٗلۍ یہِ وَنہِ زِ افکار، اخلا ق تہٕ معاملا تن منٛز افراط و تفر یط کیٚن مختلف اِنتہاہن در میان کۅ سہٕ کتھ چھےٚ انصا فٕچ۔﴾بیٚیہِ کوٚر شِستٕر نٲزِل یتھ منٛز سٮ۪ٹھاہ زور چُھ تہٕ لُکن خٲطرٕ چِھ واریا ہ فٲیدٕہ۔﴿انبیا عَلیہم ُالسّلامن ہُند  مِشن بیان کر نہٕ پتہٕ أتھۍ سٍتۍ یہِ فر ماوُن، چُھ پٲنۍ پانے اتھ کتھہِ کُن اشارٕہ کران زِ یتھ جایہِ چُھ شِستٕر مُراد سیٲسی تہٕ جنگی طا قت، تہٕ کلا مُک مُدعا چُھ یہِ زِ خُداین ٲسۍ نہٕ پنٕنۍ رسول قیا مِ عدلٕچ محض اکھ اسکیم پیش کرنہٕ خٲطرٕ مبعوٗث کٔرِ مٕتۍ، بلکہ ٲس یہِ کتھ تہِ تِہندِس مِشنس منٛز شٲمِل زِ اتھ گژِھہ عملاً نٲفِذ کر نٕچ کوٗشش یِنۍ کرنہٕ، تہٕ سۅ قُوّت گژِھہ فراہم یِنۍ کر نہٕ ییٚمہِ سٍتۍ در حقیقت عدل سپدِ قٲیِم ، اتھ یِم در ہم بر ہم کر ن تِمن یِیہِ سزا دِنہٕ، تہٕ یِم اتھ مزاحمت کرن تِہِندۍ زور یِن پُھٹرا و نہٕ﴾ یہِ چُھ امہِ موجو ب آمُت کرنہٕ زِ خُدایس سپدِ معلو م زِ کُس چُھ تٔمِس وُچھنہٕ ورٲے تَس تہٕ تٔمۍ سٕندٮ۪ن رسولن مدد کران۔پٔزِپٲٹھۍ چُھ اللہ تعالیٰ سٮ۪ٹھاہ قُوّتہٕ وول تہٕ زبردست۔ع"
  57,26,"۔اسہِ سوٗز نوح علیہ السلام تہٕ ابرا ہیم علیہ السلام، تہٕ تِمن دۅ شوٕنۍ ہٕندِس نسلس منٛز تھٲو نبوّت تہٕ کِتا ب ۔ پتہٕ روٚٹ تِہند یو اولا دَو منٛزٕ کٲنٛسہِ ہدایت تہٕ واریاہ سپٕدۍ فا سق۔"
  57,27,"۔تِمن پتہٕ سوٗزۍ اَسہِ پیٚوٹُھس پٮ۪ٹھ رسول، تہٕ تِمو سارِوٕے پتہٕ کوٚر عیسیٰ ابنِ مر یم علیہ السلام مبعوث تہٕ تس کٔر انجیل عطا،تہٕ یِمو لُکو تٔمۍ سٕنز پیروی کٔر تِہندٮ۪ن دِلن منٛز تر وواَسہِ عار تہٕ رحم۔ تہٕ رہبٲنیت کٔر تِمو پانے ایجاد۔﴿رہبٲنیتُک معنی چُھ تارِکُ الد نیا بنُن تہٕ دُنیٲوۍ زند گی نِشہِ ژٔلِتھ جنگلن تہٕ بالن منٛز روزُن ، نَتہٕ کُنہِ جایہِ تنہٲیی منٛز بِہُن﴾۔ اسہِ اوس نہٕ یہِ تِمن پٮ۪ٹھ فر ض کوٚر مُت،مگر اللہ تعالیٰ سٕنزِ خۅشنودی ہٕندِس طلبس منٛز کوٚڈتِمو یہِ بد عت پانے تہٕ پتہٕ یُس امہِ چہِ پابند ی کر نُک حق اوس سُہ کوٚرُکھ نہٕ ادا۔ تِمو منٛزٕ یِمو لُکو ایمان اوس اوٚنمُت تِہُند اجر کوٚر اسہِ تِمن عطا، مگر تِمو منٛزٕ چِھ اکثر لُکھ فا سق۔"
  57,28,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت، خُدایس کھوٚژِو تہٕ تٔمۍ سٕندِس رسول ﴿محمد صلی اللہ علیہ وسلمس﴾ پٮ۪ٹھ أنِو ایمان، اللہ تعالیٰ کر یو تۅہیہِ پننہِ رحمتُک دۅگنہٕ حصہٕ عطا، تہٕ تۅہیہِ بخشَو سُہ نُو ر ییٚمہِ کِس گاشس منٛز توٚہۍ پٔکِو، تہٕ تُہٕندۍ قصور کرِ معا ف ، اللہ تعالیٰ چُھ سٮ۪ٹھاہ معا ف کر ن وول تہٕ مہر بان۔﴿تۅہیہِ پز یو یہِ رٔوِش اختیار کرٕنۍ﴾"
  57,29,"۔تاکہ اہلِ کتا بن لگہِ پے زِ اللہ تعالیٰ سٕندِس فضلس پٮ۪ٹھ چَھنہٕ تِہٕنز کانٛہہ اجا رٕہ دٲری۔ بیٚیہِ زِ اللہ تعالیٰ سُند فضل چُھ تس پننِسٕے اتھس منٛز، یَس یژھان چُھ تس چُھ عطا کران، تہٕ اللہ تعالیٰ چُھ سٮ۪ٹھاہ فضلہٕ وول ۔ ع"
