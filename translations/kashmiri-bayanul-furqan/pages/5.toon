quran[120]{c,v,t}:
  5,1,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت، بٔندِ شن ہٕنز  کٔرِو پوٗرٕ پٲٹھۍ پابند ی ﴿ یعنی تِمن حدوٗدن تہٕ رُکا وٹن ہٕنز پابند ی کٔرِ و یِمہٕ تۅہیہِ پٮ۪ٹھ عٲید چھےٚ کر نہٕ آمٕژ۔﴾ تُہِندِ خٲطرٕ چِھ چارو ٲے قسمٕکۍ سٲر ی جانو ر حلال کر نہٕ آمٕتۍ۔﴿  اَنعا م   ﴿یعنی چار وٲے﴾ لفظ چُھ عر بی زبٲنۍ منٛز اونٹ ، گاو ، تیٖر تہٕ ژھاو لیٚن با پت وَننہٕ یِوان ۔تہٕ  بہیمہ ہُک اطلا ق چُھ پرٛتھ کٲنٛسہِ گا سہٕ کھیٚنہٕ وٲلِس جانورس پٮ۪ٹھ سپدان۔ چا ر وٲے قسمٕکۍ سٲر ی جانور آے تۅہیہِ پٮ۪ٹھ حلال کر نہٕ۔ اَمِیُک چُھ مطلب یہِ زِ تِم سٲر ی چر ند جانور چِھ تۅہیہِ پٮ۪ٹھ حلال یِم چاروٲے قٔسمٕکۍ آسن یعنی یِمن نہٕ نو کل دند آسن،حیوٲنۍ غذا بجا یہِ آسن کُلۍ کٔٹۍ گا سہٕ کھیوان تہٕ با قی حیوٲنۍ خصو صیا تن منٛز آسن چارواین سٍتۍ ہِشر تھاوان۔ اَمِچ وضا حت چھےٚ نبی صلی اللہ علیہ وسلمو پننیٚن احکامن اندر فر مٲومٕژ یِمن منٛز تِمو صلی اللہ علیہ وسلمو درندٕہ ، شکٲر ۍ پرند ہ تہٕ مُردار کھیٚنہٕ وٲلۍ جانور حرا م چِھ قرار دِتمٕتۍ﴾ سِوا ے تِم یِم برونٹھ کُن پٔکِتھ تۅہیہِ وَننہٕ یِن، البتہٕ حرا م کِس حا لتس منٛز مَہ کٔرِ و پا نس پٮ۪ٹھ شکار حلال ۔بے شک یُس حُکم اللہ تعالیٰ چُھ یژھان سُہ چُھ دِوان ۔"
  5,2,"۔اے لوٗکو ،یِمو ایمان چُھو اوٚ نمُت، خُدا پرستی ہٕنزٕ نشٲنیہِ مَہ کٔرِ یوٗکھ بے حُر مت ،﴿پرٛتھ کانٛہہ سُہ چیز  یُس کُنہِ مسلکٕچ یا عقیدٕچ یا طر زِ فِکر تہٕ عملہِ ہٕنز یا کُنہِ نظا مٕچ نما یند گی آسہِ کران تتھ وَنو تمِیُک شعار ، تِکیازِ سُہ چُھ تمہِ خٲطرٕ علا مت یا نشٲنی ہٕنز کٲم دِوان۔سر کٲرۍ جھنڈٕ ، فو جِچ تہٕ پو لسیٕچ وردی ،سکہٕ ، نوٹ تہٕ مُہرٕ چھےٚ حکو متن ہٕندۍ شعایر۔گر جا ، قر با ن گا ہ تہٕ صلیب چھےٚ مسیحتٕکۍ شعا یر۔ژھوگ، یو نہِ تہٕ مند ر چِھ بر ہمنیتٕکۍ شعا یر۔زیوٗٹھ مس ریش،کوٚر تہٕ کِر پان چِھ سکھ مذہبٕکۍ شعا یر۔دۅ کُر تہٕ درٚوت چُھ اشترا کیتُک شعا ر۔یِم سٲر ی مسلک چِھ پننیٚن پننیٚن پیر و کار ن نِشہِ پننیٚن یِمن شعا یر ن ہٕندِ احترا مُک مطا لبہٕ کران ۔ اگر کانٛہہ شخص کُنہِ نظا م کیو شعا یر و منٛزٕ کُنِچ تو ہین چُھ کران، تیٚلہِ چھےٚ یہِ امہِ کتھہِ ہٕنزِ علا مت زِ  دراصل چُھ سُہ تتھ نظا مَس خلا ف دُشمنی تھاوان، تہٕ ہرگاہ سُہ تو ہین کر ن وول اَمی نظا مُک آسہِ ، تیٚلہِ چُھ تٔمۍ سُند یہِ کار پننِس نظا مَس سٍتۍ اِرتداد تہٕ بغا وتُک معنی تھاوان۔شعایر اللہ  نِشہِ چُھ مُراد تِمہٕ سٲری علا مت تہٕ نِشٲنیہِ یِمہٕ شِر کس ، کُفرس تہٕ دہر یتس مُقابلہٕ خٲلص خُدا پرستی ہٕندِ مسلکٕچ نمٲیند گی آسن کران۔﴾ حرا م ریٚتو منٛزٕ مَہ کرِ یوٗن کانٛہہ حلال، قر بٲنی ہٕندٮ۪ن جانور ن پٮ۪ٹھ مَہ کٔرِ ودوست درٲزی، تِمن جانور ن پٮ۪ٹھ مَہ   ترٲوِ و اَتھہٕ یِہنزن گرد نن منٛز نذرِ خدا و ند ی ہٕندِ علا مت کہ طور پٹہٕ آسن گٔنڈِتھ، نَہ مَہ لٲگِو تِمن لُکن اتھہٕ یِم پننِس ربّ سٕندِ فضلہٕ خٲطرٕ تہٕ تٔمۍ سٕنزِ خۅشنو د ی ہٕندِس تلا شس منٛز محتر م  مکا نس ﴿کعبس ﴾ کُن آسن گژھان، آ، ییٚلہِ احرا مٕچ حالت اَند واتہِ تیٚلہِ ہیٚکِو ۍشکار کٔرِ تھ۔ تہٕ وُچِھو ، زِ أکۍ دٔرۍ یُس تُہندِ خٲطرٕ مسجدِ حرا مُک دروازٕ بند چُھ کوٚر مُت اتھ پٮ۪ٹھ گژِھہ نہٕ تُہُند شرارت تۅہیہِ تیوٗتاہ مشتعل کرُن۔توٚہۍ تہِ لٲگِو تِہندِس مقا بلس منٛز تِمہٕ حر کتہٕ کر نہِ یِمہٕ نہٕ شوٗبن۔﴿چو نکہ کُفارَو ٲسۍ اَمہِ وقتہٕ مُسلمان رکٲوِ مٕتۍ کعبٕچ زیارت کر نہٕ نِشہِ تہٕ مُسلمان ٲسۍ حج کر نہٕ نِشہِ تا م محر و م کر نہٕ آمٕتۍ ،اَمہِ موجو ب سپُد مُسلمانن منٛز یہِ خیا ل پٲدٕ زِ یِمن کٲفر قبیلن ہٕنزٕ وَتہٕ اسلامی مقبو ضا تَو کِنۍ چھےٚ پکان،أسۍ تہِ رُکا ووکھ تِم حجِ نِشہِ تہٕ حج کِس وقتس اندر ترٛا وَو یِہندٮ۪ن قبیلن چھا پہٕ۔ مگر یہِ آیت نٲزِل کٔرِ تھ تھٲوۍ خُدا ین یِم اَمہِ خیا لہٕ نِشہِ با ز۔﴾ نَہ ! یِمہٕ کامہِ نیکی تہٕ خُدا تر سی ہٕنزٕ چھےٚ تِمن منٛز کٔرِ و سارِنٕے سٍتۍ تعاوُن تہٕ یِمہٕ کامہِ گنا ہ زیادتی ہٕنزٕ چھےٚ تِمن منٛز مَہ کٔرِ و کٲنٛسہِ سٍتۍ تعاوُن۔خُدا یس کھۅٗژِو، تٔمۍ سُند سزا چُھ سٮ۪ٹھاہ سخت۔"
  5,3,"۔تۅہیہِ پٮ۪ٹھ آو حرا م کر نہٕ مُردار، خو ن تہٕ خنز یرٕ سُند ماز،سُہ جانور یُس اللہ تعالیٰ سٕندِ ناوٕ ورٲے بیٚیہِ کٲنٛسہِ ہٕندِس ناوس پٮ۪ٹھ آسہِ ذبح کر نہٕ آمُت، سُہ یُس ۂٹۍ چیز لٔگِتھ، یا چو ٹ لٔگِتھ،تھز رٕ پٮ۪ٹھہٕ ؤسۍ پیٚتھ،یا ٹکر کھیٚتھ موٗدمُت آسہِ،یا یُس کٲنٛسہِ دٔرِند ن کھیوٚ مُت آسہِ ،تس ورٲے یُس تۅہیہِ زِ ندٕ ہ لٔبِتھ ذبح کوٚروٗن،تہٕ سُہ یُس کُنہِ اَستا نس پٮ۪ٹھ ذبح آسہِ کر نہٕ آمُت۔دراصل چُھ لفظ نُصُبوَرتاو نہٕ آمُت۔امہِ نِشہِ چُھ مُراد سٲر ی مقا مات یِم غیر اللہ ہَن نذر و نیا ز کھا لنہٕ خٲطرٕ لُکو مخصو ص آسن کٔرِ مٕتۍ ،خوا ہ تَتہِ کنہِ پۅ تُل یا ہچُو پۅ تُل ٲسِتن یا متہٕ ٲسِتن ، سانہِ زبٲنۍ منٛز چُھ اَمِیُک ہم معنی لفظ آستا ن یا اَستھا ن یُس کٲنٛسہِ بُزر گس یا دیوتا ہس، یا کُنہِ خا ص مُشر کا نہٕ اعتقادس سٍتۍ وابستہٕ آسہِ ۔یِتھس کُنہِ آستانس پٮ۪ٹھ ذبح کر نہٕ آمُت جانو ر تہِ چُھ حرا م۔﴾امہِ علا وہ چُھ یِتہِ  تُہٕندِ خٲطرٕ نا جٲیز زِ پانٛسَو سٍتۍ کٔرِ و پنُن قسمت معلو م، یِمہٕ سار ے کامہِ چھےٚ فِسق،از چھےٚ کٲفر ن تُہٕندِ دیٖن طر فہٕ پوٗرٕ ما یو سی سپٕز مٕژ۔لہٰذا مَہ کھوٚژِو توٚہۍ تِمن بلکہ کھوٚژِو مےٚ۔﴿  اَز  چُھنہٕ مُراد کانٛہہ خا ص دۅ ہ یا تٲریخ بلکہ چُھ سُہ دَور یا زمانہٕ مُراد یتھ منٛز یِم آیات نٲزِل ٲسۍ سپٕدۍ مٕتۍ۔سانہِ زبٲنۍ منٛز تہِ چُھ اَز لفظ اَز کالہٕ خٲطرٕ عام پٲٹھۍ بو لنہٕ یِوان ۔ کٲفر ن چھےٚ تُہُندِ دیٖن طر فہٕ ما یوسی سپٕز مٕژ یعنی وۅ نۍ چُھ تُہُند دین اکھ مستقل نظام بنیا مُت تہٕ خۅد چُھ پننہِ حٲکما نہٕ طا قتہٕ سان قٲیِم تہٕ نٲفذ۔کُفارچِھ امہِ اَندٕ مایو س سپٕدۍ مٕتۍ زِ تِم کیا ہیٚکن اَتھ مِٹٲوِتھ تہٕ تۅہیہِ کیا ہیکن بیٚیہِ پٔتِمس جٲہلیتس کُن واپس نِتھ۔لہٰذا مَہ کھوٚژِو توٚہۍ تِمن بلکہ کھوٚژِ و مےٚیعنی ییٚمہِ دیٖن کیٚن احکامن تہٕ ییٚمہِ کیٚن ہدا یاتن پٮ۪ٹھ عمل کر نس منٛز چُھنہٕ تُہُندِ خٲطرٕ کُنہِ کٲفر طا قتہٕ کہ غلبُک تہٕ قہرُک ،دراندٲزی تہٕ مز احمتُک خطرٕ ہ پتھ کُن روٗد مُت۔وۅ نۍ پز یو تۅہیہِ خُدا یس کھوژُن زِ تٔمۍ سٕندٮ۪ن احکامن ہٕندِس تعمیلس منٛز اگر کانٛہہ کوتٲہی تۅہیہِ کٔرٕ و تیٚلہِ آسہِ نہٕ تۅہیہِ نِشہِ کانٛہہ عذ ر ییٚمہِ کِس بنیادس پٮ۪ٹھ تۅہیہِ سٍتۍ رَژھ تہِ نر می یِیہِ وَرتا و نہٕ ۔﴾ اَز کوٚر مےٚ تُہُندِ خٲطرٕ دیٖن مکمل،تہٕ پنٕنۍ نعمت چھَم تۅہیہِ پٮ۪ٹھ تمام ﴿پوٗرٕ﴾کٔر مٕژ،تہٕ تُہندِ خٲطرٕ چُھم تُہندِ دیٖن کہ حیثیت اسلام قبول کوٚر مُت۔﴿دین مکمل کر نہٕ نِشہِ چُھ مُراد،یہِ اکھ مستقل نظامِ فکر و عمل تہٕ اکھ تِیُتھ مکمل تہذیب و تمدنُک نظام بناوُن یتھ منٛز زند گی ہٕندٮ۪ن جُملہٕ مسٲیلن ہُند جوا ب اصو لاً یا تفصیلاً موجود آسہِ ۔ تہٕ بیٚیہِ گژِھہ نہٕ ہدایت تہٕ رہنمٲیی حا صل کر نہٕ مۅ کھہٕ کُنہِ تہِ حا لس منٛز اَمہِ نِشہِ نیٚبر نیرنٕچ ضرورت پیٚنۍ۔نعمت تمام کر نہٕ نِشہِ چُھ مُراد ہدا یت کہ نعمتٕچ تکمیل ۔تہٕ دین کہ حیثیتہٕ اسلام قبول  کر نُک مطلب چُھ یہِ زِ تۅہیہِ یُس میٲنۍ اطا عت تہٕ بند گی کر نُک اقرار کوٚر مُت اوسُو ،سُہ چُھو تۅہیہِ چو نکہ پننہِ سعی تہٕ عملہِ سٍتۍ پوٚز تہٕ مخلصا نہٕ اقرار ثٲبت کوٚر مُت، اَمہِ موجو ب چُھ مےٚ اَتھ قبو لیتُک در جہ عطا کوٚر مُت تہٕ عملاً چِھمَو توٚہۍ تتھ حالتس واتنٲوِ مٕتۍ زِ وۅ نۍ روٗدنہٕ در حقیقت میانہِ ورٲے تُہنزن گردَنیٚن پٮ۪ٹھ کٲنٛسہِ ہٕندِ اطا عتُک تہٕ بند گی ہُند شَر ط با قی۔وۅ نۍ یِتھہٕ پٲٹھۍ اعتقادس منٛز توٚہۍ میٲنۍ مُسلم چِھو تِتھے پٲٹھۍ چَھو نہٕ تۅہیہِ عملی زند گی منٛز تہِ میانہِ ورٲے کٲنٛسہِ ہُند مُسلم بٔنِتھ روزنٕچ کانٛہہ مجبو ر ی لاحق روٗزمٕژ۔﴾ لہٰذا یِم قیوٗد﴿حد﴾ حرا مٕکۍ تہٕ حلا لٕکۍ تۅہیہِ پٮ۪ٹھ چِھ عٲید کر نہٕ آمٕتۍ تِہٕنز کٔرِ و پابند ی﴾۔البتہ یُس شخص بۅ چھہِ سٍتۍ مجبو ر سپدِتھ تِمَو منٛزٕ کانٛہہ چیز کھیٚیہِ اَمہِ ورٲے زِ گنا ہس کُن آسہِ تس رغبت تیٚلہِ چُھ پٔزۍ پٲٹھۍ اللہ تعالیٰ معا ف کر ن وول تہٕ رحم فر ماون وول۔﴿تشر یح خٲطرٕ وُچِھو سورۂ بقر ہ آیت۔173﴾"
  5,4,"۔لُکھ چِھ پٕرٛژھان زِ تِہِندِ خٲطرٕ کیا چُھ حلال کر نہٕ آمُت؟ ؤنیوٗکھ تُہٕندِ خٲطرٕ چِھ سٲر ی پاک چیز حلال کرنہٕ آمٕتۍ۔﴿پٕرٛژھن والیٚن ہُند مقصد اوس یہِ زِ تِمن گوٚژھ سارِنٕے حلال چیزن ہُند  تفصیل یُن وَننہٕ تا کہ یِمو ورٲے سمجھہَن تِم پرٛتھ چیز س حرام۔در جواب ووٚ ن قرآنن حرا م چیز ن ہُند تفصیل تہٕ اَمہِ پتہٕ ترٲوٕن عام ہدا یت دِتھ کتھ زِ سٲر ی پاک چیز چِھ حلال۔یِتھہٕ پٲٹھۍپھیٖر پرٲنۍ مذ ہبی﴿نظر یہِ ﴾ سو نچن ترا یہِ دُبہٕ۔ پرٲنۍ سونچن ترا ے ٲس یہِ زِ پرٛتھ کینٛہہ چُھ حرام تَمہِ ورٲے زِ یِکینژھاہ حلال یِیہِ قرار دِنہٕ۔ قرآنن کوٚر اتھ برعکس یہِ اصو ل مُقرر زِ پرٛتھ کینٛہہ چُھ حلال تَمہِ ورٲے ییٚمِچ حُر مت ﴿حرا م آسُن﴾ وَننہٕ یِیہِ ۔ حلال خٲطرٕ چُھ پاکآسنُک قٲد امہِ موجو ب آمُت لگا و نہٕ زِ نا پاک چیزن گژِھہ نہٕ حلال مُقرر کر نٕچ کو شش سپٕدنۍ۔روٗد وۅ نۍ یہِ سوال زِ چیزن ہٕندِ پاک آسنُک تعین کِتھہٕ پٲٹھۍ سپدِ، اَمِیُک جواب چُھ یہِ زِ یِم چیز شر ع کِس اصو لس منٛز کُنہِ قٲعدس ما تحت ناپاک یِن قرار دِنہٕ یا یِمو چیزو سٍتۍ ذوقِ سلیم ﴿مَن ﴾ کرا ہت کرِ یا یِم مُہذ ب اِنسانن عام پٲٹھۍ پننِس فطر ی احساس کِس نظا فتس ﴿یعنی شوٗژرس﴾ خلا ف آسن لٔبِمٕتۍ ،تِمَو ورٲے چُھ پرٛتھ کینٛہہ پاک۔﴾تہٕ یِم شکٲر ۍ جانور تۅہیہِ سِوۍ آسن کٔرِ مٕتۍ یِمن توٚہۍ اللہ تعالیٰ سٕندِس عطا کر نہٕ آمٕتِس علم کِس بُنیا دس پٮ۪ٹھ شکارٕچ تعلیم چِھو دِوان۔تِم یَس جانورس تُہُندِ خٲطرٕ رٹن سُتہِ ہیٚکیوٗن توٚہۍ کھیٚتھ، ﴿شکٲر ۍ جانور چُھ مُراد ہوٗنۍ، سٕہہ برٛور ﴿چیتا﴾ باز، شِکرٕہ ﴿ژرِسٕہہ﴾ تہٕ تما م تِم دٔرندٕ ہ تہٕ پرندٕ ہ یِمن انسان شکارٕچ خد مت چُھ ہیٚوان۔سِوۍ کر نہٕ آمتیٚن جانور ن ہٕنز خصوصیت چھےٚ یہِ  آسان زِ سُہ ییٚمۍ سُند شکار کران چُھ تس چُھنہٕ عام دٔرندن ہٕندۍ پٲٹھۍ ژٹھ کپٹھ کٔرِتھ کھیوان بلکہ چُھ پننِس مٲلکہٕ سٕندِ خٲطرٕ تس رٔٹِتھ تھاوان۔اَمی موجو ب چُھ عام دٔرندن ہُند ژٹھ کپٹھ کوٚرمُت جانور حرا م تہٕ سِوۍ کر نہٕ آمتیٚن جانور ن ہُند شکا ر حلال۔﴾ البتہٕ اتھ پٮ۪ٹھ ہے زیٚو اللہ تعالیٰ سُند ناو۔﴿یعنی شکٲرۍ جانور ییٚلہِ شکارٕ با پت یلہٕ ترٲوِیو ن تَمہِ وِزِ ؤنۍ زِیو بِسمِ اللہ۔اَمہِ آیت نِشہِ سپُد یہِ مسلہٕ معلو م زِ شکٲرۍ جانور شکارس پتہٕ ترٛ او نہٕ وِزِ چُھ اللہ تعالیٰ سُند ناو ہیوٚ ن ضرور ی۔امہِ پتہٕ ہرگاہ شکار زِ ند ے حٲصل سپدِ تیٚلہِ گژِھہ اللہ تعالیٰ سُند ناو ہیٚتھ سُہ ذبح کرُن تہٕ ہرگاہ زند ہ میوٗل نہٕ تیٚلہِ آسہِ سُہ اَمہِ ورٲیی حلال تِکیازِشکٲرۍ جانور یلہٕ تراو نہٕ وقتے اوس اللہ تعالیٰ سُند ناو ہیٚنہٕ آمُت،یۅہے حُکم چُھ تیر چلا و نُک تہِ ۔﴾ تہٕ اللہ تعالیٰ سُند قا نون پھُٹرا ونس کھوٚژِو، خُدا یس چَھںہٕ حسا ب ہیٚنس تٲر لگا ن۔"
  5,5,"۔اَز چِھ تُہندِ خٲطرٕ سٲر ی پاک چیز حلال کر نہٕ آمٕتۍ اہلِ کتا بن ہُند کھیٚن چُھ تُہُندِ خٲطرٕ حلال تہٕ تُہُند کھیٚن چُھ تِہندِ خٲطرٕ حلال۔﴿اہلِ کتابن ہٕندِس کھیٚنس منٛز چُھ تِہُند ذبح کر نہٕ آمُت جانور تہِ حلال۔سانہِ خٲطرٕ تِہُند تہٕ تِہندِ خٲطرٕ سو ن کھیٚن حلال آسنُک مطلب چُھ یہِ زِ اَسہِ تہٕ تِمن در میان چَھنہٕ کانٛہہ رُکاوٹ یا چھوٗت چھات۔أسۍ ہیٚکو تِمن سٍتۍ کھیٚتھ تہٕ تِم ہیٚکن اَسہِ سٍتۍ۔مگر یہِ عام اجازت دِنہٕ برونٛہہ چُھ امہِ کتھہِ ہُند اعادٕ ہ کر نہٕ آمُت زِ  تُہندِ خٲطرٕ چِھ پاک چیز حلال کر نہٕ آمٕتۍ۔اَمہِ نِشہِ سپُد معلو م زِ ہرگاہ اہلِ کتاب پاکی تہٕ طہارت کیٚن قا نو نن ہٕنز پابند ی کر ن نہٕ یِم شر یعت کہ نقط نظرٕ کِنۍ ضرور ی چِھ ، یا ہرگاہ تِہِندِس کھیٚنس منٛز حرام چیز شٲمِل آسن تیٚلہِ گژِھہ تمہِ نِشہِ پر ہیز کرُن ۔ مثلاً اگر تِم اللہ تعالیٰ سُند ناو ہیٚنہٕ ورٲے کانٛہہ جانور ذبح کر ن یا تس ذبح کر نہٕ وِزِ ہیٚن اللہ تعالیٰ سٕندِ ناوٕ ورٲے بیٚیہِ کٲنٛسہِ ہُند ناو تیٚلہِ چُھنہٕ سُہ سانہِ خٲطرٕ کِھیوٚ ن جٲیز۔﴾تہٕ محفو ظ مستوراتہٕ تہِ چھےٚ تُہٕندِ خٲطرٕ حلال خوا ہ تِمہٕ اہلِ ایمانن ہٕندِ دَرِچہِ آسن،یا آسن تِمو قو مو منٛزٕ یِمن تۅہیہِ برونٛہہ کتاب ٲس دِنہٕ آمٕژ۔﴿امہِ نِشہِ چِھ مُراد یہوٗدۍ تہٕ نصاریٰ۔نِکا حُک اجا زت چُھ صرف یِہٕنز نٕے یاژن مستوراتن سٍتۍ دِنہٕ آمُت تہٕ اتھ سٍتۍ چُھ یہِ شر ط تھاو نہٕ آمُت زِ تِم گژھنمُحصنات ﴿محفوظ مستوراتہٕ﴾ آسنہِ یعنی آوارٕہ گژھن نہٕ آسٕنہِ۔تہٕ امہِ پتہٕ کِس آیتس منٛز چُھ یہِ تنبیہ تہِ کر نہٕ آمُت زِ یہوٗد ۍ  یا عیسٲے خاندارِ نہِ خٲطرٕ یِنہٕ ایمان راورِو۔﴾ بشر طیکہ توٚہۍ بٔنِو تِہندۍ مَہر دِتھ نکا حس منٛز تِہندۍمحٲفظ ،نَہ یہِ زِ آزا د شہوت رٲنی لٲگِو کرٕنۍ یا کٔرِو ژوٗرِ ژھیپہِ ٲشنٲیی، تہٕ ییٚمۍ کٲنٛسہِ أکۍ ایمان چہِ رٔوِشہِ پٮ۪ٹھ پکنس انکار کوٚر تیٚلہِ گژِھہ تٔمۍ سٕنزِ زند گی ہُند  سورُے کار نامہٕ ضا یع تہٕ ٲخرتس منٛز آسہِ سُہ خسارٕہ لد۔ع"
  5,6,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ییٚلہِ توٚہۍ نمازِ خٲطرٕ ووٚتھِو تیٚلہِ پز یٚو توٚہۍ چھٔلِو پنٕنۍ بُتھۍ تہٕ اَتھہٕ کھۅ نوٹن تام، کلن کٔرِ و مسح تہٕ کھۅر چھٔلِو ژٕ ننیٚن تام ۔﴿نبی صلی اللہ علیہ وسلمو یۅسہٕ تشر یح امہِ حُکمٕچ فر مٲو مٕژ چھےٚ تمہِ نِشہِ چُھ پے لگا ن زِ بُتھ چھلنس منٛز چُھ کۅ لکٔژ کرٕنۍ تہٕ نس صا ف کرٕنۍ تہِ شٲمل۔اَمہِ  ورٲے چَھنہٕ بُتھ چھلنٕچ تکمیل سپدان۔تہٕ کن چِھ چو نکہ کلُک اکھ حصہ،لہٰذا چُھ کلہٕ کِس مسح ہس منٛز کنن أندرٕ نیبرٕ مسح کرُن تہِ شٲمل۔امہِ علا وہ گژھن وضو شروع کر نہٕ برونٛہہ دۅ شو ے اَتھہٕ چھلٕنۍ تاکہ یِمو اَتھو سٍتۍ انسان وضو کران آسہِ تِم گژھن گۅڈ ے پاک سپٕدنۍ۔﴾ ہرگاہ جنا بت کِس حالتس منٛز ٲسِو تیٚلہِ سپدِو غسل کٔرِتھ پاک، ہرگاہ بیمار ٲسِو یا سفرٕ کِس حالتس منٛز ٲسِو یا یِیہِ تۅہیہِ منٛزٕ کانٛہہ شخص پنُن حا جت ﴿لۅکُٹ بوٚڈ پیشاب﴾ دوٗر کٔرِتھ یا تۅہیہِ آسہِ مستوراتن اتھہٕ لو گمُت تہٕ پتہٕ میلہِ نہٕ آب تیٚلہِ ہیٚیِو پاک میٚژِ کٲم ،بس ُپھِر وِ وپنٕنۍ اتھہٕ تتھ پٮ۪ٹھ ترٲوِتھ پننِس بُتھِس تہٕ اَتھو پیٚٹھۍ۔﴿تشر یح خٲطرٕ وُچِھو سورۂ نسا آیت نمبر ،43﴾ اللہ تعالیٰ چُھنہٕ تۅہیہِ پٮ۪ٹھ زند گی تنگ یژھان کرُن مگر سُہ چُھ یژھان تۅہیہِ پاک کرُن تہٕ تۅہیہِ پٮ۪ٹھ پنٕنۍ نعمت پوٗرٕ کرٕنۍ شاید زِ توٚہۍ بٔنِو شُکر گُزار۔"
  5,7,"۔ خُدا ین یۅسہٕ نعمت تۅہیہِ عطا چھےٚ کٔر مٕژ تمیُک تھٲوِو خیا ل،تہٕ سُہ پختہٕ عہد و پیمان مَہ مٔشرٲوِو یُس تٔمۍ تۅہیہِ چُھنَو ہیوٚتمُت،یعنی تُہُند یہِ قو ل زِ : اسہِ بوٗز تہٕ اطا عت کٔر قبول۔خُدا یس کھوٗژِو،اللہ تعالیٰ چُھ دِلن ہٕنٛدۍ راز تام زانان۔"
  5,8,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت اللہ تعالیٰ سٕندِ خٲطرٕ بٔنِو سیزرَس پٮ۪ٹھ قٲیِم روزن وٲلۍ تہٕ انصا فٕچ گوٲہی دِنہٕ وٲلۍ،کُنہِ دَرِچ دشمنی یِنہٕ تۅہیہِ تیوٗت مشتعل کر یو زِ انصا ف نِشہِ پھیٖرِ و ،عد ل کٔرِو ،یہِ چُھ خُدا تر سی سٍتۍ زیادہ واٹھ تھاوان،خُدا یس کھوٗژِتھ روٗزِ و کٲم کران، یِکینژھاہ توٚہۍ کران چِھو،اللہ تعالیٰ چُھ تمہِ نِشہِ پوٗرٕ با خبر ۔"
  5,9,"۔یِم لُکھ ایمان اَنن تہٕ بیٚیہِ کر ن  نیک عملہٕ ،خُدا ین چُھ تِمن وعدہ کوٚر مُت زِ تِہندٮ۪ن خطاہن یِیہِ در گُز ر کر نہٕ تہٕ تِمن میلہِ بوٚڈ اجر ۔"
  5,10,"۔روٗدۍ تِم لُکھ یِم کُفر کر ن  تہٕ اللہ تعالیٰ سٕندٮ۪ن آیاتن زانن اَپز ۍ تیٚلہِ چِھ تِم جہنمس گژھن وٲلۍ۔"
  5,11,"۔ اے لوٗکو یِمو ایمان چُھو اوٚ نمُت اللہ تعالیٰ سُند سُہ احسان کٔرِو یاد یُس تٔمۍ ﴿حا ل حا لےٕ﴾ تۅہیہِ پٮ۪ٹھ  کوٚر مُت چُھ،  ییٚلہِ زن أکۍ دٔرۍ تۅہیہِ پٮ۪ٹھ دست درٲزی ہُند ارادٕہ اوس کوٚر مُت ۔مگر خُدا ین رُکٲوۍ تِہِندۍ اَتھہٕ تۅہیہِ پٮ۪ٹھ وۅ تھنہٕ نِشہِ ، ﴿اشارہ چُھ تتھ وا قعس کُن یُس حضرت عبد اللہ بن عبا س رضی اللہ عنہ چِھ روا یت کران زِ یہوٗد یو منٛزٕ  ٲسۍ أکۍ دٔرۍ حضور صلی اللہ علیہ وسلم تہٕ تِہِندۍ خا ص خا ص صحا بہٕ رضی اللہ عنہم دعوتس پٮ۪ٹھ بُلٲوِمٕتۍ تہٕ خفیہ طور ٲسٕکھ یہِ سٲزِش کٔر مٕژ زِ اچا نک کر و تِمن پٮ۪ٹھ حملہٕ تہٕ یِتھہٕ پٲٹھۍ کڑَو اسلامس ﴿نعوذ با للہ﴾ زُو۔البتہٕ عینِ وقتس پٮ۪ٹھ سپُد نبی صلی اللہ علیہ وسلمن امہِ سٲزشہِ ہُند حال معلو م تہٕ تِمو نیوٗ نہٕ پتہٕ دعوتس پٮ۪ٹھ تشر یف۔﴾ خُدا یس کھوٚژِتھ روٗزِ وکٲم کران،با ایمانن پزِ خُدا ے سٕے پٮ۪ٹھ بھر وسہٕ کرُن۔ع"
  5,12,"۔ خُدا ین اوس بنی اسرا یلس پختہٕ عہد ہیوٚتمُت،تہٕ تِمن منٛز ٲسِن باہ  نقیب مُقرر کٔرِمٕتۍ۔﴿نقیب گوٚو نگرٲنی تہٕ پٕرٛژھ گٲر کر ن وول۔بنی اسرا یلس ٲسۍ باہ قبیلہٕ تہٕ خُدا ین اوس یِمو منٛزٕ پرٛتھ قبیلہٕ خٲطرٕ اکھ اکھ نقیب خۅد یِموٕ ے قبیلو منٛزٕ مقرر کر نُک حکم دِیتمُت تا کہ سُہ تھا و ِ ہے تِہندٮ۪ن حالاتن پٮ۪ٹھ نظر تہٕ تِمن روزِ ے بے دینی تہٕ بد اخلٲقی نِشہِ بچا ونٕچ کوٗشش کران﴾ تہٕ تِمن اوس ووٚ نمُت زِ  بہٕ چُھس تۅہیہِ سٍتۍ ، ہرگاہ تۅہیہِ نماز قٲیِم تھٲوٕ و تہٕ زکوٰتہ دِژٕ و، تہٕ میٲنۍ رسول مٲنِیوٗکھ تہٕ تِمن کوٚر ومدد تہٕ پننِس خُدایس روٗدِ و رُت قر ض دِوان ، تیٚلہِ تھٲوِ و پژھ زِ بہٕ کرٕ تُہٕنزٕ بُرٲیِیہِ تۅہیہِ نِشہِ دوٗر ،تہٕ تۅہۍ کر و تِتھیٚن با غن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان،مگر اَمہِ پتہٕ ییٚمۍ تۅہیہِ منٛزٕ کفرٕچ رٔوِش اختیار کٔر،تیٚلہِ راورٲوتٔمۍ در حقیقت سو ا  ٔلسبیل۔ ﴿سوا  ٔلسبیل چِھ تتھ بجہِ وَتہِ ونا ن یۅسہٕ باقا عدہ منٛزِ ل مقصود س تام واتنہٕ خٲطرٕ بنا و نہٕ آسہِ آمٕژ، سو ا  ٔلسبیل راوَرنُک مطلب چُھ یہِ زِ اِنسا ن وَسہِ بجہِ وَتہِ پٮ۪ٹھہٕ تہٕ راوِ بیرَو پیٚٹھۍ﴾"
  5,13,"۔پتہٕ اوس یہِ تِہُند پنُن عہد پھُٹراوُن ییٚمہِ کِنۍ اسہِ تِم پننہِ رحمت نِشہِ دوٗر چھٔکۍ، تہٕ تِہندۍ دِل  بنٲوۍ سخت،وۅ نۍ چُھ تِہُند حال یہِ زِ لفظن ہیرٕ پھیرٕ کٔرِ تھ چِھ کتھہِ واتناوان کتہِ پٮ۪ٹھہٕ کور ،یۅسہٕ تعلیم تِمن دِنہٕ ٲس آمٕژ تمِیُک بوٚڈ حصہٕ چُھکھ مٔشر وومُت، تہٕ دۅ ہ کھۅتہٕ دۅ ہ چُھ تۅہیہِ تِہندِ کُنہِ نَتہٕ کُنہِ خیا نتُک پے لگا ن روزان،تِمو منٛزٕ چِھ سٮ۪ٹھاہ کم لُکھ اَمہِ عیبہٕ نِشہِ  بٔچِتھ۔﴿وۅ نۍ ہرگاہ یِم اتھ حالس چِھ وٲتِمٕتۍ تیٚلہِ یِم تہِ بُرٕ حر کتہٕ یِم کر ن تِمن ہُند چُھ یِمن نِشہِ تو قع﴾ لہٰذا کٔرِو یِمن معا ف تہٕ یِہنز و حر کتو نِشہِ روٗزِ و چشم پوشی کر ان، اللہ تعالیٰ چُھ تِمن لُکن پسند کران یِم احسا نٕچ رٔوِش تھاوان چِھ ۔"
  5,14,"۔یِتھے پٲٹھۍ اوس اسہِ تِمن لُکن تہِ پختہٕ عہد ہیٚوتمُت یِمو ووٚنمُت اوس زِ أسۍ چِھ نصا ریٰ  مگر تِمن تہِ یُس سبق یاد اوس کر نا و نہٕ آمُت تمِیُک بوٚڈ اکھ حصہٕ کوٚر تِمو فر ا موش، ٲخر کار ووٚ و اَسہِ تِمن در میان قیا متس تام دشمنی تہٕ اکھ أکۍ سٕندِ  بغُضُک تہٕ عدا وتُک بِیو ل تہٕ ضرور واتہِ اکھ وقت ییٚلہِ اللہ تعالیٰ تِمن وَنہِ زِ  تِم کیا چِھ روٗدِمٕتۍ دُنیا ہس منٛز بناوان۔"
  5,15,"۔اے اہلِ کتاب سو ن رسول  چھُ تۅہیہِ نِشہِ آمُت یُس اللہ تعالیٰ سٕنزِ کتا بہِ ہٕنز ن واریاہن تِمن کتھن تۅہیہِ برونٛہہ کنہِ مٕژراوان چُھ، یِمن پٮ۪ٹھ توٚہۍ پردٕہ ٲسِو ترٛاوان تہٕ واریاہَو کتھو نِشہِ چُھ در گُز ر تہِ کران، ﴿یعنی تُہٕنزٕ کینٛہہ ژوٗرٕ تہٕ خیا نتہٕ چُھ مٕژراوان یُہُند مٕژ رُن دینِ حق قٲیِم کر نہٕ خٲطرٕ  سٮ۪ٹھاہ ضرور ی چُھ ۔ تہٕ کینٛژھو نِشہِ  چُھ چشم پوشی تہِ کران یِمن ہٕندِ مٕژراونٕچ کانٛہہ حقیقی ضرورت چَھنہٕ ﴾ تۅہیہِ نِشہِ چُھ اللہ تعالیٰ سٕندِ طر فہٕ گا ش ووتمُت تہٕ اکھ تِژھہ حق ہاون واجِنۍ کتا ب"
  5,16,"۔ییٚمہِ سٍتۍ اللہ تعالیٰ چُھ تِمن لُکن یِم تٔمۍ سٕندِ رضا ہٕکۍ طٲلِب چِھ سلامتی ہٕندۍ طریقہٕ وَنان تہٕ پننہِ اِذ نہٕ سٍتۍ چُھ تِمن اَنہِ گٹو منٛزٕ کٔڑِتھ گا شس کُن اَنان  تہٕ سیٚزِ وَتہِ کُن چُھ تِمن رہنمٲیی کران۔"
  5,17,"۔پٔزۍ  پٲٹھۍ کوٚر کُفر تِمو لُکو یِمو ووٚ ن زِ ، مسیح ابنِ مر یمٕے  چُھ خُدا ے،اے نبی صلی اللہ علیہ وسلم یِمن ؤنِو کٔمۍ سٕنز مجا ل چھےٚ زِ خُدا یس رٹن امہِ ارادٕہ نِشہِ پتھ زِ ، ہرگاہ سُہ ییژِھہ ہلاک کرُن مسیح ابنِ مر یمس ییٚیہِ تٔمۍ سٕنزِ ماجہِ ، تہٕ تمام زمین والیٚن ،اللہ تعالیٰ چُھ زمین تہٕ آسمانن ہُند تہٕ تِمن سارِنٕے چیز ن ہُند مٲلک یِم زمین و آسما نس در میان چِھ ، یِکینژھاہ یژھان چُھ پٲدٕ چُھ کران۔﴿یعنی محض بنو ووٗن تۅہیہِ مسیح علیہ السلام مٲلۍ سٕندِ ورٲے زیٚنہٕ کِنۍ خُدا ے حالانکہ خُدا ے یس یِتھہٕ پٲٹھۍ یژھان چُھ تس چُھ تِتھہٕ پٲٹھۍ پٲدٕ کران۔ کانٛہہ بند ہ چُھنہٕ اتھ بُنیا دس پٮ۪ٹھ  خداے بنان زِخُدا ین چُھ سُہ غیر معمو لی طور پٲدٕ کوٚر مُت ۔﴾ تہٕ تٔمۍ سٕنز قدرت چھےٚ پرٛتھ چیز س پٮ۪ٹھ حٲوی۔"
  5,18,"۔یہو د تہٕ نصا ر یٰ چِھ ونا ن زِ أسۍ چِھ اللہ تعالیٰ سٕندۍ نچِو ۍ تہٕ تٔمۍ سٕندۍ ٹٲٹھۍ ،تِمن پرٛژِھو ، تیٚلہِ کیا زِ چُھو سُہ تۅ ہیہِ تُہٕندٮ۪ن گنا ہن پٮ۪ٹھ سزا دِوان ؟ در حقیقت چِھو توٚہۍ تہِ تِتھی انسان یِتھۍ با قی انسان خُدا ین چِھ پٲدٕ کٔرِ مٕتۍ، یس سُہ یژھان چُھ تس چھُ معا ف کران تہٕ یس سُہ یژھان چُھ تس چُھ سزا دِوان، زمین تہٕ آسمان تہٕ اتھہ منٛز  یِکینژھاہ موجو د چُھ ،چھُ تٔمۍ سُندُے، تہٕ تٔسۍ کُن چُھ سارِنٕے گژُھن۔"
  5,19,"۔اے اہلِ کتا ب ، سو ن یہِ رسول صلی اللہ علیہ وسلم چُھ تمہِ  وقتہٕ تۅہیہِ نِشہِ آمُت تہٕ دینٕچ وا ضح تعلیم چُھ تۅہیہِ دِوان ، ییٚلہِ زن رسولن ہٕندِ یِنُک سلسلہٕ اکہِ مُدّت پٮ۪ٹھہٕ بند اوس، تا کہ توٚہۍ ہیٚکوِ نہٕ ؤنِتھ زِ اَسہِ نِشہِ آو نہٕ کا نٛہہ بشار ت دِنہٕ وول تہٕ کھۅژناون وول، لہٰذا وُچِھو ، وۅ نۍ آو سُہ بشارت دِنہٕ وول تہٕ کھۅژنان وول، تہٕ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔ع﴿ یعنی اگر تۅہیہِ أمِس بشیر و نذیر سٕنز کتھ مٲنِو نہٕ تیٚلہِ تھٲوِ و یاد زِ اللہ تعالیٰ چُھ قادر تہٕ طا قتہٕ وول ،پرٛتھ کانٛہہ سزا یُس سُہ تۅہیہِ دِیُن ییٚژِھہ ، کُنہِ رکا وٹہٕ ورٲے ہیٚکِیو دِتھ۔﴾"
  5,20,"۔یاد کٔرِو ییٚلہِ موسیٰ ﴿علیہ السلامن﴾ پننِس قو مس اوس ووٚنمُت زِ : اے میانہِ قو م کیو لوٗکو،اللہ تعالیٰ سٕندِ تمہِ نعمتُک خیا ل کٔرِو یۅسہٕ تٔمۍ تۅہیہِ عطا ٲسنو کٔر مٕژ، تٔمۍ کٔرۍ تۅہیہِ منٛزٕ نبی پٲدٕ، توٚہۍ  بنٲوِ نو فر مان روا ﴿بادشاہ﴾، تہٕ تۅہیہِ دِیتُنو تِکینژھاہ یہِ نہٕ دُنیا ہس منٛز بیٚیہِ کٲنسہِ اوسُن دِیتمُت۔"
  5,21,"۔اے برادرانِ قو م، تَتھ مُقدس سرزمینس منٛز سپدِ و دٲخل ،یۅسہٕ خُدا ین تُہٕندِ خٲطرٕ چھےٚ لیٚچھ مٕژ، ﴿امہِ نِشہِ چُھ مُراد فلسطینٕچ سر زمین یۅ سہٕ تمہِ وقتہٕ سخت مُشر ک تہٕ بد کار قو مو سٍتۍ آباد ٲس۔بنی اسرا یل ییٚلہِ مِصرٕ منٛزٕ درٛا ے یٔہے زمین کٔر اللہ تعالیٰ ہن تِہِندِ خٲطرٕ نا مزد تہٕ  حکم کوٚرنکھ زِ گژِھو کٔرِیوٗن یہِ فتح۔﴾ پتھ مَہ ۂٹِو نَتہٕ پھِیرِ و نا کام تہٕ نا مراد۔"
  5,22,"۔تِمو دِیُت جواب : اے مو سیٰ علیہ السلام،تَتہِ ہے بٔڑۍ زبردست لُکھ چِھ روزان،أسۍ گژھو نہٕ ہر گز یوٚت تام نَہ تِم تَتہِ  نیر ن، آ، ہرگاہ تِم تَتہِ درٛاے تیٚلہِ چِھ أسۍ توراَژنہٕ خٲطرٕ تیار۔"
  5,23,"۔تِمن کھۅژن والیٚن منٛز ٲسۍ زٕہ شخص تِتھۍ تہِ یِم خُدا ین پننہِ نعمت سٍتۍ نوٲزِمٕتۍ ٲسۍ۔﴿یِمو دۅ یو بُزر گو منٛزٕ ٲسۍ اکھ بز ر گ حضرت یُو شَع بِن نو ن یِم حضرت موسیٰ علیہ السلام سٕندِ پتہٕ خلیفہٕ سپٕدۍ ۔دوٚیِم بزر گ ٲسۍ حضرت کالِب یِم حضرتِ نُو شع سٕندۍ مُعا و ن بنے۔ژتجہن ؤرِین تام در بدر پھیر نہٕ پتہٕ ییٚلہِ بنی اسرا یل فلسطینس منٛز ژاے تمہِ ساعتہٕ ٲسۍ حضرتِ موسیٰ علیہ السلام سٕندیو سٲتھیو منٛزٕ یِمے زٕہ بُزر گ زندٕہ﴾ تِمو ووٚن:تِمن جبا ر ن ﴿طا قت والیٚن ﴾ ہٕندِ مُقا بلہٕ خٲطرٕ أژِو دروازہ اندر،ییٚلہِ توٚہۍ اندر وٲتِو تیٚلہِ روٗزِو توٚہی غٲلب،خُدا یس پٮ۪ٹھ کٔرِو بھر وسہٕ اگر توٚہۍ مو من چِھو۔"
  5,24,"۔مگر تِمو ووٚن بیٚیہِ یی زِ : اے موسیٰ ، أسۍ گژھوے نہٕ زٕ ہٕنۍ تور یوٚت تام تِم  تَتہِ چِھ ،بس ژٕ تہٕ چو ن ربّ ،دۅ شو ے گٔژِھو تہٕ لٔڑِو،أسۍ بیٚہمو ییٚتی۔"
  5,25,"۔اتھ پٮ۪ٹھ ووٚن موسیٰ ﴿علیہ السلامن﴾: اے میانہِ ربّہٕ ، میٲنِس اختیارس منٛز چُھنہٕ کانٛہہ مگر یا چُھم پنُن پان یا چُھم بو ے، بس ژٕ کر اسہِ یِمن نا فر ما ن لُکن نِشہِ الگ ۔"
  5,26,"۔خُدا ین دِیتُنس جوا ب : اچھا تیٚلہِ چُھ سُہ مُلک ژتجہن ؤرِین تام یِمن پٮ۪ٹھ حرام۔یِم پھیرن ہٹرِ ہٹرِ زمینس پٮ۪ٹھ،یِمن نا فر مانن ہٕندِس حالس پٮ۪ٹھ مَہ یِیہِ نے عار۔ع ﴿یتھ جایہِ چُھ امہِ وا قعُک حوالہٕ دِنُک مقصد دراصل بنی اسرا یلن یہِ ہاوُن زِ یُس سزا موسیٰ علیہ السلام سٕندِ س زمانس منٛز تۅہیہِ نا فر مٲنی ، انحرا ف تہٕ پست ہمتی کٲم ہیٚتھ میوٗلمُت اوسُو،وۅ نۍ میلیو تمہِ کھۅتہٕ زیادہ سخت سزا محمد صلی اللہ وسلمن ہٕندِس مقا بلس منٛز بغا وتُک طر یقہٕ اختیار کٔرِتھ۔﴾"
  5,27,"۔بیٚیہِ ؤنۍ تو یِمن آد م  علیہ السلام سٕندٮ۪ن دۅ ن نیچو ٮ۪ن ہُند سورُے قصہٕ تہِ ،ییٚلہِ تِمو دۅ شوٕ یو قربٲنی کٔر، تہٕ تِمو منٛزٕ آیہِ أکۍ سٕنز قر بٲنی قبول کر نہٕ، تہٕ دوٚیِمہِ سٕنز آیہِ نہٕ کر نہٕ، تٔمۍ ووٚن : بہٕ مار تھ ژٕ۔ تٔمۍ دِیُت جوا ب : اللہ تعالیٰ چُھ مُتقین ہٕنز ے نذرٕ قبول کران۔"
  5,28,"۔اگر ژٕمےٚ قتل کر نہٕ مۅکھہٕ اتھہٕ تُلکھ بہٕ تُلنہٕ ژٕ قتل کر نہٕ مۅکھہٕ اتھہٕ، ﴿امِیُک مطلب چُھنہٕ یہِ زِ اگر ژٕ مےٚ یِکھ قتل کر نہِ تہٕ بہٕ روزٕ گُلۍ گٔنڈِتھ ژےٚ برونٹھہٕ کنہِ قتل گژھنہٕ خٲطرٕ،بلکہ چُھ امیُک مطلب یہِ زِ اگر ژٕ مےٚ مارُن چُھکھ یژھان مگر بہٕ مارتھ نہٕ کینٛہہ﴾ بہٕ چُھس اللہ ربّ العا لمینس کھۅژان۔"
  5,29,"۔بہٕ چُھس یژھان زِ میو ن تہٕ پنُن گنا ہ کھٔسِن ژیے پٮ۪ٹھ۔تہٕ ژٕ بن جہنمی۔ظٲلِمن ہٕندِ ظُلمُک چُھ یۅہے بد لہٕ ٹھیک۔"
  5,30,"۔ ٲخر کار کوٚر تٔمۍ سٕندۍ نفسن پننِس بٲے سُند قتل تٔمۍ سٕندِ خٲطرٕ آسان،تہٕ تس مٲرِتھ گوٚو سُہ تِمن لُکن منٛز شٲمِل یِم نقصان تُلن وٲلۍ چِھ۔"
  5,31,"۔پتہٕ سوٗز خُدا ین اکھ کاو ییٚمۍ زمین تچھِنۍ لٲج،تا کہ تس تارِ ہے فِکرِ زِ پننِس بٲے سٕنز لا ش کِتھہٕ پٲٹھۍ تھاوِ ژوٗرِ،یہِ وُچِھتھ ووٚ ن تٔمۍ : افسو س مےٚ پٮ۪ٹھ!۔بہٕ ہیوٗکُس نہٕ أمِس کاو س ہیوٗ تہِ بٔنِتھ زِ پننِس بٲے سٕنز لاش چُھپاو نٕچ تدبیر کڑٕ ہا ۔اَمہِ پتہٕ گوٚو سُہ سخت پشیمان پننِس کٔرِ مٕتِس پٮ۪ٹھ۔﴿یتھ جایہِ چُھ اَمہِ وا قعٕچ ذکر کر نُک مقصد یہوٗدٮ۪ن تَتھ سٲزِ شہِ پٮ۪ٹھ ملامت کرٕنۍ یۅسہٕ تِمو نبی صلی اللہ علیہ وسلم تہٕ تِہِندۍ جلیل القدر صحا بہٕ رضی اللہ عنہم قتل کر نہٕ خٲطرٕ کٔر مٕژ ٲس۔دۅ شوٕ نۍ وا قعا تن منٛز چُھ ہِشر بالکل وا ضح ۔یِم لُکھ  تہِ ٲسۍ حسدٕ کِس بُنیا دس پٮ۪ٹھ حضور صلی اللہ علیہ وسلمن ہُند قتل کرُن یژھان تہٕ آدم علیہ السلامن ہٕندۍ أمۍ نچِوۍ تہِ اوس حسدٕ کِس بُنیا دس پٮ۪ٹھ پنُن بو ے قتل کوٚر مُت۔﴾"
  5,32,"۔اَمی وجہ کِنۍ اوس بنی اسرا یلس پٮ۪ٹھ اسہِ یہِ فر مان لیوٚکھمُت زِ ییٚمۍ کانٛہہ اِنسان خو ن کِس بد لس منٛز یا زمینس پٮ۪ٹھ فساد پھٔہلا و نہٕ ورٲے بیٚیہِ کُنہِ  وجہ کِنۍ قتل کوٚر،تٔمۍ کوٚر زنتہٕ تمام انسانن ہُند قتل۔تہٕ ییٚمۍ کٲنٛسہِ زند گی بخش،تٔمۍ بخش زَنتہٕ سارِنٕے انسانن زند گی۔ تِہُند حال چُھ یہِ زِ سٲنۍ رسول آے پوٚتُس پتھ تِمن نِشہِ ٹاکارٕ ہدا یات ہیٚتھ، تو تہِ چِھ تِمن منٛز واریاہ لُکھ زمینس منٛز زیادتی کر ن وٲلۍ۔"
  5,33,"۔یۅہے سزا چُھ ﴿تِمن ﴾ یِم لُکھ خُدا یس تہٕ تٔمۍ سٕندٮ۪ن رسولن سٍتۍ لڑان چِھ تہٕ زمینس منٛز چِھ امہِ غر ضہٕ تگ دَو کران پھیران زِ فساد کر ہن بر پا،﴿یتھ جایہِ چُھ زمین مُراد سُہ مُلک یا سُہ علا قہٕ یتھ منٛز اَمن تہٕ انتظام  قٲیِم کر نٕچ ذمہٕ دٲر ی اسلٲمی حکو متن آسہِ رٔٹمٕژ۔ تہٕ خُدا یس تہٕ رسولس سٍتۍ لڑ نُک مطلب چُھ تَتھ صا لح نِظا مَس خلا ف جنگ کرُن یُس اسلامی   حکو متن مُلکس منٛز قٲیِم آسہِ کوٚر مُت ۔ اسلامی فقہا ہن نزدیک چِھ امہِ نِشہِ مُراد تِم لُکھ یِم ہتھیار بند ﴿مُسلح﴾ سپدِتھ تہٕ ٹو لہٕ بند ی کٔرِ تھ ڈاکہٕ زنی تہٕ غارت گر ی کر ن﴾ زِ قتل گژھن یِنۍ کر نہٕ، یا گژھن جِلا یہِ وطن کر نہٕ یِنۍ،یہِ ذلت تہٕ رسوٲیی چھےٚ دُنیا ہس منٛز تِمن خٲطرٕ،تہٕ ٲخرتس منٛز چُھ تِہندِ خٲطرٕ امہِ کھۅتہٕ بوٚڈ سزا۔"
  5,34,"۔مگر یِم لُکھ تو بہٕ کر ن،اَمہِ برونٛہہ زِ توٚہۍ لٔبِو تِمن پٮ۪ٹھ قا بو،تۅہیہِ گژھیو پے آسٕنۍ زِ اللہ تعالیٰ چُھ معا ف کر ن وول تہٕ رحم فر ماو ن  وول۔ع ﴿یعنی ہرگاہ تِم فساد کر نہٕ نِشہِ با ز آسن آمٕتۍ، تہٕ صا لح نظا م در ہم بر ہم کر نٕچ یا اُلٹا ونٕچ کوٗشش آسیکھ ترٛٲومٕژ،تہٕ وۅ نۍ آسہِ تِہُند طر زِ عمل ثٲبت کران زِ تِم چِھ امن پسند ،قا نو نٕکۍ تٲبعدار تہٕ نیک چلن انسان بنیمٕتۍ ، تہٕ اَمہِ پتہٕ لگہِ تِہندٮ۪ن پٔتِمیٚن جُر من ہُند پے تیٚلہِ یِیہِ نہٕ تِمن تِمو سزا ہَو منٛزٕ کانٛہہ سزا دِنہٕ یِم پٮ۪ٹھہٕ کنہِ بیان سپٕدۍ ، البتہٕ اگر انسانن ہٕندٮ۪ن حقو قن پٮ۪ٹھ تِمو دست درٲزی کٔر مٕژ ٲس سۅ ذمہٕ دٲر ی وَسہِ نہٕ تِہند یو شا نو پٮ۪ٹھہٕ۔ مثلاً ہرگاہ کانٛہہ انسان تِمو قتل کوٚر مُت اوس یا کٲنٛسہِ اوسُکھ مال روٚٹمُت یا بیٚیہِ کانٛہہ انسٲنی جُر م آسیکھ جان و ما لس خلا ف کوٚر مُت تیٚلہِ یِیہِ تٔتھۍ جُر م کِس با رس منٛز تِمن فوجدٲر ی مُقدر مہٕ کر نہٕ البتہٕ تِمن پٮ۪ٹھ یِیہِ نہٕ بغا وتُک ، غدٲر ی ہُند تہٕ خُدا یس تہٕ رسولس خلا ف جنگ کِس معا ملس پٮ۪ٹھ کانٛہہ مُقد مہٕ چلا و نہٕ۔﴾"
  5,35,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ،خُدا یس کھوٚژِو، تہٕ تٔمۍ سٕنزِ با ر گاہ منٛز کٔرِ و تٔمۍ سٕنزِ نزد یکی ہُند ذر یعہ تلا ش،﴿یعنی پرٛتھ تمہِ ذٔرِیِکۍ روٗزِ و طٲلب تہٕ ژھانڈ ن وٲلۍ ییٚمہِ سٍتۍ تۅہیہِ تٔمۍ سٕنز نزدیکی تہٕ رضا حا صل سپدِ ۔﴾تہٕ تٔمۍ سٕنزِ وَتہِ منٛز کٔرِو جدوجہد،شا ید ما گژِھہ تۅہیہِ کا میٲبی حٲصل۔"
  5,36,"۔وارٕ پٲٹھۍ زٲنِو زِ یِمو لُکو کُفر ک رٔوِیہِ اختیار چُھ کوٚر مُت،ہرگاہ تِہِندس قبضس منٛز سار ی زمینٕچ دو لت آسہِ ،تہٕ اتھ سٍتۍ آسہِ بیٚیہِ یٖژاہ، تہٕ تِم یژھن اتھ فِدیس منٛز دِتھ قیا مت کہ دۅ ہ کہ عذا ب نِشہِ بچُن،تمہِ پتہٕ تہِ یِیہِ نہٕ سۅ تِمن قبول کر نہٕ،تہٕ تِمن میلہِ دگ تُلوُن عذا ب۔"
  5,37,"۔تِم یژھہَن جہنم  کہ نارٕ نِشہِ نیٚبر نیرُن،مگر ہیٚکن نہٕ اَمہِ منٛزٕ نیرِتھ، تہٕ تِمن یِیہِ قٲیِم روزن وول عذا ب دِنہٕ۔"
  5,38,"۔تہٕ ژوٗر، ٲسِتن زنانہٕ یا ٲسِتن مرد، دۅ شوٕنۍ ژٔٹِو اتھہٕ۔﴿دۅ شو ے اتھہٕ نہ بلکہ اکھ۔ گۅڈنِچہِ ژوٗر پٮ۪ٹھ یِیہِ دٔچُھن اتھہٕ ژٹنہٕ۔ژوٗرِ ہُندِ اِطلاق چُھ صرف تتھ کامہِ پٮ۪ٹھ سپدان زِ اِنسان نِیہِ کٲنٛسہِ ہُند ما ل تٔمۍ سٕندِ حفا ظت نِشہِ کٔڑِتھ پننِس قبضس منٛز۔اکہِ ڈھال ﴿سِپر ﴾ کہ قٍمتہٕ کھۅتہٕ  کم ژوٗرِ پٮ۪ٹھ یِیہِ نہٕ اتھہٕ ژٹنہٕ۔معتبر روایاتو نِشہِ چُھ ننان زِ نبی صلی اللہ علیہ وسلمن ہٕندِس مبا ر ک دورس منٛز اوس ڈھا لُک قٍمت داہ در ہم آسان تہٕ تمہِ زمانہٕ کِس دِر ہمس منٛز اوس  ماشہِ رتی رۅ پھ آسان۔ واریاہ چیز چِھ تِم یِہٕنزِ ژوٗرِ پٮ۪ٹھ اتھہٕ ژٹنُک سزا یِیہِ نہٕ دِنہٕ۔مثلاً میو ہ یا سبز ی ژوٗر ،کھینٕچ ژوٗر،لۅ کٹن چیز ن ہٕنز ژوٗر ، پر ندٕہ سٕنز ژوٗر، بیت الما لٕچ ژوٗر،مطلب یِژھن ژوٗرن پٮ۪ٹھ یِیہِ نہٕ اتھہٕ ژٹنہٕ۔یہِ چُھنہٕ مطلب زِ یِمہٕ سار ے ژوٗرٕ  چھےٚ معا ف۔﴾ یہِ چُھ تِہٕنزِ کمایہِ ہُند بد لہٕ تہٕ اللہ تعالیٰ سٕندِ طر فہٕ عبرت نا ک سزا،اللہ تعالیٰ سٕنز قدرت چھےٚ سارِنٕے پٮ۪ٹھ غٲلِب تہٕ سُہ چُھ دانا و بینا۔"
  5,39,"۔پتہٕ یُس ظُلم کر نہٕ پتہٕ تو بہٕ کرِ تہٕ پننِس پانس کرِ اصلا ح تیٚلہِ گژِھہ اللہ تعالیٰ سٕنز نظرِ عنا یت بیٚیہِ تس پٮ۪ٹھ مٲیل۔﴿اَمِیُک مطلب چُھنہٕ یہِ زِ یِتھِس ژوٗرس گژِھہ نہٕ اتھ ژٹنہٕ یُن۔بلکہ چُھ مطلب یہِ زِ اتھہٕ ژٹنہٕ پتہٕ یُس تو بہٕ کرِ تہٕ پنُن نفس ژوٗرِ نِشہِ پاک کٔرِتھ بنہِ اللہ تعالیٰ سُند صا لح بندٕہ سُہ بچہِ اللہ تعالیٰ سٕندِ غضب نِشہِ تہٕ اللہ تعالیٰ چَھلہِ تٔمۍ سٕندِ دا منہٕ پٮ۪ٹھہٕ یہِ داغ۔البتہ اگر کانٛہہ شخصن اتھہٕ ژٹنہٕ پتہٕ تہِ پنُن پان بد نیتی نِشہِ پاک کوٚر نہٕ تہٕ تِمے مٔکرۍ جذبات رٔچِھن پانس منٛز یِہِندِس بُنیا دس پٮ۪ٹھ أمۍ ژوٗر کٔر تہٕ أمۍ سُند اتھہٕ آوژٹنہٕ ، تیٚلہِ چُھ امِیُک معنی یہِ زِ اتھہٕ گوٚو أمۍ سٕندِ جِسمہٕ نِشہِ جُدا مگر ژوٗر روٗز بد ستورأمۍ سٕندِس نفسس منٛز موجو د۔اَمہِ وجہ کِنۍ روزِ سُہ اللہ تعالیٰ سٕندِ غضبُک حقدار تِتھے پٲٹھۍ یِتھہٕ پٲٹھۍ اتھہٕ ژٹنہٕ برونٛہہ اوس۔اَمی موجو ب چُھ قرآن مجید ژوٗرس ہدا یت دِوان زِ سُہ منگِن خُدا یس معٲفی تہٕ پننِس پانس کٔرِن اِصلا ح تِکیازِ نفسٕچ پٲکی چَھنہٕ عدا لتی سزا سٍتۍ حا صل  گژھان بلکہ چھےٚ توبہٕ تہٕ خُدا یس کُن رجوع کر نہٕ سٍتۍ حٲصل سپدان۔﴾ اللہ تعالیٰ چُھ سٮ۪ٹھاہ در گز ر کر ن وول تہٕ رحم فر ماون وول۔"
  5,40,"۔کیا تۅہیہِ چَھو نا پے زِ اللہ تعالیٰ چُھ زمینُک تہٕ آسما نن ہٕندِ سلطنتُک مٲلِک؟ ییٚمِس ییٚژِھہ سزا دِیس تہٕ ییٚمِس ییٚژِھہ معا ف کر یٚس،تس چُھ پرٛتھ چیزُک اختیار۔"
  5,41,"۔اے پیغمبر صلی اللہ علیہ  وسلم تُہٕندِ خٲطرٕ مَہ بٔنِن پر یشٲنی ہُند بٲعث تِم لُکھ یِم کُفرٕ چھِ وَتہِ منٛز تیز قد می ہاوان چِھ،خواہ تِم تِمو منٛزٕ ٲسِتن یِم ٲسہٕ چِھ ونان اَسہِ اوٚ ن ایمان مگر تِہِند یو دِلَو اوٚ ن نہٕ ایمان ، یا ٲستن تِمو منٛز یِم یہوٗدۍ چِھ، یُہُند حال یہِ چُھ زِ اَپزِ خٲطرٕ چِھ کن دِوان ،تہٕ با قی لُکن خٲطرٕ یِم نہٕ تۅہیہِ نِشہِ زانٛہہ آے چِھ بوزان ﴿یعنی تِہِندِ خٲطرٕ چِھ جا سوسی کران﴾ اللہ تعالیٰ سٕنزِ کتا بہِ ہٕندٮ۪ن لفظن چِھ پنٕنۍ جا ے مُتعیّن آسنہٕ با وجود اصلی معنی نِشہِ ڈالان،تہٕ لُکن چِھ ونان زِ ہرگاہ تۅہیہِ یہِ حکم دِنہٕ یِیہِ تیٚلہِ مٲنِو ،اگر نہٕ تیٚلہِ مَہ مٲنِو ﴿یعنی جٲہل چِھ لُکن وَنان زِ یُس حکم أسۍ تۅہیہِ چِھو وَنان ،ہر گاہ محمد صلی اللہ علیہ وسلم،تہِ یۅہے حکم تۅہیہِ ونَن تیٚلہِ مٲنۍ زیٚو نَتہٕ کٔرۍ زیٚو رَد ﴾ ییٚمِس اللہ تعالیٰ نٕے فِتنس منٛز تراونُک اِرادہ آسہِ کوٚر مُت،تس ہیکِو نہٕ اللہ تعالیٰ سٕنزِ تَھپہِ نِشہِ بچا و نہٕ خٲطرٕ توٚہۍ کِہِنۍ کٔرِتھ،﴿اللہ تعالیٰ سٕندِ طر فہٕ کانٛہہ فِتنس منٛز ترا و نُک مطلب چُھ یہِ زِ یَس شخصس منٛز اللہ تعالیٰ کُنہِ قسمٕکۍ بُرٕ خیا لات پھا نپھلان چُھ وُچھان تس برونٹھ کُن چُھ پوٚتُس پتھ تِتھۍ مو قع اَنان یِمن منٛز تٔمۍ سٕنز سخت آزمٲیش چھےٚ سپدان۔اگر سُہ شخص بُرٲیی کُن وُنہِ پوٗرٕ پٲٹھۍ چُھنہٕ نر میو مُت تیٚلہِ چُھ یِمو آز یشو سٍتۍ ہیٚن رٹا ن تہٕ بد ی ہُند مقا بلہٕ کر نہٕ خٲطرٕ یِمہٕ نیکی ہٕنزٕ قوّتہٕ تس منٛز آسان چھےٚ تِمہٕ چھےٚ وۅ تلِتھ یِوان ۔ البتہ اگر سُہ بُرٲیی کُن پوٗرٕ پٲٹھۍ نر میو مُت چُھ آسان تہٕ أند ر ی أند ر ی چُھ  تٔمۍ سٕنزِ نیکی تٔمۍ سٕنزِ بد ی نِشہِ شکست آسان کھیو مُت تیٚلہِ چُھ پرٛتھ یژِھہ آزمٲیشہِ ہٕندِس مو قعس پٮ۪ٹھ سُہ وارے  بد ی ہٕندِ س زالس منٛز پھسان پکا ن۔یۅہے چُھ اللہ تعالیٰ سُند سُہ فِتنہٕ ییٚمہِ نِشہِ کانٛہہ بِگرٕ وُن اِنسان بچا وُن تٔمۍ سٕندِس کٲنٛسہِ خیر خوا ہس تام چُھنہٕ آسان﴾ یِم چِھ تِم لُکھ یِہِندۍ دل خُدا ین ییٚژھۍ نہٕ پاک کرٕنۍ،تِہندِ خٲطرٕ چھےٚ دُنیا ہس منٛز رُسوٲیی، تہٕ ٲخرتس منٛز سخت عذا ب۔"
  5,42,"۔یِم چِھ اَپُز بو زن وٲلۍ تہٕ حرام مال کھیٚنہٕ وٲلۍ،لہٰذا  اگر یِم تۅہیہِ نِشہِ ﴿پنٕنۍ مقد مہ ہیٚتھ ﴾ یِن تیٚلہِ چُھ تۅہیہِ اختیار دِںہٕ یِوان زِ اگر ییٚژِھو فٲصلہٕ کٔرِیوٗکھ نَتہٕ کٔرِیوٗکھ انکار،اگر انکار کٔرِیوٗکھ، یِم ہیٚکن نہٕ تۅہیہِ کانٛہہ نقصان واتنٲوِتھ،تہٕ ہرگاہ فٲصلہٕ کٔرِو، تیٚلہِ کٔرِو ٹھیک پٲٹھۍ انصاف سان، تِکیازِ اللہ تعالیٰ چُھ انصا ف کر ن والیٚن پسند کران۔﴿یہوٗدۍ ٲسۍ نہٕ اوٚت تام اسلامی حکو متٕکۍ با قا عدہ لُکھ بنیمٕتۍ،بلکہ ٲسۍ تِہِندۍ تعلقا ت اِسلامی حکو متس سٍتۍ معا ہدن پٮ۪ٹھ دٔرِتھ۔اَمہِ وجہ کِنۍ اوس نہٕ نبی صلی اللہ علیہ وسلمن ہٕندِس عدا لتس منٛز تِہُند یُن ضروری ۔البتہ یِمن معا ملاتن منٛز تِم خۅد پننہِ مذ ہبی قا نو نہٕ مطا بق فٲصلہٕ ٲسۍ نہٕ یژھان کرُن تِہُند فٲصلہٕ کر ناو نہٕ موجو ب ٲسۍ تِم اتھ بھروسس پٮ۪ٹھ حضور صلی اللہ علیہ وسلمن نِشہِ یِوان زِ شا ید ما آسہِ حضور صلی اللہ علیہ وسلمن ہٕندِس شر یعتس منٛز تِہندِ خٲطرٕ بیٚاکھ کانٛہہ حکم تہٕ یِتھہٕ پٲٹھۍ ہیٚکہِ ہن تِم پننہِ مذ ہبی قا نو ن چہِ پیر وی نِشہِ بٔچِتھ۔﴾"
  5,43,"۔تہٕ یِم کِتھہٕ پٲٹھۍ چِھو تۅہیہِ حَکَم بناوان،ییٚلہِ زن یِمن نِشہِ توراتہ موجو د چھےٚ یَتھ منٛز اللہ تعالیٰ سُند حُکم لیٚکِھتھ چُھ، تہٕ پتہٕ چِھ یِم اَمہِ نِشہِ بُتھ پھِران؟ دراصل چھےٚ کتھ یہِ زِ یِمن چُھنہٕ ایمانٕے۔ع"
  5,44,"۔اَسہِ کٔرتو رات نٲزِل یتھ منٛز ہدا یت تہٕ گا ش اوس،سٲر ی نبی ، یِم مُسلم ٲسۍ ،تِم ٲسۍ تَمی مطا بق یِمن یہوٗدٮ۪ن ہٕندٮ۪ن معاملاتن ہُند فٲصلہٕ کران،تہٕ یِتھے پٲٹھۍ ٲسۍ ربّا نی ﴿علما ﴾ تہِ ﴿أتھۍ پٮ۪ٹھ فٲصلہٕ کران﴾ تِکیازِ تِم ٲسۍ اللہ تعالیٰ سٕنزِ کتا بہِ ہٕندۍ ذمہٕ دار بنا و نہٕ آمٕتۍ، تہٕ تِم ٲسۍ اتھ پٮ۪ٹھ گواہ۔لہٰذا ﴿اے یہو دیو ﴾ توٚہۍ مَہ کھوٚژِو لُکن بلکہ کھوٚژِو مےٚ، تہٕ معمو لی معمو لی مُعا وضس پٮ۪ٹھ ترٲوِو میٲنۍ آیات کٕنٕنۍ، یِم لُکھ اللہ تعالیٰ سٕندِ نٲزِل کر نہٕ آمتہِ قا نو نہٕ مطٲبق فٲصلہٕ کر ن نہٕ تِمے  چِھ کٲفر۔"
  5,45,"۔تورا تس منٛز اوس اَسہِ یہوٗدٮ۪ن خٲطرٕ یہِ حکم لیٚو کھمُت زِ جا نس بد لہٕ جان،أچھ بد لہٕ أچھ،نستہِ بد لہٕ نس،کَنہٕ بد لہٕ کَن، دندٕ بد لہٕ دند،تہٕ تمام زخمن ہٕندِ خٲطرٕ برابر بد لہٕ، پتہٕ یُس قصا صُک صد قہٕ کرِ ،تیٚلہِ چُھ سُہ تٔمۍ سٕندِ خٲطرٕ صد قہٕ، تہٕ یِم لُکھ اللہ تعالیٰ سٕندِ نٲزِل  کر نہٕ آمتہِ قا نو نہٕ مطا بق  فاصلہ کر ن نہٕ، تِمے چِھ ظٲلِم۔"
  5,46,"۔ پتہٕ سوٗز اَسہِ یِمو پیغمبر وپتہٕ مر یم علیھا السلامن ہُند فر زند عیسیٰ علیہ السلام، توارتہ منٛزٕ یِکینژھاہ تس برونٹھہٕ  کنہِ موجود اوس سُہ اوس تمِیُک تصدیق کر ن وول، تہٕ اَسہِ کٔرِ تس انجیل عطا یتھ  منٛز رہنمٲیی تہٕ روشنی ٲس،تہٕ سۅ تہِ ٲس تتھ تصد یق کرن وا جِنۍ یِکینژھاہ توارتہ منٛزٕ تمہِ وقتہٕ موجو د اوس،تہٕ خُدا ترس لُکن خٲطرٕ ٲس سراسر ہدایت تہٕ نصیحت۔"
  5,47,"۔سو ن حکم اوس کہ اہلِ انجیل کٔرِن تمہِ قا نو نہٕ مطا بق فٲصلہٕ یُس خُدا ین اَتھ منٛز نازِل چُھ کوٚر مُت ، تہٕ یِم لُکھ اللہ تعالیٰ سٕندِ نٲزِل کر نہٕ آمتہِ قا نو نہٕ مطٲبق فٲصلہٕ کر ن نہٕ، تِمے چِھ فا سق۔﴿یتھ جایہِ چِھ اللہ تعالیٰ ہن تِمن لُکن ہٕندِس حقس منٛز ترٛے حُکم ثٲبت کٔرِمٕتۍ  یِم اللہ تعالیٰ سٕندِ نٲزِل کر نہٕ آمتہِ قا نو نہٕ مطٲبق فٲصلہٕ کر ن : اکھ یہِ زِ تِم چِھ کٲفر ، دوٚ یُم یہِ زِ تِم چِھ ظٲلِم ۔ترٛیُیم یہِ زِ تِم چِھ فا سق ۔یُس شخص اللہ تعالیٰ سٕندِس حُکمس خلا ف اَتھ بُنیا دس پٮ۪ٹھ چُھ فٲصلہٕ کران زِ سُہ چُھ سمجھان اللہ تعالیٰ سٕندِ س حُکمس غلط تہٕ پننِس یا بیٚیہِ کٲنٛسہِ ہٕندِس حُکمس چُھ  صحیح سمجھان ،سُہ چُھ مکمل کٲفر تہٕ ظٲلِم تہٕ فا سق ،تہٕ یُس اعتقادٕ رٔنگۍ اللہ تعالیٰ سٕندِس حُکمس بر حق چُھ سمجھان مگر عملاً چُھ اتھ خلا ف فٲصلہٕ کران ،سُہ اگر چہِ مِلّت نِشہِ خٲرج چُھنہٕ مگر پننِس ایمانس چُھ کفر س تہٕ فِسقس سٍتۍ رلاوان ۔یِتھے پٲٹھۍ ییٚمۍ تمام معا ملاتن منٛز اللہ تعالیٰ سٕندِ حُکمہٕ نِشہِ انحرا ف چُھ کوٚر مُت ،سُہ چُھ تمام معا ملاتن منٛز کٲفر ،ظٲلِم تہٕ فا سق۔تہٕ یُس کینژھن معا ملاتن منٛز فر مانبردار تہٕ کینژھن منٛز بُتھۍ پھِیر چُھ، تٔمۍ سٕنزِ زند گی منٛز چھےٚ ایمان تہٕ اسلام ، کفر ظُلم تہٕ فِسقٕچ مِلا وٹ ٹھیک تَمی تنا سب سان ییٚمہِ تنا سب سان تٔمۍ اطا عت تہٕ انحرا ف آسہِ رلو و مُت ۔ ﴾"
  5,48,"۔اے نبی صلی اللہ علیہ وسلم، پتہٕ سوٗز اَسہِ تۅہیہِ کُن یہِ کتا ب یۅسہٕ حق ہیٚتھ چھےٚ آمٕژ۔تہٕ الکتا ب منٛزٕ یِکینژھاہ اتھ برونٹھہٕ کنہِ موجو د چُھ تتھ چھےٚ تصدیق کر ن واجِنۍ،تہٕ بیٚیہِ چھےٚ تمِچ محٲفظ تہٕ رٲچھ راوٹھ کر ن واجِنۍ۔﴿یتھ جایہِ چُھ أکِس اہم حقیقتس کُن اشارٕہ کر نہٕ آمُت۔اگر چہِ مضمو ن یتھہٕ پٲٹھۍ تہِ ادا ہیٚکہِ ہے کر نہٕ یِتھ زِ پٔتِمیٚن کتا بن  منٛز یِکینژھاہ پننِس اصلی تہٕ صحیح صورتس منٛز با قی اوس۔قرآن چھُ تتھ تصدیق کران مگر خداین کوٚر پٔتِمیٚن کتا بن  بجا یہِ  الکتا ب  لفظ استعمال ،امہِ نِشہِ چُھ یہِ راز نوٚ ن نیران زِ قرآن تہٕ تمام تِمہٕ کتا بہٕ یِمہٕ مختلف زمانن تہٕ مختلف زبا نن منٛز اللہ تعالیٰ سٕندِ طر فہٕ نٲزِل سپٕز، سار ے چھےٚ اند ہیٚتھ دراصل کُنی کتا ب۔ کُنُے چُھ یُہُند مصّنف،کُنُے چُھ یُہُند مُدعا تہٕ مقصد ،کُنی چھےٚ یِہٕنز تعلیم تہٕ کُنُے چُھ علم یُس یِہِند ذر یعہ انسٲنۍ زُرِ یا تس عطا آو کر نہٕ۔ فرق اگر چھےٚ سۅ چھےٚ عبا رتن ہٕنز ،یِمہٕ کُنی مقصدٕ خٲطرٕ مختلف بوزن والیٚن ہٕندِ لِحا ظہٕ مختلف طر یقو وَرتاو نہٕ چھےٚ آمژٕ۔قرآنس چُھ الکتا بہِ ہُند محٲفظ تہٕ نگران وَننُک مطلب یہِ زِ أمۍ چِھ تمام بر حق تعلیمات یِم پٔتِمیٚن آسمٲنۍ کتا بن منٛز دِنہٕ ٲسۍ آمٕتۍ پا نس منٛز رٔٹِتھ محفو ظ کٔرِ مٕتۍ۔وۅ نۍ ہیٚکہِ نہٕ تِہٕندٮ۪ن بر حق تعلیماتن ہُند کانٛہہ حصہ ضا یع سپدِتھ﴾ لہٰذا کٔرِ و توٚہۍ اللہ تعالیٰ سٕندِ نٲزِل کر نہٕ آمتہِ قا نو ن مطٲبق لُکن ہٕندٮ۪ن معا ملاتن ہُند فٲصلہٕ، تہٕ یُس حق تۅہیہِ نِشہِ ووتمُت چُھ تمہِ نِشہِ بُتھ پھِیرِ تھ مَہ کٔرِ و تِہنز ن خوٲہشا تن ہٕنز پیر وی ، اَسہِ کوٚر تۅہیہِ ﴿انسا نَو﴾ منز پرٛتھ کٲنٛسہِ ہٕندِ خٲطرٕ اکھ شر یعت تہٕ اکھ راہِ عمل مقرر۔اگر چہِ تُہُند اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ بناوِ ہے تۅہیہِ سارِنٕے اکھ اُمّت تہِ ، البتہ تٔمۍ کوٚر یہِ امہِ موجوٗب زِ یِکینژھاہ تٔمۍ تۅہیہِ دِیتمُت چُھنَو ،تتھ منٛز کر یٚو تۅہیہِ آز مٲیش، لہٰذا کٔرِ و نیکین منٛز اکھ أکِس برونٛہہ گژھنٕچ کوشش، ٲخر کار چُھو تۅہیہِ سارِنٕے خُدا یس کُن وا پس گژُھن،پتہٕ وَنیٚو سُہ تۅہیہِ اصلی حقیقت یتھ منٛز توٚہۍ اختلا ف کران روٗدِمٕتۍ چِھو۔"
  5,49,"۔پس اے نبی صلی اللہ علیہ وسلم، توٚہۍ کٔرِو اللہ تعالیٰ سٕندِ نازِل کر نہٕ آمتہِ قا نو نہٕ مطٲ بق یِمن لُکن ہٕندٮ۪ن معا ملاتن ہُند فٲصلہٕ، تہٕ یِہنز ن خوٲہشا تَن ہٕنز پیر وی مَہ کٔرِو،ہوشیار روٗزِ و زِ یِم لُکھ گژھنَو نہٕ تۅہیہِ فِتنس منٛز ترٛٲوِتھ تمہِ ہدایت نِشہِ ذرس برابر ڈٲلِتھ ہیٚکٕنۍ یُس خُدا ین تۅہیہِ کُن نٲزِل چُھ کوٚر مُت،پتہٕ اگر یِم تمہِ نِشہِ بُتھ پھِر ن تیٚلہِ زٲنِو زِ خُدا ین چِھ یِم پننیٚن کینژھن گنا ہن ہٕندِس پاداشس منٛز مصیبت سٕے منٛز مبتلا کر نُک فٲصلہٕ کوٚر مُت،تہٕ یہِ چھےٚ حقیقت زِ یِمو لُکو منٛزٕ چِھ اکثر فا سق۔"
  5,50,"۔﴿ہرگاہ یِم اللہ تعالیٰ سٕندِ قانو ن نِشہِ بُتھ چِھ پھِران﴾ کیا تیٚلہِ چھا بیٚیہِ جٲہلیتُک فٲصلہٕ یژھان؟ ﴿ جٲہلیت  لفظ چُھ اسلام کِس مقا بلس منٛز وَرتاو نہٕ یِوان ۔ اسلامُک طر یقہٕ چُھ سراسر عِلم ،تِکیازِ اَتھ چھےٚ خُدا ین رہنمٲیی کٔر مٕژ یُس تمام حقیقتن ہُند علم چُھ تھاوان۔تہٕ اتھ بر عکس پرٛتھ کانٛہہ سُہ طر یقہٕ یُس اسلام نِشہِ مختلف چُھ، چُھ جٲہلیتُک طر یقہٕ۔ عر بُک سُہ زمانہٕ یُس اسلام برونٛہہ اوس ،تَتھ چُھ جٲہلیتُک دَور اَتھ معنیس منٛز وَننہٕ آمُت زِ تتھ زمانس منٛز ٲسۍ اِنسا نَو علمہٕ ورٲے محض وہمس یا قیا سس تہٕ گُما نس یا خوٲہشا تن ہٕندِس بُنیا دس پٮ۪ٹھ پانس خٲطرٕ زند گی ہٕندِۍ طر یقہٕ مُقرر کٔرِ مٕتۍ۔یہِ طرزِ عمل یتھ تہِ جایہِ  کُنہِ تہِ دَورس منٛز وَرتاو نہٕ یِیہِ ،تَتھ یِیہِ بہر حال جٲہلیت کُے طر زِ عمل وَننہٕ۔﴾ حالانکہ یِم لُکھ خُدا یس پٮ۪ٹھ یقین چِھ تھاوان تِمن نز دیک کُس ہیٚکہِ خُدا یس ورٲے بیٚیہِ کانٛہہ بہتر فٲصلہٕ کر ن وول ٲسِتھ۔ع"
  5,51,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت،یہوٗدۍ تہٕ عیسٲے مَہ بنٲوِ یوٗکھ پنٕنۍ رفیق،یِم چِھ پانہٕ وٲنی اکھ أکۍ سٕندۍ رفیق،تہٕ ہرگاہ تۅہیہِ منٛزٕ کانٛہہ یِمن پنُن رفیق بناوان چُھ، تیٚلہِ چھُ تٔمۍسُند شمار تہِ تِمنٕے منٛز، پز ۍ پٲٹھۍ چُھ اللہ تعالیٰ پننہِ رہنمٲیی نِشہِ ظٲلِمن کران محروٗم۔"
  5,52,"۔توٚہۍ چِھو وُچھان یِہند ٮ۪ن دِلن منٛز نِفا قٕچ بیمٲرۍ چھےٚ تِم چِھ تِمنٕے ﴿یہو دٮ۪ن تہٕ عیساین﴾  منٛز کوشش کران پھیران،وَنان چِھ : اسہِ چُھ ڈر باسان زِ أسۍ گٔژھۍ نہٕ کُنہِ مُصیبتس منٛز پھسٕنۍ۔ مگر یہِ کتھ چَھنہٕ دوٗر ییٚلہِ اللہ تعالیٰ تۅہیہِ فٲصلہٕ کُن فتح بخشہِ ، یا کڑِ پننہِ طر فہٕ بیٚیہِ کانٛہہ کتھ نٔنۍ،پتہٕ گژھن یِم لُکھ پننِس اتھ نِفا قس پٮ۪ٹھ نٲدِم یُس یِم دِلن منٛز چُھپٲوِ تھ چِھ۔"
  5,53,"۔تہٕ تمہِ ساعتہٕ ونن اہلِ ایمان، کیا یِم چھا تِمے لُکھ یِم اللہ تعالیٰ سٕندِ ناوٕ سٍتۍ بٔڑۍ بٔڑۍ قسم کھیٚتھ یقین ٲسۍ بیہنا وان زِ ٲسۍ چِھ تۅہیہِ سٍتۍ؟ یِہندۍ سٲری اعمال سپٕدۍ ضا یع تہٕ ٲخر کار بیٖٹھۍ یِم نا کام تہٕ نا مُراد گٔژِھتھ۔"
  5,54,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، ہرگاہ تۅہیہِ منٛزٕ کانٛہہ پننہِ دینہٕ نِشہِ پھیران چُھ﴿پھیٖرِ تن﴾ اللہ تعالیٰ کرِ بیٚیہِ واریاہ لُکھ تِتھۍ پٲدٕ یِم خُدایس ٹٲٹھۍ آسن تہٕ اللہ تعالیٰ آسہِ تِمن ٹو ٹھ، یِم مومنن پٮ۪ٹھ نر م تہٕ کٲفر ن پٮ۪ٹھ سخت آسن، ﴿ مومنن پٮ۪ٹھ نر م  آسنُک مطلب چُھ یہِ زِ اکھ شخص گژِھہ نہٕ اہلِ ایمانن ہٕندِس مقا بلس منٛز پننہِ طا قتُک استعمال زانٛہہ کرُن۔أمۍ سٕنز ذہا نت ،أمۍ سٕنز ہو شیٲر ی،أمۍ سٕنز قٲبلیت ،أمۍ سُند اثر و رسوخ، أمۍ سُند مال ، أمۍ سُند جسمٲنی زور ، کانٛہہ تہِ چیز گژِھہ نہٕ مُسلمانن دَبا و نہٕ تہٕ ستاو نہٕ تہٕ نقصا ن وا تناو نہٕ خٲطرٕ آسُن۔ مُسلمانن گژِھہ یہِ پا نس در میان ہمیشہ اکھ نر م خُو ،رحم دل، ہمدرد تہٕ حلیم انسان با سُن۔ کٲفر ن پٮ۪ٹھ سخت  آسنُک مطلب چُھ یہِ زِ اکھ مو من انسان گژِھہ پننہِ ایمان چہِ پختگی منٛز، دیندٲری ہٕندِس خلو صس منٛز، اصو لن ہٕنزِ مضبو طی منٛز، سیر ت کہ طا قتہٕ کِنۍ تہٕ ایمان کہ فراست کہ وجہ کِنۍ اسلام کیٚن مخٲلفن ہٕندِس مقا بلس منٛز اکہِ مضبو ط چٹا نٕکۍ پٲٹھۍ آسُن یُس نہٕ کُنہِ پٲٹھۍ تہِ پننہِ جایہِ ڈا لنہٕ ہیٚکہِ یِتھ۔تِمن گژِھہ نہٕ یہِ ٲٹۍ گردٔنۍ تہٕ وٕ گرٕ ٹیٖرِ ہٕندۍ پٲٹھۍ نر م با سُن زِ یو ر کُن پھِر وٕ نس تو ر کُن پھیرِ۔تِمن ییٚلہِ تہِ یہِ سمکھہِ تِمن گژِھہ با سُن زِ یہِ اللہ تعالیٰ سُند بندٕہ کرِ مرُن بہتر مگر کُنہِ تہِ قٍمتس پٮ۪ٹھ ہیٚکہِ نہٕ پنُن پان  کٕنِتھ تہٕ نہ ہیٚکہِ دٔبِتھ۔﴾ یِم لُکھ اللہ تعالیٰ سٕنزِ وَتہِ منٛز جد و جہد کر ن تہٕ کٲنٛسہِ ملامت کر ن وٲلۍ سٕندِس ملا متس کھۅژن نہٕ، یہِ چُھ اللہ تعالیٰ سُند فضل، یس یژھان چُھ تَس چُھ عطا کران، اللہ تعالیٰ چُھ وسیع ذر یعن ہُند مٲلِک تہٕ سورُے کینٛہہ چُھ زانان۔"
  5,55,"۔تِہُندۍ رفیق چِھ در حقیقت صرف اللہ تعالیٰ تہٕ اللہ تعالیٰ سُند رسول تہٕ یِم اہلِ ایمان  یِم نماز چِھ قٲیِم کران،زکوٰت چھِ دِوان تہٕ خُدا یس برونٹھہٕ کنہِ چِھ نمن وٲلۍ۔"
  5,56,"۔تہٕ یُس خُدا یس تہٕ تٔمۍ سٕندِس رسو لس صلی اللہ علیہ وسلمس تہٕ اہلِ ایمانن پنُن رفیق بناوِ ، تس گژِھہ پے آسٕنۍ زِبس چھےٚ تٔمۍ سٕنز جما عت غٲلب روزن واجِنۍ ۔ ع"
  5,57,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت،تۅہیہِ بروٗنٹھمیو اہل کتا بو منٛزٕ یِمو لُکو تُہُند دین مذاق تہٕ کھیل چُھ بنو و مُت ، تِم تہٕ با قی کٲفر مَہ بنٲوِیوٗکھ پنٕنۍ دوست تہٕ رفیق۔ خدا یس کھوٗژِو  اگر توٚہۍ مو من چِھو۔"
  5,58,"۔ییٚلہِ توٚہۍ نمازِ مۅ کھہٕ ناد چِھو لایان تیٚلہِ چِھ یِم اَتھ ہزٕل کران تہٕ اتھ سٍتۍ چِھ گندا ن ۔ ﴿یعنی با نگہِ ہٕنز آواز بوٗزِ تھ چِھ اتھ نقل کران، مسخر ی خٲطرٕ چِھ اَمِکۍ الفا ظ بد لا وان تہٕ پھِر ۍ پھِرۍ چِھ پران۔﴾اَمِیُک وجہ چُھ یہِ زِ تِمن چَھنہٕ عقل۔"
  5,59,"۔تِمن ؤنِو اے اہلِ کتا ب ،توٚہۍ یتھ کتھہِ پٮ۪ٹھ اَسہِ ضد کڑان چِھو ، سۅ کیا چھےٚ اَمہِ ورٲے  زِ اسہِ چُھ خُدا یس پٮ۪ٹھ تہٕ دین چہِ تتھ تعلیمہِ پٮ۪ٹھ ایمان اوٚ نمُت یۅسہٕ اَسہِ کُن نٲزِل چھےٚ سپٕز مٕژ تہٕ اسہِ برونٛٹھ تہِ ٲس نٲزِل سپٕز مٕژ تہٕ تۅہیہِ منٛز چِھ اکثر لُکھ فا سِق؟"
  5,60,"۔بیٚیہِ ؤنیوٗکھ: کیا بہٕ کر ا تِمن لُکن ہٕنز نشا ند ہی یُہُند انجام خُدا یس نِشہِ فا سقن ہٕندِ انجا مہٕ کھۅتہٕ تہِ بدتر چُھ؟ تِم یِمن پٮ۪ٹھ خُدا ین لعنت کٔر، یِمن پٮ۪ٹھ تٔمۍ سُند غضب سپُد، یِمو منٛزٕ پٔنز ۍ تہٕ خنزیر آے بناو نہٕ، یِمو طا غو تٕچ بند گی کٔر،تِہُند در جہِ چُھ اَمہِ کھۅتہٕ تہِ زیادٕہ بُرٕ،تہٕ تِم چِھ سَوَ  ا  ٔلسبیل ﴿سیٚزِ وَتہِ ﴾ نِشہِ واریاہ زیادٕہ ڈٔلمٕتۍ۔"
  5,61,"۔ییٚلہ، یِم تۅہیہِ لُکن نِشہِ یِوان چِھ تیٚلہِ چِھ ونان زِ اَسہِ اوٚ ن ایمان حالانکہ کُفر ہیٚتھ ٲسۍ آمٕتۍ، تہٕ کُفرُے ہیٚتھ درٛاے واپس،تہٕ اللہ تعالیٰ چُھ ٹھیک پٲٹھۍ زانان یِکینژھاہ یِم دِلن منٛز چُھپٲوِ تھ چِھ ۔"
  5,62,"۔توٚہۍ چِھو وُچھان زِ یِمو منٛزٕ چِھ واریاہ لُکھ گنا ہ  تہٕ ظُلم و زیادتی ہٕنز ن کامیٚن منٛز دَوان دوران،تہٕ بیٚیہِ چِھ حرا مٕکۍ مال کھیٚوان،سٮ۪ٹھاہ بُرٕ ہ حر کتہٕ چھےٚ، یِمہٕ یِم کران چِھ ۔"
  5,63,"۔کیا زِ چِھنہٕ یِہِندۍ عٲلم تہٕ مشٲیخ یِمن گنا ہس پٮ۪ٹھ زیٚو مٕژ روانہٕ نِشہِ تہٕ حرا م کھیٚنہٕ نِشہِ پتھ رٹا ن؟ پٔزۍ پٲٹھۍ چُھ سٮ۪ٹھہٕے بُرٕ ہ زند گی ہُند کار نامہٕ یُس تِم تیار چِھ کران۔"
  5,64,"۔یہو دۍ چِھ ونان اللہ تعالیٰ سٕندۍ اتھہٕ چِھ گٔنڈِتھ۔﴿عر بی محا ورہ مطا بق کٲنٛسہِ ہٕندۍ اتھہٕ گٔنڈِتھ آسنُک مطلب چُھ یہِ زِ سُہ چُھ بخیل ، دِنہٕ نِشہِ چُھ تٔمۍ سُند اتھہٕ رُکِتھ۔﴾ گٔنڈنہٕ آے تِہِندۍ اَتھہٕ،﴿یعنی بخیل چِھ یِم پانہٕ۔پننہِ بخیلی تہٕ پننہِ تنگ دِلی کِنۍ چُھ لُکن  یُہُنٛد ناو زیٚوِ پٮ۪ٹھ۔﴾ تہٕ لعنت ؤژھ یِمن تمہِ بکواس کِنۍ یُس یِم کران چِھ ،اللہ تعالیٰ سٕندۍ اتھہٕ چِھ کُشادٕہ، یِتھہٕ پٲٹھۍ یژھان چُھ تِتھہٕ پٲٹھۍ چُھ خر چا وان۔حقیقت چھےٚ یہِ زِ یُس کلام تُہندِ س ربّ سٕندِ طر فہٕ تۅہیہِ پٮ۪ٹھ نٲزِل چُھ سپُد مُت سُہ چُھ تِمو منٛزٕ اکثر لُکن ہٕنزِ سر کشی تہٕ بٲطل پرستی منٛز اُلٹہٕ اضا فُک وجہ بنیا و مُت۔تہٕ ﴿ اَمہِ کِس پا دا شس منٛز ﴾ چُھ اَسہِ قیا متس تام یِمن در میان عدا وت تہٕ دشمنی ترٛٲومٕژ ،ییٚلہِ کُنہِ وِزِ یِم جنگ کِس نا رس ریہہ چِھ تُلان اللہ تعالیٰ چُھ تتھ ٹھنڈٕ کران، یِم چِھ زمینس منٛز فساد پھٔہلاونٕچ کوٗشش کران مگر اللہ تعالیٰ چُھنہٕ فساد  کر ن والیٚن ہر گز پسند کران۔"
  5,65,"۔اگر ﴿امہِ سر کشی بجا ے ﴾ یِم اہلِ کتا ب ایمان اَنہن تہٕ خُدا تر سی ہٕنز رٔوِش کر ہن اختیار تیٚلہِ کر ہَو أسۍ یِہٕنزٕ بُرٲیِیہِ یِمن نِشہِ دوٗر، تہٕ یِم واتنا و ہو کھ نعمت والیٚن جنتن منٛز ۔"
  5,66,"۔کاش یِمَو آسٕہَن تورا تہ، انجیل تہٕ تِمہٕ دوٚ یِمہِ کتا بہٕ قٲِیم کرِ مژٕ یِمہٕ یِہندِس ربّ سٕندِ طر فہٕ یِمن نِشہِ سوز نہٕ آسہٕ آمژٕ۔اگر یہِ کر ہن تیٚلہِ وَسہِ ہے پٮ۪ٹھہٕ تہِ یِہِندِ خٲطرٕ رِزق تہٕ بۅ نہٕ تہِ وُزِ ہے، اگر چہِ یِمو منٛزٕ کینٛہہ لُکھ جان تہِ چِھ ، مگر یِہٕنز اکثر یت چھےٚ سخت بد عمل۔ع"
  5,67,"۔اے پیغمبر، یِکینژھاہ تُہندِس ربّ سٕند طر فہٕ تۅہیہِ پٮ۪ٹھ نٲزِل چُھ کر نہٕ آمُت سُہ واتنٲوِو لُکن تام، ہرگاہ تۅہیہِ یہِ کوٚرُو نہٕ، تیٚلہِ کوٚرُو نہٕ تٔمۍ سٕنزِ پیغمبر ی ہُند حق ادا، اللہ تعالیٰ چُھو تۅہیہِ لُکن ہٕندِ شرٕ نِشہِ بچا و ن وول ، پژھ تھٲوِو زِ سُہ ہاوِ نہٕ ﴿تُہٕندِس مقا بلس منٛز﴾ کٲفر ن کا میٲبی  ہٕنز وَتھ ہرگز۔"
  5,68,"۔صا ف ؤنیوٗکھ زِ اے اہلِ کتاب،توٚہۍ چِھو نہٕ ہر گز کُنہِ اصلیتس پٮ۪ٹھ یوٚت تام نہٕ توراتہ تہٕ انجیل تہٕ تِمہٕ با قی کتا بہٕ قٲیِم کٔر یوٗکھ یِمہٕ تُہٕندِس ربّ سٕندِ طر فہٕ تۅہیہِ کُن نٲزِل چھےٚ کر نہٕ آمژٕ، ضرور سپدِ زیُس یہِ فر مان تُہٕندِس ربّ سٕندِ طر فہٕ تۅہیہِ پٮ۪ٹھ نٲزِل چُھ کر نہٕ آمُت کرِ تِمو منٛزٕ اکثر ن ہٕنزِ سر کشی تہٕ نَہ ما ننس زیادے اضا فہٕ مگر اِنکار کر ن والیٚن ہٕندِ س حا لس پٮ۪ٹھ مَہ کٔرِ و کانٛہہ افسو س۔"
  5,69,"۔﴿پژھ کٔرِوزِ ییٚتہِ چُھنہٕ کٲنٛسہِ ہُند تہِ اِجا رٕہ ﴾ مُسلمان ٲسِتن یا یہوٗدۍ، صٲبی ٲسِتن یا عیسٲے،یُس اکھا خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان اَنہِ تہٕ نیک عمل کرِ ، بے شک چَھنہٕ تٔمۍ سٕندِ خٲطرٕ کُنہِ خو فٕچ جا ے تہٕ نہ رنج کر نٕچ گُنجٲیش۔﴿تشر یح خٲطرٕ وُچِھو سورۂ بقر ہ آیت نمبر : 62﴾"
  5,70,"۔اَسہِ ہیوٚت بنی اسرٲیلس پختہٕ عہد تہٕ تِمن کُن سوٗزۍ واریاہ رسول،مگر ییٚلہِ تہِ زانہٛہ تِمن نِشہِ کانٛہہ رسول تِہندٮ۪ن نفسن کیٚن خوٲہشا تن خلا ف کینٛہہ ہیٚتھ آو تیٚلہِ کوٚر تِمو کٲنٛسہِ ہُند انکار تہٕ کانٛہہ کوٚرُکھ قتل۔"
  5,71,"۔تہٕ پننہِ جایہِ زونُکھ زِ کانٛہہ فِتنہٕ سپدِ نہٕ ظٲہر اَمہِ موجوٗب بنیے أنۍ تہٕ زٔرۍ پتہٕ کوٚر خُدا ین تِمن معا ف تہٕ تِمو منٛز روٗدۍ اکثر لُکھ وارے زیادٕہ أنۍ تہٕ زٔرۍ بنان اللہ تعالیٰ چُھ تِہِندۍ یِم سٲری حر کات وُچھان روٗدمُت۔"
  5,72,"۔پٔزۍ پٲٹھۍ کوٚر کُفر تِمو لُکو یِمو ووٚ ن زِ خُداے چُھ مسیح ابنِ مر یمٕے علیہ السلام، حالانکہ مسیح ﴿علیہ السلامن﴾ اوس ووٚ نمُت زِ  اے بنی اسرا یل ، اللہ تعالیٰ سٕنز بند گی کٔرِ و یُس میو ن ربّ تہِ چُھ تہٕ تُہُند ربّ تہِ چُھ۔ ییٚمۍ خُدا یس سٍتۍ کانٛہہ شر یک ٹھہر وو، تس پٮ۪ٹھ کوٚر خُدا ین جنت حرام تہٕ تٔمۍ سُند ٹھکانہٕ چُھ جہنم، تہٕ یِتھیٚن ظٲلِمن ہُند چُھنہٕ کانٛہہ مددگار۔"
  5,73,"۔پٔزۍ پٲٹھۍ کوٚر کُفر تِمو لُکو یِمو ووٚن خُدا ے چُھ تر ٮ۪ن ہُند کُنُے، حالانکہ أکِس خُدا یس ورٲے چُھنہٕ کانٛہہ خُدا ، اگر یِم لُکھ پننیو یِمو کتھو نِشہِ باز پھیٖر ۍ نہٕ ، تیٚلہِ یِیہِ یِمو منٛزٕ تس تس دگ تُلوُن عذا ب دِنہٕ ییٚمۍ ییٚمۍ کُفر چُھ کوٚر مُت۔"
  5,74,"۔پتہٕ کیا یِم کر ن نا ، خُدا یس برونٛہہ کنہِ تو بہٕ تہٕ تس منگن نا معٲفی؟ اللہ تعالیٰ چُھ سٮ۪ٹھاہ در گُز ر کر ن وول تہٕ رحم کر ن وول ۔"
  5,75,"۔مسیح ابن مر یم ٲسۍ نہٕ امہِ ورٲے کِنۍ زِ تِم ٲسۍ بس اکھ رسول، تِمن برونٛہہ تہِ ٲسۍ واریاہ رسول آمٕتۍ،تِہٕنز مو ج ٲس اکھ پر ہیز گار خا تو ن، تہٕ تِم دۅ شو ے ٲسۍ کھیٚن کھیوان، وُچِھو أسۍ کِتھہٕ پٲٹھۍ چِھ تِمن برونٛہہ کنہِ حقیقت چہِ نِشٲنیہِ وا ضح کران،پتہٕ وُچِھو یِم کور کُن چِھ اُلٹہٕ پھیران۔﴿یِمن کینژھن لفظن منٛز چُھ الوٗہیت مسیح علیہ السلام کِس عقیدتس تِیُتھ ٹا کارٕ  تردید آمُت کر نہٕ زِ امہِ کھۅتہٕ زیادٕہ صفٲیی چَھنہٕ ممکن ۔مسیح علیہ السلامس متعلق اگر کانٛہہ یہِ زانُن ییٚژِھہ زِ فی الحقیقت کیا ٲسۍ تِم ،تیٚلہِ ہیٚکہِ سُہ  یِمو علا ماتو نِشہِ بالکل کُنہِ شکہٕ ورٲے یہِ زٲنِتھ زِ تِم ٲسۍ محض اکھ انسان ۔ یہِ کتھ چھےٚ ظٲہر زِ یُس أکِس ماجہِ ہٕندِ شکمہٕ منٛزٕ زاو، ییٚمۍ سٕنز کرٛ ٲنۍ ہا نکل ﴿شجر ہ نسب﴾ تام موجوٗد چھےٚ، یس انسٲنی جِسم اوس ، یَس پٮ۪ٹھ تِم تمام حدود تہٕ قیود  مُقرر ٲسۍ تہٕ تِم سٲر ی صفت تہِ ٲسِسس یِم انسان سٕندِ خٲطرٕ مخصو ص چِھ ، یُس شۅ نگان اوس، کھیوان اوس، گر می تہٕ سردی اوس ژینان ، حتیٰ کہ یُس عیسا ین ہٕندِ بیان مُطٲبق شیطا ن سٕندِ ذر یعہٕ آزمٲیشہِ منٛز تہِ ترٛاو نہٕ آو ، تس متعلق کُس عقلہِ وول انسان ہیٚکہِ یہِ تصوُر کٔرِ تھ زِ سُہ چُھ پانہٕ خُدا ے یا خُدا یس چُھ خُدا یی منٛز شر یک تہٕ حصہٕ دار ۔ ﴾"
  5,76,"۔تِمن ؤنِو ،کیا توٚہۍ چِھوٕ اللہ تعالیٰ ترٛٲوِتھ تٔمۍ سٕنز بند گی کران، یَس نہٕ تۅہیہِ خٲطرٕ نقصانُک اختیار چُھ  ،نہ چُھس نفع دِنُک اختیار؟ حالانکہ سارِنٕے ہُند بوزن وول تہٕ سورُے کینٛہہ زانن وول چُھ صرف اللہ تعالیٰ ہٕے ۔"
  5,77,"۔ؤنِیوٗکھ اے اہلِ کتاب،نا حق مَہ کٔرِو پننِس دینس منٛز غلو ﴿یعنے حدٕ مَہ نیرِ و ﴾ تہٕ تِمن لُکن ہٕندٮ۪ن تخیلا تن ہٕنز پیر وی مَہ کٔرِ و یِم تۅہیہِ برونٛہہ پانہٕ گمراہ سپٕدۍ، تہٕ واریاہ کٔرِکھ گُمرا ہ تہٕ ڈٔلۍ سَوَا  ٔلسبیل ﴿یعنی سیٚزِ وَتہِ ﴾ نِشہِ ۔ع"
  5,78,"۔بنی اسرا یلو منٛزٕ یِمو لُکو کُفرٕ چ وَتھ اختیار کٔر تِمن پٮ۪ٹھ آیہِ داوٗد علیہ السلام تہٕ عیسیٰ ابن مر یم علیہ السلامن سنٕزِ زیوِ لعنت کر نہٕ، تِکیازِ تِم ٲسۍ سر کش سپٕدۍ مٕتۍ تہٕ تِمو آسہٕ زیادتیہِ لا جمٕژ کر نہِ ،"
  5,79,"۔ تِمو اوس اکھ أکِس بُرٕ ہ کامیٚن ہٕندِ اَتُر کر نہٕ نِشہِ پتھ رٹُن ترٛ وومُت۔ ﴿پرٛتھ قو مُک بِگا ڑ چُھ گۅڈٕ کینژھو نفر و سٍتۍ شر وع سپدان۔اگر قو مُک اجتمٲعی ضمیر زند ہ آسان چُھ تیٚلہِ چھےٚ عا م را ے تِمن بِگر یمیتیٚن  نفر ن دبٲوِ تھ تھاوان تہٕ قو م چُھنہٕ بحثیتِ مجمو عی ﴿اند ہیتھ﴾ بِگر ان۔ البتہ اگر قو م تِمن نفر ن ہٕندِ س معا ملس منٛز تَسا ہُل ﴿آلژار﴾ شر وع کران چُھ تہٕ غلط کار لُکن چِھ تراوان ملا مت کر نہٕ بجا ے پننہِ سو سایٹی منٛز غلط کٲر ی خٲطرٕ یلہٕ ، تیٚلہِ چھےٚ پتہٕ وارٕ وارٕ سۅ ے خر ٲبی یۅسہٕ گۅڈٕ کینژھن نفر ن تام محدود ٲس پوٗرٕ قو مس منٛز پھٔہلان۔ یۅہے چیز اوس یُس ٲخر کا ر بنی اسرا یل کہ بِگر نُک و جہ بنیا و۔﴾  بُرٕ ہ طر زِ عمل اوس یُس تِمو وَرتو و ۔"
  5,80,"۔از چِھو توٚہی واریاہ لُکھ تِمو منٛزٕ تِتھۍ وُچھان یِم ﴿اہلِ ایمانن ہٕندِس مقا بلس منٛزٕ ﴾ کٲفر ن چِھ حما یت تہٕ رفا قت کران، یقیناً چُھ سٮ۪ٹھاہ بُرٕ ہ انجام ییٚمِچ تیٲری تِہندیو نَفسو تِہِندِ خٲطرٕ کٔر مٕژ چھےٚ، اللہ تعالیٰ چُھ تِمن پٮ۪ٹھ غضبناک سپُد مُت، تہٕ تِم چِھ ہمیشہ روزن وٲلِس عذا بس منٛز مبتلا سپدن وٲلۍ۔"
  5,81,"۔اگر پٔزِ پٲٹھۍ یِم لُکھ خُدا یس تہٕ پیغمبر س صلی اللہ علیہ وسلمس تہٕ تتھ چیز س مانن وٲلۍ آسہن یُس  پیغمبر س پٮ۪ٹھ نٲزِل اوس سپُد مُت ،تیٚلہِ بنا و ہن نہٕ زانٛہہ ﴿اہلِ ایمانن ہِندِس مقا بلس منٛز ﴾ کٲفِر ن پنٕنۍ رفیق،مگر یِمو منٛزٕ چِھ اکثر لُکھ اللہ تعالیٰ سٕندِ اطا عت نِشہِ درٛامٕتۍ۔"
  5,82,"۔توٚہۍ وُچھوکھ اہل ایمانن ہٕندِس عدا وتس منٛز سارِوٕے کھۅتہٕ زیادہ سخت یہوٗد تہٕ مشر کین، تہٕ ایمان اَنن والیٚن خٲطرٕ وُچھوٗکھ دو ستی منٛز سٮ۪ٹھاہ نکھہٕ تِم لُکھ یِمو ووٚنمُت اوس زِ أسۍ چِھ نصا ر یٰ ۔ یہِ چُھ امہِ وجہ کِنۍ زِ یِمن منٛز چِھ عبا دت گُزار عٲلم تہٕ تارُک الدّنیا فقیر،تہٕ تِمن منٛز چُھنہٕ نفسُک غرور کینٛہہ۔"
  5,83,"۔ییٚلہِ تِم یہِ کلام بوزان چِھ یُس رسول ﴿صلی اللہ علیہ وسلمس﴾ پٮ۪ٹھ نٲزِل چُھ سپُد مُت پتہٕ چِھو توٚہۍ وُچھان زِ حق پرٛزٕ ناو نہٕ کہ اثرٕ سٍتۍ چُھ تِہنزن أچھن منٛز اوٚ ش بُکہٕ یِوان تِمن چُھ نیٖرِ تھ ژلان زِ  پروردِگارٕ،اَسہِ اوٚ ن ایمان،سو ن ناو لیکھ گوٲہی دِنہٕ والیٚن منٛز"
  5,84,"۔بیٚیہِ چِھ تِم ونان زِ :ٲخر کیازِ اَنَو نہٕ أسۍ خُدا یس پٮ۪ٹھ ایمان تہٕ یُس حق اسہِ نِشہِ آمُت چُھ سُہ کیا زِ مانَو نہٕ أسۍ ییٚلہِ زَن اَسہِ طمع چُھ امہِ کتھہِ ہُند زِ سو ن ربّ گژِھہ اَسہِ صا لح بند ن منٛز شٲمل کرُن؟"
  5,85,"۔تِہِندِ امہِ قو ل کہِ وجہ کِنۍ کٔرۍ خُدا ین تِمن تِتھۍ جنت عطا یِمن بٔنۍ کِنۍ  کۅلہٕ چھےٚ پکان،تہٕ تِم روزن ہمیشہ تِمن منٛز ۔یہِ جزا چُھ نیک رٔویہِ اختیار کر ن والیٚن خٲطرٕ۔"
  5,86,"۔روٗدۍ تِم لُکھ یِمو سٲنۍ آیات ماننہٕ نِشہِ انکار کوٚر تہٕ دوٚ پُکھ یِم چِھ اَپٕزۍ تِم چِھ جہنمٕکۍ حقدار۔ع"
  5,87,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت یِم پاک چیز خُدا ین تُہٕندِ خٲطرٕ حلال چِھ کٔرِمٕتۍ تِم مَہ کٔریوٗکھ حرام، ﴿یتھ آیتس منٛز چھےٚ زٕ ہ کتھہٕ ارشاد سپٕز مٕژ۔ اکھ یہِ زِ خۅد مَہ بٔنِو پانہٕ حلال و حرا مٕکۍ مختا ر ۔ حلال چُھ تی یہِ خُدا ین حلال کوٚر تہٕ حرام چُھ تی یہِ خُدا ین حرام کوٚر ۔پننہِ اختیارٕ کٔرِیوٗن کانٛہہ حلال چیز حرام تیٚلہِ یِیِو اللہ تعالیٰ سٕندِ قا نو ن بجا یہِ نفس کہ قا نو نٕکۍ پیروکار قرار دِنہٕ ۔ دوٚیُم کتھ یہِ زِ عیسٲے رٲہِبن ،ہیٚندۍ جو گین ، بودھ مذ ہب کیٚن بھِکشوٗوَن تہٕ اشرا قی متصَوِّ فینَن ہٕندۍ پٲٹھۍ مَہ کٔرِو رہبٲنیت تہٕ بُنیٲدی لذ ت تر ک کر نُک طر یقہٕ اختیار،اشرٲقۍ متصَوِّ فین﴿ گٔیہِ  سۅ چھۅ کھ یۅسہٕ دوٗرِ دوٗری پننیٚن شاگردن تصفیہ قلب تہٕ کشف کہ ذر یعہ تعلیم چھےٚ دِوان ﴾ تہٕ حدٕ نِشہِ مَہ نیٖرِ و برونٛہہ خُدا یس چِھ زیادتی کر ن وٲلۍ سخ نا پسند۔"
  5,88,"۔یِکینژھاہ حلال تہٕ پاک رزق خُدا ین تۅ ہیہِ دِیتمُت چُھنو سُہ کھیٚیِو چیٚیو،تہٕ تس خُدا ے سٕنزِ نافر مٲنی نِشہِ روزِ و بچا ن یس پٮ۪ٹھ تۅہیہِ ایمان چُھو اوٚ نمُت ۔"
  5,89,"۔توٚہۍ لُکھ یِم بے معنی قسم کھیوان چِھو تِمن پٮ۪ٹھ چُھنہٕ اللہ تعالیٰ رَٹا ن مگر یِم قسم توٚہۍ زٲنِتھ مٲنِتھ کھیوان چِھو تِمن پٮ۪ٹھ کر یو سُہ ضرور تۅہیہِ پرٛژھہٕ گٲر ﴿یُتھ قسم پھُٹرا ونُک ﴾ کفارٕ ہ چُھ یہِ زِ دا ہ مسکین کھیٲوِ یوٗکھ سُہ در میانہٕ در جُک کھیٚن یُس توٚہۍ پنٕنۍ شُر ۍ بٲژ کھیا وان چھوٗکھ یا لٲگِو تِمن پَلو،یا کٔرِ یوٗن اکھ غلا م آزا د تہٕ یَس نہٕ امِیُک طا قت آسہِ سُہ تھٲوِ ن تر ٮ۪ن دۅ ہن روزٕ ہ یہِ چُھ تُہٕندٮ۪ن قسمن ہُند کفا ر ہ ییٚلہِ زَن توٚہۍ قسم کھیٚتھ سُہ پُھٹرٲوِ و، پننیٚن قسمن ہٕنز حفا ظت کٔرِو ،یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ پنٕنۍ احکا م تُہندِ خٲطرٕ وا ضح کران،شاید زِ توہۍ کٔرِ و شکُر ادا۔"
  5,90,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت یہِ شرا ب تہٕ زار ، یِم پۅ تٕلۍ تہٕ پانٛسہٕ،یِمہٕ سار یے چھےٚ گندٕہ شیطٲنی کامہٕ، یِمو نِشہِ کٔرِ و پر ہیز ،اُمید چھےٚ زِ تۅہیہِ گژھیو فلا ح نصیب۔﴿شرا ب کِس حُر متس متعلق ٲسۍ وُنیستام زٕ ہ حُکم آمٕتۍ یِم سورۂ بقرہ آیت 219، تہٕ سورۂ نسا آیت 43 ہس منٛز گٔیہِ پتھ کُن۔ یہِ ٲخر ی حُکم یِنہٕ برونٛہہ کٔرۍ نبی صلی اللہ علیہ وسلموأکِس خطبس منٛز لُکھ خبردار زِ خُدا یس چُھ شرا ب سخ نا پسند، دوٗر چُھنہٕ زِ امہِ کہ مکمل حُر متُک حُکم یِیہِ ،لہٰذا یِمن یِمن لُکن نِشہِ شراب موجود چُھ تِم کٕنِن سُہ۔ امہِ پتہٕ کینٛہہ کال گٔژِھتھ سپٕز یہِ آیت نٲزِل تہٕ حضور صلی اللہ علیہ وسلم کر نو و اعلان زِ وۅ نۍ یِمن نِشہِ شرا ب چُھ تِم نہ ہیٚکن تتھ چیٚتھ ،نہٕ ہیٚکن کٕنِتھ بلکہ کٔرِ ن تتھ ضا یع۔چنا نچہِ آو تمی وقتہٕ مد ینہٕ چن گلیِن منٛز شراب دٲرِتھ دِنہٕ ﴾"
  5,91,"۔شیطا ن چُھ یہِ یژھان زِ شرا ب تہٕ زارٕ سٍتۍ ترٛاوِ تُہِند ٮ۪ن دِلن منٛز عداوت تہٕ بُغض تہٕ تۅہیہِ رُکا ویو اللہ تعالیٰ یاد کر نہٕ نِشہِ تہٕ نماز نِشہِ ،کیا توٚہۍ روٗزِ وٕہ تِمو چیز و نِشہِ باز؟"
  5,92,"۔ اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز کتھ مٲنِو تہٕ پھیرِ و با ز البتہ اگر تۅہیہِ حکمِ عدو لی کٔرٕ و تیٚلہِ زٲنِو زِ سٲنِس رسولس صلی اللہ علیہ وسلمس پٮ۪ٹھ ٲس صرف صا ف صا ف حکم وا تنا ونٕچ ذمہٕ دٲر ی۔"
  5,93,"۔یِمو لُکو ایمان اوٚ ن تہٕ لاجکھ نیک عملہٕ کر نہِ تِمو یِکینژھاہ گۅڈٕ ہ کھیوٚ مُت چوٚمُت اوس تتھ پٮ۪ٹھ سپدِ نہٕ کانٛہہ گرفت  بشر طیکہ تِم روزن آیند ہ تِمو چیز و نِشہِ بچا ن یِم حرا م چِھ کر نہٕ آمٕتۍ تہٕ ایمانس پٮ۪ٹھ روزَ ن ثٲبت قد م تہٕ نیک کامہِ کرَن پتہٕ ییٚمہِ ییٚمہِ چیزٕ نِشہِ رُکا و نہٕ یِن تمہِ نِشہِ رُکن تہٕ یُس اللہ تعالیٰ سُند فر مان آسہِ سُہ مانن ، پتہٕ تھاو ن پر ہیز گٲر ی سان نیک رٔوِیہِ ، اللہ تعالیٰ چُھ نیک کردار لُکن پسند کرا ن ۔ ع"
  5,94,"۔ اے لوٗکو یِمو ایمان چُھو اوٚ نمُت  اللہ تعالیٰ ترٛاو یو تۅ ہیہِ تَس شکارٕ سٕندِ ذریعہ سخت آز مٲیشہِ منٛز یُس بالکل تُہٕندٮ۪ن اَتھن تہٕ نیز ن ہٕندِس زدس منٛز آسہِ یہِ وُچھنہٕ مۅ کھہٕ زِ تۅہیہِ منٛز کُس چُھ تس غٲیبا نہٕ پٲٹھۍ کھۅژان، وۅ نۍ یُس اَمہِ تنبیہ پتہٕ اللہ تعالیٰ سٕندِ مقرر کر نہٕ آمتہِ حدٕ نِشہِ برونٛہہ درٛا و تس خٲطرٕ دگ تُلوُن عذا ب۔"
  5,95,"۔اے لوٗکو ،یِمو ایمان چُھو اوٚ نمُت اِحرا م کِس حا لتس منٛز مَہ مٲرِیوٗن شِکا ر۔﴿ انسان کٔرِ تن خوا ہ پانہٕ شکار یا بیٚیہِ کٲنٛسہِ کٔرِ تن شکار کر نس منٛز کُنہِ تہِ پٲٹھۍ مدد۔دۅ شو ے کتھہٕ چھےٚ اِحرا م کِس حا لتس منٛز منع ، امہِ علا وہ اگر شکار محرَم ﴿یُس اِحرا م لٲگِتھ آسہِ ﴾ سٕندِ خٲطرٕ مار نہٕ آسہِ آمُت اَمہِ پتہٕ تہِ چُھنہٕ مَحرَم سٕندِ خٲطرٕ یہِ کھیوٚ ن جٲیز۔ البتہٕ اگر کٲنٛسہِ پا نس خٲطرٕ شکار کوٚر مُت آسہِ تہٕ سُہ دِیہِ اَمہِ منٛزٕ مَحرَمَس بطور  تحفہٕ کینٛہہ ،سُہ کھیٚنس چُھنہٕ کانٛہہ پرواے۔امہِ حُکمہٕ نِشہِ چِھ اِیذا دِنہٕ وٲلۍ جانور مُچھہِ۔ سرُپھ ،بِیچ ، ہلکٔرۍ ہوٗنۍ تہٕ امہِ قسمٕکۍ با قی جانور یِم انسانس نقصان واتناوَن وٲلۍ چِھ ہیٚکن اِحرا م کِس حا لتس منٛز مار نہٕ یِتھ ﴾ تہٕ اگر تۅہیہِ منٛزٕ کانٛہہ زٲنِتھ مٲنِتھ یہِ کرِ تیٚلہِ یُس جانور تٔمۍ مور مُت آسہِ ، تٔسۍ یو ت اکھ جا نور آسہِ چا ر وایو منٛزٕ تس بطورِ نذر دِیُن ییٚمیُک فٲصلہِ تۅہیہِ منٛزٕ زٕ ہ عٲد ل انسان کر ن تہٕ یہِ نذ را نہٕ یِیہِ کعبہ وا تنا و نہٕ، یا اگر یہِ سپُد نہٕ تیٚلہِ آسن اَمہِ گنا ہ کِس کفا رس منٛز کینٛہہ مسکین کھیٚن کھیٚا وٕنۍ۔نَتہٕ آسن اتھ بقدر روزٕہ تھاو نہِ ، تا کہ سُہ وُچھِہ پننہِ کرِ متیُک مزٕہ ،برونٛہہ یِکینژھاہ سپُد سُہ کوٚر خُدا ین معا ف البتہ وۅ نۍ اگر کٲنٛسہِ یہِ حر کت دُبارٕہ کٔر تیٚلہِ ہیٚیہِ تس اللہ تعالیٰ بد لہٕ ،اللہ تعالیٰ چُھ سارِنٕے پٮ۪ٹھ غٲلب تہٕ سُہ چُھ بد لہٕ ہیٚنُک طا قت تھاوان۔"
  5,96,"۔ تپہندِ خٲطرٕ آو سمندرُک شِکار بیٚیہِ سُہ کھیوٚ ن حلال کر نہٕ۔ یتھ جایہِ توٚہۍ ٹھٔہرِ و تَتہِ تہِ ہیٚکِو سُہ کھیٚتھ تہٕ قا فلس خٲطرٕ ہیٚکِو زادِراہ تہِ بنٲوِتھ۔ البتہ خشکی ہُند شکار،یوٚت تام توٚہۍ اِحرا م کِس حا لتس منٛز ٲسِو، چُھ تۅہیہِ پٮ۪ٹھ حرا م کر نہٕ آمُت لہٰذا بٔچِو تس اللہ تعالیٰ سٕنزِ نا فر مٲنی نِشہِ ییٚمۍ سٕنزِ پیشی اندر توٚہۍ سٲر ی یِیِو گھیرٕ کٔرِ تھ اَننہٕ۔"
  5,97,"۔ خُدا ین بنو و مکانِ محترم ، کعبہ لُکن خٲطرٕ ﴿اجتمٲعی زند گی  ہٕندِ ﴾ قیا مُک ذر یعہ تہٕ ماہِ حرا م بیٚیہِ قر بٲنی ہٕندۍ جا نور تہٕ قلادٕہ تہِ ﴿بنٲوِن اتھ منز مُعا وِن ﴾ تاکہِ تۅہیہِ لگہِ پے زِ اللہ تعالیٰ چُھ آسمان کیٚو تہٕ زمین کیٚو سارِوٕے حا لاتو نِشہِ با خبر تہٕ تس چُھ پرٛتھ چیزُک علم۔"
  5,98,"۔خبردار سپدِ و! اللہ تعالیٰ چُھ سزا دِنس منٛز تہِ سخت تہٕ اَتھ سٍتۍ چُھ سٮ۪ٹھاہ در گُز ر تہٕ رحم کر ن وول تہِ۔"
  5,99,"۔رسول ﴿صلی اللہ علیہ وسلمن ﴾ پٮ۪ٹھ چھےٚ صرف پیغام وا تنا وٕنٕچ ذمہٕ دٲر ی برونٹھ کُن چُھ تُہندٮ۪ن نَنہِ وا نہٕ کیٚن تہٕ ژھا یہِ تھاو نہٕ آمتیٚن سارِ نٕے حا لاتن ہُند زانن وول اللہ تعالیٰ۔ اے پیغمبر صلی اللہ علیہ وسلم،یِمن ؤنِو زِ پاک تہٕ نا پاک  چِھنہٕ بہر حال یکسا ن خوا ہ نا پاکٕچ سۅ لبہٕ گی ٲسِتن کٲژا ہ تہِ فر یفتہٕ کر ن واجِنۍ،﴿یہِ آیت چھےٚ قدر و قٍمتُک اکھ نوٚوُے معیا ر پیش کران یُس ظٲہر بیٖن انسان سٕندِ معیار نِشہِ بالکل مختلف چُھ۔ظٲہر بیٖن سٕنزِ نظرٕ منٛز چُھ ہتھ 100 ، رۅ پیہِ پا نژن رۅ پین ہٕندِس مقابلس منٛز لٲزمی طور زیادٕہ قیمتی تِکیازِ ہُہ چھُ ہَتھ یِمہٕ چھےٚ پانٛژھ ،البتہ یہِ آیت چھےٚ ونان زِ اگر ہَتھ رۅپیہ اللہ تعالیٰ سٕنز نا فر مٲنی کٔرِ تھ حا صل آیہِ کر نہٕ تِمہٕ چھےٚ نا پا ک ،تہٕ اگر پا نژھ رۅپیہِ اللہ تعالیٰ سٕنز فر مانبرداری کٔرِ تھ کما و نہٕ آسن آمژٕ تِمہٕ چھےٚ پاک ، تہٕ نا پاک ٲسِتن مقدارس منٛز کوتا ہ تہِ زیادٕہ، بہر حال ہیٚکہِ نہٕ سُہ پاک چیز س برابر ٲسِتھ ﴾"
  5,100,"۔پس اے لوٗکو یِم عقلہِ وٲلۍ چِھو، اللہ تعالیٰ  سٕنزِ نا فر مٲنی نِشہِ روٗزِ و بٔچِتھ پکان امید چھےٚ زِ تۅ ہیہِ سپد یو فلا ح نصیب۔ع"
  5,101,"۔اے لوٗ کو یِمو ایمان چُھو اوٚ نمُت تِمہٕ کتھہٕ مَہ ٲسِو پٕرٛژھان یِمہٕ تۅہیہِ پٮ۪ٹھ ظٲہر کر نہٕ یِن تہٕ تۅہیہِ گژھنَو نا گوار، ﴿نبی صلی اللہ علیہ وسلمن ٲسۍ کینٛہہ لُکھ عجیب عجیب قسمٕکۍ فضو ل سوال پٕرٛژھان یِمن سوا لن نہ ٲس دین کِس کُنہِ معا ملس منٛز ضرورت آسان تہٕ نہ ٲس دُنیا کِس کُنہِ معا ملسٕے منٛز۔ اتھ پٮ۪ٹھ  چُھ تنبیہ آمُت فر ماو نہٕ ۔﴾ البتہٕ  اگر توٚہۍ تِمہٕ کِتھہٕ تَمہِ وقتہٕ پٕرٛژھو ییٚمہِ ساعتہِٕ قرآن  نٲزِل آسہِ سپدان تیٚلہِ یِن تِمہٕ تۅہیہِ پٮ۪ٹھ ظٲہر کر نہٕ ﴿ویژھنا و نہٕ ﴾ وُنِیُستام یِکینژھاہ تۅہیہِ کوٚرُو سُہ کوٚر خُدا ین معا ف سُہ چُھ در گز ر کر ن وول تہٕ بُردبار۔"
  5,102,"۔تۅ ہیہِ برونٹھ ٲسۍ أکۍدٔرۍ اَمی قسمٕکۍ سوا ل کٔرِ مٕتۍ پتہٕ سپٕدۍ تِم لُکھ یِمنٕے کتھن ہٕندِ وجہ کِنۍ کُفرس منٛز مبتلا ۔"
  5,103,"۔خُدا ین نہ چُھ کانٛہہ بَحیرہ مُقرر کوٚر مُت نہ سایبہ نہ وصیلہٕ تہٕ نہ حَام۔﴿یہِ چھےٚ اہلِ عر بن ہٕندٮ۪ن تو ہماتن ہٕنز ذکر۔ بَحیرہ چِھ   تس اوٗنٹنہِ ونان یۅسہٕ پانژِلٹہِ پیا مٕژ آسہِ تہٕ پٔتِمہِ لٹہِ آسیس نَر بچہِ  زامُت ، جٲہلیت  کِس زمانس منٛز ٲسۍ اہلِ عر ب أمِس کنس تٕرٛتھ دِتھ یلہٕ تراوان۔پتہٕ نہ اوس کانٛہہ أمِس سوار سپدان، نہ او س أمۍ سُند دۅ د یِوان  چیٚنہٕ ،نہ ٲس أمۍ سٕنز جتھ یِوان نیٚتہٕ نہٕ۔أمِس اوس حق زِ کُنہِ تہِ کھہَس تہٕ کُنہِ تہِ نَیہِ منٛز ہیٚکہِ ہے گا سہٕ کھیٚتھ تہٕ کُنہِ تہِ یارٕ بلہٕ ہیٚکہِ ہے تر یش چیٚتھ۔سا یبہ چِھ تس اونٹس یا اونِٹنہِ ونان یَس کانٛہہ نیت پوٗرٕ گژھنہٕ مۅ کھہٕ یا دود بلنہٕ خٲطرٕ یا کُنہِ خطرٕ نِشہِ بَچنہٕ خٲطرٕ بطور شُکر انہٕ آسہِ کنس  تٕر تھ دِنہٕ آمُت۔امہِ علا وٕہ یۅسہٕ اوٗنٹِنۍ دَہہِ لٹہِ پیا مٕژ آسہِ تہٕ تس آسن ہیٚتھٕے مادٕہ ژَھو زامٕتۍ ، سۅ تہِ ٲس یلہٕ یِوان ترا و نہٕ۔ وصیلتہ ، اگر ژھا و جہِ گۅڈنِیُک بچہ نر آسہِ ہے سُہ اوس خُدا ین ہٕندِس نا و س پٮ۪ٹھ ذبح یِوان کر نہٕ تہٕ ہرگاہ تس گۅڈِنچہِ لٹہِ مادٕہ ژَھو زیوِ  ہے سُہ اوس یِوان پا نس نِشہِ تھا و نہٕ، البتہ اگر نر تہٕ مادٕہ یِکہٕ وَٹہٕ زیو ہَن تیٚلہِ اوس نَر ذبح کر نہٕ بجا ے خُدا ین ہٕندِس ناوس پٮ۪ٹھ یلہٕ یِوان تراو نہٕ تہٕ أمۍ سُند ناو اوس وصیلہ۔حَام، اگر کٲنٛسہِ اوٗنٹ سُند زُر سوارِ لا یق گژِھہ ہے تیٚلہِ اوس بُڈٕ اونٹ یلہٕ  یِوان تراونہٕ۔امہِ علا وٕہ ییِمس او نٹ سٕندِ نطفہٕ سٍتۍ داہ بچہِ زیو ہن تَس تہِ ٲس آزادی میلان﴾مگر یِم کٲفر چِھ خُدا یس پٮ۪ٹھ اَپٕز تہمت لگاوان تہٕ تِمن منٛز چِھ اکثر بے عقل ﴿زِ امہِ قسمٕکۍ وَہمہٕ چِھ رٹان﴾۔"
  5,104,"۔تہٕ ییٚلہِ یِمن وَننہٕ چُھ یِوان ؤلِو تتھ قا نو نس کُن یُس خُدا یس چُھ نٲزِل کوٚر مُت، تہٕ ؤلِو پیغمبرس کُن تورٕ چِھ تِم جوا ب دِوان: سانہِ خٲطرٕ چُھ بس سُے طر یقہٕ سٮ۪ٹھاہ  یتھ پٮ۪ٹھ اسہِ پنُن مو ل بُڈِ بب چُھ وُچھمُت۔ کیا یِم روز نہٕ مٲلِس بُڈِ بب سُندُے تقلید کران۔اگر چہِ تِمن کِہِنۍ آسہِ نہٕ پے تہٕ صحیح وَتہِ ہٕنز آسہِ نہٕ تِمن خبرٕ ے ؟"
  5,105,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت پنٕنۍ فکر کٔرِو ، بیٚیہِ کٲنٛسہِ ہِنزِ گُمرٲہی سٍتۍ چُھنہٕ تۅہیہ، کِہِنۍ بِگرا ن اگر توٚہۍ خۅدراہِ راستس پٮ۪ٹھ چِھو۔﴿یعنی اَمہِ بجا یہِ زِ انسان روزِ پرتھ ساعتہٕ یہِ وُچھان زِ فلٲنۍ کیا چُھ کران تہٕ فلٲنۍ سٕندِس عقیدتس منٛز کیا خرٲبی چھےٚ تہٕ فلٲنۍ سٕنز ن عملن منٛز کیا بُرٲیی چھےٚ،تس پزِ یہِ وُچُھن زِ پانہٕ کیا چُھ سُہ کرا ن ،البتہ ییٚمہِ آیتُک مَنشہِ چُھنہٕ ہر گِز تہِ یہِ زِ انسان کٔرِن بس پننہِ نجا تٕچ فکر، با قین ہٕندِ اصلا حٕچ فِکر مَہ کٔرِن۔حضر ت ابو بکر  صد یق رضی اللہ عنہ چِھ پننِس أکِس خطبس منٛز امہِ غلط فہمی ہُند تردید کران فر ماوان: لوٗکو ، توٚہۍ چِھو یہِ آیت پران تہٕ چِھو غلط تٲوِیل کران ۔مےٚ وُچھ رسول اللہ صلی اللہ علیہ سلم یہِ فر ماوان زِ ییٚلہِ لُکن ہُند حال یہِ سپدِ زِ تِم وُچھن بُرٲیی تہٕ تتھ کر ن نہٕ بد لاونٕچ کوٗشش، ظٲلِمس  وُچھن ظُلم کرا ن تہٕ تٔمۍ سُند اتھہٕ رٹن نہٕ پتھ تیٚلہِ چَھنہٕ یہِ کتھ دوٗر زِ اللہ تعالیٰ وَلہِ سارِنٕے پننِس عذا بس منٛز۔ اللہ تعالیٰ سُند قسم تۅہیہِ چُھو لٲزِ م زِ ، رٕژرُک دِیو حُکم تہٕ بُرٲیی نِشہِ رُکٲوِ و ﴿ اگر یہِ کٔرِ و نہٕ ﴾ اللہ تعالیٰ کرِ تۅہیہِ پٮ۪ٹھ تِم لُکھ مُسلط یِم تۅہیہِ منٛز سارِوٕے کھۅتہٕ بد تر آسن تہٕ تِم وا تنا و نو تۅہیہِ سخ تکلیف ، پتہٕ منگن تُہٕندۍ نیک لُکھ خُدا یس دُعا مگر تِم گژھن نہٕ قبو ل ۔ خُدا یس کُن چُھو تۅہیہِ سارِ نٕے پوٚت پھیٖرِ تھ گژُھن پتہٕ وَنیو سُہ تۅہیہِ زِ توٚہۍ کیا ٲسِو کرا ن۔"
  5,106,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ییٚلہِ تۅہیہِ منٛز کٲنٛسہِ مو تُک وقت واتہِ تہٕ سُہ آسہِ وصیت کران تیٚلہِ چُھ تٔمۍ سٕندِ خٲطرٕ شہا دتُک نصا ب یہِ زِ تُہٕندِجما عتہٕ منٛزٕ گژھن زٕ صا حبِ عد ل انسان گواہ بناو نہٕ یِنۍ، ﴿یعنی دین دار،پر ہیز گار تہٕ قا بِل اعتماد مُسلمان ﴾ یا اگر توٚہۍ سفر کِس حا لتس منٛز ٲسِو تہٕ تَتہِ یِیہِ مو تُک مصیبت پیش تیٚلہِ گژھن غیر لُکوٕ ے منٛزٕ زٕ ہ گوا ہ تھاوٕ نۍ ، پتہٕ ہرگاہ کانٛہہ شک با سہِ تیٚلہِ گژھن نمازِ پتہٕ دۅ شو ے گوا ہ ﴿مسجدِ اندر ﴾ رُکا وٕ نۍ تہٕ تِم گژھن اللہ تعالیٰ  سُند قسم کھیٚتھ وَنٕنۍ زِ أسۍ چِھنہٕ ذٲتی فٲیدہ بد لہٕ شہا دت کٕنَن وٲلۍخوا ہ سُہ سو ن رشتہٕ دارٕ ے کو نہٕ آسہِ ﴿أسۍ چِھنہٕ تس رعا یت کر ن وٲلۍ۔﴾ تہٕ نہ چِھ أسۍ اللہ تعالیٰ سٕندِ وا سٕطچ گوٲہی چُھپا و ن وٲلۍ اگر اَسہِ یہِ کوٚر تیٚلہِ گژھو أسۍ گنا ہ گار ن منٛز یِنۍ گٕنزراونہٕ۔"
  5,107,"۔البتہ اگر پے لگہِ زِ دۅ شو یو چُھ پنُن پان گنا ہس منٛز مبتلا کوٚر مُت تیٚلہِ گژھن تِہٕنزِ جایہ، بیٚیہِ زٕ ہ شخص یِم تِہِندِ بہ نسبت  شہادت دِنہٕ خٲطرٕ اہل تر آسن تِمَو منٛزٕ کھڑا سپدٕنۍ یِمن حق تلفی آسہِ گٔمٕژ تہٕ تِم گژھن قسم کھیتھ ونٕںۍ زِسٲنۍ شہادت چھے تُہٕندِ شہادت  کھۅتہٕ زیادٕہ برحق تہٕ اَسہِ چَھنہٕ پننہِ گوٲہی منٛز کانٛہہ زیادتی کٔر مٕژ،اگر أسۍ یہِ کر و تیٚلہِ آسو أسۍ ظا لِمو منٛزٕ ۔"
  5,108,"۔ امہِ طریقہٕ یِیہِ زیادٕہ تو قع  کر نہٕ زِ لُکھ دِن ٹھیک ٹھیک شہادت،یا کر ن کم از کم اَمہِ کتھہِ ہُندُے خو ف زِ  تِہندِ یٚو قسمو پتہٕ گوٚژھ نہٕ با قین ہٕند یو قسمو سٍتۍ تِہُند تردید سپدُن۔خُدا یس کھوٚژِو تہٕ بوٗزِ و اللہ تعالیٰ چُھ نا فر مٲنی کر ن والیٚن پننہِ رہنمٲیی نِشہِ  محر و م کران ۔ ع"
  5,109,"۔ییٚمہِ دۅ ہ اللہ تعالیٰ سارِنے رسولن جمع کٔرِتھ پرٛژِھہ زِ تۅہیہِ کیا جوا ب اوو دِنہٕ۔﴿یعنی قیا مت کہ دۅ ہ یِیہِ رسولن پرٛژھنہٕ زِ اسلامس کُن یۅسہٕ دعوت تۅہیہِ دِژمٕژ ٲسٕو تمِیُک کیا جو اب دُیتنو  دُنیا ہن تۅہیہِ ؟﴾ تِم کر ن عر ض زِ اَسہِ چُھنہٕ کِہِنۍ علم ، توٚہۍ چِھو تمام پوشید ہ حقیقتہٕ زانان۔"
  5,110,"۔پتہٕ کٔرِ و تصور تمہِ مو قعُک ییٚلہِ اللہ تعالیٰ فر ماوِ زِ : اے مر یم سٕندِ فر زند عیسیٰ ﴿علیہ السلام﴾،یاد کر میٲنۍ سۅ نعمت یۅسہٕ مےٚ ژےٚ تہٕ چا نہِ ماجہِ ٲس عطا کٔرمٕژ، مےٚ کوٚرُے ژےٚ روحِ پا ک سٍتۍ مدد، ژٕ اوسُکھ منٛزِ لِس منٛز تہِ لُکن سٍتۍ کتھہٕ کران تہٕ بوٚڈ گٔژھتھ تہِ  دِژ  مےٚ ژےٚ کتا ب تہٕ حکمت بیٚیہِ توراتٕچ  تہٕ انجیلٕچ تعلیم ،ژٕ اوسُکھ میانہِ حُکمہٕ پر ندٕہ سٕنزِ شکلہِ ہُند میٚژِ پُتلہٕ بناوان، تہٕ تتھ اوسُکھ پھۅکھ دِوان تہٕ سُہ اوس میانہِ حُکمہٕ پر ندٕہ بنان،ژٕ او سُکھ زیٚنہٕ گرِ پیٹھُک اوٚ ن تہٕ میٚند ۍ لد میانہِ حُکمہٕ ٹھیک کران، ژٕ اوسُہکھ مُردہ میانہِ حُکمہٕ کڑان۔﴿یعنی موت کہ حالت نِشہِ کٔڑِتھ زند گی ہٕندِس حا لتس منٛز اَنان ﴾ پتہٕ ییٚلہِ ژٕ بنی اسرا یلس نِشہِ وا ضح نِشٲنیہِ ہیٚتھ ووتُکھ ، مےٚ بچو و مَکھ ژٕ تِمن نِشہِ تہٕ یِم لُکھ تِمن منٛز منکرِ حق ٲسۍ تِمو ووٚ ن زِ یِمہٕ نشٲنیہِ چَھنہٕ جادو گر ی ورٲے بیٚیہِ کِہِنۍ۔"
  5,111,"۔پتہٕ ییٚلہِ مےٚ حوارین اشارٕہ کوٚرزِ مےٚ پٮ۪ٹھ تہٕ میٲنِس رسولس پٮ۪ٹھ أنِو ایمان پتہٕ ووٚ ن تِمو: اسہِ  اوٚ ن ایمان تہٕ گواہ روٗزِ و زِ أسۍ چِھ مسلم۔ ﴿حوا ر ین ہٕندِس سلسلس منٛز﴾ گژِھہ یہِ وا قع تہِ یا د روزُن۔﴿چو نکہ حوارین ہِنزِ ذِکر ٲس آمٕژ امہِ موجو ب چُھ کلا مُک سلسلہ پھُٹرٲوِتھ جملہ معتر ضہ رٔنگۍ یتھ جایہِ حوا رِ ینٕے متعلق بیٚیہِ أکِس وا قعس کُن اشارٕہ کر نہٕ آمُت ییٚمہِ نِشہِ یہِ کتھ صا ف چھےٚ ننان زِ یِمو شا گردو مسیح علیہ السلامس نِشہِ برا ہِ راست تعلیم ٲس حا صل کٔر مٕژ تِم ٲسۍ مسیح علیہ السلامس اکھ انسان تہٕ محض اللہ تعالیٰ سُند اکھ بند ہ سمجھان تہٕ تِہِندِس و ہم و گما نس منٛز تہِ اوس  نہٕ پننِس مُرشد س متعلق خُدا ے یا شر یک خُدا، یا فر زندِ خُدا ے آسنُک تصور۔امہِ علا وٕہ یہِ زِ مسیح علیہ السلامَو اوس پنُن پان تہِ تِمن برونٛٹھہٕ کنہِ أکِس بے اختیار بند ہ سٕندِحیثیتہٕ پیش کوٚر مُت۔﴾ ییٚلہِ حوا ر یٚو ووٚ ن :"
  5,112,"۔ اے عیسیٰ ابن مر یم ﴿علیہ السلام﴾ کیا تُہُند ربّ ہیکیا سانہِ خٲطرٕ آسمان پٮ۪ٹھہٕ کھیٚنُک اکھ خوا ن نٲزِل کٔرِ تھ ؟ عیسیٰ ﴿علیہ السلامن﴾ ووٚ ننکھ: خُدا یس کھوژِ واگر توٚہۍ مو من چِھو ۔"
  5,113,"۔تِمو ووٚ ن :  أسۍ چِھ بس یہِ یژھان زِ تَمہِ خوا نہٕ نِشہِ کھیٚمو کھیٚن  تہٕ سٲنۍ دل گژھن مطمعِن تہٕ اسہِ  لگہِ پے زِ یِکینژھاہ تۅہیہِ اَسہِ ووٚ نُو سُہ چُھ پوٚز تہٕ أسۍ آسو تتھ پٮ۪ٹھ گواہ۔"
  5,114,"۔اَتھ پٮ۪ٹھ کوٚر عیسیٰ ابن مریم﴿علیہ السلامن﴾دعا،خُدا یا ، سانہِ ربّا ، اسہِ پٮ۪ٹھ کر آسما نہٕ پٮ۪ٹھہٕ اکھ خوا ن نٲزِل یُس سانہِ خٲطرٕ تہٕ سا نیٚن پٔتِمیٚن برونٹھمین خٲطرٕ خو شی ہُند مو قع بنہِ تہٕ چا نہِ طر فہٕ آسہِ اکھ نشٲنی، اَسہِ کر رِزق عطا تہٕ ژٕ چُھکھ بہتر ین رزق دِنہٕ وول ۔"
  5,115,"۔خُدا ین دِیُت جوا ب : بے شک کرٕ بہٕ سُہ تۅہیہِ پٮ۪ٹھ نٲزِل مگر امہِ پتہٕ یُس تۅہیہِ منٛزٕ کُفر کرِ تس دِمہٕ بہٕ تِیُتھ سزا یُس نہٕ مےٚ دُنیا ہس منٛز آسہِ کٲنٛسہِ دِیتمُت ۔ ع"
  5,116,"۔غر ض ییٚلہِ ﴿یِم احسا ن یاد پٲوِتھ﴾ اللہ تعالیٰ فر ما وِ زِ :  اے عیسیٰ ابنِ مر یم ﴿علیہ السلام﴾ ،ژےٚ اوستھہٕ لُکن ووٚ نمُت زِ اللہ تعالیٰ ہَس ورٲے بنٲوِو مےٚ تہٕ میٲنۍ موج تہِ خُدا ے ؟ ﴿عیسا یو کوٚر نہٕ صرف خُدا یس سٍتۍ مسیح علیہ السلام تہٕ رو ح القُدسٕے یو ت خُدا بناو نس پٮ۪ٹھ بس بلکہ بنٲوٕکھ مسیح علیہ السلامن ہٕنز والدہ ماجد ہ حضر ت مر یم علیہھا السلام تہِ اکھ مستقل معبود۔ مسیح علیہ السلامس  پتہٕ  اوس گۅڈنِکیٚن ترٮ۪ن ہَتھن ؤرِین تام عیسٲے دُنیا امہِ تخیل ﴿خیا لہٕ ﴾ نِشہِ با لکل بے خبر۔ ترییٚمہِ صد ی ہٕندِس ٲخر ی دورس منٛز کٔرۍ اسکندر یہِ کیو کینژھو دینیا ت کیو عٲلِمو گۅڈنِچہِ پھِرِ حضرت مر یم علیھا السلامس خٲطرٕ اُم اللہ  یا  مادرِ خُدا  لفظ استعمال تہٕ امہِ پتہٕ روٗزو ارٕ وارٕ مر یم پرستی کلیساہن منٛز پھٔہلان۔﴾ سُہ کرِ در جوا ب عر ض زِ : سبحا ن اللہ  میٲنۍ کٲم ٲس نہٕ یہِ زِ سۅ کتھ وَنہا یۅ سہٕ کتھ مےٚ وَننُک حق اوس نہٕ اگر مےٚ یِژھ کتھ ؤنِمٕژ آسِہے تیٚلہِ آسِہیو تۅہیہِ ضروٗر علم ، توٚہۍ چِھو زانان یِکینژھاہ میٲنِس دِلس منٛز چُھ تہٕ بہٕ چُھس نہٕ زانان یِکینژھاہ تُہندِس دِلس منٛز چُھ ،توٚہۍ چِھو تمام پوشید ہ حقیقتن ہٕندۍ عٲلِم ۔"
  5,117,"۔مےٚ ووٚ ن نہٕ تِمن تمہِ ورٲے کِہِنۍ ییمِیُک تۅہیہِ حکم اوسُو دِیتمُت یہِ زِ اللہ تعالیٰ سٕنز بند گی کٔرِ و یُس میو ن ربّ تہِ چُھ تہٕ تُہُند ربّ تہِ ،بہٕ اوسُس تتھ وقتس تام تِہُند نگرا ن یوٚت تام بہٕ تِمن در میان اوسُس، ییٚلہِ تۅہیہِ بہٕ وا پس بُلو ووٗس پتہٕ ٲسِو توٚہۍ تِمن پٮ۪ٹھ نگرا ن تہٕ بیٚیہِ چِھو توٚہۍسارِنٕے چیز ن پٮ۪ٹھ نگران۔"
  5,118,"۔ وۅ نۍ اگر توٚہۍ یِمن سزا دِیِو یِم چِھ تُہٕندۍ بند ہ ، تہٕ ہرگاہ معا ف کٔرِ یوٗکھ، تیٚلہِ چِھو توٚہۍ غٲلب تہٕ دانا۔"
  5,119,"۔ پتہٕ فر ماوِ اللہ تعالیٰ : یہِ چُھ سُہ دۅ ہ یتھ منٛز پٔزِ یا رین پنُن پوٚز ، نفع چُھ دِوان، تِہندِ خٲطرٕ چِھ تِتھۍ با غ یِمن بٔنۍ کِنۍ کۅ لہٕ چھےٚ پکان، ییٚتہِ تِم ہمیشہ روز ن، خدا ے سپُد تِمن رٲضۍ تہٕ تِم سپدۍ خُدا یس رٲضۍ، یٔہے چھےٚ بڑ کٲمیٲبی۔"
  5,120,"۔زمین ، آسما نن تہٕ تمام موجو د اتن ہٕنز با دشٲہی چھےٚ اللہ تعالیٰ سٕندی خٲطرٕ، تہٕ سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ قدر ت تھاوان۔ع"
