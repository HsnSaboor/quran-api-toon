quran[182]{c,v,t}:
  37,1,"۔قطا ردر قطا ر صف گنڈن والیٚن ہُند قسم،"
  37,2,"۔پتہٕ تِہُند قسم یِم گٍر نٛز کر ن وٲلۍ تہٕ لار کر ن وٲلۍ چِھ،"
  37,3,"۔پتہٕ تِہُند قسم یِم کلامِ نصیحت بوزناون وٲلۍ چِھ۔ ﴿ مُفسر ن ہٕنز اکثر یت چھےٚ اتھ کتھہِ پٮ۪ٹھ متفق زِ یِمو تر یشوٕ یَو گر و ہَو نِشہِ چِھ مُراد فر شتن ہٕندۍ گروہ، یِم اللہ تعالیٰ سٕندۍ احکام بجا اَننہٕ خٲطرٕ ہمیشہ چھِ تیار روزان،تٔمۍ سٕںز نافرمٲنی کرن والٮ۪ن چھِ گرٍنٛز کران تہٕ لار کران،بیٚیہِ چھِ مختلف طریقو  اللہ تعالیٰ یاد پاوان تہٕ کلامِ نصیحت بوزناوان﴾"
  37,4,"۔تُہُنٛد حقیقی معبود چُھ بس اَکو ے۔"
  37,5,"۔سُہ یُس زمین تہٕ آسمانن ہُند تہٕ تمام تِمن چیز ن ہُند مٲلِک چُھ یِم زمین و آسما نس منٛز چِھ، بیٚیہِ سارِنٕے مشر قن ہُند مٲلِک ۔ ﴿ آفتا ب چُھنہٕ ہمیشہ اَکی نَبہٕ کِنۍ نیران ، بلکہ چُھ پرٛتھ دۅہ اکہِ نَوِ زا ویہِ کِنۍ طلو ع سپدان۔بیٚیہِ چُھنہٕ سُہ سارِ سٕے زمینس پٮ۪ٹھ بیک وقت طلو ع سپدان، بلکہ چُھ زمین کیٚن مختلف حصّن پٮ۪ٹھ مختلف وقتن منٛز اَمِیُک طلو ع سپدان۔ یِمن وجو ہا تن ہٕندِس بُنیا دس پٮ۪ٹھ چُھ مشر ق بجا ے مشا رِ ق لفظ ورتاو نہٕ آمُت ، تہٕ اَتھ سٍتۍ چَھنہٕ مغا رِ بن ہٕنز ذِکر کر نہٕ آمٕژ، تِکیازِ لفظ مشا رق چُھ پا نے مغا رِ بس پٮ۪ٹھ دلا لت کران ۔﴾"
  37,6,"۔اسہِ چُھ دُنیا ہُک آسمان تارکن ہٕندِ زمینت سٍتۍ سجوومُت۔﴿دُنیا ہُک آسمان چُھ مُراد سُے آسمان یُس أسۍ پننیو أچھو چِھ وُچھان﴾"
  37,7,"۔تہٕ پرٛتھ نا فر مان شیطا نس نِشہِ چُھ یہِ محفوظ تھو و مُت۔"
  37,8,"۔یِم شیا طین ہیٚکن نہٕ ملا  ٔ اعلیٰ ہن ہٕنزٕ کتھہٕ بوٗزِ تھ، ﴿امہِ نِشہِ چُھ مُراد عالم بالا ہٕکۍ مخلو ق یعنی فر شتہٕ ﴾ پرٛتھ طر فہٕ چِھکھ چو ب وسان تہٕ لار چَھکھ یِوان کرنہٕ،"
  37,9,"۔تہٕ تِہندِ خٲطرٕ چُھ لگا تار عذا ب۔ تا ہم اگر تِمو منٛزٕ کانٛہہ کینٛہہ تھَپہِ تھوٚسہِ ہیٚتھ ژلہِ،"
  37,10,"۔تیٚلہِ چھےٚ اکھ شعلہٕ وٕ نۍ نارٕ ریٚہہ تس پتہٕ دَوان۔"
  37,11,"۔وۅ نۍ پٕرٛژِھو یِمن ،یِہٕنز پیدٲیش چھا زیادٕہ مشکل کِنہٕ تِمن چیزن ہٕنز یِم اَسہِ پٲدٕ چِھ کٔرمٕتۍ؟ یِم چِھ اسہِ لیس دار رَبہِ پٲدٕ کٔرِ مٕتۍ۔"
  37,12,"۔توٚہۍ چِھو ﴿ اللہ تعالیٰ سٕندٮ۪ن قدرت کیٚن معجز ن پٮ۪ٹھ ﴾ حٲران تہٕ یِم چِھ اَتھ ٹسنہٕ کران۔"
  37,13,"۔ییٚلہِ سمجھا و نہٕ چِھ یِوان ،تیٚلہِ چِھنہٕ سمجھٲنی۔"
  37,14,"۔کانٛہہ نِشٲنی ییٚلہِ وُچھان چِھ تتھ چِھ ہزٕ ل کران۔"
  37,15,"۔بیٚیہِ چِھ ونان  یہِ چُھ ٹا کارٕ جود،"
  37,16,"۔ یہِ کتہِ ہیٚکہِ بٔنِتھ زِ ییٚلہِ أسۍ موٗدِ مٕتۍ آسَو تہٕ میٚژ بَنَو، تہٕ أڈجہِ کرنٛز آسَو  روٗدِمٕتۍ،تہٕ تمہِ وقتہٕ یِمو أسۍ زندہ کٔرِ تھ تُلنہٕ؟"
  37,17,"۔تہٕ کیا برونٹھمیٚن وقتن ہٕندۍ سٲنۍ آبا واجداد تہِ یِنہٕ تُلنہٕ؟"
  37,18,"۔یِمن ؤنِو ،آ ، تہٕ توٚہۍ چِھو ﴿خُدا یس برونٛہہ کنہِ ﴾ بے بس"
  37,19,"۔بس اَکو ے گرٍ نٛز سپدِ، تہٕ اچا نک  آسن یِم پننیو أچھو وُچھان ﴿تہِ سورُے کینٛہہ ییٚمِچ خبر چھےٚ دِنہٕ یِوان﴾۔"
  37,20,"۔تمہِ ساعتہٕ وَنن یِم ہا ے سٲنۍ کم بختی، یہِ ہَے چُھ یو م الجزا۔"
  37,21,"۔یہِ چُھ سُے فٲصلُک دۅہ یُس توٚہۍ اَپُز زانان ٲسِو ۔ ع۔﴿بنا ن چُھ زِ یہِ کتھ وَنن تِمن اہلِ ایمان ، بنا ن چُھ یہِ آسہِ فر شتن ہُند قوم ، بنان چُھ زِ میدانِ حشرُک سورُے ماحو ل آسہِ تمہِ ساعتہٕ زبانِ حال سٍتۍ یہِ ونان ، تہٕ یِتہِ چُھ بنان زِ یہِ آسہِ خۅد یِمنٕے لُکن ہُند پننُے بیا کھ ردِ  عمل۔یعنی  پننیو دِلَو مٔنٛز وَنن تِم پننِس پا نس زِ دُنیا ہس منٛز روٗدِ و توٚہۍ سارِ سٕے وٲنٛسہِ یہِ سمجھان زِ کانٛہہ فٲصلُک دۅہ چُھنہٕ یِنہٕ وول۔ وو نۍ آیَو تۅہیہِ شہمت ، یُس دۅہ توٚہۍ اَپُز زانان ٲسِوسُے ووتُو برونٛہہ کُن﴾۔"
  37,22,"۔﴿حُکم سپدِ ﴾ أنیوٗکھ گھیرٕ کٔرِتھ سٲری ظٲلِم تہٕ تِہندۍسٲتھی،تہٕ تِم معبود یِہٕنز بند گی خُدا ے ترٲوِتھ کران ٲسۍ ﴿یتھ جایہِ چِھنہٕ معبوٗد مُراد فر شتہٕ تہٕ اولیا تہٕ انبیا ، بلکہ چِھ دۅ ن قسمن ہٕندۍ معبود ۔اکھ تِم انسان تہٕ شیا طین یِہٕنز پنٕنۍ خوٲہش تہٕ کوٗشش یہِ ٲس زِ لُکھ گٔژھۍ خُدا ے ترٲوِ تھ تِہٕنز بند گی کرٕنۍ۔دوٚیِم تِم پۅ تٕلۍ و غٲرٕ ہ یِہٕنز پرستش دُنیا ہس منٛز لُکھ چِھ کران روٗدِمٕتۍ﴾۔"
  37,23,"۔ پتہٕ ہٲوِو یِمن سارِنٕے جہنمٕچ وَتھ۔"
  37,24,"۔تہٕ تلسہ ٹھہرٲوِ یوٗکھ یِم ہَنا، یِمن چُھ کینٛہہ پٕرٛژُھن۔"
  37,25,"۔تۅہیہِ کیا گوٚ و ، وۅ نۍ کیازِ چِھو نہٕ اکھ أکِس مدد کران؟"
  37,26,"۔ ہاے ، اَز چِھ یِم پنُن پان ﴿تہٕ اکھ بیا کھ ﴾ حوالہٕ کران ﴿رُٹنا وان﴾ً"
  37,27,"۔ اَمہِ پتہٕ پھیرن یِم اکھ أکِس کُن تہٕ لا گن پانہٕ وٲنۍ تکرار کرُن۔"
  37,28,"۔وَنن ﴿پیر وی کر ن وٲلۍ پننیٚن پیشوا ہن﴾، توٚہۍ ٲسِو اسہِ نِشہِ سیٚدِ بُتھِہ یِوان۔ ﴿در اصل چُھ لفظ  یمین  ور تا و نہٕ آمُت۔محا ورٕہ کہ لحا ظہ اگر یہِ قُوّت و طا قت کِس معنی یس منٛز نِمو ن ، تیٚلہِ آسہِ مطلب زِ تۅہیہِ نِیِو أسۍ پننیو زورَو سٍتۍ گُمرٲہی کُن۔اگر یہِ خیر کِس تہٕ رٕژرٕ کِس معنی یس منٛز نِمو ن ،تیٚلہِ آسہِ امِیُک مطلب یہِ زِ تۅہیہِ او سُو قسم ہٲوۍہٲوۍ اسہِ اطمنا ن دِیتمُت زِ حق چُھ سُے یہِ توٚہۍ پیش چِھو کران۔﴾"
  37,29,"۔تِم دِن جوا ب ،  نَہ بلکہ ٲسِو نہٕ توٚہۍ خۅد ایمان اَنن وٲلۍ،"
  37,30,"۔تہٕ نَہ اوس تۅہیہِ پٮ۪ٹھ سو ن کانٛہہ زور، توٚہۍ ٲسِو پٲنۍ پانہٕ بُتھۍ پھِرۍ لُکھ۔"
  37,31,"۔ٲخر سپدِۍ أسۍ پننِس ربّ سٕندِ تمہِ فر ما نٕکۍ حقدار زِ أسۍ چِھ عذا بُک مزٕ ہ وُچھن وٲلۍ۔"
  37,32,"۔ لہٰذا ڈٲلِو اسہِ توٚہۍ ، تہٕ أسۍ ٲسۍ پانہٕ ڈٔلِمٕتۍ۔"
  37,33,"۔یِتھہٕ پٲٹھۍ آسن تِم سٲری تمہِ دۅہ عذا بس منٛز مُشتر ک۔"
  37,34,"۔أسۍ چِھ مُجر من سٍتۍ یی کینژھاہ کران۔"
  37,35,"۔یِم ٲسۍ تِم لوٗکھ زِ ییٚلہِ یِمن وَننہٕ اوس یِوان، خدا یس ورٲے چُھنہٕ کانٛہہ معبودِ بر حق۔ تیٚلہِ اوس یِمن تکبر کھسان،"
  37,36,"۔تہٕ ونان ٲسۍ کیا أسۍ ترا ووکھہٕ أکِس شا عر مجنو ن سٕندِ خٲطرٕ پنٕنۍ معبود؟"
  37,37,"۔حالانکہ سُہ اوس حق ہیٚتھ آمُت، تہٕ تٔمۍ اوس رسولن ہُند تصدیق کوٚر مُت۔﴿وۅ نۍ یِیہِ تِمن وننہٕ زِ ﴾"
  37,38,"۔توٚہۍ چِھو لازِ ماً درد ناک سزا بٕکۍ مزٕ ہ وُچھن وٲلۍ۔"
  37,39,"۔ تہٕ تۅہیہِ یُس بد لہٕ تہِ دِنہٕ یِوان چُھ،تِمنٕے اعما لن ہُند چُھو دِنہٕ یِوان ،یِم توٚہۍ کران چِھو روٗدِمٕتۍ۔"
  37,40,"۔مگر اللہ تعالیٰ سٕندۍ ژارنہٕ آمتۍ بندٕہ آسن ﴿امہِ بد انجامہٕ نِشہِ ﴾ محفوظ۔"
  37,41,"۔تِہندِ خٲطرٕ چُھ رزِق معلو م ﴿ مقرر کر نہٕ آمُت رِزّق﴾ ،"
  37,42,"۔پرتھ رنگٕکۍ لذیذ چیز ."
  37,43,"بیٚیہِ نعمتہٕ بٔرِتھ جنّت"
  37,44,"یِمن منٛز تِم عز ت سان یِن تھا و نہٕ تختن پٮ۪ٹھ بِہِن اکھ أکِس برونٛہہ کنہِ"
  37,45,"۔شرا ب کیو نا گو نِشہِ یِن گلہِ بٔرِتۍ جام تِمن منٛز با گ پھِر ناو نہٕ۔"
  37,46,"۔یہِ چمکہٕ وُن شراب، یُس چیٚنہٕ وا لیٚن خٲطرٕ مزٕ دار آسہِ۔"
  37,47,"۔نہ واتہِ تِہندِس جسمس تمہِ سٍتۍ کانٛہہ نقصا ن تہٕ نہ ڈَلہِ تِہٕنز عقل امہِ سٍتۍ۔"
  37,48,"۔تہٕ تِمن نِشہِ آسن نظرٕ بچا ون واجِنہِ ، خوبصورت أچھ واجِنہِ خا تو نہٕ،"
  37,49,"۔   تِژٕھہ نازُک زنتہٕ ٹھوٗلہٕ کنجہِ تلہٕ کنہِ چُھپِتھ چَھژر۔"
  37,50,"۔پتہٕ پٕرٛژھن تِم اکھ أکِس کُن متو جہ سپدِ تھ حالات۔ تِمو منٛزٕ وَنہِ اکھ،"
  37,51,"۔دنیا ہس منٛز اوس میو ن اکھ ہم نشین،"
  37,52,"۔سُہ اوس مےٚ ونان ، کیا ژٕ تہِ چُھکھہٕ تصدیق کر ن والیو منٛزٕ؟"
  37,53,"۔پٔزِپٲٹھۍ ییٚلہِ أسۍ موٗدِ مٕتۍ آسَو تہٕ مٔیژ آسَو بنیمٕتۍ ،تہٕ أڈِجہِ کرٛنٛز روزَو بٔنِتھ،کیاپٔزۍپٲٹھۍ یِیا اسہِ جز ا تہٕ سزا دِنہٕ؟"
  37,54,"۔وو نۍ کیاتوہۍ لُکھ چِھوٕ وُچُھن یژھان زِ تِم صا حب کتہِ چِھ وۅ نۍ؟"
  37,55,"۔یہِ ؤنِتھ یُتھُے سُہ نَمہِ ، تس وُچِھ جہنم کِس سَنِرس منٛز،"
  37,56,"۔ تہٕ تس وَنہِ خطا ب کران  خُدا ے سُند قسم ، ژٕ اوسُکھ بس مےٚ تباہ کر ن وول ۔"
  37,57,"۔میٲنِس ربّ سُند فضل اگر نہٕ شامِل حال آسِہے ، تیٚلہِ آسٕہا بٕتہِ اَز تِمو لُکو منٛز یِم رٔٹِتھ چِھ  اَننہٕ آمٕتۍ۔"
  37,58,"۔اچھا، کیا وۅ نۍ چِھنا أسۍ تیٚلہِ مَر ن وٲلۍ۔﴿ کلا مُک انداز چُھ صا ف ونان زِ پننِس أمِس جہنمی یارس سٍتۍ کلام کران کران چُھ اچا نک یہِ جنّتی شخص پا نس سٍتۍ کلام کر نہِ لگا ن ، تہٕ یِمہٕ کتھہٕ چھےٚ تٔمۍ سٕنزِ زیٚوِ تِتھہٕ پٲٹھۍ نیران زنتہٕ کانٛہہ شخص پنُن پان پرٛتھ توقع تہٕ پرٛتھ اندازٕہ کھۅتہٕ بہتر حا لتس منٛز وُچھِتھ سٮ۪ٹھاہ حٲرتہٕ سان تہٕ خو شی سان پٲنۍ پانے آسہِ بولان﴾ یُس مو ت اسہِ یِنہٕ وول اوس سُہ آو بس گۅڈ ے ؟"
  37,59,"۔وۅ نۍ سپدِ نہٕ اسہِ کانٛہہ عذا ب ؟"
  37,60,"۔پٔزِپٲٹھۍ چھےٚ یٔہے عظیم الشان کامیٲبی۔"
  37,61,"۔یِژھی کا میٲبی خٲطرٕ پزِ عمل کر ن والیٚن عمل کرٕنۍ۔"
  37,62,"۔ؤنِو ،یہِ ضیا فت چھا جان کِنہٕ زقُو مُک کُل؟"
  37,63,"۔اسہِ چُھ سُہ کُل ظٲلِمن خٲطرٕ فتنہٕ بنو و مُت۔﴿ یعنی مُنکر ن چُھ یہِ کتھ بوٗزِ تھ قرآنس تہٕ نبی صلی اللہ علیہ وسلمس پٮ۪ٹھ ٹسنہٕ کر نُک اکھ نوٚ و مو قع میلان۔تِم چِھ اتھ پٮ۪ٹھ ہزٕل کران ونان ، بوٗزِ تَو وۅ نۍ نٔو کتھا ہ ، جہنم کِس شعلہ وٕ نِس نارس منٛز وۅ یدن وۅ نۍ کُلۍ۔﴾"
  37,64,"۔سُہ چُھ اکھ کُل یُس جہنم کہ ژَکہِ تلہٕ چُھ نیران۔"
  37,65,"۔تمِکۍ ہیٚلۍ ﴿میوٕہ ﴾ چِھ تِتھۍ زَنتہٕ شیطا نن ہٕندۍ کلہٕ۔"
  37,66,"۔جہنمٕکۍ لُکھ کھیٚن اَتھ، تہٕ اَمی سٍتۍ برَن شکم،"
  37,67,"۔پتہٕ میلہِ تِمن اتھ پٮ۪ٹھ چیٚنہٕ خٲطرٕ گرٛکہٕ دِوُن آب۔"
  37,68,"۔تہٕ امہِ پتہٕ سپدِ تِہٕنز وا پسی أتھۍ جہنم کِس نارس کُن۔"
  37,69,"۔یِم  چِھ تِم لُکھ یِمو پنٕنۍ مٲلۍ بُڈِ بب وَتہِ ڈٔلۍ مٕتۍ وُچھ،"
  37,70,"۔ تہٕ تِہندِ نٕے نقشِ قد من پٮ۪ٹھ ترٲوٕکھ دَو۔"
  37,71,"۔حالانکہ تِمو برونٛہہ ٲسۍ واریاہ لُکھ گُمرا ہ سپٕد مٕتۍ،"
  37,72,"۔تہٕ تِمن منٛز ٲسۍ اسہِ تنبیہ کر ن وٲلۍ رسول سوٗزِ مٕتۍ۔"
  37,73,"۔وۅ نۍ وُچِھو یِمن تنبیہ آو کر نہٕ تِمن لُکن ہُند انجام کیا سپُد۔"
  37,74,"۔امہِ بد نٲمی نِشہِ چِھ اللہ تعالیٰ سٕندۍ تِمے بندٕہ بچیمٕتۍ یِم تٔمۍ پانس خٲطرٕ خٲلِص چِھ کٔرِمٕتۍ۔ع"
  37,75,"۔اسہِ اوس ﴿ امہِ برونٛہہ ﴾ نو ح علیہ السلامن ناد لو یمُت،وُچِھو زِ أسۍ کِتھۍ رٕتۍ جواب دِنہٕ وٲلۍ ٲسۍ۔"
  37,76,"۔اسہِ بچو و سُہ تہٕ تٔمۍ سٕندۍ گھر وٲلۍ کربِ عظیم ﴿بڑِ مصیبت ﴾ نِشہِ،"
  37,77,"۔تہٕ تٔمۍ سُندُے نسل تھو و پتھ کُن،"
  37,78,"۔تہٕ پٔتِمیٚن نسلن منٛز تروو تٔمۍ سُند تعر یف تہٕ توصیف۔"
  37,79,"۔ سلام چھےٚ نو حس علیہ السلامس پٮ۪ٹھ تمام  دنیاوا لیو منٛزٕ۔"
  37,80,"۔أسۍ چِھ نیکی کرن والیٚن یُتھُے جزا دِوان۔"
  37,81,"۔در حقیقت اوس سُہ سا نِیو مو من بندو منٛزٕ۔"
  37,82,"۔پتہٕ کوٚر بیا کھ دوٚر اسہِ غر ق۔"
  37,83,"۔ تہٕ نو ح علیہ السلام سٕندۍ سٕے طر یقس پٮ۪ٹھ پکن وول اوس ابراہیم۔"
  37,84,"۔ ییٚلہِ سُہ پننِس ربّ سٕندِس در بارس منٛز قلبِ سلیم ﴿صا ف دل﴾ ہیٚتھ آو۔"
  37,85,"۔ ییٚلہِ تٔمۍ پننِس مٲلِس تہٕ پننِس قو مس ووٚن  یِم کم چیز چِھ یِہٕنز توٚہۍ عبا دت چِھو کران؟"
  37,86,"۔ کیا اللہ تعالیٰ ترٛ ٲوِ تھ چِھو ا توٚہۍ اَپٕز ۍ مَپٕز ۍ معبوٗد یَژھان؟"
  37,87,"۔ ربّ العالمین سٕندِس با رس  منٛز کیا چُھ ٲخر تُہُند گُما ن ؟"
  37,88,"۔ پتہٕ ترٲو تٔمۍ تارکن پٮ۪ٹھ اکھ نظر ﴿عر بی زبٲنۍ منٛز چِھ یِم لفظ محا ورٕہ رٔنگۍ  اتھ معنی یس منٛز وَننہٕ یِوان زِ تٔمۍ کوٚر غور یا تٔمۍ شخصن لو گ سو نچُن۔﴾"
  37,89,"۔تہٕ ووٚ نُن مےٚ چھےٚ طبیعت خراب۔﴿اسہِ چُھنہٕ کُنہِ ذر یعہ یہِ معلو م زِ تمہِ ساعتہٕ اوس نہٕ حضر ت ابراہیم علیہ السلامس کُنہِ قسمُک تکلیف۔امہِ موجوٗب یِیہِ نہٕ یہِ وَننہٕ زِ حضرت ابراہیم علیہ السلامَو اوس یہِ خلا ف وا قعہ بہا نہٕ بنو و مُت۔﴾"
  37,90,"۔چنا نچہِ تِم لُکھ چِھ تس تٔتی ترٲوِ تھ نیران۔"
  37,91,"۔تِمن پٔتۍ کِنۍ ژاو سُہ ژوٗزِ پٲٹھۍ تِہندٮ۪ن معبودن ہٕندِس مندرس منٛز   تہٕ ووٚ نُن  توٚہۍ لُکھ کیازِ چِھو نہٕ کھیٚوان؟"
  37,92,"۔تۅہیہِ کیا گوٚو ،توٚہۍ چِھو نہٕ کتھ تہِ کران؟"
  37,93,"۔امہِ پتہٕ ووٚتھ سُہ تہٕ دٔچِھنہِ اَتھہٕ وٲلِنکھ زورٕ زورٕ دَب۔"
  37,94,"۔﴿واپس یِتھ ﴾ آے تِم لُکھ دَوان دَوان تس نِشہِ۔"
  37,95,"۔ تٔمۍ ووٚن کیا توٚہۍ چِھوٕ پننیٚن نٕے گر نہٕ آمتیٚن چیز ن پوٗزا کران؟"
  37,96,"۔حالانکہ اللہ تعالیٰ نٕے چِھنَو توٚہۍ تہِ پٲدٕ کٔرِ مٕتۍ تہٕ تِم چیز تہِ یِم توٚہۍ بناوان چھوٗکھ۔"
  37,97,"۔تِمو ووٚ ن پانہٕ وٲنۍ زِ  أمۍ سٕندِ خٲطرٕ کٔرِو اَکھ اَلا وٕ تیا ر، تہٕ یہِ چھٔکِیوٗن دَزوٕ نِس نارٕ ڈھیرس منٛز۔"
  37,98,"۔تِمو ٲس یٔژ ھمٕژ تس خلا ف اکھ کاروٲیی کرٕنۍ،مگر اسہِ ہٲوۍ تِمے ؤسۍ پایہِ بنٲوِتھ۔"
  37,99,"۔ ابراہیم علیہ السلام چُھ ونان  بہٕ گژٕھہ پننِس ربّس کُن ، ﴿یعنی پننِس ربّس خٲطرٕ تراوٕ پنُن گھرٕ تہٕ وطن﴾ سُے کرِ مےٚ رہنمٲیی۔"
  37,100,"۔ اے پروردگار، مےٚ کرُن اکھ فر زند عطا یُس صا لحینو منٛزٕ آسہِ۔"
  37,101,"۔﴿امہِ دُعا کِس جوابس منٛز ﴾ دِژ اسہِ تَس أکِس حلیم ﴿ بُردبار﴾ لڑکہٕ سٕنز بشارت ۔ ﴿مُراد چِھ حضر ت اسماعیل علیہ اسّلام﴾"
  37,102,"۔ سُہ لڑکہٕ ییٚلہِ تس سٍتۍ تگ دَو کر نہٕ چہِ وٲنٛسہِ ووت، پتہٕ چُھ ﴿اکہِ دۅہ ﴾ ابراہیم علیہ اسلام تس ونان  گوبر یا ، بہٕ چُھس خوا بس منٛز وُچھان زِ بہٕ چُھسَتھ ژٕ ذبح کران، وۅ نۍ وَن ژٕ ، چو ن کیا خیال چُھ؟ تٔمۍ ووٚن ،  ابّا جان ، یِکینژھاہ تۅہیہِ حُکم چُھو دِنہٕ یِوان سُہ کٔرِ و پوٗرٕ، توٚہۍ لٔبِو مےٚ ان شا اللہ صٲبر و منٛزٕ۔"
  37,103,"۔ٲخرس پٮ۪ٹھ ییٚلہِ تِمو دۅ شوٕ یَو خدا ے سٕندِس حُکمس کلہٕ نوٚ مروو، تہٕ ابراہیم علیہ السلام چُھ فر زندس بُتھہِ کِنۍ پتھر پاوان۔"
  37,104,"۔ تہٕ اسہِ لو ے نادزِ  اے ابراہیم علیہ السلام،"
  37,105,"۔ژےٚ ہو وُتھ خوا ب پوٚز بنٲوِتھ ۔﴿چو نکہ خو ابس منٛز اوس یہِ ہا و نہٕ آمُت زِ ذبح چِھ کران، یہِ آو نہٕ ہاو نہٕ زِ ذبح چُھ کر نہٕ آمُت،امہِ موجو ب ییٚلہِ حضرت ابراہیم علیہ السلامَو ذبح کر نٕچ پوٗرٕ تیٲری کٔر، پتہٕ آو فر ما و نہٕ زِ ژےٚ ہو وُتھ خوا ب پوٚز بنٲوِ تھ۔﴾أسۍ چِھ نیکی کر ن والیٚن یُتھُے جزا دِوان۔"
  37,106,"۔یقیناً ٲس یہِ اکھ ٹا کارٕ ہ آز مٲیش۔"
  37,107,"۔تہٕ اَسہِ تراو نوو اکھ بٔڑ قربٲنی فِدیس منٛز دِتھ سُہ بچہِ یلہٕ۔﴿ بجہِ قُربٲنی  نِشہِ چُھ مُراد اکھ دُمبہٕ یا اَکھ بوٚڈ کٹھ ،یُس تمہِ وقتہٕ اللہ تعالیٰ سٕندۍ فر شتن حضر ت ابراہیم علیہ السلامس برونٛہہ کنہِ پیش کوٚر تاکہ فر زند سٕندِ بدلہٕ کرتس ذبح۔اَتھ چُھ بٔڑ قربٲنی امہِ موجو ب وننہٕ آمُت زِ سۅ ٲس ابراہیم علیہ السلام ہِوِ س وفا دار بندٕ ہ سٕندِ خٲطرٕ فر زندِ ابراہیم علیہ السلام ہِوِ س صٲبر تہٕ جاں نِثار لڑ کہٕ سُند فِدیہِ ۔ امہِ علا وٕہ چُھ اتھ بٔڑ قربٲنی قرار دِنُک اکھ وجہ یِتہِ زِ قیا متس تام خٲطرٕ کوٚر خُداین یہِ سُنّت جٲری زِ اَمی تٲریخہٕ کرن تمام اہلِ ایمان پوٗرٕ دُنیا ہس منٛز جا نور قُربان ،تہٕ وفا دٲری تہٕ جا ں نِثا ری ہٕندِ امہِ عظیم الشّان وا قعٕچ یا د روزن تازٕہ کران۔﴾"
  37,108,"۔تہٕ تٔمۍ سُند تعریف تہٕ تو صیف تروو ہمیشہ خٲطرٕ یِنہٕ والیٚن نسلن منٛز۔۔"
  37,109,"۔ سلام چھےٚ ابراہیم علیہ السلامس پٮ۪ٹھ۔"
  37,110,"۔ أسۍ چِھ نیکی کر ن والیٚن یُتھُے جزا دِوان۔"
  37,111,"۔ پٔزۍ پٲٹھۍ اوس سُہ سا نیو مو من بندو منٛزٕ۔"
  37,112,"۔ تہٕ اسہِ دِژ تس اسحا ق علیہ السلام سٕنز بشارت، ﴿یعنی قربٲنی ہٕندِ امہِ وا قعہ پتہٕ دِژٕ تس حضرت اسحا ق علیہ السلام سٕندِ زیٚنٕچ بشا رت ﴾ اکھ نبی صا لحینو منٛزٕ۔"
  37,113,"۔ بیٚیہِ دِژتس تہٕ اسحا ق علیہ السلامس بر کت۔وو نۍ چھُ یِمن دۅ شوٕ نہِ ہٕندِ ذُرّ یتہٕ منٛزٕ کانٛہہ مُحسن تہٕ کانٛہہ چُھ پننِس نفسس پٮ۪ٹھ ٹا کارٕ ظُلم کرن وول ۔ ع"
  37,114,"۔تہٕ اسہِ کوٚر مو سیٰ علیہ السلامس تہٕ ہارون علیہ السلامس پٮ۪ٹھ احسا ن،"
  37,115,"۔تِمن تہٕ تِہندِس قو مس دِیُت کر بِ عظیم ﴿بَڑِ مصیبت ﴾ نِشہِ نجا ت،"
  37,116,"۔تِمن بخٕش نُصر ت ییٚمہِ وجہ کِنۍ تِمے روٗدۍ غٲلب،"
  37,117,"۔ تِمن کٔر سٮ۪ٹھاہ وا ضح کتا ب عطا،"
  37,118,"۔تِمن ہٲو سٔیز وَتھ،"
  37,119,"۔ تہٕ یِنہٕ والیٚن نسلن منٛز تھو و تِہُند ذِکرِ خیر پتھ کُن ۔"
  37,120,"۔سلام چھےٚ مو سیٰ علیہ السلام تہٕ ہارون علیہ السلامس پٮ۪ٹھ۔"
  37,121,"۔أسۍ چِھ نیکی کر ن والیٚن یُتُھے جز ادِوان،"
  37,122,"۔در حقیقت ٲسۍ تِم سا نیو مو من بندو منٛزٕ۔"
  37,123,"۔تہٕ پٔز پٲٹھۍ اوس الیا س علیہ السلام  تہِ مُر سلینو منٛزٕ۔"
  37,124,"۔یاد کٔرِو ییٚلہِ تٔمۍ پننِس قو مَس وَنیا و زِ  توٚہۍ لُکھ چِھو نا کھۅژان؟"
  37,125,"۔کیا توٚہۍ چِھوٕ بعلس ناد لایان تہٕ اَحسن الخا لقین چھوٗن تراوان،"
  37,126,"۔سُہ اللہ تعالیٰ یُس تُہُند تہٕ تُہند ٮ۪ن پٔتِمیٚن بروٗٹھمیٚن آبا و اجدادن ہُند ربّ چُھ؟"
  37,127,"۔مگر تِمو پھِیُر تس بُتھ ،لہذا چِھ تِم یقیناً سزا خٲطرٕ پیش سپد ن وٲلۍ،"
  37,128,"۔ تِمو خدا سٕند یو بندَ و ورٲے یِم خٲلِص ٲسۍ آمٕتۍ کر نہٕ۔"
  37,129,"۔بیٚیہِ تھو و اَسہِ الیا س علیہ السلام سُند ذِکر خیر یِنہٕ والین نسلن منٛز پتھ کُن۔"
  37,130,"۔سلام چھےٚ الیا س علیہ السلامس پٮ۪ٹھ۔"
  37,131,"۔أسۍ چِھ نیکی کر ن والیٚن یُتھُے جزا دِوان۔"
  37,132,"۔پٔزۍ پٲٹھۍ اوس سُہ سا نیو مو من بند و منٛزٕ ۔"
  37,133,"۔تہٕ لوٗط تہِ اوس تِموٕ ے لُکو منٛزٕ یِم رسول بنٲوِتھ سوز نہٕ ٲسۍ آمٕتۍ۔"
  37,134,"۔ یاد پٲوِو ییٚلہِ اَسہِ تس تہٕ تٔمۍ سٕندٮ۪ن سارِ نٕے گھر والیٚن نجا ت دِیُت،"
  37,135,"۔ سِوا ے اکھ بُڈ یۅ سہٕ پتھ روزن والیو منٛزٕ ٲس۔"
  37,136,"۔پتہٕ کوٚر با قی سورُے تَہس نَہس۔"
  37,137,"۔ اَز چِھو توٚہۍ رات دۅہ تِہٕنز و ﴿ وُجارٕ گٔمژَو بٔستِیَو ﴾ کِنۍ نیران۔"
  37,138,"۔کیا تۅہیہِ چَھو نا عقل یِوان ۔ ؟ع"
  37,139,"۔تہٕ یقیناً اوس یو نُس علیہ السلام تہِ رسولَو منٛزٕ۔"
  37,140,"۔یاد پٲوِو ییٚلہِ سُہ أکِس بٔر ژِناوِ کُن ژوٚ ل،"
  37,141,"۔پتہٕ سپُد چیٖر ترٛاونس منٛز شر یک تہٕ تتھ منٛز ہورُن۔"
  37,142,"۔ٲخر کار نینگلو وسُہ گاڈِ تہٕ سُہ اوس پا نس ملا مت کران ﴿ یِمن کتھن پٮ۪ٹھ غور کر نہٕ سٍتۍ یۅسہٕ وا قعٕچ صوٗرت فِکرِ چھےٚ تران سۅ چھےٚ یہِ زِ ﴿ا﴾ حضر ت یو نُس علیہ السلام یتھ ناوِ منٛز سواو ٲسۍ سپدِ مٕتۍ سۅ ٲس پننہِ گُنجٲیشہِ کھۅ تہٕ زیادٕہ بٔرِ تھ۔﴿2﴾ چیزِ ترا ویٚکھ ناوِ منٛزٕ تہٕ غالباً ترا ویٚکھ تمی ساعتہٕ ییٚلہِ بحر ی سفرس دورا ن یہِ با سیو و زِ زیادٕہ بارٕ کہ وجہ کِنۍ چُھ تمام مُسا فر ن ہٕندِس زُوس خطرٕ ہ۔لہٰذا آیہِ امہِ غر ضہٕ خٲطرٕ چیزِ تراونہٕ زِ ییٚمۍ سُند ناو چیٖز یٚو منٛزٕ نیرِ سُے گژِھہ آبس یُن چھکنہٕ ۔ ﴿3﴾ چیر یٚو منٛز درٛا و حضرت یو نس علیہ السلام سُندُے ناو، تِم آے سمندرس منٛز چھکنہٕ تہٕ پتہٕ چھےٚ تِمن گاڈ نیٚنگلاوان۔﴿4﴾ اَتھ تکلیفس منٛز سپدۍ حضرت یو نُس علیہ السلام امہِ موجو ب مبتلا زِ تِم ٲسۍ پننِس آقا یعنی اللہ تعالیٰ سٕندِ اجا زت ورٲے پننہِ ماموٗر یت چہِ جایہِ پٮ۪ٹھ ژٔلۍ مٕتۍ، أتھۍ معنی یَس پٮ۪ٹھ چُھ لفظ ۂ اَبَقّ دلا لت کران ، تِکیازِ عر بی زبٲنۍ منٛز چُھ یہِ ژَلن وٲلِس غلا م سٕندِ خٲطرٕ وَننہٕ یِوان ﴾"
  37,143,"۔وۅ نۍ اگر سُہ تسبیح کرن والیو منٛزٕ آسِہے نہٕ،"
  37,144,"۔ تیٚلہِ روزِ ہے قیا متس تام تٔسۍ گا ڈِ ہِندِس شکمس منٛز۔ ﴿یعنی قیا متس تام روزِ ہے گا ڈِ ہُنٛد شکم تٔمۍ سٕندِ خٲطرٕ قبر بٔنِتھ﴾"
  37,145,"۔ٲخر کار چھوٚکھ سُہ اَسہِ سٮ۪ٹھاہ بیمار حالتس منٛز أکِس ہموا ر زمینس پٮ۪ٹھ ۔"
  37,146,"۔تہٕ تتھ پٮ۪ٹھ وۅ پدا و اَکھ رٲنٛٹھ دار ﴿ اَلہٕ ﴾ کُل۔"
  37,147,"۔ امہِ پتہٕ سوٗز سُہ اسہِ أکِس لچھس یا امہِ کھۅتہٕ زٲید لُکن کُن ۔﴿ اکھ لچھ یا اَمہِ کھۅ تہٕ زٲید  وَننُک مطلب چُھنہٕ یہِ زِ خُدا یس اوس تِہندِس تعدادس منٛز شک ، بلکہ چُھ اَمِیُک مطلب یہِ زِ اگر کانٛہہ تِہِنزِ بستی نظر ترٛ اوِ ہے ،تیٚلہِ کرِ ہے یۅ ہے اندازٕہ زِ اَمہِ شہرٕ چ آبٲدی آسہِ اکھ لچھ کھۅتہٕ زیادے کم نہٕ کینٛہہ۔ ﴾"
  37,148,"۔تِمو اوٚ ن ایمان تہٕ اَسہِ تھٲوۍ تِم أکِس خا ص وقتس تام با قی۔"
  37,149,"۔ پتہٕ پٕرٛژِھو یِمن لُکن ، کیا ﴿ یِہٕندٮ۪ن دِلن چھا یہِ کتھ لگان زِ ﴾ تُہٕندِس ربّس خٲطرٕ گژھن آسنہِ کورِ تہٕ یِمن خٲطرٕ گٔژھن نیٚچِو آسٕنۍ۔"
  37,150,"۔پٔزِ پٲٹھۍ چھا اَسہِ ملٲیِک بنٲوِ مٕتۍ مستوٗراتہٕ، تہٕ یِم چِھ یہِ أچھو وُچھمٕژ کتھ ونان ۔"
  37,151,"۔ وارٕ پٲٹھۍ بوٗزِو ، دراصل چِھ یِم لُکھ پانہٕ تھُر مٕژ یہِ کتھ ونان زِ خُدایس چُھ اولاد،"
  37,152,"۔تہٕ در حقیقت چِھ یِم اپزِ یٲرۍ۔"
  37,153,"۔کیا خُدا ین کر یا نیٚچو یٚو بجا ے کورِ پا نس خٲطرٕ پسند؟"
  37,154,"۔تۅہیہِ کیا چُھو گوٚمُت، کِتھۍ حُکم چِھو لگا وان؟"
  37,155,"۔کیا تۅہیہِ چُھو ونا ہو ش یِوان ؟"
  37,156,"۔کِنہٕ تۅہیہِ نِش چھےٚ پننیٚن یِمن کتھن خٲطرٕ کانٛہہ صا ف سَند،"
  37,157,"۔تیٚلہِ أنِو پنٕنۍ سۅ کتاب اگر توٚہۍ پٔزِپٲرۍ چِھو۔"
  37,158,"۔یِمو چُھ خُدایس تہٕ ملٲیکن در میان نسبُک رشتہٕ بنو و مُت،﴿ اگر چہِ لفظ جِنّ چُھ وَرتاو نہٕ آمُت مگر یُس برونٛہہ کُن بیان چُھ، تمہِ نِشہِ چُھ وا ضح زِ فر شتہٕ چِھ مُراد ،یُہُند لفظی معنی چُھ پوشیدٕہ مخلو ق۔﴾ حالانکہ ملٲیک چھِ خوٗب زانان زِ یِم لُکھ چِھ مُجرم سٕندِ حیثیتہٕ پیش سپدن وٲلۍ ﴿تہٕ تِم چِھ ونان زِ﴾۔"
  37,159,"اللہ تعالیٰ چُھ صفا تَو نِشہِ پا ک"
  37,160,"یِم تٔمۍ سٕند یو خٲلص بند و وَرٲے با قی لُکھ تس کُن منسوٗب چِھ کران"
  37,161,"لہٰذا توٚہۍ تہٕ تُہٕندۍ یِم معبود"
  37,162,"ہیٚکن نہٕ خُدا یس نِشہِ کٲنٛسہِ پھِرِ تھ"
  37,163,"۔مگر صرف تس یُس جہنم کِس نار اَلا وس منٛز دزن وول آسہِ۔"
  37,164,"۔تہٕ سون حال چُھ یہِ زِ اسہِ منٛزٕ چُھ پرٛتھ أکۍ سُند اکھ مقا م  مُقرر،"
  37,165,"۔تہٕ أسۍ چِھ صف گٔنڈِ تھ خد مت گار،"
  37,166,"۔بیٚیہِ تسبیح کر ن وٲلۍ۔"
  37,167,"۔یِم لُکھ ٲسۍ گۅڈٕ وَنان زِ ،"
  37,168,"۔کاش اسہِ نِشہِ آسِہے سۅذِکر  یۅسہٕ پٔتِمیٚن قو من ٲس دِنہٕ آمٕژ،"
  37,169,"۔ تیٚلہِ آسہَو أسۍ اللہ تعالیٰ سٕندۍ ژا ر نہٕ آمٕتۍ بندٕہ۔"
  37,170,"۔مگر ﴿ییٚلہِ سۅ وٲژ﴾ پتہٕ کوٚر یِمَو تتھ انکار ،وۅ نۍ لگہِ عقریب یِمن ﴿اَمہِ رٔوِشہِ ہُند نتیجہِ ﴾ پے۔"
  37,171,"۔پننیٚن سوٗزِ مٕتیٚن بند ن سٍتۍ چُھ اَسہِ گۅڈ ے وعدہ کوٚر مُت زِ ،"
  37,172,"۔یقیناً یِیہِ تِمن مدد کر نہٕ،"
  37,173,"۔تہٕ سو نُے لشکر روزِ غٲلب سپدِ تھ۔"
  37,174,"۔لہٰذا اے نبی صلی اللہ علیہ وسلم، کینژھس کالس ترٲوِ یوٗکھ پننِس حالس پٮ۪ٹھ،"
  37,175,"۔تہٕ روٗزِ و وُچھا ن ، عنقر یب وُچھن یِم پانہٕ تہِ۔"
  37,176,"۔کیا یِم چھا سٲنِس عذا بس خٲطرٕ با نبٕر کران؟"
  37,177,"۔ییٚلہِ سُہ یِہندِس صحنس منٛز وَسہِ ،پتہٕ آسہِ سُہ دۅہ تِمن لُکن خٲطرٕ سٮ۪ٹھاہ خرا ب یِم کھۅژنا و نہٕ چِھ آمٕتۍ۔"
  37,178,"۔ بس ترٲوِ یوٗکھ کینژٕھہ کالہٕ خٲطرٕ ،"
  37,179,"۔ تہٕ روٗزِ ووُچھان، عنقر یب وُچھن یِم پانہٕ ﴿ تہِ پنُن انجام ﴾۔"
  37,180,"۔ پاک چُھ تُہُند ربّ، عزّتُک مٲلک ، تِمو تمام کَتھَو نِشہِ یِمہٕ یِم لُکھ بناوان چِھ۔"
  37,181,"۔تہٕ سلام چھےٚ رسولن پٮ۪ٹھ،"
  37,182,"۔ تہٕ سورُے حمد چُھ اللہ ربُّ العا لمین سٕندی خٲطرٕ۔"
