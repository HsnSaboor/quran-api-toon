quran[38]{c,v,t}:
  47,1,"۔یِمو لُکو کُفر کوٚر بیٚیہِ رُکٲوِ کھ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ ، خُدا ین کٔرۍ تِہندۍ اعما ل ضا یع۔"
  47,2,"۔تہٕ یِمو لُکو ایمان اوٚ ن تہٕ نیک عملہٕ کرِ، تہٕ مو نُکھ سُہ چیز یُس محمد صلی اللہ علیہ وسلمن پٮ۪ٹھ نٲزِل چُھ سپُد مُت۔ بیٚیہِ چُھ سُہ سراسر حق تِہندِ س ربّ سٕندِ طر فہٕ۔خُدا ین کرِ تِہنزٕ بُرٲ یِیہِ تِمن نِشہِ دوٗر تہٕ کوٚرُن تِہُند حال دُرست۔"
  47,3,"۔یہِ چُھ امہِ موجوٗب زِ کُفر کر ن والیو کٔر بٲطلٕچ پیروی ، تہٕ ایمان اَنن والیو کٔرتمہِ حقٕچ پیر وی یُس تِہندِس ربّ سٕندِ طر فہٕ چُھ آمُت۔یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ لوٗکن ونان تِہٕنز ٹھیک ٹھیک حیثیت۔"
  47,4,"۔پَتہٕ ییٚلہِ تۅہیہِ یِمن کٲفر ن سٍتۍ بُتھۍ لا گے سپدیو تیٚلہِ چھےٚ گۅڈنِچ کٲم تِمن گردَنہٕ تُلنہِ ، یوٚت تام زن توٚہۍ تِم جان پٲٹھۍ مٲرِیوٗکھ، پتہٕ گٔنڈٕ یوٗکھ مضبو طی سان قٍدۍ، امہِ پتہٕ ﴿چُھ اختیار﴾ کٔرِو احسا ن ، نَتہٕ کٔرِو فِد یُک معا ملہٕ ، توٚت تام یوٚت تام لڑٲے ترا وِ پنٕنۍ ہتھیار۔﴿ییٚمہِ آیت کیو لفظو سٍتۍ تہِ تہٕ یتھ سیا ق و سبا قس منٛز یہِ آیت آمٕژ چھےٚ تمہِ سٍتۍ تہِ چھےٚ یہِ کتھ صا ف پے لگا ن زِ یہِ چھےٚ لڑا یہِ ہُند حُکم یِنہٕ پتہٕ تہٕ لڑٲے شروع سپد نہٕ برونٛہہ نٲزِل سپٕز مٕژ۔ییٚلہِ کٲفر ن سٍتۍ بُتھۍ لا گے سپد یو الفا ظ چِھ اَتھ پٮ۪ٹھ دلا لت کران زِ وُنہِ چَھنہٕ بُتھۍ لا گے سپٕز مٕژ، تہٕ امہِ کہ سپد نہٕ برونٛہہ چُھ یہِ ہدا یت دِنہٕ یِوان زِ ییٚلہِ سۅ سپدِ ، تیٚلہِ پزِ مُسلمانن سارِ وٕے برونٛہہ پنُن تو جہ دُشمن سُند جنگی طاقت وارٕ پٲٹھۍ پُھٹرا ونس پٮ۪ٹھ صرف کرُن۔امہِ پتہٕ یِم لُکھ گرفتار کر نہٕ یِن تِہندِس معا ملس منٛز چُھ مُسلمانن یِتہِ اختیار زِ فِد یہِ ہیٚتھ یا پننیٚن قٍد ٮ۪ن ہُند تبا دلہٕ کٔرِتھ تراون یلہٕ، تہٕ یہِ اختیار تہِ چُھکھ زِ قٲدس منز تھٲوِتھ کر ن تِمن سٍتۍ احسا نُک برتا و،یا اگر مُنٲسِب با سیٚکھ تیٚلہِ ترٲوِنکھ احسا ن کہ طور یلہٕ۔﴾ یہِ چھےٚ تُہندِ کرنٕچ کٲم۔اللہ تعالیٰ اگر ییٚژھہ ہے تیٚلہِ ہیٚیہِ ہے یِمن پا نے انتقام، ﴿یہِ طر یقہٕ چُھ تٔمۍ امہِ موجوٗب اختیار کوٚر مُت﴾ تا کہ تۅہیہِ لُکن آزماویٚو اکھ أکۍ سٕندِ ذریعہ ۔﴿یعنی خُدایس اگر محض بٲطل پرستن ہُند کلہٕ آسِہے دگُن تیٚلہِ اوسنہٕ سُہ امہِ کامہِ خٲطرٕ تُہُند محتا ج کینٛہہ۔ یہِ کٲم ہیٚکہِ ہے تٔمۍ سُنٛد اکھ بِنیُل یا اکھ طوٗفان أچھ ٹیٖنٹہِ منٛز کٔرِتھ۔مگر تس چُھ پیش نظر یہِ زِ انسانو منٛزٕ یِم حق پرست آسن تِم ٹکرٲوِن بٲطل پرستن سٍتۍ تہٕ تِمن خلا ف کٔرِن جہا دتا کہ یَس منٛز یِم او صا ف آسن سُہ گژِھہ اتھ امتحا نس منٛز پرٛز لِتھ پوٗرٕ پٲٹھۍ نوٚن نیرُن تہٕ پرٛتھ اکھ ییٚمہِ مقا مُک تہٕ مر تبُک پننہِ کردار کہِ لحا ظہٕ حقدار آسہِ ، تس گژِھہ سُہ دِنہٕ یُن۔﴾ تہٕ یِم لُکھ اللہ تعالیٰ سٕنزِ وَتہِ منٛز مار نہٕ یِن ، اللہ تعالیٰ کرِ نہٕ ہر گز تِہِندۍ اعمال ضا یع۔"
  47,5,"۔سُہ کرِ تِمن رہنمٲیی، ﴿یعنی جنتس کُن کر یکھ رہنمٲیی﴾ تِہُند حا ل کرِ دُرست ،"
  47,6,"۔تہٕ تِمن کرِتتھ جنتس منٛز دٲخل ییٚمہِ نِشہِ تٔمۍ تِم وٲقف چِھ کر نٲوِمٕتۍ۔"
  47,7,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، اگر توٚہۍ خُدایس مدد کٔرِو سُہ کریوتۅہیہِ مدد۔﴿خُدایس مدد کر نہٕ نِشہِ چُھ مُراد اللہ تعالیٰ سُند کلمہٕ بُلند کرُن تہٕ حق سر بُلند کر نچہِ کامہِ منٛز حصہٕ نِیُن﴾ تہٕ سُہ جماوِ تُہٕندۍ قد م مضبو ط۔"
  47,8,"۔روٗدۍ تِم لُکھ یِمو کُفر کوٚر ۔تِہندِ خٲطرٕ چھےٚ ہلا کت تہٕ خُداین چِھ تِہِندۍ اعما ل چھلہٕ چھا نگرِ کٔرِمٕتۍ۔"
  47,9,"۔تِکیازِ تِمو کوٚر سُہ چیز نا پسند یُس خُداین چُھ نازِ ل کوٚر مُت۔لہٰذا کٔرۍ خُداین تِہِندۍ اعمال ضا یع۔"
  47,10,"۔کیا تِم ٲسۍ نا ز مینس منٛز پھیٖر ۍ مٕتۍ تھوٗرِمٕتۍ،تاکہِ تِمن لُکن ہُند انجام وُچھہَن یِم تِمن برونٛہہ چِھ گُزریمٕتۍ؟خُداین پِھیرُ تِہُند سورُے کینٛہہ تِمن پٮ۪ٹھ دُبہٕ، تہٕ یِتھی نتیجہِ چِھ یِمن کٲفر ن نصیبس﴿اتھ چِھ زٕ ہ مطلب۔اکھ یہِ زِ یۅسہٕ تبٲہی تِمن کٲفر ن وُچِھنۍ پیٚیہِ تِژٕ ھے تبٲہی چھےٚ وۅ نۍ تِمن کٲفر ن نصیبس یِم محمد صلی اللہ علیہ وسلمن ہٕنز دعوت چِھنہٕ مانان۔دوٚیُم مطلب چُھ یہِ زِ یِمن لُکن ہٕنز تبٲہی چَھنہٕ صرف دنیا کِس عذا بس پٮ۪ٹھ ختم سپزٕ مٕژ بلکہ چھےٚیٔہے تبٲہی تِمن ٲخرتس منٛز تہِ نصیبس﴾"
  47,11,"۔ یہِ چُھ امہِ موجو ب زِ ایمان انن  والیٚن ہُند حٲمی تہٕ کار ساز چُھ اللہ،تہٕ کٲفرن ہُند حا می تہٕ کارساز چُھنہٕ کٕہٕنۍ۔ع"
  47,12,"۔ایمان انن والیٚن تہٕ نیک عمل کرن والیٚن کرِ اللہ تعالیٰ تِمن جنّتن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅلہٕ چھےٚ پکان،تہٕ کُفر کرن وٲلۍ چِھ بس دنیا چہِ کینٛژھن دۅہن ہٕنزِ زند گی ہٕندۍ مزٕ ہ لوٗٹان،جانور ن ہٕندۍ پٲٹھۍ چِھ کھیٚوان چیٚوان، تہٕ تِہُندٲخر ی ٹھکا نہٕ چُھ جہنم۔"
  47,13,"۔اے نبی صلی اللہ علیہ وسلم، کٲژاہ بستی چھےٚ تِژٕھہ گُزر یمژٕ،یِمہٕ تُہنزِ تمہِ بستی کھۅتہٕ سٮ۪ٹھاہ زور آور آسہٕ ییٚمۍ توٚہۍ کٔڑِتھ چِھنَو ژٕھنِمٕتۍ۔﴿یعنی مکّہ ییٚتہِ قر یشو حضور صلی اللہ علیہ وسلم ہجر ت خٲطرٕ مجبو ر کٔرۍ﴾ اسہِ کٔرۍ تِم تِتھہٕ پٲٹھۍ ہلاک زِ کانٛہہ اوس نہٕ تِمن بچا و ن وول۔"
  47,14,"۔یہِ ہیٚکیا بٔنِتھ زِ یُس پننِس ربّ سٕندِ طر فہٕ أکِس صا ف تہٕ ٹا کارٕ ہدا یتس پٮ۪ٹھ آسہِ، سُہ بنہِ تِمن لُکن ہٕندۍ پٲٹھۍ یِہندِ خٲطرٕ تِہنز بُرٕ عمل خۅش کرٕوُنۍ بنا و نہٕ چھےٚ آمٕژ۔تہٕ تِم چِھ پننیٚن خوٲہشا تن ہٕندۍ پیر و کار بنیمٕتۍ۔"
  47,15,"۔پر ہیز گار لُکن خٲطرٕ ییٚمہِ جنتُک وعدٕہ چُھ کر نہٕ آمُت تمِچ شان چھےٚ یہِ زِ ، تتھ منٛز آسن کۅلہٕ پکان صا ف شفا ف آب چہِ، تہٕ کۅ لہٕ آسن پکا ن تِتھہِ دۅد چہِ ییٚمہِ کِس مَز س منٛز رَژھ فرق آسہِ نہٕ آمٕژ،کۅلہٕ آسن پکان تِتھہِ شرب چہ یُس چینہٕ والین خٲطر لذیذ آسہِ ،کۅلہٕ آسن پکان صا ف شفا ف ما چھ چہِ۔﴿حدیثس منٛز چھےٚ اَمِچ یہِ تشر یح زِ سُہ دۅد آسہِ نہٕ جا نورَو ہٕند یو تھَنَو منٛزٕ درٚ امُت کینٛہہ، سُہ شرا ب آسہِ نہٕ سٔڑروا نہٕ آمتیٚو میوَو منٛزٕ کڑ نہٕ آمُت کینٛہہ ، سُہ ماچھ آسہِ نہٕ تُلر یٚو منٛزٕ در امُت کینٛہہ، بلکہ پکن یِم سٲری چیز قدر تی نا گن ہٕنزِ شکلہِ منٛز۔ ﴾ تہٕ تَتھ منٛز آسن تِہندِ خٲطرٕ پرٛتھ قسمٕکۍ میوٕ ہ ، بیٚیہِ آسہِ تِہندِس ربّ سٕندِ طر فہٕ مغفر ت۔﴿ کیا سُہ شخص ییٚمۍ سٕندِس حِصس منٛز یہِ جنّت یِنہٕ وول چُھ﴾ سُہ ہیٚکیا تِمن لُکن ہٕندۍ پٲٹھۍ ٲسِتھ یِم جہنمس منٛز ہمیشہ روزَن، تہٕ یِمن تِیُتھ توٚ ت آب چا و نہٕ یِیہِ یُس تِہِندۍ أندرَم تا م ژٹہِ ؟"
  47,16,"۔یِمن منٛز چِھ کینٛہہ لُکھ تِتھۍیِم کن دٲرِتھ تُہٕنز کتھ بوزان چِھ ، پتہٚ ییٚلہِ تۅہیہِ نِشہِ نیران چِھ، پتہٕ چِھ تِمن لُکن پٕرٛژھان یِمن عِلمٕچ نعمت چھےٚ بخشنہٕ آمٕژ زِ وُنۍ وُنۍ کیا وَنیاو یِمَو؟ ﴿یہِ ذکر چھےٚ تِمن کُفّار ن مُنا فقن تہٕ مُنکر ینِ اہلِ کتابن ہٕنز ،یِم نبی صلی اللہ علیہ وسلمن ہٕنزِ مجلسہِ منٛز یِتھ بیٚہوان ٲسۍ، تہٕ پتہٕ ٲسۍ تِہندۍ صلی اللہ علیہ وسلم ،ارشادات یا قرآن مجیدٕ کۍ آیات بوزان، مگر چو نکہ تِہُند دل اوس تِمَو مضمو نَو نِشہِ دُور یِم حضور صلی اللہ علیہ وسلمن ہٕنزِ مُبارک زبٲنۍ نیران ٲسۍ ، امہِ موجوٗب ٲسۍ نہٕ تِم سورُے کینٛہہ بوٗزِتھ تہِ کِہِنۍ بوزان تہٕ نیٚبر نیٖرِ تھ ٲسۍ مُسلمانن پٕرٛژھان زِ وُنۍ وُنۍ کیا ٲسۍ حضور صلی اللہ علیہ وسلم فر ماوان۔﴾یِم چِھ تِم لُکھ یِہندٮ۪ن دِلن پٮ۪ٹھ خُدا ین ٹھپہٕ چُھ لگو و مُت،تہٕ یِم چِھ پننیٚن خواہشاتن ہٕندۍ پیرو کار بینمٕتۍ۔"
  47,17,"۔روٗدۍ تَم لُکھ یِمَو ہدایت چھُ لوبمُت ،اللہ تعالیٰ چُھ تِمن ہُر یمانہٕ ہدا یت دِ وان تہٕ تِمن چُھ تِہندِ حِصُک تقویٰ عطا فر ماوان۔ وۅ نۍ کیا یِم لُکھ چھا بس قیا مت سٕے پراران زِ سۅ گژِھہ اچا نک یِمن پٮ۪ٹھ یِنۍ ؟ تمِکۍ علا ما ت چِھ آمٕتۍ۔ ییٚلہِ سۅ پا نہٕ یِیہِ تیٚلہِ کُس نصیحتُک مو قٕع روزِ یِہندِ خٲطرٕ پتھ کُن ؟"
  47,18,"۔لہٰذا ، اے نبی صلی اللہ علیہ وسلم ، وارٕ پٲٹھۍ زٲنِو زِ خُدایس ورٲے چُھنہٕ عبا دتُک حقدار بیٚیہِ کانٛہہ، تہٕ معٲفی منگِو پننیٚن قصورن خٲطرٕ تہِ تہٕ مو من مردن تہٕ مو من مستوٗرا تن خٲطرٕتہِ۔﴿ اسلامن یِم اخلا ق انسان ہیچھنوو مُت چُھ،تِمو منٛزٕ چُھ اکھ یِتہِ زِ ،بندٕہ ٲسِتن پننِس ربّ سٕنز بند گی تہٕ عبا دت کر نس منٛز تہٕ تٔمۍ سٕندِ دین خٲطرٕ جان لڑاونس منٛز کٲژاہ تہِ کوٗشش کران روٗد مُت تس پزِ نہٕ زانٛہہ اَتھ دۅکھس منٛز مبتلا سپدُن زِ یِکینژھاہ مےٚ کرُن پزِ ہے تہِ کوٚر مےٚ، بلکہ پزِ تس ہمیشہ یی سمجھان روزُن زِ میٲنِس مٲلِک سُند یُس حق مےٚ اوس سُہ ہیوٚ ک نہٕ مےٚ نکھہٕ وٲلِتھ،تہٕ پرٛتھ وقتہٕ گژِھہ پننیٚن قُصور ن ہُند اعترا ف کٔرِتھ خُدایس یۅہے دُعا منگان روزُن زِ چٲنِس خد متس منٛز یۅسہٕ تہِ کوتٲہی مےٚ گٔیہِ تتھ کرُم در گُزر۔یۅہے چُھ اصلی رُوح اللہ تعالیٰ سٕندِ امہِ ارشادُک زِ  اے نبی ، پننہِ قصورٕچ منگِو معٲفی۔اللہ تعالیٰ چُھ تُہٕنز ن سر گر مِیَن تہِ زانان تہٕ تُہندِ ٹھکا نہٕ نِشہِ تہِ چُھ وٲقف۔ع"
  47,19,"۔یِمو لُکو ایمان چُھ اوٚ نمُت تِم ٲسۍ ونان زِ ﴿ مطلب چُھ یہِ زِ یِم لُکھ  پٔزۍ مسلمان ٲسۍتِم ٲسۍ قتال کہ حکمہ خاطر بے تاب ،البتہ یِم لُکھ ایمان ورٲے مسلمانن ہٕندِس دٔرِس منٛز شامل ٲسۍ گٔمٕتۍ ،قتا لُک حکم یِوا نٕے ژوٚ ل تِمن زَنتہٕ زُو نیرِ تھ۔﴾ کانٛہہ سُورٕ ہ کیا زِ چُھنہٕ یِوان نٲزِل کر نہٕ ﴿یتھ منٛز جنگُک حُکم آسہِ ۔ ﴾ مگر ییٚلہِ اکھ پۅ ختہٕ سُورٕہ نٲزِ ل کر نہٕ آو یتھ منزجنگٕچ ذکر ٲس، پتہٕ وُچُھو تۅہیہِ زِ یِہندِ س دِلس منٛز بیمٲرۍ ٲس، تِم چِھ تۅہیہِ کُن تِتھہٕ پٲٹھۍ وُچھا ن زَنتہٕ مو تٕچ  بے ہو شی تِمن پٮ۪ٹھ طٲری گٔیہِ افسوس تِہندِس حا لس پٮ۪ٹھ ۔﴿ تِہنزِ زیوِ پٮ۪ٹھ چُھ﴾"
  47,20,"۔ اطاعتُک اقرار تہٕ جا ن جان کتھہٕ۔ مگر ییٚلہِ قطعی حکم آو دِنہٕ، تمہِ وقتہٕ اگر تِم خُدایس سٍتۍ پننِس وعدس منٛز پٔزِ یٲرۍ نیرٕ ہن تیٚلہِ اوس تِہندی خٲطرٕ رُت۔"
  47,21,"۔ وۅ نۍ کیا تۅہیہِ لُکَو نِشہِ ہیٚکیا امہِ ورٲے بیٚیہِ کینٛہہ توقع کر نہٕ یِتھ زِ اگر توٚہۍ پوٚت پھیٖرِتھ گٔو، تیٚلہِ کٔرِو زمینس منٛز بیٚیہِ فساد بر پا، تہٕ پا نہٕ وٲنۍ ژٔٹِو اکھ أکِس گردَنہٕ ؟ ﴿ امہِ ارشادُک مطلب چُھ یہِ زِ اگر وُنۍ کیٚنس توٚہۍ اسلام کہ مُدا فعت نِشہِ پتھ چِھو ہیٚوان تہٕ تَمہِ عظیمِ الشّان اصلٲحی انقلا ب خٲطرٕ چِھو جان و ما لٕچ بٲزۍ لگا و نہٕ نِشہِ بُتھ پھِر ان ییٚمِچ کوٗشش محمد صلی اللہ علیہ وسلم تہٕ اہلِ ایمان کران چِھ،تیٚلہِ کیا ہیٚکہِ امہِ ورٲے اَمِیُک نتیجہِ ٲسِتھ زِ توٚہۍ پھیرِ و بیٚیہِ تتھۍ جٲہلیت کِس نظا مَس کُن یتھ منٛز توٚہۍ ہَتہٕ وادَو ؤرِ یو پٮ۪ٹھہٕ اکھ أکۍ سٕندۍ کلہٕ چِھو ژٹان روٗزِ مٕتۍ، پنٕنۍ اولاد تام چِھو زِ ند ے دفن کران روٗدِ مٕتۍ تہٕ خُداے سٕنز  زمین چِھو ظلم و فسا دٕ سٍتۍ بھران روٗدِمٕتۍ۔﴾"
  47,22,"۔یِم چِھ تِم لُکھ یِمن پٮ۪ٹھ خُداین کٔر لعنت، تہٕ یِم بنٲوِ ن أنۍ تہٕ زٔرۍ۔"
  47,23,"۔ کیا یِمو لُکو کوٚرنا قرآنس پٮ۪ٹھ غور،کِنہٕ یِہٕندٮ۪ن دِلن پٮ۪ٹھ چِھ قُلف کھٲلِتھ؟"
  47,24,"۔ حقیقت چھےٚ یہِ زِ یِم لُکھ ہدا یت وا ضح سپد نہٕ پتہٕ تمہِ نِشہِ پھیٖرۍ،تِہندِ خٲطرٕ چھےٚ شیطا نن یہِ رٔوِش سہل بنٲومٕژ، تہٕ اَپز ٮ۪ن توقعا تن ہُند سلسلہٕ چُھن تِہندِ خٲطرٕ دراز کٔرِتھ تھو و مُت۔"
  47,25,"۔اَمی موجوٗب ووٚن تِمو اللہ تعالیٰ سُنٛد نٲزِل کر نہٕ آمُت دین نا پسند کر ن والیٚن زِ کینژھن معا ملاتن منٛز مانو أسۍ تُہُند۔﴿ یعنی ایمانُک اقرار کر نہٕ تہٕ مُسلمانن ہٕندِس دٔرِس منٛز شٲمِل گژھنہٕ باوجود روٗدۍ تِم أندری أندری اسلام کیٚن دُشمنن سٍتۍ ساز باز کران تہٕ تِمن سٍتۍ روٗدۍ وعدٕہ کران زِ کینژھن معا ملاتن منٛز دِ مَو أسۍ تۅہیہِ ساتھ﴾ اللہ تعالیٰ چُھ تِہٕنزٕ یِمہٕ سِرٕ کتھہٕ وارٕ پٲٹھۍ زانان۔"
  47,26,"۔پتہٕ کیا حال آسہِ تمہِ وقتہٕ ییٚلہِ فر شتہٕ تِہندۍ رُوح کرن قبض، تہٕ تِم نِن تِمن تِہند ٮ۪ن بُتھیٚن تہٕ شا نن چو ب دِوان دِوان؟"
  47,27,"۔یہِ سپدِ اَمی موجوٗب زِ تِمو کٔر تمہِ طر یقٕچ پیر وی یُس خُدایس ناراض کر ن وول چُھ،  تہٕ تٔمۍ سٕندِ رضا ہٕچ وَتھ اختیار کرٕنۍ کٔرٕ کھ نہٕ پسند۔أتھۍ بِنا ہَس پٮ۪ٹھ کٔر ۍ تٔمۍ تِہندۍ سٲری اعمال ضا یع۔ع۔ ﴿ اعمالو نِشہِ چُھ مُراد تِم سٲری اعمال یِم مُسلمان بٔنِتھ تِم انجام روٗدۍ دِوان۔تِہٕنزٕ  نمازٕ، تِہنزٕ روزٕہ ، تِہٕنزٕزکوٰتہ ،غر ض تِم تمام عبا دات تہٕ تِمہٕ سار ے نیکیہِ یِمہٕ پننہِ ظٲہر ی شکلہِ ہندِ اعتبارٕ رژَن عملن منٛز شما ر چھےٚ سپدان گٔیہِ اتھ بِنا ہس پٮ۪ٹھ ضا یع زِ تِمو کوٚر نہٕ مُسلمان آسنہٕ با وجود تہِ خُدا یس  تہٕ تٔمۍ سٕندِس دینس تہٕ ملّت اسلامیہِ ہَس سٍتۍ اِخلا صُک تہٕ وفا دٲری ہُند رٔو یّہِ اختیار ،بلکہ روٗدۍ محض پننہِ دُنیٲو ی مفادٕ خٲطرٕ دین کیٚن دشمنن سٍتۍ ساز باز کران تہٕ اللہ تعالیٰ سٕنزِ وَتہِ منٛز جہا دُک مو قع یِوا نٕے لٔگۍ پنُن پا ن بچا ونٕچ فِکر کر نہِ﴾۔"
  47,28,"۔کیا تِمو لُکو یِہندٮ۪ن دِلن منٛز بیمٲرۍ چھےٚ چھا یہِ سمجھمُت زِ ، اللہ تعالیٰ کیا کڑِنہٕ تِہندٮ۪ن دِلن ہٕندۍ کھۅچر نٔنۍ؟"
  47,29,"۔اگر أسۍ یژھو أسۍ ہاوَو تۅہیہِ تِم أچَھو، تہٕ تِہند یو بُتھیو تلہٕ پرزنٲوِ یوٗکھ توٚہۍ تِم۔ تہٕ تِہند کلام کہِ اندازٕ تلے زٲنِیو کھ توٚہۍ تِم۔ اللہ تعالیٰ چُھ تۅہیہِ سارِ نٕے ہٕند یٚو اعما لو نِشہِ ٹھیک پٲٹھۍ وٲقف۔"
  47,30,"۔أسۍ تراوَو ضرور توٚہۍ لُکھ آزمٲیشہِ منٛز تاکہ تُہٕندٮ۪ن حالاتن ہُند کَرو جا نچ تہٕ وُچَھو زِ تۅہیہِ منٛز کم چِھ مجٲہد تہٕ ثٲبِت قد م۔"
  47,31,"۔یِمَو لُکو کُفر کوٚر تہٕ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ رُکٲوِکھ، بیٚیہِ کوٚرُکھ رسولس سٍتۍ جھگڑٕ ییٚلہِ زن تِمن پٮ۪ٹھ سیٚز وَتھ وا ضح ٲس سپٕز مٕژ، در حقیقت ہیٚکن نہٕ تِم خُدایس کانٛہہ نقصا ن کٔرِتھ، بلکہ کرِ اللہ تعالیٰ ہٕے تِہُندسورُے کوٚر مُت کرٛ وومُت ضا یع۔"
  47,32,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، توٚہۍ کٔرِ واللہ تعالیٰ سٕنز اطا عت بیٚیہِ کٔرِو رسول صلی اللہ علیہ وسلم سٕنز اطا عت، تہٕ پنٕنۍ اعما ل مَہ کٔرِ و برباد۔﴿دوٚ یِمیٚن لفظن منٛز وَنو زِ اعمالن ہُند فٲیدٕہ مند تہٕ نتیجہِ خیز آسنُک سورُے دار مدار چُھ خُدایس تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕندِس اطا عتس پٮ۪ٹھ۔اطا عت نِشہِ مُنحر ف سپدِ تھ چَھنہٕ کانٛہہ عمل تہِ رٕژ عمل روزان زِ انسا ن بنہِ کانٛہہ اجر حٲصل کر نُک حقدار۔﴾"
  47,33,"۔کُفر کر ن والیٚن تہٕ خُداے سٕنزِ وَتہِ نِشہِ رُکا و ن والیٚن، تہٕ مرنس تام کُفر س پٮ۪ٹھ جمِتھ روزن والیٚن کرِ نہٕ اللہ تعالیٰ ہر گز معا ف۔"
  47,34,"۔کمزور مَہ بٔنِو تہٕ نَہ مَہ کٔرِو صلحُک در خوا ست۔﴿ یتھ جایہِ گِژھہ یہِ کتھ در نظر روزٕنۍ زِ یہِ ارشاد چُھ تتھ زمانس منٛز فر ما و نہٕ آمُت ییٚلہِ صرف مد ینہ چہِ أکِس لۅ کچہِ بستی منٛز کینژھن ہتن پٮ۪ٹھ مشتمل مہا جر ن تہٕ انصا رن ہٕنز اکھ لۅکٕٹ مۅکٕٹ چھۅ کھ اسلامٕچ عَلم بردٲری کران ٲس ،تہٕ امِیُک مُقا بلہٕ اوس نہٕ محض قریش کیٚن طا قت ور قبیلہٕ نٕے یوت سٍتۍ کینٛہہ، بلکہ اوسُس پوٗرٕ عر ب مٕلکہٕ کیٚن کُفارن تہٕ مُشر کن سٍتۍ۔اتھ حا لتس منٛز چُھ فر ما و نہٕ یِوان زِ ہمت ہٲرِتھ یِنہٕ یِمن دشمنن سٍتۍ صلح ہُک در خواست کر نہِ لٔگِو ،بلکہِ گٔژِھو کلہٕ دِنہٕ خٲطرٕ تیار۔﴾ توٚہۍ چِھو غٲلب روزن وٲلۍ۔ اللہ تعالیٰ چُھ تۅہیہِ سٍتۍ تہٕ تُہٕندۍ اعمال کرِ نہٕ ہر گز ضا یع۔"
  47,35,"۔یہِ دُنیا ہٕچ زند گی چھےٚ اکھ کھیل تہٕ تما شہِ۔"
  47,36,"اگر توٚہۍ ایمان تھٲوِو تہٕ تقویٰ ہٕچ رٔوِشہِ پٮ۪ٹھ پکان روٗزِو، تیٚلہِ دِیہِ اللہ تعالیٰ تۅہیہِ تُہٕندۍ اجر ، تہٕ سُہ منگہِ نہٕ تۅہیہِ تُہٕندۍ مال۔ ﴿یعنی سُہ چُھ غنی ، تس چَھنہٕ پننہِ ذات خٲطرٕ تۅہیہِ کینٛہہ ہیٚنٕچ ضرورت۔ اگر سُہ پننہِ وتہِ منٛز تۅہیہِ کینٛہہ خر چ کر نہٕ خٲطرٕ ونان چُھو ، سُہ چُھو ونہٕ پننہِ خٲطرٕ بلکہ چُھو تُہٕندۍ رٕژرٕ خٲطرٕ ونان ۔ ﴾"
  47,37,"۔اگر کُنہِ ساعتہٕ سُہ تۅہیہِ تُہٕندۍ مال منگہِ تہٕ اَند ہیٚتھ کرِ سٲری تۅہیہِ نِشہِ طلب، تیٚلہِ کٔرِو توٚہۍ بخل تہٕ سُہ کڑِ تُہٕندۍ کھۅ چر نٔنۍ۔"
  47,38,"۔وُچھِو تۅہیہِ لُکن چَھو دعوت دِنہٕ یِوان زِ اللہ تعالیٰ سٕنزِ وَتہِ منٛز کٔرِ و مال خر چ۔ اتھ پٮ۪ٹھ چِھ تۅہیہِ منٛز کینٛہہ لُکھ یِم بخل چِھ کران، حالانکہ یُس بخل چُھ کران سُہ چُھ در حقیقت پننِس پان سٕے سٍتۍ بخل کران۔اللہ تعالیٰ چُھ غنی ،توٚہۍ چِھو تٔمۍ سٕندۍ محتا ج۔ اگر توٚہۍ رو ے پھِرِ و ، تیٚلہِ اَنہِ اللہ تعالیٰ تُہنزِ جایہِ بیٚیہِ کُنہِ قو مس، تہٕ تِم آسن نہٕ تُہٕندۍ پٲٹھۍ ۔ ع"
