quran[64]{c,v,t}:
  24,1,"۔یہِ چُھ اکھ سوٗرہ یُس اسہِ نٲزِل چُھ کوٚر مُت ، تہٕ یہِ چُھ اسہِ فر ض کوٚر مُت،تہٕ اتھ منٛز چِھ اسہِ صاف صا ف ہدا یات نٲزِل کٔرِ مٕتۍ ﴿ یعنی یِمہٕ کتھہٕ یتھ سوٗرس منٛز وَننہٕ چھےٚ آمژٕ  تمہِ چَھنہٕ  سفا رشاتزِ دِل ییٚژھیو تہٕ مٲنِو، نَتہٕ یِکینژھاہ ییٚژِھو تہِ کٔرِ و ، بلکہ چِھ قطعی احکام یِہنز پیر وی کرٕنۍ لٲزِم چھےٚ۔ اگر مو من چِھو تیٚلہِ چھےٚ یِہنز پیروی کرٕنۍ تُہُند فر ض ۔ ﴾ بنان چُھ توٚہۍ رٔٹِو سبق۔"
  24,2,"۔زانیہ ﴿ بدکار ﴾ زنا نہٕ زانی ﴿بد کار﴾ مَرد ،دۅشوٕ یو منٛزٕ لٲیِو پرٛتھ کٲنٛسہِ ہتھ گوڈٕ۔﴿ زِ نا ہس متعلق چُھ ابتدٲیی حکم سورہ نسا آیت 15 ہس منٛز پتھ کُن آمُت۔وۅ نۍ چُھ اَمِیُک یہِ قطعی سزا مقرر کر نہٕ یِوان ۔ یہِ سزا چُھ تمہِ صور ت خٲطرٕ ییٚلہِ زٲنی مرد نیتھرٕ روٚس آسہِ ، یا زانیہ زنانہٕ نیترٕ روٚس آسہِ قرآن پاکس منٛز تہِ چھُ اَتھ کُن اشارٕہ موجود یِتھہٕ پٲٹھۍ زن سورہ نسا  ٔ،اآیت،25 نِشہِ چھُ پے لگان تہٕ واریاہو حدیثو، حضور صلی اللہ علیہ وسلم تہٕ خلفا راشد ینن ہٕندِ عملی سنّت تہٕ اجما ع اُمّت نِشہِ تہِ چُھ یہِ ثٲبت زِ نیتھرٕ آسنہٕ کِس صورتس منٛز چُھ زنا ہُک سزا رجم ۔ ﴾ تہٕ یِمن پٮ۪ٹھ عار یِنُک جذ بہٕ یِنہٕ تۅہیہِ اللہ تعالیٰ سٕندِس دین کِس معا ملس منٛز پَتھ رٹہِ، اگر توٚہۍ خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان چِھو تھا وان ،تہٕ تِمن سزا دِنہٕ وقتہٕ گژِھہ اہلِ ایمانن ہٕنز اکھ جما عت مو جود روزٕ نۍ۔﴿ یعنی سزا گژِھہ بر سرِ عام دِنہٕ یُن تا کہ مجرِ مس گژِھہ رسوٲیی تہٕ با قین لُکن میلہِ عبرت تہٕ نصیحت، تہٕ یہِ گناہ پھٔہلہِ نہٕ مسلم معا شر س منٛز﴾۔"
  24,3,"۔زٲنی مَہ کٔرِن نکا ح مگر ﴿کٔرِن ﴾ زانیہ  ہس سٍتۍ یا مُشر ک  زنانہِ سٍتۍ، تہٕ زانیہ ہس سٍتۍ مَہ کٔرِن نکا ح مگر ﴿کٔرِن ﴾ زٲنی یا مُشر ک، تہٕ یہِ چُھ حرام کر نہٕ آمُت اہلِ ایمانن پٮ۪ٹھ۔﴿ یعنی سُہ زٲنی ییٚمۍ نہٕ تو بہٕ آسہِ کوٚر مُت تس خٲطرٕ اگر مُنٲسب چُھ،تیٚلہِ چَھس صرف زانیہ مُنٲسب یا چَھس مُشر ک زنانہٕ۔سُہ چُھنہٕ کٲنٛسہِ مو من تہٕ صا لح خا تو نہِ خٲطرٕمُنٲسب، تہٕ حرام چُھ اہلِ ایمانن خٲطرٕ زِ تِم دِن زٲنِتھ مٲنِتھ پننہِ کورِ یتھیٚن بد کارن۔ یِتھے پٲٹھۍ اگر زانیہ ﴿ تو بہٕ روٚستُے﴾ زنانن خٲطرٕ مُناسب چِھ ، تیٚلہِ چِھ یِمنٕے ہِو ۍ زٲنی یا مُشر ک ۔ کٲنٛسہِ مومن صا لح سٕندِ خٲطرٕ چَھنہٕ تِمہٕ مُنٲسب، تہٕ حرا م چُھ مو منن خٲطرٕ زِ یِمن زنانن ہٕنزِ بد چلنی ہُند حال تِمن پے آسہِ تِمن سٍتۍ کر ن دٲنستہٕ طور نکا ح۔ امہِ حُکمُک اطلا ق چُھ صرف تِمنٕے مردَن تہٕ  مستوٗراتن پٮ۪ٹھ سپدان، یِم پننہِ بُرٕ رٔوِشہِ پٮ۪ٹھ قٲیم  آسن۔یِم لُکھ تو بہٕ کٔرِتھ پننِس پا نس اصلا ح کر ن، تِمن پٮ۪ٹھ چُھنہٕ اَمِیُک اطلا ق سپدان، تِکیازِ تو بہٕ تہٕ اصلا ح پتہٕ چُھنہٕ  زانی آسنُک صفت تِمن سٍتۍ روزان﴾"
  24,4,"۔تہٕ یِم لُکھ پاک دا من ، مستوٗراتن پٮ۪ٹھ تہمت لگا و ن ،﴿ یعنی زِ نا ہٕچ  تہمت ،تہٕ یۅہے حکم چھُ پاکدامن مردن پٮ۪ٹھ تہٕ زناہٕچ تہمت لگاونُک ۔اصطلاحس منٛز چھِ اَتھ تہمت ترٲشیقذ ف ونان ۔ ﴾ پتہٕ یِن نہٕ ژور گواہ ہیٚتھ،تِمن لٲیِو شیتھ کوڑٕ، تہٕ تِہٕنز شہا دت مَہ کٔرِو زانٛہہ قبو ل، تہٕ تِم چِھ پا نے فا سق،"
  24,5,"۔سواے تِمو لُکو، یِم امہِ حر کتہٕ پتہٕ تو بہٕ کرن تہٕ اصلا ح کر ن، اللہ تعالیٰ چُھ ضرور تیٚلہِ ﴿تِہندِس حقس  منٛز﴾ بخشن وول تہٕ رحم کر ن وول۔﴿اتھ کتھہِ پٮ۪ٹھ چُھ فقہا ہن ہُند اتفا ق زِ تو بہٕ سٍتۍ چُھنہٕ قذ فُک سزا سا قط سپدان، اتھ پٮ۪ٹھ تہِ چُھ اتفاق زِ تو بہٕ کر ن وول روزِ نہٕ فا سق تہٕ اللہ تعالیٰ کرِ تس معا ف ۔ البتہ اتھ منٛز چُھ اختلا ف زِ تو بہ کر نہٕ پتہٕ یِیا أمۍ سٕنز شہا دت قبو ل کر نہٕ کِنہٕ نہ۔حنفیہ چھ امہِ کتھہِ ہٕندۍ قٲیِل زِ أمۍ سٕنز شہا دت آسہِ نہٕ قٲبِل قبو ل۔ امام شا فعی رحمتہ اللہ علیہ  ، اما م مالک علیہ رحمہ امام احمد رحمتہ اللہ علیہ  چِھ أمۍ سٕنز شہا دت قٲبلِ قبو ل سمجھان۔﴾"
  24,6,"۔تہٕ یِم لُکھ پننیٚن خا ندارِ نیٚن پٮ۪ٹھ الزام لگا و ن ﴿ یعنی بد کٲری ہُند الزام﴾ تہٕ تِمن نِشہِ آسہِ نہٕ خۅد پننہِ پا نہٕ ورٲے کانٛہہ گواہ، تیٚلہِ چھےٚ تِمو منٛز أکِس شخصہ سٕنز شہا دت ﴿ یہِ زِ سُہ ﴾ دِیِن ژورِ لٹہِ اللہ تعالیٰ  سُند قسم کھیٚتھ گوٲہی، زِ سُہ چُھ ﴿ پننِس الزا مس منٛز ﴾ پٔزِ یو ر ،"
  24,7,"۔تہٕ پوٗنژِ مہِ پھِرِ ؤنِن زِ تس پٮ۪ٹھ ٲسِن اللہ تعالیٰ سٕنز لعنت، اگر سُہ  پننِس اِلزا مس منٛز ﴾ اَپزِ یو ر چُھ۔"
  24,8,"۔تہٕ زنا نہِ نِشہِ ہیٚکہِ یِتھہٕ پٲٹھۍ سزا ٹٔلِتھ، زِ سۅ دِین ژور لٹہِ اللہ تعالیٰ سُند قسم کھیٚتھ شہادت، زِ یہِ شخص چُھ ﴿ پننِس اِلزا مس منٛز ﴾ اُپزِ یو ر،"
  24,9,"۔تہٕ پوٗنژمہِ پھِرِ ؤنِن زِ تس پٮ۪ٹھ ٲسِن اللہ تعالیٰ سُنٛد غضب ،اگر سُہ ﴿پننِس اِلزا مس منٛز ﴾ پٔزِ یو ر آسہِ ۔ ﴿ شر یعت کِس اصطلا حس منٛز چِھ اَتھ لِعا ن ونان ۔ یہِ لعا ن ہیٚکہِ نہٕ گھرِ بِہتھ سپدِ تھ، بلکہ گژِھ عدالتس منٛز سپدُن۔ لِعا نُک مطا لبہٕ ہیٚکہِ مردٕ سٕندِ طر فہٕ تہِ سپدِ تھ تہٕ زنانہِ ہٕندِ طر فہٕ تہِ۔ الزا م لگا و نہٕ پتہٕ اگر مردلِعا ن نِشہِ پان بچا ونٕچ کو شش کرِ یا زنانہٕ کرِ قسم کھیٚنس اجتنا ب۔ تیٚلہِ چُھ حنفیہ ہن نزدیک  اَمیُک سزا قٲد یوٚت تام نہٕ مجر م لِعا ن کرِ ، تہٕ دۅ شوٕ یو طر فو چُھ لِعا ن سپد نہٕ پتہٕ زنانہٕ تہٕ مرداکھ أکِس خٲطرٕ حرام سپدان ۔﴾"
  24,10,"۔تۅہیہِ لُکن پٮ۪ٹھ ﴿ اگر ﴾ اللہ تعالیٰ سُند فضل تہٕ تٔمۍ سُند رحم آسِہے نہٕ، تہٕ ﴿اگر ﴾ یہ، کتھ آسِہے نہٕ زِ اللہ تعالیٰ چُھ سٮ۪ٹھاہ تو بہٕ قبو ل کر ن وول تہٕ حکمت وول تیٚلہِ ﴿ تراوِہیٚو خا ندارنیٚن پٮ۪ٹھ الزا مُک معا ملہٕ تۅہیہِ کُھرِ س منٛز۔ ﴾ع"
  24,11,"۔ یِمو لُکو یہِ بہتا ن چُھ گٔرِ تھ اوٚ نمُت ، سُہ چُھ تۅ ہی منٛزٕ اکھ ٹو لہٕ ۔ ﴿ ییٚتہٕ پٮ۪ٹھہٕ چُھ آیت 26 ہس تام تتھ معا ملس پٮ۪ٹھ کلام فر ماو نہٕ آمُت یُس توا ریخس منٛز وا قعہ اِفک کہ ناوٕ مشہور چُھ، یتھ مُنا فِقو حضر ت عا یشہ رضی اللہ عنہا ہَس پٮ۪ٹھ معا ذ اللہ بدکٲری ہٕنزتہمت ٲس لگٲومٕژ، تہٕ اَتھ اوسُکھ تیوٗتاہ چر چہِ کوٚرمُت زِ کینٛہہ مسلمان تہِ ٲسۍ اَتھ منٛز مبتلا گٔمٕتۍ﴾ یہِ وا قعہ مَہ سمجھِو پننِس معا ملس منٛز شر، بلکہ چُھ یِتہِ تُہندِ خٲطرٕ رٕژرٕ ے۔ ﴿ مطلب چُھ یہِ زِ با منبرِ ومَہ ، مُنا فقو کوٚر پننہِ طر فہٕ تۅہیہِ پٮ۪ٹھ یہِ زور دار وار مگر ان شا  اللہ گژِھہ یِمن پوٚت پھیٖرِ تھ یہِ وا پس ، تہٕ تُہٕندِ خٲطرٕ آسہِ یہِ فٲیدہ مند۔ ﴾ ییٚمۍ یوٗتاہ اتھ منٛز حصّہ نِیوٗتٔمۍ کوٚر تیوٗتاہ گنا ہ جمع تہٕ ییٚمۍ شخصن امہِ چہِ ذمہ دٲر ی ہُند بوٚڈ حصّہ  پننِس کلس کھو ل۔﴿ یعنی عبد اللہ بنِ اُبّی یُس امہِ اِلزا مُک اصلی مُصنف تہٕ فِتنُک اصلی بٲنی اوس﴾ تس خٲطرٕ چُھ بوٚڈ عذا ب۔"
  24,12,"۔ییٚمہِ ساعتہٕ تۅہیہِ لُکو یہِ بوٗز مُت اوسُو تمی ساعتہٕ کیا زِ کوٚر نہٕ مو من مردَو تہٕ مومن مستوٗرتَو پننِس پا نس سٍتۍ نیک گُمان ﴿ دوٚیُم تر جمہٕ ہیٚکہِ یِتہِ ٲسِتھ زِ پننیٚن لُکن یا پننِس مِلّتس تہٕ پننہِ معا شرٕ ہ کیٚن لُکن سٍتۍ کیازِ کوٚرُو نہٕ نیک گُمان ۔ آیتٕکۍ الفا ظ چِھ دۅ شوٕ نۍ مفہو مَن پٮ۪ٹھ حٲوی۔ البتہٕ یُس تر جمہٕ اسہِ چُھ اختیار کوٚر مُت سُہ چُھ زیادہ معنہِ بوٚرُت۔ امِیُک مطلب چُھ یہِ زِ تۅہیہِ منٛزٕ کیا زِ کوٚر نہٕ پرتھ کٲنٛسہِ خیا ل زِ اگر مےٚ تمہِ صوٗرتِ حا لُک مقا بلہٕ پیٚیہِ ہے کرُن یوسہٕ حضر ت عا یشہ رضی اللہ عنہا ہس پیش آمٕژ ٲس ، کیا بہٕ کر ہا بدکٲر ی ہُند اَتُر؟﴾ تہٕ کیازِ ووٚ نُو نہٕ زِ یہِ چُھ ٹا کارٕہ بہتا ن ؟"
  24,13,"تِمو لُکو کیازِ أنۍ نہٕ ﴿ پننِس الزام کِس ثبو تس منٛز ﴾ ژور گواہ؟ وۅ نۍ ییٚلہِ تِمو گواہ چِھنہٕ أنِمٕتۍ، خُدا یس نزدیک چِھ تِمے اَپزِ یٲرۍ۔﴿ یتھ جایہِ گژِھہ نہٕ کٲنٛسہِ شخصس یہِ غلط فہمی گژٕھنۍ زِ یتھ جایہِ چُھ الزا م کہ غلط آسنٕچ دلیل تہٕ بُنیا د محض گوا ہن ہٕنز غیر مو جو دگی ٹھہرا و نہٕ یِوان ، تہٕ مُسلمانن چُھ یِوان وننہٕ زِ توٚہۍ تہِ دِیِو صرف امہِ وجہ کِنۍ یہِ ٹا کارٕہ بہتا ن قرار زِ الزام لگا ون وا لیو چِھنہٕ ژور گواہ أنِمٕتۍ۔ یہِ غلط فہمی چھےٚ تمہِ وا قٕچ صورت در نظر تھا و نہٕ کِنۍ پٲدٕ سپدان یۅسہٕ فی الوا قع تَتہِ پیش ٲس آمٕژ۔ اِلزا م لگا و ن والیو اوسنہٕ امہِ و جہ کِنۍ اِلزا م لگو و مُت زِ تِمو اوس یا تِمو منٛزٕ ٲس کٲنٛسہِ شخصن معا ذ اللہ پننیو أچَھو سۅ کتھ وُچھمٕژ یوسہٕ تِم زیٚوِ ٲسۍ ونان ۔بلکہ اوسُکھ صرف اتھ بُنیا دس پٮ۪ٹھ یوٗتاہ بوٚڈ اِلزا م تصنیف کوٚر مُت زِ اتفا قاً ٲس حضر ت عا یشہ رضی اللہ عنہا قٲفلہٕ نِشہِ پتھ روٗز مٕژ، تہٕ حضر ت صفوا ن رضی اللہ عنہ چِھ پتہٕ تِمن پننِس اوٗنٹس پٮ۪ٹھ سوار  کٔرِ تھ قا فلس منٛز اَنان ۔ کانٛہہ صا حبِ عقل انسان تہِ ہیٚکہِ ہے نہٕ اتھ مو قعس پٮ۪ٹھ یہِ تصّور کٔرِ تھ زِ حضرت عا یشہ رضی اللہ عنہا سُند یِتھہٕ پٲٹھۍ پتھ روزُن اوس معا ذ اللہ کُنہِ ساز با زُک نتیجہ۔ ساز باز کر ن وٲلۍ چِھنہٕ امہِ طر یقہٕ ساز باز کران زِ لشکر کِس سالار سٕنز گھر واجِنۍ روزِ ژوٗرِ پٲٹھۍ قا فلس پتھ کُن أکِس شخصس سٍتۍ تہٕ پتہٕ وا تنا وِ سُے شخص تس پننِس او نٹس پٮ۪ٹھ سوار کٔرِ تھ دۅ ہلی ٹھیک دو پہر وقتہٕ علا نیہ لشکر کِس پڑا وس پٮ۪ٹھ۔ یہِ صورتِ حال ٲس پا نے یِمن دۅ شوٕ نۍ ہٕندِ س بے گنا ہ آسنس پٮ۪ٹھ دلالت کران۔اتھ حالتس منٛز اگر اِلزا م لگا و نہٕ یِیہِ ہے، تیٚلہِ یِیہِ ہے صرف اتھ بُنیا دس پٮ۪ٹھ لگا و نہٕ زِ اگر وَنن والیو پننیو أچھَوآسٕہے کانٛہہ معا ملہ وُچھمُت۔﴾"
  24,14,"اگر تۅہیہِ لُکن پٮ۪ٹھ دُنیا ہس تہٕ ٲخرتس منٛز اللہ تعالیٰ سُند فضل بیٚیہِ رحم و کر م آسِہے نہٕ، تیٚلہِ یِمن کتھن منٛز توٚہۍ ہیٚنہٕ ٲسِو آمٕتۍ،تِہندِ س پاداشس منٛز رٔٹہِ ہیٚو تۅہیہِ بوٚڈ عذا ب۔ ﴿ ہَنا کٔرِ تو غور ، تمہِ ساعتہٕ کِژھ سخت غلطی ٲسِو توٚہۍ کران"
  24,15,"۔ییٚلہِ زَن تُہنزِ اکہِ زیٚو نِشہِ بیاکھ زیٚو یہِ اُپُز ہیٚتھ ٲس پکان،تہٕ توٚہۍ ٲسِو پننہِ ٲسہٕ تِکینژھاہ ونان پکا ن ، یتھ متعلق تۅہیہِ کانٛہہ علم اوسُو نہٕ۔ تۅہیہِ ٲسٕو یہِ کتھ معمو لی باسان، حالانکہ خُدا یس نز دیک ٲس یہِ بٔڑ کتھ۔"
  24,16,"۔یہِ بوزان بوزانٕے کیازِ ووٚ نُو تۅہیہِ زِ ،اسہِ چَھنہٕ یِژھ کتھ شوٗبان زیٚو کڑٕنۍ، سُبحا ن اللہ، یہِ چُھ اکھ عظیم بہتان۔"
  24,17,"۔اللہ تعالیٰ چُھو  تۅہیہِ نصیحت کران، زِ آیند ہ کٔرۍ زیٚو نہٕ یِژھ حر کت، اگر توٚہۍ مو من چِھو۔"
  24,18,"۔اللہ تعالیٰ چُھو تۅہیہِ صا ف صا ف ہدا یت دِوان ، تہٕ سُہ چُھ تھدِ پا یُک زانن وول تہٕ حکمت وول۔"
  24,19,"۔یِم لُکھ یژھان چِھ زِ ایمان انن وا لیٚن منٛز گژِھہ فحش ﴿ بے شر می تہٕ بے حیٲیی﴾ پھٔہلٕنۍ، تِم چِھ دُنیا ہس تہٕ ٲخرتس منٛز دگ تُلوٕ نہِ عذا بٕکۍ حقدار، اللہ تعالیٰ چُھ زانان تہٕ توہۍ چِھو نہٕ زانان۔"
  24,20,"۔ اگر اللہ تعالیٰ سُند فضل تہٕ تٔمۍ سُند رحم و کر م تۅہیہِ پٮ۪ٹھہِ آسِہے نہٕ، تہٕ یہِ کتھ آسِہے نہٕ زِ اللہ تعالیٰ چُھ سٮ۪ٹھاہ شفیق تہٕ رحیم ۔ ع ﴿ تیٚلہِ ہاوِ ہے یہِ چیز بدتر ین نتیجہ یُس تازٕ تاز ے  اوس تۅہیہِ منٛز پھٔہلا و نہٕ آمُت﴾۔"
  24,21,"۔اے لُکو یِمو ایمان چُھو اوٚ نمُت، شیطا ن سٕندِ س نقشِ قد مس پٮ۪ٹھ مَہ پٔکِو، یُس شیطا ن سٕنز پیر وی کرِ، تیٚلہ، دِیہِ سُہ تس فحش تہٕ بد ی ہُندُے حکم ، اگر اللہ تعالیٰ سُند فضل بیٚیہِ رحم و کر م تۅہیہِ پٮ۪ٹھ آسِہے نہٕ، تیٚلہِ ہیٚکہِ ہے نہٕ تۅہیہِ منٛز کانٛہہ شخص پا ک سپدِ تھ، مگر اللہ تعالیٰ ہٕے یس یژھان چُھ، تس چُھ پاک کران، تہٕ اللہ تعالیٰ چُھ بوزن وول تہٕ زانن وول ۔"
  24,22,"۔تۅہیہِ منٛز یِم لُکھ صا حبِ فضل تہٕ صا حبِ وُسعت چِھ ، تِم مَہ کھیٚن امہِ کتھہِ ہُند قسم، زِ پننیٚن رشتہٕ دارن، مسکینن تہٕ یِمو لُکو اللہ تعالیٰ سٕنزِ وتہِ منٛز ہجر ت کٔر، تِمن کر ن نہٕ مدد۔ تِمن پزِ معا ف کرُن بیٚیہِ پز یٚکھ در گُزر کرُن، کیا توہۍ چِھو نا یژھان زِ اللہ تعالیٰ کرِ تۅہیہِ معا ف ؟ تہٕ اللہ تعالیٰ سُند صفت چُھ یہِ زِ سُہ چُھ غفورورحیم۔ ﴿ یہِ آیت چھےٚ اتھ معا ملس منٛز نٲزِل گٔمٕژ زِ الزام لگا و ن والیٚن منٛز یِم کینٛہہ سیوٚد سادٕہ مُسلمان شٲمِل گٔمٕتۍ ٲسۍ، تِمن منٛز اوس اکھ حضر ت ابو بکر رضی اللہ عنہ سُند قر یبی رشتہٕ دار تہِ یِمن پٮ۪ٹھ حضرت ابو بکر رضی اللہ علیہ عنہ ہمیشہ ٲسۍ احسان کران روٗدِمٕتۍ۔ امہِ تکلیف دہ وا قعہ پتہٕ  چِھ ابو بکر رضی اللہ عنہ قسم کھیٚوان زِ وو نۍ کر ن نہٕ تِمن رضی اللہ عنہ سٍتۍ حُسنِ سلو ک۔ خُدا ین کٔر نہٕ یہِ کتھہ پسند زِ صد یق رضی اللہ عنہ ہِیوٗ شخص کیا ہیٚیہِ نہٕ عفو وَس تہٕ در گز رس کٲم ۔ ﴾"
  24,23,"۔یِم لُکھ پاک دا من ، بے خبر ، مو من مستوٗراتن پٮ۪ٹھ تہمتہٕ چِھ لگاوان، تِمن پٮ۪ٹھ آیہِ دُنیا ہس تہٕ ٲخرتس منٛز لعنت کر نہٕ ، تہٕ تِہندِ خٲطرٕ چُھ بوٚڈ عذا ب۔"
  24,24,"۔تِمن مَہ گٔژھن سُہ دۅہ مٔشِتھ، ییٚلہِ تِہنزٕ پننہِ زیٚوٕ تہٕ تِہندۍ پنٕنۍ اتھہٕ کھۅر تِہندٮ۪ن کر توٗتن ہٕنز گوٲہی دِن ۔"
  24,25,"۔تمہِ دۅہ دِیہِ اللہ تعالیٰ تِمن بھر پوٗر سُہ بد لہٕ ییٚمکۍ تِم حقدار چھِ تہٕ تِمن لگہِ پے زِ اللہ تعالیٰ ہٕے چُھ حق ، پٔزِس پٔزرٲوِتھ ہاون وول۔"
  24,26,"۔خبیث زنانہٕ چھےٚ خبیث مردَن خٲطرٕ، تہٕ خبیث مرد چِھ خبیث زنانن خٲطرٕ۔پا ک مستوٗراتہٕ چھےٚ پاک مردن خٲطرٕ، تہٕ پاک مرد چِھ پاک مستوٗراتن خٲطرٕ۔ تِہُند دا من چُھ پاک تِمو کتھو نِشہِ یِمہٕ بناو ن وٲلۍ چِھ بناوان، تِہندِ خٲطرٕ چھےٚ مغفر ت تہٕ عز تُک رزق۔ع"
  24,27,"۔اے لُکو یِمو ایمان چُھو اوٚ نمُت ، ﴿ سوٗرٕہ کِس آغا زس منٛز یِم احکام دِنہٕ آمٕتۍ ٲسۍ،تِم ٲسۍ امہِ موجو ب زِ مُعا شرس منٛز ییٚلہِ بُرٲیی رو نما سپدِ ، تیٚلہِ کِتھہٕ پٲٹھۍ گژِھ تَمیُک تدارُک یُن کر نہٕ ۔ وۅ نۍ چِھ تِم احکام دِنہٕ یِوان ، یُہُند مقصد یہِ چُھ زِ معا شرس منٛز گژِھہ گۅڈے بُرٲ یِن ہٕنزِ پیدٲیشہِ پٮ۪ٹھہٕ رو ک یِنۍ لگا و نہٕ ، تہٕ تمد ن کیٚن طور طر یقن ہُنٛد اصلا ح کٔرِ تھ گژِھ تِمن اسباسن ہُند سدِّ باب یُن کر نہٕ یِمو سٍتۍ امہِ قسمہٕ چہِ خرٲبیہِ چھےٚ پٲدٕ سپدان﴾پننیٚو گھر و ورٲے مَہ ٲسِو دوٚ یِمیٚن ہٕندٮ۪ن گھر ن منٛز اَژان، یوٚت تام نہٕ گھرٕ والیٚن اجا زت ہیٚیِو،تہٕ یوٚت تام نہٕ گھرٕ وا لیٚن سلام کٔرِو، یہِ طر یقہٕ چُھ تُہٕندِ خٲطرٕ بہتر،امید چھےٚ زِ توٚہۍ تھٲوِ و اَمیُک خیال۔"
  24,28,"۔پتہٕ اگر تَتہِ کانٛہہ وُچھوٗن نہٕ، تیٚلہِ مَہ سپدِ و دٲخل یوٚت تام نہٕ تۅہیہِ اجازت یِیہِ دِنہٕ۔﴿ یعنی کٲنٛسہِ ہٕندِس خٲلی گھر س منٛز چُھنہٕ اَژُن جا یز، اِلّایہِ زِ مکان مٲلِکن آسہِ پانہٕ امہِ کتھہِ ہُند اجا زت دِیتمُت۔ مثلاً تٔمۍ آسہِ تۅہیہِ ووٚ نمُت زِ اگر بہٕ تَتہِ آسہِ نہٕ تیٚلہِ بِہزیٚو توٚہۍ میٲنِس کُٹھِس منٛز، یا سُہ آسہِ بیٚیہِ کُنہِ جایہِ تہٕ تۅہیہِ سوزیٚو شیٚچھ زِ توٚہۍ تھٲوِ و تشر یف بہٕ وا تہٕ وُنی﴾ تہٕ اگر تۅہیہِ وَننہٕ یِیہِ زِ واپس گٔژِھو، تیٚلہِ نیرِ و واپس، یہِ چُھ تُہندِ خٲطرٕ زیادہ پاک طر یقہٕ ، ﴿ یعنی یہِ گژِھہ نہٕ تۅہیہِ نا گوار گژُھن۔ أکِس انسانس چُھ حق زِ اگر سُہ کٲنٛسہِ سمکھُن ییٚژِھہ نہٕ سُہ ہیٚکہِ انکار کٔرِ تھ، یا کانٛہہ آورِ یا آسِیٚس، تیٚلہِ ہیٚکہِ معذرت کٔرِ تھ۔﴾ تہٕ یِکینژھاہ توٚہۍ کران چِھو ، اللہ تعالیٰ چُھ تتھ ٹھیک پٲٹھۍ زانان۔"
  24,29,"۔البتہ اتھ منٛز چُھنہٕ  تُہٕندِخٲطرٕ کانٛہہ حر ج،زِ تِتھیٚن گھر ن منٛز أژِو یِمن منٛز نہٕ کانٛہہ روزان آسہِ ، تہٕ یِمن منٛز تُہندِ فٲیدُک ﴿ یا کامہِ﴾ ہُند کانٛہہ چیز آسہِ ﴿ امہِ نِشہِ چِھ مُراد ہو ٹل، سراے، مہمان خا نہٕ ، دُکان، مسا فر خا نہٕ بیترِ ، ییٚتہِ لُکن دٲخل سپد نُک عام اجازت آسہِ﴾ توٚہۍ یِکینژھاہ ظٲہر چِھو کران تہٕ یِکینژھاہ چُھپا وان چِھو، اللہ تعالیٰ چُھ سورُے زانان۔"
  24,30,"۔اے نبی صلی اللہ علیہ وسلم ، مو من مردن ؤنِو زِ پننہِ نظرٕ تھٲوِ ن بچٲوِ تھ ، ﴿ در اصل چُھ غَضِّ بصرُک حکم آمُت دِنہٕ ییٚمیُک تر جمہٕ عام پٲٹھۍ نظر بۅ ن تھا وٕنۍ یا بۅ ن کُن وُچُھن کر نہٕ چُھ یِوان ۔ در اصل چُھنہٕ امہِ حُکمُک مطلب پرٛتھ وقتہٕ بۅ ن کُنُے وُچُھن بلکہ چُھ پوٗرٕ پٲٹھۍ مُدے گٔنڈِ تھ نہ وُچُھن، یا وُچھنہٕ خٲطرٕ پننہِ أچھ با لکل آزا د تراونُک۔ یہِ مفہو م چُھ نظر بچا و نہٕ سٍتۍ ٹھیک پٲٹھۍ ادا سپدان۔ یعنی یُس چیز وُچُھن منٲسب آسہِ نہٕ، تمہِ نِشہِ گژِھہ نظر ڈالٕنۍ ، یہِ نہ کینٛہہ زِ انسان روزِ بۅ ن کُنُے وُچھان یا تھا وِ پنٕنۍ نظر دٔچُھن یا کھۅ وُر کُن۔تہٕ یہِ کتھ چھےٚ سیا ق و سبا ق نِشہِ تہِ پے لگا ن زِ یہِ پا بند ی یتھ چیز س پٮ۪ٹھ عٲید چھےٚ کر نہٕ آمٕژ، سُہ چُھ مردن ہُند مستوٗراتن کُن وُچُھن ، یا دوٚ یمیٚن لُکن ہٕندِس سترس نظر تراوٕنۍ، یا فحش چیز ن پٮ۪ٹھ نظر جما وٕ نۍ﴾ تہٕ پننیٚن شر مگا ہن ہٕنز کٔرِ ن حفا ظت، یہِ چُھ تِہندِ خٲطرٕ زیادہ پٲکیز ہ طر یقہ، یِکینژھاہ تِم کران چِھ ، اللہ تعالیٰ چُھ تمہِ نِشہِ با خبرروزان۔"
  24,31,"۔اے نبی صلی اللہ علیہ وسلم ،مو من مستوٗراتن ؤنِو پننہِ نظرٕ تھٲوِ ن بچٲوِ تھ، تہٕ پننیٚن شر مگا ہن کٔرِن حفا ظت﴿ یہِ کتھ گژِھ در نظر روزٕ نۍ زِ شر یعتِ الہٰی چُھنہٕ مستوٗراتن نِشہِ یُتُے مُطالبہٕ کران یُس تٔمۍ مردن چُھ کوٚر مُت۔یعنی نظر بچاوٕ نۍ تہٕ شر مگا ہن حفا ظت کرٕنۍ، بلکہ چُھ سُہ یِمن بیٚیہِ تہِ کینٛہہ مطا لبہٕ کران یِم تٔمۍ مردن چِھنہٕ کٔرِ مٕتۍ۔ امہِ نِشہِ چُھ صا ف ظٲہر زِ اتھ معا ملس منٛز چَھنہٕ زٔنۍ تہٕ مرد یکسان۔﴾ تہٕ پنُن بنا و سنگھا ر مَہ ہٲوِ ن ، سواے تہِ یہِ پا نے ظٲہر سپدِ،تہٕ پننیٚن سیَنن پٮ۪ٹھ  تھٲوِ ن پننیٚن کلہٕ دَجن ﴿ڈپٹن﴾ ہٕنزٕ لوٗنچہِ ترٲوِتھ۔ تِمہٕ مَہ کٔرِن پنُن بنا و سنگھا ر ظٲہر، مگر یِمن لُکن برونٛہہ کَنہِ: خا ندار ، مو ل، خا ندارن ہٕنٛدۍ مٲلۍ۔﴿مٲلۍ سٕندِس مفہو مس منٛز چُھ بُڈِ بب ، بَڈٕ بُڈِ بب، ماجہِ بُڈِ بب،ماجہِ بُڈٕ بُڈِ بب شٲمل۔ لہٰذا ہیٚکہِ اکھ زٔنۍ پننِس خا ندار سٕندِس مٲلۍ  بُڈِ ببس تہٕ تٔمۍ سٕندِس ماجہِ بُڈِ ببس برونٛہہ کُن تہِ تِتھے پٲٹھۍ یِتھ، یِتھہٕ پٲٹھۍ پننِس مٲلِس  یا ہیرٕ با بس برونٛہہ کُن چھےٚ یِوان۔﴾ پننیٚن نیچو ٮ۪ن، خا ندارن ہٕندٮ۪ن نیچو ٮ۪ن، ﴿ نیچو ٮ۪ن منٛز چِھ زُرۍ، زُر ٮ۪ن ہٕنٛدۍ شُر ۍ سٲر ی شٲمل۔ تہٕ اتھ معا ملس منٛز چَھنہٕ پننِس تہٕ وۅ رس  منٛز کانٛہہ فر ق۔ پننیٚن وۅرٕ شُر ٮ۪ن ہٕندٮ۪ن شُرٮ۪ن برونٛہہ کنہِ تہِ ہیٚکہِ اَکھ زٔنۍ تِتھے پٲٹھۍ آزادی سان زینتُک اظہا ر کٔرِ تھ یِتھہٕ پٲٹھۍ خۅد پننیٚن شُر ٮ۪ن تہٕ زُر ٮ۪ن برونٛہہ کنہِ ہیٚکہِ کٔرِ تھ۔﴾  پننیٚن با ین۔ ﴿  با ین منٛز چِھ پنٕنۍ تہٕ وۅ رٕ سٲر ی شٲمل﴾ با ین ہٕنٛد ٮ۪ن شُر ٮ۪ن ، بینیٚن ہٕندٮ۪ن شُر ٮ۪ن۔﴿بایَو بییٚنو نِشہِ چُھ مُراد تر شوٕ نۍ قسمن ہٕندۍ بٲے بیٚنہِ، تہٕ تِہند ٮ۪ن شُر ین تہٕ زُر ٮ۪ن سارِنٕے پٮ۪ٹھ چُھ یِہند ٮ۪ن اولا د ن ہُند اِطلا ق سپدان﴾  تِمہٕ مستوٗراتہٕ تہِ یِمن سٍتۍ وۅ تھا ن بیٚہوان چھےٚ، ﴿امہِ نِشہِ چُھ پٲنۍ پا نے یہِ ظٲہر سپدان زِ آوا رہ  تہٕ بد اطوا ر زنانن برونٛہہ کنہِ پزِ نہٕ شر یف مسلمان مستوٗراتن پننہِ  زینتُک اظہا ر کرُن﴾ پنٕنۍ لو نڈ ی غلا م، تِم زیرِ دست ﴿ماتحت خد متگار﴾ مرد، یِم نہٕ بیٚیہِ کُنہِ قسمُک غر ض آسن تھا وان ﴿ یعنی زیرِ دست آسنہٕ کِس بُنیا دس پٮ۪ٹھ آسہِ نہٕ تِمن متعلق یہِ شک کر نٕچ گُنجٲیش زِ تِم ہیٚکن امہِ گھر چن مستوٗراتن ہٕندِس معا ملس منٛز کُنہِ نا پا ک خو اہشہِ ہٕنز ہمت کٔرِ تھ۔﴾ تہٕ تِم شُر ۍ یِم نہٕ وُنہِ مستوٗراتن ہٕنٛز و پو شیدٕہ کتھو نِشہِ وٲقف آسن  گٔمٕتۍ۔ تِمہٕ مَہ پکِن زمینس پٮ۪ٹھ پنٕنۍ کھۅر ہٕکہٕ تراوان تراوان زِ یۅسہٕ پنٕنۍ زنیت تِمو چُھپٲوِ تھ آسہِ تھٲومٕژ تمیُک لگہِ لُکن پے۔اے مو منو ، توٚہۍ سٲری کٔرِو رٔلِتھ اللہ تعالیٰ ہس ﴿برونٛہہ کنہِ ﴾تو بہ، اُمید چھےٚ زِ فلا ح لٔبِو۔"
  24,32,"۔تۅہیہِ منٛزٕ یِم لُکھ نیترٕ ورٲے آسن، تہٕ تُہنز ولو نڈیَو تہٕ غلا مَو منٛزٕ یِم صا لح آسن ،تِہِندۍ نکا ح کٔرِ واگر تِم غر یب آسن،اللہ تعالیٰ کرِ تِمن پننہِ فضلہٕ سٍتۍ غنی اللہ تعالیٰ چُھ سٮ۪ٹھاہ وُسعت وول تہٕ علم وول۔"
  24,33,"۔تہٕ یِم نِکا حُک مو قع لبن نہٕ تِمن پزِ زِ عفّت مٲبی ﴿ پا کدا منی﴾ کٔرِن اختیار، یوٚت تام زن اللہ تعالیٰ تِمن پننہِ فضل سٍتۍ غنی کرِ۔تہٕ تُہٕند یٚو مملوٗ کَو ﴿غلا مَو ﴾ منٛزٕ یِم مکا تبتُک در خوا ست کر ن، تِمن سٍتۍ کٔرِ و مکا تبت،﴿ مکا تبتُک مطلب چُھ یہِ زِ کانٛہہ غلام یا لو نڈ ی کرِ پننِس مٲلِکس اکھ مُعا و ضہٕ ادا کر نٕچ پیشکس، تہٕ ییٚلہِ مٲلِک یہِ قبو ل کرِ،تیٚلہِ گژَھن دۅ شوٕنۍ در میان شر ٲیط یِنۍ لیٚکھنہٕ﴾ اگر تۅہیہِ پے آسیٚو زِ یِمن منٛز چُھ  رٕژَر۔﴿رٕژرٕ نِشہِ چُھ مُراد زٕہ چیز: اکھ یہِ زِ غلا مس منٛز آسہِ مالِ کتا بت ادا کر نٕچ صلٲحیت۔ دوٚیُم یہِ زِ أمِس منٛز آسہِ تیٖژھا دیا نت تہٕ راست بٲزی زِ تٔمۍ سٕندِس قَو لس پٮ۪ٹھ یِیہِ اعتماد کٔرِ تھ معا ہدہ کر نہٕ۔﴾ تہٕ  تِمن دِیِو تمہِ مالہٕ منٛز یُس خدا ین تۅہیہِ چُھنو دُیتمُت﴿یہِ چُھ عا م حُکم ، مٲلِک تہِ کٔرِ ن کینٛہہ نَتہٕ کینٛہہ رقم معا ف ، مسلمان تہِ کٔرِن یِمن مدد۔ بیت المال منٛزٕ تہِ گژِھہ یِمن اعا نت کر نہٕ یُن۔﴾تہٕ پننہِ لونڈ یہِ مَہ کٔرِ یوٗکھ بد کٲر ی پٮ۪ٹھ مجبور ﴿جٲہلیّت  کِس زمانس منٛز ٲسۍ اہلِ عر ب پننیو  لو نڈیَو ہٕندِ ذر یعہ بد کٲر ی ہُند پیشہ کرناوان ، تہٕ تِہنز کمٲے ٲسۍ کھیٚوان، اسلامَس منٛز آو یہِ پیشہ ممنو ع قرار دِنہٕ۔﴾ ییٚلہِ زن تِمہٕ پانہٕ آسن پاک دا من یژھان روزُن ﴿مطلب چُھ یہِ زِ اگر لو نڈی خۅد پننہِ مر ضی بد کٲر ی ہٕنز مر تکب سپدِ تیٚلہِ چھےٚ سۅ پننہِ جُر مٕچ پانہٕ ذمہ دار۔ قانو ن رٹہٕ تٔمِسٕے تٔمۍ سٕندِس جُر مس پٮ۪ٹھ ، البتہ اگر أمۍ سُند مٲلک جبر کٔرِ تھ أمِس یہِ پیشہ اختیار کر ناوِ ، تیٚلہِ چھےٚ ذمہ دٲر ی مٲلِک سٕنز تہٕ سُے یِیہِ رٹنہٕ ﴾ تاکہ تۅہیہِ گژھنَو دُنیٲوی فٲیدٕ ہ حٲصل، تہٕ یُس اکھا تِمن مجبو ر کرِ، تیٚلہِ چُھ امہِ جبرٕ پتہٕ اللہ تعالیٰ تِہندِ خٲطرٕ غفورو رحیم۔"
  24,34,"۔اسہِ چِھ صا ف صا ف ہدا یت دِنہٕ وٲلۍ آیات تۅہیہِ نِشہِ سوٗزِ مٕتۍ، تہٕ تِمن قو من ہٕنزٕ عبرت ناک مِثالہٕ تہِ چھےٚ تۅہیہِ برونٛہہ کنہِ پیش کرِ مَژٕ، یِم تۅہیہِ برونٛہہ چِھ گُزر یمٕتۍ، تہٕ تِمہٕ نصیحت چھےٚ اسہِ کرِ مٕژ، یِمہٕ کھۅژن والیٚن ہٕندِ خٲطرٕ چھےٚ آسان۔ ع"
  24,35,"۔ اللہ تعالیٰ چُھ آسما نن ہُنٛد تہٕ زمینُک نُور۔﴿ یعنی کایناتس منٛز یِکینژھاہ تہِ ظٲہر چُھ سُہ چُھ تٔمۍ سٕندۍ نورٕ کہ بدولتہٕ﴾۔ ﴿کا یناتس منٛز﴾ چھےٚ تٔمۍ سٕندِ نوٗرٕچ مِثال تِژھ زنتہٕ أکِس طا قس منٛز آسہِ ژونگ تھٲوِ تھ، ژو نگ آسہِ أکِس قندیلس منٛز،تہٕ قند یلُک حال آسہِ یہِ زنتہٕ مۅ ختٕکۍ پٲٹھۍ اکھ پرٛزلہٕ وُن تارُک، تہٕ سُہ ژو نگ آسہِ زیتو ن کہ اکہِ تِتھہِ مبا رک کُلۍ کہ تیٖلہٕ سٍتۍ روشن یِوان کر نہٕ، یُس نہ شر قی آسہِ نہ غر بی ﴿ یعنی ییٚمیُک بُتھ نَہ آسہِ مشر قس کُن تہٕ نَہ آسہِ مغربس  کُن ﴾، ییٚمہِ کِس تیٖلس پٲنۍ پانے آسہِ ریٚہہ ہیٚوان، چا ہے تتھ متہٕ لٔگۍ تن نار،﴿یِتھہٕ پٲٹھۍ ﴾ آسن گا شس پٮ۪ٹھ گا ش ﴿ ہُر نٕکۍ تمام اسباب جمع گٔمٕتۍ۔﴾ ﴿ییٚمہِ مثا لہِ سٍتۍ چھےٚ ژٲنِگس اللہ تعالیٰ سٕندِ س ذا تس سٍتۍ تہٕ طا قس چھےٚ کا یناتس سٍتۍ تشبیہ دِنہٕ آمٕژ، تہٕ فا نو س نِشہِ چُھ مُراد سُہ پردہ یتھ منٛز حضر تِ حقن پنُن پان چُھ خلقن ہٕنزِ نظرِ نِشہِ ژھا یہِ تھو و مُت۔ گو یا یہِ پردٕہ چُھنہٕ فی الحقیقت نا راضگی ہُند کینٛہہ، یہِ چُھ شدّتِ ظہو رُک پردٕہ، خلقن ہٕنز نظر چھےٚ یہِ وُچھِنس امہِ موجو ب عٲجز زِ نوٗر چُھ تیوٗتاہ شد ید تہٕ وسیع تہٕ محیط ییٚمیُک ادراک محدوٗد أچھ گا ش ہیٚکن نہٕ کٔرِ تھ۔روٗد یہِ مضمو ن زِ  ژو نگ آسہِ تِتھہِ زیتو ن کُلۍ کہ تیٖلہِ سٍتۍ روشن یِوان کر نہٕ یُس نہ شر قی آسہِ نہ غر بی ، یہِ چُھ صرف ژانگہِ چہ روشنی ہٕندِ کما لہٕ تہٕ امہِ کہ شدّتُک تصّور دِنہٕ خٲطرٕ۔ تِکیازِ پرٲنِس زمانس منٛز ٲس زیادہ کھۅتہٕ زیادہ روشنی روغن زیتو ن کیٚو ژانگیو سٍتۍ حا صل یِوان کر نہٕ،تہٕ یِمن منٛز اوس روشن تر ین ژو نگ سُہ آسان یُس بُلند تہٕ کُھلہٕ جایہِ ہٕندِ کُلہِ منٛزٕ کڑنہٕ آمتہِ تیٖلُک آسِہے۔ تہٕ یُس یہِ فر ماو نہٕ آو زِ  ییٚمہِ کِس تیٖلس  پا نۍ پانے آسہِ ریٚہہ ہیٚوان ، چا ہے تتھ متہٕ لٔگۍ تن نار، امہِ نِشہِ تہِ چُھ مقصد ژانگہِ کہ گا شُک زیادہ کھۅتہٕ زیادہ تیز تصّور دِیُن۔﴾ اللہ تعالیٰ یَس پننِس نوٗرس کُن یژھان چُھ رہنمٲیی چُھس فر ماوان، سُہ چُھ لُکن مِثا لو سٍتۍ کتھ سمجھاوان۔تہٕ سُہ چُھ پرٛتھ چیز نِشہِ خو ب وٲقف۔"
  24,36,"۔تٔمۍ سٕندِس نوٗرس کُن ہدا یات لبن وٲلۍ چِھ تِمن گھر ن منٛز لبنہٕ یِوان یِمن بُلند کر نُک ، تہٕ یِمن منٛز پننہِ ناوٕ چ ذِکر کر نُک خُدا ین اِذن چُھ دِیتمُت، تِمن منٛز چِھ صُبحس تہٕ شا مس تٔمۍ سٕنز تسبیح کران،"
  24,37,"۔ تِتھۍ لُکھ یِمن تجا رت تہٕ خر ید و فر وخت اللہ تعالیٰ سٕندِ ذِکر نِشہِ ،بیٚیہِ نما ز قٲیم کر نہٕ نِشہِ تہٕ زکوٰ تہ ادا کر نہٕ نِشہِ غٲفل چُھنہٕ کران۔ تِم چِھ تتھ دۅ ہس کھۅژان روزان، یتھ منٛز دِل دُبہٕ پھیرنٕچ تہٕ أچھ دَرس لگنٕچ نو بت وا تہِ،"
  24,38,"۔﴿تہٕ تِم چِھ یہِ سورُے امہِ موجو ب کران ﴾ تاکہ اللہ تعالیٰ دِیہِ تِمن تِہند ٮ۪ن بہتر ین اعما لن ہُند جزا، تہٕ مز ید نوازیٚکھ پننہِ فضل سٍتۍ، اللہ تعالیٰ یس یژھان چُھ تس چُھ بے حسا ب رزق دِوان۔"
  24,39,"۔﴿اتھ بر عکس ﴾ یِمو کُفر کوٚر، تِہندٮ۪ن اعمالن ہٕنز مِثا ل چھےٚ تِژٕھے زنتہٕ بےٚ آب میدا نس منٛز سرا ب زِ تر یشہ ۂتۍ اوس سُہ آب سمجھمُت، مگر ییٚلہِ سُہ تور ووت، تَتہِ وُچُھن نہٕ کِہِنۍ، بلکہ وُچُھن تَتہِ اللہ تعالیٰ موجود، ییٚمۍ تٔمۍ سُند پوٗرٕ پوٗرٕ حسا ب چُکوو، تہٕ خُدا یس چَھنہٕ حسا ب ہیٚنس تٲر لگا ن۔"
  24,40,"۔یا چھےٚ تٔمۍ سٕنز مِثا ل تِژٕھے زنتہٕ أکِس سٔنِس سمندرس منٛز انہِ گوٚٹ زِ پٮ۪ٹھہٕ چھےٚ اکھ لہر کھٔسِتھ، تتھ پٮ۪ٹھ چھےٚ بیا کھ کھٔسِتھ، تہٕ تتھ پٮ۪ٹھ چُھ اوٚ بر، انہِ گٔٹِس پٮ۪ٹھ چُھ انہِ گوٚٹ مُسلّط، انسان اگر پنُن اتھہٕ کڑِ ، تتھ تہِ ہیٚکہِ نہٕ وُچِھتھ، ییٚمِس اللہ تعالیٰ نوٗر بخشنہٕ نہٕ، تس خٲطرٕ چُھنہٕ پتہٕ کانٛہہ نوٗر۔ع"
  24,41,"۔کیا توٚہۍ چِھو نا وُچھان زِ اللہ تعالیٰ سٕںز تسبیح چِھ کران تِم سٲر ی یِم آسما نن تہٕ زمینس منٛز چِھ ، تہٕ تِم پر ندہ یِم پکھہٕ وہرٲوِ تھ وُڈان چِھ ؟ پرٛتھ اکھ چُھ پننہِ نمازِ تہٕ تسبیح ہُند طر یقہٕ زانان،"
  24,42,"۔تہٕ یِم سٲر ی یِکینژھاہ کران چِھ ،اللہ تعالیٰ چُھ تمہِ نِشہِ با خبر روزان۔آسما نن تہٕ زمینٕچ با دشٲہی چھےٚ اللہ تعالیٰ سٕندی خٲطرٕ ، تہٕ تٔمۍ سٕے کُن چُھ سارِ نٕے پھیرُن۔"
  24,43,"۔کیا توٚہۍ چِھو نا وُچھان زِ اللہ تعالیٰ چُھ اوٚ بر س وارٕ وارٕ پکنا وان،پتہٕ چُھ امہِ کیٚن ٹُکرن پانہٕ وٲنۍ رلا وان،پتہٕ چُھ یہِ سۅ مبرِ تھ اکھ گوٚ ن اوٚ بُر بناوان۔﴿ یعی تہہ بہ تہہ چُھس تھا وان﴾، پتہٕ چِھو توٚہۍ وُچھان زِ امہِ کہ خو لہٕ منٛزٕ چِھ روٗدٕ قطرٕ پیٚوان،تہٕ سُہ چُھ آسمان پٮ۪ٹھہٕ ،تِمن پہا ڑن ہٕندِ بدولتہٕ یِم اتھ منٛز بُلند چِھ ، ڈو ٹھ تراوان﴿ امہِ نِشہِ ہیٚکہِ مُراد ٲسِتھ سردی سٍتۍ لٔگِتھ گوٚ مُت اوٚبُر تہِ یتھ مجا ز اً آسما نٕکۍ پہا ڑ آسہِ وَننہٕ آمُت ، تہٕ زمینٕکۍ پہا ڑ تہِ ہیٚکن ٲسِتھ یِم آسما نس منٛز بُلند چِھ ، یِہند ٮ۪ن تھنگیٚن پٮ۪ٹھ لٔگِتھ گٔمتہِ شیٖن کہ اثرٕ سٍتۍ ہوا چُھ گژھان کُنہِ کُنہِ ساعتہٕ تیوٗتاہ سر د زِ اوٚ برس منٛز چُھ انجماد پٲدٕ ہیٚوان سپدُن ، تہٕ ڈوٹھ چہِ شکلہِ منٛز چُھ روٗد ہیٚوان پیوٚ ن ﴾، پتہٕ یس یژھان چُھ تس چُھ امہِ سٍتۍ نقصا ن واتناوان، تہٕ یس یژھان چُھ تس چُھ اَمہِ نِشہِ بچا وان، تٔمۍ سٕنزِ وُزملہِ ہٕنٛز چمک چھےٚ أچھن اَنہِ گوٚٹ کران۔"
  24,44,"۔ رٲژ ہُند تہٕ دۅ ہُک اُلٹ پھیر چُھ سُے کران۔اتھ منٛز چُھ اکھ سبق أچھ والیٚن ﴿ عقلمند ن﴾خٲطرٕ۔"
  24,45,"۔تہٕ خُدا ین کوٚر پرٛتھ جا نور اکہِ قٔسم کہ آبہٕ  نِشہِ پٲدٕ،کانٛہہ چُھ یِمَو منٛزٕ یٔڈ کھۅ کھشہِ پکان، تہٕ کانٛہہ چُھ دۅ ن زنگن پٮ۪ٹھ، تہٕ کانٛہہ چُھ ژۅن زنگن پٮ۪ٹھ، یِکینژھاہ سُہ یژھان چُھ  تہِ چھُ پٲدٕ کران ،سُہ چھُ پرتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  24,46,"۔اسہِ چِھ صا ف صا ف حقیقت ونَن وٲلۍ آیات نٲزِل کٔرِ مٕتۍ، برونٛہہ کُن چُھ اللہ تعالیٰ ہٕے صرا طِ مُستقیمس کُن ہدا یت دِوان یس یژھان چُھ تس۔"
  24,47,"۔یِم لُکھ چِھ ونان زِ اسہِ اوٚ ن ایمان خُدا یس تہٕ رسولس صلی اللہ علیہ وسلمس پٮ۪ٹھ، تہٕ اسہِ کٔر اطا عت قبو ل، مگر امہِ پتہٕ چُھ یِمو منٛزٕ اکھ دوٚر ﴿ اطا عت نِشہِ ﴾ بُتھ پھِران،یِتھۍ لُکھ چِھنہٕ ہر گز مو من ۔"
  24,48,"۔ییٚلہِ تِمن ناد چُھ یِوان دِنہٕ، خُدا یس تہٕ رسول ﴿صلی اللہ علیہ وسلمس ﴾ کُن، تا کہ رسول صلی اللہ علیہ وسلم کرِ تِہندِ مقدِ مُک فٲصلہٕ، تیٚلہِ چُھ تِمو منٛزٕ اکھ فر یق پوٚت ہیٚوان۔"
  24,49,"۔البتہ اگر حق تِہندِس موا فقتس منٛز آسہِ، تیٚلہِ چِھ رسولس صلی اللہ علیہ وسلمس نِشہِ بٕڈ اطا عت گزا ر بٔنِتھ یِوان۔"
  24,50,"۔کیا یِہِندٮ۪ن دِلن چھا ﴿ مُنا فقتٕچ ﴾ بیمٲرۍ لٔجمٕژ؟ کِنہٕ یِم چِھ شکس منٛز؟ کِنہٕ یِمن چُھ یہِ خو ف زِ اللہ تعالیٰ تہٕ تٔمۍ سُند رسول صلی اللہ علیہ وسلم کرِ یِمن پٮ۪ٹھ ظُلم؟ اصلی کتھ  چھےٚیہِ زِ ظٲلِم چِھ یِم لُکھ پانہٕ ۔ ع"
  24,51,"۔ایمان انن والیٚن ہٕنز کٲم چھےٚ یہِ زِ ییٚلہِ تِم خُدا یس تہٕ رسول صلی اللہ علیہ وسلمس کُن بُلا و نہٕ یِن، تاکہ رسول صلی اللہ علیہ وسلم کرِ تِہندِ مقدِ مُک فٲصلہٕ، تیٚلہِ ؤنِن تِم اسہِ بوٗز تہٕ کٔر اطا عت، یِتھۍ ہوۍ لُکھ چِھ فلا ح لبن وٲلۍ،"
  24,52,"۔تہٕ یِم خُدا یس تہٕ رسول صلی اللہ علیہ وسلم سٕنز فر ما ں بردٲر ی کر ن، تہٕ خُدا یس کھۅژن تہٕ تٔمۍ سٕنزِ نا فر مٲنی نِشہِ بچن ۔ تِمے لُکھ چِھ کامیا ب۔"
  24,53,"۔یِم ﴿ مُنا فق ﴾ چِھ اللہ تعالیٰ سٕندِ ناوٕ کۍ سخت قسم کھیٚتھ ونان ،زِ  توٚہۍ دِیِو حُکم أسۍ نیر و گھر و منٛزٕ  یِمن ؤنِو  قسم مَہ کھیٚیِو، تُہندِ اطا عتُک حال چُھ پے، تُہٕند یو کر توٗتَو نِشہِ چُھنہٕ اللہ تعالیٰ بے خبر۔"
  24,54,"۔ؤنِو ،  اللہ تعالیٰ سٕندۍ اطا عت گزار بٔنِو تہٕ رسول صلی اللہ علیہوسلم سٕندِ فر مانٕکۍ تٲبع روٗزِ و بٔنِتھ۔ البتہ اگر توٚہۍ پوٚت پھیٖرِ و ، تیٚلہِ زٲنِو ٹھیک پٲٹھۍ زِ رسو ل صلی اللہ علیہ وسلمس ییٚمہِ فر ضُک با ر چُھ ترا و نہٕ آمُت، تمِیُک ذمہ دار چھُ سُہ ،تہٕ تۅہیہِ پٮ۪ٹھ ییٚمہِ فرضُک بار چھُ تراونہٕ آمُت تمِکۍ ذمہ دا ر چِھو توٚہۍ، تٔمۍ سٕنز اطا عت اگر کٔرِ و ، تیٚلہِ لٔبِو خۅد پننہِ خٲطرٕ ہدا یت، نَتہٕ چَھنہٕ رسول صلی اللہ علیہ وسلم سٕنز ذمہٕ دٲر ی امہِ کھۅتہٕ زیا دہ کینٛہہ زِ صا ف صا ف وا تنا وِ حُکم ۔"
  24,55,"۔خُدا ین چُھ وعدہ فر مو و مُت تۅہیہِ منٛزٕ تِمن لُکن سٍتۍ یِم ایمان انن تہٕ نیک عمل کر ن، زِ سُہ بنا وِ تِمن تِتھے پٲٹھۍ زمینس منٛز خلیفہٕ،یِتھہٕ پٲٹھۍ تِمن برونٹھِم گُز ر یمٕتۍ لُکھ بنٲوِ مٕتۍ چِھن، تِہندِ خٲطرٕ کرِ تِہُند سُہ دین مضبو ط بُنیا دن پٮ۪ٹھ قٲیِم یُس خُدا ین تِہندِس حقس منٛز پسند چُھ کوٚر مُت،تہٕ تِہٕنز ﴿مو جودٕ ہ ﴾ خو فٕچ حاکت بد لا وِ اَمہٕ سٍتۍ، بس تِم کٔرِ ن میٲنۍ بند گی تہٕ مےٚ سٍتۍ مَہ کٔرِن کٲنٛسہِ شر یک ﴿ کینژھو لُکو چُھ اتھ  یہِ معنی سمجھمُت زِ  یَس کٲنٛسہِ تہِ دُنیا ہس منٛز حکو مت چھےٚ حٲصل تس چھےٚ خلا فت حٲصل۔ حالانکہ آیتس منٛز چُھ ارشاد یہِ سپُد مُت زِ یِم اہلِ ایمان آسن، اللہ تعالیٰ دِیہِ تِمن خلا فت﴾تہٕ یُس امہِ پتہٕ کُفر کرِ ﴿ اتھ ہیٚکہِ یہِ معنی تہِ ٲسِتھ زِ خلا فت حا صل گٔژِھتھ کرِ نا شُکر ی ، تہٕ یِتہِ ہیٚکیٚس ٲسِتھ زِ مُنا فقانہٕ رٔوِش کرِ اختیار زِ بظٲ ہر آسہِ مو من تہٕ در حقیقت آسہِ ایمان نِشہِ خٲلی۔﴾ تیٚلہِ چِھ یِتھی لُکھ فا سق۔"
  24,56,"۔ نماز کٔرِ و قٲیِم ، زکوٰتہ دِیِو، بیٚیہِ کٔرِ و رسول صلی اللہ علیہ وسلم سٕنز اطا عت ،امید چھےٚ زِ تۅہیہِ پٮ۪ٹھ یِیہِ رحم کر نہٕ۔"
  24,57,"۔یِم لُکھ کُفر چِھ کرا ن تِمن متعلق مَہ روٗزِ و اَتھ غلط فہمی منٛز زِ تِم کر ن خُدا یس زمینس منٛز عٲجز، تِہُند ٹھکا نہٕ چُھ دوزخ تہٕ سُہ چُھ سٮ۪ٹھہٕے بُرٕ ٹِھکا نہٕ۔ع"
  24,58,"۔اے لُکو یِمو ایمان چُھو اوٚ نمُت، لٲزِم چُھ زِ تُہنزٕ لو نڈی غلا م تہٕ تُہندۍ تِم شُر ۍ یِم وُنہِ عقلہِ ہٕندِس حد س تام چِھنہٕ وٲتمٕتۍ ، تر ٮ۪ن وقتن یِیِن تۅہیہِ نِشہِ اجا زت ہیٚتھ:، صبح نمازِ برونٛہہ ،تہٕ دُپہر س ییٚلہِ توٚہۍ پلو چِھو کٔڑِ تھ تھاوان، بیٚیہِ عشا نمازِ پتہٕ، یِم تر ےٚ وقت چِھ تُہندِ خٲطرٕ پردٕ کۍ وقت۔ یِمو پتہٕ اگر تِم بِلا اجازت یِن ، تیٚلہِ نہ چُھ تۅہیہِ پٮ۪ٹھ کانٛہہ گنا ہ ، نہ چُھ تِمن پٮ۪ٹھ، تۅہیہِ چُھو اکھ أکِس نِشہِ گرِ گرِ یُنُے آسان، یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ تُہندِ خٲطرٕ پننیٚن احکا من ہٕنز وضا حت کران، تہٕ سُہ چُھ زانن وول تہٕ حکمت وول۔"
  24,59,"۔تہٕ ییٚلہِ تُہٕندۍ شُر ۍ عقلہِ ہٕندِس حد س تام وا تن ، تیٚلہِ پزِ زِ تِتھے پٲٹھۍ ٲسِن اجازت ہیٚتھ یِوان ، یِتھہٕ پٲٹھۍ تِہندۍ بٔڑۍ چِھ اجاز ت ہیٚوا ن روٗدِ مٕتۍ، یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ پنٕنۍ آیا ت تۅہیہِ برونٛہہ کنہِ کھولان، تہٕ سُہ چُھ زانن وول تہٕ حکمت وول۔"
  24,60,"۔ تہٕ یِمہٕ مستوٗراتہٕ جوٲنی نِشہِ گُزر یمژٕ آسن، نکا ح چہِ امید وار آسن نہٕ، تِمہٕ اگر پننہِ ژادرٕ وٲلِتھ تھا ون ، تیٚلہِ چُھنہٕ تِمن پٮ۪ٹھ کانٛہہ گنا ہ ، بشر طیکہ ز ینتٕچ نمٲیش کر ن وا جِنہِ آسن نہٕ، تا ہم ور تٲوِ ن  تِمہٕ تہِ حیا دٲر ی ، تیٚلہِ چُھ تِہندِس حقس منٛز رُت۔ تہٕ اللہ تعالیٰ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  24,61,"۔کانٛہہ حر ج چُھنہٕ اگر کانٛہہ اوٚ ن یا لوٚ نگ، یا مر یض ﴿کٲنٛسہِ ہٕندِ گھرِ کھیٚیہِ ﴾ تہٕ نہٕ چُھ تۅ ہیہِ پٮ۪ٹھ اتھ منٛز کانٛہہ حر ج زِ پننیٚن گھر ن منٛز کھیٚیِو، یا پننِس مٲلِس بُڈِ بب سٕندٮ۪ن گھر ن ،یا پننیٚن ماجن نا نیٚن ہٕندٮ۪ن گھر ن ،یا پننیٚن  بھا ین ہٕندٮ۪ن گھر ن ، یا پننیٚن بیٚنیٚن ہٕندٮ۪ن گھر ن،یا پننیٚن پیٚترن ہٕندٮ۪ن گھر ن ،پننیٚن پۅ پھَن ہٕندٮ۪ن گھر ن، یا پننین مامن ہٕندٮ۪ن گھر ن ، یا پننیٚن ماسن ہٕندٮ۪ن گھر ن،یا تِمن گھر ن یِہٕنزٕ کُنزٕ تُہنزِ سپُردگی منٛز آسن، یا پننیٚن دوستن ہٕندٮ۪ن گھر ن ، اتھ منٛز تہِ چُھنہٕ کانٛہہ حر ج زِ توٚہۍ لُکھ کھیٚیہِ تَو  یِکہٕ وٹہٕ یا الگ الگ، البتہ ییٚلہِ گھر ن منٛز ٲسِو دٲخل سپدان،تیٚلہِ ٲسِو پننیٚن لُکن سلام کران، دعا ے خیر، اللہ تعالیٰ سٕندِ طر فہٕ مقرر فر ما و نہٕ آمُت، سٮ۪ٹھاہ با بر کت تہٕ پٲکیزٕہ۔ یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ تۅہیہ، بروٛنہہ کنہِ آیات بیان کران،تو قع  چُھ زِ توٚہۍ ہیٚیِو گا ٹہٕ جا رس کٲم۔ ع"
  24,62,"۔مو من چِھ دراصل تِمے یِم خُدا یس تہٕ تٔمۍ سٕندِس رسولس صلی اللہ علیہ وسلمس دِلہٕ سٍتۍ مانن، تہٕ ییٚلہِ کُنہِ اجتما عی کامہِ ہٕندِس مو قعس پٮ۪ٹھ رسول صلی اللہ علیہ وسلمس سٍتۍ آسن، تیٚلہِ مَہ نِیرِ ن تِمن صلی اللہ علیہ وسلمن اجازت ہیٚنہٕ ورٲے، ﴿اے نبی صلی اللہ علیہ وسلم ﴾ ، یِم لُکھ تۅہیہِ اجازت چِھ منگا ن ، تِمے چِھ خُدا یس تہٕ رسو ل صلی اللہ علیہ وسلمس مانن وٲلۍ، لہٰذا ییٚلہِ تِم کُنہِ  کامہِ کِنۍ اجازت منگن ، تیٚلہِ یس توٚہۍ ییٚژِھو ، اجازت ٲسِو دِوان، تہٕ یِتھیٚن لُکن ہٕندِس حقس منٛز ٲسِو خُدا یس دعا ے مغفر ت منگا ن، اللہ تعالیٰ چُھ یقیناً مغفر ت کر ن وول تہٕ سٮ۪ٹھاہ مہر بان ۔"
  24,63,"۔ مسلمانو، پا نس در میان مَہ سمجھِو رسول صلی اللہ علیہ وسلم سُند بُلا وُن پانہٕ وٲنۍ  اکھ أکۍ سُند ہیوٗبُلاوُن کینٛہہ، اللہ تعالیٰ چُھ تِمن لُکن ٹھیک پٲٹھۍ زانان یِم  تۅہیہِ منٛزٕ تِتھۍ چِھ زِ اکھ أکِس  ژھا یہِ روٗزِ تھ چِھ ژوٗرِ پٲٹھۍ ژلان۔ رسول صلی اللہ علیہ وسلم سٕندِ حُکمٕچ خلا ف ور زی کر ن والیٚن پزِ کھۅژُن زِ تِم ما گژھن کُنہِ فتنس منٛز گر فتا ر ، یا تِمن پٮ۪ٹھ ما یِیہِ دگ تُلوُن عذا ب۔"
  24,64,"۔ خبردار روٗزِ و، آسمان و زمینس منٛز یِکینژھاہ چُھ، سُہ چُھ اللہ  تعالیٰ سُند۔ توٚہۍ یَتھ  رٔوِ شہِ پٮ۪ٹھ تہِ چِھو، اللہ تعالیٰ چُھ تتھ زانان۔ ییٚمہِ دۅ ہ لُکھ تس کُن وا پس پھر نہٕ یِن، سُہ وَنہٕ تِمن زِ تِم کیا کینژھا چِھ کٔرِ تھ آمٕتۍ، سُہ چُھ پرٛتھ چیزُک علم تھاوان۔ ع"
