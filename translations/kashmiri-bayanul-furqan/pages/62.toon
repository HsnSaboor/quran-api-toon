quran[11]{c,v,t}:
  62,1,"۔اللہ تعالیٰ سٕنز تسبیح چُھ کران پرٛتھ سُہ چیز یُس آسمانن منٛز چُھ تہٕ پرٛتھ سُہ چیز یُس زمینس منٛز چُھ۔بادشاہ چُھ نہا یت مقد س ، زبردست تہٕ حکمت وول۔"
  62,2,"۔سُے چُھ ییٚمۍ اُمّی یَو منٛزٕ اکھ رسول صلی اللہ علیہ وسلم خۅد تِموٕے منٛزٕ تُل۔﴿یتھ جایہِ چُھ اُمّی لفظ یہوٗدۍ اصطلا ح کہ طور آمُت،تہٕ اتھ منٛز چُھ اکھ لطیف طنز پوشیدٕہ۔اَمیُک مطلب چُھ یہِ زِ یِمن عر بن حقارت سان یہوٗدۍ چِھ اُمّی ونان تہٕ پا نس مقا بلہٕ چِھکھ ؤسۍ پایہِ سمجھان،تِموٕے منٛزٕ چُھ غٲلب تہٕ گا ٹٕلۍ خُداین اکھ رسول تُلمُت۔سُہ چُھنہٕ پانہٕ ووٚتھمُت بلکہ چُھ تٔمۍ سُند تُلَن وول سُہ یُس کاینا تُک بادشاہ چُھ، زبردست تہٕ حکمت وول چُھ، ییٚمۍ سٕندِس طا قتس سٍتۍ لٔڑِتھ یِم پا نسٕے کرن نقصان تہٕ تس ہیٚکن نہٕ نقصا ن واتنٲوِتھ﴾۔یُس تِمن تٔمۍ سٕندۍ آیات چُھ بوز ناوان، تِہٕنز زند گی چُھ پٲراوان، بیٚیہِ چُھ تِمن کتا بہِ ہٕنز تہٕ حکمتٕچ تعلیم دِوان، حالانکہ تِم ٲسۍ اَمہِ برونٛہہ ٹا کارٕہ گُمرٲہی منٛز۔"
  62,3,"۔تہٕ ﴿ییٚمِس رسول سٕنز بعث﴾ چھےٚ تِمن با قی لُکن ہٕندِ خٲطرٕ تہِ یِم وُنہِ تِمن چِھنہٕ سمکھیٚامٕتۍ۔﴿یعنی محمد صلی اللہ علیہ وسلمن ہٕنز رسا لت چَھنہٕ صرف عر ب قو مس تا مٕے محدوٗد بلکہِ  چھےٚ پوٗرٕ دُنیا کیٚن تِمن با قی قو من تہٕ نٔسلن خٲطرٕ تہِ یِم وُنہِ اہلِ ایمانن منٛز یِتھ شٲمِل چِھنہٕ گٔمٕتۍ مگر برونٛہہ کُن چِھ قیا متس تام یِنہٕ وٲلۍ۔﴾ اللہ تعالیٰ چُھ زبردست تہٕ حکمت وول۔﴿یعنی یہِ چُھ تٔمۍ سٕندی قدر تُک تہٕ حکمتُک معجزٕ ہ زِ یِتھہِ نا ترا شیدٕہ قوم منٛزٕ کوٚرُن تِیُتھ عظیم نبی پٲدٕ ییٚمۍ سٕنز تعلیم تہٕ ہدایت اَتھ در جس تام انقلا ب انگیز چھےٚ ،تہٕ اَمہِ پتہٕ چھےٚ تِتھیٚن عا لمگیر ابد ی اصو لن ہٕنز حٲمِل یِمن پٮ۪ٹھ سٲرٕے اِنسٲنی زُر یات ہیٚکہِ سٔمِتھ اکھ اُمّت بٔنِتھ ،تہٕ ہمیشہِ ہمیشہِ خٲطرٕ ہیٚکہِ یِمو اصو لَو نِشہِ رہنمٲیی حٲصل کٔرِتھ۔﴾"
  62,4,"۔یہِ چُھ تٔمۍ سُند فضل، یس یژھان چُھ تس چُھ دِوان، تہٕ سُہ چُھ سٮ۪ٹھاہ فضل کر ن وول۔"
  62,5,"۔یِم لُکھ تورا تٕکۍ حٲمِل ٲسۍ بنا و نہٕ آمٕتۍ،مگر تِمو تُل نہٕ تمیُک بار، تِہٕنز مثال چھےٚ تس خرٕ سٕنز ہِش یَس پٮ۪ٹھ کتا بہٕ آسن کھٲلِتھ۔اَمہِ کھۅتہٕ تہِ زیادٕہ بُرٕ مثال چھےٚ تِمن لُکن ہٕنز یِمو اللہ تعالیٰ سٕندٮ۪ن آیا تن بُتھ چُھ پھِیر مُت ۔﴿یعنی تِہُند حال چُھ خرٕ سٕندِ کھۅتہٕ تہِ بدتر،تس چُھنہٕ سو نچ سمجھ اَمہِ مو جو ب چُھ معذور۔مگر یِمن چُھ سو نچ سمجٕھ ، تورات چِھ پران تہٕ پرناوان۔امہِ کِس معنیس چِھنہٕ نا وٲقف،اَمہِ پتہٕ تہِ چِھ یِم اَمہِ کہ ہدا یت نِشہِ زٲنِتھ مٲنِتھ بُتھ پِھران، تہٕ قصداً چِھ ییٚمِس نبیس ماننہٕ نِشہِ انکار کران یُس توراتہ موجوٗب سراسر حقس پٮ۪ٹھ چُھ۔یِم چِھنہٕ نا فہمی ہٕندۍ قصور وار کینٛہہ بلکہ چِھ زٲنِتھ مٲنِتھ اللہ تعالیٰ سٕندٮ۪ن آیاتن انکار کر نٕکۍ مُجر م۔ ﴾ یِتھیٚن ظٲلِمن چُھنہٕ اللہ تعالیٰ ہدا یت دِوان۔"
  62,6,"۔یِمن ؤنِو ، اے لوٗکو یِم یہوٗدۍ چِھو بنیمٕتۍ،﴿ یہِ نکتہ چُھ قٲبِل تو جہ ""اے یہوٗدیو""،چُھنہٕ وَننہٕ آمُت بلکہ چُھ""اے تِمو لُکو یِم یہوٗدۍ چِھ بنیمٕتۍ یا "" یِمو یہوٗدیت چھےٚ اختیار کٔرمٕژ"" وَننہٕ آمُت۔اَمیُک وجہ چُھ یہِ زِ اصلی دین یُس موسیٰ علیہ السّلامَو تہٕ تِمن بروٗنٹھمیو تہٕ پٔتِمیوانبیا علیہم السلامَو اوٚنمُت اوس ،سُہ اوس بس اسلام۔یِمو انبیا علیہم السلامَومنٛزٕ اوس نہٕ کانٛہہ یہوٗدۍ تہٕ نَہ ٲس تِہندِس زمانس منٛز یہوٗدیت پٲدٕ گٔمٕژ۔یہِ مذ ہب چُھ اَمہِ ناوٕ واریاہ پٔتِم پیداوار۔﴾ اگر تۅ ہیہِ یہِ گھمنڈ چُھو زِ با قی سٲری  لُکھ ترٲوِتھ چِھو صرف توٚہۍ اللہ تعالیٰ سٕندۍ ٹٲٹھۍ، تیٚلہِ کٔرِو مو تُک تمنا اگر توٚہۍ پننِس اتھ غرورس منٛز پٔزِ یٲرۍ چِھو۔"" ﴿عر بٕکۍ یہوٗدۍ ٲسۍ نہٕ پننِس تعدا دس تہٕ طا قتس منٛز مُسلمانَو کھۅتہٕ کم کینٛہہ تہٕ وسٲیلن ہٕندِ لحاظہٕ تہِ ٲسۍ واریاہ کھٔسِتھ ۔مگر ییٚمۍ چیز ن اَتھ نا برا بری  ہٕندِس مقا بلس منٛز مُسلمان غٲلِب تہٕ یہوٗدۍ مغلو ب کٔرۍ ،سُہ اوس یہِ زِ مُسلمان ٲسۍ نہٕ اللہ تعالیٰ سٕنزِ وَتہِ منٛز مر نس کھۅژان بلکہ ٲسۍ دِل و جا نہٕ پنُن سر منٛز اَتھس رٔٹِتھ میدا نِ جنگس منٛز وَسان۔اتھ بر عکس اوس یہوٗد ٮ۪ن ہُند حال یہِ زِ تِم ٲسۍ نہٕ کُنہِ تہِ وَتہِ منٛز زُو دِنہٕ خٲطرٕ تیا ر،نَہ اللہ تعالیٰ سٕنزِ وَتہِ منٛز،نہ قو م چہِ وَتہِ منٛز ،نَہ خۅد پننہِ زُو چہِ تہٕ مال و عز ت چہِ وَتہِ منٛز۔ تِمن ٲس صرف زند گی بکا ر، خواہ سۅ کِژھہ تہِ آسہِ ۔أمی چیز ن ٲسۍ تِم بُز دل بنٲوِمٕتۍ۔﴾"
  62,7,"۔مگر یِم کر ن نہٕ ہر گز تمِیُک تمنّا پننیو تِمو کر توٗتو ہٕندِ و جہ کِنۍ یِم تِمو کٔرِ مٕتۍ چِھ ،تہٕ اللہ تعالیٰ  چُھ یِمن ظٲلِمن وارٕ پٲٹھۍ زانان۔"
  62,8,"۔یِمن ؤنِو "" ییٚمہِ مو ت نِشہِ توٚہۍ ژَلا ن چِھو، سُہ یِیَو تۅہیہِ ضرور۔پتہٕ یِیِو توٚہۍ تس برونٛہہ کنہِ پیش کر نہٕ یُس پوشیدٕہ تہٕ نوٚن زانن وول چُھ۔، تہٕ سُہ وَنیو تۅہیہِ زِ توٚہۍ کیا کینٛژھاہ چِھو روٗدِمٕتۍ کران ۔ ""ع"
  62,9,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، ییٚلہِ آلَو یِیہِ کر نہٕ نمازِ خٲطرٕ جمعہ دۅہ، تیٚلہِ دوٗرِ و اللہ تعالیٰ سٕنزِ   ذکرِکُن، بیٚیہِ ترٲوِو خر ید و فر خت،﴿ اَتھ حُکمس منٛز چُھ ذِکر مُراد خطبہ، تِکیازِ با نگہِ پتہٕ یۅسہٕ عمل نبی صلی اللہ علیہ وسلم کران ٲسۍ سُہ اوس خطبہ ، تہٕ نماز ٲسۍ تِم ہمیشہ خطبہ پتہٕ ادا فر ماوان،""اللہ تعالیٰ سٕنزِ ذِکرِ کُن دوٗرِو""۔ اَمِیُک مطلب چُھنہٕ یہِ زِ دَوان دَوان یِیِو بلکہ چُھ امِیُک مطلب یہِ زِ جلد ی جلد ی کٔرِ و تورواتنٕچ کوشش۔"" خرید و فر وخت ترٲوِو ""۔ امِیُک مطلب چُھنہٕ صر ف خرید و فر وخت تراوُنُے یوت،بلکہ چُھ نمازِ گژھنہٕ چہِ فِکرِ تہٕ اہتمام ورٲے پرٛتھ کانٛہہ بیاکھ مصروفیت تراوٕنۍ۔اسلام کیٚن فقہا ہن ہُند چُھ اتھ پٮ۪ٹھ اتفاق زِ جمعہ بانگہِ پتہٕ چُھ بیع تہٕ پرٛتھ قسمُک کاروبار حرام۔البتہ چُھ حدیث مُطٲبق شُرۍ،مستوٗراتہٕ، غلام، بیمار تہٕ مسا فر جمعہ کہ فر ضیت نِشہِ مستثنیٰ تھا و نہٕ آمٕتۍ۔﴾ یہِ چُھ تُہندِ خٲطرٕ زیا دٕ بہتر اگر توٚہۍ زٲنِو۔"
  62,10,"۔پتہٕ ییٚلہِ نماز پوٗرٕ سپدِ، تیٚلہِ پٔھہلِو زمینس منٛز، تہٕ اللہ تعالیٰ سُند فضل کٔرِ و تلا ش۔﴿ اَمِیُک مطلب چُھنہٕ یہِ زِ جمعہ نمازِ پتہٕ زمینس منٛز پٔھلُن ،تہٕ رزِق تلا ش کر نہٕ چہِ دَو دَوِ منٛز لگُن چُھ ضروری بلکہ چُھ یہِ ارشاد اجا زت کِس معنیس منٛز۔چو نکہ جُمعہ ہٕچ بانگ بوٗزِ تھ اوس سورُے کارو بار تراونُک حکم دِنہٕ آمُت، امہِ مو جو ب آو فر ما و نہٕ زِ نماز ختم سپد نہٕ پتہٕ چُھو تۅہیہِ اجا زت زِ منتشر سپدِ و تہٕ پنٕنۍ یِم کاروبار تہِ ییٚژِھو تِم کٔرِ و۔ یہِ چُھ تِتُھے یُتھ حالتِ احرامس منٛز شکارس ممٲنعت کر نہٕ پتہٕ فر ما و نہٕ آو زِ ییٚلہِ توٚہۍ احرام کھوٗلِو تیٚلہِ کٔرِ و شکار۔﴿سورۂ ما یدہ آیت 2﴾ اَمِیُک مطلب چُھنہٕ زِ ضروٗر کٔرِو شکار، بلکہ چُھ یہِ زِ اَمہِ پتہٕ ہیٚکِو توٚہۍ شکا ر کٔرِتھ،لہٰذا یِم لُکھ اَمہِ آیت نِشہِ یہِ  استدلال چِھ کران زِ قرآن مطٲبق چَھنہٕ جُمعہ دۅہ چُھٹی تِم چِھ غلط ونان۔ہفتس منٛز اگر اکہِ دۅہ چُھٹی آسہِ کرٕنۍ تیٚلہِ پزِ مسلمانن جُمعہ دۅہ کرٕنۍ، یِتھہٕ پٲٹھۍ یہوٗدۍ بٹہٕ وارِ تہٕ عیسٲے چِھ آتھوارِ کران۔﴾ تہٕ اللہ تعالیٰ روٗزِ یوٗن کثر ت سان یاد کران، شاید زِ تۅہیہِ گژِھہ فلا ح نصیب۔﴿یِتھیٚن مو قعن پٮ۪ٹھ لفظ ""شاید"" وَرتا ونُک مطلب چُھنہٕ یہِ آسان زِ خُدایس چُھ معا ذاللہ کانٛہہ شک، بلکہ چُھ یہِ در اصل شاہانہٕ اندازِ بیان۔یہِ چُھ تِیٛتُھے زَنتہٕ کانٛہہ مہر بان مٲلِک پننِس ملٲزِ مس وَنہِ زِ ژٕ کر فلٲنۍ کٲم بنان چُھ ژےٚ میٖلی تر قی۔اتھ منٛز چُھ اکھ لطیف وعدہ پوشیدٕ آسان ییٚمِچ اُمید تھٲوِتھ ملٲزِم چُھ سٮ۪ٹھاہ شو قہٕ سان سۅ کٲم انجام دِوان۔﴾"
  62,11,"۔تہٕ ییٚلہِ تِمو تجا رت تہٕ کھیل تما شہِ سپدان وُچھ،تِم دَوِ یِیہِ تٔتھۍ کُن، تہٕ توٚہۍ ترٲوِوہَو وۅ دٔنۍ۔﴿یہِ چُھ مد ینہ کہ ابتدٲیی زمانُک واقعہ ۔ شام پٮ۪ٹھہٕ آو اکھ تجا رتی قٲفلہٕ عینِ نماز جمعہ کہ وقتہٕ تہٕ تٔمۍ لٲگۍ ڈو ل تا شہِ وایِنۍ تا کہ بستی ہٕندٮ۪ن لُکن لگہِ امہِ کہ یِنُک پَے۔رسول اللہ صلی اللہ علیہ وسلم ٲسۍ اَمہِ ساعتہٕ خطبہٕ ارشاد فر ماوان۔یُتھے لُکو ڈو لن تا شن ہٕنز آواز بوٗز تِم گٔے بے قرار تہٕ بَہَو ﴿12﴾ نفر و وَرٲے دورے سٲری قٲفِلس کُن۔﴾ یِمن ؤنِو ، یِکینژھاہ خُدایس نِشہِ چُھ سُہ چھُ کھیل تما شہِ تہٕ تجا رت کھۅتہٕ بہتر۔﴿ یہِ حصّہٕ چُھ  وَنان زِ یۅسہٕ غلطی صحا بن سپٕز تمِچ نو عیت کیا ٲس۔اگر معا ذ اللہ اَمِیُک و جہ ایمانس تہٕ ٲخرتس پٮ۪ٹھ دُنیا ہٕچ دٲنستہٕ تر جیح آسہِ ہے، تیٚلہِ آسہِ ہے اللہ تعالیٰ سٕندِ شرا رتُک تہٕ غضبُک اندازٕ بَد لٕے۔چو نکہ یِژھ کانٛہہ خرٲبی ٲس نہٕ تَتہِ،بلکہ  یِکینژھاہ سپُد مُت اوس سُہ اوس تر بیت چہِ کمی ہٕندِ و جہ کِنۍ سپُد مُت۔امہِ مو جو ب آے گۅڈٕ ہ مُعلّمانہٕ اندازٕہ جمعہ ہٕکۍ آداب وَننہٕ، پتہٕ آو اَتھ غلطی پٮ۪ٹھ گر فت کٔرِتھ مُر بیّا نہٕ اندا زٕ ہ فِکرِ تار نہٕ زِ جمعہ ہُک خطبہٕ بوزنس منٛز تہٕ جمعہ ہٕچ نماز پر نس منٛز یِکینژھاہ تۅہیہِ خُدایس نِشہِ میلہِ ۔سُہ چُھ ییٚمہِ دُنیا کہِ تجا رت تہٕ کھیل تما شہِ کھۅ تہٕ بہتر۔ تہٕ اللہ تعالیٰ چُھ ساروٕے کھۅتہٕ بہتر رزِ ق دِنہٕ دِنہٕ وول۔ع ﴿یعنی یتھ دُنیا ہس منٛز یِم تہِ مجا زاً رزِ ق رسٲنی ہُند ذریعہ چِھ بنان تِمو سارِ وٕے یوکھۅتہٕ بہتر رِزق دِنہٕ وول چُھ اللہ تعالیٰ۔﴾"
