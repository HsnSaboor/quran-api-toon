quran[56]{c,v,t}:
  74,1,"۔اے ،وُرُن ووٚلُتھ کٔرِتھ لَر تراوان والہِ ۔﴿ ییٚمہِ سُورٕ کۍ ابتدٲیی ستھ آیات چِھ تِم یِمن منٛز سارِ وٕے برونٛٹھ رسول اللہ صلی اللہ علیہ وسلمن اسلام کہ تبلیغُک حکم آو دِنہٕ ۔ یہِ چھےٚ ، اِقرا ٔبِسمِ رَبِّکَ الَّذی خَلَقَ ۔۔۔،پتہٕ دوٚ یُم وَحی یۅسہٕ حضور صلی اللہ علیہ وسلمن پٮ۪ٹھ نٲزِل سپٕژ﴾۔"
  74,2,"۔ؤتِھو تہٕ کٔرِ و خبردار،"
  74,3,"۔تہٕ پننِس ربّ سٕنٛدِ بجرُک کٔرِ و اعلا ن۔"
  74,4,"۔تہٕ پنٕنۍ پلو تھٲوِو پاک۔"
  74,5,"۔تہٕ گند گی نِشہِ روٗزِ و دُور ۔"
  74,6,"۔تہٕ احسا ن مَہ کٔرِو زیا دٕہ حٲصل کر نہٕ خٲطرٕ،"
  74,7,"۔تہٕ پننِس ربّس خٲطرٕ کٔرِ و صبر۔"
  74,8,"۔اچھا ،ییٚلہِ صُورس یِیہِ پھۅ کھ دِنہٕ ﴿ یہِ حصّہ سپُد ابتدٲیی آیا تو پتہٕ کینٛہہ ریٚتھ گٔژِھتھ نٲزِل ییٚلہِ رسول اللہ صلی اللہ علیہ وسلمن ہٕنٛدِ طر فہٕ اسلامُک تبلیغ اعلا نیہ شروع سپد نہٕ پتہٕ گۅڈنِچہِ لٹہِ حجُک وقت ووت ،تہٕ قر یش کیو سردارِو کوٚر اکھ کا نفر س کٔرِتھ یہِ طے زِ نیبرٕ پٮ۪ٹھہٕ یِنہٕ والیٚن حا جن گِژھ قرآن تہٕ محمد صلی اللہ علیہ وسلمن نِشہِ بد گُمان کر نہٕ خٲطرٕ پر و پگنڈ چ اکھ زبردست مُہم چلا و نہٕ یِنۍ ۔﴾"
  74,9,"۔سُہ دۅہ آسہِ سٮ۪ٹھاہ سخت دۅہ،"
  74,10,"۔کٲفر ن خٲطرٕ آسہِ نہٕ لوٚت کینٛہہ۔"
  74,11,"۔ترٲوِو مےٚ بیٚیہِ ترٲوِ یوٗن سُہ شخص یُس مےٚ کُنُے زوٚن پٲدٕ کوٚر،﴿ اَمہِ نِشہِ چُھ مُراد ولید بن مغیر ہ یُس أندرۍ أندرۍ قرآن کہ کلام الٰہی آسنُک قٲ یل اوس سپُد مُت مگر مکس منٛز پنٕنۍ سردٲری قٲیِم تھا و نہٕ خٲطرٕ دِیُت أمۍ مذکورٕہ کانفرنسہِ منٛز کٲفر ن یہِ مشورٕہ زِ حضور صلی اللہ علیہ وسلم کٔرِ یوٗن جادو گر سٕندِ حیثیت تہٕ قرآن کٔرِ یوٗن جا دِ کہ حیثیت مشہو ر ﴾"
  74,12,"۔واریاہ مال دِیُت تس،"
  74,13,"۔تہٕ تِم فر زند دِتِس یِم تس برونٛہہ کنہِ حٲضر ٲسۍ روزان،"
  74,14,"۔تہٕ أمۍ سٕندِ خٲطرٕ کٔر ریا ستٕچ ﴿سردٲری ہٕنٛز ﴾ وَتھ تہِ ہموار،"
  74,15,"۔پتہٕ چُھ تس طمع زِ بہٕ گژِھہ تس بیٚیہِ زیادٕ ہ دِیُن۔"
  74,16,"۔ہر گز ، نَہ ،تس چُھ سا نیٚن آیاتن سٍتۍ ضِد۔"
  74,17,"۔بہٕ کھا لنا وَن سُہ عنقر یب أکِس دُشوار چڑھا یہِ ۔"
  74,18,"۔ تٔمۍ سُو نچ تہٕ کینٛہہ کتھ بنا و نٕچ کرٕ ن کوشش۔"
  74,19,"۔ؤسۍ تن اللہ تعالیٰ سُنٛد مارتَس پٮ۪ٹھ،کِژھ کتھ بنا ونٕچ کٔرٕن کوٗشش۔"
  74,20,"۔آ،ؤسۍ تن اللہ تعالیٰ سُند مار تَس پٮ۪ٹھ، کِژھ کتھ بنا ونٕچ کرٕ ن کوٗشش،"
  74,21,"۔پتہٕ وُچُھن ﴿ لُکن کُن ﴾ ۔"
  74,22,"۔پتہٕ ژٕ کر ووُن ڈیٚکہٕ تہٕ کھولُن بُتھ۔"
  74,23,"۔ پتہٕ پھیوٗ ر پوٚت تہٕ پیوٚ و تکبر س منز۔"
  74,24,"۔ٲخر کار ووٚ ن تٔمۍ زِ یہِ چُھنہٕ کِہِنۍ مگر اکھ جو د یُس برونٛہہ پیٚٹھہٕ چُھ چلا ن پکا ن ،"
  74,25,"۔یہِ چُھ اکھ انسٲ نۍ کلا م ۔"
  74,26,"۔عنقر یب چھکن بہٕ سُہ جہنمس منٛز۔"
  74,27,"۔ تہٕ توٚہۍ کیا زٲنِو زِ کیا چُھ سُہ جہنم۔"
  74,28,"۔ نہ تھا وِ باقی نہ تراوِ ﴿ یعنی سُہ تھا وِ نہٕ عذا ب کیو حقدار و منٛزٕ کٲنٛسہِ با قی۔یُس تٔمۍ سٕنٛدِس گر فتس منٛز یِیہِ ، عذاب دِنہٕ ورٲے ترا وِ نہٕ تس ﴾"
  74,29,"۔ اِنسا نس مٕسلہٕ وا لن وول ۔"
  74,30,"۔کُنوُہ کا ر کُن چِھ تتھ پٮ۪ٹھ مُقرر۔"
  74,31,"۔اسہِ چِھدوز خٕکۍ یِم کار کُن فر شتہٕ بنٲوِ مٕتۍ، ﴿ ییٚتہِ پٮ۪ٹھہٕ "" تُہٕندٮ۪ن ربّ سٕندٮ۪ن لشکر ن چُھنہٕ پانہٕ تس ورٲے کٕہٕنۍ زانان "" اوٚ ت تا م چھےٚ یہِ پوٗرٕ عبا رت اکھ جملۂ معتر ضہ یُس دورانِ تقر یر کلا مُک سلسلہٕ پُھٹرٲوِتھ تِمن اعترا ض کر ن والیٚن در جواب چُھ فر ما و نہٕ آمُت یِمو رسول اللہ صلی اللہ علیہ وسلمن ہٕنٛزِ زبٲنۍ یہِ بوٗزِ تھ زِ دوزخ کیٚن کا ر کُن ہُنٛد تعداد آسہِ صرف 19،اَتھ ٹسنہٕ ٲسۍ لٲگِمٕتۍ کرٕنۍ۔تِمن با سے یہِ کتھ عجیب زِ اَکہ پا سہٕ چُھ اَسہِ وَننہٕ یِوان زِ آدم علیہ السلام سٕندِ وقتہٕ پٮ۪ٹھہٕ قیا متس تام یِمو انسا نَو تہِ کُفر تہٕ بٔڑۍ گنا ہ چِھ کٔرِ مٕتۍ، تِم یِن دوزخس منٛز ترا و نہٕ ، تہٕ دوٚ یِمہِ پا سہٕ چھےٚ اَسہِ یہِ خبر دِنہٕ یِوان زِ یِیتِس بٔڑِس دوزخس منٛز یٖتِہین بے شما ر انسانن عذا ب دِنہٕ خٲطرٕ آسن صرف 19 ، کار کُن مقرر﴾ تہٕ یُہُند تعداد چُھ کٲفر ن خٲطرٕ فتنہٕ بنو ومُت، تاکہ اہلِ کتا بن یِیہِ یقین، تہٕ ایمان وا لیٚن ہُنٛد ایمان ہُرِ،تہٕ اہلِ کتا ب تہٕ مُو من روزن نہٕ کُنہِ شکمس منٛز ، ﴿ چو نکہ اہلِ کتا ب تہٕ اہلِ ایمان چِھ فر شتن ہٕند یو غیر معمو لی طا قتو نِشہِ وٲقف ، اَمہِ مو جو ب آسہِ نہٕ تِمن اَتھ منٛز کُنہِ قسمُک شک زِ 19، فرشتہٕ چِھ دوزخُک انتظام کر نہٕ خٲطرٕ سٮ۪ٹھاہ ۔﴾ تہٕ دِلٕکۍ بیمار تہٕ کُفّار وَنن یہِ زِ ،خُدایس کیا ہیٚکہِ امہِ کتھہِ نِشہِ مطلب ٲسِتھ۔یِتھہٕ پٲٹھۍ یَس اللہ تعالیٰ یژھان چُھ تس چُھ گُمراہ کران تہٕ یس یژھان چُھ تس ہدایت بخشان،تہٕ تُہندِ س ربّ سٕندٮ۪ن لشکر ن چُھنہٕ پانہٕ تس ورٲے کانٛہہ زانان۔ تہٕ ییٚمہِ دوزخٕچ ذکر چَھنہٕ امہِ ورٲے بیٚیہِ کُنہِ غر ضہٕ کر نہٕ آمٕژ زِ لُکن سپدِ امہِ سٍتۍ نصیحت۔ع"
  74,32,"۔ہر گز نہٕ،﴿یعنی یہِ چَھنہٕ کانٛہہ ہوٲیی کتھ یتھ اَمہِ طر یقہٕ چِھ ہزٕ ل یِوان کر نہٕ﴾ قسم چُھ زوٗنہٕ ہُند،"
  74,33,"۔تہٕ رٲژ ہُند ییٚلہِ سۅ پوٚت پھیران چھےٚ،"
  74,34,"۔تہٕ صُبحُک ییٚلہ، سُہ روشن چُھ سپدان،"
  74,35,"۔یہِ دوزخ تہِ چُھ بڑ یو چیز و منٛز اکھ۔﴿یعنی یِتھہٕ پٲٹھۍ زوٗن تہٕ رات تہٕ دۅہ اللہ تعالیٰ سٕندِ قدرتٕکۍ عظیم نشا نات چِھ تِتھے پٲٹھۍ چُھ دوزخ تہِ قدر ت کیو عظیم چیز و منٛز اکھ چیز۔﴾"
  74,36,"۔انسانن خٲطرٕ کھۅژناون وول،"
  74,37,"۔تۅہیہِ منزٕ پرٛتھ تس شخصس خٲطرٕ کھۅژناون وول یُس برونٛہہ چُھ یژھان پکُن یا چُھ پتھ یژھان روزُن۔"
  74,38,"۔پرٛتھ کانٛہہ شخص چُھ پننہِ کسبہٕ بدلہٕ گِرو،"
  74,39,"۔دٔچِھنہِ اَندٕ والیو ورٲے،"
  74,40,"یِم جنتن منٛز آسن ،تِم پٕرٛژھن"
  74,41,"مجر من۔﴿یعنی جنتس منٛز روٗزِ تھ کر ن تِم جہنمِیَن سٍتۍ کتھ تہٕ کر نکھ یہِ سوال ﴾"
  74,42,"۔"" توٚہۍ کٔمۍ چیز ن نِینو دوزخس ؟"""
  74,43,"تِم ونن ""أسۍ ٲسۍ نہٕ نماز پر ن والیو منٛزٕ،"
  74,44,"تہٕ مسکین ٲسِن نہٕ کھیٚن کھیا وان ،"
  74,45,"تہٕ حقس خلا ف کتھہٕ بناون والیٚن سٍتۍ رٔلِتھ ٲسۍ أسۍ تہِ کتھہٕ بنا و نہِ لگان،"
  74,46,"تہٕ روزِ جزا ٲسۍ اَپُز دِوان قرار،"
  74,47,"یوٚت تام زن اَسہِ تتھ یقینی چیز س سٍتۍ سا بقہٕ آو پیش۔"""
  74,48,"تمہِ وقتہٕ یِیہِ نہٕ سفا رش کر ن والیٚن ہٕنز کانٛہہ سفا رش تِمن کُنہِ بکار۔"
  74,49,"ٲخر کیا چُھ یِمن لُکن گوٚ مُت زِ یِم چِھ ییٚمہِ نصیحت نِشہِ بُتھ پھِران،"
  74,50,"زنتہٕ یِم جنگلی خَر چِھ"
  74,51,"یِم سٕہَس کھوٚژِھ ژٔلِمٕتۍ چِھ ﴿ یہِ چُھ اکھ عر بی محا ورٕہ ۔ جنگلی خر ن چُھ یہِ عادت آسان زِ ییٚلہِ تِمن خطرُک مُشکُے یوت چُھ یِوان ، تِم چِھ تِتھہٕ پٲٹھۍ بد حوا س سپدِ تھ ژلا ن زِ بیاکھ کانٛہہ جا نو ر چُھنہٕ یِتھہٕ پٲٹھۍ ژلا ن ﴾."
  74,52,"بلکہ چُھ یِمو منٛزٕ پرٛتھ کانٛہہ یہِ یژھان، زِ تٔمۍ سٕندِ ناوٕ گژھن کھلہٕ خط یِنۍ سوز نہٕ۔﴿یعنی تِم چِھ یژھان زِ اگر خُدا ین پٔز پٲٹھۍ محمد صلی اللہ علیہ وسلم نبی چِھ مُقرر کٔرِ مٕتۍ ، تیٚلہِ سوٗزِ ن سُہ مکہٕ کِس أکِس أکِس سردارس تہٕ أکِس أکِس شیخ سٕندِ ناوٕ خط لیٚکھِتھ زِ محمد صلی اللہ علیہ وسلم چِھ سٲنۍ نبی، توٚہۍ کٔرِو یِہٕنز پیروی قبول﴾۔"
  74,53,"ہر گز نہٕ ، اصلی کتھ چھےٚ یہِ زِ یِمن چُھنہٕ ٲخرتُک خو ف"
  74,54,"ہر گز نہٕ ﴿ یعنی یُہُند کانٛہہ یُتھ مطا لبہٕ یِیہِ نہٕ ہر گز پوٗرٕ کر نہٕ ﴾ یہِ چھےٚ اکھ نصیحت،"
  74,55,"وۅ نۍ ییٚمۍ سُند دِل ییٚژِھہ سُہ کٔرِ تن امہِ نِشہِ سبق حٲصل"
  74,56,"تہٕ یِم کر ن نہٕ کانٛہہ سبق حٲصل ، اِلّا یہِ زِ اللہ تعالیٰ ہٕے اگر ییژِھہ۔ سُہ چُھ امِیُک حقدار زِ تس نِشہِ گژِھہ یُن تقویٰ کر نہٕ ،تہٕ سُہ چُھ امِیُک اہل زِ ﴿ تقویٰ کرن والیٚن ﴾ کرِ مغفر ت ۔ع"
