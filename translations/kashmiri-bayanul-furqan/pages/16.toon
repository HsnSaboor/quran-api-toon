quran[128]{c,v,t}:
  16,1,"۔ووت اللہ تعالیٰ سُند فٲصلہٕ ،﴿یعنی امہِ کہ ظہورُک تہٕ نِفا ذُک وقت چُھ نکھہٕ ووتمُت۔غا لباً چُھ اَمہِ فٲصلہ نِشہِ مُراد نبی صلی اللہ علیہ وسلمن ہٕنز مکہٕ پیٚٹھہٕ ہجرت ییٚمِیُک حکم کینٛہہ کال پتے آو دِنہٕ ۔قرآن کہ مطالعہ نِشہِ چھُ پے لگان زِ یِمن لُکن در میان نبی مبعو ث چُھ سپدان، تِم ییٚلہِ اِنکار کِس ٲخر ی حدس پٮ۪ٹھ واتان چِھ ، تیٚلہِ چُھ پتہٕ نبیس ہجر تُک حُکم دِنہٕ یِوان، تہٕ یۅ ہے حکم چُھ تِہندِ قسمتُک  فٲصلہٕ کران۔ اَمہِ پتہٕ یا چُھ تِمن پٮ۪ٹھ تبا کُن عذا ب یِوان،یا چُھ پتہٕ نبی تہٕ تٔمۍ سٕندٮ۪ن اِتبا ع کر ن والیٚن ہٕندِ دَستہٕ تِہُند موٗل یِوان ژَٹنہٕ۔﴾ وۅ نۍ مَہ کٔرِو اَمہِ خٲطرٕ با نبٕر،پاک چُھ سُہ، بیٚیہِ چُھ بالا تہٕ بر تر تمہِ شر کہٕ نِشہِ یُس یِم لُکھ کران چِھ۔"
  16,2,"۔اَتھ رُو حس یس بند س پٮ۪ٹھ سُہ یژھان چُھ پننہِ حُکمہٕ سٍتۍ چُھ  فر شتن ہٕندِ ذریعہ نٲزِل فر ماوان۔﴿رُو ح چُھ مُراد رُو حِ نبوّت تہٕ وَحی ییٚمہِ سٍتۍ نبی کٲم تہٕ کلام چُھ کران﴾ ﴿اَمہِ ہدا یت سان زِ لُکھ﴾ کٔرِیوٗکھ خبردار، میانہِ ورٲے چُھنہٕ تُہُند کانٛہہ معبود ، لہٰذا کھوٚژِو توٚہۍ صرف میے یوت۔"
  16,3,"۔تٔمۍ چِھ آسمان تہٕ زمین بر حق پٲدٕ کوٚر مُت، سُہ چُھ سٮ۪ٹھاہ بالا تہٕ بر تر تمہِ شر کہٕ نِشہِ یُس یِم لُکھ کران چِھ۔"
  16,4,"۔تٔمۍ کوٚر انسان أکِس معمو لی قطر س پٲدٕ، تہٕ وُچھان وُچھان بنیا و سُہ ٹاکارٕ لڑا یہِ گوٚر۔﴿اتھ ہیٚکن زٕ ہ معنے ٲسِتھ تہٕ غٲلباً چِھ دۅ شو ے مُراد۔اکھ یہِ زِ خُدا ین کوٚر نطفہٕ کِس حقیر قطرس سُہ انسان پٲدٕ یُس بحثچ تہٕ استد لالٕچ قٲبلیت چُھ تھاوان تہٕ پننہِ مُد عا خٲطرٕ ہیکہِ حُجتہٕ پیش کٔرِ تھ ۔ دوٚ یُم یہِ زِ یُس انسان خُدا ین نطفہ کِس حقیر چیز س پٲدٕ چُھ کوٚر مُت ،تٔمۍ سٕنزِ خودی  ہُند ظلم وُچِھتو زِ سُہ ووٚ تھ خۅد خُدا ے سٕندِ سٕے مقا بلس منٛز لڑٲے کر نہِ۔﴾"
  16,5,"۔تٔمۍ کٔرۍ جانو ر پٲدٕ، یِمن منٛز تُہندِ خٲطرٕ پو شاک تہِ چُھ تہٕ خۅراک تہِ ، تہٕ رنگہٕ رنگٕکۍ با قی فٲیدہ تہِ۔"
  16,6,"۔تِمن منٛز چُھ تُہندِ خٲطرٕ جمال ﴿خو بصورتی تہٕ شان ﴾ ییٚلہِ توٚہۍ تِم صبحٲے گا سہٕ کھیٚنہِ چھوٗکھ سوزان تہٕ ییٚلہِ تِم شامن چھوٗکھ واپس اَنان۔"
  16,7,"۔تِم چِھ تُہندِ خٲطرٕ تِژھن تِژھن جا ین بو ر نِوان یو ر توٚہۍ سخت جا نفشٲنی ورٲے وٲتِتھ ہیٚکہِ ہِو نہٕ۔ حقیقت چھےٚ یہِ زِ تُہُند ربّ چُھ بے حد شفیق تہٕ مہر بان۔"
  16,8,"۔تٔمۍ کٔرۍ گُرۍ تہٕ خچر پٲدٕ، تاکہ توٚہۍ سپدِ و تِمن پٮ۪ٹھ سوار تہٕ تِم بنن تُہٕنزِ زند گی ہٕنز رونق،سُہ چُھ بیٚیہِ واریاہ چیز ﴿تُہٕندِ فٲیدٕہ خٲطرٕ﴾ پٲدٕ کران، یُہُند نہٕ تۅہیہِ علمٕے چُھ۔﴿ یعنی واریاہ چیز چِھ تِم یِم انسان سٕندِ رژرٕ خٲطرٕ چِھ کٲم کران تہٕ انسانس چَھنہٕ خبرٕ ے زِ کتہِ کتہِ کٲتیا ہ خد مت گار چِھ تٔمۍ سٕندِس خد متس لٔگِتھ، تہٕ کۅسہٕ کۅسہٕ خد مت چِھ انجام دِوان ۔﴾"
  16,9,"۔تہٕ اللہ تعالیٰ سٕے چھےٚ ذِ مّہ سیٚزِ وتھ  ہا وٕ نۍ ییٚلہِ زن ہجہِ وَتہٕ تہِ مو جو د چھےٚ۔ اگر سُہ ییٚژِہے تۅہیہِ سارِنٕے دِیہِ ہیٚو تیٚلہِ ہدایت ۔ع"
  16,10,"۔سُے چُھ ییٚمۍ آسمانہٕ تُہندِ خٲطرٕ آب وول، ییٚمہِ سٍتۍ توٚہۍ پانہٕ تہِ چِھو سیراب سپدان تہٕ تُہند ٮ۪ن جانو رن خٲطرٕ تہِ چُھ چارٕہ﴿کُلۍ کٔٹۍ تہٕ گاسہٕ ﴾ پٲدٕ سپدان۔"
  16,11,"۔سُہ چُھ اَمہِ آبہٕ سٍتۍ زراعت وۅ پداوان، تہٕ زیتو ن ، تہٕ کھٔزر تہٕ دَچھ تہٕ رنگہٕ رنگٕکۍ با قی میوہ چُھ پٲدٕ کران، اتھ منٛز چھےٚ اکھ بٔڈ نِشٲنی تِمن لُکن خٲطرٕ یِم غورو فکر چِھ کران۔"
  16,12,"۔تٔمۍ چِھ تُہُندِ رٕژرٕ خٲطرٕ رات تہٕ دۅہ بیٚیہِ آفتا ب تہٕ زوٗن مُسّخر کٔرِ تھ تھٲوِ مٕتۍ،تہٕ سٲر ی تارک تہِ چِھ تٔمۍ سٕندی حُکمہٕ مُسّخر ﴿کامہِ لٔگِتھ﴾ اَتھ منٛز چھےٚ واریاہ نشٲنیہِ تِمن لُکن خٲطرٕ یِم عقلہِ چِھ کٲم ہیوان۔"
  16,13,"۔تہٕ بیٚیہِ تِم ، واریاہ رنگ بر نگ چیز یِم تٔمۍ تُہٕندِ ٰخٲطرٕ زمینس منٛز پٲدٕ چِھ کٔرِمٕتۍ، یِمن منٛز تہِ چھےٚ ضرور نشٲنیہِ تِمن لُکن خٲطرٕ یِم سبق رَٹن وٲلۍ چِھ۔"
  16,14,"۔سُے چُھ ییٚمۍ تُہندِ خٲطرٕ سمندر چُھ مُسّخر کٔرِ تھ تھو و مُت، تا کہ توٚہۍ أنِو اَمہِ منٛز ترو تازٕہ ماز تہٕ کھیٚیِو، تہٕ امہِ منٛز کٔڑِ و زمینٕکۍ تِم چیز یِم توٚہۍ لاگان چھوٗکھ ،توٚہۍ چِھو وُچھا ن زِناو چھےٚ سمندرُک سینہٕ چیران چیران پکان، یہِ سورُے چُھ امہِ خٲطرٕ زِ توٚہۍ کٔرِوپننِس ربّ سُند فضل تلا ش، ﴿ یعنی حلال طر یقو سان کٔرِو پنُن رزق حٲصل  کر نٕچ کوٗشش﴾ بیٚیہِ بٔنِو تٔمۍ سٕندۍ شکر گزار۔"
  16,15,"۔ تٔمۍ ٹھا چہِ زمینس منٛز پہا ڑن ہٕنزٕ میخہٕ، تاکہ زمین گٔژھ نہٕ توٚہۍ ہیٚتھ ڈۅ لہٕ گژٕھنۍ۔تٔمۍ کٔرۍ دٔرِیا و جٲر ی ، تہٕ قدرتی وَتہٕ بناو ٮ۪ن، تاکہ توٚہۍ لٔبِو ہدا یت ﴿وَتھ﴾ ۔"
  16,16,"۔تٔمۍ تھا وِ زمینس منٛز وَتھ ہاو نہٕ چہِ علا متہٕ تہٕ تارو کو سٍتۍ تہِ چِھ لُکھ  ہدا یت ﴿وَتھ ﴾ لبان۔"
  16,17,"۔پتہٕ کیا سُہ یُس پٲدٕ چُھ کران، تہٕ تِم یِم نہٕ کِہِنۍ چِھ پٲدٕ کران، چھا دۅ شو ے ہِوِ ی ؟ کیا توٚہۍ چِھو نا ہو شس منٛز یِوان؟"
  16,18,"۔اگر توٚہۍ اللہ تعالیٰ سٕنزٕ نعمتہٕ گٕنزراونہِ ییژِھو، کہِنۍ ہیٚکِو نہٕ گٕنز رٲوِتھ، حقیقت چھےٚ یہِ زِ سُہ چُھ سٮ۪ٹھہٕے در گزر کر ن وول تہٕ سٮ۪ٹھاہ مہر بان۔"
  16,19,"۔حالانکہ سُہ چُھ تُہُندِ س ظٲہر س  تہِ وٲقف تہٕ بٲطنس تہِ۔"
  16,20,"۔تہٕ تِمہٕ باقی ۂسِتیہِ یِمن اللہ تعالیٰ ترٲوِتھ چِھ لوٗکھ ناد لایان، تِم چِھنہٕ کُنہِ چیزٕ کۍ تہِ خٲلق ،بلکہ چِھ خۅد پانہٕ مخلو ق۔"
  16,21,"۔ مۅر دٕ ہ چِھ ، زندٕہ چِھنہٕ کینٛہہ۔تہٕ تِمن چَھنہٕ کِہِنۍ خبر زِ تِم کر یِن﴿دُوبارٕہ زندٕہ کٔرِ تھ﴾ تُلنہٕ۔ ع ﴿یِم الفاظ چِھ صا ف ونان زِ یتھ جایہِ یِمن بنا وٹی معبوٗدن ہُند خا ص طور تردید چُھ یِوان کر نہٕ تِم چِھ وفات یا فتہٕ اِنسان ، تِکیازِ فر شتہٕ چِھ زندٕہ مُردٕہ چِھنہٕ کینٛہہ، تہٕ لٔکر تہٕ کنیٚن ہٕندین پۅتلیٚن ہٕندِس معا ملس منٛز چُھنہٕ دُوبارٕ زندہ کٔرِ تھ تُلنُک سوالٕے پٲدٕ سپدان۔﴾"
  16,22,"۔تُہُند خُدا چُھ بس اَکو ے خُدا ے،مگر یِم لُکھ ٲخرت چِھنہٕ مانان،تِہند ٮ۪ن دِلن منٛز چُھ انکار بٔسِتھ روٗدمُت،تہٕ تِم چِھ تکبر س منٛز ہیٚنہٕ آمٕتۍ۔"
  16,23,"۔اللہ تعالیٰ چُھ پٔزِ پٲٹھۍ تِہِند ۍ سار ی کر توٗت زانان ،ظٲہر پٲٹھۍ تہِ تہٕ بٲطن پٲٹھۍ تہِ ،سُہ چُھنہٕ تِمن لُکن ہر گز پسند کران یِم نفس کِس تکبرس منٛز مبتلا آسن۔"
  16,24,"۔تہٕ ییٚلہِ کانٛہہ یِمن پرٛژھان چُھ زِ تُہندۍ ربّن کیا چیز چُھ یہِ نٲزِل کوٚر مُت،﴿عربس اندر ییٚلہِ نبی صلی اللہ علیہ وسلمن ہُند چر چہِ سپدِ نہِ لوٚگ تہٕ نیٚبرِ م لُکھ ٲسۍ مکّہ کیٚن روزن والیٚن نبی صلی اللہ علیہ وسلمس تہٕ قرآنس متعلق سوال کران۔﴾تیٚلہِ چِھ ونان  ہے تِمہٕ چھےٚ برونٹھمیٚن وقتن ہٕنزٕ فر سوٗدٕہ دٔلیلہٕ۔"
  16,25,"۔یِمہٕ کتھہٕ چِھ تِم امہِ موجوٗب کران زِ قیا مت کہ دۅ ہ تُلن پنٕنۍ بو ر تہِ پوٗرٕ،تہٕ سٍتۍ سٍتۍ وَٹن تِمن لُکن ہٕندۍ کینٛہہ بور تہِ یِمن یِم جہا لت کِس بُنیا دس پٮ۪ٹھ گُمرا ہ چِھ کران۔وُچِھو ! کِژھ سخت ذمہ دٲر ی چھےٚ یۅسہٕ یِم پننِس کلس پٮ۪ٹھ چِھ کماوان ۔ ع۔"
  16,26,"۔یِمو برونٛہہ تہِ چھےٚ واریاہَو لُکو ﴿حقس ؤسۍ پایہِ ہاو نہٕ مۅ کھہٕ ﴾ یِژھے مکٲرِلہٕ کرِ مژٕ، وُچِھو  زِ خُدا ین پرٛٲٹ ژَکہِ تَلے تِہنزِ مکٲرِلہِ ہٕنز عما رت، تہٕ تمیُک پش پیٚو و تِہندِ س کلس پٮ۪ٹھ،تہٕ تمہِ طر فہٕ آو تِمن پٮ۪ٹھ عذا ب ،یپٲرۍ تَمہِ کہِ یِنُک تِمن گُما نے اوسنہٕ۔"
  16,27,"۔پتہٕ کرِ اللہ تعالیٰ قیا مت کہ دۅ ہ تِمن ذلیل و خوار، تہٕ تِمن وَنہِ  ؤنِو کتہِ چِھ میٲنۍ تِم شر یک یِہندِ خٲطرٕ توٚہۍ ﴿ اہلِ حقن سٍتۍ ﴾ لڑٲیہِ ٲسِو کران؟یِمن لُکن دُنیا ہس منٛز علم اوس حا صل تِم وَنن، اَز چھےٚ رُسوٲیی تہٕ بد بختی کٲفر ن خٲطرٕ۔"
  16,28,"۔آ، تِمنٕے کٲفر ن خٲطرٕ یِم پننِس نفسس پٮ۪ٹھ ظُلم کر نہٕ وِزِ ملٲیکن ہٕند یٚو اَتھو گرفتار چِھ سپدان، پتہٕ چِھ ﴿سر کشی ترٲوِتھ﴾ فوراً اَمنس منٛز یِتھ ونان أسۍ ٲسۍ نہٕ کانٛہہ غلطی کران۔فر شتہٕ چِھ جواب دِوان کران کتھہٕ پٲٹھۍ ٲسِو نہٕ ! اللہ تعالیٰ چُھ تُہند یٚو کر توٗتو نِشہِ ٹھیک پٲٹھۍ وٲقف۔"
  16,29,"۔گٔژِھو وۅ نۍ ،أژِو جہنم کیو دروازَو مٔنٛزۍ ۔ تٔتی چُھو تۅہیہِ ہمیشہ روزُن۔پس چھےٚ حقیقت یہِ زِ سٮ۪ٹھہٕے بُرٕ ٹھکانہٕ چُھ تکبر کر ن والیٚن خٲطرٕ۔"
  16,30,"۔دوٚیِمہِ طر فہٕ ییٚلہِ پرہیزگارن چھُ پٕرژھنہٕ یِوان زِ یہِ کیا چیز چھُ یُس تُہٕندِس ربّ سٕندِ طرفہٕ نٲزِل چُھ سپُد مُت، تِم چِھ جواب دِوان زِ  بہتر ین چیز چُھ نٲزِل سپُدمُت۔امہِ قٔسمہٕ کیٚن نیکو کار لُکن خٲطرٕ چُھ یتھ دُنیا ہس منٛز تہِ رٕژَر، تہٕ ٲخرتُک گھرٕ چُھ تِہندِس حقس منٛز بہتر ٲسِتھٕے، سٮ۪ٹھاہ رُت گھرٕ چُھ پر ہیز گارن ہُند،"
  16,31,"۔دٲیمی قیا مٕکۍ جنّت ،یِمن منٛز تِم دٲخل سپد ن، کۅلہٕ آسن پکان، تہٕ سورُے کینٛہہ آسہِ تَتہِ عینِ تِہندِ منشہِ مطٲبق،  یہِ جزا چُھ دِوان اللہ تعالیٰ پر ہیز گار ن۔"
  16,32,"۔تِمن پر ہیز گارن یِہِندۍ رُو ح ییٚلہِ پٲکیز گی ہٕندِس حا لتس منٛز فر شتہٕ قبض چِھ کران، تِم چِھ وَنان  سلام ٲسِن تۅہیہِ پٮ۪ٹھ، گژِھو جنتس پننیٚن اعمالن ہٕندِ بدلہٕ۔"
  16,33,"۔اے نبی صلی اللہ علیہ وسلم، وۅ نۍ یُس یِم لُکھ انتظا ر چِھ کران، تیٚلہِ کیا چُھ امہِ ورٲے وۅ نۍ با قی روٗد مُت زِ فر شتے گژھن پیٚنۍ وٲتِتھ،یا گژِھہ تُہٕندِس ربّ سُند فٲصلہٕ صٲدر سپدُن؟ اَمی قسمٕچ ہٹ دھر می چھےٚ یِمو برونٛہہ واریاہ ہو لُکو کٔر مٕژ، پتہٕ یِکینژھاہ تِمن سٍتۍ سپُد سُہ اوس نہٕ تِمن پٮ۪ٹھ اللہ تعالیٰ سُند ظُلم، بلکہ اوس سُہ تِمن پنُن ظُلم، یُس تِمو پانہٕ کوٚر پا نس پٮ۪ٹھ۔"
  16,34,"۔تِہند ٮ۪ن کر توٗتَن ہٕنزٕ خرٲبیہِ آیہِ ٲخر کار تِمن وَلنہٕ، تہٕ سُہ چیز سپُد تِمن پٮ۪ٹھ مُسلّط یتھ تِم ہزٕ ل ٲسۍ کران۔ ع"
  16,35,"۔یِم مشر ک چِھ ونان ،  اگر اللہ تعالیٰ ییژِھے ہے تیٚلہِ نَہ کر ہَو أسۍ تہٕ نَہ کر ہن سٲنۍ مٲلۍ بُڈِ بب تس ورٲے بیٚیہِ کٲنٛسہِ ہٕنز عبادت، تہٕ نہَ ٹھہر اوہن تمۍ سٕندِ حُکمہٕ ورٲے کانٛہہ چیز  حرام۔ یِتھی ہِوۍ بہا نہٕ چِھ تِم لُکھ تہِ بناوان روٗدِمٕتۍ یِم یِمن برونٛہہ ٲسۍ، تیٚلہِ کیا رسولن پٮ۪ٹھ چھا صاف صا ف کتھ واتناو نہٕ ورٲے بیٚیہِ تہِ کانٛہہ ذمہ دٲر ی؟"
  16,36,"۔اسہِ سوٗز پرٛتھ اُمّتس منٛز اکھ رسول، تہٕ تٔمۍ سٕندِ ذر یعہ کٔرۍ سٲر ی خبردار زِ  اللہ تعالیٰ سٕنز بند گی کٔرِو تہٕ طا غوت چہِ بند گی نِشہِ بٔچِو۔ اَمہِ پتہٕ بخُش خُدا ین یِمو منٛزٕ کٲنٛسہِ  ہدایت،تہٕ کٲنٛسہِ پٮ۪ٹھ گٔیہِ ضلا لت ﴿گمرٲہی﴾ مُسلّط،پتہٕ وُچِھتو زمینس پٮ۪ٹھ اورٕ یو ر پٔکِتھ زِ بُتھ پھِر ن والیٚن ہُند انجام کیا چُھ سپُد مُت۔"
  16,37,"۔اے نبی صلی اللہ علیہ وسلم، توٚہۍ ٲسۍ تَو یِہندِ ہدا یت خٲطرٕ کٲتیاہ تہِ حر یص،مگر اللہ تعالیٰ یس گُمرا ہ چُھ کران پتہٕ چُھنہٕ تس ہدا یت دِوان، تہٕ امہِ قسمہٕ کیٚن لُکن ہُند مدد ہیکہِ نہٕ کانٛہہ کٔرِ تھ۔"
  16,38,"۔یِم لُکھ چِھ اللہ تعالیٰ سٕندِ ناوٕ کۍ ویٹھۍ پوٗٹھۍ قسم کھیٚتھ ونان زِ ،  اللہ تعالیٰ تُلہِ نہٕ کٲنٛسہِ مرا ن وٲلِس نَوِ سرٕ زندٕہ کٔرِ تھ۔تُلہِ کیا زِ نہٕ؟ یہِ چُھ اکھ وعد ہ یُس پوٗرٕ کرُن  تٔمۍ پا نس پٮ۪ٹھ چُھ وٲجِب کوٚر مُت،مگر اکثر لُکھ چِھنہٕ زانان۔"
  16,39,"۔تہٕ یہِ سپدُن چُھ امہِ موجو ب ضر وری زِ اللہ تعالیٰ مٕژراوِ تِمن برونٛہہ کنہِ یہِ حقیقت یَتھ متعلق تِم اختلاف چِھ کران، تہٕ حقس انکار کر ن والیٚن لگہِ پے زِ تِم ٲسۍ اَپزٕ یٲرۍ۔ ﴿روٗد وو نۍ اَمِیُک اِمکان﴾"
  16,40,"۔اَسہِ چُھنہٕ کانٛہہ چیز و جودس منٛز اَننہٕ خٲطرٕ امہِ کھۅتہٕ زیادہ کِہِنۍ پیٚوان کرُن، زِ تتھ دِمَو حُکم  سپدَ تہٕ بس سُہ چُھ سپدان۔ع"
  16,41,"۔یِمو لُکو ظُلم ویٚتر اونہٕ پتہٕ اللہ تعالیٰ سٕندِ خٲطرٕ ہجرت چھےٚ کٔرمٕژ، تِمن دِمَو أسۍ دُنیا سٕے منٛز رُت ٹھکانہٕ، تہٕ ٲخرتُک اجر چُھ واریاہ بوٚڈ۔﴿ یہِ اشارٕہ چُھ تِمن مہا جر ن کُن یِمو کٲفر ن ہٕندِ یو نا قا بلِ برداشت ظُلمو نِشہِ تنگ یِتھ حبشس کُن ہِجرت ٲس کٔر مٕژ﴾ کا ش لگہِ ہے پَے تِمن مظلو من یِمو صبر چُھ کوٚر مُت،"
  16,42,"۔تہٕ یِم پننِس ربّ سٕندِس بھر وسس پٮ۪ٹھ کٲم چِھ کران ﴿زِ کِیُتھ رُت انجام چُھ تِمن پرٛاران﴾"
  16,43,"۔ اے نبی صلی اللہ علیہ وسلم، اسہِ ییٚلہِ تہِ زانٛہہ تۅہیہِ برونٛہہ کُنہِ ساعتہٕ رسول چِھ سوٗزِ مٕتۍ ، تِم چِھ انسا نٕے سوٗزِ مٕتۍ یِمن کُن أسۍ پنٕنۍ پیغا م و حی ٲسۍ کران، اہلِ ذِکر ن پٕرٛژِھو اگر توٚہۍ لُکھ پانہٕ چِھو نہٕ زانان۔﴿یعنی تِمن لُکن پرٛژِھو یِمن آسمٲنی کتا بن ہُند علم چُھ زِ انبیا ٲسیا اِنسا نٕے آسان کِنہٕ بیٚیہِ کینٛہہ﴾"
  16,44,"۔پٔتِم رسول تہِ ٲسۍ اَسہِ روشن نِشٲنِیہِ تہٕ کِتا بہٕ دِتھ سوٗزِمٕتۍ، تہٕ وۅ نۍ چھےٚ یہِ ذِکر تۅہیہِ پٮ۪ٹھ نٲزِل کٔرمٕژ، تا کہِ توٚہۍ گٔژِھو لُکن برونٛہہ کنہِ تمہِ تعلیمہٕ ہٕنز تشر یح  تہٕ تو ضیح کران یۅ سہٕ تِہندِ خٲطرٕ نٲزِل چھےٚ کر نہٕ آمٕژ۔﴿یعنی رسول اللہ صلی اللہ علیہ وسلمس پٮ۪ٹھ ٲس امہِ موجوٗب کِتا ب نٲزِل کر نہٕ آمٕژ زِ تِم صلی اللہ علیہ وسلم روزن پننہِ قو لہٕ تہٕ عملہِ سٍتۍ امہِ کیٚن تعلیماتن تہٕ احکامن ہٕنز تشر یح تہٕ تو ضیح کران۔ امہِ نِشہِ چھےٚ خۅد بخود یہِ کتھ ثٲبت سپدان زِ حضور صلی اللہ علیہ وسلمن ہُند سُنت چُھ، قرآنٕچ مستند حٲکما نہٕ تشر یح۔﴾ تہٕ تا کہ لُکھ کر ن ﴿پا نہٕ تہِ ﴾ غورو فکر۔"
  16,45,"۔پتہٕ کیا تِم لُکھ ﴿یِم پیغمبر صلی اللہ علیہ وسلم سٕندِس دعوت کِس مخا لفتس منٛز﴾ بدتر کھۅتہٕ بد تر چالہٕ چِھ گِندان، چھا امہِ کتھہِ نِشہِ با لکُلے بے خوف سپٕد مٕتۍ،زِ اللہ تعالیٰ والہِ تِمن زمینس، یا انہِ تِتھہِ اَندٕ پٮ۪ٹھہٕ تِمن پیٚٹھ عذا ب ییٚتہِ پٮ۪ٹھہٕ امہِ کہ یِنُک تِمن وہم و گُما نٕے آسہِ نہٕ،"
  16,46,"۔یا ر ٹیٛکھ اچانک ییٚلہِ تِم پھیران تھوران آسن، یا ر ٹیٚکھ تِتھِس حالتس منٛز ییٚلہِ زن تِمن پانہٕ آسہِ یِنہٕ والہِ مصیبتُک خوف ،تہٕ تِم آسن امہِ نِشہِ بچنہٕ چہِ فِکرِ منٛز ہُشار روٗزِ تھ؟ سُہ یِکینژھا ہ تہِ کرُن ییٚژِھہ یِم لُکھ چِھنہٕ تس عٲجز کر نُک طا قت تھاوان۔"
  16,47,"۔حقیقت چھےٚ یہِ زِ تُہُند ربّ چُھ سٮ۪ٹھہٕے مہر بان تہٕ سٮ۪ٹھاہ رحم کر ن وول ۔"
  16,48,"۔تہٕ کیا یِم لُکھ چِھنا اللہ تعالیٰ سٕندِس پٲدٕ کر نہٕ آمتِس کُنہِ تہِ چیز س وُچھان زِ ، اَمِیُک سایہِ کِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ سٕندِ س حضورس اند سجدہ کران کران دٔچِھنۍ تہٕ کھۅوٕر ۍ پیوان؟﴿یعنی تمام جسمٲنی چیز ن ہٕنزٕ ژھا یہِ چھےٚامہِ کتھہِ ہٕنز علا مت زِ پہا ڑ ٲسِتن یا کُلۍ، جانور ٲستن یا انسان، اند ہیٚتھ چِھ سٲر ی أکِس ہمہ گیر قا نو ن کِس گرفتس منٛز گٔنڈِتھ، سارِنٕے ہٕندِس ڈیکس پٮ۪ٹھ چُھ بند گی  ہُنٛددا غ لٔگِتھ ، اُلو ہیٚتس منٛز چُھنہٕ کٲنٛسہِ ہُند رَژھ تہِ حصہٕ۔ژھا ے بنٕنۍ چھےٚ اکہِ چیزُک مٲدی آسنٕچ ٹا کارٕ ہ علا مت تہٕ ماد ی آسُن چُھ بندٕہ تہٕ مخلو ق آسنُک کُھلہٕ ثبو ت۔﴾ یتھہٕ پٲٹھۍ چِھ  اندہیٚتھ سٲر ی عٲجزی ہُند اظہا ر کران۔"
  16,49,"۔زمینس تہٕ آسمانن منٛز یِم تہِ جاندار مخلو ق چِھ تہٕ یِم فر شتہٕ چِھ ، سٲر ی چِھ خُدا یس برونٛہہ کنہِ سجدٕہ کران، تِم چِھنہٕ ہر گز تکبر کران،"
  16,50,"۔پننِس ربّس یُس تِمن پٮ۪ٹھہٕ کنہِ چُھ، تس چِھ کھۅژان، تہٕ یِکینژھاہ حکم چُھ دِنہٕ یِوان تمی مُطٲبق چِھ کٲم کران۔ ع"
  16,51,"۔اللہ تعالیٰ سُند چُھ فرمان زِ زٕہ خُدا ے مَہ بنٲوِو، ﴿دۅ ن خُدا ین ہٕندِس انکارس منٛز چُھ دۅیو کتھۅ تہٕ زیادہ خُدا ین ہُند انکار پٲنۍ پانے شٲمِل﴾خُدا ے چُھ بس اَکو ے،لہٰذا کھوٚژِو توٚہۍ میے یوت ۔"
  16,52,"۔تٔمۍ سُندُے چُھ تہِ سورُے کینٛہہ یہِ آسمانن منٛز چُھ تہٕ یِکینژھاہ زمینس چُھ، تہٕ خا لصاً چُھ تٔمۍ سُندُے دین ﴿ سٲرِ سٕے کا ینا تس منٛز﴾ چلان۔﴿دوٚیِمیٚن لفظن منٛز وَنو زِ تٔمۍ سٕندِ سٕے اطا عتس پٮ۪ٹھ چُھ ییٚمہِ کار خا نۂ ہستی ہُند نظام قٲیِم ﴾ پتہٕ کیا اللہ تعالیٰ ترٲوِتھ کھوٚژِ وہ توٚہۍ بیٚیہِ کٲنٛسہِ ؟"
  16,53,"۔تۅہیہِ یۅسہٕ تہِ نعمت حا صل چَھو ، سۅ چَھو اللہ تعالیٰ سٕندی طر فہٕ، پتہٕ ییٚلہِ کانٛہہ سخت وقت تۅہیہِ پٮ۪ٹھ یِوان چُھ، تیٚلہِ چِھو خۅد توٚہۍ لُکھ پنٕنۍ فر یاد ہیٚتھ تٔسۍ کُن دَوان۔"
  16,54,"۔مگر ییٚلہِ اللہ تعالیٰ سُہ وقت تۅہیہِ نِشہِ دور چُھ کران،تیٚلہِ چُھ اچانک تۅہیہِ منٛزٕ اکھ دوٚر پننِس ربّس سٍتۍ دوٚ یِمیٚن ﴿اَمہِ مہر بٲنی ہٕندِ شُکر یہِ خٲطرٕ ﴾ شر یک لاگان کرُن،"
  16,55,"۔تاکہ اللہ تعالیٰ سٕندِ احسا نٕچ کرِ نا شکر ی، اچھا ، کٔرِو مزٕہ،عن قر یب لگیو تۅہیہِ پے۔"
  16,56,"۔یِم لُکھ یِہندِ حقیقت نِشہِ وٲقف چِھنہٕ ، تِہٕندۍ حصّہ چِھ سانہِ عطا کرِ مَتہِ رِز قہٕ منٛزٕ مُقرر کران،اللہ تعالیٰ سُند قسم ،ضرور یِیہِ تۅہیہِ پٕرٛژھنہٕ زِ یِم اَپزٕۍ کِتھہٕ پٲٹھۍ ٲسِو تۅہیہِ بنٲوِ مٕتۍ۔"
  16,57,"۔یِم چِھ اللہ تعالیٰ سٕندِ خٲطرٕ کورِ کران تجویز۔﴿عر ب کیٚن مُشر کن ہٕندٮ۪ن معبودن منٛز ٲسۍ دیوتا کم ،دیوی آسہٕ زیادٕہ ،تہٕ یِمن دیوی ین مطعلق اوس تِہُنٛد عقیدٕہ زِ تِم چھِ خداے سٕنزٕ کورِ۔یِتھے پٲٹھۍ ٲسۍتِم فر شتن تہِ خُدا ے سٕنزٕ کورِ مانان﴾ سُبحان اللہ ! تہٕ تِہندِ خٲطرٕ تہِ یِکینژھاہ یِم پانہٕ یژھن ﴿یعنی نیٚچوۍ﴾"
  16,58,"۔ییٚلہِ یِمو منٛزٕ کٲنٛسہِ کوٗر زیٚنٕچ خو ش خبر چھےٚ دِنہٕ یِوان ، تیٚلہِ چھےٚ تٔمۍ سٕندِس بتھِس پٮ۪ٹھ  ہاے کھسان،تہٕ تس چھےٚ پتہٕ وٲنِج رَتھ چیٚوان ﴿شرارت چُھس کھسان﴾۔"
  16,59,"۔لُکن ژوٗر ژھیٚپہِ چُھ پکان زِ امہِ بُرٕ خبرِ پتہٕ کُس بُتھ  ہاوِ لُکن۔سو چان چُھ زِ ذلّت سان رَٹنہٕ کوٗر کِنہٕ میٚژِ منٛز دباوَن؟ وُچِھو کِتھۍ بُرٕ حکم چِھ تِم ، یِم خُدا یس متعلق یِم لُکھ لگا وان چِھ ۔﴿یعنی پننہِ خٲطرٕ یس کورِ یِم ؤسۍ پایہِ تہٕ بے عز ت چِھ سمجھان، سۅ ے چِھن خُدا ے سٕندِ خٲطرٕ بلا تا مُل تجویز کران﴾"
  16,60,"۔بُرٕ صفتو سٍتۍ ناو ہیٚنس لا یق چِھ تِم لُکھ یِمن ٲخرتس پٮ۪ٹھ یقین چُھنہٕ، روٗد اللہ تعالیٰ ، تس خٲطرٕ چِھ سارِ وٕے کھۅتہٕ تہٕ تھَدِ پا یِکۍ صفا ت، سُے چُھ سارِ نٕے پٮ۪ٹھ غٲلب تہٕ حکمتس منٛز چُھ کٲمِل۔ع"
  16,61,"۔اگر اللہ تعالیٰ لُکن آسِہے تِہنزِ زیادتی پٮ۪ٹھ فوراً رٹان، تیٚلہِ تراوِ ہے نہٕ رو ے زمینس پٮ۪ٹھ کٲنٛسہِ جاندارس یَلہٕ، مگر سُہ چُھ پرٛتھ کٲنٛسہِ أکِس مقرر وقتس تام مہلت دِوان، ییٚلہِ سُہ وقت چُھ واتان،تیٚلہِ ہیکہِ نٕہ پتہٕ تتھ اکھ گٔر تہِ پتھ برونٛہہ سپدِ تھ۔"
  16,62,"۔اَز چِھ یِم لُکھ اللہ تعالیٰ سٕندِ خٲطرٕ تِم چیز تجو یز کران، یِم پانہٕ یِمن پننہِ خٲطرٕ نا پسند چِھ، تہٕ اَپُز چھےٚ ونان یِہنزٕ زیوٕ زِ یِہندِ خٲطرٕ چُھ رٕژرٕے رٕژَر، یِہندِ خٲطرٕ چُھ بس اَکو ے چیز، تہٕ سُہ چُھ جہنمُک نار۔ضروٗر یِن یِم سارِوٕے برونٛہہ تتھ منٛز واتنا و نہٕ۔"
  16,63,"۔اللہ تعالیٰ سُند قسم ، اے نبی صلی اللہ علیہ وسلم ، تۅہیہِ برونٛہہ تہِ چِھ اسہِ واریاہن قو من منٛز رسول سوٗزِ مٕتۍ ﴿ تہٕ گۅڈٕہ تہِ چُھ یی سپدان روٗزمُت ﴾ زِ شیطانن ہٲوۍ تِہندۍ بُرٕ کر توٗت تِمن خۅ شنما بنٲوِتھ ﴿تہٕ رسو لن ہٕنز کتھ مٲنۍ نہٕ تِمو ﴾ سُے شیطا ن چُھ از تِمن لُکن تہِ سر پرست بنیو مُت،تہٕ یِم چِھ دگ تُلوٕ نہِ عذا بٕکۍ حقدار بنان ۔"
  16,64,"۔اسہِ چھےٚ یہِ کتاب تۅہیہِ پٮ۪ٹھ امہِ موٗجوٗب نٲزِل کٔر مٕژ زِتوٚہۍ مٕژ رٲوِ و تِمن اختلا فن ہٕنز حقیقت یِمن منٛز یِم ہیٚنہٕ چِھ آمٕتۍ۔یہِ کتاب چھےٚ رہنمٲیی تہٕ رحمت بٔنِتھ نٲزِل گٔمٕژ تِمن لُکن خٲطرٕ یِم اتھ مانن۔﴿توٚہۍ چِھو ہمیشہ روٗدٕ پیٚنہٕ وِزِ وُچھان زِ ﴾"
  16,65,"۔خُدا ین تر وو آسمانہٕ روٗد،تہٕ فوراً تر ووُن مُردٕہ زمینس اندر امہِ کہ بد ولت زُو۔﴿ یعنی یہِ منظر چُھ پرٛتھ ؤرِیہِ تُہنز وأچھو برونٹھۍ کِنۍ نیران زِ زمین چھےٚ با لکل ہموار آسان ، کُنہِ قسمٕکۍ زند گی ہٕندۍ آثا ر چِھس نہٕ لبنہٕ یِوان ،نہ گا سہٕ ، نہ درٛ مُن ،نہ یوٗ ٹہِ ، نہ پوش تہٕ نہٕ کُنہِ قسمُک سبزار۔اَتھ دورا ن چُھ روٗدُک مو سم وا تان تہٕ کینٛہہ روٗدٕ قطرٕ پیٚنس سٍتی چِھ اتھ زمینس اندر زند گی ہٕندۍ نا گ گرٛزٕ نۍ ہیوان، زمین کیٚن تحن تل دَبے مٕتیٚن بے شُمار موٗلن چُھ زُو اَژان تہٕ پرٛتھ موٗلس چُھ تیِ نیران یہِ پٔتِمہِ روٗدٕ وِزِ درٛا مُت اوس تہٕ پتہٕ اوس  ختم گوٚ مُت۔ بے شُما ر گا سہٕ ذٲژ یُہُند نام و نشا ن تہِ گر می ہٕندِ وقتہٕ روٗد مُت اوس نہٕ، فوراً چھےٚ تمی شا نہٕ سان نمودار سپدان،یِتھہٕ پٲٹھۍپٔتِمہِ روٗدٕ وِزِ وُچِھنہٕ آسہٕ آمژٕ۔ یہِ سورُے چِھو توٚہۍ گرِ گرِ پننہِ زند گی منٛز وُچھان،تہٕ پتہٕ چُھ تۅہیہِ نبی صلی اللہ علیہ علیہ وسلمن ہٕنزِ زبٲنۍ یہِ بوٗزِ تھ حٲر ت سپدان زِ اللہ کرِ انسانن مَر نہٕ پتہٕ دُوبار زندٕہ﴾۔ پٔزِ پٲٹھۍ چھےٚ اتھ منٛز اکھ نشٲنی بوزن والیٚن خٲطرٕ ۔ع"
  16,66,"۔تہٕ تُہِندِ خٲطرٕ چُھ چا رواین منٛز تہِ اکھ سبق موجود۔ أسۍ چِھو تۅہیہِ گُہِس تہٕ خو نس در میان اکھ چیز چاوان یُس تِہنزن یٔڈن منٛز چُھ آسان، یعنی خٲلِص دۅد، یُس چیٚنہٕ والیٚن خٲطرٕ سٮ۪ٹھاہ خوشگوار  چُھ۔"
  16,67,"۔﴿یتھے پٲٹھۍ﴾ کھٔزٕر کُلیو تہٕ دَچھہِ گُر نَو نِشہِ تہِ چِھو أسۍ توٚہۍ زٕ ہ چیز چاوان،یُس توٚہۍ نَشَہ آور تہِ چھوٗن بناوان تہٕ پاک رِزق تہِ ﴿اتھ منٛز چُھ اکھ ضمنی اِشارٕ ہ شرا ب کِس حرا م آسنس کُن تہِ زِ سُہ چُھنہٕ پاک رزق﴾ پٔزِ پٲٹھۍ چھےٚ اتھ منٛز اکھ نشٲنی عقلہِ کٲم ہیٚنہٕ والیٚن خٲطرٕ۔"
  16,68,"۔بیٚیہِ وُچِھو ،تُہٕندۍ ربَّن  کٔر تُلرِ پٮ۪ٹھ یہِ کتھ وَحی ۔﴿ وَحی ہُند لُغوی معنی چُھ خُفیہ تہٕ لطیف اِشارٕہ یتھ اِشارٕہ کرن وٲلِس تہٕ اشار ہ رٹن وٲلِس ورٲے کانٛہہ محسو س ہیٚکہِ نہٕ کٔرِ تھ۔أتھۍ معنیس منٛز چُھ یہِ القا ﴿دلس منٛز کتھ تراوٕنۍ﴾ تہٕ اِلہام ﴿مخفی تعلیم و تلقین﴾ کِس معنی یس منٛز استعمال سپدان﴾ زِ پہا ڑن منٛز ،تہٕ کُلیٚن منٛز، وَردار رٲنٛٹھن منٛز بناو پنٕنۍ گھرٕ﴿ یعنی مٲچِھ گن ،تو مبٕر﴾،"
  16,69,"۔پرٛتھ قسمہٕ کیٚن میو ن ہُند رس ژٕ ہہ، تہٕ روز پکان پننِس ربّ سٕنز ن ہموا ر کر نہٕ آمژن وَتن پٮ۪ٹھ۔أمِس تُلرِ منٛزٕ چُھ رنگ بر رنگُک اکھ شر بت نیران، یتھ منٛز شفا چُھ لُکن خٲطرٕ ، پٔزِ پٲٹھۍ چھےٚ اتھ منٛز تہِ اکھ نشٲنی تِمن لُکن خٲطرٕ یِم غورو فکر  چِھ کران۔"
  16,70,"۔بیٚیہِ وُچِھو،خُدا ین کٔرِ نَو توٚ ہۍ پٲدٕ ،پتہٕ چُھو سُہ تۅ ہیہِ مو ت دِوان ، تہٕ تۅ ہیہِ منٛزٕ چُھ کانٛہہ بد تر ین وٲنٛسہِ یِوان واتناو نہٕ، تا کہ سورُے کینٛہہ زاننہٕ پتہٕ گژِھنہٕ کِہِنۍ زانُن،حق چُھ یہِ زِ اللہ تعالیٰ ہٕے چُھ علِمس اندر تہِ کٲمِل تہٕ قدرتس منٛز تہِ ۔ ع"
  16,71,"۔بیٚیہِ وُچِھو ، خُدا ین چھےٚ تۅ ہیہِ منٛزٕ کینژھن کینژھن پٮ۪ٹھ رزقس منٛز فضیلت عطا کٔر مٕژ،پتہٕ یِمن لُکن یہِ فضیلت دِنہٕ آمٕژ چھےٚ تِم چِھنہٕ تِتھۍ زِ پنُن رزق آسہن پننیٚن غلا من کُن پھِران، تا کہ دۅ شو ے بنَن اتھ رِزقس منٛز ہِوی حصّہ دار، تیٚلہِ کیا یِمن چھا اللہ تعالیٰ سُندُے احسان ماننہٕ نِشہِ انکار؟ ﴿أزِکِس زمانس منٛز چُھ کینژھو لُکو یتھ آیتس یہِ مطلب کوٚڈمُت زِ یِمن لُکن خُدا ین آسہِ رزقس منٛز فضیلت عطا کٔر مٕژ، تِمن پزِ پنُن رزق پننیٚن نو کر ن تہٕ غلا من کُن ضروٗر پھِرُن، اگر نہٕ پھِر ن تیٚلہِ یِن تِم اللہ تعالیٰ سٕندِ نعمتٕکۍ مُنکر ماننہٕ۔حالانکہ ہیرِ پٮ۪ٹھہٕ چُھ سورُے تقریر شر ک کِس اِبطا لس منٛز تہٕ تو حید کِس اثبا تس منٛز پکان یِوان تہٕ برونٛہہ کُن تہِ چُھ یۅ ہے مضمو ن مُسلسل پکان۔ہرگاہ سیا ق و سباق مدِ نظر تھٲوِ تھ یِیہِ وُچھنہٕ تیٚلہِ چُھ صا ف پٲٹھۍ پے لگا ن زِ یتھ جایہِ چُھ یہِ استدلال کر نہٕ آمُت زِ ییٚلہِ توٚہۍ خۅد چِھو پننہِ مالہٕ منٛزٕ پننیٚن غلا من تہٕ نو کر ن ہِیوُے در جہ دِوان، تیٚلہِ کِتھہٕ پٲٹھۍ چِھو ٲخر یہِ کتھ صحیح سمجھان زِ یِم احسا نا ت خُدا ین تۅہیہِ پٮ۪ٹھ کٔرِ مٕتۍ چِھ تِہندِس شکر انس منٛز کٔرِ یوٗکھ خُدا یس سٍتۍ تٔمۍ سٕندۍ بے اختیار غلا م تہِ شر یک تہٕ پننہِ جایہِ سمجھِو یہِ زِ اختیار اتن تہٕ حقو قن منٛز چِھ یِم غلا م تہِ تس سٍتۍ برابرٕ کۍ حصّہٕ دار﴾"
  16,72,"۔تہٕ سُہ چُھ اللہ تعالیٰ ہٕے ییٚمۍ تُہندِ خٲطرٕ تُہنزٕ ہم جنس خاندارِ نہِ بناوِ،تہٕ تٔمی کٔرِ نَو تۅہیہِ یِمن خاندارِ نیٚن ہٕندِ ذر یعہ نیٚچو تہٕ زُر ۍ عطا، تہٕ جان جان چیز  دِتِنو کھیٚنہٕ خٲطرٕ پتہٕ کیا یِم لُکھ چھا ﴿یہِ سورُے وُچِھتھ کٔرِ تھ تہِ ﴾ با طل مانان ﴿یعنی یِمن چِھ بے بنیا د تہٕ بے حقیقت عقیدہ زِ یِہِندۍ قسمت بناوٕ نۍ تہٕ بِگاڑٕ نۍ ، یِہِندۍ مُراد پوٗرٕ کرٕنۍ تہٕ دعا بوزٕ نۍ ،یِمن اولاد دِنۍ یِمن روزگار دیاوُن،یِہِندۍ مُقد مہٕ زیناوٕ نۍ تہٕ یِم بیمار یٚو نِشہِ بچٲوٕ نۍ چُھ دیو ی یَن تہٕ دیو تا ہن بیٚیہِ جِنن تہٕ پٔتِمیٚن بروٗنٹھمیٚن بزر گن ہٕندِ س اختیار س منٛز ﴾ تہٕ اللہ تعالیٰ سٕندِس احسا نس چِھ انکار کران۔"
  16,73,"۔بیٚیہِ چِھ اللہ تعالیٰ ترٲوِتھ تِمن پوٗزان، یِہندٕ ٮ۪ن اَتھن منٛز نَہ آسما نو پٮ۪ٹھہٕ کینٛہہ رزق دِیُن چُھ تہٕ نَہ زمین نِشہِ ، تہٕ نَہ ہیٚکن تِم یہِ کٲمٕے کٔرِ تھ؟"
  16,74,"۔پس اللہ تعالیٰ ہس خٲطرٕ مَہ تُھرِ و مِثا لہٕ، ﴿ یعنی اللہ تعالیٰ مَہ زٲنِیوٗن دنیا کیٚن با دشاہن تہٕ راجن مہا راجن ہٕندۍ پٲٹھۍ زِ یِتھہٕ پٲٹھۍ تِہند ٮ۪ن خا ص نفر ن تہٕ قر یبی مُلا زمن ہٕندِتو سطہٕ ورٲے کانٛہہ پنٕنۍ عر ضی تِمن تام ہیٚکہِ نہٕ واتنٲوِتھ، تِتھے پٲٹھۍ کٔرِ و توٚہۍ خُدا یس متعلق تہِ یہِ گُما ن زِ سُہ چُھ پننِس شٲہی محلس منٛز ملٲیکن اولیا ہن تہٕ با قی قر یبی نفر ن منٛز باگ بِہِتھ، تہٕ کٲنٛسہِ ہٕنز کٲم نیرِ نہٕ تِہند یٚو وا سطو تہٕ سُفٲرِ شو ورٲے﴾ اللہ تعالیٰ چُھ زانان،توٚہۍ چِھو نہٕ زانان۔"
  16,75,"۔ اللہ تعالیٰ چُھ اکھ مثال دِوان۔ اکھا چُھ غلام یُس بیٚکۍ سُند مملو ک ﴿ملکیت  چُھ، تہٕ پا نس چُھسنہٕ کانٛہہ اختیار، بیاکھ شخص چُھ تِیُتھ یَس اسہِ پننہِ طر فہٕ جان رزق چُھ عطا کوٚر مُت، تہٕ سُہ چُھ امہِ منٛزٕ نَنہِ وانہٕ تہٕ کھٔٹِتھ جان پٲٹھۍ خر چ کران، ؤنِو، کیا یِم دۅ شو ے چھا برابر ؟ الحمدُ اللہ، ﴿چونکہ اَمہِ سوال کِس جوابس منٛز ہیوٚک نہٕ مُشرکو یہِ ؤنِتھ زِ دۅشوے چھِ برابر،اَمہِ موجوب آو فرماونہٕ ،الحمدُللہ ،یہِ کتھ تٔرٕ و تۅہیہِ فِکرِ۔﴾ مگر اکثر لُکھ چِھنہٕ ﴿یہِ سیٚود کتھ ﴾ زانان۔"
  16,76,"۔اللہ تعا لیٰ چُھ بیاکھ  اکھ مثا ل دِوان ، زٕ ہ نفر چِھ ، اکھ چُھ کوٚل زوٚر، کانٛہہ کٲم چُھنہٕ ہیٚکان کٔرِ تھ، پننِس مٲلِکس پٮ۪ٹھ چُھ بو ر بٔنِتھ روٗزِ تھ، یو ر تہِ سُہ تس سوزِ ، سُہ ہیٚکہِ نہٕ کانٛہہ جان کٲم کٔرِ تھ بیاکھ شخص چُھ تِیُتھ زِ انصا فُک حکم چُھ دِوان تہٕ پانہٕ چُھ راہِ را ستس پٮ۪ٹھ قٲیِم ،ؤنِو کیا یِم دۅ شو ے چھا یکسان ؟۔ع"
  16,77,"۔تہٕ زمین و آسمان کیٚن پو شیدہ حقیقتن ہُند علم چُھ صرف اللہ تعالیٰ سٕے یوت۔تہٕ قیا مت بر پا سپد نُک معا ملہٕ ، کانٛہہ تٲر لگہِ نہٕ مگر بس تیوٗتاہ زِ یتھ منٛز انسانس أچھ ٹیٖنٹھ گژِھ، بلکہ امہِ کھۅتہٕ تہِ کم ،حقیقت چھےٚ یہِ زِ اللہ تعالیٰ ہیٚکہِ سورُے کینٛہہ کٔرِ تھ۔"
  16,78,"۔خُدا ین کٔڑِ نَو توٚہۍ تُہنز و ما جیو ہٕند یو شکمو منٛزٕ تتھ حا لتس منٛز زِ توٚہۍ ٲسِو نہٕ کِہِنۍ زانان۔ تٔمۍ دِتِو تۅہیہِ کن، أچھ دِژ نَو، تہٕ سو چن وٲلۍ دِل دِتِنو، امہِ موجو ب زِ توٚہۍ بٔنِو شُکر گزار۔"
  16,79,"۔کیا یِمو لُکو وُچھنا زانٛہہ پر ندٕ ہ زِ آسمٲنۍ فضا ہس منٛز کِتھہٕ پٲٹھۍ چِھ مُسّخر؟ خُدا یس ورٲے کٔمۍ چِھ یِم دٔر رٲوِتھ تھٲوِ مٕتۍ؟ اتھ منٛز چھےٚ واریاہ نِشٲنیہِ تِمن لُکن خٲطرٕ یِم ایمان چِھ اَنان۔"
  16,80,"۔خُدا ین بنٲو ۍ تُہٕندِ خٲطرٕ تُہٕندۍ گھرٕ سکونٕچ جا ے، تٔمۍ کٔرۍ جانو ر ن ہٕند یو مٕسلو سٍتۍ تُہٕندِ خٲطرٕ تِتھۍ مکان پٲدٕ،یِم تۅہیہِ سفر س تہٕ قیا مس،دۅشٕو نۍ حالتن منٛز لوٚ تۍ چِھ با سان ﴿یعنی دالوٕۍ خٍمہٕ یُہُند روا ج عر بس منٛز واریاہ چُھ﴾ تٔمۍ کٔرۍ جا نو ر ن ہٕندِ ییرٕ تہٕ تو سہٕ تہٕ والَو نِشہِ تُہُندِ خٲطرٕ لا گنٕکۍ تہٕ ورتا و نٕکۍ واریاہ چیز پٲدٕ ، یِم زند گی ہٕندِس مقرر وقتس تام تۅہیہِ بکا ر چِھو یِوان۔"
  16,81,"۔تٔمۍ کوٚر پننیٚو واریاہَو بنا و نہٕ آمتیٚو چیز و سٍتۍ تُہُندِ خٲطرٕ شیٚجارُک انتظام،پہاڑن منٛز بنٲویٚن تُہُندِ خٲطرٕ چَھپن جایہِ ، تہٕ تۅہیہِ کٔرۍ نو تِتھۍ پۅ شا ک عطا یِم تۅہیہِ گر می نِشہِ بچا وان چِھو،تہٕ بیٚیہِ کینٛہہ پۅ شاک یِم اکھ أکِس سٍتۍ جنگس منٛز تُہٕنز حفا ظت چِھ کران، یِتھہٕ پٲٹھۍ چُھ سُہ تۅہیہِ پٮ۪ٹھ پننیٚن نعمتن ہُند تکمیل کران،شاید زِ توٚہۍ بٔنِوفر ماں بردار۔"
  16,82,"۔وۅنۍ اگر یِم لُکھ بُتھ چِھ پھِران، اے نبی صلی اللہ علیہ وسلم، تۅہیہِ پٮ۪ٹھ چَھنہٕ صا ف صا ف پیغامِ حق واتناو نہٕ ورٲے بیٚیہِ کانٛہہ ذمہٕ دٲر ی۔"
  16,83,"۔یِم چِھ اللہ تعالیٰ سٕندِس احسا نس پرزٕ ناوان،پتہٕ چِھ تَتھ انکار کران تہٕ یِمن منٛز چِھ اکثر لُکھ تِتھۍ یِم حق ماننہٕ خٲطرٕ تیار چِھنہٕ ۔ ع"
  16,84,"۔﴿یِمن چھا کینٛہہ ہو ش تہِ زِ تمہِ دۅہ کیا بنہِ؟﴾ ییٚلہِ پرٛتھ اُمّت منٛزٕ أسۍ اکھ گواہ کھڑا کر و ن، پتہٕ نَہ یِیہِ کٲفر ن حُجّتہٕ پیش کر نُک مو قع دِنہٕ ﴿ اَمِیُک مطلب چُھنہٕ یہِ زِ تِمن یِیہِ نہٕ صفٲیی پیش کر نُک مو قع دِنہٕ بلکہ چُھ مطلب یہِ زِ تِہندۍ جر م یِن تِژھو ٹا کارٕ ہ نا قا بلِ انکار تہٕ نا قا بلِ تٲویل شہا دتو سٍتۍ ثٲبت کر نہٕ زِ تِہندِ خٲطرٕ روزِ نہٕ صفٲیی پیش کر نٕچ کانٛہہ گُنجٲیش۔﴾تہٕ نہٕ یِیہِ تِمن تو بۂ استغفار کُے مطا لبہٕ کر نہٕ۔"
  16,85,"۔ظا لم لُکھ ییٚلہِ اکہِ پھِرِ عذا بُک مزٕہ وُچھن،پتہٕ نَہ یِیہِ تِہندِ س عذا بس منٛز کمی کر نہٕ، تہٕ نَہ یِیہِ تِمن أکِس ژِ ہِس سُمب مہلت دِنہٕ۔"
  16,86,"۔تہٕ ییٚلہِ تِم لُکھ یِمو دُنیا ہس منٛز شر ک اوس کوٚر مُت پننیٚن ٹھہرا و نہٕ آمتیٚن شر یکن وُچَھن، پتہٕ وَنن اے پر وردگار،یِمے چِھ تِم سٲنۍ شر یک یِمن أسۍ ژٕ ترٲوِ تھ ناد ٲسۍ لایان۔ اتھ پٮ۪ٹھ دِن تِہندۍ یِم معبود تِمن صا ف جوا ب زِ  توٚہۍ چِھو اَپزِ یٲرۍ۔﴿یعنی اسہِ اوسُو نہٕ تۅہیہِ یہِ  زٕ ہٕنۍ ووٚ نمُت زِ خُدا ے ترٲوِ تھ ٲسِو توٚہۍ اسہِ ناد لایان، نَہ ٲسۍ أسۍ تُہندِ س اتھ حر کتس پٮ۪ٹھ رٲضۍ بلکہ ٲس نہٕ اَسہِ خبرٕ ے زِ توہۍ چِھواسہِ نادلایان﴾"
  16,87,"۔تمہِ وقتہٕ نمن سٲر ی خُدا یس برونٛہہ کنہِ، تہٕ یِہنزٕ تِمہٕ سار ے اِفترا پردٲزی ﴿یعنی اَپزٕۍ تہٕ بہتا ن ﴾ راوَن یِمہٕ یِم دُنیا ہس  منٛز کران روٗدِ مٕتۍ ٲسۍ۔"
  16,88,"۔یِمو لُکو خۅد کُفر چ وتھ اختیار کٔر تہٕ با قی رُکٲوِکھ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ ، تِمن دِ مو أسۍ عذا بس پٮ۪ٹھ عذا ب۔،تمہِ فسادٕ بد لہٕ یُس تِم دُنیا ہس منٛز بر پا کران روٗدۍ۔"
  16,89,"۔﴿اے نبی صلی اللہ علیہ وسلم ، یِم کٔرِ یوٗکھ تمہِ دۅہ نِشہِ خبرادر ﴾ ییٚلہِ أسۍ پرٛتھ اُمّت مںزٕ خۅد تمی منٛزٕ اکھ گواہ کھڑا کر ون یُس تمہِ کِس مقا بلس منٛز شہا دت دِیہِ ،تہٕ یِمن لُکن ہٕندِس مقا بلس منٛز اَنو أسۍ توٚہۍ شہا دت دِنہٕ خٲطرٕ۔تہٕ ﴿یہِ چھےٚ تمی شہا دتٕچ تیار ی﴾ زِ اسہِ چھےٚ یہِ کتاب تۅہیہِ پٮ۪ٹھ نٲزِل کٔر مٕژ یۅسہٕ پرٛتھ چیزٕ چ صا ف صا ف وضا حت کرن واجِنۍ چھےٚ،بیٚیہِ چھےٚ ہدا یت تہٕ رحمت تہٕ بشارت تِمن لُکن خٲطرٕ یِم مسلمان چِھ ﴿ یعنی یِمو سرِ تسلیم خم چُھ کوٚر مُت﴾۔ع"
  16,90,"۔اللہ تعالیٰ چُھ عد لُک تہٕ احسا نُک تہٕ صلۂ رحمی ہُند ﴿ قرابت دارن تِہندۍ حقو ق دِنُک﴾ حکم دِوان، بیٚیہِ چُھ بد ی تہٕ بے حیٲیی تہٕ ظُلم و زیا دتی نِشہِ ٹھا کھ کران۔سُہ چُھو تۅہیہِ نصیحت کران تاکہ توٚہۍ رٔٹِو سبق۔"
  16,91,"۔اللہ تعالیٰ سُند عہد کٔرِو پوٗرٕ ییٚلہِ تۅہیہِ تس سٍتۍ کانٛہہ عہد آسیو کوٚر مُت، تہٕ پنٕنۍ قسم مَہ  پھٹرٲوِو پۅ ختہٕ کر نہٕ پتہٕ، ییٚلہِ زَن تۅہیہِ اللہ تعالیٰ آسیو گواہ بنو و مُت۔اللہ تعالیٰ چُھ تُہندِ یٚو تمام اعما لو نِشہِ با خبر۔"
  16,92,"۔تُہٕنز حالت گژِھہ نہٕ تس زنانہِ ہٕندۍ پٲٹھۍ سپدٕنۍ، ییٚمۍ پننہِ محنتہٕ سٍتۍ سٕتھٕر کوٚت تہٕ پتہٕ کوٚرُن پٲنۍ پانے تتھ پُژٕ پار، توٚہۍ چِھو پنٕنۍ قسم اکھ أکۍ سٕند ٮ۪ن معا ملاتن منٛز دغا تہٕ فر ییٕکۍ ہتھیار بناوان، تاکہِ اکھ قو م کرِ دوٚ یِمہِ قو مہٕ کھۅتہٕ زیادہ فٲیدٕہ حٲصل،حالانکہ اللہ تعالیٰ چُھ امہِ عہد و پیمان کہ ذر یعہ تۅہیہِ آزمٲیشہِ منٛز تراوان،تہٕ ضرور مژٕ راوِ سُہ قیا مت کہ دۅہ تُہند ٮ۪ن سارِنٕے اختلا فن ہٕنز حقیقت،"
  16,93,"۔ہرگاہ اللہ تعالیٰ سٕنز مشیت یہِ آسِہے ﴿زِ تۅہیہِ منٛز گوٚژھ نہٕ کانٛہہ اختلا ف آسُن﴾ تیٚلہِ بناوِ ہے سُہ تۅہیہِ سارِنٕے کُنی اُمّت، مگر سُہ یَس یژھان چُھ تس چُھ گُمرٲہی منٛز تراوان،تہٕ یس یژھان چُھ تس چُھ سیٚز وَتھ ہاوان،تہٕ ضروٗر سپد یو تۅہیہِ عملن ہٕنز پرٕژھگٲر۔"
  16,94,"۔﴿تہٕ اے مسلمانو،﴾ توٚہۍ بنٲوِو زیو نہٕ پنٕنۍ قسم پانہٕ وٲنۍ اکھ أکِس دوکھہٕ دِنُک ذر یعہ، یِنہٕ یہِ سپدِ زِ کانٛہہ قد م جمنہٕ پتہٕ گژھیو رِ کِش ﴿ یعنی کھۅر ژلیٚو نِیرِ تھ﴾، تہٕ توٚہۍ وُچِھو امہِ جُر م کِس پاداشس منٛز بُرٕ نتیجہِ ، تِکیازِ تۅ ہیہِ رُکٲوِیوکھ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ لُکھ، تہٕ بیٚیہِ آسہِ تُہٕندِ خٲطرٕ بوٚڈ عذا ب۔﴿ یعنی یہِ گژِھہ نہٕ سپدُن زِ کانٛہہ شخص ڈلہِ اسلام کہ صدا قتُک قٲیل سپد نہٕ پتہٕ محض تُہٕنز بد اخلٲقی وُچِھتھ امہِ دین نِشہِ ، تہٕ امہِ وجہ کِنۍ روزِ سُہ اہلِ ایمانن ہٕندِ س دٔرِس منٛز شٲمل سپد نہٕ نِشہِ پتھ زِ امہِ دَرِ کیٚن یِمن لُکن سٍتۍ  تس سٲبقہٕ پیش آو ، تِم وُچھنہٕ تٔمۍ اخلا قس تہٕ معا ملا تن منٛز کٲفر و کھۅ تہٕ مختلف کینٛہہ۔﴾"
  16,95,"۔اللہ تعالیٰ سُند عہد مَہ کٕنِو معمولی فٲیدہ کہ بد لہٕ،یِکینژھاہ خُدا یس نِشہِ چُھ سُہ چھُ تُہندِ خٲطرٕ زیادہ بہتر، اگر توٚہۍ زٲنِو۔"
  16,96,"۔یِکینژھاہ تۅہیہِ نِشہِ چُھ، سُہ چُھ خر چ گژھن وول،تہٕ یِکینژھاہ خُدا یس نِشہِ چُھ، سُے چُھ پتھ کُن روزن وول،تہٕ أسۍ دِمَو ضرور صبرس کٲم ہیٚنہٕ والیٚن تِہندۍ اجر، تِہندٮ۪ن بہتر ین اعما لن مطٲبق۔"
  16,97,"۔یُس شخص تہِ نیک عمل کرِ،خوا ہ سُہ مرد ٲستن یا خاتوٗن،بشر طیکہ آسہِ سُہ مو من ، سُہ کر ناوون أسۍ دُنیا ہس منٛز پا کیز ہ زند گی بسر، تہٕ ﴿ٲخرتس منٛز﴾ کرو یِتھیٚن لُکن یِہندۍ اجر یِہند ٮ۪ن بہتر ین اعما لن مطٲبق عطا۔"
  16,98,"۔پتہٕ ییٚلہِ توٚہۍ قرآن لٲگِو پرُن، تیٚلہِ مٔنگِو شیطا ن رجیمس نِشہِ اللہ تعالیٰ سُند پناہ۔﴿امِیُک مطلب چُھنہٕ صرف یُتُے زِ زبٲنۍ سٍتۍ گژِھہ  اَعوذُ بِا للہِ مِنَّ الشّیطٰنِ الرَّ جِیمِ وَننہٕ یُن، بلکہ گژِھہ اتھ سٍتۍ پٔزِ پٲٹھۍ دِلی جذ بہٕ سان خُدا یس یہِ دُعا تہِ کرُن زِ قرآن پر نہٕ وقتہٕ تھا ومےٚ شیطا ن سٕند یو گُمراہ کرن والیو وَسوَسو نِشہِ محفو ظ ،تِکیازِ ییٚمۍ ییٚتہِ ہدایت لوٚب نہٕ، سُہ لبہِ نہٕ پتہٕ بیٚیہِ کُنہِ جایہِ ہدا یت ،تہٕ ییٚمۍ ییٚمہِ کتا بہِ نِشہِ گُمرٲہی ا خذ کٔر،تس ہیٚکہِ نہٕ پتہٕ دُنیا ہُک کانٛہہ چیز گُمرٲہین ہٕندِ آو لٕنہِ منٛزٕ کٔڑِتھ۔﴾"
  16,99,"۔تس چُھنہٕ تِمن لُکن پٮ۪ٹھ تسلط حٲصل سپدان، یِم ایمان چِھ انان، تہٕ پننِس ربّس پٮ۪ٹھ چِھ بھر وسہٕ کران۔"
  16,100,"۔تٔمۍ سُند زور چُھ تِمنٕے لُکن پٮ۪ٹھ چلان یِم تس پنُن سر پرست بناوان چِھ، تہٕ تٔمۍ سٕندِ ڈالنہٕ سٍتۍ چِھ شر ک کران۔ع"
  16,101,"۔ییٚلہِ أسۍ اکہِ آیت چہِ جایہِ بیاکھ آیت چِھ نٲزِل کران تہٕ اللہ تعالیٰ چُھ بہتر زانان زِ سُہ کیا کرِ نٲزِل، پتہٕ چِھ یِم لُکھ ونان زِ توٚہۍ چِھو یہِ قرآن پانے بناوان،اصلی کتھ چھےٚ یہِ زِ یِمن منٛز چِھ اکثر لُکھ حقیقت نِشہِ ناوٲقف۔"
  16,102,"۔یِمن ؤنِو زِ یہِ چھُ رُو ح القُد سَن ٹھیک ٹھیک میٲنِس ربّ سٕندِ طر فہٕ ہَنہِ ہَنہِ نٲزِل کوٚر مُت ﴿ رُو حُ لقُدُس امِیُک لفظی تر جمہٕ چُھ پاک رُو ح  یا  پٲکیز گی ہُند رُو ح۔ تہٕ اصطلا حاً چُھ یہِ لقب حضرتِ جبر یل علیہ السّلا مس دِنہٕ آمُت ۔ یتھ جایہِ چُھ وحی اَنن وٲلِس فرشتہٕ سٕندِ ناو ہیٚنہٕ بجا ے تٔمۍ سُند لقب استعمال کرنُک مقصد سا معین امہِ حقیقت نِشہِ خبردار کرٕ نۍ زِ اَتھ کلا مس چُھ اکھ یِتُتھ رُو ح انان یُس بشر ی کمزور  یَو تہٕ نُقصو نِشہِ پاک چُھ، تہٕ بالکل امانت دٲر ی سان چُھ اللہ تعالیٰ سُند پیغام واتناوان۔﴾تاکہ ایمان انن والیٚن ہُند ایمان کرِ پۅختہٕ، تہٕ فر ماں بردارن وَنہِ زند گی ہٕندٮ۪ن معا ملاتن منٛز سیٚز وَتھ ،تہٕ تِمن دِیہِ فلا ح تہٕ سعا دتٕچ خۅ ش خبر۔"
  16,103,"۔اسہِ چُھ معلو م زِ یِم لُکھ چِھ تۅ ہیہِ متعلق ونان زِ أمِس شخصس چُھ اکھ نفر ہیٚچھنا وان تہٕ پرناوان،حالانکہ یُہُند اشارہ یس نفرس کُن چُھ تٔمۍ سٕنز زبان چھےٚ عجمی، تہٕ یہِ چھےٚ صا ف عر بی زبان۔"
  16,104,"۔حقیقت چھےٚ یہِ زِ یِم لُکھ اللہ تعالیٰ سٕندۍ آیات چِھنہٕ مانان، اللہ تعالیٰ چُھنہٕ تِمن زانٛہہ صحیح کتھہِ تام واتنُک تو فیق دِوان،تہٕ یِتھیٚن لُکن خٲطرٕ چُھ دگ تُلہٕ وُن عذا ب۔﴿اَپزِ کتھہٕ چُھنہٕ نبی صلی اللہ علیہ وسلم بناوان بلکہ﴾"
  16,105,"۔اَپُز چِھ تِم بناوان یِم اللہ تعالیٰ سٕندۍ آیات چِھنہٕ مانان ،﴿ بیاکھ تر جمہٕ ہیٚکہِ یِتہِ سپدِتھ زِ اَپُز چِھ تِم لُکھ بناوان یِم اللہ تعالیٰ سٕند ٮ۪ن آیاتن پٮ۪ٹھ ایمان چِھنہٕ انان ﴾تِمے چِھ حقیقتس منٛز اَپزِ یٲرۍ ۔"
  16,106,"۔یُس شخص ایمان اَننہٕ پتہٕ کفرکرِ، ﴿سُہ اگر﴾ مجبو ر آسہِ کر نہٕ آمُت، تہٕ دل آسہِ تٔمۍ سُند ایمانس پٮ۪ٹھ مطمعین ﴿تیٚلہِ چُھ رژٕر﴾ مگر ییٚمۍ دل چہِ رضا مندی سان کُفر قبول کوٚر، تس پٮ۪ٹھ چُھ اللہ تعالیٰ سُند غضب،تہٕ یِتھیٚن سارِنٕے لُکن خٲطرٕ چُھ بوٚڈ عذا ب۔﴿یہِ آیت چھےٚ تِمن مسلمانن متعلق یِمن پٮ۪ٹھ تَمہِ وقتہٕ سخت ظلم ٲسۍ کر نہٕ یِوان ، تہٕ نا قا بلِ برداشت تکلیف دی دی ٲسۍ کُفر س پٮ۪ٹھ یِوان مجبور کر نہٕ، تِمن چُھ وَننہٕ آمُت زِ اگر توٚہۍ کُنہِ ساعتہٕ ظُلم سٍتۍ مجبور سپدِ تھ محض زُو بچا و نہٕ خٲطرٕ کلمۂ کُفر زیٚو کٔڑِ وتہٕ دِل آسیٚو کُفرٕ کہ عقیدٕہ نِشہِ محفوظ، تیٚلہِ یِیَو معا ف کر نہٕ۔البتہ اگر دِلہٕ سٍتۍ تۅہیہِ کُفر قبول کوٚرُو،تیٚلہِ ہرگاہ دُنیا منٛزٕ توٚہۍ زُو بچٲوِو، اللہ تعالیٰ سٕندِ عذا ب نِشہِ ہیکِو نہٕ بٔچِتھ۔﴾"
  16,107,"۔یہِ چُھ امہِ موجو ب زِ تِموکٔرٲخرت کِس مقا بلس منٛز دُنیا ہٕچ زند گی پسند،تہٕ اللہ تعالیٰ سُند قٲعدٕہ چُھ زِ سُہ چُھنہٕ تِمن لُکن نجا تٕچ وَتھ ہاوان یِم تٔمۍ سٕندِ نعمتُک انکار کر ن۔"
  16,108,"۔یِم چِھ تِم لُکھ یِہند ٮ۪ن دِلن تہٕ کنن تہٕ أچھن پٮ۪ٹھ خُدا ین مۅ ہر چھےٚ لگٲوِمٕژ، یِم چِھ غفلتس منٛز ڈُبیمٕتۍ۔"
  16,109,"۔ضرور ی چُھ زِ ٲخرتس منٛز روزن یِمے لُکھ خسا رس منٛز۔﴿یہِ اِرشاد چُھ تِمن لُکن متعلق یِمو ایمانٕچ وَتھ کر یٖٹھ وُچِھتھ امہِ نِشہِ تو بہٕ اوس کور مُت، تہٕ پتہٕ ٲسۍ پننِس کٲفر تہٕ مشر ک قو مس منٛز واپس گٔمٕتۍ﴾"
  16,110,"۔اتھ بر عکس یِمن لُکن ہُند حال یہِ چُھ زِ ییٚلہِ ﴿ایمان اننہٕ کہ و جہِ کِنۍ﴾ تِم ستاو نہٕ آے، تِمو ترٲوۍ گھرٕ بار، ہجرت کٔرٕ کھ ، اللہ تعالیٰ سٕنزِ وَتہِ منٛز کر یکھ سختیہِ برداشت ،تہٕ صبرس ہیٚژٕ کھ کٲم، تِہِندِ خٲطرٕ چُھ یقیناً تُہُند ربّ مغفرت کر ن وول تہٕ سٮ۪ٹھاہ مہر بان۔ ع۔﴿یِمن سارِنٕے ہُند فٲصلہٕ سپدِ تمہِ دۅہ﴾"
  16,111,"۔ییٚلہِ پرٛتھ کانٛہہ نفس پننی بچا و چہِ فِکرِ منٛز لٔگِتھ آسہِ، تہٕ پرٛتھ کٲنٛسہِ یِیہِ تٔمۍ سٕندِ کرِ متِیُک بد لہٕ پوٗرٕ پٲٹھۍ دِنہٕ، تہٕ کٲنٛسہِ پٮ۪ٹھ ہیکہِ نہٕ ذرس سُمب ظُلم سپدِ تھ۔"
  16,112,"۔اللہ تعالیٰ چُھ اکہِ بستی ہٕنز مِثا ل دِوان، سۅ ٲس اَمن و اطمنا نٕچ زند گی بسر کران،تہٕ پرٛتھ طر فہٕ اوس اَتھ فرا غتہٕ سان رز ق واتان، تٔمۍ لوگ پتہٕ اللہ تعالیٰ سٕنز ن نعمتن ہُند کفران کرُن، اللہ تعالیٰ ہن ہو وپتہٕ امہِ کیٚن با شند ن تِہند ٮ۪ن کر توٗتن ہُند یہِ مزٕ ہ زِ بۅ چِھہ ہٕندۍ تہٕ خو فٕکۍ مصیبت گٔے تِمن پٮ۪ٹھ سوار۔"
  16,113,"۔تِمن نِشہِ آو تِہندِ پننہِ قو م منٛزٕ اکھ رسول مگر تِمو کوٚر تَس انکار، ٲخر کار رٔٹۍ تِم عذا بن ییٚلہِ زن تِم ظٲلِم ٲسۍسپدِمٕتۍ﴿حضرت ابن عبا س رضی اللہ عنہ سُند قو ل چُھ زِ یتھ جایہِ چُھ ناو ہیٚنہٕ ورٲے خۅد مکُک ناو مِثا لہِ رٔنگۍ پیش کر نہٕ آمُت۔اَمہِ تفسیر مُطٲبق ییٚمہِ خو فُک تہٕ بۅ چھہِ ہٕندِ مصیبتُک یتھ جایہِ ذِکر چھےٚ آمٕژ کر نہٕ،تمہِ نِشہِ چُھ مُراد سُہ قحط یُس نبی صلی اللہ علیہ وسلمن ہٕندِ بعث پتہٕ أکِس وقتس تام مکہٕ کیٚن لُکن پٮ۪ٹھ مُسلّط روٗد۔﴾"
  16,114,"۔پس اے لوٗکو ،خُدا ین یِکینژھاہ حلال تہٕ پاک رزق تۅہیہِ عطا چُھو کوٚر مُت سُہ کھیٚیِو، تہٕ اللہ تعالیٰ سٕندِ احسا نُک کٔرِ و شُکر اگر توٚہۍ پز ی تٔمۍ سٕنز بند گی کر ن وٲلۍ چِھو۔"
  16,115,"۔خُدا ین یِکینژھاہ تۅہیہِ پٮ۪ٹھ حرام چُھ کوٚر مُت سُہ چُھ مۅردار تہٕ خوٗن تہٕ خنز یر سُند ماز،بیٚیہِ سُہ جانور یس پٮ۪ٹھ اللہ تعالیٰ سٕندِ ورٲے بیٚیہِ کٲنٛسہِ ہُند ناوآسہِ ہیٚنہٕ آمُت البتہٕ اگر کانٛہہ بۅ چِھہ سٍتۍ مجبور تہٕ بے قرار سپدِتھ یِمن چیزن کھیٚیہِ ،امہِ ورٲے زِ سُہ آسہِ قا نو ن اِلہٰی چہِ خلا ف ورز ی ہُند خوٲہش مند، یا آسہِ ضرورت کہ حدٕ نِشہِ نیر نُک مُر تکب، تیٚلہِ چُھ پٔزِپٲٹھۍ اللہ تعالیٰ معا ف کر ن وول تہٕ رحم کر ن وول۔"
  16,116,"۔بیٚیہِ یہِ ، تُہٕنزٕ یِمہٕ زبا نہٕ اپزٕۍ احکام چھےٚ لگاوان روزان زِ یہِ چیز چُھ حلال تہٕ ہُہ چُھ حرام ﴿یہِ آیت چھےٚ نٔنۍ پٲٹھۍ وضا حت کران زِ خُدا یس ورٲے چُھنہٕ حلال تہٕ حرام کر نُک حق بیٚیہِ کٲنٛسہِ ۔ بیاکھ یُس تہِ شخص جٲیزُک تہٕ نا جٲیزُک فٲصلہٕ کر نُک جُرا ت کرِ سُہ کرِ پننہِ حدٕ نِشہِ تجا وُز، الّا یہِ زِ قا نو نِ الہٰی سَنَد مٲنِتھ وَنہِ تَمہِ کیو فر مانَو نِشہِ نتیجہِ کٔڑِتھ زِ فلٲنۍ چیز یا فلٲنۍ کٲم چھےٚ جٲیز تہٕ فلٲنۍ چھےٚ نا جٲیز۔خۅد مختار بٔنِتھ کانٛہہ چیز حلال یا حرام بناو نس چُھ خُدا یس پٮ۪ٹھ اَپُز تہٕ بہتان امہِ موجو ب فر ماو نہٕ آمُت زِ یُس شخص امہِ قٔسمٕکۍ احکام چُھ لگا وان ، تٔمۍ سٕنز یہِ کٲم ہیٚکہِ نہٕ دۅ یو کَتھو نِشہِ خٲلی ٲسِتھ، اکھ یہِ زِ ، یا چُھ سُہ امہِ کتھہِ ہُنددعویٰ کران زِ یتھ سُہ کتاب الہٰی کہِ سَنَدٕ نِشہِ بے نیا ز سپدِتھ جٲیز یا نا جٲیز چُھ ونان سُہ چُھ خُدا ین جٲیز یا ناجٲیز ٹھہر وومُت، یا چُھ تٔمۍ سُند دعویٰ یہِ زِ خُدا ین چُھ تحلیل و تحر یم ﴿حلال تہٕ حرام ﴾ کیو اختیارو نِشہِ دست بردار سپدِ تھ خۅد انسان پننہِ مر ضی ہُند قانو ن بنا و نہٕ خٲطرٕ آزاد تروومُت۔یِمو منٛزٕ یُس دعویٰ تہِ سُہ کرِ سُہ چُھ ضرور اَپُز تہٕ خُدا یس پٮ۪ٹھ بہتان﴾ امہِ قسمٕکۍ حکم لگٲوِتھ مَہ دِیو اَپزِ س وا ٹھ خُدا یس سٍتۍ، یِم لُکھ خُدا یس پٮ۪ٹھ اَپزۍ بہتان چِھ لگاوان ، تِم چِھنہٕ ہر گز فلا ح لبان۔"
  16,117,"۔ دُنیا ہُک عیش چُھ کینٛہہ دۅہ۔ ٲخر کار چُھ تِہندِ خٲطرٕ دگ تُلوُن عذاب۔"
  16,118,"۔تِم چیز ٲسۍ اسہِ خا ص طور یہوٗدٮ۪ن خٲطرٕ حرام کٔرِمٕتۍ، یِہٕنز ذکر ییٚمہِ برونٛہہ اسہِ تۅ ہیہِ نِش کٔر مٕژ چھےٚ، تہٕ یہِ اوس نہٕ تِمن پٮ۪ٹھ سو ن ظُلم، بلکہ اوس تِمن پنُنے ظُلم یُس تِم پانس پٮ۪ٹھ کران ٲسۍ۔"
  16,119,"۔البتہ یِمو لُکو جہا لت کِس بنیادس پٮ۪ٹھ بُرٕ کٲم کٔر، پتہٕ کوٚرُکھ تو بہٕ کٔرِ تھ پننہِ کامہِ ہُند اصلاح، تیٚلہِ چُھ یقیناً تو بہٕ تہٕ اصلا ح پتہٕ تُہُند ربّ تُہندِ خٲطرٕ مغفرت کر ن وول تہٕ سٮ۪ٹھاہ مہربان۔ع"
  16,120,"۔ حقیقت چھےٚ یہِ زِ ابرا ہیم علیہ السلام اوس  پننِس ذاتس  اندر پوٗرٕ اکھ اُمّت، اللہ تعالیٰ سٕندِ فر ما نُک مُطیع تہٕ یک سُو، سُہ اوس نہٕ زٕ ہٕنۍ مُشر ک۔"
  16,121,"۔اللہ تعالیٰ سٕنز ن نعمتن ہُند اوس شکر کر ن وول، خُدا ین کوٚر سُہ منتخب تہٕ سٔیزِ وَتھ ہٲونس۔دُنیا ہس اندر دِیُتن تس رٕژر،"
  16,122,"۔ تہٕ ٲخرتس منٛز آسہِ سُہ یقیناً صا لحینو منٛزٕ۔"
  16,123,"۔پتہٕ سوز اسہِ تۅہیہِ کُن وَحی، زِ یکسوٗ سپدِ تھ پٔکِو ابرا ہیم علیہ السلام سٕندِس طر یقس پٮ۪ٹھ، تہٕ سُہ اوس نہٕ مُشر کو منٛز۔"
  16,124,"۔روٗد سبت ،سُہ اوس اَسہِ تِمن لُکن پٮ۪ٹھ مُسلّط کوٚر مُت، یِمو تمہِ کیٚن احکامن منٛز اختلا ف کوٚر،تہٕ یقیناً کرِ تُہُند ربّ قیا مت کہ دۅ ہ تِمن در میان سارِ نٕے کتھن ہُند فٲصلہٕ، یِمن منٛز تِم اختلا ف چِھ کران روٗدِ مٕتۍ۔"
  16,125,"۔اے نبی صلی اللہ علیہ وسلم، پننِس ربّ سٕنزِ وَتہِ کُن دِیِو دعوت حکمتہٕ سان تہٕ بہتر ین نصیحتہٕ سان، تہٕ لُکن سٍتۍ کٔرِ و مُبا حثہٕ تِتھس طر یقس پٮ۪ٹھ یُس بہتر ین آسہِ ، تُہُند ربٕے چُھ بہتر زانان زِ کُس چُھ تٔمۍ سٕنزِ وَتہِ نِشہِ ڈٔلِتھ، تہٕ کُس چُھ سیٚزِ وَتہِ پٮ۪ٹھ۔تہٕ اگر توٚہۍ لُکھ بد لہٕ ہیٚیِو ، تیٚلہِ ہیٚیِو بس تِیُتُے ییٖژاہ تۅہیہِ پٮ۪ٹھ  زیادتی آسہِ کرنہٕ آمٕژ۔"
  16,126,"۔ البتہٕ اگر توٚہۍ صبر کٔرِ و، تیٚلہِ چُھ یقیناً یہِ صبر کر ن والیٚن ہٕندِ سٕے حقس منٛز بہتر۔"
  16,127,"۔اے نبی صلی اللہ علیہ وسلم،صبرٕ سان روٗزِ و کٲم کران،تہٕ تُہُند یہِ صبر چُھ اللہ تعالیٰ سٕندِی تو فیق سٍتۍ، یِمن لُکن ہٕندٮ۪ن حر کا تن پٮ۪ٹھ مَہ کٔرِو غم، تہٕ نہ مَہ گٔژِھنو یِہزن چال ہٲزِ ین پٮ۪ٹھ دِل تنگ۔"
  16,128,"۔  اللہ تعالیٰ چُھ تِمن لُکن سٍتۍ یِم تقو یٰ ہس چِھ کٲم ہیٚوان، بیٚیہِ چِھ احسا نس پٮ۪ٹھ عمل کران۔ع۔"
