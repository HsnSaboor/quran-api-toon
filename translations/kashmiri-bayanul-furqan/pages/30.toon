quran[60]{c,v,t}:
  30,1,"۔ ا۔ل۔م۔"
  30,2,"۔ رُو می چِھ نز دیک کِس زمینس اندر مغلو ب سپٕد مٕتۍ،"
  30,3,"۔تہٕ پننہِ امہِ مغلو بیت پتہٕ گژھن تِم کینژھن ؤرِ ین منٛز غٲلب۔ ﴿ یہِ اشارٕہ چُھ تتھ لڑا یہِ کُن یۅسہٕ تتھ زمانس منٛز رُو م تہٕ ایران چن سلطنتن در میان چلا ن ٲس۔تمہِ وقتہٕ اوس رُو مِیَو وُلٹہٕ پٲٹھۍ شکست کھیٚومُت، تہٕ کانٛہہ ہیٚکہِ ہے نہٕ خیا لٕے کٔرِ تھ زِ وۅ نۍ کیا ہیٚکن یِم بیٚیہِ تھوٚدؤتِتھ۔مگر اللہ تعالیٰ چُھ یتھ آیتس منٛز یہِ پیشن گو یی فر ماوان زِ کینژھن ؤرِ ین منٛز یِن رومی بیٚیہِ غٲلب﴾"
  30,4,"۔ اللہ تعالیٰ سُندُے اختیار چُھ، گۅڈٕ تہِ تہٕ پتہٕ تہِ ۔ تہٕ سُہ دۅ ہ آسہِ سُہ ، ییٚلہِ اللہ تعالیٰ سٕندِس بخشنہٕ آمتِس فتحس پٮ۪ٹھ مُسلمان خو شیہِ منا ون۔﴿ یہِ ٲس بیا کھ اکھ پیشن گو یی۔ امُیک معنی آو تمہِ وقتہٕ لُکن سمجھ، ییٚلہِ جنگِ بدرس منٛز یپٲرۍ مُسلمانن فتح سپٕز ، تہٕ ہۅ پٲرۍ سپٕدۍ رُو م تہٕ ایران کِس جنگس منٛز رُو می غٲلب﴾"
  30,5,"۔اللہ تعالیٰ چُھ نصر ت عطا فر ماوان یَس کٲنٛسہِ یژھان چُھ، بیٚیہِ چُھ سُہ زبردست تہٕ رحیم۔"
  30,6,"۔یہِ وعدہ چُھ خُدا ین کوٚر مُت ، خُدا ے چُھنہٕ زانٛہہ پننِس وعدس خلا ف ورز ی کران، مگر اکثر لُکھ چِھنہٕ زانان۔"
  30,7,"۔لُکھ چِھ دُنیا چہِ زند گی ہُند صرف ظٲہر ی پہلو زانان تہٕ ٲخرت نِشہِ چِھ تِم پانہٕ غٲفل، کیا تِمو کوٚر نا زانٛہہ پننِس پا نس پٮ۪ٹھ غور و فکر؟"
  30,8,"۔خُدا ین چِھ زمین تہٕ آسما ن تہٕ تِم سٲر ی چیز یِم یِمن منٛز با گ چِھ ،بر حق تہٕ أکِس مقرر وقتس خٲطرٕ پٲدٕ کٔرِ مٕتۍ۔  مگر واریاہ لُکھ چِھ  پننِس ربّ سٕندِ ملا قا تٕکۍ منکر۔ ﴿ یعنی اگر انسان کاینا ت کِس نظا مس غورٕ سان وُچھہِ، تیٚلہِ یِن تس زٕہ حقیقتہٕ ٹا کارٕ ہ پٲٹھۍ اَتھہِ: اکھ یہِ زِ یہِ چُھنہٕ کٲنٛسہِ گِند ن وٲلۍ سُند گِندَن تما شہِ ، بلکہ چُھ اکھ حکمتس پٮ۪ٹھ مبنی تہٕ با مقصد نظا م۔ دوم یہِ زِ یہِ چُھنہٕ از لی تہٕ ابد ی نظا م، بلکہ چُھ اکہِ وقتہٕ لازِ ماً اتھ ختم سپدُن۔ یِمہٕ دۅ شو ے کتھہٕ چھےٚ ٲخرتس پٮ۪ٹھ دلا لت کران ، مگر لُکھ چِھ یہِ سورُے وُچِھتھ تہِ اَتھ انکار کرا ن ﴾"
  30,9,"۔تہٕ کیا یِم لُکھ چِھنا زانٛہہ زمینس منٛز پھیٖرِ مٕتۍ تھوٗرِ مٕتۍ، زِ یِمن یِیہِ ہے تِمن لُکن ہُند انجام  اتھہِ، یِم یِمن برونٛہہ چِھ گُز ریمٕتۍ؟ تِمن اوس یِہندِ کھۅتہٕ زیا دٕہ طا قت، تِمَو لو گ زمین رٕتۍ پٲٹھۍ ، تہٕ یہِ اوسُکھ تیوٗتاہ آباد کوٚر مُت یوٗتاہ یِمو چُھنہٕ کوٚر مُت تِمن نِشہِ آے تِہِندۍ رسول ٹا کا رٕ ہ نِشٲنیہِ ہیٚتھ۔ پتہٕ اوس نہٕ اللہ تعالیٰ تِمن پٮ۪ٹھ ظُلم کر ن وول ، مگر تِم ٲسۍ پا نے پا نس پٮ۪ٹھ ظُلم کران۔"
  30,10,"۔ٲخر کار یِمو لُکو بُرٲیِیہِ آسہٕ کرِ مژٕ،تِہُند      انجام سپُد واریاہ بُرٕ،امہِ موجو ب زِ تِمو اوس اللہ تعالیٰ سٕندٮ۪ن آیا تن بُتھ پھِیرُمُت، بیٚیہِ ٲسۍ تِمن ٹسنہٕ ژٹان۔ ع"
  30,11,"۔اللہ تعالیٰ ہٕے چُھ پیدٲیِشہِ ہُند ابتدا کران،پتہٕ کرِ سُے اَمِیُک اِعادٕہ، پتہٕ یِیِو توٚہۍ تٔسۍ کُن وا پس نِنہٕ۔"
  30,12,"۔تہٕ ییٚلہِ سُہ ساعت بر پا سپدِ،تمہِ دۅہ روزن مُجر م نا اُمید دٕیا ن ۔﴿دراصل چُھ لفظ مُبلسُو ن۔ وَرتا و نہٕ آمُت۔ ابلا س گوٚ و ما یو سی تہٕ صد مہٕ کِس بُنیا دس پٮ۪ٹھ کٲنٛسہِ شخصہٕ سُند ٚغمگین سپدُن ، رٔہِتھ گژُھن۔﴾"
  30,13,"۔تِہند یٚو ٹھہر او نہٕ آمتیٚو شر یکو منٛزٕ آسہِ نہٕ کٕہنۍ تِہُند سفٲرش در ، تہٕ تِم کر ن پننیٚن شر یکن انکار۔ ﴿ یعنی تمہِ وقتہٕ کر ن یِم مُشر ک خۅد امہِ کتھہِ ہُند اقرار زِ أسۍ ٲسۍ یِم خُدا ے سٕندۍ شر یک ٹھہر اونس منٛز غلطی پٮ۪ٹھ ۔﴾"
  30,14,"۔ییٚمہِ دۅہ سُہ ساعت بر پا سپدِ، تمہِ دۅہ گژھن ﴿سٲری انسان﴾ الگ جمٲعژن منٛز تقسیم۔"
  30,15,"۔یِمو لُکو ایمان چُھ اوٚ نمُت تہٕ یِمو نیک عملہٕ چھےٚ  کرِ مژٕ، تِم یِن أکِس با غس منٛز شاداں تہٕ فر حاں ﴿ خۅشحا ل ﴾ تھاو نہٕ،"
  30,16,"۔تہٕ یِمو لُکو کُفر چُھ کوٚر مُت، بیٚیہِ چِھکھ سٲنۍ آیا ت تہٕ ٲخرتُک ملا قات اَپُز زو نمُت، تِم یِن عذا بس منٛز ﴿ گرفتار کٔرِ تھ ﴾ حٲضر تھا و نہٕ ۔"
  30,17,"۔لہٰذا کٔرِو تسبیح اللہ تعالیٰ سٕنز ییٚلہِ توٚہۍ شا م چِھو کرا ن تہٕ ییٚلہِ صبح چِھو کرا ن۔ آسما نن تہٕ زمینس منٛز چُھ تٔمۍ سٕندۍ خٲطرٕ حمد،"
  30,18,"۔تہٕ ﴿ تسبیح کٔرِ و تٔمۍ سٕنز ﴾ تر ییٚمہِ پہرٕ ، بیٚیہِ ییٚلہِ تۅہیہِ پٮ۪ٹھ ظُہرک وقت چُھ واتان۔﴿یتھ آیتس منٛز چُھ نمازِ ہٕندٮ۪ن ژۅن وقتن کُن صا ف اشارٕہ، فجر ، مغر ب، عصر ،ظُہر۔ یتھ سٍتۍ اگر سورۂ ہوٗد آیت  114، سورۂ بنی اسرا یل ، آیت 78 تہٕ سورۂ طٰہٰ ، آیت 130، پر نہٕ یِیہِ ، تیٚلہِ چُھ نمازِ ہٕندٮ۪ن پا نژو نٕے وقتن ہُند حُکم نیران ۔ ﴾"
  30,19,"۔سُہ چُھ زِ ندس مۅردس نِشہِ کڑا ن، تہٕ مۅردس چُھ زِ ندس نِشہِ کٔڑِتھ اَنان ، تہٕ زمینس چُھ تَمہِ کہ موت پتہٕ زند گی بخشا ن۔یِتھے پٲٹھۍ یِیِو توٚہۍ لُکھ تہِ ﴿ موت کہ حالت منٛزٕ ﴾ کٔڑِتھ اَننہٕ ۔ ع"
  30,20,"۔تٔمۍ سٕنز و نِشٲنِیَو منٛزٕ چُھ یہِ زِ تٔمۍ کٔرِ نَو توٚہۍ میٚژِ نِشہِ پٲدٕ ۔ پتہٕ چِھو توٚہۍ یکا یک بشر زِ ﴿ زمینس منٛز ﴾ چِھو پھٔہلان پکا ن۔"
  30,21,"۔تٔمۍ سٕنز و نشٲنِیو منٛزٕ چُھ یہِ زِ تٔمۍ بنا و تُہندِ خٲطرٕ تُہٕندی جنسہٕ منٛزٕ خا ندارِ نہِ ،تاکہ توٚہۍ کٔرِو تِمن نِشہِ سکو ن حٲصل،تہٕ تۅہیہِ منٛز با گ کوٚ رُن محبت تہٕ رحمت پٲدٕ۔ یقیناً چھےٚ اَتھ منٛز واریاہ نِشٲنِیہ تِمن لُکن خٲطرٕ یِم غو ر وفکر چِھ کران۔"
  30,22,"۔تہٕ تٔمۍ سٕنز و نِشٲنِیَو منٛزٕ چھےٚ آسمانن ہٕنٛز تہٕ زمینٕچ پیدٲیش، تہٕ تُہنز ن زبا نن تہٕ تُہٕندٮ۪ن رنگن ہُند اختلا ف۔یقیناً چھےٚ اتھ منٛز واریاہ نِشٲنِیہِ دا نش مند لُکن خٲطرٕ۔"
  30,23,"۔تہٕ تٔمۍ سٕنز ونشٲنِیَو منٛزٕ چُھ تُہندراتس تہٕ دۅ ہس شۅ نگُن، تہٕ تُہُند تٔمۍ سُند فضل تلا ش کرُن۔یقیناً چھےٚ اتھ  منٛزواریاہ نِشٲنیہِ تِمن لُکن خٲطرٕ یِم ﴿غورٕ سان ﴾ بوزان چِھ۔"
  30,24,"۔تہٕ تٔمۍ سٕنز و نِشٲنیو منٛزٕ چُھ یہِ زِ سُہ چُھو تۅہیہِ وُز ملہِ ہٕنز چمک ہا وان خو فہٕ سان تہِ تہٕ طمع سان تہِ۔ تہٕ آسما نہٕ چُھ آب ترا وان، پتہٕ چُھ امہِ کہ ذر یعہ موٗدِ مٕتِس زمینس زند گی بخشا ن۔ یقیناً چھےٚ اتھ منٛز واریاہ نِشٲنیہِ تِمن لُکن خٲطرٕ یِم عقلہِ چِھ کٲم ہیٚوان۔"
  30,25,"۔تہٕ تٔمۍ سٕنز و نِشٲنِیو منٛزٕ چُھ یہِ زِ آسمان تہٕ زمین چھےٚ تٔمۍ سٕندِ حُکمہٕ سٍتۍ قٲیِم ۔ پتہٕ یُتُھے تٔمۍ تۅہیہِ زمینہٕ پٮ۪ٹھہٕ ناد لو ے ، بس أکۍ سٕے نادس پٮ۪ٹھ یِیِو توٚہۍ اچانک نِیرِ تھ۔"
  30,26,"۔آسما نن تہٕ زمینس منٛز یِم تہِ چِھ ، تِم چِھ تٔمۍ سٕندۍ بندٕہ۔سٲر ی چِھ اند ہیٚتھ تٔمۍ سٕندی فر ما نٕکۍ تا بع۔"
  30,27,"۔سُے چُھ یُس تخلیقُک ابتدا چُھ کرا ن، پتہٕ کرِ سُے امِیُک اِعا دٕہ، تہٕ یہِ چُھ تٔمۍ سٕندِ خٲطرٕ سٮ۪ٹھاہ سہل۔ آسما نن تہٕ زمینس منٛز چُھ تٔمۍ سُند صفت سارِوٕے کھۅتہٕ بر تر ، تہٕ سُہ چُھ زبردست تہٕ حکمت وول ۔ع۔"
  30,28,"۔سُہ چُھو تۅہیہِ خۅد تُہٕندی پننہِ  ذا ت نِشہِ اکھ مثال دِوان ۔کیا تُہند یو تِمو غلا مَو منٛزٕ یِم تُہندِس مِلکیتس منٛز چِھ، چھا کینٛہہ غلا م تِتھۍ تہِ ، یِم سانہِ دِ نہٕ آمتہِ مال و دولت منٛزٕ تۅہیہِ سٍتۍ برابر کۍ شر یک آسن، تہٕ توٚہۍ ٲسِو تِمن تِتھہٕ پٲٹھۍ کھۅژان یِتھہٕ پٲٹھۍ پانہِٕ وٲنۍ پا نس ہِو ٮ۪ن چِھو کھۅژان۔﴿ یہِ چُھ سُے مضمو ن یُس سورۂ نحل آیت 71، تھس منٛز چُھ آمُت۔ دۅ شوٕ نۍ جا ین چُھ اِستدا لال یہِ زِ ییٚلہِ توٚہۍ پننِس مالس منٛز پننٕۍ غلا م چھوٗکھ نہٕ شر یک کرا ن ، تیٚلہِ کِتھہٕ پٲٹھۍ چَھو تۅہیہِ یہِ کتھ فِکرِ ترا ن زِ خُدا ے کرِ پننہِ خُدٲیی منٛز پننیٚن بند ن شر یک ؟ ﴾ یِتھہٕ پٲٹھۍ چِھ  أسۍ آیا ت کران کھوٗلِتھ پیش تِمن لُکن خٲطرٕ یِم عقلہِ چِھ کٲم ہیٚوان۔"
  30,29,"۔مگر یِم ظٲلِم چِھ سو نچنہٕ سمجھنہٕ وراے پننیٚن تخیلا تن ﴿ خو اہشاتن﴾ پتہٕ لِگمٕتۍ۔ وۅ نۍ کُس ہیٚکہِ تس شخصس وَتھ ہٲوِ تھ یُس خُدا ین آسہِ ڈو لمُت؟ یِتھیٚن لُکن ہیٚکہِ نہٕ کانٛہہ مدد گار ٲسِتھ۔"
  30,30,"۔لہٰذا ﴿ اے نبی صلی اللہ علیہ وسلم ، تہٕ نبی صلی اللہ علیہ وسلمن ہٕندیٚو پیروکارو﴾ یک سُو سپدِ تھ جمٲوِو پنُن رۅ خ یتھ دینس کُن،قٲیِم سپدِ و تتھ فطر تس پٮ۪ٹھ یَتھ پٮ۪ٹھ خُدا ین انسان چِھ پٲدٕ کٔرِ مٕتۍ، اللہ تعالیٰ سٕنز بنا و نہٕ آمٕژ سا خت ہیٚکہِ نہٕ بد لا و نہٕ یِتھ ﴿ یعنی خُدا ین چُھ انسان پنُن بندٕہ بنو و مُت تہٕ صرف چُھن پننی بند گی خٲطرٕ پٲدٕ کوٚر مُت۔ یہِ سا خت ہیٚکہِ نہٕ کٲنٛسہِ ہٕندِ بدلاو نہٕ سٍتۍ بدلِتھ۔ نہٕ ہیٚکہِ انسان بند ہ آسنہٕ نِشہِ غیر بندٕہ بٔنِتھ، نہ ہیٚکہِ کٲنٛسہِ غیر اللہ ہس اللہ بنا و نہٕ سٍتۍ سُہ حقیقتس منٛز تٔمۍ سُند اللہ بٔنِتھ۔ انسان بنٲوِ تن خوا ہ پا نس کٲتیا ہ تہِ معبود ، مگر یہِ حقیقت چھےٚ پننہِ جا یہِ اٹل زِ سُہ چھُنہٕ أکِس خُدا یس ورٲے بیٚیہِ کٲنٛسہِ ہُند بندٕہ۔ دوٚ یُم تر جمہٕ ہیٚکہِ امہِ آیتُک یِتہِ سپدِتھ زِ  اللہ تعالیٰ سٕندِس بنا و نہٕ آمتِس سا ختس گژِھہ نہٕ تبد یلی یِنۍ کر نہٕ  یعنی  یتھ فطرتس پٮ۪ٹھ  خُداین انسان چُھ پٲدٕ کوٚر مُت، سۅ بِگاڑٕ نۍ تہٕ مسخ کرٕ نۍ چُھنہٕ درست﴾ یۅہے چُھ بالکل سیوٚد تہٕ درست دین،مگر اکثر لُکھ چِھنہٕ زانان۔"
  30,31,"۔﴿قٲیِم سپدِ و اَتھ کتھہِ پٮ۪ٹھ ﴾ خُدا یس کُن رجوع کرا ن کران، تہٕ  کھوٚژِ و تَس ،تہٕ نمازٕ کٔرِ و قٲیِم ، بیٚیہِ مَہ سپدِ و تِمو مشر کو منٛزٕ یِمَوپنُن پنُن دین الگ چُھ بنو و مُت، تہٕ گروہن منٛز چِھ تقسیم گٔمٕتۍ"
  30,32,"۔پرٛتھ أکِس گروہس نِشہِ یِکینژھاہ چُھ سُہ چُھ تٔتھۍ منٛز آوُر ﴿خۅ ش ﴾ ۔"
  30,33,"۔  لُکن ہُند حال چُھ یہِ زِ ییٚلہِ یِمن کانٛہہ تکلیف واتان چُھ ،تیٚلہِ چِھ پننِس ربّس کُن رجو ع کٔرِ تھ تس ناد لایان،پتہٕ ییٚلہِ سُہ پننہِ رحمتُک ذٲیقہٕ یِمن وُچھنا وان چُھ، تیٚلہِ چِھ یکا یک یِمو منٛزٕ کینٛہہ لُکھ شر ک لاگان کرُن،"
  30,34,"۔تاکہ سٲنِس کٔرِ مٕتِس احسا نس کر ن نا شُکر ی۔ اچھا ، کٔرِو مزٕہ ،عن قر یب لگیو تۅہیہِ پے۔"
  30,35,"۔ کیا اَسہِ چھا کانٛہہ سَند تہٕ دلیل یِمن پٮ۪ٹھ نٲزِل کٔر مٕژ، یۅسہٕ شہا دت آسہِ دِوان تمہِ شر ک کِس شہا دتس پٮ۪ٹھ یُس یِم کرا ن چِھ ؟"
  30,36,"۔ییٚلہِ أسۍ لُکن رحمتُک ذٲیقہٕ وُچھنا وان چھِ، تیٚلہِ چُھ تِمن اتھ پٮ۪ٹھ بو ش کھسا ن۔ تہٕ ییٚلہِ یِہند یٚو پننیو کٔرِ مٕتیو کر توٗ تَو سٍتۍ یِمن پٮ۪ٹھ کانٛہہ مُصیبت چُھ یِوان، تیٚلہِ چِھ اچا نک ما یو س گژھنہِ لگا ن۔"
  30,37,"۔ کیا یِم لُکھ چِھنا وُچھا ن زِ اللہ تعالیٰ ہٕے چُھ رزق کُشا دٕہ کرا ن  یس یژھان چُھ تَس ، تہٕ تنگ چُھ کران ﴿ یس یژھان چُھ تَس ﴾؟  یقیناً چھےٚ اَتھ منٛز واریاہ نِشٲنیہِ تِمن لُکن خٲطرٕ یِم ایمان چِھ انان ۔"
  30,38,"۔لہٰذا ﴿ اے مو منا ﴾ رشتہٕ دارس دِ تٔمۍ سُند حق، تہٕ مسکینس تہٕ مُسا فر س ﴿ تٔمۍ سُند ﴾ ۔﴿ یہِ چُھنہٕ آمُت فر ماو نہٕ زِ رشتہٕ دارس ، مسکینس تہٕ مُسا فرس دِ خیرا ت۔ارشاد چُھ یہِ سپُد مُت زِ یہِ چُھ تٔمۍ سُند حق یُس ژےٚ دِیُن پٔزی، تہٕ حق زٲنِتھٕے دِ تٔمِس﴾ یہِ طر یقہٕ چُھ بہتر تِمن لُکن خٲطرٕ یِم اللہ تعالیٰ سٕنز خۅ شنودی چِھ یژھان ، تہٕ تِمے چِھ فلا ح لبن وٲلۍ۔"
  30,39,"۔ یُس سوٗد توٚہۍ دِوان چِھو، تا کہِ لُکن ہٕندٮ۪ن مالن منٛز رٔلِتھ گژِھہ تَتھ اِضا فہٕ، خُدا یس نز دیک چُھنہٕ تَتھ اِضا فہٕ گژھان۔ ﴿ قرآن مجیدس منٛز چھےٚ یہِ گۅڈنِچ آیت یۅسہٕ سوٗد کِس مذّمتس منٛز نٲزِل سپٕز۔یِم پتہٕ احکام چِھ ، تِمَو خٲطرٕ وُچِھو آلِ عمرا ن آیت 130 / البقر ہ آیات 275/پٮ۪ٹھہٕ 281﴾ تہٕ یۅسہٕ  زکوٰتہ توٚہۍ اللہ تعالیٰ سٕنز خۅ شنو دی حٲصل کر نہٕ کہ ارادٕہ دِوان چِھو، امہِ کی  دِنہٕ وٲلۍ چِھ در حقیقت پنٕنۍ مال ہُرراوان۔"
  30,40,"۔اللہ تعالیٰ ہٕے چُھ ییٚمۍ توٚہۍ پٲدٕ کٔرِنو، پتہٕ دُیتنَو تۅہیہِ رزِق، پتہٕ چُھو سُہ تۅہیہِ مو ت دِوان، پتہٕ کر یٚو سُہ تۅہیہِ زندہ۔ کیا تُہند یٚو ٹھہراونہٕ  آمتیٚو شر یکو مںٛزٕ  چھا کانٛہہ تِیُتھ ، یُس یِمو  منٛزٕ کانٛہہ تہِ کٲم آسہِ کران؟ پاک چُھ سُہ بیٚیہِ چُھ سٮ۪ٹھاہ بالا وبرتر تمہِ شر ک نِشہِ یُس یِم کرا ن چِھ ۔ع۔"
  30,41,"۔خشکی تہٕ ٲبی منٛز چُھ فساد برپا سپُد مُت، لُکن ہٕند یو پننیو اَتھو ہٕنزِ کما یہِ سٍتۍ﴿ یہِ اشارہ چُھ تتھ جنگس کُن یُس تمہِ وقتہٕ دُنیا کیٚن دۅ ن عظیم طا قتن یعنی رُوسس تہٕ ایرانس در میان بر پا اوس﴾ تاکہ ذٲیقہٕ وُچھنا وِ تِمن تِہنزن کینژھن عملن ہُند، بنان چُھ زِ تِم یِن با ز۔"
  30,42,"۔﴿ اے نبی صلی اللہ علیہ وسلم ﴾ یِمن ؤنِو زِ زمینس منٛز پھیٖرِ و تھوٗ رو ، پتہٕ وُچِھو گۅڈنِکیٚن گُزر یمتیٚن لُکن ہُند کیا انجام چُھ سپُد مُت ؟ تِمو  منٛزٕ ٲسۍ اکثر مُشرِ کٕے۔"
  30,43,"۔لہٰذا ﴿ اے نبی صلی اللہ علیہ وسلم﴾ پنُن رۅ خ جمٲوِ و مضبو طی سان یتھ دینِ راست کِس طر فس منٛز، امہِ برونٛہہ زِ سُہ دۅ ہ واتہِ ییٚمہِ کہ ٹلنٕچ کانٛہہ صورت اللہ تعالیٰ سٕندِ طر فہٕ چَھنہٕ۔ تمہِ دۅہ گژھن لُکھ اکھ أکِس نِشہِ الگ۔"
  30,44,"۔ییٚمۍ کُفر چُھ کوٚر مُت ،تٔمۍ سٕندِ کُفر ک وبا ل چُھ تٔمۍ سٕے پٮ۪ٹھ، تہٕ یِمو لُکو نیک عمل چھےٚ کٔر مٕژ، تِم چِھ پننی خٲطرٕ ﴿کا میٲبی ہٕنز وَتھ ﴾ صا ف کرا ن،"
  30,45,"۔تا کہ اللہ تعالیٰ دِیہِ ایمان انَن وا لیٚن تہٕ صا لح عملہٕ کر ن والیٚن پننہِ فضل سٍتۍ جزا۔یقیناً چُھنہٕ سُہ کٲفر ن پسند کرا ن۔"
  30,46,"۔ تٔمۍ سٕنز و نِشٲنِیو منٛزٕ چُھ یہِ زِ سُہ چُھ ہوا سوزان بشا رت دِنہٕ خٲطرٕ، تہٕ  تۅہیہِ پننہِ رحمتُک  مزٕ ہ وُچھناونہٕ خٲطرٕ، تہٕ امہِ غر ض خٲطرٕ زِ نا وٕ پکن تٔمۍ سٕندِ حُکمہٕ سٍتۍ،تہٕ توٚہۍ کٔرِو تٔمۍ سُند فضل تلا ش، تہٕ تٔمۍ سٕندۍ شکر گزار بٔنِو۔"
  30,47,"۔تہٕ اسہِ سوٗز ۍ تۅہیہِ برونٹھِم رسول تِہند ٮ۪ن قو من کُن، تہٕ تِم آے تِمن نِشہِ ٹا کارٕہ نِشٲنِیہِ ہیٚتھ۔ پتہٕ یِمو جُر م کوٚر ،تِمن ہیوٚت اسہِ انتقام،تہٕ اسہِ پٮ۪ٹھ اوس حق زِ أسۍکر ہَو مو منن مدد۔"
  30,48,"۔اللہ تعالیٰ ہٕے چُھ یُس ہوا ہن چُھ سوزان، تہٕ تِم چھِ اوبُر تُلان ،پتہٕ چُھ سُہ یِمن اُوبَر ن آسمانس منٛز پھٔہلاوان یِتھہٕ پٲٹھۍ یژھان چُھ تِتھہٕ پٲٹھۍ، تہٕ یِمن چُھ حصّن منٛز تقسیم کران، پتہٕ چِھو توٚہۍ وُچھان زِ روٗدٕ قطرٕہ چِھ اوٚ برٕ منٛزٕ نیٖرِ تھ پشپا ن یِوان۔ یہِ روٗد ییٚلہِ سُہ تراوان چُھ، پننیٚن بند ن یِمن پٮ۪ٹھ یژھان چُھ، تِم چھِ اچا نک خو ش و خُر م سپدان،"
  30,49,"۔حالانکہ امہِ کہ پیٚنہٕ برونٛہہ ٲسۍ تِم مایو س ہیٚتۍمٕتۍ گژٕھنۍ۔وُچِھو اللہ تعالیٰ سٕندِ رحمتٕکۍ اثرات زِ مۅردٕہ پیٚمتِس زمینس  کِتھہٕ پٲٹھۍ چُھ سُہ زِندٕہ کران،"
  30,50,"۔ یقیناً چُھ سُہ مۅ ردن زند گی بخشن وول، تہٕ سُہ  چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  30,51,"۔تہٕ اگر أسۍ تیُتھ اکھ ہوا سوزَو ییٚمہِ کہ اثرٕ سٍتۍ تِم پنُن زراعت لیٚدرِ یا مُت وُچھن،تیٚلہِ چِھ تِم کُفر کران روزان۔ ﴿ یعنی پتہٕ چِھ تِم خُدا یس وۅ ہ وۅ ہ کرا ن تہٕ تس چِھ لاگان الزام کھا لٕنۍ زِ تٔمۍ کِتھۍ مصیبت چِھ اسہِ پٮ۪ٹھ ترٲوِ مٕتۍ ، حالانکہ  ییٚلہِ خُدا ین تِمن پٮ۪ٹھ  نعمتٕچ بٲرش ٲس کٔر مٕژ، تمہِ وقتہٕ ٲس تِمو شکرٕ بجا ے اَمِچ بے قدر ی کٔر مٕژ﴾۔"
  30,52,"۔﴿ اے نبی صلی اللہ علیہ وسلم ﴾ توٚہۍ ہیٚکِیوٗ کھ نہٕ مۅردٕہ بوز نٲوِ تھ،﴿یعنی تِمن لُکن یِہِندۍ ضمیر موٗدِمٕتۍ چھِ﴾نَہ ہیکِیوٗکھ تِٕ زٔرۍ پنٕنۍ آلو بوزنٲوِتھ یِم پوٚت پھیٖرِ تھ آسن ژلان،"
  30,53,"۔ تہٕ نہ ہیٚکِو توٚہۍ تِمن گُمرٲہی منٛزٕ کٔڑِتھ سِٔیٚز وَتھ ہٲوِ تھ۔توٚہۍ ہیکِیوٗکھ صرف تِمے بو زنٲوِ تھ، یِم سا نیٚن آیا تن پٮ۪ٹھ ایمان چِھ انان، بیٚیہِ چِھ تسلیم کرا ن ۔ ع"
  30,54,"۔اللہ تعالیٰ ہٕے چُھ ییٚمۍ کمزوٗری ہٕندِس حا لتس منٛز تُہٕنزِ پیدٲشہِ ہُندابتدا کوٚر ، پتہٕ کٔرنَو کمزوٗری پتہٕ تۅہیہِ قُوّت عطا، پتہٕ کٔرۍ نَو توٚہۍ امہِ قُوّت پتہٕ ضعیف تہٕ بُڑٕ ،سُہ یِکینژھاہ یژھان چُھ تہِ چُھ تہِ چُھ پٲدٕ کران۔ تہٕ سُہ چُھ سورُے زانن وول، پرٛتھ چیز س پٮ۪ٹھ قدرت تھاون وول۔"
  30,55,"۔ تہٕ ییٚلہِ سُہ ساعت بر پا سپدِ۔﴿ یعنی قیامت ییٚمہِ کہ ینٕچ خبر چھےٚ دِنہٕ یِوان ﴾ مُجر م ونَن قسم ہٲوۍ ہٲوۍ زِ أسۍ چِھنہٕ اکہِ گھرِ کھۅتہٕ زیادہ ٹھہر یمٕتۍ، یِتھے پٲٹھۍ ٲسۍ تِم دُنیا چہِ زند گی منٛز دۅ کھہٕ کھیٚوان۔"
  30,56,"۔ مگر یِم علمہٕ تہٕ ایمان سٍتۍ نوازنہٕ ٲسۍ آمٕتۍ تِم ونَن  زِ، اللہ  تعالیٰ سٕندِس نوِ شتس منٛز چِھو توٚہۍ روزِ حشرس تام پیٚتھ روٗدٕ مٕتۍ، لہٰذا چُھ یہِ سُے روزِ حشر، مگر توٚہۍ ٲسِو نہٕ زانان۔"
  30,57,"۔لہٰذا آسہِ سُہ دۅہ یتھ  منٛز ظٲلِمن تِہنز معذرت کانٛہہ نفع دِیہِ نہٕ، نہ یِیہِ تِمن معٲفی منگنہٕ خٲطرٕ وَننہٕ ۔ ﴿ دویُم تر جمہٕ ہیٚکہِ یِتہِ سپدِ تھ  نہ یِیہِ تِمن نِشہِ یہِ یژھنہٕ زِ پنُن ربّ کٔرِ یوٗن رٲضۍ۔﴾"
  30,58,"۔ اسہِ چِھ یتھ قرآنس منٛز لُکھ رنگہٕ رنگہٕ سمجھٲوِ مٕتۍ۔ توٚہۍ أنۍ تَو خواہ کانٛہہ نِشٲنی، یِمو لُکو ماننہٕ نِشہِ انکار چُھ کوٚر مُت تِم ونن یی زِ توٚہۍ چِھو بٲطلس پٮ۪ٹھ۔"
  30,59,"۔ یِتھہٕ پٲٹھۍ چُھ ٹھپّہ لگا وان اللہ تعالیٰ تِمن لُکن ہٕندٮ۪ن دِلن پٮ۪ٹھ یِم بے علم چِھ۔"
  30,60,"۔لہٰذا ﴿ اے نبی صلی اللہ علیہ وسلم ﴾ صبر کٔرِو، یقیناً چُھ اللہ تعالیٰ  سُند وعدہ پوٚز، تہٕ ہر گز گژھنَو نہٕ لوٚ تۍ لبٕنۍ تۅہیہِ تِم لُکھ، یِم یقین چِھنہٕ کران۔ع﴿ یعنی دشمن گژھنو نہٕ تۅہیہِ تِتھۍ کمز ور سمجھنۍ زِ تِہندِ شو ر و غو غا سٍتۍ کیا دٔبِو توٚہۍ ، یا گٔژِھو تِہند یٚو بہتا نو تہٕ پانے بناو نہٕ آمژن کتھن ہٕنزِ مُہمہِ سٍتۍ مر عو ب یا سپدِ و توٚہۍ تِہنز و پا مَو  تہٕ طعنو ٹسنَو سٍتۍ پست ہمت، یا کھوٚژِو تِہنز ن دھمکین تہٕ طا قت کیٚن مُظٲہر ن تہٕ ظُلم و سِتمس ،یا پھِسلِو توٚہۍ تِہنز و دِنہٕ آمژو لا لچو سٍتۍ۔"
