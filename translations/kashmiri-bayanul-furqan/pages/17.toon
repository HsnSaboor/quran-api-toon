quran[111]{c,v,t}:
  17,1,"۔پاک چُھ سُہ ییٚمۍ نِیوٗ اکہِ رٲژ پنُن بندٕ ہ مسجدِحرام پٮ۪ٹھہٕ تتھ  مسجدِ اقصٰی ہَس تام ، ییٚمہِ کِس ما حو لس تٔمۍ بر کت چھےٚ دِژمٕژ، تا کہ تس کر ناوِ پننیٚن کینژھن نشٲنین ہُند مُشٲہدٕ ہ ۔ ﴿ یہِ وا قعہ چُھ سُے یُس اصطلا حاًمعر اج  کہ ناوٕ مشہو ر چُہ۔ اکثر معتبر روایتو کِنۍ چُھ یہِ واقعہ ہجر ت برونٛہہ اکھ ؤر ی پیش آمُت۔حد یث تہٕ سیر ت چن کتا بن منٛز چُھ امہِ وا قعُک تفصیل وارہَو صحا بو رضی اللہ عنہم روایت کوٚر مُت یُہُند تعداد پٕنژ ہن ﴿25﴾ تام چُھ واتان ۔ قرآن مجید چُھ صرف مسجدِ حرام﴿ یعنی بیت اللہ﴾ پٮ۪ٹھہٕ مسجدِ اقصٰی ﴿بیت المقدس﴾ تام حضور صلی اللہ علیہ وسلمن ہٕندِ تشر یف اَننٕچ تصر یح کران تہِٕ احا دیثن منٛز چھےٚ بیتُ المقدس  پٮ۪ٹھہٕ عا لِم با لاچہِ انتہٲیی بُلندی تام اللہ تعالیٰ سٕندِس در بارس منٛز حضور صلی اللہ علیہ وسلمن ہٕنزِ حٲضر ی ہٕنز مُفصل ذِکر کر نہٕ آمٕژ۔ امہِ سفرٕ چ کیفیت کیا ٲس؟یہِ اوسا خوا ب کِس عا لمس منٛز پیش آمُت کِنہٕ بیدٲری منٛز؟ تہٕ حضورصلی اللہ علیہ وسلمو اوسا بذا تِ خۅد تشر یف نِیو مُت یا پننہِ جایہِ روزِ تھٕے ٲسۍ تِم محض روٗحٲنی طور مُشٲہدہ کر ناو نہٕ آمٕتۍ؟ یِمن سوالن ہُند جوا ب چِھ قرآن مجید کۍ الفا ظ پانہٕ دِوان۔ پاک چُھ سُہ ییٚمۍ نِیو  یِمو لفظو سٍتۍ  ابتدا کرُن چُھ ہاوان زِ یہِ اوس سٮ۪ٹھاہ بوٚڈ تہٕ تھدِ پا یُک وا قعہٕ یُس اللہ تعالیٰ سٕندِ زبردست قدرت سٍتۍ پیش آو ۔ یہِ کتھ چھےٚ ٹا کارٕ زِ خوا بس منز کٲنٛسہِ شخصہٕ سُند امہِ قسمٕکۍ چیز و وُچِھنۍ ،یا بطو ر کشف وُچُھن چُھنہٕ یہِ اہمیت تھاوان زِ یہِ بیان کر نہٕ خٲطرٕ آسہِ امہِ تمہیدٕ چ ضرورت زِ تمام کمزوٗر یَو تہٕ نُقصو نِشہِ چھےٚ پاک سۅ ذات، ییٚمۍ پننِس بند س یہِ خوا ب ہو و یا کشفس منٛز ہو و نس یہِ سورُے ۔پتہٕ یِم الفا ظ تہِ زِ  اکہِ رٲژنیو ن پنُن بندٕہ چِھ جسمٲنی سفرس پٮ۪ٹھ ٹاکارٕ دلا لت کران ۔ خوا ب کِس سفرس یا کشفی سفر س خٲطرٕ ہیکن نہٕ یِم الفا ظ کُنہِ پٲٹھۍ تہِ مُنٲسب ٲسِتھ ۔لہٰذا چُھنہٕ سانہِ خٲطرٕ یہِ ماننہٕ ورٲے چا رے زِ یہِ اوس نہٕ محض اکھ روٗحٲنی تجر بہٕ بلکہ اوس اکھ جسمٲنی سفر تہٕ عینی مُشاہدہ یُس نبی کر یم صلی اللہ علیہ وسلم خُدا ین کر نٲوۍ﴾ در حقیقت چُھ سُے سورُے کینٛہہ بوزن وول تہٕ وُچھن وول ۔"
  17,2,"۔اَسہِ ٲس ییٚمہِ برونٛہہ مو سیٰ ﴿ علیہ السلامس﴾ کتا ب دِژ مٕژ، تہٕ سۅ ٲس بنی اسرا یل خٲطرٕ ہدا یتُک ذر یعہِ بنٲومٕژ۔امہِ تٲکیدٕ سان زِ میانہِ ورٲے بنٲوِ زِیو ن نہٕ کانٛہہ پنُن وکیل۔﴿ یعنی اعتمادُک تہٕ بھروسُک دارمدار، یس پٮ۪ٹھ تو کل یِیہِ کر نہٕ، یس پنٕنۍ معاملات یِن حوالہٕ کر نہٕ یَس کُن ہدا یت تہٕ امدادٕ خٲطرٕ رجوع یِیہِ کر نہٕ ﴾"
  17,3,"۔توٚہۍ چِھو تِمن لُکن ہٕندۍ اولاد ،یِم اسہِ نو ح ﴿علیہ السلامس﴾ سٍتۍ ناوِ منٛز سوار ٲسۍ کٔرٕمٕتۍ، تہٕ نو ح ﴿علیہ السلام ﴾اوس اکھ شکر گزار بندٕ ہ۔"
  17,4,"۔پتہٕ ٲسۍ اَسہِ پننہِ کتا بہِ منٛز بنی اسرا یل خبردار کٔرِمٕتۍ ﴿ یَتھ جایہِ چُھنہٕ کتا بہِ نِشہِ مُراد تورات کینٛہہ، بلکہ چُھ مُراد صُحفِ آسمٲنی ہُند مجمو عہٕ، ییٚمہِ خٲطرٕ قرآنس منٛز اصطلا ح رٔنگۍ لفظ الکتا ب چُھ واریاہن جا ین وَر تا و نہٕ آمُت﴾زِ توٚہۍ کٔرِ و روے زمینس پٮ۪ٹھ دۅ یہِ پھِرِ بوٚڈ فساد بر پا، تہٕ سٮ۪ٹھاہ بٔڑ سر کشی ہٲوِو۔"
  17,5,"۔ٲخر کار ییٚلہِ تِمو منٛزٕ گۅڈنِچہِ سر کشی ہُند مو قع پیش آو،اے  بنی اسرا یلس ،اَسہِ تُلۍ تُہٕندِس مقا بلس پٮ۪ٹھ پنٕنۍ تِتھۍ بند ہ یِم سٮ۪ٹھاہ زور آور ٲسۍ، تہٕ تُہندِس مٕلکس منٛز أژِتھ پھٔہلییہِ تِم پرٛتھ اندٕ۔﴿امہِ نِشہِ چھےٚ مُراد سۅ ہولنا ک تبٲہی یۅسہِٕ آشوٗر یٚو تہٕ با بلن ہٕند یٚو اَتھو بنی اسرا یلس پٮ۪ٹھ نٲزِل سپٕز۔﴾یہِ اوس اکھ وعدٕہ یتھ پوٗرٕ اوس گژھنُے۔"
  17,6,"۔اَمہِ پتہٕ دِتُو اَسہِ تۅہیہِ تِمن پٮ۪ٹھ غلبُک مو قع،تہٕ تۅہیہِ دِیتُو مالَو تہٕ اولادو سٍتۍ مدد، تہٕ تُہُند تعداد ہُر روو برونٛٹھمہِ کھۅتہٕ زیادٕہ۔"
  17,7,"۔وُچِھو! تۅہیہِ کٔرٕ و نیکی، سۅ نیکی ٲس تۅہیہِ پننی خٲطرٕ، تہٕ بُرٲیی کٔرٕ و تہٕ سۅ سپٕز تۅہیہِ پننہِ ذا ت خٲطرٕ بُرٲیی ثا بت پتہٕ ییٚلہِ دوٚ یِمہِ وعدُک وقت ووت، تہٕ اسہِ کٔرۍ با قی دشمن تۅہیہِ پٮ۪ٹھ مُسلّط تا کہِ تِم بگا ڑن تُہٕندۍ بُتھۍ، تہٕ مسجدِ﴿ بیت المقدسس ﴾ منٛز اَژن تِتھے پٲٹھۍ یِتھہٕ پٲٹھۍ گۅڈنِکۍ دشمن ژامٕتۍ ٲسۍ، تہٕ یتھ چیز س پٮ۪ٹھ تِہُند اتھہٕ پیٚیہِ تتھ تراون تبا ہ کٔرِ تھ۔﴿ امہِ نِشہِ چِھ مُراد روٗمی یِمو بیت المقدس با لکل تباہ کوٚر۔ بنی اسرا یل کٔڑِکھ چو ب دِوا ن دِوا ن فلسطین منٛزٕ تہٕ امہِ پتہٕ چِھ تِم اَز دۅ یَو ساسو ؤرِیَو پٮ۪ٹھہٕ سٲرٕ سٕے دُنیا ہس منٛز چھلہٕ چھا نگرِ تہٕ مُنتشر﴾"
  17,8,"۔بنان چُھ زِ تُہُند ربّ کرِ تۅہیہِ پٮ۪ٹھ وۅ نۍ رحم،البتہ اگر تۅہیہِ بیٚیہِ پننہِ پرا نہِ رٔوِشہِ ہُند اعادٕہ کوٚرُو،تیٚلہِ کرو أسۍ تہِ پتہٕ پننہِ  سزاہُک اعادٕہ  تہٕ یِم لُکھ نعمتس انکار چِھ کران تِہندِ خٲطرٕ  چِھ اسہِ جہنمُک قٲد خا نہٕ بنٲوِتھ تھوومُت۔"
  17,9,"۔حقیقت چھےٚ یہِ زِ یہِ قرآن چُھ سۅ وَتھ ہاوان  یۅسہٕ بالکل سیٚود چھےٚ یِم لُکھ اَتھ مٲنِتھ رٕژِ کامہِ لاگن کر نہِ تِمن چُھ یہِ بشارت دِوان،زِ تِہندِ خٲطرٕ چُھ بوٚڈ اجر،"
  17,10,"۔تہٕ یِم لُکھ ٲخرتس مانن نہٕ، تِمن چُھ یہِ خبر دِوان زِ تِہندِ خٲطرٕ چُھ اسہِ دگ تُلوُن عذاب دستیاب تھو و مُت۔ع"
  17,11,"۔ اِنسان چُھ شَر تِتھہٕ پٲٹھۍ منگان یِتھہٕ پٲٹھۍ خیر پزِ منگُن انسان چُھ سٮ۪ٹھہٕے جلد باز ثٲبت سپُد مُت۔﴿یہِ چُھ جوا ب مکہ کیٚن کٲفر ن ہٕنز ن تِمن احمقانہٕ کتھن ہُند، یِمہٕ تِم گرِ گرِ نبی صلی اللہ علیہ وسلمس ٲسۍ وَنان زِ گٔژِھو أنِو عذا ب ییٚمہِ سٍتۍ توٚہۍ اَسہِ کھۅژناوان چِھو۔پیٹھمہِ بیان پتے اَتھ سٍتۍ یہِ ارشاد فر ماونُک غر ض چُھ اتھ کتھہِ پٮ۪ٹھ خبردار کرُن زِ بے وقو فو خیر منگنہٕ بجا ے چِھو عذا ب منگان؟ تۅہیہِ چُھو اکینٛہہ اندازٕہ تہِ زِ اللہ تعالیٰ سُند عذا ب ییٚلہِ کُنہِ قو مس پٮ۪ٹھ یِوان چُھ، تتھ کۅسہٕ حالت چھےٚ گژھان۔ اتھ سٍتۍ سٍتۍاوس اتھ کتھہِ منٛز اکھ لطیف تنبیہ مسلمانن خٲطرٕ تہِ یِم کُنہِ کُنہِ ساعتہٕ کٲفر ن ہٕندِ ظلم و ستم تہٕ ہٹ دھر میو سٍتۍ تنگ یِتھ تِہندِس حقس منٛز عذا ب نٲزِل گژھنُک دُعا ٲسۍ منگُن لاگان ۔ حالانکہ وُنہِ ٲسۍ یِموٕ ے کٲفر و منٛزٕ واریاہ تِم لُکھ موجود، یِم برونٛہہ پٔکِتھ ایمان اَنن وٲلۍ تہٕ سٲرِ سٕے دُنیا ہس منٛز اسلامُک جھنڈ بُلند کر ن وٲلۍ ٲسۍ۔اتھ پٮ۪ٹھ چُھ اللہ تعالیٰ فر ماوان زِ انسان چُھ سیٹھہٕے بے صبر ثابت سپُدمُت ،پرتھ کانٛہہ سُہ چیز چھُ منگان ییٚمٕچ بروقت تس ضرورت چھےٚ باسان حالانکہ پتہٕ چھُ تس پٲنۍ پا نے تجر بہٕ سٍتۍ پے لگا ن زِاگر تمہِ ساعتہٕ أمۍ سُند دُعا قبو ل آسہِ ہے کر نہٕ آمُت ،تیٚلہِ آسہِ ہے نہٕ سُہ أمۍ سٕندِس حقس منٛز رُت۔﴾"
  17,12,"۔وُچِھو،اسہِ چھےٚ رات تہٕ دۅہ زٕ ہ نِشٲنیہِ بنا وِمژِ ۔رٲژ ہٕنز نِشٲنی بنٲواَسہِ بے نوٗر، تہٕ دۅ ہٕچ نِشٲنی کٔر روشن، تاکہ توٚہۍ ہیٚکِوپننِس ربّ سُند فضل تلا ش کٔرِ تھ، بیٚیہِ ہیکِو ریٛتُک تہٕ ؤرِیُک حسابِ معلو م کٔرِ تھ،یِتھے پٲٹھۍ چُھ اسہِ پرٛتھ کانٛہہ چیز الگ الگ تفصیل سان بیان کٔرِ تھ تھوو مُت۔"
  17,13,"۔پرٛتھ انسان سُند شگو ن چُھ اسہِ تٔمۍ سٕندِس پننِس ۂٹِس منٛز نٲلۍ تروومُت،﴿ یعنی پرٛتھ انسان سٕنز نیک بختی تہٕ بدبختی تہٕ تٔمۍ سٕندِ انجا مُک رٔژَر تہٕ بُرٲیی ہٕندۍ اسبا ب تہٕ وجو ہات چِھ خۅد تٔمۍ سٕندِ س  پننِس ذا تس اندر موجود۔﴾ تہٕ قیا مت کہ دۅہ کڑَو أسۍ اکھ نوِ شتہٕ تٔمۍ سٕندِ خٲطرٕ، یتھ سُہ کُھلہٕ کتا بہِ ہٕندۍ پٲٹھۍ لبہِ ۔"
  17,14,"۔پَرپنُن نا مۂ اعما ل، اَز چُھکھ ژٕ پنُن حسا ب لگا و نہٕ خٲطرپا نے سٮ۪ٹھاہ۔"
  17,15,"۔یُس اکھا ہ راہِ راست ﴿ہدا یت ﴾ اختیار کرِ،تٔمۍ سٕنز راست رٔوی چھےٚ تس پا نس خٲطرٕ فٲیدٕہ مند، تہٕ یُس گمرا ہ آسہِ تٔمۍ سٕنزِ گُمرٲہی ہُند وبال چُھ تٔمۍ سٕے پٮ۪ٹھ ،کانٛہہ بور تُلن وول تُلِنہٕ بیٚکۍ سُند بور۔﴿مطلب چُھ یہِ پرٛتھ کانٛہہ انسان چُھ پنٕنۍاکھ مستقل ذمہٕ دٲری تھاوان تہٕ پننِس شخصی حیثیتس منٛز چھُ خدایس برونٛہہ کنہِ جواب دہ ۔اَتھ ذٲتی ذمہٕ دٲری منٛزچُھنہٕ کانٛہہ دوٚیُم شخص تس شر یک کینٛہہ ﴾ تہٕ أسۍ چِھنہٕ عذا ب دِنہٕ وٲلۍ کینٛہہ، یوٚت تام نہٕ لُکن ﴿حق و بٲطلٕچ فر ق سمجھاو نہٕ خٲطرٕ ﴾ اکھ پیغمبر سوزون۔"
  17,16,"۔ییٚلہِ أسۍ کانٛہہ بستی ہلاک کر نُک ارداہ چِھ کران ، تیٚلہِ چِھ تمہِ کیٚن خۅ ش حال لُکن حکم دِوان،تہٕ تِم چِھ اتھ منٛز نا فر مٲنیہِ کر نہِ لاگان، پتہٕ چُھ عذا بُک فٲصلہٕ اتھ بستی پٮ۪ٹھ چسپاں گژھان، تہٕ أسۍ چِھن یہِ بر باد کٔرِتھ تراوان۔﴿یتھ حقیقتس پٮ۪ٹھ آیتس منٛز تنبیہ چُھ کر نہٕ آمُت،سۅ چھےٚ یہِ أکِس معا شر س یُس چیز ٲخر کار تباہ چُھ کران سُہ چُھ امہِ کیٚن کھیٚنہٕ چیٚنہٕ والیٚن ہُند خۅ شحال لُکن تہٕ تھد ٮ۪ن طبقن ہُند بگا ڑ ۔ ییٚلہِ کُنہِ قو مس شہمت چھےٚ آسان یِنہٕ وا جِنۍ ،تیٚلہِ چِھ تٔمِکۍ دو لت مند تہٕ صا حبِ اقتدار لُکھ فسق و فجورس منٛز وَسان, ظلم و ستم، بد کٲر یہِ تہٕ اَتٕرۍ چِھ لاگن کرٕنۍ ،ٲخرس پٮ۪ٹھ چُھ یۅ ہے فِتنہِ پوٗرٕ قو مس ڈُباوان۔ لہٰذا یُس معاشرٕہ پانہٕ پنُن دشمن آسہِ نہٕ ،تس پزِفکر تھاوٕنۍ زِ اتھ منٛز گژھن نہٕ اقتدار چہِ لاکمہِ تہٕ معا شی دولت چہِ کُنزٕ کم ظر ف تہٕ بد اخلا ق لُکن ہٕندٮ۪ن اتھن منٛز گژھنہِ﴾"
  17,17,"۔وُچِھو ،کٲتیاہ نسل چِھ  یِم نو ح علیہ السلام سٕندِ پتہٕ سانہِ حُکمہٕ ہلا ک سپٕدۍ،چو ن ربّ چُھ پننیٚن بند ن ہٕندیو گنا ہو نِشہِ پوٗرٕ پٲٹھۍ با خبر، تہٕ سورُے کینٛہہ چُھ وُچھان۔"
  17,18,"۔یُس اکھا ہ ﴿یتھ دُنیا ہس منٛز﴾جلد ی حٲصل سپد ن والیٚن فٲید ن ہُند خوٲہش مند آسہِ، تس چِھ أسۍ ییتی دِوان، یَس یوٗتاہ دِیُن یژھو، پتہٕ چِھ تٔمۍ سٕندِس تقدیرس جہنم لیکھان، یتھ منٛز سُہ دَزِ خٔجِل گٔژِھتھ تہٕ رحمت نِشہِ محر و م سپدِ تھ۔"
  17,19,"۔تہٕ یُس اکھاہ ٲخرتُک خوٲہش مند آسہِ، تہٕ اَمہِ خٲطرٕ کرِ کو شش، یِژھ امہِ خٲطرٕ کوشش پزِ کرٕنۍ،تہٕ آسہِ سُہ مومن، تیٚلہِ سپدِ یِتھِس پرٛتھ  شخصہٕ سٕنز کو شش مشکو ر۔﴿یعنی تٔمۍ سٕنزِ کامہِ یِیہِ قدر کر نہٕ، تہٕ یٖژھ کوشش تہِ ٲخرت چہِ کا میا بی خٲطرٕ تٔمۍ کٔر مٕژ آسہِ ، تمِیُک پھل سپدِ ضرور تس حٲصل﴾"
  17,20,"۔یِمن تہِ تہٕ تِمن تہِ دۅ شوٕ نۍ فر یقن چِھ أسۍ ﴿دنیا ہس منٛز ﴾ زند گی ہُند سامان دِوان پکا ن، یہِ چُھ تُہندِس ربّ سُند عطیہ،تہٕ تُہندِ س ربّ سٕندِس عطا ہس ﴿ انعامس ﴾ چُھنہٕ کانٛہہ رُکا و ن وول۔"
  17,21,"۔مگر وُچِھو، دُنیا سٕے منٛز کِژھ فضیلت چھےٚ اسہِ أکِس دٔرِس دوٚ یِمس پٮ۪ٹھ دِژٕ مٕژ۔ ﴿یعنی دُنیا سٕے منٛز چھےٚ یہِ فرق نٔنۍ پٲٹھۍ اتھہِ یِوان زِ ٲخر تٕکۍ طلب گار چِھ دُنیا پرست لُکن پٮ۪ٹھ فضیلت تھاوان ، یہِ فضیلت چَھنہٕ امہِ اعتبارٕ زِ تِہٕندۍ کھیٚن تہٕ لبا س، مکا ن تہٕ سوارِ ، تمد ن تہٕ تہذ یبٕکۍ ٹھا ٹھ چِھ یِہندِ کھۅتہٕ کھٔسِتھ۔ بلکہ چِھ امہِ اعتبارٕ زِ یِم یِکینژھاہ تہِ حٲصل چِھ کران، تہِ چِھ صدا قت سان، دیا نت تہٕ امانت دٲر ی سان حٲصل کران، تہٕ یِکینژھاہ ہۅ م چِھ حٲصل کران، تہِ چِھ ظُلم ، بے ایمانی تہٕ رنگہٕ رنگہٕ چَو حرام خوٗرِ یَو سٍتۍ حٲصل کران، پتہٕ یِکینژھاہ یِمن میلان چُھ تہِ چِھ اعتدال سان خر چ کران۔ اتھ منٛز چِھ حق دارن ہٕندۍ حقوق ادا سپدان، امہِ منٛزٕ چُھ سٲیل تہٕ محر و م سُند حصہٕ تہِ نیران، تہٕ امہِ منٛزٕ چُھ اللہ تعالیٰ سٕنزِ خۅ شنود ی خٲطرٕ دوٚیِمیٚن نیک کامیٚن منٛز تہِ مال یِوان خر چ کر نہٕ، اتھ بر عکس یِکینژھاہ دُنیا پرستن میلان چُھ، سُہ چُھ یِوان اکثر عیٲشِیَن تہٕ حرام کٲرِین منٛز، رنگہ رنگہ کیٚن فسادن تہٕ فتنہ چن کا میٚن منٛز آبٕکۍ پٲٹھۍ بہا و نہٕ۔ یِتھ پٲٹھۍ چھےٚ تمام حیثیتو کِنۍ ٲخرت کِس طلب گار سٕنز زند گی دُنیا پرست سٕنزِ زند گی نِشہِ کھٔسِتھ آسان۔﴾ تہٕ ٲخرتس منٛز آسن اَمِکۍ در جہِ بیٚیہِ تہِ ہُر یمانہٕ، تہٕ اَمِچ فضیلت آسہِ بیٚیہِ تہِ زیادٕہ کھٔسِتھ۔"
  17,22,"۔ژٕ مَہ بناوُن خُدا یس سٍتۍ بیٚیہِ کانٛہہ معبود، نَتہٕ سپدکھ ملامت زدٕہ تہٕ روزکھ بے یارومددگار بٔنِتھ۔ع"
  17,23,"۔چٲنۍ ربّن چُھ فٲصلہٕ کوٚر مُت زِ توٚہۍ مَہ کٔرِ و کٲنٛسہِ ہٕنز عبا دت ،مگر صرف تٔمۍ سٕنز، مٲلِس ماجہِ سٍتۍ کٔرِ و نیک سلو ک،اگر تۅہیہِ نِشہِ یِمو منٛزٕ کانٛہہ اکھ، یا دۅ شو ے بُڈٕ سپدن،تیٚلہِ کٔرۍ زیٚو نہٕ یِمن اُف تہِ ، نَہ دِ یز یو یِمن ہٕکہٕ جواب، بلکہ کٔرِو یِمن سٍتۍ احترام سان کتھ۔"
  17,24,"۔تہٕ نر می تہٕ رحم سان روٗزِ و یِمن برونٛہہ کنہِ کلہٕ نوٚ مرٲوِتھ، تہٕ دُعا ٲسِو کران زِ  پروردگار،یِمن پٮ۪ٹھ کررحم ، یِتھہٕ پٲٹھۍ یِمو بہٕ رحمت تہٕ شفقت سان شُر ۍ پانہٕ روٚ چھمُت اوسُس۔"
  17,25,"۔تُہُند ربّ چُھ ٹھیک پٲٹھۍ زانان زِ تُہندٮ۪ن دِلن منٛز کیا چُھ،اگر توٚہۍ صا لح بٔنِتھ روٗزِ و ، تیٚلہِ چُھ سُہ تِتھیٚن سارِنٕے لُکن در گُزر کر ن وول ،یِم پننیٚن قصورن پٮ۪ٹھ نہیب رٔٹِتھ بند گی ہٕندِس رٔوِیس  کُن پوٚت پھیرن۔"
  17,26,"۔رشتہٕ دارس دِیِو تٔمۍ سُند حق،تہٕ مسکین تہٕ مسٲفرس تٔمۍ سُند حق، فضو ل خر چی مَہ کٔرِو۔"
  17,27,"۔فضو ل خر چی کر ن وٲلۍ لُکھ چِھ شیطا ن سٕند ۍ بٲے، تہٕ شیطا ن چُھنہٕ پننِس ربّ سُند شکر گزار۔"
  17,28,"۔اگر تِمو نِشہِ ﴿ یعنی حا جت مند رشتہٕ دارو، مسکینو تہٕ مسا فر و نِشہِ ﴾ تۅہیہِ پَتھ آسہِ ہِیوٚ ن اتھ بِنا ہس پٮ۪ٹھ زِ وُنہِ چِھو توٚہۍ اللہ تعالیٰ سٕندِس تتھ رحمتس تلا ش کران ییٚمکۍ توٚہۍ امیدوار چِھو،تیٚلہِ دِیِو تِمن نر م جواب۔"
  17,29,"۔تہٕ نَہ مَہ ترٲوِیوٗن یہِ با لکُلٕے یَلہٕ زِ ملا مت زدٕہ تہٕ عٲجز بٔنِتھ روٗزِو۔﴿اتھہٕ گٔنڈٕنۍ چُھ استعارہ بخُلہٕ خٲطرٕ ،تہٕ یہِ یلہٕ تراوُن چُھ مُراد فضو ل خر چی﴾"
  17,30,"۔تُہُند ربّ یَس خٲطرٕ رز ق چُھ یژھان کُشادہ کرُن تس چُھ کران،تہٕ یس خٲطرٕ یژھان چُھ تس چُھ تنگ کران۔ سُہ چُھ پننیٚن بند ن ہٕندِ حالہٕ نِشہِ با خبر تہٕ تِمن چُھ وُچھان۔ع۔"
  17,31,"۔پنٕنۍ اولاد مَہ کٔرِ یوٗکھ غر یبی ہٕندِ اندیشہِ کِنۍ قتل،أسۍ دِمَو تِمن تہِ رزق تہٕ تۅہیہِ تہِ ، در حقیقت چُھ تِہُند قتل اکھ بوٚڈ خطا۔"
  17,32,"۔بدکٲر ی مَہ گٔژِھو نکھہٕ، سۅ چھےٚ سٮ۪ٹھاہ بُرٕ کٲم تہٕ سٮ۪ٹھہٕے خرا ب وَتھ۔"
  17,33,"۔قتلِ نفسُک اَتُر مَہ کٔرِو ، یہِ چُھ خُدا ین حرام کوٚر مُت، مگر حق سان ، تہٕ یُس شخص مظلو م پٲٹھۍ قتل آسہِ کر نہٕ آمُت، تٔمۍ سٕندِس ؤلی یَس ﴿وٲرِثس ﴾ چُھ اتھ اسہِ قصا ص کہ مطا لبُک حق عطا کوٚر مُت۔﴿ اصل الفا ظ چِھتٔمۍ سٕندِس ؤلی یس چُھ اَسہِ سلطان عطا کوٚر مُت  سُلطان نِشہِ چُھ مُراد یتھ جایہِ حُجّتییٚمہِ کِس بُنیا دس پٮ۪ٹھ سُہ قصا صُک مطا لبہٕ ہیکہِ کٔرِتھ۔﴾لہٰذا، پَزِ زِ سُہ گژِھہ نہٕ قتلس منٛز حدٕ نیرُن﴿قتلس منٛز حدٕ نیرنس ہیٚکن واریاہ صوٗرتہٕ ٲسِتھ تہٕ تِمہٕ سار ے چھےٚ ممنو ع۔مثلاً انتقام کِس جو شس منٛز مجرِ مَس علا وہ با قی قتل کرٕنۍ یا مُجر م عذا ب کٔرۍ کٔرۍ مارُن ،یا مار نہٕ پتہٕ تٔمۍ سٕنزِ لاشہِ پٮ۪ٹھ شرارت کڑُن ،یا خو ن بہارَٹنہٕ پتہٕ سُہ قتل کرُن بیترِ﴾ تس یِیہِ مدد کر نہٕ ۔ ﴿ چو نکہ اتھ وقتس تام ٲس نہٕ اسلٲمی حکو مت قٲیم سپٕز مٕژ،امہِ موجوٗب آیہِ نہٕ یہِ کتھ ویژھنا و نہٕ زِ تس کُس کرِ مدد۔ہجر ت پتہٕ ییٚلہِ اسلٲمی حکو مت قٲیم سپٕز ، پتہٕ آو یہِ طے کر نہٕ زِ تس مدد کرُن چَھنہٕ تٔمۍ سٕندِ قبیلٕچ یا تٔمۍ سٕندٮ۪ن خلیفن ہٕنز کٲم بلکہ چھےٚ اسلٲمی حکو متٕچ ،تہٕ بیٚیہِ چھےٚ تمہِ کہ عدالت کہ نِظا مٕچ کٲم۔﴾"
  17,34,"۔یتیم سٕندِس مالس نز دیک مَہ گژِھو، مگر جان طر یقہٕ سان، یوٚت تام زن سُہ پننہِ جوٲنی تام واتہِ۔ وعدٕچ پا بندی کٔرِ و، بے شک آسیو تۅہیہِ وعدس متعلق جوا ب دِیُن۔"
  17,35,"۔ییٚلہِ پیمانہٕ سٍتۍ دِیِو تیٚلہِ دِیِو پوٗرٕ بٔرِتھ،تہٕ ییٚلہِ توٗلِو تیٚلہِ توٗلِو ٹھیک ترٛ کرِ سٍتۍ،یہِ چُھ جان طر یقہٕ تہٕ انجام کہ لحا ظہٕ تہِ چُھ یی بہتر۔"
  17,36,"۔کُنہِ تِتھِس چیز س مَہ لٔگِو پتہٕ ییٚمیُک نہٕ تۅہیہِ علم آسہِ ﴿امہِ ارشادُک منشہِ چُھ یہِ زِ لُکھ کٔرِن پننہِ انفرٲدی تہٕ اجتمٲعی زند گی منٛز وہم و گُمان بجا ے  علِمٕچ پیر وی ﴾ یقیناً چھےٚ أچھ، کَن تہٕ دِل سارِنٕے ہٕنز پٕرژھگٲر سپدَن واجِنۍ۔"
  17,37,"۔زمینس پٮ۪ٹھ مَہ پٔکِو تکبر سان، توٚہۍ نَہ ہیٚکِیون زمین ژٔٹِتھ، نَہ ہیٚکِو پہا ڑن ہٕندِس تھزرس تام وٲتِتھ۔"
  17,38,"۔یِمو کتھو منٛزٕ چُھ پرٛتھ اَکِیُک بُرٕ پہلو تُہٕندِس ربّس نزدیک نا پسند یدٕ ہ۔﴿ یعنی یِمو احکامو منٛزٕ ییٚمہِ حُکمٕچ تہِ نا فر مانی کر نہٕ یِیہِ سُہ چُھ نا پسند یدٕہ﴾"
  17,39,"۔یِمہٕ چھےٚ حکمت چہِ تِمہٕ کتھہٕ، یِمہٕ تُہٕندۍ ربّن تۅہیہِ پٮ۪ٹھ وحی چھےٚ کرِمژٕ۔بیٚیہِ وُچھً خُدا یس سٍتۍ مَہ بناوُن بیٚیہِ کانٛہہ معبود،نَتہٕ یِکھ ژٕ جہنمس تراو نہٕ ملا مت زدٕہ پرٛتھ رٕژرٕ نِشہِ محر و م سپدِ تھ۔﴿ اَمہِ فر مانُک مخٲطب چُھ پرٛتھ کانٛہہ انسان۔مطلب چُھ یہِ زِ اے انسان ژٕ مَہ کر یہِ کٲم﴾"
  17,40,"۔کِژھ عجیب کتھ چھےٚ تُہٕندۍ ربّن کٔرِ نَو تۅہیہِ نیچِو عطا، تہٕ پانہٕ بنٲوِن ملٲیِک پننہِ خٲطرٕ کورِ؟ سٮ۪ٹھاہ اَپٕز کتھ چھےٚ یۅسہٕ توٚہۍ لُکھ زبٲنۍ چِھو کڑان۔ ع"
  17,41,"۔اَسہِ سمجھٲوۍ لُکھ یتھ قرآنس منٛز رنگہٕ رنگہٕ زِ ہو شسس منٛز یِیِن تہٕ نصیحت رٔٹِن، مگر تِم چِھ حق نِشہِ وراے دوٗر ژلان۔"
  17,42,"۔اے نبی  صلی اللہ علیہ وسلم، یِمن ؤنِو زِ اگر خُدا یس سٍتۍ با قی خدا ے تہِ آسٕہَن،یِتھہٕ پٲٹھۍ زن یِم لُکھ ونان چِھ، تیٚلہِ کر ہن عر ش کِس مٲلک سٕندِس مقا مَس تام وا تنٕچ کوٗشش ضروٗر۔"
  17,43,"۔پاک چُھ سُہ، تہٕ سٮ۪ٹھاہ بالا تہٕ بر تر چُھ، تِمو کتھو نِشہِ یِمہٕ یِم لُکھ ونان چِھ ۔"
  17,44,"۔تٔمۍ سٕنز پٲکی چِھ ستَوَے آسمان بیٚیہِ زمین تہٕ تِم سٲ ری چیز بیان کران، یِم آسما نس تہٕ زمینس منٛز چِھ۔﴿یعنی سٲرٕ ے کا ینات تہٕ امِیُک پرٛتھ چیز چُھ پننہِ پوٗرٕ وجودٕ سان اتھ حقیقتس پٮ۪ٹھ گو اہی دِوان زِ ییٚمۍ یہِ پٲدٕ چھےٚ کٔر مٕژ، تہٕ یُس اَمِچ پروردگٲری تہٕ رٲچھ راوٹھ چُھ کران، تٔمۍ سٕنٛز ذات چھےٚ پرٛتھ عیبہٕ تہٕ نقصٕ تہٕ پرٛتھ کمز ور ی نِشہِ مُنّزہ، تہٕ سُہ چُھ اَمہِ نِشہِ بالکل پاک زِ خدٲیی منٛز کیا آسہِ کانٛہہ تس شر یک تہٕ حصہ دار﴾ کانٛہہ چیز چُھنہٕ سُہ یُس تٔمۍ سٕنٛدِ حمدٕ سان تٔمۍ سٕنز تسبیح آسہِ نہٕ کران، مگر توٚہۍ چِھو تسبیح سمجھان،حقیقت چھےٚ یہِ زِ سُہ چُھ سٮ۪ٹھہٕے بُردبار تہٕ در گز ر کر ن وول۔"
  17,45,"۔ییٚلہِ توٚہۍ قرآن پران چِھو، أسۍ چِھ تۅہیہِ تہٕ ٲخرتس پٮ۪ٹھ ایمان نَہ انن والیٚن در میان اکھ پردٕہ حٲیلِ کران،تہٕ تِہٕندٮ۪ن دِلن پٮ۪ٹھ چِھ غلا ف کھالان،"
  17,46,"۔زِ تِم چِھنہٕ کِہِنۍ سمجھان، تہٕ تِہِندٮ۪ن کنن چِھ گۅبیٚر پٲدٕ کران۔﴿یعنی ٲخرتس پٮ۪ٹھ ایمان نَہ اَننُک چُھ یہِ قدرتی نتیجہِ زِ انسان سٕندِس دِلس لگن قُلُف تہٕ تٔمۍ سٕندۍ کن گژھن ییٚمہِ دعوت خٲطرٕ بند یۅ سہٕ دعوت قرآن چُھ پیش کران۔قرآنٕچ دعوتٕے چھےٚ اَتھ بنیادس پٮ۪ٹھ زِ دُنیٲوی زند گی ہٕندِ ظٲہر ی پہلو نِشہِ ما کھیٚیِو دۅ کھہٕ۔حقٕکۍ تہٕ بٲطلٕکۍفٲصلہٕ سپد ن نہٕ، یَتھ دُنیا ہس منٛز بلکہ سپد ن ٲخرتس منٛز۔ نیکی چھےٚ سۅ ییٚمیُک نتیجہ ٲخرتس منٛز نیرِ، خوا ہ وٲتَتِن  اَمہِ کہ وجہ سٍتۍدنیاہس منٛز انسانس کٲتیاہ تہِ تکلیف تہٕ بدی چھےٚ سۅ ییٚمِیُک نتیجہ ٲخرتس منٛز لازماً بُرٕ نیرِ ،خواہ دُنیا ہس منٛز ٲسِتن سۅ کٲژاہ تہِ مز ہ دار تہٕ فٲیدٕہ مند۔وۅ نۍ یُس شخص ٲخر تٕے چُھنہٕ مانان ،سُہ کِتھہٕ پٲٹھۍ ہیٚکہِ قرآن کِس یَتھ دعوتس کُن تو جہ دِتھ۔﴾ تہٕ ییٚلہِ تۅ ہۍ قرآنس منٛز پننِس أکۍ سٕے ربّ سٕنز ذکر چِھو کران، تیٚلہِ چِھ تِم نفر ت سان بُتھ پھِران۔﴿ یعنی تِمن چھےٚ یہِ کتھ سخت نا گوار گژھان زِ توٚہۍ چِھو صرف أکۍ سٕے خُدا یس مٲلک تہٕ مختارو نان ، تہٕ تٔمۍ سٕندِ نٕے تعر یفن ہٕنٛدۍ گۅ ن چِھو گیٚوان۔تِم چِھ ونان یہِ چُھ عجیب شخص یُس دپان چُھ علمِ غیب چُھ خُدا یس ، قدرت چھےٚ تٔمۍ سٕنزٕ ے، تصر فات تہٕ اختیارات چِھ تٔسۍ یوت ۔ ٲخر یِم سٲنۍ اَستان وٲلۍ تہِ چھا کانٛہہ چیز اہ کِنہٕ نَہ، یِمن نِشہِ اسہِ اولاد چِھ میلان، بیمار ن چُھ شفا حٲصل گژھان، کارو بار چِھ چمکا ن ،تہٕ مُراد چِھ پوٗرٕ سپدان﴾"
  17,47,"۔اَسہِ چُھ معلو م ییٚلہِ تِم کن دٲرِتھ تُہٕنٛز کتھ بو زان چِھ، تیٚلہِ کیا چِھ در اصل تِم بوزان، پتہٕ ییٚلہِ بِہِتھ چِھ سِرٕ کتھہٕ کران تیٚلہِ کیا چِھ ونان، یِم ظا لم چِھ پانہٕ وٲنۍ ونان زِ یہِ چُھ اکھ  جٲدۍ لدنفر یس پتھ توٚہۍ لُکھ گژھان چھِو ﴿کفارِ مکن ہُنٛد حال اوس یہِ زِ ژوٗرِ ژوٗرِ ٲسۍ قرآن بوزان پتہٕ ٲسۍپانہٕ وٲنۍ  مشورٕ کران زِ اَمیُک تو ڑ کیا گژِھہ آسُن۔بسا اوقات اوس تِمن پننیوٕ ے نفر و منٛزٕ کٲنٛسہِ پٮ۪ٹھ شک گژھان زِ شاید چُھ یہِ نفر قرآن بوٗزِ تھ متٲثر گوٚ مُت۔اَمہِ موجو ب ٲسۍ تِم سٲر ی  سٔمِتھ تس سمجھاوان زِ ، ہے یہِ کٔمۍ سٕندِس دۅ کھس منٛز آکھ ژٕ، یہِ شخص چُھ جٲدۍ لد، یعنی کٔمۍ تام دشمنن چُھ أمِس جود کوٚر مُت، اَمی موجو ب چُھ اورٕ یو ر چہِ کتھہٕ کران۔﴾"
  17,48,"۔وُچِھو زِ کِژٕھہ کتھہٕ چھےٚ یِمہٕ ،یِمہٕ لُکھ تۅہیہِ پٮ۪ٹھ چسپان چِھ کران، یِم چِھ ڈٔلِمٕتۍ ،یِمن چَھنہٕ وَتھ میلان۔"
  17,49,"۔تِم چِھ ونان  ییٚلہِ أسۍ أڈِجہِ تہٕ خا ک سپدِتھ روزَو، کیا تیٚلہِ یِموٕ ہ أسۍ نوِ سرٕ پٲدٕ کٔرِتھ تُلنہٕ؟"
  17,50,"۔ تِمن ؤنِو توٚہۍ بنۍ تَو کٔنۍ یا شستٕر تہِ ،"
  17,51,"۔یا اَمہِ کھۅتہٕ تہِ کانٛہہ سخت چیز یُس تُہٕندِس ذہنس  منٛز زند گی قبول کر نہٕ نِشہِ سٮ۪ٹھاہ دوٗر آسہِ  ﴿تو تہِ ؤتھِو توٚہۍ ﴾  تِم پٕرٛژھن ضرور کُس چُھ سُہ یُس نوِ سرٕ زند گی کُن پھِرِ تھ اَنہِ؟ در جواب ؤنیوٗکھ سُے ییٚمۍ توٚہۍ گۅڈنِچہِ پھِرِ پٲدٕ کٔرِ و ۔ تِم پٕرٛژھن کلہٕ ہِلٲوۍ ہِلٲوۍ﴿ انغا ض لفظس چُھ معنی کلس ہیوٚر بۅ ن کرُن ۔ یِتھہٕ پٲٹھۍ اظہا رِ تعجب خٲطرٕ، یا مذا ق کر نہٕ خٲطرٕ انسان کلس ہیوٚر بۅن چُھ کران ﴾ اچھا ، تیٚلہِ کر سپدِ یہِ ؟ توٚہۍ ؤنِو  بنان چُھ زِ سُہ وقت آسہِ نکھہٕ وونمُت"
  17,52,"۔ ییٚمہِ دۅ ہ سُہ تۅہیہِ آلَو کرِ ، تہٕ تٔمۍ سٕندِس آلوس پٮ۪ٹھ یِیِو توٚہۍ تٔمۍ سُند حمد کران کران نِیرِ تھ، تہٕ یُہُند گُمان آسہِ تمہِ وقتہٕ یہِ زِ أسۍ چِھ بس کم سٕے کالس اتھ حالتس منٛز روٗدِمٕتۍ  ع۔ ﴿ یعنی دُنیا ہس منٛز مر نہٕ کہ وقتہٕ پٮ۪ٹھہٕ قیامت کہ دۅ ہ وۅ تھنہٕ کِس وقتس تام یۅسہٕ مُدّت آسہِ ، سۅ با سیو نہٕ تۅہیہِ کینژھو گٲنٹو کھۅتہٕ زیادہ۔توٚہۍ سمجھِو تمہِ وقتہٕ یہِ زِ أسۍ ٲسۍ رژِھہ کھنجہِ شۅ نِگتھ زِ اچانک تُلۍ محشرٕ کۍ شورن أسۍ نِندرِ ﴾"
  17,53,"تہٕ اے نبی صلی اللہ علیہ وسلم، میا نیٚن بند ن ﴿یعنی مو من بند ن ﴾ ؤنِو زِ زیٚوِ ٲسِن سۅ کتھ کڑان یۅسہٕ بہتر آسہِ ﴿ یعنی مخٲلف کٔرِ تن خوا ہ  کِژٕھہ تہِ ناگوار کتھہٕ مگر مُسلمانن پزِ نہٕ بہر حال ، نَہ کانٛہہ کتھ خلافِ حق زیوِ کڑٕ نۍ تہٕ نَہ پزیٚکھ شرارتس منٛز یِتھ بے ہو د گی ہُند جواب بے ہو د گی سٍتۍ دِیُن ۔ تِمن پَزِ ٹھنڈٕ دل سان سۅ ے کتھ وَنٕنۍ یۅسہٕ گٔرِتھ ژٔرِ تھ بر حق آسہِ ، بیٚیہِ آسہِ تِہِندِس دعوت کِس وقارس مطٲبق﴾دراصل چھُ یہِ شیطان یُس انسانن درمیان فساد تراونٕچ کوٗشش چُھ کران، حقیقت چھےٚ یہِ زِ شیطا ن  چُھ انسان سُند ٹا کارٕہ دشمن"
  17,54,"۔تُہُند ربّ چُھ تُہُندِ حال نِشہِ ٹھیک پٲٹھۍ وٲقف،سُہ اگر ییژِھہ تۅہیہِ پٮ۪ٹھ کرِ رحم تہٕ اگر ییژِھہ تیٚلہِ دِیو عذا ب﴿ یعنی اہلِ ایمانن ہٕنزِ زیوِ پٮ۪ٹھ گژھن نہٕ زٕ ہٕنۍ تِتھۍ دعویٰ یِنۍ زِ أسۍ چِھ جنتی تہٕ فلٲنۍ شخص یادوٚر چُھ جہنمی۔امہِ چیزُک فٲصلہٕ چُھ اللہ تعالیٰ سٕندِس اختیارس منٛز۔ سُے چھُ تمام انسانن ہٕندِ ظٲہرٕ تہٕ بٲطن نِشہِ ،بیٚیہِ تِہندِ حال و مستقبل نِشہِ وٲقف۔تٔسۍ چُھ یہِ فٲصلہٕ کرُن زِ کس پٮ۪ٹھ فر ماوِ رحمت تہٕ کس دِیہِ عذا ب۔اکھ مُسلمان چُھ اصو لی حیثیتہٕ یہِ وَننُک مجا ز زِ اللہ تعالیٰ سٕنزِ کتا بہِ کِنۍ کمہِ قسمٕکۍ انسان چِھ رحمتٕکۍ حقدار تہٕ کمہِ قسمٕکۍ لُکھ چِھ عذا بٕکۍ حقدار۔مگر کٲنٛسہِ چُھنہٕ یہِ وننُک حق زِ فلٲنۍ شخصس یِیہِ عذا ب دِنہٕ تہٕ فلٲنۍ شخصس یِیہِ بخشنہٕ﴾ تہٕ اے نبی صلی اللہ علیہ وسلم ، اسہِ چِھو نہٕ توٚہۍ لُکن پٮ۪ٹھ رٲچھدار بنٲوِتھ سوٗزِ مٕتۍ کینٛہہ۔"
  17,55,"۔یُہُند ربّ چھ  زمین و آسمانن ہٕندٮ۪ن مخلو قن زیادہ زانان، اَسہِ دِتۍ کینژھن پیغمبر ن کینژھو کھو تہٕ کھٔسِتھ مر تبہ، تہٕ اَسی ٲس داوٗد ﴿علیہ السلامس﴾ زبور دِژٕ مٕژ۔"
  17,56,"۔یِمن ؤنِو ،ناد لٲیِتھ وُچھوٗکھ تِم معبود یِمن خُدا یس ورٲے ﴿پنُن کار ساز﴾ سمجھان چِھو،تِم ہیٚکن نہٕ کانٛہہ تکلیف تۅہیہِ نِشہِ دوٗر کٔرِ تھ تہٕ نَہ ہیٚکن بدلٲوِتھ۔﴿ امہِ نِشہِ چُھ صاف پَے لگان زِ غیر اللہ ہن سجدہ کر نُے یوت چُھنہٕ شر ک، بلکہ چُھ خُدا یس ورٲے بیٚیہِ کٲنٛسہِ دُعا منگُن ، یا تس مددٕ خٲطرٕ آلَو دِیُن تہِ شر ک ﴾"
  17,57,"۔یِمن لُکن یِم ناد چِھ لایان، تِم چِھ پانہٕ خۅد پننِس ربّ سٕندِس در بارس تام رسٲیی حٲصل کر نُک وسیلہٕ تلا ش کران زِ کُس گژِھہ تس قر یب تر، تہٕ تِم چِھ تٔمۍ سٕندِ رحمتٕکۍ اُمیدوار تہٕ تٔمۍ سٕندِس عذا بس چِھ کھۅژان﴿یِم الفا ظ چِھ صا ف ونان زِ مُشر کن ہٕندٮ۪ن یِمن معبودن تہٕ فر یاد بوزن والیٚن ہُند یتھ جایہِ ذِکر چُھ یوان کر نہٕ تِمو نِشہِ چُھنہٕ مُراد کنہِ پۅ تٕکۍ کینٛہہ ، بلکہ چِھ یا تہٕ فر شتہٕ نَتہٕ چِھ گزر یمتہِ زمانٕکۍ بر گُزیدہ انسان۔﴾ حقیقت چھےٚ یہِ زِ تُہِندِس ربّ سُند عذا ب چُھ کھۅژنَسٕے لا یق۔"
  17,58,"۔تہٕ کانٛہہ بستی چَھنہٕ تِژھ،یۅسہٕ ٲسۍ قیامت برونٛہہ ہلا ک کر ون نہٕ، یا سخت عذا ب دِمو س نہٕ، یہِ چُھ اللہ تعالیٰ سٕندِس نٔوِ شتس ﴿کتا بہِ ﴾ منٛز  لیٚکھِتھ۔"
  17,59,"۔تہٕ أسۍ رُکٲوۍ نہٕ نِشٲنیہِ سوز نہٕ  نِشہِ کٲنٛسہِ، مگر امہِ کتھہِ زِ یِمن برونٹھمیو لُکو چُھ تِمن انکار کوٚر مُت۔﴿ یہِ چُھ کُفارن ہٕندِ تمہِ مطا لبُک جواب زِ محمد صلی اللہ علیہ وسلم گژھن تِمن کانٛہہ معجزہ ہاوٕنۍ۔ مُد عا چُھ یہِ زِ تِیُتھ معجزہ وُچھنہٕ پتہٕ ییٚلہِ لُکھ چھِ امِیُک  تکذ یب کران، تیٚلہِ چُھ پتہٕ لا محا لہ تِمن پٮ۪ٹھ نز و لِ عذا ب واجِب سپدان، تہٕ پتہٕ چُھنہٕ یُتھ قو م تباہ کر نہٕ ورٲے یِوان تراو نہٕ ۔ وۅ نۍ چھےٚ سراسر یہِ اللہ تعالیٰ سٕنز رحمت زِ سُہ چُھنہٕ یُتھ کانٛہہ معجز ہ سوزان، مگر توٚہۍ چِھو تِتھۍ بے وقوف لُکھ زِ معجزُک مطا لبہٕ کٔرِ تھ چِھو ثمودٕ کۍ پٲٹھۍ انجامس یژھان واتُن۔﴾﴿چنانچہ وُچھِو﴾ثمودس دٕژ اَسہِ علٲنیہ اونٹِنۍ أنِتھ تہٕ تِمو کوٚرتَس پٮ۪ٹھ ظُلم۔ أسۍ چِھ اَمی خٲطرٕ نِشٲنیہِ سوزان زِ تِمن وُچِھتھ کھۅژن لُکھ۔"
  17,60,"۔یاد کٔرِ و اے نبی صلی اللہ علیہ وسلم، اَسہِ اوسُو تۅہیہِ ووٚ نمُت زِ تُہٕندۍ ربّن چِھ یِم لُکھ گھیرس منٛز رٔٹِمٕتۍ۔تہٕ یِکینژھاہ حال حالٕے اَسہِ تۅہیہِ ہو و مُت چُھو۔﴿ اشارہ چُھ معرا جس کُن۔ یتھ جایہِ چُھنہٕ لفظ رُویا  خوا ب  کِس معنیس منز کینٛہہ، بلکہ چُھ چشمو سٍتۍ وُچھنہٕ کِس معنیس منٛز۔﴾سُہ تہٕ بیٚیہِ سُہ کُل یتھ پٮ۪ٹھ قرآنس منٛز لعنت چھےٚ کر نہٕ آمٕژ ،تھو و اَسہِ یِمن لُکن خٲطرٕ بس اکھ فتنہٕ بنٲو،تھ ،﴿ کُلہِ نِشہِ چُھ مُراد زَ قُو م، یتھ متعلق قرآنس اندر خبر چھےٚ دِنہٕ آمٕژ زِ سُہ گژِھہ جہنم کِس ژٔکِس تل پٲدٕ ،تہٕ یِم جہنمی آسن تِمن پیٚیہِ سُہ کھیٚون۔اتھ پٮ۪ٹھ لعنت کر نہٕ نِشہِ چُھ مُراد اَمِیُک اللہ تعالیٰ سٕندِ رحمت نِشہِ دوٗر سپُد ن۔ یِمن لُکن خٲطرٕ تھو و فتنہٕ بنٲوِتھ مطلب چُھ یہِ زِ یِہندِ رٕژرٕ خٲطرٕ کر نٲوِو اَسہِ توٚہۍ معرا جِکۍ مُشا ہدات ،تاکہ تۅہیہِ ہِوِ س صادق تہٕ امین انسان سٕندِ ذر یعہِ گژِھہ یِمن لُکن حقیقتِ نفس الا مر ی تِم پٔزۍ حالات یِم دوست دشمن مانان چِھ  حٲصل تہٕ نہیب رٔٹِتھ یِن یِم سیٚزِ وَتھ پٮ۪ٹھ۔ مگر یِمو لُکو کٔرۍ اَتھ پٮ۪ٹھ تۅہیہ، پوٚت پھیِرٕ تھ ہزٕ ل۔اسہِ کٔرۍ یِم تُہٕندِ ذر یعہِ خبردار زِ ییٚتہِ چہِ حرام خوٗرِ یہِ کھیا و نا نَو تۅہیہِ زَ قُو مٕکۍ میٚنڈ ۍ،مگر تِمو ترٛوو اَتھ پٮ۪ٹھ اکھ اَسن کھنگا لہٕ تہٕ لٔگۍ وَننہٕ، ہے یہِ شخص وُچھتو ن، اکہِ اندٕ چُھ ونان زِ دو خس منٛز آسہِ نارٕ بلا ے دزان، تہٕ بیٚکہِ اندٕ  چُھ ونان تَتہِ وۅ پدن کُلۍ﴾ أسۍ چِھ یِمن نہیبس پٮ۪ٹھ نہیب کران پکان،مگر پرٛتھ نہیب چُھ یِہنزِ سر کشی منٛز اضا فہٕ کران ۔ ع"
  17,61,"۔تہٕ یاد کٔرِ و ییٚلہِ اَسہِ ملٲیکن ووٚن زِ آد مَس کٔرِ و سجدٕہ،سارِوٕ یو کوٚر سجدٕہ، مگر ابلیسن کوٚر نہٕ، تٔمۍ ووٚن  کیا بہٕ کراہ أمِس سجدٕہ یُس ژےٚ میٚژِچِھی بنو و مُت؟"
  17,62,"۔پتہٕ ووٚن تٔمۍ  تَلسہ وُچُھ، کیا یہِ اوسا اتھ قٲبل زِ ژےٚ دِژٕ تھ أمِس مےٚ پٮ۪ٹھ فضیلت؟ اگر ژٕقیامت کِس دۅ ہس تام مہلت دِکھ،تیٚلہِ کرٕ بہٕ أمۍ سٕندِس پوٗرٕ نسلس موٗلہٕ پرٛاٹَے، بس کمٕے لُکھ ہیٚکن مےٚ نِش بچِتھ۔"
  17,63,"۔اللہ تعالیٰ چُھس فر ماوان ،  اچھا گژھ ژٕ ، یِمو منٛزٕ یِم تہِ چٲنۍ پیروی کرن، ژےٚ سان چُھ تِمن سارِنٕے جہنمٕے بھر پوٗر جزا۔"
  17,64,"۔ژٕ یُس یُس پننہِ دعوت سٍتۍ پھسِلٲوِتھ ہیکہَن ،پھسِلاوُن، یِمن پٮ۪ٹھ کھا لُکھ  پنٕنۍ سوار تہٕ پیادٕہ، مالن تہٕ اولادن منٛز کر یِمن سٍتۍ شراکت، تہٕ یِم پھساوُکھ وعد ن ہٕندِس زالس منٛز، تہٕ شیطان سٕندۍ وعدٕہ چِھنہٕ اکہِ دو کھہٕ ورٲے کِہِنۍ۔"
  17,65,"۔یقیناً گٔژھی نہٕ ژےٚ میانیٚن بند ن پٮ۪ٹھ کانٛہہ اقتدار حٲصل، تہٕ تو کُّل خٲطرٕ چُھ چو ن ربّ کٲفی۔"
  17,66,"۔تُہُند﴿ حقیقی ﴾ ربّ چُھ سُہ یُس سمندرس منٛز تُہٕنز ناو چُھ چلاوان،تاکہ توٚہۍ کٔرِ و تٔمۍ سُند فضل تلا ش۔حقیقت چھےٚ یہِ زِ سُہ چُھ تُہندِس حالس پٮ۪ٹھ سٮ۪ٹھاہ مہر بان ۔"
  17,67,"۔ییٚلہِ سمندرس منٛز تۅہیہِ پٮ۪ٹھ کانٛہہ مصیبت چُھ یِوان ، تس أکِس ورٲے یِمن یِمن با قیَن توٚہۍ ناد لایان چِھو، تِم سٲری چِھو راوان، مگر ییٚلہِ سُہ تۅہیہِ بچٲوِتھ خشکی  پٮ۪ٹھ چُھو واتناوان، پتہٕ چِھو توٚہۍ تس نِشہِ بُتھ پھران۔انسان چُھ پٔزِ پٲٹھۍ نا شکر۔"
  17,68,"۔اچھا، کیا توٚہۍ چِھوٕ ہ اَمہِ کتھہِ نِشہِ با لکل بے خو ف زِ خُدا ے ہیٚکیو تۅہیہِ خشکی پٮ۪ٹھٕے زمینس وٲلِتھ،یا ہیٚکہِ تۅہیہِ پٮ۪ٹھ پتھراو کر ن وول واوٕ طو فان سوٗزِ تھ، تہٕ تۅہیہِ میلیو نہٕ امہِ نِشہِ بچا ون وول کانٛہہ مددگار؟"
  17,69,"۔تہٕ کیا تۅہیہِ چُھو و نا اَمِیُک اندیشہِ زِ خُدا ے نِیَو بیٚیہِ کُنہِ ساعتہٕ تۅ ہیہِ سمندرس منٛز، پتہٕ سوزِ تۅہیہِ پٮ۪ٹھ سخت طو فٲنی ہوا، تہٕ تُہنزِ نا شکر ی ہٕندِ بد لہٕ کر یو تۅہیہِ غر ق،تہٕ تۅہیہِ میلیو نہٕ تِیُتھ کانٛہہ یُس تس تُہٕندِ امہِ انجا مٕچ پرٛژھہٕ گٲرِ کٔرِ تھ ہیٚکہِ؟"
  17,70,"۔ یہِ چَھو سٲنۍ عنا یت زِ اَسہِ دِژ بنی آد مس بُزر گی ، تہٕ تِمن کرِ خشکی تہٕ آبس منٛز سوارِ عطا ، تہٕ تِمن دِیُت پا کیزٕ ہ چیز و منٛزٕ رزق، تہٕ پننیٚن واریاہن مخلو قن پٮ۪ٹھ کٔرٕ کھ فضیلت عطا ۔ع۔"
  17,71,"۔پتہٕ کٔرِ یو خیا ل تمہِ دۅ ہُک ،ییٚلہِ أسۍ پرٛ تھ کانٛہہ انسٲنی دوٚر بُلا وون پننِس  پیشوا ہس سان،تمہِ وقتہٕ یِمن لُکن تِہُند نامۂ اعمال دٔچِھنس اتھس منٛز دِنہٕ آو ، تِم پر ن پنُن کار نامہٕ تہٕ تِمن پٮ۪ٹھ سپدِ نہٕ ذرّ س برابر ظُلم۔"
  17,72,"۔تہٕ یُس یَتھ دُنیا ہس منٛز اوٚن بٔنِتھ روٗد،سُہ روزِ ٲخرتس منٛز تہِ اوٚ نُے،بلکہ وَتھ لبنس منٛز أنۍ سٕندۍ کھۅتہٕ تہِ زیادہ ناکام۔"
  17,73,"۔اے نبی صلی اللہ علیہ وسلم، یِمو لُکو تھٲونہٕ اتھ کوٗششہِ منٛز کانٛہہ کسر پتھ کُن زِ تۅہیہِ پھِر ہا نَو فتِنس منٛز ترٲوِتھ تَمہِ وَحی نِشہِ پوٚت، یۅسہٕ اسہِ تۅہیہِ کُن چھےٚ سوٗز مٕژ، تاکہ توٚہۍ بنٲوِہِو سٲنِس ناوس پٮ۪ٹھ پننہِ طر فہٕ کانٛہہ کتھ اگر توٚہۍ یہِ کٔرِ ہِو ،تیٚلہِ بناو ہَن تِم ضروٗر تۅہیہِ پنُن دوست۔"
  17,74,"۔تہٕ یہِ کتھ ٲس نہٕ دوٗر زِ اگر أسۍ توٚہۍ مضبو ط تھا و ہَو نہٕ، تیٚلہِ نر مِہو توٚہۍ کینٛہہ نتہٕ کینٛہہ تِمن کُن۔"
  17,75,"۔البتہ اگر توٚہۍ یہِ کٔرِ ہِو ، تیلہِ ہاو ہَو أسۍ تۅہیہِ دُنیا ہس منٛز تہِ دۅ گنہٕ عذا بُک مزٕہ تہٕ ٲخرتس منز تہِ دۅ گنہٕ عذا بُک، پتہٕ لٔبِہِو نہٕ توٚہۍ سٲنِس مقا بلس  کانٛہہ مددگار۔"
  17,76,"۔تہٕ یِم لُکھ چِھ اتھ کتھہِ پٮ۪ٹھ تہِ ہوٚل گٔنڈِتھ روٗدِمٕتۍ زِ تُہٕندۍ قد م کڑ ہن ییٚمہِ سرزمین منٛزٕ تہٕ تۅہیہِ کڑہنو ییٚتہِ نیٚبر۔ البتہٕ اگر یِم لُکھ یہِ کر ن ، تیٚلہِ ہیٚکن نہٕ پتہٕ یِم پانہٕ زیادہ کا لس ییٚتہِ ٹھٔہرِ تھ۔"
  17,77,"۔یہِ چُھ سو ن مُستقل طر یقِ کار یُس اَسہِ تِمن سارِنٕے  رسولن ہٕندِس معا ملس منٛز ور تومُت چُھ، یِم تۅہیہِ برونٛہہ اسہِ سوٗزِ مٕتۍ ٲسۍ، تہٕ سٲنِس طر یقِ کارس منٛز وُچِھو نہٕ توٚہۍ کانٛہہ تبد یلی ۔ع"
  17,78,"۔ نماز کٔرِ و قٲیِم آفتاب کہ زوال پٮ۪ٹھہٕ رٲژ ہٕندِس اَنہِ گٔٹِس تام ﴿ اتھ منٛز چھےٚ ظہر نمازِ پٮ۪ٹھہٕ عشا نمازِ تام ژۅ شو ے نمازٕ یِوان ﴾ بیٚیہِ کٔرِوفجر کہ قرآنُک تہِ اِلتزام،تِکیازِ فجرُک قرآن چُھ مشہود آسان۔﴿فجر کہ قرآن نِشہِ چُھ مُراد فجر چہِ نمازِ منٛز قرآن پرُن تہٕ فجر کہ قرآن کہ مشہود آسنُک مطلب چُھ یہِ زِ اللہ تعالیٰ سٕندۍ فر شتہٕ چِھ خا ص پٲٹھۍ امِکۍ گواہ بنان تِکیازِ اتھ چھےٚ اکھ خا ص اہمیت حٲصل﴾"
  17,79,"۔تہٕ رٲژ ہُند تہجُد پٔرِو﴿تہجدس چُھ معنی نیندٕ ر پُھٹرٲوِتھ ووتُھن ۔ لہٰذا چُھ رٲژ ہٕندِ وقتہٕ تہجد پر نُک مطلب یہِ زِ رٲژ ہٕندِس أکِس حصس شۅ نگنہٕ پتہٕ گژِھہ بیدار سپدِ تھ نماز پرٕ نۍ﴾ یہِ چُھ تُہندِ خٲطرٕ نفل، یہِ کتھ چَھنہٕ دوٗر زِ تُہُند ربّ کرِ تۅہیہِ مقامِ محموٗدس پٮ۪ٹھ فٲیز۔﴿ یعنی دُنیا تہٕ ٲخرتس منٛز واتناو یو تۅہیہِ تِتھِس مر تبس پٮ۪ٹھ ییٚتہِ توٚہۍ محمو دِ خلٲیق روٗزِ و بٔنِتھ ،پرٛتھ طر فہٕ گژِھہ تۅہیہِ پٮ۪ٹھ مد ح تہٕ تعر یفن ہٕنز بٲرِش سپدٕ نۍ، تہٕ تُہٕنز ہستی گژِھہ اکھ قٲبِل تعر یف ہستی بٔنِتھ روزٕ نۍ ۔﴾"
  17,80,"۔ تہٕ دُعا کٔرِ و زِ پروردگارٕ، مےٚ یوٚت تہِ ژٕ نِکھ پز رٕ سان نِیہِ زیٚم، تہٕ ییٚتہِ تہِ کڑ ہم پز رٕ سان کٔڑِ زیٚم، تہٕ پننہِ طر فہٕ بناوُن اکھ اقتدار میو ن مددگار۔﴿ یعنی یا کر مےٚ خۅد پا نس اقتدار عطا، یا بناوُن کانٛہہ حکو مت میٲنۍ مددگار، تا کہ تمہِ کہ طا قت سٍتۍ ہیٚکن بہٕ دُنیا ہُک بِگاڑ دُرست کٔرِ تھ ،فحش کامہِ تہٕ گنا ہن ہُند یہِ سہلاب رُکا وہن تہٕ چو ن قا نو نِ عد ل ہیٚکہٕ ہن جٲر ی کٔرِ تھ۔﴾"
  17,81,"۔بییہِ کٔرِ و علا ن زِ  حق آو، تہٕ بٲطل مِٹیاو، با طل چُھ مِٹنہٕ خاطر ے۔"
  17,82,"۔أسۍ چِھ قرآن کِس یتھ نٲزل کر نہٕ کِس سلسلس منٛز تِکینژھاہ نٲزِل کران، یُس مانن والیٚن خٲطرٕ شِفا تہٕ  رحمت چُھ، مگر ظٲلِمن خٲطرٕ چُھنہٕ خسارٕہ ورٲے بیٚیہِ کُنہِ چیز س منٛز اضا فہٕ کران۔"
  17,83,"۔انسان سُند حال چُھ یہِ زِ ییٚلہِ أسۍ تس نعمت چِھ عطا کران،تیٚلہِ چُھ سُہ بُتھۍ پھِیرُ بنان تہٕ شانہٕ پھِران،تہٕ ییٚلہِ معمولی مصیبت چُھس یِوان ،تیٚلہِ چُھ غمگین گژھان۔"
  17,84,"۔اے نبی صلی اللہ علیہ وسلم، یِمن لُکن ؤنِو زِ  پرٛتھ کانٛہہ چُھ پننِس طر یقس پٮ۪ٹھ عمل کران، وۅ نۍ چُھ یہِ صرف تُہُند ربّ بہتر زانان،زِ سیٚزِ وَتہِ پٮ۪ٹھ کُس چُھ۔ ع"
  17,85,"۔یِم لُکھ چِھو تۅہیہِ رُو حس متعلق پٕرٛژھان۔ؤنِو  یہِ رُو ح چُھ میٲنِس ربّ سٕندِ حُکمہٕ سٍتۍ یِوان، مگر تۅہیہِ لُکن چُھو کٕمے پہن علم دِنہٕ آمُت۔﴿عام پٲٹھۍ چُھ یہِ سمجھنہٕ یِوان زِ یتھ جایہِ چُھ رُو ح نِشہِ مُراد زُو۔یعنی لُکو اوس نبی صلی اللہ علیہ وسلمس رُو حِ حیاتس متعلق پُرٛژھمُت زِ امِچ حقیقت کیا چھےٚ ،تہٕ امِیُک جواب آو یہِ دِنہٕ زِ سُہ چُھ اللہ تعالیٰ سٕندِ حُکمہٕ سٍتۍ یِوان۔البتہ اگر ربط عبارت  در نظر تھا وون،تیٚلہِ چُھ  صا ف با سان زِ یتھ جایہِ چُھ رُو ح مُراد،رُوحِ نبوّت یاوَحی ۔تہٕ یٔہے کتھ چھےٚ سورہ نحل آیت،2، سورۂ مو من آیت، 15، تہٕ سوٗرۂ شوریٰ آیت ، 52 ، ہَس منٛز بیا ن سپٕز مٕژ۔ سلفَو منٛزٕ چُھ ابنِ عبا س رضی اللہ عنہہ، قتادہ تہٕ حسن بصر ی رحمہم اللہ ہَو تہِ یۅ ہے تفسیر اختیار کوٚر مُت، تہٕ صا حبِ رُو ح المعا نی چِھ حسن تہٕ قتادہ سُند یہِ قو ل نقل کران زِ رُو ح نِشہِ چُھ مُراد جبر یل علیہ السلام ،تہٕ سوال اوس در اصل یہِ زِ تِم کِتھہٕ پٲٹھۍ چھِ  نٲزل سپدان تہٕ کِتھہٕ پٲٹھۍ چھُ نبی صلی اللہ علیہ وسلمن ہٕندِس دلِ مُبارکس پٮ۪ٹھ وَحی ہُند القا  سپدان۔﴾"
  17,86,"۔تہٕ اے نبی صلی اللہ علیہ وسلم ، اگر أسۍ ییٚژھو، سورُے نِمو تۅہیہِ وا پس یہِ وحی ہٕندِ ذریعہ اسہِ تۅہیہِ عطا چُھو کوٚر مُت،پتہٕ لٔبِونہٕ توٚہۍ سٲنِس مقا بلس منٛز کانٛہہ حما یتی یُس اتھ واپس ہیکہِ دِیٲوِتھ۔"
  17,87,"۔یِکینژھاہ یہِ تۅہیہِ میوٗلمُت چُھو،یہِ چُھو تُہٕندِس ربّ سٕندِ رحمت سٍتۍ میوٗلمُت،حقیقت چھےٚ یہِ زِ تٔمۍ سُند چُھ تۅہیہِ پٮ۪ٹھ بوٚڈ فضل۔"
  17,88,"۔ؤنِو زِ اگر انسان تہٕ جِن اند ہیٚتھ سٲر ی سٔمِتھ یتھ قرآنس ہیوٗ کانٛہہ چیز اننٕچ کوٗشش کر ن، یتھ ہِیوٗ ہیٚکن نہٕ أنِتھ، خوا ہ تِم سٲری کو نہٕ آسن اکھ أکۍ سٕندۍ مدد گارٕے۔"
  17,89,"۔اسہِ سمجھٲوۍ رنگہٕ رنگہٕ یتھ قرآنس منٛز لُکھ، مگر اکثر لُکھ روٗدۍ انکارس پٮ۪ٹھٕے ڈٔٹِتھ۔"
  17,90,"۔تہٕ تِمو ووٚن  أسۍ مانَو نہٕ چٲنۍ کتھ، یوٚت تام نہٕ ژٕ سانہِ خٲطرٕ زمین پھا سوِ تھ اکھ ناگ جٲر ی کر کھ۔"
  17,91,"۔یا گژِھہ چانہِ خٲطرکھٔزر ن تہٕ دَچھہِ ہُند اکھ با غ پٲدٕ سپدُن ، تہٕ ژٕ گژھکھ تتھ منٛز کۅ لہٕ پکنا وُن۔"
  17,92,"۔یا گژھکھ ژٕ آسما نس ٹُکرٕ ٹکرٕکٔرِ تھ اسہِ پٮ۪ٹھ گرِ اوُن، یِتھہٕ پٲٹھۍ زن چو ن دعویٰ چُھ، یا گژھکھ اللہ تعالیٰ تہٕ فر شتہٕ رُوبَر اَسہِ برونٛہہ کُن اَنُن۔"
  17,93,"۔یا گژِھہ چانہِ خٲطرٕ سۅ نہٕ سُند اکھ مکا نہٕ بنُن یا گژھکھ ژٕ آسما نس پٮ۪ٹھ کھسُن، تہٕ چٲنِس کھسنس تہِ کر و نہٕ أسۍ پژھ،یوٚت تام نہٕ ژٕ اسہِ پٮ۪ٹھ تِیُتھ تحر یر وٲلِتھ اَنکھ یُس أسۍ پَرو۔ اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو پاک چُھ میو ن پروردگار!، کیا بہٕ چُھسہٕ أکِس پیغام اَنن وٲلِس انسان سٕندِ ورٲے بیٚیہِ تہِ کینٛہہ۔  ع"
  17,94,"۔لُکن برونٛہہ کُن ییٚلہِ تہِ زانٛہہ ہدا یت آو ، تہٕ تِم رُکٲوۍ نہٕ اَتھ پٮ۪ٹھ ایمان اَننہٕ نِشہِ کُنہِ چیزن، مگر بس تِہِندۍ أمۍ وَنن زِ  کیا خُدا ین سوٗز ااکھ بشر پیغمبر بنٲوِ تھ؟"
  17,95,"۔یِمن ؤنِو زِ اگر زمینس منٛز فر شتہٕ آسٕہَن اطمیانہٕ سان پھیران تھوران تیٚلہِ سوز ہو ن أسۍ ضروٗر آسما نہٕ پٮ۪ٹھے کانٛہہ فرشتہٕ تِہندِ خٲطرٕ پیغمبر بنٲوِتھ۔"
  17,96,"۔اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو زِ مےٚ تہٕ تۅہیہِ در میان چھےٚ بس أکِس اللہ تعالیٰ سٕنزٕ ے گوٲہی سٮ۪ٹھاہ، سُہ چُھ پننیٚن بند ن ہٕندِ حالہٕ نِشہِ با خبر تہٕ سورُے کینٛہہ چُھ وُچھان۔"
  17,97,"۔یس اللہ تعالیٰ ہدایت دِیہِ ، سُے چُھ ہدا یت لبن وول، تہٕ یس سُہ گمرٲہی منٛز تراوِ، تیٚلہِ ہیٚکِو نہٕ تس ورٲے تِتھیٚن لُکن خٲطرٕ کانٛہہ حما یت کر ن وول تہٕ مددگار لٔبِتھ۔یِم لُکھ اَنو کھ أسۍ قیامت کہ دۅہ بُتھۍ کھکھرِ لٔمِتھ،أنۍ، کٔلۍ تہٕ زٔرۍ، تِہُند ٹھکا نہٕ چُھ جہنم، ییٚلہِ کُنہِ وِزِ تمِیُک نار کم ہیٚیہِ سپدُن، أسۍ تُلو تھتھ بیٚیہِ ریٚہہ۔"
  17,98,"۔یہِ چُھ بد لہٕ تِہندِ تمہِ حر کتُک زِ تِمو کوٚر سا نیٚن آیاتن انکار،تہٕ ووٚ نُکھ  کیا ییٚلہِ أسۍ صرف أڈجہِ تہٕ میٚژ بَنو،تیٚلہِ یِموٕ ہ أسۍ پتہٕ نوِ سرٕ پٲدٕ کٔرِ تھ کھڑا کر نہٕ ؟"
  17,99,"۔کیا یِمن توٚر نا یہِ فِکرِ زِ ییٚمۍ خُدا ین زمین تہٕ آسمان چِھ پٲدٕ کٔرِ مٕتۍ، سُہ چُھ ضرور یِتھیٚن ہِو ٮ۪ن پٲدٕ کر نٕچ قدرت تھاوان، تٔمۍ چُھ یِہندِ حشرٕ خٲطرٕ اکھ وقت مقرر کوٚر مُت، ییٚمیُک یُن یقینی چُھ، مگر ظٲلِمن چُھ اصرا ر زِ تِم روزن اَتھ اِنکارٕ ے کران۔"
  17,100,"۔اے نبی صلی اللہ وسلم،یِمن ؤنِو ہرگاہ میٲنِس ربّ سٕندِ رحمتٕکۍ خزانہٕ تُہٕندِس قبضس منٛز آسٕہَن، تیٚلہِ رُکٲوِ ہوٗکھ ضروٗر تِم خر چ سپد ن کہِ اند یشہِ کِنۍ، پٔزِ پٲٹھۍ چُھ انسان سٮ۪ٹھاہ تنگ دل ثٲبت سپُد مُت۔ع۔﴿مُشر کینِ مکہ یِمو نفسٲنی وُجو ہا تو کِنۍ نبی صلی اللہ علیہ وسلمن ہٕندِ نبوّت تُک انکار ٲسۍ کران،تِمو منٛزٕ اوس اکھ اہم وجہ یہِ زِ یِتھہٕ پٲٹھۍ اوس تِمن نبی صلی اللہ علیہ وسلمن ہُند فضل تہٕ شر ف مانُن پیٚوان ، تہٕ پننِس کٲنٛسہِ ہم عصر تہٕ برابر ی وٲلۍ سُند فضل تہٕ بجر ماننہٕ خٲطرٕ چُھ انسان مشکل نٕے آمادہ سپدان۔أتھۍ پٮ۪ٹھ چُھ یِوان فر ماو نہٕ زِ یِمن لُکن ہٕنزِ بخیلی ہُند حال یہِ چُھ،زِ کٲنٛسہِ ہٕندِ وا قعی مر تبُک  اقرار و اعترا ف کران کران چُھ تِہُند دِل دُکھان، اگر یِمن خُدا ین آسٕہَن پننیٚن رحمت کیٚن خزا نن ہٕنزٕ کُنزٕ حوالہٕ کرِ مژٕ ،تیٚلہِ دِہن نہٕ تِم کٲنٛسہِ کھٔنڈ ہار تہِ ۔﴾"
  17,101,"۔اَسہِ آسہٕ مو سیٰ ﴿علیہ السلامس﴾ نَو نشٲنِیہِ عطا کرِ مژٕ، یِمہٕ ٹا کارٕ ہ آسہٕ اتھہِ یِوان ﴿ یِمن نَون نشٲنِین ہُند تفصیل چُھ سورۂ اعرا فس منٛز پتھ کُن وَننہٕ آمُت۔﴾ وۅ نۍ پٕرٛژِھو خۅد بنی اسرا یلس زِ ییٚلہِ مو سیٰ علیہ السلام  تِمن نِشہِ آو،تہٕ فر عو نن او سنا یی ووٚ نمُت زِ  اے مو سیٰ علیہ السلام، مےٚ چُھ باسان زِ ژٕ چُھکھ ضرور اکھ جٲدۍ لد اِنسان۔"
  17,102,"۔مو سیٰ ﴿علیہ السلامن﴾ ووٚن امہِ کِس جوا بس منٛز زِ ، ژٕ چُھکھ ٹھیک پٲٹھۍ زانان زِ یِمہٕ بصیرت افر وز نشٲنیہِ چَھنہٕ زمین تہٕ آسمانن ہٕندِس ربّس ورٲے بیٚیہِ کٲنٛسہِ نٲزِل کرِ مژٕ﴿یہِ کتھ فر مٲو حضرت مو سیٰ علیہ السلامن امہِ موجو ب زِ أکِس پوٗرٕ ملکس منٛز قحط وۅ تُھن ، یا لچھِ بٔدِس مر بع میل زمینس پٮ۪ٹھ پھٔہلِتھ علا قن منٛز مِنہِ مۅ نڈ جن ہُند أکِس بلا یہِ ہٕندۍ پٲٹھۍ نیرُن، یا تمام ملک کِس انا جس گۅدا من منٛز کِیوٚ م لُکن، تہٕ یِتھی ہِوۍ با قی عام مشکلا ت ہیٚکن نہٕ کٲنٛسہِ جادو گر سٕندِ جادِ سٍتۍ یا کُنہِ انسٲنی طا قت کہ کر تب سٍتۍ رُو نما سپدِ تھ۔جادو گر ہیٚکہِ صرف أکِس محدوٗد﴿جایہِ ﴾ لُکہٕ ہجو م چن نظر ن پٮ۪ٹھ سحر کٔرِتھ تِمن کینٛہہ کر تب ہٲوِتھ، تہٕ تِم تہِ چِھنہٕ حقیقت آسان ،بلکہ چِھ نظرِ ہٕندۍ دۅ کھہٕ آسان ﴾ تہٕ میو ن خیال چُھ یہِ زِ اے فر عو ن ، ژٕ چُھکھ ضرور اکھ شہمٕژ لَد انسان ۔"
  17,103,"۔ٲخر کار کوٚر فر عو نن ارادٕہ زِ مو سیٰ علیہ السلام تہٕ بنی اسرا یلس کڑِ ﴿مصرٕ کہ﴾ زمینہٕ منٛزٕ موٗلَو، مگر اَسہِ کوٚر سُہ تہٕ تٔمۍ سٕندۍ سٲتھی یِکہٕ وَٹہٕ غر ق۔"
  17,104,"۔ تہٕ اَمہِ پتہٕ ووٚن بنی اسرا یلس زِ وۅ نۍ بٔسِو توٚہۍ زمینس پٮ۪ٹھ۔پتہٕ ییٚلہِ ٲخرتُک وقت واتہِ، تیٚلہِ کرو أسۍ سٲری یِکہٕ وَٹہٕ أنِتھ حٲضر ۔"
  17,105,"۔یہِ قرآن چُھ اَسہِ حق ہیٚتھ نٲزِل کوٚر مُت تہٕ حق ہیٚتھٕے چُھ یہِ نٲزِل سپُد مُت،تہٕ اے نبی صلی اللہ علیہ وسلم، توٚہۍ چِھو نہٕ اَسہِ امہِ ورٲے بیٚیہِ کُنہِ کامہِ خٲطرٕ سوٗزِ مٕتۍ زِ ﴿یُس مانہِ تس ﴾ دِیو بشارت تہٕ ﴿یُس نہٕ مانہِ سُہ ﴾کٔرِ یوٗن خبردار۔"
  17,106,"۔تہٕ یہِ قرآن چُھ اسہِ ہنہِ ہنہِ نٲزِل کوٚر مُت، تا کہ توٚہۍ بوز نٲوِ یوٗکھ لُکھ یہِ وارٕ وارٕ، تہٕ یہِ چُھ اَسہِ ﴿وقتہٕ وقتہٕ﴾ در جہ بدر جہ نٲزِل کوٚر مُت۔"
  17,107,"۔اے نبی صلی اللہ علیہ وسلم ، یِمن لُکن ؤنِو زِ توٚہۍ مٲنۍ تَو یہِ یا مَتہٕ مٲنۍ تَو، یِمن لُکن ییٚمہِ برونٛہہ علم چُھ دِنہٕ آمُت،تِمن ییٚلہِ یہِ بوزناو نہٕ چُھ یِوان، تیٚلہِ چِھ تِم بُتھہِ کِنۍ سجدس وسان،"
  17,108,"۔تہٕ نِیرتِھ چُھکھ ژَلان پاک چُھ سو ن ربّ، تٔمۍ سٕندِس وعدس اوس پوٗرٕ گژھُنے۔ تہٕ تِم چِھ بُتھۍ کِنۍ ودان ودان پیٚوان،"
  17,109,"۔تہٕ یہِ بوٗزِتھ چُھ تِہُند خشو ع ﴿خُدا  ے سُند خو ف ﴾ بیٚیہِ ہُران۔﴿سجدٕہ﴾۔"
  17,110,"۔اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو  اللہ ؤنِتھ کٔرِ تَو آلو ، یا رحمٰن ؤنِتھ، ییٚمہِ ناوٕ ناد لٲیِو، تٔمۍ   سٕندِ خٲطرٕ چِھ سٲرۍ ناورٕتی﴿یہِ چُھ جوا ب مکہ کیٚن مُشر کن ہٕندِ تمہِ اعترا ضُک زِ خا لق سٕندِ خٲطرٕ اوس اللہ  ناو اَسہِ بوٗزمُت ، مگر یہِ  رحمان سُند ناو کتہِ کوٚڑُو تۅہیہِ؟ تتہِ اوس  نہٕ چو نکہ اللہ تعالیٰ سٕندِ خٲطرٕ یہِ ناو رٲیج کینٛہہ ، امہِ موجوب ٲس تِمن اتھ پٮ۪ٹھ نس کھسان ﴾ تہٕ پنٕنۍ نماز نَہ مَہ پٔرِ وزیادٕہ تھزِ آو ازِ منٛز، تہٕ نَہ مَہ پٔزِ وزیادہ لۅ ژِ آوا زِ منٛز، یِمن دۅ شوٕ نۍ در میان کٔرِ و در میانہٕ در جُک  لہجہِ اختیار۔ ﴿ابنِ عبا س رضی اللہ عنہ چِھ فر ماوان زِ ییٚلہِ مکّس منٛز نبی صلی اللہ علیہ وسلم یا با قی صحا بہ رضی اللہ عنہم نماز پر نہٕ وقتہٕ بُلند آوازِ منٛز قرآن ٲسۍ پران، کُفار ٲسۍ لاگان شو ر کرُن ،تہٕ کُنہِ وِزِ ٲسۍ لیٚکہٕ ژا ر نہِ لاگان۔اتھ پٮ۪ٹھ سپُد حکم زِ نَہ مَہ پٔرِ و تیوٗتاہ زورٕ سان زِ کُفار  بوزن تہٕ کر ن ہجو م ،تہٕ نَہ مَہ پٔرِو تیوٗتاہ لۅ تہِ زِ تُہٕندۍ پنٕنۍ سٲتھی تہِ بوزن نہٕ ۔یہِ حکم اوس صرف تِمنٕے حالاتن خٲطرٕ ،ییٚلہِ مد ینس منٛز حالات بد لیے  پتہٕ روٗد نہٕ یہِ حکم ، البتہ ییٚلہِ کُنہِ وِزِ مُسلمانن مکہٕ کیٚن حالاتن سٍتۍ بُتھۍ لاگے کرٕ نۍ پیٚیہِ ،تیٚلہِ پزِ تِمن أتھۍ ہدا یتس مطا بق عمل کرٕنۍ ﴾"
  17,111,"۔بیٚیہِ ؤنِو  حمد چُھ تس خُدایس خٲطرٕ ییٚمۍ نَہ کانٛہہ پنُن نچُو بنو و ،تہٕ نَہ چُھ با دشٲہی منٛز تس کانٛہہ شر یک، تہٕ نَہ چُھ سُہ عٲجز زِ کانٛہہ آسہِ تس مددگار۔ تہٕ تٔمۍ سُند  بجر کٔرِ و بیان ، تھَدِ پا یُک بجر۔ ع"
