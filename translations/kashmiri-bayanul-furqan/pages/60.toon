quran[13]{c,v,t}:
  60,1,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت۔ ﴿ مُفسِر ن ہُند چُھ اتھ کتھہِ پٮ۪ٹھ اتفاق زِ یِم آیات ٲسۍ تمہِ ساعتہٕ نٲزِل سپٕدمٕتۍ ییٚلہِ مکہٕ کیٚن مشر کن ہٕندِناوٕ حا طِب بن ابی بلتعہ رضی اللہ عنہ سُند خط رَٹنہٕ آو ، یتھ منٛز تِمو قبل اَز وقت دُشمن ٲسۍ مُطلع کٔرِ مٕتۍ زِ رسول اللہ صلی اللہ علیہ وسلم چِھ مکّس پٮ۪ٹھ حملہٕ کر ن وٲلۍ۔﴾ مَہ بنٲوِ یوٗکھ میٲنۍ تہٕ پنٕنۍ دشمن دوست ۔توٚہۍ چِھو تِمن دوستی ہُند پیغام سوزان، حالانکہ یُس حق تۅہیہِ نِشہِ ووتمُت چُھ، سُہ ماننہٕ نِشہِ چُھ تِمَو انکار کوٚر مُت۔تہٕ تِہٕنز رٔوِش چھےٚ یہِ زِ تِم چِھ رسول صلی اللہ علیہ وسلمس تہٕ خۅد تۅہیہِ صرف اَتھ قصورس پٮ۪ٹھ جلا وطن کران زِ تۅہیہِ چُھو پننِس ربّس ،خدا یس پٮ۪ٹھ ایمان اوٚ نمُت ﴿ لہٰذا مَہ کٔرِ و تِمن سٍتۍ دوستی﴾ اگر توٚہۍ میانہِ وَتہِ منٛز جہا د کر نہٕ خٲطرٕ تہٕ میانہِ رضا خٲطرٕ ﴿ وطن ترٲوِتھ گھر و منٛزٕ ﴾ درٛا مٕتۍ چِھو۔ توٚہۍ چِھو ژوٗرِ پٲٹھۍ تِمن دوستی ہُنٛد پیغام سوزان، حالانکہ یِکینٛژھاہ توٚہۍ ژوٗرِ پٲٹھۍ چِھو کران تہٕ یِکینٛژھاہ نَنہِ وانہٕ چِھو کران، پرٛتھ کانٛہہ چیز چُھس بہٕ وارٕ پٲٹھۍ زانان۔ یُس شخص تہِ تۅہیہِ منٛزٕ یہِ کرِ۔ سُہ ڈوٚل پٔزِ پٲٹھۍ سیٚزِ وَتہِ نِشہِ ۔"
  60,2,"۔تِہُند رٔوِیہِ چُھ یہِ زِ اگر تۅہیہِ پٮ۪ٹھ قا بو حٲصل گژھیٚکھ ،تیٚلہِ کر ن تۅہیہِ سٍتۍ دشمنی، تہٕ اَتھو تہٕ زیٚوِ سٍتۍ دِ نَو بُرٲیی سان آزار۔ تِم چِھ یی یژھان زِ کُنہِ پٲٹھۍ گٔژِھو توٚہۍ کٲفر سپدٕنۍ۔"
  60,3,"۔قیا مت کہ دۅہ نَہ یِن تُہٕنزٕ رشتہٕ دٲر یہِ کُنہِ بکا ر تہٕ نَہ تُہندۍ اولاد۔﴿چو نکہ حضر ت حاطِب رضی اللہ عنہ ہَن ٲس یہِ کٲم امہِ مو جو ب کٔر مٕژ زِ مکّس منٛز یُس تِہُند اہلِ عیا ل اوس سُہ گوٚژھ جنگ کِس مو قعس پٮ۪ٹھ محفو ظ روزُن ۔اَمہِ مو جو ب آو فر ما و نہٕ زِ ییٚمہِ آل اولادٕ خٲطرٕ ژےٚ یہِ کٲم کٔرِ تھ سُہ چُھنہٕ ٲخرتس منٛز بکار یِنہٕ وول ۔ ﴾ تمہِ دۅہ ترٛا وِ اللہ تعالیٰ تۅہیہِ در میان جُدٲیی،﴿یعنی دُنیا ہٕکۍ تمام رشتہٕ تعلقات تہٕ رابطہٕ یِن تَتہِ پُھٹراونہٕ۔ ہر کانٛہہ شخص سپدِ پننِس ذٲتی حیثیتس منٛز پیش تہٕ پرٛتھ کٲنٛسہِ آسہِ پننُے یوت حسا ب دِیُن۔لہٰذا پزِ نہٕ دُنیا ہس منٛز کٲنٛسہِ أکِس تہِ کُنہِ رشتہٕ دٲری یا دوستی یا جتّھ بند ی خٲطرٕ کانٛہہ نا جٲیز کٲم کرٕ نۍ، تِکیازِ پننہِ کرِ مَتِیُک سزا آسہِ تس پا نسٕے تُلُن،أمۍ سٕنزِ ذٲتی ذمہ دٲری منٛز سپدِ نہٕ بیٚیہِ کانٛہہ شر یک ﴾ تہٕ سُے چُھ تُہندٮ۪ن اعمالن ہُند وُچھن وول۔"
  60,4,"۔ تۅہیہِ لُکن خٲطرٕ چُھ ابراہیم علیہ السلام تہٕ تٔمۍ سٕندٮ۪ن سٲتھِیَن منٛز اکھ رُت نمو نہٕ، تِمو ووٚن پننِس قو مَس صا ف ""أسۍ چِھ پورٕ پٲٹھۍ بے زارتۅہیہِ تہٕ تِمن تُہٕندٮ۪ن معبوٗدن یِم توٚہۍ اللہ تعالیٰ ترٲوِتھ پوٗزان چھوٗکھ، اسہِ کوٚر تۅہیہِ سٍتۍ کُفُر ﴿یعنی أسۍ چِھ تُہٕندۍ کٲفر ، أسۍ نہ چِھو توٚہۍ حقس پٮ۪ٹھ مانان تہٕ نہ تُہُند دین ﴾ تہٕ اسہِ تہٕ تۅہیہِ در میان گوٚو ہمیشہ خٲطرٕ عداوت تہٕ مُژُ کر ی،یوٚت تام نہٕ توٚہۍ کُنِس خدایس پٮ۪ٹھ ایمان أنِو۔"" مگر ابراہیم علیہ السلام سُند پننِس مٲلِس یہِ وَنُن ﴿ چُھ امہِ نِشہِ مُستثنٰی ﴾ زِ "" بہٕ کرٕ تُہند خٲطرٕ ضروٗر مغفر تُک در خوا ست، تہٕ خُدایس نِشہِ  کینٛہہ حٲصل کرُن چُھنہٕ مےٚ تام""۔ ﴿دوٚ یِمیٚن لفظن منٛز چُھ امیُک یہِ مطلب زِ تُہندِ خٲطرٕ چھےٚ حضر ت ابرا ہیم علیہ السلامن ہٕنز یہِ کتھ قٲبل تقلید زِ تِمو کوٚر پننِس مُشر ک تہٕ کٲفر قومس صاف صاف بے زٲری ہُنٛد تہٕ تعلق ژٹنُک اعلان،مگر تِہٕنز یہِ کتھ چھَنہٕ تقلیدس قٲبل زِ تِمَو کوٚر پننِس مشرک مٲلۍ سٕندِ خٲطرٕ دُعا کر نُک وعدٕہ تہٕ عملاً کوٚرُکھ تٔمۍ سٕندِس حقس منٛز دُعا۔تہٕ ابراہیم علیہ السلامن تہٕ اصحابِ ابراہیمن ہُند دعا اوس یہِ زِ ﴾"" اے سانہِ ربّہٕ ، ژےٚ پٮ۪ٹھ کوٚر اَسہِ بھر و سہٕ تہٕ ژیے کُن کوٚر اَسہِ رجوع تہٕ چٲنۍ سٕے در بارس منٛز چُھ اسہِ واپس پھیرُن۔"
  60,5,"۔ اے سا نہِ ربّہٕ ، اسہِ مَہ بناو کٲفرن خٲطرٕ فِتنہٕ۔﴿کٲفر ن خٲطرٕ اہلِ ایمانن ہٕندِس فِتنہٕ بَننَس ہیٚکن واریاہ صوٗرتہٕ ٲسِتھ ۔مثلاً یہِ زِ کٲفر یِن یِمن پٮ۪ٹھ غٲلب تہٕ پننِس غلبس دِن امہِ کتھہِ ہٕنز دلیل قرار زِ أسۍ چِھ حقس پٮ۪ٹھ تہٕ اہلِ ایمان چِھ برسرِ بٲطِل۔نَتہٕ یہِ زِ اہلِ ایمانن پٮ۪ٹھ بَڈِ کٲفر ن ہُند ظُلم و ستم تِہندِ برداشت کہ حدٕ کھۅتہٕ  ژوٚر ، تہٕ ٲخر کار ییٚلہِ تِم تِمن نِشہِ پھُٹن تہٕ پتہٕ گژھن پننہِ دین و اخلا قُک سودا کر نہٕ مۅکھہٕ مجبو ر۔ نَتہٕ یہِ زِ دین حق کِس نُما یند گی ہٕندِس بُلند مقا مس پٮ۪ٹھ فٲیز سپد نہٕ با وجود آسن اہلِ ایمان تمہِ اخلا قی فضیلت نِشہِ محروم یۅسہِ اَمہِ مُقا مہٕ خٲطرٕ شایانِ چھےٚ تہٕ دُنیا ہس یِن یِہندِ س سیر ت و کردارس منٛز تِمے عیب اَتھہِ یِم جٲہلیت کِس مُعا شرس منٛز عام پٲٹھۍ پٔھہلِتھ آسن۔امہِ سٍتۍ میلہِ کٲفر ن یہِ ونُک مو قع زِ اتھ دینس منٛز کیا خوبی چھےٚ ٲخر سۅ یۅ سہٕ اَتھ سٲنِس کُفرس پٮ۪ٹھ شر ف آسہِ عطا کران؟﴾ تہٕ اے سانہِ ربّہٕ ، سانیٚن قصورن کردرگُزر، بے شک چُھکھ ژٕے زبردست تہٕ دانا۔"""
  60,6,"۔یِمنٕے لُکن ہٕندِس طر زِ عملس منٛز چُھ تُہندِ خٲطرٕ بیٚیہِ پرٛتھ تس شخصس خٲطرٕ رُت نمو نہٕ، یُس اللہ تعالیٰ سُند تہٕ ٲخرت کہ دۅ ہُک اُمید وار آسہِ ۔ تہٕ اگر اَمہِ نِشہِ کانٛہہ بُتھ آسہِ پھِران، تیٚلہِ چُھ اللہ تعالیٰ بے نیاز تہٕ پننِس ذا تس منٛز چُھ پا نہٕ محمو د۔ع"
  60,7,"۔دوٗر چُھنہٕ زِ اللہ تعالیٰ تراوِ تۅہیہِ تہٕ تِمن لُکن در میان محبت یِمن سٍتۍ اَز تۅہیہِ دُشمنی چَھو موٚلۍ ہِیٔژ مٕژ۔﴿پٮ۪ٹھہٕ کنہِ کیٚن آیتن منٛز چھےٚ مُسلمانن پننیٚن کٲفر رِشتہٕ دارن سٍتۍ تعلق ژٹنُک تلقین کر نہٕ پتہٕ یہِ اُمید تہِ دِنہٕ آمٕژ زِ تِیُتھ وقت تہِ ہیٚکہِ یِتھ ییٚلہِ تُہٕندۍ یِمے رشتہٕ دار بنَن مسلمان ،تہٕ أزِچ دشمنی گژِھہ پتہٕ محبتس منٛز تبدیل ﴾ اللہ تعالیٰ چُھ قدرت تھا وان بیٚیہِ چُھ سُہ بخشن وول تہٕ رحم کر ن وول۔"
  60,8,"۔اللہ تعالیٰ چُھو نہٕ تۅہیہِ امہِ کتھہِ نِشہِ رُکاوان زِ یِمو دین کِس معا ملس منٛز تۅہیہِ سٍتۍ جنگ چُھنہٕ کوٚر مُت،تہٕ یِمو توٚہۍ چَھہَو نہٕ پننیو گھر و منٛز کٔڑِ مٕتۍ، زِ توٚہۍ کٔرِ و تِمن لُکن سٍتۍ نیکی تہٕ انصا فُک وَرتاو۔ اللہ تعالیٰ چُھ انصا ف کر ن والیٚن پسند کران، ﴿مطلب چُھ یہِ زِ یُس شخص تۅہیہِ سٍتۍ عداوت چُھنہٕ ورتاوان ، انصا فُک تقا ضہٕ چُھ یہِ زِ توٚہۍ تہِ مَہ ورتٲوِ و تَس سٍتۍ عداوت ۔دشمن تہٕ غیر دشمن أکِس در جس منٛز تھا وُن تہٕ دۅ شوٕنۍ سٍتۍ اَکوے سلو ک کرُن چُھنہٕ انصا ف ۔ تۅہیہِ چُھو تِمن لُکن سٍتۍ سخت رٔوِیہِ ورتا و نُک حق، یِمو ایمان اننہٕ کِس پا داشس منٛز تۅہیہِ پٮ۪ٹھ ظُلم کٔرۍ تہٕ توٚہۍ کٔرِ ہَو وطنہٕ منٛز نیرنس پٮ۪ٹھ مجبور،تہٕ وطنہٕ منٛزٕ نیر نہٕ پتہٕ تہِ روٗدِو تِم پتے۔مگر یِمو لُکو اتھ ظُلمس منٛز حصّہ نیوٗو نہٕ ، انصا ف چُھ یہِ زِ توٚہۍ کٔرِو تِمن سٍتۍ رُت برتا و ،تہٕ رشتہٕ تہٕ برداری ہٕندِ لحا ظہٕ یِم تِہِندۍ حقوق تۅہیہِ پٮ۪ٹھ چِھ عٲید سپدان تِم ادا کر نس منٛز مَہ کٔرِو کمی۔﴾"
  60,9,"۔ سُہ ییٚمہِ کتھہِ نِشہِ تۅہیہِ رُکاوان چُھ، سۅ چھےٚ یہِ زِ یِمو دین کِس معا ملس منٛز تۅہیہِ سٍتۍ جنگ چُھ کوٚر مُت ،تہٕ  توٚہۍ چَھہَو تُہند یو گھر و منٛزٕ کٔڑِتھ ژٕ ھنِمٕتۍ، تہٕ تُہندِ س کڑنس منٛز چُھکھ اکھ أکِس مدد کوٚر مُت زِ توٚہۍ کٔرِو تِمن لُکن سٍتۍ دوستی۔ تِمن سٍتۍ یِم لُکھ دوستی کر ن تِمے چِھ ظٲلِم۔"
  60,10,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت،ییٚلہِ مو من مستوٗراتہٕ ہجرت کٔرِ تھ تۅہیہِ نِشہِ یِن،تیٚلہِ کٔرِو ﴿ تِہندِ مو من آسنُک تحقیق،تہٕ تِہندِ ایمانٕچ حقیقت چُھ بس اللہ تعالیٰ بہتر زانان۔پتہٕ ییٚلہِ تۅہیہِ پے لگیو تِمہٕ چھےٚ مو من، تیٚلہِ مَہ کٔرِ یوٗکھ تِمہٕ کُفّارن کُن واپس ۔﴿صلح حُدیبیہ پتہٕ روٗدۍ گۅڈٕہ گۅڈٕ ہ مُسلمان مَرد مکّہ پٮ۪ٹھہٕ مدینس کُن ژٔلۍ ژٔلۍ یِوان تہٕ تِم ٲسۍ معا ہدٕہ کیو شرٲیطو مُطا بق واپس یِوان کر نہٕ ۔پتہٕ گوٚو مُسلمان مستوٗراتن ہٕندِ یِنُک سلسلہٕ شروع،تہٕ کٲفرو کوٚر معا ہدُک حوالہٕ دِتھ تِہنزِ واپسی ہُند تہِ مُطا لبہٕ۔اتھ پٮ۪ٹھ سپُد یہِ سوال پٲدٕ زِ کیا معا ہدُک اطلاق چھا مستوٗراتن پٮ۪ٹھ تہِ سپدان؟ خُداین چُھ اَمی سوالُک جواب یتھ جایہِ دِ یتمُت زِ اگر تِمہٕ مُسلمان آسن تہٕ اَمِیُک یِیہِ اطمنان کر نہٕ زِ پٔزِ پٲٹھۍ چھےٚ تِمہٕ ایمان خٲطرٕ ے ہجرت کٔرِتھ آمژٕ،بیٚیہِ کُنہِ چیزن چَھنہٕ تِمہٕ اَنہِ مژٕ، تِمہٕ گژھن نہٕ واپس یِنہِ کر نہٕ ۔ یہِ حکم آو اَتھ بِنا ہس پٮ۪ٹھ دِنہٕ زِ معا ہدٕ کۍ یِم شرٲیط لیٛکھنہٕ ٲسۍ آمٕتۍ تِمن منٛز اوس رَجُلّ ﴿مرد﴾ لفظ لیٛکھنہٕ آمُت یِتھہٕ پٲٹھۍ زَن بخا ری ہٕندِس روایتس منٛز چُھ آمُت۔﴾ نَہ چھےٚ تِمہٕ کٲفر ن خٲطرٕ حلال تہٕ نَہ چِھ کٲفر تِہندِ خٲطرٕ۔تِہند یو کٲفر خا ندارَو یِم مَہر تِمن دِتۍ مٕتۍ ٲسۍ تِم کٔرِ و تِمن واپس۔تہٕ تِمن سٍتۍ نکا ح کر نس چُھنہٕ تۅہیہِ پٮ۪ٹھ کانٛہہ گناہ، ییٚلہِ زَن توٚہۍ تِہندۍ مَہر کٔرِو تِمن ادا۔ ﴿ مطلب چُھ یہِ زِ تِہند ٮ۪ن کٲفر خا ندارن یِم مَہر تِمن واپس یِن سوزنہٕ، تِمے یِن نہٕ یِہِندۍ مَہر شُمار کرنہٕ بلکہ وۅ نۍ یُس مُسلمان تہِ یِمو منٛزٕکٲنٛسہِ خا تونہِ سٍتۍ نکا ح ییژِھہ کرُن ،سُہ دِیِن تس مَہر تہٕ کٔرِن نکا ح۔﴾تہٕ پانہٕ تہِ مَہ تھٲوِیوٗکھ توٚہۍ کٲفر زنانہٕ پننِس نِکا حس منٛز رُکٲوِتھ ۔یِم مَہر تۅہیہِ پننیٚن کٲفر خا ندارِ نیٚن دِتِمٕتۍ ٲسِو، تِمن مٔنگِو تِم واپس، تہٕ یِم مہر کٲفرو ٲسۍ پننین مسلمان خاندارنین دِتۍ مٕتۍ تِم مٔنگِن تِمن واپس، یہِ چُھ اللہ تعالیٰ سُند حُکم ،سُہ چُھ تۅہیہِ در میان فٲصلہٕ کران، تہٕ سُہ چُھ زانن وول تہٕ حکمت وول۔"
  60,11,"۔تہٕ اگر تُہنز و کٲفر خاندارِ نیو ہٕند یو مَہر و منٛزٕ کٲفر ن نِشہِ تۅہیہِ کینٛہہ واپس میلہِ نہٕ، تہٕ پتہٕ واتہِ تُہنزٕ نو بت تیٚلہِ یِمن لُکن ہٕنزٕ خا ندارِنہِ تور چھےٚ روز مژٕ، تِمن  کٔرِو تیوٗتاہ رقم ادا یُس تِہندٮ۪ن دِنہٕ آمتیٚن مَہر ن یوت آسہِ۔ تہٕ تس خُدایس روٗزِ و کھۅژان یَس پٮ۪ٹھ تۅہیہِ ایمان چُھو اوٚنمُت۔"
  60,12,"۔اے نبی صلی اللہ علیہ وسلم ،ییٚلہِ تۅہیہِ نِشہِ مو من مستوٗراتہٕ بیعت کرنہِ یِن ۔﴿ یہِ آیت ٲس فتحِ مکہ برونٛہہ کینٛہہ کال نٲزِل گٔمٕژ۔امہِ پتہٕ ییٚلہِ مکّہ فتح سپُد،قر یشِکۍ لُکھ سپٕدۍ کھیٚجو کھیٚجو بیعت کر نہٕ خٲطرٕ حٲضر۔حضور صلی اللہ علیہ وسلمو رٔٹ پانہٕ کوہِ صفا ہس پٮ۪ٹھ مَردن بیعت تہٕ حضرت عمر رضی اللہ عنہ کٔرِ کھ پننہِ طر فہٕ ماموٗر زِ تِم رٔٹِن مستوٗراتن نِشہِ بیعت ، تہٕ تِمن کتھن ہُند کر نٲوِنکھ اقرار یِمہٕ یتھ آیتس منٛز بیان چھےٚ کر نہٕ آمژٕ ۔ امہِ پتہٕ چِھ حضور صلی اللہ علیہ وسلم مد ینہ تشر یف نِوان ۔تتہِ چِھ  أکِس مکا نس منٛز مستوٗراتن جمع کر نُک حُکم دِوان، تہٕ امہِ پتہٕ چِھ حضرت عمر رضی اللہ عنہ ہس تِمن بیعت ہیٚنہٕ خٲطرٕ سوزان۔﴾ تہٕ اَمہِ کتھہِ ہُند کٔرِن عہد زِ تِمہٕ کر ن نہٕ خُدایس سٍتۍ کٲنٛسہِ شر یک، ژوٗر کرن نہٕ ، تہٕ بدکٲری کرن نہٕ، پننیٚن اولادن کر ن نہٕ قتل، پننیٚن اَتھن کھۅرن برونٛہہ کُن اَنن نہٕ کانٛہہ بہتان بنٲوِتھ ،﴿ امہِ نِشہِ چِھ دۅن قٔسمن ہٕندۍ بہتان مُراد۔اکھ یہِ زِ کانٛہہ خاتو ن لگا وِ دوٚ یِمہِ خا تو نہِ غیر مردن سٍتۍ تہمت ۔تہٕ اَمہِ قسمہٕ چہ کتھہٕ پٔھلاوِ لُکن منٛز،بیاکھ یہِ زِ أکِس خاتونہِ زیٚوِ شُر بیٚیہِ کٲنسہِ ہُنٛد،تہٕ خاندارس  دِیہِ یقین زِ یہِ چُھ چو نُے﴾ تہٕ کُنہِ امرِ معر و فس ﴿ نیک کامہِ ﴾ منٛز کر ن نہٕ تُہٕنز نافر مٲنی، ﴿یتھ مختصر کتھہِ منٛز چِھ بٔڑۍ زٕ ہ قا نو نی نکتہٕ بیان آمٕتۍ کر نہٕ۔ اکھ یہِ زِ نبی صلی اللہ علیہ وسلمن ہٕندِس اطا عتس پٮ۪ٹھ تہِ چُھ رٕژرس منٛز اطا عتُک قٲد آمُت لگا و نہٕ ، حالانکہ حضور صلی اللہ علیہ وسلمن ہٕندِس  بارس منٛز ٲس نہٕ کُنہِ ادنیٰ شکٕچ تہِ گنجٲیش زِ تِم صلی اللہ علیہ وسلم کیا ہیٛکن کُنہِ وِزِ بُرٲیی ہُند حُکم تہِ دِتھ ۔امہِ نِشہِ گٔیہِ یہِ کتھ پٲنۍ پانے وا ضح زِ دُنیا ہس منٛز ہیٚکہِ نہٕ کٲنٛسہِ مخلو ق سٕنز اطا عت قا نونِ خُدا وندی ہٕند یو حَدو نیٚبر نِیرِ تھ کر نہٕ یِتھ۔تِکیازِ ییٚلہِ اللہ تعالیٰ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز اطا عت تام معر و ف کہ شر طہٕ سٍتۍ مشروط آسہِ ، تیٚلہِ کتہِ ہیٚکہِ بیٚیہِ کٲنٛسہِ ہُند یہِ مقا م ٲسِتھ زِ تس واتہِ غیر مشروط اطا عتُک حق،تہٕ تٔمۍ سٕندِ کُنہِ تِتھہِ حُکمٕچ یا قانو نٕچ یا ضٲبطٕچ تہٕ رسمٕچ یِیہِ پیروی کرنہٕ یُس قا نونِ خدا و ند ی خلا ف آسہِ۔ دوٚ یِم کتھ یۅسہٕ آینی حیثیت سٮ۪ٹھاہ اہمیت تھا وان چھےٚ سۅ چھےٚ یہِ زِ اتھ آیتس منٛز چُھ پا نژھ منفی احکام دِنہٕ پتہٕ مثبت حکم صرف اَکو ے دِنہٕ آمُت،تہٕ سُہ چُھ یہِ زِ تمام نیک کامیٚن منٛز یِیہِ نبی صلی اللہ علیہ وسلمن ہٕندٮ۪ن احکامن ہٕنز اطا عت کر نہٕ۔ یوٚت تام زن بُرٲیِین ہُند تعلق چُھ، تِمہٕ بجہِ بجہِ بُرٲیِیہِ آیہِ گٔنٛز راونہٕ یِمن منٛز زمانہٕ جا ہلیت چہِ مستوٗراتہٕ مبتلا آسہٕ، تہٕ یِمو نِشہِ آو باز روزُک عہد ہیٚنہٕ ۔ مگر یوٚت تام رٕژرن ﴿نیکیَن ﴾ ہُند تعلق چُھ، تِہُند کانٛہہ فہر ست دِتھ آو نہٕ عہد ہیٚنہٕ زِ تۅہیہِ چِھو فلٲنۍ فلٲنۍ اعمال کرٕنۍ بلکہ آو صرف یہِ عہد ہیٚنہٕ زِ ییٚمہِ نیک کامہِ ہُند تہِ حُکم حضور صلی اللہ علیہ وسلم دِن تمِچ آسیو تۅہیہِ پیروی کرٕنۍ۔ ﴾ تیٚلہِ ہیٚیِو یِمن بیعت تہٕ یِہندِس حقس منٛز کٔرِ و خُدایس نِشہِ دُعاے مغفرت، یقیناً چُھ اللہ تعالیٰ  در گُزر فر ما ون وول رحم کر ن وول۔"
  60,13,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت، تِم لُکھ مَہ بنٲوِ یوٗکھ دوست یِمن پٮ۪ٹھ خُداین غضب چُھ کوٚرمُت،یِم ٲخرت نِشہِ تِتھے پٲٹھۍ نا اُمید چِھ ، یِتھہٕ پٲٹھۍ قبر ن منٛز پٮ۪تھ کٲفر  چِھ غمگین۔ع"
