quran[123]{c,v,t}:
  11,1,"۔ا۔ل۔ر ،چُھ فر مان ، ﴿کتاب لفظُک تر جمہٕ چُھ یَتھ جایہِ انداز بیان کہ منا سبت کِنۍ فر مان  کر نہٕ آمُت۔عر بی زبٲنۍ منٛز چُھنہٕ یہِٰ لفظ کتا ب تہٕ تحر یر کِس معنیَس منٛزٕ ےیوت یِوان، بلکہ چُھ حکم تہٕ شٲہی فر مان کِس معنیس منٛز تہِ یِوان، تہٕ خۅد چُھ یہِ لفظ قرآنس منٛز واریاہن جاین أتھۍ معنیس منٛز وَرتاو نہٕ آمُت﴾ ییٚمکۍ آیات پختہٕ تہٕ مُفصّل چِھ ارشاد سپدِ مٕتۍ،أکِس دانا تہٕ با خبر ہستی ہٕندِ طر فہٕ۔"
  11,2,"۔زِ توٚہۍ مَہ کٔرِ و عبا دت مگر کٔرِ و صرف أکِس اللہ تعالیٰ سٕنز۔بہٕ چُھس تٔمۍ سٕندِ طر فہٕ تۅہیہِ خبردار کر ن وول تہِ ، تہٕ بشار ت دِنہٕ وول تہِ۔"
  11,3,"۔بیٚیہِ یہِ زِ توٚہۍ مٔنگِو پننِس ربّس معٲفی تہٕ تس کُن یِیِو پھیرِ تھ،تیٚلہِ دِیَو سُہ تۅہیہِ أکِس خا ص وقتس تام زند گی ہُنٛد رُت سامان ﴿یعنی دُنیا ہس منٛز یُس تُہٕندِ ٹھہر نُک وقت مقرر چُھ، تتھ وقتس تام تھاو یٚو نہٕ سُہ تۅہیہِ خرا ب پٲٹھۍ بلکہ تھا ویٚو جان پٲٹھۍ۔تٔمۍ سٕنزٕ نعمتہٕ سپد ن تۅہیہِ پٮ۪ٹھ نٲزِل۔ تٔمۍ سٕنز و بر کتو سٍتۍ سپدِ و سر فراز، خۅ ش حال روٗزِ و تہٕ زند گی منٛز سپدیٚو امن تہٕ سکو ن نصیب۔ذلّت تہٕ خوٲر ی سان نہٕ کینٛہہ بلکہ روٗزِ و عز ت و احترام سان زندٕہ﴾ تہٕ پرٛتھ صا حبِ فضلس کرِ تٔمۍ سُند فضل عطا ﴿یعنی یُس شخص اخلا قن تہٕ اعما لن منٛز یوٗت برونٛہہ پکہِ، اللہ تعالیٰ کرِ تس تیوٗت بوٚڈ در جہِ عطا ، یُس  شخص تہِ پننہِ سیر ت و کردارٕ سٍتۍ پنُن پان کُنہِ تہِ فضیلتُک حقدار ثٲبِت کرِ سۅ فضیلت یِیہِ تس ضروٗر دِنہٕ ﴾ البتہ اگر توٚہۍ پوٚت چِھو ہیٚوان تیٚلہِ چُھس بہٕ تُہٕندِ س حقس منٛز اکہِ بڈِ وُلٹہٕ دۅہ کہِ عذا ب نِشہِ کھۅژان۔"
  11,4,"۔تۅہیہِ سارِنٕے چُھو خُدا یس کُن پھیرُن،تہٕ سُہ ہیٚکہِ سورُے کینٛہہ کٔرِ تھ۔"
  11,5,"۔وُچِھو،یِم لُکھ چِھ پننیٚن سینن پھِران ،تاکہ أمِس نِشہِ روزٕ ہن ژھایہِ ﴿مکہ کیٚن کٲفر ن ہُند حال اوس یہِ زِ ییٚلہِ تِم رسول اللہ صلی اللہ علیہ وسلمس وُچھان ٲسۍ، تِم ٲسۍ وَتھ ڈالان تاکہِ تِم گٔژھۍ نہٕ تِمن برونٛہہ کُن یِنۍ ﴾ خبردار ،ییٚلہِ یِم پلوَو سٍتۍ پنُن پان وَلان چِھ، اللہ تعالیٰ چُھ یِہندِس کھٔٹِتھ تھٲوِ مٕتِس تہِ زانان تہٕ یِکینٛژھاہ نوٚن آسہِ تَتھ تہِ ، سُہ چُھ تِمو رازَونِشہِ تہِ وٲقف یِم سینن منٛز چِھ ۔"
  11,6,"۔زمینس منٛز پکن وول کانٛہہ جاندار تہِ چُھنہٕ تِیُتھ ییٚمۍ سُند رز ق اللہ تعالیٰ سٕندِ ذِمہٕ آسہِ نہٕ، تہٕ یَس متعلق نہٕ سُہ زانان آسہِ زِ کتہِ چُھ سُہ روزان ،تہٕ کتھ جایہِ چھُ حوا لہٕ  کر نہٕ یِوان،سورُے کینٛہہ چُھ أکِس صا ف کتا بہِ منٛز در ج۔"
  11,7,"۔تہٕ سُے چُھ ییٚمۍ تمام آسمان تہٕ زمین شیٚن دۅ ہن منٛز پٲدٕ کٔرۍ ییٚلہِ زن تمہِ برونٛہہ تٔمۍ سُند عر ش آبس پٮ۪ٹھ اوس ﴿أسۍ ہیٚکو نہٕ ؤنِتھ اَمہِ آبہٕ نِشہِ کیا چھُ مُراد ۔یہِ چھا یۅ ہے آب ، یُس أسۍ اَمہِ ناوٕ ہ چِھ زانان؟ کِنہٕ یہِ لفظ چُھ محض استعارٕہ رٔنگۍ مادٕہ کہ تمہِ ما یع﴿Fluid﴾ حالت خٲطرٕ وَرتا و نہٕ آمُت یُس موجود ہ صورتس منٛز اَننہٕ برونٛہہ اوس؟عر شس پٮ۪ٹھ آسنُک معنی متعیّن کرُن تہِ چُھ مشکل ۔ممکن چُھ زِ اَمِیُک  مفہو م آسہِ زِ تمہِ وقتہٕ ٲس اللہ تعالیٰ سٕنز سلطنت آبس پٮ۪ٹھ﴾ تا کہ تۅہیہِ وُچھیٚو آز ماوِتھ زِ تۅہیہِ منٛزٕکُس چُھ بہتر عمل کرن وول۔﴿یعنی تخلیقُک مقصد اوس یہِ زِ انسان دُنیا ہس منٛز پٲدٕ کٔرِ تھ یِیہِ تس آز مٲیش کر نہٕ﴾ اے نبی صلی اللہ علیہ وسلم ،وۅ نۍ اگر توٚہۍ وَنان چِھو زِ لوٗکو، مر نہٕ پتہٕ یِیو توٚہۍ دُو بارٕہ تھوٚد تُلنہٕ، منکر ین چِھ فوراً وَنان زِ یہِ چھےٚ نَنہِ وانہٕ جا دو گر ی۔﴿ یعنی مر نہٕ پتہٕ انسانن ہُنٛد دُوبارٕہ زند ہ سپدُن چُھنہٕ ممکن ، مگر سا نیٚن عقلن چُھ جود یِوان کر نہٕ زِ أسۍ ما نَو سۅ کتھ یۅسہٕ نہٕ سپدِ تھ ہیٚکہِ ﴾"
  11,8,"۔تہٕ اگر أسۍ أکِس خا ص وقتس تام یِہندِس سزا ہس پتھ پتھ چِھ دِوان تیٚلہِ چِھ تِم لاگان وَنُن زِ ٲخر کٔمۍ چیز ن چُھ سُہ رُکٲوِ تھ تھو و مُت؟ بوٗزِ و ! ییٚمہِ دۅ ہ اَمہِ سزا ہُک وقت ووت،تیٚلہِ ہیٚکہِ نہ سُہ پتہٕ کٲنٛسہِ ہٕندِ پھِر نہٕ سٍتۍ پھیٖرِ تھ  تہٕ سُے چیز یِیہِ تہٕ رَٹہِ یِمن گھیرس منٛز،یَتھ یِم ہزٕل ٲسۍ کران ۔ ع"
  11,9,"۔اگر أسۍ کُنہِ وقتہٕ انسان پننہِ رحمت سٍتۍ نوازان چِھن تہٕ پتہٕ چِھن بیٚیہِ سُہ تَمہِ نِشہِ محر وٗم کران،تیٚلہِ چُھ سُہ ما یو س گژھان تہٕ پتہٕ چُھ لاگان نا شکر ی کرٕنۍ۔"
  11,10,"۔تہٕ اگر اَمہِ مصیبت پتہٕ یُس تس پٮ۪ٹھ آمُت اوس، أسۍ سُہ نعمتُک مزٕ ہ چِھن وُچھنا وان، تیٚلہِ چُھ وَنان میٲنۍ سٲر ی رنج تہٕ غم سپٕدۍ ختم، پتہٕ چَھنہٕ تس پژھ یِوان تہٕ کھسان چُھس بو ش۔"
  11,11,"۔اَمہِ عیبہٕ نِشہِ اگر پاک چِھ ، تیٚلہِ چِھ بس تِم لُکھ یِم صبر کر ن وٲلۍ تہٕ نکیو کار چِھ، تہٕ تِمے چِھ یِہندِ خٲطرٕ مغفرت تہِ چھےٚ تہٕ بوٚڈ اجر تہِ چُھ۔"
  11,12,"۔اے پیغمبر صلی اللہ علیہ وسلم ،یِنہٕ یہِ سپدِ زِ توٚہۍ ترٲوِ و تِمو چیز و منٛزٕ کانٛہہ چیز ﴿بیان کر نہٕ نِشہِ ﴾ یِم تۅہیہِ کُن وَحی چِھ یِوان کر نہٕ، تہٕ اَتھ کتھہِ پٮ۪ٹھ سپد یٚو دِل تنگ،زِ تِم وَنن  أمِس شخصس پٮ۪ٹھ کیازِ آو نہٕ کانٛہہ خزانہٕ نٲزِل کر نہٕ ؟ یا یہِ زِ أمِس سٍتۍ کیازِ آو نہٕ کانٛہہ فر شتہٕ ؟ توٚہۍ چِھو محض خبردار کر ن وٲلۍ، برونٹھ کُن چُھ پرٛتھ چیزُک اختیار تھاون وول اللہ تعالیٰ۔"
  11,13,"۔کیا یِم چھاوَنان زِ پیغمبر ن چھےٚ یہِ کتاب پا نے بنٲومٕژ؟ ؤنِو،  اچھا ، کتھ چھا یہِ ، أنِو  تیٚلہِ أتھۍ ہِو ۍ داہ سوٗرٕہ بنٲوِ تھ ،تہٕ خُدا یس ورٲے یِم یِم ﴿تُہٕندۍ معبو د ﴾ چِھ اگر تِم ہیٚکِیوٗ کھ مددٕ خٲطرٕ بُلٲوِ تھ، تیٚلہِ بُلٲوِیوٗکھ ﴿تِم تہِ ﴾ اگر توٚہۍ ﴿تِم معبود سمجھِنس منٛز﴾ پٔزِ یٲرۍ چِھو۔"
  11,14,"۔ وۅ نۍ اگر تِم ﴿تُہٕندۍ معبود ﴾ تۅہیہِ مددَس چِھنہٕ یِوان ، تیٚلہِ زٲنِو زِ یہِ چُھ اللہ تعالیٰ سٕندِ عِلمہٕ سٍتۍ نٲزِل سپُد مُت، بیٚیہِ یہِ زِ خُدا یس ورٲے چُھنہٕ کانٛہہ حقیقی  معبود۔ کیا وۅ نۍ نوٚ مرٲوِوٕ ہ توٚہۍ ﴿یتھ امرِ حقس برونٛہہ کنہِ ﴾ پنُن کلہٕ؟"
  11,15,"۔یِم لُکھ بس ییٚمہِ دنیا چہِ زند گی تہٕ اَمہِ کین مٲر ۍ مَنز ر ن ہٕندۍ طٲلب چِھ آسان، تِہنزِ کار گُزٲر ی ہُند پھل چِھ أسۍ تِمن ییٚتی دِوان،تہٕ  اتھ چَھنہٕ تِمن سٍتۍ کانٛہہ کمی یِوان کر نہٕ ۔"
  11,16,"۔ٲخرتس منٛز چُھنہٕ یِمن لُکن خٲطرٕ نارٕ ورٲے بیٚیہِ کِہِنۍ ،﴿تَتہِ سپدِ معلو م زِ ﴾ یِکینژھاہ تِمو دُنیا ہس منٛز بنو و ، سُہ سورُے گوٚو مِلیا میٹ تہٕ وۅ نۍ چُھ تِہُند سورُے کوٚر مُت کرٛ وومُت محض بٲطِل۔"
  11,17,"۔پتہٕ سُہ شخص یُس پننِس ربّ سٕندِ طر فہٕ اکھ صا ف شہا دت تھاوان اوس﴿یعنی ییٚمِس خۅد پننِس وجودس منٛز، تہٕ زمین و آسما ن کِس سا ختس منٛز، بیٚیہِ کاینات کِس نظم و نسقس منٛز اَمہِ کتھہِ ہٕنز ٹا کارٕ ہ شہا دت ٲس میلان زِ ییٚمہِ دُنیا ہُک خا لق ، ما لک ، پروردگار بیٚیہِ حٲکِم تہٕ فر مان روا چُھ صرف اکھ اللہ تعالیٰ ، پتہٕ ییٚمہِ سُند دِل یِمے شہا دتہٕ وُچھِتھ گۅڈے  اوس یہِ گوٲہی تہِ دِوان  زِ ییٚمہِ زند گی پتہٕ گژِھہ بیٚیہِ کانٛہہ زند گی ضرور آسٕنۍ یَتھ منٛز انسان پننِس خُدا یس پننیٚن عملن ہُند حسا ب دِیہِ ، تہٕ پننہِ کرِ مَتہِ کرٛاوِ متِیُک رَٹہِ جز ا تہٕ سزا۔﴾ اَمہِ پتہٕ آو اَکھ گواہ تہِ پروردگارٕ سٕندِ طر فہٕ ﴿اَمہِ شہا دت  کِس تٲییدس منٛز۔﴾ ﴿یعنی قرآن ،ییٚمۍ اَمہِ فکر ی تہٕ عقلی شہا دتُک تٲیید کوٚر تہٕ أمِس ووٚنُن زِ پٔزۍ پٲٹھۍ چھےٚ حقیقت سۅ ے ییٚمیُک نِشان ژےٚ کا ینا تس تہٕ پننہِ نفس کیٚن آثا رن منٛز لوٚ بمُت چھُے﴾ تہٕ اَمہِ برونٛہہ ٲس مو سیٰ  علیہ السلامن ہٕنز کتا ب رہنما تہٕ رحمت کہ طور تہِ موجود﴿کیا سُتہِ ہیٚکیا دُنیا پر ستن ہٕندۍ پٲٹھۍ اَتھ انکار کٔرِ تھ؟﴾ یِتھۍ لُکھ اَنن اَتھ پٮ۪ٹھ ضرور ایمان۔ تہٕ انسٲنی گرو ہَو منٛزٕ یُس اکھا ہ اتھ انکار کرِ ، تیٚلہِ ییٚمہِ جایہِ ہُند تس خٲطرٕ وعدہ چُھ سُہ چُھ جہنم، لہٰذا، اے پیغمبر، توٚہۍ  گٔژھۍ زیٚو نہٕ امہِ چیزٕ طر فہٕ کُنہِ شکس منٛز، یہِ چُھ حق تُہٕندِس ربّ سٕندِ طر فہٕ۔ مگر اکثر لُکھ چِھنہٕ مانان ۔"
  11,18,"۔تہٕ تس شخصس کھۅتہٕ بوٚڈ ظٲلِم کُس آسہِ یُس خُدا یس پٮ۪ٹھ اَپُز کھالہِ؟ ﴿یعنی یہِ وَنہٕ زِ خُدایس سٍتۍ چِھ خُدٲیی تہٕ بند گی منٛز با قی تہِ شر یک۔ یا وَنہِ یہِ زِ خُدا یس چَھنہٕ پننیٚن بند ن ہٕندِس ہدا یتس تہٕ گمرٲہی سٍتۍ کانٛہہ دلچسپی،تہٕ تٔمۍ چَھنہٕ کانٛہہ کتا ب تہٕ کانٛہہ نبی سانہِ ہدا یت خٲطرٕ سوٗز مُت، بلکہ چِھن أسۍ آزاد ترٛٲوِ مٕتۍ زِ یِم طر یقہٕ أسۍ ییٚژھو تِم ہیٚکو پننہِ زند گی منٛز وَرتٲوِتھ۔ یا وَنہِ یہِ زِ خُدا ین چِھ أسۍ بٔلۍ گِندِنہٕ رٔنگۍ پٲدٕ کٔرِ مٕتۍ تہٕ یِتھے پٲٹھۍ کرِ اَسہِ ختم تہِ ، تس برونٛہہ کنہِ چَھنہٕ اَسہِ کانٛہہ جواب دہی تہٕ نہ چُھ جزا تہٕ نَہ چُھ سزا﴾ یِتھۍ لُکھ سپد ن پننِس ربّ سٕندِس در بارس منٛز پیش،تہٕ گواہِ دِن شہا دت زِ یِم چِھ تِم لُکھ یِمو پننِس ربّس پٮ۪ٹھ اَپُز اوس کھولمُت، بوٗزِ و! اللہ تعالیٰ سٕنزلعنت چھےٚ ظٲلِمن پٮ۪ٹھ۔﴿اندازِ بیان نِشہِ چُھ ظٲہر زِ یہِ کتھ یِیہِ ٲخرتس منٛز تِہنزِ پیشی ہٕندِس مو قعس پٮ۪ٹھ وَننہٕ ﴾"
  11,19,"۔تِمن ظٲلِمن پٮ۪ٹھ یِم اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ لُکن رُکاوان چِھ ، تٔمۍ سٕنز وَتھ چِھ ۂج کرٕ نۍ یژھان، بیٚیہِ چِھ ٲخرتس انکار کران۔"
  11,20,"۔ تِم ٲسۍ نہٕ زمینس منٛز خُدا یس بے بس کر ن وٲلۍ،تہٕ نَہ اوس اللہ تعالیٰ سٕندِس مقا بلس منٛز تِہُند کانٛہہ مددگار، تِمن یِیہِ وۅ نۍ دۅ گنہٕ عذا ب دِنہٕ، تِم نَہ ٲسۍ کٲنٛسہِ ہُند بوزانٕے ،تہٕ نہ اوس تِمن پانہٕ کینٛہہ فِکرِ تران۔"
  11,21,"۔یِم چِھ تِم لُکھ یِمو پنُن پان ترٛ ووخسا رس منٛز ۔ تہٕ تہِ سورُے روو تِمن یِکینژھاہ تِمو بنو و مُت اوس۔"
  11,22,"۔اَتھ منٛز چُھنہٕ رَژھ تہِ شک زِ تِمے روزن ٲخرتس منٛز سارِوٕے کھۅ تہٕ خسارس منٛز۔"
  11,23,"۔روٗدۍ تِم لُکھ یِمو ایمان اوٚ ن تہٕ یِمو نیک عملہٕ کرِ تہٕ پننِس ربّ سٕندی روٗدۍ بٔنِتھ ،تیٚلہِ چِھ پٔزۍ پٲٹھۍ تِم جنّتی لُکھ ،تہٕ ہمیشہ روزن جنتس منٛز۔"
  11,24,"۔ یِمن دۅ شوٕ نۍ فر یقن ہٕنز مثال چھےٚ تِژٕھے زَنتہٕ اکھ انسان آسہِ اوٚن تہٕ زوٚر، تہٕ بیاکھ آسہِ گاشدار تہٕ بوزن وول، کیا یِم دۅ شو ے ہیٚکنہٕ یکسا ن ٲسِتھ ؟ کیا توٚہۍ چِھو نا ﴿ اَمہِ مثالہِ سٍتۍ ﴾ کانٛہہ سبق رٹان ۔؟ع"
  11,25,"۔ ﴿تہٕ یتھی حالات ٲسۍ ییٚلہِ ﴾ اَسہِ نو ح علیہ السلام تٔمۍ سٕندِس قو مس کُن سوٗز مُت اوس، ﴿تٔمۍ ووٚن ﴾ بہٕ چُھسَو توٚہۍ لُکھ صا ف صا ف خبردار کران۔"
  11,26,"۔خُدا یس ورٲے مَہ کٔرِ و کٲنٛسہِ ہٕنز عبا دت نَتہٕ چُھ مےٚ اندیشہِ زِ تۅہیہِ پٮ۪ٹھ یِیہِ اکہِ دۅ ہ دگ تُلوُن عذا ب ۔"
  11,27,"۔در جواب ووٚ ن تٔمۍ سٕندِ قو م کیو سردارو، یِمو تٔمۍ سٕنز کتھ ماننہٕ نِشہِ انکار اوس کوٚر مُت۔سا نہِ نظرِ منٛز چُھکھ نہٕ ژٕ اَمہِ وَرٲے کِہِنۍ زِ اکھ انسان چُھکھ سٲنۍ پٲٹھۍ۔تہٕ أسۍ چِھ وُچھا ن زِ سانہِ قو مہٕ منٛزٕ کٔر بس تِمو یِم اَسہِ نِشہِ اَراذِل ﴿ؤسۍ پایہِ ﴾ ٲسۍ سو نچنہٕ سمجھنہٕ ورٲے چٲنۍ پیر وی اختیار۔تہٕ أسۍ چِھنہٕ کانٛہہ تِیُتھ چیز تہِ لبا ن ، یتھ منٛز توٚہۍ اَسہِ کھۅتہٕ زیادہ کھٔسِتھ چِھو،بلکہ چِھو أسۍ توٚہۍ اَپزِ یٲرۍ سمجھان۔"
  11,28,"۔تٔمۍ ووٚ ن  اے بردارانِ قو م، ہَنا سوٗنچتو زِ اگر بہٕ پننِس ربّ سٕندِ طر فہٕ  أکِس ٹاکارٕ ہ شہادتس پٮ۪ٹھ قٲیِم اوسُس، پَتہٕ کٔر مےٚ تٔمۍ پنٕنۍ خا ص رحمت عطا ۔مگر سۅ آیَو نہٕ تۅہیہِ اَتھہِ ، تیٚلہِ کیا ذر یعہ چُھ ٲخر اَسہِ نِشہِ زِ توٚہۍ ییژِھو نہٕ ما نُن ، تہٕ أسۍ والَو زبردستی  سان یہِ تُہٕندِ ٮ۪ن کا ڈ یٚن منٛز؟"
  11,29,"۔تہٕ اے برادرانِ قو م ،اتھ کامہِ پٮ۪ٹھ چُھس نہٕ بہٕ تۅہیہِ کانٛہہ مال منگان ، میو ن اَجر چُھ اللہ تعالیٰ سٕندِ ذمہٕ، تہٕ بہٕ روٗدُس تِمن لُکن دھکہٕ دِنہٕ نِشہِ تہِ ، یِمو میٲنۍ کتھ مٲنِمٕژ چھےٚ، تِم چِھ پٲنۍ پانے پننِس ربّ سٕندِس در بارس منٛز گژھن وٲلۍ، مگر بہٕ چُھس وُچھان زِ توٚہۍ چِھو جہا لت وَرتاوان۔"
  11,30,"۔تہٕ اے قو م، مےٚ کُس یِیہ، اللہ تعالیٰ سٕنزِ تَھپہِ نِشہِ بچا ونہِ اگر بہٕ یِم لُکھ پا نس نِشہِ دوٗر کر کھ؟ یہِ کتھہِ رَژھ تہِ چَھنا تۅہیہِ لُکن ہٕندِس سمجھس منٛز یِوان ؟"
  11,31,"۔تہٕ بہٕ چُھس نہٕ تۅہیہِ وَنان زِ مےٚ نِش چِھ اللہ تعالیٰ سٕندۍ خزا نہٕ، نَہ چُھس یہِ ونان زِ مےٚ چُھ غیبُک علم، نہ چُھ میو ن یہِ دعویٰ زِ بہٕ چُھس فر شتہٕ، بیٚیہِ ہیٚکہٕ نہٕ بہٕ یِتہِ ؤنِتھ زِ یِمن لُکن تُہنزٕ أچھ حقا رت چہِ نظرِ چھےٚ وُچھان،تِمن دِیُت نہٕ خُدا ین کانٛہہ رٕژَر، تِہندِ  نفسُک حال چُھ اللہ تعالیٰ ہٕے بہتر زانان، اگر بہٕ یُتھ کینٛہہ وَنہٕ تیٚلہِ آسہٕ بہٕ ظٲلِم۔"
  11,32,"۔ ٲخر کار ووٚن تِمو لُکو زِ  اے نو ح علیہ السلام ،ژےٚ کوٚرُتھ اَسہِ سٍتۍ جھگڑٕ۔ تہٕ سُتہِ کوٚرُتھ سٮ۪ٹھاہ،بس وۅ نۍ اَن ژٕ سُہ عذا ب ییٚمِچ دھمکی ژٕ اَسہِ دِوان چُھکھ، ہر گاہ پٔزِ یور چُھکھ۔"
  11,33,"۔نو ع علیہ السلام چِھ جوا ب دِوان  سُہ اَنہِ اللہ تعالیٰ ہٕے ؟ ہرگاہ ییٚژِھہِ  تہٕ تۅہیہِ چُھو و نہٕ تیوٗتاہ بل بوتہٕ زِ سُہ رُکٲوِ یوٗن، وۅ نۍ ہرگاہ بہٕ  تۅہیہِ کینٛہہ خیر خوٲہی کرٕ نۍ تہِ یَژٕھہ، میٲنۍ خیر خوٲہی ہیٚکہِ نہٕ تۅہیہِ کانٛہہ فٲیدہ دِ تھ۔"
  11,34,"۔ ییٚلہِ زن اللہ تعالیٰ نٕے تۅہیہِ گمراہ کر نُک اردإہ آسہِ کوٚرمُت، ﴿یعنی اگر خُدا ین تُہٕنز ہٹ دھر می ، شر پسند ی تہٕ رٕژرٕ نِشہِ بے رغبتی وُچِھتھ یہِ فٲصلہٕ چُھ کوٚر مُت زِ تۅہیہِ دِیَو نہٕ سیٚزِ وَتہِ پٮ۪ٹہ پکنُک تو فیق تہٕ یِمن وَتن منٛز توٚہۍ خۅد پانہٕ چِھو راوُن یژھان تِمنٕے منٛز راوریٚو تۅہیہِ ، تیٚلہِ ہیٚکہِ نہٕ وۅ نۍ تُہٕندِ رٕژرٕ خٲطرٕ میٲنۍ کانٛہہ کو شش کار گرسپدِ تھ﴾ سُے  چُھ تُہُند ربّ تہٕ تٔسۍ کُن چُھ تۅہیہِ وا پس پھیرُن۔"
  11,35,"۔اے نبی صلی اللہ علیہ وسلم، کیا یِم لُکھ چھا ونان زِ أمۍ شخصن چُھ یہِ سورُے پانے بنو و مُت؟ یِمن ؤنِو  اگر مےٚ یہِ پانے چُھ بنو و مُت ، تیٚلہِ چھےٚ مےٚ پٮ۪ٹھ پننہِ جُر مٕچ ذمہٕ دٲر ی، تہٕ یُس جُر م توٚہۍ کران چِھو، تَمہِ چھ ذمہٕ دٲر ی نِشہِ چُھس بہٕ بَر ی ۔  ع"
  11,36,"۔ نو ح ﴿علیہ السلامس ﴾ پٮ۪ٹھ آیہِ وحی کر نہٕ، زِ تُہُندِ قو م منٛزٕ یِمو لُکو ایمان اوٚ ن ، بس تِمو اوٚ ن ، وو نۍ چُھنہٕ کانٛہہ مانن وول ، یِہند ٮ۪ن کر توٗ تن پٮ۪ٹھ ترٲوِو غم ہِیوٚ ن۔"
  11,37,"۔ تہٕ سانہِ نگرٲنی منٛز، سانہِ وَحی مطٲ بق لٲ گِو اکھ نا و بنا وٕ نۍ ، تہٕ وُچِھو یِمو لُکو ظلم چُھ کوٚر مُت تِہندِ س حقس منٛز کٔرۍ زیو نہٕ مےٚ سفٲرش، تِم سٲر ۍ چِھ وۅ نۍ اند ہیٚتھ ڈُبَن وٲلۍ۔"
  11,38,"۔نو ح علیہ السلام  اوس ناو بناوان،تہٕ تٔمۍ سٕنٛدِ قو م کیو سردارَو منٛزٕ یُس اکھا تَس بروٗنٛٹھۍ کِنۍ نیران اوس، سُہ اوس تَس ہَزٕ ل کران، تٔمۍ ووٚن  اگر توٚہۍ اَسہِ پٮ۪ٹھ چِھو اَسان، تیٚلہِ چِھ أسۍ تہِ تۅہیہِ پٮ۪ٹھ اَسان تُہٕندی پٲٹھۍ،"
  11,39,"۔عنقر یب لگیٚو تۅہیہِ پا نے خبر زِ  کَس پٮ۪ٹھ چُھ سُہ عذا ب یِوان یُس تس رُسوا کرِ ،تہٕ کس چھےٚ سۅ بلا ے یِوان، یوسہٕ ٹا لنہٕ سٍتۍ ٹلہِ نہٕ۔﴿یہِ چُھ اکھ عجیب  معا ملہٕ ، یتھ پٮ۪ٹھ غور کر نہٕ سٍتۍ پے چُھ لگا ن زِ دنیا کہ ظٲہرٕ ہ سٍتۍ کوٗتاہ دۅ کھہٕ چُھ انسان کھیوان۔ییٚلہِ نو ح علیہ السلام در یاو نِشہِ واریاہ دوٗر خشکی  پٮ۪ٹھ پنُن جہا زٕ بناوان آسٕہَن ،پَزی اَسہِ ہے یہِ لُکن اکھ سٮ۪ٹھاہ ہزٕ ل کر وٕ نۍ تہٕ فضو ل کٲم با سان ، تہٕ تِم آسٕہَن اَسان اَسان وَنان زِ یِہٕنز دیو نگی وٲژ ٲخر یتھ حدس تام زِ وۅ نۍ چلا ون یِم خشکی اندر جہا زٕ۔ تمہِ ساعتہِٕ آسہِ ہے نہٕ کٲنٛسہِ ہٕندِس خواب و خیا لس منٛز تہِ یہِ کتھ یِوان زِ کینٛہہ دۅہ سپٕدِ تھ چلہِ پَزی ییٚتہِ جہازٕ۔ البتہٕ یَس شخصَس حقیقتُک علم اوس، تہٕ یس خبر ٲس زِ پگاہ کیا زِ پیٚیہِ ییٚتہِ جہازٕ چ ضرورت ، تس آسہِ ہے یِہندِس جہالتس تہٕ بے خبر ی پٮ۪ٹھ، تہٕ پتہٕ یِہندِس احمقا نہٕ اطمینا نس پٮ۪ٹھ،پوٚتھ پھِرِ تھ اَسُن یِوان تہٕ سُہ آسہِ ہے ونان زِ کٲتیا ہ نادان چِھ یِم لُکھ زِ شہمت چھےٚ یِہندِ س کلس پٮ۪ٹھ وٲژ مٕژ، مےٚ کٔرۍ یِم خبردار زِ ہے سۅ بلا ے وٲژٕوکھۅ ر ن تل، تہٕ یِہنز ن أچھن برونٛہہ کنہِ چُھس تمہِ نِشہِ بچنٕچ کوٗشش تہِ کران۔ مگر یِم چِھ مطمعین بِہِتھ تہٕ پوٚت پھِرِ تھ چھِ مےٚ دیوا نہٕ سمجھان۔﴾"
  11,40,"۔وۅ نۍ ییٚلہِ سو ن حکم ووت،تہٕ تَتھ تنو ر س ﴿تندوٗرَس﴾ لٔج گرٛکھ ﴿اَتھ متعلق چِھ مفسر ن ہٕندۍ مختلف قو ل مگر اَسہِ نزدیک چُھ صحیح سُے یُس قرآن کیو وا ضح لفظو سٍتۍ فِکرِ چُھ تران زِ طو فا نُک ابتدا گوٚو اکہِ خا ص تندوورٕ پٮ۪ٹھہٕ شروع  یتھ تلہٕ کنہِ اَکھ ناگ وُزیاو،پتہٕ سپٕز اکہِ پاسہٕ پیٹھہٕ روٗدٕ رانٛٹھ پیٚنۍ شروع تہٕ دوٚ یِمہِ پاسہٕ لٔگۍ زمینس منٛز جایہِ جایہِ نا گ وُز نہِ ﴾ پتہٕ ووٚن اَسہِ  پرٛتھ قٔسم کیٚن جانو ر ن ہُنٛد جو رٕہ تھٲوِ و ناوِ منٛز، پنٕنۍ گھرِ کۍ بٲژتہِ ، تِمو شخصو وَرٲے یِہٕنز نشٲند ہی گۅڈے چھےٚ کر نہٕ آمٕژ کٔرِ یوٗکھ اَتھ منٛز سوار۔﴿ یعنی چا نیٚن گھرِ کیٚن یِمن افرادن متعلق گۅڈے چُھ وَننہٕ آمُت زِ تِم چِھ کٲفر تہٕ اللہ تعالیٰ سٕندِ رحمتٕکۍ حقدار چِھنہٕ کینٛہہ، تِم مَہ بیٚہٲوِیوٗکھ ناوِ منٛز﴾ تہٕ تِم لُکھ تہِ بیٚہنٲوِ یوٗکھ یِمو ایمان چُھ اوٚنمُت۔ تہٕ کمٕے لُکھ ٲسۍ یِمونو ح ﴿علیہ السلامس ﴾ سٍتۍ ایمان اوس اوٚ نمُت۔"
  11,41,"۔نوح﴿علیہ السلامن ﴾ ووٚن  سوار سپدِ و اَتھ منٛز ،اللہ تعالیٰ سٕندی ناوٕ سٍتۍ چُھ اَمِیُک پکُن تہِ ، تہٕ اَمِیُک ٹھٔہرُن تہِ ، میو ن ربّ چُھ سٮ۪ٹھاہ غفورو حیم۔"
  11,42,"۔ناو ٲس یِمن لُکن ہیٚتھ پکا ن ،تہٕ اکھ اکھ لہر ٲس پہاڑٕ کۍ پٲٹھۍ وۅ تھان۔نو ح علیہ السلام سُنٛد فر زند اوس دوٗر بِہِتھ ،﴿نوح علیہ السلامن﴾ کوٚر نس آلَو، گو بریٛا اَسہِ سٍتۍ سپَد سوار، کٲفر ن سٍتۍ مَہ روز۔"
  11,43,"۔ تٔمۍ دِیُت پوٚت پھیرِ تھ جوا ببہٕ کھسہٕ وُنی أکِس با لس پٮ۪ٹھ،یُس مےٚ آبہٕ نِشہ، بچا وِ۔نو ح ﴿علیہ السلامن﴾ ووٚن  اَز چُھنہٕ کانٛہہ چیز اللہ تعالیٰ سٕندِ حُکمہٕ نِشہِ بچا و ن وول سواے یہِ زِ اللہ تعالیٰ ہٕے کرِ کٲنٛسہِ پٮ۪ٹھ رحم ۔اَتھ دوران آیہِ اکھ لہر دۅ شوٕنۍ منٛز با گ ،تہٕ سُتہِ گوٚو ڈبُن والیٚن منٛز شٲمل۔"
  11,44,"۔حکم سپُد  اے زمین ،پنُن سورُے آب نینٚگلاو ،تہٕ اے آسمان تھکھ کر۔ چنا نچہ آب بیوٗٹھ زمینس منٛز ،فٲصلہٕ آو کر نہٕ ناو بیٖٹھ جودی پٮ۪ٹھ۔﴿جُودِی پہاڑ چُھ کر دستا ن کِس علا قس منٛز جز یر ۂ ابن عمر کِس شمال مشر قی طر فس کُن، تہٕ اَز تہِ چُھ جُودِی ناوَے مشہو ر﴾ تہٕ وَننہٕ آو زِ دوٗر سپُد ظٲلِمن ہُند قو م !"
  11,45,"۔ نو ح ﴿علیہ السلامن ﴾ لو ے پننِس ربّس ناد،ووٚ نُن  اے ربّ ، میو ن فر زند چُھ میا نیو گھرٕ بٲژَو منٛزٕ،تہٕ چو ن وعدہ چُھ پوٚز،تہٕ ژٕ چُھکھ سارِوٕے حٲکِمو کھۅتہٕ بوٚڈ تہٕ بہتر حاکم۔"
  11,46,"۔در جواب سپُد ارشاد  اے نو ح علیہ السلام،سُہ چُھنہٕ چا نیو گھرٕ وا لیو منٛزٕ،سُہ چُھ اکھ بِگر یمٕژ کٲم، ﴿ یہِ مٲنۍ تو تِیُتھے زَنتہٕ أکِس شخصہٕ سٕندِ جسمُک کانٛہہ تان آسہِ دۅٚریو مُت، تہٕ ڈا کٹر ن آسہِ سُہ ژٹنُک فٲصلہٕ کوٚر مُت۔ وۅ نۍ چُھ سُہ مر یض ڈا کٹر س وَنان زِ یہِ ہے چُھ میانہِ جسمُک اکھ حصہٕ یہِ کیازِ چُھکھ ژٹان؟ تہٕ ڈاکٹر چُھ امہِ کِس جوا بس منٛز ونان زِ یہِ چُھنہٕ چا نہِ جسمُک حصہٕ روٗدمُت تِکیازِ یہِ چُھ دۅدریو مُت ۔لہٰذا ،أکِس صا لح مٲلِس تٔمۍ سٕندِس نا لایق فر زند س متعلق یہِ وَنُن زِ یہِ چُھ اکھ بِگر یمٕژ کٲم۔اَمِیُک مطلب چُھ یہِ زِ ژےٚ یۅسہٕ محنت یہِ رَچھنس منٛز کٔرٕ تھ سۅ گٔیہِ ضا یع تہٕ یہِ کٲم بِگر ییہِ۔﴾لہٰذا مَہ کر ژٕ مےٚ تمہِ کتھہِ ہُند در خوا ست ییٚمِچ حقیقت ژٕ زانان چُھکھ نہٕ، بہٕ چُھسے ژےٚ نصیحت کران زِ پنُن پان مَہ بنا و جٲہلن ہٕندۍ پٲٹھۍ۔"
  11,47,"۔نوح علیہ السلام چِھ فوراً عر ض کران  اے میانہِ ربّہٕ،بہٕ چُھس چو ن پنا ہ منگان۔اَمہِ نِشہِ زِ سُہ چیز منگے ژےٚ ییٚمیُک نہٕ مےٚ علم چُھ﴿ یعنی سُہ درخواست کرٕ ییٚمہِ کہ صحیح آسنُک مےٚ علم چُھنہٕ﴾ اگر ژےٚ مےٚ معا ف کوٚرُتھ نہٕ تہٕ رحم کوٚرُتھ نہٕ، تیٚلہِ گژٕھہ بہٕ برباد ۔"
  11,48,"۔ حکم سَپدُس  اے نو ح علیہ السلام وَس ، سانہِ طر فہٕ چھےٚ سلا متی تہٕ بر کتہٕ ژےٚ پٮ۪ٹھ،تہٕ تِمن گروہن پٮ۪ٹھ یِم ژےٚ سٍتۍ چِھ،تہٕ کینٛہہ گروہ چِھ تِتھۍ تہِ یِمن أسۍ کینٛژھس کالس تام زند گی ہُند سامان عطا کر و ۔ پَتہٕ وَاتہِ تِمن سانہِ طر فہٕ دَگ تُلوُن عذا ب ۔"
  11,49,"۔اے نبی صلی اللہ علیہ وسلم ، یِمہٕ چھےٚ غیب چہِ خبرٕ،یِم أسۍ تۅ ہیہِ کُن وَحی چِھ کران،اَمہِ برونٛہہ نَہ ٲسِو توٚہۍ تِمہٕ زانان تہٕ نَہ تُہُند قو م، لہٰذا کٔرِ و  صبر، رُت انجام چُھ مُتقین ہٕندِ سٕے حقس منٛز۔ ع ۔﴿ یعنی یِتھہٕ پٲٹھۍ نو ح علیہ السلام تہٕ تٔمۍ سٕندٮ۪ن سٲتھین کامیٲبی گٔیہِ حٲصل ،تِتھے پٲٹھۍ سپد یو تۅہیہِ تہٕ تُہندٮ۪ن سٲتھیَن تہِ ۔ لہٰذا یِم مصٲ یب تہٕ تکلیف وُنۍ کیٚنس تۅہیہِ پٮ۪ٹھ گُز ران چِھ ، تِمو سٍتۍ مَہ سپدِ و غمگین، بلکہ روٗزِ و ہمت سان تہٕ صبرٕ سان پنٕنۍ کٲم کران۔﴾"
  11,50,"۔بیٚیہِ سوٗز اَسہِ عادس کُن تٔمۍ سُند بو ے ہوٗد علیہ السلام،تٔمۍ ووٚ ن  اے برادرانِ قو م ! اللہ تعالیٰ سٕنز عبا دت کٔرِ و، تس ورٲے چُھنہٕ بیٚیہِ کانٛہہ تُہُند خُدا، تۅہیہِ چِھو محض اَپزٕۍ تُھرِ مٕتۍ۔"
  11,51,"۔اے بردارانِ قوم ! یَتھ کامہِ پٮ۪ٹھ چُھس نہٕ بہٕ تۅہیہِ نِشہِ کانٛہہ اجر یژھان، میو ن اجر چُھ تٔمۍ سٕندِ ذمہٕ ییٚمۍ پٲدٕ کوٚر مُت چُھنَس ، کیا توٚہۍ چِھو نا رَژھ تہِ عقلہِ کٲم ہیوان؟"
  11,52,"۔ تہٕ اے میانہِ قو م کیو لوٗکو ! پننِس ربّس مٔنگِو معٲفی، پتہٕ پھیٖرِ و تس کُن ، سُہ مٕژراوِ تُہٕندِ خٲطرٕ آسما نٕکۍ دہا نہٕ ،تہٕ تُہٕندِس موجو دٕ قُوّ تس پٮ۪ٹھ کرِ مز ید قوتُک اضا فہٕ،مُجرِ م بٔنِتھ مَہ پھِرِ و ﴿بند گی نِشہِ ﴾ بُتھ۔"
  11,53,"۔تِمو دِیُت جواب  اے ہوٗد علیہ السلام،ژٕ چُھکھ نہٕ اَسہِ نِشہِ کانٛہہ ٹا کارٕ شہا دت ہیٚتھ آمُت، تہٕ چٲنِس وننس پٮ۪ٹھ ہیٚکو کھ نہٕ أسۍ پنٕنۍ معبود ترٲوِتھ، تہٕ ژےٚ پٮ۪ٹھ چِھنہٕ ٲسۍ ایمان اَنن وٲلۍ۔"
  11,54,"۔أسۍ چِھ یہِ سمجھان زِ ژےٚ پٮ۪ٹھ چھےٚ سا نیٚو معبودَو منٛزٕ کٲنٛسہِ ہٕنز ژٔنڈ آمٕژ۔ ﴿یعنی ژےٚ ٲسی کٲنٛسہِ دیو ی یا دیو تا ہس یا کٲنٛسہِ حضرت سٕندِس آستا نس پٮ۪ٹھ کانٛہہ گُستٲخی کٔرمٕژ،تمیُک خمیا زٕ ہ چُھ یُس ژٕ پیٚتر اوان چُھکھ، تِکیازِ ژٕ چُھکھ اورٕ یو زٕ چہِ کتھہٕ کران، تہٕ تِمے بٔستیہِ یِمن منٛز ژٕ رات تام عزّت سان روزان اوسُکھ ، اَز چھی ژےٚ تَتہِ لیٚکَو تہٕ کَنیو سٍتۍ استقبال سپدان﴾۔ہوٗد ﴿علیہ السلامن ﴾ ووٚن  بہٕ چُھس اللہ تعالیٰ سٕنز شہادت پیش کران تہٕ توٚہۍ روٗزِ و گواہ زِ خُدا یس ورٲے یِم با قی تۅہیہِ خُدٲیی منٛز شر یک چِھو قرار دِتۍ مٕتۍ ، تَمہِ نِشہِ چُھس بہٕ بے زار۔"
  11,55,"۔مےٚ خلا ف یہِ تۅہیہِ کرُن چُھو سٲر ی کٔرِ و رٔلِتھ، تہٕ مےٚ مَہ دِیِو رَژھ تہِ مہلت،"
  11,56,"۔میو ن بھر وسہٕ چُھ خُدا یس پٮ۪ٹھ ، یُس میو ن ربّ تہِ چُھ تہٕ تُہُند تہِ ، کانٛہہ جاندار  چُھنہٕ سُہ ییٚمۍ سُند  ژھو گ تٔمۍ سٕندِس اتھس منٛز آسہِ نہٕ، بے شک چُھ میو ن ربّ سیٚزِ وَتہِ پٮ۪ٹھ۔"
  11,57,"۔اگر توٚہۍ پوٚت پھیٖرِ و تہٕ پھیر ۍ تَو، یُس پیغا م دِ تھ بہٕ تۅہیہِ کُن سوز نہٕ اوسُس آمُت سُہ چُھ مےٚ تۅہیہِ تام وا تنو و مُت، وۅ نۍ تُلہِ میو ن ربّ تُہٕنزٕ جایہِ بیاکھ قو م، تہٕ توٚہۍ ہیٚکوِ نہٕ تتھ کانٛہہ نقصان واتنٲوِتھ، یقیناً چُھ میو ن ربّ پرٛتھ چیز س پٮ۪ٹھ نگران۔"
  11,58,"۔پتہٕ ییٚلہِ سو ن حکم آو، اَسہِ دِیُت پننہِ رحمت سٍتۍ ہوٗد ﴿علیہ السلامَس ﴾ تہٕ تِمن لُکن نجا ت یِمو تس سٍتۍ ایمان اوس اوٚ نمُت، تہٕ اکہِ سخت عذا ب نِشہِ بچٲوۍ تِم ۔"
  11,59,"۔یِم چِھ عاد، تِمو کوٚر پننِس ربّ سٕندِ ٮ۪ن آیا تن انکار، تٔمۍ سٕندٮ۪ن رسولن ہٕنز کتھ مٲنِکھ نہٕ، تہٕ حق کِس پرٛتھ زور آور دشمن سٕنز روٗدۍ پیر وی کران۔"
  11,60,"۔ٲخر کار ووٚتھ یَتھ دُنیا ہس منٛز تہِ تِمن پھٹکار ﴿لعنت﴾ تہٕ قیا مت کہ دۅہ تہِ ،بوٗزِ و! عادن کوٚر پننِس ربّس سٍتۍ کُفر، بوٗزِ و ! عاد آے دوٗر چھکنہٕ ،ہوٗد علیہ السلام سٕندِ قو مٕکۍ لُکھ ۔ ع"
  11,61,"۔ تہٕ ثمو دس کُن سوٗز اَسہِ تٔمۍ سُند بو ے صا لح علیہ السلام ، تٔمۍ ووٚن  اے میانہِ قو م کیو لوٗ کو، اللہ تعالیٰ سٕنز عبا دت کٔرِ و، تس ورٲے چُھنہٕ تُہُند کانٛہہ خدا،سُے چُھ ییٚمۍ توٚہۍ زمین منٛزٕ پٲدٕ چِھنَو کٔرِ مٕتۍ ، تہٕ ییٚتہِ چِھنَو توٚہۍ بسٲوِ مٕتۍ، لہٰذا مٔنگِو توٚہۍ تس معٲفی تہٕ تس کُن پھیرِ و واپس، یقیناً چُھ میو ن ربّ قر یب ، تہٕ سُہ چُھ دُعا ہَن جوا ب دِنہٕ وول ۔ ﴿یتھ مختصر کتھہِ منٛز چُھ حضرت صا لح علیہ السلامن شر ک کہ سار ی کارور بارُک موٗل ژوٚٹمُت۔ مشر ک چِھ سمجھان تہٕ ہو شیار لُکو چھےٚ تِمن یہِ کتھ سمجھا ونٕچ کوٗشش کٔر مٕژ زِ خُدا وند عا لم سُند متبر ک دروازٕہ چُھ عام انسانن ہٕندِ دسترس نِشہِ سٮ۪ٹھاہ دوٗر۔ تٔمۍ سٕندِس دربارس تام کتہِ ہیٚکہِ عا م انسان وٲتِتھ ۔ تو ر تام دُعا وا تٕنۍ تہٕ پتہٕ تِہُند جوا ب میلُن ہیٚکہِ نہٕ کُنہِ پٲٹھۍ تہِ ممکن ٲسِتھ یوٚت تام نہٕ پاک رُو حن ہُند وسیلہٕ ژھا نڈ نہٕ یِیہِ ،تہٕ یوٚت تام نہٕ تِمن مذ ہبی منصب دارن ہٕندۍ خد مات یِن حٲصل کر نہٕ ، یِم ہیوٚر تام نذرٕ ، نیا ز تہٕ عر ضیہِ واتنا ونٕکۍ طر یقہٕ چِھ زانان۔یٔہے چھےٚ سۅ  غلط فہمی ییٚمہِ بندس تہٕ خُدا یس در میان واریاہن لۅ کٹیٚن بڈ ٮ۪ن معبو دن تہٕ سفٲرش دارن ہُند اکھ جِم غفیر چُھ کھڑا کوٚر مُت۔حضرت صا لح علیہ السلام چِھ جٲہلیت کِس اتھ پوٗرٕ طلسمس صرف دۅ یو لفظو سٍتۍ ہو ر چھکان پھُٹرٲوِتھ۔ اکھ یہِ زِ اللہ تعالیٰ چُھ نکھہٕ ۔ دوٚیُم یہِ زِ سُہ چُھ دُعا ہن جوا ب دِنہٕ وول۔ یعنی تُہُند یہِ خیا ل تہِ چُھ غلط زِ سُہ چُھ تۅہیہِ نِشہِ دوٗر ، تہٕ یِتہِ چُھ غلط زِ توٚہۍ ہیٚکوِ نہٕ براہِ راست تس ناد لٲیِتھ پننیٚن دُعا ہن ہُند جوا ب حٲصل کٔرِ تھ۔ تۅہیہِ منٛزٕ ہیٚکہِ اکھ اکھ شخص تس پا نس نکھہٕ لٔبِتھ ،تس ہیٚکِو لۅ تہِ پٲٹھۍ کتھ ؤنِتھ ،پننہِ عر ضِیہِ ہیٚکہِ براہِ راست تٔمۍ سٕندِس خد متس منٛز پیش کٔرِ تھ، تہٕ پتہٕ چُھ سُہ برا ہِ راست پننِس پرٛتھ بندٕ ہ سٕند ٮ۪ن دُعا ہن ہُند جوا ب تہِ پانہٕ دِوان ۔ لہٰذا ، ییٚلہِ سلطنت کِس سُلطا ن سُند در بارِ عام پرٛتھ وقتہٕ پرٛتھ شخصہٕ سٕندِ خٲطرٕ یلہٕ چُھ، تہٕ پرٛتھ شخصس نکھے چُھ موجو د ، تیٚلہِ کتھ حما قتس منٛز چِھو توٚہۍ ہیٚنہٕ آمٕتۍ زِ تٔمۍ سٕندِ خٲطرٕ چِھو وا سطہٕ ، ؤسیلہِ تہٕ سفٲرش دار ژھانڈا ن پھیران؟﴾"
  11,62,"۔تِمو ووٚن  اے صا لح علیہ السلام ،ییٚمہِ برونٛہہ اوسُکھ ژٕ اَسہِ در میان تِیُتھ شخص یَس سٍتۍ سٮ۪ٹھاہ تو قعات وا بستہٕ ٲسۍ، کیا ژٕ چُھکھہٕ اَسہِ تِمن معبوٗد ن ہٕنزِ بند گی نِشہِ رُکا وُن یژھان یِہٕنز عبادت سٲنۍ مٲلۍ بُڈِبب کران ٲسۍ؟ ژٕ یَتھ طر یقس کُن اَسہِ بُلاون چُھکھ ،تتھ متعلق چُھ اَسہِ سخت شک ییٚمۍ أسۍ دۅ لا بَس منٛز ترٲوِ مٕتۍ چِھ ۔"
  11,63,"۔ صا لح ﴿علیہ السلامن ﴾ ووٚن  اے بردارانِ قو م، تۅہیہِ چُھوا کینژھاہ اَتھ کتھہِ پٮ۪ٹھ تہِ غور کوٚر مُت زِ اگر بہٕ پننِس ربّ سٕندِ طر فہٕ اکھ صا ف شہادت اوسُس تھاوان، تہٕ تٔمۍ کٔر مےٚ پننہِ طر فہٕ رحمت تہِ عطا ،تیٚلہِ کُس ہیٚکہِ مےٚ اللہ تعالیٰ سٕنزِ تھپہِ نِشہِ بچٲوِ تھ، اگر بہٕ تٔمۍ سٕنز نا فر مٲنی کرٕ ؟توٚہۍ کیا بکار یِیِو مےٚ اَمہِ ورٲے زِ مےٚ ترٲوِو زیادہ خسا رس منٛز۔"
  11,64,"۔تہٕ اے میانہِ قو م کیو لوٗ کو،وُچِھو یہِ اللہ تعالیٰ سٕنز اوٗنٹِنۍچھےٚ تُہٕندِ خٲطرٕ اکھ نشٲنی، یہِ ترٲوِیوٗن اللہ تعالیٰ سٕندِ س زمینس منٛز گا سہٕ کھینہٕ خٲطرٕ یلہٕ،أمِس لٲگۍ زیٚو نہٕ خرا ب نیّتہٕ سان اَتھہٕ،ہرگاہ یہِ کوٚرُو ،تیٚلہِ گژِھہ نہٕ زیادہ ژیر زِ تۅہیہِ پٮ۪ٹھ یِیہِ اللہ تعالیٰ سُند عذا ب ۔"
  11,65,"۔مگر تِمو مٲرسۅ اوٗنٹۍ ، اَتھ پٮ۪ٹھ کٔرۍ تِم صا لح ﴿علیہ السلامن ﴾ خبرادر زِ  بس وۅ نۍ روٗزِ و تر ٮ۪ن دۅ ہن گھر ن اندر لَسا ن بسا ن، یہِ چُھ تِیُتھ معیاد یُس نہٕ اَپُز ثٲبِت سپدِ ۔"
  11,66,"۔ٲخر کار ییٚلہِ سانہِ فٲصلُک وقت ووت،پتہٕ بچو واَسہِ پننہِ رحمت سٍتۍ صا لح علیہ السلام تہٕ تِم لُکھ یِمو تس سٍتۍ ایمان اوٚ نمُت اوس، تہٕ تمہِ دۅ ہ چھ رسوٲیی نِشہِ تھٲوۍ تِم محفو ظ ،بے شک چُھ چو ن ربّٕے در اصل طا قتو ر تہٕ با لا دست۔"
  11,67,"۔روٗدۍ تِم لُکھ یِمو ظُلم اوس کوٚر مُت ،تِم رٔٹۍ أکۍ سخت دھما کن۔تہٕ تِم روٗدۍ پننیٚن بٔستِین منٛز تِتھہٕ پٲٹھۍ بے حس تہٕ بے حر کت پیٚتھ۔"
  11,68,"۔ زَنتہٕ تِم تَتہِ زانٛہہ بٔسیمتی ٲسۍ نہٕ، بوٗزِ و ! ثمو د ن کوٚر پننِس ربس سٍتۍ کُفر، بوٗزِ و ! دوٗر آے چھکنہٕ ثمود !۔ع"
  11,69,"۔تہٕ وُچِھو ابرا ہیم ﴿علیہ السلامس ﴾ نِشہِ وٲتۍ سٲنۍفر شتہٕ خۅ ش خبر ہیٚتھ،ووٚ نہس ژےٚ پٮ۪ٹھ ٲسِن سلام، ابرا ہیم ﴿علیہ السلامن ﴾ دِیتُنکھ جوا ب ، تۅہیہِ پٮ۪ٹھ تہِ ٲسِن سلام، پتہٕ گوٚو نہٕ زیادٕہ کال زِ ابرا ہیم ﴿علیہ السلامن﴾ اوٚ ن اکھ بُزِ تھ ووٚژھ ﴿تِہندِ ضیا فت خٲطرٕ ﴾۔ ﴿اَمہِ نِشہِ سپُد معلو م زِ فر شتہٕ ٲسۍ انسٲنۍ شکلہِ منٛز حضرت ابرا ہیم علیہ السلامس نِشہِ آمٕتۍ تہٕ گۅڈٕ گۅڈٕ اوس نہٕ تِمو پنُن تعارُف کر نوو مُت، اَمہِ موجوٗب سو نچ ابراہیم علیہ السلامن زِ یِم چِھ کم تا م غیر زان پٔژھۍ تہٕ تِہندِ س یِنَس سٍتی کوٚرُکھ فوراً تِہندِ خٲطرٕ ضیا فتُک انتظا م۔﴾"
  11,70,"۔مگر ییٚلہِ وُچُھن زِ تِہٕندۍ اَتھہٕ چِھنہٕ کھیٚنس کُن بڑا ن ، ﴿ اَمہِ پتہٕ لوٚگ حضرت ابرا ہیم علیہ السلامس پَے زِ تِم چِھ فر شتہٕ ﴾ سُہ پیوٚ و تِہندِ سٍتۍ شکمس منٛز تہٕ دِلہٕ مٔنٛزۍ لوٚگ تِہندِ سٍتۍ خو ف محسو س کر نہِ ،  تِمو ووٚن  کھۅ ژمَہ ، أسۍ چِھ لوٗط علیہ السلام سٕندِس قو مس کُن سوزنہٕ آمٕتۍ۔"
  11,71,"۔ابرا ہیم علیہ السلام سٕنز خاندارِنۍ تہِ ٲس وۅ د نہِ ، یہِ بوٗزِ تھ ترٛ ووتَمہِ اَسُن، پتہٕ دِژ اَسہِ تَس اسحا ق علیہ السلام سٕنز خۅش خبر ،تہٕ اسحا ق ﴿علیہ السلامس ﴾ پتہٕ یعقو ب علیہ السلام سٕنز خۅ ش خبر ۔"
  11,72,"۔تَمہِ ووٚ ن  ہا ے میٲنۍ کم بختی ! ﴿ اَمِیُک مطلب چُھنہٕ یہِ زِ فی الو اقع ٲس حضرت سارہ علیہا السلام اَتھ پٮ۪ٹھ خۅ ش گژھنہٕ بجا ے اُلٹہٕ اَتھ پنٕنۍ کم بختی سمجھان بلکہ چِھ دراصل یِم تَمہِ قٔسمہٕ کیو لفظو منٛزٕ یِم مستو راتہٕ عا م پٲٹھۍ تعجُب کیٚن مو قعن پٮ۪ٹھ وَنان چھےٚ﴾ کیا وۅ نۍ زیٚوِ یٚا مےٚ شُر ییٚلہِ زَ ن بہٕ بُڈٕ چُھس گٔمٕژ،تہٕ میو ن خاندار تہِ چُھ بُڈٕ گومُت؟ یہِ چھےٚ بٔڑٕ عجیب کتھ۔"
  11,73,"۔فر شتو ووٚن  کیا اللہ تعالیٰ سٕندِس حکمس پٮ۪ٹھ چُھکھہٕ تعجُب کران؟ ابرا ہیم علیہ السلام سٕند یو گھرٕ والیو ، تۅہیہِ پٮ۪ٹھ چھےٚ اللہ تعالیٰ سٕنز رحمت تہٕ تٔمۍ سٕنزٕ بر کتہٕ ، تہٕ پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ سٮ۪ٹھاہ قٲبلِ تعر یف تہٕ بٔڑشان تھاون وول ۔"
  11,74,"۔پتہٕ ییٚلہِ ابرا ہیم علیہ السلام سٕنز گھبرا ہٹ دوٗر سپٕز،تہٕ ﴿اولاد سٕندِ بشارت سٍتۍ ﴾ سپُد تٔمۍ سُند دل خۅش،پتہٕ کوٚر تٔمۍ قومِ لوٗط علیہ السلام کِس معا ملس منٛز اَسہِ سٍتۍ جھگڑٕ شروع۔﴿ یَتھ مو قعس پٮ۪ٹھ چُھ لفظ  جھگڑٕ انتہٲیی محبت کِس تہٕ شفقت کِس وا ٹھس ظٲہر کران یُس حضرت ابرا ہیم علیہ السلامس پننِس ربّس سٍتۍ اوس۔ ییٚمہِ سٍتۍ چھےٚ یہِ تصویر أچھن برونٹھ کُن یِوان زِ بند س تہٕ خُدا یس در میان چُھ واریاہس کا لس نیا ے جٲری روزان۔بندٕ ہ  چھُ اقرار کران زِ کُنہِ پٲٹھۍ ٹٲلۍ تَو قومِ لوط علیہ السلام پٮ۪ٹھہٕ عذا ب ۔ اللہ تعالیٰ چُھ در جواب وَنان زِ یہِ قو م چُھ وۅ نۍ خیرٕ نِشہِ با لکل خٲلی سپُد مُت، تہٕ اَمِکۍ جُر م چِھ تمہِ حدٕ نِشہِ گُزر یمٕتۍ زِ اَتھ سٍتۍ یِیہِ کانٛہہ رعا یت کر نہٕ۔ مگر بندہ چُھ  زِسُہ چُھ لگا تار وَنان زِ  پروردِگارٕ ، اگر رَژھ کھنڈ تہِ رٕژر اَتھ منٛز موجود چُھ، تیٚلہِ دِ تہٕ اَتھ ہنا بیٚیہِ مہلت ،بنان چُھ زِ اَتھ رٕژرس نیرِ پَھل۔﴾"
  11,75,"۔ در حقیقت اوس ابراہیم علیہ السلام سٮ۪ٹھاہ حلیم تہِٕ نر م دل انسان ، تہٕ پرتھ حالس منٛز اوس اسہِ کُن رجو ع کران۔﴿ٲخر کار ووٚن سا نیو فر شتَو تس ﴾  اے ابرا ہیم علیہ السلام ،اَمہِ نِشہِ یہِ باز، چٲنِس ربّ سُند حکم چُھ سپُد مُت،"
  11,76,"۔تہٕ وۅ نۍ یِیہِ یِمن لُکن پٮ۪ٹھ سُہ عذا ب ضر ور یُس کٲنٛسہِ ہٕندِ پھِر نہٕ سٍتۍ پھیٖرِتھ ہیٚکہِ نہٕ۔"
  11,77,"۔ تہٕ ییٚلہِ سٲنۍ فر شتہٕ لو ط ﴿علیہ السلامس﴾ نِشہِ وٲتۍ،تِہٕندِ یِنہٕ سٍتۍ با نٛبر یٛا و سُہ ، تہٕ دِل سپُد س تنگ تہٕ وَننہِ لوٚگ زِ اَز چُھ سخت مصیبتُک دۅہ ۔﴿یِم فر شتہٕ ٲسۍ خو بصورت لڑ کن ہٕنزِ شکلہِ منٛز حضرتِ لوط علیہ السلامس نِشہِ وٲتِمٕتۍ، تہٕ حضرت لو ط علیہ السلام ٲسۍ اَمہِ کتھہِ نِشہِ بے خبر زِ یِم چِھ فر شتہٕ۔ یۅ ہے وجہ اوس زِ یِمن مہمانن ہٕندِ یِنہٕ سٍتۍ سپد ۍ حضرت لو ط علیہ السلام سخت پر یشا ن تہٕ دل گو کھ تنگ، تِم ٲسۍ امہِ کتھہِ نِشہِ با خبر زِ سُہ قو م کوٗتاہ بد کردار تہٕ بے حیا چُھ سپُد مُت﴾"
  11,78,"۔﴿یِمن مہمانن ہٕندِس یِنَس سٍتی﴾ تٔمۍ سٕندِ قو مٕکۍ لُکھ دور یِیہِ بے اختیار تٔمۍ سٕندِس گھر س کُن، گۅڈٕہ پٮ۪ٹھے ٲسۍ تِم یِژھنٕے بد کٲرِین ہٕندۍ عٲدی۔ لو ط﴿علیہ السلامن ﴾ ووٚن تِمن با یو ، میا نہِ کورِ چَھو ہیٚکیا موجود، یمہٕ چھےٚ تُہٕندِ خٲطرٕ پٲکیزہ تر﴿اَمِیُخ مطلب چھُنہٕ یہِ زِ حضرت لوط علیہ السلامن کرِ پننہِ کورِ تِمن بدکٲری خٲطر پیش۔یِمہٕ چھےٚ تُہٕندِ خٲطر پاکیزہ تر یہِ جُملہٕ چُھنہٕ یِتھہِ غلط مفہو مٕچ گنجٲیش تھاوان۔ حضرت لو ط علیہ السّلا من ہُند مقصد اوس صا ف پٲٹھۍ یہِ زِ پننہِ نفسٕچ شہو ت کٔرِ و تمہِ فطر ی تہٕ جٲیز طر یقہٕ پوٗرٕ، یُس خُدا ین چُھ مقرر کوٚر مُت تہٕ اَمہِ خٲطرٕ چَھنہٕ زنانن ہٕنز کمی ۔ ﴾ ہنا کٔرۍ تَو اللہ تعالیٰ سُند خو ف ، تہٕ میا نیٚن مہمانن ہٕندِس معا ملس منٛز متہٕ کٔرۍ تو مےٚ رُسوا،کیا تۅہیہِ منٛز چُھنا کانٛہہ رُت انسان ؟"
  11,79,"۔تِمو دِیُت جواب  ژےٚ چھےٚ خبرٕ ے زِ چا نیٚن کو رٮ۪ن منٛز چُھنہٕ سو ن کانٛہہ حصہٕ۔ تہٕ ثےٚ چھے یِتہِ خبر زِ أسۍ کیا چھِ یژھان"
  11,80,"۔لو ط﴿علیہ السلامن﴾ ووٚن  کا ش مےٚ نِشہِ آسِہے تیوٗتاہ طا قت زِ بہٕ کرٕہَو توٚہۍ سِیوٚد،یا آسہِ ہیٚم کانٛہہ مضبو ط سہا رے زِ تٔمۍ سُند پنا ہ رٹہا ۔"
  11,81,"۔پتہٕ ووٚن فر شتو تس زِ  اے لو ط علیہ السلام، أسۍ چِھ چٲنِس ربّ سٕندِ طر فہٕ سوز نہٕ آمٕتۍ فر شتہٕ، یِم لُکھ ہیکہٕ نَے نہٕ ژےٚ کٕہٕنۍ نقصان وا تنٲوِتھ،لہٰذا ، نیر رٲتھۍ کِیتُے رٲژ ہٕندِ کُنہِ وقتہٕ پنُن اہل وعیا ل ہیٚتھ، تہٕ وُچِھو، یِنہٕ تۅہیہِ منٛزٕ کانٛہہ شخص پتھ کُن نظر دِیہِ ، مگر چٲنۍ خاندارِنۍ ﴿گژھہ نہٕ ژےٚ سٍتۍ ﴾ تِکیازِ تَس پٮ۪ٹھ تہِ چُھ تی کینژھاہ گُدرَن وول یُس یِمن لُکن پٮ۪ٹھ گُدرِ ، یِہنزِ تبٲہی خٲطرٕ چُھ صُبحُک وقت مقرر، وۅ نۍ کوٗتاہ کا لٕے چُھ صُبح سپد نس!"
  11,82,"۔ پتہٕ ییٚلہِ سانہِ فٲصلُک وقت نکھہٕ ووت، اَسہِ کٔر یہِ بستی برباد،تہٕ اَتھ پٮ۪ٹھ برساوِ اَسہِ پینہٕ آمژِ میٚژِ ہٕنزٕ کنہِ پیوٚٹُھس پٮ۪ٹھ۔"
  11,83,"۔یِمو منٛزٕ پرٛتھ کانٛہہ کٔنۍ تُہٕندِس ربّ سٕنز نِشان زدٕہ ٲس،﴿یعنی اکھ اکھ  کٔنۍ ٲس اللہ تعالیٰ سٕندِ طر فہٕ نامز د کر نہٕ آمٕژ زِ تبٲ ہ کٲری ہنز کیا کٲم چھےٚ تَتھ کرٕ نۍ ، تہٕ کتھ کنہِ کس مُجر مس پٮ۪ٹھ  چُھ وَسُن ﴾ ،تہٕ ظٲلِمو نِشہِ چُھنہٕ یہِ سزا دوٗر ۔ ع۔"
  11,84,"۔ تہٕ مَد یَن والیٚن کُن سوٗز اَسہِ تٔمۍ سُنٛد بو ے شُعیب علیہ السلام ،تٔمۍ ووٚن  اے میا نہِ قو م کیو لوٗکو ، اللہ تعالیٰ سٕنز عبا دت کٔرِ و ، تس ورٲے چُھنہٕ کانٛہہ خُدا ، بیٚیہِ مَہ ٲسِو میننَس تو لنس منٛز کمی کران، اَز چُھسَو بہٕ توٚہۍ رٕ تِس حا لتس منٛز وُچھان، مگر مےٚ چُھ ڈر زِ پگا ہ یِیہِ تۅہیہِ پٮ۪ٹھ سُہ دۅہ ییٚمیُک عذا ب سارِ نٕے کۅم کٔرِ تھ رَٹہِ۔"
  11,85,"۔تہٕ اے برادرانِ قو م ،ٹھیک ٹھیک میٖنِو پوٗرٕ تہٕ توٗلِو پوٗرٕ انصا ف سان،تہٕ لُکن مَہ ٲسَو تِہٕند ٮ۪ن چیز ن منٛز گھا ٹہٕ دِوان۔زمینس منٛز مَہ ٲسِو فساد پھٔہلا وان پھیران۔"
  11,86,"۔اللہ تعالیٰ سُند دِنہٕ آمُت بچت چُھ تُہٕندِ خٲطرٕ بہتر، اگر توٚہۍ مو من چِھو ،تہٕ بہر حال چُھسنہٕ بہٕ تۅہیہِ پٮ۪ٹھ نگرانِ کار۔"
  11,87,"۔تِمو دِیُت جواب  اے شُعیب، کیا چٲنۍ نماز چَھیہِ ژےٚ یہِ ہیٚچھِنا وان زِ أسۍ ترٛا ووکھ تِم سٲر ی معبود یِہٕنز بند گی سٲنۍ مٲلۍ بُڈِ بب کران ٲسۍ؟ یا یہِ زِ اَسہِ آسہِ نہٕ پننہِ مالہٕ منٛزٕ خر چا ونُک اختیار کینٛہہ؟ بس ژٕے چُھکھہٕ اکھ با و قار تہٕ نیک چلن انسان روٗدمُت!"
  11,88,"۔شُعیب علیہ السلام چُھ وَنان  با یو ،توٚہۍ سوٗنچِو پانے زِ اگر بہٕ پننِس ربّ سٕندِ طر فہٕ أکِس ٹا کارٕہ شہادتس پٮ۪ٹھ اوسُس،تہٕ پتہٕ کوٚرتٔمۍ مےٚ پننہِ طر فہٕ جان رزق تہِ عطا ۔﴿ یعنی اگر مےٚ خُدا ین حق شنا س بصیرت تہِ دِژ مٕژ آسہِ ، تہٕ حلال رزق تہِ آسِنَم عطا کوٚرمُت ،تیٚلہِ کِتھہٕ پٲٹھۍ ہیٚکہِ یہِ میا نہِ خٲطرٕ جٲیز ٲسِتھ زِ ییٚلہِ خُدا ین مےٚ پٮ۪ٹھ یہِ فضل چُھ کوٚرمُت، تیٚلہِ کرٕ بہٕ تُہٕنز ن گمرٲہِیَن تہٕ حرام خوری یَن حق تہٕ حلال ؤنِتھ تٔمۍ سٕنز نا شکر ی۔﴾۔ تہٕ بہٕ چُھس نہٕ ہر گز یہِ یژھان زِ یِمو کتھو نِشہِ بہٕ توٚہۍ رُکاوان چُھسَو تِمہٕ کامہِ کرٕ بہٕ پانہٕ، بہٕ چُھس اصلا ح کرُن یژھان یوٚت تام تہِ مےٚ پِلہِ ، تہٕ یِکینژھاہ یہِ بہٕ کرُن چُھس یژھان، اَمِیُک سورُے دارمدار چُھ اللہ تعالیٰ سٕندِ س تو فیقس پٮ۪ٹھ، تٔسۍ پٮ۪ٹھ کوٚرمےٚ بھر وسہٕ ، تہٕ پرٛتھ معاملس منٛز چُھس بہٕ تٔسۍ کُن رجو ع کران۔"
  11,89,"تہٕ اے برادرانِ قو م، مےٚ خلا ف گٔژھ نہٕ  تُہٕنز یہِ ہٹ دھر می یہِ نو بت واتنا وٕنۍ،زِ ٲخر کار یِیہِ تۅہیہِ پٮ۪ٹھ تہِ سُے عذا ب یُس  نو ح علیہ السلام سٕندِ س قو مس آو ، یا ہوٗد علیہ السلام سٕندِس قو مس یا صالح علیہ السلام سٕندِ س قو مس پٮ۪ٹھ آمُت اوس، تہٕ لوط علیہ السلام  سُند قوم چُھنہٕ تۅہیہِ نِشہِ زیادہ دوٗر تہِ کینٛہہ"
  11,90,"وُچِھو ! پننِس ربّس مٔنگِو معٲفی، تہٕ تس کُن پھیٖرِ و واپس ، بے شک چُھ میو ن ربّ رحیم تہٕ پننِس مخلو قس سٍتۍ چُھ محبت تھا وان"
  11,91,"تِمو دِیُت جواب  اے شعیب علیہ السلام ، چا نہِ واریاہ کتھہٕ چَھنہٕ اَسہِ فکر ی تران، تہٕ أسۍ چِھ وُچھان زِ ژٕ چُھکھ اَسہِ در میان اکھ کمزور انسان،چٲنۍ برادر ی نَے آسِہے ،تیٚلہِ آسہکھ ژٕ خبر کر اَسہِ سنگسار کوٚر مُت ،ژےٚ چُھے نہٕ تیوٗت بل بوتہٕ زِ ژٕ پوشکھ اَسہِ"
  11,92,"۔شُعیب علیہ السلام چُھ ونان  با یو، کیا میٲنۍ برادری چھا تۅہیہِ پٮ۪ٹھ اللہ تعالیٰ سٕندِ کھۅ تہٕ زیادہ گوٚب،زِ تۅہیہِ کوٚرُو ﴿برادری ہُند خو ف ﴾ تہٕ اللہ تعالیٰ ترٛووٗن بالکل پسِ پشت؟زٲنِتھ تھٲوِو زِ یِکینژھاہ توٚہۍ کران چِھو، سُہ چُھنہٕ اللہ تعالیٰ سٕندِ گرِ فتہٕ نِشہِ نیٚبر کینٛہہ۔"
  11,93,"۔اے میانہِ قو م کیو لوٗ کو،توٚہۍ روٗزِ و پننِس طر یقس پٮ۪ٹھ کٲم کران،تہٕ بہٕ روزٕ پننِس طر یقس پٮ۪ٹھ کران،جلد ی لگیو تۅہیہِ پے زِ کَس پٮ۪ٹھ چُھ ذِلّتُک عذا ب یِوان،تہٕ کُس چُھ اَپزِ یو ر ، توٚہۍ تہِ کٔرِ و انتظا ر تہٕ بٕتہِ روزٕ تۅہیہِ سٍتۍ وُچھان۔"
  11,94,"۔ٲخر کا ر ییٚلہِ سانہِ فٲصلُٕک وقت ووت،اَسہِ بچو و پننہِ رحمت سٍتۍ شعیب علیہ السلام تہٕ تٔمۍسٕندۍ مو من سٲتھی تہٕ یِمو لُکو ظُلم اوس کوٚر مُت، تِم رٹۍ أکۍ سخت دھما کن تِتھہٕ پٲٹھۍزِ تِم روٗدۍ پننیٚن بٔستِیَن منٛز بے حیٚس تہٕ بے حر کت پیٚتھ۔"
  11,95,"۔ زَنتہٕ زانٛہہ کٲلۍ تِم تَتہِ بَسا نٕے ٲسۍ نہٕ۔بوٗزِ و ! مَد یَن وٲلۍ تہِ آے دوٗر چَھکنہٕ یِتھہٕ پٲٹھۍ ثمود ٲسۍ چَھکنہٕ آمٕتۍ۔ع"
  11,96,"۔تہٕ مو سیٰ علیہ السلام سوز اَسہِ پننیٚو نِشٲنیو سان تہٕ ٹا کارٕ ہ ما موٗر یت کہ سَنَدٕ سان۔"
  11,97,"۔ فر عو ن تہٕ تٔمۍ سٕندٮ۪ن سلطنت کیٚن زٕ ٹھیٚن کُن ، مگر تِمو کٔر فر عو ن سٕندِ حُکٕچ پیر وی،حالانکہ فرعو ن سُند حکم اوس نہٕ سیٚز رس پٮ۪ٹھ کینٛہہ،"
  11,98,"۔قیا مت کہ دۅہ آسہِ سُہ پننِس قومس برونٛہہ برونٛہہ،تہٕ پننہِ پیشوٲیی منٛز نِیہِ تِمن جہنمس کُن، کِژھ بدتر جا ے وُرود ﴿ واتنٕچ جاے ﴾ چھےٚ یہِ ، یَتھ پٮ۪ٹھ کانٛہہ واتہِ !۔"
  11,99,"۔ تہٕ تِمن لُکن ؤژھ دُنیا ہس منٛز تہِ لعنت ، تہٕ قیا مت کہ دۅہ تہِ وَسیٚکھ، کِیُتھ بُرٕ بد لہٕ چُھ یہِ ، یُس کٲنٛسہِ میلہِ !"
  11,100,"۔یہِ چھےٚ کینژھن بٔستِیَن ہٕنز دلیل ، یۅسہٕ أسۍ توٚہۍ بو زناوان چِھو، تِمن منٛز چھےٚ وُنہِ تہِ کینٛہہ کھڑا تہٕ کینژھن ہُند موٗل چُھ ژھیوٚنمُت۔"
  11,101,"۔اَسہِ کوٚر نہٕ تِمن پٮ۪ٹھ ظُلم، تِمو کوٚر پٲنۍ پانے پانس پٮ۪ٹھ ستم ، تہٕ تِہٕندۍ تِم معبو د یِمن تِم خُدا ے ترٲوِتھ ناد أسۍ لایان ، آے نہٕ رَژھ تہِ تِمن در کار ،ییٚلہِ اللہ تعالیٰ سُند حکم آو ، تِمو دِیُت نہٕ تِمن ہلا کت تہٕ  بر بٲدی ورٲے بیٚیہِ کانٛہہ فٲیدٕہ۔"
  11,102,"۔تُہُند ربّ ییٚلہِ کُنہِ ظٲلم بستی رَٹان چُھ تیٚلہِ چھےٚ پتہٕ تٔمۍ سٕنز پکڑ یژٕھے آسان،پٔزۍ پٲٹھۍ چھےٚ تٔمۍ سٕنز پکڑ سٮ۪ٹھاہ سخت تہٕ دگ تُلوٕ نۍ آسان۔"
  11,103,"۔حقیقت چھےٚ یہِ زِ اَتھ منٛز چھےٚ اکھ نشٲنی پرٛتھ تس شخصس خٲطرٕ،یُس ٲخرت کِس عذا بس کھۅژِ۔سُہ آسہِ اَکھ دۅ ہ ییٚلہِ سٲر ی لُکھ جمع آسن، تہٕ یِکینژھاہ تہِ پتہٕ تمہِ دۅ ہ سپدِ ، سارِنٕے ہٕنزن أچھن برونٛہہ کنہِ سپدِ۔"
  11,104,"۔تمہِ کِس اَننس منٛز چِھنہٕ أسۍ سٮ۪ٹھاہ زیادٕہ ژیر کران کینٛہہ، بس اَکھ گٕنز رِتھ ژٲرِتھ مُدّت چھےٚ اَمہِ خٲطرٕ مقرر۔"
  11,105,"۔ییٚلہِ سُہ یِیہِ ،تیٚلہِ آسہِ نہٕ کٲنٛسہِ کتھ کر نٕچ مجال ، اِلاّیہِ زِ اللہ تعالیٰ سٕنٛدِاجازتہٕ کرِ کینٛہہ عر ض،پتہٕ آسن کینٛہہ لُکھ تمہِ دۅ ہ بد بخت تہٕ کینٛہہ آسن نیک بخت۔"
  11,106,"۔یِم بد بخت آسن تِم گژھن جہنمس ﴿ییٚتہِ تر یشہِ تہٕ گر می ہٕندِ شِدّت سٍتۍ﴾تِم پھرٛکن تہٕ پھوٗنکن ۔"
  11,107,"۔تہٕ أتھۍ حالتس منٛز روزن تِم ہمیشہ، یوٚت تام زمین تہٕ آسمان قٲیم چِھ ﴿محا ورٕہ رٔنگۍ چِھ یِم لفظ ہمیشگی ہٕندِس معنیس منٛز وَرتاو نہٕ یِوان ﴾ اِلّایہِ زِ تُہُند ربّ ییژِھہ بیٚیہِ کینٛہہ، بے شک چُھ تُہُند ربّ پوٗرٕ اختیار تھاوان زِ یہِ ییٚژِھہ تہِ کرِ۔"
  11,108,"۔روٗدۍ تِم لُکھ یِم نیک بخت نیرن،تِم گژھن جنتس تہٕ تَتہِ روزن ہمیشہ ،یوٚت تام زمین تہٕ آسمان قٲیِم چِھ، اِلّایہِ زِ تُہُند ربّ ییژِھہ بیٚیہِ کینٛہہ، تِژھہ بخشِش میلہِ تِمن ییٚمیُک سلسلہٕ زانٛہہ ژھیٚنہِ نہٕ۔"
  11,109,"۔لہٰذا، اے نبی صلی اللہ علیہ وسلم،توٚہۍ مَہ روٗزِو تِمن معبودن ہٕندِ طر فہٕ کُنہِ شکس منٛز یِہٕنز عبادت یِم کران چِھ،یِم چِھ ﴿بس لکیرِ ہٕند فقیر بٔنِتھ﴾ تِتھے پٲٹھۍ پوٗزا پاٹ کران پکان،یِتھہٕ پٲٹھۍ گۅڈٕ یِہٕندۍ مٲلۍ بُڈِ بب کران ٲسۍ، تہٕ أسۍ دِمَو بھر پوٗر یِمن یُہُند حصہٕ،اَمہِ ورٲے زِ تَتھ منٛز آسہِ کانٛہہ ژٹھ کپَٹھ۔ع"
  11,110,"۔اَسہِ چھےٚ ییٚمہِ برونٛہہ مو سیٰ ﴿علیہ السلامس﴾ تہِ کتاب دِژِ مٕژ تہٕ اَتھ با رس منٛز تہِ اوس اختلاف کر نہٕ آمُت ﴿یِتھہٕ پٲٹھۍ اَز یَتھ کتا بہِ ہٕندِس بارس منٛز چُھ کر نہٕ یِوان ، یۅسہٕ تۅہیہِ چھےٚ دِنہٕ آمٕژ﴾اگر تُہٕندِ س ربّ سٕندِ طر فہٕ گۅڈ ے آسِہے نہٕ اکھ کتھ طے کر نہٕ آمٕژ،تیٚلہِ آسِہے یِمن اختلا ف کر ن والیٚن در میان خبر کر فٲصلہٕ کرنہٕ آمُت، پَزر چُھ یہِ زِ یِم لُکھ چِھ اَمہِ طر فہٕ شکس تہٕ دُل مُلِس منٛز پیٚمٕتۍ۔"
  11,111,"۔تہٕ یِتہِ چُھ پَزر کہ تُہُند ربّ دِیہِ یِمن یِہندِ ٮ۪ن اعما لن ہُند پوٗرٕ پوٗرٕ بد لہٕ، پٔزۍ پٲٹھۍ چُھ سُہ یِہِنز و تمام حر کتو نِشہِ با خبر۔"
  11,112,"۔لہٰذا ،اے  نبی صلی اللہ علیہ وسلم ، توٚہۍ تہٕ تُہٕندۍ تِم سٲتھۍ یِم  کفر و بغا و ت پٮ۪ٹھہٕ ایمانس تہٕ اطا عتس کُن﴾ پھیرۍ مٕتۍ چِھ ، روٗزِ و ٹھیک پٲٹھۍ راہِ راستس پٮ۪ٹھ ثٲبِت قد م، یِتھہٕ پٲٹھۍ زن تۅہیہِ حکم چُھ دِنہٕ آمُت۔ تہٕ بند گی ہٕندِ حدٕ ہ نِشہِ مَہ کٔرِ و تجا وُز۔ یِکینژھاہ توٚہۍ کران چِھو تَتھ پٮ۪ٹھ چُھ تُہُند ربّ نظر تھاوان۔"
  11,113,"۔یِمن ظٲلِمن کُن نٔمۍ زِیٚو نہٕ رَژھ تہِ، نَتہٕ یِیِو جہنم کِس وَل گنتِس منٛز۔تہٕ تۅہیہِ میلہِ نہٕ کانٛہہ تِیُتھ ولی تہٕ سر پرست یُس تۅہیہِ خُدا یس نِشہِ بچٲوِتھ ہیٚکہِ ، تہٕ کُنہِ طر فہٕ واتہِ نہٕ تۅہیہِ مدد۔"
  11,114,"۔تہٕ وُچِھو ، نماز کٔرِ و قٲیِم دۅ ہ کیٚن دۅ شوٕ نۍ اَند ن پٮ۪ٹھ، تہٕ کینٛہہ رات سپد نس پٮ۪ٹھ ۔﴿دۅہ کیو اَند و نِشہِ چُھ مُراد صُبح تہٕ مغرب، تہٕ کینٛہہ رات سپد نس پٮ۪ٹھ چُھ مُراد عشا ہُک وقت۔ نمازِ ہٕندٮ۪ن وقتن ہُند تفصیل زانٛنہٕ مۅ کھہٕ وُچِھو سورۂ بنی اسرا یل آیت ،78، سورۂ طٰہٰ آیت ، 130،تہٕ سورۂ روم آیت 18،17﴾ در حقیقت چھےٚ نِیکیہِ بُرٲیِین دوٗر کران،یہِ چھےٚ اکھ یاد دِہٲنی تِمن لُکن خٲطرٕ یِم خُدا یس یاد تھاون وٲلۍ چِھ۔"
  11,115,"۔بیٚیہِ کٔرِو صبر، اللہ تعالیٰ چُھنہٕ نیکی کر ن والیٚن ہُند اجر ضا یع کران۔"
  11,116,"۔پتہٕ کیا زِ روٗدۍ نہٕ تِمن قو من منٛز یِم تۅہیہِ برونٛہہ چِھ گُز یمٕتۍ تِتھۍ رٕ تۍ لُکھ موجود،یِم لُکن زمینس منٛز فساد بر پا کر نہٕ نِشہِ رُکا وٕ ہن؟ یِتھۍ لُکھ اگر درٛا ے تہِ مگر درٛا ے کم، یِم اَسہِ یِمو قو مو منٛزٕ بچٲوۍ، ظٲلِم لُکھ روٗدۍ بس تِمنٕے مَزن پتہٕ پتہٕ، یِہِندۍ سامان تِمن سۅ لبہٕ گی سان دِنہٕ ٲسۍ آمٕتۍ،تہٕ تِم روٗدۍ مُجر م بٔنِتھ۔"
  11,117,"۔تُہُند ربّ چُھنہٕ تِیُتھ زِ بستی ین کرِ نا حق تبا ہ، ییٚلہِ زَن تِہندۍ روزن وٲلۍ آسن اصلا ح کر ن وٲلۍ۔"
  11,118,"۔بے شک اگر تُہُند ربّ ییژِھہ ہے،تیٚلہِ ہیکہِ ہے تمام انسانن اکٲے اُمّت بنٲوِتھ،مگر وۅ نۍ روزن تِم مختلف طر یقنٕے پٮ۪ٹھ پکان۔"
  11,119,"۔تہٕ غلط وَتہِ پٮ۪ٹھ پکنہٕ نِشہِ بچن صِر ف تِم لُکھ ، یِمن پٮ۪ٹھ ربّ سٕنز رحمت چھےٚ، اَمی ﴿ انتخا ب چہِ آزٲدی تہٕ اختیار تہٕ امتحا ن ﴾ خٲطرٕ ٲسۍ تٔمۍ تِم پٲدٕ کٔرِ مٕتۍ، تہٕ تُہٕندِ س ربّ سٕنز سۅ کتھ سپٕز پوٗرٕ ، یۅسہِٕ تٔمۍ ؤنِمٕژ ٲس، زِ بہٕ بَر ن جہنم جِنَو تہٕ انسا نو  سارِوٕے سٍتۍ۔"
  11,120,"۔اے نبی صلی اللہ علیہ وسلم، یِم پیغمبر ن ہٕندۍ قصہٕ یِم أسۍ توٚہۍ بو ز ناوان چِھو، یِم چِھ تِم چیز ،یِمو سٍتۍ أسۍ تُہُند دِل چِھ مضبو ط کران، یِمن منٛز مِیوٗ لُو تۅہیہِ حقیقتُک علم، تہٕ ایمان اَنن والیٚن سپٕز نصیحت تہٕ بیدٲری حٲصل۔"
  11,121,"۔روٗدۍ تِم لُکھ یِم ایمان چِھنہٕ اَنان ، تِمن ؤنِو زِ توٚہۍ روٗزِ و پننِس طر یقس پٮ۪ٹھ کٲم کران، تہٕ أسۍ چِھ پننِس طر یقس پٮ۪ٹھ کٲم کران، انجامِ کارُک کٔرِ و توٚہۍ تہِ انتظار تہٕ أسۍ تہِ چِھ مُنتظر۔"
  11,122,"انجامِ کارُک کٔرِ و توٚہۍ تہِ انتظار تہٕ أسۍ تہِ چِھ مُنتظر"
  11,123,"آسما نن تہٕ زمینس اندر یِکینژھاہ چُھپِتھ چُھ، سورُے چُھ اللہ تعالیٰ سٕندِس قدرت کِس قبضس منٛز،تہٕ سورُے معا ملہٕ چُھ تٔسۍ کُن یِوان رجو ع کر نہٕ ،لہٰذا ، اے نبی صلی اللہ علیہ وسلم، توٚہۍ کٔرِ و تٔمۍ سٕنز عبا دت تہٕ تٔسۍ پٮ۪ٹھ تھٲوِ و بھر وسہٕ ،یِکینژھاہ توٚہۍ لُکھ کران چِھو ، تُہُند ربّ چُھنہٕ تمہِ نِشہِ بے خبر ۔ع"
