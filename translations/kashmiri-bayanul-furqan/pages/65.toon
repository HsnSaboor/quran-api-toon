quran[12]{c,v,t}:
  65,1,"۔اے نبی صلی اللہ علیہ وسلم ،ییٚلہِ توٚہۍ لُکھ زنانن طلا ق دِیِو، تیٚلہِ ٲسِو تِمن تِہندِ عِد ت خٲطرٕ طلا ق دِوان ۔﴿عِد ت خٲطرٕ طلا ق دِ نَس چِھ زٕ ہ مطلب تہٕ یتھ جایہِ چِھ دۅ شو ے مُراد ۔اکھ یہِ زِ حیض کِس حا لتس منٛز مَہ دِیِوزَنانہِ طَلا ق بلکہ دِیو تمہِ وقتہٕ طلا ق ییٚمہِ سٍتۍ تٔمۍ سُند عِدّت شروع ہیٚکہِ سپدِ تھ۔دوٚ یُم زِ عِدّتس منٛز دِیِو رجوع کر نٕچ گُنجٲیش تھٲوِتھ  طلا ق ،یِتھہٕ پٲٹھۍ مَہ دِیِو طلا ق ییٚمہِ سٍتۍ رجوع کر نُک مو قعے روزِ نہٕ پَتھ کُن۔اَمہِ حُکمٕچ یۅسہِ تشر یح حد یثو نِشہِ میلان چھےٚ تمہِ مطٲبق چُھ طلا قُک قٲعدٕ ہ یہِ زِ حیض کہ وقتہٕ گژھہِ نہٕ طلا ق دِنہٕ یُن ، بلکہ گژِھہ تتھ طُہر کِس حالتس منٛز دِنہٕ یُن یتھ منٛز خاندارن آسہِ نہٕ خاندارِنہِ سٍتۍ مُبا شرت کٔر مٕژ، یا گژِھہ تتھ حا لتس منٛز دِنہٕ یُن ییٚلہِ زَن زنانہِ ہُند گو بہِ کھۅرآسُن پے آسہِ۔ تہٕ اَکی وقتہٕ گژھن نہٕ ترٛےٚ طلا ق دِنہٕ یِنۍ۔﴾ تہٕ عِدّتُک وقت گٕنز رِ و ٹھیک ٹھیک،تہٕ خُدایس کھۅٚژِ و یُس تُہُند ربّ چُھ۔ ﴿ یعنی طلا ق مَہ سمجِھو گِندُن کینٛہہ زِ طلا قُک اہم معا ملہٕ پیش یِنہٕ پتہٕ تہِ یِیہِ نہٕ یہِ یا د تھا و نہٕ زِ کر چُھ طلا ق دِنہٕ آمُت،کر گوٚو عِدّت شروع تہٕ اَتھ کر چُھ ختم گژُھن۔ییٚمہِ ساعتہٕ طلا ق دِنہٕ یِیہِ ،سُہ وقت تہٕ سُہ تٲریخ گژِھہ یاد تھاوُن ،تہٕ یِتہِ گژِھہ یا د تھا وُن زِ کتھ حالتس منٛز چُھ زنانہِ آمُت طلا ق دِنہٕ ﴾، ﴿عِدّت کہ وقتہٕ﴾ نَہ مَہ کٔڑِ یوٗکھ تِمہٕ توٚہۍ گھر و منٛزٕ، تہٕ نَہ مَہ نیرِن تِمہٕ پانہٕ ۔ ﴿ یعنی نَہ گژِھہ مَر د شرارتس منٛز یِتھ زنانہِ گھرٕ منٛزٕ کڑُن ، تہٕ نَہ گژِھہ زنانہٕ شرارتس منٛز یِتھ ژَلٕنۍ۔عِدّتس تام چُھ گھرٕ أمۍ سُند۔أتھۍ گھرس  منٛز پزِ دۅ شوٕنۍ روزُن تاکہ پانہٕ وٲنۍ اگر کانٛہہ مو افقتٕچ صوٗرت نیٖرِ تھ ہیٚکہِ ، تیٚلہِ  ہیٚکہِ تمہِ نِشہِ فٲیدٕ ہ تُلنہٕ یِتھ۔اگر دۅشوے أکِس گھرس منٛز روزن ،ترٮ۪ن ریٚتن یا ترٛے حیض یِنس تام یا گۅ بہِ کھۅر آسنہٕ کِس صوٗرتس منٛز خلا ص گژھنس تام ہیٚکن اَمِکۍ مو قع بار ہا یِتھ۔﴾ اِلّا یہِ زِ تِمہٕ گژھن کُنہِ ٹا کارٕہ بُرٲیی ہٕنزٕ مُرتکب۔﴿یعنی بد چلنی ہِنزٕ مرتکب سپدن یا روزَن عِدّت کِس وقتس منٛز ژُوان تہٕ بد زبٲنی کران۔﴾ یِم چِھ اللہ تعالیٰ سٕندۍ مُقرر کر نہٕ آمٕتۍ حد،تہٕ یُس کانٛہہ اللہ تعالیٰ سٕند یو حدَو نِشہِ نیرِ ،سُہ کرِ خۅد پا نس پٮ۪ٹھ ظُلم، توٚہۍ چِھو نہٕ زانان ، بنان چُھ اللہ تعالیٰ کرِ امہِ پتہٕ ﴿ مو ا فقتٕچ ﴾ کانٛہہ صوٗرت پٲدٕہ۔"
  65,2,"۔پتہٕ ییٚلہِ تِمہٕ پننِس ﴿عِدّت کِس ﴾ خٲتِمس پٮ۪ٹھ واتن، تیٚلہِ رُکٲوِ یوٗکھ تِمہٕ جان طر یقہٕ ﴿ پننِس نکا حس منٛز ﴾ نَتہٕ سپدِ و جا ن طر یقہٕ تِمو نِشہِ جُدا۔ تہٕ تِتھۍ زٕہ نفر بنٲوِ یوٗکھ گواہ یِم تۅہیہِ منٛز صا حبِ عد ل آسن۔﴿ امہِ نِشہِ چُھ مُراد طلا قس پٮ۪ٹھ تہِ گواہ تھٲوٕنۍ تہٕ رجوع کر نس پٮ۪ٹھ تہِ﴾۔تہٕ ﴿اے گواہ بنَن والیو ! ﴾ گوٲہی کٔرِ وٹھیک ٹھیک اللہ تعالیٰ سٕندِ خٲطرٕ ادا۔
یِمہٕ چھےٚ کتھہٕ یِہٕنز نصیحت تۅہیہِ لُکن کر نہٕ چَھو یِوان، پرٛتھ تس شخصس یُس اللہ تعالیٰ تہٕ ٲخرت کِس دۅہس پٮ۪ٹھ ایمان آسہِ تھا وان۔﴿یِم لفٕظ چِھ پانہٕ وَنان زِ یِم ہدا یات پٮ۪ٹھہٕ کنہِ چِھ دِنہٕ آمٕتۍ تِم چِھ نصیحتٕچ حیثیت تھاوان، نَہ زِ قا نو نٕچ ۔اگر اِنسان وَننہٕ آمتِس طریقس خلا ف طلا ق دِیہِ ، عِدّتُک شما ر تھا وِنہٕ یا د،خاندار نہِ کڑِ معقول عُذرٕ ورٲے گھرٕ منٛزٕ ،عِدّت مۅ کلنس پٮ۪ٹھ کرِ زنانہٕ ستا و نہٕ خٲطرٕ رجوع ،اگر رخصت کر یٚس تیٚلہِ کریس ژُوان  ژُوان، تہٕ طلا قس ،رجوعس، علحٰید گی،کُنہِ چیز س پٮ۪ٹھ تہِ تھا و نہِ گواہ،اَمہِ سٍتۍ پیٚیہِ نہٕ طلا قس ،رجوعس تہٕ علحیٰد گی ہٕنٛد ٮ۪ن قا نو نی نتیجن منٛز کانٛہہ فر ق۔البتہ اللہ تعالیٰ سٕندِس نصیحتس خلا ف عمل کرٕنۍ آسہِ اَمہِ کتھہِ ہٕنز دلیل زِ أمۍ سٕندِس دِلس منٛز چُھنہٕ اللہ تعالیٰ تہٕ ٲخرت کِس دۅہس پٮ۪ٹھ صحیح ایمان مو جود ، ییٚمہِ کِس بِنا ہس پٮ۪ٹھ أمۍ سُہ طر زِ عمل اختیار کوٚر ، یُس أکِس جان مو منس اختیار پَزِ نہٕ کرُن﴾۔یُس اکھا ہ خُدایس کھوٚژِتھ کٲم کرِ، اللہ تعالیٰ کرِ تٔمۍ سٕندِ خٲطرٕ مُشکلا تو منٛزٕ نیرٕ نٕچ کانٛہہ وَتھ پٲدٕہ۔"
  65,3,"۔ تہٕ أمِس دِیہِ تِژِھہ وَتہِ کِنۍ رِزق یو ر نہٕ تٔمۍ سُند گُمان تہِ آسہِ گژھان۔یُس خُدایس پٮ۪ٹھ بھروسہٕ کرِ تٔمۍ سٕندِ خٲطرٕ چُھ سُہ کٲفی۔ اللہ تعالیٰ چُھ پنٕنۍ کٲم پوٗرٕ کٔرِتھ روزان، خُداین چُھ پرٛتھ چیزٕ خٲطرٕ اکھ تقدیر مقرر کٔرِ تھ تھوومُت۔"
  65,4,"۔تہٕ تُہنز وزَنا نَو منٛزٕ یِمہٕ حیض نِشہِ آسن نا اُمید گٔمٕژ، تِہندِ س معا ملس منٛز اگر تۅ ہیہِ شک چُھ لا حق تیٚلہِ ﴿ گٔژھیوٚ تۅہیہِ معلو م آسُن ﴾ تِہُند عدّت چُھ ترےٚ ریٚتھ۔تہٕ یۅہے حکم چُھ تِہُند یِمن وُنہِ ما ہؤری ﴿حیض ﴾ آسہِ نہٕ گوٚ مُت ﴿ خوا ہ متہٕ ٲسِتن حیض لۅ کچا رٕ کِنۍ آمُت یا امہِ و جہ زِ کیںٛژھن مستوٗراتن چُھ واریا ہہِ کٲلۍ حیض یُن شروع گژھان ، تہٕ خال خا لٕے چُھ یہِ سپدان زِ کٲنٛسہِ زَنہِ چُھنہٕ سٲرِ سٕے وٲنٛسہِ یِوان، بہر حا ل چُھ تمام صوٗرتن منٛز یِژِھہ زَنہِ ہُند عدّت سُے یُس ﴿ آیسہ﴾ زنانہِ ہُند عدّت چُھ یعنی طلا ق کہ وقتہٕ پٮ۪ٹھہٕ ترٛےٚ ریٚتھ﴾ تہٕ گۅ بہِ کھۅ ر مستوٗراتن ہندِ عِدّتُک حد چُھ یہِ زِ تِمہٕ گژھن خلا ص گژھنہِ۔ ﴿یعنی زٔنۍ گٔژھۍ تن خا ندار سٕندِ وَفات پتہٕ فوراً خلا ص یا لٔگۍ تنس 4، ریٚتھ دَاہ دۅہ کھۅتہٕ زیادٕہ وقت،بہر حال گِژھہ خلا ص سپدنس سٍتۍ تٔمۍ سُند عِدّت ختم﴾ یُس شخص خُدایس کھۅژِ ، تٔمۍ سٕندِ س معا ملس  منٛز چُھ سُہ سہولیت پٲدٕ کران۔"
  65,5,"۔ یہِ چُھ اللہ تعالیٰ سُند حکم یُس تٔمۍ تۅہیہِ کُن چُھ نٲزِل کوٚر مُت۔یُس خُدایس کھۅ ژِ، اللہ تعالیٰ کرِ تٔمۍ سٕنزٕ بُرٲیِیہِ تس نِشہِ دوٗر، تہٕ تس دِیہِ بوٚڈ اجر۔"
  65,6,"۔ تِمہٕ تھٲوِیوٗکھ ﴿عدّت کِس وقتس منٛز ﴾ تٔتھۍ جایہِ ییٚتہِ توٚہۍ چِھو روزان ،یِژھ جاے تہِ تۅہیہِ دستیا ب آسہِ ، تہٕ تِمہٕ تنگ کر نہٕ موجوٗب مَہ ستا وِیوٗکھ تِمہٕ۔تہٕ اگر تِمہٕ گۅبہِ کھۅر آسن تیٚلہِ روٗزِ و تِمن پٮ۪ٹھ تتھ وقتس تام خر چ کران،یوٚت تام نہٕ تِمہٕ خلا ص گژھن۔پتہٕ اگر تِمہٕ تُہٕندِ خٲطرٕ ﴿شُرِس ﴾ چاوَن دۅہ،تیٚلہِ دِ یِو تِمن تِہٕنز اُجرت،تہٕ رٔتۍ پٲٹھۍ کٔرِو ﴿ اُجرتُک معا ملہٕ ﴾ پانہٕ وٲنۍ کتھ با تھہِ سٍتۍ مقرر،البتہ اگر تۅہیہِ ﴿اُجرت مقرر کر نس منٛز ﴾ اکھ بیا کھ تنگ کوٚروٗن،تیٚلہِ چاوِ بد ل خا تو ن شُرِس دۅہ۔"
  65,7,"۔یُس خۅشخال نفر آسہِ سُہ دِیِن پننہِ خۅشحٲلی مطٲبق نفقہ،تہٕ یَس رزق کم آسہِ دِنہٕ آمُت،سُہ کٔرِ ن تَمی مالہٕ منٛزٕ خر چ یُس خُداین چُھ تس دِیتمُت۔خُداین یَس یِکینژھاہ دِ یتمُت چُھ، تمہِ کھۅتہٕ زیادٕہ چُھنہٕ سُہ تس مکلّف ٹھہراوان﴿ یعنی بار چُھس نہٕ تراوان،﴾ یہِ کتھ چَھنہٕ دوٗر زِ اللہ تعالیٰ کرِ تنگ دستی پتہٕ فر اخ دستی تہِ عطا ۔ع"
  65,8,"۔ کٲژاہ بستی چھےٚ یِمو پننِس ربّ سٕنز تہٕ تٔمۍ سٕندٮ۪ن رسولن ہٕندِس حکمس شر کشی کٔر ﴿وۅ نۍ چُھ مُسلمانن یِوان تنبیہ کر نہٕ زِ اللہ تعالیٰ سٕندِس رسول صلی اللہ علیہ وسلم  تہٕ تٔمۍ سٕنزِ کتا بہِ ہٕندِ ذر یعہِ یِم احکام تِمن دِنہٕ چِھ آمٕتۍ،اگر تِم یِہنز نا فر مٲ نی کر ن تیٚلہِ کُس انجام پیٚیہِ تِمن دُنیا ہس تہٕ  ٲخرتس منٛز وُچھُن ،تہٕ اگر اطا عتٕچ وَتھ کرن اختیار تیٚلہِ کُس جزا کرن حٲصل﴾ اَسہِ ہِیوٚت سختی سان تِمن حسا ب،تہٕ تِمن دِیُت وُلٹہٕ پٲٹھۍ سزا۔"
  65,9,"۔تِمو وُچھ پننہِ کرِ مَتِیُک سزا، تہٕ تِہُند انجام کار چُھ گا ٹے گاٹہٕ،"
  65,10,"۔خُداین چُھ ﴿ٲخرتس منٛز﴾ تِہندِ خٲطرٕ سخت عذا ب تھو و مُت دستیا ب۔ لہٰذا کھوٚژِ و خُدایس اے صا حبِ عقل لُکو، یِمو ایمان چُھو اوٚنمُت،خُداین چھےٚ تۅ ہیہِ کُن اکھ نصیحت کٔرمٕژ نٲزِل،"
  65,11,"۔اکھ تِیُتھ رسول صلی اللہ علیہ وسلم یُس تۅہیہِ اللہ تعالیٰ سٕندۍ صا ف صاف ہدایات دِنہٕ وٲلۍ آیات چُھو بوزناوان﴿ مفسر و منٛزٕ چُھ کینٛژھو ووٚ نمُت زِ نصیحت نِشہِ چُھ مُراد قرآن تہٕ رسولس نِشہِ چِھ مُراد محمد صلی اللہ علیہ وسلم۔تہٕ کینٛہہ چِھ ونان زِ نصیحت نِشہِ چِھ مُراد پانہٕ رسول اللہ صلی اللہ علیہ وسلم ،یعنی تِہٕنٛز ذات ٲس کُلہُم پٲٹھۍ نصیحت۔اَسہِ نزدیک چُھ یہِ دوٚ یُم تفسیر زیا دٕہ صحیح﴾ تا کہ ایمان انَن والیٚن تہٕ نیک عمل کر ن والیٚن اَنہِ ، اَنہِ گٹَو منٛز کٔڑِتھ گاشس کُن۔یُس کانٛہہ خُدایس پٮ۪ٹھ ایمان اَنہِ تہٕ نیک عمل کرِ، اللہ تعالیٰ کرِ تس تِتھیٚن جنّتن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅلہٕ آسن پکا ن۔ یِم لُکھ روزن تِمن منٛز ہمیشہ ہمیشہ۔خُداین چُھ یِتھِس شخصس خٲطرٕ بہتر ین رِزق تھو و مُت۔"
  65,12,"۔اللہ تعالیٰ چُھ سُہ ییٚمۍ سَتھ آسمان بنٲوۍ تہٕ زمین کہ قٔسمٕکۍ تِمنٕے ہِوۍ،﴿"" تِمنٕے ہِو ۍ "" اَمیُک مطلب چُھنہٕ یہِ زِ ییتیاہ آسمان بنٲوِ ن تِژَے بناویٚن زمینہٕ تہِ ، بلکہ چُھ مطلب یہِ زِ یتھہٕ پٲٹھۍ تٔمۍ واریاہ آسمان چِھ بنٲوِمٕتۍ ، تِژھے بنا و یٚن واریاہ زمینہٕ تہِ ۔تہٕ "" زمین کہ قسمٕکۍ "" اَمیُک مطلب چُھ یہِ زِ یِتھہٕ پٲٹھۍ یہِ زمین یتھ پٮ۪ٹھ انسان چِھ روزان چھےٚ پننیو مو جود اتو خٲطرٕ فر ش تہٕ مَنزُل، تِتھے پٲٹھۍ چھےٚ خُداین کا ینا تس منٛز بیٚیہِ زمینہٕ تہِ بنا وِمَژٕ ، یِمہٕ پننیٚن پننیٚن آبٲدِ ین خٲطرٕ فر ش تہٕ مَنزُل چھےٚ۔دوٚ یِمیٚن لفظن منٛز وَنو زِ آسما نس پٮ۪ٹھ یِم بے شما ر تارک تہٕ سیّارٕ ہ چِھ نظرِ گژھان یِم سٲری چِھنہٕ وٲران کھنڈراتن ہٕنٛدۍ پٲٹھۍ کینٛہہ، بلکہ چِھ زمینٕکۍ پٲٹھۍ یِمن منٛز تہِ چِھ واریاہ تِتھۍ یِمن منٛز دُنیا چِھ آباد ۔﴾ تِمن در میان چُھ حُکم نٲزِل سپدان روزان۔﴿ یہِ کتھ چَھو تۅہیہِ اَمہِ موجو ب یِوان وَننہٕ ﴾ تا کہ توٚہۍ زٲنِو زِ اللہ تعالیٰ چُھ پرٛتھ چیز س پیٚٹھ قد رت تھا وان، بیٚیہِ یہِ زِ اللہ تعالیٰ سُند علم چُھ پرٛتھ  چیز س پٮ۪ٹھ احا طہٕ کٔرِتھ۔ع"
