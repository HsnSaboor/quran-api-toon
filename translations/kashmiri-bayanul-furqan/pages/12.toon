quran[111]{c,v,t}:
  12,1,"۔ا۔ل۔ر۔، یِم چِھ تمہِ کتا بہِ ہٕندۍ آیات ، یۅسہٕ پنُن مُدعا صا ف صا ف چھےٚ بیان کران۔"
  12,2,"۔ اَسہِ چُھ یہِ نٲزِل کوٚر مُت قرآن بنٲوِتھ عر بی زبٲنۍ منٛز ﴿ قرآنٕکۍ لُغوی معنی چِھ پرُن ، تہٕ اتھ کتا بہِ یہِ ناو کر نُک مطلب چُھ یہِ زِ یہِ چھےٚ خا صن تہٕ عا من ہٕندِ پر نہٕ خٲطرٕ ، تہٕ یہِ چھےٚ بکثر ت پر ن وول چیز﴾ تا کہِ توٚہۍ ﴿ اہلِ  عر ب ﴾ ہیٚکیوٗن یہِ جان پٲٹھۍ سمجِھتھ۔"
  12,3,"۔اے نبی صلی اللہ علیہ وسلم، أسۍ چِھ یہِ قرآن تۅہیہِ کُن و حی کٔرِ تھ بہتر ین اندا زس منٛز وا قعات تہٕ حقا یق تۅہیہِ بیان کران، نَتہٕ ٲسِو توٚہۍ ییٚمہِ برونٛہہ﴿یِمو چیز و نِشہِ ﴾ با لکُلٕے بے خبر۔"
  12,4,"۔یہِ چھےٚ تمہِ وقتٕچ ذِکر ییٚلہِ حضرت یو سف علیہ السلام پننِس با بہٕ صٲبس چِھ ونان ابا جان، مےٚ چُھ خوا ب وُچھمُت ، زِ کاہ تارک چِھ ، بیٚیہِ چُھ آفتا ب تہٕ زوٗن ،تہٕ تِم چِھ مےٚ سجدٕہ کران۔"
  12,5,"۔ در جواب ووٚ ن تِہندۍ با بہٕ صٲبن، گو بر یا ، پنُن یہِ خوا ب ؤنۍ زینہٕ پننیٚن با ین، نَتہٕ واتنا و نے تِم ژےٚ نقصا ن﴿حضرت یوسف علیہ السلامس چِھ داہ با ے با قی ماجن ہٕندۍ آسان ، ییٚلہِ زن بِن یمین تِمن  کو نٛس کوٚٹ تہٕ پنُن سخ بو ے چُھ  آسان۔حضرت یعقو ب علیہ السلام ٲسۍ زانان زِ وۅ رٕ با ین چُھ یو سف علیہ السلامس سٍتۍ حسد تہٕ تِم چِھنہٕ اخلا ق لحا ظہٕ تہِ تیٖتیاہ صا لح زِ تِم ہیٚکن پنُن مطلب کڑ نہٕ خٲطرٕ کا نٛہہ تہِ ناروا کار روٲیی کٔرِتھ ۔لہٰذا چِھ تِم پننِس صا لح فر زند س تٲکید کران زِ یِمن نِشہِ روٗزۍ زِ ہُشار۔خوابُک مطلب اوس صا ف زِ آفتا ب نِشہِ اوس مُراد حضرت یعقو ب علیہ السلام، زوٗنہِ نِشہِ اوس مُراد تِہٕنز خاندارِنۍ ﴿حضرت یو سف علیہ السلامن ہٕنز وۅ رٕ مو ج تہٕ کاہ ستارٕہ چُھ مُراد کاہ بٲے۔﴾حقیقت چھےٚ یہِ زِ شیطا ن چُھ انسان سُند ٹا کارٕ دشمن۔"
  12,6,"۔تہٕ یی سپدِ  یہِ ژےٚ خوا بس منٛز وُچھمُت چھُے زِ  چو ن ربّ کر ی ژےٚ ﴿پننہِ کامہِ خٲطرٕ ﴾ منتخب تہٕ ژےٚ ہیچھنٲوی کتھن ہٕندِس ژٔکِس تل وا تُن ﴿دراصل چِھ  تَا وِیلِ الاَّ حَا دِیث الفا ظ ورتاو نہٕ آمٕتۍ،یُہُند مطلب صرف خوا ب کہ تعبیر کُے یو ت علم چُھنہٕ یِتھہٕ پٲٹھۍ زن گُما ن چُھ  کر نہٕ آمُت، بلکہ چُھ اِمِیُک مطلب یہِ زِ اللہ تعالیٰ دِی ژےٚ معا ملہٕ فہمی تہٕ حقیقت پرٛز ناونٕچ تعلیم ، تہٕ سۅ بصیرت کٔر ی عطا ، ییٚمہِ سٍتۍ ژٕ پرٛتھ معا ملہٕ کِس سَنرس منٛز تہٕ تمہِ کِس ژٔکِس تام وا تنس قٲبل سپد کھ﴾ بیٚیہِ کرِ ژےٚ پٮ۪ٹھ تہٕ آلِ یعقو ب علیہ السلامس  پٮ۪ٹھ پنٕنۍ نعمت تِتھے پٲٹھۍ پوٗرٕ، یِتھہٕ پٲٹھۍ ییٚمہِ برونٛہہ تٔمۍ چا نیٚن بزر گن ابرا ہیم علیہ السلام تہٕ اسحا ق ﴿علیہ السلامس﴾ پٮ۪ٹھ کٔر مٕژ چھےٚ، پٔز ۍ پٲٹھۍ چُھ چو ن رب علم وول تہٕ حکمت وول۔"
  12,7,"۔حقیقت چھےٚ یہ، یو سُف علیہ السلام تہٕ تِہندِ ٮ۪ن  با ین ہٕندِس قصَس منٛز چھےٚ یِمن پٕرٛژھن والیٚن خٲطرٕ  بجہِ نشٲنیہِ ۔"
  12,8,"۔یہِ قصہٕ چُھ یِتھہٕ پٲٹھۍ شروع سپدان زِ تٔمۍ سٕند یو با یَو ووٚن پانہٕ وٲنۍیہِ یو سف تہٕ أمۍ سُند بو ے ﴿مُراد چُھ حضر ت یوسف علیہ السلامن ہُند سخ بو ے بِن یمین،یُس تِمن علیہ السلامن کینٛہہ ؤری کو نس اوس ﴾ دۅ شو ے چِھ سٲنِس مٲلِس سانہِ نِشہِ زیادٕہ ٹٲٹھۍ، حالانکہ أسۍ چِھ پوٗرٕ اکھ کھیٚج، پٔز کتھ چھےٚ یہِ زِ سو ن با بہٕ صٲب چُھ بالکُلے ڈوٚلمُت۔"
  12,9,"۔پٔکِو یو سف کٔرِ یوٗن قتل یا چھکیوٗن سُہ کُنہِ جایہِ ، تا کہ تُہٕندِس مٲلۍ سُند تو جہ پھیرِ صرف تۅہیہِ کُن، یہِ کٲم کر نہٕ پتہٕ بٔنۍ زِ یو پتہٕ بیٚیہِ نیک۔"
  12,10,"۔اَتھ پٮ۪ٹھ ووٚن تِمو منٛزٕ أکۍ  یو سف علیہ السلام مَہ کٔرِ یوٗن قتل، سُہ چھکِیوٗن کُنہِ انہِ گٔٹۍ کِرٛ یرِس منٛز، کانٛہہ یِنہٕ گژھ وُن قٲفلہٕ نِیس تَمہِ منزٕکٔڑِتھ، اگر کینٛہہ کر نُے چُھو۔"
  12,11,"۔اتھ فٲصلس پٮ۪ٹھ ووٚن تِمو پننِس مٲلِس نِشہِ گٔژِھتھ  ابا جان ، یہِ کیا دلیل چھےٚ زِ توٚہۍ چِھو نہٕ یو سف سٕندِ س معا ملس منٛز اسہِ پٮ۪ٹھ بھر وسہٕ کران، حالانکہ أسۍ چِھ تٔمۍ سٕندۍ پٔزۍ خیر خوا ہ ؟"
  12,12,"۔پگا ہ سوٗزِ یوٗن سُہ اسہِ سٍتۍ، کینژھاہ کھیٚیہِ چیٚیہِ ﴿پھیٖرِ تھ تھوٗرِتھ﴾ ۔﴿دراصل چِھ لفظ  یَر تَع، کُچھ چَر چُگ لے گا ورتاو نہٕ آمٕتۍ۔اُردو محا ورس منٛز ہرگاہ شُر جنگلس منٛز اورٕ یو ر پھیرِ تھ کینٛہہ پھل ژٹان تہٕ کھیو ان پکہِ ، تیٚلہِ چِھ تس خٲطرٕ لو لہٕ سان یِم لفظ ورتاو نہٕ یِوان ﴾ تہٕ گِند نہٕ درٛو کنہٕ سٍتۍ تہِ رنز ناوِدِل، أسۍ چِھ أمۍسٕندِ حفا ظت خٲطرٕ موجود۔"
  12,13,"۔مٲلۍ ووٚنکھ،  تُہُند یہِ پا نس سٍتۍ نِیُن چُھ مےٚ عذا ب کران،تہٕ مےٚ چُھ اند یشہٕ زِ خبر أمِس ما کھیٚیہِ را مہٕ ہوٗن ژٹھ کپٹھ کٔرِ تھ، ییٚلہِ زن توٚہۍ امہِ نِشہِ غٲفل ٲسِو۔"
  12,14,"۔تِمو دِیُت جوا ب  سانہِ آسنہٕ با وجود اگر یہِ را مہٕ ہوٗنۍ کھیٚو و ، ییٚلہِ زن أسۍ اکھ کھیٚج چِھ ، تیٚلہِ آسو أسۍ سٮ۪ٹھہٕے خسا رٕ ہ لد ﴿بیٚہو ال﴾۔"
  12,15,"۔ یِتھہٕ پٲٹھۍ ییٚلہِ اصرار کٔرِ تھ تِمو سُہ نِیوٗ، تہٕ تِمو کوٚر فٲصلہٕ زِ یہِ تراوون أکِس اَنہِ گٔٹۍ کرِ یرس منٛز، پتہٕ کٔر اسہِ یو سف ﴿علیہ السلامس ﴾ وَحی زِ  اکھ وقت واتہِ ییٚلہِ ژٕ یِمن یِہٕنز یہِ حر کت یاد پاو کھ،یِم چِھ پننہِ کامہِ ہٕند یو نتیجو نِشہِ بے خبر۔"
  12,16,"۔شا مس آے تِم وَدان تہٕ بُتھہِ بُتھہِ دِوان مٲلِس نِشہِ ۔"
  12,17,"۔تہٕ ووٚ نُکھ  اباجان ، أسۍ ٲسۍ دورِ ہُند مقا بلہٕ کر نس کُن لگمٕتۍ، تہٕ یو سف علیہ السلام اوس اسہِ پننِس سامانس نِشہِ تر وو مُت، تہٕ اتھ دوران آو  را مہٕ ہوٗن تہٕ تٔمۍ کھیو و سُہ توٚہۍ کٔرِ و نہٕ سانہِ کتھہِ پژھ،اگر چہِ أسۍ پٔزِیٲری کو نہٕ آسو ۔"
  12,18,"۔تہٕ تِمو ٲس یو سف علیہ السلام سٕنز قمیض اَپُز مَپُز خو ن مٔتِتھ أنۍ مٕژ،یہِ بو زِ تھ ووٚن تِہندۍ مٲلۍ  بلکہ تُہٕندۍ نفسن بنٲو تُہٕندِ خٲطرٕ تُہٕنز کٲم سہل، اچھا ، بہٕ کرٕ صبر تہٕ وارٕ پٲٹھۍ کرٕ صبر، یۅسہٕ کتھ توٚہۍ بناوان چِھو ، تتھ  پٮ۪ٹھ ہیکہِ اللہ تعالیٰ سٕے مدد منگنہٕ یِتھ۔"
  12,19,"۔اورٕ آو اَکھ  قٲفلہٕ تہٕ تٔمۍ سوٗز پنُن سقّہ آب اننہٕ خٲطرٕ ، سقّن یُتُھے کر یٖر س منٛز آبہٕ با نہٕ وول، ﴿ییٚلہِ تٔمۍ یو سف علیہ السلام وُچھ﴾ تٔمۍ لٲے کر یکھ مبا ر ک ٲسِنو ، ییٚتہِ چُھ اکھ لٔڑ کہٕ۔ تِمو لُکو چُھپو و سُہ تجا رتک مال زٲنِتھ، حالانکہ یِکینژھاہ تِم کران ٲسۍ، اللہ تعالیٰ  اوس تمہِ نِشہِ باخبر۔"
  12,20,"۔ٲخر کار کُن سُہ تِمو کینژھن دِ ر ہمن ہٕندِ بد لہٕ، تہٕ تِمن اوس نہٕ تٔمۍ سٕندِس قٍمت کِس معا ملس منٛز کُنہِ ہُر یمانہٕ ﴿ رقمُک ﴾ تو قع۔ ع"
  12,21,"۔ مصرٕ کۍ ییٚمۍ شخصن یہِ موٚ لۍ ہیوٚت تٔمۍ ووٚن پننہِ خاندارِنہِ ، یہِ تھٲوِ ز یٚن ٹھیک پٲٹھۍ، عنقر یب سپدِ یہِ سانہِ خٲطرٕ فا ید ہ مند ثٲبت، یا بناوون یہِ أسۍ پنُن نیٚچو۔ یِتھہٕ پٲٹھۍ کٔڑ اَسہِ یو سف علیہ السلام سٕندِ خٲطرٕ اتھ سر زمینس منٛز قد م جماو نٕچ صورت، تہٕ تَس کوٚر معا ملہٕ فہمی ہٕنز تعلیم دِنُک انتظا م، اللہ تعالیٰ چُھ پنٕنۍ کٲم کٔر تھٕے روزان، مگر اکثر لُکھ چِھنہٕ زانان۔"
  12,22,"۔تہٕ پتہٕ ییٚلہِ سُہ پننہِ پوٗرٕ جوٲنی تام ووت، تہٕ اسہِ کوٚر تس فٲصلہٕ کر نُک طا قت تہٕ علم عطا، یِتھہٕ پٲٹھۍ چِھ أسۍ نیک لُکن جزا دِوان۔"
  12,23,"۔ یس خا توٗ نہِ ہٕندِس گھرس منٛز سُہ اوس ،تٔمۍ لوگ سُہ ور غلا وُن،تہٕ اکہِ دۅہ کوٚرُن دروازٕ ہ بندٕ، تہٕ ووٚننس  وَلہٕ ۔ یو سف علیہ السلام چِھس ونا ن  اللہ تعالیٰ سُند پناہ، میٲنۍ ربّن کوٚر مےٚ رُت تھز ر عطا ﴿تہٕ بہٕ کرا،یہِ کٲم!﴾ ﴿عام پٲٹھۍ چُھ مفسرو تہٕ تر جمہٕ کر ن والیو یہِ سمجھمُت زِ یتھ جایہِ چُھ میٲنۍ ربّن  لفظ حضر ت یو سف علیہ السلامو تس شخصہٕ سٕندِ خٲطرٕ ور تو و مُت، ییٚمۍ سٕندِس مُلا زمتس منٛز تِم ٲسۍ، تہٕ تِہندِ امہِ جوا بُک مطلب اوس یہِ زِ میٲنۍ آقا ہن چُھنس بہٕ تمہِ رٕ تہِ آیہِ تھوو مُت ، پتہٕ کِتھہٕ پٲٹھۍ ہیٚکہِ بہٕ یہِ نمک حرٲمی کٔرِ تھ زِ تٔمۍ سٕنزِ خاندارِ نہِ سٍتۍ کرٕ بدکٲر ی۔مگر یہِ کتھ  چھےٚأکِس نبی سٕندِ شان نِشہِ ؤسۍ پایہِ زِ سُہ کرِ گنا ہ نِشہِ با زروزنہٕ خٲطرٕ اللہ تعالیٰ سٕندِ بجا ے کٲنٛسہِ بند ہ سُند لحا ظ ۔تہٕ قرآنس منٛز چَھنہٕ اَمِچ کانٛہہ مثال تہِ موجود زِ کٲنٛسہِ نبین کیا آسہِ خُدا یس ورٲے بیٚیہِ کٲنٛسہِ پنُن ربّ ووٚنمُت۔﴾ یِتھۍ ظا لم چِھنہٕ زانٛہہ کا میا نی لبان۔"
  12,24,"۔سۅ پٔچ تس کُن تہٕ یو سف علیہ السلام تہِ پکہِ ہے تس کُن۔ اگر سُہ پننِس ربّ سُند بُرھان وُچھِہے نہٕ﴿بُر ہان چُھ معنی تھاوان،دلیل تہٕ حُجت۔ ربّ سُند بُر ہان  چُھ مُراد اللہ تعالیٰ سٕنز ہٲومٕژ سۅ دلیل ، ییٚمہِ کِس بُنیا دس پٮ۪ٹھ حضر ت یو سف علیہ السلامن ہٕندۍ ضمیر ن تِہُند نفس امہِ کتھہِ ہُند قٲیل کوٚر زِ تس خا توٗنہِ ہٕنز عٲشِچ دعوت قبول کرٕنۍ چُھنہٕ چا نہِ خٲطرٕ شایانِ شان، تہٕ سۅ دلیل چھےٚ پٔتِمس جُملس منٛز آمٕژ زِ  میٲنۍ ربّن کوٚر مےٚ تھز ر عطا تہٕ بہٕ کرا یژِھ بُرٕ کٲم، یِتھیٚن ظا لمن چَھنہٕ کا میا بی حا صل سپدان۔ ﴾یی سپُد، تاکہ أسۍ کر ہَو تس نِشہِ بد ی تہٕ بے حیٲیی دوٗر، در حقیقت اوس سُہ سا نیو ژار نہٕ آمتیو بندو منٛزٕ۔"
  12,25,"۔ٲخر کار ژوٚل یو سف علیہ السلام تہٕ سۅ، اکھ أکِس پتہٕ دروازس کُن،تہٕ تَمہِ ژٔٹ پٔتۍ کِنۍ یو سف علیہ السلام سٕنز قمیض ﴿لٔمِتھ﴾ دروازس پٮ۪ٹھ وُچھ دۅ شوٕ یو تٔمۍ سُند خاندار موجود، تس وُچھان وُچھا نے لٔج خا تو ن وَننہِ کیا سزا چُھ تس شخصس یَس چا نہِ گھرٕ واجِنہِ پٮ۪ٹھ خراب نیت آسہِ ؟امہِ ورٲے کیا سزا ہیٚکہِ ٲسِتھ زِ سُہ گژِھہ قٲد کر نہٕ یُن،یا گژِھہ تس سخت عذا ب دِنہٕ یُن ۔"
  12,26,"۔ یو سف علیہ السلام چِھ ونان  یٔہے ٲس مےٚ پھساونٕچ کوٗشش کران ۔ أمِس خا تو نہِ ہٕندِ پننہِ خا ندانٕکۍ أکۍ شخصن کٔر ﴿مُنٲسِب طر یقہٕ﴾ شہا دت پیش، زِ اگر یو سف علیہ السلام  سٕنزقمیض بروٗنٹھۍ کِنۍ ژھیٚنۍ مٕژ آسہِ ، تیٚلہِ چھےٚ خا تو ن پٔزِ یٲر، تہٕ یہِ چُھ اَپزِ یو ر۔"
  12,27,"۔تہٕ ہرگاہ أمۍ سٕنز قمیض پٔتۍ کِنۍ ژھیٚنۍ مٕژ ٲس،تیٚلہِ چھےٚ خا توٗن اَپزِ یٲر، تہٕ یہِ چُھ پٔزِ یو ر ۔ ﴿مطلب چُھ یہِ زِ اگر یو سف علیہ السلامن ہٕنز قمیض برونٹھۍ کِنۍ ژھیٚنۍ مٕژ ٲس،تیٚلہِ چھےٚ یہِ امہِ کتھہِ ہٕنز ٹا کارٕ نشٲنی زِ اقدام اوس یو سف علیہ السلامن ہٕندِ طر فہٕ ، تہٕ خا تو ن ٲس پنُن پان بچا و نہٕ مۅ کھہٕ کشمکش کران، البتہ اگر یو سف علیہ السلامن ہٕنز قمیض پٔتۍ کِنۍ ژھیٚنۍ مٕژ ٲس ، تیٚلہِ چُھ امہِ نِشہِ صا ف ننان زِ خا تو ن ٲس تس پتہٕ دورا ن ،تہٕ یو سف علیہ السلام ٲسۍ تس نِشہِ بچُن یژھان۔ امہِ علا وہ ٲس اتھ منٛز منا سب طر یقٕچ بیا کھ شہا دت تہِ چُھپِتھ۔ سۅ ٲس یہِ زِ أمۍ شخصن ﴿شٲہدن﴾ پھِیرُ صرف حضرت یوسف علیہ السلامن ہٕنزِ قمیضہِ کُن تو جہ۔ امہِ نِشہِ سَپُد صا ف ظٲہر زِ خا تو نہِ ہٕندِس جسمس یا تٔمۍ سٕندِس پۅ شا کھس پٮ۪ٹھ اوس نہٕ گۅڈٕ ہ پٮ۪ٹھے کانٛہہ تشدُدک نِشا نہٕ، حالانکہ اگر یہِ مُقدِمہٕ اقدام زنا با الجبرُک آسِہے، تیٚلہِ آسٕہن خا تو نہِ ہٕندِس جسمس پٮ۪ٹھ اَمِکۍ ٹا کارٕ آثا ر ﴾"
  12,28,"۔ ییٚلہِ خا ندارن وُچھ زِ یو سف علیہ السلام سٕنز قمیض چھےٚ پٔتۍ کِنۍ ژھیٚنۍ مٕژ، تٔمۍ ووٚن  یِم چھےٚ تۅہیہِ زنانن ہٕنزٕ چالٲکیہِ ، پٔزۍ پٲٹھۍ چھےٚ بڈٕ خطر ناک آسان تُہٕنزٕ چالہٕ۔"
  12,29,"۔یو سف علیہ السلام،امہِ معا ملہٕ نِشہِ کردر گُز ر، تہٕ اے خا تو ن ژٕ منگ پننہِ غلطی پٮ۪ٹھ معٲفی، ژٕےٲسِکھ دراصل خطا کار ۔ ع"
  12,30,"۔شہر چو مستوٗراتو لاجہِ پانہٕ وٲنۍ سوٗسرِ گوٗسرِکر نہِ زِ عز یز سٕنز خاندارِنۍ چھےٚ پننِس نو جوان غلا مَس پتہٕ لٔج مٕژ، ﴿عز یز اوسنہٕ تس شخصہٕ سُند ناو ، بلکہ چُھ مصرس منٛز کٲنٛسہِ بٔڈِس اقتدار وٲلِس خٲطرٕ اصطلاح رٔنگۍ یہِ لفظ ورتاو نہٕ یِوان ﴾محبتن چھےٚ سۅ بے قا بو کٔرمٕژ،سٲنۍ کِنۍ چھےٚ سۅ ٹا کارٕہ غلطی کران۔"
  12,31,"۔تمہِ ییٚلہِ تِہنزٕ یِمہٕ مکا رانہٕ کتھہٕ بوزٕ ، تمہِ سوٗز تِمن ناد، تہٕ تِہندِ خٲطرٕ سجٲوٕ ن تکیہ دار مجلس تہٕ ضیا فتس منٛز تھٲوٕ ن پرٛتھ  کٲنٛسہِ برونٛہہ کنہِ اکھ اکھ شراکھ ، ﴿پتہٕ کوٚرُن عینِ تمہِ ساعتہٕ ییٚلہِ تِمہٕ میوٕ ہ آسہٕ ژٔٹۍ ژٔٹۍ کھیوان﴾ حضر ت یو سف علیہ السلامس اِشارٕہ زِ یِمن برونٛہہ کُن ولہٕ، ییٚلہِ تِمن مستوٗراتن ہٕنز نظر تس پٮ۪ٹھ پیٚیہِ ، تِم گٔیہِ رٔہِتھ تہٕ ژٔٹِکھ پنٕنۍ اَتھہٕ،تہٕ پٲنۍ پانے ژوٚ لُکھ نِیرِ تھ  حا شا لِلّہ ﴿پناہ خدا ے سُند ﴾ ، یہِ شخص چُھنہٕ انسان، یہِ چُھ کُستام تھدِ پایُک فر شتہٕ۔"
  12,32,"۔عزیز سٕنزِخاندارِنہِ ووٚن وُچھوٕ تۅہیہِ ، یہِ چُھ  سُہ شخص ییٚمۍ سٕندِس معا ملس منٛز توٚہۍ مےٚ پٮ۪ٹھ ٲسِو کتھہٕ کران،بےشک کٔر میے یہِ پھسا ونٕچ کوٗشش، مگر یہِ بچا و، اگر نہٕ یہِ میو ن وَنُن مانہِ،تیٚلہِ یِیہِ قٲد کر نہٕ، تہٕ پتہٕ سپدِ بےٚ عزت لُکن منٛز شمار۔"
  12,33,"۔یو سف  علیہ السلام چِھ ونان  اے میانہِ ربّ ! قٲد چُھم منظّو ر، بہ نسبت یہِ زِ بہٕ کرٕ سۅ کٲم یۅسہٕ یِم لُکھ مےٚ نِشہِ یژھان چِھ ، تہٕ اگر ژےٚ یِہنزٕ چالہٕ مےٚ نِشہِ دوٗر کر یٚتھ نہٕ، تیٚلہِ پھسہٕ بہٕ یِہندِ س زالس منٛز، تہٕ پتہٕ گژٕھہ جٲہلن منٛز شٲمل۔ تٔمۍ سٕندۍ ربّن کوٚر تٔمۍ سُند دُعا قبول، تہٕ یِمن مستوٗراتن ہٕنزٕ چالہٕ کر یٚن تَس نِشہِ دوٗر،"
  12,34,"۔بےٚ شک چُھ سُے ،یُس سارِنٕے ہُند بوزان چُھ تہٕ سورُے کینٛہہ زانان چُھ۔"
  12,35,"۔پتہٕ زو ن تِمو لُکو یہِ زِ أکِس وقتس تام کر و ن یہِ قٲد حالانکہ تِمو آسہٕ ﴿ تٔمۍ سٕنز پاک دا منی تہٕ خۅ د پننیٚن مستوٗراتن ہٕند ٮ۪ن بُرٕ اطوارن ہٕنزٕ ﴾ ٹا کارٕ نشٲیہِ وُچھمژٕ۔ ع ﴿امہِ نِشہِ لوٚ گ پے زِ کانٛہہ شخص انصا ف کیو شرا یطو مطا بق عدا لتس منٛز مجر م ثٲبت کر نہٕ ورٲے بس یو نہی رٔٹِتھ جیل سوزُن چُھ ،بے ایمان حکمرانن ہُند طر یقہ۔اتھ معا ملس منٛز چِھنہٕ أزِ کۍ شیطا ن تہِ ژور سا س ؤرۍ برونٛٹھمِیو شر پسند و کھۅ تہٕ زیادہ مختلف کینٛہہ۔"
  12,36,"۔قٲد خا نس منٛز سپد ۍ بیٚیہِ تہِ زٕہ غلا م تس سٍتۍ دٲخل ۔اکہِ دۅہ چُھ یِمو منٛزٕ اکھ ونان،  مےٚ چُھ خواب وُچھمُت زِ بہٕ چُھس شرا ب کشید ہ کران دوٚ یم ووٚن ،  مےٚ وُچھ زِ میٲنِس کلس پٮ۪ٹھ چھےٚ ژۅ چہِ تھا و نہٕ آمژٕ،تہٕ جاناوار چِھ یِمن کھیو ان۔ دۅ شوٕ یو ووٚ ن  اسہِ ؤنِو امِیُک تعبیر، أسۍ چِھ وُچھان زِ توٚہۍ چِھو نیک انسان ۔"
  12,37,"۔یو سف علیہ السلام چِھ ونان  ییٚتہِ یُس کھیٚن تۅہیہِ میلان چُھ، سُہ یِنہٕ برونٹھ وَنو بہٕ تۅہیہِ یِمن خوا بن ہُند تعبیر، یہِ چُھ تِمَوعلِمو منٛزٕ ،یِم میٲنۍ ربّن مےٚ عطا چِھ کٔرِ مٕتۍ، پَز ر چُھ یہِ زِ مےٚ چُھ تِمن لُکن ہُند طر یقہٕ ترٲوِ تھ یِم خُدا یس پٮ۪ٹھ ایمان چِھنہٕ انان، تہٕ ٲخرتس چِھ انکار کران،"
  12,38,"۔پننیٚن بُز ر گن ابرا ہیم علیہ السلام ، اسحا ق علیہ السلام تہٕ یعقو ب علیہ السلام سُند طر یقہٕ اختیار کوٚر مُت، سٲنۍ کٲم چَھنہٕ یہِ زِ خُدا یس سٍتۍ ٹھہراوون کانٛہہ شر یک،در حقیقت چُھ یہِ اللہ تعالیٰ سُند فضل اَسہِ پٮ۪ٹھ بیٚیہِ تمام انسانن پٮ۪ٹھ ﴿زِ تٔمۍ چِھنہٕ أسۍ پا نس ورٲے بیٚیہِ کٲنٛسہِ ہٕندۍ بند ہ بنٲوِمٕتۍ﴾ مگر اکثر لُکھ چِھنہٕ شُکر کران۔"
  12,39,"۔اے زندان کیو سٲتھیو، توٚہۍ سوٗنچتو پا نے زِ واریاہ متفرق ﴿الگ الگ ﴾ ربّ چھا بہتر، کِنہٕ سُہ اکھ اللہ تعالیٰ یُس سارِنٕے پٮ۪ٹھ غٲلِب چُھ؟"
  12,40,"۔سُہ ترٲوِ تھ یِہنٕز توٚہۍ عبادت کران چِھو، تِم چِھنہٕ امہِ ورٲے کِہِنۍ زِ بس چِھ کینٛہہ ناو، یِم تۅہیہِ تہٕ تُہند یو آبا و اجدادَو چِھ تھٲوِمٕتۍ، خُدا ین کٔر نہٕ یِہندِ خٲطرٕ کانٛہہ سَنَد نٲزِل، فر ما ن روایی ہُند اقتدار چُھنہٕ خُدا یس ورٲے کٲنٛسہِ ہٕندِ خٲطرٕ ، تٔمۍ سُند حکم چُھ زِ خۅد تس ورٲے مہ کٔرِ و بیٚیہِ کٲنٛسہِ ہٕنز عبادت، یۅ ہے چُھ زند گی ہُند اصلی سیوٚد طر یقہٕ ،مگر اکثر لُکھ چِھنہٕ زانان۔اے زندان کیو ساتھیو، تُہندِ خوا بُک تعبیر چُھ یہِ زِ تۅہیہِ منٛزٕ چاوِ اکھ پننِس رب  ﴿شاہ مصر س﴾ شراب، ﴿آیت نمبر 33 ہس سٍتۍ اگر یہِ آیت پر نہٕ یِیہِ ، تیٚلہِ چُھ پے لگا ن زِ ییٚلہِ حضرت یو سف علیہ السلامن ووٚن  میو ن ربّ امہِ نِشہِ اوس مُراد اللہ تعالیٰ سٕنز ذات ،تہٕ ییٚلہِ مصرٕ سٕندِس غلا مَس ووٚنُکھ زِ ژٕ چاو ہن پنُن ربّ شرا ب، اَمہِ نِشہِ اوس مُراد شاہِ مصر ، تِکیازِ سُہ اوس مصر ٕکِس بادشاہ سٕے پنُن ربّ سمجھان۔﴾"
  12,41,"۔روٗد بیاکھ ، سُہ یِٰیہِ پھا نسہِ کھالنہٕ، تہٕ جاناوار کھیٚن تِکہِ تِکہِ تٔمۍ سُند کلہٕ ۔سپُد فٲصلہٕ تمہِ کتھہِ ہُند یۅ سہٕ توٚہۍ پٕرٛژھان ٲسِو"
  12,42,"۔پتہٕ یس متعلق خیال اوس زِ سُہ گژِھہ تِمو منٛز یلہٕ ، تس ووٚن یو سف ﴿علیہ السلامن ﴾ زِ  پننِس ربّ ﴿شاہِ مصرس ﴾ نِشہِ کٔرۍ زِ میٲنۍ ذِکر۔ مگر شیطا نن تر وٚو سُہ تِتھس غفلتس منٛز زِ تس گٔیہِ پننِس ربّ ﴿شاہِ مصر س ﴾ نِشہِ تٔمۍ سٕنز ذِکر کرٕ نۍ مٔشِتھ، تہٕ یو سف علیہ السلام  روٗد کینٛژھن ؤرِ ین جیل سٕے منٛز۔ع"
  12,43,"۔اکہِ دۅہ چُھ بادشاہ ونان ﴿منٛز باگ چُھ کینٛژھن ؤرِین ہٕندِ قٲد کہِ وقتُک حال أتی ترٲوِتھ وۅ نۍ بیان تتھ  مقا مس سٍتۍ جور نہٕ یِوان ، ییٚتہِ پٮ۪ٹھہٕ حضرت یو سف علیہ السلامن ہُند دُنیٲوی عر وج شروع سپُد﴾  مےٚ چُھ خوا بس منٛز وُچھمُت زِ ستھ مۅ چہِ گٲو چھےٚ، یِمن چھےٚ ستھ لا غر گٲو کھیٚوان، تہٕ انا جِکۍ ستھ ہیٚلۍ چِھ سبز تہٕ با قی ستھ چِھ ہوٚ کِھمٕتۍ، اے اہلِ در بار، مےٚ ؤنَو اَمہِ خوا بک تعبیر، اگر توٚہۍ خو ابن ہُند مطلب چِھو سمجھان۔"
  12,44,"۔ لُکو ووٚن  یِمہٕ چھےٚ پر یشا ن خوا بن ہٕنزٕکتھہٕ، تہٕ أسۍ چِھنہٕ امہِ قسمہٕ کیٚن خوا بن ہُند تعبیر زانان۔"
  12,45,"۔یِمو دۅ یو قٍدیو منٛزٕ یُس شخص بچو مُت اوس، تہٕ تس پیٚیہِ وۅ نۍ واریاہہِ کٲلۍ کتھ یاد، تہٕ تٔمۍ ووٚن،بہٕ وَنو تۅہیہِ حضراتن اَمِچ تٲویل، مےٚ سوٗزِ و ﴿قٲد خا نس منٛز یو سف علیہ السلا مس نِشہِ ﴾۔"
  12,46,"۔سُہ گوٚو تہٕ ووٚ نُن  یو سف  ، اے پٔزیارِ ﴿ دراصل چُھ لفظ صد یق ورتاو نہٕ آمُت، یُس عر بی زبٲنۍ منٛز پزر س تہٕ راست بٲزی ہٕندِ س تھدِ پایہِ کِس مر تبس خٲطرٕ ورتا و نہٕ چُھ یِوان۔امہِ سٍتۍ ہیکو یہِ اندازہ کٔرِ تھ زِ قٲدٕ خا نہٕ کِس وقتس منٛز کِیُتھ سوٚ ن اثر اوس أمۍ شخصن حضرت یو سف علیہ السلامن ہٕندِ سیر ت نِشہِ روٚٹمُت،تہٕ یہِ اثر کوٗتاہ را سخ اوس واریاہ وقت گز ر نہٕ پتہٕ تہِ ﴾ مےٚ وَن اَمہِ خوا بُک مطلب زِ ستھ مۅ چہِ گٲو چھےٚ،یِمن ستھ لا غر گٲو چھےٚ کھیوان، تہٕ ستھ ہیٚلۍ چِھ سبز تہٕ ستھ چِھ ہوٚکِھمٕتۍ، تاکہ بہٕ گژٕھہ تِمن لُکن نِشہِ واپس، تہٕ شاید زِ تِمن لگہِ پَے۔ ﴿یعنی چٲنۍ قدٕر تہٕ رۅتبہٕ زانن ، تہٕ تِمن سپدِ احسا س زِ کمہِ پا یُک اِنسا ن کتہِ چُھ تِمو بند تھو ومُت، تہٕ یِتھہٕ پٲٹھۍ میلہِ مےٚ پنُن وعدہ پوٗرٕ کر نُک مو قع، یُس مےٚ ژےٚ سٍتۍ قٲد کہ وقتہٕ کوٚر مُت اوس﴾"
  12,47,"۔یو سف علیہ السلام چِھ ونان  ستن ؤرِ ین روٗزِ و لگا تار توٚہۍ زمیندٲر ی کران، اتھ دورا ن یِم فصل توٚہۍ لوٗنِو، تمہِ منٛزٕ کٔڑِو بس کمٕے حصہ، یُس تۅہیہِ خۅ را ک رٔنگۍ بکار لگہِ ، تہٕ با قی تھٲوِو ہیٚلیو سان ﴿ ہیٚلہِ نٕے منٛز﴾۔"
  12,48,"۔ پتہٕ یِن ستھ ؤرۍ بڈٕ سخت۔ تمہِ وقتہٕ یِیہِ سُہ سورُے اناج کھیٚنہٕ ،یُس توٚہۍ تمہِ وقتہٕ خٲطرٕ جمع کٔرِ و۔ اگر کینٛہہ بچہِ ، سُہ بچہ تی یُس تۅہیہِ رٔژھرٲوِتھ آسیو تھو و مُت۔"
  12,49,"۔اَمہِ پتہٕ واتہِ بیٚیہِ اکھ ؤر ی تِیُتھ، یتھ منٛز بارانِ رحمت سٍتۍ لُکن ہُند فر یاد یِیہِ بوزنہٕ، تہٕ تِم چیٖر ن رس۔ ع"
  12,50,"۔باد شاہن ووٚ ن سُہ أنیوٗن مےٚ نِش ، مگر ییٚلہِ شٲہی قٲصد یو سف ﴿علیہ السلامس ﴾ نِشہِ ووت ، تٔمۍ ووٚ ن  پننِس ربّس نِشہِ گژھ واپس ،تہٕ تس پٕرژھ زِ تِمن مستوٗراتن ہُند معا ملہ کیا چُھ، یِمو پنٕنۍ اتھہٕ ژٔٹِمٕتۍ ٲسۍ؟ میو ن ربّ چُھ تِہنزِ مکٲر ی نِشہِ با خبر۔"
  12,51,"۔ اتھ پٮ۪ٹھ کوٚر با د شا ہن تِمن مستوراتن نِشہِ در یا فت ،  تُہُند کیا تجر بہٕ چُھ تمہِ وقتُک، ییٚلہِ تۅہیہِ یو سف علیہ السلام پھسا ونٕچ کو شش ٲسٕو کٔر مٕژ؟ سارِ وٕے ووٚ ن یک زبان حا شا اللہ ﴿ پنا ہ خدا ے سُند ﴾، اَسہِ وُچھ نہٕ تس منٛز بد ی ہٕنٛز اَکھ رَژھ تہِ ۔ عز یز سٕنزِ خاندارِ نہِ ووٚ ن  وو نۍ چُھ حق درٛ امُت نوٚن، سۅ ٲسٕس بےٕ ، ییٚمۍ سُہ پھِسلاو نٕچ کوٗشش ٲس کٔر مٕژ، بے شک چُھ سُہ با لکل پٔزِ یو ر ۔"
  12,52,"۔﴿یو سف علیہ السلام﴾ چِھ ونان  امہِ نِشہِ اوس میو ن غر ض یہِ زِ ﴿عز یز ﴾ زانہِ زِ مےٚ ٲس نہٕ در پردٕ ہ تٔمۍ سٕنز خیا نت کٔر مٕژ، تہٕ یہِ زِ یِم خیا نت چِھ کران ، تِہنز ن چا لن چُھنہٕ اللہ تعالیٰ کا میٲبی ہٕنزِ وتہِ لاگان ۔"
  12,53,"۔ بہٕ چُھسَن نہٕ پَنُن نفس بر ی کران ﴿ یعنی پنُن نفس چُھس نہٕ بے قصور قرار دِوان ﴾ نفس چُھ بَد ی کُنُے ہٕس دِوان،اِلاّ یہِ زِ کٲنٛسہِ پٮ۪ٹھ آسہِ میٲنِس ربّ سٕنز رحمت،بے شک چُھ میو ن ربّ سٮ۪ٹھاہ مغفر ت کر ن وول تہٕ رحم کر ن وول ۔"
  12,54,"۔ باد شاہن ووٚن  تِم أنیوٗکھ مےٚ نِش، تا کہ بہٕ کر کھ تِم پننہِ خٲطرٕ مخصو ص۔ ییٚلہِ حضرت یو سف ﴿علیہ السلامن ﴾ تس سٍتۍ کتھ با تھ کٔر،تٔمۍ ووٚن  وۅ نۍ چَھو تۅہیہِ اسہِ نِش قدٕر تہٕ رۅ تبہٕ ، تہٕ تُہندِس اما نتس پٮ۪ٹھ چُھ پوٗرٕ بھر وسہٕ۔"
  12,55,"۔ یو سف علیہ السلام چِھ ونان  مٕلکٕکۍ خزا نہٕ کٔرِ و مےٚ حوا لہٕ، بہٕ چُھس حفا ظت کر ن وول تہِ ، تہٕ مےٚ چُھ علم تہِ ۔"
  12,56,"۔یِتھہٕ پٲٹھۍ کٔراسہِ تتھ سر زمینس  منٛز یو سف ﴿علیہ السلامس ﴾ خٲطرٕ اقتدارٕ چ وَتھ ہموار،تَس اوس اختیار زِ اَتھ منٛز یتھ جایہِ ییٚژِھہ ہے پنٕنۍ جا ے ہیٚکہِ ہے بنٲوِتھ۔﴿ یعنی وۅ نۍ ٲس سٲرٕ ے مصرٕ چ سر زمین تٔمۍ سٕنز، تمہِ چہِ پرٛتھ جا یہِ ہیٚکہِ ہے سُہ پنٕنۍ جا ے ؤنِتھ ۔تتہِ اوس نہٕ کانٛہہ گو شہِ تہِ تِیُتھ روٗد مُت، یُس تس رُکاو نہٕ ہیٚکہِ ہے یِتھ۔ یہِ چُھ گویا تمہِ کٲمِل تسلُّطُک تہٕ ہمہ گیر اقتدارُک بیان۔ یُس حضرت یو سف علیہ السلامس تتھ مٕلکس پٮ۪ٹھ حٲصل اوس۔ پرٲنۍ مُفسر ین تہِ چِھ اتھ آیتس یۅ ہے تفسیر کران، چنا نچہِ ابن زید چِھ اَمِکۍ معنے بیان کران زِ  اسہِ بنو و یو سُف علیہ السلام تِمن سارِنٕے چیز ن ہُند مٲلِک یِم مصرس منٛز ٲسۍ ، دُنیا کِس اَتھ حصس منٛز یتھ جایہِ یِکینژھاہ سُہ کرُن ییٚژھہ ہے ، تہِ ہیٚکہِ ہے کٔرِ تھ ۔سۅ سر زمین ٲس تس حوا لہٕ کر نہٕ آمٕژ۔ حتیٰ کہ اگر سُہ ییٚژِھہ ہے فر عو نس پَنُن زیردست بناوُن تہٕ پانہٕ تس بالا تر گژُھن ،تیٚلہِ ہیکہِ ہے یِتہِ کٔرِتھ۔ مجا ھد سُند خیال چُھ زِ مِصرٕ کۍ با دشاہن اوس حضر ت یو سف علیہ السلامن ہٕندِ دست اسلام قبول کوٚر مُت﴾ پننہِ رحمت سٍتۍ یُس أسۍ یژھان چِھن سُہ چِھن نوازان، نیک لُکن ہُند اجر چُھنہٕ اسہِ نِشہِ ضا یع گژھان،"
  12,57,"۔تہٕ ٲخر تُک اجر چُھ تِمن لُکن خٲطرٕ  زیادٕہ بہتر ،یِمو ایمان اوٚ ن ،تہٕ پر ہیز گٲر ی سان روٗدۍ کٲم کران۔ع"
  12,58,"۔ یو سف علیہ السلام سٕندۍ بٲے آے مصر تہٕ تٔمۍ سٕندِس خد متس منٛز سپٕدۍ حٲضر ﴿یتھ جایہِ چھِ بیٚیہِ ستن ٲٹھن ؤرِ ین ہٕندۍ وا قعات منٛز باگ ترٲوِتھ بیا نُک سلسلہٕ تتھ جایہِ سٍتۍ واٹنہٕ آمُت، ییٚتہِ پٮ۪ٹھہٕ بنی اسرا یلن ہُند مِصر مُنتقل سپدنُک ابتدا سپُد﴾ تٔمۍ پرٛزٕ نٲوۍ، تِمو  پرزٕ نو و نہٕ سُہ۔"
  12,59,"۔پتہٕ ییٚلہِ تٔمۍ تِہُند سامان تیار کر نوو،تہٕ نیر نہٕ وقتہٕ ووٚ نُن تِمن  پنُن وۅ رٕ بو ے أنۍ زِ یو ن مےٚ نِش ، وُچھان چھِو نا بہٕ کِتھہٕ پٲٹھۍ چُھس بٔرِتھ پیمانہٕ دِوان، تہٕ بہٕ کِیُتھ مہمان نواز چُھس ۔"
  12,60,"۔اگر نہٕ سُہ توٚہۍ مےٚ نِش أنیوٗن، تیٚلہِ چُھنہٕ مےٚ نِشہِ تُہندِ خٲطرٕ کانٛہہ اناج،بلکہ پٔکۍ زیو نہٕ مےٚ بروٗنٹھۍ کِنۍ تہِ ۔ ﴿یہِ کتھ آسِہے حضر ت یوسف علیہ السلامن اتھ بُنیا دس پٮ۪ٹھ فر ماو مٕژ زِ قحط کہ وجہ کِنۍ اوس مِصر س منٛز اناجس پٮ۪ٹھ کنٹر و ل۔ اناج نِنہٕ خٲطرٕ ٲسۍ یِم داہ بٲے آمٕتۍ مگر تِم آسٕہن پننِس مٲلۍ سُند تہٕ پننِس کٕہِمِس بٲے سُند حصہٕ منگان۔اتھ  پٮ۪ٹھ  آسہِ حضر ت یوسف علیہ السلامن ووٚ نمُت زِ یہِ عذ ر چُھ معقو ل زِ تُہُند مو ل چُھ بُڈٕ تہٕ بیٚیہِ چُھ نا بینا ،تو ے ہیٚکہِ نہٕ سُہ پانہٕ یِتھ، مگر بٲے سٕندِ نَہ یِنُک  معقو ل سبب کیا ہیٚکہِ ٲسِتھ؟ خیر وُنۍ کیٚنَس چِھ أسۍ تُہنزِ زبٲنۍ پٮ۪ٹھ اعتبارٕ کٔرِ تھ تۅہیہِ پوٗرٕ اناج دِوان،مگر اگر آیندہ تۅہیہِ سُہ پا نس سٍتۍ اوٚ نوٗن نہٕ، تیٚلہِ مۅکلہِ تُہُند اعتبار تہٕ تۅ ہیہِ میلیو نہٕ ییٚتہِ کانٛہہ اناج﴾"
  12,61,"۔تِمو ووٚ ن  أسۍ کر و کوٗشش زِ والد صٲب گژھن تس سوز نہٕ خٲطرٕ رٲضۍ سپٕدنۍ،تہٕ أسۍ کر و ضروٗر یہِ ﴿کٲم ﴾۔"
  12,62,"۔ یوسف علیہ السلام چِھ پننیٚن غلا من اِشارہ کران زِ  تِمو لُکو یُس مال ﴿قٍمت﴾ اناج بد لہٕ دِیُتمُت چُھ، سُہ تھٲوِ و ژوٗرِ پٲٹھۍ تِہندِس سا ما نسٕے منٛز۔ یہِ کوٚر یو سف ﴿ علیہ السلامن﴾ اَتھ اُمید پٮ۪ٹھ زِ گھرٕ وٲتِتھ پرزٕ ناو ن تِم پنُن وا پس لوٚ بمُت مال ﴿ یا اتھ فیٲضی پٮ۪ٹھ سپد ن احسا ن مند﴾ تہٕ بنان چُھ بیٚیہِ یِن یو ر ۔"
  12,63,"۔ ییٚلہِ تِم پننِس مٲلِس نِشہِ وٲتۍ تہٕ ووٚنُکھ،اے ابّاجان ، اَسہِ آو آیند ہ اناج دِنہٕ نِشہِ انکار کر نہٕ،لہٰذا سوٗزِ یوٗن توٚہۍ سو ن بو ے اَسہِ سٍتۍ،تا کہ أسۍ یِمو اناج ہیٚتھ ، تہٕ تٔمۍ سٕندِ حفا ظتٕکۍ ذمہ دار چِھ أسۍ ۔"
  12,64,"۔مٲلۍ دِیُت جواب  کیا أمۍ سٕندِس معا ملس منٛز کرا بہٕ تۅہیہِ پٮ۪ٹھ تِیُتھُے بھر وسہٕ،یُتھ امہِ برونٛہہ تٔمۍ سٕندِس بٲے سٕندِس معا ملس منٛز کوٚر مُت چُھم؟بس چُھ اللہ تعالیٰ بہتر محٲفظ، تہٕ سُہ چُھ سارِوٕے کھۅتہٕ کھٔسِتھ رحم کر ن وول۔"
  12,65,"۔پتہٕ ییٚلہِ تِمو پنُن سامان مٕژ روو، تِمو وُچھ تِہُند مال تہِ چُھ تِمن آمُت وا پس کر نہٕ،یہِ وُچِھتھ لٲے تِمو کرٛیکھ ابا جان ، اَسہِ کیا گژِھہ بیٚیہِ آسُن، وُچِھو یہِ سو ن مال ﴿ قٍمت﴾ تہِ چُھ اسہِ وا پس دِنہٕ آمُت،بس وۅ نۍ گژھو أسۍ تہٕ پننِس اہلِ و عیا لس خٲطرٕ اَنو رَسد ،پننِس بٲے سٕنز حفا ظت تہِ کرو ،تہٕ بیٚیہِ اَنو أکِس اونٹ سُند یو ت ہُر یمانہٕ وز ن ،ییٖتہِ اَنا جُک اِضا فہٕ ہیٚکہِ آسٲنی سان سپٕدِ تھ۔"
  12,66,"۔ تِہندۍ مٲلۍ ووٚ ن بہٕ سوزن نہٕ ہر گز سُہ تۅہیہِ سٍتۍ، یوٚت تام نہٕ توٚہۍ اللہ تعالیٰ سٕندِ ناوٕ مےٚ پۅ ختہٕ وعدٕہ دِیِو زِ سُہ أنِیوٗن ضرور مےٚ نِشہِ وا پس، اِلاّیہِ زِ تۅہیہِ یِیِو گھیر نہٕ، ییٚلہِ تِمو تس پنٕنۍ پنٕنۍ وعدٕہ دِ تۍ،پتہٕ ووٚ ن تٔمۍ  وُچِھو ، سٲنِس اتھ قَو لس پٮ۪ٹھ چُھ اللہ تعالیٰ نگہبان ﴿ضٲمِن﴾"
  12,67,"۔پتہٕ ووٚ ن تٔمۍ  میا نیو گو بر و ، مِصر کِس دارُ السلطنتس منٛز أژۍ زیو نہٕ اکہِ دروازٕہ کِنۍ ﴿غا لباً آسِہے حضرت یعقو ب علیہ السلامس اند یشہ زِ اَتھ قحط کِس زمانس اگر یِم چھۅ کھ بٔنِتھ مِصر س منٛز دٲخل سپد ن ، بنان چُھ یِمن پٮ۪ٹھ ما سپدِ شک، تہٕ گُمان مایِیہِ کر نہٕ زِ یِم چِھ لو ٹ مار کر نہِ یور آمٕتۍ﴾بلکہ گٔژھۍ زیو مختلف دروازَو کِنۍ دٲخل،مگر بہٕ ہیکو نہٕ توٚہۍ اللہ تعالیٰ سٕندِ مشیت نِشہِ بچٲوِتھ،حکم چُھنہٕ تس ورٲے کٲنٛسہِ ہُند تہِ چلا ن ، تٔسۍ پٮ۪ٹھ کوٚر مےٚ بھر وسہٕ،تہٕ یس کٲنٛسہِ أکِس تہِ بھر وسہٕ آسہِ کرُن تٔسۍ پٮ۪ٹھ کٔرِن ۔"
  12,68,"۔تہٕ وا قعہ تہِ سپُد یی زِ ییٚلہِ تِم پننِس مٲلۍ سٕندِ ہدا یت مطٲ بق شہر س اندر ﴿مختلف دروازہ کِنۍ ﴾ دٲخل سپٕدۍ،تہٕ تٔمۍ سٕنزیہِ احتیا طی تدبیر آیہِ نہٕ اللہ تعالیٰ سٕندِس مشیت کِس مقا بلس منٛز رژھ تہِ بکار۔ آ، وۅ نۍ گوٚو یُس اند یشہ یعقو ب علیہ السلام سٕندِس دِلس منٛز اوس ،سُہ دوٗر کر نہٕ خٲطرٕ کٔر تٔمۍ پنٕنۍ کِنۍ کوٗشش ۔بے شک اوس سُہ سانہِ دِنہٕ آمژِ تعلیم کِنۍ صا حب علم، مگر اکثر لُکھ چِھنہٕ معا ملٕچ حقیقت زانان۔ع"
  12,69,"۔یم لُکھ وٲتۍ یو سف علیہ السلام سٕندِس  خدمتس منٛز،تٔمۍ نیوٗ پنُن بوے ناد دِتھ پانس نِش الگ ،تہٕ ووٚنُن تس  زِ ، بہٕ چُھس چو ن سُے بو ے ﴿ یُس روومُت اوس﴾ وۅ نۍ مہ کر ژٕ تِمن کتھن ہُنٛد غم، یِمہٕ کتھہٕ یِم لُکھ چِھ روٗدِمٕتۍ کران۔ ﴿غا لباً آسہِ ملا قا تس منٛز بن یمینن ووٚ نمُت زِ یو سف علیہ السلام سٕندِ پتہٕ کمہٕ کمہٕ زِ یا دتِیہِ کرِ وۅ رٕ با یو ،تہٕ حضرت یو سف علیہ السلامن آسہِ بٲیِس دِلا سہٕ دِیُتمُت زِ وۅ نۍ روزکھ ژٕ میے نِشہِ ، یِمن ظٲلِمن ہٕندِس پنجس منٛز دِمَتھ نہٕ بہٕ دُبارٕہ، بنان چُھ أتھۍ مو قعس پٮ۪ٹھ آسہِ دۅ یو با یو یِتہِ مشو رہ کوٚرمُت زِ بِن یمینس مصرس منٛز رُکاو نہٕ خٲطرٕ کیا تد بیر یِیہِ کر نہٕ ،ییٚمہِ سٍتۍ سُہ پردٕہ تہِ روٗزِ بر قرار یُس حضرت یو سف علیہ السلام مصلحتاً وُنہِ بر قرار ٲسۍ یژھان تھاوُن۔﴾"
  12,70,"۔ییٚلہِ یو سف علیہ السلام یِمن با ین ہُند سامانہٕ لوٚ گ برناو نہِ ، تٔمۍ تھوو پنِنس بٲے سٕندِس سا ما نس  منٛز پنُن پیا لہٕ، پتہٕ لو ے أکۍ ناد لاین وٲلۍ ناد، اے قا فلہٕ والیو ، توٚہۍ چِھو ژوٗر۔"
  12,71,"تمو پُرٛوژھ پوٚت پھیرِ تھ  ژےٚ کُس چیز روُے؟"
  12,72,"سر کٲرۍ مُلٲزِ مَو ووٚن  بادشاہ سُند پیمانہٕ چُھنہٕ اسہِ میلان۔ ﴿تہٕ تِہندۍ جمعدارن ووٚن﴾  یُس شخص أنِتھ دِیہِ ،تس خٲطرٕ چُھ بارِ شُتر انعا م﴿یعنی أکِس اونٹ سُنٛد وزن﴾، اَمِیُک ذِمہٕ چُھس بہٕ نِوان"
  12,73,"۔یِمو با یَو ووٚ ن  اللہ تعالیٰ سُند قسم ، توٚہۍ چِھو ٹھیک پٲٹھۍ زانان زِ أسۍ چِھنہٕ یتھ مٕلکس منٛز فساد کر نہِ آمٕتۍ، تہٕ أسۍ چِھنہٕ ژوٗرکر ن وٲلۍ لُکھ۔"
  12,74,"۔تِمو ووٚ ن  اچھا ، اگر تُہٕنز کتھ اَپزٕ درٛا یہِ ، تیٚلہِ کیا چُھ ژوٗرٕ سُند سزا؟"
  12,75,"۔تِمو ووٚن  تٔمۍ سُند سزا؟ییٚمۍ سٕندِ سامانہٕ منٛزٕ چیز نیرِ ، سُہ گژھ پانے پننِس سزا ہس منٛز تھا و نہٕ یُن، اَسہِ نِشہِ چُھ ظٲلِمن سزا دِنُک یۅ ہے طر یقہٕ۔"
  12,76,"۔تمہِ پتہٕ کٔر یو سف ﴿علیہ السلامن﴾ پننِس  بٲیس برونٛہہ تِہٕنز ن گُنَن تلٲشی شروع،پتہٕ کوٚرُن پننِس بٲے سٕنزِ گُنہِ منٛزٕ رودومُت چیز برآمد، یِتھہٕ پٲٹھۍ کوٚر اَسہِ یو سف علیہ السلام سُند تٲیید پننہِ تد بیر سٍتۍ، تٔمۍ سٕنز کٲم ٲس نہٕ یہِ زِ با دشاہ سٕندِ دِینہٕ ﴿ یعنی مصر کہِ شٲہی قا نو نہٕ ﴾ منٛزٕ رٹہِ ہے پننِس بٲیس، اِلاّ یہِ زِ اللہ تعالیٰ ہٕے ییٚژِھہ ﴿عام پٲٹھۍ چُھ اَمہِ آیتُک یہِ تر جمہٕ کر نہٕ یِوان زِ  یو سف علیہ السلام ہیکہَن نہٕ بادشاہ سٕندِ قا نو ن مُطا بق پننِس بٲیِس رٔٹِتھ۔ البتہ اگر اَتھ یہِ معنی یِیہِ کڑ نہٕ ، تیٚلہِ چھےٚ کتھ با لکل بے معنی سپدان۔ژوٗرنَہ رٹنُک کیا و جہ ہیکہِ ٲخر با دشاہ سٕندِس قا نو س منٛز ٲسِتھ؟ کیا دُنیا ہس منٛز چھا کانٛہہ سلطنت تِژھ تہِ ٲسمٕژ ییٚمیُک قا نو ن ژوٗرس آسہِ نہٕ گرفتار کر نُک اجا زت دِوان ؟ لہٰذا چھےٚ صحیح کتھ یہِ زِ اللہ تعالیٰ سٕندِس نبی حضر ت یو سف علیہ السلامن ہٕنز ٲس نہٕ یہِ کٲم زِ بادشاہ سٕندِ قا نو ن مطٲبق کر ہن عمل ،تو ے چِھ حضر ت یو سف علیہ السلام پننیٚن با ین تِہندِ ﴿علا قُک ﴾ قانو ن پٕرٛژھان تہٕ شر یعت ابرا ہیمی مطٲبق چِھ بٲیِس رٹا ن ﴾ أسۍ ییٚمۍ سٕندۍ در جہِ یژھان چِھ ، بلند چِھ کران،تہٕ اکھ علم تھاو ن وول چُھ تِیُتھ ، یُس پرٛتھ صا حب علم سٕندِ کھۅتہٕ بالا تر چُھ۔"
  12,77,"۔ یِمو با یَو ووٚن  اگر یہِ ژوٗر کرِ ، تعجب کتھ تہِ چَھنہٕ کینٛہہ، أمِس برونٛہہ چھےٚ أمۍ سٕندۍ بٲے ﴿یو سف علیہ السلامن ﴾ تہِ ژوٗر کٔرمٕژ۔ یو سف ﴿علیہ السلامن﴾ بوٗز یِہٕنز یہِ کتھ تہٕ کٔرٕ ن ژیٚڈ، حقیقت کٔڑٕ ن نہٕ یِمن برونٛہہ کنہِ نٔنۍ، بس ﴿وُٹھو تٔلۍ﴾ ووٚ نُن یُتے زِ سٮ۪ٹھاہ خرا ب چِھو توٚہۍ لُکھ، ﴿مےٚ برونٛہہ کنہِ ﴾ یُس الزا م توٚہۍ لگا وان چِھو ،تمِچ حقیقت چُھ اللہ تعالیٰ وارٕہ پٲٹھۍ زانان۔"
  12,78,"۔تِمو ووٚن  اے سردار،ذی اقتدار﴿عز یز﴾ ، ﴿یتھ جایہِ یُس لفظ   عزیز حضر ت یو سف علیہ السلامن ہٕندِ خٲطرٕ ورتاو نہٕ چُھ آمُت۔ صرف چُھ اتھ بنیادس پٮ۪ٹھ مُفسر و قیا س کوٚر مُت زِ حضر ت یو سف علیہ السلام ٲسۍ تٔتھۍ منصبس پٮ۪ٹھ ما موٗر سپد ۍ مٕتۍ، یتھ  پٮ۪ٹھ امہِ برونٛہہ زلیخا ہُند خاندار ماموٗر اوس، مگر اَسہِ چھےٚ آیت نمبر 30 کِس حٲشیس منٛز وضا حت کٔر مٕژ زِ یہِ اوس نہٕ مصر س منٛز کُنہِ خا ص منصبُک ناو ۔ بلکہ اوس محض صا حب اقتدار کِس معنیس منٛز ورتاو نہٕ یِوان ۔﴾ أمۍ سُند مو ل چُھ واریاہ بُڈٕ انسان ،أمۍ سٕنزِ جایہِ رٔٹیوٗن توٚہۍ اَسہِ منٛز کانٛہہ، اَسہِ چِھو توٚہۍ سٮ۪ٹھاہ نیک نفس انسان با سا ن۔"
  12,79,"۔ یو سف ﴿علیہ السلامن﴾ ووٚن  اللہ تعالیٰ سُند پناہ ، بیاکھ کانٛہہ شخص کِتھہٕ پٲٹھۍ ہیکو ن أسۍ رٔٹِتھ، یَس نِشہِ اَسہِ پنُن مال لوٚ ب ، سُہ ترٲوِتھ اگر أسۍ بیا کھ رٹو ن ، تیٚلہِ آسو أسۍ ظٲلِم ۔ ع ﴿احتیا ط وُچِھو زِ  ژوٗر چِھنہٕ ونان ، بلکہ چِھ ونان یہِ زِ یس نِشہِ اسہِ پنُن مال لوٚ ب۔أتھۍ چِھ شر ع کِس اصطلا حس منٛز  تَو رِیہ  ونان ، یعنی  حقیقتس پٮ۪ٹھ پردہ تراوُن  یا  امرِ وا قعہ چُھپاوُن ۔ ییٚلہِ کٲنٛسہِ مظلو مس ظٲلِمس نِشہِ بچا و نہٕ خٲطرٕ یا کانٛہہ بوٚڈ سِتم دور کر نٕچ کانٛہہ صوٗرت اَمہِ ورٲے آسہِ نہٕ زِ کانٛہہ خلا فِ وا قعہ کتھ یِیہِ وننہٕ ،یا یِیہِ خلا فِ حقیقت کانٛہہ حیلہٕ کر نہٕ ، تیٚلہِ کرِ اتھ صوٗرتس منٛز اکھ پر ہیز گار انسان ٹا کارٕ ہ اَپُز وننہٕ نِشہِ اجتنا ب کران کران تِژھہ کتھ ونٕنچ یا تژِھ تد بیر کر نٕچ کو شش ،ییٚمہِ سٍتۍ حقیقت چُھپٲوِتھ بد ی یِیہِ دور کر نہٕ ۔ وۅ نۍ وُچِھتو اَتھ سٲرِ سٕے معا ملس منٛز کِتھہٕ پٲٹھۍ چِھ حضرت یو سف علیہ السلام جٲیز تَو رِ یہ ہٕکۍ شرا یط پوٗرٕ کران۔ بٲے سٕنزِ رضا مند ی سان چِھ تٔمۍ سٕندِس سا ما نس منٛز پیا لہٕ تھاوان، مگر ملٲزِمن ووٚ نُکھ نہٕ زِ أمِس پٮ۪ٹھ لگٲوِ و ژوٗرِ ہُند الزام۔ییٚلہِ سر کٲر ۍ مُلٲز مَو ژوٗرِ ہٕندِس الزامس منٛز یِم لُکھ رٔٹِتھ أنۍ ، تہٕ خا مو شی سان ؤتھۍ تہٕ کٔرٕ کھ تلٲشی۔وۅ نۍ ییٚلہِ تِمو با یَو ووٚن زِ بن یمین سٕنز جایہِ رٔٹِیوٗن اسہِ منٛزٕ کانٛہہ ، تہٕ امہِ کِس جوا بس منٛز تہِ کٔرٕ کھ تِہٕنز ے کتھ تِمن اُلٹہٕ زِ تُہُند پنُن فتویٰ اوس یہِ زِ ییٚمہِ سٕندِ سامانہٕ منٛزٕ مال چُھ درٛا مُت سُے رٔٹیوٗن ،لہٰذا چُھ وۅ نۍ تۅہیہِ برونٛہہ کنہِ بن یمین سٕندِ سامانہٕ منٛزٕ سو ن مال درٛا مُت ، تہٕ یۅ ہے رٹو ن أسۍ پا نس نِشہِ ، بیاکھ کِتھہٕ پٲٹھۍ ہیکو ن أمۍ سٕنزِ جایہِ رٔٹِتھ﴾"
  12,80,"۔ییٚلہِ تِم یو سف ﴿علیہ السلامس ﴾ نِشہِ ما یوٗس سپٕدۍ، تِم درٛا ے پتہٕ أکِس کوٗنس کُن تہٕ لو گُکھ مشو ر کرُن، یِمو منٛز یُس سارِنٕے زِ یُٹھ اوس تٔمۍ ووٚن،  تۅہیہِ چَھو نا پے زِ تُہندۍ مٲلۍ چُھو تۅہیہِ اللہ تعالیٰ سٕندِس ناوس پٮ۪ٹھ عہد و پیمان ہیوٚتمُت؟ تہٕ امہِ برونٛہہ یِکینژھاہ تۅہیہِ یو سف علیہ السلام سٕندِس معا ملس منٛز کوٚر مُت چُھو، سُتہِ چُھو  تۅ ہیہِ پے،وۅ نۍ نیر نہٕ بہٕ ہر گز ییٚتہِ یوٚت تام نہٕ مےٚ وٲلد صٲب اجا زت دِیہِ،نَتہٕ یوٚت تام نہٕ صرف اللہ تعالیٰ میٲنِس حقس منٛز کانٛہہ فٲصلہٕ فر ماوِ،تِکیازِ سُہ چُھ سارِوٕے کھۅتہٕ بہتر فٲصلہٕ کر ن وول ۔"
  12,81,"۔توٚہۍ گٔژِھو تہٕ ؤنِو پننِس والد صٲبس زِ ،ابّا جان ، چٲنۍ صا بزادن چھےٚ ژوٗر کٔرمٕژ،اسہِ وُچھنہٕ سُہ ژوٗر کران، یِکینٛژھاہ اسہِ پے لوٚگ،بس سُے چِھ أسۍ بیان کران،تہٕ غیبٕچ نگہبٲنی ہیکو نہٕ أسۍ کٔرِ تھ ﴿یعنی اَسہِ چُھنہٕ علمِ غیب﴾"
  12,82,"۔توٚہۍ پٕرٛژِھۅ تمہِ بستی ہٕندٮ۪ن لُکن ییٚتہِ أسۍ ٲسۍ، قا فلس پٕرٛژھو ،یس سٍتۍ أسۍ آمٕتۍ چِھ ، أسۍ چِھ پننِس بیانس منٛز بالکل پٔزیٲرۍ۔"
  12,83,"۔ یہِ داستان بوٗزِ تھ ووٚن مٲلۍ  دراصل بنٲو تُہٕندۍ نفسن تُہندِ خٲطرٕ بیٚیہِ اکھ کتھ سہل ﴿یعنی تۅہیہِ نزدیک چُھ یہِ باور کرُن واریاہ سہل زِ میو ن فر زند ییٚمۍ سٕندِ نیک کردارٕ نِشہِ  بہٕ ٹھیک پٲٹھۍ وٲقف چُھس ، ہیکہِ اکہِ پیا لہ چہِ ژوٗرِ ہُند مر تکب سپدِ تھ۔تُہٕندِ خٲطرٕ ٲس گۅڈٕ پنُن بو ے راوراو نٕچ ،تہٕ تٔمۍ سٕنز قمیضہِ پٮ۪ٹھ اَپُز خو ن مٔتھِتھ اَنٕنۍ واریاہ سہل کٲم بنیمٕژ۔وۅ نۍ سپُد تِیُتُھے سہل تُہٕندِ خٲطرٕ ،دوٚ یِمِس بٲیس پٔزۍ پٲٹھۍ ژوٗر مانُن تہٕ مےٚ نِش وٲتِتھ اَمِچ خبر دِنۍ تہِ ﴾ اچھا بہٕ کرٕ اَتھ پٮ۪ٹھ تہِ صبر تہٕ وارٕپٲٹھۍ کرٕ۔دوٗر چُھنہٕ زِ اللہ تعالیٰ رَلاوِ تِمن سارِنٕے مےٚ سٍتۍ،سُہ چُھ سورُے کینٛہہ زانان تہٕ تٔمۍ سٕنزٕ سار ے کامہِ چھےٚ حکمتس پٮ۪ٹھ بٔنِتھ۔"
  12,84,"۔پتہٕ پھیٚر تٔمۍ تِمن نِشہِ رۅ ے تہٕ لوٚ گ وَننہٕ زِ ہا ے یو سف ! سُہ اوس أند ری أندری غمہٕ سٍتۍ گلا ن ،تہٕ تٔمۍ سٕنز أچھ آسہٕ سفید گٔمژٕ۔"
  12,85,"۔فر زند و ،ووٚن  خدارا ! توٚہۍ چھوٗن بس یو سف علیہ السلام یاد کران روزان،نو بت چھےٚ یہِ وٲژمٕژ زِ تٔمۍ سٕندِس غمس منٛز کٔرِ و توٚہۍ  پا نس سوٗر یا کٔرِو پنُن پان ہلا ک۔"
  12,86,"۔تٔمۍ ووٚن  بہٕ چُھس نہٕ پننہِ پر یشٲنی تہِ پننہِ غمُک فر یاد خُدا یس ورٲے بیٚیہِ کٲنٛسہِ کران،تہٕ خُدا یس نِشہِ یِتھہٕ پٲٹھۍ بہٕ وٲقف چُھس توٚہۍ چِھو نہٕ۔"
  12,87,"۔میانیو گوٚبر و، گٔژِھو یو سف علیہ السلام تہٕ تٔمۍ سٕندِس بٲے سُند نیب کٔڑِو، اللہ تعالیٰ سٕندِ رحمت نِشہِ مَہ گٔژِھو نا امید، تٔمۍ سٕندِ رحمت نِشہِ چِھ صرف کٲفرٕ ے یٲتۍ نا امید سپدان۔"
  12,88,"۔ییٚلہِ تِم لُکھ مصر گٔژِھتھ یو سف علیہ السلام سٕنزِ پیشی منٛز دٲخل سپٕدۍ تہٕ تِمو کوٚر عر ض زِ اے سردارِ بااقتدار،أسۍ تہٕ سٲنۍ اہل و عیا ل چِھ سخت مصیبتس منٛز، تہٕ أسۍ چِھ کینٛہہ معمو لی رقم ہیٚتھ آمٕتۍ، توٚہۍ دِیِو اَسہِ بھر پوٗر اناج تہٕ بیٚیہِ دِیِو خیرا ت،اللہ تعالیٰ چُھ خیرات دِنہٕ والیٚن جز ا دِوان ۔"
  12,89,"۔﴿یہِ بوٗزِ تھ روٗد نہٕ یو سف علیہ السلامس پا نس تام ﴾ تٔمۍ ووٚن  تۅہیہِ چُھوٕ ہ یِکینژھاہ تہِ پے زِ تۅہیہِ کیا اوسُو یو سف علیہ السلامس تہٕ تٔمۍ سٕندِس بٲیِس سٍتۍ کوٚر مُت، ییٚلہِ زن توٚہۍ نادان ٲسِو؟"
  12,90,"۔وۅ ٹھ کھیٚتھ ووٚن تِمو ،ہا ے ! کیا ژٕ چُھکھہٕ یو سف علیہ السلام ؟ تٔمۍ ووٚن ، آ، بہٕ چُھس یو سف علیہ السلام تہٕ یہِ چُھ میو ن بوے۔ خُدا ین کوٚر اَسہِ پٮ۪ٹھ احسان۔حقیقت چھےٚ یہِ زِ اگر کانٛہہ تقویٰ ہَس تہٕ صبرس کٲم ہیٚیہِ ،تیٚلہِ چُھنہٕ خُدا یس نِشہِ تٔمۍ سُند اجر ضا یع گژھان۔"
  12,91,"۔تِمو ووٚن  بخدا ، ژےٚ کٔر نے خُدا ین اسہِ پٮ۪ٹھ فضیلت عطا، تہٕ پٔزۍ پٲٹھۍ ٲسۍ أسۍ خطا کار۔"
  12,92,"۔ تٔمۍ دِیُت جواب  اَز چَھنہٕ تۅہیہِ پٮ۪ٹھ کانٛہہ گرفت، اللہ تعالیٰ کٔرِ نو تۅہیہِ معاف،سُہ چُھ سارِوٕے کھۅتہٕ کھٔسِتھ معا ف کر ن وول۔"
  12,93,"۔گٔژِھو میٲنۍ یہِ قمیض نِیو، تہٕ میٲنِس مٲلِس ترٲوِو بتھِس پٮ۪ٹھ، تِمن یِیہِ گا ش واپس،تہٕ پنُن سورُے اہل و عیا ل أنیوٗن مےٚ نِشہِ ۔  ع"
  12,94,"۔ییٚلہِ یہِ قٲفلہٕ ﴿مِصر پٮ۪ٹھہٕ﴾ روانہٕ سپُد،تِہِندۍ بابہٕ صٲبن ووٚن ﴿ کنعا نس منٛز﴾بہٕ چُھس یو سف علیہ السلام سٕنز خۅ شبو ے محسو س کران، یِنہٕ توٚہۍ لُکھ ؤنِو زِ بہٕ چُھس بُجر س منٛز ڈوٚ لمُت۔"
  12,95,"۔گھرٕ کیو بٲژو ووٚن خدا ے سُند قسم ،توٚہۍ چِھو وُنہِ تہِ پرٲنِس وہمس منٛز۔"
  12,96,"۔پتہٕ ییٚلہِ خۅ ش خبر اَنن وول ووت، تہٕ تٔمۍ ترٲو یو سف علیہ السلام سٕنز قمیض یعقو ب علیہ السلام سٕندِ س رۅ یس پٮ۪ٹھ،تہٕ تَمی ساعتہٕ آو تس بیٚیہِ أچھ گا ش۔پتہٕ ووٚن تٔمۍ  بہٕ اوسَو نا تۅہیہِ ونان ؟ بہٕ چُھس اللہ تعالیٰ سٕندِ طر فہٕ تِکینژھاہ زانان یِنہٕ توٚہۍ زانان چِھو۔"
  12,97,"۔سارِوٕ یَو ووٚن  ابّا جان ،توٚہۍ کٔرِو سا نیٚن گنا ہن ہٕندِ مغفرت خٲطرٕ دُعا،پٔزِ پٲٹھۍ ٲسۍ أسۍ خطا کار۔"
  12,98,"۔ تٔمۍ ووٚن  بہٕ کرٕ پننِس ربّس تُہندِ خٲطرٕ معٲفی ہُند در خواست ، سُہ سٮ۪ٹھاہ معا ف کر ن وول تہٕ رحیم ۔"
  12,99,"۔پتہٕ ییٚلہِ یِم لُکھ یو سف ﴿علیہ السلامس﴾ نِشہِ وٲتۍ،تٔمۍ بیہنٲوۍ پنٕنۍ وا لد ین پا نس سٍتۍ، تہٕ پننیٚن سارِ نٕے خاندان والیٚن ووٚنُن پٔکِو ،وۅ نۍ پٔکِو شہر س منٛز، خُداین اگر یٚو ژھ، تیٚلہِ روٗزِ و امن و سکو ن سان ۔"
  12,100,"۔﴿شہرس منٛز دٲخل سپد نہٕ پتہٕ ﴾ تُلۍ تٔمۍ پنٕنۍ والد ین تہٕ بیہنٲوِن پا نس نِشہِ تختس پٮ۪ٹھ،تہٕ سٲر ی ؤتھۍ بے اختیار تس برونٛہہ کنہِ سجدس۔﴿لفظ سجدٕہ نِشہِ چھےٚ واریاہن لُکن غلط فہمی سپٕز مٕژ، حتیٰ کہ أکۍ دٔرۍ چُھ اَمی نِشہِ استدلال کٔرِ تھ با دشاہن تہٕ پیر ن خٲطرٕ سجد ۂ تحیتہ تہٕ سجد ۂ تعظیمی ہُک جوا ز کوٚڈمُت۔ با قی لُکن پیٚیہِ امہِ قبا حت نِشہِ بچنہٕ خٲطرٕ یہِ وضا حت کرٕ نۍ زِ بروٗنٹھمیٚن شر یعتن منٛز اوس سجدۂ عبا دت غیر اللہ ہن خٲطرٕ حرام، روٗد وۅ نۍ سُہ سجدٕہ یُس عبا دت کہ جذ بہٕ نِشہِ خٲلی آسہِ ، تیٚلہِ ہیٚکہِ سُہ خُدا یس ورٲے با قین تہِ کر نہٕ یِتھ ، البتہ شر یعت محمد ی صلی اللہ علیہ وسلمس منٛز آو پرٛتھ قسمُک سجد ہ غیر اللہ ہن خٲطرٕ حرام کر نہٕ ۔ مگر سار ے غلط فہمیہِ چھےٚ در اصل امہِ وجہ کِنۍ پٲدٕ گٔمژٕ زِ لفظ سجدہ آو مو جود اسلٲمی اصطلا حُک ہم معنی سمجھنہٕ ، یعنی اَتھہٕ ،کوٚٹھۍ تہٕ ڈیکہٕ زمینس پٮ۪ٹھ تھاوُن۔حالانکہ سجدُک معنی چھُ محض نَمُن تہٕ یتھ جایہِ چُھ یہِ لفظ أتھۍ معنیس منٛز ورتاو نہٕ آمُت۔﴾ یو سف ﴿علیہ السلامن﴾ وۅٚن ،  ابّا جان ،یہِ چُھ تعبیر میانہِ تمہِ خوا بُک ،یُس مےٚ برونٛہہ اوس وُچھمُت،میٲنۍ ربّن بنو و یہِ حقیقت،تٔمۍ سُند احسان چُھ زِ تٔمۍ کوٚڈنس بہٕ قٲدٕ منٛزٕ، تہٕ توٚہۍ أنۍ نَو صحر ا منٛزٕ کٔڑِتھ تہٕ رلٲوِ نَو مےٚ سٍتۍ، حالانکہ شیطا نن اوس مےٚ تہٕ میا نیٚن با ین در میان پھا ٹوَن واد تُر وومُت،پز ر چُھ یہِ زِ میو ن ربّ چُھ غیر محسو س تدبیر و سٍتۍ پنٕنۍ مشیت پوٗرٕ کران،بے شک چُھ سُہ زانن وول تہٕ حکمت وول۔"
  12,101,"۔ اے میانہِ ربّ ،ژےٚ کٔرٕ تھ مےٚ حکو مت عطا ، تہٕ بہٕ ہیٚچھنو و تھس کتھن ہٕندِس ژٔکِس تل واتُن، زمین و آسما ن بناوان والہِ ، ژٕ ے چُھکھ دُنیا ہس تہٕ ٲخرتس منٛز میو ن سر پرست، میو ن خٲتمہٕ کر اسلامس پٮ۪ٹھ تہٕ مےٚ رَلا و صا لحینن سٍتۍ۔"
  12,102,"۔اے نبی صلی اللہ علیہ وسلم، یہِ  قصہٕ چُھ غیب چو خبر و منٛزٕ ، یُس أسۍ تۅہیہِ پٮ۪ٹھ وَحی چِھ کران، نَتہٕ ٲسِو نہٕ توٚہۍ تمہِ ساعتہٕ موجو د، ییٚلہِ یو سف علیہ السلام سٕند یو بایَو پانہٕ وٲنۍ اتفا ق کٔرِتھ سازِش ٲس کٔرمٕژ۔"
  12,103,"۔مگر توٚہۍ ییٚژھۍ تَو کوٗتاہ تہِ ، یِمو منٛزٕ چِھنہٕ اکثر لُکھ مانن  وٲلۍ۔"
  12,104,"۔حالانکہ توٚہۍ چِھو نہٕ امہِ خد مت خٲطرٕ یِمن کانٛہہ اُجر ت تہِ منگا ن، یہِ چھےٚ اکھ نصیحت یۅسہٕ دُنیا والیٚن خٲطرٕ عام چھےٚ۔ع"
  12,105,"۔زمینس تہٕ آسما نن منٛز کٲژاہ نشٲنِیہِ چھےٚ یِمو پٮیٚٹھۍ یِم لُکھ پکا ن چِھ روزان، تہٕ رژھ چِھنہٕ یِم تو جہ کران۔"
  12,106,"۔یِمو منٛزٕ چِھ اکثر خُدا یس مانان ، مگر تِتھہٕ پٲٹھۍ زِ تس سٍتۍ چِھ با قین شر یک ٹھہراوان۔"
  12,107,"۔ کیا یِم چھا مطمعِن  زِ اللہ تعالیٰ سٕندِ عذا بٕچ کانٛہہ بلا ے کیا رٹہِ نہٕ یِمن ، یا بے خبر ی منٛز کیا یِیہِ نہٕ قیا متٕچ گٔر اچانک یِمن پٮ۪ٹھ۔"
  12,108,"۔توٚہۍ ؤنِو یِمن صاف زِ  میٲنۍ وَتھ چھےٚ یہِ ، بہٕ چُھس خُدا یس کُن ناد دِوان، بہٕ چُھس پانہٕ تہِ پوٗرٕ گا شس منٛز پنٕنۍ وَتھ وُچھان ، تہٕ میٲنۍ سٲتھی تہِ چِھ وُچھان، تہٕ اللہ تعالیٰ چُھ پاک تہٕ شر ک کر ن والیٚن سٍتۍ چُھنہٕ مےٚ کانٛہہ وا سطہٕ۔"
  12,109,"۔اے نبی صلی اللہ علیہ وسلم، تۅہیہِ برونٛٹھ یِم پیغمبر اسہِ سوٗزِ مٕتۍ ٲسۍ، تِم تہِ ٲسۍ سٲر ی اِنسا نٕے،تہٕ تِمنٕے بٔستین ہٕند یو روزن والیو منٛزٕ ٲسۍ ،تہٕ تِمنٕے کُن چِھ أسۍ وحی روٗدِ مٕتۍ سوزان۔ پتہٕ کیا ،یِم لُکھ چِھنا زمینس منٛز پھیٖرِ مٕتۍ تھوٗرِ مٕتۍ،تہٕ تِمن قو من ہُند انجام وُچھنا یِمو، یِم یِمن برونٛہہ چِھ گُزر یمٕتۍ؟ پٔزۍ پٲٹھۍ چُھ ٲخرتُک گھرٕ تِمن لُکن خٲطرٕ زیادہ بہتر ،یِمو﴿پیغمبر ن ہٕنز کتھ مٲنِتھ﴾ تقویٰ ہٕچ رٔوِش اختیار کٔر، کیا وُنہِ تہِ سمجھِو نا توٚ ہۍ لُکھ ؟"
  12,110,"۔﴿گۅٚڈٕ نِکیٚن پیغمبر ن سٍتۍ تہِ چُھ یی سپدان روٗدمُت زِ تِم روٗدۍ واریاہس وقتس نصیحت کران تہٕ لُکو دِیُت نہٕ بوٗزِ تھ تہِ جواب﴾ یوٚت تام زن پیغمبر سپٕدۍ لُکو نِشہِ مایو س،تہٕ لُکو تہِ سمُجھ زِ تِمن اوس آمُت اَپُز وننہٕ، تہٕ پتہٕ ووت اچا نک پیغمبر ن سو ن مدد،پتہٕ ییٚلہِ یُتھ مو قع  واتان چُھ، تیٚلہِ چُھ سو ن قاعدہ یہِ زِ یُس أسۍ یژھان چِھن سُہ چِھن بچا وان،تہٕ مُجر مَو پٮ۪ٹھہٕ یِیہِ نہٕ سو ن عذا ب واپس پھِر نہٕ۔"
  12,111,"۔ بروٗنٹھمیٚن لُکن ہٕند یٚن یِمن قصن منٛز چُھ عقل تہٕ ہو ش تھاون والیٚن خٲطرٕ عبرت، یِکینژھاہ یہِ قرآنس اندر بیان چُھ یِوان کر نہٕ ،یمہٕ چَھنہٕ بنا وٹی کتھہٕ، بلکہ یِمہٕ کتا بہٕ ییٚمہِ برونٛہہ چھےٚ آمٕژ، یہِ چُھ تِمنٕے ہُند تصد یق،تہٕ پرٛتھ  چیزُک تفصیل ﴿یعنی پرتھ تمہِ چیزُک تفصیل یُس انسان سٕندِ ہدا یت تہٕ  رہنمٲیی خٲطرٕ ضرور ی چُھ۔کینٛہہ لُکھ چِھ پرٛتھ چیز کہ تفصیل نِشہِ مُراد خوا ہ مخواہ دُنیا کیٚن سارِنٕے چیز ن ہُند تفصیل نِوان تہٕ پتہٕ چھےٚ تِمن یہِ پر یشٲنی پیش یِوان زِ قرآنس اندر چُھنہٕ جنگلا ت ، طب ، ریٲضی تہٕ با قین علو م و فنونن متعلق کانٛہہ تفصیل میلان، تہٕ کینٛہہ لُکھ چِھ پتہٕ زبردستی پرٛتھ فنُک تفصیل قرآن منٛزٕ کڑ نہِ لگان۔﴾ تہٕ ایمان اَنن والیٚن خٲطرٕ چُھ ہدا یت تہٕ رحمت۔ ع"
