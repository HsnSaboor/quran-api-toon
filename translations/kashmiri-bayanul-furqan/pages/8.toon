quran[75]{c,v,t}:
  8,1,"۔تۅہیہِ چِھو اَنفا لس متعلق پٕرٛژھان ﴿اَنفا ل چُھ نَفلُک جمع۔ عر بی زبٲنۍ منٛز چِھ نفل تتھ چیز س ونان یُس وٲجب یا تَمہِ کھۅتہٕ ہُر یمانہٕ آسہِ ۔ ییٚلہِ یہِ تٲبع ﴿ماتحت ﴾ سٕندِ طر فہٕ آسہِ تیٚلہِ چُھ اَمہِ نِشہِ مُراد سۅ رضا کارانہٕ خد مت آسان یۅسہٕ اکھ بندٕہ پننِس مٲلِکس خٲطرٕ فر ض کھۅتہٕ ہُر یمانہٕ پننہِ خو شی بجا چُھ اَنان ، مثلاً نفل نماز ۔تہٕ ییٚلہِ یہِ متبو ع ﴿یس اِتبا ع یِیہِ کر نہٕ ﴾ سٕندِ طر فہٕ آسہِ چُھ امہِ نِشہِ مُراد سُہ عطیہ یا انعا م آسان یُس مٲلِک پننِس بندس چُھ تٔمۍ سٕندِ حقہٕ کھۅتہٕ ہُر یمانہٕ دِوان ۔ یتھ جایہِ چُھ انفا ل لفظ تِمن مالِ غنیمتن خٲطرٕ وَرتا و نہٕ آمُت یِم جنگِ بدرس منٛز مسلمانن ٲسۍ حٲصل گٔمٕتۍ تہٕ یِمن انفا ل قرار دِنُک مطلب چُھ مسلمانن یہِ کتھ ذہن نشین کرٕ نۍ زِ یہِ چَھنہٕ تُہٕنز کمٲے بلکہ چُھ اللہ تعالیٰ سُند فضل تہٕ انعام یُس تٔمۍ تۅہیہِ عطا کوٚر نو ﴾ ؤنِو یِم انفا ل چِھ خُدا یس تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕندۍ، لہٰذا کھوٚژِ و خُدا یس تہٕ اکھ أکِس سٍتۍ تھٲوِو پنٕنۍ تعلقا ت دُرست ،بیٚیہِ کٔرِو اللہ تعالیٰ سٕنز تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز اطا عت، اگر توٚہۍ مو من چِھو ﴿یہِ کتھ چھےٚ امہِ موجو ب فر ماو نہٕ آمٕژ زِ یہِ مال بٲگراونس متعلق کانٛہہ حُکم یِنہٕ برونٛہہ اوس مسلمانومنٛزٕ کینژھو دَر یٚو  پننِس حقس متعلق دعویٰ لو گمُت کرُن ﴾"
  8,2,"۔پٔزۍ اہلِ ایمان چِھ تِم لُکھ یِہندۍ دِل اللہ تعالیٰ سٕنز ذکر بوٗزِ تھ لرزان چِھ تہٕ ییٚلہِ اللہ تعالیٰ سٕندۍ آیات تِمن برونٛہہ کنہِ پر نہٕ چِھ یِوان تیٚلہِ چُھ تِہُند ایمان ہُران، تِمن چُھ پننِس ربّس پٮ۪ٹھ اعتماد آسان۔"
  8,3,"۔یِم نماز چِھ قٲیِم کران تہٕ یِکینژھاہ اسہِ تِمن دِیتمُت چُھ تمہِ منٛزٕ چِھ ﴿سانہِ وَتہِ منٛز ﴾ خر چ کران۔"
  8,4,"۔یِتھی لُکھ چِھ حقیقی مو من ۔یِہندِ خٲطرٕ چِھ یِہندِس ربّس نِشہِ بٔڑۍ در جہِ ،قصور و نِشہِ چُھکھ در گزر بیٚیہِ چُھکھ بہتر ین رز ق ۔"
  8,5,"۔﴿یتھ مالِ غنیمت کِس معا ملس منٛز تہِ چھےٚ تِژٕھے صوٗرت پیش یِوان یژھ تمہِ وقتہٕ پیش ٲس آمٕژ ییٚلہِ ﴾ تُہٕندۍ ربّن حق سان توٚ ہۍ پننہِ گھرِ ٲسِنو کٔڑِ مٕتۍ،تہٕ مو منو منٛزٕ اوس أکِس دٔرِس یہِ نا گوار گوٚ مُت۔"
  8,6,"۔تِم ٲسۍ اتھ حق کِس معا ملس منٛز تۅہیہِ سٍتۍ ژُوان حالانکہ سُہ اوس ٹا کارٕ ہ پٲٹھۍ نوٚ ن درٛا مُت تِہُند حال اوس یہِ زَنتہٕ تِم وُچھان ٲسۍ تِم چِھ مو تس کُن کھٕرٛ کہٕ وٕنہٕ یِوان ۔"
  8,7,"۔یاد کٔرِو سُہ موقع ییٚلہِ اللہ تعالیٰ اوس تۅہیہِ سٍتۍ وعدہ کران زِ دۅ شوٕیو دٔریٚو منٛزٕ گژھیو تۅہیہِ اکھ حٲصل ﴿یعنی قر یشن ہُند تجا رتی قٲفلہٕ یُس شام کِنۍ اوس یِوان نَتہٕ قر یشن ہُند لشکر یُس مکہٕ پٮ۪ٹھہٕ یِوان اوس﴾ توٚہۍ ٲسِو یژھان زِ کمز ور دوٚر گوٚژُھو تۅہیہِ میلُن مگر اللہ تعالیٰ سُند ارادٕہ اوس یہِ زِ پننیو ارشادَو سٍتۍ ہاوِ ہے حقس حق بنٲوِ تھ، تہٕ کٲفر ن ژَٹہِ ہے موٗل۔"
  8,8,"۔تاکہ حق روزِ ہے حق بٔنِتھ تہٕ بٲطل روز ہے با طل بٔنِتھ، خوا ہ مُجرِ من یہِ کوتاہ تہِ نا گوار گٔژھۍ تن ۔"
  8,9,"۔بیٚیہِ سُہ مو قع ییٚلہِ توٚہۍ پننِس ربّس فر یاد ٲسِو کران،در جوا ب فر مو و تٔمۍ زِ بہٕ سوزٕ تُہٕندِ مددٕ خٲطرٕ پیوٚ ٹھس پٮ۪ٹھ اکھ سا س فر شتہٕ۔"
  8,10,"۔یہِ کتھ ؤنۍ نَو خُدا ین تۅہیہِ صرف امہِ موجو ب زِ تۅہیہِ سپد یو خو ش خبر،تہٕ تُہٕندۍ دِل سپدَن اَمہِ سٍتۍ مطمعین، نَتہٕ ییٚلہِ تہِ مدد سپدان چُھ، سُہ چُھ اللہ تعالیٰ سٕندی طر فہٕ سپدان، پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ زبردست تہٕ حکمت وول ۔ع"
  8,11,"۔بیٚیہِ سُہ وقت ییٚلہِ اللہ تعالیٰ پننہِ طر فہِٕ غنو د گی ہٕنزِ شکلہِ منٛز تۅہیہِ پٮ۪ٹھ اِطمینان تہٕ بے خو فی ہٕنز کیفیت طٲر ی اوس کران۔﴿ یۅ ہے تجر بہ اوس مُسلمانن جنگ  اُحدس منٛز پیش آمُت،یِتھہٕ پٲٹھۍ زن سورہ آلِ عمران آیت ، 154، ہَس منٛز فر ما و نہٕ چُھ آمُت﴾ تہٕ آسما نہٕ پٮ۪ٹھہٕ اوس تۅہیہِ پٮ۪ٹھ آب تراوان،تاکہ تۅہیہِ کرِ ہیٚو پاک تہٕ تۅہیہِ نِشہِ کرِ  ہے شیطا ن سٕنز تراو نہٕ آمٕژ نا پٲکی دوٗر،تہٕ تُہٕندۍ دل کرِ ہے مضبوط تہٕ امہِ ذریعہ دٔرراوِ ہے تُہٕندۍ قد م۔"
  8,12,"۔بیٚیہِ سُہ وقت ییٚلہِ تُہُند ربّ فر شتن اوس اِشارہ کران زِ بہٕ چُھس تۅہیہِ سٍتۍ، توٚہۍ تھٲوِ یوٗکھ اہلِ ایمان ثٲبت قد م، بہٕ ترا وٕ یِمن کٲفر ن ہٕندٮ۪ن دِلن منٛز بیٖم، لہٰذا ، لگٲوِو توٚہۍ تِہنز ن گردنن پٮ۪ٹھ چو ٹ۔ ﴿جنگِ بدر کۍ یِم وا قعات یوٚت تام اکہِ اکہِ یاد پاو نہٕ چِھ آمٕتۍ اَمہِ نِشہِ چُھ مقصد در اصل لفظاَنفا ل ہٕچ معنو یت وا ضح کرٕ نۍ۔ابتدا ہس منٛز اوس ارشاد سپُد مُت زِ توٚہۍ کتھ چِھو ما لِ غنیمتس پننہِ جا نفشٲنی ہُند پھل سمجھِتھ اَمِکۍ مٲلک تہٕ مختار بنان ۔ یہِ چُھ در اصل اللہ تعالیٰ سُند عطیہِ تہٕ مُعطِی ﴿عطیہ دنہٕ وول﴾ چُھ خۅد پننہِ مالُک پانہٕ مختار۔وۅ نۍ چِھ امہِ کِس ثبوتس منٛز یِم وا قعات گٕنز را و نہٕ آمٕتۍ زِ اتھ کا میٲبی منٛز لگٲوۍ تَو پا نے حسا ب تہٕ وُچِھتَو زِ تُہٕنزِ جا نفشٲنی ، جُر اتُک تہٕ جسارتُک کوتاہ حصہٕ اوس، تہٕ اللہ تعالیٰ سٕندِ عنا یتُک کوتاہ حصہٕ اوس۔ امہِ موجو ب اَمِیُک فٲصلہٕ کرُن زِ یہِ کِتھہٕ پٲٹھۍ گژِھہ بٲگرا و نہٕ یُن چَھنہٕ تُہٕنز کٲم بلکہ چھےٚ اللہ تعالیٰ سٕنز کٲم﴾"
  8,13,"۔یہِ چھُ امہِ موجو ب زِ تِمو کوٚر خُدا یس تہٕ تٔمۍ سٕندِس رسولس صلی اللہ علیہ وسلمس سٍتۍ مقا بلہٕ تہٕ یُس خُدا یس تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلمس سٍتۍ مقا بلہٕ کرِ، اللہ تعالیٰ چُھ تٔمۍ سٕندِخٲطرٕ سٮ۪ٹھاہ سخت گیر۔"
  8,14,"۔ یہِ چُھ تۅہیہِ لُکن ہُند سزا ﴿مخٲطب چِھ کُفارِ قر یش ، یِمن بدرس منٛز شکست میوٗل ﴾ وۅ نۍ وُچِھو اَمِیُک مزٕ ہ، تہٕ تۅہیہِ گژھیو فِکرِ تَرُن زِ حقس انکار کر ن والیٚن خٲطرٕ چُھ جہنمُک عذا ب۔"
  8,15,"۔اے لوٗکو یِمو ایمان چُھو اونمُت ،ییٚلہِ تۅہیہِ أکِس لَشکر کِس صوٗرتس منٛز کُفار ن سٍتۍ بُتھۍ لاگے سپدِ تیٚلہِ پھِر ۍ زیو نہٕ تِہندِس مقا بلس منٛز شا نہٕ ﴿یعنی یوٚت پھیٖرۍ زیٚو نہٕ ﴾"
  8,16,"۔ییٚمۍ اَتھ مو قعس پٮ۪ٹھ شا نہٕ پھِر ۍ اِلاّیہِ زِ جنگی چا لہِ رٔنگۍ کرِ  یا کرِ کٲنٛسہِ دوٚ یِمِس فوجس سٍتۍ رَلنہٕ موجو ب ، نَتہٕ یِیہِ سُہ اللہ تعالیٰ سٕندِس غضبس منٛز ہیٚنہٕ، تٔمۍ سُند ٹھکا نہٕ آسہِ جہنم ، تہٕ سۅ چھےٚ سٮ۪ٹھہٕے نا کارٕ ہ وا پسی ہٕنز جاے ۔"
  8,17,"۔ لہٰذا چھےٚ حقیقت یہِ زِ تۅہیہِ کٔرِ یوٗکھ نہٕ تِم قتل،بلکہ کٔرۍ تِم خُدا ین قتل ،تہٕ اے نبی صلی اللہ علیہ وسلم  ،تۅہیہِ چھوٚ کوٕ نہٕ  بلکہ چھوٚک خداین ۔﴿بدرکِس معرکس منٛز ییٚلہِ مسلمانن تہٕ کٲفرن ہٕندۍ لشکر اکھ أکِس برونٛٹھ کُن آے تہٕ پتہٕ ووت  اَتھہٕ مِلوَ نُک مو قع، حضور صلی اللہ علیہ وسلم چِھ پننِس دستِ مبا رکس منٛز اکھ سیٚکہِ مۅ ٹھ تُلان تہٕ پتہٕ چِھ شاہَتِ الو جُو ہ، وَنان و نان سۅ کُفا ر ن کُن چھکا ن تہٕ یہِ فر ماو نس سٍتی چِھ مسلمان حضور صلی اللہ علیہ وسلمن ہٕندِ س اِشارس پٮ۪ٹھ یکبا ر کُفار ن پٮ۪ٹھ حملہٕ کران۔یہِ چُھ أتھۍ وا قعس  کُن اشارہ۔ مطلب چُھ یہِ زِ دستِ مبا ر ک اوس حضو ر صلی اللہ علیہ وسلمن ہُند مگر ضر ب اوس  اللہ تعالیٰ سٕندِ طر فہٕ ﴾"
  8,18,"۔ ﴿تہٕ مو منن ہٕندۍ اتھہٕ یِم اتھ کامہِ منٛز استعمال آے کر نہٕ﴾ اوس امہِ موجو ب زِ اللہ تعالیٰ تارِ ہے مو منن اکہِ بہتر ین آز ما یشہِ سٍتۍ کا میٲبی سان اَپو ر ، پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ بو زن وول تہٕ زانن وول ۔ یہِ معا ملہٕ چُھ تۅہیہِ سٍتۍ ، تہٕ کا فر ن سٍتۍ چُھ معا ملہٕ یہِ زِ اللہ تعالیٰ چُھ تِہنزن چا لن کمزور کر ن وول۔"
  8,19,"۔ ﴿ یِمن کٲفر ن ؤنِو ﴾ اگر توٚہۍ فٲصلہٕ ٲسِو یژھان، رٔٹِو تیٚلہِ ووت فٲصلہِٕ تۅہیہِ برونٛہہ کُن ۔﴿ مکہ پٮ۪ٹھہٕ روا نہٕ سپد نہٕ وِزِ اوس مُشرِ کو کعبٕکۍ پردٕہ رٔٹِتھ دُعا مو نگمُت زِ خُدا یا ، دۅ یو دَریو منٛزٕ یُس بہتر چُھ تس کر فتح عطا ﴾ وۅ نۍ پھیٖرِ و باز، تُہٕندی خٲطرٕ چُھ بہتر، اگر یوٚت پھیٖرِ تھ سۅ ے غلطی کٔرِو ، تیٚلہِ کر و أسۍ تہِ تَمی سزا ہُک اِعا دٕہ، تہٕ تُہٕنز جمعیّت ، خوا ہ سۅ کٲژاہ تہِ زیادٕہ آسہِ ، یِیَو نہٕ تۅہیہِ بکار ، اللہ تعالیٰ چُھ مو منن سٍتۍ ۔ ع"
  8,20,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، اللہ تعالیٰ سٕنز تہٕ تٔمۍ سٕندِس رسول سٕنز کٔرِ و اطا عت  تہٕ حکم بو زنہٕ پتہٕ مَہ پھِر و تمہِ نِشہِ بُتھ۔"
  8,21,"۔تِمن لُکن ہٕندۍ پٲٹھۍ مَہ بٔنِو ، یِمو ووٚن زِ اسہِ بوٗز حا لانکہ تِم چِھنہٕ بوزان۔"
  8,22,"۔پٔزۍ پٲٹھۍ چِھ خُدا یس نز دیک بد تر ین قسمٕکۍ جا نور تِم زٔرۍ تہٕ کٔلۍ یِم عقلہِ  چِھنہٕ کٲم ہیٚوان۔"
  8,23,"۔ اگر خُدا یس پے آسہِ ہے زِ یِمن منٛز چُھ رژھ تہِ رٕژر تیٚلہِ دِیہِ ہے سُہ تِمن بوزنُک تو فیق، ﴿مگر رٕژرٕ ورٲے ﴾ اگر سُہ تِمن بو زنا وِ ہے تیٚلہِ پھِر ہَن تِم بے رُخی سان بُتھ۔"
  8,24,"۔ اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ، اللہ تعالیٰ تہٕ تٔمۍ سٕندِ س رسول صلی اللہ علیہ  وسلم سٕندِس آلو س پٮ۪ٹھ ؤنِو لبیک ییٚلہِ زَن رسول صلی اللہ علیہ وسلم تۅہیہِ تتھ چیز س کُن بُلا وِ یُس تۅہیہِ زند گی بخشن وول چُھ، بیٚیہِ تھٲوِ و زٲنِتھ زِ اللہ تعالیٰ چُھ انسا نس تہٕ تٔمۍ سٕندِس دِلس در میان حٲیل تہٕ تٔسۍ کُن یِیِو توٚہۍ ﴿روزِ محشر س منٛز ﴾ ؤٹِتھ نِنہٕ ۔"
  8,25,"۔بیٚیہِ بٔچِو تمہِ  فِتنہٕ نِشہِ ییٚمِچ شہمت مخصو ص پٲٹھۍ تِمنٕے لُکن تام محدوٗد روزِنہٕ یِمَو تۅہیہِ منٛزٕ گنا ہ آسہِ کوٚر مُت ۔ ﴿اَمہِ نِشہِ  چُھ مُراد تِم اجتما عی فتنہٕ یِم عا م وَبا ہٕکۍ پٲٹھۍ تِژھ شہمت چِھ اَنان یتھ منٛز صرف گنا ہ کر ن وٲلی یٲتۍ چِھنہٕ گرفتار سپدان بلکہ چِھ  تِم لُکھ تہِ مارٕہ گژھان یِمَو گنا ہ  گار سو سا یٹی منٛز روزُن آسہِ برداشت کوٚر مُت ﴾ تہٕ زٲنِتھ تھٲوِ و ، اللہ تعالیٰ چُھ سخت سزا دِنہٕ وول ۔"
  8,26,"۔یا د کٔرِو سُہ وقت ییٚلہِ توٚہۍ کمٕے ٲسِو ،زمینس منٛز ٲسِو توٚہۍ کمز ور یِوان سمجھنہٕ، توٚہۍ ٲسِو کھۅژا ن روزان زِ خبر لُکھ مامِٹا وَنو تۅہیہِ، پتہٕ کٔر نو تۅ ہیہِ خُدا ین چَھپن جا ے دستیا ب ، پننہِ مددٕ سٍتۍ کٔرِن تُہٕندۍ اتھہٕ مضبو ط تہٕ تۅہیہِ وا تنو ونَو جا ن رزِق ، شا ید زِ توٚہۍ بٔنِو شکر گزار ۔"
  8,27,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت،مَہ کٔرِ و خُدا یس تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس ﴾ سٍتۍ خیا نت ، پننیٚن اما نتن منٛز مہ کٔرِ و زٲنِتھ مٲنِتھ غدٲر ی ہُنٛد اَتُر۔﴿  پننیٚن امانتن  نِشہ، چُھ مُراد تمہٕ سار ے ذمہ دٲرِیہِ یِم کٲنٛسہِ پٮ۪ٹھ اعتماد کٔرِ تھ تس حوالہٕ یِن کر نہٕ ،خو اہ تِمہٕ  عہدِ وفا  چہِ ذمہ دٲرِیہِ آسن یا اجتمٲعی معا ہد ن ہٕنزٕ ، یا  آسن جما عت کیٚن رازن ہٕنزٕ ، یا شخصی تہٕ جما عتی مالن ہٕنزِ، یا کُنہِ عہدہ تہٕ منصب چہِ ، یِمہٕ جماعت کٲنٛسہِ شخصس پٮ۪ٹھ بھر وسہٕ کٔرِ تھ حوا لہٕ کٔرِ ﴾"
  8,28,"۔تہٕ زٲنِتھ روٗزِ و ، زِ تُہٕندۍ مال تہٕ تُہٕندۍ اولاد چِھ در حقیقت آز مٲیشہِ ہٕندۍ سامان تہٕ خُدا یس نِشہِ چُھ اَجر دِنہٕ خٲطرٕ واریاہ کینٛہہ۔ ع"
  8,29,"۔ اے لوٗ کو یِمو ایمان چُھو اوٚنمُت ، اگر توٚہۍ تقوٰی اختیار کٔرِ و ، تیٚلہِ تھا وِ اللہ تعالیٰ تُہندِ خٲطرٕ کہؤٹ بہم۔﴿ کہؤٹ چِھ تتھ چیز س ونان یۅسہٕ اصلٕچ تہٕ کھۅٹِچ فر ق چھےٚ نٔنۍ کڑا ن ۔یۅ ہے مفہو م چُھ فر قا نُک  تہِ ، اوَے چُھ اَسہِ  فر قان  لفظُک تر جمہٕ کہؤٹ  کوٚر مُت۔ارشادِ الہٰی ہُک مَنشہِ چُھ یہِ زِ اگر خُدا یس کھۅٚژۍ کھۅٚژۍ دُنیا ہس منٛز کٲم کرِ و تیٚلہِ کرِ خُدا ے تۅہیہِ منٛز فرق کر نُک سُہ طا قت پٲدٕ ، یِیِمہِ سٍتۍ قد مس  قد مس پٮ۪ٹھ تۅہیہِ پٲنۍ پا نے  یہِ پے لگہِ زِ کُس ہیوٗ رٔوِ یہِ چُھ صحیح تہٕ کُس  چُھ غلط،کۅ سہٕ ہِش وَتھ چھےٚ حق یۅسہٕ خُدا یس کُن چھےٚ گژھان تہٕ کۅسہٕ وَتھ چھےٚ بٲطل یۅسہٕ شیطا نس   سٍتۍ چھےٚ رلا وان﴾ تہٕ تُہٕنز بُرٲییہِ کرِ تۅ ہیہِ نِشہِ دوٗر تہٕ تُہٕندۍ قصورکرِ معا ف ، اللہ تعالیٰ چُھ بوڈ فضل کر ن وول ۔"
  8,30,"۔سُہ وقت تہِ چُھ یاد پا ونس قٲبل، ییٚلہِ منکر ینِ حق تۅہیہِ خلا ف تدبیر ٲسۍ سو نچا ن زِ تۅہیہِ کر ہَنَو قٲد یا کر ہَنَو قتل، نَتہٕ کڑ ہَنو وطنہٕ منٛزٕ ﴿یہِ چھےٚ تمہِ مو قعٕچ ذکر ییٚلہِ قر یشن ہُند یہِ اند یشہِ یقین کِس حدس تا م اوس ووٚ نمُت زِ وو نۍ گژھن محمد صلی اللہ علیہ وسلم تہِ مد ینہٕ۔تمہِ ساعتہٕ لٔگۍ تِم پانہٕ وٲنۍ وَننہِ زِ اگر یہِ شخص مکہٕ منٛزٕ درٛاو تیٚلہِ ژلہِ خطر ہ سانہِ قا بو نِشہِ نیٚبر۔چنا نچہِ تِمو کوٚر حضور صلی اللہ علیہ وسلمن متعلق ٲخر ی فٲصلہٕ کر نہٕ مۅ کھہٕ اکھ اجتماع تہٕ اتھ کتھہِ پٮ۪ٹھ کوٚرُکھ پانہٕ وٲنۍ مشو رٕ ہ زِ امہِ خطرُک سدِ با ب کِتھہٕ پٲٹھۍ یِیہِ کر نہٕ ﴾ تِم ٲسۍ پننہِ چا لہٕ گِندا ن تہٕ اللہ تعالیٰ اوس پنٕنۍ چا ل گںدا ن  تہٕ اللہ تعالیٰ چُھ سارِنٕے ہٕندِ کھۅ تہٕ بہتر چا ل گںد ن وول ۔"
  8,31,"۔ییٚلہِ تِمن ٲسۍ سٲنۍ آیات بو ز ناو نہٕ یِوان ، تِم ٲسۍ ونان زِ  آ، بوٗز اَسہِ ، ہر گاہ یژھو أسۍ تہِ ہیٚکو یِژھے کتھہٕ بنٲوِتھ، یِمہٕ چھےٚ تِمے پرا نہٕ دلیلہٕ یِمہٕ لُکھ چِھ گۅڈٕ پٮ۪ٹھے ونان پکا ن۔"
  8,32,"۔ تہٕ سۅ کتھ تہِ چھےٚ یاد یۅسہٕ تِمو ؤنِمٕژ ٲس زِ  خُدا یا ، اگر یہِ وا قعی حق چُھ چا نہِ طر فہٕ ، تیٚلہِ وال اَسہِ پٮ۪ٹھ آسما نہٕ پٮ۪ٹھہٕ کنہِ ، نَتہٕ اَن کانٛہہ دگ تُلوُن عذا ب اَسہِ پٮ۪ٹھ۔"
  8,33,"۔تمہِ وقتہٕ اوسنہٕ اللہ تعالیٰ تِمن پٮ۪ٹھ عذا ب نٲزِل کر ن وول ییٚلہِ توٚہۍ تِمن در میان ٲسِو، تہٕ بیٚیہِ چُھنہٕ اللہ تعالیٰ سُند یہِ قٲعدہ زِ لُکھ آسن استغفار کران تہٕ سُہ دِیہِ تِمن عذا ب۔"
  8,34,"۔مگر وۅ نۍ کیا زِ کرِ نہٕ سُہ تِمن پٮ۪ٹھ عذا ب نٲزِل ، ییٚلہِ زن تِم مسجدِ حرا مٕچ وَتھ چِھ رُکا وان ، حالانکہ تِم چِھنہٕ امہِ مسجدِ ہٕندۍ جٲیز مُتؤلۍ کینٛہہ، اَمِکۍ جٲیز مُتؤلۍ ہیکن صرف اہل تقویٰ ہٕے ٲسِتھ، مگر اکثر چِھنہٕ اَتھ کتھہِ زانان۔"
  8,35,"۔بیت اللہ ہس نکھہٕ کۅ سہٕ نما ز چھےٚ یِمن لُکن سپدان؟ بس چِھ شُرِ نہِ کران تہٕ اَتھہٕ وایان، لہٰذا ، رٔٹِو وۅ نۍ ، تمہِ عذا بُک مزٕ ہ وُچِھو پننِس تتھ انکارِ حق کِس پا داشس منٛز یُس توٚہۍ کران چِھو روٗدِمٕتۍ۔"
  8,36,"۔یِمو لُکو حق ماننہٕ نِشہِ انکار چُھ کوٚر مُت ، تِم چِھ پنٕنۍ مال اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ رُکا و نہٕ مۅ کھہٕ خر چ کرا ن، تہٕ وُنہِ روزن بیٚیہِ خر چ کرا ن، مگر ٲخر کار بنن  یِمے کوٗششہِ تِہندِ خٲطرٕ پچھتاو نُک سبب ،پتہٕ گژھن تِم مغلو ب ، پتہٕ یِن یِم کٲفر جہنمس کُن گھیرٕ کٔرِتھ اَننہٕ ۔"
  8,37,"۔ تا کہ اللہ تعالیٰ کرِ گند گی ،پٲکیزگی نِشہِ چھٲنٹِتھ بیوٚ ن،تہٕ پرٛتھ قسمٕچ گند گی رلٲوِ تھ کریٚس کُنُے، پتہٕ چھکہِ تتھ پھٹجہِ جہنمس، یِمے لُکھ چِھ اصلی خسا رٕ ہ لد ۔ ع"
  8,38,"۔ اے  نبی صلی اللہ علیہ وسلم، یِمن کٲفر ن ؤنِو زِ اگر وُنہِ تہِ با ز پھیر ن تیٚلہِ یِکینژھاہ پتھ کُن سپُد مُت چُھ ، سُہ یِیہِ در گز ر کر نہٕ ، البتہٕ اگر یِم تَمی پٔتِمہِ رٔوِشہِ ہُند اعا دٕہ کر ن تیٚلہِ یِکینژھاہ پٔتِمیٚن قو من سٍتۍ سپُد مُت چُھ سُہ چُھ سارِ نٕے پے ۔"
  8,39,"۔ ﴿اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ﴾ یِمن کٲفر ن سٍتۍ کٔرِ و جنگ یوٚت تام فِتنہٕ گژِھہ ختم تہٕ دین سپدِ پوٗرٕ پٲٹھۍ اللہ تعالیٰ سٕندِ خٲطرٕ ، پتہٕ اگر تِم فتنہ نِشہِ با ز پھیرن، تیٚلہِ چُھ تِہٕند ٮ۪ن اعما لن ہُند وُچھن وول اللہ تعالیٰ ،"
  8,40,"۔تہٕ اگر تِم مانن نہٕ تیٚلہِ روٗزِ و زٲسِتھ زِ اللہ تعالیٰ چُھ تُہُند رچھن وول تہٕ سُہ چُھ بہتر ین حٲمی تہٕ مددگار ۔"
  8,41,"۔تہٕ تۅہیہِ گژِھہ پے لگٕنۍ زِ یُس مالِ غنیمت تۅہیہِ حٲصل چُھو کوٚر مُت﴿ یتھ جایہِ چُھ تَمہِ مالِ غنیمت کہ بٲگراونُک قا نو ن وَننہٕ یِوان یتھ متعلق تقر یر کِس ابتدا ہس منٛز وَننہٕ اوس آمُت زِ یہِ چُھ اللہ تعالیٰ سُند انعا م یتھ متعلق فٲصلہٕ کر نُک اختیار اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕے یو ت چُھ، وۅ نۍ آو سُہ فٲصلہٕ بیان کر نہٕ ﴾ تَمِیُک پوٗنزِ م حصہ چُھ خدا یس تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس ﴾ خٲطرٕ بیٚیہِ رشتہٕ دارن ، یتیمن، مسکینن تہٕ مسافر ن خٲطرٕ اگر تۅہیہِ ایمان اوٚنمُت چُھو خُدا یس پٮ۪ٹھ تہٕ تتھ چیز س پٮ۪ٹھ یُس فٲصلہٕ کہ دۅہ ،یعنی دۅ شوٕنۍ فو جن ہٕندِ ٹکر او نہٕ کہ دۅ ہ اسہِ پننِس بند س پٮ۪ٹھ نٲزِل اوس کوٚر مُت،﴿ یعنی سُہ تٲییدتہٕ نصرت ییٚمہِ کہ بد و لتہٕ تۅہیہِ فتح حٲصل سپزٕ و ، تہٕ ییٚمہِ کہ بدو لتے تۅہیہِ یہِ مالِ غنیمت حٲسل سپدُو، تیٚلہِ کٔرِ و یہِ حصہٕ خو شی سان ادا ﴾ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  8,42,"۔یاد کٔرِو سُہ وقت ییٚلہِ توٚہۍ وادی ہٕندِ ییٚمہِ طر فہٕ ٲسِو تہٕ تِم ٲسۍ دوٚ یِمہِ طر فہٕ پڑا و ترٲوِتھ تہٕ فٲصلہٕ اوس تۅہیہِ بٔنۍ کِنۍ ﴿ سٲحِلس ﴾ کُن اگر تۅہیہِ تہٕ تِمن در میان گۅڈ ے مقا بلٕچ قرار داد سپد یمٕژ آسِہے،تیٚلہِ کٔرِ ہِو توٚہۍ ضروٗرتتھ مو قعس پٮ۪ٹھ اجتناب، البتہ یِکینژھاہ پیش آو سُہ اوس امہِ موجو ب زِ ییٚمہِ کتھہِ ہُند فٲصلہٕ خُدا ین کوٚر مُت اوس تتھ کڈِ نوٚ ن تا کہ یس ہلا ک چُھ سپدُن ،سُہ گژھہِ ٹا کارٕ دلیلہِ سان ہلاک، تہٕ یَس زند ہ چُھ روزُن ، سُہ روزِ ٹا کارٕ دلیلہِ سان زند ہ،یقیناً چُھ اللہ تعالیٰ بو زن وول تہٕ زانن وول۔"
  8,43,"۔اے نبی صلی اللہ علیہ وسلم ، تہٕ یاد کٔرِ و سُہ وقت،ییٚلہِ اللہ تعالیٰ اوس تِمن تُہندِس خوا بس منٛز کمٕے ہاوان۔﴿یہِ چھےٚ تمہِ وقتٕچ کتھ ییٚلہِ حضو ر صلی اللہ علیہ وسلم مُسلمان ہیٚتھ مد ینہٕ پٮ۪ٹھہٕ نیران ٲسۍ یا وَتہِ ٲسۍ کُنہِ جایہِ ، تہٕ یہِ ٲس نہٕ پے زِ کٲفر ن ہُند لشکر کوتاہ بوٚڈ چُھ۔ تمہِ وقتہٕ وُچھ حضور صلی اللہ علیہ وسلمو خوا بس منٛز یہِ لشکر،تہٕ یُس منظر تِمن برونٛہہ کنہِ پیش آو کر نہٕ تمہِ نِشہِ کوٚر تِمو اندازہ زِ دشمنن ہُند تعداد چُھنہٕ زیادہ کینٛہہ﴾ ہرگاہ سُہ تۅہیہِ تِہُند تعداد زیادہ ہاوِ ہے۔تیٚلہِ ہٲرِ ہِو ضرور توٚہۍ ہمت تہٕ لڑا یہِ ہٕندِس معا ملس منٛز تُلہِ ہِو تنا زعہ، مگر خُدا ے نٕے بچٲوِ نو توٚہۍ امہِ نِشہِ ، پٔزۍ پٲٹھۍ چُھ سُہ سیٖنَن ہُند حال تام زانان۔"
  8,44,"۔تہٕ یاد کٔرِ و ییٚلہِ مقا بلہٕ کہ وقتہٕ خُدا ین تۅہیہِ لُکن ہٕنز ن نظر ن منٛز دُشمن کمٕے ہٲوۍ تہٕ تِہنزن نظر ن منٛز کٔرِ نو توٚہۍ کم کٔرِ تھ پیش،تاکہ یۅسہٕ کتھ سپد ن وا جِنۍ ٲس تتھ کڑِ اللہ تعالیٰ نوٚ ن ، تہٕ ٲخر کار چِھ سٲر ی معا ملات اللہ تعالیٰ سٕے کُن رجوع سپدان ۔ع"
  8,45,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، ییٚلہِ کُنہِ دٔرِس سٍتۍ تُہُند مقا بلہٕ سپدِ تیٚلہِ روٗزِ و ثا بت قد م ، بیٚیہِ کٔرِ یوٗن اللہ تعالیٰ کثر ت سان یاد،تو قع چُھ زِ تۅہیہِ سپد یو کا میٲبی نصیب۔"
  8,46,"۔ بیٚیہِ کٔرِو اللہ تعالیٰ سٕنز تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز اطا عت تہٕ پانہٕ وٲنۍ مَہ تُلِو تنا زعہ تیٚلہِ گژِھہ تۅہیہِ منٛز کمزوٗری پٲدٕ،تہٕ تۅہیہِ وسیٚو پھۅ کھٕے تہٕ صبرس ہیٚیِو کٲم۔﴿یعنی پنٕنۍ جذ با ت تہٕ خوٲہشا ت تھٲوِ و گنڈَس منٛز۔ جلد بٲزی ،گھبرا ہٹ ،خو ف، طمع تہٕ نا منٲسب جو شہِ نِشہِ بٔچِو۔ٹھنڈ دلہٕ سان تہٕ سو نچنہٕ سمجھنہٕ آمتہِ فٲصلہٕ سان کٔرِو کٲم۔خطرات تہٕ مشکلا ت آسن برونٛہہ کنہِ ، تُہٕندۍ قد م گژھن نہٕ نَٹٕنۍ۔اشتعال انگیز مو قع ییٚلہِ پیش یِن ،تمہِ ساعتہٕ گژھن نہٕ تۅہیہِ تِم بے محل حر کت یا اتھہٕ شر کر ناوٕ نۍ۔ ییٚلہِ مصٲبین ہُند حملہ سپدِ، حالات آسن با سان بِگران، تیٚلہِ گژھن نہٕ اضطراب کِس حا لتس منٛز تۅہیہِ ہو ش و حوا س ڈلٕنۍ۔مقصد حٲصل کر نہٕ کہ شو قہٕ سٍتۍ بے قرار سپدِ تھ،یا کانٛہہ نیم پختہٕ تدبیر سرسری نظرِ منٛز کار گروُ چِھتھ گژھن نہٕ تُہٕندۍ ارادٕہ جلد با زی سٍتۍ مغلوب سپدٕ نۍ، تہٕ ہرگاہ کُنہِ وِزِ دُنیٲوی فٲیدہ تہٕ منا فع بیٚیہِ نفس کہ لذ تٕکۍ تر غیبات آسن تۅہیہِ پا نس کُن پھساوان ، تِہندِس مقا بلس منٛز تہِ گژِھہ نہٕ تُہُند نفس تیوٗتاہ کمز ور آسُن زِ بے اختیار گٔژِھو تِمن کُن ۔ یِم تمام مفہو م چِھ صرف  صبر  لفظس منٛز پوٗشیدہ، تہٕ اللہ تعالیٰ چُھ فر ماوان زِ یِم لُکھ یِمو تمام حیثیتو کِنۍ صٲبر آسن ، میو ن تٲیید چُھ تِمنٕے حٲصل﴾یقیناً چُھ اللہ تعالیٰ صبر کر ن والیٚن سٍتۍ۔"
  8,47,"۔تہٕ تِمن لُکن ہٕندۍ ہِوۍ رنگ ڈھنگ مہ کٔرِ و اختیار یِم پننیٚو گھر و منٛزٕ ہیٚٹہٕ دِوان تہٕ لُکن پنٕنۍ شان ہاوان ہاوان درٛا ے تہٕ یِہٕنز رٔوِش یہِ چھےٚ ، زِ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ چِھ رُکا وان، یِکینژھاہ تِم کران چِھ سُہ چُھنہٕ اللہ تعالیٰ سٕندِ گرِ فتہٕ نیٚبر۔"
  8,48,"ذرا کٔرِ تو خیا ل تمہِ وقتُک ییٚلہِ شیطا نن تِمن لُکن ہٕندۍ کر توٗت تِہنزن نظر ن منٛز خۅشنمابنٲوِتھ ہٲوِمٕتۍ ٲسۍ تہٕ تِمن اوسُن ووٚنمُت ا زہیٚکہِ نہٕ تۅہیہِ پٮ۪ٹھ کانٛہہ غٲلب یِتھ، بیٚیہِ یہِ زِ بہٕ چُھس تۅہیہِ سٍتۍ ،ییٚلہِ دۅ شو ے دٔرۍ اکھ أکِس برونٛہہ کُن آے، پتہٕ ژوٚل سُہ پوٚت کھو ر ی تہٕ لوٚ گ وَننہٕ زِ بہٕ چُھس تۅہیہِ نِشہِ الگ ،بہٕ چُھس تِکینژھاہ وُچھان  یِنہٕ توٚہۍوُچھان چِھو، بہٕ چُھس اللہ تعالیٰ ہَس کھۅژان،تہٕ اللہ تعالیٰ چُھ سٮ۪ٹھاہ سخت سزا دِنہٕ وول ۔ع"
  8,49,"۔ییٚلہِ زن منا فق تہٕ تِم سٲر ی لُکھ یِہندٮ۪ن دِلن بیمٲرۍ چھےٚلٔجمٕژ، وَنان ٲسۍ زِ یِم لُکھ چِھ یِہِندۍ دیٖنن کٔرِ مٕتۍ دیوا نگی منٛز مبتلا ﴿یعنی مد ینٕکۍ منا فق تہٕ تِم سٲر ی لُکھ یِم دنیا پر ستی تہٕ خُدا یس نِشہِ غفلت کِس مر ضس منٛز گرفتار ٲسۍ ،یہِ وُچِھتھ زِ مُسلمانن ہٕنز مۅ چِھہ یٲژ بے سر وسامان جماعت چھےٚ قر یش ہِوِ س زبردست طا قس سٍتۍ ٹکرا و نہِ گژھان ،ٲسۍ پانہٕ وٲنۍ ونان زِ یِم لُکھ چِھ پننِس دینی جو شس منٛز دیوا نہٕ گٔمٕتۍ۔یتھ معر کس منٛز چھےٚ یِہٕنز تبٲہی یقینی  ،مگر أمۍنبی صلی اللہ  علیہ وسلمن چُھ یِمن تِتھہِ جادِ یُک پھۅ کھ دِ یتمُت زِ یِہٕنز عقل چھےٚ دیوا نہٕ گٔمژ تہٕ وُچھا ن وُچھا ن چِھ یِم موت کِس دہا نس کُن پکا ن ﴾ حالانکہ اگر کا نٛہہ خُدا یس پٮ۪ٹھ بھر وسہٕ کرِ تیٚلہِ چُھ پٔزۍ پٲٹھۍ اللہ تعالیٰ سٮ۪ٹھاہ زبردست تہٕ دا نا ۔"
  8,50,"۔کا ش توٚہۍ ہیٚکۍ ہِو سۅ حالت وُچِھتھ ییٚلہِ فر شتہٕ ٲسۍ قتل گٔمٕتیٚن کٲفر ن ہٕندۍ رو ح قبض کرا ن، تِم ٲسۍ تِہند ٮ۪ن بُتھیٚن تہٕ تِہند ٮ۪ن شانَن پٮ۪ٹھ ضر ب لگا وان لگا وان پکا ن تہٕ ونان ٲسۍ، رٔٹِو وُچِھو وۅ نۍ دَزنُک سزا،"
  8,51,"۔یہِ چُھ جزا ییٚمیُک سامان تُہند یو پننیو اَتھو اوس گۅڈ ے مہیا کٔرِ تھ تھو و مُت،نَتہٕ چُھنہٕ اللہ تعالیٰ پننیٚن بند ن ظُلم کر ن وول ۔"
  8,52,"۔یہِ معا ملہ آو یِمن سٍتۍ تِتھے پٲٹھۍ پیش یِتھہٕ پٲٹھۍ آلِ فر عو ن تہٕ تِمن بروٗنٹھمیٚن دوٚ یِمیٚن لُکن سٍتۍ  پیش چُھ یِوان روٗد مُت تِکیازِ تِمو کوٚر اللہ تعالیٰ سٕندۍ آیات ماننہٕ نِشہِ انکار تہٕ خُدا ین رٔٹۍ تِم تِہند ٮ۪ن گُنا ہن پٮ۪ٹھ۔ اللہ تعالیٰ چُھ قوّت تھاوان بیٚیہِ چُھ سخت سزا دِنہٕ وول۔"
  8,53,"۔یہِ سپُد اللہ تعالیٰ سٕندِس تتھ سُنّتس مطٲبق زِ سُہ چُھنہٕ کُنہِ نعمتس یۅسہٕ تٔمۍ کُنہِ قو مس عطا آسہِ کٔر مٕژ توٚت تام بد لا وان، یوٚت تام نہٕ سُہ قو م خۅ د پنُن طر زِ عمل چُھ بد لاوان، اللہ تعالیٰ چُھ سورُے کینٛہہ بوزن وول تہٕ زانن وول ۔"
  8,54,"۔آلِ فرعو نس تہٕ تِمن بروٗنٹھمیٚن قو من سٍتۍ یِکینژھاہ پیش آو سُہ اوس أتھۍ ضٲبطس مطا بق ، تِمو پھِیرُ پننِس ربّ سٕندٮ۪ن آیا تن بُتھ، تمہِ پتہٕ کٔرۍ اَسہِ تِم تِہند ٮ۪ن گنا ہن ہٕندِس پا داشس منٛز ہلا ک تہٕ آلِ فر عو ن کوٚر غر ق، یِم سٲر ۍ ٲسۍ ظٲ لِم لُکھ۔"
  8,55,"۔پٔزۍ پٲٹھۍ چِھ خُدا یس نز دیک زمینس پٮ۪ٹھ پکن والیو لُکو منٛزٕ سارِوٕے کھۅتہٕ بدتر تِم لُکھ یِمو حق ماننہٕ نِشہِ انکار کوٚر ، پتہٕ چِھنہٕ تِم کُنہِ پٲٹھۍ سُہ قبو ل کر نہٕ خٲطرٕ تیار ۔"
  8,56,"۔﴿خصو صاً ﴾یِمو منٛزٕ تِم لُکھ یِمن سٍتۍ تۅہیہِ معا ہدہ کوٚرُو،پتہٕ چِھ تِم پرٛتھ مو قعس پٮ۪ٹھ سُہ پُھٹراوان تہٕ خُدٲے خو فس چِھنہٕ کھۅژان۔﴿یتھ جایہِ چُھ خا ص طور یہو دٮ۪ن کُن اشارہ یِمن سٍتۍ نبی صلی اللہ علیہ وسلمن معا ہد ہ اوس تہٕ امہِ با وجود ٲسۍ تِم حضور صلی اللہ علیہ وسلمن تہٕ مُسلمانن ہٕندِس مخا لفتس منٛز سر گر م ، جنگِ بدرٕ پتے لوگ تِمو انتقام ہیٚنہٕ خٲطرٕ قر یشن ہٕس دِیُن ﴾"
  8,57,"۔لہٰذا اگر یِم لُکھ تۅہیہِ لڈ ایہِ منٛز سمکھن تیٚلہِ ہیٚیِو یِمن تِژھ خبر زِ یِمن پتہٕ یِم لُکھ یِژھ رٔوش اختیار کر ن وٲلۍ آسن تِمن گژِھہ پھرٛ ٹھ گژُھن۔﴿ اَمِیُک مطلب چُھ یہِ زِ اگر کُنہِ قو مس سٍتۍ سو ن معا ہد ہ آسہِ تہٕ پتہٕ نِیہِ سُہ پننیٚن معا ندا نہٕ ذمہٕ دٲرِین پسِ پشت ترٛ ٲوِتھ اَسہِ خلا ف کُنہِ جنگس منٛز حصّہٕ ،تیٚلہِ گژھو أسۍ تہِ پننیٚو اخلٲقی ذمہٕ دٲرِ یو نِشہِ سبکدوش تہٕ اسہِ آسہِ حق زِ تس سٍتۍ کر و جنگ ۔بیٚیہِ اگر کُنہِ قو مس سٍتۍ اسہِ لڑٲے چلا ن آسہِ تہٕ أسۍ وُچَھو زِ دشمنس سٍتۍ چِھ تِتھہِ اکہِ قو مٕکۍ نفرتہِ جنگس منٛز شر یک یس سٍتۍ اَسہِ معا ہدہ چُھ تیٚلہِ کرَو نہٕ أسۍ تِم قتل کر نس منٛز تہٕ تِمن سٍتۍ دشمن سُند ہیوٗ سلو ک کر نس منٛز ہر گز تہِ ژیٚڈ﴾ تو قع چُھ زِ بد عہد ن ہٕندِ اَمہِ انجا مہٕ نِشہِ رٹن تِم ہیٚن۔"
  8,58,"۔تہٕ اگر زانٛہہ تۅہیہِ کٲنٛسہِ قو مس نِشہِ خیا نتُک اندیشہ آسیٚو،تیٚلہِ چھٔکِو تٔمۍ سُند معا ہد ہ عَلانیہ تس برونٛہہ کُن ۔ ﴿یعنی سُہ کٔرِ یوٗن صا ف پٲٹھۍ خبردار زِ سو ن تہٕ تُہُند معا ہد ہ روٗد نہٕ وۅ نۍ با قی ، تِکیازِ توٚہۍ چِھو عہدٕ چ خلا ف ور زی کران﴾ یقیناً چُھنہٕ اللہ تعالیٰ خیا نت کر ن والیٚن پسند کران ۔ ع۔"
  8,59,"۔منکر ینِ حق مَہ روٗزِ ن اتھ غلط فہمی منٛز زِ تِمو نِیہِ بٲزۍ،یقیناً ہیٚکن نہٕ تِم اَسہِ ہا ر نٲوِ تھ ۔"
  8,60,"۔تہٕ توٚہۍ لُکھ ، یوٚت تام تۅہیہِ پِلہِ ، زیادہ کھۅتہٕ زیادہ طا قت تہٕ تیار رو زن وٲلۍ رٔچِھتھ گُر ۍ تھٲوِ یوٗکھ تِہندِ مقا بلہٕ  خٲطردستیا ب ۔﴿مطلب چُھ یہِ زِ تۅہیہِ نِشہِ گژِھہ  سا مانِ جنگ تہٕ اکھ مستقل فو ج پرٛتھ وقتہٕ تیا ر آسُن تا کہ بو قتِ ضرورت ہیٚکِو فوراً جنگی کار وٲیی کٔرِ تھ ۔یہِ گژِھہ نہٕ آسُن زِ کلس پٮ۪ٹھ خطرہ وٲتِتھ لٲگِو گھبرا ہٹس منٛز جلد ی جلد ی رضا کار ، اسلحہ تہٕ رَسدُک سامان جمع کر نہِ تہٕ اَتھ دورا ن زِ یہِ تیا ر ی آسہِ اندواتَنے تہٕ دُشمنَن آسہِ پنٕنۍ کٲم مۅ کلٲومٕژ﴾ تا کہ امہِ ذر یعہ کٔرِ و یوٗکھ اللہ تعالیٰ سٕندۍ تہٕ پنٕنۍ دشمن تہٕ تِم با قی دشمن خو ف زدٕہ، یِم نہٕ توٚہۍ زانان چھوٗکھ مگر اللہ تعالیٰ چُھکھ زانان،اللہ تعالیٰ سٕنزِ وَتہِ منٛز یِکینژھاہ توٚہۍ خر چ کٔرِ و ، تَمِیُک پوٗرٕ پوٗرٕ بد لہٕ یِیہِٰ تۅہیہِ کُن پھِر نہٕ ،تہٕ تۅہیہِ سٍتۍ سپد نہٕ ہر گز ظُلم۔"
  8,61,"۔ تہٕ اے نبی صلی اللہ علیہ وسلم ،اگر دشمن صلح تہٕ سلامتی کُن مٲیل آسن تیٚلہِ سپدِ و توٚہۍ تہِ امہِ خٲطرٕ آمادٕہ تہٕ خُدا یس پٮ۪ٹھ کٔرِ و بھر وسہٕ ، پٔزۍ پٲٹھۍ چُھ سُے سورُے کینٛہہ بوزن وول تہٕ زانن وول ۔"
  8,62,"۔تہٕ اگر تِمن دغا بٲزی ہٕنز نیت آسہِ تیٚلہِ چُھ  تُہُندِ خٲطر اللہ تعالیٰ کٲفی ،سُہ چھُ ییٚمۍ پننہِ مددٕ سٍتۍ تہٕ مو منن ہٕندِ ذریعہ تُہُند تٲیید کوٚر ۔"
  8,63,"۔تہٕ مو منن ہٕندۍ دِل جوروِن اکھ أکِس سٍتۍ ،اگر رو ے زمینٕچ سٲرٕ ے دو لت تہِ کٔرۍ ہِو خر چ تِہِندۍ دل ہیٚکۍ ہِو نہٕ جوروِتھ مگر سُہ چُھ اللہ تعالیٰ ییٚمۍ یِہِندۍ دل جورٕ وۍ، یقیناً چُھ سُہ سٮ۪ٹھاہ زبردست بیٚیہِ حکمت وول ۔"
  8,64,"۔اے نبی صلی اللہ علیہ وسلم، تُہندِ خٲطرٕ چُھ بس اللہ تعالیٰ کٲفی، بیٚیہِ تُہٕندٮ۪ن پیر و کا ر اہلِ ایمانن خٲطرٕ ۔ع"
  8,65,"۔اے نبی صلی اللہ علیہ وسلم ، مو من اُبھٲرِیوٗکھ جنگس پٮ۪ٹھ۔اگر تۅہیہِ منٛزٕ وُہ نفر صٲبر آسن تِم یِن دۅ ن ہَتھن پٮ۪ٹھ غٲلب تہٕ اگر ہَتھ  نفر یِتھۍ آسن، تِم روزن منکر ینِ حقو منٛزٕ سا سس نفر س پٮ۪ٹھ گوٚ بۍ تِکیازِ تِم چِھ تِتھۍ لُکھ یِمن سمجھ چُھنہٕ۔﴿أزِ کِس اِصطلا حس  منٛز یتھ چیز س قوّتِ معنو ی یا قوّتِ اخلٲقی ﴿Moral﴾ وَنان چِھ ، اللہ تعالیٰ چُھ أتھۍ چیزس فقہ وفہم بیٚیہِ مانُن زانُن ونان۔یَس شخصس پننہِ مقصدُک صحیح شعورآسہِ تہٕ سُہ آسہِ ٹھنڈٕ دِلہٕ سونچِتھ سمجھتھ امہِ موجوٗب لڑا ن زِ ییٚمہِ خٲطرٕ سُہ پنُن زُو دَاوس چُھ لاگنہِ آمُت، سُہ چُھ تٔمۍ سٕنزِ انفرٲدی زند گی کھۅ تہٕ قٍمتی تہٕ امہِ کہ ضا یع سپد نہٕ پتہٕ چُھ زندٕہ روزُن بے قٍمت ،سُہ چُھ بے شعو ری سان لڑ ن وٲلِس انسان سٕندِ کھۅتہٕ کینٛہہ گۅ نہٕ زیاد ہ طا قت تھاوان، اگر چہِ جسمٲنی طا قتس منٛز دۅ شوٕ نۍ در میان کانٛہہ فر ق آسہِ نہٕ ﴾"
  8,66,"۔اچھا، وۅ نۍ کوٚر خُدا ین تُہُند بو ر کم۔ تہٕ تس لوٚگ پے زِ وُنہِ چھےٚ تۅہیہِ منٛز کمزوٗری،لہٰذا ، اگر تۅہیہِ ہَتھ نفرصٲبر آسن۔تِم یِن دۅ ن ہَتھن پٮ۪ٹھ غٲلب تہٕ ﴿اگر ﴾ ساس آسن یِتھی، تِم یِن دۅ ن ساسن پٮ۪ٹھ اللہ تعالیٰ سٕندِ حکمہٕ غٲلب ﴿اَمِیُک مطلب چُھنہٕ یہِ زِ گۅڈٕ ہ ٲس اَکِچ تہٕ دَہن ہٕنز نسبت تہٕ وۅ نۍ چھےٚ چو نکہ تۅہیہِ منٛز کمزور ی آمٕژ اَمہِ موجوٗب چھےٚ اَکِچ تہٕ دۅ ن ہٕنز نسبت قٲیِم کر نہٕ آمٕژ۔بلکہ چُھ اَمِیُک صحیح مطلب یہِ زِ اصو لی تہٕ معیٲری حیثیت چھےٚ اہلِ ایمانن تہٕ کفا ر ن در میان اَکِچ تہٕ دَہن ہٕنزٕ ے نسبت ،مگر چو نکہ وُنہِ چَھنہٕ تۅہیہِ لُکن ہٕنز اخلٲقی تر بیت مکمل سپٕز مٕژ، تہٕ وُنہِ چُھنہٕ تُہندِ سو نچنُک پیمانہٕ بلو غ کِس حدس ووتمُت،امہِ موجو ب چُھ تۅہیہِ گۅڈ ے تُہٕندِ کم آسنہٕ با وجود یہِ مطا لبہٕ کر نہٕ یِوان زِ پننہِ کھۅتہٕ دۅ گنہٕ  طا قتس سٍتۍ ٹکرا و نس منٛز گٔژِھو نہٕ توٚہۍ ہر اسہٕ کرٕ نۍ ۔ یہِ کتھ گژِھہ مدِ نظر روزٕ نۍ زِ یہِ اِرشاد چُھ، 2ھ ہُند ییٚلہِ زَن مسلمانو منٛزٕ واریاہ لُکھ وُنہِ تازٕہ تازے اسلامَس منٛز دٲخل ٲسۍ سپٕدۍ مٕتۍ تہٕ تِہٕنز تر بیت ٲس وُنہِ ابتدٲیی حالتس منٛز﴾"
  8,67,"۔ کٲنٛسہِ نبیس چُھنہٕ یہِ شوٗبان زِ تس نِشہِ آسن قٍدۍ،یوٚت تام نہ سُہ زمینس اندر دشمنن ٹھیک پٲٹھۍ ختم کرِ ،توٚہۍ لُکھ چِھو دُنیاہٕکۍ فٲید ہ یژھان، حالانکہ خُدا یس پیشِ نظر چُھ ٲخرت،تہٕ اللہ تعالیٰ چُھ غٲلب تہٕ حکمت وول ۔"
  8,68,"۔اگراللہ تعالیٰ سُند تحر یر گۅڈ ے آسِہے نہٕ لیٚکھنہٕ آمُت،تیٚلہِ یِکینژھاہ تۅہیہِ لُکو نیوٗمُت چُھو تمہِ کِس پاداشس منٛز یِیہِ ہیٚو تۅہیہِ بوٚڈ سزا دِنہ۔"
  8,69,"۔لھٰذا یِکینژھاہ مال تۅہیہِ حٲصل چُھو کوٚر مُت ،سُہ کھیِیِو تِکیازِ سُہ چُھ حلال تہٕ پاک۔بیٚیہِ روٗزِ و خُدا یس کھۅژان۔﴿جنگِ بدر برونٛہہ یِم ابتدٲیی ہدا یات سورۂ محمدس منٛز دِنہٕ ٲسۍ آمٕتۍ، تِمن منٛز اوس جنگی قٍد یو نِشہِ فِد یہِ وصو ل کر نُک اجا زت دِنہٕ آمُت۔البتہ اوس اتھ سٍتۍ یہِ شر ط لگا و نہٕ آمُت زِ گۅڈٕ گژِھہ دشمن سُند طا قت اصل پٲٹھۍ یُن ختم کر نہٕ پتہٕ گژِھہ قٍدۍ رٹنٕچ فکر یِنۍ کر نہٕ ، اَمہِ فر ما نہٕ مطٲبق یِم قٍدۍ مسلمانَو بَدرس منٛز گرفتار کٔرۍ تہٕ پتہٕ یُس تِمن نِشہِ فدیہِ وصو ل کوٚرُکھ،سُہ اوس اجاز تہٕ مطٲ بق مگر غلطی سپٕز یہِ زِ دشمن سُند طا قت ختم کر نُک  یُس شر ط مقد م تھاو نہٕ اوس آمُت ،سُہ پوٗرٕ کر نہٕ برونٛٹھے لٔگۍ مُسلمانن دشمنن قٲد کرنس تہٕ مالِ غنیمت جمع کر نس کُن ۔یٔہے کتھ کٔر خُدا ین نا پسند ،تِکیازِ اگر یہِ کر نہٕ یِیہِ ہے نہٕ تہٕ مُسلمان کر ہن کفا ر ن ہُند پیچھا ،تیٚلہِ یِیہِ ہے أتھۍ مو قعس پٮ۪ٹھ قر یشن ہُند طا قت پھُٹرا و نہٕ ﴾ یقیناً چُھ اللہ تعالیٰ در گزر کر ن وول تہٕ رحم فر ماون وول ۔ ع"
  8,70,"۔ اے نبی صلی اللہ علیہ وسلم،تۅہیہِ لُکن ہٕندِس قبضس منٛز یِم قٍدۍ چِھ تِمن ؤنِو زِ اگر خُدا یس پے لوٚگ زِ تُہندِس دِلس منٛز چُھ کینٛہہ خیر،تیٚلہِ دِیَو سُہ تۅہیہِ تمہِ کھۅتہٕ تہِ کھٔسِتھ یِکینژھاہ تۅہیہِ ہیٚنہٕ چُھو آمُت تہٕ تُہندۍ خطا کرِ معاف، اللہ تعالیٰ چُھ در گزر کر ن وول تہٕ رحم فر ماو ن وول ۔"
  8,71,"۔البتہ اگر تِم تۅہیہِ سٍتۍ خیا نتُک ارادٕہ چِھ تھاوان، تیٚلہِ چُھ تِمو امہِ برونٛہہ خُدا یس سٍتۍ خیا نت کوٚر مُت ، چنا نچہِ دِیُت خُدا ین تمہِ کُے سزا تِمن زِ تِم آے تُہندِس قا بوَس منٛز، اللہ تعالیٰ چُھ سورُے زانان بیٚیہِ چُھ حکمت وول۔"
  8,72,"۔یِمو لُکو ایمان قبول کوٚر تہٕ ہجر ت کٔرٕ کھ تہٕ اللہ تعالیٰ سٕنزِ وَتہِ منٛز لڑٲوِ کھ پنٕنۍ جان تہٕ پنٕنۍ مال خر چٲوِکھ،تہٕ یِمو لُکو ہجر ت کر ن والیٚن جاے دِژ،بیٚیہِ کوٚرُکھ تِمن مدد،تِمے چِھ در اصل  اکھ أکۍ سٕندۍ ؤلۍ ﴿مددگار﴾ روٗدۍ تِم لُکھ یِمو ایمان اوٚ ن مگر ہجر ت کٔرِ تھ گٔے نہٕ ﴿ دارُلاسلامس منٛز﴾ تیٚلہِ چُھنہٕ تۅہیہِ یِمن سٍتۍ ولا یتُک ﴿مدد کر نُک ﴾ کانٛہہ تعلق  یوٚت تام نہٕ تِم ہجر ت کٔرِ تھ یِن ۔﴿ ولا یت  لفظ چُھ عر بی زبٲنۍ منٛز حما یت ، نصر ت مدد گٲر ی ،ڈُکھِس آسُن ،دو ستی ، قرا بت ،سر پرستی تہٕ أتھۍ سٍتۍ رَلہِ وٕ نیٚن مفہو من خٲطرٕ وَننہٕ یِوان ۔ ییٚمہِ آیت کِس سیا قس تہٕ سبا قس منٛز چُھ ٹا کارٕ ہ پٲٹھۍ مُراد سُہ رشتہٕ یُس اکہِ ریا ستُک پننیٚن شہر یَن سٍتۍ ،تہٕ شہرِ ین ہُند پننِس ریا ستس سٍتۍ تہٕ شہر تہٕ شہرِ ین در میان پانہٕ وٲنۍ چُھ آسان۔لھٰذا چھےٚ یہِ آیت دستو ر ی تہٕ سیٲسی ولا یتس اسلامی ریا ست کیٚن ارضی حد و ن تام محد و د کران تہٕ یِمو حدودَو نِشہِ یِم مُسلمان نیبر چِھ تِمن چھےٚ امہِ مخصو ص رشتہٕ نِشہِ خٲر ج قرار دِوان۔امہِ عدمِ ولا یتکۍ قا نو نی نتیجہِ چِھ سٮ۪ٹھاہ وسیع یِہٕندۍ تفصیلات  بیان کر نُک مو قع یتھ جایہِ چُھنہٕ ﴾ آ، اگر تِم دین کِس معا ملس منٛز تۅہیہِ مدد منگن تیٚلہِ چُھ تِمن مدد کرُن تۅہیہِ پٮ۪ٹھ فر ض مگر کُنہِ تِتھِس قو مس خلا ف نہٕ کینٛہہ یس سٍتۍ تۅہیہِ معا ہدہ آسہِ ﴿ پیٹھِمِس حصّس منٛز چِھ دارُالاسلام نِشہِ نیبر روزن وٲلۍ مسلمان  سیٲسی ولا یت کہ رشتہٕ نِشہِ خٲرج قرار  دِنہٕ آمٕتۍ۔وۅ نۍ چھےٚ یہِ آیت اَتھ وضا حت کران زِ امہِ رشتہٕ نِشہِ خٲر ج سپد نہٕ با وجود چِھنہٕ تِم  دینی اُخوّت کہ رشتہٕ نِشہِ خٲر ج کینٛہہ۔ اگر کُنہِ جایہِ یِمن پٮ۪ٹھ ظُلم آسہِ سپدان، تہٕ تِم منگن اسلٲمی برداری ہٕندِس تعلق کِس بنیا دس پٮ۪ٹھ دارُلاسلام کِس حکو متس تہٕ امہِ کیٚن با شند ن مدد، تیٚلہِ چُھ تِہُند فر ض زِ پننیٚن مظلو م با ین کٔرِ ن مدد۔ مگر امہِ پتہٕ چُھ مزید وضا حت کٔرِ تھ فر ما و نہٕ آمُت زِ یِمن دینی با ین ہٕندِ مددُک فر یضہٕ یِیہِ نہٕ اَنہِ کھلہِ انجام دِنہٕ ، بلکہ یِیہِ بین الا قوامی ذمہ دٲرِ ین تہٕ اخلٲقی حدودن ہُند پا س و لحا ظ تھٲوِ تھٕے انجام دِنہٕ۔ اگر ظُلم کر ن وٲلِس قو مس سٍتۍ دارُلاسلامٕکۍ معا ہد انہٕ تعلقات آسن، تیٚلہِ یِیہِ نہٕ اتھ صوٗرتس منٛز مظلو م مُسلمانن کانٛہہ تِیُتھ مدد کر نہٕ یُس معا ہد ن ہٕنز ن اخلٲقی ذمہ دٲرِین خلا ف آسہِ ﴾ یِکینژھاہ توٚہۍ کران چِھو اللہ تعالیٰ چُھ تتھ وُچھان۔"
  8,73,"۔یِم لُکھ منکرِ حق چِھ ، تِم چِھ اکھ أکۍ سٕنز حما یت کران،اگر توٚہۍ یہِ کٔرِ و نہٕ تیٚلہِ سپدِ زمینس اندر فتنہٕ تہٕ بوٚڈ فساد پٲدٕ۔﴿یعنی اگر دارُلاسلامٕکۍ مُسلمان اکھ أکۍ سٕندۍ  ؤلی  بنَن نہٕ ، تہٕ اگر ہجرت کٔرِ تھ دارُالسلامس منٛز نَہ یِنہٕ وٲلیٚن تہٕ دارُلکفرس منٛز روزن والیٚن مُسلمانن دارُالسلامٕکۍ مُسلمان پننہِ سیٲسۍ ولا یت نِشہِ خٲر ج سمجھن نہٕ، تہٕ اگر نیٚبرِ میٚن مُسلمانن ہٕندِس مدد منگنس پٮ۪ٹھ  تِمن مدد یِیہِ نہٕ کر نہٕ ، تہٕ اگر سٍتۍ  سٍتۍ تمہِ قا نو نٕچ پا بند ی تہِ یِیہِ نہٕ کر نہٕ زِ یتھ قو مَس سٍتۍ اسلٲمی ریا ستُک معا ہدٕہ آسہِ تَتھ خلا ف یِیہِ نہٕ مسلمانن مدد کر نہٕ، تہٕ اگر مسلمان کر ن نہٕ کٲفر ن سٍتۍ موالاتُک تعلق ختم ، تیٚلہِ گژِھہ زمینس پٮ۪ٹھ بوٚڈ فتنہٕ تہٕ فساد برپا۔﴾"
  8,74,"۔یِمو لُکو ایمان اوٚ ن تہٕ یِمو اللہ تعالیٰ سٕنزِ وَتہِ منٛز گھر با ر ترٲوۍ تہٕ جدوجہد کٔرٕ کھ۔تہٕ یِمو پنا ہ دِیُت تہٕ مدد کوٚ رُکھ۔ تِمَے چِھ پٔزۍ مومن تِہندِ خٲطرٕ چُھ خطا ہو نِشہِ در گز ر تہٕ بہتر ین رز ق ۔"
  8,75,"۔ تہٕ یِمو لُکو پتہٕ اوٚ ن ایمان تہٕ آے ہجر ت کٔرِ تھ، تہٕ تۅہیہِ سٍتۍ رٔلِتھ لٔگۍجدوجہد کر نہِ ، تِم تہِ چِھ تۅ ہی منٛز شٲمل، اللہ تعالیٰ سٕنزِ کتا بہِ منٛز چِھ خو نُک رشتہٕ تھا و ن وٲلۍ اکھ أکۍ سٕندۍ زیادہ حقدار۔ یعنی وراثت سپدِنہٕ اسلامی برادری ہِندِس بنیا دس پٮ۪ٹھ بلکہ سپدِ رشتہٕ دٲر ی ہٕندِس بنیا دس پٮ۪ٹھ تقسیم۔تہٕ امہِ حُکمٕچ تشر یح چُھ نبی صلی اللہ علیہ وسلمن ہُند یہِ حکم کران زِ صر ف آسن مسلمان رشتہٕ دارٕے اکھ أکۍ سٕندۍ وٲرث۔مُسلمان آسہِ نہٕ کٲنٛسہِ سُند یا کٲفر آسہِ نہٕ کٲنٛسہِ مُسلمان سُند وٲرث کینٛہہ﴾ یقیناً چُھ اللہ تعالیٰ پرٛتھ چیز س زانان۔ ع"
