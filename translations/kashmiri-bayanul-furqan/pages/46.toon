quran[35]{c,v,t}:
  46,1,"۔ ح۔م۔"
  46,2,"۔ ییٚمہِ کتا بہِ ہُند نزو ل چُھ اللہ تعالیٰ سٕندِ طر فہٕ یُس غٲلب تہٕ حکمت وول چُھ۔"
  46,3,"۔اسہِ چھےٚ زمین تہٕ آسمان تہٕ تِم سٲری چیز یِم تِمن در میان چِھ بر حق تہٕ اکہِ خا ص وقتہٕ کہ تعیّن سان پٲدٕ کٔرِمٕتۍ۔مگر یِم کٲفر لُکھ چِھ تَمہِ حقیقت نِشہِ روے پھِرِتھ ییٚمہِ نِشہِ یِم با خبر چِھ کر نہٕ آمٕتۍ۔"
  46,4,"۔اے نبی صلی اللہ علیہ وسلم ، یِمن ؤنِو،  زانٛہہ چُھو تۅہیہِ أچھ مٕژ رٲوِتھ تہِ وُچھمُت زِ تِمہٕ ہستی چھےٚ کیا، یِمن توٚہۍ خُداے ترٲوِتھ ناد چِھو دِوان؟ مےٚ ہٲوِ تَو زمینس منٛز کیا چُھ تِمو پٲدٕ کوٚرمُت؟ کِنہٕ آسمانن ہٕندِس تخلیقس تہٕ تد بیرس منٛز چُھ تِہُند کانٛہہ حصّہٕ؟ أنۍ تَو تیٚلہِ ییٚمہِ برونٛہہ آمژِ کُنہِ کتا بہِ ہُند یا علمُک کانٛہہ پٔتِم حصّہٕ ﴿یِمن عقیدن ہٕندِس ثبوتس منٛز ﴾ اگر تۅہیہِ نِشہِ آسہِ ، اگر توٚہۍ پٔزِیٲرۍ چِھو۔"
  46,5,"۔ٲخرکُس آسہِ تس شخصہٕ سٕندِ کھۅتہٕ ڈوٚلمُت انسان یُس اللہ تعالیٰ ہَس ترٲوِتھ تِمن لایہِ ناد، یِم قیا متس تام تس جواب ہیٚکن نہٕ دِتھ،﴿جواب دِنہٕ نِشہِ چُھ مُراد کٲنٛسہِ ہٕندِس در خوا ستس پٮ۪ٹھ فٲصلہٕ صٲدٕر کرُن۔مطلب چُھ یہِ زِ یِمن معبوٗد ن نِشہِ چِھنہٕ تِم اختیار ے یِہندِس بُنیا دس پٮ۪ٹھ یِم تِہندٮ۪ن دُعا ہَن تہٕ در خواستن پٮ۪ٹھ کانٛہہ فٲصلہٕ ہیٚکن صٲدر کٔرِتھ۔﴾ بلکہِ چِھ امہِ نِشہِ تہِ بے خبر زِ ناد لاین وٲلۍ چِھ تِمن ناد لایان،"
  46,6,"۔تہٕ ییٚلہِ سٲری انسان جمع یِن کر نہٕ،تمہِ وقتہٕ آسن تِم پننیٚن ناد لا ین والیٚن ہٕندۍ دُشمن، تہٕ تِہندِ س عبا دتس آسن مُنکر۔﴿یعنی تِم ونن صا ف صاف زِ نَہ اوس اسہِ یِمن زانٛہہ ووٚ نمُت زِ توٚہۍ لٲیِو مددٕ خٲطرٕ اَسہِ ناد،أسۍ چِھو تۅہیہِ حا جت روٲیی کر ن وٲلۍ ،تہٕ نَہ چھےٚ اسہِ یہِ خبر زِ یِم ٲسۍ اسہِ ناد لایان ،یِمو چِھ أسۍ پا نے حا جت روا بنٲوِمٕتۍ تہٕ پا نے چُھکھ اسہِ نا د دِیُن لوگمُت۔﴾"
  46,7,"۔یِمن لُکن ییٚلہِ سٲنۍ آیات چِھ صا ف صاف بوزناو نہٕ یِوان، تہٕ حق چُھ یِمن برونٛہہ کُن واتان ، تیٚلہِ چِھ یِم کٲفر لُکھ تتھ متعلق ونان زِ یہِ چُھ ٹا کارٕ ہ جود۔"
  46,8,"۔کیا تِہُند وَنُن چھا یہِ زِ رسولن چُھ یہِ پا نے بنو ومُت؟ یِمن ؤنِو،  اگر مےٚ یہِ پانہٕ چُھ بنو و مُت تیٚلہِ ہیٚکِو نہٕ توٚہۍ مےٚ خُداے سٕنزِ تھپہِ نِشہِ بچٲوِتھ، یِمہٕ کتھہٕ توٚہۍ بناوان چِھو اللہ تعالیٰ چُھ تِمن وارٕ پٲٹھۍ زانان، مےٚ تہٕ تۅہیہِ در میان چُھ سُے گوٲہی دِنہٕ خٲطرٕ کٲفی، تہٕ سُہ چُھ سٮ۪ٹھاہ در گُزر کر ن وول تہٕ رحم کر ن وول ۔﴿یتھ جایہِ چھےٚ یہِ کتھ زٕہ معنی دِوان،اکھ یہِ زِ یہِ اللہ تعالیٰ سُندُے رحم تہٕ تٔمۍ سُندُے در گُزر ییٚمۍ کِںۍ تِٕ لُکھ زمینس اندر شاہ چھِ کھالان یِمن اللہ تعالیٰ سٕندِس کلامس افترا قرار دِنس منٛز کانٛہہ خوف چھُنہٕ،نتہٕ اگر کانٛہہ کانٛہہ بے رحم تہٕ سخت گیر خُداے ییٚمہِ کاینا تُک مٲلِک آسِہے ،تیٚلہِ آسِہے نہٕ یِژٕھ حر کتہٕ کرن والیٚن اکھ شہہ کھٲلِتھ دوٚ یُم شہہ کھا لُن نصیب گژھان۔دوٚ یُم مطلب چُھس یِتہِ زِ اے ظٲلِمو، اگر وُنہِ تہِ یِیِو امہِ ہٹ دھر می نِشہِ با ز تیٚلہِ چُھ خُداےسٕندِ رحمتُک دروازٕہ تُہندِ خٲطرٕ یلہٕ ،تہٕ یِکینژھاہ تۅہیہِ وُنُیستام کوٚر مُت چُھو سُہ ہیٚکہِ معا ف سپدِتھ۔﴾"
  46,9,"۔یِمن ؤنِو ، بہٕ چُھس نہٕ کانٛہہ نوٚو رسُول ، ﴿یعنی یِتھہٕ پٲٹھۍ گۅڈٕ سٲری رسول انسانٕے آسان ٲسۍ ، تہٕ خُدٲیی صفا تن تہٕ اختیاراتن منٛز اوس نہٕ تِہُند کانٛہہ حصّہٕ آسان ، تِیتُھے رسول چُھس بٕتہِ ۔﴾ مےٚ چَھنہٕ پے زِ پگاہ کیا چُھ تۅہیہِ سٍتۍ سپدن وول تہٕ مےٚ سٍتۍ کیا چھُ سپدن وول ،بہٕ چھُس صرف تٔمی  وحی ہٕنزپیروی کران یۅسہٕ مےٚ نِش سوزنہٕ چھےٚ یِوان، تہٕ بہٕ چُھس نہٕ أکِس صا ف صا ف خبردار کر ن وٲلۍ سٕندِ ورٲے بیٚیہِ کِہِنۍ۔"
  46,10,"۔اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو  زانٛہہ سوٗنچوٕ تۅہیہِ زِ اگر یہِ کلا م اللہ تعالیٰ سٕندی طر فہٕ اوس تہٕ تۅہیہِ کوٚرُو اَتھ انکار۔﴿تیٚلہِ کُس انجام آسہِ تُہُند؟﴾ تہٕ أتھۍ ہِوِس أکِس کلا مَس پٮ۪ٹھ چھےٚ بنی اسرٲیلٕکۍ أکۍ گواہن شہا دت تہِ دِژمٕژ۔ تٔمۍ اوٚ ن ایمان تہٕ توٚہۍ روٗدِو پننِس تکبر س منٛزٕ ے۔﴿یتھ جایہِ  چُھنہٕ گواہ نِشہِ مُراد کانٛہہ خا ص شخص کینٛہہ بلکہ چُھ اِسرٲیلُک اکھ عام اِنسان مُراد۔ خُداے سٕندِ اِرشادُک مُدعا چُھ یہِ زِ قرآن مجید یۅسہٕ تعلیم تۅہیہِ برونٛہہ کنہِ پیش چُھ کران،یہِ چُھنہٕ کانٛہہ نوٚو چیز یُس دُنیا ہس منٛز گۅڈ نچہِ لٹہِ تۅہی یوت برونٛہہ کنہِ آسہِ پیش کر نہٕ آمُت، تہٕ توٚہۍ ہیٚکِو یہِ عذر کٔرِ تھ زِ أسۍ کِتھہٕ پٲٹھۍ مانَو یِمہٕ کتھہٕ یِمہٕ انسٲنی زُرِیا تس برونٛہہ کُن آمژے آسہٕ نہٕ۔ییٚمہِ برونٛہہ چِھ یِمے تعلیمات یِتھے پٲٹھۍ وحی ہٕندِ ذریعہ بنی اسرٲیلس برونٛہہ کُن تورات تہٕ دوٚیِمیٚن آسمٲنی کتا بن ہٕنزِ شکلہِ منٛز آمٕتۍ، تہٕ تِہِندۍ أکۍ عام انسانن چِھ یِم مٲنِمٕتۍ۔﴾ یِتھیٚن ظٲلِمن چُھنہٕ اللہ تعالیٰ ہدا یت دِوان۔ع"
  46,11,"۔ یِمو لُکو ماننہٕ نِشہِ انکار چُھ کوٚر مُت تِم چِھ ایمان اَنن والیٚن متعلق ونان زِ اگر یہِ کتا ب مانٕنۍ جان کٲم آسِہے تیٚلہِ ہیکہَن نہٕ یِم لُکھ اتھ کامہِ منٛز اسہِ برونٛہہ گٔژِھتھ۔﴿ تِہُند مطلب اوس زِ قرآنِ مجید س پٮ۪ٹھ چُھ کینژھو نا سمجھ لُکو ایمان اوٚ نمُت ،نَتہٕ اگر یہِ کانٛہہ جان کٲم آسِہے تیٚلہِ کتہِ روزٕ ہن اسہِ ہِوٗۍ دٲنشوَر لُکھ یہِ ما ننہٕ نِشہِ پتھ۔﴾چونکہ تِمو کوٚر نہٕ تَمہِ نِشہِ ہدایت حاصل امہِ مو جو ب وَنن تِم ضروٗر زِ یہِ چُھ پرون اَپُز۔"
  46,12,"۔حالانکہ امہِ برونٛہہ چھےٚ موسیٰ علیہ السلام سٕنز کتا ب رہنما تہٕ رحمت بٔنِتھ آمٕژ، تہٕ یہِ کتا ب چھےٚ تتھ تصدیق کر ن واجِنۍ آمٕژ عر بی زبٲنۍ منٛز، تاکہ ظٲلِمن کرِ خبردار تہٕ نیک رٔوِشہِ پٮ۪ٹھ پکن والیٚن دِیہِ بشارت۔ پٔزِ پٲٹھۍ یِمو لُکو ووٚن زِ اللہ تعالیٰ ہٕے یوت چُھ سون ربّ،پتہٕ روٗدۍ تتھ پٮ۪ٹھ ڈاڈ کٔرِتھ ، تِہندِ خٲطرٕ نہٕ چُھ کانٛہہ خو ف تہٕ نَہ سپدن تِم غمگین۔"
  46,13,"۔یِتھۍ لُکھ چِھ جنّتس منٛز گژھن وٲلۍ، ییٚتہِ تِم ہمیشہِ روزن پننیو تِمو اعما لو ہٕندِ بد لہٕ یِم تِم دُنیا ہس منٛز چِھ روٗدِمٕتۍ کران۔"
  46,14,"۔اَسہِ کوٚر انسانس ہدایت زِ سُہ کٔرِن پننِس مٲلِس ما جہِ سٍتۍ نیک برتاو۔ تٔمۍ سٕنزِ ما جہِ تھو و سُہ تکلیف تُلِتھ پننہِ یٔڈ منٛز،تہٕ تکلیف تُلِتھٕے دِ یتُنَس زَنم ، تہٕ أمۍ سُند حمل تہٕ دۅد تراو نا و نس منٛز لگۍ تٕرٛہ ﴿30﴾ ریٚتھ۔ یوٚت تام سُہ پننِس پوٗرٕ طا قتس ووت، تہٕ گوٚو ژتجی وُہُر، پتہٕ ووٚ ن تٔمۍ  اے میا نہِ ربّہٕ ، مےٚ دِ تو فیق زِ بہٕ کرٕ چا نیٚن تِمن نعمتن ہُند شُکر یِمہٕ ژےٚ مےٚ تہٕ میٲنِس مٲلِس ما جہِ عطا فر ما و یٚتھ، تہٕ تِژھ نیک عمل کرٕ ییٚمہِ سٍتۍ ژٕ رٲضۍ گژھکھ، تہٕ میٲنۍ اولا د بنا وُکھ نیک تہٕ مےٚ دِ سکو ن ، بہٕ چُھس چٲنِس در بارس منٛز توبہٕ کران تہٕ بہٕ چُھس تا بع فر مان﴿ مُسلم ﴾ بندو منٛزٕ ۔"
  46,15,"۔امہِ قسمہٕ کیو لُکو نِشہِ چِھ أسۍ تِہِندۍ بہتر ین اعمال قبول کران ،تہٕ تِہٕنز و بُرٲییو نِشہِ چِھ در گُزر کران۔ یِم سپدن جنتی لُکن منٛز شٲمِل ،تمہِ پَزِ وعدٕہ مطٲبق یُس یِمن سٍتۍ کر نہٕ اوس یِوان۔"
  46,16,"۔تہٕ ییٚمۍ شخصن پننِس مٲلِس ماجہِ ووٚن:  اُف ، تنگ کوٚروٗس بہٕ تۅہیہِ، کیا توٚہۍ چِھوٕ ہ مےٚ یہِ ڈر پا وان زِ بہٕ یِمہٕ مر نہٕ پتہٕ قبرِ منٛزٕ کڑ نہٕ ؟ حا لا نکہ مےٚ برونٛہہ چِھ واریا ہ نسل گُزر یمٕتۍ﴿تِمو منٛزٕ آو نہٕ کانٛہہ قبرِ منٛزٕ ووٚ تِھتھ﴾۔ موج تہٕ مول چُھ خُدایس پناہ منگان تہٕ أمِس چِھ وَنا ن  اے بد نصیب مانتہٕ، اللہ تعالیٰ سُند وعدہ چُھ پوٚز۔"
  46,17,"مگر سُہ چُھ ونان  یِمہٕ چھےٚ سار ے بروٗنٹھمیٚن وقتن ہٕنزٕ دلیلہٕ۔"
  46,18,"۔ یِمے چِھ لُکھ یِمن پٮ۪ٹھ عذا بُک فٲصلہٕ چُھ چسپاں سپُد مُت۔ یِمو برونٛہہ یِم جِنن تہٕ انسانن ہٕندۍ ٹو لہٕ ﴿ اَمہِ قسمٕکۍ ﴾ گُزر یمٕتۍ چِھ تِمنٕے منٛز گژھن یِم تہِ شٲمِل ،بے شک چھِ یِم خسا رس منٛز روزن وٲلۍ لُکھ۔"
  46,19,"۔دۅ شوٕ یو دَر یٚو منٛزٕ چِھ پرٛتھ أکۍ سٕندۍ در جہِ تِہند یو اعما لو ہٕندِ لحا ظہٕ،تاکہ اللہ تعالیٰ دِیہِ یِہندِ کرِ متِیُک پوٗرٕ پوٗرٕ بدلہٕ یِمن،تہٕ یِمن پٮ۪ٹھ یِیہِ نہٕ ہر گز ظُلم کرنہٕ۔"
  46,20,"۔پتہٕ ییٚلہِ یِم کٲفر لُکھ نارس برونٛٹھ کُن أنِتھ کھڑا یِن کرنہٕ، پتہٕ یِیَکھ وَننہٕ ! تۅہیہِ مۅ کلا ویو پننہِ حصّہ چہِ نعمتہٕ پننہِ دُنیا چہ زند گی منٛز تہٕ تِمن تُلُو تۅہیہِ لطف، پس اَز یِیَو تۅہیہِ رُسوا کرن وول عذا ب دِنہٕ، امہِ موجوٗب زِ توٚہۍ ٲسِو زمینس منٛز کُنہِ حق ورٲے تکبُر کران،بیٚیہِ اَمہِ موجوٗب زِ توٚہۍ ٲسِو نا فر مٲنِیہِ کران۔ ع"
  46,21,"۔یِمن بو نٲوِ تَو عاد سٕندِس بٲیِس ﴿ہوٗد علیہ السلام﴾ سُند قصّہٕ، ییٚلہِ تٔمۍ احقا فس منٛز پنُن قو م با خبر کریاو۔ تہٕ یِتھۍ خبردار کر ن وٲلۍ ٲسۍ تس برونٛٹھ تہِ گُزر یمٕتۍ تہٕ امہِ پتہٕ تہِ روٗدۍ یِوان۔زِ خُدایس ورٲے مَہ کٔرِو کٲنٛسہِ ہٕنز بند گی،مےٚ چُھ تُہندِس با رس منٛز اکہِ بڈِ ہولنا ک دۅہ کہ عذابُک اندیشہِ۔"
  46,22,"۔تِمو ووٚ ن  کیا  ژٕچُھکھہٕ اَمہِ موجوب آمُت زِ اَسہِ ڈٲلِتھ کرکھ ژٕ اسہِ سا نیٚو معبوٗدَو نِشہِ ژھیٚنہٕ۔اچھا اَن ژٕ پنُن سُہ عذا ب ییٚمہِ نِشہِ ژٕ اسہِ کھۅژناوان چُھکھ،اگر پٔزِ پٲٹھۍ ژٕ پٔزِ یور چُھکھ۔"
  46,23,"۔تٔمۍ ووٚن زِ  اَمیُک علم چُھ اللہ تعالیٰ سٕے،﴿یعنی امہِ کتھہِ ہُند علم زِ تۅہیہِ پٮ۪ٹھ کر یِیہِ عذا ب سوز نہٕ تہٕ کوٚت تام یِیہِ تۅہیہِ مہلت دِنہٕ ۔﴾تہٕ بہٕ چُھس تۅہیہِ صرف سُہ پیغام واتناوان یُس ہیٚتھ بہٕ سوز نہٕ چُھس آمُت۔ مگر بہٕ چُھس وُچھا ن زِ توٚہۍ لُکھ چِھو جہا لت ورتا وان۔"
  46,24,"۔پتہٕ ییٚلہِ تِمو سُہ عذا ب وُچُھ پننیٚن وادِ یَن کُن یِوان، پتہٕ لوگُکھ وَنُنیہِ چُھ اوٚ بُر یُس اَسہِ سٲرا ب کرِ ۔ نَہ،بلکہ چُھ یہِ سُے چیز ییٚمہِ خٲطرٕ توٚہۍ با نبٕر ٲسِو کران۔﴿یتھ جایہِ چَھنہٕ امہِ کتھہِ ہٕنز وضا حت زِ تِمن کٔمۍ دِیُت یہِ جواب۔کلا م کہ اندازٕہ نِشہِ چُھ پٲنۍ پا نے یہِ نَنا ن زِ یہِ اوس سُہ جوا ب یُس اصلی صورتِ حالن تِمن عملاً دِیُت۔تِم ٲسۍ سمجھان زِ یہِ چُھ اوٚبُر یُس تِہنز ن وادِ یَن چُھ سٲراب کر نہِ آمُت تہٕ حقیقتس منٛز اوس سُہ واوٕ طوفان یُس تِمن تباہ تہٕ برباد کر نہٕ مۅکھہٕ برونٛہہ اوس پکان۔﴾ یہِ چُھ واوٕ طوفا ن یتھ منٛز درد ناک عذا ب چُھ برونٛہہ پکا ن ،"
  46,25,"۔پننِس ربّ سٕندِ حکمہٕ کرِ پرٛتھ چیز س تباہ۔ٲخر کار سپُد تِہُنٛدحال یہِ زِ تِہنز وروزَن جایَو ورٲے اوس نہٕ تَتہِ کِہِنۍ اَتھہِ یِوان۔ یِتھہٕ پٲٹھۍ چِھ أسۍ مُجر من بد لہٕ دِوان۔"
  46,26,"۔تِمن اوس اسہِ تِکینژھاہ دِ یتمُت یِنہٕ تۅہیہِ اوسُو دِیتمُت۔تِمن ٲسۍ اسہِ کن، أچھ تہٕ دِل ،سورُے کینٛہہ دِ یتمُت ،نَہ لٔگۍ تِم کَن تِمن کُنہِ بکا ر،نَہ أچھ،نہ دل، تِکیازِ تِم ٲسۍ اللہ تعالیٰ سٕندٮ۪ن آیا تن انکار کران ، تہٕ تَمی چیز کِس پھیرس منٛز آے تِم ، یتھ تِم ہزٕ ل ٲسۍ کران۔ ع"
  46,27,"۔تۅہیہِ أندۍ پٔکۍ کیٚن علا قن منٛز چھےٚ اسہِ واریاہ بستی ہلا ک کرِ مَژٕ۔پنٕنۍ آیات سوٗزِتھ سمجھٲوۍتِم گرِ گرِ رنگہٕ رنگہٕ، بنان چُھ زِ تِم یِہَن باز۔"
  46,28,"۔پتہٕ کیازِ کوٚر نہٕ تِمو ۂستِیَو تِمن مدد یِم تِمَو اللہ تعالیٰ ترٲوِ تھ تٔمۍ سٕندِ تقرُبُک ذریعہ سمجھان سمجھان معبوٗد ٲسۍ بنٲومٕتۍ؟ ﴿یعنی تِمن ہستی ین سٍتۍ اوس تِمو عقید تُک ابتدا اَمہِ خیا لہٕ کوٚر مُت زِ تِم چِھ خُداے سٕندۍ مقبول بندٕہ ، تِہندِ ؤسیلہٕ سپدِ اسہِ خُدایس نِشہِ رسٲیی۔مگر برونٛہہ پکا ن پکان بنا وِ خۅد تِمے ہستی تِمو پنٕنۍ معبوٗد،مددٕ خٲطرٕ لو گُکھ تِمنٕے ناد دِیُن تہٕ تِمنٕے لٲگِکھ دُعا منٕگنۍ تہٕ تِمنٕے مُتعلق لوگُکھ یہِ سمجھُن زِ تِم چِھ صا حبِ تصّرُف یعنی اختیار تھاون وٲلۍ۔سٲنۍ فر یاد رٔسی تہٕ مُشکل کُشٲیی کرن یِمے۔اَمی گُمرٲہی منٛزٕ کڑ نہٕ مۅ کھ کٔر خُداین پنٕنۍ آیات پننیٚن رسولن ہٕندِ ذریعہ سوٗزِتھ رنگہٕ رنگہٕ پٲٹھۍ تِم سمجھا ونٕچ کوٗشش۔مگر تِم روٗدۍ پننیٚن یِمن اپز ٮ۪ن خُداین ہٕنزِ بند گی پٮ۪ٹھ بضد تہٕ روٗدۍ اصرار کران زِ أسۍ روٗز و اللہ تعالیٰ سٕندِ بجا ے یُہندُے دامن رٔٹِتھ۔وۅ نۍ ؤنۍ تَو ییٚلہِ یِمن مُشر کن پٮ۪ٹھ یِہنزِ گُمرٲہی ہٕندِ وجہ کِنۍ اللہ تعالیٰ سُند عذاب آو، تِہِندۍ تِم فر یا درس تہٕ مُشکل کشا معبوٗد کتہِ ٲسۍ موٗدِ مٕتۍ؟ تِم کیازِ آے نہٕ اَتھ بُرٕ وقتس منٛز تِمن مدد کر نہٕ؟﴾ بلکہ ٲسۍ تِم یِمن رٲوِمٕتۍ، تہٕ یہِ اوس تِہندِ اَپزِ یُک تہٕ تِمن بنا وٹی عقیدن ہُند انجام یِم تِمو پانہٕ بنٲوِمٕتۍ ٲسۍ۔﴿تہٕ سُہ واقعہ تہِ چُھ قٲبِل ذکر﴾"
  46,29,"۔ییٚلہِ اسہِ جِنَن ہٕنز اکھ چھۅکھ تۅہیہِ کُن أنِمٕژ ٲس تاکہ قرآن بوزن۔﴿یہِ ذِکر چھےٚ تمہِ وا قعٕچ یُس طا یف کہ سفرٕ پٮ۪ٹھہٕ مکہ یِوان یِوان وَتہِ اندر پیش اوس آمُت۔نمازِ منٛز ٲسۍ حضور صلی اللہ علیہ وسلم تلا و ت فر ما وان زِ جِنَن ہٕنز اکھ چھۅکھ درایہِ اَپٲرۍ تہٕ تِمَو کوٚر قرآن بو زنہٕ خٲطرٕ قرار۔اَتھ بارس منٛز چھےٚ تمام روا یتہٕ اتھ کتھہِ پٮ۪ٹھ مُتفق زِ اتھ مو قعس پٮ۪ٹھ ٲسۍ نہٕ جِن حضور صلی اللہ علیہ وسلمن برونٛہہ کُن آمٕتۍ۔تہٕ نہ اوس حضور صلی اللہ علیہ وسلمو تِہند یُن محسوس کوٚر مُت، بلکہ چُھ پتہٕ اللہ تعالیٰ وحی ہٕندِ ذریعہ تِمن صلی اللہ علیہ وسلم تِہندِ ینٕچ تہٕ قرآن بوزنٕچ خبردِوان﴾ ییٚلہِ تِم تتھ جایہِ وٲتۍ﴿ییٚتہِ توٚہۍ قرآن ٲسِو پران﴾ تِمو ووٚن پانہٕ وٲنۍ خا موش سپدِ و ۔ پتہٕ ییٚلہِ سُہ پر نہٕ آو ، پتہٕ پھیٖرۍ تِم خبردار کرن وٲلۍ بٔنِتھ پننِس قو مس کُن۔"
  46,30,"۔تِمو ووٚن گٔژِھتھ، اے سانہِ قو م کیو لوٗکو،اسہِ چھےٚ اکھ کتا ب بوٗزمٕژ یۅسہٕ موسیٰ علیہ السلامس پتہٕ چھےٚ نٲزِل کر نہٕ آمٕژ، تصدیق کرن وا جِنۍ چھےٚ تِمن کتا بن ہٕنز یِمہٕ اَتھ برونٛہہ چھےٚ آمژٕ، رہنمٲیی چھےٚ کران حقس تہٕ سیٚزِ وَتہِ کُن۔﴿امہِ نِشہِ چُھ پے لگا ن زِ یِمو جِنو اوس گۅڈٕ پٮ۪ٹھے حضر ت موسیٰ علیہ السلام تہٕ آسمٲنی کتابن پٮ۪ٹھ ایمان اوٚنمُت ۔ قرآن بوز نہٕ پتہٕ کوٚر تِمو محسو س زِ یہِ چھےٚ سۅ ے تعلیم یۅسہٕ پٔتِم انبیا چِھ دِوان روٗدمٕتۍ ،امہِ موجوٗب چِھ تِم اتھ کتا بہِ تہٕ امہِ کِس اَنن وٲلِس رسول اللہ صلی اللہ علیہ وسلمس پٮ۪ٹھ تہِ ایمان اَنان ۔﴾"
  46,31,"۔ اے سا نہِ قو م کیو لوٗکو ،خُدایس کُن بُلا ون وٲلۍ سٕنز دعوت کٔرِ و قبول تہٕ تس پٮ۪ٹھ أنِو ایمان، اللہ تعالیٰ کرِ تُہندٮ۪ن گنا ہن در گُزر، تہٕ تۅہیہِ بچا و یٚو درد ناک عذاب نِشہِ ۔"
  46,32,"۔تہٕ یُس کانٛہہ اللہ تعالیٰ سٕندِس دٲعی سٕنز کتھ مانہِ نہٕ ،تس نہ چُھ زمینس منٛز پنُن کانٛہہ بل بو تہٕ، زِ خُدایس ہیٚکہِ عٲجز کٔرِتھ، تہٕ نہ چھِس کینٛہہ تِتھۍ حٲمی تہٕ سر پرست زِ أمِس بچا و ن خُدایس نِشہِ۔ یِتھۍ لُکھ چِھ کُھلہٕ گُمرٲہی  منٛز ہیٚنہٕ آمٕتۍ۔"
  46,33,"۔تہٕ کیا یِمن لُکن چُھنا یہِ فِکرِ تران زِ ییٚمۍ خُداین یہِ زمین تہٕ آسما ن پٲدٕ کٔرۍ، تہٕ یِمن بنا وان بناوان تھوٚک نہٕ سُہ،سُہ چُھ ضرور اتھ پٮ۪ٹھ قدرت تھا وان زِ مۅ ردن کرِ زندٕہ؟ کیا زِ نہٕ ، یقیناً چُھ سُہ پرٛتھ چیزٕچ قدرت تھاوان۔"
  46,34,"۔ییٚمہِ دۅہ یِم کٲفر نارس برونٛٹھ کُن اَننہٕ یِن ،تمہِ ساعتہٕ یِیہِ یِمن پرٕژھنہٕ، کیا یہِ چُھنا حق؟ تِم وَنن  آ، سٲنِس ربّ سُند قسم ﴿ یہِ چُھ پٔزِ پٲٹھۍ حق﴾۔ اللہ تعالیٰ فر ماوِ  اچھا وُچِھو تیٚلہِ وۅ نۍ عذا بُک مٕزہ پننِس تتھ انکار کِس پا داشس منٛز یُس توٚہۍ کران ٲسِو روٗدِمٕتۍ۔"
  46,35,"۔پس اے نبی  صلی اللہ علیہ وسلم، صبر کٔرِو یِتھہٕ پٲٹھۍ اُولو العزم ﴿تھدِ پایہِ کیو ﴾ رسُو لو صبر چُھ کوٚرمُت، تہٕ یِہندِس معا ملس منٛز مَہ کٔرِ و جلد ی۔ییٚمہِ دۅہ یِم لُکھ تتھ چیز س وُچھن ییٚمیُک یِمن ڈر چُھ یِوان پاو نہٕ، تیٚلہِ باسہِ یِمن یِتھہٕ پٲٹھۍ زِ زنتہٕ دُنیا ہس منٛز ٲسۍ نہٕ اکہِ گرِ کھۅتہٕ زیادٕہ کالس روٗدِمٕتۍ۔کتھ آیہِ واتنا و نہٕ، وۅ نۍ کیا نا فر مان لُکو ورٲے ہیکیا بیٚیہِ کانٛہہ ہلاک سپدِ تھ؟ع"
