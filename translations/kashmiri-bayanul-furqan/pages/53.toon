quran[62]{c,v,t}:
  53,1,"تارکُک قسم ییٚلہِ سُہ لوٗس ،﴿یعنی ییٚلہِ ٲخری تارُک لوٗسِتھ روشن صُبح پھوٚل﴾"
  53,2,"تُہُنٛد رفیق نہ چھُ ڈوٚلمُت تہٕ نہ چھُ باولہٕ گوٚمُت،﴿ تُہُند رفیق نِشہِ چُھ مُراد رسول اللہ صلی اللہ علیہ وسلم، تِکیازِ تِم صلی اللہ علیہ وسلم ٲسۍ نہٕ کُفّارِ مکن خٲطرٕ غیر زان کینٛہہ بلکہ زاے تِمنٕے منٛز باگ تہٕ شُر ۍ پانہٕ پٮ۪ٹھہٕ سپٕدۍ جوان تہٕ جوٲنی پٮ۪ٹھہٕ سپدۍ اَڈورٕ۔مطلب چُھ یہِ زِ رسول اللہ صلی اللہ علیہ وسلم چُھوٗکھ توٚہۍ وارٕ پٲٹھۍ زانان۔یہِ کتھ چھےٚ روشن صبحٕکۍ پٲٹھۍ نٔنۍ زِ تِم چِھنہٕ ڈٔلِمٕتۍ تہٕ نَہ چِھ باورٕ گٔمٕتۍ انسان﴾"
  53,3,"تِم چِھنہٕ پننہِ نفس چہِ خوٲہِشہِ سٍتۍ بولا ن،"
  53,4,"یہِ چھےٚ اکھ وحی یۅسہٕ تِمن پٮ۪ٹھ نٲزِل چھےٚ یِوان کر نہٕ"
  53,5,"تس چھےٚ أکۍ زبردست قُوّت وٲلۍ تعلیم دِژ"
  53,6,"یُس سٮ۪ٹھاہ صا حب حکمت چُھ ﴿ امہِ نِشہِ چُھنہٕ مُراد اللہ تعالیٰ بلکہ چُھ جبر یل علیہ السلام یِتھہٕ پٲٹھۍ زن برونٛہہ کُن پے چُھ لگان﴾"
  53,7,"سُہ گوٚو برونٛہہ کنہِ کھڑا ییٚلہِ زَن سُہ بالٲیی اُفقس پٮ۪ٹھ اوس ،﴿اُفق چُھ مُراد آسما نُک سُہ مشر قی اند یپٲرۍ آفتا ب چُھ کھسان تہٕ دۅہُک گا ش چُھ پٔھہلان ۔مُراد چُھ یہِ زِ گۅڈنِچہِ پھِرِ ییٚلہِ نبی صلی اللہ علیہ وسلمو جبر یل علیہ السلام وُچھ، تمہِ وقتہٕ ٲسۍ تِم آسمان کہ مشر قی اَندٕ کِنۍ نٔنۍ درٛا مٕتۍ۔﴾"
  53,8,"پتہٕ آو نکھہٕ تہٕ سپُد پٮ۪ٹھہٕ کنہِ معلَّق،"
  53,9,"یوٚت تام زن دۅ ن کمانن برابر، یا روٗد امہِ کھۅتہٕ کم دوٗر یٚر۔﴿یعنی آسمان کہ بالٲیی مشر قی اندٕ کِنۍ نوٚن نیر نہٕ پتہٕ چِھ جبر یل علیہ السلام رسول اللہ صلی اللہ علیہ وسلمن کُن پکُن شروع کران یوٚت تام زن برونٛہہ پکا ن پکا ن تِم حضور  صلی اللہ علیہ وسلمس پیٚٹھۍ کِنۍ یِتھ ہوا ہس منٛز معلَّق سپٕدۍ ، پتہٕ نمییہِ تِم صلی اللہ علیہ وسلمس کُن تہٕ یوٗتاہ سپٕدۍ قر یب زِ تِمن علیہ السلامن تہٕ حضور  صلی اللہ علیہ وسلمن روٗد صرف دۅ ن کمانن برابر یاامہِ کھۅتہٕ کم دوٗر یٚر۔چو نکہ تمام کما نہٕ چَھنہٕ ہِشے آسان امہِ موجوٗب آو دوٗرِرُک اندازٕہ وَننہٕ خٲطرٕ فر ما و نہٕ زِ دۅ ن کما نن برابر، یا روٗد امہِ کھۅتہٕ کم دوٗر یٚر۔﴾"
  53,10,"تمہِ پتہٕ واتنٲو تٔمۍ اللہ تعالیٰ سٕندِس بند س وحی یۅسہٕ تہِ واتناوٕنۍ ٲس"
  53,11,"نظرِ یِکینژھاہ وُچھ، دِلن رَلوو نہٕ تَتھ اَپُز۔﴿یعنی یہِ مُشٲہد یُس دُہٕلۍ گا شس تہٕ پوٗرٕ بیدٲری ہٕندِس حا لتس منٛز کُھلہٕ أچَھو محمد صلی اللہ علیہ وسلمس سپُد،تتھ پٮ۪ٹھ ووٚن نہٕ تِہندۍ دلِ مُبا رکن زِ یہِ چُھ نظرِ ہُند دۅ کھہٕ ، یا یہِ زِ کانٛہہ  جن یا شیطان چھُ مےٚ اَتھہِ یِوان یا مےٚ برونٛہہ کُن کانٛہہ خیٲلی صورت آمٕژ تہٕ بہٕ چھُس بیدٲری منٛزٕے کانٛہہ خو اب وُچھان،بلکہ سمجُھ تِہندۍ دلِ مُبا رکن ٹھیک ٹھیک تی یہِ تِہنزٕ چسمانِ مُبا رک وُچھان آسہٕ۔ تِمن صلی اللہ علیہ وسلمن سپُد نہٕ اتھ کتھہِ منٛز کانٛہہ شک زِ در حقیقت چِھ یِم جبر یل علیہ السلام تہٕ یُس پیغا م یِم واتناوان چِھ سُہ چُھ وا قعی خُداے سٕندِ طر فہٕ وحی ﴾"
  53,12,"کیا وۅ نۍ چِھو ا توٚہۍ تِمن سٍتۍ تَتھ چیز س پٮ۪ٹھ ژُوان یَتھ تِم پننیو چشمو چِھ وُچھان؟"
  53,13,"تہٕ اکہِ پھِرِ وُچھ تِمو بیٚیہِ سُہ،"
  53,14,"سِدرَ تُہ المُنتَھٰی ہَس نِشہِ وَسان ۔﴿ سِدرہ چِھ عر بی زبٲنۍ منٛز برٛ ییہِ کُلِس ونان تہٕ مُنتہیٰ لفظُک معنی چُھ ٲخر ی اَند۔"" سِدر تہ المُنتہٰی "" لفظُک لُغوی معنی چُھ "" سُہ برٛ ییہِ کُل یُس ٲخر ی یا انتہٲیی اَندس پٮ۪ٹھ چُھ۔"" سا نہِ خٲطرٕ چُھ یہِ زانُن مُشکل زِ یَتھ مٲدی عا لم کِس ٲخری سر حدس پٮ۪ٹھ کِیُتھ چُھ سُہ برٛ ییہِ کُل تہٕ اَمِچ حقیقی نو عیت تہٕ کیفیت کیا چھےٚ ،یِم چِھ کا ینا تِ خُدا و ند ی ہٕنٛد ۍ تِم اَسرار، یو ر سو ن فہم تہٕ ظۅن وٲتِتھ ہیٚکہِ نہٕ۔بہر حال چُھ سُہ کانٛہہ تِیُتھے چیز ییٚمہِ خٲطرٕ اِنسٲنی زبٲنۍ ہٕندٮ۪ن لفظن منٛز ""سِدرہ "" کھۅتہٕ منٲسب لفظ خُدا یس نزدیک بیٚیہِ کانٛہہ اوس نہٕ۔﴾"
  53,15,"ییٚتہِ نکھے جنت الماویٰ چُھ"
  53,16,"تمہِ وقتہٕ اوس سِدرہ ہس پٮ۪ٹھ وَلنہٕ یِوان یِکینژھاہ تہِ وَلنہٕ اوس یِوان"
  53,17,"نظرِ نَہ گوٚ و دُگوش تہٕ نَہ درٛا یہِ حدٕ نیٚبر،"
  53,18,"تہٕ تِمو وُچھِہ ربّ سٕنز بجہِ بجہِ نشٲنیہِ ۔﴿یہِ آیت چھےٚ امہِ کتھہِ ہٕنز وضا حت کران زِ حضور صلی اللہ علیہ وسلمووُچھ نہٕ اللہ تعالیٰ ، بلکہ وُچھَکھ تٔمۍ سٕنزٕ عظیم الشّان نِشٲنِیہِ ، تہٕ چو نکہ سیا ق کہ تعلق سٍتۍ اوس یہِ دوٚ یُم مُلا قات تہِ تٔسۍ ہستی سٍتۍ سپُد مُت یَس  سٍتۍگۅڈ نِیُک ملا قات سپُد مُت اوس،لہٰذا پیٚیہِ یہِ مانُن زِ اُفقِ اعلیٰ ہس پٮ۪ٹھ یُس تِمو صلی اللہ علیہ وسلمو گۅڈ نِچہِ پھِرِ وُچھمُت اوس سُتہِ اوس نہٕ اللہ تعالیٰ ، تہٕ دوٚ یِمہِ پھِرِ یُس سِد ر تہ المُنتہیٰ ہس نِشہِ وُچُھکھ سُتہِ اوس نہٕ اللہ تعالیٰ۔اگر حضور صلی اللہ علیہ وسلمو یِمو مو قعو منٛزٕ کُنہِ موقعس پٮ۪ٹھ اللہ جلّ شا نہ وُچھمُت آسِہے ، تیٚلہِ ٲس یہِ تِیژبٔڈ کتھ زِ یتھ جایہِ یِیہِ ہے ضرور اَمِچ ذکر کر نہٕ۔﴾"
  53,19,"وۅ نۍ ؤنۍ تو ، تۅہیہِ چُھوٕ زانٛہہ أمِس لات ،تہٕ أمِس عُزّٰی"
  53,20,"،تہٕ تر یِیِم اکھ دیو ی منا ت سٕندِس حقیقتس پٮ۪ٹھ ہَنہ غور تہِ کوٚر مُت؟ ﴿ مطلب چُھ یہِ زِ یۅسہٕ تعلیم محمد صلی اللہ علیہ وسلم تۅہیہِ دِوان چِھو، تتھ چِھو توٚہۍ لُکھ گُمرٲہی تہٕ بدرٲہی قرار دِوان، حالانکہ عِلم چُھ تِمن صلی اللہ علیہ وسلمن اللہ تعالیٰ سٕندِ طر فہٕ دِنہٕ یِوان تہٕ خُداین چِھ تِمن چشمانِ مُبا ر کَو تِم چیز ہٲوِ مٕتۍ یِہٕنز شہا دت تِم تۅہیہِ برونٛہہ کنہِ دِوان چِھ ۔وۅ نۍ وُچھِتَو پا نے زِ یِمن عقید ن ہٕنزِ پیر وی پٮ۪ٹھ توٚہۍ اِصرار کران پکا ن چِھو تِم کتھ حدس تام چِھ غیر معقو ل ،تہٕ یِہندِس مقا بلس منٛز یُس شخص تۅہیہِ سِیٔز وَتھ ونان چُھو ،تٔمۍ سٕنز مُخا لفت کٔرِتھ کَس چِھو ٲخر توٚہۍ نقصا ن کران۔﴾"
  53,21,"کیا نیٚچِو ۍ چھا تُہندِ خٲطرٕ تہٕ کورِ گٔیہِ خُداے سٕندِ خٲطرٕ؟﴿یعنی یِمہٕ دیو ی دِژ وکھ تۅہیہِ اللہ ربّ العالمین سٕنزٕ کورِ قرار،تہٕ یہِ بے ہوٗدٕہ عقیدٕہ ایجا د کر نہٕ وِزِسُو نچو نا تۅہیہِ یِتہِ زِ پننہِ خٲطرٕ چِھو توٚہۍ کوٗر زیٚنۍ ذلّت سمجھان،تہٕ یژھان چِھو زِ اسہِ گٔژھۍ گوٚبرٕے یٲتۍ آسٕنۍ ، مگر خُدایس خٲطرٕ چِھو کورِ تجو یز کران !﴾"
  53,22,"یہِ گٔیہِ تیٚلہِ اَنہِ کَھلہِ بٲگران !"
  53,23,"در اصل چِھنہٕ یِم کِہِنۍ مگر بس کینٛہہ ناو، یِم تۅہیہِ تہٕ تُہٕند یو ما لیو بُڈِ  بَبو تھٲوِمٕتۍ چِھ۔ خُداین چَھنہٕ یِہندِ خٲطرٕ کانٛہہ سَنَد کٔرمٕژ نٲزِل۔ حقیقت چھےٚ یہِ زِ لُکھ چِھ صرف وہم و گُما نٕچ پیر وی کران تہٕ نفٕس کیٚن خوٲہشا تن ہٕندۍ مرید چھِ بنیمٕتۍ۔حالا نکہ تِہندِس ربّ سٕندِ طر فہٕ چُھ تِمن نِشہِ ہدا ت آمُت"
  53,24,"یِکینژھاہ اِنسان ییٚژِھہ کیا تٔمۍ سٕندِ خٲطرٕ چھا تی حق؟ ﴿ییٚمہِ آیتُک بیا کھ مطلب ہیٚکہِ یِتہِ ٲسِتھ زِ کیا انسانس چھا یہِ حق زِ یَس ییٚژِھہ تس بناوِ معبوٗد ؟ تہٕ تریُیم مطلب ہیٚکیس یِتہِٕ ٲسِتھ زِ انسان سُند سُہ طمع تہِ ہیٚکیا پوٗرٕ سپدِ تھ یُس سُہ یِمن معبوٗدن نِشہِ پنٕنۍ مُراد حٲصل کر نہٕ با پت تھا وان چُھ؟ ﴾"
  53,25,"دُنیا تہٕ ٲخرتُک مٲلِک چُھ بس اللہ تعالی"
  53,26,"آسمانن منٛزکٲتیاہ فرشتہ چھِ موجود،تِہُند شفا عت ہیٚکہِ نہٕ رژھ تہِ بکا ر یِتھ،یوٚت تام نہٕ اللہ تعالیٰ کانٛسہِ تِتھِس شخصہٕ سٕندِس حقس منٛز تمِیُک اجا زت دِیہِ ییٚمہِ سٕندِ خٲطرٕ سُہ کانٛہہ عر ض داشت بوزُن ییٚژِھہ تہٕ تتھ کرِ پسند"
  53,27,"مگر یِم لُکھ ٲخرتس چِھنہٕ مانان ، تِم چِھ فر شتن دیو ی یَن ہٕنٛد ۍ ناو کران،"
  53,28,"حالانکہ امہِ معا ملُک کانٛہہ علم چُھنہٕ تِمن حٲصل،تِم چِھ محض گُما نٕچ پیر وی کران۔تہٕ گُمان ہیٚکہِ نہٕ حق چہِ جایہِ رژھ تہِ کٲم دِتھ"
  53,29,"لہٰذا ،اے نبی صلی اللہ علیہ وسلم،ترٲوِیوٗن سُہ شخص تٔمۍ سٕندِس حا لس پٮ۪ٹھ ،یُس سا نہِ ذکرِ نِشہِ بُتھ چُھ پھِران،تہٕ یَس دُنیا چہِ زند گی ورٲے کِہِنۍ بکا ر چُھنہ"
  53,30,"یِمن لُکن ہُند مبلغ علم چُھ بس یی کینژھاہ ۔ ﴿یہِ چُھ جملہ مُعتر ضہ یُس کلا مُک سلسلہ منٛز با گ پُھٹرٲوِتھ پٔتِمہِ کتھہِ ہٕنزِ تشر یح ہٕندِ طور ارشاد چُھ فر ما و نہٕ آمُت۔﴾یہِ کتھ چُھ تُہُند ربّےٕ زیا دہ زانان زِ تٔمۍ سٕنزِ وَتہِ نِشہِ کُس چُھ ڈوٚ لمُت، تہٕ کُس چُھ سیٚزِ وَتہِ پٮ۪ٹھ،"
  53,31,"تہٕ زمین و آسمانن ہٕندِ پرٛتھ چیزُک مالک چُھ بس اللہ تعالیٰ۔تاکہ اللہ تعالیٰ دِیہِ بُرٲیی کرن والیٚن تِہنزِ عملہِ ہُند بد لہٕ﴿ییٚتہِ پٮ۪ٹھہٕ چُھ بیٚیہِ سُے کلامُک سلسلہٕ شر وع گژھان یُس ہیٚرِ پٮ۪ٹھہٕ چلا ن اوس۔ گو یا جملہ مُعترضہ ترٲوِتھ چُھ کلا مُک سلسلہٕ یِتھہٕ پٲٹھۍ:"" یہِ ترٲوِ یوٗن تٔمۍ سٕندِس حالس پٮ۪ٹھ تاکہ اللہ تعالیٰ دِیہِ بُرٲیی کرن والیٚن تِہنزِ عملہِ ہُند بد لہٕ۔""﴾تہٕ تِمن لُکن تہِ دِیہِ رُت جزا یِمو نیک رٔوِیہِ وَر تو و مُت چُھ،"
  53,32,"یِم بڑ یو بڈیو گنا ہو تہٕ ٹا کارٕ وُچا پہٕ کامیو نِشہِ پر ہیز چِھ کران، اِلاّیہِ زِ کینٛہہ قصور گژِھہ تِمن سر زد۔بے شک چُھ تُہندِس ربّ سٕندِ مغفرتُک دامن وسیع۔سُہ چُھو تۅہیہِ تمہِ وقتہٕ پٮ۪ٹھہٕ خوٗب زانان ییٚلہِ تٔمۍ زمینہٕ نِشہِ پٲدٕ کٔرِ نَو، تہٕ ییٚلہِ توٚہۍ پننیٚن ما جن ہٕنزن یٔڈن منٛز جنین ﴿ یعنی خا مٕے ﴾ ٲسِو۔ لہٰذا مَہ کٔرِ و پننہِ نفس چہِ پٲکی ہٕندۍ دعویٰ، سُے چُھ بہتر زانان زِ پٔزِ پٲٹھۍ کُس چُھ متقی؟"
  53,33,"اے نبی صلی اللہ علیہ وسلم پتہٕ وُچھوٗ نہٕ تۅہیہِ سُہ شخص تہِ یُس خُداے سٕنزِ وَتہِ نِشہِ پھیوٗر،"
  53,34,"تہٕ کم کینژھاہ دِ تھ رُکیا و؟ ﴿ اشارٕہ چُھ ولید بن مُغیرہ ہس کُن یُس قر یش سردارو منٛزٕ اکھ بوٚڈ سردار اوس۔یہِ شخص اوس گۅڈٕ رسول اللہ صلی اللہ علیہ وسلمن ہٕنز دعوت قبول کر نس پٮ۪ٹھ آما دٕہ گوٚ مُت۔مگر ییٚلہِ أمۍ سٕندِس أکِس مُشر ک دوستس پے لوٚگ زِ یہِ چُھ مُسلمان بنُن یژھان ،تٔمۍ ووٚن أمِس زِ ژٕ مَہ تراو پنُن آبٲیی دین، اگر ژےٚ ٲخرت کہ عذا بُک خطرٕ ہ چھی تیٚلہِ دِ مےٚ یوٗتاہ رقم،بہٕ چُھسے ذمہٕ دٲری رٹا ن زِ چا نہِ بد لہٕ رَٹہٕ بہٕ تَتہِ عذا ب۔ولید چُھ یہِ کتھ مانان تہٕ خُداے سٕنزِ وَتہِ پٮ۪ٹھ یِوان یِوان چُھ امہِ نِشہِ ڈلان،مگر یُس رقم تس پننِس مُشر ک دوستس دِیُن اوس،سُہ دُیتنَس کمٕے تہٕ با قی روٚٹُن پتھ﴾"
  53,35,"کیا تس نِشہِ چھا علمِ غیب زِ سُہ چُھ حقیقتس وُچھان؟"
  53,36,"کیاتس وٲژ نا تِمن کتھن ہٕنز خبر یِمہٕ مو سیٰ علیہ السلام سٕندٮ۪ن صحیفن منٛز،"
  53,37,"تہٕ ابرا ہیم علیہ السلام سٕندٮ۪ن صحیفن منٛز بیان چھےٚ سپٕز مَژٕ ییٚمۍ وفا دٲری ہُنٛد حق کوٚر ادا؟﴿برونٛہہ کُں یِیہِ یِمن تعلیماتن ہُنٛد خلاصہ بیان کرنہٕ یِم حضرت موسیٰ علیہ السلامن تہٕ ابراہیم علیہ السلامن ہٕندٮ۪ن صحیفن منٛز نٲزل ٲسۍ گٔمٕتۍ﴾"
  53,38,"یہِ زِ کانٛہہ بور تُلن وول تُلہِ نہٕ بیٚکۍ سُنٛدبور﴿یعنی پرتھ کنٛہہ شخص چھُ پننہِ کارُک پانہٕ ذمہٕ دار۔أکِس شخصہٕ سٕنز ذِمہٕ دٲری ہیٚکہِ نہٕ بیکِس پٮ۪ٹھ تراو نہٕ یِتھ ۔کانٛہہ شخص اگر ییٚژِھہ تہِ سُہ ہیٚکہِ نہٕ بیٚکِس شخصہٕ سٕندِ کارچ ذمہ دٲری پا نس پٮ۪ٹھ ہیٚتھ ،نَہ یِیہِ اصلی مُجر م اتھ بِناہس پٮ۪ٹھ ترا و نہٕ یِتھ زِ تٔمۍ سٕنزِ جا یہِ چُھ بیاکھ شخص سزا پیٚتر او نہٕ خٲطرٕ پنُن پا ن پیش کران﴾"
  53,39,"بیٚیہِ یہِ زِ انسانس خٲطرٕ چُھنہٕ کِہِنۍ مگر تہِ ییٚمہِ خٲطرٕ تٔمۍ سعی چھےٚ کٔرمٕژ﴿یعنی پرٛتھ شخصس یِکینژھاہ میلہِ تہِ میلٚیس پننہِ عملہِ ہُند پھل۔أکِس شخصہٕ سٕنزِ عملہِ ہُند پھل ہیٚکہِ نہٕ بیکِس مِیٖلِتھ ۔تہٕ کانٛہہ شخص ہیٚکہِ نہٕ سعی تہٕ عملہِ ورٲے کِہِنۍ حٲصل کٔرِ تھ۔﴾"
  53,40,"بیٚیہِ یہِ زِ تٔمۍ سٕنز سعی یِیہِ عنقریب وُچھِنہٕ ،"
  53,41,"تٔمۍ سُند پوٗرٕ جز ا یِیہِ تس دِنہٕ ،"
  53,42,"بیٚیہِ یہِ زِ ٲخر کار چُھ واتُن تُہٕندِس ربّ سٕے نِشہِ ،"
  53,43,"بیٚیہِ یہِ زِ تٔمی اَسنٲوۍ تہٕ تٔمی ودٕ نٲوۍ،﴿یعنی خو شی تہٕ غم دۅ شوٕ نۍ ہٕندۍ اَسباب چِھ تٔمۍ سٕندی طر فہٕ۔جان تہٕ خرا ب قسمتُک آگُر چُھ تٔمۍ سٕندِ سٕے اَتھس منٛز۔ کانٛہہ بیا کھ ہستی چَھنہٕ یتھ کا ینا تس منٛز تِژھ یۅ سہٕ قسمتن ہٕندِس بنا و نس تہٕ بِگا ڑنس منٛز کُنہِ قسمُک دخل آسہِ تھا وان ۔﴾"
  53,44,"بیٚیہِ یہِ زِ تٔمی دِیُت مو ت تہٕ تٔمی بخش زند گی،"
  53,45,"تہٕ یہِ زِ تٔمی کوٚر نر تہٕ ما دُک جورٕ پٲدٕ ،"
  53,46,"اکہِ قطرٕ ہ سٍتۍ ییٚلہِ سُہ تراونہٕ چُھ یِوان ،"
  53,47,"بیٚیہِ یہِ زِدوٚیِم زند گی عطا کرٕنۍ تہِ چھےٚ تٔمۍ سٕندی ذِمہٕ،"
  53,48,"بیٚیہِ یہِ زِ تٔمی بنٲوۍ غنی تہٕ تٔمی بخُش جا یداد،"
  53,49,"تہٕ یہِ زِ سُے چُھ شِعر یٰ ہُک ربّ ، ﴿ شِعر یٰ چُھ آسمانُک روشن تر ین تا رُک۔مِصر تہٕ عر ب کیٚن لُکن اوس یہِ عقیدٕہ زِ یہِ تارُک چُھ انسانن ہٕندِس قستمس پٮ۪ٹھ اثر تراوان۔أتھۍ بِنا ہس پٮ۪ٹھ اوس یہِ تِہندٮ۪ن معبوٗدن منٛز شٲمِل۔﴾"
  53,50,"بیٚیہِ یہِ زِ تٔمی کوٚر عادِ اُولیٰ ﴿پرٛ و ن عاد ﴾ ہلاک،"
  53,51,"تہٕ ثمو د مِٹو وُن تِتھہٕ پٲٹھۍ زِ تِمو منٛزٕ تروُون نہٕ کانٛہہ یلہٕ،"
  53,52,"تہٕ یِمو برونٛہہ کوٚرُن قو مِ نو ح علیہ السلام تباہ،تِکیازِ تِم ٲسۍ سخت ظٲلِم تہٕ سر کش لُکھ،"
  53,53,"تہٕ دُبہٕ پھیرن وا جِنہٕ بستی لا یَن تھوٚد تُلِتھ پتھر،"
  53,54,"پتہٕ کوٚر تٔمۍ چیز ن تِمن وُرُن﴿تۅہیہِ چُھوپے زِ ﴾ کٔمۍ چیز ن کوٚرنکھ وُرُن،﴿ دُبہٕ پھیرن وا جِنیو بستی یَو نِشہِ چُھ مُراد قو مِ لُو ط چہِ بٔستِیہِ۔ تہٕ "" پتہٕ کوٚر تٔمۍ چیز ن تِمن وُرُن ﴿تۅہیہِ چَھو پَے زِ ﴾ کٔمۍ چیز ن کوٚرنکھ وُرُن"" چُھ مُراد غا لباً بحرِ مردارُک آب یُس تِہنز ن بٔستِین منٛز أژِتھ پتہٕ تِمن پٮ۪ٹھ پٔھہلیاو، تہٕ اَز تام چُھ سُہ اتھ علا قس پٮ۪ٹھ وُرُن کٔرِ تھ﴾"
  53,55,"لہٰذا ، اے انسان پننِس ربّ سٕنز ن کمن کمن نعمتن منٛز کر کھ ژٕ شک؟"""
  53,56,"یہِ چُھ اَکھ نہیب گۅڈنِکیو آمتیو نہیبَو منٛزٕ"
  53,57,"یِنہٕ واجِنۍ گٔر چھےٚ نکھہٕ وٲژمٕژ،"
  53,58,"خُدایس ورٲے چُھنہٕ کانٛہہ تتھ ہٹا ون وول"
  53,59,"کیا وۅ نۍ چھا یِمے تِمہٕ کتھہٕ یِمن پٮ۪ٹھ توٚہۍ اظہا رِ تعجُب چِھو کران؟"
  53,60,"اَسان چِھو تہٕ وَدان چِھو نہٕ ؟"
  53,61,"تہٕ گیٚوان گِندان چِھو یِمہٕ کتھہٕ ٹالان؟"
  53,62,"مِو خُدایس برونٛہہ کنہِ تہٕ کٔرِ و تٔمۍ سٕنٛز بند گی"
