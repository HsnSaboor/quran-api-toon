quran[176]{c,v,t}:
  4,1,"۔اے لوٗکو ،پننِس ربّس کھوژِو ییٚمۍ توٚہۍ اکہِ جا نہٕ نِشہِ پٲدٕ کٔرِ نَو تہٕ تَمی جانہٕ نِشہِ بنو وُن تَمِیُک جو رٕ تہٕ یِمو دۅ شوٕ یو سٍتۍ پھٔہلٲوِن دُنیاہس اندر واریاہ مرد تہٕ مستوٗراتہٕ  تس خُدا یس کھوٗژِو ییٚمۍ  سُند وا سطہٕ دِتھ اکھ أکِس چِھوپنٕنۍ حق منگان، بیٚیہِ کٔرِو رشتہٕ تہٕ قرا بتٕکۍ تعلقا ت بگا ڑ نہٕ نِشہِ پر ہیز ،زٲنِو زِ اللہ تعالیٰ چُھ تۅہیہِ پٮ۪ٹھ نگرٲنی کران۔"
  4,2,"۔یتیمن ہٕندۍ مال دِیِو تِمن وا پس، اصل مال مَہ بد لٲوِ و خراب مالہٕ سٍتۍ تہٕ تِہندۍ مال مَہ کھیِیو پننِس ما لس سٍتۍ رَلٲوِتھ ،یہِ چُھ واریاہ بوٚڈ گنا ہ ۔"
  4,3,"۔تہٕ اگر تۅہیہِ اندیشہ آسہِ زِ یتیمن سٍتۍ ہیکوِۍ نہٕ انصا ف کٔرِ تھ تیٚلہِ یِمہٕ مستورا تہٕ تۅہیہِ پسند یِنو تِمَو منٛز کٔرِ و دۅ ن دۅن، تر یٚن تریٚن ،ژۅن ژۅن سٍتۍ نکا ح۔﴿یہِ کتھ چھےٚ مدِ نظر تھاوٕنۍ زِ یہِ آیت ٲس نہٕ اکہِ کھۅتہٕ  زیادہ خاندارِنہِ کر نہٕ کِس اجا زتس منٛز آمٕژ تِکیازِ یہِ نٲزِل سپدِ نہٕ برونٹھے ٲس یہِ کٲم جٲیز تہٕ خۅد آسہٕ رسول اللہ صلی اللہ علیہ وسلمس اکہِ کھۅتہٕ زیادہ گھر واجِنہِ تَمہِ وقتہٕ موجو د ۔ دراصل ٲس یہِ امہِ  موجوب نٲزِل گٔمٕژ زِ لڑا ین منٛز شہید سپد ن وا لیٚن ہٕندۍ یِم یتیم شُر ۍ پتھ کُن ٲسۍ روٗدِمٕتۍ تِہندۍ مسٲیل حل کر نہٕ  موجوٗب آو فر ما و نہٕ زِ اگر تِمن یتیمن ہٕندۍ حقوق یِتھہٕ پٲٹھۍ ہیٚکِو نہٕ ادا کٔرِ تھ تیٚلہِ کٔرِ و تِمن مۅ نڈ ن سٍتۍ نکا ح یِمن یتیم شُر ۍ سٍتۍ آسن۔﴾ البتہ اگر تۅہیہِ اندیشہِ آسیٚو زِ تِمن سٍتۍ ہیٚکِو نہٕ عد ل کٔرِ تھ تیٚلہِ کٔرِو اکٲے زنانہٕ۔﴿اتھ کتھہِ پٮ۪ٹھ چُھ اُمّت کیٚن فقا ہن ہُنٛد اجما ع زِ امہِ آیت کہ ذر یعہ چُھ تعدادِ ازوا ج محدود کر نہٕ آمُت تہٕ بیک وقت ژورَو کھۅتہٕ زیادٕہ گھرواجِنہِ تھاو نہٕ نِشہِ چُھ ٹھاکھ کر نہٕ آمُت۔اَمہِ علا وہ چھےٚ  یہِ آیت تعدادِ اَزواج کِس جوازس عد ل کِس شر طس سٍتۍ مشر و ط کران۔یُس شخص عدلُک شر ط پوٗرٕ چُھنہٕ کران مگر اکہِ کھۅتہٕ زیادہ گھر واجِنہِ کر نہٕ کِس اجازتس چُھ فٲیدہ تُلان سُہ چُھ خُدا یس سٍتۍ دغا بٲزی کران۔ اسلامی حکو مت چن عدا لتن چُھ یہِ حق حٲصل زِ، ییٚمِس خاندار نہِ یا یِمن خاندارِ نیٚن سٍتۍ سُہ انصا ف آسہِ نہٕ کران تِمن کٔرِن دار رسی۔کینٛہہ لُکھ چِھ اہلِ مغر ب کیٚو نظر یا تَو نِشہِ مغلو ب تہٕ مر عو ب سپدِ تھ یہِ ثٲبت کر نٕچ کو شش کران زِ قرآنُک اصلی مقصد اوس تعدادِ اَزواجُک طر یقہٕ ﴿یُس نقطہ نظر کِنۍ دراصل بُرٕ طر یقہٕ چُھ﴾ مِٹا وُن۔مگر اَمہِ قٔسمہٕ چہِ کتھہٕ چھےٚ دراصل محض ذہنی غلا می ہُند نتیجہِ ۔ تعدادِ ازواجُک فی نفسہٖ اکھ بُرٲیی آسُن چُھ خۅد نا قٲبِل تسلیم ، تِکیازِ کینژھن حالاتن منٛز چُھ یہِ چیز اکھ تمدُنی تہٕ اخلا قی ضرورت بنان ۔ قرآنن چُھ صر یح لفظن منٛز یہِ جٲیز قرار دیتمُت تہٕ ور گہٕ پٲٹھۍ تہِ چُھن نہٕ امہِ کِس مذمتس منٛز کانٛہہ تِیُتھ لفظ تہِ وَرتو و مُت ییٚمہِ سٍتۍ معلو م سپدِ زِ فی الواقع چُھ سُہ اتھ بند کرُن یژھان۔﴾ یا نیوٗکھ تِمہٕ مستوٗاتہ پننِس زو جیتس منٛز یِمہٕ تُہندِس قبضس منٛز چھےٚ آمژٕ۔﴿مُراد چھےٚ لوٗنڈ یہِ۔یعنی تِمہٕ مستوٗراتہٕ یِمہٕ جنگس اندر گرفتار سپدِ تھ آمژٕ آسن تہٕ جنگ کیٚن اسیٖر ن ہُنٛد تبا د لہٕ نہ سپدَن کِس صورتس منٛز آسن حکو مت کہ طر فہٕ لُکن منٛز بٲگرا و نہٕ آمٕژ۔﴾ بےٚ انصا فی نِشہِ بچنہٕ خٲطرٕ چُھ یہِ نیک عملہِ زیادہ نکھہٕ۔"
  4,4,"۔تہٕ مستوٗراتن ہُنٛد مَہر کٔرِ و خو ش دِلی سان  ﴿فر ض زٲنِتھ﴾ ادا البتہٕ اگر تِمہٕ پانہٕ پننہِ خوشی سان مَہرُک کانٛہہ حصہ تۅہیہِ معا ف کر ن تیٚلہِ ہیٚکِو توٚہۍ سُہ مزٕہ سان کھیٚتھ۔"
  4,5,"۔تہٕ پنٕنۍ تِم مال یِم خُدا ین تُہندِ خٲطرٕ زند گی قٲیِم تھاونٕکۍ ذر یعہ چِھ بنٲوِمٕتۍ ، مَہ کٔرِو نادان لُکن حوا لہٕ البتہٕ دِیِو تِمن کھیٚنہٕ خٲطرٕ تہٕ لاگنہٕ مۅ کھہٕ تہٕ تِمن کٔرِو نیک ہدایت ۔"
  4,6,"۔تہٕ یتیمن روٗزِ و آز مٲیش کران یوٚت تام زن تِم نِکا حس قٲبل وٲنٛسہِ وا تن ۔﴿یعنی ییٚلہِ تِم با لغ آسن ہیوا ن سپدُن، تیٚلہِ روٗزِ وُچھان زِ تِہُند عقلی نشو و نما کِیُتھ چُھ تہٕ تِمن منٛز کتھ حدس تام چھےٚ پنٕنۍ معا ملات پانہٕ خو د پننہِ ذمہٕ دار ی سان پکنا ونٕچ صلٲحیت پٲدٕ سپٕز مٕژ۔﴾ پتہٕ اگر تۅہیہِ تِمن منٛز اہلیت با سیٚو تیٚلہِ کٔرِو تِہٕندۍ مال تِمن حوا لہٕ ،یِنہٕ زانٛہہ یہِ کٔرِ و زِ انصا ف کہ حدٕ نِشہِ ڈٔلِتھ کھیٚیِو تِہندۍ مال امہِ خو فہٕ جلد ی جلد ی زِ بٔڑۍ گٔژِھتھ  کر ن تِم پننہِ حقُک مُطا لبہٕ ،یتیم سُند یُس سر پرست مالدار آسہِ سُہ ہیٚیِن پر ہیز گٲر ی کٲم تہٕ یُس غر یب آسہِ سُہ کھیٚیِن معر و ف طر یقہٕ۔﴿یعنی پننہِ خد متُک حق رٔٹِن اَتھ حدس تام زِ پرٛتھ کانٛہہ غیر جانبدار معقو ل انسان گژِھہ اَتھ  مُنٲسِب تسلیم کرُن۔ اَمہِ علا وہ یِکینژھاہ خدمتُک حق سُہ رَٹہِ ، تہِ گژِھنہٕ ژوٗرِ ژِھیٚپہِ رَٹُن بلکہ گژِھہ اعلا نیہ مُقرر کٔرِ تھ  رَٹُن ، بیٚیہِ گژِھہ تَمِیُک حسا ب تھاوُن۔﴾ پتہٕ ییٚلہِ تِہِندۍ مال تِمن حوالہٕ ہیٚیِو کرٕنۍ تیٚلہِ تھٲوِ یوٗکھ اَتھ پٮ۪ٹھ لُکھ گواہ تہٕ حسا ب ہیٚنہٕ مۅ کھہٕ چُھ اللہ تعالیٰ سٮ۪ٹھاہ۔"
  4,7,"۔مَردَن خٲطرٕ چُھ تَمہِ مالہٕ منٛزٕ حصہٕ یُس مٲلۍ ماجہِ تہٕ قر یبی رشتہٕ دارَو آسہِ پتھ کُن ترٛ وومُت تہٕ مستوٗراتن خٲطرٕ تہِ چُھ تمہِ مالہٕ منٛزٕ حصہٕ یُس مٲلۍ ماجہِ تہٕ قر یبی رشتہٕ دارَو آسہِ پتھ کُن ترٛوو مُت خوا ہ سُہ کم ٲسِتن یا زیادہ ، ﴿یَتھ آیتس منٛز چِھ وا ضح طور پانژھ قا نو نی حکم دِنہٕ آمٕتۍ : اکھ یہِ زِ میراث چُھنہٕ صرف مر دن ہُنٛد ے یوت حصہٕ بلکہ چھےٚ مستو راتہٕ تہِ امہِ چہِ حقدار۔دوٚیُم یہِ زِ میراث گژِھہ بہر حال بٲگراونہٕ یُن خوا ہ سُہ کوتا ہ تہِ کم آسِتن ۔ترٛیُیم یہِ زِ یَتھ آیتس منٛز چُھ میت سُند پتھ کُن ترٛوومُت سورُے مال قا بِل تقسیم قرار دِنہٕ آمُت تہٕ اَتھ منٛز چُھنہٕ منقو لہٕ تہٕ غیر منقو لہٕ ، زر عی یا غیر زر عی، آبٲیی تہٕ غیر آبٲیی ہُک تفر یق کر نہٕ آمُت۔ژوٗرِم چُھ اَمہِ نِشہِ پے لگان زِ مُو ر ث ﴿ییٚمۍ سٕنز وارثت آسہِ ﴾ سٕنزِ زند گی منٛز چُھنہٕ کانٛہہ حقِ میرا ث پٲدٕ سپدان بلکہ چُھ میرا ثُک حق تمہِ وقتہٕ پٲدٕ سپدان ییٚلہِ مُورِث کانٛہہ مال ترٲوِتھ گُزر یو مُت آسہِ۔پوٗنژِم زِ امہِ نِشہِ چُھ یہِ قٲعد ہ تہِ نیران زِ قر یب تر رشتہٕ دار سٕنزِ موجو دگی منٛز ہیکہِ نہٕ دوٗر درا زُک رشتہٕ دار وَرا ثت حٲصل کٔرِ تھ۔برونٛٹھ کُن چھےٚ اَمی قٲعدٕچ تشر یح ،آیت نمبر 11، کِس ٲخرس تہٕ آیت نمبر 33 ہس منٛز کر نہٕ آمٕژ۔﴾ تہٕ یہِ حصہ چُھ ﴿اللہ تعالیٰ سٕندِ طر فہٕ ﴾ مُقرر۔"
  4,8,"۔تہٕ ییٚلہِ بٲگر او نہٕ کِس مو قعس پٮ۪ٹھ رشتہٕ دار ،یتیم تہٕ مسکین یِن اَمہِ مالہٕ منٛزٕ دِیِو تِمن تہِ کینٛہہ تہٕ تِمن سٍتۍ کٔرِو رٔتۍ پٲٹھۍ کتھ۔"
  4,9,"۔لُکن پزِ اَمہِ کتھہِ ہُند خیا ل کٔرِ تھ کھوژُن زِ اگر تِم پانہٕ خۅد پَتھ کُن بے بس اولا د ترٛاوٕ ہَن، تہٕ مر نہٕ وقتہٕ کِتھۍ اندیشہِ گژھہَن تِمن پننیٚن شُر ٮ۪ن ہِندِ س حقس منٛز لا حق لہٰذا کھوٚژِن تِم خُدا یس تہٕ سیز رٕچ کتھ کٔرِن۔یِم لُکھ ظُلمہٕ سان یتیمن ہُند مال چِھ کھیٚوان"
  4,10,"۔در حقیقت چِھ تِم نار سٍتۍ پنٕنۍ شکم  برا ن تہٕ تِم یِن ضرور جہنم کِس نارٕ اَلا وس منٛز ترا و نہٕ ۔ع"
  4,11,"۔تُہٕندٮ۪ن اولادن متعلق چُھ اللہ تعالیٰ تۅہیہِ ہدا یت دِوان زِ : مردٕ سُنٛد حصہ چُھ دۅ ن مستوراتن برابر ، ﴿چو نکہ شر یعتن چُھ خاندٲنی زند گی منٛز مردس پٮ۪ٹھ معٲشی ذمہٕ دٲرِین ہُند زیادہ بارتر وومُت تہٕ مستورات چَھن واریاہ ہَو معا شی ذمہٕ دٲرِیَو نِشہِ سکبدوش تھاوِمَژٕ، لہٰذا اوس اِنصا فُک تقا ضہٕ یٖی زِ میراث منٛزٕ گوٚژھ خا تو نہِ ہُنٛد حصہ مردس بہ نسبت کم یُن تھاو نہٕ۔﴾اگر ﴿میت سٕنزٕ وٲرِث ﴾ دۅ یو کھۅتہٕ زیادہ کورِ آسن تیٚلہِ گژِھہ تِمن زٕ تہٲیی دِنہٕ یُن۔﴿یۅہے حُکم چُھ دۅ ن کور ٮ۪ن ہُند تہِ ۔ مطلب چُھ یہِ زِ اگر کٲنٛسہِ شخصس نیچُو آسہِ نہٕ کینٛہہ بلکہ آسنس کور ے یا ژٕ، خوا ہ زٕ ہ کورِ آسنس یاد ۅیو کھۅتہٕ زیادہ،بہر حال سپدِ کُل وراژتُک ،3/2 یُم حصہٕ یِمن کورٮ۪ن منٛز تقسیم تہٕ با قی3/1یُم حصہٕ سپدِ با قی وٲرِثن منٛز تقسیم۔البتہ اگر میتس صرف اَکو ے لڑ کہٕ آسہِ تیٚلہِ چُھ اَتھ پٮ۪ٹھ اجما ع زِ با قین وٲرِثن ہٕنزِ غیر موجود گی منٛز بنہِ سُہ سار ی ما لُک وٲرِث ،تہٕ اگر با قی وٲرث موجو د آسن، تِمن یِیہِ پنُن حصہٕ دِنہٕ تہٕ با قی سورُے مال میلہِ أمۍ سٕے۔﴾ تہٕ ہرگاہ اکٲے  کوٗر وٲرث آسہِ تیٚلہِ چھےٚ نصف وراثت تٔمۍ سٕنز ،اگر میت صا حب اولاد آسہِ تیٚلہِ گژِھہ تٔمۍ سٕند یو والد ینو منٛزٕ پرٛتھ کٲنٛسہِ وراثت منٛزٕ شیُم حصہٕ میلُن۔﴿یعنی میت سٕندِس صا حب اولاد آسنہٕ کِس صوٗرتس منٛز آسہِ بہر حال میت سٕند یٚو والد ینو منٛزٕ پرٛتھ کانٛہہ 2/1حصُک حقدار، خوا ہ میتہٕ سٕنزٕ وٲرِث صرف کور یے یٲژٕ آسِتن یا نیٚچِوی یٲتۍ یا آسِتن نیچِو ۍ تہٕ کورِ ، یا آسِتن اکھ نیچُو یا اکھ کوٗر، روٗدۍ وۅ نۍ با قی3/2حصہٕ یِمن منٛز آسن با قی وٲرِث شر یک۔﴾ تہٕ اگر سُہ صا حبِ اولاد اوسنہٕ تہٕ مول مو ج آسہِ تٔمۍ سُنٛد وٲرِث تیٚلہِ گژِھہ ماجہِ یُن ترٛیُیم حصہٕ دِنہٕ ۔﴿مٲلِس ماجہِ ورٲے اگر بیٚیہِ کانٛہہ وٲرِث اوسنہٕ تیٚلہِ میلہِ با قی حصہٕ مٲلِس ۔نَتہٕ یِیہِ 3/2حصہٕ مٲلِس تہٕ با قی وٲرِثن دِنہٕ ۔ ﴾ تہٕ اگر میتس بٲے بیٚنہِ تہِ آسن تیٚلہِ آسہِ مو ج شیٚمہِ حصٕچ حقدار ۔﴿بٲے بیٚنہِ آسنہٕ کِس صوٗرتس منٛز چُھ ماجہِ ہُنٛد حصہٕ 3/1کہ بجایہِ 6/1کر نہٕ آمُت۔یِتھہٕ پٲٹھۍ یُس ماجہِ ہٕندِ حصہٕ منٛزٕ 6/1حصہٕ  نِنہٕ آو سُہ یِیہِ مٲلۍ سٕندِس حصس منٛز ترا و نہٕ تِکیازِ اَتھ صورتس منٛز چھےٚ مٲلۍ سٕنزٕ ذمہٕ دٲرِیہِ ہُران۔ یہِ روٗزِ ن وا ضح زِ اگر میت سٕندِۍ والد ین زند ہ آسن تیٚلہِ چُھنہٕ تٔمۍ سٕنز ن بیٚنیٚن با ین حصہٕ واتان۔﴾ ﴿یِم سٲر ی حصہٕ یِن تَمہِ وقتہٕ کڑ نہٕ﴾ ییٚلہِ سۅ وصیت یۅسہٕ میّتن کٔر مٕژ آسہِ ، پوٗرٕ یِیہِ کر نہٕ تہٕ یُس قر ض تس پٮ۪ٹھ آسہِ سُہ یِیہِ نکھہٕ والنہٕ ۔﴿وصیتٕچ ذکر اگر چہِ قر ضہٕ برونٛہہ چھےٚ کر نہٕ آمٕژ البتہٕ اُمتُک چُھ اَتھ پٮ۪ٹھ اجما ع زِ قر ض چُھ وصیتس پٮ۪ٹھ مقدّم۔ یعنی اگر میتس قر ض آسہِ تیٚلہِ یِیہِ ساروٕے برونٛہہ میت سٕندِ ترا و نہٕ آمتہِ مال منٛزٕ سُہ نکھہٕ والنہٕ، پتہٕ یِیہِ وصیت پوٗرٕ کر نہٕ تہٕ امہِ پتہٕ سپدِ وراثت تقسیم۔﴾ توٚہۍ چِھو نہٕ زانان زِ تُہٕندِس مٲلِس ماجہِ تہٕ تُہندٮ۪ن اولادن منٛز کُس چُھ نفع لحا ظہٕ تۅہیہِ زیادٕہ نکھہٕ۔یِم حصہٕ چِھ خُدا ین مُقرر کٔرِ مٕتۍ تہٕ اللہ تعالیٰ چُھ یقیناً سارِوٕے حقیقتو نِشہِ وٲقف تہٕ سار ے مصلحتہٕ زانن وول ۔"
  4,12,"تہٕ تُہٕنز و خاندارِ نیو یِکینژھاہ ترٛ وومُت آسہِ، تَمِیُک نصف میلیو تۅہیہِ اگر تِمہٕ بے اولاد آسن نَتہٕ چُھ اولاد آسنہٕ کِس صوٗرتس منٛز پتھ کُن تراو نہٕ آمتہِ مٲلُک 4/1 حصہٕ تُہُند ییٚلہِ سۅ وصیت پوٗرٕ یِیہِ کر نہٕ یۅسہٕ تِمو کٔر مٕژ آسہِ ، تہٕ یُس قر ض تِمو پتھ کُن تروومُت آسہِ سُہ یِیہِ نکھہٕ والنہٕ تہٕ تِمہٕ آسن تُہٕندِ تر کہٕ منٛزٕ ژوٗرِ مہِ حصہٕ چہِ حقدار اگر توٚہۍ بے اولاد ٲسِو نَتہٕ آسہِ صا حبِ اولاد آسنہٕ کِس صوٗرتس منٛز ٲٹھِم حصہٕ تِمن ہُند۔﴿یعنی خوا ہ اکھ خاندارِنۍ ٲسِتن یا ٲسِتن اکہِ کھۅتہٕ زیادٕہ ،اولاد آسنہٕ کِس صوٗرتس منٛز آسن تِمہٕ 8/1چہِ تہٕ اولاد آسنہٕ کِس صوٗرتس منٛز آسن4/1 چہِ حصہٕ دار تہٕ یہِ 4/1یا 8/1یِیہِ سا رِنٕے خاندارِ نیٚن منٛز برابر ی سان بٲگر او نہٕ ۔﴾ امہِ پتہٕ زِ یۅسہٕ وصیت تۅہیہِ کٔر مٕژ آسیو سۅ یِیہِ پوٗرٕ کر نہٕ تہٕ یُس قر ض تۅہیہِ تروومُت آسیو سُہ یِیہِ نکھہٕ والنہٕ۔ تہٕ اگر سُہ مرد یا زنانہٕ ﴿ییٚمۍ سُند میراث بٲگراوُن آسہِ ﴾ بےٚ اولاد تہِ آسہِ تہٕ تٔمۍ سُنٛد مول موج تہِ آسہِ نہٕ زِندٕہ مگر تٔمۍ  سُند اکھ بو ے یا اکھ بیٚنہِ آسہِ موجو د تیٚلہِ میلہِ بٲیس تہٕ بیٚنہِ پرٛتھ أکِس شیُیم حصہٕ تہٕ اگر بٲے بیٚنہِ اکہِ کھۅتہٕ زیادہ آسن تیٚلہِ آسن تِم کُل تر کہٕ کِس اکھ تہٲیی منٛز سٲر ی شر یک۔ ﴿یَتھ آیتس متعلق چُھ مفسر ن ہُنٛد اجما ع زِ اَتھ منز چُھ بایو تہٕ بیٚنیو نِشہِ مُراد اَخیا فی ﴿وۅرٕ﴾ بٲے تہٕ بیٚنہِ  یعنی یِم میتس سٍتۍ صرف ماجہِ ہٕندِ طر فہٕ رشتہٕ آسن تھاوان ﴿ماجہِ آسن کُنی ﴾ تہٕ مول آسہِ تِمن بیاکھ ۔روٗدۍ وۅ نۍ سخ بٲے بیٚنہِ ، تہٕ تِم وۅرٕ بٲے بیٚنہِ یِم مٲلۍ سٕندِ طر فہٕ میتس سٍتۍ رشتہٕ آسن تھاوان ،تِہُنٛد حُکم چُھ ییٚمی سوٗرکِس ٲخری آیتس منٛز ارشاد سپُد مُت۔﴾ اَمہِ پتہٕ زِ یۅسہٕ وصیت کر نہٕ آسہِ آمٕژ سۅ یِیہِ پوٗرٕ کر نہٕ ، تہٕ قر ض یُس میّتن تروومُت آسہِ یِیہِ نکھہٕ والنہٕ بشر طیکہ سُہ آسہِ نہٕ ضرر رسا ن۔﴿وصیتس منٛز چھےٚ ضرررسٲنی یہِ زِ تِتھہٕ پٲٹھۍ یِیہِ وصیت کر نہٕ ییٚمہِ سٍتۍ مستحق رشتہٕ دارن ہٕندۍ حقو ق تلف سپدان آسن۔تہٕ قر ضس منٛز چھےٚ ضرررسٲنی یہِ زِ انسان کرِ محض حق دارن محروم کر نہٕ خٲطرٕ خوا ہ مخو اہ پا نس پٮ۪ٹھ تِتھہِ قر ضُک اقرار یُس تٔمۍ ہِیوٚت مُتُے آسہِ نہٕ، یا کرِ بیٚیہِ کانٛہہ تِیُتھ ژھل ییمِیُک مقصد  یہِ آسہِ زِ حقدار گژھن میراث نِشہِ محروم سپدٕنۍ۔﴾ یہِ حُکم چُھ اللہ تعالیٰ سٕندِ طر فہٕ تہٕ اللہ تعالیٰ چُھ دانا و بینا تہٕ نر م خۅ ے ۔"
  4,13,"۔یِم چِھ اللہ تعالیٰ سٕندۍ مقرر کر نہٕ آمٕتۍ حد ،یُس اللہ تعالیٰ سٕنز تہٕ رسول ﴿صلی اللہ علیہ وسلمن ﴾ ہٕنٛز اطا عت کرِ تس کرِ خُدا تِتھیٚن با غن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان تہٕ یِمن با غن منٛز روزِ سُہ ہمیشہ تہٕ یٔہے چھےٚ بٔڈ کٲمیٲبی ۔"
  4,14,"۔تہٕ یُس اللہ تعالیٰ سٕنز تہٕ رسول ﴿صلی اللہ علیہ وسلمن ﴾ ہٕنٛز نافر مٲنی کرِ تہٕ تٔمۍ سٕندیو مقرر کر نہٕ آمتیو حدَو نِشہِ ژلہِ نیٚبر تس ترٛاوِ اللہ تعالیٰ نارس یَتھ منٛز سُہ ہمیشہ روزِ تہٕ تس خٲطرٕ چُھ رُسوا کر ن وول عذا ب ۔ ع"
  4,15,"۔تُہٕنز و مستوٗراتَو منٛزٕ یِمہٕ بدکٲری ہُند اَتُر کر ن تِمن پٮ۪ٹھ رٔٹِو پننیو منٛزٕ ژۅ ن نفر ن ہٕنٛز گوٲہی تہٕ اگر ژو ر نفر گوٲہی دِن، تیٚلہِ تھٲوِیوٗکھ تِمہٕ گھر ن منٛز بند یوٚت تام زن تِمن مو ت یِیہِ یا کڑِ اللہ تعالیٰ تِہِندِ خٲطرٕ کانٛہہ وَتھ،"
  4,16,"۔تہٕ تۅہیہِ منٛزٕ یِم اَمہِ کامہِ ہُنٛد اَتُر کر ن تِمن دۅ شوٕ نۍ دِیِو تکلیف پتہٕ اگر تِم تو بہٕ کر ن تہٕ پنُن اصلا ح کر ن تیٚلہِ ترٲوِ یوٗکھ یلہٕ تِکیازِ اللہ تعالیٰ چُھ سٮ۪ٹھاہ تو بہٕ قبول کر ن وول تہٕ رحم کر ن وول ۔ ﴿یہِ اوس بدکٲری متعلق ابتدٲیی حُکم ۔امہِ پتہٕ سپٕز سورہ نوٗرٕچ سۅ آیت نٲزِل یتھ منٛز مردس تہٕ زنا نہِ دۅ شوٕنۍ خٲطرٕ کُنُے حُکم دِنہٕ آوزِ تِمن گژھن ہتھ﴿100﴾ہتھ ﴿100﴾ ہتھ دُرٕ یِنۍ لگا و نہٕ  ۔﴾"
  4,17,"۔یہِ زٲنِو زِ خُدا یس پٮ۪ٹھ چُھ تو بہٕ کہ قبو لیتُک حق تِمنٕے لُکن خٲطرٕ یِمن نادٲنۍ کِنۍ کانٛہہ اَتُر چُھ گژھان،تہٕ امہِ پتہٕ چِھ جلدی تو بہٕ کران، یِتھیٚن لُکن پٮ۪ٹھ چُھ اللہ تعالیٰ پننہِ نظرِ عنا یت سٍتۍ بیٚیہِ تو جہ دِوان ،تہٕ اللہ تعالیٰ چُھ سارِنٕے کتھن ہٕنٛز خبر تھاون وول بیٚیہِ حکمت وول گا ٹُل۔"
  4,18,"۔ البتہٕ تو بہٕ چُھنہٕ تِمن لُکن خٲطرٕ کینٛہہ یِم بُرٕ کامہِ کران چِھ روزان،یوٚت تام زَن تِمو منٛزٕ کٲنٛسہِ ہٕندِ موتُک وقت چُھ واتان تمہِ وِزِ چُھ سُہ ونان زِ وۅ نۍ کوٚر مےٚ تو بہٕ ،تہٕ یِتھے پٲٹھۍ چُھنہٕ تو بہٕ تِمن لُکن خٲطرٕ تہِ یِم مر نس تام کٲفر روزن، یِتھیٚن لُکن خٲطرٕ چُھ اَسہِ دگ تُلوُن عذا ب تیار تھوومُت۔"
  4,19,"۔اے لوٗکو ،یِمو ایمان چُھو اوٚ نمُت تُہٕندِ خٲطرٕ چُھنہٕ یہِ حلال زِ زبردستی روٗزِ زنانن ہٕندۍ وٲرث بٔنِتھ۔﴿امہِ نِشہِ چُھ مُراد یہِ زِ خاندرا سٕندِ مر نہٕ پتہٕ مَہ روٗزِن تٔمۍ سٕندۍ خاندان وٲلۍ تس مۅ نڈِ زنانہِ میت سُند میراث زٲنِتھ تٔمۍ سٕندۍ ولی تہٕ وٲرث بٔنِتھ۔خاندارِنہِ ییٚلہِ خاندار موٗد،سۅ چھےٚ پتہٕ آزاد۔عدت گُزارِتھ یوٚت ییژِھہ توٚت گٔژِھن تہٕ یس سٍتۍ نکا ح کرُن ییژِھہ تس سٍتۍ کٔرِن ۔﴾ تہٕ نہ چُھ یہِ حلال زِ تِمہٕ کٔریوٗکھ تنگ تہٕ تَمہِ مہرُک کینٛہہ حصہٕ نِنٕچ کٔرِو کوشش یُس تۅہیہِ تِمن دِیتمُت چُھو،آ،اگر تِمہٕ کُنہِ ٹا کارٕ ہ بد چلنی ہٕنز مر تکب آسن ﴿تیٚلہِ چُھ ضرور تۅہیہِ تنگ کر نُک حق،مال نِنہٕ موجوٗب نہٕ کینٛہہ بلکہ بد چلنی ہُند سزا دِنہٕ موجوٗب﴾ تِمن سٍتۍ کٔرِو رٕتۍ پٲٹھۍ زند گی بسر اگر تۅہیہِ تِمہٕ نا پسند آسن بنان چُھ زِ اکھ چیز  آسیو نہٕ تۅہیہِ پسند مگر خُدا ین آسہِ تٔتھۍ منز واریاہ کینٛہہ رٕژَر تھو ومُت۔"
  4,20,"۔تہٕ اگر توٚہۍ أکِس خاندار نہِ ہٕنزِ جایہِ بیاکھ خاندارِنۍ اَننُک اِرادے کٔرِو تیٚلہِ اگر تۅہیہِ تس أکِس ڈھیرس یوت مالٕے کیازِ آسیو نہٕ دِیتُمت تمہِ منٛزٕ ہیٚیہِ زِ یوس نہٕ کِہِنۍ واپس، کیا توٚہۍ ہیٚوٕہ تس بہتان لگٲوِتھ تہٕ ٹا کارٕ ظُلم کٔرِتھ واپس؟"
  4,21,"۔تہٕ ٲخر کِتھہٕ پٲٹھۍ ہیٚوٗس ییٚلہِ زَن توٚہۍ اکھ أکِس نِشہِ چِھو لطف اندوز سپٕدۍ مٕتۍ تہٕ تِمو چُھہَو تۅہیہِ پختہٕ عہد ہیوٚتمُت؟"
  4,22,"۔تہٕ یِمن مستورا تن سٍتۍ تُہٕندیو ما لیو نکا ح آسہِ کوٚر مُت تِمن سٍتۍ مَہ کٔرِو ہر گز نکا ح مگر یہِ گۅڈٕ ہ سپُد تہِ سپُد۔﴿اَمیُک چُھنہٕ یہِ مطلب زِ زمانہٕ جٲہلیتس اندر ییٚمۍ وۅرٕ ماجہِ سٍتۍ نکا ح اوس کوٚر مُت سُہ ہیٚکہِ یہِ حکم یِنہٕ پتہٕ تہِ تس پننِس زوجیتس منز تھٲوِتھ، بلکہ چُھ مطلب یہِ زِ گۅڈٕ یِم اَمہِ قسمٕکۍ نکا ح کر نہٕ آمٕتۍ ٲسۍ تِمو نِشہِ زامٕتۍ شُرۍ یِن نہٕ یہِ حکم یِنہٕ پتہٕ حرا مٕکۍ ماننہٕ ،تہٕ نہ ہیٚکہِ پننیٚن مالیٚن ہٕندِ وراثت منٛزٕ تِہُند حق ختم سپدِتھ۔﴾ در حقیقت چھےٚ یہِ بے حیٲیی ہٕنز اکھ کٲم ،نا پسند ید ہ چھےٚ بیٚیہِ چھےٚ ناکارٕہ۔﴿اسلٲمی قا نو نس منٛز چھےٚ یہِ کٲم فوجدٲری جُر م تہٕ اَتھ پٮ۪ٹھ ہیٚکہِ پو لیس کاروٲیی کٔرِتھ۔﴾"
  4,23,"۔تۅہیہِ پٮ۪ٹھ آیہِ حرام کر نہٕ تُہٕنزٕ ماجہِ۔﴿ماجہِ ہُنٛد اطلا ق چُھ پننہِ ماجہِ تہٕ وۅرٕ ماجہِ دۅشوٕنۍ پٮ۪ٹھ سپدان، امہِ موجوٗب چھےٚ دۅ شو ے حرام۔امہِ علا وہ چھےٚ أتھۍ حکمس منٛز مٲلۍ سٕنز مو ج تہٕ ماجہِ ہٕنز موج تہِ شٲمِل ﴾،کورِ ﴿کورِ ہٕندِس حُکمس منٛز چھےٚ نیچِوۍ سٕنز کوٗر تہٕ کورِ ہٕنز کوٗرتہِ شٲمل﴾ بیٚنہِ ، ﴿پنٕنۍ بیٚنہِ تہٕ وۅ رٕ بیٚنہِ چھےٚ اَتھ حکمس منٛز یکسان۔﴾ پۅ پھہٕ تہٕ ماسہٕ، باوزٕ تہٕ بینزٕ،﴿یِمن سارِنٕے رشتن منٛز چَھنہٕ پننیٚن تہٕ وۅ رَن در میان کانٛہہ فر ق﴾ تہٕ تُہٕنزٕ تِمہٕ ماجہِ یِمو تۅہیہِ دود ٲسیو دِیتمُت تہٕ تُہنزٕ دۅ د بیٚنہِ، ﴿یَتھ کتھہِ پٮ۪ٹھ چُھ اُمّتس منٛز اتفا ق زِ أکۍ لڑ کن یا لڑ کی ییٚمِس خا تو نہِ ہُنٛد دۅ د آسہِ چوٚمُت تس خٲطرٕ چھےٚ سۅ خا تو ن ماجہِ ہِندِس حکمس منٛز تہٕ تٔمۍ سُند خاندار چُھس مٲلۍ سٕندِس حکمس منٛز ، تہٕ تمام تِم رِشتہٕ یِم اصلی ماجہِ تہٕ مٲلۍ سٕندِ تعلق سٍتۍ حرام چِھ سپدان،چِھ دۅ د ماجہِ تہٕ مٲلۍ سٕندِ تعلق سٍتۍ حرا م سپدان۔ تس شُرِس خٲطرٕ چُھنہٕ دۅدٕ ماجہِ ہُند سُے شُر حرام یس سٍتۍ تٔمۍ دۅ د آسہِ چوٚمُت بلکہ چِھ تٔمۍ سٕندۍ سٲر ی اولادتس پننیٚن با ین پننیٚن ہٕندۍ پٲٹھۍ تہٕ تِہِندۍ شُر ۍ چِھ تس خٲطرٕ پننیٚن با پتھٕر ن تہٕ بیٚنتھٕر ن ہٕندۍ پٲٹھۍ۔﴾ تہٕ تُہٕنز ن خاندارِنیٚن ہٕنزٕ ماجہِ ﴿ہَش ماجہِ ﴾ تہٕ تُہٕنز ن خاندارِنیٚن ہٕنزٕ کورِ یِمو تُہٕنز ن کۅ چھن منٛز پرورش لٔجمٕژ چھےٚ ﴿یعنی﴾ تِمن خاندارِنیٚن ہٕنزٕ کورِ یِمن سٍتۍ تُہُند تعلق دۅ ن بٲژن ہُند سپُد مُت آسہِ ۔﴿یِژھہ لڑ کی ہُند حرا م آسُن چُھنہٕ اتھ شر طس پٮ۪ٹھ مو قوف زِ تٔمۍ آسہِ وۅرٕ مٲلۍ سٕندِس گھرس منٛز پرورش حٲصل کٔرمٕژ۔اُمت کیٚن فقا ہن ہُند چُھ اتھ کتھہِ پٮ۪ٹھ تقریباً اجما ع زِ وۅرٕ کوٗر چھےٚ بہر حال انسانس پٮ۪ٹھ حرام خواہ تٔمۍ وۅرٕ مٲلۍ سٕندِ گھرِ پرورِش حٲصل ٲسِتن کٔرمٕژ یا متہٕ ٲسِتن ۔﴾ نَتہٕ اگر ﴿صرف نکا ح آسہِ سپُد مُت تہٕ﴾ دۅ ن بٲژن ہُند تعلق آسہِ نہٕ سپُد مُت تیٚلہِ ﴿یِیہِ نہٕ تۅہیہِ تِمہٕ ترٛٲوِتھ تِہنزن کوریٚن سٍتۍ نکا ح کر نس پٮ۪ٹھ﴾پرٛژھہٕ گٲر کر نہٕ تہٕ تُہٕندٮ۪ن تِمن نیچِو ٮ۪ن ہٕنزٕ خاندارِنہِ یِم تُہُندِ پُشتٕکۍ آسن۔ ﴿نیچوِۍ سٕندِی پٲٹھۍ چھےٚ زُر ٮ۪ن ہٕنزٕ خاندارِنہِ تہِ بُڈِ بَبن پٮ۪ٹھ حرام۔﴾تہٕ یِتہِ چُھ تۅہیہِ پٮ۪ٹھ حرام کر نہٕ آمُت زِ یِکہٕ وٹہٕ تھٲوِیوٗکھ زٕ بیٚننہِ نکا حس منٛز۔﴿نبی صلی اللہ علیہ وسلمن ہُند چُھ ارشاد زِ ماس تہٕ بیٚنزٕ تہٕ پۅپھ تہٕ باوزٕ تہِ چھےٚ یکہٕ وٹہٕ نکا حس منٛز تھاوِ نہِ حرام۔اتھ معا ملس منٛز گژِھہ یہِ اصو ل سمجُھن زِ تِژٕھہ زٕ ہ زنانہٕ جمع کر نہِ چُھ بہرحال حرام یِمن منٛز اگر اکھ مرد آسہِ ہے تیٚلہِ آسہِ ہے تٔمۍ سُند نکا ح دوٚیِمہِ سٍتۍ حرام ۔ ﴾ مگر یہِ گۅڈٕ سپُد تہِ سپُد اللہ تعالیٰ چُھ بخشن وول تہٕ رحم کر ن وول ۔﴿یعنی اَتھ پٮ۪ٹھ سپدِ نہٕ پرٕژٕھہ گٲر مگر ییٚمۍ شخصن کُفرٕ کِس حا لتس اندر زٕ ہ بیٚنہِ یکہٕ وٹہٕ نکا حس منٛز آسن تھاوِ مٕژ تس چھےٚ اسلام اَننہٕ پتہٕ اکھ تھا وٕ نۍ تہٕ اکھ ترٛاوٕنۍ ﴾"
  4,24,"تہٕ تِمہٕ مستوٗراتہٕ تہِ چھےٚ تۅہیہِ پٮ۪ٹھ حرا م یِمہٕ بیٚیہِ کٲنٛسہِ ہٕندِس نکا حس منٛز آسن ﴿محصنا ت﴾ ، البتہٕ تِژٕھہ مستوٗراتہٕ چھےٚ امہِ نِشہِ مُستثنیٰ یِمہٕ ﴿جنگس منٛز﴾ تۅہیہِ اتھس منٛز یِن ۔ ﴿یعنی یِمہٕ مستوراتہٕ جنگ منٛز گرفتار سپد ن تہٕ تِہٕندۍ کٲفر خاندار آسن دارُلحر بس منٛز تِمہٕ چَھنہٕ حرا م ، تِکیاز، دارُلحر ب پٮ۪ٹھہٕ دارُالاسلامس منٛز یِنہٕ پتہٕ سپٕدۍ تِہندۍ نکا ح ختم ۔ ﴾یہِ چُھ اللہ تعالیٰ سُند قانو ن ییٚمِچ پابند ی تۅہیہِ پٮ۪ٹھ لٲزِم چھےٚ کر نہٕ آمٕژ۔ یِمن ورٲے یژاہ مستوراتہٕ چھےٚ ،تُہٕندِ خٲطرٕ چُھ حلال کر نہٕ آمُت زِ تِمہٕ ہیٚکِیوٗکھ توٚہۍ پننیو مالَو ذر یعہ حٲصل کٔرِ تھ بشر طیکہ نکا ح کِس گنڈس منٛز کٔرِیوٗکھ تِم محفو ظ ،نَہ یہِ زِ آزاد شہو ت رٲنی لٲگِو کرٕنۍ پتہٕ یُس توٚہۍ ازدوٲجی زند گی ہُنٛد لُطف تِمن نِشہِ حٲصل کٔرِو، تَمہِ بد لہٕ کٔرِ و تِہندۍ مَہر بطور فر ض زٲنِتھ ادا، البتہٕ مہر مقرر سپد نہٕ پتہٕ اگر اکھ أکۍ سٕنزِ رضا مند ی سا ن تۅہیہِ در میان کانٛہہ  سمجھو تہٕ سپدِ تیٚلہِ چُھنہٕ تتھ منٛز کانٛہہ حر ج، اللہ تعالیٰ چُھ زانن وول تہٕ دانا۔"
  4,25,"۔تہٕ یَس شخصَس تۅہیہِ منٛزٕ یہِ طا قت آسہِ نہٕ زِ خاندٲنۍ مسلمان مستوراتن﴿مُحصناتن﴾ سٍتۍ کرِ نکاح تس پزِ تُہٕنز و تِمو لو نڈِ یو منٛزٕ کٲنٛسہِ سٍتۍ نکا ح کرُن یِمہٕ  تُہٕندِس قبضس منٛز آسن تہٕ مو من ﴿خا تو نہٕ ﴾ آسن اللہ تعالیٰ چُھ تُہٕندٮ۪ن ایمانن ہُنٛد حال ٹھیک پٲٹھۍ زانان،  توٚہۍ سٲر ی چِھو اَکی دَرِکۍ لُکھ لہٰذا کٔرِو تِہِندٮ۪ن سر پرستن ہٕندِ اجا زتہٕ تِمن سٍتۍ نکا ح تہٕ معر و ف طر یقہٕ سان کٔرِ و تِہِندۍ مَہر ادا تاکہ تِمہٕ روزن نکا ح کِس گنڈس منٛز محفو ظ ﴿مُحصنا ت﴾ بٔنِتھ، آزاد شہوت رٲنی کران پھیرن نہٕ تہٕ نَہ کر ن ژوٗرِ ژھیٚپہِ ٲشنٲیِیہِ ، پتہٕ ییٚلہِ تِمہٕ نکا ح کِس گنڈس منٛز محفو ظ سپد ن،تہٕ اَمہِ پتہٕ سپد ن کُنہِ بد چلنی ہنزٕ مر تکب ،تیٚلہِ چُھ تِمن پٮ۪ٹھ تَمہِ سزا بہ نسبت اوٚڈُے سزا یُس خاندٲنۍ مستوراتن ﴿محصنا تن ﴾ خٲطرٕ مُقرر چُھ۔﴿یتھ رکو عس منٛز چُھ مُحصنٰت دۅ ن مختلف معنین منٛز ورتاو نہٕ آمُت۔اکھ  خاندرٕ واجِنہِ مستوراتہٕ  یمن خاندار سٕنز حفا ظت حٲصل آسہِ ۔دوٚیُم خاندٲنۍ مستوراتہٕ یِمن خاندانٕچ حفا ظت حٲصل آسہِ، اگر چہِ تِمہٕ نیترٕ واجِنہِ آسن نہٕ ۔ آیت 24 ،ہَس منٛز چُھ مُحصنٰت لفظ لو نڈ ی ہٕندِ مقا بلہٕ بغیر خاندارٕ واجِنیٚن خاندٲنۍ مستوراتن خٲطرٕ وَرتاو نہٕ آمُت یِتھہٕ پٲٹھۍ زن آیت کہ مضمو ن نِشہِ صا ف ظٲہر چُھ۔ اَتھ بر عکس چُھ لو نڈِین خٲطرٕ محصنٰت لفظ گۅڈِنِکِس معنیس منٛز ورتاو نہٕ آمُت تہٕ صا ف لفظن منٛز چُھ فر ماو نہٕ آمُت زِ ییٚلہِ یِمن نکا ہٕچ حفا ظت حٲصل سپدِ ﴿فَاِ ذَآ اُحصِنَّ﴾ تیٚلہِ چُھ یِمن خٲطرٕ بد کٲر ی سپد نس پٮ۪ٹھ تمہِ سزا ہُک نصف یُس مُحصنٰتن یعنی بغیرِ خاندار واجِنیٚن خاندٲنۍ مستوراتن خٲطرٕ چُھ۔﴾ یہِ سہو لیت چھےٚ تۅہیہِ منٛزٕ تِمن لُکن خٲطرٕ پٲدٕ کر نہٕ آمٕژ،یِمن خاندرنَہ کر نہٕ کِنۍ پر ہیز گٲر ی ہُنٛد ٹھوٚٹھ پھُٹنُک اندیشہٕ آسہِ البتہ اگر توٚہۍ صبر کٔرِ و تیٚلہِ چُھ یہِ تُہٕندِ خٲطرٕ بہتر تہٕ اللہ تعالیٰ چُھ بخشنہٕ وول تہٕ رحم کر ن وول ۔ع"
  4,26,"۔اللہ تعالیٰ چُھ یژھان زِ تۅہیہِ پٮ۪ٹھ کرِ تِم طریقہٕ وا ضح تہٕ تِمنٕے طر یقن پٮ۪ٹھ پکنا وِ تۅہیہِ یِہٕنز پیر وی تۅہیہِ بروٗنٛٹھِم رٔتۍ لُکھ کران ٲسۍ، سُہ چُھ پنٕنۍ رحمت ہیٚتھ تۅہیہِ کُن ظۅن پھِر نُک اِرادٕہ تھاوان تہٕ سُہ چُھ زانن وول تہِ تہٕ دانا تہِ ۔"
  4,27,"۔آ، اللہ تعالیٰ چُھ تۅہیہِ پٮ۪ٹھ رحمت سان ظۅ ن پھِرُن یژھان مگر یِم لُکھ خۅ د پانہٕ پننہِ نفس کیٚن خو اہشا تن ہٕنز پیر و ی کران چِھ تِم چِھ یژھان زِ توٚہۍ گٔژِھو سیٚزِ وَتہِ نِشہِ ڈلِتھ دوٗر نیرٕ نۍ۔"
  4,28,"۔اللہ تعالیٰ چُھ تۅہیہِ پٮ۪ٹھہٕ پابند یہِ لوٚژراونہِ یژھان۔تِکیازِ انسان چُھ آمُت کمزور پٲدٕ کر نہٕ۔"
  4,29,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت۔پانہٕ وٲنۍ مَہ کھیٚیو اکھ أکۍ سٕندۍ مال بٲطِل طر یقو سٍتۍ۔لین دین گژِھہ سپدُن اکھ أکۍ سٕنزِ رضا مند ی سان ۔  بٲطل طر یقونِشہِ چُھ مُراد تِم سٲر ی طر یقہٕ یِم حقس خلا ف آسن تہٕ شر عی تہٕ اخلا قی طور آسن نا جٲیز۔اکھ أکۍ سٕنز رضا مند ی نِشہِ چُھ مُراد آزاد انہٕ زاننہٕ ماننہٕ آمٕژ رضا مندی ۔کُنہِ دباوس یا دو کھس تہٕ فر یبس پٮ۪ٹھ بناو نہٕ آمژِ رضا مند ی ہُند ناو گوٚۅ ونہٕ رضا مند ی۔﴾تہٕ پنُن پان مَہ کٔرِو قتل۔﴿یہِ کتھ ہیٚکہِ پٔتِمہِ کتھہِ ہٕنز پٔتِم ہَن تہِ ٲسِتھ تہٕ پانہٕ تہِ ہیٚکہِ مستقل کتھ ٲسِتھ۔اگر پٔتِمہِ کتھہِ ہٕنز پٔتِم ہَن مانو و ن تیٚلہِ چُھ اَمِیُک مطلب یہِ دوٚ یِمیٚن ہُند مال نا جٲیز طور کھیوٚن چُھ خۅ پنُن پان ہلا کتس منٛز ترٛاوُن۔تہٕ اگر یہِ مستقل کتھ مانو ن تیٚلہِ چِھ اتھ زٕ ہ معنی :اکھ یہِ زِ اکھ أکۍ سُند قتل مَہ کٔرِو، بیٚاکھ یہِ زِ خۅ د کشی مَہ کٔرِ و ۔﴾ پژھ کٔرِو زِ اللہ تعالیٰ چُھ تۅہیہِ پٮ۪ٹھ مہربان۔"
  4,30,"۔یُس  شخص ظُلم و زیادتی سان یہِ کرِ سُہ تراوون أسۍ ضرور نارس منٛز تہٕ یہِ کٲم چَھنہٕ اللہ تعالیٰ سٕندِ خٲطرٕ مُشکل کینٛہہ،"
  4,31,"۔ اگر توٚہۍ تِمو بڑیو بڑیو گنا ہو نِشہِ پر ہیز کران روٗزِ و یِمو نِشہِ ٹھا کھ چُھو یِوان کر نہٕ تیٚلہِ کروکھ أسۍ تُہٕنزٕ لۅ کچہِ مۅکچہِ بُرٲیِیہِ تُہندِ حسا بہٕ نِشہِ دوٗر تہٕ توٚہۍ کرو عز ت چہِ جایہِ دٲخل۔"
  4,32,"۔تہٕ مَہ کٔرِو تَمِیُک تمنا یِکینٛژھاہ خُدا ین تۅہیہِ منٛزٕ کٲنٛسہِ با قین ہٕندِس مقا بلس منٛز زیادٕہ چُھ دِیتمُت، یِکینژھاہ مردَو چُھ کمو و مُت تمہِ مُطٲبق چُھ تِہُند حصہٕ تہٕ یِکینٛژھاہ مستوراتَو چُھ کمو و مُت تمہِ مُطٲبق چُھ تِہُند حصہٕ، آ، خُدا یس روٗزِ و تٔمۍ سٕندِ فضلُک دُعا منگان یقیناً چُھ اللہ تعالیٰ  پرٛتھ چیزُک علم تھاوان۔"
  4,33,"۔تہٕ اَسہِ چِھ تَمہِ پرٛتھ تر کٕکۍ حقدار مُقرر کٔرِ مٕتۍ یِم والد ین تہٕ قر یبی رشتہٕ دار پتھ کُن تراون ،وۅ نۍ روٗدۍ تِم لُکھ یِمن سٍتۍ تۅہیہِ عہد و پیمان آسن تِمن دِیِو پنُن حِصہٕ ،یقیناً چُھ اللہ تعالیٰ پرٛتھ چیز س پٮ۪ٹھ نگرا ن۔ع ﴿عر ب کیٚن لُکن ہُند اوس قا عدٕہ زِ یِمن لُکن در میان دو ستی تہٕ بٲے بند تِکۍ عہد و پیمان سپدان ٲسۍ تِم ٲسۍ اکھ أکۍ سٕندِ میرا ثٕکۍ حقدار بنان ۔ یِتھے پٲٹھۍ یُس نیچو اوس یِوان بناو نہٕ سُتہِ اوس منگتہٕ سُند وٲرث بنان ۔ یتھ آیتس منٛز چُھ جٲہلیتُک یہِ طر یقہٕ منسوخ کٔرِ تھ فر ماو نہٕ آمُت زِ وراثت گژِھ تَمہ قٲعدہ مُطٲبق رشتہٕ دار ن منٛز تقسیم سپدٕ نۍ یُس اَسہِ مقرر چُھ کوٚر مُت ،البتہٕ یِمن لُکن سٍتۍ تۅہیہِ عہد و پیمان آسن تِمن ہیٚکوِ پننہِ زند گی منٛز پننہِ مر ضی مُطٲبق دِتھ ﴾"
  4,34,"۔ مرد چِھ مستورا تن پٮ۪ٹھ قَوّام۔﴿قوّام چِھ تس شخصس ونان یُس کٲنٛسہِ فردس یا اِدارس یا نِظا مٕکۍ معاملات دُرست حالتس منٛز چلا ونُک تہٕ اَمِچ حفا ظت  تہٕ رٲچھ راوٹھ کر نُک تہٕ امِکۍ ضروریات دستیا ب تھاو نُک ذِمہٕ دار آسہِ ۔﴾ اتھ بُنیادس پٮ۪ٹھ زِ خُدا ین چھےٚ تِمو منٛزٕ أکِس دِژمٕژ دوٚ یِمِس پٮ۪ٹھ فضیلت، تہٕ اتھ بِنا ہس پٮ۪ٹھ زِ مرد چِھ پنٕنۍ مال خر چ کرا ن، وۅ نۍ یِمہٕ صا لح مستو را تہٕ چھےٚ تِمہٕ چھےٚ  فر مابنردار آسان تہٕ مر دن پٔتۍ کِنۍ چھےٚ اللہ تعالیٰ سٕندِس حفا ظتس  تہٕ نگرٲنی منٛز تِہندٮ۪ن حقو قن ہٕنز حفا ظت کران تہٕ یِمن مستوراتن نِشہِ تۅہیہِ بد خو بی ہُند اندیشہِ آسہِ تِمہٕ سمجھٲوِ یوٗکھ، خوا ب گا ہَو منٛزٕ روٗزِ و تِمن نِشہِ بیٚو ن تہٕ لٲیوٗکھ۔﴿اَتھ چُھنہٕ یہِ مطلب  یہِ زِ  ترٛ یشو ے کامہِ گژھن بیک وقت کر نہٕ یِنہٕ، بلکہ چُھ مطلب یہِ زِ بدخو یی ہٕندِس حا لتس منٛز چُھ یِمن تر یشوٕ نۍحا لتن ہُنٛد اجا زت ۔وۅ نۍ روٗز یِمن  پٮ۪ٹھ عمل در آمد ،تیٚلہِ گژِھہ بہر حال اَتھ منٛز قصورس تہٕ سزا ہس در میان تنا سُب آسُن، تہٕ یَتھ جایہِ لۅ تہِ وا یہِ تدبیرِ سٍتۍ اصلا ح ہیٚکہِ سپدِ تھ تتھ جایہِ گژِھہ نہٕ سخت تد بیرس کٲم ہیٚنۍ۔حضور صلی اللہ علیہ وسلمو ییٚلہِ  تہِ خاندارِ نیٚن لا یِنُک اجازت چُھ دِیتمُت سُہ چُھکھ با دِل نا خو استہٕ دِیتمُت تہٕ توتہِ چُھکھ یہِ چیز نا پسند فر مو و مُت۔﴾ پتہٕ اگر تِمہٕ تُہٕنزٕ فر مانبردار سپدن تیٚلہِ مَہ کٔرِ یو خوا مخواہ تِمن پٮ۪ٹھ دست درٲزی خٲطرٕ بہانہٕ تلا ش،یقین تھٲوِ و زِ پٮ۪ٹھہٕ کنہِ چُھ اللہ تعالیٰ مو جو د یُس بوٚڈ تہٕ بالا تر چُھ۔"
  4,35,"۔تہٕ اگر تۅہیہِ کُنہِ وِزِ خاندارس تہٕ خاندارِ نہِ ہٕندۍ تعلقا ت بِگرٕنُک اند یشہِ آسیو ۔تیٚلہِ کٔرِ یوٗن اکھ حَکم مردٕ سٕند یو رشتہٕ دارَو منٛزٕ تہٕ اکھ زَنہِ ہٕند یو رشتہٕ دارو منٛزٕ مُقرر،تِم دۅ شو ے ﴿اگر ﴾ اصلا ح یژھن کرُن تیٚلہِ کَڑِ  اللہ تعالیٰ تِمن دۅ شوٕ نۍ در میان مو افقتٕچ صورت ۔﴿دۅ شوٕ نۍ نِشہِ چُھ مُراد ثٲلث تہِ تہٕ زٕ ہ بٲژتہِ ۔ پرٛتھ لڑا یہِ منٛز چُھ صلح سپدنُک امکان بشر طیکہ دۅ شو ے دٔرۍ گژھن صلح پسند آسٕنۍ تہٕ مٔنزِ م تہِ گژھن یژھان آسٕنۍ زِ دۅ ن در ٮ۪ن منٛز گژِھہ کُنہِ پٲٹھۍ صفٲیی سپدٕ نۍ ۔ ﴾ اللہ تعالیٰ چُھ سورُے کینٛہہ زانان تہٕ بیٚیہِ چُھ با خبر ۔"
  4,36,"۔تہٕ توٚہۍ سٲر ی کٔرِ و اللہ تعالیٰ سٕنز بند گی ، تس سٍتۍ مَہ بناوِ یوٗن کانٛہہ شر یک، مٲلِس ماجہِ سٍتۍ کٔرِ و نیک برتاو ،قرا بت دارن تہٕ یتیمن تہٕ مسکینن سٍتۍ کٔرِ و رُت سلو ک تہٕ بیٚیہِ کٔرِ و ہمسایہِ رشتہٕ دارس سٍتۍ تہٕ غیر زان ہمسایس سٍتۍ تہٕ سٍتۍ بٲجِس سٍتۍ ،﴿امہِ نِشہِ چُھ مُراد دوست یُس سٍتۍ آسہِ تہٕ سُہ شخص تہِ یس سٍتۍ کُنہِ جایہِ کُنہِ تہِ وقتہٕ پکُن پیٚیہِ ۔ مثلاً توٚہۍ چِھو بازر نیران، بیاکھ نفر اتہِ چُھ تۅہیہِ سٍتۍ پکان یا کُنہِ وا نس پٮ۪ٹھ ٲسِو توٚہۍ سودا رَٹا ن تہٕ بیاکھ کانٛہہ خریدار تہِ آسہِ تۅہیہِ نِشہِ بِہِتھ ،یا سفرس دوران آسہِ بیٚیہِ کانٛہہ شخص تُہُند ہمسفر۔یہِ عارضی ہمسا یگی تہِ چھےٚ پرٛتھ مہذ ب تہٕ شر یف انسانس پٮ۪ٹھ اکھ حق عٲید کرا ن ییٚمیُک تقا ضہٕ یہِ چُھ زِ سُہ کٔرِ ن حتی الامکان تس سٍتۍ نیک سلو ک تہٕ تس تکلیف دِنہٕ نِشہِ روٗزِ ن پتھ۔﴾ تہٕ مسا فرس سٍتۍ ،تہٕ تِمن لو نڈی غلا من سٍتۍ یِم تُہندِس قبضس منٛز آسن تھٲوِ و احسا نُک معا ملہٕ ،یقین تھٲوِو اللہ تعالیٰ چُھنہٕ تِتھِس شخصس پسند کرا ن  یُس پنِنس زٕ چھرس منٛز مغرور آسہِ ،بیٚیہِ کرِ پننِس بجر س پٮ۪ٹھ فخر۔"
  4,37,"۔تہٕ تِتھۍ لُکھ تہِ چِھنہٕ خُدا یس پسند یِم کنجو سی کران چِھ تہٕ با قین تہِ چِھ کنجو سی ہُند ہدا یت دِوان ۔تہٕ یِکینژھاہ خُدا ین تِمن پننہِ فضلہٕ سٍتۍ دِیتمُت چُھ تتھ چِھ چُھپاوان،نعمتُک انکار کر ن والیٚن تِتھیٚن لُکن خٲطرٕ چُھ اَسہِ رُسوا کر ن وول عذا ب دستیا ب تھو ومُت۔"
  4,38,"۔ تہٕ تِم لُکھ تہِ چِھ خُدا یس نا پسند یِم پنٕنۍ مال محض لُکن ہاو نہٕ مۅ کھہٕ چِھ خر چ کرا ن۔ تہٕ در حقیقت نَہ چُھ تِمن خُدا یس پٮ۪ٹھ ایمان تہٕ نَہ چُھکھ ٲخرتس پٮ۪ٹھ ،پوٚز چُھ یہِ زِ شیطا ن یَس تہِ رفیق بنیا و تَس سپٕز سٮ۪ٹھاہ  بُرٕ رفا قت حٲصل۔"
  4,39,"۔ٲخر کار کۅسہٕ آفت یِیہِ ہے یِمن لُکن پٮ۪ٹھ اگر یِم خُدا یس تہٕ ٲخر ت کِس دۅ ہس پٮ۪ٹھ ایمان تھاوہَن تہٕ یِکینژھاہ خُدا ین دِیتمُت چُھ تمہِ منٛزٕ کر ہَن خر چ ہرگاہ یِم یہِ کر ہن تیٚلہِ ہیٚکہِ ہے نہٕ خُدا یس نِشہِ تِہنزِ نیکی ہُند حال ژھا یہِ روٗزِ تھ۔"
  4,40,"۔اللہ تعالیٰ چُھنہٕ کٲنٛسہِ پٮ۪ٹھ ذرّس برابر ظُلم کران اگر کانٛہہ اکھ نیکی کرِ اللہ تعالیٰ چُھ تتھ دۅ گنہٕ کرا ن تہٕ پتہٕ چُھ پننہِ طر فہٕ بوٚڈ اجر عطا کران۔"
  4,41,"۔ پتہٕ سوٗنچِو زِ تمہِ وقتہٕ کیا کر ن یِم ییٚلہِ أسۍ پرتھ اُمّت منٛزٕ اکھ گوا ہ اَنو و ن تہٕ یِمن لُکن پٮ۪ٹھ کرَو توٚہۍ ﴿یعنی محمد صلی اللہ علیہ وسلم ﴾ گواہ سٕندِ حیثیت کھڑا ۔"
  4,42,"۔تمہِ وقتہٕ کر ن تِم سٲر ی لُکھ تمنا یِمو رسول ﴿صلی اللہ علیہ وسلمن ﴾ ہٕنز کتھ مٲنۍ نہٕ تہٕ تِہٕنز نا فر مٲنی روٗدۍ کران زِ کا ش زمین پھٹہِ ہے تہٕ تِم گژھن تٔتھۍ منٛز ،تَتہِ ہیٚکن نہٕ تِم پنٕنۍ کانٛہہ کتھ خُدایس نِشہِ ژوٗرِ تھٲوِتھ۔ع"
  4,43,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ییٚلہِ توٚہۍ نَشہِ کِس حالتس منٛز ٲسِو تیٚلہِ گٔژھۍ زِ یو نہٕ نمازِ نکھہٕ۔﴿یہِ چُھ شرابس متعلق دوٚیُم حُکم۔گۅڈنِیُک حکم اوس سُہ یُس سورۂ بقر ہ ، آیت 219 ،ہَس منٛز آو ۔﴾ نماز گژِھہ تمہِ وقتہٕ پرٕنۍ ییٚلہِ تۅہیہِ پے آسہِ زِ توٚہۍ کیا چِھو ونان ۔﴿یعنی نمازِ منٛز گژِھہ انسانس یوٗتاہ ہوش روزُن ز سُہ گژِھہ زانُن زِ سُہ کیا چیز چُھ پننہِ زبٲنۍ سٍتۍ ادا کران، تہِ گژِھہ نہٕ آسُن زِ سُہ گژِھہ کھڑا نماز پر نہٕ خٲطرٕ تہٕ شروع کرِ کانٛہہ غز ل۔﴾ تہٕ یِتھے پٲٹھۍ مَہ گژِھو جنا بت کِس حا لتس منٛز تہِ نمازِ نز دیک ، یوٚت تام نہٕ غسل کٔرِ و ،﴿جنا بت نِشہِ چُھ مُراد سۅ گند گی یۅسہٕ مُبا شر ت سٍتۍ یا نیند رِ دوران مادٕہ خٲرِج سپد نہٕ سٍتۍ لا حق چھےٚ سپدان۔﴾ اِلّا یہِ زِ وَتہِ ٲسِو پکان۔﴿فقہا ہَو تہٕ مُفسر و منٛزٕ چُھ أکۍ دٔرۍ اَمہِ آیتُک یہِ مفہو م سمجھمُت زِ جنا بت کِس حا لتس منٛز گژِھہ نہٕ مسجدِ منٛز گژُھن اِلّایہِ زِ کُنہِ کامہِ خٲطرٕ پیٚیہِ مسجدِ مٔنٛزۍ نیرُن۔دوٚیُم دوٚر چُھ اَمہِ نِشہِ سفر مُراد نِوان ۔ یعنی اگر انسان سفر کِس حا لتس منٛز آسہِ تہٕ جنا بت سپدیٚس لا حق تیٚلہِ ہیٚکہِ تیمُم کٔرِ تھ۔﴾ تہٕ ہرگاہ کُنہِ وِزِ یہِ سپدِ زِ توٚہۍ ٲسِو بیمار یا ٲسِو سفرس منٛز یا تۅہیہِ منٛزٕ آو کانٛہہ شخص رفعِ حا جت ﴿پیشا ب ﴾ کٔرِ تھ یا تۅہیہِ آسیو خاندارِ نیٚن سٍتۍ لمس کوٚر مُت۔﴿اتھ کتھہِ منٛز چُھ اختلا ف زِ لَمس یعنی چُھوُن نِشہِ کیا چُھ مُراد۔ واریاہن اِما من ہٕنز راے چھےٚ زِ امہِ نِشہِ چُھ مُراد مُباشرت  تہٕ یٔہے راے چھےٚ امام ابو حنیفہ رحمتہ اللہ علیہ تہٕ تِہٕندیو اصحابو اختیار کٔرمٕژ ۔اتھ برعکس چھُ کینژھن دوٚیِمین فقہاہن نزدیک اَمہِ نِشہِ مُراد چُھوُن یا اتھہٕ لاگُن تہٕ یٔہے راے چھےٚ امام شا فعی رحمتہ اللہ ہن اختیار کٔرمٕژ۔امام ما لک رحمتہ اللہ ہن ہٕنز راے چھےٚ زِ اگر مرد یا زنانہٕ اکھ أکِس شہوٲنی جذ با تو سان اتھہٕ لاگن تیٚلہِ پھُٹہِ تِمن وضو ، البتہ اگر شہوٲنی جذبا تو ورٲے أکۍ سُند جسم دوٚ یِمِس سٍتۍ مَس﴿ Touch﴾ سپدِ تیٚلہِ چُھنہٕ اَتھ پرواے۔﴾تہٕ اگر آب میلہِ نہٕ تیٚلہِ  کٔرِ و پاک میٚژِ سٍتۍ تیمُم تہٕ اَمہِ سٍتۍ کٔرِ و پننیٚن بُتھیٚن تہٕ اَتھن پٮ۪ٹھ مسح، ﴿حُکمٕچ تفصیلی صورت چھےٚ یہِ زِ ہرگاہ انسان بے وضو چُھ یا تس چُھ غسلُک حا جت تہٕ آب چُھنہٕ میلان تیٚلہِ ہیٚکہِ تیمُم کٔرِ تھ نماز پٔرِ تھ۔اگر مریض چُھ تہٕ غُسل یا وضو کر نہٕ سٍتۍ چُھس نقصا نُک اندیشہِ تیٚلہِ ہیٚکہِ آب آسنہٕ با و جو د تیمُم کِس اجازتس فٲیدٕہ تُلِتھ۔﴾بے شک چُھ اللہ تعالیٰ نر می کٲم ہیٚنہٕ وول تہٕ مغفر ت کر ن وول ۔"
  4,44,"۔کیا  تۅہیہِ وُچھوٗکھہٕ تِم لُکھ تہِ یِمن کتا بہِ ہٕندِ علمُک کینٛہہ حصہٕ دِنہٕ چُھ آمُت؟ تِم چِھ خۅد ضلا لتٕکۍ خریدار بٔنِتھ ،تہٕ یژھان چِھ زِ توٚہۍ تہِ ڈٔلِو وَتہِ نِشہِ"
  4,45,"۔اللہ تعالیٰ چُھ تُہند ٮ۪ن دُشمنن ٹھیک پٲٹھۍ زانان تہٕ تُہندِ حما یت تہٕ مددگٲر ی خٲطرٕ چُھ بس اللہ تعالیٰ کٲفی ۔"
  4,46,"۔یِمو لُکو یہو دیتُک طر یقہٕ اختیار چُھ کوٚر مُت تِمن منٛز چِھ کینٛہہ لُکھ یِم لفظن پننہِ جایہِ نِشہِ پھِران چِھ ۔﴿اتھ چِھ ترےٚ مطلب:اکھ یہِ زِ اللہ تعالیٰ سٕنزِ کتا بہِ منٛز چِھ ردو بد ل کرا ن۔دوٚیُم یہِ زِ پننہِ تٲویلہٕ کٔرۍ کٔرۍ چِھ کتا بہِ ہٕندٮ۪ن آیاتن ہٕندی معنی کتہِ پٮ۪ٹھہٕ کورو اتنا و ان۔ترٛییُم یہِ زِ محمد صلی اللہ علیہ وسلم تہٕ تِہندٮن پیرو کارن ہٕندِ س صحبتس منٛز یِتھ چِھ تِہٕنزٕ کتھہٕ بوزان تہٕ واپس نیٖرِ تھ چِھ لُکن برونٹھہٕ کنہِ غلط طر یقہٕ روایت کرا ن ،کتھ چھےٚ آسا ن اَکھ وَننہٕ آمٕژ تِم چِھ پننہِ شرا رتہٕ بیاکھ معنی لُکن نِشہِ پھٔہلاوان۔﴾تہٕ دینِ حقس خلاف چِھ بُرٲیی کر نہٕ مۅ کھہٕ پننہِ زیٚوٕ ہ اورٕ یو ر پھِرِ تھ وَنان ۔سَمِعنَا وَعَصَینَا ﴿ یعنی ییٚلہِ  تِمن اللہ تعالیٰ سٕندۍ احکام چھِ بوزناونہٕ یِوان تہٕ تِم چھِ بڈِ ونان سَمِعَنَا اَسہِ بوٗز تہٕ لۅتہِ چھِ ونانعَصَینَااَسہِ کوٚر نہٕ قبو ل۔ یا چِھ اَطَمعنَا اسہِ کوٚر قبو ل  لفظُک تلفظ تِتھہٕ پٲٹھۍ زیٚو پھِرِ  تھ کڑا ن زِ سُہ چُھ عَصَینَا بنان۔﴾ تہٕ اِسمَعَ غَیرَ مُسمَعِ۔﴿یعنی دورانِ گفتگو ییٚلہِ تِم کانٛہہ کتھ محمد صلی اللہ علیہ وسلمس چِھ وَنٕنۍ یَژھان تیٚلہِ چِھ وَنان ،اِسمَعَبوزِو  تہٕ پتہٕ چِھ سٍتی وَنان ،غیر مُسمَعِ تہِ ، یتھ زٕ ہ معنی چِھ ۔اکھ مطلب چُھس زِ توٚہۍچھِو تِتھۍ محتر م زِ تۅہیہِ یِیِو نہٕ کانٛہہ کتھ خلا فِ مر ضی بو زناونہٕ ۔دوٚیُم مطلب چُھس زِ توٚہۍ چِھو نہٕ اَتھ قٲبِل زِ کانٛہہ بوزناو یو تۅہیہِ کینٛہہ۔بیاکھ اکھ مطلب چُھ یہِ زِ اللہ تعالیٰ بوزِ ن توٚہۍ بٔنِو زٔرۍ۔﴾ بیٚیہِ چِھ ونان رَاعِنَا ﴿اَمِچ تشر یح چھےٚ سورۂ بقرۂ آیت نمبر 104،کِس وضا حتس منٛز کر نہٕ آمٕژ۔﴾ حالانکہ اگر تِم وَنہنسَمِعنَا وَ اَطعنَابیٚیہِ اِسمَع تہٕ اُنظُر نَا تیٚلہِ اوس یہِ تِہِندی خٲطرٕ بہتر تہٕ یہِ اوس زیادہ راست بٲزی ہُند طریقہٕ مگر تِمن پٮ۪ٹھ چھےٚ تِہِندِ بٲطل پرستی ہٕندِ بدولت اللہ تعالیٰ سٕنز لعنت ؤژھمٕژ،امہِ موجو ب چِھ تِم کمٕے پہن ایمان انان۔"
  4,47,"۔اے تِمو لوٗکو یِمن کتا ب ٲس دِنہٕ آمٕژ مٲنِو سۅ کتا ب یۅسہٕ وۅ نۍ اَسہِ نٲزِل چھےٚ کٔر مٕژ تہٕ یۅسہٕ کتا ب تتھ کتا بہِ تصد یق تہٕ تٲیید چھےٚ کران یۅسہٕ تۅہیہِ نِشہِ گۅڈٕ پٮ۪ٹھے موجو دٲس اَتھ پٮ۪ٹھ أنِو ایمان اَمہِ برونٛٹھ زِ أسۍپھرِ و تُہٕندۍ بُتھۍ خرا ب کٔرِ تھ پتھ کُن یا تِم کروکھ تِتھے پٲٹھۍ لعنت زدٕہ یِتھہٕ پٲٹھۍ سبت والیٚن سٍتۍ اَسہِ کوٚر مُت اوس ﴿وُچِھو تشر یح:سورۂ  بقرہ آیت :65﴾ تہٕ یاد تھٲوِو اللہ تعالیٰ سُند حُکم چُھ نٲفذ سپدِ تھ روزان۔"
  4,48,"۔اللہ تعالیٰ چُھنہٕ بس شِر کَسٕے یو ت معا ف کران اَمہِ ورٲے یِم تہِ با قی گنا ہ چِھ ،یس خٲطرٕ سُہ یژھان چُھ تس چُھ معا ف کران، خُدا یس سٍتۍ ییٚمۍ بیٚیہِ کانٛہہ شر یک ٹھہروو تٔمۍ کوٚر سٮ۪ٹھاہ بوٚڈ اَپُز تصنیف ،بیٚیہِ کٔرٕن سخت بَڑِ گنا ہٕچ کتھ ۔"
  4,49,"۔کیا تۅ ہیہِ وُچھوٗکھ تِم لُکھ تہِ یِم پننہِ نفس چہِ پٲکیز گی ہٕندۍ سٮ۪ٹھاہ دَم چِھ دِوان ؟ حالانکہ پٲکیز گی یس یژھان چُھ تس چُھ اللہ تعالیٰ عطا کران تہٕ ﴿یۅسہٕ پٲکیز گی تِمن میلان چَھنہٕ تہٕ درحقیقت ﴾ چُھنہٕ تِمن پٮ۪ٹھ ذرس برابر ظُلم یِوان کر نہٕ۔"
  4,50,"۔وُچِھتو ، یِم چِھنہٕ خُدا یس پٮ۪ٹھ تہِ اَپُز الزام لا گنس ہِرا سہٕ کران، تہٕ تِہندِ ٹا کارٕ ہ گنا ہ گار آسنہٕ خٲطرٕ چُھ یۅ ہے اکھ گناہ کٲفی۔ع"
  4,51,"۔کیا تۅہیہِ وُچھوٗکھ نا تِم لُکھ یِمن کتا بہِ ہٕندِ علمہٕ منٛزٕ کینٛہہ حصہ چُھ دِنہٕ آمُت تہٕ تِہُند حا ل چُھ یہِ زِ تِم چِھ جِبت تہٕ طا غو ت مانان ۔﴿ جِبت :اَتھ چِھ معنے بے حقیقت ، بے اصل تہٕ بے فٲیدہ چیز۔اسلام چہِ زبٲنۍ منٛز چِھ جو د، کہا نت ﴿جو تش﴾ فا ل گیر ی، شگو ن، مہو رت تہٕ با قی تمام ؤہمی تہٕ خیٲلی کتھہٕجِبت  لفظس سٍتۍ تعبیر کر نہٕ آمٕژ۔طا غوت: تشر یح خٲطرٕ وُچُھو سورۂ بقر ہ آیت نمبر :256﴾ بیٚیہِ چِھ کٲفر ن متعلق ونان زِ ایمان اَنن والیو کھۅتہٕ چِھ یِمے زیادہ صحیح وَتہِ پٮ۪ٹھ ﴿یتھ جا یہِ چِھ کٲفر مُراد مشر کین عر ب ﴾"
  4,52,"۔یِتھی لُکھ چِھ یِمن پٮ۪ٹھ خداین لعنت چھےٚ کٔر مٕژ تہٕ یس پٮ۪ٹھ خُدا ے لعنت کرِ پتہٕ وُچھوٗن نہٕ توٚہۍ تٔمۍ سُند کانٛہہ مددگار۔"
  4,53,"۔ کیا حکو متس منٛز چھا یِہُنٛد کانٛہہ حصہٕ؟ اگر یہِ آسِہے تیٚلہِ دِہن نہٕ یِم با قین اکھ کھٔنڈہار تہِ ۔"
  4,54,"۔پتہٕ کیا یِم چھا با قین سٍتۍ امہِ موجوٗب حسد کران زِ خُدا ین چِھ تِم پننہِ فضلہٕ سٍتۍ نوٲزِ مٕتۍ؟ اگر یہِ کتھ  چھےٚتیٚلہِ گژِھہ یِمن پے لگُن زِ اَسہِ کٔر ابرا ہیم ﴿علیہ السلام﴾ سٕندٮ۪ن اولادن کتا ب تہٕ حکمت عطا بیٚیہِ بخشُک مُلکِ عظیم۔"
  4,55,"۔مگر تِمو منٛزٕ اوٚن کٲنٛسہِ اَتھ پٮ۪ٹھ ایمان تہٕ کٲنٛسہِ پھِیرُ اَمہِ نِشہِ بُتھ ،تہٕ بُتھ پھر ن والیٚن خٲطرٕ چُھ بس جہنمُک شعلہٕ وُن نارٕ ے کٲفی۔﴿یاد گژِھہ تھاوُن زِ یَتھ جایہِ چُھ بنی اسرا یل چَن  حٲسدا نہٕ کتھن جوا ب دِنہٕ یِوان ۔ اَمہِ جوا بُک مطلب چُھ یہِ زِ ٲخر کتھ کتھہِ پٮ۪ٹھ چِھو توٚہۍ لُکھ دَزان؟توٚہۍ تہِ چِھو ابرا ہیم علیہ السلام سٕندۍ اولاد تہٕ یِم بنی اسما عیل علیہ السلام سٕندۍ اولادتہِ چھِ ابراہیم علیہ السلام سٕندی اوالاد۔اَسہِ یُس وعدٕہ ابرا ہیم علیہ السلامس سٍتۍ دُنیا کہ اِمامتُک کوٚر مُت اوس سُہ اوس آل ابرا ہیم علیہ السلام منٛزٕ صرف تِمن لُکن خٲطرٕ یِم سانہِ سوز نہٕ آمژِ کتا بہِ ہٕنز تہٕ حکمتٕچ پیر وی کر ن۔یہِ کتا ب تہٕ حکمت ٲس گۅڈٕ اَسہِ تۅہیہِ نِشہِ سوٗز مٕژ مگر یہِ ٲس تُہٕنز نا لا یقی زِ تۅہیہِ پھیٚرُ و اَمہِ نِشہِ بُتھ۔وۅ نۍ دِیُت اَسہِ سُے چیز بنی اسمٰعیلس  تہٕ یہِ چھےٚ یِہٕنز خۅش نصیبی زِ یِمَو چُھ اَتھ پٮ۪ٹھ ایمان اوٚ نمُت ۔﴾"
  4,56,"۔یِمو لُکو سٲنۍ آیات ماننہٕ نِشہِ انکار چُھ کوٚر مُت تِم تراووکھ أسۍ یقیناً نارس منٛز تہٕ ییٚلہِ تِہِندِ جسمُک مٕسلہٕ گٔلِتھ مۅ کلہِ تہٕ تتھ جایہِ کرو أسۍ بیاکھ مٕسلہٕ پٲدٕ، تا کہ تِم وُچَھن ٹھیک پٲٹھۍ عذا بُک مزٕ ہ، اللہ تعالیٰ چُھ بٔڑ قدرت تھاوان تہٕ پنٕنۍ فٲصلہٕ عملا ونٕچ حکمت چُھ ٹھیک پٲٹھۍ زانان ۔"
  4,57,"۔تہٕ یِمو لُکو سٲنۍ آیات مٲنۍ تہٕ نیک عملہٕ کر یکھ تِم کروکھ أسۍ تِتھیٚن با غن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان ییٚتہِ تِم ہمیشہ روزن تہٕ تِمن میلن پٲکیز ہ خاندارِنہٕ تہٕ تِم تھاوو کھ أسۍ گٔنِس شیٚہجار س تل۔"
  4,58,"۔مسلمانو، اللہ تعالیٰ چُھ تۅہیہِ حکم دِوان زِ امانت کٔرِ و اہلِ امانتن حوالہٕ تہٕ ییٚلہِ لُکن در میان فٲصلہٕ کٔرِ و تیٚلہِ کٔرِ و عدلہٕ سان، ﴿یعنی توٚہۍ روٗزۍ زیٚو تِمو بُرٲیو نِشہِ بٔچِتھ یِمن منٛز بنی اسرا یل مبتلا چِھ سپٕدۍ مٕتۍ۔ بنی اسرا یل چو بنیادی غلطیو  منٛزٕ ٲس اکھ غلطی یہِ زِ تِمو لٲگۍ پننِس انحطا ط کِس زمانس منٛز امانت،یعنی ذمہٕ دٲر ی ہٕندۍ منصب تہٕ مذ ہبی پیشوٲیی تہٕ قو می سردٲر ی ہٕندۍ مر تبہ تِتھیٚن لُکن دِنۍ یِم نا اہل ، کم ظر ف ، بد اخلا ق ،بد دیا نت تہٕ بد کار ٲسۍ ۔نتیجہ درٛا ویہِ زِ بُرٕ لُکن ہٕندِس قیا دتس منٛز روٗد سورُے قو م خرا ب سپدان۔مسلمانن چُھ ہدا یت دِنہٕ یِوان زِ توٚہۍ کٔرۍزیٚو نہٕ یہِ ۔ بنی اسرا یلٕچ دوٚیِم بٔڈ کمزور ی ٲس یہِ زِ تِم ٲسۍ انصا ف کہ روح نِشہِ با لکل خٲلی سپٕدۍ مٕتۍ۔تِم ٲسۍ شخصی  تہٕ قو می غر ضو خٲطرٕ آرا مہٕ سان ایمان نیٚنگلاوان تہٕ نَنہِ وا نہٕ ٲسۍ ہٹ دھر می ورتا وان۔انصا ف کِس ۂٹِس پٮ۪ٹھ شرا کھ چلا و نس اوس نہٕ رژھ تہِ تِمن عار یِوان۔اللہ تعالیٰ چُھ مسلمانن ہدا یت دِوان زِ توٚہۍ بٔنۍ زیو نہٕ زانٛہہ بے انصا ف ۔ خوا ہ کٲنٛسہِ سٍتۍ دوستی آسیو یادشمنی ، بہر حال ییٚلہِ کتھ ؤنِو انصا فٕچ ؤنِو تہٕ ییٚلہِ فٲصلہٕ کٔرِ و عد لہٕ سان کٔرِ و۔﴾ اللہ تعالیٰ چُھو تۅہیہِ واریاہ رٕژ نصیحت کران۔تہٕ پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ سورُے کینٛہہ بوزان تہٕ وُچھان۔"
  4,59,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت اطا عت کٔرِو اللہ تعالیٰ سٕنز تہٕ اطا عت کٔرِو رسول صلی اللہ علیہ وسلمن ہٕنز تہٕ تِمن لُکن ہٕنز یِم تۅہیہِ منٛز صا حب اَمر آسن پتہٕ ہرگاہ تۅہیہِ در میان کُنہِ معا ملس منٛز تنا زعہ سپدِ تیٚلہِ  پھِرِ یوٗن سُہ خُدا یس تہٕ رسول  صلی اللہ علیہ وسلمس کُن۔﴿یہِ آیت چھےٚ اسلام کہ پوٗرٕ مذ ہبی ،تمد نی تہٕ سیا سی نظا مٕچ بُنیا د تہٕ اسلامی ریا ست کہ دستورٕچ اولیٚن دفعہ ۔ اتھ منٛز چِھ حسبِ ذیل ژور اصو ل مستقل طور قٲیِم کر نہٕ آمٕتۍ:﴿1﴾ اسلامی نظا مس منٛز چُھ  اصل مُطا عیس اطا عت یِیہِ کر نہٕ  اللہ تعالیٰ۔اکھ مسلمان چُھ سارِوٕے برونٛہہ اللہ تعالیٰ سُند بندٕ ہ ، با قی یِکینژھاہ چُھ تہِ چُھ امہِ پتہٕ۔﴿2﴾ اسلامی نظا مٕچ دوٚیُم بُنیا د چھےٚ رسول اللہ  صلی اللہ علیہ وسلمن ہٕنز اطا عت۔﴿3﴾ یِمو دۅ یو اطا عتو پتہٕ چھےٚ یِمن ما تحت روٗزِ تھ تریٚیِم اطا عت مُسلمانن ہٕندٮ۪ن اُو لی الامر ن ہٕنز یِم خۅ د مُسلمانو منٛزٕ آسن ۔اُو لی الامَر کِس مفہو مس منٛز چِھ تِم سٲر ی لُکھ شامِل یِم مُسلمانن ہٕندٮ۪ن اجتما عی معا ملا تن ہٕندۍ سر برا ہِ کار آسن ، خواہ تِم علما آسن ، یا سیٲسی رہنمٲیی کر ن وٲلۍ لیڈر آسن، یا ملکی انتظا م کر ن وٲلۍ حٲکم یا عدا لتی فٲصلہٕ کر ن وٲلۍ جج، یا تمدّ نی تہٕ مُعا شر تی امو ر ن منٛز قبیلن تہٕ بٔستِین تہٕ محلن ہٕنز سر برٲہی کر ن وٲلۍ زِٹھۍ ، بزر گ تہٕ سردار آسن ۔ ﴿4﴾ اللہ تعالیٰ سُند حکم تہٕ رسول ﴿صلی اللہ علیہ وسلمن ﴾ ہُند طر یقہٕ چُھ بنیٲدی قا نو ن تہٕ ٲخر ی سَنَد۔ مُسلمانن در میان یا حکو متس تہٕ عو امس در میان یَتھ مسلس منٛز تہِ نِزا ع پٲدٕ گژِھہ تتھ منٛز یِیہِ فٲصلہٕ خٲطرٕ قرآ نس تہٕ سُنتس کُن رجو ع کر نہٕ تہٕ یُس فٲصلہٕ تو رٕ حٲصل سپدِ تتھ برونٛٹھہٕ کنہِ نوٚ مراوَن سٲر ی پنُن سر تہٕ کر ن تسلیم۔﴾ اگر تۅہیہِ پٔزۍ پٲٹھۍ خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان چُھو ،یۅہے چُھ اکھ صحیح طر یقہٕ  کار تہٕ انجام کہ اعتبارٕ تہِ چُھ بہتر۔ع۔"
  4,60,"۔اے نبی صلی اللہ علیہ وسلم تۅہیہِ وُچِھو نا تِم لُکھ یِم دعویٰ چِھ کران زِ اسہِ چُھ ایمان اوٚ نمُت تتھ کتا بہِ پٮ۪ٹھ یۅسہٕ تۅہیہِ کُن نٲزِل چھےٚ کر نہٕ آمٕژ تہٕ تِمن کتا بن پٮ۪ٹھ یِمہٕ تۅہیہِ برونٛہہ آسہٕ نٲزِل کر نہٕ آمژٕ،مگر یژھان چِھ یہِ زِ پننیٚن معا ملا تن ہُند فٲصلہٕ کرنہٕ خٲطرٕ کر ہَن طا غوتس کُن رجو ع حالانکہ یِمن اوس طا غو تس سٍتۍ کُفر کر نُک حکم دِنہٕ آمُت ﴿یتھ جایہِ چُھ وا ضح طور  طا غوت مُراد سُہ حٲکم یُس قا نو نِ الہٰی ورٲے کُنہِ دوٚیِمہِ قا نو ن مطابق فٲصلہٕ کران آسہِ ، تہٕ بیٚیہِ سُہ نظامِ عدالت یُس نہٕ اللہ تعالیٰ سٕندِ اقتدارِ اعلیٰ ہُک مُطیع آسہِ تہٕ نَہ آسہِ اللہ تعالیٰ سٕنز کتا ب ٲخر ی سَنَد مانان ۔﴾ شیطا ن چُھ یِمن سیٚزِ وَتہِ نِشہِ ڈٲلِتھ واریاہ دوٗر یَژھان نِیُن۔"
  4,61,"۔تہٕ ییٚلہِ یِمن وَننہٕ چُھ یِوان زِ ؤلِو تتھ چیز س کُن یُس خُدا ین چُھ نٲزِل کوٚر مُت ، تہٕ ؤلِو رسول ﴿صلی اللہ علیہ وسلمس ﴾کُن پتہٕ چھوٗکھ توٚہۍ یِم مُنا فق وُچھان زِ یِم چِھ تۅہیہِ کُن یِنَس ہِرا سہٕ کران ۔"
  4,62,"۔پتہٕ کیا چُھ تمہِ وِزِ سپدان ییٚلہِ یِہٕندٮ۪ن پننیٚن اَتھن ہُند اوٚ نمُت مصیبت یِمن پٮ۪ٹھ یِوان  چُھ؟تمہِ وقتہٕ چِھ یِم تۅہیہِ نِشہِ قسم کھیوا ن کھیوان یِوان تہٕ ونان چِھ ، خُدا ے سُند قسم، أسۍ ٲسۍ صرف رٕژر یژھان تہٕ سٲنۍ نیت ٲس یہِ زِ فر یقن در میان گژِھہ کُنہِ پٲٹھۍ مو افقت سپٕدنۍ ۔"
  4,63,"۔اللہ تعالیٰ چُھ زانان یِکینژھاہ یِہندٮ۪ن دِلن منٛز چُھ ،یِمن مَہ دِیِو کنہٕ ڈو ل، یِم سمجھٲوِیوٗکھ بیٚیہِ کٔرِیوٗکھ تِژھ نصیحت یۅسہٕ یِہِندٮ۪ن دِلن منٛز وَسہِ۔"
  4,64,"۔﴿یِمن ؤنِو زِ ﴾ اَسہِ یُس تہِ رسول سوٗز مُت چُھ، سُہ چھ اَمی موجوٗب سوٗزمُت زِ اللہ تعالیٰ سٕندِس حکم کِس بنیادس پٮ۪ٹھ گژِھہ تٔمۍ سٕنٛز اطا عت یِنۍ کر نہٕ۔اگر تِمو یہِ طر یقہٕ اختیار کوٚر مُت آسہِ ہے زِ ییٚلہِ یِمو پننِس نفسسس پٮ۪ٹھ ظُلم اوس کوٚر مُت تَمہِ وِزِ یَہَن تۅہیہِ نِشہِ تہٕ خُدا یس منگہَن معٲفی تہٕ رسول ﴿صلی اللہ  علیہ وسلم﴾تہِ کرِ ہے یِہنزِ معٲفی خٲطرٕ در خوا ست، یِم لبہَن یقیناً خُدا یس بخشن وول تہٕ رحم کر ن وول ۔"
  4,65,"۔نَہ ، اے محمد صلی اللہ علیہ وسلم، تُہٕندِس ربّ سُند قسم یِم ہیٚکن نہٕ مو من ٲسِتھٕے یوٚت تام نہٕ یِم پننیٚن با ہمی معا ملاتن منٛز تۅہیہِ فٲصلہٕ کر ن وول تسلیم کر ن پتہٕ یِکینٛژھاہ توٚہۍ فٲصلہِ کٔرِ وتتھ پٮ۪ٹھ گژھن نہٕ پننیٚن دِلن منٛز تہِ کانٛہہ تنگی محسو س کرٕنۍ۔بلکہ گژھن سر بسر تسلیم کرٕنۍ۔"
  4,66,"۔اگر اَسہِ یِمن حُکم آسہِ ہے دِیتمُت زِپنُن پان کٔرِ و ہلاک یا نِیرِ و پننیو گھر و منٛزٕ۔تیٚلہِ کر ہَن یِمو منٛزٕ کمٕے لکھ  اتھ پٮ۪ٹھ عمل ۔حالانکہ یۅسہٕ نصیحت یِمن کر نہٕ چھےٚ یِوان اگر یِم اَتھ پٮ۪ٹھ عمل کر ہَن تیٚلہِ بَنہِ ہے یہِ یِہِندِ خٲطرٕ زیادہ بہتر ی تہٕ زیادہ ثٲبت قد می ہُنٛد ذر یعہ۔"
  4,67,"۔تہٕ ییٚلہِ یِم یہِ کر ہَن تیٚلہِ دِمہٕ ہَو أسۍ یِمن پننہِ طر فہٕ سٮ۪ٹھاہ بوٚڈ اَجر۔"
  4,68,"۔تہٕ یِمن ہاوٕ ہَو سیٚز وَتھ۔"
  4,69,"۔یِم لُکھ اللہ تعالیٰ سٕنز تہٕ رسول صلی اللہ علیہ وسلمن ہٕنز اطا عت کر ن تِم آسن تِمن لُکن سٍتۍ یِمن پٮ۪ٹھ خُدا ین انعا م چُھ فر مو ومُت یعنی انبیا علیہم السلام ،تہٕ شہدا تہٕ صا لحین۔﴿اَمِیُک مطلب چُھ یہِ زِ ٲخرتس منٛز آسن تِم یِمن لُکن سٍتۍ۔اَتھ چُھنہٕ یہِ مطلب زِ یِمو منٛزٕ بنہِ کانٛہہ اَمہِ کامہِ ہٕندِ بد و لتہٕ نبی ۔ ﴾کِتھۍ جان چِھ یِم رفیق یِم کٲنٛسہِ میسر سپد ن۔"
  4,70,"۔یہِ چُھ حقیقی فضل یُس اللہ تعالیٰ سٕندِ طر فہٕ میلان چُھ تہٕ حقیقت زاننہٕ خٲطرٕ چُھ بس اللہ تعالیٰ سُندُے علم کٲفی ۔ع"
  4,71,"۔اے لوٗکو یِمو ایمان چُھ اوٚ نمُت مقا بلہٕ خاطرٕروٗزِ و پرٛتھ وِزِ تیار،پتہٕ یُتھ مو قع آسہِ الگ الگ چھۅ کن ہٕنزِ شکلہِ منٛز نیٖرِ و یا نیٖرِ و یکہٕ وَٹہٕ۔﴿یہِ کتھ روٗزِ ن وا ضح زِ یہِ فر مان اوس تمہِ وقتہٕ نٲزِل سپُد مُت ییٚلہِ جنگِ اُحد کہِ شکست کہ وجہ کِنۍ أندۍ پٔکۍ کیٚن قبیلن ہٕنز ہمت بڑ یمٕژ ٲس تہٕ مُسلمان ٲسۍ پرٛتھ طر فہٕ خطرا تن منٛز ہیٚنہٕ آمٕتۍ۔﴾"
  4,72,"۔آ، تۅہیہِ منٛز چُھ کانٛہہ نفر تِیُتھ تہِ یُس لڑا یہِ نِشہِ پتھ چُھ ہیٚوان، اگر تۅہیہِ پٮ۪ٹھ کانٛہہ مصیبت چُھ یِوان تیٚلہِ چُھ ونان خُدا ین کوٚر مےٚ پٮ۪ٹھ بوٚڈ فضل زِ بہٕ گوس نہٕ یِمن لُکن سٍتۍ۔"
  4,73,"۔تہٕ اگر اللہ تعالیٰ سٕندِ طر فہٕ تۅہیہِ پٮ۪ٹھ فضل چُھ سپدان تیٚلہِ چُھ ونان تہٕ تِتھہٕ پٲٹھۍ چُھ ونان زَنتہٕ تۅہیہِ تہٕ تس درمیان اوس نہٕ محبتُک کانٛہہ واٹھٕے،اےکاش بٕتہِ آسٕہا یِمن سٍتۍ تیٚلہِ نیرِ ہے بٔڑ کٲم۔"
  4,74,"۔ ﴿یِتھیٚن لُکن گژِھہ پے لگٕنۍ زِ ﴾ اللہ تعالیٰ سٕنزِ وَتہِ منٛز پَزِ لڑُن تِمن لُکن یِم ٲخرت کہ بد لہٕ دنیا ہٕچ زند گی فر و خت کر ن ،پتہٕ یُس اللہ تعالیٰ سٕنزِ وَتہٕ منٛز لَڑِ تہٕ پتہٕ یِیہِ مار نہٕ یارو زِ غٲلِب تس کر و أسۍ ضرور اجرِ عظیم عطا۔"
  4,75,"۔ٲخر کیا و جہ چُھ زِ توٚہۍ لٔڑِ و نہٕ اللہ تعالیٰ سٕنزِ وَتہِ منٛز تِمن بے بس مردن، مستو را تن تہٕ شُر ٮ۪ن ہٕندِ مۅ کھہٕ یِم کمزور زٲنِتھ دَبا و نہٕ چِھ آمٕتۍ تہٕ فر یاد چِھ کران زِ خُدا یا اَسہِ کڑ ییٚمہِ بستی منٛزٕ ییٚمِکۍ روز ن وٲلۍ ظٲلِم چِھ تہٕ پننہِ طر فہٕ کر تن سو ن  کانٛہہ حامی تہٕ مددگار پٲدٕ﴿ارشاد چھُ تِمن مظلوم شُرٮ۪ن ،مستوراتن تہٕ مردن کُن یِمَو مکس منٛز عرب کیٚن باقی قبیلن منٛز اسلام اوس قبو ل کوٚر مُت مگر نہ ٲسۍ ہجر ت کٔرِ تھ ہیٚکان تہٕ نہ ٲسۍ پنُن پان ظُلمہٕ نِشہِ بچٲوِتھ ہیٚکان۔یِم بے کس ٲسۍ رنگہٕ رنگہٕ تختہ مشق بناونہٕ یِوان تہٕ دعا ٲسۍ منگان زِ کانٛہہ گوٚژھ تِمن اَمہِ ظلمہٕ نِشہِ بچاوُن﴾"
  4,76,"۔یِمو لُکو ایمانٕچ وَتھ رٔٹ، تِم چِھ اللہ تعالیٰ سٕنزِ وَتہِ منٛز لڑان تہٕ یِموکُفرٕ چ وَتھ پا ننٲو، تِم چِھ طا غوت چہِ وَتہِ منٛز لڑان، لہٰذا لٔڑِ و شیطا ن سٕندٮ۪ن سٲتھین سٍتۍ تہٕ پژھ کٔرِ و شیطا ن سٕنزٕ چا لہٕ چھےٚ در حقیقت سٮ۪ٹھاہ کمزور ۔ ع"
  4,77,"۔کیا تۅہیہِ وُچھوٗکھ تِم لُکھ تہِ یِمن وَننہٕ اوس آمُت زِ پنٕنۍ اَتھہٕ تھٲوِو پَتھ تہٕ نماز کٔرِ و قٲیِم تہٕ زکوٰتہ دِیِو ؟ وۅ نۍ ییٚلہِ تِمن لڑا یہِ ہُند حُکم آو دِنہٕ،پتہٕ چُھ یِمَو منٛزٕ أکِس فر یق سُند حال یہِ زِ لُکن چِھ تِتھہٕ پٲٹھۍ کھۅژان یِتھہٕ پٲٹھۍ خدا یس پزِ کھۅژُن یا تَمہِ کھۅتہٕ تہِ زیادے۔ وَنان چِھ خُدا یا، اَسہِ پٮ۪ٹھ کیا زِ لیٚو کُھتھ یہِ لڑا یہِ ہُند حکم ؟ اَسہِ کیا زِ دِژٕ تھ نہٕ وُنہِ بیٚیہِ مہلت؟یِمن ؤنِو ،دُنیا چہِ زند گی ہُند سر مایہِ چُھ اکھ پیوٗنتاہ تہٕ ٲخر ت چُھ  أکِس پر ہیز گار انسان سٕندِ خٲطرٕ زیادہ بہتر تہٕ تۅہیہِ پٮ۪ٹھ یِیہِ نہٕ أکِس پَنہٕ داوِ یو ت تہِ ظُلم کر نہٕ۔﴿یعنی اگر توٚہۍ اللہ تعالیٰ سٕندِ دینٕچ خد مت بجا أنِو تہٕ تٔمۍ سٕنزِ وَتہِ اندر ہٲوِو جا نفشٲنی تیٚلہِ چُھنہٕ یہِ ممکن زِ خُدا یس نِشہِ کیا گژِھہ تُہُند اجر ضا یع۔﴾"
  4,78,"۔روٗد وۅ نۍ مو ت ،توٚہۍ یتھ جایہِ تہِ ٲسِو بہر حال روزِ سُہ توٗر ۍ وٲتِتھ خوا ہ توٚہۍ ٲسِتو کِژھن مضبو ط عما رتن منٛز۔اگر یِمن کانٛہہ فا ید ہ چُھ واتان تیٚلہِ چِھ ونان زِ یہِ چُھ اللہ تعالیٰ  سٕندِ طر فہٕ تہٕ ہرگاہ کانٛہہ نقصا ن چُھکھ واتان  تیٚلہِ چِھو ونان زِ اے نبی صلی اللہ علیہ وسلم، یہِ چُھ تُہُندِ بد و لتہٕ ،ؤنِو ، سورُے کینٛہہ چُھ اللہ تعالیٰ سٕندۍ طر فہ۔ٲخر کیا گوٚو یِمن لُکن زِ یِمن چَھنہٕ کٕہٕنۍ کتھ فِکرِ تران۔"
  4,79,"۔اے انسان، ژےٚ یُس تہِ رٕژر حا صل چِھی سپدان ﴿سُہ چِھی ﴾ اللہ تعالیٰ سٕندِ عنا یت سٍتۍ حٲصل سپدان تہٕ یُس مصیبت ژےٚ یِوان چِھی ،سُہ چھی ژےٚ پننہِ عملہِ ہٕندِ بد و لت یِوان۔اے محمد صلی اللہ علیہ وسلم،اَسہِ چِھو توٚہۍ لُکن خٲطرٕ رسول بنٲوِتھ سوٗزِ مٕتۍ تہٕ اَتھ پٮ۪ٹھ چھےٚ اللہ تعالیٰ سٕنز گوٲہی سٮ۪ٹھاہ ۔"
  4,80,"۔ییٚمۍ رسول سٕنز اطا عت کٔر  تٔمۍ کٔر در اصل اللہ تعالیٰ سٕنز اطا عت تہٕ ییٚمۍ بُتھ پھُیر ،بہر حال چِھو نہٕ اَسہِ توٚہۍ لُکن پٮ۪ٹھ رٲچھدر بنٲوِتھ سوٗزِ مٕتۍ۔"
  4,81,"۔تِم چِھ برونٛہہ کنہِ ونان زِ اَسہِ کٔر فر مانٕچ اطا عت مگر ییٚلہِ تۅہیہِ نِشہِ نیرا ن چِھ تہٕ یِمن منٛز چُھ اکھ دوٚر رٲژن منٛز جمع سپدِ تھ تُہٕنز ن کتھن خلا ف مشو رٕ ہ کران۔ اللہ تعالیٰ چُھ یِہنزٕ یِمہٕ سار ے سِرٕ کتھہٕ لیٚکھان توٚہۍ مَہ کٔرِو یُہُند پرواے تہٕ خُدا یس پٮ۪ٹھ تھٲوِو بھروسہٕ سُے  چُھ بھروسس خٲطرٕ کٲفی۔"
  4,82,"۔کیا یِم لُکھ چِھنا قرآنس پٮ۪ٹھ غور کران؟ اگر یہِ اللہ تعالیٰ سٕندِ ورٲے بیٚیہِ کٲنٛسہِ ہٕندِ طر فہٕ آسِہے تیٚلہِ یِیہِ ہے اَتھ منٛز واریاہ کینٛہہ اختلاف بیٲنی لَبنہٕ۔﴿یہِ کلام چُھ خۅد شہا دت دِوان زِ یہِ ہیٚکہِ نہٕ خدا یس ورٲے بیٚیہِ کٲنٛسہِ ہُند کلام آسِتھٕے ۔کٲنٛسہِ انسانس چُھنہٕ یو ت عبور زِ سُہ روزِ ؤری وادَن تام مختلف حالاتن منٛز، مختلف مو قعن پٮ۪ٹھ ،مختلف مضمو نن پٮ۪ٹھ تقریر کران ، تہٕ گۅڈٕ ہ پٮ۪ٹھہٕ اندس تام بنن تٔمۍ سٕندۍ سٲر ی تقریر تِتھۍ ہموار، یک رنگ، تنا سب دار مجمو عہٕ ییٚمیُک اکھ جُز دوٚیِمِس جُزس سٍتۍ ٹکراوان آسہِ نہٕ، یتھ منٛز راے ہٕنزِ تبد یلی ہُند کُنہِ جایہِ نام نشا ن تہِ میلہِ نہٕ، یتھ منٛز کلام کر ن وٲلۍ سٕندِ نفس چہِ مختلف کیفیتہٕ پنٕنۍ مختلف رنگ ہاوَن نہٕ، تہٕ یتھ پٮ۪ٹھ زانٛہہ نظرِ ثٲنی ہٕنز ضرورت تہِ پیش یِیہِ نہٕ۔﴾"
  4,83,"۔یِم لُکھ ییٚلہِ کانٛہہ اِطمنان بخش یا خو ف ناک خبر بوزان چِھ تتھ چِھ پھٔہلاوان حالانکہ اگر سۅ ﴿خبر﴾ یِم رسولس تہٕ پننہِ جما عت کیٚن ذمہٕ دارن تام واتناون تیٚلہِ لگہِ سۅ تِتھیٚن لُکن پے یِم یِمن در میان امہِ کتھہِ ہٕنز صلٲحیت چِھ تھاوان زِ تمہِ نِشہِ ہیٚکن صحیح نتیجہِ کٔڑِتھ۔﴿سُہ اوس چو نکہ ہنگا مُک مو قع امہِ موجوٗب آسہٕ پرٛتھ طر فہٕ افواہ چلان، کُنہِ وِزِ ٲسۍ خطرٕ کۍ بے بنیاد مبا لغہ آمیز اطلا ع یِوان تہ تِمو سٍتۍ آسہٕ جَل جَل مدینس تہٕ امہِ کیٚن أندۍ پٔکۍ کیٚن طر فن منٛز پر یشا نیہِ پھٔہلان۔کُنہِ وِزِ اوس کانٛہہ چالاک دشمن کانٛہہ واقعی خطرہ چُھپا و نہٕ خٲطرٕ اِطمنان بخش خبرٕ سوزان تہٕ لُکھ ٲسۍ یِمہٕ بوٗزِ تھ غفلتس منٛز شۅ نگ تراوان۔عام لُکن اوس نہٕ اندازٕ ہ زِ امہِ قسمہٕ چہِ غیر ذمہ دارانہٕ افواہ پھٔہلاونٕکۍ نتیجہِ کٲتیاہ خراب چِھ آسان۔یِہِندۍ کن ییٚلہِ تہِ کُنہِ جایہِ کانٛہہ ژٕر بوزہَن ،یِم ٲسۍ تتھ جایہِ جایہِ پھِروان تہٕ بوزناوان ۔یِمنٕے لُکن چھےٚ یَتھ آیتس منٛز کنہٕ دٔر آمٕژ کر نہٕ تہٕ یِمن چُھ سختی سان تنبیہ آمُت کر نہٕ زِ افواہ پھٔہلاو نہٕ نِشہِ روٗزِ ن با ز تہٕ پرٛتھ کانٛہہ خبر یۅسہٕ تِم بوز ن سۅ واتناوِن ذمہٕ دار لُکن نِشہِ تہٕ روٗزِ ن ژھۅ پہٕ کٔرِ تھ۔﴾  اگر تۅہیہِ پٮ۪ٹھ اللہ تعالیٰ سٕنز مہر بٲنی تہٕ رحمت آسہِ ہے نہٕ تیٚلہِ آسہٕ ﴿تُہٕنزٕ کمزور یہِ تِژٕھہ زِ ﴾سٮ۪ٹھاہ کم کینٛژھو وَرٲے ٲسِہِو توٚہۍ سٲر ی شیطا نس پتہٕ لگمٕتۍ۔"
  4,84,"۔اے نبی صلی اللہ علیہ وسلم،لہٰذا لٔڑِو توٚہۍ اللہ تعالیٰ سٕنزِ وَتہِ منٛز توٚہۍ چِھو نہٕ پننہِ ذاتہٕ ورٲے بیٚیہِ کٲنٛسہِ خٲطرٕ ذمہٕ دار کینٛہہ البتہ کٔرِیوٗکھ اہلِ ایمان لڑ نہٕ مۅ کھہٕ آمادٕہ، یہِ کتھ چَھنہٕ دوٗر زِ اللہ تعالیٰ پھُٹرا وِ کٲفر ن ہُند زور ،اللہ تعالیٰ سُند زور چُھ سارِوٕے کھۅتہٕ زبردست  تہٕ تٔمۍ سُند سزا چُھ سارِوٕے کھۅتہٕ زیادٕہ سخت۔"
  4,85,"۔ یُس رِژرٕچ سفٲرش کرِ سُہ لبہِ تَمہِ منٛزٕ حصہٕ تہٕ یُس بُرٲیی ہٕنز سفٲرش کرِ سُہ لبہِ تَمہِ منٛز حصہٕ تہٕ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ نظر تھاون وول۔"
  4,86,"۔ تہٕ ییٚلہِ کانٛہہ احترا مہٕ سان تۅہیہِ سلام کرِ تیٚلہِ دِیوِ تس اَمہِ کھۅتہٕ بہتر طر یقہ جواب۔یا کم از کم تِتھے پٲٹھۍ، اللہ تعالیٰ چُھ پرٛتھ چیزُک حسا ب ہیٚنہٕ وول۔"
  4,87,"۔اللہ تعالیٰ چُھ سُہ یَس وَرٲے کانٛہہ خُدا ے چُھنہٕ ،سُہ کر یو تۅہیہِ سارِنٕے تمہِ قیا مت کہ دۅہ جمع ییٚمہِ کِس یِنس منٛز کانٛہہ شک چُھنہٕ تہٕ اللہ تعالیٰ سٕنزِ کتھہِ کھۅتہٕ کھٔسِتھ کٔمۍ سٕنز کتھ ہیٚکہِ پٔز ٲسِتھ ۔ع"
  4,88,"۔پتہٕ کیا چُھو یہِ تۅہیہِ گوٚ مُت زِ منا فِقن متعلق چھےٚ تۅہیہِ منٛز زٕ ہ رایہِ لبنہٕ یِوان حالانکہ یِمہٕ بُرٲیِیہِ  تِمو کما وِمٕژ چھےٚ ،تِہِندِ بدو لت چِھ خُدا ین تِم دُبہٕ پھِر مٕتۍ کیا توٚہۍ چِھوٕ ہ یژھان زِ یَس خُدا ین ہدا یت بخُش نہٕ تس بخشِو توٚہۍ ہدا یت ؟ حالانکہ یُس خُدا ین وَتہِ ڈو ل تس خٲطرٕ لٔبِو نہٕ توٚہۍ کانٛہہ وَتھ۔"
  4,89,"۔تِم چِھ یہِ یژھان زِ یِتھہٕ پٲٹھۍ تِم پانہٕ کٲفر چِھ تِتھے پٲٹھۍ سپدِ و توٚہۍ کٲفر تا کہ تِم تہٕ توٚہۍ گژِھو سٲر ی یکسا ن لہٰذا مَہ بنٲوِیو ن تِمو منٛزٕ کانٛہہ پنُن دوست یوت تام نہٕ تِم اللہ تعالیٰ سٕنزِ وَتہِ منٛز ہجر ت کٔرِ تھ یِن تہٕ ہرگاہ تِم ہجرت نِشہِ باز روزَن تیٚلہِ ییٚتہِ لٔبِیو وٗکھ ،رٔٹیووٗکھ تہٕ کٔرِ یوٗکھ قتل۔﴿یہِ حکم چُھ تِمن منا فق مسلمان ہُند یِم برسرِ جنگ کٲفر قو مس سٍتۍ تعلق تھاوان آسن تہٕ اسلامی حکو متس خلا ف نِن دشمنن ہٕندۍ پٲٹھۍ کاروٲیِیَن منٛز حصہٕ۔﴾ تہٕ یِمو منٛزٕ مَہ بناوِیوٗن کانٛہہ اَکھ پنُن دوست تہٕ مددگار۔"
  4,90,"۔البتہ تِم منا فق چِھ امہَ حُکمہ نِشہِ مُستثنیٰ  یِم کُنہِ تِتھس قو مس سٍتۍ رَلن یَس سٍتۍ تۅہیہِ معا ہدہ چُھ۔ ّ﴿اَمِیُک مطلب چُھنہٕ یہِ زِ  یِتھۍ منا فق ہیٚکوکھ پنٕنۍ  دوست تہٕ مددگار بنٲوِتھ۔بلکہ چُھ اَمِیُک مطلب یہِ زِ یِم یِن نہٕ رَٹنہٕ تہٕ مار نہٕ تِکیازِ یِم چِھ تِتھس قو مس سٍتۍ رلیامٕتۍ یس سٍتۍ اسلامی حکو متُک مُعاہدہ چُھ۔﴾یِتھے پٲٹھۍ چِھ تِم منا فق تہِ مُستثنیٰ یِم تۅہیہِ نِشہِ یِوان چِھ تہٕ لڑایہِ نِشہِ چِھ تِہِندۍ دل تنگ آمٕتۍ ،نَہ چِھ تۅہیہِ سٍتۍ لڑُن یژھان نہ پننِس قو مس سٍتۍ ،اللہ تعالیٰ اگر ییژِھہ ہے یِمن کرِ ہے تۅہیہِ پٮ۪ٹھ مُسلط تہٕ تِم تہِ لڑ ہن تۅہیہِ سٍتۍ ،لہٰذا اگر تِم تۅہیہِ نِشہِ الگ سپد ن تہٕ با ز ر وزن تہٕ تۅہیہِ کُن پِلنا و ن صلحُک تہٕ اَمنُک اَتھہٕ تیٚلہِ چَھنہٕ خُدا ین تُہٕندِ خٲطرٕ تِمن پٮ۪ٹھ دست درٲزی ہٕنز کانٛہہ وَتھ تھٲومٕژ۔"
  4,91,"۔بیٚیہِ اکہِ قسمٕکۍ مُنا فق میلنو تۅہیہِ  تِتھۍ ،یِم یژھان  چِھ زِ تۅہیہِ سٍتۍ تہِ روزٕ ہن اَمنس منٛز تہٕ بیٚیہِ روز ہن اَمنس منٛز پننِس قو مس سٍتۍ تہِ مگر ییٚلہِ کُنہِ وِزِ فِتنُک مو قع لبن تتھ منٛز ترا وَن  وۅ ٹھ ،یِتھۍ لُکھ اگر تُہندِ مقا بلہٕ نِشہِ باز رو زن نہٕ تہٕ صلح تہٕ سلامتی کر ن نہٕ تۅہیہِ برونٛٹھ کنہِ پیش تہٕ پنٕنۍ اَتھہٕ رٹن نہٕ پتھ تیٚلہِ ییٚتہِ تہِ تِم سمکھن رٔٹیوٗکھ تہٕ مٲرِیوٗکھ ،یِمن پٮ۪ٹھ اَتھہٕ تُلنہٕ خٲطرٕ چھےٚ اَسہِ تۅہیہِ کُھلہٕ حُجت دِژمٕژ۔ ع"
  4,92,"۔کٲنٛسہِ مو من سٕنز چَھنہٕ یہِ کٲم زِ دوٚ یِمَس مو منس کرِ قتل ، اِلّایہِ زِ بِل چُک سپد یٚس تہٕ یُس شخص کٲنٛسہِ مو منس غلطی کِنۍ قتل کرِ تیٚلہِ چُھ اَمِیُک کفا رٕ ہ یہِ زِ اکھ مو من کٔرِن غلا می نِشہِ آزاد۔﴿چو نکہ مقتو ل اوس مو من امہِ موجوٗب چُھ أمۍ سٕند قتلُک کفارٕ ہ أکِس مو من غلا م سٕنز آزٲد ی قرار دِنہٕ آمُت۔﴾ تہٕ مقتو ل سٕندٮ۪ن وٲرثن دِیِن خو ن بہا ۔﴿نبی صلی اللہ علیہ وسلمو چُھ خو ن بہا ہُک مقدار ہتھ اونٹ ، یا ہتھ گٲوٕہ یا زٕہ ساس ژھا وجہِ مقرر کرِمژٕ۔اگر بیٚیہِ کُنہِ شکلہِ منٛزٕ کانٛہہ شخص خو ن بہا ییٚژِھہ دِیُن تیٚلہِ یِیہِ تَمِیُک مقدار یِمنٕے چیزن ہٕند بازٕ ر ۍ قٍمتہٕ کہ لحا ظہٕ مُقرر کر نہٕ۔مثلاً نبی صلی اللہ علیہ وسلمن ہٕندِ وقتہٕ ٲسۍ خو ن بہا دِنہٕ والیٚن خٲطرٕ 8 شتھ دینا ر ، یا 8 سا س دِر ہم مقرر۔ ییٚلہِ حضرت عمر رضی اللہ عنہن ہُند زمانہٕ آو تہٕ تِمو فر موو زِ اونٹن ہُند قٍمت چُھ وۅ نۍ ہُر یو مُت ،لہٰذا یِن وۅ نۍ سۅ نہٕ کیٚن سِکن ہٕندۍ اکھ ساس دینار، یا رۅ پہٕ کیٚن سکن ہٕندۍ 12 ساس دِر ہم خو ن بہا دِیا و نا و نہٕ۔ مگر وا ضح روٗزِ ن زِ خو ن بہا ہُک یہِ مقدار یُس مقرر کر نہٕ چُھ آمُت چُھنہٕ زٲنِتھ مٲنِتھ کر نہٕ آمتہِ قتلہٕ خٲطرٕ کینٛہہ بلکہ چُھ اَلہٕ گٲبہٕ گٔمتہِ قتل خٲطرٕ۔﴾ اِلاًیہِ زِ تِم کر ن خو ن بہا معا ف البتہ اگر سُہ مسلمان مقتو ل کُنہِ تِتھہِ قو مُک اوس یس سٍتۍ تۅہیہِ دشمنی آسہِ تیٚلہِ چُھ اَمِیُک کفارہ اکھ مو من غلا م آزاد کرُن تہٕ ہرگاہ سُہ کُنہِ تِتھہِ غیر مُسلم  قو مُک فرد اوس یس سٍتۍ تۅہیہِ معا ہدٕہ آسہِ تیٚلہِ یِیہِ تٔمۍ سٕندٮ۪ن وٲرِثن خو ن بہا دِنہٕ تہٕ اکھ مو من غلا م آسہِ آزاد کرُن۔﴿ییٚمہِ آیت کیٚن احکامن ہُند خلا صہٕ چُھ یہِ : ہرگاہ مقتول دارُلا سلامُک روزن وول آسہِ تیٚلہِ چُھ أمۍ سٕندِس قٲتِلس خو ن بہا تہِ دِیُن تہٕ خُدا یس معا فی منگنہٕ با پت چُھس اکھ غلا م تہِ آزاد کرُن۔اگر سُہ دارُلحر بُک روزن وول آسہِ تیٚلہِ چُھ قٲتِلس صرف غلا م آزاد کرُن ،خو ن بہا چُھس نہٕ کینٛہہ۔اگر سُہ کُنہِ تِتھہِ دارُلکفرُک روزن وول آسہِ یس سٍتۍ اسلامی حکو متس معا ہد ہ چُھ تیٚلہِ چُھ قٲتِلس اکھ غلا م آزاد کرُن تہٕ امہِ علا وہ چُھس خو ن بہا تہِ دِیُن، البتہ خو ن بہا ہُک مقدار آسہِ تِیُتُے یوٗتاہ امہِ معا ہدہ والہِ قو م کِس کٲنٛسہِ غیر مسلم فر د سٕندِس قتل کر نہٕ کِس صورتس منٛز معا ہدہ رٔنگۍ دِیُن پزَ ﴾ پتہٕ یس غلام دستیا ب سپدِ نہٕ سُہ تھٲوِ ن لگا تار دۅ ن ریٚتن ہٕنز روزٕ ہ۔﴿یعنی روزہ تھٲوِ ن لگاتار،منٛز س مہ ترٲوِن کانٛہہ دۅ ہ۔ ہرگاہ کانٛہہ شخص شر عی عذرٕ ورٲے کانٛہہ دۅ ہ پُھٹرا وِ تس چھےٚ نَوِ سرٕ بیٚیہِ گۅڈٕ پٮ۪ٹھے روزٕہ شر وع  کر نہِ۔﴾ یہِ چُھ اتھ گنا ہس پٮ۪ٹھ خُدا یس برونٛہہ کنہِ تو بہٕ کر نُک طر یقہٕ۔﴿یعنی یہِ چُھنہٕ جُر مانہٕ بلکہ چُھ تو بہٕ  تہٕ کفارہ۔جُر ما نس منٛز چُھنہٕ ندا مت ،شر مساری تہٕ اصلا ح نفسُک کانٛہہ رُو ح آسان بلکہ چُھ سُہ عمو ماً سخت نا گوٲر ی سان مجبو راً دِنہٕ یِوان تہٕ پتھ کُن چُھ تراوان بیزٲر ی تہٕ تلخی ۔اتھ بر عکس چُھ اللہ تعالیٰ یژھان زِ یس بند س خطا سپُد سُہ چھٔلِن عبا دت سٍتۍ ،کارِ خیر سٍتۍ تہٕ حقو ق ادا کر نہٕ سٍتۍ پننہِ روح پٮ۪ٹھہٕ اَمِیُک اثر تہٕ شر مسٲر ی تہٕ ندا مت سان کٔرِ ن خُدا یس کُن رجوع تا کہ یہِ گنا ہ تہِ سپدِ معا ف تہٕ آیند ہ خٲطرٕ روزِ أمۍ سُند نفس یِژٕھہ غلطیہِ دۅ ہرا و نہٕ نِشہِ تہِ محفو ظ۔﴾ تہٕ اللہ تعالیٰ چُھ زانن وول تہٕ دا نا ۔"
  4,93,"۔روٗد سُہ شخص  یُس کٲنٛسہِ مو منس زٲنِتھ مٲنِتھ قتل کرِ تیٚلہِ چُھ تٔمۍ سُند جزا جہنم یتھ منٛز سُہ ہمیشہ روزِ تس پٮ۪ٹھ چُھ اللہ تعالیٰ سُند غضب تہٕ تٔمۍ سٕنز لعنت تہٕ خُدا ین چُھ تٔمۍ سٕندِ خٲطرٕ سخت عذا ب تیار تھوو مُت ۔"
  4,94,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ییٚلہِ توٚہۍ اللہ تعالیٰ سٕنزِ وَتہِ منٛز جہا دٕ خٲطرٕ نیٖرِ و تیٚلہِ کٔرِ و دوستس دُشمنس منٛز فر ق تہٕ یُس تۅہیہِ کُن سلامہِ سٍتۍ پیش قد می کرِ تس مَہ ؤنِو فوراً زِ ژٕ چُھکھ  نہٕ مو من،  ہرگاہ توٚہۍ دنیٲوی فٲیدٕ ہ یژھان چِھو تیٚلہِ چِھ خُدا یس نِشہِ تُہندِ خٲطرٕ واریاہ مالِ غنیمت، ٲخر  ہے چِھو توٚہۍ پانہٕ تہِ أتھۍ حا لتس منٛز مبتلا روٗدِمٕتۍ ،پتہٕ کوٚر خُدا ین تۅہیہِ پٮ۪ٹھ احسان۔لہٰذا ہیٚیو تحقیقس کٲم۔﴿اسلام کِس ابتدا ہس منٛز اوس لفظ اسلام علیکم مُسلمانن اندر شعا رٕچ تہٕ علا متٕچ حیثیت تھاوان تہٕ اکھ مُسلمان اوس دوٚ یِمِس مُسلمانس وُچِھتھ یہِ لفظ اتھ معنیس منٛز وَرتاوان زِ بہٕ چُھس چا نی جما عتُک نفر، دوست تہٕ خیر خوا ہ، دشمن چُھس نہٕ کینٛہہ، خصوصیت سان ٲس تتھ زمانس اندر امہِ شعا رچ ﴿طر یقٕچ﴾ اہمیت امہِ وجہ کِنۍ تہِ زیادہ زِ تمہِ وقتہٕ ٲس نہٕ عر ب کیٚن نَو مُسلمن تہٕ کٲفر ن در میان پۅ شاکھس ، زبٲنۍ تہٕ بیٚیہِ کُنہِ چیز س منٛز نٔنۍ فر ق ییٚمہِ سٍتۍ اکھ مُسلمان سر سر ی نظر ترٲوِتھ دوٚیِمس مسلمان بٲیِس پرٛزٕ نٲوِ تھ ہیکہِ ہے ۔ البتہ لڑا یہِ ہٕندٮ۪ن مو قعن پٮ۪ٹھ ٲس اکھ پیچید گی یہِ در پیش یِوان زِ مُسلمان ییٚلہِ کُنہِ دشمن سٕنزِ چھۅ کہِ پٮ۪ٹھ حملہٕ کران ٲسۍ،کُنہِ وِزِ اوس اَتھ زدس منٛز کانٛہہ مُسلمان تہِ یِوان ،سُہ اوس حملہٕ کر ن والیٚن مُسلمانن یہِ وَننہٕ خٲطرٕ زِ بٕتہِ چُھس تُہندُے دینی بوے اسلام علیکم  یا لاَ اِلٰہ اِلّا اللہ بَڑِ بَڑِ ونان مگر مسلمانن اوس تس پٮ۪ٹھ یہِ شک گژھان زِ یہِ چُھ کٲفریُس محض زُو بچا و نہٕ خٲطرٕ حیلہٕ چُھ کران ، امہِ موجو ب ٲسۍ بسا اوقا ت تِم تس قتل نِوان کٔرِ تھ۔آیتُک مَنشہِ چُھ یہِ زِ یُس شخص پنُن پان مسلمان سٕندِ حیثیت پیش کران چُھ، تس متعلق چُھو نہٕ تۅہیہِ سر سر ی طور یہِ فٲصلہٕ کر نُک حق زِ سُہ چُھ محض زُو بچا و نہٕ خٲطرٕ اَپُز ونان ۔ بنان چُھ سُہ آسہِ پوٚز ونان تہٕ بنان چُھ سُہ آسہِ اَپُز ونان۔ حقیقت سپدِ تحقیق سٍتی معلو م ۔ تحقیق ورٲے یلہٕ تراونس منٛز اگر یہِ اِمکان چُھ زِ اکھ کٲفر بچا وِ اَپُز ؤنِتھ پنُن زُو،مگر قتل کر نس منٛز چُھ اَمہِ کتھہِ ہُند تہِ اِمکان زِ اکھ بے گنا ہ مو من سپدِ تُہندِ اتھہٕ مارٕ۔﴾ یِکینژھاہ توٚہۍ کران چِھو اللہ تعالیٰ چُھ تمہِ نِشہِ با خبر ۔"
  4,95,"۔ مسلمانَو منٛزٕ یِم لُکھ کُنہِ عذرٕ وَرٲے گھر ن منٛز چِھ بِہِتھ روزان تہٕ تِم یِم اللہ تعالیٰ سٕنزِ وَتہِ منٛز جان و مال سٍتۍ جہا د چِھ کرا ن ، دۅ شوٕنۍ ہٕنز حیثیت چَھنہٕ ہِشی ،خُدا ین چُھ بِہِتھ روزن والیٚن بہ نسبت جان و مال سٍتۍ جہاد کر ن والیٚن ہُند در جہ بڑ وومُت اگر چہِ پرٛتھ کٲنٛسہِ ہٕندِ خٲطرٕ خُدا ین رٕژرُکُے وعدہ چُھ کوٚر مُت۔مگر خُدا یس نِشہِ چُھ مجٲہد ن ہٕندٮ۪ن خد ما تن ہُند معا و ضہٕ بِہِتھ روزن والیٚن ہٕندِ کھۅتہٕ زیادٕہ۔"
  4,96,"۔ تِہٕندِ خٲطرٕ چِھ اللہ تعالیٰ سٕندِ طر فہٕ بٔڑۍ در جہ ِ بیٚیہِ چھےٚ مغفرت تہٕ رحمت۔ع"
  4,97,"۔یِم لُکھ پننِس نفسس پٮ۪ٹھ ظُلم کران ٲسۍ۔تِہِندۍ رُو ح ییٚلہِ فر شتو قبض کٔرۍ تہٕ پُرٛژھہَکھ زِ یہِ کتھ حا لتس  منٛز ٲسِو توٚہۍ مبتلا؟﴿ مُراد چِھ تِم لُکھ یِم اسلام قبو ل کر نہٕ پتہٕ تہِ کُنہِ مجبو ر ی تہٕ عذرٕ وَرٲے  پننِس کٲفر قو مس در میان قیام کٔرِ تھ ٲسۍ تہٕ نیم مسلمان تہٕ نیم کٲفرا نہٕ زند گی بسر کر نس پٮ۪ٹھ ٲسۍ رٲضۍ ۔ حالانکہ اکھ دارُلالسلام اوس  بد س آمُت یَتھ کُن یِم ہجر ت ہیٚکہَن کٔرِ تھ تہٕ یِہِندِ خٲطرٕ اوس پننہِ دین وا عتقادٕ مُطا بق پوٗرٕ اسلامی زند گی بسر کرٕنۍ ممکن سپُد مُت تہٕ دارُلاسلام طر فہٕ ٲس یِمن یہِ دعوت تہِ دِنہٕ آمٕژ زِ پنُن ایمان بچا و نہٕ خٲطرٕ وٲتِن ہجر ت کٔرِ تھ اور،﴾ تِمو دِیُت جوا ب زِ أسۍ ٲسۍ زمینس اندر کمزور تہٕ مجبور ،فر شتو ووٚ نہکھ : کیا اللہ تعالیٰ سٕنز زمین ٲس نا وسیع تا کہ توٚہۍ کٔرِ ہِو تَتھ اندر ہجر ت ؟ یِم چِھ تِم لُکھ یُہُند ٹھکا نہٕ جہنم چُھ تہٕ سُہ چُھ سٮ۪ٹھٕہٕے بُرٕ ٹھکا نہٕ۔"
  4,98,"۔ آ، یِم مرد، مستورا تہٕ تہٕ شُر ۍ پز ی بے بس چِھ تہٕ نیرنٕچ کانٛہہ وَتھ یا ذر یعہ چِھنہٕ لبا ن ،"
  4,99,"۔﴿یہِ کتھ چَھنہٕ ﴾ دور زِ اللہ تعالیٰ کرِ تِمن معا ف، اللہ تعالیٰ چُھ بوٚڈ معا ف کر ن وول تہٕ در گُزر کر ن وول۔"
  4,100,"۔یُس اکھا ہ اللہ تعالیٰ سٕنزِ وَتہِ منٛز ہجر ت کرِ سُہ لبہِ زمینس اندر پنا ہ نِنہٕ خٲطرٕ واریاہ جا ے تہٕ روز نہٕ خٲطرٕ سٮ۪ٹھاہ گُنجٲیش تہٕ یُس اکھا ہ پننہِ گھرِ خُدا یس  تہٕ رسول ﴿صلی اللہ علیہ وسلمس ﴾ کُن ہجر ت خٲطرٕ نیرِ پتہٕ  یِیہِ تس وَتہِ منٛزٕ ے مو ت تٔمۍ سُند اجر سپُد اللہ تعالیٰ سٕندِ ذمہٕ وٲجب، اللہ تعالیٰ چُھ سٮ۪ٹھاہ مغفر ت کر ن وول تہٕ رحیم۔ع ﴿یتھ جایہِ گژِھہ یہِ کتھ  سمجھنۍ زِ ییٚمۍ شخصن اللہ تعالیٰ سٕندِس دینس پٮ۪ٹھ ایمان آسہِ اوٚ نمُت۔ تس خٲطرٕ چھےٚ کُفرٕ کِس نظا مس تحت زند گی گُزارٕنۍ صرف دۅ ن صوٗرتن منٛز جٲیز۔اکھ یہِ زِ سُہ روزِ تَتھ سر زمینس منٛز اسلام غا لب کر نٕچ تہٕ کُفر ک نظا م اسلام کِس نظا مس منٛز تبد یل کر نٕچ   جد و جہد کران یِتھہٕ پٲٹھۍ انبیا علیہم السلام تہٕ تِہِندۍ ابتدٲیی پیرو کار کران چِھ روٗدِمٕتۍ۔دوٚییُم یہِ زِ تس آسہِ نہٕ پٔزۍ پٲٹھۍ تَتہِ نیرنٕچ کانٛہہ وَتھ اَتھہِ یِوان تہٕ سُہ آسہِ سخت نفر ت تہٕ بے زٲر ی سان مجبور اً تَتہِ قیام کٔرِ تھ۔﴾"
  4,101,"۔تہٕ ییٚلہِ توٚہۍ سفرٕ خٲطرٕ نیٖرِ و کانٛہہ پرواے چُھنہٕ اگر توٚہۍ نمازِ منٛز اِختصار کٔرِ و۔﴿اَمنہٕ کہ وقتہٕ کہ سفرُک قصر چُھ یہِ زِ یِمن وقتن ژور رکٲژ فر ض چھےٚ تِمن منٛز گژھن زٕ ہ رکٲژ پر نہِ تہٕ جنگ کِس حا لتس منٛز چُھنہٕ قصرٕ خٲطرٕ کانٛہہ حد مُقرر۔ جنگی حا لات ییٚمہِ طر یقہٕ تہِ اجازت دِن نماز گژِھہ پر نہٕ یِنۍ ۔ ﴾ ییٚلہِ زن تۅہیہِ اند یشہ آسہِ زِ کٲفر ستا و نَو تۅہیہِ تِکیازِ تِم چِھ نَنہِ وا نہٕ تۅہیہِ سٍتۍ دشمنی پٮ۪ٹھ ڈٔٹِتھ۔"
  4,102,"۔تہٕ اے نبی صلی اللہ علیہ وسلم،ییٚلہِ توٚہۍ مسلمانن در میان ٲسِو تہٕ ﴿جنگ کِس حالتس  منٛز ﴾ سپدِ  و تِم نماز پر ناو نہٕ خٲطرٕ کھڑا تیٚلہِ گژِھہ تِمو منٛزٕ اکھ جماعت تۅہیہِ سٍتۍ کھڑا سپدٕ نۍ تہٕ پنُن سامانہٕ تھٲوِ ن پا نس سٍتۍ ،پتہٕ ییٚلہِ سۅ سجد ہ کرِ تیٚلہِ نیٖرِ ن پتھ کُن تہٕ بیاکھ جماعت ییٚمۍ نہٕ وُنہِ نمازِ آسہِ پٔر مٕژ یِیِن تہٕ پٔرِن تۅہیہِ سٍتۍ نماز تہٕ سۅ تہِ روٗزِن ہُشیار تہٕ پنُن سامانہٕ تھٲوِن سٍتۍ۔﴿صلٰو تہِ خو فُک یہِ حکم چُھ تتھ صورتس منٛز ییٚلہِ زَن دشمن سٕندِ حملُک خطرٕ آسہِ مگر عملاً آسہِ نہٕ قتا لُک معر کہ گر م کینٛہہ۔ ﴾  تِکیازِ کُفار چِھ ز اگہِ روٗزِ تھ زِ توٚہۍ گٔژِھو پننیو ہتھیارَو تہٕ پننہِ سا مانہٕ نِشہِ ہنا غا فل تہِٕ تِم کر ن تۅہیہِ پٮ۪ٹھ اکی ساعتہٕ حملہ البتہٕ اگر توٚہۍ روٗد کہ و جہ کِنۍ تکلیف محسو س کٔرِو یا بیمار ٲسِو تیٚلہِ چُھنہٕ سا ما نہٕ کٔڑِ تھ تھاو نس منٛز کانٛہہ حر ج مگر تو تہِ روٗزِ و حیٚسہٕ، یقین تھٲوِو زِ خُدا ین چُھ کٲفر ن خٲطرٕ رُسوا کر ن وول عذا ب تھو و مُت ۔"
  4,103,"۔پتہٕ ییٚلہِ نمازِ نِشہِ فا رغ سپدِ و  تیٚلہِ روٗزِ یوٗن وۅ دٕنۍ تہٕ بِہِتھ تہٕ لرترٲوِ تھ، پرتھ حا لس منٛز اللہ تعالیٰ یاد کران پتہٕ ییٚلہِ اطمنان سپد یو تیٚلہِ پٔرِ و پوٗرٕ نماز ،در حقیقت  چھےٚ نماز تِیُتھ فر ض  یُس وقتہٕ چہِ پا بند ی سان با ایمانن پٮ۪ٹھ لا زم چُھ آمُت کر نہٕ۔"
  4,104,"۔مَہ ہٲوِ و کمزور ی اَتھ جما عتس پتہٕ دورنس منٛز اگر توٚہۍ تکلیف چِھو تُلان، تِم تہِ چِہ تُہندی پٲٹھۍ تکلیف تُلان تہٕ توٚہۍ چِھو خُدا یس نِشہِ تمہِ چیزٕ کۍ اُمید وار ییٚمکۍ اُمیدوار تِم چِھنہٕ ،اللہ تعالیٰ چُھ سورُے کینٛہہ زانان تہٕ سُہ چُھ زانن وول تہٕ حکمت وول۔ع"
  4,105,"۔اے نبی صلی اللہ علیہ وسلم، اسہِ چھےٚ یہِ کتا ب حق ہیٚتھ تۅ ہیہِ کُن نٲزِل کٔرمٕژ تا کہ یوسہٕ سِیٔز وَتھ خُدا ین تۅہیہِ ہٲومٕژ چھےٚ تتھ مطٲبق کٔرِ و لُکن در میان فٲصلہٕ ،توٚہۍ مَہ بٔنِو بد دیا نت لُکن ہٕندِ طرفہٕ ژُوَن وٲلۍ۔"
  4,106,"۔تہٕ خُدا یس کٔرِو در گُزر کر نُک در خوا ست سُہ چُھ سٮ۪ٹھاہ در گُزر کر ن وول تہٕ رحیم۔"
  4,107,"۔یِم لُکھ پننِس نفسس سٍتۍ خیا نت چِھ کران۔توٚہۍ مہ کٔرِ و تِمن حما یت ﴿یُس شخص دوٚیِمِس سٍتۍ خیا نت چُھ کران سُہ چُھ دراصل گۅڈٕہ پننِس پا نس سٍتۍ خیا نت کران۔﴾ خُدا یس چُھنہٕ تِیُتھ شخص پسند یُس خیا نت کار تہٕ بد کار آسہِ۔"
  4,108,"۔ یِم لُکھ ہیٚکن انسانن نِشہِ پنٕنۍ حر کات چُھپٲو ِتھ مگر خُدا یس نِشہِ ہیٚکن نہٕ چُھپٲوِتھ، سُہ چُھ تمہِ ساعتہٕ تہِ یِمن سٍتۍ آسان ییٚلہِ یِم رٲژن اندر ژوٗرِ روٗزِ تھ تٔمۍ سٕنزِ مر ضی خلا ف مشورٕہ چِھ کران یِہِنزن سارِنٕے عملن پٮ۪ٹھ چُھ اللہ تعالیٰ اِحا طہٕ کٔرِ تھ ۔"
  4,109,"۔آ، تۅہیہِ لُکو کٔرٕو یِمن مُجر من ہٕند طر فہٕ دنیا چہِ زند گی منٛز لڑٲے مگر قیا مت کہ دۅ ہ کُس کرِ تِہندِ مۅ کھہٕ خُدا یس سٍتۍ لڑٲے؟ ٲخر کُس آسہِ تَتہِ یُہُند وکیل؟"
  4,110,"۔اگر کانٛہہ شخص غلط کٲم کرِ یا کرِ پننِس نفسس پٮ۪ٹھ ظُلم تہٕ امہِ پتہٕ کرِ خُدا یس در گز ر کر نُک در خوا ست سُہ لبہِ خُدا یس در گُز ر کر ن وول تہٕ رحیم۔"
  4,111,"۔مگر یُس بُرٲیی کماوِ تٔمۍ سٕنز یہِ کمٲے آسہِ تٔمۍ سٕندِ خٲطرٕ وبال۔ خُدا یس چھےٚ تمام کتھن ہٕنز خبر تہٕ سُہ چُھ زانن وول تہٕ حکمت وول۔"
  4,112,"۔پتہٕ ییٚمۍ کٲنٛسہِ أکۍ کانٛہہ خطا یا گناہ کوٚر پتہٕ کھولُن تَمِیُک الزام کٲنٛسہِ بے گنا ہس پٮ۪ٹھ تٔمۍ کوٚر سٮ۪ٹھاہ بَڑِ بہتا نُک تہٕ ٹا کارٕ ہ گنا ہُک بار جمع۔ع"
  4,113,"۔اے نبی صلی اللہ علیہ وسلم، اگر اللہ تعالیٰ سُند فضل تۅہیہِ پٮ۪ٹھ آسِہے نہٕ تہٕ تٔمۍ سٕنز رحمت آسہِے نہٕ تۅہیہِ شٲملِ حال تیٚلہِ اوس یِمو منٛزٕ أکۍ دٔرۍ توٚہۍ غلط فہمی منٛز مبتلا کر نُک فٲصلے کوٚر مُت حا لانکہ پز ر چُھ یہِ زِ تِم ٲسۍ نہٕ پانس ورٲے بیٚیہِ کٲنسہِ غلط فہمی منٛز مبتلا کرا ن تہٕ تۅہیہِ ہیٚکہَن نہٕ کانٛہہ نقصا ن کٔرِ تھ۔﴿یعنی اگر تِم غلط تفصیل تہٕ شہا دتہٕ پیش کٔرِ تھ تۅہیہِ غلط فہمی منٛز مبتلا کر نس منٛز کامیاب تہِ گژھہَن تہٕ پننِس حقس منٛز کر ہن انصا فس خلا ف فٲصلہٕ تہِ حٲصل ،تیٚلہِ تہِ اوس نقصا ن تِہُندُے ، تۅہیہِ واتِہہَو نہٕ کانٛہہ نقصان۔ تِکیازِ خُدا یس نز دیک آسہن مُجرِ م تِم نَہ زِ توٚہۍ۔ یُس شخص حٲکِمس دو کھہٕ دِتھ پننِس حقس منٛز غلط فٲصلہٕ چُھ حٲصل کران سُہ چُھ خۅد پننِس پا نس اَتھ غلط فہمی منٛز ترٛاوان زِ یِمَو تدبیر و سٍتۍ سپُد حق تٔمۍ سُند حالانکہ پزر چُھ یہِ زِ خُدا یس نز دیک ییٚمۍ سُند حق چُھ سُہ چُھ تٔمۍ سُندُے روزان تہٕ کُنہِ غلط فہمی ہٕندِس بُنیا دس پٮ۪ٹھ حاکِم عدالت سُند فٲصلہٕ کر نہٕ سٍتۍ چَھنہٕ حقیقتس پٮ۪ٹھ کانٛہہ فر ق پیٚوان۔﴾ خُدا ین چھےٚ تۅہیہِ پٮ۪ٹھ کتا ب تہٕ حکمت نٲزِل کٔر مٕژ تہٕ تۅہیہِ چُھنَو تِکینژھاہ وونمُت یِنہٕ تۅہیہِ پے ٲس تہٕ تٔمۍ سُند فضل چُھ تۅہیہِ پٮ۪ٹھ سٮ۪ٹھاہ بوٚڈ۔"
  4,114,"۔لُکن ہٕنز ن خُفیہ سِرٕ کتھن منٛز چُھنہٕ اکثر و بیشتر کانٛہہ رٕژر آسان، آ، اگر کانٛہہ ژھایہِ پٲٹھۍ صد قُک تہٕ خیر اتُک تلقین  کرِ یا کُنہِ نیک کامہِ خٲطرٕ ، یا وَنہِ لُکن ہٕندٮ۪ن معا ملاتن منٛز اصلا ح کر نہٕ مۅ کھہٕ کٲنٛسہِ کینٛہہ ، تیٚلہِ چھےٚ یہِ رٕژ کتھ تہٕ یُس اکھا ہ اللہ تعالیٰ سٕنزِ رضا مند ی خٲطرٕ یہِ کرِ تس کرو عنقر یب أسۍ بوٚڈٕ اجر عطا ۔"
  4,115,"۔مگر یُس شخص رسول ﴿صلی اللہ علیہ وسلمن ﴾ ہٕندِس مخا لفتس پٮ۪ٹھ ہوٚ ل گٔنڈِ تھ آسہِ تہٕ اہلِ ایمانن ہٕنزِ رٔوِشہِ ورٲے پکہِ بیٚیہِ کُنہِ رٔوِشہِ پٮ۪ٹھ ،حالانکہ آسہِ تس پٮ۪ٹھ  سیٚزِ وَتھ وا ضح سپٕز مٕژ تیٚلہِ پکنا وون سُہ أسۍ توٗر ۍ کُن یو رکُن سُہ پانہٕ  پھِیوٗر تہٕ سُہ چھکون جہنمس منٛز یۅسہٕ بدتر ین روزن جا ے چھےٚ ۔ ع"
  4,116,"۔اللہ تعالیٰ کرِ نہٕ بس شرِ کسٕے یو ت معا ف ،امہِ ورٲے ہیٚکہِ سورُے کینٛہہ معا ف سپدِتھ، یَس سُہ معا ف ییٚژِھہ کرُن، ییٚمۍ خُدا یس سٍتۍ کانٛہہ شر یک زو ن سُہ دراو گمرٲہی منٛز سٮ۪ٹھاہ دوٗر۔"
  4,117,"۔تِم چِھ خُدا یس ترٲوِتھ دیو ی یَن معبود بناوان، تِم چِھ تس بٲغی شیطا نس معبود بناوان۔"
  4,118,"۔یس خُدا ین لعنت کٔر ۔﴿ شیطا نس چُھنہٕ اتھ معنیس منٛز کانٛہہ تہِ معبو د بناوان زِ تس برونٛٹھہٕ کنہِ آسہِ بند گی ہٕندی رسم ادا کران تہٕ تس آسہِ الو ہیتُک در جہِ دِوان ۔ البتہ چھےٚ تس معبود بناوٕنٕچ صورت  یہِ زِ انسان چُھ پننہِ نفسٕچ لاکم شیطا ن سٕندِس اتھس منٛز دِوان تہٕ یپٲرۍ سُہ پھِروان چُھس تپٲرۍ چُھ پھیران، گویا کہ یہِ چُھ تٔمۍ سُند بند ہ تہٕ  سُہ چُھ أمۍ سُند خُدا ے۔ امہِ نِشہِ لوٚگ پے زِ ژھۅ پہٕ دم کٔرِ تھ تہٕ أچھ ٹُوِ تھ اطا عت تہٕ پیروی کر نُک ناو تہِ چُھ عبا دت ، تہٕ یُس شخص امہِ قسمٕچ اطا عت کران چُھ سُہ چُھ دراصل تس شخصہٕ سٕنز عبا دت کران یُس تٔمۍ خُدا ے ترٲوِ تھ پنُن مُطا ع آسہِ بنو و مُت۔﴾ ﴿تِم چِھ تس شیطا ن سٕنز اطا عت کران۔﴾ ییٚمۍ خُدا یس اوس ووٚنمُت زِ : بہٕ ہیٚمہٕ چا نیٚن بند ن اکھ مقرر  حصہٕ ضرور ۔﴿یعنی یِہند ٮ۪ن اوقا تن منٛز، یِہِنز ن محنتن تہٕ کوٗششن منٛز، یِہِنزن قُوّ تن تہٕ قٲبلیتن منٛز،یِہندِس مالس تہٕ یِہندٮ۪ن اولادن منٛز لگا وٕ بہٕ پَنُن حصہٕ تہٕ تِتھہٕ پٲٹھی پھسا وکھ زِ یِم کر ن یِمن سارِنٕے چیز ن ہُند اکھ بوٚڈ حصہٕ میانہِ وَتہِ منٛز خر چ ۔ ﴾"
  4,119,"۔بہٕ ڈا لکھ یِم ، بہٕ پھساوَکھ یِم طمعہن منٛز  ،بہٕ دِمہٕ یِمن حکم تہٕ میانہِ حُکمہٕ دِن یِم جانور ن کنَن تٕرٛتھ۔﴿اہلِ عر بن ہٕند یو تو ہما تو منٛزٕ چُھ أکِس کُن اِشارٕ ہ۔تِہُند اکھ قٲعدہ اوس زِ ییٚلہِ اونٹِنہِ پانٛژھہ یاداہ بچہِ زیوٕ ہَن ،تس ٲسۍ کنن تٕرٛتھ دِتھ پننِس دیوتا سٕندِس ناوس پٮ۪ٹھ یلہٕ تروان تہٕ تس کٲم ہیٚنۍ اوس حرا م یِوان زاننہٕ ۔ یِتھے پٲٹھۍ ییٚمِس اونٹہٕ سٕندِ نطفہٕ سٍتۍ داہ بچہِ زیو ہَن سُتہِ اوس دیو تا سٕندِس ناو س پٮ۪ٹھ صدقہٕ رٔنگۍ یلہٕ تراونہٕ یِوان تہٕ کنس تٕرتھ دِیُن ٲس امہِ کتھہِ ہٕنٛز علا مت زِ یہِ چُھ خیرا ت رٔنگۍ یلہٕ تروانہٕ آمُت جانور۔﴾  ۔تہٕ بہٕ دِمہٕ یِمن حکم تہٕ یِم کر ن میانہِ حُکمہ خُدا یی سا ختس منٛز ردو بد ل۔﴿خُدا یی ساختس منٛز ردو بد ل کر نُک مطلب چُھنہٕ چیز ن ہٕندِس پیدٲیشی بناو ٹس منٛز ردو بد ل کرُن کینٛہہ بلکہ یتھ جایہِ یَتھ رد و بد لس شیطٲنی کٲم چھےٚ وَننہٕ آمٕژ سۅ چھےٚ یہِ زِ انسان ہیٚیہِ کُنہِ چیز س سۅ کٲم ییٚمہِ خٲطرٕ خدا ین سُہ پٲدٕ چُھنہٕ کوٚر مُت، تہٕ کُنہِ چیز س ہیٚیہِ نہٕ سۅ کٲم ییٚمہِ خٲطرٕ سُہ خُدا ین پٲدٕ چُھ کوٚر مُت ۔ دوٚ یِمیٚن لفظن منٛز وَنَو تِمہٕ  سار ے کامہِ یِمہٕ انسان پننِس تہٕ با قی  چیز ن ہٕندِس فطرتس خلا ف چُھ کران ، تہٕ تِمہٕ تمام صوٗرتہٕ یِمہٕ سُہ فطر ت کہِ منشہِ نِشہِ ژَلنہٕ خٲطرٕ اختیار چُھ کران۔ییٚمہِ آیت موجوٗب چِھ شیطا ن سٕنٛدۍ گمراہ کُن تحر یکا ت یِم :قومِ لو طٕچ عمل ،ضبِط ولادت، رہبٲنیت، نیترٕ ورٲے روزُن ، مرد تہٕ زنانہٕ ہانٛٹھ بناو نہِ ، مرد بناوُن نا مرد ،زنا نہٕ تِمو کامیو نِشہِ مُچھہِ تھا و نہِ یِمہٕ فطرتَن تِمن حوالہٕ چھےٚ کرِ مژٕ تہٕ تِمہٕ تمدُن کیٚن تِمن شعبن منٛز کھکھرِ اَننہٕ یِمن خٲطرٕ مرد چُھ پٲدٕ آمُت کر نہٕ۔﴾یہِ شیطا ن ییٚمۍ کٲنٛسہِ أکۍ خُدا یس بجاے یہِ پنُن ولی تہٕ سر پرست بنو و سُہ پیٚو ونَنہِ وا نہٕ خسا رس منٛز۔"
  4,120,"۔سُہ چُھ یِمن لُکن سٍتۍ وعدہ کران تہٕ یِمن چُھ امیدٕ دِوان مگر شیطا ن سٕندۍ سٲر ی وعدہ چِھنہٕ فر یب ورٲے بیٚیہِ کِہِنۍ۔"
  4,121,"۔ یِمن لُکن ہُند ٹھکا نہٕ چُھ جہنم ییٚمہِ نِشہِ یِم مۅ کلنٕچ کانٛہہ صورت لبن نہٕ۔روٗدۍ تِم لُکھ یِم ایمان اَنن تہٕ نیک عملہٕ کر ن تِم کروکھ أسۍ تِتھیٚن باغن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان۔"
  4,122,"۔تِم روزن تَتہِ ہمیشہ ہمیشہ خٲطرٕ ،یہِ چُھ اللہ تعالیٰ سُند پوٚز وعدہ تہٕ خُدا یس کھۅ تہٕ کُس آسہِ پننہِ کتھہِ منٛز پٔزِ یو ر۔"
  4,123,"۔انجام کار ﴿عذا ب تہٕ ثواب﴾ نَہ چُھ تُہندٮ۪ن آرِزُوَن پٮ۪ٹھ مو قو ف نہ اہلِ کتا بن ہٕندٮ۪ن آرزُوَن پٮ۪ٹھ، یُس اکھا بُرٲیی کرِ تِمیُک پھل لبہِ سُہ تہٕ خُدا یس مقا بلہٕ لبہِ نہٕ پننہِ خٲطرٕ کانٛہہ حٲمی تہٕ مددگار۔"
  4,124,"۔تہٕ یُس اکھا نیک عمل کرِ ،خوا ہ سُہ مر دٲسِتن یا زنانہٕ، بشرطیکہِ آسہِ مو من تیٚلہِ گژھن یِتھی لُکھ جنتس منٛز دٲخل تہٕ تِمن سپدِ نہٕ زَرس سُمب حق تلفی ۔"
  4,125,"۔تس شخصہٕ سٕندِ کھۅتہٕ بہتر کٔمۍ سُند طر یقِ زند گی ہیٚکہِ بہتر ٲسِتھ ییٚمۍ خُدا یس برونٛٹھہٕ کنہِ پنُن کلہٕ نوٚ مروو، تہٕ پنُن رٔوِیہِ تھووُن نیک تہٕ یک سُو سپدِ تھ کٔرٕ ن ابرا ہیم علیہ السلام سٕندِ طر یقٕچ پیر وی تس ابرا ہیم علیہ السلام سٕندِ طر یقٕچ پیر وی یُس خُدا ین پنُن دوست اوس بنو و مُت۔"
  4,126,"۔آسمانن تہٕ زمینس منٛز یِکینژھاہ چُھ، سُہ چُھ اللہ تعالیٰ سُند تہٕ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ احا طہٕ کٔرِ تھ۔ع"
  4,127,"۔لُکھ چِھو تۅہیہِ مستوراتن ہٕندِس معا ملس منٛز فتویٰ پٕرٛژھان۔﴿یہِ چُھنہٕ آمُت وَننہٕ زِ کیا فتویٰ ٲسۍ پرٛژھان۔ البتہٕ آیت 128،پٮ۪ٹھہٕ ، 130، ہَس منٛز یُس فتویٰ دِنہٕ آمُت چُھ تمہِ سٍتۍ چھےٚ سوالٕچ نو عیت فِکرِ تران۔﴾ ؤنِو ، اللہ تعالیٰ چُھو تۅہیہِ تِہِندِس معا ملس منٛز فتویٰ دِوان۔تہٕ سٍتی چُھو تِم احکام تہِ یاد پاوان یِم گۅڈٕ ہ پٮ۪ٹھے تۅہیہِ یتھ کتا بہِ منٛز چِھ بوزناو نہٕ یِوان، یعنی تِم احکام یِم تِمن یتیم کورن متعلق چِھ یِہِندۍ حق توٚہۍ ادا چِھو نہٕ کران تہٕ یِہِندۍ نکا ح  کرنس منٛز توٚہۍ باز چھِو روزان۔﴿یا چھِو لالچہ ہٕندِس بنیادس پٮ۪ٹھ پانہٕ یژھان توٚہۍ تِمن سٍتۍ نکاح کرُن۔﴾﴿تَرُ غَبُو نَ تَنکِحُو ھُن، اَمیُک مطلب ہیٚکہِ یِتہِ ٲسِتھ زِ  تۅہیہِ چَھو یِمن سٍتۍ نکا ح کر نٕچ رغبت  تہٕ یِتہِ ہیٚکہِ ٲسِتھ زِ تۅہیہِ چُھو نہٕ یِمن سٍتۍ نکا ح پسند۔﴾ تہٕ تِم احکام یِم تِمن شُر ٮ۪ن متعلق چِھ یِمن بے چا ر ن کانٛہہ طاقت چُھنہٕ ،اللہ تعالیٰ  چُھو تۅہیہِ ہدا یت دِوان زِ یتیمن سٍتۍ روٗزِ و انصا فس پٮ۪ٹھ قٲیِم تہٕ یُس رٕژَر توٚہۍ کٔرِ و سُہ روزِ نہٕ اللہ تعالیٰ سٕندِ علمہٕ نِشہِ کھٔٹِتھ۔"
  4,128,"۔اگر کٲنٛسہِ زنانہِ پننِس خاندارس نِشہِ بد سلو کی یا بے رُخی ہُند خطرٕ ہ آسہِ ، ﴿ییٚتہِ پٮ۪ٹھ چُھ لُکن ہٕندِ سوالُک جوا ب شر وع سپدان۔سوال اوس یہِ زِ اکہِ کھۅتہٕ زٲیِد خاندارنہِ آسنٕکِس صورتس منٛز یُس عد لُک حُکم چُھ دِنہٕ آمُت تَتھ پٮ۪ٹھ کِتھہٕ پٲٹھۍ یِیہِ عمل کر نہٕ ییٚلہِ زن اکھ خاندارنۍ چھےٚ ہمیشہ بیمار ﴿دا یُم المر ض ﴾ یا جسمٲنی رٲبطس قٲبل چَھنہٕ روٗزمٕژ۔کیا اتھ صورتس منٛز تہِ چھا أمِس پٮ۪ٹھ لٲزِ م زِ دۅ شونۍ سٍتۍ تھا وِ یکسا ن محبت؟ جسمٲنی تعلقس منٛز تہِ وَرتاوِ ہِشر ؟ تہٕ ہرگاہ سُہ یہِ کرِ نہٕ تیٚلہِ چھا عدل کہ شر طُک تقا ضہٕ یہِ زِ دوٚیِم خاندر کر نہٕ مۅکھہٕ تراوِ سُہ گۅڈٕ نچہِ خاندارِنہِ؟ بیٚیہِ اگر گۅڈنِچ خاندار نۍ پانہٕ ییٚژِھہ  نہٕ جُدا سپدُن، کیا تیٚلہِ ہیٚکِیا دۅ ن بٲژن منٛز امہِ قٔسمُک معا ملہٕ سپدِ تھ زِ یۅسہٕ خاندارِنۍ غیر مر غو ب سپٕز مٕژ چھےٚ سۅ کرِ پننیو کینژھو حقو قَو نِشہِ پنُن پان دست بردار تہٕ خاندارس کرِ طلا ق نِشہِ باز روزنس پٮ۪ٹھ رٲضۍ؟ کیا یہِ کٲم کرٕنۍ ماچھےٚ عد ل کِس شر طس خلا ف ؟﴾ کانٛہہ پرواے چُھنہٕ زِ خاندار تہٕ خاندارِنۍ کَر ن ﴿کینٛژھن حقو قن ہٕنزِ کمی بیشی پٮ۪ٹھ﴾ پانہٕ وٲنۍ صلح ۔ ﴿یعنی طلا ق تہٕ جُدٲیی نِشہِ چُھ بہتر زِ پانہٕ وٲنۍ مصٲلحت کٔرِ تھ روٗزِ ن اکھ خاندارِنۍ تٔسۍ خاندارس سٍتۍ یَس سٍتۍ تَمہِ وٲنٛسہِ ہُند اکھ  حصہ گُزورمُت چُھ ۔﴾ صلح چھُ بہرحال بہتر۔نفس چِھ تنگ دِلی کُن جلد ی مٲیل سپدان البتہٕ اگر توٚہۍ لُکھ احسا ن سان پیش یِیِو تہٕ خُدٲے خو فس ہیٚیِو کٲم تیٚلہِ تھٲوِ و پژھ زِ اللہ تعالیٰ آسہِ نہٕ تُہٕندِ اَمہِ طر زِ عملہٕ نِشہِ بے خبر۔"
  4,129,"۔خاندارِ نیٚن در میان پوٗرٕ پوٗرٕ عدل کرُن چُھنہٕ تۅہیہِ تام ہرگاہ توٚہۍ ییٚژِھو تہِ تو تہِ ہیٚکِو نہٕ کٔرِ تھ لہٰذا ﴿چُھ قا نو نِ الہٰی یُک منشہِ پوٗرٕ کر نہٕ خٲطرٕ یہِ سٮ۪ٹھاہ زِ ﴾ أکِس خاندار نہِ کُن مَہ نٔمِو تِتھہٕ پٲٹھۍ زِ دوٚ یِم تھٲوِیو ن آو یزان۔﴿ییٚمہِ آیت نِشہِ چُھ کینژھو یہِ نتیجہِ کوٚڈمُت زِ قرآن چُھ اکہِ پا سہٕ عد ل کہ شر طہٕ سان تعدادِ ازوا جُک اجازت دِوان تہٕ دوٚ یمہِ پاسہٕ چُھ عدلس نا ممکن قرار دِتھ یہِ اجازت عملاً منسوخ کران۔در حقیقت چَھنہٕ اَتھ آیتس منٛز یُتھ نتیجہِ کڑ نہٕ خٲطرٕ کانٛہہ گُنجٲیش۔اگر صرف یُتُے وَننس پٮ۪ٹھ اکتفا کر نہٕ  آسہِے آمُت زِ توٚہۍ ہیکِو نہٕ خاندارِنیٚن در میان عد ل کٔرِ تھ۔ تیٚلہِ یِیہِ ہے یہِ نتیجہِ کڑ نہٕ ، مگر امہِ پتے چُھ یہِ فر ماو نہٕ آمُت زِ لہٰذا نٔمۍ زیو نہٕ با لکلٕے أکۍ سٕے خانادرِنہِ کُن۔ اَمہِ کتھہِ تھو و نہٕ کانٛہہ مو قع امہِ مطلبہٕ خٲطرٕ پتھ کُن یُس مسیحی یوٗر پس  تقلید کر ن وٲلۍ حضرات اَمہِ نِشہِ کڑُن چِھ یژھان۔﴾ اگر توٚہۍ پنُن طر زِ عمل  دُرست تھٲوِ و تہٕ خُدا یس روٗزِ و کھۅژان اللہ تعالیٰ چُھ چشم پوٗشی کر ن وول تہٕ رحم کر ن وول۔"
  4,130,"۔البتہ اگر زٕ ہ بٲژاکھ أکِس نِشہِ بیٚو نٕے سپد ن اللہ تعالیٰ کرِ پننہِ وسیع  قدرت سٍتۍ دۅ شوٕنۍ اکھ أکۍ سٕنزِ محتا جی نِشہِ بے نیا ز ،اللہ تعالیٰ سُند دا من چُھ واریاہ کُشادہ تہٕ سُہ چُھ دانا و بینا۔"
  4,131,"۔آسما نن تہٕ زمینس منٛز یِکینژھاہ چُھ، سورُے چُھ اللہ تعالیٰ سُندُے ،تۅہیہِ برونٛہہ یِمن اسہِ کتا ب دِژ مٕژ ٲس ،تِمن تہِ اوس یۅہے ہدا یت دِیتمُت تہٕ وۅ نۍ چِھو تۅہیہِ تہِ یۅ ہے ہدا یت دِوان زِ خُدا یس کھوٗژۍ کھۅٗژۍ روٗزِ و کٲم کران البتہ اگر توٚہۍ مانان چِھو نہٕ ، مَہ مٲنِو آسما ن تہٕ زمین کیٚن تمام چیزن ہُند مٲلِک چُھ بس خدا ے تہٕ سُہ چُھ بے نیا ز، پرٛتھ تعر یفُک حقدار۔"
  4,132,"۔ آ، بس خدا ے چُھ مٲلک تِمن سارِنٕے چیزن ہُند یِم آسمانن منٛز چِھ تہٕ یِم زمینس اندر چِھ تہٕ کار سٲزی خٲطرٕ چُھ بس سُے کٲفی۔"
  4,133,"۔ہرگاہ سُہ ییٚژِھہ تۅہیہِ ہٹٲوِتھ اَنہِ سُہ با قین تُہنزِ جایہِ تہٕ سُہ چُھ اَمِچ پوٗرٕ قدرت تھاوان،"
  4,134,"۔ یُس شخص محض دُنیا کہ ثوا بُک طٲلب آسہِ تَس گژِھہ پے آسٕنۍ زِ خُدا یس نِشہِ چُھ ثوا بِ دنیا تہٕ ثو اب ٲخر ت تہِ تہٕ اللہ تعالیٰ چُھ سمیع وبصیر﴿بوزن وول تہِ تہٕ وُچھن وول تہِ ﴾ ۔ع"
  4,135,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت انصا فٕکۍ عَلم بردار تہٕ اللہ تعالیٰ سٕندِ موجوٗب بٔنِو گواہ اگر چہِ تُہنٛدِ انصا فُک تہٕ تُہنزِ گوٲہی ہُند دَب خۅد تُہٕندِس پننِس ذا تس پٮ۪ٹھ یا تُہندِس مٲلِس ماجہِ تہٕ رشتہٕ دارن پٮ۪ٹھ کیازِ آسہِ نہٕ وَسان معا ملُک فر یق خواہ مال دار ٲسِتن یا غر یب اللہ تعالیٰ چُھ تُہٕندِ کھۅتہٕ زیادٕہ تِہُند خیر خواہ لہٰذا مَہ روٗزِ و پننہِ نفس چہِ خوٲہشہِ ہٕنزِ پیر وی منٛز عدلہٕ نِشہِ پَتھ  تہٕ اگر تۅہیہِ وُٹِھتھ کتھ ؤنِو یا پزرٕ نِشہِ بچو وُو دا من۔تیٚلہِ زٲنِو زِ یِکینژھاہ توٚہۍ کران چِھو خُدا یس چھےٚ  تِمچ خبر ۔"
  4,136,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ایمان أنِو خُدا یس پٮ۪ٹھ تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس﴾ پٮ۪ٹھ تہٕ تتھ کتا بہِ پٮ۪ٹھ یۅسہٕ خُدا ین پننِس رسول ﴿صلی اللہ علیہ وسلمس﴾ پٮ۪ٹھ نٲزِل چھےٚ کٔر مٕژ تہٕ پرٛتھ تتھ کتا بہِ پٮ۪ٹھ یِمہٕ ییٚمہِ برونٛہہ تٔمۍ نٲزِل چھےٚ کرِ مژٕ۔﴿ایمان اَنن والیٚن وَنُن زِایمان أنِو چُھ بظٲہر عجیب با سان۔ مگر یتھ جایہِ چُھ لفظ ایمان دۅ ن الگ معنیِن منٛز وَرتاو نہٕ آمُت۔ ایمان اَننُک  اکھ مطلب چُھ یہِ زِ انسان کٔرِن انکارٕ بجا یہِ اقرارٕچ وَتھ اختیار، نہ مانَن والیٚن نِشہِ الگ سپدِ تھ گٔژِھن مانن والیٚن منٛز شٲمل۔ تہٕ اَمِیُک دوٚ یُم مطلب چُھ یہِ زِ انسان یتھ چیز س مانہِ تتھ مٲنِن پزِ دِلہٕ سان ، پوٗرٕ سنجیدگی سان تہٕ خلو ص سان۔ آیتس منٛز چُھ خطا ب تِمن تمام مسلمانن یِم گۅڈنِکہِ معنی کہ لحا ظہٕ مانن والیٚن منٛز شُما ر چِھ سپدان تہٕ تِمن چُھ مطا لبہٕ آمُت کر نہٕ زِ دوٚ یِمہِ معنی کہ لحا ظہٕ بٔنِن پٔزۍ مو من۔﴾ ییٚمۍ خُدا یس تہٕ تٔمۍ سٕندٮ۪ن ملٲیکن تہٕ تٔمۍ سٕنز ن کتابن تہٕ تٔمۍ سٕندٮ۪ن رسولن تہٕ قیا مت کِس دۅ ہَس سٍتۍ کُفر کوٚر سُہ پھوٚٹ گمرٲہی منٛز تہٕ ڈوٚ ل وَتہِ۔﴿کُفر کر نس تہِ چِھ زٕ ہ مطلب ۔اکھ یہِ زِ انسان کرِ صا ف انکار۔دوٚیُم یہِ زِ زبٲنۍ سٍتۍ مانہِ مگر دِلہٕ سٍتۍ مانہِ نہٕ یا پننہِ رٔوِیہِ سٍتۍ کرِ ثٲبت زِ یتھ چیز س سُہ ماننُک دعویٰ کران چُھ، فی الواقع چُھنہٕ تتھ مانان۔﴾"
  4,137,"۔روٗدۍ تِم لُکھ یِمو ایمان اوٚ ن ، پتہٕ کوٚرُکھ کُفر پتہٕ اوٚنُکھ بیٚیہِ ایمان، پتہٕ کوٚرُکھ بیٚیہِ کُفر پتہٕ روٗدۍ پننِس کُفرس منٛز برونٛہہ پکان اللہ تعالیٰ کرِ نہٕ ہر گز تِمن معا ف تہٕ نہ ہاوِ تِمن سِیٔز وَتھ ۔"
  4,138,"۔مُنا فقن دِیِو خو ش خبر تِہندِ خٲطرٕ چُھ دگ تُلوُن عذا ب تیار۔"
  4,139,"۔﴿  تِکیازِ ﴾ یِم چِھ اہلِ ایمانن ترٲوِتھ کٲفر ن پنٕنۍ رفیق بناوان تہٕ کیا یِم لُکھ چھا عز ت ژھانڈ نہِ تِمن نِشہِ گژھان؟ حالانکہ عزت چُھ اند ہیٚتھ اللہ تعالیٰ سٕے خٲطرٕ۔"
  4,140,"۔خُدا ین چُھ یتھ کتا بہِ منٛز گۅڈ ے یہِ حکم دِیتمُت زِ یتھ جایہِ توٚہۍ بوٗزِ و زِ اللہ تعالیٰ سٕندٮ۪ن آیا تن خلا ف چُھ کُفر یِوان بکنہٕ تہٕ یِمن چُھ مذا ق یِوان کر نہٕ تَتہِ مَہ روٗزِ و تِمن نِشہِ بِہِتھ یوٚت تام نہٕ لُکھ بیٚیہِ کُنہِ کتھہِ کُن لگن وۅ نۍ ہرگاہ توٚہۍ یہِ کران چِھو تیٚلہِ چِھو توٚہۍ تہِ تِمنٕے ہِوۍ ،پژھ کٔرِ و زِ اللہ تعالیٰ چُھ منا فقن تہٕ کٲفر ن جہمنس منٛز أکِسٕے جایہِ جمع کر ن وول۔"
  4,141,"۔ یِم مُنا فق چِھ تُہندِس معا ملس منٛز پرٛاران، ﴿مطلب واووُچِھتھ چِھ ناو تراوان﴾ اگر اللہ تعالیٰ سٕندِ طر فہٕ فتح تُہٕنز سپٕز پتہٕ یِن تہٕ ونَن زِ کیا أسۍ ٲسۍ نا تۅہیہِ سٍتۍ؟ ہرگاہ کٲفر ن ہُنٛد پوتُر گوٚ ب روٗد پَتہٕ ونَن تِمن زِ کیا اَسہِ اوس نا تۅہیہِ خلا ف لڑ نُک طا قت مگر تَمہِ پتہٕ تہِ بچٲوِ و اَسہِ توٚہۍ مُسلمانَو نِشہِ ؟بس کرِ اللہ تعالیٰ ہٕے تُہٕندِ تہٕ تِہندِ معا ملُک فٲصلہٕ قیا مت کہ دۅ ہ تہٕ ﴿اَتھ فٲصلس منٛز ﴾ چَھنہٕ خُدا ین کٲفر ن خٲطرٕ مُسلمانن پٮ۪ٹھ غٲلب ینٕچ ہر گز تہِ کانٛہہ سبیل تھٲومٕژ۔ ع"
  4,142,"۔یِم مُنا فق چِھ خدا یس سٍتۍ دوکھہٕ بٲزی کران حالانکہ چِھ در حقیقت اللہ تعالیٰ نٕے دوکھس منٛز ترٲوِ مٕتۍ ییٚلہِ نمازِ خٲطرٕ وۅ تھان چِھ تیٚلہِ چِھ کٔش کٔش محض لُکن ہاو نہٕ خٲطرٕ وۅ تھان تہٕ خُدا یس چِھ کمٕے پہن یاد کران ۔"
  4,143,"۔کُفر س تہٕ ایمانس در میان چُھکھ تذبذ ب، نَہ چِھ پوٗرٕ یو ر کن نَہ چِھ پوٗرٕ ہو ر کن، یُس خُدا ین ڈو لمُت آسہِ تس خٲطرٕ ہیٚکِو نہٕ توٚہۍ کانٛہہ وَتھ لٔبِتھ۔﴿یعنی ییٚمۍ اللہ تعالیٰ سٕندِ کلا مہٕ نِشہِ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلمن ہٕندِ  سیرت نِشہِ ہدا یت آسہِ نہٕ لوٚبمُت ،یُس پزرٕ نِشہِ  ڈٔلِتھ تہٕ بٲطل پرستی کُن رٲغب وُچِھتھ خُدا ین تہِ آسہِ توٗرۍ کُن پھِیرُمُت یو ر کُن سُہ پانہٕ پھیرُن یژھان اوس تہٕ ییٚمۍ سٕندِ ضلا لت ژھانڈ نہٕ کہ وجہِ کِنۍ خُدا ین آسن تس پٮ۪ٹھ ہدا یتٕکۍ دروازٕہ بند کٔرِمٕتۍ تہٕ صرف آسنس گُمرٲہی ہٕندی یٲتۍ دروازٕ ہ یلہٕ ترٲوِمٕتۍ، یِتھِس شخصس سِیٔز وَتھ ہاوٕ نۍ چُھنہٕ در اصل کٲنٛسہِ انسانس تام۔﴾"
  4,144,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت مو من ترٲوِتھ مَہ بنٲوِ یوٗکھ کٲفر پنٕنۍ رفیق، کیا توٚہۍ چِھوٕ ہ یژھان زِ خُدا یس دِیِو پا نس خلا ف ٹا کارٕ حُجت ؟"
  4,145,"۔پژھ کٔرِ و زِ منا فق گژھن جہنم کِس سارِوٕے کھۅتہٕ بٔنِمِس طبقس منٛز تہٕ توٚہۍ وُچھوُن نہٕ کانٛہہ تِہُند مددگار ۔"
  4,146,"۔البتہ یِم تِمو منٛزٕ تو بہٕ کر ن ، تہٕ پننِس طر زِ عملس کر ن اصلا ح بیٚیہِ رَٹن اللہ تعالیٰ سُند دا من تہٕ پنُن دین کر ن اللہ تعالیٰ سٕندِ خٲطرٕ خٲلص یِتھۍ لُکھ چِھ مو منن سٍتۍ تہٕ اللہ تعالیٰ کرِ ضرور مو منن اجرِ عظیم عطا۔"
  4,147,"۔ٲخرکیا ضرورت چھےٚ خُدا یس زِ خوا  مخواہ دِیَو تۅہیہِ سزا ہرگاہ توٚہۍ شکر گُزار بندٕ ہ بٔنِتھ روٗزِ وتہٕ ایمان چہِ رٔوِشہِ پٮ۪ٹھ پٔکِو۔اللہ تعالیٰ چُھ بوٚڈ قدردان تہٕ سارِنٕے ہٕندِ حا لہٕ نِشہِ چُھ وٲقف۔﴿شُکر ییٚلہِ بندٕ ہ سٕندِ طر فہٕ آسہِ ، تیٚلہِ چُھ احسا ن مند ی ہٕندِس معنیَس منٛز آسان تہٕ ییٚلہِ اللہ تعالیٰ سٕندِ طر فہٕ آسہِ تیٚلہِ چُھ قدر دٲنی ہٕندِس معنیس منٛز آسان ﴾"
  4,148,"۔اللہ تعالیٰ چُھنہٕ اَتھ پسند کران زِ انسان مٕژ راوِ بد گو یی پٮ۪ٹھ زبان اِلّایہِ زِ کٲنٛسہِ پٮ۪ٹھ آسہِ ظُلم کر نہٕ آمُت۔ ﴿یعنی مظلو مَس چُھ حق واتان ظٲلِمس خلا ف کرِ آواز بلند ﴾ تہٕ اللہ تعالیٰ چُھ سورُے کینٛہہ بوزن وول تہٕ زانن وول ۔ ﴿مظلو م آسنہٕ کِس صورتس منٛز ہرگاہ تۅہیہِ بد گو یی ہُند حق چُھ۔﴾"
  4,149,"۔البتہ اگر توٚہۍ نَنہِ وا نہٕ تہٕ پوشیدٕ ہ پٲٹھۍ رٕژرٕ ے کران روٗزِ و یا کٔرِ و کم از کم بُرٲیی نِشہِ در گُز ر تیٚلہِ چُھ اللہ تعالیٰ ﴿سُند صفت تہِ یۅہے زِ سُہ چُھ﴾ سٮ۪ٹھاہ معاف کر ن وول،﴿حالانکہ سزا دِنس پٮ۪ٹھ چُھ﴾ پوٗرٕ قدرت تھاوان۔"
  4,150,"۔یِم لُکھ خُدا یس تہٕ تٔمۍ سٕندٮ۪ن رسولن سٍتۍ کُفر چِھ کران بیٚیہِ چِھ یژھان خُدا یس تہٕ تٔمۍ سٕندٮ۪ن رسولن در میان فر ق کرٕ نۍ تہٕ وَنان چِھ زِ کانٛہہ مانو ن أسۍ تہٕ کانٛہہ مانو ن نہٕ بیٚیہِ چِھ یژھان کُفر س تہٕ ایمانس منز با گ اکھ وَتھ کڑٕ نۍ۔"
  4,151,"۔تِم سٲر ی چِھ پۅختہٕ کٲفر تہٕ یِتھیٚن کٲفر ن خٲطرٕ چُھ اَسہِ سُہ سزا دستیا ب تھوومُت یُس تِمن ذلیل و خوار کر ن وول آسہِ۔"
  4,152,"۔اَتھ بر عکس یِم لُکھ خُدا یس تہٕ تٔمۍ سٕندٮ۪ن رسولن مانن تہٕ تِمن در میان کر ن نہٕ فر ق تِمن کرو أسۍ ضرور تِہِندۍ اجر عطا ، تہٕ اللہ تعالیٰ چُھ سٮ۪ٹھاہ درگُز ر کر ن وول تہٕ رحم کر ن وول ۔ ع"
  4,153,"۔اے نبی صلی اللہ علیہ وسلم، یِم اہلِ کتاب اگر اَز تۅہیہِ مُطا لبہٕ چِھ کران زِ توٚہۍ کر نٲوِ و آسما نہٕ پٮ۪ٹھہٕ تِمن پٮ۪ٹھ کانٛہہ تحر یر نٲزِل، اَمہِ کھۅ تہٕ کھٔسِتھ مجر مانہٕ مُطا لبہٕ چِھ یِمو گۅڈٕ ہ مو سیٰ ﴿علیہ السلامس﴾ کٔرِ مٕتۍ تَس اوس یِمو ووٚ نمُت زِ اَسہِ ہاوُن نَنہِ وانہٕ خُدا ے تہٕ اَمی سر کشی ہٕندِ وَجہ کِنۍ ٲس اچا نک یِمن پٮ۪ٹھ ترٛٹھ پیمٕژ پتہٕ بنو و یِمو ووٚژھ پنُن معبود حالانکہ یِمو آسہٕ ٹا کارٕ نشٲنیہِ وُچِھمژٕ  اَتھ پٮ۪ٹھ تہِ کوٚر اَسہِ یِمن در گُز ر ، اَسہِ کوٚر موسیٰ ﴿علیہ السلامس﴾ ٹا کارٕ ہ فر مان عطا ۔"
  4,154,"۔تہٕ یِمن لُکن پٮ۪ٹھ طوٗر﴿پہا ڑ﴾ تھوٚد تُلِتھ ہیوٚت اَسہِ یِمن ﴿تمہِ فر مان کہ اطاعتُک ﴾عہد، اَسہِ دِیُت یِمن حُکم زِ دروازس  أژۍ زیٚو تٔمۍ نٔمۍ، ﴿اَمِچ ذکر چھےٚ سورۂ بقرہ ،آیت نمبر 59۔58 ، منٛز سپٕز مٕژ﴾ اَسہِ ووٚ ن یِمن زِ سَبتُک قا نو ن مَہ پُھٹرٲوِو  تہٕ اَتھ پٮ۪ٹھ ہیوٚت یِمن پختہٕ عہد۔"
  4,155,"۔ٲخر کار تِہندِ عہد شکنی ہٕندِ وجہ کِنۍ تہٕ امہِ وجہ کِنۍ زِ یِمو زٲنۍ اللہ تعالیٰ سٕندۍ آیات اَپٕزۍ تہٕ واریاہ پیغمبر کٔرِ کھ نا حق قتل تہٕ اتھ حد س تام ووٚ نُکھ زِ سٲنۍ دِل چِھ غِلا فن منٛز محفوظ۔﴿یعنی توٚہۍ کٔرۍ تَو کینٛہہ تہِ سا نیٚن دِلن پٮ۪ٹھ پیٚیہِ نہٕ اَمِیُک کانٛہہ اثر ﴾ در حقیقت چُھ خُدا ین یِہٕنزِبٲطل پرستی ہٕندِ وجہ کِنۍ یِہندٮ۪ن دِلن پٮ۪ٹھ ٹُھپہِ لگو و مُت تہٕ اَمی وجہ کِنۍ چِھ یِم سٮ۪ٹھاہ کم ایمان اَنان ۔"
  4,156,"۔اَمہِ پتہٕ درٛا ے یِم پننِس کُفرس منٛز تیوٗتاہ حدٕ زِ مر یم ﴿علیھا السلامس﴾ پٮ۪ٹھ لگووُکھ سخت بہتا ن۔"
  4,157,"۔تہٕ پانہٕ ووٚ نُکھ زِ اَسہِ چُھ مسیح عیسیٰ ابن مر یم علیہ السلام، اللہ تعالیٰ سُند رسول قتل کوٚر مُت ﴿یہِ مُجرِ مانہٕ جُر ات اوس تیوٗتاہ ہُر یو مُت زِ رسولس ٲسۍ رسول زانان تہٕ پتہٕ کوٚرُکھ تٔمۍ سٕندِ قتلُک اقدام تہٕ فخرٕ سان ووٚ نُکھ زِ اَسہِ کوٚر اللہ تعالیٰ سُند رسول قتل۔یتھ مو قعس پٮ۪ٹھ اگر سورۂ مر یم رکو ع ۔ 2 ، تفسیر سان پر نہٕ یِیہِ  تیٚلہِ لگہِ پے زِ بنی اسرا یل ٲسۍ در حقیقت حضرت عیسیٰ علیہ السلامس رسول زانان تہٕ امہِ با و جو د کھٲلۍ تِم علیہ السلام تِمو تِہندۍ کِنۍ صلیبہِ پٮ۪ٹھ۔﴾ حالانکہ نَہ کوٚر سُہ تِمو در حقیقت  قتل تہٕ نہ کھو لُکھ صلیبہِ پٮ۪ٹھ بلکہ آو معا ملہٕ تِہندِ خٲطرِٕ شکہٕ لد بناو نہٕ۔﴿یہِ آیت چھےٚ وا ضح کرا ن زِ حضرت مسیح علیہ السلام ٲسۍ صلیبہِ پٮ۪ٹھ کھا لنہٕ برونٛٹُھے تُلنہٕ آمٕتۍ ، عیسا ین تہٕ یہوٗدۍ کھا لَہن تِمن علیہ السلامن صلیبہِ پٮ۪ٹھ ،خُدا ین ٲسۍ تِم کمہِ تام ساعتہٕ تُلِمٕتۍ تہٕ پتہٕ یُس شخص یہوٗدیو صلبیہِ کھو ل ، سُہ اوس بیاکھ کُستام یُس خبر کتھ وجہَس پٮ۪ٹھ تِمو لُکو عیسیٰ ابن مر یم علیہ السلام سمُجھ۔﴾ تہٕ یِمو لُکو اَتھ متعلق اختلا ف کوٚر مُت چُھ تِم تہِ چِھ در اصل شکس منٛز مبتلا ۔ تِمن نِشہِ چُھنہٕ اتھ معا ملس منٛز کٕہٕنۍ علم، محض  چِھ گُما نٕچ پیر وی کران،تِمو کوٚر نہٕ مسیح علیہ السلام پٔزۍ پٲٹھۍ قتل ۔"
  4,158,"۔بلکہ تُل سُہ خُدا ین پا نس کُن ،اللہ تعالیٰ چُھ زبردست طا قت تھاون وول تہٕ حکمت وول تہٕ اہلِ کتا بو منٛزٕ آسہِ نہٕ سُہ کانٛہہ یُس نہٕ تٔمۍ سٕندِ مو ت برونٛہہ تس پٮ۪ٹھ ایمان اَنہِ۔﴿یتھ کتھ چِھ زٕ ہ معنے بیان کر نہٕ آمٕتۍ تہٕ لفظن منٛز چُھ دۅ شوٕنۍ ہُند ہیوُے احتما ل۔ اکھ معنی چُھس یُس تر جمس منٛز چُھ وَرتاو نہٕ آمُت ، دوٚ یُم چُھس یہِ زِ اہلِ کتا بو منٛزٕ چُھنہٕ کانٛہہ تِیُتھ یُس پننہِ مو ت برونٛہہ تس پٮ۪ٹھ ایمان اَنہِ نہٕ ﴾"
  4,159,"۔تہٕ قیا مت کہ دۅ ہ دِیہِ سُہ تِمن پٮ۪ٹھ گوٲہی ۔"
  4,160,"۔غرض یِمن یہو د ٮ۪ن ہٕندِس أتھۍ ظٲلمانہٕ رٔوِ یہِ کِس بُنیا دس پٮ۪ٹھ کٔرۍ اَسہِ واریاہ تِم پاک چیز تِہٕندِ خٲطرٕ حرا م، یِم گۅڈٕ ہ تِہندِ خٲطرٕ حلال ٲسۍ تہٕ اَتھ بُنیادس پٮ۪ٹھ زِ یِم چِھ حدٕ کھۅتہٕ زیادہ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ رُکا وان۔"
  4,161,"۔بیٚیہِ چِھ سوٗد رَٹان ییٚمہِ نِشہِ یِمن ٹھا کھ اوس کر نہٕ آمُت تہٕ لُکن ہٕندۍ مال چِھ نا جٲیز طریقہٕ کھیوان۔﴿غا لباً چُھ یہِ تٔتھۍ مضمو نس کُن اشارٕہ یُس برونٛٹھ کُن۔آیت نمبر 146،سورۂ انعا مس منٛز یِنہٕ وول چُھ ۔یعنی یہِ زِ بنی اسرا یلس پٮ۪ٹھ آے تِم سٲری جانور حرا م کر نہٕ یِمن نَم چِھ آسا ن ، تہٕ یِمن پٮ۪ٹھ آو گٲو ہُند تہٕ ژھاو جہِ ہُند چر ب تہِ حرا م کر نہٕ ۔ امہِ علا وھ چُھ ممکن زِ اشارٕہ آسہِ دوٚ یِمیٚن پابند ین تہٕ سختین کُن تہِ یِمہٕ یہوٗدۍ فِقس منٛز درٛینٹھۍ چھےٚ گژھان ۔ کٲنٛسہِ دٔرۍ سٕندِ خٲطرٕ زند گی ہُنٛد دٲیرٕہ تنگ کر نہٕ یُن چُھ درحقیقت تٔمۍ سٕندِ س حقس منٛز سزا تہٕ بیٚیہِ نہٕ کینٛہہ ۔ ﴾ تہٕ یِم لُکھ یِمو منٛزٕ کٲفر چِھ ، تِہندِ خٲطرٕ چُھ اَسہِ د گ تُلہٕ وُن عذا ب تیار تھو ومُت۔"
  4,162,"۔مگر یِمن منٛز یِم لُکھ پختہٕ علم تھاون وٲلۍ چِھ تہٕ بیٚیہِ چِھ ایمان دار تِم سٲری چِھ تٔتھۍ تعلیمہِ پٮ۪ٹھ ایمان انان یۅسہٕ اے نبی صلی اللہ علیہ وسلم ، تۅہیہِ کُن نٲزِل چھےٚ کر نہٕ آمٕژ تہٕ یۅسہٕ تۅہیہِ برونٛٹھ نٲزِل ٲس کر نہٕ آمٕژ ،امہِ قسمہٕ کیٚن ایمانن اَنن والیٚن تہٕ نماز زکوٰتٕچ پابند ی کر ن والیٚن بیٚیہِ خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ پوٚز عقیدٕ ہ تھاو ن والیٚن لُکن کرَو أسۍ ضرور اجرِ عظیم عطا۔ع"
  4,163,"۔ اے نبی صلی اللہ علیہ وسلم، اسہِ چھےٚ تۅہیہِ کُن تِتھے پٲٹھۍ وحی سوٗز مٕژ، یِتھہٕ پٲٹھۍ نو ح علیہ السلام تہٕ تس پتہٕ یِم پیغمبر آے تِمن پٮ۪ٹھ سوٗز مٕژ ٲس، اَسہِ سوٗز و حی ابرا ہیم علیہ السلام، اسما عیل علیہ السلام،اسحا ق علیہ السلام، یعقو ب علیہ السلام،تہٕ یعقو ب علیہ السلام سٕندٮ۪ن اولاد ن  بیٚیہِ عیسیٰ  علیہ السلام، ایو ب علیہ السلام، یونُس علیہ السلام، یارون علیہ اسلام، تہٕ سلیمان علیہ السلامس کُن، اَسہِ دِژ داوٗد ﴿علیہ السلامس ﴾ زبور۔"
  4,164,"۔اَسہِ کٔر تِمن رسولن پٮ۪ٹھ تہِ وحی نٲزِل یِہٕنز ذِکر اَسہِ ییٚمہِ برونٛہہ تۅہیہِ نِشہِ کٔر مٕژ چھےٚ تہٕ تِمن رسولن پٮ۪ٹھ تہِ یِہنز ذِکر اَسہِ تۅہیہِ نِشہِ کٔر نہٕ ،اَسہِ کٔر مو سیٰ علیہ السلامس سٍتۍ تِتھہٕ پٲٹھۍ کتھ با تھ یِتھہٕ پٲٹھۍ کران چِھ۔"
  4,165,"۔یِم سٲر ی رسول ٲسۍ خو ش خبر دِنہٕ وٲلۍ تہٕ کھۅژناو ن وٲلۍ بنٲوِتھ سو زنہٕ آمٕتۍ تا کہ تِم معبو ث کر نہٕ پتہٕ روزِ نہٕ لُکن نِشہِ خُدا یس مقا بلہٕ کانٛہہ حُجت ۔﴿یعنی یِمن تمام پیغمبر ن ہٕندِ سوزنُک اوس اَکو ے غر ض تہٕ سُہ اوس یہِ زِ اللہ تعالیٰ چُھ انسٲنۍ زُرِ یا تس پٮ۪ٹھ اتمام حُجت کرٕ نۍ یژھان تا کہ ٲخر ی عدالت کِس مو قعس پٮ۪ٹھ گژھِہ نہٕ کانٛہہ گمراہ مُجر م، تس برونٛٹھہٕ کنہِ ہیٚکُن یہِ عذر پیش کٔرِ تھ زِ أسۍ ٲسۍ نا وٲقف تہٕ تۅہیہِ او سُو نہٕ حقیقت حال نِشہِ با خبر کر نہٕ مۅ کھہٕ سانہِ خٲطرٕ انتظا م کوٚر مُت ۔ ﴾ تہٕ اللہ تعالیٰ چُھ بہر حال غٲلب روزن وول بیٚیہِ حکمت وول تہٕ دانا۔"
  4,166,"۔﴿لُکھ چِھنہٕ مانان متہٕ مٲنۍ تن ﴾ مگر اللہ تعالیٰ چُھ گوٲہی دِوان زِ اے نبی صلی اللہ علیہ وسلم،یِکینژھاہ تٔمۍ تۅہیہِ پٮ۪ٹھ نٲزِل چُھ کوٚرمُت سُہ چُھن پننہِ علمہٕ سٍتۍ نٲزِل کوٚر مُت، تہٕ اَتھ پٮ۪ٹھ چِھ فرشتہٕ تہِ گواہ،اگر چہِ اللہ تعالیٰ سُند گواہ آسُن با لکل کٲفی چُھ۔"
  4,167,"۔یِم لُکھ  اَتھ ماننہٕ نِشہِ خۅد انکار کران چِھ تہٕ با قین چِھ اللہ تعالیٕ سٕنزِ وَتہِ نِشہِ رُکا وان تِم چِھ پٔزۍ پٲٹھۍ گمرٲہی منٛز حقہٕ نِشہِ سٮ۪ٹھاہ دوٗر درٛا ومٕتۍ۔"
  4,168,"۔یتھہٕ پٲٹھۍ تِمو لُکو کفُر ک تہٕ بغا وتُک طریقہ اختیار کوٚر ،تہٕ،ظُلمس تہٕ سِتمس پٮ۪ٹھ   ؤتھۍ،اللہ تعالیٰ کرِ نہٕ ہر گز تِمن معا ف تہٕ تِمن ہاوِنہٕ سِیٔز وَتھ۔"
  4,169,"۔مگر ہا ویٚکھ جہنمس کُن وَتھ ،یتھ منٛز تِم ہمیشہ روزن،خُدا یس خٲطرٕ چَھنہٕ یہِ کانٛہہ مُشکل کٲم۔"
  4,170,"۔لوٗکو ،یہِ رسول چُھ تۅہیہِ نِشہِ اللہ تعالیٰ سٕندِ طر فہٕ حق ہیٚتھ آمُت،ایمان أنِو ، تُہٕندی خٲطرٕ چُھ بہتر، تہٕ اگر انکار چِھو کران تیٚلہِ زٲنِو زِ یِکینژھاہ آسما نن تہٕ زمینس منٛز چُھ، سورُے چُھ اللہ تعالیٰ سُندُے، تہٕ اللہ تعالیٰ چُھ زانن وول تہِ تہٕ حکمت وول تہِ۔ ﴿یعنی نَہ چُھ تُہُند اللہ تعالیٰ بے خبر زِ تٔمۍ سٕندِس سلطنتس منٛز روٗزِ تھ کٔرِ و توٚہۍ یَچھ کامہِ تہٕ تس آسہِ نہٕ خبرٕ ے تہٕ نَہ چُھ سُہ نادان زِ تس آسہِ نہٕ تگان پننیٚن فر مانن ہٕنز خلا ف ور زی کر ن والیٚن سٍتۍ أنزراوُن۔﴾"
  4,171,"۔اے اہلِ کتا ب ،پننِس دینس منٛز مَہ کٔرِو غَلُوّ تہٕ خُدا یس کُن مَہ کٔرِ و حق ورٲے بیٚیہِ کانٛہہ کتھ منسو ب ۔﴿یتھ جایہِ چُھ اہلِ کتا ب مُراد عیسٲے تہٕ غَلُو وُک معنی چُھ کُنہِ چیز کِس تٲیید س تہٕ حما یتس منٛز حدٕ نیرُن۔یہوٗدٮ۪ن ہُند جُر م اوس یہِ زِ تِم درٛا ے مسیح علیہ السلام سٕندِس انکارس تہٕ مخالفتس منٛز حدٕ، تہٕ عیساین ہُند جُر م چُھ یہِ زِ تِم درٛا ے مسیح علیہ السلام سٕندِس عقیدتس تہٕ محبتس منٛز حدٕ، تہٕ سُہ دِیتُک خدا ے سُند نیٚچِو بلکہ خۅد خدا ے قرار۔﴾مسیح  عیسیٰ ابن مر یم علیہ السلام اوس نہٕ اَمہِ ورٲے کِہنۍ زِ سُہ اوس اللہ تعالیٰ سُند اکھ رسول۔تہٕ سُہ اوس اکھ فر مان یُس خُدا ین مر یم ﴿علیھا السلامس﴾ کُن سوٗز۔﴿دراصل چُھ لفظکلمہ وَرتا و نہٕ آمُت۔مر یم علیھا السلامس کُن کلمہٕ سو زنُک مطلب چُھ یہِ زِ خدا ین کوٚر حضرت مر یم علیھا السلامن ہٕنزِ بچہِ دانہِ حُکم زِ کٲنٛسہِ مردٕ سٕندِ نطفہٕ نِشہِ سٲراب سپد نہٕ ورٲے کٔرِن حمل ٹھہراوُن قبول۔عیسا یو سمُجھ گۅڈٕ ہ لفظ کلمہ  کلام  یا  نُطق۔کتھہِ  ہُند ہم معنی ، پتہٕ نیوٗکھ امہِ کلام و نطق نِشہِ مُراد  خداےسٕندِ ذٲتی کلا مُک صفت۔ پتہٕ کوٚر کُ یہِ قیا س قٲیِم زِ خُدا ے سٕندۍ أمۍ ذٲتی صِفتن کٔر مر یم علیہ السلام سٕندِس شکمس منٛز دٲخل سپدِ تھ سۅ جسمٲنی صورت اختیار، یۅ سہٕ مسیح علیہ السلام سٕنزِ شکلہِ منز ظٲہر سپٕز، یِتھہٕ پٲٹھۍ گوٚو عیسا ین منٛز مسیح علیہ السلام سٕنزِ فٲسد الو ہیتُک عقید ہ پٲدٕ۔ تہٕ أمۍ غلط تصّوُر ن دِتۍ موٗل زِ خُدا ین چُھ خۅ د پنُن پان یا پننیو اَزلی صفا تو منٛزٕ نطق و کلامُک صفت مسیح علیہ السلامس سٕنزِ شکلہِ منٛزظٲہر کوٚر مُت ۔ ﴾ تہٕ اکھ رو ح اوس خُدا ے سٕندِ طر فہٕ ﴿ییٚمۍ مر یم علیہا السلامن ہٕنزِ بچہِ دانہِ منٛز شُر ۍ سٕنز شکل اختیار کٔر ﴾۔ ﴿یتھ جایہِ چُھ خۅد مسیح علیہ السلامس رُوح مِنہُ ﴿خدا ے سٕندِ طر فہٕ اکھ رو ح ﴾ وَننہٕ آمُت تہٕ سورۂ بقر ہ آیت، 87، منٛز چُھ یہِ مضمو ن یِتھہٕ پٲٹھۍ بیان سپُد مُت زِ  اَسہِ کوٚر پاک رُو ح سٍتۍ مسیح علیہ السلامس مدد۔دۅ شوٕ نۍ عبا رتن ہُند مطلب چُھ یہِ زِ خدا ین اوس مسیح علیہ السلامس سُہ پٲکیز ہ رو ح عطا کوٚر مُت یُس بد ی نِشہِ بے خبر اوس، یُس سراسر حقا نیت تہٕ راست باز اوس ،تہٕ از سر تا پا اوس فضیلت اخلا ق ۔ عیسا یو کوٚر اَتھ منٛز یہِ غلو، رُو ح مِنَ اللہِ  ، دِیتُکھ خۅد خدا ے سُند رو ح قرار ، تہٕ رُو حُ القُد سُک مطلب کوٚڈ کھ یہِ زِ سُہ اوس خدا ے سُند پنُن روحِ مُقدس یُس مسیح السلامس اندررَلا و نہٕ اوس آمُت۔یِتھہٕ پٲٹھۍ آو خدا یس تہٕ مسیح علیہ السلامس سٍتۍ اکھ ترییُم خدا روحُ القُدس بناو نہٕ﴾ لہٰذا ، أنِو توٚہۍ خدا یس تہٕ تٔمۍ سٕند ٮ۪ن رسولن پٮ۪ٹھ ایمان تہٕ مَہ ؤنِو زِ  ترےٚ  چِھ۔﴿یعنی ترٮ۪ن خُدا ین ہُند عقیدٕہ ترٲوِو خوا ہ سُہ ٲسِتن کُنہِ تہِ شکلہِ منٛز تۅہیہِ منٛز مو جو د ۔ حقیقت چھےٚ یہِ زِ عیسٲے چِھ بیک وقت تو حید تہِ مانان تہٕ تثلیت تہِ ۔ مسیح علیہ السلامن ہٕندۍ ٹا کارٕ قو ل یِم انجیلن منٛز میلان چِھ تِہندِس بنیا دس پٮٹھ ہیٚکہِ نہٕ کانٛہہ عیسٲے اتھ انکار کٔرِ تھ زِ خُدا ے چُھ بس اَکو ے خُدا ے، تہٕ تس ورٲے چُھنہٕ بیٚیہِ کانٛہہ خُدا ے۔ تِہندِ خٲطرٕ  چھُنہٕ یہِ تسلیم کر نہٕ ورٲے چار ے کانٛہہ زِ تو حید چُھ اصلی دین مگر امہِ با و جو د چِھ تِم مسیح علیہ السلامن ہٕندِس ذا تس اندر غَلُو کہ بٲعثٕ تثلیثٕکۍ قٲیل تہِ ، تہٕ از تام ہیٚکۍ نہٕ یہِ فٲصلہٕ کٔرِ تھ زِ یِمن دۅ ن مُتضا د عقید ن کِتھہٕ پٲٹھۍپکناون  یِکہٕ وٹہٕ۔ ﴾ باز یِیِو، یہِ چُھ تُہٕندۍ خٲطرٕ بہتر، خُدا ے چُھ بس اَکو ے خُدا ے، سُہ چُھ پاک امہِ نِشہِ زِ کانٛہہ آسہِ تس نیٚچُو۔﴿یہِ چھےٚ عیساین ہٕندِ ژوٗرِ مہِ غَلُوٕ چ تردید ۔ عیسٲے  روایات اگر صحیح تہِ آسن تو تہِ چُھ تِمو منٛزٕ ﴿خصو صاً گۅڈ نِچو تر ییو انجیلَو نِشہِ ﴾ زیادہ کھۅتہٕ زیادٕہ بس یُتُے ثٲبت سپدان زِ مسیح علیہ السلامَو اوس خُدا یس تہٕ بند ن ہٕندِس تعلُقس مٲلِس تہٕ اولاد سٕندِس تعلُقس سٍتۍ ہِشر دِیتمُت  تہٕ مو ل  لفظ ٲسۍ  تِم خُدا یس خٲطرٕ محض مجا زی طور  تہٕ استعارہ رٔنگۍ ورتاوان۔یہِ چَھنہٕ صرف مسیح علیہ السلامن ہٕنزٕ ے یٲژ خصو صیت بلکہ ٲسۍ پرانہِ زمانہٕ پٮ۪ٹھہٕ بنی اسرا یل خُدا یس خٲطرٕ مول لفظ وَرتاوان پکا ن ، تہٕ امِچہِ واریاہ مِثا لہٕ چھےٚ با یبل کِس پرٲنِس عہد نا مس منٛز موجو د ۔ مسیح علیہ السلامن اوس یہِ لفظ پننہِ قو م کہ محا ورٕہ مطا بقٕے وَر تو و مُت، تہٕ تِم ٲسۍ نہٕ صرف خُدا یس پنُنے یوت بلکہ ٲسۍ تس تمام انسانن ہُند مو ل ونان ۔ مگر عیسا یو کوٚریتھ جایہِ بیٚیہِ غَلُو تہٕ مسیح علیہ السلام دِیتُکھ خُدا ے سُند نیچُو قرار۔﴾ زمین و آسما نن ہٕندۍ سٲر ی چیز چِھ تٔمۍ سٕنز مِلکیت،تہٕ تِہِندِ کفا لت تہٕ خبر گیر ی خٲطرٕ چُھ بس سُے سٮ۪ٹھاہ۔ ع"
  4,172,"۔مسیح ﴿علیہ السلامن﴾ سمٕجھ نہٕ زانٛہہ یہِ کتھ عٲب زِ سُہ آسہِ اللہ تعالیٰ سُند اکھ بند ہ، تہٕ نَہ چِھ مُقر ب تر ین فر شتہٕ پننہِ خٲطرٕ اَتھ عٲب زانان،اگر کانٛہہ اللہ تعالیٰ سٕنزِ بند گی پننہِ خٲطرٕ عٲب چُھ سمجھان تہٕ تکبُر چُھ کران،تیٚلہِ یِیہِ اکھ وقت ییٚلہِ اللہ تعالیٰ سارِنٕے ؤٹِتھ پا نس برونٛہہ کنہِ جمع کرِ۔"
  4,173,"۔تمہِ وقتہٕ کر ن تِم لُکھ یِمو ایمان أنِتھ نیک طر زِ عمل اختیار چُھ کوٚرمُت پنٕنۍ اجر پوٗرٕ پوٗرٕ حٲصل تہٕ اللہ تعالیٰ کرِ پننہِ فضل سٍتۍ تِمن ہُر یمانہٕ اجر عطا، تہٕ یِمو لُکو بند گی عٲب سمجھ تہٕ بیٚیہِ کوٚرکھ تکبُر،تِمن دِیہِ اللہ تعالیٰ دگ تُلوُن سزا، تہٕ خُدا یس ورٲے یِمن یِمن ہٕنزِ سر پرستی تہٕ مددگٲر ی پٮ۪ٹھ تِم بھر وسہٕ ٲسۍ تھاوان تِمو منٛزٕ لبن نہٕ کانٛہہ اکھا تَتہِ۔"
  4,174,"۔لوٗکو ،تُہندِس ربّ سٕندِ طر فہٕ چھےٚ تۅہیہِ نِشہِ روشن دلیل آمٕژ، تہٕ اَسہِ چھےٚ تۅہیہِ کُن تِژھ رو شنی سوٗز مٕژ یۅسہٕ تۅہیہِ صا ف صا ف وَتھ ہاوَن واجِنۍ چھےٚ۔"
  4,175,"۔وۅ نۍ یِم لُکھ اللہ تعالیٰ سٕنز کتھ مانَن تہٕ تٔمۍ سُند پنا ہ ژھا نڈن، تِمن رَٹہِ اللہ تعالیٰ پننِس رحمت کِس تہٕ پننِس فضل و کر م کِس دا منس تَل،بیٚیہِ ہا ویٚکھ پا نس کُن ینٕچ سِیوٚد وَتھ۔"
  4,176,"اے نبی صلی اللہ علیہ وسلم۔لوٗکھ چِھو تۅہیہِ ﴿کَلاَ لہ کِس معا ملس منٛز فُتویٰ ﴾پٕرژھان۔ ﴿کَلا لہ کِس معنیس منٛز چُھ اختلاف۔کینژھن ہٕنز راے چھےٚ زِ کلالہ چُھ سُہ شخص یُس لاو لد آسہِ تہٕ یس مو ل بُڈِ بب زند ہ آسہِ نہٕ۔تہٕ کینژھن ہٕنز را ے چھےٚ سُہ شخص یُس لاولد مرِ تس چِھ کَلا لہ ونان ۔ البتہ عا م فقہا ہو چھےٚ حضرت ابو بکر رضی اللہ عنہہ ہَن ہٕنٛز یہِ را ے تسلیم کٔر مٕژ زِ اَمِیُک اطلا ق چُھ گۅڈ نِکسٕے صورتس پٮ۪ٹھ سپدان تہٕ خۅد بذا ت چُھ قرآن نِشہِ تہِ امِیُک تٲیید سپدان تِکیازِ یتھ جایہِ چھےٚ کَلا لہ سٕنز بیٚنہِ نصف تر کٕچ وٲرث قرار دِنہٕ آمٕژ۔حالانکہ اگر کَلالہ سُند مو ل زند ہ آسہِ تیٚلہِ چُھنہٕ بیٚنہِ موٗلۍ کانٛہہ حصہ واتان۔﴾  ؤنِو ، اللہٰ چُھو تۅہیہِ کلا لس متعلق فتویٰ دِوان، اگر کانٛہہ شخص بے اولاد مَرِ ،تہٕ تس آسہِ اکھ بیٚنہِ، تیٚلہِ میلہِ تس امہِ تر کہٕ منٛزٕ نصف،﴿یتھ جایہِ چُھ تِمن با ین بیٚنیٚن ہُند ذکر سپدان یِم میتس سٍتۍ ماجہِ تہٕ مٲلِس دۅ شوٕ نۍ منٛز ، یا آسن صرف مٲلۍ سٕندۍ کِنۍ مشتر کہ۔ حضرت ابو بکر صد یق رضی اللہ عنہ چِھ اکہِ ساعتہٕ أکِس خطبس منٛز امہِ معنے یِچ وضا حت کران تہٕ صحا بو رضی اللہ عنہ منٛزٕ کوٚر نہٕ کٲنٛسہِ اتھ سٍتۍ اختلا ف ، أتھۍ بنیادس پٮ۪ٹھ چُھ سارِنٕے اَتھ مسلس پٮ۪ٹھ اتفا ق﴾ تہٕ اگر بیٚنہِ بے اولاد مرِ تیٚلہِ آسہِ بو ے تٔمۍ سُند وٲرث، ﴿یعنی بو ے آسہِ تٔمۍ سٕندِ پوٗرٕ ما لُک وٲرث اگر بیٚیہِ کانٛہہ صا حب فر یضہ آسہِ نہٕ ۔ تہٕ اگر کانٛہہ صا حب فر یضہ موجو د آسہِ ، مثلاً خاندار، تیٚلہِ میلہِ تٔمۍ سُند حصہ نکھہٕ والنہٕ پتہٕ با قی تمام تر کہٕ بٲیِس۔﴾ اگر میت سٕنزٕ وٲرث زٕ ہ بیٚنہِ آسن،تیٚلہِ آسن تِمہٕ تر کہٕ ﴿پتھ کُن تراونہٕ آمتہِ ﴾ منٛزٕ زٕ ہ تہٲیی ہٕنز حقدار ﴿یۅ ہے حُکم چُھ دۅ یو کھۅ تہٕ زیادہ بیٚنیٚن خٲطرٕ تہِ ﴾،تہٕ اگر واریاہ بٲے بیٚنہِ آسن، تیٚلہِ میلہِ مستوراتن اکھ حصہ تہٕ مردن زٕہ حصہ،اللہ تعالیٰ چُھ تُہندِ خٲطرٕ احکامن وضا حت کران ، تاکہ توٚہۍ روٗزِ و نہٕ وَتہِ ڈٔلِتھ پکان،تہٕ اللہ تعالیٰ چُھ پرٛتھ چیزُک علم تھاوان۔ ع"
