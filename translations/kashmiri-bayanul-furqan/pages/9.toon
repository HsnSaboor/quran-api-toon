quran[129]{c,v,t}:
  9,1,"۔اعلانِ برات ﴿قطعِ تعلق﴾ چُھ اللہ تعالیٰ سٕندِ طر فہٕ تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمن﴾ ہٕندِ طر فہٕ تِمن مُشر کن یِمن سٍتۍ تۅہیہِ معا ہدٕہ ٲسِو کٔرِ مٕتۍ۔﴿ یِم آیات ٲسۍ رکوع ،5، کِس آخرس تام 9 ھ منٛز تمہِ وقتہٕ نٲزِل سپدٕ یمٕتۍ ییٚلہِ نبی صلی اللہ علیہ وسلمو حضرت ابو بکر صد یق رضی اللہ عنہ  حج خٲطرٕ روانہٕ ٲسۍ کٔرِ مٕتۍ۔ تِمن رضی اللہ علیہ عنہ پتہٕ ییٚلہِ یِم آیات نٲزِل سپٕدۍ، حضور صلی اللہ علیہ وسلم چِھ حضرت علی رضی اللہ عنہ ہَس سوزان تا کہ حاجن ہٕندِ س  عام مجمس منٛز بوزناون یِم ،تہٕ پتہٕ کر ن یِمن ژۅ ن کتھَن ہُند اعلان:﴿1﴾ تِیُتھ کانٛہہ شخص اَژِ نہٕ جنتس یُس دینِ اسلام قبول کر نہٕ نِشہِ انکار کرِ ﴿2﴾ ییٚمہِ ؤرِیہِ پتہٕ گژِھہ نہٕ کانٛہہ مُشر ک حج خٲطرٕ یُن ﴿3﴾ بیتُ اللہ ہس أندۍ أندۍ ننگے طوا ف کرُن چُھ ممنو ع ﴿4﴾ یِمن لُکن سٍتۍ رسول اللہ صلی اللہ علیہ وسلمن ہُند معا ہد ہ با قی چُھ، یعنی یِم عہد پُھٹرا ونٕکۍ مر تکب چِھنہٕ گمٕتۍ، تِمن سٍتۍ ییہِ معا ہدہ کِس وقتس تام وفا کر نہٕ ۔ حضور صلی اللہ علیہ وسلمن  ہٕندِ امہِ ہدا یتہٕ مطٲبق چِھ حضرت علیرضی اللہ ، 10 ذی الحجہ یہِ اعلان کران۔روٗد وۅ نۍ معا ہد ن ہُند تعلق ۔ سور ہ انفا ل آیت 58 ہَس منٛز آو پتھ کُن فر ما و نہٕ زِ ییٚلہِ تۅہیہِ کُنہِ قو مہٕ طر فہٕ خیا نت﴿عہد شکنی تہٕ غدٲری﴾ ہُند اندیشہٕ آسہِ ،تیٚلہِ چھٔکِو علی الا علان تٔمۍ سُند مُعا ہدٕہ تس کُن تہٕ سُہ کٔرِ یوٗن خبردار زِ وۅ نۍ چُھنہٕ چو ن تہٕ سو ن کانٛہہ معا ہدٕہ با قی ۔ اَمی اخلا ق کہ ضٲبطہ مطٲ بق آو معا ہد ن ہٕنزِ منسوخی ہُند یہِ عام اعلا ن تِمن قبیلن خلا ف کر نہٕ یِم عہد و پیمان با وجود ٲسۍ ہمیشہ اسلامس خلا ف سٲزشہِ کران روزان، تہٕ ییٚلہِ تِمن مو قع اوس یِوان تمہِ ساعتہٕ ٲسۍ عہدُک پاس بالاے طا ق تھٲوِ تھ دشمنی پٮ۪ٹھ کھڑا سپدان۔امہِ اعلان پتہٕ روٗد نہٕ عر ب کیٚن مُشر کن امہِ ورٲے کانٛہہ چارہ  زِ یا گژھن تِم لڑ نس پٮ۪ٹھ تیار سپٕدنۍ تہٕ اسلامی طا قتس سٍتۍ ٹکرٲوِتھ گژھن صفحہ ہستی پٮ۪ٹھہٕ مِٹنٕۍ، یا گژھن ملک ترٲوِتھ نیرٕ نۍ نَتہٕ گژھن اسلام قبول کٔرِ تھ پنُن پان تہٕ پنُن علا قہٕ تتھ نظم و ضبطس پُشراوٕنۍ ،ییٚمۍ مٕلکُک واریاہ حصہٕ  چُھ گۅڈ ے اسلامی حکو متس تا بع بنو و مُت﴾"
  9,2,"۔لہٰذا پھِیرِ و تھوٗرِ و توٚہۍ لُکھ بیٚیہِ ژۅ ن ریٚتن مٕلکس منٛز تہٕ زٲنِتھ تھٲوِ و زِ توٚہۍ چِھو نہٕ خُدا یس عٲجز کر ن وٲلۍ کینٛہہ،بیٚیہِ یہِ زِ اللہ تعالیٰ چُھ تِمن رُسوا کر ن وول یِم حقس انکار چِھ کران۔"
  9,3,"۔ اطلاعِ عام چُھ اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمن ﴾ ہٕندِ طر فہٕ حجِ اکبر کہ دۅ ہ تمام لُکن خٲطرٕ زِ اللہ تعالیٰ چُھ مُشر کو نِشہِ  بَر ی الذّمہ تہٕ تٔمۍ سُند رسول صلی اللہ علیہ وسلم تہٕ ﴿حجِ اکبرُک لفظ چُھ حج اصغر کِس مقا بلس منٛز۔ اہلِ عر ب ٲسۍ عمر ہ ہَس لۅ کٹ حج ونان۔اتھ مقا بلہٕ یُس حج ذی الحجہ کیٚن مقرر تٲریخن منٛز سپدان چُھ، تتھ چِھ حجِ اکبر ونان ﴾ وۅ نۍ اگر توٚہۍ لُکھ تو بہٕ کٔرِو ،تیٚلہِ چُھ تُہٕندی خٲطرٕ بہتر ، تہٕ اگر بُتھ چِھو پھِران تیٚلہِ زٲنِو ٹھیک پٲٹھۍ زِ توٚہۍ چِھو نہٕ اللہ تعالیٰ عا جز کر ن وٲلۍ تہٕ اے نبی صلی اللہ علیہ وسلم، انکار کر ن وٲلۍ بوزنٲوِیوٗکھ سخت عذا بٕچ خۅ ش خبر،"
  9,4,"۔تِمَو مشر کَو ورٲے یِمن سٍتۍ تۅہیہِ معا ہد ہ کٔرِ و پتہٕ کٔر نہٕ تِمو پنُن عہد پوٗرٕ کر نس منٛز تۅہیہِ سٍتۍ کانٛہہ کمی تہٕ نہ کوٚرُکھ تۅہیہِ خلا ف کٲنٛسہِ مدد، تیٚلہِ کٔرِ و توٚہۍ تہِ یِتھیٚن لُکن سٍتۍ معا ہد ہ کِس وقتس تام وفا  تِکیازِ اللہ تعالیٰ چُھ متقی لُکنٕے پسند کران۔"
  9,5,"۔لہٰذا ییٚلہِ حرام ریٚتھ نیر ن ﴿یتھ جایہِ چُھ حرام ریٚتَو نِشہِ مُراد تِم ژور ریٚتھ یِمن ہٕنز مہلت مُشر کن ٲس دِنہٕ آمٕژ۔چو نکہ اتھ مہلت کِس وقتس منٛز اوسنہٕ مُسلمانن خٲطرٕ جٲیز زِ مُشر کن پٮ۪ٹھ کر ہن حملہٕ ، امہِ موجو ب چُھ یِمن ریتن حرام ریٚتھ وَننہٕ آمُت﴾ تیٚلہِ کٔرِیوٗکھ مُشر ک قتل ییٚتہِ لٔبِیوٗکھ تَتہِ ، تہٕ تِم رٔٹیوٗکھ تہٕ گھیر او کٔرِیوٗکھ۔تہٕ پرٛتھ زاگس پٮ۪ٹھ بِہِو تِمن خبر ہیٚنہٕ خٲطرٕ پتہٕ اگر تِم تو بہٕ کر ن بیٚیہِ کر ن نماز قٲیم تہٕ زکوٰتہ دِن تیٚلہِ ترٲویوٗکھ یلہٕ ﴿یعنی محض  گژِھہ نہٕ کفرو شر ک نِشہِ تو بہٕ کر نس پٮ۪ٹھ معا ملہٕ ختم ، بلکہ آسہِ تِمن نماز قٲیِم کرٕنۍ بیٚیہِ زکوٰتہ دِنۍ ،نَتہٕ یِیہِ نہٕ یہِ ماننہٕ زِ کُفر ترٲوِتھ چُھ تِمو اسلام قبول کوٚر مُت ﴾ اللہ تعالیٰ چُھ در گُز ر کر ن وول تہٕ رحم فر ماو ن وول۔"
  9,6,"۔تہٕ اگر مُشر کو منٛزٕ کانٛہہ شخص پنا ہ منگِتھ تۅہیہِ نِشہِ یُن ییژِھہ ﴿تاکہ اللہ تعالیٰ سُند کلام بوزِ﴾ تیٚلہِ دِیِو تس ﴿پنا ہ یوٚت تام سُہ اللہ تعالیٰ سُند کلام بوزِ ،پتہٕ واتنٲوِیوٗن سُہ تٔمۍ سٕندِس ﴿پنا ہ گا ہس ﴾تام، یہِ گژِھہ امہِ موجو ب کرُن زِ یِم لُکھ چِھنہٕ علم تھاوان ۔ ع"
  9,7,"۔یِمن مشر کن خٲطرٕ کِتھہٕ پٲٹھۍ ہیٚکہِ  ٲخر اللہ تعالیٰ ہس تہٕ تٔمۍ سٕندِس رسولس صلی اللہ علیہ وسلمس نز د یک کانٛہہ عہد﴿وعدٕہ﴾ ٲسِتھ؟ماسِواے تِمن لُکن یِمن سٍتۍ مسجدِ حرا مس نِشہِ معا ہد ہ اوسُو کوٚر مُت، ﴿یعنی بنی کنا نہ تہٕ بنی خُزاعہ بنی  ضمٚر ہ ﴾ تیٚلہِ یوٚت تام تِم تۅہیہِ سٍتۍ سِیوٚد روزن، توٚہۍ تہِ روٗزِ و تِمن سٍتۍ سیوٚد، تِکیازِ اللہ تعالیٰ چُھ متقی ین پسند کران۔"
  9,8,"۔مگر یِمو ورٲے کتھہٕ پٲٹھۍ ہیٚکہِ با قی مشر کن سٍتۍ کانٛہہ عہد ٲسِتھ ییٚلہِ زن تِہُند حال چُھ یہِ زِ اگر تۅہیہِ پٮ۪ٹھ غٲلب یِن،  تیٚلہِ نَہ کر ن تُہٕندِس معا ملس منٛز کُنہِ قرا بتُک لحا ظہٕ تہٕ کر ن کُنہِ معا ہد ہ چہِ ذمہ دٲر ی ہُند؟ تِم چِھ پننیٚو زبا نو سٍتۍ تۅہیہِ رٲضۍ کر نٕچ کوٗشش کران، مگر دل چِھکھ انکار کران، تہٕ تِمن منٛز چِھ اکثر فا سق۔"
  9,9,"۔تِمو کوٚر اللہ تعالیٰ سٕند یو آیا تَو بد لہٕ معمو لی  قٍمت قبول، پتہٕ سپٕدۍ اللہ تعالیٰ سٕنزِ وَتہِ منٛز ٹھوٚر بٔنِتھ کھڑا، سٮ۪ٹھاہ بُرٕ کر توٗت ٲسۍ تِم ،یِم تِم کران روٗدۍ۔"
  9,10,"۔کٲنٛسہِ مومن سٕندِس بارس منٛز نَہ چِھ یِم قرا بتُک لحا ظہٕ کران تہٕ نہ چِھ کُنہِ عہد چہِ ذمہ دٲر ی ہُند تہٕ زیاد تی چھےٚ ہمیشہ یِہِندی طر فہٕ سپٕز مٕژ۔"
  9,11,"۔لہٰذا ، اگر یِم تو بہ کر ن تہٕ نماز کر ن قٲیم تہٕ زکوٰتہ دِن، تیٚلہِ چِھ تُہٕندۍ دینی بٲے۔﴿یعنی نماز تہٕ زکوٰتہ ورٲے محض تو بہٕ کر نہٕ سٍتۍ بنَن نہٕ تِم تُہٕندۍ دینی بٲے ۔البتہ اگر تِم یہِ شر ط پوٗرٕ کر ن تیٚلہِ آسہِ نہٕ اَمِیُک نتیجہ صرف یۅ ہے زِ تُہٕندِ خٲطرٕ سپدِ تِمن پٮ۪ٹھ اَتھہٕ تُلُن تہٕ تِہندِس جان و ما لس اَتھہٕ لا گُن حرام، بلکہ آسہِ مزید اتھ یہِ فٲیدٕہ زِ اسلامی معا شر س منٛز گژھن تِمن برابرٕ  کۍ حقو ق حٲصل۔ تِم آسن معا شرتی، تمد نی تہٕ قا نو نی حیثیتہٕ تمام دوٚ یِمیٚن مُسلمانن ہٕندۍ پٲٹھۍ۔کانٛہہ فر ق تہٕ امتیاز ہیٚکہِ نہٕ تِہنزِ وَتہِ منٛز ٹھوٚر بٔنِتھ﴾ تہٕ زانن والیٚن خٲطرٕ چِھ أسۍ پنٕنۍ احکام واضح کران۔"
  9,12,"۔تہٕ اگر عہد کر نہٕ پتہٕ یِم ،بیٚیہِ پنٕنۍ قسم پُھٹراون تہٕ تُہٕندِس دینس پٮ۪ٹھ کر ن حملہٕ کرٕنۍ شروع تیٚلہِ کٔرِ و کُفر کیٚن عَلم بردارن سٍتۍ جنگ تِکیازِ تِہند ٮ۪ن قسمن ہُند چُھنہٕ کانٛہہ اعتبار ،شاید زِ ﴿ پتہٕ یِن تلوار ہٕندِ زورَے﴾ تِم با ز۔﴿یتھ جایہِ چُھ عہد کر نُک تہٕ قسم کھیٚنہٕ  نِشہِ مُراد مُسلمان سپد نُک عہد کرُن تہٕ اسلام چہِ وفا درٲی ہٕندۍ قسم کھیٚنۍ ۔ مطلب چُھ یہِ زِ اگر یِم مُسلمان سپد نہٕ پتہٕ بیٚیہِ کفر س کُن پھیٖرۍ، تیٚلہِ گژِھہ یِمن سٍتۍ جنگ یُن کر نہٕ ۔اَمی حُکمہٕ مطٲبق اوس حضرت ابو بکرِ صد یق رضی اللہ عنہ ہَن مُرتد ن خلا ف جنگ کوٚر مُت ۔ ﴾"
  9,13,"۔کیا توٚہۍ لٔڑِ و نا تِتھیٚن لُکن سٍتۍ یِم پنٕنۍ عہد چِھ روٗدِمٕتۍ پھُٹرا وان،تہٕ یِمو رسول صلی اللہ علیہ وسلم مٕلکہٕ منٛزٕ کڑ نُک قصد اوس کوٚر مُت تہٕ زیادتی ہُند ابتدا کر ن وٲلۍ ٲسۍ تِمے؟ کیا توٚہۍ چِھوٕ ہ یِمن کھۅژان؟ اگر توٚہۍ مو من چِھو تیٚلہِ چُھ اللہ تعالیٰ اَمِیُک زیادہ حقدار زِ تس کھوٚژِو ۔"
  9,14,"۔یِمن سٍتۍ لٔڑِو، اللہ تعالیٰ دِیا و ناوِ تُہٕند یو اَتھو سٍتۍ یِمن سزا،تہٕ یِمن کرِ ذلیل و خوار تہٕ یِہندِس مقا بلس منٛز کر یو تۅہیہِ مدد،تہٕ واریاہن مو منن ہٕندٮ۪ن دِلن پاوِ شیٚہجار۔"
  9,15,"۔تہٕ تِہند ٮ۪ن دِلن ہُند پھُہُن ﴿ژکھ﴾  مِٹاوِ بیٚیہِ یس ییژِھہ تس دِیہِ تو بُک تو فیق تہِ۔ ﴿مُسلمانن اوس خو ف زِ یہِ اعلان سپد ٲنۍ لگہِ عر بہٕ کِس أندۍ پٔکِس نار تہٕ اَسہِ یِیہِ أکِس بٔڑس خو ن ریز جنگس سٍتۍ سٲبقہٕ پیش ، خُدا ین دِیُت یِمن آیاتن منٛز اطمینان زِ تُہُند یہِ اندیشہٕ چُھ غلط،نتیجہ آسہِ اتھ  بر عکس ﴾ اللہ تعالیٰ چُھ سورُے زانن وول تہٕ دانا ۔"
  9,16,"۔کیا تۅہیہِ لُکو چُھوٕ ہ یہِ سمجھمُت زِ یِتھَے  یِیِو یلہٕ تراونہٕ،حالانکہ خُدا ین وُچُھے  نہٕ وُنہِ یہِ زِ تۅہیہِ منٛز کم لُکھ چِھ تِم یِمو ﴿تٔمۍ سٕنزِ وَتہِ اندر ﴾ جان فِشٲنی کٔر تہٕ بیٚیہِ بنو وُکھ نہٕ خُدایس تہٕ رسول ﴿صلی اللہ علیہ وسلمس ﴾ تہٕ مو مِنو ورٲے بیٚیہِ کانٛہہ جگر ی دوست ، یِکینژھاہ توٚہۍ کران چِھو اللہ تعالیٰ چھُ تمہِ نِشہِ با خبر ۔ع"
  9,17,"۔مُشر کن ہٕنز چَھنہٕ یہِ کٲم زِ تِم بنن اللہ تعالیٰ  سٕنز ن مسجد ن ہٕندۍ مُجٲور تہٕ خٲدم حالانکہ تِم چِھ خۅد پا نس پٮ۪ٹھ کُفرٕ چ شہا دت دِوان،تِہندۍ سٲر ی اعمال سپدۍ ضا یع تہٕ تِمن چُھ ہمیشہ جہنمس منٛز روزُن۔"
  9,18,"۔ اللہ تعالیٰ سٕنز ن مسجد ن ہٕندۍ آبا د کار ﴿ مُجاور تہٕ خا د م ﴾ ہیٚکن تِمے لُکھ ٲسِتھ یِم خُدا یس تہٕ ٲخرت کِس دۅ ہس مانن، تہٕ نماز کر ن قٲیم ، زکوٰتہ دِن،بیٚیہِ کھۅژن نہٕ خُدا یس ورٲے کٲنٛسہِ ، یِمنٕے نِشہِ  چُھ یہِ تو قع زِ یِم پکن سیٚزِ وَتہِ۔"
  9,19,"۔کیا تۅہیہِ لُکو چھوٕ ہ حا جن تر یش چاو نس  تہٕ مسجدِ حرا مٕچ مجا ور ی کر نس تس شخصہٕ سٕنزِ کامہِ برابر زٲنۍ مٕژ،ییٚمۍ ایمان اوٚن خُدا یس پٮ۪ٹھ تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ تہٕ ییٚمۍ جا ن فشٲنی کٔر اللہ تعالیٰ سٕنزِ وَتہِ منٛز ﴿ امہِ ارشادٕ سٍتۍ چُھ یہِ فٲصلہٕ کر نہٕ آمُت زِ بیت اللہ ہٕچ تو لیت ہیٚکہِ نہٕ وۅ نۍ مُشر کن نِشہِ روٗزِ تھ۔ مشر کیِن قر یش ہیٚکن نہٕ صرف أتھۍ بنیا دس پٮ۪ٹھ اَمِکۍ حقدار ٲسِتھ زِ تِم چِھ حا جن روٗدِ مٕتۍ خد مت کران ﴾ خُدا یس نزدیک چِھنہٕ یِم دۅ شو ے برابر کینٛہہ، تہِٕ اللہ تعالیٰ چُھنہٕ ظٲلمن رہنمٲیی کران۔"
  9,20,"۔یِمو ایمان اوٚ ن تہٕ یِمو تٔمۍ سٕنزِ وَتہِ منٛز گھر بار ترٲوۍ،بیٚیہِ کوٚرُکھ جان و ما ل سٍتۍ جہا د، خُدا یس نزد یک چُھ تِمنٕے لُکن ہُند در جہ بوٚڈ،تہٕ تِمَے چِھ کا میاب۔"
  9,21,"۔تِہُند ربّ چُھ تِمن پننہِ رحمتٕچ تہٕ پننہِ  خۅ شنود ی ہٕنز بیٚیہِ تِتھیٚن جنتن ہٕنز بشا رت دِوان ، ییٚتہِ تِہندِ خٲطرٕ پا یدار عٲشِکۍ سامانہٕ آسن۔"
  9,22,"۔تِم روزن یِمن منٛز ہمیشہ، پٔزۍ پٲٹھۍ چُھ خُدا یس نِشہِ خد ما تن ہُند بد لہٕ دِنہٕ خٲطرٕ واریاہ کینٛہہ۔"
  9,23,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت،پنٕنۍ مٲلۍ تہٕ پنٕنۍ بٲے تہِ مَہ بنٲوِیوکھ پنٕنۍ رفیق،اگر تِم کُفرس دِن ایمانس پٮ۪ٹھ تر جیح تۅہیہِ منٛزٕ یِم تِمن رفیق بناو ن تِمے آسن ظٲلم۔"
  9,24,"۔اے نبی صلی اللہ علیہ وسلم، ؤنِو زِ اگر تُہٕندۍ مٲلۍ ،تہٕ تُہٕندۍ فر زند ، تہٕ تُہٕندۍ بٲے ،تہٕ تُہنزٕ خاندارِ نہِ تہٕ تُہٕندۍ اَنگ ٲشنا و، تہٕ تُہٕندۍ تِم مال  یِم تۅہیہِ کمٲوِ مٕتۍ چِھو،تہٕ تُہٕندۍ تِم کارٕ بار،یِہندِ خسارُک تۅہیہِ خو ف چُھو، تہٕ تُہٕندۍ تِم گھرٕ یِم تۅ ہیہِ پسند چِھو، چِھو تۅہیہِ اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم تہٕ تٔمۍ سٕنزِ وَتہِ منٛزٕ جہا د کھۅتہٕ زیادہ ٹٲٹھۍ تیٚلہِ کٔرِو انتظار یوٚت تام اللہ تعالیٰ پنُن فٲصلہٕ تۅہیہِ برونٛہہ کُن اَنہِ تہٕ اللہ تعالیٰ چُھنہٕ فا سق لُکن رہنمٲیی کران۔ع"
  9,25,"۔ خُدا ین چُھ ییٚمہِ برونٛہہ واریاہن مو قعن پٮ۪ٹھ تۅہیہِ مدد کوٚر مُت، کینٛہہ کال برونٛہہ غزوہ حُنین کہ دۅہ ﴿تٔمۍ سٕنزِ دستگیر ی ہٕنز شان چَھو تۅہیہِ وُچھمٕژ﴾۔﴿غزوہ حُنین اوس شوا ل ،8 ھ منٛز یِم آیات نٲزِل گژھنہٕ برونٛہہ صرف باہ تُرٛواہ ریٚتھ مکس تہٕ طا یفس منٛز با گ حُنین  چہِ وادی منٛز پیش آمُت۔اَتھ غزوس منٛز اوس مسلمانن ہٕندِ طر فہٕ صرف ، 12 سا س فو ج تہٕ دوٚ یِمہِ طر فہٕ ٲسۍ کُفار یِہندِ کھۅتہٕ واریاہ کم۔ مگر امہِ با وجود چِھ ہوازن قبیلٕکۍ تیر انداز مسلمانن پتھ ژَلنہٕ مۅ کھہٕ مجبو ر کران تہٕ اِسلامُک لشکر چُھ بُرٕ پٲٹھۍ چھلہٕ چھا نگرِ گٔژِھتھ تِتر بِتر سپدان۔تمہِ وقتہٕ ٲسۍ صرف نبی صلی اللہ علیہ وسلم بیٚیہِ کم کینژھاہ جان باز صحا بہ رضی اللہ عنہم یِہندۍ قد م پننہِ جایہِ ڈٔلۍ نہٕ تہٕ تِہٕنز ی ثٲبت قد می ہُند نتیجہ اوس زِ نَوِ سرٕ ہیوٚک فو جُک تر تیب قٲیم سپدِ تھ تہٕ ٲخر کار سپٕز مُسلمانن فتح نصیب۔ نَتہٕ یِکینژھاہ فتحِ مکہ نِشہِ حا صل  اوس سپُد مُت تمہِ کھۅتہٕ ژوٚر بیٚیہِ ہے حُنینس منٛز روارُن ﴾ تمہِ دۅہ اُوسُو تۅہیہِ پننہِ تعداد کہ کثر تُک غرور۔مگر سُہ لوٚ گُو نہٕ تۅہیہِ کُنہِ بکار تہٕ زمین گٔیہِ پننہِ وُسعت با وجود تۅہیہِ پٮ۪ٹھ تنگ تہٕ توٚہۍ ژٔلِو شانہٕ پھِرِ تھ۔"
  9,26,"۔خُدا ین کٔر پتہٕ پنٕنۍ سکینت پننِس رسول ﴿صلی اللہ علیہ وسلمس ﴾ پٮ۪ٹھ تہٕ مو نن پٮ۪ٹھ نٲزِل تہٕ تِم لشکر وٲلِن، یِم تۅہیہِ اَتھہِ ٲسِو نہٕ یِوان ، بیٚیہِ دِیتُن منکر ینِ حقن سزا۔ تہٕ یۅ ہے بد لہٕ چُھ تِمن لُکن یِم حقس چِھ انکار کران۔"
  9,27,"۔ پتہٕ ﴿وُچِھو تۅہیہِ یِتہِ زِ ﴾ یِتھہٕ پٲٹھۍ سزا دِنہٕ پتہٕ یس اللہ تعالیٰ یژھان چُھ تس چُھ تو بُک تو فیق  بخشان۔﴿ارشاد چُھ اتھ کتھہِ کُن زِ غزوہ حُنینَس  منٛز یِمو کُفارَو شکست کھیوٚو تِم سٲر ی سپٕدۍ پتہٕ مُسلمان۔﴾ اللہ تعالیٰ چُھ در گُز ر کر ن  وول تہٕ رحم فر ماون وول۔"
  9,28,"۔اے لوٗکو یِمَو ایمان چُھو اوٚ نمُت،مُشر کین چِھ نا پا ک، لہٰذا گژھن نہٕ یِم ییٚمہِ ؤرِیہِ پتہٕ مسجدِ حرا مس نکھہٕ یِنۍ ﴿یعنی  آیند ہ ؤریہِ چُھنہٕ یِمن خٲطرٕ حج تہٕ یِہٕنز زیار تٕے  یٲژ بند بلکہ چُھ مسجدِ حرام کیٚن حدوٗدن منٛز یُہُند داخلہٕ تہِ بند﴾ تہٕ اگر تۅہیہِ تنگ دستی ہُند خو ف چُھ، تیٚلہِ چَھنہٕ یہِ کتھ دوٗر زِ اگر اللہ تعالیٰ ییٚژِھہ تۅہیہِ کر یو پننہِ فضل سٍتۍ غنی،اللہ تعالیٰ چُھ زانن وول تہٕ حکمت وول۔"
  9,29,"۔جنگ کٔرِ و ﴿اہلِ کتا بو منٛزٕ ﴾ تِمن لُکن خلا ف یِم خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان چِھنہٕ اَنان تہٕ یِکینژھاہ خُدا ین تہٕ تٔمۍ سٕندۍ رسول ﴿صلی اللہ علیہ وسلمن ﴾ حرام چُھ قرار دِیتمُت تتھ چِھنہٕ حرام کران،بیٚیہِ چِھنہٕ دینِ حق پنُن دین بناوان یِم اہل کتاب ﴿تِمن سٍتۍ لٔڑِو ﴾ توٚت تام زِ تِم دِن پننہِ اَتھہٕ جِز یہِ بیٚیہِ روزن لۅ کٕٹۍ بٔنِتھ۔ع۔﴿یعنی لڑا یہِ ہُند غا یت چُھنہٕ یہِ زِ تِم أنِن ایمان تہٕ دینِ حقٕکۍ بٔنن پیروکار۔بلکہ چُھ اَمِیُک غا یت یہِ زِ تِہنز حکمرانی گژِھہ ختم گژٕھنۍ ،تِم گژھن نہٕ زمینس پٮ۪ٹھ حٲکم تہٕ صا حبِ اَمر بٔنِتھ روزٕ نۍ بلکہ گژھن زمین کہ نظا مِ زند گی ہٕنزٕ لاکمہٕ ، بیٚیہِ فر ماں روٲیی تہٕ اما نتٕکۍ اختیارات دینِ حق کیٚن پیر و کار ن ہٕندٮ۪ن اتھن منٛز روزٕ نۍ تہٕ اہلِ کتاب گژھن یِمن ما تحت تٲبع تہٕ مطیع بٔنِتھ روزٕنۍ۔امہِ پتہٕ ییٚمہِ سُند دِل یِمَو منٛزٕ ییٚژِھہ، سُہ سپدِن پننہِ مر ضی مسلمان ،نَتہٕ روٗزِن جز یہِ دِوان ۔ جزِ یہِ چُھ بد ل تمہِ اما نُک تہٕ حفا ظتُک ،یُس ذمِیَن اسلامی حکو متس منٛز عطا چُھ یِوان کر نہٕ ۔ بیٚیہِ چھےٚ یہِ علا مت تمہِ حُکمٕچ زِ یِم لُکھ چِھ تا بع امر بننس پٮ۪ٹھ رٲضی ﴾"
  9,30,"۔یہوٗدۍ چِھ ونان زِ عُز یر علیہ السلام چُھ اللہ تعالیٰ سُند فر زندہ، تہٕ عیسٲے چِھ ونان زِ مسیح علیہ السلام چُھ اللہ تعالیٰ سُند فر زند،یِمہٕ چھےٚ بے  حقیقت کتھہٕ ،یِمہٕ تِم پننیو زبانو منٛزٕ چِھ کڑا ن۔تِمن لُکن کُن وُچِھتھ یِم یِمن برونٛہہ کفرس منٛز مبتلا ٲسۍ سپٕدۍ مٕتۍ۔اللہ تعالیٰ سُند مار یِمن پٮ۪ٹھ،یِم کپٲرۍ چِھ دو کھہٕ کھیٚوان۔"
  9,31,"۔تِمو چِھ پنٕنۍ عٲلم تہِٕ در ویش خُدا یس ورٲے پنٕنۍ ربّ بنٲوِمٕتۍ۔﴿حدیثِ شر یفس منٛز چُھ آمُت زِ حضرت عد ی بن حا تم رضی اللہ عنہ یِم گۅڈٕ ہ عیسٲ ے ٲسۍ، ییٚلہِ نبی صلی اللہ علیہ وسلمن نِشہِ حا ضر سپدِ تھ مُشر ف بہ اسلام سپٕدۍ،تِمو کوٚر حضور صلی اللہ علیہ وسلمس سوال زِ یتھ  آیتس منٛز یُس اَسہِ پٮ۪ٹھ پنٕنۍ عٲلم تہٕ درویش خُداے بناو نُک الزام عٲید کر نہٕ چُھ آمُت ، اَمِچ اصلیت کیا چھےٚ؟ در جواب چِھ حضور صلی اللہ علیہ وسلم فر ماوان کیا یہِ چُھنا پَزر زِ یِکینژھاہ یِم لُکھ حرام چِھ قرار دِوان سُہ چُھو توٚہۍ حرام مانان تہٕ یِکینژھاہ یِم حلال چِھ قرار دِوان سُہ چِھو حلال مانان ؟ تِمو کوٚر عر ض با لکل چِھ أسۍیی کران۔فر مووُکھ بس یۅ ہے گوٚو یِم ربّ  بناوٕ نۍ۔امہِ نِشہِ سپُد معلو م زِ اللہ تعالیٰ سٕنزِ کتا بہِ  ہٕندِ سَنَدٕ ورٲے یِم لُکھ انسٲنی زند گی خٲطرٕ  جٲیز تہٕ نا جٲیز کۍ حدوٗد چِھ مقرر کران، تِم چِھ در اصل خُدا یی ہٕندِس مقا مس پٮ۪ٹھ پننہِ غرور سٍتۍ کھٔسِتھ جاے رٹا ن تہٕ یِم یِہندِس اَتھ شر یعت سٲزی ہٕندِس حقس چِھ تسلیم کران تِم چِھ یِمن خُدا ے بناوان ﴾  تہٕ یِتھے پٲٹھۍ عیسیٰ ابن مر یم علیہ السلامن تہِ ﴿ربّ مانان ﴾ حالانکہ یِمن اوس نہٕ أکِس معبودس ورٲے بیٚیہِ کٲنٛسہِ ہٕنز عبا دت کر نُک حکم دِنہٕ آمُت، سُہ یس ورٲے کانٛہہ چُھنہٕ عبا دتُک حقدار، سُہ چُھ پاک تِمَو مشر کانہٕ کَتھَو نِشہِ ، یِمہٕ یِم لُکھ کران چِھ ۔"
  9,32,"۔یِم لُکھ چِھ یژھان اللہ تعالیٰ سُند گاش کرٕ ہن پننیو پھۅ کَو سٍتۍ ژھیٚتہٕ، مگر اللہ  تعالیٰ چُھنہٕ پنُن گا ش مکمل کر نہٕ ورٲے مانن وول کینٛہہ، خوا ہ کٲفر ن گٔژھۍ تن یہِ کوتاہ تہِ نا گوار،"
  9,33,"۔سُہ چُھ اللہ تعالیٰ ہٕے ییٚمۍ پنُن رسو ل صلی اللہ علیہ وسلم ہدا یت تہٕ دینِ حق  ہیٚتھ سوٗز مُت چُھ،تاکہ اَتھ کرِ تمام جنسِ دینَس پٮ۪ٹھ غٲلب، ﴿الدّین لفظُک تر جمہٕ چُھ اَسہِ ، جِنسِ دین  کوٚر مُت۔لفظ دین چُھ عر بی زبٲنۍ منٛز تمہِ نظا مِ زند گی یا طر یق زند گی خٲطرٕ استعمال سپدان ییٚمہِ کِس قٲیم کر ن وٲلِس سَنَد تہٕ مُطا ع تسلیم کٔرِ تھ تٔمۍ سٕنز اِتبا ع یِیہِ کر نہٕ۔ لہٰذا چُھ بعثتِ رسول ہُک غر ض یَتھ آیتس منٛز طر یقن تہٕ نظا من پٮ۪ٹھ غٲلب۔رسول سٕنز بعثت چَھنہٕ زانٛہہ اَمہِ غر ضہٕ خٲطرٕ سپٕز مٕژ زٕ یُس نظامِ زند گی ہیٚتھ سُہ آمُت چُھ، سُہ گژِھہ  کُنہِ دوٚیِمہِ نظامِ زند گی تا بع تہٕ تمہِ سٍتۍ مغلوب سپدِتھ ،تہٕ تمہِ چن دِنہٕ آمژ ن رعا یتن تہٕ گنجٲیِشن منٛز ژٔمِتھ روزُن ، بلکہ چُھ سُہ زمین و آسمان کِس بادشاہ سُند نمایند ہ بٔنِتھ یِوان ،تہٕ سُہ چُھ پننِس بادشاہ سُند نظامِ  حق غٲلب وُچُھن یژھان۔اگر کانٛہہ دوٚیُم نظامِ زند گی دُنیا ہس منٛز روزِ تہِ ، تتھ پزِ تیٚلہِ خُدٲیی نظام چن بخشنہٕ آمژن گُنجٲیشن منٛز ژٔمِتھ روزُن، یِتھہٕ پٲٹھۍ زَن جز یہِ ادا کر نہٕ کِس صوٗرتس منٛز ذمی ین ہُند نظامِ زند گی روزان چُھ، نہ کہ یہِ زِ کُفار آسن غٲلب تہٕ دینِ حقس مانن وٲلۍ روزن ذمی بٔنِتھ ﴾ خواہ مُشر کن سپد ۍ تن یہِ کوتاہ تہِ نا گوار ۔"
  9,34,"۔اے  لوٗکو یِمو ایمان چُھو اوٚ نمُت،اہلِ کتا بن ہٕندٮ۪ن دین کیٚن اکثر عٲلِمن تہٕ در ویشن ہُند حال چُھ یہِ زِ تِم چِھ لُکن ہٕندۍ مال بٲطل طر یقو کھیٚوان،تہٕ تِمن چِھ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ رُکاوان یِم سۅ ن تہٕ رۅ پھ چِھ جمع کٔرِ تھ تھاوان، تہٕ یِمن چِھنہٕ اللہ تعالیٰ سٕنزِ وَتہِ منٛز خر چ کران،  تِمن دِیِو درد ناک عذا بٕچ خۅ ش خبر ۔"
  9,35,"۔اکھ دۅ ہ واتہِ ، أتھۍ سۅ نس تہٕ رۅ پس پٮ۪ٹھ یِیہِ جہنمک نار زالنہٕ، تہٕ پتہٕ یِن اَمی سٍتۍ یِہندِۍ ڈیٛکہٕ تہٕ لَرٕ تہٕ کمر داغوَ نہٕ، یہِ چُھ سُہ خزا نہٕ یُس تۅہیہِ پننہِ خٲطرٕ جمع اوسُو کوٚر مُت ، رٔٹِو وۅ نۍ وُچِھو پننہِ جمع کر نہٕ آمتہِ دو لتُک مزٕ ہ۔"
  9,36,"۔حقیقت چھےٚ یہِ زِ ، ریٚتن ہُند تعداد چُھ اللہ تعالیٰ سٕندِ س نٔوِ شتَس منٛز یَہَے ﴿12﴾ ﴿تَتہِ پٮ۪ٹھہٕ ﴾ ییتہِ پٮ۪ٹھہٕ خُداین آسمان تہٕ زمین چھےٚ پٲدٕ کٔر مٕژ،تہٕ یِمن منٛز چِھ ژور ریٚتھ حرام، ﴿ژورَو حرام ریٚتَو نِشہِ چُھ مُراد ،ذی القعدہ، ذی الحجہ، بیٚیہِ محر م حجہِ خٲطرِٕ تہٕ رجب عمرہ خٲطرٕ ﴾ یۅ ہے چُھ ٹھیک ضٲبطہٕ،لھٰذا مَہ کٔرِ و یِمن ژۅ ن ریٚتن منٛز پا نس پٮ۪ٹھ ظُلم تہٕ مُشر کن سٍتۍ لٔڑِو سٲر ی سٔمِتھ،یِتھہٕ پٲٹھۍ تِم چِھ سٲر ی سٔمِتھ تۅہیہِ سٍتۍ کڑا ن تہٕ زٲنِتھ تھٲوِ و زِ اللہ تعالیٰ چُھ متقی یِنٕے سٍتۍ ۔ یعنی اگر مُشر ک یِمن ریٚتن تہِ لڑ نہٕ نِشہِ با ز پھیرن نہٕ، تیٚلہِ یِتھہٕ پٲٹھۍ تِم متفق سپدِ تھ تۅہیہِ سٍتۍ لڑا ن چِھ، متفق سپدِ تھ لٔڑِ و توٚہۍ تہِ تِمن سٍتۍ ،سورۂ بقر ہ آیت، 194،چھےٚ اَمِیُک تفسیر کران﴾"
  9,37,"۔نَسِی چھےٚ کفرس منٛز اکھ مز ید کا فر انہٕ حر کت ییٚمہِ سٍتۍ یِم کٲفر لُکھ چِھ گمرٲہی منٛز مبتلا کر نہٕ یِوان، کُنہِ ؤرِیہِ چِھ أکِس ریٚتس حلال کران ۔تہٕ کُنہِ ؤرِیہِ چِھ تتھ حرا م کران،تا کہ اللہ تعالیٰ سٕندٮ۪ن حرام کر نہٕ آمتیٚن ریٚتن ہُند تعداد تہِ کر ن پوٗرٕ،تہٕ اللہ تعالیٰ سُند حرام کر نہٕ آمُت کر ن حلال تہِ ۔﴿عر بس منٛز ٲس نَسِی دوٚ یہِ قٔسمٕچ۔اکھ صورت ٲس یہِ زِ جنگ و جد ل تہٕ غا رت گر ی تہٕ خو نٕکۍ انتقام ہیٚنہٕ خٲطرٕ ٲسۍ کُنہِ حرام ریٚتس حلال دِوان قرار،تہٕ امہِ بد لہٕ کُنہِ حلال ریٚتس حرام کٔرِ تھ ریٚتن ہُند تعداد پوٗرٕ کران۔دوٚ یِم صورت ٲس یہِ زِ قمر ی ؤرِ یس ٲسۍ شمسی ؤری مطٲبق بناو نہٕ مۅ کھہٕ اَتھ کبیسہ ہُک اکھ ریٚتھ بڑاوان تاکہ حج گژِھہ أکۍ سٕے مو سمس منٛزیِوان روزُن ،تہٕ  تِم گژھن تِمو تکلیفو نِشہِ بچنۍ ،یِم قمر ی حسا بہٕ مطٲبق  مختلف مو سمن منٛز حجُک گردش کران روز نہٕ سٍتۍ پیش چِھ یِوان۔یِتھہٕ پٲٹھۍ اوس حج ، 33 ہَن ؤرِین تام پننِس اصلی وقتس خلا ف دوٚ یمیٚن تٲریخن منٛز سپدان روزان تہٕ صرف اوس ژۅ یہِ ترٛہِمہِ ﴿34﴾ ؤرِ یہِ اکہِ لٹہِ پننِس اصلی تٲر یخس یعنی ذی الحجہ کِس نٔوِ مِس تہٕ دٔہِمِس تٲریخس پٮ۪ٹھ ادا سپدان۔نبی صلی اللہ علیہ وسلمو ییٚمہِ ؤرِ یہِ حجتہ الوادع کوٚر مُت چُھ ،تمہِ ؤرِ یہِ اوس پننیٚن اصلی تار یخن پٮ۪ٹھ حج آمُت تہٕ تمی وقتہٕ پٮ۪ٹھہٕ آو نَسِی ہُند طر یقہ ممنو ع کر نہٕ ﴾ تِہندۍ بُرٕ اعمال چِھ تِہٕندِ خٲطرٕ خۅ ش کرٕ وُنۍ بنا و نہٕ آمٕتۍ تہٕ اللہ تعالیٰ چُھنہٕ منکر ینِ حقن ہدا یت دِوان ۔ع"
  9,38,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت۔﴿ یِم آیات چِھ رکوع ،9 کِس ٲخرس تام غزوۂ تبو ک چہِ تیٲری ہٕندِ وقتہٕ نٲزِل گٔمٕتۍ﴾ تۅہیہِ کیا سَپدُو ،زِ ییٚلہِ تۅہیہِ اللہ تعالیٰ سٕنزِ وَتہِ منٛزنیر نہٕ خٲطرٕ وَننہٕ آو،تہٕ توٚہۍ گٔو زمینس سٍتۍ لٲرِ تھ؟ کیا ٲخرت کِس مقا بلس منٛز کٔروٕہ تۅہیہِ دُنیا ہٕچ زند گی پسند؟ اگر یہِ کتھ چھےٚ تیٚلہِ گژِھہ تۅہیہِ پے آسٕنۍ ، زِ دُنیٲوی زند گی ہُند یہِ سورُے ساز و سامان نیرِ ٲخرتس منٛز واریاہ کم،"
  9,39,"۔اگر توٚہۍ ؤتھِو نہٕ ،تیٚلہِ دِیَو اللہ تعالیٰ تۅہیہِ دگ تُلوُن عذا ب،تہٕ تُہنزِ جایہِ تُلہِ بیٚیہِ کٲنٛسہِ دٔرِس،تہٕ توٚہۍ ہیٚکِو نہٕ خُدا یس  کانٛہہ نقصا ن واتنٲوِتھ،سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  9,40,"۔تۅہیہِ اگر نبی ﴿صلی اللہ علیہ وسلمس ﴾ مدد کوٚرُو نہٕ تیٚلہِ چُھنہٕ کانٛہہ پرواے ،خُدا ین چُھ تَس تمہِ وقتہٕ مدد کوٚر مُت ییٚلہِ کٲفِر و سُہ کٔڑِتھ اوس ژُھنمُت ، ییٚلہِ سُہ صرف دۅ ن منٛز دوٚ یُم اوس ، ییٚلہِ تِم دۅ شو ے غا رس منٛز ٲسۍ ،ییٚلہِ سُہ پننِس سٲتھِیَس ونان اوس زِ غم مَہ کر اللہ تعالیٰ چُھ اَسہِ سٍتۍ۔ ﴿یہِ ذکر چھےٚ تمہِ ساعتٕچ ییٚلہِ کفارِ مکہ چِھ نبی صلی اللہ علیہ وسلمن ہٕندِ قتلُک قصد کران تہٕ حضور صلی اللہ علیہ وسلم  چِھ عین تمی رٲژ یۅ سہٕ قتلہٕ خٲطرٕ مقرر ٲس کر نہٕ آمٕژ مکہ منٛزٕ نیرِ تھ غارِ ثو رس منٛز تر ٮ۪ن دۅ ہن کھٔٹِتھ روزان تہٕ امہِ پتہٕ چِھ مد ینس کُن ہجر ت کران۔تمہِ وقتہٕ چِھ صرف حضرت ابو بکر رضی اللہ غا رس منٛز تِمن سٍتۍ آسان ﴾ تمہِ وقتہٕ کوٚر خُدا ین تَس پٮ۪ٹھ سکو ن ِ قلب نٲزِل تہٕ تس کوٚرُن تِمو لشکرَو و سٍتۍ مدد یِم تۅہیہِ اَتھہِ ٲسِو نہٕ یِوان، تہٕ کٲفر ن سپٕز نا کٲمی  تہٕ اللہ تعالیٰ سُند کلمہ چُھ تھوٚدُے، اللہ تعالیٰ چُھ زبردست بیٚیہِ دانان تہٕ بینا۔"
  9,41,"۔ نیرِ و خواہ لوٚتۍ چِھو یا گوٚ بۍ تہٕ جہا د کٔرِ و اللہ تعالیٰ سٕنزِ وَتہِ منٛز پننیو مالَو تہٕ پننیو جا نو سٍتۍ،یہِ چُھ تُہٕندِ خٲطرٕ بہتراگر توٚہۍ زٲنِو ۔"
  9,42,"۔ اے نبی صلی اللہ علیہ وسلم، اگر فٲیدہ سہل الحصو ل ﴿ سہل حٲصل کرُن ﴾ آسہٕے تہٕ سفر لوٚت آسِہے تیٚلہِ گژھہَن تِم ضروٗر تۅہیہِ پتہٕ پتہٕ نیر نہٕ خٲطرٕ آمادٕہ مگر تِمن پٮ۪ٹھ گٔیہِ یہِ وَتھ سٮ۪ٹھاہ کِرٛیٖٹھ ﴿یعنی یہِ  وُچِھتھ زِ مقا بلہ چُھ روٗم ہِوِس طا قتس سٍتۍ تہٕ وقت چُھ شد ید گر می ہُند تہٕ مٕلکس چھےٚ قحط سٲلۍ ،تہٕ نَوِ ؤرِیِکۍ فصل ،یِم لۅ ننس وٲتِمٕتۍ ٲسۍ ،تِمن لوٚ گ تبوٗکُک سفر سٮ۪ٹھاہ گوٚ ب با سِنہٕ ﴾ وۅ نۍ ونَن تِم اللہ تعالیٰ سُند قسم کھیٚوان کھیٚوان زِ اگر أسۍ نیرِ تھ ہیکہٕ ہَو ،أسۍ نیر ہَو پٔزِ پٲٹھۍ تۅہیہِ سٍتۍ ،تِم چِھ پنُن پان ہلا کتس منٛز تراوان ، اللہ تعالیٰ چُھ وارٕ ہ پٲٹھۍ زانان زِ تِم چِھ اَپزِ یٲرۍ۔ ع"
  9,43,"۔اے نبی صلی اللہ علیہ وسلم ، اللہ تعالیٰ کٔرۍ نَو تۅہیہِ معا ف،تۅہیہِ کیازِ دِیتُو تِمن رخصت ؟ ﴿ تۅہیہِ پَزِ ہیو  نہٕ پانہٕ  رخصت دِیُن﴾ تاکہ تۅہیہِ پٮ۪ٹھ گژِھہ ہے ظٲہر زِ کم لُکھ چِھ پٔزِ یٲرۍ تہٕ اَپزِ یا رٮ۪ن متعلق تہِ لگہِ ہیٚو پَے ۔"
  9,44,"۔ یِم لُکھ خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان چِھ تھاوان،تِم کر ن نہٕ زٕ ہٕنۍ تۅہیہِ یہِ درخواست زِ تِمن گژِھہ پننہِ جان ومال سان جہاد کر نہٕ نِشہِ معا ف یُن تھا و نہٕ، اللہ تعالیٰ چُھ متقی ین وارٕ پٲٹھۍ زانان۔"
  9,45,"۔یِتھۍ درخواست چِھ صرف اَمہِ قسمٕکۍ لُکھ کران یِمن خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان چُھنہٕ، یِہٕندٮ۪ن دِلن منٛز شک چُھ،تہٕ تِم چِھ پننِس شکسٕے منٛز ترّ دُو ہیٚتھ۔"
  9,46,"۔اگر پٔزۍ پٲٹھۍ تِہُند اردإ نیر نُک آسہِ ہے تیٚلہ کر ہن تِم امہِ خٲطرٕ کینٛہہ تیٲری مگر خُدا یس اوسنہٕ تِہُند وۅ تھن  پسندٕے امہِ موجو ب کٔرۍ تٔمۍ تِم آلٕژۍ تہٕ وَننہٕ آکھ زِ روٗزِ و بِہِتھ، بیٚہہ والن سٍتۍ۔"
  9,47,"۔اگر تِم تۅہیہِ سٍتۍ نیرٕ ہن تیٚلہِ کر ہن نہٕ خرٲبی ورٲے تۅہیہِ منٛز کُنہِ چیزُک اِضا فہٕ۔تِم کر ہن تۅہیہِ در میان فتنہٕ تُلنہٕ خٲطرٕ تگ دَو ،تُہُندِ دَرِیُک حال چُھ یہِ زِوُ نہِ چِھ اَتھ منٛز واریاہ لُکھ تِتھۍ موجود، یِم تِہٕنزٕ کتھہٕ کن دٲرِتھ چِھ بوزان، اللہ تعالیٰ چُھ یِمن ظٲلمن وارٕ پٲٹھۍ زانان۔"
  9,48,"۔ییٚمہِ برونٛہہ تہِ چھےٚ یِمو لُکو فتنہٕ تُلنٕچہِ کو ششہِ کرِ مژٕ،تہٕ توٚہۍ ناکام کر نہٕ مو جو ب چُھ یِمو پرٛتھ قسم چن تد بیر ن ہُند اُلٹ پھیر کوٚرمُت،یو ت تام زَن یِہِنزِ مر ضی خلا ف حق آو ، تہٕ اللہ تعالیٰ سٕنزکٲم وٲژ اَندس۔"
  9,49,"۔یِمو منٛزٕ چھُ کُستام یُس وَنان چھُ زِ مےٚ دِیِو رخصت تہٕ مےٚ مَہ ترٲوِ و فِتنس منٛز۔ بوٗزِ تھ تھٲوِ و ، یِم لُکھ چِھ فِتنس منٛزٕ ے ہینہٕ آمٕتۍ،تہٕ یِم کٲفر چِھ جہنمن گھیرس منٛز رٔٹِمٕتۍ۔"
  9,50,"۔ ییٚلہِ تۅہیہِ خیر چُھ واتان تیٚلہِ چُھ یِمن تکلیف سپدان،تہٕ ییٚلہِ تۅہیہِ کانٛہہ مصیبت چُھ یِوان، یِم چِھ وَنان زِ جان گوٚو اَسہِ اوس گۅڈ ے پنُن معا ملہٕ ٹھیک کوٚر مُت، أتی چِھ خو شی سان پوٚت پھیٖرِ تھ نیران۔"
  9,51,"۔ یِمن ؤنِو  اَسہِ چَھنہٕ ہر گز کانٛہہ﴿بُرٲیی یارٕ ژَر ﴾ واتان مگر تِکینٛژھاہ یہِ خُدا ین سانہِ خٲطرٕ لیٚو کھمُت چُھ، اللہ تعالیٰ ہٕے چُھ سو ن مو لٰی،تہٕ اہلِ ایمانن پزِ تٔسۍ پٮ۪ٹھ بھر وسہٕ کرُن۔"
  9,52,"۔یِمن ؤنِو  سٲنِس معا ملس منٛز ییٚمہِ چیزٕ کۍ توٚہۍ مُنتظر چِھو ، سُہ کیا چُھ امہِ ورٲے زِ سُہ چُھ دۅ یَو رٕ ژرَو منٛزٕ اکھ رٕژر ﴿یعنی اللہ تعالیٰ سٕنزِ وتہِ منٛز شہا دت یا اِسلامٕچ فتح﴾ تہٕ ییٚمہِ چیزٕ کۍ أسۍ تُہٕندِ س معا ملس منٛز منتظر چِھ ، سُہ چُھ یہِ زِ اللہ تعالیٰ چُھ تۅہیہِ پانہٕ سزا دِوان، یا چُھو سا نیٚو اَتھو دِیا وان ؟ اچھا وۅ نۍ کٔرِ و توٚہۍتہِ انتظا ر تہٕ أسۍ تہِ چِھ تۅہیہِ سٍتۍ انتظا رس ۔"
  9,53,"۔یِمن ؤنِو  توٚہۍ کٔرِ تَو پنٕنۍ مال خواہ رٲضی خو شی خر چ ،یا کٔرِ تَو نا خو شی سان، بہر حال یِن نہٕ تِم قبول کر نہٕ، تِکیازِ توٚہۍ چِھو فا سق لُکھ ۔"
  9,54,"۔ یِہندۍ دِنہٕ آمٕتۍ مال قبو ل نہ کر نُک وَجہ چُھنہٕ اَمہِ ورٲے کِہِنۍ زِ یِمَو کوٚر خُدا یس تہٕ تٔمۍ سٕندِس رسول ﴿ صلی اللہ علیہ وسلمس ﴾ سٍتۍ کُفر ،ییٚلہِ نمازِ خٲطرٕ چِھ یِوان تیٚلہِ چِھ کٔش کٔش یِوان،تہٕ ییٚلہِ اللہ تعالیٰ سٕنزِ وَتہِ منٛز خر چ چِھ کران ،تیٚلہِ چِھ نا خو شی سان ﴿چیٚٹۍ زٲنِتھ ﴾ خر چ کران۔"
  9,55,"۔یِہندِس مال دو لتس تہٕ یِہند ٮ۪ن اولادن ہٕندِس کثرتس وُچِھتھ مَہ کھیٚیِو دو کھہٕ، اللہ تعالیٰ چُھ یژھان زِ یِمنٕے چیز ن ہٕندِ ذریعہ کرِ یِمن دُنیا چہِ زند گی منٛز عذا بس منٛز مبتلا ،تہٕ اگر یِم زُو تہِ دِن،سُہ گژھن بس انکارِ حق کِس حا لتس منٛز دِنۍ۔"
  9,56,"۔تِم چِھ اللہ تعالیٰ سُند قسم کھیے کھیے وَنان زِ أسۍ چِھ تۅہی منٛزٕ حالانکہ  چِھنہٕ تِم ہر گز تۅہیہِ منٛزٕ،درا صل چِھ تِم تِتھۍ لُکھ یِمن تُہُند خو ف چُھ۔"
  9,57,"۔اگر تِم کانٛہہ چَھپن جاے لبن ،یا کانٛہہ گۅپھ یا سۅ جاے یَتھ منٛز أژِتھ ہیٚکن،تیٚلہِ ژَلن تہٕ بیٚہَن تٔتھۍ منٛز ژورِ ۔"
  9,58,"۔ اے نبی صلی اللہ علیہ وسلم، یِمو منٛزٕ چِھ کینٛہہ لُکھ صد قات ﴿یعنی اموا لِ زکوٰتہ﴾ بٲگرا ونس منٛز تۅہیہِ پٮ۪ٹھ اعتراض کران،اگر اَمہِ مالہٕ منٛزٕ یِمن کینٛہہ دِنہٕ یِیہِ ، تیٚلہِ سپد ن خو ش،تہٕ اگر دِنہٕ یِیکھ نہٕ، تیٚلہِ چِھ ناراض گژھان۔"
  9,59,"۔کوتاہ جان روزِ ہے زِ یِکینژھاہ خُدا ین تہٕ رسول ﴿صلی اللہ علیہ وسلمن﴾ یِمن دِیتمُت اوس ، تتھ پٮ۪ٹھ روزٕ ہن رٲضۍ تہٕ وَنہن زِ  اللہ چُھ سانہِ خٲطرٕ کٲفی،سُہ دِیہِ اَسہِ  پننہِ فضلہٕ سٍتۍ بیٚیہِ تہِ کینٛہہ ،تہٕ تٔمۍ سُند رسول صلی اللہ علیہ وسلم تہِ فر ماوِ اَسہِ پٮ۪ٹھ عنا یت،أسۍ چِھ اللہ تعالیٰ سٕے کُن مُد ے گٔنڈِ تھ۔ ع۔"
  9,60,"۔یِم صد قات چِھ درا صل فقیر ن تہٕ مسکینن خٲطرٕ ۔﴿ فقیر چُھ مُراد سُہ  شخص یُس پننہِ معشیت خٲطرٕ دوٚ یِمیٚن ہٕندِ مددُک محتا ج آسہِ ،تہٕ مسکین گٔیہِ تِم لُکھ یِم عام حا جت مند ن ہٕندِ کھۅتہٕ زیادہ خستہٕ حال آسن ۔﴾ تہٕ تِمن خٲطرٕ یِم صد قات چن کامیٚن پٮ۪ٹھ مقرر آسن ،تہٕ تِمن خٲطرٕ یُہُند تا لیفِ قلب مطلوٗب آسہِ۔﴿ تالیفِ قلب گوو دلِ رَنٛز وُن۔اَمہِ حکمہٕ نِشہِ چُھ یہِ مقصد زِ یِم لُکھ اسلام کِس مخا لفتس منٛز سر گر م آسن تہٕ مال دِتھ ہیٚکہِ عداوتُک جو ش ٹھنڈٕ کر نہٕ یِتھ ،یا یِم لُکھ کفا ر ن ہٕندِس کیمپس منٛز تِتھۍ آسن زِ اگر مالہٕ سٍتۍ تِم پھُٹرا و نہٕ یِن تہٕ پُھٹنہٕ پتہٕ ہیٚکن مسلمانن ہٕندۍ مددگار بٔنِتھ، یا یِم لُکھ نٔوی نٔوی آسن اسلامس اندر دٲخل گمٕتۍ تہٕ تِہنزٕ کمزوٗر یہِ وُچِھتھ آسہِ اندیشہِ زِ ہرگاہ مالہٕ سٍتۍ تِمن مدد آو نہٕ کر نہٕ ، تیٚلہِ پھیر ن بیٚیہِ کُفر س کُن، یِتھۍ لُکھ گژھن مسقتل وضیفہ یا وقتی عطیہِ دِ تھ  اسلامٕکۍ حٲمی تہٕ مدد گار یا مطیع تہٕ فر مان بردار،یا کم از کم بے ضرر دشمن بنا و نہٕ یِنۍ ﴾ امہِ علا وہ چُھ یہِ گر دَنہٕ یلہٕ ترٛاونہٕ خٲطرٕ ﴿ گردنہٕ یلہٕ تر او نا و نہٕ نِشہِ چُھ مُراد غلا م آزاد کرٕنۍ ﴾ تہٕ قر ضدارن مدد کر نس منٛز بیٚیہِ راہِ خُدا ہس منٛز ﴿ راہِ خُدا ، لفظ چُھ عام ،  ۔تِمہٕ تمام نیکی ہٕنزٕ کامہِ یِمن منٛز اللہ تعالیٰ سٕنز رضا آسہِ ، چھےٚ امہِ لفظ کِس مفہو مس منٛز دٲخل۔علما ہن ہٕندۍ أکۍ دٔرۍ چھےٚ یہِ راے ظٲہر کٔر مٕژ زِ امہِ رٔنگۍ ہیٚکہِ زکوٰتہ دِنہٕ یِتھ ،خواہ تِم بجا ے خۅد ٲسِتن آسودٕہ حال تہٕ پننیٚن ضرور یاتن خٲطرٕ متہٕ ٲسِتن تِمن مددٕچ ضرورت ۔﴾ تہٕ مسا فر نوٲزی منٛز استعمال کر نہٕ خٲطرٕ﴿مسافر ٲسِتن پننہِ گھرِ امیر، مگر ہرگاہ سفرٕ کِس حا لتس منٛز سُہ مددُک محتا ج سپدِ ، تیٚلہِ یِیہِ تس زکوٰتہ کہ مَدٕ منٛزٕ مدد کر نہٕ﴾ اکھ فر یضہٕ چُھ اللہ تعالیٰ سٕندِ طر فہٕ تہٕ اللہ تعالیٰ چُھ سورُے کینٛہہ زانن وول تہٕ دانا تہٕ بینا۔"
  9,61,"۔یِمو منٛزٕ چِھ کینٛہہ لُکھ یِم پننیو کتھو سٍتۍ نبی ﴿صلی اللہ علیہ وسلمس دُکھ چِھ دِوان ۔ تہٕ وَنان چِھ زِ یہِ شخص چُھ کَنہٕ لیٚڈٕ ،ؤنِو ،سُہ چُھ تُہٕنٛدِ رٕژرٕ خٲطرٕ یُتھ،خُدا یس پٮ۪ٹھ چُھ ایمان تھاوان تہٕ اہلِ ایمانن پٮ۪ٹھ چُھ اعتماد کران  بیٚیہِ چُھ سراسر رحمت تِمن لُکن خٲطرٕ یِم تۅہیہِ منٛزٕ ایماندار چِھ،تہٕ یِم لُکھ اللہ تعالیٰ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس﴾ دُکھ چِھ دِوان،تِمن خٲطرٕ چُھ دگ تُلوُن سزا۔"
  9,62,"۔یِم لُکھ چِھ تۅہیہِ برونٛہہ کنہِ قسم کھیٚوان تاکہ تۅہیہِ کر نَو رٲضۍ۔ حالانکہ اللہ تعالیٰ تہٕ تٔمۍ سُند رسول صلی اللہ علیہ وسلم چِھ اَمِیُک زیادہ حقدار زِ یِم کر ن تِمن رٲضۍ کر نٕچ فکر۔ اگر یِم مو من چِھ ۔"
  9,63,"۔ کیا یِمن چَھنا خبر زِ یُس اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہِ وسلمس ﴾ سٍتۍ  مقا بلہٕ چُھ کران، تس خٲطرٕ چُھ جہنمُک نار یتھ منٛز سُہ ہمیشہ روزِ ؟ یہِ چھےٚ سٮ۪ٹھاہ بٔڈ رسوٲیی۔"
  9,64,"۔ یِم مُنا فق چِھ کھۅژان،زِ خبر مُسلمانن پٮ۪ٹھ ما سپدِ کانٛہہ تِیُتھ سورٕہ نٲزِل یُس تِہندِ ٮ۪ن دِلن ہٕندۍ راز نٔنۍ کڑِ ،اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو : بیٚیہِ کٔرِوہَزٕل، اللہ تعالیٰ چُھ تتھ چیز س کھُلا وَن وول ییٚمہِ کِس کھُلنَس توٚہۍ کھۅژان چِھو۔"
  9,65,"۔ اگر یِمن پٕرٛژِھو زِ توٚہۍ کیا کتھہٕ ٲسِو کران، تیٚلہِ دِن فوراً جوا ب زِ أسۍ ٲسۍ اَسُنا تہٕ گِندُنا کران۔ ﴿غزوۂ تبو ک کِس زمانس منٛز ٲسۍ اکثر منا فق پننیٚن مجلِسن منٛز بِہِتھ نبی صلی اللہ علیہ وسلمس تہٕ مُسلمانن مذا ق تہٕ ٹسنہٕ کران تہٕ ہزٕ ل کٔرۍ کٔرۍ ٲسۍ تِمن لُکن ہٕنز ہمت تہٕ ارادٕہ کمزور کر نٕچ کو شش کران یِمن تِم نیک نیتی سان جہا دٕ خٲطرٕ آمادٕہ وُچھان ٲسۍ۔ چنا نچہِ روایتن منٛز چِھ تِہِندۍ واریاہ قَو ل  نقل کر نہٕ  آمٕتۍ۔ مثلاً أکِس محفلہِ مںٛز ٲسۍ  منا فق بِہِتھ  ٹھٹھہٕ مسخرِل کران۔أکۍ ووٚن  کیا روٗمی تہِ  چِھو ا تۅہیہِ کینژھن عر بی ین ہٕندۍ پٲٹھۍ سمٕجھ مٕتۍ؟ پگا ہ وُچھۍ زِیو ، یِم سٲر ی پہلوان یِمو لڑ نہٕ خٲطرٕ چُھ تشر یف  اوٚ نمُت آسن رَزٕ گنڈ کٔرِتھ  بیٚکۍ ووٚن  کیُتھ مزٕ ہ یِیہِ ییٚلہِ پٮ۪ٹھہٕ ہتھ ہتھ کوڑٕ ہ وا لنُک حکم سپدِ ۔ بٚیکۍ أکۍ منا فقن ییٚلہِ حضور صلی اللہ علیہ وسلم وُچھ جنگ چہِ تیٲر یہِ کران تٔمۍ ووٚن یار ن دو ستن  وُچھِتو کھ یِم ،یِم چِھ درٛا مٕتۍ روٗمٕکۍ تہٕ شامٕکۍ قلع فتح کر نہِ﴾ یِمن ؤنِو  کیا تُہٕنز مسخرِ ل ٲسا خُدا یس تہٕ تٔمۍ سٕندٮ۪ن آیاتن  تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕے سٍتۍ ؟"
  9,66,"۔ وۅ نۍ مَہ بنٲوِ و عذرات تۅہیہِ چُھو ایمان اَننہٕ پتہٕ کُفر کوٚر مُت،اگر اَسہِ تۅہیہِ منٛزٕ أکِس دٔرِس معا ف تہِ کوٚر مگر دوٚ یِمِس دٔرِ س دِمَو ضرور أسۍ سزا تِکیازِ سُہ چُھ مجر م ۔  ع"
  9,67,"۔مُنا فق مرد تہٕ منا فق زنانہٕ ،سٲر ی چِھ اکھ أکِس ہم رنگ۔ بُرٲیی ہُند حکم چِھ دِوان تہٕ رٕژرٕ نِشہِ چِھ ٹھا کھ کرا ن، تہٕ پنٕنۍ اَتھہٕ چِھ خیر نِشہِ رُکٲوِتھ تھاوان۔ یِمو مُشر وو خُدا ے تہٕ خُدا ین تہِ مٔشرٲوۍ یِم ، پٔزۍ پٲٹھۍ چِھ یِمے منا فق فا سق۔"
  9,68,"۔یِمن منا فق مردن تہٕ زنانن تہٕ کٲفر ن خٲطرٕ چُھ خُدا ین نارِ جہنمُک وعدٕہ کوٚرمُت،یتھ منٛز یِم ہمیشہ روزن،سُے چُھ یِہندِ خٲطرٕ منٲسِب،یِمن پٮ۪ٹھ چھےٚ اللہ تعالیٰ سٕنز لعنت تہٕ یِہندِ خٲطرٕ چُھ قٲیِم روزن وول عذا ب۔"
  9,69,"۔تۅہیہِ لُکن ہٕندۍ رنگ ڈھنگ چِھ تِمے یِم تُہٕندٮ۪ن بروٗنٹھِمیٚن ہٕندۍ ٲسۍ تِم ٲسۍ تُہٕندِ کھۅ تہٕ زیادٕہ زور آور تہٕ تُہٕندِ کھۅتہٕ زیادہ مال اولادٕ وٲلۍ، پتہٕ تُلۍ تِمو دنیا ہس منٛز پننہِ حصٕکۍ مزٕہ تہٕ تۅہیہِ تہِ تُلِو پننہِ حصٕکۍ مزٕہ تِتھے پٲٹھۍ یِتھہ پٲٹھۍ تِمو ٲسۍ تُلِمٕتۍ، تہٕ تِتھہِ نٕے بحثن منٛز ٲو توٚہۍ تہِ ہیٚنہٕ یِتھیٚن بحثن منٛز تِم ٲسۍ ہیٚنہٕ آمٕتۍ،لہٰذا سپُد تِہُند انجام یہِ زِ دُنیا ہس تہٕ ٲخرتس منٛز یِکینژھاہ تِمو کوٚر مُت کرٛ وو مُت اوس تہِ سپُد ضا یع تہٕ تِمے چِھ خسارس منٛز۔"
  9,70,"۔کیا یِمن نِشہِ وٲژنا یِہٕندٮ۪ن بروٗنٹھِمیٚن لُکن ہٕنز تٲر یخ؟ نو ح علیہ السلام سُند قو م، عاد، ثمو د، ابرا ہیم علیہ السلام سُند قو م، مَدٛیَن ہٕکۍ لُکھ تہٕ تِمہٕ بستیہِ یِمہٕ دُبہٕ آیہِ پھِر نہٕ۔ ﴿ یعنی قو مِ لوط چہِ بستیہِ یِمہٕ دُبہٕ کٔرِ تھ آیہِ تھا و نہٕ ۔﴾ تِہِندۍ رسول آے تِمن نِشہِ ٹا کارٕ ہ نشٲنیہِ ہیٚتھ، پتہٕ ٲس نہٕ یہِ اللہ تعالیٰ سٕنز کٲم زِ تِمن پٮ۪ٹھ کرِ ہے ظُلم مگر تِم ٲسۍ پانے پا نس پٮ۪ٹھ ظُلم کر ن وٲلۍ۔"
  9,71,"۔مو من مرد تہٕ مو من مستوراتہٕ ،یِم سٲر ی چِھ اکھ أکِس رفیق، رٕژرُک چِھ حکم دِوان تہٕ بُرٲیی نِشہِ چِھ رُکا وان، نماز چِھ قٲیِم کران ، تہٕ زکوٰتہ چِھ دِوان بیٚیہِ چِھ اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز اطا عت کران،یِم چھِ تِٕ لُکھ یِمن پٮ۪ٹھ ضرور اللہ تعالیٰ سٕنز رحمت نٲزِل سپدِ ، پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ سارِ نٕے پٮ۪ٹھ غٲلب بیٚیہِ حکیم تہٕ دانا۔"
  9,72,"۔یِمن مو من مردن تہٕ مو من مستوراتن سٍتۍ چُھ اللہ تعالیٰ سُند وعدٕہ زِ یِمن دِیہِ تِتھۍ با غ یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکا ن تہٕ یِم روزن ہمیشہ یِمن منٛز۔ یِمن سدا بہار با غن منٛز آسن یِمن خٲطرٕ پا کیزٕ ہ قیا م گاہ، تہٕ سارِوٕے کھۅتہٕ کھٔسِتھ یہِ زِ اللہ تعالیٰ سٕنز خۅ شنو د ی سپدِ یِمن حٲصل ۔ یٔہے چھےٚ بٔڈ کا میٲبی ۔ع"
  9,73,"۔ ﴿ییتہِ پٮ۪ٹھہٕ چِھ تِم آیات شر وع سپدان یِم غزوہ تبو ک پتہٕ چِھ نٲزِل سپٕدۍ مٕتۍ ﴾ اے نبی صلی اللہ علیہ وسلم، کُفار ن تہٕ منا فقن دۅ شوٕ نۍ سٍتۍ کٔرِ و پوٗرٕ طا قتہٕ سان مقا بلہٕ تہٕ یِمن سٍتۍ یِیِو سختی  سان پیش، ٲخر کار چُھ یُہُند ٹھکانہٕ جہنم تہٕ سۅ چھےٚ بد تر ین روزن جاے ۔"
  9,74,"۔یِم لُکھ چِھ اللہ تعالیٰ سُند قسم کھے کھے وَنان زِ اَسہِ ؤنۍ نہٕ سۅ کتھ، حالانکہ یِمو چھےٚ ضرور سۅ کافرا نہٕ کتھ ؤنِمٕژ﴿سۅ کتھ کیا ٲس یتھ کُن یتھ جایہِ اشارہ چُھ کر نہٕ آمُت، اَتھ متعلق چِھنہٕ اسہِ نِشہِ یقینی معلو مات وٲتِمٕتۍ کینٛہہ،البتہٕ چھےٚ یِژھن کٲفر انہٕ کتھن متعلق واریاہن روایتن منٛز ذکر آمٕژیِمہٕ تمہِ وقتہٕ منا فقو کرِ مَژٕ آسہِ ۔ مثلاً أکۍ منا فقن ووٚن أکِس مسلمان نو جو انس سٍتۍ کتھ کران کران زِ اگر وا قعی تہِ سورُے کینٛہہ پوٚز چُھ یُس یہِ شخص ﴿نبی صلی اللہ علیہ وسلم ﴾ پیش چُھ کران تیٚلہِ چِھ أسۍ سٲر ی خَر و کھۅتہٕ تہِ بدتر۔ بیٚیہِ أکِس روایتس منٛز چُھ زِ تبو ک کِس سفرس دوران رٲو نبی صلی اللہ علیہ وسلمن ہٕنز اوٗنٹِنۍ أکِس جایہِ ۔ تمہِ وقتہٕ کٔرۍ منا فقو پننہِ مجلسہِ منٛز بِہِتھ سٮ۪ٹھاہ مذا ق تہٕ ووٚ نُکھ پانہٕ وٲنۍ زِ  یِم حضرت چِھ آسما ن چہِ خبرٕ بو ز ناوان مگر یِمن چَھنہٕ پننہِ اوٗنٹنہِ ہٕنز کانٛہہ خبر زِ سۅ کتہِ چھےٚ وُنۍ کیٚنس۔﴾ تِم سپد ۍ اسلام قبول کر نہٕ پتہٕ کُفرٕ کۍ مرتکب تہٕ تِمو کوٚر تِکینژھاہ کر نُک ارداہ یہِ تِمو کٔرِ تھ ہیوٚک نہٕ ۔ ﴿یہِ اشارہ چُھ تِمن سٲزِشن کُن یِمہٕ مُنا فقو غز وۂ تبو ک کہ وقتہٕ آسہٕ کرِ مژٕ۔أکِس مو قعس پٮ۪ٹھ بنٲو تِمو یہِ سیکم زِ رٲتۍ کِیُتھ لگا وَن سفر س دورا ن حضو ر صلی اللہ علیہ وسلمس کُنہِ کھیہِ منٛز۔تِمو اوس پانہٕ وٲنۍ یِتہِ فٲصلہٕ کوٚر مُت زِ اگر تبو کس منٛز مسلمانو شکست کھیو ٚ و ، تیٚلہِ تھا وَن فوراً مد ینس منٛز عبد اللہ بن ابی سٕندِس کلس پٮ۪ٹھ شٲہی تاج﴾ یُہُند یہِ سورُے شرارت چُھنا أتھۍ کتھہِ پٮ۪ٹھ زِ خُدا ین تہٕ تٔمۍ سٕندۍ رسول ﴿صلی اللہ علیہ وسلمن ﴾ بنٲوۍ یِم پننہِ فضلہٕ سٍتۍ غنی !  وۅ نۍ اگر یِم پننہِ رٔوِشہِ نِشہِ با ز یِن ، تیٚلہِ چُھ یہِ یِہِندۍ خٲطرٕ بہتر ،تہٕ اگر یِم باز پھیر ۍ نہٕ تیٚلہِ دِیہِ اللہ تعالیٰ یِمن سٮ۪ٹھاہ دگ تُلوُن سزا، دُنیا ہس منٛز تہِ تہٕ ٲخرتس منٛز تہِ ، تہٕ زمینس منٛز چُھنہٕ کانٛہہ یُس یِمن حما یتی تہٕ مدد گار آسہِ ۔"
  9,75,"۔ یِمن منٛز چِھ کینٛہہ تِتھۍ تہِ یِمو خُدا یس سٍتۍ عہد اوس کوٚر مُت زِ اگر تٔمۍ پننہِ فضل سٍتۍ أسۍ نوٲزۍ تیٚلہِ کر و أسۍ خیرا ت بیٚیہِ بنو صا لح،"
  9,76,"۔مگر ییٚلہِ خُدا ین پننہِ فضل سٍتۍ تِم دو لت مند بنٲوۍ۔ پتہٕ لوگ تِمَو بخل کرُن ، تہٕ پننہِ عہدٕ نِشہِ پھیٖرۍ تِتھہٕ پٲٹھۍ زِ یِمن چُھنہٕ اَمِیُک پرواے تام"
  9,77,"۔نتیجہ درٛا و یہِ زِ خُدا ین بیٚہہنو و تِہند ٮ۪ن دِلن منٛز نِفا ق، یُس تٔمۍ سٕندِس خد متس منٛز تِہنزِ پیشی ہٕندِس دۅ ہس تام تِمن پتے روزِ تِہنزِ امہِ وعدٕہ خلٲفی کِنۍ یوسہٕ تِمو خُدا یس سٍتۍ کٔر، تہٕ تمہِ اَپزِ کہ وجہ کِنۍ یُس تِم ونان روٗدۍ،"
  9,78,"۔ کیا یِمن لُکن چَھنا پَے زِ خُدا یس چِھ یِہِندۍ چُھپا و نہٕ آمٕتۍ راز تہٕ یِہنزٕ پو شیدٕ کنہٕ پھِسرا یہِ تام معلو م ، تہٕ سُہ چُھ تمام غیب چو کتھو نِشہِ پوٗزٕ پٲٹھۍ با خبر؟ ﴿سُہ چُھ وارٕ پٲٹھۍ زانان تِمن کنجو س دو لت مند ن ﴾ یِم بر ضا و رغبت دِنہٕ والیٚن اہلِ ایمانن ہٕنز ن مٲلۍ قر بٲنین پٮ۪ٹھ کتھہٕ چِھ کران ﴿ یعنی تِمن چِھ عیب لَد ونان ﴾"
  9,79,"۔تہٕ تِمن لُکن چِھ ٹسنہٕ ژٹان یِمن نِشہِ ﴿اللہ تعالیٰ سٕنزِ وَتہِ منٛز دِنہٕ خٲطرٕ﴾ اَمہِ ورٲے کِہِنۍ چُھنہٕ یِکینٛژھاہ تِم پا نس  پٮ۪ٹھ مشقت برداشت کٔرِ تھ دِوان چِھ اللہ تعالیٰ چُھ یِمن ٹَسنہٕ ژٹن والیٚن ٹسنہٕ ژٹان، تہٕ یِہندِ خٲطرٕ چُھ کُڈُر عذا ب،"
  9,80,"۔اے نبی صلی اللہ علیہ وسلم،خواہ توٚہۍ کٔرۍ تَو یِتھیٚن لُکن ہٕندِ خٲطرٕ معا فی ہُند درخواست یا متہٕ کٔرِ تو ، اگر توٚہۍ سَتتھہِ لٹہِ تہِ یِمن معاف کر نُک در خوا ست کٔرِ و، اللہ تعالیٰ کرِ نہٕ یِمن ہر گز معا ف امہِ موجوٗب زِ یِمَو چُھ خُدا یس تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس﴾ سٍتۍ کُفر کوٚر مُت،تہٕ اللہ تعالیٰ چُھنہٕ فا سق لُکن نجا تٕچ وَتھ ہاوان۔ ع"
  9,81,"۔یِمن لُکن پتھ روزنُک اجا زت اوس دِنہٕ آمُت تِم سپٕدۍ خُدا ے سٕندِس  رسول﴿صلی اللہ علیہ وسلمس﴾ ساتھ نَہ دِ نَس تہٕ گھرِ روزنس پٮ۪ٹھ خۅ ش تہٕ تِمن گوٚو نہٕ گوارٕہ زِ اللہ تعالیٰ سٕنزِ وَتہِ منٛز کر ہن جان و مال سٍتۍ جہا د۔تِمو ووٚ ن لُکن زِ  یتھ سخت گر می منٛز مَہ نیٖرِ و ۔ یِمن ؤنِو زِ جہنمُک نار چُھ امہِ کھۅتہٕ زیادہ گر م ، کا ش یِمن آسہِ ہے اَمِیُک شعور۔"
  9,82,"۔وۅ نۍ پزِ زِ یِم لُکھ کٔرِن پنُن اَسُن کم تہٕ ؤدِ ن زیادٕہ، امہِ موجوٗب زِ یۅسہٕ بد ی یِم کما وان روٗدِ مٕتۍ چِھ تمِیُک جز ا چُھ یُتُھے ﴿زِ یِمن پَزِ اَتھ پٮ۪ٹھ وَدُن﴾۔"
  9,83,"۔اگر اللہ تعالیٰ تۅہیہِ یِمن در میان وا پس نِیَو تہٕ آیندٕ ہ منگیو یِمو منٛزٕ کانٛہہ دوٚر جہا دس نیر نہٕ خٲطرٕ اجا زت تیٚلہِ ؤنۍ زِ یو کھ صا ف وۅ نۍ ہیٚکِو نہٕ ہر گز توٚہۍ مےٚ سٍتۍ نیٖرِ تھ تہٕ نہ ہیٚکِو مےٚ سٍتۍ رٔلِتھ کٲنٛسہِ دشمنس سٍتۍ لٔڑِ تھ، تۅہیہِ  اوسُو برونٛہہ، بِہِتھ روزُن پسند کوٚرمُت۔تیٚلہِ روٗزِ و وۅ نۍ گھرِ بیٚہَن والیٚن سٍتۍ بِہِتھ۔"
  9,84,"۔تہٕ آیندٕہ یُس یِمو منٛزٕ مَرِ ، تٔمۍ سُند نمازِ جنا زہ تہِ پٔرۍ زِ یو نہٕ توٚہۍ ہر گز تہٕ نہ گٔژھۍ زِ یو تٔمۍ سٕنزِ قبرِ پٮ۪ٹھ زانٛہہ کھڑا،تِکیازِ یِمَو چھُ خُدا یس تہٕ تٔمۍ سٕندِس رسول ﴿ صلی اللہ علیہ وسلمس ﴾ سٍتۍ کفر کوٚر مُت تہٕ تِم چِھ موٗدِ مٕتۍ اتھ حالس منٛز زِ تِم ٲسۍ فا سق،"
  9,85,"۔ تِہٕنز مال دٲری تہٕ تِہُند کثرتِ او لاد یِنہٕ تۅہیہِ دوکھس منٛز ترٛا ویو،خُدا ین چُھ اردإہ کوٚر مُت زِ اَمہِ مالہٕ تہٕ اولادٕ ذر یعہ دِیہِ یِمن ییتھۍ دُنیا ہس منٛز سزا تہٕ تِہِندۍ زُو گژھن اتھ حالس منٛز نیرٕ نۍ زِ تِم آسن کٲفر ۔"
  9,86,"۔ ییٚلہِ زانٛہہ کانٛہہ سورٕہ اَمہِ مضمو نُک نٲزِل سپُد زِ اللہ تعالیٰ مٲنِیوٗ ن تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس﴾ سٍتۍ رٰٔلِتھ کٔرِو جہا د ، پتہٕ وُچھوٕ ہ تۅہیہِ زِ یِمن لُکن یِمَو منٛزٕ طا قت تہٕ وسعت اوس تِمے لٔگۍ تۅہیہِ در خوا ست کر نہِ زِ تِمن گژِھہ جہا د کہ شر کتہٕ نِشہِ معا ف یُن تھا و نہٕ، تہٕ تِمو ووٚ ن زِ اَسہِ ترٲوِ و أسۍ روزَو بِہَن والیٚن سٍتۍ۔"
  9,87,"۔تِمَو لُکو کوٚر گھرِ بیٚہَن واجِنیٚن منٛز شٲمل سَپدُن پسند۔تہٕ تِہٕندِ ٮ۪ن دِلن پٮ۪ٹھ آو ٹھپہٕ لگا و نہٕ، امہِ موجو ب چُھنہٕ وۅ نۍ تِمن کِہِنۍ فکرِ تران۔"
  9,88,"۔ اَتھ بر عکس کوٚر رسول ﴿صلی اللہ علیہ وسلم﴾ تہٕ تِمو لُکو یِمو رسول ﴿صلی اللہ علیہ وسلمس ﴾ سٍتۍ ایمان اوس اوٚ نمُت پننہِ جان و مال سٍتۍ جہا د تہٕ وۅ نۍ چِھ سٲری رٕژَر یِمنٕے خٲطرٕ تہٕ یِمے چِھ فلا ح لبن وٲلۍ۔"
  9,89,"۔خُدا ین چِھ یِہِندِ خٲطرٕ تِتھۍ با غ تیار تھٲوِمٕتۍ یِمن بٔنۍ کِنۍ کۅ لہٕ چھےٚ پکان، یِمن منٛز روزن تِم ہمیشہ ۔یہِ چھےٚ عظیم الشا ن کا میٲبی ۔ع"
  9,90,"۔ عر ب کیو بدو ی یَو منٛز تہِ آے واریاہ لُکھ یِمو عُذر کٔرۍ تاکہ تِمن تہِ گژِھہ پتھ روزنُک اجا زت دِنہٕ یُن ﴿عر بِکۍ بدوی چُھ مُراد تِم عر بی دیہٲتۍ تہٕ صحرٲے لُکھ یِم مد ینس أندۍ پٔکۍ بسا ن ٲسۍ ﴾ یِتھہٕ پٲٹھۍ روٗدۍ بِہِتھ تِم لُکھ یِمو اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس﴾ سٍتۍ ایما نُک اَپُز عہد اوس کوٚر مُت، یِمو بد و ی یَو  منٛزٕ یِمو لُکو کفرُک طر یقہٕ اختیار چُھ کوٚر مُت ، عنقر یب پیٚیہِ تِمن دگ تُلوُن عذا ب وُچُھن۔"
  9,91,"۔ضعیفن تہٕ بیمار ن بیٚیہِ تِمن لُکن یِمن جہا دس منٛز شر کتہٕ خٲطرٕ وَتہٕ خر چ آسہِ نہٕ، ہرگاہ پتھ روزن تیٚلہِ چُھنہٕ کانٛہہ حر ج ییٚلہِ زن تِم دل کہ خلو صہٕ سان اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕندۍ وفادار آسن۔﴿اَمہِ نِشہِ سپُد معلو م زِ یِم لُکھ بظٲہر   معذور آسن تِہندِ خٲطرٕ تہِ چَھنہٕ کمزور ی تہٕ بیمٲرۍ یا محض نا دٲری کا فی کینٛہہ، بلکہ ہیٚکن تِہندِ خٲطرٕ یِمہٕ مجبو ر یہِ صر ف اتھ صوٗرتس منٛز معٲفی ہُند و جہ ٲسِتھ ییٚلہِ زن تِم اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم  سٕندۍ پٔزۍ وفا دار آسن ، نَتہٕ ہر گاہ وفا دٲر ی مو جو د آسہِ نہٕ تیٚلہِ ہیٚکہِ نہٕ کٲنٛسہِ شخصس صرف امہِ موجوٗب معا ف کر نہٕ یِتھ زِ سُہ اوس فر ض ادا کر نہٕ کِس مو قعس پٮ۪ٹھ بیمار یا نا دار ﴾ یِتھیٚن محسِنَن پٮ۪ٹھ چَھنہٕ اعتراضٕچ کانٛہہ گُنجٲ یش، تہٕ اللہ تعالیٰ چُھ در گُز ر کر ن وول تہٕ رحم فر ماون وول ۔"
  9,92,"۔یِتھے پٲٹھۍ چُھنہٕ تِمن لُکن پٮ۪ٹھ تہِ اعتراضُک کانٛہہ مو قع ،یِمو تۅہیہِ نِش پانہٕ یِتھ در خوا ست اوس کوٚر مُت زِ اَسہِ گژھن سوارِ دستیا ب یِنہِ تھا و نہٕ ،تہٕ ییٚلہِ تۅہیہِ ووٚ نُو زِ بہٕ ہیکہٕ نہٕ تُہٕندِ خٲطرٕ سوار ین ہُند انتظام کٔرِ تھ تہٕ تِم گٔیہِ مجبو راً وا پس تہٕ حال اوس یہِ زِ تِہنز و أچھو کِنۍ اوس اوٚ ش وَسان تہٕ تِمن اوس امہِ کتھہِ ہُند سٮ۪ٹھاہ دُکھ زِ تِم چِھنہٕ پننِس خر چس پٮ۪ٹھ جہا دس منٛز شر یک سپدنُک طا قت تھاوان۔"
  9,93,"۔البتہ چُھ اعتراض تِمن لُکن پٮ۪ٹھ یِم مالدار چِھ ، تہٕ امہِ پتہٕ تہِ چِھو تۅہیہِ در خوا ست کران زِ تِمن گژِھہ جہادس منٛز شر یک  سپد نہٕ نِشہِ معا ف یُن تھاو نہٕ،تِمو کوٚر گھرِ بِہَن واجِنیٚن منٛز شٲمل سپدُن پسند،تہٕ خُدا ین لگو و تِہندِٮ۪ن دِلن پٮ۪ٹھ ٹھپہٕ،امہِ موجوٗب چِھنہٕ وۅ نۍ تِم کِہِنۍ زانان﴿زِ خُدا یس نِشہِ کیا نتیجہِ نیر ن وول چُھ تِہنزِ اَمہِ  رٔوشہِ ہُند ﴾۔"
  9,94,"۔ یِم کر ن رنگہٕ رنگہٕ عُذرات تۅہیہِ نِشہِ پیش تیٚلہِ توٚہۍ واپس پھیٖرِ تھ یِمن نِشہِ وٲتِو ، مگر توٚہۍ ؤنۍ زِ یو صا ف کہ  بہا نہٕ مَہ کٔرِ و ، أسۍ کرو نہٕ تُہنزِ کُنہِ کتھہِ پٮ۪ٹھ اعتبار،خُداین چِھ اَسہِ تُہٕندۍ حالات ؤنِمٕتۍ، وۅ نۍ وُچھہِ اللہ تعالیٰ تہٕ تٔمۍ سُند رسول صلی اللہ علیہ وسلم یُہُند طر زِ عمل ، پتہٕ یِیِو توٚہۍ تس کُن واپس پھِر نہٕ یُس نوٚ ن تہٕ پو شیدٕ ہ سورُے زانن وول چُھ۔تہٕ سُہ وَنیو تۅہیہِ زِ توٚہۍ کیا کینژھاہ چِھو کران روٗزِمٕتۍ۔"
  9,95,"۔تُہٕنزِ وا پسی پٮ۪ٹھ کھیٚن  یِم تۅہیہِ برونٛہہ کنہِ قسم تا کہ توٚہۍ کٔرِ و تِمن در گز ر تیٚلہِ کٔرِو بے شک توٚہۍ یِمن در گز ر، تِکیازِ یِم چِھ گند گی تہٕ یِہٕنز اصلی جا ے چھےٚ جہنم یُس  یِہنزِ کما یہِ بد لہٕ یِمن نصیب سپدِ۔"
  9,96,"۔یِم کھیٚن تۅہیہِ برونٛہہ کنہِ قسم ، تاکہ توٚہۍ سپدِ و یِمن رٲضۍ، حالانکہ اگر توٚہۍ یِمن رٲضۍ تہِ سپدِ و ، اللہ تعالیٰ گژِھ نہٕ یِمن فا سق لُکن ہر گز رٲضۍ ۔"
  9,97,"۔یِم عربٕکۍ بدوی چھِ کفرس تہٕ نفاقس منٛز زیادٕہ سخت تہٕ یِہندِس معا ملس منٛز چِھ امہِ کتھہِ ہٕندۍ زیادہ امکان زِ تمہِ دین کیو حدودَو نِشہِ روزن نا وٲقف ،یُس خُدا ین پننِس رسولس  پٮ۪ٹھ چُھ نٲزِ ل کوٚر مُت۔﴿عر بٕکۍ بدوی چُھ مُراد تِم عر بی دیہا تی تہٕ صحر ٲے لُکھ یِم مد ینس أندۍ پٔکۍ بسا ن ٲسۍ۔ یِمو لُکو ییٚلہِ مدینس منٛز اکھ مضبو ط مُستحکم طا قت وۅ تلا ن وُچھ یِم سپٕدۍ گۅڈٕ گۅڈٕ مر عو ب ۔پتہٕ روٗدۍ اسلام چن تہٕ کُفر چن لڑا یَن دورا ن أکِس وقتس تام مو قع شنٲسی تہٕ ابنُ الو قتی ہٕنزِ رٔوِشہِ پٮ۪ٹھ پکا ن یعنی واو  وُچِھتھ ٲسۍ ناو ترٛا وان ۔پتہٕ ییٚلہِ اسلامی حکو متُک اقتدار حجاز تہٕ نجدکِس أکِس بٔڑِس حِصّس پٮ۪ٹھ قٲیِم سپُد تہٕ امہِ کِس مُقابلس مںٛز لوٚگ مخٲلف قبیلن ہُند زور پُھٹنہِ ،یِمولُکو وُچھ وقتٕچ مصلحت أتھۍ منٛز زاِسلام کِس دٲیرس منٛز سپدن دٲخل،مگر یِمن لُکن منٛز ٲسۍ کم لُکھ تِتھۍ یِمو اَتھ دینس دینِ حق سمجھِتھ ایمان آسہِ ہے اوٚ نمُت تہٕ مُخلصا نہٕ طر یقو سان آسٕہَن امہِ کیٚن تقا ضن پوٗرٕ کر نس پٮ۪ٹھ آمادٕہ۔تِہٕنز یٔہے حالت چھےٚ یتھ جایہِ تِتھہٕ پٲٹھۍ بیان کر نہٕ آمٕژ زِ شٔہر ۍ لُکن بہ نسبت چِھ یِم دیہٲتۍ تہٕ صحرٲوۍ لُکھ زیادہ مُنا فقانہٕ رٔوِیہِ تھا وان ،تہٕ یِمن منٛز چھےٚ حقس انکار کر نٕچ کیفیت زیادٕہ لبنہٕ یِوان ۔پتہٕ چُھ اَمِیُک و جہ تہِ وَننہٕ آمُت زِ شٔہرۍ لُکھ چِھ اہلِ علم تہٕ اہلِ حقن ہٕندِ صحبت نِشہِ فٲیدٕہ تُلِتھ کینژھاہ دین تہٕ اَمِکۍ حدود ہیٚچھان ، مگر یِم بد و ی چِھ چو نکہ سٲر سٕے وٲنٛسہِ با لکل أکِس معٲشی حیوا ن سٕندۍ پٲٹھۍ دۅ ہس رات کِس دٲیر س منٛزروزان ،تہٕ یِمن چُھنہٕ حیوٲنۍ زند گی ہٕند یٚو ضرور یا تو نِشہِ کھٔسِتھ کُنہِ چیز س کُن توجہ  کر نُک مو قعے میلان ۔امہِ موجوٗب چِھ دین تہٕ امہِ کیو حدوٗدَو نِشہِ یِہندِ نا وٲقف روزنٕکۍ امکان زیادٕہ ۔ برونٛٹھ کُن چُھ، 122 ہِمِس آیتس منٛز یِہندِ اَمہِ مر ضُک علا ج آمُت تجو یز کر نہٕ۔﴾ اللہ تعالیٰ چُھ سورُے زانان بیٚیہِ چُھ زانن وول تہٕ حکمت وول۔"
  9,98,"۔یِمن بدوِ یَن منٛز چِھ تِتھۍ تِتھۍ لُکھ موجو د یِم اللہ تعالیٰ سٕنزِ وَتہِ منٛز چِھ کینٛہہ خر چ کران تہٕ اتھ چِھ پا نس پٮ۪ٹھ زبردستی ہٕنز چیٚٹۍ سمجھان، تہٕ تُہٕندِ س حقس منٛز چِھ  زمانہ چن گر دشن ہُند انتظا ر کران﴿زِ توٚہۍ گٔژھِو کُنہِ چکر س منٛز پھَسٕنۍ تہٕ تِم کڑ ہن پننہِ گردَنہِ منٛزٕ اَمہِ نظا م کہ اطا عتُک نا لہٕ کوٚر یَتھ منٛز تۅہیہِ یِم کھٔسِتھ چھوٗکھ تھٲوِ مٕتۍ ﴾ حالانکہ بد ی ہُند دٲیرٕ ہ چُھ پانہٕ یِمنٕے پٮ۪ٹھ مُسلّط تہٕ اللہ تعالیٰ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  9,99,"۔ تہٕ یِمنٕے بد وِیَن منٛز چِھ کینٛہہ لُکھ تِتھۍ تہِ ، یِم خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ چِھ ایمان تھاوان، تہٕ یِکینژھاہ خر چ چِھ کران تتھ چِھ اللہ تعالیٰ سٕندِس در بارس منٛز نز د یکی ہُند تہٕ رسول ﴿صلی اللہ علیہ وسلمن ﴾  ہٕندِ طر فہٕ رحمتٕکۍ دُعا رَٹنُک ذر یعہ بناوان ، آ، یقیناً ! سُہ چُھ ضرور تِہندِ خٲطرٕ نز د یکی ہُند ذر یعہ ،تہٕ اللہ تعالیٰ کرِ ضرور تِمن پننِس رحمتس منٛز دٲخل ، پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ در گُز ر کر ن وول تہٕ رحم فر ماون وول۔ع"
  9,100,"۔تِم مہا جر تہٕ انصار یِمو سارِوٕے برونٛٹھ ایمان کِس  دعوتس پٮ۪ٹھ لبیک وَننس منٛز سبقت کٔر، بیٚیہِ تِم یِم امہِ پتہٕ راست بٲزی سان تِمن پتہٕ آے، خُدا ے سپُد  تِمن رٲضۍ تہٕ تِم سپٕدۍ خُدا یس رٲضۍ، خُدا ین چِھ تِمن خٲطرٕ تِم با غ دستیاب تھٲوِ مٕتۍ یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکا ن، تہٕ تِم روزن ہمیشہ یِمن منٛز، یٔہے چھےٚ عظیم الشا ن کامیٲبی۔"
  9,101,"۔ تۅہیہِ أندۍ پٔکۍ یِم بد و ی روزان چِھ تِمن منٛز چِھ واریاہ مُنا فق  تہٕ یِتھے پٲٹھۍ چِھ خۅد مدینہ کیٚن با شند ن منٛز تہِ منا فق موجو د یِم نِفا قس منٛز طا ق  چِھ بنیمٕتۍ، توٚہۍ چھوٗکھ نہٕ تِم زانان، أسۍ چِھکھ تِم زانان، قر یب چُھ سُہ وقت ییٚلہِ أسۍ تِمن دۅ یہِ پھِرِ سزا دِمَو، پتہٕ یِن تِم سٮ۪ٹھاہ بَڈِ سزا خٲطرٕ و اپس اَننہٕ۔"
  9,102,"۔بیٚیہِ چِھ کینٛہہ لُکھ یِمو پننیٚن قصور ن ہُند اعترا ف چُھ  کوٚرمُت،تِہٕنز عمل چھےٚ مخلو ط ،کینٛہہ چھےٚ نیک تہٕ کینٛہہ چھےٚ بَد، یہِ کتھ چھَنہٕ دوٗر زِ اللہ تعالیٰ سپدِ تِمن پٮ۪ٹھ مہربان ،تِکیازِ سُہ چُھ در گز ر کر ن وول تہٕ رحم فر ماو ن وول ۔"
  9,103,"۔اے نبی صلی اللہ علیہ وسلم ،توٚہۍ کٔرِ یوٗکھ یِم یِہٕندِ یو مالَو منٛزٕ صد قہٕ رٔٹِتھ پاک تہٕ ﴿ نیکی ہٕنزِ وَتہِ منٛز﴾ پکنٲوِ یوٗکھ یِم برونٛہہ تہٕ یِہندِس حقس منٛز کٔرِ و رحمتُک دُعا ، تِکیازِ تُہُند دُعا آسہِ یِہندِ خٲطرٕ تسکینُک وجہ، اللہ تعالیٰ چُھ سورُے بوزان تہٕ زانان۔"
  9,104,"۔کیا یِمن لُکن چَھنا خبر زِ سُہ چُھ اللہ تعالیٰ ہٕے یُس پننیٚن بند ن ہُند تو بہٕ چُھ قبو ل کران، تہٕ تِہندِس خیر اتس چُھ  قبو لیّت عطا کران، بیٚیہِ یہِ زِ اللہ تعالیٰ چُھ سٮ۪ٹھاہ معا ف کر ن وول تہٕ رحیم۔"
  9,105,"۔تہٕ اے نبی صلی اللہ علیہ وسلم، یِمن لُکن ؤنِو زِ توٚہۍ کٔرِ و عمل ، اللہ تعالیٰ تہٕ تٔمۍ سُند رسول صلی اللہ علیہ وسلم بیٚیہِ مو من سٲری وُچَھن زِ تُہُند طر زِ عمل کیا چُھ وۅ نۍ روزان، پتہٕ یِیِو توٚہۍ تس کُن وا پس پھِر نہٕ یُس نوٚ ن تہٕ پو شیدٕ ہ سورُے چُھ زانان، تہٕ سُہ وَنیو تۅہیہِ زِ توٚہۍ کیا چِھو روٗدِمٕتۍ کرا ن۔"
  9,106,"۔کینہہ لُکھ چِھ بیٚیہِ یُہُند معا ملہٕ وُنہِ اللہ تعالیٰ سٕندِس حکمس پٮ۪ٹھ چُھ ٹھٔہرِ تھ، چا ہے دِیہِ تن تِمن سزا ، تہٕ چا ہے سپدۍ تن تِمن پٮ۪ٹھ نَوِ سرٕمہر بان ، اللہ تعالیٰ چُھ سورُے کینٛہہ زانان بیٚیہِ چُھ زانن وول تہٕ حکمت وول۔"
  9,107,"۔بیٚیہِ چِھ کینٛہہ لُکھ یِمَو اکھ مسجد بنٲو، اَمہِ غر ضہٕ خٲطرٕ زِ ﴿دعوتِ حقس ﴾ و تنا و ہن نقصا ن ، تہٕ ﴿اللہ تعالیٰ سٕنز بند گی کر نہٕ بجا ے﴾ کر ہن کُفر ، بیٚیہِ تراوِ ہن اہلِ ایمانن منٛز پھا ٹَو ن واد، بیٚیہِ بنا وٕ ہن ﴿اتھ یُس بظٲہر عبادت گاہ چُھ باسان ﴾ تس شخصہٕ سٕندِ خٲطرٕ کمین گا ہ ﴿زاگہِ روزنٕچ جا ے ﴾ یُس امہِ برونٛہہ خُدا یس تہٕ تٔمۍ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس﴾ خلا ف بر سرِ پیکار چُھ سپُد مُت۔ تِم وَنن قسم کھیے کھِیے ضرور زِ سو ن اِرادٕہ اوسنہٕ رٕژرٕ وٲرے بیٚیہِ کُنہِ چیزُک مگر اللہ تعالیٰ چُھ گواہ زِ تِم چِھ موٗلَے اَپزِ یٲرۍ۔"
  9,108,"۔توٚہۍ گٔژھۍ زِیو نہٕ ہر گز اتھ عما رتس منٛز کھڑا ،یۅسہٕ مسجدروزِ اوّل پٮ۪ٹھہٕ تقویٰ ہس پٮ۪ٹھ قٲیِم ٲس کر نہٕ آمٕژ، سۅ ے چھےٚ اَمہِ خٲطرٕ زیادہ منٲسب زِ توٚہۍ سپدِ و تَتھ منٛز عبا دت خٲطرٕ کھڑا، تتھ منٛز چِھ تِتھۍ لُکھ یِم پاک روزُن چِھ پسند کران، تہٕ خُدا یس چِھ پٲکیز گی اختیار کر ن وٲلۍ پسند۔﴿ تمہِ وقتہٕ آسہٕ مد ینس منٛز زٕ ہ مسجدٕ ، اکھ ٲس قُبا یۅسہٕ شہر کیٚن مضا فاتن منٛز ٲس ، بیاکھ ٲس مسجد نبو ی یۅسہٕ شہرس منٛزٲس۔یِمن دۅ ن مسجد ن ہٕنزِ موجو د گی منٛز ٲس نہٕ تر ییِم مسجد بناونٕچ کانٛہہ ضرورت ، مگر منا فقو بنو و یہِ بہا نہٕ زِ روٗدس تہٕ سردرٲژن منٛز چُھ عام لُکن خصوصاً کمزور ن تہٕ معذورن یِم یِمو مسجدَو نِشہِ دوٗر روزان چِھ پانژن وقتن واتُن مشکل گژھان، لہٰذا چِھ أسۍ محض نماز پَر ن والیٚن ہٕنزِ آسانی خٲطراَکھ نٔو مسجد تعمیر کرٕنۍ یژھان۔یِتھہٕ پٲٹھۍ ہیوٚت تِمَو اَمہِ کہ تعمیرُک اجازت تہٕ یہِ بنٲوٕکھ  پننیٚن سٲزِ شن ہُند اَڈٕہ۔ تِم ٲسۍ یژھان زِ نبی صلی اللہ علیہ وسلمس دۅ کھہٕ دِتھ کر ناوٕ ہن تِہندِ ذر یعہ اَمِیُک اِفتتا ح ،مگر اللہ تعالیٰ چُھ حضور  صلی اللہ علیہ وسلمس تِہندِ یٚو اردَو نِشہِ گۅڈے خبردار کران تہٕ تبو ک پٮ۪ٹھہٕ وا پس تشر یف أنِتھ چِھ تِم صلی اللہ علیہ وسلم  اَتھ مسجدِ مِسمار کران۔﴾"
  9,109,"۔پتہٕ کیا چُھ تُہُند خیال زِ بہتر ین انسان چھا سُہ ییٚمۍ پننہِ عما رتٕچ بُنیا د اللہ تعالیٰ سٕندِس خو فس تہٕ تٔمۍ سٕنز ر ضا حٲصل کر نس پٮ۪ٹھ تھٲومٕژ آسہِ ، کِنہٕ سُہ ییٚمۍ پنٕنۍ عمارت أکِس وٲدی ہٕندِس کھۅ کھرِس نا پا یدا ر بٔٹھِس پٮ۪ٹھ ٲس کھڑا کٔر مٕژ، تہٕ سۅ گیہِ تس ہیٚتھ سیوٚدُے جہنم کِس نا رس منٛز؟ یِتھیٚن ظٲلِم لُکن چُھنہٕ اللہ تعالیٰ زٕ ہٕنۍ سٔیز وتھ ہاوان،"
  9,110,"۔یہِ عما رت یۅسہٕ تِمو بنٲو مٕژ چھےٚ ،روٗزِ ہمیشہ یِہندٮ۪ن دِلن منٛز بے یقینی ہُند موٗل بٔنِتھ۔﴿ییٚمہِ کہ نیرنٕچ وۅ نۍ کانٛہہ صورت چَھنہٕ ﴾ اَمہِ ورٲے زِ یِہندۍ دِلٕے گٔژھن پارٕہ پارٕہ، اللہ تعالیٰ چُھ سٮ۪ٹھاہ با خبر  بیٚیہِ  حکمت وول ۔ع"
  9,111,"۔ حقیقت چھےٚ یہِ زِ خُدا ین چِھ مو مِنن نِشہِ تِہندۍ نفس تہٕ تِہندۍ  مال جنت کہ بد لہٕ موٚ لۍ ہیٚتۍ مٕتۍ۔﴿ یتھ جایہِ چُھ ایمانُک یہِ معا ملہٕ یُس خُدا یس تہٕ بندس در میان چُھ آسان بَیعس سٍتۍ تعبیر کر نہٕ آمُت۔اَمِیُک معنی چُھ یہِ زِ ایمان چُھ در اصل اکھ معا ہد ہ ییٚمہِ ذریعہ بندٕ ہ چُھ پنُن نفس تہٕ پنُن مال خُدا یس کٕنا ن تہٕ امہِ کِس معا وضس منٛز چُھ اللہ تعالیٰ سٕندِ طر فہٕ سُہ  وعدہ قبو ل کران زِ مَر نہٕ پتہٕ کرِ سُہ تس دوٚیِمہِ زند گی منٛز جنت عطا ﴾ تِم چِھ اللہ تعالیٰ سٕنزِ وَتہِ منٛز لڑان تہٕ مَران، تِمن سٍتۍ چُھ ﴿جنتُک وعدٕہ ﴾ اللہ تعالیٰ سٕندِ ذمہٕ اکھ پختہٕ وعدہ توراتس تہٕ انجیلس تہٕ قرآنس منٛز، بیٚیہِ کُس چُھ یُس اللہ تعالیٰ سٕندِ کھۅتہٕ کھٔسِتھ پَنُن عہد پوٗرٕ کر ن وول آسہِ؟ لہٰذا ،منٲوِو خو شیہِ پننِس تَتھ سودا ہس پٮ۪ٹھ یُس تۅہیہِ خُدا یس نِشہِ چُکو و مُت چُھو، یٔہے چھےٚ سارِ وٕے کھۅتہٕ بٔڈ کا میٲبی۔"
  9,112,"۔ خُدا یس کُن بار بار پھیرن وٲلۍ ،﴿ دراصل چُھ لفظ، التَّا یبُونَ وَر تاو نہٕ آمُت ییٚمیُک لفظی تر جمہٕ  تو بہٕ کر ن وٲلۍ  چُھ۔مگر یتھ کلام کِس اندازس منٛز یہِ لفظ استعمال چُھ کر نہٕ آمُت، تمہِ نِشہِ چُھ صا ف ظٲہر زِ توبہٕ کرُن چُھ اہلِ ایمانن ہٕند یو مستقل صفا تَو منٛزٕ ۔ امہِ موجو ب چُھ اَمِیُک صحیح مفہو م یہِ زِ تِم چِھنہٕ اَکی لٹہِ تو بہٕ کران بلکہ چِھ ہمیشہ تو بہٕ کران روزان۔تہٕ توبُک اصلی معنی چُھ رجوع کرُن تہٕ باز پھیرُن ،لہٰذا چُھ اَسہِ اَمِیُک حقیقی رو ح ظٲہر کر نہٕ خٲطرٕ اَمِیُک تشر یحی تر جمہٕ یِتھہٕ پٲٹھۍ کوٚر مُت  تِم چِھ خُدا یس کُن بار بار پھیران۔ تٔمۍ سٕنز بند گی بجا اَنن وٲلۍ ،تٔمۍ سٕندٮ۪ن تعر یفن ہٕندۍ گۅن گیٚوَن وٲلۍ ،تٔمۍسٕندِ خٲطرٕ زمینس منٛز گر دش کر ن وٲلۍ، ﴿دوٚیُم تر جمہٕ ہیٚکیٚس ٲسِتھروزٕہ تھا و ن وٲلۍ  تہِ ﴾ تس برونٛہہ کنہِ رکو ع تہٕ سجدٕہ کر ن وٲلۍ، نیکی ہُند حُکم دِنہٕ وٲلۍ ، بد ی نِشہِ رُکا و ن وٲلۍ، تہٕ اللہ تعالیٰ سٕندٮ۪ن حدودن ہٕنز حفا ظت کر ن وٲلۍ،﴿اَمہِ شانٕکۍ چِھ آسان تِم مو من یِم خُدا یس سٍتۍ بیع چِھ کران﴾ تہٕ اے نبی صلی اللہ علیہ وسلم ، تِمن مو مِنن دِیو خۅ ش خبر ۔"
  9,113,"۔نبی ﴿صلی اللہ علیہ وسلمس﴾ تہٕ بیٚیہِ تِمن لُکن یِمو ایمان چُھ اوٚ نمُت چُھنہٕ شوٗبان زِ مُشر کن خٲطرٕ کر ن مغفر تُک دُعا، چا ہے تِم کو نہٕ آسن یِمن رشتہٕ دارٕ ے ، ییٚلہِ زن تِمن پٮ۪ٹھ یہِ کتھ ٹا کارٕ چھےٚ، زِ تِم چِھ جہنمٕکۍ حقدار۔"
  9,114,"۔ ابرا ہیم ﴿علیہ السلامن ﴾ یُس دُعا ے مغفرت پننِس مٲلِس کوٚر مُت اوس،سُہ اوس امہِ وعدٕہ کہ وجہ سٍتۍ یُس تٔمۍ پننِس مٲلِس سٍتۍ کوٚر مُت اوس،مگر ییٚلہِ تس پٮ۪ٹھ یہِ کتھ ٹا کارٕ سپٕز زِ تٔمۍ سُند مو ل چُھ اللہ تعالیٰ سُند دشمن، پتہٕ گوٚو سُہ تس نِشہِ بے زار، حق چُھ یہِ ابرا ہیم علیہ السلام اوس سٮ۪ٹھاہ نر م دل تہٕ خُدا یس کھۅژوُن بیٚیہِ بُر دبار انسان ۔"
  9,115,"۔اللہ تعالیٰ سُند چُھنہٕ یہِ طر یقہٕ زِ سُہ کرِ لُکن ہدا یت دِنہٕ پتہٕ بیٚیہِ گمرٲہی منٛز مبتلا، یوٚت تام نہٕ تِمن صا ف صا ف وَنہِ زِ تِمن کَمو چیز و نِشہِ پَزِ بچُن۔ در حقیقت چُھ خُدا یس پرٛتھ چیزُس علم ۔"
  9,116,"۔ پتہٕ چھےٚ حقیقت زِ اللہ تعالیٰ سٕندِ سٕے قبضسس منٛز چھےٚ زمینٕچ تہٕ آسما نن ہٕنز سلطنت، تٔمۍ سٕندِ سٕے اختیارس منٛز چھےٚ زند گی تہٕ موت ،تہٕ کانٛہہ چُھنہٕ تُہُند حٲمی تہٕ مددگار تِیُتھ یُس تۅہیہِ تس نِشہِ بچٲوِتھ ہیکہِ ۔"
  9,117,"۔خُدا ین کوٚر معا ف نبی ﴿ صلی اللہ علیہ وسلمس ﴾ بیٚیہِ تِمن مہا جر ن تہٕ انصارن یِمو سٮ۪ٹھاہ تنگ وقتس منٛز نبی ﴿صلی اللہ علیہ وسلمس ﴾ ساتھ دِیُت، اگر چہِ یِمو منٛزٕ کینژھن ہٕندۍ دِل ہجر س کُن مٲیل ٲسۍ گٔمٕتۍ۔﴿ یعنی کینژھن مخلص صحا بن رضی اللہ عنہم تہِ اوسنہٕ اتھ سخت وقتس منٛز جنگس نیر نس وۅ ندٕ آمُت مگر چو نکہ تِہند ٮ۪ن دِلن منٛز اوس ایمان تہٕ تِم ٲسۍ پزِ دِلہٕ دین حقس سٍتۍ محبت تھاوان،امہِ موجوٗب آے ٲخر کار پننہِ اتھ کمزوٗری پٮ۪ٹھ غٲلب﴾ ﴿مگر ییٚلہِ تِمو اَمہِ ہَجرٕچ اِتبا ع کٔر نہٕ ، بلکہ دِیتُکھ نبی صلی اللہ علیہ وسلمس ساتھ تہٕ ﴾ خُدا ین کوٚر تِمن معا ف ،بے شک چُھ تٔمۍ سُند معا ملہٕ  یِمن لُکن سٍتۍ شفقتُک تہٕ مہر بٲنی ہُند ،"
  9,118,"۔تہٕ تِمن تر شیوٕ نۍ تہِ کوٚر تٔمۍ معا ف  یُہُند معا ملہٕ ملتو ی اوس کر نہٕ آمُت ییٚلہِ زمین پننہِ سار ی وُسعت با وجود تِمن پٮ۪ٹھ تنگ گٔیہِ ،تہٕ تِہِندۍ پنٕنۍ زُو تہِ گۅ بییہِ تِمن تہٕ تِمو زو ن زِ خُدا یس نِشہِ بچنہٕ خٲطرٕ چَھنہٕ کانٛہہ چَھپن جاے،خۅ د اللہ تعالیٰ سٕندِ رحمت کہ دامنہٕ ورٲے تہٕ پتہٕ پھیوٗ ر اللہ تعالیٰ پننہِ مہر بٲنی سان تِمن کُن تاکہ تِم پھیر ن تس کُن واپس، پٔزۍ پٲٹھۍ چُھ سُہ سٮ۪ٹھاہ معا ف کر ن وول تہٕ رحیم ۔ ع ۔ ﴿یِم تر یٚشوَے صا حب ٲسۍ کعب بن مالک رضی اللہ عنہ ہلال بن اُمیہ رضی اللہ عنہ ، تہٕ مُرارہ بن ربیع رضی اللہ عنہ، تر یشو ے ٲسۍ حقیقی مو من ، اَمہِ برونٛہہ اوسُکھ پننہِ اخلا قُک واریاہِہ لٹہِ ثبوت دِتمُت، قر بٲنیہِ آسکھ دِژ مژٕ مگر یِمو خد ماتَو با و جود یۅسہِٕ سُستی یِمَو جنگِ تبو ک کِس نازُک مو قعس پٮ۪ٹھ ہٲو، ییٚلہِ زن تمام قٲبلِ جنگ اہلِ ایمانن جنگس نیر نُک حُکم دِنہٕ اوس آمُت ،تتھ پٮ۪ٹھ آیہِ سخت گر فت کر نہٕ ۔ نبی صلی اللہ علیہ وسلمو دِیُت تبو ک پٮ۪ٹھہٕ واپس تشر یف أنِتھ مسلمانن حُکم زِ کانٛہہ کرِ نہٕ یِمن سٍتۍ سلام کلا م۔ ژتجی دوٚ ہۍ پتہٕ آو یِمن پننیٚن خاندارِ نین نِشہِ الگ روزنُک تٲکید کر نہٕ، فی الو اقع اوس مد ینہٕ چہِ بستی منٛز یُہُند سُے حال سپُد مُت ییٚمِچ تصویر یتھ آیتس منٛز پیش چھےٚ کر نہٕ آمٕژ۔ٲخر کار ییٚلہِ یِہِندِس سو شل با یکا ٹس، 50،دۅ ہ سپٕدۍ تَمہِ پتہٕ سپُد معٲفی ہُند یہِ حُکم نٲزِل۔﴾"
  9,119,"۔ اے لُکو یِمو ایمان چُھ اوٚ نمُت ،خُدا یس کھوٚژِو تہٕ تِمن لُکن دِیِو ساتھ یِم پٔزِ یٲرۍ چِھ ۔ مد ینہٕ کیٚن با شند ن تہٕ أندۍ پٔکۍ کیٚن بدوِی یَن اوس نہٕ ہر گز یہِ شوٗبان"
  9,120,"۔ زِ اللہ تعالیٰ سٕندِس رسول ﴿صلی اللہ علیہ وسلمس﴾ ترٲوِتھ روزٕ ہن گھرِ بِہِتھ تہٕ تِمن نِشہِ بے خبر سپدِ تھ لا گہَن پننہِ پننہِ پانٕچ فکر کرٕنۍ۔ امہِ موجو ب زِ یہِ سپدِ نہٕ زانٛہہ زِ تِم کر ن اللہ تعالیٰ سٕنزِ وَتہِ منٛز بۅ چھہِ ہُند تر یشِ ہُنٛد تہٕ جسمٲنی مشقتُک کانٛہہ تکلیف برداشت،تہٕ حقس انکار کرن والیٚن یۅسہٕ وَتھ نا گوار چھےٚ تتھ پٮ۪ٹھ تُلَن تِم کانٛہہ قد م تہٕ کٲنٛسہِ دشمنس ہیٚن تِم ﴿حق کہ عدا وتُک ﴾ کانٛہہ انتقا م، تہٕ امہِ بد لہٕ کیا یِیہِ نہٕ تِہندِس حقس منٛز اکھ صا لح عمل لیٚکھنہٕ، پٔزۍ پٲٹھۍ چُھنہٕ خُدا یس نِشہِ احسا ن کر ن والیٚن ہٕندِ خد متُک حق ضا یع گژھان۔"
  9,121,"۔یِتھے پٲٹھۍ ہیٚکہِ نہٕ زانٛہہ یِتہِ سپدِتھ زِ تِم کر ن ﴿اللہ تعالیٰ سٕنزِ وَتہِ منٛز ﴾ کم یا زیادہ کانٛہہ خر چہِ تہٕ ﴿سعی تہٕ جہا دس منٛز ﴾ کر ن کانٛہہ وادی عبور ۔تہٕ تِہندِس حقس منٛز کیا یِیہِ نہٕ سۅ لیٚکھنہٕ، تا کہ اللہ تعالیٰ  کرِ تِہندِ امہِ رٕتہِ کار نا مُک بد لہٕ تِمن عطا۔"
  9,122,"۔ تہٕ یہِ اوس نہٕ ضروری کینٛہہ زِ اہلِ ایمان نیرٕ ہَن اند ہیٚتھ سٲری، مگر یہِ کیا زِ سپُد نہٕ زِ تِہنزِ آبادی منٛزٕ یِہَن کینٛہہ لُکھ نیٖرِ تھ تہٕ دینُک فہم کر ہن پٲدٕ، واپس گٔژِھتھ کر ہَن پتہٕ پننہِ علا قہٕ کیٚن با شند ن با خبر ۔ تاکہ تِم کر ہَن ﴿غیر مسلمانہٕ رٔوِشہِ نِشہِ ﴾ پر ہیز ۔ع۔﴿مُراد چُھ یہِ  زِ سارِنٕے بد وِی یَن ہُند مد ینہٕ واتُن اوس نہٕ ضروری۔پرٛتھ بستی تہٕ پرٛتھ علا قہٕ کیو لکو منٛز اگر کینٛہہ لُکھ مد ینہ یِتھ دینُک علم حا صل کرٕ ہن، پتہٕ گژھہَن واپس تہٕ پننہِ علا قہٕ کیٚن لُکن ہیچھنا وٕ ہن دین ، تیٚلہِ روزِ ہے نہٕ بد وی ین منٛز سۅ جہا لت ییٚمہِ کہ وجہ کِنۍ تِم منا فقت چہِ بیمار منٛز مبتلا چِھ تہٕ اسلام قبول کر نہٕ باوجو د چھِنہٕ مسلمان آسنُک حق ادا کران۔﴾"
  9,123,"۔اے لُکو یِمو ایمان چُھو اوٚ نمُت، جنگ کٔرِ و تِمن منکر ینِ حقن سٍتۍ یِم تۅہیہِ نِشہِ چِھ ۔ ﴿یتھ جایہِ چُھ کُفارَو نِشہِ مُراد تِم منا فق لُکھ یُہُند انکارِ حق پوٗرٕ پٲٹھۍ ظٲہر اوس سپُد مُت تہٕ یِہندِ خلط ملط روزنہٕ سٍتۍ اسلٲمی سو سا یٹی سخت نقصان واتان ٲسۍ۔﴾ بیٚیہِ پَزِ  زِ تِم گژھن تۅہیہِ منٛز سختی لَبٕنۍ ،﴿ یعنی سُہ نر م سلو ک گژِھہ ختم سپدُن یُس وُنیستام تِمن سٍتۍ سپدان چُھ روٗدمُت﴾ تہٕ زٲنِتھ تھٲوِ و زِ اللہ تعالیٰ چُھ متقی ین سٍتۍ۔"
  9,124,"۔ییٚلہِ کانٛہہ نوٚ و سورٕہ چُھ نٲزِل سپدان،تہٕ تِمو منٛزٕ چِھ کینٛہہ لُکھ ﴿مذا قہٕ رٔنگۍ مسلمانن ﴾ پٕرٛژھان زِ ؤنِو، تۅہیہِ منٛزٕ کٔمۍ سٕندِس ایمانس منٛز سپُد اَمہِ سٍتۍ اضا فہٕ؟ یِمو لُکو ایمان چُھ اوٚنمُت، تِہندِس ایمانس منٛز چُھ پٔزۍ پٲٹھۍ ﴿پرٛتھ نٲزِل سپدۍ مٕتۍ سوٗرن﴾ اِضا فَے کوٚر مُت،تہٕ تِم چِھ امہِ سٍتۍ دِل شاد،"
  9,125,"۔البتہ یِمن لُکن ہٕندٮ۪ن دِلن ﴿نفا قُک ﴾ مر ض لو گمُت اوس، تِہندِس پرٲنِس نجا ستس پٮ۪ٹھ کوٚر ﴿پرٛتھ نٔوۍ سُو رَن ﴾ بیٚیہِ اکہِ نجا سَتُک اِضا فہٕ تہٕ تِم روٗدۍ مَر نہٕ کِس دمَس تام کُفر سٕے منٛز مبتلا ۔"
  9,126,"۔کیا یِم لُکھ چِھنا وُچھان زِ پرٛتھ ؤرِ یہِ چِھ یِم اکہِ دۅ یہِ پھِرِ آزمٲیشہِ منٛز تراونہٕ یِوان ؟ ﴿یعنی کانٛہہ ؤری چُھنہٕ تِیُتھ گُزر یو مُت ییٚلہِ زن اکہِ دۅ یہِ لٹہِ تِتھۍ حالات آسن نہٕ پیش یِوان ، یِمن منٛز یِہندِ ایمانُک دعویٰ آزمٲیِشہِ ہٕنزِ کہو چہِ پٮ۪ٹھ گکھر او نہٕ آسہِ نہٕ یِوان ، تہٕ امہِ کہ کھۅ چرُک راز آسہِ نہٕ فا ش سپدان۔﴾ مگر اتھ پٮ۪ٹھ تہِ نَہ چھِ تو بہٕ کران، تہٕ نہ چِھ کانٛہہ سبق رٹا ن۔"
  9,127,"۔ ییٚلہِ کانٛہہ سوٗرٕہ چُھ نٲزِل سپدان، تیٚلہِ چِھ یِم لُکھ أچھَو مٔنزی اکھ أکِس سٍتۍ کتھہٕ کران زِ ہے تۅہیہِ ما چُھو کانٛہہ وُچھان ، پتہٕ چِھ ژوٗرِ پٲٹھۍ ژَلا ن ، خُدا ین چِھ یِہِندۍ دِل پھِرِ مٕتۍ۔ تِکیازِ یِم چِھ نا سمجھ لُکھ۔"
  9,128,"۔ وُچھِو ! تۅہیہِ لُکن نِشہِ چُھ اکھ رسول ﴿صلی اللہ علیہ وسلم﴾ آمُت ،یُس خۅد تۅ ہی منٛز چُھ، تُہُند نقصا نس منٛز پیوٚ ن چُھ تس پٮ۪ٹھ شا ق ﴿گوٚ ب ﴾ ، سُہ چُھ تُہنزِ کا میٲبی ہُند حر یص ﴿خو اہشمند﴾، ایمان انَن والیٚن خٲطرٕ چُھ سُہ شفیق تہٕ نہا یت مہر بان۔"
  9,129,"۔وۅ نۍ اگر یِم لُکھ تۅہیہِ نِشہِ بُتھ چِھ پھِرا ن، اے نبی صلی اللہ علیہ وسلم ، تیٚلہِ ؤنِو یِمن زِ  میا نہِ خٲطرٕ چُھ بس اللہ تعالیٰ ، کانٛہہ معبود چُھنہٕ مگر سُہ، تٔسۍ پٮ۪ٹھ کوٚر مےٚ بھر وسہٕ تہٕ سُہ چُھ مٲلک عر شِ عظیمُک۔ ع"
