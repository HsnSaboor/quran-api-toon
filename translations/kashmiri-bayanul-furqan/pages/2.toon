quran[286]{c,v,t}:
  2,1,"الف،لام،میم ﴿یِم حر وفِ مُقطّعا ت چِھ قرآن مجید کیٚن کینٛژھن سوٗرن  ہٕنٛدِس ابتدا ہس منٛز لَبنہٕ یِوان ۔ مُفسرَو چِھ یِہِنٛد ۍ مختلف معنے بیا ن کٔرِ مٕتۍ ، مگر یِہِنٛدِ س کُنہِ معنِیس پٮ۪ٹھ چُھنہٕ اتفا ق تہٕ یُہُنٛد معنی زانُن چُھ اَمہِ مو جو ب غیر ضرور ی زِ اگر انسان یُہُنٛد  معنی زانہِ تہِ نہٕ، قرآن نِشہِ ہدا یت حا صل  کر نس منٛز چَھنہٕ کانٛہہ کسر  روزان﴾"
  2,2,"یہِ چھےٚ اللہ تعالیٰ سٕنٛز کتا ب، یَتھ منٛز چُھنہٕ کانٛہہ شک ﴿اَمیُک اکھ سِیٚو د تہٕ سادٕ ہ مطلب چُھ یہِ  بے شک چھےٚ یہِ اللہ تعالیٰ سٕنٛز کتا ب ۔ مگر بیاکھ مطلب ہیکیٚیس یِتہِ ٲسِتھ زِ یہِ چھےٚ تِژھ کتا ب یتھ منٛز نہٕ شکٕچ کانٛہہ کتھ چھےٚ ﴾۔ ہدا یت چھےٚ تِمن پر ہیز گار لُکن خٲطرٕ۔"
  2,3,"یِم غیبس پٮ۪ٹھ ایمان چِھ اَنان ﴿ غیب چُھ مُراد تِمہٕ سار ے حقیقتہٕ یِمہٕ انسان سٕنٛدِ حوا سہٕ نِشہِ ژھا یہِ چھےٚ تہٕ برا ہِ راست چَھنہٕ عا م انسانن ہٕندِس تجر بس تہٕ مُشٲہدس منٛز یِوان ، مثلاً اللہ تعالیٰ سٕنٛز ذات تہٕ صِفا ت ، ملٲیِک ،وَحی ،جنت ،جہنم بیترِ ﴾  نما ز چِھ قٲیِم کران۔﴿اِقا مت الصلوٰتُک معنی چُھنہٕ صرف یی زِ انسان گژِھہ پا بند ی سان نما ز ادا کرُن، بلکہ چُھ اَمِیُک مطلب یہِ زِ اجتمٲعی طور گژِھہ نمازِ ہُنٛد نظا م با قٲعدٕہ قٲیِم کر نہٕ یُن ، اگر کُنہِ بٔستی منٛز اکھ اکھ نفر بیوٚ ن  بیوٚ ن نماز پرا ن چُھ۔ مگر جمٲعژ سان چُھنہٕ یہِ فر ض ادا کر نُک نظم، تیٚلہِ ہیکہِ نہٕ یہِ وَننہٕ یِتھ زِ تَتہِ چھےٚ نماز قٲیِم کر نہٕ یِوان﴾ یُس رِزق اَسہِ تِمن دِیتمُت چُھ،تمہِ منٛزٕ چِھ خر چ کران۔"
  2,4,"یۅسہٕ کتا ب تۅ ہیہِ پٮ۪ٹھ نٲزِل چھےٚ آمٕژ کر نہٕ ﴿یعنی قرآن ﴾ تہٕ یِمہٕ کتا بہٕ تۅہیہِ برٛونٛہہ نٲزِل آسہِ آمٕژ کر نہٕ تِمن سارِ نٕے پٮٹھ چِھ ایمان اَنان تہٕ ٲخرتس پٮ۪ٹھ چِھ یقین تھاوان۔یِتھۍ لُکھ چِھ پننِس ربّ سٕندِ طر فہٕ سیٚزِ وَتہِ پٮ۪ٹھ"
  2,5,"تہٕ تِمے چِھ کا میٲبی لبن وٲلۍ۔"
  2,6,"یِمو لُکو ﴿ یِمہٕ کتھہٕ ما ننس ﴾ انکار کوٚر تِہندِ خٲطرٕ چُھ یکسا ن خوا (ہھشی کتھ) توٚہۍ تِم خبردار کٔرِ توکھ یا متہٕ کٔرِ توکھ ، بہر حال چِھنہٕ تِم مانن وٲلۍ کینٛہہ۔"
  2,7,"خُدا ین چھےٚ تِہندِٮ۪ن دِلن تہٕ تِہند ٮ۪ن کنن پٮ۪ٹھ مۅ ہر لگٲومٕژ ﴿اَمِیُک مطلب چُھنہٕ یہِ زِ خُدا ین ٲس مۅ ہر لگٲومٕژ، اَمہِ موجوٗب کوٚر تِمو ماننس انکار۔بلکہ چُھ اَمِیُک مطلب یہِ زِ ییٚلہِ تِمو بنیٲدی کتھہٕ رَد کرِ، یِہٕنٛز ذکر پٮ۪ٹھ کنہِ کر نہٕ آیہِ ،تہٕ پننہِ خٲطرٕ کٔرٕکھ قرآن چہِ پیش کر نہٕ آمٕژِ وَتہِ بر عکس بیا کھ وَتھ اختیار ، پَتہٕ لگٲو خُدا ین تِہندٮ۪ن دِلن تہٕ کنن پٮ۪ٹھ مۅ ہر﴾۔تہٕ تِہٕنٛزن أچھن پٮ۪ٹھ چُھ پردٕہ پیٚو مُت، تِم چِھ سخت سزا ہٕکۍ حقدار ۔ع"
  2,8,"کینٛہہ لُکھ چِھ تِم تہِ یِم وَنان چِھ اَسہِ چُھ خُدا یس پٮ۪ٹھ تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان اوٚ نمُت حالانکہ چِھنہٕ تِم حقیقتس منٛز مو من کینٛہہ۔"
  2,9,"تِم چِھ خُدا یس سٍتۍ تہٕ ایمان اَنن والیٚن سٍتۍ دو کھہٕ بٲزی کران، مگر تِم چِھ دراصل پنہٕ نُے پان دوکھس منٛز ترٛا وان تہٕ تِمن چُھنہٕ اَمِیُک شعور ،"
  2,10,"۔تِہندٮ۪ن دِلن منٛز چھےٚ اکھ بیمٲرۍ۔ یۅسہٕ خُدا ین زیادے ہُررٲو ﴿بیمٲرۍ چھےٚ مُراد مُنا فقتٕچ بیمٲرۍ،تہٕ خُدا ین ہُررٲویہِ بیمٲرۍچُھ یہِ معنی تھاوان زِ سُہ چُھنہٕ مُنا فقس فوراً سزا دِوان بلکہ چُھس ڈیٚجر ترٛا وان تہٕ اَمہِ ڈیجرُک نتیجہِ چُھ یہِ آسان زِ مُنا فق چُھ وارٕہ پٲٹھۍ مُنا فق بنا ن ﴾ تہٕ یُس اَپُز تِم وَنان چِھ ،تَمہِ کِس مُعا وضس منٛز چُھ تِہنٛدِ خٲطرٕ دَگ تُلہٕ وُن سزا۔"
  2,11,"۔ ییٚلہِ زانٛہہ تِمن آو وَننہٕ زِ زمینس منٛز مہ کٔرِو فساد تہٕ تِمو ووٚ ن یٖی زِ  أسۍ چِھ اصلا ح کر ن وٲلۍ۔"
  2,12,"۔خبردار ! حقیقتس منٛز چِھ یِمے لُکھ فسٲدۍ ۔مگر تِمن چُھنہٕ شعور۔"
  2,13,"۔تہٕ ییٚلہِ تِمن وَننہٕ آوزِ یِتھہٕ پٲٹھۍ با قی لُکو ایمان چُھ اوٚ نمُت تِتھے پٲٹھۍ أنِو توٚہۍ تہِ ایمان،تورٕ دِیُت تِمو یۅ ہے جواب زِ  کیا أسۍ اَنوٕ ہ بے و قو فن ہٕنٛدۍ پٲٹھۍ ایمان ؟خبردار! حقیقتس منٛز چِھ یِم پانہٕ بے وقوف،مگر یِم چِھنہٕ زانان ۔"
  2,14,"۔ییٚلہِ یِم اہلِ ایمانن سمکھان چِھ ، تیٚلہِ چِھ وَنان اَسہِ چُھ ایمان اوٚ نمُت تہٕ ییٚلہِ خلوَکھ پننیٚن شیطا نن چِھ سمکھان تیٚلہِ چِھ وَنان زِ اصلی چِھ أسۍ تۅہیہِ سٍتۍ تہٕ ہۅ من لُکن چِھ محض مذا ق کران۔"
  2,15,"۔اللہ تعالیٰ چُھ یِمن مذا ق کران سُہ چُھ یِہٕنٛز رَز ڈیٚج تراوان، تہٕ یِم چِھ پننہِ نا فر مٲنی کِنۍ اَنیٚن ہٕنٛد ۍ پٲٹھۍ وَتہِ ڈَلان روزان۔"
  2,16,"۔یِم چِھ تِم لُکھ یِمو ہدا یتہٕ بد لہٕ گُمرٲہی موٚ لۍ ہِیٔژ، مگر یہِ تجا رت چُھنہٕ یِہنٛدِ خٲطرٕ نفع دِنہٕ وول کینٛہہ، تہٕ یِم چِھنہٕ ہر گز صحیح وَتہِ پٮ۪ٹھ۔"
  2,17,"۔یِہنز مِثا ل چھےٚ تِژھ زَنتہٕ أکۍ شخصن نار زو ل ﴿گا شہِ مۅ کھہٕ ﴾ پتہٕ ییٚلہِ تٔمۍ سورُے اوٚ نٛد پوٚک گا شِر وو اَمہِ پتہٕ نِیوٗ خدا ین یِمن ﴿أچھ﴾ گا ش تہٕ یِم ترٛٲوِن تتھ حالس منٛز زِ گٹہٕ زلیٚن منٛز چُھنہٕ یِمن کِہنۍ اَتھہِ یِوان ﴿مطلب چُھ یہِ زِ ییٚلہِ اللہ تعالیٰ سٕنٛدۍ أکۍ بند ن روشنی پھٔہلٲو تہٕ حق کوٚڑُن بٲطلہٕ نِشہِ چھٲنٛٹِتھ با لکل نوٚ ن ،یِم لُکھ گا شدار ٲسۍ تِمن پٮ۪ٹھ گٔیہِ تمام حقیقتہٕ روشن ،مگر یِم منا فق نفس پرستی منٛز أنۍ ٲسۍ گٔمٕتۍ  تِمن اوس نہٕ اَتھ گا شس منٛز کِہنۍ اَتھہِ یِوان﴾"
  2,18,"۔یِم چِھ زٔرۍ ،یِم چِھ کٔلۍ ،یِم چِھ أنۍ ،یِم پھیرن نہٕ وۅ نۍ پوٚت۔"
  2,19,"۔یا سمجھِو یِہٕنز مِثا ل یِتھہٕ پٲٹھۍ زِ آسما نہٕ چُھ زبردس روٗد پیٚوان تہٕ اَتھ سٍتۍ چھےٚ کرٛہِنۍ وُنل تہٕ گگراے تہٕ وُز ملہٕ  تہِ یِم چِھ گگر ایہِ بوٗزِ تھ زُو لرزٕہ پننیٚن کنَن منٛز اوٚ نگجہِ بران تہٕ اللہ تعالیٰ چُھ یِمن حقس انکار کر ن والیٚن پرٛتھ اندٕ گیرس منٛز رٔٹِتھ۔"
  2,20,"۔وُز ملہِ سٍتۍ چھےٚ یِہٕنٛز حا لت یہِ سپدان زنتہٕ نِیہِ یِمن وُنۍ وُزملہٕ أچھ گاش تھَپہِ ،تہٕ ییٚلہِ یِمن رَژھ کھنڈ گاش باسان چھُ  تیٚلہِ چِھ یِم تَتھ منٛز ہَنہ پکا ن تہٕ ییٚلہِ اَنہِ گوٚٹ چُھکھ سپدان، تیٚلہِ چِھ وۅ دٕنۍ روزان ﴿گۅڈنِچ مِثا ل ٲس مُنا فقن ہٕنٛز یِم دِلہٕ کِنۍ مُنکر ٲسۍ تہٕ کُنہِ غر ضہٕ تہٕ مَصلحتہٕ کِنۍ ٲسۍ مسلمان بنیمٕتۍ۔ تہٕ یہِ دوٚ یِم مِثا ل چھےٚ تِہٕنٛز یِم شکس تہٕ دُل مُلِس منٛز ٲسۍ تہٕ یُہُنٛد ایمان کمزور اوس، کینٛہہ ٲسۍ حقٕکۍ قٲیِل تہِ ، مگر تِژِھہ حق پرستی ہٕندۍ قٲیِل ٲسۍ نہٕ زِ اَمہِ خٲطرٕ کرٕ ہَن تکلیف تہٕ مصیبت تہِ برداش﴾اللہ تعالیٰ ہرگاہ ییٚژِھہ ہے، بوز نُک تہٕ وُچھنُک طا قت نِیہِ ہکھ تھپہِ ،پٔزۍ پٲٹھۍ چُھ اللہ تعالیٰ پرٛتھ چیز س پٮ۪ٹھ قدر ت تھاوان۔ع"
  2,21,"۔لوٗکو! بند گی کٔرِ و پننِس تس ربّ سٕنٛز یُس تُہُنٛد تہٕ تۅ ہیہِ برونٛہہ یِم لُکھ ٲسۍ تِمن سارِنٕے ہُنٛد پٲدٕ ہ کر ن وول چُھ ،تُہٕندِ مۅ کلنٕچ امید ہیٚکہِ أتھۍ صوٗرتس منٛز ٲسِتھ ﴿یعنی دُنیا ہس منٛز غلط بینی تہٕ غلط کٲر ی نِشہِ تہٕ ٲخر تس منٛز اللہ تعالیٰ سٕندِ عذا ب نِشہِ مۅ کلنٕچ امید ﴾"
  2,22,"۔سُے چُھ ییٚمۍ تُہندِ خٲطرٕ زمینُک فر ش وَتھر وو آسما نُک پَش بنووُن آسما نہٕ وو لُن آب تہٕ اَمہِ سٍتۍ تھووُن پرٛتھ قسمُک پیدا وار کٔڑِتھ تُہندِ خٲطرٕ رزق فرا ہم وۅ نۍ ییٚلہِ توٚہۍ یہِ زانان چِھو تیٚلہِ مَہ مٲنِیوٗکھ با قی خدا یَس مدِ مقٲبل ﴿با قی خدا یس مدِ مقا بل ماننُک مطلب چُھ بند گی تہٕ عبا دت کیو مختلف قٔسمو منٛزٕ کُنہِ قسمُک طر یقہٕ خدا یس وَرٲے با قین سٍتۍ وَرتاوُن۔﴾"
  2,23,"۔تہٕ اگر تۅہیہِ اَتھ کتھہِ منٛز شک چُھو زِ یہِ کتا ب یوسہٕ اَسہِ پَننِس بند س پٮ۪ٹھ نٲزِل چھےٚ کٔر مٕژ، یہِ چھا سٲنۍ کِنہٕ نہٕ تیٚلہِ أنۍ تَو أتھۍ ہیوٗاَکھ سوٗرٕ ہ بنٲوِ تھ ،پنٕنۍ سٲر ی سٲتھی أنیوٗکھ ،خُدا یس وَرٲے یس یس توٚہۍ مدد چِھو یژھان ہِیوٚن ،تس تس ہیٚیِو اگر توٚہۍ پٔزِ یٲرۍ چِھو تیٚلہِ ہٲوِ تَو یہِ کٲم کٔرِ تھ ۔"
  2,24,"۔وۅ نۍ ہرگاہ تۅہیہِ یہِ ہیوٚ کوٕنہٕ کٔرِ تھ ،تہٕ پٔزۍ پٲٹھۍ ہیٚکِو نہٕ کٔرِتھ،تیٚلہِ کھوٗژِو تتھ نا رس ، ییٚمیُک زالُن بَنن انسان تہٕ کنہِ ﴿یعنی تَتہِ بٔنِو نہٕ توٚ ہی یٲتۍ جہنمُک زالُن ، بلکہ آسن تُہٕندۍ تِم پۅ تٕلۍ تہِ تَتہِ تۅہی سٍتۍ موجوٗد ،یِمن توٚہۍ عبا دت تہٕ سجدٕ ہ چِھو کران ﴾ یُس تیا ر چُھ آمُت تھاو نہٕ حقس انکار کر ن والیٚن خٲطرٕ ۔"
  2,25,"۔تہٕ اے پیغمبر ، یِم لُکھ یتھ کِتا بہِ پٮ۪ٹھ ایمان اَنن تہٕ ﴿یتھ مُطٲبِق کر ن ﴾ پننہِ عملہٕ دُرست تِمن دِیو خۅ ش خبر زِ تِمن خٲطرٕ چِھ تِتھۍ با غ ،یِمن بٔنۍ  کۅ لہٕ آسن پکان، ییٚلہِ تِمن کانٛہہ میوٕ ہ کھیٚنہٕ خٲطرٕ دِنہٕ یِیہِ ،تِم ونَن زِ یِتھی میوٕ ہ ٲسۍ اَسہِ ییٚمہِ برو نٛہہ دُنیا ہس منٛز تہِ دِنہٕ یِوان حالانکہ تِمن باغن ہٕندِۍ میوٕ ہ آسن شکلہِ کِنۍ دُنیا کیٚن میوَن ہِو ۍ تہٕ تِمن خٲطرٕ آسن تَتہِ پا کدا من خاندار نہِ تہٕ تِم روزن ہمیشہ خٲطرٕ تٔتھۍ۔"
  2,26,"۔آ، اللہ تعالیٰ چُھنہٕ ہر گز تہِ اَتھ منٛد چھان زِ سُہ دِیہِ مٔہۍ سٕنٛز یا اَمہِ کھۅتہٕ تہِ ؤسۍ پایہِ چیز ن ہٕنٛزٕ مثالہٕ ﴿ییٚتہِ نس چھُ اکہِ اعترا ضٕچ ذِکر کر نہٕ ورٲے اَمِیُک جوا ب آ مُت دِنہٕ ۔ قرآنس منٛز چھےٚ واریاہن جا ین مُد عا کہِ وضا حت خٲطرٕ زلٕر ۍ سٕنٛز، مچھہِ ہٕنٛز تہٕ مٔہۍ بیترِ سٕنٛزٕ مِثا لہٕ آمژٕ دِنہٕ ، یِمن پٮ۪ٹھ اوس مخٲلفن اعترا ض زِ یہِ کِیُتھ کلامِ الہٰی چُھ یتھ منٛز امہِ قسمہٕ کیٚن ؤسۍ پایہِ چیز ن ہٕنٛزٕ مِثا لہٕ چھےٚ دِنہٕ آمژٕ﴾یِم لُکھ حقٕچ کتھ قبول کر  ن وٲلۍ چِھ تِمن چُھ یِمے مِثا لہٕ وُچِھتھ پے لگان زِ یہِ چُھ حق یُس تِہندِس ربّ سٕندی طر فہٕ آمُت چُھ تہٕ یِم مانن وٲلۍ چِھنہٕ تِم چِھ یِم مِثا لہٕ بوٗزِ تھ وَنان زِ یِژَھو مِثا لو سٍتۍ کیا مقصد چُھ خدا یس ؟ یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ اَکی کتھہِ سٍتۍ واریاہن کران گُمرٲہی منٛز مبتلا تہٕ واریاہن چُھ سِیٔز وَتھ ہاوان تہٕ گُمرٲہی منٛز چُھ سُہ تِمنٕے لُکن مبتلا کران ، یِم فا سق چِھ ﴿فا سق گوٚو نا فر مان، اطا عت کہ حدٕ نِشہِ نیر ن وول ﴾"
  2,27,"۔خُدا یس سٍتۍ چِھ مضبوٗط عہد کر نہٕ پتہٕ سُہ پھُٹراوان ﴿با دشاہ یُس فر مان یا ہدا یات پننیٚن مُلٲزِمن تہٕ لُکن ہٕندِناوٕ جٲر ی چُھ کران، تِم چِھ عر بی زبٲنۍ منٛز عہدس سٍتۍ تعبیر یِوان کر نہٕ۔ اللہ تعالیٰ سُنٛد عہد چُھ سُہ مُستقل فر مان، ییٚمہِ کِنۍ تمام اِنسٲنی زُرِ یا تھ صرِف تٔمۍ سٕنٛزٕ ے بند گی،اطا عت تہٕ پرستش کر نس پٮ۪ٹھ مامو ر چھےٚ۔ مضبو ط عہد کر نہٕ پتہٕ  اَمہِ سٍتۍ چُھ اِرشاد اَتھ کِتھہ کُن زِ آدم علیہ السلام بناو نہٕ وقتہٕ اوس تمام انسانن اَمہِ فر مانٕچ پا بند ی کر نُک اقرار ہیٚنہٕ آمُت۔یِتھہٕ پٲٹھۍ زن سورۂ اعراف،آیت 72 ہَس منٛز بیان چُھ سپُد مُت﴾ خُدا ین یَتھ جور نُک حُکم چُھ دِیتمُت ،تتھ چِھ ژٹان ﴿یعنی یِمن رٲبطن ہٕندِس قیا مس پٮ۪ٹھ تہٕ استحکا مس پٮ۪ٹھ انسان سٕنزِ اجتمٲعی تہٕ اِنفرٲدی کا میٲبی ہُنٛد دار مدار چُھ، تہٕ خُدا ین یِمن ہٕنٛدِ دُرست تھا و نُک حُکم چُھ دِیتمُت ،تِمن پٮ۪ٹھ چِھ یِم  مَکٕژ چلا وان ﴾تہٕ زمینس پٮ۪ٹھ چِھ فساد بر پا کران حقیقتس منٛز چِھ یِمے لُکھ نقصا ن تُلن وٲلۍ۔"
  2,28,"۔توٚہۍ کِتھہٕ پٲٹھۍ چِھو خُدا یس سٍتۍ کُفرُک رٔوِیہِ وَر تاوان حالانکہ توٚہۍ ٲسِو بے جان، تٔمۍ کٔر نَو تۅہیہِ زند گی عطا پتہٕ کرِ سُے تُہُند زُو سلب، پتہٕ کرِ سُے تۅہیہِ نوِ سرٕ زند گی عطا پتہٕ چُھو تۅہیہِ تٔسۍ کُن واپس گژُھن ۔"
  2,29,"۔سُے چُھ، ییٚمۍ تُہندِ خٲطرٕ زمینٕکۍ سٲر ی چیز پٲدٕ ہ کٔر ۍ پتہٕ دِیتُن ہِیوٚ ر کُن تو جہ پتہٕ کٔرِ ن سَتھ آسما ن اُستوار ﴿سَتن آسمانن ہٕنٛز حقیقت کیا چھےٚ ،اَمِیُک تعیّن چُھ مشکل۔ اِنسا ن چُھ پرٛتھ زمانس منٛز آسمان، یا وَنو دوٚ یِمیٚن لفظن منٛز عا لمِ بالا ہس متعلق پننیٚن مُشٲہد ن تہٕ قیا سن مُطٲبق مختلف تصوّر قٲیِم کران روٗدمُت ، یِم برابر بد لان روٗدِ مٕتۍ چِھ۔ بس ژھوٚٹۍ پٲٹھۍ گژِھہ یہِ سمجُھن زِ یا چُھ اَمہِ سٍتۍ مطلب یہِ ،زِ زمینہِ علا وٕہ یِکینٛژھاہ کاینا ت چھےٚ، یہِ چھےٚ خُدا ین ستن محکم طبقن منٛز بٲگرٲومٕژ،نَتہٕ یہِ زِ ، کا ینا ت کِس یتھ حلقس منٛز زمین چھےٚ، سُہ چُھ ستن طبقن پٮ۪ٹھ مشتمل﴾ تہٕ سُہ چُھ پرٛتھ چیزُک علم تھاون وول ۔ ع"
  2,30,"۔پتہٕ کٔرۍ تَو تمہِ وقتُک تصوّر ییٚلہِ تُہٕندۍ ربّن فر شتن ووٚ نمُت اوس زِ بہٕ چُھس زمینس پٮ۪ٹھ اکھ خلیفہٕ بناون وول﴿خلیفہٕ گوٚو سُہ یُس کٲنٛسہِ  ہٕنٛدِس مِلکیتس منٛز تٔمۍ سٕنٛدۍ عطا کر نہٕ آمٕتۍ اختیارات تٔمۍ سٕنٛدِ نٲیبہٕ سٕنٛدِ حیثیتہٕ استعمال کرِ ﴾ تِمو کوٚر عر ض  کیا توٚہۍ چِھو حض زمینس پٮ۪ٹھ کٲنٛسہِ تِتِھس مُقرر کر ن وٲلۍ یُس تمہِ کِس انتظا مَس تلُک پٮ۪ٹھ کرِ تہٕ خو نر یزی کرِ ؟ أسۍ حض تُہٕندِ حمد و ثنا سان تُہٕنزتسبیح تہٕ تُہٕندِ خٲطرٕ تقدیس کرانٕے چِھ  فر مو وُن: بہٕ چُھس زانان ، یِکینژھاہ نہٕ توٚہۍ زانان چِھو ،"
  2,31,"۔اَمہِ پتہٕ ہیٚچھنو و خُدا ین آد م سارِنٕے چیز ن ہٕنٛد ۍ ناو پتہٕ کوٚرُن فر شتن برونٛہہ کنہِ پیش  ،أتی فر مو وُناگر تُہُند خیا ل صحیح چُھ ﴿زِ کانٛہہ خلیفہ مُقرر کٔرِ تھ بِگرِ نِظا م ﴾ ، تیٚلہِ ؤنۍ تَو توٚ ہۍ یِمن چیز ن ہٕندۍ ناو"
  2,32,"۔تِمو کوٚر عر ض، نُقصہٕ نِشہِ چھےٚ پاک تُہُنٛزٕ ے ذا ت ، اَسہِ چُھ بس  تی کینژھاہ علم یِکینٛژھاہ تۅہیہِ اسہِ دِیتمُت چُھو ،در حقیقت چُھنہٕ تۅہیہِ ورٲے کانٛہہ سورُے کینٛہہ زانن وول تہٕ سمجھُن وول"
  2,33,"۔پتہٕ ووٚ ن خُدا ین آد مس :  وَن یِمن ژٕ یِمن چیز ن ہٕندۍ ناو تِمن سارِ نٕے چیز ن ہٕندۍ ناو ییٚلہِ تٔمۍ تِمن ؤنۍ تہٕ خُدا ین فر مو و پتہٕ: مےٚ اوسمَو نا تۅہیہِ ووٚ نمُت زِ بہٕ چُھس آسما نس ہٕنٛزٕ تہٕ زمین چہِ تِمہٕ سار یے حقیقتہٕ زانان یِمہٕ تۅہیہِ نِشہِ ژھا یہِ چھےٚ یِکینٛژھاہ توٚہۍ ظٲہر چِھو کرا ن ، سُتہِ چُھ مےٚ معلو م تہٕ یِکینٛژھاہ توٚہۍ کھٔٹِتھ چِھو تھاوان ،سُتہِ چُھس زانان ۔"
  2,34,"۔پتہٕ ییٚلہِ اَسہِ فر شتن حُکم دِیُت زِ آد مس برونٛہہ کنہِ کٔرِ و سجدٕ ہ ،سٲرِ وٕ یَو کوٚر سجدٕ ہ مگر ابلیسن کوٚر انکار تَس گوٚو پننہِ بَجرُک تکبر تہٕ سُہ سپُدنا فر مانن منٛز شٲمل،"
  2,35,"۔پتہٕ ووٚ ن اَسہِ آد مَس زِ  ژٕ تہٕ چٲنۍ خاندارِ نۍ ، دۅ شو ے روٗزِ و جنّتس منٛز تہٕ اطمینان سان یہِ ییٚژِھو تہِ کھیٚیِو ییٚتہِ ، مگر یتھ کُلس یِیہِ زیٚو نہٕ نکھہٕ نَتہٕ یِیِو ظٲلِمو منٛز گنٛز ر نہٕ ۔"
  2,36,"۔ٲخر کار کٔڑ شیطا نن تِمن دۅ شوٕ نۍ اَتھ کُلِس کُن گژھنٕچ کل تہٕ ڈا لِن سانہِ حُکم چہِ پیر وی نِشہِ تہٕ کڑ نٲوِ ن تِم تمہِ حا لت منٛزٕ یَتھ منٛز تِم ٲسۍ، اَسہِ دِیُت حُکم زِ  وۅ نۍ ؤسِو توٚہۍ سٲر ی ییٚتہِ بۅ ن ، توٚ ہۍ چِھو اکھ أکۍ سٕندۍ دُشمن تہٕ تۅہیہِ چُھو أکِس خا ص وقتس تام زمینس پٮ۪ٹھ ٹھہرُن تہٕ تٔتھۍ چُھو گُزر بسر کرُن ۔"
  2,37,"۔تمہِ وقتہٕ کوٚر آد من پننِس ربّس نِشہِ کینٛہہ کلمات ہیٚچھِتھ تو بہٕ یُس تٔمۍ سٕندۍ ربّن قبول کوٚر ۔ تِکیازِ سُہ چُھ سٮ۪ٹھاہ معا ف کر ن وول تہٕ رحم کر ن وول۔"
  2,38,"۔اَسہِ ووٚ ن زِ  توٚہۍ سٲر ی ؤسِو ییٚتہِ بۅ ن  پتہٕ یُس میانہِ طر فہٕ کانٛہہ ہدا یت تۅہیہِ تام واتہِ تہٕ یِم لُکھ میٲنِس تَتھ ہدا یتس پٮ۪ٹھ عمل کر ن تِہنٛدِ خٲطرٕ آسہِ نہٕ کُنہِ خو فٕچ تہٕ غمٕچ گُنجٲیش۔"
  2,39,"۔تہٕ یِم لُکھ اتھ مانٕنَس انکار کر ن تہٕ سا نیٚن آیا تن پھِرن بُتھ تِم چِھ نارس گژھن وٲلۍ لُکھ، ییٚتہِ تِم ہمیشہ روزَ ن ۔ع"
  2,40,"۔اے بنی اسرا یل ! یاد کٔرۍ تَو میٲنۍ سۅ نعمت یۅسہٕ مےٚ تۅہیہِ عطا ٲسمَو کٔر مٕژ ﴿ مد ینہٕ طیّبہ تہٕ اَتھ أندۍ پٔکۍ کیٚن علا قن منٛز اوس یہو دٮ۪ن ہُنٛد اکھ بوٚڈ تعداد بسان، اَمہِ مو جو ب چُھ ییٚتہِ پٮ۪ٹھہٕ برونٛٹھ کُن کینٛژھن رکو عن تام یِمن تبلیغ کر نہٕ آمُت ﴾ مےٚ سٍتۍ یُس تُہُنٛد عہد اوس سُہ کٔرِ و توٚہۍ پوٗرٕ ، تہٕ یُس میو ن عہد تۅہیہِ سٍتۍ اوس سُہ کرٕ بہٕ پوٗرٕ تہٕ میے یوت کھوٗژِو توٚہۍ۔"
  2,41,"۔تہٕ مےٚ یۅسہٕ کتاب سوٗز مٕژ چھےٚ اتھ پٮ۪ٹھ أنِو ایمان یہِ چھےٚ تمہِ کِتا بہِ ہٕنٛدِ س تٲییدَس منٛز یۅسہٕ تۅہیہِ نِشہِ گۅڈٕ ہ پٮ۪ٹھہٕ موجوٗد ٲس، لہٰذا مَہ بٔنِو سارَنٕے برونٛہہ گۅڈٕہ توٚہی اَمِکۍ مُنکر، کم قٍمتس پٮ۪ٹھ مہ کٔنِو میٲنۍ آیات ﴿کم قٍمتہٕ نِشہِ چُھ مُراد تِم دُنیٲوی فٲیدٕ ہ یِمَو مۅ کھہٕ یِم لُکھ اللہ تعالیٰ سٕنٛد ۍ احکام تہٕ ہدا یات رَد کران ٲسۍ۔حق کٕننہٕ کِس معا ملس منٛز رٔٹۍ تَن انسان دُنیا ہٕچ سٲرِ سٕے دولت تہِ ، بہر حال چُھ سُہ کمٕے   قٍمت تِکیازِ حق چُھ یقیناً اَمہِ نِشہِ واریاہ گوٚ ب چیز ﴾ تہٕ میانہِ غضبہٕ نِشہِ بٔچِو ۔"
  2,42,"۔حق مَہ بنٲوِیوٗن بٲطلُک رنگ کھٲلِتھ شکہٕ لد تہٕ زٲنِتھ مٲنِتھ مہ کٔرِ و حق چُھپا ونٕچ کوٗشش نماز کٔرِ و قٲیِم ، زکوٰتہ دِیِو،"
  2,43,"۔ تہٕ یِم لُکھ مےٚ برونٛہہ کنہِ نمان چِھ تِمن سٍتۍ نٔمِو توٚہۍ تہِ۔"
  2,44,"۔با قَین چِھو توٚہۍ نیکی ہٕنٛز وَتھ اختیار کر نہٕ خٲطرٕ وَنان مگر پنُن پان چُھو مٔشِتھ گژھان؟ حالانکہ چِھو توٚہۍ کتا بہِ ہٕنٛز تلا و ت کرا ن، کیا توٚہۍ چِھو نَہ عقلہِ بِلکُلٕے کٲم ہیٚوان؟"
  2,45,"۔صبرس تہٕ نمازِ ہیٚیِو  مدد بے شک چھےٚ نماز اکھ سخت مُشکل کٲم، مگر تِمن فر مان بردار بند ن خٲطرٕ چَھنہٕ مُشکل کینٛہہ،"
  2,46,"۔ یِم سمجھان چِھ زِ ٲخر کار چُھ تِمن پننِس ربّس سٍتۍ ملا قات کرُن، تہٕ تٔسۍ کُن چُھکھ پوٚت پھیٖرِ تھ گژُھن۔"
  2,47,"۔ اے بنی اسرا یل ! یاد کٔرِ و میٲنۍ سۅ نعمت یۅسہٕ مےٚ تۅہیہِ عطا ٲسمو کٔر مٕژ تہٕ یہِ کتھ تہِ زِ مےٚ ٲسمَو تۅہیہِ دُنیا کیٚن سارِنٕے قو من پٮ۪ٹھ فضیلت عطا کٔر مٕژ ﴿اَمِیُک مطلب چُھنہٕ یہِ زِ ہمیشہ خٲطرٕ ٲسِو توٚہۍ دُنیا کیو قو مَو کھۅتہٕ افضل قرار دِنہٕ آمٕتۍ بلکہ چُھ مطلب یہِ زِ اَکھ وقت اوس ییٚلہِ دُنیا کیو قو مَو منٛزٕ توٚہی سُہ قو م ٲسِو یَس نِشہِ اللہ تعالیٰ سُنٛد دِیتمُت علمِ حق اوس تہٕ یُس عا لمہٕ کیٚن قو من ہُنٛد امام تہٕ رہنما اوس بناو نہٕ آمُت ، تا کہ سُہ پکنا وِ ہے لُکن ناد دِتھ ربّ سٕنٛزِ بند گی ہٕنزِ وَتہِ پٮ۪ٹھ ﴾"
  2,48,"۔تہٕ کھوٗژِو تَتھ دو ہس ییٚلہِ کانٛہہ کٲنسہِ رَژھ تہِ بکار یِیہِ نہٕ نَہ سپدِ کٲنسہِ ہٕندِ طرفہٕ سُفٲرش قبو ل نہ یِیہِ کانٛہہ فِد یہِ رٔٹِتھ یلہٕ تراونہٕ، تہٕ نہ ہیٚکہِ مُجرِ من کُنہِ کِنۍ مدد میٖلِتھ۔"
  2,49,"یاد کٔرِ وسُہ وقت ،ییٚلہِ اَسہِ تۅہیہِ فر عو نی یَن ہٕنٛزِ غلا می نِشہِ نجات بخُش ﴿ آلِ فر عو نُک  تر جمہٕ چُھفر عو نی کر نہٕ آمُت۔اَتھ منٛز چِھ فر عو نن ہٕنٛدۍ خاندان تہٕ مصرُک حکمران طبقہٕ دۅ شو ے شٲمل﴾ تِمو ٲسۍ ہَو توٚہۍ سخت عذا بَس منٛز مبتلا کٔرِ مٕتۍ تُہٕنٛدٮ۪ن لڑ کن ٲسۍ ذبح کران تہٕ تُہٕنٛز ن کوریٚن ٲسۍ زندٕہ روزنہٕ دِوان تہٕ اَتھ حالتس منٛز ٲس تُہندِس ربّ سٕندِ طر فہٕ تۅہیہِ بٔڑا زما یش۔"
  2,50,"۔یاد کٔرِ و سُہ وقت ،ییٚلہِ اَسہِ سمندر پھا سوِ تھ تُہٕنٛدِ خٲطرٕ وَتھ بنٲو، پتہٕ تٲرِو توٚہۍ اَمہِ مٔنٛز ۍ حفا ظت سان اَپو ر ، پتہٕ پھا ٹوٕ ۍ فر عو نی تٔتی تُہٕنٛز ن أچھن برٛونٛہہ کنہِ آبَس۔"
  2,51,"۔یاد کٔرِو ، ییٚلہِ اَسہِ مو سیٰ علیہ السلام ژتجہن دۅ ہَن رٲژن ہٕندِس قرار دادس پٮ۪ٹھ طلب کوٚر ﴿مِصرٕ نِشہِ نجا ت لَبنہٕ پتہٕ ییٚلہِ بنی اسرا یل جز یرہ نما ے سینا ہس منٛز وٲتۍ ،اَمہِ پتہٕ کٔرۍ خدا ین حضرت موسیٰ علیہ السلام ژتجہن دۅ ہن رٲژن خٲطرٕ کوہِ طورس پٮ۪ٹھ طلب تا کہ تَتہِ یِہَن اَمہِ قو مہٕ خٲطرٕ یُس وۅ نۍ آزاد اوس سپُد مُت، شر یعتٕکۍ قا نو ن تہٕ عملی زند گی ہٕندۍ ہدا یات عطا کر نہٕ﴾ تہٕ تس پٔتۍ کِنۍ بَنو وٗن ووٚژھ تۅہیہِ پنُن معبود تمہِ وقتہٕ ٲسٕو تۅہیہِ بٔڈ زیادتی کٔر مٕژ ،"
  2,52,"۔مگر اَتھ پٮ۪ٹھ تہِ دِژٕ و اَسہِ تۅہیہِ معٲفی،زِ شا ید مَا بٔنِو توٚہۍ وۅ نۍ شُکر گزار ۔"
  2,53,"۔یاد کٔرِو زِ ﴿ٹھیک تَمہِ وقتہٕ ییٚلہِ توٚہۍ یہِ ظُلم ٲسِو کران ﴾ اَسہِ کٔر مو سیٰ ﴿علیہ السلامس﴾ کتا ب تہٕ فُر قان عطا تا کہِ توٚہۍ ہیٚکِو اَمہِ سٍتۍ سِیٔز وَتھ حا صل کٔرِ تھ ۔﴿فُر قا ن گوٚو سُہ چیز ییٚمہِ سٍتۍ حقٕچ تہٕ بٲطلٕچ فر ق ظٲہر سپدِ۔ ییٚتہِ نَس چُھ فُر قا ن مُراد دینُک سُہ علم تہٕ فہم، ییٚمہِ سٍتۍ انسان حقس تہٕ بٲطلَس منٛز فر ق چُھ کران ۔ ﴾"
  2,54,"۔یاد کٔرِو ییٚلہِ موسیٰ ﴿علیہ السلامن یہِ نعمت ہیٚتھ واپس یِتھ ﴾ پننِس قو مَس ووٚ ن زِ ، لوٗکَو ، تۅہیہِ کوٚرُو پا نس پٮ۪ٹھ سخت ظُلم، ووٚژھ بنو وُن پنُن معبود لہٰذا کٔرِو توٚہۍ پننِس خٲلقس برٛو نٛہہ کنہِ تو بہٕ تہٕ پنٕنۍ زُو کٔرِیوٗکھ قتل ﴿یعنی پنٕنۍ تِم نفر کٔرِ یوٗکھ قتل، یِمو ووٚژھ معبود بنو و تہٕ تس کٔرٕکھ پوٗزا﴾ أتھۍ منٛز چھےٚ تُہٕندِ س خٲلِقس نز دیک تُہٕنٛز پا پر جٲہی۔ تمہِ وقتہٕ کوٚر تُہٕنٛدۍ خٲلِقن تُہُند تو بہٕ قبو ل تِکیازِ سُہ چُھ سٮ۪ٹھاہ معا ف کر ن وول تہٕ رحم فر ماو ن وول ۔"
  2,55,"۔یاد کٔرِ و ییٚلہِ تۅہیہِ موسیٰ ﴿علیہ السلامس﴾ اوسُو ووٚ نمُت زِ أسۍ کَرَو نہٕ چا نہِ کتھہِ پٮ۪ٹھ ہر گز تہِ پژھ یوٚت تام نہٕ پننیٚو أچھو نَنہِ وانہِ اللہ تعالیٰ ﴿ژےٚ سٍتۍ کلامہٕ کران ﴾ وُچھو ن تمہِ ساعتہٕ رٔٹِنو توٚہۍ وُچھان وُچھان اکہِ زبردس ترٛ ٹہِ ،توٚہۍ ٲسِو موٗدِ مٕتۍ ، مگر اَسہِ کٔرِو توٚہۍ بیٚیہِ زِندٕہ،"
  2,56,"۔شاید کہ امہِ احسا نہٕ پتہٕ بٔنِو توٚہۍ شُکر گُزار ۔"
  2,57,"۔ اَسہِ کوٚر تۅہیہِ پٮ۪ٹھ اوٚ برُک سایہِ ، منّ و سلویٰ ہُک غٕذا کوٚر تُہٕنٛدِ خٲطرٕ فرا ہم تہٕ اَسہِ ووٚ نُو تۅہیہِ یِم پا ک چیز اَسہِ تۅہیہِ عطا چِھ کٔرِ مٕتۍ ،تِم کھیٚیِو، ﴿مگر تُہٕنٛدِ یٚو اَسلافَو یِکینٛژھاہ کوٚر ﴾ سُہ اوس نہٕ اَسہِ پٮ۪ٹھ ظُلم بلکہ کوٚرُکھ پٲنۍ پانس پٮ۪ٹھ ظُلم ۔"
  2,58,"۔پتہٕ کٔرِویاد زِ ییٚلہ، اَسہِ ووٚ نمُت اوس زِ یہ بستی  ﴿یۅسہٕ تۅہیہِ برونٛہہ کنہِ چھےٚ ﴿ اَتھ منٛز سپدِو دٲخٕل اَمِیُک پیداوار، یِتھہٕ پٲٹھۍ ییٚژِھو، مزٕہ سان کھیٚیِو مگر بٔستی ہٕندِس دروازَس أژۍ زِ یٚو سجدٕ کران کران تہٕ ؤنۍ زیٚو حِطَّتہَ حِطَّتہَ   ﴿اَتھ ہیٚکن زٕ ہ مطلب ٲسِتھ ،اکھ یہِ زِ پننیٚن خطا ہَن معٲفی منگان منگان أژۍ زیٚو ، دوٚ یُم یہِ زِ لوٗٹ مار تہٕ قتلِ عام بجا یہِ گٔژھۍ زیٚو بٔستی ہٕندٮ۪ن روزَ ن والیٚن در گُزر تہٕ عام معٲفی ہُنٛد اعلا ن کران کران پکان﴾ أسۍ کرَو تُہٕندۍ خطا در گُزر تہٕ نیکو کار ن کرَو مزید فضل و کرَم عطا"
  2,59,"۔ مگر یۅسہٕ کتھ تِمن وَننہٕ ٲس آمٕژ، سو بد لٲوِ تھ کوٚر ظٲلِمو بیٚیہِ کیا تام ٲخر کار کوٚر اسہِ ظُلم کر ن والیٚن اَسمانہٕ پٮ۪ٹھہٕ عذا ب نٲزِل یہِ اوس سزا تِمن نا فر مٲنِیَن ہُنٛد یِمہٕ تِم کران ٲسۍ ۔ ع"
  2,60,"۔یاد کٔرِ و ییٚلہِ مو سیٰ ﴿علیہ السلامن ﴾ پننہِ قو مہٕ خٲطرٕ آبُک دعا کوٚر ، اَسہِ ووٚ نُس زِ فلٲنۍ پَلس پٮ۪ٹھ لا ے پننہِ عا صہٕ سٍتۍ ژٔنڈ، چنا نچہِ تمہِ منٛزٕ درٛا ے باہ ناگ تہٕ پرٛتھ قبیلن زو ن زِ کۅ سہٕ جا ے چھےٚ تٔمۍ سٕنٛز آب نِنہٕ خٲطرٕ ﴿بنی اسرا یلٕکۍ قبیلہٕ ٲسۍ باہ ﴿12﴾ خُدا ین کوٚڈ پرٛتھ قبیلہٕ خٲطرٕ اکھ اکھ نا گ تا کہ تِمن گٔژھ نہٕ پانہٕ وٲنۍ آبس پٮ۪ٹھ لڑٲے وۅ تھٕنۍ ، تمہِ وقتہٕ اوس یہِ ہدا یت دِنہٕ آمُت زِ ﴾ اللہ تعالیٰ سُنٛد دِیتمُت رِز ق کھیٚیِو چیٚیِو تہٕ زمینس پٮ۪ٹھ مَہ پٔکِو فساد پھٔہلاوان۔"
  2,61,"۔یاد کٔرِ و ، ییٚلہِ تۅہیہِ اوسُو ووٚ نمُت زِ  اے موسیٰ ! أسۍ ہیٚکَو نہٕ اَکی قٔسمہٕ کِس کھیٚنس پٮ۪ٹھ صبر کٔرِ تھ پننِس ربّس منگتہٕ دُعا زِ سا نہِ خٲطرٕ کرِ ہے زمینٕکۍ پیداوار،ہاکھ، ترکٲرۍ، کٕنٕک، رۅ ہن ،گنڈٕہ،دال بیتر پٲدٕ ہ اَتھ پٮ۪ٹھ ووٚ ننکھ موسیٰ ﴿علیہ السلامن﴾: کیا اکہ بہتر چیزٕ بجا یہِ چِھوٕ ہ توٚہۍ اد نیٰ در جِکۍ چیز رٹٕنۍ یژھان؟ٹھیک چُھ، گٔژِھو کُنہِ شٔہر ۍ آبٲدی منٛز روٗزِ و ، یِکینٛژھاہ توٚہۍ منگان چِھو، تَتہِ میلیٚو تہِ۔ ٲخر کار وٲژ نو بت اوٚ ت تام زِ ذلت تہٕ خوٲر ی ،پستی تہٕ بد حٲلی سپٕز تِمن پٮ۪ٹھ مُسلط تہٕ تِم آے اللہ تعالیٰ سٕندِس غضبس منٛز ہیٚنہٕ ،یہِ نتیجہِ اوس  تِہنٛزن نا فر مٲنِیَن ہُنٛد تہٕ امہِ کتھہِ ہُنٛد زِ تِم ٲسۍ شر ح کیو حدَو نِشہِ نیٖرۍ نیٖرۍ گژھان۔ع"
  2,62,"۔پژھ کٔرِو زِ نبی عر بی ﴿صلی اللہ علیہ وسلمس ﴾ مانن وٲلۍ ٲسِتن یا یہوٗدۍ ،عیسٲے ٲسِتن یا صا بی تہٕ یُس تہِ خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان اَنہِ تہٕ نیک عمل کرِ تٔمۍ سُنٛد اَجر چُھ تٔمۍ سٕندِس ربّس نِشہِ تہٕ تس خٲطرٕ چُھنہٕ کُنہِ قسمُک خو ف تہٕ رنج ﴿عبا رتُک سِلسلہٕ دَر نظر تھٲوِ تھ چھےٚ یہِ کتھ پٲنۍ پانے وا ضح گژھان زِ یَتھ جایہِ چُھنہٕ ایمان تہٕ نیک عملن ہُنٛد تفصیل وَنُن مقصد کینٛہہ زِ کمن کمن کتھن گژِھہ انسان مانُن تہٕ کمہٕ کمہٕ عملہٕ کٔرِ تھ بَنہِ سُہ خُدا یس برونٛہہ کنہِ اَجرُک حقدار،یَتھ جایہِ چھُ مقصد یہوٗدٮ۪ن ہٕندِس تتھ خام خیالس تردید کرُن زِ تِم ٲسۍ صرف یہودٮ۪ن ہٕنزِ جمٲعژ نجاتُک اِجا رٕ ہ دار سمجھان ۔ تِم ٲسۍ اَتھ خا م خیا لس منٛز زِ تِہنٛزِ جمٲعژ سٍتۍ یَس تہِ کٲنٛسہِ واٹھ چُھ، خواہ سُہ ٲسِتن عملن تہٕ عقید ن ہٕندِ لحا ظہٕ کِیُتھ تہِ ، بہر حال چُھ نجات تٔمِس تقدیرس ،تہٕ با قی تمام انسان یِم تِہٕنزِ جمٲعژ نیٚبر چِھ ، تِم چِھ صرِف جہنمُک زالُن بننہِ خٲطرٕ پٲدٕ سپٕدۍ مٕتۍ۔ یہِ غلط فہمی دوٗر کر نہٕ خٲطرٕ چُھ فر ماو نہٕ یِوان زِ خُدا یس برونٛہہ کنہِ چُھنہٕ اصٕل چیز تُہٕنزٕ یِمہٕ جمٲعژ بٔندِیہِ ،بلکہ یتھ کتھہِ پٮ۪ٹھ تَتہِ دار مدار چُھ، سُہ چُھ ایمان تہٕ نیک عمل۔ یُس تہِ انسان یہِ چیز ہیٚتھ حٲضر سپدِ ، سُہ کرِ پننِس ربّس نِشہِ پنُن اَجر حٲصل ۔ خُدا یس برونٛہہ کنہِ سپدِ فٲصلہٕ انسان سٕندٮ۪ن صِفا تن پٮ۪ٹھ نَہ کہ تُہنٛزن مر د م شمٲری ہٕنٛز ن رجسڑ ن پٮ۪ٹھ ﴾"
  2,63,"۔یاد کٔرِو سُہ وقت، ییٚلہِ تۅہیہِ پٮ۪ٹھہٕ طور تھوٚد تُلِتھ اَسہِ تۅہیہِ پختہٕ عہد اوسُو ہیوٚتمُت تہٕ وونمُت اوسُو زِ یۅسہٕ کِتا ب أسۍ تۅہیہِ دِوان چِھو اَتھ کٔرۍ زیٚو  مضبو طی سان تھپھ تہٕ یِم احکام تہٕ ہدایت اَتھ منٛز درٕج چِھ تِم تھٲوِ زیٚو یاد ،اَمی سٍتۍ یِیہِ تو قع تھاو نہٕ زِ توٚہۍ ہیٚکِو تقویٰ چہِ رٔوِشہِ پٮ۪ٹھ پٔکِتھ"
  2,64,"۔مگر اَمہِ پتہٕ پھیٖرِ و توٚہۍ پننہِ عہدٕ نِشہِ ،اَتھ پٮ۪ٹھ تہِ ترٛوو نہٕ اللہ تعالیٰ سٕندۍ فضلن تہٕ تٔمۍ سٕندۍ رحمتن تُہُند ساتھ کینٛہہ ،نَتہٕ ٲسۍ ہِو توٚہۍ خبر کر تبا ہ سپٕدمٕتۍ۔"
  2,65,"۔اَمہِ پتہٕ چُھو تۅہیہِ پننہِ قو م کیٚن تِمن لُکن ہُنٛد سُہ قصّہٕ یادٕے ،یِمو  سبتُک قا نو ن پُھٹر وو مُت اوس ﴿ سَبت: یعنی بٹہٕ وارِ ہُنٛد دۅ ہ۔ بنی اسرا یلن خٲطرٕ اوس یہِ قا نو ن آمُت مُقرر کر نہٕ زِ تِم تھٲوِ ن بٹہٕ وار آرا م تہٕ عبادتٕ خٲطرٕ مخصو ص۔اَمہِ دۅ ہ مہ کٔرِ ن کُنہِ قسمٕچ دُنیٲوی کٲم ،حتیٰ کہ غذ ا رَنہٕ نٕچ کٲم تہِ مہ کٔرِ ن پانہٕ ، نَہ مہ کر نٲوِن نو کر ن اَتھ ﴾ اَسہِ  ووٚ ن تِمن وَاندَر بٔنِو تہٕ روٗزِ و اَتھ حا لتس منٛز زِ پرٛتھ اَندٕ ہ گژِھہ تۅہیہِ لعنت ملا مت کر نہٕ یِنۍ،"
  2,66,"۔ یِتھہٕ پٲٹھۍ بنو و اَسہِ تِہُند انجام تمہِ زمانہٕ کیٚن لُکن تہٕ  اَمہِ پتہٕ یِنہٕ والیٚن نٔسلن خٲطرٕ عبر ت تہٕ کھۅژ ن والیٚن خٲطرٕ بنو و نصیحت۔"
  2,67,"۔پتہٕ کٔرۍ تَو سُہ وا قعہ یاد، ییٚلہِ موسیٰ ﴿علیہ السلامن﴾ پننِس قو مس ووٚن زِ در حقیقت چُھو اللہ تعالیٰ تۅہیہِ اکھ گاو ذبح کرنُک حُکم دِوان، وَننہِ لٔگۍ کیا ژٕ چُھکھہٕ اَسہِ مذا ق کران؟ موسیٰ ﴿علیہ السلامن﴾ ووٚ ن ﴿تِمن ﴾ : بہٕ چُھس تمہِ نِشہِ اللہ تعالیٰ سُنٛد پنا ہ منگان زِ بہٕ کرٕ جٲہلن ہٕنٛزٕ ہِشہِ کتھہٕ ،"
  2,68,"۔تِمَو ووٚ ن ٹھیک چُھ، پننِس ربّس کر تہٕ در خوا ست زِ سُہ ؤنِن اَسہِ تَس گاوِ ہُنٛد کینٛہہ تفصیل، موسیٰ ﴿علیہ السلامن﴾  وون﴿تِمن ﴾ ، اللہ تعالیٰ سُنٛد چُھ ارشاد زِ سۅ گژِھہ تِژھہ گاو آسٕنۍ یۅسہٕ نَہ بُڈٕ ہ آسہِ تہٕ نہ آسہِ وَژٕھر بلکہ گژِھہ در میانہٕ وٲنٛسہِ ہٕنٛز آسٕنۍ لہٰذا یُس حُکم دِنہٕ چُھ یِوان تَتھ کٔرِ و تعمیل،"
  2,69,"۔پتہٕ لٔگۍ وَننہِ ،پننِس ربّس پٕرٛژھ بیٚیہِ یہِ کتھ زِ تس کِیُتھ رنگ گژِھ آسُن موسیٰ  ﴿ السلامن﴾ ووٚ ننکھ ، سُہ چُھ فر ماوان لیٚدِرنگٕچ گاو گژِھہ آسٕنۍ ییٚمۍ سُنٛد رنگ تِیُتھ نَپہٕ نَپہٕ کروُن آسہِ زِ وُچَھن وٲلۍ گژھن خۅش گژٕھنۍ ،"
  2,70,"۔پتہٕ ووٚ نُکھ، ربّس پٕرٛژِھتھ وَن صا ف صا ف کِژھ گاو گژِھہ آسٕنۍ ، اَسہِ چُھ تٔمۍ سُنٛد اندازٕہ کر نَس منٛز گُما نہٕ گوٚ مُت خُدا ین ہر گاہ یوٚژھ، أسۍ لَبَو تٔمۍ سُنٛد نیب ،"
  2,71,"۔موسیٰ ﴿علیہ السلامن﴾ دِیُت ﴿تِمن﴾ جوا ب : اللہ تعالیٰ چُھ ونان سۅ چھےٚ تِژھ گاو یَس خد مت چَھنہٕ یِوان ہیٚنہٕ، نَہ چھےٚ زمین وایان نَہ چھےٚ آب کھا لنس لَمان، صحیح سلامت تہٕ بےٚ دا غ چھےٚ ،اَتھ پٮ۪ٹھ دِژ تِمو کرٛیکھ زِ آ، وۅ نۍ ووٚ نُتھ ژےٚ ٹھیک نیب، پتہٕ کٔر تِمو سۅ ذبح نَتہٕ اوس نہٕ با سان زِ تِم کر ہَن یہِ ۔ع ﴿چو نکہ بنی اسرا یلن اوس اہلِ مصر وتہٕ پننیٚو ہمسایہِ قو مَو نِشہِ گاوِ ہٕنٛدِ عزمتُک تہٕ گٲو پرستی ہُنٛد مر ض لار یٚو مُت، تہٕ أتھۍ بنیا دس پٮ۪ٹھ اوس تِمَو مصرٕ منٛزٕ نیرِۍ تھٕے ووٚژھ بنو و مُت پنُن معبود۔اَمہِ موجوٗب آو تِمن حُکم دِنہٕ زِ گاو کٔرِ ن ذبح ۔ تِمَو کٔر کتھ ڈالنٕچ کوٗشش تہٕ لٔگۍ تفصیلا ت پٕرٛژھنہِ ۔ مگر یٖتۍ یٖتۍ تفصیل تِم پرٛژھان گٔے تیٖتۍ تیٖتۍ گٔے تِم گِران ، ٲخر کار وٲژکتھ اَتھ حدس تام زِ تٔسۍ خا ص قسمٕچہِ سۅ نۂرۍ گاوِ پٮ۪ٹھ، یۅسہٕ تَتھ زمانس منٛز پوٗزا یہِ خٲطرٕ مُشکَس ٲس یِوان تھاو نہٕ، آو زَنتہٕ اُنگٕج پٮ۪ٹھ تھٲوِ تھ وَننہٕ زِ أمِس کٔرِ و کھش﴾"
  2,72,"۔تہٕ ژےٚ چُھیہِ یاد سُہ وا قعہ ییٚلہِ ژےٚ اَکھ شخص اوستھَن قتل کوٚر مُت، پتہٕ لاجَو اَتھ  پٮ۪ٹھ لڑایہِ تہٕ أکِس پٮ۪ٹھ ٲسِو قتلُک اِلزا م کھا لنہٕ لٔگۍ مٕتۍ تہٕ خُدا ین اوس فٲصلہٕ کوٚر مُت زِ یِکینٛژھاہ توٚہۍ چُھپا وان چِھو ، تتھ کڑِ نوٚ ن ۔"
  2,73,"۔تمہِ وقتہٕ دِیُت اَسہِ حُکم زِ مقتو ل سٕنٛزِ لا شہِ لگٲوِ و أمۍ سٕندِ اکہِ حصّہٕ سٍتۍ ژٔنڈ ،وُچِھو یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ مۅرد ن زند گی بخشا ن تہٕ تۅہیہِ چُھو پننہِ نِشٲنیہِ ہاوان تا کہِ توٚہۍ سمجھِو۔"
  2,74,"۔مگر یِژٕھہ نشٲنیہِ وُچھنہٕ پتہٕ تہِ سپٕدۍ ٲخر کار تُہٕنٛدۍ دِل سخت کنیٚن ہٕندۍ پٲٹھۍ سخت، بلکہِ یِہٕنزِ سختی کھۅتہٕ تہِ زیادٕہ سخت تِکیازِ کنیٚو منٛز چھےٚ کانٛہہ تِژھ کٔنۍ تہِ آسان ییٚمہِ منٛزٕ نا گ چِھ نیران، کانٛہہ چھےٚ پھٹا ن تہٕ اَمہِ منٛزٕ چُھ آب نیران تہٕ کانٛہہ چھےٚ اللہ تعالیٰ سٕنٛدِ خو فٕ سٍتۍ لرزِ تھ ؤسۍ تہِ پیٚوان، اللہ تعالیٰ چُھنہٕ تُہُندِ یٚو کر توٗ تَو نِشہِ بےٚ خبر کینٛہہ ۔"
  2,75,"۔اے مسلمانو، کیا توٚہۍ چِھوٕ ہ وۅ نۍ یِمن لُکن نِشہِ یہِ تو قع تھاوان زِ یِم اَنن تُہندِس دعوتس پٮ۪ٹھ ایمان ﴿یہِ خطا ب چُھ مد ینہٕ کیٚن تِمن نویٚن مُسلمانن کُن یِمو تازٕہ تاز ے نبی صلی اللہ علیہ وسلمس پٮ۪ٹھ ایمان اوس اوٚ نمُت ۔یِمہٕ کتھہٕ یِمہٕ تِمن نبوّتس ،کتا بہِ ، ملٲیکن، ٲخرتس ،شر یعتس بیترِ متعلق کنَن گٔیہِ ، تِمہٕ سار یے آسہٕ تِمو پننیٚن یہوٗدۍ ہمسا ینٕے نِشہِ بوزٕ مژٕ۔ تِمن اوس وۅ نۍ تو قع زِ یِم لُکھ گۅڈ ے انبیا ہن ہٕنٛدۍ تہٕ آسمٲنۍ کتا بن ہٕندی پیر و کار چِھ تہٕ یِہٕنٛز و دِنہٕ آمٕژ و خبروٕ ے کِنۍ اَسہِ ایمانٕچ دو لت حٲصل سپٕز مٕژ چھےٚ، تِم دِن ضروٗر اَسہِ ساتھ، بلکہ نیر ن تِم اَتھ وَتہِ منٛز برونٛہہ برونٛہہ ﴾ حالانکہ یِمو منٛزٕ چُھ أکِس فر یق سُنٛد طر یقہٕ یہِ روٗد مُت زِ اللہ تعالیٰ سُنٛد کلام بوٗزِ تھ تہٕ یہِ سمجھِتھ کوٚرُکھ پتہٕ زٲنِتھ مٲنِتھ اَتھ منٛز تحر یف ﴿بد لووُکھ ﴾"
  2,76,"۔﴿محمد رسول اللہ صلی اللہ علیہ وسلمس﴾ پٮ۪ٹھ ایمان اَنن والیٚن چِھ سمکھان، تَمہِ وِزِ چِھ ونان أسۍ تہِ چِھکھ تِم صلی اللہ علیہ وسلم مانان۔پتہٕ ییٚلہِ پانہٕ وٲنۍ اکھ أکِس سٍتۍ چِھ خلو کھ پٲٹھۍ کتھ با تھ کران تَمہِ ساعتہٕ چِھ ونان، عقل چَھو رٲو مٕژ؟ یِمن لُکن چِھو تِمہٕ کتھہٕ وَنان یِمہٕ خدا ین تۅہیہِ پٮ۪ٹھ ظٲہر چھےٚ کرِ مژٕ تا کہِ تُہنٛدِ س ربّس نِشہِ کرن تِمہٕ ﴿کتھہٕ﴾ تۅہیہِ خلا ف حُجّت رٔنگۍ پیش؟ تیٚلہِ کیا زِ چِھو نہٕ عقلہِ کٲم پیٚوان ۔"
  2,77,"۔ کیا یِمن چَھنا پے زِ یِکینٛژھاہ یِم چُھپا وان چِھ تہٕ یِکینٛژھا ظٲہر کران چِھ ، خدا یس چھےٚ سارِ نٕے کتھَن ہٕنٛز پے ؟"
  2,78,"۔یِمن منٛز چھےٚ بیٚاکھ اکھ جما عت اُمیّن ہٕنٛز ،یِمن کِتا بہِ ہُنٛد علمٕے چُھنہٕ بس پننہِ بے بُنیا د اُمید تہٕ خوٲہِشہِ ہیٚتھ چِھ بِہِتھ تہٕ محض چِھ وَہمہٕ گُما نس پٮ۪ٹھ پکا ن روزان ،"
  2,79,"۔اَدٕ ہ ہلا کت تہٕ تبٲہی چھےٚ تِمن لُکن خٲطرٕ یِم پننیٚو اَتھو شر عُک تحر یر ﴿کتا ب ﴾ چِھ لیٚکھا ن پتہٕ چِھ لُکن وَنان زِ یہ چُھ اللہ تعالیٰ سٕنٛدِ طر فہٕ آمُت تا کہِ امہِ کِس مُعا وضس منٛز کر ن کم کینٛژھاہ فٲیدٕ ہ حٲصل، تِہِنٛدِ اَتُھک یہِ لیٚو کھمُت تہِ چُھ تِہِنٛدِ خٲطرٕ تبٲہی ہُنٛد سا مانہٕ  تہٕ تِہٕنٛز یہِ کمٲ ے تہِ چھےٚ تِہِنٛدِ خٲطرٕ ہلا کتُک بٲعث ،"
  2,80,"۔تِم چِھ وَنان زِ نار چُھوِ نہٕ ﴿اَتھہٕ لاگنہِ ﴾ اَسہِ ہر گز تہِ ،البتہ کینٛژھن دۅ ہن ہے سزا میلہِ تہِ  میٖلۍ تن، یِمن پٕرٛژِھتَو ، کیا تۅہیہِ چُھوٕ ہ خُدا یس کانٛہہ عہد ہِیوٚتمُت ییٚمہِ وعدٕچ سُہ خلا ف وَرز ی ہیٚکہِ نہٕ کٔرِ تھ ؟ کِنہٕ کتھ چھےٚ یہِ زِ توٚہۍ چِھو اللہ تعالیٰ سٕندِ ذِمہٕ تِژٕھہ کتھ وَنان یِمن متعلق نہٕ تۅ ہیہِ علم چُھو زِ تٔمۍ چُھ یِمن ﴿ کتھن ﴾ ہُنٛد ذِمہٕ ہیوٚتمُت ؟"
  2,81,"۔ٲخر کیا زِ چُھوِنہٕ تۅہیہِ جہنمُک نار؟ یُس تہِ بٔدی کما وِ تہٕ پننہِ خطا کٲر ی ہٕنٛدِ چکرس منٛز روزِ  سُہ چُھ جہمنی تہٕ جہنم سٕے منٛز روزِ سُہ ہمیشہ،"
  2,82,"۔ تہٕ یِم لُکھ ایمان اَنن تہٕ نیک عملہٕ کر ن تِمے چِھ  جنتی تہٕ جنتس منٛز روزن تِم ہمیشہ۔ع"
  2,83,"۔ یاد کٔرِو اسرا یل سٕنٛد ٮ۪ن اولاد ن اوس اَسہِ پختہٕ عہد ہیٛوٚتمُت زِ خُدا یس ور ٲے کٔرۍ زیٚو نہٕ کٲنٛسہِ ہٕنٛز عبا دت، مٲلِس ما جہِ سٍتۍ کٔرۍ زیٚو نیک سلو ک، بیٚیہِ رشتہٕ دار ن سٍتۍ ، یتیٖمن تہٕ مِسکینن سٍتۍ ل،ُکن ؤنۍ زیٚو رٕژکتھ نماز کٔرۍ زیٚو قٲ یِم تہٕ زکوٰتہ دِی زیٚو مگر کینٛژھو نَفر و وَرٲے پھیٖرِ و توٚہۍ سٲر ی اَمہِ عہدٕ نِشہِ تہٕ وُنِیستا م چِھو پھیٖرِ تھٕے ۔"
  2,84,"۔پتہٕ کٔرۍ تَو یا د، اَسہِ اوسُو تۅہیہِ مضبوٗط عہد ہیوٚتمُت زِ پانہٕ وٲنۍ بہٲوۍ زیٚو نہٕ اکھ أکۍ سُنٛد خو ن تہٕ نہ کٔرۍ زِیو ن پانہٕ وٲنۍ کانٛہہ گھرٕ نِشہِ بےٚ گھر تۅہیہِ  اوسُو اَمِیُک اقرار کوٚر مُت تہٕ توٚہۍ چھِو پانہٕ اَتھ پٮ۪ٹھ گواہ۔"
  2,85,"۔ مگر اَز چِھو توٚہی تِم زِ پانہٕ وٲنۍ چِھو اکھ أکِس قتل کرا ن پننہِ برادر ی ہٕنٛدۍ کینٛہہ لُکھ چھوکھ بےٚ گھر کرا ن ظُلم وزیادتی سان چِھو یِمن خلا ف دَڑ بٔندِ یہِ کرا ن تہٕ ییٚلہِ تِم لڑا یہِ  منٛز رَٹنہٕ آمٕتۍ تۅہیہِ نِشہِ چِھ یِوان ،تمہِ ساعتہٕ چِھو رہٲیی خٲطرٕ فدِ یُک لین دین کر ان حا لانکہ تِم تِہندیٚو گھر و منٛزٕ کڑ نُے  اوس گۅڈے تۅہیہِ پٮ۪ٹھ حرا م۔ کیا تیٚلہِ چِھوٕ ہ توٚہۍ کتا بہِ ہٕنٛدِ س أکِس حصّس پٮ۪ٹھ ایمان اَنان تہٕ دوٚ یِمَس حصّس سٍتۍ چِھو کُفر کران ،پتہٕ یِم لُکھ تۅہیہِ منٛزٕ یہِ  کر ن ، تُہِند سزا کیا چُھ امہِ ور ٲے زِ دُنیا چہِ زند گی روزن تِم ذلیل و خوا ر سپدِ تھ تہٕ ٲخرتس منٛز یِن شدید تر ین عذا بس کُن پھِر نہٕ؟ اللہ تعالیٰ چُھنہٕ تِمو حر کتو نِشہِ بےٚ خبر یِمہٕ توٚہۍ کرا ن چِھو ،"
  2,86,"۔یِم چِھ تِم لُکھ یِمو ٲخر ت کٕنِتھ دُنیا ہٕچ زند گی چھےٚ موٚ لۍ ہِیٔژ مٕژ, لہٰذا نَہ ہیٚکہِ یِہندِ س سزا ہس منٛز کانٛہہ کمی سپدِ تھ تہٕ نہ ہیٚکہِ یِمن کانٛہہ مدد وٲتِتھ۔ع"
  2,87,"۔اَسہِ دِژ موسیٰ ﴿علیہ السلامس﴾ کتا ب اَمہِ پتہٕ سوٗزۍ پوٚتُس پتھ پیغمبر ٲخر کار سوٗز عیسیٰ ابنِ مر یم علیہ السلام روشن نِشٲنِیہِ دِ تھ تہٕ روحِ پاک سٍتۍ کوٚر تس مدد ﴿روحِ پاک  نِشہِ چُھ مراد وحی ہُنٛد علم تہِ ، تہٕ جبر ٖل علیہ السلام تہِ یِم و حی ہُنٛد علم اَنان ٲسۍ ، تہٕ بذا تِ خۅد حضر ت مسیح علیہ السلامن ہُنٛد پنُن  پٲکیزٕ ہ رو ح تہِ یُس خُدا ین قُدّسی صفات بنو و مُت اوس﴾ پتہٕ کُس طر یقہٕ چُھ یہِ تُہُنٛد زِ ییٚلہِ تہِ کانٛہہ پیغمبر تُہٕنٛزن نفسی خوٲہِشن خلا ف کانٛہہ چیز ہیٚتھ تۅہیہِ نِش آو ، تیٚلہِ کٔرٕ و تۅہیہِ تٔمۍ سٕنٛدِس مُقا بلس منٛز نا فر مٲنی یٲژ ،کانسہِ کوٚرُو انکار تہٕ کانٛہہ کوٚرُن قتل !۔"
  2,88,"۔تِم چِھ وَنان ،سٲنۍ دِل چِھ محفوظ  ،نَہ ، اصلی کتھ چھےٚ یہِ زِ تِہندِ کُفرٕ کِنۍ چُھ تِمن اللہ تعالیٰ سٕنٛدِ طر فہٕ پھٹکار ووٚ تھمُت ، امہِ موجوٗب چِھ تِم کمٕے ایمان اَنان ۔"
  2,89,"۔تہٕ وۅ نۍ یۅسہٕ کتا ب اللہ تعالیٰ سٕنٛدِ طر فہٕ تِمن نِشہِ آمٕژ چھےٚ ،تتھ سٍتۍ کیا چُھ تِہُند بر تا و ؟ حا لانکہ سۅ چھےٚ تتھ کتا بہِ تصد یق کرا ن یۅسہِ تِمن نِشہِ گۅڈٕ ہ پٮ۪ٹھ موجوٗد ٲس اَمہِ با و جود ٲسۍ تِم امہِ کہ یِنہٕ برونٛہہ پانہٕ کُفار ن خلا ف فتح تہٕ کا میٲبی ہٕنٛدۍ دُعا منگان ﴿نبی صلی اللہ علیہ وسلمن﴾ ہٕنٛدِ تشر یف اَننہٕ برونٛہہ ٲسۍ یہوٗدۍ بے صبر ی سان تس پیغمبر س انتظا رس ییٚمۍ سٕندِ بعث چہِ پیشن گوٗییہِ تِہنٛد یٚو انبیا ہَو آسہٕ کرِ مژٕ تہٕ تِم ٲسۍ دُعا منگان زِ سُہ پیغمبر گوٚژھ جلد ی یُن ، کُفا ر ن ہُنٛد غلبہٕ مِٹہے    تہٕ سانہِ عر و جُک دور گژِھہ ہے شروع۔﴾ مگر ییٚلہِ سُہ چیز آو ، یُس تِمو پرٛزٕنو و تہِ ، پتہٕ کوٚر تِمو اَتھ ماننہٕ نِشہِ انکار، اللہ تعالیٰ سٕنٛز لعنت چھےٚ یِمن انکار کر ن والیٚن پٮ۪ٹھ ،"
  2,90,"۔کِیُتھ بُرٕ ہ ذر یعہِ چُھ ییٚمہِ سٍتۍ یِم پننہِ نفسُک تسلی چِھ حٲصل کران ﴿ امہِ آیتُک دوٚیُم تر جمہٕ ہیٚکہِ یِتہِ ٲسِتھ : کِیُتھ بُرہٕ چیز چُھ، ییٚمہِ خٲطرٕ یِمو پنٕنۍ نفس کٕنۍ  ، یعنی پنٕنۍ کا میٲبی ، سعادت تہٕ پنُن نجا ت کوٚرُکھ قر بان ۔﴾  زِ یُس ہدا یت خُدا ین نٲزِل چُھ کوٚر مُت ، اَتھ چِھ صرف اَتھ ضدس پٮ۪ٹھ قبو ل کر نہٕ نِشہِ انکار کران زِ خدا ین یُس بندٕ ہ پننہِ فضلہٕ ﴿وَحی تہٕ رسا لت ﴾سٍتۍ پانہٕ یوٚژھ سُہ کوٚرُن مالامال ﴿یِم لُکھ ٲسۍ یژھان زِ یِنہٕ وول پیغمبر گوٚژھ یِہِنٛدی قو مہٕ منٛز پٲدٕ ہ سپدُن۔مگر ییٚلہِ سُہ أکِس دوٚیِمَس قو مس منٛز زاو یَتھ تِم پا نس مُقا بلہٕ ؤسۍ پایہِ سمجھان ٲسۍ ،تِم سپٕدۍ تس انکار کر نس پٮ۪ٹھ آمادٕہ۔ گویا تِہُند مطلب اوس یہِ زِ خُدا یس پَزِ ہے تِمن پٕرٛژِھتھ پیغمبر سوزُن۔﴾ لہٰذا چِھ یِم وۅ نۍ حقدار بنیمٕتۍ زِ یِمن گژِھہ یُن غضبس پٮ۪ٹھ غضب کر نہٕ ، تہٕ یِتھیٚن کٲفر ن خٲطرٕ چُھ سخت رُسوا کر ن وول عذا ب مقرر۔"
  2,91,"۔ ییٚلہِ تِمن وَننہٕ چُھ یِوان زِ یِکینٛژھاہ خُدا ین نٲزِل چُھ کوٚر مُت تتھ پٮ۪ٹھ أنِو ایمان تورٕ چِھ تِم وَنان أسۍ چِھ صرِف تَتھ چیز س پٮ۪ٹھ ایمان اَنان، یُس اَسہِ ﴿بنی اسرا یلن ﴾ پٮ۪ٹھ نٲزِل چُھ گوٚ مُت  اَمہِ دٲیرٕ ہ نیٚبر یِکینٛژھاہ آمُت چُھ ، تتھ چِھ تِم ماننس انکار کران حالانکہ سُہ چُھ حق تہٕ تَتھ تعلیمہِ چُھ تصد یق تہٕ تٲیید کران یۅسہٕ تِمن نِشہِ گۅڈے موجو د ٲس، اَچھا ، یِمن ؤنِو : اگر توٚہۍ تٔتھۍ تعلیمہِ پٮ۪ٹھ ایمان تھاون وٲلۍ چِھو یۅسہٕ تۅہیہِ نِشہِ آمٕژ ٲس ، تیٚلہِ ؤنۍ تَو اللہ تعالیٰ سٕنٛدۍ تِم پیغمبر یِم ﴿خۅد بنی اسرا یلس منٛز زامٕتۍ ٲسۍ﴾ کیازِ روٗدِ یوٗکھ قتل کران؟"
  2,92,"۔مو سیٰ علیہ السلام کمہٕ کمہٕ روشن نِشٲنیہِ ہیٚتھ آو تۅہیہِ نِش اَمہِ پتہٕ تہِ ٲسِو توٚہۍ تِتھۍ ظٲلِم زِ تس پتے بنو وٗن ووٚژھ معبوٗد ۔"
  2,93,"۔پتہٕ کٔرۍ تَو سُہ میثا ق یاد ، یُس تۅہیہِ پٮ۪ٹھ طوٗر تھوٚد تُلنہٕ پتہٕ اَسہِ تۅہیہِ ہیٛوٚمُت اوسُو، اَسہِ اوس تٲکید کوٚر مُت زِ یِم ہدا یت أسۍ دِوان چِھ ، تِہٕنز کٔرِو سختی سان پا بند ی تہٕ کن دٲرِ تھ بوٗزِ و ، تُہند یٚو اَسلا فَو ووٚ ن زِ اَسہِ بوٗزِ ، مگر مانَو نہٕ کینٛہہ تہٕ تِہنٛزِ بٲطِل پرستی ہُنٛد حال اوس یہِ زِ تِہندٮ۪ن دِلن منٛز اوس ووٚژُھے بسیٚو مُت، ؤنیوٗکھ : اگر توٚہۍ مو من چِھو ، تیٚلہِ چُھ یہِ عجیب ایمان ، یُس تۅہیہِ یژِھن بُرٕ ہ حر کتن ہُنٛد حُکم چُھو دِوان ۔"
  2,94,"۔یِمن ؤنِو زِ اگر پٔزۍ پٲٹھۍ خُدا یس نز دیک ٲخر تُک گھرٕ تمام اِنسان ترٛ ٲوِتھ صِر ف تُہٕندی خٲطرٕ مخصوٗص چُھ تیٚلہِ پز یٚو تۅہیہِ مو تُک تمنا کرُن اگر توٚہۍ پننِس اتھ خیا لس منٛز  پٔزِیٲرۍ چِھو ،"
  2,95,"۔پَژھ کٔرِ و یِم کر ن نہٕ زانٛہہ اَمِیُک تمنا  تِکیازِ یِمَو یِکینژھا ہ پننیو اَتھو کمٲوِتھ چُھ تور سوٗز مُت ،تمَیُک تقا ضہٕ چُھ یی ﴿زِ یِم کر ن نہٕ تور گژھنُک تمنا ﴾ اللہ تعالیٰ چُھ یِمن ظٲلِمن ہٕندِ حالہٕ نِشہِ ٹھیک پٲٹھۍ وٲقف"
  2,96,"۔توٚہۍ لٔبِیوٗکھ یِم سارِوٕے کھۅتہٕ زیادٕہ زِندٕ ہ روزنٕکۍ لا لچی حتیٰ کہِ یِم چِھ اَتھ معا ملس منٛز مُشرِ کو کھۅتہٕ تہِ کھٔسۍ تھٕے،  یِمو منٛز چُھ اکھ اکھ شخٕص یہِ یژھان زِ کُنہِ پٲٹھۍ گوٚژھ سا سس ؤرِ یس زِ ند ہ روزُن حالانکہ زیٖٹھ وٲنٛس ہیٚکہِ نہٕ تس عذا ب نِشہِ دوٗر نِتھ،ییٚمہِ قسمٕکۍ اعما ل یِم کران چِھ، اللہ تعالیٰ چُھ بہر حال تِمن وُچھان۔ع"
  2,97,"۔یِمن ؤنِو یَس تہِ کٲنٛسہِ جبر یل ﴿علیہ السلامس﴾ سٍتۍ عداوت چُھ ﴿یہوٗدۍ ٲسۍ نہٕ صرِ ف نبی صلی اللہ علیہ وسلمس تہٕ تِمن پٮ۪ٹھ ایمان اَنن والہِ نٕے یوت بد رَووَنان ، بلکہ ٲسۍ اللہ تعالیٰ سٕندِ س بر گُزیدٕ ہ فرشتہٕ جبر یل علیہ السلامس تہِ لیٚکہٕ ژاران ،تہٕ وَنان ٲسۍ زِ سُہ چُھ سو ن دُشمن۔ سُہ چُھنہٕ رحمتُک فر شتہٕ بلکہ چُھ عذا بُک فر شتہٕ ﴾ تس گژِھہ پے آسٕنۍ زِ جبر یل ﴿علیہ السلامن ﴾ چُھ اللہ تعالیٰ سٕندی حُکمہٕ سٍتۍ یہِ قرآن تُہٕندِس دِلس پٮ۪ٹھ نٲزِل کوٚر مُت یُس تِمن کتا بن ہُنٛد تصد یق تہٕ تٲیید چُھ کران یِمہٕ گۅڈ ے چھےٚ سوزنہٕ آمژٕ تہٕ ایمان اَنن  وا لیٚن خٲطرٕ چُھ ہدا یت تہٕ کامیٲبی ہٕنٛز بشا رت بٔنِتھ آمُت،"
  2,98,"۔﴿اگر جبر یل علیہ السلامس سٍتۍ یِہندٕ عداوتُک وجہ یۅ ہے چُھ، ؤنِو تیٚلہِ زِ ﴾یِم اللہ تعالیٰ سٕنٛدۍ تہٕ تٔمۍ سٕندٮ۪ن فر شتن تہٕ تٔمۍ سٕندٮ۪ن پیغمبر ن تہٕ جبر یل علیہ السلام  تہٕ میکا یل علیہ السلام سٕند ۍ دُشمن چِھ اللہ تعالیٰ چُھ تِمن کٲفر ن ہُنٛد دُشمن۔"
  2,99,"۔ اَسہِ چِھ تۅہیہِ کُن تِتھۍ آیات نٲزِل کٔر مٕتۍ یِم صا ف صا ف چِھ حقُک اظہار کر ن وٲلۍ تہٕ یِہٕنٛزِ پیروی نِشہِ چِھ تِمے لُکھ انکار کران یِم فا سق چِھ"
  2,100,"۔کیا یہِ چُھنا  ہمیشہ  پٮ۪ٹھہٕ سپدان روٗد مُت زِ ییٚلہِ تِمو کانٛہہ عہد کوٚر ، کٲنٛسہِ نَتہٕ کٲنٛسہِ دٔرۍ تھو و تِمو منٛزٕ ضروٗر سُہ بالاے طا ق؟ بلکہِ چِھ یِمو منٛزٕ اکثر یِتھی ،یِم پزِ دِلہٕ ایمان چِھنہٕ اَنان ۔"
  2,101,"۔تہٕ ییٚلہِ تِمن نِشہِ اللہ تعالیٰ  سٕنٛدِ طر فہٕ کانٛہہ رسول تمہِ کتا بہِ ہُنٛد تصد یق تہٕ تٲیید کران آو یۅسہٕ تِمن نِشہِ گۅڈٕ پٮ۪ٹھہٕ موجوٗد ٲس، یِمو اہلِ کتا بو منٛز ترٛٲو أکۍ دٔرۍ اللہ تعالیٰ سٕنٛز کتا ب تِتھہٕ پٲٹھۍ پسِ پُشت زَنتہٕ تِم کینٛہہ زانانٕے ٲسۍ نہٕ۔"
  2,102,"۔تہٕ لٔگۍ تِمن چیز ن ہٕنٛز پیروی کر نہِ ،یِمن شیطا ن ، سُلیمان ﴿علیہ السلامن﴾ ہٕندِ سلطنتُک ناو ہیٚتھ پیش کرا ن ٲسۍ حالانکہ سُلیمان ﴿علیہ السلامن﴾ اوس نہٕ زانٛہہ تہِ کُفر کوٚر مُت، کُفر ٲسۍ تِم شیطا ن کران یِم لُکن جا دوٗد گر ی ہٕنٛز تعلیم ٲسۍ دِوان، تِم لٔگۍ تتھ چیز س پتہٕ یُس با بِلس منٛز دۅ ن فر شتن ، ہارُو تس پٮ۪ٹھ نٲزِل اوس آمُت کر نہٕ حالانکہ تِم﴿  فر شتہٕ ﴾ ییٚلہِ تہِ کٲنٛسہِ اَمِچ تعلیم دِوان ٲسۍ، تیٚلہِ ٲسۍ صا ف پٲٹھۍ گۅڈ ے خبردار کران زِ وُچھ، أسۍ چِھی محض اکھ اَز مٲیش ، ژٕ مَہ گژھ کُفر س منٛز مبتلا ﴿یتھ آیتس متعلق چِھ واریاہ قو ل ، مگر یِکینٛژھاہ مےٚ سمجھمُت چُھ، سُہ چُھ یہِ زِ یَتھ زمانس منٛز سورُے بنی اسرا یل قو مِ با بلس منٛز قٍدۍ تہٕ غلام بٔنِتھ اوس ،خُدا ین آسن انسٲنۍ شکلہِ منز یِمن نِشہِ آز مٲیشہِ خٲطرٕ زٕہ فر شتہٕ سوٗزِ مٕتۍ ۔ یِتھہٕ پٲٹھۍ قومِ لو طس نِشہِ فر شتہٕ ٲسۍ خوبصورت لڑ کن ہٕنٛزِ شکلہِ منٛز گٔمٕتۍ، تِتھے پٲٹھۍ آسن یِمن اسرا یلی لُکن نِشہِ تِم پیٖر ن تہٕ فقیر ن ہٕنٛز شکلہِ منٛز گٔمٕتۍ ،تَتہِ آسہِ تِمو اکہِ طر فہٕ سٲحر ی با زرُک جٲد ۍ وان لگو و مُت تہٕ دوٚ یِمہِ طر فہٕ آسہَن تِم حُجّت اَندوَاتنا و نہٕ خٲطرٕ پرتھ أکِس خبردار کران زِ ، ہے وُچھِوزِأسۍ چھِ تُہٕندِ خٲطرٕ ازمٲیشہِ ہٕنز حیثیت تھاوان ،توٚہۍ مَہ کٔرِو پنُن ٲخرت خراب،مگر اَمہِ باوجود آسہن لُکھ یِہندٮ۪ن پیش کر نہٕ آمٕتیٚن عملیا تن ، نقشن تہٕ تعویز ن پتہٕ لاران۔﴾ اَمہِ پتہٕ تہِ ٲسۍ یِم لُکھ تِمن نِشہِ سُہ چیز ہیٚچھان، ییٚمہِ سٍتۍ خاندارس تہٕ خاندارِنہِ منٛز جدٲیۍ ہیٚکہَن کٔرِ تھ یہِ کتھ ٲس وا ضح زِ اللہ تعالیٰ سٕنٛدِ اِذ نہٕ ورٲے ہیٚکہٕ ہَن نہٕ تِم امہِ سٍتۍ کٲنٛسہِ تہِ نقصا ن واتنٲوِ تھ ،امہِ با وجو د ٲسۍ تِم تیُتھ چیز ہیٚچھان یُس خۅد تِہنٛدِ خٲطرٕ فٲیدٕ مند اوس نہٕ ، بلکہ اوس نقصا ن دہ تہٕ تِمن اوس وارٕ ہ پٲٹھۍ معلو م زِ یُس امہِ چیزُک خریدار بنیٚا و تٔمۍ سٕندِ خٲطرٕ چُھنہٕ ٲخرتس منٛز کانٛہہ حصہٕ ،کٲژاہ بُرٕ ہ لالٕچ ٲس ییٚمہِ بد لہٕ تِمو پنٕنۍ نفس کٕنۍ ،کا ش تِمن آسہِ ہے پَے!"
  2,103,"۔اگر تِم تقویٰ تہٕ ایمان اختیار کرٕ ہن تیٚلہِ یِکینژھا اَمِیُک بد لہٕ خُدا یس نِشہِ میلہِ ہے ، سُہ اوس تِہنٛدِ خٲطرٕ زیادہ بہتر کاش تِمن آسہِ ہے خبر ۔ ع"
  2,104,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت مَہ ٲسِو وَنان ، رٰعِنا، بلکہ ٲسِو وَنان ، اُنظُر نا تہٕ تو جہ سان بوٗزِو کتھ ﴿یہوٗدۍ ییٚلہِ نبی اکر م صلی اللہ علیہ وسلمن ہٕنزِ مجلسہِ منٛز یِہَن تِم ٲسۍ پننہِ سلامہِ تہٕ کلامس منٛز پرتھ ممکن طریقہ پننہِ دِلُک بخار یژھان کڑُن۔ییٚلہِ نبی اکرم صلی اللہ علیہ وسلمن ہٕندِس گفتگووَس  دورا ن یہوٗدٮ۪ن کُنہِ وقتہٕ یہِ وَنٕنچ ضرورت پیش یِیہِ ہے زِ ٹھہرِ و  اَسہِ دِیِو یہِ کتھ سمجھنہٕ ، تیٚلہِ وَنہَن تِم راعنا۔ اَمہِ لفظُک ظٲہر ی مفہو م اوس یہِ زِ  اَسہِ کٔرِ تَو ہنا رعا یت  یا سٲنۍ کتھ بوٗزۍ تَو ۔ مگر اتھ منٛز ٲسۍ بیٚیہِ تہِ کینژھو پا سَو بُرٕ ہ معنی تہِ نیران ۔ اَمہِ موجو ب آو مُسلمانن حُکم دِنہٕ زِ توٚہۍ کٔرِ و یہِ لفظ استعمال کر نہٕ نِشہِ پر ہیز تہٕ اَتھ بجا یہِ ٲسِو  اُنظُر  نَا  وَنان ۔یعنی اَسہِ کُن فر مٲوِ تَو تو جہ یا اَسہِ دِیہِ تَو ذرا سمجھنہٕ ۔ ﴾ یِم کٲفر چِھ دگ تُلوٕ نہِ عذا بٕکۍ حقدار،"
  2,105,"۔یِم لُکھ یِمو دعوت حق قبو ل کر نہٕ نِشہِ انکار کوٚر مُت چُھ خوا ہِ اہل، کتا بَو منٛزٕ ٲسِتن یا مُشرِ ک ٲسِتن یِم چِھنہٕ ہر گز یہِ پسند کران زِ تُہٕنٛدِس ربّ سٕنٛدِ طر فہٕ گژِھ  تۅہیہِ پٮ۪ٹھ کانٛہہ رٕژَر نٲزِل سپدُن مگر اللہ تعالیٰ یَس یژھان چُھ، تَس چُھ پننہِ رحمت خٲطرٕ ژاران تہٕ سُہ چُھ سٮ۪ٹھاہ فضٕل کر ن وول ۔"
  2,106,"۔أسۍ یۅسہٕ پنٕنۍ آیت مسنو خ چِھ کران یا مٔشراوان چِھ اَتھ جایہِ چِھ اَمہِ کھۅتہٕ بہتر اَنان یا کم از کم تِژٕھے ﴿یہِ چُھ اکہِ خا ص شکُک جواب یُس یہوٗدۍ ٲسۍ مُسلمانن ہٕنٛدٮ۪ن دِلن منٛز ترٛاوُن یژھان۔ تِہُند اعترا ض اوس یہِ زِ اگر پٔتِمہِ کتا بہٕ تہِ اللہ تعالیٰ سٕنٛد ی طر فہٕ آمٕژٕ آسہٕ تہٕ یہِ قُر آن تہِ چُھ اللہ تعالیٰ سٕنٛدِ ی طر فہٕ آمُت ۔ تیٚلہِ کیازِ چِھ تِہنٛدیٚو کینٛژھو احکا مو بجا یہِ یتھ منٛز بد ل احکام دِنہٕ آمٕتۍ ؟﴾ کیا تۅ ہیہِ چھےٚ نا پے زِ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان ؟"
  2,107,"۔کیا تۅ ہیہِ چھےٚ نا خبر زِ زٔمینٕچ تہٕ آسما نن ہٕنز حٲکمیت چھےٚ اللہ تعالیٰ سٕنٛدی خٲطرٕ تہٕ تس ورٲے چُھنہٕ کانٛہہ تُہٕنٛز خبر اَتر ہیٚنہٕ وول تہٕ تُہُند مدد کر ن وول ؟"
  2,108,"۔کیا اَمہِ پتہٕ چِھوٕ ہ توٚہۍ پننِس رسولس تمہِ قٔسمٕکۍ سوال تہٕ مُطا لبہٕ کرٕنۍ یژھان ییٚمہِ قسمٕکۍ موسیٰ علیہ السلامس  کر نہٕ چِھ آمٕتۍ ؟ ﴿یہوٗدۍ ٲسۍ نکتہٕ کٔڑۍ کٔڑۍ قٔسمہٕ قٔسمٕکۍ سوال مُسلمانن برونٛہہ کنہِ پیش کران تہٕ یِمن ٲسۍ ہٕس دِوان زِ پننِس پیغمبرس پٕرٚژِھویہِ ،پتہٕ پٕرٛژِھیٚوٗس یہِ ، پتہٕ ہُہ ۔اَتھ پٮ۪ٹھ چُھ اللہ تعالیٰ مُسلمانن تنبیہ کران زِ اَتھ معا ملس منٛز بٔچِو یہوٗدٮ۪ن ہٕنٛز رٔوِش اختیار کر نہٕ نِشہِ﴾ حالانکہ ییٚمۍ شخصن ایمانٕچ رٔوِش کُفرٕ چہِ رٔوِشہِ سٍتۍ بد لٲو سُہ ڈوٚ ل سیٚزِ وَتہِ نِشہِ ،"
  2,109,"۔اہلِ کتا بَو منٛزٕ چِھ اکثر لُکھ یہِ یژھان زِ کُنہِ پٲٹھۍ پھِر ہا نَو بیٚیہِ تۅہیہِ ایمان نِشہِ کُفر س کُن اگر چہِ حق یِمن پٮ۪ٹھ ظٲہر چُھ سپدُ مُت ، مگر پننہِ نفٕس کہ حسدٕ کِنۍ چھےٚ تُہٕنٛدِ خٲطرٕ یِہٕنٛز یہِ خوٲہِش ،امہِ کِس جوابس منٛز ہِیٚیِو توٚہۍ عفو تہٕ  در گُزرس کٲم یوٚت تام زَن اللہ تعالیٰ پانہٕ پنُن فٲصلہٕ نٲفِذ کرِ ،اِطمنا ن تھٲوِ و ، زِ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان ،"
  2,110,"۔نماز کٔرِ و قٲیِم تہٕ زکوٰتہ دِیِو پننہِ عٲقبتٕ خٲطرٕ یُس رٕژَر کمٲوِتھ توٚہۍ برونٛہہ کُن سوٗزِ و خُدا یس نِشہِ وُچِھو سُہ مو جود، یِکینٛژھا توٚہۍ کران چِھو ، اللہ تعالیٰ چُھ تتھ وُچھان۔"
  2,111,"۔ تِہُند وَنُن چُھ زِ کانٛہہ شخٕص گژِھہ نہٕ جنّتس یوٚت تام نہٕ سُہ یہوٗدۍ آسہِ یا ﴿ عیسٲین ہُنٛدِ خیا لہٕ ﴾ عیسٲے آسہِ، یِم چِھ تِہٕنٛدۍ تمنا تِمن ؤنِو ،پنٕنۍ دلیل کٔرِ و پیش اگر توٚہۍ پننِس دعویٰ کر نس منٛز پٔزِ یٲر ۍ چِھو ۔"
  2,112,"۔﴿در اصل نَہ چَھو تۅہیہِ کانٛہہ خصو صیت تہٕ نَہ بیٚیہِ کٲنٛسہِ ﴾ حق چُھ یہِ زِ یُس تہِ پنُن پان اللہ تعالیٰ سٕندِس اطا عتس حوالہٕ کرِ تہٕ عملاً پکہِ نیک رٔوِشہِ  پٮ۪ٹھ ، تٔمۍ سٕنٛدِ خٲطرٕ چُھ تٔمۍ سٕنٛدِ س ربّس نِشہِ اَمِیُک اجر ۔ تہٕ یِتھیٚن لُکن خٲطرٕ چُھنہٕ کانٛہہ خو ف تہٕ کانٛہہ غم ۔ ع"
  2,113,"۔یہوٗدۍ چِھ ونان : عیٖسا ین نِش چُھنہٕ کِہِنۍ ،عیسٲے چِھ وَنان: یہوٗدٮ۪ن نِشہِ چُھنہٕ کِہِنۍ حالانکہ دۅ شو ے چِھ کتا ب پران تہٕ اَمی قسمٕکۍ دعویٰ چِھ تِمن لُکن نِشہِ تہِ ، یِمن نِشہِ کتا بہِ ہُنٛد علم چُھنہٕ یِم اختلاف یِمن منٛز یِم لُکھ ہیٚنہٕ چِھ آمٕتۍ ، یُہُنٛد فٲصلہٕ کرِ اللہ تعالیٰ قیا مت کہِ دۅ ہ۔"
  2,114,"۔تہٕ تس شخصہٕ سٕنٛدِ کھۅتہٕ کُس  ہیکہِ بوٚڈ ظٲلِم ٲسِتھ یُس اللہ تعالیٰ سٕندٮ۪ن عبا دت گا ہن منٛز تٔمۍ سٕنٛدِ ناوٕ چ ذِکر کر نہٕ نِشہِ رُکاوِ تہٕ یِمن آسہِ وٲرٲنی کر نس پٮ۪ٹھ ؟ یِتھۍ لُکھ چِھ اَتھ قٲبِل زِ یِمن عبا دت گا ہن منٛز گژھن نہٕ قد م تراوٕنۍ تہٕ اگر تور گژھن تہِ ، کھۅژا ن کھۅژا ن گژھَن گژٕھنۍ تِہنٛدِ خٲطرٕ چھےٚ دُنیا ہس منٛز رُ سوٲیی تہٕ ٲخرتس منٛز  چُھکھ عذا بِ عظیم۔"
  2,115,"۔مشرِ ق تہٕ مغرِ ب سٲر ی چِھ اللہ تعالیٰ سٕنٛد ۍ یو ر کُن تہِ توٚہۍ رۅ خ کٔرِ و ،توٗرۍ کُن چُھ اللہ تعالیٰ سُنٛد رۅ خ،  اللہ تعالیٰ چُھ سٮ۪ٹھاہ وُسعت وول تہٕ سورُے کینٛہہ زانن وول۔"
  2,116,"۔تِم چِھ وَنان زِ خُدا ین چُھ کُستا م نیچُو بنو و مُت ،اللہ تعالیٰ چُھ پاک یِمو کتھو نِشہِ ،اصلی حقیقت چھےٚ یہِ زِ زمینٕکۍ  تہٕ آسما نٕکۍ سٲری چیز چِھ تٔمۍ سٕنٛد ی اَنٛد ہیٚتھ چِھ سٲر ی تٔمۍ سٕنٛد ی تٲبعدار۔"
  2,117,"۔سُہ چُھ آسما نن تہٕ زمینس بنا و ن وول تہٕ ییٚمہِ کتھہِ ہُنٛد سُہ فٲصلہٕ چُھ کرا ن تمہِ خٲطرٕ چُھ بس یہِ حُکم دِوان زِ  سپَد  تہٕ سۅ چھےٚ سپدان۔"
  2,118,"۔نادان چِھ وَنان زِ اللہ تعالیٰ کیا زِ چُھنہٕ اسہِ سٍتۍ پانہٕ کتھہٕ کران یا کانٛہہ نشٲنی کیا زِ چَھنہٕ اَسہِ نِش یِوان ؟ یژِھے کتھہٕ ٲسۍ یِمن برونٛٹھم لُکھ تہِ کران ﴿یِمن سارِنٕے پٔتِمیٚن بروٗنٹھمیٚن گُمرا ہن ﴾ ہٕنزٕ سو نٛچن  ترٛا یہِ چھےٚ ہِشے، یقین کرن والیٚن خٲطرٕ چھےٚ اَسہِ نشٲنیہِ صا ف صا ف ظٲہر کرِ مَژٕ۔"
  2,119,"۔﴿ اَمہِ کھۅتہِٕ بٔڈ نِشٲنی کیا ہیٚکہِ ٲسِتھ زِ ﴾ اَسہِ سوٗزِ و توٚہۍ علمِ حق سان خۅ ش خبر دِنہٕ وٲلۍ تہٕ کھۅژناون وٲلۍ بنٲوِتھ ﴿یعنی با قی نِشٲنیہِ تھٲوِ توکھ أتی ، سارِوٕے کھۅتہٕ ٹا کارٕ ہ نِشٲنی چھےٚ محمد صلی اللہ علیہ وسلمن ہنٛز پنٕنۍ شخصیت ۔یِہِند نبوّت بروٗنٹھم حالات ،تَمہِ قو مٕکۍ تہٕ مُلکٕکۍ حالات یَتھ منٛز یِم پٲدٕ ہ سپٕدۍ ، تہٕ تِم حالات یِمن حالاتن منٛز یِہٕنٛز پرورش سپٕز تہٕ،40ؤری زند گی گُزٲرٕکھ ، پتہٕ سُہ عظیم الشا ن کار نامہٕ یُس پیغمبر سپد نہٕ پتہٕ یِمو انجام دِیُت ،یہِ سورُے کینٛہہ چُھ تِژھ اکھ روشن نِشٲنی ییٚمہِ پتہٕ بیٚیہِ کُنہِ نشٲنی ہٕنٛز ضرورت چَھنہٕ روزان۔﴾ وۅ نۍ یِمو لُکو جہنمس سٍتۍ رشتہٕ چُھ ووٹمُت ، تِہِنٛدِ طر فہٕ چِھو نہٕ توٚہۍ ذِمہٕ دار تہٕ جوا ب دہ کینٛہہ ۔"
  2,120,"۔یہوٗدۍتہٕ عیسٲے گژھنو نہٕ تۅہیہِ ہر گز تہِ رٲضۍ یوٚت تام نہٕ توٚہۍ تِہنٛدِس طر یقس پٮ۪ٹھ پٔکِو، صا ف ؤنِو زِ وَتھ چھےٚ بس سۅ ے یۅسہٕ خُدا ین ؤنمٕژ چھےٚ نَتہٕ اگر تمہِ علمہٕ پتہٕ ، یُس تۅہیہِ نِشہِ آمُت چُھ، کٔرٕ و تۅ ہیہِ تِہنٛز ن خوٲہِشن ہٕنٛز پیر وی تیٚلہِ چُھنہٕ تُہٕنٛدِ خٲطرٕ اللہ تعالیٰ سٕنزِ تھَپہِ نِشہِ بچا و ن وول کانٛہہ دوست تہٕ مددگار ،"
  2,121,"۔یِمن لُکن اَسہِ کتاب چھےٚ دِژمٕژ تِم چِھ تتھ تِتھہٕ پٲٹھۍ پران یِتھہٕ پٲٹھۍ پر نُک حق چُھ تِم چِھ یتھ ﴿قرآنس ﴾ پٮ۪ٹھ پزِ دِلہٕ ایمان اَنان ﴿یہِ اشارٕہ چُھ اہلِ کتا بن ہٕنٛد ٮ۪ن صا لح عنصر ن کُن زِ یِم لُکھ چِھ چو نکہ دیا نت دٲر ی تہٕ سیٚزرٕ سان اللہ تعالیٰ سٕنٛز یہِ کتاب پران یوسہٕ یِمن نِش گۅڈٕ پٮ۪ٹھے موجو د ٲس، اَمہِ موجو ب چِھ تِم یہِ قرآن بوٗزِ تھ یا پٔرِتھ اتھ پٮ۪ٹھ ایمان اَنان ۔﴾ تہٕ یِم اَتھ سٍتۍ کُفرُک رٔوِیہِ وَرتا وَن تِمے چِھ دراصل نقصا ن تُلن وٲلۍ۔ ع"
  2,122,"۔ اے بنی اسرا یل ! یاد کٔرِ و میٲنۍ سۅ نعمت ییٚمہِ سٍتۍ مےٚ توٚہۍ نوٲزِ مٕتۍ ٲسِمَو بیٚیہِ ٲسمَو تۅہیہِ دُنیا کیٚن تما م قو من پٮ۪ٹھ فضیلت دِژمٕژ"
  2,123,"۔تہٕ کھوٗژِو تتھ دۅ ہس ییٚلہِ نہٕ کانٛہہ کٲنٛسہِ رَژھ تہِ بکا ر یِیہِ ،نَہ یِیہِ کٲنٛسہِ  نِشہِ فدِیہِ قبو ل کر نہٕ ،نَہ دِیہِ کانٛہہ سفٲرشی انسانس فٲیدٕ ہ تہٕ نہٕ میلہِ مُجرِ من کُنہِ کِنۍ کانٛہہ مد د ۔"
  2,124,"۔یاد کٔرِو ییٚلہِ ابرا ہیم علیہ السلام ،تٔمۍ سٕنٛدۍ ربّن کینٛژھن کتھن منٛز اَز مو و تہٕ سُہ وُترٛیا و پوٗرٕ تِمن سارِنے کتھن منٛز پتہٕ فر مو و نس : بہٕ چُھسَتھ ژٕ سارِنٕے لُکن ہُنٛد پیشوا بناون وول ابرا ہیم علیہ السلامن کوٚر عر ض : کیا میا نین اولادن سٍتۍ تہِ چھا یۅ ہے وعدٕہ؟ تٔمۍ دُیتنَس جوا ب : میو ن وعدٕہ چُھنہٕ ظٲلِمن متعلق کینٛہہ ﴿یعنی یہِ وعدٕ ہ چُھ چا نیٚن اولاد ن ہٕنٛدِ س صر ف تتھ حصّس سٍتۍ تعلق تھاوان یُس صا لح آسہِ ۔تِمن منٛز یِم ظٲلِم آسن تِمن خٲطرٕ چُھنہٕ یہِ وعدٕہ ۔یَتھ جایہِ چُھنہٕ ظا لم مُراد انسانن پٮ۪ٹھٕے یوت ظُلم کر ن وول کینٛہہ بلکہ سُتہِ یُس حقس تہٕ صدا قتس پٮ۪ٹھ ظُلم آسہِ کرا ن ۔﴾"
  2,125,"۔بیٚیہِ یہِ زِ اَسہِ اوس یہِ گھرٕ ﴿کعبہ﴾ لُکن خٲطرٕ مر کز تہٕ اَمنٕچ جا ے قرار دِیتمُت تہٕ لُکن اوس حُکم دِیتمُت زِ ابرا ہیم علیہ السلام یتھ جایہِ عبادت خٲطرٕ کھڑا چُھ سپدان سۅ جاے بنٲوِو مُستقٕل نمازِ ہٕنٛز جا ے بیٚیہِ اوس ابرا ہیم علیہ السلامس تہٕ اسما عیل علیہ السلامس تٲکید کوٚر مُت زِ میو ن یہِ گھرٕ تھٲوِیوٗن طوا ف، اعتکا ف ،رکوع تہٕ سجدٕ ہ کر ن والیٚن خٲطرٕ پاک۔"
  2,126,"۔بیٚیہِ یہِ زِ ابرا ہیم ﴿علیہ السلامن﴾ کوٚردُعا: اے میانہِ ربّہٕ ، یہِ شہر بناوُن اَمنُک شہر تہٕ اَمہِ کیٚن با شند ن منٛز یِم خُدا یس تہٕ ٲخرتس مانن ، تِمن کر پرٛتھ قٔسمہٕ کیٚن پھلن ہُنٛد رزق عطا ۔ در جوا ب فر مو و تٔمۍ سٕنٛدۍ ربّن: تہٕ یُس نہٕ مانہِ ، دُنیا چہِ کینٛژھن دۅ ہن ہٕنٛزِ زند گی ہُنٛد سامانہٕ دِمہٕ بہٕ تس تہِ مگر ٲخر کار نِمن جہنم کِس عذا بس کُن کھکھرِ، تہٕ سۅ چھےٚ بد تر ین روزن جا ے ۔"
  2,127,"۔تہٕ یاد کٔرِو ییٚلہِ ابرا ہیم علیہ السلام تہٕ اسما عیل علیہ السلام امہِ گھرٕ چہِ لبہٕ ٲسۍ کھالان دُعا ٲسۍ روزان کران: اے سانہِ ربّہٕ ، سٲنۍ یہِ خد مت کر قبو ل ، ژٕ چُھکھ سارِنٕے ہُنٛد بوزن وول تہٕ سورُے کینٛہہ زانن وول"
  2,128,"۔ اے ربّ ، اسہِ دۅ شوٕ نۍ بناو پنُن مُسلم ﴿فر مان بردار ﴾اَسہِ وَن پننہِ عبا دتٕکۍ طر یقہٕ ،تہٕ سا نیٚن کوٗتٲہِیَن کر در گُز ر ژٕ چُھکھ بوٚڈ معا ف کر ن وول تہٕ رحم کر ن وول"
  2,129,"۔تہٕ اے سا نہِ ربّہٕ ، یِمن لُکن منٛز تُلُن خۅد یِہِنٛد ی قو مہٕ منٛز اکھ تِیُتھ رسول یُس یِمن چٲنۍ آیات بوز ناوِ ، یِمن دِیہِ کتا ب ہٕنٛز تہٕ حِکمتٕچ تعلیم تہٕ یِہٕنٛز ن زِند گِیَن کرِ پاک، ژٕ چُھ بوٚڈ اقتدارٕ وول تہٕ حکمت وول ۔ع"
  2,130,"۔وۅ نۍ کُس چُھ یُس ابرا ہیم علیہ السلام سٕنٛدِس طر یقس نفر ت کرِ ؟ ییٚمۍ پانہٕ پنُن پان حما قتس تہٕ جہا لتس منٛز ترٛوومُت آسہِ ،تس ورٲے کُس ہیٚکہِ یہِ حر کت کٔرِ تھ؟ ابرا ہیم علیہ السلام چُھ سُہ شخٕص ، یُس اَسہِ دُنیا ہس منٛز پننہِ کامہِ خٲطرٕ ژورٕ مُت اوس تہٕ ٲخرتس منٛز سپدِ تٔمۍ سُنٛد شُما ر صا لح لُکن منٛز ۔"
  2,131,"۔تٔمۍ سُنٛد حال اوس یہِ زِ ییٚلہِ تٔمۍ سٕنٛدۍ ربّن تس ووٚ ن :  ،ُمسلم سَپَد ﴿مُسلم : گوٚو سُہ یُس خُدا یس برونٛہہ کنہِ اطا عتُک کلہٕ نوٚ مرا وِ ،اللہ تعالیٰ سٕے مانہِ پنُن مٲلِک،آقا ، حٲکِم تہٕ معبوٗد، یُس پنُن پان مکمل پٲٹھۍ خُدا یس پُشرا وِ تہٕ تٔمۍ سٕنٛدِ ہدا یتہٕ مطا بق کر دُنیا ہس منٛز زند گی بسر یُس ہدا یت تٔمۍ سٕندِ طر فہٕ آمُت آسہِ ۔ امہِ عقیدُک تہٕ عملہِ ہٕندِ اَمہِ طر زُک ناو چُھ اسلام تہٕ یۅہے اوس تمام انبیا ہن ہُنٛد دین یِم گۅڈٕ ہ پٮ۪ٹھہٕ دُنیا کیٚن مختلف مُلکن تہٕ قو من منٛز آے ﴾ تہٕ تٔمۍ ووٚ ن فوراً بہٕ سَپدُس کاینات کِس مٲلکہٕ سُنٛدمُسلم۔"
  2,132,"۔أتھۍ طر یقس پٮ۪ٹھ پکنُک ہدا یت اوس تٔمۍ پننیٚن اولاد ن کوٚر مُت تہٕ اَمہِ چی وصیت ٲس یعقو ب علیہ السّلامن تہِ پننیٚن اولاد ن کٔر مٕژ ،تٔمۍ اوس ووٚ نمُت زِ  میا نیو شُر یو ، خُدا ین چُھ تُہٕنٛدِ خٲطرٕ یۅ ہے دین پسند کوٚر مُت لہٰذا روٗزۍ زیٚو مر نہٕ کِس دَمس تا م بس مُسلم ۔"
  2,133,"۔پتہٕ کیا توٚہۍ ٲسِوٕ ہ تمہِ وقتہٕ موجو د ، ییٚلہِ یعقو ب علیہ السلام ییٚمہِ دُنیا رۅ خصت اوس سپدان؟ تٔمۍ پرٛوژھ مر نہٕ وقتہٕ  پننیٚن شُر ٮ۪ن: گو بر و، میا نہِ پتہٕ کٔمۍ سٕنٛز بند گی کٔرِ و توٚہۍ ؟ تِمو سارِ وٕے دِیُت جوا ب : أسۍ کر و تٔسۍ أکِس اللہ تعالیٰ سٕنٛز بند گی یُس تۅہیہِ تہٕ تُہٕنٛد یٚو بُزر گو، ابرا ہیم علیہ السلام، اسما عیل علیہ السلام تہٕ اسحا ق ﴿علیہ السّلامن﴾ خُدا ے چُھ مو نمُت تہٕ أسۍ چِھ تٔمۍ سٕنٛدی مُسلم ﴿فر مان بردار ﴾۔"
  2,134,"۔تِم ٲسۍ کینٛہہ لُکھ ، یِم درٛا ے یِکینٛژھاہ تِمو کَمو و ،سُہ چُھ تِہٕندِ خٲطرٕ تہٕ یِکینژھاہ توٚہۍ کمٲوِ و ،سُہ چُھ تُہٕندِ خٲطرٕ تۅہیہِ یِیَو نہٕ یہِ پٕرٛژھنہٕ زِ تِم کیا ٲسۍ کران۔"
  2,135,"۔یہوٗدۍ چِھ ونان : یہوٗدۍ اگر چھِو ، تیٚلہِ لٔبِو سِیٔز وَتھ۔عیسٲے چِھ وَنان : عیسٲے اگر چِھو، تیٚلہِ میلیٚو ہدا یت تِمن ؤنِو : نَہ ، بلکہ سورُے ترٛٲوِ تھ  ابرا ہیم علیہ السلام سُنٛد طر یقہٕ تہٕ ابرا ہیم علیہ السلام اوس نہٕ مُشرِ کَو منٛزٕ۔"
  2,136,"۔مُسلمانو ، ؤنِو زِ :  اَسہِ اوٚ ن ایمان خُدا یس پٮ۪ٹھ تہٕ تتھ ہدا یتس پٮ۪ٹھ یُس اَسہِ کُن نٲزِل چُھ سپُد مُت تہٕ یُس ابرا ہیم علیہ السلام، اسما عیل علیہ السلام، اسحا ق علیہ السلام، تہٕ یعقو ب علیہ السلام سٕندٮ۪ن اولادن کُن نٲزِل اوس سپُد مُت تہٕ یُس مو سیٰ تہٕ عیسیٰ ﴿علیہ السلامس﴾ تہٕ دوٚ یِمیٚن تمام پیغمبر ن تِہندِس ربّ سٕندِ طر فہٕ دِنہٕ اوس آمُت أسۍ چِھنہٕ تِمن در میان کانٛہہ فر ق کرا ن تہٕ أسۍ چِھ اللہ تعالیٰ سٕندۍ مُسلم ﴿فر مان بردار ﴾۔"
  2,137,"۔ پتہٕ اگر تِم تِتھے پٲٹھۍ ایمان اَنن، یِتھہٕ پٲٹھۍ تۅہیہِ چُھو ایمان اوٚ نمُت، تیٚلہِ چِھ ہدا یتس پٮ۪ٹھ تہٕ ہر گاہ اَمہِ نِشہِ بُتھ پھِر ن ، تیٚلہِ چھےٚ ٹا کارٕ کتھ زِ تِم چِھ ضِدس پٮ۪ٹھ، لہٰذا تھٲوِ و اِطمنا ن زِ تِہنٛدِس مُقا بلس منٛز چُھو تۅہیہِ اللہ تعالیٰ حما یت خٲطرٕ سٮ۪ٹھاہ، سُہ چُھ سورُے کینٛہہ بوزان تہٕ زانان ۔"
  2,138,"۔وَنِو :  اللہ تعالیٰ سُنٛد رنگ کٔرِ و اختیار ،تٔمۍ سٕنٛد رنگہٕ کھۅتہٕ کھٔسِتھ رنگ کٔمۍ سُند آسہِ ؟ تہٕ أسۍ چِھ تٔمۍ سٕنٛزٕ ے بند گی کر ن وٲلۍ لُکھ ۔"
  2,139,"۔اے نبی صلی اللہ علیہ وسلم ! یِمن ؤنِو : کیا توٚہۍ چِھوٕ ہ اللہ تعالیٰ سٕنٛدِس با رس منٛز اَسہِ سٍتۍ ژُوان؟ حالانکہ سُے چُھ سو ن ربّ تہِ تہٕ تُہُنٛد ربّ تہِ ،سٲنۍ اعما ل چِھ سا نہِ خٲطرٕ ، تُہٕندۍ اعما ل چِھ تُہٕنٛدِ خٲطرٕ تہٕ اَسہِ چھےٚ اللہ تعالیٰ سٕنٛدِی خٲطرٕ پنٕنۍ بند گی خٲلص کٔر مٕژ۔"
  2,140,"۔کِنہٕ تُہُند وَنُن چُھ یہِ زِ ابرا ہیم علیہ السلام، اسما عیل علیہ السلام ، اسحا ق علیہ السلام، یعقو ب علیہ السلام تہٕ یعقو ب علیہ السلام سٕنٛدۍ اولاد سٲر ی ٲسۍ اند ہیٚتھ یہوٗدۍ یا نصرٲنۍ؟ وَنِیوٗکھ:ِ توٚہۍ چِھوٕ ہ زیادٕہ زانان کِنہٕ اللہ تعالیٰ ؟ تس شخصہٕ سٕندِ کھۅتہٕ بوٚڈ ظٲلِم کُس آسہِ ، ییٚمہِ سٕنٛدِ ذِمہٕ اللہ تعالیٰ سٕنٛدِ طر فہٕ اکھ گوٲہی آسہِ تہٕ سُہ چُھپا وِ تَتھ ؟"
  2,141,"۔تُہٕنز و حر کتَو و نِشہِ چُھنہٕ اللہ تعالیٰ غٲفِل تہِ کینٛہہ۔ تِم ٲسۍ کینٛہہ لُکھ ،یِم گُزر ے تِہٕنٛز کمٲے ٲس تِہٕنٛدِ خٲطرٕ تہٕ تُہٕنٛز کمٲے چھےٚ تُہٕنٛدِ خٲطرٕ تۅہیہِ یِیَو نہٕ تِہنٛز ن عملن متعلق سوال کر نہٕ۔ع"
  2,142,"۔ نادان لُکھ وَنن ضروٗر : یِمن کیا گوٚو زِ یتھ قبلس کُن رۅ خ کٔرِ تھ یِم گۅڈٕ ہ نماز پرا ن ٲسۍ ،تَمہِ نِشہِ پھیٖرۍ اچا نک ؟ ﴿نبی صلی اللہ علیہ وسلم روٗدۍ ہجرت پتہٕ مد ینہٕ طیّبس منٛز شۅ را ہن یا سَد ہن ریٚتن تام بیتُ المقدّسس کُن رۅ خ کٔرِ تھ نمازِ پرا ن ۔ پتہٕ آو کعبس کُن بُتھ کٔرِ تھ نماز پر نُک حُکم ۔﴾ اے نبی صلی اللہ علیہ وسلم، یِمن وَنِو : مشر ق تہٕ مغر ب سورُے چُھ اللہ تعالیٰ سُنٛد، اللہ تعالیٰ تعالیٰ یس یژھان چُھ، تَس چُھ سِیٔز وَتھ ہاوان ۔"
  2,143,"۔تہٕ یِتھے پٲٹھۍ بنٲوِو اَسہِ توٚہۍ مسلمان اکھ  اُمّتِ وَسط۔ ﴿ اُمّتِ وَسط نِشہِ چُھ مُراد تِژھ اکھ اعلیٰ تہٕ حدٕ کھۅتہٕ شر یف چھۅ کھ، یۅسہٕ عد ل و انصا فس تہٕ در میانہٕ رٔوِشہِ پٮ۪ٹھ قٲیِم آسہِ ، یۅسہٕ دُنیا کیٚن قو من در میان صدرٕ سٕنٛز حیثیت آسہِ تھاوان، ییٚمہِ سُنٛد تعلق سارِنٕے سٍتۍ حقُک تہٕ پز رُک یکسا ن تعلق آسہِ ، تہٕ نا حق تہٕ ناروا تعلق آسیٚس نہٕ کٲنٛسہِ سٍتۍ ۔﴾ تا کہ توٚہۍ ٲسِو لُکن پٮ۪ٹھ گواہ تہٕ رسول آسہِ تۅہیہِ پٮ۪ٹھ گواہ ﴿اَمہِ نِشہِ چُھ مُراد یہِ زِ ٲخرتس منٛز ییٚلہِ سٲرِسٕے انسانی زُر یا تس یِیہِ یِکہٕ وَٹہٕ حسا ب ہیٚنہٕ، تمہِ وقتہٕ دِیہِ رسول تُہٕنٛدِ س ذمہٕ دار نُما یندٕہ سٕنٛدِ حیثیت تۅہیہِ پٮ۪ٹھ گوٲہی زِ صحیح فکرِ ہٕںز،صا لح عملن ہنٛز تہٕ عد ل کہ نظا مٕچ یوسہٕ تعلیم اَسہِ تس دِژ مٕژ ٲس، کیا سۅ واتنٲواتٔمۍ کانٛہہ کمی کر نہٕ ورٲے اند ہیٚتھ سٲرٕ ے ،تہٕ عملاً تہِ ہووا تٔمۍ اَتھ مطا بق کٲم کٔرِ تھ۔ اَمہِ پتہٕ آسیٚو تۅہیہِ رسول سٕندِ قٲیِم مقا م سٕندِ حیثیت عا م انسانن پٮ۪ٹھ گواہ سٕندِ حیثیت وۅ تُھن تہٕ یہِ شہادت آسیٚو دِنۍ زِ رسولن یِکینٛژھاہ تۅہیہِ تام واتنو و مُت اوس ، سُہ واتنو وا تۅہیہِ لُکن تام تہٕ یِکینٛژھاہ رسولن تۅہیہِ عمل کٔرِ تھ ہو و مُت اُوسنَو ، تہِ ہووٕ و اتۅ ہیہِ تِمن عمل کٔرِ تھ  تہٕ اَتھ منٛز ما کٔرٕ و کانٛہہ کوتٲہی ﴾۔گۅڈٕہ یَتھ اَندس کُن توٚہۍ رۅخ ٲسِو کران سُہ اوس اَسہِ صِرف یہِ وُچھنہٕ خٲطرٕ قبلہٕ مُقرر کوٚر مُت زِ کُس چُھ رسول سٕنٛز پیر وی کرا ن تہٕ کُس چُھ پوٚت پھیران، اوس تہِ یہِ معا ملہٕ بڈٕ سخت، مگر تِمن لُکن خٲطرٕ سپُد نہٕ رَژھ تہِ سخت ثٲبت ،یِم اللہ تعالیٰ سٕندِ ہدا یت نِشہِ فیض یا ب ٲسۍ ،اللہ تعالیٰ کرِ نہٕ تُہنٛدِ س اَتھ ایمانس ہر گز ضا یع، پَژھ کٔرِو زِ اللہ تعالیٰ چُھ لُکن ہٕنٛدِس حقس منٛز سٮ۪ٹھاہ شفیق تہٕ رحیم ۔"
  2,144,"۔اے نبی صلی اللہ علیہ وسلم، اَمہِ تُہٕنٛدِ رویُک بار بار آسمانس کُن وۅ تُھن چِھ أسۍ وُچھان، رٔٹِو، تٔتھۍ قبلس کُن چِھو أسۍ توٚہۍ پھِرا ن، یُس توٚہۍ پسند چِھو کران۔پھِرِ و مسجد حرا مَس کُن پنُن رۅ خ وۅ نۍ ییٚتہِ توٚہۍ ٲسِو ، تٔتھۍ کُن أسۍ زیٚو رۅ خ کٔرِ تھ نماز پرا ن﴿یہِ چُھ سُہ اصلی حکم ،یُس قبلہ بدلاونس متعلق دِنہٕ اوس آمُت ۔یہِ حُکم سپُد رجب یا شعبا ن ، 2 ہجر ی منٛز نٲزِل۔ نبی صلی اللہ علیہ وسلم چِھ أکِس صحا بی رضی اللہ عنہ  سُند دعوتس پٮ۪ٹھ گٔمٕتۍ آسان۔ تَتہِ چُھ ظُہر نماز ہُنٛد وقت واتان تہٕ نبی صلی اللہ علیہ وسلم چِھ  لُکن نماز پرناو نہٕ خٲطرٕ کھڑا سپدان۔زٕ ہ رکٲژ آسکھ پر ناوِ مژٕ تہٕ ترٛییٚمہِ رکٲژ منٛز چھےٚ تمی ساعتہٕ و حی ہٕندِ ذر یعہ یہِ آیت نٲزِل سپدان تہٕ تمی وقتہٕ چِھ نبی صلی اللہ  علیہ وسلم تہٕ سٲر ی لُکھ یِم تِہٕندِس اِقتداہس منٛز جما عتس منٛز ٲسۍ بیت المقدس نِشہِ کعبس کُن پنُن رۅ خ پھِرا ن۔ اَمہِ پتہٕ آو مد ینس دٔچِھنۍ کھووٕ رۍ اَمیُک ڈنڈ وٗرٕ دِنہٕ تہٕ یُس یہِ فر ماو نہٕ چُھ آمُت زِ  چا نہِ رۅ یُک با ر بار اَسمانس کُن وۅ تُھن چِھ أچھۍ وُچھان  بیٚیہِ یہِ زِ تٔتھۍ قبلس کُن چِھو أسۍ پھِرا ن ، یُس توٚہۍ پسند چِھو کران  اَمہِ نِشہِ چُھ صا ف پے لگا ن زِ قبلہ بد لا و نُک حُکم یِنہٕ برونٛہہ ٲسۍ نبی صلی اللہ علیہوسلم اَمِکۍ مُنتظر ۔ ﴾یِم لُکھ یِمن کتا ب ٲس دِنہٕ آمٕژ تِم چِھ وارٕ پٲٹھۍ زانان زِ ﴿قبلہ بد لاو نُک یہِ ﴾ حُکم چُھ تِہنٛدِ س ربّ سٕندۍ طر فہٕ تہٕ بیٚیہِ چُھ بر حق مگر امہِ با و جو د یِکینٛژھاہ تِم کران چِھ ، اللہ تعالیٰ چُھنہٕ تَمہِ نِشہِ بے خبر کینٛہہ ۔"
  2,145,"۔توٚہۍ أنۍ تَو یِمن اہلِ کتا بن نِشہِ کانٛہہ تہِ نِشٲنی ، یہِ چُھنہٕ ممکن زِ یِم لا گن تُہٕندِ قبلٕچ  پیر وی کرٕنۍ تہٕ یِمو منٛزٕ چُھنہٕ کانٛہہ دوٚ ر تہِ دوٚ یِمہ سٕندِ قبلٕچ  پیروی کر نہٕ خٲطرٕ تیار تہٕ اگر تۅہیہِ تَمہِ عِلمہٕ پتہٕ یُس تۅہیہِ نِش آمُت چُھ، تِہنٛز ن خوٲہشا تن ہٕنٛز پیر وی کٔرٕ و تیٚلہِ گژِھہ یقیناً تُہُند شُما ر ظٲلِمن منٛز ۔"
  2,146,"۔یِمن لُکن اَسہِ کتا ب چھےٚ دِمٕژ، تِم چِھ سۅ جا ے ﴿یۅسہٕ قبلہٕ آیہِ بناو نہٕ﴾ تِتھہٕ پٲٹھۍ پرٛزٕ ناوان  یِتھہٕ پٲٹھۍتِم پننین اولادن چھِ پرزناوان﴿یہِ چُھ عر بُک محا ورٕ ہ۔ یتھ چیز س انسان پٔزۍ پٲٹھۍ آسہِ زانان تہٕ تَتھ متعلق آسیٚس نہٕ کُنہِ قٔسمُک شک شُبہٕ ،تس چِھ یہِ وَنان زِ سُہ چُھ تَتھ چیز س تِتھہٕ پٲٹھۍ پرٛزٕ ناوان یِتھہٕ پٲٹھۍ پننیٚن اولاد ن چُھ پرٛزٕ ناوان۔یہوٗدٮ۪ن تہٕ عیسٲین ہٕندۍ عٲلم ٲسۍ یہِ کتھ ٹھیک پٲٹھۍ زانان زِ کعبہٕ چُھ حضرتِ ابرا ہیم علیہ السلامَن تعمیر کوٚر مُت تہٕ اَتھ بر عکس سَپُد بیت المقدس تِمن علیہ السلامن پتہٕ 13 ، شتھ ؤری حضرتِ سلیمان علیہ السلامَن ہِنٛد یٚو أتھو ےتعمیر تہٕ یہِ کتھ ٲس نہٕ کٲنٛسہِ نِشہِ کھٔٹِتھ﴾ مگر یِمو منٛزٕ چُھ اکھ دوٚر زٲنِتھ مٲنِتھ حق چُھپاوان ،یہِ چُھ پٔزِ پٲٹھۍ اکھ امرِ حق تُہندِس ربّ سٕندِ طر فہٕ ،"
  2,147,"۔لہٰذا مَہ پیٚیِو اَتھ متعلق ہر گز تہِ شکس منٛز۔ ع"
  2,148,"۔پرٛتھ کٲنٛسہِ خٲطرٕ چُھ اکھ اَند،یتھ کُن سُہ پھیران چُھ پَس توٚہۍ کٔرِ ونیِکیَن کُن سبقت یَتھ جایہِ تہِ توٚہۍ ٲسِو ،اللہ تعالیٰ لبیٚو تۅ ہیہِ تٔمۍ سٕندِ قدرت نِشہِ چُھنہٕ کانٛہہ چیز نیٚبر۔"
  2,149,"۔تُہُند گُزر ییٚمہِ جایہِ کِنۍ تہِ سپدِ تَتی پٮ۪ٹھہٕ پھرِ و پنُن رۅ خ ﴿نما ز وقتہٕ ﴾ مسجدِ حرا مس کُن تِکیازِ یہِ چُھ تُہٕنٛدِ س ربّ سُنٛد بالکل بر حق فٲصلہٕ تہٕ اللہ تعالیٰ چُھنہٕ تُہنٛد یٚو اعما لو نِشہِ بے خبر کینٛہہ۔"
  2,150,"۔تہٕ یپٲر ۍ تہِ تُہُنٛد گُزر سپدِ پنُن رۅ خ ٲسۍ زیٚو مسجدِ حرام سٕے کُن پھِرا ن تہٕ ییٚتہِ تہِ توٚہۍ چِھو تٔتھۍ کُن رۅ خ کٔرِ تھ پٔرِ و نماز تا کہ لُکن میلہِ نہٕ تۅہیہِ خلا ف کانٛہہ حُجّت﴿یعنی کٲنٛسہِ میلہِ نہٕ یہِ وَننُک مو قع زِ وُچھِو سا یِم کِتھۍ مو من چِھ زِ یِم چِھ پننِس ربّ سٕنٛدِس ٹا کارٕ ہ حُکمس خلا ف ور زی کرا ن ﴾ آ، تِمَومنٛزٕ یِم ظٲلِم چِھ تِہٕنٛز زبان گژِھہ نہٕ کُنہِ تہِ حا لس منٛز بند ۔ لہٰذا مَہ کھوٚژِ و تِمن بلکہ کھوٚژِ و مےٚ ﴿اَمہِ کتھہِ ہُنٛد تعلق چُھ اَتھ عبا رتس سٍتۍ زِ  تٔتھۍ کُن رۅخ کٔرِ تھ پٔرِ و نماز تا کہ لُکن میلہِ نہٕ تۅہیہِ خلا ف کانٛہہ حُجّت﴾ تہٕ اَمہِ موجوٗب زِ بہٕ کرٕ تۅہیہِ پٮ۪ٹھ پنٕنۍ نعمت پوٗرٕ تہٕ اَتھ تو قعس پٮ۪ٹھ زِ میانہِ اَمہِ حُکم چہِ پیر وی سٍتۍ لٔبِو کا میٲبی ہٕنٛز وَتھ۔"
  2,151,"۔تِتھے پٲٹھۍ یِتھہٕ پٲٹھۍ ﴿تۅہیہِ اَمہِ چیزٕ سٍتۍ کامیٲبی نصیب سپٕز وزِ ﴾ اَسہِ سوٗز تۅہیہِ در میان خۅد تۅ ہی منٛزٕ اکھ رسول یُس تۅہیہِ سٲنۍ آیات بوزناوان چُھ، تُہٕنٛز ن زِ ند گیَن چُھ شیرٕ پٲر ﴿یعنی پاک ﴾ کران تہٕ تۅہیہِ چُھو کتا بہِ ہٕنٛز تہٕ حِکمتٕچ تعلیم دِوان تہٕ تۅہیہِ چُھو تِمہٕ کتھہٕ ہیٚچھناوان ، یِمہٕ نہٕ توٚہۍ زانان ٲسِو ۔"
  2,152,"۔ لہٰذا تھٲوِو توٚہۍ مےٚ یاد، بہٕ تھاوَو توٚہۍ یاد تہٕ میو ن شُکر کٔرِو ، تہٕ نا شُکر ی مہ کٔرِو ۔ع"
  2,153,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ۔ صبرس تہٕ نمازِ ہیٚیِو مدد ،اللہ تعالیٰ چُھ صبر  کر ن والیٚن سٍتۍ۔"
  2,154,"۔تہٕ یِم لُکھ اللہ تعالیٰ سٕنٛزِ وَتہِ منٛز مار نہٕ یِن ، تِمن مہ ؤنِو  مۅردٕ  در حقیقت چِھ یِتھۍ لُکھ زِ ندٕ ہ، مگر تۅہیہِ چُھو نہٕ تِہنٛزِ زند گی ہُنٛد شعور آسان۔"
  2,155,"۔تہٕ أسۍ کر و تۅہیہِ ضروٗر آز مٲیش خو فَس تہٕ خطرس منٛز فا قہٕ کٔشی منٛز جان و مال کیٚن نقصا نَن تہٕ آمد نِیَن ہٕندِس خسا رس منٛز ترٲوِتھ، یِمن حالاتن منٛز یِم لُکھ صبر کر ن ، تِمن دِیِو خۅ ش خبر ،"
  2,156,"۔تہٕ ییٚلہِ کانٛہہ مُصیبت وُچھن تیٚلہِ وَنن زِ  أسۍ چِھ اللہ تعالیٰ سٕندی تہٕ اللہ تعالیٰ سٕے کُن چُھ اَسہِ وا پس گژُھن"
  2,157,"۔تِمن پٮ۪ٹھ سپدَن تِہنٛدِس ربّ سٕنٛدِ طر فہٕ سٮ۪ٹھاہ عِنا یتہٕ، تٔمۍ سٕنٛز رحمت کرِ تِمن پٮ۪ٹھ سایہِ تہٕ تِمے لُکھ چِھ ہدا یتس پٮ۪ٹھ۔"
  2,158,"۔پٔزۍ پٲٹھۍ چُھ صفا تہٕ مَر وَہ اللہ تعالیٰ سٕنٛز و نِشٲنِیَو منٛزٕ لہٰذا یُس شخٕص بیت اللہ ہُک حج یا عمرٕہ کرِ ﴿ذو الحّجہِ کیٚن مقرر کر نہٕ آمتیٚن تٲریخن منٛز یۅسہٕ کعبٕچ زیارت کر نہٕ چھےٚ یِوان ، تمِیُک ناو چُھ حج تہٕ یِمو تٲریخو وَرٲے یۅسہٕ زیارت بیٚیہِ کُنہِ وقتہٕ کر نہٕ یِیہِ ، تتھ چِھ عُمر ہ وَنان﴾تس خٲطرٕ چُھنہٕ کانٛہہ گنا ہ زِ سُہ دٔوِن یِمن دۅ شوٕ نۍ با لہٕ ٹیٚکر ٮ۪ن در میان تہٕ یُس اکھا ہ رضا تہٕ رغبت سان کانٛہہ نیکی ہٕنٛز کٲم کرِ خُدا یس چُھ تِمیُک علم تہٕ سُہ چُھ تَتھ قدر کر ن وول ۔"
  2,159,"۔یِم لُکھ سا نیٚن نٲزِل کر نہٕ آمٕتیٚن روشن تعلیما تن تہٕ ہدا یتن کھٔٹِتھ چِھ تھاوان حالانکہ اَسہِ چِھ یِم سارِنٕے اِنسا نن ہٕنٛزِ رہنمٲیی خٲطرٕ پننہِ کتا بہِ منٛز بیان کٔرِ مٕتۍ ،پَژھ کٔرِ و زِ اللہ تعالیٰ تہِ چُھ تِمن پٮ۪ٹھ لعنت کران تہٕ تمام لعنت کر ن وٲلۍ تہِ چِھ تِمن پٮ۪ٹھ  لعنت سوزان ،"
  2,160,"۔البتہ، یِم امہِ رٔوِشہِ نِشہِ با ز پھیرن تہٕ پننہِ عملہِ ہٕنٛدِ س طر زَس کر ن اِصلا ح تہٕ یِکینٛژھاہ چُھپا وان ٲسۍ ،تَتھ لاگن بیان کرُن تِمن کرٕ بہٕ معا ف تہٕ بہٕ چُھس سٮ۪ٹھاہ در گز ر کر ن وول رحم کر ن وول۔"
  2,161,"۔یِمو لُکو کُفرُک رٔوّیہِ اختیار کوٚر ﴿کُفر  لفظ چُھ ایمان کِس مقا بلس منٛز وَننہٕ یِوان ۔ ایمانُک معنی چُھ مانُن ،قبو ل کرُن ،تسلیم کرُن۔اَتھ بر عکس چُھ کُفرُک معنی ۔نہ مانُن ، رد کرُن ، انکار کرُن ، قرآن مطٲبق چھےٚ کُفرکہِ رٔویہِ چہِ مختلف صوٗرتہٕ: اَکھ یہِ زِ انسان مانہِ نہٕ مُلہٕ مۅ نجی خدا یس یا کرِ نہٕ تٔمۍ سٕندِس اعلیٰ اقتدارس تسلیم ،تہٕ تس کرِ پنُن تہٕ سار ی کایناتُک مٲلِک  تہٕ معبوٗد ماننہٕ نِشہِ انکار ،یا تس مانہِ نہٕ کُن مٲلک تہٕ معبوٗد۔دوٚ یِم یہِ زِ اللہ تعالیٰ مانہِ مگر تٔمۍ سٕندِٮ۪ن احکا من تہٕ تٔمۍ سٕندٮ۪ن ہدا یتن کرِ علم و قا نو نُک وٲحد آگُر تسلیم کر نہٕ نِشہِ انکار۔ترٛییِم یہِ زِ اصو لاً کرِ یہِ کتھ تہِ تسلیم زِ تَس پزِ اللہ تعالیٰ سٕندِ نٕے ہدا یتن پٮ۪ٹھ پکُن، مگر یِمن پیغمبر ن اللہ تعالیٰ پنٕنۍ ہدا یت تہٕ پنٕنۍ احکام واتناو نہٕ خٲطرٕ وا سطہٕ چُھ بناوان ،تِمن کرِ نہٕ تسلیم ۔ژوٗرِ م یہِ زِ پیغمبر ن در میان  کرِ فر ق تہٕ پننہِ مر ضی یا پننیٚن تعصُبن ہٕنٛدِس بنیا دس پٮ۪ٹھ مانہِ کٲنٛسہِ تہٕ کٲنٛسہِ مانہِ نہٕ۔ پوٗنٛژِم یہِ زِ  پیغمبر و یِم عقیدٕہ ،اخلا ق تہٕ زند گی ہٕندۍ قا نو ن اللہ تعالیٰ سٕندِ طر فہٕ ؤنۍ مٕتۍ چِھ ، تِمن یا تِمو منٛزٕ کرِ کُنہِ چیز س ماننہٕ نِشہِ انکار۔شیِیِم یہِ زِ نظر یہ کِس بُنیا دس پٮ۪ٹھ مانہِ یِمن سارِنٕے چیز ن مگر عملاً کرِ زِ ٲنِتھ مٲنِتھ اللہ تعالیٰ سٕندٮ۪ن احکامن ہٕنٛز نافر مٲنی تہٕ اَتھ نا فر مٲنی پٮ۪ٹھ روزِ اِصرار کران، تہٕ دُنیا چہ زند گی منٛز تھاوِنہٕ پننہِ رٔوِیچ بنیاد اطا عتس پٮ۪ٹھ بلکہ تھا وِ نا فر مٲنی پٮ۪ٹھٕے۔﴾ تہٕ کُفرٕ کِس حالت سٕے منٛز دِیتُکھ زُو تِمن پٮ۪ٹھ چھےٚ اللہ تعالیٰ سٕنٛز تہٕ فر شتن ہٕنٛز تہٕ تمام انسانَن ہٕنٛز لعنت ،"
  2,162,"۔اَتھ لعنت زد گی ہٕندِس حا لتس منٛز روزن تِم ہمیشہ ،نہ گژِھہ تِہنٛدِ س عذا بس منٛز کٔمی،تہٕ نہ یِیہِ تِمن پتہٕ بیٚیہِ کانٛہہ دوٚ یِم مہلت دِنہٕ۔"
  2,163,"۔تُہُند خُدا ے چُھ کُنُے خدا ے، تس رحمان و رحیمس وَرٲے چُھنہٕ بیٚیہِ کانٛہہ خدا ے ،"
  2,164,"۔﴿یہِ حقیقت پرٛزنا و نہٕ خٲطرٕ اگر کانٛہہ نشٲنی تہٕ علا مت در کار چھےٚ  تیٚلہِ چھےٚ ﴾پٔزۍ پٲٹھۍ آسما نن تہٕ زمین کِس بناوٹس منٛز رٲژ ہٕندِس تہٕ دۅ ہ کِس اکھ أکِس پتہٕ پیہم یِنس منٛز تِمن ناوَن منٛز یِمہٕ انسان سٕندۍ نفع وٲلۍ چیز ہیٚتھ دٔرِیاو ن تہٕ سمندرن منٛز پھیران تھوران چھےٚ ،روٗدٕ کِس تتھ آبس منٛز یتھ اللہ تعالیٰ ہیٚرِ چُھ والان پتہٕ چُھ امہِ سٍتۍ مۅردٕ زمینس زند گی بخشا ن تہٕ ﴿پننہِ اَمی انتظام  کہ بد و لتہٕ چُھ ﴾ زمینس پٮ۪ٹھ ہر قسمٕکۍ زُودار مخلو ق پھۂلاوان واوَن ہٕندِس گردشس منٛز ،تہٕ تِمن اوٚبرٕ لنگیٚن منٛز یِم آسما نس تہٕ زمینس منٛز با گ فر مانٕکۍ تٲبع چِھ بنٲوِ تھ تھا و نہٕ آمٕتۍ چھےٚ بےٚ شمار نشٲنیہِ تِمن خٲطرٕ یِم لُکھ عقلہِ کٲم چِھ ہیٚوان۔"
  2,165,"۔﴿مگر اللہ تعالیٰ سٕندِس کُن آسٕنس پٮ۪ٹھ دلالت کر ن واجِنہِ یٖژاہ ٹا کارٕ نشٲنیہِ آسنہٕ با و جود تہِ چِھ﴾کینٛہہ لُکھ تِتھۍ یِم خُدا یس ورٲے دوٚیِمیٚن تٔمۍ سُند ہَمسر تہٕ مدِ مُقٲبل چِھ بناوان تہٕ تِہُند چُھکھ تِیُتھ محبت یُتھ محبت خدا یس سٍتۍ گوٚژھ آسُن حالانکہ ایمان وٲلۍ لُکھ چِھ سارِوٕے کھۅتہٕ زیادٕہ خُدا یس ٹوٹھ تھاوان، کاش یِکینژھا ہ یِمن عذا ب وُچِھتھ فِکرِ تَرَن وول چُھ ،سُہ گوٚژھ أزۍ یِمن ظٲلِمن فِکرِ تَرُن کہ سٲر ی طا قت تہٕ سٲر ی اختیار چِھ اللہ تعالیٰ سٕنٛدِ سٕے قبضس منٛز تہٕ یہِ زِ اللہ تعالیٰ چُھ سزا دِنس منٛز تہِ سٮ۪ٹھاہ سخت۔"
  2,166,"۔ییٚلہِ سُہ سزا دِیہِ تمہِ وقتہٕ آسہِ حا لت یہِ زِ تِمے پیشوا تہٕ رہنما ،یِہٕنز دُنیا ہس منٛز پیروی ٲس آمٕژ کر نہٕ، کر ن پننیٚن پیر وکار ن نِشہِ لا تعلقی ہُنٛد اظہا ر مگر سزا تہِ یِیکھ ضرور دِنہٕ تہٕ تِہنٛدٮ۪ن سارِنٕے اَسبا بن تہٕ وسٲیلن ہُنٛد سلسلہِ ژھیٚنہِ۔"
  2,167,"۔تہٕ تِم لُکھ یِم دُنیا ہس منٛز تِہٕنٛز پیروی ٲسۍ کرا ن ،ونَن زِ کا ش اَسہِ یِیہِ ہے بیٚیہِ اکہِ لٹہِ مو قع دِنہٕ ، تیٚلہِ یِتھہٕ پٲٹھۍ یِم اَز اَسہِ نِشہِ بے زٲر ی چِھ ظٲہر کران، أسۍ تہِ ہاوٕ ہَو یِمن نِشہِ بے زار سپدِ تھ ،یِتھہٕ پٲٹھۍ اَنہِ اللہ تعالیٰ یِمن لُکن ہٕنٛدۍ تِم اعما ل، یِم دُنیا ہس منٛز یِم کران چِھ ، یِمن برونٛہہ کُن تِتھہٕ پٲٹھۍ زِ یِم روزَن حسر ت تہٕ پَشیمٲنیو سان اتھہٕ موٗران مگر نارٕ منٛزٕ نیر نٕچ کانٛہہ وَتھ لبن نہٕ ۔ع"
  2,168,"۔اے لوٗکو! زمینس منٛز یِم حلال تہٕ پاک چیز چِھ تِم کھیٚیِو تہٕ شیطا ن سٕنٛز ن وَنہِ مَژن وَتن پٮ۪ٹھ مہ پٔکِو۔سُہ چُھ نَنہِ وانہٕ تُہُنٛد دشمن،"
  2,169,"۔ تۅہیہِ چُھو سُہ بد ی تہٕ بے حیٲیی ہُنٛد حُکم دِوان بیٚیہِ چُھو یہِ ہیٚچھنا وان زِ توٚہۍ ؤنِو اللہ تعالیٰ سٕنٛدِ س ناوَس پٮ۪ٹھ تِمہٕ کتھہٕ یِمن متعلق نہٕ تۅہیہِ علم چُھ زِ ﴿تِمہٕ چھےٚ خُدا ین فر ماوِ مژٕ۔﴾"
  2,170,"۔تِمن ییٚلہِ وَننہٕ چُھ یِوان زِ خُدا ین یِم احکام چِھ نٲزِل کٔرِ مٕتۍ تِہٕنٛز کٔرِ و پیروی تیٚلہِ چِھ جوا ب دِوان زِ أسۍ کر و تَمی طر یقٕچ پیر وی یتھ پٮ۪ٹھ اَسہِ پنُن مو ل بُڈِ بب چُھ وُچھمُت، اچھا  اگر تِہنٛد ۍ مٲلۍ بُڈِ بَبن عقلہِ آسہِ نہٕ کٲم ۂِیژ مٕژ تہٕ سِیٔز وَتھ آسیٚکھ نہٕ لبٔمٕژ، کیا تیٚلہِ روزنہٕ یِم اَمہِ پتہٕ تہِ تِہنٛزٕ ے پیر وی کرا ن؟"
  2,171,"۔یِم لُکھ یِمو اللہ تعالیٰ سٕنٛدِس ؤنۍ مٕتِس طریقس پٮ۪ٹھ  پکنہٕ نِشہِ انکار کوٚر مُت چُھ،یِہٕنٛز حا لت چھےٚ بالکل تِژٕھے یِتھہٕ پٲٹھۍ پۅ ہل جانور ن کرٛیٚکھ چُھ لایان تہٕ تِم چِھنہٕ کھٕرٛکوَنہٕ چہِ آواز ورٲے کِہِنۍ تہِ بوزان، یِم چِھ زٔرۍ، یِم چِھ کٔلۍ، یِم چِھ أنۍ اَوَے چَھنہٕ یِمن کتھ فِکرِ تران۔"
  2,172,"۔اے لوٗکویِمَو ایمان چُھو اوٚ نمُت یِم پاک چیز اَسہِ تۅہیہِ بخشمٕتۍ چِھو، تِم کھیٚیِو آرا مہٕ سان تہٕ اللہ تعالیٰ سُنٛد کٔرِ و شکر،اگر توٚہۍ پٔزۍ پٲٹھۍ اللہ تعالیٰ سٕنٛزے بند گی کر ن وٲلۍ چِھو،"
  2,173,"۔اللہ تعالیٰ سٕنٛدِ طر فہٕ اگر کانٛہہ پابند ی تۅہیہِ پٮ۪ٹھ چھےٚ، تیٚلہِ چھےٚ سۅ یہِ زِ موردار مَہ کھیٚیِو ، خوٗنہٕ نِشہِ تہٕ خنز یرٕ سٕنٛدِ مازٕ نِشہِ کٔرِو پر ہیز بیٚیہِ مہٕ کھیٚیِو تِیُتھ کانٛہہ چیز یَتھ پٮ۪ٹھ اللہ تعالیٰ سٕنٛدِ ناوٕ ورٲے بیٚیہِ کانٛہہ ناو آسہِ ہیٚنہٕ آمُت، آ، وۅ نۍ یُس شخٕص مجبور ی ہٕنٛدِ س حا لتس منٛز آسہِ تہٕ سُہ کھیٚیہِ یِمو منٛزٕ کانٛہہ چیز اَمہِ ورٲے زِ سُہ آسہِ قا نو ن پھُٹرا و نُک اِرادٕہ تھاوان یا ضرورت کہ حد نیرِ، تیٚلہِ چُھنہٕ تَس گنا ہ، اللہ تعالیٰ چُھ بخشن وو ل تہٕ رحم کر ن وول ﴿یَتھ آیتس منٛز چُھ حرا م چیز کہ استعمالُک اجازت تریٛیو شرطو سان دِنہٕ آمُت ۔ اکھ یہِ زِ پٔزۍ پٲٹھۍ آسہِ مجبو ر ی ہِنٛز حا لت۔ مثلاً بۅ چھہِ یا ترٛیشہِ دادِ آسہِ زُو س بٔنِتھ آمُت ،یا بیمار سٍتۍ آسہِ زُو نیر نُک خطرٕہ تہٕ اَتھ حا لتس منٛز آسہِ نہٕ حرا م چیز ورٲے بیٚیہِ کانٛہہ چیز میّسر۔دوٚ یِم یہِ زِ اللہ تعالیٰ سُنٛد قا نو ن پُھٹرا ونٕچ خوٲہش آسہِ نہٕ دِلس منٛز۔ ترٛیٛیِم یہِ زِ ضرور تہٕ کھۅتہٕ زیادٕہ گژِھہ نہٕ حدٕ یُن نیر نہٕ، مثلاً حرا م چیزٕ کۍ کینٛہہ میٚنڈۍ یا کینٛہہ قطر ہ یا کینٛہہ دام اگر زُو بچٲوِ تھ ہیٚکن ،تیٚلہِ گژِھہ نہٕ اَمہِ کھۅتہٕ زیادٕہ اَمہِ چیز ک استعمال سپدُن ﴾۔"
  2,174,"۔حق چُھ یہِ زِ یِم لُکھ تِم احکا م چُھپاوان چِھ یِم خُدا ین پننہِ کتا بہِ منٛزٕ نٲزِ ل چِھ کٔرِ مٕتۍ تہٕ معموٗلی دُنیٲوی فٲید ن پٮ۪ٹھ چِھ یِمن چَھپہِ دِوان تِم چِھ در اصل پنٕنۍ شکم نارٕ سٍتۍ برا ن، قیا مت کہِ دۅ ہ کرِ نہٕ اللہ تعالیٰ ہر گز تِمن سٍتۍ کتھ نہ دِیہِ تِمن پا ک قرار،تہٕ تِمن خٲطرٕ چُھ دگ تُلوُن سزا۔"
  2,175,"۔یِم چِھ تِم لُکھ یِمو ہدا یتہٕ بد لہٕ ضلا ت ہِیٔژ موٚلۍ تہٕ مغفرت بدلہٕ ہیوٚتُکھ عذاب موٚلۍ،کِیُتھ عجیب چُھ یُہُنٛد حو صلہٕ زِ جہنمُک عذا ب ویٚتر اونہٕ خٲطرٕ چِھ تیا ر!۔"
  2,176,"۔یہِ سورُے کینٛہہ سپُد اَمہِ و جہِ کِنۍ زِ خُدا ین ٲس ٹھیک حقہٕ مُطٲبق کتا ب نٲزِل کٔرمٕژ مگر یِمو لُکو کتا بہِ منٛز اختلاف کٔرۍ تِم گٔے پننیٚن جِھگڑن منٛز حقہٕ نِشہِ واریاہ دوٗر ۔ ع"
  2,177,"۔نیکی چَھنہٕ یہِ زِ تۅہیہِ کٔرِو پنٕنۍ رۅ خ مشر قس کُن یا مغر بس کُن بلکہ چھےٚ نیکی یہِ زِ انسان گژِھہ خُدا یس تہٕ ٲخرت کِس دۅ ہس تہٕ ملٲیِکن تہٕ اللہ تعالیٰ سٕنٛزِ نٲزِ ل کر نہٕ آمژِ کتا بہِ تہٕ تٔمۍ سٕندٮ۪ن پیغمبر ن دِلہٕ سٍتۍ مانُن تہٕ اللہ تعالیٰ سٕنٛدِس محبتس منٛز گژِھہ پنُن ٹوٹھ مال رشتہٕ دار ن تہٕ یتیمن پٮ۪ٹھ مسکیٖنن تہٕ مُسٲفِر ن پٮ۪ٹھ، مَددٕ خٲطرٕ اَتھہٕ دارن وا لیٚن پٮ۪ٹھ تہٕ غلامن ہٕنٛزِ رہٲیٖی پٮ۪ٹھ خر چ کرُن، نما ز گژِھہ قٲیِم کرُن تہٕ زکوٰتہ گژِھہ دِیُن تہٕ نیک چِھ تِم لُکھ زِ ییٚلہِ عہد کر ن تیٚلہِ کَر ن تَتھ وَفا تہٕ تنگی تہٕ مصیبت کِس وقتس منٛز تہٕ حق و بٲطل کِس جنگس منٛز کر ن صبر ،یِم لُکھ چِھ پٔزِیٲرۍ تہٕ یِمے لُکھ  چِھ متقی۔"
  2,178,"۔اے لوٗکو یِمو ایمان چُھ اوٚ نمُت تُہٕندِ خٲطرٕ چُھ قتل کیٚن مُقدِ مَن منٛز قَصاصُک حُکم لیٚکھنہٕ آمُت، آزاد  شخصن آسہِ قتل کوٚر مُت تیٚلہِ گژِھہ تس آزاد سٕے بد لہٕ ہیٚنہٕ یُن، غلا م آسہِ قاتل تیٚلہِ گژِھہ سُے غلا م یُن قتل کر نہٕ تہٕ زنانہِ آسہِ یہِ جُر م کوٚر مُت تیٚلہِ گژِھہ تٔمۍ سٕے زنانہِ قصا ص یُن ہیٚنہٕ ،وۅ نۍ ہرگاہ کٲنٛسہِ قٲتِلس سٍتۍ تٔمۍ سُنٛد بو ے نر می کَر نہٕ خٲطرٕ تیا ر آسہِ تیٚلہِ گژِھہ معروٗف  طر یقہٕ مطٲبق خو ن بہا ہُک تصیفہٕ سپدُن تہٕ قٲتِلَس چُھ لٲزِ م زِ دیا نت دٲری سان کٔرِن خو ن بہا ﴿خو نُک مُعا و ضہٕ ﴾ ادا ۔﴿ ییٚمہِ آیت نِشہِ سپُد یِتہِ معلو م زِ اسلام کین تعزیرات کین قا نو نن منٛز چُھ قتلُک معا ملہٕ رٲضی نا مس قٲبل۔ قٲتل سُند جان ہیٚنَس پٮ۪ٹھ کرِ اصرار۔ البتہ معٲفی ہٕنٛدِس صوٗرتس منٛز چُھ قٲتِلس خو ن بہا ادا کرُن﴾ یہِ چھےٚ تُہٕندِ س رب سٕندِ طر فہٕ نَر می تہٕ رحمت، اَتھ پٮ۪ٹھ تہِ یُس زیادتی کرِ ﴿مثلاً مقتو ل سُنٛد وٲرِث کرِ خو ن بہا و صو ل کر نہٕ پتہٕ بیٚیہِ انتقا م ہیٚنٕچ کوٗشش ،یا قٲتِل کرِ خو ن بہا ادا کر نَس منٛز اَز پگا ہ تہٕ یُس مقتو ل سٕندۍ وٲرِثن تس سٍتۍ احسان کوٚر مُت چُھ، تَمِیُک بد لہِ دِ یس احسان فر امو شی سٍتۍ ﴾ تس خٲطرٕ چُھ دگ تُلہٕ وُن سَزا۔"
  2,179,"۔شعور تہٕ عقل تھاو ن والیو ، تُہٕنٛدِ خٲطرٕ چھےٚ قصا صس منٛز زند گی اُمید چھےٚ زِ توہۍ کٔرِ و اَمہِ قا نو ن چہِ خلا ف ورزی نِشہِ پر ہیز ۔"
  2,180,"۔تۅہیہِ پٮ۪ٹھ چُھ فر ض آمُت کر نہٕ زِ ییٚلہِ تۅہیہِ منٛزٕ کٲنٛسہِ ہٕنٛدِ مو تُک وقت واتہِ  تہٕ سُہ آسہِ پا نس پتھ کُن مال ترٛا وان تیٚلہِ کٔرِ ن مٲلِس ماجہِ تہٕ رشتہٕ دار ن خٲطرٕ معروٗف طر یقہٕ وصیت ﴿یہِ حُکم اوس تتھ زمانس منٛز دِ نہٕ آمُت، ییٚلہِ زَ ن وراثت بٲگراونہٕ خٲطرٕ وُنہِ کانٛہہ قا نو ن اوس نہٕ مُقرر کر نہٕ آمُت ۔ تمہِ وقتہٕ آو پرٛتھ شخصس پٮ۪ٹھ لٲزِم کر نہٕ زِ سُہ کٔرِن پننیٚن وٲرثن ہٕندۍ حِصّہٕ ؤصیتہٕ سٍتۍ مُقرر تا کہ تٔمۍ سٕندِ مر نہٕ پتہٕ نَہ سپدَن خا ندانس منٛز جھگڑٕ تہٕ نہ سپدِ کٲنٛسہِ حق دارس حق تلفی۔پتہٕ ییٚلہِ ورا ثت بٲگرا و نہٕ خٲطرٕ خُدا ین پانہٕ اکھ ضٲبطہٕ بنو و ﴿ یُس برونٛہہ کُن سورۂ نِساہس منٛز یِنہٕ وول چُھ﴾ پتہٕ کوٚ ر نبی صلی اللہ علیہ وسلمو قٲعدٕہ مقرر زِ وٲرِثن ہٕنٛدۍ یِم حصہٕ خدا ین چِھ مقرر کٔرِ مٕتۍ تِمن منٛز یِیہِ نہٕ وصیت سٍتۍ کمی بیشی کر نہٕ۔ تہٕ غیر وٲرث سٕنٛدِس حقس منٛز گژِھہ نہٕ کُل جایدادٕ کہ اکھ تِہٲیی کھۅتہٕ زیادٕہ وصیت کرٕنۍ۔بیٚیہِ ہیٚکن نہٕ مسلم تہٕ کٲفر پانہٕ وٲنۍ وٲرث ٲسِتھ ﴾ یہِ چُھ حق مُتقی لُکن پٮ۪ٹھ ،"
  2,181,"۔پتہٕ یِمو وصیت بوٗزتہٕ پتہٕ بد لٲوٕ کھ سۅ ، تیٚلہِ آسہِ تَمِیُک گنا ہ تِمن بد لاو ن والیٚن پٮ۪ٹھ، اللہ تعالیٰ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  2,182,"۔البتہ ییٚمِس یہِ اند یشہِ آسہِ زِ وصیت کر ن وٲلۍ چھےٚ نادٲنستہٕ یا قصداً حق تلفی کٔرمٕژ تہٕ پتہٕ کرِ سُہ معا ملس سٍتۍ تعلق تھاو ن والیٚن در میان اِصلا ح، تیٚلہِ چُھنہٕ تَس کانٛہہ گنا ہ ،اللہ تعالیٰ چُھ بخشن وول تہٕ رحم کر ن وول ۔ ع"
  2,183,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت، تۅہیہِ پٮ۪ٹھ آیہِ روزٕ ہ فر ض کر نہٕ یِتھہٕ پٲٹھۍ تۅہیہِ برٛو نٹھمیٚن پیغمبر ن ہٕند ٮ۪ن پیر وکارن پٮ۪ٹھ فر ض آسہٕ آمٕژ کر نہٕ تَو قع چُھ زِ اَمہِ سٍتۍ گژِھہ تۅہیہِ منٛز تقویٰ ہُک صفت پٲدٕہ۔"
  2,184,"۔یِم چھےٚ کینٛژھن مُقرر دۅ ہن ہٕنٛزٕ روزٕہ اگر  تۅہیہِ منٛز کانٛہہ بیما ر آسہِ۔ یا سفر س پٮ۪ٹھ آسہِ تیٚلہِ کٔرِن با قین دۅ ہن منٛز یُتُے تعداد پوٗرٕ تہٕ یِم لُکھ روزٕہ تھا و نُک طا قت آسن تھاوان ﴿پتہٕ تھاوَن نہٕ ﴾ تیٚلہِ دِیِن تِم فِد یہِ ۔ اکہِ روزٕ ہ ﴿دۅ ہُک ﴾ فِد یہِ چُھ اکھ مسکین کھیٚن کِھیٚا وُن تہٕ یُس پننہِ خو شی سا ن زیادے رٕژَر وَرتاوِ، تیٚلہِ چُھ یہِ تٔمۍ سٕندی خٲطرٕ بہتر البتہٕ اگر توٚہۍ سمجھِو ،تیٚلہِ چُھ تُہٕنٛدِ خٲطرٕ یٖی جا ن زِ روزٕ تھٲوِ و ﴿ اسلام کیٚن اکثر احکامن ہٕندۍ پٲٹھۍ آیہِ روزَن ہٕنٛز فر ضیت تہِ وارٕ وارٕ عٲید کر نہٕ ۔نبی صلی اللہ علیہ وسلمو اوس مسلمانن ابتدا ہس منٛز پرٛتھ ریٚتہٕ صرف ترٛ ٮ۪ن دۅ ہن روزٕ ہ تھا و نُک ہدا یت فر مو و مُت، مگر یِمہٕ روزٕ ہ آسہٕ نہٕ فر ض ۔پتہٕ گوٚو ، 2 ہجر ی منٛز  رمضا ن چن روزن ہُنٛد یہِ حُکم نٲزِل ،مگر اَتھ منٛز آیہِ یہِ رعایت تھاو نہٕ زِ یِم لُکھ روزٕہ برداشت کر نُک طا قت آسن تھاوان تہٕ امہِ پتہٕ تہِ تھاون نہٕ روزٕ ہ، تِم کھیٚٲوِن پرتھ روزٕ ہ دۅ د بد لہٕ أکِس مسکینس کھیٚن۔ پتہٕ سپُد بیٚاکھ حُکم نٲزِل یُس برونٹھ کُن یِیہِ ﴾۔"
  2,185,"۔رمضان چُھ سُہ ریٚتھ یَتھ منٛز قرآن آو نٲزِل کر نہٕ یُس انسانن خٲطرٕ سراسر ہدا یت چُھ تہٕ تِژھن وا ضح تعلیماتن پٮ۪ٹھ چُھ مُشتمل ،یِمہٕ سِیٔز وَتھ ہاوَن واجِنہِ تہٕ حقَس تہٕ بٲطلس فر ق کر ن واجِنہِ چھےٚ لہٰذا ، یُس شخٕص وُنۍ کہ پٮ۪ٹھہٕ اَتھ ریٚتس لَبہِ ،تس چُھ لٲزِم اَتھ پوٗرٕ ریٚتس تھٲوِن روزٕ ہ۔تہٕ یُس کانٛہہ مر یض آسہِ یا سفر س پٮ۪ٹھ آسہِ ، تیٚلہِ کٔرِن سُہ با قین دۅ ہن منٛز روزن ہُنٛد تعداد پوٗرٕ ،اللہ تعالیٰ چُھ تۅہیہِ سٍتۍ نر می یژھان کرٕنۍ سختی چُھنہٕ یژھان کرٕ نۍ امہِ مو جوٗب چُھو تۅہیہِ یہِ طر یقہٕ وَننہٕ یِوان تا کہ توٚہۍ ہیٚکِو روزن  ہُنٛد تعداد پوٗرٕ کٔرِ تھ تہٕ ییٚمہِ  ہدا یت سٍتۍ خُدا ین توٚہۍ سرافر ز چِھنو کٔرِ مٕتۍ ،تتھ پٮ۪ٹھ کٔرِ و اللہ تعالیٰ سٕنٛزِ کبر یٲیی ہُنٛد اظہا ر تہٕ اعترا ف بیٚیہِ بٔنِو شُکر گُزار ۔"
  2,186,"۔تہٕ اے نبی صلی اللہ علیہ وسلم ،میٲنۍ بندٕہ اگر تۅہیہِ مےٚ متعلق پٕرٛژھن تیٚلہِ وَنِو تِمن زِ بہٕ چُھس تِمن نکھے ،نادلاین وول ییٚلہِ مےٚ ناد چُھ لایان، بہٕ چُھس تٔمۍ سُنٛد آلو بوزان تہٕ جواب چُھس دِوان، لہٰذا پَزِ تِمن زِ میٲنِس دعوتس پٮ۪ٹھ ؤنِن لبیک تہٕ مےٚ پٮ۪ٹھ أنِن ایمان،﴿یہِ کتھ بوزنٲوِیوٗکھ تِم ﴾ بنان چُھ زِ تِم لبن  سِیٔز وَتھ۔"
  2,187,"۔تُہٕنٛدِ خٲطرٕ چُھ روزَ ن ہٕندِس زمانس منٛز رٲژن اندر پننیٚن خاندارِنیٚن نِشہِ گژُھن حلال کر نہٕ آمُت تِمہٕ چھےٚ تُہندِ خٲطرٕ لبا س تہٕ توٚہۍ چِھو تِہنٛدِ خٲطرٕ لبا س خُدا یس سپُد معلو م زِ توٚہۍ ٲسِو ژوٗرِ ژوٗرِ پننِس پا نس سٍتۍ خیا نت کرا ن مگر تٔمۍ کوٚر تُہُنٛد قصور معا ف تہٕ تۅہیہِ کوٚرنَو در گُزر ،وۅ نۍ ہیٚکِو توٚہۍ پننیٚن خاندارِنیٚن سٍتۍ رات گُزٲرِتھ تہٕ یُس لطف خُدا ین تُہنٛدِ خٲطرٕ جٲیز چُھ کوٚر مُت ،سُہ کٔرِ و حٲصل، اَمہِ علا وٕ ہ کھیٚیِو چیٚیِو رٲژن اندر توٚت تام یوٚت تا م زِ تۅہیہِ رٲژ ہٕنٛزِ سیا ہ داوِ نِشہِ صُبح ہٕچ سفید داو نٔنۍ پٲٹھۍ اَتھہِ یِیہِ ،تیٚلہِ کٔرِ و یِمہٕ سار ے کامہِ ترٲوِ تھ رٲژ تام پنُن روزٕ ہ پوٗرٕ تہٕ ییٚلہِ توٚہۍ مسجدِ ن منٛزٛ اعتکا فس ٲسِو، تیٚلہِ مَہ کٔرِو خاندارِ نیٚن سٍتۍ مُبا شر ت، یِم چِھ اللہ تعالیٰ سٕنٛدۍ گنڈ نہٕ آمٕتۍ حد یِمن نکھہٕ گٔژِھۍ زیٚو نہٕ، یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ پنٕنۍ احکام لُکن خٲطرٕ وضا حت سان بیان کرا ن، تو قع چُھ زِ تِم بچن غلط رٔوِ یہِ نِشہِ ۔"
  2,188,"۔تہٕ توہۍ لُکھ نَہ مَہ کھیٚیِو پانہٕ وٲنۍ اکھ أکۍ سُنٛد مال نا جٲیز طر یقہٕ تہٕ نہ مہ کٔرِ و حٲکِمن برونٛہہ کنہِ تِم اَمہِ غر ضہٕ پیش زِ تۅہیہِ میلیو دوٚ یِمیٚن ہٕندِ مالُک کانٛہہ حِصہٕ قصد اً ظٲلما نہٕ طر یقہٕ سٍتۍ کھیٚنُک مو قع ۔ع ﴿اَمہِ آیتُک اکھ مفہو م چُھ یِتہِ زِ حٲکِمن رُشو ت دِتھ مہ کٔرِو نا جٲیز فا یدٕ تُلنٕچ کوشِش تہٕ دوٚ یُم مفہو م چُھس یہِ زِ ییٚلہِ توٚ ہۍ پانہٕ زانان چِھو زِ مال چُھ دوٚ یِمس شخصہٕ سُند ،تیٚلہِ مَہ نِیِو تٔمۍ سُنٛد مُقد مہٕ عدا لتس محض امہِ موجوٗب زِ تس نِشہِ چُھنہٕ مِلکِیتُک کانٛہہ ثبو ت یا اَتھ بنیا دس پٮ۪ٹھ زِ ٹڈ بٲزی سٍتۍ ہیٚکِو توٚہۍ یہِ کھیٚتھ۔یِتہِ چُھ بنان زِ عدا لتُک حٲکِم دِیا و نا وِ مُقد مہٕ کہِ رپورٹ کہِ لحا ظہٕ سُہ مال تۅہیہِ ۔ مگر سُہ آسہِ نہٕ تُہُنٛد جٲ یز مال کینٛہہ ۔﴾"
  2,189,"۔اے نبی صلی اللہ علیہ وسلم ، لُکھ چُھو تۅہیہِ زوٗنہِ ہٕنٛدِ س لۅکٹنس تہٕ بڈ نس متعلق پٕرٛژھان، وَنِو : یِمہٕ چھےٚلُکن خٲطرٕ تٲر یخ مُقرر کر نہٕ چہِ تہٕ حج چہِ علا متہٕ بیٚیہِ وَنِو یِمن : یہِ چَھنہٕ کانٛہہ نیکی ہٕنٛز کٲم زِ توٚہۍ چِھو پننیٚن گھر ن منٛز پٔتِمہِ طر فہٕ اَژان، درا صل چھےٚ نیکی یہِ زِ انسان بچہِ اللہ تعالیٰ سٕنٛز ناراضگی نِشہِ، لہٰذا ٲسِو توٚہۍ پننیٚن گھر ن منٛز دروازٕکِنی یِوان البتہ خُدا یس روٗزِ و کھۅژان ۔شا ید زِ تۅ ہیہِ سپدِ یٚو کا میٲبی نصیب﴿ تِمو سارِوٕے تو ہم پر ستا نہٕ رَسمو منٛزٕ ، یِم عر بس منٛز رٲیج ٲسۍ اوس اکھ رسم یِتہِ زِ ییٚلہِ تِم حج خٲطرٕ احرا م ٲسۍ گنڈان،تیٚلہِ ٲسۍ تِم دروازہ بجاے پٔتِمہِ دیوارٕ پیٚٹھۍ گھرس منٛز اژان یا ٲسۍ پٔتِمہِ لَبہِ دٲر بنٲوِتھ گھرس منٛز داٍخل سپدان۔ امہِ علا وٕ ہ ییٚلہِ سفرٕ پٮ۪ٹھہٕ یِہَن ، تمہِ ساعتہٕ تہِ ٲسۍ مکا نس منٛز پٔتِمہِ اَندٕ اَژان۔یتھ آیتس منٛز چُھنہٕ صرف اَمہِ رسمُک تردید آمُت کر نہٕ بلکہ چُھ تمام وہمن پٮ۪ٹھ یہِ ؤنِتھ ضر ب آمُت  لگا و نہٕ زِ نیکی چھےٚ  درا صل خُدا یس کھۅژنُک تہٕ تٔمۍ سٕنٛد  ٮ۪ن احکامن ہنٛزِ خلا ف ورز ی نِشہِ بچنُک ناو﴾۔"
  2,190,"۔تہٕ توٚہۍ لٔڑِ و اللہ تعالیٰ سٕنٛزِ وَتہِ منٛز تِمن لکُن  سٍتۍ یِم تۅہیہِ سٍتۍ لڑا ن چِھ مگر زیادتی مہ کٔرِ و تِکیازِ اللہ تعالیٰ چُھنہٕ زیادتی کر ن والیٚن پسند کرا ن۔"
  2,191,"۔تِمن سٍتۍ لٔڑِ و یَتھ جایہِ تہِ تۅ ہیہِ تِمن سٍتۍ مُقا بلہٕ پیش یِیہِ تہٕ تِم کٔڑیوٗکھ تَتہِ  ییٚتہِ تِمو توٚہۍ چِھہمَو کٔڑِمٕتۍ اَمہِ موجوٗب زِ قتل اگر بُرٕ ہ چُھ، مگر فِتنہٕ چُھ اَمہِ کھۅ  تہٕ تہِ بُرٕ، یَتھ جایہِ چُھ فتنہٕ مُراد زِ کانٛہہ چھۅکھ یا کانٛہہ شخص محض اَتھ بنیادس پٮ۪ٹھ ظلم و سمتُک نشا نہٕ بناوُن زِ تٔمۍ چُھ بٲطل ترٛٲوِ تھ حق کوٚر مُت قبو ل﴾ تہٕ مسجدِ حرا مس نکھہٕ یوٚت تام نہٕ تِم تۅہیہِ سٍتۍ لڑ ن ،توٚہۍ تہِ مہ لٔڑِو مگر ییٚلہِ تِم تَتہِ لڑ نس ہِرا سہٕ کرن نہٕ ، تیٚلہِ کٔرِ یوٗکھ توٚہۍ تہِ کُنہِ ہِرا سہٕ ورٲے قتل، یِتھیٚن کٲفر ن چُھ یۅ ہے سزا۔"
  2,192,"۔پتہٕ اگر تِم با ز پھیرن تیٚلہِِ زٲنِو زِ اللہ تعالیٰ چُھ معا ف کر ن وول تہِٕ رحم کر ن وول ۔"
  2,193,"۔توٚہۍ روٗزِ و تِمن سٍتۍ لڑا ن یوٚت تام نہٕ فِتنہٕ ختم گژِھہ تہٕ دین بنہِ اللہ تعالیٰ سٕندِ خٲطرٕ پتہٕ اگر با ز پھیر ن  تیٚلہِ سمجِھو زِ ظٲلِمن ور ٲے چَھنہٕ کٲنٛسہِ پٮ۪ٹھ دست درٲزی روا کینٛہہ۔"
  2,194,"۔ماہِ حرا مُک بدلہٕ چُھ ماہِ حرا مٕے تہٕ تمام حُر متَن ہُنٛد لحا ظ سپدِ برابر ی سان ﴿عر ب کیٚن لُکن منٛز اوس حضر تِ ابرا ہیم علیہ السلامن ہٕنٛدِ وقتہٕ پٮ۪ٹھہٕ یہِ قٲعدٕ ہ چلان آمُت زِ ذی القعدہ ، ذی الحجہ تہٕ مُحر م ،یِم ترٛےٚ ریٛتھ ٲسۍ حج خٲطرٕ مخصو ص تہٕ ماہِ رجب اوس عمرٕ ہ خٲطرٕ مخصو ص آمُت تھاو نہٕ، یِمن ژۅ ن ریٚتن منٛز ٲس قتل و غا رت گر ی منع ۔ تا کہِ کعبٕکۍ زیارت کر ن وٲلۍ گژَھن امن و امان سان اللہ تعالیٰ سٕندِس گھرس تام تہٕ پننیٚن گھر ن تہِ ہیٚکن آرا م سان واپس گٔژِھتھ ۔ أتھۍ بنیا دس پٮ۪ٹھ اوس یِمن ریٚتن حرا م ریٚتھ یِوان وننہٕ ﴾۔لہٰذا یُس تۅہیہِ پٮ۪ٹھ دست درٲزی کرِ، توٚہۍ تہِ کٔرِو تس پٮ۪ٹھ تِتھے پٲٹھۍ دست درٲزی، اللہ تعالیٰ چُھ تِمنٕے لُکن سٍتۍ ،یِم تٔمۍ سٕندۍ حد پھُٹرا ونس چِھ پر ہیز کرا ن۔"
  2,195,"۔ اللہ تعالیٰ سٕنٛزِ وتہِ منٛز کٔرِ وخر چ تہٕ پننیٚو اَتھو مَہ ترٲوِ و پنُن پان ہلا کتس منٛز ،احسا نُک طر یقہٕ کٔرِ و اختیار تِکیازِ اللہ تعالیٰ چُھ احسان کرن والیٚن پسند کرا ن،"
  2,196,"۔اللہ تعالیٰ سٕنٛزِ خۅ شنوٗدی خٲطرٕ ییٚلہِ حج تہٕ عمر ہ خٲطرٕ نیت کٔرِ و تیٚلہِ کٔرِ و سۅ پوٗرٕ تہٕ اگر وَتہِ منٛز کُنہِ جا یہِ پیٚیِو، تیٚلہِ یۅسہٕ تہِ قر بٲنی میّسر یِیَو ،اللہ تعالیٰ سٕندِس در بارس منٛز کٔرِو پیش ﴿یعنی ہرگاہ وَتہِ منٛز کانٛہہ تِیُتھ سبب پیش یِیہِ ییٚمہِ کِنۍ برونٛہہ پکُن نا ممکن آسہِ،تہٕ مجبوراً پیٚیہِ رُکُن،تیٚلہِ یُس تہِ جانور اونٹ،گاو،ژھاوٕج، یِمَو منٛزٕ میسر آسہِ، اللہ تعالیٰ سٕندِ خٲطرٕ کٔرِ و قر بان﴾ تہٕ پننیٚن کلَن مہ کٲسِو مَس یوت تام نہٕ قر بٲنی پننہِ جایہِ واتہِ مگر یُس شخٕص مر یض آسہِ یا ییٚمِس کلس کانٛہہ تکلیف آسہِ اَمہِ موجوٗب کاسہِ کلس مَس تیٚلہِ پزِ تس زِ فد یہِ رٔنگۍ تھٲوِ ن روزٕہ نَتہٕ دِیِن صد قہٕ یا کٔرِ ن قر بٲنی۔  حد یث نِشہِ چُھ  پے لگان زِ نبی صلی اللہ علیہ وسلمو چُھ اَتھ صوٗرتس منٛز ترٛ ٮ۪ن دۅ ہن روزٕ تھاونُک یا شیٚن مسکینن کھیٚن کِھیٚا و نُک یاکم از کم اکھ ژھاوٕج ذبح کر نُک حُکم دِیُتمُت﴾پتہٕ اگر تۅہیہِ اَمن نصیب سپدِ ﴿یعنی سُہ سبب گژِھہ دوٗر ییٚمہِ کِنۍ تۅہیہِ وَتہِ اوسُو پیٚو مُت مجبوراً رُکُن تہٕ توٚہۍ وٲتِو حجہِ برٛونٛہہ مکّہ﴾ ،تیٚلہِ یُس شخٕص تۅہیہِ منٛزٕ حجُک وقت واتنس تام عُمرُک فٲیدٕ ہ تُلہِ سُہ دِیِن مقدوٗرٕ مُطٲبق قر بٲنی تہٕ ہر گاہ قر بٲنی میّسر آسہِ نہٕ تیٚلہِ تھٲوِ ن ترٛےٚ روزٕہ حج کِس وقتس منٛز تہٕ ستھ ﴿7﴾ تھٲوِ ن گھرٕ وٲتِتھ ،یِتھہٕ  پٲٹھۍ تھٲوِ ن پوٗرٕ داہ روزٕ ہ، یہِ رعا یت چھےٚ تِمن لُکن خٲطرٕ،یِہنٛدۍ گھرٕ مسجدِ حرامَس نکھہٕ آسن نہٕ، اللہ تعالیٰ سٕندٮ۪ن یِمن احکامن ہٕنٛزِ خلا ف ورزی نِشہِ بٔچِو تہٕ ٹھیک پٲٹھۍ زٲنِو زِ اللہ تعالیٰ چُھ سخت سزا دِنہٕ وول ۔ ع"
  2,197,"۔حجِکۍ ریٚتھ چِھ سارِنٕے معلو م، یُس شخٕص یِمن مُقرر کر نہٕ آمتیٚن ریٚتن منٛز حجِچ نیت کرِ تس پزِ خبردار روزُن زِ حجس دورا ن گژِھہ نہٕ تس کانٛہہ شہوٲنی حرکت ، کانٛہہ بد عملی ،کانٛہہ لڑا یہِ جھگڑٕ چ کتھ سرزد سپٕد نۍ تہٕ یۅسہٕ نیک کٲم توٚہۍ کٔرِ و ، تَمِیُک علم آسہِ خُدا یس ۔حج کہ سفرٕ خٲطرٕ تُلِو وَتہٕ خرٕ چ سٍتۍ، تہٕ سارِ وٕ ے کھۅ تہٕ بہتر زادِراہ ﴿وَتہٕ خر چ ﴾ چُھ پر ہیز گٲر ی، پَس اے ہو شمندو ! میانہِ نا فر مٲنی نِشہِ کٔرِ و پر ہیز ،"
  2,198,"۔تہٕ ہر گاہ حجس سٍتۍ سٍتۍ توٚہۍ اللہ تعالیٰ سُنٛد فضل تہِ ژھٲرِ و ، تیٚلہِ چُھنہٕ اَتھ کانٛہہ حر ج﴿ربّ سُنٛد فضل ژھا ر نُک مطلب چُھ سفرس دورا ن روزٕ گارٕ خٲطرٕ کانٛہہ کٲم کرٕنۍ ﴾ پتہٕ ییٚلہِ عر فات کِنۍ پٔکِو تیٚلہِ کٔرِ یوٗن مَشعرِ حرا مَس ﴿مُز دلفہٕ ﴾ نِشہِ ٹھہرِ تھ اللہ تعالیٰ یاد تہٕ تِتھہٕ پٲٹھۍ کٔرِیوٗن یاد ،ییٚمیُک ہدایت تٔمۍ تۅہیہِ دِیٛتمُت چُھو ،اَمہِ برونٛہہ ٲسِو نَتہٕ توٚہۍ لُکھ وَتہِ ڈٔلِمٕتۍ ،"
  2,199,"۔پتہٕ ییٚمہِ جایہِ پٮ۪ٹھہٕ با قی سٲر ی لُکھ پوٚت چِھ پھیران ،تَتی پٮ۪ٹھہٕ پھیٖرِ و توٚہۍ تہِ پوٚت تہٕ خُدا یس منگِو معٲفی ﴿حضرت ابرا ہیم علیہ السلام تہٕ اسماعیل علیہ السّلا من ہٕنٛدِ س زمانس منٛز اوس عر بُک معر و ف حجُک طر یقہٕ  یہِ زِ 9 ذی الحجہ ٲسۍ مِنیٰ پٮ۪ٹھہٕ عَر فات گژھان تہٕ تَتہِ پھیٖرِ تھ ٲسۍ راتس مُزدلفہ ہس منٛز ٹھہرا ن ۔ مگر اَمہِ پتہٕ ییٚلہِ وارٕ وارٕ قر یشن ہٕنٛز بر ہمنّیت قٲیِم سپٕز، تِمو ووٚ ن : أسۍ چِھ اہلِ حرا م ، یہِ کتھ چھےٚ سانہِ مَر تبہٕ نِشہِ ؤسۍ پایہِ زِ أسۍ گژھوعا م عر ب کیٚن لُکن سٍتۍ عر فا تَس تام۔چنا نچہِ تِمو کٔرپننہِ خٲطرٕ یہِ امتیٲزی شان قٲیِم زِ تِم ٲسۍ مُزدلفہ پٮ۪ٹھے وا پس یِوان تہٕ عام لُکن ٲسۍ ترٛاوان عر فاتس تام گژھنہٕ خٲطرٕ تٔتی۔امہِ فخر و غرورُک پۅ تُل آو یتھ آیتس منٛز پھُٹرا و نہٕ ﴾ یقیناً چُھ سُہ معا ف کر ن وول تہٕ رحم فر ماون وول۔"
  2,200,"۔پتہٕ ییٚلہِ پننہِ حجِکۍ ارکان ادا کٔرِ تھ مۅ کلٲوِ و ،تمہِ پتہٕ یِتھہ پٲٹھۍ گۅڈٕ ہ پننیٚن آباو اجدادن ہٕنٛز ذِکر ٲسِو کران، تِتھے پٲٹھۍ کٔرِ و وۅ نۍ اللہ تعالیٰ سٕنٛز ذِکر بلکہ اَمہِ کھۅتہٕ تہِ زیادٕہ ﴿مگر خُدا یس یاد کر ن والیٚن منٛز تہِ چھےٚ واریاہ فر ق ﴾ تِمو منٛزٕ چُھ کانٛہہ تِیُتھ، یُس ونان چُھ زِ اے سانہِ ربّہٕ ، اَسہِ دِسورُے کینٛہہ دُنیا سٕے منٛز ،یِتھِس شخصہٕ سٕنٛدِ خٲطرٕ چھُنہٕ ٲخرتس منٛز کانٛہہ حِصّہٕ تہٕ کانٛہہ چُھ ونان زِ ،"
  2,201,"۔اے سانہِ ربّہٕ ! اَسہِ دِ دُنیا ہس منٛز تہِ رٕژَر تہٕ ٲخرتس منٛز تہِ رٕژَر تہٕ نارٕ کہِ عذا ب نِشہِ بچا و اَسہِ۔"
  2,202,"۔پننہِ کما یہِ مُطٲبق میلہِ یِتھیٚن لُکن ﴿دۅ شوٕ نۍ جاین ﴾ حِصّہٕ تہٕ خُدا یس چَھنہٕ حِسا ب نکھہٕ والنس تٲر لگا ن۔"
  2,203,"۔یِم چِھ گٔر نز ہٕندۍ  کینٛہہ دۅ ہ، یِم تۅہیہِ اللہ تعالیٰ سٕندِس یادس منٛز گُزارٕنۍ پَزن پتہٕ ہرگاہ کانٛہہ جلدی کٔرِ تھ دوٚ نۍ دۅ ہن منٛز واپس گوٚو ، تیٚلہِ چُھنہٕ کانٛہہ حر ج تہٕ یُس کینٛژھس کا لس زیادٕہ ٹھٔہرِ تھ پھیٛوٗر،تَمہِ پتہٕ تہِ چُھنہٕ کانٛہہ حرٕ ج ﴿یعنی ایّامِ تشر یقن منٛز گٔژھۍ تن خوا ہ 12 ذی الحجہ یا 13، ذی الحجہ مِنیٰ پٮ۪ٹھہٕ مکّس کُن واپسی، دۅ شوٕ نۍ صورتن منٛز چُھنہٕ کانٛہہ حر ج ﴾ بشر طیکہِ یِم دۅ ہ آسن تٔمۍ تقویٰ سان گُزٲرِمٕتۍ ،اللہ تعالیٰ سٕنٛزِ نا فر مٲنی نِشہِ بٔچِو تہٕ ٹھیک پٲٹھۍ زٲنِو زِ اکہِ دۅ ہ چھےٚ تٔمۍ سٕندِس خد متس منٛز تُہٕنٛز پیشی سپد ن واجِنۍ ۔"
  2,204,"۔اِنسانن  منٛز چُھ کانٛہہ تِیُتھ ،ییٚمہِ سٕنٛزٕ  کتھہٕ تۅہیہِ دُنیا چہِ زند گی منٛز واریاہ جان چَھو با سان تہٕ پننہِ نیک نیتی پٮ۪ٹھ چُھ سُہ گرِ گرِ خُدا یس گوا ہ ٹھہرا وان مگر حقیقتس منٛز چُھ سُہ بد تر ین دشمنِ حق آسان۔"
  2,205,"۔ییٚلہِ تس اقتدار چُھ حٲصِل گژھان﴿دوٚ یُم تر جمہٕ ہیٚکیٚس یِتہِ ٲسِتھییٚلہِ سُہ پوٚت چُھ پھیران۔ مطلب یِمہٕ کتھہٕ ؤنِتھ ییٚلہِ سُہ پوٚت چُھ پھیرا ن تہٕ پتہٕ چُھ عملاً یی کرا ن ﴾ پتہٕ چھےٚ زمینس پٮ۪ٹھ تٔمۍ سٕنٛز سٲرٕ ے تگ دَو اَمہِ خٲطرٕ آسا ن زِ فساد پھٔہلاوِ، کھا ہ زمین کرِ برباد تہٕ انسٲنۍ نسل کرِ تباہ حالانکہ اللہ تعالیٰ ﴿یَس سُہ گواہ اوس بناوان ﴾ چُھنہٕ فسادس ہر گز پسند کرا ن ۔"
  2,206,"۔تہٕ ییٚلہِ تَس وَننہٕ چُھ یِوان زِ خُدا یس کھۅژ تیٚلہِ چُھ پننہِ وقا رُک خیا ل تس گنا ہس پٮ۪ٹھ دٔرراوان، یِتھِس شخصَس خٲطرٕ چُھ بَس جَہنمٕے کٲفی تہٕ سۅ چھےٚ واریاہ بُرٕ جاے ۔"
  2,207,"۔دوٚ یِمہِ پا سہٕ چُھ اِنسا نَو منٛزٕ تِیُتھ کانٛہہ شخص تہِ ، یُس اللہ تعالیٰ سٕندِ رضا خٲطرٕ پنُن زُو چُھ دا وَس لاگان تہٕ یِتھیٚن بند ن پٮ۪ٹھ چُھ اللہ تعالیٰ سٮ۪ٹھاہ مہر بان۔"
  2,208,"۔اے ایمان انَن والیو ! توٚہۍ گژِھو پوٗرٕ پٲٹھۍ اسلامس منٛز دٲخل ﴿یعنی کُنہِ ژَٹھ کپٹہِ ورٲے تہٕ تحفظ ور ٲے أنِو پنٕنۍ پوٗرٕ زند گی اسلامَس تحت۔ یہِ گژِھہ نہٕ آسُن زِ توٚہۍ کٔرِ و پنٕنۍ زند گی مختلف حصّن منٛز تقسیم کٔرِ تھ کینٛژھن حِصّن منٛز اسلامٕچ پیر وی تہٕ کینٛہہ حِصّہٕ کٔرِ یوٗکھ اَمہِ چِھ پیر وی نِشہِ الگ ﴾ تہٕ شیطا ن سٕنٛز پیر وی مہ کٔرِوتِکیا زِ سُہ چُھ نَنہِ وانہٕ تُہُنٛد دُشمن۔"
  2,209,"۔یِم ٹا کاہ ہدا یت تۅہیہِ نِشہِ آمٕتۍ چِھ، ہرگاہ یِم لَبنہٕ پتہٕ تۅہیہِ بیٚیہِ لغزِ ش گٔیَو تیٚلہِ زٲنِو ٹھیک پٲٹھۍ زِ اللہ تعالیٰ چُھ سارِنٕے پٮ۪ٹھ غٲلب بیٚیہِ چُھ حکمت وول تہٕ دانا۔"
  2,210,"۔﴿یِمو سارِوٕے نصیحتَو پتہٕ تہٕ ہدایتَو پتہٕ تہِ ہرگاہ لُکھ سیوٚد گژھن نہٕ تیٚلہِ ﴾ کیا تِم چھا اَتھ انتظا رس زِ اللہ تعالیٰ گژِھہ اوٚ برٕ چن چھٔتر ن پٮ۪ٹھ فر شتن سٍتۍ خۅد بذا ت یُن تہٕ پتہٕ گژِھہ فٲصلے سپدُن؟ ٲخر کار ہَے سٲر ی معا ملا ت چِھ اللہ تعالیٰ سٕے نِشہِ پیش سپد ن وٲلۍ۔ع"
  2,211,"۔بنی اسرا یلس پٕرٛژِھو: اَسہِ کِژٕھہ نَنہِ نَنہِ نشٲنیہِ چھےٚ تِمن ہا وِ مٕژ۔﴿تہٕ پتہٕ پٕرٛژِھو یِتہِ تِمنٕے زِ ﴾ اللہ تعالیٰ سٕنٛز نعمت حٲصل کر نہٕ پتہٕ یُس قو م اَتھ سنگدِ لی سان بد لاوان چُھ تتھ قو مَس کِیُتھ سخت سزا چُھ اللہ تعالیٰ دِوان ۔"
  2,212,"۔یِمو لُکو کُفر چ وَتھ اختیار کٔرمٕژ چھےٚ، تِہِندِ خٲطرٕ چھےٚ دُنیا ہٕچ زند گی سٮ۪ٹھاہ ٹٲٹھ تہٕ دِل پسند بناو نہٕ آمٕژ، یِتھۍ لُکھ چِھ ایمانٕچ وَتھ اختیار کر ن والیٚن ہَزٕ ل کرا ن مگر قیا مت کہ دۅ ہ آسن پر ہیز گار لُکھٕے تِہٕندِ مقا بلہٕ عٲلی مقا م، روٗد دُنیا ہُک رِزِ ق ،خُدا یس چُھ اختیار ، یس ییٚژِھہ تس دِیہِ بے حسا ب ۔"
  2,213,"۔ابتدا ہس منٛز ٲسۍ سٲر ی لُکھ أکۍ سٕے طر یقس پٮ۪ٹھ۔﴿پتہٕ روٗزِ نہٕ یہِ حا لت تہٕ اختلا ف سپٕدۍ ظٲہر ﴾ اَمہِ پَتہٕ سوٗزۍ خُدا ین پیغمبر یِم سِیٔز وَتھ اِختیار کر نس پٮ۪ٹھ خۅ ش خبر دِنہٕ وٲلۍ ، تہٕ ہَجہِ وَتہِ ہٕند یٚو نتیجَو نِشہِ کھۅژناون وٲلۍ ٲسۍ تہٕ تِمن سٍتۍ کٔرٕ ن بر حق کتاب نٲزِل تاکہ یِم  اختلاف لُکن در میان حقس متعلق نٔنۍ ٲسۍ درٛامٕتۍ ، تِہُنٛدفٲصلہٕ کرِ ﴿ تہٕ یِم اختلاف نوٚ ن نیرنُک وجہ اوس نہ یہِ زِ ابتدا ہس منٛز اوس نہٕ لُکن حق وننہٕ آمُت ،سۅ کتھ چَھنہٕ ﴾ اختلاف کوٚر تِمو لُکو ،یِمن حقُک علم اوس دِنہٕ آمُت۔ حق ترٲوِتھ کٔڑۍ تِمو روشن ہدا یت حٲصل کر نہٕ پتہٕ محض اَمہِ موجو ب مختلف طر یقہٕ زِ تِم ٲسۍ پانہٕ وٲنۍ زیادتی کرٕنۍ یژھان البتہ یِمو لُکو پیغمبر ن علیہ السلامن پٮ۪ٹھ ایمان اوٚ ن، تِمن ہٲو خُدا ین پننہِ اِذنہٕ سٍتۍ حقٕچ سۅ وَتھ، یَتھ منٛز لُکو اختلاف کوٚر مُت اوس، یَس اللہ تعالیٰ یژھان چُھ، تس چُھ سِیٔز وَتھ ہاوان۔"
  2,214,"۔پتہٕ کیا تۅہیہُِلُکو چُھوٕ ہ سمجھمُت زِ توٚہۍ گٔژِھو یِتھے جنتس منٛز دٲخل حالانکہ وُنہِ گُدریٛا و نہٕ تہِ سورُے تۅہیہِ پٮ۪ٹھ ، یہِ تۅہیہِ برٛوٗنٹھِمیٚن ایمان اَنن والیٚن پٮ۪ٹھ گُدر یو مُت چُھ؟ ﴿مطلب چُھ یہِ زِ انبیا علیہم السلام ییٚلہِ تہِ زانٛہہ دُنیا ہس منٛز آمٕتۍ چِھ ، یِمن انبیا علیہم السلامن تہٕ بیٚیہِ تِمن پٮ۪ٹھ ایمان اَنن والیٚن لُکن آو اللہ تعالیٰ سٕند ٮ۪ن بٲغی تہٕ نافر مان بند ن سٍتۍ سخت مقا بلہٕ پیش تہٕ تِمو کٔر پنُن زُو مصیبتس منٛز ترٛا وِتھ بٲطل طر یقن ہٕندِس مُقا بلس منٛز دینِ حق قٲیِم کر نٕچ کوٗشش ، اَدٕ ہ ہیٚکۍ تِم جنتٕکۍ حقدار سپدِ تھ۔ اللہ تعالیٰ سُنٛدجنت چُھنہٕ یوٗتاہ سوٚگ زِ توٚہۍ تُلِو نہٕ  اللہ تعالیٰ سٕنٛدِ مۅکھہٕ تہٕ تٔمۍ سٕنٛدِ دین خٲطرٕ کانٛہہ تکلیف تہٕ یہِ سپدیٚو تۅہیہِ مفت حٲصل﴾ تِمن  پٮ۪ٹھ آیہِ سختیہِ کر نہٕ،مُصیبت آکھ ،دٕنہٕ وِتھ آے تراو نہٕ حتیٰ کہ وقتٕکۍ رَسوٗلن تہٕ تٔمۍ سٕنٛد یٚو اہل ایمان سٲتھیِو دِژ کریٛکھ زِ اللہ تعالیٰ سُنٛد مدد کر واتہِ؟ ﴿تمہِ وقتہٕ آو تِمن دِلا سہٕ دِنہٕ زِ ﴾ آ،اللہ تعالیٰ سُنٛد مدد چُھ نز دیک ۔"
  2,215,"۔لُکھ چِھ پٕرژھان أسۍ کیا کرَو خرٕچ ؟ جوا ب دِیوٗکھ یُس مال تہِ توٚہۍ خر چ کٔرِو ﴿سُہ کر و ﴾ پننِس مٲلِس ماجہِ پٮ۪ٹھ ،تہٕ رشتہٕ دارن پٮ۪ٹھ،یتیمن تہٕ مسکینن تہٕ مُسا فر ن پٮ۪ٹھ خرٕچ تہٕ یُس تہِ رَژر توٚہۍ کٔرِ و اللہ تعالیٰ آسہِ تمہِ نِشہِ با خبر۔"
  2,216,"۔تۅہیہِ چُھو جنگُک حُکم آمُت دِنہٕ تہٕ سُہ چُھو تۅہیہِ نا گوار۔بنان چُھ زِ اکھ چیز آسہِ تۅہیہِ ناگوار تہٕ سُے آسہِ تُہٕنٛدِ خٲطرٕ بہتر تہٕ بنان چُھ اکھ چیز آسہِ تۅہیہِ پسند تہٕ سُے آسہِ تُہٕندِ خٲطرٕ شر ، اللہ تعالیٰ چُھ زنان ،توٚہۍ چِھو نہٕ زانان۔ع"
  2,217,"۔لُکھ چِھ پٕرٛژھان ماہِ حرا مس منٛز لڑُن کِیُتھ چُھ؟ ؤنیوٗکھ :اَتھ منٛز لڑُن چُھ سٮ۪ٹھاہ بُرٕہ، مگر اللہ تعالیٰ سٕنٛز وَتہِ نِشہِ لُکھ رُکا وٕ نۍ تہٕ خُدا یس سٍتۍ کفر کرُن تہٕ مسجد حرامٕچ وَتھ خُدا پرستن بند کرٕ نۍ، تہٕ حر مٕکۍ روزَن وٲلۍ تتہِ کڑٕنۍ چُھ خُدا یس نز دیک اَمہِ کھۅتہٕ تہِ بُرٕہ تہٕ فتنہٕ چُھ خو ن ریز ی کھۅتہٕ زیادٕہ شد ید ﴿یہِ کتھ چھےٚ أکِس وا قعس متعلق ۔رجب 2 ھ منٛز ٲس نبی صلی اللہ علیہ وسلمو ٲٹھن نفر ن ہٕنٛز اکھ چھۅ کھ نَخلَہ ہَس کُن سوٗز مٕژ۔ یہِ چھےٚ مکّس تہٕ طا یفس در میان اکھ جاے ۔ تہٕ اَتھ چھۅ کہِ اوسُکھ ہدا یت فر مو و مُت زِ قر یشن ہٕندٮ۪ن آیندٕ ہ کیٚن منصو بن تہٕ تِہندِس نقل و حر کتس متعلق کٔرِ و معلو مات حٲصل۔جنگُک کانٛہہ اجا زت اوسُکھ نہٕ دِیتمُت۔مگر وَتہِ سمکُھ یِمن قر یشن ہُنٛد اکھ لۅکُٹ تجارتی قٲفلہٕ۔اَتھ پٮ۪ٹھ کوٚر یِمو حملہٕ، اکھ نفر کوٚرُکھ قتل تہٕ با قی لُکھ أنِکھ مال ہیٚتھ گرِفتا ر کٔرِ تھ مد ینہٕ شر یف۔یہِ کاروٲیی سپٕز تمہِ وقتہٕ، ییٚلہِ زَن ماہِ رجب اوس ختم تہٕ ماہِ شعبان اوس شر وع سپدان تہٕ یہِ کتھ ٲس شکہٕ لد زِ اَما ہ حملہٕ سَپُد اہ ماہِ رجب ﴿یعنی ماہِ حرا مس ﴾ منٛز کِنہٕ ماہِ شعبا نس اندر ۔ البتہ قر یشو تہٕ تِمن سٍتۍ رٔلِتھ در پردٕہ یہو دیو تہٕ منا فقو دِژ اَتھ وا قعس مسلمانن خلا ف بد نا می کر نہٕ مو جوٗب خو ب شہر ت ۔سخت اعترا ضا ت کٔرِ تھ زِ یِم چِھ درٛا مٕتۍ بٔڑۍ اللہ وٲلۍ بٔنِتھ تہٕ حال چُھکھ یہِ زِ ماہِ حرا مس منٛز تہِ چِھنہٕ خو ن ریز ی کر نہٕ نِشہِ ہرا سہٕ کران ۔یِمنٕے اعترا ضن ہُنٛد جواب چُھ یتھ آیتس منٛز دِنہٕ آمُت﴾ تِم روزن تۅہیہِ سٍتۍ لڑا ن حتیٰ کہ اگر تِمن پا نس تام آسِہے ،تیٚلہِ پھرٕ ہا نَو تۅہیہِ پننہِ دِینہٕ نِشہِ پوٚت ﴿تہٕ یہِ سمجھِو ٹھیک پٲٹھۍ زِ ﴾ تۅہیہِ منٛز یُس تہِ کانٛہہ پننہِ دینہٕ نِشہِ پھیرِ تہٕ کُفرٕ کِس حا لتس منٛز دِیہِ زُو تٔمۍ سٕندۍ اعمال گژھن دُنیا ہس تہٕ ٲخرتس دۅ شوٕ نۍ منٛز ضا یع امہِ قسمٕکۍ سٲر ی لُکھ چِھ جہنمی تہٕ ہمیشہ روزن جہنم سٕے منٛز۔"
  2,218,"۔اَتھ بر عکس یِمو لُکو ایمان چُھ اوٚ نمُت تہٕ یِمو اللہ تعالیٰ سٕنٛزِ وَتہِ منٛزٕ گھرٕ بار چُھ ترٛوو مُت تہٕ جہا د چُھکھ کوٚر مُت ﴿جہا دُک معنی چُھ کانٛہہ مقصد حٲصل کر نہٕ مۅ کھہٕ پنٕنۍ انتہٲیی کو شش صَر ف کرٕنۍ۔یہِ چُھنہٕ محض جنگُک ہم معنی۔جنگ خٲطرٕ چُھ قِتا ل لفظ ورتاو نہٕ یِوان۔جہا د چُھ اَمہِ کھۅتہٕ واریاہ وسیع مفہو م تھاوان تہٕ اَتھ منٛز چھےٚ پرٛتھ قسمٕچ جدوجہد شٲمِل ﴾ تِم چِھ اللہ تعالیٰ سٕندِ رحمتٕکۍ جٲیز امیدوار تہٕ اللہ تعالیٰ چُھ تِہنٛز ن لغزِ شن معا ف کر ن وول تہٕ پننہِ رحمت سٍتۍ چُھ تِمن نوازن وول۔"
  2,219,"۔پرٛژھان چِھو:شرا بُک تہٕ زارُک کیا حُکم چُھ؟ ؤنِیوٗکھ:یِمن دۅشوٕنۍ چیز ن منٛز چھےٚ بٔڈ خرٲبی اگر چہِ یِمن منٛز لُکن خٲطرٕ کینٛہہ نفع تہِ چِھ مگر تِہُند گنا ہ چُھ تِہنٛدِ فٲیدٕہ کھۅ تہٕ واریاہ زیادٕہ ﴿یہِ چُھ شرا بس تہ زارس متعلق گۅڈنِیُک حُکم ،یتھ منٛز صر ف نا پسند گی ہُنٛد اظہا ر کٔرِ تھ یہِ ترا و نہٕ چُھ آمُت۔برونٛٹھ کُن یِن سورۂ نسا آیت 43 تہٕ سورۂ ما ید ہ آیت۔نمتھس ،90 منٛز با قی احکام ۔﴾پٕرٛژھان چِھ :أسۍ کیا کر و اللہ تعالیٰ سٕنٛزِ وَتہِ منٛز خر چ؟ وَنیوٗکھ: یِکینٛژھاہ تُہٕنٛدِ ضرورت کھۅتہٕ زیادٕہ آسہِ ﴿یَتھ آیتس چِھ از کل عجیب عجیب معنی کڑ نہٕ یِوان۔حالانکہ آیت کیٚو الفا ظو نِشہِ چُھ صا ف ظٲہر زِ یِم لُکھ ٲسۍ پننہِ مالٕکۍ پانہٕ مٲلِک ۔سوال ٲسۍ یہِ پٕرٛژھان زِ اللہ تعالیٰ سٕنٛدِ رضا خٲطرٕ کیا کرَو أسۍ خر چ ؟ فر ماو نہٕ آو زِ گۅڈٕ ہ کٔرِ و اَمہِ سٍتۍ پننہِ ضرور تہٕ پوٗرٕ۔پتہٕ یہِ ہُرِسُہ کٔرِ و اللہ تعالیٰ سٕنزِ وَتہِ منٛز خرچ،یہِ چھُ رضاکارانہٕ خرچ یُس اَکھ بندہ پننِس ربّ سٕنزِ وَتہِ منٛز پننہِ خوشی سان کران چھُ﴾ یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ تُہنٛدِ خٲطرٕ صاف صا ف  احکام بیان کرا ن۔ شا ید زِ توٚہۍ کٔرِو دنیا  تہٕ ٲخرت دۅ شوٕ نۍ ہٕنز فکر۔"
  2,220,"۔ پرٛژھان چِھو: یتیمن سٍتۍ کیا معا ملہٕ یِیہِ وَرتا و نہٕ ؟ وَنیوٗکھ : یتھ طر ز عملس منٛز تِہندِ خٲطرٕ رٕژَر آسہِ ، سُے وَرتاوُن چُھ بہتر اگر توٚہۍ پنُن تہٕ تِمن ہُنٛد خر چہِ تہٕ لسُن بسُن مُشتر کہٕ تھٲوِ و ، ، تیٚلہِ چُھنہٕ اَتھ منٛز کانٛہہ حر ج۔ٲخر چِھو تۅہیہِ تِم پننی بٲے، برٲیی کر ن والیٚن تہٕ نیکی کر ن والیٚن دۅ شوٕ نۍ ہُنٛد حال چُھ خُدا یس برونٛہہ کنہِ روشن ہرگاہ اللہ تعالیٰ یژِھہ ہے اَتھ معا ملس منٛز کرِ ہے تۅہیہِ پٮ۪ٹھ سختی مگر سُہ چُھ صا حب اختیار آسنہٕ علا وٕہ صا حبِ حکمت تہِ۔"
  2,221,"۔توٚہۍ  کٔرۍ زیٚو نہٕ مُشر ک زنانن سٍتۍ ہر گز نکا ح ،یوٚت تام نہٕ تِمہٕ ایمان اَنن ،اکھ مو من لو نڈ ی چھےٚ أکِس مُشر ک شر یف زادِ کھۅ تہٕ بہتر اگر چہِ تۅہیہِ سو سٮ۪ٹھاہ پسند آسیٚو تہٕ پننیٚن مَستوٗراتن ہُنٛد نکا ح مہ کٔرِ و زانٛہہ مُشرِک مردن سٍتۍ ،یوٚت تام نہٕ تِم ایمان اَنن، اکھ مو من غلام چُھ شر یف مُشرِک سٕنٛدِ کھۅتہٕ بہتر اگر چہِ سُہ تۅہیہِ سٮ۪ٹھاہ پسند آسیٚو ،یِم لُکھ چِھو تۅہیہِ نارس کُن بُلاوان تہٕ اللہ تعالیٰ چُھو تۅہیہِ پننہِ اِذ نہٕ سٍتۍ جنّتس تہٕ مغفر تس کُن بُلا وان تہٕ سُہ چُھ پنٕنۍ احکام وا ضح طور لُکن برونٛہہ کنہِ بیان کران تو قع چُھ زِ تِم رٹن سبق تہٕ نصیحت کر ن قبول ۔ع"
  2,222,"۔ پٕرٛژھان چِھ : حیضُک کیا حُکم چُھ؟ وَنیوٗکھ ،سۅ چھےٚ گند گی ہٕنٛز اکھ حالت اَتھ منٛز روٗزِ و زَنانَو نِشہِ الگ تہٕ تِمن نکھہٕ مَہ گٔژِھو ﴿مطلب چُھ زِ اَتھ حالتس منٛز مَہ کٔرِ و تِمن سٍتۍ مُبا شر ت﴾ یوٚت تام نہٕ تِمہٕ  پاک و صا ف سپد ن  تیٚلہِ گٔژِھو تِمن نِشہِ تِتھہٕ پٲٹھۍ یِتھہٕ پٲٹھۍ خدا ین تۅہیہِ حُکم چُھنَو دِیتمُت، اللہ تعالیٰ چُھ تِمن لُکن پسند کران یِم بد ی نِشہِ پَتھ روزن تہٕ پٲکیز گی کر ن اختیار ۔"
  2,223,"۔تُہٕنٛزٕ زنانہٕ چھےٚ تُہٕنٛدۍ ذرا عت ﴿ڈوٗرۍ﴾ تۅہیہِ چُھو اختیار ،یپٲر ۍ ییٚژِھو ،پننِس زرا عتس منٛز گٔژِھو مگر پننہِ مستقبلٕچ کٔرِ و فکر تہٕ اللہ تعالیٰ سٕنٛزِ نا رٲضی نِشہِ بٔچِو  ﴿یِم چِھ جا مع الفا ظ ،یِمو منٛزٕ چِھ زٕہ مطلب نیران تہٕ دۅ شوٕنۍ ہٕنٛز اہمیت چھےٚ ہشی۔اکھ یہِ زِ پنُن نسٕل بر قرار تھاوٕنٕچ کٔرِ و کوٗشش تا کہ تُہٕنٛدِ دُنیا ترٛا ونہٕ برونٛہہ سپدَ ن تُہٕنٛزِ جایہِ کٲم کر ن وٲلۍ پٲدٕ ہ۔ دوٚ یُم یہِ زِ یُس ینہٕ وول نسٕل توٚہۍ پننہِ جایہِ تھا و ن وٲلۍ چِھو ، سُہ کٔرِ یوٗن دین ، اخلا ق تہٕ انسٲنیت کیٚو جو ہَر و سٍتۍ سجا ونٕچ کوٗشش ﴾ تہٕ وارٕ پٲٹھۍ زٲنِو زِ تۅہیہِ چُھو اکہِ دۅ ہ تٔمِس سمکھُن  تہٕ اے نبی صلی اللہ علیہ وسلم، یِم تُہٕند ٮ۪ن ہدا یتن مانن تِم بوزنٲیوٗکھ کا میٲبی ہٕنٛز تہٕ سعا دتٕچ خۅ ش خبر ۔"
  2,224,"۔اللہ تعالیٰ سُنٛد ناو مَہ کٔرِ و تِتھۍ قسم کھینہٕ خٲطرٕ استعمال یِمو سٍتۍ مقصد آسہِ نیکی نِشہِ تہٕ تقویٰ نِشہِ تہٕ اللہ تعالیٰ سٕند یٚو بند ن ہٕنٛز و نیک کامیو نِشہِ پَتھ  روزُن﴿مطلب کانٛہہ رٕژ کٲم نہ کر نُک قسم کِھیٚون﴾ اللہ تعالیٰ چُھ تُہٕنٛزٕ سار ے کتھہٕ بوزان تہٕ سورُے کینٛہہ چُھ زانان۔"
  2,225,"۔یِم بےٚ معنی قسم توٚہۍ بِلا ارادٕہ کھیٚوان چِھو ، تِمن پٮ۪ٹھ چُھنہٕ اللہ تعالیٰ گرِ فت کرا ن مگر یِم قسم توہۍ پزِ دِلہٕ سان کھیٚوان چِھو ، تِہٕنز پٕرٛژھہٕ گٲر کٔر یٚو سُہ ضرور ،اللہ تعالیٰ چُھ سٮ۪ٹھاہ در گُزر کر ن وول تہٕ بُرد بار ۔"
  2,226,"۔یِم لُکھ پننیٚن گھر واجِنیٚن سٍتۍ تعلق نَہ تھا ونُک قسم کھیٚوان چِھ۔تِہنٛدِ خٲطرٕ  چھےٚ ژۅن ریٚتن ہٕنٛز مہلت ﴿شرح کِس اصطلا حس منٛز چِھ اَتھ ایلا وَنان ۔خاندارس تہٕ خاندار نہِ در میان ہیٚکن نہٕ ہمیشہ خۅ شگوار تعلقا ت روٗزِ تھ۔بِگرٕ نٕکۍ سبب چِھ پٲدٕہ گژھان روزان۔البتہ تِتھِس بِگرٕ نس چُھنہٕ اللہ تعالیٰ سُنٛد شر یعت پسند کران زِ دۅ شوے روزن اکھ أکِس سٍتۍ قا نو نی طور دۅ ن بٲژن ہِندِس رشتس منٛز گٔنڈِتھ،مگر عملاً روزن  اکھ أکِس  نِشہِ تِتھہٕ پٲٹھۍ الگ زِ زَنتہٕ تِم زٕہ بٲژ آسن نہٕ۔ یِتھِس بِگر نَس خٲطرٕ  چھےٚ خُدا ین ژۅ ن ریٚتن ہٕنٛز مہلت مقرر کٔر مٕژ زِ یا تہٕ گژھن تِم اَتھ دورا ن تعلقات دُرست کرٕنۍ، نَتہٕ گژھن دۅ ن بٲژن ہُنٛد رشتہٕ ژٹٕنۍ تاکہ دۅ شوے گژھن اَکھ أکِس نِشہِ آزاد تہٕ یَس سٍتۍ پتہٕ گُزارٕ ہیٚکن کٔرِ تھ تس سٍتۍ کر ن نکا ح﴾ وۅ نۍ اگر تِمو رجو ع کوٚر ، تیٚلہِ چُھ اللہ تعالیٰ  معا ف کر ن وول تہٕ رحیم،"
  2,227,"۔تہٕ ہرگاہ تِمو طلا ق دِنہٕ کُے فٲصلہٕ آسہِ کوٚر مُت تیٚلہِ زٲنِن زِ اللہ تعالیٰ چُھ سورُے بوزان تہٕ زانان ﴿یعنی اگر ژےٚ ہٕٹہٕ مٕٹہٕ خاندارِنۍ ترٲومٕژ چھےٚ ، تیٚلہِ مَہ روز خُدا یس نِشہِ بے خو ف کینٛہہ ،سُہ چُھنہٕ چا نہِ زیادتی نِشہِ ناوٲقف کینٛہہ﴾۔"
  2,228,"۔یِمن مستوراتن طلا ق آسہِ دِنہٕ آمُت ، تِمہٕ تھٲوِن ترٛے ما ہؤری گژھنس تام پنُن پان پَتھ تہٕ تِمن خٲطرٕ چُھنہٕ یہِ جٲیز زِ خُدا ین یِکینٛژھاہ تِہنٛز ن بچہِ دانیٚن منٛز پٲدٕ ہ آسہِ کوٚر مُت ،سُہ تھاوَن کھٔٹِتھ ۔تِمن پَزِ نہٕ ہر گز تہِ یہِ کرُن اگر تِمہٕ خُدا یس تہٕ ٲخرت کِس دۅ ہس پٮ۪ٹھ ایمان چھےٚ تھاوان تہٕ ہرگاہ تِہندۍ خاوند آسن تعلقات درست کر نس پٮ۪ٹھ آمادٕہ ،تیٚلہِ چِھ تِم اَتھ عِدّتس دوران بیٚیہِ تِمن پننِس زوجیتس منٛز واپس رٹنٕکۍ حقدار ﴿یہِ حکم چُھ صرف اَتھ صورتس متعلق یَتھ منٛز خاندارن پننہِ خاندارِنہِ اکھ یازٕہ طلا ق آسن دِتِمٕتۍ۔اَتھ صورتس منٛز چُھ طلا ق رَجعی سپدان تہٕ عدت کِس وقتس دورا ن ہیٚکہِ خاندار رجوع کٔرِ تھ ﴾۔مستوراتن خٲطرٕ تہِ چِھ معر وف طر یقہٕ تِتھی حقوق،یِتھۍ مردن ہٕندۍ حقو ق تِمن پٮ۪ٹھ چِھ ،البتہٕ مردن چُھ تِمن پٮ۪ٹھ اکھ درجہِ حٲصل تہٕ سارِنٕے پٮ۪ٹھ چُھ اللہ تعالیٰ غٲلب اقتدار تھاون وول حکیم تہٕ دانا موجو د ۔ ع"
  2,229,"۔طلا ق چُھ دۅ یہِ پھِرِ پتہٕ گژِھہ خاندارِنۍ یا تہٕ سیٚو د پٲٹھۍ رُکاوٕنۍ نَتہٕ  گژِھہ سۅ جان طر یقہٕ رخصت یِنۍ کر نہٕ ﴿ییٚمہِ آیت کِنۍ ہیٚکہِ اکھ مرد أکِس نکا حس منٛز پننہِ خاندارِ نہِ زیادٕہ کھۅتہٕ زیادٕہ دۅ یی پھِرِ طلا ق رَجعی ہُک حق استعمال کٔرِتھ۔ ییٚمۍ شخصن پننہِ خاندارِنہِ دۅ یہِ پِھرِ طلا ق دِتھ رجو ع آسہِ کوٚر مُت ،اگر سُہ پننہِ عمرِ منٛز کُنہِ تہِ ساعتہٕ أمِس ترٛییُم طلا ق دِیہِ ، مستقل طور گژھہِ خاندارِنۍ تس نِشہِ جُدا ﴾ تہٕ رخصت کر نہٕ وقتہٕ چُھنہٕ تۅہیہِ یہِ جٲیز زِ یِکینژھاہ تۅہیہِ تِمن دِیتمُت آسیٚو ،تمہِ منٛزٕ ہِیٚیو کینٛہہ واپس البتہ یہِ صورت چھےٚ الگ زِ دۅ ن بٲژن آسہِ نہٕ اللہ تعالیٰ سٕنٛد ٮ۪ن حدوٗدن پٮ۪ٹھ قٲیِم روزنُک اند یشہِ ،اَتھ صوٗرتس منٛز اگر تۅہیہِ یہِ خو ف آسیو زِ تِم دۅ شو ے ہیٚکن نہٕ اللہ تعالیٰ سٕندٮ۪ن حدوٗد ن پٮ۪ٹھ قٲیِم روٗزِ تھ تیٚلہِ چُھنہٕ تِمن دۅ ن در میان یہِ معا ملہٕ سپد نس منٛز کانٛہہ حر ج زِ خاندارِنۍ کرِ پننِس خاوندس کینٛہہ مُعا وضہٕ دِتھ مۅ کجار حٲصِل ﴿شر یعت کِس اصطلا حس منٛز چِھ اَتھ  خُلح  ونان ،یعنی أکِس خاندارِنہٕ ہُنٛد پننِس خاوندس کینٛہہ معا و ضہٕ دِ تھ تس نِشہِ طلا ق حٲصل کرُن۔اَتھ صورتس منٛز آسہِ مردٕ سٕنٛدِ خٲطرٕ جٲیز کہ پنُن  دِیتمُت مال یا امہِ منٛزٕ کانٛہہ حصہٕ یَتھ پٮ۪ٹھ پانہٕ وٲنۍ اتفاق آسہِ سپُد مُت، رَٹہِ خاندارِنہِ نِشہِ واپس ۔ البتہٕ اگر مَردن پانے آسہِ خاندارِنہٕ طلا ق دِیتمُت تیٚلہِ ہیٚکہِ نہٕ سُہ تَس پننہِ دِتہِ مَتہِ مالہٕ منٛزٕ کِہِنۍ واپس ہیٚتھ ﴾ یِم چِھ اللہ تعالیٰ سٕندۍ مقرر کرنہٕ آمٕتۍ حدود،یِمو پیٚٹھۍ مَہ نِیرِو، تہٕ یِم لُکھ اللہ تعالیٰ سٕند یٚو حدوٗد پیٹھۍ نیر ن، تِمَے چِھ ظٲلِم ۔"
  2,230,"۔پتہٕ اگر ﴿دۅ یہِ لٹہِ طلا ق دِنہٕ پتہٕ خاوند ن خاندارِنہِ ترٛ ییٚمہِ پھِرِ ﴾ طلا ق دِیُت ،تیٚلہِ آسہِ نہٕ سۅ خاندارِنۍ پتہٕ تس خٲطرٕ حلال اِلاّیہِ تٔمۍ سُنٛد نکاح سپدِ کٲنٛسہِ دوٚ یِمَس شخصس سٍتۍ تہٕ سُہ دِیہِ تس طلا ق ﴿یعنی زانٛہہ کٲلۍ دِیَس پننہِ مر ضی طلا ق۔اَمہِ منٛز چُھنہٕ سٲزشی نکا حُک تہٕ طلا قُک کانٛہہ جوا ز نیر ان یُس محض گۅڈِنِکِس خا ندارس خٲطرٕ زنانہٕ حلال کر نہٕ خٲطرٕ آسہِ کر نہٕ آمُت﴾ پتہٕ اگر گۅڈنِیُک خاندار تہٕ یہِ زنانہٕ دۅ شو ے یہِ سو نچن زِ اللہ تعالیٰ سٕند ٮ۪ن حدوٗدن پٮ۪ٹھ روزَو قٲیم ،تیٚلہِ چُھنہٕ یِمن اکھ أکِس کُن رجو ع کر نس کانٛہہ حر ج، یِم چِھ اللہ تعالیٰ سٕندۍ مُقرر کر نہٕ آمٕتۍ حد یِمن سُہ تِمن لُکن ہٕندِ ہدا یت خٲطرٕ وا ضح چُھ کران، یِم ﴿تٔمۍ سٕندٮ۪ن حد ن پُھٹرا ونُک انجا م﴾ زانان چِھ۔"
  2,231,"۔تہٕ ییٚلہِ توٚہۍ خاندارِنیٚن طلا ق دِیِو تہٕ تِہُنٛد عِدّت ہیٚیہِ پوٗرٕ سپدُن تیٚلہِ رُکٲوِیوٗکھ یا جان طر یقہٕ نَتہٕ کٔرِیوٗکھ جان طر یقہٕ رخصت، محض ستا و نہٕ خٲطرٕ تھٲوِزیوکھ نہٕ رُکٲوِ تھ زِ یہِ آسہِ زیادتی تہٕ یُس یہِ کرِ ،سُہ کر حقیقتس منٛز پٲنۍ پانس پٮ۪ٹھ ظُلم ،اللہ تعالیٰ سٕندٮ۪ن آیاتن مَہ بنٲوِ و مذا ق، مٔشِتھ مَہ گٔژِھۍ نَو زِ خُداین کِژھ بٔڈ نعمت چَھنَو تۅہیہِ عطا کٔر مٕژ ،سُہ چُھو تۅہیہِ نصیحت کران زِ یۅسہٕ کتا ب تہٕ حکمت تٔمۍ تۅہیہِ پٮ۪ٹھ نٲزِل چھےٚ کٔر مٕژ، تمہِ کہ احترا مُک تھٲوِ و لحا ظ ،خُدا یس کھوٚژِو تہٕ ٹھیک پٲٹھۍ زٲنِو  زِ خُدا یس چھےٚ پرٛتھ کتھہِ ہٕنٛز خبر ۔ ع"
  2,232,"۔ییٚلہِ توٚہۍ پننیٚن  خاندارنین طلا ق مۅکلٲوِ و دِتھ تہٕ تِمہٕ کر ن پنُن عدّت پوٗرٕ تہٕ پتہٕ مَہ بٔنِو اَتھ منٛز رُکاوٹ زِ تِمہٕ کر ن پننیٚن زیرِ تجو یز خاو ند ن سٍتۍ نکا ح ییٚلہِ زن تِم معر و ف طر یقہٕ پانہٕ وٲنۍ نکا ح کر نس پٮ۪ٹھ رٲضۍ آسن، تۅہیہِ چَھو نصیحت یِوان کر نہٕ زِ یژھ حر کت کٔرۍ زیٚو نہٕ ہر گز اگر توٚہۍ خُدا یس تہٕ ٲخرت کِس دو ہس پٮ۪ٹھ ایمان اَنن وٲلۍ چِھو، تُہٕنٛدِ خٲطرٕ چُھ شٲیستہٕ تہٕ پٲکیزٕ ہ طر یقہٕ یۅ ہے زِ امہِ نِشہِ روٗزِ و با ز ،اللہ تعالیٰ چُھ زانان توٚہۍ چِھو نہٕ زانان۔"
  2,233,"۔ماجہِ چٲون پوٗرٕ دو ن ؤرِین پننیٚن شُر ٮ۪ن دۅ د، اگر مٲلۍ یژھان آسن زِ تِہٕنٛدۍ اولاد گٔژھۍ رضا عت کِس وقتس تام پوٗرٕ دۅ د چیٚنۍ۔ ﴿یہِ چُھ اَتھ صورتس منٛز حکم ییٚلہِ زٕ ہ بٲژ اکھ أکِس نِشہِ الگ آسن گٔمٕتۍ ،خو اہ تِم طلا ق کہ ذر یعہ ٲسِتن یا خُلح یا فسخ تہٕ تفر یق کہ ذر یعہ ٲسِتن الگ گٔمٕتۍ ،تہٕ زَنا نہِ ہٕنٛزِ کۅ چھِ منٛز آسہِ دۅ د چیٚو ن شُر ﴾ اتھ صوٗرتس منٛز آسن شُر ۍ سٕندِس مٲلِس معروف طر یقہٕ تِمن کھیٚن تہٕ پَلو دِنۍ مگر کٲنٛسہِ پٮ۪ٹھ گژِھہ نہٕ تٔمۍ سٕند وُسعتہٕ کھۅتہٕ زیا دٕہ بار ترٛاوُن کینٛہہ ،نہ گژِھہ مو ج اَمہِ و جہ کِنۍ تکلیفس منٛز یِنۍ تراو نہٕ زِ شُر چُھ تٔمۍ سُنٛد تہٕ نہ گژِھہ مولٕے اَمہِ وجہِ کِنۍ تنگ یُن کر نہٕ زِ شُر چُھ تٔمۍ سُنٛد ،دۅ د چا و ن وا جِنہِ ہُنٛد یہِ حق یُتھ شُر ۍ سٕنٛدِ س مٲلِس پٮ۪ٹھ چُھ سُے چُھس تٔمۍ سٕندِس وٲرِثَس پٮ۪ٹھ تہِ البتہ اگر فر یق با ہمی رضا مند ی تہٕ مَشورٕہ سان دۅد ترٛا وناوُن یژھن تیٚلہِ چُھنہٕ اَتھ منٛز کانٛہہ حر ج تہٕ ہرگاہ تُہُنٛد خیا ل آسہِ زِ پنُن اولاد چٲوِ یوٗن غیر زَنہِ نِشہِ دۅ د ،تہٕ اَتھ منٛز تہِ چُھنہٕ کانٛہہ حر ج بشر طیکہِ یِکینٛژھاہ اَمِیُک مُعا و ضہٕ مقرر کٔرِو ،سُہ کٔرِ و معروف طر یقہٕ ادا ،خُدا یس کھوٗژِو تہٕ زٲنِو کہ یِکینٛژھاہ توٚہۍ کرا ن چِھو ، سورُے چُھ خُدا یس نظر ن تل۔"
  2,234,"۔ تۅہیہِ منٛزٕ یِم لُکھ مَر ن ، تِمن پَتھ کُن اگر تِہٕنٛزٕ خاندارِ نہِ زندٕہ آسن تیٚلہِ تھٲوِن تِمہٕ پنُن پان ژۅ ن ریٚتن دَہن دۅ ہن پتھ ﴿یہِ وفا تُک عِدّت چُھ تِمن مستوراتن خٲطرٕ تہِ یِمن سٍتۍ خاندارن ہٕنٛز خلو تِ صحیحہ آسہِ نہٕ سپٕز مٕژ۔ البتہ گۅ بہِ کھۅ ر خاتو ن چھےٚ امہِ نِشہِ مُچھہِ۔تٔمۍ سٕندِ وفا تُک عِدّت چُھ خلا ص گژھنس تام ، خۅ اہ سۅ خاندار سنٛدِ مر نہٕ پتے خلا ص گژھۍ تَن یا لٔگۍ تن اَتھ کینٛہہ ریٚتھ۔ پنُن پان تھٲوِ ن پَتھ اَمِیُک مُراد چُھنہٕ صرف یُتُے یو ت زِ یِمہٕ مَہ کٔرِن اَتھ وقتس اندر نکا ح بلکہ چُھ اَمہِ نِشہِ یِتہِ مُراد زِ پنُن پان رٔٹِن بناوٕ سنگارٕ نِشہِ تہِ پتھ﴾ پتہٕ ییٚلہِ تِہُند عدّت پوٗرٕ سپدِ تیٚلہِ چُھ تِمن اختیار، پننِس ذات کِس معا ملس منٛز یِکینٛژھاہ معروف طر یقہٕ یَژھن تہِ کٔرِ ن ۔تۅہیہِ پٮ۪ٹھ چَھنہٕ اَمِچ کانٛہہ ذمہٕ دٲر ی، اللہ تعالیٰ چُھ تۅ ہیہِ سارِنٕے ہٕنٛز و عملو نِشہِ با خبر ۔"
  2,235,"۔دۅ شوٕ نۍ صوٗرتن منٛز چُھنہٕ کانٛہہ حر ج۔ عدّت کِس وقتس منٛز کٔرۍ تو خوا ہ توٚہۍ تِمن مو نڈ ن مستوراتن سٍتۍ اِشارن منٛز نِشا نہِ ہُنٛد ارادٕہ ،یا کٔرۍ تو وَر گہٕ پٲٹھۍ خوا ہِ دِلس منٛز تھٲوِ ۍ تَو کھٔٹِتھ ،خُدا یس چھےٚ پے زِ تِہندِس با رس منٛز سوٗ نچوٕے توٚہۍ دِلس منٛز مگر وُچِھو ، سِر پٲٹھۍ کٔرۍ زیٚو نہٕ وعٕدہ اقرار ،اگر کانٛہہ کتھ چَھو کرٕنۍ، تیٚلہِ کٔرِو معروف طر یقہٕ تہٕ نکا حُک قَو ل و قرار کر نُک فٲصلہٕ مہ کٔرِو توٚہۍ تام یوٚت تام نہٕ عدّت پوٗرٕ سپدِ۔ ٹھیک پٲٹھۍ سمجھِو زِ اللہ تعالیٰ چُھ تُہٕنٛد ٮ۪ن دِلن ہُنٛد حال تام زانان لہٰذا کھوٚژِو تَس تہٕ یِتہِ زٲنِو زِ اللہ تعالیٰ چُھ بُرد بار ﴿لۅ کچن لۅ کچن کتھن چُھ ﴾ در گُزر فر ماوان۔ع"
  2,236,"۔تۅہیہِ پٮ۪ٹھ چُھنہٕ کینٛہہ گنا ہ اگر پننیٚن خاندارِ نیٚن طلا ق دِیِو اَمہِ برونٛہہ زِ اَتھہٕ لا گنٕچ نو بت وَاتہِ یا مَہر سپدِ مُقرر اَتھ صوٗرتس منٛز گژِھہ تِمن کینٛہہ نَتہٕ کینٛہہ ضروٗر دِیُن، خۅ شحال شخٕص دِین پننہِ مقدوٗر مُطٲبق تہٕ غر یب شخص دِین پننہِ مقدورٕ مطٲبق معروٗف طر یقہٕ خر چ، یہِ حق چُھ نیک انسانن پٮ۪ٹھ۔"
  2,237,"۔تہٕ  اگر تۅہیہِ اَتھہٕ لاگنہٕ برونٛہہ طلا ق آسیٚو دِیتمُت البتہ مَہر آسہِ مُقرر کر نہٕ آمُت تیٚلہِ چُھو اَتھ صوٗرتس منٛز نصف مَہر دِیُن ،یہِ چھےٚ بیاکھ کتھ زِ زَنا نہٕ کرِ نر می ﴿تہٕ مَہر ہیٚیہِ نہٕ ﴾ یا سُہ مرد ییٚمۍ سٕندِس اختیارس منٛز نِکا حُک قو ل و قرار آسہِ ،ہیٚیہِ نر می کٲم ﴿تہٕ پوٗرٕ مَہر دِیہِ ﴾ تہٕ توٚہۍ ﴿یعنی مرد ﴾ ہیٚیِو نر می کٲم، تیٚلہِ چُھ یہِ تقویٰ ہس سٍتۍ زیادٕہ ہِشر تھاوان پانہٕ وٲنۍ یِم معاملات آسنو ،تِمن منٛز مٔشرٲوِ زیٚو نہٕ احسا ن، تُہنٛز ن عملن چُھ اللہ تعالیٰ وُچھان۔"
  2,238,"۔پننیٚن نمازن کٔرِو رٲچھ راوٹھ خصوصاً تمہِ نمازِ ہٕنٛز یۅسہٕ صلوٰتہِ الوسطیٰ آسہِ ﴿آیتس منٛز چُھ لفظ  صلوٰتہِ الوسطیٰ وَرتاو نہٕ آمُت۔وسطیٰ ہُک معنی چُھ مٔنٛزِ مہِ چیزُک تہِ تہٕ تِتھہِ چیزُک تہِ یُس اعلیٰ تہٕ اشر ف آسہِ۔ صلوٰتہِ الو سطیٰ ہُک مُراد ہیٚکہِ مٔنٛزِ مہِ نمازِ ہُنٛد تہِ ٲسِتھ تہٕ تمہِ نمازِ ہُنٛد تہِ یۅسہٕ صحیح وقتس پٮ۪ٹھ پوٗرٕ خشو ع تہٕ تو جہ سان خُدا یس کُن یِیہِ پر نہٕ، یَتھ منٛز نمازِ ہٕنٛزٕ تمام خوٗبیہِ موجوٗد آسن۔ یِمَو مفسر و یہِ لفظ مٔنٛزِ مہِ نمازِ ہٕنٛدِس معنیس منٛز چُھ نِیو مُت تِمن نِشہِ چُھ عام پٲٹھۍ اَمہِ نِشہِ مُراد عصر نماز﴾ خُدایس برونٛہہ کنہِ سپدِو تِتھہٕ پٲٹھۍ کھڑا، یِتھہٕ پٲٹھۍ فر مان بردار غلا م چِھ کھڑا سپدان ،"
  2,239,"۔ہرگاہ بد اَمنی ہٕنٛز حالت آسہِ تیٚلہِ خوا ہ پید ل ٲسِو، خوا ہ سوار ٲسِو ،یِتھہٕ پٲٹھۍ ممکن سپدِ نمازِ پٔرِو تہٕ ییٚلہِ امن سپد یٚو حٲصل ،تیٚلہِ کٔرِیوٗن اللہ تعالیٰ تمہِ طر یقہٕ یاد یُس تٔمۍ توٚہۍ ہیٚچھنٲوِمٕتۍ چِھو ییٚمہِ نِشہِ توٚہۍ گۅڈٕہ نا وٲقف ٲسِو۔"
  2,240,"۔تۅہیہِ منٛز یِم لُکھ مَر ن تہٕ پتھ کُن ترٛا وَن خاندارِنہِ تِمن پزِ پننیٚن خاندارِنیٚن ہٕندِس حقس منٛز یہِ وصیت کرٕنۍ زِ أکِس ؤریس تام گژِھہ تِمن نان ونفقہ دِنہٕ یُن تہٕ تِمہٕ گژھن نہٕ گھرٕ منٛزٕ یِنہٕ کڑ نہٕ پتہٕ اگر تِمہٕ پانے نیر ن کانٛہہ ذِمہٕ دٲر ی چَھنہٕ تۅہیہِ پٮ۪ٹھ اَتھ منٛز یِکینٛژھاہ تِمہٕ معروف طر یقہٕ پننِس ذاتس متعلق کر ن، اللہ تعالیٰ چُھ سارِنٕے پٮ۪ٹھ غٲلب اقتدار تھاو ن وول تہٕ سُہ چُھ حکمت وول تہٕ دانا ،"
  2,241,"۔یِتھے پٲٹھۍ یِمن زنانن طلا ق آسہِ دِنہٕ آمُت، تِمہٕ تہِ گژھن مُنٲسِب طور کینٛہہ نَتہٕ کینٛہہ دِتھ رخصت یِنہِ کر نہٕ یہِ چُھ حق تِمن لُکن پٮ۪ٹھ یِم متّقی چِھ۔"
  2,242,"۔یِتھہٕ پٲٹھۍ چُھو اللہ تعالیٰ تۅہیہِ صا ف صا ف پنٕنۍ احکام وَنان اُمید چھےٚ زِ توٚہۍ کٔرِو گا ٹہٕ جارٕ سان کٲم۔ع"
  2,243,"۔تۅہیہِ کوٚرواتِمن لُکن ہٕندِس حالس پٮ۪ٹھ تہِ ہَنا غور یِم موت کہ ڈرٕ پنٕنۍ گھرٕ بار ترٛٲوِتھ درٛا مٕتۍ ٲسۍ تہٕ ساسن ہٕندِس تعدادس منٛز ٲسۍ؟خُدا ین فر مو و تِمن :مٔرِو پتہٕ بخش تٔمۍ تِمن نوِ سرٕ ہ زند گی ﴿یہِ اشارٕہ چُھ بنی اسرا یل کِس خروج کِس وا قعس کُن ۔ سورۂ ماید ہ کِس ژوٗرِمِس رکو عس منز چھُ اللہ تعالیٰ ہن اَمِیُک تفصیل بیان کوٚر مُت ﴾ حقیقت چھےٚ یہِ زِ اللہ تعالیٰ چُھ انسانس پٮ۪ٹھ سٮ۪ٹھاہ فضل کر ن وول مگر اکثر لُکھ چِھنہٕ شُکر کرا ن۔"
  2,244,"۔مُسلمانو! اللہ تعالیٰ سٕنٛزِ وَتہٕ منٛز کٔرِو جنگ تہٕ وارٕپٲٹھۍ زٲنِو زِ اللہ تعالیٰ چُھ بوزن وول تہٕ زانن وول۔"
  2,245,"۔تۅہیِہ منٛزٕ کُس چُھ یُس خُدایس قر ضِ حَسَن دِیہِ تاکہِ اللہ تعالیٰ کرِ تس کینٛہہ گو نہٕ ہُررٲوِتھ واپس؟﴿قر ضِ حَسن  نِشہِ چُھ مُراد خٲلص نیکی ہٕنٛدِ جذ بہٕ سان لالچہِ روٚس اللہ تعالیٰ سٕنٛزِ وَتہِ منٛز مال خرچاوُن۔اَتھ چُھ اللہ تعالیٰ پانس پٮ۪ٹھ قر ض مانان تہٕ وعدٕہ چُھ کران زِ صرف دِمَو نہٕ بہٕ تۅہیہِ اصلٕے یوت بلکہ دِمَو اَمہِ کھۅتہٕ کینٛہہ گۅ نہٕ ہُر یمانہٕ﴾ کم کرُن تہِ چُھ اللہ تعالیٰ سٕندِس اختیارس منٛز تہٕ ہُراوُن تہِ چُھ اللہ تعالیٰ سٕندِس اختیارس منٛز تہٕ تٔسۍ کُن چُھو تۅہیہِ پھیٖرِ تھ گژُھن۔"
  2,246,"۔پتہٕ کوٚروٕہ تۅہیہِ تتھ معا ملس پٮ۪ٹھ تہِ غور، یُس موسیٰ ﴿علیہ السلامس﴾ پتہٕ بنی اسرا یل کیٚن سردارن پیش اوس آمُت؟تِمو ووٚن پننِس پیغمبرس : سا نہِ خٲطرٕ کرُن اکھ با د شاہ مُقرر تا کہ أسۍ کر و اللہ تعالیٰ سٕنٛزِ وَتہِ منٛز جنگ، پیغمبر ن پُرٛوٚژھنکھ : پتہٕ گوٚژھ نہٕ یہِ سپدُن زِ تۅہیہِ یِیَو لڑا یہِ ہُنٛد حُکم دِنہٕ تہٕ پتہٕ لٔڑِو نہٕ توٚہۍ ؟ تِم لٔگۍ وَننہٕ : یہِ کِتھہٕ پٲٹھۍ ہیٚکہِ سپدِتھ زِ اللہ تعالیٰ سٕنٛزِ وَتہِ منٛز لڑَو نہٕ أسۍ ییٚلہِ زن أسۍ پننیٚو گھرَو منٛزٕ چِھ کڑ نہٕ آمٕتۍ تہٕ سٲنۍ شُر ۍ بٲژ چِھ اَسہِ نِشہِ جُدا آمٕتۍ کر نہٕ مگر ییٚلہِ تِمن جنگُک حُکم آو دِنہٕ ،اکہِ کم تعدادٕ وَرٲے پھِر ۍ تِمو سارِوٕیو شا نہٕ تہٕ اللہ تعالیٰ چُھ تِمو منٛزٕ أکِس أکِس ظٲلِمَس زانان۔"
  2,247,"۔تِہنٛدۍ پیغمبر ن ووٚ ن تِمن زِ خُدا ین چُھ طالوت کوٚرمُت تُہٕنٛدِ خٲطرٕ بادشاہ مقرر ،یہِ بوٗزِ تھ ووٚ ن تِمو: سُہ کِتھہٕ پٲٹھۍ بنیٚا و اَسہِ پٮ۪ٹھ بادشاہ بننُک حقدار؟ تٔمۍ سٕنٛدِ کھۅتہٕ چِھ أسۍ باد شٲہی ہٕندۍ زیادٕہ حقدار، سُہ چُھنہٕ کانٛہہ بوٚڈ مالدار شخٕص تہِ کینٛہہ پیغمبر ن دِیتُنکھ جوا ب : خدا ین چُھ تُہٕنٛدِ بد لہٕ سُے کوٚرمُت منتخب تہٕ تس چَھن دمٲغی تہٕ جسمٲنی دۅ شوے قٲبلیتہٕ پوٗرِ پوٗرٕ عطا کرِ مژٕ تہٕ خُدایس چُھ اختیاریَس پنُن مُلک ییٚژِھہ تس دِیہِ ،اللہ تعالیٰ چُھ سٮ۪ٹھاہ وُسعت تھاوان تہٕ سورُے کینٛہہ چھےٚ تس پے ۔"
  2,248,"۔اَتھ سٍتۍ ووٚ ن تِہٕنٛدۍ پیغمبر ن تِمن یِتہِ زِ اللہ تعالیٰ سٕنٛدِ طر فہٕ تٔمۍ سُنٛد بادشاہ مُقرر سپدٕ نٕچ علا مت چھےٚ یہِ زِ تٔمۍ سٕندِس وقتس منٛز میلیو تۅہیہِ سُہ صند و ق واپس یتھ تُہنٛدِس ربّ سٕندِ طر فہٕ تُہٕنٛدِ خٲطرٕ دِل کہ سکونُک سا مانہٕ چُھ یتھ منٛز آلِ مو سیٰ علیہ السلام تہٕ آلِ ہارون علیہ السلام سٕندۍ پتھ کُن ترٲوِ مٕتۍ تبر کات چِھ تہٕ یَتھ وُنۍ کیٚنس فر شتہٕ سنٛبٲلِتھ چِھ اگر توٚہی مو من چِھو ، تیٚلہِ چھےٚ یہِ تُہنٛدِ خٲطرٕ واریاہ بٔڑ نِشٲنی ۔ع"
  2,249,"۔پتہٕ ییٚلہِ طالوت درٛا و لشکر ہیٚتھ تہٕ تٔمۍ ووٚ ن : أکِس دٔرِیاوس پٮ۪ٹھ چھےٚ اللہ تعالیٰ سٕندِ طر فہٕ تُہٕنٛز اَز مٲیش سپدَن واجِیٚنۍ یُس تمہِ منٛزٕ ترٛ یش چیٚیہِ سُہ چُھنہٕ میو ن سٲتھی، میو ن سٲتھی چُھ صرف سُہ یُس نہٕ تَمہِ سٍتۍ ترٛ یش ہوٚ مراوِ۔آ، تھوٚ مب اوٚڈ تھوٚ مب اگر کانٛہہ چیٚیہِ چیٚیِن، اکہِ لۅ کچہِ چھۅکہٕ ورٲے سپٕدۍ سٲر ی اَمہِ دِر یاوٕ نِشہِ سٲرا ب۔پتہٕ ییٚلہِ طا لوٗت تہٕ تٔمۍ سٕندۍ مسلمان سٲتھی در یاوس تٔرِ تھ برونٛہہ پٔکۍ اَمہِ پتہٕ ووٚ ن تِمو طا لو تس زِ اَز چُھنہٕ اَسہِ منٛز جا لوتس تہٕ تٔمۍ سٕندٮ۪ن لشکر ن سٍتۍ مُقا بلہٕ کر نُک طا قت ﴿یہِ وَنن وٲلۍ آسٕہن غالباً تِمے لُکھ یِمَو در یا وس پٮ۪ٹھ گۅڈے پننہِ بے صبر ی ہُنٛد اظہا رس اوس کوٚر مُت ﴾ مگر یِم لُکھ یہِ سمجھان ٲسۍ زِ تِمن چُھ اکہِ دۅ ہ خدا یس سمکھُن ،تِمو ووٚ ن :  وار یاہہِ پھِرِچُھ یہِ سپدُمُت زِ اکھ لۅ کٕٹ چھۅ کھ چھےٚ اللہ تعالیٰ سٕندِ اِذ نہٕ سٍتۍ أکِس بجہِ چھۅ کہِ پٮ۪ٹھ غا لب سپٕز مٕژ ،اللہ تعالیٰ چُھ صبر کر ن والیٚن سٲتھی۔"
  2,250,"۔تہٕ ییٚلہِ تِم جا لوت تہٕ تٔمۍ سٕندِس لشکرس سٍتۍ مُقا بلہٕ کر نہٕ درٛا ے تہٕ تِمو کوٚر دُعا : اے سا نہِ ربّہٕ ! اَسہِ دِ صبر ، سٲنۍ قد م جماو تہٕ یَتھ کٲفر چھۅ کہِ پٮ۪ٹھ کر اَسہِ  فتح نصیب"
  2,251,"۔ٲخر کار ژٔلر ٲوۍ تِمو اللہ تعالیٰ سٕندِ اِذ نہٕ سٍتۍ کٲفر تہٕ داوٗد ن کوٚر جا لوت قتل تہٕ خُدا ین کٔر تَس سلطنت تہٕ حکمت عطا بیٚیہِ یِمن یِمن چیز ن ہُنٛد علم یوٚژھنَس سُہ علم دِیتُنَس اگر یِتھہٕ پٲٹھۍ اللہ تعالیٰ انسانن ہٕنٛزِ أکِس چھۅ کہٕ دوٚ یِمہِ چھۅ کہِ ہٕندِ ذر یعہِ ڈالان روزِ ہے نہٕ تیٚلہِ بِگرِ ہے زمینُک نظا م ،وۅ نۍ گوٚو دُنیا کیٚن لُکن پٮ۪ٹھ چُھ اللہ تعالیٰ سُنٛد بوٚڈ فضل ﴿زِ سُہ فساددفع کر نُک انتظا م کران روزان﴾۔"
  2,252,"۔یِم چِھ اللہ تعالیٰ سٕندۍ آیات یِم أسۍ ٹھیک ٹھیک توٚہۍ بوزناوان چِھو تہٕ اے محمد صلی اللہ علیہ وسلم ،توٚہۍ چِھو یقیناً تِمو لُکو منٛزٕ ،یِم رسول بنٲوِ تھ سوزنہٕ چِھ آمٕتۍ ۔"
  2,253,"۔یِم رسول ﴿یِم سانہِ طر فہٕ انسانن ہٕنٛدِ ہدا یتہٕ خٲطرٕ مُقرر سپٕدۍ﴾ اَسہِ کٔرۍ یِمن اکھ أکۍ سٕندِ کھۅتہٕ کھٔسِتھ مر تبہٕ عطا، تِمو منٛزٕ اوس کانٛہہ تِیُتھ یَس سٍتۍ اللہ تعالیٰ بذا تِ خۅد ہمکلام سپُد، کٲنٛسہِ دِتِن با قیو حیثیتو بُلند در جہ تہٕ ٲخرس پٮ۪ٹھ کر ین عیسیٰ ابن مر یم ﴿علیہ السلامس﴾ روشن نشٲنیہِ عطا تہٕ روحِ پاک سٕندِ ذر یعہ کوٚر نس مدد ،اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ اوس نہٕ ممکن زِ یِمو پیغمبر و پتہٕ یِمو لُکو ٹاکارٕ نشٲنیہِ وُچھمژٕ آسہٕ، تِم کیا لڑ ہن پانہٕ وٲنۍ مگر  اللہ تعالیٰ سٕنٛز مشیّت ٲس نہٕ یہِ زِ سُہ رُکا وِ ہے لُکن جبراً اختلا ف نِشہِ ، اَمہِ وجہ ﴾ کوٚر تِمو پانہٕ وٲنۍ اختلا ف، پتہٕ اوٚ ن کٲنٛسہِ ایمان تہٕ کٲنٛسہِ رٔٹ کُفرٕ چ وَتھ آ، ہرگاہ اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ لڑ ہَن نہٕ تِم ہرگز مگر اللہ تعالیٰ یہِ یژھان چُھ تہِ چُھ کرا ن ۔ ع"
  2,254,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت یِکینژھاہ مال و متا ع اَسہِ تۅہیہِ بخشمُت چُھو، تَمہِ منٛزٕ کٔرِو خر چ اَمہِ برونٛہہ زِ سُہ دۅ ہ واتہِ ، ییٚمہِ دۅ ہ خر ید فر و خت سپدِ نہٕ ،نَہ یِیہِ دوستی بکا ر تہٕ نَہ چلہِ سفٲرش  تہٕ ظٲلِم چِھ دراصل تِمے ، یِم کُفرٕچ وَتھ پا نناوان چِھ۔"
  2,255,"۔اللہ تعالیٰ چُھ سُہ زندٕہ جاوید ہستی، یُس سٲرِ سٕے کا ینا تس چُھ سنبھٲلِتھ، تس ورٲے چُھنہٕ کانٛہہ خدا ے، سُہ نَہ  چُھ شۅنگان تہٕ نَہ چھےٚ تس  زو لہٕ گژھان یِکینٛژھاہ زمینس تہٕ آسمانن اندر چُھ، سُہ چِھ تٔمۍ سُندُے ،کُس چُھ سُہ یُس تٔمۍ سٕندِس خد متس اندر تٔمۍ سٕندِ اجازت ورٲے سفٲرش ہیٚکہِ کٔرِ تھ ؟ یِکینژھاہ بند ن برونٛہہ کنہِ چُھ، تمِچ تہِ چَھس خبر ، تہٕ یِکینژھاہ تِمن نِشہِ کھٔتِتھ چُھ تمہِ نِشہِ تہِ چُھ وٲقف تہٕ بیٚیہِ ہیٚکن نہٕ تِم تٔمۍ سٕند یٚو   معلو ماتو منٛزٕ کُنہِ چیز س متعلق سوٗنچتھٕے اِلاّ یہِ زِسُہ اگر کُنہِ چیزُک علم تِمن پانے دِیُن ییژِھہ۔تٔمۍ سٕنٛز حکو مت چھےٚ آسمانن تہٕ زمینس پٮ۪ٹھ اِحا طہٕ کٔرِ تھ ﴿یتھ جایہ، چُھ لفظکُر سی استعمال سپُد مُت،یتھ عا م پٲٹھۍ حکو مت تہٕ اقتدار رٔنگۍ چِھ وَرتاوان ۔اردو تہٕ کٲشِر زبٲنۍ اندر تہِ چِھ کُرسی لفظ ؤنِتھ حٲکمانہٕ اختیارات مُراد آسان۔ اَمی لفظہٕ کہ رعا یت سٍتۍ چھےٚ یہِ آیتآیت الکر سی ناوٕ مشہو ر تہٕ اتھ اندر چھےٚ اللہ تعالیٰ سٕنز تِژھ مکمل معرفت بخشنہ آمٕژ،ییٚمِچ مثال کُنہِ چھَنہٕ میلان ۔حدیث شریفس اندر چھےٚ یہِ أتھۍبنیادس پٮ۪ٹھ قرآنٕچ سارِوٕے کھۅتہٕ افضل آیت قرار دِنہٕ آمٕژ۔﴾تہٕ تِہٕنٛز رٲچھ راوٹھ چَھنہٕ تٔمۍ سٕندِ خٲطرٕ تھٔکراوَن واجیٚنۍ کٲم بس سۅ ے چھےٚ اکھ بزر گ تہٕ تھَدِ پا یِچ ذات ۔"
  2,256,"۔دین کِس معا ملس منٛز چَھنہٕ کانٛہہ زورد زبردستی ﴿یعنی کانٛہہ اکھا ہیکو ن نہٕ ایمان اَننس پٮ۪ٹھ مجبور کٔرِ تھ﴾ صحیح کتھ چھےٚ آمٕژ غلط خیا لو تو نِشہِ چھٲنٹِتھ  بیٚو ن تھاو نہٕ ،وۅ نۍ ییٚمۍ طا غو تس انکار کٔرِ تھ خُدایس پٮ۪ٹھ ایمان اوٚ ن ﴿لُغت کہ اعتبارٕ یِیہِ طا غوت تس پرٛتھ شخصس وَننہٕ یُس پننہِ جٲیز حدٕ نِشہِ نیٚبر آسہِ درٛا مُت۔قرآن کِس اصطلا حس منٛز چُھ طا غوت مُراد سُہ بندٕ ہ یُس بند گی ہٕنٛدِ حدٕ ڈٔلِتھ خۅد آقٲیی تہٕ خداوند ی ہٕندۍ دَم دِیہِ ، بیٚیہِ کر ناوِ اللہ تعالیٰ سٕندٮ۪ن بند ن پنٕنۍ بند گی ۔﴾ تٔمۍ کٔر تِتھِس مضبو ط سہا رس تھَپھ یُس نہٕ زانٛہہ پھٹُن وول چُھ تہٕ اللہ تعالیٰ ﴿ییٚمۍ سُند سہارٕ ہ أمۍ روٚٹمُت چُھ﴾ چُھ سورُے کینٛہہ بوزن وول تہٕ زانن وول۔"
  2,257,"۔یِم لُکھ ایمان چِھ اَنان ،تِہُنٛد حٲمی تہٕ مدد گار چُھ اللہ تعالیٰ تہٕ سُہ چُھ تِمن اَنہِ گٹۅ منٛزٕ کٔڑِتھ گا شس کُن اَنان تہٕ یِم لُکھ کُفرٕ چ وَتھ رَٹا ن چِھ ، تِہنٛدۍ حٲمی تہٕ مددگار چِھ طا غوت،﴿  یَتھ جایہِ چُھ طا غو ت  طوا غیت کِس معنیس منٛز وَرتا و نہٕ آمُت۔طوا غیت مطلب چُھ واریاہ طا غوت ، یعنی خُدا یس بُتھ پھِرتھ چُھنہٕ انسان أکۍ سٕے طا غوت سٕندِس زالَس منٛز پھسا ن بلکہ چِھ واریاہ طا غوت أمِس پٮ۪ٹھ مُسلط سپدا ن﴾ تہٕ تِم چِھ تِمن گا شہِ منٛزٕ کٔڑِتھ اَنہِ گٹن کُن لٔمِتھ نِوان یِم چِھ نارس گژھن وٲلۍ لُکھ ییٚتہِ یِم ہمیشہ روزَن ۔ع"
  2,258,"۔کیا  تۅہیہِ کوٚرُونا تس شخصسہٕ سٕندِس حالس پٮ۪ٹھ غور ،ییٚمۍ ابرا ہیم ﴿علیہ السلامس﴾ سٍتۍ لڑٲے ٲس کٔرمٕژ۔﴿تس شخصس نِشہِ چُھ مُراد  نمروٗد،یُس حضرت ابرا ہیم علیہ السلامن ہٕندِ وطنُک عرا قُکبا دشاہ اوس﴾ لڑٲے اَتھ کتھہِ پٮ۪ٹھ زِ ابرا ہیم ﴿علیہ السلامَو﴾  سُند ربّ کُس چُھ ،تہٕ اتھ بنیاد س پٮ۪ٹھ زِ تس شخصس ٲس خدا ین حکو مت دِژمٕژ ییٚلہِ ابرا ہیم ﴿علیہ السلامَو﴾ووٚن زِ میو ن ربّ چُھ  سُہ ییٚمۍ سٕندِس اختیارس منٛز زند گی تہٕ موت چُھ تہٕ تٔمۍ دِیت تورٕ جواب : زند گی تہٕ موت چُھ میٲنِس اختیارس منٛزابرا ہیم ﴿علیہ السلامَو﴾ ووٚن اچھا، اللہ تعالیٰ چُھ آفتا بس مشر ق کِنۍ کھالان۔ژٕ کھا لتَن سُہ مغر ب کِنۍ  یہِ بوٗزِ تھ گوٚو سُہ منکرِ حق رٔہِتھ۔مگر اللہ تعالیٰ چُھنہٕ ظٲلِمن سِیٔز وَتھ ہاوان۔"
  2,259,"۔نَتہٕ وُچھتو ن مثا لہِ رٔنگۍ سُہ شخص۔یُس اکہِ تِژِھہ بستی کِنۍ درٚاو یۅسہٕ پننیٚن چَھتن پٮ۪ٹھ دُبہٕ ٲس پھِیرٕژ تٔمۍ ووٚ ن : یہِ آبٲد ی ، یۅسہٕ ہلا ک چھےٚ سپٕز مٕژ،اَتھ کِتھہٕ پٲٹھۍ بخشہِ اللہ تعالیٰ دُبارٕ ہ زند گی ؟ یہِ وَننس سٍتی کوٚر خدا ین تٔمۍ سُند رُو ح قبض تہٕ سُہ روٗد ہتھس ؤرِیس تام مٔرِ تھ اَمہِ پتہٕ دِژ خدا ین تس دوبارٕ ہ زند گی تہٕ پرٛژُھنس: وَن ،کوتاہ کال سپدُے؟ ﴿اَتھ حالتس منٛز﴾تٔمۍ ووٚ ن : اکھ دۅ ہ یا کینٛہہ گٲنٛٹہٕ آسہٕ روٗد مُت  فر ماونہٕ آس : ہتھ ؤری گٔیہِ ژےٚ أتھۍ حالتس منٛز وۅ نۍ دِتہٕ نظرا ہ پننِس کھیٚنس تہٕ تریشہِ زِ اَتھ منٛز ما چھےٚ کانٛہہ فر ق آمٕژ ،دویِمہِ پاسہٕ ترٛا و تہٕ پننِس خرس تہِ نظراہ ﴿زِ أمۍ سُند کرٛنٛز تہِ چُھ دۅد رِیو مُت ﴾ تہٕ یہِ کوٚر اَسہِ امہِ موجوٗب زِ أسۍ چِھ یژھان ژٕ بناوو تھ لُکن خٲطرٕ اکھ نشٲنی پتہٕ وُچھتہٕ زِ أڈِجن ہُنٛد یہِ کرٛنٛز کِتھہٕ پٲٹھۍ تُلو و ن أسۍ تہٕ کھالو س ماز مٕسلہٕ۔ یِتھہٕ پٲٹھۍ ییٚلہِ حقیقت تس برونٛہہ کنہِ با لکل ظٲہر سپٕز تہٕ تٔمۍ ووٚ ن : بہٕ چُھس زانان زِ اللہ تعالیٰ چُھ پرٛتھ چیزس پٮ۪ٹھ قدرت تھاوان ۔"
  2,260,"۔تہٕ سُہ واقعہ تہِ روزِ ن نظر ن تل، ییٚلہِ ابرا ہیم ﴿علیہ السلامن﴾ اوس ووٚ نمُت زِ میانہِ مٲلکہٕ! مےٚ ہاو تہٕ،ژٕ کِتھہٕ پٲٹھۍ چھَہَکھ مُردٕہ کران زندٕہ فر ماو نہٕ آس : کیا ژےٚ چھی نا ﴿اتھ کتھہِ پٮ۪ٹھ ﴾ ایمان ؟  تٔمۍ کوٚر عر ض:  مےٚ چُھ اتھ پٮ۪ٹھ ایمان ، مگر دِلُک  اِطمنان چُھم در کار ؟ ﴿یعنی سُہ اطمنا ن یُس أچھو وُچھنہٕ سٍتۍ چُھ سپدا ن ﴾ فر ماو نہٕ آس : اچھا  ژور وُڈوٕنۍ جاناوار رَٹُکھ تِم کرُکھ سِو ۍ پتہٕ تھاو تِمن ہُنٛد اکھ اکھ ٹُکرٕ أکِس أکِس بالس پٮ۪ٹھ پتہٕ لایُکھ ناد تِم یِن دَوان ژےٚ نِش، وارٕپٲٹھۍ زان زِ اللہ تعالیٰ چُھ سٮ۪ٹھاہ با اقتدار تہٕ حکمت وول ۔ع"
  2,261,"۔یِم لُکھ پنٕنۍ مال اللہ تعالیٰ سٕنزِ وَتہِ اندر خر چ چِھ کرا ن تِہندِ خر چاونٕچ مثا ل چھےٚ تِژھہ زَنتہٕ اکھ دا نہٕ یِیہِ وَو نہٕ، تہٕ تتھ نیر ن سَتھ ہیٚلۍ تہٕ پرتھ ہیٚلِس منٛز آسن ہَتھ پھٔلۍ ،یِتھے پٲٹھۍ ییٚمۍ سٕنزِ عملہِ اللہ تعالیٰ یژھان چُھ، تتھ چُھ ہُراوان، سُہ چُھ فر اخ دست تہِ تہٕ زَانن وول تہِ۔"
  2,262,"۔یِم لوٗکھ پنٕنۍ مال اللہ تعالیٰ سٕنزِ وَتہِ اندر خر چ کرا ن چِھ تہٕ خرچ کٔرِ تھ چِھنہٕ پتہٕ آسا ن گٕنٛز ران، نہ چِھ دُکھ دِوان تِہُنٛد اجر چُھ تِہندِس ربّس نِشہِ تہٕ تِہنٛدِ خٲطرٕ چَھنہٕ کُنہِ غمٕچ تہٕ خو فٕچ گُنجٲیش۔"
  2,263,"۔اکھ میٖٹھ کتھ تہٕ کُنہِ نا گوار کتھہِ پٮ۪ٹھ أچھ وَٹنہِ چُھ تمہِ خیرا ت کھۅتہٕ بہتر یَتھ پٔتۍ کِنۍ دُکھ آسہِ ،اللہ تعالیٰ چُھ بے نیا ز تہٕ بُردبٲر ی چھےٚ تٔمۍ سُند صفت ۔"
  2,264,"۔اے ایمان اَنن والیو ! پنٕنۍ صد قا ت مہ رَلٲوِو احسان زٲنِتھ تہٕ دُکھ دِتھ تس شخصہٕ سٕندۍ پٲٹھۍ خا کس یُس پنُن مال محض لُکن ہاو نہٕ موجوٗب چُھ خر چ کرا ن بیٚیہِ نہ چُھس خدا یس پٮ۪ٹھ ایمان تہٕ نہ ٲخرت کِس دۅ ہس پٮ۪ٹھ ت،ٔمۍ سٕندِ خر چاونٕچ مِثا ل چھےٚ تِژھ زنتہٕ اکھ پَل اوس ،یتھ پٮ۪ٹھ میٚژِ ہُنٛد اکھ تہہ اوس کھوتمُت، اَتھ پٮ۪ٹھ ییٚلہِ زورٕ سان روٗدٕ لَوٕ پیٚیہِ ،تہٕ یہِ سٲرٕ ے میٚژ آیہِ چَھلنہٕ ،پَل روٗد پلکٕۍ پٲٹھۍ ،یِتھۍ لُکھ یۅسہٕ پنٕنۍ کِنۍ خیرات کٔرِتھ نیکی کماوان چِھ تمہِ سٍتۍ چُھنہٕ تِمن کِہِنۍ تہِ اَتھہِ لگا ن تہٕ کافرن سیز وَتھ ہاوٕنۍ چھُنہٕ اللہ تعالیٰ سُنٛد دستور﴿یتھ جایہِ  چُھ  کٲفر  لفظ نا شکر گُزار تہٕ مُنکر نعمت کِس معنیس منٛز ورتاو نہٕ آمُت﴾اَتھ بر عکس یِم لُکھ پنُن مال محض اللہ تعالیٰ سٕندِ رضا جو یی خٲطرٕ دِل کہ پوٗرٕ ثبا ت و قرار سان خرٕچ چِھ کران تِہندِ خر چاو نٕچ مِثا ل چھےٚ تِژھ زنتہٕ کُنہِ پا تھلِس پٮ۪ٹھ آسہِ اکھ با غ ، ہرگاہ صحیح روٗد پیٚیہِ تَتھ نیرِ دۅ گنہٕ پھل تہٕ ہرگاہ صحیح روٗد پیٚو و نہٕ کینٛہہ، تیٚلہِ تہِ آسہِ تَمہِ خٲطرٕ اکٲے روٗدٕ لَوٕ کٲفی، توٚہۍ یِکینژھاہ کران چِھو ، سورُے چُھ اللہ تعالیٰ وُچھان۔"
  2,265,"اَتھ بر عکس یِم لُکھ پنُن مال محض اللہ تعالیٰ سٕندِ رضا جو یی خٲطرٕ دِل کہ پوٗرٕ ثبا ت و قرار سان خرٕچ چِھ کران تِہندِ خر چاو نٕچ مِثا ل چھےٚ تِژھ زنتہٕ کُنہِ پا تھلِس پٮ۪ٹھ آسہِ اکھ با غ ، ہرگاہ صحیح روٗد پیٚیہِ تَتھ نیرِ دۅ گنہٕ پھل تہٕ ہرگاہ صحیح روٗد پیٚو و نہٕ کینٛہہ، تیٚلہِ تہِ آسہِ تَمہِ خٲطرٕ اکٲے روٗدٕ لَوٕ کٲفی، توٚہۍ یِکینژھاہ کران چِھو ، سورُے چُھ اللہ تعالیٰ وُچھان۔"
  2,266,"۔کیا تۅہیہِ منٛزٕ چھا کانٛہہ یہِ پسند کران زِ تس گوٚژھ اکھ پھۅ لہٕ وُن با غ آسُن ،تتھ گژٕھہ کۅ لہٕ آسنہِ سگہٕ وان ۔ کھٔزٕر ،دَچھ تہٕ پرٛتھ قسمہٕ کیو میوَ و سٍتۍ گوٚژھ بٔرِ تھ آسُن تہٕ اَتھ نِیہِ عینِ تمہِ وقتہٕ نارٕ ژَٹھ زٲلِتھ ییٚلہِ زن سُہ پانہٕ بُڈ یو مُت آسہِ ، تہٕ تٔمۍ سٕندۍ نا با لغ شُر ۍ آسن نہٕ وَنہِ کُنہِ لا یق؟﴿ یعنی ہرگاہ توٚہۍ یہِ پسند چِھو نہٕ کرا ن زِ تُہٕنز وٲنٛسہِ واد ن ہٕنٛز کمٲے سپدِ أکِس تِتھِس مو قعس پٮ۪ٹھ تبا ہ ، ییٚلہِ زن توٚہۍ تمہِ نِشہِ فٲید ہ تُلنٕکۍ سارِوٕے کھۅتہٕ زیادہ حا جت مند ٲسِو، تہٕ تۅہیہِ آسہِ نہِ روٗد مُت نَوِ سرٕ زیننُک کانٛہہ مو قع پتھ کُن ،تیٚلہِ کِتھہٕ پٲٹھۍ چِھو توٚہۍ یہِ کتھ پسند کران زِ دُنیا ہس منٛز أکِس زِ یٖٹھِس وقتس تام کٲم کر نہٕ پتہٕ ترٲوِو توٚہۍ ٲخرت چہِ زند گی اندر تِتھہٕ پٲٹھۍ قد م زِ توروٲتِتھ لگیَو تۅہیہِ اچا نک پے زِ تُہندِس زند گی ہِندِس پوٗرٕ کار نا مس چُھنہٕ ییٚتہِ کانٛہہ مۅ ل، یِکینژھاہ تۅہیہِ دُنیا خٲطرٕ کمو و مُت اوسُو،سُہ روٗد دُنیا سٕے منٛز۔ ٲخرتس خٲطرٕ اوسُو نہٕ کِہِنۍ کمو و مُت زِ ییٚتہِ کھیٚیہِ ہِو ۍ تَمِیُک پھل ﴾ یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ پننہِ کتھہٕ تۅہیہِ بیان کرا ن بنا ن چُھ زِ توٚہۍ کٔرِ و غورو فکر ۔ع"
  2,267,"۔اے لوکو ! یِمو ایمان چُھو اوٚ نمُت یِم مال تۅہیہِ کمٲوِمٕتۍ چِھو تہٕ یِکینژھاہ اَسہِ زمین منٛزٕ تُہٕندِ خٲطرٕ کوٚڈ مُت چُھ، تمہِ منٛزٕ کٔرِو بہتر ین حصہٕ اللہ تعالیٰ سٕنزِ وَتہِ منٛز خر چ، یِنہٕ یہِ سپدِ زِتٔمۍ سٕنزِ وَتہِ منٛز دِنہٕ خٲطرٕ لٲگِو خرا ب کھۅتہٕ خرا ب چیز ژارنٕچ کوشش کرٕنۍ حالانکہ یۅ ہے چیز ہرگاہ کانٛہہ تۅہیہِ دِیو ،توٚہۍ کٔرِو نہٕ ہرگز تہِ سُہ چیز رٹُن برداشت ، اِلاّیہِ زِرٹنس وِزِؤٹِو أچھ۔تۅہیہِ پز یٚو زانُن زِ اللہ تعالیٰ چُھ بے نیا ز تہٕ بہتر ین صفا ت چِھس وصف ۔"
  2,268,"۔شیطا ن چُھو توٚہۍ غر یبی نِشہِ کھۅژناوان تہٕ شر منا ک طر زِ عمل پانناونٕچ تر غیب چُھو دِوان مگر اللہ تعالیٰ چُھو تۅہیہِ پننہِ مغفر تٕچ تہٕ فضلٕچ اُمید دِوان ،اللہ تعالیٰ چُھ بوٚڈ فرا خ دست تہٕ دانا۔"
  2,269,"۔یُس یژھان چُھ تس چُھ حکمت عطا کرا ن تہٕ یَس حکمت حٲصل سپٕز تس سپٕز در حقیقت بٔڑ دو لت حٲصل، یِمو کتھو نِشہِ چِھ صرف تِمے لُکھ سبق رٹا ن یِم گا ٹٕلۍ چِھ ۔"
  2,270,"۔تۅہیہِ یِکینژھاہ تہِ خر چ آسیٚو کوٚر مُت تہٕ یۅسہٕ نَذر تہِ مٲنۍ مٕژ آسیو۔﴿نذ ر گوٚو یہِ زِ انسان کرِ عہد زِ اگر تس یہِ مُراد پوٗرٕ گوٚو تیٚلہِ کرِ سُہ تِژھ کانٛہہ نیک کٲم یۅسہٕ نہٕ تس پٮ۪ٹھ فر ض آسہِ۔اگر یہِ مُراد کُنہِ حلال تہٕ جٲیز کتھہِ ہُنٛد آسہِ تہٕ خُدا یس آسہِ منگنہٕ آمُت ،تہٕ یہِ مُراد پوٗرٕ گژھنس پٮ۪ٹھ یُس عہد انسانن کوٚر مُت آسہِ سُہ آسہِ اللہ تعالیٰ سٕندی خٲطرٕ ، تیٚلہِ چھےٚ یِژھنذر اللہ تعالیٰ سٕندِس اطا عتس منٛز تہٕ اَمِیُک پوٗرٕ کرُن چُھ اجرو ثوا بُک ذر یعہ ۔ہرگاہ وۅ نۍ یہِ صورت آسہِ نہٕ تیٚلہِ چھےٚ امہِ قسمٕچ نذر  معصیت ﴿گنا ہ﴾ اَمِیُک پوٗرٕ کرُن چُھ عذا بُک ذر یعہ ﴾ خدا یس چُھ تَمیُک علم تہٕ ظٲلِمن ہُنٛد چُھنہٕ کانٛہہ مددگار ۔"
  2,271,"۔ اگر پنٕنۍ صد قا ت عَلا نیہِ ﴿نَنہِ وا نہٕ ﴾ دِیِو ،تیٚلہِ چُھ یِتہِ ٹھیک وۅ نۍ اگر ژھا یہِ پٲٹھۍ حا جت مند ن دِیِو تیٚلہِ چُھ یہِ تُہٕنٛد خٲطرٕ زیادہ بہتر۔تُہنزٕ وار یاہ بُرٲیہِ چھےٚ اَمہِ طر یقہٕ سٍتۍ مِٹا ن تہٕ یِکینژھاہ توٚہۍ کرا ن چِھو ، بہر حال چھےٚ خدا یس تمِچ خبر ۔"
  2,272,"۔اے نبی صلی اللہ علیہ وسلم، تۅہیہِ پٮ۪ٹھ چَھنہٕ لُکن ہدا یت بخشنٕچ ذمہٕ دٲر ی، ہدا یت چُھ خدا یس تام یس ییٚژِھہ تس چُھ بخشا ن تہٕ نیکی ہٕنزِ وَتہِ منٛز یُس مال توٚہۍ خر چ کرا ن چِھو ، سُہ چُھو تۅہیہِ پننہِ خٲطرٕ رُت، ٲخٕر ہَے چِھو توٚہۍ اَمی غر ضہٕ خر چ کرا ن زِ اللہ تعالیٰ سٕنز رضا گٔژھ حٲصل سپٕد نۍ تیٚلہِ یِکینٛژھاہ مال توٚہۍ نیکی ہٕنزِ وتہِ اندر خر چ کٔرِو تِمِیُک پوٗرٕ پوٗرٕ اجر یِیہِ تۅہیہِ دِنہٕ تہٕ ہر گز تہِ سپدِ نہٕ تُہٕنز حق تلفی۔"
  2,273,"۔خا ص طور چِھ تُہنٛدِ مددٕ کۍ حقدار تِم تنگ دست لُکھ یِم اللہ تعالیٰ سٕنٛزِ کامہِ اندر تِتھہٕ پٲٹھۍ چِھ آوٕ ر ۍ گٔمٕتۍ زِ تِم چِھنہٕ ہیٚکا ن پنُن روزگار کما و نہٕ با پت  زمینس پٮ۪ٹھ تگ دَوکٔرِتھ، تِہٕنز خۅددٲر ی وُچِھتھ چُھ نا وٲقف انسان گُمان کرا ن زِ تِم چِھ خۅ شحا ل، توٚہۍ ہیٚکِو تِہٕندِ یٚو بُتھیو پٮ۪ٹھہٕ تِہٕنز اندرونی حا لت پچھٲنِتھ مگر تِم چِھنہٕ اَمہِ قسمٕکۍ زِ لُکن پتہٕ پتہٕ پٔکِتھ منگن تِمن کینٛہہ ،تِہندِس اِعا نتس منٛز یِکینژھاہ مال توٚہۍ خر چ کٔرِ و سُہ روزِ نہٕ خُدا یس نِشہِ کھٔٹِتھ ۔ع"
  2,274,"۔یِم لُکھ پنٕنۍ مال چِھ خر چ کرا ن راتس تہٕ دۅ ہس ژھا یہِ پٲٹھۍ بیٚیہِ نَنہِ وا نہٕ تِہُنٛد اجر چُھ تِہندِس ربّس نِشہِ تہٕ تِہندِ خٲطرٕ چَھنہٕ کُنہِ خو فٕچ تہِ غمٕچ جاے ۔"
  2,275,"۔مگر یِم لُکھ سوٗد کھیوان چِھ تِہُند حال چُھ تس شخصہٕ سُنٛد  ہیوٗآسان یُس شیطا نن زیٖر دِتھ با ولہٕ آسہِ کوٚر مُت ﴿عر بٕکۍ ٲسۍ دیوا نہٕ انسانس مجنو ن  ﴿یعنی آسیب زَدٕہ ﴾ وَنان تہٕ ییٚلہِ کٲنٛسہِ شخصس متعلق یہِ وَنُن آسہِ زِ یہِ چُھ پاگل گوٚ مُت تیٚلہِ ٲسۍ ونان زِ أمِس چُھ جِن ژا مُت۔یۅہے محا ورٕ ہ وَر تٲوِتھ چُھ قرآن سوٗد خور س تَس شخصس سٍتۍ ہِشر دِوان یس دما غ آسہِ ڈوٚ لمُت ﴾ تہٕ اَتھ حالتس منٛز تِہندِ مبتلا گژھنُک وجہ چُھ یہِ زِ تِم چِھ ونان  تجا رت تہِ ہے چھُ سوٗد سٕے ہِیوٗ چیز ،﴿یعنی تِہندِ نظریہ ہٕچ خرٲبی چھےٚ یہِ زِ تِم چِھنہٕ سمجھان فر ق زِ تجا رتس منٛز یُس اصل لاگتس پٮ۪ٹھ مُنا فع چُھ رَٹنہٕ یِوان أمہِ کِس نو عیتس تہٕ سوٗد کِس نو عیتس منٛز ، تہٕ دۅ شوٕنۍ چِھ أکۍ قسمُک چیز سمجِھتھ یہِ دلیل دِوان زِ ییٚلہِ تجا رتس منٛز لگا و نہٕ آمتِس پو نٛسَس پٮ۪ٹھ نفع جٲیز چُھ، تیٚلہِ کیازِ چُھ قر ضس پٮ۪ٹھ دِنہٕ آمتِس پونٛسَس پٮ۪ٹھ نفع رٹُن نا جٲیز ﴾ حالانکہ خدا ین چُھ تجا ر ت حلال کوٚر مُت تہٕ سوٗد حرا م لہٰذا یس شخصس پننِس ربّ سٕندِ طر فہٕ یہِ نصیحت واتہِ تہٕ آیندٕ ہ خٲطرٕ پھیرِ سُہ سوٗد کھیٚنہٕ نِشہِ با ز، تیٚلہِ یِکینژھاہ پتھ کُن تٔمۍ کھیٚوو تہِ کھیون، تٔمۍ سُند معا ملہ چُھ خُدا یس حوالہٕ ﴿یہِ چُھنہٕ آمُت فر ماو نہٕ زِ یِکینژھاہ تٔمۍ کھیٚو وتَتھ کرِ اللہ تعالیٰ معا ف بلکہ چُھ ارشاد یہِ سپدان زِ أمۍ سُند معا ملہٕ چُھ خُدا یس حوالہٕ۔ امہِ کَتھہِ نِشہِ چُھ یہِ پے لگا ن زِ یہِ کھیو ن تہِ کھیو ن  وَننُک مطلب چُھنہٕ زِ یِکینٛژھاہ کھیو ن سُہ آو معا ف کر نہٕ، بلکہ چُھ امہِ نِشہِ محض قا نو نی رعایت مُراد ۔یعنی یُس سوٗد کھینہٕ آو ،تتھ یِیہِ نہٕ قا نو نی طور وا پس دِنُک مطا لبہٕ کر نہٕ ﴾ پتہٕ یُس امہِ حکمہٕ پتہٕ بیٚیہِ ۂہے حر کت کرِ ،سُہ چُھ جہنمی ییتہِ سُہ ہمیشہ روزِ۔"
  2,276,"۔اللہ تعالیٰ چُھ سوٗدس نیست نابو د کرا ن تہٕ صد قا تن چُھ پو چھر دِوان تہٕ اللہ تعالیٰ چُھنہٕ کٲنٛسہِ نا شکر بد عمل انسانس پسند کران وۅ نۍ یِم لُکھ ایمان اَنن تہٕ نیک عملہٕ کر ن،"
  2,277,"۔ بیٚیہِ کر ن نماز قٲیِم تہٕ زکوٰتہ دِن تِہُنٛد اجر چُھ بے شک تِہندِس ربّس نِشہِ تہٕ تِمن خٲطرٕ چُھنہٕ کُنہِ خو فُک تہٕ غمُک مو قع کینٛہہ۔"
  2,278,"۔ اے لوٗکو ! یِمو ایمان اوٚ نمُت چُھو ، خُدایس کھوٗژِو تہٕ یِکینژھاہ تُہُند سوٗد لُکن پٮ۪ٹھ باقی چُھ روٗد مُت، سُہ ترٛٲوِو اگر پٔزۍ پٲٹھۍ تۅہیہِ ایمان چُھو اوٚ نمُت۔"
  2,279,"۔وۅ نۍ ہرگاہ تۅہیہِ یہِ کوٚرُو نہٕ تیٚلہِ سپدِو با خبر زِ اللہ تعالیٰ تہٕ تسٕندِس رسول ﴿صلی اللہ علیہ وسلمن﴾ ہٕنٛدِ طر فہٕ تۅہیہِ خلا ف اعلانِ جنگ ۔﴿یہِ آیت ٲس فتح مکہ پتہٕ نٲزِل سپٕز مٕژ ییٚلہِ زن عر ب اوس اِسلامی مملکتس ماتحت آمُت۔اَمہِ برونٛہہ اگر چہِ سوٗد اکھ نا پسند ید ہ چیز اوس سمجھنہٕ یِوان مگر قا نو نی طور اوس نہٕ یہِ بند کر نہٕ آمُت۔یہِ نٲزِل سپد نہٕ پتہٕ بنیا و اسلامی حکو مت کیٚن حدودن اندر سوٗدی کار و بار اکھ فوجدٲر ی جُر م۔آیت کیٚن ٲخر ی الفا ظن ہٕنٛدِس بُنیا دس پٮ۪ٹھ چھےٚ ابن عبا س رضی اللہ عنہ ، حسن بصر ی رحمتہ اللہ ، ابن سیر ین رحمتہ اللہ تہٕ ربیع بن انس رحمتہ اللہ سٕنز را ے یہِ زِ یُس شخس دارُلا سلامَس اندر سوٗد کھیٚیہِ،سُہ گژِھہ تو بہٕ کر نہٕ مۅ کھہٕ مجبور یُن کر نہٕ۔ تہٕ اگر با ز پھِیوٗر نہٕ تیٚلہِ گژِھہ یُن قتل کر نہٕ۔ با قی فقہا ہن ہٕنز راے چھےٚ زِ یُتھ شخص چُھ قٲد کرُن کٲفی یوٚت تام سُہ سوٗد نہَ کھینُک عہد کرِ توٚت تام گژِھہ نہٕ سُہ یلہٕ یُن ترا و نہٕ ﴾ وُنہ، تہِ چُھ مو قع تو بہٕ کٔرِ و ﴿تہٕ سوٗد ترٲوِو ﴾ پنُن اصل سر مایہِ وا پس رٹنُک چِھو توٚہۍ حق تھاوان نَہ مَہ کٔرِ و ظُلم ،نہ گژِھہ تۅہیہِ پٮ۪ٹھ ظُلم کر نہٕ یُن۔"
  2,280,"تُہُند قر ض دار اگر تنگ دست آسہِ ، تنگ دستی ختم گژھنس تام دِیوٗس مہلت  تہٕ ہرگاہ صد قہٕ کٔرِ و  ، تیٚلہِ چُھ یہِ تُہٕندِ خٲطرٕ زیادہ بہتر اگر توٚہۍ سمجھِو ﴿اَمی آیت منٛزٕ چُھ یہِ حُکم کڑ نہٕ آمُت زِ یُس شخص قر ض نکھہٕ والنہٕ نِشہِ عٲجز سپُد ، اسلامی عدالت کرِ تٔمۍ سٕند ٮ۪ن قر ض دِنہٕ وا لیٚن مُہلت دِنہٕ مۅ کہہٕ مجبو ر تہٕ کینٛژھن حالتن منٛز آسہِ یہِ عدالت پوٗرٕ قر ض یا قر ضُک اکھ حصہٕ معا ف کر ناونٕچ مجا ز تہِ۔ فقہا ہَو چھےٚ وضا حت کٔر مٕژ زِ کٲنٛسہِ ہُنٛد مکا ن یَتھ منٛز بسا ن آسہِ ، کھینہٕ با نہٕ ، لاگنٕکۍ پلَو تہٕ تِم آلات یِمو سٍتۍ سُہ پنُن روزٕ گار کماوان آسہِ ، ہیٚکن نہٕ کُنہِ تہِ حا لتس منٛز قُرُ ق کر نہٕ یِتھ ﴾"
  2,281,"تمہِ دۅ ہ چہ رُسوٲیی تہٕ مصیبت نِشہِ بٔچِو ، ییٚلہِ توٚہۍ خُدا یس کُن واپس گٔژِھو پتہٕ میلہِ تَتہِ پرٛتھ شخصس تٔمۍ سٕنزِ کما و نہٕ آمٕژ نیکی یا بد ی ہُنٛد پوٗرٕ بدلہٕ تہٕ کانٛسہِ پٮ۪ٹھ سپدِ نہٕ ہرگز تہِ ظُلم۔ ع"
  2,282,"۔اے لوٗکو ،یِمو ایمان چُھ  اوٚ نمُت ییٚلہِ توٚہۍ کُنہِ مقرر کر نہٕ آمتہِ وقتہٕ خٲطرٕ پانہٕ وٲنۍ قر ضُک لین دین ٲسِو کران ﴿اَمہِ منٛزٕ چُھ یہِ حُکم نیران زِ قر ضہٕ کِس معا ملس منٛز گژِھہ وقت مقرر کر نہٕ یُن ﴾ تیٚلہِ گژِھہ یہِ لیٚکھِتھ تھاوُن فر یقن در میان گژِھ اکھ شخص انصا ف سان دستاویز لیٚکھُن یس خدا ین پَر نٕچ لیٚکھنٕچ قٲبلیت آسہِ بخشمٕچ ،تس پزِ نہٕ لیٚکھنہٕ نِشہِ انکار کرُن سُہ لیٚکھِن تہٕ اِملا ﴿عبارت ﴾ ؤنِن سُہ شخص یس پٮ۪ٹھ حق چُھ واتان ﴿یعنی قر ض نِنہٕ وول ﴾ تہٕ تس پزِ خدا یس ،پننِس ربّس کھۅژُن زِ یُس معا ملہٕ طے آسہِ سپُد مُت تتھ منٛز گژِھہ نہٕ کانٛہہ کمی بیشی کرُن البتہٕ اگر قر ض نِنہٕ وول خۅد بذا ت آسہِ نادان یا ضعیف آسہِ ، یا آسہِ نہٕ ہیٚکان اِملا کر نٲوِ تھ  تیٚلہِ  کر نٲوِ ن تٔمۍ سُنٛد ولی انصا فہٕ سان اِملا ،پتہٕ تھٲوِ یوٗکھ پننیو مر دَو منٛزٕ زٕ ہ نفرواَتھ پٮ۪ٹھ گواہ تہٕ اگر زٕ ہ مرد آسن نہٕ تیٚلہِ گژھن اکھ مرد تہٕ زٕ ہ مستوٗراتہٕ آسنہِ۔ یِم گواہ گژھن تِتھیو لُکو منٛزٕ آسٕنۍ ،یِہنزِ گوٲہی تۅہیہِ در میان مقبول آسہِ تا کہ اگر أکِس مٔشِتھ گژِھہ بیٚاکھ پاو یٚس یاد، گواہن ییٚلہِ گواہ بننہٕ موجوٗب وَننہٕ یِیہِ ، تیٚلہِ پزِ نہٕ تِمن انکار کرُن، معا ملہٕ ٲسِتن لۅکُٹ یا بوٚڈ، معیادمُقرر کٔرِ تھ گژِھہ نہٕ اَمیُک دستا و یز لیٚکھنا ونس کٲہلی ورتاوِنۍ ،خُدایس نکھہٕ چُھ یہِ طریقہ تُہندِ خٲطرٕ زیادٕہ انصا فس پٮ۪ٹھ بناو نہٕ آمُت، اَمہِ سٍتۍ چھےٚ شہا دت قٲیِم سپد نس پٮ۪ٹھ زیادہ سہو لیت گژھان ،تہٕ شکن تہٕ شُبہا تن منٛز مبتلا سپد نُک امکان چُھ تُہٕندِ خٲطرٕ کم روزان البتہ یُس تجارتی لین دین توٚہۍ اَتھو پیٚٹھی پانہٕ وٲنۍ کران چِھو کانٛہہ حر ج چُھنہٕ اگر یہِ لیٚکھِتھ یِیہِ نہٕ تھاو نہٕ مگر تجا رتی معا ملہٕ طے کر نہٕ وقتہٕ گژھن گواہ تھاوٕنۍ ،کٲتب تہِ گواہ گژِھہ نہٕ ستاو نہٕ یُن، اگر یہِ کٔرِو تیٚلہِ کٔرِ و گُنا ہُک اَتُر ،اللہ تعالیٰ سٕندِ غضبہٕ نِشہِ بٔچِو ،سُہ چُھو تۅہیہِ عملہِ ہٕندِ صحیح طریقٕچ تعلیم دِوان تہٕ تس چُھ پرٛتھ چیزُک علم۔"
  2,283,"۔ہرگاہ توہۍ سفر کِس حالتس اندر چِھو تہٕ دستا ویز لیٚکھنہٕ خٲطرٕ سپدیٚو نہٕ کٲتب دستیا ب، تیٚلہِ کٔرِ و ورَہن با لقَبَضس پٮ۪ٹھ معا ملہٕ طے ﴿رہن بِالقَبضُک مقصد چُھ صرف یہِ زِ قر ض دِنہٕ وٲلِس گژِھہ پننہِ قر ض چہِ واپسی ہُنٛد اطمنا ن سپدُن۔ مگر تس چُھنہٕ پننِس دِنہٕ آمتِس مال کِس معا و ضس منٛز گِرو تھاو نہٕ آمتِس چیز س فٲیدٕ تُلنُک حق، تِکیازِ یہِ چُھ سوٗد۔البتہ اگر کانٛہہ جانور گرِ و آسہِ آمُت رَٹنہٕ ،تیٚلہِ ہیٚکہِ تٔمۍ سُنٛد دۅد استعمال کر نہٕ  یِتھ ،تس ہیکہِ سوٲر ۍ تہٕ بور تُلنا ونٕچ خد مت ہیٚنہٕ یِتھ، تِکیازِ یہِ چُھ دراصل تَمہِ غذا ہُک معا و ضہٕ یُس گرِ و رَٹن وول تس جانورس کھیاوان چُھ۔ ﴾اگر تۅہیہِ منٛزٕ کانٛہہ شخص دوٚ یِمس شخصس پٮ۪ٹھ بھر وسہٕ کٔرِ تھ تس سٍتۍ کانٛہہ معا ملہٕ طے کرِ تیٚلہِ یس پٮ۪ٹھ بھر وسہٕ کر نہٕ آو ، تس پزِ زِ امانت کٔرِن ادا، بیٚیہِ کھوٚژِن خدا یس ،پننِس ربّس۔تہٕ ہرگز مَہ چُھپٲوِو شہا دت، یُس شہادت چُھپاوان چُھ تٔمۍ سُنٛد دِل چُھ گنا ہس منٛز آلو دٕ تہٕ اللہ تعالیٰ  چُھنہٕ تُہند یٚو اعمالو نِشہِ بے خبر ۔"
  2,284,"۔آسما نن تہٕ زمینس اندر یِکینٛژھاہ چُھ، سورُے چُھ اللہ تعالیٰ سُند خوا ہ توٚہۍ پننہِ دِل چہِ کتھہٕ ظٲہر کٔرِ تو یا چھپٲوِ تو، اللہ تعالیٰ ہیٚیہِ بہر حال تِہُنٛد حسا ب تۅہیہِ ،پتہٕ چُھ تس اختیار  یَس یژِھہ تس کرِ معا ف تہٕ یس ییژِھہ تس دِیہِ سزا ، سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان ۔"
  2,285,"۔رسول ﴿صلی اللہ علیہ وسلمَو﴾ چُھ تتھ ہدا یتس پٮ۪ٹھ ایمان اوٚ نمُت یُس تِمن پٮ۪ٹھ تِہنٛدِ س ربّ سٕنٛدِ طر فہٕ نٲزِل چُھ سپُد مُت تہٕ یِم لُکھ أمِس رسولس صلی اللہ علیہ وسلمس مانن وٲلۍ چِھ ، تِمو تہِ چُھ یہِ ہدا یت دِلہٕ سٍتۍ تسلیم کوٚر مُت، یِم سٲر ی چِھ خدایس ،تٔمۍ سٕندٮ۪ن فر شتن ،تٔمۍ سٕنز ن کتا بن تہٕ تٔمۍ سٕندٮ۪ن رسولن مانان تہٕ تِہُنٛد قَو ل چُھ یہِ زِ  أسۍ چِھکھ نہٕ خدا ے سٕندۍ رسول اکھ أکِس نِشہِ الگ کران۔ اَسہِ بوٗز حُکم تہٕ اطاعت کٔر قبول۔ اے  مالکہٕ ،اَسہِ کر مغفرت تہٕ اَسہِ چُھ ژیے کُن واپس پھیرُن۔"
  2,286,"۔اللہ تعالیٰ چُھنہٕ کٲنٛسہِ جاندارس پٮ۪ٹھ تٔمۍ سٕندِ طا قتہٕ کھۅتہٕ زیادہ ذمہٕ دٲر ی ہُند با ر ترحاوان، پرٛتھ شخصن یوسہٕ نیکی کٔر،تَمِیُک پھل چُھ تٔمۍ سٕندِی خٲطرٕ تہٕ یوسہٕ بد ی کٔر مٕژ چَھن ،تِمیُک وبال چُھ تٔمۍ سٕے پٮ۪ٹھ۔﴿اے ایمان اَنن والیو ، توٚہۍ کٔرِ و یِتھہٕ پٲٹھۍ دعا ﴾ اے سانہِ ربّہٕ، اسہِ یِم قصور سہواً گژھن، تِمن پٮ۪ٹھ مَہ رٹھ اَسہِ ،سا نہٕ مٲلکہٕ ، اسہِ پٮ۪ٹھ مَہ ترٛا و تِم بار یِم ژےٚ اَسہِ برونٛٹھمیٚن لُکن پٮ۪ٹھ ٲسی ترٲوِ مٕتۍ ،سانہِ پروردگارٕ ،یُس بار اَسہِ منٛز تُلنُک طا قت چُھنہٕ ،سُہ مَہ تھاو اَسہِ پٮ۪ٹھ ،اَسہِ سٍتۍ کر نر می اَسہِ کردر گُز ر اَسہِ پٮ۪ٹھ کر رحم ژٕ چُھکھ سو مولیٰ ،کٲفر ن ہٕنٛدِس مقا بلس منٛز کر اَسہِ مدد۔ ع"
