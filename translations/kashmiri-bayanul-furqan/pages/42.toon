quran[53]{c,v,t}:
  42,1,"ح م،"
  42,2,"۔ع س ق۔"
  42,3,"۔یِتھے پٲٹھۍ چُھ غٲلب تہٕ حکمت وول خُداے تۅہیہِ کُن تہٕ تۅہیہِ بروٗنٹھمیٚن گُزریمتیٚن ﴿رسُو لن ﴾ کُن وَحی کران روٗد مُت۔﴿یعنی یِمہٕ کتھہٕ قرآنس منٛز بیان چھےٚ کر نہٕ یِوان یِمے کتھہٕ چھےٚ خُداین وَحی ہِندِ ذر یعہ رسول اللہ صلی اللہ علیہ وسلمن پٮ۪ٹھ نٲزِل کرِ مَژٕ تہٕ بروٗنٹھمیٚن رسُو لن پٮ۪ٹھ تہِ چُھ سُہ یِمے کتھہٕ نٲزِل کران روٗد مُت ۔﴾"
  42,4,"۔آسما نن تہٕ زمینس منٛز یِکینژھاہ تہِ چُھ سُہ چُھ تٔمۍ سُندُے ،سُہ چُھ برتر تہٕ عظمت وول۔"
  42,5,"۔قر یب چُھ زِ آسمان پھٹن پیٚٹھۍ کِنۍ ۔﴿ یعنی یہِ چَھنہٕ کانٛہہ معمولی کتھ زِ اللہ تعالیٰ سٕنزِ خُدٲیی منٛز یِیہِ کُنہِ تہِ حیثیت کانٛہہ مخلو ق شر یک قرار دِنہٕ ، یہِ چھےٚ تِژھہ سخت کتھ زِ اتھ پٮ۪ٹھ اگر آسمان پھٹن نا ممکن چُھنہٕ کینٛہہ ﴾ فر شتہٕ چِھ پننِس ربّ سٕندِ حمدٕ سان تسبیح کران،تہٕ زمین وا لیٚن ہٕندِس حقس منٛز چِھ در گزر کر نٕکۍ در خوا ست کران۔خبردار روٗزِ و ، حقیقتس منٛز چُھ اللہ تعالیٰ غفورورحیم۔"
  42,6,"۔یِمو لُکو سُہ ترٲوِتھ پنٕنۍ کینٛہہ با قی سر پرست چِھ بنٲوِ مٕتۍ۔﴿ دراصل چُھ لفظ""اولیا ""وَر تا و نہٕ آمُت ییٚمیُک مفہو م عر بی زبٲنۍ منٛز سٮ۪ٹھاہ وسیع چُھ۔ بٲطل معبودن متعلق چِھ گُمرا ہ انسانن ہٕندۍ مختلف عقیدٕہ تہٕ وا ریاہ مختلف طر زِ عمل یِم قرآن مجیدس منٛز خُدایس ورٲے با قی پنُن ولی بنا و نس سٍتۍ چِھ تعبیر آمٕتۍ کر نہٕ ۔ قرآن موجوٗب چُھ انسان تس ہستی پنُن ولی بناوان﴿1﴾ ییٚمۍ سٕندِس وَننس پٮ۪ٹھ سُہ پکہِ ،ییٚمۍ سٕندِس ہدا یتس پٮ۪ٹھ عمل کرِ تہٕ ییٚمۍ سٕندٮ۪ن مُقرر کر نہٕ آمتیٚن طر یقن ،رسمن ،قانونن تہٕ ضٲبطَن ہٕنز پیروی کرِ ﴿2﴾ ییٚمۍ سٕنزِ رہنمٲیی پٮ۪ٹھ سُہ اعتماد کرِ تہٕ یہِ سمجھہِ زِ سُہ چُھ تس صحیح وَتھ وَنن وول تہٕ غلطی نِشہِ بچا ون وول﴿3﴾ یَس متعلق  سُہ یہِ سمجھہِ زِ اگر بہٕ دُنیا ہس منٛز کینٛہہ تہِ روزٕ کران، سُہ بچا وِ مےٚ امہِ کیو بُرٕ نتیجو نِشہِ ، تہٕ اگر خُداے چُھ تہٕ ٲخرت تہِ چُھ یِنہٕ وول تیٚلہِ بچا و یٚم تَمہِ کہ عذا ب نِشہِ تہِ ﴿4﴾ یس متعلق سُہ یہِ سمجھہِ زِ سُہ چُھ تس دُنیا ہس منٛز فوق الفطر ی طر یقہٕ مدد کران، آفات و مصٲیِبَو نِشہِ چُھس حفاظت کران،تس چُھ روزگار دِوان ، اولاد چُھس دِوان ، مُراد چُھس پوٗرٕ کران تہٕ با قی پرٛتھ قسمٕکۍ حا جت چُھس پوٗرٕ کران ۔ ﴾ اللہ تعالیٰ ہٕے چُھ تِمن پٮ۪ٹھ نِگران ،توٚہۍ چِھو نہٕ تِہِندۍ ذمہٕ دار۔"
  42,7,"۔آ، یِتھے پٲٹھۍ چُھ اے نبی صلی اللہ علیہ وسلم،یہِ عر بی قرآن اسہِ تۅہیہِ کُن وَحی کوٚر مُت تا کہ توٚہۍ کٔرِو بٔستِیَن ہُند مر کز ﴿شہرِ مکّہ﴾ تہٕ اَمہِ کِس أندۍ پٔکِس منٛز روزن وٲلۍ خبردار،تہٕ جمع سپدن والہِ دۅہ نِشہِ کھۅژنٲوِ یوٗکھ ییٚمہِ کِس یِنَس منٛز کانٛہہ شک چُھنہٕ۔ أکِس دٔرِس چُھ جنّتس تہٕ بیٚکِس دٔرِس چُھ جہنمس منٛز گژُھن۔"
  42,8,"۔اگر اللہ تعالیٰ ییژِھہ ہے یِمن سارِنٕے بنا وِ ہے اَکٲے اُمّت،مگر سُہ یَس یژھان چُھ تس چُھ پننِس رحمتس منٛز دٲخل کران،تہٕ ظٲلِمن نہ چُھ کانٛہہ ولی تہٕ نہ چُھکھ مدد گار۔"
  42,9,"۔یِم چھا ﴿ تِتھِۍ نادان زِ ﴾ سُہ ترٲوِ تھ چِھ یِمَو با قی بناوِ مٕتۍ ولی ؟ ولی چُھ اللہ تعالیٰ ہٕے ،سُے چُھ مۅردن زندٕہ کران، تہٕ سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔ ع"
  42,10,"۔تۅہیہِ در میان یتھ معا ملس پٮ۪ٹھ اختلا ف سپدِ ﴿ییٚتہِ پٮ۪ٹھہٕ اگر چہِ آیت 12/ہس تام پوٗرٕ عبا رت اللہ تعالیٰ سٕندِ طر فہٕ وَحَی چھےٚ مگر یتھ منٛز چُھنہٕ متکلّم اللہ تعالیٰ، بلکہ چِھ رسول اللہ صلی اللہ علیہ وسلم ۔ گویا اللہ جلّ شانٗہ چُھ پننِس نبی صلی اللہ علیہ وسلمس ہدا یت دِوان زِ توٚہۍ کٔرِو یہِ اعلان ۔اَمِچ مِثال چھےٚ سورۂفا تحہ،یُس اگر چہِ اللہ تعالیٰ سُند کلام چُھ، مگر بندٕہ چِھ پننہِ طر فہٕ یہِ دُعا کہ طور اللہ تعالیٰ سٕندِس در بارس منٛز پیش کران۔ ﴾ تمِیُک فٲصلہٕ کرُن چھےٚ اللہ تعالیٰ سٕنز کٲم،سُے اللہ چُھ میو ن ربّ،تٔسۍ پٮ۪ٹھ کوٚر مےٚ بھر وسہٕ ، تہٕ تٔسۍ کُن چُھس بہٕ رجوع کران ۔"
  42,11,"۔آسمانن تہٕ زمینُک بناو ن وول ، ییٚمۍ تُہندِ جنسہٕ منٛزٕ تُہندِ خٲطرٕ جورٕ پٲدٕ کٔرۍ، تہٕ یِتھے پٲٹھۍ بنٲوِ ن جا نورن منٛز تہِ ﴿تِہِندی ہم جنس ﴾ جورٕ ، تہٕ امہِ طر یقہٕ چُھ سُہ تُہٕندۍ نسل پھٔہلاوان۔کا ینا تُک کانٛہہ چیز چُھنہٕ تس ہیوٗ، سُہ چُھ سورُےکینٛہہ بوزن وول تہٕ وُچھن وول،"
  42,12,"۔آسمانن تہٕ زمین کیٚن خزانن ہٕنزٕ کُنزٕ چھےٚ تٔسۍ نِشہِ ،یَس یژھان چُھ کھلہٕ رز ق چُھس دِوان،تہٕ یس یژھان چُھ مِیٖنِتھ توٗلِتھ چُھس دِوان ، تس چُھ پرٛتھ چیزُک علم"
  42,13,"۔تٔمۍ چُھ تُہندِ خٲطرٕ دِینُک سُے طر یقہٕ مقرر کوٚر مُت ییٚمِیُک حُکم تٔمۍ نو ح علیہ السلامس دِیتمُت اوس،تہٕ یُس ﴿اے محمد صلی اللہ علیہ وسلم ﴾ وۅ نۍ اسہِ تۅہیہِ کُن وَحَی ہٕندِ ذر یعہ سوٗز مُت چُھ، تہٕ ییٚمیُک ہدا یت اسہِ ابرا ہیم علیہ السلام تہٕ مو سیٰ علیہ السلام تہٕ عیسیٰ علیہِ السلامَس دِیتمُت چُھ،امہِ تٲکید سان زِ قٲیم کٔرِو یہِ دِین تہٕ اتھ منٛز مَہ سپدِ و بِیوٚ ن بِیوٚ ن۔یٔہے کتھ چھےٚ یِمن مُشر کن سخت نا گوار گٔمٕژ یتھ کُن ﴿ اے محمد صلی اللہ علیہ وسلم ﴾ توٚہۍ یِمن دعوت چِھو دِوان ۔ اللہ تعالیٰ یَس یژھان چُھ تس چُھ پنُن بناوان ،تہٕ سُہ چُھ پانس کُن ینٕچ وَتھ تٔسۍ ہاوان یُس تس کُن رجوع کرِ۔"
  42,14,"۔لُکن منٛز یُس پھا ٹوَن واد ظٲہر سپُد،سُہ سپُد امہِ پتہٕ زِ تِمن نِشہِ اوس عِلم آمُت،تہٕ اَتھ بِنا ہس پٮ۪ٹھ سپُد زِ تِم ٲسۍ اکھ أکِس پٮ۪ٹھ زیا دتی یژھان کرٕ نۍ ۔ اگر تہِندۍ ربّن گۅڈے آسہِ ہے نہٕ یہِ فر مو و مُت زِ أکِس مقرر کر نہٕ آمٕتِس وقتس تام یِیہِ فٲصلہٕ مُلتوی تھا و نہٕ ، تیٚلہِ آسہِ ہے یُہُند قضّیہِ مۅ کلا و نہٕ آمُت۔تہٕ حقیقت چھےٚ یہِ زِ بروٗنٹھمیو پتہٕ یِم لُکھ کتا بہِ ہٕندۍ وٲرث بنا و نہٕ آے، تِم چِھ تمہِ طر فہٕ سٮ۪ٹھاہ اضطراب انگیز شکس منٛز۔﴿یعنی یِم نسل پتہٕ آے تِمن روٗدنہٕ یہِ اطمنان زِ یِمہٕ کتا بہٕ تِمن واژمژٕ چھےٚ ،تِمہٕ کتھ حدس تام چھےٚ پننِس صحیح صوٗرتس منٛز تہٕ کتھ حدس تام چھےٚ تِمن منٛز مِلا وٹ سپٕز مٕژ۔تِم چِھنہٕ یِتہِ یقین سان زانان زِ تِہندیو انبیا ہَو کیا تعلیم ٲس أنمٕژ۔پرٛتھ کانٛہہ چیز چُھ تِمن نِشہِ مشکو ک تہٕ ذہنن چُھکھ کُھر اَنان۔"
  42,15,"۔﴿چو نکہ یہِ حا لت چھےٚ پٲدٕ سپٕز مٕژ ﴾ اے محمد صلی اللہ علیہ وسلم ، اَمہِ موجو ب دِیو وۅ نۍ توٚہۍ تٔتھۍ دینس کُن دعوت ، تہٕ یِتھہٕ پٲٹھۍ تۅہیہِ حکم چُھو دِنہٕ آمُت تٔتھۍ پٮ۪ٹھ سپدِ و مضبو طی سان قٲیِم ، تہٕ یِمن لُکن ہٕنز ن خو ٲ ہشا تن ہٕنز اِتبا ع مَہ کٔرِو، تہٕ یِمن ؤنِو زِ "" خُدا ین یۅ سہٕ کتا ب نٲزِل چھےٚ کٔر مٕژ مےٚ اوٚ ن تتھ پٮ۪ٹھ ایمان ۔ مے چُھ حکم دِنہٕ آمُت زِ بہٕ کرٕ تۅہیہِ در میان انصا ف۔اللہ تعالیٰ چُھ میو ن ربّ تہِ تہٕ تُہُند ربّ تہِ۔ٲنۍ اعمال چھِ سانہِ خٲطرٕ تہٕ تُہٕںدۍ اعمال چھِ تُہٕندِ خٲطرٕ۔اسہِ تہٕ تۅہیہِ در میان چُھنہٕ کانٛہہ نیا ے۔﴿یعنی معقو ل دٔلیلو سان کتھ سمجھاو نُک یُس حق اوس سُہ کوٚر اَسہِ ادا۔ وۅ نۍ کیا فایدہ چُھ بٔلۍ ژُو نہٕ سٍتۍ ۔توٚہۍ اگر اسہِ سٍتۍ ژُوِ و،مگر أسۍ چِھنہٕ ژُوٕ نہٕ خٲطرٕ تیا ر ۔ ﴾ اللہ تعالیٰ کرِ اکہِ دۅہ اسہِ سارِنٕے جمع تہٕ تٔسۍ کُن چُھ سارِنٕے گژُھن"""
  42,16,"۔اللہ تعالیٰ سٕندِس دعوتس پٮ۪ٹھ لبیّک وَننہٕ پتہٕ یِم لُکھ ﴿لبیّک ونن والیٚن سٍتۍ ﴾ اللہ تعالیٰ سٕندِس معا ملس منٛز ژُوان چِھ ،تِہٕنز حُجت بٲزی چھےٚ تِہندِس ربّس نزدیک بٲطِل، تہٕ تِمن پٮ۪ٹھ چُھ تٔمۍ سُند غضب تہٕ تِہندِ خٲطرٕ چُھ سخت عذا ب۔"
  42,17,"۔سُہ چُھ اللہ تعالیٰ ہٕے ییٚمۍ حقہٕ سان یہِ کتا ب تہٕ میزان چُھ نٲزِل کوٚر مُت۔﴿میزان نِشہِ چُھ مُراد اللہ تعالیٰ سُند شر یعت یُس ترٛکرِ ہٕندۍ پٲٹھۍ چُھ توٗلِتھ صحیح تہٕ غلط ،حق تہٕ بٲطِل ، ظلم تہٕ عدل بیٚیہِ را ستی ہٕنز فر ق واضح کران ۔ ﴾ تہٕ تۅہیہِ کیا خبر چَھو ، بنان چُھ زِ فٲصلٕچ گٔر آسہِ نکھے وٲژ مٕژ۔"
  42,18,"۔ یِم لُکھ تَمہِ کِس یِنَس پٮ۪ٹھ ایمان چِھنہٕ تھاوان ، تِم چِھ تمہِ خٲطرٕ با نبٕر کران،مگر یِم اَتھ پٮ۪ٹھ  ایمان چِھ تھاوان تِم چِھ تتھ کھۅژان، تہٕ زانان چِھ زِ یقیناً چھےٚ سۅ یِنہٕ وا جِنۍ ۔ بوٗزِ و یِم لُکھ تمہِ گرِ ہٕندِس یِنَس منٛز شک تراون وٲلۍ بحث چِھ کران، تِم چِھ گُمرٲہی منٛز واریاہ دوٗر درٛ امٕتۍ۔"
  42,19,"۔اللہ تعالیٰ چُھ پننیٚن بند ن پٮ۪ٹھ سٮ۪ٹھاہ مہر بان۔پَس یِکینژھاہ یژھان چُھکھ تہِ چُھکھ دِوان،تہٕ سُہ چُھ سٮ۪ٹھاہ قُوّت وول تہٕ زبردست ۔ع"
  42,20,"۔یُس کانٛہہ ٲخرتُک زراعت چُھ یژھان،تٔمۍ سُند زراعت چِھ أسۍ بڑھاوان، تہٕ یُس دُنیا ہُک زراعت چُھ یژھان تس چِھ دُنیا منٛز ے دِوان،مگر ٲخرتس منٛز چُھنہٕ تٔمۍ سُند کانٛہہ حصّہٕ۔"
  42,21,"۔کیا یِم لُکھ چھا کینٛہہ تِتھۍ شر یک خدا تھاوان، یِمو یِہندِ خٲطرٕ دِ ینٕچ نوعیت تھا ون وول اکھ تِیُتھ طر یقہٕ چُھ مُقرر کوٚر مُت،ییٚمیُک خدا ین اِذن چُھنہٕ دِیتمُت؟ ﴿ یتھ آیتس منٛز چُھ "" شُر کَا "" نِشہِ مُراد زِ یہِ کتھ چھےٚ ٹا کارٕ ہ زِ تِم چِھنہٕ شر یک یِمن یِم  لُکھ  دعا چھِ منگان یا یِمن نذرونیاز چھِ کھالان یا یِمن برونٛہہ کنہِ پوٗزا پاٹٕکۍ رسم چھِ ادا کران ۔بلکہ چھِ یِمو نِشہِ مُرادتِم انسان ، یِم لُکو چِھ شر یک فی الحکم ٹھٔہرٲوِمٕتۍ، یِہٕندٮ۪ن ہیچھنا و نہٕ آمتیٚن افکارن، عقٲیدن ، نظر یاتن تہٕ فلسفن پٮ۪ٹھ لُکھ ایمان چِھ انان، یِہنز ن دِنہٕ آمژن قدرن مانان چِھ ، یِہند ٮ۪ن پیش کر نہٕ آمتیٚن اخلٲقی اصو لن تہٕ تہذ یب و ثقا فت کیٚن معیار ن قبول چِھ کران۔ یِہندۍ مُقرر کر نہٕ آمٕتۍ قا نون ،طر یقہٕ تہٕ ضٲبطہٕ پننیٚن مذہبی رسمن تہٕ عبا دتن منٛز ، پننہِ شخصی زند گی منٛز، پننِس مُعا شرتس منٛز، پننِس تمدُنس منٛز ،پننِس کاربارس تہٕ لین دینس منٛز، تہٕ پننِس سیا ستس تہٕ حکو متس منٛز تِتھہٕ پٲٹھۍ  چِھ اختیار کران زَنتہٕ یۅہے سُہ شر یعت چُھ ییٚمِچ پیر وی تِمن کرٕنۍ پزِ ۔ ﴾ اگر فٲصلٕچ کتھ طے آسِہے نہٕ سپٕز مٕژ تیٚلہِ آسہے یُہُند قضیّہ مۅکلا و نہٕ آمُت۔یقیناً چُھ یِمن ظٲلِمن خٲطرٕ درد ناک عذا ب۔"
  42,22,"۔توٚہۍ وُچِھو زِ یِم ظٲلِم آسن تمہِ وقتہٕ پننہِ کرِ مَتہِ کِس انجا مس کھۅژان،تہٕ سُہ روزِ یِمن پٮ۪ٹھ یِتھ۔اَتھ بر عکس یِمو لُکو ایمان چُھ اوٚ نمُت تہٕ یِمو نیک عملہٕ چھےٚ کرِ مٕژ،تِم آسن جنت کیٚن گُلستا نن منٛز ، یِکینژھاہ تہِ تِم یژھن تہِ میلہِ تِمن ربّس نِشہِ ، یۅ ہے چُھ بوٚڈ فضل ۔"
  42,23,"۔یہِ چُھ سُہ چیز ییٚمِچ خۅ ش خبر اللہ تعالیٰ پننیٚن تِمن بند ن چُھ دِوان یِمو مو ن تہٕ یِمَو نیک عملہِ کرِ۔ اے نبی صلی اللہ علیہ وسلم ، یِمن لُکن ؤنِو زِ "" بہٕ چُھس نہٕ یتھ کامہِ پٮ۪ٹھ تۅہیہِ نِشہِ کُنہِ اَجرُک طٲلب۔ البتہ چُھس قرابتُک محبت ضروٗر یژھان۔""﴿یتھ آیتس چِھ ترےٚ تفسیر کر نہٕ آمٕتۍ:﴿1﴾ بہٕ چھُس نہٕ یتھ کامہِ پٮ۪ٹھ تۅہیہِ نِشہِ کانٛہہ اجر طلب کران، مگر یہِ چُھس ضروٗر یژھان زِ توٚہۍ لُکھ ﴿ یعنی اہلِ قر یش ﴾ کٔرِ تو کم از کم تمہِ رشتہٕ دٲری ہُند لحا ظہٕ یوسہٕ مےٚ تہٕ تۅہیہِ در میان چھےٚ ۔ یہِ کُس ستم چُھ زِ سارِوٕے کھۅتہٕ زیادہ چِھو توٚہۍ میا نی دشمنی پٮ۪ٹھ بضِد""۔ ﴿2﴾ بہٕ چُھس نہٕ تۅہیہِ نِشہِ یتھ کامہِ پٮ۪ٹھ امہِ ورٲے کانٛہہ اَجر یژھان زِ تۅہیہِ منٛز گٔژھ اللہ تعالیٰ سٕنزِ نزدیکی ہٕنز چا ہت گژٕھنۍ پٲدٕ۔"" ﴿3﴾ تر ییُم تفسیر یِمو مُفسر و کوٚر مُت چُھ تِمو منٛزٕ چِھ کینٛہہ اقا ر بَو نِشہِ تمام بنی عبد المطلب مراد نِوان ، تہٕ کینٛہہ چِھ اَتھ صرف حضرت علی رضی اللہ عنہ تہٕ حضر ت فا طمہ رضی اللہ عنہا تہٕ تِہِندٮ۪ن اولادن تام محدود تھاوان۔مگر واریاہ ہَو وجود ہا تَو کِنۍ چُھنہٕ یہِ تفسیر کُنہِ پٲٹھۍ تہِ قٲبل ۔اوّل ییٚمہِ وقتہٕ مکّہ معظمس منٛز سورۂ شوریٰ نٲزِل چُھ سپُد مُت ، تَمہِ ساعتہِٕ اوس نہٕ حضرت علی رضی اللہ عنہ تہٕ حضر ت فاطمہ رضی اللہ عنہا سُند خا ندرٕ ے سَپُد مُت ، اولاد سُند چُھنہٕ سوالٕے۔تہٕ بنی عبد المطلب منٛزٕ ٲسۍ نہٕ نبی صلی اللہ علیہ وسلمن اَند ہیٚتھ سٲری ساتھ دِوان، بلکہ ٲسۍ تِمو منٛزٕ کینٛہہ نَنہِ وانہِ دشمنن ہٕندۍ سٲتھی ، تہٕ ابو لہب سُند عداوت چُھ سورُے دُنیا زانان۔ دوم یہِ زِ ، نبی صلی اللہ علیہ وسلمن ہٕندۍ رشتہٕ دار ٲسۍ نہٕ صرف بنی عبد المطلب یٲتۍ۔حضور صلی اللہ علیہ وسلمن ہٕنزِ وٲلدٕ ہ سٕندِ کِنۍ ، وٲلد صٲبنہِ کِنۍ بیٚیہِ حضر ت خد یجہ رضی اللہ عنہا ﴿خاندارِنہِ ﴾ ہٕندِ کِنۍ ٲس تمام گھر ن منٛز حضور صلی اللہ علیہ وسلم ہٕنز رشتہٕ دٲری۔یِمن سارنٕے گھر ن منٛز ٲسۍ حضور  صلی اللہ علیہ وسلمن  ہٕندۍ بہتر ین حٲمی تہِ تہٕ بدتر ین دشمن تہِ ۔ تر ییِم کتھ یۅسہٕ یِمو سارِ وٕ یو کھۅتہٕ زیادہ اہم چھےٚ ، سۅ چھےٚ یہِ زِ اکھ نبی یتھ بلند مقا مس پٮ۪ٹھ کھڑا سپدِتھ دعوتِ اَلَی اللہ ہُک آلَو بُلند چُھ کران ،تمہِ مقا مہٕ پٮ۪ٹھہٕ اَتھ کارِ عظیمس پٮ۪ٹھ یہِ بدلہٕ منگُن زِ توٚہۍ کٔرِ و میا نیٚن رشتہٕ دارن سٍتۍ محبت،چھےٚ تیٖژاہ ؤسۍ  پایہ، کتھ زِ کانٛہہ نیک خصلت تھاون وول انسان ہیٚکہِ نہٕ امِیُک تصوّرٕے کٔرِ تھ زِ خُداین آسہِ پننِس نبی صلی اللہ علیہ وسلمس یہِ کتھ ہیٚچھنٲو مٕژ تہٕ نبی صلی اللہ علیہ وسلمو آسہِ قر یش کیٚن لُکن منٛز کھڑا سپدِ تھ یہِ کتھ ؤنِمٕژ۔امہِ علا وہ چھےٚ یہِ کتھ وارَے زیادٕہ بے مو قع باسان ییٚلہِ أسۍ وُچھان چِھ زِ امہِ کلا مٕکۍ مخٲلف چِھنہٕ اہلِ ایمان کینٛہہ بلکہ چِھ کفّار ۔ہیرِ پٮ۪ٹھہٕ چُھ سورُے تقر یر یِمنٕے کُن کر نہٕ یِوان تہٕ برونٛہہ کُن تہِ چُھ رُوے سخن یِمنٕے کُن۔ اتھ سلسلۂ کلا مَس منٛز کتہِ چُھ مخٲلِفَو نِشہِ کُنہِ نو عیتُک بد لہٕ طلب کر نُک سوال گژھان پٲدٕ ۔ بد لہٕ چُھ تِمن لُکن یِوان منگنہٕ یِہنزن نظر ن منٛز تتھ کامہِ کانٛہہ قدر آسہِ یۅسہٕ کٲنٛسہِ شخصن تِہندِ خٲطرٕ آسہِ انجامِ دِژ مٕژ۔ ﴾ یُس کانٛہہ اَکھا ہ رٕژر کماوِ، أسۍ کر و تٔمۍ سٕندِ خٲطرٕ تتھ رٕ ژرس منٛز بہتر ی ہُند اضا فہٕ ۔  بے شک چُھ اللہ تعالیٰ سٮ۪ٹھاہ در گزر  کر ن وول تہٕ قدر دان"
  42,24,"۔یِم لُکہ چھا وَنان زِ أمۍ شخصن چُھ خُدا یس پٮ۪ٹھ اَپُز بہتا ن تُھر مُت؟ اگر اللہ تعالیٰ ییژِھہ تُہٕندِ س دِلس پٮ۪ٹھ کرِ مۅ ہر۔ ﴿مطلب چُھ یہِ زِ اے نبی صلی اللہ علیہ وسلم ، یِمو لُکو چِھو توٚہۍ تہِ پنٕنۍ پٲٹھۍ مجٕھمٕتۍ ، یِتھ پٲٹھۍ یِم خۅد پننیو غر ضو خٲطرٕ بڈِ کھۅتہٕ بوٚڈ اَپُز چِھ ونان ، تِمو سوٗنچ زِ تۅہیہِ تہِ چُھو تِتھے پٲٹھۍ پنُن دُکان چمکاو نہٕ خٲطرٕ اکھ اَپُز تُھر مُت، مگر یہِ اللہ تعالیٰ سُند عنا یت زِ تٔمۍ چَھنہٕ تُہندِ س دِلس پٮ۪ٹھ سۅ مۅ ہر لگا و مٕژ یۅسہٕ یِہند ٮ۪ن دِلن پٮ۪ٹھ چھن لگٲومٕژ۔﴾ سُہ چُھ بٲطلس مِٹا وان تہٕ حق چُھ پننیو فر ما نَو سٍتۍ حق بنٲوِتھ ہاوان۔"
  42,25,"۔سُہ چُھ سیٖنن منٛز چُھپِتھ راز زانان۔"
  42,26,"سُے چُھ یُس پننیو بندَو نِشہِ چُھ تو بہٕ قبول کران، تہٕ بُرٲیَو نِشہِ چُھ در گزر فر ماوان، حا لانکہ تس چُھ تۅہیہِ لُکن ہٕنز ن تمام کا میٚن ہُند علم ۔ سُہ چُھ ایمان انن والیٚن تہٕ نیک عمل کر ن والیٚن ہُند دُعا قبول کران، تہٕ پننہ، فضلہٕ سٍتۍ چُھ تِمن بیٚیہِ زیادٕہ دِوان ۔ روٗدۍ انکار کرن وٲلۍ ، تِمن خٲطرٕ چُھ سخت سزا"
  42,27,"۔اگر اللہ تعالیٰ پننیٚن سارِنٕے بند ن کُھلہٕ رزق دِیہِ ہے،تیٚلہِ کر ہن تِم زمینس منٛز سرکشی ہُند طوفان بر پا ، مگر اکہِ حسا بہٕ سان یوٗت سُہ یژھان چُھ تیوٗت چُھ نٲزِل کران، یقیناً چُھ سُہ پننیو بندَو نِشہِ با خبر تہٕ تِمن پٮ۪ٹھ چَھس نظر۔"
  42,28,"۔سُے چُھ یُس لُکن ہٕندِ مایوٗس سپد نہٕ پتہٕ روٗدچُھ ترٛا وان ، تہٕ پنٕنۍ رحمت چُھ پھٔہلاوان،تہٕ سُے چُھ قٲبِل تعر یف ولی ﴿ کار ساز﴾ ۔"
  42,29,"۔تٔمۍ سٕنز و نِشٲنِیو منٛزٕ چھےٚ یہِ زمین تہٕ آسمانن ہٕنز پیدٲیش، بیٚیہِ تِم جاندار مخلو قات یِم تٔمۍ دۅ شوٕ نۍ جا ین چِھ پھٔہلٲوِ تھ تھٲوِ مٕتۍ۔ سُہ ییٚلہِ ییژِھہ یِمن ہیٚکہِ سۅ مبرِ تھ ۔ ع"
  42,30,"۔تۅہیہِ لُکن پٮ۪ٹھ یُس تہِ مصیبت آمُت چُھ، سُہ چُھ تُہٕند یو پننیو اَتھو ہٕنزِ کمایہِ سٍتۍ آمُت،﴿ اِشارٕہ چُھ مکّہ معظمہٕ کِس تتھ قحطس کُن یُس تتھ زمانس منٛز بر پا اوس﴾ تہٕ وار یا ہَو قصوٗرَو نِشہِ چُھ سُہ تو تہِ در گُزر کران۔"
  42,31,"۔توٚہۍ چِھو نہٕ زمینس منٛز پننِس خدایس عٲجز کر ن وٲلۍ کینٛہہ،تہٕ اللہ تعالیٰ سٕندِس مقا بلس منٛز چُھو ونہٕ تۅہیہِ کانٛہہ حٲمی تہٕ مددگار۔"
  42,32,"۔تٔمۍ سٕنز و نِشٲنِیو منٛزٕ چِھ یِم جہا زٕ یِم سمندرس منٛز پہاڑن ہٕندۍ پٲٹھۍ اَتھہِ چِھ یِوان۔"
  42,33,"۔اللہ تعالیٰ ییٚمہِ ساعتہٕ ییژِھہ ہوا ہس ہیٚکہِ أکۍ سٕے جایہِ رُکٲوِتھ تھٲوِ تھ ، تہٕ یِم روزن سمندرکِس پُشتس ﴿سطحس ﴾ پٮ۪ٹھ سیٚدَے۔اتھ منٛز چھےٚ بجہِ نِشٲنیہِ پرتھ تس شخصس خٲطرٕ یُس کمال در جُک صبر تہٕ شُکر کر ن وول آسہِ۔"
  42,34,"۔یا ﴿تِمن پٮ۪ٹھ سوار سپدن والیٚن ہٕند یو ﴾ وار یاہَو گنا ہَو نِشہِ در گُزر کران کران ڈُبا وِ تِمن تِہند ٮ۪ن کینژھنٕے کر توٗتن ہٕندِس پا داشس منٛز،"
  42,35,"۔تہٕ تمہِ وقتہٕ لگہِ سا نیٚن آیا تن منٛز جھگڑٕ کر ن وا لیٚن پَے زِ ، تِہندِ خٲطرٕ چَھنہٕ کانٛہہ چَھپن جاے۔"
  42,36,"۔یِکینژھاہ تہِ تۅہیہِ لُکن دِنہٕ چُھ آمُت،سُہ چُھ محض دُنیا چہِ کینژھن دۅہن ہٕنزِ زند گی ہُند ساز و سا مان ، تہٕ یِکینژھاہ خُدا یس نِشہِ چُھ ، سُہ چُھ بہتر تہِ تہٕ پا یدار تہِ۔ سُہ چُھ تِمن لُکن خٲطرٕ یِمو ایمان چھُ اوٚ نمُت تہٕ پننِس ربّس پٮ۪ٹھ چِھ بھر وسہٕ کران،"
  42,37,"۔یِم بڑ یو بڑ یو گنا ہَو تہٕ بے حیٲیی ہٕنز و کا میو نِشہِ پر ہیز چِھ کران،تہٕ اگر شرارت کھسیٚکھ تیٚلہِ چِھ در گُز ر کران،"
  42,38,"۔یِم پننِس ربّ سُند حکم چِھ مانان ، نماز چِھ قٲیِم کران،پنٕنۍ معالات چِھ اکھ أکِس سٍتۍ مشورٕ ہ کٔرِ تھ چلا وان، اسہِ یِکینژھاہ رزق تہِ یِمن دِ یتمُت چُھ تمہِ منٛزٕ چِھ خر چ کران،"
  42,39,"۔تہٕ ییٚلہِ یِمن پٮ۪ٹھ زیادتی چھےٚ کر نہٕ یِوان تیٚلہِ چِھ تمِیُک مقا بلہٕ کران ۔ ﴿ وو نۍ چھےٚ ییٚتہِ پٮ۪ٹھہٕ آیت 43/کِس عبا رتس تام پٔتِمہِ آیتٕچ تشر یح ﴾"
  42,40,"۔بُرٲیی ہُند بد لہٕ چھےٚ تِژٕھے بُرٲیی،پتہٕ یُس معا ف کرِ بیٚیہِ کرِ اصلا ح تٔمۍ سُند اجر چُھ اللہ تعالیٰ سٕندِ ذمہٕ ، اللہ تعالیٰ چُھنہٕ ظٲلِمن پسند کران"
  42,41,"۔تہٕ یِم لُکھ ظُلم سپد نہٕ پتہٕ بد لہٕ ہیٚن ، تِمن ہیٚکہِ نہٕ ملا مت کر نہٕ یِتھ،"
  42,42,"۔ملا متٕکۍ حقدار چِھ تِم یِم دوٚ یمیٚن پٮ۪ٹھ ظُلم چِھ کران ،تہٕ زمینس منٛز چِھ نا حق زیا دتِیہِ کران۔ یِتھیٚن لُکن چُھ درد ناک عذاب۔"
  42,43,"۔البتہ یُس شخص صبرس کٲم ہیٚیہِ تہٕ در گُزر کرِ،تیٚلہِ چِھ یہِ سٮ۪ٹھاہ اُولوالعزمی ہٕنز و کا میٚو منٛزٕ﴿یعنی ہمت واجِنیو کا میو منٛزٕ ﴾۔ع"
  42,44,"۔یَس اللہ تعالیٰ ہٕے گُمرٲہی منٛز چھکہِ ، تس چُھنہٕ کانٛہہ سنبھا لن وول خُدایس پتہٕ۔توٚہۍ وُچھِو زِ یِم ظٲلِم ییٚلہِ عذا ب وُچُھن، پتہٕ وَنن کیا وۅ نۍ چھا واپس پھیرنٕچ کانٛہہ وَتھ؟"
  42,45,"۔تہٕ توٚہۍ وُچِھو زِ یِم ییٚلہِ جہنمس برونٛہہ کُن اَننہٕ یِن ، پتہٕ آسن ذلّت سٍتۍ نٔمۍ نٔمۍ گژھان،تہٕ تَتھ وُچھن ژوٗرِ ژوٗرِ ٹٔلۍ ٹا ر یوٚ۔تمہِ وقتہٕ وَنن تِم لُکھ یِمو ایمان اوس اوٚ نمُت زِپٔزِ پٲٹھۍ چِھ اصلی خسا رٕ ہ لد تِمے یِمو اَز قیا مت کہ دۅ ہ پنُن پان تہٕ پنٕنۍ تعلق دار خسارس منٛز ترٲوۍ۔ خبردار روٗزِ و ،ظٲلِم لُکھ آسن مُستقل عذا بس منٛز ، تہٕ یِمن آسہِ نہٕ کانٛہہ حٲمی تہٕ سر پرست،"
  42,46,"۔یِم اللہ تعالیٰ سٕندِس مُقا بلس منٛز یِہندِ س مددس یِن۔یس اللہ تعالیٰ گُمرٲہی منٛز تراوِ،تس خٲطرٕ چَھنہٕ بچا وٕچ کانٛہہ سبیل۔"
  42,47,"۔مٲنِو پننِس ربّ سٕنز کتھ امہِ برونٛہہ زِسُہ دۅہ واتہِ ییٚمہِ کہ ٹلنٕچ کانٛہہ صورت اللہ تعالیٰ سٕندِ طر فہٕ چَھنہٕ ۔تمہِ دۅہ آسہِ نہٕ تُہِندِ خٲطرٕ کانٛہہ چَھپن جاے،، تہٕ نہ آسہِ کانٛہہ تُہند حال بدلاونٕچ کوٗشش کر ن وول۔﴿ اصلی الفا ظ چِھ ،وَمَا لَکُم مِن نَکِیر، اَتھ چِھ بیٚیہِ تہِ کینٛہہ مفہو م ۔اکھ یہِ زِ توٚہۍ ہیٚکِو نہٕ پننیو کر توٗتَو منٛزٕ کُنہِ أکِس انکار کٔرِ تھ۔ دوٚیُم یہِ زِ توٚہۍ  ہیٚکِو نہٕ رخت بدلٲوِ تھ کُنہِ جایہِ کٔھٹِتھ روٗزِ تھ۔تریُیم یہِ زِ تۅہیہِ سٍتۍ یِکینژھاہ تہِ کر نہٕ یِیہِ تتھ پٮ۪ٹھ نہ ہیٚکِو توٚہۍ کانٛہہ احتجاج کٔرِ تھ تہٕ نہ ہیٛکِو نا را ضگی ہُند اظہار کٔرِ تھ۔ژوٗرِم یہِ زِ یتھ حالتس منٛز توٚہۍ مبتلا کر نہٕ ٲسِو آمٕتۍ، تۅہیہِ آسہِ نہٕ سۅ بد لا و نُک طا قت﴾"
  42,48,"۔وۅ نۍ اگر یِم لُکھ بُتھ چِھ پھِران، اے نبی صلی اللہ علیہ وسلم، اسہِ چِھو نہٕ توٚہۍ یِمن پٮ۪ٹھ رٲچھدر بنٲوِتھ سوٗزِ مٕتۍ۔تۅہیہِ پٮ۪ٹھ چھےٚ صرف کتھ وا تنا و نٕچ ذمہٕ دٲر ی۔ انسان سُند حال چُھ یہِ زِ ییٚلہِ أسۍ أمِس پننہِ رحمتُک مز ہ چِھ ہاوان تیٚلہِ چُھس اَتھ پٮ۪ٹھ بو ش کھسان، تہٕ اگر أمۍ سٕندٮ۪ن پننیٚن اَتھن ہُند کوٚر مُت کرٛ وومُت  کُنہِ مصیبت چہِ شکلہِ منٛز تس نٲلۍ چُھ گژھان،تیٚلہِ چُھ سخت نا شکُر ی کر ن وول بنان۔"
  42,49,"۔اللہ تعالیٰ چُھ زمینُک تہٕ آسما نن ہٕنزِ با دشٲہی ہُند مٲلِک،یِکینژھاہ یژھان چُھ تہِ چُھ پٲدٕ کران،یَس یژھان چُھ تس چُھ کورِ دِوان،یس یژھان چُھ تس چُھ لڑ کہٕ دِوان،"
  42,50,"۔تہٕ یس یژھان چُھ تس چُھ ہانٹھ بناوان۔سُہ چُھ سورُے کینٛہہ زانان بیٚیہِ چُھ پرٛتھ چیزس پٮ۪ٹھ قدرت تھا وان۔"
  42,51,"۔کٲنٛسہِ بشرٕ سٕنز چَھنہٕ یہِ مجا ل زِ اللہ تعالیٰ کرِ تس سٍتۍ رو برو کتھ۔تٔمۍ سٕنز کتھ چھےٚ یا تہٕ وَحی ﴿اشارہ﴾ کہ طور آسان، ﴿یتھ جایہِ چُھ وَحی نِشہِ مُراد القا ، اِلہا م، دِلس منٛز  کانٛہہ کتھ تراوٕ نۍ، یا خوا بس منٛز کینٛہہ ہا وُن یِتھہٕ پٲٹھۍ حضرا ت ابراہیم علیہ السلام تہٕ حضر ت یو سف علیہ السلامس ہا و نہٕ آو ﴾، نَتہٕ چھےٚ پردٕہ پٔتۍ کِنۍ آسان، ﴿مُراد چُھ یہِ زِ بندٕہ بوزِ اَکھ آواز، مگر بولن وول یِیَس نہٕ اَتھہِ، یِتھہٕ پٲٹھۍ حضر ت مو سیٰ علیہ السلامس سٍتۍ سپُد زِ طور کہِ دا منہٕ تَلہٕ لٔج اکہِ کُلہِ نِشہِ اچا نک آوا ز یِنہِ مگر بولن وول اوس تِہنز و نظر و نِشہِ ژھا یہِ ﴾ یا چُھ سُہ کانٛہہ پیغا م بر ﴿ فر شتہٕ ﴾ سوزان، تہٕ یِکینژھاہ سُہ یژھان چُھ تہِ چُھ تٔمۍ سٕنٛدِ حُکمہٕ سٍتۍ وَحی کران۔﴿ یہِ چھےٚ وَحی ینٕچ سۅ صورت ییٚمہِ کہ ذر یعہ تمام آسمٲنۍ کتا بہٕ انبیا علہیم السّلامن تام وا ژ مٕژ چھےٚ﴾ سُہ چُھ بلند تر تہٕ حکمت وول۔"
  42,52,"تہٕ یِتھے پٲٹھۍ چُھ اَسہِ ﴿ اے نبی صلی اللہ علیہ وسلم ﴾ پننہِ حُکمہٕ سٍتۍ اکھ رُو ح تۅہیہِ کُن وَحی کوٚر مُت۔ ﴿ "" یِتھے پٲٹھۍ "" نِشہِ چُھنہٕ مُراد محض ٲخر ی طر یقہٕ بلکہ چِھ تِم تر یشو ے طر یقہٕ یِم ہیرِ میٚن آیا تن منٛز وَننہٕ چِھ آمٕتۍ ، تہٕ ""رُو ح "" نِشہِ چُھ مُراد وَحی، یا سۅ تعلیم یۅسہٕ وَحی ہٕندِ ذر یعہ حضور صلی اللہ علیہ وسلمن دِنہٕ آیہِ ﴾ تۅہیہِ ٲسٕو نہٕ کِہنۍ پے زِ کتا ب کیا چھےٚ آسا ن تہٕ ایمان کیا چُھ آسان، مگر سُہ رُوح بنو و اَسہِ اکھ گا ش، ییٚمہِ سٍتۍ أسۍ وَتھ  چِھ ہاوان پننیو بندو منٛزٕ یَس یژھان چِھ تَس"
  42,53,"یقیناً چِھو  توٚہۍ سیٚزِ وَتہِ کُن یُس زمین و آسمان کہ پرٛتھ چیزُک مٲلِک چُھ۔خبردار روٗزِ و ، سٲری معالات چِھ خُداے سٕے کُن رجوع کران۔ ع"
