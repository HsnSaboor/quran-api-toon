quran[69]{c,v,t}:
  29,1,"۔ا۔ل۔م۔"
  29,2,"کیا لُکو چھا یہِ سمجھمُت زِ تِم یِن بس یُتُے وننس پٮ۪ٹھ یلہٕ تراونہٕ زِ  اسہِ اوٚ ن ایمان  تہٕ تِم کیا یِن نہٕ آز ماو نہٕ؟"
  29,3,"۔حالانکہ اسہِ چھےٚ تِمن سارِ نٕے لُکن آز ما یش کٔر مٕژ، یِم یِمن برونٛہہ چِھ گُزریمٕتۍ۔ خُدا یس چُھ یہِ ضروٗر وُچُھن زِ پٔزِ یٲرۍ کم چِھ، تہٕ اَ پزِ یٲرۍ کم چِھ ۔"
  29,4,"۔ تہٕ کیا تِمو لُکو یِم بُرٕ حر کتہٕ چِھ  کران، چھا یہِ  سمجھمُت زِ تِم نِن اسہِ نِشہِ بٲزۍ؟﴿اندازِ کلام نِشہِ چُھ ظٲہر زِ یِمو لُکو نِشہِ چِھ مُراد تِم ظا لم یِم ایمان اَنن والیٚن پٮ۪ٹھ ستم ٲسۍ کران، تہٕ اسلام کِس دعوتس ٲسۍ زکھ واتنا ونہٕ خٲطرٕ خرا ب کھۅتہٕ خرا ب حر کٔژ کرا ن﴾ سٮ۪ٹھاہ بوٚڈ غلط حکم چُھ، یُس تِم لگاوان چِھ۔"
  29,5,"۔یُس اکھا خُدایس سمکھنُک تو قع آسہِ تھا وان۔ ﴿تس گژِھہ پے آسٕنۍ زِ ﴾ اللہ تعالیٰ سُند مُقرر کر نہٕ آمُت وقت چُھ یِنہٕ وول، تہٕ اللہ تعالیٰ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  29,6,"۔یُس شخص تہِ مجا ہدٕہ کرِ سُہ کرِ پنٕنی رٕژرٕ خٲطرٕ۔﴿ مُجا ہدٕہ نِشہِ چُھ مُراد کُفّارن ہٕندِس مُقا بلس منٛز دینِ حقُک علَم بلند کر نہٕ تہٕ بُلند تھا و نہٕ  خٲطرٕ جدو جہد کرٕ نۍ﴾ اللہ تعالیٰ چُھ یقیناً دُنیا والیو نِشہِ بے نیا ز۔﴿ یعنی اللہ تعالیٰ چُھنہٕ امہِ مجا ہدُک مُطا لبہٕ تۅہیہِ امہِ موجو ب کرا ن  زِ تس چھےٚ معا ذ اللہ پنٕنۍ کانٛہہ ضرورت اتھ منٛز، بلکہ چُھو یہِ تۅہیہِ پننہِ اخلٲقی تہٕ رُوحٲنی تر قی ہُند ذریعہ﴾۔"
  29,7,"۔تہٕ یِم لُکھ ایمان اَنن تہٕ نیک عملہٕ کرن،تِہنزٕ بُرٲیِیہِ کرو أسۍ تِمن نِشہِ دوٗر،تہٕ تِمن دِ مو تِہنز ن بہتر ین عملن ہُند اجر۔"
  29,8,"۔اسہِ کوٚر انسانس ہدا یت زِ پننِس مٲلِس ماجہِ سٍتۍ کٔرِن نیک سلو ک۔البتہ اگر تِم ژےٚ پٮ۪ٹھ دبا و ترا ون زِ ژٕ ٹھہراوُن مےٚ سٍتۍ تِیُتھ کانٛہہ﴿ معبو د﴾ شر یک، یُس ژٕ﴿ میٲنِس شر یک سٕندِ حیثیتہٕ ﴾ چھہَن نہٕ زانان، تیٚلہِ مَہ کر تِہٕنز اطا عت ۔﴿ یِمو نوجو انو مکّس منٛز ایمان اوس اوٚ نمُت ، تِہندۍ وا لدین ٲسۍ تِمن پٮ۪ٹھ یہِ دبا و ترا وان زِ تِم یِیِن ایمان نِشہِ باز۔ اتھ پٮ۪ٹھ آو فر ماو نہٕ زِ مٲلِس ماجہِ ہٕندۍ حقو ق چِھ پننہِ جایہِ ، مگر تِمن چُھنہٕ یہِ حق زِ خُدا ے سٕنزِ وتہِ نِشہِ رُکا ون اولادن﴾ میے کُن چُھو تۅہیہِ سارِ نٕے پوٚت پھیٖرِ تھ یُن، پتہٕ وَنو بہٕ تۅہیہِ زِ توٚہۍ کیا چِھو کران روٗدمٕتۍ۔"
  29,9,"۔تہٕ یِمو لُکو ایمان آسہِ اوٚ نمُت تہٕ یِمو نیک عملہٕ آسن کرِ مژٕ، تِم کر وکھ أسۍ ضرور صا لح لُکن منٛز دٲخل۔"
  29,10,"۔لُکومنٛزٕ چُھ کانٛہہ تِیُتھ یُس ونان چُھ زِ اسہِ اوٚ ن ایمان خُدایس پٮ۪ٹھ۔مگر ییٚلہِ سُہ اللہ تعالیٰ سٕندِس معا ملس منٛز ستا و نہٕ آو،پتہٕ زٲنۍ تٔمۍ لُکن ہٕندِ طر فہٕ تراونہٕ آمٕژ آزمٲیش اللہ تعالیٰ سٕندِ عذا بٕکۍ پٲٹھۍ، وۅ نۍ اگر تُہندِس ربّ سٕندِ طر فہٕ فتح تہٕ نصر ت آیہِ،تیٚلہِ ونہِ یۅ ہے شخص زِ  أسۍ ٲسۍ تۅہی سٍتۍ۔ کیا دُنیا والیٚن ہٕندٮ۪ن دِلن ہُند حال چُھنا خُدایس وارٕ پٲٹھۍ پے،"
  29,11,"۔بیٚیہِ چُھ خُدایس ضرور یہِ وُچھنُے زِ ایمان انن وٲلۍ کم چِھ، تہٕ مُنا فق کم چِھ۔"
  29,12,"۔یِم کٲفر لُکھ چِھ ایمان انن والیٚن ونان زِ توٚہۍ کٔرِو سانہِ طر یقٕچ پیر وی، تہٕ تُہندۍ خطارَٹو أسۍ پا نس پٮ۪ٹھ ۔حالانکہ چِھنہٕ تِم تِہند یٚو خطا ہَو منٛزٕ کِہِنۍ تہِ پا نس پٮ۪ٹھ ہیٚنہٕ وٲلۍ، تِم چِھ ژَکہِ اَپُز ونان۔"
  29,13,"۔آ ، ضرور تُلن تِم پنٕنۍ بور تہِ تہٕ پننیٚن بو رن سٍتۍ تُلن با قی واریاہ بور تہِ۔ ﴿ یعنی اکھ بو ر پانہٕ گمراہ سپد نُک ، تہٕ با قی بوردوٚیمیٚن گُمراہ کرنٕکۍ یا گُمرٲہی پٮ۪ٹھ مجبور کر نٕکۍ ﴾ تہٕ قیا مت کہ دۅ سپدِ یقیناً تِمن تِمن اِفترا پر د ٲزِین ہٕنز پرٛژھہ  گٲر یِم تِم کران چِھ روٗد مٕتۍ۔ ع ﴿ یعنی تَتھ اَپزِس متعلق  یِیِکھ پرٛژھنہٕ یُس تِم پانہٕ بناوان ٲسۍ﴾"
  29,14,"۔اسہِ سوٗز نُو ح علیہ السلام تٔمۍ سٕندِس قو مس کُن، تہٕ سُہ روٗد پنژاہ کم أکِس ساسَس ؤرِیس تِمن در میان، ٲخر کار رٔٹۍ تِم طوفا نن اتھ حا لس منٛز زِ تِم ٲسۍ ظٲلِم۔"
  29,15,"۔پتہٕ بچو و اسہِ نُو ح علیہ السلام بیٚیہِ نا وِ وٲلۍ،تہٕ دُنیا والیٚن خٲطرٕ تھٲو سۅ اَکھ عبرتٕچ نشٲنی بنٲوِ تھ۔ ﴿ یعنی سۅ نا و یا قو م نوُحس پٮ۪ٹھ عذا بُک  وا قعہ بنو و نشا نِ عبرت﴾۔"
  29,16,"۔بیٚیہِ سوٗز ابرا ہیم علیہ السلام ییٚلہِ تٔمۍ پننِس قو مس ووٚن :  اللہ تعالیٰ سٕنز بند گی کٔرِو تہٕ تس کھوٚژِو۔یہِ چُھ تُہندِ خٲطرٕ بہتر اگر توٚہۍ زٲنِو۔"
  29,17,"۔ خُدا ترٲوِتھ یِم توٚہۍ پوٗزان چھوٗکھ تِم چِھ محض پۅ تٕلۍ، تہٕ توٚہۍ چِھو اکھ اَپُز بناوان در حقیقت یِہِنز پوٗزا توٚہۍ خدا یس ورٲے کران چِھو، تِمن چُھنہٕ تۅہیہِ رزق دِنُک تہِ اختیار ،خُدایس منگِو رزق، تہٕ تٔمۍ سٕنزٕے بند گی کٔرِ و تہٕ تٔمۍ سُند شُکر کٔرِو، تٔسۍ کُن یِیِو توٚہۍ وا پس پھِر نہٕ۔"
  29,18,"۔تہٕ اگر توٚہۍ انکار کران چھِو تیٚلہِ چھُ تۅہیہِ برونٹھمیٚو واریاہ ہو قو مَو اِنکار کوٚر مُت، تہٕ رسول ﴿ صلی اللہ علیہ وسلمس ﴾پٮ۪ٹھ چَھنہٕ  صا ف صا ف پیغا م وا تنا و نہٕ ورٲے بیٚیہِ کانٛہہ ذمہٕ دٲر ی۔"
  29,19,"۔کیا یِمو لُکو چُھنا وُچھمُتُے زانٛہہ زِ کِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ پیدٲیشہِ ہُنٛد ابتدا کران، پتہٕ چُھ تمُیک اِعادہ کران؟ یقیناً چُھ یہِ ﴿اِعادہ ﴾ اللہ تعالیٰ سٕندِ خٲطرٕ واریا ہ سہل۔"
  29,20,"۔یِمن ؤنِو زمینس اندر پھیٖرِ و تھوٗرِو،تہٕ وُچِھو زِ تٔمۍ کِتھہٕ پٲٹھۍ چُھ پیدٲیشہِ ہُنٛد ابتدا کوٚر مُت، پتہٕ بخشہِ اللہ تعالیٰ دوٚ یمہِ پھرِ تہِ زند گی، یقیناً چُھ اللہ تعالیٰ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  29,21,"۔یَس ییٚژِھہ تس دِیہِ سزا،تہٕ یس ییٚژِھ تس کرِ رحم ،تٔسۍ  کُن یِیِو توٚہۍ واپس پھِر نہٕ۔"
  29,22,"۔توٚہۍ نَہ چَھو زمینس منٛز عٲجز کر ن وٲلۍ نَہ آسما نس منٛز،تہٕ خُدا یس نِشہِ بچا ون وول کانٛہہ سر پر ست تہٕ مددگار چُھنہٕ تُہٕندِ خٲطرٕ ۔ ع۔"
  29,23,"۔یِمو لُکو اللہ تعالیٰ سٕندٮ۪ن آیا تن ہُند تہٕ تس سٍتۍ ملا قاتس چُھ انکار کوٚر مُت،تِم چِھ میا نہِ رحمت نِشہِ ما یوس سپٕدۍ مٕتۍ۔﴿یعنی تِہُند کانٛہہ حصّہ چُھنہٕ میانہِ رحمت منٛزٕ۔ تِمن خٲطرٕ چَھنہٕ امہِ  کتھہِ ہٕنز کانٛہہ گُنجٲیش زِ تِم ہیٚکن میا نہِ رحمت منٛز حصّہٕ حٲصل کر نٕچ اُمید تھٲوِ تھ۔ بیٚیہِ ییٚلہِ تِمو ٲخر ت سٕے انکار کوٚر ، تہٕ یہِ کوٚرُکھ نہٕ تسلیمٕے زِ تِمن چُھ زانٛہہ خُدا یس نِشہِ پیش سپدُن ، تیٚلہِ چُھ امِیُک معنی یہِ زِ تِمو چُھنہٕ خدا ے سٕندِس بخشنس تہٕ مغفرتس سٍتۍ اُمیدِ ہُند رشتہٕ گۅڈٕ  پٮ۪ٹھے وا بستہٕ کوٚر مُت﴾ تہٕ تِہندِ خٲطرٕ چُھ دگ تُلوُن سزا۔"
  29,24,"۔پتہٕ اوس نہٕ ابرا ہیم علیہ السلام سٕندِ قومُک جوا ب امہِ ورٲے کِہِنۍ،زِ تِمو ووٚن  قتل کٔرِ یوٗن یہِ ، نَتہٕ زٲلِیوٗن یہِ ۔  ٲخر کار بچو و سُہ خُدا ین نارٕ نِشہِ، یقیناً چھےٚ اَتھ منٛز نِشٲنیہِ تِمن لُکن خٲطرٕ یِم ایمان اَنن وٲلۍ چِھ۔"
  29,25,"۔تہٕ تٔمۍ ووٚن تۅہیہِ چھوٗکھ دنیا چہِ زند گی منٛز اللہ تعالیٰ ترٲوِ تھ پۅ تٕلۍ بنٲوِ مٕتۍ پا نس در میان محبتُک ذر یعہ۔﴿ یعنی تۅہیہِ چُھو خُدا پرستی بجا ے بُت پرستی ہٕندِس بُنیا دس پٮ۪ٹھ پننہِ اجتما عی زند گی ہُند  تعمیر کوٚر مُت یُس دُنیٲوی زند گی ہٕندِس حدس تام تُہُند قو می شیرازہ ہیٚکہِ گٔنڈِ تھ۔ تِکیازِ ییٚتہِ ہیٚکن کُنہِ تہِ عقیدس پٮ۪ٹھ لُکھ جمع  سپدِ تھ، خوا ہ سُہ حق ٲسِتن یا با طل۔تہٕ پرٛتھ کانٛہہ اتفا ق تہٕ سا نپُت، چا ہے سُہ ٲسِتن کِتھِس تہِ غلط عقیدس پٮ۪ٹھ ، ہیٚکہِ پانہٕ وٲنۍ ، دوستِیَن ، رشتہٕ دٲرِ یَن، برادٔرِین تہٕ با قی تما م مذ ہبی ، مُعاشر تی، تمد نی ، معٲشی تہٕ سیٲ سی تعلقاتن ہٕندِ قیا مُک ذر یعہ بٔنِتھ۔﴾ مگر  قیامت کہ دۅہ کٔرِو توٚہۍ اکھ أکِس انکار، بیٚیہِ کٔرِو اکھ أکِس پٮ۪ٹھ لعنت،تہٕ نار آسہِ تُہُند ٹھکا نہٕ تہٕ کانٛہہ آسہِ نہٕ تُہُند مددگار۔"
  29,26,"۔تمہِ وقتہٕ چُھ لوٗط علیہ السلام تَس مانان ﴿ایمان انان ﴾ سُہ چُھ زبردست تہٕ حکمت وول۔"
  29,27,"۔تہٕ اسہِ کوٚر تس اسحا ق علیہ السلام تہٕ یقو ب علیہ السلام ﴿ہیوٗ اولاد﴾ عطا ، تہٕ تٔمۍ سٕندِس نسلس منٛز تھٲو نبوّت تہٕ کتاب، تہٕ تس کوٚر دُنیا ہس منٛز تمِیُک اجر عطا، تہٕ ٲخر تس منٛز آسہِ سُہ یقیناً صا لحینو منٛزٕ۔"
  29,28,"۔ بیٚیہِ سوٗز اسہِ لوٗط علیہ السلام ییٚلہِ تٔمۍ پننِس قو مَس ووٚ ن : توٚہۍ چِھو سۅ فحش کٲم کران، یۅسہٕ تۅہیہِ برونٛہہ دنیا والیٚو کٲنٛسہِ چَھنہٕ کٔر مٕژ۔"
  29,29,"۔ کیا تُہُند حال چھا یہِ زِ مردن نِشہِ چِھو گژھان ، بیٚیہِ چِھو زہزنی کران، تہٕ پننیٚن مجلسن منٛز چِھو بُرٕ کامہِ کران ؟ پتہٕ اوس نہٕ کانٛہہ جواب تٔمۍ سٕندِ قو مہٕ طر فہٕ ،  امہِ ورٲے زِ تِمو ووٚن  اَن ، اللہ تعالیٰ سُند عذا ب، اگر ژٕ پٔزِ یور چُھکھ۔"
  29,30,"۔لوٗط علیہ السلام چُھ ونان  اے میا نہِ ربّ، یِمن مفسد ن ہٕندِس مقا بلس منٛز کر مےٚ مدد۔ ع"
  29,31,"۔تہٕ ییٚلہِ سٲنۍ فر شتہٕ ابراہیم علیہ السلامس نِشہِ بشا رت ہیٚتھ وٲتۍ، تِمو ووٚ ن تس أسۍ چِھ ییٚمہِ بستی ہٕندۍ لُکھ ہلاک کر ن وٲلۍ، ﴿ ییٚمہِ بستی  ہُند اشارٕہ اوس قومِ لوٗط  کِس علا قس کُن۔حضر ت ابراہیم علیہ السلام ٲسۍ تمہِ وقتہٕ فلسطین کِس جَبرو نس ﴿ موجو دہ الخیل﴾ منٛز روزان۔ امہِ شہر کِس جنو ب مشر قس منٛز چُھ کینٛہہ میل دوٗر بحیرۂ مردارُک سُہ حصہٕ ، ییٚتہِ گۅڈٕ قو م لوٗط علیہ السلام بسا ن اوس ، تہٕ وۅ نۍ یتھ پٮ۪ٹھ بحیرُک آب چُھ پھٔہلِتھ۔ یہِ علا قہٕ چُھ وَسوٕ نِس کُن ، تہٕ جَبرون چَو تھز و پہا ڑِ یو پٮ۪ٹھہٕ چُھ صا ف اَتھِہ یِوان۔ اَمی موجو ب چِھ فر شتہٕ  اتھ کُن اشارہ کٔرِ تھ حضر ت ابراہیم علیہ السلامس عر ض کرا ن زِ  أسۍ چِھ یہِ بستی ہلاک کر ن وٲلۍ﴾۔اَمِکۍ لُکھ چِھ واریاہ ظٲلِم بنیمٕتۍ۔"
  29,32,"۔ ابراہیم علیہ السلام چُھ ونان  تَتہِ ہے لوٗط علیہ السلام چُھ۔ تِمو ووٚ ن  أسۍ چِھ وارٕ پٲٹھۍ زانان زِ تَتہِ کُس کُس چُھ۔ أسۍ بچا وو ن سُہ تہٕ تٔمۍ سٕندۍ سٲری گرِ کۍ بٲژ، تٔمۍ سٕنزِ خا ندارِ نہِ ورٲے۔ تٔمۍ سٕنز خاندارِ نۍ ٲس پتھ روزن والیٚو منٛزٕ۔"
  29,33,"۔پتہٕ ییٚلہِ سٲنۍ فر شتہٕ لوٗط ﴿علیہ السلامس﴾ نِشہِ وٲتۍ ، تِہندِس یِنَس پٮ۪ٹھ سپُد سُہ سخت پریشان تہٕ دل گو س تنگ تِمو ووٚن  نہ مَہ کھۅژ،نَہ مَہ ہےٚ غم، أسۍ بچاووتھ ژٕ تہٕ بیٚیہِ چٲنۍ گرِکۍ بٲژ، سوِ اے چٲنۍ خا ندارِ نۍ ، یۅسہٕ پتھ روزن والیو منٛزٕ چھےٚ ۔"
  29,34,"۔أسۍ چِھ ییٚمہِ بستی ہٕندٮ۪ن لُکن پٮ۪ٹھ آسما نہٕ پیٚٹھہٕ عذا ب نٲزِل کر ن وٲلۍ، تمہِ فسق ﴿ بد کٲری﴾ ہٕندِ بد و لت یُس یِم کران چِھ روٗدِمٕتۍ۔"
  29,35,"۔تہٕ اَسہِ چھےٚ تمہِ بستی ہٕنز اکھ ٹا کارٕ ہ نشٲنی ترٲومٕژ۔﴿امہِ ٹا کارٕ ہ نشٲنی نِشہِ چُھ مُراد بحیر ہ مردار، یَتھ بحرِ لوٗط تہِ ونان چِھ ۔ قرآن مجیدس منٛز چُھ واریاہن جا ین مکہ کیٚن کٲفر ن خطاب کٔرِ تھ فر ماو نہٕ آمُت زِ یُس عذا ب اَتھ ظا لم قو مس پٮ۪ٹھ امہِ کیو کر تُو تَو کِنۍ آمُت اوس، تمِچ اکھ نِشا نی چھےٚ از تہِ عا م شاہر اہ ہس پٮ۪ٹھ موجود، یۅسہٕ توٚہۍ پننیٚن تجا رتی سفر ن منٛز شا مَس کُن گژھنہٕ وِزِ رات دۅہ وُچھان چِھو۔﴾تِمن لُکن خٲطرٕ یِم عقلہِ چِھ کٲم ہیٚوان۔"
  29,36,"۔تہٕ مد یَنَس کُن سوٗز اسہِ تِہُند بو ے شعیُب علیہ السلام تٔمۍ ووٚن  اے میانہِ قو م کیو لُکو ، اللہ تعالیٰ سٕنز بند گی کٔرِو، تہٕ ٲخرت کہ دۅ ہٕکۍ روٗزِ و اُمید وار، بیٚیہِ مَہ پھیٖرِ و زمینس منٛز مُفسدبٔنِتھ زیا د تی کران۔"
  29,37,"۔مگر تِمو پھیِرُتَس بُتھ۔ ٲخر کار رٔٹۍ تِم أکۍ سخت بِنِلۍ، تہٕ تِم روٗدۍ پننیٚن گھر ن منٛزٕ ے پیٚتھ۔"
  29,38,"۔بیٚیہِ کٔرۍ اَسہِ عا د تہٕ ثمو د ہلا ک، تۅہیہِ چھَوٕہ تِمہٕ جایہِ وُچھمژٕ، ییٚتہِ تِم روزان ٲسۍ ،تِہندۍ اعمال بنٲوۍ شیطا نن تِہندِ خٲطرٕ خۅشنما، تہٕ تِم ڈٲلِن سیٚزِ وَتہِ نِشہِ ، حالانکہ تِم ٲسۍ ہو ش گوش تھا وان۔"
  29,39,"۔تہٕ قا رو ن تہٕ فر عو ن تہٕ ہا مان کوٚر اسہِ ہلا ک۔ مو سیٰ علیہ السلام آو تِمن نِشہِ بیّنات ہیٚتھ، مگر تِمو کوٚر زمینس منٛز پننہِ بجرُک تکبر، حالانکہ ٲسۍ نہٕ تِم سبقت نِنہٕ وٲلۍ۔"
  29,40,"۔ٲخر کار روٚٹ اَسہِ پرٛتھ کانٛہہ تٔمۍ سٕندِس گنا ہس پٮ۪ٹھ۔ پتہٕ سوٗز اسہِ تِمو منٛزٕ کٲنٛسہِ پٮ۪ٹھ پتھر او کر ن وول ہوا، تہٕ کانٛہہ روٚٹ أکۍ زبردست دھما کن، تہٕ کانٛہہ وول آسہِ زمینس تل، تہٕ کانٛہہ کوٚر غر ق، اللہ تعالیٰ اوس نہٕ تِمن پٮ۪ٹھ ظُلم کر ن وول، مگر تِم ٲسۍ پا نے پا نس پٮ۪ٹھ ظُلم کران۔"
  29,41,"۔یِمو لُکو خُدا ے ترٲوِ تھ با قی چِھ پنٕنۍ سرپرست بنٲوِ مٕتۍ، تِہٕنز مِثا ل چھےٚ زلٕر ۍ سٕنز ہِش، یُس پنُن اکھ گھرٕ چُھ بناوان، تہٕ سارِ وٕے گھرو کھۅتہٕ زیادہ کمز ور گھرٕ چُھ زلٕرۍ سُندُے گھرٕ آسان۔کا ش یِمن لُکن آسہِ ہے علم۔"
  29,42,"۔خُدایس ترٲوِ تھ یتھ چیز س تہِ یِم لُکھ ناد چِھ لایان، اللہ تعالیٰ چُھ وارٕ پٲٹھۍ زانان، تہٕ سُے چُھ زبردست تہٕ حکمت وول۔"
  29,43,"۔ یِمہٕ مثا لہٕ چِھ أسۍ لُکن ہٕنزِ فہمٲیشہِ خٲطرٕ دِوان ، مگریِم مثا لہٕ چِھ تِمے لُکھ سمجھان یِم علم تھا ون وٲلۍ چِھ۔"
  29,44,"۔ خُدا ین چِھ آسمان تہٕ زمین بر حق پٲدٕ کٔرِ مٕتۍ، در حقیقت چھےٚ اتھ اکھ نشٲنی اہلِ ایمانن خٲطرٕ ۔ ع"
  29,45,"۔﴿ اے نبی صلی اللہ علیہ وسلم ﴾ تلا وت کٔرِو تمہِ کتا بہِ ہٕنز ، یۅسہٕ تۅہیہِ کُن وَحی ہٕندِ ذر یعہ چھےٚ سوز نہٕ آمٕژ، بیٚیہِ کٔرِ و نما ز قٲیم،پٔزِ پٲٹھۍ چھےٚ نماز فحش تہٕ بُرٕ کا میو نِشہِ رُکا وان، تہٕ اللہ تعالیٰ سٕنز ذکر چھےٚ امہِ کھۅتہٕ تہِ بوٚڈ چیز۔﴿ مطلب چُھ یہِ زِ فحش کا میو نِشہِ رُکاوُن چُھ اکھ لۅکٹ چیز ، اللہ تعالیٰ سٕںزذکر یعنی نمازِہٕندۍ برکات چھِ اَمہِ کھۅتہٕ تہِ کٔھسِتھ۔﴾اللہ تعالیٰ چھُ زانان، یِکینژھاہ توٚہۍ کرا ن چِھو۔"
  29,46,"۔تہٕ اہلِ کتا بن سٍتۍ مَہ کٔرِ و بحث مگر کٔرِ و جان طر یقہٕ۔تِمو لُکو ورٲے یِم تِمومنزٕ ظٲلم آسن۔ ﴿ یعنی یِم لُکھ ظُلمُک رٔوِ یہِ ورتا ون ، تِمن سٍتۍ ہیٚکہِ تِہندِ ظُلم کہ نو عیت کہ لحا ظہٕ مُختلف رٔوِّ یہِ تہِ وَرتا و نہٕ یِتھ۔ مطلب چُھ یہِ زِ پرٛتھ وقتہٕ تہٕ پرٛتھ حالس منٛز پرتھ قسم کیٚن لُکن ہٕندِ س مقا بلس منٛز گژِھہ نہٕ نر م تہٕ میوٗٹُھے یو ت بٔنِتھ روزُن زِ دُنیا سمجھہِ حق کِس دٲعی سٕندِس شرا فتس کمز ور ی تہٕ لا چٲری، اسلام چُھ پننیٚن پیرو کار ن شٲیستگی، شرافت تہٕ معقو لیت ضروٗر ہیٚچھنا وان مگر عٲجز ی تہٕ مسکینی چُھکھ نہٕ ہیٚچھنا وان زِ تِم روزن پرٛتھ ظا لم سٕندِ خٲطرٕ نر م میوٚنڈا بٔنِتھ۔﴾ تہٕ تِمن ؤنِو  زِ اسہِ چُھ ایمان اوٚ نمُت تتھ چیز س پٮ۪ٹھ تہِ ، یُس اسہِ کُن چُھ سوزنہٕ آمُت تہٕ تتھ چیز س پٮ۪ٹھ تہِ یُس تۅہیہِ کُن اوس سوز نہٕ آمُت، سو ن خُداتہٕ تُہُند خُدا چُھ اَکو ے، تہٕ أسۍ چِھ تٔمۍ سٕندی مُسلم ﴿ فر ماں بردار﴾۔"
  29,47,"۔ ﴿اے نبی صلی اللہ علیہ وسلم ﴾ اَسہِ چھےٚ یِتھے پٲٹھۍ تۅہیہِ کُن کتا ب نٲزِل کٔرمٕژ۔ ﴿ اتھ ہیٚکن زٕ مطلب ٲسِتھ۔ اکھ یہِ زِ یِتھہٕ پٲٹھۍ گۅڈنِکیٚن پیغمبر ن پٮ۪ٹھ اسہِ کتا بہِ آسہٕ نٲزِل کرِ مژٕ، تِتھے پٲٹھۍ چھےٚ وۅ نۍ یہِ کتا ب تۅہیہِ پٮ۪ٹھ نٲزِل کٔرمٕژ۔ دوٚ یِم یہِ زِ اسہِ چھےٚ اَمی تعلیمہِ سان یہِ کتاب نٲزِل کٔرمٕژ زِ سا نیٚن پٔتِمیٚن کتا بن ہُند انکار کٔرِ تھ نہٕ کینٛہہ، بلکہ گژِھہ تِمن سارِ نٕے ہُند اقرار کران کران یہِ ماننہٕ یِنۍ﴾ امہِ موجو ب چِھ تِم لُکھ یِمن گۅڈٕہ ٲس اسہِ کتا ب دِژٕ مٕژ، یتھ پٮ۪ٹھ ایمان انان ، ﴿ سیا ق و سبا ق چُھ پانے ونان زِ امہِ نِشہِ چِھنہٕ مُراد تمام اہلِ کتا ب بلکہ چِھ تِم اہلِ کتا ب یِمن آسمٲنۍ کتا بن ہُند صحیح علم تہٕ فہم نصیب اوس سپُد مُت، یِم حقیقی معنی یس منٛز اہلِ کتا ب ٲسۍ۔ ﴾ تہٕ یِمو لُکو منٛزٕ تہِ چِھ واریاہ یتھ پٮ۪ٹھ ایمان انان ۔ ﴿ یہِ اشارہ چُھ اہلِ عر بن کُن ۔ مطلب چُھ یہِ زِ حق پسند لُکھ چِھ پرٛتھ جایہِ یَتھ پٮ۪ٹھ ایمان انان، خوا ہ تِم اہلِ کتا بو منٛزٕ ٲسِتن یا غیر اہلِ کتا بو منٛزٕ ۔ ﴾ تہٕ سا نیٚن آیا تن ہُند انکار چِھ صرف کا فرٕے یوت کران۔"
  29,48,"۔ ﴿اے نبی صلی اللہ علیہ وسلم ﴾ توٚہۍ ٲسِو نہٕ ییٚمہِ برونٛہہ کانٛہہ کتاب پرا ن، تہٕ نَہ ٲسِو پننہِ اتھہٕ سٍتۍ لیٚکھان، اگر یہِ آسِہے ، تیٚلہِ ہیٚکہَن با طل پرست لُکھ شکس منٛز پیٚتھ۔"
  29,49,"۔در اصل چھےٚ یِمہٕ ٹا کارٕ نشٲنیہِ تِمن لُکن ہٕندٮ۪ن دِلن منٛز، یِمن علم چُھ بخشنہٕ آمُت، ﴿ یعنی أکِس اُمّی سُند قرآن ہِش کتا ب پیش کرٕ نۍ تہٕ اچا نک تِمن زبردست کمالاتن ہُند اظہا ر کرُن یِہندِ خٲطرٕ کُنہِ سٲبقہٕ تیٲری ہٕندۍ آثا ر، زانٛہہ تہِ کٲنٛسہِ ہٕندِس مُشٲہدس منٛز چِھنہٕ آمٕتۍ، یِمے چھےٚ عقل تہٕ فہم تھا ون والیٚن ہٕنز ن نظر ن منٛز تِہنزِ پیغمبر ی پٮ۪ٹھ دلا لت کر ن واجِنہِ روشن تر ین نِشٲنِیہِ ۔ ﴾ تہٕ سانیٚن آیا تن ہُند انکار چِھنہٕ کران مگر تِم یِم ظالم چِھ۔"
  29,50,"۔یِم لُکھ چِھ ونان زِ  کیا زِ آیہِ نہٕ نٲزِل کر نہٕ أمِس شخصس پٮ۪ٹھ نِشٲنِیہِ أمۍ سٕندِس ربّ سٕندِ طر فہٕ؟ ؤنِو  نِشٲنِیہِ چھےٚ خُدا یس نِشہِ ، تہٕ بہٕ چُھس صرف صا ف صا ف خبردار کر ن وول۔"
  29,51,"۔تہٕ کیا یِمن لُکن خٲطرٕ چَھنا یہِ ﴿ نِشٲنی ﴾ کٲفی زِ اسہِ کٔر تۅہیہِ پٮ۪ٹھ کتا ب نٲزِل ، یۅسہٕ یِمن پٔرِتھ چھےٚ بوز ناو نہٕ یِوان ؟ در حقیقت چھےٚ اتھ منٛز رحمت تہٕ نصیحت تِمن لُکن خٲطرٕ یِم ایمان چِھ اَنان ۔ ع۔"
  29,52,"۔﴿ اے نبی سلی اللہ علیہ وسلم ﴾ ؤنِو زِ مےٚ تہٕ تۅہیہِ در میان چُھ اللہ تعالیٰ گوٲہی خٲطرٕ کٲفی۔ سُہ چُھ آسمانن تہٕ زمینس منٛز سورُے کینٛہہ زانان۔ یِم لُکھ بٲطلس چِھ مانان تہٕ خُدایس سٍتۍ چِھ کُفر کرا ن، تِمے چِھ خسا رس منٛز روزن وٲلۍ۔"
  29,53,"۔ یِم لُکھ چِھو تۅہیہِ جلد ی عذا ب اَننُک مطا لبہ کران۔ اگر اکھ وقت مُقرر آسِہے نہٕ کر نہٕ آمُت، تیٚلہِ آسِہے یِمن پٮ۪ٹھ عذا ب آمُت ۔تہٕ یقیناً یِیہِ سُہ ﴿ پننِس وقتس پٮ۪ٹھ ﴾ اچا نک ، اَتھ حالس منٛز زِ یِمن روزنہٕ خبرٕ ے ۔"
  29,54,"۔یِم چِھو تۅہیہِ جلد ی عذا ب اَننُک مُطا لبہ کران، حالانکہ جہنمن چِھ یِم کٲفر گھیرس منٛز رٔٹِمٕتۍ﴿ تہٕ یِمن لگہِ پے﴾"
  29,55,"۔تمہِ دۅہ ،ییٚلہِ یِمن عذا ب پیٚٹھۍ کِنۍ تہِ وُرُن کرِ، تہٕ کھۅرَو بٔنۍ کِنۍ تہِ ،  تہٕ ونیٚکھ زِ وُچِھو وۅ نۍ مزٕ ہ تِمن کر توٗتن ہُند ،یِم توٚہۍ کران ٲسِو۔"
  29,56,"۔اے میا نیٚو بندو ! یِمو ایمان چُھو اوٚ نمُت،میٲنۍ زمین چھےٚ وسیع، لہٰذا کٔرِو توٚہۍ میٲنی بند گی ۔﴿ یہِ اشارہ چُھ ہجرتس کُن۔ مطلب چُھ یہِ زِ اگر مکّس منٛز خُداے سٕنز بند گی کرٕنۍ مشکل چِھو گژھان ، تیٚلہِ نیرِ و ملک ترٲوِ تھ ، خُدا ے سٕنز زمین چَھنہٕ تنگ۔ یتھ جا یہِ توٚہۍ خُداے سٕندۍ بند ہ بٔنِتھ روٗزِ تھ ہیٚکِو ،تو ر گٔژِھو۔﴾"
  29,57,"۔پرٛتھ زُو دارس چُھ مو تُک مزٕ ہ وُچُھن، پتہٕ  یِیِو توٚہۍ سٲری اَسی کُن واپس پھِر نہٕ ۔"
  29,58,"۔یِمو لُکو ایمان چُھ اوٚ نمُت تہٕ نیک عملہٕ چھےٚ کرِ مژٕ، تِم تھا ووکھ أسۍ جنّت چن بُلند و بالا عما رتن منٛز، یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکا ن ، تَتہِ روزن تِم ہمیشہ،کوتاہ جان اجر چُھ عمل کر ن والیٚن خٲطر۔"
  29,59,"۔تِمن لُکن خٲطرٕ یِمو صبر چُھ کوٚر مُت تہٕ یِم پننِس ربّس پٮ۪ٹھ بھروسہٕ چِھ کران۔"
  29,60,"۔ کٲتیاہ جا نور چِھ یِم پنُن رِز ق ہیٚتھ چِھنہٕ پھیران تھوران، اللہ تعالیٰ چُھ تِمن رزِق دِوان ، تہٕ تُہُند رِزق دِنہٕ وول تہِ چُھ سُے۔ سُہ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  29,61,"۔اگر توٚہۍ یِمن پٕرٛژِھو زِ زمین تہٕ آسما ن کٔمۍ چِھ پٲدٕ کٔرِ مٕتۍ، ﴿ ییٚتہِ پٮ۪ٹھہٕ چُھ بیٚیہِ کلا مُک رۅخ کُفّارِ مکن کُن گژھان﴾ تہٕ زوٗن تہٕ آفتا ب کٔمۍ چُھ مُسّخر کٔرِ تھ تھو و مُت، تیٚلہِ وَنن ضروٗر زِ خُدا ین ، تیٚلہِ کپٲرۍ چِھ یِم دوکھہٕ کھیٚوان؟"
  29,62,"۔ اللہ تعالیٰ ہٕے چُھ یُس پننیٚو بندو منٛزٕ ییٚمۍ سُند رزِق یژھان چُھ تٔمۍ سُند چُھ کُشادہ کران، تہٕ ییٚمِس یژھان چُھ تس چُھ تنگ کران، یقیناً چُھ اللہ تعالیٰ پرٛتھ چیزُک زانن وول۔"
  29,63,"۔بیٚیہِ اگر توٚہۍ یِمن پٕرٛژِھو کٔمۍ تروو آسما نہٕ آب، تہٕ اَمہِ ذر یعہ کٔرٕ ن مۅر دٕہ پیمٕژ زمین زِ ندہ، تیٚلہِ ونن تِم ضرور خُداین۔ؤنِو، الحمدُ للّہ ، ﴿یتھ جایہِ چُھ الحمدُ لِلّہ زٕہ معنے دِوان ۔ اکھ یہِ زِ ییٚلہِ یمہٕ سار ے کامہِ خُدا ے سٕنزٕ چھےٚ، تیٚلہِ چُھ حمدُک حقدار تہِ صرف سُے، دوٚ یِمیٚن کپٲرۍ ووت حمدُک اِستحقا ق ﴿حق﴾ ؟ دوٚ یُم یہِ زِ خُدا ے سُند شُکر چُھ، امہِ کتھہِ ہُند اعترا ف چِھو توٚہۍ پانہٕ تہِ کران۔﴾ مگر یِمو منٛزٕ چِھنہٕ اکثر لُکھ سمجھان ۔ ع"
  29,64,"۔ تہٕ یہِ دُنیا ہٕچ زند گی چَھنہٕ کِہِنۍ مگر اکھ کھیل تہٕ دِل رَنٛز ناوُن۔ اصلی زند گی ہُند گھرٕ چُھ ٲخرتُک گھرٕ ،کا ش زانہن یِم لُکھ ۔"
  29,65,"۔ییٚلہِ یِم لُکھ ناوِ منٛز چِھ سوار سپدان،تیٚلہِ چِھ پنُن دین اللہ تعالیٰ سٕندِ خٲطرٕ خٲلص کٔرِتھ تس دُعا منگا ن، پتہٕ ییٚلہِ سُہ یِمن بچٲوِ تھ ہۅ چھرس پٮ۪ٹھ چُھ انان، پتہٕ چِھ اچا نک یِم شر ک کر نہِ لگا ن،"
  29,66,"۔تاکہ اللہ تعالیٰ سٕندِس دِ تۍمٕتِس نجا تس پٮ۪ٹھ کر ن تٔمۍ سٕندِس نعمتس انکار ، تہٕ ﴿ دنیا چہ زند گی ﴾ تُلن مزٕ ہ۔ اچھا عنقر یب لگہِ یِمن پے۔"
  29,67,"۔کیا یِم چِھنان وُچھا ن زِ اسہِ چُھ اکھ پُر امن حر م بنو و مُت، حالانکہ یِمن أندۍ پٔکۍ ٲسۍ لُکھ تُلنہٕ یِوان ؟ ﴿ یعنی کیا یِہُنٛد شہرِ مکہ ، ییٚمہِ کِس دا منس منٛز یِمن کما ل در جُک امَن چُھ حٲصل ، چھا کٲنٛسہِ لا تن یا ہُبلن حر م بنو و مُت؟ کیا کٲنٛسہِ دِیو ی یا دیو تا سُند اوسا یہِ طا قت زِ ڈا یَو سا سَو ؤرِ یَو پٮ۪ٹھہٕ ہیٚکہِ ہے عر ب کِس انتہٲیی بدا منی ہٕندِس ما حو لس منٛز یہِ جا ے تمام فِتنو تہٕ فسادَو نِشہِ محفو ظ تھٲوِ تھ؟ اگر نہٕ اَمِچ حُر مَت برقرار تھاون وٲلۍ أسۍٲسۍ تیٚلہِ کُس اوس؟ ﴾ کیاا مہِ پتہٕ  تہِ چھا یِم لُکھ بٲطِلس مانان، تہٕ اللہ تعالیٰ سٕندِس نعمتس چِھ انکار کران ؟"
  29,68,"۔تس شخصس کھۅتہٕ کھٔسِتھ ظٲلِم کُس آسہِ یُس خُدا یس اَپُز تھا وِ لٲگِتھ، یا کرِ حقس اِنکار، ییٚلہِ زن سُہ أمِس برونٛہہ کُن ووتمُت آسہِ ؟، کیا یِتھیٚن کٲفر ن ہُند ٹھکا نہٕ چُھنا صرف جہنم؟"
  29,69,"۔یِم لُکھ سانہِ خٲطرٕ مُجا ہدٕہ کر ن، تِمن ہا وَو أسۍ پننہِ وَتہٕ، ﴿ مطلب چُھ یہِ زِ یِم لُکھ اللہ تعالیٰ سٕنزِ وَتہِ منٛز اخلاص سان پوٗرٕ دُنیا ہس سٍتۍ کش مکشُک خطرہ موٚ لۍ چِھ ہیٚوان، تِمن چُھنہٕ اللہ تعالیٰ تِہندِس حا لس پٮ۪ٹھ تراوان، بلکہ چُھ سُہ تِمن دستگیر ی تہٕ رہنمٲیی کران ، تہٕ پا نس کُن یِنہٕ چہ وتہٕ چُھ تِہندِخٲطرٕ یلہٕ تراوان۔سُہ چُھ قد مس قد مس پٮ۪ٹھ تِمن ونان زِ سٲنۍ خوشنود ی کِتھہٕ پٲٹھۍ ہیٚکِو توٚہۍ حٲصل کٔرِ تھ ۔ پرٛتھ أکِس مو ڑس پٮ۪ٹھ چُھ تِمن گا ش ہاوان زِ سیٚز وَتھ کپٲرۍ چھےٚ ، تہٕ غلط وَتہٕ کمہٕ چھےٚ۔ ییٖژاہ نیک نیتی تہٕ رٕژرٕچ طلب تِمن منٛز آسان چھےٚ ، تیوٗتاہ چُھ اللہ تعالیٰ سُنٛد مدد تہٕ تو فیق  تہٕ ہدا یت تہِ تِمن سٍتۍ روزان۔﴾ تہٕ یقیناً چُھ اللہ تعالیٰ نکیو کار نٕے سٍتۍ ۔ ع"
