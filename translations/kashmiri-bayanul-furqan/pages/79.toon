quran[46]{c,v,t}:
  79,1,"قسم چُھ تِمن ﴿فرشتن ﴾ ہُنٛد یِم ڈُبِتھ لَمان چھِ،"
  79,2,"تہٕ وارٕ وارٕ چھِ کٔڑِتھ نِوان ﴿ اَمہِ نِشہِ چُھ مُراد تِم فرشتہٕ یِم موتہٕ وقتہٕ انسان سُنٛد زُو أمۍ سٕنٛدین جسم کیٚن سَنہِ رن تام ؤسِتھ تہٕ أمۍ سٕنٛز ورَ گو منٛزٕ لٔمِتھ کڑان چھِ﴾"
  79,3,"تہٕ ﴿تِمن فر شتن ہُنٛد یِم کا ینا تس منٛز ﴾ تیز ی سان ژھا نٹہِ پھیران چھِ ﴿ اَمہِ نِشہِ چُھ مُراد تِم فرشتہٕ یِم احکامِ الہٰی کِس تعمیلس منٛز تِتھہٕ پٲٹھۍ رَواں دَواں چھِ روزان زنتہٕ تِم فضا ہس منٛز ژھا نٹ چھِ وایان آسان﴾،"
  79,4,"پتہٕ چھِ ﴿حکم بجا اَننس منٛز ٹٕکھ نِوان تہٕ برونٛہہ نیر نٕچ کوشش کران﴾،"
  79,5,"پتہٕ چھِ ﴿احکامِ الہٰی مطٲبق﴾ معاملاتن ہُنٛد انتظام پکہٕ ناوان﴿یِم چھِ کاینات کہ سلطنتٕکۍ تِم  کارکُن یِہٕنٛدٮ۪ن اتھن منٛز دُنیا ہُک سورُے انتظام اللہ تعالیٰ سٕنٛدِ حکمہٕ مطٲبق چلان چُھ﴾،"
  79,6,"ییٚمہِ دۅہ ہیٚٹھ مارِ بُنِلۍ ہیٚٹھ"
  79,7,"تہٕ أتھۍ پتے لگہِ بیا کھ ہیٚٹھ،"
  79,8,"کینٛہہ دل آسن تِم ، یِم تَمہِ دۅہ خو فہٕ سٍتۍ نٹا ن آسن"
  79,9,"تِہٕنٛزٕ نظرٕ آسن لرز یمژٕ"
  79,10,"یِم لُکھ چھِ ونان"" کیا پٔزۍ پٲٹھۍ یِمو اہ أسۍ پوٚت پھٖرِتھ واپس اَننہٕ؟"
  79,11,"کیا ییٚلہِ ہا أسۍ دۅدریمژٕ کھۅ کھرِ أڈجہِ بنیمٕتۍ آسَو؟"
  79,12,"وَننہِ لٔگۍ "" یہِ پوٚت پھیرُن آسہِ تیٚلہِ سٮ۪ٹھاہ خسارٕ ہ دِنہٕ وول۔""﴿یعنی ییٚلہِ تِمن جواب دِنہٕ آو زِ ،آ ، یی سپدِ ، پتہٕ لٔگۍ تِمۍ مذاقہٕ رٔنگۍ پانہٕ وٲنۍ اَکھ أکِس وَننہِ زِ ہے یارو ، ہرگاہ اَسہِ پٔزۍ پٲٹھۍ پوٚت پھیٖرِتھ نوِ سرٕ زند گی ہٕنٛدِس حا لتس منٛز پیوٚ و یُن تیٚلہِ کیا سہ موٗدۍ أسۍ ، اَسہِ پیوٚ و تیٚلہِ تاوَن﴾"
  79,13,"حالانکہ یہِ چُھ بس یُتُے کامہِ پیوٗنٛت زِ زورٕ سان سپدِ اکھ گٍرٚ نٛز"
  79,14,"تہٕ اچا نک آسن یِم أکِس کُھلہٕ مٲدانس منٛز مو جود"
  79,15,"تۅہیہِ چھا مو سیٰ علیہ السلام سٕنٛدِ قٕصٕچ خبر وٲژ مٕژ؟"
  79,16,"ییٚلہِ تٔمۍ سٕنٛد ۍ ربن تس طویٰ چہِ مقدس وٲدی اندر ناد لوے زِ ،"
  79,17,"فر عو نس نِشہِ گژھ ، سُہ چُھ بُتھۍ پُھیر سپُد مُت،"
  79,18,"بیٚیہِ وَن تس، کیا ژٕہ چُھکھٕ اَمہِ خٲطرٕ تیار زِ پٲکیز گی کر کھ اختیار،"
  79,19,"تہٕ بہٕ کر ے چٲنِس ربس کُن چٲ نۍ رہنمٲیی ، پتہٕ گژِھہ﴿تٔمۍ سُنٛد﴾ خو ف ژےٚ منٛز پٲدٕ؟"
  79,20,"پتہٕ ہٲو مو سیٰ علیہ السلامَن ﴿فر عونس نِشہِ گٔژِھتھ﴾ تَس بٔڑ نشٲنی ﴿بٔڑ نشٲ نی چُھ مُراد عاصُک شہمار بنُن ییٚمِچ ذکر قرآن مجیدس اندر واریاہن جا ین چھےٚ کر نہٕ آمٕژ﴾"
  79,21,"مگر تٔمۍ کوٚر انکار تہٕ مو نُن نہٕ کینٛہہ،"
  79,22,"پتہٕ پھِیوٗر چالبٲزِیہِ کر نہٕ خٲطرٕ پوٚت"
  79,23,"کٔرِن لُکھ جمع کر یکھ لٲیِتھ"
  79,24,"پتہٕ ووٚ ننکھ ""بہٕ چُھس تُہنٛد سارِوٕے کھۅتہٕ بوٚڈ خداے"
  79,25,"ٲخر کار روٚٹ سُہ اللہ تعالہٰ ہن ٲخرت کِس  تہٕ دنیا کِس عذابس منٛز"
  79,26,"در حقیقت چُھ اتھ منٛز بوٚڈ بارٕ عبرت پرتھ تس شخصس خٲطرٕ یُس کھۅژِ ﴿ یعنی خداے سُنٛد رسول صلی اللہ علیہ وسلم نہ ماننہٕ کہ تَمہِ انجام نِشہِ  کھوژِ ن یُس انجام فر عو نَن وُچھ﴾"
  79,27,"۔ کیا تُہٕنٛز تخلیق چھا زیادٕ ہ سخت کٲم کِنہٕ آسما نٕچ؟اللہ تعالیٰ ہن بنو و یہ"
  79,28,"اَمیُک چھت تُلُن واریاہ تھوٚد ،پتہٕ کوٚرُن اَتھ توازُن قٲیِم،"
  79,29,"اَمِچ رات بنٲوٕ ن گٔٹ تہٕ دۅہ کوٚڈُن توٚن"
  79,30,"اَمہِ پتہٕ وتھر ٲوٕن زمین،"
  79,31,"اَمہِ منٛزٕ کوٚڈُن اَمیُک آب تہٕ نیوٗر ﴿یعنی تِم کُلۍ کٔٹۍ یِم انسان تہٕ حیوان غذارٔنگۍ استعمال کران چھِ﴾"
  79,32,"تہٕ اتھ منٛز تھٲوِن پہاڑ ٹھٲکِتھ،"
  79,33,"تُہٕنٛدِ نفع خٲطرٕ تہٕ بیٚیہِ تُہٕنٛد ٮ۪ن چا رواین ہٕنٛدِ فٲیدٕ خٲطرٕ"
  79,34,"پتہٕ ییٚلہِ سُہ عظیم ہنگا مہٕ ﴿مُراد چُھ قیا مت ﴾ برپا سپدِ،"
  79,35,"ییٚمہِ دۅہ انسان پنُن سورُے کوٚر مُت تہٕ کرٚ وومُت یاد کرِ،"
  79,36,"تہٕ ہر کٲنسہِ وُچھَن وٲلِس برونٛٹھہٕ کَنہِ یِیہِ دوزخ مٕژرٲوِتھ تھاونہٕ،"
  79,37,"وۅ نۍ ییٚمۍ سر کشی کٔر مٕژ ٲس"
  79,38,"تہٕ دنیا چہِ زند گی ٲسٕن تر جیح دِژ مٕژ،"
  79,39,"تہٕ ییٚمۍ پننِس ربس برونٛہہ کنہِ کھڑا سپدنُک خو ف اوس تھو و مُت،"
  79,40,"بیٚیہِ اوسُن بُرٕ خوٲہشا تَو نِشہِ پنُن نفس پتھ روٚٹمُت،"
  79,41,"تٔمۍ سُنٛد ٹھکا نہٕ آسہِ پٔزۍ پٲٹھۍ جنت"
  79,42,"یِم لُکھ چھِ تۅہیہِ پٕرٚ ژھان زِ ""ٲخر کر یِیہِ سۅ گٔر ﴿یعنی قیا مت﴾؟"""
  79,43,"یہِ کتہِ چھےٚ تُہٕنٛز کٲم زِ اَمیُک وقت ؤنِو،"
  79,44,"اَمیُک علم چُھ خدایس نِشہِ اندواتان،"
  79,45,"توٚہۍ چھِو صرف خبردار کر ن وٲلۍ ہر کٲنسہِ تَس شخصس یُس اَمیُک خو ف تھا وِ"
  79,46,"ییٚمہِ دۅہ یِم لُکھ اَتھ وُچھن،تہٕ یِمن با سہِ زَ نتہٕ ﴿یِم دنیا ہَس منٛز یا مو ت کِس حالتس منٛز ﴾ چھِ دۅ ہ کِس پٔتمِس یا گۅڈ نِکِس پہرس روٗدِ مٕتۍ"
