quran[30]{c,v,t}:
  67,1,"۔سٮ۪ٹھاہ بزر گ تہٕ برتر چُھ سُہ ییٚمۍ سٕنٛدِس اَتھس منٛز ﴿ کا ینا تٕچ﴾ سلطنت چھےٚ ، تہٕ سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھا وان۔﴿ یعنی یِکینٛژھاہ ییٚژِ ھہ تہِ ہیٚکہِ کٔرِتھ، کانٛہہ چیز چُھنہٕ تس رُکاون وول زِ تس آسہِ کانٛہہ کٲم کرٕنۍ تہٕ سُہ کیا ہیٚکہِ نہٕ کٔرِتھ﴾"
  67,2,"۔ییٚمۍ مو ت تہٕ زند گی ایجاد کٔر،تاکہِ تۅہیہِ لُکن وُچھِ آزمٲوِتھ زِ تۅہیہِ منٛز کُس چُھ بہتر عمل کر ن وول۔﴿یعنی دُنیا ہس منٛز چُھ تٔمۍ انسانن ہٕنٛدِ مر نُک تہٕ زندٕہ روزنُک یہِ سلسلہٕ امہِ  مو جو ب شروع کوٚر مُت زِ یِمن ہیٚیہِ امتحان ، بیٚیہِ وُچھہِ کَس انسان سٕنٛز عمل چھےٚ زیادٕہ بہتر﴾بیٚیہِ چُھ سُہ زبردست تہِ،تہٕ در گُزر کر ن وول تہِ۔"
  67,3,"۔ییٚمۍ پیوٚٹُھس پٮ۪ٹھ ستھ آسمان بنٲوۍ﴿ اے انسانہٕ ﴾ ژٕ لبکھ نہٕ رحمٰن سٕنٛدِس تخلیقس منٛز کُنہِ قسمٕچ بےٚ ربطی۔﴿در اصل چُھ لفظ ""تَفاوُت""وَرتاونہٕ آمُت، اَتھ چُھ معنی عدمِ تنا سُب،اکھ چیز بیٚکِس چیز س سٍتۍ نَہ رَلُن ،بے جوڑ آسُن﴾ پتہٕ وُچھ پوٚت پھیٖرِتھ ،کُنہِ جایہِ چھےٚ نہٕ ژےٚ کانٛہہ خلل نظرِ گژھان؟﴿دراصل چُھ لفظ""فطُور"" وَر تاو نہٕ آمُت،اَتھ چُھ معنی ،پھرٛاٹھ،رُم، پھا س رخنہٕ، پھوٚٹمُت آسُن، پُھٹمُت آسُن۔مطلب چُھ یہِ زِ پوٗرٕ کا ینا تٕچ بندِس چھےٚ تِژھہ چُست تہٕ زمین کہ اکہِ ذرٕہ پٮ۪ٹھہٕ عظیم کہکشا نن تام چُھ پرٛتھ کانٛہہ چیزتِیُتھ مر بو ط زِ کُنہِ جایہِ چُھنہٕ کانیا ت کہ نظمُک تسلسل پُھٹان۔توٚہۍ کٔرِ تَو خواہ کوتاہ تہِ جستجو تۅہیہِ ہیکیونہٕ اَتھ منٛز کُنہِ جایہِ  رخنہٕ میٖلتھ۔﴾"
  67,4,"۔ پتہٕ وُچھتہٕ پھِرۍ پھِر ۍ ، چٲنۍ نظر پھیرِ تھٔکِتھ نا کام گٔژِھتھ واپس۔"
  67,5,"۔اَسہِ چُھ تُہُنٛد نزدیکُک آسمان عظیم الشّان ژانگیو سٍتۍ سجو ومُت۔﴿نزدیکُک آسمان چُھ مُراد سُہ آسمان ییٚمکۍ تارک تہٕ سیّارٕہ دوٗر بینہِ ورٲے أسۍ وُچھان چِھ۔﴾تہٕ تِم چِھ اَسہِ شیطان ژٔلراونٕکۍ ذر یعہ بنٲوِمٕتۍ۔ یِمن شیطا نن خٲ طرٕ چُھ اَسہِ سُہ نار دستیا ب تھوومُت یَتھ لمبک آسن وۅتھا ن ۔"
  67,6,"۔ یِمو لُکو پننِس ربّس سٍتۍ کُفر کوٚر،تِہنٛدِ خٲ طرٕ چُھ جہنمُک عذاب تہٕ سُہ چُھ سٮ۪ٹھٕے بُرٕہ ٹِھکانہٕ۔"
  67,7,"۔ ییٚلہِ تِم تتھ منٛز چَھکنہٕ یِن ، تِم بوزن تَمہِ چہِ ہولناک آوازٕ۔﴿اتھ  ہیٚکہِ یِتہِ معنی ٲسِتھ زِ یہِ آسہِ خۅد جہنمٕچ آواز،تہٕ یِتہِ ہیٚکیٚس ٲسِتھ زِ یہِ آواز آسہِ جہنم منٛزٕ یِوان ییٚتہِ تِم لُکھ آسن کرٛ یکہٕ دِوان یِم یِمن برونٛہہ آسن تور چھکنہٕ آمٕتۍ۔﴾تہٕ سُہ آسہِ جو ش ماران۔"
  67,8,"۔ غضب کہ شِدّ تہٕ سٍتۍ آسہِ پھٹان، پرٛتھ وِزِ ییٚلہِ تتھ منٛز کانٛہہ کھیٚج تراونہٕ یِیہِ ،تمِکۍ کارِ ندٕہ پٕرٚژھن تِمن لُکن، ""کیا تۅہیہِ نِشہِ اوسنا کانٛہہ خبردار کر ن وول آمُت؟"""
  67,9,"۔ تِم دن جواب ""آ،خبردار کر ن وول اوس اَسہِ نِشہِ آمُت،مگر اَسہِ پھِیرُتس بُتھ بیٚیہِ ووٚن خُداین چُھنہٕ کِہٕنۍ تہِ نٲزِل کوٚرمُت،توٚہۍ چِھو بجہِ گُمرٲہی منٛز۔"""
  67,10,"۔تہٕ تِم وَنن "" کا ش أسۍ بوز ہَو یا سمجھِہ ہَو،تیٚلہِ گژھہَو نہٕ اَز ییٚمہِ شعلہٕ وُنہِ نارٕ کیٚن سزا وارن منٛز شٲمل۔"
  67,11,""" یِتھہٕ پٲٹھۍ کرن تِم پننہِ قصُورُک پانہٕ اعتراف،لعنت چھےٚ یِمن جہنمی یَن پٮ۪ٹھ۔"
  67,12,"۔یِم لُکھ ربس وُچھنہٕ ورٲے چھِ کھۅژان ،پٔزِ پٲٹھۍ چھےٚ تِہنٛدِ خٲ طرٕ مغفر ت تہٕ سٮ۪ٹھا ہ بوٚڈ اجر۔"
  67,13,"۔ توٚہۍ کٔرِ تَو  لۅ تہِ لۅ تہِ کتھ یا کٔرِ و تَو بَڈِ ﴿ خُدایس خٲ طرٕ چُھ یکسا ن ﴾ سُہ دِلن ہُنٛد حال تام زانان۔"
  67,14,"۔ کیا سُے آسہِ نازانان ییٚمۍ پٲدٕ چُھ کوٚر مُت۔﴿ بیاکھ تر جمہٕ ہیٚکیس یِتہِ ٲسِتھ زِ "" کیا پننِس مخلو ق سٕے زانہِ نا سُہ؟""﴾ حالا نکہ  سُہ چُھ باریک بین تہٕ با خبر۔ع"
  67,15,"۔سُے چُھ ییٚمۍ تُہُنٛدِ خٲ طرٕ زمین چھےٚ تھٲ و مٕژ تا بع کٔرِتھ، پٔکِو ،تمہِ کِس سینس پٮ۪ٹھ تہٕ کھیٚیِو اللہ تعالیٰ سُنٛد رِزق،تٔمۍ سٕنٛدِ سٕے در بارس منٛز چُھ تۅہیہِ دوبارہ زندٕہ سپدِتھ واتُن۔"
  67,16,"۔کیا توٚہۍ چِھوٕ تمہِ نِشہِ بے خو ف یہِ آسمانن منٛز چُھ۔﴿اَمیُک چُھنہٕ یہِ مطلب زِ اللہ تعالیٰ چُھ آسمانس منٛز روزان،بلکہ چھےٚ یہِ کتھ اَمہِ لحا ظہٕ فر ماونہٕ آمٕژ زِ انسان ییٚلہِ فطر ی طور چُھ خُدایس سٍتۍ رجو ع کرُن یژھان تیٚلہِ چُھ آسمانس کُن وُچھان ۔ ییٚلہِ دُعا چُھ منگا ن تیٚلہِ چُھ آسما نس کُن اَتھہٕ تُلان۔ کُنہِ آفت کِس مو قعس پٮ۪ٹھ ییٚلہِ تمام سہا رَو نِشہِ نا اُمید چُھ سپدان ،تیٚلہِ چُھ آسمانس کُن بُتھ کٔرِتھ خُدایس فر یاد کران،کانٛہہ ناگہا نی بلا ے چھےٚ یِوان تیٚلہِ چُھ وَنان یہِ ؤژھ ہیٚر ی آسمانہٕ۔ غیر معمو لی طور حٲ صِل سپدان وٲلِس چیز س متعلق چُھ وَنان یہِ چُھ عالم بالا پٮ۪ٹھہٕ آمُت ۔اللہ تعالیٰ سٕنٛز ن سوزنہٕ آمژٕ کتا بن چُھ کُتبِ آسمٲنی یا کتبِ سما و ی وَننہٕ یِوان ۔ یِمو سارِ وٕے یَو کَتھو نِشہِ چُھ ظٲ ہر سپدان زِ یہِ کتھ چھےٚ انسان سٕنٛدِس فطر ت سٕے منٛز زِ ییٚلہِ تہِ سُہ اللہ تعالیٰ سُنٛد تصّور چُھ کران تیٚلہِ چُھنہٕ تٔمۍ سُنٛد ذہن بۅ ن زمینس کُن گژھان بلکہ چُھ ہیوٚ ر آسمانس کُن گژھان۔﴾ تۅہیہِ والیو زمینس، تہٕ اچانک لاگہِ یہِ زمین ہیٚٹھ ہیٚٹھ کرٕنۍ؟"
  67,17,"۔ کیا توٚہۍ چِھوٕ اَمہِ نِشہِ بے خو ف زِ سُہ یُس آسما نس منٛز چُھ سوزِ تۅہیہِ پٮ۪ٹھ پتھراو کرن وول ہوا؟پتہٕ لگیو تۅہیہِ پے زِ میو ن نہیب کِیُتھ چُھ آسان۔"
  67,18,"۔ یِمَو بروٗنٹھمِیو گزر یمتیو لُکو چُھ بُتھ پھِیرمُت،پتہٕ وُچھِو میٲ نۍ گر فت کٲژاہ سخت ٲس۔"
  67,19,"۔ کیا یِم لُکھ چِھنا پانس پیٚٹھۍ کِنۍ وُڑن وٲلۍ جانا وار پکھہٕ مٕژ راوان تہٕ وَٹان وُچھان؟ خداے رحما نس ورٲے چُھنہٕ کانٛہہ یُس یِمن تھپھ کٔرِتھ آسہِ،سُے چُھ پرٛتھ چیزُک نگہبان۔"
  67,20,"۔ ؤنِو ،کُس لشکر چُھ ٲخر تۅہیہِ نِشہِ یُس خداے رحمان سٕنٛدِس مقابلس منٛز تۅہیہِ مدد ہیٚکہِ کٔرِتھ؟﴿ بیا کھ تر جمہٕ ہیٚکہِ یِتہِ ٲسِتھ زِ "" خدا ے رحمٰنس ورٲے کُس چُھ یُس تُہُنٛد لشکر بٔنِتھ تۅ ہیہِ دستگیر ی آسہِ کران ۔"" ﴾حقیقت چھےٚ یہِ زِ یِم مُنکر چِھ دو کھس منٛز پیٚتھ۔"
  67,21,"۔ نَتہٕ ؤنۍ تو، کُس چُھ یُس تۅہیہِ رزق ہیٚکہِ دِتھ اگر خدا ے رحمٰن پنُن رِزق رُکاوِ، دراصل چِھ یِم لُکھ سر کشی کر نس تہٕ حق نِشہِ پوٚت ہیٚنس پٮ۪ٹھ ڈٔٹِتھ۔"
  67,22,"۔ ہَنا سوٗ نچِتَو،یُس شخص بُتھ بۅ ن کُنُے رٔٹِتھ پکان آسہِ ﴿ یعنی چاروٲے سٕندۍ پٲٹھۍ آسہِ گردن بۅ ن رٔٹِتھ تٔتھۍ وَتہِ پٮ۪ٹھ پکان یَتھ پٮ۪ٹھ کٲنٛسہِ سُہ تروومُت آسہِ ۔﴾سُہ چھا زیادہ صحیح وَتھ لبَن وول ،کِنہٕ سُہ یُس کلہٕ تھوٚد تُلِتھ ہموار سڑکہِ پٮ۪ٹھ آسہِ پکان؟"
  67,23,"۔ یِمن ؤنِو اللہ تعالیٰ ہے چُھ ییٚمۍ توٚہۍ پٲدٕہ کٔرِنَو،تۅہیہِ دِتۍ نَو بوزنٕکۍ تہٕ وُچھنٕکۍ طاقت،بیٚیہِ دِتۍ نَو سو نچن سمجھن وٲلۍ دِل، مگر توٚہۍ چِھو کمٕے کران شُکر ادا۔﴿یعنی تۅہیہِ آسنو خُداین علم و عقل تہٕ سما عت و بینٲیی ہٕنٛزٕ یِمہٕ نعمتہٕ حق شنٲسی خٲطرٕ دِژ مَژٕ۔توٚہۍ چِھو  نا شکر ی کران زِ یِمن چِھو سار ے کامہِ ہیٚوان،مگر بس سۅ ے یٲژکٲم چھوٗکھ نہٕ ہیوٚان ییٚمہِ خٲطرٕ یِمہٕ دِنہٕ آسہٕ آمژٕ۔﴾"
  67,24,"۔ یِمن ؤنِو ،اللہ تعالیٰ ہٕے چُھ ییٚمۍ توٚہۍ زمینس منٛز چِھنَو پٔھہلٲوِمٕتۍ،تہٕ تٔسۍ کُن یِیِو توٚہۍ ؤٹِتھ نِنہٕ۔"
  67,25,"۔یِم چِھ وَنان "" اگر توٚہۍ پٔزِ یٲرۍ چِھو تیٚلہِ ؤنِو یہِ وعدٕہ کر گژِھہ پوٗرٕ؟"
  67,26,"۔ ؤننِو ، "" اَمیُک علم چُھ خُدایس نِشہِ،بہٕ چُھس بس صاف صا ف خبردار کر ن وول۔"""
  67,27,"۔ پتہٕ ییٚلہِ یِم تتھ چیز س نکھہٕ وُچھن، تِمن سارِنٕے لُکن ہٕندٮ۪ن بُتھیٚن گژِھہ مسخہٕ صور ت یِمو انکار چُھ کوٚرمُت،تہٕ تمہِ وقتہٕ یِیہِ تِمن وَننہٕ زِ یۅ ہے چُھ سُہ چیز ییٚمہِ خٲطرٕ توٚہۍ تقا ضہٕ آسِو کران ۔"
  67,28,"۔ یِمن ؤنِو،زانٛہہ سو نچوٕ تۅہیہِ یِتہِ زِ اللہ تعالیٰ کٔرِتن خواہ مےٚ تہٕ میا نیٚن سٲتھِین ہلاک یا کٔرِتن اَسہِ پٮ۪ٹھ رحم،کٲفرن کُس بچا وِدگ تُلہٕ وٕنہِ عذا ب نِشہِ؟﴿مکہ معظّمس منٛز ییٚلہِ رسول اللہ صلی اللہ علیہ وسلمن ہٕنٛدِ دعوتُک آغا ز سپُد،تہٕ قر یشن ہٕنٛدٮ۪ن مختلف خا ندانن سٍتۍ تعلق تھا ون والیو نفر و لوگ اسلام قبول کرُن، گھر ن ہٕنٛدۍ گھرٕ لٔگۍ حضور صلی اللہ علیہ وسلمن تہٕ تِہنٛدٮ۪ن سٲتھِیَن بد دُعا کر نہِ ۔ جٲدۍ تہٕ تعو یزٕہ لٲگِہَکھ کرٕنۍ تاکہ تِم گژھۍ مَرٕنۍ ۔حتیٰ کہ  قتلٕکۍ منصوبہٕ تہِ لٲگِکھ سو نچِنۍ۔اَتھ پٮ۪ٹھ آو یہِ فر ما و نہٕ زِ یِمن ؤنِو زِ أسۍ خواہ ہلاک گژھو یا روزَو اللہ تعالیٰ سٕنٛدِ فضل سٍتۍ زِ ندٕہ ،اَمہِ سٍتۍ کیا گژھیو تۅہیہِ حٲصل؟توٚہۍ کٔرِ و پنٕنۍ فِکر زِ اللہ تعالیٰ سٕنٛدِ عذا ب نِشہِ کِتھہٕ پٲٹھۍ بٔچِو۔﴾"
  67,29,"یِمن ؤنِو زِ سُہ چُھ سٮ۪ٹھاہ مہربان،  تٔسۍ پٮ۪ٹھ چُھ اَسہِ ایمان اوٚنمُت ،تہٕ تٔسۍ پٮ۪ٹھ چُھ اسہِ بھر وسہٕ،عن قر یب لگیو تۅہیہِ پے زِ کُس چُھ ٹا کارٕہ گُمرٲیی منٛز ہیٚنہٕ آمُت۔"
  67,30,"۔ یِمن ؤنِو ،زانٛہہ سو نچوٕ تۅہیہِ یِتہِ زِ اگر تُہٕندٮ۪ن کرِ یر ٮ۪ن ہُنٛد آب زمینس تل وَسہِ،تیٚلہِ کُس چُھ یُس تۅہیہِ پکہٕ وُن آب﴿ آبِ رواں﴾ ہیکیو أنِتھ دِتھ۔ ع"
