quran[110]{c,v,t}:
  18,1,"۔تعر یف چُھ اللہ تعالیٰ سٕندِ خٲطرٕ ییٚمۍ پننِس بند س پٮ۪ٹھ یہِ کتاب نٲزِل کٔر،تہٕ اتھ منٛز تھوٚوُن نہٕ کانٛہہ ہَجر۔"
  18,2,"۔ٹھیک ٹھیک سیوٚد کتھ ونَن واجِنۍ کتاب،تاکہ سۅ کرِ لُکن اللہ تعالیٰ سٕندِ سخت عذا ب نِشہِ خبردار، تہٕ ایمان أنِتھ دِیہِ نیک عمل کر ن والیٚن خۅ ش خبر ، زِ تِہندِ خٲطرٕ چُھ رُت اجر،"
  18,3,"۔ یتھ منٛز تِم ہمیشہ روزن،تہٕ تِمن لُکن کھۅژناوِ،"
  18,4,"۔یِم ونان چِھ زِ خُدا ین چُھ کانٛہہ نیچُو بنو و مُت۔"
  18,5,"۔امہِ کتھہِ ہُند نَہ چُھ تِمن کانٛہہ علم، تہٕ نَہ اوس تِہندِس مٲلِس بُڈِ ببَس، بٔڑ کتھ چھےٚ یوسہٕ تِہندِ ٲسہٕ چھےٚ نیران،تِم چِھ محض اُپُز بکا ن۔"
  18,6,"۔اچھا ، اے نبی صلی اللہ علیہ وسلم ،شاید گٲلِو توٚہۍ غمہٕ سٍتۍ یِمن پَتھ پنُن پان، اگر نہٕ یِم یتھ تعلیمہِ پٮ۪ٹھ ایمان اَنن۔"
  18,7,"۔پزر چُھ یہِ زِ یِکینژھاہ ساز و سامان تہِ یتھ زمینس پٮ۪ٹھ چُھ، یہِ چُھ اَسہِ زمینٕچ زینت بنو و مُت، تاکہ یِم لُکھ آزماووکھ زِ یِمن منٛز کُس چُھ بہتر عمل کر ن وول۔"
  18,8,"۔ٲخر کار چِھ ٲسۍ اَتھ سٲرِ سٕے اکھ ہموار مٲدان بناون وٲلۍ۔"
  18,9,"۔کیا توٚہۍ چِھوٕ ہ سمجھان زِ غا ر تہٕ تختی وٲلۍ، ٲسۍ سانیو بَجو عجیب نِشٲنِیو منٛزٕ ؟ ﴿یعنی تِم نو جوان یِم پنُن ایمان بچا و نہٕ خٲطرٕ غارس منٛز ٲسۍ چَھپنہِ ژامٕتۍ، تہٕ یِہندِس غا رس پٮ۪ٹھ پتہٕ یاد گٲر ی تختی ٲس لگا و نہٕ آمٕژ﴾"
  18,10,"۔ییٚلہِ تِم نو جو ان غا رس منٛز چَھپنہِ ژاے، تہٕ تِمو ووٚن زِ  اے پروردگارٕ، اسہِ کر پنٕنۍ خا ص رحمت عطا۔ تہٕ سو ن معا ملہٕ کردُرست۔"
  18,11,"۔اَسہِ سٲوۍ تِم أتھۍ غارس منٛز تھا پ دِتھ ؤری وادن خٲطرٕ مَژِنیندرِ، ﴿تھا پ= یعنی سۅ ژٔنڈ یۅسہٕ شُرس ساو نہٕ وِزِ لولہٕ سان چِھ دِوان ﴾"
  18,12,"۔پتہٕ وُزنٲوۍ اسہِ تِم، تاکہ وُچَھو تِہند یو دۅ یَو دَر یو منٛز کُس ہیٚکہِ پننہِ قیام کہ مُدّتُک صحیح شُمار کٔرِتھ۔ع"
  18,13,"۔أسۍ بوزناوَو تۅہیہِ تِہُند اصلی قصّہٕ ۔تِم ٲسۍ کینٛہہ نوجو ان یِمو ربّس پٮ۪ٹھ ایمان اوس اوٚ نمُت، تہٕ اسہِ ٲس تِمن ہدا یتس منٛز تر قی بخشمٕژ۔﴿روایتو نِشہِ چُھ پے لگا ن زِ یِم نوجو ن ٲسۍ ابتدٲیی دَورس منٛز مسیح علیہ السلام سٕندیو پیرَو کارَو منٛزٕ ، تہٕ بیٚیہِ ٲسۍ رو می سلطنت کیو لُکو منٛزٕ، تمہِ وقتہٕ ٲسۍ رو می سلطنتٕکۍ لُکھ مشر ک تہٕ تِم ٲسۍ اہلِ تو حید ن دُشمن بنان ﴾"
  18,14,"۔اسہِ کٔرۍ تِہندۍ دل تمہِ وقتہٕ مضبو ط ییٚلہِ تِم ووٚتھۍ،تہٕ تِمو کوٚر یہِ اعلان زِ  سو ن ربّ چُھ بس سُے یُس آسمانن تہٕ زمینُک ربّ چُھ۔ أسۍ لایَو نہٕ سُہ ترٲوِتھ بیٚیہِ کٲنٛسہِ معبودس ناد،اگر أسۍ یہِ کرو ، تیٚلہِ کرو بالکل بے جا کتھ۔ ﴿پتہٕ ووٚن تِمو پانہٕ وٲنۍ اکھ أکِس ﴾"
  18,15,"۔ییٚمۍ سٲنۍ قو من چِھ کایناتُک ربّ ترٲوِتھ با قی خُدا ے بنٲوِمٕتۍ۔یِم لُکھ کیا زِ چِھنہٕ یِہِندِس معبود آسنس پٮ۪ٹھ کانٛہہ ٹا کارٕ دلیل اَنان ؟ ٲخر کُس ہیٚکہِ تس شخصہٕ سٕنزِ کھۅتہٕ تہِ بوٚڈ ظٲلِم ٲسِتھ یُس خُدا یس پٮ۪ٹھ اَپُز کھالہِ؟"
  18,16,"۔وۅ نۍ ییٚلہِ توٚہۍ یِمن نِشہِ تہٕ بیٚیہِ یِہِندٮ۪ن غیر اللہ معبودن نِشہِ لا تعلق چِھو گٔمٕتۍ، تیٚلہِ پٔکِو فلٲنۍ غارس منٛز نِمو پناہ۔ تُہُند ربّ کرِ تۅ ہیہِ پٮ۪ٹھ پننہِ رحمتُک دامن وسیع، تہٕ تُہٕنزِ کامہِ خٲطرٕ کرِ سہو لیت تہٕ آسٲیش مہیّا۔﴿منٛز با گ چھےٚ یہِ ذکر تراونہٕ آمٕژ زِ امہِ با ہمی فٲصلہٕ مطٲبق درٛاے تِم امہِ شہرٕ منٛزٕ تہٕ پہاڑن در میان روٗدۍ أکِس غارس منٛز چُھپِتھ، تاکہ سنگسار سپد نہٕ نِشہِ یا اِرتدادس پٮ۪ٹھ مجبو ر کر نہٕ یِنہٕ نِشہِ بچن ﴾"
  18,17,"۔توٚہۍ اگر تِم غارس منٛز وُچھِہوٗکھ ،تیٚلہِ با سِہٚیو تۅہیہِ زِ آفتاب ییٚلہِ کھسان چُھ،  تہٕ ییٚلہِ لو سان چُھ،تیٚلہِ چُھ تِہُند غا ر ترٲوِ تھ دٔچِھنۍ کِنۍ کھسان، تہٕ ییٚلہِ لوسان چھُ تیٚلہِ چُھ تِمن نِشہِ ژھا یہِ روٗزِ تھ کھووٕرۍ کِنۍ وَسان، تہٕ تِم چِھ غا رس منٛز أکِس وسیع جایہِ روٗزِ تھ۔ یہِ چھےٚ اللہ تعالیٰ سٕنز و نشٲنیَو منٛز اکھ،یس اللہ تعالیٰ ہدایت دِیہِ ،سُے چُھ ہدا یت لبن وول، تہٕ یس خُدا ے ڈالہِ، تس خٲطرٕ وُچھوٗن نہٕ توٚہۍ کانٛہہ ولی مُر شد ﴿مددگار تہٕ سیٚز وَتھ ہاون وول﴾۔ع"
  18,18,"۔تِم وُچِھتھ سمجھِہِو توٚہۍ زِ تِم چِھ ہُشار، حالانکہ ٲسۍ شوٚنگِتھ،أسۍ ٲسۍ تِمن دَچُھن کھۅوُر لرِ پھِرُن دیاوناوان،تہٕ تِہُند ہوٗن اوس غار کِس گٔلِس پٮ۪ٹھ اتھہٕ پھٔہلٲوِتھ بِہِتھ۔اگر توٚہۍ تِمن کُن نظر ترٲوِ ہِو، تیٚلہِ ژٔلِہِو پوٚت کھو ر ی،تہٕ تۅہیہِ یِیہِ ہیوٚامہِ نظارٕ ہ سٍتۍ کھۅژُن۔"
  18,19,"۔تہٕ اَمی عجیب کرامت سٍتۍ تُلۍ اسہِ تِم تھوٚد ﴿یعنی ییٚمہِ عجیب طر یقہٕ تِم سا و نہٕ ٲ سۍ آمٕتۍ ، تہٕ دُنیا اوس تِہِندِ حال نِشہِ بے خبر تھاو نہٕ آمُت۔تِژٕھے عجیب قدرتٕچ کرا مت ٲس تِہندِ اکہِ طو یل وقتہٕ پتہٕ ہُشار سپدُن تہِ ﴾ تا کہ پانہٕ وٲنۍ کر ن ہنا پٕرٛژھگٲر۔تِمو منٛز پُرٛوژھ أکۍ  ؤنِو ،کٍتِس کالس روٗدۍ یتھ حالس منٛز؟ با قیو ووٚن  شاید دۅ ہس کھنڈس یا آسَو امہِ کھۅتہٕ کم کا لس روٗدِمٕتۍ۔پتہٕ ووٚن تِمو  اللہ تعالیٰ ہٕے چُھ بہتر زانان زِ اَسہِ کوتا ہ وقت گُزریو اَتھ حالتس منٛز، پٔکِو ،وۅ نۍ سوزن پننیٚو منٛزٕ کانٛہہ یہِ رۅ پہٕ سِکہٕ دِتھ شہر، تہٕ سُہ وُچھہِ سارِوٕے کھۅتہٕ جان کھیٚن کتہِ چُھ میلان، تَتہِ اَنہِ سُہ کینٛہہ کھیٚنہٕ خٲطرٕ، بیٚیہِ پز یٚس زِ ہنا کرِ ہُشٲری سان کٲم،یہِ گوژھ نہٕ بنُن زِ سُہ کرِ کٲنٛسہِ خبردار زِ أسۍ چِھ ییٚتہِ۔"
  18,20,"۔ہرگاہ تِمن لُکن ہُند اتھہٕ اسہِ پٮ۪ٹھ پیوٚو ،تیٚلہِ کر ن بَس اسہِ ضرور سنگسار، یا نِن پتہٕ زبردستی سان پننِس مِلّتس منٛز واپس، تہٕ اگر یہِ سپُد تیٚلہِ ہیٚکَو نہٕ زانٛہہ أسۍ فلا ح لٔبِتھ۔"
  18,21,"۔یِتھہٕ پٲٹھۍ کٔرۍ اسہِ شہرٕ کۍ لُکھ تِہندِس حالس پٮ۪ٹھ با خبر۔﴿ یعنی ییٚلہِ سُہ شخص کھیٚن موٚ لۍ ہیٚنہٕ خٲطرٕ شہر گوٚو ، دُنیا اوس بدلیا مُت۔رو م یُس بُت پرست اوس ،تَتھ اوس عیسٲے بنیمتِس واریاہ کال گوٚ مُت۔ زبان ،تہذ یب، تمدُّن، لبا س پرٛتھ چیز س منٛز ٲس ٹا کارٕ فر ق آمٕژ۔زٕ ہ ہتھ ؤری بروٗنٹھِم یہِ شخص بنیاو پننہِ سِٹایلہٕ سٍتۍ ، پلَوو سٍتۍ، زبٲنۍ سٍتۍ پرٛتھ چیز کہ اعتبارٕ فوراً اکھ تما شہِ، تہٕ ییٚلہِ تٔمۍ پرا نہِ زمانُک سکّہٕ کھیٚن موٚ لۍ ہینہٕ خٲطرٕ کوٚڈ،وانہٕ وٲلۍ سٕنز أچھ گٔیہِ روٚبوٗدٕہ۔ ییٚلہِ تحقیق آو کر نہٕ، پتہٕ لوٚگ پے زِ یہِ شخص چُھ مسیح علیہ السلام سٕند یو پیر و کارو منٛز، یِم زٕہ ہَتھ ؤری برونٛہہ پنُن ایمان بچا و نہٕ خٲطرٕ ژٔلمٕتۍ ٲسۍ۔یہِ خبر وٲژ سٮ۪ٹھاہ جلد شہر چہِ عیسٲے آبٲدی تام تہٕ حُکّام ہیٚتھ ووت لُکن ہُند اکھ ہجو م غارس کِس گٔلِس پٮ۪ٹھ۔وۅ نۍ ییٚلہِ اصحابِ کہف خبردار سپٕدۍ زِ تِم چِھ زٕہ ہتھ ؤری پتہٕ نیندرٕ بیدار گٔمٕتۍ،تِمو کٔر پننیٚن عیسٲے با ین سلام، اَمہِ پتہٕ چِھ لَر ترٛوان تہٕ أتھۍ سٍتۍ چِھ تِہندۍ رو ح پرواز کران ﴾ تا کہ لُکھ زانن زِ اللہ تعالیٰ سُند وعدٕہ چُھ پوٚز، بیٚیہِ یہِ زِ قیا مت چہِ گرِ چُھ بے شک یُن۔﴿مگر ہنا کٔرۍ تَو خیا ل زِ ییٚلہِ سو نچنٕچ اصلی کتھ یہِ ٲس﴾ تمہِ ساعتہٕ ٲسۍ تِم پانہٕ وٲنۍ اتھ کتھہِ پٮ۪ٹھ ژوُان زِ یِمن اصحابِ کہفن سٍتۍ کیا گژِھہ یُن کر نہٕ، کینژھو لُکو ووٚ ن یِمن پٮ۪ٹھ کھٲلِو دیوار، یُہُند ربّے چُھ یُہُند معاملہٕ بہتر پٲٹھۍ زانان۔﴿اندازِ کلام نِشہِ چُھ با سان زِ یہِ کتھ ٲس تِمَو لُکو ؤنِمٕژ یِم نصاریٰ ہَن منٛز رٕتۍ ٲسۍ ۔ تِہٕنز راے ٲس یہِ زِ اصحا بِ کہف یِتھہٕ پٲٹھۍ غارس منٛز لَر ترٲوِتھ چِھ ، تِمن دِیو تِتھے پٲٹھۍ لر ترٲوِتھ روز نہٕ، تہٕ غا ر کِس گٔلِس لگٲوِو محرٲبۍ دروازٕہ ، یُہنُد ربّے چُھ بہتر زانان زِ یِم کم لُکھ چِھ ، کمہِ مر تبٕکۍ انسان چِھ، کمہِ جز اہٕکۍ چِھ حقدار۔﴾مگر یِم لُکھ تِہند ٮ۪ن معا ملاتن پٮ۪ٹھ غٲلب ٲسۍ۔تِمو ووٚن أسۍ بناوَو یِمن پٮ۪ٹھ اکھ عبادت گاہ۔ ﴿یہِ سپُد امہِ وجہ کِنۍ زِ امہِ وقتہٕ ٲسۍ عیسٲے لُکن منٛز تہِ مُشر کانہٕ خیا لات پھٔہلیمٕتۍ۔پرانیٚو پۅ تلیٚو بجا ے میٖلۍ تِمن یِم نٔوۍ معبوٗد پوٗز ایہِ خٲطرٕ﴾"
  18,22,"۔کینٛہہ لُکھ وَنن زِ تِم ٲسۍ ترٚے تہٕ ژورِم اوس تِہُند ہوٗن، تہٕ کینٛہہ با قی وَنن زِ پا نژھ ٲسۍ تہٕ شییُم اوس تِہُند ہوٗن، یِم سٲر ی چِھ أچھ ؤٹِتھ کتھہٕ کران، بیٚیہِ کینٛہہ لُکھ چِھ ونان زِ ستھ ٲسۍ تہٕ ٲٹھِم اوس تِہُند ہوٗن ﴿ امہِ نِشہِ چُھ پے لگا ن زِ اَمہِ وا قعہ پتہٕ، دوٗن ترٚے ہتھ ؤرۍ ٲسۍ نزو لِ قرآن کِس زمانس منٛز امہِ کیٚن تفصیلا تن متعلق مختلف افسا نہٕ عیسا ین منٛز پھٔہلیمٕتۍ ،تہٕ عمو ماً ٲسۍ نہٕ لُکن نِشہِ مُستند معلو مات کینٛہہ۔ تاہم چُھنہٕ چو نکہ خُدا ین ترٛییٚمہِ کتھہِ ہُند تردید کوٚر مُت ، امہِ موجوٗب ہیکو گُمان کٔرِ تھ زِ صحیح تعداداوس سَتَے﴾ؤنِو ، میو ن ربّٕے چُھ بہتر زانان زِ تِم کٲتیاہ ٲسۍ،کمٕے لُکھ چِھ تِہُند صحیح تعداد زانان، پس سرسری کتھہِ کھۅتہٕ کھٔسِتھ مَہ کٔرِو یِہندِس تعداد کِس معا ملس منٛز لُکن سٍتۍ بحث،تہٕ نَہ مَہ پٕرٛژِھو یِمن متعلق کٲنٛسہِ کینٛہہ۔ ع﴿ مطلب چُھ یہِ زِ اصل چیز چُھنہٕ تِہُند تعداد کینٛہہ ،بلکہ چُھ اصل چیز تِم سبق یِم امہِ قصّہٕ نِشہِ میلان چِھ ﴾"
  18,23,"۔تہٕ وُچِھو ،کُنہِ چیز س متعلق مَہ ؤنِو زانٛہہ یہِ ،زِ بہٕ کرٕ پگا ہ یہِ کٲم۔﴿ یہِ چُھ جُملہ مُعتر ضَہ یُس پٔتِمہِ آیت کہ مضمو ن کہ منا سبتہٕ سلسلہ کلا مس منٛز با گ چُھ ارشاد فر ماو نہٕ آمُت۔ پٔتِمس آیتس منٛز اوس ہدایت دِنہٕ آمُت زِ اصحا بِ کہفن ہُند صحیح تعدا چُھ خُدا یس معلو م تہٕ امِیُک تحقیق کرُن چھےٚ غیر ضروری کٲم۔اتھ سِلسلس منٛز چُھ برونٹھِم کتھ ارشاد فر ماو نہٕ برونٛہہ جملہ معتر ضہ رٔنگۍ بیاکھ اکھ ہدایت تہِ نبی صلی اللہ علیہ وسلمس تہٕ اہلِ ایمانن دِنہٕ آمُت ،تہٕ سُہ چُھ یہِ زِ توٚہۍ ؤنۍ زیو نہٕ زانٛہہ دعویٰ سان زِ بہٕ کرٕ پگا ہ فلٲنۍ کٲم۔تۅہیہِ کیا خبر چَھوزِ توٚہۍہیٚکہِ وا سۅ کٲم کٔرِتھ تہِ کِنہٕ نہٕ۔﴾"
  18,24,"۔ ﴿توٚہۍ ہیٚکِو نہٕ کِہِنۍ کٔرِتھ﴾ اِلاّ یہِ زِ اللہ تعالیٰ ییٚژِھہ، اگر مشر پھہٕ کِنۍ یِژھ کتھ زیوِ نیرِ، تیٚلہِ کٔرِیوٗن فوراً پنُن ربّ یاد تہٕ ؤنِو اُمید چھےٚ زِ میو ن ربّ کرِ مےٚ اتھ معا ملس منٛز رٕژرٕ نِشہِ قر یب تر کتھہِ کُن رہنمٲیی۔"
  18,25,"۔تہٕ تِم روٗدۍ پننِس غارس منٛز ترٮ۪ن ہَتن ؤرِین، تہٕ ﴿کینٛہہ لُکھ چِھ مدّت کِس شُمارس منٛز﴾ 9 ،ؤری بیٚیہِ برونٛہہ پٔکِمٕتۍ۔"
  18,26,"۔توٚہۍ ؤنِو ،اللہ تعالیٰ چُھ تِہندِ قیامتٕچ مُدّت زیادٕہ زانان،﴿یعنی اصحابِ کہفن ہٕند تعدادٕکۍ پٲٹھۍ اگر تِہندِ س قیام کِس مُدّتس متعلق لُکن در میان اختلاف چُھ، مگر تۅہیہِ چَھو نہٕ اَتھ ژھٲنڈ دِنٕچ ضرورت۔اللہ تعالیٰ ہٕے چُھ بہتر زانان زِ تِم کٍتِس کا لس روٗدۍ اتھ حا لتس منٛز﴾ آسمانن تہٕ زمینٕکۍ سٲر ی پوشیدٕ ہ حال چِھ تٔسۍ معلو م، کوتاہ جان چُھ سُہ وُچھن وول تہٕ بوزن وول!، ﴿زمین و آسمان کیٚن مخلوقن ہُند﴾ چُھنہٕ تس ورٲے کانٛہہ خبر اَتر ہیٚنہٕ وول،سُہ چُھنہٕ پننِس حکو متس منٛز کٲنٛسہِ شر یک کران۔"
  18,27,"۔اے نبی صلی اللہ علیہ وسلم ،تُہندِس ربّ سٕنزِ کتا بہِ منٛز یِکینژھاہ تۅہیہِ پٮ۪ٹھ وَحی چُھ آمُت کر نہٕ سُہ﴿یِتھہٕ پٲٹھۍ چُھ تِتھے پٲٹھۍ﴾ بوزنٲوِو ، کانٛہہ چُھنہٕ تِمَکۍ فر مودات بدلا ونُک مجا ز،﴿تہٕ اگر توٚہۍ کٲنٛسہِ ہٕندِ خٲطرٕ اتھ منٛز ردو بد ل کٔرِ و تیٚلہِ ﴾ لٔبِو نہٕ تس نِشہِ بچِتھ ژلنہٕ خٲطرٕ کانٛہہ چَھپن جاے۔"
  18,28,"۔تہٕ پنُن پان کٔرِیوٗن تِمن لُکن سٍتۍ روزنس پٮ۪ٹھ مطمعین،یِم پننِس ربّ سٕندِ رضا ہٕکۍ طلب گار بٔنِتھ تس صُبحس تہٕ شا مس آلَو چِھ دِوان،تہٕ تِمن نِشہِ مَہ ڈٲلِو ہر گز نظر،کیا توٚہۍ چِھوٕ ہ دُنیا ہٕچ زینت پسند کر ان؟کٲنٛسہِ تِتھِس شخصہٕ سٕنز اطا عت مَہ کٔرِو ،ییٚمۍ سُند دل اسہِ پننہِ ذکر ﴿یاد کر نہٕ﴾ نِشہِ غٲفِل چُھ کوٚر مُت، ﴿ یعنی تٔمۍ سٕنز کتھ مَہ مٲنِو، تس برونٛہہ کنہِ مَہ نٔمِو ،تٔمۍ سٕنز مر ضی مَہ کٔرِو پوٗرٕ تہٕ تٔمۍ سٕندِ س وننس پٮ۪ٹھ مَہ پٔکِو۔یَتھ جایہِ چُھ اطا عتلفظ پننِس وسیع مفہو مس منٛز استعمال سپُد مُت﴾ تہٕ یُس پننہِ نفس چہِ خوٲہشہِ ہٕنز پیروی چُھ کران،تہٕ ییٚمۍ سُند طر یق کاریرٕ وٕنۍ ناوِ پٮ۪ٹھ مبنی چُھ۔"
  18,29,"۔صا ف ؤنِو زِ یہِ چُھ حق تُہندِس ربّ سٕندِ طر فہٕ، وۅ نۍ یُس ییژِھہ سُہ مٲنِتَن،تہٕ یُس نہٕ ییٚژِھہ سُہ کٔرِ تن انکار،اسہِ چُھ ﴿انکار کر ن والیٚن ﴾ظالمن خٲطرٕ اکھ نار تیار تھوو مُت، ییٚمہِ کیو لَمبکَو تِم گھیرس منٛز رٔٹِمٕتۍ چِھ ، تَتہِ اگر تِم تر یش منگن، تِمن یِیہِ تِتھہٕ آبہٕ سٍتۍ توا ضح کر نہٕ یُس پٔلِمہِ ہیوٗ آسہِ، تہٕ سُہ زالہِ تِمن ٲس،بد تر ین چینُک چیز تہٕ سٮ۪ٹھاہ بُرٕ آرام گاہ!"
  18,30,"۔روٗدۍ تِم لُکھ یِم مانن تہٕ کر ن نیک عملہٕ، تیٚلہِ چِھنہٕ أسۍ یقیناً نیکو  کار لُکن ہُند اجر ضا یع کران۔"
  18,31,"۔تِہندِ خٲطرٕ چِھ سدا بہا ر جنت،یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان،آ، تِم یِن سۅ ن سٕندِ یو کر یٚو سٍتۍ پٲروانہٕ۔﴿ پرٲنِس زمانس منٛز ٲسۍ بادشاہ سۅ ن سٕندۍ کٔرۍ لاگان۔اہلِ جنت کیٚن لبا سن منٛز امہِ چیزٕچ ذِکر کر نہٕ نِشہِ چُھ مقصد یہِ زِ تَتہِ یِن تِمن شا ہانہٕ لبا س لاگنہٕ۔ اکھ کٲفر تہٕ فا سق بادشاہ سپدِ تَتہِ ذلیل و خوار ،تہٕ اکھ مو من تہٕ صا لح موٚزوٗر روزِ تَتہِ با دشاہن ہٕندۍ پٲٹھۍ شان و شو کت سان۔﴾ تٔنۍ ریشم تہٕ اَطلس تہٕ دِیبَا ہٕکۍ سبز پلو لاگن، تہٕ تھد ٮ۪ن مسند ن پٮ۪ٹھ بیٚہَن تکیہِ لگٲوِتھ۔ بہتر ین اجر تہٕ تھدِ در جِچ روزن جاے! ع"
  18,32,"۔اے نبی صلی اللہ علیہ وسلم، تِمن برونٛہہ کنہِ کٔرِواکھ مثال پیش، زٕہ شخص ٲسۍ۔ یِمو منٛز دِتۍ اسہِ أکِس زٕہ دچھِ با غ، تہٕ تِمن أندۍ أندۍ لگٲو اَسہِ کھٔزر کُلیٚن ہٕنزٕ قطا رٕ، تہٕ تِمن در میان تھٲو کٲشتٕچ زمین۔"
  18,33,"۔دۅ شوے باغ پھوٚ لۍ تہٕ وۅ پد ے جان پٲٹھۍ، تہٕ بار آور سپد نس منٛز تھٲونہٕ تِمو کانٛہہ تہِ کسر  ،تِمن با غن منٛز با گ کٔر اسہِ اکھ نہر جٲر ی،"
  18,34,"۔تہٕ تس سپُد خوٗب نفع حٲصل،یہِ سورُے حٲصل کٔرِتھ ووٚن تٔمۍ اکہِ دۅہ پننِس ہمسایس کتھ کران کران ،بہٕ چُھس چا نہِ کھۅتہٕ زیادہ مالدار، تہٕ چانہِ کھۅتہٕ چَھم زیادہ طا قت ور نفر ی۔"
  18,35,"۔پتہٕ سپُد سُہ پننِس جنتس منٛز دٲخل، تہٕ پننہِ پان کِس حقس منٛز لوکُن ظٲلِم بٔنِتھ وَنُن،مےٚ چُھنہٕ باسان زِ یہِ دو لت سپدِ زانٛہہ فنا ، تہٕ مےٚ چُھنہٕ تو قع زِ قیامتٕچ گٔر کیا یِیہِ زانٛہہ،"
  18,36,"۔تٔمۍ سٕندۍ ہمساین ووٚن کتھ با تھ کران کران تس،"
  18,37,"۔کیا ژٕ چُھکھہٕ تس ذاتس سٍتۍ کُفر کران ییٚمۍ ژٕ گۅڈٕ میٚژِ نِشہِ تہٕ پتہٕ نُطفہٕ نِشہِ پٲدٕ کوٚرنکھ، تہٕ ژٕ کوٚرنکھ مکمل انسان بنٲوِتھ کھڑا؟"
  18,38,"۔؟وۅ نۍ روٗدُس بہٕ۔میو ن ربّ چُھ سُے اللہ تعالیٰ ،تہٕ بہٕ چُھسن نہٕ تس سٍتۍ کانٛہہ شر یک کران۔"
  18,39,"۔تہٕ ییٚلہِ ژٕ پننِس جنتس منٛز اَژان اوسُکھ، تیٚلہِ کیا زِ درٛا و نہٕ چانہِ زیٚوِ تمہِ ساعتہٕ یہِ زِ، ماشا اللہ لا قُو تہ اِلّا بِا للہ؟۔﴿یعنی یِکینژھاہ اللہ تعالیٰ ییٚژِھہ تی سپدِ،نَہ چھُ میون زور تہٕ نَہ چھُ بیٚیہِ کٲنسہِ ہُنٛد کانٛہہ زور،سون اگر کینٛہہ چٔلِتھ ہیٚکہِ سُہ ہیٚکہِ بس اللہ تعالیٰ سٕندِ تو فیق تہٕ تٲییدٕ سٍتۍ چٔلِتھ۔﴾اگر ژےٚ بہٕ مالس تہٕ اولادن منٛز چُھسَے ؤسۍ پایہِ باسان،"
  18,40,"۔تیٚلہِ چھنہٕ یہِ کتھ دوٗر زِ میو ن ربّ ہیکہِ مےٚ چانہِ جنت کھۅتہٕ بہتر عطا کٔرِتھ،تہٕ چٲنِس جنتس  پٮ۪ٹھ سوزِ آسمانہٕ کانٛہہ آفت،ییٚمہِ سٍتۍ سُہ صا ف مٲدان روزِ بٔنِتھ، یا وَسہِ تمِیُک آب زمینس اندر ﴿تہٕ خشک گژِھہ﴾،"
  18,41,"۔تہٕ پتہٕ ہیککھ نہٕ ژٕ سُہ کُنہِ پٲٹھۍ تہِ کٔڑِتھ۔ٲخرکار سپُد یہِ زِ تٔمۍ سُند سورُے میوٕ ہ آو تھپہِ نِنہٕ،تہٕ سُہ روٗد پننِس دچھہِ با غس پٮ۪ٹھ خرچاونہٕ آمتِس لا گتس پٮ۪ٹھ اتھہٕ موٗران،﴿تِکیازِ ﴾ با غ اوس پننیٚن ڈکھن پٮ۪ٹھ دُبہٕ پھیوٗرمُت،"
  18,42,"۔تہٕ وَننہٕ لوٚ گ زِ ، کا ش! مےٚ آسِہے نہٕ پننِس ربّس سٍتۍ کانٛہہ شریک ٹھہر و ومُت۔"
  18,43,"۔نَہ درٛایہِ تس اللہ تعالیٰ ترٲوِتھ کانٛہہ جما عت زِ تس کر ہے مدد، نہ ہیوٚ ک تٔمۍ اَمہِ آفتُک مقا بلہٕ کٔرِتھ۔"
  18,44,"۔تمہِ وقتہٕ لوٚگ پے زِ کا ر سٲزی ہُند اختیار چُھ خُدا ے بر حق سٕندی خٲطرٕ،انعام چُھ سُے بہتر یُس سُہ عطا کرِ تہٕ انجام چُھ سُے بخیر یُس سُہ ہاوِ ۔ ع"
  18,45,"۔تہٕ اے نبی صلی اللہ علیہ وسلم، یِم سمجھٲویوٗکھ دُنیا چہِ زند گی ہٕنز حقیقت ییٚمہِ مثالہِ سٍتۍ،زِ اَز ترٛوو اَسہِ آسمانہٕ روٗد،زمینُک دَرٛمُن تہٕ گا سہٕ وۅ پد یٚا و جان پٲٹھۍ گوٚن گوٚن، پگا ہ گوٚو أتھۍ درٛمنَس تہٕ گا سس بوٚ س، یَتھ ہوا چِھ اورٕ وُڑناوان۔اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  18,46,"۔یہِ مال تہٕ یِم اولاد چِھ محض دُنیٲوی زند گی ہٕنز اکھ ہنگٲمی آرٲیش﴿زینت﴾"
  18,47,"۔دراصل چھےٚ پتھ کُن روزن واجِنہِ نیکی تُہٕندِس ربّس نز دیک نتیجہِ کہ لحا ظہٕ بہتر، تہٕ یِمنٕے کُن یِن رٕژٕ اُمیدٕ وابستہٕ کرنہٕ۔"
  18,48,"۔فِکر گژِھ تمہِ دۅ ہٕچ آسٕنۍ ،ییٚلہِ أسۍ پہا ڑ چلا ووکھ، تہٕ توٚہۍ لٔبِیوٗن زمین بالکل نیٚتھہٕ نٔنۍ، تہٕ أسۍ کروکھ تمام انسان تِتھہٕ پٲٹھۍ گھیٖرِ تھ جمع زِ﴿ پٔتِمیو بروٗنٹھمیو منٛزٕ ﴾پیٚیہِ نہٕ اکھ تہِ۔تہٕ سٲری یِن اند ہیٚتھ تُہٕندِس ربّ سٕندِس در بارس منٛز صف در صف جمع کر نہٕ۔وُچِھتَو وۅ نۍ ٲو نا توٚہۍ اَسہِ نِشہِ تِتھے پٲٹھۍ یِتھہٕ پٲٹھۍ اَسہِ توٚہۍ گۅڈنِچہِ لٹہِ پٲدٕ ٲسِو کٔرِ مٕتۍ۔تۅہیہِ اوسُو سمجھمُت زِ اسہِ چُھنہٕ تُہندِ خٲطرٕ وعدُک کانٛہہ وقت مُقّر رٕے کوٚر مُت۔"
  18,49,"۔تہٕ نا مۂ اعمال یِیہِ برونٹھہٕ کنہِ تھاو نہٕ۔ تمہِ وقتہٕ وُچِھو توٚہۍ زِ مُجر م لُکھ آسن پننہِ زند گی ہٕنزِ کتا بہِ منٛز در ج کر نہٕ آمتیو چیز و نِشہِ کھۅژان،تہٕ ونان آسن زِ ہاے سٲنۍ بد قسمتی،یہِ کِژھ کتاب چھےٚ زِ سٲنۍ کانٛہہ لۅکٕٹ بٔڑ حر کت روٗزنہٕ تِژھ، یۅسہٕ نہٕ اتھ منز در ج آسہِ کر نہٕ آمٕژ۔یہِ یِکینژھاہ تِمو کوٚر مُت اوس تہِ سورُے لبَن پا نس برونٛہہ کنہِ حٲضر، تہٕ تُہُند ربّ کرِ نہٕ کٲنٛسہِ پٮ۪ٹھ ظُلم۔ع"
  18,50,"۔یاد کٔرِو،ییٚلہِ اسہِ فر شتن ووٚن زِ آدمس علیہ السلام کٔرِو سجدٕہ،تِمو کوٚر سجدٕہ مگر ابلیسن کوٚر نہٕ، سُہ اوس جِنو منٛزٕ امہِ موجو ب درٛا و پننِس ربّ سٕندِ حکم کہ اطاعت نِشہِ۔﴿یعنی ابلیس اوسنہٕ فر شتو منٛزٕ، بلکہ اوس جِنو منٛزٕ، اَمی موجو ب سپُد تٔمۍ سٕندِ خٲطرٕ اطاعت نِشہِ نیٚبرنیرُن ممکن۔فر شتو منٛزٕ ہرگاہ آسِہے ،تیٚلہِ ہیٚکہِ ہے نہٕ نا فر مٲنی کٔرِتھ۔اتھ برعکس چِھ جنّ انسانن ہٕندۍ پٲٹھۍ ذی اختیار مخلوق یِم پیدٲیشی طور فر مان بردار چِھنہٕ بناو نہٕ آمٕتۍ بلکہ چُھکھ کفرو ایمان تہٕ اطاعت و معصیّتُک دۅ شوٕ نۍ ہُند اختیار دِنہٕ آمُت﴾ وۅ نۍ کیا توٚہۍ چِھوٕ مےٚ ترٲوِ تھ سُہ تہٕ بیٚیہِ تٔمۍ سٕنز ذُرّیت پنٕنۍ سر پرست بناوان ،حالانکہ تِم چِھ تُہٕندۍ دُشمن؟ سٮ۪ٹھہٕے بُرٕ بد ل چُھ یتھ ظا لم لُکھ اختیار چِھ کران۔"
  18,51,"۔مےٚ ٲسۍ نہٕ آسمان تہٕ زمین پٲدٕ کر نہٕ وقتہٕ تِم ناددِتھ أنٕمٕتۍ،تہٕ نہ ٲسِم خۅد تِم تِہندِس تخلیقس منٛز شر یک کٔرِمٕتۍ۔ میٲنۍ کٲم چَھنہٕ یہِ زِ گُمراہ کران وٲلۍ آسکھ پنٕنۍ مددگار بناوان۔﴿مطلب چُھ یہِ زِ یِم شیطا ن کِتھہٕ پٲٹھۍ بنے تُہندِ اطا عتٕکۍ تہٕ بند گی ہٕندۍ حقدار؟بند گی ہُند حقدار ہیکہِ صرف خٲلِقٕے ٲسِتھ۔تہٕ یِمن شیطا نن ہُند حال چُھ یہِ زِ آسمان و زمین کِس تخلیقس منٛز شر یک سپدُن چھےٚ دوٗر کتھ ،یِم چِھ پانہٕ مخلو ق۔﴾"
  18,52,"۔پتہٕ کیا کر ن یِم لُکھ تمہِ دۅہ ییٚلہِ یُہُند ربّ یِمن وَنہِ زِ دِیوِ آلَو ۂستِین یِم تۅہیہِ میٲنۍ شر یک ٲسِیوٗکھ سمجھ مٕتۍ، یِم دِن تِمن آلو مگر تِم یِن نہٕ یِہندِس مددس،تہٕ أسۍ بناوَو یِمن منٛز باگ اَکُے مشتر کہٕ ہلا کتُک چاہ۔"
  18,53,"۔سٲری مجر م وُچَھن تمہِ دۅ ہ نار، تہٕ سمجھن زِ وۅ نۍ چُھ  تِمن اَتھ منٛز گژُھن، تہٕ تِم لبن نہٕ امہِ نِشہِ بچنہٕ خٲطرٕ کانٛہہ چھپن جاے۔ع"
  18,54,"۔اَسہِ سمجھٲوۍ یتھ قرآنس اندر لُکھ رنگہٕ رنگہٕ،مگر انسان سپُد سٮ۪ٹھہٕے لڑایہِ گوٚر ثٲبت۔"
  18,55,"۔تِمن برونٛٹھ کُن ییٚلہِ ہدایت ووت،اتھ ماننہٕ نِشہِ تہٕ پننِس ربّس  معٲفی منگنہٕ نِشہِ کٔمۍ چیز ن رُکٲوۍ ٲخر تِم ؟ اَمہِ ورٲے چُھنہٕ بیٚیہِ کینٛہہ زِ تِم چِھ انتظا رس زِ تِمن سٍتۍ تہِ گژِھہ تی کینژھا سپدُن یہِ پٔتِمیٚن قو من سٍتۍ چُھ سپُد مُت، یایہِ زِ تِم گژھن عذا بس برونٛہہ کُن واتان وُچِھنۍ!"
  18,56,"۔رسول چِھکھ نہٕ أسۍ امہِ کامہِ ورٲے بیٚیہِ کُنہِ غر ضہٕ خٲطرٕ سوزان زِ تِم دِن بشا رتٕکۍ تہٕ نہیب کر نٕکۍ خد مات انجام۔مگر کٲفر ن ہُند حال چُھ یہِ زِ تِم چِھ بٲطلٕکۍ ہتھیار ہیٚتھ حقس ؤسۍ پایہِ ہا و نٕچ کوٗشش کران،تہٕ تِمو چِھ میٲنۍ آیات تہٕ تِم نہیب یِم تِمن کر نہٕ آے مذا ق بنٲوِمٕتۍ۔"
  18,57,"۔تہٕ تس شخصس کھۅتہٕ بوٚڈ ظٲلِم کُس چُھ، یس تٔمۍ سٕندِس ربّ سٕندۍ آیات بوزنٲوِتھ نصیحت یِیہِ کر نہٕ، تہِٕ سُہ پھِرِ تِمو نِشہِ بُتھ،تہٕ مٔشراوِ سُہ بُرٕ انجام ییٚمیُک انتظام تٔمۍ پننہِ خٲطرٕ خۅد پننیٚو اَتھو چُھ کوٚرمُت؟﴿یِمو لُکو یہِ رٔوِش اختیار چھےٚ کٔرمٕژ﴾ تِہندٮ۪ن دِلن پٮ۪ٹھ چھےٚ اَسہِ غلا فہٕ کھا جِمژٕ، یِمہٕ تِمن قرآنٕچ کتھ چَھنہٕ سمجھنہٕ دِوان ،تہٕ تِہندٮ۪ن کنن چُھ اسہِ گۅبٚیر پٲدٕ کوٚر مُت۔توٚہۍ دِیتَو ہدا یتس کُن تِمن کوتاہ تہِ ناد، تِم لبن نہٕ اتھ حالتس منٛز زٕ ہٕنۍ ہدایت۔"
  18,58,"۔تُہُند ربّ چُھ بوٚڈ مغفرت کر ن وول تہٕ رحمت وول۔ اگر سُہ تِمن تِہندٮ۪ن کرتوٗتن پٮ۪ٹھ رَٹُن ییٚژِھہ ہے،تیٚلہِ سوزِ ہے تِمن جلد ی عذا ب۔مگر تِہندِ خٲطرٕ چُھ وعدُک اکھ وقت مُقّرر،تہٕ تمہِ نِشہِ بٔچِتھ لبن نہٕ تِم ژلنٕچ کانٛہہ وَتھ۔"
  18,59,"یِمہٕ عذا ب دِنہٕ آمژٕ، بٔستیہِ چھےٚ تۅہیہِ برونٛہہ کنہِ موجو د ۔تِمو ییٚلہِ ظُلم کوٚر ، اَسہِ کٔرۍ تِم ہلاک،تہٕ تِمو منٛزٕ اوس پرٛتھ کٲنٛسہِ خٲطرٕ اسہِ ہلا کتُک وقت مُقّر کوٚر مُت۔ع ﴿یِمن ؤنۍ تَو سُہ قصّہٕ یُس موسیٰ علیہ السلامس پیش اوس آمُت﴾"
  18,60,"۔ییٚلہِ موسیٰ ﴿علیہ السلامَن﴾ پننِس خٲدِمَس ووٚن زِ، بہٕ مۅکلاو نہٕ پنُن سفر، یوٚت تام نہٕ بہٕ دۅ ن دریاون ہٕندِس سنگمس پٮ۪ٹھ واتہِ، نَتہٕ روزٕ بہٕ أکِس زیٖٹھِس وقتس تام لگاتار پکان۔﴿کُنہِ مُستند  ذریعہ نِشہِ چُھنہٕ یہِ معلو م سپُد مُت زِ حضرت موسیٰ علیہ السلامن ہُند یہِ سفر کتھ زمانس منٛز اوس پیش آمُت،تہٕ تِم زٕ ہ دریاو کم ٲسۍ یِہندِس سنگمس پٮ۪ٹھ یہِ واقعہ پیش آو۔مگر ییٚلہِ قصّس پٮ۪ٹھ غور چِھ کران تیٚلہِ چُھ باسان زِ یہِ چُھ تمہِ وقتُک وا قعہ ییٚلہِ موسیٰ علیہ السلام مِصرس منٛز ٲسۍ تہٕ فر عو نس سٍتۍ ٲس تِمن کشمکش چلان،تہٕ دۅ یَو در یاوَو نِشہِ چُھ مُراد،نیلِ اَز رق تہٕ نیلِ اَبیض، یِہندِ س سنگمس پٮ۪ٹھ موجودٕہ شہر خرطوم چُھ بٔسِتھ۔امہِ قیا س کیٚن وجوہا تن پٮ۪ٹھ چُھ اسہِ تفصیلی بحث تفہیمُ القرآن، جلد سو م تفسیر سورۂ کہفس اندر کوٚر مُت﴾"
  18,61,"۔پس ییٚلہِ تِم تِہندِس سنگمس پٮ۪ٹھ وٲتۍ،پنٕنۍ گاڈ گٔیکھ مٔشِتھ، تہٕ سۅ گٔیہِ نِیٖرِتھ تِتھہٕ پٲٹھۍ در یاوس منٛز زنتہٕ کانٛہہ سُر نگ لٲگِتھ ٲس﴿تمی مٔنٛزۍ ژٔج﴾"
  18,62,"۔برونٛہہ پٔکِتھ چِھ موسیٰ علیہ السلام پننِس خٲدمس ونان،اَن سَہ سو ن نا شتہٕ،أزِ کِس سفرس منٛز چِھ أسۍ وُلٹہٕ پٲٹھۍ تھٔکِمٕتۍ۔"
  18,63,"۔خٲدم چُھ ونان تۅہیہِ وُچھوٕ ہ ! یہِ کیا سپُد؟ییٚلہِ أسۍ تَتھ پلس نِشہِ ٹھٔہرِتھ ٲسۍتمہِ ساعتہٕ روٗد نہٕ مےٚ گاڈِ ہُنٛد خیال، تہٕ شیطا نن کوٚر نس بہٕ تِتھہٕ پٲٹھۍ غٲفِل زِ مےٚ گٔیہِ ﴿تۅہیہِ نِشہِ ﴾ امِچ ذِکر کرٕنۍ مٔشِتھ۔گاڈ درٛا یہِ عجیب پٲٹھۍ تہٕ ؤژھ در یاو س"
  18,64,"۔موسیٰ علیہ السلام چِھ وناناَمہِ کُے اوس اسہِ تلا ش۔ ﴿یعنی منٛزلِ مقصودُک اوس یۅہے نیب وَننہٕ آمُت۔﴾ چنا نچہِ تِم دۅ شوٕے دراے پننیٚن قد من ہٕند یٚن نِشٲنن پٮ۪ٹھ واپس۔"
  18,65,"۔تہٕ تَتہِ لوٚب تِمو سانیٚو بندو منٛزٕ اکھ بندہ،یُس اَسہِ پننہِ رحمت سٍتۍ نَو وز مُت اوس،تہٕ پننہِ طر فہٕ اوس تس اکھ خا ص علم عطا کوٚر مُت۔﴿تمام معتبر حدیثن منٛز چُھ تس بندٕہ سُند ناو خضر وَننہٕ آمُت﴾۔"
  18,66,"۔موسیٰ علیہ السلام چِھ تس ونانکیا بہٕ ہیٚکا تۅہیہِ سٍتۍ روٗزِتھ،تاکہ توٚہۍ دِیو میٚتہِ تمہِ دٲنِش مند ی ہٕنز تعلیم یۅسہٕ ہیٚچھنا و نہٕ چِھو آمٕتۍ؟"
  18,67,"۔تٔمۍ دِیُت جواب ، توٚہۍ ہیکِو نہٕ مےٚ سٍتۍ صبر کٔرِتھ،ٲخرکِتھہٕ پٲٹھۍ ہیٚکوِ ۍ توٚہۍ تتھ پٮ۪ٹھ صبر کٔرِتھ،"
  18,68,"۔ییٚمہِ چیزٕ چ تۅہیہِ خبرٕ ے آسہِ نہٕ؟"
  18,69,"۔موسیٰ علیہ السلام چِھ ونان  ان شا اللہ لٔبِو توٚہۍ مےٚ صٲبر،تہٕ بہٕ کر نہٕ کُنہِ معا ملس منٛز تُہٕنز نا فر مٲنی۔"
  18,70,"۔تٔمۍ ووٚن اچھا ، اگر تۅہیہِ مےٚ سٍتۍ پکُن چُھو، تیٚلہِ پٕرٛژھۍ زیٚو نہٕ مےٚ کانٛہہ کتھ،یوٚت تام نہٕ بہٕ پانہٕ تمِچ ذکر تۅہیہِ نِش کرٕ۔ع"
  18,71,"۔وۅ نۍ سپٕدۍ تِم دۅ شوے روانہٕ یوٚت تام زن تِم أکِس ناوِ کٔھتۍ،تٔمۍ شخصن کوٚر ناوِ گوٚد، موسیٰ علیہ السلام چِھ ونان تۅہیہِ کوٚرُویتھ ناوِگوٚدتاکہ کہ سٲری سوار ڈُبٲوِیوٗکھ؟ یہِ کٔرٕو تۅہیہِ اکھ سخت حر کت۔"
  18,72,"۔سُہ چُھ ونان مےٚاوسمے ناژےٚ ووٚنمُت زِ ژٕ ہیکُکھ نہٕ مےٚسٍتۍ صبر کٔرِتھ؟"
  18,73,"۔موسیٰ علیہ السلام چِھ ونان بُل چُکِس پٮ۪ٹھ مَہ رٔٹِو مےٚ، میٲنِس معاملس منٛز مَہ ہیٚیِو توٚہۍ سختی کٲم۔"
  18,74,"۔پتہٕ پٔکۍ تِم دۅ شو ے ،یوٚت تام زن تِمن اکھ لڑکہٕ میوٗل،تہٕ تٔمۍ کوٚر سُہ قتل، موسیٰ علیہ السلام چِھ ونان تۅہیہِ کوٚروٗن اَکھ بے گنا ہ قتل،حالانکہ تٔمۍ اوس نہٕ کٲنٛسہِ ہُند قتل کوٚر مُت؟ یہِ کٲم کٔرٕ و تۅہیہِ سٮ۪ٹھہٕے بُرٕ۔"
  18,75,"۔تٔمۍ ووٚن مےٚ اوسمے نا ژےٚ ووٚنمُت زِ ژٕ ہیککھ نہٕ مےٚ سٍتۍ صبر کٔرِتھ،"
  18,76,"۔مو سیٰ علیہ السلام چِھ ونان ییٚمہِ پتہٕ اگر بہٕ تۅہیہِ کینٛہہ پٕرٛژَھو، تیٚلہِ رٔٹۍ زیوٚ نہٕ توٚہۍ مےٚ پا نس  سٍتۍ، رٔٹۍ تَو ،وۅ نۍ میوٗلُو تۅہیہِ میانہِ طر فہٕ عُذر۔"
  18,77,"۔پتہٕ پٔکۍ تِم برونٛہہ یوٚت تام أکِس بستی منٛز وٲتۍ، تہٕ تمہِ کیٚن لُکن موٚنگُکھ کھیٚن،مگر تِمو کوٚر تِمن دۅ شوٕنۍ ہٕندِ ضیا فتہٕ نِشہِ انکار،تَتہِ وُچھِ تِمو اکھ دیوار، یُس ؤسِتھ اوس ہیٚوان پیٚون، تٔمۍ شخصن کوٚر سُہ دیوار بیٚیہِ کھڑا، موسیٰ علیہ السلام چِھ ونان  اگر توٚہۍ ییژِھہ ہِو ، اَتھ پٮ۪ٹھ ہیٚکہِ ہِو توٚہۍ یِمن اُجر ت ہیٚتھ۔"
  18,78,"۔تٔمۍ ووٚن  بس چو ن تہٕ میو ن ساتھ سپُد ختم، وۅ نۍ وَنے بہٕ ژےٚ تِمن کتھن ہٕنز حقیقت یِمن پٮ۪ٹھ ژےٚ صبر ہیوٚکُتھ نہٕ کٔرِ تھ۔"
  18,79,"۔ تمہِ ناوِ ہُند معا ملہٕ چُھ یہِ زِ سۅ ٲس کینژھن غر یب نفر ن ہٕنز، یِم دریاوس منٛز محنت موٚزوٗرۍ ٲسۍ کران ،مےٚ یوٚژھ  زِسۅ بناو ن عٲب دار،تِکیازِ برونٛہہ کُن اوس تِتھِس أکِس بادشاہ سُند علا قہٕ،یُس پرٛتھ ناوِ اوس زبردستی تھپھ دِتھ نِوان۔"
  18,80,"۔روٗد وۅ نۍ سُہ لڑ کہٕ ،تٔمۍ سٕندۍ والد ین ٲسۍ مو من،اسہِ با سیو و زِ یہِ لڑ کہٕ کرِ پننہِ سر کشی تہٕ کُفرٕ کِنۍ تِمن تنگ،"
  18,81,"۔امہِ موٗجو ب یٚوژھ اسہِ زِ تِہُند ربّ گژِھہ تِمن تس بد لہٕ تِیُتھ اولادِیُن،یُس اخلا قس منٛز تہِ تٔمۍ سٕندِ کھۅتہٕ بہتر آسہِ تہٕ یس نِشہِ صلۂ رحمی ہُند تہِ زیادہ تو قع آسہِ۔"
  18,82,"۔تہٕ ییٚمہِ دیوارُک معا ملہٕ چُھ یہ زِ یہِ چُھ دۅ ن یتیم لڑ کن ہُند، یِم یتھ شہرس منٛز روزان چِھ ، اَتھ دیوارس تلہٕ کنہِ چُھ یِمن بچن خٲطرٕ اکھ خزانہٕ دفن، تہٕ یِہُند مو ل اوس اکھ نیک انسان، اَمہِ موجوٗب یٚوژھ چٲنۍ ربّن زِ یِم دۅ شو ے بچہِ گژھن با لغ گژٕھنۍ،تہٕ پنُن خزا نہٕ کڑٕنۍ، یہِ چُھ چٲنِس ربّ سٕندِس رحمت کِس بنیا دس پٮ۪ٹھ کر نہٕ آمُت، مےٚ چُھنہٕ پننہِ اختیارٕ کِہِنۍ کوٚر مُت۔یہِ چھےٚ حقیقت تِمن کتھن ہٕنز یِمن پٮ۪ٹھ ژےٚ صبر ہیوٚ کُتھ نہٕ کٔرِ تھ۔﴿یتھ قصّس منٛز چھےٚ یہِ کتھ وا ضح زِ حضرتِ خضر ن یِمہٕ ترٛے کامہِ کرِ ، تِمہٕ آسہٕ اللہ تعالیٰ سٕندی حُکمہٕ ،مگر یہِ کتھ تہِ چھےٚ وا ضح زِ یِمن منٛز آسہٕ گۅڈٕ نِچہِ زٕ ہ کامہِ تِژٕھ یُہُند اجازت اللہ تعالیٰ سٕندِس سوزنہٕ آمتِس کُنہِ شر یعتس منٛز کٲنٛسہِ انسانس زانٛہہ چُھنہٕ دِنہٕ آمُت۔ حتیٰ کہ اِفہا م کِس بنیادس پٮ۪ٹھ تہِ چُھنہٕ کانٛہہ انسا ن اَمِیُک مجا ز زِ کٲنٛسہِ ہٕنزِ ناوِ کرِ اتھ بنیا دس پٮ۪ٹھ خراب زِ برونٛہہ پٔکِتھ نِیہِ تس کانٛہہ غٲصب سۅ تھپھ دِتھ، تہٕ کٲنٛسہِ لڑ کس کرِ امہِ موجو ب قتل زِ بوٚڈ گٔژِھتھ چُھ سُہ سر کش تہٕ کا فر سپدن وول۔امہِ موجو ب چُھنہٕ یہِ ماننہٕ ورٲے کانٛہہ چار ے زِ حضر ت خضر ن کرِ نہٕ یِمہٕ کامہِ احکام شر یعت کِس بنیا دس پٮ۪ٹھ، بلکہ آسن احکام مشیت کِس بنیا دس پٮ۪ٹھ کرِ مَژٕ تہٕ یِژھن کامیٚن خٲطرٕ چُھ اللہ تعالیٰ انسانَو ورٲے بیٚیہِ قٔسمہٕ کیٚن مخلو قن کٲم ہیٚوان۔قٕصہ کہ نو عیت نِشی چُھ یہِ ظٲہر سپدان زِ خُدا ین ٲسۍ حضرت موسیٰ علیہ السلام پننِس أمِس بند س نِشہِ امہِ غر ضہٕ سوٗزِ مٕتۍ زِ پردٕہ تُلِتھ ہاوَن تِمن اکہِ نظرٕ زِ یتھ مشیت کِس کار خانس منٛز کمو مصلحتو مطٲبق  چھےٚ کٲم سپدان، تہٕ یِم مصلحتہٕ ہیکہِ نہٕ انسان سمجِھتھ۔صرف اتھ بُنیا دس پٮ۪ٹھ زِ خُدا ین چُھ حضر ت خضر سٕندِ خٲطرٕ بندٕہ استعمال کوٚر مُت چُھنہٕ تِمن انسان قرار دِنہٕ خٲطرٕ کٲفی۔سورۂ انبیا آیت 26،سورۂ زُخرُف آیت 19، تہٕ واریاہن جا ین چُھ فر شتن خٲطرٕ تہِ یہِ لفظ وَرتاو نہٕ آمُت ﴾۔ع"
  18,83,"۔اے نبی ﴿صلی اللہ علیہ وسلم﴾یِم لُکھ چھِو تۅہیہِ ذوالقرنینس متعلق پٕرژھان ، یِمن ؤنِو ، بہٕ بوزنا وَو توٚہۍ تٔمۍ سُند کینٛہہ حال۔"
  18,84,"۔اسہِ اوس تس زمینس منٛز اقتدار عطا کوٚر مُت، تہٕ تس ٲسۍ پرٛتھ قسمٕکۍ اَسباب تہٕ وَسٲیل بخشمٕتۍ۔"
  18,85,"۔ تٔمۍ کوٚر ﴿گۅڈٕ ہ مغربس  کُن اکہِ مُہِمہِ ہُند ﴾ سَنٛز۔"
  18,86,"۔یوٚت تام زن سُہ آفتا ب لو سنہٕ چہِ جایہِ تام ووت ﴿یعنی مغر ب کِس ٲخر ی سرحدس تام ﴾ تٔمۍ وُچھ آفتا ب أکِس کِرٛہِنس آبس منٛز لو سان﴿ یعنی تَتہِ اوس آفتا ب لوسنہٕ وِزِ با سان زِ آفتا ب چُھ سمندر کِس سیٲہی مٲیل آبس منٛز ڈُبان﴾ تہٕ تَتہِ میوٗل تس اکھ قو م، اَسہِ ووٚن  اے ذُو القر نین، ژےٚ چھی یہِ اختیار تہِ حٲصل زِ ژٕ ہیٚککھ یِمن تکلیف واتنٲوِتھ، بیٚیہِ یِتہِ زِ ژٕ ہیٚککھ یِمن سٍتۍ نیک سلو ک کٔرِتھ"
  18,87,"۔تٔمۍ ووٚن  یُس تِمو منٛزٕ ظُلم کرِ،أسۍ دِمَو تس سزا، پتہٕ یِیہِ سُہ پننِس ربّس کُن واپس اَننہٕ،تہٕ سُہ دِیہِ تس بیٚیہِ زیادہ سخت عذاب۔"
  18,88,"۔تہٕ یُس تِمَو منٛز ایمان اَنہِ تہٕ نیک عمل کرِ،تس خٲطرٕ چُھ رُت جزا، تہٕ ٲسۍ دِمَو تس نر م احکام ۔"
  18,89,"۔پتہٕ کٔر تٔمۍ ﴿اکہِ دوٚیِمہِ مُہمہِ ہٕنز ﴾ تیٲری۔"
  18,90,"۔یٚوت تام زن سُہ آفتا ب کھسنہٕ چہِ جایہِ تام ووت ۔ ﴿ یعنی مشر ق کِس ٲخر ی سرحدس تام﴾ تَتہِ وُچھ تٔمۍ زِ آفتا ب چُھ تِتھس أکِس قو مس پٮ۪ٹھ  طلو ع سپدان، یتھ خٲطرٕ تاپہٕ نِشہِ بچنہٕ مۅ کھہٕ کانٛہہ سامانہٕ چُھنہٕ اسہِ کوٚر مُت۔"
  18,91,"۔یہِ حال اوس تِہُند ،تہٕ ذُولقرنینس نِشہِ یِکینژھاہ اوس سُہ ٲسۍ أسۍ زانان۔"
  18,92,"۔پتہٕ کوٚر تٔمۍ ﴿بیٚیہِ اکہِ مُہمہِ ہُند﴾ بندوبست۔"
  18,93,"۔یٚوت تام زن سُہ دۅ ن پہاڑن منٛز باگ ووت، یِمن نِشہِ میوٗل تس اکھ قو م، یُس مُشکلی سان کانٛہہ کتھ سمجھان اوس۔"
  18,94,"۔تِمو لُکو ووٚن زِ  اے ذوالقر نین، یا جو ج تہٕ ماجو ج چِھ یتھ سر زمینس اندر فساد پھٔہلاوان،﴿یا جو ج تہٕ ماجو ج نِشہِ چُھ مُراد، ایشا کیٚن شمال مشر قی علا قن ہٕندۍ تِم قو م، یِم پرانہِ زمانہٕ پٮ۪ٹھے تہذیب یا فتہٕ مُلکن پٮ۪ٹھ برباد کروٕ نۍ حملہٕ چِھ روٗدِمٕتۍ کران ،تہٕ یِہِندۍ سہلاب وقتاً فوقتاً وۅ تِلِتھ ایشا ہس تہٕ یوٗرپس دۅ شوٕ نۍ طر فن رۅ خ چِھ روٗدِمٕتۍ کران۔حز قی ایل سٕندِس صحیفس ﴿باب 39،38﴾ منٛز چُھ تِہُند علا قہٕ روس تہٕ تو بل﴿موجودٕہ تو با لسک﴾ تہٕ مسک ﴿موجودٕہ ماسکو﴾ وَننہٕ آمُت۔اسرا یلی مورِخ یو سیفوس چُھ یِمَو نِشہِ چُھ مُراد سیتھین قو م نِوان ، یُہُند علا قہٕ بحرِ اَسود کِس شما لس تہٕ مشر قس منٛز بٔسِتھ اوس۔ جیر وم سٕندِ بیان مطٲبق ٲسۍ ماجو ج کا کیشیا کِس شمالس منٛز بحرِ خَزَرس نکھہٕ بٔسِتھ۔﴾ کیا أسۍ دِمو یہِ ژےٚ امہِ کامہِ خٲطرٕ کانٛہہ ٹیکس، تاکہ ژٕ بنا وکھ اَسہِ تہٕ تِمن منٛز با گ اکھ دیوار؟"
  18,95,"۔تٔمۍ ووٚن یِکینژھاہ میٲنۍ ربّن مےٚ دِیتمُت چُھ سُہ چُھ سٮ۪ٹھاہ، توٚہۍ کٔرِ و بس محنتہٕ سان مےٚ مدد، بہٕ بناوٕ تۅہیہِ تہٕ تِمن در میان مضبو ط ٹھوٚر۔"
  18,96,"۔مےٚ دِیِو شستٕر ژادٕر﴿پٔٹۍ﴾ أنِتھ۔ ٲخر ییٚلہِ دۅ شوٕ نۍ پہا ڑن در میان تٔمۍ خٲلی جا ے برابر کٔر، تہٕ وونُن لُکن زِ وۅ نۍ زٲلِو نار، یوٚت تام زن ﴿یہِ شِستُر و دیوار﴾ بالکل نارٕکۍ پٲٹھۍ وۅزُل کر نہٕ آو، پتہٕ ووٚن تٔمۍ  أنِو ،وۅ نۍ پھِرٕ بہٕ اتھ پٮ۪ٹھ ویگلو و مُت ترٛام۔ ﴿یہِ دیوار اوس تِیُتھ زِ ﴾"
  18,97,"۔یا جو ج و ماجو ج ہیٚکہَن نہٕ اتھ پٮ۪ٹھ کھٔسِتھ تہٕ برونٛہہ پٔکِتھ، تہٕ اتھ منٛز نقب لگا و ن اوس تِہِند خٲطرٕ وارے مُشکل۔"
  18,98,"۔ ذُوالقرنینن ووٚن  یہِ چھےٚ میٲنِس ربّ سٕنز رحمت،مگر ییٚلہِ میٲنِس ربّ سٕندِ وعدُک وقت یِیہِ ،تیٚلہِ کرِ سُہ تتھ ہموار، تہٕ میٲنِس ربّ سُند وعدہ چُھ بر حق۔"
  18,99,"۔ تہٕ تمہِ دۅ ہ ترا ووکھ أسۍ لُکھ یَلہٕ ﴿مُراد چُھ قیامتُک دۅ ہ۔ ذو القرنین یُس اشارٕہ قیامت کِس بر حق وعدس کُن کوٚر تمہِ کہ مُنا سبت چِھ یِم آیا ت تٔمۍ سٕنزِ کتھہِ پٮ۪ٹھ اِضا فہٕ کران کران فر ماو نہٕ آمٕتۍ﴾ زِ ﴿ سمندر چن لہر ن ہٕندۍ پٲٹھۍ﴾ یِن اکھ أکِس سٍتۍ ٹا سوَ نہٕ، پتہٕ یِیہِ صوٗرس پھۅ کھ دِنہٕ، تہٕ أسۍ کروکھ سٲری انسان یِکہٕ وَٹہٕ جمع۔"
  18,100,"۔ تہٕ سُہ دۅ ہ آسہِ ییٚلہِ أسۍ جہنم اَنو ن کٲفر ن برونٛہہ کُن،"
  18,101,"۔تِمن کٲفر ن یِم میٲنِس نصیحتس کُن أنۍ بٔنِتھ ٲسۍ، تہٕ کینٛہہ بوزنہٕ خٲطرٕ ٲسۍ نہٕ تیارٕ ے ۔ ع"
  18,102,"۔کیا تیٚلہِ چھا تِم لُکھ یِمو کُفر چُھ اختیار کوٚر مُت، یہِ خیال تھاوان زِ مےٚ ترٲوِتھ بناوَن میا نیٚن بند ن پنٕنۍ کار سا ز؟ اسہِ چُھ یِتھیٚن کٲفر ن ہٕندِ ضیا فت خٲطرٕ جہنم تیار تھوومُت۔"
  18,103,"۔اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو، کیا أسۍ وَنوٕ ہ تۅہیہِ زِ پننیٚن اعما لن منٛز کم لُکھ چِھ سارِوٕے کھۅتہٕ نا کام تہٕ نا مُراد؟"
  18,104,"۔تِم یِہٕنز سٲرِ ے جدو جہد دُنیا چہِ زند گی منٛز سیٚزِ وتہِ نِشہِ ڈٔلِتھ روٗز، تہٕ تِم روٗدۍ سمجھان زِ تِم چِھ سورُے کینٛہہ ٹھیک کران۔"
  18,105,"۔یِم چِھ تِم لُکھ یِمو پننِس ربّ سٕندۍ آیات ماننہٕ نِشہِ انکار کوٚر، تہٕ تٔمۍ سٕندِس در بارس منٛز پیش سپد نس کوٚرُکھ نہٕ یقین، امہِ موجو ب سپٕدۍ تِہندۍ اعمال ضا یع۔"
  18,106,"۔تِہُند جزا چُھ جہنم، تمہِ کُفر کہ بد لہٕ یُس تِمو کوٚر، تہٕ تَتھ مذا ق کِس پا داشس منٛز یُس تِم میٲنیٚن آیاتن تہٕ میانیٚن رسولن سٍتۍ کران روٗدۍ۔"
  18,107,"۔البتہ تِم لُکھ یِمو ایمان اوٚن تہٕ یِمو نیک عملہٕ کرِ،تِہنزِ میز بٲنی خٲطرٕ آسن فِردو سٕکۍ با غ،"
  18,108,"۔یِمن منٛز تِم ہمیشہ روزن، تہٕ تمہِ جایہِ نیرِتھ کُنہِ جایہِ گژھنس یِیہِ نہٕ تِمن وۅ ند ے۔"
  18,109,"۔اے نبی صلی اللہ علیہ وسلم ، ؤنِو زِ اگر سمندر میٲنِس ربّ سٕنزٕ کتھہٕ لھیٚکھنہٕ خٲطرٕ روشنٲ یی ﴿ میٖل ﴾بنہِ، سُہ گژِھہ ختم مگر میٲنِس ربّ سٕنزٕ کتھہٕ گژھن نہٕ ختم، بلکہ اگر أسۍ بیٚیہِ ییٖژھا ہ روشنٲیی اَنَو، تیٚلہِ پوشہِ نہٕ سۅ تہِ۔ ﴿اللہ تعالیٰ سٕنز و  کتھو  نِشہِ چُھ مُراد تٔمۍ سٕنزٕ کامہِ تہٕ کمالات، بیٚیہِ قدرتٕکۍ تہٕ حکمتٕکۍ عجا یبا ت﴾"
  18,110,"۔اے نبی صلی اللہ علیہ وسلم، ؤنِو زِ بہٕ چُھس اکھ انسان تۅہیہ ہِیوٗ، مےٚ کُن چھےٚ وحی یِوان کر نہٕ زِ تُہُند خُدا چُھ بس اَکوے خُدا ے، لہٰذا یُس کانٛہہ اکھا ہ پننِس ربّ سٕندِ ملا قتُک اُمیدوار آسہِ ، تس پزِ سُہ کٔرِن نیک عمل، تہٕ بند گی منٛز مَہ کٔرِن پننِس ربّس سٍتۍ کٲنٛسہِ شر یک ۔ع"
