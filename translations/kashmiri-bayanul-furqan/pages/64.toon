quran[18]{c,v,t}:
  64,1,"۔اللہ تعالیٰ سٕنز تسبیح چُھ کران پرٛتھ سُہ چیز یُس آسمانن منٛز چُھ، تہٕ پرٛتھ سُہ چیز یُس زمینس منٛز چُھ۔ تٔمۍ سٕنزٕ ے چھےٚ باد شٲہی تہٕ تٔسۍ خٲطرٕ چُھ حمد، تہٕ سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ قدر ت تھا وان۔ ﴿یعنی سُہ چُھ قادرِ مطلق یِکینژھاہ کرُن ییٚژِھہ تہِ ہیٚکہِ کٔرِ تھ۔کانٛہہ طا قت چُھنہٕ تٔمۍ سٕندِس قد رتس محد دو کر ن وول۔﴾"
  64,2,"۔سُے چُھ ییٚمۍ توٚہۍ پٲدٕہ کٔرِ نَو، پتہٕ چُھ تۅہیہِ منٛزٕ کانٛہہ کٲفر تہٕ کانٛہہ چُھ مو من ، تہٕ اللہ تعالیٰ چُھ تہِ سورُے کینٛہہ  وُچھان یہِ توٚہۍ کران چِھو۔"
  64,3,"۔تٔمۍ چھےٚ زمین تہٕ سٲری آسمان بر حق پٲدٕ کٔرِ مٕتۍ، تہٕ تُہٕنز صورت بنٲو تٔمۍ، تہٕ سۅ بنٲوٕ ن سٮ۪ٹھاہ جان ، تہٕ تٔسۍ کُن چُھو تۅہیہِ ٲخر کار واپس پھیرُن۔"
  64,4,"۔زمین تہٕ آسمانن ہٕنٛدٮ۪ن تمام چیز ن ہُنٛد چُھ تس علم، یِکینٛژھاہ توٚہۍ چُھپا وان چِھو تہٕ یِکینژھاہ توٚہۍ ظٲہر چِھو کران۔﴿بیاکھ تر جمہٕ ہیٚکیس یِتہِ ٲسِتھ زِ "" یِکینژھاہ توٚہۍ ژھا یہِ پٲٹھۍ چِھو کران تہٕ یِکینژھاہ نَنہِ وانہٕ چِھو کران ۔ "" ﴾ سورُے چُھ تس معلو م ، تہٕ سُہ چُھ دِلن ہُند حال تام زانان۔"
  64,5,"۔ کیا تۅہیہِ نِشہِ وٲژنا تِمن لُکن ہٕنز کانٛہہ خبر  یِمو ییٚمہِ برونٛہہ کُفر کوٚر، تہٕ پتہٕ وُچُھکھ پننیٚن عملن ہٕندِ شہمتُک مزٕہ؟ تہٕ برونٛہہ کُن چُھ تِہندِ خٲطرٕ اکھ دگ تُلہٕ وُن عذاب۔"
  64,6,"۔اَمہِ انجا مٕکۍ حقدار سپٕدۍ تِم اَمہِ موجو ب زِ تِمن نِشہِ روٗدۍ تِہندۍ رسول  ٹا کارٕ ہ دلیلہٕ تہٕ نِشٲنیہِ ہیٚتھ یِوان ، مگر تِمو ووٚن "" کیا انسان دِنہٕ اَسہِ ہدایت؟"" تہٕ یِتھہٕ پٲٹھۍ کوٚر تِمو ماننہٕ نِشہِ انکار تہٕ پُھیٚرُکھ بُتھ، پتہٕ سپُد اللہ تعالیٰ تہِ تِمن نِشہِ بے  پرواہ ، تہٕ اللہ تعالیٰ چُھ بے نیاز تہٕ پننِس ذاتس منٛز چُھ پانہٕ محمو د۔"
  64,7,"۔مُنکر و چُھ سٮ۪ٹھاہ دعویٰ سان ووٚ نمُت زِ تِم یِن نہٕ مَر نہٕ پتہٕ ہر گز دُبارٕہ تُلنہٕ۔ یِمن ؤنِو"" نَہ میٲنِس ربّ سُند قسم توٚہۍ یِیِو ضرور تُلنہٕ،﴿یتھ جایہِ چُھ یہِ سوال وۅ تھا ن زِ أکِس ٲخرت کِس مُنکرس کیا فر ق چھےٚ ٲخر اَمہِ سٍتۍ پیٚوان زِ توٚہۍ دِیِو تس ٲخرت کہ ینٕچ خبرقسم ہٲوِتھ  یا قسم ہاونہٕ ورٲے؟سُہ ییٚلہِ نہٕ اَتھ چیز س مانٲنی چُھ تیٚلہِ کِتھہٕ پٲٹھۍ ہیٚکہِ محض اَتھ بِنا ہس پٮ۪ٹھ مٲنِتھ زِ توٚہۍ چِھو قسم ہٲوِتھ تس یہِ کتھ وَنان ؟ اَمِیُک جواب چُھ یہِ زِ رسول اللہ صلی اللہ علیہ وسلم ٲسۍ تِم لُکھ مخٲطِب یِم پننِس ذٲتی عِلم کِس تہٕ تجر بہٕ کِس بِنا ہس پٮ۪ٹھ یہِ کتھ وارٕ پٲٹھۍ زانان ٲسۍ زِ حضور صلی اللہ علیہ وسلمو چُھنہٕ زانٛہہ  سٲرِسٕے عمرِ اَپُز ووٚ نمُت،اَمہِ موجوٗب ٲسِتن تِم حضور صلی اللہ علیہ وسلمس خلا ف کِتھۍ بہتان تہِ تُھران،، پننیٚن دِلن منٛز ہیٚکہن نہٕ تِم یہِ تصور تہِ کٔرِتھ زِ یُتھ پٔزِ یور انسان کیا ہیٚکہِ زانٛہہ اللہ تعالیٰ سُند قسم ہٲوِتھ سۅ کتھ ؤنِتھ ییٚمہِ کہ بر حق آسنُک تس عِلم تہٕ یقین آسہِ نہٕ﴾ پتہٕ یِیَو تۅہیہِ ضروٗر وَننہٕ زِ تۅہیہِ کیا  کینژھاہ چُھو ﴿ دُنیا ہس منٛز ﴾ کوٚر مُت کرٛ و مُت، تہٕ یہِ کرُن چُھ اللہ تعالیٰ سٕندِ خٲطرٕ واریاہ سہل ۔"""
  64,8,"۔لہٰذا ،أنِو ایمان خُدایس پٮ۪ٹھ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلمس پٮ۪ٹھ،تہٕ تَتھ روشنی پٮ۪ٹھ یۅسہٕ اَسہِ نٲزِ ل چھےٚ کٔر مٕژ۔﴿یتھ جایہِ چُھ سیا ق و سبا ق خۅد وَنان زِ اللہ تعالیٰ سٕنزِ نٲزِل کر نہٕ آمژِ روشنی نِشہِ چُھ مُراد قرآن۔یِتھہٕ پٲٹھۍ روشنی چھےٚ پا نے نٔنۍ نیران ،تہٕ أندۍ پٔکۍ کیٚن تمام تِمن چیز ن چھےٚ نوٚن کڑان یِم گۅڈٕہ  اَنہِ گٔٹِس منٛز چُھپِتھ ٲسۍ،تِتھے پٲٹھۍ چُھ قرآن اکھ تِیُتھ ژونگ ییٚمیُک بر حق آسُن بجا ے خۅد روشنی چُھ،تہٕ اَمہِ چہِ روشنی منٛز ہیٚکہِ انسان پرٛتھ کانٛہہ سُہ مسلہٕ سمجِھتھ یتھ سمجھنہٕ خٲطرٕ أمِس پنٕنۍ علمٕکۍ ذرایع  تہٕ عقل کٲفی چَھنہٕ﴾ یِکینٛژھاہ توٚہۍ کران چِھو اللہ تعالیٰ چُھ تمہِ نِشہِ با خبر۔﴿ اَمِیُک پے لگیو تۅہیہِ تمہِ دۅہ ﴾"
  64,9,"۔ییٚلہِ اجتما ع کہ دۅہ سُہ تۅہیہِ سارِنٕے یِکہٕ وَٹہٕ کرِ۔ ﴿ اجتما ع ہُک دۅہ چُھ مُراد قیا مت، تہٕ سٲری یِکہٕ وَٹہٕ کر نہٕ نِشہِ مُراد تمام تِم انسان بیک وقت زندٕہ کٔرِ تھ جمع کرٕنۍ یِم ابتدا پٮ۪ٹھہٕ قیا متس  تام دنیاہس منٛز پٲدٕ گٔمٕتۍآسن ﴾سُہ دۅہ آسہِ اَکھ أکۍ سٕندِس مقابلس منٛز لُکن ہٕندِ ہا ر نُک زیننُک ۔﴿یعنی اصلی ہار جیت آسہِ قیا مت کہ دۅہ ۔ توروٲتِتھ لگہِ پے زِ اصلی  کٔمۍ تُل خسا رٕ ہ تہٕ کُس گوٚ و نفع زِ یٖنِتھ۔کٔمۍ کھیٚو و اصلی دو کھہٕ تہٕ کُس درٛاو عٲقل ۔کٔمۍ کوٚڈ پنُن سورُے زند گی ہُند سر مایہِ غلط کاروبارس منٛز لگٲوِتھ پا نس دیوٚ و ل، تہٕ کٔمۍ کرِ پننہِ قُوّتہٕ تہٕ قٲبلیتہٕ تہٕ کو ششہِ تہٕ مال تہٕ اوقا ت ، نفع کِس کاروبارس منٛز لگٲوِتھ سٲری فٲیدٕہ حٲصِل ،یِم گۅڈٕ نِکِس شخصس تہِ حٲصل ہیٚکہ ہَن سپدِ تھ اگر سُہ دُنیا ہٕچ حقیقت سمجھنس منٛز دو کھہٕ کھیٚیہِ ہے نہٕ ۔﴾ ییٚمۍ خُدایس پٮ۪ٹھ ایمان چُھ اوٚ نمُت تہٕ نیک عمل چُھ کران،اللہ تعالیٰ دٕنہِ تٔمۍ سٕندۍ گناہ،تہٕ تس کرِ تِتھیٚن جنّتن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان۔یِم لُکھ روزَن ہمیشہ ہمیشہِ یِمن منٛز۔یٔہے چھےٚ بٔڑ کا میٲبی ۔"
  64,10,"۔تہٕ یِمولُکو کُفر چُھ کوٚر مُت تہٕ سا نیٚن آیاتن چُھکھ بُتھ پھِیرُمُت، تِم آسن جہنمٕکۍ بسکین دار یتھ منٛز تِم ہمیشہ روزَن،تہٕ سُہ چُھ بدتر ین ٹِھکا نہٕ ۔ ع"
  64,11,"۔کانٛہہ مُصیبت چُھنہٕ زانٛہہ یِوان مگر چُھ اللہ تعالیٰ سٕندِ اِذنہٕ سٍتی یِوان۔یُس شخص خُدایس پٮ۪ٹھ ایمان آسہِ تھا وان اللہ تعالیٰ چُھ تٔمۍ سٕندِس دِلس ہدایت بخشان، خُدایس چُھ پرٛتھ چیزُک علم۔"
  64,12,"۔اللہ تعالیٰ سٕنز اطا عت کٔرِ و ، بیٚیہِ کٔرِ و رسول صلی اللہ علیہ وسلمن ہٕنزاطا عت۔ البتہ اگر توٚہۍ اطا عت نِشہِ بُتھ چِھو پِھران،تیٚلہِ چَھنہٕ سٲنِس رسول صلی اللہ علیہ وسلمس پٮ۪ٹھ صا ف صا ف حق واتنا ونہٕ ورٲے بیٚیہِ کانٛہہ ذمہٕ دٲری۔"
  64,13,"۔اللہ تعالیٰ چُھ سُہ یَس ورٲے کانٛہہ خُداے چُھنہٕ،"
  64,14,"۔اے لُوکو یِمو ایمان چُھو اوٚنمُت،تُہنزو خا ندار نیو منٛزٕ تہٕ تُہند یو اولادَو منٛزٕ چِھ کینٛہہ تُہٕندۍ دشمن، تِمو نِشہِ روٗزِ و با خبر۔ تہٕ اگر توٚہۍ عفووَس تہٕ در گُز رس کٲم ہیٚیِو تہٕ معا ف کٔرِ و تیٚلہِ چُھ اللہ تعالیٰ مغفرت کر ن وول تہٕ مہربان۔﴿یعنی دُنیٲوی رشتہٕ کہ لحا ظہٕ اگر چہِ یِم تِم لُکھ چِھ یِم انسانس سارِ وٕے کھۅتہٕ زیادٕہ ٹٲٹھۍ چِھ آسان، مگر دین کہ لحا ظہٕ چِھ یِم تُہٕندۍ ""دشمن""۔ یہِ دشمنی ٲسِتن خواہ اَمہِ حیثیتہٕ زِ تِم آسن تۅہیہِ ایمان نِشہِ رُکا وان تہٕ کُفر س کُن آسن لَمان ، یا اَمہِ حیثیتہٕ زِ یِہنزٕ ہمدر دِیہِ آسن کُفّارن سٍتۍ، بہر حال چُھ یہِ تِیُتھ چیز زِ تۅہیہِ پز یوٚ یِمن نِشہِ  ہُشار روزُن، تہٕ یِہندِس محبتس منٛز گرفتار سپدِ تھ گژِھہ نہٕ پنُن عا قبت برباد کرُن۔البتہ اَمیُک مطلب چُھنہٕ یہِ زِ دشمن سمجھِتھ لٲگِو توٚہۍ تِمن سٍتۍ سخت برتاو کرُن ، بلکہ چُھ مُدعا صرف یہِ زِ تِہُند اصلا ح اگر ہیٚکیِو نہٕ کٔرِ تھ تیٚلہِ بچٲوِو کم از کم پنُن پان﴾"
  64,15,"۔تُہٕندۍ مال تہٕ تُہٕندۍ اولاد چِھ دراصل اکھ آزمٲیش، تہٕ اللہ تعالیٰ ہٕے چُھ یَس نِشہِ بوٚڈ اجر چُھ۔"
  64,16,"۔لہٰذا یوٚت تام تۅہیہِ پا نس تام آسہِ خُدایس روٗزِ و کھۅژان، بیٚیہِ بوٗزِ و تہٕ کٔرِ و اطا عت، تہٕ پنٕنۍ مال کٔرِ و خرٕچ ، یہِ چُھ تُہٕندۍ خٲطرٕ بہتر۔یِم پننہِ دل چہِ تنگی نِشہِ محفوظ روٗدۍ، بس چِھ  تِمے فلا ح لبن وٲلۍ۔"
  64,17,"۔اگر توٚہۍ خُدایس قر ضِ حَسن دِ یِو، تیٚلہِ دِ یہِ سُہ تۅہیہِ کینٛہہ گۅ نہٕ ہُررٲوِتھ ،تہٕ تُہند یو قصورَو نِشہِ کر یٚو در گزر،اللہ تعالیٰ چُھ سٮ۪ٹھاہ قدردان تہٕ بُردبار،"
  64,18,"۔ حٲضر تہٕ غٲیب پرٛتھ چیز س چُھ زانان،زبردست تہٕ بیٚیہِ چُھ حکمت وول۔ ع"
