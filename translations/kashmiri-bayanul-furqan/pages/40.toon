quran[85]{c,v,t}:
  40,1,"ح۔م"
  40,2,"۔ییٚمہِ کتا بہِ ہُند نز و ل چُھ اللہ تعالیٰ سٕندِ طر فہٕ یُس زبردست چُھ،سورُے کینٛہہ زانن وول چُھ۔"
  40,3,"۔گنا ہ معا ف کر ن وول تہٕ توبہٕ قبول کرن وول چُھ،سخت سزا دِنہٕ وول تہٕ سٮ۪ٹھاہ صا حبِ فضل چُھ، کانٛہہ معبود چُھنہٕ تس ورٲے ،تٔسۍ کُن چُھ سارِنٕے واپس پھیرُن۔"
  40,4,"۔اللہ تعالیٰ سٕندٮ۪ن آیا تن منٛز چِھنہٕ ژُوان مگر صرف تِم لُکھ یِمو کُفر چُھ کوٚر مُت۔اَمہِ پتہٕ یِنہٕ تۅہیہِ دُنیا کیٚن مٕلکن منٛز تِہُند پھیرُن تھورُن﴿اثر و رسو خ ﴾ کُنہِ دو کھس منٛز تراویٚو۔"
  40,5,"۔یِمو برونٛہہ چُھ نوح علیہ السلام سٕندۍ قو مَن تہِ بُتھ پھِیرُمُت،تہٕ تس پتہٕ چھےٚ واریاہَو با قی دَریٚو تہِ یہِ کٲم کٔرمٕژ۔پرٛتھ قو من کوٚرارادٕہ پننِس رسولس پٮ۪ٹھ تاکہ تس کرِ ہے گرفتار۔تِمو سارِ وٕ یو کٔر بٲطل کیو ہتھیارَو سٍتۍ حق ؤسۍ پایہِ ہا ونٕچ کوٗشش، مگر ٲخر کار رٔٹۍ مےٚ تِم، پتہٕ وُچھِو زِ میو ن سزا کوتاہ سخت اوس۔"
  40,6,"۔یِتھےپٲٹھۍ چُھ تُہٕندِس ربّ سُند یہِ فٲصلہٕ تہِ تِمن سارِنٕے لُکن پٮ۪ٹھ چسپاں سپُد مُت یِم کُفرٕ کۍ مرتکب چِھ سپٕدمتۍ زِ  تِم چِھ وا صلِ جہنم سپدن وٲلۍ۔"
  40,7,"۔عرشِ الہٰی یِکۍ حٲمِل فر شتہٕ ، بیٚیہِ تِم یِم عرشس أندۍ پٔکۍ چِھ حٲضر روزان، سٲری چِھ پننِس ربّ سٕندِ حمدٕ سان تٔمۍ سٕنز تسبیح کران۔تِمن چُھ تس پٮ۪ٹھ ایمان بیٚیہِ چِھ ایمان اَنن والیٚن ہٕندِس حقس منٛز دعا ے مغفر ت کران۔تِم چِھ ونان:""اے سانہِ ربّہ،ژٕ چُھکھ پننہِ رحمتہٕ تہٕ پننہِ عِلمہٕ سان پرٛتھ چیزس پٮ۪ٹھ چھٲوِتھ، لہٰذا کر معا ف تہٕ بچاوُک جہنم کہ عذا بہٕ نِشہِ تِم لوٗکھ یِمو تو بہٕ چُھ کوٚرمُت بیٚیہِ چھکھ چٲنۍ وَتھ اختیار کٔرمٕژ۔"
  40,8,"۔اے سانہِ ربّہ،بیٚیہِ کرُکھ دٲخل تِم ہمیشہ روزن والیٚن تِمن جنّتن منٛز یِمن ہُند ژےٚ تِمن سٍتۍ وعدہ چھُے کوٚرمُت، بیٚیہِ یِم صا لح آسن تِہِند یٚو والد ینو تہٕ خا ندارِ نیو تہٕ اولادَو منٛز﴿تِم تہِ واتنا وُکھ تو ر تِمنٕے سٍتۍ ﴾ ژٕ چُھکھ بے شک غٲلب تہٕ حکمت وول۔"
  40,9,"۔تہٕ بچا وُکھ تِم بُرٲیَو نِشہِ۔ یُس ژےٚ قیا مت کہ دۅہ بُرٲیَو نِشہِ بچَو وتھن،تس پٮ۪ٹھ کورُتھ ژےٚ بوٚڈ رحم، یٔہے چھےٚ بٔڑ کامیٲبی ۔"" ع"
  40,10,"۔یِمو لُکو کُفر چُھ کوٚرمُت، قیا مت کہ دۅہ یِیہِ تِمن کر یکھ لٲیِتھ وَننہٕ"" از یوٗتاہ سخت شرارت تۅہیہِ پانس پٮ۪ٹھ چُھو کھسان ،اللہ تعالیٰ اوس امہِ کھۅتہٕ زیادٕہ غضب ناک تۅہیہِ پٮ۪ٹھ تمہِ وقتہٕ سپدان،ییٚلہِ توٚہۍ ایمانس کُن ٲسِو بُلا و نہٕ یِوان تہٕ توٚہۍ ٲسِو کفر کران۔"""
  40,11,"۔تِم وَنن "" اے سانہِ ربّہ، ژےٚ دِیتُتھ پٔزِ پٲٹھۍ اسہِ مو ت دۅیہِ پھرِ تہٕ زند گی دۅ یہِ پھرِ ، ﴿ دۅیہِ پھِرِ موت تہٕ دۅیہِ پھِرِ زند گی نِشہِ چُھ مُراد سُے چیز ییٚمچِ ذِکر سورۂ بقر ہ آیت 28 ہس منٛز کر نہٕ چھےٚ آمٕژ﴾ وۅ نۍ چِھ أسۍ پننیٚن قصّور ن ہُند اعتراف کران،کیا وۅ نۍ چھا ییٚتہِ نیرنٕچ تہِ کانٛہہ سبیل؟"" ﴿جواب میلیٚکھ﴾"
  40,12,"۔""یہِ حالت یتھ منٛز توٚہۍ مُبتلا چِھو،چھےٚ امہِ وجہ زِ ییٚلہِ کُنِس خُدایس کُن بُلا و نہٕ اوس یِوان،تیٚلہِ ٲسِو توٚہۍ ماننہٕ نِشہِ انکار کران،تہٕ ییٚلہِ تس سٍتۍ با قی ٲسۍ یِوان رَلا و نہٕ تیٚلہِ ٲسِو توٚہۍ مانان ۔وۅ نۍ چُھ فٲصلہٕ اللہ بزرگ و بر تر سٕندِس اَتھس منٛز""۔"
  40,13,"۔سُے چُھ یُس تۅہیہِ پننہِ نِشٲنیہِ چُھو ہاوان،تہٕ آسما نہٕ چُھ تُہندِ خٲطرٕ رزق نٲزِل کران۔﴿یعنی روٗد چُھ تراوان یُس رزقُک سبب چُھ، گر می تہٕ سردی چُھ نٲزِل کران، ییٚمیُک بوٚڈ دخل رِزق وۅ پدنس منٛز چُھ﴾ مگر ﴿یِمن نشٲنِیَن ہٕندِ مُشٲہدٕ ہ نِشہِ چُھ﴾ صرف سُے شخص سبق رٹا ن یُس خُدایس کُن رجوع کر ن وول آسہِ۔﴿لہٰذا ، اے رجوع کر ن والیو﴾"
  40,14,"۔اللہ تعالیٰ سٕے دِیِو نا د پنُن دین تس خٲطرٕ خٲلِص کٔرِتھ، خواہ تُہٕنز یہِ کٲم گٔژھۍ تن کٲفر ن کٲژاہ تہِ گوار۔"
  40,15,"۔سُہ چُھ بُلند در جہ وول، عر شُک مٲلِک ۔پننیو بند و منٛز یَس پٮ۪ٹھ یژھان چُھ پننہِ حُکمہ چُھ رُو ح نٲزِل کران، تاکہ سُہ کرِ مُلا قات کہ دۅہ نِشہِ خبردار۔"
  40,16,"۔سُہ دۅہ ییٚلہِ زن سٲری لُکھ بے پردٕہ آسن، خُدایس نِشہِ آسہِ نہٕ تِہنز کانٛہہ کتھ تہِ چُھپِتھ۔﴿تمہِ دۅہ یِیہِ کریکھ دِتھ پرٛژھنہٕ﴾ از کٔمۍ سٕنز بادشٲہی چھےٚ؟ ﴿سورُے عالم دِیہِ کر یکھ ﴾ اللہ واحدِ القہا ر سٕنز۔﴿وَننہٕ یِیہِ ﴾"
  40,17,"۔از یِیہِ پرٛتھ شخصس تٔمۍ سٕنزِ کمایہِ ہُندبد لہٕ دِنہٕ یۅسہٕ تٔمۍ کٔر مٕژ ٲس، از سپدِ نہٕ کٲنٛسہِ پٮ۪ٹھ کانٛہہ ظُلم ۔تہٕ اللہ تعالیٰ چُھ حسا ب ہیٚنس منٛز سٮ۪ٹھاہ تیز۔"
  40,18,"۔اے نبی صلی اللہ علیہ وسلم،کھۅژنٲوِ یوٗکھ یِم لُکھ تمہِ دۅہ نِشہِ یُس نکھہٕ چُھ ووتمُت۔ییٚلہِ وٲنِجہِ آسن ہِر ۍ وٲلِس تام کھسان تہٕ لُکھ آسن ودۅ نہِ ژھو پہٕ دَم کٔرِ تھ غمٕکۍ گرۅکھ والان۔ ظٲلِمن نَہ آسہِ کانٛہہ ہمدرد دوست تہٕ نہ کانٛہہ سفٲرش کر ن وول ییٚمۍ سٕنز کتھ ماننہٕ یِیہِ۔"
  40,19,"۔اللہ تعالیٰ چُھ نظر ن ہٕنزِ ژوٗرِ نِشہِ تام وٲقف، تہٕ تِم راز تام چُھ زانان یِم سینن  منٛز چِھ چُھپا و نہٕ آمٕتۍ۔"
  40,20,"۔تہٕ اللہ تعالیٰ کرِ ٹھیک ٹھیک بے لا گ فٲصلہٕ۔روٗدۍ تِم یِمن ﴿ یِم مُشر ک ﴾ اللہ تعالیٰ ترٲوِ تھ ناد چِھ دِوان،تِم چِھنہٕ کُنہِ چیزٕ کۍ تہِ فٲصلہٕ کر ن وٲلۍ، بے شک چُھ اللہ تعالیٰ ہٕے سورُے کینٛہہ بو زن وول تہٕ وُچھن وول۔ع"
  40,21,"۔کیا یِم لُکھ چِھنا زانٛہہ زمینس پٮ۪ٹھ پھیرِ مٕتۍ تھوٗرِ مٕتۍ، تا کہ یِمن یِیہِ ہے تِمن لُکن ہُند انجام اَتھہِ یِم یِمن برونٛہہ چِھ گُزریمٕتۍ؟ تِم ٲسۍ یِہندِ کھۅتہٕ زیادہ طا قت وَر، تہٕ یِہندِ کھۅتہٕ زیادہ زبردست آثا ر چِھکھ زمینس منٛز ترٲوِ مٕتۍ۔ مگر خُداین رٔٹۍ تِم تِہٕندٮ۪ن گنا ہن پٮ۪ٹھ،تہٕ تِمن اوس نہٕ خُدایس نِشہِ کانٛہہ بچا و ن وول ۔"
  40,22,"۔یہِ تُہند انجام سپُد امہِ موجوٗب زِ تِمن نِشہِ آے تِہندِۍ رسول بیّنات ہیٚتھ۔﴿بیّنات نِشہِ چِھ مُراد ترےٚ چیز۔ گۅڈنیُک، تِتھۍ ٹاکارٕہ علا مات تہٕ نِشا نیہِ یِمہٕ یِہندِس ماموٗر مِن اللہ آسنس پٮ۪ٹھ شٲہد آسہٕ۔دوٚیِم ، تِژٕھہ روشن دٔلیلہٕ یِمہٕ یِہنزِ پیش کر نہٕ آمٕژ تعلیم ہٕندِ حق آسنُک ثبوت آسہٕ دِوان ۔ ترییم ، زند گی ہٕندٮ۪ن مسٲیلن تہٕ معالاتن متعلق تِتھۍ ہدایات یِمن وُچھِتھ پرٛتھ کانٛہہ عقلہِ وول انسان یہِ زٲنِتھ ہیٚکہِ ہے زِ یِژھ پٲکیز ہ تعلیم  ہیٚکہِ نہٕ کانٛہہ اَپزِ یو ر ، خۅد غر ض اِنسا ن دِتھ۔﴾ تہٕ تِمو کوٚر ماننہٕ نِشہِ انکار۔ٲخر کار رٔٹۍ تِم خُداین۔ یقیناً چُھ سُہ سٮ۪ٹھاہ قُوّت وول تہٕ سزا دِ نس منٛز واریاہ سخت۔"
  40,23,"۔اسہِ سوٗز موسیٰ علیہ السلام پننیو نِشٲنِیو سان تہٕ ٹا کارٕہ ماموٗر یت کہ سَنَدٕ سان،"
  40,24,"۔فر عونس تہٕ ہا مانس تہٕ قارونس کُن، مگر تِمو ووٚن "" سٲحر چُھ، کذّاب چُھ۔"""
  40,25,"۔پتہٕ ییٚلہِ تٔمۍ سانہِ طر فہٕ تِمن برونٛہہ کُن حق اوٚن، پتہٕ ووٚن تِمو "" یِم لُکھ ایمان أنِتھ أمِس سٍتۍ شٲمِل چِھ سپدٕ مٕتۍ تِہندۍ سٲری لڑ کہٕ کٔرِ یوٗکھ قتل، تہٕ لڑکین دِیِو زندٕہ روزنہٕ۔"" مگر کٲفر ن ہٕنز چال گٔیہِ ضا یع۔"
  40,26,"۔اکہِ دۅہ چُھ فر عو ن پننیٚن در با ریٚن ونان"" ترٲوِ و مےٚ یلہٕ ، بہٕ کر ن یہِ مو سیٰ علیہ السلام قتل ، تہٕ وُچھِن یہِ پننِس ربّس ناد لٲیِتھ، مےٚ چُھ اندیشہِ زِ یہِ بد لاوِ تُہُند دین، نَتہٕ کرِ مٕلکس منٛز فساد بر پا۔"""
  40,27,"۔ مو سیٰ علیہ السلام چُھ ونان "" مےٚ چُھ پننِس ربّ سُند تہٕ چٲنِس ربّ سُند پنا ہ روٚٹمُت، پرٛتھ تس تکبر س کر ن وٲلۍ سٕندِس مقا بلس منٛز یُس حسا ب کِس دۅہس پٮ۪ٹھ ایمان چُھنہٕ تھا وان ۔ ""ع"
  40,28,"۔اتھ مو قعس پٮ۪ٹھ چُھ آلِ فرعو ن منٛزٕ اکھ مو من شخص، ییٚمۍ پنُن ایمان چُھپٲوِتھ اوس تھو و مُت ونان : ""کیا توٚہۍ کٔرِیوٗ نہٕ اکھ شخص صرف اتھ وجَہس پٮ۪ٹھ قتل زِ سُہ چُھ ونان میو ن ربّ چُھ اللہ ؟ حالانکہ سُہ آو تۅہیہِ نِشہِ تُہٕندِس ربّ سٕندِ طر فہٕ بینا ت ہیٚتھ۔اگر سُہ پٔزِ یو ر چُھ تیٚلہِ گژِھہ تس تٔمۍ سُند اَپُز خۅدتس پٮ۪ٹھ پھیٖرِتھ ۔البتہٕ اگر سُہ پٔزِ یو ر چُھ تیٚلہِ یِمن ہو لنا ک نتیجن ہُند خو ف سُہ تۅہیہِ دِوان چُھو تِمو منٛزٕ یِن کینٛہہ تۅہیہِ پٮ۪ٹھ ضروٗر۔اللہ تعالیٰ چُھنہٕ تِتھس کٲنٛسہِ شخصس ہدایت دِوان یُس حد نیرن وول تہٕ کذّاب آسہِ۔"
  40,29,"۔اے میا نہِ قو م کیو لوٗکو، از چَھو تۅہیہِ بادشٲہی حٲصل تہٕ زمینس منٛز چِھو توٚہۍ غٲلِب، البتہٕ اگر اللہ تعالیٰ سُند عذا ب اسہِ پٮ۪ٹھ آو تیٚلہِ کُس چُھ پتہٕ یُس اسہِ مدد ہیٚکہِ کٔرِتھ۔""فر عو ن چُھ ونان "" بہٕ چُھسَو تۅہیہِ سۅ ے راے دِوان یۅسہٕ مےٚ مُنٲسِب چھےٚ باسان، تہٕ بہٕ چُھسَو تۅہیہِ تٔتھۍ وَتہِ کُن رہنمٲیی کران یۅسہٕ ٹھیک چھےٚ۔"""
  40,30,"۔ییٚمۍ شخصن ایمان اوس اوٚ نمُت سُہ چُھ ونان ، "" اے میا نہِ قو م کیو لوٗکو ، مےٚ چُھ خو ف زِ تۅہیہِ پٮ۪ٹھ تہِ گوٚژھ نہٕ سُہ دۅہ واتُن یُس ییٚمہِ برونٛہہ واریا ہن درٮ۪ن پٮ۪ٹھ چُھ آمُت،"
  40,31,"۔ یُتھ دۅہ قومِ نوح علیہ السلام تہٕ عاد تہٕ ثمو د تہٕ یِمن پتھ یِم قوم ٲسۍ تِمن پٮ۪ٹھ اوس آمُت۔تہٕ حقیقت چھےٚ زِ اللہ تعالیٰ چُھنہٕ پننیٚن بند ن پٮ۪ٹھ ظُلمُک کانٛہہ ارداہ تھا وان۔"
  40,32,"۔اے قو م، مےٚ چُھ ڈر زِ تۅہیہِ پٮ۪ٹھ گوٚژھ نہٕ فر یادُک تہٕ کریٚکہِ نادُک دۅہ واتُن،"
  40,33,"۔ییٚلہِ توٚہۍ اکھ أکِس ناد دِیِو تہٕ ژلا ن ژلا ن پھیٖرِ و ، مگر تمہِ ساعتہٕ آسہِ نہٕ خُدایس نِشہِ بچا و ن وول کانٛہہ۔ پوٚز چُھ یہِ زِ یَس اللہ تعالیٰ ڈالہِ تس چُھنہٕ پتہٕ کانٛہہ وَتھ ہاو ن وول آسان۔"
  40,34,"۔امہِ برونٛہہ اوس یوسُف علیہ السلام تۅ ہیہِ نِشہِ بینا ت ہیٚتھ آمُت، مگر توٚہۍ روٗدِو تٔمۍ سٕنزِ اَنہِ مژِ تعلیمہِ ہٕندِ طر فہٕ شک سٕے منٛز۔پتہٕ ییٚلہِ تِہُندانتقال سپُد،پتہٕ ووٚنُو تۅہیہِ وو نۍ سوزِ نہٕ اللہ تعالیٰ تِمن پتہٕ ہر گز کانٛہہ رسول۔"" ﴿بظٲہر چُھ باسان زِ برونٛہہ کُن چِھ یِم لفظ خُداین آلِ فر عو ن کِس مو من شخصہٕ سٕندِس قو مس پٮ۪ٹھ بطور اضا فہٕ ارشاد فر مٲوِمٕتۍ﴾ یِتھے پٲٹھۍ چُھ اللہ تعالیٰ تِمن سارِنٕے لُکن گُمرٲہی منٛز ترٛاوان یِم حدٕ نیر ن وٲلۍ تہٕ شکی چِھ آسان،"
  40,35,"۔تہٕ اللہ تعالیٰ سٕندٮ۪ن آیا تن منٛز چِھ ژُوان امہِ ورٲے زِ تِمن نِشہِ آسہِ کانٛہہ سَنَد یا د لیل آمٕژ۔یہِ رَو یّہِ چُھ خُدایس تہٕ ایمان انن والیٚن نزدیک سخت نا پسند۔یِتھے پٲٹھۍ چُھ اللہ تعالیٰ پرٛتھ تکبُر کر ن وٲلِس تہٕ سر کش سٕندِس دِلس پٮ۪ٹھ ٹھپّہٕ لگا وان۔"
  40,36,"فر عو نن ووٚن "" اے ہامان میانہِ خٲطرٕ بنا و اَکھ بلند عما رت، تاکہ بہٕ ہیٚکہٕ وَتن تام وٲتِتھ، آسما نن ہٕنٛز ن وَتن تام، تہٕ مو سیٰ علیہ السلام سُنٛد خداوُچَھن پِلَن کٔرِ تھ"
  40,37,"مےٚ چُھ یہِ مو سیٰ علیہ السلام بس اپز یو ر با سان۔"" یِتھہٕ پٲٹھۍ آیہِ فر عو ن سٕنٛدِ خٲطرٕ تٔمۍسٕنز بد عملی خۅ شنما بنا و نہٕ، تہٕ سُہ آو سِیٚزِ وَتہِ نِشہِ رُکا و نہٕ۔ فر عو ن سٕنٛز سٲرٕ ے چال بٲزی گٔیہِ ﴿تٔمۍ سٕنٛز پننہِ ﴾ تباہی ہٕنٛزِ وَتہِ منٛز استعمال۔ع"
  40,38,"سُہ شخص ییٚمۍ ایمان اوس اوٚ نمُت چُھ وَنان ، ""اے میا نہ قو م کیو لٗوکو ، میٲنۍ کتھ  مٲنِو،بہٕ چُھسَو تۅہیہِ صحیح وَتھ ونان۔"""
  40,39,"اے قو م ، یہِ دُنیا ہٕچ زند گی چھےٚ کینٛژن دۅ ہن ہٕنٛز، ہمیشہ کہ قیام کر نٕچ جا ے چُھ بس ٲخر ت،"
  40,40,"۔یُس بُرٲیی کرِ تس میلہِ تِیٛتُھے بد لہٕ یٖژاھ تٔمۍ بُرٲیی آسہِ کٔرمٕژ۔تہٕ یُس نیک عمل کرِ ، خوا ہ سُہ مرد ٲسِتن یا خا تون ، بشر طیکہِ آسہِ مو من ، یِتھۍ سٲری لُکھ گژھن جنّتس منٛز دٲخل ییٚتہِ تِمن بے حسا ب رزق یِیہِ دِنہٕ۔"
  40,41,"۔ اے قو م، ٲخر کیا دٔلیل چھےٚ یہِ زِ بہٕ چُھسَو توٚہۍ نجا تس کُن بُلا وان، تہٕ توٚہۍ چِھو مےٚ نارس کُن دعوت دِوان!"
  40,42,"۔توٚہۍ چِھو مےٚ امہِ کتھہِ ہٕنز دعوت دِوان زِ بہٕ گژٕھہ خُدایس سٍتۍ کُفر کرُن، تہٕ تس سٍتۍ گژٕھہ تِمہٕ ہستی شر یک ٹھہرٲوُن یِم نہٕ بہٕ زانان چُھسکَھ، ﴿ یعنی مےٚ چَھنہٕ پے زِ خُدٲیی منٛز چھا تِہٕنز کانٛہہ شر کت﴾حالانکہ بہٕ چُھسَو توٚہۍ تس زبردست مغفرت کرن وٲلِس خُدایس کُن بُلاوان۔"
  40,43,"۔نَہ ،حق چُھ یہِ تہٕ اتھ خلا ف ہیٚکہِ نہٕ سپدِ تھ زِ یِمن کُن توٚہۍ مےٚ بُلاوان چِھو تِہندِ خٲطرٕ نَہ چھےٚ دُنیا سٕے منٛز کانٛہہ دعوت ،نہ ٲخرتس منٛز،﴿یتھ کتھہِ ہیٚکن بیٚیہِ تہِ کینٛہہ معنی ٲسِتھ۔ اکھ یہِ زِ،نَہ چُھ یِمن دُنیا ہس منٛز یہِ حق واتان تہٕ نہ ٲخرتس منٛز زِ یِہٕنز خُدٲیی تسلیم کر نہٕ خٲطرٕ گژِھہ خُداے سٕندٮ۪ن خلقن دعوت دِنہٕ یِنۍ ۔ دوٚ یُم یہِ زِ لوٗکو چِھ یِم زبردستی خُداے بنٲوِ مٕتۍ،نَتہٕ  نہ چِھ یِم یتھ دُنیا ہس منٛز خُدٲیی ہُند دعویٰ کر ن وٲلۍ، نہ وۅ تھن ٲخرتس منٛز یہِ دعویٰ ہیٚتھ زِ أسۍ تہِ ہے ٲسۍ خُداے تۅہیہِ کیا زِ مٲنِو نہٕ أسۍ۔ ترییُم یہِ زِ یِمن ناد دِنُک فٲیدٕ  نَہ چُھ یتھ دُنیا ہس منٛز نہ چُھ ٲخرتس منٛز، تِکیازِ یِم چِھ  بالکل بے اختیار تہٕ یِمن ناد لا یُن چُھ قطعی لا حٲصل۔﴾ تہٕ اسہِ سارِ نٕے چُھ پھیرُن اللہ تعالیٰ سٕے کُن، تہٕ حدٕ نیر ن وٲلۍ چِھ نارس گژھن وٲلۍ"
  40,44,"از یِکینژھا بہٕ ونان چُھس ،عن قر یب یِیہِ سُہ وقت ییٚلہِ توٚہۍ سُہ یاد کٔرِ یوٗن۔تہٕ پنُن معا ملہٕ چُھس بہٕ خُدایس پُشراوان،سُہ چُھ پننیٚن بند ن ہُند نگہبان۔"""
  40,45,"۔ٲخرکار یِمہٕ بُرٕ کھۅ تہٕ بُرٕ چالہٕ تِمو لُکو تس مو منس خلا ف گِنٛزٕ،خُداین بچو و سُہ تِمو سارِ یَو نِشہِ،﴿امہِ نِشہِ چُھ پے لگان زِ سُہ شخص چُھ فر عو ن سٕندِس سلطنتس منٛز تیٖتہِ بڈِ اہم شخصیتُک مٲلِک اوسمُت زِ پوٗرٕ در بارس منٛز فر عو نس برونٛہہ کنہِ حق گویی کر نہٕ با وجود ہیٚکہِ ہے نہٕ علا نیہ تس سزا دِنُک جُرات کر نہٕ یِتھ ، امہِ و جہ کِنۍ پیٚیہِ فرعو نس تہٕ تٔمۍ سٕندٮ۪ن حٲمِیَن تس مار نہٕ خٲطرٕ خفیہ تد بیرٕ کر نہِ ۔ مگر یِمن تدبیر ن تہِ دِیُت نہٕ خُداین برونٛہہ پکنہٕ۔﴾ تہٕ فر عو ن سٕندۍ سٲتھی آے خۅد بد تر ین عذا ب کِس پھیر س منٛز ہیٚنہٕ۔"
  40,46,"۔جہنمُک نار چُھ یتھ برونٛہہ کُن تِم صبحس تہٕ شا مس پیش چِھ یِوان کر نہٕ، تہٕ ییٚلہِ قیا متٕچ گٔرواتہِ، حُکم سپدِ زِ آلِ فرعو ن کٔرِیوٗن شدید عذا بس منٛز دٲخل۔"
  40,47,"۔ پتہٕ کٔرِو خیال تمہِ وقتُک ییٚلہِ یِم لُکھ جہنمس منٛز اکھ أکِس سٍتۍ ژُوان آسن۔ دُنیا ہس منٛز یِم لُکھ کمزور ٲسۍ تِم وَنن زٕ ٹھۍ بنَن والیٚن زِ ، ""أسۍ ٲسۍ تُہٕندۍ تا بع، کیا وۅ نۍ بچٲوِوٕ توٚہۍ اسہِ ییٚتہِ نارِ جنہم کہ تکلیف کہ کُنہِ حصّہٕ نِشہِ ؟"""
  40,48,"تِم زٕ ٹھۍ بنَن وٲلۍ دِن جواب، أسۍ سٲری چِھ ییٚتہِ أکۍ سٕے حا لس منٛز، تہٕ خُداین چُھ بند ن در میان فٲصلہٕ کوٚر مُت۔"" پتہٕ وَنن یِم جہنمس منٛز پیمٕتۍ لُکھ جہنم کیٚن اہلِ کارن،"
  40,49,"""پننِس ربّس کٔرۍ تَو دُعا زِ سٲنِس عذا بس کرِ ہے اکہِ دۅہٕچ کمی"
  40,50,"تِم پرٕٛ ژھن"" کیا تۅہیہِ نِشہِ ٲسۍ ناتُہٕندۍ رسول بینات ہیٚتھ یِوان روٗدِمٕتۍ ؟تِم وَنن ،آ،جہنٕکۍ اہلِ کار وَنن ""تیٚلہِ کٔرِو توٚہی دعا تہٕ کٲفرن ہُنٛد دعا چھُ ضایع گژھن وول"
  40,51,"۔پژھ کٔرِو أسۍ چِھ پننیٚن رسولن تہٕ ایمان اَنن والیٚن ہُند مدد ییٚمہِ دُنیا چہِ زند گی منٛز تہِ لازِ ماً کران، تہٕ تمہِ دۅہ تہِ کرَو ییٚلہِ گواہ آسن کھڑا۔"
  40,52,"۔ییٚلہِ ظٲلِمن تِہُند عذ ر کانٛہہ تہِ فٲیدہ دِیہِ نہٕ، تہٕ تِمن وَسہِ لعنت تہٕ بدتر ین ٹھکا نہٕ یِیہِ تِہندِس حصّس منٛز۔"
  40,53,"۔وُچھِتو زِ موسیٰ علیہ السلامس کٔر اسہِ رہنمٲیی، تہٕ بنی اسرایل بنو و تمہ کتا بہِ ہُند وٲرث، یۅسہٕ عقل تہٕ گاٹہٕ جار تھاون والیٚن خٲطرٕ ہدایت تہٕ نصیحت ٲس۔"
  40,54,"وُچھِتو زِ موسیٰ علیہ السلامس کٔر اسہِ رہنمٲیی، تہٕ بنی اسرایل بنو و تمہ کتا بہِ ہُند وٲرث، یۅسہٕ عقل تہٕ گاٹہٕ جار تھاون والیٚن خٲطرٕ ہدایت تہٕ نصیحت ٲس"
  40,55,"لہٰذا ، اے نبی صلی اللہ علیہ وسلم،صبر کٔرِو ،اللہ تعالیٰ سُند وعدہ چُھ بر حق، پننہِ قصورٕچ مٔنگِو معٲفی۔﴿یتھ سیا ق وسبا قس منٛز یہِ کتھ وننہٕ چھےٚ آمٕژ، تتھ پٮ۪ٹھ غور کر نہٕ سٍتۍ چُھ صا ف باسان زِ یتھ جایہِ چُھ""قصور "" نِشہِ مُراد بے صبر ی ہٕنز سۅ کیفیت یۅسہٕ شد ید مخا لفت کِس تتھ ماحولس منٛز خصوصیت سان پننیٚن سٲتھِیَن ہٕنز مظلو می وُچھ وُچھ نبی صلی اللہ علیہ وسلمن أندرٕ ٲس پٲدٕ سپدان۔تِم ٲسۍ یژھان زِ جلد ی گوٚژھ کانٛہہ تِیُتھ معجزہ یُن ہاو نہٕ ییٚمہِ سٍتۍ کفّار گژھہَن قٲیل۔نَتہٕ گٔژِھہ اللہ تعالیٰ سٕندِ طر فہٕ بیٚیہِ کانٛہہ تِژھ کتھ ظہورس منٛز یِنۍ ییٚمہِ سٍتۍ یہِ مخا لفتُک طوفا ن ٹھنڈٕ گژِھہ ہے۔یہِ خوٲہش ٲس نہٕ بذات خۅد کانٛہہ گناہ یتھ کُنہِ تو بہ وا ستغفارُک حا جتِ پیٚیہِ ہے، البتہٕ یتھ بلند مقا مَس پٮ۪ٹھ خُداین حضور سر فراز ٲسۍ کٔرمٕتۍ تہٕ ییٚمہِ زبردست اُو لو العزمی ہُند سُہ مقام تقا ضہٕ اوس کران، تمہِ لحا ظہٕ با سییہِ خُدایس یہِ معمو لی بے صبر ی تہِ حضور صلی اللہ علیہ وسلمن ہٕندِ مر تبہٕ نِشہِ ؤسۍ پایہِ ،امہِ موجوٗب سپُد ارشاد زِ اتھ کمزور ی پٮ۪ٹھ منگِو توٚہۍ خُدایس معٲفی تہٕ چٹا ن چہ مضبو طی سان سپدِ و پننِس مو قفس پٮ۪ٹھ قٲیِم ،یِتھہٕ پٲٹھۍ زَن تۅہیہِ ہِوِ س عظیم المر تبت انسانس آسُن پزِ ۔﴾ تہٕ صبح و شام روٗزِو پننِس ربّ سٕندِحمدٕسان تٔمۍ سٕنز تسبیح کران"
  40,56,"حقیقت چھےٚ یہِ زِ یِم لُکھ کُنہِ سَنَدٕ تہٕ حجّت ورٲے ،یۅسہٕ  تِمن نِشہِ آمٕژ آسہِ ، اللہ تعالیٰ سٕندٮ۪ن آیا تن منٛز ژُوان چِھ، تِہند ٮ۪ن دِلن منٛز چُھ کِبر بٔرِتھ، مگر تِم چھِنہٕ تتھ بجر س واتن وٲلۍ ییٚمیُک تِمن غروٗر چُھ۔ بس مٔنگِو اللہ تعالیٰ سُند پناہ، سُہ چُھ سورُے کینٛہہ وُچھان تہٕ بوزان"
  40,57,"آسمانن تہٕ زمینُک پٲدٕ کرُن چھےٚ انسان سٕندِ پٲدٕ کر نہٕ بہ نسبت یقیناً زیادہ بٔڑ کٲم، مگر اکثر لُکھ چِھنہٕ زانان"
  40,58,"تہٕ یہِ ہیٚکہِ نہٕ بٔنِتھ زِ اوٚن تہٕ گاشدار ہیٚکہِ یکسا ن سپدِ تھ، تہٕ ایمان دار تہٕ صا لح تہٕ بدکار آسن برابر"
  40,59,"مگر توٚہۍ لُکھ چِھو کمٕے پہن سمجھان۔یقیناً چھےٚ قیا متٕچ گٔر یِنہٕ واجِنۍ ، امہِ کِس یِنَس منٛز چُھنہٕ کانٛہہ شک،مگر اکثر لُکھ چِھنہٕ مانان"
  40,60,"۔تُہُند ربّ چُھ ونان"" مےٚ دِیو نا د،بہٕ کرٕ تُہٕندۍ دُعا قبول،﴿یعنی دعا قبول کر نٕکۍ سٲری اختیارات چِھ مےٚ،لہٰذا مَہ مٔنگِو توہۍ با قین دُعا بلکہ مٔنگِو میے﴾ یِم لُکھ تکبُرس منٛز یِتھ میا نہِ عبادت نِشہِ بُتھ چِھ پھِران، ضروٗر گژھن تِم ذلیل و خو ار سپدِتھ جہنمس منٛز دٲخٕل۔""ع ﴿یتھ آیتس منٛز چھےٚ زٕ کتھہٕ خا ص طور قٲبِل توجّہ۔اکھ یہِ زِ دُعا تہٕ عبادت چُھ یتھ جایہِ ہم معنی الفاظَو رٔنگۍ وَرتاو نہٕ آمُت۔تِکیازِ گۅڈنِکِس فِقر س منٛز یُس چیز دُعا کہ لفظہٕ سٍتۍ تعبیر اوس کر نہٕ آمُت ، سُے چُھ دوٚ یِمِس فِقرس منٛز عبادت کہ لفظہٕ سٍتۍ تعبیر فر ماو نہٕ آمُت۔امہِ سٍتۍ گٔیہِ یہِ کتھ واضح زِ دُعا چُھ عینِ عبادت تہٕ جانِ عبادت۔دوٚیُم یہِ زِ خُدایس دُعا نہ منگن والیٚن خٲطرٕ چِھ "" تکبرس منٛز یِتھ چِھ میانہِ عبادت نِشہِ بُتھ پھِران۔"" الفاظ وَر تاو نہٕ آمٕتۍ ۔امہِ نِشہِ چُھ پے لگا ن زِ اللہ تعالیٰ ہس دُعا منگُن چُھ عینِ بند گی ہُند تقا ضہٕ ،تہٕ امہِ نِشہِ بُتھ پھِر نُک معنی چُھ یہِ زِ انسان چُھ تکبُرس منٛز مبتلا ۔﴾"
  40,61,"۔سُہ چُھ اللہ تعالیٰ ہٕے ،ییٚمۍ تُہندِ خٲطرٕ رات بنٲو،تاکہ توٚہۍ ہیکِو اَتھ منٛز سکو ن حٲصل کٔرِ تھ، تہٕ دۅ ہ کوٚرُن روشن۔حقیقت چھےٚ یہِ زِ اللہ تعالیٰ چُھ لُکن پٮ۪ٹھ سٮ۪ٹھاہ فضل کر ن وول ،مگر اکثر لُکھ چِھنہٕ شکرادا کران۔"
  40,62,"۔سُے اللہ تعالیٰ ﴿ییٚمۍ تُہندِ خٲطرٕ یِکینٛژھاہ کوٚر مُت چُھ ﴾ چُھ تُہُند ربّ پرٛتھ چیزُک پٲدٕ کر ن وول ۔تس ورٲے چُھنہٕ کانٛہہ معبود۔پتہٕ کپٲرۍ چِھو توٚہۍ ڈالنہٕ یِوان؟"
  40,63,"۔یِتھے پٲٹھۍ چِھ تِم سٲری لُکھ ڈالنہٕ آمٕتۍ یِم اللہ تعالیٰ سٕندٮ۪ن آیا تن انکار ٲسۍ کران۔"
  40,64,"۔سُہ چُھ اللہ تعالیٰ ہٕے، ییٚمۍ تُہندِ خٲطرٕ زمین بنٲو قرار کر نٕچ جا ے، تہٕ پٮ۪ٹھہٕ بنو وُن آسمانُک چھت۔ییٚمۍ تُہٕنز صوٗرت بنٲوتہٕ سۅ تہِ بنٲوٕن سٮ۪ٹھاہ جان۔ییٚمۍتۅہیہِ پاکیزٕہ چیز ن ہُند رِزق دِیُت۔سُے اللہ تعالیٰ ﴿ییٚمۍ سٕندۍ یِم کار چِھ ﴾ چُھ تُہُند ربّ۔ بے حسا ب بر کتہٕ وول چُھ سُہ تُہُند ربّ۔"
  40,65,"۔سُے چُھ زِ ندٕہ ،تس ورٲے چُھنہٕ کانٛہہ معبود ، تٔسۍ دِیو توہۍ ناد پنُن دین تٔسۍ کُن خٲلص کٔرِ تھ۔ سٲری تعر یف چِھ اللہ ربّ العالمین سٕے خٲطرٕ۔"
  40,66,"۔اے نبی صلی اللہ علیہ وسلم ،یِمن لُکن ؤنِو زِ مےٚ چُھ تِمن ہستی ین ہٕندِ عبا دت نِشہِ ٹھاکھ کر نہٕ آمُت یِمن توٚہۍ اللہ تعالیٰ ترٲوِتھ ناد چِھو دِوان۔﴿بہٕ کِتھہٕ پٲٹھۍ ہیٚکہٕ یہِ کٲم کٔرِ تھ﴾ ییٚلہِ زَن مےٚ نِشہِ میٲنِس ربّ سٕندِ طر فہٕ بیّنات چِھ آمٕتۍ۔ مےٚ چُھ حُکم آمُت دِنہٕ زِ بہٕ گژٕھہ ربّ العا لمینس برونٛہہ کنہِ پنُن کلہٕ نوٚمراوُن۔"
  40,67,"۔سُے چُھ سُہ ییٚمۍ توٚہۍ میژِ کٔرِنَو پٲدٕ، پتہٕ کٔرِنو نُطفہٕ نِشہِ ، پتہٕ کٔرِو نَو خوٗنہٕ دۅگلہٕ نِشہِ، پتہٕ چُھو سُہ تۅہیہِ شُر ۍ سٕنزِ شکلہِ منٛز کڑان، پتہٕ چُھو بٔڑ راوان تاکہ توٚہۍ وٲتِو پننِس پوٗرطا قتس، پتہٕ چُھو بیٚیہِ بٔڑ راوان تاکہ توٚہۍ وٲتِو بُجرس۔تہٕ تۅہیہِ منٛز چُھ کانٛہہ گۅڈ ے یِوان واپس بُلاو نہٕ۔ یہِ سورُے کینٛہہ چُھ امہِ موجو ب یِوان کر نہٕ تا کہ توٚہۍ وٲتِو پننِس مُقر و قتس تام، بیٚیہِ امہِ موجو ب زِ توٚہۍ سمجھِو حقیقت۔"
  40,68,"۔ سُے چُھ زند گی دِنہٕ وول،تہٕ سُے چُھ موت دِنہٕ وول ۔سُہ ییٚمہِ کتھہِ ہُند تہِ فٲصلہٕ چُھ کران،بس اکھ حُکم چُھ دِوان زِ سۅ سپدِن تہٕ سۅ چھےٚ سپدان۔ع"
  40,69,"۔تۅہیہِ وُچھِوٕ تِم لُکھ یِم اللہ تعالیٰ سٕندٮ۪ن آیاتن منٛز ژُوان چِھ، کپٲرۍ چِھ تِم پھِر و نہٕ یِوان؟"
  40,70,"۔تِمن لُکن یِم یَتھ کتا بہِ تہٕ تِمن سارِنٕے کتا بن انکار چِھ کران یِمہٕ اسہِ پننیٚن رسولن سٍتۍ سوز مژٕ چھےٚ، عن قر یب لگہِ یِمن پے،"
  40,71,"۔ییٚلہِ طوق آسن یِہنز ن گر دنَن منٛز ، بیٚیہِ ہا نکلہٕ،"
  40,72,"۔یِمن گٔنڈِ تھ تِم گرٛکہٕ وٕ نِس آبس کُن کھکھرٕ یِن نِنہٕ ، تہٕ پتہٕ یِن جہنم کِس نارس منٛز چَھکنہٕ۔"
  40,73,"۔پتہٕ یِیہِ تِمن پرٛژھنہٕ زِ ، ""وۅ نۍ کتہِ چِھ خُدایس ورٲے تِم با قی خُداے یِم توٚہۍ شر یک ٲسِیوٗکھ کران؟"""
  40,74,"۔تِم دِن جواب۔"" تِم رٲوۍ اسہِ نِشہِ بلکہ ٲسۍ نہٕ أسۍ ییٚمہِ برونٛہہ کُنہِ چیز س ناد دِوان۔"" یِتھہٕ پٲٹھۍ کرِ اللہ تعالیٰ کٲفر ن ہُند گُمرا ہ سپدُن ثٲبت۔"
  40,75,"۔تِمن یِیہِ وَننہٕ "" یہِ تُہُند انجام سپُد امہِ موجوٗب زِ توٚہۍ ٲسِو زمینس پٮ۪ٹھ نا حقس پٮ۪ٹھ مست، تہٕ پتہٕ ٲسِو تتھ پٮ۪ٹھ ژینٛگان۔"
  40,76,"۔وۅ نۍ گٔژِھو، جہنم کیٚن دروازن منٛز سپدِ و دٲخل،ہمیشہ چُھو تۅہیہِ تٔتی روزُن،سٮ۪ٹھاہ زیادٕہ بُرٕ ٹھکانہٕ چُھ تکبُر کر ن والیٚن ہُند۔"""
  40,77,"۔ لہٰذا ، اے نبی صلی اللہ علیہ وسلم ، صبر کٔرِو ،اللہ تعالیٰ سُند وعدٕہ چُھ برحق۔وۅ نۍ خواہ أسۍ تۅہی برونٹھہٕ کنہِ یِمن تِہٕندٮ۪ن بُرٕ نتیجن ہُند کانٛہہ حصّہٕ ہاوَو یِمو نِشہِ أسۍ یِم کھۅژناوان چِھکھ، یا تُلو ﴿تمہِ برونٛہہ﴾ توٚہۍ دُنیا منٛزٕ،پھیرُن چُھ یِمن اَسِی کُن واپس۔"
  40,78,"۔اے نبی صلی اللہ علیہ وسلم،تۅہیہِ برونٛہہ چِھ اسہِ واریاہ رسول سوزِ مٕتۍ،یِمو منٛزٕ کینٛژھن ہٕندۍ حالات اسہِ تۅہیہِ ؤنِمٕتۍ چِھو،تہٕ کینژھن ہٕندۍ چِھو نہٕ ؤنِمٕتۍ۔ کٲنٛسہِ رسولس تہِ اوس نہٕ یہِ طا قت زِ اللہ تعالیٰ سٕندِ اِذنہٕ ورٲے اَنہِ ہے خۅد کانٛہہ نشٲنی۔پتہٕ ییٚلہِ اللہ تعالیٰ سُند حُکم آو،پتہٕ آو حقہٕ مطٲبق فٲصلہٕ کر نہٕ تہٕ تمہِ وقتہٕ روٗدۍ غلط کار لُکھ خسا رس منٛز۔ ع"
  40,79,"۔اللہ تعالیٰ نٕے چِھ تُہندِ خٲطرٕ چاروٲے بنٲوِ مٕتۍ،تاکہ یِمو منٛزٕ سپدِ و توٚہۍ کٲنٛسہِ پٮ۪ٹھ سوار تہٕ کانٛسہِ ہُند کھیٚیو ماز۔"
  40,80,"۔یِمن منٛز چِھ تُہندِ خٲطرٕ بیٚیہِ تہِ واریاہ فٲیدٕہ۔تِم چِھ اَتھ تہِ بکار لگان زِ تُہٕندٮ۪ن دِلن منٛز یوٚت گٔژھنُکھ حا جت آسہِ تِمن پٮ۪ٹھ ﴿کھٔسِتھ ﴾ ہیٚکِو توٚہۍ توروٲتِتھ۔تِمن پٮ۪ٹھ تہِ تہٕ ناون پٮ۪ٹھ تہِ چِھو توٚہۍ سوار یِوان کر نہٕ ۔"
  40,81,"۔اللہ تعالیٰ چُھ تۅہیہِ پننہِ یِمہٕ نِشٲنِیہِ ہاوان، ٲخرتٔمۍ سٕنز ن کمن کمن نِشٲنین کٔرِو توٚہۍ انکار۔"
  40,82,"۔پتہٕ کیا یِم چِھنا زمینس منٛز پھیٖرِ مٕتۍ تھوٗرِ مٕتۍ زِ  یِمن یِیہِ ہے تِمن لُکن ہُند انجام اَتھہِ یِم یِمن برونٛہہ چِھ گزریمٕتۍ؟تِم ٲسۍ یِمو کھۅتہٕ تعدادس منٛز تہِ زیادہ، یِمو کھۅتہٕ کھٔسِتھ ٲسۍ طا قت وَر،تہٕ زمینس منٛز چِھکھ یِہندِ کھۅتہٕ زیادہ شاندار آثا ر ترٲوِمٕتۍ۔ یِکینژھاہ کمٲے تِمو کٔرمٕژ ٲس،ٲخر کتھ لٔج سۅ تِمن بکار؟"
  40,83,"۔ییٚلہِ تِہندۍ رسول تِمن نِشہِ بیّنات ہیٚتھ آے، تِم روٗدۍ تٔتھۍ علِمس منٛز مست یُس تِمن پا نس نِشہِ اوس، تہٕ پتہٕ آے تٔتھۍ چیز کِس پھیرس منٛز یتھ تِم ٹسنہٕ ٲسۍ کران۔"
  40,84,"۔ییٚلہِ تِمو سو ن عذا ب وُچھ، کریکھ دِژٕ کھ زِ اَسہِ مو ن اللہ وحدہٗ لا شر یک،تہٕ أسۍ چِھ انکار کران تِمن سارِ نٕے معبودن ہُند یِم أسۍ تٔمۍ سٕندۍ شر یک ٲسۍ ٹھٔہراوان۔"
  40,85,"۔مگر سو ن عذا ب وُچھنہٕ پتہٕ ہیٚکہِ ہے نہٕ تِہُند ایمان تِہندِ خٲطرٕ نفع دِنہٕ وول بٔنِتھ، تِکیازِ یۅ ہے چُھ اللہ تعالیٰ سُند مقرر ضٲبطہٕ یُس ہمیشہِ تٔمۍ سٕند ٮ۪ن بند ن منٛز چُھ جٲری روٗد مُت، تہٕ تمہِ وقتہٕ روٗدۍ کٲفر لُکھ خسارس منٛز پیٚتھ۔ع"
