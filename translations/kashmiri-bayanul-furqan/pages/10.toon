quran[109]{c,v,t}:
  10,1,"۔ا۔ل۔ر۔ یِم چِھ تَمہِ کتا بہِ ہٕندۍ آیات یۅسہٕ حکمت سٍتۍ تہٕ گا ٹہٕ جارٕ سٍتۍ لبر یز چھےٚ۔"
  10,2,"۔ کیا لُکن گوٚواہ اَتھ کتھہِ پٮ۪ٹھ تعجب، زِ اسہِ سوٗز خۅد تِموٕ ے منٛز أکِس انسانس پٮ۪ٹھ وَحی،زِ ﴿غفلتس منٛز پیمٕتیٚن ﴾ لُکن کھۅژنا وِ تہٕ یِم مانن تِمن دِیہِ خۅ ش خبر ،زِ تِہندِ خٲطرٕ چُھ تِہندِس ربّس نِشہِ پوٚز عز ت تہٕ سر فرٲزی؟ ﴿اَتھ پٮ۪ٹھ﴾ ووٚن مُنکرَو زِ یہِ شخص چُھ نَنہٕ وانہٕ جادوگر۔﴿ تِم ٲسۍ حضور صلی اللہ علیہ وسلمس اَتھ معنیس منٛز جادو گر وَنان زِ یُس تہِ قرآن بوٗزِ تھ تہٕ تِہندِ تبلیغ سٍتۍ مُتٲثر سپدِ تھ ایمان اوس اَنان سُہ اوس پتہٕ زُوَس گِند نہٕ خٲطرٕ ،دُنیا ہس سٍتۍ ژھیٚننہٕ خٲطرٕ تہٕ پرٛتھ کانٛہہ مصیبت ویٚتراونہٕ خٲطرٕ تیار سپدان﴾"
  10,3,"۔حقیقت چھےٚ یہِ زِ تُہُند ربّ چُھ سُے اللہ تعالیٰ ییٚمۍ آسمان تہٕ زمین شیٚن دۅ ہن منٛز پٲدٕ کٔرۍ،پتہٕ چُھ سلطنت کِس تختس پٮ۪ٹھ جلوٕہ گر سپدِ تھ کایناتُک اِنتظام چلاوان۔کانٛہہ شفاعت ﴿سفٲرش﴾ کر ن وول چُھنہٕ۔اِلّایہِ زِ تٔمۍ سٕندِ اجا زت پتہٕ کرِ شفاعت ،سُے اللہ تعالیٰ چُھ تُہُند ربّ، لہٰذا کٔرِ و توٚہۍ تٔمۍسٕنزٕ ے عبادت، کیا وۅ نۍ یِیِو نا توٚہۍ ہو شس منٛز؟"
  10,4,"۔تٔمۍ سٕے کُن چُھ تۅہیہِ سارِنٕے پوٚت پھِیرِ تھ گژُھن،یہِ چُھ اللہ تعالیٰ سُند پکہٕ وعدہ، بے شک چُھ پیدٲیشہِ ہُند ابتدا سُے کران،پتہٕ کرِ سُے دُبارٕ زندٕہ، تاکہ یِمو لُکو ایمان اوٚن تہٕ یِمو نیک عملہٕ کرِ تِمن دِیہِ انصا ف سان جزا، تہٕ یِمو کُفر ک طر یقہٕ اختیار کوٚرتِم چیٚیِن گرٛ کہٕ وُن آب، تہٕ دگ تُلوُن عذا ب پیٚترٲوِن ، تتھ انکارِ حق کِس پاداشس منٛز یُس تِم کران روٗدۍ۔"
  10,5,"۔سُے چُھ ییٚمۍ آفتاب پرٛزلہٕ وُن بنو و ،تہٕ زونہِ دِژٕن چمک۔بیٚیہِ کٔرِ ن زوٗنہِ ہٕندۍ لۅ کٹہٕ نٕکۍ تہٕ بڑ نٕکۍ منٛز ل ٹھیک پٲٹھۍ مُقرر تاکہ توٚہۍ کٔرِ و اَمہِ سٍتۍ ؤرِ ین تہٕ تٲریخن ہٕندۍ حسا ب معلو م، خُدا ین چُھ یہِ سورُے کینٛہہ بر حق پٲدٕ کوٚرمُت،سُہ چُھ پننہِ نشٲنِیہِ ویٚژھنٲوۍ ویٚژھنٲوۍ پیش کران، تِمن لُکن خٲطرٕ یِم علم چِھ تھاوان۔"
  10,6,"۔پٔزۍ پٲٹھۍ چھےٚ رات کِس تہٕ دۅ ہ کِس بد لنَس ﴿ یِنَس گژھنس ﴾ منٛز، بیٚیہِ پرٛتھ کُنہِ چیز س منٛز یُس خُدا ین زمینس تہٕ آسما نن منٛز پٲدٕ چُھ کوٚرمُت نِشٲنیہِ تِمن لُکن خٲطرٕ یِم ﴿غلط بینی تہٕ غلط رَوِی﴾ نِشہِ بچُن چِھ یژھان۔﴿یعنی یِمو نِشٲنِیو سٍتۍ ہیٚکن تِمے لُکھ حقیقتس تام رسٲیی حٲصل کٔرِ تھ، یِمن منٛز یِم صفا ت موجود آسن۔ اکھ یہِ زِ تِم گژھن جٲہلا نہٕ تعصّبا تَو نِشہِ پاک سپدِ تھ علم حٲصل کر نہٕ کیٚن تِمن ذرا یع ہَن کٲم ہیٚنۍ ، یِم خُدا ین انسانس چِھ دِ تۍ مٕتۍ۔دوٚیُم یہِ زِ تِمن گژِھہ پانہٕ یہِ خوٲہش آسٕنۍ زِ غلطی نِشہِ بچَن تہٕ صحیح وتھ کر ن اختیار﴾"
  10,7,"۔ حقیقت چھےٚ یہِ زِ یِم لُکھ اَسہِ سٍتۍ ملا قات کر نُک تو قع چِھنہٕ تھاوان،تہٕ دُنیا چی زند گی پٮ۪ٹھ چِھ رٲضۍ تہٕ مطمعِن گٔمٕتۍ، تہٕ یِم لُکھ سانیو نِشٲنِیَو نِشہِ غٲفل چِھ ،"
  10,8,"۔تِہُند اُخروی ٹھکا نہٕ آسہِ جہنم،تِمن بُرٲییِن ہٕندِس پاداشس منٛز یمہٕ تِم ﴿ پننہِ امہِ غلط عقیدٕہ تہٕ غلط طر زِ عملہٕ سٍتۍ﴾ کماوان روٗدۍ۔"
  10,9,"۔ تہٕ پتہٕ چھےٚ حقیقت زِ یِمو لُکو ایمان اوٚن ﴿یعنی یِمو تِمہٕ صدا قتہٕ قبول کرِ، یِمہٕ کتا بہِ منٛز پیش چھےٚ کر نہٕ آمژٕ﴾ بیٚیہِ روٗدۍ نیک عملہٕ کران،تِمن پکنا وِ تِہُند ربّ ،تِہندِ ایمان کہ وجہ کِنۍ سیٚزِ وَتہِ پٮ۪ٹھ، نعمت والیٚن جنتن منٛز،یِمن بٔنۍ کِنۍ کۅ لہٕ پکن،"
  10,10,"۔تَتہِ آسہِ تِہُند آلَو یہِ زِ پاک چُھکھ ژٕ اے خُدا یا ، تِہُند دُعا آسہِ یہِ زِ  سلا متی ٲسِن  تہٕ تِہنزِ پرٛتھ کتھہِ ہُند خٲتمہٕ آسہِ اَتھ پٮ۪ٹھ زِ  سٲر ی تعر یف چِھ اللہ ربُ العا لمین سٕے خٲطرٕ ۔ع"
  10,11,"۔ہر گاہ اللہ تعالیٰ لُکن سٍتۍ بُرٕ ہ معا ملہٕ وَرتا و نس منٛز تہِ تژٕھے جلد ی کرِ ہے ییٖژاہ جلد ی تِم دُنیا ہُک رٕژَر منگنس منٛز چِھ کران ،تیٚلہِ آسہِ ہے تِہنزِ عملہِ ہٕنز مہلت خبر کر ختم کر نہٕ آمٕژ،﴿مگر یہِ چُھنہٕ سو ن طر یقہ ﴾ امہِ موجوٗب چِھ أسۍ تِمن لُکن ،یِمن اَسہِ سٍتۍ ملا قات کر نُک تو قع چُھنہٕ ،تِہنزِ سر کشی منٛز تِمن گُمراہ گژھنہٕ خٲطرٕ چھوٗٹ دِوان۔"
  10,12,"۔انسان سُند حال چُھ یہِ زِ ییٚلہِ تس پٮ۪ٹھ کانٛہہ سخت وقت چُھ یِوان۔تیٚلہِ چُھ لَر ترٲوِتھ ، یا بِہتھ ، یا وۅ دنہِ اَسہِ ناد لایان،مگر ییٚلہِ أسۍ تٔمۍ سُند یہِ مصیبت دوٗر چِھ کران پتہٕ چُھ تِتھہٕ پٲٹھۍ نیران زِ زَنتہٕ اوس نہٕ تٔمۍ کُنہِ بُرٕ ہ وقتس منٛز زانٛہہ اَسہِ نادٕ ے لو یمُت۔یِتھہٕ پٲٹھۍ چِھ حدٕ ہ نیر ن والیٚن خٲطرٕ تِہندۍ کر توٗت مٲرۍ مٔندۍ بنا و نہٕ آمٕتۍ۔"
  10,13,"۔لوٗکو ،تۅہیہِ برونٹھم قو م کٔرۍ اَسہِ ہلاک۔ ﴿یتھ جایہِ چُھ لفظ  قر ن وَرتاو نہٕ آمُت، عر بی زبٲنۍ منٛز چُھ اَمِیُک مُراد ، اکہِ  دورٕ کۍ لُکھ مگر قرآن مجیدس منٛز ییٚمہِ اندازٕ ہ یہِ مختلف مو قعن پٮ۪ٹھ وَر تاو نہٕ چُھ آمُت، تمہِ نِشہِ چُھ با سان زِ  قر ن  نِشہِ چُھ مُراد سُہ قو م یُس پننِس دَورس منٛز بر سرِ عر و ج آسہِ روٗد مُت۔ یِتھہِ قومٕچ ہلا کت چَھنہٕ لٲزِ ماً یۅ ہے معنی تھاوان زِ تمیُک نسل گژِھہ موٗلی مِٹا و نہٕ یُن، بلکہ چُھ معنی سُہ قو م پننہِ عر و ج کہ مقا مہٕ نِشہِ گِر اوُن۔تِمیُک تہذ یب و تمد ن تبا ہ سپدُن ،تِمیُک تشخص مِٹُن تہٕ تمِکۍ جُز پارٕہ پارٕہ سپدِ تھ دوٚ یمیٚن قو من منٛز راوٕنۍ ،یِتہِ چھےٚ ہلا کتٕچ اکھ صور ت ﴾ ییٚلہِ تِمو ظُلمٕچ رٔوِش اختیار کٔر۔تہٕ تِہندۍ رسول آے تِمن نِش ٹا کارٕ ہ  نشٲنیہِ ہیٚتھ،تہٕ تِمو اوٚ ن نہٕ ایمانٕے، یِتھہٕ پٲٹھۍ چِھ أسۍ مُجر من تِہند ٮ۪ن جُر من ہُند بد لہٕ دِوان۔"
  10,14,"۔وۅ نۍ چھےٚ اَسہِ تِمن پتہٕ تۅہیہِ زمینس پٮ۪ٹھ جاے دِژ مٕژ، تا کہ وُچَھو ،توٚہۍ کِژٕھہ عملہٕ چِھو کران۔"
  10,15,"۔ ییٚلہِ یِمن سانہِ صاف صا ف کتھہٕ بوزنا و نہٕ چھےٚ یِوان ، پتہٕ چِھ تِم لُکھ یِمن اَسہِ سٍتۍ ملا قا تُک تو قع چُھنہٕ ،وَنان زِ  امہِ بجا یہِ أنِو بیٚیہِ کانٛہہ قرآن،یا کٔرِ و اَتھ منٛز کینٛہہ تر میم۔ اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو ، یہِ چَھنہٕ میٲنۍ کٲم زِ پننہِ طر فہٕ کرٕ اتھ منٛز کانٛہہ ردو بد ل ،بہٕ چُھس صرف تمہِ وَحی ہُند پیر و کار یۅسہٕ مےٚ نِش سوزنہٕ چھےٚ یِوان،ہرگاہ بہٕ پننِس ربّ سٕنز نافر مٲنی کرٕ تیٚلہِ چُھ مےٚ اکہِ بَڈِ خطر ناک دۅ ہ کہ عذا بُک ڈر ۔"
  10,16,"۔بیٚیہِ ؤنِو اگر اللہ تعالیٰ سٕنز مشیت یٔہے آسہِ ہے،تیٚلہِ بوزناو ہَو نہٕ بہٕ توٚہۍ یہِ قرآن زانٛہہ ،تہٕ اللہ تعالیٰ دِیہِ ہیٚو نہٕ اَمِچ خبر تہِ تۅہیہِ اَمہِ برونٛہہ چھےٚ مےٚ تۅہیہِ در میان اکھ عمراہ گُزٲرمٕژ، کیا توٚہۍ چِھو نا عقلہِ کٲم ہیٚوان؟ ﴿یعنی بہٕ چُھس نہٕ تُہٕندِ خٲطرٕ کانٛہہ غیر زان  نفر کینٛہہ،بہٕ زاس تُہندِ س شہر س منٛز ،تۅہی در میان ووتُس شُر ۍ پانہٕ پٮ۪ٹھہٕ یتھ وٲنٛسہِ ۔ کیا توٚہۍ ہیٚکۍ واہ میانہِ سٲرِ سٕے زند گی پٮ۪ٹھ نظر ترا و نہٕ پتہٕ ایمان دٲر ی سان وۅ نۍ یہِ ؤنِتھ زِ یہِ قرآن آسہِ خۅد بذا ت مےٚ پنُن لیٚو کھمُت کلام۔بیٚیہِ ہیٚکۍ واہ توٚہۍ مےٚ نِش یہِ تو قع کٔرِتھ زِ بہٕ وَنہٕ یوٗتاہ بوٚڈ اَپُز زِ خۅد بنٲوٕ پننہِ دِلہٕ کانٛہہ کتھ، تہٕ پتہٕ وَنہٕ لُکن زِ یہِ چھےٚ اللہ تعالیٰ سٕندِ طر فہٕ مےٚ پٮ۪ٹھ نٲزِل سپٕز مٕژ﴾"
  10,17,"۔پتہٕ کُس ہیٚکہِ تٔمۍ سٕندِ کھۅ تہٕ بوٚڈ ظٲلِم ٲسِتھ ، یُس اکھ اُپٕز کتھ بنٲوِ تھ خُدا یس کُن منسوٗب کرِ ، یادِ یہِ اللہ تعالیٰ سٕندٮ۪ن پز ٮ۪ن آیا تن اَپُز قرار، پٔزۍ پٲٹھۍ ہیٚکن نہٕ مُجر م زانٛہہ تہِ کامیٲبی لٔبِتھ۔"
  10,18,"۔یِم لُکھ چِھ خُدا یس وَرٲے تِہٕنز عبادت کران،یِم نَہ یِمن نقصان ہیٚکن واتنٲوِتھ تہٕ نَہ نفع، تہٕ وَنان چِھ یہِ زِ یِم چِھ خُدا یس نِشہِ سٲنۍ سفٲرِش دار،اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو  کیا توٚہۍ چِھوٕہ خُدا یس امہِ کتھہِ ہٕنز خبردِوان یتھ نَہ سُہ آسمانن منٛز چُھ زانان تہٕ نَہ زمینس منٛز؟ ﴿اللہ تعالیٰ سٕندِ س عِلمَس منٛز کُنہِ چیزُک نَہ آسُن چُھ یہِ معنی تھاوان زِ سُہ آسہِ نہٕ گۅڈے موجود، امہِ موجو ب زِ سورُے کینٛہہ یہِ موجود چُھ سُہ چُھ اللہ تعالیٰ سٕندِس علمس منٛز۔لہٰذا چُھ یہِ اکھ نہایت لطیف اندازِ بیان سفٲرشی ین ہُند مسلہٕ مۅ کلا ونُک زِ خُدا یس چَھنہٕ یہِ پتہٕے زِ زمینس یا آسما نس منٛز چُھ کانٛہہ تٔمۍ سٕندِس در بارس منٛز تۅہیہِ سفٲرش کر ن وول ، پتہٕ کمن سفٲرش دَر ن ہٕنز خبر چِھو تس توٚہۍ دِوان ؟﴾ پاک چُھ سُہ بیٚیہِ چُھ بالا و بر تر تمہِ شِر کہٕ نِشہِ یُس یِم لُکھ کران چِھ ۔"
  10,19,"۔گۅڈٕ گۅڈٕ ٲسۍ سٲر ی انسان اکٲے اُمّت پتہٕ بنٲو ۍ تِمو مختلف عقیدٕہ تہٕ مسلک ،تہٕ اگر تُہندِ س ربّ سٕندِ طر فہٕ گۅڈے اکھ کتھ طے آسہِ ہے نہٕ کر نہٕ آمٕژ، تیٚلہِ یَتھ چیز س منٛز تِم پانہٕ وٲنۍ اختلاف چِھ کران تَمِیُک یِیہِ ہے فٲصلہٕ کر نہٕ۔﴿یعنی اگر خُدا ین گۅڈ ے آسہِ ہے نہٕ یہِ فٲصلہٕ کوٚر مُت زِ فٲصلہٕ سپدِ قیا مت کہ دۅ ہ تیٚلہِ یِیہِ ہے اَمِیُک فٲصلہٕ ییٚتی کر نہٕ ﴾"
  10,20,"۔بیٚیہِ یِکینژھاہ تِم یہِ وَنان چِھ زِ أمِس نبی ﴿صلی اللہ علیہ وسلمس ﴾ پٮ۪ٹھ کیا زِ آیہِ نہٕ أمۍ سٕندِس ربّ سٕندِ طر فہٕ کانٛہہ نشٲنی سوزنہٕ،یِمن ؤنِو  غیبُک مٲلِک تہٕ مختار چُھ بس اللہ تعالیٰ، اچھا ، کٔرِو انتظار ،بٕتہٕ کرٕ تۅہیہِ سٍتۍ انتظار۔ع"
  10,21,"۔ لُکن ہُند حال چُھ یہِ زِ مصیبت پتہٕ ییٚلہِ أسۍ تِم رحمتُک مزٕہ چِھکھ وُچھنا وان، تیٚلہِ چِھ تِم فوراً سا نیٚن نِشٲنیَن ہٕندِ س معا ملس منٛز چال بٲزِ یہِ شروع کران،﴿ یعنی مصیبت چُھ اللہ تعالیٰ سٕندِ طر فہٕ اکھ نِشٲنی آسان،یُس انسانس احسا س چُھ دِوان زِ در حقیقت چُھنہٕ خُدا یس ورٲے بیٚیہِ کانٛہہ یہِ دوٗر کر ن وول۔ مگر ییٚلہِ سُہ دوٗر چُھ گژھان تہٕ پتہٕ چُھ جان وقت یِوان ، اَمہِ پتہٕ چِھ تِم لاگان وَنُن زِ یہِ چُھ سا نیٚن معبودن تہٕ سفٲرش دَر ن ہٕندِ عنا یتُک نتیجہ ﴾ یِمن ؤنِو  اللہ تعالیٰ چُھ پننہِ چالہِ منٛز تۅہیہِ نِشہِ سٮ۪ٹھاہ تیز، تٔمۍ سٕندۍ فر شتہٕ چِھ تُہنزٕ ساریے مکٲرِلہٕ لیٚکھان۔"
  10,22,"۔ سُہ چُھ اللہ تعالیٰ ہٕے یُس تۅہیہِ خشکی تہٕ ٲبی منٛزۍ پکنا وان چُھو، چنا نچہ ییٚلہِ توٚہۍ ناوَن منٛز سوار چِھو آسان ،تہٕ مُو ٲفق ہَوا ہس پٮ۪ٹھ چِھو خۅ ش پٲٹھۍ سفر آسان کران، تہٕ پتہٕ چُھ اچانک مخٲلف ہوا ہُک زور یِوان ،تہٕ پرٛتھ طر فہٕ چِھ لہرن ہٕنزٕ تھا پرٕ ہ وَسان  تہٕ مسافر چِھ سمجھان زِ طو فا نس منٛز آے ہیٚنہٕ، تمہِ وقتہٕ چِھ سٲر ی پنُن دین اللہ تعالیٰ  سٕندی خٲطر خٲلص کٔرِتھ تس دُعا منگان زِ  اگر ژےٚ اَسہِ ییٚمہِ بلا یہِ نِشہِ نجا ت دِ یتُتھ،تیٚلہِ بنو أسۍ شکر گزار بندٕہ۔"
  10,23,"۔ مگر ییٚلہِ سُہ تِمن بچا وان چُھ،پتہٕ چِھ تمِے لُکھ حق نِشہِ بُتھ پھِر ۍ سپدِتھ زمینس منٛز بغا وت کرٕنۍ لاگان، لوٗکو ،تُہٕنز یہِ بغا وت چھےٚ تۅہیہِ پا نس خلا ف گژھان۔دُنیا چہِ زند گی ہٕندۍ چِھ صرف کینٛہہ دۅہ مزٕ ہ ﴿لوٗٹِو﴾، پتہٕ چُھو تۅہیہِ اَسہِ کُن یُن واپس پھیرِ تھ ،تمہِ ساعتہٕ وَنو أسۍ تۅہیہِ زِ توٚہۍ کیا کینژھاہ چِھو روٗدِمٕتۍ کران۔"
  10,24,"۔دُنیا ہٕچ یہِ زند گی ﴿ییٚمہِ کِس نشسس منٛز مست سپدِ تھ توٚہۍ سانیو نِشٲنِیو نِشہِ غفلت چِھو وَرتاوان﴾ اَمِچ مثا ل چھےٚ تِژٕھے زَنتہٕ آسما نہٕ ترٛ وو اَسہِ روٗد،تہٕ زمینُک پیداوروۅ پدیٛا و جان پٲٹھۍ، یتھ انسان تہٕ جانور سٲری چِھ کھیٚوان، عینِ وقتس پٮ۪ٹھ ییٚلہِ زن زمین بہار ہیٚتھ وۅ لسنس ٲس آمٕژ تہٕ پیداوار ٲسۍ شو بِدار پٲٹھۍ کھڑا۔تہٕ یِہٕندۍ مٲلک ٲسۍ سمجھان زِ وۅ نۍ چِھ أسۍ یِمن فٲیدٕہ تُلنس پٮ۪ٹھ قٲدِر،اچانک آورٲتھۍ کِیُت یا دۅ ہلہِ سون حکم تہٕ اَسہِ کوٚر یہِ تِتھہٕ پٲٹھۍ تباہ، زَنتہٕ رات اوسُے نہٕ تَتہِ کینٛہہ، یِتھہٕ پٲٹھۍ چِھ أسۍ ویٚژٕھینۍ ویٚژٕھنۍ نِشٲنیہِ پیش کران،تِمن لُکن خٲطرٕ یِم سو چن سمجھن وٲلۍ چِھ ۔ ﴿ توٚہۍ چِھو  یَتھ نا پا یدار زند گی ہٕنٛدِ س فر یبس منٛز مبتلا سپدان﴾"
  10,25,"۔تہٕ اللہ تعالیٰ چُھو تۅہیہِ دار السَّلامس کُن دعوت دِوان ﴿یعنی دُنیا ہس منٛز زند گی بسر کر نہٕ کِس تتھ طر یقس کُن چُھو دعوت دِوان یُس ٲخرت چہِ زند گی منٛز تۅہیہِ دارُالسَّلامُک حقدار بناوِ۔دارُ السَّلا م نِشہِ چُھ مُراد جنت تہٕ اَمِیُک معنی چُھ  سلامتی ہُند گھرٕ ،سۅ جا ے ییٚتہِ نہٕ کانٛہہ آفت ،کانٛہہ نقصان ، کانٛہہ غم تہٕ تکلیف آسہِ ﴾ ﴿ ہدایت چُھ تٔمۍ سٕندِس اختیارس منٛز﴾ یَس سُہ یژھان چُھ سیٚز وَتھ چُھس ہاوان۔"
  10,26,"۔یِمو لُکو رٕژرُک طر یقہٕ اختیار کوٚر ، تِمن خٲطرٕ چُھ رٕژَر تہٕ ہُر یمانہٕ فضل،تِہند ٮ۪ن بتھیٚن پٮ۪ٹھ کھسہِ نہٕ روے سیٲہی تہٕ ذِلت، تِم چِھ جنتٕکۍ حقدار ییٚتہِ تِم ہمیشہ روزن۔"
  10,27,"۔تہٕ یِمو لُکو بُرٲیِیہِ کماوِ ، یِژٕھہ تِہنز بُرٲیی چھےٚ، تِیُتھے میلہِ تِمن بد لہٕ ، ذِ لّت سپدِ تِمن پٮ۪ٹھ مُسلّط ، خُدا یس نِشہِ آسہِ نہٕ تِمن کانٛہہ بچا و ن وول، تِہندٮ۪ن بُتھیٚن پٮ۪ٹھ آسہِ تِژھہ تٲر یکی ،زَنتہٕ رٲژ ہٕندۍ سیا ہ پردٕہ آسن تِمن پٮ۪ٹھ، تِم چِھ جہنمٕکۍ حقدار ییٚتہِ تِم ہمیشہ روزن۔"
  10,28,"۔ییٚمہِ دۅ ہ أسۍ تِم سٲری یِکہٕ وَٹہٕ ﴿پننِس عدا لتس منٛز﴾ جمع کروکھ، پتہٕ وَنَوتِمن لُکن یِمو شر ک چُھ کوٚر مُت زِ ٹھٔہرِ و توٚہۍ تہِ تہٕ تُہٕندۍ بنا و نہٕ آمٕتۍ شر یک تہِ ، پتہٕ تُلو أسۍ تِمن در میان غٲر زٲنی ہُنٛد پردٕہ تھوٚد۔﴿یعنی مُشر کن پرزٕ ناون تِہِندۍ معبود زِ یِم چِھ تِم لُکھ یِم سٲنۍ عبادت ٲسۍ کران تہٕ مُشر ک پرزٕ ناون پننیٚن معبود ن زِ یِم چِھ تِم یِہٕنز أسۍ عبادت ٲسۍ کران﴾ تہٕ تِہندۍ شر یک ونَن زِ  توٚہۍ ٲسِو نہٕ سٲنۍ عبادت کران۔"
  10,29,"۔اَسہِ تہٕ تۅہیہِ در میان چھےٚ اللہ تعالیٰ سٕنز گوٲہی  کٲفی زِ ﴿توٚہۍ اگر سٲنۍ عبادت کران تہِ ٲسِو﴾ أسۍٲسۍ تُہٕندِ اَمہِ عبادت نِشہِ بالکل بے خبر۔"
  10,30,"۔تمہِ وقتہٕ وُچھہِ پرٛتھ کانٛہہ شخص پننہِ کرِ مَتِیُک مزٕ ہ، سٲر ی یِن پننِس حقیقی مٲلِکس کُن پھِر نہٕ تہٕ تِم سٲر ی اپٕز ۍ راوَن یِم تِمو بنٲوِمٕتۍ ٲسۍ۔ع"
  10,31,"۔یِمن پٕرٛژِھو ، کُس چُھو تۅہیہِ آسمان تہٕ زمین نِشہِ رزق دِوان؟ یِمہٕ بوزنہٕ چہِ تہٕ وُچھنہٕ  چہِ قُوّتہٕ کٔمۍ سٕندِس اختیارس منٛز چھےٚ؟ کُس چُھ بے جان منٛزٕجاندار تہٕ جان دار منٛزٕ بےٚ جان کڑان؟ کُس چُھ یتھ عالم کِس نظمس تد بیر کران؟ تِم وَنن ضرور زِ اللہ تعالیٰ ؤنِو ،پتہٕ چِھو نہٕ توٚہۍ ﴿حقیقتس  خلا ف پکنس ﴾ پر ہیز کران؟"
  10,32,"۔تیٚلہِ چُھ یۅہے اللہ تعالیٰ تُہُند حقیقی ربّ، پتہٕ کیا روٗد حق پتہٕ گمرٲہی وَرٲے مز ید پتھ کُن؟  ٲخر کور کُن چِھو یِوان توٚہۍ پھِر وٕ نہٕ ؟ ﴿یتھ جایہِ گژِھہ خیال روزُن زِ خطا ب چُھ عام لُکن تہٕ تِمن چُھنہٕ سوال یِوان کر نہٕ زِ  توٚہۍ کور کُن چِھو پھیران بلکہ چُھ یہِ زِ  توٚہۍ کورکُن چِھو پھِر وٕ نہٕ یِوان ۔ اَمہِ نِشہِ چُھ صا ف ظٲہر زِ کانٛہہ گمراہ کُن شخص یا گروہ چُھ موجود ،یُس لُکن صحیح اَندٕ نِشہِ ڈٲلِتھ غلط اَندس کُن چُھ پھِران۔أتھۍ بِنا ہِس پٮ۪ٹھ چُھ لُکن وَننہٕ یِوان زِ توٚہۍ کیازِ چِھو أنۍ بٔنِتھ غلط  رہنمٲیی کر ن والیٚن پتہٕ پتہٕ پکان ؟ توٚہۍ کیازِ چِھو نہٕ پننہِ عقلہِ کٲم ہیٚتھ سو چان زِ ییٚلہِ حقیقت چھےٚ یہِ تیٚلہِ کور کُن چِھو ٲخٕر تۅہۍ پکنا و نہٕ یِوان ۔﴾"
  10,33,"﴿اے نبی صلی اللہ علیہ وسلم، وُچِھو ﴾ یِتھہٕ پٲٹھۍ آیہِ نا فر مٲنی کر ن والیٚن پٮ۪ٹھ تُہندِ س ربّ سٕنز کتھ صٲدق زِ تِم مانن نہ"
  10,34,"یِمن پٕرٛژِھتو ، تُہُند و ٹھٔہر او نہٕ آمتیو شر یکو منٛزٕ چھا کانٛہہ سُہ یُس تخلیقُک ابتدا تہِ آسہِ کران تہٕ پتہٕ کرِ اَمِیُک اِعادٕ تہِ ؟ ؤنِو سُہ چُھ صرف اللہ تعالیٰ یُس تخلیقُک  ابتدا  تہِ چُھ کران اَمِیُک اعادٕ ہ تہِ ، پتہٕ کتھ اُلٹہٕ وَتہٕ پٮ۪ٹھ چِھو توٚہۍ پکنا و نہٕ یِوان ؟"
  10,35,"۔ یِمن پٕرٛژِھتو تُہٕند یو ٹھٔہراونہٕ آمتیو شر یکو منٛزٕ چھا کانٛہہ تِیُتھ، یُس حقس کُن رہنمٲ یی آسہِ کران؟ ؤنِو سُہ چُھ صرف اللہ تعالیٰ یُس حقس کُن رہنمٲیی چُھ کران، پتہٕ ؤنۍ تَو، یُس حقس کُن رہنمٲیی چُھ کران، سُہ چھا اَمِیُک زیادہ حقدار زِ تٔمۍ سٕنز پیروی گژِھ یِنۍ کر نہٕ کِنہٕ سُہ یُس خۅد پانہٕ وَتھ چُھنہٕ لبا ن ، اِلّایہِ زِ تس یِیہِ رہنمٲیی کر نہٕ؟ ٲخر کیا چُھو تۅہیہِ گوٚمُت، کِتھۍ اُٰٹہٕ فٲصلہٕ چِھو کران ؟"
  10,36,"۔حقیقت چھےٚ یہِ زِ یِمو منٛزٕ چِھ اکثر لُکھ محض قیا سس تہٕ گُما نس پتہٕ پتہٕ پکان روزان ﴿ یعنی یِمو مذہب بنٲوۍ ،یِمو فلسفہ تصنیف کٔرۍ تہٕ یِمو زند گی ہٕندۍ قا نو ن کٔرۍ تجو یز، تِمو کوٚر نہٕ یہِ سورُے علم کِس بُنیا دس پٮ۪ٹھ بلکہ کورُکھ گُما نس تہٕ قیا سس پٮ۪ٹھ ،تہٕ یِمو یِمن مذ ہبی تہٕ دُنیٲوی رہنمٲہن ہٕنز پیروی کٔر،تِمو تہِ کٔر نہٕ زٲنِتھ تہٕ سمجِھتھ بلکہ کوٚرُکھ محض اَمہِ  گُمان کِس بنیادس پٮ۪ٹھ تِہُند اتبا ع زِ ییٚلہِ یِتھۍ یِتھۍ بٔڑۍ بٔڑۍ لُکھ وَنان چِھ ، تہٕ مٲلۍ بُڈِ بب چِھ یِمن مانان روٗدِ مٕتۍ تہٕ اکھ دُنیا چُھ  یِہٕنز پیروی کران تیٚلہِ آسن ضرور ٹھیکھٕے وَنان۔﴾ حالانکہ گُمان چُھنہٕ حقٕچ ضرورت رَژھ تہِ پوٗرٕ کران، یِکینژھاہ یِم کران چِھ اللہ تعالیٰ چُھ تتھ وارٕ پٲٹھۍ زانان۔"
  10,37,"۔ تہٕ یہِ قرآن چُھنہٕ سُہ چیز، یُس اللہ تعالیٰ سٕنزِ وَحی تہٕ تعلیمہِ ورٲے تصنیف یِیہِ کر نہٕ،بلکہ یِکینژھاہ گۅڈٕ چُھ آمُت یہِ چُھ تِمیُک تصدیق تہٕ الکتاب ہُند تفصیل،اَتھ منٛز چُھنہٕ کانٛہہ شک زِ یہِ چُھ کاینات کِس فر مان روا سٕندِ طر فہٕ ۔"
  10,38,"۔ کیا یِم لُکھ چھا وَنان زِ پیغمبر ن چُھ یہِ پانہٕ تصینف کوٚر مُت؟ ؤنِو ، تیٚلہِ أنۍ تَو اکھ سُورٕہ یُتُھے  تصنیف کٔرِ تھ، تہٕ اکھ اللہ تعالیٰ ترٲوِتھ یُس یُس توٚہۍ مددٕ خٲطرٕ ہیٚکِیوٗن أنِتھ سُہ أنِیوٗن، اگر توٚہۍ پننِس اَتھ الزا مس منٛز پٔزِ یٲرۍ چِھو۔"
  10,39,"۔دراصل یُس چیز تِہندِس علم کِس گرِ فتس منٛز آو نہٕ تہٕ ییٚمِچ اصل حقیقت تہِ یِمن برونٛہہ کُن آیہِ نہٕ، یِمو پھِیرُتتھ بُتھ  خواہ مخواہ سو نچنہٕ ورٲے ﴾ یِتھے پٲٹھۍ چُھ یِمن بروٗنٹھمیو لُکو تہِ بُتھ پھِیرُمُت، پتہٕ وُچِھو تِمن ظٲلِمن کُس انجام سپُد۔"
  10,40,"۔تِمو منٛزٕ اَنن کینٛہہ لُکھ ایمان،تہٕ کینٛہہ اَنن نہٕ، تہٕ تُہُند ربّ چُھ تِمن فساد یٚن خوٗب زانان ۔ع"
  10,41,"۔اگر یِم تۅہیہِ بُتھ چِھو پھِران،تیٚلہِ ؤنیوٗکھ زِ  میٲنۍ عمل چھےٚ میانہِ خٲطرٕ تہٕ تُہٕنز عمل چھےٚ تُہٕندِ خٲطرٕ، یِکینژھاہ بہٕ کران چُھس تمہِ چہِ ذمہٕ دٲری نِشہِ چِھو توٚہۍ بر ی۔تہٕ یِکینژھاہ توٚہۍ کران چِھو تمہِ چہِ ذمہ دٲری نِشہِ چُھس بہٕ بر ی۔﴿ یعنی خوا مخواہ ژُونٕچ تہٕ بحث کرنٕچ چَھنہٕ کانٛہہ ضرورت۔اگر بہٕ الزام ترٲشی چُھس کران تیٚلہِ چُھس بہٕ پننہِ عملہِ ہُند پانے ذمہ دار تۅہیہِ پٮ۪ٹھ چَھنہٕ اَمچ کانٛہہ ذمہ دٲری ،تہٕ اگر توٚہۍ پزِ کتھہِ چِھو بُتھ پھِران تیٚلہِ چِھو نہٕ مےٚ کانٛہہ نقصا ن واتنا وان ،بلکہ چِھو پا نسٕے نقصان کران﴾"
  10,42,"۔ یِمو منٛزٕ چِھ واریاہ لُکھ یِم تُہٕنز کتھ چِھ بوزان،مگر کیا توٚہۍ بونٲوِیوٗکھہٕ زٔرۍ، خواہ تِم مَتہٕ ٲسِتن کِہِنۍ سمجھان؟ ﴿اَکھ بوزُن گوٚو سُہ یُس جانور تہِ بوزان چِھ ۔ دوٚ یُم بوزُن گوٚ سُہ یتھ منٛز معنیس کُن تہِ تو جہ آسہِ تہٕ یہِ آماد گی تہِ آسہِ لبنہٕ یِوان زِ کتھ اگر معقو ل آسہِ تیٚلہِ یِیہِ سۅ ماننہٕ ﴾"
  10,43,"۔ یِمو منٛزٕ چِھ واریاہ لُکھ یِم تۅہیہِ وُچھان چِھ، مگر کیا توٚہۍ ہٲوِوٕہ اَنٚین وَتھ،خواہ متہٕ ٲسِتن تِمن کِہِنۍ یِوان؟"
  10,44,"۔حقیقت چھےٚ یہِ زِ اللہ تعالیٰ چُھنہٕ لُکن پٮ۪ٹھ ظُلم کران، لُکھ چِھ پانے پا نس پٮ۪ٹھ ظُلم کران۔"
  10,45,"۔﴿از چِھ یِم ییٚمہِ دُنیا چہِ زند گی منٛز مست ﴾ تہٕ ییٚمہِ دۅہ اللہ تعالیٰ یِمن اِکہِ وٹہٕ کرِ تیٚلہِ ﴿ با سہِ یِمن یٔہے دُنیا ہٕچ زند گی تِژھ ﴾ زنتہٕ یِم محض أکِس گھرِ کھنجہِ ٲسۍ پانہٕ وٲنۍ زان پہچان کر نہِ ٹھٔہر یمٕتۍ،﴿تمہِ وقتہٕ سپدِ تحقیق زِ ﴾ پٔزۍ پٲٹھۍ روٗدۍ سخت خسارس  منٛز تِم لُکھ یِمو اللہ تعالیٰ سٕندِس ملا قا تس بُتھ پھِیُر تہٕ ہر گز ٲسۍ نہٕ تِم سیٚزِ وَتہِ پٮ۪ٹھ۔"
  10,46,"۔یِمو بُرٕ نتیجو نِشہِ یِم أسۍ کھۅژناوان چِھکھ ،تِہُند کانٛہہ حصہٕ ہاوَو أسۍ تُہٕنزِ حیٲتی منٛز،یا تمہِ برونٹھُے تُلو أسۍ توٚہۍ،بہر حال چُھ یُن یِمن اَسی کُن تہٕ یِکینژھاہ یِم کران چِھ تتھ پٮ۪ٹھ چُھ اللہ تعالیٰ گواہ۔"
  10,47,"۔پرٛتھ اُمّت خٲطرٕ چُھ اکھ رسول ،﴿اُمّت لفظ چُھنہٕ یَتھ جایہِ محض قو م کِس معنیس منٛز، بلکہ أکِس رسول سٕندِ یِنہٕ پتہٕ یِمن یِمن لُکن تام تٔمۍ سٕنز دعوت واتہِ ،تِم سٲری چِھ تٔمۍ سٕندِس اُمّتس منٛز شٲمل، بیٚیہِ چُھنہٕ امہِ خٲطرٕ یِتہٕ ضروری زِ رسول آسہِ تِمن در میان زِ ندہ موجود، بلکہ رسول سٕندِ پتہٕ تہِ یوٚت تام تٔمۍ سٕنز تعلیم موجود روزِ پرٛتھ شخصہٕ سٕندِ خٲطرٕ آسہِ یہِ معلو م کرُن ممکن زِ در حقیقت کمہِ چیز چ تعلیم اوس سُہ دِوان ،تتھ وقتس تام یِن دُنیا ہٕکۍ سٲر ی لُکھ تٔمۍ سٕندی اُمّت قرار دِنہٕ ،تہٕ تِمن پٮ۪ٹھ سپدِ سُہ حکم ثٲبت یُس برونٹھ کُن یِیہِ بیان کر نہٕ۔ امہِ لحا ظہٕ چِھ محمد صلی اللہ علیہ وسلمن ہٕنزِ تشر یف آوری پتہٕ تمام دنیا ہٕکۍ انسان تِہٕنز ا مّت ،تہٕ تتھ وقتس تام روزن یوٚت تام قرآن پننِس خٲلص صورتس منٛز موجود چُھ۔ اَمی وجہ کِنۍ آو نہٕ آیتس منٛز یہِ فر ماو نہٕ زِ  پرٛتھ قو مس منٛز  چُھ اکھ رسول  بلکہ چُھ ارشاد یہِ سپُد مُت زِ  پرٛتھ اُمّتہٕ خٲطرٕ چُھ اکھ رسول۔﴾  پتہٕ ییٚلہِ کٲنٛسہِ اُمّتس نِشہِ تٔمۍ سُند رسول چُھ یِوان،تیٚلہِ چِھُ تٔمۍ سُند فٲصلہٕ پوٗرٕ انصا ف سان مۅ کلا و نہٕ یِوان ،تہٕ تس پٮ۪ٹھ چُھنہٕ ذَرّس یوت ظُلم یِوان کر نہٕ۔"
  10,48,"۔وَنان چِھ زِ اگر تُہٕنز یہِ دھمکی پٔز چھےٚ تیٚلہِ کر گژِھہ یہِ ٲخر پوٗرٕ؟"
  10,49,"۔ؤنِو  میٲنِس اختیارس منٛز چُھنہٕ خۅد پنُن نفع تہٕ نقصا ن تہِ ،سورُے کینٛہہ چُھ اللہ تعالیٰ سٕندِ س مٔشیتس پٮ۪ٹھ موقوف،پرٛتھ اُمّت خٲطرٕ چھےٚ مہلتٕچ اکھ مُدّت مقرر،ییٚلہِ یہِ مُدّت پوٗرٕ چھےٚ سپدان،تیٚلہِ چُھنہٕ أکِس گھرِ سُمب سُل تہٕ ژیر سپدان۔"
  10,50,"۔یِمن ؤنِو ،تۅہیہِ سوٗ نچوٕہ زانٛہہ یہِ زِ اگر اللہ تعالیٰ سُند عذا ب اچا نک رٲتھۍ کِیُت یا دۅ ہلہِ یِیہِ ﴿تیٚلہِ کیا ہیٚکِو توٚہۍ کٔرِ تھ تَمہِ ساعتہٕ﴾،یہِ کیا چُھ ٲخٕر تِیُتھ چیز ییٚمہِ خٲطرٕ مُجر م بانبٕر کر ن؟"
  10,51,"۔کیا ییٚلہِ سُہ تۅہیہِ پٮ۪ٹھ واتہِ تمی وقتہٕ مٲنِوٕ ہ توٚہۍ سُہ؟ وۅ نۍ چِھو بچُن یژھان؟ حالانکہ توٚہۍ ٲسِو خۅد بذا ت امہِ کہ جلد ی یِنُک تقا ضہٕ کران !"
  10,52,"۔پتہٕ یِیہِ ظٲلِمن وَننہٕ زِ وۅ نۍ وُچھِو پو شوٕ نہِ عذا بُک مٕز ہ، یِکینژھا ہ توٚہۍ کما وان چِھو روٗدِمٕتۍ تمہِ کہ پاداش ورٲے کُس بد لہٕ یِیہِ تۅہیہِ دِنہٕ ؟"
  10,53,"۔پتہٕ چِھ پٕرٛژھان کیا پٔزۍ پٲٹھۍ چھا تہِ پوٚز یہِ توٚہۍ وَنان چِھو؟ ؤنِو  میٲنِس ربّ سُند قسم ،یہِ چُھ بالکل پوٚز، تہٕ تۅہیہِ چُھو نہٕ تیوٗت بل بوتہٕ زِ توٚہۍ ہیکِو سُہ ظہورس منٛز یِنہٕ نِشہِ رُکٲوِتھ۔ع۔"
  10,54,"۔اگر پرٛتھ کٲنٛسہِ تس شخصس نِشہِ ییٚمۍ ظُلم چُھ کوٚرمُت۔رو ے زمینٕچ دو لت تہِ آسہِ ،سُہ گژِھہ تمہِ عذا ب نِشہِ بچنہٕ خٲطر تتھ فِدیس منٛز دِنس پیٹھ آمادٕہ ییٚلہِ یِم لُکھ سُہ عذاب وُچھَن ،پتہٕ پچھتاون دِلہٕ مٔنزی،مگر تِمن در میان یِیہِ پوٗرٕ انصا ف سان فٲصلہٕ کرنہٕ، کانٛہہ ظُلم سپدِنہٕ تِمن پٮ۪ٹھ۔"
  10,55,"۔بوٗزِو ! آسمانن تہٕ زمینس اندر یِکینژھاہ چُھ سُہ چُھ اللہ تعالیٰ سُند،بوٗزِ تھ تھٲوِو ! اللہ تعالیٰ سُند وعدہ چُھ پوٚز،مگر اکثر انسان چِھنہٕ زانان۔"
  10,56,"۔سُے چُھ زند گی بخشا ن تہٕ سُے چُھ مو ت دِوان،تہٕ تٔسۍ کُن چُھ سارِنٕے پوٚت پھیرِتھ گژُھن۔"
  10,57,"۔ہے لوٗکو، تۅہیہِ نِشہِ چھےٚ تُہٕندِس ربّ سٕندِ طر فہٕ نصیحت آمٕژ، یہِ چُھ سُہ چیز یُس دل کیٚن داد ین شفا چُھ تہٕ یِم اتھ قبول کر ن تِہندِ خٲطرٕ چُھ رہنمٲیی تہٕ رحمت۔"
  10,58,"۔اے نبی صلی اللہ علیہ وسلم،ؤنِو زِ  یہِ چُھ اللہ تعالیٰ سُند فضل تہٕ تٔمۍ سٕنز مہر بٲنی زِ یہِ چیز سوٗز تٔمۍ، اتھ پٮ۪ٹھ پزِ لُکن خو شی منا وٕ نۍ، یہِ چُھ تِمو سارِوٕے چیز و کھۅتہٕ بہتر یِمن لُکھ چِھ جمع کران۔"
  10,59,"۔اے نبی صلی اللہ علیہ وسلم یِمن ؤنِو  تۅہیہِ لُکو چُھوٕ زانٛہہ یِتہِ سو نچمُت زِ یُس رزق خُدا ین تُہٕندِ خٲطرٕ وولمُت اوس۔﴿ اُردو زبٲنۍ منٛز یا کٲشرۍ پٲٹھۍ چِھ رزق ، کھیٚنہٕ چیٚنہٕ کیٚن چیزن ونان ۔ مگر عر بی زبٲنۍ منٛز چُھنہٕ یہِ خۅراک سٕے تام محدوٗد بلکہ چُھ عطا ،بخشش تہٕ نصیب کِس معنیس منٛز تہِ عام۔ خُدا ین یِکینژھاہ اِنسا نس دُنیا ہس منٛز دِیتمُت چُھ سُہ سورُے چُھ تٔمۍ سُند رِزق ﴾ تمہِ منٛزٕ کوٚر ُو تۅہیہِ پانے کانٛہہ چیز حرام تہٕ کانٛہہ حلال ! ﴿یعنی توٚہۍ بنییو خۅد بذا ت قا نو ن تہٕ شر یعت بنا ونٕکۍ مختار۔حالانکہ ییٚمۍ سُند رِزق چُھ تٔمۍ سُند چُھ یہِ حق زِ امہِ کیٚن استعمال کیٚن جٲیز تہٕ نا جا یز صوٗرتن خٲطرٕ کرِ حدود تہٕ اصول مُقرر﴾ یِمن پٕرژِھو، خُداین اوسا تۅہیہِ اَمِیُک اجازت دِیتمُت؟ کِنہٕ توٚہۍ چِھو خُدا یس پٮ۪ٹھ اِفترا کران ﴿اَپُز کھالان﴾؟ ﴿اِفترا ہس چھےٚ ترے صورتہٕ : اکھ یہِ زِ کانٛہہ شخص وَنہِ یہ زِ یِم اختیارات چِھ خُدا ین انسانن حوالہٕ کٔرِمٕتۍ،دوٚیُم یہِ زِ سُہ وَنہِ زِ اللہ تعالیٰ سٕنز چَھنہٕ یہِ کٲمٕے زِ سانہِ خٲطر کرِ قا نو ن تہٕ شر یعت مُقرر،تریُیم  یہِ زِ سُہ کرِ حلال و حرا مٕکۍ یِم احکام خُدا یس کُن منسوٗب حالانکہ بطورِ سَنَد ہیٚکہِ نہٕ اللہ تعالیٰ سٕنز کانٛہہ کتا ب پیش کٔرِتھ ﴾"
  10,60,"۔یِم لُکھ خُدا یس پٮ۪ٹھ  یہِ اَپُز اِفترا گنڈا ن چِھ ، تِہُند کیا گُمان چُھ زِ قیامت کہ دۅہ کیا معاملہ سپدِ تِمن سٍتۍ؟اللہ تعالیٰ چُھ لُکن پٮ۪ٹھ مہر بٲنی ہٕنز نظر تھاوان۔مگر اکثر انسان چِھ تِتھۍ یِم شکر چِھنہٕ کران ۔ ع"
  10,61,"۔اے نبی صلی اللہ علیہ وسلم،توٚہۍ یتھ حالس منٛز تہِ آسان چِھو تہٕ قرآن منٛزٕ یِکینژھاہ تہِ بوزناوان چِھو،تہٕ لوٗکو ،توٚہۍ تہِ یِکینژھاہ کران چِھو،اَتھ سٲرِسٕے دورا ن چِھو أسۍ تۅہیہِ وُچھان روزان،کانٛہہ ذَرّس یوت چیز چُھنہٕ آسما نس یا زمینس منٛز تِیُتھ ،یُس تُہٕندِس ربّس نِشہِ پو شیدٕ ہ آسہِ ، نَہ لۅ کُٹ تہٕ نَہ بوٚڈ، تہٕ أکِس صا ف کتا بہِ منٛز آسہِ نہٕ در ج۔"
  10,62,"۔بوٗزِ و ! یِم اللہ تعالیٰ سٕندۍ دوست چِھ ، تِمن خٲطرٕ چُھنہٕ کُنہِ خو فُک مو قع۔"
  10,63,"۔﴿یِم چِھ تِمے ﴾ یِمو ایمان اوٚن تہٕ یِمو تقویٰ ہُک رٔوِیہِ اختیار کوٚر۔"
  10,64,"۔دنیا تہٕ ٲخرت دۅ شوٕنۍ زند گِیَن منٛز چھےٚ تِہندِ خٲطرٕ بشارتٕے بشارت، اللہ تعالیٰ سٕنزٕ کتھہٕ ہیٚکن نہٕ بد لتھ،یٔہے چھےٚ بٔڑ کا میٲبی ۔"
  10,65,"۔ اے نبی صلی اللہ علیہ وسلم ،یِمہٕ کتھہٕ یِم لُکھ تۅہیہِ پٮ۪ٹھ بناوان چِھ ، تمہٕ مَہ کٔرِنَو تۅہیہِ غمگین،عزت چُھ اَند ہیٚتھ اللہ تعالیٰ سٕندِس اختیارس منٛز، تہٕ سُہ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  10,66,"۔با خبر روٗزِو ! آسما نن ہٕندۍ بسن وٲلۍ آسِتن یا زمینٕکۍ ،سٲری چِھ اند ہیٚتھ اللہ تعالیٰ سٕندۍ مملوٗک، تہٕ یِم لُکھ خُدا یس ورٲے کینژھن ﴿پننیٚن خۅد ساختہٕ ﴾ شر یکن چِھ ناد لایان،تِم چِھ صا ف پٲٹھۍ وہم و گما نٕکۍ پیروکار،تہٕ محض چِھ قیاس آرٲیِیہِ کران۔"
  10,67,"۔سُہ چُھ اللہ تعالیٰ ہٕے ییٚمۍ تُہٕندِ خٲطرٕ رات بنٲو تا کہ اتھ منٛز کٔرِ و سکو ن حا صل۔تہٕ دۅہ بنو وُن گا شدار،اَتھ منٛز چھےٚ نشٲنِیہِ تِمن لُکن خٲطرٕ یِم ﴿کن مٕژرٲوِتھ پیغمبر سٕنٛز دعوت ﴾ چِھ بوزان۔"
  10,68,"۔لوٗکو ووٚن زِ خُدا ین چُھ کُستام نیچُو بنو و مُت، سُبحان اللہ! سُہ چُھ بے نیا ز،آسمانن تہٕ زمینس منٛز یِکینژھاہ چُھ، سورُے چُھ تٔمۍ سُندُے ملکیت تۅہیہِ نِشہِ کیا دلیل چھےٚ ٲخر اَمہِ کتھہِ ہٕنز؟کیا توٚہۍ چِھوٕ ہ خُدا یس متعلق تِمہٕ کتھہٕ وَنان ، یِمہٕ تُہٕندِس عِلمَس منٛز چَھنہٕ؟"
  10,69,"۔اے نبی صلی اللہ علیہ وسلم، ؤنِو زِ یِم لُکھ خُدا یس پٮ۪ٹھ اَپُز اِفترا ﴿بہتان ﴾ چِھ کھالان تِم لبن نہٕ ہر گز فلا ح۔"
  10,70,"۔دنیا چہِ کینژھن دۅ ہن ہٕنزِ زند گی منٛز کٔرۍ تن مزہ، پتہٕ چُھ تِمن اسہِ کُن وا پس پھیرُن،پتہٕ وُچھنا ووکھ أسۍ سخت عذا بُک مزٕ ہ تمہِ کفرٕ بد لہٕ یُس تِم کران چِھ ۔ع"
  10,71,"۔یِم بوز ناوِ یوٗکھ نو ح علیہ السلام سُنٛد قصہٕ، تمہِ وقتُک قصہٕ ،ییٚلہِ تٔمۍ پننِس قو مس اوس ووٚنمُت زِ  اے برادرانِ قو م، اگر میو ن تۅہیہِ در میان روزُن تہٕ اللہ تعالیٰ سٕندۍ آیات بوزنٲوۍ بوزنٲوۍ توٚہۍ غفلت نِشہِ بیدار کرٕنۍ نا قا بلِ برداشت چُھ سپُد مُت تیٚلہِ چُھ میو ن بھر وسہٕ خُدا یس پٮ۪ٹھ، توٚہۍ کٔرِ و پنٕنۍ ٹھٔہراونہٕ آمٕتۍ شر یک پا نس سٍتۍ رٔٹِتھ اکھ مُتفقہٕ فٲصلہٕ تہٕ یُس منصوبہٕ تۅہیہِ پیشِ نظر آسہِ ، سُہ سمجھِو ٹھیک پٲٹھۍ تاکہ تَمِیُک کانٛہہ پٔہلو روزِ نہٕ تُہنزِ نظرِ منٛز پوٗشیدہ، پتہٕ أنیوٗن سُہ مےٚ خلا ف عملہِ منٛز ،تہٕ مےٚ مَہ دِیِو ہر گز مہلت۔"
  10,72,"۔تۅہیہِ پھرُو میانہِ نصیحت نِشہِ بُتھ ﴿مےٚ کُس نقصا ن کوٚرُو﴾ بہٕ اوسُس نہٕ تۅہیہِ نِشہِ کُنہِ اَجرُک طلب گار،میون اَجر چُھ خُدایس ذِمہٕ تہٕ مےٚ چُھ حکم آمُت دِنہٕ زِ ﴿خواہ کانٛہہ مٲنۍ تن یا متہٕ مٲنۍ تن ﴾ بہٕ گژھہ پانہٕ مسلم بٔنِتھ روزُن۔"
  10,73,"۔تِمو کوٚرتَس انکار تہٕ نتیجہِ درٛا ویہِ زِ اَسہِ بچو و سُہ تہٕ تِم لُکھ یِم تَس سٍتۍ ناوِ منٛز سوار ٲسۍتہٕ تِمے بنٲوۍ زمینس اندر جا نشین تہٕ تِم سار ی لُکھ کٔرۍ غر ق، یِمو سا نیٚن آیا تن بُتھ اوس پھِیرُمُت،۔لہٰذا ،وُچِھو زِ یِمن تنبیہ اوس کر نہٕ آمُت﴿مگر تِمو ۂیژ تو تہِ تکبرس کٲم ﴾ تِمن کیا انجام سپُد۔"
  10,74,"۔ پتہٕ سوٗزۍ اَسہِ نو ح ﴿علیہ السلامس﴾ پتہٕ مختلف پیغمبر تِہند ٮ۪ن قو من کُن تہٕ تِم آے تِمن نِشہِ ٹا کارٕ نشٲنیہِ ہیٚتھ،مگر یَتھ چیز س تِمَو گۅڈٕ ہ انکار اوس کوٚر مُت،تِمَو اوٚ ن نہٕ بیٚیہِ تَتھ پٮ۪ٹھ ایمان ،یتھہٕ پٲٹھۍ چِھ أسۍ حدٕہ نیر ن والیٚن ہٕندٮ۪ن دِلن پٮ۪ٹھ ٹھپہٕ لگاوان۔"
  10,75,"۔پتہٕ سوٗز تِمن پتہٕ اَسہِ مو سیٰ علیہ السلام تہٕ ہارون علیہ السلام فر عو نس تہٕ تٔمۍ سٕندٮ۪ن سردارن کُن پننہِ نِشٲنِیہِ ہیٚتھ، مگر تِمو کوٚر پننہِ بجر ک تکبر تہٕ تِم ٲسۍ مجر م لُکھ۔"
  10,76,"۔لہٰذا ، ییٚلہِ سانہِ طر فہٕ حق تِمن برونٛہہ کُن آو،پتہٕ ووٚن تِمو زِ یہِ چُھ نَنہِ وانہٕ جو د۔"
  10,77,"۔مو سیٰ ﴿علیہ السلامن﴾ ووٚن توٚہۍ چِھوٕ ہ حقس یہِ وَنان ییٚلہِ زن سُہ تۅہیہِ برونٛہہ کُن آو ؟ کیا یہِ چھا جو د؟ حالانکہ جادو گر چِھنہٕ فلا ح لبا ن ﴿ مطلب چُھ یہِ زِ ظٲہر نظرِ منٛز یُس ہِشر جٲدِس تہٕ معجز س در میا ن آسان چُھ تتھ بُنیادس پٮ۪ٹھ دِیٛتو تۅہیہِ لُکو بے تکلّف یہِ جود قرار، مگر نا دا نو ،تۅہیہِ وُچھوٕ نہٕ یہِ زِ جادو گر کمہِ سیر تٕکۍ تہٕ اخلا قٕکۍ لُکھ چِھ آسان تہٕ کمو مقصد و خٲطرٕ چِھ جا دوٗگر ی کران۔کیا کانٛہہ جادو گر چھا بے غر ض پٲٹھۍ تہٕ بے خو ف پٲٹھۍ کٲنٛسہِ زبردست فر مان روا سٕندِس در بارس منٛز یِوان تہٕ تس چُھ گُمر ٲہی پٮ۪ٹھ کنہٕ دٔر کران ، تہٕ تس چھا خُدا پرستی تہٕ طہارتِ نفس اختیار کر نٕچ دعوت دِوان ؟﴾"
  10,78,"۔تِمو ووٚن در جوا ب  کیا ژٕ چُھکھہٕ امہِ موجو ب آمُت زِ اَسہِ پھِرَکھ تمہِ طر یقہٕ نِشہِ یَتھ پٮ۪ٹھ اَسہِ پنُن مو ل بُڈِ بب چُھ  وُچھمُت تہٕ زمینس منٛز گژِھہ تۅہیہِ دۅ ن ہُند زٕ چھر قٲیِم سپدُن؟ چٲنۍ کتھ چِھنہٕ أسۍ مانن وٲلۍ۔"
  10,79,"۔تہٕ فر عو نَن ووٚن﴿ پننیٚن نفر ن﴾ زِ پرٛتھ کانٛہہ مٲہر فن جادو گر کٔرِ یوٗن مےٚ برونٛٹھہٕ کنہِ حٲضر۔"
  10,80,"۔ییٚلہِ جادو گر آے ،پتہٕ چُھ موسیٰ علیہ السلام تِمن وَنان۔ یِکینژھاہ تۅہیہِ چَھکُن چُھو چھٔکِو"
  10,81,"۔پتہٕ ییٚلہِ تِمو پنٕنۍ اَنچھر ﴿مٲتھٕر ، تِم لفظ یِم جادو گر پَران چِھ ﴾ چٔھکۍ ،موسیٰ ﴿علیہ السلامن﴾ ووٚن یِکینژھاہ تۅہیہِ چھوٚ کُو یہِ چُھ جود، اللہ تعالیٰ کرِ اَتھ وُنی بٲطِل ﴿ثٲبت﴾،فسادیٚن ہٕنزِ  کامہِ چُھنہٕ اللہ تعالیٰ سِیوٚد دِوان گژھنہٕ،"
  10,82,"۔تہٕ اللہ تعالیٰ چُھ پننیٚو فر مانَو سٍتۍ حقس حق بنٲوِتھ ہاوان، خوا ہ مجرِ من سُہ کوتاہ تہِ نا گُوار سپدِ۔ع"
  10,83,"۔﴿پَتہٕ وُچِھو ﴾ زِ موسیٰ علیہ السلام مو ن نہٕ تٔمۍ سٕندِ قو مہٕ منٛزٕ کینژھو نَو جوا نَو ورٲے بیٚیہِ کٲنٛسہِ ﴿متَنس منٛز چُھ لفظ  ذُرِّیَّتہ استعمال سپُد مُت۔یَتھ معنی چُھ اولاد۔اَسہِ کوٚر اَتھ تر جمہٕ  نوجو ان۔ در اصل یوسہٕ کتھہ امہِ خا ص لفظہٕ کہ وَرتا و نہٕ سٍتۍ قرآن مجید چُھ بیان کرٕنۍ یژھان،سۅ چھےٚ یہِ زِ تتھ پُر خطر زمانس اندر کوٚر کینژھو لٔڑ کَو تہٕ کور یٚو حقس ساتھ دِنُک حقُک علمبردار پنُن رہنما تسلیم کر نُک جُر ات مگر  مالیٚن ماجن تہٕ قو م کیٚن عمر رسیدٕ ہ لُکن سَپُد نہٕ یہِ تو فیق نصیب۔تِمن  پٮ۪ٹھ روٗز مصلحت پر ستی بیٚیہِ دُنیا وی اغرا ضن ہٕنز بند گی تہٕ عا فیت کو شی تِتھہٕ پٲٹھۍ غٲلب زِ تِم سپٕدۍ نہٕ تِتھس حقس ساتھ دِنس پٮ۪ٹھ آمادٕہ ییٛمِچ وَتھ تِمن خطر اتَو سٍتۍ بٔرِ تھ ٲس باسان، بلکہ روٗدۍ تِم پوٚت پھِرِ تھ نو جو ان نٕے رُکاوان زِ موسیٰ علیہ السلامس نکھہٕ مَہ گٔژِھو، نَتہٕ گٔژِھو توٚہۍ تہِ فر عو ن سٕندِس غضبس منٛز گرفتار تہٕ اَسہِ پٮ۪ٹھ أنِو مصیبت﴾ فرعو ن سٕندِ ڈر سٍتۍ تہٕ خۅد پننہِ قو م کیٚن رسوخ والیٚن لُکن ہٕندِ ڈر سٍتۍ﴿یِمن خو ف اوس﴾ زِ فرعون کرِ تِمن عذا بس منٛز مبتلا تہٕ پَز ر چُھ یہِ زِ فر عو نس اوس زمینس اندر غلبہٕ تہٕ سُہ اوس تِمو لُکو منٛزٕ یِم کُنہِ حدس پٮ۪ٹھ چِھنہٕ رُکا ن۔﴿یعنی پنُن مطلب کڑ نہٕ خٲطرٕ چِھنہٕ تِم کانٛہہ بُرٕ کھۅتہٕ بُرٕہ طر یقہٕ وَرتاونس منٛز تہِ  ہر اسہٕ  کران۔تِم چِھنہٕ کانٛہہ ظُلم ،کانٛہہ بد اخلٲقی ،کانٛہہ وحشت تہٕ بر بر یت وَرتاو نس کھۅژان۔ پننیٚن خوٲہشا تن ہٕندِ موجو ب ہیٚکن تِم کُنہِ تہِ اِنتہا ہس تام وٲتِتھ۔ تِمن خٲطرٕ چُھنہٕ کانٛہہ حد یَتھ پٮ۪ٹھ وٲتِتھ تِم پتھ روزَن﴾"
  10,84,"۔موسیٰ ﴿علیہ السلامن﴾ ووٚن پننِس قو مس زِ  لوٗکو،اگر توٚہۍ پٔزۍ پٲٹھۍ خُدا یس پٮ۪ٹھ ایمان چِھو تھاوان، تیٚلہِ کٔرِو تس پٮ۪ٹھ بھر وسہٕ اگر مسلمان چِھو،"
  10,85,"۔تِمو دِیُت جوا ب ، اَسہِ کوٚر اللہ  تعالیٰ سٕے پٮ۪ٹھ بھر وسہٕ،اے سانہِ ربّ ،اسہِ مَہ بنا و ظالم لُکن خٲطرٕ فِتنہٕ۔"
  10,86,"۔تہٕ پننہِ رحمت سٍتۍ دِہ اَسہِ کٲفر و نِشہِ نجات۔ ﴿یہِ جوا ب اوس تِمن نو جوا نن ہُند یِم موسیٰ علیہ السلامس ساتھ دِ نس پٮ۪ٹھ آمادہ ٲسۍ سپٕدۍ مٕتۍ۔یتھ جایہِ چُھنہٕ ﴿قَالُو ا﴾ ہُک  ضمیر قو مس کُن کینٛہہ بلکہ چُھ ﴿ذُرّیَّتھ ﴾ لفظس کُن پھیران یِتھہٕ پٲٹھۍ زَن کلا م کہ سلسلہٕ سٍتۍ  خۅد پے چُھ لگان ﴾"
  10,87,"۔تہٕ اَسہِ کوٚر مو سیٰ ﴿علیہ السلامس ﴾ تہٕ تٔمۍ سٕندِس بٲیِس اشارٕہ۔ زِ  مصرس منٛز کٔرِ و پننہِ قو م خٲطرٕ کینٛہہ مکا نہٕ فرا ہم،تہٕ پنٕنۍ یِم مکا نہٕ ٹھٔہرٲوِیوٗکھ قبلہٕ، بیٚیہِ کٔرِ و نما ز قٲیِم ﴿مصرس  منٛز اوس حکو مت کہ تشددٕ سٍتۍ خۅد بنی اسرا یل چہِ پننہِ ایمان چہِ کمزور ی کِنۍ اسرا یلی تہٕ مصر ی مُسلمانن منٛز با جما عت نمازِہُند نظام ختم سپُد مُت، تہٕ یہِ اوس تِہُند شیرازٕہ چھلہٕ چھا نگرِ سپد نُک تہٕ تِہِندِس دینی رُو حس پٮ۪ٹھ مو ت طٲر ی سپدَنُک اکھ سٮ۪ٹھاہ بوٚڈ سبب۔امہِ موجو ب آو حضرت مو سیٰ علیہ السلامس حکم دِنہٕ زِ یہِ نظام کٔرِن نِو سرٕ قٲیم تہٕ مِصرس منٛز گژھن کینٛہہ مکا نہٕ اَمہِ غر ضہٕ خٲطرٕ تعمیر یا تجو یز کر نہٕ یِنۍ تَتہِ گژِھہ اجتمٲعی نماز ادا کر نہٕ یِنۍ۔یِم مکانہٕ قبیلہٕ ٹھہرا ونُک مطلب چُھ یہِ زِ یِم مکا نہٕ گژھن سار ی قو م خٲطرٕ مر کز تہٕ مر جع ٹھہرا و نہٕ یِنۍ ،تہٕ امہِ پتے نماز قٲیِم کر نُک۔ مطلب چُھ یہِ زِ بیوٚ ن بیوٚن پننہِ جایہِ نماز پر نہٕ  بجا یہ، پٔرِن یِمن مقرر کر نہٕ آمژن جا ین پٮ۪ٹھ جمع سپدِ تھ نماز﴾ تہٕ اہلِ ایمانن دِیو بشارت ۔"
  10,88,"۔موسیٰ ﴿علیہ السلامن ﴾ کوٚر دُعا  اے سانہِ ربّ ،ژےٚ چِھی فرعو ن تہٕ تِہندِ ۍ سردار دُنیا چہِ زند گی منٛز زینت سٍتۍ تہٕ مالَو سٍتۍ نوٲزِ مٕتۍ۔اے ربّ ،کیا یہِ چھا امہِ موجو ب زِ تِم ڈا لن لُکن چانہِ وَتہِ نِشہِ ؟ اے ربّ ،یِہِندۍ مال کرُکھ برباد تہٕ یِہِندٮ۪ن دِلن پٮ۪ٹھ کر تِژھ مۅ ہر زِ ایمان اَنن نہٕ یوٚت تام نہٕ دگ تُلوُن عذا ب وُچَھن۔ ﴿یہِ دُعا اوس حضرت موسیٰ علیہ السلامن قیا مِ مصر کِس با لکل ٲخر ی زمانس منٛز کوٚر مُت، تہٕ تمہِ وقتہٕ اوسُن کوٚر مُت ییٚلہِ پوٚتُس پتھ نشٲنیہِ وُچھنہٕ پتہٕ تہٕ دینٕچ حُجت پوٗرٕ سپد نہٕ پتہٕ تہِ فر عو ن تہٕ تٔمۍ سٕندِ سلطنتٕکۍ سر کردٕہ لُکھ حق چہِ دشمنی پٮ۪ٹھ انتہٲیی ہٹ دھر می سان جمِتھ روٗدۍ۔یِتھِس مو قعس پٮ۪ٹھ یُس  بد دُعا پیغمبر کران چُھ، سُہ چُھ ٹھیک ٹھیک سُے آسان یُس کُفرس پٮ۪ٹھ اصرار کر ن والیٚن متعلق خۅد اللہ تعالیٰ سُند فٲصلہٕ چُھ آسان، یعنی یہِ زِ پتہٕ گژِھہ نہٕ یِمن ایمانُک تو فیق یُن بخشنہٕ﴾"
  10,89,"۔خُدا ین فر مو در جواب  تۅہیہِ دۅ شٕونۍ ہُند دُعا آو قبول کر نہٕ، ثٲبت قد م روٗزِ و تہٕ تِمن لُکن ہٕندِ طر یقٕچ پیروی مَہ کٔرِو ہر گز یِمن علم چُھنہٕ۔"
  10,90,"۔تہٕ اَسہِ تٲرۍ بنی اسرا یل سمندرس اَپور،پتہٕ دورِ یٚا و فر عو ن تہٕ تٔمۍ سٕندۍ لشکر تِمن ظلم تہٕ زیادتی ہٕندِ غر ضہٕ پتہٕ ،حتیٰ کہ ییٚلہِ فرعو ن ڈُبنہِ لوٚگ تٔمۍ لو گ وَنُنمےٚ مو ن خُدا وندِ حقیقی تس ورٲے چُھنہٕ کانٛہہ ،یس پٮ۪ٹھ بنی اسرا یلو ایمان اوٚ ن، تہٕ بٕتہِ چُھس سرِ اطا عت نوٚ مر اوَن والیو منٛزٕ۔"
  10,91,"۔﴿جوا ب آس دِنہٕ﴾ وۅ نۍ چُھکھہٕ ایمان اَنان ! حالانکہ ییٚمہِ برونٛہہ تام روٗدُکھ ژٕ نا فر نی کران،بیٚیہِ اوسُکھ فساد کر ن والیو منٛزٕ۔"
  10,92,"۔وۅ نۍ بچا وَو أسۍ صرف چٲنۍ لا شی یٲژ تا کہ ژٕ بنکھ یِنہٕ والیٚن نسلن خٲطرٕ عبر تُک نِشانہٕ اگر چہِ واریاہ اِنسان تِتھۍ چِھ یِم سانیو نِشٲنِیو نِشہِ غفلت چِھ وَر تاوان۔ع"
  10,93,"۔اَسہِ دِیُت بنی اسرا یلس سٮ۪ٹھاہ رُت ٹھکا نہٕ تہٕ تِمن کٔرۍ زند گی ہٕندۍ سٮ۪ٹھاہ جان و سٲیل عطا ، پتہٕ کوٚر نہٕ تِمو پانہٕ وٲنۍ اختلاف مگر تمہِ وقتہٕ کوٚرُکھ ییٚلہِ علم اوس تِمن نِشہِ آمُت، پٔزۍ پٲٹھۍ کرِ تُہُند ربّ قیا مت کہ دۅ ہ تِمن در میان اَمہِ چیزُک فٲصلہٕ۔ یتھ منٛز تِم اختلا ف چِھ کران روٗزِ مٕتۍ۔"
  10,94,"۔وۅ نۍ اگر توٚہیہِ ییٚمہِ ہدا یت کہ طر فہٕ کینٛہہ تہِ شک آسہِ یُس اَسہِ تۅہیہِ پٮ۪ٹھ نٲزِل چُھ کوٚر مُت تیٚلہِ پٕرٛژِھو تِمن لُکن یِم گۅڈٕ پٮ۪ٹھے کتاب چِھ پران، در حقیقت چُھ یہِ تۅہیہِ نِشہِ حقٕے آمُت تُہٕندِس ربّ سٕندِ طر فہٕ،لہٰذا گٔژِھو نہٕ توٚہۍ شک کر ن والیٚو منٛزٕ آسٕنۍ۔"
  10,95,"۔تہٕ لُکن منٛز مَہ گٔژِھو شٲمل ،یِمو اللہ تعالیٰ سٕندٮ۪ن آیا تن بُتھ چُھ پھِیرُ مُت، نَتہٕ ٲسِو توٚہۍ نقصا ن تُلن والیو منٛزٕ۔﴿یہِ خطا ب چُھ بظٲہر  نبی صلی اللہ علیہ وسلمس مگر دراصل چِھ کتھ بوزناوٕنۍ تِم لُکھ یِم حضور  صلی اللہ علیہ وسلمن ہٕندِس دعوتس منٛز شک ٲسۍ کران، تہٕ اہلِ کتا بن ہُند حوالہٕ چُھ امہِ موجو ب دِنہٕ آمُت زِ عر بٕکۍ لُکھ ٲسۍ آسمٲنۍ کتا بن ہٕندِ علمہٕ نِشہِ بے خبر، تِہندِ خٲطرٕ ٲس یہِ آواز اکھ نٔو آواز، مگر اہلِ کتا بو منٛزٕ ،یِم لُکھ دیندار تہٕ مُنصف مزاج ٲسۍ تِم ہیکہَن امہِ کتھہِ ہُند تصد یق کٔرِتھ زِ ییٚمہِ چیزٕ چ دعوت قرآن چُھ دِوان یہِ چُھ سُے چیز ییٚمِچ دعوت تمام پٔتِم پیغمبر دِوان چِھ روٗدِمٕتۍ۔﴾"
  10,96,"۔حقیقت چھےٚ یہِ زِ یِمن لُکن پٮ۪ٹھ تُہندِس ربّ سُند قَو ل راست چُھ آمُت ﴿یعنی یہِ قو ل زِ یِم لُکھ خۅد حقٕکۍ طٲلب چِھنہٕ آسان تہٕ یِم پننیٚن دِلن پٮ۪ٹھ ضد ،تعصُب تہٕ ہٹ دھر می ہٕندۍ قُلف چِھ تھا وان کھٲلِتھ ،تہٕ یِم دُنیا کِس محبتس منٛز مد ہو ش تہٕ عا قبت نِشہِ بے خبر چِھ آسان تِمن چُھنہٕ ایمانُک تو فیق نصیب سپدان﴾"
  10,97,"۔ تِمن نِشہِ یِیہِ تن کانٛہہ تہِ نِشٲنی تِم چِھنہٕ ایمان انان۔"
  10,98,"۔ یوٚت تام نہ دگ تُلوُن عذا ب برونٹھ کُن وُچُھن واتان۔ پتہٕ کیا کانٛہہ تِژھ مثا ل چھا زِ اکہِ بستی آسہِ عذا ب وُچِھتھ ایمان اوٚ نمُت تہٕ تَمِیُک ایمان آسہِ تَتھ خٲطرٕ نفع بخش ثٲبت سپُد مُت؟ یُو نس علیہ السلام سٕندِ قو م وَرٲے ﴿چَھنہٕ اَمِچ کانٛہہ مِثال﴾ تٔمۍ قو من ییٚلہِ ایمان اوس اوٚ نمُت ، البتہٕ اَسہِ اوس تمہِ پٮ۪ٹھہٕ دنیا چہ زند گی منٛز رُسوٲیی ہُند عذا ب ہٹو ومُت ﴿ مُفسر و چُھ اَمِیُک وجہ یہِ بیان کوٚر مُت زِ حضرت یو نس علیہ السلام ٲسۍ عذا بُک اِطلاع دِنہٕ پتہٕ چو نکہ اللہ تعالیٰ سٕندِ اجازت ورٲے پنُن ٹھکانہٕ ترٲوِ تھ درٛ امٕتۍ، امہِ موجوٗب ییٚلہِ عذا بٕکۍ آثا ر وُچھِتھ  اَشور یو تو بہٕ استغفار کوٚر، خُدا ین کوٚر تِمن معا ف ﴾ تہٕ اَتھ اوسُن أکِس وقتس تام زند گی نِشہِ فٲیدٕہ تُلنُک مو قع دِیتمُت۔"
  10,99,"۔ اگر تُہٕندِس ربّ سٕنز مشیت یہِ آسِہے ﴿زِ زمینس منٛز گژھۍ مو من تہٕ فر مان بردارٕے آسٕنۍ﴾ تیٚلہِ آسِہے سارِوٕے زمین کیو لکو ایمان اوٚ نمُت،پتہٕ کیا توٚہۍ کٔرِیوٗکھہٕ لُکھ مجبور زِ تِم بٔنِن مو من ؟"
  10,100,"۔کانٛہہ نفس ہیٚکہِ نہٕ اللہ تعالیٰ سٕندِ اِذ نہٕ ورٲے ایمان أنِتھ،تہٕ اللہ تعالیٰ سُند طر یقہٕ چُھ یہِ زِ یِم لُکھ عقلہِ کٲم چِھنہٕ ہیوان سُہ چُھ تِمن پٮ۪ٹھ گند گی ترٛا وان۔"
  10,101,"۔ تِمن ؤنِو زمینس تہٕ آسمانن اندر یِکینژھاہ چُھ سُہ وُچِھو أچھ مٕژرٲوِتھ۔ تہٕ یِم لُکھ ایمان اَننُے چِھنہٕ یژھان، تِہندِ خٲطرٕ کتہِ ہیٚکن نشٲنیہِ تہٕ تنبیہ ٲخر مفید ٲسِتھ؟"
  10,102,"۔وۅ نۍ کتھ چیز س چِھ یِم لُکھ پراران، اَمِہ ورٲے زِ تِمے خرا ب دۅ ہ وُچھنہٕ یِم ، یِم یِمن برونٹھمیو گُزر یمتیو لُکو وُچِھمٕتۍ چِھ ؟ تِمن ؤنِو  اچھا انتظا ر کٔرِ و ،بٕتہِ کرٕ تۅہیہِ سٍتۍ انتظا ر۔"
  10,103,"۔ پتہٕ ﴿ییٚلہِ سُہ وقت واتان چُھ﴾ أسۍ چِھکھ پنٕنۍ رسول تہٕ تِم لُکھ بچا وان یِمو ایمان آسہِ اوٚ نمُت، سو ن چُھ یہِ حق زِ مو من بچا و وکھ ۔ع"
  10,104,"۔اے نبی صلی اللہ علیہ السلام، ؤنِو زِ  اے لوٗکو، اگر توٚہۍ وُنُیستام میٲ نِس دینس متعلق کُنہِ شکس منٛز چِھو ، تیٚلہ، بوزِ وزِ خُدا یس ورٲے یِہٕنز عبادت توٚہۍ کران چِھو، بہٕ چُھسنہٕ تِہٕنز عبا دت کران،بلکہ چُھس صرف تس اللہ تعالیٰ سٕنز بند گی کران ییٚمۍ سٕندِس قبضس منٛز تُہُند مو ت چُھ، مےٚ چُھ حکم دِنہٕ آمُت زِ بہٕ گژٕھہ ایمان اَنن والیو منٛزٕ آسُن۔"
  10,105,"۔تہٕ مےٚ چُھ فر ما و نہٕ آمُت زِ یکسوٗ سپدِ تھ کرٕ پنُن پان ٹھیک ٹھیک یتھ دینس پٮ۪ٹھ قٲیم،﴿اصل لفظ چِھ  أَقِم وَجھَکَ لِلدّیِن حَنیِفَا  اَتھ چُھ لفظی معنی پنُن بُتھ جماو  اَمیُک مفہو م چُھ یہِ زِ تُہُند رُخ گژِھہ أکۍ سٕے اندس کن قٲیم سپدُن ، سُہ گژِھہ نہٕ اورٕ یو ر گژھان آسُن۔سُہ گژِھہ نہٕ گرا پتھ کُن گرا برونٛہہ کُن تہٕ کُنہِ وِزِ گرادٔچُھن تہٕ گرا کھووُر پھیران آسُن۔بلکہ پٔکِوِ نستہِ سیوٚد تتھۍ وَتہِ پٮ۪ٹھ نظر جمٲوِتھ یۅسہٕ وَتھ تۅہیہِ ہاو نہٕ چھےٚ آمٕژ۔یہِ بند ش ٲس بجا ے خۅد سٮ۪ٹھاہ چُست مگر اتھ پٮ۪ٹھ تہِ آو نہٕ بس کر نہٕ۔ اتھ پٮ۪ٹھ آو بیٚیہِ اکھ قٍید  حنیفاً ہُر روا نہٕ۔ حنیف چِھ تس ونان یُس سارِوٕے طر فَو نِشہِ پھیرِ تھ صرف أکِس طر فس کُن آسہِ ﴾ تہٕ ہر گز تہٕ ہر گز گژٕھہ نہٕ مشر کو منٛزٕ آسُن۔"
  10,106,"۔ تہٕ اللہ تعالیٰ ترٲوِ تھ مَہ لٲیِو کٲنٛسہِ تِژھہ ہستی آلَو، یوسہٕ نَہ تۅہیہِ فٲیدہ ہیٚکہِ واتنٲوِتھ تہٕ نہ نقصا ن، ہرگاہ توٚہۍ یہِ کٔرِ و ،تیٚلہِ ٲسِو ظٲلِمو منٛزٕ۔"
  10,107,"۔اگر اللہ تعالیٰ تۅہیہِ کُنہِ مصیبتس منٛز تراویٚو ، تیٚلہِ چُھنہٕ خۅد تس ورٲے کانٛہہ یُس اتھ مصیبتس ہٹا وِ، تہٕ اگر سُہ تُہٕندِس حقس منٛز کُنہِ رٕژ رُک ارداہ کرِ ،تیٚلہِ چُھنہٕ تٔمۍ سٕندِس فضلس تہِ کانٛہہ رُکاوَن وول، پننیو بندو منٛزٕ یَس سُہ یژھان چُھ تس چُھ پننہِ فضلہٕ سٍتۍ نوازان، بیٚیہِ چُھ سُہ در گُزر کر ن وول تہٕ رحم فر مان وول۔"
  10,108,"۔ اے محمد صلی اللہ علیہ وسلم ،ؤنِو زِ  اے لوٗکو ،تۅہیہِ نِشہِ چُھ تُہندِس ربّ سٕندِ طر فہٕ حق آمُت، وۅ نۍ یُس سٔیز وَتھ اختیار کرِ تٔمۍ سُنٛد سیٚزرس پٮ۪ٹھ پکُن چُھ تٔمۍ سٕندی خٲطرٕ فا یدٕہ مند، تہٕ یُس گمراہ چُھ تٔمۍ سٕنز گمرٲہی چھےٚ تٔمۍ سٕندی خٲطرٕ تبا ہ کُن تہٕ بہٕ چُھس نہٕ تۅہیہِ پٮ۪ٹھ کانٛہہ مختار۔"
  10,109,"۔ تہٕ اے نبی صلی اللہ علیہ وسلم ،توٚہۍ روٗزِ و ییٚمہِ ہدا تٕچ پیروی کران یُس تۅہیہِ کُن بذر یعہ وَحی چُھ سوزنہٕ یِوان ، بیٚیہِ کٔرِ و صبر یوٚت تام اللہ تعالیٰ فٲصلہٕ کرِ، تہٕ سُے چُھ بہتر ین فٲصلہٕ کر ن وول ۔ع"
