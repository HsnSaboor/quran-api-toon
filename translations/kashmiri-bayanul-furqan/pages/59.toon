quran[24]{c,v,t}:
  59,1,"۔ اللہ تعالیٰ سٕنزٕ ے تسبیح چھےٚ کٔر مٕژ پرٛتھ چیز ن یُس آسما نن تہٕ زمینس منٛز چُھ  تہٕ سُے چُھ غٲلِب تہٕ حکمت وول۔"
  59,2,"۔ سُے چُھ ییٚمۍ اہلِ کتا ب کٲفر گۅڈ نِکۍ سٕے ہیلَس منٛز تِہند یو گھرَو  منٛزٕ نیٚبر چٔھکۍ۔﴿ یتھ جایہِ چُھ اہلِ کتا ب کٲفر و نِشہِ مُراد بنی نضیرُک یہوٗدۍ قبیلہٕ یُس مد ینہ کِس أکِس حصّس منٛز روزان اوس ۔اتھ قبیلس سٍتۍ اوس رسول اللہ صلی اللہ علیہ وسلمن ہُند مُعا ہد ہ ، مگر أمۍ قبیلن کٔر گرِ گرِ عہد شکنی۔ٲخر کار چِھ حضور صلی اللہ علیہ وسلم ربیعُ الاوّل 4 ھ منٛز تِمن نوٹس دِوان زِ یا نِیرِ و مد ینہٕ منٛزٕ نَتہٕ سپدِ و جنگ خٲطرٕ تیار ۔ تِم چِھ نیر نہٕ نِشہِ انکار کران تہٕ پتہٕ چِھ حضور صلی اللہ علیہ وسلم مُسلمانن ہُند لشکر ہیٚتھ تِمن مُحا صرٕہ کران تہٕ جنگٕچ نو بت واتنہٕ برونٹھٕے چِھ تِم جلا و طنی  پٮ۪ٹھ آما دٕہ سپدان حالانکہ تِہِندۍ قلعہ ٲسۍ سٮ۪ٹھاہ مضبو ط ،تہٕ تِہُند تعداد تہِ اوس نہٕ مسلمانَو کھۅ تہٕ کم کینٛہہ تہٕ جنگی ساز و سا مان تہِ اوس تِمن سٮ۪ٹھاہ۔﴾  تۅہیہِ اوسُو نہٕ ہر گز یہِ گُمان زِ تِم نیرن، تہٕ تِمو تہِ اوس یہِ سمجھمُت زِ تِہندۍ قلعہٕ بچا و ن تِمن خُدا یس نِشہِ ۔ مگر اللہ تعالیٰ آو تِمن تمہِ اَندٕ یو ر کُن نہٕ تِہُند ظۅ ن تہِ اوس گوٚ مُت۔﴿ اللہ تعالیٰ سُند تِمن پٮ۪ٹھ یُن""اَتھ چُھنہٕ یہِ معنی زِ اللہ تعالیٰ اوس بیٚیہِ کُنہِ جا یہِ تہٕ پتہٕ کوٚرُن تتہِ پٮ۪ٹھہٕ یِمن حملہٕ ۔ بلکہ چُھ یہِ مجٲزی کلام ۔اصلی مُدعا چُھ یہِ تصّور دِیُن زِ مُسلمانن ہٕندِ حملہٕ برونٛہہ ٲسۍ تِم اَتھ خیا لس منٛز زِ اگر نیبرٕ ۍ کِنۍ کانٛہہ حملہٕ سپُد، تیٚلہِ رُکا وون سُہ أسۍ پننیو قعلہٕ بٔندِ یو سٍتۍ ۔ مگر خُداین کوٚر تِمن تژِھہ وَتہِ کِنۍ حملہٕ یپٲرۍ کٲنٛسہِ بلا یہِ ہٕندِ یِنُک تِمن توقع ہٕے اوس نہٕ ۔ تہٕ سۅ وَتھ ٲس یہِ زِ تِمن منٛز بنٲوٕن تِہٕنز ہمت تہٕ مقا بلٕچ قُوّت کھۅ کھر تہٕ کمزور ییٚمہِ پتہٕ تِمن نَہ تِہندۍ ہتھیار بکار لٔگۍ تہٕ نہ تِہٕندۍ مضبو ط قعلہٕ ۔﴾ تٔمۍ ترٛ ووتِہندٮ۪ن دِلن منٛز بیم۔ نتیجہِ درٛ او یہِ زِ تِم ٲسۍ پننیو اَتھ تہِ پنٕنۍ گھرٕ برباد کران تہٕ مو مِنن ہٕند یو اَتھو تہِ ٲسۍ برباد کرناوان۔ لہٰذا کٔرِ و عبرت حٲصل اے أچھ گا ش تھا وَن والیو!"
  59,3,"۔ اگر خُداین تِٕہندِس حقس منٛز جِلا وطنی آسہِ ہے نہٕ لیٛچھمٕژ، تیٚلہِ دِیہِ ہے سُہ تِمن دُنیا  سٕے منٛز عذا ب ،﴿ دُنیا کہ عذا ب نِشہِ چُھ مُراد تِہُند نام و نشا ن مِٹا وُن۔اگر تِم صلح کٔرِتھ پنٕنۍ زُو بچا و نہٕ بجا ے لڑ ہَن تیٚلہِ مِٹہِ ہے تِہُند نام و نشا ن﴾تہٕ ٲخر تس منٛز گوٚ و تِہندِ خٲطرٕ جہنمُک عذا ب ٲسِتھٕے۔"
  59,4,"۔یہِ سُورُے کینٛہہ سپُد امہِ موجوٗب زِ تِمو کوٚر خُدایس تہٕ تٔمۍ سٕندِس رسول اللہ صلی اللہ علیہ وسلمس سٍتۍ مقا بلہٕ ، تہٕ یُس اکھا ہ خُدایس سٍتۍ مقا بلہٕ کرِ ، اللہ تعالیٰ چُھ تس سزا دِنس منٛز واریاہ سخت۔"
  59,5,"۔تۅہیہِ لُکو یِم کٔھزٕر کُلۍ ژٔٹِو ، یا یِمن پننیٚن گۅڈن پٮ۪ٹھ کھڑا دِ یتُو روزنہٕ ، یہِ سورُے اوس اللہ تعالیٰ سٕندی اِذ نہٕ سٍتۍ۔﴿ یہِ اِشا رہ چُھ تتھ معا ملس کُن زِ بنی نضیر س  دٔچِھنۍ کھووٕرۍ یِم نخلستان ٲسۍ ، تِہِندۍ واریاہ کُلۍ ژٔٹۍ  مسلمانو مُحا صرٕ کِس آغا زس منٛز نَتہٕ زٲلِکھ تا کہ مُحا صرٕ ہ ہیٚکہِ آسٲنی سان کر نہٕ یِتھ ،تہٕ یِم کُلۍ فو جی نقل و حر کتس منٛز ٹٔھرۍ ٲسۍ تِم تھٲوِکھ کھڑا ہٕے۔اتھ پٮ۪ٹھ تُل مدینہ کیو مُنا فقو تہٕ یہوٗدیو شو ر زِ محمد صلی اللہ علیہ وسلم ہَے فسا د فی الارض نِشہِ ٹھا کھ چِھ کران ، مگر وُچِھتَو یہِ ، سر سبز پھل دا ر کُلۍ چِھ ژَٹنہٕ یِوان ، اگر نہٕ یہِ فسا د فی الارض چُھ تیٚلہِ کیا چُھ۔ اتھ پٮ۪ٹھ چُھ  اللہ تعالیٰ یہِ حُکم نٲزِل فر ما وان زِ تۅہیہِ لُکو یِم کُلۍ ژٔٹِو تہٕ یِمن کھڑا دِ یتُو روز نہٕ، یِمو منٛزٕ چَھنہٕ کانٛہہ کٲم نا جٲیز ، بلکہ چُھ دۅشوٕنۍ اللہ تعالیٰ سُند اِذن حٲصل﴾تہٕ ﴿خُداین اوس یہِ حُکم امہِ مو جو ب دِیتمُت ﴾ تا کہ فٲسِقن کرِ ذلیل و خوار۔﴿یعنی اللہ تعالیٰ سُند ارادٕہ اوس یِتہِ زِ یِم کُلۍ ژٹنہٕ سٍتۍ تہِ سپدِ تِمن ذِلّت تہٕ رُسوٲیی ، تہٕ نَہ ژٹنہٕ سٍتۍ تہِ۔ ژٹنس منٛز اوس تِہندِ ذلّتُک تہٕ رُسوٲیی ہُند پہلو یہِ زِ یِم با غ تِمو پننیو اَتھو ٲسۍ لگٲوِمٕتۍ تہٕ یِمن با غن ہٕندۍ تِم واریاہ زیٹھہِ کالہٕ پیٹھہٕ مٲلک ٲسۍ،تِہِندۍ تِم کُلۍ ٲسۍ تِہنز ن أچھن برونٛہہ کنہِ ژٹنہٕ یِوان تہٕ تِم ہیٚکہن نہٕ ژَٹن والیٚن کُنہِ پٲٹھۍ تہِ رُکٲوِتھ۔روٗد وۅ نۍ کُلیٚن ہٕندِس نہ ژَٹنس منٛز ذِلّتُک پہلو، سُہ اوس یہِ زِ ییٚلہِ تِم مد ینہٕ منٛزٕ درٛاے ،تِہنزٕ أچھ آسہٕ یہِ وُچھا ن زِ یِم سر سبز باغ تِہنز ملکیت ٲسۍ تِم چِھ اَز مُسلمانن ہٕندِس قبضس منٛز گژھان۔اگر تِمن پِلہِ  ہے تِم کر ہن تِمن با غن پوٗرٕ پٲٹھۍ وُجارٕ تہٕ پتہٕ نیر ہَن  ،اکھ کُل تہِ تھا و ہن نہٕ سیوٚ د مُسلمانن خٲطرٕ پَتھ کُن۔مگر بے بسی سان ترٛوُو کھ سورُے کینٛہہ تِتھے پٲٹھۍ تہٕ درٛاے حسرت سان ۔ ﴾ ﴿ وۅ نۍ چھےٚ تِمن جا یدا دن ہٕنٛز تہٕ اِملا کٕچ  ذکر سپدان یِم بنی نضیرٕ کۍ مِلکیت ٲسۍ تہٕ تِہندِ جلا و طنی پتہٕ آے اسلٲمی حکو مت کِس قبضس منٛز۔ یِمن متعلق چُھ خُداین ییٚتہِ پٮ۪ٹھہٕ آیت 10 ،ہس تام فر مو و مُت زِ یُہُند انتظام کِتھہٕ پٲٹھۍ گژِھہ کر نہٕ یُن۔﴾"
  59,6,"۔تہٕ یِم مال اللہ تعالیٰ ہن تِہندِ قبضہٕ منٛزٕ کٔڑِتھ پننِس رسول صلی اللہ علیہ وسلمس کُن پھِرۍ، ﴿ یِمو لفظو سٍتۍ چُھ پٲنۍ پا نے یہِ معنی نیران زِ یہِ زمین تہٕ تِم سٲری چیز یِم ییٚتہِ چِھ، چِھنہٕ در اصل تِمن لُکن ہُند حق یِم اللہ تعالیٰ سٕندۍ بٲغی چِھ ۔ امہِ مو جو ب یِم تہِ مال أکِس جٲیز تہٕ بر حق جنگ کِس نتیجس منٛز کُفّارن ہٕندِ قبضہٕ پٮ۪ٹھہٕ نیرِ تھ اہلِ ایمانن ہٕندِس قبضس منٛز یِن، تِہٕنز حقیقی حیثیت چھےٚ یہِ زِ تِہِندۍ مٲلِکن چِھ تِم پننیو خیا نت کر ن والیو تہٕ غدار مُلٲزِ مَو ہٕندِ قبضہٕ نِشہِ کٔڑِتھ پننیٚن فر ماں بردار مُلٲزِمن کُن پِھرِ مٕتۍ۔ اَمی مو جو ب چِھ یِم اِملا ک اسلٲمی قا نو ن کِس اصطلاحس منٛز فے،"" واپس پِھر نہٕ آمٕتۍ مال "" قرار دِنہٕ آمٕتۍ۔﴾  تِم چِھنہٕ تِتھۍ مال یِمن پٮ۪ٹھ تۅہیہِ پنٕنۍ گُر ۍ تہٕ اوٗنٹ دَو نٲوِمٕتۍ آسن، بلکہ یَس پٮ۪ٹھ اللہ تعالیٰ پننیٚن رسولن ہُند تسلّط یژھان چُھ تس چُھ فر ماوان، تہٕ اللہ تعالیٰ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔﴿یعنی یِمن مالَن ہُند مُسلمانن ہٕندِس قبضس منٛز یُن چُھنہٕ سیدِ سیوٚ د لڑن والہِ فو ج چہِ نَرِ ہٕندِ زورُ ک نتیجہ،بلکہ چُھ یہِ تمہِ مجمو عی قُوّتُک نتیجہ یۅسہٕ خُدا ین پننِس رسول صلی اللہ علیہ وسلمس تہٕ اُمّتس تہٕ تِہندِس قٲیِم کر نہٕ آمتِس نظا مس چھےٚ عطا کٔرمٕژ۔امہِ موجو ب چِھ یِم مال ، مالِ غنیمت نِشہِ با لکل مختلف حیثیت تھا وان تہٕ لڑن والہِ فوجُک چُھنہٕ یہِ حق زِ مالِ غنیمتٕکۍ پٲٹھۍ یِیہِ یِتہِ تَتھ فوجس منٛز بٲگراونہٕ۔ یِتھہٕ پٲٹھۍ چُھ شر یعتس منٛز غنیمتُک تہٕ فے ہُک حکم بیوٚ ن بیوٚ ن کر نہٕ آمُت۔غنیمت چِھ تِم اموالِ منقو لہ یِم جنگی کار وٲین دورا ن دشمن سٕند یو لشکرَ و نِشہِ حٲصل گژَھن ۔ یِمو ورٲے چِہ دشمنِ ملک سٕندۍ زمین، مکا نہٕ تہٕ با قی اموالِ منقو لہٕ وغیر منقو لہٕ غنیمت کہ تعر یفہٕ نِشہِ خٲرج تہٕ یِم چِھ فے ہَس منٛز شٲمِل۔﴾"
  59,7,"۔یِکینٛژھاہ تہِ اللہ تعالیٰ بٔستِیَن ہٕند یو لُکو نِشہِ پننِس رسول صلی اللہ علیہ وسلمس کُن پِھرِ ،سُہ چھُ اللہ تعالیٰ تہٕ رسول صلی اللہ علیہ وسلمس تہٕ رشتہٕ دارن خٲطرٕ،﴿ رشتہٕ دارَو نِشہِ چُھ مُراد رسول اللہ صلی اللہ علیہ وسلمن ہٕندۍ رشتہٕ دار، یعنی بنی ہا شم تہٕ بنی المُطَّلِب ، یہِ حصّہٕ اوس اَمہِ مو جو ب آمُت مقر ر کر نہٕ زِ رسول اللہ صلی اللہ علیہ وسلم کر ہن پننہِ ذاتٕکۍ تہٕ پننہِ اہلِ وعیا لِکۍ حقو ق ادا کر نس سٍتۍ سٍتۍ پننیٚن تِمن رشتہٕ دارن ہٕندۍ حقو ق تہِ ادا ،یِم تِہندِ مد تٕکۍ محتا ج آسٕہَن، یا یِمن حضور صلی اللہ علیہ وسلم مدد کرنٕچ ضرورت کر ہَن محسوس۔حضور صلی اللہ علیہ وسلمن ہٕندِ وفا ت پتہٕ روٗد نہٕ یہِ اکہِ الگ تہٕ مُستقل حیثیتہٕ پَتھ کُن، بلکہ سپٕدۍ مُسلمانن ہٕندٮ۪ن با قی مِسکینن، یتیمن تہٕ مُسا فر ن سٍتۍ سٍتۍ بنی ہا شم تہٕ بنی المطلب کیٚن محتا ج لُکن ہٕندۍ حقو ق تہِ بیت المال کہ ذِ مّہ عٲید ۔ البتہٕ آو اَتھ بِنا ہَس پٮ۪ٹھ یُہُند حق دوٚ یِمیٚن پٮ۪ٹھ فٲیق سمجھنہٕ تِکیازِ زکٲژ منٛز چُھنہٕ یِمن حصّہٕ ۔﴾ تہٕ یتیمن تہٕ مسکینن تہٕ مسا فر ن خٲطرٕ،تا کہ سُہ روزِ نہٕ تُہٕندٮ۪ن مالدار نٕے یوت منٛز گردش کران۔ ﴿ یہِ چُھ قرآنِ مجید کیو اہم اصو لی ہدایتو منٛزٕ یَتھ اسلامی مُعا شرٕ چ تہٕ حکو مت چہِ معٲ شی پا لیسی ہُند یہِ بُنیٲ دی قٲعدہ چُھ بیان کر نہٕ آمُت زِ دولتٕچ گردش گژِھہ پوٗرٕ مُعا شرس منٛز عا م سپدٕ نۍ ، یہِ گژِھہ نہٕ سپدُن زِ مال روزِ صرف مالدار نٕے یوت منٛز نَژان،امیر بَنہِ دۅہ کھۅتہٕ دۅہ امیر تہٕ غر یب روزن دۅہ کھۅتہٕ دۅہ غر یب تر سپدان۔﴾ یِکینٛژھاہ رسول صلی اللہ علیہ وسلم تۅہیہِ  دِیَو تہِ رٔٹِو ، تہٕ ییٚمہِ چیزٕ نِشہِ سُہ تۅہیہِ رُکا وِ تَمہِ نِشہِ رُکِو۔خُدایس کھوٚ ژِو ،اللہ تعالیٰ چُھ سخت سزا دِنہٕ وول ۔ ﴿ اگر چہِ یہِ ارشاد بنی نضیر کِس مال کِس بٲگر اونس متعلق نٲزِل سپُد مُت اوس مگر حُکمٕکۍ الفاظ چِھ عام ، لہٰذا  چُھ امِیُک مَنشہِ یہِ زِ سارِ نٕے معاملا تن منٛز کٔرِ ن مُسلمان حضور صلی اللہ علیہ وسلمن ہٕنز اطا عت ۔ اَتھ مَنشس چھےٚ یہِ کتھ وارَے زیادٕہ وا ضح کران زِ "" یِکینژھاہ رسول تۅہیہِ دِیَو "" اَتھ مقابلہٕ چِھنہٕ یِم الفا ظ فر ما و نہٕ آمٕتۍ زِ "" یِکینژھاہ دِیَو نہٕ "" بلکہِ چُھ فر ما و نہٕ آمُت زِ "" ییٚمہِ چیزٕ نِشہِ سُہ تۅہیہِ رُکا وِ "" یا ٹھا کھ کرِ "" تمہِ نِشہِ رُکِو ۔﴾"
  59,8,"۔﴿امہِ علا وٕہ چُھ سُہ مال ﴾ تِمن غر یب مہا جر ن خٲطرٕ یِم پننیو گھر و تہٕ جا یدا دَو نِشہِ کڑنہٕ چِھ آمٕتۍ۔ یِم لُکھ چِھ اللہ تعالیٰ سُند فضل تہٕ تٔمۍ سٕنز خوشنودی یژھان،بیٚیہِ چھِ اللہ تعالی سٕندِس تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلمن ہٕندِس حما یتس پٮ۪ٹھ ہوٚ ل گٔنڈِتھ روزان۔ یِمے چِھ راست  باز لُکھ۔ ﴿ تہٕ سُہ چُھ تِمن لُکن خٲطرٕ تہِ ﴾"
  59,9,"۔یِم یِمن مہا جر ن ہٕندِ یِنہٕ برونٛٹھٕے ایمان أنِتھ دارُلہجرتس منٛز بسا ن ٲسۍ۔﴿مُراد چِھ انصا ر ، یعنی فے یَس منٛز چُھنہٕ صرف مہا جر ن ہُندُے یوت حق ، بلکہ یِم مُسلمان گۅڈٕہ پٮ۪ٹھے دارُلاسلا مَس منٛز آباد چِھ تِم تہِ چِھ حقدار۔﴾یِم چِھ تِمن لُکن سٍتۍ محبت کران یِم ہجر ت کٔرِتھ تِمن نِش چِھ آمٕتۍ، تہٕ یِکینٛژھا ہ تہِ تِمن دِنہٕ یِیہِ ، یِم چِھنہٕ تمِیُک کانٛہہ حا جت تہِ پننیٚن دِ لن منٛز محسو س کران ، بیٚیہِ چِھ پننِس ذا تس پٮ۪ٹھ با قین تر جیح دِوان خواہ پانہٕ ٲسِتن محتا ج۔حقیقت چھےٚ یہِ زِ یِم لُکھ پننہِ دل چہِ تنگی نِشہِ بچا و نہٕ آے، تِمے چِھ فلا ح لبن وٲلۍ۔ ﴿ تہٕ سُہ چُھ تِمن لُکن خٲطرٕ تہِ ﴾"
  59,10,"۔یِم یِمن پتہٕ چِھ آمٕتۍ، ﴿یعنی فے کیو مَالَو منٛزٕ چُھنہٕ صرف مو جو دٕہ نسلن ہُندُے یوت حق بلکہ چُھ تِہُند تہِ حق یِم پتہٕ یِن ﴾ یِم ونان چِھ زِ "" اے سا نہِ ربّہٕ، اَسہِ تہٕ سا نیٚن با ین کر مغفر ت یِمو اسہِ برونٛہہ چُھ ایمان اوٚنمُت، تہٕ سا نیٚن دِلن منٛز مَہ تھا و اہلِ ایمانن خٲطرٕ بغُض، اے سا نہِ ربّہٕ ، ژٕچھکھ سٮ۪ٹھا ہ مہر بان تہٕ رحیم۔"" ع۔ ﴿یتھ آیتس منٛز چُھ مُسلمانن یہِ اہم اخلٲقی در س آمُت دِنہٕ زِ تِم مَہ تھٲوِن کٲنٛسہِ مُسلمان سٕندِ خٲطرٕ پننِس دِلس منٛز بغُض تہٕ پا نس برونٛہہ گُزر یمتیٚن مُسلمانن ہٕندِس حقس منٛز روٗزِ ن دُعا ے مغفرت کران ، نَہ زِ تِمن پَر ن تبرا۔﴾"
  59,11,"۔تۅہیہِ وُچھوٗکھ نا تِم لُکھ یِمو مُنا فقتٕچ رٔوِش چھےٚ اختیار کٔرمٕژ؟﴿ یتھ پوٗرٕ رکوعس منٛز چُھ مُنا فَقن ہٕندِس رٔوِ یس پٮ۪ٹھ کلام کر نہٕ آمُت۔ ییٚلہِ رسول اللہ صلی اللہ علیہ وسلمو بنی نضیرس مد ینہٕ منٛزٕ نیر نہٕ خٲطرٕ دَہن دۅہن ہٕنز نوٹس ٲس دِژ مٕژ تہٕ تِہُند محا صرہ شروع سپد نس منٛز ٲسۍ وُنہِ کینٛہہ دۅہ با قی ،تمہِ ساعتہٕ ٲس مد ینہ کیو مُنا فِق لیڈرَو تِمن یہِ شیٚچھ سوٗز مٕژ زِ أسۍ یِمو زٕ ہ ساس نفر ہیٚتھ تۅہیہِ مَدتس تہٕ بیٚیہِ وۅ تھہِ بنی قُر یظ تہٕ بنی غطفا ن تہِ تُہندِ حما یت خٲطرٕ۔لہٰذا ، روٗزِ و توٚہۍ مُسلمانن ہٕندِس مقا بلس منٛز ڈٔٹِتھ تہٕ ہر گز مَہ ترٲوِو یِمن برونٛہہ کنہِ ہتھیار۔یِم لڑن تۅہیہِ سٍتۍ أسۍ لڑَو تُہندِ اندٕ تہٕ اگر توٚہۍ ییٚتہِ کٔڑۍ ہَو أسۍ تہِ نیرَو تۅہی سٍتۍ۔﴾یِم چِھ پننیٚن کٲفر اہلِ کتاب با ین ونان، ""اگر توٚہۍ کڑ نہٕ ٲو، تیٚلہِ نیرَ و أسۍ تہِ تۅہیہِ سٍتۍ، تہٕ تُہندِس معا ملس منٛز مانَو نہٕ أسۍ ہر گز کٲنٛسہِ ہٕنز کتھ، تہٕ ہر گاہ تۅہیہِ سٍتۍ جنگ آو کر نہٕ ، تیٚلہِ کرو أسۍ تۅہیہِ مدد۔"" مگر اللہ تعالیٰ چُھ گواہ زِ یِم لُکھ چِھ در حقیقت اَپزِ یٲرۍ۔"
  59,12,"۔اگر تِم کڑ نہٕ آے یِم نیر ن نہٕ ہر گز تِمن سٍتۍ، تہٕ اگر تِمن سٍتۍ جنگ آو کر نہٕ تیٚلہِ کر ن نہٕ ہر گز یِم تِمن مدد، تہٕ ہرگاہ یِم تِمن مدد تہِ کر ن ، تیٚلہِ تہِ ژلَن پوٚت پھِیرِتھ،تہٕ پتہٕ لبن نہٕ کُنہِ کِنۍ مدد۔"
  59,13,"۔یِہندٮ۪ن دِلن منٛز چُھ اللہ تعالیٰ سٕندِ کھۅتہٕ کٔھسِتھ تُہُند خو ف ،  امہِ موجو ب زِ یِم چِھ تِتھۍ لُکھ یِمن نہٕ سۅ د بۅد چھےٚ۔﴿ یتھ لۅ کِٹس حِصّس منٛز چھےٚ اکھ بٔڈ حقیقت آمٕژ بیان کرنہٕ۔یَس شخصس سو نٕچ سمجھ آسہِ تس چھےٚ یہِ خبرزِ دراصل چُھ کھۅژنس لا یق اللہ تعالیٰ سُند طا قت نَہ زِ انسانن ہُند طا قت ،امہِ موجوٗب روزِ سُہ پرٛتھ تِژِھہ کامہِ نِشہِ پتھ یتھ پٮ۪ٹھ تس خُدایس نِشہِ پٕرٛژٕھگا رِ ہُند خطرٕ ہ آسہِ ، خوا ہ کانٛہہ اِنسٲنی طا قت ٲسِتن پٔرژھگٲر کر ن وول یا متہٕ ٲسِتن ، سُہ گژِھہ پرٛتھ کانٛہہ سُہ فر یضہٕ انجام دِ نہٕ خٲطرٕ کھڑا یُس خُداین تس پٮ۪ٹھ عٲید آسہِ کوٚرمُت ، خوا ہ سٲری دُنیا ہٕکۍ طا قت بٔنۍ تن اَتھ منٛز ٹٔھرۍ تہٕ رُکا وٹ۔ البتہ ، اکھ نا سمجھ انسان چُھ تمام معالاتن منٛز پننہِ طر زِ عملُک فٲصلہٕ خُدایس بجا ے اِنسٲنی طا قتن ہٕندِ لحا ظہٕ کران۔سُہ چُھنہٕ امہِ موجو ب کُنہِ چیزٕ نِشہِ پتھ روزان زِ خُداے  کیا رَٹیٚم، بلکہ چُھ امہِ موجو ب پتھ روزان زِ برونٛٹھہٕ کنہِ چُھم کانٛہہ انسٲنی طا قت خبر ہیٚنہٕ خٲطرٕ پراران۔تہٕ اگر کانٛہہ کٲم کرِ سۅ تہِ  کرِ نہٕ اتھ بِنا ہس پٮ۪ٹھ زِ خُداین چُھ اَمِیُک حکم دِ یتمُت بلکہ کرِ اَتھ بِنا ہس پٮ۪ٹھ زِ کانٛہہ انسٲنی طا قت چُھ امیُک حکم دِنہٕ وول ،یا اَتھ پسند کر ن وول۔ یٔہے سمجھنٕچ تہٕ نا سمجھی ہٕنز فر ق چھےٚ دراصل مو من تہٕ غیر مو من سٕندِس سیرتس تہٕ کردارس اکھ أکِس نِشہِ بیوٚن کڑا ن۔﴾"
  59,14,"۔ یِم کر ن نہٕ زانٛہہ یِکہٕ وٹہٕ سپدِتھ ﴿ کُھلہٕ مٲدانس منٛز ﴾ تُہُند مقا بلہٕ ، اگر لڑَن تہِ ، سُہ لڑَن قلعہٕ بند بٔستِیَن منٛز بِہِتھ،نَتہٕ دیوارن پٔتۍ کِنۍ ژھا یہِ روٗزِ تھ۔ یِم چِھ پانہٕ وٲنۍ اکھ أکۍ سٕندِس مخا لفتس منٛز سٮ۪ٹھاہ سخت ۔ توٚہۍ چھوٗکھ یِم یِکہٕ وَٹہٕ سمجھان مگر یِہِندۍ دل چِھ اکھ أکِس نِشہِ بیوٚ ن بیوٚ ن ۔ یُہُند یہِ حال چُھ امہِ مو جو ب تِکیازِ یِم چِھ بے عقل لُکھ۔"
  59,15,"۔ یِم چِھ تِمنٕے لُکن ہِوۍ یِمَو کمٕے کال برونٛہہ پننہِ کرِ مَتِیُک مزٕ ہ چُھ وُچھمُت۔ ﴿ اشارٕہ چُھ کُفّارِ قر یشن تہٕ یہوٗد بنی قینقا عس کُن یِمو پننہِ تعداد کہ کثر ت  تہٕ پننہِ سا زو سامان با وجود یِموٕ ے کمزور یو کِنۍ مُسلمانن ہٕنزِ لۅ کچہِ  بے ساز و سامان جمٲعژ نِشہِ شکست کھیوٚو﴾ تہٕ یِہندِ خٲطرٕ چُھ دگ تُلہٕ وُن عذاب۔"
  59,16,"۔یِہنز مِثا ل چھےٚ شیطا ن سٕنز ہِش زِ گۅڈٕ چُھ سُہ انسانس وَنان کُفر کر ، تہٕ پتہٕ ییٚلہِ انسان چُھ کُفر کران ، سُہ چُھ ونان بہٕ چُھس ژےٚ نِشہِ لا تعلق ، مےٚچُھ اللہ ربُّ العا لمینس نِشہِ ڈر با سان ،"
  59,17,"۔پتہٕ چُھ دۅ شوٕنۍ ہُند انجام یہِ سپدَن وول زِ ہمیشہ خٲطرٕ گٔژِھن جہنمس ،تہٕ ظٲلِمن چُھ یۅ ہے جزا ۔ع"
  59,18,"۔ اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ، خُدایس کھوٚژِو ،تہٕ پرٛتھ شخص وُچِھن یہِ زِ تٔمۍ کیا سامان چُھ پگا ہ خٲطرٕ تیار کوٚر مُت۔﴿پگا ہ چُھ مُراد ٲخرت۔ گویا دُنیا ہٕچ یہِ پوٗرٕ زند گی چھےٚ"" اَز"" تہٕ "" پگا ہ "" چُھ سُہ قیا متُک دۅہ یُس اَمہِ "" اَز "" پتہٕ یِنہٕ وول چُھ ۔﴾ خُدایس روٗزِ و کھۅژا ن ، اللہ تعالیٰ چُھ یقیناً تُہند یو تِمو سارِ وٕے اعما لو نِشہِ با خبر یِم توٚہۍ کران چِھو۔"
  59,19,"۔تِمن لُکن ہٕندۍ پٲٹھۍ مَہ بٔنِو یِمو اللہ تعالیٰ مٔشروو، تہٕ خُدا ین مٔشر ووتِمن خۅد پنُن نفس، ﴿یعنی خُدا فرامو شی ہُند لٲزمی نتیجہِ چُھ خۅد فرا مو شی ۔ ییٚلہِ اِنسا نس یہِ مٔشِتھ چُھ گژھان زِ سُہ چُھ کٲنٛسہِ ہُند بندٕ ہ،تیٚلہِ چُھ لاز ماً سُہ دُنیا ہس منٛز پنٕنۍ اکھ غلط حیثیت مُتعیّن کران تہٕ أمۍ سٕنز سٲرٕے زند گی چھےٚ اَمی بُنیٲدی غلط فہمی ہٕندِ بٲعث غلط گٔژِھتھ روزان۔یِتھے پٲٹھۍ ییٚلہِ تس یہِ مٔشِتھ چُھ گژھان زِ سُہ چُھنہٕ کُنِس خُدایس ورٲے بیٚیہِ کٲنٛسہِ ہُند بندٕ ہ ،پتہٕ چُھنہٕ سُہ أمِس أکِس خُداے سٕنز بند گی کرا ن ییٚمۍ سُند سُہ در حقیقت بندٕ چُھ، سُہ چُھ پتہٕ تِمن واریاہن ہٕنز بند گی کران روزان یُہُند سُہ در حقیقت بند ے چُھنہٕ ﴾ یِمے لُکھ چِھ فا سق۔"
  59,20,"۔ جہنمس گژھن وٲلۍ تہٕ جنتس گژھن وٲلۍ ہیٚکن نہٕ زانٛہہ یکسا ن ٲسِتھ۔ جنتس گژھن وٲلۍ چِھ در حقیقت کامیاب۔"
  59,21,"۔اگر اسہِ یہِ قرآن کُنہِ پہا ڑس پٮ۪ٹھ تہِ وولمُت آسہِ ہے ، تیٚلہِ وُچِھہو توٚہۍ زِ سُہ چُھ اللہ تعالیٰ سٕندِ خو فہٕ سٍتۍ دَبان تہٕ پھٹا ن ۔ ﴿ امہِ مِثا لہِ ہُند مطلب چُھ یہِ زِ قرآن یِتھہٕ پٲٹھۍ اللہ تعالی سٕںز کبریٲیی تہٕ تس برونٛہہ کنہِ بندٕہ سٕںز ذمہٕ دٲری تہٕ جواب دہی صاف صاف چھُ بیان کران،اَمِیُک فہم اگر پہا ڑس ہِوِس عظیم مخلوقس تہِ نصیب سپدِ ہے،تہٕ تس لگہِ ہے پے زِ تس کٔمِس ربِّ قدیرس برنٛہہ کنہِ چھےٚ پننیٚن اعمالن ہٕنز جواب دِہی کرٕنۍ، تیٚلہِ اَژ ِ ہے بیٖمہٕ سٍتۍ تس تہِ نٹھ ۔﴾ یِمہٕ مِثا لہٕ چِھ أسۍ لُکن برونٛہہ کنہِ امہِ موجو ب بیان کران زِ تِم کرن ﴿ پننِس حالتس پٮ۪ٹھ ﴾ غور۔"
  59,22,"۔سُہ چُھ اللہ تعالیٰ ہٕے یَس ورٲے کانٛہہ معبوٗد چُھنہٕ،﴿یعنی یَس ورٲے کٲنٛسہِ ہٕنز یہِ حیثیت ، مقام تہٕ مر تبہٕ چُھنہٕ زِ تٔمۍ سٕنز بند گی تہٕ پرستش یِیہِ کر نہٕ ۔یَس ورٲے کٲنٛسی چِھنہٕ خُدٲیی ہٕندۍ صفا ت تہٕ اختیار زِ تس آسہِ معبوٗد آسنُک حق واتان۔﴾پوشیدٕ ہ نوٚ ن پرٛتھ چیزُک زانن وول، سُہ چُھ مہر بان تہٕ رحم کر ن وول۔"
  59,23,"۔سُہ چُھ اللہ تعالیٰ ہٕے یَس ورٲے کانٛہہ معبوٗد چُھنہٕ۔ سُہ چُھ بادشاہ سٮ۪ٹھاہ مُقّدس،﴿ یعنی سُہ چُھ امہِ نِشہِ بد ر جہا بالا تہٕ برتر زِ تٔمۍ سٕندِس ذاتس منٛز آسہِ  کانٛہہ عیب یا نقُص یا کانٛہہ قبیح صفت۔بلکہ چُھ سُہ اکھ پٲکیزٕہ تر ین ہستی یَس متعلق کُنہِ برٲیی ہُند تصّور تہِ ہیٚکو نہٕ کٔرِتھ﴾ سَرا سَر سلامتی،﴿یعنی تٔمۍ سٕنز ذات چھےٚ امہِ نِشہِ بالا تر زِ کانٛہہ آفت یا کمزور ی یا خٲمی کیا سپدِ تَس لا حق،یا کُنہِ ساعتہٕ کیا یِیہِ تٔمۍ سٕندِس کما لس پٮ۪ٹھ زوال﴾ اَمن دِنہٕ وول ، ﴿ یعنی تٔمۍ سُند مخلوق چُھ اَمہِ نِشہِ اَمنس منٛز زِ سُہ کیا کرِ اَتھ پٮ۪ٹھ ظُلم ، یا حق نِیَس تَھپہِ ،یا کرِ أمۍ سُند اجر ضا یع ، یا کرِ أمِس سٍتۍ پننیٚن کٔرِ مٕتیٚن وعدن ہٕنز خلا ف ورزی﴾ نگہبان، ﴿ دراصل چُھ لفظ ،اَلمُھَیمِنُ۔ورتا و نہٕ آمُت یتھ ترےٚ معنی چِھ۔اکھ  رٲچھ راوٹھ تہٕ حفا ظت کرن وول ، دوٚ یُم شٲھد یُس وُچھان آسہِ زِ کُس کیا چُھ کران ۔ترٛیُیم سۅ ہستی ییٚمۍ لُکن ہٕندۍ ضرورت تہٕ حا جت پوٗرٕ کر نُک ذِمّہ آسہِ روٚٹمُت۔﴾ سارِنٕے پٮ۪ٹھ غٲلب، پنُن حکم بزور نٲفذ کر ن وو ل ، تہٕ بوٚڈُے بٔنِتھ روزن وول۔ پاک چُھ اللہ تعالیٰ تمہِ شر کہٕ نِشہِ یُس لُکھ کران چِھ۔"
  59,24,"۔ سُہ چُھ اللہ تعالیٰ ہٕے یُس تخلیقُک منصو بہٕ بناون وول تہٕ تتھ نٲفذ کر ن وول تہٕ تتھ مُطٲبق صوٗرت گر ی کر ن وول چُھ۔ تس خٲطرٕ چِھ بہتر ین ناو۔ پرٛتھ کانٛہہ چیز یُس آسمانن تہٕ زمینس منٛز چُھ، چُھ تٔمۍ سٕنز تسبیح  کران،﴿یعنی  زبانِ قال یا زبانِ حال سان چُھ یہِ بیان کران زِ تٔمۍ سُند خٲلِق چُھ پرٛتھ عیبہٕ، نُقصہٕ ، کمزور ی تہٕ غلطی نِشہِ پا ک ﴾ بیٚیہِ چُھ سُہ زبردست تہٕ حکمت وول۔ع"
