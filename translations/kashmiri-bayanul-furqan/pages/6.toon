quran[165]{c,v,t}:
  6,1,"۔تعر یف چِھ اللہ تعالیٰ سٕندِ خٲطرٕ ییٚمۍ زمین تہٕ آسمان بنٲوۍ، گاش تہٕ اَنہِ گٔٹۍ کٔرِن پٲدٕ ،امہِ پتہٕ تہِ چِھ تِم لُکھ یِمو حقٕچ دعوت ماننہٕ نِشہِ انکار چُھ کوٚر مُت دوٚ یِمیٚن کران پننِس ربّس برابر۔"
  6,2,"۔سُے چُھ ییٚمۍ توٚہۍ میٚژِ بنٲوۍ نَو، پتہٕ کوٚرُن تُہندِ خٲطرٕ زند گی ہُند اکھ وقت مقر ر،بیٚیہِ چُھ بیا کھ اکھ وقت تہِ یُس تس نِشہِ مقرر کٔرِتھ چُھ ﴿یعنی قیا متٕچ گٔر ییٚلہِ سٲری پٔتِم بروٗنٹھم انسان نوِ سرٕ زند ہٕ یِن کر نہٕ تہٕ حسا ب دِ نہٕ خٲطرٕ سپدَن پننِس ربّس برونٹھہٕ  کنہِ حٲضر﴾ مگر توٚہۍ لُکھ چِھو شکس منٛز ہیٚنہٕ آمٕتۍ ،"
  6,3,"۔سُے اکھ اللہ تعالیٰ چُھ آسما نن منٛز تہِ زمینس منٛز تہِ، تُہٕندۍ کھُلہٕ تہٕ چُھپاو نہٕ آمٕتۍ سٲری حال چُھ زانان،تہٕ یۅسہٕ برٲیی یا نیکی توٚہۍ کماوان چِھو تمہِ نِشہِ چُھ ٹھیک پٲٹھۍ با خبر ۔"
  6,4,"۔ لُکن ہُند حال چُھ یہِ تِہندِس ربّ سٕنز و نشٲنِیو منٛزٕ چَھنہٕ کانٛہہ نشٲنی تِژھ یۅسہٕ تِمن برونٹھ کُن آسہِ آمٕژ،تہٕ تِمو آسہِ نہٕ تمہِ نِشہِ بُتھ پھُیرمُت۔"
  6,5,"۔چنا نچہ وۅ نۍ یُس حق تِمن نِشہِ آو تَتھ تہِ پھِیرُ تِمو بُتھ۔ اچھا ، یتھ چیز س تِم وُنیستام ہزٕ ل چِھ کران روٗدِ مٕتۍ عنقر یب وا تن تتھ متعلق تِمن نِشہِ کینٛہہ خبرٕ۔ ﴿اشارہ چُھ ہجرتس کُن تہٕ تِمن کامیٲبِیَن کُن  یِمہٕ ہجر ت پتہٕ پیو ٹُھس پٮ۪ٹھ اسلامس حٲصل سپدَن واجِنہِ آسہٕ۔ییٚمہِ وقتہٕ یہِ اشارٕہ اوس کرنہٕ آمُت تمہِ وقتہٕ نَہ ہیکہَن کُفار یہِ گمان کٔرِ تھ زِ کمہِ قسمہٕ چہِ خبرٕ چھےٚ تِمن واتن واجِنہِ تہٕ نہ اوس مُسلمانن ہٕندِ سٕے ذہنس منٛز اَمِیُک کانٛہہ تصوّر ۔﴾"
  6,6,"۔کیا یِمو وُچھنا زِ یِمن برو نٛہہ کٲتیاہ تِتھۍ قو م چِھ اسہِ ہلاک کٔرمٕتۍ یُہُند پننِس پننِس زمانس منٛز دَبہٕ دَبہٕ چُھ روٗدمُت؟ تِمن اوس اسہِ زمینس منٛز سُہ اقتدار بخشُمُت یُس نہٕ تۅہیہِ چُھو بخشمُت، تِمن پٮ۪ٹھ تراوِ اَسہِ آسمان پٮ۪ٹھہٕ سٮ۪ٹھاہ بٲرِشہِ تہٕ تِمن بٔنۍ کِنۍ پکنا وِ کۅ لہٕ، ﴿مگر ییٚلہِ تِمو نعمتن انکار کوٚر پتہٕ ﴾ ٲخر کار کٔرۍ اَسہِ تِم تِہندٮ۪ن گنا ہن ہٕندِس پا داشس منٛز ہلاک تہٕ تِہِنزِ جایہِ تُلۍ دوٚیِمہِ دورٕ کۍ قو م۔"
  6,7,"۔اے پیغمبر صلی اللہ علیہ وسلم ،اگر أسۍ تۅہیہِ پٮ۪ٹھ کاغذ س منٛز لیٚکھنہٕ آمٕژ کانٛہہ کتاب تہِ نٲزِل کر ہَو،پَتہٕ وُچھہَن لُکھ تتھ پنٕنۍ اتھہٕ لٲگِتھ تہِ تمہِ پتہٕ تہِ یِمو حقس اِنکار چُھ کوٚر مُت تِم وَنہن یی زِ  یہِ چُھ نَنہِ وانہٕ جو د ۔"
  6,8,"۔وَنان چِھ زِ أمِس نبی صلی اللہ علیہ وسلمس پٮ۪ٹھ کیازِ آو نہٕ کانٛہہ فرشتہٕ نٲزل کر نہٕ؟﴿یعنی ییٚلہِ یہِ شخص اللہ تعالیٰ سٕندِ طر فہٕ پیغمبر بنٲوِتھ سوزنہٕ چُھ آمُت تیٚلہِ گوٚژھ آسما نہٕ اکھ فرشتہٕ وَسُن یُس لُکن ونہِ ہے زِ یہِ چُھ اللہ تعالیٰ سُند پیغمبر،أمۍ سٕنز کتھ مٲنِو نَتہٕ یِیَو تۅہیہِ سزا دِنہٕ ۔﴾ہرگاہ اَسہِ فرشتہٕ آسہِ ہے نٲزِل کوٚر مُت تیٚلہِ آسہِ ہے کرتام فٲصلہٕ سپُد مُت، پتہٕ یِیہِ ہے نہٕ یِمن کانٛہہ مہلت دِنہٕ۔"
  6,9,"۔پتہٕ ہرگاہ أسۍ فرشتہٕ کر ہو ن نٲزل تیٚلہِ تہِ کر ہو ن سُہ انسٲنی شکلہِ منٛزٕ ے نٲزِل تہٕ یِتھہٕ پٲٹھۍ کر ہوکھ یِم تتٔھۍ شکس منٛز مبتلا یتھ منٛز یِم وُنۍ کیٚنَس مبتلا چِھ۔"
  6,10,"۔اے نبی صلی اللہ علیہ وسلم، تۅہیہِ برونٛہہ تہِ چُھ واریاہن رسولن ہَزٕ ل کر نہٕ آمُت، مگر تِمن ہَزٕ ل کر ن والیٚن پٮ۪ٹھ سپٕز ٲخرس سۅ ے حقیقت مُسلّط یتھ تِم ہَزٕ ل ٲسۍ کران۔ع۔"
  6,11,"۔ یِمن ؤنِو ،زمینس پٮ۪ٹھ پھیٖرِ تھ وُچھتَو بُتھ پھِر ن والیٚن ہُند کیا انجام چُھ سپُد مُت۔"
  6,12,"۔یِمن پٕرٛژِھو، آسما نن تہٕ زمینس منٛز یِکینژھاہ چُھ سُہ کٔمۍ سُند چُھ؟ ؤنِو سورُے کینٛہہ چُھ اللہ تعالیٰ سُندُے تٔمۍ چُھ رحم و کر مُک طر یقہ پانس پٮ۪ٹھ لٲزِم کوٚر مُت ﴿توَے چُھنہٕ سُہ نا فر مٲنِین تہٕ سر کٔشِیَن پٮ۪ٹھ تۅہیہِ جلد ی تھپھ ترٛاوان﴾ قیا مت کہ دۅ ہ کر یوسُہ تۅہیہِ سارِنٕے ضروٗر جمع ، یہِ چھےٚ با لکل اکھ شکہٕ روٚ س حقیقت ،مگر یِمو لُکو خۅد پنُن پان تبٲہی منٛز مبتلا چُھ کوٚر مُت تِم چِھنہٕ یہِ مانان۔"
  6,13,"۔رٲژ ہٕندِس اَنہِ گٔٹِس منٛز تہٕ دۅ ہ کِس گا شس منٛز یِکینژھاہ ٹھٔہرِتھ چُھ ،سورُے چُھ اللہ تعالیٰ سُند تہٕ سُہ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  6,14,"۔ؤنِو ، کیا اللہ تعالیٰ ترٲوِتھ بناو نہٕ بہٕ بیٚیہِ کانٛہہ پنُن سرپرست؟ سُہ خُدا ے ترٲوِتھ یُس زمین و آسما نُک خا لق چُھ۔ تہٕ یُس روٗزی دِوان چُھ، روٗزۍ چُھنہٕ نِوان؟ ؤنِو ،مےٚ چُھ یۅ ہے حکم دِنہٕ آمُت زِ سارِوٕے برونٹھ نوٚ مر اوٕ بہٕ تس برونٛہہ کنہِ سر ﴿تہٕ تا کید چُھ کر نہٕ آمُت زِ کانٛہہ چُھ شر ک کران تہٕ کٔرِ تَن﴾ ژٕ مَہ گژھ بہر حال مشر کن منٛز شٲمل۔"
  6,15,"۔ؤنِو اگر بہٕ پننِس ربّ سٕنز نافر ما نی کرٕ ، تیٚلہِ چُھس کھۅژان زِ اکہِ بڈِ ﴿خو ف ناک ﴾ دۅ ہ پیٚیہِ مےٚ سزا رٹُن۔"
  6,16,"۔تمہِ دۅ ہ یُس سزا نِشہِ بچا و ، تس پٮ۪ٹھ کوٚر خُدا ین سٮ۪ٹھاہ بوٚڈ رحم، تہٕ یہے چھےٚ ٹاکارٕ کامیٲبی۔"
  6,17,"۔ہرگاہ اللہ تعالیٰ تۅہیہِ کُنہِ قسمُک نقصان واتناوِ، تیٚلہِ چُھنہٕ تس ورٲے کانٛہہ یُس تۅہیہِ تَمہِ نقصا ن نِشہِ بچٲوِتھ ہیٚکہِ ، تہٕ اگرسُہ تۅہیہِ کُنہِ رٕژرٕ سٍتۍ آباد کرِ،تیٚلہِ چُھ سُہ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  6,18,"۔سُہ چُھ پننیٚن بند ن پٮ۪ٹھ کٲمِل اختیارات تھاوان، بیٚیہِ چُھ دانا تہٕ با خبر ۔"
  6,19,"۔یِمن پٕرٛژِھو ،کٔمۍ سٕنز گوٲہی چھےٚ سارِوٕے کھۅتہٕ کھٔسِتھ؟ ؤنِو ، مےٚ تہٕ تۅہیہِ در میان چُھ اللہ تعالیٰ گواہ، تہٕ یہِ قرآن چُھ مےٚ کُن بذر یعہ وَحی سوزنہٕ آمُت،تاکہِ تۅہیہِ بیٚیہِ یس یس نِشہِ یہِ واتہِ سارِنٕے کرٕ نہیب، کیا پٔزِ پٲٹھۍ ہیٚکہِ وٕہ توٚہۍ لُکھ یہِ شہادت دِتھ، زِ خُدا یس سٍتۍ چِھ با قی خدا ے تہِ ؟﴿کُنہِ چیز چ شہا دت دِنہٕ خٲطرٕ چُھنہٕ محض قیا س یا گُمان کا فی کینٛہہ، بلکہ چُھ امہِ خٲطرٕ علم آسُن ضروری ییٚمہِ کِس بُنیا دس پٮ۪ٹھ انسان یقین سان ہیٚکہِ ؤنِتھ زِ یِتھہٕ پٲٹھۍ چُھ۔ لہٰذا چُھ سوالُک مطلب یہِ زِ کیا پز ی چُھو ا تۅہیہِ یہِ علم زِ یتھ دُنیا ہَس اندر چُھ خُدا یس ورٲے بیٚیہِ تہِ کانٛہہ کا ر فر ما حا کم اختیارٕ وول یَس بند گی تہٕ پرستش ہُند حقدار گژِھہ آسُن﴾ ؤنِو ، بہٕ ہیٚکہِ نہٕ ہر گز اَمِچ شہا دت دِتھ ؤنِو ، اللہ تعالیٰ چُھ سُہ اکھ تہٕ بہٕ چُھس تمہِ شر کہٕ نِشہِ کُنہِ شکہٕ روٚس بے زار یتھ منٛز توٚہۍ چِھو ہیٚنہٕ آمٕتۍ۔"
  6,20,"۔یِمن لُکن اَسہِ کتا ب چھےٚ دِژمٕژ تِم چِھ اتھ کتھہِ تِتھہٕ پٲٹھۍ شکہٕ روٚ س پرٛزٕ ناوان یِتھہٕ پٲٹھۍ تِمن پننیٚن نیٚچو ٮ۪ن پرزٕ ناونس منٛز کانٛہہ شک چُھنہٕ آسان مگر یِمو پنُن پان خۅد خسارس منٛز تر وومُت چُھ تِم چِھنہٕ اَتھ مانان۔ع"
  6,21,"۔تہٕ تس شخصہٕ سٕندِ کھۅتہٕ کھٔسِتھ ظٲلِم کُس آسہِ یُس خُدا یس پٮ۪ٹھ اَپُز بہتا ن  لگاوِ، یا کرِ اللہ تعالیٰ سٕنز ن نِشٲنِین انکار؟ پٔزۍ پٲٹھۍ ہیٚکن نہٕ یِتھۍ ظٲلِم کامیٲبی لٔبِتھ۔"
  6,22,"۔ییٚمہِ دۅ ہ یِم سٲر ی جمع کر و کھ تہٕ مُشر کن پٕرٛژَھو  زِ وۅ نۍ کتہِ چِھ تِم  تُہٕندۍ ٹھۂر او نہٕ آمٕتۍ شر یک یِم توٚہۍ پنٕنۍ خُدا ے ٲسِیوٗکھ سمجھان"
  6,23,"۔ تہٕ تِم ہیٚکن نہٕ اَمہِ وَرٲے کانٛہہ فتنہ تُلِتھ زِ ﴿یہِ اَپُز بیان دِن زِ ﴾ اے سانہِ مٲلکہٕ ، چو ن قسم ٲسۍ نٕہ أسۍہر گز مُشر ک۔"
  6,24,"۔وُچِھو ،تمہِ وقتہٕ کِتھہٕ پٲٹھۍ بَناون یِم پا نس پٮ۪ٹھ اَپُز، تہٕ تَتہِ روان یِہِندۍ سٲری بنا وٹی معبود۔"
  6,25,"۔یِمن منٛز چِھ کینٛہہ لُکھ تِتھۍ یِم کن دٲرِ تھ تُہٕنز کتھ بوزان چِھ مگر حال چُھ یہِ زِ اَسہِ چِھ تِہندٮ۪ن دِلن پٮ۪ٹھ پردٕہ تھٲوِمٕتۍ ترٲوِتھ یِہِندِ وجہ کِنۍ تِم اَتھ چِھنہٕ کِہِنۍ سمجھان تہٕ تِہند ٮ۪ن کنن منٛز چُھ گۅ بیٚر ترٛ وومُت ﴿زِ سورُے کینٛہہ بوزنہٕ پتہٕ تہِ چِھنہٕ کِہِنۍ بوزان ﴾ تِم وُچِھتن کانٛہہ تہِ نشٲنی ،اتھ پٮ۪ٹھ اَنن نہٕ ایمان ، حد چُھ یہِ زِ ییٚلہِ تِم تۅہیہِ نِشہِ یِتھ ژُوان چِھ، تِمو منٛزٕ یِمو لُکو انکارُک فٲصلہٕ چُھ کوٚرمُت تِم چِھ ﴿ سار یے کتھہٕ بوزنہٕ پتہٕ ﴾ یی وَنان زِ یِمہٕ چھےٚ پرا نیٚن لُکن ہٕنزٕ دلیلہٕ بیٚیہِ نہٕ کِہِنۍ۔"
  6,26,"۔تِم چِھ یہِ پٔز کتھ قبول کر نہٕ نِشہِ لُکن رُکاوان تہٕ پانہٕ تہِ چِھ امہِ نِشہِ دوٗر ژَلا ن ﴿تِمن چُھ باسان یہِ کر نہٕ سٍتۍ چِھو تِم  تۅہیہِ کینٛہہ بِگا ڑ ان﴾ در اصل چِھ تِم خۅد پننی تبٲہی ہُند سامانہٕ گرا ن مگر تِمن چُھنہٕ امہِ کتھہِ ہُند شعور۔"
  6,27,"۔کا ش توٚہۍ ہیٚکۍ ہِو تمہِ وقتٕچ سۅ حالت وُچِھتھ ییٚلہِ تِم جہنم کِس بٔٹھِس پٮ۪ٹھ کھڑا یِن کر نہٕ تمہِ وقتہٕ ونَن تِم زِ کا ش کانٛہہ صوٗرتھا ہ آسہِ ہے تِژھ زِ أسۍ گٔژھۍ دُنیا ہس منٛز بیٚیہِ واپس یِنۍ سوز نہٕ تہٕ پننِس ربّ سٕنز ن نِشٲنِیَن پھِر ہَو نہٕ بُتھ تہٕ ایمان انن والیٚن منٛز گژھہَو شٲمل۔"
  6,28,"۔در حقیقت وَنن تِم یہِ کتھ محض امہِ وجہ کِنۍ زِ یتھ حقیقتس پٮ۪ٹھ تِمو پردٕہ ترٲوِتھ اوس تھو و مُت سۅ آسہِ  تمہِ وقتہٕ بے نقا ب سپدِ تھ تِمن برونٹھ کُن آمٕژ،نَتہٕ ہرگاہ تِم پرا نہِ زند گی منٛز واپس یِن سوزنہٕ تیٚلہِ کر ن تی سورُے کینٛہہ ییٚمہِ نِشہِ تِمن ٹھا کھ چُھ کر نہٕ آمُت ۔در حقیقت چِھ تِم اَپزِ یٲرۍ ﴿امہِ موجو ب ہیٚن پننہِ امہِ خوٲہشہِ ہٕندِس اِظہا رس منٛز اَپزِ سٕے کٲم ﴾"
  6,29,"۔ از چِھ یِم لُکھ ونان زِ زند گی یِکینژھاہ تہِ چھےٚ بس چھےٚ یٔہے سٲنۍ دُنیا ہٕچ زند گی تہٕ أسۍ یِمو نہٕ مر نہٕ پتہٕ ہر گز دو بارٕ تھوٚد تُلنہٕ۔"
  6,30,"۔کا ش توٚہۍ ہیٚکۍہِوسُہ منظر وُچِھتھ ییٚلہِ یِم پننِس ربّس برونٹھہٕ کنہِ کھڑا یِن کر نہٕ، تمہِ وقتہٕ پٕرٛژِھہ یُہُند ربّ یِمن کیا یہِ چھنا حقیقت؟ یِم وَنن : آ، اے سانہِ ربّہ ، یٔہے چھےٚ حقیقت، سُہ فر ماوِ :  اچھا ، وُچِھو تیٚلہِ عذا بُک مزٕ ہ تِکیازِ توٚہۍ ٲسِو حقیقتس انکار کران۔ ع"
  6,31,"۔تِم لُکھ آے خسا رس منٛز ہیٚنہٕ یِمو خُدا یس سٍتۍ پننہِ ملا قا تُک اطلا ع اَپُز دِیُت قرار ییٚلہِ اچا نک سۅ گٔر واتہِ تیٚلہِ وَنن یِمے لُکھ افسو س ! اتھ معا ملس منٛز کِیُتھ تقصیر گوٚو اَسہِ ۔ تہٕ یِمن ہُند حال آسہِ یہِ ز پنیٚن شانَن پٮ۪ٹھ آسن پننیٚن گنا ہن ہُند بور ہیٚتھ،وُچِھو ! کِیُتھ ناکارٕ بور چُھ یُس یِم تُلان چِھ ۔"
  6,32,"۔ دُنیا ہٕچ زند گی چھےٚ اکھ کھیل تہٕ اکھ تما شہِ ۔﴿اَمِیُک مطلب چُھنہٕ یہِ زِ دُنیا چہ زند گی منٛز چَھنہٕ کانٛہہ سنجیدٕ گی تہٕ یہِ چھےٚ محض کھیل تہٕ تما شہِ رٔنگۍ بناو نہٕ آمٕژ۔دراصل چُھ اَمِیُک مطلب یہِ زِ ٲخرت چہِ حقیقی تہٕ پایدار زند گی ہٕندِس مقا بلس منٛز چھےٚ یہِ دُنیا ہٕچ زند گی تِژھ زنتہٕ کانٛہہ شخص رَنٛز ناوِ کھیلہِ تہٕ تفر یح سٍتۍ دِل تہٕ پتہٕ یِیہِ پننِس اصلی سنجیدٕہ کاروبارس کُن وا پس۔ امہِ علا وہ چُھ اتھ کھیلہِ تہٕ تما شس سٍتۍ امہِ موجو ب تہِ ہِشر آمُت دِنہٕ زِ ییٚتہِ چِھ حقیقت  ژھایہِ آسنہٕ کہ وجہ کِنۍ بے بصیرت تہٕ ظا ہر پرست انسانن  خٲطرٕ غلط فہمیِن منٛز مبتلا سپد نٕکۍ واریاہ سبب موجود تہٕ یِمن غلط فہمِین منٛز پھٔسِتھ چِھ  لوٗکھ حقیقت نفسُ الامر ی ﴿تِم پٔزۍ حالات یِم دوست دشمن سٲری چِھ مانان ﴾ خلا ف تِتھۍ تِتھۍ عجیب طر ز عمل ورتاوان یِہِندِ بد و لت تِہٕنز زند گی محض اکھ کھیل تہٕ تما شہِ چھےٚ روزان بٔنِتھ ۔﴾ در حقیقت چُھ ٲخرت کُے مقا م تِمن لُکن خٲطرٕ بہتر یِم زیاں کٲری ﴿نقصا ن وا تنا و نہٕ ﴾ نِشہِ بچُن چِھ یژھان تیٚلہِ کیا توٚہۍ لُکھ ہیٚیِو نا عقلہِ کٲم؟"
  6,33,"۔اے نبی صلی اللہ علیہ وسلم، اسہِ چُھ معلو م زِ یِمہٕ کتھہٕ یِم لُکھ بناوان چِھ تِمو سٍتۍ چُھو تۅہیہِ تکلیف واتان البتہ یِم لُکھ چِھو نہٕ تۅہیہِ بُتھ پھِران بلکہ چِھ یِم ظٲلِم در اصل اللہ تعالیٰ سٕندٮ۪ن آیا تن انکار کران۔﴿وا قعہ چُھ یہِ زِ یوٚت تام حضور صلی اللہ علیہ وسلمو اللہ تعالیٰ سٕندۍ آیات بوزناوٕ نۍ شر وع ٲسۍ نہٕ کٔرِمٕتۍ ،توٚت تام ٲسۍ تِہندِ قو مٕکۍ سٲر ی لُکھ تِمن ، امین تہٕ صادق سمجھان، تہٕ تِہنزِ پر ہیز گٲر ی پٮ۪ٹھ اوسُکھ مکمل اعتماد۔تِمو کوٚر حضور صلی اللہ علیہ وسلمس تمہِ وقتہٕ انکار ییٚلہِ زن تِمو اللہ تعالیٰ سٕندِ طر فہٕ پیغا م وا تنا وُن شر وع کوٚر تہٕ اَتھ دوٚیِمِس دَورس منٛز تہِ اوس نہٕ کانٛہہ تِیُتھ یُس شخصی حیثیتہٕ تِمن اَپزِ یو ر قرار دِنُک جُرا ت ہیٚکہِ ہے کٔرِ تھ۔حضور صلی اللہ علیہ وسلمن ہٕندۍ کٲنٛسہِ سخت کھۅتہٕ سخت مخا لفِن تہِ لگو و نہٕ زانٛہہ تِمن پٮ۪ٹھ یہِ الزام زِ تِم صلی اللہ علیہ وسلم چِھ دُنیا کِس کُنہِ معا ملس منٛز زانٛہہ اَپُز وَننٕکۍ مر تکب سپٕدۍ مٕتۍ۔ تِمو یوٗتاہ تہِ حضور صلی اللہ علیہ وسلمن ہُند تکذ یب کوٚر سُہ کوٚرُکھ محض نبی آسنہٕ کہ حیثیتہٕ ۔ حضور صلی اللہ علیہ وسلمن ہُند سارِوٕے کھۅتہٕ بوٚڈ دشمن اوس ابو جہل۔حضرت علی رضی اللہ عنہ چِھ روا یت کران زِ اکہِ دۅ ہ ووٚن تٔمۍ پانہٕ حضور صلی اللہ علیہ وسلمس سٍتۍ کتھ کران کران  أسۍ چِھو نہٕ تۅہیہِ اَپزِ یو ر وَنان ،مگر یِکینژھاہ توٚہۍ پیش چِھو کران تتھ چِھ اَپُز قرار دِوان ۔﴾"
  6,34,"۔تۅہیہِ برونٛہہ تہِ چِھ واریاہن رسولن انکار آمُت کر نہٕ، مگر اتھ انکارس پٮ۪ٹھ تہٕ تِمن سختی یَن پٮ۪ٹھ یِمہٕ تِمن واتنا و نہٕ آیہِ ، کوٚر تِمَو صبر،یوٚت تام زن تِمن سو ن مدد ووت۔اللہ تعالیٰ سٕنزٕ کتھہٕ بد لاونُک طا قت چُھنہٕ کٲنٛسہِ منٛز، تہٕ پتمیٚن رسولن سٍتۍ یِکینژھا ہ پیش آو تمہِ چہِ خبرٕ چَھو تۅہیہِ واژٕ مژے۔"
  6,35,"۔تاہم اگر یِمن لُکن ہٕنز بے رُخی تۅہیہِ برداشت چَھنہٕ سپدان، تیٚلہِ اگر تۅہیہِ منٛز کانٛہہ زور چُھ تیٚلہِ ژھٲنڈِ و زمینس اندر کانٛہہ سُر نگ﴿ ٹنل﴾ یا لٲگِو آسمانس ہیر تہٕ کٔرِ و تِمن تام کانٛہہ نشٲنی اَنٕنچ کو شش اگر اللہ تعالیٰ ییژِہے تِمن سارِنٕے ہیٚکہِ ہے ہدا یتس پٮ۪ٹھ جمع کٔرِ تھ، لہٰذا مَہ بٔنِو نادان۔﴿یعنی یہِ فِکر مَہ کٔرِ و یِمن لُکن گٔژھ کانٛہہ نشٲنی ہاو نہٕ یِنۍ ییٚمہِ سٍتۍ یِم ایمان اَنہن۔خُدا یس ہرگاہ یہِ در نظر آسہِ زِ سٲر ی انسان گٔژھۍ سیٚزِ وَتہِ پٮ۪ٹھ جمع یِنۍ کر نہٕ تیٚلہِ کرِ ہے سُہ سارِنٕے مو مِن پٲدٕ۔ تیٚلہِ کیا ضرورت ٲس رسول سوزنٕچ تہٕ اہلِ ایمانن تہٕ اہلِ کفر ن در میان ؤری وادن کشمکش کر ناونٕچ ﴾"
  6,36,"۔حق کِس دعوتس پٮ۪ٹھ چِھ لبیک تِمے لُکھ وانان یِم بو زن وٲلۍ چِھ ،روٗدۍ مُردٕ ہ تِمن تُلہِ اللہ تعالیٰ بس قبر و منٛزے ﴿بوزن والیو نِشہِ چِھ مُراد تِم لُکھ یِہِندۍ ضمیر زندٕہ چِھ ، یِمو پنٕنۍ عقل تہٕ فکر چَھنہٕ معطل کٔر مٕژ، تہٕ یِمو پننیٚن دِلن ہٕندٮ۪ن دروازن پٮ۪ٹھ تعصُبٕکۍ تہٕ جُمو دٕ کۍ قُلف چِھنہٕ کھٲلِمٕتۍ۔یِہِندِس مقا بلس منٛز چِھ مُردہ تِم لُکھ یِم لکیرِ ہٕندۍ فقیر بٔنِتھ اَنیٚن ہٕندۍ پٲٹھۍ پکان چِھ روزان تہٕ امہِ لکیرِ نِشہِ ڈٔلِتھ چِھنہٕ کٕہٕنۍ کتھ بوزنہٕ خٲطرٕ تیار خوا ہ سُہ کیا زِ آسہِ نہٕ ٹا کارٕ حقٕے﴾ تہٕ پتہٕ یِن تِم ﴿تٔمۍ سٕندِس عدا لتس منٛز پیش سپدنہٕ خٲطرٕ﴾ وا پس اَننہٕ ۔"
  6,37,"۔یِم لُکھ چِھ ونان زِ أمِس نبی  ﴿صلی اللہ علیہ وسلمس﴾ پٮ۪ٹھ کیازِ آیہِ  نہٕ أمۍ سٕندِس ربّ سٕندِ طر فہٕ کانٛہہ نشٲنی نازِل کر نہٕ ؟ ؤنِو ،اللہ تعالیٰ چُھ نشٲنی نٲزِل کر نٕچ پوٗرٕ قدرت تھاوان، مگر یِمو منٛزٕ چِھ اکثر لُکھ نا دٲنی منٛز مبتلا ۔﴿نشٲنی نِشہِ چُھ مُراد سُہ معجزٕہ یُس اتھہِ یِیہِ ۔ اللہ تعالیٰ سٕندِ امہِ ارشادُک مطلب چُھ یہِ زِ معجزٕہ نَہ ہا و نُک وجہ چُھنہٕ یہِ زِ اَسہِ چُھنہٕ معجزٕہ ہاو نُک طا قت بلکہ چُھ اَمِیُک وجہ بیٚیہِ تہِ کینٛہہ یتھ یِم لُکھ محض پننہِ نا دانی کِنۍ چِھنہٕ سمجھان﴾"
  6,38,"۔زمینس منٛز پکن وول کانٛہہ جانور تہٕ ہوا ہس منٛز پکھو سٍتۍ وُڈن وول کانٛہہ پر ندٕ ہ وُچھتو ن،یِم سٲر ی چِھ تُہندی پٲٹھۍ اَنوا ع  ﴿یعنی طبقہٕ ﴾، اسہِ چَھنہٕ یِہندِس تقدیر کِس نَوِ شتَس ﴿تحر یرس﴾ منٛز کانٛہہ کسرِ تھٲومٕژ، پتہٕ چِھ یِم سٲر ی پننِس ربّس کُن ؤٹِتھ یِوان اَننہٕ۔"
  6,39,"۔مگر یِم لُکھ سانیٚن نِشٲنیَن بُتھ چِھ پھِرا ن تِم چِھ زٔرۍ تہٕ کٔلۍ ، اَنہِ گٹن منٛز چِھ ہیٚنہٕ آمٕتۍ ،اللہ تعالیٰ یس یژھان چُھ تس چُھ ڈالان تہٕ یس یژھان چُھ تس چُھ سیٚزِ وَتہِ پٮ۪ٹھ لاگان۔﴿ اللہ تعالیٰ سُند ڈالُن چُھ یہِ زِ أکِس جہا لت پسند اِنسا نس گژِھ نہٕ اللہ تعالیٰ سٕنز ن نشٲنِین ہٕندِ مطا لعُک تو فیق دِنہٕ یُن تہٕ ہرگاہ اکھ تعصب تھاون وول غیر حقیقت پسند طا لب علم یُہُند مُشاہدٕہ تہِ کرِ تٔمۍ سٕنز وأچھو نِشہِ روزن حقیقت پرزناونٕکۍ نِشانہٕ دوٗرتہٕ غلط فہمی منٛز پھسا ون وٲلۍ چیز نِن تس حق نِشہِ دوٗر کھۅتہٕ دوٗر۔اتھ بر عکس چُھ اللہ تعالیٰ سٕندِ طر فہٕ ہدا یت یہِ زِ أکِس طا لب حقس یِیہِ علم کیو ذٔر یو نِشہِ فٲیدہ تُلنُک تو فیق بخشنہٕ تہٕ اللہ تعالیٰ سٕند یو آیا تو نِشہِ روز نس حقیقتس تام واتنٕکۍ نِشانہٕ میلان﴾"
  6,40,"۔یِمن ؤنِو ،غو ر کٔرِ تھ ؤنۍ تو ، ہرگاہ کُنہِ ساعتہٕ تۅہیہِ پٮ۪ٹھ اللہ تعالیٰ سٕندِ طر فہٕ کانٛہہ مصیبت یِوان چُھ یا پٔتِم گٔر واتان چھےٚ، کیا تمہِ ساعتہٕ چِھوٕہ توٚہۍ خُدا یس ورٲے بیٚیہِ کٲنٛسہِ ناد لایان؟ؤنِو اگر توٚہۍ پز یٲرۍ چِھو۔"
  6,41,"۔تمہِ وقتہٕ چِھو توٚہۍ اللہ تعالیٰ سٕے ناد لایان، پتہٕ ہرگاہ سُہ یژھان چُھ تیٚلہِ چھُ یہِ مصیبت تۅہیہِ نِشہِ دوٗر کران،یِتھیٚن مو قعن پٮ۪ٹھ چِھو تۅہیہِ پنٕنۍ ٹھہراو نہٕ آمٕتۍ شر یک مٔشِتھ گژھان۔ع ﴿یعنی یہِ نشٲنی چَھو تۅہیہِ پننِس پانس اندر موجود۔ییٚلہِ کانٛہہ بوٚڈ مصیبت یِوان چُھ یا موت چُھ پننِس خو فناک صورتس منٛز  تۅہیہِ برونٛہہ کنہِ کھڑا سپدان تمہِ ساعتہٕ چَھو نہٕ بس أکِس اللہ تعالیٰ سٕندِ دا من ورٲے بیٚیہِ کٲنٛسہِ ہٕنز چھپن جا ے اتھہِ یِوان ۔ بٔڑۍ بٔڑۍ مُشر ک چِھ یِتھیٚن مو قعن پٮ۪ٹھ پننیٚن معبوٗدن مٔشرٲوِتھ کُنِس خُدایس آلو دِنہِ لگا ن ۔ سخت کھۅتہٕ سخت دہر یہِ ﴿ خُدا یس انکار کر ن وول ﴾ تام چھُ خدا یس برونٛہہ کنہِ اتھہٕ داران۔یہِ چھےٚ اَمہِ کتھہِ ہٕنز دٔلیل زِ خدا پرستی تہٕ تو حیدٕ چ شہا دت چھےٚ پرٛتھ انسان سٕندِس نفسس منٛز موجو د یتھ پٮ۪ٹھ غفلتٕکۍ تہٕ جہا لتٕکۍ کٲتیاہ تہِ پردہ آسن ترا و نہٕ آمٕتۍ ، مگر تو تہِ چھےٚ سۅ کُنہِ نتہٕ کُنہِ ساعتہٕ وۅ تِلتھ برونٹھ کُن یِوان ۔﴾"
  6,42,"۔تۅہیہِ برونٛہہ سوٗزۍ اَسہِ واریاہن قو من کُن رسول پتہٕ کٔرۍ تِم قو م تکلیفن تہٕ مشکلا تن اندر مبتلا تا کہ تِم نَمن عٲجزی سان اسہِ برونٛہہ کنہِ۔"
  6,43,"۔البتہ ییٚلہِ تِمن پٮ۪ٹھ سانہِ طر فہٕ سختی آیہِ تیٚلہِ کیا زِ کٔر نہٕ تِمو عٲجز ی اختیار؟ مگر تِہِندۍ دِل سپدٕۍ وارَے سخت تہٕ شیطا نن دِیُت تِمن اِطمینان زِ یِکینژھاہ توٚہۍ کران چِھو تہِ چِھو ٹھیک کران۔"
  6,44,"۔ پتہٕ ییٚلہِ تِمو سۅ نصیحت مٔشرٲویو سہٕ تِمن کر نہٕ ٲس آمٕژ،اَسہِ ترٛٲوۍ تِہِندِ خٲطرٕ پرٛتھ رنگہٕ چن خۅ شحٲلین ہٕندۍ دروازٕہ یلہٕ، یوٚت تام تِم تِمن بخچٲیِشن منٛز خو ب مست سپٕدۍ یِم تِمن عطا آسہٕ کر نہٕ آمژٕ، پتہٕ رٔٹھۍ تِم اسہِ اچا نک تہٕ وۅ نۍ اوس حال یہِ زِ تِم ٲسۍ پرٛتھ خیر نِشہِ مایو س۔"
  6,45,"۔یِتھہٕ پٲٹھۍ آو تِمن لُکن ہُند موٗل ژٔٹِتھ ترٛا و نہٕ یِمو ظلم اوس کوٚر مُت تہٕ  پرٛتھ کانٛہہ تعر یف چُھ اللہ رب العا لمینس خٲطرٕ ﴿زِ تٔمۍ ژوٚٹ تِہُند موٗل﴾۔"
  6,46,"۔ اے نبی صلی اللہ علیہ وسلم ، یِمن ؤنِو ، زانٛہہ سوٗ نچُوٕ ہ تۅہیہ  یِتہِ زِ ہرگاہ اللہ تعالیٰ تُہٕنز بینٲیی تہٕ سما عت ﴿أچھ گاش تہٕ بوزَن بل﴾ تھپہِ نِیہِ تہٕ تُہٕند ٮ۪ن دِلن کرِ مۅ ہر ۔﴿یتھ جایہِ چُھ مۅ ہر مُراد سو نچنٕچ سمجھنٕچ صلٲحیت تہٕ طا قت سلب کرٕنۍ ﴾ تہٕ خُدا یس ورٲے کُس خُدا ے چُھ بیٚیہِ یُس یِمہٕ قُوّتہٕ واپس ہیٚکہِ دِیاو نٲوِتھ؟ وُچھِو، کِتھہٕ پٲٹھۍ چِھ أسۍ گرِ گرِ پننہِ نشٲنیہِ  یِمن برونٛہہ کنہِ پیش  کران تہٕ پتہٕ کِتھہٕ پٲٹھۍ چِھ یِم تِمَو نِشہِ نظر ڈالان۔"
  6,47,"۔ ؤنِو ، توٚہیہِ سوٗنچُوٕہ زانٛہہ ہرگاہ اللہ تعالیٰ سٕندِ طر فہٕ اچا نک یا نٔنۍ پٲٹھۍ تۅہیہِ پٮ۪ٹھ عذا ب یِیہِ پتہٕ ؤنۍ تو ظا لم لُکو ورٲے گژھیا کانٛہہ ہلاک؟"
  6,48,"۔أسۍ یِم رسول سوزان چِھ تِم چِھ اَمی مۅ کھہٕ سوزان زِ تِم گژھن نیک کردار لُکن خٲطرٕ خۅ ش خبر دِنہٕ وٲلۍ تہٕ بد کردار لُکن خٲطرٕ کھۅژناون وٲلۍ آسٕنۍ،پتہٕ یِم لُکھ تِہٕنز کتھ مانن تہٕ پننہِ طر زِ عملُک اصلا ح کر ن،تِمن خٲطرٕ چُھنہٕ کُنہِ خو فُک یا غمُک مو قع،"
  6,49,"۔تہٕ یِم لُکھ سا نیٚن آیا تن بُتھ پھِر ن تِم تُلن پننیٚن نا فر مٲنِین ہٕندِس پا داشس منٛز سزا۔"
  6,50,"۔اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو ،  بہٕ چُھس نہٕ تۅہیہِ یہِ وَنان زِ مےٚ نِشہِ چِھ اللہ تعالیٰ سٕندۍ خزا نہٕ نہ چُھم غیبُک علم، تہٕ نہ چُھس یہِ ونان زِ بہٕ چُھس فر شتہٕ، بہٕ چُھس صرف تمہِ و حی ہٕنز پیر وی کران یۅسہٕ مےٚ پٮ۪ٹھ نٲزِل چھےٚ یِوان کر نہٕ پتہٕ پرٛژِھو یِمن : کیا اوٚ ن تہٕ بیٚیہِ گا شدار دۅ شو ے ہیٚکہٕ نہٕ برابر ٲسِتھ؟کیا توٚہۍ چِھو نا غور کران ؟ ع"
  6,51,"۔تہٕ اے نبی صلی اللہ علیہ وسلم ،توٚہۍ کٔرِ و تَمہِ ﴿وَحی ہِندِ علمہٕ﴾ کہ ذریعہ تِمن لُکن نصیحت یِمن امہِ کتھ ہُند خو ف چُھ زِ پننِس ربّس برونٛہہ کنہِ یِن تتھ حالس منٛز پیش کر نہٕ زِ تس ورٲے آسہِ نہٕ تَتہِ کانٛہہ ﴿تِیُتھ اقتدارٕ وول ﴾ یُس تِہُند حٲمی تہٕ مدد گار آسہِ ، یا کرِ تِمن سفٲرش، شاید ماکر ن ﴿ییٚمہِ نصیحت نِشہِ ہیٚن رٔٹِتھ﴾ تِم پر ہیز گٲر ی ہٕنز رٔوِش اختیار۔"
  6,52,"۔تہٕ یِم لُکھ دۅ ہس راتس پننِس ربّس ناد چِھ لایان تہٕ تٔمۍ سٕنز خۅ شنود ی حٲصل کر نس کُن چِھ لٔگۍ مٕتۍ تِم مَہ چھٔکِیوٗکھ پا نس نِشہِ دوٗر ، تِہندِ حسا بہٕ منٛزٕ چُھنہٕ کُنہِ چیزُک با ر تۅہیہِ پٮ۪ٹھ تہٕ تُہٕندِ حسا بہٕ منٛزٕ چُھنہٕ کُنہِ چیزُک با ر تِمن  پٮ۪ٹھ ،اتھ پٮ۪ٹھ تہِ ہرگاہ توٚہۍ تِم دوٗر چھٔکِیوٗکھ تیٚلہِ سپدِ و ظٲلِمن منٛز شما ر۔"
  6,53,"۔یِتھہٕ پٲٹھۍ چِھ دراصل اسہِ یِمو لُکو منٛزٕ کینٛہہ کینژھن ہٕندِ ذر یعہ آز مٲیشہِ منٛز ترٲوِ مٕتۍ،﴿یعنی غر یب، مُفلس تہٕ تِم لُکھ یِم سما جس منٛز ادنیٰ حیثیت چِھ تھاوان،تِمن سارِوٕے برونٛہہ ایمانُک تو فیق دِتھ چِھ اَسہِ دو لتُک تہٕ عز تُک غروٗر تھاو ن وٲلۍ لُکھ آز مٲیشہِ منٛز ترٲوِمٕتۍ ۔﴾تا کہ یِمن وُچِھتھ وَنن تِم :  کیا یِم چھا تِم لُکھ یِمن پٮ۪ٹھ اسہِ در میان اللہ تعالیٰ سُند فضل و کر م سپُد؟ آ، کیا اللہ تعالیٰ چُھنا پننیٚن شکر گزار بند ن یِہندِ کھۅتہٕ زیادٕہ زانان؟"
  6,54,"۔ییٚلہِ تۅہیہِ نِشہِ تِم لُکھ یِن یِم سانیٚن آیاتن پٮ۪ٹھ ایمان چِھ انان تِمن ؤنِو : تۅہیہِ پٮ۪ٹھ چھےٚ سلامتی، تُہندۍ ربّن چُھ رحم و کر مُک طر یقہٕ پا نس پٮ۪ٹھ لٲزِم کوٚر مُت، ﴿بس یہِ چُھ تٔمۍ سُند رحم و کر م ﴾ زِ ہرگاہ تۅہیہِ منٛزٕ کٲنٛسہِ نا دٲنی سان کُنہِ بُرٲیی ہُند اَتُرکوٚرمُت آسہِ ، پتہٕ کرِ اَمہِ پتہٕ تو بہٕ تہٕ بیٚیہِ کرِ اصلا ح ، تیٚلہِ چُھ تَس معا ف کران بیٚیہِ چُھ نر می کٲم ہیٚوان ۔﴿یِمو لُکو تَمہِ وقتہٕ نبی صلی اللہ علیہ وسلمن پٮ۪ٹھ ایمان اوس اوٚ نمُت تِمن منٛز ٲسۍ واریاہ لُکھ تِتھۍ تہِ یِمن جٲہلیت کِس زمانس منٛز بٔڑۍ بٔڑۍ گناہ ٲسۍ سپٕدۍ مٕتۍ۔ اگر چہِ وۅ نۍ اسلام قبول کر نہٕ پتہٕ تِہٕنزٕ زند گیہ با لکل بد لیمژٕ آسہٕ مگر اسلامٕکۍ مخالف ٲسۍ تِمن پٔتِمہِ زند گی ہٕند ٮ۪ن عٲبن تہٕ حر کتن ہٕنزٕ پامہٕ تہٕ طعنہٕ دِوان۔ اتھ پٮ۪ٹھ چُھ یِوان فر ماو نہٕ زِ اہلِ ایمانن دِیِو دِلا سہٕ ،یِمن ؤنِو زِ یُس شخص تو بہٕ کٔرِ تھ پنُن پان چُھ شیران تٔمۍ سٕندٮ۪ن پٔتِمیٚن قصوٗرن پٮ۪ٹھ گرِ فت کرٕنۍ چُھنہٕ اللہ تعالیٰ سُند طریقہٕ﴾"
  6,55,"۔تہٕ یِتھہٕ پٲٹھۍ چِھ أسۍ پننہِ نشٲنیہِ ویژٕھنۍ ویٚژٕھنۍ پیش کران تا کہ مُجر من ہٕنز وَتھ سپدِ بالکل ظٲہر ۔ع"
  6,56,"۔ اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو زِ : اللہ تعالیٰ ترٛٲوِتھ یِمن با قین توٚہۍ لُکھ ناد  چھِولایان تِہٕنز بند گی کر نہٕ نِشہِ چُھ مےٚ ٹھا کھ آمُت کر نہٕ۔ؤنِو : بہٕ کرٕ نہٕ تُہنز ن خوٲہشا تن ہٕنز پیر وی ،ہرگاہ مےٚیہِ کوٚر تیٚلہِ سَپدُس گُمراہ ،سِیٔز وَتھ لبن والیٚو منٛز روٗدُس نہٕ۔"
  6,57,"۔ؤنِو : بہٕ چُھس پننِس ربّ سٕندِ طر فہٕ أکِس ٹا کارٕ ہ دلیلہِ پٮ۪ٹھ قٲیِم تہٕ تۅہیہِ چُھو اَتھ بُتھ پھِیرُمُت،وۅ نۍ چُھنہٕ میٲنِس اختیارس منٛز سُہ چیز ییٚمہِ خٲطرٕ توٚہۍ با نبٕر چِھو کران، فٲصلُک سورُے اختیار چُھ خُدا یس ،سُے چُھ امرِ حق بیان کران تہٕ سُے چُھ بہتر ین فٲصلہٕ کر ن وول ۔"
  6,58,"۔ؤنِو: اگر سُہ چیز مےٚ تام آسہِ ہے ییٚمہِ خٲطرٕ توٚہۍ با نٛبٕر چِھو کران۔تیٚلہِ آسہِ ہے مےٚ تہٕ تۅہیہِ در میان خبر کر فٲصلہٕ سپُد مُت، مگر اللہ تعالیٰ چُھ زیادہ بہتر ین زانان زِ ظٲلِمن سٍتۍ کُس معا ملہٕ گژِھہ وَرتا و نہٕ یُن۔"
  6,59,"۔تس نِشہِ چھےٚ غیب چِہ کُنزٕ یِمن تس ورٲے کانٛہہ چُھنہٕ زانان ۔سمندر ن تہٕ خشکی منٛز یِکینٛژھاہ چُھ، سارِچی چھَس خبر ۔کُلہِ پٮ۪ٹھہٕ ؤسِتھ پیٚنہٕ وول کانٛہہ پَنہٕ ؤتھٕر چُھنہٕ تِیُتھ ییٚمِچ نہٕ تس خبر چھےٚ،زمین کیٚن اَنہِ گٔٹۍ پردن منٛز چُھنہٕ کانٛہہ دانہٕ تِیُتھ ییٚمہِ نِشہِ سُہ باخبر چُھنہٕ ،خشک وتر سورُے کینٛہہ چُھ أکِس کُھلہٕ کتا بہِ منٛز لیٚکھِتھ۔"
  6,60,"۔سُے چُھ تس رٲژ منٛز تُہٕندۍ رو ح چُھ قبض کران،تہٕ یِکینژھاہ دۅ ہس توٚہۍ کران چِھو تتھ چُھ زانان،پتہٕ چُھ دوٚیِمہِ دۅ ہ سُہ بیٚیہِ تۅہیہِ تٔتھۍ کارو بار کِس عا لمس منٛز واپس سوزان تاکہ زند گی ہٕنز مقرر مُدّت سپدِ پوٗرٕ،ٲخر کار چھےٚ تٔسۍ کُن تُہٕنز واپسی، پتہٕ وَنیو سُہ زِ توٚہۍ کیا چِھو روٗدِمٕتۍ کران۔"
  6,61,"۔پننیٚن بند ن پٮ۪ٹھ چُھ سُہ پوٗرٕ قدرت تھاوان،تہٕ تۅہیہِ پٮ۪ٹھ چُھ نگرٲنی کرن وٲلۍ مُقرر کٔرِ تھ سوزان ، یوٚت تام زن تۅہیہِ منٛزٕ کٲنٛسہِ ہٕندِ مو تُک وقت چُھ واتان تہٕ تٔمۍ سٕندۍ سوزنہٕ آمٕتۍ فر شتہٕ چِھ تس رو ح قبض کران،تہٕ پنُن فر ض انجا م دِ نس منٛز چِھنہٕ رَژھ تہِ کوتٲہی کران،"
  6,62,"۔پتہٕ چِھ اند ہیٚتھ سٲر ی خُدا یس ،پننِس حقیقی آقا ہس کُن وا پس اَننہٕ یِوان ،خبردار سپدِ و ، فٲصلٕکۍ سٲر ی اختیار چِھ تٔسۍ حٲصل تہٕ سُہ چُھ حسا ب ہیٚنس منٛز سٮ۪ٹھاہ تیز۔"
  6,63,"۔ اے نبی صلی اللہ علیہ وسلم ،یِمن پٕرٛژِھو ، صحرا تہٕ سمندر کیٚن اَنہِ گٹن منٛز کُس چُھو تۅہیہِ خطر و نِشہِ بچا وان؟ کُس چُھ یَس توٚہۍ ﴿ مصیبت کہ وقتہٕ﴾ سٮ۪ٹھاہ وِلہٕ زٲر ی کٔرۍ کٔرۍ تہٕ ژوٗرِ ژوٗرِ چِھو دُعا منگان ؟ کَس چِھو وَنان زِ اگر ییٚمہِ بلا یہِ نِشہِ تٔمۍ أسۍ بچٲوۍ تیٚلہِ بَنو أسۍ ضرور شکر گزار؟"
  6,64,"۔ ؤنِو ، اللہ تعالیٰ چُھو تۅ ہیہِ اَمہِ نِشہِ تہٕ پرٛتھ تکلیف نِشہِ نجا ت دِوان ۔پتہٕ چِھو توٚہۍ با قی تٔمۍ سٕندۍ شر یک ٹھہراوان۔﴿یعنی یہِ حقیقت زِ اللہ تعالیٰ ہٕے چُھ تنہا قادر مطلق تہٕ سُے چُھ تمام اختیار اتن ہُند مٲلک ،تہٕ تُہندِ رٕژرُک تہٕ بُرٲیی ہُند مختارِ کُل چُھ سُے، تہٕ تٔمۍ سٕندِ نٕے اتھن منٛز چھےٚ تُہندِ قسمٕتچ لا کم، اَمِچ شہا دت چھےٚ تۅہیہِ پننِس نفسس اندر موجود ، ییٚلہِ کانٛہہ سخت وقت واتان چُھ تہٕ تمام ذرِ یعن تہٕ اَسبا بن ہٕنز برا نتھ چھےٚ مۅ کلان تہٕ تمہِ وقتہٕ چِھو توٚہۍ بے اختیار تٔسۍ کُن رجوع کران۔مگر یہِ ٹا کارٕ علامت آسنہٕ با وجو د تہِ چِھو  با قی تۅہیہِ خُدٲیی اندر بِلا دلیل تہٕ بلا حجت تہٕ ثبو تَو ورٲے تٔمۍ سٕندۍ شر یک بنٲوِمٕتۍ، پَلا ن چِھو تٔمۍ سٕندِس رزقس پٮ۪ٹھ تہٕ رزق دِنہٕ وٲلۍ چھوٗکھ با قی بناوان۔مدد چُھو تٔمۍ سٕندِ فضل و کر م سٍتۍ حٲصل سپدان تہٕ حٲمی تہٕ نٲصر چھوٗکھ با قی بناوان۔غلا م چِھو تٔمۍ سٕندۍ مگر بند گی چِھو کران با قین ہٕنز۔ مُشکل کُشٲیی چُھ کران سُہ،خرا ب حا لاتن منٛز چِھو وِلہٕ زٲر ی کران تس برونٛہہ کنہِ تہٕ ییٚلہِ سُہ وقت مۅ کلان چُھ پتہٕ چِھ تُہٕندۍ مشکل کُشا بنان با قی تہٕ پتہٕ چِھ کٹھ کۅ کر نذر و نیا ر تِمن یِوان کھالنہٕ۔﴾"
  6,65,"۔ؤنِو سُہ چُھ اتھ پٮ۪ٹھ قدرت تھاوان زِ ہیٚرِ پٮ۪ٹھہٕ کرِ تۅہیہِ پٮ۪ٹھ کانٛہہ عذا ب نٲزِل ، یا کرِ تُہٕندیو قد مَو بٔنۍ کِنۍ بر پا،یا وُچھنا ویو تۅہیہِ فر قن منٛز تقسیم کٔرِتھ أکِس دٔرِس دوٚیِمہِ درِکہِ طا قتُک مزٕہ۔وُچِھو ،أسۍ کِتھہٕ پٲٹھۍ چِھ گرِ گرِ مختلف طر یقو پننہِ نشٲنیہِ یِمن برونٛہہ کنہِ پیش کران، بنان چُھ یِم سمجھن حقیقت،"
  6,66,"۔تُہُند قو م چُھ تمِیُک انکار کران حالانکہ چھےٚ سۅ حقیقت یِمن ؤنِو زِ بہٕ چُھس نہٕ تۅہیہِ پٮ۪ٹھ رٲچھدر بناو نہٕ آمُت،﴿ یعنی میٲنۍ کٲم چَھنہٕ یہِ زِ یِکینژھاہ توٚہۍ وُچھان چِھو نہٕ سُہ ہاوَو بہٕ تۅہیہِ زبردستی تہٕ یِکینژھاہ توٚہۍ سمجھان چِھو نہٕ سُہ والہٕ بہٕ بزور تُہندٮ۪ن کاڈٮ۪ن منٛز ۔تہٕ یِتہِ چَھنہٕ میٲنۍ کٲم زِ اگر توٚہۍ وُچِھو نہٕ ,سمجھِو نہٕ تہٕ بہٕ کیا کرٕ تۅہیہِ پٮ۪ٹھ عذا ب نٲزِل ۔﴾"
  6,67,"۔ پرٛتھ کُنہِ خبرِ ہٕندِ ظہوٗر سپدنُک چُھ  اکھ وقت مقرر ، عنقر یب سپد یو تۅہیہِ پانے انجام معلو م۔"
  6,68,"۔تہٕ اے نبی صلی اللہ علیہ وسلم، ییٚلہِ توٚہۍ وُچِھو زِ لُکھ چِھ سانیٚن آیاتن پٮ۪ٹھ نکتہ چیٖنیہِ کران تیٚلہِ نِیرِ و تِمن نِشہِ ، یوٚت تام تِم یہِ کتھ با تھ ترٲوِتھ با قی کتھن کُن لگن تہٕ ہرگاہ تۅہیہِ شیطا ن کُنہِ ساعتہٕ مَشر پھَس منٛز تراوِ تیٚلہِ ییٚمہِ وِزِ تۅہیہِ امہِ غلطی ہُند احسا س سپدِ ، تمہِ پتہٕ مَہ بِہِو یِتھیٚن ظٲلِم لُکن نِشہِ ۔"
  6,69,"۔یِہندِ حسا بہٕ منٛزٕ چَھنہٕ کُنہِ چیزٕ چ ذمہٕ دٲری پرہیز گار لُکن پٮ۪ٹھ،البتہٕ نصیحت کرٕنۍ چھےٚ تُہُند فر ض شاید زِ تِم بچن غلطس پٮ۪ٹھ پکنہٕ نِشہِ ۔"
  6,70,"۔ترٲوِیوٗکھ تِم لُکھ یِمو پنُن دین کھیل تہٕ تما شہِ چھُ بنو و مُت،تہٕ یِمن دُنیا ہٕچ زند گی دو کھس منٛز مبتلا کٔرِتھ چھےٚ، آ، مگر یہِ قرآن بوزنٲوِتھ روٗزِ و نصیحت تہٕ نہیب دِوان زِ کانٛہہ شخص گوٚژھ نہٕ پننیٚن کرِ متیٚن کر توٗتن ہٕندِس وَبا لس منٛز گرفتار گژُھن تہٕ گرفتار تہِ اتھ حالس منٛز زِ خُدا یس نِشہِ بچا و ن وول  کانٛہہ حٲمی تہٕ مدد گار بیٚیہِ کانٛہہ سفٲرش در آسہِ نہٕ تٔمۍ سٕندِ خٲطرٕ،ہر گاہ سُہ پرٛتھ کانٛہہ ممکن چیز فِدیس منٛز دِتھ مۅ کلُن ییٚژھہِ ،تہٕ سُتہِ یِیہِ نہٕ تس نِشہِ قبول کر نہٕ، تِکیازِ یِتھۍ لُکھ یِن خۅد پننہِ کما یہِ ہٕندِس نتیجس منٛز رَٹنہٕ ، یِمن میلہِ پننِس انکارِ حق کِس مُعا وضس منٛز گرٛکہٕ دِوُن آب چیٚنہٕ خٲطرٕ تہٕ دگ تُلہٕ وُن عذا ب پیٚتر او نہٕ خٲطرٕ۔ ع"
  6,71,"۔اے نبی صلی اللہ علیہ وسلم، تِمن پرٛژھِو کیا اللہ تعالیٰ ترٲوِتھ لایِوٕ ہ أسۍ تِمن ناد یِم نَہ اَسہِ نفع ہیٚکن دِتھ نَہ نقصا ن؟ تہٕ ییٚلہِ زن خُدا ین اَسہِ سِیٔز وَتھ چھےٚ ہٲو مٕژ،تیٚلہِ کیا أسۍ پھیروٕہ پوٚت؟ کیا أسۍ کروٕہ پنُن حال تس شخصہٕ سُند ہیوٗ یُس شیطا نو صحرا وَس منٛز وَتہِ ڈو لمُت آسہِ تہٕ سُہ آسہِ حٲران تہٕ پر یشان پھیران،ییٚلہِ زن تٔمۍ سٕندۍ سٲتھی تس ناد آسن لایان زِیوٗرۍ وَلا ، ییٚکیا چھےٚ سِیٔزوَتھ ،ؤنِو ، حقیقتس منٛز چھےٚ صحیح رہنمٲیی صرف اللہ تعالیٰ سٕنز رہنمٲیی تہٕ تٔمۍ سٕندِ طر فہٕ چُھ یہِ حکم اَسہِ میوٗلمُت زِ کا ینا ت کِس مٲلِکس برونٛہہ کنہِ نوٚمرٲوِو پنُن کلہٕ،"
  6,72,"۔نماز کرِو قٲیِم تہٕ تٔمۍ سٕنزِ نا فر مٲنی نِشہِ بچِو،تٔسۍ کُن یِیِو توٚہۍجمع کٔرِتھ نِنہٕ۔"
  6,73,"۔سُے چُھ ییٚمۍ آسمان تہٕ زمین بر حق چھےٚ پٲدٕ کٔر مٕژ۔﴿قرآنس منٛز چھےٚ یہِ کتھ جایہِ جایہِ بیان کر نہٕ آمٕژ زِ خُدا ین چِھ زمین و آسمان بر حق پٲدٕ کٔرِ مٕتۍ یا چِھن حق سا ن پٲدٕ کٔرِ مٕتۍ۔اَمِیُک اکھ مطلب چُھ یہِ زِ زمینُک تہٕ آسما نن ہُند تخلیق چُھنہٕ محض گِند نہٕ رٔنگۍ سپُد مُت، یہِ چُھنہٕ کٲنٛسہِ شُر ۍ سُند تما شہِ زِ محض دِل رنز وَنہٕ خٲطرٕ روزِ سُہ اتھ گِندان تہٕ پتہٕ چھکیٚس پُھٹرٲوِتھ پتھر۔در اصل چھےٚ یہِ اکھ سٮ۪ٹھاہ سنجیدٕ ہ کٲم یۅسہٕ حکمت کِس بُنیا دس پٮ۪ٹھ چھےٚ کر نہٕ آمٕژ،اکھ عظیم مقصد چھُ اتھ منٛز کار فر ما، تہٕ اَمِیُک اکھ دَور مۅ کلنہٕ  پتہٕ چُھ یہِ ضرور ی زِ پٲدٕ کر ن وول ہیٚیہِ تمہِ پوٗرٕ کامہِ ہُند حسا ب یۅسہٕ اتھ دَورس منٛز کر نہٕ چھےٚ آمٕژ تہٕ اَمی دور کیٚن نتیجن پٮ۪ٹھ تھاوِ دوٚ یِمہِ دورٕچ بُنیا د۔دوٚیُم مطلب چُھس یہِ زِ خُدا ین چُھ یہِ کا ینا تُک نظا م حق کیٚن ٹھو س بُنیا د ن پٮ۪ٹھ قٲیِم کوٚر مُت۔ تٔمۍ سُند پرٛتھ کانٛہہ چیز چُھ عد ل،حکمت تہٕ را ستی ہٕند ٮ۪ن قانو ن پٮ۪ٹھ مبنی۔در حقیقت چَھنہٕ بٲطلس خٲطرٕ اَتھ نِظا مس منٛز موٗل دِنٕچ تہٕ بار آور سپد نٕچ کِہِنۍ گنجٲیش۔یہِ چھےٚ بیٚاکھ کتھ زِ اللہ تعالیٰ دِیہِ با طل پرستن مو قع زِ اگر تِم پننِس اَپزِ س، ظُلمس ،تہٕ ہجر س فر وغ یژھان چِھ دِیُن تیٚلہِ کٔرِن تِم کو شش مگر ٲخر کار چھکہِ زمین بٲطلُک پرٛتھ کانٛہہ بیٲلۍ پھوٚل نیٚبر تہٕ ٲخر ی فر د وُچھہِ حسا بس منٛز پرٛتھ با طل پرستس زِ یِمہٕ کوٗشِشہِ تٔمۍ اتھ خبیث کُلہِ کِس کا شتس تہٕ پھا نپھلاونس منٛز کرِ مژٕ چھےٚ تِمہٕ سار ے گٔیہِ ضایع ۔ترٚیُیم مطلب چُھس یہِ زِ خُدا ین چھےٚ یہِ کا ینا ت حق کِس بُنیا دس پٮ۪ٹھ پٲدٕ کٔر مٕژ پننِس ذٲتی حق کِس بِنا ہس پٮ۪ٹھٕے چُھ سُہ اتھ فر مان روٲیی کران۔ تٔمۍ سُند حکم چُھ ییٚتہِ امہِ موجو ب چلا ن تِکیازِ تٔسۍ چُھ پننِس بنٲوِ مٕتِس کاینا تس منٛز حکمرٲنی ہُند حق ۔بیٚیہِ چُھنہٕ کٲنٛسہِ ہُند حق زِ ییٚتہِ کیا چلہِ تٔمۍ سُند حُکم ﴾تہٕ ییٚمہِ دۅ ہ سُہ وَنہِ زِ حشر سپدِن برپا تمی دۅہ سپدِ سُہ ،تٔمۍ سُند ارشاد چُھ عینِ حق۔تہٕ ییٚمہِ دۅ ہ صوٗرس یِیہِ پھۅکھ دِنہٕ تمہِ دۅ ہ آسہِ با د شٲہی تٔمۍ سٕنزٕ ے۔سُہ چُھ غیب تہٕ شہا دت پرٛتھ چیزُک عا لِم بیٚیہِ چُھ دا نا تہٕ با خبر۔﴿غیب چُھ مُراد تہِ سورُے کینٛہہ یُس مخلو قا تن نِشہِ پوٗشیدہ چُھ۔شہا دت چُھ مُراد تہِ سورُے کینٛہہ یُس مخلو قا تن وِیٚو د تہٕ معلو م چُھ۔ ﴾"
  6,74,"۔ابرا ہیم ﴿علیہ السلامن﴾ ہُند وا قعہ کٔرِو یاد ییٚلہِ تٔمۍ پننِس مٲلِس آز رس وَنیا و کیا ژٕ چُھکھہٕ پۅ تٕلۍ بناوان خدا ے؟مےٚ چُھکھ ژٕ تہٕ چو ن قو م کُھلہٕ گمرٲہی منٛز اَتہِ یِوان ۔"
  6,75,"۔ابرا ہیم ﴿علیہ السلامس﴾ ٲسۍ یِتھے پٲٹھۍ أسۍ زمین تہِٕ آسمانن ہٕندِ سلطنتُک نظا م ہاوان تہٕ اَمہِ موجو ب ٲسِس ہاوان زِ سُہ بَنہِ یقین کر ن والیو منٛزٕ۔"
  6,76,"۔چنا نچہ ییٚلہِ تس پٮ۪ٹھ رات طٲری سپٕز ،تٔمۍ وُچھ اکھ تارُک، ووٚ نُن یہِ چُھ میو ن ربّ۔مگر ییٚلہِ سُہ لوٗس ،تٔمۍ ووٚن۔لوسن وٲلۍ چِھنہٕ مےٚ ٹٲٹھۍ،پتہٕ ییٚلہِ زوٗن وُچھِن پرٛزلان تہٕ ووٚنُن یہِ چھُ میون ربّ،"
  6,77,"۔مگر ییٚلہِ سۅ تہِ لوٗس تہٕ ووٚ نُن اگر میٲنۍ ربّن مےٚ رہنمٲیی آسہِ ہے نہٕ کٔرمٕژ تیٚلہِ آسٕہا بٕتہِ گُمراہ لُکن منٛز شٲمل گوٚ مُت"
  6,78,"۔پتہٕ ییٚلہِ آفتا ب وُچُھن تابان تہٕ ووٚ نُن یہِ چُھ میو ن ربّ ،یہِ چُھ سارِوٕے کھۅتہٕ بوٚڈ۔مگر ییٚلہِ سُتہِ لوٗس تہٕ ابراہیم علیہ السلام چِھ کرٛیکھ دِوان اے برادرانِ قو م، بہٕ چُھس تِمن سارِنٕے بے زار،یِم توٚہۍ اللہ تعالیٰ سٕندۍ شر یک چُھو کھ ٹھٔہراوان۔﴿یَتھ جایہِ چھےٚ حضرت ابرا ہیم  علیہ السلامن  ہٕندِ ابتدٲیی تفکُّرٕچ  کیفیت بیان کر نہٕ آمٕژ یُس نبوّت کِس منصبس پٮ۪ٹھ سرفراز سپد نہٕ برونٛہہ تِہندِ خٲطرٕ حقیقتس تام وا تنُک ذر یعہ بنیاد۔اتھ منٛز چُھ وَننہٕ آمُت زِ اکھ صحیح دما غ تہٕ صحیح نظر تھاون وول انسان ییٚمۍ سراسر شر ک کِس ماحو لس  منٛز أچھ آسہِ  مژراوِ مژٕ،کِتھہٕ پٲٹھۍ سپُد کاینات کیٚن آثارن ہُند مشٲہدٕ ہ کٔرِ تھ تہٕ تِمن پٮ۪ٹھ صحیح غورو فکر کٔرِتھ حقٕچ کتھ معلو م کر نس منٛز کامیا ب﴾"
  6,79,"۔مےٚ کوٚر یکسُو سپدِتھ پنُن رۅخ تس ہستی کُن ییٚمۍ زمین تہٕ آسما ن  چِھ پٲدٕ کٔرِ مٕتۍ تہٕ بہٕ چُھس نہٕ ہر گز شر ک کر ن والیو منٛزٕ۔"
  6,80,"۔تٔمۍ سٕندۍ قو من لٲج تَس سٍتۍ ژُوٕ نۍ، پتہٕ ووٚن تٔمۍ پننِس قو مس  کیا توٚہۍ لُکھ چِھوٕہ اللہ تعالیٰ سٕندِس معا ملس منٛز مےٚ سٍتۍ ژُوان؟حلانکہ تٔمۍ چھےٚ مےٚ سیٚز وَتھ ہٲومٕژ تہٕ بہٕ چھُس نہٕ  تُہٕندٮ۪ن ٹھٔہراو نہٕ آمتیٚن شر یکن کھۅژان،آ ہرگاہ میو ن ربّ کینٛہہ ییٚژِھہ تیٚلہِ ہیٚکہِ سُہ ضرور سپدِتھ،میٲنِس ربّ سُند علم چُھ پرٛتھ چیز س پٮ۪ٹھ چھٲوِتھ،تیٚلہِ کیا توٚہۍ یِیِو نا ہوشس منٛز؟ ﴿دراصل چُھ لفظ تَذَکَّر،استعمال سپُد مُت ییٚمیُک صحیح مفہو م یہِ چُھ زِ اکھ شخص یُس غفلتس تہٕ مشر پھَس منٛز آسہِ ہیٚنہٕ آمُت تہٕ وۅٹھ کھیٚتھ پیٚیہِ تَس سُہ چیز یاد یُس تس مٔشِتھ اوس گوٚ مُت،اَمی موجو ب چُھ اَسہِ اَفَلا تَتَذَکّرُون، ہَس یہِ تر جمہٕ کوٚر مُت﴾"
  6,81,"۔تہٕ بہٕ کِتھہٕ پٲٹھۍ کھۅژٕ ٲخٕر تُہٕندٮ۪ن ٹھٔہراو نہٕ آمتیٚن شر یکن، ییٚلہِ زن توٚہۍ خُدا یس سٍتۍ تِم چیز خُدٲیی منٛز شر یک بناو نس چِھو نہٕ کھۅژان یِہِندِ خٲطرٕ تٔمۍ تۅہیہِ پٮ۪ٹھ کانٛہہ سَند چَھنہٕ نٲزِل کٔرمٕژ؟اَسہِ دۅشوٕ یَو فر یقو منٛزٕ کُس چُھ زیادٕہ اَمنُک تہٕ اطمنا نُک حقدار؟ؤنِو اگر تۅہیہِ کینٛہہ علم چُھو۔"
  6,82,"۔در حقیقت چُھ اَمن تِمنٕے خٲطرٕ تہٕ سِیٚزِ وَتہِ پٮ۪ٹھ چِھ تِمے یِمَو ایمان اوٚ ن تہٕ یِمَو پنُن ایمان ظلمہٕ سٍتۍ آلو دٕہ کوٚر نہٕ۔ع"
  6,83,"۔یہِ ٲس سٲنۍ سۅ حُجّت یۅسہٕ اَسہِ ابرا ہیم ﴿علیہ السلامس ﴾ تٔمۍ سٕندِس قو مس مقا بلہٕ عطا کٔر ،أسۍ یَس یَژھان چِھ تَس چِھ بُلند مر تبہٕ عطا کران حق چُھ یہِ زِ تُہُند ربّ چُھ سٮ۪ٹھاہ حکمت وول تہٕ زانن وول ۔"
  6,84,"۔پتہٕ دِیُت اَسہِ ابرا ہیم ﴿علیہ السلا مس﴾ اسحا ق ﴿علیہ السلام ﴾تہٕ یعقو ب ﴿علیہ السلامس﴾ہِیوٗ اولاد تہٕ پرٛتھ أکِس ہٲو سِیٔز وَتھ ﴿سۅ ے سِیٔز وَتھ یۅسہٕ ﴾ ییٚمہِ برونٛہہ نو ح علیہ السلامس ہٲومٕژ ٲس،تہٕ تٔمۍ سٕندی نسلہٕ منٛزٕ ﴿بخُش ہدا یت﴾ داوٗد علیہ السلام، سلیمان علیہ السلام،ایوب علیہ السلام، یوسف علیہ السلام،مو سیٰ علیہ السلام،تہٕ ہارو ن ﴿علیہ السلامس﴾ یِتھہٕ پٲٹھۍ چِھ أسۍ نیکو کار ن تِہِنزِ نیکی ہُند بد لہٕ دِوان ۔"
  6,85,"۔﴿تٔمۍ سٕندِ وٕے اولادَو منٛزٕ کوٚر ہدا یت ﴾ زکر یا علیہ السلام تہٕ یحییٰ علیہ السلام تہٕ الیا س ﴿علیہ السلامس﴾ پرٛتھ کانٛہہ اوس تِمَو منٛزٕ صا لح۔"
  6,86,"۔﴿تٔمۍ سٕندی خاندان منٛزٕ ﴾ اسما عیل علیہ السلام، الیسع علیہ السلام، تہٕ یو نس علیہ السلام  تہٕ لو ط ﴿علیہ السلامس ہٲووَتھ﴾ یِمو منٛزٕ کٔر اَسہِ پرٛتھ أکِس دُنیا والیٚن پٮ۪ٹھ فضیلت عطا۔"
  6,87,"۔بیٚیہِ نوٲزۍ اَسہِ تِہِندۍ آبا واجداد تہٕ تِہِندۍ اولاد تہٕ تِہِند یو با یَو منٛزٕ واریاہ، تِم ژٲر ۍ پننہِ خد مت خٲطرٕ تہٕ تِمن کٔر سیٚزِ وَتہِ کُن رہنمٲیی۔"
  6,88,"۔یہِ چُھ اللہ تعالیٰ سُند ہدا یت ییٚمہِ سٍتۍ سُہ یَس یژھان چُھ تس چھُ رہنمٲیی کران البتہ اگر یِمَو لُکو شر ک آسہِ ہے کوٚر مُت تیٚلہِ گژِھہِ ہے یُہُند سورُے کوٚر مُت کرٛوومُت ضا یع۔"
  6,89,"۔یِم ٲسۍ تِم لُکھ یِمن اَسہِ کتا ب تہٕ حکم تہٕ نبوّت ٲس عطا کٔرمٕژ۔﴿یَتھ جایہِ چھےٚ انبیا علیھم السلامن ترٛے چیز عطا کر نٕچ ذکر آمٕژ۔اکھ کتا ب یعنی اللہ تعالیٰ سُند ہدایت نامہٕ۔بیاکھ حکم یعنی ہدا یت نا مُک صحیح فہم تہٕ اَمِکۍ اصو ل، زند گی ہٕندٮ۪ن معا ملا تن پٮ۪ٹھ موٲفق کر نٕچ صلٲحیت ،تہٕ زند گی ہٕندٮ۪ن مسٲیلن منٛز فٲصلہٕ کُن راے قٲیم کرنٕچ خداداد قٲبلیت ۔ترٛییُم نبوّت ،یعنی یہِ منصب زِ تِم کرن امہِ ہدا یت نامہٕ مطا بق اللہ تعالیٰ سٕندٮ۪ن خلقن رہنمٲیی﴾ وۅ نۍ اگر یِم لُکھ اَتھ ماننہٕ نِشہِ انکار چِھ کران ﴿کانٛہہ پرواے چُھنہٕ﴾ اَسہِ چھےٚ بیٚیہِ کینژھن لُکن یہِ نعمت حوالہٕ کٔر مٕژ یِم اتھ مُنکر چِھنہٕ۔"
  6,90,"۔اے نبی صلی اللہ علیہ وسلم، تِمے لُکھ ٲسۍ اللہ تعالیٰ سٕندِ طر فہٕ ہدا یت یا فتہٕ ،تِہٕنزِی وَتہِ پٮ۪ٹھ پٔکِو توٚہۍ، تہٕ ؤنِو زِ بہٕ چُھس نہٕ ﴿اتھ تبلیغ تہٕ ہدا یت چہِ ﴾ کامہِ پٮ۪ٹھ تۅہیہِ نِشہِ کُنہِ اُجر تُک طٲلب کینٛہہ۔ یہِ چھےٚ اکھ عام نصیحت تمام دُنیا والیٚن خٲطرٕ ۔ ع"
  6,91,"۔یِمو لُکو کٔر نہٕ خُدا یس قدر ، یِتھہٕ پٲٹھۍ تس قدٕر کر نُک حق اوس،﴿یعنی خُدا یس متعلق کوٚرُکھ غلط اندازٕہ﴾ ییٚلہِ ووٚنُکھ خُدا ین چُھنہٕ کٲنٛسہِ بشر س پٮ۪ٹھ کِہِنۍ نٲزِل کوٚر مُت یِمن پٕرٛژِھو سۅ کتا ب  یۅسہٕ مو سیٰ ﴿علیہ السلامن﴾ أنۍ مٕژ ٲس، یۅسہٕ تمام انسانن خٲطرٕ روشنی تہٕ ہدا یت ٲس،یۅسہٕ توٚہۍ چَھلہِ چَھلہِ چُھو ن کران ، کمٕے چِھو ہاوان تہٕ واریاہ کینٛہہ چِھو چُھپا وان،تہٕ ییٚمہِ ذریعہ تۅہیہِ سُہ علم اوسُو نہٕ آمُت یُس نہٕ تۅہیہِ حٲصل اوسُو تہٕ نہ اوس تُہندِس مٲلِس بُڈِ ببس، ٲخر تمِیُک نٲزِل کر ن وول کُس اوس؟﴿چو نکہ یہِ جواب چُھ یہو دٮ۪ن دِنہٕ یِوان امہِ موجو ب چُھ دلیلہِ رٔنگۍ حضر ت مو سیٰ علیہ السلامس پٮ۪ٹھ توراتُک نزول پیش کر نہٕ آمُت ،تِکیازِ یِم ٲسۍ خۅد اَِمِکۍقٲیل۔ ظٲہر چُھ زِ یُہُند یہِ تسلیم کرُن زِحضرت مو سیٰ علیہ  السلامس پٮ۪ٹھ ٲس توراتہ نازل سپٕز مٕژ ، چُھ پٲنۍ پانے یِہِندِ اَمہِ قَو لُک تردید کران زِ خُدا ین چُھنہٕ کٲنٛسہِ بشر س پٮ۪ٹھ کِہِنۍ نٲزِل کوٚر مُت ،بیٚیہِ چھےٚ کم از کم امہِ نِشہِ یہِ کتھ ثٲبت سپدان زِ بشر س پٮ۪ٹھ ہیٚکہِ اللہ تعالیٰ سُند کلام نٲزِل سپدِتھ تہٕ سپُد مُت تہِ چُھ﴾ بس یُتُے ؤنِو زِ اللہ، پتہٕ ترٲوِیوٗکھ یِم پننیٚن دلیل بٲزین سٍتۍ گند نہٕ خٲطرٕ۔"
  6,92,"۔﴿تمی کتا بہِ ہٕندۍ پٲٹھۍ﴾ چھےٚ یہِ اکھ کتاب یۅسہٕ اَسہِ چھےٚ نٲزِل کٔر مٕژ۔ سٮ۪ٹھاہ خیر و بر کت واجِنۍ چھےٚ ،تَمہِ چیزُک چھےٚ تصد یق کران یُس  اَمہِ برونٛہہ اوس آمُت تہٕ امہِ موجوب چھےٚ نٲزل کرنہٕ آمٕژ زِ اَمہِ کہ ذر یعہ کٔرِیوٗکھ توٚہۍ بٔستِیَن ہٕندِ امہِ مر کزٕ کۍ ﴿یعنی مکّہ﴾ تہٕ اَتھ أندۍ پٔکۍ روزن وٲلۍ خبردار، یِم لُکھ ٲخرتس مانان چِھ تِم چِھ یتھ کتا بہِ پٮ۪ٹھ ایمان انان تہٕ تِہُند حال چُھ یہِ زِ پننیٚن نمازن ہٕنز چِھ پابند ی کران۔"
  6,93,"۔تہٕ تس شخصہٕ سٕندِ کھۅتہٕ بوٚڈ ظٲلِم کُس آسہِ یُس خُدا یس اَپُز  بہتا ن لاگہِ ،یا وَنہِ زِ مےٚ پٮ۪ٹھ چھےٚ وحی آمٕژ ییٚلہِ زن تس پٮ۪ٹھ کِہِنۍ وَحی آسہِ نہٕ نٲزِل کر نہٕ آمٕژ،یا یُس اللہ تعالیٰ سٕندٮ۪ن نٲزِل کر نہٕ آمتیٚن چیزن ہٕندِس مقا بلس منٛز وَنہِ زِ بہٕ ہاوٕہ یُتُھے کانٛہہ چیز نٲزِل کٔرِتھ؟کاش توٚہۍ وُچھہوٗکھ ظٲلِم تتھ حالتس منٛز ییٚمہِ  ساعتہٕ تِم مو ت چہِ سختی منٛز غۅطہٕ آسٕہَن کھیٚوان تہٕ فرشتہٕ آسٕہن اتھہٕ پِلنٲوۍ پلنٲوۍ ونان زِ  ؤلِو، کٔرِو پنُن زُو،اَز یِیَو تۅہیہِ تِمن کتھن ہٕندِس پاداشس منٛز ذِلتُک عذا ب دِنہٕ یِمہٕ توٚہۍ خُدا یس تُہمت لگٲوِتھ نا حق ٲسِو بکا ن،تہٕ تٔمۍ سٕندٮ۪ن آیا تن ہٕندِس مقا بلس منٛز ٲسِو سر کشی ہاوان۔"
  6,94,"۔﴿تہٕ اللہ تعالیٰ فر ماویٚکھ﴾ رٔٹۍ تو ، وۅ نۍ سپدِ و توٚہۍ تِتھے پٲٹھۍ تنِ تنہا اَسہِ برونٛہہ کنہِ حٲضر یِتھہٕ پٲٹھۍ اَسہِ توٚہۍ گۅڈنِچہِ پھِرِ تنہا ٲسِو پٲدٕ کٔرِمٕتۍ،یِکینژھاہ دُنیا ہس منٛز اسہِ تۅہیہِ دِیتمُت اوسُو سُہ سورُے کینٛہہ چِھو پتھ کُن ترٲوِتھ آمٕتۍ،بیٚیہِ چِھنہٕ وۅ نۍ أسۍ تِمن تُہندٮ۪ن سفٲرش دَرن کُن تہِ وُچھان یِمن متعلق توٚہۍ سمجھان ٲسِو زِ تۅہیہِ بکار یِنس منٛز چُھ تِہُنٛد تہِ کینٛہہ حصہٕ، تۅہیہِ یِم پانہٕ وٲنۍ رٲبطہٕ ٲسۍ تِم ژھیٚنۍ سٲر ی تہٕ تِم سٲر ی رٲوِ و تۅہیہِ یُہُند تۅہیہِ بوش اوسُو ۔ع"
  6,95,"۔دا نس تہٕ آنچہِ پھاٹوَن وول چُھ اللہ تعالیٰ۔ ﴿یعنی زمین کیو تَہَو منٛز بیٲلۍ پھوٚ ل پھا ٹِو تھ تمہِ منٛز کُلِیُک کوٚٹ کڑ ن وول ﴾ سُے چُھ زِ ندس کڑا ن مۅردس نِشہِ تہٕ سُے چُھ مۅردس زِندس نِشہِ کڑ ن وول ۔ ﴿زندٕ ہ کڑُن مۅردس نِشہِ ، اَمِیُک  مطلب چُھ بے جان ماہ نِشہِ زند ہ مخلو ق پٲدٕ کرٕنۍ ، تہٕ زند ہ نِشہِ مۅردٕ کڑ نُک مطلب چُھ، جاندار چیز و منٛزٕ بے جان مادٕہ خٲر ج کرٕنۍ ﴾ یِمہٕ سار ے کامہِ کر ن وول چُھ اللہ تعالیٰ ،پتہٕ کور کُن چِھو توٚہۍ ڈلان پکان؟"
  6,96,"۔سُے چُھ رٲژ ہُند پردٕہ ژٔٹِتھ صُبح کڑان، تٔمی چھےٚ رات سکونُک وقت بنٲومٕژ،تٔمی چُھ زوٗن تہٕ آفتاب کھسنُک تہٕ لو سنُک حسا ب مقرر کوٚر مُت، یِم سٲر ی چِھ تس زبردست قدرت تہٕ علم تھاون وٲلۍ سٕندۍ ٹھۂراونہٕ آمٕتۍ اندازٕہ،"
  6,97,"۔تہٕ سُے چُھ ییٚمۍ تُہندِ خٲطرٕ تارک بنٲوۍ صحرا تہٕ سمندر ن ہٕنز ن انہِ گٹن منٛز وتھ معلو م کر نٕکۍ ذر یعہ، وُچِھو اسہِ چھےٚ نشٲنیہِ کھوٗلتھ بیان کرِ مژٕ تِمن لُکن خٲطرٕ یِمن علم چُھ۔ ﴿یعنی امہِ حقیقت چہِ نشٲنیہِ زِ اللہ تعالیٰ چُھ صرف اکھ، کانٛہہ بیاکھ چُھنہٕ خُدا یی ہٕندۍ صفات تھاوان،نہ چُھ خُدٲیی ہٕندٮ۪ن اختیار ن منٛز حصہٕ دار، تہٕ نہ چُھ خُدٲیی ہٕندٮ۪ن حقو قن منٛز کُنہِ حقُک حقدار۔﴾"
  6,98,"۔تہٕ سُے چُھ ییٚمۍ توٚہۍ اکہِ جانہٕ نِشہِ پٲدٕ کٔرۍ نو،پتہٕ چُھ پرٛتھ کٲنٛسہِ ہٕندِ خٲطرٕ اکھ جا ے قرار بیٚیہِ تٔمۍ سٕندِ خٲطرٕ اکھ حوالہٕ کرٕنٕچ جاے، یِمہٕ نشٲنیہِ چھےٚ اسہِ وا ضح کرِ مژٕ تِمن لُکن خٲطرٕ یِمن سۅ دبود چھےٚ ۔"
  6,99,"۔تہٕ سُے چُھ ییٚمۍ آسما نہٕ وول آب،پتہٕ وۅ پدٲوِن تمہِ سٍتۍ پرٛتھ قسمٕکۍ کُلۍ کٔٹۍ،پتہٕ کٔرِن امہِ سٍتۍ سبز سبز ڈوٗرۍ تہٕ کُلۍ پٲدٕ،پتہٕ کٔڑِن یِمو منٛزٕ تَہس پٮ۪ٹھ تہہ تھاون وٲلۍ دانہٕ،تہٕ کھٔزٕر پھُلیہ سٍتۍ کٔرِن میٚوَن  ہٕندۍ گُر نٕے گُر ن پٲدٕ یِم بار سٍتۍ نر مان چِھ بیٚیہِ لگٲوِن دَچھہِ ہٕنٛد ۍ، زیتو ن تہٕ دٲنن ہٕندۍ  با غ۔یِہندۍ میوٕہ  اکھ أکِس سٍتۍ ہِشر تہِ تھاوان چِھ تہٕ بیٚیہِ چھےٚ پرٛتھ اکہِ چہِ خصوصیتہٕ بیٚو ن بیٚو ن تہِ ، یِم کُلۍ ییٚلہِ پھۅ لان چِھ ، یِہِندِس میوٕ ہ نیر نس تہٕ پتہٕ یِہندِ س پینہٕ کِس کیفیتس پٮ۪ٹھ ترٲوِ تو ہَنا غورٕ سان نظر، یِمن چیز ن منٛز چھےٚ نِشٲنیہِ تِمن لُکن خٲطرٕ یِم ایمان چِھ انان۔"
  6,100,"۔اتھ پٮ۪ٹھ تہِ ٹھہرٲوۍ لُکو جِنّ اللہ تعالیٰ سٕندۍ شر یک ، ﴿ یعنی پننہِ وہمہٕ گُما نہٕ سٍتۍ کوٚرُکھ مقرر  کاینا ت کِس نظا مَس منٛز تہٕ انسان سُند قسمت بنا و نس تہٕ بگا ڑنس منٛز چھےٚ خُدا یس ورٲے باقی پوشیدٕہ ۂستیہ تہِ شر یک ۔ کانٛہہ چُھ روٗدُک دیو تا تہٕ کانٛہہ چُھ کُلۍ کٔٹۍ وۅ پدا و نُک ،کانٛہہ چھےٚ دَو لتٕچ دیو ی تہٕ کانٛہہ چھےٚ بیمارِہٕنز ، امہِ  قسمٕکۍ فضو ل اعتقاد چِھ دُنیا کیٚن تمام مُشر ک قو من منٛز، اَرواحَن، شیطا نن، را کھشَسن ، دیو یَن متعلق لبنہٕ یِوان ۔﴾حالانکہ سُہ چھُ تِہُنٛد خٲلق تہٕ زاننہٕ ماننہٕ ورٲے کٔرِکھ تٔمۍ سٕندِ خٲطرنیٚچِوۍ تہٕ کورِ تصنیف،حالانکہ سُہ چُھ پاک تہٕ بالا تر ، تِمو کتھو نِشہِ یِمہٕ یِم لُکھ ونان چِھ ۔ع"
  6,101,"۔سُہ چُھ آسمانن ہُند تہٕ زمینُک ایجاد کر ن وول ، تس کِتھہٕ پٲٹھۍ ہیٚکہِ کانٛہہ نیچُو ٲسِتھ ییٚلہِ زن تس کانٛہہ زند گی ہُند شر یکٕے چُھنہٕ،تٔمۍ چُھ ہرکانٛہہ چیز پٲدٕ کوٚر مُت تہٕ تس چُھ ہر کُنہِ چیزُک علم۔"
  6,102,"۔یہِ چُھ اللہ تعالیٰ، تُہُند ربّ، کانٛہہ خُدا ے چُھنہٕ تس ورٲے ،پرٛتھ چیزُک خٲلق ،لہٰذا کٔرِ و  توٚہۍ تٔمۍ سٕنز ے بند گی ، تہٕ سُہ چُھ پرٛتھ چیزُک کفیل،"
  6,103,"۔نظرٕ ہیٚکن نہٕ تس لٔبِتھ تہٕ سُہ چُھ نظرٕ لَبان، سُہ چُھ سٮ۪ٹھاہ بٲریک بین ﴿راز زانَن وول﴾ تہٕ با خبر۔"
  6,104,"۔وُچِھو تۅہیہِ نِشہِ چھےٚ تُہٕندِس ربّ سٕندِ طر فہٕ بصیرت چہِ روشنیہِ آمژٕ، وۅ نۍ یُس بینٲیی کٲم ہیٚیہِ ، پا نسٕے خٲطرٕ کرِ رُت تہٕ یُس اوٚ ن بنہِ ، پانہٕ تُلہِ نقصا ن، بہٕ چُھس نہٕ تۅہیہِ پٮ۪ٹھ کانٛہہ  پا سبان۔﴿یہِ حصہٕ اگر چہِ اللہ تعالیٰ سُند کلام چُھ نبی صلی اللہ علیہ وسلمن ہٕندِ طر فہٕ ادا سپدان، یِتھہٕ پٲٹھی سورۂ فا تحہ چُھ اللہ تعالیٰ سُند کلام مگر چُھ بند ن ہٕنزِ زیوِ ادا سپدان۔ بہٕ چُھس نہٕ تۅہیہِ پٮ۪ٹھ پاسبانیعنی میٲنۍ کٲم چھےٚ بس یِژٕے زِ یہِ روشنی کرٕ تۅہیہِ برونٛہہ کنہِ پیش۔امہِ پتہٕ چھےٚ أچھ مٕژرٲوِتھ وُچُھن یا نَہ وُچُھن تُہٕنز کٲم۔مےٚ چَھنہٕ یہِ کٲم سُپر د کر نہٕ آمٕژ زِ یِمو خۅد چھےٚ پانہٕ أچھ بند کرِ مژٕ، تِہنزٕ أچھ مٕژراوٕ زبردستی تہٕ یِکینژھاہ تِم چِھنہٕ وُچھان سُہ ہاوکھ بٕے ۔﴾"
  6,105,"۔یِتھہٕ پٲٹھۍ چِھ أسۍ بار بار پنٕنۍ آیات مختلف طر یقو بیان کران تہٕ امہِ موجوٗب چِھ کران زِ یِم لُکھ وَنن  ژٕہ چُھکھ کس تام نِشہِ پٔرِتھ آمُت،تہٕ یِم لُکھ علم چِھ تھاوان تِمن پٮ۪ٹھ کر و أسۍ حقیقت روشن۔"
  6,106,"۔اے نبی صلی اللہ علیہ وسلم،ییٚمہِ وحی ہٕنز پیر وی گٔژِھو کران یۅسہٕ تۅہیہِ پٮ۪ٹھ  تُہندِس ربّ سٕندِ طر فہٕ نٲزِل چھےٚ سپٕز مٕژ، تِکیازِ تس أکِس ربّس ورٲے چُھنہٕ کانٛہہ خُدا ے تہٕ یِمن مُشر کن پتہٕ مَہ لٔگِو۔"
  6,107,"۔اگر اللہ تعالیٰ سٕنز مشیت آسہِ ہے تیٚلہِ ﴿ہیٚکہِ ہے سُہ تِیُتھ بند وبست کٔرِ تھ زِ ﴾ یِم لُکھ کر ہن نہٕ شر ک،  توٚہۍ چِھو نہٕ اسہِ یِمن پٮ۪ٹھ پاسبان مُقرر کٔرِمٕتۍ تہٕ نہ چِھو توٚہۍ یِمن پٮ۪ٹھ حوا لہٕ دار ﴿رٲچھ در﴾۔"
  6,108,"۔﴿اے مسلمانو﴾ یِمن یِم لُکھ خُدا یس ورٲے آلو چِھ دِوان تِمن مَہ ؤنِو بدرد،یِنہٕ پتہٕ یِم شِر ک نِشہِ برونٛہہ نِیرِتھ جہالت کِس بنیادس پٮ۪ٹھ خُدا یس لاگن لیٚکہٕ ژارنہِ ،اَسہِ چُھ یِتھے پٲٹھۍ پرٛتھ دٔرِس خٲطرٕ تٔمۍ سٕنز عمل خۅ شنما بنٲو مٕژ، پتہٕ چُھ تِمن پننِس ربّس کُن پوٚت پھیٖرِتھ یُن،تمہِ ساعتہٕ وَنہِ سُہ تِمن زِ تِم کیا چِھ روٗدِ مٕتۍ کران۔"
  6,109,"۔یِم لُکھ چِھ اللہ تعالیٰ سٕنٛدۍ بٔڑۍ بٔڑۍ قسم ہٲوۍ ہٲوۍ وَنان زِ اگر کانٛہہ نشٲنی ﴿یعنی معجزہ ﴾ اسہِ برونٛہہ کُن یِیہِ تیٚلہِ اَنو أسۍ تتھ پٮ۪ٹھ ایمان۔اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو زِ  نشٲنیہِ چھےٚ اللہ تعالیٰ سٕندِس اختیارس منٛز۔  تہٕ تۅہیہِ کِتھہٕ پٲٹھۍ یِیَو فِکرِ تار نہٕ زِ اگر نشٲنیہِ یِن تہِ، تیٚلہِ تہِ چِھنہٕ یِم ایمان انن وٲلۍ۔﴿یہِ خطا ب چُھ مسلمانن یِم بے تا ب سپدِ تھ تمنا ٲسۍ کران زِ تژھ کانٛہہ نشٲنی گٔژھ ظٲہر سپدٕ نۍ ییٚمہِ سٍتۍ تِہندِ ۍ گُمرٲہ بٲے سیٚزِ وَتہِ پٮ۪ٹھ یِہَن ﴾"
  6,110,"۔أسۍ چِھ تِتھے پٲٹھۍ یِہِندۍ دِل تہٕ نظرٕ پھِران یِتھہٕ پٲٹھۍ یِمو گۅڈنِچہِ لٹہِ یتھ﴿کتا بہِ ﴾ پٮ۪ٹھ ایمان اوس نہٕ اوٚ نمُت۔ أسۍ چِھکھ یِم یِہِنز ِ سر کشی منٛزٕ ے وَتہِ ڈالنہٕ موجو ب یلہٕ تراوان۔ع"
  6,111,"۔ہرگاہ أسۍ فر شتہٕ تہِ یِمن پٮ۪ٹھ نٲزِل کر ہو کھ تہٕ مۅردٕہ کر ہن یِمن سٍتۍ کتھہٕ،بیٚیہِ کر ہَو تمام دُنیا ہٕکۍ چیز یِہِنز ن أچھن برونٛٹھہٕ کنہِ جمع، تمہِ پتہٕ تہِ ٲسۍ نہٕ یِم ایمان اَنن وٲلۍ ، اِلّایہِ زِ مشیتِ الہٰی  آسہِ یی ﴿زِ یِم اَنن ایمان ﴾ مگر اکثر لُکھ چِھ نا دٲنی ہٕنزٕ کتھہٕ کران۔"
  6,112,"تہٕ اسہِ چِھ یِتھے پٲٹھۍ ہمیشہ ، شیطان جِنّ پرٛتھ نبی سٕندۍ دشمن بنٲوِمٕتۍ یِم اکھ أکِس پٮ۪ٹھ خۅش آیند ہ کتھہٕ دو کھہٕ تہٕ فر یب رٔنگۍ القا  ٔ چھِ روٗدِمٕتۍ کران ﴿یعنی دِلس منٛز چھِ وَسوسہٕ روٗدِمٕتۍ تراوان﴾اگرتُہندِس ربّٕ سٕنز مشیت یہِ آسہِ ہے زِ تِم گٔژھۍ نہٕ یہِ کرٕنۍ تیٚلہِ کر ہن نہٕ تِم زٕ ہٕنۍ ، لہٰذا ترٲوِ یوٗکھ توٚہۍ تِم تِہِندِس حا لس پٮ۪ٹھ زِ روٗزِ ن پننہِ اِفترا پردٲزی ﴿بہتا ن تُھرنس ﴾ منٛز آوٕ ر ی ۔"
  6,113,"﴿ یہِ سورُے چِھ أسۍ یِمن امہِ موجوٗب کر نہٕ دِوان زِ ﴾یِم لُکھ ٲخرتس پٮ۪ٹھ ایمان چِھنہٕ تھاوان تِہندِۍ دل سپدِ ن اتھ ﴿خۅشنما دۅ کھس﴾ کُن مٲیل تہٕ تِم سپدِن امہِ نِشہِ رٲضۍ تہٕ تِمن بُرا ین ہُند کٔرِ ن اِکتسا ب﴿ اَتُر﴾ یُہُند اِکتسا ب تِم کرُن چِھ یژھان۔﴿آیت 110 ،پٮ۪ٹھہٕ آیت ، 113،ہس تام یۅسہٕ کتھ فر ماو نہٕ چھےٚ آمٕژسۅ چھےٚ یہِ زِ انسان سٕندِس بارس منٛز چُھنہٕ اللہ تعالیٰ سُند قا نو ن یہِ زِ تس یِیہِ مشیّتس تحت تمہِ طر یقہٕ ہدا یت بخشنہٕ یِتھہٕ پٲٹھۍ کُلِس چُھ میوٕ ہ نیران یا خۅد بذا ت چُھ انسا نس کلس مَس یِوان ،بلکہ چُھ تٔمۍ انسان دُنیا ہس منٛز آزمٲیشہِ خٲطرٕ پٲدٕ کوٚر مُت تہٕ آزمٲیشہِ ہٕندِ غر ضہٕ چھےٚ یہِ کتھ خۅد تٔمۍ سٕندِس اختیارس پٮ۪ٹھ ترا و نہٕ آمٕژ زِ سُہ چھا راہِ راستس کُن گژُھن یژھان کِنہٕ  گُمرٲہی کُن۔ اگرسُہ پانے گُمراہ ییژِھہ گژُھن تیٚلہِ چُھنہٕ اللہ تعالیٰ پننہِ مشیّت سٍتۍ جبراً تس ہدا یت دِوان ۔﴾"
  6,114,"۔پتہٕ ییٚلہِ حال چُھ یہِ ، تیٚلہِ کیا بہٕ ژھا ر نہٕ خُدا یس ورٲے بیٚیہِ کانٛہہ فٲصلہ کر ن وول ، حالانکہ تٔمۍ چھےٚ پوٗرٕ تفصیل سان تۅہیہِ کُن کتا ب نٲزِل کٔرمٕژ۔﴿یتھ جایہِ چِھ متکلم نبی صلی اللہ علیہ وسلم تہٕ خطاب چُھ مُسلمان کُن ﴾ تہٕ یِمن لُکن اسہِ ﴿تۅہیہِ برونٛہہ ﴾ کتا ب ٲس دِژمٕژ تِم چِھ زانان زِ یہِ کتا ب چھےٚ تُہندِس ربّ سٕندِ طر فہٕ حق سان نٲزِل سپٕز مٕژ لہٰذا مَہ گٔژِھو توٚہۍ شک کر ن والیٚن منٛز شٲمل۔"
  6,115,"۔تُہندِس ربّ سٕنز کتھ چھےٚ پزرٕ سان تہٕ انصا ف کہ اعتبارٕ سان کٲمل، کانٛہہ چُھنہٕ اَمِکۍ فر مان تبد یل کر ن وول تہٕ سُہ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  6,116,"۔تہٕ اے نبی صلی اللہ علیہ وسلم،اگر توٚہۍ تِمن لُکن ہٕندِس اکثر یت کِس وننس پٮ۪ٹھ پٔکِو یِم زمینس منٛز بسان چِھ تیٚلہِ ڈا لنَو تِم تۅہیہِ اللہ تعالیٰ سٕنز وَتہِ نِشہِ ،تِم چِھ محض گُما نس پٮ۪ٹھ پکان بیٚیہِ چِھ قیا س آرٲیِیہِ کران۔"
  6,117,"۔در حقیقت چُھ تُہُند ربّ زیادہ بہتر زانان زِ کُس چُھ تٔمۍ سٕنزِ وَتہِ نِشہِ ڈٔلِتھ، تہٕ کُس چُھ سیٚزِ وَتہِ پٮ۪ٹھ۔"
  6,118,"۔پتہٕ اگر توٚہۍ لُکھ اللہ تعالیٰ سٕندٮ۪ن آیا تن پٮ۪ٹھ ایمان چِھو تھاوان تیٚلہِ یس جانورس پٮ۪ٹھ اللہ تعالیٰ سُند ناو آسہِ ہیٚنہٕ آمُت تٔمۍ سُند ماز کھیٚیِو ۔"
  6,119,"۔کیا وجہ چُھ ٲخر توٚہۍ کھیِیو نہٕ سُہ چیز یتھ پٮ۪ٹھ اللہ تعالیٰ سُند ناو آسہِ ہیٚنہٕ آمُت؟ حالانکہ یِمن چیز ن ہُند استعمال حالتِ اِضطرارٕ وَرٲے با قی تمام حالتن منٛز خُدا ین حرا م چُھ کوٚر مُت، تمِچ تفصیل چھےٚ تٔمۍ تۅہیہِ ؤنِمٕژ، اکثر لُکن ہُند حال چُھ یہِ زِ علمہٕ ورٲے چِھ محض پننیٚن خوٲہشا تن ہٕندِس بُنیادس پٮ۪ٹھ گُمراہ کر ن واجِنہِ کتھہٕ کران، یِمن حدٕ نیر ن والیٚن چُھ تُہُند ربّ ٹھیک پٲٹھۍ زانان۔"
  6,120,"۔ توٚہۍ بٔچِو ٹا کارٕ گنا ہَو نِشہِ تہِ تہٕ پو شیدہ گنا ہَو نِشہِ تہِ ، یِم لُکھ گنا ہ چِھ کماوان، تِمن میلہِ ضروٗر پننہِ امہِ کما یہِ ہُند بد لہٕ۔"
  6,121,"۔تہٕ یُس جانور اللہ تعالیٰ سُند ناو ہیٚتھ آسہِ نہٕ ذبح کر نہٕ آمُت تٔمۍ سُند مازمَہ کھیٚیِو،یہِ کرُن چُھ فِسق، شیطا ن چِھ پننیٚن سٲتھیِن ہٕندٮ۪ن دِلن منٛز شکو ک تہٕ اعتراضا ت اِلقا کران تا کہ تِم کر ن تۅہیہِ سٍتۍ جھگڑٕ،البتہٕ اگر تۅہیہِ تِہٕنز اطا عت قبول کٔرٕ و تیٚلہِ چِھو پٔزۍ پٲٹھۍ توٚہۍ مُشر ک۔ع"
  6,122,"۔کیا سُہ شخص یُس گۅڈٕ ہ مۅردٕ ہ اوس ، پتہٕ بخٕش تس اسہِ زند گی تہٕ تس کٔر سۅ روشنی عطا ییٚمہِ کِس گاشس منٛز سُہ لُکن در میان زند گی ہٕنز وَتھ چُھ طے کران سُہ ہیٚکیا تس شخصہٕ سٕندۍ پٲٹھۍ ٲسِتھ یُس اَنہِ گٹن منٛز آسہِ ہیٚنہٕ آمُت تہٕ کُنہِ پٲٹھۍ آسہِ نہٕ تِمو منٛزٕ نیران ؟ ﴿یعنی توٚہۍ کِتھہٕ پٲٹھۍ ہیٚکِو یہِ  تو قع تھٲوِتھ زِ یس انسانس انسا نیتُک شعور آسہِ نصیب سپُد مُت تہٕ یُس علم چہِ روشنی منٛز ہجن وتن منٛز با گ حقٕچ سِیٔز وَتھ صا ف پٲٹھۍ وُچھان آسہِ سُہ کرِ تِمن بے شعور لُکن ہٕندۍ پٲٹھۍ دُنیا ہس منٛز زند گی بسر یِم نا دا نی تہٕ جہا لت کیٚن انہِ گٹن منٛز در بدر پھیران چِھ ﴾ کٲفر ن خٲطرٕ چِھ یِتھے پٲٹھۍ تِہندۍ اعمال خۅ شنما بنا و نہٕ آمٕتۍ،"
  6,123,"۔تہٕ یِتھے پٲٹھۍ چِھ اسہِ پرٛتھ بستی منٛز تمِکۍ بٔڑۍ بٔڑۍ مُجر م لگٲوِمٕتۍ زِ تَتہِ وَہرا وَن پننہِ مکر و فر یبٕکۍ زال، در اصل چِھ تِم پننِس فر یب کِس زالس منٛز پانہٕ پھسا ن ، مگر تِمن چُھنہٕ اَمِیُک شعور ۔"
  6,124,"۔ییٚلہِ تِمن برونٛہہ کُن کانٛہہ آیت چھےٚ یِوان،تیٚلہِ چِھ تِم ونان أسۍ مانَو نہٕ توٚت تام یوٚت تام نہٕ سُہ چیز پانہٕ اسہِ دِنہٕ یِیہِ یُس اللہ تعالیٰ سٕندٮ۪ن رسولن چُھ آمُت دِنہٕ  اللہ تعالیٰ چُھ زیادہ بہتر زانان زِ پننہِ پیغا مبر ی ہٕنز کٲم کس ہیٚیہِ تہٕ کِتھہٕ پٲٹھۍ ہیٚیَس، نز دیک چُھ سُہ وقت ییٚلہِ یِم مُجر م پننیٚن مکٲرِلَن ہٕندِس پاداشس منٛز خُدا یس نِشہِ ذِلّت تہٕ سخت عذا ب تُلن۔"
  6,125,"۔لہٰذا ﴿یہِ چھےٚ حقیقت زِ ﴾ یس اللہ تعالیٰ ہدا یت عطا کر نُک ارادہ چُھ کران،تٔمۍ سُند سینہٕ چُھ اسلام خٲطرٕ مٕژ راوان،تہٕ یَس گُمرٲہی منٛز ترا ونُک ارادہ چُھ کران، تٔمۍ سُند سینہٕ چُھ تنگ کران۔تہٕ تمہِ آیہِ چُھس مۅٹھوان ﴿زِ اسلامُک تصّوُر کرا نٕے ﴾چُھ تس باسان زِ زَنتہٕ تٔمۍ سُند رُو ح لوٚ گ آسما نس کُن پرواز کر نہِ،یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ ﴿حق نِشہِ فرار تہٕ نفر تٕچ﴾ نا پا کی تِمن لُکن پٮ۪ٹھ مُسلّط کران یِم ایمان اَنان چِھنہٕ، ﴿یتھ جایہِ گٔیہِ یہِ کتھ وا ضح زِ یِم لُکھ ایمان چِھنہٕ انان اللہ تعالیٰ چُھ تِمنٕے ہُند سینہٕ اسلام خٲطرٕ تنگ کران تہٕ تِمن چُھنہٕ ہدا یت بخشنُک ارادہ کران﴾"
  6,126,"۔حالانکہ یہِ وَتھ چھےٚ تُہٕندِس ربّ سٕنز سِیٔز وَتھ،تہٕ امِکۍ نشا نا ت چِھ تِمن لُکن خٲطرٕ وا ضح کر نہٕ آمٕتۍ یِم نصیحت چِھ قبول کران،"
  6,127,"۔تِہندِس ربّس نِشہِ چُھ تِہندِ خٲطرٕ سلامتی ہُند گھرٕ،تہٕ سُہ چھُ تِہُند سر پرست ،تمہِ صحیح طرزِ عمل کہ وجہ کِنۍ یُس تِمو اختیار چُھ کوٚر مُت۔"
  6,128,"۔ییٚمہِ دۅہ اللہ تعالیٰ یِمن سارنٕے لُکن ؤٹِتھ جمع کرِ، تمہِ دۅہ کرِسُہ جنّن ﴿یعنی شیطان جِنّن﴾ خطا ب تہٕ فر ما ویٚکھ زِ اے گروہِ جنّ ،تۅہیہِ کوٚرُو انسٲنۍ زُریا تس پٮ۪ٹھ خوب اتھہٕ صا ف﴿یعنی تۅہیہِ کٔرِ یوٗکھ تِم پا نس تٲبع﴾انسانو منٛزٕ یِم یِہِندۍ رفیق ٲسۍ تِم کر ن عر ض،پروردگارٕ، اسہِ منٛزٕ کوٚر پرٛتھ کٲنٛسہِ اکھ  بیاکھ خو ب استعما ل،تہٕ وۅ نۍ چِھ أسۍ تتھ وقتس تام وٲتِمٕتۍ یُس ژےٚ سانہِ خٲطرٕ مُقرر اوسُے کوٚر مُت۔ امہِ نِشہِ بچن صرف تِمے یِمن اللہ تعالیٰ ییٚژِھہ بچاوُن، بے شک چُھ تُہُند ربّ حکمت وول تہٕ زانن وول۔"
  6,129,"۔وُچِھو، یِتھہٕ پٲٹھۍ بناوو کھ أسۍ ﴿ٲخرتس منٛز﴾ ظٲلِم اکھ أکِس سٕندۍ سٲتھی تمہِ کما یہِ ہِندِ وجہ کِنۍ یۅسہٕ تِم ﴿دُنیا ہس منٛز اکھ أکِس سٍتۍ رٔلِتھ﴾ کران ٲسۍ۔ع"
  6,130,"۔﴿اتھ مو قعس پٮ۪ٹھ پٕرٛژِھہ اللہ تعالیٰ یِمن یِتہِ زِ ﴾ اے گروہِ جِنّ و اِنس، تۅہیہِ نِشہِ ٲسۍ نا خۅد تۅہی منٛزٕ تِتھۍ رسول آمٕتۍ یِم تۅہیہِ میٲنۍ آیات ٲسِو بوزناوان،تہٕ ییٚمہِ أزِکہِ دۅہ کہ انجام نِشہِ کھۅژناوان ٲسِو؟ تِم وَنن آ، أسۍ چِھ پانس خلا ف پانہٕ گوٲہی دِوان اَز چِھ دُنیا چہِ زند گی یِم لُکھ دو کھس منٛز ترٲوِمٕتۍ، مگر تمہِ وقتہٕ دِن تِم پانہٕ  پانس خلا ف گوٲہی زِ تِم ٲسۍ کٲفر۔"
  6,131,"۔﴿یہِ شہادت یِیہِ تِمن امہِ موجو ب رَٹنہٕ زِ ﴾یہِ گژِھہ ثٲبت زِ تُہُند ربّ اوس نہٕ بٔستِیَن ظُلم کٔرِتھ تبا ہ کر ن وول کینٛہہ ییٚلہِ زَن تِہٕندۍ با شندہ حقیقت نِشہِ نا وٲقف آسن۔"
  6,132,"۔پرٛتھ کٲنٛسہِ شخصہٕ سُند در جہ چُھ تٔمۍ سٕندِ عملہِ ہٕندِ لحا ظہٕ تہٕ تُہُند ربّ چُھنہٕ لُکن ہٕند یٚو اعمالو نِشہِ بے خبر کینٛہہ۔"
  6,133,"۔ہرگاہ سُہ ییٚژِھہ تۅہیہِ لُکن نِیَو تہٕ تُہٕنزِ جایہِ یِمن ییٚژِھہ تِمن لُکن انہِ،یِتھہٕ پٲٹھۍ تٔمۍ توٚہۍ بیٚیہِ کینژھن ہٕندِ نسل نِشہِ تُلِمٕتۍ چِھنَو ۔"
  6,134,"۔تۅہیہِ سٍتۍ ییٚمہِ چیزُک وعدہ چُھ کر نہٕ یِوان سُہ چُھ یقیناً یِنہٕ وول، تہٕ توٚہۍ چِھو نہٕ خُدا یس عٲجز کر نُک طا قت تھاوان۔"
  6,135,"۔اے نبی صلی اللہ علیہ وسلم ، ؤنِو زِ لُکو ،توٚہۍ روٗزِ و پننہِ جایہِ عمل کران تہٕ بٕتہِ چُھس پننہِ جایہِ عمل کران، عنقر یب لگہِ تۅہیہِ پے زِ انجامِ کار کٔمۍ سٕندِس حقس منٛز چُھ بہتر سپدان،بہرحال چھےٚ یہِ حقیقت زِ ظٲلِم ہیٚکن نہٕ فلا ح لٔبِتھ۔"
  6,136,"۔یِمو لُکو چُھ اللہ تعالیٰ سٕندِ خٲطرٕ خۅد تٔمۍ سٕندِ وٕے پٲدٕ کر نہٕ آمتیو زراعتو تہٕ چاروایو منٛزٕ اکھ حصہٕ مُقرر کوٚر مُت تہٕ ونان چِھ یہِ چُھ اللہ تعالیٰ سٕندِ خٲطرٕ، بز عمِ خۅد ﴿ پننی خیالہٕ ﴾ ، تہٕ یہِ چُھ سا نیٚن ٹھہراو نہٕ آمتیٚن شر یکن خٲطرٕ ،پتہٕ یُس حصہٕ یِہند ٮ۪ن ٹھہراو نہٕ آمتیٚن شر یکن خٲطرٕ چُھ، سُہ چُھنہٕ خُدا یس واتان، مگر یُس خُدا یس خٲطرٕ چُھ، سُہ  چُھ تِہندٮ۪ن شر یکن واتان۔﴿یُس حصہٕ تِم لُکھ اللہ تعالیٰ  سٕندِ ناوٕ کڑان ٲسۍ تَتھ منٛز تہِ ٲسۍ رنگہٕ رنگہٕ چالبٲزِ یہِ کٔرِتھ کٔمی کران روزان تہٕ پرٛتھ طر یقہٕ ٲسۍ پننیٚن خۅد ساختہٕ شر یکن ہُند حصہٕ ہُرا ونٕچ کوٗشش کران۔ مثلاً یُس اناج یا پھل بیترِ اللہ تعالیٰ سٕندِ ناوٕ کڑ نہٕ اوس یِوان تمہِ منٛزٕ اگر کینٛہہ ؤسِتھ پیٚیہِ ہے تیٚلہِ اوس سُہ شر یکن ہٕندِس حصّس منٛز شٲمل یِوان کر نہٕ، تہٕ ہرگاہ شر یکن ہٕندِ حصہٕ منٛزٕ ؤسِتھ پیٚیہِ ہے یا رَلہِ ہے اللہ تعالیٰ سٕندِس حصّس منٛز، تیٚلہِ اوس سُہ واپس یِوان تِہندِس حصس منٛز ترا و نہٕ۔ ہرگاہ کُنہِ وجہ کِنۍ نذر و نیا زُک اناج خۅد پا نس استعمال کر نٕچ ضرورت پیٚیہِ ہیٚکھ تیٚلہِ ٲسۍ اللہ تعالیٰ سُند حصہٕ کھیٚوان مگر شر یکن ہٕندِس حصّس ٲسۍ اتھہٕ لا گنس کھۅژان زِ کُنہِ کِنۍ گٔژھ نہٕ کانٛہہ وُلٹہٕ ژٔنڈ یِن ۔﴾ کِتھۍ بُرٕ فٲصلہٕ چِھ کران یِم لُکھ !"
  6,137,"۔تہٕ یِتھے پٲٹھۍ چُھ واریاہن مُشر کن خٲطرٕ یِہندِ یو شر یکو پننیٚن اولادن ہُند قتل خۅش کروُن بنو و مُت،﴿یتھ جایہِ چُھ شر یکن  ہُند لفظ دوٚیِمس أکِس معنیس منٛز وَرتاو نہٕ آمُت یُس گۅڈنِکہِ معنی نِشہِ مختلف چُھ۔ آیت 136،ہَس منٛز یِم شر یک  لفظہٕ سٍتۍ تعبیر چِھ کر نہٕ آمٕتۍ تِم ٲسۍ تِہٕندۍ تِم معبود یِہٕنز بر کت یا سفٲرش یا توسُط یِم لُکھ کانٛہہ نعمت حٲصل سپد نس منٛز مددگار ٲسۍ سمجھان تہٕ نعمتُک شکر انہٕ کرنٕکۍ حقدار زٲنِتھ ٲسۍ تِمن اللہ تعالیٰ سٕندۍ حصہ دار بناوان۔اتھ بر عکس چُھ یَتھ آیتس منٛز شر یک  نِشہِ مُراد تِم انسان یِمو قتلِ اولادُک رسم ایجاد کوٚر مُت اوس تہٕ بیٚیہِ چِھ تِم شیطا ن یِمو یہِ ظٲلما نہٕ رسم تِمن لُکن ہٕنز ن نظر ن منٛز اکھ جٲیز تہٕ پسند ید ہ کٲم بنٲومٕژ ٲس۔اہل عر بن منٛز آسہٕ قتلِ اولاد چہِ ترٛے صوٗرتہٕ رٲیِج تہٕ قرآنس اندر چُھ تریشوٕ نۍ کُن اشار ہ کر نہٕ آمُت۔﴿1﴾ کورٮ۪ن ہُند قتل ،امہِ خیا لہٕ زِ کانٛہہ گوٚژھ نہٕ تِہُند زامتُر بَنُن یا قبٲیلی لڑا ین منٛز گژھنہٕ تِمہٕ دشمنن ہٕندٮ۪ن اتھن منٛز لگنہِ یا بیٚیہِ کُنہِ وجہ کِنۍ گژھنہٕ تِمہٕ عزت والنہِ۔﴿2﴾ شُر ٮ۪ن ہُند قتل ، امہِ خیا لہٕ زِ تِمن ہٕندِ رَچھنُک پا لنُک بار تُلن گژِھہ مُشکل تہٕ روزگار کیٚن ذر یعن ہٕنزِ کمی ہٕند رٔنگۍ بَنَن تِم سُہ با ر ،یُس تُلِتھ ہیٚکو نہٕ۔ ﴿3﴾ پننیٚن معبو دن ہٕنز خو شی  خٲطرٕ شُر ۍ قر بان کرٕنۍ تا کہِ تِمن کر ن ہلا کتس منٛز مبتلا تہٕ تِمن پٮ۪ٹھ بناو ن تِہُند دین شکہٕ لد ۔﴿ جا ہلیت کہ زمانٕکۍ عربٕکۍ لُکھ ٲسۍ پننِس پانس حضرت ابرا ہیم علیہ السلا من تہٕ اسما عیل علیہ السلامن ہٕندۍ پیرو کار وَنان تہٕ سمجھان، تہٕ اتھ بنیادس پٮ۪ٹھ اوس تِہُند خیا ل یہِ زِ ییٚمہِ مذ ہبٕچ تِم اتبا ع چِھ کران سُہ چُھ اللہ تعالیٰ سُندُے پسند یدٕہ مذہب۔البتہ اتھ دینس منٛز گٔیہِ تِہندۍ مذہبی پیشوا ، قبیلن ہٕندۍ سردار،خاندانن  ہٕندۍ زٕ ٹھۍ بیٚیہِ مختلف لُکھ رنگہٕ رنگ کیٚن عقید ن، اعما لن تہٕ رسمن ہُند اضا فہٕ کران یِم پتہٕ یِنہٕ والیو نٔسلو اصلی مذ ہبٕکۍ جُز سمجھ تہٕ تِہُند پوٗرٕ دین بنیاو شکہٕ لد﴾ اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ کر ہن نہٕ یِم یہِ ، لہٰذا ترٲوِیوٗکھ یِم زِ اوٗرۍ روزن پننہِ بہتا ن ترا شی اندر ۔"
  6,138,"۔وَنان چِھ زِ یِم جانور تہٕ یِم کھاہ چِھ محفو ظ ، یِمن ہیٚکن صرف تِمے لُکھ کھیٚتھ یِم أسۍ یَژھو کھ کِھیا وٕنۍ، حالانکہ یہِ پابند ی چھےٚ تِہٕنز پانہٕ بناو نہٕ آمٕژ،پتہٕ چِھ کینٛہہ جانور یِمن پٮ۪ٹھ سوٲرۍ تہٕ بو ر کھا لُن حرام چُھ کر نہٕ آمُت تہٕ بیٚیہِ چِھ کینٛہہ جانور یِمن پٮ۪ٹھ یِم اللہ تعالیٰ سُند ناو چِھنہٕ ہیٚوان ،تہٕ یہِ سورُے کینٛہہ چُھ یِمو خُدا یس پٮ۪ٹھ بہتا ن لگو و مُت ،عنقر یب دِیہِ یِمن اللہ تعالیٰ یِمن بہتان ترا شِیَن ہُند بد لہٕ۔"
  6,139,"۔بیٚیہِ چِھ وَنان زِ یِکینژھاہ یِمن جانورن شکمس منٛز چُھ یہِ چُھ سانیٚن مَردن خٲطرٕ مخصوص تہٕ سانیٚن مستو راتن پٮ۪ٹھ چُھ حرام،البتہٕ اگر سُہ مۅردٕہ آسہِ تیٚلہِ ہیٚکن دۅشوے تٔمۍ سٕندِس کھینس منٛز شریک سپدِتھ ،یِمہٕ کتھہٕ یِمہٕ یِمَو بناوِمژٕ چھےٚ ،یُہُند بد لہٕ دِیہِ اللہ تعالیٰ یِمن ضروٗر، پٔزۍ پٲٹھۍ چُھ سُہ حکمت وول تہٕ سارِنٕے کتھن ہٕنز چھےٚ تس خبر ۔"
  6,140,"۔یقیناً پیٚیہِ خسا رس منٛز تِم لُکھ یِمو پنٕنۍ اولاد جہا لت کِس تہٕ نادٲنی ہٕندِ س بُنیا دس پٮ۪ٹھ قتل کٔرۍ تہٕ اللہ تعالیٰ سُند دِیتُمُت رزق ٹھٔہر ووُکھ خُدا یس پٮ۪ٹھ بہتا ن ترٲشی کٔرِتھ حرا م،یقیناً ڈٔلۍ تِم وَتہِ نِشہِ تہٕ تِم ٲسۍ نہٕ ہر گز تہِ سیٚز وَتھ لبن والیو منٛزٕ۔ع"
  6,141,"۔سُہ چھ اللہ تعالیٰ ہٕے ییٚمۍ قسمہٕ قسمٕکۍ با غ تہٕ تا کِستان ﴿دَچھہِ رانٛٹھ دار﴾ تہٕ نخلستان ﴿کھٔزٕ ر کُلۍ﴾ پٲدٕ کٔرۍ زراعت وۅ پدٲوِن یِمو منٛزٕ قسمہٕ قسمٕکۍ ماکو لات ﴿کھیٚنہٕ چیز ﴾ حٲصل چِھ سپدان، زیتو ن تہٕ دٲن کُلۍ وۅ پدٲوِن یِہِندۍ میوٕہ شکلہِ کِنۍ ہِو ی تہٕ مزٕ ہ رٔنگۍ بیٚو ن بیٚو ن چِھ ۔ کھیٚیِو یِہِندۍ پیداوار ییٚلہِ یِم وۅ پدن، تہٕ اللہ تعالیٰ سُند حق کٔرِ و ادا ییٚلہِ یُہُند فصل لوٚنِو، تہٕ حدٕ مَہ نِیرِ و زِ اللہ تعالیٰ چُھنہٕ حدٕ نیر ن والیٚن پسند کران۔"
  6,142,"۔پتہٕ چُھ سُے ییٚمۍ چار وایَو منٛزٕ تِم جانور تہِ پٲدٕ کٔرۍ یِمن سوٲرۍ تہٕ بو ر تُلنٕچ کٲم چھےٚ یِوان ہیٚنہٕ تہٕ تِم تہِ یِم کھیٚنَس تہٕ وَتھراونس چِھ بکار لگا ن۔﴿یعنی تِہٕندِس دالس تہٕ ییرس چِھ فر ش بناو نہٕ یِوان ﴾کھیٚیِو تِمو چیزو منٛزٕ یِم خُدا ین تۅہیہِ چِھو بخشمٕتۍ تہٕ شیطا ن سٕنز پیر وی مَہ کٔرِو،تِکیازِ سُہ چُھ تُہُند ٹا کارٕہ دشمن۔"
  6,143,"۔یِم چِھ ٲٹھ نر مادٕہ ، زٕہ چِھ تیٖر ن ہٕندِ قسمٕکۍ تہٕ زٕ ہ چِھ ژھاولیٚن ہٕندِ قسمٕکۍ،اے نبی صلی اللہ علیہ وسلم، یِمن پٕرٛژِھو زِ خُدا ین چھا تِہٕندۍ نَر حرام کٔرِ مٕتۍ کِنہٕ مادٕہ،کِنہٕ تِم بچہِ یِم گبیٚن تہٕ ژھاوجن ہٕندٮ۪ن شکمن منٛز آسن؟ صحیح صحیح علمہٕ سان ؤنِو مےٚ اگر توٚہۍ پٔزِیٲرۍ چِھو۔"
  6,144,"۔تہٕ یِتھے پٲٹھۍ چِھ زٕ ہ او نٹہٕ سٕندِ قٔسمہٕ منٛزٕ تہٕ زٕ ہ چِھ گٲوِ ہٕندِ قٔسمہٕ منٛزٕ،پٕرٛژِھو، یِہِندۍ نَر چھا خُدا ین حرا م کٔرِ مٕتۍ کِنہٕ مادٕ،کِنہٕ تِم بچہِ یِم اونٹنہِ تہٕ گٲوہٕندِس شکمس منٛز آسن؟کیا توٚہۍ ٲسِوٕہ تمہِ ساعتہٕ حٲضر ییٚمہِ ساعتہٕ خُدا ین تِہندِ حرا م آسنُک حکم تۅہیہِ دِیتُمُت اوسنو؟ پتہٕ کُس آسہِ تس شخصہٕ سٕندِ کھۅتہِٕ کھٔسِتھ ظٲلِم یُس اَپٕز کتھ خُدا یس کُن منسو ب کٔرِ تھ وَنہِ تا کہ علمہٕ ورٲے کرِ لُکن غلط رہنمٲیی،یقیناً چُھنہٕ اللہ تعالیٰ یِتھیٚن ظٲلِمن سِیٔز وَتھ ہاوان۔ع"
  6,145,"۔اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو زِ یۅسہٕ وَحی مےٚ نِش آمٕژ چھےٚ اتھ منٛز چُھنہٕ مےٚ کانٛہہ تِیُتھ چیز لبنہٕ یِوان یُس کٲنٛسہِ کھیٚنہٕ وٲلِس پٮ۪ٹھ حرام آسہِ ،اِلاّیہِ زِ سُہ آسہِ مۅردار،یا آسہِ بہاو نہٕ آمُت خو ن، یا آسہِ خنزیر سُند ماز تِکیازِ سُہ چُھ نا پاک، یا فِسق آسہِ زِ اللہ تعالیٰ سٕندِ ناوٕ ورٲے آسہِ بیٚیہِ کٲنٛسہِ ہٕندِس ناوس پٮ۪ٹھ ذبح کر نہٕ آمُت۔﴿اَمِیُک مطلب چُھنہٕ یہِ زِ یِمو ورٲے چُھنہٕ کانٛہہ چیز شر یعتس منٛز حرام کینٛہہ، بلکہ چُھ مطلب یہِ زِ حرام چِھنہٕ تِم چیز یِم تۅہیہِ لُکو حرام چِھو کٔرِمٕتۍ بلکہ حرا م یِم چیز ۔ تشر یح خٲطرٕ وُچِھو سورۂ مایدہ آیت نمبر، ا، تہٕ 4۔﴾ پتہٕ یُس شخص مجبور ی ہٕندِس حا لتس منٛز ﴿یِمومنٛزٕ کانٛہہ چیز کھیٚیہِ ﴾ امہِ ورٲے زِ سُہ آسہِ نا فر ما نی ہُند ارادٕہ تھاوان تہٕ امہِ ورٲے زِ سُہ کرِ ضر ورت کہ حدٕ نِشہِ تجا وُز،تیٚلہِ چُھ یقیناً تُہُند ربّ در گُزر کر ن وول تہٕ رحم فر ماون وول۔"
  6,146,"۔تہٕ یِمو لُکو یہو دیت اختیار کٔر تِمن پٮ۪ٹھ ٲسۍ اَسہِ سٲر ی پنجہِ وٲلۍ جانور حرا م کٔرِ مٕتۍ، بیٚیہِ گٲو تہٕ ژھاو جہِ ہٕنز چر بی تہِ ، اَمہِ ورٲے زِ یُس چر ب تِہندِس کمبر س یا تِہند ٮ۪ن أندر مَن لور آسہِ یا روزِ أڈجہِ لور یہِ اوس اسہِ تِمن تِہنزِ سر کشی ہُند سزا دیتُمُت ﴿مزید وضا حت موجوٗب وُچِھو سورۂ آل عمرا ن آیت، 93 تہٕ سورۂ نسا ،آیت ،160﴾ تہٕ یِکینژھاہ أسۍ یہِ ونان چِھ یہِ چِھ بالکل پوٚز ونان ۔"
  6,147,"۔وۅ نۍ اگر تِم تۅہیہِ بُتھ پھرن تیٚلہِ ؤنِو تِمن زِ تُہندِس ربّ سٕندِ رحمتُک دا من چُھ وسیع ،تہٕ مجر  مَو نِشہِ یِیہِ نہٕ تٔمۍ سُند عذا ب وا پس پھِر نہٕ۔"
  6,148,"۔یِم مشر ک لُکھ وَنن ﴿تُہٕنز ن یِمن کتھن ہٕندِس جوا بس منٛز﴾ ضرور زِ اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ نہ کرہَو أسۍ شر ک تہٕ نہ کر ہَن سٲنۍ مٲلۍ بُڈِ بب، تہٕ نہ ٹھہرا وٕ ہَو أسۍ کانٛہہ چیز حرام۔﴿یعنی تِم کر ن پنُن جُر م تہٕ پننہِ غلط کٲر ی خٲطرٕ سُے پر ون عُذر پیش یُس ہمیشہ چِھ مُجر م تہٕ غلط کار لُکھ  پیش کران روٗدِمٕتۍ۔ تِم ونن زِ سٲنِس حقس منٛز چھےٚ اللہ تعالیٰ سٕنز مشیت یٔہے زِ أسۍ گژھو شر ک کرٕنۍ تہٕ یِم چیز اسہِ حرا م چِھ ٹھہرٲوِمٕتۍ تِم ٹھہراووکھ حرام۔نَتہٕ اگر اللہ تعالیٰ ییٚژھہ ہے نہٕ زِ أسۍ گٔژھۍ یہِ کرٕنۍ تیٚلہِ کِتھہٕ پٲٹھۍ اوس ممکن زِ سانہِ دٔسۍ گژھن یِمہٕ کامہِ سرزد۔لہٰذا چِھ أسۍ اللہ تعالیٰ سٕندِس  مشیّتس مطٲبق یہِ سورُے کینٛہہ کران، امہِ موجو ب چِھ صحیح کران۔وۅ نۍ اگر اَمِیُک الزام لگہِ سُہ لگہِ نہٕ اسہِ ، سُہ لگہِ خُدا یس ۔تہٕ یِکینژھاہ أسۍ کران چِھ ، أسۍ چِھ یی کر نہٕ خٲطرٕ مجبور تِکیازِ امہِ ورٲے بیٚیہِ کینٛہہ کرُن چُھ سانہِ طا قتہٕ نِشہِ نیٚبر۔﴾ یِژَے کتھہٕ بنٲوۍ بنٲوۍ اوس یِمن بروٗنٹھمیو لُکو تہِ حقس انکار کوٚر مُت یوٚت تام زن ٲخرکار سانہِ عذا بُک مزٕہ تِمو وُچھ،یِمن ؤنِو  کیا تۅہیہِ نِشہِ چھا کانٛہہ علم یُس اسہِ برونٛہہ کنہِ پیش ہیٚکِو کٔرِتھ؟ توٚہۍ چِھو صرف گُما نس پٮ۪ٹھ پکا ن تہٕ ژھر ے قیا س آرٲیِیہِ چِھو کران۔"
  6,149,"۔پتہٕ ؤنو﴿تُہٕندس اتھ حُجت کِس مقا بلس منٛز﴾حقیقت رس ﴿یعنی پوٗرٕ غٲلب ﴾حُجت چھےٚ خُدا یس نِشہِ ، بے شک ہرگاہ اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ دِیہِ ہیٚو تۅہیہِ سارِنٕے ہدا یت۔ ﴿یعنی توٚہۍ یۅسہٕ حُجت پننہِ عذرٕ رٔنگۍ پیش چِھو کران زِ اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ کر ہَو نہٕ أسۍ شر ک۔امہِ نِشہِ چَھنہٕ پوٗرٕ کتھہ ادا سپدان۔پوٗرٕ کتھ اگر وَنٕنۍ چِھو یَژھان تیٚلہِ ؤنِو یِتھہٕ پٲٹھۍ زِ اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ دِیہِ ہے اسہِ سارِنٕے ہدایت۔دوٚیِمیٚن لفظن منٛز  وَنَو زِ توٚہۍ چِھو نہٕ پننہِ اِنتخا ب نِشہِ سِیٔز وتھ اختیار کر نہٕ خٲطرٕ تیار، بلکہ چِھو یہِ یژھان زِ خُدا ین یِتھہٕ پٲٹھۍ فر شتہٕ چِھ پیدٲیشی طور سیزِ وتہِ پٮ۪ٹھ پکن وٲلۍ بنٲوِمٕتۍ، تِتھے پٲٹھۍ گوٚژُھو تۅہیہِ تہِ بناوُن۔ بے شک اگر یہِ مشیّت اللہ تعالیٰ سٕنز انسان سٕندِس حقس منٛز آسِہے ،تیٚلہِ ہیٚکہِ ہے سُہ ضرور یہِ کٔرِتھ ۔مگر یہِ چَھنہٕ تٔمۍ سٕنز مشیّت ۔لہٰذا یۅسہٕ گُمرٲہی تۅہیہِ پانہٕ پا نس خٲطرٕ چَھو پسند کٔر مٕژ،اللہ تعالیٰ تہِ دِیو تۅہیہِ أتھۍ منٛز روزنہٕ۔﴾"
  6,150,"۔یِمن ؤنِو زِ أنِیوٗکھ پنٕنۍ تِم گواہ یِم امہِ کتھہِ ہٕنز شہا دت دِن،زِ خُدا ے نٕے چِھ یِم چیز حرام کٔرۍ مٕتۍ۔ پتہٕ اگر تِم شہادت دِن تیٚلہِ دی زیٚو نہٕ توٚہۍ تِمن سٍتۍ شہادت ،﴿یعنی اگر تِم شہا دتٕچ ذمہٕ دٲر ی سمجھان آسن تہٕ زانان آسن زِ شہادت چھےٚ اَمی کتھہِ ہٕنز دِنۍ ییٚمیُک علم انسانس آسہِ ،تیٚلہِ کر ن نہٕ تِم ہر گز یہِ شہادت دِنُک جُر ات ۔ البتہ اگر تِم لُکھ شہادتِٕچ ذمہ دٲر ی محسو س کر نہٕ ورٲے ضِدس لایِنہٕ یِن زِ اللہ تعالیٰ سُند ناو ہیٚتھ کر ن نہٕ اَپٕز گوٲہی دِنس ہِر اسہٕ، تیٚلہِ بٔنۍ زیٚو نہٕ تِہندس اتھ اَپزِس منٛز تِہندۍ سٲتھی۔﴾ تہٕ ہر گز پٔکۍ زِ یٚو نہٕ تِہندِٮ۪ن خوٲہشا تن پتہٕ پتہٕ یِمو سا نیٚن آیاتن بُتھ چُھ پھِیرُمُت ،تہٕ یِم ٲخر تٕکۍ مُنکر چِھ ، بیٚیہِ یِم با قین چِھ پننِس ربّ سُند ہمسر ﴿برابر﴾ بناوان۔ع"
  6,151,"۔اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو زِ ؤلِو بہٕ بوزناوَو تُہٕندۍ ربّن کیا پابند یہِ چھےٚ تۅہیہِ پٮ۪ٹھ عٲید کرِمَژٕ:﴿یعنی تُہندِس ربّ سٕنزٕ عٲید کر نہٕ آمژٕ پابند یہِ چَھنہٕ تمہٕ یِمن منٛز توٚہۍ گرفتار چِھو، بلکہ چھےٚ اصلی پابند یہِ نۅ مہٕ﴾ یہِ زِ تس سٍتۍ مَہ کٔرِیوٗن کانٛہہ شر یک، تہٕ مٲلِس ماجہِ سٍتۍ کٔرِو نیک سلوک، بیٚیہِ مَہ کٔرِیوٗکھ پنٕنۍ اولاد غر یبی ہٕندِ ڈرٕ کِنۍ قتل،أسۍ چِھو تۅہیہِ تہِ رزق دِوان تہٕ  تِمن تہِ دِمَو،تہٕ بے شر می ہٕنز ن کتھن مَہ گٔژِھو نکھہٕ تہِ خوا ہ تِمہٕ نَنہِ وانہٕ ٲسِتن یا ژھا یہِ پٲٹھۍ ،﴿دراصل چُھ لفظفواحش  استعمال سپُد مُت ییٚمیُک اِطلا ق تِمن تمام کامیٚن پٮ۪ٹھ چُھ سپدان یِہنز بُرٲیی بالکل واضح چھےٚ۔قرآنس منٛز چُھ زِ نا، قومِ لوٗطٕچ عمل، ننگے روزُن ،اَپٕز تہمت تہٕ یس سٍتۍ مٲلۍ نکاح کوٚر مُت آسہِ تس سٍتۍ نکا ح کرُن فحش کامیٚن منٛز شما ر کر نہٕ آمُت۔حدیث شر یفس منٛز چُھ ژوٗرِ ،شراب نو شی تہٕ بیٚچھہِ نَس فواحش وَننہٕ آمُت۔یِتھے پٲٹھۍ چھےٚ تمام شر مناک کامہِ تہِ فوٲحشن منٛز شٲمل تہٕ اللہ تعالیٰ سُند ارشاد چُھ یہِ زِ یژٕھہ کامہِ نہ گژھن نَنہِ وانہٕ یِنہِ کر نہٕ تہٕ نَہ ژھایہِ پٲٹھۍ﴾ تہٕ بیٚیہِ کانٛہہ زُو یُس خُدا ین محتر م چُھ ٹھہر وو مُت مَہ کٔرِیوٗن ہلاک مگر حقہٕ سان، یِمہٕ چھےٚ کتھہٕ یُہُند ہدایت تٔمۍ تۅہیہِ کوٚرمُت چُھو بنان چُھ زِ توٚہۍ ہِیٚیو عقلہِ کٲم۔"
  6,152,"۔بیٚیہِ یہِ زِ یتیم سٕندِس مالس نکھہٕ مَہ گٔژِھو،مگر تمہِ طر یقہٕ یُس بہتر ین آسہِ،یوٚت تام زن سُہ پننہِ جوٲنی تام واتہِ ،تہٕ مینہٕ نس تو لنس منٛز کٔرِ و انصا ف ،أسۍ چِھ پرٛتھ شخصس پٮ۪ٹھ ذمہ دٲر ی ہُند تِیتُے بار تھاوان یوتاہ تٔمۍ سٕندِ س اِمکانس منٛز چُھ،تہٕ ییٚلہِ کتھ ؤنِو انصا فٕچ ؤنِو خواہ معا ملہٕ کو نہٕ آسہِ پننِس رشتہٕ دار سُندُے تہٕ اللہ تعالیٰ سُند عہد کٔرِ و پوٗرٕ۔ ﴿ اللہ تعالیٰ سٕندِ عہد نِشہِ چُھ مُراد سُہ عہد یُس انسانس تہٕ خُدا یس بیٚیہِ انسانس تہٕ انسانس در میان فطر ی طور پٲنۍ پانے چُھ گنڈ نہٕ یِوان ییٚمہِ ساعتہٕ اکھ شخص اللہ تعالیٰ سٕنزِ زمینہِ پٮ۪ٹھ أکِس انسٲنی مُعا شرس منٛز چُھ پٲدٕ سپدان۔﴾ یِمن کتھن ہُند ہدا یت چُھو خُداین تۅہیہِ کوٚر مُت بنان چُھ زِ توٚہۍ کٔرِو نصیحت قبول۔"
  6,153,"۔بیٚیہِ چُھ تٔمۍ سُند ہدا یت یہِ زِ یٔہے چھےٚ میٲنۍ سِیٔز وَتھ ،لہٰذا پٔکِو توٚہۍ أتھۍ پٮ۪ٹھ،تہٕ با قی وتن پٮ۪ٹھ مَہ پٔکِو زِ تِمہٕ ڈا لنو تۅہیہِ اَمہِ سیٚزِ وَتہِ نِشہِ تہٕ کر نَو چھلہٕ چھا نٛگٕر، یہِ چُھ سُہ ہدایت یُس تُہٕندۍ ربّن تۅہیہِ کوٚر مُت چُھنَو بنان چُھ زِ توٚہۍ بچِو کج رَوی ﴿وَتہِ ڈلنہٕ ﴾نِشہِ ۔"
  6,154,"۔پتہٕ ٲس اسہِ موسیٰ ﴿علیہ السلامس﴾ کتا ب عطا کٔرمٕژ۔ یۅسہٕ رٕژرٕ چ رٔوِش اختیار کر ن وٲلِس انسانس پٮ۪ٹھ نعمتُک تکمیل تہٕ پرٛتھ ضرور ی چیزُک تفصیل تہٕ سراسر ہدایت تہٕ رحمت ٲس﴿تہٕ امہِ موجو ب ٲس بنی اسرا یلس دِنہٕ آمٕژ زِ ﴾ شاید اَنن لُکھ پننِس ربّس سٍتۍ ملا قات کر نس پٮ۪ٹھ ایمان۔ع ﴿مُراد چُھ یہِ زِ لُکھ ترٲوِن پنُن پان غیر ذمہٕ دار سمجُھن تہٕ یہِ مٲنِن زِ تِمن چُھ اکہِ دۅہ پننِس  ربّس برونٛہہ کنہِ حٲضر سپدِتھ پننیٚن عملن ہُند جواب دِیُن﴾"
  6,155,"۔ تہٕ یِتھے پٲٹھۍ چھےٚ یہِ کتاب اسہِ نٲزِل کر مٕژ اکھ بر کت واجِنۍ کتاب، لہٰذا کٔرِو توٚہۍ  اَمِچ پیر وی بیٚیہِ کٔرِو تقویٰ ہٕچ رٔوِش اختیار ،یہِ کتھ چَھنہٕ دوٗر زِ تۅہیہِ پٮ۪ٹھ  یِیہِ رحم کر نہٕ،"
  6,156,"۔وۅ نۍ ہیٚکو نہٕ توٚہۍ   یہِ ؤنِتھ زِ کتا ب ٲس اَسہِ برونٹھمیٚن دۅ ن گر و ہن دِنہٕ آمٕژ، تہٕ اَسہِ ٲس نہٕ کانٛہہ خبر زِ تِم کیا ٲسۍ پران پرناوان۔"
  6,157,"۔تہٕ وۅ نۍ ہیٚکِو نہٕ توٚہۍ یہِ بہا نہٕ تہِ کٔرِتھ زِ اگر اسہِ پٮ۪ٹھ کتا ب آسہِ ہے نٲزِل کر نہٕ آمٕژ تیٚلہِ سپدٕ ہَو أسۍ تِہندِ کھۅتہٕ زیادٕہ ہدایت یا فتہٕ ثٲبت،تۅہیہِ نِشہِ چھےٚ تُہٕندِس ربّ سٕندِ طر فہٕ اکھ روشن دلیل تہٕ ہدایت تہٕ رحمت آمٕژ،وۅ نۍ کُس ہیٚکہِ تٔمۍ سٕندِ کھۅتہٕ بوٚڈ ظٲلِم ٲسِتھ یُس اللہ تعالیٰ سٕندٮ۪ن آیاتن انکار کرِ تہٕ تِمو نِشہِ پھِرِ بُتھ،یِم لُکھ سا نیو آیاتَو نِشہِ بُتھ چِھ پھِران تِمن دِمو أسۍ اَتھ روگردٲنی ہٕندِس پاداشس منٛز ضرور بدتر ین سزا۔"
  6,158,"۔ لُکھ چھا وۅ نۍ اتھ انتظارس زِ تِمن برونٛہہ کُن یِتھ گژھن فر شتہٕ کھڑا سپٕدنۍ،یا گژِھہ تُہُند ربّ پانہٕ یُن ،یا گژھن تُہٕندِس ربّ سٕنز کینٛہہ ٹاکارٕ نشٲنیہِ ظٲہر سپدٕنہٕ؟﴿یعنی قیا متٕکۍ آثار،یا عذا ب ،یا بیٚیہِ کانٛہہ تِژھ نشٲنی یوسہٕ حقیقتس بالکل گژِھہ پردہ تھوٚد تُلٕنۍ تہٕ ییٚمہِ کہ ظٲہر سپد نہٕ پتہٕ امتحا نُک تہٕ آزمٲیشہِ ہُند کانٛہہ سوالٕے روزِ نہٕ پتھ کُن۔﴾ ییٚمہِ دۅہ تُہندِس ربّ سٕنزٕ کینٛہہ مخصوص نشٲنیہِ ظاہرسپدَن۔ پتہٕ دِیہِ نہٕ تِتھِس کٲنٛسہِ شخصس تٔمۍ سُند ایمان کانٛہہ فٲیدٕہ ییٚمۍ نہ گۅڈٕ ایمان آسہِ اوٚ نمُت، یا ییٚمۍ نہٕ پننِس ایمانس منٛز کانٛہہ رٕژر آسہِ کمو و مُت، اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو زِ اچھا ،توٚہۍ کٔرِ و انتظا ر ،أسۍ تہِ کر و انتظا ر۔"
  6,159,"۔یِمو لُکو پننِس دینَس ٹکرٕ ٹکرٕ کٔرۍ تہٕ سپدٕۍ الگ الگ دٔرۍ ﴿گروہ ﴾ ، یقیناً چُھنہٕ تۅہیہِ تِمن سٍتۍ کانٛہہ واسطہٕ، تِہُند معا ملہٕ چُھ خُدا یس سپُرد، سُے ونہِ تِمن زِ تِمو کیا کینژھاہ چُھ کوٚر مُت،"
  6,160,"۔یُس اللہ تعالیٰ سٕندِس در بارس منٛز نیکی ہیٚتھ یِیہِ تس خٲطرٕ چُھ داہ گۅ نہٕ اجر ،  تہٕ یُس بد ی ہیٚتھ یِیہِ تس یِیہِ تِیتُے بد لہٕ دِنہٕ یوٗتاہ تٔمۍ قصور چُھ کوٚر مُت، تہٕ کٲنٛسہِ پٮ۪ٹھ یِیہِ نہٕ ظُلم کر نہٕ۔"
  6,161,"۔اے نبی صلی اللہ علیہ وسلم، ؤنِو میٲنۍ ربّن چھےٚ پٔزِ پٲٹھۍ مےٚ سِیٔز وتھ ہٲومٕژ،بالکل ٹھیک دین یَتھ منٛز کانٛہہ ہجر چُھنہٕ، ابراہیم ﴿علیہ السلامن﴾ ہُند طر یقہٕ یُس یکسوٗ سپدِتھ تِمَو اختیار اوس کوٚر مُت، تہٕ تِم علیہ السلام ٲسۍ نہٕ مُشر کو منٛزٕ۔"
  6,162,"۔ؤنِو میٲنۍ نماز، میٲنۍ تمام مَراسِم عبودیت۔﴿دراصل چُھ لفظ نُسُک استعمال سپُد مُت۔اَمِیُک معنی چُھ قر بٲنی تہِ تہٕ اَمِیُک اطلا ق چُھ عمو میت سان بند گی تہٕ پرستش ہٕندٮ۪ن دوٚیِمیٚن تمام صوٗرتن پٮ۪ٹھ سپدان﴾ میو ن زند ہ روزُن میو ن مَرُن ،سورُے کینٛہہ چُھ اللہ رب العا لمینس خٲطرٕ،"
  6,163,"۔ یس نہٕ کانٛہہ شر یک چُھ ،امہِ کُے چُھ مےٚ حکم دِنہٕ آمُت تہٕ سارِوٕے برونٛہہ چُھس اطا عتُک کلہٕ نوٚ مراوان وول بہٕ۔"
  6,164,"۔ؤنِو ،کیا بہٕ کرا خُدا یس ورٲے بیٚیہِ کانٛہہ ربّ تلا ش حالانکہ سُے چُھ پرٛتھ چیزُک ربّ؟ پرٛتھ کانٛہہ شخص یِکینژھاہ کماوان چُھ تَمِیُک ذمہٕ دار چُھ سُہ پانہٕ، کانٛہہ بور تُلن وول چُھنہٕ دوٚیِمہِ سُند بور تُلان۔﴿یعنی پرٛتھ شخص چُھ خۅد پننہِ عملہِ ہُند ذمہ دار۔ أکۍ سٕندِ عملہِ ہٕنز ذمہٕ دٲر ی چَھنہٕ بیٚیِس پٮ۪ٹھ﴾ پتہٕ چُھو تۅہیہِ سارِنٕے پننِس ربّس کُن واپس پھیرُن، تمہِ وقتہٕ کڑِ سُہ تۅہیہِ پٮ۪ٹھ تُہندٮ۪ن اختلا فن ہٕنز حقیقت نٔنۍ ۔"
  6,165,"۔سُے چُھ ییٚمۍ توٚہۍ زمینٕکۍ خلیفہٕ بناوِنَو ، تہٕ تۅہیہِ منٛزٕ دِتِن کینٛژھن ہٕندِس مقا بلس منٛز کینٛژھن بُلند در جہِ ، تاکہِ یِکینژھاہ تۅہیہِ دِنہٕ چُھ آمُت تتھ منٛز کرِ تۅہیہِ آزمٲیش ۔بے شک چُھ تُہُند ربّ سزا دِنس منٛز تہِ سٮ۪ٹھاہ تیز، تہٕ سٮ۪ٹھاہ در گز ر کر ن وول تہٕ رحم فر ماون وول تہِ ۔ع۔"
