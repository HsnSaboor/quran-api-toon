quran[52]{c,v,t}:
  14,1,"۔ا۔ل۔ر۔ اے محمد صلی اللہ علیہ وسلم۔یہِ چھےٚ اکھ کتاب یۅسہٕ اسہِ تۅہیہِ کُن چھےٚ نٲزل کٔر مٕژ، تاکہ توٚہۍ أنیوٗکھ لُکھ اَنہِ گٹو منٛزٕ کٔڑِ تھ گا شس منٛز، تِہندِ س رب سٕندِ توفیق سٍتۍ، تس اللہ تعالیٰ سٕنزِ وَتہِ پٮ۪ٹھ یُس زبردست تہٕ پننِس ذا تس منٛز پانہٕ محمود چُھ۔﴿حمید لفظ اگر چہ محمو د کُے ہم معنی چُھ، مگر دۅ شوٕ نۍ لفظن منٛز چھےٚ اکھ لطیف فر ق۔کٲنٛسہِ شخصس وَنو محمو د تَمی وقتہٕ ییٚلہِ زن تٔمۍ سُند تعر یف آسہِ کر نہٕ آمُت ، نَتہٕ آسہِ کر نہٕ یِوان، مگر حمید چُھ پٲنۍ پانے حمدُک ، خوا ہ کانٛہہ تٔمۍ سُند حمد کٔرِ تن یا متہٕ کٔرِ تن ﴾"
  14,2,"۔بیٚیہِ چُھ زمین تہٕ آسما ن کیٚن تمام مو جو داتن ہُند مٲلِک۔تہٕ سخت تبا ہ کر ن وول سزا چُھ حق نَہ مانن والیٚن خٲطرٕ ،"
  14,3,"۔یِم دُنیا چہِ زند گی چِھ ٲخرتس پٮ۪ٹھ تر جیح دِ وان، یِم اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ لُکن چِھ  رُکاوان، بیٚیہِ چِھ یژھان زِ یہِ وَتھ گٔژھ ﴿تِہند یو خوٲہشا تو مطا بق ﴾ۂج گٔژٕھنۍ، یِم لُکھ چِھ  گمرٲہی منٛز سٮ۪ٹھاہ دوٗر درٛامٕتۍ۔"
  14,4,"۔اسہِ ییٚلہِ تہِ پنُن پیغا م دِنہٕ خٲطرٕ کانٛہہ رسول سوٗز ،تٔمۍ دِیُت  پننہِ قو م چی زبٲنۍ منٛز پیغام۔تاکہ سُہ سمجھا وِ تِمن کتھ ٹھیک پٲٹھۍ ویٚژھنٲوِ تھ ،پتہٕ یَس اللہ تعالیٰ چُھ یژھان،تس چُھ گمراہ کران تہٕ یس یژھان چُھ تس چُھ ہدا یت بخشان،سُہ چُھ بالا دَست تہٕ حکمت وول۔"
  14,5,"۔اسہِ چُھ ییٚمہِ برونٛہہ مو سیٰ علیہ السلام تہِ پننہِ نشٲنِیہِ ہیٚتھ سوٗز مُت۔تس تہِ اوس اسہِ حکم دیتُمت زِ پنُن قو م اَنُن اَنہِ گٹو منٛزٕ کٔڑِ تھ گا شس منٛز،تہٕ تِمن کر تار یخِ الہٰی ہٕکۍ سبق آمو ز واقعا ت بو ز نٲوِ تھ نصیحت۔﴿  ایّا م  لفظ چُھ عر بی زبٲنۍ منٛز اصطلا حاً تو اریخی یاد گار کیٚن وا قعا تن خٲطرٕ وَننہٕ یِوان۔ایّام اللہ  نِشہِ چُھ مُراد انسٲنی تورایخٕکۍ تِم اہم باب ، یِمن منٛز خُدا ین پٔتِمیٚن زمانہٕ کیٚن قو من تہٕ بجن بجن شخصتین تِہٕندِ یٚو اعما لو لحا ظہٕ جزا یا سزا چُھ دِیتمُت﴾ یِمن واقعا تن منٛز چھےٚ نشٲنِیہِ پرٛتھ تس شخصس خٲطرٕ یُس صبر تہٕ شکر کر ن وول آسہِ۔﴿ یعنی یِم نِشٲنِیہِ چھےٚ پننہِ جایہِ  مو جود مگر یِمو نِشہِ فٲیدہ تُلُن چھےٚ صرف تِمن لُکن ہٕنز کٲم، یِم اللہ تعالیٰ سٕنز و آز مٲیشو نِشہِ صبرٕ سان تہٕ با مردی سان گُز رن وٲلۍ چِھ، تہٕ بیٚیہِ آسن اللہ تعالیٰ سٕنز ن نعمتن جان پٲٹھۍ محسو س کٔرِ تھ تِہُند صحیح شکر یہِ کر ن وٲلۍ۔﴾"
  14,6,"۔یاد کٔرِ و ییٚلہِ مو سیٰ ﴿علیہ السلامن ﴾ پننِس قو مس ووٚن  اللہ تعالیٰ سُند سُہ احسان تھٲوِ و یاد، یُس تٔمۍ تۅہیہِ پٮ۪ٹھ چُھ کوٚر مُت، تٔمۍ ترا و نٲوِنَو توٚہۍ فر عو ن والیٚن نِشہِ یلہٕ، یِم تۅہیہِ سخت تکلیف ٲسِو دِوان،تہٕ تُہٕندٮ۪ن لڑ کن ٲسۍ قتل کران، تہٕ تُہٕنز ن کو رٮ۪ن ٲسۍ زند ہ تھٲوِ تھ بچا وان، اتھ منٛزٲس تُہندِ س ربّ سٕندِ طر فہٕ تۅہیہِ بٔڑ آز مٲیش ۔ع۔"
  14,7,"۔تہٕ یاد تھٲوِ و تُہٕندۍ ربّن ٲسۍ خبردار کٔرِ مٕتۍ زِ ، اگر شُکر گُزار بٔنِو، تیٚلہِ کر و بہٕ تۅہیہِ بیٚیہِ زیادہ عطا، تہٕ اگر کُفر انِ نعمت ﴿نا شکر ی﴾ کٔرِ و ، تیٚلہِ چُھ میو ن سزا سٮ۪ٹھاہ  سخت۔"
  14,8,"۔ تہٕ مو سیٰ﴿علیہ السلامن﴾ ووٚن زِ اگر توٚہۍ کُفر کٔرِ و ،تہٕ زمینس پٮ۪ٹھ تمام روزن وٲلۍ تہِ سپد ن کٲفر، اللہ تعالیٰ چُھ بے نیاز تہٕ پننِس ذا تس منٛز چُھ پانہٕ محمود۔"
  14,9,"۔ کیا تۅہیہِ نِشہِ وٲتۍ نا تِمن قو من ہٕندۍ حالات ،یِم تۅہیہِ برونٛہہ چِھ گُزر یمٕتۍ۔؟﴿حضرت مو سیٰ علیہ السلامن ہُند تقر یر سپُد پٮ۪ٹھہٕ کنہِ ختم ، وۅ نۍ چُھ براہِ راست مکہٕ کیٚن کُفارن خطا ب شر وع سپدان۔﴾قومِ نو ح ، عاد ، ثمو د، تہٕ تِمن پتہٕ یِنہٕ وٲلۍ واریاہ قو م، یُہُند تعداد اللہ تعالیٰ سٕے معلو م چُھ؟ تِہندۍ رسول ییٚلہِ تِمن نِشہِ صا ف صاف کتھہٕ تہٕ ٹا کارٕ نشٲنیہِ ہیٚتھ آے، تِمو ہیٚتۍ پننیٚن  اَتھن ٲسن منٛز ژٔپۍ۔﴿ یہِ چِھ تِیُتھے اندازِ بیان یتھہٕ پٲٹھۍ أسۍ کٲشر ۍ پٲٹھۍ چِھ وَنان کنن تھوٚپ دِیُن یا دند ن تل اوٚنگٕج ژٕھنٕنۍ۔﴾ تہٕ ووٚ نکُھ زِ  یُس پیغام ہیٚتھ توٚہۍسوزنہٕ چِھو آمٕتۍ، أسۍ چِھنہٕ سُہ مانان، تہٕ ییٚمہِ چیزٕ چ توٚہۍ اسہِ دعوت چِھو دِوان، تمہِ طر فہٕ چِھ أسۍ تَتھ سخت شکس منٛز ہیٚنہٕ آمٕتۍ یُس دُل مُلِس منٛز چُھ ترٛاوان۔"
  14,10,"۔تِہند یٚو رسو لَو ووٚن،  کیا اللہ تعالیٰ سٕندِ س بارس منٛز چھا شک ،یُس آسما نن تہٕ زمینُک خٲلق چُھ؟ سُہ چُھو تۅہیہِ بُلاوان تاکہِ تُہٕندۍ قصور کرِ معا ف، تہٕ تۅہیہِ دِیو أکِس مقرر وقتس تام مہلت۔ تِمو دِیُت جواب توٚہۍ چِھو اَسہِ تِمن ۂستِیَن ہٕنز بند گی نِشہِ رُکا وٕ نۍ یژھان ،یِہٕنز بند گی مٲلِس بُڈِ بب سٕندِ وقتہٕ پٮ۪ٹھہٕ پکا ن چھےٚ روٗز مٕژ، اچھا ، أنِو کانٛہہ ٹا کارٕ سَند۔"
  14,11,"۔تِہند یٚو رسو لَو ووٚ ن تِمن ، پٔزِ پٲٹھۍ چِھنہٕ أسۍ کِہِنۍ مگر چِھ توٚہی ہِو ی انسان ۔البتہ پننیٚو بندو منٛزٕ یس اللہ تعالیٰ یژھان چُھ، تس چُھ نوازان، تہٕ یہِ چُھنہٕ سٲنِس اختیارس منٛز زِ تۅہیہِ خٲطرٕ اَنو کانٛہہ سَند ، سَند ہیکہِ اللہ تعالیٰ سٕندِ ی اِذ نہٕ سٍتۍ یِتھ، تہٕ اللہ تعالیٰ سٕے پٮ۪ٹھ پزِ اہلِ ایمانن بھر وسہٕ کرُن ۔"
  14,12,"۔تہٕ أسۍ کیا زِ کرَو نہٕ خُدا یس پٮ۪ٹھ بھر وسہٕ،ییٚلہِ زن سا نیٚن زند گی ہٕنز ن وَتن منٛز تٔمۍ اَسہِ رہنمٲیی چھےٚکٔر مٕژ؟یِم تکلیف توٚہۍ لُکھ اسہِ دِوان چِھو تِمن پٮ۪ٹھ کرو أسۍ صبر، تہٕ بھر وسہٕ کر ن والیٚن ہُند بھرو سہٕ  گژِھہ اللہ تعالیٰ سٕے پٮ۪ٹھ آسُن۔ ع"
  14,13,"۔ٲخر کار ووٚن انکار کرن والیو پننین رسولن زِیا آسیو تۅہیہِ سٲنِس ملّتس منٛز واپس یُن ،نتہٕ کڑو أسۍ توٚہۍ پننہِ ملکہٕ منٛزٕ۔﴿اَمِیُک مطلب چُھنہٕ یہِ زِ انبیا علیھمُ السلام  ٲسۍ نبوّت کِس منصبس پٮ۪ٹھ سر فراز سپد نہٕ برونٛہہ پننیٚن گُمرا ہ قو من ہٕندِ س مِلّتس  منٛزشٲمل آسان بلکہ چھُ اَمِیُک معنی یہِ زِ نبوت برونٛہہ ٲسۍ چونکہ تِم اکہِ قسمٕچ خاموش زندگی بسر کران،کُنہِ دینُک تبلیغ تہٕ کُنہِ رایج الوقت دینُک تردید ٲسۍ نہٕ کران۔اَمہِ موجوب اوس تِہُنٛد قوم یہِ سمجھان زِ تِم چھِ سٲنِس ملتس منٛز۔تہٕ نبوّتٕچ کٲم شروع کر نہٕ پتہٕ اوس تِمن پٮ۪ٹھ یہِ الزا م یِوان لگا و نہٕ زِ  تِم چھِ ملتِ آبایی منٛزٕ درامٕتۍ حالانکہ تِم ٲسۍ نہٕ نبوت برونٛہہ مشرکن ہٕندِس ملتس منٛز شٲمل آسان سپٕدۍمٕتۍ زِتمہِ منٛز نیرنُک الزا م ہیکہِ ہے تِمن پٮ۪ٹھ لٔگِتھ﴾ تمہِ پتہٕ سوٗز تِہندۍ ربّن تِمن پٮ۪ٹھ وحی زِ،  أسۍ کروکھ یِم ظٲلِم ہلا ک،"
  14,14,"۔تہٕ تِمن پتہٕ کرو توٚہۍ زمینس منٛز آباد،یہِ چُھ انعام تٔمۍ  سُند یُس میٲنِس در بارس منٛز جوا ب دہی ہُند خو ف آسہِ تھاوان، تہٕ میٲنِس وعیدس ﴿اعلانِ عذا بس﴾ آسہِ کھۅژان۔"
  14,15,"۔تِمو اوس فٲصلہٕ یوٚژھمُت﴿ پتہٕ سپُد تِہُند فٲصلہٕ یِتھہٕ پٲٹھۍ ﴾ تہٕ پرٛتھ کانٛہہ حقُک بُتھۍپھِیُرتہٕ ضد ی دشمن سپُد ناکام،"
  14,16,"۔پتہٕ چُھ اَمہِ پتہٕ برونٛہہ کُن تس خٲطرٕ جہنم ، تتہِ یِیہِ تس پُھٹہٕ رتھ ہیوٗ آب  چیٚنہٕ خٲطرٕ دِنہٕ،"
  14,17,"۔یتھ سُہ زبردستی ہَٹہِ بۅ ن والنٕچ کوٗشش کرِ تہٕ مُشکلنٕے ہیٚکہِ وٲلِتھ۔ پرٛتھ طر فہٕ روزِ مو ت تس پٮ۪ٹھ چھٲوِ تھ، مگر سُہ ہیٚکہِ نہٕ مٔرِ تھ، تہٕ برونٛہہ کُن روزِ اکھ سخت عذا ب تٔمۍ سٕندِ س زُوَس پٮ۪ٹھ لا گُو۔"
  14,18,"۔ یِمو لُکو پننِس ربّس سٍتۍ کُفر چُھ کوٚر مُت تِہنز ن عملن ہٕنز مِثا ل چھےٚ تتھ سوٗرس ہِش، یُس اکہِ طوٗفٲ نی دۅ ہ چہِ آند ھی آسہِ ﴿ ہوا ہس﴾ منٛز وُڈوو مُت﴿ یعنی  تِہٕنزٕ عملہٕ گژھن ضا یع﴾۔تِمن میلہِ نہٕ پننہِ کرِ میتُک رَژھ تہِ پھل۔یٔہے چھےٚ انتہٲیی ؤسۍ پا یچ گمرٲہی۔"
  14,19,"۔کیا توٚہۍ چِھو نا وُچھان زِ خُدا ین چھےٚ آسمان وز مینٕچ تخلیق حقس پٮ۪ٹھ قٲیِم کٔر مٕژ؟ہر گاہ سُہ ییژِھہ تیٚلہِ نِیو تۅہیہِ لُکن، تہٕ نٔو اکھ خلقت اَنہِ تُہنزِ جایہِ ۔"
  14,20,"۔یہِ کرُن چُھنہٕ تٔمۍ سٕندِ خٲطرٕ رَژھ تہِ دُشوار۔"
  14,21,"۔تہٕ ییٚلہِ یِم لُکھ یِکہٕ وٹہٕ خُدا یس برونٛہہ کنہِ بے نقا ب گژھن،تمہِ وقتہٕ یِم یِمو منٛز دُنیا ہس منٛز کمز ور ٲسۍ ،تِم وَنن تِمن لُکن یِمن دُنیا ہس منٛز پننہِ بجرُک تکبر اوس،  دُنیا ہس منٛز ٲسۍ أسۍ تۅہیہِ تٲبع، کیا توٚہۍ ہیٚکِوٕہ وۅ نۍ اللہ تعالیٰ سٕندِ عذا ب نِشہِ اَسہِ بچا و نہٕ خٲطرٕ تہِ کینٛہہ کٔرِ تھ؟تِم دِن جواب اگر خُدا ین اَسہِ نجا تٕچ کانٛہہ وتھ ہٲو مٕژ آسِہے، تیٚلہِ ہاوٕ ہَو أسۍ تۅہیہِ ضرور، وۅ نۍ چھےٚ ہِشی کتھا خوا ہ أسۍ بُتھہِ بُتھہِ دِمَو یا کرَو صبر، بہر حال چَھنہٕ سانہِ بچنٕچ کانٛہہ صور ت۔ ع"
  14,22,"۔تہٕ ییٚلہِ فٲصلہٕ کر نہٕ یِیہِ ، پتہٕ وَنہِ شیطا ن،  حقیقت چھےٚ یہِ زِ خُدا ین یِم  وعدہ تۅہیہِ سٍتۍ کٔرِ مٕتۍ ٲسۍ ، تِم سٲر ی ٲسۍ پٔزۍ، تہٕ مےٚ ییٖتیاہ وعدہ کٔرۍ، تِمو منٛزٕ کوٚرُم نہٕ کِہِنۍ تہِ پوٗرٕ،کانٛہہ زور اوسنہٕ میو ن تۅہیہِ پٮ۪ٹھ، مےٚ کوٚر نہٕ امہِ ورٲے کِہِنۍ زِ پننہِ وَتہِ کُن دِژمَو تۅہیہِ دعوت، تہٕ تۅہیہِ ووٚ نُو میٲنِس دعوتس پٮ۪ٹھ لبیک ،وۅ نۍ مَہ کٔرِو مےٚ ملا مت، پننِس پا نسٕے کٔرِو ملامت،ییٚتہِ نَہ ہیکو بہٕ تۅہیہِ فر یاد رسی ﴿اتھہٕ روٚٹ﴾ کٔرِ تھ،تہٕ نہ ہیٚکِو توٚہۍ میٲنۍ فر یاد رسی کٔرِ تھ ییٚمہِ برونٛہہ یُس بہٕ تۅہیہِ خُدٲیی منٛز شر یک بنو و مُت اوسوٗس،بہٕ چُھس تَمہِ نِشہِ بر ی﴿یہِ کتھ چھےٚ ظٲہر زِ شیطا نس نہ چُھ کانٛہہ اعتقٲدی حیثیتہٕ خُدٲیی منٛز شر یک ٹھہرٕ اوان، تہٕ نہٕ چُھ کانٛہہ تٔمۍ سٕنز پر ستش کران۔سٲر ی چِھ تس پٮ۪ٹھ لعنتٕے سوزان۔البتہ چھےٚ تٔمۍ سٕنز اطا عت تہٕ غلٲمی تہٕ تٔمۍ سٕندِ طر یقٕچ أچھ ٹُوِتھ یاز ٲنِتھ پیر وی یِوان ضروٗر کر نہٕ، تہٕ یۅ ہے چُھ یتھ جایہِ شر ک کِس لفظس سٍتۍ  تعبیر آمُت کر نہٕ ﴾ یِتھیٚن ظٲلِمن خٲطرٕ چُھ بے شک دگ تُلوُن سزا۔"
  14,23,"۔اتھ برعکس یِمو لُکو دُنیا ہس منٛز ایمان چُھ اوٚ نمُت ،تہٕ یِمو نیک عملہٕ چھےٚ کرِ مَژٕ،تِم یِن تِتھیٚن با غن منٛز دٲخل کر نہٕ  یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان۔پننِس ربّ سٕندِ اِذ نہٕ سٍتۍ روزن تِم تتہِ ہمیشہِ ، تہٕ تتہِ سپدِ تِہُند استقبال سلامتی ہٕندِ مبا رک باد سٍتۍ۔"
  14,24,"۔کیا توٚہۍ چِھو ناوُچھان زِ خُدا ین کتھ چیز س سٍتۍ چھےٚ کلمۂ طیبہ ہٕچ مِثا ل دِژ مٕژ؟ اَمِچ مِثا ل چھےٚ تِژھ زَنتہٕ اکھ جان ذٲژ ہُند کُل ییٚمِکۍ موٗل زمینس اندر سٔنۍ چِھ لٔگِتھ،تہٕ شا خ چِھ آسما نس تام وٲتِمٕتۍ،"
  14,25,"۔پرٛتھ وقتہٕ چُھ سُہ پننِس ربّ سٕندِ حُکمہٕ سٍتۍ پھل دِوان، یِمہٕ مِثا لہٕ چُھ اللہ تعالیٰ امہِ موجو ب دِوان زِ لُکھ رَٹن یِمو نِشہِ سبق۔"
  14,26,"۔تہٕ کلمۂ خبیثہ ہٕچ مِثال چھےٚ، اکہِ بدذات کُلِچ ہِش ، یُس زمین کہ سطح پٮ۪ٹھہٕ کٔڑِتھ دوٗر چُھ یِوان چھکنہٕ، تتھ خٲطرٕ چُھنہٕ کانٛہہ استحکام۔"
  14,27,"۔ایمان اَنن والیٚن چُھ اللہ تعالیٰ أکِس ثٲبت قو ل کِس بنیا دس پٮ۪ٹھ دنیا تہٕ ٲخرت، دۅ شوٕ نۍ منٛز ثٲبت قد می عطا کران، تہٕ ظٲلِمن چُھ اللہ تعالیٰ گُمرا ہ کران، خُدا یس چُھ اختیار یہِ ییٚژِھہ تہِ کرِ ۔ ع"
  14,28,"۔تۅہیہِ وُچھوٕ ہ تِم لُکھ یِمو اللہ تعالیٰ سٕنز نعمت کٔر حٲصل تہٕ سۅ بدلٲوٕکھ کُفر انِ نعمت ﴿یعنی نا شکر ی﴾ سٍتۍ، تہٕ ﴿پا نس سٍتۍ﴾ ژُھنُکھ پنُن قو م تہِ ہلا کت کِس گھرس منٛز،"
  14,29,"۔یعنی جہنمس ، یتھ منٛز تِمن مٕسلہٕ وَسہِ ،"
  14,30,"۔تہٕ سۅ چھےٚ بد تر ین روزن جاے۔ بیٚیہِ کٔرِ کھ اللہ تعالیٰ سٕندۍ کینٛہہ شر یک تجو یز، تاکہِ تِم ڈا لن یِمن  اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ؟یِمن ؤنِو ، اچھا کٔرِ و عٲش، ٲخر کار چُھو تۅہیہِ پوٚت پھیرِ تھ گژھن جہنمسٕے منٛز۔"
  14,31,"۔ اے نبی صلی اللہ علیہ وسلم،میا نیو یِمو بندو ایمان چُھ اوٚنمُت،تِمن ؤنِو زِ نماز کٔرِ ن قٲیِم ، تہٕ یِکینژھاہ اسہِ تِمن دِ یتمُت چُھ تمہِ منٛزٕ کٔرِن نَنہِ وانہٕ پٲٹھۍ تہٕ ژھایہِ پٲٹھۍ ﴿ خیر چہِ وتہِ اندر﴾خر چ، امہِ برونٛہہ زِ سُہ دۅہ واتہِ یتھ منٛز نہ ہیوٚن کٕنُن آسہِ ، تہٕ نہ سپدِ یار برادر ی۔"
  14,32,"۔اللہ تعالیٰ چُھ سُے ییٚمۍ زمین تہٕ آسمان پٲدٕ کٔرۍ ، تہٕ آسما نہٕ وولُن آب، پتہٕ کٔرِ ن تمہِ ذر یعہ تُہنزِ رزق رسٲنی خٲطرٕ قٔسمہٕ قسمٕکۍ پھل پٲدٕ،ییٚمۍ ناو تُہٕندِ خٲطرٕ مُسّخر کٔر، تاکہ سمندرس منٛز پکہِ تٔمۍ سٕندِ حکمہٕ، تہٕ در یاوِ کٔرِن تُہندِ خٲطرٕ مُسّخر۔"
  14,33,"۔ییٚمۍ آفتا ب تہٕ زوٗن تُہندِ خٲطرٕ مُسّخر کٔر زِ لگاتار چھِ پکا ن روزان، تہٕ رات تہٕ دۅہ کوٚرُن تُہندِ خٲطرٕ مُسّخر۔﴿تُہندِ خٲطرٕ کوٚرُن مُسّخر۔ عام طور چِھ لُکھ یِمن لفظن غلطی کِنۍ تا بع کر نہٕ کِس معنیس منٛز نِوان ،تہٕ پتہٕ چِھ ییٚمہِ مضمو ن کیو آیا تَو نِشہِ عجیب عیجب قسمٕکۍ معنی پٲدٕ کر نہِ لگا ن ۔ حتیٰ کہ کینژھو لُکو چُھ یتھ حدس تام سمجھمُت زِ یِمن آیا تن ہٕندِ مددٕ چُھ تسّخیرِ سٰموٰت وارض انسان سٕندِ مقصدُک انتہا۔حالانکہ انسان سٕندِ خٲطرٕ یِمن چیز ن ہٕندِ مُسّخر کر نُک مطلب چُھنہٕ امہِ ورٲے کِہِنۍ زِ خُدا ین چِھ یِم تِتھیٚن قا نو نن ہٕندۍ پا بند بنٲوِ تھ تھٲوِ مٕتۍ یِہندِ بد و لتہٕ یِم انسان سٕندِ خٲطرٕ فٲیدہ مند چِھ بنیمٕتۍ۔﴾"
  14,34,"۔ییٚمۍ تۅہیہِ تہِ سورُے کینٛہہ دِیتُنَو یہِ تۅہیہِ تَس موٚنگُو ﴿یعنی تُہندِ فطر تٕچ پرٛتھ کانٛہہ منگ کٔرٕن پوٗزٕ ،تُہنزِ زند گی خٲطرٕ یِکینژھاہ مطلو ب اوس تہِ کورنَو مہیا ، تُہندِ بقا تہٕ ارتقا خٲطرٕ یِمن یِمن وسٲیلن ہٕنز ضرورت ٲس تِم سٲر ی کٔرِ نو فر اہم۔﴾ اگر توٚہۍ اللہ تعالیٰ سٕنز ن نعمتن ہُند شمار ییژِھو کرُن، کِہِنۍ ہیٚکِو نہٕ کٔرِ تھ۔ حقیقت چھےٚ یہِ زِ انسان چُھ سٮ۪ٹھہٕے بے انصا ف تہٕ نا شکُر گُزار۔ع"
  14,35,"۔یادکٔرِو سُہ وقت ییٚلہِ ابراہیم ﴿علیہ السلامن﴾ دُعا اوس کوٚر مُت زِ پروردگار، یہِ شہر ﴿یعنی مکّہ﴾ بناوُن اَمنُک شہر، تہٕ بہٕ تہٕ میٲنۍ اولاد بچا وُکھ بُت پرستی نِشہِ ۔"
  14,36,"۔پروردِگار ، یِمو پۅ تلیو چِھ واریاہ گُمرٲہی منٛز ترٲوِمٕتۍ﴿بنان چُھ زِ میا نیٚن اولادن تہِ کر ن یِم گُمراہ ، لہٰذا تِمو منٛزٕ﴾ یُس میٲنِس طر یقس پٮ۪ٹھ پکہِ سُہ چُھ میو ن، تہٕ یُس مےٚ خلا ف طر یقہ اختیارکرِ،تیٚلہِ چُھکھ ژٕ پٔزِپٲٹھۍ در گُزر کر ن وول مہر بان۔"
  14,37,"۔پروردگارٕ ، مےٚ چُھ أکِس بے زراعت وادی منٛز پننیٚن اولادن ہُند اکھ حصّہٕ چٲنِس محتر م گھرس نِشہِ أنِتھ بسو و مُت، پروردگارٕ ، یہِ چُھ مےٚ امہِ خٲطرٕ کوٚر مُت زِ یِم لُکھ کر ن ییٚتہِ نماز قٲیِم،لہٰذا کر ژٕ لُکن ہٕندۍ دِل یِمن کُن مٲیل، تہٕ یِمن دِ کھیٚنہٕ خٲطرٕ پھل، بنان چُھ یِم بنن شُکر گُزار۔"
  14,38,"۔ پروردگارٕ ، ژٕ چُھکھ زانان یِکینژھاہ أسۍ کھٔٹِتھ تھاوان چِھ ، تہِ یِکینژھاہ نوٚن چِھ کڑان۔ تہٕ پٔزِ پٲٹھۍ چُھنہٕ خُدا یس نِشہِ کِہِنۍ تہِ چُھپِتھ،نَہ زمینس منٛز تہٕ نَہ آسما نن منٛز ۔"
  14,39,"۔ شکر چُھ تس اللہ تعالیٰ سُند ییٚمۍ مےٚ یتھ بُجرس منٛز اسما عیل علیہ السلام تہٕ اسحا ق علیہ السلام ہِوۍ فر زند دِتۍ،حقیقت چھےٚ یہِ زِ میو ن ربّ چُھ دُعا ضرور بوزان ۔"
  14,40,"۔ اے میانہِ پروردگارٕ ، مےٚ بناو نماز قٲیم کر ن وول، تہٕ میا نیو اولادَو منٛزٕ تہِ ﴿تُلکھ تِم لُکھ یِم یہِ کٲم کر ن ﴾ پروردگارٕ، میو ن دُعا کر قبول۔"
  14,41,"۔پروردگارٕ، مےٚ تہٕ میا نیٚن والد ینن تہٕ سارِنٕے ایمان والیٚن کر تمہِ دۅہ مغفرت ییٚلہِ حسا ب قٲیِم سپدِ ۔ ع ﴿حضرت ابراہیم علیہ السلامن اوس اتھ دُعا ے مغفرتس منٛز پنُن مو ل اتھ وعدٕہ کِس بنیا دس پٮ۪ٹھ شر یک کوٚر مُت یُس تِمو وطنہٕ منٛزٕ نیر نہٕ وقتہٕ کوٚر مُت اوس، سَاَستَغفِرُلَکَ رَبِّی﴿مر یم آیت نمبر 47﴾ مگر پتہٕ ییٚلہِ تِمن احسا س سپُد زِ سُہ اوس اللہ تعالیٰ سُند دشمن پتہٕ چِھ تِم تِمن بے راز سپدان۔ ﴿التو بہ آیت نمبر  114﴾۔"
  14,42,"۔وۅ نۍ یِکینژھا ہ یِم ظٲلِم لُکھ کران چِھ، توٚہۍ مَہ سمجھوٗن اللہ تعالیٰ تَمہِ نِشہِ غٲفل، اللہ تعالیٰ چُھ یِمن ٹالان تمہِ دۅہ خٲطرٕ،ییٚلہِ یہِ حال آسہِ زِ أچھ آسن پھٔٹِتھ درٛا مژٕ،"
  14,43,"۔کلہٕ تھوٚد تُلِتھ آسن ژلان، نظرٕ آسنکھ پٮ۪ٹھ کُن رونٛٹہٕ گٔمژٕ،تہٕ دِل آسنکھ ﴿خو ف سٍتۍ﴾ راوان۔"
  14,44,"۔اے نبی صلی اللہ علیہ وسلم،تمہِ دۅ ہ نِشہِ کھۅژنٲوِیوٗکھ توٚہۍ یِم ییٚلہِ عذا ب رٹہِ یِمن،تمہِ وقتہٕ وَنن یِم ظٲلِم زِ ، اے سانہِ ربّہٕ ،اسہِ دِرَژھ کھنڈ بیٚیہِ مہلت، أسۍ وَنو چٲنِس دعوتس لبیک ،بیٚیہِ کرَو رسولن ہٕنز پیر وی۔﴿مگر یِمن یِیہِ صاف جوا ب دِنہٕ زِ ﴾ کیا توٚہۍ چِھو نا تِمے لُکھ یِم ییٚمہِ برونٛہہ قسم کھیے کھیے ونان ٲسۍ زِ، اَسہِ پٮ۪ٹھ چُھنہٕ زو الس یُنُے زانٛہہ؟"
  14,45,"۔حالانکہ توٚہۍ ٲسِو تِمن قو من ہٕنز ن بٔستِین  منٛز روٗدِمٕتۍ ،یِمو پننِس پا نس پٮ۪ٹھ ظلم اوس کوٚر مُت، تہٕ وُچھمُت اوسُو زِ اَسہِ کیا سلو ک کوٚر تِمن سٍتۍ، تہٕ تِہنزٕ مِثا لہٕ دی دی ٲسِو اَسہِ توٚہۍ سمجھا وِ مٕتۍ تہِ ۔"
  14,46,"۔تِمو چلا وِ پننہِ سار ے چالہٕ، مگر تِہنزِ پرٛتھ چالہِ ہُند توٚڑ اوس خُدا یس نِشہِ ، اگر چہِ تِہنزٕ چالہٕ تِژٕھہ غضب چہِ آسہٕ، زِ پہاڑ ہیکہن تِمو سٍتۍ ٹٔلِتھ۔"
  14,47,"۔پس اے نبی صلی اللہ علیہ وسلم ،توٚہۍ مَہ کٔرِ و ہر گز یہِ گُما ن زِ اللہ تعالیٰ کرِ زانٛہہ پننیٚن رسولن سٍتۍ کر نہٕ آمتیٚن وعدن خلا ف، اللہ تعالیٰ چُھ زبردست تہٕ بیٚیہِ چُھ اِنتقام ہیٚنہٕ وول۔"
  14,48,"۔کھۅژنٲوِ یوٗکھ یِم تمہِ دۅہ نِشہِ ییٚلہِ زمین تہٕ آسمان بدلٲوِتھ کتہِ کور یِن واتنا و نہٕ۔﴿ ییٚمہِ آیت نِشہِ تہٕ قرآن کیو دوٚیِمیٚو اِشارَو سٍتۍ چُھ پے لگا ن زِ قیا متس منٛز گژھن نہٕ زمین و آسمان با لکل نیست و نا بود بلکہ یِیہِ مو جودٕ طبیعی نظا م در ہم بر ہم کر نہٕ، امہِ پتہٕ یِیہِ نفخِ صورِ اوّل ﴿ یعنی صورس گۅڈنِیُک پھۅکھ دِنہٕ پٮ۪ٹھہٕ﴾ تہٕ نفخِ صورِ ٲخر ﴿ یعنی صورس دوٚیُم پھۅ کھ دِ نس ﴾ در میان أکِس خا ص و قتس منٛز، یتھ اللہ تعالیٰ ہٕے چُھ زانان، زمینٕچ تہٕ آسما نن ہٕنز موجودٕ ہ ہیت بد لاو نہٕ، تہٕ پتہٕ یِیہِ بیاکھ اکھ نظا م با قی فطرت کیو قا نُو نَو سان بنا و نہٕ۔ سُے آسہِ عا لِم ٲخرت ۔پتہٕ یِن نفخِ صورِ ٲخر ﴿ یعنی صورُک ٲخری پھۅ کھ ﴾  دِنس سٍتی تِم انسان یِم آدم علیہ السلام سٕندِ تخلیق پٮ۪ٹھہٕ قیا متس تام پٲدٕ ٲسۍ سپدِ مٕتۍ ،نوِ سرٕ زند ہ کر نہٕ تہٕ سپد ن  اللہ تعالیٰ سٕندِس در بارس منٛز پیش ،قرآن چہِ زبٲنۍ منٛز چُھ امہِ کُے ناو حشر ییٚمیُک لُغوی معنی چُھ وَٹُن تہٕ جمع کرُن۔﴾  تہٕ اند ہیٚتھ گژھن سٲر ی اللہ وا حد القہا رس برونٛہہ کنہِ بے نقا ب حٲضر۔"
  14,49,"۔ تمہِ دۅہ وُچھوٗ کھ توٚہۍ مُجر م زِ ہا نکلن منٛز آسن اتھہٕ کھۅر گٔنڈِتھ،"
  14,50,"۔تار کو لٕکۍ پلو آسنکھ لٲگِتھ، تہٕ نارٕکۍ شعلہ آسن تِہند یٚن بُتھیٚن وَلنہٕ یِوان۔"
  14,51,"۔یہِ اسہِ امہِ موجوٗب زِ اللہ تعالیٰ دِیہِ پرٛتھ نفسَس تٔمۍ سٕندِ کرِ متیُک بد لہٕ۔خُدا یس چَھنہٕ حسا ب ہیٚنس زیادٕہ  تٲر لگان۔"
  14,52,"۔ یہِ چُھ اکھ پیغا م سارِنٕے انسانن خٲطرٕ، تہٕ یہِ چُھ سوز نہٕ آمُت امہِ موجوٗب زِ یِم گژھن امہِ کہ ذر یعہ خبردار یِنۍ کر نہٕ، تہِٕ یِم گژھن زانٕنۍ  زِ در حقیقت چُھ خُدا ے بس اَکو ے،تہٕ یِم عقل چِھ تھاوان تِم  گژھن ہو شس منٛز یِنۍ۔ ع"
