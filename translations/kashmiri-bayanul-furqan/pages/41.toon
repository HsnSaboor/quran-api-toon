quran[54]{c,v,t}:
  41,1,"۔حٰ ۔ م،"
  41,2,"۔یہِ چُھ خُداے رحمٰن و رحیم سٕندِ طر فہٕ نٲزِل کر نہٕ آمُت چیز،"
  41,3,"۔اکھ کتا ب ییٚمکۍ آیات وارٕ پٲٹھۍ ویٚژھنٲوِ تھ چِھ آمٕتۍ بیان کر نہٕ، عر بی زبٲنۍ ہُند قرآن،تِمن لُکن خٲطرٕ یِم علم چِھ تھا وان،"
  41,4,"۔ بشا رت دِنہٕ وول تہٕ کھۅژنا وَن وول۔مگر یِمو لُکو منٛزٕ پِھیُر اکثر و اَمہِ نِشہِ بُتھ ،لہٰذا چِھنہٕ تِم بوزان۔"
  41,5,"۔وَنان چِھ  یتھ چیز س کُن ژٕ اَسہِ بُلاوان چُھکھ، تمہِ چیز خٲطرٕ چِھ سا نیٚن دِلن پٮ۪ٹھ پردٕ ہ پیٚمٕتۍ، سٲنۍ کن چِھ زٔرۍ گٔمٕتۍ، بیٚیہِ چُھ اسہِ تہٕ ژےٚ در میان اکھ پردٕہ حٲیل گوٚ مُت۔ژٕ کر پنٕنۍ کٲم، أسۍ روزَو پنٕنۍ کٲم کران۔"
  41,6,"۔اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو ،بہٕ چُھس اکھ بشر تۅہی ہِیوٗ۔مےٚ چُھ وَحی ہٕنٛدِ ذریعہ وننہٕ یِوان زِ چو ن خُدا چُھ بس اَکو ے خدا،لہٰذا کر ژٕ سِیٚود تٔمۍ سٕے کُن رۅ خ تہٕ تس منٛگ معٲفی۔"
  41,7,"۔تبا ہی چھےٚ تِمن مُشرِ کن یِم زکوٰتہ چِھنہٕ دِوان، تہٕ ٲخرتس چِھ انکار کران۔"
  41,8,"۔روٗدۍ تِم لُکھ یِمو ایمان اوٚن تہٕ نیک عملہٕ کرَیٛکھ ، تِہِندِ خٲطرٕ چُھ یقیناً تِیُتھ اجر ییٚمیُک سلسلہٕ زانٛہہ چُھنہٕ پھُٹن وول ۔ع"
  41,9,"۔اے نبی صلی اللہ علیہ وسلم ،یِمن ؤنِو ،کیا توٚہۍ چِھوٕ تس خُدایس سٍتۍ کُفر کران تہٕ با قی چھوٗکھ تٔمۍ سٕندۍ شر یک ٹھٔہراوان ییٚمۍ زمین بنٲو دۅ ن دۅ ہن منٛز؟سُے چُھ سارِنٕے عا لمن ہُند ربّ۔"
  41,10,"﴿زمین و جو دس منٛز اَننہٕ پتہٕ ﴾ جمٲوۍ تٔمۍ اَتھ پٮ۪ٹھ پہا ڑ،تہٕ اَتھ منٛز تھا وٮ۪ن بر کتہٕ، تہٕ اَتھ اندر کوٚرُن سارِنٕے منگن والیٚن خٲطرٕ پرٛتھ أکۍ سٕندِ طلب و حا جت مطٲبق ٹھیک اندازٕہ سان خۅ راکُک سامان فرا ہم ﴿ یعنی تِمن تمام مخلو قا تن خٲطرٕ یِم خۅ را کٕکۍ طٲلب ٲسۍ﴾ یِمہٕ سارے کامہِ سپزٕ ژۅن دۅ ہن منٛز۔"
  41,11,"۔پتہٕ سپُد سُہ آسما نس کُن متو جہ ﴿اَتھ چُھنہٕ یہِ مطلب زِ زمین بناونہٕ پتہٕ تہٕ اَتھ منٛز آبٲدی ہُند انتظا م کر نہٕ پتہٕ بنٲوۍ تٔمۍ آسمان۔یتھ جایہِ چُھنہٕ لفظ پتہٕ  زمٲنی تر تیبہ خٲطرٕ کینٛہہ بلکہ چُھ بیٲنی تر تیبہ خٲطرٕ استعمال سپُد مُت۔امہِ پتہٕ کہ فقرٕ ہ سٍتۍ چھےٚ یہِ کتھ وا ضح سپدان﴾یُس تمہِ ساعتہٕ محض دٕہ اوس۔تٔمۍ ووٚن آسما نس تہٕ زمینس  وجودس منٛز یِیِو، خواہ توٚہۍ ییٚژھۍ تَو یا متہٕ ییٚژھۍ تَو۔ دۅشوٕ یَو ووٚ ن  أسۍ آے فر ماں بردارن ہٕندۍ پٲٹھۍ ﴿وجودس منٛز ﴾۔"
  41,12,"۔تمہِ پتہٕ بنٲوۍ تٔمۍ دۅ ن دۅ ہن منٛز ستھ آسمان، تہٕ پرٛتھ آسما نس منٛز کوٚرُن وحی تمِیُک قا نو ن ﴿ یعنی تِم کِتھہٕ پٲٹھۍ کر ن پنٕنۍ کٲم ﴾۔تہٕ دُنیا ہُک آسما ن کوٚر اَسہِ ژانگیو سٍتۍ آرا ستہٕ تہٕ یہِ کوٚر وارٕ پٲٹھۍ محفوظ۔ یہِ سورُے چُھ أکِس زبردست زانن وا جِنہِ ہستی ہُنٛد منصو بہٕ۔"
  41,13,"۔وۅ نۍ اگر یِم لُکھ بُتھ چِھ پھِران، تیٚلہِ ؤنِو یِمن زِ بہٕ چُھسَو توٚہۍ تمی آیہِ کہ اکہِ اچا نک یِنہٕ والہِ عذا ب نِشہِ کھۅژناوان، یُتھ عاد تہٕ ثمو دس پٮ۪ٹھ نٲزِل اوس سپُد مُت۔"
  41,14,"۔ییٚلہِ خُداے سٕندۍ رسول تِمن بروٗنٹھۍ کِنۍ تہٕ پٔتۍ کِنۍ ، پرٛتھ طر فہٕ آے تہٕ تِم سمجھجٲوِ کھ زِ، خُدایس ورٲے مَہ کٔرِو کٲنٛسہِ ہِنز بند گی،پتہٕ ووٚ ن تِمو  اگر سۅ ن ربّ ییٚژِھہ ہے تیٚلہِ سوزِ ہے فرشتہٕ،لہٰذا چِھنہٕ أسۍ سۅ کتھ مانان ییٚمہِ خٲطرٕ توٚہۍ سوزنہٕ چِھو آمٕتۍ۔"
  41,15,"۔عادُک حا ل اوس یہِ زِ کُنہِ حقہٕ ورٲے بنے تِم زمینس منٛز زٕٹھۍ ﴿ تکبر کوٚرُکھ ﴾،تہٕ وَننہٕ لٔگۍ کُس چُھ سا نہِ کھۅتہٕ زیادٕہ زور آور۔ تِمن توٚ ر نہٕ یہِ فِکرِ زِ ییٚمۍ خُدا ین تِم پٲدٕ چِھ کٔرِ مٕتۍ ، سُہ چُھ تِہندِ کھۅتہٕ زیادٕہ زور آور ؟ تِم روٗدۍ سا نیٚن آیا تن بس انکار کران،"
  41,16,"۔ٲخر کار سوٗز اَسہِ کینٛژھن منحوس دۅہن منٛز تِمن پٮ۪ٹھ سخت طوفٲنی ہوا، تاکہِ تِم وُچھنا ووکھ دُنیا چی زند گی منٛز ذلت تہٕ رُسوٲیی ہُند مٕز ہ ، تہٕ ٲخرتُک عذا ب چُھ امہِ کھۅتہٕ تہِ زیادٕہ رُسواکرن وول،تَتہِ آسہِ نہٕ کانٛہہ یِمن مدد کر ن وول ۔"
  41,17,"۔روٗدۍ وۅ نۍ ثمود ،تِمن برونٛہہ کنہِ کٔر اَسہِ سِیٔز وتھ پیش، مگر تِمو کوٚر وَتھ وُچھِنہٕ بجا ے اوٚ ن روز نُے پسند ، ٲخر آو تِہندیو کر توٗ تَو ہٕندِ بد و لتہٕ تِمن پٮ۪ٹھ عذا ب،"
  41,18,"۔تہٕ اَسہِ بچٲوۍ تِم لُکھ یِمو ایمان اوس اوٚ نمُت ،بیٚیہِ ٲسۍ گمرٲہی تہٕ بد عملی نِشہِ پر ہیز کران ۔ع"
  41,19,"۔بیٚیہِ کٔرِتَو ذرا تمہِ وقتُک خیال ییٚلہِ یِم اللہ تعالیٰ سٕندۍ دشمن جہنمس کُن گژھنہٕ خٲطرٕ گھیرٕ کٔرِ تھ یِن اَننہٕ۔﴿اَصلی مُدعا چُھ وَننُک یہِ زِ ییٚلہِ تِم اللہ تعالیٰ سٕندِس عدالتس منٛز پیش سپدنہٕ خٲطرٕ گھیرٕ کٔرِ تھ اَننہٕ یِن ، البتہ یہِ مضمو ن چُھ یِمن لفظن منٛز بیان کر نہٕ آمُت زِ جہنمس کُن گژھنہٕ خٲطرٕ یِن گھیرٕ کٔرِتھ اَننہٕ تِکیازِ یُہُند انجام چُھ ٲخر کار جہنم سٕے منٛز گژُھن﴾ تِہندۍ بروٗنٹھم یِن پٔتِمیٚن ہٕندِس یِنَس تام پتھ کُن رُکاو نہٕ ،﴿ یعنی یہِ سپدِ نہٕ زِ اکہِ اکہِ نسلُک تہٕ اکہِ اکہِ پیٖرِ ہُند حسا ب ہیٚنہٕ پتہٕ یِیہِ تَمِیُک فٲصلہٕ کر نہٕ ، بلکہ یِن تمام پٔتِم بروٗنٹھم نسل بیک وقت جمع کر نہٕ تہٕ سارِنٕے یِیہِ یِکہٕ وَٹہٕ حسا ب ہیٚنہٕ،تِکیازِ پرٛتھ نسل کِس نیک یا بد آسنس منٛز چُھ تَمہِ بروٗنٹھمہِ نسل کہ ترٛاونہٕ آمتہِ دینی تہٕ اَخلٲقی میر اثُک حصّہ شٲمِل آسان۔﴾"
  41,20,"۔پتہٕ ییٚلہِ سٲری تو رواتن، تِہِندۍ کن تہٕ تِہنزٕ أچھ تہٕ تِہندِ جسمٕکۍ مٕسلہٕ دِن تِمن پٮ۪ٹھ گوٲہی زِ تِم کیا کینٛژھاہ چِھ روٗدِ مٕتۍدُنیا ہس منٛز کران"
  41,21,"۔تِم وَنن پننہِ جسم کیٚن مٕسلن تۅہیہِ کیازِ دِژٕ و اسہِ خلا ف گوٲہی؟تِم دِن جواب  اَسہِ دِیُت تٔمی خُداین بولنُک طا قت ییٚمۍ پرٛتھ کانٛہہ چیز بولن وول چُھ بنو و مُتتٔمی ٲسِو توٚہۍ گۅڈنِچہِ پھِرِ پٲدٕ کٔرِ مٕتۍ، تہٕ وۅ نۍ چِھو توٚہۍ تٔمۍ سٕے کُن واپس اَننہٕ یِوان۔"
  41,22,"۔توٚہۍ ییٚلہِ دُنیا ہس منٛز جُرُم کر نہٕ وقتہٕ چُھپان ٲسِو ، تۅہیہِ اوسُو نہٕ یہِ خیال زِ کُنہِ ساعتہٕ دِن تُہٕندۍ پنٕنۍ کن تہٕ تُہنزٕ أچھ تہٕ تُہندِ جسمٕکۍ مٕسلہٕ تۅہیہِ پٮ۪ٹھ گوٲہی۔بلکہِ اوسُو تۅہیہِ یہِ سمجھمُت زِ تُہٕندٮ۪ن واریا ہن اعما لن ہٕنز چَھنہٕ خُدایس تہِ خبر۔"
  41,23,"۔تُہٕندۍ أمی گُما نن یُس تۅہیہِ پننِس ربّس سٍتۍ کوٚر مُت اوسُو، ڈُبٲوِ نَو توٚہۍ،تہٕ اَمی بدولت گٔو توٚہۍ خسا رس منٛز۔"
  41,24,"۔اتھ حا لتس منٛز کٔرِ تن تِم صبر ﴿ یا متہٕ کٔرِ تن﴾ نارٕے آسہِ تِہُند ٹھکا نہٕ ،تہٕ اگر رجُوعُک موقع یژھن ،کانٛہہ موقع یِیہِ نہٕ تِمن دِنہٕ ۔"
  41,25,"۔اَسہِ ٲسۍ تِمن پٮ۪ٹھ سٲتھی مُسلّط کٔرِ مٕتۍ، یِم تِمن پٔتۍ کِنۍ بروٗنٹھۍ کِنۍ پرٛتھ کانٛہہ چیز ٲسۍخۅش کر وُن بنٲوِ تھ ہاوان، ٲخر کاروٗ د تِمن پٮ۪ٹھ تہِ سُے عذا بُک فٲصلہٕ چسپاں سپدِ تھ، یُس تِمن بروٗنٛہہ گُزر یمتیٚن جِنّن تہٕ انسانن ہٕند ٮ۪ن گروہن پٮ۪ٹھ چسپاں سپُد مُت اوس، یقیناً ٲسۍ تِم خسارس منٛز روزن وٲلۍ۔ع"
  41,26,"۔یِم منکر ینِ حق چِھ ونان، یہِ قرآن مَہ بوٗزِ و ہر گز، تہٕ ییٚلہِ یہِ بوزناو نہٕ یِیہِ تیٚلہِ ترٛٲوِ و اَتھ منٛز خلل  ﴿شور کٔرِ و ﴾ ، بنان چُھ زِ یِتھے پٲٹھۍ یِیِو توٚہۍ غٲلب۔"
  41,27,"۔تہٕ یِمہٕ بد تر ین حر کتہٕ یِم کران چِھ روٗدِ مٕتۍ تِہُند پوٗرٕ پوٗرٕ بد لہٕ دِ مَو یِمن۔"
  41,28,"۔ سُہ چُھ جہنم یُس اللہ تعالیٰ سٕند ٮ۪ن دُشمنَن میلہِ مُعا وضس منٛز۔ تٔتھۍ منٛز آسہِ ہمیشہ ہمیشہ خٲطرٕ تِہندِ خٲطرٕ گھرٕ۔یہِ چُھ سزا تمہِ جُر مُک زِ تِم روٗدۍ سا نیٚن آیا تن انکار کران۔"
  41,29,"۔تَتہِ وَنن یِم کٲفر زِ،  اے سانہِ ربّہ ، اسہِ ہا و تکھ تِم جِن تہٕ انسان یِمو أسۍ گُمرا ہ ٲسۍ کٔرِ مٕتۍ، أسۍ مَتھو کھ تِم کھۅ ر ن تل، تا کہ تِم گژھن وارٕ پٲٹھۍ ذلیل و خوار"
  41,30,"۔یِمو لُکو ووٚ ن زِ اللہ تعالیٰ چُھ سو ن ربّ، تہٕ پتہٕ روٗدۍ تِم اَتھ پٮ۪ٹھ ثٲبت قد م ، ﴿ یعنی تِم روٗدۍ نہٕ محض اتفاقاً کُنہِ وِزِ خُدایس پنُن ربّ ؤنِتھ شۅ نگ ترٲوِ تھ بِہِتھ ، تہٕ نَہ سپٕدۍ اَتھ غلطی منٛز مبتلا زِ خُدا یس روزَ ن پنُن ربّ تہِ وَنان تہٕ سٍتۍ سٍتۍ روزن با قین تہِ پنُن ربّ بناوان پکا ن ، بلکہ روٗدۍ اکہِ پھِرِ یہِ عقیدٕہ قبو ل کر نہٕ پتہٕ سٲرِ سٕے وٲنٛسہِ اَتھ پٮ۪ٹھ  قٲیِم ،اتھ خلا ف کوٚرُکھ نہٕ دوٚ یُم بیٚیہِ کانٛہہ عقیدٕ ہ اختیار، تہٕ نہ کٔرٕ کھ اَتھ عقیدس سٍتۍ کُنہِ بٲطل عقیدٕ چ مِلا وٹ ، تہٕ پننہِ عملی زند گی منٛز تہِ روٗدۍ تو حید کہ عقیدٕ کۍ تقا ضہٕ پوٗرٕ کران ۔﴾پٔزِپٲٹھۍ چِھ تِمن پٮ۪ٹھ فر شتہٕ نٲزِل سپدان، تہٕ وَنان چِھکھ زِ  نہ مَہ کھوٚژِ و نہ مَہ سپدِ و غمگین، تہٕ خۅش سپدِ و تَمہِ جنّت کہ بشا رت سٍتۍ ییٚمیُک تۅہیہِ سٍتۍ وعدہ چُھ کر نہٕ آمُت۔"
  41,31,"۔أسۍ چِھ ییٚمہِ دُنیا چہِ زند گی منٛز تہِ تُہٕندۍ سٲتھی تہٕ ٲخرتس منٛز تہِ۔یِکینٛژھاہ توٚہۍ تَتہِ ییٚژِھو تہِ میلیو، تہٕ پرٛتھ کانٛہہ چیز ییٚمیُک توٚہۍ تمنا کٔرِ و سُہ سپدِ تُہُند،"
  41,32,"۔یہِ چُھ ضیا فتُک سامان تٔمِس ہستی ہٕند طر فہٕ یُس غفوروحیم چُھ۔ع"
  41,33,"۔تہٕ تس شخصہٕ سٕندِ کھۅتہٕ کھٔسِتھ کتھ کٔمۍ سٕنز ہیٚکہِ ٲسِتھ ییٚمۍ خُدایس کُن دعوت دِژتہٕ نیک عمل کرٕن، بیٚیہِ ووٚنُن زِ بہٕ چُھس مسلمان۔"
  41,34,"۔تہٕ اے نبی صلی اللہ علیہ وسلم ، نیکی تہٕ بد ی چَھنہٕ یکسان۔ بد ی کٔرِو تمہِ نیکی سٍتۍ دفع یۅسہٕ بہتر ین آسہِ۔ توٚہۍ وُچھِو زِ تۅہیہِ سٍتۍ یَس عدا وت اوس،سُہ چھُ جگر ی دوست بنیا مُت۔"
  41,35,"۔یہِ صفت چُھنہٕ نصیب سپدان مگر تِمن لُکن یِم صبر چِھ کران، تہٕ یہِ مقا م چُھنہٕ حٲصل سپدان مگر تِمن لُکن یِم صبر چِھ کران، تہٕ یہِ مقا م چُھنہٕ حٲصل سپدان مگر تِمن لُکن یِم سٮ۪ٹھاہ نصیب وٲلۍ چِھ۔"
  41,36,"۔تہٕ اگر توٚہۍ شیطا ن سٕندِ طر فہٕ کانٛہہ اُکسا ہٹ محسو س کٔرِو، تیٚلہِ منگِو اللہ تعالیٰ سُند پناہ،﴿شیطان سٕندِ اُکسا ہٹ نِشہِ چُھ مُراد شرارت کھا لُن یعنی ہٕس دِیُن۔ییٚلہِ انسان یہِ محسو س کر زِ لیٚکہٕ ژارن والیٚن تہٕ الزا م تراشی کر ن والیٚن مخا لفن ہٕنز ن کتھن پٮ۪ٹھ چُھ شرارت کھسان تہٕ وادَس واد کر نس پٮ۪ٹھ چھےٚ طبیعت آمادٕہ سپدان تیٚلہِ گژِھہ فوراً سمجھُن زِ یہِ چُھ شیطان یُس أمِس پننیٚن رٔذیل مخٲلِفن ہٕندِس سطحس پٮ۪ٹھ وَسنہٕ خٲطرٕ چُھ ہٕس دِوان﴾۔ سُہ چُھ سورُے کینٛہہ بوزان تہٕ زانان۔"
  41,37,"۔اللہ تعالیٰ سٕنز و نِشٲنِیو منٛز چِھ یہِ رات تہٕ دۅہ تہٕ آفتا ب تہٕ زو ن ۔آفتا بس تہٕ زوٗنہِ مَہ کٔرِ و سجدٕہ، بلکہ کٔرِ وتس خُدایس سجدٕہ ییٚمۍ یِم پٲدٕ چھِ کٔرِمٕتۍ، ہرگاہ پٔزِ پٲٹھۍ توٚہۍ تٔمۍ سٕندۍ عبادت کر ن وٲلۍ چِھو۔"
  41,38,"۔البتہ اگر یِم لُکھ تکبُرس منٛز یِتھ پننی کتھہِ پٮ۪ٹھ ڈٔٹِتھ روزن، تیٚلہِ چُھنہٕ پرواے،یِم فر شتہٕ تُہٕندِس ربّ سٕندۍ مقرب چِھ تِم چِھ راتس دۅ ہس تٔمۍ سٕنز تسبیح کران،تہٕ زانٛہہ چِھنہٕ تھکان۔"
  41,39,"۔تہٕ اللہ تعالیٰ سٕنزو نِشٲنِیَو منٛزٕ چھےٚ اکھ یہِ زِ توٚہۍ چِھو وُچھان زمین چھےٚ دَبیمٕژ ﴿وٲران﴾، پتہٕ یُتھُے اسہِ اتھ پٮ۪ٹھ روٗد ترٛوو، سۅ چھےٚ یکبار گرایہِ ماران تہٕ ویٚٹھان۔ یقیناً یُس خُداے اَتھ موٗدِ مٕتِس زمینس زند گی چُھ دِوان ،سُہ چُھ مۅردن تہِ زند گی بخشن وول۔ یقیناً چُھ سُہ پرٛتھ چیزس پٮ۪ٹھ قدرت تھاوان۔"
  41,40,"۔یِم لُکھ سا نیٚن آیا تن اُلٹہٕ معنی چِھ وَلان،تِم چِھنہٕ اَسہِ نِشہِ ژوٗرِ کینٛہہ۔پانے سوٗ نچِو زِ سُہ شخص چھا بہتر یُس نارس یِیہِ چھکنہٕ، کِنہٕ سُہ یُس قیا مت کہ دۅہ اَمن کِس حالتس منٛز حٲضر سپدِ؟ کران روٗزِو یِکینژھاہ توٚہۍ ییٚژِھو، تُہٕنزن سارِنٕے حر کتن چُھ اللہ تعالیٰ وُچھان۔ یِم چِھ تِم لُکھ یِمن برونٛہہ کُن کلامِ نصیحت آو، تِمو کوٚر سُہ ماننہٕ نِشہِ انکار۔"
  41,41,"۔مگر حقیقت چھےٚ یہِ زِ یہِ چھےٚ اکھ زبردست کتاب"
  41,42,"۔، با طل نَہ ہیٚکہِ اَتھ پٮ۪ٹھ بروٗنٹھۍ کِنۍ یِتھ نَہ پٔتۍ کِنۍ ﴿ بروٗنٹھۍ کِنۍ نہ یِنُک مطلب چُھ یہِ زِ قرآنس پٮ۪ٹھ براہِ راست حملہٕ کٔرِ تھ اگر کانٛہہ شخص امہِ چہِ کُنہِ کتھہِ غلط تہٕ کُنہِ تعلیمہِ باطل تہٕ فٲسد ثٲبت کرُن ییٚژِھہ، سُہ ہیٚکہِ نہٕ اَتھ منٛز کامیا ب گٔژِھتھ۔پٔتۍ کِنۍ نہ ینُک مطلب چُھ یہِ زِ قیا متس تام ہیٚکہِ نہٕ زانٛہہ حقیقت تہٕ صداقت تِژھہ منکشف سپدِ تھ یۅسہٕ قرآن کیٚن پیش کر نہٕ آمتیٚن حقٲیقن خلا ف آسہِ، کانٛہہ تِیُتھ علم ہیٚکہِ نہٕ یِتھ یُس فی الواقععلم  آسہِ تہٕ قرآن کِس بیان کر نہٕ آمتِس علمس آسہِ تردید کران، کانٛہہ تجر بہٕ تہٕ مُشٲہدٕ ہ ہیٚکہِ نہٕ تِیُتھ ٲسِتھ یُس یہِ ثٲبِت کرِزِ قرآنن یۅسہٕ رہنمٲیی عقٲید ن، اَخلا قس، قا نونس، تہذیب و تمدّنس ، معیشت و معا شر تس تہٕ شہر ی انتظا م کِس با بس منٛز انسانس دِژ مٕژ چھےٚ، سۅ کیا چھےٚ غلط﴾یہِ چُھ أکِس حکیم و حمید سُند نٲزِل کر نہٕ آمُت چیز۔"
  41,43,"۔اے نبی صلی اللہ علیہ وسلم ، تۅ ہیہِ یِکینژھاہ وَننہٕ چُھو یِوان تتھ منٛز چُھنہٕ کانٛہہ چیز تہِ تِیُتھ یُس تۅہیہِ بروٗنٹھمیٚن گُزریمتیٚن رسولن آسہِ نہٕ وَننہٕ آمُت۔بے شک چُھ تُہُند ربّ سٮ۪ٹھاہ در گز ر کر ن وول، تہٕ اَتھ سٍتۍ چُھ سٮ۪ٹھاہ درد ناک سزا دِنہٕ وول تہِ۔"
  41,44,"۔اگر أسۍ یہِ عجمی قرآن بنٲوِتھ سوز ہَو، تیٚلہِ ونہَن یِم لُکھ کیازِ آے نہٕ اَمِکۍ آیات ویٚژھنٲوِ تھ بیان کرنہٕ؟یہِ کٲژاہ عجیب کتھ چھےٚ زِ کلام چُھ عجمی تہٕ مخٲطب چِھ عر بی۔ ﴿یہِ چُھ تمہِ ہٹ دھر می ہُند اکھ نمو نہٕ ییٚمہِ سٍتۍ نبی صلی اللہ علیہ وسلمن ہُند مقا بلہ اوس یِوان کر نہٕ۔ کفار ٲسۍ ونان زِ محمد صلی اللہ علیہ وسلم چِھ عر بی یعنی عر بٕکۍ روزن وٲلۍ ،یِم اگر عر بی یس منٛز قرآن چِھ پیش کران تیٚلہِ کِتھہٕ پٲٹھۍ یِیہِ اندازٕہ کر نہٕ زِ یہِ کلام چُھنہٕ تِمو پانے بنو و مُت بلکہ چُھ یِمن پٮ۪ٹھ خُداین نٲزِل کوٚر مُت۔ یہِ کلام ہیٚکہِ خُداے سُند نٲزِل کر نہٕ آمُت کلام تمہِ وقتہٕ ماننہٕ یِتھ، ییٚلہِ یہِ کُنہِ تِژِھہ زبٲنۍ منٛز اچا نک زبردست تقر یر لا گہِ کرُن یتھ نہٕ یِم زانان آسٕہن۔مثلا فارسی یا رومی یا یونٲنۍ۔اتھ پٮ۪ٹھ چُھ اللہ تعالیٰ فرماوان زِ وۅ نۍ چُھ یِہنزِ پننہِ زبٲنۍ منٛز قرآن سوزنہٕ آمُت یتھ یِم سمجِھتھ ہیٚکن ،یِمن چُھ یہِ اعتراض زِ أکِس عر ب کِس روزن وٲلۍ سٕندِ ذر یعہ کیازِ آو یہِ کلام عر بی زبٲنۍ منٛز نٲزِل کر نہٕ؟ البتہ اگر دوٚ یِمہِ زبٲنۍ منٛز سوزنہٕ یِیہِ ہے،تیٚلہِ کر ہن تمہِ وِزِ یِمے لُکھ اعتراض زِ یہِ کتھ تہِ چھےٚ عجیب زِ عر ب قو مس منٛز آو اکھ عر بُک روزن وول رسول بنٲوِ تھ سوزنہٕ، مگر أمِس پٮ۪ٹھ آو کلام تِژِھہ زبٲنۍ منٛز نٲزِل کر نہٕ یتھ نَہ چُھ رسول سمجھان تہٕ نَہ قوم﴾یِمن ؤنِو یہِ قرآن چُھ ایمان انن والیٚن خٲطرٕ ہدایت تہٕ شفا، مگر یِم لُکھ ایمان چِھنہٕ اَنان تِہندِ خٲطرٕ چُھ یہِ کنَن زَر تہٕ أچھن پٔٹ۔تِہُند حال چُھ یُتھ زَنتہٕ تِمن دوٗرِ آسہِ آلَو یِوان دِنہٕ ۔ع"
  41,45,"۔ییٚمہِ برونٛہہ ٲس اسہِ مو سیٰ علیہ السلامس کتا ب دِژ مٕژ تہٕ تٔمۍ سٕندِس معا ملس منٛز تہِ اوس یۅہے اختلا ف سپُد مُت۔ اگر تُہٕندۍ ربّن گۅڈے آسہِ ہے نہٕ اکھ کتھ طے کٔرمٕژ، تیٚلہِ یِیہِ ہے یِمن اختلا ف کر ن والیٚن در میان فٲصلے مۅکلا و نہٕ۔تہٕ حقیقت چھےٚ یہِ زِ یِم چِھ تٔمۍ سٕندِ طر فہٕ سخت اِضطرا ب انگیز شکس منٛز۔"
  41,46,"۔ یُس نیک عمل کرِ ، سُہ کرِ پننی خٲطرٕ رُت، یُس بد ی  کرِ،تَمیُک وَبال آسہِ تٔسۍ پٮ۪ٹھ، تہٕ تُہُنٛد ربّ چُھنہٕ پننیٚن بند ن ہٕنٛدس حقس منٛز ظٲلِم کینٛہہ۔"
  41,47,"۔تمہِ ساعتُک ﴿مُراد چُھ قیامت ﴾علم چُھ اللہ تعالیٰ سٕے کُن پھیران، سُہ چُھ تِمن سارِنٕے پھلن ﴿میٚوَن ﴾ زانان، یِم پننیو پُھلیَو منٛز چِھ نیران، تٔسۍ چھےٚ پَے زِ کۅسہٕ مادٕہ چھےٚ حٲملہٕ سپٕز مٕژ تہٕ کس چُھ بچہِ زامُت۔پتہٕ ییٚمہِ دۅہ سُہ یِمن لُکن ناددِیہِ زِ کتہِ چِھ میٲنۍ تِم شر یک؟ یِم وَنن  اسہِ چُھ عرض کوٚر مُت ، اَز چُھنہٕ اسہِ منٛزٕ کانٛہہ اَمِچ گوٲہی دِنہٕ وول۔"
  41,48,"۔تمہِ وقتہٕ راوَن تِم سٲری معبوٗد تِمن ، یِمن یِم امہِ برونٛہہ ناد ٲسۍ دِوان ،تہٕ یِم لُکھ سمجھن زِ وۅ نۍ چَھنہٕ یِہندِ خٲطرٕ کانٛہہ چَھپن جاے۔"
  41,49,"۔انسان چُھنہٕ زانٛہہ رٕژرُک دُعا منگان منگان تھکان، تہٕ ییٚلہِ کانٛہہ آفت تس پٮ۪ٹھ یِوان چھےٚ، تیٚلہِ چُھ مایوس تہٕ دل شکستہٕ گژھان،"
  41,50,"۔مگر یُتھُے سخت وقت گُزر نہٕ پتہٕ أسۍ تس پننہِ  رحمتُک مزٕہ چِھ وُچھناوان، یہِ چُھ ونان زِ  بہٕ چُھس امہِ کُے حقدار،تہٕ مےٚ چُھنہٕ باسان  زِ قیا مت کیا یِیہِ زانٛہہ،البتہ اگر پٔزِ پٲٹھۍ بہٕ پننِس ربّس کُن واپس پھِر نہٕ آس، تیٚلہِ کرٕ تَتہِ تہِ بہٕ عٲش۔ حالانکہ کُفر کرن والیٚن وَنو أسۍ لٲز ماًزِ تِم کیا کٔرِ تھ چِھ آمٕتۍ، تہٕ تِم وُچھنا ووکھ أسۍ سٮ۪ٹھاہ گندٕہ عذابُک مزٕ ہ۔"
  41,51,"۔انسانس ییٚلہِ أسۍ نعمت چِھ دِوان،تیٚلہِ چُھ سُہ بُتھ پھِران تہٕ بوش چُھس کھسان،تہٕ ییٚلہِ کانٛہہ آفت تس چُھوان چھےٚ،تیٚلہِ چُھ زِ یٖٹھۍ زِیٖٹھۍ دُعا منگنہِ لگان۔"
  41,52,"۔اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو ، زانٛہہ سو نچوٕ ہ تۅہیہِ یِتہِ زِ اگر پٔزِ پٲٹھۍ یہِ قرآن اللہ تعالیٰ سٕندی طر فہٕ اوس، تہٕ توٚہۍ روٗدِ و اَمِیُک انکار کران، تیٚلہِ کُس آسہِ تس شخصہٕ سٕندِ کھۅتہٕ وَتہِ ڈوٚلمُت یُس امہِ کِس مخٲلفتس منٛز دوٗر آسہِ درٛامُت؟"
  41,53,"۔عنقر یب ہاوَو أسۍ یِمن پننہِ نِشٲنیہِ آفاقس منٛز تہِ ﴿یعنی ہیٚرِ بۅ ن ژۅ پٲرۍ ﴾ تہٕ یِہِندٮ۪ن پننیٚن نفسن منٛز تہِ، یوٚت تام زن یِمن پٮ۪ٹھ یہِ کتھ کُھلہِ زِ یہِ قرآن چُھ پٔزِ پٲٹھۍ بر حق۔ کیا یہِ کتھ چَھنا کٲفی زِ تُہُند ربّ چُھ پرٛتھ چیزُک شٲہد؟"
  41,54,"۔خبردار روٗزِ و ، یِم لُکھ چِھ پننِس ربّ سٕندِس ملا قاتس منٛز شک تھاوان۔بوٗزِ تھ تھٲوِو ، سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ مُحیط ۔ع ﴿یعنی کانٛہہ چیز نہ چُھ تٔمۍ سٕندِ گِرِ فتہٕ نِشہِ نیٚبر تہٕ نہ چُھ تٔمۍ سٕندِ علمہٕ نِشہِ ژھایہِ ۔﴾"
