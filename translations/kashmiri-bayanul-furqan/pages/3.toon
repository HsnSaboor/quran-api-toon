quran[200]{c,v,t}:
  3,1,"۔ا،ل،م۔"
  3,2,"۔اللہ تعالیٰ ،سُہ زند ہ جا وید ہستی ،یُس کاینا ت کِس نظا مس سنبھا لِتھ چُھ، حقیقتس منٛز چُھنہٕ تس ورٲے کانٛہہ خُدا ے۔"
  3,3,"۔اے نبی صلی اللہ علیہ وسلم، تٔمۍ کٔر تۅہیہِ پٮ۪ٹھ یہِ کتاب نٲزل یۅسہٕ حق ہیٚتھ چھےٚ آمٕژ تہٕ تِمن کتا بن چھےٚ تصد یق کران یِمہٕ گۅڈٕ ہ پٮ۪ٹھے آسہٕ آمژٕتہٕ  تٔمۍ کٔر نٲزِل تورات تہٕ انجیل ۔"
  3,4,"۔ییٚمہِ برونٹھ انسانن ہٕندِ ہدا یت خٲطرٕ تہٕ تٔمۍ چھےٚ سۅ کہؤٹ نٲزِل کٔرمژٕ﴿یۅسہٕ حقٕچ  تہٕ بٲطلٕچ فر ق ہاون واجِیٚنۍ چھےٚ﴾ وۅ نۍ یِم لُکھ اللہ تعالیٰ سٕندۍ فر مان قبول کر نہٕ نِشہِ انکار کرن تِمن میلہِ پٔزۍ پٲٹھۍ سخت سزا۔ اللہ تعالیٰ چُھ بے پنا ہ طا قتُک مٲلک تہٕ سُہ چُھ بُرٲیی ہُند بد لہٕ دِنہٕ وول۔"
  3,5,"۔ زمین و آسما نُک کانٛہہ چیز چُھنہٕ خُدا یس نِشہِ پو شیدٕہ ،"
  3,6,"۔سُے چھُ یُس  تُہٕنز ن ما جن ہٕنز ن یٔڈ ن منٛز تُہنزٕ صوٗرتہٕ،یِژٕھہ یژھا ن  چُھ،تِژٕھہ چُھ بناوان ،تس زبردست حکمت وٲلِس ورٲے چُھنہٕ بیٚیہِ کانٛہہ خُدا ے۔"
  3,7,"۔اے نبی صلی اللہ علیہ وسلم، سُے خُدا ے چُھ ییٚمۍ یہِ کتا ب تۅہیہِ پٮ۪ٹھ نٲزِل چھےٚ کٔر مٕژ،یتھ کتا بہِ اندر چِھ دۅ یہِ قسمٕکۍ آیا ت:اکھ محکمات،یِم کتا بہِ ہٕندۍ اصل بنیا د چِھ ﴿آیات محکمات گٔیہِ تِم آیات یِہٕنز زبان بالکل صا ف چھےٚ تہٕ یُہُند معنی متعین کر نس منٛز کُنہِ شکٕچ گنجٲیش چَھنہٕ۔ یِم آیات چِھ  کتا بہِ ہٕنٛز اصل بنیاد۔ یعنی قرآن ییٚمہِ غر ضہٕ خٲطرٕ نٲزِل سپُد مُت چُھ ،تتھ غر ضس چِھ یِمے آیات پوٗرٕ کران۔یِمنٕے منٛز چھےٚ دُنیا ہس آمٕژ اسلامس کُن دعوت دِنہٕ۔ یِمنٕے منٛز چھےٚ عبرت چہ تہٕ نصیحت چہ کتھہٕ فر ماو نہٕ آمژٕ، یِمنٕے منٛز چُھ گُمرٲہیَن ہُنٛد تردید تہٕ سیٚزِ وَتہِ ہٕنز تو ضیح کر نہٕ آمٕژ، یِمنٕے منٛز چِھ دینٕکۍ بنیٲدی اصول بیان کر نہٕ آمٕتۍ ، یِمنٕے منٛز چِھ عقٲید،عبا دت ، اخلا ق فرٲیض تہٕ امر و نہی ہٕکۍ احکام ارشاد سپدٕۍ مٕتۍ۔﴾  تہٕ دوٚ یِمۍ چِھ مُتشا بہا ت۔﴿مُتشا بہا ت یعنی تِم آیا ت یِہندِس مفہو مس منٛز شکٕچ گنجٲیش چھےٚ۔یہِ کتھ چھےٚ ظٲہر زِ انسان سٕندِ خٲطرٕ ہیٚکہِ نہٕ زند گی ہٕنز کانٛہہ وَتھ تجو یز کر نہٕ یِتھ یوٚت تام نہ انسانس غیبی حقیقتن متعلق کم کھۅتہٕ کم ضرور ی معلو ما ت دِنہٕ یِن ۔ تہٕ یِتہِ چُھ ظٲہر زِ یِم چیز انسان سٕندِ حوا سہٕ نِشہِ پوشیدٕ ہ چِھ، یِم نہٕ تٔمۍ زانٛہہ ؤچھمٕتۍ چِھ ، نَہ لوگنکھ اَتھہٕ ، نَہ وُچھنکھ مزٕ ہ ۔ نَہ ہیٚکن یِمن خٲطرٕ انسٲنی زبٲنۍ منٛز تِتھۍ الفا ظ میٖلِتھ یِم یِمنٕے خٲطرٕ وضح آسن کر نہٕ آمٕتۍ ،تہٕ نَہ ہیٚکن تِتھۍ بیا نٕکۍ ویٚد ۍ طر یقہٕ ﴿اسلو ب﴾ مِیلِتھ ، یِمو سٍتۍ ہر کٲنٛسہِ بوزن وٲلۍ سٕندِس ذہنس منٛز تِہُنٛد نقشہِ بٔنِتھ ہیکہِ۔ ضرور ی چُھ زِ اَمہِ نو عیتٕکۍ مضمو ن بیان کر نہٕ خٲطرٕ یِن تِم الفا ظ تہٕ بیان کر نٕکۍ طریقہ ﴿اسلو ب﴾ وَرتاو نہٕ یِم اصل حقیقتس سٮ۪ٹھاہ نکھہٕ ہِشر تھاو ن والیٚن محسو س چیزن خٲطرٕ انسٲنی زبٲنۍ منٛز لبنہٕ  چِھ یِوان۔چنا نچہِ یِمن حقیقتن ہٕندِس بیا نس منٛز چھےٚ قرآنس اندر اَمی قسمٕچ زبان وَرتاونہٕ آمٕژ، تہٕ متشا بہا ت گٔیہِ تِم آیات یِمن منٛز یہِ زبان چھےٚ استعمال سپٕز مٕژ۔﴾ یِمن لُکن ہٕندِ س دِلس منٛز ہجر چُھ تِم چِھ فِتنہٕ کِس تلا شس منٛز ہمیشہ متشا بہا ت نٕے پتہٕ روزان تہٕ تِمن چِھ معنی پُشراونچہِ کو ششہِ کران روزان حالانکہ تِہُند حقیقی  مفہو م چُھنہٕ خدا یس ورٲے کٕہٕنۍ  زانان اتھ بر عکس یِم لُکھ عِلمس اندر پختہٕ کار چِھ ،تِم چِھ ونان زِ: اَسہِ چُھ تِمن پٮ۪ٹھ ایمان ، یِم سٲری چِھ سٲنِس ربّ سٕندی طر فہٕ ﴿یتھ جایہِ گژِھہ نہٕ کٲنٛسہِ شک گژُھن زِ ییٚلہِ تِم لُکھ -، متشا بہا تن ہُنٛد صحیح مفہو م زانا نٕے چِھنہٕ ، تیٚلہِ کِتھہٕ پٲٹھۍ اوٚ ن تِمو یِمن پٮ۪ٹھ ایمان۔ حقیقت چھےٚ یہِ زِ أکِس عقل تھاون وٲلِس انسانس چُھ قرآن کہ کلامُ اللہ آسنُک یقین محکمات کہ مطا لبہٕ سٍتۍ حٲصل سپدان، نَہ زِ متشا بہا ت چَو تٲوِیلو سٍتۍ۔ ییٚلہِ آیاتِ محکما تن پٮ۪ٹھ غور وفکر کر نہٕ سٍتۍ تس یہِ اِطمنان حا صل چُھ سپدان زِ یہِ  کتا ب چھےٚ وا قعی اللہ تعالیٰ سٕنزٕ ے کتا ب ، پتہٕ چِھنہٕ متشا بہات تٔمۍ سٕندِس دِلس اندر کُنہِ قسمُک اندیشہِ پٲدٕ کران﴾ تہٕ یہِ چُھ پوٚز زِ صرف چِھ دٲنش مند لُکھٕے کُنہِ چیزٕ  نِشہِ صحیح سبق حٲصل کران۔"
  3,8,"۔تِم چِھ خدا یس دُعا کران زِ :  پروردگارٕ ، ییٚلہِ ژےٚ اَسہِ سِیٔز وَتھ چھےٚ ہٲومٕژ،تیٚلہِ کٔرۍ زیٚنہٕ سٲنۍ دِل ہجرس منٛز مبتلا اَسہِ کر پننہِ فیض کہ خزا نہٕ منٛز رحمت عطا بے شک چُھکھ ژٕےحقیقی فیاض۔"
  3,9,"۔پروردِگارٕ، پٔزۍ پٲٹھۍ چُھکھ ژٕ اکہِ دۅ ہ سٲر ی لوٗکھ جمع کر ن وول۔تمہِ دۅ ہ کِس یِنَس منٛز چُھنہٕ کانٛہہ شک، ژٕ چُھکھ نہٕ ہر گز پننِس وعدس ڈلن وول۔ ع"
  3,10,"۔یِمو لُکو کُفرُک رٔوِیہِ وَرتو و تِمن نَہ یِیہِ اللہ تعالیٰ سٕندِس مقا بلس منٛز تِہُند مال بکا ر تہٕ نَہ اولاد تِم بَنن جہنمُک زالُن۔"
  3,11,"۔ تِہُند انجام آسہِ تِیُتھے ،یُتھ فر عو ن سٕندٮ۪ن سٲتھیِن تہٕ تِمن بروٗنٹھمیٚن نا فر مانن ہُنٛد سپُد مُت چُھ ،تِمو زٲنۍ اللہ تعالیٰ سٕندۍ آیات اَپزٕ ۍ نتیجہِ درٛا و یہِ زِ خُدا ین رٔٹۍ تِم تِہند ٮ۪ن گنا ہن پٮ۪ٹھ تہٕ پَزر چُھ یہِ زِ اللہ تعالیٰ  چھُ سخت سزا دِنہٕ وول۔"
  3,12,"۔لہٰذا، اے نبی صلی اللہ علیہ وسلم،یِمو لُکو تُہٕنز دعوت قبول کر نہٕ نِشہِ انکار چُھ کوٚر مُت ، تِمن ؤنِو زِ نز دیک چُھ سُہ وقت، ییٚلہِ توٚہۍ مغلو ب گٔژِھو تہٕ جہنمس کُن یِیِو کھٚر  کوان پکنا ونہٕ تہٕ جہنم چُھ سٮ۪ٹھاہ بُرٕ ٹھکا نہٕ۔"
  3,13,"۔تُہٕندِ خٲطرٕ اوس تِمن دۅ ن دَر یٚن منٛز اکھ عبرتُک نِشانہٕ، یِمو﴿بدرس اندر﴾ اکھ أکِس سٍتۍ مقا بلہٕ کوٚر ،اکھ دوٚر اوس  اللہ تعالیٰ سٕنزِ وَتہِ منٛز لڑا ن تہٕ بیاکھ دوٚر اوس کٲفر ،وُچھن وٲلۍ أسۍ ہو شہِ گو شہِ پننیو چشمو وُچھان زِ کٲفر ن ہُنٛد دوٚر چُھ مو منن ہٕندِ دَرِ کھۅتہٕ دۅ گنہٕ ﴿اگر چہِ حقیقی فر ق ترٛ و گنہٕ ٲس، البتہ سرسری نظر ترٛاون وول تہِ ہیٚکہِ ہے نہٕ یہِ محسو س کر نہٕ ورٲے روٗزِ تھ زِ کٲفر ن ہُنٛد لشکر چُھ مسلمانو کھۅ تہٕ دۅ گنہٕ﴾ مگر ﴿نتیجن  کوٚر ثا بِت زِ ﴾ اللہ تعالیٰ یَس پننہِ فتح تہٕ نصرت سٍتۍ یژھان چُھ، تَس چُھ مدددِوان، یِم پٔزۍ پٲٹھۍ وُچھن وٲلۍ چِھ تِمن چُھ اَتھ منٛز بوٚڈ سبق پوٗشیدٕہ ۔"
  3,14,"۔لُکن خٲطرٕ چُھ پا نس کُن رٲغب کر ن والین چیز ن ہُنٛد محبت خۅ ش کروُن بنا و نہٕ آمُت ﴿مثلاً﴾ مستوٗراتہٕ ،اولاد ،سۅ نٕکۍ رۅ پٕکۍ ڈھیر ،چیدٕ ہ گُر ۍ، چاروٲے تہٕ زر عی زمین مگر یِم سٲر ی چِھ دنیا چہِ کینژھن دۅ ہن ہٕنٛزٕ زند گی ہٕنٛد ۍ سامانہ،  در حقیقت یُس بہتر ٹھکا نہٕ چُھ، سُہ چُھ خدا یس نِشہِ ۔"
  3,15,"۔ؤنِو : بہٕ وَنوٕ ہ زِ یِمو کھۅتہٕ زیا دہ رُت چیز کیا چُھ؟ یِم لوٗکھ تقویٰ ہٕچ رٔوِش پا نناون تِمن خٲطرٕ چِھ تِہندِس ربّس نِشہِ با غ یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکا ن تَتہِ سپدِ تِمن ہمیشہ روزنٕچ زند گی حٲصل، پٲکیزٕہ خاندارِ نہِ آسن تِمن رفیق تہٕ اللہ تعالیٰ سٕندِ رضا سٍتۍ آسن تِم سرفراز اللہ تعالیٰ چُھ پننیٚن بند ن ہٕندِس رٔوِیس پٮ۪ٹھ سٔنۍ نظر تھاوان۔"
  3,16,"۔یِم چِھ تِم لُکھ یِم ونان چِھ زِ : سانہِ مٲلکہٕ، اَسہِ اوٚ ن ایمان سا نیٚن خطا ہن کردرگُزر تہٕ اَسہِ بچا و نا رِ جہنم نِشہِ"
  3,17,"۔ یِم لُکھ چِھ صبر کر ن وٲلۍ ،پٔزِ یٲرۍ چِھ فر ما نبردار تہٕ خرچاون وٲلۍ چِھ بیٚیہِ چِھ رٲژ ہٕندٮ۪ن ٲخر ی پہر ن منٛز خُدا یس مغفر تٕکۍ دُعا منگا ن ۔"
  3,18,"۔خُدا ین چھےٚ پانہٕ امہِ کتھہِ ہٕنٛز شہا دت دِژ مٕژ زِ : تس ورٲے چُھنہٕ کانٛہہ خُدا تہٕ فرشتہٕ تہٕ سٲر ی اہلِ علم تہِ چِھ پز رٕ سان تہٕ انصا ف سان اَتھ پٮ۪ٹھ گواہ زِ تس زبردست حکیمس وَرٲے چُھنہٕ در حقیقت کانٛہہ خُدا ۔"
  3,19,"۔ خُدا یس نز دیک چُھ  دین صرف اسلام، اَمہِ دِین نِشہِ ۂٹِتھ یِم مختلف طر یقہٕ تِمو لُکو اختیار چِھ کٔرِ مٕتۍ یِمن کتا ب ٲس دِنہٕ آمٕژ تِہِندِ اَمہِ طر زِ عملُک وجہ اوس نہٕ اَمہِ ورٲے کِہِنۍ زِ تِمو کوٚر علم یِنہٕ پتہٕ پانہٕ وٲنۍ اکھ أکِس پٮ۪ٹھ زیادتی کر نہٕ موجوٗب یہِ  تہٕ یُس اکھا ہ اللہ تعالیٰ سٕندٮ۪ن احکامن تہٕ ہدا یتن ہٕنٛدِ اطا عت نِشہِ انکار کرِ خُدا یس چَھنہٕ تس حسا ب ہیٚنَس منٛز تٲر لگا ن۔"
  3,20,"۔اے نبی صلی اللہ علیہ وسلم ،وۅ نۍ ہرگاہ یِم لُکھ تۅہیہِ سٍتۍ جھگڑٕ کر ن تیٚلہِ ؤنِو یِمن :  مےٚ تہٕ میا نیو پیرو کارو چُھ خُدا یس برونٛٹھہٕ کَنہِ کلہٕ نوٚ مرٲوِ تھ تسلیم  کوٚرمُت۔ پتہٕ پٕرٛژِھو اہلِ کتا بن تہٕ غیر اہلِ کتا بن دۅ شوٕ نۍ: کیا تۅہیہِ تہِ کٔروٕ ہ تٔمۍ سٕنز اطا عت تہٕ بند گی قبول؟ اگر کٔرٕکھ تیٚلہِ لٔبٕکھ سِیٔز وَتھ تہٕ ہرگاہ امہِ نِشہِ بُتھ پھیٚرُکھ تیٚلہِ ٲس تۅہیہِ پٮ۪ٹھ صرف پیغا م واتنا ونٕچ ذمہٕ دٲر ی، برونٛٹھ کُن چُھ اللہ تعالیٰ پانہٕ پننیٚن بند ن ہٕندۍ معا ملا ت وُچھن وول۔ ع"
  3,21,"۔یِم لُکھ اللہ تعالیٰ سٕندۍ احکام تہٕ ہدا یت ماننہٕ نِشہِ انکار چِھ کران تہٕ تٔمۍ سٕندٮ۪ن پیغمبر ن چِھ نا حق قتل کران تہٕ تِتھیٚن لُکن چِھ زُوس پتہٕ لگا ن یِم خلقِ خُدا یس اندر عد لُک تہٕ را ستی ہُنٛد حُکم دِنہٕ خٲطرٕ وۅ تھن تِم بو نٲزِ یوٗکھ دگ تُلوٕ نہِ عذا بٕچ خۅ ش خبر۔"
  3,22,"۔یِم چِھ تِم لُکھ یِہِندۍ اعما ل دنیا ہس تہٕ ٲخرتس دۅ شوٕنۍ منٛز ضا یع سپٕدۍ تہٕ یُہُند چُھنہٕ کانٛہہ مددگار۔"
  3,23,"تۅہیہِ وُچُھو نا زِ یِمن لُکن کتا بہِ ہٕندِ علمہِ منٛزٕ  کینٛہہ حصہٕ میوٗلمُت چُھ، تِمن ہُنٛد حال کیا چُھ؟ ییٚلہِ تِمن  اللہ تعالیٰ سٕنزِ کتا بہِ کُن ناد چُھ یوان دِنہٕ تا کہِ سۅ کرِ تِمن در میان فٲصلہٕ تِمو منٛز چُھ اکھ فر یق امہِ نِشہِ پتھ ہیٚوان تہٕ اَتھ فٲصلس کُن چُھ یِنہٕ نِشہِ بُتھ پھِران۔"
  3,24,"۔تِہُند یہِ طر زِ عمل چُھ اَمہِ وجہ کِنۍ زِ تِم چِھ وَنان : جہنمُک نار ہیکہِ نہٕ اَسہِ چُھوِتھ تہِ تہٕ ہرگاہ جہنمُک سزا اَسہِ دِنہٕ تہِ یِیہِ مگر سُہ آسہِ صرف کینٛژھن دۅ ہن خٲطرٕ۔ تِہِند یو خۅد ساختہٕ عقیدو چِھ تِم پننِس دین کِس معا ملس منٛز بجن غلط فہمِیَن منٛز ترٲوِ مٕتۍ"
  3,25,"۔مگر کیا بنہِ تِمن ییٚلہِ أسۍ  تِم تَمہِ دۅہ جمع کر وکھ ییٚمہِ دۅ ہُک یُن یقینی چھُ؟تمہِ دۅ ہ یِیہِ پرتھ شخصس تٔمۍ سٕنزِ کما یہِ ہُنٛد پوٗرٕ پوٗرٕ بد لہٕ دِنہٕ تہٕ  کٲنٛسہِ یِیہِ نہٕ ظُلم کر نہٕ۔"
  3,26,"۔ؤنِو ، خُدا یا ،مٕلکہٕ کہِ مٲلکہٕ ژٕ یَس یژھکھ تس دِکھ حکو مت تہٕ یَس یژھکھ تس نِکھ تھپہِ ،یَس یژھکھ تس دِکھ عزت تہٕ یُس یژھہَن سُہ کرٕ ہَن ذلیل رٕژَر چُھ چٲنِس اختیارس منٛز ب،ے شک چُھکھ ژٕ پرٛتھ چیز س پٮ۪ٹھ قدرت تھا وان۔"
  3,27,"۔رات چَھہَن دۅ ہ منٛزٕ کٔڑِ تھ اَنان تہٕ دۅ ہ چھہَن رٲژ منٛزٕ کٔڑِتھ اَنان، بے جان منٛزٕ چھہَن جاندار کڑان تہٕ جاندار منٛزٕ چَھہَن بے جان کڑا ن تہٕ یَس یژھان چُھکھ تس چُھکھ بے حسا ب رزِ ق دِوان ۔"
  3,28,"۔مو منین مَہ بنٲوِن ہر گز اہلِ ایمان ترٲوِ تھ کٲفر ن پنٕنۍ رفیق تہٕ یارو مددگار ،یُس یہِ کر تس چُھنہٕ خُدا یس سٍتۍ کانٛہہ تعلق، آ، یہِ چُھ معا ف زِ توٚہۍ کٔرِ و تِہِندِ ظُلمہٕ نِشہِ بچنہٕ خٲطرٕ یہِ طر زِ عمل اختیار۔﴿یعنی اگر کانٛہہ مو من کٲنٛسہِ اسلام دشمن جما عت کِس چُنگلس منٛز پھسیامُت آسہِ تہٕ تس آسہِ تِہندِ ظُلم و ستمُک خو ف ، تیٚلہِ چُھ تس اجا زت زِ سُہ تھٲوِ ن پنُن ایمان چُھپٲوِ تھ تہٕ کٲفر ن سٍتۍ روٗزِ ن بظٲہر تِتھہٕ پٲٹھۍ زِ زَنتہٕ تِموٕ ے منٛز کانٛہہ نفر آسہِ  ۔یا ہرگاہ تٔمۍ سُنٛد مُسلمان آسُن ظٲہر آسہِ سپُد مُت تیٚلہِ ہیکہِ سُہ کُفارن سٍتۍ دوستا نہٕ رٔوِیُک اظہا ر کٔرِ تھ ، حتیٰ کہ شد ید خو ف کِس حا لتس منٛز یَس شخصس برداشت کر نُک طا قت آسہِ نہٕ، تس چُھ کلمہ کُفر و ننُک تام اجازت﴾ مگر اللہ تعالیٰ چُھو تۅہیہِ پننہِ پانہٕ نِشہِ کھۅژناوان تہٕ تۅہیہِ چُھو تٔسۍ کُن وا پس پھیٖرِتھ گژُھن۔﴿یعنی پنُن زُو بچا و نہٕ خٲطرٕ ہیٚکِو توٚہۍ اَتھ حدس تو تقّیہ ﴿خو ف کہ وجہ کِنۍ حق ژوٗرِ تھا وُن﴾ کٔرِ تھ زِ اسلام کِس مِشنس تہٕ اسلامی جماعت کِس مفادس تہٕ کٲنٛسہِ مسلمان سٕندِس جان و ما لس نقصان واتنا و نہٕ ورٲے کٔرِو پننہِ جان و ما لُک تحفُظ۔ مگر خبردار کُفر تہٕ کُفارن ہٕنٛز تژِھہ کانٛہہ خد مت گژِھ نہٕ تُہند یٚو اَتھو انجام وا تٕنۍ ییٚمہِ سٍتۍ اسلام کِس مقا بلس منٛز کُفرس فر و غ حا صل سپد نُک تہٕ مُسلمانن پٮ۪ٹھ کُفار غٲلِب سپد نُک اِمکان آسہِ ﴾"
  3,29,"۔اے نبی صلی اللہ علیہ وسلم ، لُکھ کٔرِ یِوٗکھ خبردار زِ تُہند ٮ۪ن دِلن اندر یِکینٛژھاہ چُھ، خوا ہ توٚہۍ سُہ کھٔٹِتھ تھٲوِ تو یا نوٚ ن کٔڑۍ تو بہر حال چُھ اللہ تعالیٰ تتھ زانان،زمین و آسمانن ہُنٛد کانٛہہ چیز چُھنہٕ تٔمۍ سٕندِ علمہٕ نِشہِ نیٚبر  تہٕ تٔمۍ سُنٛد اقتدار چُھ پرٛتھ چیز س پٮ۪ٹھ حٲو ی۔"
  3,30,"۔سُہ دۅ ہ چُھ یِنہٕ وول ییٚلہِ پرٛتھ کانٛہہ نفس پننہِ کرِ مَتِیُک پھل حٲضر وُچھہِ خوا ہ تٔمۍ رٕژر ٲسِتن کوٚر مُت  یا بُرٲیی،تمہِ دۅ ہ کرِ انسان یہِ تمنا زِ کاش آسہِ ہے یہِ دۅ ہ تس نِشہِ واریاہ دوٗر !اللہ تعالیٰ چُھو تۅہیہِ پننہِ پانہٕ نِشہِ کھۅژناوان تہٕ سُہ پننیٚن بند ن ہُند سٮ۪ٹھاہ خیر خوا ہ ۔ع"
  3,31,"۔اے نبی صلی اللہ علیہ وسلم، لُکن ؤنِو زِ  ہرگاہ تۅہیہِ پٔزۍ پٲٹھۍ خُدا یس سٍتۍ محبت چُھو تیٚلہِ کٔرِو میٲنۍ پیر وی ، اللہ تعالیٰ کرِ تۅہیہِ سٍتۍ محبت تہٕ تُہند ٮ۪ن خطا ہن کرِ در گُزر ،سُہ چُھ سٮ۪ٹھاہ معا ف کر ن وول تہٕ رَحیم۔"
  3,32,"۔تِمن ؤنِو زِ  اللہ تعالیٰ سٕنز تہٕ رسول صلی اللہ علیہ وسلم سٕنز اطا عت کٔرِ و قبو ل پتہٕ اگر تِم تُہٕنٛز یہِ دعوت قبول کر ن نہٕ تیٚلہِ چُھنہٕ پٔزۍ پٲٹھۍ یہِ ممکن زِ اللہ تعالیٰ کرِ تِتھیٚن لُکن سٍتۍ محبت ،یِم تٔمۍ سٕندِس تہٕ تسندِس رسول صلی اللہ علیہ وسلم سٕندِس اطا عتس اِنکار آسن کران۔"
  3,33,"۔خدا ین ٲسۍ آد م علیہ السلام تہٕ نو ح علیہ السلام تہٕ آلِ ابرا ہیم علیہ السلام تہٕ آلِ عمرا ن علیہ السلام تمام دنیا والیٚن پٮ۪ٹھ تر جیح دِتھ ﴿پننہِ رسا لت خٲطرٕ ﴾ منتخب کٔرِ مٕتۍ ﴿عمرا ن اوس حضرت موسیٰ علیہ السلام تہٕ حضرت ہارو ن علیہ السلام سٕندِس مٲلِس ناو، یتھ با یبلس منٛز  عَمَر ام  چُھ لیٚکھنہٕ آمُت۔﴾"
  3,34,"۔یِم ٲسۍ اکہِ سلسلٕکۍ لُکھ ،یِم اکھ أکۍ سٕندِ نسلہٕ منٛز زامٕتۍ ٲسۍ، اللہ تعالیٰ چُھ سورُے بوزان تہٕ زانان۔"
  3,35,"۔﴿سُہ اوس تمہِ وقتہٕ بوزان﴾ ییٚلہِ عمران سٕنٛز زٔنۍ وَنان ٲس زِ : میانہِ پروردگارٕ، بہٕ چَھس یہِ شُر یُس مےٚ یٔڈ منٛز چُھ چا نہِ نٲوۍ کران، سُہ آسہِ چا نی کامہِ خٲطرٕ وقف میٲنۍ یہِ پیش کش کر قبول، ژٕ چُھکھ بوزن وول تہٕ زانن وول۔ ﴿اگر عمران سٕنٛز زٔنۍ مُراد نِموعمرا ن سٕنٛز خاندارِنۍ تیٚلہِ نیرِ اَتھ مطلب یہِ زِ یہِ چُھنہٕ سُہ عمران ییٚمۍ سٕنز ذکر پٮ۪ٹھہٕ کنہِ سپز مٕژ چھےٚ بلکہ ٲسۍ یِم حضرت مر یم علیہ السلام سٕندۍ والد یُہُند ناو شا ید عمران آسہِ۔ وۅ نۍ اگر عمران سٕنٛز زٔنۍ مُراد نِمو آلِ عمرا نٕچ زٔنۍ تیٚلہِ نیرِ اَتھ یہِ مطلب زِ حضرت مر یم علیہ السلام سٕنز وٲلدٕ ہ ٲس اَمہِ قبیلٕچ﴾۔"
  3,36,"۔پتہٕ ییٚلہِ تَس سۅ کوٗر زَایہِ تہٕ تمہِ ووٚ ن : میا نہِ مٲلکہٕ ، مےٚ چھےٚ کوٗر زَامٕژ حالانکہ یِکینژھاہ تس زامُت اوس،خُدا یس ٲس تمِچ خبر تہٕ لڑ کہٕ چُھنہٕ کورِ ہٕندۍ پٲٹھۍ آسان۔خیر، مےٚ تھووأمِس مر یم ناو تہٕ بہٕ چَھسن یہِ کوٗر تہٕ أمۍ سُند یِنہٕ وول نسل شیطانِ مردود سٕندِ فتنہٕ نِشہِ چٲنِس پنا ہس منٛز دِوان"
  3,37,"۔ٲخر کار کٔر تَسٕندۍ ربّن یہِ کوٗر خو شی سان قبول، سۅ بنٲوٕن اکھ سٮ۪ٹھاہ رٕژ کوٗر تہٕ زَکَر یا علیہ السلام بنو و ن تٔمۍ سُند سر پرست۔زکر یا علیہ السلام ییٚلہِ کُنہِ وِزِ تَسٕندِس محرا بس اندر اوس گژھان سُہ اوس کانٛہہ نَتہٕ کانٛہہ کھینہٕ چیٚنُک چیز تس نِشہِ وُچھان، پرٛژھان اوسُس مر یم ، یہِ کتہِ پٮ۪ٹھہٕ ووت ژےٚ نِش؟سۅ ٲس جوا ب دِواناللہ تعالیٰ سٕندِ طر فہٕ آو ،اللہ تعالیٰ یس یژھان چُھ تس چُھ بے حسا ب رزِق دِوان ۔"
  3,38,"۔یہِ حال وُچِھتھ لٲے زَکر یا  علیہ السلامن پننِس ربّس  کریٚکھ: ووٚ نُن:  پروردگارٕ، پننہِ قدرت سٍتۍ کر تہٕ مےٚ نیک اولاد عطا ژٕے چُھکھ دُعا بوزن وول۔"
  3,39,"۔در جوا ب چِھ فرشتہٕ آواز دِوان ،ییٚلہِ سُہ محرا بس منٛز کھڑا نماز اوس پرا ن ، زِ : اللہ تعالیٰ چھی ژےٚ یحییٰ علیہ السلام سٕنز خۅش خبر دِوان، سُہ یِیہِ اللہ تعالیٰ سٕندِ طر فہٕ اکہِ فر مانُک تصد یق کر ن وول بٔنِتھ۔﴿اللہ تعالیٰ سٕندِ فر مان  نِشہِ چُھ مُراد حضرت عیسیٰ علیہ السلام۔ چو نکہ تِہِنز پیدٲیش ٲس اللہ تعالیٰ سٕندِ اکہِ زبردست فر مانہٕ سٍتۍ معجز ٲتی طور سپٕز مٕژ۔امہِ موجو ب چُھ تِمن  قرآن مجیدس منٛز کَلِمَتہُ مِنَ اللہ۔وَننہٕ آمُت۔﴾ تس منٛز آسہِ سردٲر ی تہٕ بزر گی ہٕنٛز شا ن، کمال در جُک ضٲبطہٕ آسیٚس ،نبوّت سٍتۍ سپدِ سرفراز تہٕ صا لحینَن منٛز یِیہِ شُمار کر نہٕ۔"
  3,40,"۔زَکر یا علیہ السلامن ووٚن  پروردگإ ، مےٚ کَتہِ بنہِ لڑ کہٕ؟ مےٚ چُھ واریاہ بُجر آمُت تہٕ میٲنۍ خاندارِنۍ چھےٚ ہانٹھ جواب میوٗلُس: یی سپدِ ، ﴿یعنی چا نہِ بُڈٕ آسنہٕ با و جو د تہٕ چانہِ خاندارنہِ ہِندِ ہا نٹھ آسنہٕ باوجود دِی ژےٚ اللہ تعالیٰ لڑ کہٕ ۔ ﴾ اللہ تعالیٰ یِکینژھاہ یژھان چُھ تہِ چُھ کران ۔"
  3,41,"۔عر ض کوٚرُن ، مٲلکہٕ ، تیٚلہِ کر تہٕ میانہِ خٲطرٕ کانٛہہ نشٲنی مقرر۔ وَننہٕ آسنِشٲنی چھےٚ یہِ زِ ژٕ کر کھ نہٕ تر ٮ۪ن دۅ ہن لُکن سٍتۍ اشارٕہ ورٲے کانٛہہ کتھ با تھ ﴿یا ہیٚککھ نہٕ کٔرِتھ﴾ اتھ دوران کٔرِۍ زٮ۪ن پنُن ربّ سٮ۪ٹھاہ یاد تہٕ صبح و شام روٗزِۍ زِ تٔمۍ سٕنز تسبیح کران۔ع"
  3,42,"۔پتہٕ ووت سُہ وقت ییٚلہِ مر یم ﴿علیہا السلامس﴾ نِشہِ فر شتہٕ آے تہٕ ووٚ نہَس اے مر یم علیہ السلام ،خُدا ین کٔر نکھ ژٕ بر گزیدٕہ تہٕ پٲکیز گی کٔر نے عطا تہٕ تمام دنیا چن مستو راتن پٮ۪ٹھ تر جیح دِتھ ژٲرنکھ ژٕ پننہِ خد مت خٲطرٕ،"
  3,43,"۔ اے مر یم علیھاالسلام، پننِس ربّ سٕندِ فر ما نٕچ طٲبع دار بٔنِتھ روز ،تس برونٛہہ کَنہِ سپد سر بسجود ،تہٕ یِم بند ہ تس برونٛہہ کنہِ نمن وٲلۍ چِھ، ژٕ تہِ نَم تِمن سٍتۍ۔"
  3,44,"۔اے نبی صلی اللہ علیہ وسلم، یِم چھےٚ غیب چہِ خبرٕ یِم أسۍ تۅہیہِ و حی ہٕند ذر یعہ وَنان چِھ نَتہٕ ٲسِو تَمہِ وقتہٕ توٚہۍ تَتہِ موجو د ییٚلہِ ہَیکلٕکۍ خٲدِم یہِ فٲصلہٕ کر نہٕ خٲطرٕ زِ مر یم علیہا السلام سُنٛد سر پرست کُس گژِھہ آسُن پنٕنۍ پنٕنۍ قلم ٲسۍ چھکان۔﴿یعنی چیٖرِ ٲسۍ ترٛاوان﴾ تہٕ نہ ٲسِو تمہِ وقتہٕ حٲضر ییٚلہِ تِم پانہٕ وٲنۍ ژُوان ٲسۍ۔"
  3,45,"۔تہٕ ییٚلہِ فر شتَو ووٚ ن : اے مر یم  علیہا السلام،اللہ تعالیٰ چھی ژےٚ پننہِ اکہِ فر مانٕچ خۅ ش خبر دِوان، تَسُند ناو آسہِ مسیح  عیسیٰ ابنِ مر یم، دُنیا ہس تہٕ ٲخرتس منٛز آسہِ مُعزز،اللہ تعالیٰ سٕندٮ۪ن مُقّر ب بند ن منٛز یِیہِ شُما ر کر نہٕ۔"
  3,46,"۔منٛز لِس منٛز تہِ کرِ لُکن سٍتۍ کلام تہٕ بوٚڈ گٔژِھتھ تہِ ،تہٕ سُہ آسہِ اکھ صا لح مرد۔"
  3,47,"۔یہِ بوٗزِ تھ چھےٚ مر یم علیہا السلام ونان : پروردِگارٕ ، مےٚ کتہِ زیوِ شُر مےٚ چُھنہٕ کٲنٛسہِ مَردن اَتھہٕ لوگمُتجواب آس دِنہٕ : ییٖ سپدِ ۔ ﴿یعنی امہِ با وجو د زِ کٲنٛسہِ مردَن چِھی نہ ژےٚ اتھہٕ لوگمُت ، ژےٚ زیٚو ی شُر ﴾ اللہ تعالیٰ یہِ یژھان چُھ  تہِ چُھ پٲدٕ کران ،ییٚلہِ سُہ کُنہِ کامہِ ہندِ کر نُک فٲصلہٕ چُھ کران۔بس چُھ ونان سَپَد تہٕ سۅ چھےٚ سپدان۔"
  3,48,"۔﴿پتہٕ ووٚ ن فر شتو پننِس کلام کِس سلسِلس منٛز﴾ تہٕ اللہ تعالیٰ دِیہِ تس کتاب تہٕ حکمتٕچ تعلیم۔تورات تہٕ انجیلُک علم ہیٚچھنا و یٚس۔تہٕ بنی اسرا یلس کُن کریٚس پنُن رسول مقرر۔"
  3,49,"۔﴿پتہٕ ییٚلہِ سُہ بحیثیتِ رسول بنی اسرا یلس کُن آو تہٕ ووٚ نُن﴾ بہٕ چُھس تُہندِس ربّ سٕندِ طر فہٕ تۅہیہِ نِشہِ نشٲنی ہیٚتھ آمُت، بہٕ چُھس تۅہیہِ برونٛٹھہٕ کنہِ میٚژِ سٍتۍ پر ندہ سٕنزِ شکلہِ ہُنٛد اکھ پُتلہٕ بناوان تہٕ تتھ چُھس پھۅ کھ لایان، سُہ چُھ اللہ تعالیٰ سٕندِ حُکمہٕ سٍتۍ پرندٕ ہ بنان ، بہٕ چُھسَن اللہ تعالیٰ سٕندِ حُکم سٍتۍ زیٚنہٕ گرِ پیٚٹھُک اوٚ ن تہٕ میٚند ۍ لد ٹھیک کران تہٕ تٔمۍ سٕندِ حُکمہٕ سٍتۍ چُھس مُردٕ ہ زندٕ ہ کران۔ بہٕ چُھسو تۅہیہِ ونان زِ توٚہۍ کیا چِھو کھیوان تہٕ کیا چِھو پننیٚن گھر ن منٛز ذخیر ہ کٔرِ تھ تھاوان۔ اَتھ منٛز چھےٚ تُہٕندِ خٲطرٕ کٲفی نِشٲنی ہرگاہ توٚہۍ ایمان وٲلۍ چِھو۔"
  3,50,"۔تہٕ بہٕ چُھس تَتھ تعلیمہِ تہٕ ہدا یتس تصد یق کر ن وول بٔنِتھ آمُت یُس توراتس منٛز وُنۍ کیٚنَس میٲنِس زمانس منٛز مو جو د چُھ تہٕ بیٚیہِ چُھس امہِ موجوٗب آمُت زِ تُہندِ خٲطرٕ کرٕ کینٛہہ تِم چیز حلال یِم تۅہیہِ پٮ۪ٹھ حرام کر نہٕ چِھ آمٕتۍ۔﴿یعنی تُہٕندٮ۪ن جٲہلن ہٕندٮ۪ن تو ہما تن فقہین ہٕندٮ۪ن قا نو نی سنرن تہٕ زٲوِ جار ن ، تُہٕندٮ۪ن رہبا نیت پسند لُکن ہٕنز ن سختی یَن ،تہٕ غیر مُسلم قو من ہٕندِ غلبہٕ تہٕ تسلُط کہ بد و لت یِمن قٲد ن ہُنٛد اضا فہٕ تۅہیہِ منٛز اللہ تعالیٰ سٕندِس اصلی شر یعتس منٛز سپُد مُت چُھ، بہٕ کرٕ تِم منسو خ تہٕ تُہُندِ خٲطرٕ دِمہٕ تِمے چیز حلال تہٕ تِمے چیز حرا م قرار یِم خُدا ین حلال یا حر ام چِھ کٔرۍ مٕتۍ ﴾ وُچھِو ، بہٕ چُھس تُہٕندِس ربّ سٕندِ طر فہٕ تۅہیہِ نِشہِ نشٲنی ہیٚتھ آمُت، لہٰذا کھوژِ و خُدا یس تہٕ میٲنۍ اطا عت کٔرِ و ۔"
  3,51,"۔اللہ تعالیٰ چُھ میو ن ربّ تہِ تہٕ تُہُند ربّ تہِ۔لہٰذا کٔرِ و تٔمۍ سٕنز ے بند گی، یہِ چھےٚ سِیٔز وَتھ۔"
  3,52,"۔ییٚلہِ عیسیٰ علیہ السلامن محسو س کوٚر زِ بنی اسرا یل چِھ کُفرس تہٕ انکارس پٮ۪ٹھ آما دٕ ہ پتہٕ ووٚ ن تٔمۍ  کُس بَنہِ اللہ تعالیٰ سٕنزِ وَتہِ منٛز میو ن مددگار؟ حوارِ یَو دِیُت جوا ب  أسۍ چِھ اللہ تعالیٰ سٕندۍ مددگار،﴿حوٲر ی لفظ چُھ تقر یباً سُے معنی تھاوان یُسانصا ر لفظُک مفہو م چُھ۔أسۍ چِھ اللہ تعالیٰ سٕندۍ مددگار اَمِیُک مطلب چُھ زِ اللہ تعالیٰ سٕنزِ کامہِ منٛز چِھ أسۍ تۅہیہِ مددگار﴾ اَسہِ اوٚ ن خُدا یس پٮ۪ٹھ ایمان ،توٚہۍ روٗزِ و گواہ زِ أسۍ چِھ مُسلم﴿خُدا یس برونٛہہ کنہِ اطا عتُک کلہٕ نوٚ مرا وَ ن وٲلۍ﴾۔"
  3,53,"۔سا نہِ مالکہٕ ، یُس فر مان ژےٚ نازِ ل چُھے کوٚر مُت، اَسہِ کوٚر سُہ تسلیم تہٕ رسول سٕنز پیر وی کٔر قبول، سو ن ناو لیکھ گوٲہی دِنہٕ والیٚن منٛز ۔"
  3,54,"۔پتہٕ لاجہِ بنی اسر ایلو ﴿مسیحس خلا ف ﴾  خفیہ تدبیر کر نہِ ۔ در جوا ب کٔر خُدا ین تہِ پنٕنۍ خُفیہ تد بیر تہٕ  یِژھن تد بیرٕ ن منٛز چُھ اللہ تعالیٰ سارِنٕے سَرس ۔ع ۔﴿سۅ ٲس اللہ تعالیٰ سٕنز خُفیہ تد بیر ے﴾"
  3,55,"۔ییٚلہِ تٔمۍ ووٚ ن زِ : اے عیسیٰ علیہ السلام، وۅ نۍ نِمتھ بہٕ ژٕ وا پس تہٕ تُلُتھ پانس کُن ﴿در اصل چُھ لفظ مَتَو فِّیک ورتاو نہٕ آمُت۔تَوَ فِّی۔ہُک اصلی معنی چُھ رَٹنُک تہٕ وصو ل کر نُک۔ رُو ح قبض کرُنچُھ امہِ لفظُک مجٲزی استعمال نَہ زِ اصلی لغو ی معنی﴾ تہٕ یِمو چو ن اِنکار چُھ کوٚر مُت تِمو نِشہِ ﴿یعنی تِمن تہٕ تِہندِس گند ہ ماحو لس منٛز تِمن سٍتۍ روزنہٕ نِشہِ ﴾ کر تھ بہٕ پاک تہٕ چٲنۍ پیر وی کر ن وٲلۍ تھاو کھ قیا متس تام تِمن لُکن پٮ۪ٹھ بالادست ،یِمو ژےٚ انکار چھےٚ کوٚر مُت پتہٕ چُھو تۅہیہِ سارِنٕے ٲخر کار مےٚ نِش واتُن تمہِ وقتہٕ کرٕ بہٕ تِمن کتھن ہُند فٲصلہٕ یِمن منٛز تۅہیہِ در میان اختلا ف چُھ سپُد مُت۔"
  3,56,"۔یِمو لُکو کُفر تہٕ انکا رٕچ رٔوِش اختیار چھےٚ کٔر مٕژ۔تِمن دِمہٕ دُنیا ہس تہٕ ٲخرتس دۅ شوٕنۍ  منٛز سخت سزا۔تہٕ تِم وُچھن نہٕ کانٛہہ مددگار۔"
  3,57,"۔تہٕ یِمو ایمان تہٕ نیک عملی ہُند رٔوِیہِ اختیار چُھ کوٚر مُت تِمن یِن تِہِندۍ اجر پوٗرٕ پوٗرٕ دِنہٕ تہٕ ﴿وارٕ پٲٹھۍ زٲنِو زِ ﴾ ظٲلِمن سٍتۍ چُھنہٕ اللہ تعالیٰ ہر گز محبت کران ۔"
  3,58,"۔ اے نبی صلی اللہ علیہ وسلم ، یِم چِھ آیا ت تہٕ حکمت سٍتۍ لبر یز تذکرٕ ہ یِم أسۍ توٚہۍ بوزناوان چِھو۔"
  3,59,"۔خُدا یس نز دیک چھےٚ عیسیٰ علیہ السلام سٕنز مثا ل آد م علیہ  السلام سٕنز ہِش، خُدا ین کوٚر سُہ میژِ پٲدٕ  تہٕ  حُکم دِیتُنَس سپَد تہٕ سُہ سپُد۔﴿یعنی اگر محض مٲلۍ سٕندِ ورٲے پٲدٕ سپُد نُے کٲنٛسہِ خُدا ے یا خُدا ے سُنٛد نیچُو بناو نہٕ خٲطرٕ دلیل آسہِ کٲفی تیٚلہِ پَزِ ہے عیسا ین آد مس علیہ السلامس متعلق تھٔدِ س در جس پیٚٹھ یُتھ عقیدٕ ہ تجو یز کرُن ، تِکیازِ مسیح اوس صرف مالہِ ورٲے زامُت ، مگر آد م علیہ السلام زاو مٲلِس تہٕ ماجہِ دۅ شوٕ نۍ ورٲے﴾۔"
  3,60,"۔یہِ چھےٚ اصلی حقیقت یۅسہٕ تُہٕندِس ربّ سٕندِ طر فہٕ وَننہٕ چھےٚ یِوان تہٕ توٚہۍ مہ گٔژِھو تِمن لُکن منٛز شٲمل یِم اتھ منٛز شک چِھ کران ۔"
  3,61,"۔یہِ علم یِنہٕ پتہٕ یُس کانٛہہ اکھا وۅ نۍ اتھ  معا ملس منٛز تۅہیہِ سٍتۍ جھگڑٕ کرِ اے نبی صلی اللہ علیہ وسلم، تیٚلہِ وَنوِ تس زِ  وَلہٕ بہٕ تہٕ ژٕ یِمو پانہٕ تہِ تہٕ پنٕنۍ شُر ۍ بٲژ تہِ اَنو کھ تہٕ خُدا یس مَنگو دُعا زِ یُس اَپزِ یو ر آسہِ تس پٮ۪ٹھ ٲسِن اللہ تعالیٰ سٕنز لعنت۔"
  3,62,"۔یِم چِھ با لکل صحیح وا قعات تہٕ حقیقت چھےٚ یہِ زِ اللہ تعالیٰ ہَس ورٲے چُھنہٕ کانٛہہ خُدا و ند تہٕ سۅ چھےٚ اللہ تعالیٰ سٕنزٕ ے ہستی ،ییٚمۍ سُند طا قت سارِوٕے کھۅتہٕ بالا چُھ تہٕ ییٚمۍ سٕنز حکمت عا لم کِس نظا مس اندر کار فر ما چھےٚ ۔"
  3,63,"۔وۅ نۍ اگر یِم لُکھ ﴿اَتھ شر طس پٮ۪ٹھ برونٛٹھ کُن یِنہٕ نِشہِ ﴾ بُتھ پھِر ن ﴿تیٚلہِ سپدِ تِہُند فسٲدۍ آسُن صا ف ظا ہر﴾ تہٕ اللہ تعالیٰ چُھ فسا دٮیٚن ہُنٛد حال وارٕ پٲٹھۍ زانان۔ع"
  3,64,"۔ اے نبی صلی اللہ علیہ وسلم ، ؤنِو ، اے اہلِ کتاب ؤلِو أکِس تِژھہ کتھہِ کُن یۅسہٕ تۅہیہِ تہٕ اَسہِ در میان ہِشی چھےٚ یہِ زِ أسۍ کر و نہٕ خُدا یس ورٲے کٲنٛسہِ ہٕنز بند گی تس سٍتۍ کر و ن نہٕ کانٛہہ شر یک تہٕ اَسہِ منٛزٕ مَہ بنٲوِن کانٛہہ کٲنٛسہِ پنُن ربّ، یہِ دعوت قبول کر نہٕ نِشہِ ہرگاہ تِم بُتھ پھِر ن تیٚلہِ ؤنیوٗکھ صا ف زِ گواہ روٗزِ و أسۍ چِھ مُسلم ﴿یعنی صرف اللہ تعالیٰ سٕنز بند گی تہٕ اطا عت کر ن وٲلۍ ﴾۔"
  3,65,"۔اے اہلِ کتا ب توٚہۍ کیا زِ چِھو ابرا ہیم سٕندِس ﴿دین کِس﴾ با رس منٛز ژُوان؟ تورات تہٕ انجیل چھےٚ ابراہیم ﴿علیہ السلامس ﴾ پتہٕ نٲزِل گٔمژٕ تیٚلہِ کیا زِ چِھونہٕ  توٚہۍ یہِ کتھ سمجھان ۔"
  3,66,"۔تۅہیہِ لُکن یِمن چیز ن ہُند علم چُھو تِمن  منٛز کٔرِ و تۅہیہِ سٮ۪ٹھاہ بحث وۅ نۍ کیا زِ چِھو تِمن معا ملاتن منٛز بحث کر نہِ درٛا مٕتۍ یِمن متعلق تۅہیہِ رَژھ تہِ علم چُھنہٕ اللہ تعالیٰ چُھ زانان، توٚہۍ چِھو نہٕ زانان۔"
  3,67,"۔ابرا ہیم علیہ السلام نَہ اوس یہو د ی تہٕ نہ اوس عیسٲے بلکہ اوس سُہ مُسلم یکسوٗ ۔﴿درا صل چُھ لفظحنیف استعمال سپُد مُت ، امہِ نِشہِ چُھ مُراد سُہ شخص یُس پرٛتھ طر فہٕ بُتھ پھِرِ تھ أکِس خا ص وَتہِ پٮ۪ٹھ پکہِ۔ یۅ ہےمفہوٗم چُھ مسلم یکسوٗ  ادا کران﴾ تہٕ سُہ اوس نہٕ ہر گِز مُشرِ کو منٛزٕ۔"
  3,68,"۔ ابراہیم ﴿علیہ السلامس﴾ سٍتۍ نسبت تھاو نُک سارِ وٕے کھۅتہٕ زیادٕہ حق ہرگاہ کٲنٛسہِ واتان چُھ تیٚلہِ چُھ تِمن لُکن واتان یِمو تٔمۍ سٕنز پیر وی کٔر تہٕ وۅ نۍ چُھ یہِ نبی صلی اللہ علیہ وسلم  تہٕ أمۍ سٕندۍ مانن وٲلۍ امہِ نسبتٕکۍ زیادہ حقدار، اللہ تعالیٰ چُھ صرف تِمن لُکن ہُند حٲمی تہٕ مددگار یِم ایمان وٲلۍ آسن۔"
  3,69,"۔﴿اے ایمان اَنن والیو ﴾اہلِ کتا بَو منٛزٕ چُھ اکھ دوٚر یژھان زِ کُنہِ پٲٹھۍ ڈا لیو تۅہیہِ سُہ سیٚزِ وَتہِ نِشہِ حالانکہ تِم چِھنہٕ در حقیقت پا نس ورٲے  بیٚیہِ کٲنٛسہِ گُمرٲہی منٛز تراوان مگر تِمن چُھنہٕ اَمِیُک شعور۔"
  3,70,"۔اے اہل کتاب کیا زِ چِھو اللہ تعالیٰ سٕند ٮ۪ن آیا تن انکار کران حالانکہ توہۍ چِھو خو د یِمن ہُنٛد مشٲہدٕ کران۔﴿دوٚ یِم تر جمہٕ ہیکہِ اَمِیُک یِتہِ ٲسِتھ زِ توٚہۍ چِھو پانہٕ تہِ گوٲہی دِوان ۔ دۅ شوٕ نۍ صوٗرتن منٛز چُھنہٕ معنی یَس کانٛہہ اثر پیٚوان ۔نبی صلی اللہ علیہ وسلمن ہٕنز پٲکیز زند گی ، تہٕ صحا بہ کرِ امن ہٕنز ن زند گی یَن پٮ۪ٹھ تِہندِ تعلیم وتر بیتٕکۍ حیر ت انگیز اثرا ت، تہٕ تِم بُلند پایہِ مضمو ن یِم قرآنس منٛز ارشاد سپدان ٲسۍ،در اصل ٲسۍ یِم سٲر ی چیز اللہ تعالیٰ سٕند تِتھۍ روشن آیات زِ یُس شخص انبیا علیہ السلامن ہٕندٮ۪ن احوا لن تہٕ آسمٲنۍ کتا بن ہٕندِ طر زٕ نِشہِ وٲقف  آسہِ ہے ، تس خٲطرٕ اوس یِمن آیاتن وُچِھتھ حضور صلی اللہ علیہ وسلمن ہٕندِس نبوّ تس پٮ۪ٹھ شک کرُن سٮ۪ٹھاہ مُشکل۔﴾"
  3,71,"۔کیا زِ چِھو حق بٲطلُک رنگ کھٲلِتھ شکہٕ لد بناوان؟ کیا زِ  چِھو زٲنِتھ مٲنِتھ حق چُھپا وان ؟ ع"
  3,72,"۔اہلِ کتا بو منٛزٕ چُھ اکھ دوٚر وَنان زِ أمِس نبی یَس مانن والیٚن پٮ۪ٹھ یِکینژھاہ نٲزِل چُھ سپُد مُت تتھ پٮ۪ٹھ أنِو صُبحٲے ایمان تہٕ شا مس کٔرِ و تتھ انکار ،شاید پھیرن یِم لُکھ امہِ تر کیبہِ سٍتۍ پننہِ ایمان نِشہِ ،"
  3,73,"۔بیٚیہِ چِھ یِم لُکھ پانہٕ وٲنۍ ونان زِ پننِس مذ ہب دارٕ سٕندِ ورٲے مٲنۍ زیٚو نہٕ بیٚیہِ کٲنٛسہِ ہٕنز کتھ ،اے نبی  صلی اللہ علیہ وسلم، یِمن ؤنِو زِ :  در اصل چُھ ہدا یت اللہ تعالیٰ سُند ہدا یت تہٕ یہِ چُھ تٔمۍ سُندُے دِیُت زِ کٲنٛسہِ یِیہِ تی کینژھاہ دِنہٕ یہِ کُنہِ وِزِ تۅہیہِ اُو سُو دِنہٕ آمُت  ،یایہِ زِ دوٚ یِمیٚن میلہِ تۅہیہِ خلا ف تُہندِ س ربّ سٕندِس  در بارس منٛز پیش کر نہٕ خٲطرٕ مضبوط  حُجت اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو زِ :  فضل تہٕ شر ف چُھ اللہ تعالیٰ سٕندِ س اختیارس منٛز یَس یِژھہ تس کرِ عطا ،اللہ تعالیٰ سٕنٛز نظر چھےٚ سٮ۪ٹھاہ وسیع ،تہٕ سُہ چُھ سورُے کینٛہہ زانان۔﴿در اصل چُھ لفظ واسع استعمال سپُد مُت یُس با لعمو م قرآنس اندر تر ٮ۪ن مو قعن پٮ۪ٹھ چُھ یِوان ۔ اکھ سُہ مو قع یتھ جایہِ انسانن ہٕندِ کُنہِ دَر چہِ تنگ خیٲلی تہٕ تنگ نظر ی ہٕنز ذِکر چھےٚ یِوان تہٕ تس چھےٚ اتھ حقیقتس پٮ۪ٹھ مُتنبہ ﴿خبردار﴾ کر نٕچ ضر ورت پیش یِوان زِ اللہ تعالیٰ چُھنہٕ تُہٕندۍ پٲٹھۍ تنگ نظر۔دوٚیُم چُھ سُہ مو قع ییٚلہِ کٲنٛسہِ ہٕندِس بخلس، تنگ دلی تہٕ کم حو صلگی پٮ۪ٹھ ملا مت کٔرِ تھ یہِ وَنُن چُھ آسان زِ اللہ تعالیٰ چُھ فر اخ دست ،تُہٕندۍ پٲٹھۍ چُھنہٕ بخیل۔ترٛییُم چُھ سُہ مو قع ییٚلہِ لُکھ پننہِ تخیّل چہِ تنگی ہٕندِ وجہ کِنۍ خُدا یس کُن کُنہِ قسمٕچ محد ودیت منسوٗب چِھ کران تہٕ تِمن چُھ یہِ وَنُن آسان زِ اللہ تعالیٰ چُھ غیر محدود ﴾۔"
  3,74,"۔پننہِ رحمت خٲطرٕ یس یژھان چُھ تس چُھ مخصو ص کران۔تہٕ تٔمۍ سُند فضل چھُ سٮ۪ٹھاہ بوٚڈ۔"
  3,75,"۔ اہلِ کتا بو منٛزِٕ چُھ کانٛہہ تِیُتھ تہِ زِ ہرگاہ توٚہۍ تٔمۍ سٕنٛدِس بھروسس پٮ۪ٹھ مال و دولتُک اکھ ڈھیر تہِ دِیِو سُہ کر تُہُند مال تۅہیہِ وا پس تہٕ کٲنٛسہِ ہُند حال چُھ یہِ زِ اگر توٚہۍ أکِس دینا ر کِس معا ملس منٛز تہِ تس پٮ۪ٹھ بھر وسہٕ کٔرِ و  سُہ دِیَو نہٕ واپس اِلاّ یہِ زِ توٚہۍ گٔژِھو تس کلس پٮ۪ٹھ سوار ،تِہِند اَمہِ اخلا قی حا لتُک وجہ چُھ یہِ زِ تِم چِھ ونان : اُمیّن ﴿غیر یہو د ی  لُکن ﴾ ہٕندِس معاملس پٮ۪ٹھ چَھنہٕ اَسہِ پرٕژھ گٲر تہٕ یہِ کتھ چِھ تِم محض اَپُز بنٲوِ تھ خُدا یس کُن منسوٗب کرا ن  حالانکہ تِمن چُھ معلو م ﴿زِ خُدا ین چَھنہٕ یِژھہ کانٛہہ کتھ فر مٲومٕژ﴾۔"
  3,76,"۔ٲخر کیا زِ سپدِ نہٕ تِمن پرٕژٕھہ گٲر؟ یُس تہِ پَنُن عہد پوٗرٕ کرِ تہٕ بُرٲیی نِشہِ روزِ بٔچِتھ ۔سُہ بنہِ اللہ تعالیٰ سُند ٹو ٹھ تِکیازِ پر ہیز گا ر لُکھ چِھ خدا یس پسند ۔"
  3,77,"۔روٗدۍ وۅ نۍ تِم لُکھ یِم اللہ تعالیٰ سُند عہد تہٕ پنٕنۍ قسم کمس قٍمتس پٮ۪ٹھ چِھ کٕنان تِمن خٲطرٕ چُھنہٕ ٲخرتس اندر کانٛہہ حصہٕ ،اللہ تعالیٰ نہ کرِ قیا مت کہِ دۅ دٕ ہ تِمن سٍتۍ کتھ، نہ وُچِھہ تِمن کُن تہٕ نہ کرِ تِمن پاک بلکہ چُھ تِہندِ خٲطرٕ سخت دگ تُلوُن عذا ب۔"
  3,78,"۔تِمن منٛز چِھ کینٛہہ لُکھ تِتھۍ یِم کتا ب پران پران تِتھہٕ پٲٹھۍ چِھ زیٚو پھِران زِ توٚ ہیہِ با سیو یِکینٛژھا ہ تِم پران چِھ سۅ چھےٚ کتا بہِ ہٕنٛزٕ ے عبا رت حالانکہ چَھنہٕ سۅ کتا بہِ ہٕنز عبا رت آسان۔ تِم چِھ وَنان یہِ کینٛژھاہ أسۍ پران چِھ یہِ چُھ اللہ تعالیٰ سٕندِ طر فہٕ حالانکہ چُھنہٕ سُہ اللہ تعالیٰ سٕندِ طر فہٕ آسان تِم چِھ زٲنِتھ مٲنِتھ اَپزٕ کتھ خُدا یس کُن منسو ب کرا ن۔"
  3,79,"۔کٲنٛسہِ انسان سٕنز کٲم چَھنہٕ یہِ زِ اللہ تعالیٰ کرِ تس کتا ب تہٕ حُکم تہٕ نبوّت عطا تہٕ سُہ وَنہِ لُکن زِ خُدا یس ورٲے بٔنِو توٚہۍ میٲنۍ بندٕ ہ سُہ ونہِ یٖی زِ پٔزۍ ربّٲنۍ بٔنِو یِتھہٕ پٲٹھۍ زَن تمہِ کتا بہِ ہٕنٛزِ تعلیمہِ ہُنٛد تقا ضہٕ چُھ  یوسہٕ توٚہۍ پرا ن تہٕ پرناوان چِھو ۔"
  3,80,"۔سُہ وَنہِ نہٕ ہر گز تہِ تۅہیہِ یہِ زِ فرشتہٕ یا پیغمبر بنٲوِ یوٗکھ پنٕنۍ ربّ ،کیا یہِ چھا ممکن زِ اکھ نبی دِیو تۅہیہِ کُفرُک حُکم ییٚلہِ زَ ن توٚہۍ مُسلم چِھو ؟ع"
  3,81,"۔یاد کٔرِو، خُدا ین اوس پیغبر ن عہد ہیوٚتمُت زِ : اَز چِھو مےٚ توٚہۍ کتا بہِ سٍتۍ تہٕ حکمت تہٕ دانٲیی سٍتۍ نوٲزِ مٕتۍ پگا ہ اگر کانٛہہ بیاکھ رسول تۅہیہِ نِشہِ تمی تعلیمہِ ہُند تصد یق کرا ن یِیہِ یۅسہٕ گۅڈ ے تۅہیہِ نِشہِ موجود چھےٚ تیٚلہِ آسیو تۅہیہِ تتھ پٮ۪ٹھ ایمان اَنُن تہٕ تس آسیو مدد کرُن ۔ ﴿مطلب چُھ یہِ زِ پرٛتھ پیغمبر س چُھ اَمہِ کتھہِ ہُند عہد ہیٚنہٕ آمُت۔یتھ جایہِ چھےٚ یہِ کتھ ہنا بیٚیہِ سمجھِنۍ زِ حضرت محمد صلی اللہ علیہ وسلمن برونٛٹھ چُھ پرٛتھ نبیس یۅ ہے عہد ہیٚنہٕ آمُت تہٕ أتھۍ بُنیا دس پٮ۪ٹھ چھےٚ پرٛتھ نبیَن پننِس اُمتس یِنہٕ وٲلِس نبی سٕنز خبر دِژ مٕژ تہٕ تس سا تھ دِنُک ہدا یت کوٚر مُت۔البتہ نَہ چُھ قرآنس اندر نہ حدیثن منٛز کُنہِ تہِ جایہِ امہِ کتھہِ ہُنٛد پے لگا ن زِ حضرت محمد صلی اللہ علیہ وسلمس کیا چُھ اَمہِ قسمُک کانٛہہ عہد ہینہٕ آمُت یا تِمو کیا چُھ پننِس اُمتس کٲنٛسہِ یِنہٕ وٲلِس نبی سٕنز خبر دِتھ تس پٮ۪ٹھ ایمان اَنُنک ہدا یت دِیتمُت ۔ بلکہ چُھ قرآنس اندر صراحت سان حضور صلی اللہ علیہ وسلمن خا تم انبین صلی اللہ علیہ وسلم  فر ما و ہٕ آمُت تہٕ واریاہن حد یثن اندر چُھ حضور صلی اللہ علیہ وسلمو فر مو و مُت زِ تِمن پتہٕ چُھنہٕ کانٛہہ نبی یِنہٕ وول۔﴾ یہِ ارشاد فر مٲوِتھ پرٛ وژھ خُدا ین : کیا توٚہۍ چِھوٕ ہ اَمِیُک اقرار کران تہٕ اَتھ پٮ۪ٹھ چِھوٕ ہ میانہِ طر فہٕ عہدٕ چ گوٚ ب ذمہٕ دٲر ی رٹا ن ؟ تِمو ووٚ ن : آ، أسۍ چِھ اقرار کران۔ خُدا ین فر مو و : اچھا تیٚلہِ روٗزِ و گواہ تہٕ بٕتہِ چُھس تۅہیہِ سٍتۍ گواہ"
  3,82,"۔امہِ پتہٕ یُس پننِس عہد س پھیرِ سُے چُھ فٲسِق۔"
  3,83,"۔وۅ نۍ کیا یِم لُکھ چھا اللہ تعالیٰ سٕندِ اطا عتُک طر یقہٕ ﴿دین اللہ ﴾ ترٲوِ تھ بیٚیہِ کانٛہہ طر یقہٕ یژھان؟ حالانکہ آسما نٕکۍ تہٕ زمینٕکۍ سٲر ی چیز چِھ چا ر ونا چار اللہ تعالیٰ سٕندِی فر مانٕکۍ طا بع ﴿مُسلم﴾ تہٕ تٔسۍ کُن چُھ سارِنٕے وا پس پھیرُن"
  3,84,"۔اے نبی صلی اللہ علیہ وسلم، ؤنِو زِ  أسۍ چِھن اللہ تعالیٰ مانان ، سۅ تعلیم چِھ مانان یۅسہٕ اَسہِ پٮ۪ٹھہٕ نٲزِل چھےٚ آمٕژ کر نہٕ  تِم تعلیمات تہِ چِھ مانان یِم ابرا ہیم علیہ السلام، اسما عیل علیہ السلام،اسحا ق علیہ السلام، یعقو ب علیہ السلام تہٕ اولادِ یعقو ب بس علیہ السلامس پٮ۪ٹھ نٲزِل ٲسۍ سپٕدۍ مٕتۍ  تہٕ تِمن ہدا یاتن پٮ۪ٹھ تہِ چِھ ایمان تھاوان یِم موسیٰ علیہ السلام تہٕ عیسیٰ علیہ السلام تہٕ با قی پیغمبر ن تِہندِس ربّ سٕندِ طر فہٕ دِنہٕ آے، أسۍ چِھنہٕ تِمن در میان فر ق کرا ن تہٕ أسۍ چِھ اللہ تعالیٰ سٕندۍ فر مان بردار ﴿مُسلم ﴾"
  3,85,"۔اَمہِ فرمان بردٲری ﴿اسلام﴾ ورٲے یُس شخص بیٚیہِ کانٛہہ طر یقہٕ اختیار کرُن ییٚژِھہ تٔمۍ سُند سُہ طر یقہٕ یِیہِ نہٕ ہر گز قبو ل کر نہٕ تہٕ ٲخرتس منٛز روزِ سُہ نا کام تہٕ نا مُراد۔"
  3,86,"۔کِتھہٕ پٲٹھۍ چُھ ممکن زِ اللہ تعالیٰ بخشہِ تِمن لُکن ہدا یت یِمو ایمانٕچ نعمت حٲصل سپٕد نہٕ پتہٕ نوِ سرٕ کفر کوٚر حالانکہ تِمو چھےٚ اتھ کتھہِ پٮ۪ٹھ پانہٕ گوٲہی دِژمٕژ زِ یہِ رسول چُھ حقس پٮ۪ٹھ تہٕ تِمن نِشہِ چھےٚ ٹا کارٕ نِشٲنیہِ تہِ آمژٕ اللہ تعالیٰ چُھنہٕ ظٲلِمن ہدا یت دِوان ۔"
  3,87,"۔تِہندِ ظُلمُک صحیح بد لہٕ چُھ یٖی زِ تِمن پٮ۪ٹھ چھےٚ اللہ تعالیٰ سٕنز تہٕ فر شتن ہٕنز تہٕ تمام انسانن ہٕنز لعنت۔"
  3,88,"۔ أتھۍ حا لتس منٛز روزن تِم ہمیشہ ،نہ گژِھہ تِہندِ س عذا بس منٛز کمی تہٕ نہ یِیہِ تِمن مہلت دِنہٕ"
  3,89,"۔البتہ بچن تِم لُکھ یِم امہِ پتہٕ تو بہٕ کٔرِ تھ پننہِ  طر زِ عملُک اصلا ح کرن اللہ تعالیٰ چُھ بخشن وول تہٕ رحم کر ن وول۔"
  3,90,"۔مگر یِمو لُکو ایمان اَننہٕ پتہٕ کُفر پاننو و ، پتہٕ روٗدۍ پننِس کُفر س منٛز برونٛٹھ پکان۔﴿یعنی تِمو کوٚر نہٕ انکار سٕے یوت پٮ۪ٹھ بس بلکہ کٔرٕکھ عملی طور مخا لفت تہٕ مزا حمت تہِ ، اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ لُکھ رُکا و نہٕ خٲطرٕ لگو وُکھ حدٕ کھۅتہٕ زور، شبہا ت کٔرِ کھ پٲدٕ، بد گُما نیہِ پھٔہلا و یٛکھ ، دِلن منٛز ترٛ ٲوِکھ وَسو سہٕ تہٕ بدتر ین سٲزِ شہِ تہٕ فساد کٔرِ کھ پٲدٕ تاکہ نبی صلی اللہ علیہ وسلمن ہُنٛد مِشن گوٚژھ نہٕ کُنہِ پٲٹھۍ کامیا ب سپدُن﴾"
  3,91,"۔تِمن ہُند تو بہٕ گژِھہ نہٕ ہر گز قبول یِتھۍ لُکھ چِھ پکہٕ گمرٲہ۔ یقین تھٲوِ و یِمو لُکو کُفر پا ننو و،تہٕ کفرٕ کِسٕے حا لتس منٛز دِیتُکھ زُو تِمو منٛزٕ ہرگاہ کانٛہہ پنُن پان سزا نِشہِ بچا و نہٕ خٲطرٕ رو ے زمینس یو ت تہِ سۅ ن فِدیس منٛز دِیہِ تہٕ سُہ یِیہِ نہ قبول کر نہٕ، یِتھیٚن لُکن خٲطرٕ چُھ دگ تُلوُن عذا ب تیار تہٕ تِم لبن نہٕ پنُن کانٛہہ مدد گار ۔ ع"
  3,92,"۔توٚہۍ ہیٚکِوۍ نہٕ نیکی تام وٲتِتھ یٚوت تام نہٕ پنٕنۍ تِم چیز ﴿اللہ تعالیٰ سٕنزِ وَتہِ منٛز﴾ خر چ کٔرِ و یِم تۅہیہِ ٹٲٹھۍ چِھو تہٕ یِکینٛژھاہ توٚہۍ خر چ کٔرِ و اللہ تعالیٰ آسہِ نہٕ تمہِ نِشہِ بے خبر ۔"
  3,93,"۔کھیٚنٕکۍ یِم سٲ ری چیز ﴿یِم شر یعتِ محمدی یَس منٛز حلال چِھ ﴾ ٲسۍ بنی اسرا یلس خٲطرٕ تہِ حلال ، ﴿قرآنس تہٕ محمد صلی اللہ علیہ وسلمن ہٕندِٮ۪ن تعلیماتن پٮ۪ٹھ ییٚلہِ یہوٗدۍ عٲلِم کانٛہہ اصو لی اعترا ض ہیٚکۍ نہٕ کٔرِ تھ﴿تِکیازِ دین چہِ بنیا دٕ یِمن کتھن پٮ۪ٹھ چھےٚ تِمن منٛز ٲس نہٕ سٲبق انبیا ہن ہٕنز ن تعلیماتن تہٕ نبی عر بی صلی اللہ علیہ وسلمن ہٕنزِ تعلیمہِ اندر رَژھ تہِ فر ق ﴾ پتہٕ کٔرۍ تِمو فقہی اعترا ضا ت شر وع۔اتھ سلسلس منٛز اوس تِہُند گۅڈنیُک اعتراض یہِ زِ تۅہیہِ چِھو کھینہٕ چینٕکۍ کینٛہہ چیز حلال قرار دِتمِٕتۍ یِم پٔتِمیٚن انبیا ہن ہٕندِ زمانہٕ پٮ۪ٹھہٕ اَز تام حرا م چِھ۔ اَمی اعترا ضُک جوا ب چُھ یتھ جایہِ دِنہٕ یِوان ۔ یِتھے پٲٹھۍ اوس تِہُند اکھ اعتراض یِتہِ زِ بیت المُقدس ترٲوِ تھ کیازِ آو خا نہ کعبہ قبلہٕ بناو نہٕ۔ اَمہِ پتٕکۍ آیات چِھ اَمہِ کِسٕے جوابس منٛز۔﴾البتہ کینٛہہ چیز ٲسۍ تِتھۍ یِم توراتہ نٲزِل کر نہٕ برونٛٹھ اسرا یل ﴿حضرت یعقو ب علیہ السلامن﴾ خۅد پا نس پٮ۪ٹھ حر ام ٲسۍ کٔرِ مٕتۍ یِمن ؤنِو ،ہر گاہ توٚہۍ ﴿پننِس اعترا ضس منٛز﴾ پٔزِیٲرۍ چِھو تیٚلہِ أنِو توراتہ تہٕ  پیش کٔرِ و تمِچ کانٛہہ عبارت"
  3,94,"۔امہِ  پتہٕ تہِ یِم لُکھ پننہِ بنا و نہٕ آمژٕ اَپزٕ کتھہٕ خُدا یس کُن منسو ب کرا ن روزن  تِمے چھِ در حقیقت ظٲلِم ،"
  3,95,"۔ؤنِو، خُدا ین یِکینٛژھاہ فر مو و مُت چُھ، پوٚز چُھن فر مو و مُت، تۅہیہِ پز یو یکسوٗ سپدِ تھ ابرا ہیم علیہ السلام سٕندِ طر یقٕچ پیر وی کرٕنۍ تہٕ ابرا ہیم علیہ السلام اوس نہٕ شر ک کر ن والیو منٛزٕ۔"
  3,96,"۔بے شک یُس سارِوٕے برونٛٹھِم عبا دت گاہ انسانن خٲطرٕ تعمیر سپُد چُھ سُے یُس مکس اندر وا قع چُھ ،اَتھ ٲس خیر و بر کت دِنہٕ آمٕژ تہٕ تمام دنیا والیٚن خٲطرٕ اوس ہدا یتُک مر کز بناو نہٕ آمُت"
  3,97,"۔ اَتھ منٛز چھےٚ ٹا کارٕ نِشٲنیہِ ،﴿یعنی اَتھ گھرس اندر چِھ تِتھۍ ٹا کارٕ ہ علا مات لبنہٕ یِوان یِمو سٍتۍ ثٲبت چُھ سپدان زِ یہِ   چُھ اللہ تعالیٰ سٕندِس در بارس اندر مقبو ل سپُد مُت تہٕ یہِ چُھ خُدا ین پننہِ گھرٕ کہ حیثیتہٕ رٔنگۍ پسند فر مو و مُت۔وٲران ریگستانس منٛز آو بناو نہٕ تہٕ اَمہِ پتہٕ کوٚر خُدا ین اَتھ أندۍ پٔکۍ روزن والیٚن خٲطرٕ رز ق رسٲنی ہُنٛد بہتر کھۅتہٕ بہتر انتظام ۔ڈا ین سا سن ؤرِین روٗد جا ہلیت کہ وجہ کِنۍ سورُے ملکِ عر ب انتہٲیی بد امنی ہٕندِس حالتس اندر مبتلا ،مگر اَتھ فساد وٲلِس سر زمینس منٛز اوس کعبہ تہٕ کعبُک اوٚ ند پوٚ کُے تِیُتھ یتھ منٛز اَمن قٲیِم روٗد۔ بلکہ ٲس اَمی کعبٕچ یہِ بر کت زِ پوٗرٕ ؤری کیٚن ژۅ ن ریٚتن اوس پوٗرٕ مٕلکس اَمہِ کی بد و لتہٕ اَمن حٲصل سپدان۔امہِ پتہٕ اوس وُنہِ نصف صد ی برونٛہہ سارِوٕیَو وُچھمُتھ زِ اَبر ہہ ہن ییٚلہِ کعبہ کہ تخر یب خٲطرٕ مکس پٮ۪ٹھ حملہٕ کوٚر تہٕ تٔمۍ سُند فو ج کِتھہٕ پٲٹھۍ سپُد اللہ تعالیٰ سٕندِ قہرُک شکار۔اَمہِ وا قعہ نِشہِ اوس عر بُک بچہِ بچہِ وٲقف تہٕ اَمکۍ چشم دید گواہ ٲسۍ یِمن آیاتن ہٕندِ نٲزِل سپد نہٕ وقتہٕ موجو د ۔﴾یہِ چُھ ابراہیم علیہ السلام سٕندِ عبا دتُک مقا م تہٕ اَمِیُک حال چُھ یہِ زِ یُس اَتھ منٛز دٲخل سپُد تٔمۍ لوٚب اَمن، لُکن پٮ۪ٹھ چُھ اللہ تعالیٰ سُند یہِ حق زِ یُس اتھ گھرس تام وا تنُک استطا عت  ،یعنی طا قت ﴾ تھاوان آسہِ، سُہ کٔرِن اَمِیُک حج تہٕ یُس اکھا ہ امہِ حُکمہٕ چِہ پیر وی نِشہِ انکار کرِ، تس گژِھہ پے آسٕنۍ زِ اللہ تعالیٰ چُھ تمام دنیا والیو نِشہِ بے نیا ز۔"
  3,98,"۔ؤنِو ، اے اہلِ کتا ب توٚہۍ کیازِ چِھو اللہ تعالیٰ سٕنزٕ کتھہٕ ماننہٕ نِشہِ انکار کران؟ یِمہٕ حر کتہٕ توٚہۍ کران چِھو اللہ تعالیٰ چُھ سورُے وُچھان"
  3,99,"۔ؤنِو ،اے اہلِ کتاب یہِ کیا رٔوِش چھےٚ تُہٕنز زِ یُس اللہ تعالیٰ سٕنز کتھ مانان چُھ سُتہِ چھوٗن توٚہۍ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ رُکا وان تہٕ یژھان چِھو زِ سُہ گژِھہ ہَجہِ وَتہِ پکُن ، حالانکہ توٚہی چِھو پانہٕ ﴿تٔمۍ سٕندِس راہِ را ستس پٮ۪ٹھ آسنس ﴾گواہ ،تُہٕنز وحر کتو نِشہِ چُھنہٕ اللہ تعالیٰ بے خبر ۔"
  3,100,"۔اے لوٗکو ، یِمو ایمان چُھو اوٚ نمُت اگر تۅہیہِ یِمو اہلِ کتا بو منٛزٕ أکِس دٔرۍ سٕنز کتھ مٲنِو تیٚلہِ پھِرٕ نَو یِم ایمان نِشہِ تۅہیہِ بیٚیہِ کُفرس کُن،"
  3,101,"۔تُہٕندِ خٲطرٕ کُس مو قع چُھ وۅ نۍ کُفرس کُن گژھنُک ،ییٚلہِ زَن تۅہیہِ اللہ تعالیٰ سٕندۍ آیات بوزنا و نہٕ چِھ یِوان تہٕ تۅہیہِ در میان چُھ تٔمۍ سُند رسول موجود؟ یُس اللہ تعالیٰ سُند دامن مضبو طی سان رَٹہِ  سُہ لبہِ ضرور سِیٔز وَتھ ۔ع"
  3,102,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ،خُدا یس کھوٚژِ و یُتھ کھوٚژنُک حق تٔمۍ سُند چُھ ،تۅہیہِ گژھیو نہٕ موت یُن مگر اَتھ حالتس منٛز زِ توٚہۍ گٔژِھو مُسلم آسٕنۍ۔اللہ تعالیٰ سٕنز ِرَزِ کٔرِ و سٲر ی سٔمِتھ مضبوٗطی سان تھپھ تہٕ پھا ٹوَن واد مَہ تُلِو۔﴿اللہ تعالیٰ سٕنز رَز چُھ مُراد اللہ تعالیٰ سُند دین ،تہٕ یہِ چُھ اَمہِ موجوٗب رَزِ سٍتۍ تعبیر آمُت کر نہٕ زِیۅ ہے چُھ سُہ رِشتہٕ یُس اکہِ طر فہٕ اہلِ ایمانن ہُند تعلق خُدا یس سٍتۍ قٲیِم چُھ کران تہٕ دوٚ یِمہِ پاسہٕ چُھ تمام ایمان اَنن والیٚن پانہٕ وٲنۍ رَلٲوِتھ اکھ جما عت بناوان۔﴾"
  3,103,"۔اللہ تعالیٰ سُند سُہ احسا ن تھٲوِ و یاد یُس تٔمۍ تۅہیہِ پٮ۪ٹھ کوٚر مُت چُھ ،توٚہۍ ٲسِو اکھ أکۍ سٕندۍ دشمن تٔمۍ رَلٲوۍ تُہٕندۍ دِل تہٕ تٔمۍ سٕندِ فضل و کر مہٕ سٍتۍ بنییو توٚہۍ بٲے بٲے، توٚہۍ ٲسِو أکِس نارٕ بٔرِ تِس چا ہ کِس بٔٹھِس پٮ۪ٹھ وۅدنہِ ،خُدا ین بچٲوِۍ نَو توٚہۍ امہِ نِشہِ، یِتھہٕ پٲٹھۍ چُھ اللہ تعالیٰ پننہِ نِشٲنیہِ تۅہیہِ برونٛہہ کنہِ روشن کران، بنان چُھ زِ یِمو نِشٲنیو سٍتۍ یِیَو تۅہیہِ پننہِ کامیٲبی ہٕنز سٔیِز وَتھ اَتھہِ۔"
  3,104,"۔تۅہیہِ منٛز گژھن کینٛہہ لُکھ ضروٗر تِتھۍ آسٕنۍ یِم نیکی کُن ناد دِن رٕژرُک حُکم دِن تہٕ بُرٲیو نِشہِ روزَن پتھ رَٹان، یِم لُکھ یہِ کٲم کر ن تِمے لبَن فلا ح ۔"
  3,105,"۔یِنہٕ تۅہیہِ تِمن لُکن ہٕنٛز بٲش گژھیو یِم فر شتن منٛز تقسیم سپٕدۍ تہٕ نٔنۍ نٔنۍ وا ضح ہدایات رَٹنہٕ پتہٕ سپٕدۍ بیٚیہِ اختلا فن منٛز مبتلا ،یِمو یہِ رٔوِش وَرتٲو تِمن چُھ تَمہِ دۅ ہ سخت سزا رَٹُن۔"
  3,106,"۔ییٚلہِ زَن کینٛہہ لُکھ سر خ رو آسن تہٕ کینٛژھن لُکن ہُنٛد بُتھ آسہِ کرِ ہُن یِہُند بُتھ کر ہُن آسہِ ﴿تِمن یِیہِ وَننہٕ زِ ﴾ ایمانٕچ نعمت حا صل کر نہٕ پتہٕ تہِ کوٚرُو تۅہیہِ کٲفر انہٕ رٔوِ یہِ اختیار؟ وُچِھتو وۅ نۍ امہِ کُفرا نِ نعمت کہ بد لہٕ عذا بُک مزٕ ہ ۔"
  3,107,"۔روٗدۍ تِم لُکھ یِہنٛدۍ بُتھۍ روشن آسن تِمن میلہِ اللہ تعالیٰ سٕندِس رحمت کِس دا منس تل جاے تہٕ ہمیشہ روزن تِم أتھۍ حا لتس منٛز۔"
  3,108,"۔یِم چِھ اللہ تعالیٰ سٕندۍ ارشادات یِم أسۍ توٚہۍ ٹھیک ٹھیک بوزناوان چِھو تِکیازِ خُدا یس چُھنہٕ دنیا والیٚن پٮ۪ٹھ ظُلم کر نُک کانٛہہ ارداہ۔"
  3,109,"۔زمین و آسما نکیٚن تمام چیز ن ہُنٛد مٲلک چُھ اللہ تعالیٰ تہٕ سٲر ی معا ملات چِھ اللہ تعالیٰ سٕندِ سٕے در بارس منٛز پیش سپدان۔ ع"
  3,110,"۔وۅ نۍ چِھو دُنیا ہس منٛز سۅ بہتر ین چھۅ کھ توٚہۍ یۅ سہٕ انسانن ہٕندِ ہدا یتہٕ تہٕ اصلا ح خٲطرٕ دنیا ہس منٛز اَننہٕ چھےٚ آمٕژ ،توٚہۍ چِھو نیکی ہُنٛد حُکم دِوان بد ی نِشہِ چِھو رُکا وان تہٕ خُدا یس پٮ۪ٹھ چِھو ایمان تھاوان یِم اہلِ کتاب اگر ایمان اَنہن یِہِندۍ خٲطرٕ اوس بہتر﴿یتھ جایہِ چُھ اہلِ کتاب مُراد یہو دۍ﴾ اگر چہِ یِمو منٛزٕ کینٛہہ لُکھ ایمان دار تہِ  چِھ مگر یِہِندۍ اکثر افراد چِھ نا فر مان۔"
  3,111,"۔یِم ہیٚکن نہٕ تۅہیہِ کانٛہہ نقصا ن واتنٲوِتھ ،زیادٕہ کھۅتہٕ زیادہ ہیٚکن رَژھ کھنڈ ستٲوِتھ اگر یِم تۅہیہِ سٍتۍ لڑ ن، مقا بلہٕ وِزِ ژَلن پوٚت کھورِ پتہٕ گژھن تِتھہٕ پٲٹھۍ بے بس زِ کُنہِ جایہِ میلہِ نہٕ یِمن مدد۔"
  3,112,"۔یِم یتھ جایہِ تہِ لبنہٕ آے یِمن ووٚ تھ ذِلّت کُے مار کُنہِ جایہِ ہر گاہ اللہ تعالیٰ سٕندِ ذمہٕ یا انسانن ہٕندِ ذمہٕ پنا ہ حٲصل گوکھ تہِ سۅ چھےٚ بیٚاکھ کتھ۔﴿یعنی اگر دُنیا ہس منٛز یِمن کُنہِ جایہِ رَژھ کھنڈ امن تہٕ سکو ن نصیب سپُد تہِ ، سُہ چُھنہٕ یِمن پننِس بل بو تس پٮ۪ٹھ قٲیِم کر نہٕ آمُت اَمن و سکو ن کینٛہہ بلکہ چُھکھ دوٚ یِمیٚن ہٕندِ حما یتُک تہٕ مہر بٲنی ہُند نتیجہِ ۔ کُنہِ جایہِ دِیُت یِمن کٲنٛسہِ مُسلم حکو متن اللہ تعالیٰ سٕندِ طر فہٕ اَمان تہٕ کُنہِ جایہِ رٔٹۍ کٲنٛسہِ غیر مُسلم حکو متن پننِس حما یتس منٛز۔ یِتھے پٲٹھۍ میوٗل یِمن بسا اوقا ت دُنیا ہس منٛز کُنہِ جایہِ زور حاصل کرنُک موقع تہِ مگر سُتہِ نہٕ پننیو زرور بلکہ محض ہمسایہِ زورو یٔہے حیثیت چھےٚ تمہِ یہوٗدۍ ریاستٕچ یۅسہٕ اسرا یل ناوٕ محض امر یکہ، بر طا نیہ ،تہٕ روس کہ حما یتہٕ قٲیِم سپٕز۔﴾ یِم چِھ اللہ تعالیٰ سٕندِس غضبس منٛز ہیٚنہٕ آمٕتۍ یِمن پٮ۪ٹھ چھےٚ محتا جی تہٕ مغلو بی مُسلط کر نہٕ آمٕژ تہٕ یہِ سورُے چُھ اَمی وجہ کِنۍ سپُد مُت زِ یِم روٗدۍ اللہ تعالیٰ سٕندٮ۪ن آیا تن سٍتۍ کُفر کران تہٕ یِمو کٔرۍ پیغمبر نا حق قتل، یہِ چُھ یِہنز ن نا فر مٲنین تہٕ زیا دتین ہُنٛد انجام۔"
  3,113,"۔مگر سٲر ی اہل کتا ب چِھنہٕ یکسا ن۔یِمن منٛز چِھ کینٛہہ لُکھ تِتھۍ تہِ یِم سیٚزِ وَتہِ پٮ۪ٹھ قٲیِم چِھ ، رٲژن چِھ اللہ تعالیٰ سٕندۍ آیات پران تہٕ تس برونٛہہ کنہِ چِھ سجدٕ ہ کران ،"
  3,114,"۔خُدا یس تہٕ ٲخرت کِس دوہس پٮ۪ٹھ چِھ ایمان تھاوان نیکی ہُند حُکم چِھ دِوان ،بُرٲیو نِشہِ چِھ رُکا وان تہٕ رٕژن کامیٚن منٛز چِھ سر گر م روزان، یِم چِھ صا لح لُکھ،"
  3,115,"۔تہٕ یۅسہٕ نیکی تہِ یِم کر ن تَتھ یِیہِ نہٕ بے قدر ی کر نہٕ اللہ تعالیٰ چُھ پر ہیز گار لُکن ٹھیک پٲٹھۍ زانان۔"
  3,116,"۔روٗدۍ تِم لُکھ یِمو کُفرُک رٔویہِ اختیار کوٚر تِمن یِیہِ نہٕ اللہ تعالیٰ سٕندِس مقا بلس منٛز نَہ  تِہُند مال بکا ر تہٕ نَہ اولاد، تِم چِھ نارس گژھن وٲلۍ لُکھ تہٕ ہمیشہ روزَن نار سٕے منٛز،"
  3,117,"۔یِکینٛژھاہ تِم پننہِ ییٚمہِ دُنیا چہِ زند گی منٛز خر چ کران چِھ تمِچ مثا ل چھےٚ تمہِ ہوا ہٕچ ہِش یتھ منٛز کٹھ کوٚش آسہِ تہٕ سُہ پکہِ تِمن لُکن ہٕندِ زر اعتہٕ پیٚٹھۍ یِمو پا نس پٮ۪ٹھ ظُلم چُھ کوٚر مُت تہٕ تتھ تراوِ برباد کٔرِ تھ ،خُدا ین کوٚر نہٕ تِمن پٮ۪ٹھ ظُلم بلکہ چِھ تِم در حقیقت پانے پا نس پٮ۪ٹھ ظُلم کران۔"
  3,118,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت پننہِ جما عت کیو لُکو ورٲے مَہ بنٲوِ یوٗکھ با قی پنٕنۍ راز دار تِم چِھنہٕ تُہٕنزِ خرٲبی ہٕندِس کُنہِ مو قعس فٲیدٕہ تُلنس ژیر کران تۅہیہِ ییٚمہِ چیزٕ سٍتۍ نقصا ن واتہِ سُے چُھ تِمن ٹو ٹھ، تِہندِ دِلُک بغض چُھ تِہندِ ٲسہٕ کِنۍ نیران تہٕ یِکینژھاہ تِم پننیٚن وَچھن منٛز چُھپٲوِ تھ چِھ سُہ چُھ امہِ کھۅتہٕ تہِ شدّید تر، اَسہِ چِھو تۅہیہِ صا ف صا ف ہدا یات دِتمٕتۍ اگر تۅہیہِ عقل چَھو ﴿تیٚلہِ وَرتٲوِو یِمن سٍتۍ تعلق تھاو نس منٛز احتیاط۔﴾"
  3,119,"۔تۅہیہِ چُھو یِمن سٍتۍ محبت مگر یِمن چُھنہٕ تۅہیہِ سٍتۍ محبت حالانکہ توٚہۍ چِھو تمام آسمٲنی کتا بہٕ مانان  ییٚلہِ تِم تۅہیہِ سمکھان چِھو ،تیٚلہِ چِھ تِم ونان زِ اَسہِ تہِ چُھ ﴿تُہُند رسول تہٕ تُہٕنز کتا ب ﴾ مٲنمٕژ مگر ییٚلہِ الگ سپدان چِھ پتہٕ چُھ تۅہیہِ خلا ف تِہندِ عدا وتُک تہٕ غضبُک حال یہِ آسان زِ پننہِ اُنگجہِ چِھ لاگان ژاپنہِ، یِمن ؤنِو زِ پننِس شرارتس منٛز مٔرِ و أندری دٔزِتھ ،اللہ تعالیٰ چُھ دِلن منٛز چُھپا و نہٕ آمٕتۍ راز تام زانان۔"
  3,120,"۔ییٚلہِ تۅہیہِ خیر چُھو واتان تیٚلہِ چُھ تِمن یہِ شر باسان تہٕ ییٚلہِ تۅہیہِ پٮ۪ٹھ کانٛہہ مصیبت چھُ یِوان تیلہِ چھِ یِم خۅش گژھان مگر یِہٕنز کانٛہہ تہِ تد بیر ہیکہِ نہٕ تۅہیہِ خلا ف کار گر سپدِ تھ ، بشر طیکہ توٚہۍ ہیٚیِو صبرس کٲم تہٕ خُدا یس کھوٗژِتھ روٗزِ و کٲم کران یِکینٛژھاہ یِم کران چِھ ، اللہ تعالیٰ چُھ تتھ پٮ۪ٹھ حٲوی ۔ع"
  3,121,"۔﴿اے پیغمبر صلی اللہ علیہ وسلم،مُسلمانن برونٛہہ کنہِ کٔرِ و تمہِ سا عتٕچ ذِکر ﴾ ییٚلہِ توٚہۍ واریاہ سُلہِ پننہِ گھرِ ٲسِو درٛ امٕتۍ تہٕ ﴿اُحدکِس میدا نس اندر ﴾ ٲسِو مُسلمانن جنگ خٲطرٕ جا بجا ما مور کرا ن، اللہ تعالیٰ چُھ ساریے کتھہٕ بوزان تہٕ سُہ چُھ سٮ۪ٹھاہ با خبر ،"
  3,122,"۔یاد کٔرِو ییٚلہِ تۅہیہِ منٛزٕ زٕ دٔرۍ بُز دلی ہاونس پٮ۪ٹھ آمادٕ ہ سپٕدۍ مٕتۍٲسۍ حالانکہ اللہ تعالیٰ اوس یِہندِ مددٕ خٲطرٕ موجود تہٕ مو منَن پَزِ اللہ تعالیٰ سٕے پٮ۪ٹھ بھر وسہٕ تھاوُن۔"
  3,123,"۔خُدا ین اوسنو گۅڈ ے جنگِ بدر کِس مو قعس پٮ۪ٹھ تۅہیہِ مدد کوٚر مُت حالانکہ تتھ وقتس تام ٲسِو توٚہۍ سٮ۪ٹھاہ کمزور لہٰذا پز یٚو تۅہیہِ زِ توٚہۍ بٔچِو اللہ تعالیٰ سٕنزِ نا شکر ی نِشہِ امید چھےٚ زِ وۅ نۍ بٔنِو توٚہۍ شکر گزار۔"
  3,124,"۔اے نبی صلی اللہ علیہ وسلم، یاد کٔرِ و ییلہِ توٚہۍ مو منن ٲسِو ونان : کیا تُہٕندِ خٲطرٕ چَھنا یہِ کتھ کٲفی زِ اللہ تعالیٰ کرِ ترٛ ے ساس فر شتہٕ سوٗزِ تھ تُہُند مدد؟"
  3,125,"۔بے شک ، اگر توٚہۍ صبر کٔرِ و ، تہٕ خُدا یس کھۅژان کھۅژان روٗزِ و کٲم کران تیٚلہِ ییٚمہِ وِزِ دشمن تۅہیہِ پٮ۪ٹھ حملہٕ کر ن تمی وِزِ کرِ تُہُند ربّ ﴿ترٛ ے ساس نہٕ کینٛہہ ﴾پانٛژٕ و سا سَو صا حب نِشا ن فر شتو سٍتۍ تُہُنٛد مدد۔"
  3,126,"۔یہِ کتھ چھےٚ خُدا ین تۅہیہِ امہِ موجوٗب ؤنِمٕژ زِ توٚہۍ گٔژِھو خۅ ش۔تہٕ تُہٕندٮ۪ن دِلن سپدِ اَمہِ سٍتۍ اطمنا ن۔ فتح تہٕ نصرت یِکینٛژھاہ تہِ چُھ، سُہ چُھ اللہ تعالیٰ سٕندِ طر فہٕ ، یُس سٮ۪ٹھاہ قُوّت وول تہٕ دانا بینا چُھ۔"
  3,127,"۔﴿تہٕ یہِ مدد دِیہِ سُہ تۅ ہیہِ امہِ مو جو ب ﴾ تاکہ کُفر چہِ وَتہِ پٮ۪ٹھ پکن والیٚن ہٕنز اکھ نٔر ژٹہِ نَتہٕ دِیہِ تِمن تِیُتھ ذلیل شکست زِ تِم گژھن نا مرٲدی سان پسپا۔"
  3,128,"۔﴿اے پیغمبر صلی اللہ علیہ وسلم﴾ فٲصلہٕ کیٚن اختیار اتن منٛز چُھنہٕ تُہُند کانٛہہ حصہٕ ،خُدا یس چُھ اختیار ،چا ہے سُہ تِمن معا ف کرِ ، چا ہے سزا دِیَکھ تِکیازِ تِم چِھ ظٲلِم،"
  3,129,"۔زمینس تہٕ آسما نن اندر یِکینٛژھاہ چُھ، تَمِیُک مٲلِک چُھ اللہ تعالیٰ  یَس ییٚژِھ تس کرِ معا ف تہٕ یَس ییٚژِھہ تس دِیہِ عذا ب، سُہ چُھ معا ف کر ن وول تہٕ رحیم۔﴿جنگِ اُحدس اندر ییٚلہِ نبی صلی اللہ علیہ وسلم زخمی سپٕدۍ ،تمہِ وِزِ درٛا و نبی صلی اللہ علیہ وسلمن ہٕندِ دہانِ مبا ر کہ منٛزٕ کُفار ن ہٕندِس حقس منٛز بد دُعا تہٕ تِمو صلی اللہ علیہ وسلمو فر مو و زِ  سُہ قو م کِتھہٕ پٲٹھۍ لبہِ فلا ح یُس پننِس نبی یَس زخمی کرِ ۔ یِم آیات چِھ أتھۍ متعلق ارشاد سپٕدۍ مٕتۍ۔﴾"
  3,130,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت یہِ بڑوُن تہٕ کھسُو ن سوٗد کھیٚو ن ترٲوِ و تہٕ خُدا یس کھوٗژِو، اُمید چھےٚ زِ فلا ح گژھیو حٲصل،"
  3,131,"۔ تَمہِ نارٕ نِشہِ بٔچِو یُس کٲفر ن خٲطرٕ چُھ تھا و نہٕ آمُت ،"
  3,132,"۔بیٚیہِ کٔرِ و اللہ تعالیٰ سٕنٛز تہٕ رسول صلی اللہ علیہ وسلم سٕنٛز اطا عت تو قع چُھ زِ تۅہیہِ پٮ۪ٹھ یِیہِ رحم کر نہٕ۔"
  3,133,"۔دَوان پٔکِو تتھ وَتہِ پٮ۪ٹھ یۅسہٕ تُہنٛدِس ربّ سٕندِس مغفرتس تہٕ تٔمۍ سٕندِس جنتس کُن گژھان چھےٚ، ییٚمِچ وُسعت زمینس تہٕ آسما نن ہِش چھےٚ، تہٕ سۅ چھےٚ تِمن خُدا یس کھۅژ ن والیٚن لُکن خٲطرٕ دستیا ب آمٕژ تھاو نہٕ۔"
  3,134,"۔یِم پرٛتھ حا لس منٛز پنُن مال چِھ خر چ کرا ن ، خوا ہ تِم بد حال ٲسِتن یا خۅشحال ٲسِتن،  یِم شرا رتس چِھ چیٚتھ نِوان تہٕ دوٚ یِمیٚن ہٕندۍ قصو ر چِھ معا ف کران۔یِتھۍ نیک لُکھ چِھ خُدا یس سٮ۪ٹھاہ پسند۔"
  3,135,"۔تہٕ یِہُند حال یہِ چُھ زِ اگر کُنہِ وقتہٕ تِہندِ دٔسۍ کانٛہہ فحش کٲم سر زد چھےٚ سپدان یا کانٛہہ گنا ہ کٔرِ تھ چِھ تِم پا نس پٮ۪ٹھ ظُلم کران  تِمن چُھ سٍتی اللہ تعالیٰ یاد پیٚوان تہٕ تس چِھ پننیٚن قصو رن پٮ۪ٹھ معا فی منگان تِکیازِ خُدا یس ورٲے کُس چُھ یُس گنا ہ ہیکہِ معا ف کٔرِ تھ؟ تہٕ تِم چِھنہٕ زانٛہہ دٲنستہٕ پننِس کٔرۍ مٕتِس پٮ۪ٹھ اِصرار کران۔"
  3,136,"۔یِتھیٚن لُکن ہُنٛد جزا چُھ یِہندِس ربّس نِشہِ یہِ زِ سُہ کرِ تِمن معا ف تہٕ تِتھیٚن با غن منٛز کرِ تِمن دٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکا ن تہٕ تَتہِ روزن تِم ہمیشہ، کِیُتھ جان بد لہٕ چُھ نیک اعما ل کر ن والیٚن خٲطرٕ ۔"
  3,137,"۔تۅہیہِ برونٛٹھ چِھ واریاہ دَور گُزر یمٕتۍ زمینس پٮ۪ٹھ پھیرِ تھ تھوٗرِ تھ وُچِھتو زِ تِمن لُکن ہُند انجام کیا سپُد یِمو ﴿اللہ تعالیٰ سٕندۍ احکام ہدا یات ﴾ اَپزٕ ۍ زٲنۍ۔"
  3,138,"۔یہِ چُھ لُکن خٲطرٕ اکھ صا ف تہٕ ٹا کارٕ تنبیہ  تہٕ یِم خُدا یس آسن کھۅژان تِمن خٲطرٕ چُھ ہدا یت تہٕ نصیحت۔"
  3,139,"۔دل شکستہ مَہ گٔژِھو، غم مہ کٔرِ و توٚہی روٗزِ و غٲلب اگر توٚہۍ مو من چِھو ۔"
  3,140,"۔وُنۍ کیٚنس اگر توٚہیہِ چو ٹ چُھو لوٚ گمُت اَمہِ برونٛہہ چُھ یُتھُے چو ٹ تُہندِس مخٲلف فر یقس تہِ لوٚ گمُت۔﴿اِشارہ چُھ جنگِ بدرس کُن تہٕ وَننُک مطلب چُھ یہِ ییٚلہِ یہِ چو ٹ کھیٚتھ کٲفر پست ہمت سپٕدۍ نہٕ، جنگِ اُحدس منٛز یہِ چو ٹ کھیٚتھ کیازِ گٔژِھو توٚہۍ غمگین؟﴾ یِم چِھ زمانٕکۍ سنیٛروۅ گنیار یِمن أسۍ لُکن در میان چِھ گردِش دِوان روزان، تۅہیہِ پٮ۪ٹھ آو یہِ وقت اَمہِ موجو ب زِ اللہ تعالیٰ اوس وُچُھن یژھان زِ تۅہیہِ منٛز کم  چِھ پٔزۍ مو من تہٕ تِمن لُکن اوس ژارُن یژھان یِم پٔزۍ پٲٹھۍ ﴿سیز رٕکۍ پزرٕکۍ﴾ گواہ آسن۔﴿اصل الفا ظ چِھ۔   وَیَتَخِذَ مِنکُم شُہَدآ  ٔ،َمِیُک اکھ مطلب چُھ یہِ زِ تۅہیہِ منزٕاوس کینٛہہ شہید یژھان نِیُن ،یعنی کینٛژھن لُکن اوس شہا دتُک عز ت یژھان عطا کرُن۔تہٕ دوٚ یُم مطلب چُھ یہِ زِ اہلِ ایمانن تہٕ مُنا فقن ہٕندِس اتھ مخلو ط دٔرِس منٛز یتھ پٮ۪ٹھ توٚہۍ وُنۍ کیٚنس مشتمل چِھو، اوس تِمن لُکن یژھان ژارُن یِم حقیقتس منٛز شُھَدَآ عَلیٰ النَّاسِ چِھ یعنی تَمہِ اعلیٰ منصبٕکۍ چِھ اہل یتھ پٮ۪ٹھ اَسہِ اُمتِ مُسلمہ چھےٚ سر فراز کٔرمٕژ۔﴾ تِکیازِ ظٲلِم لُکھ چِھنہٕ خُدایس پسند۔"
  3,141,"۔تہٕ سُہ اوس اَمہِ آز مٲیشہِ ہٕندِ ذر یعہ یَژھان مو منن الگ ژٲرِ تھ کٲفر مِٹا وٕنۍ۔"
  3,142,"۔کیا تۅہیہِ چُھوٕ ہ یہِ سمجھُمُت زِ یتھے گٔژِھو جنتس اندر حالانکہ وُنہِ وُچھنہٕ خُدا ین یہِ زِ تۅہیہِ منٛزٕ کم چِھ تِم لُکھ یِم تٔمۍ سٕنزِ وَتہِ منٛز زُوَن چِھ گندن وٲلۍ تہٕ تٔمۍ سٕندِ خٲطرٕ چِھ صبر کر ن وٲلۍ ۔"
  3,143,"۔توٚہۍ ہے ٲسِو مو تُک تمنا کران!۔مگر یہِ ٲس تمہِ وقتٕچ کتھ ییٚلہِ مو ت برونٛہہ کُن اوس نہٕ آمُت، وۅ نۍ وو تو سُہ تۅہیہِ برونٛٹھ  کُن تہٕ تۅہیہِ وُچھوٗن أچھو۔ع"
  3,144,"۔محمد صلی اللہ علیہ وسلم چِھنہٕ اَمہِ ورٲے کِہِنۍ زِ بس چِھ اکھ رسول، تِمن برونٛہہ چِھ بیٚیہِ تہِ رسول گُزر یمٕتۍ  ،تیٚلہِ کیا اگر تِم مَر ن یا قتل یِن کر نہٕ، کیا توٚہۍ لُکھ پھیٖرِ وٕ ہ پوٚت کھورِ واپس؟ یاد تھٲوِ و ! یُس پوٚت پھیرِ سُہ واتناوِنہٕ خُدا یس کانٛہہ نقصا ن البتہ یِم اللہ تعالیٰ سٕندی شکر گُزار بند ہ بٔنِتھ روزن تِمن دِیہِ اَمِیُک جز ا۔"
  3,145,"۔کانٛہہ زُوذات ہیکہِ نہٕ اللہ تعالیٰ سٕندِ اِذ نہٕ ورٲے مٔرِ تھ ،مو تُک وقت چُھ لیٚکھِتھ  یُس شخص دنیا کہ ثواب کہِ اِرادہ کٲم کرِ ،تس دِمَو أسۍ دُنیا منٛز ے تہٕ یُس ٲخرت کہ ثو اب کہِ اِرادہ کٲم کرِ تس میلہِ ٲخر تُک ثو اب تہٕ شُکر کر ن والیٚن کرَو أسۍ تِہُند جزا ضرور عطا۔"
  3,146,"۔ییٚمہِ برونٛٹھ کٲتیا وَے نبی چِھ تِتھۍ گُزر یمٕتۍ یِمن سٍتۍ رٔلِتھ واریاہ ہو خُدا پر ستو جنگ کوٚر اللہ تعالیٰ سٕنزِ وتہِ اندر ،یِم مصیبت تِمن تُلنٕۍ پے  تِمَو سٍتۍ سپٕدۍ نہٕ تِم دل شکستہٕ ،تِمو  ہٲونہٕ کمزور ی، تِم نمیہِ نہٕ ﴿بٲطلس برونٛہہ کنہِ﴾ یِتھۍ نٕے صٲبر ن چُھ اللہ تعالیٰ پسند کران۔"
  3,147,"۔تِہُند دُعا اوس بس یہِ زِ : اے سانہِ ربّ  ، سانیٚن غلطین تہٕ کو تٲہِیِن کر دَر گُز ر، سانیٚن کا میٚن اندر یِکینژھاہ چا نیٚو حدو نِشہِ ڈٔلِتھ چُھ سپُد مُت سُہ کر معا ف، اَسہِ تھاو ثٲبت قد م تہٕ کٲ فر ن ہٕندِس مقا بلس منٛز کر اَسہِ مدد۔"
  3,148,"۔ٲخر کار دِیُت خُدا ین تِمن دُنیا ہُک ثوا ب تہِ تہٕ اَمہِ کھۅتہٕ بہتر کوٚرنَکھ ٲخر تُک ثوا ب تہِ عطا ،خُدا یس چِھ یِتھی نیک عمل لُکھ پسند ۔ع"
  3,149,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت اگر توٚہۍ تِمن لُکن ہٕندٮ۪ن اِشارن پٮ۪ٹھ پٔکِو یِمو کُفرٕ چ وَتھ چھےٚ پا ننا و مٕژ تیٚلہِ پکنا و نَو تِم تۅہیہِ پوٚت کھو ر یٚو واپس تہٕ توٚہۍ سپدِ و نا مُراد ۔"
  3,150,"۔﴿تِہٕنزٕ کتھہٕ چَھو غلط﴾ حقیقت چھےٚ یہِ زِ اللہ تعالیٰ چُھ تُہُند حٲمی تہٕ مددگار تہٕ سُہ چُھ بہتر ین مدد کر ن وول۔"
  3,151,"۔عنقر یب چُھ سُہ وقت یِنہٕ وول ییٚلہِ أسۍ حقس انکار کر ن والیٚن ہٕندٮ۪ن دِلن اندر ہٲبتھ بیٚہنا وَو، امہِ موجو ب زِ تِمو چِھ خُدا یس سٍتۍ تٔمۍ سٕنزِ خُدٲیی منٛز تِم شر یک ٹھہرٲوِ مٕتۍ  یِہندِس  شر یک آسنس پٮ۪ٹھ خُدا ین کانٛہہ سَنَد چَھنہٕ نٲزِل کٔر مٕژ ،تِہُند ٲخر ی ٹھکا نہٕ چُھ جہنم تہٕ سٮ۪ٹھاہ بُرٕ چھےٚ سۅ روزن جا ے یۅسہٕ تِمن ظٲلِمن نصیب سپدِ ۔"
  3,152,"۔ خُدا ین یُس ﴿تٲیید و نُصر تُک﴾ وعدہ تۅہیہِ سٍتۍ اوس کوٚر مُت ، سُہ کوٚر تٔمۍ پوٗرٕ، ابتدا ہس اندر ٲسِو تٔمۍ سٕندِ حُکمہٕ سٍتۍ توٚ ہی تِم قتل کران مگر ییٚلہِ تۅہیہِ کمزور ری ہٲوٕ و تہٕ پننہِ کامہِ منٛز کوٚرُو پانہٕ وٲنۍ اختلاف تہِٕ یُتھُے خُدا ین سُہ چیز تۅہیہِ ہو و نَو ییٚمہِ کِس محبتس اندر توٚہۍ گرفتار ٲسِو ﴿ یعنی مالِ غنیمت﴾ تۅہیہِ کٔرٕ و پننِس سردار سٕندِ حُکمٕچ خلا ف ور زی امہِ موجو ب زِ تۅہیہِ منٛزٕ ٲسۍ کینٛہہ لُکھ دنیا ہٕکۍ طٲلب تہٕ کینٛہہ ٲسۍ  ٲخرتٕچ خوٲہش تھاوان تمہِ وِزِ کٔرِۍ نَو توٚہۍ خُدا ین کٲفر ن ہٕندِس مقا بلس منٛز پسپا تا کہ سُہ کرِ ہے تُہٕنز آز مٲیش تہٕ حق چُھ یہِ زِ خُدا ین کوٚر نَو تۅہیہِ تو تہِ معا ف تِکیازِ مو منن پٮ۪ٹھ چُھ اللہ تعالیٰ نظرِ عنا یت تھاوان۔"
  3,153,"۔یاد کٔرِو ییٚلہِ توٚہۍ ثلان ٲسِو،کٲنٛسہِ کُن پوٚت پھیرِ تھ وُچھنُک تہِ اوسو نہٕ ہو ش تہٕ رسول صلی اللہ علیہ وسلم اوسُو تۅہیہِ پتہٕ پتہٕ ناد لایان۔﴿جنگِ اُحدس اندر ییٚلہِ مُسلمانن پٮ۪ٹھ دۅ یہِ طر فہٕ بیک وقت اچا نک حملہٕ سَپُد تہٕ تِہد ٮ۪ن صفن منٛز پھٔہلیہِ اَبتر ی، کینٛہہ لُکھ ژٔلۍ مد ینس کُن تہٕ کینٛہہ کھٔتۍ اُحد س پٮ۪ٹھ ، مگر نبی صلی اللہ علیہ وسلم ڈٔلۍ نہٕ پننہِ جایہِ اکھ ٲنٹ تہِ۔ ژورَو طر فو اوس دُشمنن ہُنٛد ہجو م ،دَہن بہَن نفر ن ہٕنز اکھ لۅ کٕٹ جما عت ٲس مو جو د ، مگر اللہ تعالیٰ سٕندۍ رسول صلی اللہ علیہ وسلم ٲسۍ اَتھ نا زُک مو قعس  پٮ۪ٹھ تہِ پہا ڑ کۍ پٲٹھۍ پننہِ جایہِ جٔمِتھ تہٕ ژَلن والیٚن ٲسۍ ناد لایان۔اِلَیَّ عِبَادَ اللہِ ،اِلَیَّ عِبَادَ اللہِ ،اللہ تعالیٰ سٕند یٚو بند و مےٚ کُن یِیِو ، اللہ  تعالیٰ سٕند یٚو بند و مےٚ کُن یِیِو ۔﴾ تمہِ وقتہٕ دِیتُنو خُدا ین تُہٕنزِ اَمہِ رٔوِشہِ ہُند بد لہٕ یہِ زِ تۅہیہِ دِیتُنو غمس پٮ۪ٹھ غم تا کہ آیند ہ خٲطرٕ میلہِ تۅہیہِ یہِ سبق زِ یِکینژھاہ تُہُندِ اتھہٕ منٛز نیرِیا یُس مصیبت  تۅہیہِ پٮ۪ٹھ نٲزِل سپدِ ،تتھ پٮ۪ٹھ گٔژِھو نہٕ غمگین سپدٕنۍ ،اللہ تعالیٰ چُھ تُہند یو سارِوٕے اعما لو نِشہِ با خبر ۔"
  3,154,"۔اَمہِ غمہٕ پتہٕ کٔر خُدا ین تۅہیہِ منٛزٕ کینژھن لُکن پٮ۪ٹھ تِژھ اِطمنا نٕچ حا لت طٲر ی زِ تِمن لجہِ نِند رِڈِکسہٕ گژھنہٕ۔﴿یہِ اوس اکھ عجیب تجر بہٕ یُس اَمہِ وقتہٕ لشکرِ اسلام کیٚن کینژھن لُکن پیش آو۔حضرت ابو طلحہ رضی اللہ عنہ یِم اتھ جنگس منٛز شر یک ٲسۍ، تِم چِھ پانہٕ بیان کران زِ اتھ حا لتس منٛز اوس اَسہِ پٮ۪ٹھ نِند رِ ڈِکسن ہُند تِیُتھ غلبہٕ سپدان زِ تلوار آسہٕ اَتھو منٛز ؤسۍ پیٚنہِ ہیٚوان ۔﴾ مگر  بیاکھ اکھ چھۅ کھ، ییٚمۍ سٕندِ خٲطرٕ سٲرٕ ے اہمیت بس پننہِ ذا تہٕ خٲطرٕ ٲس خُدا یس متعلق لٲگِن رنگہٕ رنگہٕ جٲہلا نہٕ گما نہٕ کرٕنۍ یِم سراسر حقس خلا ف ٲسۍ ،یِم لُکھ چِھ وۅ نۍ وَنان زِ :  یہِ کٲم چلا و نس اندر چُھ سو ن تہِ کانٛہہ حصہٕ ؟ یِمن ؤنِو! ﴿کٲنٛسہِ ہُنٛد  چُھنہٕ کانٛہہ حصہٕ ﴾ اَمہِ کامہِ ہٕندۍ سٲر ی اختیارات چِھ اللہ تعالیٰ سٕندِس اتھس منٛز دراصل یۅسہٕ کتھ یِم لُکھ پننیٚن دِلن منٛز چُھپٲوِ تھ چِھ سۅ چِھنہٕ یِم تۅہیہِ پٮ۪ٹھ ظٲہر کران، تِہُند اصلی مطلب چُھ یہِ زِ :  اگر ﴿قیا دت کیٚن ﴾ اختیاراتن منٛز سو ن کینٛہہ حصہ آسِہ ہے تیٚلہِ  یِمہَو نہٕ أسۍ ییٚتہِ مار نہٕ۔ یِمن ؤنِو زِ :  اگر توٚہۍ پننیٚن گھر ن منٛز تہِ ٲسِہِو ،یِمن لُکن ہُنٛد مو ت لیٚکھنہٕ اوس آمُت تِم نیر ہن خۅ د پننیٚن قتل گا ہن کُن  تہٕ یُس یہِ معا ملہٕ پیش آو ، اوس امہِ مو جو ب زِ یِکینژھاہ تُہند ٮ۪ن سینن اندر کھٔٹِتھ چُھ، اللہ تعالیٰ آز ما وِتتھ تہٕ یُس کھۅ چر تُہند ٮ۪ن دِلن اندر چُھ تتھ ترٛا وِ چھٲنٛٹِتھ ،اللہ تعالیٰ چُھ دِلن ہُنٛد حال وارٕ پٲٹھۍ زانان۔"
  3,155,"۔تۅہیہِ منٛزٕ یِم لُکھ مقا بلہٕ کہ دۅ ہہ پوٚت پھیرِ مٕتۍ ٲسۍ تِہنزِ اَمہِ لغز شہِ ہُنٛد وجہ اوس یہِ زِ تِہٕنز و کینٛژھو کمزوٗر یو کِنۍ ٲسۍ شیطا نن تِہندۍ قد م نٹہٕ نٲوِ مٕتۍ خُدا ین کوٚر تِمن معا ف، اللہ تعالیٰ چھ  سٮ۪ٹھاہ در گُزر کر ن وول تہٕ بُردبار ۔ ع"
  3,156,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت کٲفر ن ہٕنزٕ ہِشہِ کتھہِ مَہ کٔرِ و ،یِہِندۍ یار بٲے اگر کُنہِ وِزِ سفر س چِھ نیران یا جنگس منٛز  چِھ شر یک سپدان ﴿تہٕ تَتہِ چھِ کُنہِ حٲدثٕکۍ شکار سپدان ﴾ تیٚلہِ چِھ تِم ونان زِ اگر تِم اَسہِ نِشہِ آسہن تیٚلہِ نَہ یِہَن مار نہٕ ، نہ گژھہَن قتل، اللہ تعالیٰ چُھ اَمہِ قسمہٕ چن کتھن یِہندٮ۪ن دِلن منٛز حسر تُک تہٕ غمُک سبب بناوان حالانکہ مار ن وول تہٕ زندٕہ کر ن وول چھ در اصل اللہ تعالیٰ ہٕے یوت ،تہٕ تُہند ٮ۪ن تمام حر کا تن پٮ۪ٹھ چُھ سُے نظر تھٲوِ تھ۔"
  3,157,"۔اگر توٚہۍ اللہ تعالیٰ سٕنزِ وَتہِ اندر مار نہٕ یِیِو یا مٔرِ و تیٚلہِ یۅسہٕ اللہ تعالیٰ سٕنز رحمت تہٕ مغفر ت تُہندِس حصس منٛز یِیہِ ، سۅ چھےٚ تِمو سارِوٕے چیز و نِشہِ زیادہ بہتر یِمن یِم لُکھ جمع چِھ کران تہٕ"
  3,158,"۔خوا ہ توٚہی مٔر ۍ تَو یا مار نہٕ یِیہِ تَو بہر حال چُھ تۅہیہِ سارِنٕے سٔمِتھ گژُھن اللہ تعالیٰ سٕے کُن۔"
  3,159,"۔﴿اے پیغمبر صلی اللہ علیہ وسلم ﴾ یہِ چھےٚ اللہ تعالیٰ سٕنٛز بٔڑ رحمت زِ توٚہۍ چِھو یِمن لُکن خٲطرٕ سٮ۪ٹھاہ نر م مزا ج، نَتہٕ اگر توٚہۍ تیز مزا ج تہٕ سنگ دِل ٲسِہِو تیٚلہِ ژَلہَن یِم تۅہیہِ أندۍ پٔکۍ ،یِہِندۍ قصو ر کٔرِ و معا ف، یِہِندِس حقس منٛز کٔرِ و دُعا ے  مغفرت تہٕ دین چہِ کامہِ منٛز تھٲوِ یوٗکھ یِم تہِ مشورس منٛز شٲمل، پتہٕ ییٚلہِ تُہُند عز م کُنہِ رایہِ پٮ۪ٹھ مُستحکم سپدِ تیٚلہِ کٔرِو خُدا یس پٮ۪ٹھ بھروسہٕ ،خُدا یس چِھ تِم لُکھ پسند یِم تٔمۍ سٕندِ سٕے بھروسس پٮ۪ٹھ کٲم چِھ کران۔"
  3,160,"۔ییٚلہِ اللہ تعالیٰ تُہٕندِس مددس پٮ۪ٹھ آسہِ تیٚلہِ چُھنہٕ کانٛہہ طا قت تۅہیہِ پٮ۪ٹھ غٲلب یِنہٕ وول تہٕ ییٚلہِ سُہ تۅہیہِ ترٛا وِ،تیٚلہِ کُس چُھ تس پتہٕ یُس تۅہیہِ مدد ہیٚکہِ کٔرِ تھ ؟ لہٰذا یِم پٔزۍ مو منن چِھ تِمن پزِ اللہ تعالیٰ سٕے پٮ۪ٹھ بھر وسہٕ تھاوُن۔"
  3,161,"۔کٲنٛسہِ نبی سٕنز ہیٚکہِ نہٕ یہِ کٲم ٲسِتھ زِ سُہ کرِ خیا نت تہٕ یُس اکھا خیا نت کرِ سُہ سپدِ پنٕنۍ خیا نت ہیٚتھ قیا مت کہ دۅ ہ حٲضر پتہٕ میلہِ پرٛتھ کٲنٛسہِ شخصس پننہِ کما یہِ ہُنٛد پوٗرٕ پوٗرٕ بد لہٕ تہٕ کٲنٛسہِ پٮ۪ٹھ سپدِ نہٕ کانٛہہ ظُلم۔"
  3,162,"۔یہِ کِتھہٕ پٲٹھۍ چُھ ممکن زِ یُس شخص ہمیشہ اللہ تعالیٰ سٕنزِ مر ضی پٮ۪ٹھ پکن وول آسہِ سُہ کرِ تس شخصہٕ سٕنزٕ کامہِ یُس اللہ تعالیٰ سٕندِس غضبس منٛز آسہِ ہیٚنہٕ آمُت تہٕ ییٚمۍ سُنٛد ٲخر ی ٹھکا نہٕ جہنم آسہِ یُس بد تر ین ٹھکا نہٕ چُھ۔"
  3,163,"۔خُدا یس نز دیک چھےٚ دۅشوٕ نۍ قٔسمہٕ کیٚن انسانن منٛز واریاہ فر ق تہٕ اللہ تعالیٰ چُھ سارِنٕے ہٕنز ن عملن پٮ۪ٹھ نظر تھاوان۔"
  3,164,"۔ در حقیقت چھےٚ اہل ایمانن پٮ۪ٹھ خُدا ین یہِ بٔڑبارٕ مِنَتھ تھٲومٕژ زِ تِمن در میان تُلُن خۅ د تِموٕ ے منٛزٕ اکھ تِیُتھ پیغمبر یُس تٔمۍ سٕندۍ آیات چُھ تِمن بوزناوان، تِہنزٕ زند گیہِ چُھ پاک کران تہٕ تِمن چُھ کتاب تہٕ دانٲیی ہٕنز تعلیم دِوان حالانکہ امہِ برونٛٹھ ٲسۍ یِمے لُکھ نَنہِ وا نہِ گُمرٲہِیَن منٛز ہیٚنہٕ آمٕتۍ ۔"
  3,165,"۔تہٕ یہِ کُس حا ل چُھ تُہُند زِ ییٚلہِ تۅہیہِ مصیبت ووت تہٕ تۅہیہِ لوگُو وَنُن ،یہِ کتہِ آو ؟ حالانکہ ﴿جنگ بدرس منٛز ﴾ چُھ امہِ کھۅتہٕ دۅ گنہٕ مُصیبت تُہند یٚو اَتھو ﴿مُخٲلف فر یقس﴾ ووتمُت اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو ، یہِ مصیبت چُھو تۅہیہِ پننہِ دَستہٕ پانے اوٚ نمُت، اللہ تعالیٰ چُھ پرٛتھ چیزس پٮ۪ٹھ قٲدِر ۔"
  3,166,"۔یُس نقصا ن لڑا یہِ ہٕندِ دۅ ہ تۅہیہِ ووتُو سُہ اوس اللہ تعالیٰ سٕندِ اِذ نہٕ سٍتۍ تہٕ امہِ موجوٗب اوس زِ اللہ تعالیٰ وُچھہِ زِ تۅہیہِ منٛزٕ کم چِھ مو من"
  3,167,"۔ تہٕ زانُن اوس یژھان کم چِھ منا فق؟ تِم منا فق  زِ ییٚلہِ تِمن وَننہٕ آو: ؤلِو اللہ تعالیٰ سٕنزِ وتہِ اندر کٔرِو جنگ یا کٔرِو کم از کم ﴿پننی شہرُک﴾ دِفا ع وَننہٕ لٔگۍزِ اگر اَسہِ پے آسِہے زِ اَز گژِھہ جنگ تیٚلہِ نیرٕ ہَو أسۍ ضرور تۅہیہِ سٍتۍ  یہِ کتھ ییٚلہِ تِم ونان ٲسۍ تمہِ وقتہٕ ٲسۍ تِم ایمان کہ بہ نسبت کُفرس زیادہ قر یب۔تِم چِھ پننیو زبا نَو سٍتۍ تِمہٕ کتھہٕ ونان یِمہٕ نہٕ تِہندٮ۪ن دِلن منٛز آسان چھےٚ تہٕ یِکینٛژھاہ تِم دِلن منٛز چُھپا وان چِھ اللہ تعالیٰ چھ تتھ ٹھیک پٲٹھۍ زانان۔"
  3,168,"۔ یِم چِھ تِمے لُکھ یِم پانہٕ روٗدۍ بِہِتھ تہٕ یِہِندۍ یِم یار بٲے لڑ نہِ گٔے تہٕ مار نہٕ آے تِمن متعلق ووٚ ن تِمو زِ اگر تِم سٲنۍ کتھ مٲنہن تیٚلہِ ما یِہَن مار نہٕ، یِمن ؤنِو : اگر توٚہۍ پننہِ اَتھ کتھہِ منٛز پٔزِ یٲر ۍ چِھو تیٚلہِ ییٚمہِ ساعتہٕ تۅہیہِ خۅ د پا نس مو ت یِیہِ سُہ ڈٲلۍ زِ یو ن تہٕ أسۍ تہِ وُچھو۔"
  3,169,"۔یِم لُکھ  اللہ تعالیٰ سٕنزِ وَتہِ اندر قتل سپٕدۍ مٕتۍ چِھ تِمن مَہ ؤنِو مۅردٕ تِم چھِ در حقیقت زِ ندٕہ ،پننِس ربّس  نِشہِ چِھ رزق حا صل کران۔"
  3,170,"۔یِکینٛژھاہ خُدا ین تِمن پننہِ فضلہٕ سٍتۍ دِیتمُت چُھ تتھ پٮ۪ٹھ چِھ خۅ ش تہٕ خُر م تہٕ اِطمنا ن چُھکھ زِ یِم اہلِ ایمان یِمن پتہٕ دُنیا ہس اندر پتھ کُن روٗدِ مٕتۍ چِھ تہٕ وُنہِ چِھنہٕ تو روٲتِمٕتۍ تِمن خٲطرٕ تہِ چُھنہٕ کُنہِ خو فُک تہٕ غمُک کانٛہہ مو قع۔"
  3,171,"۔تِم چِھ اللہ تعالیٰ سٕندِس اِنعا مس تہٕ تٔمۍ سٕندِس فضلس پٮ۪ٹھ خۅ ش تہٕ خۅ شحا ل تہٕ تِمن چُھ معلو م سپُد مُت زِ اللہ تعالیٰ چُھنہٕ مو مِنن ہُنٛد اجر ضا یع کران۔ع"
  3,172,"۔﴿یِتھیٚن مو منن ہٕندِس اجر س﴾ یِمو زخم کھیٚنہٕ پتہٕ تہِ اللہ تعالیٰ تہٕ رسول ﴿صلی اللہ علیہ وسلمن ﴾ ہٕندِس نادَس پٮ۪ٹھ لبیک ووٚ ن ۔ ﴿جنگ اُحدس اندر ییٚلہِ مُشر کین پوٚت پھیٖرِ تھ کینٛہہ منز ل دوٗر ژٔلۍ، اَمہِ پتہٕ آو تِمن ہو ش تہٕ تِمو لوگ پانہٕ وٲنۍ وَنُن زِ اَسہِ کۅ سہٕ حر کت کٔر یہِ ، اَسہِ اوس محمد صلی اللہ علیہ وسلمن ہُند طا قت پھُٹرا و نُک سٮ۪ٹھاہ قٍمتی مو قع حا صل سپُد مُت ، سُہ راوُر اَسہِ ۔ چنا نچہِ یم ٹھہر یِیہِ أکِس جایہِ تہٕ کوٚرُکھ مشورٕہ زِ مد ینس  پٮ۪ٹھ گژِھہ فوراً دوٚیُم حملہٕ کر نہٕ یُن۔مگر یِمن گٔیہِ نہ ہمت تہٕ گٔے واپس مکہ۔یپٲرۍ اوس نبی صلی اللہ علیہ وسلمن تہِ اندیشہِ زِ یِم گٔژھۍ نہٕ وا پس پھیرٕنۍ۔اَمہِ موجوٗب چِھ حضور صلی اللہ علیہ وسلم جنگِ اُحد کہِ دوٚ یمہِ دۅ ہے مُسلمانن جمع کٔرِ تھ فر ماوان زِ اَسہِ پَزِ کُفار ن ہُند پیچھا کرُن۔اگر چہ یہِ سٮ۪ٹھاہ نازُک مو قع اوس مگر اَمہِ پتہٕ تہِ یِم پٔزۍ مو من ٲسۍ تِم گٔے زُو قر بان کر نہٕ خٲطرٕ تیار تہٕ درٛا ے نبی صلی اللہ علیہ وسلمن سٍتۍ حَمرالاسد نٲوۍ جایہِ تام یۅسہٕ مد ینہٕ پٮ۪ٹھہٕ 8 میل دوٗر چھےٚ۔ییٚمہِ آیتُک اشارٕ چُھ تِمنٕے فدا کار ن کُن۔﴾تِمو منٛزٕ یِم شخص نیکو کار تہٕ پر ہیز گار چِھ ، تِمن خٲطرٕ چُھ بوٚڈ اجر ۔"
  3,173,"۔یِمن لُکو ووٚ ن زِ : تۅہیہِ خلا ف چِھ بٔڑۍ فو ج جمع گٔمٕتۍ ،تِمن کھوٗژِو ، تہٕ یہِ بوٗزِ تھ گوٚو تِہندِس ایمانس منٛز ہُر یٚر تہٕ تِمو دِیُت جوا ب زِ : اَسہِ چُھ اللہ تعالیٰ سٮ۪ٹھاہ تہٕ سُے  چُھ بہتر ین کار ساز۔"
  3,174,"۔ٲخر کار وٲتۍ تِم اللہ تعالیٰ سٕندِ نعمتہٕ سان تہٕ فضلہٕ سان واپس، تِمن ووت نہٕ کُنہِ قسمُک نقصا ن تہِ تہٕ اللہ تعالیٰ سٕندِس رضا ہس پٮ۪ٹھ پکنُک شر ف تہِ گوگھ حٲصل، اللہ تعالیٰ چُھ بوٚڈ فضل کر ن وول۔ ﴿اُحد پٮ۪ٹھہٕ واپس پھیرنہٕ پتہٕ اوس ابوسُفیانن مسلمانن چلینج دِیُتمُت زِ برونٹھس گژِھہ بدرکِس مقامس پٮ۪ٹھ تۅہیہِ تہٕ اَسہِ بیٚیہِ مُقا بلہٕ ۔ مگر ییٚلہِ وعدُک وقت نکھہٕ ووٚت تس ژا یہِ کۅٹھیٚن نٹھ تہٕ روٗزٕس نہٕ ہیٚمتھٕے ۔لہٰذا سوٗز تٔمۍ پنُن اَند بچا و نہٕ مۅ کھہٕ ژوٗرِ پٲٹھۍ اکھ شخص ییٚمۍ مد ینس اندر یِمہٕ خبرٕ پھٔہلاوِ زِ ییٚمہِ ؤرِیہِ چھےٚ قر یشو بٔڑ زبردست تیا ر ی کٔر مٕژ تہٕ تِم چِھ سٮ۪ٹھاہ بوٚڈ لشکر جمع کران ییٚمیُک مقا بلہٕ سارِسٕے عر بس منٛز کٕہٕنۍ ہیٚکہِ نہٕ کٔرِ تھ۔ مُسلمان ٲسۍ اَمہِ اَپزِ خبرِ نِشہِ ہنا مُتٲثر سپٕدۍ مٕتۍ مگر ییٚلہِ اللہ تعالیٰ سٕندۍ رسول صلی اللہ علیہ وسلمو أکِس بٔڑِس لُکہٕ تعدادس منٛز اعلا ن فر مو و زِ اگر کٕہٕنۍ نیرِنہٕ تیٚلہِ نیرٕ بہٕ کُنُے زوٚ ن۔اَمہِ پتہٕ چِھ 15، شتھ فِدا کار تِمن سٍتۍ نیر نہٕ خٲطرٕ تیا ر سپدان تہٕ حضور صلی اللہ علیہ وسلم چِھ تِمے ہیٚتھ بدر تشر یف نِوان ۔ ابو سفیا ن آو نہٕ مقا بلہٕ خٲطرٕ تہٕ مسلمانَو تُل ٲٹھن دۅ ہن بدرس منٛز روٗزِ تھ تجا رتی کاروبارس سٮ۪ٹھاہ فٲیدہ۔﴾"
  3,175,"۔وۅ نۍ لوٚگُو تۅہیہِ پے زِ سُہ اوس دراصل شیطا ن، یُس پننیو دوستو سٍتۍ اوس بٔلۍ کھۅژناوان لہٰذا کھوٚژۍ زیو نہٕ توٚہۍ آیند ہ انسانن، مےٚ کھوٚژۍ زیٚو اگر توٚہۍ حقیقتس منٛز صا حبِ ایمان چِھو۔"
  3,176,"۔﴿اے پیغمبر صلی اللہ علیہ وسلم﴾ یِم لُکھ اَز کُفر چہِ وَتہِ اندر سٮ۪ٹھاہ تگ دَو چِھ کران،تِہنزٕ سر گر میہ مَہ کٔرِنَو تۅہیہِ غمگین، تِم ہیٚکن نہٕ خُدا یس کانٛہہ نقصا ن وا تنٲوِ تھ ،اللہ تعالیٰ سُنٛد اِرادٕہ چُھ یہِ زِ تِہِندِ خٲطرٕ تھاوِ نہٕ ٲخرتس اندر کانٛہہ حصہٕ تہٕ ٲخر کار چُھ تِمن سخت سزا میلَن وول۔"
  3,177,"۔یِم لُکھ ایمان ترٲوِتھ کُفرٕ کۍ خر یدار چِھ بنیمٕتۍ تِم چِھنہٕ یقیناً خُدا یس کانٛہہ نقصا ن کران تِہندِ خٲطرٕ چُھ دگ تُلوُن عذا ب تیار۔"
  3,178,"۔یہِ مہلت یۅسہٕ أسۍ تِمن دِوان چِھ اَتھ مَہ سمجھِن یِم کٲفر پننِس حقس منٛز بہتر کینٛہہ، أسۍ چِھ یِمن امہِ موجوٗب یلہٕ گی تراوان زِ یِم ؤٹِن خوٗب گنا ہن ہُنٛد بار پتہٕ چُھ یِہِندِ خٲطرٕ سخت ذلیل کر ن وول سزا۔"
  3,179,"۔اللہ تعالیٰ دِیہِ نہٕ مو منن اَتھ حا لس منٛز ہر گز روزنہٕ یتھ منزتوٚہۍ لُکھ وُنۍ کیٚنس چِھو ،سُہ کرِ پاک لُکن نا پاک لُکو نِشہِ بیٚو ن ضرور مگر اللہ تعالیٰ سُنٛد چُھنہٕ یہِ طر یقہٕ زِ تۅہیہِ لُکن کر یو غیبس پٮ۪ٹھ مُطلع۔﴿یعنی تۅہیہِ وَنیو زِ تۅہیہِ منٛزٕ کُس چُھ مو مِن تہٕ کُس چُھ منا فق،غیب چہِ کتھہٕ وَننہٕ خٲطرٕ ﴾ یَس سُہ پننیو رسولو منٛزٕ یژھان چُھ تس چُھ منتخب کران، لہٰذا تھٲوِ و ﴿غیب چن کتھن متعلق﴾خُدا یس تہٕ تٔمۍ سٕندٮ۪ن رسولن پٮ۪ٹھ ایمان، اگر توٚہۍ ایمانس تہٕ تقویٰ چہِ رٔوِشہِ پٮ۪ٹھ پٔکِو تیٚلہِ میلیو تۅہیہِ بوٚڈ اجر ۔"
  3,180,"۔یِم لُکھ خدا ین پننہِ فضلہٕ سٍتۍ نوٲزِ مٕتۍ چِھ تہٕ پتہٕ چِھ تِم بخلس کٲم ہیٚوا ن ،تِم مَہ روٗزِ ن اَتھ خیا لس منٛز زِ یہِ بخیلی چھےٚ تِہٕندِ خٲطرٕ جان، نہ، یہِ چھےٚ تِہندِ خٲطرٕ سٮ۪ٹھاہ بُرٕ ،یِکینژھاہ تِم پننہِ کنجو سی سٍتۍ جمع چِھ کران، سُے بَنہِ قیا مت کہ دۅ ہ تِہِنزِ گردٔنۍ ہُند طو ق، زمینک تہٕ آسمانن ہُنٛد میراث چُھ اللہ تعالیٰ سُندُے تہٕ توٚہۍ یِکینژھاہ کران چِھو، اللہ تعالیٰ چُھ تمہِ نِشہِ با خبر ۔ ع"
  3,181,"۔خُدا ین بوٗز تِمن لُکن ہُنٛد قَو ل یِم ونان چِھ زِ اللہ تعالیٰ چُھ فقیر تہٕ أسۍ چِھ غنی۔﴿یہِ اوس یہوٗدٮ۪ن ہُنٛد قَو ل ۔ قرآن مجیدس اندر ییٚلہِ یہِ آیت آیہِ زِ  کُس چُھ  یُس خُدا یس رُت قر ض دِیہِ  اَتھ پٮ۪ٹھ ہزٕل کران کران لو گ یہوٗدیو وَنُن زِ ، آ، خُدا صٲب چُھ غر یب سپُد مُت، وۅ نۍ چُھ سُہ بند ن قر ض منگان ۔﴾ تِہٕنزٕیِمہٕ کتھہٕ تہِ لیٚکھو أسۍ، تہٕ امہِ برونٛہہ یُس تِم پیغمبر ن روٗدۍ نا حق قتل کران ،سُتہِ چُھ یِہندِس نامہ اعمالس منٛز ثَبت ﴿ییٚلہِ فٲصلُک وقت واتہِ تمہِ وقتہٕ ﴾ ونَو أسۍ یِمن زِ ، رٔٹۍ تَو ،وۅ نۍ وُچِھتو جہنم کہ عذا بُک مز ہ ۔"
  3,182,"۔یہِ چَھو تۅہیہِ پننیٚن اَتھن ہٕنز کمٲے، اللہ تعالیٰ چُھنہٕ پننیٚن بند ن ہٕندِ خٲطرٕ ظٲلِم۔"
  3,183,"۔یِم لُکھ ونان چِھ  خُدا ین چُھ اَسہِ ہدا یت کوٚر مُت زِ أسۍ کر و ن نہٕ کانٛہہ رسول تسلیم  یوٚت تام نہٕ سُہ اَسہِ برونٛٹھہٕ کنہِ تِژھہ قربٲنی کرِ یَتھ ﴿غیبی طور یِتھ﴾ نار کھیَیہِ تِمن ؤنِو : تۅ یہِ نِشہِ چِھ مےٚ برونٛٹھ واریاہ نبی آمٕتۍ، یِمو واریاہ روشن نِشٲنِیہِ اَنہِ مَژٕ آسہٕ تہٕ سۅ نشٲنی تہِ ٲسٕکھ أنۍ مٕژ ییٚمِچ ذِکر توٚہۍ کران چِھو ،پتہٕ اگر   ﴿ایمان اَننہٕ خٲطرٕ یہِ شر ط پیش کر نس منٛز ﴾ تۅہۍ پٔزِ یٲرۍ چِھو ، تیٚلہِ  کیازِ کٔریوٗکھ تِم رسول تۅہیہِ قتل؟"
  3,184,"۔اے نبی صلی اللہ علیہ وسلم، وۅ نۍ اگر یِم لُکھ تۅہیہِ بُتھ پھِران چِھ ، تۅہیہِ برونٛہہ چُھ واریاہن رسولن بُتھ آمُت پھِر نہٕ یِمَو ٹا کارٕ ہ نِشٲنِیہِ تہٕ صحیفہ تہٕ گا ش دِنہٕ وا جِنہِ کِتا بہٕ آسہٕ اَنِمژٕ۔"
  3,185,"۔ٲخر کار چُھ پرٛتھ کٲنٛسہِ شخصس مرُن تہِٕ توٚہۍ سٲر ی لٔبِو پنٕنۍ پنٕنۍ پوٗرٕ اجر قیا مت کہ دۅہ ،کا میا ب چُھ دراصل سُہ یُس تَتہِ جہنم کہ نارٕ نِشہِ بچہِ تہٕ جنتس منٛز یِیہِ دٲخل کر نہٕ ،روٗدوۅ نۍ یہِ دُنیا، یہِ چُھ محض اکھ نوٚ ن فر یب ﴿دِنہٕ وول ﴾ چیز۔"
  3,186,"۔مسلمانو، تۅہیہِ یَنَو مال تہٕ جان دۅ شوٕ نۍ ہٕنزٕ آز مٲیشہِ در پیش تہٕ توٚہۍ بوٗزِ و اہلِ کتا بن تہٕ مُشر کن نِشہِ واریاہ تکلیف دہ کتھہٕ ،اگر یِمن تمام حالاتن منٛز توٚہۍ صبر تہٕ تقویٰ چہِ رٔوِشہِ پٮ۪ٹھ قٲیِم روٗزِ و تیٚلہِ چھےٚ یہِ حو صلٕہ واجِنۍ کٲم۔"
  3,187,"۔یِمن اہلِ کتا بن پٲوِو سُہ عہد تہِ یاد یُس خُدا ین یِمن ہیوٚ تمُت اوس، تۅہیہِ آسنو کتا بہِ ہِندۍ تعلیمات پھٔہلاوٕنۍ ،تِم آسنو نہٕ کھٔٹِتھ تھاوٕنۍ مگر تِمو ترٛٲو کتاب پسِ پُشت تہٕ معمو لی قٍمتس پٮ۪ٹھ کٕنِکھ سۅ ،کوتاہ بُرٕ کاروبار چُھ یُس یِم کران چِھ ۔"
  3,188,"۔توٚہۍ سمٕجھ زیٚو نہٕ ہر گز زِ یِم لُکھ پننیٚن کر توٗتن پٮ۪ٹھ خۅ ش چِھ تہٕ یژھان چِھ زِ تِہٕنزن کامیٚن ہٕندۍ تعر یف گٔژھۍ تِمن حٲصل سپٕدنۍ یِم در حقیقت تِمو چَھنہٕ کرِ مژٕ۔توٚہۍ مَہ سمجھوٗ کھ تِم لُکھ عذا ب نِشہِ محفو ظ ،پٔزۍ پٲٹھۍ چُھ تِہندِ خٲطرٕ درد ناک سزا تیار ۔"
  3,189,"۔زمین تہٕ آسمانن ہُند مٲلِک چُھ اللہ تعالیٰ تہٕ تٔمۍ سٕنز قدرت چھےٚ سارِنٕے پٮ۪ٹھ حٲو ی ۔ع"
  3,190,"۔پٔزۍ پٲٹھۍ چھےٚ زمین تہٕ آسما نن ہٕنزِ پیدٲیشہِ منٛز رٲژ ہٕندِس تہٕ دۅ ہ کِس وارِ وارِ یِنَس منٛز تِمن ہو ش مند لُکن خٲطرٕ واریاہ نِشٲنیہِ۔"
  3,191,"۔یِم وۅ تھان ،بیٚہوان تہٕ لَر ترٲوِ تھ، پرٛتھ حالس اندر خُدا یس چِھ یاد کران بیٚیہِ چِھ زمین تہٕ آسمانن ہٕندِس  بنا وٹس پٮ۪ٹھ غور وفکر کران ﴿تِمن چُھ پٲنۍ پانے ژلا ن نیرِ تھ ﴾ پروردِگارٕ، یہِ سورُے کینٛہہ چھُے نہٕ ژےٚ فضو ل تہٕ بے مقصد بنو و مُت، ژٕ چُھکھ پاک امہِ نِشہِ زِ ژٕ کر کھ کانٛہہ فضو ل کٲم۔اے ربّ ،لہٰذا بچا و اَسہِ جہنم کہ عذا بہٕ نِشہِ ۔"
  3,192,"۔ژےٚ یُس اکھاہ  جہنمس تروو تھن، در حقیقت ترٛوو تھن سُہ بٔڑِس ذِلتس تہٕ رُسوٲیی منٛز تہٕ پتہٕ آسہِ نہٕ یِتھیٚن ظٲلِمن ہُنٛد کانٛہہ مددگار"
  3,193,"۔سانہِ ربّہٕ، اَسہِ بوٗزناد دِنہٕ وٲلۍ سُند ناد یُس ایمانس کُن بُلاوان اوس تہٕ ونان اوس زِ پنُن ربّ  مٲنِیوٗن ۔اَسہِ کٔر تٔمۍ سٕنز دعوت قبول اے سانہِ آغہٕ، یِم قصور اَسہِ گٔمٕتۍ چِھ  تِمن کردر گُز ر ۔یِمہٕ بُرٲییہِ اَسہِ منٛز چھےٚ تِمہٕ کردوٗر تہٕ سو ن خٲتِمہٕ کر نیک لُکن سٍتۍ،"
  3,194,"۔خُدا و ند ا،یِم وعدہ ژےٚ پننیٚن رسولن ہٕندِ ذر یعہ چھی کٔرِ مٕتۍ، اَسہِ سٍتۍ کرُکھ تِم پوٗرٕ تہٕ قیا مت کہ دۅ ہ مَہ ترٛاو اَسہِ رُسوٲیی منٛز بے شک چُھکھ نہٕ ژٕ پننِس وعدس خلا ف کر ن وول ۔"
  3,195,"۔در جواب فر مو و تِہندۍ ربّن: بہٕ چُھس نہٕ تۅہیہِ منٛزٕ کٲنٛسہِ ہٕنز عمل ضا یع کر ن وول خوا ہ سُہ مرد ٲسِتن یا خا تو ن، توٚہۍ سٲر ی چِھو اکھ أکۍسٕندۍ ہم جنس، لہٰذا یِمو لُکو میانہِ خٲطرٕ پنٕنۍ وطن ترٛ ٲوۍ۔تہٕ یِم پننیو گھر و منٛزٕ کڑ نہٕ آے تہٕ ستا و نہٕ آے میانہِ وَتہِ اندر تہٕ میانہِ خٲطرٕ لوٚڑُکھ تہٕ مار نہٕ آے، تِہِندۍ سٲر ی قصور کرٕ بہٕ معا ف تہٕ تِم کر کھ تِتھیٚن با غن منزدٲخل یِمن بٔنۍ کِنۍ کۅ لہٕ آسن پکان،یہِ چھُ خُدا یس نِشہِ تِہُند جزا تہٕ بہتر ین جزا چُھ صرف اللہ تعالیٰ ہس نِشہِ ۔"
  3,196,"۔اے نبی صلی اللہ علیہ وسلم، یِنہٕ تۅہیہِ دُنیا کیٚن مُلکن منٛز اللہ تعالیٰ سٕندٮ۪ن نا فر مان لُکن ہُند وۅ تُھن بِہُن کُنہِ دو کھس منٛز ترٛا و یو ۔"
  3,197,"۔یہِ چُھ محض کینژھن دۅ ہن ہٕنزِ زند گی ہُند لُطفہٕ پیوٗنتا ہ، پتہٕ گژھن یِم سٲر ی جہنمس یۅسہٕ بدتر ین روزن جا ے چھےٚ۔"
  3,198,"۔ اتھ بر عکس یِم لُکھ پننِس ربّس کھوٚژۍ کھوٚژۍ زِ ند گی گُزاران چِھ تِہِندِ خٲطرٕ چِھ تِتھۍ با غ یِمن بٔنۍ کِنۍ کۅ لہٕ چھےٚ پکا ن، تِمن با غن منٛز روزن تِم ہمیشہ، اللہ تعالیٰ سٕندِ طر فہٕ چُھ یہِ سامانِ ضیا فت تِہندِ خٲطرٕ تہٕ یِکینژھاہ خُدا یس نِشہِ چُھ نیک لُکن خٲطرٕ، سُے چُھ سارِوٕے کھۅتہٕ بہتر۔"
  3,199,"۔اہلِ کتا بو منٛزٕ تہِ چِھ کینٛہہ لُکھ تِتھۍ یِم خُدا یس مانان چِھ ،تتھ کتا بہِ پٮ۪ٹھ تہِ چِھ ایمان تھاوان یۅسہٕ تۅہیہِ کُن چھےٚ سوزنہٕ آمٕژ تہٕ تتھ کتا بہِ پٮ۪ٹھ تہِ چُھکھ ایمان یوسہٕ ییٚمہِ برونٛہہ خۅد تِمن کُن ٲس سوز نہٕ آمٕژ ،خدا یس برونٛہہ کنہِ چِھ نٔمِتھ تہٕ اللہ تعالیٰ سٕندٮ۪ن آیا تن چِھنہٕ معمو لی قٍمتس کٕنان، تِہُند اجر چُھ تِہندِس ربّس نِشہِ تہٕ اللہ تعالیٰ چُھنہٕ حسا ب نکھہٕ وا لنس منٛز ژیر کران۔"
  3,200,"۔اے لوٗکو یِمو ایمان چُھ اوٚ نمُت ، صبرس ہیٚیِو کٲم ،بٲطل پرستن ہٕندِس مُقا بلس منٛز ہٲوِ و مَر دی، حق کہ خد مت خٲطرٕ روٗزِ و ہوٚل گٔنڈِ تھ تہٕ خُدا یس روٗزِ و کھۅژان، اُمید چھےٚ زِ فلا ح گژھیو حٲصل۔"
