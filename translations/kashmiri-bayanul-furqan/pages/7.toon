quran[206]{c,v,t}:
  7,1,"۔ا۔ل۔م۔ ص۔"
  7,2,"۔یہِ چھےٚ اکھ کتا ب یۅسہٕ تۅہیہِ کُن چھےٚ نٲزِل کر نہٕ آمٕژ، لہٰذا ، اے نبی صلی اللہ علیہ وسلم،تُہٕندِس دِلس منٛز گژِھہ نہٕ اَمہِ سٍتۍ کانٛہہ خو ف سپدُن ﴿یعنی کھۅژنہٕ ورٲے تہٕ خو ف ورٲے و اتنٲوِ و یہِ لُکن تام تہٕ اَمِیُک مَہ کٔرِ و کانٛہہ پر واے زِ مخٲلف کمہِ قٔسمُک استقبا ل کر ن اَتھ ﴾ امہِ کہ نٲزِل کر نُک غر ض چُھ یہِ زِ امہِ سٍتۍ کھۅژنٲوِ یوٗکھ توٚہۍ ﴿ منکر ینِ حق ﴾ تہٕ ایمان اَنن والیٚن خٲطرٕ آسہِ نصیحت ۔"
  7,3,"۔لوٗکو ،یِکینٛژھاہ تُہندِس ربّ سٕندِ طرفہٕ تۅہیہِ پیٹھ نازل چھُ کرنہٕ آمُت تمِچ کٔرِو پیروی تہٕ پنُن ربّ ترٲوِ تھ مَہ کٔرِ و با قی سر پر ستن ہٕنز پیر وی ، مگر توٚہۍ چِھو نصیحت کمٕے پہن مانان ۔"
  7,4,"۔کٲژا ہ بٔستیہِ چھےٚ  یِمہٕ اَسہِ ہلا ک کرِ ،تِمن پٮ۪ٹھ ووٚ تھ سو ن عذا ب اچا نک رٲتھۍ کِیُت، نَتہِٕ آو مَندِ نیٚن تَمہِ ساعتہٕ ییٚلہِ تِم آرا مَس ٲسۍ۔"
  7,5,"۔پتہٕ ییٚلہِ سو ن عذا ب  تِمن پٮ۪ٹھ آو تِہنز ن زبا نن پٮ۪ٹھ اوس نہٕ امہِ ورٲے کانٛہہ آلَو زِ پٔزۍ پٲٹھۍ ٲسۍ أسۍ ظٲلِم ۔"
  7,6,"۔ لہٰذا سپدِ یہِ ضروٗر زِ أسۍ کر و تِمن لُکن پرٛژھہٕ گٲریِمن کُن اسہِ پیغمبر چِھ سوٗزِ مٕتۍ، تہٕ پیغمبر ن تہِ پٕرٛژھو ﴿زِ پیغا م وا تنا ونُک فر ض کتھ حدس تام دِیُت تِمو انجام تہٕ تِمن کیا جوا ب میوٗل تِمیُک﴾"
  7,7,"۔پتہٕ کر و أسۍ خۅد پوٗرٕ علمہٕ سان سٲر ی حالات تِمن برونٛہہ کنہِ پیش ، ٲخر أسۍ ما ٲسۍ کُنہِ جایہِ کھٔٹِتھ روٗزِ تھ۔"
  7,8,"۔ تہٕ وز ن آسہِ تمہِ دۅ ہ عینِ حق۔﴿یعنی تمہِ دۅ ہ آسہِ نہٕ اللہ تعالیٰ سٕندِس حق کِس میزانس منٛز حق ورٲے کانٛہہ چیز گوٚ ب تہٕ وَز نہٕ ورٲے آسہِ نہٕ کانٛہہ چیز حق۔ یس سٍتۍ یوٗتاہ حق آسہِ تیوٗتاہ آسہِ سُہ با وزن ، تہٕ فٲصلہٕ یِکینژھاہ تہِ سپدِ ، سُہ سپدِ و زنہٕ کہ لحا ظہٕ ،بییہِ کُنہِ چیزُک یِیہِ نہٕ ذرّس یوت تہِ لحا ظہٕ کر نہٕ ﴾ یِہِندۍ پٲترۍ گوٚ بۍ آسن  تِمے آسن فلا ح لبن وٲلۍ۔"
  7,9,"۔تہٕ یِہِندۍ پٲتر ۍ لوٚتۍ آسن تِمے آسن پنُن پان خسا رس منٛز تراون وٲلۍ، تِکیازِ تِم ٲسۍ سا نیٚن آیا تن سٍتۍ ظٲلمانہٕ برتاو کران روٗدِمٕتۍ۔"
  7,10,"۔اَسہِ بسٲوِ و توٚہۍ زمینس منٛز اختیار وسان ، تہٕ تُہُندِ خٲطرٕ کوٚر ییٚتہِ زند ہ روزنُک سا مان فرا ہم، مگر توٚہۍ لُکھ چِھو کمٕے پہن شکُر گزار بنان ۔ ع"
  7,11,"۔اسہِ کوٚر تُہندِ تخلیقُک ابتدا ، پتہٕ بنٲو تُہٕنز صورت پتہٕ ووٚ ن فر شتن آد م علیہ السلامس کٔرِ و سجدٕہ، اتھ حُکمس پٮ۪ٹھ کوٚر سارِ وٕ ے سجدٕہ مگر ابلیس سپُد نہٕ سجدٕہ کر ن والیٚن منٛز شٲمل۔﴿اَمِیُک مطلب چُھنہٕ ابلیس اوس فر شتو منٛزٕ۔درا صل ییٚلہِ زمینُک انتظا م کر ن والیٚن فر شتن آد مَ علیہ السلامس برونٛہہ کنہِ سجدٕ ہ کر نُک حُکم دِنہٕ آو، اَمِیُک مطلب اوس یہِ زِ تِم تمام مخلو ق تہِ سپدِ ن آد م علیہ السلام سٕندۍ مُطیع یِم فر شتن ہٕندِ س انتظا مس تحت ٲسۍ۔امہِ مخلو ق منٛزٕ کوٚر صرف اِبلیسن برونٛہہ پٔکِتھ یہِ اعلان زِ سُہ کرِ نہٕ آد م علیہ السلامس برونٛہہ کنہِ سجدٕ ہ ۔﴾"
  7,12,"۔پٕرٛژھنہٕ آس، ژٕ کٔمۍ چیز ن رُکو ونکھ سجدٕ ہ کر نہٕ نِشہ، ییٚلہِ زَن مےٚ اُوسمے ژےٚ حکم دِ یتمُت؟ تٔمۍ ووٚن بہٕ چُھس أمۍ سٕندِ کھۅ تہٕ بہتر ،ژےٚ کوٚر تھس بہٕ نارٕ نِشہِ پٲدٕ، تہٕ یہِ کوٚر تھن میٚژِ نِشہِ پٲدٕ"
  7,13,"۔ فر ما و نہٕ آس ، اچھا ، وَس ژٕ ییٚتہِ بۅ ن ژےٚ چھی نہٕ حق زِ ییٚتہِ کر کھ بجرُک تکبر نیر گژھ، در حقیقت چُھکھ ژٕ تِمو لُکو منٛزٕ یِم پانہٕ پنٕنۍ ذلّت چِھ یژھان۔ ﴿دراصل چُھ لفظ ، صا غر ین ، وَر تا و نہٕ آمُت ۔ صا غر چُھ مُراد الراضی با لذُل، یعنی سُہ یُس ذلّت ، صغار تہٕ ؤسۍ پایہِ حیثیت پانہٕ اختیار کرِ ۔ لہٰذا اوس اللہ تعالیٰ سٕندِ ارشادُک مطلب یہِ زِ بندٕہ تہٕ مخلو ق آسنہٕ با وجو د چو ن پننِس کِبر س مبتلا سپدُن چُھ  یہِ معنہِ تھا وان زِ ژٕ چُھکھ پانہٕ ذلیل یژھان سپدُن ۔﴾"
  7,14,"۔تٔمۍ ووٚ ن ،  مےٚ دِیِو تَتھ دۅ ہس تام مہلت ییٚلہِ یِم سٲر ی دو با رٕ تُلنہٕ یِن"
  7,15,"۔فر ما و نہٕ آس ،  ژےٚ چھےٚ مہلت"
  7,16,"۔تٔمۍ ووٚ ن  اچھا ، یِتھہٕ پٲٹھۍ بہٕ ژےٚ گمر ٲہی منٛز مبتلا کوٚ ر تھس، بٕتہِ روزٕ وۅ نۍ چا نہِ سیٚزِ وَتھ پٮ۪ٹھ یِمن انسانن زاگہِ روٗزِ تھ،"
  7,17,"۔ پرٛتھ طر فہٕ کرٕ بہٕ یِمن گھیرٕ ، بروٗنٹھۍ کِنۍ تہٕ پٔتۍ کِنۍ، دٔچِھنۍ تہٕ کھووٕ رۍ تہٕ ژٕ لبہَکھ نہٕ تِمو منٛز اکثر شکر گز ار کینٛہہ فر ما و نہٕ آس، نیر ییٚتہِ ذلیل تہٕ ٹھکر او نہٕ آمتہِ ۔"
  7,18,"۔یقین تھا وزِ یِمَومنزٕ یِم چٲنۍ پیر وی کر ن ، ژےٚ سان برٕ بہٕ تِمو سٍتۍ جہنم"
  7,19,"۔تہٕ اے آد م علیہ السلام ، ژٕ تہٕ چٲنۍ خا ندارِنۍ ، دۅ شو ے روٗزِ و یتھ جنتس منٛز، ییٚتہِ یُس چیز تۅہیہِ دل وَنہِ سُہ کھیٚیِو ،مگر یتھ کُلس کُن گژھۍ زیٚو نہٕ۔ نَتہٕ گٔژِھو ظٲلِمن منٛز شٲمل۔"
  7,20,"۔پتہٕ ڈٲلۍ تِم شیطا نن۔تاکہ تِہندۍ شر مگا ہ یِم اکھ أکِس نِشہِ چُھپا و نہٕ ٲسۍ آمٕتۍ مٕژ را وِ ہے تِمن برونٛہہ کنہِ۔ تٔمۍ ووٚ ن تِمن تُہٕندۍ ربّن یُس توٚہۍ ییٚمہِ کُلہِ نِشہِ پتھ رٔٹِنو اَمِیُک وجہ چُھنہٕ امہِ ورٲے بیٚیہِ کِہِنۍ زِ توٚہۍ گٔژِھو نہٕ فر شتہٕ بنٕنۍ،یا تۅہیہِ گٔژٕھو نہٕ ہمیشہ خٲطرٕ پو شوٕ نۍ زند گی حٲصل سپدٕنۍ ۔"
  7,21,"۔تہٕ تٔمۍ ووٚن قسم ہٲوِتھ تِمن زِ بہٕ چُھس پز ی تُہُند رُت کا نچھن وول۔"
  7,22,"۔یِتھہٕ پٲٹھۍ أنۍ تٔمۍ تِم دۅ شو ے وارٕ وارٕ دو کھہٕ دِتھ پننِس ژھلس منٛز، ٲخر کار ییٚلہِ تِمو امہِ کُلیُک مزٕ ہ وُچھ،تِہندۍ ستَر سپٕدۍ اکھ أکِس برونٹھہٕ کنہِ یلہٕ،تہٕ تِمو لٲگۍ جنت کیٚو پنہٕ ؤتھر وَسٍتۍ پنٕنۍ جسم ژھا یہِ تھاوٕنۍ، پتہٕ لٲے تِہندۍ ربّن تِمن کرٛیکھ، کیا مےٚ ٲسِمو نا توٚہۍ اَمہِ کُلہِ نِشہِ پتھ رٔٹۍ مٕتۍ۔تہٕ بیٚیہِ او سمو نا ووٚ نمُت زِ شیطا ن چُھ تُہُند ٹا کارٕ ہ دشمن ؟"
  7,23,"۔ دۅ شوٕے ووٚن  اے سانہِ ربّا ،اسہِ کوٚ ر پا نس پٮ۪ٹھ ظُلم، وۅ نۍ ہرگاہ ژےٚ اسہِ در گز ر فر مووُتھ نہٕ تہٕ رحم کوٚرُتھ نہٕ، تیٚلہِ گژَھَو  پٔزِ پٲٹھۍ أسۍ تبا ہ ۔ ﴿امہِ نِشہِ لوٚ گ پے زِ انسانس منٛز چُھ شر م وحیا ہُک جذ بہٕ اکھ فطر ی جذ بہٕ تہٕ امِیُک اوّلین اظہا ر چُھ سۅ شر م یۅسہٕ پننہِ جسمٕکۍ مخصو س حصہٕ با قین برونٹھہٕ کنہِ کھۅ لنہٕ وِزِ انسان فطر تاً ژینان چُھ ، توے ٲس شیطا ن سٕنز گۅڈنِچ چال یۅسہٕ تٔمۍ انسٲنی فطر ت چہِ سیٚزِ وَتہِ نِشہِ ہٹا و نہٕ خٲطرٕ انسانس پٮ۪ٹھ چلٲو یہِ زِ سُہ لگا وِ أمۍ سٕندِس اتھ شر م و حیا کِس جذ بس پٮ۪ٹھ ٹا س تہٕ ننگہٕ گی ہٕنزِ وَتہِ کِنۍ مٕژ راوِ أمۍ سٕندِ خٲطرٕ فحش کا میٚن ہُند دروازٕہ تہٕ أمِس کرِ جنسی معا ملا تن منٛز بدراہ۔امہِ علا وہ سپُد امہِ نِشہِ یِتہِ معلو م زِ انسانس منٛز چھےٚ تھٔدِ س حا لتس پٮ۪ٹھ واتنٕچ اکھ فطر ی بۅ چھہِ مو جو د۔اوَے پیوٚ و شیطا نس أمِس برونٹھ کُن خیر خوا ہ سٕندِس لبا سس منٛز یُن تہٕ یہِ پیو س وَنُن زِ بہٕ چُھسَتھ ژٕ یژھان زیادہ بُلند حالتس کُن نِیُن۔یِتہِ سپُد امہِ نِشہِ معلو م زِ انسان سٕنز اصلی خو بی یۅسہٕ  أمِس شیطا نس سٕندِ س مقا بلس منٛز بہتر چھےٚ بناوان چھےٚ یہِ زِ ییٚلہِ أمِس قصور سرزد سپدِ تیٚلہِ سپدِن یہِ نٲدِم تہِٕ خُدا یس منگِن معٲفی۔اتھ بر عکس ییٚمۍ چیز ن شیطا ن ذلیل تہٕ خوا ر کوٚر ، سُہ اوس یہِ زِ قصور کٔرِ تھ سپُد سُہ خُدا یس مقا بلہٕ کھڑا تہٕ کٔرٕن بغا وت﴾"
  7,24,"۔فر ما و نہٕ آکھ،  ؤسِو بۅ ن، توٚہۍ چِھو اکھ أکۍ سٕندۍ دشمن، تہٕ تُہندِ خٲطرٕ چُھ أکِس خا ص وقتس تام زمین سٕے منٛز جا ے قرار،تہٕ زندٕہ روزنُک سامان۔"
  7,25,"۔بیٚیہِ آکھ فر ماو نہٕ  تٔتی چُھو تۅہیہِ زند ہ روزُن ، تہٕ تٔتی چُھو مَرُن تہٕ ٲخر کار یِیِو توٚہۍ تمی منٛزٕ کڑ نہٕ۔ع"
  7,26,"۔اے اولادِ آد م ، اسہِ کوٚر ژےٚ پٮ۪ٹھ لبا س نٲزِل تاکہ چا نیٚن جسم کیٚن قا بل شر م حصن کرِ پردٕ ،چا نہِ جسم کہ حفا ظت خٲطرٕ تہٕ زینت خٲطرٕ بنہِ ذر یعہ تہِ ، تہٕ بہتر ین لبا س چُھ تقویٰ ہُک لبا س،یہِ چھےٚ اللہ تعالیٰ سٕنزَ و نشٲنِیو منٛزٕ اکھ نِشٲنی، شاید زِ لُکھ کر ن امہِ نِشہِ سبق حٲصل۔"
  7,27,"۔اے بنی آد م ،یِنہٕ یہِ سپدِ زِ شیطا ن کر ی ژےٚ بیٚیہِ تِتھے پٲٹھۍ فتنس منٛز مبتلا ، یتھہٕ پٲٹھۍ تٔمۍ چو ن مو ل مو ج جنتہٕ منٛزٕ کڑ نو و مُت اوس،تہٕ تِہندۍ لبا س ٲسِن تِمن کڑ نٲوِ مٕتۍ ،تا کہ تِہندۍ شر مگا ہ مٕژ راوِ ہے اَکھ أکِس برونٛہہ کنہِ ،سُہ تہٕ تٔمۍ سٕندۍ سٲتھی چِھو تۅہیہِ تِژِھہ جایہِ پٮ۪ٹھہٕ وُچھان ییٚتہِ پٮ۪ٹھہٕ نہٕ توٚہۍ تِم ہیٚکِیوٗکھ وُچِھتھ ،یِم شیطا ن چِھ اسہِ تِمن لُکن ہٕندۍ سر پرست بنا وِمٕتۍ یِم ایمان چِھنہٕ اَنان ۔"
  7,28,"۔یِم لُکھ ییٚلہِ کانٛہہ شر منا ک کٲم چِھ کران،پتہٕ چِھ ونان زِ اَسہِ چِھ پنٕنۍ مٲلۍ بڈِ بب أتھۍ طر یقس پٮ۪ٹھ وُچِھمتۍ تہٕ اللہ تعالیٰ نٕے چُھ اسہِ یہِ کر نُک حکم دِیتمُت ،﴿یہِ ارشاد چُھ عر ب کیٚن لُکن ہٕندِس ننگہٕ طوا فس کُن۔ تِمن منٛز ٲسۍ اکثر لُکھ حج کِس مو قعس پٮ۪ٹھ ننگے طوا ف کران تہٕ تِہنزٕ زنانہٕ آسہٕ اَتھ معا ملس منٛز مردَو کھۅ تہٕ زیادے بے حیا ، تِہنز ن نظر ن منٛز ٲس یہِ اکھ مذ ہبی کٲم، تہٕ نیک سمجھِتھ ٲس یہِ کٲم کر نہٕ یِوان ﴾یِمن ؤنِو ، اللہ تعالیٰ چُھنہٕ زانٛہہ بے حیٲیی ہُند حکم دِوان ،کیا توٚہۍ چِھوٕ ہ اللہ تعالیٰ سُند ناو ہیٚتھ تِمہٕ کتھہٕ ونان یِمن متعلق تۅہیہِ علم چُھنہٕ زِ تِمہٕ چھےٚ اللہ تعالیٰ سٕندِ طر فہٕ ؟"
  7,29,"۔اے نبی صلی اللہ علیہ وسلم، یِمن ؤنِو ،میٲنۍ ربّن چُھ سیٚز رُک تہٕ انصا فُک حکم دِیتمُت، تہٕ تٔمۍ سُند حکم چُھ یہِ زِ پرٛتھ عبا دتس منٛز تھٲوِ و پنُن رۅ خ ٹھیک تہٕ تٔسۍ کٔرِو آلو،پنُن دین تس خٲطرٕ خٲلص کٔرِ تھ،یتھہٕ پٲٹھۍ تٔمۍ توٚہۍ اَز چِھنَو پٲدٕ کٔرِ مٕتۍ تِتھے پٲٹھۍ یِیِو توٚہۍ بیٚیہِ پٲدٕ کر نہٕ۔"
  7,30,"۔أکِس دٔرِس چھےٚ تٔمۍ سٔیِز وَتھ ہٲومٕژ مگر دوٚ یِمِس دٔرِس پٮ۪ٹھ چھےٚ گمرٲہی روٗزِ مٕژ چسپان گٔژِھتھ،تِکیازِ تِمو چِھ خُدا یس بجا ے شیطا ن پنٕنۍ سر پرست بنٲوِ مٕتۍ،تہٕ تِم چِھ سمجھان زِ أسۍ چِھ سیٚزِ وَتہِ پٮ۪ٹھ۔"
  7,31,"۔اے بنی آد م ، پرٛتھ عبا دت کِس مو قعس پٮ۪ٹھ روٗزِ و پننہِ زینت سٍتۍ آراستہٕ۔﴿یتھ جایہِ چُھ زینت مُراد مکمل لبا س۔اللہ تعالیٰ سٕندِس عبا دتس منٛز کھڑا سپد نہٕ خٲطرٕ چُھنہٕ صرف یُتُے کٲفی زِ انسان چُھپا وِ صرف پنُن ستر ، بلکہ چُھ اتھ سٍتۍ یِتہِ ضروری زِ پننہِ طا قتہٕ موجو ب لا گِن سُہ پنُن لبا س تہِ ، ییٚمہِ سٍتۍ ستر پوٗشی تہِ سپدِ تہٕ زینت تہِ ۔انسان یِتھہٕ پٲٹھۍ کٲنٛسہِ معزز انسانس سمکھنہٕ خٲطرٕ جا ن لبا س چُھ لاگان تِتھے پٲٹھۍ پَزِ تس اللہ تعالیٰ سٕندِ عبا دت خٲطرٕ تہِ جان لبا س لا گُن۔﴾بیٚیہِ کھیٚیِو چیٚیِو حدٕ مَہ نیرِو ،تِکیازِ اللہ تعالیٰ چُھنہٕ حدٕ نیر ن والیٚن پسند کران ۔ ع"
  7,32,"۔اے نبی صلی اللہ علیہ وسلم ، یِمن ؤنِو ، کٔمۍ کٔر اللہ تعالیٰ سٕنز سۅ زینت حرا م یۅسہٕ خُدا ین پننیٚن بندن خٲطرٕ کٔڑ مٕژ ٲس تہٕ کٔمۍ ٲسۍ اللہ تعالیٰ سٕندۍ پاک چیز ممنو ع کٔرِ مٕتۍ؟ ؤنِو ،یِم سٲر ی چیز چِھ دُنیا چہِ زند گی منٛز تہِ ایمان انن والیٚن خٲطرٕ ، تہٕ قیا مت کہ دۅ ہ تہِ آسن خٲلص پٲٹھۍ تِمنٕے خٲطرٕ۔۔یِتھہٕ پٲٹھۍ چِھ أسۍ پننہِ کتھہٕ صا ف صا ف بیان کران تِمن لُکن خٲطرٕ یِم علم تھا و ن وٲلۍ چِھ ۔"
  7,33,"۔اے نبی صلی اللہ علیہ وسلم ، یِمن ؤنِو زِ میٲنۍ ربّن یِم چیز حرا م چِھ کٔر مٕتۍ تِم چِھ یِم : بے شر می ہِنزٕ کامہِ خوا ہ نَنہِ وانہٕ سپدَن یا ژھا یہِ پٲٹھۍ تہٕ گنا ہ ﴿دراصل چُھ لفظ اِثمُ وَرتا وٕ نہٕ آمُت ییٚمیُک اصلی معنی چُھ کوتٲہی۔تہٕ امہِ نِشہِ چُھ مُراد انسان سٕنز پننِس ربّ سٕندِس اطا عتس تہٕ فر مانبردٲر ی منٛز کوتٲہی کرٕنۍ ﴾ تہٕ حقس خلا ف زیا دتی۔﴿یعنی حدٕ نیرِ تھ تِتھیٚن حدوٗد ن منٛز قد م تراوُن یِمن منٛز اَژنُک حق انسانس آسہِ نہٕ ﴾ تہٕ یہِ زِ خُدا یس سٍتۍ کٔرِ و یوٗن توٚہۍ کانٛہہ تِیُتھ شر یک ییٚمۍ سٕندِ خٲطرٕ تٔمۍ کانٛہہ سَندَ چَھنہٕ نٲزِل کٔر مٕژ،بیٚیہِ یہِ زِ اللہ تعالیٰ سٕندِس نا وس پٮ۪ٹھ ؤنِو کانٛہہ تِژھہ کتھ یتھ متعلق تۅہیہِ علم آسیو نہٕ ﴿زِ حقیقتس منٛز چھےٚ سۅ تٔمی فر مٲومٕژ﴾۔"
  7,34,"۔پرٛتھ قو مَس خٲطرٕ چُھ مُہلتُک اکھ وقت مُقرر،پتہٕ ییٚلہِ کُنہِ قو مُک مُقرر وَقت چُھ پوٗرٕ سپدان تیٚلہِ چُھنہٕ أکِس گرِ سُمب تہِ ژیر سپدان۔﴿تہٕ یہِ کتھ ٲس خُدا ین تخلیق کہ آغا ز کہِ وقتے صا ف فر مٲومٕژ زِ ﴾"
  7,35,"۔اے بنی آد م ، یا د تھا و ، اگر توٚہیہِ نِشہِ خۅ د تۅ ہیہ منٛزٕ تِتھۍ رسول یِن ، یِم تۅہیہِ میٲنۍ آیا ت آسن بو زناوان، تیٚلہِ یُس نا فر مٲنۍ نِشہِ بچہِ تہٕ پننِس رٔوِ یس کرِ اصلا ح،تس خٲطرٕ چُھنہٕ نہ کُنہِ خو فُک مو قع تہٕ نہ کُنہِ غمُک،"
  7,36,"۔تہٕ یِم لُکھ سانیٚن آیا تن بُتھ پھِر ن ۔ تہٕ تِہندِس مقا بلس  منٛزوَرتاون سر کشی ﴿تکبُر﴾ تِمے آسن جہنمی ،ییٚتہِ تِم ہمیشہ روزن ۔"
  7,37,"۔ٲخر کُس آسہِ تس کھۅ تہٕ بوٚڈ ظٲلِم یُس سراسر اَپزِ کتھہٕ بناوِ تھ خُدا یس کُن منسوٗب کرِ ،یا کرِ اللہ تعالیٰ سٕندٮ۪ن پز ٮ۪ن آیا تن انکار؟ یِتھۍ لُکھ روزن پننہِ تقدیر کہ نٔوِ شتہٕ ﴿لوح محفو ظ﴾ مطٲبق پنُن حصہٕ حا صل کران، ﴿یعنی دُنیا ہس منٛز ییٖتاہ دۅ ہ تِہندِ مۅ ہلتٕکۍ مقرر چِھ تَتھ وقتس تام روزن ییٚتہِ تہٕ بظٲہر ییٚمہِ قسمٕچ زند گی تِہندِس نصیبس آسہِ خوا ہ رٕژ ٲسِتن یا خرا ب، تِم گُزارن سۅ ﴾ یوٚت تام زن سۅ گٔر واتہِ ییٚلہِ سٲنۍ سوزنہٕ آمٕتۍ فر شتہٕ تِہندۍ روح قبض کر نہٕ خٲطرٕ واتن تمہِ وقتہٕ پٕرٛژھن تِم تِمن زِ ؤنِووۅ نۍ کتہِ چِھ تُہٕندۍ معبو د یِمن توٚہۍ خُدا یس بجا یہِ آلو ٲسِو دِوان ؟ تِم وَنن زِ  اَسہِ رٲوۍ سٲر ی۔ تہٕ تِم دِن خۅ د پا نس خلا ف گوٲہی زِ أسۍ ٲسۍ پٔزِ پٲٹھۍ منکرِ حق۔"
  7,38,"۔اللہ تعالیٰ فر ما و یکھ، گٔژِھو ، توٚہۍ تہِ گٔژِھو تٔتھۍ جہنمس یتھ منٛز تۅہیہِ برونٹھِم گُزر یمٕتۍ جِنَن تہٕ انسانَن ہٕندۍ دٔرۍ چِھ گٔمتۍ،پرٛتھ دوٚر ییٚلہِ جہنمس منٛز اَژِ سُہ سپدِ پننِس بروٗنٹھِمِس دٔرِس پٮ۪ٹھ لعنت کران کران دٲخل، حتیٰ کہ ییٚلہِ سٲر ی تَتہِ جمع سپدن،تہٕ پرٛتھ کانٛہہ پٔتِم دوٚر وَنہِ گۅڈنِکِس دٔرِ س متعلق زِ اے ربّ ،یِم ٲسۍ تِم یِمو أسۍ گمراہ کٔرۍ،لہٰذا دِیو یِمن نارُک دۅ گنہٕ عذا ب،در جوا ب سپدِ ارشاد، پرٛتھ کٲنٛسہِ ہٕندِ خٲطرٕ چِھ دۅگنہٕ عذاب مگر تۅہیہِ چَھو نہٕ پے۔﴿یعنی اکھ عذا ب پانہٕ گمرٲہی اختیار کر نُک تہٕ دویُم عذا ب با قی گمر اہ کر نُک ،اکھ سزا پننیٚن جُر من ہُند تہٕ دویُم سزا دوٚ یِمیٚن خٲطرٕ پیشگی جُر من ہُند میراث پتھ کُن ترا و نُک ﴾"
  7,39,"۔ تہٕ گۅڈنِیُک دوٚر وَنہِ دوٚیِمِس دٔرِس زِ  ﴿اگر أسۍ قا بلِ الزام ٲسۍ ﴾تۅہیہ کۅسہٕ  فضیلت ٲسٕو تیٚلہِ اسہِ پٮ۪ٹھ، وۅ نۍ وُچِھو پننہِ کما یہِ ہٕندِ بد لہٕ عذا بُک مزٕہ۔ع"
  7,40,"۔پژھ کٔرِو ،یِمو لُکو سا نیٚن آیا تن اِنکار چُھ کوٚر مُت تہٕ تِہندِ س مقا بلس منٛز چَھکھ سر کشی کٔرمٕژ، تِہٕندِ خٲطرٕ یِن نہٕ آسما نٕکۍ دروازٕہ  ہر گز مژٕ روانہٕ،تِہُند جنتس گژُھن چُھ تیوٗتُے نا ممکن یوت سٕژٕ نۍ گدِ مٔنٛزۍ او نٹہٕ سُند نیرُن چُھ،مُجر من چُھ اَسہِ نِشہِ یُتُھے بد لہٕ میلان،"
  7,41,"۔یِہندِ خٲطرٕ آسہِ جہنمُک وَتھرُن تہٕ جہنم کُے وُرُن، یہِ چُھ سُہ بد لہٕ یُس أسۍ ظٲلِمن چِھ دِوان ۔"
  7,42,"۔اتھ برعکس یِمو سٲنۍ  آیات چِھ مٲنۍ مٕتۍ بیٚیہِ چھکھ رٕژٕ کامہِ کرِ مَژٕ، تہٕ اتھ معا ملس منٛز چِھن أسۍ پرٛتھ کانٛہہ تٔمۍ سٕندِ اِستطا عت مُطا بٕقے ذمہ دار ٹھہرا وان، تِم چِھ اہلِ جنت ، ییٚتہِ تِم ہمیشہ روزن۔"
  7,43,"۔تِہندٮ۪ن دِلن منٛز یُس کدوٗرت اکھ أکِس خلا ف آسہِ سُہ کڑو ن أسۍ نیٚبر،تِمَن بٔنۍ کِنۍ آسن کۅ لہٕ پکا ن، تہٕ تِم وَنن زِ  تعر یف چُھ اللہ تعالیٰ سٕندی خٲطرٕ ییٚمۍ اَسہِ یہِ وَتھ ہٲو، أسۍ ہیٚکہِ ہَو نہٕ پانہٕ وَتھ لٔبِتھ ہرگاہ اللہ تعالیٰ سٲنۍ رہنمٲیی کرِ ہے نہٕ، سٲنِس ربّ سٕندۍ سوز نہٕ آمٕتۍ رسول ٲسۍ پٔزِ پٲٹھۍ حقٕے ہیٚتھ آمٕتۍ ۔تمہِ وقتہٕ یِیہِ آواز زِ یہِ جنت ییٚمِکۍ توٚہۍ وٲرث چِھو بنا و نہٕ آمٕتۍ یہِ چُھو تۅہیہِ تِمن عملن ہٕندِ بد لہٕ حٲصل سپُد مُت یِم توٚہۍ کران ٲسِو ۔"
  7,44,"۔پتہٕ وَنن یِم جنتٕکۍ لُکھ جہنم کیٚن آلو دِ تھ،  اسہِ لٔبۍ تِم سٲر ی وعدہ ٹھیک یِم سٲنۍ ربّن اَسہِ سٍتۍ کٔرِ مٕتۍ ٲسۍ، تۅہیہِ تہِ لٔبِوَ ا تِم وعدہ ٹھیک یِم تُہٕندۍ ربّن کٔرِ مٕتۍ ٲسۍ؟ تِم دِن جوا ب آ پتہٕ لایہِ اکھ ناد دِنہٕ وول تِمن در میان ناو زِ اللہ تعالیٰ سٕنز لعنت تِمن ظٲلِمن پٮ۪ٹھ ۔"
  7,45,"۔یِم اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ لُکن رُکاوان ٲسۍ، تہٕ تتھ ٲسۍ یژھان ہج کرٕ نۍ بیٚیہِ ٲسۍ ٲخرتس کران انکار۔"
  7,46,"۔ یِمن دۅ شوٕنۍ دَر ٮ۪ن﴿گروہن﴾ منٛز با گ سپدِ اکھ پردٕ ہ حٲیل ییٚمہِ کیٚن تھزر ن ﴿عرا فن ﴾ پٮ۪ٹھ بیٚیہِ تہِ کینٛہہ لُکھ آسن، یِم پرٛزناون پرٛتھ کٲنٛسہِ تٔمۍ سٕندِ ڈیٚکہِ سٍتۍ،تہٕ جنت والیٚن وَنن آلو دِتھ زِ  سلامتی ٲسِن تۅہیہِ پٮ۪ٹھ یِم لُکھ سپدۍ نہٕ جنتس منٛز دٲخل مگر تمِکۍ اُمیدوار آسن۔﴿یعنی یِم اصحا ب الا عرا ف آسن تِم لُکھ یِہنزِ زند گی ہُند نَہ آسہِ مثبت پہلو تیوٗتاہ مضبوط زِ یِم ہیٚکن جنتس دٲخل سپدِ تھ تہٕ نَہ آسہِ منفی پہلو تیوٗتاہ خرا ب زِ جہنمس یِن ترا و نہٕ۔لہٰذا روزن تِم جنتس تہٕ جہنم کِس درمیٲنی سر حدس پٮ۪ٹھ تہٕ اللہ تعالیٰ سٕندِ فضلہ سٍتۍ آسیٚکھ یہِ اُمید زِ اَسہِ گوٚژھ جنت نصیب سپدُن ﴾"
  7,47,"۔تہٕ ییٚلہِ تِہنزٕ نظرٕ جہنم والیٚن کُن پھیر ن تیٚلہِ وَنن ،اے سا نہِ ربّا ، اَسہِ کٔرۍ زیٚنہٕ یِمن ظٲلِمن لُکن منٛز شٲمل ۔ع"
  7,48,"۔پتہٕ کر ن یِم اعرا فٕکۍلُکھ جہنم کیٚن کینژھن بجن شخصیتن تِہٕنز و نِشٲنیو سٍتۍ  پرٛز نٲوِ تھ  آلو زِ وُچِھوٕ ہ تۅہیہِ،اَز نَہ آے  تُہٕندۍ ٹو لہٕ تۅہیہِ بکار تہٕ نہ تِم ساز و سامان یِمن توٚہۍ ﴿تکبُر سان ﴾ بٔڑۍ چیز ٲسِو سمجھان۔"
  7,49,"۔تہٕ کیا یِم اہلِ جنت چِھنا تِمے لُکھ یِمن متعلق توٚہۍ قسم ہٲوۍ ہٲوۍ ونان ٲسِو زِ یِمن دِیہِ نہٕ اللہ تعالیٰ پننہِ رحمت منٛزٕ رَژھ تہِ ؟ اَز آو یِمنٕے وَننہٕ زِ دٲخل سپدِ و جنتس منٛز ،تُہٕندِ خٲطرٕ نَہ چُھ خو ف نَہ سپدِ و توٚہۍ غمگین۔"
  7,50,"۔تہٕ تِم جہنمٕکۍ لُکھ کر ن جنّت والیٚن آلو،زِ اسہِ پٮ۪ٹھ ترٲوۍ تَو کم کینژھاہ آب یا یُس رز ق خُدا ین تۅہیہِ دِیتمُت چُھنَو تمی منٛزٕ چھٔکۍ تَو کینژھاہ،تِم دِن جوا ب زِ  خُدا ین چِھ یِم دۅ شو ے چیز تِمن منکر ینِ حقن پٮ۪ٹھ حرام کٔرِمٕتۍ،"
  7,51,"۔یِمو پنُن دین کھیل تہٕ تفر یح اوس بنو و مُت تہٕ یِم دنیا چہِ زند گی ٲسۍ دوکھس منٛز مبتلا کٔرِ مٕتۍ،اللہ تعالیٰ چُھ فر ماوان اَز مٔشر او وکھ أسۍ تہِ تِم تِتھے پٲٹھۍ ، یِتھہٕ پٲٹھۍ تِم أزۍ کہ دۅ ہُک ملا قات مٔشر اوان ٲسۍ،تہٕ سانیٚن آیا تن روٗدۍ انکار کران ۔"
  7,52,"۔ أسۍ چِھ یِمن لُکن نِشہِ اکھ تِژھ کتا ب ہیٚتھ آمٕتۍ،یۅسہٕ اَسہِ علم کِس بنیا دس پٮ۪ٹھ مفصل چھےٚ بنٲومٕژ، تہٕ یۅ سہٕ ایمان انَن والیٚن خٲطرٕ ہدا یت تہٕ رحمت چھےٚ۔"
  7,53,"۔کیا وۅ نۍ چھا یِم لُکھ اَمہِ ورٲے بیٚیہِ کُنہِ کتھہِ پراران زِ سُہ انجام گژِھہ برونٛہہ کُن یُن ییٚمِچ یہِ کتاب خبر چھےٚ دِوان ؟ ییٚمہِ دۅ ہ سُہ انجام برونٛہہ کُن آو،تِمے لُکھ یِمو یہِ گۅڈٕ نظر اندا ز اوس کوٚر مُت وَنن زِ پٔز پٲٹھۍ ٲسۍ ربّ سٕندۍ رسول حق ہیٚتھ آمٕتۍ،کیا وۅ نۍ میلنہٕ اَسہِ کینٛہہ سفٲرش دَر،یِم سٲنِس حقس منٛز سفٲرش کرن؟ نَتہٕ گٔژھۍ أسۍ دوبار واپس یِنۍ سوزنہٕ ،تاکہ یِکینژھاہ أسۍ گۅڈٕ ہ ٲسۍ کران تتھ بر عکس کر ہَو أسۍ دوٚ یِمِس طر یقس پٮ۪ٹھ کٲم۔ تِمو ترٛوو پنُن پان خسا رس منٛز تہٕ تِم سٲر ی اَپزِٕ ۍ رٲوۍ اَز تِمن ، یِم تِمو تصنیف ٲسۍ کٔرِ مٕتۍ ۔ ع"
  7,54,"۔در حقیقت چُھ تُہُند ربّ اللہ تعالیٰ ہٕے ییٚمۍ آسمان تہٕ زمین شیٚن دۅ ہن منٛز پٲدٕ کٔرۍ ﴿یَتھ جایہِ چُھ لفظ دۅ ہ  تَمی ژوٚوہَن گٲنٛٹن ہٕندِ دۅ ہُک ہم معنی یَتھ دُنیا ہکۍ لُکھ دۅہ چِھ ونان یا چُھ یہِ لفظ دَور  کِس معنِیَس منٛز وَرتا و نہٕ آمُت۔﴾پتہٕ سپُد پننِس سلطنت کِس تختس پٮ۪ٹھ  جلو ہ فر ما ۔﴿ اللہ تعالیٰ سُند عر شس پٮ۪ٹھ جلوہ فر ما سپد نٕچ تفصیلی کیفیت سمجھُن چُھ سانہِ خٲطرٕ نا ممکن ۔ یہِ چُھ مُتشا بہا تَو منٛزٕ یِہِندۍ معنے متعیّن ہیٚکن نہٕ کر نہٕ یِتھ ۔﴾ یُس رٲژ چُھ دۅ ہس پٮ۪ٹھ وَلان ،تہٕ پتہٕ چُھ رٲژ پتے دۅ ہ یِوان ،ییٚمۍ آفتا ب تہٕ زوٗن تہٕ تا رک پٲدٕ کٔرۍ ، سٲر ی چِھ تٔمۍ سٕندی فر ما نٕکۍ تٲبع۔ خبردار روٗزِ و ! تٔمۍ سُندُے  چُھ پٲدٕ کرُن تہٕ تٔمۍ سُندُے چُھ حُکم ۔﴿ یعنی اللہ تعالیٰ نٕے چھےٚ یہِ کا ینا ت پٲدٕ کٔر مٕژ تہٕ سُے چُھ اَمِیُک فر ما نروا، پنٕنۍ خلق چِھنہٕ تٔمۍ با قین حوالہٕ کٔرِمٕتۍ،نہ چُھن کٲنٛسہِ مخلو قس یہِ حق دیتمُت زِ خۅد مختار سپدِ تھ یِکینژھاہ ییژِھ تہِ کرِ ﴾ سٮ۪ٹھاہ  با بر کت آسنُک مطلب چُھ یہِ زِ تٔمۍ سٕنز ن خو بِیَن تہٕ رٕژر ن چُھنہٕ کانٛہہ حدٕے ، بے حد تہٕ بے حسا ب خیرات چُھ تٔمۍ سٕندی ذات نِشہِ پھٔہلان﴾ سارِنٕے جہا نن ہُند مٲلک تہٕ پروردگار۔"
  7,55,"۔ناد لٲیِو پننِس ربّس  زٲر ی کرا ن کران تہٕ ژھا یہِ پٲٹھۍ،پٔزۍ پٲٹھۍ چُھنہٕ سُہ حدٕ نیر ن والیٚن پسند کران۔"
  7,56,"۔زمینس منٛز مَہ کٔرِو فساد بر پا، ییٚلہِ زن اتھ اصلا ح چُھ سپُد مُت۔﴿ یعنی ہتہٕ بدیٚو تہٕ ساسہٕ بد یٚو ؤرِ یو پٮ۪ٹھہٕ یِم اللہ تعالیٰ سٕندِ یٚو پیغمبر و تہٕ انسٲنی زُر یا ت کیٚو خیر خوا ہو ہٕنز و کوٗشِشو سٍتۍ انسانی اخلا ق تہٕ تمد نس منٛز اصلا حات سپد یمٕتۍ چِھ تِمن منٛز مَہ کٔرِ و پننیو غلط کٲرِیو سٍتۍ خرٲبی پٲدٕ ﴾ بیٚیہِ کٔرِ و اللہ تعالیٰ سٕے آلو خو فس سان تہٕ امیدٕ سان،پٔزۍ پٲٹھۍ چھےٚ اللہ تعالیٰ سٕنز رحمت نیک کردار لُکن نکھہٕ۔"
  7,57,"۔تہٕ اللہ تعالیٰ ہٕے چُھ سُہ یُس ہوا ہَن چُھ پننِس رحمتَس برونٛہہ برونٛہہ خو شخبر ی ہیٚتھ سوزان، پتہٕ ییٚلہِ تِم آبہٕ دار اوٚ بر س تھود چِھ تٰلا ن،تہٕ پتہٕ چِھ تَتھ کُنہِ مۅردٕہ زمینس کُن حر کت دِوان ،تہٕ سُہ چھُ تَتہِ روٗد ترٲوِتھ ﴿تَمی سو ختہٕ گٔمتہِ زمین منٛزٕ ﴾ رنگہٕ رنگہٕ میوٕ ہ کڑان، وُچِھو، یِتھہٕ پٲٹھۍ چِھکھ أسۍ مۅردٕ موت کہ حالت منٛزٕ کڑا ن، شا ید زِ توٚہۍ رٔٹِو امہِ مُشٲہدٕ ہ نِشہِ سبق۔"
  7,58,"۔یۅسہٕ زمین اصل چھےٚ آسان سۅ چھےٚ پننِس ربّ سٕندِ حُکمہٕ سٍتۍ جان پیدا وار دِوان،تہٕ یۅسہٕ زمین خرا ب چھےٚ آسان تتھ چُھنہٕ نا قص پیداوار ورٲے بیٚیہِ کِہِنۍ نیران، یِتھے پٲٹھۍ چِھ أسۍ گرِ گرِ کران نشٲنیہِ پیش تِمن لُکن خٲطرٕ یِم شکر گزار سپد ن وٲلۍ چِھ ۔ ع"
  7,59,"۔اَسہِ سوٗز نو ح علیہ السلام تٔمۍ سٕندِس قو مس کُن۔﴿حضر ت نو ح علیہ  السلامن ہُند قو م اوس تتھ علا قس منٛز روزان یتھ أسۍ از کل عرا ق چِھ وَنان ﴾ تٔمۍ ووٚ ن  اے برادارانِ قو م، اللہ تعالیٰ سٕنز بند گی کٔرِ و ، تس ورٲے چُھنہٕ تُہُند کانٛہہ خُدا ے  بہٕ چُھس تُہٕندِس حقس منٛز اکہِ وُلٹہٕ دۅ ہ کہ عذا ب نِشہِ کھۅژان"
  7,60,"۔تٔمۍ سٕند یو قو م کیو سردار و دِیُت جوا ب اسہِ چُھ یہِ  با سان ژٕ چُھکھ ٹا کارٕ ہ گمرٲہی منٛز مبتلا"
  7,61,"۔نو ح علیہ السلام  چِھ وَنان  اے برادرانِ قو م ،بہٕ چُھس نہٕ کُنہِ گُمرٲہی منٛز مبتلا ، بلکہ چُھس بہٕ ربّ العا لمین سُند رسول،"
  7,62,"۔تۅہیہِ نِش چُھس پننِس   ربّ سٕندۍ پیغا م واتنا وان ، بہٕ چُھس تُہُند خیر خواہ تہٕ مےٚ چُھ اللہ تعالیٰ سٕندِ طر فہٕ تِکینژھاہ پے یہِ نہٕ تۅہیہِ پے چُھو ۔"
  7,63,"۔کیا تۅہیہِ گوٚوٕ ہ اتھ کتھہِ پٮ۪ٹھہٕ تعجُب زِ تۅہیہِ نِشہِ وٲژ خۅد تُہٕندِس قو م کِس أکِس شخصہٕ سٕندِ ذر یعہِ تُہندِس ربّ سٕنز یاد ہٲنی تاکہ تۅہیہِ کر یو خبردار تہٕ توٚہۍ بٔچِو غلط رٔوِیہِ نِشہِ تہٕ تۅہیہِ پٮ۪ٹھ یِیہِ رحم کر نہٕ  ؟"
  7,64,"۔مگر تِمو پھِیُرتس بُتھ، ٲخر کار دِیُت اسہِ تس تہٕ تٔمۍ سٕندٮ۪ن سٲتھیٚن أکِس ناوِ منٛز نجا ت،تہٕ تِم لُکھ ڈُبٲوۍ یِمو سانیٚن آیا تن انکار اوس کوٚر مُت، پٔزۍ پٲٹھۍ ٲسۍ تِم نا بینا لُکھ ۔ ع ۔"
  7,65,"۔تہٕ عادس کُن سوٗز تٔمۍ سُند بو ے ہوٗد علیہ السلام ﴿قومِ عادُک اصلی ٹھِکا نہٕ اوس  احقا ف علا قہٕ یُس حجا ز، یَمن تہٕ یمامَہ  ہَس منٛز با گ چُھ ۔ییٚتی پٮ۪ٹھ پھٔہلِتھ کوٚر تِمو یَمن کیٚن مغر بی سٲحِلن ،عما ن تہٕ حضر مو ت پٮ۪ٹھہٕ عرا قس تام پننہِ طا قتُک دبد بہٕ قٲیِم ﴾ تٔمۍ ووٚ ن  اے برادارِن قو م ، اللہ تعالیٰ سٕنز بند گی کٔرِ و ، تس ورٲے چُھنہٕ تُہُند بیٚیہِ کانٛہہ خُدا ے  تیٚلہِ کیا ،توٚہۍ کٔرِ ونا غلط کا میو نِشہِ پر ہیز ؟"
  7,66,"۔تٔمۍ سٕندِ قو م کیو سردارَو ،یِم تٔمۍ سٕنز کتھ ماننہٕ نِشہِ انکار ٲسۍ کران ، ووٚ نہَس در جوا ب اَسہِ چُھ با سان ژٕ چُھکھ بے عقلی منٛز مبتلا ، تہٕ اَسہِ چُھ با سان ژٕ چُھکھ اَپزِ یو ر ۔"
  7,67,"۔تٔمۍ ووٚن  اے بردارانِ قو م ، بہٕ چُھس نہٕ بے عقلی منٛز مبتلا ،بلکہ چُھس بہٕ ربّ العا لمین سُند رسول، تۅہیہِ نِشہِ چھُس پننِس ربّ سٕندۍ پیغام واتناوان،"
  7,68,"۔ بیٚیہِ چُھس  تُہُند تِیُتھ خیر خواہ  یَس پٮ۪ٹھ بھر وسہٕ یِیہِ کر نہٕ،"
  7,69,"۔کیا تۅہیہِ گوٚوٕہ اَتھ کتھہِ پٮ۪ٹھ تعجُب زِ تۅہیہِ نِشہِ وٲژ خۅد تُہندِی قو م کِس نفرٕ سٕندِ ذر یعہ تُہندِس ربّ سٕنز یا د دہٲنی، تا کہ سُہ کر یو تۅہیہِ با خبر ؟ مٔشِتھ مَہ گٔژِھ نَو ،تُہٕندۍ ربّن بنٲوِ نَو توٚہۍنو ح علیہ السلام سٕندِ قو م پتہٕ پنٕنۍ جا نشین،تہٕ توٚہۍ بنٲوۍ نَو جا ن پٲٹھۍ صحت مند ، لہٰذا تھٲوِ و اللہ تعالیٰ سٕندِ قد ر تٕکۍ کمالات  یاد ، ﴿دراصل چُھ لفظ آلا  وَرتا و نہٕ آمُت، ییٚمیُک معنی نعمتن ہُند تہِ چُھ  تہٕ اللہ تعالیٰ سٕندٮ۪ن کمالات ہُند تہِ ، بیٚیہِ صفا ت حمید ہ تہِ ﴾ اُمید چھےٚ زِ فلا ح لٔبِو۔"
  7,70,"۔تِمَو دِیُت جوا ب  کیا ژٕ چُھکھہٕ اسہِ نِشہِ امہِ موجو ب آمُت زِ أسۍ کرَو کُنِس اللہ تعالیٰ سٕنزٕ ے یٲژ عبا دت تہٕ تِم ترا ووکھ یِہٕنز عبا دت سٲنۍ مٲلۍ بُڈِ بب چِھ روٗدِ مٕتۍ کران؟  اچھا ، اَن ژٕ سُہ عذا ب ییٚمِچ دھمکی ژٕ اسہِ  دِوان چُھکھ اگر ژٕ پٔزِ یو ر چُھکھ ۔"
  7,71,"۔تٔمۍ ووٚ ن  تُہٕندِس ربّ سُند عذا ب ووٚتھ  تۅہیہِ پٮ۪ٹھ تہٕ بیٚیہِ تٔمۍ سُند غضب۔ کیا توٚہۍ چِھوٕ مےٚ سٍتۍ تِمن نا وَن پٮ۪ٹھ ژُوان یِم تۅہیہِ تہٕ تُہٕندۍ مٲلۍ بُڈِببن تھٲوِمٕتۍ چِھ ، ﴿یعنی توٚہۍ چِھو کٲنٛسہِ روٗدُک، کٲںٛسہِ ہوا ہُک ، کٲنٛسہِ دو لتُک تہٕ کٲنٛسہِ بیمارِ ہُند ربّ ونان ، حالانکہ یِمو منٛزٕ چُھنہٕ در حقیقت کانٛہہ تہِ کُنہِ چیزُک ربّ،یِم سٲر ی چِھ محض ناو یِم تۅہیہِ تھٲوِمٕتۍ چِھو،یُس یِہِندۍ مۅ کھہٕ ژُوان چُھ سُہ چُھ دراصل کینژھن ناوَ ن ہٕندِ مۅ کھہٕ ژُوان نَہ زِ کُنہِ حقیقت خٲطرٕ﴾ یِہندِ خٲطرٕ خُدا ین کانٛہہ سَندَ چَھنہٕ نٲزِل کٔرِمٕژ؟ اچھا تیٚلہِ کٔرِ و توٚہۍ تہِ انظا ر تہٕ بٕتہِ کرٕ تۅ ہیہِ سٍتۍ انتظا ر۔"
  7,72,"۔ٲخر  کار بچو و اَسہِ پننہِ مہر بٲنی سٍتۍ ہوٗد علیہ السلام تہٕ تٔمۍ سٕندۍ  سٲتھۍ۔تہٕ تِمن لُکن ژوٚٹ موٗل یِمو سا نیٚن آیا تن بُتھ پھِیرُ تہٕ تِم ٲسۍ نہٕ ایمان اَنن وٲلۍ۔ع"
  7,73,"۔تہٕ ثمود س کُن سوٗز اَسہِ تٔمۍ سُند بو ے صا لح علیہ السلام ﴿قومِ ثمودٕ چ   روزن جا ے ٲس شمال مغر بی عر بُک سُہ علا قہٕ یُس از تہٕ الحجر ناوٕ زاننہٕ چُھ یِوان ۔ مو جودٕ ہ زمانس منٛز چھےٚ مدینس تہٕ تبو کس در میان اکھ جاے یتھ مدا ین صا لح چِھ ونان ۔ یۅہے اوس ثمودُک صدرِ مقام تہٕ پرٲنِس زمانس منٛز ٲسِس حجر وَنان ۔ از تام چھےٚ تَتہِ قو مِ ثمود چہِ کینٛہہ عما رتہِٕ مو جو د یِمہٕ تِمو با ل کھٔنۍ کھٔنۍ  بنا وِ مژٕ آسہٕ ﴾ تٔمۍ ووٚن  اے برادرانِ قو م، اللہ تعالیٰ سٕنز بند گی کٔرِ و ، تس ورٲے چُھنہٕ تُہُند بیٚیہِ کانٛہہ خُدا ے،تۅہیہِ نِشہِ چھےٚ تُہندِس ربّ سٕنز ٹا کارٕ دلیل آمٕژ،یہِ اللہ تعالیٰ سٕنز اوٗنٹِنۍ چھےٚ تُہٕندِ خٲطرٕ اکہِ نشٲنی رٔنگۍ ، ﴿ امہِ قصٕکۍ یِم تفصیلا ت قرآنس منٛز مختلف جا ین بیان چِھ سپٕدۍ مٕتۍ تِمو نِشہِ چُھ ننان زِ ثمو د کیو لُکو اوس پانہٕ خۅد حضرت صا لح علیہ السلامَس اکہِ تِژِھہ نشٲنی ہُند مطا لبہٕ کوٚر مُت یۅسہٕ اللہ تعالیٰ سٕندِ طر فہٕ تِہندِس مامور آسنس پٮ۪ٹھ ٹا کارٕ ہ دلیل آسہِ  ،تہٕ اَمہِ کِسٕے جوا بَس منٛز ٲس حضرت صا لح علیہ السلامن اونٹنۍ پیش کٔر مٕژ۔﴾  لہٰذا ترٲوِیوٗن یہِ یلہٕ تا کہ اللہ تعالیٰ سٕندِس زمینس منٛز روزِ گاسہٕ کھیٚوان پھیران،أمِس لٲگۍ زِ یو نہٕ کُنہِ بُرٕ ارادٕہ سان اتھہٕ، نَتہٕ رَٹیو تۅہیہِ اکھ دَگ تُلوُن عذا ب۔"
  7,74,"۔یاد کٔرِ و سُہ وقت ییٚلہِ خُدا ین قو مِ عا دٕ پتہٕ توٚ ہۍ تمِکۍ جا نشین بنٲوِ نو تہٕ تۅہیہِ کوٚر نَو زمینس منٛز یہِ تھز ر عطا زِ اَز چِھو توٚہۍ تٔمۍ سٕندٮ۪ن ہموا ر مٲدانن منٛز عٲلیشان محل بناوان۔ تہٕ تٔمۍ سٕندۍ بال چِھو مکانن ہٕنزِ شکلہِ منٛز گران لہٰذا  مَہ سپدِ و تٔمۍ سٕند یو قدرت کیو کما لاتو نِشہِ غٲفل، تہٕ زمینس منٛز مَہ کٔرِ و فسا د ۔"
  7,75,"۔تٔمۍ سٕند یو قوم کیو سردارَو یِم نَرِ دٔچِھنۍ ﴿مغرور ﴾ ٲسۍ بنیمٕتۍ ووٚ ن کمز ور طبقہٕ کیٚن تِمن لُکن یِمو ایمان اوس اوٚ نمُت ٍ کیا توٚہۍ چِھوٕ ہ زانان پٔزۍ پٲٹھۍ زِ صا لح علیہ السلام چِھ پننِس ربّ سُند پیغمبر؟ تِمو دِیُت جوا ب بے شک یُس پیغا م ہیٚتھ سُہ سوزنہٕ چُھ آمُت سُہ چِھ أسۍ مانان ۔"
  7,76,"۔یِم نَرِ دٔچِھنۍ ٲسۍ بنیمٕتۍ  تِمَو ووٚن، یُس چیز تۅہیہِ مو نمُت چُھو أسۍ چِھ تتھ انکار کران۔"
  7,77,"۔پتہٕ مٲرتِمو سۅ اوٗنٹِنۍ ﴿اگر چہِ سۅ او نٹنۍ صرف أکی شخصن مٲر مٕژ ٲس یِتھ پٲٹھۍ زن سورۂ قمر س تہٕ سورۂ شمَسَس منٛز ارشاد چُھ سپُد مُت،مگر چو نکہ سورُے قو م اوس تس شخصس پٔتۍ کِنۍ ڈٔکھِس ،تہٕ سُہ اوس در اصل اتھ جُر مَس منٛز قو م چہِ مر ضی ہُند آلۂ کار، امہِ موجوٗب چُھ الزام سٲرِ سٕے قو مس پٮ۪ٹھ کھا لنہٕ آمُت﴾ تہٕ پوٗرٕ گُستٲخی سان کٔرٕ کھ پننِس ربّ سٕندِ حکمٕچ خلا ف ورز ی،تہٕ بیٚیہِ ووٚ نُکھ صا لح ﴿علیہ اسلامَس ﴾ زِ  گژھ اَن سُہ عذا ب ییٚمِچ دھمکی ژٕ اسہِ دِوان چُھکھ۔ ہرگاہ ژٕ پز ۍ پٲٹھۍ پیغمبر و منٛزٕ چُھکھ۔"
  7,78,"۔ٲخر کار آیہِ اَکھ لرزاوَن واجِنۍ آفت تہٕ رٔٹِن تہٕ تِم روٗدۍ پننیٚن گھر ن اندر بُتھ تل  کُن دِتھ پیٚتھ۔"
  7,79,"۔تہٕ صا لح  علیہ السلام درَاو تِہنزِ بستی منٛزٕ یہِ ونان ونان زِ اے میانہِ قو مہٕ ، مےٚ واتنو و پننِس ربّ سُند پیغا م ژےٚ تام تہٕ مےٚ کٔر چٲنۍ سٮ۪ٹھاہ خیر خوٲہی،مگر بہٕ کیا کرٕ ژےٚ چِھی نہٕ پنٕنۍ خیر خوا ہ پَسندٕ ے۔"
  7,80,"۔ تہٕ لوٗط علیہ السلام سوٗز اسہِ پیغمبر بنٲوِ تھ ، پتہٕ کٔرِ و یا د ییٚلہِ تٔمۍ پننِس قو مس ووٚ ن ﴿حضرت لو ط علیہ السلام ٲسۍ حضرت ابرا ہیم علیہ السلامن ہٕندۍ با بتھٕر ، تہٕ یہِ قو م ییٚمہِ کہ ہدا یت خٲطرٕ تِم سو زنہٕ ٲسۍ آمٕتۍ اوس تتھ علا قس منٛز روزان یتھ جایہِ وۅ نۍ بحیرۂ مُردار واقع چُھ﴾  کیا توٚہۍ چِھو اتِتھۍ بے حیا سپدۍ مٕتۍ زِ سۅ فحش کٲم چِھو کران یۅسہٕ تۅہیہِ برونٛہہ دُنیا ہس منٛز کٲنٛسہِ چَھنہٕ کٔرمٕژ؟"
  7,81,"۔توٚہۍ چِھو زَنا نو بجا یہِ مردن سٍتۍ پنٕنۍ خوٲہش پوٗرٕ کران،حقیقت چھےٚ یہِ زِ توٚہۍ چِھو  با لکُلٕے حدٕ نیر ن وٲلۍ لُکھ۔"
  7,82,"۔مگر تٔمۍ سٕندِ قو مُک جوا ب اوس نہٕ امہِ ورٲے کِہِنۍ زِ کٔڑِیوٗکھ یِم لُکھ پننیو بستیو منٛزٕ، یِم چِھو سٮ۪ٹھاہ پاک باز بنان ۔"
  7,83,"۔ٲخر کار کوٚڈ اَسہِ لوٗط علیہ السلام تہٕ تٔمۍ سٕندۍ گھر وٲلۍ بچٲوِ تھ نیٚبر، سِوا ے تٔمۍ سٕنز خاندارِنۍ یوسہٕ پتھ روزن والیو منٛزٕ ٲس۔"
  7,84,"۔تہٕ اَتھ قو مس پٮ۪ٹھ ترٲواکھ بٲرِش، پتہٕ وُچِھو زِ تِمن مجر من ہُند انجام کیا سپُد۔ع ﴿بٲرش چُھنہٕ یتھ جایہِ مُراد آبُک روٗد بلکہ چُھ مُراد کنہِ روٗد یِتھہٕ پٲٹھۍ زن قرآنس اندر با قی جا ین بیان چُھ سپُد مُت ﴾"
  7,85,"۔ پتہٕ سوٗز اسہِ مَد یَن کیٚن لُکن کُن تٔمۍ سُند بو ے شعیب علیہ السلام۔ ﴿مَد یَنُک اصلی علا قہٕ اوس حجا زٕ کِس شما ل مغر بس تہٕ فلسطین کِس جنو بس منٛز بحراحمر تہٕ خلیج عَقَبہ کِس بٔٹِھس پٮ۪ٹھ مگر جزیر ہ نما ے سینا کِس مشر قی بٔٹھِس پٮ۪ٹھ تہِ اوس اَمِیُک کینٛہہ سلسلہٕ پھٔہلِتھ۔یہِ اوس اکھ سٮ۪ٹھاہ بوٚڈ تجا رت پیشہِ قو م ۔ پرٲنِس زمانس منٛز یۅسہٕ بٔڈ تجا رتی وَتھ بحرِ احمر کہِ بٹھہِ بٹھہِ یَمنہٕ پٮ۪ٹھہٕ مکہ تہٕ ینبو ع کِنۍ نِیرِ تھ شام تام گژھان ٲس تہٕ بیاکھ اکھ بٔڈ تجا رتی وَتھ یۅسہٕ عرا ق پٮ۪ٹھہٕ مِصرس کُن گژھان ٲس،امہِ کِس ژُؤتِس پٮ۪ٹھ آسہِ امہِ قو م چہِ بٔستیہِ آبا د﴾ تٔمۍ ووٚن : اے برادارنِ قو م ، اللہ تعالیٰ سٕنز بند گی کٔرِ و ، تس ورٲے چُھنہٕ تُہُند بیٚیہِ کانٛہہ خُدا ے تۅہیہِ نِشہِ چھےٚ تُہندِس ربّ سٕندِ طر فہٕ ٹا کارٕ رہنمٲیی آمٕژ،لہٰذا کٔرِ و ، وَز ن تہٕ پیمانہٕ پوٗرٕ، لُکن مَہ دِیِو تِہند ٮ۪ن چیز ن منٛز گھا ٹہٕ، تہٕ زمینس منٛز مَہ کٔرِ و فساد بر پا ییٚلہِ زن اَمِیُک اصلا ح چُھ سپُد مُت، أتھۍ منٛز چُھ تُہُند رٕژَر اگر توٚہۍ پٔزۍ پٲٹھۍ مو من چِھو۔﴿امہِ نِشہِ چھُ صا ف پے لگا ن زِ یِم لُکھ ٲسۍ ایمانٕکۍ دعویٰ دار ﴾"
  7,86,"۔تہٕ ﴿زند گی ہٕنزِ ﴾ پرتھ وَتہِ پٮ۪ٹھ مَہ بِہِو رَہز ن ﴿ڈا کو ﴾ بٔنِتھ زِ لُکھ کھۅژنٲوِ یو کھ تہٕ ایمان اَنن وٲلۍ لٲگِیوٗکھ اللہ تعالیٰ سٕنزِ وَتہِ نِشہِ رُکاوٕنۍ تہٕ سِیٔز وَتھ ۂج کر نہٕ باپت  گٔنڈِ و ہوٚ ل،یاد کٔرِ و سُہ وقت ییٚلہِ توٚہۍ کمٕے ٲسِو، پتہٕ بنٲوِ نَو خُدا ین توٚہۍ واریاہ، تہٕ أچھ مٕژرٲوِتھ وُچِھو زِ دُنیا ہس منٛز کُس انجام چُھ فساد کر ن والیٚن ہُند سپُد مُت۔"
  7,87,"۔اگر تۅ ہیہِ منٛزٕ اکھ دوٚ ر تَتھ تعلیم  پٮ۪ٹھُ ایمان چُھ اَنان یَتھ سٍتۍ بہٕ سو زنہٕ چُھس آمُت تہٕ بیاکھ چُھنہٕ ایمان اَنان ، تیٚلہِ روٗزِ و صبرٕ سان وُچھان یوٚت تام اللہ تعالیٰ اسہِ در میان فٲصلہٕ کرِ، تہٕ سُے چُھ سارِوٕے کھۅتہٕ بہتر فٲصلہٕ کر ن وول ۔"
  7,88,"۔ تٔمۍ سٕندِ قو م کیو سردارَو یِم پننِس بجرٕ کِس تکبر س منٛز ہیٚنہٕ ٲسۍ آمٕتۍ ،ووٚ نہَس زِ  اے شعیب علیہ السلام، أسۍ کڑ وتھ ژٕ تہٕ تِم لُکھ یِمو ژےٚ سٍتۍ ایمان چُھ اوٚ نمُت پننہِ بستی منٛزٕ ، نَتہٕ چُھو تۅہیہِ لُکن سٲنِس مِلّتس منٛز واپس یُن  شعیب علیہ السلام چِھ جوا ب دِوان  کیا أسۍ یِموٕ ہ زبردستی پھِر نہٕ اگر چہِ أسۍ رٲضۍ آسَو نہٕ ؟"
  7,89,"۔ أسۍ آسو خُدا یس بہتا ن لگا و ن وٲلۍ اگر تُہٕندِس مِلّتس منٛز واپس پھیٖر ۍ ییٚلہِ زن خُدا ین اسہِ امہِ نِشہِ چُھ نجا ت دِیتمُت، سانہِ خٲطرٕ چُھنہٕ وۅ نۍ تتھ کُن پھیرُن کُنہِ پٲٹھۍ تہِ ممکن اِلّایہِ زِ اللہ تعالیٰ ، سو ن ربّ اگر ییٚژِھہ سٲنِس ربّ سُند علم چُھ پرٛتھ چیز س پٮ۪ٹھ حٲوی، تٔسۍ پٮ۪ٹھ کوٚر اسہِ اعتماد ،اے سانہِ ربّہ ، اسہِ تہٕ سٲنِس قو مس در میان کر ٹھیک ٹھیک فٲصلہٕ تہٕ ژٕ چُھکھ بہتر ین فٲصلہٕ کر ن وول"
  7,90,"۔تٔمۍ سٕند قو م کیو سردار و یِمو تٔمۍ سٕنز کتھ ماننہٕ نِشہِ انکار اوس کوٚر مُت لٔگۍ پانہٕ وٲنۍ وَننہِ اگر تۅہیہِ شعیب علیہ السلام سٕنز پیروی قبول کٔرٕ و ، تیٚلہِ گٔژِھو برباد۔ ﴿یہِ کتھ چَھنہٕ صرف شعیب علیہ السلامن ہٕندِ قو م کیٚن سردار نٕے تام محدوٗد۔پرٛتھ زمانس منٛز چِھ بِگر یمتِیو لُکو حقس ، سیٚز رس تہٕ دیا نت چہِ رٔوِشہِ منٛز یِتھی خطرات محسو س کٔرِمٕتۍ۔ پرٛتھ دورٕ کیٚن فساد کرن والیٚن ہُند چُھ یۅ ہے خیال روٗد مُت زِ تجا ر ت ، سیا ست تہٕ با قی دُنیٲوی معا ملات ہیٚکن نہٕ اَپزِ ورٲے، بے ایمٲنی  تہٕ بد اخلٲقی وَرٲے پٔکۍ تھٕے۔ایمان دٲر ی پٮ۪ٹھ پکُن گوٚو پنُن دُنیا بر باد کرُن ﴾"
  7,91,"۔  مگر سپُد یہِ زِ اکھ کھۅژناون واجِنۍ آفت آیہِ تہٕ رٔٹِن تہٕ تِم روٗدۍ پننیٚن گھر ن منٛز بُتھ تل کُن گٔژِھتھ پیٚتھ۔"
  7,92,"۔یِمو لُکو شعیب ﴿علیہ السلامس ﴾ بُتھ پِھیرُ تِم مٹیٚا ے تِتھہٕ پٲٹھۍ زنتہٕ تِم تِمن گھر ن منٛز بَسیٚا متی ٲسۍ نہٕ ٲخر سپٕدۍ تِمے برباد یِمو شعیب ﴿علیہ السلامس﴾ بُتھ پھِیرُ۔"
  7,93,"۔تہٕ شعیب علیہ السلام درٛاو یہِ ونان ونان تِہنز و بستیَو منٛزٕ زِ اے بردارانِ قو م ، مےٚوا تنٲوۍ پننِس ربّ سٕندۍ پیغام تۅہیہِ تام تہٕ تُہٕنزِ خیر خوٲہی ہُنٛد حق کوٚرُم ادا۔وۅ نۍ کِتھہٕ پٲٹھۍ کرٕ بہٕ تتھ قومس پٮ۪ٹھ افسوس یُس حق ماننہٕ نِشہِ انکار چُھ کران۔ ع"
  7,94,"۔زانٛہہ تہِ چُھنہٕ یہِ سپُد مُت زِ اَسہِ آسہِ کُنہِ بستی منٛز نبی سوزمُت تہٕ تمہِ بستی ہٕندۍ لُکھ آسن نہٕ گۅڈٕ تنگی تہٕ سختی منٛز مبتلا کٔرِ مٕتۍ،امہِ خیا لہٕ زِ شا ید ما کر ن تِم عٲجز ی اختیار۔"
  7,95,"۔پتہٕ بدلٲو اَسہِ تِہٕنز بد حٲلی خۅشحالی سٍتۍ یوٚت تام زن تِم ٹھیک پٲٹھی پھا نپھلے تہٕ لٔگۍ وَننہِ زِ سا نیٚن اَسلا فن تہِ چِھ رٔتۍ تہٕ خرا ب دۅ ہ آمتی روٗدمٕتۍ۔ ٲخر کار رٔٹۍ اسہِ تِم اچا نک تہٕ تِمن لٔج نہٕ پے تہِ ۔﴿أکِس أکِس نبیس متعلق تہٕ اکہِ اکہِ قو مُک معا ملہٕ بیوٚ ن بیوٚ ن پٲٹھۍ بیان کر نہٕ پتہٕ چُھ وۅ نۍ سُہ جا مع ضٲبطہٕ بیان کر نہٕ یِوان یُس پرٛتھ زمانس منٛز خُدا ین چُھ ابنیا علیہُم السّلامن ہٕندِس بعث کِس مو قعس پٮ۪ٹھ اختیار کوٚر مُت، تہٕ سُہ چُھ یہِ زِ ییٚلہِ کُنہِ قومہٕ خٲطرٕ کانٛہہ نبی سوز نہٕ آو،قو م آو گۅڈٕ ہ مصیبتن تہٕ آفا تن منٛز مبتلا کر نہٕ تا کہ تَمِکۍ کَن گژھن نصیحت خٲطرٕ یلہٕ تہٕ سُہ گژِھہ پننِس خُدا یس برونٛہہ کنہِ عٲجز ی سان نمنَس پٮ۪ٹھ آمادٕہ۔پتہٕ ییٚلہِ اتھ ساز گار ما حو لس منٛز تہِ تَمِیُک دل حق قبو ل کر نس کُن مٲیل سپدُ نہٕ، پتہٕ آو سُہ خۅشحٲلی ہٕندِس فِتنس منٛز مبتلا کر نہٕ ، تہٕ ییٚتہِ پٮ۪ٹھہٕ گوٚو تَمہِ چہِ بربٲدی ہُند دٔسلابہٕ شر وع۔ پیغمبر سٕنز کتھ نہ بو زنہٕ با و جود ییٚلہِ تَتھ پٮ۪ٹھ نعمتن ہٕنز بٲرش سپٕز تیٚلہِ سمجُھ تٔمۍ زِ پٮ۪ٹھہٕ کنہِ چُھنہٕ کانٛہہ خُدا ے مو جو د یُس گر فت کر ن وول آسہِ تہٕ ﴿ ہمچو ماد یگر ے نیست  سانہِ کھۅ تہٕ کھٔسِتھ چُھنہٕ کانٛہہ ﴾ اَمہِ قٔسمُک ہوا ژَاو تَتھ دما غس تہٕ أمۍ چیز ن کوٚر یہِ ٲخر کار اللہ تعالیٰ سٕندِس عذا بس منٛز مبتلا﴾"
  7,96,"۔ہرگاہ بٔستِیَن ہٕندۍ لُکھ ایمان اَنہن تہٕ تقویٰ ہٕچ رٔوِش کر ہن اختیار تیٚلہِ مٕژ راوٕ ہَو أسۍ تِمن پٮ۪ٹھ آسمان تہٕ زمین کیٚن بر کتن ہٕندۍ دروازٕہ،مگر تِمو پھِیرُ بُتھ،لہٰذا رٔٹۍ اسہِ تِم تَمہِ بُرٕ کَما یہِ ہٕندِس حسا بَس منٛز یۅسہٕ تِم وَٹا ن ٲسۍ۔"
  7,97,"۔تیٚلہِ کیا ، بٔستِین ہٕندۍ لُکھ گیا وۅ نۍ امہِ نِشہِ بے خو ف زِ سٲنۍ گرفت یِیہِ نہٕ رٲتھ کِیُت اچا نک تِمن  پٮ۪ٹھ ییٚلہِ زن تِم شوٚنگِتھ آسن؟"
  7,98,"۔یا تِمن چھا اطمینان سپُد مُت زِ سو ن مضبو ط اتھہٕ پیٚیہِ نہٕ اچا نک تِمن پٮ۪ٹھ دۅ ہ کہ وقتہٕ ییٚلہِ زن تِم گِندان آسن؟"
  7,99,"۔کیا یِم لُکھ چھا اللہ تعالیٰ سٕنزِچالہِ نِشہِ بے خو ف ؟ حالانکہ اللہ تعالیٰ سٕنزِ چالہِ نِشہِ چُھ سُے قو م بے خو ف آسان یُس تبا ہ سپدن وول آسہِ ۔ع ﴿دراصل چُھ لفظ  مَکرَ وَرتا و نہٕ آمُت یمِیُک معنی عر بی زبٲنۍ منٛز خفیہ تد بیر چُھ۔یعنی کٲنٛسہِ شخصس خلا ف تِژھ چال گِندٕ نۍ زِ یوٚت تام نہٕ تس پٮ۪ٹھ فٲصلہٕ کر ن وول ٹا س وَسہِ توٚت تام گژِھہ نہٕ تس پے لگٕنۍ زِ تس چھےٚ شہمت یِنہٕ واجِنۍ بلکہ گژِھہ سُہ ظٲہر ی حالات وُچِھتھ یی سمجھان روزُن زِ سورُے چُھ ٹھیک ۔﴾"
  7,100,"۔بیٚیہِ کیا تِمن لُکن یِم سٲبق اہلِ زمینو پتہٕ زمینٕکۍ وٲرث چِھ آسان ، دیُت نا أمۍ اَمرِ وا قعن کانٛہہ سبق ﴿یعنی تِمن میوٗل نا ہدا یت زِ ﴾ اگر أسۍ یژھو تیٚلہِ ہیکو کھ أسۍ تِم تِہندٮ۪ن قصور ن پٮ۪ٹھ رٔٹِتھ؟ ﴿مگر تِم چِھ سبق آمو ز حقٲیقو نِشہِ کنہٕ ڈو ل دِوان ﴾ تہٕ أسۍ چھِ تِہندٮ۪ن دِلن پٮ۪ٹھ مۅ ہر لگا وان ،پتہٕ چِھنہٕ تِم کِہِنۍ بوزان۔"
  7,101,"۔یِم قو م یِہٕندۍ قصہٕ أسۍ تۅہیہِ بوزناوان چِھو ﴿چِھ تۅہیہِ برونٛہہ کنہِ مِثا لہِ رٔنگۍ موجود ﴾، یِہندۍ رسول آے یِمن نِشہِ ٹا کارٕہ نشٲنیہِ ہیٚتھ ، مگر یَتھ چیز س یِمَو اکہِ پھِرِ انکاراوس کوٚر مُت پتہٕ ٲسۍ نہٕ تِم تتھ مانن وٲلۍ ،وُچِھو یِتھہٕ پٲٹھۍ چِھ أسۍ حقس انکار کر ن والیٚن ہٕندٮ۪ن دِلن پٮ۪ٹھ مۅ ہر لگاوان۔"
  7,102,"۔اَسہِ وُچھ نہٕ یِمو منٛزٕ اکثر ن منٛز عَہدُک ﴿وَعدُک ﴾ کانٛہہ پاس۔ بلکہ وُچھ اکثر فا سق۔"
  7,103,"۔پتہٕ سوٗزتِمن قو من پتہٕ ﴿یِہٕنز ذکر پٮ۪ٹھہٕ کنہِ کر نہٕ آیہِ ﴾ اَسہِ مو سیٰ علیہ السلام پننہِ نِشٲنیہِ ہیٚتھ فر عو نس تہٕ تٔمۍ سٕندٮ۪ن قو م کیٚن سردارن نِشہِ ۔﴿لفظ  فر عو ن  اَمِیُک معنی چُھ سو ر ج دیو تا سُند اولا د  مصرٕ کۍ پرٛٲنۍ لُکھ ٲسۍ آفتا بس یُس یُہُند مہا د یو یا ربّ اعلیٰ اوس، رَع  وَنان تہ فر عو ن اوس أمۍ سٕے کُن منسو ب ۔یہِ او س نہٕ کٲنٛسہِ أکِس شخصہٕ سُند ناو کینٛہہ بلکہ اوس مِصر کیٚن با دشا ہن ہُند لقب یِتھہٕ پٲٹھۍ رو س کیٚن با دشاہن ہُند لقب زار تہٕ ایرا ن کیٚن با دشا ہن ہُند لقب کِسریٰ اوس ﴾ مگر تِمو تہِ کوٚر سانیٚن نِشٲنِین سٍتۍ ظُلم، لہٰذا وُچِھو تِمن فساد کر ن والیٚن ہُند کیا انجام سپُد ۔"
  7,104,"۔ مو سیٰ ﴿علیہ السلامن ﴾ ووٚ ن  اے فر عو ن ، بہٕ چُھس کا ینا ت  کِس مٲلک سٕندِ طر فہٕ یو ر سو ز نہٕ آمُت،"
  7,105,"۔میو ن منصب چُھ یۅ ہے زِ اللہ تعالیٰ سُند ناو ہیٚتھ وَننہٕ حق ورٲے کانٛہہ کتھ، بہٕ چُھس تۅہیہِ لُکن نِشہِ تُہندِس ربّ سٕندِ طر فہٕ ٹا کارٕ دلیلِ ما موٗر یت ہیٚتھ آمُت، لہٰذا سوزُکھ ژٕ بنی اسرا یل مےٚ سٍتۍ۔"
  7,106,"۔ فر عو نن ووٚ ننس  اگر ژےٚ کانٛہہ نشٲنی چھےٚ أنِمٕژ تہٕ پننِس دعویٰ ہَس منٛز چُھکھ پٔزِ یو ر تیٚلہِ کر سۅ پیش ۔"
  7,107,"۔مو سیٰ ﴿علیہ السلامن ﴾ چھوٚ ک پنُن عا صہٕ تہٕ اچانک اوس سُہ اکھ زند ہ شہمار ﴿اژدہا ﴾۔"
  7,108,"۔تٔمۍ کوٚڈ پننہِ چندٕ منٛزٕ اتھہٕ تہٕ سارِ نٕے وُچھن والیٚن برونٛہہ کنہِ اوس سُہ چمکا ن ۔ ع"
  7,109,"۔اتھ پٮ۪ٹھ ووٚن فر عو ن سٕندِ قو م کیو سردارَو پانہٕ وٲنۍ زِ یقیناً چُھ یہِ شخص بوٚڈ مٲہر جا دو گر ۔ تۅہیہِ چُھو پننہِ زمین نِشہِ بے دا خل کرُن یژھان ۔ ﴿ مو سیٰ علیہ السلا من ہٕندِ نبو تُک دعویٰ اوس پا نس منٛز پا نے یہِ معنی تھاوان زِ تِم علیہ السلام ٲسۍ در اصل زند گی ہٕندِ س سٲرِ سٕے نِظا مس بحیثیتِ مجمو عی تبد یل کرُن یژھان،یتھ منٛز شکہٕ ورٲے ملکُک سیٲسی نظا م تہِ شٲمل چُھ۔تِکیازِ ربّ العٰلمین سُند نُما یند ہ چُھنہٕ زٕ ہٕنۍ مُطیع تہٕ رعیّت بٔنِتھ روزنہٕ خٲطرٕ یِوان بلکہ چُھ مُطا ع ﴿ییٚمۍ سٕنز اطا عت کر نہٕ یِیہِ ﴾ تہٕ را عی ﴿وتہٕ ہاوُک ﴾ بننہٕ خٲطرٕ ے یِوان روزان تہٕ کٲنٛسہِ کٲفرٕ سٕنزِ حکمر ٲنی ہُند حق تسلیم کرُن چُھ تٔمۍ سٕندِس رسا لت کِس حیثیتس خلا ف ۔ یۅ ہے و جہ چُھ زِ حضرت مو سیٰ علیہ السلامن ہٕنزِ  زبٲنۍ رسا لتُک دعویٰ بوز ان بوزانٕے گوٚو فر عو نس تہٕ تٔمۍ سٕندٮ۪ن سلطنت کیٚن ذمہٕ دار ن برونٛہہ کنہِ سیٲ سی ، معٲشی تہٕ تمدُنی انقلا بُک خطرٕ ہ ظٲ ہر تہٕ تِمو سمجُھ زِ اگر أمِس شخصہٕ سٕنز کتھ پٔچ برونٛہہ، تیٚلہِ گژِھ سا نیو اَتھو منٛزٕ     اقتدار نیٖرِ تھ ۔﴾"
  7,110,"۔ وۅ نۍ ؤنِو کیا چِھو ونان ؟"
  7,111,"۔پتہٕ دِیُت تِمو سارِوٕ یوفر عو نس مشو رٕہ زِ یہِ تہٕ أمۍ سُند بو ے تھٲوِیوٗن انتظا رس تہٕ تمام شہر ن منٛز سوٗزِ یوٗکھ قٲصد"
  7,112,"۔ تا کہ پرٛتھ کٲنٛسہِ مٲہر فن جادو گر س اَنن تۅہیہِ نِشہِ ۔چنا نچہِ جادو گر آے فر عو نس نِشہِ"
  7,113,"۔تِمو ووٚ ن  اگر أسۍ غٲلب روٗدۍ تیٚلہِ میلہِ اَسہِ اَمِیُک مُعا و ضہٕ ضرور؟"
  7,114,"۔ فر عو نن دِیتُنکھ جوا ب  آ، تہٕ توٚہۍ سپدِ و مقّر بِ با ر گاہ ﴿یعنی میا نیو ٹا ٹھیو منٛزٕ ﴾۔"
  7,115,"۔ پتہٕ ووٚن تِمو موسیٰ ﴿علیہ السلامس ﴾ ژٕ چھککھٕ کِنہٕ أسۍ چَھکو؟"
  7,116,"۔مو سیٰ ﴿ علیہ السلامن ﴾ دِیتُنکھ جوا ب  توٚہۍ چھٔکِو ییٚلہِ تِمَو پنٕنۍ مٲتھٕر  کٔر، لُکن ہٕنز ن أچھن کوٚرُک سِحرٕ ہ تہٕ دِل با نبر ٲوِکھ تہٕ سٮ۪ٹھاہ زبردست جود اوٚ نکُ بنٲوِ تھ۔"
  7,117,"۔اَسہِ کوٚر مو سیٰ ﴿علیہ السلامس﴾ اشارٕہ زِ چھکھ پنُن عا صہٕ ،عا صہٕ چھکنٕچ ٲس تٲر زِ وُچھان وُچھان روٗد سُہ تِہندِس اتھ اَپزِ س جٲدِس نینٚگلا وان پکا ن۔"
  7,118,"۔یِتھہٕ پٲٹھۍ یُس حق اوس سُہ گوٚو ثٲبت تہٕ یِکینٛژھا تِمو بنٲوِ تھ اوس تھو و مُت سُہ روٗد بٲطل بٔنِتھ۔"
  7,119,"۔فر عو ن تہٕ تٔمۍ سٕندۍ سٲتھی سپٕدۍ مقا بلہٕ کِس مٲدا نس منٛز مغلوٗب تہٕ ﴿فتح مند سپد نہٕ بجا یہِ سپدۍ ﴾ پوٚت پھِیرِ تھ خٔجل"
  7,120,"۔تہٕ جادو گر ن ہُند سپُد یہِ حال زِ زَنتہٕ أند ری کٔمۍ تام چیز ن تِم سجد س منٛز گِر ٲوۍ۔"
  7,121,"۔وَننہٕ لگۍ  اَسہِ مو ن ربّ العا لمین،"
  7,122,"۔سُہ ربّ یَس مو سیٰ علیہ السلام تہٕ ہا رو ن علیہ السلام چِھ مانان ۔ ﴿یِتھہٕ پٲٹھۍ پلٹٲو خُدا ین فر عو نی ین ہٕنز چال پوٚت پھِرِ تھ تِمنٕے پٮ۪ٹھ۔ مٕلکٕکۍ تمام مٲہر جادو گر اَننٲوِ تھ ہاوِ یا و تِمَو منظر عا مس پٮ۪ٹھ امہِ موجو ب یہِ نظا رٕہ تا کہ عا م لُکن دِن حضرت مو سیٰ اللہ علیہ السلامن ہٕندِ جا دو گر آسنُک یقین ،یا کم از کم ترا ونکھ شکسٕے منٛز۔البتہ اتھ مقا بلس منٛز ہا ر نہٕ پتہٕ کوٚر تِہند یو بُلا و نہٕ آمتیو فن کیو مٲہر و اِتفا ق سان فٲصلہٕ زحضر ت مو سیٰ علیہ السلام یُس چیز پیش چِھ کران سُہ چُھنہٕ ہر گز تہِ جو د بلکہ چُھ پز ۍ پٲٹھۍ ربّ العا لمین سٕندِ طا قتُک کمال یتھ برونٛہہ کنہِ کٲنٛسہِ جا دو گر سُند زور ہیکہِ نہٕ چٔلِتھ۔﴾"
  7,123,"۔فر عو نَن ووٚنتۅہیہِ اوٚ نُو أمِس پٮ۪ٹھ ایمان اَمہِ برونٛہہ زِ بہٕ دِمہٕ ہَو تۅہیہِ اَمِیُک اجا زت؟ یقیناً چھےٚ یہِ اکھ خفیہ سٲزش ٲسمٕژ ،یۅ سہٕ تۅہیہِ یَتھ داراکسطنتس منٛز کٔرٕو تا کہ اَمِکۍ مٲلک ہیٚکِیوٗ کھ اقتدارٕ نِشہِ بے دخل کٔرِ تھ ،اچھا وۅ نۍ لگیو تۅہیہِ اَمِیُک نتیجہ پے،"
  7,124,"۔بہٕ ژَٹنا وَو تۅہیہِ اَتھہٕ کھۅ ر مُخٲلف طر فَو ﴿یعنی دٔچِھنۍ نٔر تہٕ کھووٕ ر زنگ یا کھووٕ نٔر تہٕ دٔچِھنۍ زنگ ﴾ تہٕ  اَمہِ پتہٕ کھا لَو توٚہۍ سٲر ی پھا نسہِ ۔"
  7,125,"۔تِمو دِیُت جوا ب  اسہِ چُھ بہر حال پننِس ربّ سٕے  کُن واپس گژُھن،"
  7,126,"۔ژٕ یتھ کتھہِ پٮ۪ٹھ اسہِ انتقام چُھکھ یژھان ہیوٚ ن، سۅ چَھنہٕ امہِ ورٲے بیٚیہِ کِہِنۍ زِ ییٚلہِ سٲنِس ربّ سٕنز نشٲنیہِ اسہِٕ برونٛہہ کُن آیہِ ، اَسہِ مانہِ تِمہٕ، اے ربّ ، اسہِ پٮ۪ٹھ کر صبرُک فیضا ن تہٕ اَسہِ تُل دُنیا منٛزٕ اتھ حالس اندر زِ أسۍ آسو چٲنۍ فر مان بردار۔ع ﴿فر عو نن ییٚلہِ بٲزۍ وُچھ پلٹا ن تٔمۍ چلٲو ٲخر ی چال یہِ زِ یہِ سورُے معا ملہٕ دِیہِ ہے سُہ مو سیٰ علیہ السلام تہٕ جا دو گر ن ہٕنز سٲزِش قرار تہٕ پتہٕ کر ناوِ ہے جا دو گر ن اَتھہِ جسمٲنی عذا بٕچ تہٕ قتل کر نٕچ دھمکی دِتھ پننہِ امہِ الزا مُک اقرار مگر یہِ چال تہِ گٔیہِ نہٕ تس کا میا ب ۔جا دو گر و کوٚر پنُن پان پرٛتھ سزا خٲطرٕ پیش کٔرِ تھ ثٲبت زِ مو سیٰ علیہ السلامن ہٕندِس صدا قتس پٮ۪ٹھ تِہُند ایمان اَنُن اوس نہٕ کُنہِ سٲزشہِ ہُند نتیجہ بلکہ اوس حق کہ اعترا ضُک نتیجہِ۔یتھ جا یہِ چھےٚ یہِ کتھ تہِ وُچِھنۍ لا یق زِ کینٛژھن ژِہیٚن منٛز کو تاہ بوٚڈ انقلا ب کوٚر یِمن جا دو گر ن ہٕنزِ زند گی منٛز ایمانن پٲدٕ۔وُنۍ وُنۍ کینٛہہ کال برونٛہہ اوس یِمنٕے جا دو گر ن ہٕندِ ذہا نتُک حال یہِ زِ پننہِ آیا یی دین کہ حما یت تہٕ کا میٲبی خٲطرٕ ٲسۍ پننیو گھر و منٛزٕ نیرِ تھ آمٕتۍ تہٕ فر عو نس ٲسۍ پرٛژھان زِ اگر اَسہِ پنُن مذ ہب مو سیٰ علیہ السّلامن ہٕندِ حملہٕ نِشہِ بچو و ، تیٚلہِ میلیٚا اَسہِ سرکارس نِشہِ انعا م؟ وۅ نۍ ییٚلہِ ایمانٕچ نعمت نصیب سپدٕ کھ ، یِہٕنزٕ ے حق پر ستی تہٕ اولو العز می وٲژاتھ حد س زِ کینٛہہ کال برونٛہہ یس با دشاہس بر و نٛہہ کنہِ  لالچہِ سان پان ٲسۍ وتھراوان ،وۅنۍ چھِ تِم تٔمۍ سٕنزِ کبریٲیی تہٕ جبروٗتس ٹھوٗنکرٕ لایان تہٕ تِم بدترین سزا چھِ پیٚتراونہٕ خٲطرٕتیا ر یِہٕنز دھمکی سُہ دِوان چُھکھ، مگر یہِ حق ترا و نہٕ خٲطرٕ چِھنہٕ تیار ییٚمِچ صدا قت یِمن پٮ۪ٹھ ظٲہر چھےٚ گٔمٕژ۔﴾"
  7,127,"۔فر عو نس ووٚ ن تٔمۍ سٕندِ قو م کیو سردارو کیا ژٕ ترا و ہنہٕ مو سیٰ علیہ السلام تہٕ تٔمۍ سُند قو م یِتھے یلہٕ زِ ملٕکس منٛز پھٔہلاون فساد، تہٕ سُہ تراوِ چٲنۍ تہٕ چا نیٚن معبو د ن ہٕنز بند گی کرٕ نۍ ؟ فر عو نن دِیُت جوا ب  بہٕ کر نا وکھ تِہندۍ نیٚچِو قتل تہٕ تِہٕنز ن مستوٗراتن دِمہٕ زند ہ روزنہٕ۔ ﴿ یہِ کتھ گژِھہ وا ضح روزٕ نۍ زِ اکھ سِتمُک دَو ر اوس سُہ یُس حضرت مو سیٰ علیہ السلامن ہٕنزِ پیدایشہِ برونٛہہ جٲری اوس سپُدمُت،تہٕ دوٚیِمہِ ستمُک دور چھُ یہِ یُس حضرت موسیٰ علیہ السلامن  ہٕندِ بعثت پتہٕ شر وع سپُد۔دۅ شوٕ نۍ زمانن منٛز ٲس یہِ کتھ مشتر ک زِ بنی اسرٲیلٕکۍ نیچو ۍ آے قتل کر نہٕ تہٕ تِہنزٕ کورِ آیہِ زندٕہ تھا و نہٕ تا کہ وارٕ وارٕ سپدِ تِہندِ نسلُک خٲتِمہٕ تہٕ یہِ قو م راوِ با قی قو من منٛز شرٚ پَتھ﴾ سا نہِ اقتدارٕچ گرفت چھےٚ یِمن پٮ۪ٹھ مضبو ط۔"
  7,128,"۔ مو سیٰ ﴿علیہ السلامن ﴾ ووٚ ن پننِس قو مس خُدا یس مٔنگِو مدد بیٚیہِ کٔرِ و صبر ، زمین چھےٚ اللہ تعالیٰ سٕنز، پننیو بندَو منٛزٕ  یس یژھان چُھ تَس چُھ اَمِیُک وٲرِث بنا وان، ﴿یَتھ زمانس منٛز چِھ کینٛہہ لُکھ امہِ آیت نِشہِ  زمین چھےٚ اللہ تعالیٰ سٕنز کٔڑِ تھ نِوان تہٕ یِم لفظ چِھ أتی تھاوان زِ  یَس سُہ یژھان چُھ تس چُھ اَمِیُک وٲرث بناوان۔﴾ تہٕ ٲخری کامیٲبی چھےٚ تِمنٕے خٲطرٕ یِم تس کھوٚژۍ کھوٚژۍ کٲم کرَن ۔"
  7,129,"۔تٔمۍ سٕندِ قو م کیو لُکو ووٚ ن  چا نہِ یِنہٕ برونٛہہ تہِ ٲسۍ أسۍ ستا و نہٕ یِوان ،تہٕ وۅ نۍ چِھ چا نہِ یِنہٕ پتہٕ تہِ ستا و نہٕ یِوان ۔تٔمۍ دِیُت جوا ب  نکھہٕ چُھ سُہ وقت زِ تُہُند ربّ کرِ تُہٕندِس دُشمنس ہلا ک تہٕ تۅہیہِ بناو یٚو زمینس اندر خلیفہٕ، پتہٕ وُچھہِ زِ توٚہۍ کِژٕھہ عملہٕ چِھو کران ۔ ع"
  7,130,"۔اَسہِ تھٲوۍ فر عو ن سٕندۍ لُکھ واریاہن ؤرِین تام قحطس تہٕ پیداوار چہِ کمی منٛز مبتلا تا کہِ شاید مایِیہِ تِمن ہو ش ۔"
  7,131,"۔ مگر تِہُند حال اوس یہِ زِ ییٚلہِ رُت وقت واتان اوس تیٚلہِ ٲسۍ ونان زِ أسۍ چِھ اَمِکی حقدار،تہٕ ییٚلہِ خرا ب وقت واتان اوس تیٚلہِ ٲسۍ موسیٰ ﴿علیہ السلامس﴾ تہٕ تٔمۍ سٕندٮ۪ن سٲتھِین پننہِ خٲطرٕ فا لِ بد ٹھٔہراوان، حالانکہ در حقیقت اوس تِہُند فالِ بد خُدا یس نِشہِ ، مگر تِمو منٛزٕ ٲسۍ اکثر بے علم۔"
  7,132,"۔تِمو ووٚن موسیٰ ﴿علیہ السلامس﴾ زِ  ژٕ اَنتہٕ اسہِ پٮ۪ٹھ جو د کر نہٕ خٲطرٕ خوا ہ کانٛہہ تہِ نشٲنی، توتہِ چِھنہٕ أسۍ چٲنۍ کتھ مانن وٲلۍ۔"
  7,133,"۔ٲخر کار سوٗز اَسہِ تِمن پٮ۪ٹھ طوفا ن،ہالَو کھیٚچہِ تراویکھ،﴿زۅوٕہ﴾ کٔیٚمۍ کٕرٚیٖل پھٔہلٲوِکھ ، منہِ مۅنڈ جہِ کجیٚکھ ،تہٕ خو ن برسووُکھ ،یِمہٕ ساریے نشٲنیہِ ہا و یکھ بیوٚ ن بیوٚن کٔرِ تھ مگر تِم روٗدۍ تکبر ﴿سر کشی﴾ کران پکان،تہٕ تِم لُکھ ٲسۍ بٔڑۍ بٔڑۍ مجرِم۔"
  7,134,"۔ییٚلہِ تِمن پٮ۪ٹھ کانٛہہ بلا ے سپدِ ہے نٲزِل تیٚلہِ ٲسۍ ونان ، اے موسیٰ علیہ السلام ،ژےٚ یُس منصب پننِس ربّ سٕندِ طر فہٕ حٲصل چِھی تمہِ کِس بنیا دس پٮ۪ٹھ منگتہٕ ربّس سانہِ خٲطرٕ دُعا،ہرگاہ ژٕ ییٚمہِ لٹہِ اسہِ نِشہِ یہِ بلا ے دوٗرکر کھ تیٚلہِ مانَو أسۍ چٲنۍ کتھ،تہٕ بنی اسرا یل سوزوکھ ژےٚ سٍتۍ۔"
  7,135,"۔مگر ییٚلہِ أسۍ یِمو پٮ۪ٹھہٕ پنُن عذا ب أکِس مقرر وقتس تام خٲطرٕ ہٹاوان ٲسۍ، یتھ تِم بہر حال واتن وٲلۍ ٲسۍ،تیٚلہِ ٲسۍ تِم جلد ی پننہِ وعدہ نِشہِ پوٚت ہیوٚان۔"
  7,136,"۔پتہٕ ہیوٚت اسہِ تِمن اِنتقام تہٕ پھا ٹٕوۍ تِم سمندرس تِکیازِ تِمو اوس سا نیٚن نِشٲنیَن بُتھ پھیرُ مُت تہٕ تِمو نِشہِ ٲسۍ بے پرواہ سپٕدۍ مٕتۍ۔"
  7,137,"۔ تہٕ تِہنزِ جایہِ بنٲوۍ اسہِ تِم لُکھ یِم کمزور بنٲوِ تھ ٲسۍ تھاونہٕ آمٕتۍ ، تمہِ سرزمین کہ مشر ق و مغر بٕکۍ وٲرث یُس اَسہِ بر کتو سٍتۍ مالا مال اوس کوٚر مُت۔﴿یعنی بنی اسرا یل آے فلسطین کہ سر زمینٕکۍ وٲرث بناو نہٕ ۔قرآن مجیدس  منٛز چِھ مختلف جا ین  فلسطین تہٕ شام کہ سر زمینہٕ خٲطرٕ یِم الفا ظ ورتا و نہٕ آمٕتۍ زِ اسہِ چھےٚ اَتھ سر زمینس منٛز بر کتہٕ تھاوِمژٕ﴾ یِتھہٕ پٲٹھۍ گوٚو بنی اسرٲیل کِس حقس منٛز تُہٕندِس ربّ سُند وعدہ پوٗرٕ،تِکیازِ تِمو ٲس صبرس کٲم ہیٚژ مٕژ،تہٕ اَسہِ کوٚر فر عو ن سُند تہٕ تٔمۍ سٕندِ قو مُک تہِ سورُے کینژھاہ برباد، یہِ تِم بناوان تہٕ کھا لان ٲسۍ۔"
  7,138,"۔بنی اسرٲیل تٲرۍ اسہِ سمندرس اَپو ر، پتہٕ پٔکۍ تِم تہٕ وَتہِ پکا ن درٛا ے تِتھہٕ اکہِ قو م کِنۍ یُس پننیٚن کینژھن پۅ تلیٚن ہُند گر و یدٕہ اوس بنیا مُت،وَننہٕ لٔگۍ اے موسیٰ علیہ السلام، سانہِ خٲطرٕ تہِ بناو کانٛہہ تِیُتھ معبودا،یِتھۍ یِمن لُکن ہٕندۍ معبود چِھ ۔ ﴿یہِ قو م اگر چہِ مسلمان اوس مگر یہِ اثر اوسُک ہَتہٕ بد یو ؤرِ یو پٮ۪ٹھہٕ مصرس منٛز أکِس بُت پرست قو مس در میان روزُنُک ﴾ مو سیٰ ﴿علیہ السلامن﴾ ووننکھ توٚہۍ لُکھ چِھو سٮ۪ٹھاہ نادٲنی ہِنزٕ کتھہٕ کران۔"
  7,139,"۔یِم لُکھ ییٚمہِ طر یقٕچ پیر وی کران چِھ سُہ چھُ برباد سپدن وول۔تہٕ یۅسہٕ عمل یِم کران چِھ سۅ چھےٚ سراسر بٲطل۔"
  7,140,"۔پتہٕ  ووٚن موسیٰ ﴿علیہ السلامن﴾ کیا بہٕ کر نہٕ خُدا یس ورٲے بیٚیہِ کانٛہہ معبود تُہندِ خٲطرٕ تلا ش؟ حالانکہ سُہ چُھ اللہ تعالیٰ ہٕے ییٚمۍ تۅہیہِ دُنیا کیٚن تمام قو من پٮ۪ٹھ فضیلت چَھو عطا کٔر مٕژ۔"
  7,141,"۔تہٕ ﴿اللہ تعالیٰ چُھ فر ماوان ﴾ سُہ وقت کٔرِ و یاد ییٚلہِ اَسہِ تۅہیہِ فر عو ن والیٚن نِشہِ نجا ت دِیتُو،یُہُند حال یہِ اوس زِ تۅہیہِ ٲسِو سخت عذا بس منٛز مبتلا تھاوان،تُہٕندٮ۪ن نیچو ٮ۪ن ٲسۍ قتل کران تہٕ تُہٕنز ن مستو راتن ٲسۍ زند ہ روز نہٕ دِوان ، تہٕ اتھ منٛز ٲس تُہندِس ربّ سٕندِ طر فہٕ تۅہیہِ بٔڈ آزمٲیش ۔ع"
  7,142,"۔اسہِ کوٚر موسیٰ علیہ السلام تٕرٛ ہن رٲژن تہٕ دۅ ہن خٲطرٕ ﴿کوہِ سینا ہس پٮ۪ٹھ ﴾ طلب تہٕ پتہٕ کوٚر بیٚیہِ دَہن دۅ ہن ہُند اضا فہٕ، یِتھہٕ پٲٹھۍ سپُد تٔمۍ سٕندِس ربّ سُند مقرر کر نہٕ آمُت وقت ژتجی دۅ ہ پوٗرٕ،موسیٰ ﴿علیہ السلامن﴾ ووٚ ن پکا ن پکان پننِس بٲیِس ہارو ن ﴿علیہ السلامس ﴾ زِ میا نہِ پتہٕ کٔرۍ زِ ژٕ میٲنِس قو مس منٛز میٲنۍ جا نشینی بیٚیہِ روٗزِ ۍ زِ ٹھیک کٲم کران تہٕ بِگا ڑ پٲدٕ کر ن وٲلین ہٕندِس طر یقس پٮ۪ٹھ پٔکۍ زینہٕ"
  7,143,"۔ییٚلہِ سُہ سٲنِس مقرر کر نہٕ آمتِس وقتس پٮ۪ٹھ ووت تہٕ تٔمۍ سٕندۍ ربّن کوٚرتس سٍتۍ کلام،پتہٕ کوٚر تٔمۍ التجا زِ  اے ربّ ،مےٚ دِسۅ نظر زِ بہٕ وُچھَتھ ژٕ۔ فر ما و نہٕ آس ژٕ ہیٚککھ نہٕ مےٚ وُچِھتھ ۔ آ،وُچھ ژٕ برونٹھہٕ کنہِ کِس پہا ڑس کُن، اگر سُہ پننہِ جایہِ قٲیم روزِ تیٚلہِ ہیٚککھ ژٕ مےٚ وُچِھتھ۔ چنا نچہ ییٚلہِ تٔمۍ سٕندۍ ربّن پہا ڑس پٮ۪ٹھ تجلی کٔر، سُہ کوٚرُن ریزٕ ہ ریزٕہ تہٕ موسیٰ علیہ السلام پیٚو و بے ہو ش گٔژِھتھ پتھر، ییٚلہِ ہو ش آس تہٕ ووٚ نن پا ک چھےٚ چٲنۍ ذات ،بہٕ چُھس چٲنِس حضورس منٛز توبہٕ کران تہٕ سارِوٕے گۅڈِنیُک ایمان اَنن وول چُھس بہٕ۔"
  7,144,"۔فر ماو نہٕ آس ،  اے موسیٰ علیہ السلام،مےٚ کوٚرمکھ ژٕ تمام لُکن پٮ۪ٹھ تر جیح دِتھ منتخب تا کہ ژٕ کر کھ میٲنۍ پیغمبر ی تہٕ مےٚ سٍتۍ سپد کھ ہمکلا م، لہٰذا یِکینژھاہ بہٕ دِمے سُہ رَٹھ تہٕ کرشُکر۔"
  7,145,"۔اَمہِ پتہٕ دِژ اسہِ موسیٰ ﴿علیہ السلامس﴾ زند گی ہٕندِس پرٛتھ شعبس متعلق نصیحت تہٕ پرٛتھ پہلو س خٲطرٕ وا ضح ہدا یت تختی یَن پٮ۪ٹھ لیٚکھِتھ تہٕ ووٚ ن تس : یِم ہدا یات رٔژھر او مضبو ط اَتھو تہٕ پننِس قو مس دِ حکم زِ یِہٕندٮ۪ن بہتر مضمو نن ہٕنز کٔرِن پیر و ی، عنقر یب ہاوَے ژےٚ فا سقن ہٕندۍ گھرٕ۔"
  7,146,"۔پننیو نِشٲنیو سٍتۍ پِھرٕ بہٕ تِہٕنزٕنظرٕ یِم کُنہِ حق ورٲے زمینس اندر بٔڑۍ چِھ بنان ، تِم وُچِھتن خوا ہ کانٛہہ نشٲنی تہِ زانٛہہ اَنَن نہٕ تتھ پٮ۪ٹھ ایمان،اگر سِیٔز وتھ تِمن برونٛٹھ کُن یِیہِ ، سۅ وَتھ رٹن نہٕ تہٕ اگر ۂج وَتھ اَتھہِ یِیکَھ، تتھ پٮ۪ٹھ پکن ،امہِ موجو ب زِ تِمو پھِیرُ سانیٚن نِشٲنِیَن بُتھ تہٕ یِمن سٍتۍ روٗدۍ لا پر وٲہی کران۔سانیٚن نِشانین ییٚمۍ تہِ کٲنسہِ بُتھ پِھیٛر تہٕ ٲخرت چہ پیشی ہُنٛد کوٚرُن انکار،"
  7,147,"۔ تٔمۍ سٕندۍ سٲری اعما ل سپٕدۍ ضا یع، کیا لُکن ہیکیا تَمہِ ورٲے بیٚیہِ کانٛہہ جز امیٖلِتھ زِ یُتھ وَوَن تِیُتھ لو نن ؟ ع"
  7,148,"۔موسیٰ ﴿علیہ السلامس ﴾ پٔتۍ کِنۍ بنو و تٔمۍ سٕندِ قو م کیو لُکو پننیٚو گٔہنَو سٍتۍ أکِس ؤژھ سُند پُتلہٕ ییٚمہِ منٛزٕ داندٕ سٕنز ہِش آواز نیران ٲس،کیا تِمن او سنا اتھہِ یِوان زِ سُہ نَہ چُھ تِمن سٍتۍ کتھ کران،تہٕ نَہ چُھ کُنہِ معا ملس منٛز تِمن رہنمٲیی کران؟ مگر تو تہِ بنو و سُہ تِمو پنُن معبود تہٕ تِم ٲسۍ سخت ظٲلِم۔﴿یہِ اوس تمہِ مصر یت زدگی ہُند دوٚ یُم ظہو ر یُس بنی اسرٲیل ٲسۍ مصرٕ منٛز پا نس سٍتۍ ہیٚتھ درٛا مٕتۍ۔مصرس منٛز یُس گٲو ہٕندِ پوٗزایہِ تہٕ تقدیسُک روا ج اوس، تمہِ سٍتۍ اوس یہِ قو م تیو تاہ شدّت سان مُتٲثر سپُد مُت زِ پیغمبر سٕندِ نیر نہٕ پتے بنو و تٔمۍ پوٗزایہِ خٲطرٕ اکھ بنا وٹی ووٚژھ﴾"
  7,149,"۔پتہٕ ییٚلہِ تِہنزِ فر یب خۅردگی ہُند طِلسم پُھٹ ﴿ یعنی نٲدِ م سپٕدۍ ﴾ تہٕ تِمو وُچھ زِ در حقیقت چِھ تِم گمراہ سپٕدۍ مٕتۍ، پتہٕ لٔگۍ وَننہِ زِ اگر سٲنۍ ربّن اسہِ پٮ۪ٹھ رحم کوٚر نہٕ تہٕ اسہِ کوٚرُن نہٕ در گزر تیٚلہِ گژھَو أسۍ بر باد ۔"
  7,150,"۔ہو رٕ چِھ موسیٰ علیہ السلام شرار تہٕ ہوٚت تہٕ غمہٕ ہوٚت پننِس قو مس کُن پھیران، یِوان یِوا نٕے ووٚن تٔمۍ سٮ۪ٹھاہ بُرٕ جا نشینی کٔرٕ و تۅہیہِ لُکومےٚ پتہٕ! کیا تۅہیہِ ہیوٚکوٕ نا یوتاہ صبر کٔرِ تھ زِ پننِس ربّ سٕندِ حُکمُک کٔرِ ہو انتظار؟ تہٕ لگا وٮ۪ن تختی یہِ پتھر تہٕ پننِس بٲیِس ﴿ہاروٗن علیہ السلامس﴾ روٚٹُن کلُک مَس تہٕ لوٚ منس ، ہارون ﴿علیہ السلامن ﴾ ووٚ ننس  اے میا نہِ ماجہِ ہٕندِ نیچوِ ، یِمو لُکو دَبو و ہس بہٕ ، تہٕ قر یب اوس زِ یِم مارٕ ہن مےٚ ،لہٰذا مَتہٕ دِتہٕ دُشمنن  مےٚ پٮ۪ٹھ اَسنُک مو قع تہٕ یتھ ظٲلِم قو مس سٍتۍ مَتہٕ کر تہٕ مےٚ شٲمل۔"
  7,151,"۔پتہٕ ووٚن موسیٰ ﴿علیہ السلامن ﴾ اے ربّ ، مےٚ تہٕ میٲنِس بٲیِس کر معا ف،تہٕ اسہِ کر پننِس رحمتس منٛز دٲخل،ژٕ چُھکھ سارِنٕے ہٕندِ کھۅتہٕ کھٔسِتھ رحم کر ن وول ۔ ع"
  7,152,"۔﴿در جوا ب سپُد ارشادزِ﴾ یِمو لُکو ووٚژھ بنو و پنُن معبود تِم گژھن ضرور پننِس ربّ سٕندِس غضبس منٛز گرفتار تہٕ دنیا چہِ زند گی منٛز گژھن ذلیل ۔ اَپُز تُھرن والیٚن چِھ أسۍ یُتُھے سزا دِوان ۔"
  7,153,"۔تہٕ یِم لُکھ بُرٕ عملہ کر ن پتہٕ کر ن تو بہٕ بیٚیہِ اَنن ایمان، تیٚلہِ چُھ پٔزۍ پٲٹھۍ چو ن ربّ امہِ تو بہٕ تہٕ ایمان پتہٕ در گز ر تہٕ رحم فر ماون وول۔"
  7,154,"۔ پتہٕ ییٚلہِ موسیٰ علیہ السلام سُند شرارت ہَمیو و تٔمۍ تُجہِ تِمہٕ تختی یِہندِس تحریرس منٛز ہدا یت تہٕ رحمت ٲس تِمن لُکن خٲطرٕ یِم پننِس ربّس کھۅژا ن چِھ ،"
  7,155,"۔تہٕ تٔمۍ کٔرۍ پننہِ قو مٕکۍ سَتتھ نفر منتخب، تاکہ تِم سپد ن ﴿تس سٍتۍ ﴾ سٲنِس مقرر کر نہٕ آمتِس وقتس پٮ۪ٹھ حٲضر۔﴿یہِ طلبی ٲس امہِ غر ضہٕ خٲطرٕ تِکیازِ قو مٕکۍ ستتھ نُما یندٕہ منگن کوہِ سینا ہس پٮ۪ٹھ حا ضر سپدِ تھ قو م کہ طر فہٕ ووٚژھ پوٗزٕ نہٕ کہ جُر مٕچ معا فی تہٕ نَوِ سرٕ کرن اطا عتُک عہد اُستوار﴾ ییٚلہِ یِم أکۍ سخت بِنِلۍ رٔٹۍ موسیٰ ﴿علیہ السلامن﴾ کوٚر عر ض  اے میانہِ پروردِگارٕ ، اگر توٚہۍ ییٚژِھہ ہِو تیٚلہِ ہیٚکۍ ہِو گۅڈے یِمن تہٕ مےٚ ہلاک کٔرِ تھ، کیا توٚہۍ کٔرِ وٕ ہ تتھ قصورس منٛز اَسہِ سارِنٕے ہلا ک یُس اَسہِ منٛزٕ کینژھو نادانو کوٚر مُت اوس ؟ یہِ ٲس تُہٕنز تراونہٕ آمٕژ اکھ آز مٲیش ییٚمہِ ذر یعہ یُس توٚہۍ یژھان چِھو سُہ چھوٗن گمرٲہی منٛز مبتلا کران،یس یژھان چِھو تس چِھو ہدا یت بخشا ن، سٲنۍ سر پرست چِھو توٚہی لہٰذا کٔرِ و اَسہِ معا ف تہٕ اسہِ پٮ۪ٹھ کٔرِ و رحم ، توٚہۍ چِھو سارِ نٕے کھٔسِتھ معا ف کر ن وٲلۍ۔"
  7,156,"۔تہٕ سانہِ خٲطرٕ لیٚکھِو ییٚمہِ دُنیا ہُک رٕژر تہِ تہٕ ٲخرتُک تہِ ، اسہِ کوٚر تۅہیہِ کُن رجوع۔ در جوا ب سپُد ارشاد سزا یَس یژھان چُھس تس چُھس دِوان ،مگر میٲنۍ رحمت چھےٚ پرٛتھ چیز س پٮ۪ٹھ چھٲوِتھ،تہٕ سۅ لیٚکھہٕ بہٕ تِمن لُکن ہٕندِس حقس منٛز یِم نا فر مٲنی نِشہِ پر ہیز کر ن، زکوٰتہ دِن تہٕ میا نیٚن آیتن پٮ۪ٹھ اَنن ایمان۔"
  7,157,"۔لھٰذا چھےٚ یہِ رحمت اَز یِمن لُکن ہُند حصہٕ ﴾ یِم أمِس پیغمبر نبی اُمّی ﴿صلی اللہ علیہ وسلمن﴾ ہٕنز  پیر وی کر ن اختیار۔﴿یتھ جایہِ چُھ نبی صلی اللہ علیہ وسلمن خٲطرٕ اَمّی لفظ یہوٗدۍ اصطلا ح کہ لحا ظہٕ وَرتا و نہٕ آمُت ۔بنی اسرا یل ٲسۍ پا نس ورٲے با قی سارِنٕے قو من اُمّی ﴿گو یم یا جنٹا یل﴾ وَنان ۔ تِہُند قو می فخر و غرور نہ اوس کٲنٛسہِ اُمّی سٕنز پیشوٲیی تسلیم کر نہٕ خٲطرٕ تیار تہٕ نہ اوس اتھ پٮ۪ٹھ تیار زِ اُمّتِیَن خٲطرٕ کر ہن پا نس برابر انسٲنی حقو قٕے تسلیم ۔چنا نچہ قرآنس منٛز چُھ تِہُند یہِ قو ل نقل آمُت کر نہٕ زِ اُمّیَن ہٕندۍ مال کھینَس پٮ۪ٹھ چَھنہٕ اَسہِ پٕرٛژٕھ گٲر۔﴿آل عمرا ن آیت نمبر 75﴾لہٰذا چُھ اللہ تعالیٰ یِہٕنز ے اصطلا ح وَرتٲوِتھ فر ماوان زِ وۅ نۍ چُھ تُہُند قسمت أمۍ سٕے اُمّی یَس سٍتۍ وابستہٕ۔ہرگاہ أمۍ سٕنز پیر وی قبول کٔرِ و تیٚلہِ میلیٚو میا نہِ رحمت منٛزٕ حصہٕ ،نتہٕ چُھ سُے غضب تُہُند مقدر یَتھ منٛز توٚہۍ صدِ یو پٮ۪ٹھہٕ گرفتار چِھو﴾ ییٚمۍ سٕنز ذکر تِمن پننِس تواریخس تہٕ انجیلس منٛز لیٚکِھتھ چھےٚ میلان،سُہ چُھ تِمن نیکی ہُند حُکم دِوان،تہٕ بد ی نِشہِ چُھکھ رُکاوان،تِہندِ خٲطرٕ چُھ پاک چیز حلال کران،تہٕ نا پاک چیز حرام کران،تہٕ تِمو پٮ۪ٹھہٕ چُھ با ر والان یِم تِمن نکھس ٲسۍ تہٕ تِمہٕ بند شہِ چُھکھ مٕژ راوان یِمن تِم گٔنڈِتھ ٲسۍ۔﴿یعنی تِہندٮ۪ن فُقہا ہَن ہٕندیٚو پننیو قا نو نی زٲوِ جا رو سٍتۍ ، تِہِندٮ۪ن رٲہِبن ہٕندیٚو پننیو زُہد کیو مبا لغو سٍتۍ تہٕ تِہندِ جٲہل عوام کیو پننیو تَو ہما تَو تہٕ خۅ د ساختہٕ حدودَو تہٕ ضٲبطو سٍتۍ یِمن بار ن تل تِہٕنز زند گی دبٲوِتھ چھےٚ تھٲومٕژ تہٕ یِمن بندِ شن منٛز کھٔسِتھ چَھکھ تھٲومٕژ، یہِ پیغمبر چُھو تِم سٲری بور وَلان تہٕ تمام بند شہِ پھُٹرٲوِتھ چُھ زند گی آزاد کر ان﴾لھٰذا یِم لُکھ أمِس پٮ۪ٹھ ایمان اَنن۔ تہٕ أمِس کر ن حما یت تہٕ مدد تہٕ تمہِ روشنی ہٕنز کر ن پیر وی یۅسہِ أمِس سٍتۍ نٲزِل چھےٚ کر نہٕ آمٕژ، تِمے چِھ فلا ح لبن وٲلۍ۔"
  7,158,"۔اے محمد صلی اللہ علیہ وسلم ، ؤنِو زِ اے انسانو، بہٕ چُھس تۅہیہِ سارِنٕے کُن تس اللہ تعالیٰ سُند پیغمبر،یُس زمین تہٕ آسمانن ہٕنزِ باد شٲہی ہُند مٲلک چُھ، تس ورٲے چُھنہٕ کانٛہہ خُدا ے ،سُے چُھ زند گی بخشان تہٕ سُے چُھ موت دِوان ،لہٰذا، أنِو ایمان خُدا یس پٮ۪ٹھ تہٕ تٔمۍ سٕندِس سوزنہٕ آمتِس نبی اُمّی یس پٮ۪ٹھ یُس اللہ تعالیٰ تہٕ تٔمۍ سٕندۍ ارشادات مانان چُھ، بیٚیہِ کٔرِ و پیر وی تٔمۍ سٕنز، اُمید چھےٚ زِ توٚہۍ لٔبِو سیٚز وَتھ۔"
  7,159,"۔ موسیٰ علیہ السلام سٕندِس قو مس منٛز اوس اکھ دوٚر تِیُتھ تہِ یُس حق مطٲبق ہدا یت اوس دِوان تہٕ حق مطا بٕقے اوس انصاف تہِ کران۔"
  7,160,"۔تہٕ اسہِ ٲس اتھ قو مس بَہَن ﴿12﴾ گھر ن منٛز تقسیم کٔرِ تھ تِمن مُستقل درٮ۪ن ﴿ٹو لن ﴾ ہٕنز شکل دِژ مٕژ،تہٕ ییٚلہِ موسیٰ ﴿علیہ السلامس﴾ پنٕنۍ قو من آب موٚ نگ ،اسہِ کوٚر تس اِشارٕہ،زِ فلٲنۍ پلس تراو پننہِ لورِ سٍتۍ ژٔنڈ،چنا نچہِ تمی ساعتہٕ درٛا ے تمہِ پلہٕ منٛزٕ باہ ناگ،تہٕ پرٛتھ دٔرۍ کٔر پننہِ آب نِنٕچ جاے ﴿یارٕ بل﴾ مقرر  اسہِ کوٚر تِمن پٮ۪ٹھ اوٚ برُک سایہِ تہٕ تِمن پٮ۪ٹھ وول من وسلوٰی،کھیٚیِو تِم پاک چیز یِم اَسہِ تۅہیہِ بخشمٕتۍ چِھو۔ مگر امہِ پتہٕ یِکینژھاہ تِمو کوٚر ،سُہ کوٚرُکھ نہٕ اسہِ پٮ۪ٹھ ظُلم بلکہ روٗدۍ پٲنۍ پانس ظُلم کران۔"
  7,161,"۔یاد کٔرِ وسُہ وقت ییٚلہِ تِمن وَننہٕ اوس آمُت زِ  یتھ بستی منٛز گٔژِھتھ بٔسِو، تہٕ امہِ کہ پیداوارٕ نِشہِ کٔرِ و پننہِ منشہِ مطٲبق روز ی حٲصل بیٚیہِ گژِھو حِطتہُ حطتہُ وَنان تہٕ شہر کِس دروَازس أژِو سجدٕہ کران کران،أسۍ کر و تُہٕندۍ خطا معا ف ، تہٕ نیک رٔوِیہِ تھاون والیٚن کرَو مزید فضل عطا ۔"
  7,162,"۔مگر یِم لُکھ تِمو منٛزٕ ظٲلِم ٲسۍ تِمو بد لٲو سۅ کتھ یوسہٕ تِمن وَننہٕ ٲس آمٕژ،تہٕ نتیجہِ درٛا ویہِ زِ اسہِ سوٗز تِہندِس ظُلم کِس پا داشس منٛز تِمن پٮ۪ٹھ آسما نہٕ  عذا ب۔ع"
  7,163,"۔بیٚیہِ پٕرٛژھۍ تو یِمن تمہِ بستی ہُند حال تہِ یۅسہٕ سمندر بٔٹھِس پٮ۪ٹھ ٲس۔﴿مُحقِقن ہُند غٲلب تو جہ چُھ اتھ کُن زِ یہِ جا ے ٲس اَیلہ نَتہٕ ایلا ت نَتہٕ ایلو ت،اَتھ جایہِ چُھ وۅ نۍ اسرٲیلٕکۍ یہوٗدۍ ریا ستن اَمی ناوُک اکھ بندر گاہ بنو و مُت تہٕ اَتھ نکھے چُھ اُردنُک مشہو ر بند ر گاہ عقبہ﴾ یِمن پٲوِو یاد سُہ واقعہ زِ تِتکۍ لُکھ ٲسۍ سَبت﴿بٹہٕ وارِ﴾ دۅ ہ اللہ تعالیٰ سٕندٮ۪ن احکامن ہٕنز خلا ف ورز ی کران،بیٚیہِ  یہِ زِ گاڈٕ آسہٕ سبت کہ دۅ ہے ہیوٚر کھٔسۍ کھٔسۍ ﴿آب کِس ﴾ سطحس پٮ۪ٹھ تِمن برونٹھ کُن یِوان ۔ تہٕ سَبت ورٲے  آسہٕ نہٕ با قی دۅ ہن یِوان ، یہِ اوس امہِ موجو ب سپدان زِ أسۍ ٲسۍ تِہنز ن نا فر مٲنِیَن ہٕندِ وجہ کِنۍ تِم آز مٲیشہِ منٛز تراوان ۔"
  7,164,"۔بیٚیہِ پٲوِو تِمن یِتہِ یاد ییٚلہِ تِمو منٛزٕ أکۍ دٔرۍ دوٚ یِمِس دٔرِس ووٚ نمُت اوس زِ توٚہۍ کیازِ چِھو تِتھیٚن لُکن نصیحت کران یِمن اللہ تعالیٰ ہلا ک کر ن وول چُھ،نَتہٕ چُھکھ سخت سزا دِنہٕ وول، تِمو دِژَاو جوا ب زِ  أسۍ چِھ یہِ سورُے تُہندِس ربّس برونٛہہ کنہِ پنٕنۍ معذر ت پیش کر نہٕ خٲطرٕ کران تہٕ یہِ  اُمید چِھ کران زِ شاید مالاگن یِم لُکھ تٔمۍ سٕنزِ نا فر مانی نِشہِ پر ہیز کرُن۔"
  7,165,"۔ٲخر کار ییٚلہِ تِمو تِم ہدا یات بِلکُلٕے فر اموش کٔرۍ یِم تِمن یاد ٲسۍ کر ناو نہٕ آمٕتۍ،اَسہِ بچٲوۍ تِم یِم بُرٲیی نِشہِ رُکاوان ٲسۍ،تہٕ با قٕے سٲر ی لُکھ یِم ظٲلم ٲسۍ رٔٹۍ تِہنز ن نا فر مٲنین پٮ۪ٹھ سخت عذا بس منٛز۔"
  7,166,"۔ پتہٕ ییٚلہِ تِم پوٗرٕ سر کشی سان سۅ ے کٲم کران روٗدۍ ییٚمہِ نِشہِ تِم رُکا و نہٕ ٲسۍ آمٕتۍ، پتہٕ ووٚ ن اَسہِ  تِمن بٔنِو پٔنزۍ، ذلیل و خوار۔﴿امہِ بیان نِشہِ لوٚگ پے زِ اتھ بستی منٛز چِھ تر ییہِ قسمٕکۍ لُکھ ٲسِمٕتۍ۔اکھ تِم یِم بہا دُری سان اللہ تعالیٰ سٕندٮ۪ن احکامن ہٕنز خلا ف ورزی ٲسۍ کران۔دوٚیُم  تِم یِم بذا تِ خۅد پانہٕ ٲسۍ نہٕ خلا ف ور زی کران مگر یہِ خلا ف ور زی ٲسۍ ژھو پہٕ دم کٔرِ تھ لوٚب کُن وُچھان تہٕ نصیحت کر ن والیٚن ٲسۍ ونان زِ یِمن کم بختن کیا گژِھہ نصیحت سٍتۍ  حاصل ۔ترییِم تِم یُہُنٛد ایمانی غیرت اللہ تعالیٰ سٕندیٚن حدودن ہٕنز یہِ ٹاکارٕہ بے حُرمتی برداشت ہیٚکہِ ہے نہٕ کٔرِتھ تہٕ تِم ٲسۍاَمہِ خیالہٕ نیکی ہُنٛد حکم کرنس تہٕ بدی نِشہِ رکاونس منٛز سرگرم زِ شاید ما یِن تِم مجرم لُکھ یِہِندِ نصیحت سٍتۍسیٚزِ وتہِ پٮ۪ٹھ تہٕ اگر تِم سِیٔز وتھ اختیار کر ن نہٕ تمہِ پتہٕ تہِ کر و أسۍ پنُن فر ض نکھہٕ وٲلِتھ خُدا یس برونٛہہ کنہِ پننہِ برا تُک ثبوت پیش۔اَتھ صوٗرتس منٛز ییٚلہِ اتھ بستی پٮ۪ٹھ اللہ تعالیٰ سُند عذا ب آو ، قرآن مجید چُھ وَنان زِ یِمو تر ییٚو دَر یو منٛزٕ آو صرف ترٛییُم دوٚرُے یو ت امہِ نِشہِ بچا و نہٕ تِکیازِ أمۍ ٲس خُدا یس برونٛہہ کنہِ پنٕنۍ معذ رت پیش کر نٕچ فکر کٔرمٕژ تہٕ یۅہے اوس ییٚمۍ پننہِ برا تُک ثبوت اوس فرا ہم کٔرِ تھ تھو و مُت۔با قی دۅ ن دٔرٮ۪ن ہُند شمار سپُد ظٲلِمن منٛزتہٕ تِم سپٕدۍ پننِس جُر م کِس حدس تام عذا بس منٛز مبتلا۔ البتہ پٔنزۍ آے صرف تِم لُکھ بناو نہٕ یِم پوٗرٕ سر کشی سان حکمٕچ خلا ف ورزی روٗدۍ کران پکا ن﴾"
  7,167,"۔بیٚیہِ کٔرِو یاد ییٚلہِ تُہٕندۍ ربّن اعلا ن کوٚر زِ سُہ روزِ برابر قیا متس تام بنی اسرٲیلس پٮ۪ٹھ تِتھۍ لُکھ مُسلّط کران،یِم تِمن بد تر ین عذا ب دِن ۔ پٔزۍ پٲٹھۍ چُھ تُہُند ربّ عذا ب دِنس منٛز تیز دست، تہٕ پٔزۍ پٲٹھۍ چُھ سُہ در گز رس تہٕ رحمس تہِ کٲم ہیٚنہٕ وول۔"
  7,168,"۔اسہِ کٔرۍ تِم زمینس اندر چھلہِ چھلہِ کٔرِ تھ واریاہن قو من منٛز تقسیم  کینٛہہ لُکھ ٲسۍ تِمن منٛز نیک تہٕ کینٛہہ ٲسۍ اَمہِ نِشہِ مختلف  تہٕ أسۍ روٗدۍ تِمن جان تہٕ خرا ب حالاتو سٍتۍ آز مٲیش کران زِ شاید ما پھیر ن پوٚت۔"
  7,169,"۔پتہٕ سپدۍ بروٗنٹھمیو نٔسلو پتہٕ تِتھۍ نا خلف یِہٕندۍ جا نشین یِم کتا ب الہٰی ہٕندۍ وٲرث ٲسِتھ ییٚمۍ دُنیا ہٕکۍ فٲیدٕ ہ چھ وٹان۔بیٚیہِ چِھ وَنان زِ تو قع چُھ اسہِ یِیہِ معا ف کر نہٕ، پتہٕ اگر سُے متا عِ دُنیا چُھکھ برونٛہہ کُن یِوان،تَھپھ دِتھ چِھ تَتھ رٹا ن ، کیا یِمن چُھنا کتا بہِ ہُند عہد ہیٚنہٕ آمُت زِ اللہ تعالیٰ سٕندِس ناوس پٮ۪ٹھ ؤنِن سۅ ے کتھ یۅسہٕ  حق آسہِ ؟تہٕ یِمو چُھ پانہٕ پوٚرمُت یہِ کتا بہٕ منٛز چُھ لیٚکھِتھ،ٲخر تُک قیام گاہ چُھ پر ہیز گار لُکن خٲطرٕ بہتر۔﴿یتھ آیتس ہیٚکن زٕ تر جمہٕ گٔژِھتھ ۔اکھ سُہ یُس اَسہِ متنس منٛز چُھ کوٚر مُت۔دوٚیُم یہِ زِ  پر ہیز گار  لُکن خٲطرٕ چُھ آخرت کُےقیام گاہ بہتر۔﴾کیا توٚہۍ چِھو نا یہِ کتھہِ رَژھ تہِ سمجھان؟"
  7,170,"۔یِم لُکھ کتا بہِ ہٕنز پابند ی چِھ کران تہٕ یِمو نماز چھےٚ قایم کٔرِ تھ تھٲومٕژ،پٔزۍ پٲٹھۍ کر و نہٕ أسۍ یِتھیٚن نیک کردار لُکن ہُند اجر ضا یع۔"
  7,171,"۔تِمن چھا سُہ وقت تہِ یاد ییٚلہِ اسہِ پہا ڑ ہِلٲوِتھ تِمن پٮ۪ٹھ تِتھہٕ پٲٹھۍ تھوو زِ زَنتہٕ سُہ  چھٔتٕر چُھ تہٕ تِم ٲسۍ گُمان کران زِ سُہ  پیٚیہِ تِمن پٮ۪ٹھ،تہٕ تمہِ وقتہٕ اوس اَسہِ تِمن ووٚنمُت زِ یۅسہٕ کتاب أسۍ تۅہیہِ دِوان چِھو یہِ رٔٹِو مضبو طی سان تھپھ کٔرِ تھ،تہٕ یِکینژھاہ اَتھ منٛز لیٚکھِتھ چُھ تہِ تھٲوِ و یاد،تو قع چُھ زِ توٚہۍ روٗزِ و غلط کٲر ی نِشہِ بٔچِتھ۔ع"
  7,172,"۔تہٕ اے نبی صلی اللہ علیہ وسلم،لُکن پٲوِو سُہ وقت یاد ییٚلہِ تُہٕندۍ ربّن بنی آد م سٕند یو پُشتو منٛزٕ تِہُند نسل  اوس کوڈمُت۔تہٕ تِمن اوسُن خۅد تِم پا نس پٮ۪ٹھ گواہ بنٲوِتھ پُرٛوژھمُت، کیا بہٕ چُھس نا تُہُند ربّ؟تِمو ووٚن  ضرور ژٕے چُھکھ سو ن ربّ، أسۍ چِھ اتھ پٮ۪ٹھ گوٲہی دِوان ۔ ﴿یِتھہٕ پٲٹھۍ زَن واریاہو حد یثو نِشہِ پے چُھ لگا ن زِ یہِ معا ملہٕ چُھ آدم علیہ السلام سٕندِس تخلیق کِس مو قعس پٮ۪ٹھ پیش آمُت۔تمہِ وقتہٕ یِتھہٕ پٲٹھۍ فر شتن جمع کٔرِ تھ گۅڈنِکِس انسانس سجد ہ اوس کر نا و نہٕ آمُت تہٕ زمینس پٮ۪ٹھ اوس انسان سٕندِ خلا فتُک اعلا ن کر نہٕ آمُت، تِتھے پٲٹھۍ اوس آدم علیہ السلام سُند سورُے نسل تہِ یُس قیا متس تام پٲدٕ سپد ن وول اوس بیک وقت وجو د تہٕ شعور بخشِتھ خُدا ین پا نس برونٛہہ کنہِ حا ضر کوٚر مُت تہٕ تِمن نِشہِ ٲسٕن پننہِ ربو بیّت تٕچ شہا دت رٔٹمٕژ﴾ یہِ کوٚر اَسہِ امہِ موجو ب زِ توٚہۍ گٔژِھو نہٕ قیا مت کہ دۅ ہ یہِ وَنٕنۍ زِ أسۍ ٲسۍ امہِ کتھہِ نِشہِ بے خبر ۔"
  7,173,"۔نَتہٕ گٔژِھو نہٕ یہِ وَنٕنۍ زِ  شِر کُک ابتدا اوس سٲنۍ مٲلۍ بُڈِ بَبن اسہِ برونٛہہ کوٚر مُت،تہٕ أسۍ زاے تِہندِ نسلہٕ منٛزٕ پوٚتُس، پتہٕ کیا توٚہۍ چِھوٕ ہ اَسہِ اتھ قصورس پٮ۪ٹھ رٹا ن یُس غلط کار لُکَو کوٚر مُت اوس ؟"
  7,174,"۔وُچِھو ، یِتھہٕ پٲٹھۍ چِھ أسۍ وا ضح طور نِشٲنیہِ پیش کران، ﴿یعنی حق کہ معر فتٕکۍ تِم نشا نات یِم انسانس پننِس نفسَس منٛز موجو د چِھ تہٕ حقیقتس کُن چِھس رہنمٲیی کران ﴾ تہٕ امہِ موجو ب چِھ کران زِ یِم لُکھ پھیرن پوٚت ۔"
  7,175,"۔ تہٕ اے نبی  صلی اللہ علیہ وسلم ،یِمن برونٛہہ کنہِ کٔرِو تس شخصہٕ سُند حال بیان یس اَسہِ پننیٚن آیا تن ہُند علم عطا اوس کوٚر مُت، مگر سُہ ژوٚ ل تِہنزِ پا بند ی نِشہِ ،ٲخرکار لوٚگ شیطا ن تس پتہٕ،یوٚت تام زن سُہ ڈلہِ متیٚن  لُکن منٛز روٗد شٲمل سپدِ تھ ۔"
  7,176,"۔اگر أسۍ ییٚژِھ ہَو تیٚلہِ کر ہَو أسۍ تس یِمو آیا تو ذر یعہ بلند ی عطا،مگر سُہ روٗد زمین سٕے کُن نٔمِتھ تہٕ بیٚیہِ روٗد پننہِ نفس چہِ خوٲہشہِ پتے لہٰذا گٔیہِ تٔمۍ سٕنز حالت ہوٗنۍ سٕنز ہِش زِ توٚہۍ کٔرِو تس پٮ۪ٹھ حملہ تو تہِ  روزِ سُہ زیٚو آو یزان ترٛٲوِتھ، تہٕ سُہ ترٲوِیوٗن یلہٕ تو تہِ روزِ سُہ زیٚو آویزان ترٲوِتھ۔﴿مفسرو چھےٚ عہدِ رسالتس تہٕ امہِ برونٛٹھمہِ تواریخ کیٚن مختلف شخصن پٮ۪ٹھ یہِ مِثا ل چسپاں کٔرمٕژ البتہ چھےٚ حقیقت یہِ زِ سُہ خا ص  شخص چُھ پردس تل یُس یتھ مِثا لہِ منٛز پیشِ نظر اوس ، وٕں گوٚو یہِ مثا ل چھےٚ تس پرٛتھ شخصس پٮ۪ٹھ چسپاں سپدان یس منٛز یہِ صفت آسہِ ۔اللہ تعالیٰ چُھ تٔمۍ سٕندِس حا لتس ہوٗنِس سٍتۍ ہِشر دِوان ییٚمۍ سٕنز پرٛتھ وقتہٕ آو یزان زیٚو تہٕ پشپہٕ وٕنۍ پھیٖن اکہِ ژھیٚتہٕ نہ گژھن والہِ حر ص کہ نارُک تہٕ زانٛہہ نَہ سیر گژھن والہِ نیّتُک پے چھےٚ دِوان ۔ یہِ مٲنۍ تو سۅ ے ہِش مِثا ل ییٚلہِ کانٛہہ دُنیا ہس منٛز طمع تہٕ لالچہِ منٛز اوٚن چُھ سپدان تس چِھ پتہٕ ونان أمِس چُھ ہوٗن گوٚ مُت یہِ چُھ مٔکرِ س پیٚو مُت﴾ یٔہے مثال چھےٚ تِمن لُکن ہٕنز یِم سانیٚن آیا تن بُتھ چِھ پھِران۔یِمہِ دلیلہٕ روٗزِ و توٚہۍ یِمن بوزناوان، بنان چُھ زِ یِم ماکر ن غور وفکر۔"
  7,177,"۔سٮ۪ٹھاہ بُرٕ مِثا ل چھےٚ تِمن لُکن ہٕنز یِمو سا نیٚن آیاتن بُتھ پھِیرُ، تہٕ تِم چِھ روٗدِمٕتۍ خۅد پا نس پٮ۪ٹھ ظلم کران۔"
  7,178,"۔یَس اللہ تعالیٰ ہدا یت بخشہِ ، بس سُے چُھ ہدا یت لبا ن تہٕ یَس اللہ تعالیٰ پننہِ رہنمٲیی نِشہِ محر وم کرِ سُے چُھ روزان نا کام تہٕ نامُراد بٔنِتھ۔"
  7,179,"۔تہٕ یہِ چھےٚ حقیقت زِ واریاہ جِن تہٕ انسان چِھ تِتھۍ یِم  اسہِ جہنم خٲطر ے چِھ پٲدٕ کٔرِ مٕتۍ تِمن چِھ دل تہٕ دما غ مگر تِم چِھنہٕ یِمو سٍتۍ سو نچا ن تِمن چھےٚ أچھ مگر تِم چِھنہٕ یِمو سٍتۍ وُچھان۔ تِمن چِھ کن مگر تِم چِھنہٕ یِمو سٍتۍ بوزان،تِم چِھ جا نو ر ن ہٕندۍ پٲٹھۍ بلکہ تِہندِ کھۅ تہٕ تہِ گٔژھۍ تھٕے،یِم چِھ تِم لُکھ یِم غفلتس منٛز چِھ رٲوِمٕتۍ۔﴿ یعنی اسہِ ٲسۍ یِم دل و دما غ، أچھ تہٕ کنو سان پٲدٕ کٔرِمٕتۍ مگر یِمو ظٲلِمو ہِیٔژ نہٕ یِمن کانٛہہ کٲم تہٕ ٲخرکار بنے پننیو غلط کٲرِیو کِنۍ جہنمس قٲبل﴾"
  7,180,"۔اللہ تعالیٰ چُھ رٕتیٚن ناو ن ہُند حقدار، تس دِیِو رٕتیٚو ناوَو سٍتی آلو،تہٕ تِم لُکھ ترٲوِیوٗکھ یِم تٔمۍ سُند ناو تھاو نس منٛز سیٚزرٕ نِشہِ ڈَلان چِھ، یِکینژھاہ تِم کران چِھ تَمِیُک بد لہٕ میلہِ تِمن ضرور۔﴿رٔتیٚن ناو ن  ہُند چُھ مُراد تِم ناویِمَو سٍتۍ اللہ تعالیٰ سٕندِ عظمتُک تہٕ برتر ی ہُند ،تٔمۍ سٕندِ تقّدُسُک تہٕ پٲکیز گی ہُند ،تہٕ تٔمۍ سٕندٮ۪ن کمال کیٚن صفا تن ہُند اِظہا ر آسہِ سپدان۔اللہ تعالیٰ سُند ناو تھاونس منٛز سیٚزِ رٕنِشہِ ڈلُن چُھ یہِ زِ خُدا یس یِن تِم ناو دِنہٕ یِم تٔمۍ سٕندِ مر تبہٕ نِشہِ ؤسۍ پایہِ آسن ،یِم تٔمۍ سٕندِس ادبس خلا ف آسن، یِمو سٍتۍ عیب تہٕ نقص تس کُن منسوٗب آسن سپدان یا یِمو سٍتۍ تٔمۍ سٕندِس اقدس تہٕ اعلیٰ ذا تس متعلق کُنہِ غلط عقیدُک اِظہا ر آسہِ سپدان﴾"
  7,181,"۔سٲنِس مخلو قس منٛز چُھ اکھ دوٚر تِیُتھ تہِ یُس ٹھیک پٲٹھۍ حق مطا بق ہدا یت تہٕ حق مطا بق انصا ف چُھ کران ۔ ع۔"
  7,182,"۔روٗدۍ تِم لُکھ یِمو سانیٚن آیا تن بُتھ چُھ پھِیرُمُت، تِم نِمو کھ أسۍ در جہ پتہٕ در جہ تمہِ طر یقہٕ تبٲہی کُن زِ تِمن لگہِ نہٕ پے تہِ۔"
  7,183,"۔بہٕ چُھس تِمن ڈیٚجر ترٛا وان،بے شک چھےٚ میٲنۍ تد بیر پۅ ختہٕ۔"
  7,184,"۔بیٚیہِ کیا یِمو لُکو سو نچ نازانٛہہ؟ یِہندِس رفیقس پٮ۪ٹھ چُھنہٕ جنونُک کانٛہہ اثر۔ ﴿ رفیق چِھ مُراد محمد صلی اللہ علیہ وسلم۔حضور صلی اللہ علیہ وسلمن چُھ مکہ کیٚن لُکن ہُند رفیق امہِ موجوٗب وَننہٕ آمُت زِ تِم صلی اللہ علیہ وسلم ٲسۍ نہٕ تِمن خٲطرٕ غیر زان۔ تِم زاے تِمنٕے منٛز ،تِمنٕے در میان گُزورُکھ لۅ کچا ر،جوٲنی تہٕ بُجر ،نبوّت برونٛہہ اوس سورُے قو م تِمن صلی اللہ علیہ وسلمن سٮ۪ٹھاہ سلیم الطبع تہٕ صحیح الدّ ماغ انسان سٕندِ حیثیتہٕ زانان ۔نبوّت پتہٕ ییٚلہِ تِمو اللہ تعالیٰ سُند کلام لوگ واتناوُن، اچا نک لو گُکھ تِمن مجنو ن ونُن۔یہِ کتھ چھےٚ ٹا کارٕ زِ جنو نُک حکم اوس نہٕ تِمن کتھن پٮ۪ٹھ کینٛہہ یِمہٕ حضور صلی اللہ علیہ وسلم نبی  سپدنہٕ برونٹھ ٲسۍ کران بلکہ اوس تِمنٕے کتھن پٮ۪ٹھ لگا و نہٕ یِوان یِمن ہُند تبلیغ نبی سپد نہٕ پتہٕ تِمو صلی اللہ علیہ وسلم کوٚر۔اَمی وجہ کِنۍ چُھ فر ماو نہٕ یِوان زِ یِمو لُکو چھا زانٛہہ سوٗنچمُت تہِ ،ٲخر کۅ سہٕ کتھ چھےٚ یِمو کتھو منٛزٕ جنو نٕچ؟﴾ سُہ چُھ اکھ خبردار کر ن وول یُس ﴿بُرٕ انجام برونٹھ کُن یِنہٕ برونٛہہ ﴾ٹا کارٕ ہ پٲٹھۍ با خبر چُھ کران۔"
  7,185,"۔کیا یِمو لُکو کوٚرنا آسمان تہٕ زمین کِس انتظا مس پٮ۪ٹھ زانٛہہ غو ر ، بیٚیہِ وُچُھکھ نا أچھ  مٕژ رٲوِ تھ کانٛہہ چیز تہِ یُس خُدا ین چُھ پٲدٕ کوٚر مُت؟ تہٕ کیا یِمَو سوٗنچ نا یِتہِ زِ شاید ما آسہِ تِہنزِ زند گی ہٕنز مہلت ختم ہیٚژ مٕژ سپدٕ نۍ؟ ٲخٕر ، پیغمبر صلی اللہ علیہ وسلم، سٕندِ اَمہِ تنبیہ پتہٕ کۅسہٕ کتھ ہیٚکہِ بیٚیہِ تِژھ ٲسِتھ یَتھ پٮ۪ٹھ یِم ایمان اَنن؟"
  7,186,"۔یَس اللہ تعالیٰ رہنمٲیی نِشہِ محر و م کرِ تس خٲطرٕ چُھنہٕ پتہٕ کانٛہہ رہنما، تہٕ اللہ تعالیٰ چُھ یِمن یِہٕنزِ سر کشی منٛزٕ ے در بدر یلہٕ تراوان۔"
  7,187,"۔یِم لُکھ چِھو تۅہیہِ پرٛژھان زِ کَر سپدِ ٲخر سۅ قیا متٕچ گٔر نٲزِل؟ ؤنِو  تمِیُک علم چُھ میٲنِس ربّ سٕے نِشہِ تتھ کرِ پننِس وقتس پٮ۪ٹھ سُے ظٲہر آسمانن تہٕ زمینس منٛز آسہِ سُہ سٮ۪ٹھاہ سخت وقت سُہ یِیہِ اچا نک تۅہیہِ پٮ۪ٹھ۔یِم لُکھ چِھو تۅہیہِ تتھ متعلق تِتھہٕ پٲٹھۍ پٕرٛژھان زَنتہٕ توٚہۍ تتھ ژھا رنس کُن چِھو لگمٕتۍ ؤنِو  اَمِیُک علم چُھ صرف خُدا یس مگر اکثر لُکھ چِھ امہِ حقیقت نِشہِ ناوٲقف"
  7,188,"۔اے نبی صلی اللہ علیہ وسلم ، یِمن ؤنِو زِ بہٕ چُھس نہٕ پننہِ ذا تہٕ خٲطرٕ کُنہِ نفع تہٕ نقصا نُک اختیار تھاوان،اللہ تعالیٰ ہٕے یِکینژھاہ یژھان چُھ تہِ چُھ سپدان، تہٕ اگر مےٚ غیبُک علم آسِہے تیٚلہِ کر ہا بہٕ واریاہ فٲیدٕہ پننہِ خٲطرٕ حٲصل۔تہٕ مےٚ واتہِ ہے نہٕ زانٛہہ کانٛہہ نقصا ن، بہٕ چُھس محض اکھ خبردار کر ن وول تہٕ خۅش خبر بوزناون وول تِمن لُکن خٲطرٕ یِم میٲنۍ کتھ مانن۔ع"
  7,189,"۔سُہ چُھ اللہ تعالیٰ ہٕے ییٚمۍ توٚہۍ اکہِ جانہٕ نِشہِ پٲدٕ کٔرِ نو تہٕ تٔمۍ سٕندی جِنسہٕ نِشہِ بنو وُن تٔمۍ سُند جورٕہ تاکہ تس نِشہِ کرِ سکو ن حٲصل۔پتہٕ ییٚلہِ مردن تَس وُرُن کوٚر پتہٕ روٗد تس اکھ خفیف ﴿لوٚت﴾ ہیوٗ حمل یَتھ تُلۍ تُلۍ سۅ پھیران تھوران روٗز پتہٕ ییٚلہِ سۅ گۅ بیٚیہِ ،دۅ شوٕ یو کوٚر خُدا یس ،پننِس ربّس دُعا زِ اگر ژےٚ اَسہِ جان شُر عطا کوٚر تھن تیٚلہِ آسو أسۍ چٲنۍ شُکر گزار۔"
  7,190,"۔مگر ییٚلہِ خُدا ین تِمن جان تہٕ تندرست شُر دِیُت،پتہٕ لٲگۍ تِمو تٔمۍ سٕنزبخچٲیِشہِ تہٕ عنا یتس منٛز با قی تٔمۍ سٕندۍ شر یک ٹھٔہراوٕنۍ۔﴿مطلب چُھ یہِ زِ اولاد دِنہٕ وول چُھ اللہ تعالیٰ،اگر اللہ تعالیٰ زنا نہِ ہٕندِس شکمس منٛز پوٚنز یا سُرُپھ یا بیٚیہِ کُنہِ عجیب شکلہِ ہُند حیوان پٲدٕ کرِ ، یابناوِ شُرِس یٔڈ منٛز ے اوٚ ن ،زوٚر،لوٚنگ،یا تھا وِتٔمۍ سٕنز ن جسمٲنی ،ذہنی تہٕ نفسٲنی قوّتن منٛز کانٛہہ نُقُص ، تیٚلہِ چُھنہٕ کٲنٛسہِ منٛز یہِ طا قت زِ اللہ تعالیٰ سٕندِس اتھ سا ختس ہیٚکہِ بدلٲوِ تھ۔امہِ حقیقت نِشہِ چِھ مشر ک تہِ تِتھے پٲٹھۍ با خبر یِتھہٕ پٲٹھۍ کُنِس خُدا یس ما نن وٲلۍ چِھ۔ چنا نچہ چُھ   یۅ ہے وجہ زِ بیٚیہِ حسا بہٕ آسنہٕ کہ وقتہٕ چھےٚ تمام اُمیدٕاللہ تعالیٰ سٕے کُن وا بستہٕ آسان زِ سُے کرِ جان تہٕ تندرست  شُر پٲدٕ۔پتہٕ ییٚلہِ اُمیدٕ چھےٚ پوٗرٕ سپدان تہٕ اَکھ مٲرۍ موٚند شُر چھُ تھَنہٕ  پیوان ،شکر کرنہٕ موجوب چھِ پتہٕ نذر تہٕ نیازکٲنٛسہِ دیوی،کٲنسہِ اوتارس ،کٲنٛسہِ ؤلِیَس یا کٲنٛسہِ  حضرت سٕندِس نا وس پٮ۪ٹھ کھالنہٕ یِوان تہٕ شُرِس چِھ پتہٕ تِم ناو تھاو نہٕ یِوان زَنتہٕ سُہ خُدا یس ورٲے بیٚیہِ کٲنٛسہِ ہٕندِ عنا یتُک نتیجہ چُھ﴾ اللہ تعالیٰ چُھ سٮ۪ٹھاہ بلند تہٕ برتر تِمو مُشرِ کانہٕ کتھو نِشہِ یِمہٕ یِم لُکھ کران چِھ ۔"
  7,191,"۔کِتھۍ نادان چِھ یِم لُکھ زِ تِمن چِھ اللہ تعالیٰ سٕندۍ شر یک ٹھہر اوان یِم نہٕ کُنہِ چیز س پٲدٕ چِھ کران بلکہ چِھ تِم پانہٕ خۅد پٲدٕ یِوان کر نہٕ،"
  7,192,"۔تِم  نہ ہیٚکن یِمن مدد کٔرِ تھ تہٕ نَہ چُھکھ پا نسٕے مدد کر نُک طا قت ۔"
  7,193,"۔اگر توٚہۍ تِمن سیٚزِ وَتہِ پٮ۪ٹھ یِنٕچ دعوت دِیِو، تِم یِن نہٕ تۅہیہِ پتہٕ پتہٕ۔دۅ شوٕ نۍ صوٗرتن منٛز چُھ تُہٕندِ خٲطرٕ یکسان ،خوا ہ توٚہۍ تِمن آلو کٔرۍ تو یا خا موش روٗزی تو ، ﴿یعنی یِمن مشر کن ہٕندٮ۪ن با طل معبودن ہُند حال چُھ یہِ زِ کٲنٛسہِ سٔیز وتھ ہاوٕ نۍ تہٕ پننیٚن پیر و کار ن رہنمٲیی کرٕ نۍ چھےٚ دوٗر، تِم بِچٲر ۍ چِھنہٕ کٲنٛسہِ رہنما سٕنزِ پیر و ی قٲبل تہِ ،حتیٰ کہ کٲنٛسہِ آلو کر ن وٲلۍ سٕندِ س آلو س تہِ ہیٚکن نہٕ جوا ب دِ تھ ﴾"
  7,194,"۔اللہ تعالیٰ تٕرٛٲوِ تھ یِمن توٚہۍ لُکھ ناد چِھو دِوان ، تِم چِھ محض بندٕ ہ یِتھہٕ پٲٹھۍ توٚہۍ بند ہ چِھو،یِمن منگۍ تو دُعا تہٕ وُچھۍ تَو ، یِم دِنہٕ تُہٕندٮ۪ن دُعا ہَن جوا ب ، اگر یِہندِس بارس منٛز تُہٕندۍ خیا لات صحیح چِھ ۔"
  7,195,"۔کیا یِمن چھا کھۅر زِ تِمو سٍتۍ پکن؟ کیا یِمن چھا اتھہٕ زِ تِمو سٍتۍ کر ن تھپھ؟ کیا یِمن چھا أچھ زِ تِمو سٍتۍ وُچھن ؟ کیا یِمن چھا کن زِ تِمو سٍتۍ بوزن ؟ اے نبی صلی اللہ علیہ وسلم ، یِمن ؤنِو زِ  بُلٲوِیوٗکھ پنٕنۍ ٹھہر او نہٕ آمٕتۍ شر یک، پتہٕ کٔرِ و توٚہۍ سٲر ی مےٚ خلا ف تد بیر تہٕ مےٚ مَہ دِیو ہر گز تہِ مہلت،"
  7,196,"۔میو ن حٲمی تہٕ مدد کر ن وول چُھ سُہ اللہ تعالیٰ ییٚمۍ یہِ کتا ب چھےٚ نٲزِل کٔرِ مٕژ، تہٕ سُہ چُھ نیک انسانن حما یت کران۔"
  7,197,"۔اَتھ بر عکس یِمن توٚہۍ اللہ تعالیٰ تٕرٛ ٲوِ تھ ناد چِھو لایان ، تِم نہ ہیٚکن تۅہیہِ مدد کٔرِ تھ ،تہٕ نہ چِھ تِم خۅد پا نسٕے مدد کر نس قٲبل۔"
  7,198,"۔بلکہِ اگر توٚہۍ تِمن سیٚزِ وَتہِ پٮ۪ٹھہ یِنہٕ خٲطرٕ ؤنِو تِم ہیٚکن نہٕ تُہٕنز کتھ تہِ بوٗزِ تھ، بظٲہر چُھ تۅہیہِ اَتھہِ یِوان زِ تِم چِھ تۅہیہِ کُن وُچھان،مگر در حقیقت چِھنہٕ تِم کِہِنۍ تہِ وُچھان۔"
  7,199,"۔ اے نبی صلی اللہ علیہ وسلم،نر می تہٕ در گز رُک طر یقہٕ کٔرِ و اختیار ، معر وفُک تلقین گٔژِھو کران،تہٕ جٲہلو  نِشہِ روٗزِو پتھ۔"
  7,200,"۔اگر شیطا ن کُنہِ وِزِ تۅہیہِ  ہٕس دِیہِ ،خُدا یس مٔنگِو پناہ ،سُہ چُھ سورُے کینٛہہ بوزن وول تہٕ زانن وول۔"
  7,201,"۔در حقیقت یِم متقی چِھ تِہُند حال چُھ یہِ آسان زِ اگر کُنہِ وِزِ شیطا ن سٕندِ اثرٕ سٍتۍ کانٛہہ بُرٕخیال تِمن یِوان تہِ چُھ تِم چِھ فوراً خبردار گژھان تہٕ پتہٕ چُھ تِمن صا ف اتھہِ یِوان زِ تِمن خٲطرٕ کیا چُھ صحیح طر یقِ کار۔"
  7,202,"۔ روٗدۍ وۅ نۍ تِہندۍ ﴿یعنی شیطا نن ہٕندۍ ﴾ بٲے، تِم چِھ تِمن تِہنزِ گمرٲہی منٛز  لَما ن پکنا وان ، تہٕ تِمن چِھنہٕ وَتہِ ڈا لنس منٛز کانٛہہ کسر پتھ کُن تراوان۔"
  7,203,"۔اے نبی صلی اللہ علیہ وسلم،ییٚلہِ توٚہۍ یِمن لُکن برونٛہہ کنہِ کانٛہہ نشٲنی ﴿یعنی معجز ہ ﴾ پیش چِھو نہٕ کران ،تیٚلہِ چِھ یِم ونان زِ تۅ ہیہِ کیا زِ کوٚرُو نہٕ پا نس خٲطرٕ کُنہِ نشٲنۍ ہُند  انتخا ب؟ یِمن ؤنِو  بہٕ چُھس صرف تمہِ و حی ہٕنز پیر وی کران یۅسہٕ میٲنۍ ربّن مےٚ کُن چھےٚ سوٗز مٕژ، یِمہٕ چھےٚ بصیر ت چہِ رو شنیہِ تُہٕندِس ربّ سٕندِ طر فہٕ بیٚیہِ ہدا یت تہٕ رحمت تِمن لُکن خٲطرٕ یِم اتھ قبو ل کرن۔"
  7,204,"۔ییٚلہِ قر آن  تۅہیہِ برونٛٹھہٕ  کنہِ پر نہٕ یِیہِ تیٚلہِ بوٗزِ و سُہ تو جہ سان تہٕ خا مو ش روٗزِ و ،بنان چُھ تۅہیہِ پٮ۪ٹھ تہِ سپدِ رحمت۔"
  7,205,"۔ اے نبی صلی اللہ علیہ وسلم، پنُن ربّ کٔرِ یوٗن یاد دِلہٕ مٔنزۍ عٲجز ی سان تہٕ خو فہٕ سان ، بیٚیہِ کٔرِ یوٗن زیوِ سٍتۍ تہِ لۅ تہِ لۅ تہِ ،صُبحس تہٕ شا مَس، توٚہۍ مَہ بٔنِو  تِمو لُکو منٛزٕ یِم غفلتس منٛز چِھ پیٚمٕتۍ۔"
  7,206,"۔ یِم فر شتہٕ تُہٕندِس ربّس نِشہِ نز دیکی ہُند مقا م چِھ تھاوان،تِم چِھنہٕ زانٛہہ پننِس بجرٕ کِس غروٗرس منٛز یِتھ تٔمۍ سٕندِ عبا دت نِشہِ بُتھ پھِران، تِم چِھ تٔمۍ سٕنز تسبیح کران تہٕ تس برونٛہہ کنہِ چِھ نٔمِتھ روزان۔ع۔ ﴿یتھ جایہِ چُھ حُکم زِ یُس شخص یہِ آیت پرِ یا بو زِ سُہ کٔرِ ن سجدٕہ۔قرآن مجیدس منٛز چِھ یِتھۍ ژۅداہ۔14،مقا م یِمن جاین سجدٕ کۍ آیات چِھ آمٕتۍ ۔﴾۔"
