quran[40]{c,v,t}:
  75,1,"Prisiekiu Prikėlimo Diena"
  75,2,"ir prisiekiu priekaištaujančia siela (dėl prikėlimo tikrumo)!"
  75,3,"Ar žmogus galvoja, kad Mes nesurinksime jo kaulų?"
  75,4,"Taip! (Mes) Gebame (netgi) suderinti jo pirštų galiukus."
  75,5,"Tačiau žmogus trokšta pasilikti nuodėmėje."
  75,6,"Jis klausia: „Kada yra Prikėlimo Diena?“"
  75,7,"Tad, kai regėjimas apaks"
  75,8,"ir mėnulis užtems,"
  75,9,"ir saulė bei mėnulis bus sujungti,"
  75,10,"žmogus sakys Tą Dieną: „Kur yra pabėgimo (vieta)?“"
  75,11,"Ne! Nėra prieglobsčio!"
  75,12,"Pas tavo Viešpatį Tą Dieną yra pastovumo (vieta)."
  75,13,"Žmogui bus pranešta Tą Dieną apie tai, ką jis pasiuntė ir užlaikė."
  75,14,"Tikrai, žmogus prieš save bus liudytoju,"
  75,15,"netgi jei jis pateiks savo pasiteisinimus."
  75,16,"Nejudink savo liežuvio su juo (Muchammedai ﷺ) tam, kad paskubintum jį (t. y. Korano recitavimą)."
  75,17,"Iš tiesų, Mums priklauso jo surinkimas (tavo širdyje) ir jo recitavimas (to padarymas įmanomu)."
  75,18,"Tad, kai Mes parecituojam jį (per Džibrilį (Gabrielių)), tada sek jo recitavimu."
  75,19,"Tada Mums priklauso jo išaiškinimas (tau)."
  75,20,"Ne, tačiau jūs (žmonės) mylite artimiausią (t. y. šį žemišką gyvenimą)"
  75,21,"ir paliekate (t. y. apleidžiate) Amžinybę."
  75,22,"(Kai kurie) veidai Tą Dieną bus švytintys,"
  75,23,"žvelgiantys į savo Viešpatį."
  75,24,"O (kai kurie) veidai Tą Dieną bus persikreipę,"
  75,25,"besitikintys, jog jiems bus padaryta (kažkas) nepakeliamo."
  75,26,"Ne, kai tai (t. y. siela) pasieks raktikaulius"
  75,27,"ir bus pasakyta: „Kas išgydis jį (ir išgelbės jį nuo mirties)?“,"
  75,28,"ir jis (t. y. mirštantysis) bus tikras, kad tai išsiskyrimo (laikas),"
  75,29,"ir (šio pasaulio) sunkumas bus sujungtas su (Amžinybės) sunkumu,"
  75,30,"pas tavo Viešpatį Tą Dieną bus eitynės."
  75,31,"O jis (netikintysis) nepatikėjo, nei jis meldėsi."
  75,32,"Tačiau (vietoj to) jis neigė ir nusigręžė."
  75,33,"Ir paskui jis ėjo pas savo žmones, besipuikuodamas (iš išdidumo)"
  75,34,"Vargas tau ir vargas!"
  75,35,"Paskui vargas tau ir vargas!"
  75,36,"Ar žmogus galvoja, kad jis bus paliktas apleistas?"
  75,37,"Ar nebuvo jis Nutfa (sumaišytų vyriškų ir moteriškų išskyrų mišinio) išleistos sėklos?"
  75,38,"Tada jis buvo prisikabinęs krešuliukas ir (Allahas) sukūrė (jo formą), ir suderino (jį),"
  75,39,"ir padarė iš jo du porininkus, vyrą ir moterį."
  75,40,"Argi (Kūrėjas) nėra Galintis suteikti gyvybę mirusiam?"
