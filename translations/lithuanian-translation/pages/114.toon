quran[6]{c,v,t}:
  114,1,"Sakyk: „Aš ieškau prieglobsčio pas žmonijos Viešpatį,"
  114,2,"žmonijos Valdovą,"
  114,3,"žmonijos Dievą,"
  114,4,"nuo blogio pasišalinančio (nuo šnabždėjimo į žmogaus širdį, kai jis prisimena Allahą) šnabždūno (velnio, kuris šnabžda į žmogaus širdį),"
  114,5,"kuris šnabžda (blogį) į žmonių krūtines,"
  114,6,"iš džinų ir žmonių tarpo.“"
