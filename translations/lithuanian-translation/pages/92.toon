quran[21]{c,v,t}:
  92,1,"(Prisiekiu) naktimi, kai ji uždengia,"
  92,2,"ir (prisiekiu) diena, kai ji pasirodo,"
  92,3,"ir (prisiekiu) Tuo, Kuris sukūrė vyrą ir moterį."
  92,4,"Iš tiesų, jūsų pastangos yra skirtingos (tikslais ir priežastimis)."
  92,5,"Tam, kuris duoda (labdarą) ir bijo Allaho,"
  92,6,"ir tiki Al-Husna.",footnotes:322171:1
  92,7,"Mes palengvinsime jam link lengvumo."
  92,8,"Tačiau tam, kuris sulaiko ir mano, kad jam nieko nereikia,"
  92,9,"ir neigia geriausią (atlygį),"
  92,10,"Mes palengvinsime jam link sunkumo."
  92,11,"Ir kuo padės jam jo turtas, kai jis kris (sunaikinime)?"
  92,12,"Iš tiesų, (priklausantis) Mums yra vedimas"
  92,13,"Ir iš tiesų, Mums priklauso Amžinybė ir pirmasis (gyvenimas)."
  92,14,"Taigi aš įspėjau jus apie Ugnį, kuri liepsnoja."
  92,15,"Niekas (kitas neįžengs ir) nedegs tenais, išskyrus patį blogiausią,"
  92,16,"kuris neigė ir nusigręžė."
  92,17,"Tačiau išvengs jos Al-Mutakūn (teisingasis (žr. ają 2:2)),"
  92,18,"(tas), kuris duoda (iš) savo turto, kad apvalytų save,"
  92,19,"ir (duoda) ne kam nors (kad tas padarytų jam) paslaugą, atsilygindamas,"
  92,20,"tačiau tik siekdamas savo Viešpaties, Aukščiausiojo, Veido."
  92,21,"Ir jis bus patenkintas (kai įžengs į Rojų)."
