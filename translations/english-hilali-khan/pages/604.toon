quran[7]{c,v,t,f}:
  112,1,"Say (O Muhammad صلى الله عليه وسلم): "He is Allâh, (the) One.<sup foot_note=155073>1</sup>",footnotes:155073:1
  112,2,""Allâh-us-Samad (السيد الذي يصمد إليه في الحاجات) [Allâh the Self-Sufficient Master, Whom all creatures need, (He neither eats nor drinks)]."
  112,3,""He begets not, nor was He begotten.<sup foot_note=155074>1</sup>",footnotes:155074:1
  112,4,""And there is none co-equal or comparable unto Him.""
  113,1,"Say: "I seek refuge with (Allâh), the Lord of the daybreak,"
  113,2,""From the evil of what He has created,"
  113,3,""And from the evil of the darkening (night) as it comes with its darkness; (or the moon as it sets or goes away),"
  113,4,""And from the evil of those who practise witchcraft when they blow in the knots,"
  113,5,""And from the evil of the envier when he envies.""
  114,1,"Say: "I seek refuge with (Allâh) the Lord of mankind,<sup foot_note=155075>1</sup>",footnotes:155075:1
  114,2,""The King of mankind -<sup foot_note=155076>1</sup>",footnotes:155076:1
  114,3,""The Ilâh (God) of mankind,"
  114,4,""From the evil of the whisperer (devil who whispers evil in the hearts of men) who withdraws (from his whispering in one’s heart after one remembers Allâh).<sup foot_note=155077>1</sup>",footnotes:155077:1
  114,5,""Who whispers in the breasts of mankind."
  114,6,""Of jinn and men.""