quran[23]{c,v,t}:
  56,77,"بیشک یہ بہت عزت والا قرآن ہے"
  56,78,"جو کتاب ( لوح ) محفوظ میں ہے"
  56,79,"اس کتاب کو صرف پاک لوگ ہی چھوسکتے ہیں"
  56,80,"یہ رب العلمین کی طرف سے نازل کی ہوئی ہے"
  56,81,"کیا تم اس قرآن کو معمولی سمجھ رہے ہو!"
  56,82,"اور تم نے تکذیب کو اپنا رزق بنا لیا ہے"
  56,83,"پس جب روح نرخرے تک پہنچ جائے"
  56,84,"اور تم اس وقت ( روح کو نکلتا ہوا ) دیکھ رہے ہو"
  56,85,"اور ہم اس ( مرنے والے ) کی بہ نسبت تم سے بہت قریب ہوتے ہیں لیکن تم دیکھ نہیں سکتے"
  56,86,"پس اگر تم کسی کے زیر فرمان نہیں ہو"
  56,87,"تو تم اس روح کو لوٹاتے کیوں نہیں ‘ اگر تم سچے ہو"
  56,88,"پس اگر وہ ( مرنے والا ) مقربین میں سے ہے"
  56,89,"تو اس کے لیے راحت اور نفیس پھول اور انعام والی جنت ہے"
  56,90,"اور اگر وہ ( مرنے والا ) دائیں طرف والوں میں سے ہے"
  56,91,"۔ ( اے دائیں طرف والے ! ) تجھ پر سلام ہو کیونکہ تو دائیں طرف والوں سے ہے"
  56,92,"اور اگر وہ ( مرنے والا ) تکذیب کرنے والا ‘ گمراہوں میں سے ہے"
  56,93,"تو اس پر سخت کھولتے ہوئے پانی کی ضیافت ہے"
  56,94,"اور دوزخ میں جلنا ہے"
  56,95,"بیشک یہی ضرور حق الیقین ہے"
  56,96,"پس آپ اپنے رب عظیم کے اسم کی تسبیح کرتے رہیے"
  57,1,"آسمانوں اور زمینوں کی ہر چیز اللہ کی تسبیح کر رہی ہے اور وہ بہت غالب بےحد حکمت والا ہے"
  57,2,"آسمانوں اور زمینوں میں اسی کی حکومت ہے ‘ وہی زندہ کرتا ہے اور مارتا ہے اور وہ ہر چیز پر قادر ہے"
  57,3,"وہی اوّل اور آخر ہے اور ظاہر اور باطن ہے اور وہ ہر چیز کو خوب جاننے والا ہے"
