quran[42]{c,v,t}:
  80,1,"اللہ ہی کے نام سے  ( شروع کرتا ہوں )  جو نہایت رحم فرمانے والا بہت مہربان ہے"
  80,2,"۔  (  رسول )  چیں بہ جبیں ہوئے اور انہوں نے منہ پھیرا"
  80,3,"کہ ان کے پاس ایک نابینا آیا"
  80,4,"آپ کو کیا پتہ شاید وہ پاکیزگی حاصل کرتا ہے"
  80,5,"یا نصیحت قبول کرتا تو اس کو نصیحت نفع دیتی"
  80,6,"جس نے بےپرواہی کی"
  80,7,"تو آپ اس کے درپے ہیں"
  80,8,"اور اگر وہ پاکیزگی حاصل نہ کرے تو آپ کو کوئی ضرر نہیں ہوگا"
  80,9,"اور رہا وہ جو آپ کے پاس دوڑتا ہوا آیا ہے"
  80,10,"اور وہ اللہ سے ڈرتا ہے"
  80,11,"تو آپ اس کی طرف توجہ نہیں کرتے"
  80,12,"بیشک یہ  (  قرآن )  نصیحت ہے"
  80,13,"سو جو چاہے اس سے نصیحت حاصل کرے"
  80,14,"یہ عزت والے صحیفوں میں ہے"
  80,15,"جو بلندی والے پاکیزہ ہیں"
  80,16,"ان کے ہاتھوں سے لکھے ہوئے"
  80,17,"جو عزت والے نیک ہیں"
  80,18,"۔  ( کافر )  انسان ہلاک ہوجائے وہ کیسا ناشکرا ہے"
  80,19,"اسے کس چیز سے پیدا کیا ہے ؟"
  80,20,"اس کو نطفہ سے پیدا کیا، پھر اس کو مناسب اندازہ پر رکھا"
  80,21,"پھر اس کے لیے راستہ آسان کیا"
  80,22,"پھر اس کو موت دی پس اس کو قبر میں پہنچایا"
  80,23,"پھر جب چاہے گا اس کو زندہ کر کے نکالے گا"
  80,24,"بیشک اس نے اللہ کے حکم پر ابھی تک عمل نہیں کیا"
  80,25,"انسان کو چاہیے کہ وہ اپنے کھانے پر غور کرے"
  80,26,"ہم نے خوب پانی بہایا"
  80,27,"پھر ہم نے زمین کو شق کیا"
  80,28,"سو اس میں غلہ اگایا"
  80,29,"اور انگور اور سبزی"
  80,30,"اور زیتون اور کھجور"
  80,31,"اور گھنے باغات"
  80,32,"اور میوے اور  (  مویشیوں )  کا چارا"
  80,33,"تمہیں اور تمہارے مویشیوں کو فائدہ پہنچانے کے لیے"
  80,34,"پس جب کانوں کو بہرا کرنے والی  (  قیامت )  آجائے گی"
  80,35,"اس دن ہر شخص اپنے بھائی سے بھاگے گا"
  80,36,"اور اپنی ماں اور باپ سے"
  80,37,"اور اپنی بیوی اور بیٹوں سے"
  80,38,"اس دن ہر شخص کو اپنی پڑی ہوگی جو اس کو  (  دوسروں سے )  بےپرواہ کر دے گی"
  80,39,"اس دن کئی چہرے چمکتے ہوئے ہوں گے"
  80,40,"مسکراتے ہوئے ہشاش بشاش"
  80,41,"اور اس دن کئی چہرے غبار آلود ہوں گے"
  80,42,"ان پر سیاہی چھائی ہوئی ہوگی"
