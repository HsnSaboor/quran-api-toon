quran[29]{c,v,t}:
  81,1,"جب سورج کو لپیٹ دیا جائے گا"
  81,2,"اور جب ستارے جھڑ جائیں گے"
  81,3,"اور جب پہاڑچلائے جائیں گے"
  81,4,"اور جب دس ماہ کی حاملہ اونٹنیاں بےکار چھوڑ دی جائیں گی"
  81,5,"اور جب وحشی جانور جمع کیے جائیں گے"
  81,6,"اور جب سمندر بھڑکا دیے جائیں گے"
  81,7,"اور جب جانیں ملا دی جائیں گی"
  81,8,"اور جب زندہ درگور ( لڑکی ) سے سوال کیا جائے گا"
  81,9,"وہ کس گناہ میں قتل کی گئی ؟"
  81,10,"اور جب صحائف اعمال پھیلا دیے جائیں گے"
  81,11,"اور جب آسمان کھینچ لیا جائے گا"
  81,12,"اور جب دوزخ کو بھڑکا دیا جائے گا"
  81,13,"اور جب جنت قریب کردی جائے گی"
  81,14,"تو ہر شخص جان لے گا جو کام اس نے پیش کیا ہے"
  81,15,"میں قسم کھاتا ہوں پیچھے ہٹنے والے ستاروں کی"
  81,16,"چلنے پھرنے والے چھپنے والے ستاروں کی"
  81,17,"اور رات کی جب جانے لگے"
  81,18,"اور صبح کی جب چمکنے لگے"
  81,19,"بیشک یہ معزز رسول کا قول ہے"
  81,20,"جو قوت والا ہے عرش والے کے نزدیک بلند مرتبہ ہے"
  81,21,"جس کی آسمانوں میں اطاعت کی جاتی ہے وہاں امانت دار ہے"
  81,22,"اور تمہارے نبی مجنون نہیں ہیں"
  81,23,"اور بیشک انہوں نے اسے روشن کنارے پر دیکھا"
  81,24,"اور وہ ( نبی ) غیب کی خبر دینے پر بخیل نہیں ہیں"
  81,25,"اور یہ ( قرآن ) شیطان مردود کا قول نہیں ہے"
  81,26,"سو تم کہاں جا رہے ہو ؟"
  81,27,"بیشک وہ تمام جہان والوں کے لیے نصیحت ہے"
  81,28,"تم میں سے ہر اس شخص کے لیے جو سیدھا چلنا چاہے"
  81,29,"اور تم صرف وہی چاہتے ہو جس کو اللہ رب العلمین چاہتا ہے"
