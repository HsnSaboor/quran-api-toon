quran[30]{c,v,t}:
  74,18,"عنقریب میں اس کو صعود پر چڑھاؤں گا"
  74,19,"بیشک اس نے سوچا اور فیصلہ کیا"
  74,20,"اس پر اللہ کی مار ہو اس نے کیسا فیصلہ کیا"
  74,21,"اس پر پھر اللہ کی مار ہو اس نے کیسا فیصلہ کیا"
  74,22,"پھر اس نے غور کیا"
  74,23,"پھر تیوری چڑھائی اور منہ بگاڑا"
  74,24,"پھر اس نے اعراض کیا اور تکبر کیا"
  74,25,"پھر کہا : یہ  (  قرآن )  تو وہی جادو ہے جو پہلے سے نقل ہوتا آیا ہے"
  74,26,"یہ صرف بشر کا کلام ہے"
  74,27,"میں عنقریب اس کو دوزخ میں داخل کر دوں گا"
  74,28,"اور آپ کو کیا معلوم کہ دوزخ کیا ہے"
  74,29,"نہ وہ باقی رکھتی ہے نہ چھوڑتی ہے"
  74,30,"وہ کھال کو جھلسانے والی ہے"
  74,31,"اس پر انیس فرشتے مقرر ہیں"
  74,32,"اور ہم نے دوزخ کے محافظ صرف فرشتے بنائے ہیں، اور ہم نے ان کی یہ تعداد صرف کافروں کی آزمائش کے لیے مقرر کی ہے، تاکہ اہل کتاب یقین کرلیں اور ایمان والوں کا ایمان اور زیادہ ہوجائے اور نہ اہل کتاب شک کریں اور نہ ایمان والے اور تاکہ جن لوگوں کے دلوں میں بیماری ہے وہ اور کفار یہ کہیں کہ اللہ نے اس عجیب بات کو بیان کرنے سے کیا ارادہ فرمایا ہے ؟ اسی طرح اللہ جس میں چاہے گمراہی پیدا کرتا ہے اور جس میں چاہے ہدایت پیدا کردیتا ہے، اور اللہ کے لشکروں کو اللہ کے سوا کوئی نہیں جانتا، اور یہ صرف بشر کے لیے نصیحت ہے"
  74,33,"ہرگز نہیں ! چاند کی قسم"
  74,34,"اور رات کی جب وہ جانے لگے"
  74,35,"اور صبح کی جب وہ روشن ہو"
  74,36,"بیشک دوزخ ضرور بہت بڑی چیزوں سے ایک ہے"
  74,37,"بشر کو ڈرانے والی ہے"
  74,38,"تم میں سے ہر اس شخص کے لیے  (  ڈرانے والی )  ہے جو  (  نیکی میں )  آگے بڑھے یا  ( برائی کی وجہ سے )  پیچھے رہ جائے"
  74,39,"ہر شخص اپنے عمل کے بدلے میں گروی ہے"
  74,40,"ماسوا دائیں طرف والوں کے"
  74,41,"وہ جنتوں میں ایک دوسرے سے پوچھ رہے ہوں گے"
  74,42,"مجرموں کے متعلق"
  74,43,"۔  (  وہ مجرموں سے کہیں گے : )  تمہیں کس جرم نے دوزخ میں داخل کیا ؟"
  74,44,"وہ کہیں گے : ہم نماز پڑھنے والوں میں سے نہ تھے"
  74,45,"اور ہم مسکین کو کھانا نہیں کھلاتے تھے"
  74,46,"اور ہم لغو کاموں میں مشغول رہتے تھے"
  74,47,"اور ہم یوم جزا کی تکذیب کرتے تھے"
