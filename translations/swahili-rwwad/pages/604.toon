quran[15]{c,v,t}:
  112,1,"Sema: Yeye Mwenyezi Mungu ni wa Pekee."
  112,2,"Mwenyezi Mungu ndiye Mkusudiwa."
  112,3,"Hakuzaa wala hakuzaliwa."
  112,4,"Wala hana anayelingana naye hata mmoja."
  113,1,"Sema: Ninajikinga kwa Mola Mlezi wa mapambazuko."
  113,2,"Kutokana na shari ya alivyoviumba."
  113,3,"Na kutokana na shari ya giza la usiku liingiapo."
  113,4,"Na kutokana na shari ya wanaopulizia mafundoni."
  113,5,"Na kutokana na shari ya hasidi anapohusudu."
  114,1,"Sema: Ninajikinga kwa Mola Mlezi wa wanadamu."
  114,2,"Mfalme wa wanadamu."
  114,3,"Mungu wa wanadamu."
  114,4,"Kutokana na shari ya Shetani mtia wasiwasi, ajifichaye mno (Al-Khannaas)."
  114,5,"Anayetia wasiwasi katika vifua vya watu."
  114,6,"Kutokana na majini na wanadamu."