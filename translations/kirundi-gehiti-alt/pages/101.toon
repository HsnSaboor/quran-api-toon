quran[11]{c,v,t}:
  101,1,"Umusi nkuramutima."
  101,2,"Mbega, ni igiki umusi nkuramutima?"
  101,3,"Ni igiki cokumenyesha ico ari co umusi nkuramutima?"
  101,4,"Ni umusi, abantu bazozuka batagira iyo baja n’iyo bava, bashwiragiye nk’ibinyugunyugu bishwiragijwe;"
  101,5,"N’imisozi ikaba nk’ubwoya bw’isufi busanzajwe, butumuriwe hejuru n’umuyaga."
  101,6,"Uwo wese rero, ivyiza vyiwe bizoremera ku munzani;"
  101,7,"Uyo, ni we azoba mu buzima bushimishije mu Bwami bw’ijuru."
  101,8,"Nayo uwo ivyiza vyiwe bizohwahuka ku munzani;"
  101,9,"Uyo rero, uburuhukiro bwiwe ni mu manga ihonya."
  101,10,"Mbega none, ni igiki cokumenyesha ico ari co imanga ihonya?"
  101,11,"Ni umuriro udahera, ururumba."
