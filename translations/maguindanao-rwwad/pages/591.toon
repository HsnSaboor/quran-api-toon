quran[32]{c,v,t}:
  86,1,"(Saki su Allah) idsapa ku su langit andu su bitun."
  86,2,"Dili nengka katawan (Muhammad) i at-tariq."
  86,3,"Bitun a pagkandap."
  86,4,"Uman i sakataw na aden malaa-ikat a pambantay salakanin."
  86,5,"Ilay nu su manusya u ngin i asal nin."
  86,6,"Nakabpun sa ig a padtubpa."
  86,7,"Nakabpun kanu sulbu nu mama andu lalab na babay."
  86,8,"Su Allah na magaga nin mapambalingan su taw kanu nabpunan nin."
  86,9,"Gay a mapayag su masulan."
  86,10,"Dala bagalu a taw andu dala makadtabang."
  86,11,"Ibet kanu langit a aden ulan nin."
  86,12,"Andu su lupa a aden utan nin."
  86,13,"Benal su kadtalu (Qur’an) na bantang na ungangan."
  86,14,"Dikana angiyas atawka ipan-damangyas."
  86,15,"Benal a bagitung silan sa kabinasan."
  86,16,"(Allah)na binasan kubun silan."
  86,17,"Lanati ka (Muhammad) su mga kafeer,ka balanatan ku bun silan."
  87,1,"Tasbih ka sun gala nu kadnan nengka a mapulu."
  87,2,"Sekanin (Allah) i minaluy a napabpalas."
  87,3,"Sekanin (Allah) i minukul andu tinumutulu."
  87,4,"Sekanin (Allah) i napambwat kanu mga utan."
  87,5,"Binaluy nin i nagangu a malupat."
  87,6,"Batyan nami salak (Muhammad) na dili nengka kalipatanan."
  87,7,"Nya tabya na kahandan nu Allah, ka katawan nin su mpayag-masulan."
  87,8,"Pakalamwan nami seka sa lalan a mapya."
  87,9,"Pangindaw ka sa ambalaguna a indawan."
  87,10,"Nya ma-indaw na su magilak."
  87,11,"Andu sanggila sa indawan su darwaka."
  87,12,"Antu bas u makaludap sa naraka."
  87,13,"Mawli na di minatay (andu makatana) atawka dili makambibyag (andu agkapya)."
  87,14,"Saben-sabenal a naka-untung su mid-sutti."
  87,15,"Andu linabit nin su Allah a mid-sambayang."