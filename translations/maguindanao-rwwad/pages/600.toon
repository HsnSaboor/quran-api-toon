quran[21]{c,v,t}:
  100,10,"Andu mapayag su dalam nu pusung (magidsan i kakafeer andu inugut)."
  100,11,"Su kadnan nilan i mataw mamalas sakanilan."
  101,1,"Su gay a mawli."
  101,2,"Nginba i gay a mawli?"
  101,3,"Dili nengka katawan (Muhammad) u ngin i pidtalu a gay a mawli?"
  101,4,"Gay a mabaluy su taw sa mana bun su upaman a tapudi a manganot a padtatampula."
  101,5,"Mabaluy manem su palaw sa mana den libubuk a pamakabayug."
  101,6,"Su taw a mawgat i timbangan a mapya."
  101,7,"Antu ba i taw a mawyag a masuwat."
  101,8,"Su taw manem a mapagkag su mapya nin kanu timbangan."
  101,9,"Na lu pabpatuyan sa naraka a haawiyah."
  101,10,"Dili nengka gatawan i haawiyah?"
  101,11,"Apuy a mayaw gayd."
  102,1,"Makasimpang salakanu su kadakal na tamuk."
  102,2,"Taman sa lu kanu den sa kubur makaimaman."
  102,3,"Uway, dili abpalis na katawan nubu."
  102,4,"Mawli na indanun ka dili sumala na katawan nu bu."
  102,5,"Umana bu ka katawan nu kakinag nu sa naraka."
  102,6,"Na dili sumala na maylay nu su naraka a jaheem."
  102,7,"Mawli na maylay nu su matakapala."
  102,8,"Mawli na makaidsa salakanu su mga limu a inanggay salakanu."