quran[96]{c,v,t}:
  56,1,"Olwa eshikhole shilikholekha (olweyindukho iliula)."
  56,2,"Abulaho uliyingasia okhwikholekha khwashio tawe."
  56,3,"Shiishinjia (okhwinjisia abakhayi mumuliro) shinininjia (okhuninia abakhola amalai mwikulu)."
  56,4,"Olwa eshialo shilirenjibwa obutinyu."
  56,5,"Ne olwefikulu filisiebwa busiebwa."
  56,6,"Fiaba shinga olufu lutumukha."
  56,7,"Nanyu muliba tsimbia tsitaru."
  56,8,"Abandu bomukhono omulunji. Koo, ni babu wina abo Abandu bomukhono omulunji?"
  56,9,"Ne Abandu bomukhono omukaata. Koo, nibabu wina abo bomukhono omukaata?"
  56,10,"Ne beyimbeli baliba imbeli."
  56,11,"Abo nibo bali hambi muno (nende Nyasaye)."
  56,12,"Mumikunda chiomwikulu chobwokholo."
  56,13,"Omukabo omukhongo mubaali imbeli."
  56,14,"Nende mutiti mubeyinyuma."
  56,15,"Baliba khubifumbi biaronwa."
  56,16,"Baliyiekhakhwo nibalengane."
  56,17,"Balikhalabanilwa nende Abasiani bolusoolili lulawa tawe."
  56,18,"Nibachinjile bikombe nende tsibinika nende tsigilasi, tsilimwo ebinywebwa okhurula musebele ingwalafu."
  56,19,"Shibilibatsunia omurwe nohomba shibilibamesia tawe."
  56,20,"Nende ebiamo biabayanza."
  56,21,"Nende inyama yeliyoni shingala bekombanga."
  56,22,"Nende Abakhasi bomwikulu abalahenganga abalali abasatsa babu tawe, abetsimoni tsindayi."
  56,23,"Bali shinga ebisole bialiindwa obulai."
  56,24,"Omurungo khukabakholanga."
  56,25,"Shibaliwulilamwo keshifwabi nohomba ketsimbi tawe."
  56,26,"Halali amakhuwa komulembe konyene."
  56,27,"Ne Abandu bomukhono musatsa, nishina shilinyoola Abandu bomukhono musatsa?"
  56,28,"Baliba khumisaala chibulaho amawa."
  56,29,"Nende ebikoko biloondane."
  56,30,"Nende eshiinikha eshikhongo."
  56,31,"Nende amaatsi kakhulukusia."
  56,32,"Nende ebiamo ebinji."
  56,33,"Shibiwetsanga nohomba shibikalilungwa tawe."
  56,34,"Nende obulili bwachingulwa ekulu."
  56,35,"Toto efwe khwabaloonga abakhasi bomwikulu (hurul ain) okhulonga khwa toto obuyia."
  56,36,"Mana nikhubakhola abashisila."
  56,37,"Bachamana nende Abasatsa babu abayelana ninabo."
  56,38,"Khulwa Abandu bomukhono musatsa."
  56,39,"Omukabo omukhongo khubaali imbeli."
  56,40,"Ne omukabo omukhongo khubaali inyuma."
  56,41,"Abandu bomukhono mukhasi. Koo, ni shina shilinyoola Abandu bomukhono mukhasi?"
  56,42,"Baliba mumuyeka kwomulilo nende amatsi kayia pa."
  56,43,"Nende eshinikha shiomwosi omumali ti."
  56,44,"Shishili shiokhunyoolamwo obunyifu nohombo obwihotselefu tawe."
  56,45,"Toto abo bali, khale awo bamenyanga, shinga benya mubwokholo."
  56,46,"Ne baali nibakhaila khubionoono ebikhongo."
  56,47,"Ne baboolanga mbu: “Nikhumala khwafwa mana khwaba liloba nende ebikumba, mbu toto efwe khulilamusibwa?"
  56,48,"Nohomba bapapa befu bakhale?”"
  56,49,"Boola mbu: “Toto balia abeyimbeli nende beinyuma."
  56,50,"Toto balikhuung’aasibwa khulwa ebise bieyinyanga yarechekhwa yamanyikha."
  56,51,"Khandi toto enywe abakori abakhayi."
  56,52,"Mulilia toto khumusala kwa zaqqum."
  56,53,"Mulikwitsusia mutsinda tsienyu."
  56,54,"Ne mana mulinywa amaatsi kayile pa!"
  56,55,"Ne mulikanywa shinga ingamia inywetsanga nili nende obuloo."
  56,56,"Obo nobucheni bwokhubukaniIwa bwabu inyanga yomurungo."""
  56,57,"Nefwe khwabaloonga enywe, shichilanga shina nimulasuubila tawe?"
  56,58,"Koo, mulolangakhwo amatsi kolwibulo kamwitikhanga?"
  56,59,"Koo nenywe mukaloonganga nohomba nefwe abaloonji?"
  56,60,"Efwe khwabarecheshela lifwa, nafu shikhushilungwa tawe."
  56,61,"Okhukalukhania abaandi balali enywe, ne khubalonje enywe ebilonje biamulamanyile tawe."
  56,62,"Ne toto mwamala okhumanya okhulongwa khwa ambeli, neshina shichilanga nimuletsulila tawe?"
  56,63,"Ne mulolangakhwo emimela chiamuraakanga?"
  56,64,"Nenywe muchimesinjia nohomba nefwe khuchimesinjia?"
  56,65,"Ne khwenyanga, khwakhachikholele chiakhaya okhurakhwo shiosishiosi tawe, mwatong’a nimung’ang’alile."
  56,66,"Nemuboola mbu: “Toto efwe khusandibungwa khushakhurusinjia."
  56,67,"Halali efwe khwimilwe.”"
  56,68,"Koo, mulolangakhwo amaatsi kamunywetsanga?"
  56,69,"Ni enywe mukeshinjia okhurula mumaleesi nohomba nefwe bakeshiinjia?"
  56,70,"Khwenyanga, khwakhakakholele keyichumbi, nikakhabanga mbu simuupanga orio tawe?"
  56,71,"Mulolangakhwo omulilo kwamwashinjia?"
  56,72,"Nenywe mwaloonga omusaala kwakwo nohomba nefwe baloonga?"
  56,73,"Efwe khwakukhola okhuba eshitsulisio nende kwokhukhoonya balia bali mushitsimi."
  56,74,"Kho litswenule elira lia Nyasaye wuwo Omulonji, Omukhongo."
  56,75,"Ne toto nditsuba khubise bietsing’ining’ini tsikwitsanga."
  56,76,"Ne toto shino neshitsubo eshikhongo, mumanyangakhwo toto."
  56,77,"Toto eyo ni Ikurani yoluyali."
  56,78,"Mushitabu shialindwa."
  56,79,"Shashitilangakhwo tawe halali Omutswenufu."
  56,80,"Sheshibwa okhurula khu Nyasaye Omulesi webiloonje bioosi."
  56,81,"Ne kano namakhuwa kamulekanga?"
  56,82,"Amwakhopele orio khumukabo kwenyu (kwa abahele) nanyu mwikhola mbu muyingananga?"
  56,83,"Kaliba karie olwa omwoyo kuliuula khulukamukamu (mwikolomero)?"
  56,84,"Ne enywe ebise ebo muhenganga."
  56,85,"Ne efwe khuli ahambi muno ninanyu, nanyu shimukhulolanga tawe."
  56,86,"Ne enywe nikakhabanga mbu shimulirungwa tawe."
  56,87,"Kalusiekhwo omwoyo oko nikali mbu muboolanga obwatoto."
  56,88,"Ne naliba mubalia basutibwa hambi nende Nyasaye."
  56,89,"Kuliba omwikhoyo nende ebiokhuunya obulai, nende emikunda chomwikulu chobwokholo."
  56,90,"Ne naliba mubandu bomukhono omusatsa."
  56,91,"Ni omulembe khwiwe owuli Mubandu bomukhono musatsa."
  56,92,"Ne naliba Mubayingani Abakori."
  56,93,"Obucheni bwokhubukaniIwa bubwe buliba amaatsi kayile pa!"
  56,94,"Nende okhwinjisibwa mumulilo kwa Jahim."
  56,95,"Toto buno nibo obwatoto bwokhwisikwa."
  56,96,"Kho litswenule elira lia Nyasaye wuwo Omulesi, Woluyali."
