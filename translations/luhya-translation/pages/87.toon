quran[19]{c,v,t}:
  87,1,"Tswenula elira lia Nyasaye wuwo Omulesi, Owoluyali, Owa hekulu muno."
  87,2,"Ulia owaloonga mana naleng’aasia obulai."
  87,3,"Ulia wabusia amakhuwa mana nalunjisia."
  87,4,"Ulia wamesia olwayilo."
  87,5,"Mana nalukhola olumila olumali."
  87,6,"Khulakhusomesia mana sholibilila tawe."
  87,7,"Halali aka Nyasaye achama. Toto Ye amanyile akali habulafu nende kefisile."
  87,8,"Ne khutsia okhukhwanguyilisia kabe amangu."
  87,9,"Kho itsulisia, nikali mbu okhwitsulisia okho khukhoonya."
  87,10,"Yetsa okhwitsulila ulia uria."
  87,11,"Ne yetsa okhwira ehale nako (ametsulisio ako) omukori."
  87,12,"Ulia ulinjila mumulilo omukhongo muno."
  87,13,"Mana shalifwamwo nohomba shalilamukhamwo tawe."
  87,14,"Toto yamala okhubura ulia wetswenula."
  87,15,"Mana niyetsulila elira lia Nyasaye wuwe Omulesi mana naswaliya."
  87,16,"Halali enywe mwayanza mana nimuranjilisia muno obulamu bwokhushialo!"
  87,17,"Ne obulamu bwomwikulu nobulayi ne nibwokhutong'a muno."
  87,18,"Toto kano kali mubitabo bia imbeli."
  87,19,"Ebitabu bia Ibrahim nende Musa."
