quran[78]{c,v,t}:
  55,1,"Owetsimbabaasi tsinyinji."
  55,2,"Yechesia Ikurani."
  55,3,"Yaloonga Omundu."
  55,4,"Namwechesia okhwinoosia."
  55,5,"Eliuba nende Omwesi bichendanga khubise (Nyasaye yabiraho kho abandu bamanye khubio ebise, tsinyanga, amawichi nende emyaka)."
  55,6,"Ne emilandula nende emisaala binamilanga Nyasaye."
  55,7,"Ne yachingula likulu (nalikhola okhuba eshitsafu shye eshialo) ne naraho eshichelo."
  55,8,"Kho mulatutuyia eshichelo tawe."
  55,9,"Ne muchele habwene, ne mulaleemia eshichelo tawe."
  55,10,"Ne eshialo yashiraho khulwa ebiloonje."
  55,11,"Shilimwo ebiamo nende emitende chili nende ebibuli."
  55,12,"Nende imele yamakhoba nende amasafu ka raihan (kawunyanga obulayi)."
  55,13,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,14,"Yaloonga Omundu okhurula khwiloba shinga liokhuloonjela tsinyungu."
  55,15,"Ne naloonga Al-Jan (papa wa amajini) okhurula khumulilo kubula omwosi."
  55,16,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,17,"Nyasaye Omulesi we ebukwe tsibili nende we mumbo tsibili."
  55,18,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,19,"Yalekhulila tsinyanza tsibili tsibukananga."
  55,20,"Hakari watsio shiliho eshikalilo tsilasasania tawe."
  55,21,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,22,"Mutsinyaanza etso ebisole (lulu) birulangamwo nende ebiendo (marjan)."
  55,23,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,24,"Ne bioosi ni ebibie bichendanga khumaatsi shinga efikulu."
  55,25,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,26,"Bioosi bili khushialo biliwa."
  55,27,"Ne bulitong’a obweni bwa Nyasaye wuwo Omulesi Woluyali nende Obuhani."
  55,28,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,29,"Bioosi bili mwikulu nende mushialo bisabanga Nyasaye, buli ebise atsililisinjia amakhuwa."
  55,30,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,31,"Khulibabalila kamwakholanga mana khubarunje, enywe ebilonje bibili (amajini nende abandu)."
  55,32,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,33,"Enywe Amajini nende Abandu, nimunyala okhunyeleela elwanyi welikulu nende eshialo, nakhanyeleele. Shimunyala okhunyeleela tawe okhurusiakho murumushire amaani katoto (ne mulanyola hena amani ako)."
  55,34,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,35,"Mularumilwa tsinzesele tsiomulilo nende ebichuma bisaalululwe, mana shimulahonokokha tawe."
  55,36,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,37,"Olwelikulu liliatikha mana libe eliakhanyu shinga amafura kasalululwe."
  55,38,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,39,"Inyanga eyo abulao ulireebwa tsimbi tsitsie tawe, omundu nohomba lijini."
  55,40,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,41,"Abetsimbi balimanyikhana khubimanyisio biabu, nibatilwa khulwotosi nende ebisisilo."
  55,42,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,43,"Ino niyo Jahannamu ya ababii bayingasinjia."
  55,44,"Bakhabotokhanengemwo nende mumatsi kamwo akayia paa."
  55,45,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,46,"Ne ulia waria okhwemibwa imbeli wa Nyasaye wuwe Omulesi aliba nemikunda chibili."
  55,47,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,48,"Emikunda chilimwo emisaala chiamasaka amarakalafu."
  55,49,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,50,"Tsisebele tsilimwo tsibili tsikhulukusinjia."
  55,51,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,52,"Mumikunda echo bilimwo ebiamo bioosi bibili bibili."
  55,53,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,54,"Baliyekha khubulili obwa amarungeti kabwo kakwalaala, ne ebiamo biemikunda echo bilieleela ahambi."
  55,55,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,56,"Ne mukari omo abakhasi balimwo beliinda, shibatilwakhwo nende omundu nohomba lijini tawe."
  55,57,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,58,"Opara mbu bo ni lichina lia yaqut nende ebisole ebilafu (marjan)."
  55,59,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,60,"Koo, omurungo kwobulayi kwakhakhaya okhuba obulayi?"
  55,61,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,62,"Ne okhushilakhwo hao chilimwo emikunda chindi chibili."
  55,63,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,64,"Chiamasafu kelima ti."
  55,65,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,66,"Tsilimwo tsisebele tsibili tsielima."
  55,67,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,68,"Ebiamo bilimwo, mitende nende rumana."
  55,69,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,70,"Mukari omo balimwo abakhasi abalayi abawulili."
  55,71,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,72,"Abakhasi abalayi betsimoni tsikhongo, balarulanga munzu tawe."
  55,73,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,74,"Shibatilwakhwo nomundu nohomba lijini tawe."
  55,75,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,76,"Baliyekha khubifumbi bioluyali biobukondo bwamasafu nende emikeka chianabwa obulayi."
  55,77,"Kho emikabo shina chia Nyasaye wenyu Omulesi chiamukhayanga?"
  55,78,"Ni lietsikhabi elira lia Nyasaye wuwo Omulesi, Woluyali nende Obuhani."
