quran[20]{c,v,t}:
  90,1,"Nditsuba khulitokho lino!"
  90,2,"Ne ewe oli omwibule omulekhule welitokho lino."
  90,3,"Nende khumwibusi nende shiayebula."
  90,4,"Toto bwene khwaloonga omundu khubusandi."
  90,5,"Koo, aparanga mbu abulaho omundu yesiyesi umunyala?"
  90,6,"Aboola mbu: “Ndasamba eshiachi shiomwandu.”"
  90,7,"Kho aparanga mbu abulaho yesiyesi umulolanga?"
  90,8,"Koo, shikhwamuhelesia tsimoni tsibili tawe?"
  90,9,"Nende olulimi nebinwa bibili?"
  90,10,"Ne nikhumumanyia tsinjila tsioosi tsibili?"
  90,11,"Ne shiyeruma khunjila yebisikirasio tawe."
  90,12,"Ne nishina shikhwechesia okhumanya injila yebisikirasio?"
  90,13,"Nokhukhola omurumwa abe omulekhule."
  90,14,"Nohomba okhulisia inyanga yeyinzala."
  90,15,"Omwana omufwilwa omwikho."
  90,16,"Nohomba omumanani omushisandu."
  90,17,"Mana abe mubalia basuubila mana nibachelelana okhwifwila ne nibachelelana okhulolanila eshisa."
  90,18,"Abo nibo Abandu bomukhono musaatsa."
  90,19,"Ne balia bakhaya ebimanyisio biefu, abo nibo Abandu bomukhono mukhasi."
  90,20,"Ekulu wabu kuliba omulilo omululu kwekalilwa buli tsimbeka."
