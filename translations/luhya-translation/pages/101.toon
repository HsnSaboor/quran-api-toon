quran[11]{c,v,t}:
  101,1,"Eshikhong’ondanga!"
  101,2,"Eshikhong’ondanga ni shina?"
  101,3,"Ne nishiina shilakhumanyia mbu eshikhong’ondanga nishina?"
  101,4,"Inyanga yabandu baliba shinga tsimburukuru tsisaalanibwe."
  101,5,"Ne tsingulu tsiliba shinga obwoya bwelikondi busakhululwe!"
  101,6,"Kho ulia weshichelo shishie shiliba eshisiro,"
  101,7,"Oyo aliba mubulamu buchamisia."
  101,8,"Ne ulia weshichelo shishie shiliba eshiangu,"
  101,9,"Oyo eshimenyo shishie shiliba mumulilo kwa Hawiya!"
  101,10,"Ne nishina shikhumanyisia mbu nishina esho?"
  101,11,"Ni omulilo kwakhanga muno!"
