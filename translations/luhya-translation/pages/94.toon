quran[8]{c,v,t}:
  94,1,"Shikhwakhubambulila eshilifu shishio tawe?"
  94,2,"Ne nikhukhuruula omusiko kukwo?"
  94,3,"Kwali nikwafunaka omukongo kukwo?"
  94,4,"Ne nikhura hekulu okhurumbulwa khukhwo?"
  94,5,"Ne toto halala nende obusiro buliho obwangu."
  94,6,"Toto halala nende obusiro buliho obwangu."
  94,7,"Kho, nonyoola obwiyangu, khola eshinani."
  94,8,"Ne yenya muno ewa Nyasaye wuwo Omulesi."
