quran[25]{c,v,t}:
  84,1,"Olwa likulu liliarukha."
  84,2,"Ne olwa liliwulila Nyasaye walio Omulesi, shingala lialachilwa okhumuwulila."
  84,3,"Olwa liloba lilikwalaasibwa."
  84,4,"Mana liarusia bioosi bilimwo liaba likhaya."
  84,5,"Ne olwa liliwulila Nyasaye walio Omulesi, shingala lialachilwa okhumuwulila."
  84,6,"Ewe omundu, toto ewe okhalabananga muno okhutsia ewa Nyasaye wuwo Omulesi, mana olibukana ninaye."
  84,7,"Kho ulia owulihebwa eshitabu shishie nomukhono kukwe omulunji."
  84,8,"Oyo okhubalilwa (ebikhole) khukhwe khuliba okhwangu."
  84,9,"Ne alikalushila abandu bebe naasangalile."
  84,10,"Ne ulia ulihelesibwa eshitabu shishie namukongo wuwe."
  84,11,"Oyo alisaba okhusikha."
  84,12,"Ne alinjila mumulilo."
  84,13,"Toto ye yali mubandu bebe niyasaangala."
  84,14,"Toto ye yaparanga mbu shalikalukha khandi tawe."
  84,15,"Tawe! Toto bwene Nyasaye wuwe Omulesi yamulolanga muno!"
  84,16,"Ne nditsuba khubwakhanyu bweliuba nilitsia okhukwa."
  84,17,"Nende khushilo nende shia shibuusinjia."
  84,18,"Nende khumwesi shingala kukhongoyanga."
  84,19,"Toto bwene mwitsa okhunina eshisia khushisia!"
  84,20,"Bali barie abalasuubilanga tawe?"
  84,21,"Ne nibasoomelwa Ikurani, shibaretsanga obweni hasi tawe."
  84,22,"Halali balia abakhaya bayingananga butswa."
  84,23,"Ne Nyasaye amanyile muno akababisanga mukari mwabu."
  84,24,"Kho baboolere akeshinyasio eshilulu!"
  84,25,"Halali balia basuubila mana nibakhola amalayi. Abo baliba nende omurungo kulawa tawe."
