quran[19]{c,v,t}:
  82,1,"Olwe likulu lilisambukha."
  82,2,"Ne olwa tsing’ining’ini tsilibulungukha."
  82,3,"Ne olwa tsinyanza tsiliarulwa."
  82,4,"Ne olwa ebilindwa biliyabululwa."
  82,5,"Buli omundu alimanya shayakhola imbeli nende mukhumalilikha."
  82,6,"Ewe Omundu, ni shina shiakhukatia waalekha Nyasaye wuwo Omulesi, Woluyali?"
  82,7,"Ulia wakhuloonga, mana naakhukasia obulayi, nakhuleng’ania."
  82,8,"Nakhukasia mulikondo liomwene yachama."
  82,9,"Shikali kario tawe! Halali enywe mukatsulanga Inyanga yomurungo."
  82,10,"Ne toto bwene muli nende Abalindi."
  82,11,"Abahandichi aboluyali."
  82,12,"Bamanya koosi kamukholanga."
  82,13,"Toto abakholi bamalayi baliba mubwokholo."
  82,14,"Ne toto abakholi betsimbi baliba mumulilo."
  82,15,"Balinjilamwo inyanga yomurungo."
  82,16,"Ne shibalinyalilwa okhurulamwo tawe."
  82,17,"Ne ni shina shilakhumanyia inyanga yomurungo eyo?"
  82,18,"Khandi ni shina shilakhumanyia inyanga yomurungo eyo?"
  82,19,"Inyanga yomundu alikhaywa okhukhoonya owundi shiosishiosi, ne inyanga eyo okhulomesia khwoosi khuliba khwa Nyasaye yenyene."
