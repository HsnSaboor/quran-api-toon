quran[11]{c,v,t}:
  93,1,"Nditsuba khu isenya (okhurula itsuli okhula eshitere)!"
  93,2,"Nditsuba khushilo olwa shinjilanga!"
  93,3,"Nyasaye wuwo shiyakhulekha tawe, nohomba shiyakhusinyishila tawe."
  93,4,"Ne obulamu bwomwikulu nobulayi khwiwe okhushira bwa khushialo."
  93,5,"Ne Nyasaye wuwo Omulesi alakhuwa okhula ochame."
  93,6,"Shiyakhunyoola noli omufwilwa mana nakhuwa eshimenyo?"
  93,7,"Ne nakhunyoola niwakora, mana nakhulunjisia?"
  93,8,"Ne nakhunyoola noli omumanani mana nakhuyindiasia?"
  93,9,"Kho omwana omufwilwa, olamufuolafia tawe!"
  93,10,"Naye usaba olamuwusa tawe!"
  93,11,"Ne obwokholo bwa Nyasaye wuwo Omulesi obuboole."
