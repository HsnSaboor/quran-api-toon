quran[30]{c,v,t}:
  89,1,"Nditsuba khubise biomumabwibwi."
  89,2,"Nende khubilo ekhumi."
  89,3,"Nende khu bibili bibili nende khushilala shilala."
  89,4,"Nende khushilo shinga shiburanga."
  89,5,"Kho, mu kano shilimwo eshitsubo khumuchesi?"
  89,6,"Shiwalolakhwo shinga Nyasaye wuwo Omulesi yakhola Abandu ba A’di tawe?"
  89,7,"Abandu ba Iram, eyali nende tsinzu tsindambi?"
  89,8,"Aba Nyasaye alalongakhwo shinga bo khushialo tawe."
  89,9,"Nende Thamudi abakasinjia tsinzu mumatwoma?"
  89,10,"Nende Firauni wetsinzu shinga tsisiilo?"
  89,11,"Abakhola tsimbi muno khushialo?"
  89,12,"Nibetsusiamwo obwononia?"
  89,13,"Mana Nyasaye wuwo Omulesi nabakhupa eshiboko shieshinyasio."
  89,14,"Toto Nyasaye wuwo Omulesi abahenganga nabalindilile."
  89,15,"Ne Omundu olwa Nyasaye wuwe Omulesi amutema namuhelesia emiandu nende obwokholo, amalanga aboola mbu: “Nyasaye wanje Omulesi yambelesiye oluyali!”"
  89,16,"Ne namutema mana amuleemie omukabo kwe, naboola mbu: “Nyasaye wanje Omulesi yandutuyia!”"
  89,17,"Shikali kario tawe! Halali enywe shimuhenganga abana bafwilwa neshisa tawe."
  89,18,"Ne shimutinyisaninjia okhulisia abamanani tawe."
  89,19,"Ne mulitsanga emiandu chia abafwilwa okhulia khwatoto."
  89,20,"Ne mwayanza emiandu obuyanzi obuunji muno."
  89,21,"Shikali kario tawe! Olwa eshialo shilifunakwa ebitonye ebitonye."
  89,22,"Ne aliitsa Nyasaye wuwo Omulesi nende Abamalaika olunyali olunyali."
  89,23,"Ne omulilo kwa Jahannamu kulireerwa inyanga eyo, omundu inyanga eyo alitsulila, halali okhwitsulila okho shikhulimukhoonya shiosishiosi tawe."
  89,24,"Aliboola mbu: “Manyanga, ndakharanjisiliyie ebikhole ebilayi khulwa obulamu bwanje (bwemakombe)!”"
  89,25,"Mana inyanga eyo abulaho yesiyesi ulihelesia eshinyasio shinga eshinyasio shishie."
  89,26,"Ne yesiyesi shaliboya shinga okhuboya khukhwe tawe."
  89,27,"Ewe omwoyo omwihotselefu!"
  89,28,"Kalukha khu Nyasaye wuwo Omulesi noli nende obuchami, ne khandi nochamilwe."
  89,29,"Kho injila halala nende Abasumba banje."
  89,30,"Mana winjile mumukunda kwanje kwomwikulu."
