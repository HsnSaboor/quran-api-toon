quran[50]{c,v,t}:
  77,1,"Nditsuba khuchirumungwa kaala!"
  77,2,"Nende chiwutsanga obutinyu."
  77,3,"Nende chimitsanga ifula isalana!"
  77,4,"Nende abamalaika bekhanga okhwaukhasia amalayi nende amabii."
  77,5,"Nende abamalaika bekhanga nende obufimbuli."
  77,6,"Bube khubo eshichila nohomba amekanyilisio."
  77,7,"Toto bwene kamulakungwa kaliba!"
  77,8,"Olwa tsing’ining’ini tsilisumibwa."
  77,9,"Ne olwa likulu liliatisibwa."
  77,10,"Ne olwa efikulu filipurusibwa."
  77,11,"Ne olwa Abarumwa balikhung'asibwa kubise bilala."
  77,12,"Khulwa inyanga shina eyo yasutibwa imbeli?"
  77,13,"Khulwa inyanga yokhwaukhania."
  77,14,"Ne shina shikhumanyia inyanga yokhwaukhania?"
  77,15,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,16,"Shikhwasishia abaranjilila?"
  77,17,"Mana nikhubalondiakhwo abeinyuma?"
  77,18,"Endio nilwakhukholanga Abandu ababii."
  77,19,"Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi."
  77,20,"Shikhwabaloonga okhurulana nende amatsi kalekungwa?"
  77,21,"Mana nikhukara habundu ayenzefu alayi."
  77,22,"Okhula ebise bimanyishe."
  77,23,"Mana nikhuraho ebise, ne nifwe abamanya ebise bikhoyeshele."
  77,24,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,25,"Shikhwakhola liloba libe liokhukhung’asia tawe?"
  77,26,"Abalamu nende abafu?"
  77,27,"Ne nikhuramwo efikulu efirambi (fiokhutinyisia liloba), ne nukhubanywesia amatsi amalayi."
  77,28,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,29,"Tsie khushinyasio shiamwakatsulanga."
  77,30,"Tsie mushinikha (shiomwosi) shiamarafi kataru."
  77,31,"Sishirera eshinikha shiosishiosi tawe, ne sishikhonya shiosishiosi okhurulana nende omulilo tawe."
  77,32,"Omulilo oko kusukunanga tsinzesele shinga tsinzu tsikhongo."
  77,33,"Shinga tsingamia tsia namabuyu."
  77,34,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,35,"Ino ni inyanga yabalaliboola shiosishiosi tawe."
  77,36,"Nohomba shibalifuchililwa okhurusia eshichila tawe."
  77,37,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,38,"Ino niyo inyanga yobwawukhani, khubakhung’asiye nende abeyimbeli."
  77,39,"Kho, nimuli nende liokhututa, nakhatutekho."
  77,40,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,41,"Toto abaria Nyasaye baliba mubiinikha nende tsisebele."
  77,42,"Nende ebiamo mubuli biabenyanga muno."
  77,43,"Lie, ne munywe mumwikhoyo khukalia kamwakholanga."
  77,44,"Toto endio nilwakhurunganga abakholi bamalayi."
  77,45,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,46,"Lie, ne mwikhoye hatiti. Toto enywe muli abamabii muno."
  77,47,"Eshinyasio eshikhongo inyanga eyo shiliba khubakatsulanga."
  77,48,"Ne nibabolerwa mbu: “Inamile Nyasaye”, shibenamanga tawe."
  77,49,"Eshinyasio eshikhonga inyanga eyo shiliba khubakatsulanga."
  77,50,"Mana nimakhuwa shina olunyuma lwa kano akabalasuubila?"
