quran[15]{c,v,t}:
  112,1,"Say: “He is Allah, the One;"
  112,2,"Allah, the Eternal Refuge."
  112,3,"He neither begets nor is He begotten,"
  112,4,"and there is none comparable to Him.”"
  113,1,"Say, “I seek refuge with the Lord of the daybreak,"
  113,2,"from the harm of all what He has created;"
  113,3,"from the harm of darkening [night] when it spreads around,"
  113,4,"from the harm of the sorceresses who blow on knots,"
  113,5,"and from the harm of the envier when he envies.""
  114,1,"Say, “I seek refuge with the Lord of mankind,"
  114,2,"the Sovereign of mankind,"
  114,3,"the God of mankind,"
  114,4,"from the harm of the lurking whisperer,"
  114,5,"who whispers into the hearts of mankind,"
  114,6,"from among jinn and mankind.”"