quran[3]{c,v,t}:
  22,0,بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ ۝ 
  22,1,يٰٓاَيُّهَا النَّاسُ اتَّقُوْا رَبَّكُمْ ۚ اِنَّ &nbsp;زَلْزَلَةَ السَّاعَةِ شَيْءٌ عَظِيْمٌ ۝ 
  22,2,يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ عَمَّآ اَرْضَعَتْ وَتَضَعُ كُلُّ ذَاتِ حَمْلٍ حَمْلَهَا وَتَرَى النَّاسَ سُكٰرٰي وَمَا هُمْ بِسُكٰرٰي وَلٰكِنَّ عَذَابَ اللّٰهِ شَدِيْدٌ ۝ 
  22,3,وَمِنَ النَّاسِ مَنْ يُّجَادِلُ فِي اللّٰهِ بِغَيْرِ عِلْمٍ وَّيَتَّبِـعُ كُلَّ شَيْطٰنٍ مَّرِيْدٍ ۝ۙ 
  22,4,كُتِبَ عَلَيْهِ اَنَّهٗ مَنْ تَوَلَّاهُ فَاَنَّهٗ يُضِلُّهٗ وَيَهْدِيْهِ اِلٰى عَذَابِ السَّعِيْرِ ۝ 
  22,5,يٰٓاَيُّهَا النَّاسُ اِنْ &nbsp;كُنْتُمْ فِيْ رَيْبٍ مِّنَ الْبَعْثِ فَاِنَّا خَلَقْنٰكُمْ مِّنْ تُرَابٍ ثُمَّ مِنْ نُّطْفَةٍ ثُمَّ مِنْ عَلَقَةٍ ثُمَّ مِنْ مُّضْغَةٍ مُّخَلَّقَةٍ وَّغَيْرِ مُخَلَّقَةٍ لِّنُبَيِّنَ لَكُمْ ۭ وَنُقِرُّ فِي الْاَرْحَامِ مَا نَشَاۗءُ اِلٰٓى اَجَلٍ مُّسَمًّى ثُمَّ نُخْرِجُكُمْ طِفْلًا ثُمَّ لِتَبْلُغُوْٓا اَشُدَّكُمْ ۚ وَمِنْكُمْ مَّنْ يُّتَوَفّٰى وَمِنْكُمْ مَّنْ يُّرَدُّ اِلٰٓى اَرْذَلِ الْعُمُرِ لِكَيْلَا يَعْلَمَ مِنْۢ بَعْدِ عِلْمٍ شَيْــــًٔا ۭ وَتَرَى الْاَرْضَ هَامِدَةً فَاِذَآ اَنْزَلْنَا عَلَيْهَا الْمَاۗءَ اهْتَزَّتْ وَرَبَتْ وَاَنْۢبَتَتْ مِنْ كُلِّ زَوْجٍۢ بَهِيْجٍ ۝ 
  22,6,ذٰلِكَ بِاَنَّ &nbsp;اللّٰهَ هُوَ الْحَقُّ وَاَنَّهٗ يُـحْيِ الْمَوْتٰى وَاَنَّهٗ عَلٰي كُلِّ شَيْءٍ قَدِيْرٌ ۝ۙ 
  22,7,وَّاَنَّ &nbsp;السَّاعَةَ اٰتِيَةٌ لَّا رَيْبَ فِيْهَا ۙ وَاَنَّ &nbsp;اللّٰهَ يَبْعَثُ مَنْ فِي الْقُبُوْرِ ۝ 
  22,8,وَمِنَ النَّاسِ مَنْ يُّجَادِلُ فِي اللّٰهِ بِغَيْرِ عِلْمٍ وَّلَا هُدًى وَّلَا كِتٰبٍ مُّنِيْرٍ ۝ۙ 
  22,9,ثَانِيَ عِطْفِهٖ لِيُضِلَّ عَنْ سَبِيْلِ اللّٰهِ ۭ لَهٗ فِي الدُّنْيَا خِزْيٌ وَّنُذِيْقُهٗ يَوْمَ الْقِيٰمَةِ عَذَابَ الْحَرِيْقِ ۝ 
  22,10,ذٰلِكَ بِمَا قَدَّمَتْ يَدٰكَ وَاَنَّ &nbsp;اللّٰهَ لَيْسَ بِظَلَّامٍ لِّـلْعَبِيْدِ 10۝ۧ
  22,11,وَمِنَ النَّاسِ مَنْ يَّعْبُدُ اللّٰهَ عَلٰي حَرْفٍ ۚ فَاِنْ &nbsp;اَصَابَهٗ خَيْرُۨ اطْـمَاَنَّ &nbsp;بِهٖ ۚ وَاِنْ &nbsp;اَصَابَتْهُ فِتْنَةُۨ انْقَلَبَ عَلٰي وَجْهِهٖ ڗ خَسِرَ الدُّنْيَا وَالْاٰخِرَةَ ۭ ذٰلِكَ هُوَ الْخُسْرَانُ &nbsp;الْمُبِيْنُ 11؀ 
  22,12,يَدْعُوْا مِنْ دُوْنِ اللّٰهِ مَا لَا يَضُرُّهٗ وَمَا لَا يَنْفَعُهٗ ۭ ذٰلِكَ هُوَ الضَّلٰلُ الْبَعِيْدُ 12۝ۚ 
  22,13,يَدْعُوْا لَمَنْ ضَرُّهٗٓ اَقْرَبُ مِنْ نَّفْعِهٖ ۭ لَبِئْسَ الْمَوْلٰى وَلَبِئْسَ الْعَشِيْرُ 13؀ 
  22,14,اِنَّ &nbsp;اللّٰهَ يُدْخِلُ الَّذِيْنَ اٰمَنُوْا وَعَمِلُوا الصّٰلِحٰتِ جَنّٰتٍ تَجْرِيْ مِنْ تَحْتِهَا الْاَنْهٰرُ &nbsp;ۭ اِنَّ &nbsp;اللّٰهَ يَفْعَلُ مَا يُرِيْدُ 14؀ 
  22,15,مَنْ كَانَ &nbsp;يَظُنُّ اَنْ &nbsp;لَّنْ يَّنْصُرَهُ اللّٰهُ فِي الدُّنْيَا وَالْاٰخِرَةِ فَلْيَمْدُدْ بِسَبَبٍ اِلَى السَّمَاۗءِ ثُمَّ لْيَقْطَعْ فَلْيَنْظُرْ هَلْ يُذْهِبَنَّ كَيْدُهٗ مَا يَغِيْظُ 15؀ 
  22,16,وَكَذٰلِكَ اَنْزَلْنٰهُ اٰيٰتٍۢ بَيِّنٰتٍ ۙ وَّاَنَّ &nbsp;اللّٰهَ يَهْدِيْ مَنْ يُّرِيْدُ 16؀ 
  22,17,اِنَّ &nbsp;الَّذِيْنَ اٰمَنُوْا وَالَّذِيْنَ هَادُوْا وَالصّٰبِــِٕــيْنَ وَالنَّصٰرٰي وَالْمَجُوْسَ وَالَّذِيْنَ اَشْرَكُـوْٓا ڰ اِنَّ &nbsp;اللّٰهَ يَفْصِلُ بَيْنَهُمْ يَوْمَ الْقِيٰمَةِ ۭ اِنَّ &nbsp;اللّٰهَ عَلٰي كُلِّ شَيْءٍ شَهِيْدٌ 17؀ 
  22,18,اَلَمْ تَرَ اَنَّ &nbsp;اللّٰهَ يَسْجُدُ لَهٗ مَنْ فِي السَّمٰوٰتِ وَمَنْ فِي الْاَرْضِ وَالشَّمْسُ وَالْقَمَرُ وَالنُّجُوْمُ وَالْجِبَالُ وَالشَّجَرُ وَالدَّوَاۗبُّ وَكَثِيْرٌ مِّنَ النَّاسِ &nbsp;ۭ وَكَثِيْرٌ حَقَّ عَلَيْهِ الْعَذَابُ ۭ وَمَنْ يُّهِنِ اللّٰهُ فَمَا لَهٗ مِنْ مُّكْرِمٍ ۭ اِنَّ &nbsp;اللّٰهَ يَفْعَلُ مَا يَشَاۗءُ 18؀ڍ{السجدہ} 
  22,19,ھٰذٰنِ خَصْمٰنِ اخْتَصَمُوْا فِيْ رَبِّهِمْ ۡ فَالَّذِيْنَ كَفَرُوْا قُطِّعَتْ لَهُمْ ثِيَابٌ مِّنْ نَّارٍ ۭ يُصَبُّ مِنْ فَوْقِ رُءُوْسِهِمُ الْحَمِيْمُ 19؀ۚ 
  22,20,يُصْهَرُ بِهٖ مَا فِيْ بُطُوْنِهِمْ وَالْجُلُوْدُ 20؀ۭ 
  22,21,وَلَهُمْ مَّقَامِعُ مِنْ حَدِيْدٍ 21؀ 
  22,22,كُلَّمَآ اَرَادُوْٓا اَنْ يَّخْرُجُوْا مِنْهَا مِنْ غَمٍّ اُعِيْدُوْا فِيْهَا ۤ وَذُوْقُوْا عَذَابَ الْحَرِيْقِ 22؀ۧ 
  22,23,اِنَّ &nbsp;اللّٰهَ يُدْخِلُ الَّذِيْنَ اٰمَنُوْا وَعَمِلُوا الصّٰلِحٰتِ جَنّٰتٍ تَجْرِيْ مِنْ تَحْتِهَا الْاَنْهٰرُ يُحَلَّوْنَ فِيْهَا مِنْ اَسَاوِرَ مِنْ ذَهَبٍ وَّلُؤْلُؤًا ۭ وَلِبَاسُهُمْ فِيْهَا حَرِيْرٌ 23؀ 
  22,24,وَهُدُوْٓا اِلَى الطَّيِّبِ مِنَ الْقَوْلِ ښ وَهُدُوْٓا اِلٰى صِرَاطِ الْحَمِيْدِ 24؀ 
  22,25,اِنَّ &nbsp;الَّذِيْنَ كَفَرُوْا وَيَصُدُّوْنَ عَنْ سَبِيْلِ اللّٰهِ وَالْمَسْجِدِ الْحَرَامِ الَّذِيْ جَعَلْنٰهُ لِلنَّاسِ سَوَاۗءَۨ الْعَاكِفُ فِيْهِ وَالْبَادِ ۭ وَمَنْ يُّرِدْ فِيْهِ بِاِلْحَادٍۢ بِظُلْمٍ نُّذِقْهُ مِنْ عَذَابٍ اَلِيْمٍ 25؀ۧ 
  22,26,وَاِذْ بَوَّاْنَا لِاِبْرٰهِيْمَ مَكَانَ &nbsp;الْبَيْتِ اَنْ &nbsp;لَّا تُشْرِكْ بِيْ شَيْـــــًٔا وَّطَهِّرْ بَيْتِيَ لِلطَّاۗىِٕفِيْنَ وَالْقَاۗىِٕمِيْنَ وَالرُّكَّعِ السُّجُوْدِ &nbsp;26؀
  22,27,وَاَذِّنْ فِي النَّاسِ بِالْحَجِّ يَاْتُوْكَ رِجَالًا وَّعَلٰي كُلِّ ضَامِرٍ يَّاْتِيْنَ مِنْ كُلِّ فَجٍّ عَمِيْقٍ 27؀ۙ 
  22,28,لِّيَشْهَدُوْا مَنَافِعَ لَهُمْ وَيَذْكُرُوا اسْمَ اللّٰهِ فِيْٓ اَيَّامٍ مَّعْلُوْمٰتٍ عَلٰي مَا رَزَقَهُمْ مِّنْۢ بَهِيْمَةِ الْاَنْعَامِ &nbsp;ۚ &nbsp;فَكُلُوْا مِنْهَا وَاَطْعِمُوا الْبَاۗىِٕسَ الْفَقِيْرَ 28؀ۡ 
  22,29,ثُمَّ لْيَقْضُوْا تَفَثَهُمْ وَلْيُوْفُوْا نُذُوْرَهُمْ وَلْيَطَّوَّفُوْا بِالْبَيْتِ الْعَتِيْقِ 29؀ 
  22,30,ذٰلِكَ ۤ وَمَنْ يُّعَظِّمْ حُرُمٰتِ اللّٰهِ &nbsp;فَهُوَ خَيْرٌ لَّهٗ عِنْدَ رَبِّهٖ &nbsp;ۭ وَاُحِلَّتْ لَكُمُ الْاَنْعَامُ اِلَّا مَا يُتْلٰى عَلَيْكُمْ فَاجْتَنِبُوا الرِّجْسَ مِنَ الْاَوْثَانِ &nbsp;وَاجْتَنِبُوْا قَوْلَ الزُّوْرِ 30؀ۙ 
  22,31,حُنَفَاۗءَ لِلّٰهِ غَيْرَ مُشْرِكِيْنَ بِهٖ ۭ وَمَنْ يُّشْرِكْ بِاللّٰهِ فَكَاَنَّمَا خَرَّ مِنَ السَّمَاۗءِ فَتَخْطَفُهُ الطَّيْرُ اَوْ تَهْوِيْ بِهِ الرِّيْحُ فِيْ مَكَانٍ &nbsp;سَحِيْقٍ 31؀ 
  22,32,ذٰلِكَ ۤ وَمَنْ يُّعَظِّمْ شَعَاۗىِٕرَ اللّٰهِ فَاِنَّهَا مِنْ تَقْوَي الْقُلُوْبِ 32؀ 
  22,33,لَكُمْ فِيْهَا مَنَافِعُ اِلٰٓى اَجَلٍ مُّسَمًّى ثُمَّ مَحِلُّهَآ اِلَى الْبَيْتِ الْعَتِيْقِ 33؀ۧ 
  22,34,وَلِكُلِّ اُمَّةٍ جَعَلْنَا مَنْسَكًا لِّيَذْكُرُوا اسْمَ اللّٰهِ عَلٰي مَا رَزَقَهُمْ مِّنْۢ بَهِيْمَةِ الْاَنْعَامِ &nbsp;ۭ فَاِلٰـهُكُمْ اِلٰهٌ وَّاحِدٌ فَلَهٗٓ اَسْلِمُوْا ۭ وَبَشِّرِ الْمُخْبِتِيْنَ 34؀ۙ 
  22,35,الَّذِيْنَ اِذَا ذُكِرَ اللّٰهُ وَجِلَتْ قُلُوْبُهُمْ وَالصّٰبِرِيْنَ عَلٰي مَآ اَصَابَهُمْ وَالْمُقِيْمِي الصَّلٰوةِ ۙ وَمِمَّا رَزَقْنٰهُمْ يُنْفِقُوْنَ 35؀ 
  22,36,وَالْبُدْنَ جَعَلْنٰهَا لَكُمْ مِّنْ شَعَاۗىِٕرِ اللّٰهِ لَكُمْ فِيْهَا خَيْرٌ ڰ فَاذْكُرُوا اسْمَ اللّٰهِ عَلَيْهَا صَوَاۗفَّ ۚ فَاِذَا وَجَبَتْ جُنُوْبُهَا فَكُلُوْا مِنْهَا وَاَطْعِمُوا الْقَانِعَ وَالْمُعْتَرَّ ۭ كَذٰلِكَ سَخَّرْنٰهَا لَكُمْ لَعَلَّكُمْ تَشْكُرُوْنَ 36؀ 
  22,37,لَنْ يَّنَالَ اللّٰهَ لُحُوْمُهَا وَلَا دِمَاۗؤُهَا وَلٰكِنْ يَّنَالُهُ التَّقْوٰي مِنْكُمْ ۭ كَذٰلِكَ سَخَّرَهَا لَكُمْ لِتُكَبِّرُوا اللّٰهَ عَلٰي مَا هَدٰىكُمْ ۭ وَبَشِّرِ الْمُحْسِنِيْنَ 37؀ 
  22,38,اِنَّ &nbsp;اللّٰهَ يُدٰفِعُ عَنِ الَّذِيْنَ اٰمَنُوْا ۭ اِنَّ &nbsp;اللّٰهَ لَا يُحِبُّ كُلَّ خَوَّانٍ &nbsp;كَفُوْرٍ 38؀ۧ 
  22,39,اُذِنَ لِلَّذِيْنَ يُقٰتَلُوْنَ بِاَنَّهُمْ ظُلِمُوْا ۭ وَاِنَّ &nbsp;اللّٰهَ عَلٰي نَصْرِهِمْ لَقَدِيْرُۨ 39؀ۙ 
  22,40,الَّذِيْنَ اُخْرِجُوْا مِنْ دِيَارِهِمْ بِغَيْرِ حَقٍّ اِلَّآ اَنْ &nbsp;يَّقُوْلُوْا رَبُّنَا اللّٰهُ ۭ وَلَوْلَا دَفْعُ اللّٰهِ النَّاسَ بَعْضَهُمْ بِبَعْضٍ لَّهُدِّمَتْ صَوَامِعُ وَبِيَعٌ وَّصَلَوٰتٌ وَّمَسٰجِدُ يُذْكَرُ فِيْهَا اسْمُ اللّٰهِ كَثِيْرًا ۭوَلَيَنْصُرَنَّ اللّٰهُ مَنْ يَّنْصُرُهٗ ۭ اِنَّ &nbsp;اللّٰهَ لَقَوِيٌّ عَزِيْزٌ 40؀ 
  22,41,اَلَّذِيْنَ اِنْ &nbsp;مَّكَّنّٰهُمْ فِي الْاَرْضِ اَقَامُوا الصَّلٰوةَ وَاٰتَوُا الزَّكٰوةَ وَاَمَرُوْا بِالْمَعْرُوْفِ وَنَهَوْا عَنِ الْمُنْكَرِ ۭ وَلِلّٰهِ عَاقِبَةُ الْاُمُوْرِ 41؀ 
  22,42,وَاِنْ &nbsp;يُّكَذِّبُوْكَ فَقَدْ كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوْحٍ وَّعَادٌ وَّثَمُوْدُ 42؀ۙ 
  22,43,وَقَوْمُ اِبْرٰهِيْمَ وَقَوْمُ لُوْطٍ 43؀ۙ 
  22,44,وَّاَصْحٰبُ مَدْيَنَ ۚ وَكُذِّبَ مُوْسٰى فَاَمْلَيْتُ لِلْكٰفِرِيْنَ ثُمَّ اَخَذْتُهُمْ ۚ فَكَيْفَ كَانَ &nbsp;نَكِيْرِ 44؀ 
  22,45,فَكَاَيِّنْ مِّنْ قَرْيَةٍ اَهْلَكْنٰهَا وَهِىَ ظَالِمَةٌ فَهِيَ خَاوِيَةٌ عَلٰي عُرُوْشِهَا وَبِئْرٍ مُّعَطَّلَةٍ وَّقَصْرٍ مَّشِيْدٍ 45؀ 
  22,46,اَفَلَمْ يَسِيْرُوْا فِي الْاَرْضِ فَتَكُوْنَ لَهُمْ قُلُوْبٌ يَّعْقِلُوْنَ بِهَآ اَوْ اٰذَانٌ &nbsp;يَّسْمَعُوْنَ بِهَا ۚ فَاِنَّهَا لَا تَعْمَى الْاَبْصَارُ وَلٰكِنْ تَعْمَى الْقُلُوْبُ الَّتِيْ فِي الصُّدُوْرِ 46؀ 
  22,47,وَيَسْتَعْجِلُوْنَكَ بِالْعَذَابِ وَلَنْ يُّخْلِفَ اللّٰهُ وَعْدَهٗ ۭ وَاِنَّ &nbsp;يَوْمًا عِنْدَ رَبِّكَ كَاَلْفِ سَنَةٍ مِّمَّا تَعُدُّوْنَ 47؀ 
  22,48,وَكَاَيِّنْ مِّنْ قَرْيَةٍ اَمْلَيْتُ لَهَا وَهِىَ ظَالِمَةٌ ثُمَّ اَخَذْتُهَا ۚ وَاِلَيَّ الْمَصِيْرُ 48؀ۧ 
  22,49,قُلْ يٰٓاَيُّهَا النَّاسُ اِنَّمَآ اَنَا لَكُمْ نَذِيْرٌ مُّبِيْنٌ 49؀ۚ 
  22,50,فَالَّذِيْنَ اٰمَنُوْا وَعَمِلُوا الصّٰلِحٰتِ لَهُمْ مَّغْفِرَةٌ وَّرِزْقٌ كَرِيْمٌ 50؀ 
  22,51,وَالَّذِيْنَ سَعَوْا فِيْٓ اٰيٰتِنَا مُعٰجِزِيْنَ اُولٰۗىِٕكَ اَصْحٰبُ الْجَحِيْمِ 51؀ 
  22,52,وَمَآ اَرْسَلْنَا مِنْ قَبْلِكَ مِنْ رَّسُوْلٍ وَّلَا نَبِيٍّ اِلَّآ اِذَا تَـمَنّىٰٓ اَلْقَى الشَّيْطٰنُ فِيْٓ اُمْنِيَّتِهٖ ۚ فَيَنْسَخُ اللّٰهُ مَا يُلْقِي الشَّيْطٰنُ ثُمَّ يُحْكِمُ اللّٰهُ اٰيٰتِهٖ ۭ وَاللّٰهُ عَلِيْمٌ حَكِيْمٌ 52؀ۙ 
  22,53,لِيَجْعَلَ مَا يُلْقِي الشَّيْطٰنُ فِتْنَةً لِّلَّذِيْنَ فِيْ قُلُوْبِهِمْ مَّرَضٌ وَّالْقَاسِيَةِ قُلُوْبُهُمْ ۭ وَاِنَّ &nbsp;الظّٰلِمِيْنَ لَفِيْ شِقَاقٍۢ بَعِيْدٍ 53؀ۙ 
  22,54,وَّلِيَعْلَمَ الَّذِيْنَ اُوْتُوا الْعِلْمَ اَنَّهُ الْحَقُّ مِنْ رَّبِّكَ فَيُؤْمِنُوْا بِهٖ فَتُخْبِتَ لَهٗ قُلُوْبُهُمْ ۭ وَاِنَّ &nbsp;اللّٰهَ لَهَادِ الَّذِيْنَ اٰمَنُوْٓا اِلٰى صِرَاطٍ مُّسْتَقِيْمٍ 54؀ 
  22,55,وَلَا يَزَالُ الَّذِيْنَ كَفَرُوْا فِيْ مِرْيَةٍ مِّنْهُ حَتّٰى تَاْتِيَهُمُ السَّاعَةُ بَغْتَةً اَوْ يَاْتِيَهُمْ عَذَابُ يَوْمٍ عَقِيْمٍ 55؀ 
  22,56,اَلْمُلْكُ يَوْمَىِٕذٍ لِّلّٰهِ ۭ يَحْكُمُ بَيْنَهُمْ ۭ فَالَّذِيْنَ اٰمَنُوْا وَعَمِلُوا الصّٰلِحٰتِ فِيْ جَنّٰتِ النَّعِيْمِ 56؀ 
  22,57,وَالَّذِيْنَ كَفَرُوْا وَكَذَّبُوْا بِاٰيٰتِنَا فَاُولٰۗىِٕكَ لَهُمْ عَذَابٌ مُّهِيْنٌ 57؀ۧ 
  22,58,وَالَّذِيْنَ هَاجَرُوْا فِيْ سَبِيْلِ اللّٰهِ ثُمَّ قُتِلُوْٓا اَوْ مَاتُوْا لَيَرْزُقَنَّهُمُ اللّٰهُ رِزْقًا حَسَنًا ۭ وَاِنَّ &nbsp;اللّٰهَ لَهُوَ خَيْرُ الرّٰزِقِيْنَ 58؀ 
  22,59,لَيُدْخِلَنَّهُمْ مُّدْخَلًا يَّرْضَوْنَهٗ ۭ وَاِنَّ &nbsp;اللّٰهَ لَعَلِيْمٌ حَلِيْمٌ 59؀ 
  22,60,ذٰلِكَ ۚ وَمَنْ عَاقَبَ بِمِثْلِ مَا عُوْقِبَ بِهٖ ثُمَّ بُغِيَ عَلَيْهِ لَيَنْصُرَنَّهُ اللّٰهُ ۭ اِنَّ &nbsp;اللّٰهَ لَعَفُوٌّ غَفُوْرٌ 60؀ 
  22,61,ذٰلِكَ بِاَنَّ &nbsp;اللّٰهَ يُوْلِجُ الَّيْلَ فِي النَّهَارِ وَيُوْلِجُ النَّهَارَ فِي الَّيْلِ وَاَنَّ &nbsp;اللّٰهَ سَمِيْعٌۢ بَصِيْرٌ 61؀ 
  22,62,ذٰلِكَ بِاَنَّ &nbsp;اللّٰهَ هُوَ الْحَقُّ وَاَنَّ &nbsp;مَا يَدْعُوْنَ مِنْ دُوْنِهٖ هُوَ الْبَاطِلُ وَاَنَّ &nbsp;اللّٰهَ هُوَ الْعَلِيُّ الْكَبِيْرُ 62؀ 
  22,63,اَلَمْ تَرَ اَنَّ &nbsp;اللّٰهَ اَنْزَلَ مِنَ السَّمَاۗءِ مَاۗءً ۡ فَتُصْبِحُ الْاَرْضُ مُخْضَرَّةً ۭ اِنَّ &nbsp;اللّٰهَ لَطِيْفٌ خَبِيْرٌ 63؀ۚ 
  22,64,لَهٗ مَا فِي السَّمٰوٰتِ وَمَا فِي الْاَرْضِ ۭ وَاِنَّ &nbsp;اللّٰهَ لَهُوَ الْغَنِيُّ الْحَمِيْدُ 64؀ۧ 
  22,65,اَلَمْ تَرَ اَنَّ &nbsp;اللّٰهَ سَخَّرَ لَكُمْ مَّا فِي الْاَرْضِ وَالْفُلْكَ تَجْرِيْ فِي الْبَحْرِ بِاَمْرِهٖ ۭ وَيُمْسِكُ السَّمَاۗءَ اَنْ &nbsp;تَقَعَ عَلَي الْاَرْضِ اِلَّا بِاِذْنِهٖ ۭ اِنَّ &nbsp;اللّٰهَ بِالنَّاسِ لَرَءُوْفٌ رَّحِيْمٌ 65؀ 
  22,66,وَهُوَ الَّذِيْٓ اَحْيَاكُمْ ۡ ثُمَّ يُمِيْتُكُمْ ثُمَّ يُحْيِيْكُمْ ۭ اِنَّ &nbsp;الْاِنْسَانَ &nbsp;لَكَفُوْرٌ 66؀ 
  22,67,لِكُلِّ اُمَّةٍ جَعَلْنَا مَنْسَكًا هُمْ نَاسِكُوْهُ فَلَا يُنَازِعُنَّكَ فِي الْاَمْرِ وَادْعُ اِلٰى رَبِّكَ &nbsp;ۭ اِنَّكَ لَعَلٰى هُدًى مُّسْتَقِيْمٍ 67؀ 
  22,68,وَاِنْ &nbsp;جٰدَلُوْكَ فَقُلِ اللّٰهُ اَعْلَمُ بِمَا تَعْمَلُوْنَ 68؀ 
  22,69,اَللّٰهُ يَحْكُمُ بَيْنَكُمْ يَوْمَ الْقِيٰمَةِ فِيْمَا كُنْتُمْ فِيْهِ تَخْتَلِفُوْنَ 69؀ 
  22,70,اَلَمْ تَعْلَمْ اَنَّ &nbsp;اللّٰهَ يَعْلَمُ مَا فِي السَّمَاۗءِ وَالْاَرْضِ ۭ اِنَّ &nbsp;ذٰلِكَ فِيْ كِتٰبٍ ۭ اِنَّ &nbsp;ذٰلِكَ عَلَي اللّٰهِ يَسِيْرٌ 70؀ 
  22,71,وَيَعْبُدُوْنَ مِنْ دُوْنِ اللّٰهِ مَا لَمْ يُنَزِّلْ بِهٖ سُلْطٰنًا وَّمَا لَيْسَ لَهُمْ بِهٖ عِلْمٌ ۭ وَمَا لِلظّٰلِمِيْنَ مِنْ نَّصِيْرٍ 71؀ 
  22,72,وَاِذَا تُتْلٰى عَلَيْهِمْ اٰيٰتُنَا بَيِّنٰتٍ تَعْرِفُ فِيْ وُجُوْهِ الَّذِيْنَ كَفَرُوا الْمُنْكَرَ ۭ يَكَادُوْنَ يَسْطُوْنَ بِالَّذِيْنَ يَتْلُوْنَ عَلَيْهِمْ اٰيٰتِنَا ۭ قُلْ اَفَاُنَبِّئُكُمْ بِشَرٍّ مِّنْ ذٰلِكُمْ ۭ اَلنَّارُ &nbsp;ۭ وَعَدَهَا اللّٰهُ الَّذِيْنَ كَفَرُوْا ۭ وَبِئْسَ الْمَصِيْرُ 72؀ۧ 
  22,73,يٰٓاَيُّهَا النَّاسُ ضُرِبَ مَثَلٌ فَاسْتَمِعُوْا لَهٗ ۭ اِنَّ &nbsp;الَّذِيْنَ تَدْعُوْنَ مِنْ دُوْنِ اللّٰهِ لَنْ يَّخْلُقُوْا ذُبَابًا وَّلَوِ اجْتَمَعُوْا لَهٗ ۭ وَاِنْ &nbsp;يَّسْلُبْهُمُ الذُّبَابُ شَيْـــــًٔـا لَّا يَسْتَنْقِذُوْهُ مِنْهُ ۭ ضَعُفَ الطَّالِبُ وَالْمَطْلُوْبُ 73؀ 
  22,74,مَا قَدَرُوا اللّٰهَ حَقَّ قَدْرِهٖ ۭاِنَّ &nbsp;اللّٰهَ لَقَوِيٌّ عَزِيْزٌ 74؀ 
  22,75,اَللّٰهُ يَصْطَفِيْ مِنَ الْمَلٰۗىِٕكَةِ رُسُلًا وَّمِنَ النَّاسِ &nbsp;ۭ اِنَّ &nbsp;اللّٰهَ سَمِيْعٌۢ بَصِيْرٌ 75؀ۚ 
  22,76,يَعْلَمُ مَا بَيْنَ اَيْدِيْهِمْ وَمَا خَلْفَهُمْ ۭ وَاِلَى اللّٰهِ تُرْجَعُ الْاُمُوْرُ 76؀ 
  22,77,يٰٓاَيُّهَا الَّذِيْنَ اٰمَنُوا ارْكَعُوْا وَاسْجُدُوْا وَاعْبُدُوْا رَبَّكُمْ وَافْعَلُوا الْخَــيْرَ لَعَلَّكُمْ تُفْلِحُوْنَ 77؀ڋ{السجدہ} 
  22,78,وَجَاهِدُوْا فِي اللّٰهِ حَقَّ جِهَادِهٖ ۭ هُوَ اجْتَبٰىكُمْ وَمَا جَعَلَ عَلَيْكُمْ فِي الدِّيْنِ مِنْ حَرَجٍ ۭ مِلَّـةَ اَبِيْكُمْ اِبْرٰهِيْمَ ۭهُوَ سَمّٰىكُمُ الْمُسْلِـمِيْنَ ڏ مِنْ قَبْلُ وَفِيْ ھٰذَا لِيَكُوْنَ الرَّسُوْلُ شَهِيْدًا عَلَيْكُمْ وَتَكُوْنُوْا شُهَدَاۗءَ عَلَي النَّاسِ ښ فَاَقِيْمُوا الصَّلٰوةَ وَاٰتُوا الزَّكٰوةَ وَاعْتَصِمُوْا بِاللّٰهِ ۭ هُوَ مَوْلٰىكُمْ ۚ فَنِعْمَ الْمَوْلٰى وَنِعْمَ النَّصِيْرُ 78؀ۧ 
