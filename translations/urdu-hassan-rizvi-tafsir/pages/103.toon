  103,1,آیت نمبر۱:ہر آن گزرتے اور ختم ہوتے وقت کی قسم کھا کر یہ بتایا گیا ہے کہ ہر انسان نقصان میں ہےصرف وہ لوگ نقصان سے محفوظ ہیں جو ایمان اور نیک اعمال کی دولت دنیا کی زندگی سے کماتے ہیں ۔ کیوں کہ موت کے بعد وہ لوگ ابدی وسر مدی نعمتوں سے لطف اندوز ہوں گے۔ اس کے لئے:(۱) شریعت محمدیؐ کی پابندی، فرائض الہٰہ کا ادا کرنا، اور حرام کاموں سے بچنا ضروری ہے ۔ اسی کو عمل صالح کہا گیا ہے۔ یہ کام <<صبر علی الطاعۃ اور صبر علی المعصیۃ>>۔ یعنی اطاعت الٰہی پر صبر کے اور حرام کاموں سے بچنے پر صبر کیے بغیر نہیں ہوسکتا۔ گناہوں سے بچنے اور حرام لذتوں سے بچنے پر صبر کرنا پڑتا ہے، بُری خواہشات کو قربان کرنا پڑتا ہے۔ اس کے بعد اس کو آپس میں حق کی وصیت اور ایک دوسرے کو صبر کی نصیحت بھی کرنی ضروری ہے۔&&(تفسیر کبیر)&&خداوندِ عالم جب کسی چیز کی قسم کھاتا ہے، تو وہ قسم اس کے دعویٰ پر دلیل بھی ہوتی ہے زمانے کی قسم کھانے کا مطلب یہ ہے کہ گزرتا ہواوقت اس حقیقت پر گواہ ہے کہ انسان بڑے نقصان میں ہے، سوا ان لوگوں کے جن میں چارصفتیں ہیں ، جو اس سورۃ میں بیان کی گئی ہیں ۔مطلب یہ ہے کہ انسانی تاریخ اس بات پر گواہی دے رہی ہےکہ جو لوگ ان چار صفتوں سے خالی تھے وہ بالآخر تباہ ہوئے۔ پھر گزرتے وقت کی قسم یہ سمجھانے کے لئے کھائی گئی ہے کہ یہی گزرتا وقت تمہیں کام کرنے کے لئے دیا گیا ہے۔ جس طرح امتحان ہال میں طلباء کو تین گھنٹے کا وقت دیا جاتا ہے، تاکہ وہ اس میں اپنی محنتوں کے جوہر دکھائیں ۔ ہم جو کچھ عمل کرتے ہیں اسی محدود وقت کے اندر کرتے ہیں ، اس لئے ہمارا اصلی سرمایہ وقت ہے جو تیزی سے گزررہا ہے۔اب اگر ہم نے یہ وقت غلط کاموں پر خرچ کردیا تو ہم سخت نقصان میں رہاجائیں گے، نفع صرف اور صرف ان لوگوں کو ہوگا جو اسی وقت میں یہ چار صفات جو اس سورۃ میں بیان کی گئی ہیں ، اپنے اندر پیدا کرلیں گے۔ جس طرح طالب علم وہی کامیاب ہوتا ہے جو پرچہ ملنے کےبعد اپنا ہر سیکنڈ صحیح جواب لکھنے میں صرف کرتا ہے۔لغت کے اعتبار سے <<خسارہ>> کا لفظ نفع کی ضد ہے۔ قرآن نے خسارے کا لفظ <<فلاح>> یعنی مکمّل کامیابی کے مقابلے پر استعمال فرمایا ہے۔ خسارے سے یہاں مراد دنیا اور آخرت دونوں کی ناکامی مراد ہے۔ مگر حقیقی فائدہ و نقصان آخرت میں ظاہر ہوگا۔ایمان کے معنی:صرف زبانی اقرار کے نہیں ہوتے، بلکہ خدا، رسولؐ اور آخرت اور تمام ابدی حقیقتوں کو سچے دل سے ماننےکو ایمان کہتے ہیں ۔قرآن نے ایمان کی حقیقت یہ بتائی ہے کہ:<< إِنَّمَا ٱلۡمُؤۡمِنُونَ ٱلَّذِينَ ءَامَنُواْ بِٱللَّهِ وَرَسُولِهِۦ ثُمَّ لَمۡ يَرۡتَابُواْ >> ۔ && (سورۃ ۴۹ الحجرات آیت ۱۵ پارہ ۲۶) && یعنی : @@مومن تو حقیقت میں وہ ہیں جنہوں نے اللہ اور اس کے رسولؐ کو دل سے مانا،اور پھر شک میں نہ پڑے@2۔پھر فرمایا: <<إِنَّمَا ٱلۡمُؤۡمِنُونَ ٱلَّذِينَ إِذَا ذُكِرَ ٱللَّهُ وَجِلَتۡ قُلُوبُهُمۡ   >> && (سورۃ ۸ الانفال آیت ۲ پارہ ۹) &&یعنی : @@مومن تو حقیقتاً وہ ہیں کہ جب اللہ کا ذکر کیا جائے تو ان کے دل لرزلرز جاتے ہیں@@ ۔پھر فرمایا: << وَٱلَّذِينَ ءَامَنُوٓاْ أَشَدُّ حُبّٗا لِّلَّهِۗ  >>۔۔۔&& (سورۃ ۲ البقرۃ آیت ۱۶۵ پارہ ۲) && یعنی : @@اور جولوگ ایمان لاتے ہیں وہ سب سے زیادہ شدید محبت خدا سے کرتے ہیں@@ ۔نیز فرمایا کہ: << فَلَا وَرَبِّكَ لَا يُؤۡمِنُونَ حَتَّىٰ يُحَكِّمُوكَ فِيمَا شَجَرَ بَيۡنَهُمۡ ثُمَّ لَا يَجِدُواْ فِيٓ أَنفُسِهِمۡ حَرَجٗا مِّمَّا قَضَيۡتَ وَيُسَلِّمُواْ تَسۡلِيمٗا >> ۔&& (سورۃ ۴ النساء آیت۶۵پارہ ۵) && یعنی :@@ اے نبیؐ! آپؐکے رب کی قسم، وہ ہرگز مومن نہیں ہوسکتے جب تک کہ وہ اپنے باہمی اختلافات میں تمہیں فیصلہ کرنے والا نہ مان لیں ، پھر جو کچھ تم فیصلہ کرو، اس پر اپنے دلوں میں کوئی تنگی بھی محسوس نہ کریں ، بلکہ سر بسر تسلیم کرلیں@@ ۔&& (سورۃ۴ نسا آیت ۶۵ پارہ ۵) &&
  103,3,آیت نمبر۳:عمل صالح:نیک عمل قرآن کی رو سے صرف وہی عمل ہے جو ایمان کی بنیاد پر کیا جائے۔ یعنی : اس تصور سے کیا جائے کہ میں اپنے مالک کی اطاعت کرنے کے لئے اس کام کو انجام دے رہا ہوں ۔اسی لیے قرآن نے جہاں بھی عمل صالح کا حکم دیا، وہاں پہلے ایمان لانے کا حکم دیا اور ساتھ ساتھ اجر کی بھی امید دلائی گئی۔ اس لئے ایمان وہی ہے جو عمل سے ثابت ہو۔ ایمان بلاعمل صرف ایک دعویٰ ہے بلاثبوت۔ ایمان اور عمل صالح کا تعلق بیج اور درخت والا ہے۔ گویا صرف ایمان کادعویٰ انسان کے خسارے سے نہیں بچاسکتاجب وہ ایمان کے عملی تقاضوں پر عمل نہ کرے۔ایمان اور عمل صالح کی صفتیں پیدا کرنے کے بعد ، حکم دیا گیاکہ ایسے لوگ دوسروں کو بھی حق اور صبر کی نصیحت کریں ۔ گویا خد ایک مومن اور صالح معاشرہ دیکھنا چاہتا ہے۔ ایسا معاشرہ جس میں ہر فردیہ ذمے داری محسوس کرے کہ اسے معاشرے کو بگاڑ سے بچانا بھی ہے۔حق کے معنی:(۱) صحیح اور سچی حقیقت(۲) دوسروں کا وہ حق جو انسان کو ادا کرنا ضروری ہے خواہ وہ خدا کا حق ہو یا بندوں کا حق ہویا اپنے نفس کا حق ہو۔دوسروں کو حق کی نصیحت کرنے کا مطلب یہ ہے کہ مسلمان معاشرہ حق کے خلاف کسی کام کو دیکھ کر خاموش تماشائی نہیں بن سکتا۔ اس کے لئے ضروی ہے کہ اگر باطل سر اُٹھائے تو ہر مسلمان اس کے خلاف اُٹھ کھڑا ہو، اور معاشرے کا فرد عدل و انصاف کےمطابق تمام حقداروں کا حق ادا کرے۔ اور دوسروں کو بھی اس کی تلقین کرے۔ اگر یہ بات کسی معاشرے میں نہ رہے گی تو وہ نقصان سے ہرگز نہیں بچ سکتا۔ اسی بات کو خداوندِ عالم نے یوں فرمایا کہ:<< وَإِذۡ قَالَتۡ أُمَّةٞ مِّنۡهُمۡ لِمَ تَعِظُونَ قَوۡمًا ٱللَّهُ مُهۡلِكُهُمۡ أَوۡ مُعَذِّبُهُمۡ عَذَابٗا شَدِيدٗاۖ قَالُواْ مَعۡذِرَةً إِلَىٰ رَبِّكُمۡ وَلَعَلَّهُمۡ يَتَّقُونَ >> ۔ && (سورۃ ۷ الاعراف آیت ۱۶۴ پارہ۹) && یعنی : @@جب ایک گروہ نے کہا کہ تم ان لوگوں کو کیوں نصیحت کرتے ہو جنہیں اللہ ہلاک کرنے والا ہے یا ان پر شدید عذاب نازل کرنے والا ہے؟ تو انہوں نے کہا: یہ نصیحت ہم اس لئے کرتے ہیں تاکہ ہم تمہارے پروردگار کے سامنے سرخرو ہونے اور اس لئے تاکہ وہ تقویٰ اختیار کرلیں ۔ اور اللہ کے عذاب سے بچ جائیں @@۔پھر اگلی آیت میں فرمایا کہ:<< فَلَمَّا نَسُواْ مَا ذُكِّرُواْ بِهِۦٓ أَنجَيۡنَا ٱلَّذِينَ يَنۡهَوۡنَ عَنِ ٱلسُّوٓءِ وَأَخَذۡنَا ٱلَّذِينَ ظَلَمُواْ بِعَذَابِۢ بَ‍ِٔيسِۢ بِمَا كَانُواْ يَفۡسُقُونَ>> ۔&& (سورۃ ۷ الاعراف آیت ۱۶۵ پارہ ۹) && یعنی : @@اور جب وہ اس نصیحت کو بھول گئے جو انہیں کی گئی تھی، تو ہم نے ان لوگوں کو نجات دی جو کہ انکو برائی سے روکتے اور نصیحت کرتے تھے۔ اور ظالموں اور بدکاروں کو سخت عذاب میں پکڑ لیا۔ بسبب اس فسق وفجور اور بدکاری کے جو وہ کیا کرتے تھے@@۔اسی لئے <<امربالمعروف اور نہی عن المنکر>>کرنے والوں کی تعریف قرآن مجید میں اس طرح فرمائی:<< كُنتُمۡ خَيۡرَ أُمَّةٍ أُخۡرِجَتۡ لِلنَّاسِ تَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَتَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَتُؤۡمِنُونَ بِٱللَّهِۗ وَلَوۡ ءَامَنَ أَهۡلُ ٱلۡكِتَٰبِ لَكَانَ خَيۡرٗا لَّهُمۚ مِّنۡهُمُ ٱلۡمُؤۡمِنُونَ وَأَكۡثَرُهُمُ ٱلۡفَٰسِقُونَ >> ۔ && (سورۃ ۳ آل عمران آیت ۱۱۰ پارہ۴) && یعنی : @@تم بہترین گروہ ہو جو لوگوں کو نیکی کی طرف رغبت دلاتے ہو اور برائی سے روکتے ہو، اور اللہ کو دل سے مانتے ہو@@۔صبر کی تلقین:کامطلب یہ ہے کہ حق کی عملی پیروی کرے اور حق کی حمایت کرے اور حقوق ادا کرنے میں جو مشکلات اور تکالیف، نقصانات، محرومیاں ، اور مشقتیں اُٹھانی پڑتی ہیں ان کوبرداشت کیا جائے ، اور ایک دوسرے کو ان پر ثابت قدم رہنے کی تلقین کرتے رہیں ۔ ہر فرد دوسرے کی ہمت بندھاتا رہے کہ وہ مصائب اور تکالیف کو صبر کے ساتھ برداشت کرے۔&& (تفسیر کبیر ۔ مجمع البیان۔ تفہیم۔ تفسیر نمونہ) <<  خُسر>>&& خُسران کا لفظ بتارہا ہے کہ دنیا تجارت گاہ ہےاسی لئے }}فرزندِ رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام علی نقی علیہ السلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: دنیا ایک بازار ہے جس میں ایک گروہ نے نفع کمایا، اور دوسرے گروہ نے نقصان اُٹھایا۔&& (تحف العقول) {{ &&زندگی کے نقصان سے بچنے کا طریقہ ایمان، عمل صالح، وصیت حق اور وصیت صبر ہے یہ فائدہ اسی دنیا کے گزرتے وقت میں حاصل کر کے ہم نقصان سے بچ سکتے ہیں جبکہ یہ گزرتا ہوا وقت بہت محدود ہے۔ اسی لئے }}حضرت امام علی علیہ السلام نے فرمایا: انسان ک ہر سانس موت کی طرف بڑھتا ہوا ایک قدم ہے۔&& (نہج البلاغۃ کلمات قصار ۷۴) {{ &&انسان کے وقت اور محنت کی اصل قیمت صرف جنّت ہے۔ یعنی وہ اسی وقت ایمان و عمل صالح، وصیت حق اور وصیت صبر پر خرچ کرکے جنّت حاصل کرسکتا ہے۔اسی لئے }}حضرت امام علی علیہ السلام نے فرمایا: تمہارے وجود کی قیمت جنّت کے علاوہ اور کچھ نہیں ہے، کہیں ایسا نہ ہو کہ تم اپنے آپ کو اس سے کمتر کسی اور چیز کے بدلے بیچ ڈالو۔&& (نہج بلاغۃ کلمات قصار ۴۵۶) {{ &&کامیابی کا چار نکاتی پروگرام(۱) ایمان۔ یعنی صحیح عقائد وانکار یعنی شرک، کفر اور نفاق کو چھوڑ کر، توحید، عدل، نبوت، امامت اور قیامت کی ابدی حقیقتوں کو دل سےمان لینا۔ (۲) نیک اعمال یعنی عبادات، اللہ کی  راہ میں مال خرچ کرنا، اللہ کی اطاعت کرتے ہوئے کوششیں کرنا، علم حاصل کرنا، ہر اچھّا کام انجام دینا خدا کی اطاعت کرنا، اور جناب رسول خدا صلی اللہ علیہ و آلہ وسلم کی پیروی کرنا، نیک عمل ایمان کا لازمی منطقی نتیجہ ہوتا ہے۔(۳) دوسروں کو حق کی نصیحت کرنا۔ یعنی ایمان وعمل صالح کی طرف بلانا، تاکہ لوگ باطل کو چھوڑ کرحق کی طرف آئیں ۔ حق کے معنی سچی حقیقت۔ سب سے بڑی سچی حقیقت اصول دین ہیں ۔ اس لئے حق سے اوّلین مراد اصول دین ہیں ۔ اور <<صبر>> سے مراد حق سے روکنے والی چیزون کا مقابلہ کرنا۔ باطل کے مقابلے پر ایمان وعمل صالح کی حفاظت کرنا۔صبر کرنے میں خدا کی اطاعت پر صبر کرنا بھی شامل ہے۔ گناہ پر اُبھارنے والی چیزوں کو برداشت کرنا بھی شامل ہے، مصائب اور ناگواریوں پر صبر کرنا بھی شامل ہے ۔ کیوں کہ صبر کی تین قسمیں ہیں ۔(۱) صبر علی الطاعۃ۔۔ یعنی خدا کی اطاعت میں زحمتوں پر صبر کرنا۔۔ اور (۲) صبر علی المصیبۃ۔۔ باطل کا مقابلہ کرتے ہوئے، اور ناسازگار حالات کا مقابلہ کرتے ہوئے صبر کرنا۔ (۳) <<صبر علی المعصیۃ>>۔ گناہوں سے بچنے پر صبر کرنا۔ یعنی گناہ کرسکتا ہو لیکن خوف خدا کی وجہ سے گناہ کو نہ کرے۔ یہ سب سے زیادہ عظیم ہے۔ اور اس کا ثواب بھی سب سے زیادہ ہے۔&&(تفسیر نمونہ)۔&&زمانے کی قسم کھانے کا مطلب یہ ہے کہ گزرتا وقت اس حقیقت کو ثابت کرنے کے لئے بہت کافی ہے کہ صرف وہی فرد یا قوم نقصان سے بچ سکی جو ایمان و عمل صالح، وصیت حق اور وصیت صبر پر کاربند رہی۔ایمان، یعنی ابدی حقیقتوں کو دل سے سمجھ کرماننا۔ عمل صالح ان ابدی حقیقتوں کو دل سے ماننے کا عملی تقاضا ہے جن کو پورا کرناعمل صالح ہے، اور عمل صالح کی اتنہا یہ ہے کہ خدا کی نعمتوں کو صرف اپنی حد تک محدود نہ رکھا جائے، بلکہ اس کا فیض دوسروں تک پہنچایا جائے ، اسی کو وصیت حق فرمایا، اور یہ تمام کام صبر کے ساتھ برداشت کیے بغیر ممکن نہیں اس لئے صبر کرنے اور دوسروں کو صبر کرنے کی نصیحت کرنے کا حکم دیا۔&& (فصل الخطاب) }}&&فرزندِرسول خدا حضرت امام جعفر صادق علیہ السلام  نے فرمایا کہ: جس وقت کی قسم کھائی ہے اس سے مراد وہ وقت بھی ہے جس وقت قائم آلِ محمدؐ حضرت امام مہدیؑ(صاحب العصر) خروج یا ظہور فرمائیں گے۔ && (تفسیر صافی بحوالہ الاکمال) {{ &&اس میں شک نہیں کہ اسلامی منشور کے ان چار نکات کے تاویلی مصداق کر بلاوالوں سے بہتر مثال کوئی نہیں ہے وہ اپنی مثال آپ ہیں جو اوج انسانیت تک پہنچنے کا بہترین اسوہ حسنہ ہے اس لئے ان کی یاد منانا انسانیت کا اہم فریضہ ہے۔
