  52,1,آیت نمبر۱:<< ’’الطُّوْرِ‘‘ >> ایک خاص پہاڑ جس سے مراد وہ پہاڑ جس پر حضرت موسٰی علیہ السّلام خدا سے باتیں کیا کرتے تھے۔&&(تفسیر کبیر)&&
  52,3,آیت نمبر۳:<< ’’رِقٍ‘‘ >> اس جھلی کوکہتے ہیں جس پر لکھا جایا کرت اتھا۔ مراد ہروہ چیز جس پر لکھا جائے۔&&(تفسیر صافی ص۴۷۰) && اہل کتاب ،توراۃ ،زبور ،انجیل اورآسمانی صحیفوں کو ہرن کی کھال (رق) پرلکھتے تھے ۔ تاکہ محفوظ رہے ۔ کھلی ہوئی کتاب اس لیے فرمایا کہ وہ نایاب نہ تھیں لوگ بآسانی پڑھ کرسمجھ لیتے تھے۔&&(تفسیر کبیر، مجمع البیان، تفہیم)&&
  52,4,آیت نمبر۴:<< ’’الْبَيْتِ الْمَعْمُوْرِ۝۴ ‘‘ >> {{ فرزند رسول خدا  صلی اللہ علیہ و آلہ وسلم حضرت امام محمدباقر علیہ السّلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا کہ: ’’ خداوند کریم وعظیم نے عرش کے نیچے چارستون قائم کیے ہیں،وہی << ’’الْبَيْتِ الْمَعْمُوْرِ۝۴ ‘‘ >> ہے۔ خداوند عالم نےتمام فرشتوں کوحکم دیا کہ اس کا طواف کریں،پھر فرشتوں کوبھیجا کہ زمین میں ایک مکان اسی اندازکا اسی کے مانند بنائو اورجوجو زمین میں ہیں ان کو یہ حکم دیا کہ و ہ اس کا طواف کریں ۔ &&(تفسیر نورالثقلین)&& }} !!{{ حضرت امام علی رضا علیہ السّلام نے فرمایا:<< ’’الْبَيْتِ الْمَعْمُوْرِ۝۴ۙ ‘‘ >> میں روزانہ سترہزار فرشتے آتے ہیں اورجو ایک دفعہ آتا ہے اس کو پھر دوبارہ آنا نصیب نہیں ہوتا۔ << ’’الْبَيْتِ الْمَعْمُوْرِ۝۴ۙ ‘‘ >> ساتویں آسمان پر فرشتوں کا عبادت خانہ ہے جوکعبہ کے عین محاذ پر ہے۔ &&(تفسیر صافی ، ص۴۷۸، مجمع البیان)&& }} دوسری تفسیر:یہ ہے کہ << ’’الْبَيْتِ الْمَعْمُوْرِ۝۴ۙ ‘‘ >>  یعنی آباد گھر، سے مراد کعبہ یعنی بیت اللہ ہے۔ جوکبھی طواف کرنےوالوں،حج وعمرہ کرنے والوں سے خالی نہیں رہتا بلکہ ہروقت آباد رہتا ہے۔ &&( بقول حضرت امام علی علیہ السّلام ، ابن عباسؓ ،عکرمہ ، مجاہد، قتادہ ضحاک ابن زید در تفسیر کبیر، مجمع البیان )&& دونوں تفسیر یعنی ’’کعبہ‘‘ اور << ’’الْبَيْتِ الْمَعْمُوْرِ۝۴ ‘‘ >> جوساتویں آسمان پر آباد گھر ہے، دونوں مراد لیے جا سکتے ہیں ۔ یعنی خدا نےصرف زمین کے کعبہ ہی کی قسم نہیں کھائی ہے بلکہ دونوں خدا کےگھروں کی قسم کھائی ہے۔ وہ بھی جوزمین والوں سےآباد ہے اور وہ بھی جوآسمان والوں سے آباد ہے۔ &&(تفسیر کبیر، تفہیم)&&
  52,5,آیت نمبر ۵:<< ’’السَّقْفِ الْمَرْفُوْعِ۝۵ ‘‘ >> یعنی ’’اونچی چھت ‘‘ سے مراد آسمان ہے بلکہ پورا عالم بالا مراد ہے۔ &&(تفسیر کبیر)&&
  52,6,آیت نمبر ۶:<< ’’الْبَحْرِ الْمَسْجُوْرِ۝۶ ‘‘ >> کے کئی معنی ہیں۔(۱) آگ سے بھرا ہوا سمندر ۔ قیامت کےدن سمندر کا پانی زمین کے اندر چلا جائے گا اور سارے سمندر آگ سے بھرجائیں گے۔(۲) ’’رکا ہواسمندر‘‘ کیوں کہ خدا نے سمندروں کوزمین میں دھنس جانے سے بھی روک رکھا ہے اورخشکی پر پھیل جانے سے بھی روک رکھا ہے۔(۳) لبریز اورموجیں مارتا ہوا سمندر ۔&&(مفردات امام راغب)&&
  52,7,آیت نمبر ۷: مطلب یہ ہے یہ سارا نظام کائنات بزبان حال گواہی دے رہا ہے کہ اعمال کی جزاء سزاضرورمل کر رہے گی، اوراسی جزاء وسزا کے ملنے کا نام حشر ہے۔&&(تفسیر ماجدی)&& آیت میں عذاب کا ذکر ہے ۔اس لئے بدکاروں کوعذاب سے ڈرایا جا رہا ہے۔ کہ عذاب ضرور بالضرور واقع ہوگا۔
  52,8,آیت نمبر ۸ : << تَمُوْر>> کی اصل << مَوْر>> ہے۔ عرب میں مَوْر کے معنی گھومنا ،پھڑکنا، جھومنا، چکر کاٹنا ،باربار آگے پیچھے حرکت کرنا ہوتا ہے۔ قیامت کے دن آسمان کی یہی حالت ہوگی اورسارا نظام عالم تہ وبالا ہوجائے گا۔ &&(مفردات امام راغب)&&
  52,10,آیت نمبر ۱۰ : مطلب یہ ہے کہ قیامت کے دن زمین کی گرفت یا کشش اس قدر ڈھیلی یا کمزور پڑجائے گی کہ بڑے بڑے پہاڑ اپنی جڑوں سے اکھڑ کر بادلوں کی طرح فضائوں میں اڑتے پھرتے دکھائی دیں گے۔ &&(تفسیر کبیر)&& روز قیامت پہاڑ ریت کے ذرے بن کر ہوا میں اڑجائیں گے۔
  52,15,آیت نمبر ۱۵ : آیت کی تشریح: کفار وحی کے بارے میں یہ کہا کرتے تھے کہ یہ جادو ہے۔ لیکن اب جو جہنم کا ذکرآیا تو کہنے لگے کہ یہ بھی جادو ہی ہے۔&&(تفسیر صافی)&& محققین نے نتیجہ نکالا کہ حق کے منکر اورانکاری حقیقتاً حقائق پرسنجیدگی سے غور ہی نہیں کرتے بلکہ بے فکر اور بےاعتنائی ،بے خیالی اور بے پروائی کے ساتھ سرسری گزر جاتے ہیں۔&&( تفسیر ماجدی)&& دنیا میں جتنے پیغمبران منکرین حق کوسمجھاتے تھے اور جہنم یاد دلاتے تھے تو یہ احمق کہتے تھے کہ یہ سب الفاظ کی جادوگری ہے جس سے ہم کو بےوقوف بنایا جا رہا ہے۔ ہم کومعلوم ہے جنت کی حقیقت لیکن دل کے بہلانے کوغالب یہ خیال اچھا ہےاب لو یہ جہنم تمھارے سامنے ہے۔ اب بتائو ،یہ جادو ہے؟ الفاظ کا کرشمہ ہے؟ دل کا بہلاوا ہے؟ یا واقعاً بھڑکتی دہکتی آگ ہے؟ &&(تفسیرکبیر ،مجمع البیان ،تفہیم)&&
  52,16,آیت نمبر ۱۶: << ’’اِنَّما‘‘ >> کے لفظ سے شروع ہوتی ہے جوعرب گرامر کے اعتبار سے کلمہ حصر ہے جس کا مطلب یہ ہوتا ہے کہ تمھیں بس صرف اتنا ہی عذاب ہو رہا ہے جتنا تمھارا جرم ہے ،جسکے تم مستحق ہو، جرم سے زیادہ سزا نہیں دی جا رہی ہے۔ اس لیے اب تم اسے برداشت کرتے رہو۔ &&(تفسیرماجدی)&&
  52,18,آیت نمبر۱۸:محققین نے نتیجے نکالے کہ!!:(۱)کسی شخص کےجنت میں داخل ہو جانے کے بعد یہ فرمانا کہ: اسے جہنم سے بچا لیا گیا بظاہر عجیب سا معلوم ہوتا ہے مگر یہاں یہ بتانا مقصود ہے کہ دوزخ سے بچ جانا بجائے خود خداوندعالم کی ایک بہت ہی بڑی نعمت ہے۔(۲)دوسری بات یہ معلوم ہوئی کہ دوزخ سے بچنا صرف خدا ہی کی مہربانی سے ممکن ہے کیونکہ خدا نے خود فرمایا: ’’اللہ نے ان کو دوزخ سے بچالیا‘‘ یعنی دوزخ سے بچنا صرف اللہ ہی کے فضل وکر م سے ممکن ہے۔
  52,19,آیت نمبر ۱۹ : آیت کی تشریح!!:<< ’’ھَنِیٔ‘‘ >> ایسی چیز کوکہتے ہیں جوبغیر مشقت یا دشواری یا رکاوٹ کے حاصل ہو جائے اورخوشگواربھی ہو۔&&( مفردات امام راغب)&& جنت کی تمام نعمتیں صرف ارادہ کرتے ہی مل جائیں گی ،جیسا کہ خود خداوندعالم نے فرمایا:<< ’’لَہُمْ فِيْہَا مَا يَشَاۗءُوْنَ۝۰ ‘‘ >> &&(سورہ نحل آیت ۳۱)&& یعنی @@ان کیلئے وہاں پروہ چیز موجود ہوگی جسے وہ چاہیں گے‘‘۔ @@ گویا خدا انسان کے اندر وہاں اپنی صفت کن فیکون کی ادنیٰ سی جھلک پیدا کردیگا کہ بندہ جیسے ہی جوچیز چاہے گا اس کے سامنے فوراً بلا کسی کوشش ،مشقت یا رکاوٹ کے حاضر ہوجائے گی۔ [[ خودی کو کربلند اتنا کہ ہرتقدیر سے پہلے خدا بندے سے خود پوچھے بتا تیری رضا کیا ہے ]] اقبال &&( مؤلف)&& یہا ں ’’مزے‘‘ کا لفظ اپنے اندربہت گہر ا اوروسیع معنی رکھتا ہے ۔ جنت کے مزے دنیا کے مزوں سے بہت زیادہ اعلیٰ اور وسیع ہوں گے۔!! (۱) جنت میں جونعمتیں ملیں کی وہ دنیا کی نعمتوں سےبہت اعلیٰ ہوں گی۔ خدا فرماتا ہے کہ وہاں ایسی ایسی نعمتیں ہوں گی جن کو نہ کسی آنکھ نے دیکھا ہوگا نہ دلوں نے سوچا ہوگا۔(۲) جنت کی نعمتیں نہ کم ہوں گی ،نہ ختم ہوں گی ،نہ ضائع ہوں گی، نہ کوئی چھینے گا۔(۳) وہاں نعمتوں کا کوئی حساب کتاب نہ ہوگا۔ (۴) خواہش کے مطابق ہوں گی۔ (۵) عزت و احترام سے ۔(۶) کھانے صرف لذت حاصل کرنے کیلئے ہوں گے۔(۷) ہدہضمی نہ ہوگی۔(۸) صاف ستھری ہوں گی۔ وغیرہ وغیرہ ۔ &&(تفسیر کبیر، مجمع البیان ،تفہیم ،تفسیر نمونہ)&&
  52,20,آیت نمبر ۲۰ : << ’’مُتَّكِـــِٕيْنَ‘‘ >> : یعنی تکیہ لگا کر بیٹھنا ۔ یہ سکون و اطمینان عزت اور خوشی کی تعبیر ہے کیونکہ انسان تکیہ لگا کراسی وقت بیٹھتا ہے جب پر سکون ہوتا ہے عزت دینے کیلئے بٹھایا جاتا ہے۔ << ’’حُوْر‘‘ >. جمع ہے << حَورَاء >> کی ۔ حور اس خوبصورت عورت کوکہتے ہیں جس کی آنکھیں خوب کالی ہوں مگر پوراجسم گورا ہو۔ یہ کنایہ ہے بہت زیادہ خوبصورت عورت کا، کیوں کہ خوبصورتی کا آنکھوں سے بہت گہرا تعلق ہوتا ہے۔ &&(مفردات امام راغب)&&
  52,21,آیت نمبر۲۱:مومن کی اولاد بھی فائدے حاصل کرے گی:{{ فرزند رسول خدا  صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ اگرکوئی مومن (اپنے ایمان وعمل کی وجہ سے ) درجے میں بڑھا ہوا ہوگا جبکہ اس کی اولاد اس سے کم مرتبہ ہوگی، توخداوند کریم و رحیم اس کی اولاد کے درجے بڑھا بڑھا کرمومن کی اولاد کومومن سے ملادے گا، تا کہ اس مومن کی آنکھیں ٹھنڈی رہیں۔ سبحان اللہ وبحمدہ، &&(تفسیر صافی ص۴۷۸) && }} !!ایک دوسری تفسیر یہ بھی ہے کہ :’’جو لوگ ایمان لائے اور ان کی اولادیں نا بالغ مرگئیں( یعنی ان کوعمل صالح کمانے کا موقع ہی نہ ملا) وہ بچے بھی اپنے ماں باپ سے ملادیے جائیں گے ۔ &&(ابن جریر)&& مگرزیادہ سلجھا ہوا مطلب یہ ہے کہ اگربالغ اولاد اپنے باپ دادا کےنیک راستےپر چلی ،مگرعمل صالح کے اعتبار سے اس درجہ کمال تک نہ پہنچ سکی توباپ داداؤں کے حسن عمل کی وجہ سے اولاد کی کمزوریوں کونظرانداز کردیاجائے گا اوران کےمرتبے بڑھادیے جائیںگے ۔ بغیر باپ دادا کے مرتبوں کوگھٹائے۔ &&(تفیسر تبیان ۔بقول ابن عباسؓ)&&غرض بہت سے افراد ایسے ہوں گے کہ ان کا نیک عمل کمزور ہوگا ،درجات عالیہ کے قابل نہ ہو گے ،جبکہ ان کے والدین بلند مرتبوں پرہوں گے ،خدا ان لوگو کے نیک والدین کےاحترام میں ان کی اولادوں کوان کے بلند درجات تک پہنچادےگا۔&&( تفسیر ماجدی)&& !!{{ روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’ جب قیامت کا دن ہوگا، توخداوند حکیم ان سب کوجمع کرے گا اورایک آگ روشن کرے گا، اورانھیں(اولادوں بچوں کوپوری عقل دے کر) حکم دے گا کہ خودکوآگ میں گرادیں‘‘۔ جواس حکم پر عمل کرے گا ( اورآگ میں کودجائے گا) توآگ اس کے لئے سرد ہوجائے گی۔ اوروہ صحیح وسالم رہے گا، مگر جوحکم نہ مانے گا،وہ خدا کی مہربانیوں سے محروم رہے گا۔&&(تفسیر نورالثقلین جلد۵،ص۱۳۹)&& }} !!{{ ابن عباسؓ سےروایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نےفرمایا:جس وقت انسان جنت میں داخل ہوگا تواپنے والدین بیوی بچوں کے بارے میں پوچھے گا ،توا سے کہاجائے گا وہ تیرے درجے مقام اورعمل تک نہیں پہنچ سکے۔ وہ عرض کرے گا مالک !میں نےجونیک اعمال کیے تھے وہ ان کے لیے بھی کیے اوراپنے لئے بھی۔ پس حکم دیا جائے گا کہ : ’’ان کوبھی اس کے ساتھ ملادو‘‘ ۔ &&(تفسیر مراغی ھلد۲۷ ص۲۶ انوارالنجف)&& }} گروی: خدا کا فرمانا کہ : ہرشخص اپنے اعمال کے بدلے گروی ہے ۔ یعنی اچھے اوربرے اعمال کے بدلے گروی ہے۔{{ جناب امیرالمومنین علیہ السّلام نے فرمایا:’’ وہ قبروں میں رہن اورلحدوں میں سونے والے ہیں‘‘۔&& ( نہج البلاغہ خطبہ ۴۵)&& }} !! آیت سے ثابت ہوا کہ ہر شخص کے اعمال نیک وبد ہمیشہ اس کےساتھ ساتھ رہیں گے۔&&(تفسیر نمونہ)&& {{ یہ آیت محمد وآل محمد  صلی اللہ علیہ و آلہ وسلم کے حق میں اتری: فرزند رسول خداؐ حضرت امام محمدباقرعلیہ السّلام سے منقول ہے کہ جب قیامت قائم ہوگی توجانب عرش سےایک منادی ندا کرے گا کہ اے لوگو! اپنی اپنی آنکھیں بند کرلو تا کہ جناب فاطمہ علیہا السّلام بنت محمد  صلی اللہ علیہ و آلہ وسلم گزرجائیں‘‘۔ پس آپ علیہ السّلام جنت کے لباس میں ملبوس ہوں گی بارہ ہزار حوران جنت ان کا استقبال کریں گی جن کے پیچھے پچاس ہزار ملائکہ مرصع اور مسجع عمدہ سوارہوں گے۔ پس ایسے ماحول میں شہزادی کونین علیہا السّلام صراط سے گر کر جنت فردوس میں داخل ہوں گی پھر نور کے تخت پر جلوہ گرہوں گی، آپ کے اطراف حوران جنت ہوں گی۔ زیر عرش دومحل ہوں گے ایک سفید جس میں ستر ہزار عالی شان محل وبنگلے ہوں گے جن میں محمد  صلی اللہ علیہ و آلہ وسلم وآل محمد علیہ السّلام کی رہائش ہوگی۔ اوردوسرامحل زرد جس میں ستر ہزار قصر وبنگلے حضرت ابراہیم اورآل ابراہیم علیہ السّلام کےلیے مخصوص ہوں گے پس ایک فرشتہ جانب پروردگار شہزادی کونین علیہا السّلام کی طرف سلام پہنچائے گا اورعرض کرے گا کہ خداوند کریم ورحیم کا ارشاد ہے کہ جوکچھ طلب کرو میں دنیے کےلیے تیارہوں۔ شہزادی کونین علیھا السّلام عرض کریں گی کہ میں اپنی اولاد اورحبداروں کی شفاعت کی طالب ہوں۔ پروردگار کا ارشاد ہوگا کہ تمھاری شفاعت مقبول ہے۔ پس شہزادی کونین علیہا السّلام پروردگارعالم کی حمد بجالائیں گی۔ یہ حدیث بیان فرما کر امام محمد باقرعلیہ السّلام نے اسی آیت مجیدہ کی تلاوت فرمایا کرتےتھے۔ &&(تفسیر انوارالنجف)&& }} !!{{ محمد بن مسلم کہتا ہے کہ فرزندان رسول  صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق اور امام محمد باقرعلیہ السّلام سے میں نے سناکہ خداوند کریم نے امام حسین علیہ السّلام کی شہادت کے صلہ میں چار انعامات عطا فرمائےہیں۔(۱)ان کی اولاد میں امامت(۲) ان کی تربت میں شفاء(۳) ان کی قبر کے پاس دعاء کا قبول ہونا۔(۴) جوشخص ان کی زیارت کوجائے توآمدورفت کا زمانہ اس کی عمر میں شمار نہیں ہوتا۔ میں نے عرض کیا : حضوروالا علیہ السّلام ! یہ چیزیں توامام حسین علیہ السّلام کے صدقے میں دوسروں کوملیں گی ،لیکن خود ان کوکیا ملا؟ امام علیہ السّلام نے فرمایا:’’ان کواپنے جدنامدار کے ساتھ ملادیاپس وہ رسول اللہ  صلی اللہ علیہ و آلہ وسلم کے پاس ان کے درجہ میں ہوں گے۔ پھرامام علیہ السّلام نے اسی آیت کوپڑھا۔<< ’’ اَلْحَـقْنَا بِہِمْ ذُرِّيَّتَہُمْ۔۔۔۔الخ‘‘ >> &&(برہان ،امالی شیخ ، انوارالنجف)&& }} جب انسان پرموت کاوقت آتا ہے!!:{{ فرزند رسول خدا  صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے :’’ جب انسان پر موت کاوقت آتا ہے توسب سے پہلے اس کا مال اس کے سامنے مجسم ہوکرآتا ہے ۔وہ مال سے کہتا ہے کہ آج مجھ پر سب سے سخت وقت پڑا ہے۔ بتا تو میرے کیا کام آئے گا؟‘‘ مال کہتا ہے کہ میں تمھارے لیے تمھارا کفن اورقبر کا انتظام کرسکتاہوں۔ مرنے والامایوس ہوکر دوسری طرف دیکھتا ہے تواس کی اولاد مجسم ہوکراس کے سامنے آتی ہے۔ وہ کہتا ہے کہ تم بتاؤ اس کٹھن وقت میں تم لوگ میرے کیا کام آسکتے ہو؟ اولاد کہے گی کہ ہم آپ کواپنے کاندھوں پرسوارکرکے آپ کی قبرتک پہنچادیں گے۔ مرنے والاپھر مایوس ہوکرادھر اُدھر دیکھنےلگتا ہے تواسے ایک نہایت حسین وجمیل شخصیت قریب آتی ہوئی نظرآتی ہے جوآکر اس کابازو تھام لیتی ہے اورکہتی ہے کہ نہ گھبراؤ میں قبرمیں نشرمیں حشر میں،میزان میں آپ کاساتھ دوں گی۔ یہاں تک کہ آپ کوجنت کے دروازے تک پہنچادوں گی۔ مرنے والاحیران ہوکر اس سے پوچھتاہے کہ تم کون ہو؟ وہ شخص کہتاہے : میں آپ کاغیر نہیں ہوں (حیران نہ ہوں) میں آپ کا وہی نیک عمل ہوں جسے آپ بڑی کراہت کے ساتھ انجام دیا کرتے تھے۔&&(الکافی)&& }} اس وقت مرنےوالا سمجھتا ہے کہ اصل ساتھی صرف اس کے اعمال نیک وبد ہیں اوراصل دولت صرف نیک اعمال بجالاناہے۔&&(مؤلف)&& << رَہِيْنٌ >> کے معنی: خداوندعالم کا فرماناـ:’’ ہرشخص اپنی کمائی (عمل) کے عوض رہن ہے۔ یہ بڑامعنی خیز جملہ ہے ۔اگرہم کسی سے کچھ قرض لیں توقرض دینے والا کوئی چیز رہن رکھ لیتاہے ۔وہ ہمیں اس ووقت واپس ملتی ہے جب ہم(قرض لینےوالے) قرض اداکردیتے ہیں۔خداوندعالم نےانسان کوجودنیا کی نعمتیں اور زندگی کی نعمتیں ،صلاحیتیں اوراختیارات دیے ہیں وہ سب خدا کا دیا ہوا قرضہ ہے اورہماری جان(نفس) خدا کے پاس رہن ہے۔ اگرہم خد اکی قرض دی ہوئی دنیا کی نعمتوں کوخدا کی مرضی کے مطابق استعمال کرتے ہیں توہم اپنی رہن شدہ جان کوجہنم سے چھڑا لیتے ہیں، اگرہم خدا کی قرض دی ہوئی دنیا کی نعمتوں کوخدا کی مرضی کے خلاف استعمال کرتے ہیں توہماری جان ضبط کرلی جائےگی اورجہنم رسید کردی جائے گا۔ ہرشخص اپنی جان اپنے فرائض اداکرکے اورحرام کاموں سےبچ کرچھڑاسکتا ہے ۔پہلے اولاد اپنی جان اپنے نیک اعمال کے ذریعہ چھڑائےگی ۔اب اگر جان چھڑانے کے بعد اولاد کادرجہ باپ داداسے کم رہا، توپھر خدافضل وکرم شامل ہوگا، پھرخدا اپنے فضل وکرم کی وجہ سے کم درجہ اولادوں کو اٹھاکر جنت کے اعلیٰ درجوں میں ان کے باپ داداؤں کے ساتھ ملادے گا۔ یعنی باپ دادا کی نیکیوں کا فائدہ اولاد کوصرف اس وقت ملے گاجب پہلے وہ اپنی جان جہنم سے چھڑا لیںاور خود کوجنت میں داخل ہونےکا مستحق بنالیں۔ یہ نہیں ہوگا کہ اولاد جہنم کی مستحق ہواوراسے باپ دادا کی نیکیوں کی وجہ سے جنت کے بلند درجوں میں پہنچا دیا جائے۔ ہاں اگر جنت میں جانے کا مستحق خود کو بنا لیا،تب اولادکوباپ داداکی کمائی کی وجہ سے بلند درجات مل جائیں گے ،تاکہ باپ دادا کا دل خوش کر دیا جائے۔ خداوند عالم کافضل وکرم یہ گوارانہ کرے گا کہ باپ دادا کے درجے کم کرکے ان کی اولادوں سے ان کوملادے، تاکہ باپ داداکوخوشی حاصل ہواور خوشی میں اضافہ پراضافہ ہواوران کی آنکھیں ٹھنڈی رہیں۔ &&(تفسیر کبیر، مجمع البیان ،تفسیر نمونہ ،تفہیم)&&
  52,23,آیت نمبر ۲۳ : آیت کا مطلب یہ ہےکہ:جنتی لوگ جنت کی شراب پی کربہکیں گے نہیں ۔ کسی قسم کی کوئی فضول لغویاغلط بات ان کے منہ سے نہ نکلے گی اورنہ کوئی غلط کام کریں گے۔ نہ اول فول بکیں گے جیسے کہ دنیا کےشرابی شراب پی کر بکا کرتے ہیں ۔ اسی طرح خداوندعالم نے قرآن مجید میں یوں ارشاد فرمایا: ’’ (اس جنت کی)شراب کو پی کرنہ کوئی جھگڑا ہوگا، نہ مدہوشی ہوگی۔&&(سورہ صافات آیت ۴۷ پارہ ۲۳)&& &&(تفسیر صافی)&& !!اصل میں دنیا میں جو چیز بھی حرام ہے وہ اپنی کسی نہ کسی برائی کی وجہ سے حرام ہے ۔ کیونکہ جنت والی شراب میں کسی قسم کی کوئی برائی یا نقصان موجود ہی نہ ہوگا اس لئے اس کا پینا گناہ نہ ہوگا۔ جنت کی ہرچیز میں سے نقصان یا خرابی کا پہلو ہی نکال دیا جائے گا اسی لئے وہاں کی شراب پینے والوں میں وہ کوئی خرابی پیدا ہی نہ ہوگی جودنیا کی شراب پینے والوں میں پیدا ہوجاتی ہے۔ وہاں کی شراب میں صرف کیف ،لطف ،مسرت ،شادابی ‘سکون اوربلاکی لذت ہوگی اور بس ۔ اس لئے جنت کے شرابیوں کیلئےخداوند عالم نےفرمایا کہ ان میں نہ کوئی جھگڑا ہوگا، نہ فساد اورنہ وہ ایک دسرے کوگناہگار ٹھہرائیں گے۔ &&(فصل الخطاب)&& << ’’كَاْسً‘‘ >> شراب سے بھر ے پیالے کو کہتے ہیں (فارسی میں اس کوساغر کہتے ہیں) &&(مفردات امام راغب)&&
  52,24,آیت نمبر ۲۴:چوتھی نعمت جنتیوں کیلئے نوجوان خادم (غلمان) ہوں گے ، جو ہر دم جوان رہیں گے موتیوں جیسے خوبصورت ،چمکدار جیسے صدف کے اندر گوہر ، وہ غلمان ہر طرف گھوم گھوم کران کی خدمت کر رہے ہوں گے ،اگرچہ جنتیوں کو خدمتگاروں کی ضرورت ہی نہ ہوگی، اس لئے کہ وہاں کا اصول توبہ ہے کہ وہ جوچاہیں گے آ موجود ہوگا،مگر یہ ان کا احترام ہے کہ ان کے خدمتگار ان کے چاروں طرف دوڑ بھاگ رہے ہوں گے۔&&(تفسیر نمونہ)&&
  52,25,آیت نمبر۲۵:جنتی کہیں گےکہ:جنتیوں کا ایک دوسرے سےیہ کہنا کہ :’’ ہم اپنے گھروالوں کے درمیان بھی خوف وہراس میں تھے۔ یعنی ہمیں(۱) ظالموں، جابروں، سرکشوں، کافروں،مشرکوں کاخوف رہتاتھا۔ پھر ہمیں اپنے گناہوں اور اپنی قوم کے گناہوں کی وجہ سے عذاب خدا کے آنے کا خوف ہروقت ستاتا رہتا تھا۔ مگرخداوند کریم نے ہم پراحسان فرمایا کہ ہمیں اپنے ہرقسم کے عذاب یا سزا سے بچا لیا۔&&(تفسیر نمونہ)&& جنتیوں کے اس جملے سے معلوم ہوا کہ جنتی دنیا میں جابر ،قاہر ،ظالم کے روپ میں نہیں ہوتے ۔عام طورپر وہ مظلوم ،ستائے ہوئے، خوفزدہ رہنےوالے ہوتے ہیں، برے لوگوں کے شرسے ہمیشہ خائف رہتے ہیں،مگراس کا مطلب یہ بھی نہیں ہے کہ وہ بالکل نرم چارہ ہوتے ہیں حتی الامکان وہ اپنے اندر اتنی طاقت پیدا کرتے رہتے ہیں کہ ظلم وجبر ،کفر وشرک کا مقابلہ کرسکیں لیکن اس کے باوجود خدا کے عذاب اورناراضگی سے ضرورہر وقت خائف رہتے ہیں۔&&(مؤلف)&& تیسرا خوف ان کویہ ہوگا کہ کہیں دنیا کی چکاچوند ان کواوران کی اولادوں کو گمراہ نہ کردے اسی لیے جنتیوں نے بعد میں فرمایا کہ :’’ خدا نے ہم پراحسان فرمایا اور تباہ کردینے والے عذاب سے ہمیں بچا لیا۔&&(تفسیر نمونہ)&& یہ بھی ممکن ہے کہ یہ آیت ان جنتیوں کے بارے میں ہو، جوغیر مومن گھرانوں میں پیدا ہوئے ، خود اسلام لائے اورہمیشہ ڈرتے رہے کہ ان کواسلام اورایمان کی وجہ سے قتل نہ کردیاجائے۔ مگر خدا کی مدد کی امید لیے ہوئے ایمان پرڈٹے رہے۔ &&(تفسیر کبیر امام رازی) && مطلب یہ ہے کہ ہم دنیا میں عیاشی کی غفلت والی زندگی نہیں گزار رہےتھے بلکہ ہمیں ہروقت یہ دھڑکا لگا رہتا تھا کہ کہیں ہم سے کوئی ایسا کام سرزد نہ ہوجائے جس پر خدا کے ہاں ہماری پکڑہو۔ گھرمیں ہم اس لے ڈرتے تھے کہ کہیں اولاد کوعیش کرانے یا ترقی دلانے کے چکرمیں ہم حرام کی کمائی تک نہ پہنچ جائیں، دوسروں کے حقوق نہ مارنے لگیں، طر ح طرح کی ناجائز تدبیریں نہ کرنے لگیں، ہم کوئی ایسا کام نہ کربیٹھیں کہ ہماری آخرت تباہ ہوجائے۔ پھرہمیں اپنی اولاد کے بدعمل ہونے یا خراب ہونے کا بھی خوف رہتا تھا۔ اس لیے ہم ان کی دیکھ بھال کرتے تھے اورنیک تربیت کرنے میں لگے رہتے تھے۔ &&(تفسیر مجمع البیان ،تفہیم ،تفسیرنمونہ، تفسیرانوارالنجف)&&
  52,27,آیت نمبر۲۷:<< سَمُوْمِ >> :اس گرمی کی شدت کوکہتے ہیں جو جسم کےاندر مساموں ( یعنی ) چھوٹے چھوٹے سوراخوں تک میں داخل ہوجاتی ہے اورانسان کوسخت تکلیف پہنچاتی ہے۔<< ’’سم‘‘ >> کا لفظ ہلاک کردینے والی چیز پر بھی بولاجاتا ہے یعنی مار ڈالنے والی گرمی۔ &&(لسان العرب، لغات القرآن)&& اس سے مراد لو کی وہ لپ ہیں جوجہنم سےاٹھ رہی ہوں گی۔ &&(تفسیر کبیر)&& << ’’سموم‘‘ >> دوزخ کے خاص بہت ہی سخت گرم حصے کوکہتے ہیں ۔ &&(مجمع البیان بقول حسن)&&
  52,28,آیت نمبر ۲۸:آیت کی تشریح:<< ’’بَرُّ‘‘ >> کے اصل معنی خشکی کے ہیں۔ دوسرے معنی میں یہ لفظ ان لوگوں کیلئے بولا گیا جن کے نیک اعمال بہت زیادہ وسیع ہوں ظاہر ہے کہ اس << ’’بَرُّ‘‘ >> کا سب سے اعلیٰ اوربہترین مصداق خدا کی ذات ہے کہ اس کا فیض ہر طرف پھیلا ہوا ہے، یہاں تک کہ تمام جہانوں کوگھیرے ہوئے ہے۔&&(مفردات امام راغب)&& غرض ان آیتوں میں جنت کی چودہ نعمتیں بیان کی گئی ہیں !!:(۱)جنت کے گھنے سرسبز و شاداب باغات۔(۲) جنت کی بے حد و بے حساب نعمتیں۔(۳) دائمی سرمدی لطف و کیف۔(۴) عذاب جہنم سے امن پانے کا احساس اورخوشی۔(۵) جنت کے کھانے پینے کی بے پناہ مزے دار چیزیں۔(۶) مومنین کا ایک دوسرے سے پرسکون حالت میں مل کر باتیں کرنا۔(۷) حوروں جیسی بے حد خوبصورت بیویاں ۔(۸) مومن کے گھروالوں اور اولادوں کا ایک جگہ ساتھ رہنا۔(۹) لاکھوں قسم کے بے حد تازہ مزے دار میوے اور پھل۔(۱۰) ہرقسم کےبے حد تازہ مزے دار پرندوں کے بھنے ہوئے گوشت۔(۱۱) شراب طہور کے پرلطف جام۔(۱۲) موتیوں جیسے خوبصورت خوشنما سرگرم خادم (غلمان)(۱۳) ماضی کی حسین یادیں ۔(۱۴) جنت کی موجودہ حالت سے خوب اچھی طرح لطف اندوزی۔ یاد رہے کہ یہ جنت کی تمام نعمتوں کا بیان نہیں ہے۔ یہ صرف چند مادی نعمتوں کا قدر ے بیان ہے ان کے علاوہ روحانی معنوی نعمتیں بھی ہیں جن کی کوئی حد ہے نہ حساب۔ &&(تفسیر نمونہ)&&
  52,29,آیت نمبر۲۹:قریش مکہ کی انتہائی جہالت کا ذکر!!:قریش مکہ جب رسول خدا  صلی اللہ علیہ و آلہ وسلم سے آخرت کی باتیں‘ حساب و کتاب کے وعدے، جہنم کے ڈراوے سنتے تو انھیں بڑاغصہ آتا تھا ، کیونکہ جہنم کے ڈراوے انھیں تمام صفات پر تھے جوان میں بدرجہ اتم پائے جاتے تھے، گویا رسول  صلی اللہ علیہ و آلہ وسلم کے کلمات انھیں جہنمی ثابت کرتے تھے، اس لیے جل کرسول  صلی اللہ علیہ و آلہ وسلم کو مجنون یعنی پاگل کہہ کردل ٹھندا کرلیا کرتے تھے۔آج کے مغربی مفکرین بھی یہ لکھتے ہیںش کہ (معاذاللہ) رسول  صلی اللہ علیہ و آلہ وسلم پر صرع Epilepcy کے دورے پڑتے تھے انہی دوروں کے درمیان جو کچھ آپ کے منھ سے نکلتا تھا اس کوقرآن یا وحی کہتے ہیں، آج کوئی بھی آدمی قرآن کو سمجھ کر پڑھے تو وہ واضح طورپر سمجھ سکتا ہے کہ اتنے گہر ی بامعنی الفاظ کسی صرع کے دورہ پڑنے والے کی بے معنی بک بک سے کتنے مختلف اورکتنے اعلیٰ ہیں۔ مگر بے شرمی اورتعصب کی یہ انتہا ء ہے کہ ایسے با معنی بلند ترین بے مثل کلام کو صرع کے دورے کی بکواس قرار دیا جائے۔ &&(تفسیر کبیر، تفہیم ،تفسیر نمونہ)&& [[ انسان اس طرح اترآیے عنادپر۔ لعنت خداکی حشرتک ابن زیاد پر]] ۔شان نزول:یہ ہے کہ قریش دارالندوہ (عربوں کے جد اعلی قصی بن کلاب کا گھر جہاں وہ مشوروں کیلیے جمع ہوتے تھے) میں جمع ہوئے تا کہ جناب رسول خدا  صلی اللہ علیہ و آلہ وسلم کی تحریک اسلام کوکسی طرح ختم کردیں۔ بنی عبدالدار کے قبیلہ کے ایک شخص نے کہا: ہمیں محمد  صلی اللہ علیہ و آلہ وسلم کے مرنے کا انتظار کرنا چاہئیے ۔کیونکہ شاعر جلد مرجاتے ہیں۔ جیسا کہ زہیر ،نابغہ ،اعشی، (زمانہ جاہلیت کے بڑے بڑے شاعر) جلد مرگئے ۔ (اسی طرح معاذاللہ محمد  صلی اللہ علیہ و آلہ وسلم کی بساط بھی جلدالٹ جائے گی) اس مشور ے پرسب مطمئن ہوگئے۔ان کے جواب میں یہ آیت اتری۔&&( تفسیر مراغی جلد۲۷)&& محققین نے لکھا کہ:اس آیت میں خدا کا فرمانا :<< ’’فَذَكِّرْ‘‘ >> @@ (پس نصیحت کرو) @@۔(۱) اس سے معلوم ہوا کہ پچھلی تمام آیات میں جنتیوں اور جہنمیوں کا حال بیان کیا گیا ہے۔ اس کا اصل مقصد یہ تھا کہ ان کے دل حق کوسننے سمجھنے اوراصلاح کرنے پرآمادہ ہوں۔ (۲) قریش جناب رسول خدا  صلی اللہ علیہ و آلہ وسلم کو کاہن بھی کہتے تھے اورمجنون بھی۔ یہ دونوں القاب بتا رہے ہیں کہ وہ کس قدر جھوٹے تھے،اس لیے کہ ’’کاہن‘‘ یعنی آئندہ کی خبریں بتانے والا انسان توبلا کا مکار اورچالاک ہوتا ہے ،وہ اڑتی چڑیا کے پرگن لیا کرتا ہے جبکہ ’’مجنون‘‘ بے عقل ،حواس باختہ ہوتا ہے۔ اب بیک وقت کسی کوکاہن بھی کہہ رہے ہیں اورمجنون بھی۔ یہ متضاد باتیں خود بتا رہی ہیں کہ وہ جھوٹے ہیں۔ ]]دروغ گو را حافظہ نباشد[[&&(تفسیر نمونہ)&& کاہن: شیخ مرتضیٰ انصاری نے علامہ حلیؒ کے حوالے سے ’’کاہن‘‘ کے معنی یہ لکھے ہیں: ’’ جوکسی جن کواپنا مددگار بنا لیتا ہے اوراس کے ذریعہ سے چھپی ہوئی آئندہ کی باتیں اورخبریں حاصل کرلیتا ہے ،اورپھر لوگوں کوسناتا پھرتا ہے۔قرآن کی دوسری آیتوں سے بھی یہ بات معلوم ہوتی ہے کہ کاہن جنوں سے تعلق قائم کرلیتا ہے۔ &&(فصل الخطاب)&&
  52,30,آیت نمبر۳۰:<< ’’مَنُوْنِ‘‘ >> کے معنی:رات دن کا گزرنا ، وقت کا گزرنا۔&&(مفردات امام راغب ،لسان العرب) && مطلب یہ ہے کہ وقت کے گزرنے کے ساتھ ساتھ محمد  صلی اللہ علیہ و آلہ وسلم مرجائے گا اوراس کی شاعری کا دفتر اوردوسرے شاعروں کی طرح لپیٹ کررکھ دیا جائےگا۔&&(تفسیر نمونہ)&& << ’’مَنُوْنِ‘‘ >> کے دوسرے معنی ابن عباسؓ نے بتائے، یعنی ’’حوادث روزگار‘‘ یعنی زمانے کا کوئی حادثہ اس مارکرچھٹی کرے گا۔ &&(تفسیر قرطبی جلد۹)&& قریش مکہ کے کہنے کا مطلب یہ تھا کہ ہم اس بات کا انتظار کررہے ہیں کہ محمد  صلی اللہ علیہ و آلہ وسلم شاعر پر ’’ معاذاللہ‘‘ کوئی آفت آئے جوشاعروں پر عشق کے چکر میں بہت جلد آہی جایا کرتی ہے کیونکہ یہ شاعر ہے کسی نہ کسی سے محبت کے چکر میں ضرور پھنسے گا پھرکوئی قبیلہ ضرور اسے قتل کردے گا ہم تو بس اس بات کا انتظار کررہے ہیں کہ کسی طرح ہماری جان اس سے چھوٹ جائے۔(۲) دوسرا خیال ان کا یہ تھاکہ یہ شخص (رسول  صلی اللہ علیہ و آلہ وسلم) ہمارے خدائوں کوبرا بھلا کہتاہے ان پر تنقید کرتا ہے اس لئے ہمارے کسی نہ کسی دیوتا کی ماراس پر ضرورپڑے گی، یا پھر………(۳) کوئی دل جلا بت پرست ان کی باتیں سن کر آپے سے باہر ہوجائے گا اوران کا کام تمام کردے گا۔(معاذ اللہ) &&(تفسیر کبیر، تفہیم ،مجمع البیان)&& [[ تھی خبر گرم کہ غالب کے اڑیں گے پرزے ۔ دیکھنے ہم بھی گئے تھے، پہ تماشا نہ ہوا]]
  52,31,آیت نمبر ۳۱:آیت کی تشریح:خداوندعالم نے رسول  صلی اللہ علیہ و آلہ وسلم سے کافروں کو یہ جواب دلوایا کہ اے کافرو! تم رسول  صلی اللہ علیہ و آلہ وسلم کی موت کا انتظار کر رہے ہو، ہم تمھارے اوپر عذاب الٰہی آنے کا انتظار کر رہے ہیں۔ ہم خدا کے دین کے عالم گیر ہونے کا انتظار کررہے ہیں، تم اپنے خیالات ،جھوٹی خواہشات پر تکیہ لگائےہوئے ہو، اور ہم خدا کے لطف و کرم پر بھروسہ کیے ہوئے ہیں۔ &&(تفسیر نمونہ)&& معلوم ہوا کہ خدا کے لطف و کرم عنایت اورمہربانی پر تکیہ کیے ہوئے خدا کے کسی نمائندہ کا انتظار کرنا کہ وہ آئے اوردین اسلام کوعالمگیر فتح سے ہمکنار کرے، سنت رسول  صلی اللہ علیہ و آلہ وسلم بھی ہے اورحکم بھی ہے۔ اس لیے {{ فرزند رسول  صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام نے فرمایا:’’ افضل ترین عبادتوں میں سے یہ بھی ہے کہ انسان خدا کی طرف سے << ’’فرج‘‘ >> یعنی خوشی کا انتظار کرے << (اَفْضَلُ الْعِبَادَۃِ اِنتِظَارُ الْفَرَجِ) >. &&(تحفہ العقول)&& [[ کبھی اے حقیقت منتظر نظرآ لباس مجاز میں کہ ہزاروں سجدے تڑپ رہے ہیں مری جبین نیاز میں ]] ۔(اقبال)۔ [[ مجذوب فرنگی نے بانداز فرنگی۔مہدی علیہ السّلام کے تخیل سے کیا زندہ وطن کو۔اے توکہ ہے مہدی علیہ السّلام کے تخیل ہی سے بیزار۔محروم نہ کر آہوئے مشکین سے ختن کو]] ۔(اقبال)
  52,32,آیت نمبر۳۲:خداوند عالم کے دوالفاظ کا کمال:خداوندعالم کے ان دولفظوں نے اسلام کے مخالفین کے پروپیگنڈے کی ہوا نکال کربرہنہ کردیا، اس لیے کہ :(۱) قریش کے سردار بڑے عقلمند بنے پھرتے تھے۔ خدا ان سےپوچھ رہا ہے کہ : کیا تمھاری عقل یہی کہتی ہے کہ جس شخص میں شاعر کی ایک صفت بھی نہیں ہےاس کو شاعرکہتے پھرو، جس کلام میں سراسر عقل ہی عقل ہواس کلام کےلانے والے کو پاگل کہو، جس انسان کوساری دنیا سب سےزیادہ عقلمند انسان کہے اس کومجنون کہتے پھرو۔ جس کی باتوں سے کہانیت کی باتوں اور گول مول فقروں سے دور کا بھی کوئی تعلق نہ ہوا س کوکاہن کہو، جس کےانداز و اطوار میں کہیں کوئی جادوگر کی صفات نہ دکھائی دیں اس کوجادوگر کہتے ہو۔ پھریہ کہ کاہن کے جملے فقرے انداز ،بیان سب الگ ہوتے ہیں اور شاعر کے الگ اور پاگل انسان کے الفاظ اور تیورسب الگ ہوتے ہیں۔ تم ایک وقت میں ایک ہی آدمی کوشاعر بھی کہہ رہے ہو، کاہن بھی کہہ رہےہو اورپاگل بھی کہتے پھرتے ہو۔ آخرمیں فرمایا کہ تم خوب سمجھتے ہو کہ ہمارارسول  صلی اللہ علیہ و آلہ وسلم نہ شاعر ہے ،اورنہ کاہن ہے نہ پاگل ہے۔ اصل بات صرف یہ ہے کہ تم حق دشمنی اورحسد میں حد سے گزر ے ہوئے لوگ ہو۔ اسی حق دشمنی ،حسد اور تکبر کے جوش میں تم متضاد باتیں کر رہے ہو، غصے میں عقل سے اندھے ہوکربے سروپا الزامات لگا رہے ہو۔ خود تمھارے الزامات اس قدر احمقانہ اورواضح طوپرغلط ہیں کہ کوئی سمجھدار آدمی ان کوقابل توجہ نہیں سمجھ سکتا۔ &&(تفسیر کبیر، مجمع البیان، تفہیم، تفسیر نمونہ ،انوارالنجف)&&
  52,33,آیت نمبر ۳۳: آیت کی تشریح:!!خداوند عالم کا یہ جملہ کس قدر چبھتا ہوا ہے کہ :’’اصل بات یہ ہے کہ یہ لوگ ایمان ہی لانا نہیں چاہتے‘‘۔’’ جب انسان پہلے سے یہ بات طے کرلے کہ میں نامانوں‘‘ پھر اس کوکوئی حقیقت اورسچائی دکھائی نہیں دیتی۔ قریش مکہ اورعرب کے تمام سمجھدارلوگ خوب اچھی طرح سے جانتے تھے کہ قرآن انسانی کلام ہوہی نہیں سکتا۔ اس لیے کہ ان کے تمام بڑے بڑے شاعروں اور ادیبوں نے متفقہ طورپر سورۃ الکوثر کے آگے کعبہ کی دیوار پر لکھ دیا تھا کہ << مَاھٰذَا کَلَامُ الْبَشَرِ>> (یہ بشر کا کلام نہیں ہوسکتا۔) اب قریش عرب کا یہ کہنا کہ قرآن رسول نے خود گھڑلیا ہے،صاف صاف بتا رہا ہے کہ وہ خود سمجھتے تھے کہ یہ ہم جھوٹ بول رہے ہیں۔ وہ رسول کے طرزکلام سے بخوبی واقف تھے ،اہل زبان تھے چالیس سال سے رسول صلی اللہ علیہ و آلہ وسلم کا کلام سن رہے تھے۔ آج ہر پڑھا لکھا آدمی سمجھ سکتا ہے کہ قرآن احادیث رسول  صلی اللہ علیہ و آلہ وسلم کے مقابلے میں کتنا زیادہ ارفع واعلیٰ اورفصیح وبلیغ کلام ہے۔ دونوں کا انداز یکسر جداگانہ ہے، اس کے باوجود قریش کا یہ کہنا کہ یہ قرآن رسول  صلی اللہ علیہ و آلہ وسلم گھڑا ہوا کلام ہے، صاف صاف یہ بتاتا ہے کہ وہ اصل میں یہ بات پہلے سے طے کرچکے تھے کہ ہمیں قرآن کوخدا کا کلام ہرگز نہیں ماننا ہے۔ ایسے ہٹ دھرم ضدی ،حق دشمن عقل دشمن ،مفاد پرست لوگوں سے کبھی کوئی حق بات نہیں منوائی جاسکتی۔ &&(تفسیر کبیر ،تفسیرابن ہشام ،تفہیم تفسیر نمونہ)&&
  52,34,آیت نمبر۳۴:قرآن خدا کا کلام ہے:پچھلی آیت میں تویہ ثابت کیا گیا کہ قرآن رسول  صلی اللہ علیہ و آلہ وسلم کا گھڑا ہوا کلام نہیں ہے۔ اس آیت۳۴ میں یہ ثابت کیا جا رہا ہے کہ یہ قرآن سرے سے انسان کا کلام ہے ہی نہیں،بلکہ یہ ایسا کلام ہے جسے انسان بنا ہی نہیں سکتا۔ یہ خالق کا کلام ہے۔ پھر یہ چیلنج دیا گیا کہ اگر یہ کسی انسان کا کلام ہے توسب مل کر اس شان کا تھوڑاسا ہی کلام بنا کر لے آئو۔قرآن نے یہ چیلنج پوری دنیا کو دیا۔ تین مرتبہ یہ چیلنج مکہ میں دیا۔ پھر مدینہ میں دیا اورآج تک پوری دنیا اس چیلنج کونہیں توڑسکی۔ &&(تفسیر کبیر ، مجمع البیان ،تفہیم، انوارالنجف)&&
  52,35,آیت نمبر ۳۵ :آیت کی تشریح:بعض مفسرین نےاس کا مطلب یہ لکھا کہ کیا تم اپنے آپ ازخود بغیر ماں باپ کے پیدا ہوگئے؟ &&(ابن جریر)&& لیکن صاف مطلب یہ ہے کہ تم ازخود پیدا ہوگئے ؟ یعنی کیا تم نے خود اپنے آپ کوپیدا کیاہے؟ یا تمھارا کوئی پیدا کرنےوالا نہ تھا؟ تم خود بخود پیدا ہوگئے ۔ یہ دونوں امکانات عقلی حیثیت سے ناممکن ہیں۔ &&(مجمع البیان)&&
  52,36,آیت نمبر۳۶تا۳۸:ان آیات کا اصل مطلب یہ ہے: یہ دہریئے کافر جان بوجھ کرخدا کے وجود کا انکار کرتے ہیں کیونکہ ان کا ضمیر ،وجود، دل و دماغ کسی پیدا کرنے والے کے وجود کا یقین دلاتا ہے ،مگرکیوں کہ یہ سرپھرے دانشور اس بات پر سنجیدگی سے غور و فکر ہی نہیں کرتے،اس لئے انکار کرتے ہیں ،تاکہ ان کی بدمعاشیوں اور مفادات میں کوئی رکاوٹ نہ آن پڑے ،اس لئے یہ سزا کے مستحق ٹھہرے۔&&(فصل الخطاب)&&
  52,39,آیت نمبر۳۹:ان آیات میں تمام سوالات انکاری حیثیت رکھتے ہیں :مثلاً کفار کا یہ کہنا کہ فرشتے اللہ کی بیٹیاں ہیں ؟ اس کا جواب یہ دیا جا رہا ہے کہ تمھیں کیسے عالم بالا تک رسائی ہوئی؟ تم نے کیسے جان لیا کہ فرشتے لڑکیاں ہیں اورخدا نے ان کواپنی بیٹیاں بنا لیا ہے؟ جوشخص خدا کی طرف سے خدا کے علم کو تمھارے سامنے پیش کررہا ہے اس کوتوسنتے نہیں اورازخود غیب کی باتیں گھڑ رہے ہو۔ کیا جس وقت خدا ملائکہ کو بنا رہا تھا، تم دیکھ رہے تھے کہ خدا نے ان کواپنی لڑکیاں یا بیٹیاں بنا لیا ہے۔ &&(تفسیر کبیر، مجمع البیان ،تفہیم)&& یہ بات یاد رہے کہ لڑکا لڑکی انسانی لحاظ سے قدر وقیمت میں برابرہیں یہ آیت توجاہل عربوں کے عقیدے پرضرب ہے اور اس کی تردید ہے اوربیہودہ عقیدے کی تردید ہے۔&&(تفسیر نمونہ)&&
  52,40,آیت نمبر ۴۰ : آیت کی تشریح: جناب رسول خدا  صلی اللہ علیہ و آلہ وسلم نے کبھی مشرکوں،کافروں سے رسالت کا معاوضہ طلب نہیں فرمایا۔کیونکہ جوخدا و رسول  صلی اللہ علیہ و آلہ وسلم کومانتے ہی نہ ہوں ان سے معاوضہ طلب کرنے کا کوئی سوال ہی پیدا نہیں ہوتا معاوضہ آل محمد  صلی اللہ علیہ و آلہ وسلم کی محبت کی شکل میں صرف مومنین سے ان ہی کی فرمائش پرحکم الٰہی کے تحت طلب فرمایا وہ بھی اپنے فائدے کےلیے نہیں ،خود مومنین کے فائدے کےلیے۔جیسا کہ خودخدا نے ارشاد فرمایا:<< ’’قُلْ مَا سَاَلْتُكُمْ مِّنْ اَجْرٍ فَہُوَلَكُمْ۝۰  ‘‘>> &&(سورہ سبا۔۴۷،پارہ۲۲)&& @@ ’’( میں جوکچھ اجر تم سے طلب کررہا ہوں پس وہ بھی تمھارے فائدے کےلیے ہے‘‘۔)@@ اورفائدہ یہ ہے کہ جب تم میرے اقرباء سے محبت کروگے تویہ محبت خدا سے محبت شمار ہوگی اوراس کے نتیجہ میں خود خدا تم سے محبت کرے گا۔ {{ جیسا کہ جناب رسول خدا  صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:<< ’’اَحَبَّ اللہُ مَنْ اَحَبَّ حُسَیْنَا‘‘ >> خدا خود اس شخص سے محبت کرتا ہے جوحسین علیہ السّلام سے محبت کرتا ہے۔&&(ترمذی شریف)&& }} خود قرآن میں رسول  صلی اللہ علیہ و آلہ وسلم کے قرابتداروں سے محبت کرنے کا فائدہ ارشاد فرمایا:<< ’’وَمَنْ يَّــقْتَرِفْ حَسَـنَۃً نَّزِدْ لَہٗ فِيْہَا حُسْـنًا۝۰  ‘‘ >> &&(سورہ شوریٰ۔۲۳، پارہ ۲۵) (۱)&& @@ اورجواس نیکی (آل محمد  صلی اللہ علیہ و آلہ وسلم کی محبت) کوکمائے گا (حاصل کرے گا) ہم خود اس کی نیکی میں اضافہ کردیں گے‘‘۔@@ ……پھرآخر میں فرمایا:(۲) << اِنَّ اللہَ غَفُوْرٌ شَكُوْرٌ۝۲۳ >> &&(سورہ شوریٰ۔۲۳) پارہ۲۵)&& @@’’بیشک اللہ (گناہوں کو) معاف کرنےوالابھی ہے (قدر دان ) شکرگزار بھی‘‘۔@@ یعنی جوآل محمد  صلی اللہ علیہ و آلہ وسلم سے محبت کرے گا اس کے گناہ بھی معاف ہوں گے اورناقص نیکیوں کی بھی قدر کی جائیگی۔&&(مؤلف)&&
  52,41,آیت نمبر ۴۱: آیت کی تشریح: مشرک دعویٰ کرتے تھے کہ بہت جلد رسول  صلی اللہ علیہ و آلہ وسلم کی زندگی کا خاتمہ ہو جائے گا ان سے پوچھا جا رہا ہے کہ : کیا تم کوغیب کاعلم ہے؟ کیا تم کو یہ علم ہے کہ تم رسول  صلی اللہ علیہ و آلہ وسلم کے بعد زندہ رہوگے ۔&&(تفسیر نمونہ ،انوارالنجف)&&
  52,42,آیت نمبر ۴۲: آیت کی تشریح: کفار مکہ کی مکاریوں اور بدمعاشیوں کا وبال دنیا میں بھی خود انہی پر پڑا کہ وہ بدر کے دن قتل کر دیے گئے۔&&(تفسیر صافی)&& یہ چال خود ان پرالٹی پڑگئی، اورایسا ہواکہ اس وقت کوئی تصور بھی نہ کرسکتا تھا کہ اس قدر کم تعداد میں کمزور مسلمان ،قریش عرب کی بساط ہی کوالٹ کررکھ دیں گے۔ مگر تاریخ گواہ ہے کہ بدر میں قریش کے چنیدہ سردار مارے گئےاور پھر چند سال میں مکہ پر مسلمانوں کا قبضہ ہوگیا اور قریش عرب کی ساری چالیں الٹی انہی پر جا پڑیں ۔ &&(تفسیر کبیر، مجمع البیان، تفہیم ، تفسیر نمونہ ،انوارالنجف)&& [[ الٹی ہوگئیں سب تدبیریں کچھ نہ دوانے کام کیا۔آخر اس بیماری دل نے اپناکام تمام کیا ]]
  52,43,آیت نمبر ۴۳: آیت کی تشریح:خداوندعالم نے گیارہ پے درپے سوالوں کی بھرمار کرکے مشرکوں کی تمام تدبیروں اور بدمعاشیوں کا بھی خاتمہ کردیا اوران کیلئے فرار کے راستے ہرطرف سے بند کر دیے۔ زبردست دلائل دے کرآخر کار شرک کی نفی صرف یہ فرما کرکی کہ << سُبْحٰنَ اللہِ عَمَّا يُشْرِكُوْنَ۝۴۳ >> یعنی @@ اللہ کی ذات پاک ہے اس بات سے کہ جسے وہ اللہ کا شریک بناتے ہیں‘‘۔@@ &&(تفسیر نمونہ)&&
  52,44,آیت نمبر ۴۴: آیت کی تشریح: اس آیت میں مشرکین اورحق کے منکروں کی اصل ذہنیت کوبے نقاب کیا ہے کیونکہ انھیں طلب حق سے دورکا بھی واسطہ نہیں۔اس لئے وہ کتنے ہی دلائل سن لیں،معجزے دیکھ لیں یہ حق کوماننے والے نہیں ہیں۔ قرآن میں ایک اورجگہ فرمایا:’’ اگرہم آسمان کا کوئی دروازہ بھی کھول دیتے اوریہ دن دہاڑے اس میں چڑھنے بھی لگتے ،پھربھی یہ لوگ یہی کہتے کہ ہماری آنکھیں دھوکہ کھا رہی ہیں، بلکہ ہم پر جادو کردیا گیا ہے۔ &&(سورہ الحجرات ۱۵،۱۶ ،پارہٍ۱۴)&&
  52,47,آیت نمبر ۴۷ : آیت کی تشریح:اصل میں جب انسان حقیقتوں کو جاننا ہی نہ چاہے تو پھر وہ ابوجہل بن جاتا ہے ۔ پھروہ کسی واقعے کسی دلیل یا معجزے سے سبق نہیں لیتا ۔ پھر اس کیلئے قیامت سے پہلے بھی عذاب مقرر ہیں۔ مثلاً جنگ بدر میں ان کا ذلت کی موت سے مرنا اور بعض کا گرفتار ہونا۔ &&( تفسیر کبیر، انوارالنجف، ابودائود)&&
  52,48,آیت نمبر۴۸:اپنے رب کا فیصلہ آنے تک صبرکرو!!:خداوندعالم کا اپنے رسول  صلی اللہ علیہ و آلہ وسلم سے یہ فرمانا کہ: ’’اپنے رب کا فیصلہ آنے تک صبرکرو‘‘۔ یعنی صبرواستقامت کےساتھ اپنے پالنے والے مالک کے حکم کی تعمیل کرتے ہوئے اپنا کام کیے جائو کیونکہ تمھارا کام حق کوپہنچاتے رہنا ہے۔ اب یہ مانتے ہیں یا نہیں مانتے ،تواس کا تم سے کوئی تعلق نہیں۔ان سے ہم خود نمٹ لیں گے کیونکہ تم ہماری نگاہ کے سامنے ہو، ہم دیکھ رہے ہیں کہ تم اپنا کام کیے جا رہے ہو۔ &&(تفسیر کبیر ،مجمع البیان، تفسیر نمونہ، تفہیم)&& خداوندعالم کا یہ حکم دینا کہ: ’’ تم جب اٹھو تواپنے پالنے والے مالک کی تسبیح حمد کے ساتھ اٹھو‘‘۔ مفسرین نے اس کی کئی تفسیریں اورمعنی لکھے ہیں:(۱)جب کسی محفل ،مجلس سے اٹھو تواللہ کی حمد وتسبیح کرو۔ {{ جناب رسول خدا  صلی اللہ علیہ و آلہ وسلم جب بھی کسی مجلس سے اٹھتے توتسبیح پڑھتے اورفرماتے: اس سے تمھاری ان باتوں کا کفارہ ادا ہوجاتا ہے جوتم اس مجلس میں کرتے ہو۔ &&(ابودائود، ترمذی، نسائی)&& !!{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ جوشخص کسی مجلس میں بیٹھا اوراس میں خوب قیل وقال ،بحث مباحثہ ہوا اور وہ اٹھنے سے پہلے یہ کہے:<< سُبْحَانَکَ اللّٰھُمَّ وَبِحَمْدِکَ اَشْھَدُاَنْ لَّآ اِلٰہَ اِلَّآ اَنْتَ اَسْتَغْفِرُکَ وَاَتُوْبُ اِلَیْکَ>> ۔&&(تفسیر المیزان)&& یعنی : ’’اے اللہ! توہر عیب سے پاک ہے اورحمد صرف تیرے ہی لیے ہے۔میں گواہی دیتا ہوں کہ تیرے سوا کوئی معبود (قابل عبادت) نہیں ہے ،میں تجھ سے اپنے گناہوں کی معافی طلب کرتا ہوں اورتیری ہی طرف رجوع کرتا ہوں‘‘۔ اس کے یہ کہنے کی وجہ سے اللہ اس کے ان گناہوں کومعاف کردیتا ہے جواس مجلس ومحفل میں سرزد ہوگئے ہوں ۔&&(حاکم ،المیزان، تفسیردرمنثور جلد۶)&& }} ایک تفسیر یہ ہے کہ جب تم اللہ کی طرف بلانے کےلیے اٹھو تواس کا آغاز اللہ کی حمد وتسبیح سےکیا کرو۔ اسی لیے جناب رسول خدا  صلی اللہ علیہ و آلہ وسلم اپنے تمام خطبوں کا آغاز خدا کی حمد وثناء سے کیا کرتے تھے۔&&(تفسیر کبیر)&& ایک تفسیر یہ بھی ہے کہ ’’اے رسول  صلی اللہ علیہ و آلہ وسلم !جب تم نماز تہجد کےلیے اٹھو توتسبیح پڑھو۔ &&(تفسیر نمونہ)&& !!{{ فرزندان رسول خدا  صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السّلام ،امام جعفرصادق علیہ السّلام سے منقول ہے کہ جناب رسول خدا  صلی اللہ علیہ و آلہ وسلم رات کے وقت اٹھتے اور اطراف آسمان پر نظرڈال کرسورہ آل عمران کی پانچ آیتیں۱۹۰تا۱۹۴ تلاوت فرماتے اورنمازشب میں مشغول ہوجاتے ۔ &&(تفسیر مجمع البیان ،تفسیر انوارالنجف)&& }} ایک تفسیر یہ بھی ہے کہ :’’جب تم دوپہر کوقیلولہ کرکے اٹھا کرو تونماز پڑھا کرو۔ اس سے مراد نماز ظہر (اورعصر) ہے۔&&( ابن جریر)&&
  52,49,آیت نمبر۴۹:یہاں پر پانچوں نمازوں کےاوقات بتائے گئے ہیں:فرمایا کہ:’’ جب بھی کھڑے ہوا کریں‘‘۔ یعنی جب دوپہر کوقیلولہ فرما کر کھڑے ہوا کریں تونمازظہر اورنمازعصر پڑھا کریں۔ پھرفرمایا:’’ رات کے کچھ حصے میں‘‘ … تسبیح پڑھا کیجئیے۔ یعنی مغرب ،عشاء اور تہجد کی نمازیں پڑھا کیجئیے۔ &&(تفسیر نمونہ)&& اوریہ فرمایا کہ:’’ جب ستارے پلٹتے ہیں‘‘ ۔ یعنی فجر کے وقت صبح کی نماز پڑھا کیجئیے۔ &&(تفسیر کبیر، فصل الخطاب ،تفہیم)&& !!ملاحظہ فرمائیں کہ خداوندعالم نے پانچوں نمازوں کے اوقات تین قسموں میں بیان فرمائے ہیں۔(۱) دوپہر کوقیلولہ سے اٹھ کر، یعنی ظہروعصر کی نماز۔(۲) رات کے کچھ حصے میں، یعنی مغرب وعشاء اورتہجد کی نمازیں ۔(۳) اورصبح کی نماز کوالگ بیان فرمایا ہے۔ {{ جناب امیرالمومنین علیہ السّلام نے فرمایا:<< ’’ اِدْبَارَ النُّجُوْمِ‘‘ >> ستاروں کےلوٹنے کا وقت، تسبیح کرنےسے مراد صبح کی جودورکعت ہے۔}} {{ آنحضرت  صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’تمھارے لئے صبح کی نفل نمازکی دورکعتیں دنیا اور جوکچھ اس میں ہے اس سے بہتر ہے۔ &&(تفسیر قرطبی جلد۹)&& }}
