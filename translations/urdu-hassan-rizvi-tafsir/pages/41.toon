  41,1,آیت نمبر۱:>>حا۔ میم<<:{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السَّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: >> حا۔ میم<<سے مراد حمید اور مجید ہے۔ (>>حمید<< کے معنی جو از خود قابلِ حمد وتعریف ) ہو۔ اور مجید کے معنی بزرگ و برتر۔&&(معانی الاخبار، شیخ صدوق ؒ)&&}}بعض مفسرین نے لکھّا کہ: >>ح<< سے مراد خدا کی حاکمیّت ہے اور >> م << سے مراد خدا کی مالکیّت ہے۔ &&(تفسیر قرطبی)&&{{ابن عباس سے روایت ہے کہ :حٰمٓ‘‘ خدا کا اسمِ اعظم ہے۔&&(تفسیر قرطبی)&&یہ سارے کےسارے معنی مراد لینے میں کوئی حرج نہیں ہے۔ &&(تفسیر نمونہ)&&
  41,3,آیت نمبر۳:>>عربی<< کے معنی:امام راغب اصفہانی نے مفردات القرآن ‘‘ میں لفظ >>عربی<< کے معنی لکھّے (۱) فصیح کلام کرنا (۲) بلیغ کلام کرنا۔ (۳) صفائی کے ساتھ واضح اظہار کرنا (۴) اِس طرح کلام کرنا کہ جو مطلب اور مقصد کو پوری پوری طرح سمجھا دے ۔ یہاں پر قُرْاٰنًا عَرَ بِیًّا کے یہی معنی ہیں ۔ جو اوپر بیان ہوئے ہیں ۔&&(مفردات القرآن امام راغب، لغات القرآن نعمانی جلد ۴)&&!!شانِ نزول:{{ایک دن ابوجہل نے اپنے چچا ولید سے ، جو بڑا ادیب اور قابل آدمی تھا پوچھا:’’ یہ جو محمدصلی اللہ علیہ وآلہ وسلم کہتا ہے ، یہ جادو ہے یا کہانت‘‘؟ ولید جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے پاس گیا۔ آنحضرت صلی اللہ علیہ وآلہ وسلم حجرِ اسماعیل علیہ السلام  کے پاس بیٹھے تھے، اور کہنے لگا:’’ اے محمدؐ! اپنے کچھ شعر سنا و‘‘حضورِ اکرمٰؐ صلی اللہ علیہ وآلہ وسلم نے فرمایا:’’ یہ شعر نہیں ہیں ، بلکہ اللہ تعالی کا کلام ہے، جووہ اپنے انبیا علیہ السلام  پر اُتارتا ہے۔‘‘ولید بولا: جو کچھ بھی ہے، پڑھو۔‘‘حضورِ اکرم صلی اللہ علیہ وآلہ وسلم نے سورۃ حٰمٓ السجدۃ کی تلاوت شروع کی ۔ جب دوسری آیت پڑھی ، کہ >>تَنْزِيْلٌ مِّنَ الرَّحْمٰنِ الرَّحِيْمِ>> تو ولید بولا:’’ یہ وہی رحمٰن ہے جو یمامہ میں رہتا ہے‘‘؟آنحضرت صلی اللہ علیہ وآلہ وسلم نے فرمایا:’’ میں خدا کو پکار رہا ہوں جو رحمٰن ورحیم ہے۔مگر جب حضور اکرم صلی اللہ علیہ وآلہ وسلم نے عاد و ثمود کی قوموں پر صاعقہ کے عذات کے اترنے والی آیات پڑھیں تو ولید پر لرزہ طاری ہونے لگا، اُس کے بدن کے رونگٹے کھڑے ہو گئے۔ گھبرا کر اُٹھا اور گھر چلا گیا ابوجہل قریش کے سرداروں سے کہنے لگا کہ ولید بن مغیرہ محمدصلی اللہ علیہ وآلہ وسلم کے دین میں داخل ہو گیا۔ شاید محمد صلی اللہ علیہ وآلہ وسلم کی باتوں میں آگیا، محمدصلی اللہ علیہ وآلہ وسلم کا جاود اُس پر چل گیا۔دوسرے دن ابو جہل اپنے چچا ولید کے گھر گیا اور بولا کہ :’’ آپ نے ہمیں شرمندہ کردیا۔ آپ محمدصلی اللہ علیہ وآلہ وسلم پر فریفتہ ہو گئے۔‘‘ ولید نے کہا: نہیں ، میں محمدصلی اللہ علیہ وآلہ وسلم پر ایمان نہیں لایا ہوں ، البتہ اُن کے کلام سے میرے رونگٹے کھڑے ہوگئے ۔گھبرا کر اُٹھا اور گھر چلا گیا۔ابوجہل نے پوچھا :’’ کیا وہ شعر تھے‘‘؟ ولید نے کہا ؛’’نہیں ‘‘ ابوجہل نے کہا:’’ کیا وہ موزوں خطبے تھے؟‘‘ ولید نے کہا:’’ نہیں نہ وہ خطبہ ہے ، نہ شعر ہے لیکن اُس کے کلام میں ایک خاص چمک ہے۔‘‘ ابوجہل نے کہا‘‘: پھر وہ کہانت ہے‘‘؟ ولید نے کہا:’’ نہیں ۔‘‘ پھر دوسرے دن ولیدنے کہا :’’ محمد صلی اللہ علیہ وآلہ وسلم کا کلام جادو ہے۔‘‘ کیونکہ وہ دلوں کو اپنی طرف کھینچتا ہے۔‘‘ اسی موقع پر آیت نمبر ۱۱ سے ۳۰ تک اُتریں ۔&&(بحارانوار، تفسیر قرطبی)&&}}
  41,5,آیت نمبر۵:کافروں کایہ کہنا کہ ’’ ہمارے اور تمھارے درمیان حجاب حائل ہو گیاہے۔‘‘ یعنی ‘‘: اے محمدصلی اللہ علیہ وآلہ وسلم ! تم نے جو اسلام کی تبلیغ شروع کر دی ہے اس نے ہمارے اور تمھارے درمیان جدائی ڈال دی ہے۔ ہمیں ایک دوسرے سے کاٹ دیا ہے، اب ہم یکجا جمع نہیں ہو سکتے۔ کافروں کا یہ کہنا کہ :’’ تو اپنا کام کرہم اپناکام کیے جائیں گے۔‘‘ اس کا مطلب تویہ ہے کہ ہمیں تم سے کوئی سروکار نہیں ۔‘‘ دوسرا مطلب یہ ہے کہ :’’ تم دین اسلام کی تبلیغ کیے جاو، ہم اُس کی مخالفت کیے جائیں گے۔ اور جو کچھ ہم سے ہو سکے گا تمھیں نیچا دکھانے کے لیے کیے جائیں گے۔&&(تفہیم مجمع البیان)&&
  41,6,آیت نمبر۶:اس میں قطعاًکو ئی شبہ نہیں کہ نبی صلی اللہ علیہ وآلہ وسلم بظاہر ہم جیسا بشر ہوتا ہے،مگر اُس کی امتیازی خصوصیّت یہ ہوتی ہے کہ >>یُوْ حٰٓی اِلَّی <<( یعنی )اُ س کی جانب خدا کا پیغام خفیہ طور پر وحی کیا جاتا ہے جس طرح منطق کی زُبان میں انسان کی تعریف ’’حیوان ناطق‘‘ یعنی ‘‘ایسا حیوان جو سوچ سمجھ سکتا ہو کی جاتی ہے۔ اب اگر کسی انسان کو صرف حیوان کہا جائے تو یہ غلط بھی ہو گا اور انسان کی توہین بھی ہوگئی ۔ کیونکہ انسان کی تعریف صرف حیوان نہیں کی گئی، بلکہ حیوانِ ناطق کی گئی ہے، بالکل اسی طرح نبی صلی اللہ علیہ وآلہ وسلم کو صرف بشر نہیں کہا گیا ہے بلکہ ساتھ ساتھ   >>یُوْ حٰی اِلَیَّ<< ’’وحی والا‘‘ بھی کہا گیا ہے۔ اس لیے اگر نبی صلی اللہ علیہ وآلہ وسلم کو بشر کہنے کا شوق ہے تو ’’صاحبِ وحی بشر‘‘ کہنا پڑے گا۔ صرف بشر نہیں کہا سکتا۔ یہ کہنا قرآن کی رو سے غلط بھی ہے اور نبی صلی اللہ علیہ وآلہ وسلم کو صرف ’’بشر ‘‘ نہیں کہاجا سکتا۔ یہ کہنا قرآن کی رو سے غلط بھی ہے اور نبی صلی اللہ علیہ وآلہ وسلم کی توہین کرنا بھی ۔ اسی لیے پورے قرآن میں کہیں کسی مومن نے نبی صلی اللہ علیہ وآلہ وسلم کو ہم جیسا بشر نہیں کہا۔ ہمیشہ کفّار و مشرکین نے انبیاء کرام علیہ السلام  کو ہم جیسا بشر کہہ کر پکارا ۔ کیونکہ وہ انبیاء کرام علیہ السلام کے منکر تھے اور اُن توہین کرنا چاہتے تھے&&(مولّف)&&
  41,7,آیت نمبر۷:آیت میں زکوٰۃ کے معنی:میں مفسّرین نے اختلاف کیا ہے۔(۱) زکوٰۃ کے یہاں معنی پاکیزگی اختیار کرنا ہے، جو توحید کے عقیدے کو دل سے مان لینے اور عملاَ اللہ تعالی کی اطاعت کرنے سے حاصل ہوتی ہے۔ اس لیے جو مشرک یہ عقیدہ اورعمل اختیار نہیں کرتے اُن کی فکر و عمل سب نجس ہوتے ہیں ۔ &&(بقول ابن عباس، عکرمہ، مجاہد، تفسیر مجمع البیان و تفسیر کبیر)&&(۲)زکوٰۃ کے دوسرے معنی ، وہ مال ہے جو مال کوپاک کرنے کی نیّت سے اللہ تعالی کی راہ میں دیا جائے اس لحاظ سے آیت کے معنی یہ ہوں گے کہ تباہی اُن لوگوں کے لیے ہے جو شرک کرکے خدا کا حق مارتے ہیں ، اور زکوٰۃ نہ دے کر بندوں کا حق مارتے ہیں ۔&&(بقول قتادہ ، سدِی ، حسن بصری ، ضحاک ، مقاتل از تفسیر کبیر، مجمع البیان)&&زکوٰۃ کی اہمیت:{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السّلام سے روایت ہے کہ: جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے حضرت امام علی ابنِ ابی طالب علیہ السَّلام کو یہ وصیت بھی فرمائی تھی کہ ’’ میری اُمت کے دس قسم کے لوگ کفر کرچکے ہیں ،اُن میں وہ بھی ہیں جو زکوٰۃ ادا نہیں کرتے ۔ اے علی علیہ السلام ! جو شخص اپنے مال سے زکوٰۃ کا ایک قیراط (روپیہ) ادا نہیں کرے گا ، وہ نہ مومن ہے نہ مسلمان ۔ خدا کے نزدیک اُس کی کوئی قدر و قیمت نہیں ۔‘‘اےعلی علیہ السلام ! زکوٰۃ ادا نہ کرنے والا مرتے وقت خدا سے گڑگڑا کر درخواست کرتا ہے کہ مجھے دنیا میں لوٹا دے (تاکہ میں صدقہ خیرات کردوں )مگر خدا لوٹا نے سے انکارکردیتا ہے۔ ‘‘ نیز فرمایاکہ:’’اللہ تعالی نے امراء کے مالوں میں غرباء کے لیے زکوٰۃ فرض کردی ، جسے ادا کیے بغیر امراء قابل تعریف نہیں ہوسکتے، اورزکوٰۃ کے ذریعہ امراء اپنی جان (خون) کی حفاظت کرتے ہیں اور مسلمان کہلاتے ہیں &&(وسائل الشیعہ جلد ۶ص۱۹۔۱۸)&&}}
  41,8,آیت نمبر۸:>>غَیْرُ مَمْنُوْنٍ>>:اس کے کئی معنی ہیں (۱) جو کبھی ختم ہونے والا اجر نہیں ہوتا۔ &&(مجمع البیان)&&(۲) خدا اُن کو اُن کا اجر بطور اُن کے اعمال کی جزاء کے دے گا ۔ اُن کا اجر بطور استحقاق ملے گا ،ایمان و عمل کی وجہ سے احسان جتا کر نہیں بلکہ عزّت اور شان کے ساتھ دیا جائے گا۔&&(تفسیر علی ابن ابراہیم، تبیان، تفسیر کبیر ، تفہیم)&&!!آیت کی تشریح:قرآن میں تخلیق کائنات کے حوالے سے چھ دنوں کا ذکر ہو ا۔ یا ۔ دو دنوں کا ذکر ہوا اصل میں یہ بتدریج تخلیق میں لانے کا بیان ہے ۔ مراد محض وقت ہے ۔ ایک خلقت کی ابتدا کا وقت مرادہے۔ اور دوسرا اُس کی تکمیل کا۔&&(تفسیر صافی ، تفسیر قمی)&&بعض مفسّرین نے کہا ہے کہ دو دنوں سے مراد دو وقت ہیں ۔ پہلا وقت ابتدا ئے خلقت اور دوسرا وقت انتہائے زندگی ہے۔ یعنی زمین کی ایجاد سے فنا تک کی تمام تخلیق کا کارنامہ اُسی ذات کا مرہونِ منت ہے جو رب العٰلمین ہے&&(تفسیر انوار النجف،)&&
  41,10,آیت نمبر۱۰:>>سَوَآءٌ لِّلسَّآئِلِیْنَ>>:سائل وہی ہوتا ہے جو محتاج ہو اور اللہ تعالی کے ماسوا سب محتاج ہیں اور >>سَوَآء<< کے معنی درست اور برابر کے ہیں ۔ یعنی یہ نظامِ قدرت تمام ماسواء اللہ تعالی کے لیے صحیح اور مناسب ہے ۔ پس اللہ تعالی کے انعام و احسان کا انکار کرنا کفر اور کسی دوسرے کی طرف منسوب کرنا شرک ہے۔ {{بروایت کافی فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت جعفر صادق علیہ السَّلام سے منقول ہے ’’خدا وند عالم نے جملہ، خیر ’’بروز اتوار خلق فرمائی ، اور زمینوں کو سوموار (پیر) کے دن پیدا کیا ، اور اہل زمین کے خورد ونوش کی اشیاء واسباب کو منگل کے روز خلق کیا، آسمان کی تخلیق بدھ اور جمعرات کو ہوئی، اور اُن کی غذا وں کے اسباب یوم جمعہ پیدا فرمائے، اور اس فرمان کا یہی مطلب ہے >>خَلَقَ السَّمٰوٰتِ وَالْاَرْضَ وَمَا بَیْنَھُمَا فِیْ سِتَّۃِ اَیَّامٍ‘‘>>&&(تفسیر برہان ، تفسیر انوارالنجف)&&}}خدا وند عالم کا فرمان کہ@@ ’’ہم نے زمین میں برکتیں رکھ دی ہیں ۔‘‘@@ برکتوں سے مراد وہ بے حد و انتہاء سامان ہے جو کروڑوں سال سے زمین کے پیٹ سے نکلا چلا جا رہا ہے، اور انسانوں و حیوانوں کی ضرورتیں پوری کیے چلا جارہا ہے۔خداوند عالم کا فرمانا:@@’’ زمین کے اندر مانگنے والوں کے لیے طلب و حاجت کے مطابق ٹھیک ٹھیک اندازے سے خوراک کا سامان مہیا کردیا ہے۔‘‘@@ یعنی ہم نے زمین میں ضرورت مندوں کے لیے اندازوں کے مطابق سامان رِز ق رکھ دیا ہے۔ وہ بھی تمام مخلوقات کی مانگ اور ضرورت کے مطابق صرف جسم کی پرورش ہی کے لیے نہیں ، بلکہ ہمارے ذوق کی تسکین کے لیے طرح طرح کی خوراکیں درکار ہیں ، اُن کا بھی انتظام فرمادیا۔&&(تفسیر کبیر)&&مارکس کے فلسفہ کے ماننے والے اِسی آیت سے کہ خداوند نے فرمایا<<سَوَآئً لِّلسَّآئِلیْنَ:‘‘>>@@''سب مانگنے والوں کے لیے برابر ‘‘@@ یہ نتیجہ نکالا کہ اللہ تعالی نے سب انسانوں کے لیے زمین میں برابر خوراک رکھی ہے اس لیے ایسا نظام اشتراکی بنانا چاہے کہ جو سب کو مساوی راشن دے سکے۔ مگریہ استدلال اس لیےغلط ہے کہ یہاں >>سائلین<< یعنی طلب کرنے والوں سے مراد صرف انسان نہیں ہیں ، بلکہ حیوان ، چرند ، پرند، کیڑے ، مکوڑے سب مراد ہیں ، جن کے لیے غذائیں زمین میں رکھ دی گئی ہیں ، تو کیا ساری مخلوقات کو مساوی طور پر رزق دینے کا انتظام کیا جاسکتا ہے؟ کیا کوئی حکومت انسانوں اور حیوانوں کے درمیان معاشی مساوات قائم کر سکی ہے؟ (نوٹ : لیکن مساوات خاص طور پر بُنیادی زندگی میں ہونا یقیناَ عدل کا تقاضا ہے۔)&&(مؤلف)&&!!چار دن:خدا نے فرمایا کہ@@: ہم نے زمین اور سات آسمانوں کو چھ دنوں میں پیدا کیا۔‘‘@@ زمین اور ساتوں آسمانوں سے مراد پوری کائنات ہے۔ پھر یہ بتایا گیا کہ خدا نے دو دنوں میں سات آسمان بنائے۔ یعنی پوری کائنات مع ہماری زمین کے بنائی۔ اور چاردنوں میں زمین کے اندر وہ سب کچھ سامان بھر دیا جس کی اُنھیں قیامت تک ضرورت تھی۔ اِن چاروں دونوں میں دوسرے سیاروں میں کیا کچھ کیا؟ اس کا ذکر یہاں نہیں فرمایا، کیونکہ نزولِ قرآن کے وقت کاانسان ان باتوں کو ہضم نہیں کر سکتا تھا۔
  41,11,آیت نمبر۱۱:خدا کا طرزِ تخلیق کائنات:{{حضرت امیرالمومین علیہ السَّلام نے جہاں تخلیق آسمان کا ذکر فرمایا ہے وہاں اس طرح ارشاد فرمایا کہ :’’ اللہ تعالی جلّ شانہ نے پہلے پانیوں کو پیدا کیا اور ہوا وں کے ذریعے پانیوں کی سطح میں حرکت پیدا کی، اُس کی جھاگ سے سطح زمین کو خلعت وجود بخشا اور اُس سے اُٹھنے والے دھوئیں کو اوپر اُٹھایا، اور اُس سے آسمان کو وجود بخشا۔‘‘&&(نہج البلاغۃ، تفسیر انوارالنجف)&&}}زمین و آسمان کے ذکر کے بعد یہ سوال پید ا ہوتا ہے کہ خدا نے آسمانوں اور زمین کو کس طرح پیدا فرمایا؟جواب یہ ہے کہ اللہ تعالی کی ایجاد میں آلات و اسباب کی ضرورت نہیں ہوتی، وہ تو>> اَمْرِکُنْ‘‘>>سے چیز کو عد م سے نکال کر خلعتِ وجود عطا فرمایا کرتا ہے، چنانچہ آسمانوں اور زمین کی پیدائش کا بھی جب ارادہ فرمایا : کہ عدم سے نکل کر عرصہ وجود میں آجا و ، خواہ کَرھًا ۔ یعنی میرا تم کو پیدا کرنا امرِ تکوینی ہے نہ کہ امرِ تشریعی جس میں مخاطب کو اختیار دیا جاتا ہےپس امرتکوینی میں مخلوق کی محال نہیں کہ انکار کرسکے۔ پس جب اُس کا ارادہ ہوا تو آسمان اور زمین فوراً بن گئے ، اور اُن کا فوراً بن جانا، اُن کی زبان حال سے جواب تھا کہ ’’ اے پروردگار! ہم اطاعت کرتے ہوئے حاضر ہیں ، ہمیں تیرے حکم ایجا د میں انکار کی مجال ہی کیا‘‘ اور اس خطاب میں ذوی العقول مخلوق بھی شامل ہیں ۔&&(تفسیر انوارالنجف)&&غرض اس آیت میں خدا وند عالم نے آسمانوں اور زمین میں اپنی قدرت کاملہ کا اثر قبول کرنے کو مثلاً یا مجازاَ فرمایا ہے۔مطلب یہ ہے کہ جب خدا کی طرف سے کوئی حکم ہوتا ہے، تو زمین اور آسمانوں کی ہر ہر چیز اس کی اطاعت کے لیے اپنی آمادگی کا اظہار کرتی ہے۔ گویا کائنات کی ہر چیز خدا کی اطاعت کے لیے بالکل تیار ہے۔&&(تفسیر صافی)&&خداوند عالم کا یہ فرمانا @@’’اور زمین اور آسمانوں کا جواب دینا‘‘ @@یہ صرف لفظی جمع خرچ نہیں ہے یہ اسی حقیقت کا بیان ہے جس کو قرآن میں ’’سورۃ یٰسٓ‘‘ میں <<کُنْ>> کے لفظ سے بیان کیا گیا ہے یعنی :<<اَمْرُہٗٓ اِذَآ اَرَادَشَیْئٍا اَنْ یَّقُوْلَ لَہٗ کُنْ فَیَکُوْنُ ‘‘>>&&(یٰسٓ ۳۶ آیت۸۲پ۲۳)&&’’اُس کی شان تو یہ ہے کہ جب وہ کسی چیز کا ارادہ کرتا ہے تو اُ سکو کہتا ہے کہ’’ ہوجا‘‘تو وہ ہو جاتی ہے۔‘‘مطلب یہ ہے کہ وہ خدا کے حکم پر فوراً بلا تکّلف وجود میں آگئے ، اور خدا کے حکم کی اطاعت کرنے میں نہ زمین نے انکار کیا نہ آسمان نے ۔ خدا کے حکم کے عین مطابق وجود میں آگئے اور وہ چلنے لگے۔&&(تفسیر مجمع البیان)&&’’دُخان‘‘ سے مراد :یہ ہے کہ تمام آسمان شروع میں دھویں کی شکل کے تھے۔ جدید سائنس سے بھی یہ معلوم ہُوا ہے کہ آسمانوں کی تخلیق کا آغاز بڑے بڑے گیسوں کے مجموعوں سے ہواتھا۔ آج بھی بہت سے آسمانی ستارے گیس اور دھویں کے بڑے بڑے مجموعوں کی صورت میں موجود ہیں ۔پھر خدا نے آسمانوں اور زمین سے کہاکہ ’’ چلو اب صورت اختیار کرو چاہے مجبور ہو کر یا خوشی خوشی‘‘ ۔ مطلب یہ ہے کہ خدا کا یہ قطعی ارادہ تھا کہ یہ گیسز منجمد ہو کر صورت اختیار کریں چاہے وہ یہ بات چاہتے ہوں کہ نہ چاہتے ہوں ۔ ثابت ہوا کہ ساری کائنات خدا کے ارادے کی تابع فرمان ہے۔&&(تفسیر نمونہ)&&
  41,13,آیت نمبر ۱۳ کی تشریح>>صاعقہ<< ایک زبرست ، مہبب ، خطرناک دل ہلا دینے والی آواز کو کہتے ہیں جو فضا میں اُٹھتی ہے۔ اُس میں آگ ہوتی ہے اور موت ۔ کبھی کبھی دوسرے عذاب بھی اُس میں ہوتے ہیں ۔&&(مفردات امام راغب)&&جب قومِ عاد پر وہ تیز ہوائیں ،دھماکوں کے ساتھ آئیں تو اُن پر اندھیرا چھا گیا ۔ کیونکہ وہ ہوائیں اس قدر غبار آلود تھیں کہ ہاتھ تک سجھائی نہ دیتا تھا۔ وہ احمق سمجھے کے بادل آرہے ہیں ۔ خدا نے اُن سے کہا:’’ یہ بادل نہیں ہیں ، یہ وہی عذاب ہے جس کی تم جلد مچا رہے تھے۔ یہ ایسی ہوا کے تیز و طرار جھونکے اور جھکڑہیں جن میں سخت تکلیف دینے والا عذاب چھپا اور بھرا ہوا ہے۔‘‘&&(تفسیر نمونہ بحوالہ سورۃ احقاف آیت ۲۴)&&
  41,14,آیت نمبر ۱۴ کی تشریح:خدا کا فرمانا کہ@@ ’’ جب خدا کے رسول علیہ السلام  اُن کے پاس آگے پیچھے ، ہر طرف سے آئے ‘‘ @@(۱) یعنی اُن کے پاس خدا کے رسول علیہ السلام  مستقل آتے رہے، (۲) دوسرا مطلب یہ ہے کہ رسولوں علیہم السلام  نے طرح طرح سے اُن کو سمجھایا اور قائل کرنے کی کوششیں کیں ۔(۳) تیسرا مطلب یہ ہے کہ اُن کے پاس اُن کے علاقوں میں بھیجے ہوئے رسول علیہم السلام  بھی آئے اور گرد و پیش کے ملکوں میں بھیجے ہوئے رسول علیہ السلام  اوراُن کے پیغامات بھی آئے مگر اُنھوں نے کہا کہ اگر خدا کو ہمارا دین پسند نہ ہوتا تو وہ ہمارے پاس فرشتوں کو بھیجتا ۔ بھلا تمھاری خاطرہم اپنے باپ داد کا دین کیوں چھوڑدیں &&(تفسیر کبیر، مجمع البیان، کشاف تفہیم)&&
  41,15,آیت نمبر۱۵:قومِ عاد پر عذاب:قومِ عاد عرب کے جنوب میں حضر موت کے علاقے احقاف میں رہتی تھی، یہ بڑی طاقتور، مالدار ، متمـّدن، ترقی یافتہ قوم تھی، بڑے خوبصورت محلّات قلعے ، اور بلند عمارات بناتے تھے، دنیوی ٹھاٹ باٹھ ، جاہ و جلال ، شان بان دکھاتے تھے۔ بڑے سخت دل اور جنگجو تھے آخرت کار اپنی دولت اور طاقت پر تکبّر کرنے لگے ۔ اس تکبّر کی وجہ حضرت ہود پیغمبر علیہ السلام  سے بغاوت کی ، اس سرکشی کا نتیجہ یہ ہوا کہ خدا نے بڑی تندوتیز ہوا اُن پر بھیجی جس نے اُٹھا اُٹھا کر دو مرتبہ پوری قوم کو زمین پر دے مارا، جس طرح کھجور کے درخت کو تنے سے اُٹھا کرزمین پر دے مارا جاتاہے۔ یہ آندھی سات راتیں اور آٹھ دن مسلسل چلتی رہی۔ &&(ملاخطہ ہو سورۃ ۵۴قمراور سورۃ الحاقّہ)&&خداوند عالم نے فرمایا:@@’’ یہ تو دنیوی سزا ہے ۔ آخرت کی سزا اس سے کہیں زیادہ ذلیل کرنےوالی ہوگی۔‘‘@@ دنیا کی سزاآخرت کے مقابلہ پر ایسی ہی ہوتی ہے جسیے سمندر کے مقابلہ پر قطرہ ۔ وہاں اُن کی کوئی مدد بھی نہ کر سکے گا۔&&(تفسیر نمونہ۔ مجمع البیان)&&
  41,16,آیت نمبر۱۶:>>صَرصَر<< کے معنی(۱) طوفانی ہوا (۲) سخت گرم لُو (۳) سخت ٹھنڈی ہوا (۴) ایسی ہوا جس کے چلنے سے بہت شور ہو۔غرض اس پر سب کا اتفاق ہے کہ >>صرصر<< کا لفظ بہت تیز طوفانی ہوا کے لیے استعمال ہوتا ہے۔&&(مفردات القرآن امام راغب ، لغات القرآن، لسان العرب)&& ہوا وں کی مختلف قسمیں :{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السَّلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ وآلہ وسلم نے فرمایا:>> صرصر<< سے مراد بے حد ٹھنڈی ہوا ہے۔‘‘&&(تفسیر صافی ، تفسیر قمی)&&}}ہوائیں آٹھ قسم کی ہیں ، چار باعثِ عذاب اور چار باعثِ رحمت۔ جو باعثِ عذاب ہیں وہ یہ ہیں ۔(۱) عاصف (۲) صرصر(۳) سموم‘‘(۴)عقیم اور جو باعث رحمت ہیں وہ یہ ہیں (۱)ناشرات (۲) مبشرات (۳) مرسلات(۴) فارقات&& (الحدیث) && &&(تفسیر انوارالنجف)&&>>’اِیَّامٍ نَّحِسَاتٍ‘‘ >> منحوس دنوں : سے مراد ’’عذاب الہٰی کے اُترنے کے دن ہیں ۔ اب اس سے یہ ثابت کرنا کہ کچھ دن منحوس بھی ہوتے ہیں ، نہایت غیر منطقی بات ہے۔ ہر دن اللہ تعالی کا پیدا کیا ہوا ہے۔ کوئی دن غیر خدا کا پیدا کیا ہوانہیں ہے۔ کیونکہ اللہ تعالی ہر عیب سے پاک ہے ، اس لیے ہر دن معصوم دمخلوق ہے ۔ البتہ جن دنوں میں جس قوم یا فرد نے کوئی برُا کا کیا ہے اوراس کی وجہ سے اس پر عذاب آیا ہے۔ تو وہ دن صر ف اُس قوم یا فرد کے لیے منحوس ہیں ، وہ بھی انکے اپنے کرتوت کی وجہ سے ۔ اصل میں نحوست دنوں میں نہیں ہواکرتی ، لوگوں کے بُرے اعمال خراب یا منحوس ہوتے ہیں ۔اِسی حماقت پر مبنی بعض نجومی پرستوں نے شمسی، قمری مہینوں کے سعد اور نحس دنوں کی پوری تقویم بناکر چھاپ رکھی ہے، اور اُس کا باقاعدہ کاروبار بنا رکھا ہے۔ یہ غیرمنطقی ، غیر عقلی اورغیر معتبر روایتوں پر مبنی ہے۔ پھر یہ کہ جو شخص خدا کی قدر اور رحمت پر بھروسہ کرتا ہے تو خدا خود اُس کے لیے کافی ہو جاتا ہے۔ اُس کو ان حماقتوں کی طرف توجہ دینے کی کوئی ضروت باقی نہیں رہتی۔ خدا وند عالم نے خودفرمایا:<<وَمَنْ یَّتَوَ کَّلْ عَلَی اللہ تعالی فَھُوَ حَسْبُہٗ>> یعنی @@’’ اور جو شخص اللہ تعالی پر بھروسہ کرتا ہے تو اللہ تعالی اُس کے لیے کافی ہو جاتا ہے۔‘‘@@[[مومن تو فقط حکمِ الہٰی کا ہے پابند۔تقدیر کے پابند نباتات و جمادات ۔ستارہ کیا مری تقدیر کی خبر دے گا۔وہ آپ وسعتِ افلاک میں ہے خوار و زبوں ۔]]&&(اقبال)&&{{اَئمّہ اہل بیت طاہرین علیہ السَّلام سے بطریقِ روایات احاد ایّام کی سعادت اور نحوست منقول ہے ۔ ایام ہفتہ میں سے بعض سعد، بعض نحس اوربعض کو میانہ کہا گیا ہے۔مگر ماہرین نے ان روایات کو معتبر نہیں مانا، &&(فصل الخطاب)&&}} روزِ جمعہ عید کے دن کو زیادہ فضیلت والا فرمایا اس دن غسل کرنا بیحد ثواب کا باعث ہوا ہے&&(تفسیر انوار النجف)&&اور پیر کے دن کی نحوست سے بچنے کے لیے اُس دن نماز فجر کی پہل رکعت میں سورہ دھر کی تلاوت کی جائے
  41,17,آیت نمبر۱۷:انسان فاعل مختار ہے۔محققین نے خداوند عالم کے اس ارشاد سے کہ :@@’’ اُنھوں نے اندھے پن کو سیدھا راستہ پانے پر ترجیح دی۔‘‘ @@ یہ نتیجے نکالے کہ:’’ (۱) انسان فاعل مختار ہے، مجبور نہیں ہے۔ (۲) خدا کا ہدایت فرمانا بطور جبر نہیں ہوا کرتا ، ورنہ لوگوں کے ترجیح دینے کا کوئی سوال ہی نہ ہوتا۔ &&(تفسیر نمونہ، کبیر امام رازی)&&>>فَھَدَیْنٰھُمْ>> ہدایت کی نسبت جب اہل ایمان کی طرف ہوتی ہے تو وہاں اس کے معنی ثابت قدمی اور منزل کی طرف رسائی ہوتے ہیں ۔ اور جہاں کفار سے اسکی نسبت ہو وہاں راہ دکھاناہوتا ہے۔ خدا کسی کو جبراَ ایمان پرنہیں لاتا ۔&&(انوار النجف)&&
  41,20,آیت نمبر ۲۰: مطلب یہ ہے کہ ایسا نہیں ہو گا کہ ایک ایک نسل کا حساب ہوتا رہے گا، بلکہ تمام اگلی پچھلی نسلوں کا حساب ایک ساتھ اکٹھا کیا جائے گا ، تاکہ جس آدمی کے اعمال کے اثرات جتنی نسلوں تک پہنچے ہیں ، اُن سب کاحساب لگایا جاسکے، اسی لیے قیامت کے دن ایک نسل کے بعد دوسری نسل آئے گی۔ اور ٹھہرائی جائے گی، مگر عدالت کا کام اُس وقت شروع ہوگا جب سب اگلے پچھلے لوگ ایک جگہ جمع ہو جائیں گے۔ &&(تفسیر کبیر، تفہیم)&& ’’پھر جب کوئی مجرم اپنے جرائم کا انکار کرےگا ،اور تمام شہادتوں اور دلیلوں کو یکسر ماننے سے انکار کردے گا پھر خدا وند عالم کے حکم سے اُس کے اپنے اعضا بولنے اورگواہیاں دینے لگیں گے۔‘‘&&(الحدیث مطابق حدیث رسولصلی اللہ علیہ وآلہ وسلم ازانس ، ابوموسیٰ اشعری ، ابو سعید خُدری ، ابن عباس از مسلم، نسائی ، ابن جریر)&&
  41,21,آیت نمبر۲۱:>>جُلُوْدِ ھِمْ>>@@ ’’اُن کی کھالیں ‘‘@@<<جلودھم‘‘>> سے مراد جسم کے اعضا مثلاَ ہاتھ ، پیر ، زُبان وغیرہ ہر اُس عمل کی گواہی دیں گے جو اُن سے متعلق ہوگا، اور کان اور آنکھیں اتمامِ حجّت کے علاوہ اپنے متعلّقہ اعمال کے بارے میں گواہ ہوں گی۔ پس عالمِ بیچارگی میں کافر لوگ حیرت سے اپنے اعضا سے کہیں گے کہ تم نے ہمارے خلاف کیوں گواہی دی، حالانکہ تم میں بولنے کی طاقت نہیں تھی۔؟ وہ جواب دیں گے کہ ہمیں اللہ تعالی نے طاقتِ گویائی دے دی ہے۔&&(تفسیر انوارالنجف)&&خدا کا فرمان ہے کہ:@@’’ جس نے ہر چیز کو گویا کر دیا ۔‘‘ @@اس سے محققین نے نتیجہ نکالا کہ ’’قیامت کے دن صرف ہمارے اعضا ہی گواہی نہ دیں گے بلکہ ہر ہر چیز بول اُٹھے گی ، جس کے سامنے انسان نے کوئی بُرا کا م کیا ہو گا جیساکہ خود خدا نے دوسری جگہ فرمایا:<<يَوْمَىِٕذٍ تُحَدِّثُ اَخْبَارَہَا بِاَنَّ رَبَّكَ اَوْحٰى لَہَا >> &&(سورۃ۹۹ الزلزال آیت ۴۔۵پارہ نمبر ۳۰)&& یعنی :@@ اُس دن زمین اپنے حالات و خبریں بیان کردے گی کیونکہ تیرے مالک نے اُسے حکم دیا ہوگا۔‘‘@@ &&(القرآن)&& &&(تفسیر کبیر)&&
  41,22,آیت نمبر۲۲:پوشیدہ گناہوں پر اعضاءجسم کی گواہی:مطلب یہ ہے کہ تم خود اپنی بے عزتی سے بچنے کے لیے لوگوں سے تو اپنے گناہ چھپاتے رہتے تھے لیکن تم یہ نہ سمجھتے تھے کہ خدا کے حکم پر خود تمھارے اپنے اعضا ہی بول پڑیں گے اور تمھارے کرتوت کی گواہیاں دینے لگیں گے، پھرتم نے اپنے گناہ اپنے اعضا سے کیوں نہ چھپائے۔ یا تم نے یہ کیوں نہ سمجھا کہ جو خدا زُبان کو بولنے کی طاقت دےسکتا ہے وہ اعضا کو بھی بُلوا سکتا ہے۔ {{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السَّلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ وآلہ وسلم نے فرمایا:’’ جو خدا کو پہچان لیتا ہے وہ گناہ نہیں کرتا ۔‘‘&&(تحف العصول)&&}}{{جناب امیر المومنین علیہ السَّلام سے روایت ہے کہ ’’یہاں کھالوں ‘‘ سے مراد جنسی اعضاء بھی ہیں ۔‘‘&&(الکافی ، من لایحضرہ الفقیہ)&&}}{{نیز آپ علیہ السلام نے فرمایا:’’ بندگانِ خدا رات  کے پردوں اور دن کے اُجالوں ‘‘ میں جو گناہ کرتے ہیں وہ اللہ تعالی سے پوشیدہ نہیں ہیں ، وہ ہر چھوٹی سے چھوٹی چیز سے آگاہ اور ہر شے پر اُس کا علم محیط ہے،تمھارے ہی اعضا اُسکے سامنے گواہ بن کر پیش ہوں گے، اور تمھارے ہی ہاتھ پا وں اُس کے لا و لشکر ہیں ، اور تمھارے ہی قلب و ضمیر اُس کے جاسوس ہیں اور تمھاری تنہائیوں ‘‘ کے عشرت کدے’’اس کی نظروں کے سامنے ہیں ۔‘‘&&(نہج البلاغہ ۱۹۷)&&}}ہمارے اعمال کےسات گواہ ہوں گے۔(۱) خود خدا کی ذات:@@’’ تم جس حالت میں بھی رہو، قرآن کی جس آیت کو بھی پڑھو کوئی بھی کام کرو، ہم خود تمھارے اوپر گواہ ہیں ۔‘‘@@&&(سورۃ یونس آیت۶۱پارہ ۱۱)&&(۲) انبیا علیہم السلام  اور اُن کے اوصیا علیہم السلام  :@@’’ پس کیا حال ہو گا جب ہم ہر اُمّت سے ایک ایک گواہ لائیں گے اور اے رسولصلی اللہ علیہ وآلہ وسلم تمھیں اُن سب پر گواہ بنائیں گے۔‘‘@@&&(سورۃ النساء آیت۴۱پارہ۵)&&{{حضرت امام جعفر صادق علیہ السلام نے فرمایاکہ:’’ ہر زمانے میں اس اُمت کے لیے ہم میں سے ایک امام ہوگا جو اُس اُمت پر گواہ ہوگا، اور حضرت محمد صلی اللہ علیہ وآلہ وسلم ہم سب پر گواہ ہوں گے۔‘‘&&(اصولِ کافی جلد۱)&&(۳) }}@@ہمارے اعضاء بدن :’’ اُس دن ، اُن کے خلاف اُن کی زُبانیں ، ہاتھ ، پا وں اُن کے اعمال کی گواہی دیں گے۔‘‘@@&&(سورۃ یٰسں ٓ آیت۶۵پارہ۲۳ سورۃ النور آیت ۲۴پارہ۱۸)&&(۴) بدن کی جِلد یا جنسی اعضاء &&(حٰمٰٓ السجدہ ۴۱ آیت ۲۱۔۲۲ پارہ ۲۴)&&(۵)فرشتے : &&(سورۃ قٓ آیت ۲۱ پارہ ۲۶ )&& (۲) زمین : &&(سورۃ الزلزال آیت ۴ پارہ ۳۰)&& (۷) زمانہ؟ {{جناب امیرالمومنین علیہ السلام  سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا کہ :’’ کوئی دن آدم علیہ السلام  پر ایسا نہیں گذرتا کہ وہ یہ نہ کہتا ہو کہ اے فرزند آدم علیہ السلام  ! میں ایک نیا دن ہوں اور تجھ پر گواہ ہوں ، مجھ میں اچھی اچھی باتیں کرتا رہ اور نیک اعمال بجالاتا رہ تاکہ روزِ قیامت میں تیرے حق میں گواہی دوں ۔‘‘ &&(سفینہۃ البحار جلد ۲)&&}}حُسنِ ظن کی جزاء نجاتِ اَبَدی:{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السَّلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا :’’سب سے آخری آدمی جس کو جہنّم میں لے جانے کا حکم ہو گا ، وہ اِدھر اُدھر دیکھے گا ۔ اللہ تعالی اُس سے پوچھے گا کہ ایسا کیوں کر رہا ہے؟وہ کہے گا کہ :’’ مالک ! میرا خیال یہ نہ تھا کہ تو مجھے جہنّم کے حوالے کر دےگا۔‘‘خدا پوچھے گا کہ :’’تیرا میرے بارے میں کیا گمان تھا‘‘؟وہ کہے گا:’’ میرایہ خیال تھا کہ تو مجھے معاف کر دے گا اور مجھے جنّت میں جگہ دے گا۔‘‘خدا حکم دے گا کہ’’ اے میر ے فرشتو! میں نے اس کے گناہ معاف کر دیے، اور اب اسے جنت میں داخل کر دو۔‘‘&&(تفسیر علی ابن ابراہیم، تفسیر نورالثقلین جلد ۴)&&}}{{اس کے بعد آنحضرت صلی اللہ علیہ وآلہ وسلم نے فرمایا : ’’ کوئی بندہ ایسانہیں ہے کہ وہ اللہ تعالی کی طرف نیک گمان کرے،اور اُس کا نیک گمان اُسے فائدہ نہ پہنچائے۔‘‘ پھر آپ صلی اللہ علیہ وآلہ وسلم نے اِسی آیت کی تلاوت فرمائی}}۔شانِ نزول آیت:بہت سے مفسرین نے اس آیت کی شانِ نزول یہ لکھی ہے کہ کفار قریش اور بنی ثقیف کے تین آدمی جن کے سر چھوٹے اور پیٹ بڑے تھے خانہ کعبہ کے پاس جمع ہوئے ۔ ایک نے کہا:’’ کیا خدا ہمیں سُن رہا ہو گا؟‘‘ دوسرے نے کہا:آہستہ بولو، اگر زور سے بولوگے تو سُن لے گا۔‘‘ تیسرے نے کہا:’’ اگر وہ بلند آواز سُن سکتا ہے تو آہستہ آواز بھی سُن سکتا ہے۔‘‘ اس پر یہ آیتیں اُتریں ۔&&(تفسیر قرطبی، مجمع البیان، تفسیر کبیر، روح البیان، بخاری مسلم ، ترمذی)&&{{آنحضرت صلی اللہ علیہ وآلہ وسلم نے فرمایا:’’ مومن کو چاہیے کہ وہ خدا سے اس طرح ڈرے کہ گویا وہ جہنّم کے کنارے پر کھڑا ہے اور جہنّم کو دیکھ رہا ہے، مگر ساتھ ساتھ خدا سے اس قدر امید معافی رکھے کہ گویا وہ جنتی ہے}}{{حضرت امامِ جعفر صادق علیہ السلام نے فرمایا :’’ خدا مومن کے گمان کے پاس پاس ہے اگر وہ خدا کے لیے اچھا گمان رکھتا ہے تو اُس کا نتیجہ بھی نیک ہوتا ہے، اگر مومن خدا کے ساتھ بدگمانی کرتا ہے تو اُس نتیجہ بُرا ہوتا ہے،‘‘ جیسکہ اس آیت میں مذکور ہے۔&&(تفسیر مجمع البیان)&&}}
  41,26,آیت نمبر ۲۶ کی تشریح: یعنی کفّار نے جب دیکھا کہ جو لوگ قرآن سُنتے ہیں ، وہ فوج درفوج کھینچ کھینچ کر اسلام قبول کر لیتے ہیں ، پس اُنھوں نے تجویز سوچی کہ جب حضورصلی اللہ علیہ وآلہ وسلم اکرم قرآن کی تلاوت کریں اُس وقت شور مچا یا جائےیا سیٹیاں اور تالیاں بجائی جائیں یا کوئی دوسرا لغومشغلہ اختیار کیا جائے، تاکہ لوگوں کے کانو ں تک قرآن نہ پہنچ سکتے اور اس طریقہ سے اسلامی تعلیم لوگوں تک نہ پہنچ سکے گی اور ہم کامیاب ہو ں گے۔&&(تفسیر انوارالنجف، قرطبی، روح المعانی)&&
  41,27,آیت ۲۷کی تشریح:>>فَلَنُذِیْقَنَّ’>> پس ہم ضرور ’’عذاب کا مزہ‘‘ چکھائیں گے‘‘ یعنی دنیا میں اُن کو سخت عذاب میں مبتلا ء کریں گے اور آخرت میں اُن کو اُ ن کے شر ک اور اعمال فاسدہ کی بدترین سزا دیں گے۔ پس دنیاوی عذاب جنگ بدر میں قتل ہونا اور قید ہونا تھا اور اُخری عذاب ہمیشہ کا جہنّم اُن کے لیے تیار ہے اور{{ تفسیر برہان میں حضرت امام جعفرصادق علیہ السلام سے منقول ہے کہ ’’ ولایت علی علیہ السلام ابنِ ابی طالب علیہ السلام کو ترک کرکے انکار کرنے والوں کافروں کو دنیاوی زندگی میں بھی سخت عذاب دیا جائے گا اور آخرت میں بھی ان کے لیے ہمیشہ کا ٹھکانا دوزخ ہے۔ کیونکہ وہ آیات الہٰی کا انکار کرتے ہیں اور آیات الہٰی ائمہ طاہرین ہیں ۔‘‘تنزیل کفارِ مکہ کے لیےتھی ۔ لیکن تاویل اہلِ بیت علیہ السلام کے دشمنوں کے لیے تا قیامت جاری رہے گی۔&&(تفسیر برہان ، تفسیر انوار النجف)&&}}
  41,29,آیت نمبر ۲۹ کی تشریح:انسان جب مصیبت میں گرفتار ہوتا ہے تو جس نے اُس پر بلا ڈالی ہوتی ہے یا جس کی وجہ سے وہ بلا وں میں گرفتار ہوتا ہے اُس پر شدید غصہ کرتا ہے اور چاہتا ہے کہ اُس سے انتقام لے ۔ اُس کے ٹکڑے ٹکڑے کر دے، اسی کیفیت میں کفار اُن لوگوں کو بُرا بھلا کہہ رہے ہیں جن کی باتوں کو مان کر اُنھوں نے دنیا میں کفر اختیار کیا ، حق کا انکار کیا یاظلم کیا تھا۔ ساتھ ساتھ وہ سخت افسوس بھی کریں گے کہ کیوں ہم نے رسولوں علیہم السلام  کی باتیں نہ سُنیں اور دنیا کی زندگی سے صحیح معنی میں فائدہ اُٹھانے کا موقع گنوا دیا۔&&(تفسیر نمونہ)&&دنیا میں تو لوگ اپنے بدمعاش لیڈروں کے اشاروں پر ناچتے ہیں ، مگر جب قیامت میں ان کو پتہ چلے گا کہ اُن بدمعاش لیڈروں نے اُنھیں جہنّم تک پہنچا دیا، تب یہی ماننے والے اُنھیں خوب خوب کوسیں گے ، اور چاہیں گے کہ کسی طرح وہ ہمارے ہاتھ آجائیں تو ہم اُن کی گردن پکڑ کر اپنے پیروں سے روند ڈالیں ، مگر اب پچھتاوے کیا ہوت جب چڑیاں چک گئیں کھیت&&(تفسیر کبیر،مجمع البیان، تفہیم)&&!!سبق:اس آیت سے معلوم ہوا کہ ہمیں ہر بڑے آدمی کی اندھی تقلید یا اطاعت نہیں کرنی چاہیے۔ بلکہ یہ دیکھنا چاہیے کہ وہ جو بات کہہ رہا ہے وہ حق ہے کہ نہیں ۔ اگر حق نہیں ہے تو اُس کی بات بالکل نہیں ماننی چاہیے، خواہ وہ کتنا ہی دولتمند یا صاحب اقتدار آدمی ہو۔ اندھی تقلید سے بڑھ کر کوئی چیز تباہ کن نہیں ہوتی، ہر معاملہ میں عقل سلیم سے کام لینا ضروری ہے۔&&(مولف)&&<<وَقَالَ الَّذِیْنَ>>{{ایک روایت میں ہے کہ جِنّوں میں سے پہلا گمراہ کُن ابلیس ہے، اور آدمیوں میں سے پہلا قابیل ہے ، اور بعض مفسرین نے کہا ہے کہ جنوں میں انسانوں میں سے ہر گمراہ کرنے والا ، اس جگہ مراد ہے ۔ پس ان کے پیچھے چل کر جو لوگ دوزخ میں جائیں گے ، وہ اللہ تعالی سے درخواست کریں گے کہ ہم اُن کو پیروں کے نیچے روندنا چاہتے ہیں جنھوں نے ہمیں گمراہ کرکے جہنّم کا راستہ دکھایا تھا۔&&(تفسیر بُرھان)&&}}!!{{اور تفسیر بُرہان میں فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السلام سے منقول ہے کہ آپ علیہ السلام  نے راوی حدیث ابن کلیب سے فرمایا: خدا کی قسم ! اس آیت میں وہی دو آدمی مراد ہیں ۔ تین مرتبہ آپ علیہ السلام نے قسم کھاکر اس فقرےکو دہرایا ۔ پھر فرمایا:’’ ہم آسمانوں اور زمین میں اللہ تعالی کے خزانہ دار ہیں ۔‘‘&&(تفسیر انوارالنجف، برہان)&&}}
  41,30,آیت نمبر۳۰:فرشتوں کا نزول کب اور کس پر ہوتا ہے؟خداوند عالم کا یہ فرمان:@@’’ اُن پر فرشتے اُترتے ہیں ۔‘‘‘@@ (۱) یعنی موت کے وقت فرشتے آکر اُن کو جنت کی خوشخبری سناتے ہیں ۔&&(تفسیر تبیان)&&(۲) دوسرا قول یہ ہے کہ ’’ایسا تین دفعہ ہوگا۔ (۱) موت کے وقت (۲) قبروں کے اندر (۳)قبروں سے اُٹھائے جانے کے وقت۔ &&(مجمع البیان)&&{{کسی نے فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السلام  دریافت کیا کہ ’’ ہمیں خبر ملی ہے کہ آپ علیہ السلام  کے پاس فرشتے آتے جاتے رہتے ہیں ؟امام علیہ السلام  نے فرمایا :’’ہاں ‘ خدا کی قسم آتے ہیں ، ہمارے فرش پر بیٹھتے ہیں ، کیا تم نے خدا کی کتاب میں یہ آیت نہیں پڑھی‘‘َ؟پھر امام علیہ السلام نے اِسی آیت کو تلاوت فرمایا۔&&(البصائر)&&}} اِستقامت :’’دین پر مضبوطی سے جمے رہے‘‘ کے معنی۔{{جناب امیرالمومنین حضرت امام علی علیہ السلام نے فرمایا :’’ جب تم نے یہ کہ دیا کہ : ’’ ہمارے پالنے والا مالک اللہ تعالی ہے‘‘ تواب اس پر مضبوطی سے جمے رہو۔ ( یعنی ) (۱) قرآن کے بتائے ہوئے اصول پر عمل کرو جس راستے پر قرآن نے چلنےکا حکم دیا ہے اُس پر چلو، اور جس طریقے سے خدا نے اپنی عبادت کا حکم دیا ہے اُسے انجا م دیتے رہو۔ (۲) خدا کے حکم کےخلاف کچھ نہ کرو۔ (۳) خدا کے دین میں کوئی نئی بات (بدعت) پیدا نہ کرو۔ (۴) اور کسی موقع پر دین کی مخالفت نہ کرو۔‘‘&&(نہج البلاغۃ خطبہ ۱۷۶)&&}}!!{{جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ کچھ لوگوں نے یہ کہا کہ ہمارا پالنے والا مالک اللہ تعالی ہے‘‘ مگر پھر اُس کے منکر ہو گئے لیکن جو شخص یہ بات کہے اور مرتے وقت تک اسی پر ثابت قدم رہے وہ وہ ہے جو اس پر قائم رہا۔‘‘&&(تفسیر مجمع البیان)&&{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام علی رضا علیہ السلام  نے فرمایا : ’’ خدا کی قسم! استقامت کا مطلب (ائمہ اہلِ بیت علیہ السلام  کی) ولایت بھی ہے جس پر تم قائم ہو۔‘‘&&(مجمع البیان)&&}}!!{{ایک شخص نے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے دریافت کیا کہ ’ ’ مجھے کوئی ایسا حکم دیجیے کہ جسے میں مضبوطی سے تھامے رہوں اور نجا ت پا جاوں ۔‘‘آنحضرت صلی اللہ علیہ وآلہ وسلم نے فرمایا : <<قُلْ رَّبِّیَ اللہ تعالی ثُمَّ اسْتَقِمْ‘‘>>(کہو میرا پالنے والا مالک اللہ تعالی ہے ، پھر اُس پر مضبوطی سے قائم رہو۔‘‘)پوچھا ’’ وہ کونسی چیز ہے جو سب سے زیادہ خطرناک ہے، اور مجھے اُس سے بچنا چاہیے‘‘؟ آن حضرت صلی اللہ علیہ وآلہ وسلم نے اپنی زُبان پکڑ کر فرمایا:’’یہ ہے‘‘&&(روح المعانی)&&}}خوف اور حُزن میں فرق اور مومن کی موت کے وقت کا منظر :خوف آئندہ کے خطروں کا ہوتا ہے اور >>حُزن<< گذرے ہوئے زمانے کے ناگوار حالات کو یاد کرنے سے ہوتا ہے۔ خدا نے یہاں خوف کا ذکر پہلے کیا ہے اور >>حُزن << کا بعد میں ۔ اس لیے کہ مومن کو زیادہ خوف آخرت کا ہوتا ہے۔&&(تفسیر نمونہ)&&فرزند رسول خداصلی اللہ علیہ وآلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا:’’ جب کوئی مومن مرتا ہے تو جناب رسول خداصلی اللہ علیہ وآلہ وسلم جناب امیرالمومنین اور جناب امام حسن علیہ السلام و امام حسین علیہ السلام اُس کے پاس پہنچ کر خوشخبری سناتے ہیں ۔&&(الحدیث انوارالنجف)&&{{فرزند رسول صلی اللہ علیہ وآلہ وسلم خدا صلی اللہ علیہ وآلہ وسلم حضرت امام حسن عسکری علیہ السلام  سے منقول ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا :’’ جب مومن کے پاس ملک الموت پہنچتا ہے اور اس مومن کو حالتِ اضطراب میں دیکھتا ہے تو کہتا ہے کہ ایسے شخص کو موت سے گھبرانے کی کیا ضرورت ہے جس سے ایک کھوٹا روپیہ چلا جائے اور لاکھوں روپے مل جائیں ، ذرا اوپر کی طرف نظر اُٹھا کر دیکھو۔ ’’تو مومن جنّت کے منازل دیکھے گا تو ملک الموت کہے گا کہ دنیاوی منازل کے بدلے یہ جنت کے مکانات اور نعمات تیرے لیے ۔ اور تیری نیک اولاد کے لیے ہیں ۔ کیا یہ تجھے پسند نہیں ہیں ؟‘‘ تو مومن خوش ہو کر کہے گا یقیناَ میں راضی ہوں ۔ پھر ملک الموت کہے گا نگا ہ اُٹھاو’’ تو مومن اپنے سامنے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم امیرالمومنین علیہ السلام  اور آلِ اطہار علیہم السلام  کو دیکھے گا پس فرشتہ کہے گا کہ یہ تیرے سردار موجود ہیں کیا ان کی رفاقت تجھے منظور نہیں ہے؟ &&(تفسیر انوارالنجف)&&}}یادرہے کہ ایمان اورنیک اعمال پر قائم رہنا ایمان کے درخت کا پھل ہےجتنا ایمان مضبوط ہو گا اُس قدر انسان ایمان اور نیک اعمال پر جما رہے گا۔ ایمان اور نیک عمل ایک دوسرے پر اثر انداز ہوتے ہیں ۔ قرآن میں دوسری جگہ بھی ایمان پر جمے رہنے پر انعام و اکرام کی عطا کا ذکر ہے۔<<وَّاَنْ لَّوِ اسْتَــقَامُوْا عَلَي الطَّرِيْقَۃِ لَاَسْقَيْنٰہُمْ مَّاۗءً غَدَقًا۱۶ۙ ‘‘>> یعنی :@@’’ اگر وہ (ایمان والے ) سیدھے راستے پر جمے رہتے تو ہم خوب خوب سیرا ب کرتے۔‘‘ &&(سورۃ ۷۲الجن آیت ۱۶پارہ ۲۹)&&&&( یعنی اپنی رحمتوں کی خوب خوب بارشیں برساتے)&&!!فرشتوں کے اترنے کا مطلب:صرف یہ نہیں کہ ہم اُنھیں آنکھوں سے بھی دیکھیں ۔ اکثر فرشتوں کا اُترنا غیر محسو س طریقے سےسے بھی ہوتا ہے جب مومن مصیبتوں اورمخالفتوں میں گھر جاتاہے توفرشتے اتر اتر کراس کے دل کو مضبوط کرتے ہیں ۔ تسلیاں دیتے ہیں ڈھارس بندھاتے ہیں اور مرد مومن غیر محسوس طریقے سے یہ سمجھ لیتا ہے کہ کوئی اُس کے دل کو تھام رہا ہے۔اس لیے بعض مفسرین کا یہ کہنا درست نہیں ہے کہ مومنین پر فرشتے صرف موت کے وقت اُترتے ہیں ۔ حقیقتاً وہ دنیا میں بھی مومن کے ساتھ ساتھ رہتے ہیں ۔ جس طرح شیاطین منکروں کو شرارتیں سمجھاتے ہیں ۔ اسی طرح فرشتے مومنین کے ساتھی بن کر اُن کو ڈھارس دیتے ہیں ۔ شیاطین منکروں کو شرارتیں سمجھاتے ہیں ، اسی طرح فرشتے مومنین کے ساتھی بن کر اُن کو ڈھارس دیتے ہیں ۔ شیاطین باطل پرستوں کو دنیا کو خوبصورت بنا کر دکھاتے ہیں ، اور فرشتے مومنین کے دلوں میں آخرت کی یاد اور محبت کو تازہ کردیتے ہیں ۔ اور وہی پیغام اُن کے دلو ں میں ڈالتے ہیں جو آیت میں بیان کیاگیا ہے کہ’’ تم کسی طرح بھی کافروں اور حق دشمنوں سے نہ ڈرو، اپنے مادّی نقصانات پر رنج نہ کرو۔ تمھیں ڈرنے کی کوئی ضرورت نہیں ، تمھار اہر نقصان خوب خوب پورا ہوگا، جنتی تمھارے منتظر ہیں ۔‘‘موت کے وقت یہی فرشتے مومن کو تسلّیاں دیتے ہیں کہ دنیا کے چھٹنے کا کوئی غم نہ کرو۔ کیونکہ جہاں تم جارہے ہو وہاں تمھارے ساتھی ہیں ، وہاں تمھارے لیے چین ہے ، تم آخرت کا بھی خوف نہ کرو ہم تمھیں جنت کی بشارت دے رہے جس کا تم سے وعدہ کیا جاتا رہا ہے۔&&(تفسیر کبیر، مجمع البیان، تفہیم)&&
  41,33,آیت نمبر۳۳:بہترین گفتگو کرنے والے کون ہوتے ہیں ۔جن میں یہ تین صفات پائی جائیں :(۱) خدا کی معرفت اور اطاعت کی طرف بُلانے والے۔(۲)صرف دوسروں کو خدا کی اطاعت کی طرف بُلانے پر اکتفا، نہ کرکے خود بھی خدا کی اطاعت یعنی نیک اعمال انجام دینے والے۔(۳)حق بات کے سامنے سر جُھکا دینے والے۔گویا یہ وہ لوگ ہیں جو ایمان کے تینوں ارکان (درجوں )پر فائز ہیں ۔ایمان کے تین درجے ہیں (۱) اقرار باللسان یعنی زُبان سے خدا کی وحدانیت اور ابدی حقائق کا اقرار کرنا ، یہ کام بھی وہ کرتے ہیں ۔ (۲) تسلیم بالقلب یعنی دل سے ماننا۔(۳) عملٌ بالارکان ۔ یعنی دین کی تعلیمات پر اعضاء وجوارح سے عمل کرنا۔ وہ یہ تینوں کام کرتے ہیں پھر اس سے آگے بڑھ کر وہ دین کے چوتھے رکن یعنی تبلیغ دین کا حق بھی ادا کرتے ہیں ۔اس میں شک نہیں کہ ان اوصاف کے اولین حامل حضرت محمد صلی اللہ علیہ و آلہ وسلم اور ائمہ اہلِ بیت علیہ السلام  ہیں لیکن جو شخص جس قدر اپنے اندر ان صفات کو پیدا کرے گا ہو اُسی قدر اس آیت کا مصداق قرار پائے گا۔&&(تفسیر نمونہ)&&<<وَمَنْ اَحْسَنُ‘‘>>اس آیت مجیدہ میں خدا وند کریم نے تبلیغ دین کرنے والوں کی مدح فرمائی اور اس کی طرف اشارہ ہے کہ تمام نیکیوں میں سے بہت بڑی نیکی خدا کے دین کی تبلیغ ہے۔ بشرطیکہ تبلیغ کرنے والا خود بھی عمل صالح کرنے والا ہو اور اللہ تعالی کی طرف دعوت دیتے ہوئے خود بھی اُس کیطرف پوری طرح جھکنے والا ہو۔اور تفسیر صافی میں بروایت عیاشی مذکورہ ہے کہ یہ آیت حضرت امام علی ابنِ ابی طالب علیہ السلام کے حق میں اُتری ہے۔&&(تفسیر انوار لنجف)&&فرشتے مومنین کو تسلیاں بھی دیتے ہیں اور پھر اب اُن کو اُن کا اصل کام بھی بتاتے جارہے ہیں جس کام کی وجہ سے آج وہ اس مقام پر پہنچے ہیں کہ فرشتے اُن کے ساتھی بننے پر فخر کررہے ہیں ۔مومن کا پہلا کام ایمان لانے کے بعد ایمان پر ثابت قدم ہو جانا ہے۔دوسرا کام یہ ہے کہ مومن خود بھی ایمان کے تقاضوں کے مطابق نیک عمل کرے اور دوسروں کو بھی اللہ تعالی کی اطاعت اور غلامی کی طرف بلائے۔اس آیت کی اہمیت کا اندازہ اس بات سے لگائیے کہ جس وقت یہ آیت اُتررہی تھی، مسلمان سارے عرب کی مخالفتوں میں دشمنیوں کامقابلہ کر رہے تھے، اُس وقت کسی کو خدا کی اطاعت کے لیے بلانا، ہر قسم کی ازیت ، مصیبت اور ذلت کو دعوت دینا تھا، ظاہر ہے اُس وقت اسلام کے عقیدے پر قائم رہنا ، پھر اُس سے نہ ہٹنا اور پھر لوگوں کو خدا کی طرف بُلانا کتنا مشکل کا تھا ، اس کا تصورکرنا آج ممکن نہیں ہے۔ مگر بہر حال آج بھی حق بات کرنا آسان کام نہیں ہوتا ، حق پر قائم رہنا ہنسی کھیل نہیں ہے۔&&(تفسیر کبیر ، مجمع البیان، کشاف، تفہیم)&&[[گفتارِ صدق مایہ آزارمی شود۔چوں حرفِ حق بلند شود دار می شود]]۔&&(عرفی)&&
  41,34,آیت ۳۴ کی تشریح:یہاں اخلاق کا بنیادی اصول بیان کیا جارہا ہے کہ نیکی اور بدی برابر نہیں ہوا کرتی ۔ بدی آخر کار انسان کا بھٹہ بِٹھا دیا کرتی ہے۔ دوسرے یہ کہ بُرائی کرنے والے اور اُس کے علمبردار اپنے دلوں میں خوب جانتے ہیں کہ وہ جھوٹے ظالم، ہٹ دھرم ، مفاد پرست ، بدمعاش ہیں ۔ یہی بات بُرے لوگوں کو خود اُن کی اپنی نگاہوں میں گرادیتی ہے، اگرچہ بظاہر نیکی بدی کے مقابلے میں کمزور دکھائی دیتی ہے۔ مگردلوں کو مسخر کرتی ہے ۔ کیونکہ نیکی بجائے خود ایک طاقت ہے آخر کار نیکی غالب آکر رہتی ہے ، اور بدی سے لوگ متنفر ہو جاتے ہیں ۔دوسری بات یہ بتائی گئی کہ نیکی کا مقابلہ صرف نیکی سے نہ کرو بلکہ اُس نیکی سے کرو جو اعلیٰ درجے کی ہو۔ یعنی اگرکوئی شخص تمھارے ساتھ بُرائی کرے تو صرف یہ نہیں کہ اُس کو معاف کردو، بلکہ اعلیٰ درجے کی نیکی یہ ہے کہ تم اُس پر احسان بھی کرو۔ اُس کا نتیجہ یہ ہوگا کہ بدترین دشمن آخر کار آپ کا جگری دوست بن جائے گا۔ گالی کے مقابلے پر دعائے خیر دینا ، آخر کار گالی دینے والےکو شرمندہ کردیتا ہے۔ کیونکہ شرارت مشکل ہی سے نیکی کے مقابلے پر کھڑی رہ سکتی ہے۔&&(تفسیر کبیر، مجمع البیان، تفہیم)&&{{اس کی سب سے بڑی مثال جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی ہے کہ جو عورت آپ صلی اللہ علیہ وآلہ وسلم کے سر اقدس پر روز کوڑا ڈالتی تھی اور ایک دن نہ ڈالا تو آپ صلی اللہ علیہ وآلہ وسلم نے جا کر اس کی عیادت کی اور فرمایا کہ ’’بتا و میں تمھارے کیا کا م آسکتا ہوں ‘‘؟یہ سُن کر وہ عورت حیران و ششدررہ گئی ۔ اُس نے کہا:’’ آج سے پہلے مجھے سب سے زیادہ نفرت اے محمدؐ! تم سے تھی اور آج کے بعد میرے پاس سب سے زیادہ محبت اورعزت آپ صلی اللہ علیہ وآلہ وسلم کے لیے ہے۔‘‘&&(شیر ابن ہشام)&&}}{{حضرت امام حسن علیہ السلام  کو ایک شامی نے دیکھتے ہی گالیاں دینی شروع کردیں ۔ آپ علیہ السلام  خاموشی سے سنتے رہے۔ جب وہ دل بھر کے گالیاں دے چکا تو امام علیہ السلام  نے بڑی نرمی سے فرمایا:’’تم شاید مسافر ہو( یعنی مجھے پہنچانتے نہیں ) اگر تم کوسواری درکار ہے تو میں سواری دینے کو تیار ہوں ، اگر مکان رہنے کے لیے چاہیے ، تو میرا مکان حاضر ہے، کھانے کی ضرورت ہے ، تو تم میرے مہمان ہو، پنا ہ چاہیے تو میں تمھیں پنا ہ دیتا ہوں ۔‘‘یہ جملے سُنتے ہی وہ گالیاں دینے والا شامی امام علیہ السلام  کے قدموں پر گرپڑا اور زندگی بھر آپ علیہ السلام  کی غلامی کرتا رہا۔&&(ناسخ التواریخ ، جلاالعیون، منتہی الامال)&&}}{{فرزند رسول خداصلی اللہ علیہ وآلہ وسلم حضرت اما م جعفر صادق علیہ السلام سے روایت ہے کہ :’’ نیکی سے یہاں مراد تقیہ کرنا بھی ہے اور بدی سے مراد بات کا فاش کردینا بھی ہے۔‘‘&&(مجمع البیان)&&}}مقصدیہ ہے کہ جہاں ایمان و عقائد کا بیان کرنا قتل ہوجانے یا برباد ہونے کا سبب ہو وہاں نیکی یہ ہے کہ حقائق کو چھپا لیا جائے ، وہاں حق کو بیان کرنے میں ، سوا برائی کے اور کچھ حاصل نہ ہوگا کہ ناحق خون بہے گا۔&&(موئف)&&ایسے مواقع پر بہترین طریقہ کار یہ ہے کہ بُرائی کا جواب اچھے الفاظ میں دے ۔ حُسن اخلاق کے ذریعہ جہالت کا مقابلہ کرے۔ عفوودرگذر سے کام لے۔ بُرائی کا جواب بُرائی سے دینا بد مزاج اور بدلہ لینے والوں کا کام ہوتا ہے۔ اس سے سرکش و گمراہ لوگوں کی سرکشی اورظلم میں اور اضافہ ہوجاتا ہے۔ اگر بُرائی کا بدلہ اچھائی سے دیا جائے تو سخت سے سخت دشمن بھی پکے دوست بن جائیں گے ۔ تبلیغ دین کا یہ بنیادی اصول ہے ۔ کیونکہ بُرائی کے جواب میں اچھا ئی کرنے سے بُرے سے بُرے آدمی کا ضمیر بھی بیدار ہو سکتاہےاور اُن کے اندر انقلاب پیدا کر سکتا ہے۔&&(تفسیر نمونہ)&&{{اس کی سب سے بڑی مثال جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کا فتح مکہ کے موقع پر جب مکہ میں فاتحانہ طور پر داخل ہوئے تو ایک مسلمان نے ابوسفیان کو دیکھ کر یہ نعرہ لگایا:’’آج انتقام لینے کا دن ہے، آج تمھاری جان و مال کے احترام ختم ہو جانے کا دن ہے، قریش کی ذلت و خواری کا دن ہے۔ ‘‘ مگر آنحضرت صلی اللہ علیہ وآلہ وسلم نے فوراَ فرمایا:<< اِذْھَبُوْ افَاَنْتُمْ الطِّلْقَآئ‘‘>> یعنی اے قریش کے لوگو!جا و تم سب آزاد ہو۔ کیونکہ آج رحمت کا دن ہے، آج قریش کی عزت کا دن ہے۔ میں تمھارے لیے وہی کہوں گا، جو یوسف علیہ السلام  نے اپنے بھائیوں کے لیے کہاتھا۔ آج تم پر کسی قسم کی ملامت نہیں ہے۔ خداتمھیں معاف کرے کہ وہ <<ارحم الرحمین>> ہے۔‘‘&&(بحارالانوار جلد ۲۱سیرت ابنِ ہشام)&&}}{{جنا ب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا اِس آیت میں خداوند عالم نے اپنے پیغمبر علیہ السلام  کو ادب سکھایا ہے ۔ کیونکہ نیکی اور بدی برابر نہیں ہوسکتیں ۔ اس لیے بُرائی کو اچھائی کے ذریعے دور کرو۔ یعنی جن لوگوں نے تم سے بُرائی کی ہے اُن سے اچھا سلوک کرو تاکہ جو تمھارے دشمن ہیں وہ بھی تمھارے پکے اور سچے دوست بن جائیں ۔&&(تفسیر علی ابن ابراہیم ، نورالثقلین)&&}}{{ایک شخص نے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے سامنے اپنے ساتھی کی غیبت کی آنحضرت صلی اللہ علیہ وآلہ وسلم نے فرمایا :’’ میں ایک ایسا کلمہ جانتاہوں کہ اگر غصے والا انسان اُس کی اپنی زبان سے جاری کرے تو اُس کا غصہ ختم ہو جائے اوروہ کلمہ یہ ہے کہ کہو: <<’’اَعُوْذُ بِاللہ تعالی مِنَ الشَّیْطَانِ الرَّجِیْم‘‘>> ( یعنی ) میں اللہ تعالی سے شیطانِ مردود کے شر سے بچنے کی پنا مانگتا ہوں ۔‘‘ اس لیے کہ خداوند عالم کا حکم ہے کہ :’’ جب شیطانی وسوسے تمھیں گھیر لیں تو خدا کی پناہ طلب کرو۔‘‘&&(تفسیر روح المعانی جلد ۲۴)&&}}{{جناب امیر المومنین حضرت امام علی علیہ السلام ابن ابی طالب علیہ السلامنے فرمایا: ’ ’ جب شیطانی وسوسے تمھیں گھیر لیں تو چاہیے کہ خدا سے پنا ہ طلب کی جائے اور یہ بھی کہا جائے کہ :’’ میں نے خدا کو دل سے مان لیا ہے اور میں اپنے دین کو اُس کے لیےخاص کرتا ہوں ۔‘‘ (یہ بات دل ہی دل میں کہے) &&(تفسیر نوار الثقلین جلد ۴)&&}}ایک تفسیر :یہ بھی ہے کہ یہاں ’’بُرائی‘‘ سےمراد سخت کلامی اور بد زبانی ، اور ’’بھلائی‘‘ سےمراد رواداری ، تہذیب ، شائستگی اور نرم کلامی ہے۔&&(تفسیر تبیان)&&{{ابو ہریرہ نے بیان کیا ہے کہ ایک دفعہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی موجودگی میں ایک شخص نے حضرت ابوبکر کو بے تحاشا گالیاں دینی شروع کر دیں ۔ حضرت ابوبکرؓ خاموشی سے گالیاں سنتے رہے، اور جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم اُن کو دیکھ کر مسکراتے رہے۔ مگر کچھ دیر کے بعد حضرت ابوبکر کا پیمانہ صبر لبریز ہوگیا اور اُنھوں نے سخت الفاظ کہے۔ جیسے ہی سخت الفاظ اُن کی زُبان سے نکلے جناب رسول خداصلی اللہ علیہ وآلہ وسلم کے چہرے پر ناراضگی کے آثار نمودار ہوئے اور آپ صلی اللہ علیہ وآلہ وسلم فوراَ اُٹھ کر تشریف لے گئے۔حضرت ابوبکرؓ آپ صلی اللہ علیہ وآلہ وسلم کے پیچھے دوڑے اور راستے میں عرض کی کہ جب تک وہ شخص مجھے گالیاں دیتا رہا آپ صلی اللہ علیہ وآلہ وسلم خاموشی سے سنتے رہے اور مسکراتے رہے۔ مگر جسیے ہی میں نے اُس کا دو بدو جواب دیا ۔ تو آپ ناراض ہو گئے۔ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ جب تک تم خاموشی سے گالیاں سُنتے رہے، ایک فرشتہ تمھارے ساتھ ساتھ تھا، اور تمھاری طرف سے جواب دیتا جا رہاتھا۔ مگر جب تم سخت الفاظ بول پڑے تو فرشتہ چلا گیا اور اس کی جگہ شیطان آگیا۔ اب میں شیطان کے ساتھ تو نہیں بیٹھ سکتا تھا۔‘‘&&(مسند امام احمد حنبل)&&}}مقصد یہ ہے کہ تمھارا مخالف کتنی ہی تم سے بد زُبانی ، سخت کلامی کرتا رہے، مگر تم بد زُبانی اور سخت کلامی سے کام نہ لو۔ ممکن ہے کہ تمھاری نرم کلامی کی وجہ سے دشمن کی سخت کلامی، نرم کلامی میں تبدیل ہو جائے، اور پھر وہ نرمی آہستہ آہستہ محبت اور الفت اور دوستی کی شکل اختیار کرے۔&&(فصل الخطاب)&&
  41,36,آیت نمبر۳۶:خدا وند عالم کا آخر میں یہ فرمان ہے کہ@@’’وہ سب کچھ سُنتا ، جانتا ہے‘‘@@ مومن کے دل میں صبر و سکون اور اطمینان کی ٹھنڈک پیدا کرتا ہے۔ یہ یقین کہ خدا ہمارے صبر و برداشت کو جانتا ہے اور مخالفوں کی بد معاشیوں اور ظلم کو دیکھ رہا ہے، اُن کی ساری باتیں بھی سُن رہا ہے، اس بات کو جاننے سمجھنے کے بعد مردِ مومن اپنا ہر معاملہ خدا کے سپرد کر دیا کرتا ہے اور خود مطمئن ہو جاتا ہے۔ کیونکہ وہ جانتا ہے کہ خدا نے یہ فرمادیا ہے کہ<<’’وَمَنْ یَّتَوَکَّلْ عَلَی اللہ تعالی فَھُوَ حَسْبُہٗ‘‘ ‏>>یعنی ۔’’ اور جو خدا پر بھروسہ کرتا ہے تو خدا خود اُس کے لیے کافی ہو جاتا ہے۔‘‘&&(سورۃ الطلاق آیت۳پارہ۲۸)&&&&(تفسیر کبیر ، تفہیم)&&عرفا نے نتیجے نکالے:(۱) شیطانی وسوسوں کا امکان کا ملین میں بھی ہوتا ہے۔ (۲) اصلاحِ اخلاق کے لیے مجاہدہ ضروری ہے (۳)ندہ مومن کو شیطان سے کسی وقت غافل نہیں رہنا چاہیے۔ (۴)اور انسان کو ہر وقت شیطان کے شر سے بچنے کے لیے خدا سے پنا ہ مانگتے رہنا چاہیے۔&&(تفسیر صافی ، مرشد تھانوی)&&اِس آیت میں ظاہر ی طور پر کلام کا خطاب تو جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی طرف ہے مگر اصل تعلیم اُمت کو دنیا مقصود ہے۔اس سے معلوم ہوا کہ جہاں کہیں بھی مخاطب رسولِ خدا صلی اللہ علیہ و آلہ وسلم ہوتے ہیں ، وہاں ہمیشہ اصل مراد آن حضرت صلی اللہ علیہ وآلہ وسلم کی ذات نہیں ہوا کرتی بلکہ اکثر اصل مقصد اُمّت کو سُنانا مقصور ہوتا ہے۔&&(فصل الخطاب)&&
  41,37,آیت نمبر۳۷:مطلب یہ ہے کہ چاند سورج نہ خود خدا ہیں ، نہ خدا کے شریک ہیں اور نہ خدا کا مظہر ہیں کہ تم انکی عبادت کرنے لگو۔ یہ صرف خدا کی قدرت اور رحمت کی نشانیاں ہیں اس لیے اِ ن پر غور و فکر کرو کہ اُن کا خالق ، مالک ، مدبر ، چلانے والا کون ہے؟ وہ ایک ہی ہو سکتا ہے۔ کیونکہ ان میں ایک ربط اور نظم پایا جاتا ہے۔ چاند سورج کا نکلنا اور پھر چھپ جانا بتا رہا ہے کہ اُن میں کوئی خدا یا خدا کا مظہر نہیں ہے۔بلکہ دونوں مجبور ولاچار ہیں ، خدا کے غلام ہیں اور اُس کے بنائے ہوئے قانون میں جکڑے ، بندھے ، دن رات دوڑ دھوپ کر رہے ہیں ۔جواب ہے مشرکوں کے لیے کہ جو یہ کہتے تھےکہ’’ ہم چاند سورج کو سجدہ نہیں کرتے بلکہ ان کے واسطے سے اللہ تعالی کو سجدہ کرتے ہیں ۔‘‘ اُن سے کہا جا رہا ہے کہ اگر تم اللہ تعالی کی عبادت کرتے ہو تو ان واسطوں کی عبادت کرنے کی کیا ضرورت ہے؟ یہ تو خود تمھارے فائدوں کے لیے دن رات بھاگ دوڑ کر رہے ہیں ۔ اگر سجدہ کرنا ہے تو براہِ راست خدا کو سجدہ کرو۔&&(تفسیر کبیر ، مجمع البیان، تفہیم)&[[نہ تو زمیں کے لیے ہے نہ آسماں کے لیے ۔جہاں ہے تیرے لیے تُو نہیں جہاں کے لیے ’’]] جو لوگ سورج ، چاند اور ستاروں کی پرستش کرتے تھے اور اپنے اس فعلِ بد کی توجیہ میں کہتے تھے کہ ’’ ہم اُن کو اللہ تعالی کی بارگا ہ میں وسیلہ قرار دیتے ہوئے اُن کی پرستش و پوجا کرتے ہیں ، درحقیقت مقصودِ عبادت اللہ تعالی ہی ہے۔‘‘کہ خداوند کریم نے اس آیت میں ان کے لیے اس نظریے کی تردید فرمائی ہے کہ چاند و سورج میری قدرت اورتوحید کی نشانیوں میں سے ہیں ، اور میری مخلوق ہیں ، تم لوگوں کا فرض ہے کہ میری اس قسم کی نشانیوں کو دیکھ کر میری عظمت و جلالت کے سامنے سربسجود ہو جا و اور مجھے لائقِ عبادت قرار دے کر میری کسی مخلوق کو میرا شریکِ عبادت نہ بنا و۔ پس اگر تمھارا یہ دعوٰی صحیح ہے کہ مقصودِ عبادت اللہ تعالی ہے تو سورج، چاند اورستاروں کی پرستش کا طریقہ ترک کرکے مجھے معبود واحد قراردیتے ہوئے صرف میری عبادت کرو، اور میری ذات کے لیے ہی سجدہ کرو۔ ’’ اور یہ آیت ، آیت سجدہ ہے ، کیونکہ اس کے اختتام پر سجدہ کرنا ضروری ہے۔<< تَعْبُدُوْنَ۔’>>’تفسیر مجمع البیان‘‘ میں ہے کہ اس امر میں اختلاف ہے کہ تلاوت کرتےہوئے کسی جگہ سجدہ کرناچاہیے۔چنانچہ اَئمہ ٔ طاہرین علیہ السلام  سے مقامِ سجدہ یہی جگہ منقول ہے ۔ اور بعض لوگوں کے نزدیک اگلی آیت کا اختتام یعنی <<لَا یَسْئَمُوْنَ>> ہے اور اُس جگہ سجدہ کرنا واجب ہے ۔اور کتاب << مَن لایحضرہ الفقیہ‘‘>> سے منقول ہے کہ سجدہ میں یہ دعا پڑھنی چاہیے۔:>>لَآ اِلٰہَ اِلَّا اللہ تعالی حَقًّا حَقًّا لَآ اِلٰہَ اِلَّا اللہ تعالی اِیْمَانًا وَّ تَّصْدِیْقًا، لَآ اِلٰہَ اِلَّا اللہ تعالی عَبُوْدِیَّۃً وَّرِقًا سَجَدْتُ لَکَ یَارَبِّ تَعَبُّدً اوَّرِقًا لَّا مُسْتَنْلِفًا وَّلَا مُسْتَکْبِرً ایَلْ اَنَا عَبْدٌ ذَلِیْلٌ خَآئِفٌ مُّسْتَجِیْرٌ>>۔ پس سجدہ سے سر اُٹھا کر اللہ تعالی اکبر کہیں ۔&&(تفسیر انوارالنجف)&&
  41,38,آیت نمبر۳۸:عرفا نے نتیجہ نکالاکہ <<تکبیر >> کے مقابلے میں خدا وند عالم کا فرشتوں کا ذکر کرنا بتاتا ہے کہ ملائکہ ، مقربین کی تعداد تکبر کرنے والے احمقوں سے کہیں زیادہ ہے۔&&(تفسیر ماجدی)&&خدا کا فرمانہے کہ :@@’’ اگر وہ غرور تکبر کی وجہ سے اپنی ہی بات پر اڑے رہیں ، تو اُن کی پرواہ نہ کرو،@@ مطلب یہ ہے کہ اے رسولؐ! اگر وہ تمھاری بات کو ماننا اپنی ذلّت سمجھیں اور اپنی جہالت ، کفر اور شرک پر ڈٹے رہیں ، تو اب اُ نکو مزید سمجھانے کی ضرورت نہیں ہے۔ آپ صلی اللہ علیہ وآلہ وسلم اُن سے منھ پھیر لیں ، اُن کی پرواہ نہ کریں ۔ کیونکہ آپ صلی اللہ علیہ وآلہ وسلم نے اپنا کام کر دیا ۔ آپ صلی اللہ علیہ وآلہ وسلم کا کام پیغام پہنچانا تھا، سو آپ صلی اللہ علیہ وآلہ وسلم نے کر دیا اب اگر سب کچھ سُننے کے بعد بھی یہ اپنے تکبّر کی وجہ سے اڑے چلے جا رہے ہیں تو یہ اس بات کے مستحق نہیں ہیں کہ آپ صلی اللہ علیہ وآلہ وسلم ان پر مزید توجہ مبذول فرمائیں ، بلکہ یہ اب اس بات کے مستحق ہیں کہ ان سے منھ پھیر لیا جائے، ان کے نہ ماننے سے حقیقت بدل نہیں سکتی ۔ اس لیے کہ پوری کائنات کا نظام جن فرشتوں کے ذریعے سےچل رہا ہے ، وہ سب کے سب اللہ تعالی کی توحید ، بندگی اور اطاعت پر قائم ہیں ۔&&(تفسیر کبیر، مجمع البیان، تفہیم)&&حضرت امام علی علیہ السلام  اور عبداللہ تعالی بن مسعود کے نزدیک>> اِنْ کُنْتُمْ اِیَّاہُ تَعْبُدُوْنَ>> پر سجدہ کرنا چاہیے، امام مالک اور امام شافعی بھی اس کے قائل ہیں ۔&&(تفسیر کبیر)&&
  41,39,آیت نمبر۳۹:>>اَھْتَزُّ<<کے معنی’’تروتازہ ہو کر جھومنا۔‘‘ اصل میں جب درخت ترو تازہ ہوتے ہیں تو جھومتے ، بل کھاتے ہیں ۔ اسی کیفیت کے لیے یہ لفظ استعمال ہوتا ہے۔&&(لغات القرآن نعمانی جلد۱)&&>>رَبَتْ<< کی معنی:بڑھنا، پھولنا، پھلنا، اُبھرنا ، نکلنا ہوتا ہے۔ یہ لفظ >>رَبْوٌ<< سے نکلا ہے۔ جس کے معنی بلند ہوئے ، پھولنے پھلنے کے ہوتے ہیں ۔&&(لغات القرآن نعمانی جلد۱، مفردات امام راغب)&&>>خَاشِعَۃً<< یعنی : بارش کی تاخیر کی وجہ سے زمین پر جو خشکی اوریبوست سی ظاہر ہوتی اُس کو >>خشوع << سے تعبیر کیا گیا ہے۔&&(تفسیر انوارالنجف)&&
  41,40,آیت نمبر۴۰:خدا وند عالم کا یہ فرمان ہے کہ :@@’’ وہ لوگ جو ہماری آیتوں کے اُلٹے سیدھے ، ٹیڑھے میڑھے مطلب پہنا رہے ہیں ، تو وہ ہم سے چُھپے ہوئے نہیں ہیں ۔‘‘@@ تو یہ آیت دھمکی ہے اُن باطل فرقوں اور علماء کے لیے جو قرآنی آیات کی اُلٹی سیدھی تاویلیں اپنی مرضی سے کرتے ہیں ۔[[خود بدلتے نہیں قرآن کو بدل دیتے ہیں]] &&(اقبال)&&&&(تفسیر ماجدی)&&اس سے یہ اُصول اخذ کیا گیا ہے کہ ہر اصل اپنے ظاہر پر محمول ہو گی، تاوقت یہ کہ کوئی قطعی دلیل یا قولِ رسول صلی اللہ علیہ وآلہ وسلم نہ مل جائے۔&&(فصل الخطاب)&&اس آیت میں اُن غالی صوفیوں کی بھی رد آگئ جو اپنی مرضی سے ایجا کردہ قرآن کی تاویلیں پیش کرتے رہتے ہیں ، اور اُن میں موشگافیاں فرماتے رہتے ہیں ۔&&(مرشد تھانوی)&&خداوند عالم کا فرمانا:@@’’جو لوگ ہماری آیتوں کے اُلٹے ، معنی پہناتے ہیں ۔‘‘@@ یعنی الحاد کرتےہیں ۔ الحاد کا مطلب سیدھی ،سادی بات میں ٹیڑھ نکالنا ہوتا ہے۔ محکم آیت کا ایک صاف ستھرا واضح مطلب ہوا کرتا ہے ، گمراہ لوگ اُس مطلب کو چھوڑ کر اُن کو اُلٹا سیدھا، ٹیڑھا غلط مطلب پہنانے کی کوشش کرتے ہیں ۔ اس طرح خود بھی گمراہ ہوتے ہین اور دوسروں کو بھی گمراہ کرتے ہیں ۔ کفارِ مکہ جہاں اسلام کے خلاف اور چالیں چل رہے تھے ، وہاں یہ چال بھی تھی کہ وہ الفاظِ قرآن کے غلط اُلٹے معنی پہنا کر اعتراضات جڑتے اور اس طرح لوگوں کو بہکاتے۔خدا وند عالم کا فرمان ہے کہ:@@’’ ایسے لو گ ہم سے کچھ چھُپے ہوئے نہیں ہیں ۔‘‘@@ یہ ایک زبردست دھمکی ہے مطلب یہ ہے کہ وہ ہم سے اور ہماری سخت سزا سے بچ نہیں سکتے ۔اور آخر میں خدا وند عالم کا یہ فرمان ہےکہ:@@’’ مگر حقیقت یہ ہے کہ یہ ایک زبردست کتاب ہے۔‘‘ @@یعنی قرآن بالکل اٹل ہے ۔ اس کو چالوں سے شکست نہیں دی جاسکتی۔ کیونکہ قرآن وہ کتاب ہے جس میں صداقت کا زور ہے، لامحدود علم کی طاقت ہے، بے پناہ زبردست حجت اوردلیل ہے ، زُبان و بیان کی شان بان ہے۔ پھر خدا وند عالم کی لامحدود طاقتیں اُس کی پشت پناہ ہیں ۔ رسولِ اکرم صلی اللہ علیہ وآلہ وسلم کی پاک و پاکیزہ بلند اخلاق و الی شخصیت اُس کی حامی ہے۔ اس لیے جھوٹے ، اوچھے، کھوکھلے پروپیگنڈے کے ہتھیاروں سے اس کتاب کو زک پہنچانا ناممکن نہیں ۔پھونکوں سے یہ چراغ بُجھایا نہ جائے گا&&(تفہیم کبیر، مجمع البیان ۔ تفہیم)&& خدا وند عالم کا یہ فرمان:@@’’ یاد رہے ، جو قیامت کے دن امن و امان کے ساتھ آئے گا۔‘‘@@ قیامت کے دن وہی شخص امن و امان کے ساتھ آئے گا جو دنیا میں صاحبِ ایمان رہا ہوگا۔ اور اُس نے دنیا میں ایمان کے عملی تقاضوں کو پورا کیا ہوگا۔&&(تفسیر ماجدی)&&اللہ تعالی نے فرمایا: << لَآ اِلٰہَ اِلَّا اللہُ‘‘>>میرے قلعہ ہے جس نے یہ کلمہ دل سے پڑھ لیا، وہ امن میں ہوگا۔‘‘ امام علی رضا علیہ السلام نے فرمایا اس کلمہ کی کچھ شرائط ہیں اور اُن شرائط میں ہماری ولایت کا دل سے مان لینا بھی ہے۔&&(بحارالانوار، عیون لاخبار)&&
  41,41,آیت نمبر۴۱:>>عَزِیْز << کے معنی:ایسا غالب جو کبھی کسی طرح مغلوب نہ ہوسکے۔ اب جبکہ یہ لفظ قرآن کے لیے استعمال ہواہے تو اس کے معنی نادر، لاجواب، نایاب کے ہوتے ہیں ۔ یعنی ایسی زبردست کتاب جس پر کوئی کبھی غالب نہ آسکے ۔&&(مفردات القرآن، زجاج)&&بعض علما نے لکھا کہ >>عَزِیْز<< سے مراد ایسی کتا ب ہے کہ جس کی مثل کوئی اور کتاب یا کلام نہ ہو۔&&(بیہقی)&&
  41,43,آیت نمبر۴۳:{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ :’’قرآن نے جو کچھ پچھلے لوگوں کو خبر یں سُنائی ہیں اُن میں کوئی حرف باطل نہیں اور نہ قرآن کی سُنائی ہوئی ان خبروں میں کوئی لفظ باطل ہو گا جو آئندہ کے بارے میں ہیں ۔‘‘&&(البیان)&&}}باطل کا لفظ حق کی ضد ہے ۔ پہلوان آدمی کو عربی میں بطل کہتے ہیں کہ وہ مد مقابل کو باطل کر دیتا ہے۔&&(امام راغب)&&مگر یہاں باطل کا لفظ مطلق ہے۔ اسے کسی خاص مصداق میں محدود نہیں کیا جاسکتا۔ پھر آخر میں خدا کا یہ فرمان ہے کہ:@@’’قرآن اُتارا ہوا ہے حکیم و حمید کا۔‘‘@@ اس سے بالکل واضح ہو گیا کہ باطل کی قرآن تک رسائی کسی طرح ممکن نہیں ۔ کیونکہ غلطی محدود یا کم علم والے سے ہوتی ہے۔ اور خدا کا علم لامحدود ہے۔ وہ حکیم مطلق ہے ۔ اس لیے اس کے کلام میں غلطی کا کوئی تصور ممکن نہیں ۔ تضاد و اختلاف بھی بھولنے یا علم کے بڑھنے سے ہوتا ہے۔ اس کا بھی خدا کے علم میں عمل دخل نہیں ۔ واضح ہو گیا کہ قرآن ہر قسم کے نقص، تضاد، تحریف ، کمی ، زیادتی سے قطعاَ پاک صاف ہے۔&&(تفسیر نمونہ)&&آیت میں آگے پیچھے کا ذکر مفہوم میں قوت پیدا کرنے کے لیے کیا گیا ہے۔ یعنی : قرآن میں کسی رُخ سے بھی کسی غلطی کا بھی کوئی امکان تصور میں بھی نہیں لایا جاسکتا۔ &&(تفسیر ماجدی)&&بعض مفسرین نے اسکا یہ مطلب بھی لکھا کہ : قرآن سے پہلے کوئی کتابِ خدا ایسی نہیں آئی کہ جسنے قرآن کو غلط قراردیا ہو۔&&(تفسیر جلالین)&&<<لَا یَاْتِیْہِ الْبَاطِلُ‘‘>> یعنی :قر آن میں کوئی باطل ، غلط بات داخل نہیں ہو سکتی۔ یعنی : کسی قسم کا جھوٹ، غلط بات کسی طریقے سے قرآن کے پاس نہیں پھٹک سکتی، نہ قرآن میں کوئی تناقض ہے ، نہ پچھلی آسمانی کتابوں کے خلاف کوئی چیز ہے، نہ آئندہ علمی دریافتوں کے خلاف کوئی بات ہے، نہ قرآن میں تضاد ہے، نہ تحریف ، کیونکہ خدا نے قرآن کے بارے میں خود فرمایا ہے:<<اِنَّا نَحْنُ نَزَّلْنَا الذِّكْرَ وَاِنَّا لَہٗ لَحٰفِظُوْنَ >>&&(آیت نمبر۹ الحجر ۱۶پارہ۱۴)&& یعنی :@@’' ہم ہی نے قرآن کو اُتارا ہے اور ہم ہی اس کی حفاظت کرنے والے ہیں ۔‘‘@@&&(کشاف، المیزان ، مجمع البیان)&&>>لَا یَاْتِیْہِ الْبَاطِلُ<<اس کی کئی تاویلیں بیا ن کی گئی ہیں ۔(۱) باطل سے مراد شیطان ہے۔ یعنی : شیطان نہ اس میں سے حق کو کم کرنے اور نہ باطل کے اضافہ پر قادرہے۔(۲) اس کو باطل کرنے والی کوئی کتاب نہیں خواہ اس سے پہلے کی ہو یا بعد کی۔(۳) گذشتہ یا آئندہ کی خبروں سے کوئی ایسی بات نہیں جو قرآن مجید میں نہ ہو۔ اور اُس کو غلط ثابت کر دیا جا سکے۔ (۴) پہلے اُترنے والی آیتوں اور بعد والی آیتوں میں کہیں بھی غلطی و بطلان کی کوئی گنجائش نہیں ہے۔ (۵)قرآن مجید کی آیات میں کسی جہت سے کوئی کمزوری و نقص نہیں ہے مثلاَ بیان ، حقائق الفاظ ومعانی ، قصص ، تاریخ ،فصاحت و بلاغت اور اوامرونواہی وغیرہ میں کہیں بھی انگشت نمائی کی جگہ نہیں ہے۔ اور یہ کتاب ہر لحاظ سے شک و ریب سے بالاتر ہے ۔ تاقیامت ضابطہ حیات ہے۔&&(تفسیر انوارالنجف)&&خداوند عالم کا فرمان ہے کہ:@@’’ قرآن ایسی زبردست کتاب ہے کہ باطل نہ اُس کے سامنے سے آسکتا ہے اور نہ پیچھے سے @@ باطل کے سامنے سے آنے کا مطلب یہ ہے کہ اگر کوئی شخص یہ چاہے کہ قرآن پر براہِ راست سامنے سے حملہ کرکے قرآن کی کسی بات کو یا تعلیم کو غلط ثابت کردے تو وہ اُس میں کامیاب نہیں ہو سکتا۔اور اس کا مطلب یہ بھی ہو سکتا ہے کہ آئندہ زمانے میں کبھی کوئی حقیقت اور صداقت ایسی معلوم نہیں ہو سکے گی جو قرآن کے پیش کردہ حقائق و تعلیمات کو غلط ثابت کردے۔&&(تفسیر کیبر، تفسیر مجمع البیان، تفہیم)&&اور باطل کا قرآن کے پیچھے سے آنے کا مطلب یہ ہے کہ صرف آج ہی نہیں پچھلے تمام زمانے میں بھی کبھی کوئی قرآن کے اُن حقائق کو غلط ثابت نہیں کر سکا جو آج قرآن پیش کر رہا ہے۔اور اس کا مطلب یہ بھی ہو سکتا ہے کہ کوئی شخص کسی ترکیب یا مکاری سے قرآن کے متن کے اندر کسی قسم کے باطل مطالب کو داخل نہیں کر سکے گا۔&&(موئف)&& یعنی نہ کبھی ماضی میں اور نہ کبھی مستقبل میں ، نہ واضح طور پر اور نہ مکاری سے قرآنی عقائد اخلاق قانون، تہذیب، تمدن، معشیت ، معاشرت ، سیاست کے ابواب میں جو قرآن نے رہنمائی فرمائی ہے وہ کبھی غلط ثابت نہ ہو سکے گی، باطل چاہے سامنے سے آکر حملہ کر ے یا ہیر پھیر کے راستوں سے چھاپے مارے، بہر حال کسی طرح سے بھی باطل قرآن کی تعلیمات و پیغامات کو شکست نہیں دے سکتا۔ قرآن کی تعلیمات کو نہ غلط ثابت کرسکیں گے اور نہ اُس کی چلائی ہوئی اصلاحی تحریک کو دبا سکیں گے۔&&(تفسیر کبیر، مجمع البیان، کشاف، تفہیم)&&کیونکہ جیساکہ اس آیت کے آخر میں فرمایا:@@’’ یہ (قرآن) ایک حکیم مطلق اور ہر قسم کی تعریف (حمد) کے لائق ذات کا اُتارا ہوا ہے۔‘‘@@ اسلیے قرآن کو کبھی غلط ثابت نہیں کیا جاسکتا۔&&(موئف)&&
  41,44,آیت نمبر۴۴:قرآن ہدایت بھی ہے اور شفا بھی: یعنی : خالی الذہن انسان کے لیے قرآن ہدایت ہے اور کفر و نفاق و شر ک کی بیماریوں میں مبتلا انسانوں کے لیے قرآن مجید شفا کا پیغام ہے۔اور جو لوگ قرآن پر ایمان نہیں لاتے گویا قرآنی ہدایت کے سننے سے اُن کے کان بہر ے ہیں اور قرآنی حقائق اُن کےسامنے تاریکی میں ہیں اور ہدایت کی آواز اُن کو یوں معلوم ہوتی ہےجس طرح کوئی دور سے بُلارہا ہو اور اُس کی آواز سمجھی نہ جا سکتی ہو۔&&(تفسیر انوارالنجف)&&آیت کا سبق یہ ہے کہ جس طرح پچھلے انبیا ء کرام علیہ السلام  کی تکذیب کی گئی اور اُنھیں تکلیفیں دی گئیں ، وہی کچھ اے رسولؐ! آپ صلی اللہ علیہ وآلہ وسلم کے ساتھ بھی ہو رہا ہے ۔ اب جس طرح پچھلے انبیاء کرام ء نے بلا وں اور مخالفتوں پر صبر کیا تھا ، آپ صلی اللہ علیہ وآلہ وسلم بھی صبر کیجیے۔&&(تفسیر ماجدی، مرشد تھانوی)&&!!ضروری نوٹ:یاد رہے کہ خداوند عالم کا چاہنا کبھی بلا وجہ نہیں ہوا کرتا۔ کیونکہ وہ حکیم مطلق اور خالقِ عقل ہے ۔ اُس کا چاہنا ہمیشہ استحقاق کی بنا پر ہوا کرتا ہے۔ اس لیے اگر خدا مومنین کو معاف کرتا ہے تواُن کے ایمان ، نیک اعمال اور توبہ کی وجہ سے معاف کر تا ہے۔ اور اگر کافروں ، حق دشمنوں کو سزادیتا ہے تو اُن کے کبر ، ضد، حق دشمنی اور ظلم کی وجہ سے ۔&&(تفسیر جلالین)&&!!محققین نے لکھا کہ خدا کی اصل صفت تو رحمت سے ڈھک لیناا ور معاف کردینا ہے لیکن منکرین اور ظالمین نے خود کو اپنے عمل سے مغفرت اور معافی کا نااہل بنالیا ، اس لیے ان کے لیے شدید دردناک سز ا رکھی گئی ہے۔&&(تفسیر ماجدی)&&چار چیزیں دل کو خراب کر دیتی ہیں :{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام موسیٰ کاظم علیہ السلام  نے فرمایا :’’ چار چیزیں دل کو خراب کر دیتی ہیں اور سنگدلی کا باعث ہو جاتی ہیں ، اور یہ نفاق کی خصلتیں اسطرح دل میں نفاق کو بڑھاتی ہے جیسے پانی درخت کو (۱) ناچ رنگ اور گانا سننا۔(۲) فحش کلام کرنا (۳) بادشاہوں کے پاس جانا(۴) شکار کی تلاش میں رہنا۔‘‘ آن حضرت صلی اللہ علیہ وآلہ وسلم نے فرمایا : ’’ جو بادشاہوں کا ہم نشین ہو ، وہ فتنہ پرداز ہو جاتاہے اور جس قدر بادشاہ سے نزدیکی ہوتی چلی جاتی ہے اُسی قدر خدا سے دوری ہو تی چلی جاتی ہے۔&&(روح الحیات علامہ مجلسی ص۵۵۹)&&}}
  41,45,آیت نمبر۴۵:حق دشمنی کی انتہاء:کفارِ عرب اور قریش کی حق دشمنی کی انتہا ملاحظہ فرمائیں کہ وہ کہتے تھے کہ محمد صلی اللہ علیہ وآلہ وسلم تو خود عرب ہیں اور عربی زُبان اُن کی مادری زُبان ہے ، اب جو یہ عربی زُبان میں قرآن پیش فرمارہے ہیں تو ہم کیسے مان لیں کہ یہ خداکا کلام ہےاور اُنھوں نے خود نہیں گھڑا ہے۔ ہم تو جب مانتے کہ یہ خدا کا کلا م ہے جب یہ کسی ایسی زُبان میں لاکر دکھاتے جسے یہ بولنا جانتے نہیں ہیں ۔ جیسے’’فارسی‘‘ میں قرآن لاتے یا رومی، یونانی زُبان میں فرفر قرآن سُناتے ، تب ہم مانتے کہ ہاں یہ کلام اُن کا گھڑا ہوانہیں ہے بلکہ خدا کا اُتارا ہوا کلام ہے ۔ کیونکہ یہ زُبانیں تو محمدصلی اللہ علیہ وآلہ وسلم جانتے ہی نہیں ہیں ، اس لیے ان زبانوں میں وہ کوئی کلام نہیں گھڑ سکتے۔گویا اُن کے اعتراض کا حاصل یہ تھا کہ عربوں کے لیے عربی زُبان میں قرآن کیوں بھیجا گیا؟اگر کسی دوسری زُبان میں قرآن آتا تو پھر یہ کہتے کہ:’’ لیجیے عرب قوم میں ایسا آدمی رسول صلی اللہ علیہ وآلہ وسلم بناکر بھیجا گیا ہے جو اُس زُبان میں ہمیں خدا کا پیغام سُنا رہے ہیں جسیے ہم سمجھ ہی نہیں سکتے ۔ بھلا جس بات کو ہم سمجھ ہی نہیں سکتے ، اُس پر کیسے ایمان لائیں ؟ اُسے کیسے دل سے مان لیں ؟&&(تفسیر کبیر، مجمع البیان، تفہیم)&&ایسوں کے لیے فارسی محاورہ ہے کہ :’’ خوئے بدرابہانہ بسیار‘‘ یعنی : ’’بُرے کام کے لیے بہت سے بہانے ہواکرتے ہیں ۔‘‘اصل میں اُن کو قرآن کو ماننا ہی نہیں تھا۔ کیونکہ قرآن اُنکے باپ دادا وں کے فاسق عقیدوں کی رد تھا، اور اُن کے مفادات پر اس کے ماننے سے ضرب پڑ رہی تھی، اس لیے نہ ماننے کے لیے وہ بہانوں پر بہانے تراشتےتھے۔ کبھی کہتے تھے یہ جادو ہے ، کبھی کہتے تھے کہ یہ گھڑا ہوا ہے، کبھی کہتے تھے کہ یہ عربی میں کیوں اترا ہے؟&&(موئف)&&خدا وند عالم کا فرمانا:@@’’ اُن کا حال تو ایسا ہے جیسے اُن کو دور سے پکارا جا رہا ہو۔‘‘@@اگر کسی کو بہت دور سے پکار ا جاتا ہے تو اُن کے کان میں آواز تو پڑتی ہے مگر اس کی سمجھ میں نہیں آتا کہ کہنے والا کیا کہہ رہا ہے؟ گویا قرآن حق دشمنوں کی ہٹ دھرمی کی انتہائی کیفیت کا نقشہ کھینچ رہا ہے کہ اگر انسان حق کو جاننا چاہتا ہے تو مخالف کی بات کو سننے اور سمجھنے کی کوشش ضرور کرتا ہے، اگر معقول بات ہوتی تو کھلے دل سے مان لیتا ہے۔ لیکن اگر متعصب اور حق دشمن ہوتا ہے تو وہ حق بات کی طرف مطلق توجہ ہی نہیں دیتا۔ اُس کو سمجھاتے وقت آپ کو یوں محسوس ہوگا کہ گویا آپ کی آواز اُ س کے کانوں کے پردوں سے ٹکرا ٹکرا کر باہر کی طرف نکل نکل آتی ہے،دل و دماغ تک پہنچنے کے لیے تمام دروازے اُس نے بند کر کے رکھے ہیں ۔ گویا آواز تو سُنتا ہے مگر اُس کی سمجھ میں کچھ نہیں آتا، اس کی وجہ اس کی بے اعتنائی اور بے پروائی اور تکبر ہے۔&&(کشاف ، تفسیر کبیر، تفہیم)&&فقہا نے تنیجہ نکالا کہ:’’قرآن کا اطلاق قرآن کے ترجمے پر بھی جائز ہے۔‘‘&&(ابوبکر جصاص)&&آیت نمبر ۴۵: خداوند عالم کا فرمانا:@@’’ اگر تمھارے پالنے والے مالک نے یہ بات پہلے ہی سے طے نہ کر دی ہوتی ‘‘@@ اس قسم کے الفاظ قرآن میں اکثر بیان کیے گئے ہیں ۔ اس کے تین معنی ہوتے ہیں :(۱) خدا نے یہ بات پہلے ہی سے طے کر دی ہے کہ انسانوں کے درمیان سارے اختلافات اور مظالم کا پورا پورا فیصلہ قیامت کے دن ہو گا۔ کیونکہ دنیا دارالعمل ہے اور قیامت دارالجزا ہے۔(۲) دوسری بات خدا نے یہ پہلے ہی سے طے کر رکھی ہے کہ خدا کے رسولوں صلی اللہ علیہ وآلہ وسلم کی برکت کی وجہ سے اُمتوں پر مختتم (آخری) عذاب نہیں آئے گا کہ جس کی وجہ سے پوری کی پوری قوم کو صفحہ ہستی سے مٹادیا جائے ، سوا اس کے کہ کوئی نبی صلی اللہ علیہ وآلہ وسلم خود ایسی بد دعا کرے۔(۳)یہ بات بھی خدا نے پہلے سے طے کر لی ہے کہ جہنم کوظالموں ، جابروں ، کافروں اور مشرکوں سے بھر دیا جائے گا۔جب بھی خدا یہ فرماتا ہے کہ :اگر تمھارے مالک نے یہ بات طے نہ کر دی ہوتی ‘‘ تو ہر جگہ اس کا مطلب انہی تین باتوں کی طرف ہوتا۔&&(تفسیر تبیان، مجمع البیان)&&آخر میں خدا وند عالم کا یہ فرمانا کہ:@@’’ حقیقت یہ ہے کہ لوگ سخت قسم کے شک میں پڑے ہوئے ہیں ۔‘‘ @@گویا خدا یہ بتلارہا ہے کہ یہ کفّار و مشرکین جو رسول اکرم صلی اللہ علیہ وآلہ وسلم کی مخالفت پر مخالفت کررہے ہیں ، یہ ان کا انکار کسی علم و یقین کی بنیاد پر نہیں ہے ، بلکہ اُن کے دلوں میں شک نے جڑ پکڑ لی ہے، اور وہ شک اس لیے ہے کہ ان میں جاہلانہ تعصب اور مفاد پرستی اپنی انتہا پر پہنچی ہوئی ہے، وہ بارباریہ شک کرتے ہیں کہ ہمارے باپ دادا جیسے عقلمند ترین لوگ کیسے غلط عقیدوں پر جم کر مر سکتے ہیں ؟دوسرا شبہ اُن کو یہ ہے کہ اگر ہمارے یہ مندر ختم ہو گئے تو ہمار ا پیٹ کیسے بھر ےگا؟عربوں کا یہ شک اُن کی باربار مختلف باتوں کے بنانے سے ظاہر ہو جاتا تھا۔ مثلاَ ایک طرف تو وہ یہ کہتے تھے کہ یہ قرآن ایسا بے مثل کلام ہے جو ہم نے کبھی کسی بڑے سے بڑے شاعر سے بھی نہیں سُنا ۔ دوسری طرف وہ یہ کہتے تھے کہ:’’ محمدصلی اللہ علیہ وآلہ وسلم دیوانہ ہے، پاگل ہے (معاذ اللہ) اُس کو مرگی کا مرض ہے اور اُس پر شیاطین اُترتے ہیں ۔ (نعوذ باللہ) کبھی جب قرآن کی زبردست تاثیر کو دیکھ کر بلبلا بلبلا اُٹھتے تھے تو کہتے تھے کہ یہ جادو ہے جو ہم پر چل گیا ہے۔ایک طرف تو کہتے تھے کہ محمدصلی اللہ علیہ وآلہ وسلم صادق و امین ہے، دوسری طرف کہتے تھے کہ اُس نے یہ کلام خود گھڑلیا ہے ، اور کہتا ہے کہ خدا کی طرف سے اُترا ہے۔ایک طرف تو کہتے تھے کہ محمدصلی اللہ علیہ وآلہ وسلم بے غرض قسم کا شریف آدمی ہے، دوسری طرف جا کر کہتے تھے کہ یہ دولت ، اقتدار اور نام و نمود کے لیے دوڑ دھوپ کر رہا ہے۔اُن کی یہ تضاد بیانی از خود واضح طور پر بتارہی ہے کہ وہ شک کی کیفیت میں گرفتار تھے اُنھیں خود یقین نہیں کہ محمد صلی اللہ علیہ وآلہ وسلم خدا کے سچے رسول صلی اللہ علیہ وآلہ وسلم ہیں ۔ کیونکہ اُنھوں نے زندگی بھر اپنی آنکھوں سے دیکھا تھا کہ محمدصلی اللہ علیہ وآلہ وسلم کوئی نفس پرست، مفاد پرست یا خود غرض قسم کا آدمی نہیں ہے ۔ اُس کی ساری زندگی ہر قسم کے عیب سے پاک رہی ہے، اور ہمیشہ نیکی اوربھلائی کے کاموں میں مصروف رہتا ہے۔ کبھی اپنی نفسانی غرض سے کوئی کام نہیں کرتا۔&&(تفسیر کبیر، کشاف ، مجمع البیان انوار النجف ، تفہیم)&&<< فَا خْتُلِفَ فِیْہِ‘‘>> یعنی آپ صلی اللہ علیہ وآلہ وسلم سے پہلے حضرت موسیٰ علیہ السلام کو کتاب دی گی تو بعض مان گئے اور بعض لوگ انکار پر ڈٹ گئے ،اور اس قسم کا نظریاتی اختلاف ہمیشہ ہوتا رہا ہے۔ لہٰذا گھبرانے کی بات نہیں ۔ آپ صلی اللہ علیہ وآلہ وسلم بے فکر ہو کر تبلیغ میں مشغول رہیں ۔ کوئی مانے تو اُس کو فائدہ ہو گا، جو نہ مانے گا جہنم میں جائے گا۔ اگر ایک وقت تک عذاب کے موخر کرنے کا فیصلہ نہ ہو چکا ہوتا تو ان پر بھی عذاب بھیج دیا جاتا۔ تاہمآپ صلی اللہ علیہ وآلہ وسلم ان کے ضد وانکار کی پرواہ کیے بغیر امور تبلیغ کو انجام دیتے رہیں ۔&&(تفسیر انوار النجف)&&
  41,46,آیت نمبر۴۶:خدا وند کریم عادلِ مطلق ہے۔مطلب یہ ہے کہ : اے رسولؐ! تمھارا پالنے والا مالک کبھی ظلم نہیں کرتا ، اس لیے وہ کبھی ایسانہ کرے گا کہ نیک لوگوں کی نیکیوں کو ضائع کر دے اور بُرے لوگوں کو اُن کی بُرائی کا بدلہ نہ دے ۔ اسی لیے اگلی آیت میں فرمایا:’’ اُس قیامت کی ساعت کا علم اللہ تعالی ہی کی طرف لوٹتا ہے۔‘‘ یعنی : خدا کا عدل قیامت کے دن ظاہر ہو کر رہے گا، اس لیے کہ وہ اپنے بندوں پر ظلم نہیں کیا کرتا۔‘‘&&(تفسیر کبیر، تفہیم)&&خداوند عالم سے ظلم کا تصوّر بھی محال ہے ۔ اس لیے کہ فرمایا:@@’’ وہ اپنے بندوں پر ظلم نہیں کرتا۔‘‘ @@یعنی : ساری مخلوق اُس کی غلام ہے، اُس کو اپنی مخلوق سے کوئی دشمنی نہیں ہے کہ وہ اُن پر ظلم کرے ، بلکہ سارے عالم پر اسکی رحمتیں اور عنایتیں ہیں ۔دوسرے یہ کہ وہ ارحم الراحمین ہے۔ سب رحم کرنے والوں سے زیادہ رحم کرنے والا ہے۔ جو ایسا ہو، وہ اپنے بندوں پر ظلم کیوں کر ے گا؟تیسرے یہ کہ ظلم وہ کرتا ہے جس کا مفاد اٹکا ہوا ہوتا ہے۔ خدا بے نیاز ہے، اُس کو کسی سے کوئی غرض نہیں ہے کہ اُس غرض کو پورا کرنے کے لیے اُس پر ظلم کرے۔چوتھے یہ کہ خدا ہر عیب سے پاک ہے ، اور ظلم سے بڑا کوئی عیب نہیں ہے۔پانچویں یہ کہ ظلم وہ کرتاہے جسے دوسروں کے حقوق کا پورا علم نہیں ہوتا ، جبکہ خدا کا علم لامحدود ہے، اور ہر کھلی ہوئی اور چھپی ہوئی بات کو پوری پوری طرح جانتا ہے۔محققین نے اس سے یہ نتیجہ نکالاکہ اس آیت سے خداوند عالم کا عادل مطلق ہونا پوری طرح ثابت ہے۔&&(فصل الخطاب)&&{{فرزند رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے کسی نے دریافت کیا کیا خدا بندوں کی طاقت سے زیادہ اُن پر ذمہ داری ڈالتا ہے‘‘؟امام علیہ السلام  نے فرمایا:’’ وہ ایسا کیسے کرسکتا ہے جبکہ اُس نے کہہ دیا کہ:’’ تمھارا مالک کسی پر ظلم نہیں کرتا۔‘‘سائل نے پھر امام علیہ السلام  سے دریافت کیا :’’ کیا خدا بندوں کو گناہ پر مجبور کرتا ہے؟‘‘امام علیہ السلام  نے فرمایا:’’نہیں ، بلکہ خدا چھوٹ دیتا ہے کہ ، اور مہلت پر مہلت دیتا ہے تاکہ وہ اپنے گناہوں سے توبہ کر لیں ۔‘‘پھر امام علیہ السلام  نے فرمایا: ’’ جوشخص یہ سمجھتا ہے کہ خدا بندوں کو گناہوں پر مجبور کرتا ہے وہ (جبریہ عقیدہ رکھتا ہے) یا یہ سمجھتا ہے کہ خدا اُن کی طاقت سے زیادہ اُن پر ذمہ داریاں ڈالتا ہے۔ اُس کے ہاتھ کا ذبخ شدہ جانور کا گوشت نہ کھا و۔نہ اُس کی گواہی قبول کرو، نہ اس کے پیچھے نماز پڑھو، نہ اُسے زکوٰۃ میں سے کچھ دو( یعنی اُس کو مرتد سمجھو۔)&&(عیون الاخبار الرضا علیہ السلام  ، تفسیر نورالثقلین)&&}}{{جناب امیرالمومنین حضرت اما م علی ابنِ ابی طالب علیہ السلام  نے فرمایا: ’’ خدا کی قسم! نعمتیں اُس وقت تک نہیں چھینی جاتیں جب تک لوگ گناہ نہیں کرتے، کیونکہ خدا اپنے بندوں پر قطعاَ کوئی ظلم نہیں کرتا۔‘‘پھر فرمایا : ’’ اگر لوگ بلا وں کے اُترنے اور نعمتوں کے چھینے جانے کے موقع پر بھی سچے دل سے اپنے پالنے والے مالک کی طرف توجہ کریں اور خدا سے محبت بھر ے دل کے ساتھ خدا کی بارگاہ میں اپنی مشکل کشائی کی درخواست کریں ،تو خدا نھیں چھینی ہوئی نعمتیں واپس پلٹا دے گا۔ اور اُن کے ہر بگڑے ہوئے کام کو ٹھیک کر دے گا۔‘‘&&(نہج البلاغہ خطبہ ۸۸)&&}}آیت کا اصل مقصد اور پیغام(۱) خدا کے عادلِ مطلق ہونے کو ثابت کرنا ہے۔(۲) {{جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کو تسکین دینا ہے کہ آپ صلی اللہ علیہ وآلہ وسلم حق دشمنوں کی ضد، کج بحثیوں اور حق دشمنی سے نہ گھبرائیں ، اس لیے کہ جو بدی کرے گا اُس کاوبال اُسی پر ہوگا۔ جیسی کرنی ویسی بھرنی۔(۳) اسلام کا بنیادی پیغام شخصی ذمہ داری ہے، جو یہاں دیا جا رہا ہے۔ (۴) نیک لوگوں سے صرف نسبی یا محبت کے دعوے کا تعلق کافی نہیں ہوتا ۔ نیک لوگوں سے تعلق اتنا استوار ہوتا ہے جتنی عملاً اُن کی پیروی کی جاتی ہے۔ (۵)ہر شخص اچھی طرح سے یہ سمجھ لے کہ جو شخص اچھے اچھے کام کرےگا، وہ خود اپنے کو فائدہ پہنچائے گا ۔ کیونکہ خدا ہر نیکی کا نیکی کرنے والے کو بھرپور اجر عطا فرمائے گا، اور ہر بُرائی کرنے والا اپنی بُرائی کی سزا پائے گا ، کیو نکہ خدا ظالم نہیں ہے کہ نیکیوں کو نیکی کا بدلہ نہ دے یا کم دے، اور ظالموں کو اُن کے ظلم کی سزا نہ دے۔&&(تفسیر ماجدی، تفسیر کبیر، مجمع البیان)&&علماءِ علم کلام نے اس آیت سے یہ نتیجے نکالے کہ:۱۔اسلامی تعلیمات کی ایک بنیادی حقیقت شخصی ذمہ داری ہے۔۲۔نیک بزرگوں کی طرف محض نسبی محبت کا تعلق رکھنا کافی نہیں ہے۔۳۔نیز یہ کہ خدا عادلِ حقیقی ہے۔&&(تفسیر ماجدی)&&
  41,47,آیت نمبر۴۷: اس ساعت یا وقت  سے مراد قیامت کا وقت یعنی وہ وقت جب برائی کرنے والوں کو برائی کا اور نیک لوگوں کو نیکی کا بدلہ دیا جائے گا۔ مظلوموں کی داد رسی کی جائے گی اور ظالموں کو ان کے کرتوت کی سزا دی جائے گی ۔ ]]از مکافاتِ عمل غافل مشو ۔ گندم از گندم بروید جو ز جو[[ ۔ اور خدا وند حکیم کا یہ فرمانہ کہ @@،، اس وقت کا علم اللہ تعالی ہی کی طرف لوٹتا ہے ،،@@ یعنی اللہ تعالی کے سوا کوئی نہیں جانتا کہ وہ فیصلہ کا وقت کب آئے گا ؟ یہ جواب کفّار کے اس چیلنج کا دیا جا رہا ہے کہ وہ کہتے تھے جو بار بار کہا جا رہا ہے کہ برائی کا انجام برا ہوا، تو آخر وہ کب ہوگا ؟ پھر خدا وند عالم کا یہ فرمانا@@’’ وہی خدا وند حکیم جانتا ہے کہ کون سے پھل پھول شگوفے نکلیں گے اور کون سی مادہ حاملہ ہوگی اور کس نے بچّہ جنا ہے ،،@@ گویا خدا وند حکیم یہ بتلا رہا ہے کہ صرف قیامت کے دن ہی کی بات نہیں ، بلکہ تمام غیبی باتوں کا علم صرف اور صرف اللہ تعالی ہی کو ہے۔ کوئی دوسرا عالم الغیب نہیں ہے (یہ اور بات ہے کہ خدا وند حکیم خود کسی کو غیب کا کچھ علم عطا فرمادے) دوسرے یہ کہ ہر بات کے تمام جزئیات کا تفصیلی علم خدا وند حکیم ہی کو حاصل ہے کہ کون کیا کر رہا ہے ؟ اور کون سی غلطی کررہا ہے؟ اس لیے کسی کو خدا وند حکیم کی خدائی میں من مانی نہیں کرنی چاہیے اور نہ کسی کو خدا وند حکیم سے بے خوف ہونا چاہیے ۔ آخری مطلب یوں ہے کہ اے احمقو ! تم قیامت کے آنے کی تاریخ معلوم کرنے کے چکر میں کیوں پڑے ہوئے ہو ، اگر فکر کرنی ہے تو اس بات کی فکر کرو کہ جب وہ وقت آئے گا تو تمھیں تمام بدمعاشیوں کی بڑی سخت سزا بھگتنی پڑے گی۔ &&(تفسیر کبیر۔ مجمع البیان)&&{{ایک دفعہ جناب رسول صلی اللہ علیہ وآلہ وسلم سفر پر جارہے تھے ۔ راستے میں ایک شخص نے آپ کو روک کر پوچھا کہ: ’’ قیامت کب آئے گی ؟،، آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا : ’’ خدا وند حکیم کے بندے قیامت تو بہرحال آنی ہی آنی ہے ۔ تو یہ بتا کہ تو نے اس کے لیے کیا تیاری کی ہے؟،، &&(صحاح ستہ ، سنن اور مسانید میں حد تواتر کے ساتھ)&&}}آخر میں خداوند عالم کایہ فرمان ہے کہ @@جب خدا وند حکیم قیامت کے دن مشرکوں سے پوچھے گا کہ بتاو میرے وہ شریک کہاں ہیں ؟ تو مشرک کہیں گے : ’’ آج ہم میں سے کوئی اس کی گواہی دینے والا نہیں ہے ۔ ،،@@ یعنی مشرک یہ کہیں گے کہ اب ہم پر یہ حقیقت پوری پوری طرح کھل چکی ہے کہ ہم جنھیں خدا وند حکیم کا شریک سمجھ بیٹھے تھے وہ سرا سر غلط تھا۔ اب ہمارے درمیان کوئی ایک شخص بھی اس بات کا قائل نہیں ہے کہ تیری خدائی میں تیرا کوئی شریک ہوسکتا ہے۔ مشرکوں کا یہ کہنا کہ ’’ ہم عرض کرچکے ہیں ، بتا رہے ہیں کہ مشرک قیامت کے دن بار بار مختلف مراحل میں خدا وند حکیم کی وحدانیت کا اقرار کریں گے شرک کی نفی کا اعتراف کریں گے ۔ بار بار اعتراف کریں گے واقعاًحق وہی تھا جو انبیاء کرام علیہم السلام لائے تھے۔ ہماری غلطی تھی کہ ہم اپنی جہالتوں پر اڑے رہے تھے ۔ مگر وہاں ان کا یہ اعتراف و اقرار انھیں کوئی فائدہ نہ پہنچا سکے گا۔ اس لیے کہ عقل کا امتحان ختم ہوچکا ہوگا۔ ہر غیب ظاہر ہوچکا ہوگا۔ اس لیے اگلی آیت میں فرمایا: @@’’ اس وقت ان کے وہ سارے جھوٹے خدا وند حکیم ان کے پاس سے غائب ہوجائیں گے جنھیں یہ اس سے پہلے پکارتے تھے تب وہ سمجھ لیں گے کہ اب ان کے لیے ہوجائیں گے جنھیں یہ اس سے پہلے پکارتے تھے تب وہ سمجھ لیں گے کہ اب ان کے لیے پناہ لینے ( یعنی عذاب خدا وند حکیم سے بچنے ) کی کوئی جگہ نہیں ہے ۔ ،، @@ پھر وہ اپنے گناہ اور شرک کے اقرار کے بعد جہنم واصل کر دیے جائیں گے۔ خس کم جہاں پاک ۔ &&(تفسیر کبیر ۔ تفہیم)&& غرض اس آیت میں خدا وند حکیم کی صفتِ علم کو بیان کیا گیا ہے ۔ خدا وند حکیم کا علم کامل اور ہر چیز کو گھیرے ہوئے ہے۔ اس بات کا علم بھی صرف خدا وند حکیم ہی کو ہے کہ قیامت کب آئے گی ؟&&(تفسیر ماجدی)&&اور خدا وند حکیم کا فرمانا کہ@@ ’’ بتاو میرے شریک کہاں ہیں؟ ،، @@تو میرے شریک سے مراد وہ ہیں جن کی لوگ خدا وند حکیم کو چھوڑ کر عبادت کیا کرتے تھے۔ &&(تفسیرصافی ۔ تفسیر قمی)&&مشرکوں کا یہ کہنا : ’’ اب ہم میں سے کوئی نہیں ہے جو ان کے خدا وند حکیم ہونے کی گواہی دے ۔ ،، اس کا مطلب یہ ہے کہ اب ہم میں سے کوئی بھی ان کو تیرا شریک ماننے کو تیار نہیں ہے۔ &&(مدارک)&& کیونکہ اب قیامت کے دن ہم پر تمام حقیقت کھل چکی ہے اور شرک کرنے کے بدترین نتائج ہم نے خود اپنی آنکھوں سے دیکھ لیے ہیں اس لیے ہم نے اب ان جھوٹے خداوں سے علیٰحدگی اختیار کرلی ہے۔ اور اب وہ جھوٹے خدا وند حکیم ہمیں کہیں دکھائی بھی تو نہیں دے رہے ہیں ۔ وہ تو گدھے کے سینگھوں کی طرح ہمارے پاس سے رفو چکر ہوچکے ہیں ۔ &&(تفسیر صافی)&&
  41,48,آیت نمبر۴۸: یعنی مایوسی کے عالم میں مشرک قیامت کے دن ہر طرف نظریں دوڑائیں گے کہ جن کی عمر بھر سیوا کرتے رہے شاید ان میں سے کوئی مدد کے لیے آجائے اور ہمیں خدا وند حکیم کے عذاب سے چُھڑالے یا کم سے کم ہماری کچھ سزا ہی کم کرادے۔ مگر انھیں کسی طرف سے کوئی مدد نہیں ملے گی۔ یہ ان کی انتہائی بے چارگی کی تصویر کشی کی گئی ہے ۔ &&(تفسیر کبیر۔ مجمع البیان ۔ تفہیم)&&’’[[ اس طرح تو ہوتا ہے اس طرح کے کاموں میں ۔ ]]آخر میں مشرکوں کے لیے خدا وند عالم کا یہ فرمان ہے کہ :@@ ’’ تب وہ لوگ سمجھ لیں گے،، @@یہاں >> ظن << کا لفظ استعمال ہوا ہے ۔ یہاں ظن کے معنی اندازے کے نہیں ہیں بلکہ پوری طرح سمجھ لینے اور یقین کرلینے کے ہیں ۔ قرآن میں اور کئی مقامات پر بھی ظن کے معنی یقین کرنے کے آئے ہیں ۔ &&(قرطبی ۔ روح ۔ ابن کثیر۔ تفسیر کبیر)&&{{امام راغب نے لکھا کہ >>ظن << اس عقیدے اور نظریے کو کہتے ہیں جو دلیل اور قرینے سے حاصل ہو۔ یہ عقیدہ کبھی یقین بن جاتا ہے اور کبھی صرف کمزور گمان بن کے رہ جاتا ہے۔ &&(مفرداتِ امام راغب)&&}}
  41,49,آیت نمبر۴۹: یہاں انسان سے مراد غیر ترتیب یافتہ ناشکرا انسان ہے جس کا دل ایمان کے نور سے منور نہ ہوا ہو۔ ایسے لوگ زندگی بھرمال ، دولت، اقتدار ، جنسی خواہشات ہی کے چکروں میں پھرتے رہ جاتے ہیں ۔ ان کے پاس وہ پاک روح یا عقل نہیں ہوتی جو مادیات کے آگے کچھ دیکھ سکیں ۔ ایسے لوگوں کے پاس جب دنیا کی نعمتیں آتی ہیں تو وہ خوش و خرم مسرور بلکہ مغرور ہوجاتے ہیں ۔ مگر جب دنیا کی نعمتیں ان سے منہ موڑ لیتی ہیں پھر اُن کے پاس کوئی چراغ نہیں ہوتا جو ان کے اندھیروں کو روشن کرسکے اور اُمید کی کوئی کرن پیدا کرسکے۔ پھر یہ لوگ انتہائی نا امید frustrated ہوجاتے ہیں اور اکثر خود کشی تک نوبت پہنچ جاتی ہے ۔ &&(تفسیر نمونہ)&&’’ >>یوس << یاس کے معنی ہے اور فنوط کے معنی نا امیدی جس کا چہرے کے رنگ سے اظہار ہوتا ہے ۔ &&(تفسیر المیزان ۔ تفسیر کبیر ۔ روح المعانی)&&علامہ طبرسی نے لکھا کہ یاس اچھائی سے نا امید ہونے کو کہتے ہیں اور قنوط رحمت سے ناامید ہونے کوکہتے ہیں ۔ &&(مجمع البیان)&&مغروروں کے لیے قرآن نے بتایا کہ:@@خوشی کے عالم میں وہ کہتا ہے ’’ میں ہرگز نہیں سمجھتا کہ قیامت برپا ہوگی (اور اگر برپا کی بھی گئی) تو میں اپنے مالک کی طرف جاوں گا اور اس سے بہتر اور اعلیٰ مقام پاوں گا ۔ ،،@@ &&(سورہ کہف ۱۸ ، ۳۵ ، ۳۶ ۔ پ۱۵)&& عام چھچورا انسان ہمیشہ اپنی بھلائی ، خوش حالی ، ترقی ، روزی کی وسعت ، تندرستی ، بال بچوں کی خیریت اور فائدوں کی دعا کرتا ہی چلا جاتا ہے اور کبھی تھکتا نہیں ۔ مگر جیسے ہی کوئی آفت آجاتی ہے یا نقصان ہوجاتا ہے تو خدا وند حکیم کی رحمت سے بالکل مایوس ہوکر لوگوں کے سامنے خدا وند حکیم کے لیے اُلٹی سیدھی باتیں بنانے لگتا ہے۔ یا لوگوں کی خوشامدیں کرنے لگتا ہے۔ پھر دنیا کا عیش اور کامیابیوں کے پاتے ہی آپے سے باہر ہو جاتا ہے۔ کیونکہ انسانوں کی بہت بڑی اکثریت اسی قسم کے طرز عمل کا شکار ہے۔ اس لیے اس کو مطلق انسان کی صفت قرار دیا گیا ہے۔ لیکن دراصل یہ ایک چھچورے ، کم ظرف ، کم عقل، کمزور دین ایمان والے انسان کا بیان ہے کہ اگر زندگی میں کامیابیاں ملنے لگیں تو : ’’ زندگی زندہ دلی کا نام ہے ۔ ،، اور اگر کچھ ناکامیاں ہوگئیں تو : ]] زندگی نام ہے مرمر کے جئے جانے کا[[، اللہ تعالی میاں پر پھبتیاں کسی جانے لگیں ۔ ایسے ہی کم ظرف ، چھچورے آدمی کی اگلی آیت میں صفت یہی بیان کی گئی ہے کہ جب اسے خدا وند حکیم کی نعمتیں ملتی ہیں تو کہتا ہے کہ مجھے میری اہلیت علیہم السلام اور قابلیت کی بناء پر ملا ہے۔ یہ سب کچھ میرا حق ہے۔ اللہ تعالی کے سامنے اکڑ جاتا ہے ۔ مگر جب مصیبتوں میں گرفتار ہوتا ہے تو لمبی لمبی دعائیں مانگنے لگتا ہے ۔ &&(تفسیر کبیر ۔ تفہیم ۔ مجمع البیان ۔ انوار النجف)&&اصل بات یہ ہے کہ مومن کو اپنی ہر غیر اختیاری اور تکوینی مصیبت کے برداشت کرنے پر خدا وند حکیم سے اجر ملنے کا یقین ہوتا ہے اور اس کا تمام تر بھروسہ بھی خدا وند حکیم پر ہی ہوتا ہے اس لیے وہ مصائب کا مقابلہ سکون و وقار کے ساتھ کرتا ہے۔ لیکن جو شخص خدا وند حکیم پر ایمان ہی نہیں رکھتا وہ اس دولتِ سکون سے محروم رہتا ہے۔ زخم کھاتا ہے مگر اس کے زخم پر ایمان کا مرہم نہیں لگتا۔ اس لیے وہ حسرت و یاس میں تڑپتا ہی رہتا ہے&&(تفسیر ماجدی)&& مگر یاد رہے کہ یہاں انسان سے مراد نا شکرا ، کافر ، حریص ، انسان ہے ۔ &&(قرطبی۔ معالم بقول سدی)&& اور یہاں خیر یعنی بھلائی سے مراد ، دولت ، عزت ، صحت اور حکومت ہے ۔ &&(قرطبی ۔ ابن کثیر)&&!!{{حضرت علی علیہ السلام  نے دعا فرمائی ہے کہ:’’ ہمارا خدا وند حکیم سے یہی سوال ہے کہ وہ ہمیں اور تمھیں ایسے لوگوں میں قرار دے کہ جنھیں نعمتیں مست اور مغرور نہیں بنا دیتیں اور کوئی کامیابی انھیں خداوند عالم کی اطاعت سے نہیں روکتی ، تاکہ موت آنے پر انھیں کسی قسم کی کوئی شرمندگی نہیں ہوتی ۔ ،، &&(نہج البلاغہ ۔ خطبہ ۶۴)&&}}
  41,50,آیت نمبر۵۰:ناشُکرے کافر کا یہ کہنا کہ ’’ اگر میں آخرت کی طرف لوٹایا گیا تو وہاں بھی میرے لیے بھلائی ہی بھلائی ہوگی۔ میں وہاں بھی مزے ہی اُڑاوں گا ۔ ،، مطلب یہ کہ اول تو قیامت کے قائم ہونے کا کوئی سوال ہی نہیں ہے۔ لیکن بفرضِ محال اگر قیامت قائم ہوگئی تو میں اتنی بڑی توپ ہوں کہ خدا وند حکیم کو میری عزّت کرنی ہی پڑے گی۔ کیوں کہ میں ہوں ں ہی بہت قابل ، لائق فائق ، عقلمند ، اعلیٰ قسم کا انسان۔ اس کا ثبوت یہ ہے کہ مجھے دنیا دولت ، عزّت ، قوّت ، حکومت سب کچھ ملا ہے۔ یہ سب مجھے دنیا میں اسی لیے تو ملا ہے کہ میں ان سب کا مستحق ہوں ۔ تو پھر یہی حق مجھے آخرت میں بھی حاصل ہوگا ۔ &&(تفسیر صافی)&& مگر اس احمق کو یہ معلوم ہی نہیں کہ دینا دارالامتحان ہے یہاں جو کچھ ملتا ہے۔ امتحاناً ملتا ہے۔ اتفاقاَ نہیں ملتا ۔ استحقاقاَ نہیں ملتا۔ یہ مال اولاد سب امتحان کے پرچے ہیں جو ہر کس ونا کس کو دیے جاتے ہیں۔ ان امتحانی پرچوں کو ٹھیک ٹھیک حل کرتا ہے اس کے بعد اس کو کامیابی کی ڈگری (سند) دی جاتی ہے۔ اس لیے دنیا میں کسی کو مال ، اولاد ، عزت و اقتدار کا مل جانا ، اس بات کی ہرگز ہرگز دلیل نہیں ہوا کرتا کہ وہ خدا وند حکیم کا پسندیدہ ہے ، خدا وند حکیم کا چہیتا ہے یا بڑا طرّم خان ہے کہ بس اب آخرت میں بھی خدا وند حکیم اسے ہر وہ چیز دے گا جو دنیامیں دی ہے۔ ایسا کوئی رنگ نہیں ہے۔ یہ فکر قطعاً غلط اور بے سروپا ہے۔ [[ایں خیال است و محال است و جنوں]] &&(مولف)&&
  41,51,آیت نمبر۵۱:یہاں پر یہ سوال پیدا ہوتا ہے کہ ایک طرف تو خدا وند حکیم یہ فرما رہا ہے کہ وہ چھچورا قسم کا آدمی نعمتیں چِھن جانے پربالکل مایوں ہوجاتا ہے۔ اور یہاں یہ فرمارہا ہے کہ وہ لمبی لمبی دعائیں کرنے لگتا ہے ۔ بظاہر یہ تضاد معلوم ہوتاہے۔ اس کا جواب اس طرح دیا گیا کہ !!:جواب نمبر۱ :۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ کچھ لوگ تو مشکلات میں بالکل مایوس ہوکر بیٹھ جاتے ہیں اور کچھ لمبی دعائیں مانگنے لگتے ہیں ۔ &&(تفسیر روح البیان ۔ جلد ۸)&&!!جواب نمبر۲ :۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ کچھ مفسرین نے لکھا ہے کے مایوسی سے مراد تمام ذرائع سے نا امید اور مایوسں ہو جانا ۔ مگر خدا وند حکیم سے مایوں نہیں ہوتے اس لیے لمبی لمبی دعائیں کرتے ہیں ۔ &&(تفسیر المیزان)&&مگر یہ تفسیر مناسب نہیں ہے۔ کیونکہ ظاہری اسبا ب سے مایوس ہوکر خدا وند حکیم سے دعائیں کرنا قابل مذمت نہیں بلکہ قابل تعریف عمل ہے۔ &&(تفسیر نمونہ)&&!!جواب نمبر۳:۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ ۔ لمبی لمبی دعاوں سے مراد خدا وند حکیم سے دعائیں کرنا نہیں بلکہ چیخ پکار مچانا اور لوگوں کی خوشامدیں کرنا ہوسکتا ہے۔ &&(تفسیر نمونہ)&&
  41,52,آیت نمبر۵۲:خدا وند عالم دشمنانِ حق کو سمجھا رہا ہے کہ اے نبیصلی اللہ علیہ و آلہ وسلم آپ ان سے کہیں جس طرح بے سوچے سمجھے تم خدا وند حکیم کی باتوں کا انکار پر انکار کیے چلے جارہے ہو اور اہم ترین باتوں کو سننے سمجھنے کے بجائے کانوں میں انگلیاں ٹھونسے چلے جارہے ہو ، یہ کوئی عقل مندی کا کام نہیں کررہے ہو۔ کیونکہ تم کسی دلیل کی بنا پر یہ دعویٰ نہیں کر سکتے کہ قرآن خدا وند حکیم کا کلام نہیں ہے اور نہ یقین سے کہ سکتے ہو کہ قرآن کی تعلیمات غلط ہیں تم جو کچھ سمجھ رہے ہو کہ قرآن گھڑی ہوئی کتاب ہے یہ کسی علم کی بنا پر نہیں ہے بلکہ صرف تمھارا گمان (guess work) ہے ، جو غلط بھی ہوسکتا ہے۔ اب یہ سوچو کہ اگر ، تمھارا یہ گمان ، خیال (guess work) صحیح نکلا تو زیادہ سے زیادہ یہ ہوگا کہ قرآن کو ماننے والے اور نہ ماننے والے برابر ہو جائیں گے۔ کیونکہ دونوں مٹی میں مل کر مٹی ہوجائیں گے لیکن اگر قرآن کی بات صحیح نکلی اور دوسری زندگی سامنے آگئی تو پھر سوچ لو کہ تمارے اس آج کے انکار کا انجام کتنا برا ہوگا۔ تم کس بری طرح تباہی اور بربادی کا شکارہوگے۔ اس لیے تمھارا اپنا فائدہ اور بھلائی اور خیریت اسی میں ہے کے تم حق دشمنی ، ضد ، ہٹ دھرمی۔ ۔ ۔ کج حجتی چھوڑ کر سنجیدگی کے ساتھ قرآن پر غور و فکر کرو۔ اب غور کرلینے کے بعد اگر ایمان لانے کا فیصلہ کرتے ہو تو لاو۔ اور ا گر ایمان لانے کا فیصلہ کرنے کی تم میں جرأت نہیں ہے، تو کم سے کم ایسے سچے حقیقی پیغام کی مخالفت میں اس حد تک تو آگے نہ بڑھ جاو کہ واپس جانا ممکن ہی نہ رہے۔ اس قدر ظلم و ستم کر ڈالو کہ خود بھی ایمان نہ لاو اور ایمان داروں پر حملے کرنے لگو ۔ ان کے قتل و غارت پر اُتر آو ، لوگوں کو نیکیوں سے روکنے لگو۔ یہ عمل تو اس قدر تباہ کن ہوگا کہ جس کی تباہی کا کوئی اندازہ بھی نہیں کرسکتا۔ &&(تفسیر کبیر ۔ تفہیم ۔ مجمع البیان)&&خدا وند عالم کا یہ فرمانا کہ@@ ’’ پھر اس شخص سے زیادہ گمراہ کون ہوگا ،،@@ یعنی خدا وند حکیم نے صاف صاف یہ نہیں فرمایا کہ غور وفکر نہ کرنے والے گمراہ ہیں ، بلکہ اس فیصلہ کی تلخی کو کم کرنے کے لیے فرمایا کہ ’’ اس شخص سے زیادہ گمراہ کون ہوگا؟،، یہ ایک مہذب انداز ہے ، رواداری پر مبنی کہ بات بھی پوری طرح کہ دی جائے مگر اس کی تلحی بھی زیادہ نہ ہو ۔ &&(فصل الخطاب)&&!!{{حج کا زمانہ تھا اور امام جعفر صادق علیہ السلام کے پاس اس وقت کا عظیم دہریہ فلسفی ابن ابی العوجَا بھی موجود تھا۔ امام علیہ السلام نے اس سے پوچھا : ’’ تم یہاں کیا کرنے آئے ہو ؟،، کہنے لگا : ’’ ہم عادت سے مجبور ہو کر حج کے زمانے میں یہاں آجاتے ہیں ۔ ،، امام علیہ السلام نے فرمایا: ’’ حج میں بحث ، مباحثہ ، جھگڑا نہیں کیا جاتا۔ اگر وہی سچ ہے جیسا کے تم کہتے ہو ( کہ خدا وند حکیم نہیں ہے) ۔ حالانکہ ایسا نہیں ہے ، تو تم بھی نجات پاگئے اور ہم بھی۔ لیکن اگر حقیقت وہی ہے جو ہم کہتے ہیں ۔ ۔ ۔ اور ہے بھی یہی سچ ۔ ۔ ۔ ۔ تو ایسی صورت میں ہم بچ جائیں گے اور تم برباد ہوگے ۔ ،، یہ سن کر ابن ابی العوجاء نے اپنے ساتھیوں سے کہا : ’’ مجھے اپنے دل میں درد محسوس ہورہا ہے ۔ ،، اس کے شاگرد اسے گھر لے کر پہنچے ہی تھے کہ مرگیا ۔ && (الکافی ۔ جلد نمبر۱ ، ۶۱ ، کتاب التوحید)&&}}
  41,53,آیت نمبر۵۳:اس آیت کے کئی مطالب لکھے گئے ہیں ۔ ایک مطلب تو یہ ہے کہ کافر عنقریب خود اپنی آنکھوں سے دیکھ لیں گے کہ قرآن کا پیغام دنیا میں پھیل چکا ہے۔ اس وقت ان کو پتہ چل جائے گا کہ قرآن واقعی حق تھا جس کا وہ انکار کررہے تھے ۔ مگر اس تفسیر پر یہ اعتراض ہے کہ بڑے بڑے علاقوں کو فتح کرلینا کسی پیغام والوں کے پیغام کی صداقت کی دلیل نہیں ہوا کرتا۔ بہت دفعہ باطل قوتیں بھی دنیا میں چھا جایا کرتی ہیں ۔ لیکن اسلام کے سلسلے میں یہ شبہ اس لیے غلط ہے کہ اسلام کی فتح آمروں ، بادشاہوں جیسی فتح نہ تھی۔ بلکہ اسلام نے دنیا کے اخلاق ، اقدار ، ذہنی فکر کو بدلا اور سیاسی ، تمدنی ، معاشرتی ، معاشی ، اخلاقی انقلاب برپا کیا۔ اخلاقی اور دینی فضائل کو عام کیا ۔ زندگی کے ہر شعبہ میں خدا وند حکیم ترسی ، انصاف اور عدل کو داخل کیا ۔ اسلام نے اپنے پیدا کردہ معاشرے میں انسانوں کو اتنا اونچا اٹھایا کہ دوسرے معاشروں کے چیدہ چیدہ لوگ بھی اس سطح پر بلند نظر نہیں آتے ۔ اسلام نے پوری عالمِ انسانیت کو اوہام اور خرافات ، جادو ٹوٹکے کے چکر سے نکال کر علمی ، تحقیق ، سائینٹفک طرز عمل اختیار کرنے پر مجبور کردیا۔ انسانوں میں رنگ و نسل ، زبان و وطن کی تفریق کو اور طبقات کی تقسیم کو ، اونچ نیچ کے امتیاز کو ، چُھوت چھات کو ، عورتوں ، مزدوروں ، مقروضوں ، کمزوروں کے حقوق کی پامالی کو ، بے پناہ قسم کے جرائم کو ، شراب نوشی ، جوئے بازی ، زنا کاری کو تہس نہس کردیا۔ انسانی حقوق کو بحال کیا ، عورتوں کی عزت کرنا سکھایا۔ ان کے حقوق ادا کرنا سکھایا۔ بین الاقوامی تعلقات میں معاہدوں کا احترام کرنا سکھایا۔ جنگ میں وحشیانہ حرکتوں سے روک دیا طوائف الملوکی ، فتنہ و فساد ، بدامنی ، خوں ریزی ، فسق و فجور کی جڑوں کو کاٹنے کو کوشش کی۔ ان تمام برائیوں کی جگہ تقویٰ ، طہارت ، عدل و انصاف ، شرافت و تہذیب ، شائستگی ، علم ، اخوت اور محبت پیدا کی۔ حتیٰ کہ مسلمانوں نے اپنے زوال کے دور میں بھی تہذیب اور شائستگی کا مظاہرہ کیا ۔ یورپ کی قوموں نے افریقہ ، امریکہ ، ایشیا بلکہ خود یورپ میں مغلوب اور کمزور قوموں کو غلام بنا کر وہ ظالمانہ سلوک کیا کہ اس کی کوئی ایک مثال بھی مسلمانوں کی تاریخ میں نہیں ملتی۔ یہ قرآن ہی کی برکت ہے کہ جس نے مسلمانوں میں انسانیت کا احترام پیدا کیا تاکہ وہ غلبہ پاکر بھی ظالم نہ بنیں ۔ پوری تاریخ گواہ ہے کہ مسلمانوں نے اپنی مفتوحہ قوموں کے ساتھ کتنا اچھا اور منصفانہ سلوک کیا۔ عیسائیوں ، یہودیوں ، ہندوں کے ساتھ بہترین برابری کا سلوک کیا۔ مگر آج عیسائی ، یہودی اور ہندو ، دنیا پر غالب ہیں جو ہر جگہ مسلمانوں کو مغلوب کرکے ہر قسم کے ظلم ڈھارہے ہیں ۔ &&(تفسیر کبیر۔ تفہیم)&&!!ضروری نوٹ:لیکن یہ سلوک عام مسلمانوں کا تھا جو مفتوجہ قوموں کے ساتھ بیان کیا گیا۔ البتہ مسلمان بادشاہوں نے خصوصاَ بنی امیہ اور بنی عباس کے مسلمان خلفاء نے اپنے سیاسی حریفوں کے ساتھ بدترین سلوک کیا۔ یہ اس لیے کہ وہ اصل میں دل سے مسلمان نہ ہوئے تھے۔ صرف اقتدار حاصل کرنے کے لیے اپنے کو مسلمان ظاہر کرتے تھے اسی طرح اُن کے خاص حالی موالی بھی انھیں کی طرح اپنے سیاسی حریفوں ، خاص طور پر ائمہ اہلیت علیہم السلام  علیہ السلام اور ان کے ماننے والوں کے ساتھ بے حد برا سلوک کرتے تھے جس کی گواہ خود مسلمانوں کی اپنی تاریخ ہے۔ مگر ان خلفاء کا یہ سلوک عام مسلمانوں کے سلوک کے خلاف تھا۔ پورا عالم اسلام عمومی طور پرائمہ اہلیت علیہ السلام کا دل سے احترام کرتا تھا ، سوا اُن پالتو کتّوں کے جو بنی امّیہ ، بنی عباس کے خلفاء کے دستر خوان پر پلتے تھے۔ &&(مولف)&&آیت کی دوسری زیادہ صحیح تفسیر !اس آیت کی دوسری تفسیر یہ ہے کہ اللہ تعالی تعالیٰ نے انسانوں کو خود ان کے اپنے وجود کے اندر بھی اور پوری کائنات کے اند ربھی اپنی قدرت ، حکمت ، رحمت اور عظمت کی وہ وہ نشانیاں دکھائی ہیں کہ اگر وہ لوگ انفس و آفاق پر غور کریں گے تو خود ان پر یہ بات کھل جائے گی کہ قرآن جو تعلیم دے رہا ہے وہ بالکل درست رہے۔ رہا یہ اعتراض کرنا کہ نفس وآفاق کی نشانیاں ، تو وہ دیکھ ہی رہے تھے ، پھر ان سے یہ کہنا کہ ہم انھیں ایسی ایسی نشانیاں دکھائیں گے اس ’’ دکھائیں گے،، کا آخر مطلب کیاہے؟ یہ اعتراض مہمل ہے اس لیے کہ خدا وند حکیم نے بے شک بہت سی نشانیاں دکھائی ہیں ، لیکن جیسے جیسے انسان کا علم ، تجربہ بڑھتا جاتا ہے اتنا اتنا وہ خدا وند حکیم کی تخلیقات میں نئی نئی نشانیاں اور گہرائیاں دیکھتا چلا جاتا ہے۔ کیونکہ خدا وند حکیم کی نشانیاں بے حد و بے حساب ہیں ۔ انسان کبھی ان کا احاطہ نہیں کرسکتا اورنہ کبھی ان کا احاطہ کرسکے گا ۔ اس لیے ہر ہر دور میں انسان کے سامنے نئی نئی نشانیاں آتی ہی چلی جائیں گی ۔ &&(تفسیر کبیر ۔ مجمع البیان ۔ تفہیم ۔ انوار النجف)&&[[ہر سو تری قدرت کے ہیں لاکھوں جلوے ۔ حیراں ہوں کہ دو آنکھوں سے کیا کیا دیکھوں ]] ۔ آخر میں خدا وند عالم کا فرمان ہے کہ @@’’ تیرا پالنے والا مالک ہر چیز کا دیکھنے والا ہے ،،@@ یہ جملہ ایک قسم کی وارننگ ہے کہ کیا ان لوگوں کو جنھیں اس قدر واضح حق کی نشانیاں ۔ انفس و آفاق میں دکھائی جارہی ہیں ان کے لیے خدا وند حکیم کے عذاب سے ڈرنے کے لیے کیا یہ بات کافی نہیں ہے کہ ان واضح دلائل کو جھٹلانے والے اور اس پیغامِ حق کو نقصان پہنچانے کی کوششیں کرنے والوں کی ایک ایک حرکت کو خدا وند حکیم خود اچھی طرح سے دیکھ رہا ہے ۔ &&(مولف)&& [[خزر اے چیرہ دستاں سخت ہیں قدرت کی تعذیریں]] &&(اقبال)&&حقیقت یہ ہے کہ پوری کائنات خدا وند حکیم کی مخلوق ہونے کی وجہ سے خدا وند حکیم کے وجود قدرت ، رحمت ، عظمت ، شان بان کا پتہ دے رہی ہے۔ جیسے ایک تصویر مصّور کے فن کا پتہ دیتی ہے ۔ عمارت ،معمار کا کمال کا پتہ دیتی ہے جیسے ایک تصویر مصور کے فن کا پتہ دیتی ہے۔ عمارت ، معمار کے کمال کا پتہ دیتی ہے۔ اس طرح تمام عالم اپنے خالق کی عظمت و کمال کا پتہ دیتا ہے۔ مگر نفسِ انسانی کو خدا وند عالم نے عالمِ امکان میں اپنے اوصاف و صفات کا آئینہ بنایا ہے۔ اسی لیے نفس انسانی کے کمالات پر غور و فکر کرنے سے ہمارا ذہن اسی طرح خدا وند حکیم کی طرف متوجہ ہوتا ہے جیسے کسی کی تصویر کو دیکھ کر اس شخص کی طرف ذہن منتقل ہوتا ہے۔ اب جتنا نفس کامل ہوگا اتنا ہی وہ خدا وند حکیم کی معرفت کا بہترین او رکامل ترین ذریعہ ہوگا۔ اب جو اکمل ہستیاں ہوں گی وہ ’’ وجہ اللہ تعالی ،، یعنی اللہ تعالی کا چہرہ کہلانے کی مستحق ہوں گی ۔ کیونکہ چہرہ ہر شخص کی پہچان اور معرفت کا ذریعہ ہوتا ہے۔ &&(افضل المطالب ۔ فصل الخطاب)&&!!خدا وند حکیم کی نشانیاں :{{امام جعفر صادق علیہ السلام سے روایت ہے کہ فرمایا:’’ اے مفضل! لعاب دہن اور اس کے فوائد کے بارے میں غور کرو کہ یہ لعاب ہمیشہ منہ میں چلتا ہی رہتا ہے تاکہ حلق اور زبان ہمیشہ مرطوب رہے اور خشک نہ ہونے پائے ۔ کیونکہ اگر یہ اعضاء خشک ہوجائیں تو انسان ہلاک ہوجائے کیونکہ پھر وہ رطوبت کے بغیر غذا نگل نہیں سکتا ۔ ،،&&(بحار الانوار ، جلد نمبر ۳ ، ۷۷)&&}}{{امام حسین علیہ السلام فرماتے ہیں :’’ خدا وند حکیم یا خدا وند حکیم یا ! اندھی ہو جائے وہ آنکھ جو تجھے نہ دیکھے ،،&&(دعائے عرفہ از امام حسین علیہ السلام )&&}}{{امام حسین علیہ السلام دعائے عرفہ میں فرماتے ہیں :’’ میرے پالنے والے مالک! کیا دوسری موجود ات کے لیے کوئی ایسا ظہور ہے جوتیرے لیے نہ ہو؟ کیا دوسری موجود ات تیری نشاندہی کرسکتی ہیں ؟ تو کب مخفی رہا ہے کہ تجھے پہچاننے کے لیے کسی دلیل کی ضرورت ہو ؟ تو ہم سے لب دور ہوا ہے کہ تیرے آثار ہمیں تیری طرف جانے کی رہنمائی کریں ؟ اندھی ہوجائے وہ آنکھ جو تجھے نگراں سمجھ کر نہ دیکھے۔ اور نقصان اٹھایا اس بندے نے اپنی تجارت میں جس نے تیری محبت کا کوئی حصہ نہ پایا ۔ ،،&&(دعائے عرفہ از امام حسین علیہ السلام )&&!!انسان کے اندر کیا نشانیاں (۱)ہرانسان کے پاوں کے تلوے میں ایک خاص قسم کا خلا یا گڑھا موجود ہوتا ہے جب کہ فوج میں جس آدمی کے تلوے میں گڑھا یا خلا نہیں ہوتا یا کم ہوتا ہے تو اس کو فوج میں بھرتی نہیں کیا جاتا۔ کیونکہ ایسا انسان اگر کھڑا ہوتو جلد تھک جاتا ہے اس سے معلوم ہوا کہ کسی علیم و حکیم نے ہمیں بنایا ہے ۔ (۲)انسان کی آنکھ او رمنہ میں پانی کے چشمے پھوٹتے رہتے ہیں جو باریک باریک سوراخوں سے نکلتے ہیں ۔ اگر یہ نہ ہوتے تو انسان نہ دیکھ سکتا ، نہ بول سکتا اور نہ غذا نگل سکتا ۔ (۳)اگر آنکھ ہمیشہ مرطوب نہ رہے تو ڈھیلوں کی گردش سخت تکلیف دینے لگے پلکیں ایک دوسرے کو چھیل کر رکھ دیں ۔ (۴)آنکھ کو اس طرح کا بنایا گیا ہے کے آنکھ کے اندر کا پانی نمکین ہے۔ جب آنکھ میں گردو غبار یا کوئی چیز چلی جاتی ہے تو وہ پانی از خود بہنے لگتا ہے اور جب تک اس چیز کو باہر نہیں پھینک دیتا نہیں رکتا ۔ (۵)جب کہ منہ کے اندر کا لعاب کچھ ذائقہ یا نمک نہیں رکھتا۔ تاکہ انسان غذا کا ذائقہ اچھی طرح سے محسوس کرسکے ۔ (۶)پھر یہ دونوں چشمے جچے تلے حساب کتاب کے تحت بہتے ہیں ۔ ان کی فزیکل اور کیمیکل کیفیت بہت جچی تلی ہوتی ہے۔ اس سے ہم یقین کرسکتے ہیں کہ کائنات اور ہمارے جسم کا یہ نظام اندھے بہرے اتفاق یا مادی ارتقاء کا نتیجہ نہیں ہے ۔ کوئی تو ہے جو نظامِ ہستی چلا رہا ہےچلا رہا ہے ۔ &&(تفسیر نمونہ)&&
  41,54,آیت نمبر۵۴:مطلب یہ ہے کہ ان کافروں منکرینِ حق کے انکارحق کی بنیادی وجہ یہ ہے کہ ان کو اس بات کا یقین نہیں ہے کے کبھی ان کو خدا وند حکیم کو منہ دکھانا ہوگا اور اپنے اعمال کا حساب دینا ہوگا۔ اسی لیے یہ طرم خان بنے حق کی مخالفت پر تلے بیٹھے ہیں ۔ اگر ان کو یہ بات معلوم ہوجاتی کہ ہر شخص کو بہرحال خدا وند حکیم کے سامنے کھڑے ہوکر اپنے اعمال کا حساب کتاب چکانا ہے ۔ @@ اور اللہ تعالی ہر بات سُن رہا ہے اور ہر چیز پر محیط ہے ، @@تو یہ کبھی ہرگز اللہ تعالی کے پیغام کا انکار نہ کرتے اور نہ اس کا مذاق آیت کے آخری الفاظ کہ@@ ’’ خدا وند حکیم ہر ہر چیز کا احاطہ کیے ہوئے ہے ۔ ،،@@ نے واضح طور پر یہ بتا دیا کہ :(۱)کوئی شخص کس طرح سے بھی خدا وند حکیم کی گرفت سے بچ نکل نہیں سکتا ۔ (۲)اور کسی کی کوئی چھوٹی سی چھوٹی بدمعاشی ایسی نہیں ہے جو خدا وند حکیم کو معلوم نہ ہو ۔ &&(تفسیر کبیر۔ تفہیم۔ مجمع البیان۔ انوار النجف)&& قیامت کے آنے کے بارے میں جتنے اعتراضات ہیں وہ سب کے سب ان دو باتوں کو سمجھ لینے سے دور ہوجاتے ہیں جو آیت کے آخر میں بیان کی گئی ہیں ۔ (۱) قیامت کے آنے پر سب سے بڑا اعتراض یہ ہے کہ مرنے کے بعد ہم کیسے دوبارہ زندہ ہوں گے؟ اس کا جواب یہ دیا گیا کہ خدا وند حکیم ہر چیز کو (اپنے علم و قدرت سے) گھیرے ہوئے ہے۔ یعنی کوئی چیز خدا وند حکیم کے علم سے باہر نہیں ہے۔ اس لیے اس کو ہمیں دوبارہ زندہ کرنے کے طریقے کا بھی علم ہے ۔ پھر دوسرے یہ کہ اس کی قدرت لامحدود ہے۔ وہ اپنی قدرت سے ہر چیز کو گھیرے ہوئے ہے ۔ کوئی کام اور کوئی چیز اس کی قدرت سے باہر نہیں ہے۔ اس لیے وہ مردوں کو دوبارہ زندہ کرنے پر بھی قادر ہے ۔ &&(فصل الخطاب)&&
