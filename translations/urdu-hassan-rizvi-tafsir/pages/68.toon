  68,1,آیت نمبر۱: <<ن>> حروفِ مقطّات میں سے ہے۔ حروفِ مقطّات خداوندِ عالم کے راز ہیں ۔ اُن کی حقیقت کاعلم صرف خداوندِ عالم کو ہے: پھر خداوندِ عالم نے اُس کا علم صرف اپنے رازدار ،اطاعت گذار ،اپنے خاص الخاص بندوں کو عطا فرمایا ہے او اُن حروف کے ذریعہ خداوند عالم سے جو کچھ بھی طلب کرتے ہیں ،وہ اُنھیں مل جاتا ہے۔&& (ضحاک از معالم)&&غرض یہ حروف خفیہ Code Words ہیں ،جو عام لوگوں کے لیے تو بےمعنی ہیں مگر خاص لوگوں مثلاً؛انبیاء کرام علیہم السلام اور آئمہ اطہار علیہم السَّلام کے لیے خدا کے راز ہیں ۔ (تفسیر اہلِ بیت علیہم السلام )!!قلم کی اہمیت:قلم بظاہر بہت معمولی سی چیز ہے،مگر خداوندِ عالم نے اس کی قسم کھائی ہے ،اِس لیے کہ قلم سے علوم پھیلتے ہیں ،افکار اور تحقیقات کا قافلہ آگے بڑھتا ہے۔ لوگوں کو ہدایات اور تعلیمات ملتی ہیں ۔ انسان کو معاشرتی،سیاسی ،سماجی اور اقتصادی ترقی ملتی ہے۔ تاریخِ بشر کا دور ہی اُس وقت سے شروع ہوتا ہے جب اس نے لکھنا شروع کیا۔ کتنے تعجب کی بات ہے کہ قرآن قلم کی اھمیت اُس وقت بتا رہا ہے جب مکّہ جیسے مرکزی شہر میں صرف ۲۰ آدمی لکھنے والے تھے۔ عر ب،لکھنے کو اپنی توہین سمجھتے تھے۔عربوں کا محاورہ تھا کہ  ہم عرب لوگ کاغذ کے سفید چہرے کا منہ کالا نہیں کیا کرتے۔ایسے قلم اور علم دشمن ماحول میں خداوندِ عالم کا قلم کی قسم کھا کر اُس کی عظمت کا اعلان کرنا کتنا عجیب ہے ،پھر پہلی وحی کا اقراء سے شروع ہونا،پڑھنے کی اہمیت کو بتاتا ہے۔&&(تفسیر نمونہ۔ تفسیر کبیر) }}&& فرزندِ رسول صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: >>نون<< جنّت میں ایک نہر ہے ،جسے خداوندِ کریم نے حکم دیا کہجم جا اور روشنائی بن جا۔تو وہ روشنائی بن گئی۔ پھر اللہ تعالیٰ نے حکم دیاکہ اے قلم ! لکھ پس جو کچھ ہوچکا ہے اور جو کچھ قیامت تک ہونے والا ہے ،قلم نے لوح ِمحفوظ پر لکھ دیا۔ پس وہ روشنائی نور کی روشنائی ہے،اور قلم بھی نور کا قلم ہے ،اور لوحِ محفوظ بھی نور کی تختی ہے۔&&(تفسیر صافی بحوالہ معانی الاخبار) &&}}نیز {{امام علیہ السلام نے فرمایا کہ: ، مادیّات میں خداوندِ قدیر نے سب سے پہلے قلم کو پیدا کیا پھر حکم دیا کہلکھ۔ قلم نے پوچھا: کیالکھوں ؟ فرمایا:  جوکچھ ہوچکا ہے اور جو کچھ قیامت تک ہونے والا ہے سب لکھ ڈال۔قلم نے سب لکھ دیا۔&&(تفسیر قمی) &&}} نیز {{امام علیہ السلام سے روایت ہے کہ:  قرآن میں جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم کے پانچ نام آئے ہیں محمّد صلی اللہ علیہ و آلہ وسلم ۔احمد ۔ عبداللہ ۔ بشیر (ونذیر) ۔ نون&&(الخصال){{ &&!!{{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام موسیٰ کاظم علیہ السلام سے روایت ہے کہ:نون حضرت رسالت مآب صلی اللہ علیہ و آلہ وسلم کے ناموں میں سے ایک نام ہے۔اور قلم حضرت امیر المومنین علیہ السلام کا نام ہے۔&&(تفسیر بُرہان ،انوار النجف)&&{{ <<مَایَسْطُرُوْنَ >> یعنی : جسے لکھنے والے لکھ رہ ہیں ۔ مجاہد تابعی کہتے ہیں کہ قلم سے یہاں مراد (اولین معنی میں یہاں ) وہ قلم ہے جس سے قرآن یا اُس کے معنی لکھّے جائیں ۔ اس لیے <<مایسطرون >> جو لکھا جارہا ہےسے مراد <<قرآن <<ہے۔&&(تفسیر کبیر ۔ تفہیم ۔ مودودی) &&!! احادیثِ رسول صلی اللہ علیہ و آلہ وسلم اور قلم کی اہمیت:{{جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: <<اوَّلُ مَاخَلْقُ اللہُ الْقَلمِ >> @@(اللہ نے سب سے پہلے قلم کو پیدا کیا۔)@@&&(تفسیر نورالثقلین جلد۵ ۔ تفسیر کبیر جلد ۳۰)&& }}}}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:  پہلی چیز جس کو خدا نے پیدا کیا ،ایک موتی تھا۔ (جس سے قلم بنا)&&(تفسیر کبیر ) &&{{نیز!! }}حضور اکرم صلی اللہ علیہ و آلہ وسلم نے فرمایاء  پہلی چیز جو خد ا نے بنائی وہ عقل تھی۔&&(تفسیر کبیر امام رازی) && }} {{فرزندِ رسول صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے اپنے اصحاب سے فرمایا تھا کہ: علو م کو لکھو اور آنے والوں کے لیے وہ تحریریں چھوڑ جاو۔علماء نے لکھا کہ  بیان دو قسم کے ہوتے ہیں ایک زبان کا بیان،دوسرا قلم کا بیان۔زبان کا بیان وقت کے گذرنے کے ساتھ کہنگی لاحق ہوتی ہے۔ لیکن قلم کا بیان ہر زمانے میں تازہ بہ تازہ اور باقی رہتاہے۔&&(تفسیر نمونہ)&&{{ علماء نے لکھا کہ :  دین و دنیا کے معاملات کی بنیاد دو چیزوں پر ہے قلم اور تلوار۔ مگر تلوار ،قلم کے ماتحت رہتی ہے۔&&(تفسیر مجمع البیان)&& ]]عرب شاعر نے لکھا کہ:  جس دن جنگجو اپنی تلواروں کی قسم کھائیں گے اُس دن قلم سے لکھنے والوں کی سربلندی ظاہر ہوگی۔ اِس لیے کہ خدا نے تلوار کی نہیں ،قلم کی قسم کھائی ہے[[۔ }}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:  تین آوازیں ہیں کہ تمام حجابوں کو توڑ کر خدا کی بارگاہ میں پہنچ جاتی ہیں : (۱) لکھتےوقت علماء کے قلم کی آواز (۲) میدانِ جہاد میں مجاہدین کے قدموں کی چاپ (۳) پاکدامن عورتوں کے چرخوں کی آواز (یعنی حلال روزی کمانے والی عورتوں کی سعی)&&(الشباب فی الحکم) {{&& }}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایاء  علماء کے قلم کی روشنائی شہداء کے خون سے افضل ہے۔&&(تفسیرکبیر رازی)&&{{
  68,2,آیت نمبر۲:اصل بات جس پر قسم کھائی گئی: وہ یہ ہے کہ رسولِ خدا صلی اللہ علیہ و آلہ وسلم مجنون نہیں ہیں ۔ اِس کا ثبوت بھی خود قرآن کا متن ہے کہ جو کاتبانِ وحی کے ہاتھوں لکھّا جارہا ہے۔اصل بات یہ تھی کہ عرب والے رسول صلی اللہ علیہ و آلہ وسلم کو قرآن کے اُترنے سے پہلے بہترین آدمی مانتے تھے۔قرآن نے اُتر کر اُن کے غلط عقائد کی نفی کی۔ اب کیوں کہ قرآن کا استدلال اِس قدر زبردست تھا کہ عربوں کے لیے اس کا جواب دینا ،ناممکن تھا ،اِسلیے مجبوراً کہنے لگے کہ رسول صلی اللہ علیہ و آلہ وسلم پاگل ہوگئے ہیں ۔ <<معاذاللہ>>گویا قرآن کی وجہ سے رسول صلی اللہ علیہ و آلہ وسلم کو پاگل کہنے لگے اِسی لیے خداوندِ عالم نے قرآن ہی کو دلیل قرار دیا کہ قرآن کا متن دیکھ لو قرآن کا مدلّل ،فصیح و بلیغ کلام از خود بتا دے گا کہ اِس کا لانے والا ،اِسے پڑھنے والا پاگل ہو ہی نہیں سکتا۔ ایسے بلند پایہ مضامین جن میں زبردست ربط و استدلال ہو ،وہ کوئی پاگل آدمی بیان ہی نہیں کرسکتا۔&&(تفسیر کبیر ، مجمع البیان ، انوار النجف ،تفہیم)&&
  68,3,آیت نمبر۳: معلوم ہوا کہ ہدایت کرنے والے کو لازوال اور بے حساب اجر ملتا ہے۔ اِس لیے کہ یہ صدقہ جاریہ ہے (ایسی نیکی ہے جو مرنے کے بعد بھی لوگوں کو فیض پہنچاتی رہتی ہے۔)}} فرزندِ رسول صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ:تین چیزیں آدمی کو مرنے کے بعد بھی فائدہ پہنچاتی ہیں ،اس لیے وہ صدقہ جاریہ ہیں ۔(۱) ایسا کوئی کام جس سے لوگوں کو فائدہ پہنچتا رہے ۔جیسے کنواں (ہسپتال وغیر)جب تک لوگوں کواس سے فائدہ پہنچتا رہےگا ،عمل کرنے والے کو ثواب ملتا رہے گا۔ (۲) علمی اثر۔ یعنی کوئی کتاب یا درس دینا۔ جب تک کتاب یا درس کے اثرات باقی رہیں گے ثواب ملتا رہے گا ۔ (۳)ولدِ صالح : نیک اولاد: جب تک نیک اولاد اعمالِ صالح بجالاتے رہیں گے والدین کو اس کا ثواب ملتا رہے گا۔&&(الحدیث) &&{{
  68,4,آیت نمبر۴: {{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت محمد باقر علیہ السلام سے روایت ہے کہ << خُلق عظیم<<کے معنی ہیں : >>دین عظیم<<۔&&(تفسیر صافی بحوالہ قمی)&&گویا پورا دین خُلق و اخلاق کی تربیت کے سوا کچھ نہیں ۔ِ&&(مولف)&&]]اصل مذہت احترامِ آدمی است[[ {{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ: اللہ تعالی نے اپنے نبی صلی اللہ علیہ و آلہ وسلم پاک کو ادب کی تعلیم دی،اِس طرح کہ آپ صلی اللہ علیہ و آلہ وسلم کو بہترین ادب سکھایا،جب ادب کی تعلیم مکمل ہوچکی ،تب اللہ جلّ شانہ،نے ارشاد فرمایا: << اِنَّکَ لَعَلیٰ خُلُقٍ عَظِیْمٍ>> اے رسول صلی اللہ علیہ و آلہ وسلم ! یقینا آپ صلی اللہ علیہ و آلہ وسلم اخلاق ِعظیم کے مالک ہیں ۔&&(کافی)&&!! اخلاق کا لفظ خُلق سے بنا ہے۔ اُردو میں اِس کے معنی خوشامد کرنا بن گیا ہے جو عربی ادب کے اعتبار سے بالکل غلط ہے۔عربی میں خَلَق کے معنی : ظاہری خِلقت کے ہوتے ہیں ،اور خُلق کے معنی باطنی کیفیتوں اور درستگی کے ہوتے ہیں ۔ اِس لئے خداوندِ عالم کا جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کو خُلق عظیم کا مالک فرمانے کا مطلب یہ کہ آپ صلی اللہ علیہ و آلہ وسلم زندگی کے ہر شعبہ باطنی میں کیفیتوں کے اعتبار سے نہایت ہی بلند نقطہ اخلاق پر فائز ہیں ۔&&(فصل الخطاب ،مفردات امام راغب) && }} حضرت امام علی ابنِ طالب علیہ السلام سے کسی نے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے اخلاق کی عظمت کو دریافت کیا،تو آپ علیہ السلام کانپنے لگے۔ آپ علیہ السلام نے سوال کرنے والے سے دریافت فرمایا کہ:  تم اللہ تعالیٰ کی دینوی نعمتوں کو بیان کردو۔اُس نے عرض کی :یہ تو ممکن ہی نہیں ۔&&(سورۃ۴ النساء آیت )آپ علیہ السلام نے فرمایا:  اللہ نے دنیا کی نعمتوں کو <<متاع الدنیا قلیل<< فرمایا جبکہ رسول صلی اللہ علیہ و آلہ وسلم کے اخلاق کو عظیم فرمایا ہے ۔ جب تم قلیل کو شمار نہیں کرسکتے تو میں ،جسے خدا عظیم فرمائے ،اُس کی عظمت کو کیسے بیان کرسکتا ہوں ؟!!{{جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کا اخلاق:۔(۱) آپ صلی اللہ علیہ و آلہ وسلم کا اخلاق اتنا بلند تھا کہ دشمنوں کی لاکھوں اذیتوں کو برداشت کیا،مگر کبھی بد دعاء نہ کی ۔ طائف والوں نے اس قدر پتھر مارے کہ آپ صلی اللہ علیہ و آلہ وسلم پتھروں میں چھپ گئے۔ رات جبریل علیہ السلام نے ہاتھ پکڑ کر پتھروں سے نکالا۔ اور بد دعاء کی درخواست کی تو آپ صلی اللہ علیہ و آلہ وسلم نے ہاتھ اُٹھا کر فرمایا: << اَللّٰھُمَّ اھْدِ قَوْمِیْ فَاِنَّھُم لَایَعْلَمُوْنَ >> مالک! میری قوم کو ہدایت عطا فرما کہ وہ مجھے پہچانتے نہیں ۔(۲) جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے اخلاق کی دوسری مثال یہ ہے کہ جب آںحضرت صلی اللہ علیہ و آلہ وسلم کی شریک ِ حیات حضرت عائشہؓ سے پوچھا گیا کہ رسولِ خدا صلی اللہ علیہ و آلہ وسلم کا اخلاق کیا تھا؟ تو اُنھوں نے فرمایا:  <<کَانَ خُلْقُہٗ قُرْاٰنٌ >> آںحضرت صلی اللہ علیہ و آلہ وسلم کا اخلاق قرآن تھا۔&&(امام احمد ،مسلم ،ابوداود ،ابنِ ماجہ ،داری ،ابنِ جریر) {{&& معلوم ہوا کہ جنابِ رسولِ خداصلی اللہ علیہ و آلہ وسلم نے صرف قرآن کی تعلیم ہی نہیں پیش کی تھی بلکہ آپ صلی اللہ علیہ و آلہ وسلم کا کردار قرآن مجید کامکمّل مجسمہ تھا۔ یہ فرق ہے انبیاء کرام علیہم السلام اور دوسرے فلاسفہ میں کہ وہ صرف اخلاق کی تھیوریاں پیش کرتے ہیں ،مگر انبیاء کرام علیہم السلام اس پر عمل کرکے بھی دکھاتے ہیں ۔ اس لیے انبیاء کرام علیہم السلام کی تعلیمات عملا پھیلتی ہیں اور لوگ اُن پر عمل کرتے ہیں ۔(۳) {{ام المومنین حضرت عائشہؓ فرماتی ہیں کہ : جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے کبھی کسی خادم کو نہ مارا،نہ ڈانٹا ،کبھی کسی عورت پر ہاتھ نہ اٹھایا<<جہاد فی سبیل اللہ>> کے سوا اپنے کسی سے جنگ نہ کی اپنی ذات کے لیے کبھی کسی کو کسی قسم کی تکلیف نہ دی،نہ کبھی کسی سے انتقام لیا۔ آپ صلی اللہ علیہ و آلہ وسلم کا طریقہ کار یہ تھا کہ جب دو کاموں میں سے کسی ایک کام کا آپ صلی اللہ علیہ و آلہ وسلم کو انتخاب کرنا ہوتا تھا تو آپ صلی اللہ علیہ و آلہ وسلم آسان تر کام کو پسند فرماتے تھے،سوا اس کے کہ وہ گناہ نہ ہو۔ اگر کوئی کام گناہ کا ہوتا تو آپ صلی اللہ علیہ و آلہ وسلم سب سے زیادہ اُس سے دور رہتے تھے۔&&(سند احمد بن جنبل)&&}}!! حضرت انس فرماتے ہیں کہ: میں نے دس سال رسولِ خداصلی اللہ علیہ و آلہ وسلم کی خدمت کی۔ آپ صلی اللہ علیہ و آلہ وسلم نے کبھی میری کسی بات پر اُف نہ کی ،کبھی مجھ سے یہ نہ کہا کہ تو نے یہ کیوں کیا،اور نہ کبھی کسی کام پر یہ فرمایا کہ کہ تو نے یہ کیوں نہ کیا؟&&(بخاری مسلم)&& }}حضرت امام علی ابنِ طالب علیہ السلام نے اخلاق رسولِ اکرم صلی اللہ علیہ و آلہ وسلم کے بارے میں فرمایا:(۱) کوئی شخص جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم کے پاس آکر مایوس اور نااُمید واپس نہ ہوتا تھا۔(۲) تین چیزوں کو آپ صلی اللہ علیہ و آلہ وسلم نے اپنے سے بالکل الگ کردیا تھا۔ جھگڑنا، زیادہ باتیں کرنا،اور ایسے کسی کام میں دخل دینا جس سے آپ صلی اللہ علیہ و آلہ وسلم کا تعلق نہ ہو۔(۳) تین چیزوں کو آپ صلی اللہ علیہ و آلہ وسلم نے لوگوں کے لیے چھوڑدیا تھا۔ اول یہ کہ آپ صلی اللہ علیہ و آلہ وسلم کسی کی مذمت نہیں کرتے تھے دوسرے یہ کہ کسی کو بُرا بھلا نہیں کہتے تھے اور تیسرے یہ کہ لوگوں کے چھپے ہوئے عیوب کی جستجو نہیں کرتے تھے(۴)آپ صلی اللہ علیہ و آلہ وسلم صرف اُن موضوعات پر بات کرتے تھے جن پر بولنا ثواب ہے۔(۵) بات اتنی موثر انداز سے فرماتے کہ لوگ سننے پر مجبور ہوجاتے اور اپنی جگہ سے ہلتے تک نہ تھے۔(۶) لوگ آپؐ کے پاس جھگڑے نہیں کرسکتے تھے۔(۷) جب کوئی اجنبی آدمی سختی سے کلام کرتا ،تو آپ صلی اللہ علیہ و آلہ وسلم تحمل اور برداشت سے کام لیتے۔ (۸)آپ صلی اللہ علیہ و آلہ وسلم اکثر اپنے اصحاب سے فرماتے کہ جب کسی کو حاجت مند دیکھو تو اُس کی حاجت پوری کرو۔ (۹) آپ صلی اللہ علیہ و آلہ وسلم کبھی کسی کی بات نہیں کاٹتے تھے،اُس کی پوری بات سنتے تھے۔&&(ملحض از معانی الاخبار) &&{{اخلاق کی تربیت حضورصلی اللہ علیہ و آلہ وسلم کے نزدیک اتنی اہم تھی کہ آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا:<<اِنَّمَابعثت لاتمم مکارم الاخلاق>>(میں اخلاق کے فضائل کی تکمیل ہی کے لیے بھیجا گیا ہوں )&&(تفسیر مجمع البیان ،تفسیر کبیر)&&}}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: مومن اپنے اچھے اخلاق کی وجہ سے اُس شخص کے درجات حاصل کرلیتا ہے جو رات بھر عبادت کے لیے کھڑا رہتا ہے ،اور دن بھر روزے رکھتا ہے۔&&(تفسیر مجمع البیان)&&{{ نیز}} آں حضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا:  عمل کے تولنے والی ترازو (میزانِ عمل) میں کوئی چیز قیامت کے دن اچھے اخلاق سے زیادہ وزنی نہیں ہوگی۔&&(تفسیر مجمع البیان)&&{{نیز!! }}ارشاد فرمایا:  تم سب میں خدا کے ہاں سب سے زیادہ محبوب وہ شخص ہے ،جس کے اخلاق سب سے بہتر ہوں ۔ اچھے اخلاق والے وہ ہوتے ہیں جوجُھک کر ادب سے ملتے ہیں ،خود کو ادنیٰ سمجھتے ہیں ،دوسروں سے محبت کے ساتھ ملتے ہیں ۔تم میں خدا کو سب سے زیادہ ناپسند وہ لوگ ہیں جو ایک دوسرے کی چغلیاں کھاتے ہیں اور بھائیوں کو ایک دوسرے سے جدا کردیتے ہیں ،اور نیک لوگوں کی غلطیاں تلاش کرتے رہتے ہیں ۔&&(تفسیر مجمع البیان)&&{{ {{حضور اکرم صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:  جو چیز سب سے زیادہ لوگوں کو جنت میں داخل کرے گی (۱) تقویٰ ،(یعنی برائیوں سے بچنا اور فرائضِ الٰہیہ کو ادا کرنا) (۲) اور اچھے اخلاق ،ہیں ۔&&(سفینہ ۔ البحار جلد۱ ۔ وسائل الشیعہ جلد ۸ ،تفسیر قرطبی جلد۵ ۱) &&}} !!{{فرزندِ رسول ِ خداصلی اللہ علیہ و آلہ وسلم حضرت امام محّمد باقر علیہ السلام سے روایت ہے کہ جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:  مومنین میں اُس کاایمان سب سے بہتر اور کامل ہے جس کے اخلاق سب سے زیادہ بہتر اور کامل ہیں ۔&&(روح المعانی) &&}}!!{{فرزندِ رسولِ خداصلی اللہ علیہ و آلہ وسلم حضرت امام علی رضا علیہ السلام سے روایت ہے کہ جنابِ رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایاء تمہارے لیے لازم ہے کہ تم اچھے اچھے اخلاق اختیار کرو کیوں کہ اچھے اخلاق والا آدمی آخر کار جنّتی ہوگا ،اور بُرے اخلاق سے بچو ، کیوں کہ بُرے اخلاق والا جہنّمی ہے ۔&&(وسائل الشیعہ جلد ۸) &&}}نیز {{امام علیہ السلام سے یہ بھی روایت ہے کہ :  مومن کے اندر کم سے کم تین صفتیں ضرور ہونی چاہیں ۔ (۱) دوسروں کے راز کا چھپانا ،کہ یہ خدا وندِ عالم کی صفت ہے۔ (اللہ کا کلمہ پڑھنے والا کم سے کم اللہ کی ایک صفت تو اپنے اندر پیدا کرے) (۲)حُسنِ اخلاق کہ یہ جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم کی نمایاں صفت ہے۔ (نبی صلی اللہ علیہ و آلہ وسلم کا کلمہ پڑھنے والے کم سے کم اپنے نبی صلی اللہ علیہ و آلہ وسلم کی سب سے نمایاں صفت تو اپنے اندر پیدا کرے) (۳)مصائب پر صبر ۔ کہ یہ آئمہ اہلِ بیت علیہم السلام کی سب سے نمایاں صفت ہے (آلِ محّمد سے دوستی اور محبت کا دعویدار کم سے کم آلِ محّمدصلی اللہ علیہ و آلہ وسلم کی ایک نمایاں صفت تو اپنے اندر پیدا کرے)&&(تحف العقول ، مولف) &&!!حاصلِ کلام:یہ ہوا کہ (۱) حُسنِ اخلاق جو ایمان کا معیار ہے (۲) تکمیلِ انسانی کا راز ہے (۳) رضائے الہی حاصل کرنے کا وسیلہ ہے (۴)دن رات عبادتیں کرنے کے برابر ہے ( ۵)اور یہ انسان کی بہترین صفت ہے۔&&(تفسیر نمونہ)&&}}
  68,8,آیت ۸ تا۹:شانِ نزول:یہ آیات اُس وقت اُتریں جب مکے کے سرداروں نے حضور اکرم صلی اللہ علیہ و آلہ وسلم سے عرض کی کہ  آپ اپنا پیغام چھوڑ کر بزرگوں کے دین یعنی شرک،بت پرستی اور رسومِ جاہلیت کو قبول فرمائیں ۔خداوندِ عالم نے اِن آیات کے ذریعہ سے رسول صلی اللہ علیہ و آلہ وسلم کو اُن کی بات ماننے سے انکار کرنے کا حکم دیا۔&&(تفسیر کبیر امام رازی جلد۴۰ ،تفسیر مراغی جلد ۲۹)&& ولید بن مغیرہ جو مشرکوں کا بڑا سردار تھا ،نے بہت سارا مال جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم کی خدمت میں پیش کیا کہ اگرآپ اِسلام سے پھر جائیں تو یہ سارا مال حاضر ہے۔&&(تفسیر کبیر) && >> یُدْھِنُوْن << <<مداھنہ>> کے مادہ سے ہے جس کی اصل <<دھن<< ہے۔ یعنی تیل۔ جس کے دوسرے معنی مَسکا لگانا،خوشامد کرنا ،جھکاو اور نرمی کے ہیں ۔ یہاں جھکاو ،بلکہ منافقانہ جھکاو اور نرمی مراد ہے۔&&(مفردات امام راغب ،تفسیر نمونہ)&&
  68,11,آیت۱۱ : << ھَاَّزِ>> <<طعنے دینے والے ۔ جو اپنے طنز و طعنوں سے لوگوں کے دل دکھاتے ہیں ۔
  68,12,آیت ۱۲: << اَثِیْمِ >> بہت زیادہ گناہ کرنے والے کو کہتے ہیں ۔&&(ابنِ کثیر ۔ معالم) &&}} جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:  کیامیں تمھیں شریر ترین (بدترین) لوگوں کے بارے میں بتا دوں ؟ <<سنو بدترین لوگ وہ ہوتے ہیں جو چغل خوریاں کر کرکے دوستوں کے درمیان جدائی ڈالتے ہیں ۔ پاک صاف لوگوں کے عیب فاش کرتے رہتے ہیں ۔&&(اصلِ کافی جلد۲) &&{{!!گویا یہ مکھّی فطرت لوگ ہوتے ہیں جو پورے جسم کے صرف اُس حصے پر بیٹھتی ہے جو سب سے زیادہ گندا اور غلیظ ہوتا ہے ۔ یہ اپنے عیب تلاش کرنے کی بجائے نیک لوگوں کے عیب تلاش کرتے رہتے ہیں ۔ اگر عیب تلاش کرنے کا شوق ہو،توانسان کو اپنے عیب تلاش کرکے اپنی اصلاح کرکے اعلیٰ مراتب حاصل کرنے میں پوری پوری کوشش کرنی چاہیے۔&&(تفسیر نمونہ)&& !!نیز}}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم فرمایا کرتے تھے:  تم میں سے کوئی شخص میرے اصحاب میں سے کسی کے بارے میں کوئی ایسی بات نہ کرے جو مجھے اُس سے بندظن کردے ،کیوں کہ میں یہ چاہتا ہوں کہ سب سے پاکیزہ دل کے ساتھ ملا کروں ۔&&(سنن ابوداود ،صحیح ترمذی ،فی ظلال القرآن جلد۸)&& {{آیت۱۲: << مَنَّاعٍ لِّلْخَیْرِ >>  خیر <<کے عربی میں معنی مال اور بھلائی کے ہوتے ہیں ۔مطلب یہ ہے کہ وہ انسان سخت بخیل ہے جو کسی کو کوڑی دینے کا ارادہ نہیں رکھتا۔ اور اگر >> خیر<<کے معنی بھلائی کے لیے جائیں ،تو اُس کا مطلب یہ ہے کہ وہ ایسا آدمی ہے کہ ہر اچھے کام میں رکاوٹ بنتا ہے ،خاص کر حق کی تبلیغ میں ۔&&(مفردات امام راغب۔ تفسیر کبیر۔ تفہیم)&&
  68,13,آیت ۱۳ : <<عُتُلِ >> عربی میں ایسے شخص کو کہتے ہیں جو خوب ہٹا کٹا ہو۔ ہر چیز کو اپنی طرف کھینچتا ہو،بہت کھاتا پیتا ہو ، مگر ساتھ ساتھ سخت بد اخلاق ،بدکردار ،جھگڑا لو ،ظالم اور سفّاک اور دوسروں کو محروم کرنے والا ہو۔&&(مفردات امام راغت ،لغات القرآن نعمانی،تفسیر کبیر ،مجمع البیان) &&!!قرآن نے کسی کانام نہیں لیا۔ معلوم ہوا کہ جس میں بھی یہ صفات ہوں گی وہ اِس بات کا مصداق ہوگا،اور یہ کہ جس کے یہ اوصاف بیان کیے گئے ہیں ،وہ مکّے میں اتنا مشہور تھا کہ سب سمجھ گئے کہ یہ کن حضرت کی تعریف ہورہی ہے۔مفسرین نے لکھا کہ یہ ولید بن مغیرہ ،اسودبن عبدالیغوث اور اخنس بن شریق تھے۔&&(تفسیر کبیر ۔ تفہیم ،مجمع البیان) &&<< زنِیْمِ>> اُس کو کہتے ہیں جس کا حسب نسب واضح نہ ہو۔ بدنسل انسان۔
  68,14,آیت ۱۴ : کا مطلب یہ ہے کہ کسی آدمی ،بد چلن،بداخلاق ،اِن صفات کے مالک انسان کی دھونس اس بناء پر قبول نہ کرو کہ وہ دولت مند ہے۔ جو بہت مال و اولاد والا ہونے کی وجہ سے مغرور ہوگیا ہو۔جب ہماری آیتیں اس کو سُنائی جاتی ہیں تو کہتا ہے کہ یہ پچھلے وقتوں کے افسانے ہیں ۔&&(تفسیر کبیر۔ تفہیم)&&}}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: تین قسم کے لوگ جنت میں داخل نہ ہوں گے (۱) جواظ ۔ یعنی ہر وہ شخص جو مال بہت زیادہ کرتا رہتا ہے ،اور کنجوس ہوتا ہے۔(۲) جعظرمی ۔ یعنی ۔ سخت مزاج ،بدخو ۔ ہر کسی سے جھگڑے کرنے والا۔ (۳)<<عُتُلِّ زَنِیْمٍ>>۔ یعنی بداخلاق ،پیٹ بھر بھر کے کھانے والا ظالم آدمی۔&&(تفسیر نوالثقلین جلد۵) &&{{
  68,16,آیت۱۶ : << خُرطُومِ >>  ناک پر نشان لگانا۔ {{فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام زین العابدین علیہ السلام نے یزید ملعون کے سامنے اپنے خطبے میں فرمایا کہ:  میں اُس کا بیٹا ہوں جس نے مشرکوں کی ناکوں پر ضرب لگائی تھی۔ (یعنی ناک کاٹ ڈالی یا ذلیل وخوار کیا تھا،جو اپنے کو بڑے بڑے طُرمّ خاں بتے تھے)&&(بحار الانوار جلد ۴۵) &&{{گویا }}خداوندِ عالم کا یہ فرمانا :کہ: ہم ہی اُن کی ناک پر علامت لگائیں گے{{۔حضرت امام علی علیہ السلام ابنِ ابی طالب علیہ السلام کے ہاتھ سے پورا ہوا۔ اللہ کے کام ید اللہ ہی کے ہاتھ سے پورے ہونے چاہیں ۔&&(مولف)&&]]ہاتھ ہے اللہ کا بندہ مومن کا ہاتھ[[&& (اقبال)&&!! <<اَلْخُرْطْوْمِ >> یعنی : ناک: قیامت کے روز اُس کی ناک پر ایسا نشان ہوگا کہ اُس سے سب لوگ اُس کی پہچان لیں گے کہ پیغمبر علیہ السلام کا دشمن ہے۔ اور مروی ہے کہ جنگِ بدر میں اُس کا ناک پر تلوار کا زخم لگا تھا۔ اور قُمی سے منقول ہے کہ زبانِ رجعت میں حضرت امیر المومنین علیہ السلام اپنے دشمنوں کے چہروں پر نشان لگائیں گے ،جس سے وہ دور ہی سے پہچانے جاسکیں گے۔&&(تفسیر انوار النجف)&&!!غرض اِن آیات میں خداوندِ عالم نے بدترین صفات سرداروں ،وڈیروں ،مکاروں کے بُرے صفات و اخلاق کی ایسی تصویر کشی فرمائی ہے کہ پورے قرآن میں اس کی مثال نہیں ملتی۔ اِس سے معلوم ہوتا ہے کہ ہمارے رسول صلی اللہ علیہ و آلہ وسلم کے مخالفین کس قدر گھٹیا ،جھوٹے ،پست اخلاق کہ لوگ ،عیب جو ،چغل خور ،حد سے آگے بڑھنے والے ،گنہگار ،بے اصل لوگ تھے،جو صرف اپنے ذاتی مفادات کی وجہ سے رسولِ اکرم صلی اللہ علیہ و آلہ وسلم کی مخالفت پر تُلے ہوئے تھے۔&&(تفسیر نمونہ)&&
  68,17,آیت نمبر۱۷:<<لَیَصْرَمنہا>> کھجور کے پھل اتارنے کو صرام کہا جاتاہے۔ اور گندم کی فصل کاٹنے کو<<حصاد>>کہا جاتا ہے۔
  68,19,آیت ۱۹: <<طوف>> کے معنی کسی چیز کے گرد گھومنے کے ہوتے ہیں ۔ اِس لیے جو شخص رات کو گھروں کے گرد گھوم گھوم کر گھرو ں کی حفاظت کرتا ہے اُس کو طائف (چوکیدار)کہتے ہیں ۔اصل میں یہ اُس عذاب کا ذکر ہے جو اُن کے باغ پر آیا تھا۔ &&(تفسیر نعمانی جلد ۴) &&
  68,25,آیت نمبر۲۵:یہ ایک مومن کے باغ کا قصّہ ہے:قصہ یہ ہے کہ ایک کھجوروں کا باغ بوڑھے مردِمومن کی ملکیت میں تھا۔ وہ اپنی ضرورت بھر لے کر باقی ساری پیداوار غرباء و فقراء میں تقسیم کردیا کرتا تھا۔ جب وہ مرگیا تو اُس کے بیٹوں نے آپس میں یہ فیصلہ کیا کہ اب ہم کسی حاجت مند کو اس باغ کی پیداوار میں سے ایک دانہ بھی نہ دیں گے۔ ہم خود ہی اس کی پیداوار کے زیادہ مستحق ہیں لہٰذا کل صبح سویرے سویرے ہی ہم پھلوں کو توڑ لیں گے ،تاکہ فقراء و مساکین کو خبر ہی نہ ہوسکے اور سارے کے سارے پھل توڑ کرلے آئیں گے۔اُنھوں نے یہ ارادہ اپنی کسی ضرورت کی وجہ سے نہیں کیا تھا بلکہ اپنی کنجوسی ،خدا سے غفلت اور آخرت پر ایمان نہ ہونے کی وجہ سے کیا تھا،ورنہ انسان کو اپنی پیداوار یا آمدنی میں سے کچھ نہ کچھ حاجت مندوں کے لیے ضرور رکھنا چاہیے۔بعض مفسّرین نے لکھا کہ مستثنیٰ نہ کرنے کا مطلب یہ ہے کہ اُنھوں نے صبح سویرے پھل توڑنے کا فیصلہ محتاجوں کو محروم رکھنے کے لیے کیا اور وہ یہ سمجھے کہ وہ یہ سب کام خوداپنی طاقت کے بل بوتے پر کرلیں گے،اِس لیے اُنھوں نے ان شاء اللہ تک کہنا گوارا نہ کیا۔ کہ اگر اللہ نہ چاہا تو ہم ایسا کریں گے۔ انجام یہ ہوا کہ اللہ نے اُن کے ہرے بھرے پھلدار باغ پر بجلی گرا دی اور باغ جل کر سیاہ ہوگیا اور راکھ کے سوا کچھ باقی نہ رہا۔ طائف سے مراد بلا ہوتی ہے جو اچانک رات کو نمودار ہو۔ اور <<صریم>> کے معنی سیاہ راکھ۔جب یہ احمق صبح سویرے باغ کے پھل توڑنے جارہے تھے تو آپس میں بہت آہستہ آہستہ باتیں کررہے تھے تاکہ کہیں کوئی اُن کی آواز سن کر کچھ پھل مانگنے نہ آجائے۔ اب جو باغ کو جاکر دیکھا تو وہاں راکھ کے سوا کچھ نہ تھا۔&&(تفسیر کبیر) &&!!پہلے تو اُن کو یقین نہ آیا کہ یہ ہمارا وہی باغ ہے جو کل تک پھلوں سے لدا ہوا تھا۔ بولے کہ شاید ہم اندھیرے میں راستہ بھول گئے۔ لیکن بعد میں انھیں احساس ہوا کہ یہ فقراء و مساکین کے محروم کرنے کی نیتِ فاسدہ کا عذاب ہمارے باغ کی تباہی کا باعث ہوا۔&&(تفسیر انوارالنجف)&&!!تعلیم یا سبق: اسلامی تعلیمات میں ہمیں یہ حکم دیا گیا کہ جب پھل توڑو تو اللہ کا حق ، یعنی فقراء حاضر ہونے والوں کو بھی اُس میں سے ایک حصہ دو۔ سورۃ الانعام میں فرمایا: <<وَاٰتُوْ احَقَّہٗ یَوْمَ حَصَادِہٖ >> یعنی:@@ اور اُن کی فصل کی کٹائی کے دن اُس دن اُس کا) اللہ کا حق دیدو @&&(سورۃ الانعام آیت۱۴۱ پارہ ۸) && اس کو <<حق الحصاد >>فصل توڑنے ،کاٹنے کا حق کہتے ہیں جو زکوٰۃ کے علاوہ ہے اُس کی حد مقرر نہیں ہے۔&&(سنن بیہقی) &&!!اسباق(۱) محروموں ،محتاجوں کو اُن کے حق سے محروم رکھنے والے دنیا میں ہی تباہ و برباد ہوجاتے ہیں ۔ کبھی یہ بجلیاں معاشرے میں انقلابوں کی وجہ سے گرتی ہیں ،کبھی جنگوں اور آسمانی بلاوں کی صورت میں وارد ہوتی ہیں ۔&&(مولف)&&!!(۲) ظلم اور گناہ سے روزی کی کمی اور تنگی کا تعلق ہوتا ہے۔{{فرزندِ رسولِ خداصلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا:<< مَنْ حَسُنَ نِیَّتَہٗ زادَ رِزْقَہٗ >>یعنی :  جو اچھی نیت رکھتا ہے ،اُس کے رزق میں اضافہ کیا جاتا ہے۔&&(تحف العقول) &&}}فرزندِرسولِ خداصلی اللہ علیہ و آلہ وسلم حضرت امام باقر علیہ السلام سے روایت ہے کہ : کبھی کبھی انسان گناہ کرتا ہے تو اُس کی روزی کاٹ دی جاتی ہے۔اِس کے بعد امام علیہ السلام نے یہی آیات پڑھیں۔&&(تفسیر نورالثقلین جلد )&&
  68,28,آیت ۲۸ میں لفظ <<اَوْسَطُھُمْ >> کے معنی  اُن کا سب سے اچھا آدمی <<بولا سب سے افضل و بہتر آدمی &&(معالم ۔ ابنِ کثیر بقول عکرمہ ،تفسیر صافی) && !!غرض بتایا جارہا ہے کہ یہ سب سے چھوٹا تھا جس نے اپنے بڑے بھائیوں کو کافی سمجھانے کی کوشش کی تھی کہ تمھارا رویہ غلط ہے ،غریبوں کو محروم نہ کرو ،اور نہ اتنے اتراو کہ جو چاہو کہو ، اللہ کی مرضی کو بھی پیشِ نظر رکھو۔ مگر بڑے بھائی نہ مانے اور تکبر میں آگئے ،مگر جب پوری طرح تیا پانچا ہوگیا،تو لگے ایک دوسرے پر الزام لگانے اور ہائے وائے مچانے۔&&(فصل الخطاب)&&
  68,32,آیت نمبر۳۲:بدلہ دنیا میں بھی مل سکتاہے مگر آخرت میں ملنا لازمی ہے۔ اور یہ بھی ہوسکتا ہے کہ نیکیوں کا بدلہ دنیا میں بھی ملے اور آخرت میں بھی۔ البتہ گناہوں کی سزا اگر دنیا میں مل گئی تو پھر آخرت میں نہ ملے گی۔ ابنِ مسعودنے کہا کہ انھیں دنیا میں ہی ایک اچھا باغ مل گیا تھا۔&&(مدارک)&&ابنِ عباس نے کہا کہ یہ باغ یمن میں تھا۔ &&(معالم)&& یہ باغ حبشہ میں تھا&&(ابنِ کثیر ابنِ جریر) &&قصے کا ماحصل یہ ہے کہ اہلِ غفلت ہمیشہ اپنی چالاکیوں ،مکاریوں ،بدمعاشیوں پر مطمئن اور بھروسہ کیئے رہتے ہیں اور اس طرح غریبوں کا حق مارتے رہتے ہیں ۔ مگر برے کام کا برا انجام ہوتا ہے۔&&(تفسیر ماجدی)&&
  68,35,آیت نمبر۳۵:مکہ کے بڑے بڑے سردار مسلمانوں سے کہتے تھے کہ ہمیں جو یہ نعمتیں دنیامیں مل رہی ہیں یہ اِس بات کی واضح دلیل ہیں کہ خدا ہمیں پسند کرتا ہے ،اور تمھاری بد حالی اِس بات کا ثبوت ہے کہ خدا تم سے ناراض ہے۔ اِس لیے اگر آخرت ہوئی بھی ،تب بھی ہم وہاں بھی مزے اُڑائیں گے اِس لیے کہ وہاں بھی خدا ہمیں اِسی طرح نوازے گا کیوں کہ وہ ہمیں پسند کرتاہے ،اور تم پر وہاں بھی عذابِ الٰہی نازل ہوگا کیوں کہ خدا تم کو پسند نہیں کرتا۔ چنانچہ اس آیت ۳۵ میں ۔ اور۔ آیت۳۶ میں اُن کو جواب دیا جارہا ہے کہ تمھاری یہ بات عقل کے خلاف ہے ۔ کیوں کہ خدا عادل اور حکیم ہے ۔ وہ ہر عیب سے پاک ہے۔ وہ بھلا یہ بات کیسے کرسکتا ہے مجرموں اور فرماں برداروں میں کوئی فرق نہ کرے۔ کیا خداوندِعالم <<معاذ اللہ>>کوئی اندھا راجہ ہے کہ جو آخرت میں اتنا بھی نہ دیکھے گا کہ کس نے اُس کی اطاعت کی تھی،اور کس نے سرکشی کی زندگی گذاری تھی۔ تم احمق ہوکہ صرف دینوی مادی خوشحالی کو تو دیکھ رہے ہو مگر اپنی بدکرداری اور بدمعاشیوں کو نہیں دیکھ رہے اور اس پر یہ حکم بھی لگارہے ہو کہ ہماری طرح خدا بھی ہماری بدمعاشیوں ،بدکرداریوں کو نہیں دیکھے گا۔&&(تفسیر کبیر ۔ تفہیم مجمع البیان)&&
  68,36,آیت۳۶ : احمقوں کے فیصلے ملاحظہ فرمائیں کہ }}خداوندِ عالم نے فرمایا: جب ہم اُسے اپنی طرف سے تکلیف اور پریشانی کے بعد رحمت کا مزہ چکھاتے ہیں ،تو وہ احمق کہتا ہے کہ :  یہ میری اچھائیوں اور مستحق ہونے کی وجہ سے ہوا ہے،اور یہ بھی سمجھتا ہے کہ قیامت کبھی برپا نہ ہوگا }}( یہ مال عہدہ ،اولاد ہمیشہ ہمیشہ میرے ہی پاس رہے گا کیوں کہ میں ہوں ہی بہت اچھا آدمی) اور اگر بالفرض قیامت آہی گئی ،تو جس وقت میں اپنے پالنے والے مالک کے پاس لوٹوں گا ،تو میرے لیے خدا کے پاس بہت اچھا اجر اور بڑے اعلیٰ بدلے ہوں گے!!۔یہ احمق دنیا اور آخرت کو اپنے ہی لیے مخصوص سمجھتا ہے ،جبکہ اُس نے کوئی نیک کام بھی انجام نہیں دیا۔ مگر یہ اُس کی خود پسندی کی انتہا ہے۔اِسی لیے آخر میں خداوندِ عالم اُس احمق سے پوچھ رہاہے کہ:  کیاتمھارے پاس اِس دعوٰے کی کوئی نقلی یا عقلی دلیل ہے ؟ کیاتمھارے پاس کوئی آسمانی کتاب ہے جس سے تم یہ اُلٹے سُلٹے سبق سیکھتے ہو؟ (مسخ شدہ آسمانی کتاب مراد ہے)
  68,38,آیت۳۸ : کافر کہتے ہیں کہ ہم جس طرح دنیا میں مزے اُڑارہے ہیں ،اِسی طرح آخرت میں بھی مزے اڑائیں گے اور مسلمان دنیامیں بھی سختیاں جھلیں گے اور آخرت میں بھی۔جواباً کافروں سے کہاجا رہا ہے۔ یہ تمہارا احمقانہ فیصلہ ہے جوعقل کے خلاف ہے۔ اس لیے کہ آخرت توجزاء وسزا کاعالم ہے، پھر بھلا یہ کیسے ممکن ہے کہ نافرمانیاں اور بدمعاشیاں کرنے والے جو<< دارالجزاء>> ہے۔ مزے اُڑائیں اور شرافت اور نیکیوں پر سزا دی جائے۔ یہ سب تمھاری اوندھی عقل کے اُلٹے سُلٹے فیصلے ہیں ۔&&(فصل الخطاب ،تفسیر ماجدی ،تفسیر کبیر)&&
  68,40,آیت نمبر۴۰: مطلب یہ ہے کہ تمھارے سب دعوے بے بنیاد ہیں ۔ خود پسندی کے سوا کچھ نہیں ،&&(تفسیر نمونہ)&&
  68,41,آیت نمبر۴۱: کافروں سے اُنکے غلط فیصلوں کی سند اور مآخذ پوچھا جارہاہے۔ کہ کیا اللہ کی طرف سے تمھارے پاس کوئی آدمی آیا ہے جس سے تم نے یہ عہد لے لیا ہو کہ تم خدا کے قانونِ مکافات اور خدا کی سزاوں سے مستثنیٰ کردئیے گئے ہو؟ کیا تمہارے بنائے ہوئے خدا کے شریکوں نے تم سے ایسے ایسے احمقانہ فیصلے کروائے ہیں ؟ کیا تمھارے اُلٹے فیصلوں نے خدا کو اپنا پابند بنا لیا ہے؟ اپنے جھوٹے دعووں پر کوئی عقلی یا نقلی دلیل پیش کرو۔ مگر جھوٹ کے پاوں کہاں؟&&(فصل الخطاب)&&
  68,42,آیت نمبر۴۲:&&(نوٹ) &&آخرت میں صرف وہی لوگ خدا کو سجدہ کرسکیں گے جنہوں نے دنیامیں خداکی اطاعت کی ہوگی۔آیت ۴۲<< یُکْشَفُ عَنْ سَاق>> (پنڈلی کھولنے) کا لفظ استعمال ہوا ہے۔عربی محاورے میں کشفِ ساق یعنی۔>> پنڈلی کھولنے <<کے معنی کسی سخت مشکل وقت آ پڑنے کے ہوتے ہیں ۔ کیوں کہ سخت مشکل وقت میں انسان پاجامہ کے پانچے اوپر چڑھا کر بھاگتا ہے جس سے پنڈلیاں کھل جاتی ہیں ۔&&(مدارک،تفسیر روح المعانی، قاموس،تاج۔مفردات امام راغب ،ابنِ جریر) &&<< یَوْمَ یُکْشَفُ عَنْ سَاقٍ >> یعنی  جس دن پنڈلی کھول دی جائے گی۔یعنی جس دن سختی ظاہر ہوگی۔ عربی میں ایسے سخت موقع پر کہتے ہیں <<التَّفَّتِ السَّاقُ بِالسَّاقِ>> یعنی لپٹ گئی پنڈلی پر پنڈلی۔ یعنی شدت پر شدت لپٹ گئی ۔ بلاوں پر بلائیں ٹوٹ پڑیں ۔ جب کسی واقعہ کی شدت اور ہولناکی بتانی ہوتی ہے تو پنڈلی کا ذکر کیاجاتا ہے۔&&(لغات القرآن نعمانی) && !!دوسرا مطلب یہ ہے کہ جس دن تمام معاملات کی اصلیت اور حقیقت بالکل اِس طرح سے کھل جائے گی کہ آنکھیں اُس کو واضح طور پر دیکھ لیں گی۔ درخت کے تنے کو بھی ساق کہتے ہیں اُس کی چھال اُتر جائے تو لکڑی کی حقیقت معلوم ہوجاتی ہے۔&&(تفسیر کبیر ۔ مفردات امام راغب ۔ مجمع البیان طبرسیؒ) &&}}ابنِ عباس نے فرمایاکہ: کشف ساق سے مراد حقائق پر سے پردہ اٹھالیاجانا ہے۔ مطلب یہ ہوا کہ قیامت کے دن تمام حقیقتیں بے نقاب ہوجائیں گی اور ہر شخص کا عمل کُھل کر سامنے آجائے گا۔&&(تفسیر ابنِ عباس ۔ تفسیر کبیر) {{&& !!ایک اعتراض اور اُس کا جواب:اعتراض کیا جاتا ہے کہ قیامت کے دن شریعت کی پابندیاں ختم ہوچکی ہوں گی،وقتِ امتحان گذر چکا ہوگا۔ پھر لوگوں کو سجدہ کرنے کی دعوت کیوں دی جائے گی۔؟ جواب یہ ہے کہ: }}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:  قیامت کے دن نورِ الھٰی سے حجاب اُٹھا دیا جائے گا،مومنین نورِ الھٰی کی عظمت (شان بان) کو دیکھ کر سجدے میں گڑپڑیں گے ،مگر (منکروں اور) منافقوں کی پیٹھ اتنی سخت ہوجائے گی کہ وہ سجدہ نہ کرسکیں گے ۔&&(تفسیر نورالثقلین جلد ۵ ) && معلوم ہوا کہ جولوگ دنیا میں خداتعالیٰ کی عظمت کے آگے جُھکنے کے عادی تھے وہاں بھی فوراَ سجدہ ریز ہوجائیں گے ،لیکن جو دنیامیں عظمتِ الھٰی سے متاثر نہ ہوکر سجدے نہیں کرتے تھے،وہ وہاں بھی سجدہ نہ کرسکیں گے۔ البتہ مومنین نورِ الھیٰ کی عظمت سجدہ کرنے کی دعوت (تقاضوں ) پورا کریں گے۔ اور یہ اُن کے لیے بڑی عّزت مرتبہ اور معراجِ کمال ہوگی۔&&(تفسیرنمونہ)]] &&وہ ایک سجدہ جسے تو گراں سمجھتا ہے۔ہزار سجدوں سے دیتا ہے آدمی کو نجات[[ &&(اقبال)&&
  68,44,آیت نمبر۴۴:<<فَذَرْنِیْ >> پس مجھے چھوڑ دو مطلب یہ ہے کہ اے رسولؐ! آپ صلی اللہ علیہ و آلہ وسلم کافروں اور حق کے منکروں سے نمٹنے کی فکر نہ فرمائیں ،اُن سے نمٹنا میرا کام ہے آپ صلی اللہ علیہ و آلہ وسلم اُن کا معاملہ مجھ پر چھوڑ دیں ۔<<استدراج>>یعنی  بے خبری میں آہستہ آہستہ تباہی کی طرف لے جانا اِس طرح ہوتاہے کہ خداوندِ عالم ظالموں کو دنیا کی نعمتوں سے نوازتا چلا جاتا ہے۔صحت ،مال ،اولاد ،دنیا کی کامیابیاں قدم چومتی چلی جاتی ہیں ۔ اصل مقصد اتمامِ حجت ہے اور سوچنے ،سنبھلنے کی مہلت دینا ہوتا ہے۔ مگر وہ احمق سمجھتا ہے کہ مجھ میں ضرور کوئی سرخاب کا پر لگا ہوا ہے کہ خدا مجھے نوازے ہیں چلا جارہا ہے۔ اِس طرح کا ظلم اور سرکشی روز بروز بڑھتی ہی چلی جاتی ہے۔وہ احمق مرتے دم تک یہ نہیں سمجھ پاتا کہ جو نعمتیں اُسے مل رہی ہیں وہ انعاماَ نہیں مل رہی ہیں بلکہ امتحاناً مل رہی ہیں ۔ اُس نے کونسا ایسا اچھا کام کیا ہے جس کے انعام میں اس کو نعمتیں عطا کی جائیں ؟ غرض اُس کی ناسمجھی کی وجہ سے خدا کی نعمتیں اُس کے لیے خدا کا عذاب بن جاتی ہے۔&&(تفہیم ،تفسیر کبیر ،مجمع البیان ،انوار النجف) &&{{فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ:  کبھی کبھی جب سرکش لوگ گناہ پر گناہ کیے چلے جاتے ہیں ،تو خدا اُن کو اور نعمتیں (امتحاناً)بھی دیتا ہے۔ اِس پر وہ (بجائے شکرِ نعمت کے) اور اپنے گناہوں سے غافل ہوجاتے ہیں اور توبہ کرنا بھی بھول جاتے ہیں ،یہی << اِستدراج>> ہے یعنی تدریجی بلاء یا درجہ بدرجہ عذاب کی طرف لے جانا۔&&(تفسیر مجمع البیان طِبرسیؒ) &&{{گویا خدا کا عذاب اِس طرح بھی آتا ہے کہ گناہوں کے مقابلے پر اُنھیں مہلت اور نعمت دی جاتی ہے،وہ اُسے خدا کی مہربانی سمجھنے لگتے ہیں ۔ نتیجتاً،غفلت ،ظلم،گناہ،فِسق و فجور میں ڈوبتے چلے جاتے ہیں ۔ پھر اچانک خذا کا عذاب اُن کو پکڑ لتا ہے۔ یہ عذابِ الہٰی کی سب سے خطرناک اور دردناک شکل ہے۔ اچانک بندہ کو نعمتوں سے نکال کر عذابوں میں ٹھونس دیاجاتا ہے۔ << الامان ،الحفیظ>> &&(تفسیر نمونہ)&&(اسی حقیقت کو جناب زینب علیہ السلام نے یزید کے سامنے اپنے خطبے میں پیش فرمایا تھا)&&(مولف)&&استدراج کی پہچان:(۱) ایک شخص نے حضرت امام جعفر صادق علیہ السلام سے پوچھا: میں نے خدا سے مال طلب کیا،خدا نے مجھے مال عطا فرمادیا۔ پھر میں نے خدا سے اولاد طلب کی ،خدا نے اولاد بخش دی۔ یہ کہیں استدراج تو نہیں ہے؟}}امام علیہ السلام نے فرمایا:  اگر خدا کی عطاوں کے ساتھ ساتھ حمد وشکر (واطاعتِ خدا) ہو،تو پھر یہ استدراج نہیں ۔ (بلکہ نعمت ہے)&&(اصولِ کافی ،تفسیر نورالثقلین جلد ۵ ) &&{{ (۲) {{فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ: جب انسان پر اللہ تعالیٰ کی نعمت آئے اور گناہ کرنے کے بعد توبہ نہ کرے،تو یہی خدا کا قانونِ استدراج ہے ۔&&(تفسیر انوارالنجف)&& {{!!اصل فلسفہ یہ ہے کہ خداوندِ عالم ظالموں ،جابروں اور قوموں پر عذاب میں جلدی نہیں فرماتا کیوں کہ (۱) خدا کو ظالم کے قبضے سے نکل جانے کا خوف نہیں ہوتا۔(۲)خدا نے دنیا کو امتحان کے لیے بنایا ہے ،اور امتحان دینے کے لیے کچھ وقت دینا ضروری ہوتا ہے۔&&(تفسیر نمونہ۔ تفسیر کبیر)&& (۳)یہ کہ خداوندِعالم حجت تمام کرنا چاہتا ہے ،اگر گناہ یا ظلم کرنے پر فوراَ سزا دیدے تو تو کل روزِ حساب یہ ظالم،جابر،جاسق و فاجر یہ کہیں گے کہ: مالک! آپ نے ہمیں سوچنے،سمجھنے،سنبھلنے کا موقع ہی نہیں دیا۔ اگر موقع دیاجاتا تو ہم اپنی غلطیوں پر ضرور نادم ہوکر اپنی اصلاح کرلیتے۔ اِس طرح خدا کے عذاب اور دائمی سزا سے بچ نکلنے کی صورت پیدا ہوجاتی ،اور حجّت تمام بھی نہ ہوپاتی۔&&(مولف)&& }}نیز امام علیہ السلام سے روایت ہے کہ:  بہت سے لوگ اِس بات سے دھوکہ کھاجاتے ہیں کہ اگر اللہ تعالیٰ فلاں شخص سے راضی نہ ہوتا تو اُس پر اپنی دُنیوی نعمتوں کی بارش کیوں کرتا؟ جبکہ خدا فرماتا ہے کہ:  میں کافروں کو مہلت پر مہلت اور ڈھیل پر ڈھیل دیتا ہوں <<۔ میں فوری طور پر گناہوں پر سزا نہیں دیتا۔ کیوں کہ جلد بازی وہ کرے جس کو مجرم کے بھاگ جانے کا خوف ہو ،جبکہ میری گرفت اس قدر مضبوط ہے کہ کوئی اُس سے نکل کر بھاگ نہیں سکتا۔&&(تفسیر انوارالنجف)&&{{
  68,45,آیت نمبر۴۵:<< اِنَّ کَیْدِیْ مَتِیْنٌ >> << کَیْد>> کے معنی خفیہ تدبیر کے ہوتے ہیں۔ خفیہ چال صرف اُس وقت بُری ہوتی ہے جب اُس کا مقصد کسی کو نقصان پہنچانا ہو۔ ورنہ بجائے خود اِس میں کوئی بُرائی نہیں۔ خاص طور پر اس کے ساتھ ایسا کرنا جو اس طرزِ عمل کا اِس لیے مستحق ہو کہ اُسنے ظلم و جبر فسق فجور کو اپنا طرزِ عمل بنالیا ہو۔ جیسی کرنی ویسی بھرنی۔&&(تفہیم)&& تفسیر انوار النجف میں << کید>> کے معنی عذاب کے لکھے ہیں۔ یعنی تحقیق میرا عذاب بہت سخت ہے۔
  68,46,آیت ۴۶کا مطلب یہ ہے کہ: اے احمقو! کیا تم یہ سمجھتے ہو کہ اگر خدا کے رسول صلی اللہ علیہ و آلہ وسلم کو مان لوگے تو تم سے اِسکا کوئی بڑا معاوضہ طلب کرلیا جائے گا؟&&(فصل الخطاب)&&
  68,47,آیت ۴۷پس یہ سوال بظاہر جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم ہی سے کیا جا رہا ہے ،مگر اصل مخاطب آپ صلی اللہ علیہ و آلہ وسلم کے مخالفین ہیں ۔ مطلب یہ ہے کہ : اے احمقو! کیاتم نے پردے کے پیچھے جھانک کر دیکھ لیا ہے کہ ہمارا یہ رسول صلی اللہ علیہ و آلہ وسلم ہمارا بھیجا ہوا نہیں ہے،اور جو ابدی حقیقتیں یہ بیان کررہا ہے وہ سب غلط ہیں ،اس لیے تم اُس کو اتنی شدت کے ساتھ جھٹلا رہے ہو؟&&(تفسیر مجمع البیان۔ تفسیر کبیر ،تفہیم)&&
  68,48,آیت۴۸ کا پیغام:یہ ہے کہ (۱) اے رسول صلی اللہ علیہ و آلہ وسلم ! لوگوں کی مخالفتوں پر صبر کیجئے۔ جلد بازی سے کام نہ لیجئے۔ یونس علیہ السلام کی طرح گھبرا کر بد دعا نہ کیجئے۔ خدا سے پوچھے بغیر کوئی چھوٹے سے چھوٹا کام بھی نہ کیجئے۔ مثلاً؛ جس طرح حضرت یونس علیہ السلام خدا سے پوچھے بغیر بد دعاء کرکے شہر سے تشریف لے گئے تھے۔ آپ صلی اللہ علیہ و آلہ وسلم ایسی جلد بازی ہرگز نہ کیجئے گا۔&&(فصل الخطاب ۔ تفسیر کبیر)(۲) !!دوسرا پیغام یہ ہے کہ : اے رسول صلی اللہ علیہ و آلہ وسلم ابھی وہ وقت دور ہے کہ جب خدا یہ فیصلہ فرمائے کہ تمھارے دشمن مغلوب ہوجائیں اس لیے اس وقت جو دشواریاں پیش آرہی ہیں اُن کو برداشت کیجئے تاکہ آپ کی سیرت آپ ؐکی اُمت کے لیے رہنمائی کا ذریعہ بن جائے۔ پھر اِس بات کو مزید سمجھانے کے لیے حسّی مثال دی کہ : خبردار! حضرت یونس علیہ السلام کی طرح بےصبری سے کام نہ لینا۔ اِسی بےصبری اور جلد بازی کی وجہ سے وہ مچھلی کہ پیٹ میں پہنچادئیے گئے تھے۔&&(تفسیر کبیر ۔ مجمع البیان۔ تفہیم)&&
  68,49,آیت نمبر۴۹: حضرت یونس علیہ السلام بغیر خدا کی اجازت لیے اپنی قوم کے لیے بد دعاء فرماکر بستی سے نکل پڑے۔ کشتی پر بیٹھے تو دریا میں طوفان آگیا۔ تب حضرت یونس علیہ السلام کو احساس ہوا کہ غلطی ہوگئی۔ مجھے خداوندِ عالم سے اجازت لے کر بستی سے نکلنا چاہیے تھا ۔ جلد بازی نہیں کرنی چاہیے تھی۔اِدھر جب کشتی طوفان میں گِھر گئی تو لوگوں نے آپس میں کہا کہ ہم میں ضرور کوئی غلام اپنے آقا کی اجازت کے بغیر بھاگ نکلا ہے۔ کیوں کہ اُن لوگوں کا عقیدہ یہ تھا کہ ایسے بھاگے ہوئے غلام کی وجہ سے طوفان آیا کرتے ہیں ،اِس لیے ایسے آدمی کو دیار میں پھینک دینے سے طوفان ٹل جایاکرتے ہیں ۔اب جو کشتی میں سوار لوگوں کے ناموں کا قرعہ پڑا،اور بار بار حضرت یونس علیہ السلام کا ہی نام نکلا۔ تو اُن کو بالکل یقین ہوگیا کہ وہ اپنے مالک خداوندِ عالم کی اجازت کے بغیر بستی سے نکل پڑے ،اُن کو خدا کے حکم کا انتظار کرنا چاہیے تھا۔ اِسی دوران اُنھوں نے دیکھا کہ طوفان کی وجہ ایک بہت بڑی مچھلی تھی،جو کشتی کے چکر لگارہی تھی۔ حضرت یونس علیہ السلام بغیر کسی تردّد کے کشتی سے سمندر میں کود پڑے تو مچھلی نے اُن کو نگل لیا۔ اب اُنھوں نے اپنی غلطی کا اعتراف اِن الفاظ میں کیا:<<لَآ اِلٰہَ اِلَّا اَنْتَ سُبْحٰنَکَ اِنیِّ کُنْتُ مِنَ الظّٰلِمِیْنَ >> &&نہیں ہے کوئی معبود سوا تیرے ،تو ہر عیب سے پاک ہے میں گنہگار ظالم ہوں &&۔آخرِ کار خدا نے توبہ قبول فرمائی اور مچھلی نے دریا کے کنارے کھلے میدان میں اُن کو اُگل دیا۔&&(فصل الخطاب ۔ مجمع البیان)&& !!سبق:اِس واقعے سے یہ سبق ملا کہ: (۱) اہم فیصلے کرتے وقت جلد بازی نہیں کرنی چاہیے۔(۲) جلد بازی میں بد دعا نہیں کرنی چاہیے۔&&(مولف)&&(۳) سزا دینے میں بھی جلدی نہیں کرنی چاہیے۔ &&(مرشد تھانوی)&&(۴)!!جس وقت حضرت یونس علیہ السلام مچھلی کے پیٹ میں ڈالے گئے تھے وہ ملامت کی حالت میں تھے مگر جب اُنھوں نے خدا کی تسبیح کی اور اپنی غلطی کو دل سے مان لیا،تو مچھلی کے پیٹ سے نکال کر چٹیل میدان پر پھینکے گئے ،مگر اُس وقت وہ ملامت یا مذمت کی حالت میں نہ تھے۔ اِسی لیے کہ خداوندِ عالم نے اُن کی تسبیح اور معانی مانگنے کی وجہ سے اپنے دامنِ رحمت میں لے لیا تھا ۔ وہیں ایک بیل دار درخت اُگا دیا۔ اُس کے پتّے سایہ دیتے اور اُس کا پھل بھوک پیاس کو دور کرتا۔اِس سے معلوم ہوا کہ انسان کو خدا کی تسبیح تعریف وار شکر کرتے رہنا چاہیے۔ اور (۵) اپنی خطاوں کی دل سے معافیاں مانگتے رہنا چاہیے۔ایسا کرنے سے خدا کا دامنِ رحمت اُس کو ڈھانپ لے گا۔ (سبحان اللہ)&&(تفسیر کبیر ،مجمع البیان ،تفہیم) &&
  68,50,آیت نمبر۵۰:تسبیح الٰہی کی عظمت:آیات سے معلوم ہوا کہ دو مختلف سزائیں ،ایک شدید اور دوسری ہلکی،حضرت یونس علیہ السلام کے انتظار میں تھیں ۔ پہلی سزا یہ کہ قیامت تک مچھلی کے پیٹ میں رہیں ۔ دوسری یہ کہ جب بھی مچھلی کے پیٹ سے نکلیں مذموم اور خدا کی مہربانیوں سے دور ہوکر۔لیکن حضرت یونس علیہ السلام کی تسبیح اور استغفار کرنے کی وجہ سے دونوں سزائیں ٹل گئیں ۔ مچھلی کے پیٹ سے باہر بھی نکل آئے اور قابلِ مذمت بھی نہ رہے۔معلوم ہوا کہ خدا کی تسبیح کرنے کی وجہ سے ،اور اپنے گناہوں پر معافیاں طلب کرنے سے انسان کے گناہ صرف مٹادئیے جاتے ہیں ،بلکہ(۲) وہ قابلِ ملامت بھی نہیں رہتا۔ (۳) اور اگر وہ نیکیاں کرتا ہے تو خدا اُس کو نیک بندوں میں چن بھی لیتا ہے ۔ >>سبحان اللہ<< &&(تفسیر نمونہ)&&!!خداوندِ کریم کی نعمت نے حضرت یونس علیہ السلام کے مسئلہ کے حل کا تدارک اس طرح فرمایا:خدا کی رحمت شاملِ حال ہوئی ،اور وہ شکم ماہی سے باہر نکلے۔ غرض اللہ نے اپنی رحمتِ کاملہ و واسعہ کی وجہ سے اُن کی دعاء کو قبول فرمایا: اِس طرح کہ مچھلی کے پیٹ سے زندہ باہر نکالا۔(۲) مذموم حالت سے نجات دی۔ یعنی اُن کا ترک اولیٰ معاف فرمایا۔ (۳) پھر عہدہ نبوت سے سرفراز فرمایا &&(۴)اور اُن کی قوم کی طرف دوبارہ بھییجا ،جہاں وہ (۵) باعزت طور پر قوم میں رہے۔&&(تفسیر انوارالنجف)&&
  68,51,آیت ۵۱: شاہ عبدالقادر شاہ صاحب نے لکھا کہ: مطلب یہ ہے کہ کافر ،جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کو سخت غصے میں گھور گھور کر اِس لیے دیکھتے تھے کہ شاید اس طرح رسولِ خدا صلی اللہ علیہ و آلہ وسلم ڈر کر قرآن پڑھنا چھوڑ دیں ۔&&(موضع القرآن)علامہ طِبرسیؒ نے لکھا کہ: عرب محاورہ ہے کہ:]] اُس نے میری طرف ایسی نگاہ سے دیکھا کہ قریب تھا کہ وہ مجھے زمین پر گرا دے گا،اور ایسی سخت نگاہ سے دیکھا کہ قریب تھا کہ وہ مجھے کھا جائے یا مار ڈالے[[&&(مجمع البیان۔ بیضاوی) &&!!بعض لوگوں نے اِس آیت سے یہ نتیجہ نکالا کہ نظرِ بد اثر رکھتی ہے۔ عربوں کا یہ محاورہ ہے کہ ]] نظرِ بد اونٹ کو قبر میں اُتار دیتی ہے۔[[ بُری نگاہوں کا اثر تجربے اور مشاہدے سے بھی ثابت ہے۔ مگر اُس کا تعلق اِس آیت سے کچھ سمجھ میں نہیں آتا۔&&(فصل الخطاب)&& !!نظرِ بد کا تعویز:}}جناب امیر المومنین علیہ السلام نے فرمایا کہ جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے امام حسن علیہ السلام اور امام حسین علیہ السلام کے لیے بدنظر سے حفاظت کے لیے یہ تعویز بتایا تھا کہ:<<اُعیذکمابکلمات اللہ التامۃ واسمائہ الحسنی کلھاعامۃً من شرالسآمۃِ والھامۃِ ومن شرکل عینٍ لآمۃٍ ومن شرحاسدٍاذاحسد>> یعنی:  (میں نے تم دونوں کو خدا کے کامل کلمات کی پناہ میں ،اور اُس کے بہترین ناموں کی پناہ میں دیا،عموما ہر ڈسنے والے اور کاٹ کھانے والے سے ،بُری نظر ڈالنے والی ہر آنکھ کے شر سے ،اور حسد کرنے والے کے شر سے جب وہ حسد کرے)۔{{!! }}جناب امیر المومنین علیہ السلام نے فرمایا کہ : << العین حق و الرقی حق>> بُری نظر بھی حقیقت ہے اور اس کو دفع کرنے کے لیے دعاء اور تعویز بھی ہے۔&&(نہج البلاغہ کلمات قصارنمبر ۴۰۰) &&{{ مگر نظرِبد یا جادو ٹوٹکوں سے بچنے کے لیے بیہودہ اعمال کا سہارا لینا جائز نہیں ،جو عامل لوگوں کو بے وقوف بنانے کے لیے کرتے ہیں ،اور خوب خوب مال بٹورتے ہیں خاص کر ایسے اعمال جو شریعت کے خلاف ہوں یا گندے ہوں ۔&&(تفسیر نمونہ)&&!!شانِ نزول:(۱) کفار اپنی نظروں سے دوسروں کو متاثر کرنے کے لیے ایک عمل یہ کرتے تھے کہ تین دن کچھ کھائے پیئے بغیرے رہتے اور جس کو اپنی نظرِ بد سے نقصان پہنچانا چاہتے اُس کو خوب تعریف کرتے ،اور اِ سطرح اُس کو گرادیتے۔خداوندِ عالم فرمارہا ہے کہ:اے رسولؐ! یہ کفار آپ صلی اللہ علیہ و آلہ وسلم کو بھی اپنی نظرِ بد سے شکار کرنا چاہتے ہیں ۔ کیوں کہ اُن کو آپ کا قرآن پڑھنا سخت ناگوار ہوتا ہے،مگر اللہ آپ صلی اللہ علیہ و آلہ وسلم کو اُن کے ہر قسم کے شر سے محفوظ رکھتا ہے۔ اس لیے آپ کو اُن کے ہر قسم کے شر سے محفوظ رکھتاہے۔ اس لیے آپ کو گھبرانے کی کوئی ضرورت نہیں ۔ وہ آپ صلی اللہ علیہ و آلہ وسلم کے کلام کے اثر سے گھبرا کر آپ صلی اللہ علیہ و آلہ وسلم کو کبھی دیوانہ ،کبھی جادوگر کہہ دیتے ۔ اِس لیے آپ صلی اللہ علیہ و آلہ وسلم اُن کی پرواہ نہ کریں ۔اِس طرح رسولِ اکرم صلی اللہ علیہ و آلہ وسلم کو صبر کی تلقین کی گئی ہے۔&&(تفسیر انوار النجف)&& (۲) !!{{فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ: روزِ غدیر جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے حضرت امام علی ابنِ ابی طالب علیہ السلام کو اپنے ہاتھوں پر بلند فرمایا اور آپ علیہ السلام کی مولائیت کا اعلان فرمایا،تو منافقوں نے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم اور حضرت امام علی علیہ السلام کو گھور گھور کر دیکھنا شروع کردیا ،اور ایک دوسرے سے کہتے تھے کہ رسولِ خدا صلی اللہ علیہ و آلہ وسلم پاگل ہوگئے ہیں <<معاذ اللہ>> ۔ اس پر جبریل علیہ السلام یہ آیت لے کر اُترے۔&&(تفسیر براہان ،انوارالنجف) &&اِس سورۃ کی آخری دونوں آیات نظرِ بد کا تعویز ہیں ۔&&(تفسیر انوارالنجف)&&
