  72,1,آیت نمبر۱:شانِ نزول:جناب رسولِ خدا مکہ اور طائف کے درمیان بازار ِعکاظ میں اسلام کی دعوت دینے کے لیے تشریف لے آئے ،مگر کسی نے آپؐکی ایک بات نہ سنی ،واپسی میں آپ صلی اللہ علیہ و آلہ وسلم نے ایک وادی میں رات کو قیام فرمایا: آج کل اُ سکو وادی جن کہتے ہیں رات کے وقت آپ صلی اللہ علیہ و آلہ وسلم قرآن کی تلاوت فرمارہے تھے کہ جنوں کا ایک گروہ وہاں سے گذرا انھوں نے قرآن کو بغور سنا اور ایمان لے آئے اور پھر اپنی قوم میں جاکر اسلام کی تبلیغ کی۔&&(تفسیر علی ابن ِبراہیم۔تفسیر نورالثقلین ) &&[[خدا کے دین کو کا موسیٰ سے پوچھیئے احوال۔کہ آگ لینے کو جائیں پمیبری مل جائے]]حضرت ابنِ عباسؓ کہتے ہیں کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم صبح کی نماز پڑھ رہے تھے ،اُدھر جن آیات کی تحقیق کررہے تھے کہ آسمانوں پر اس قدر سخت پہر کیوں بھٹا دئیے گئے ہیں ؟ ہمیں کیوں آسمان سے کوئی خبر حاصل کرنے سے روک دیا گیا ہے؟ اُن جنوں نے جب رسولِ اکرم صلی اللہ علیہ و آلہ وسلم سے قرآن سنا تو وہ سمجھ گئے کہ یہی قرآن ہے جس کا نزول ہو رہا ہے،اِسی لیے آسمان پر ہمارے جانے پر پہرے بھٹا دئیے گئے ہیں ۔ چنانچہ وہ اسلام لے آئے اور اسلام کے مبلغ بن گئے۔&&(صحیح بخاری ۔مسلم ،مُسند احمد ،فی ظلال ،تفسیر کبیر ،تفسیر ابنِ عباسؓ) &&حضرت ابو طالب علیہ السلام کی وفات کے بعد جب رسولِ خدا صلی اللہ علیہ و آلہ وسلم پر سخت وقت آگیا تو آپ صلی اللہ علیہ و آلہ وسلم نے طائف جانے کا ارادہ فرمایا،مگر طائف کے سرداروں نے شدّت سے آپ ؐکی مخالفت کی ۔ آپ صلی اللہ علیہ و آلہ وسلم کو اِس قدر پتھر مارے کہ پاہائے مبارک سے خون بہنے لگا۔ تھکے ماندے ایک باغ کے پاس وارد ہوئے اُس باغ کے مالک کا غلام عداس آپ صلی اللہ علیہ و آلہ وسلم پر ایمان لے آیا۔ پھر آپ صلی اللہ علیہ و آلہ وسلم مکّے کی طرف لَوٹے تو رات کے وقت ایک کھجور کے درخت کے قریب نماز پڑھنے لگے۔ اُسی جگہ سے نصیبین اور یمن کے جنوں کا ایک گروہ گذر رہا تھا۔ اُنھوں نے صبح کی نماز میں جناب رسولِ خداؐ کی تلاوت کو غور سے سنا اور ایمان قبول کرلیا۔&&(تفسیر مجمع البیان ۔سیرت ابنِ ہشا م جلد ۲) &&ابنِ مسعود کہتے ہیں کہ ہم نے ایک رات حضور صلی اللہ علیہ و آلہ وسلم کو مکے میں نہ پایا۔ ہم آپ صلی اللہ علیہ و آلہ وسلم کی تلاش میں نکلے ،کوئی پتہ نہ چلا،ہم ڈرگئے کہ کہیں دشمنوں نے آپ صلی اللہ علیہ و آلہ وسلم کو قتل نہ کردیا ہو۔ غرض ہم تلاش کرتے ہوئے مکے کے دروں کی طرف گئے تو اچانک ہم نے دیکھا کہ رسول صلی اللہ علیہ و آلہ وسلم کوہِ حرا کی طر ف سے آرہے ہیں ۔ ہم نے دریافت کیا: آپ صلی اللہ علیہ و آلہ وسلم کہاں تھے؟ ہم رات بھر آپ صلی اللہ علیہ و آلہ وسلم کو تلاش کرتے رہے ؟ کل رات ہماری زندگی کی بدترین رات تھی۔}} آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا: جنوں میں سے ایک جن مجھے لینے کے لیے آیا تھا اور میں اُن کے لیے قرآن پڑھنے گیا تھا۔&&(تفسیر مجمع البیان)&&{{ <<قُرْاٰنًا عَجَبًا >>:یعنی عجیب و عریب پڑھی جانے والی و چیز شاید جنوں نے یہ الفاظ اس لئے استعمال فرمائے کہ اُنھوں نے پہلی مرتبہ قرآن سنا تھا ۔ اُن کو اُس وقت معلوم ہی نہ تھا کہ یہ کیا چیز پڑھی جارہی ہے؟&&(تفہیم)&& ، عجب ،کا لفظ مبالغہ کا صیغہ ہے۔ عربی میں اس کے معنی بہت زیادہ حیران کردینے والی چیز کے ہیں جنوں کا مطلب یہ تھا کہ ہم ایسا کلام سُن کر آئے ہیں جو اپنی زُبان اور مضامین کے اعتبار سے حیران کُن حد تک لا جواب اور بے نظیر ہے۔&&(مفردات امام راغب)&&قرآن مجید کو عجب اس لیے کہا گیا ہے کہ باوجود اس کے کہ <<حروفِ تہجی>> اور <<الفاظ متداولہ عربیہ>> سے مرکب ہے لیکن معافی و مقاصد اور روانی و تسلسل کے اعتبار سے اپنی نظیر آپ ہے۔ خارقِ عادت ہونے کے لحاظ سے اِس کو<< عجب <<سے تعبیر کیا گیا ہے۔&&(تفسیر انوار النجف)&&
  72,2,آیت نمبر۲: اِس آیت سے معلوم ہوا کہ (۱) جن اللہ کے وجود اور اُس کے پالنے والے مالک ہونے کے منکر نہیں ۔ (۲) اِن میں کچھ جن مشرک بھی ہوتے ہیں ہیں (۳) آسمانی کتب اور نبوت کا سلسلہ جنوں میں جاری نہیں ہے۔ (۴)جن انسانوں ہی میں آنے والے انبیاء کرام علیہم السلام کو مانتے ہیں ۔ مثلاً یہ جن جنھوں نے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے قرآن سنا تھا حضرت موسٰی کو ماننے والے تھے۔(۵) سورۃ الرحمن سے بھی معلوم ہوتا ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے مخاطب انسان اور جن دونوں تھے۔يٰمَعْشَرَ الْجِنِّ وَالْاِنْسِ اِنِ اسْتَطَعْتُمْ اَنْ تَنْفُذُوْا مِنْ اَقْطَارِ السَّمٰوٰتِ وَالْاَرْضِ>> &&(سورۃ ۵۵ الرحمن آیت ۳۳ پارہ ۲۷ )&&(تفسیر کبیر۔تفہیم۔ مجمع البیان) &&!! جنات کی حقیقت:(۱) جن سے مراد چھپی ہوئی ،نظر نہ آنے والی مخلوق ،ایک ایسا وجود جو آگ کے شعلے سے پیدا کیا گیا ہے جبکہ انسان مٹی سے پیدا کیا گیا ہے۔(۲) جن علم رکھتا ہے ۔ منطق استدلال جانتا ہے۔ حق اور باطل کو پہچان سکتا ہے۔(۳) اُس پر بھی خدا نے ہماری طرح فرائض واجب کیے ہیں ۔ &&( سورہ جن اور سورہ رحمن کی آیات)(۴)جنوں میں مومن بھی ہیں اور کافر بھی۔ &&(بحوالہ سورہ جن) && (۵) جنوں پر بھی قیامت آئے گی۔&&(سورہ جن) && (۶) جن آسمانوں پر چڑھ کر خبریں سن سکتے تھے لیکن اب اُن کو روک دیا گیا ہے۔&&(سورہ جن) && (۷) جن انسانوں سے باتیں کرتے ہیں اور کچھ چھپی ہوئی باتیں بتا دیتے ہیں ۔&&( سورہ جن)&&(۸)بعض جن بہت طاقتور ہوتے ہیں : مثلاً<<قَالَ عِفْرِيْتٌ مِّنَ الْجِنِّ اَنَا اٰتِيْكَ بِہٖ >>&&( سورہ۲۷ النمل ۳۹ پارہ ۱۹) (۹) &&جن خدا کی اجازت سے انسانوں کے کچھ کام بھی کرسکتے ہیں ۔ مثلاً<<وَمِنَ الْجِنِّ مَنْ يَّعْمَلُ بَيْنَ يَدَيْہِ بِـاِذْنِ رَبِّہٖ>> اور جنوں میں کا ایک گروہ خدا کے حکم سلیمان علیہ السلام کے سامنے کام کیا کرتا تھا۔يَعْمَلُوْنَ لَہٗ مَا يَشَاۗءُ مِنْ مَّحَارِيْبَ وَتَمَاثِيْلَ وَجِفَانٍ كَالْجَــوَابِ وَقُدُوْرٍ رّٰسِيٰتٍ>> عبادت خانے تصویریں ،بڑے بڑے برتن ،تالابوں کی مانند لگن اور زمین میں پیوست دیگیں بناتے تھے ۔&&(سورۃ ۳۴ سبا آیت ۱۲ ۔ ۱۳ پارہ ۲۲)&&(۱۰)جن انسانوں سے پہلے زمین پر پیداہوئے تھے یعنی فرمایا:<<وَالْجَاۗنَّ خَلَقْنٰہُ مِنْ قَبْلُ مِنْ نَّارِ السَّمُوْمِ>> (اور جنوں کو ہم نے انسانوں سے قبل آگ کے تیز شعلے سے پیدا کیا۔)&&( سورۃ ۱۵ الحجر آیت ۲۷ پارہ ۱۴) (۱۱) مگر انسان جنوں سے افضل ہیں ۔ اِسی لیے خدا نے رسول انسانوں میں چُنے اور انسان ہی کو مسجودِ ملائک بنایا تھا (۱۲) ماہرین کہتے ہیں کہ وہ موجودات جن کو ہم اپنے ظاہری حواس سے محسوس کرسکتے ہیں ، اُن موجودات کے مقابلے میں جن کو ہم اپنے حواس سے درک نہیں کرسکتے ،بہت کم ہیں ۔ مثلاً ایسی دور بینیں ایجاد ہوچکی ہیں جن سے پتہ چل گیا ہے کہ پانی یا خون کے ایک قطرے میں ہزاروں جاندار مخلوقات موجود ہیں ۔&&(تفسیر نمونہ۔ آفام المرجان فی احکام الجان)&&(۱۳) }}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  خداوندِ عالم نے جنوں کو پانچ اقسام میں پیدا فرمایا ہے:(۱) ہوا کی طرح فضا میں (جو نظر نہیں آتے ) (۲) ایک قسم سانپوں کی شکل میں ۔ا(۳) ایک قسم بچھووں کی صورت میں (۴)ایک قسم کیڑوں مکوڑوں (جراثیم) کی شکل میں ۔(۵) ایک قسم انسانوں کی مانند ہے جس کا حساب کتاب بھی ہوگا (ثواب و )عقاب بھی ہوگا۔&&(سفینہ ۔ البحار جلد اول ص ۱۸۶ مادیات) &&}}جناب امیر المومنین علیہ السلام نے فرمایا: برتن کے ٹوٹے ہوئے حصّے اور اُس کے دستے کی طرف سے پانی نہ پیا کرو۔ کیوں کہ شیطان اُس کے دستے اور ٹوٹے ہوئے حصے پر بیٹھا ہوتا ہے۔ (کیوں کہ شیطان کی آماجگاہ گندے مقامات ہوتے ہیں )&&(کتاب کافی جلد ۶) &&
  72,3,آیت نمبر۳: اصل بات یہ ہے کہ جو لوگ مسلمان گھروں میں پیدا ہوتے ہیں وہ اِس بات کا اندازہ ہی نہیں کرسکتے کہ مشرکوں نے اپنے دیوتاوں کے ساتھ اُن کے بیوی بچوں کا یک لمبا سلسلہ بنا رکھا ہے ۔جس کو بڑی بڑی مہذب قومیں مصری ،عراقی ،یونانی ،چینی ،ایرانی اور آجکل خاص کر ہندو مذاہب خوب خوب جانتے ،اور مانتے ہیں ۔&&(تفسیر ماجدی)&&!! شانِ نزول:اِن آیتوں کی شانِ نزول یہ ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم صبح کی نماز پڑھ رہے تھے کہ وہاں سے کچھ جن گذر رہے تھے وہ قرآن کو سننے کے لیے رُک گئے ۔ قرآن کی فصاحت و بلاغت سے بہت متاثر ہوکر تعجب کرنے لگے۔ آخر کار ایمان لے آئے ،جو خود یہاں پر ان کے اپنے بیان ہی سے ظاہر ہے جس کو وہ اپنی قوم سے جاکر کہہ رہے ہیں ،اور خداوندِ عالم اُس کو نقل فرما رہا ہے۔اِس سے یہ بھی معلوم ہوگیا کہ خدا کا پیغام خدا کے بندوں کو پہنچانا ،خداوندِ عالم کو کس قدر پسند ہے۔&&(فصل الخطاب)&& جناب ابو حمزہ شمالی سے مروی ہے کہ وہ جن وادی شیصبان کے رہنے والے تھے۔اور بعض نے کہا کہ وہ نَصیبَین کے رہنے والے سات جن تھے اُن کو حضور صلی اللہ علیہ و آلہ وسلم نے دیکھا ،تو آپ صلی اللہ علیہ و آلہ وسلم کی تبلیغ سے مسلمان ہوگئے ،اور آپ نے اُن کو باقی جنوں کی طرف مبلغ بنا کر روانہ فرمایا۔&&(تفسیر انوارالنجف)&& آنے والے جن یا تو عیسائی تھے یا کسی ایسے مذہب پر تھے جو خدا کو بیوی بچوں والا مانتا ہے۔ دوسرے ایسا معلوم ہوتا ہے کہ حضوراکرم صلی اللہ علیہ و آلہ وسلم نے قرآن مجید کی وہ آیات پڑھیں جن سے اُن کو عقیدے کی غلطی کا اندازہ ہوگیا ،اور انھوں نے جان لیا کے خداوندِ عالم کی ذات والا صفات اِس بات سے بہت بلند و بالا ہے کہ اُس کے بیوی بچے بھی ہوں ۔&&(تفسیر کبیر۔ تفہیم)&&اِس آیت سے معلوم ہوتا ہے:کہ جو گمراہیاں آدمیوں میں پھیلی ہوئی ہیں وہی جنوں میں بھی ہیں ۔ عیسائیوں کی طرح وہ بھی اللہ کے جو رو (بیوی) بیٹا ،بتاتے ہیں ۔&&(شاہ عبد القادر ۔ شیخ السلام عثمانی) &&
  72,4,آیت نمبر۴: بیوقوف اور نادان سے مراد شیطان ہے۔&&(مجمع البیان) &&اور عام جنات بھی مراد لیے جاسکتے ہیں ۔&&(تفسیر کبیر) &&<< سفیہ>>: یعنی بے وقوف ۔ یہ لفظ عربی میں بے عقل شخص کے لیے بھی بولا جاتا ہے ا ور احمقوں کے یے بھی بولا جاتا ہے۔ یہاں اگر ایک شخص کے لیے بولا گیا ہے تو مراد ابلیس ہے اور چند لوگوں کے لیے بولا گیا ہے تو کچھ بے عقل جن مراد ہیں ۔&&(تفسیر کبیر۔ مفردات امام راغب) &&زیادہ تر مفسرین کا خیال ہے کہ یہاں <<سفیہ>>یعنی احمق کا لفظ ابلیس کے لیے استعمال ہوا ہے کیوں کہ ابلیس خداوندِ عالم کے لیے ناروا باتیں کرتا پھرتا ہے اور خدا سے بغاوت کرچکا ہے۔ اور خود کو بہت بڑی توپ سمجھتا ہے۔ ابلیس عالمِ بےعمل اور عابدِ خواہ ،خدا سے منحرف ،متکبر تھا،اِس لیے اُس کے احمق ہونے میں کوئی شک نہیں کرسکتا۔ بلکہ اُس سے بڑا احمق اور کون ہوسکتا ہے؟&&(تفسیرنمونہ)<<&& شَطَط <<کے معنی حدِّ اعتدال سے نکل کر دو ر جا پڑنے کے ہیں ۔ اِسی لیے حق سے دور باتوں کو << شَطَط << کہتے ہیں اور اُن بڑے دریاوں کے کناروں کو بھی <<شَطْ<<کہتے ہیں جن کا فاصلہ پانی سے بہت زیادہ دور ہوتا ہے۔&&(مفردات امام راغب)&&
  72,5,آیت نمبر۵: جنوں کے کہنے کا مطلب یہ ہے کہ ہمارے گمراہ ہونے کا سبب یہ ہوا کہ ہم کبھی یہ سوچ بھی نہ سکتے تھے کہ انسان یا جن اللہ تعالیٰ کے بارے میں جھوٹ گھڑنے کی بھی جراٰت کرسکتے ہیں ۔لیکن اب یہ قرآن سن کر ہمیں معلوم ہوگیا کہ وہ لوگ جھوٹے تھے جو یہ کہتے ہیں کہ خدا نے کسی کو اپنی بیوی اور کسی کو اپنا بیٹا بنا لیا ہے۔&&(تفہیم۔ مجمع البیان) &&اب جبکہ قرآن سننے کے بعد ہمیں حق معلوم ہوگیا ہے ،اور ہم ایمان لے آئے ہیں اس لیے اب ہمیں اپنے باپ دادا کی اندھی تقلید نہیں کرنی چاہیے۔ ہم کو یہ بات مان لینی چاہیے کہ شرک غلط طرزِ فکر ہے۔&&(تفسیر نمونہ ۔تفسیر کبیر) &&!!اصل میں یہ جنوں یا انسانوں کی انتہائی دلیری اور ہمت کی بات ہے کہ حق کو جان لینے کے بعد اُنھوں نے اپنے باپ دادا کے پرانے غلط عقیدوں کو یکسر چھوڑدیا۔[[آئینِ نو سے ڈرنا،طرزِ کہن پہ اَڑنا۔۔۔۔ منزل یہی کٹھن ہے ،قوموں کی زندگی میں]] &&(اقبال)&& مطلب یہ ہے کہ ہم صرف اِس غلط فہمی میں تھے کہ(۱) جنوں یا انسانوں سے کوئی فرد اللہ کی طرف جھوٹی باتیں منسوب نہ کرے گا (۲) اور ہم سمجھ رہے تھے کہ شرک کرنے میں ہم خدا کو راضی کر رہے ہیں کیوں کہ کہنے والوں نے ہم سے یہی کہ رکھا تھا ۔ اور اب جو ہم نے قرآن سُنا تو معلوم ہوا کہ اُنھوں نے اللہ پر بہتان لگا رکھا تھا ،لہٰذا اب ہم نے شرک سے توبہ کرلی ہے۔&&(انوارالنجف)&&
  72,6,آیت نمبر۶: {{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام محّمد باقر علیہ السلام نے فرمایا:  اُس زمانے میں لوگ کاہنوں کے پاس جایا کرتے تھے جن کو شیاطین وحی کیا کرتے تھے (خفیہ طور پر بتا دیا کرتے تھے) پھر وہ لوگ کاہنوں سے کہا کرتے تھے کہ تم ہم نے اپنی مائی باپ یا مددگار مان لیا ہے اِس لیے وہ ہماری حفاظت کریں،ہم اُن کی حفاظت میں رہیں گے)&&(تفسیر صافی ۔ تفسیر قمی)&& اب کیو ںکہ لوگوں نے اُن شیاطین کی پناہ لینی شروع کردی تو اُسکی وجہ سے اُن شیاطین جنوں کا تکبر اور سرکشی اور بڑھ گئی ۔&&(تفسیر صافی)&& تفسیر قمی میں ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی ولادت سے پہلے کچھ جن کچھ آدمیوں کے پاس آیا کرتے تھے اور جو خبریں وہ آسمانوں پر جا کر سنا کرتے تھے،اُن آدمیوں کو بتایا کرتے تھے،پھر وہ لوگ دوسروں کو جنوں کی بتائی ہوئی باتیں بتا دیا کرتے تھے۔ایسے ہی لوگوں کو کاہن کہا جاتا تھا۔&&(تفسیرقمی)<<&&رھَق <<کے معنی تکبر ،سرکشی،سرچڑھنا ،اترانا ،ظلم و ستم کرنا ،زیادتی زبردستی کرنا ،زبردستی چھا جانے کی کوشش کرنا۔ اب کیوں کہ اِس قسم کے کاموں کا آخری نتیجہ تباہی اور بربادی ہوتا ہے۔ اِس لیے << رھق<<کے دوسرے معنی تباہی اور بربادی کے ہیں۔&&(لغات القرآن نعمانی) &&!!بعض ماہرین نے لکھا کہ: عرب جب یہ کہتے ہیں کہ <<توفِیْہ رَھَقَّ>> تومطلب یہ ہوتا ہے کہ اِس میں عقل کی کمی ہے،یا وہ ہر طرف سے شر برائیوں میں گھرا ہواہے۔ (مبرد) !! }}حضرت ابنِ عباسؓ فرماتے ہیں کہ: جاہلیت کے زمانے میں عرب جب کسی سُنسان وادی سے گذرتے تو پکار پکار کر کہتے کہ :  ہم اس وادی کے مالک جن کی پناہ مانگتے ہیں۔یا مثلاً؛کسی عرب کا چارہ،پانی ختم ہوجاتا تھا،تو وہ دوسری جگہ چارہ ،پانی تلاش کرتے جب مل جاتا تو اترتے وقت پکار پکار کر کہتے کہ: ہم اس وادی کے مالک (جن) کی پناہ مانگتے ہیں تاکہ ہم محفوظ رہیں۔&&(تفسیر ابنِ عباس) &&۔ عربوں کے اس عقیدے کی بنا پر جنوں میں سرکشی اور تکبر و غرور اور بڑھ گیا تھا ،حالاں کہ جن خدا کی مخلوق ہیں ،پناہ لی جائے تو کائنات کے مالک و خالق سے لی جائے۔ &&(تفسیر مجمع البیان ۔ روح المعانی)ْ]وہ ایک سجدہ جسے تو گراں ۔سمجھتا ہے ۔ہزار سجدوں سے دیتا ہے آدمی کو نجات[[&&(اقبال)&&
  72,7,آیت نمبر۷: جنوں کے کہنے کا مطلب یہ ہے کہ : ہم تو غلطی سے یہ سمجھ رہے تھے کہ اب اللہ کسی کو اپنا رسول علیہ السلام بناکر نہیں بھیجے گا۔مگر اب ہماری یہ غلط فہمی دور ہوگئی ۔ اب قرآن سُن کر ہم کو معلوم ہوگیاکہ اللہ نے اپنی ایک رسول صلی اللہ علیہ و آلہ وسلم بھیجا ہے ،جو قرآن جیسا عجیب و غریب ،بے حد فصیح و بلیغ کلام سناتا ہے۔&&(شیخ الاسلام عثمانی)&&
  72,8,آیت نمبر ۸:جنوں کے کہنے کا مطلب یہ ہے کہ اس رسول صلی اللہ علیہ و آلہ وسلم کے آنے کی وجہ سے ہی یہ ہوا کہ آسمان پربڑے سخت پہرے بٹھادئیے گئے ہیں ۔ اِسی لیے اب ہم آسمان کی باتیں نہیں سن سکتے۔&&(فصل الخطاب)&&
  72,9,آیت نمبر ۹:اصل میں یہی وجہ ہے جس کی وجہ سے جن اِس تلاش میں نکلتے تھے کہ ضرور کوئی ایسا خاص واقعہ پیش آیا ہے جس کی وجہ سے آسمانوں پراس قدر سخت انتظامات کردئیے گئے ہیں کہ اب ہم کو عالمِ بالا کی کوئی بات سننے کا موقع نہیں دیا جا رہا ہے۔ ہم آسمانوں پر جدھر بھی جاتے ہیں ،مار بھگائے جاتے ہیں ۔&&(تفہیم۔ تفسیر کبیر)<< &&رَصَد <<کے معنی گھات لگا کر بیٹھنا۔ (تاک میں بیٹھنا)&&(مفردات امام راغب)&&<< شِھَاب << معنی وہ شعلہ جو آگ کی طرح بھڑک کر نکلتا ہے ۔ اور ایک لمبا روشن خط آسمان پر بتاتا ہے۔&&(مفردات امام راغب)&& اصل میں یہ شہاب وہ تیر ہیں جو اُن شیاطین کو مارے جاتے ہیں جو چوری چھپے آسمان کے فرشتوں کی باتیں سننے کے لیے اوپر آتے ہیں ۔ مگر ہم اِس حقیقت کو پوری طرح سمجھ نہیں سکتے۔ &&(فصل الخطاب ۔ تفسیر نمونہ ۔ لغات القرآن نعمانی) &&اِس آیت سے:(۱) چوری چھپے کسی کی باتیں سننے کی مذمت نکلتی ہے۔ (۲) کاہنوں پر جو لوگوں کو عقیدت ہوتی ہےاُس کی بھی جڑ کٹ جاتی ہے۔ اِس لیے کہ کاہن جنوں ہی سے غیب کے راز معلوم کرلیا کرتے تھے ،اور اب جن خود آسمان پر جا کر راز کی باتیں معلوم نہیں کرسکتے۔[[وہ شاخ ہی نہ رہی جس پہ آشیانہ تھا]]&&(مولف)&& }}جناب امیر المومنین علیہ السلام نے فرمایا: نجومی مثل کاہن کے ہے،کاہن مثل ساحر کے ہے،ساحر مثل کافر کے ہے اور کافر جہنمی ہوتا ہے۔&&(نہج البلاغہ کلمات قصار) {{&&
  72,10,آیت نمبر۱۰: محققین نے نتیجہ نکالا کہ جنوں کو یہ بات معلوم تھی کہ آسمانوں پر شیاطین کو جانے سے دو درجہ سے روکا جاتا ہے ۔ (۱) جب آسمان سے کوئی عذاب آنے والاہوتا ہے (۲) یا پھر جب خدا کسی نبی کے ذریعہ سے اپنی ہدایات اُتارنا چاہتا ہے۔جنات اِسی بات کو سمجھ کر اُس نبی صلی اللہ علیہ و آلہ وسلم کی تلاش میں نکلے تھے کہ خدا نے اُن کی ہدایت فرمائی اور وہ لوگ اُ س مقام سے گذرے جہاں جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم صبح کی نماز ادا فرمارہے تھے۔ جنوں نے قرآن سنا ،غور کیا ،اور سمجھ گئے کہ یہی وہ رسول صلی اللہ علیہ و آلہ وسلم ہیں جو خدا کی طرف سے بھیجے گئے ہیں ،اور انہی کے آنے کی وجہ سے آسمانوں پر پہرے دار بٹھا دئیے گئے ہیں ۔&&(تفسیر مجمع البیان ،تفسیر کبیر،کشاف ۔ تفہیم) &&
  72,11,آیت نمبر۱۱: جنوں کے کہنے کا مطب یہ ہے کہ : ہم میں بھی اچّھے بُرے جن پائے جاتے ہیں ۔ اعتقادات میں بھی ہمارے بہت سے فرقے ہیں ،اِس لیے ہم بھی راہِ حق معلوم کرنے کے محتاج ہیں ۔ ہم کو خدا کی ہدایت سے لاپرواہ نہیں ہونا چاہیے۔ &&(تفسیر کبیر ۔ تفہیم)&&!!اِس آیت سے معلوم ہوا کہ نزولِ قرآن سے پہلے بھی تمام کے تمام جن ایک راہ پر نہ تھے۔ کچھ نیک اور کچھ بدمعاش تھے۔ اُن میں فرقے اور جماعتیں ہیں ۔ کوئی مشرک ،کوئی عیسائی ہے۔ قرآن کے آنے کے بعد بھی اُن میں اختلاف ہے اور انسانوں کی طرح سب کے حق کا راستہ قبول نہیں کرتے۔&&(شیخ الاسلام عثمانی) &&
  72,12,آیت نمبر ۱۲ کی تشریح:مطلب یہ ہے کہ یہ خیال بالکل غلط ہے کہ کوئی شخص خدا کی سزا سے بھاگ کر بچ نکلے گا۔ایسا سوچنا بالکل غلط ہے ،اس لیے کہ خدا کی قدرت پوری کائنات کو گھیرے ہوئے ہے اس لیے پنجہ قدرت سے فرار ممکن نہیں ہے۔ جن کہہ رہے ہیں کہ ہمارے اسی عقیدہ نے کہ ہم خدا کے پنجۂ عدالت سے بچ نکل سکتے ،ہمیں خدا کے سامنے سر تسلیم خم کرنے اور اس کی اطاعت پر مجبور کردیا۔ کہ یہی واحد صورت ہے خدا کے عذاب سے بچنے کی۔&&(تفسیر نمونہ)&&
  72,13,آیت نمبر۱۳:میں جنوں کے کہنے کا مطلب یہ تھا کہ (۱) یہ بات ہمارے لیے فخر کا موقع ہے کہ جنوں میں سے سب سے پہلے ہم نے قرآن سنا اور سب سے پہلے ہم قرآن پر ایمان لائے۔(۲) یہ کہ سچے دل سے خدا ،رسول صلی اللہ علیہ و آلہ وسلم اور آخرت کو ماننے والے کے لیے اللہ تعالیٰ کے ہاں کوئی کھٹکایا خطرہ نہیں ہے ،اس کو کسی قسم کا نصان نہ پہنچے گا۔ یعنی اُس کی نیکیاں ضائع نہیں جائیں گی ،نہ اسکی دوسرے کے گناہ اُس پر لادے جائیں گے۔ غرض خدا کے پاس جاکر سچا با عمل مومن ہر قسم کی ذلت و رسوائی و نقصان سے محفوظ رہے گا۔&&(شیخ الاسلام عثمانی) &&ایمان کے لفظ کے معنی امن سے ہوجانا ہوتا ہے۔جو خدا پر دل سے ایمان لے آتا ہے ۔یعنی خدا رسول صلی اللہ علیہ و آلہ وسلم اور آخرت اور قرآن کو دل سے مان لیتاہے،وہ ہرقسم کے نقصان اور خطرات سے امن میں ہوجاتا ہے کیوں کہ }}خداوندِ عالم نے فرمایا:<<لا الہ الا حصنی فمن قالھا،دخل فی حصنی ومن دخل فی حصنی، اٰمن من عذابی>> نہیں ہے کوئی معبود سوا اللہ کے ،یہ بات دل سے مان لینا میرا قلعہ ہے ،پس جس نے یہ اقرار کرلیا وہ میرے قلعے میں داخل ہوگیا،اور جو میرے قلعے میں داخل ہوگیا،وہ میری سزاوں سے محفوظ ہوگیا۔&&(حدیث قدسی ،سلسلۃ الذہب از امام علی رضا علیہ السلام ۔ بحار لانوار ،عیون الاخبار) &&{{اِس کے بعد }}فرزندِ رسول صلی اللہ علیہ و آلہ وسلم ، حضرت امام علی رضا علی السلام نے حدیث قدسی کے پڑھنے کے بعد فرمایا:  <<بشرطھاوشروطھاوانامن شروطھا>>لیکن خدا کا یہ فرمان کچھ شرائط کے ساتھ ہے اور اس میں اُن شرائط میں سے ہوں ۔یعنی: اگر میری امامت کو تسلیم کرو گے تو عذاب الہٰی کی سزا سے امان میں رہوگے۔ &&(آئمہ اہلبیت علیہ السلام کی امامت و ولایت کو دل سے ماننا شرط نجات ہے)&&(حدیث ِ قدسی مروی از امام علی رضا علیہ السلام از تفسیر نورالثقلین ،تفسیر بتیان) &&امام احمد ابنِ جنبل سے اِس حدیث کے بارے میں پوچھا گیا تو اُنہوں نے فرمایا:  اِس حدیث کا کیا کہنا ،اس کے راوی (یعنی آئمہ اہلِ بیت علیہم السلام ) &&سلسلۃ الذھب &&( سنہری سلسلہ والے) ہیں اُن کے نام اگر کسی دیوانے پر پڑھ دئیے جائیں تو وہ فرزانہ ہوجائے گا۔سبحان اللہ>> اِس حدیث سے ثابت ہوگیا کہ نجاتِ آخرت کے لیے آئمہ اہلِ بیت علیہم السلام کی امامت اور ولایت کو ماننا لازمی شرط ہے۔ اور یہ پوری اُمّت مسلمہ کا مسلم عقیدہ ہے کیوں کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:<<مثل اھلبیتی کمثل سینۃ نوحٍ من رکبھانجیٰ من تخلف عناغرق وھوٰی>> میرے اہلِ بیت علیہم السلام کی مثال کشتی نوح علیہ السلام کی طرح ہے ،جو اُ س پر سوار ہوا نجات پاگیا،اور جس نے اس سے منہ موڑا غرق ہوا اوربرباد ہوا۔&&(الحدیث۔ ازتفسیر کبیر امام رازی۔ صواعقِ محرقہ۔ ینابیع المودۃ) &&!!عظیم صوفی نیاز بریلویؒ جو سلسلہ نیاز کے بانی ہیں ۔ فرماتے ہیں :]]نیاز اندر قیامت بے سرد سماماں نہ خوہی شد۔۔۔۔کہ ازحب و تولائے علی داری تو سامانی[[۔یعنی :اے نیاز! تو قیامت کے دن بے سرد سامان رہے گا ،اس لیے کہ تیرے پاس علی علیہ السلام ابنِ ابی طالب کی محبت اور ولایت کے اقرار جیسا بہترین سامانِ نجات موجود ہے۔[[کفن میں ہے مرے کربل کی مٹی ۔۔۔۔مسافر بے سرو سامان نجات موجود ہے ]]۔&&(نیاز بریلوی)&&
  72,14,آیت نمبر۱۴: ]]جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: مومن وہ ہے جس سے لوگ اپنی جان و مال کو محفوظ سمجھیں ۔ &&(تفسیر روح البیان جلد۱۰) && نیز آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا:  مسلمان وہ ہے جس کے ہاتھ اور زبان سے مسلمان محفوظ رہیں ۔&&(اصول کافی جلد ۶ باب مومن و علاماتہ) && [[آخر میں جنوں کا کہنا کہ :  جو شخص اسلام کو اختیار کرنے اُس نے سیدھی راہ انتخاب کرلی۔(۱) اس سے معلوم ہوا کہ انسان کو عمل کرنے کا اختیار حاصل ہے۔&& (مولف)&&(۲) مومن وہ ہوتا ہے جو اپنے ارادے ،قصد ،تحقیق اور اپنی تلاش کی بدولت ہدایت حاصل کرتا ہے ،آنکھیں بند کرکے اندھی تقلید نہیں کرات،اسی لیے ایمان لانے پر عظیم اجر پاتا ہے۔&&(تفسیر نمونہ)&& ]]زُبان سے کہہ بھی دیا لَآاِلٰہَ اِلَّا اللہ تو کیا حاصل۔دل و نگاہ مسلماں نہیں تو کچھ بھی نہیں[[ &&(اقبال)&&
  72,15,آیت نمبر۱۵:سوال یہ ہے کہ: جن تو آگ کے بنے ہیں ،پھر اُن کو جہنم کی آگ سے تکلیف کیسے پہنچ سکتی ہے؟جواب یہ ہے کہ: قرآن کی رُو سے آدمی بھی مٹی سے بناہے ،پھر مٹی کاڈھیلا انسان کو مارنے پر تکلیف کیوں ہوتی ہے۔ حقیقت یہ ہے کہ انسان اگرچہ مٹی سے بناہے ،مگر بننے کے بعد وہ بالکل مختلف چیز بن جاتا ہے۔ اِسی طرح جن اگرچہ آگ سے بنتے ہیں مگر وہ صاحبِ احساس اور زندہ مخلوق ہیں اس طرح آگ اُن کو بھی جلادے گی اور اذیت دے گی۔ (پھر جہنم کی آگ جس کے شعلے سے خود آگ بھی پناہ مانگتی ہے)&&(تفہیم۔ مجمع البیان) &&<<الٰقٰطُوْنَ>>راہِ حق سے انحراف کرنے والے ۔ اسی لیے جناب امیر المومنین علیہ السلام سے جنگِ صفیں میں لڑنے والے لشکر کو قاسطین کہا جاتاہے جنِ جمل والوں کو ناکثین (یعنی بیعت توڑنے والے) اور جنگِ نہروان والوں کو مارقین (یعنی دین سے فارغ) کہا جاتا ہے۔&&(انوار النجف) &&
  72,16,آیت نمبر۱۶: آیت کا مطلب یہ ہے کہ جنوں کی طرح اگر مکے والے بھی خدا و رسول ؐآخرت کو دل سے مان لیتے تو ہم اُن کو بھی خوب اچھی طرح سے سیراب کرتے۔&&(جلالین۔ شاہ رفیع الدّین) &&کئی سال تک عرب میں قحط پڑا۔ لوگ قحط سے تنگ آچکے تھے،اب عربوں سے کہا جا رہا ہے کہ سدھر جاو۔ اگر تم ایمان لے آو گے (یعنی خدا رسول صلی اللہ علیہ و آلہ وسلم آخرت اور قرآن کو دل سے مان لوگے) تو ہم تم پر بارش اور روزی کے دروازے کھو ل دینگے۔&&(تفسیر ماجدی)&&پانی کو یہاں نعمتوں کی کثرت کے طور پر فرمایا گیاہے۔ اِس لیے کہ پانی ہی پر کھیتی باڑی ،زندگی زراعت ،صنعت،بستیاں بسنے کا دارومدار ہے۔&&(تفہیم)&& بعض روایات میں ہے کہ اُس وقت مکے والے اپنی شرارت کی سزا میں سخت قحط میں گرفتار تھے ،اُن کو بتایا جا رہا ہے کہ : اگر تم ایمان لاکر سیدھے ہوجاو اور جنوں کی طرح قرآن کو دل سے مان لوگے تو بارانِ رحمت سے سیراب ہوسکتے ہو۔&&(شیخ الاسلام عثمانی) &&
  72,17,آیت نمبر۱۷:<< ذِکْر << سے منہ موڑنے کا مطلب:یہ ہے کہ (۱) اللہ کی نصیحتوں کو قبول نہ کرنا ۔ (۲) اللہ کی باتیں نہ سننا (۳) اللہ کی اطاعت اور عبادت سے منہ موڑ لینا۔&&(تفہیم ۔ تفسیر کبیر)&&[[جانتا ہو ں ثواب ِ طاعت و زُہد ۔۔۔۔پر طبیعت اِدھر نہیں آتی]] !!محققین نے نتیجہ نکالا کہ:خداوندِ عالم جن چیزو ں سے بندوں کا امتحان لیتا ہے اُن میں ایک چیز یہ بھی ہے کہ وہ بندے کو بہت سی نعمتیں عطا فرماتا ہے ،پھر دیکھتا ہے کہ وہ شکر کرتا ہے یا کفر (ناشکری) یعنی یہ دیکھتا ہے کہ وہ خدا کی نعمتوں کو خدا کی عطا مان کر خدا کی مرضی کے مطابق استعمال کرتا ہے ،یا اُن کو اپنے باپ کا (ناجائز) مال سمجھ کر خدا کی مرضی کے خلاف استعمال کرتا ہے ،اگر وہ کفر و انکار والی راہ اختیار کرتا ہے ،یعنی خدا کی نعمتوں کو خدا کی عطا نہیں مانتا اور اپنی من مانی کرکے خدا نعمتوں کوخدا کی مرضی کے خلاف استعمال کرتا ہے تو پھر خدا اُس کو اپنی سخت سزا میں پکڑ لیتا ہے۔&&(تفسیر نمونہ۔ تفسیر کبیر۔ مجمع البیان) &&!! حاصلِ مطلب یہ ہےکہ اللہ کی یاد سے منہ موڑ کر آدمی کو چین نصیب نہیں ہوسکتا۔ کیوں کہ معصیتِ خدا کا راستہ سراسر پریشانیوں اور عذاب کا راستہ ہے نجات کا راستہ نہیں ہے۔&&(شیخ السلام)&&
  72,18,آیت نمبر۱۸: آیت میں اِس بات کی تعلیم دی گئی ہے کہ یہ بات بالکل جائز نہیں کہ عبادت کا کچھ حصہ تو خدا کے لیے کیا جائے اور کچھ عبادت کسی غیرِخدا کے لیے کی جائے،یہ شرک ہے۔ مساجد سے یہاں مراد اعضائے سجدہ بھی ہیں ۔ یعنی وہ سات اعضاء جو سجدے میں استعمال ہوتے ہیں ۔ &&(پیشانی ،دونوں ہتھیلیاں ،دونوں گھٹنے ،دونوں پیروں کے انگوٹھے)۔&&(معالمِ ۔ ابنِ کثیر ۔امام راغب) &&}}حضرت امام علی ابنِ ابی طالب علیہ السلام سے روایت ہے کہ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: <<مساجد>> سے یہاں مراد وہ وہ اعضاء بھی ہیں جو سجدے کی حالت میں زمین پر ٹکتے ہیں ۔ یعنی : پیشانی ۔دونوں گھٹنے اور دونوں پیروں کے انگوٹھے۔&&(تفسیر قمی۔ تفسیر صافی۔ من لا یحضرہ الفقیہ ،کفی بروایت امام صادق علیہ السلام ۔ تفسیر عیاشی بروایت امام محمّد تقی علیہ السلام ) &&{{ تمام مفسرین نے مساجد سے مراد عبادت گاہوں کو لیاہے۔مطلب یہ ہے کہ << مساجد<<عبادتگاہوں میں سوا خدا کے کسی کی عبادت نہیں کرنی چاہیے۔}}جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  میرے لیے تو پوری کی پوری زمین مسجد یا عبادتگاہ طہارت حاصل کرنے کا ذریعہ بنادی گئی ہے۔&&(تفہیم ۔ تفسیر کبیر۔ وسائل الشیعہ جلد ۲){{&&تاریخی واقعہ:ایک دفعہ خلیفہ معتصم عباسی کے دربار میں ایک چو رکے ہاتھ کاٹنے پر علماء اسلام میں بحث چھڑ گئی ۔ کچھ علماء نے کہا کلائی سے ہاتھ کاٹا جائے گا ،انھوں نے تیمم والی آیت سے استدلال کیا،کچھ علماء نے کہا کہنی سے ہاتھ کاٹا جائے گا،انھوں نے وضو والی آیت سے استدلال کیا،معتصم عباّسی نے {{فرزندِ رسولِ خدا حضرت امام محمد تقی الجواد سے پوچھا کہ آپ علیہ السلام کیافرماتے ہیں ؟ امام علیہ السلام نے فرمایا: صرف چار انگلیاں کاٹی جائیں ،ہاتھ کی ہتھیلی اور انگوٹھا چھوڑ دینا چاہیے۔جب معتصم عباّ سی نے دلیل طلب کی تو اما م علیہ السلام نے یہی آیت تلاوت کی اور فرمایا کہ : یہ سجدے والے اعضاء اللہ کے لیے ہیں ۔اور جو چیز خدا کے لیے ہو اس کو کاٹنا نہیں چاہیے{{۔چنانچہ خلیفہ نے امام علیہ السلام کے اِس استدلال پر سخت تعجب کیا اور آپ کی علمیت کا معترف ہوگیا ۔ اور امام علیہ السلام ہی کے حکم کے مطابق چور کی چاروں انگلیوں کو جڑ سے کاٹنے کا حکم جاری کیا۔&&(نور الثقلین جلد ۵ ۔ وسائل الشیعہ جلد ۱۸) &&اِس آیت سے غلط نتیجہ یہ نکالا جاتاہے کہ  بس خدا کے سوا کسی کو نہ پکارو،اس لیے کسی کو خدا کی بارگاہ میں وسیلہ یا شفیع نہ بناو۔ حالاں کہ شفاعت اور وسیلہ دونوں قرآن سے ثابت ہیں ،اور عقیدئہ توحدی کی نفی کرتے ۔ خود قرآن میں خدا نے فرمایا:<<وَلَوْ اَنَّھُمْ اِذْ ظَّلَمُوْٓا اَنْفُسَھُمْ جَاۗءُوْكَ فَاسْتَغْفَرُوا اللہَ وَاسْتَغْفَرَ لَھُمُ الرَّسُوْلُ لَوَجَدُوا اللہَ تَوَّابًا رَّحِـيْمًا>> یعنی :@@اگر انھوں نے گناہ کرکے اپنے اوپر ظلم کیا ہے ،تو وہ آپ صلی اللہ علیہ و آلہ وسلم کے پاس آجائیں اور اللہ سے استغفار کریں اور رسول صلی اللہ علیہ و آلہ وسلم اُس کے لیے استغفار کریں تو وہ اللہ کو بخشنے والا ،رحم کرنے والاپائیں گے@@۔&&( سورۃء النساء آیت ۶۴ پارہ ۵)&& سورۃ توبہ میں فرمایا:<<خُذْ مِنْ اَمْوَالِہِمْ صَدَقَـۃً تُطَہِّرُھُمْ وَتُزَكِّيْہِمْ بِہَا وَصَلِّ عَلَيْہِمْ۰ اِنَّ صَلٰوتَكَ سَكَنٌ لَّھُم وَاللہُ سَمِيْعٌ عَلِيْم>>)@@ان کے اموال میں سے صدقہ قبول کرکے اُ سکے ذریعہ سے اُن کو پاک کردو اور اُن کا تذکیہ کرو،اور (اے رسولؐ!) تم اُن کے لیے دعائے خیر کرو ( کیوں کہ) یقینا تمھاری دعاء اُن کے لیے سکون و آرام کا باعث ہوگی ،اور اللہ سننے والا ،جاننے والا ہے۔@@ &&( سورۃ ۹ التوبۃ آیت۱۰۳ پارہ ۱۱)&&سورۃ یوسف میں حضرت یوسف علیہ السلام کے بھائی اپنے والد حضرت یعقوب علیہ السلام سے درخواست کررہے ہیں <<قَالُوْا يٰٓاَبَانَا اسْـتَغْفِرْ لَنَا ذُنُوْبَنَآ اِنَّا كُنَّا خٰطِـــِٕـيْنَ۹۷ قَالَ سَوْفَ اَسْتَغْفِرُ لَكُمْ رَبِّيْ اِنَّہٗ ہُوَالْغَفُوْرُ الرَّحِيْمُ>>۹۸ &&( سورۃ۱۲ یوسف آیت ۹۷۔۹۸ پارہ ۱۳)یعنی:  اُن سب نے کہا: @@ اسے ہمارے بابا جان! آپ علیہ السلام ( اللہ کے نبی علیہ السلام ہیں ) ہمارے لیے ہمارے گناہوں کی بخشش و معافی کی  اللہ سے <<دعاء فرمائیں ،یقینا ہم تو بالکل گنہگار ہیں ۔ انھو ں نے ( حضرت یعقوب علیہ السلام نے ) فرمایا: میں تمھارے لئے اپنے پالنے والے مالک سے بہت جلد استغفار کروں گا،یقینا وہ تو بہت بڑا بخشنے والا اور رحم کرنے والا ہے @@&&(تفسیر کبیر) &&ان مذکورہ آیات سے شفاعت اور توسْل ۔ یعنی خدا کی بارگاہ میں کسی کو اپنا وسیلہ بنانے کا جواز واضح طور ثابت ہوگیا۔ بلکہ یہ بھی ثابت ہوگیا کہ خود خدا وندِ عالم نے ہمیں اللہ والوں سے شفاعت حاصل کرنے اور وسیلہ بنانے کی تعلیم دی،جبکہ ان کو صرف شفیع اور وسیلہ سمجھا جائے ،خدا کا شریک یا ساجھی نہ سمجھا جائے ۔ &&(تفسیر انوارا لنجف ،تفسیر نمونہ) &&مطلب یہ ہے کہ خالص خدائے واحد کی عبادت کرو اور اس کا شریک بناکرکسی کو کہیں بھی نہ پکارو،خاص کر مسجدوں میں تو ایسا کام نہ کرو جو صرف اور صرف خدا کی عبادت کے لیے بنائی گئی ہیں ۔ بعض مفّسرین نے مساجد سے مراد اعضاء سجدہ لیے ہیں ۔ یعنی وہ اعضاء جو سجدے کے وقت زمین &&( یا سجدہ کی جگہ) &&پر رکھے جاتے ۔ پھر یہ مطلب یہ ہوگا کہ یہ خدا کے دئیے ہوئے اعضاء خدا ہی کو سجدہ کرنے کے لیے دئیے ہیں ،لہٰذا ان سے ان کے مالک و خالق کے سوا کسی اور کے لیے سجدہ نہ کرنا۔&&(شیخ السلام عثمانی)&&
  72,19,آیت نمبر ۱۹:میں لفظ عبداللہ کے معنی اللہ کا غلام سے مراد یہاں جناب رسولِ صلی اللہ علیہ و آلہ وسلم کی ذات ہے۔&&(تفسیر صافی ٹوٹ پڑنے کے دو معنی ہیں :(۱) قرآن کو سننے کے شوق میں ٹوٹے پڑنا۔ (۲) یہ کہ جب جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم قرآن پڑھتے تو مکے والے اُن کو ستانے کے لیے ٹوٹ پڑتے۔ ان کافروں ،مشرکوں سے کہا جارہا ہے کہ:  تمھیں اس حرکت کی سزاد ی جائے گی۔&&(فصل الخطاب)&&
  72,20,آیت نمبر ۲۰ میں کہا جارہا ہےکہ : مجھے کیوں ستاتے ہو ،میں کوئی بری یا نامعقول بات تو نہیں کہ رہا ہوں ۔ صرف اپنے پاک مالک کو پکار رہا ہوں ۔ میں کسی کو اس کا شریک نہیں مانتا،اس میں لڑنے جھگڑنے کی کیا بات ہے ،سوچنے سمجھنے کی بات ہے میں تو اُسی ایک اللہ پر بھروسہ کرتا ہوں ۔&&(شیخ الاسلام عثمانی)&&
  72,21,آیت نمبر۲۱: نبی صلی اللہ علیہ و آلہ وسلم کا پیغام پہنچانے والا ہوتا ہے ،خدا کے اختیارات کامالک نہیں ہوتا: یہ بات قرآن بار بار سمجھا ئی ہے۔ مثلاً فرمایا: <<فَاعْلَمُوْٓا اَنَّمَا عَلٰي رَسُوْلِنَا الْبَلٰغُ الْمُبِيْنُ>> یعنی: @@پس تم کو معلوم ہوا چاہیے کہ ہمارے رسول صلی اللہ علیہ و آلہ وسلم کی ذمہ داری صرف ہمارے پیغام کو واضح طور پر پہنچا دینا ہے@@&&(سورۃ ۵ المائدہ آیت ۹۶ پارہ ۷) &&پھرسورہ اعرف میں فرمایا:<<قُلْ لَّآ اَمْلِكُ لِنَفْسِيْ نَفْعًا وَّلَا ضَرًّا اِلَّا مَا شَاۗءَ اللہُ۰ۭ وَلَوْ كُنْتُ اَعْلَمُ الْغَيْبَ لَاسْـتَكْثَرْتُ مِنَ الْخَيْرِ وَمَا مَسَّنِيَ السُّوْۗءُ۰ۚۛ اِنْ اَنَا اِلَّا نَذِيْرٌ وَّبَشِيْرٌ لِّقَوْمٍ يُّؤْمِنُوْنَ۱۸۸ۧ>> یعنی: @@کہدیجئے کہ میں تو خود اپنے لیے بھی کسی فائدے اور نقصان کامالک نہیں ہوں ،مگر جو اللہ چاہے اور اگر میں غیب ( کے خزانوں ) کی خبر رکھتا تو اپنے لیے بہت سا فائدہ جمع کر لیتا اور مجھے کوئی نقصان نہ پہنچتا۔ میں تو صرف ان لوگوں کے لیے جو دل سے خدا کو مانتے ہیں ڈرانے اور خوشخبری دینے والا ہوں @@۔&&( سورہ اعراف آیت ۱۸۸پارہ ۹)&&(تفسیر کبیر) &&اصل بات یہ ہے کہ انسانوں میں افراط و تفریط کا زبردست رُجحان ہوتا ہے ۔ کچھ لوگ تو اسقدر تفریط کی طرف مائل ہوتے ہیں کہ وہ یہ بات نہیں سمجھ پاتے کہ انسان بھلا خدا کا رسول کیسے ہوسکتا ہے ۔ دوسرے افراط کے عالم میں یہ سمجھتے ہیں کہ رسول صلی اللہ علیہ و آلہ وسلم،خدائی اختیارات میں شریک ہوتا ہے ۔ وہ خدا کی طرح جو چاہے کرسکتا۔ رسول مافوق بشر ہستی ہوتا ہے۔ قرآن اِن دونوں کے درمیان اعتدال کی بات کرتا ہے کہ رسول صلی اللہ علیہ و آلہ وسلم کا بھیجا ہوا نمونہ عمل ہوتا ہے خدا کا محبوب ہوتاہے ،ہمارے لیے وسیلہ ہوتا ہے ،شفاعت کا اختیار رکھتا ہے۔ مگر خدا کا شریک یا خدائی اختیارات کامال نہیں ہوتا۔&&(مولف( &&
  72,22,آیت نمبر۲۲: جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے یہ کہلوایا جارہا ہے کہ  میں بھلا تم کونفع نقصان از خود کیسے پہنچا سکتا ہوں ،خود میرا اپنا نفع نقصان میرے اپنے قبضہ قدرت میں نہیں ہے۔ قادرِ مطلق تو صرف اور صرف خدا ہے۔میں بالغرض اگر ان فرائض کی ادائیگی میں جو خدا نے مجھ پر لازم فرمائے ہیں کچھ کمی کروں تو پھر کوئی شخص بھی مجھے اللہ کی سزا سے نہیں بچا سکتا۔ پھر میرے لیے پوری کائنات میں کوئی جگہ نہیں ہے جہاں جاکر پناہ حاصل کرسکوں ۔&&(شیخ الا سلام عثمانی) &&مطلب یہ ہے کہ میں نہ خدا ہوں نہ خدا کا شریک ہوں ، نہ خدائی اختیارات رکھتا ہوں ، بلکہ میں تو خدا کا بندہ کامل ہوں ۔ اُسی سے ڈرتا ہوں ،ہر نفع و نقصان اُسی کے ہاتھ میں ہے اُس کے سوا کوئی جاء پناہ نہیں ہے۔&&(مولف)&& !!حضرت امام علی ابنِ ابی طالب علیہ السلام نے فرمایا:فروامن اللہ الی اللہ (اللہ کے خوف سے بھاگو اللہ کی پناہ کی طرف) یعنی خدا کے عذاب سے اگر پناہ مل سکتی ہے تو خداہی کے دامنِ رحمت میں پناہ لے کر،اور کسی طرح کسی کی پناہ حاصل نہیں ہوسکتی۔&&(مولف)&&
  72,23,آیت نمبر۲۳:آیت کا مطلب یہ ہے کہ: اے مکہ والو! آخر تمھیں مجھ پر اتنا غصہ کیوں آرہا ہے ؟ میں تو بس ایک پیغمبر ہوں ،اللہ کا پیغام لے کر آیا ہوں ،جس کا کام ہی یہ ہوتا ہے کہ وہ خداوندِ عالم کے پیغامات پہنچادے۔ اب تمھارا نفع نقصان خود تمھارے ہاتھ میں ہے اگر تم مان لوگے تو خود تمھارا ہی فائدہ ہوگا،ورنہ تم خود ہمیشہ ہمیشہ جہنم کی آگ میں جُھلسو گے۔ (جلو گے) رہا میں ،تو میں خدائے واحد کا ایک عبد (غلام) ہوں ،اگر میں خدا کے پیغامات کو نہ پہنچاوں تو اسکی سزا سے نہ بچ سکتا۔ اِس لیے اب جو میری بات نہ مانے گا،وہ خدا کے عذاب سے نہ بچ سکے گا۔&&(فصل الخطاب)&&صحیح نتیجہ یا تعلیم: آیت کے آخری الفاظ کا یہ مطلب ہرگز نہیں ہے کہ ہر گناہ کی سزا ،ابدی جہنم ہے۔ بات کیو ں کہ توحید پر ہورہی ہے ،اسی حوالے سے مطلب یہ ہے کہ جو شخص خدا کی یکتائی کو نہ مانے گا اور خدا کے ساتھ دوسرے جھوٹے خداوں کو شریک کرگے گا،اُ سکے لیے ہمیشہ ہمیشہ کی جہنم ہوگی۔&&(تفسیر کبیر۔ تفہیم)&&
  72,24,آیت ۲۴کا شانِ نزول:یہ ہے کہ جب مکے کے لوگ جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی زُبان سے قرآن مجید سنتے تھے تو آپ صلی اللہ علیہ و آلہ وسلم پر ٹوٹ پڑتے تھے۔ ان کو یہ غرور تھا کہ ہم تعداد میں بہت زیادہ ہیں اور اللہ کے رسول کے بظاہر چند مٹھی بھر ساتھی ہیں ہم ان کو دبا لیں گے۔ ان سے کہا جارہا ہے کہ اکثریت اور پارٹی بندی کے دھوکے میں نہ رہو،اس لیے کہ بہت جلد تمھاری شامت آیا ہی چاہتی ہے ،تمھاری مہلت عمل بس ختم ہی ہونے والی ہے،اس وقت تم کو ازخود معلوم ہوجائے گا کہ کس کے مدد گار کمزور ہیں اور کس کی پارٹی تعداد میں کم ہے۔&&(تفسیر کبیر۔ تفہیم۔ مجمع البیان) &&حق کا معیار کثرتِ تعدادا نہیں ہوتا:مددگاروں اور ماننے والوں کی اکثریت کبھی حق کا معیار نہیں ہوتی فرعون بھی حضرت موسیٰ علیہ السلام کے بارے میں کہا کرتا تھا:<<اِنَّ ھٓؤُلَاۗءِ لَشِرْذِمَۃٌ قَلِيْلُوْنَ>> &&:@@(یعنی بیشک (موسیٰ علیہ السلام کے ماننے والے) ایک چھوٹا سا گروہ ہیں ۔ تعداد میں تھوڑے ہیں @@۔&&(سورۃ ۲۶ الشعراء آیت ۵۴ پارہ ۱۹) && مشرکین عرب ہمیشہ یہی کہا کرتے تھے:<<نَحْنُ اَكْثَرُ اَمْوَالًا وَّاَوْلَادًا۰ۙ وَّمَا نَحْنُ بِمُعَذَّبِيْنَ>> &&( سورہ سبا ۳۴ ۔ آیت ۳۵ پارہ ۲۲)یعنی:@@ہم اور اولاد میں کثرت والے ہیں ،اور ہمیں عذاب نہیں دیا جاسکتا۔@@اور سورہ کہف میں ایک بے ایمان نے اپنے مومن ساتھی سے کہا :<<فَقَالَ لِصَاحِبِہٖ وَھُوَيُحَاوِرُہٗٓ اَنَا اَكْثَرُ مِنْكَ مَالًا وَّاَعَزُّ نَفَرًا>> &&( سورۃ الکہف ۱۸اایت ۲۴ پارہ ۱۵)یعنی:@@پس اس نے اپنے ساتھ سے جس سے وہ محوِ گفتگو تھا ،کہا کہ میں تجھ سے مال میں بھی بہت زیادہ ہوں اور کثرت ِ افراد بھی معزز ہوں ۔جبکہ انبیاء کرام اکثریت یا مال کی زیادتی پر نہیں بلکہ اللہ پر بھروسہ کرتے ہیں @@۔خدا تعالیٰ نے سورہ بقرہ میں فرمایا:<<قَالَ الَّذِيْنَ يَظُنُّوْنَ اَنَّھمْ مُّلٰقُوا اللہِ۰ۙ كَمْ مِّنْ فِئَۃٍ قَلِيْلَۃٍ غَلَبَتْ فِئَۃً كَثِيْرَۃًۢ بِـاِذْنِ اللہِ۰ۭ وَاللہُ مَعَ الصّٰبِرِيْنَ۲۴۹ >>:@@وہ لوگ جن کو اللہ سے ملاقات کا یقین تھاکہنے لگے کہ کتنے ہی چھوٹے چھوٹے گروہ ایسے ہیں جو خدا کے حکم سے بڑے بڑے گروہوں پر غالب آجاتے ہیں ، (کیوں کہ)اللہ صبر کرنے والوں کے ساتھ ہے (مدد کرتا ہے)۔@@&&(سورۃ ۲ البقرۃ ۔ آیت ۲۴۹ پارہ ۲) &&}}جناب امیر المومنین علیہ السلام فرماتے ہیں : اے لوگو! ہدایت کی راہ میں لوگوں کے کم ہونے سے کبھی وحشت زدہ یا خوف زدہ نہ ہوجانا۔&&(نہج البلاغہ خطبہ ۲۰۱) {{&& قرآن مجید کی مذکورہ بالا آیات اس حقیت کو واضح طور پر بتا رہی ہیں کہ اکثریت کاہونا کبھی حق کا معیار نہیں ہوا کرتا،اکثریت پر ناز کرنا کافر ذہنیت ہے جو اسی کو نجات کامعیار قرار دیتی ہے۔)&&تفسیر نمونہ)&&[[جمہوریت اک طرزِ حکومت ہے کہ جس میں ۔لوگوں کو گناہ کرتے ہیں تو لا نہی کرتے]]۔]]گریز از طرز جمہوری،غلامی پختہ کاری شد ۔کہ از مغزِ دو صد خَر،جکرِ انسانی نمی آید۔یعنی: جمہوریت سے گریز کرو ،اس لیے کہ دو سو گدھے ملک بھی ایک انسان کی عقل نہیں لاسکتے[[۔&&(اقبال)&&!!آیت کا پیغام:یہ ہے کہ اے کافرو! حق دشمنو! تم جتھے بنا بنا کر ہم پر حملے کرتے ہو اور یہ سمجھتے ہو کہ محمّد صلی اللہ علیہ و آلہ وسلم کے ساتھ تھوڑے سے ہیں ،اس لیے کمزور یں ،لیکن جب میرے وعدے کا وقت آ دھمکے گا،اور تمھارا تیا پانچا ہوجائے گا،اُس وقت تمھیں خود پتا چل جائے گا کہ کس کے ساتھی تھوڑے اور کمزور تھے۔&&(شیخ الا سلام عثمانی)&&
  72,25,آیت نمبر۲۵: مطلب یہ ہے کہ قیامت کا آنا بالکل یقینی بات ہے ،جو ہر قسم کے شک و شبہ سے بالاتر ہے۔&&(تفسیر ماجدی)&&قرآن مجید میں کئی جگہ یہ بات بتالائی گئی ہے کہ قیامت کے آنے کا تو علم صرف خدا کو ہے۔ جس طرح موت کا آنا یقینی ہے،مگر اس کا وقت صرف اللہ کو معلوم ہے۔ اسی طرح قیامت پورے عالم کی موت ہے۔ ہم کو یہ تو یقینی طور پر معلوم ہے کہ قیامت ضرور آئے گی،مگر اُس کا وقت موت کے وقت کی طرح صرف اور صرف خدا کو معلوم ہے۔&&(مولف)&& ایک دفعہ جبریل علیہ السلام جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی خدمت میں عربی بدو (دیہاتی) کی شکل میں آئے اور پوچھا: بتلائے قیامت کب آئے گی؟ }}آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا: تم جس سے سوال کر رہے ہو ،وہ اس مسئلے میں سوال کرنے والے سے زیادہ علم نہیں رکھتا۔عربی بدو نے پوچھا:  اے محمّدؐ! قیامت کب آئے گی؟ فرمایا:  وائے ہو تم پر،قیامت تو آکر رہے گی۔ تم بتاو کہ تم نے قیمت کے لیے کیا تیاری کی ہے۔؟عربی بدو نے کہا: میں نے نماز،روزہ تو زیادہ جمع نہیں کیا،مگر میں خدا اور اس کے رسول سے محبت کرتا ہوں ۔جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:فانت مع من اخببت یعنی :  پھر تم اس کے ساتھ رہوگے جس سے محبت کرتے ہو۔جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم کے صحابی انسؓ نے کہا : مسلمان کی حدیث پر اتنا خوش نہیں ہوتے،جتنا یہ یہ حدیث سن کر خوش ہوتے ہیں ۔&&(تفسیر مراغی جلد۲۹ ص ۱۵۰) {{&& یہی حدیث کچھ کمی کے ساتھ  بخاری شریف میں بھی ہے۔
  72,26,آیت نمبر۲۶:غیب سے مراد خدا کے راز بھی ہیں اور شریعت کے اسرار بھی ہیں ،کائنات کی تخلیق کے راز مقصود ہیں ۔البتہ محققین نے لکھا کہ اولیائے علیہم السلام اُمت جو انبیائے کرام علیہم السلام کا سایہ ہوتے ہیں ،خدا اپنے خاص راز اور اسرارِ شرعی اُن پر منکشف فرماتا ہے ،مگر یہ انکشاف انبیائے کرام علیہم السلام کے واسطے ہوتا ہے۔&&(تفسیر ماجدی)&& کیو ں کہ انبیائے کرام ہی خدا اور اس کی مخلوق کے درمیان واسطہ ہوتے ہیں ۔&&(مولف)&&آیت کا مطلب یہ ہے کہ غیب کا پورا علم صرف اور صرف اللہ کو ہے۔ مکمل علمِ غیب اللہ کے سوا کسی کو نہیں ۔ پھر آیت ۲۷ میں بتلایا جا رہا ہے کہ خدا جس شخص کو اپنے پیغامات پہنچانے کے لیے مقرر کرتا ہے اُس کو غیب کا جتنا علم چاہتا عطا فرماتا ہے ،پھر اُ س پیغام کی حفاظت کے لیے فرشتوں کو مقرر کرتا ہے ،تاکہ وہ غیب کا علم محفوظ طریقے سے رسول صلی اللہ علیہ و آلہ وسلم تک پہنچ جائے۔اِسی لیے آیت ۸۔۹ میں جنوں کی زُبانی بتلایا گیا تھا کہ انھوں نے دیکھا کہ عالمِ بالا تک رسائی کے تمام دروازے بند ہیں ،سخت پہردار لگے ہوئے ہیں ،اب وہاں سے کوئی سن گن نہیں مل سکتی کیوں کہ خدا کے پیغامات نبی صلی اللہ علیہ و آلہ وسلم پر جارہے ہیں ،یہ اُن کی حفاظت کا بندوبست ہے۔&&(تفسیر کبیر۔ تفہیم۔ مجمع البیان) &&اور حضرت محمّد مصطفیٰ صلی اللہ علیہ و آلہ وسلم چونکہ تمام رسولوں کے سلطان اور سب سے افضل ہیں لہٰذا اُن کو تمام رسولوں  سے زیادہ علمِ غیب دیا اور اس قدر دیا جس قدر آپ صلی اللہ علیہ و آلہ وسلم کی عالمی رسالت کے ماتحت ان کے شایانِ شان تھا ،اور حضرت امام علی علیہ السلام سے حضرت امام مھدی علیہ السلام تک تمام آئمہ علیہم السلام چونکہ حضرت محمّد مصطفیٰ صلی اللہ علیہ و آلہ وسلم کے صحیح جانشین ہیں لہٰذا غیوب کا علم رکھنے میں تمام انبیاء و مرسلین سے افضل و برتر ہیں ۔ اور ترکیب نحوی کے اعتبار سے مَنِ ارْتَضیٰ میں اسم موصول مبتداء ہے اور فَاِنَّہٗ اُس کی خبر ہے ،اور آخر میں فرمایا کہ جس نبی صلی اللہ علیہ و آلہ وسلم و رسول صلی اللہ علیہ و آلہ وسلم کو جس قدر علم ہے وہ اللہ کے احاطہ ،علم کے اندر ہے اور خود جانتا ہے کہ اُس نے کس کو کتنا علمِ غیب دیا ہے۔&&(تفسیرانوار النجف)&&
  72,27,آیت ۲۷ کی تشریح:{{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام محمّد باقر علیہ السلام سے روایت ہے کہ : جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم وہ رسول صلی اللہ علیہ و آلہ وسلم ہیں جو کو خدا وندِ عالم نے << مرتضیٰ<<&&(خدا کا چنا ہوا) &&کہا: یہ اس لیے کہ خدا اُن سے خوش ہوا ۔ اور ہم جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کے (حقیقی) وارث ہیں ،ہم کو بھی خداوندِ عالم نے اپنے غیب میں جتنا چاہا ،عطا فرمادیا پس جو کچھ بھی ہوچکا ہے ہم اُ سے بھی جانتے ہیں ،اور جو کچھ قیامت تک ہونے والا ہے ،ہم اُسے بھی جانتے ہیں ۔&&(تفسیر صافی۔ الخرائج و الجرائح بروایت امام علی رضا علیہ السلام ) &&{{اس آیت نے یہ ثابت کر دیا کہ انبیاء کرام علیہم السلام اور اولیاء علیہم السلام خدا اجمالی طور پر علم غیب رکھتے تھے جو خدا نے خود ان کو عطا فرمایا تھا ۔ جیسا کے سورہ آلِ عمران میں حضرت عیسیٰ علیہ السلام نے فرمایا:<<وَاُنَبِّئُكُمْ بِمَا تَاْكُلُوْنَ وَمَا تَدَّخِرُوْنَ فِيْ بُيُوْتِكُمْ۰>> یعنی: @@اور میں تمھیں ،جو تم کھاتے ہو اور جسے تم اپنے گھروں میں جمع کرتے ہو خبر دیتا ہوں @@ &&(سورہ آل عمران آیت ۴۹پارہ۳) &&}}جناب رسولِ خداؐ نے حضرت امام علی علیہ السلام سے فرمایا: اے علی! تم کو مقامِ خاج پر ایک عورت ملے گی جس کے پاس حاطب کا ایک خط ہے جو حاطب نے مکے والوں کو لکھا تھا ۔ وہ اس عورت سے چھین لاو ۔حضرت علی علیہ السلام تشریف لے گئے ،اسی مقام پر وہ عورت ملی ۔ پہلے اس نے انکار کیا ،پھر اعتراف کرکے وہ خط حضرت امام علی علیہ السلام کے حوالے کردیا۔&&(تفسیر نمونہ)&& !!جنگ موتہ کے موقع پر }}آںحضرت صلی اللہ علیہ و آلہ وسلم نے نام بنام خبر دی کہ جب یہ علمبردار شہید ہوتو فلاں علم کو اٹھائے پھر جب شہید ہوجائے تو جعفر علیہ السلام ابن ابو طالب عَلَم کو اٹھائیں ۔&&(کامل ابنِ اثیر جلد۲){{&&اِسی صورت سے مراد }}حضرت امام علی ابن ابی طالب علیہ السلام نے بہت سے واقعات کی خبر دی مثلاً (۱) آپ علیہ السلام نے اہلِ بصرہ کے لیے فرمایا تھا : گویا میں دیکھ رہا ہوں کہ آسمان اور زمین سے اللہ کا عذاب تم پر نازل ہورہا ہےاور تم سب کے سب اُ سمیں غرق ہوگئے ہو،میں صرف تمھاری مسجد کی چوٹی کشتی کی طرح پانی کے اوپر دیکھ رہا ہوں ۔&&(نہج البلاغہ)&& (۲) حجر بن قیس سے فرمایا تھا کہ : تمھیں میرے بعد، مجھ پرلعنت کرنے پر مجبور کیا جائے گا۔&&(مستدرک الصحیحین جلد ۲ ص ۲۰۸)&&(۳) آپ علیہ السلام نے مروان کے بارے میں کہا تھا:  وہ بڑھاپے میں گمراہی کا پرچم اپنے کندھے پر اٹھائے گا۔&&(یعنی خلیفہ بن کر لوگوں کو گمراہ کریگا)&&(طبقات ابنِ سعد جلد ۵)(۴)کمیلؒ بن زیاد نے حجاج ابنِ یوسف سے کہا تھا کہ حضرت امام علی علیہ السلام نے خبر دی تھی کہ&&( اے حجاج) تو مجھے قتل کرے گا۔&&(الاصابہ ابن حجر جلد ۵)&&(۵) خارجیوں سے جنگ شروع ہونے سے پہلے فرمادیا تھا کہ:  اس جنگ میں صرف ہمارے دس ،آدمی بھی نہیں مارے جائیں گے۔ اور ان کے دس آدمی بھی نہیں بچیں گے۔اور ایسا ہی ہوا۔&&(بیہقی کی مجمع جلد۶)&&(۶) کربلا کی سرزمین سے گذرتے ہوئے اصبغ بن نباتہ سے فرمایا کہ ،یہاں میرے بیٹے حسین علیہ السلام کی قبر بنے گی۔&&(الریاض النضرۃ جلد۲) &&اسی قسم کے حضرت امام علی ابنِ طالب علیہ السلام علیہ السلام کے بیانات بے شمار ہیں ۔ ملاحظہ فرمائیں اہلِ سنت کی مشہور کتاب &&(فضائل الخمسہ جلد ۲ ص ۲۳۱ سے ص۲۵۳){{&& اصولِ کافی کی جلد اول کے متعدد ابواب میں آئمہ اہلِ بیت علیہم السلام نے علم ِ غیب کی باتیں بتلائی ہیں ۔ علامہ مجلسی ؒ نے بحارالانوار کی جلد ۲۶ میں اسی قسم کی ۲۲ حدیثیں جمع فرمائی ہیں ۔ }}حضرت امام علی ابنِ ابی طالب علیہ السلام نے یہ بھی فرمایا: یہ علمِ غیب نہیں ہے۔ یہ ایک علم ہے جو میں نے صاحبِ علم (جناب رسولِ خدا) سے حاصل کیا ہے۔&&(نہج البلاغہ)!!نتیجہ اور خلاصہ:اس سے معلوم ہوا کہ اسرارِ غیب دو قسم کہ ہیں ۔(۱) ایک << علمِ غیب<<یہ وہ علم ہے جو صرف اور صرف خدا جانتا ہے۔ا سکے سوا کوئی نہیں جانتا۔(۲) علمِ غیب کی دوسری قسم وہ ہے جو خود خدا انبیاءکرام اور اولیاء کرام کو تعلیم دیتا ہے۔&&(تفسیر نمونہ)&&{{!! }}جناب امیر المومنین حضرت امام علی ابنِ ابی طالب علیہ السلام نے فرمایا: (اصل) علمِ غیب تو قیامت کا علم ہے جس کا ذکر خدا نے اس آیت میں بھی فرمایا ہے کہ  قیامت کے آنے کے وقت کا علم خدا کے ساتھ مخصوص ہے۔ خدا ہی بارش کو اتارتا ہے جو کچھ ماوں کے رحموں میں ہے ،اسے بھی جانتا ہے کہ رحموں میں لڑکا ہے یا لڑکی ،خوبصورت ہے یا بدصورت ،سخی ہے یا بخیل ،سعادت مند ہے یا شقی،دوزخی ہے یا جنتی۔ یہ سب علوم غیب ہیں جن کو خدا کے سوا کوئی نہیں جانتا۔ پھر ان کے علاوہ وہ علوم ہیں جن کو خدا نے اپنے پیغمبر علیہ السلام کو تعلیم دی اور آنحضرت صلی اللہ علیہ و آلہ وسلم نے مجھ تعلیم دی۔&&(نہج البلاغہ) &&}}فرزندِ رسول صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا: خدا کا ایک علم تو ایسا ہے جسے اُس کے علاوہ کوئی نہیں جانتا۔ مگر ایک علم ایسا بھی جسے اُس نے خود فرشتوں اور انبیاء علیھم السلام کو سکھایا ہے ۔اب جو کچھ خدا نے فرشتوں اور رسولوں علیہم السلام کو دیا ہے ،اسے ہم (آئمہ اہلِ بیت علیہم السلام ) بھی جانتے ہیں ۔&&(بحار الانور جلد ۲۶ ص ۱۶ حدیث۵) &&کیوں کہ آئمہ اہلِ بیت اور انبیاء کرام علیہم السلام کے حقیقی اور اولین وارث ہیں اس لیے ان کو تمام انبیاء کا علم خدا نے خود سکھایا ہے۔ اسی لیے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:<<انامدینۃ العلم وعلی بابھا>>(میں شہر ِعلم ہوں اور علی علیہ السلام اس کا دروازہ ہیں ۔)&&(ترمذی۔ صواعق محرقہ)&&قرآن نے حکم دیا: <<الْبُيُوْتَ مِنْ اَبْوَابِہَا>> :@@گھروں میں ان کے دروازوں سے آو@@&&( البقرۃ آیت ۱۸۹ پارہ ۲)}}&&امام علیہ السلام نے فرمایا: یہاں گھروں کے دروازوں سے مراد لکڑی کے دروازے نہیں ہیں بلکہ اس علم کے دروازے مراد ہیں جو علم رکھتے ہیں جسے خدا نے ان کو عطا کیا ہے یعنی ہم اہل بیت علیہم السلام رسول صلی اللہ علیہ و آلہ وسلم مراد ہیں ۔&&(تفسیر نورالثقلین) &&{{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم حضرت امام زین العابدین علیہ السلام نے فرمایا: اگر قرآن میں ایک آیت نہ ہوتی تو میں تمھیں ان تمام واقعات کی خبریں سنا دیتا ،جو ہو چکے ہیں ،اور جو ہونے والے ہیں ۔راوی نے پوچھا:  وہ کونسی آیت ہے ؟فرمایا:<<يَمْحُوا اللہُ مَا يَشَاۗءُ وَيُثْبِتُ وَعِنْدَہٗٓ اُمُّ الْكِتٰبِ >>یعنی : @@خدا جسے چاہتا ہے محو کردیتا ہے اور جسے چاہتا ہے ثابت باقی رکھتا ہے اور اُمّ الکتاب (لوحِ محفوظ) خدا کے پاس ہے۔@@&&(سورۃ الرعد آیت ۳۹ پارہ ۱۳)&&(تفسیر نورالثقلین جلد ۶ ص ۵۱۶) &&{{مطلب یہ ہے کہ ہمارے پاس قیامت تک کے واقعات کا علمِ غیب تو ہے مگر یہ پتہ نہیں ہے کہ کونسی چیز خدا مٹاکر دوسری لکھ دے گا۔ اس کا علم صرف خدا کو ہے۔ &&(مولف)&& جب بھی امام علیہ السلام کسی چیز کو جاننا چاہتا ہے تو خدا خود اس بات کو اسے سکھا دیتا ہے ۔ &&(الکافی از امام صادق علیہ السلام )&&!!قرآن سے ثابت ہے:کہ انبیاء کرام علیہم السلام اور اوصیاء ِرسول صلی اللہ علیہ و آلہ وسلم علمِ غیب رکھتے تھے۔مثلاً : قرآن میں ہے کہ }}حضرت سلیمان علیہ السلام پیغمبر نے اپنے درباریوں سے پوچھا ملکہ سبا کا تخت کون میرے پاس لاسکتا ہے ؟<<قَالَ الَّذِيْ عِنْدَہٗ عِلْمٌ مِّنَ الْكِتٰبِ اَنَا اٰتِيْكَ بِہٖ قَبْلَ اَنْ يَّرْتَدَّ اِلَيْكَ طَرْفُكَ۰ۭ فَلَمَّا رَاٰہُ مُسْتَقِرًّا عِنْدَہٗ قَالَ ھٰذَا مِنْ فَضْلِ رَبِّيْ۰>>یعنی:@@ اُس شخص نے جو کتاب میں سے کچھ علم رکھتا تھا کہا:  میں اس کو آنکھ جھپکنے سے پہلے ہی آپ علیہ السلام کے پاس لے آوں گا۔ پس جب سلیمان علیہ السلام نے اسے (تختِ بلقیس کو) اپنے پاس رکھا ہوا دیکھا تو فرمایا:  میرے پالنے والے مالک کا فضل ہے۔@@&&(سورۃ ۲۷ النمل آیت ۴۰ ۔ پارہ ۱۹) &&قرآن مجید میں خدا نے فرمایا:<<قُلْ كَفٰى بِاللہِ شَہِيْدًۢا بَيْنِيْ وَبَيْنَكُمْ۰ۙ وَمَنْ عِنْدَہٗ عِلْمُ الْكِتٰبِ۴۳>> یعنی: @@ اے رسولؐ! فرمادیجئے کہ میرے اور تمھارے درمیان گواہی کے لیے اللہ کافی ہے اور وہ شخص کافی ہے جس کے پاس کتاب کا علم ہے ۔@@&&( سورۃ الرعد آیت ۴۳ پارہ ۱۳)&&اہلِ سنت کی کتاب کی روایات کے مطابق ابو سعید خُدری نے فرمایا کہ میں نے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم سے <<الَّذِيْ عِنْدَہٗ عِلْمٌ مِّنَ الْكِتٰبِ >>جس کے پاس تھوڑا سا علمِ کتاب ہے کے معنی پوچھے توحضورِ اکرم صلی اللہ علیہ و آلہ وسلم نے فرمایا:  وہ میرے بھائی سلیمان علیہ السلام بن داود کے وصی علیہ السلام تھے (آصف علیہ السلام بن برخیا تھے) پھرمیں نے<< وَمَنْ عِنْدَہٗ عِلْمُ الْكِتٰبِ>> (یعنی) جس کے پاس پورا علمِ کتاب ہے ۔یہ کون ہیں؟ }}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:<<ذٰلک اخی علی ابن ابی طالب یعنی>>  وہ میرے بھائی علی ابنِ ابی طالب علیہ السلام ہیں ۔&&(احقاق الحق جلد۳۔ تفسیر نورالثقلین جلد ۲ و کتب اہل سنت) &&{{اب جسے پورے قرآن کا علم دیا گیا ہوگا اس کے پاس کتنا علم ہوگا۔
  72,28,آیت نمبر۲۸:محققین نے نتیجہ نکالا کہ ، قیامت کے وقت کا جاننا علومِ نُبوت میں سے نہیں ہے۔ اس لیے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم کو قیامت کے وقت کا علم نہ ہونا آپ صلی اللہ علیہ و آلہ وسلم کے نبوت کے دعوے پر کوئی اثر نہیں کرسکتا۔ خداوندِ عالم جن علوم کو ضروری سمجھتا ہے ،انبیا کرام علیہم السلام کو عطا فرماتا ہے۔ اور انبیاء کرام علیہم السلام سے اس علم میں کسی قسم کی غلطی کا کوئی امکان نہیں ہوتا۔ جزیات سے کلیات ،اور جزوی باتوں سے اصولی باتوں تک پہنچ جانا، قرآن مجید کا اسلوب بیان ہے۔&&(تفسیر ماجدی۔ تفسیر کبیر) &&محققین نے اس آیت سے یہ نتیجے نکالے:(۱) خدا نے اپنے رسولوں صلی اللہ علیہ و آلہ وسلم اور پیغامبروں (اور رسول صلی اللہ علیہ و آلہ وسلم کے اوصیاء ) کو اپنے پاس سے علمِ غیب عطا فرمایا ہے ،تاکہ وہ کارِ رسالت کو بھر پور طریقے سے انجام دے سکیں ۔(۲) اپنے نبی صلی اللہ علیہ و آلہ وسلم پر خدا فرشتوں کو حفاظت کے لیے مقرر کرتا ہے تاکہ خدا کے پیغامات ٹھیک ٹھیک رسول تک پہنچ جائیں اور رسولِ خدا کے پیغامات ٹھیک ٹھیک خدا کے بندوں تک پہنچا سکیں ۔&&(تفسیر کبیر ۔مجمع البیان ۔ تفہیم) && (۳) خدا کے رسول صلی اللہ علیہ و آلہ وسلم صرف پوسٹ مین نہیں ہوتے ، وہ خدا کا دیا ہوا علمِ غیب بھی رکھتے ہیں اور ان کی حفاظت پر ملائکہ مقرر ہوتے ہیں ۔(۴)رسولِ خدا صلی اللہ علیہ و آلہ وسلم پر بھی وار پیغام لانے والے فرشتوں پر بھی خدا کی قدرت اس طرح محیط ہے کہ خدا کے پیغامات میں بال برابر کا فرق نہیں آسکتا ،خدا کے پیغامات کا حرف حرف محفوظ ہے ،فرشتے یا شیاطین ان پیغامات میں ذرہ برابر کمی یا زیادتی نہیں کرسکتے۔(۵) جب آسمانوں سے پیغام کے آنے میں خدا اپنے پیغامات کی اس قدر حفاظت کا بندوبست کر رہا ہے تو پھر ممکن ہے کہ رسول صلی اللہ علیہ و آلہ وسلم کی وفات کے بعد اپنے پیغامات کی حفاظت کا کوئی بندوبست نہ کرے گا،ان پیغامات کو درباری Paidملاوں کے حوالے کردے گا۔ کہ وہ خدا کے پیغامات ظالم ،جابر بادشاہوں کی مرضی کے مطابق ادلتے بدلتے رہیں ۔ بقول ڈاکٹر اقبال:]]خود بدلتے نہیں قراں کو بدل دیتے ہیں ۔۔۔۔ہوئے کس درجہ فقیہانِ حرم بے توفیق[[۔]]یہی شیخ حرم ہے جو چُرا کر بیچ کھاتا ہے۔گلیمِ بوذرؓ و دلق ِ اویس ؓ و چادرِ زھراء صلی اللہ علیہ و آلہ وسلم [[خداوندِ عالم نے جس طرح قرآن کے الفاظ کی حفاظت فرمائی ہے کہ:<<اِنَّا نَحْنُ نَزَّلْنَا الذِّكْرَ وَاِنَّا لَہٗ لَحٰفِظُوْنَ>> @@ہم ہی نے قرآن کو اتارا ہے اور ہم ہی خود اس کی حفاظت کرنے والے ہیں @@&&(الحجر ۱۵ آیت ۹ پارہ ۱۴) &&قرآن میں فرمایا کہ :<<ثُمَّ اَوْرَثْنَا الْكِتٰبَ الَّذِيْنَ اصْطَفَيْنَا مِنْ عِبَادِنَا>> &&(فاطر نمبر ۲۵ آیت ۳۲ پارہ ۲۲)&&یعنی: @@ پھر ہم نے اپنی کتاب کا وارث اُن لوگوں کو بنایا جن کو ہم نے اپنے بندوں میں سے خود چُنا۔@@نیز فرمایا:<<وَجَعَلْنَا مِنْہُمْ اَىِٕمَّۃً يَّہْدُوْنَ بِاَمْرِنَا لَمَّا صَبَرُوْا۰ۭ وَكَانُوْا بِاٰيٰتِنَا يُوْقِنُوْنَ>>۲۴ &&(سورۃ ۲۲ السجدہ آیت ۲۴ پارہ ۲۱)یعنی: @@اور پھر ہم نے ان میں امام مقرر کیے تاکہ وہ ہمارے امر کے ساتھ ہدایت کریں ،جب انھوں نے صبر کے جوہر دکھائے اور وہ ہماری آیتوں پر یقین رکھتے تھے@@پھر قرآن نے ان لوگو کی طہارتِ کردار کا بھی اعلان فرمادیا:<<اِنَّمَا يُرِيْدُ اللہُ لِيُذْہِبَ عَنْكُمُ الرِّجْسَ اَہْلَ الْبَيْتِ وَيُطَہِّرَكُمْ تَطْہِيْرًا>> &&(سورۃ ۳۳ الاحزاب آیت ۳۳ پارہ ۲۲) &&(یعنی: @@بس اللہ نے اس بات کا ارادہ کرلیا ہے کہ اے اہلِ بیت علیہم السلام رسولؐ) تم سے ہر قسم کی برائی اور نجاست کو دور ہی رکھے اور تمھیں ایسا پاک رکھے جو حق ہے پاک رکھنے کا۔@@پھر }}جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: میں تم میں دو بہت قیمتی چیزیں چھوڑے جا رہا ہوں ایک اللہ کی کتاب دوسری میری عزت (اولاد) میرے اہلِ بیت علیہم السلام ،جب تک تم لوگ ان دونوں سے تعلق جوڑے رہو گے (یعنی ان کی ہدایات پر عمل کرتے رہوگے) کبھی ہرگز گمراہ نہ ہوگے۔ اور یہ دونوں کبھی ہرگز ایک دوسرے سے جدا نہ ہوں گے یہاں تک کہ میرے پاس حوضِ کوثر پر نہ لوٹ آئیں ۔ (الحدیث)&&(صحیح مسلم ،صواعق محرقہ ،تفسیر مجمع البیان ،تفسیر نورالثقلین ،تفسیر انوار النجف) &&{{!!حاصلِ مطلب یہ ہے کہ:خداوندِ عالم نے آسمانوں پر چوکی ،پہرے کے یہ زبردت انتظامات اس لیے کیے ہیں کہ خداوندِ عالم دیکھ لے کہ اس کے فرشتوں نے اور اس کے پیغام لے جانے والوں نے اس کے پیغامات مِن و عَن ،بالکل ٹھیک ٹھیک اس کے بندوں تک پہنچادئیے ۔ (تاکہ اتمامِ حجت ہوجائے اور کل کوئی یہ نہ کہ کہ ہمیں خبر نہ ہوسکی)&&(شیخ الاسلام عثمانی)&&
