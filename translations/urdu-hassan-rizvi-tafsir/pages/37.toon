  37,1,آیت نمبر۱:<<صافات>> <<صافہ>> کی جمع ہے۔ یعنی کی کئی صفیں باندھ کر عبادت کرنے والے۔قسم کھانے کا فلسفہ:(۱) قسم ہمیشہ کسی ایسی بات پر کھائی جاتی ہے جو بہت اہم ہو، اور بہت قابل قدر ہو۔(۲) دوسرے یہ کہ قرآن میں قسم تاکید کے لئے کھائی جاتی ہے یعنی جو بات قسم کھانے کے بعد کہی جائے گی وہ بہت اہم ہے جس کو سستا سمجھنا اور ماننا بہت ضروری ہے۔&&(تفسیر کبیر ۔ تفسیر نمونہ)&&جس طرح فرشتے صفیں باندھ کر عبادت کرتے ہیں اور قابل قدر ہیں ، اسی طرح صفیں باندھ کر خدا کی راہ میں جہاد کرنے والے مجاہدین اور صفیں باندھ کر باجماعت نماز پڑھنے والے نمازی بھی اس قسم میں شامل اور خداکی نگاہ میں عظیم مرتبہ رکھتے ہیں ۔ &&(تفسیر برہان جلد ۴، تفسیر درمنشور،جلد ۵)&&[[دو عالم سے کرتی ہے بیگانہ دل کو۔عجب چیز ہے لذت آشنائی]]&&(اقبال)&&
  37,2,آیت ۲: <<زاجرات>> کے معنی ڈانٹنے والے،، &&(المنجد)&&اکثر مفسرین کے نزدیک یہ ان فرشتوں کی صفت ہے جو بادلوں اور ہوائوں کو ڈانٹ دپٹ کر ہنکاتے رہتے ہیں اور شیاطین کو جھڑکتے اور ہٹاتے رہتے ہیں ۔ &&(لغات القرآن نعمانی جلد۳)&&یہاں ان فرشتوں کی قسم کھائی جارہی ہے جو شیطانی وسوسوں کو دلوں سے دور کرتے ہیں اور لوگوں کو نیک کاموں کی طرف ہانکتے رہتے ہیں ۔&&(تفسیر نمونہ)&&
  37,3,آیت ۳کی تشریح:جن اوصاف کی یہاں قسم کھائی جارہی ہے بظاہر تو وہ فرشتوں کے اوصاف ہی ہیں جو کائنات عالم کے چلانے پر مامور ہیں ، اور ہر طاقت کو خدا کے احکام کے تابع فرمان رکھتے ہیں ۔لیکن بعض شیعہ تفاسیر میں ان سے اولین مراد انبیا کرام علیہ السلام اور ائمہ اہل بیت علیہم السلام کی ارواح بھی ہیں جو خدا کی عبادت میں صفیں باندھتے رہے ہیں اور برائی سے روکنے کے لئے ضرورتاً ڈانٹ دپٹ سے بھی کام لیتے ہیں ۔ مگر یہ ڈانٹنا ڈپٹنا صرف حق دشمنوں اور سخت سرکشوں کے لئے مخصوص ہے۔&&(تفسیر مجمع البیان)&&{{جناب امرالمومنین علیہم السلام نے فرمایا: ان فرشتوں میں ایک گروہ صفیں باندھے ہمیشہ خدا کی تسبیح کرتا رہتا ہے، جو ذرا نہیں تھکتے، نہ انہیں نیند آتی ہے اور نہ وہ کبھی سہو کرتے ہیں ، نہ سست پڑتے ہیں ۔&&(نہج البلاغۃ)&&}}!!نتائج وتعلیمات:ان تینوں آیتوں کی ترتیب بتارہی ہے کہ ہمیں حق کی راہ میں تین کام کرنے چاہئیں ۔(۱) سب سے پہلے صفیں باندھ کر انکساری کے ساتھ خدا کی عبادت کے لئے تیار ہوجانا چاہیے۔(۲) راہ حق کے لئے حق کے پھیلانے میں جو رکاوٹیں آئیں ان کو دور کرنا چاہیے۔(۳) پھر خدا کی آیتوں اور احکامات کو پڑھ پڑھ کر لوگوں کو سکھانا اور سمجھانا چاہیے۔خدانے ان تین کام کرنے والوں کی قسم کھاکر ایسے کام کرنے والوں کی قدروقیمت کو پسند اور روشن فرمایا ہے۔&&(تفسیر نمونہ، مجمع البیان، تفسیر کبیر)&&}}
  37,5,آیت۵: <<رب المشارق>>: یعنی بہت سے مشرقوں کا مالک اور پالنے والا۔ پرانے مفسرین کے لئے یہ لفظ بہت مشکل تھا۔ انہوں نے لکھا کہ موسموں کے اختلاف کے ساتھ مختلف نقطوں سے سورج کے طلوع ہونے کے مقامات مراد ہیں ۔ &&(جلالین)&& مگر اب جب کہ جدید تحقیقات سے ثابت ہوچکا ہے لاکھوں کروڑوں آفتاب ہیں ، جن کے اپنے اپنے نظام ہیں جن سے مشرقوں کی کثرت کا تصور بالکل واضح ہوگیا۔&&(فصل الخطاب)&&!!آیت کا پیغام:یہ ہے کہ اصل معبود، جو کائنات کا مالک پالنے والا ہے وہی مستحق عبادت ہے ، اسی کے کامل اطاعت اور غلامی میں انسانوں کے فائدے ہیں یہی عقل وفطرت کا تقاضا ہے۔&&(مجمع البیان تفسیر کبیر)&&
  37,6,آیت نمبر۶:<<السمآ الدنیا>> قریب کے آسمان سے مراد وہ بلندی سے جو بغیر دور بین کے دیکھی جاسکتی ہے&&(تفسیر کبیر)&& سماء،کسی متعین چیز کا نام نہیں ، بلکہ قدیم ترین زمانے سے یہ لفظ عالم بالا کی بلندیوں کے لئے استعمال کیا جاتا ہے۔&&(لسان العرب)&&موجودہ سائنس کی روسے ستاروں کا خوبصورتی کے ساتھ ٹمٹمانا اس کرہ ہوئی کی وجہ سے ممکن ہوتا ہے جو ہماری زمین کو چاروں طرف سے گھیرے ہوئے ہے۔ اس سے معلوم ہوا کہ خدا کانچلا آسمان <<السما الدنیا>> فرمانا کس قدر فصیح وبلیغ ہے۔&&(تفسیر نمونہ)&&
  37,9,آیت نمبر ۹: اصل بات یہ تھی کہ عرب میں کہا نت کا بڑا زور تھا- جگہ جگہ کاہن بیٹھے غیب کی باتیں بتا رہے تھے- ان کا دعویٰ تھا کہ وہ شیاطین ان کے قبضے میں ہیں جو ان کو آسمان سے ہر طرح کی خبریں لاکر سناتے ہیں- اس ماحول میں جب رسول اکرمؐ نے قرآن سنایا تو عربوں نے یہی سمجھا کہ ان کے پاس (معاذ اللہ) شیاطین آسمان سے کچھ خبریں لاکر سناتے ہیں جسے یہ وحی الٰہی بنا کر پیش کردیتے ہیں ۔اس کے جواب میں فرمایا جارہا ہے کہ اب شیاطین کی رسائی عالم بالا تک نہیں ہوسکتی۔ اگر شیاطین عالم بالا میں جانے کی   کوشش بھی کرتے ہیں تو ایک تیز شعلہ ان کا پیچھا کرتا ہے۔ بتانا یہ مقصود ہے کہ کائنات کا یہ عظیم الشان نظام ملائکہ کے ذریعہ سے چل رہا ہے اور شیاطین کا اس میں کوئی عمل دخل ممکن نہیں ، اور ہمارے رسول پر ہماری وحی آتی ہے&&(تفسیر کبیر، تفہیم، مجمع البیان)&&ان آیتوں کا مفہوم یقیناً سوفیصد درست ہے مگر اس کی تفصیلی حقیقت اور کیفیت کا سمجھنا الحال ہمارے بس کی بات نہیں ۔ &&(فصل الخطاب)&&کیونکہ یہ ان ہستیوں کی باتیں ہیں جن کا وجود اور اعمال ہمارے تجربات اور احساسات میں بھی نہیں آسکتے۔ &&(مولف)&&
  37,11,آیت ۱۱ کی تشریح:کفار مکہ کا اصرار تھا کہ آخرت ، یعنی مرنے کے بعد جی اُٹھنا کسی طرح ممکن نہیں ہوسکتا۔ ان کو جواب دیا جارہا ہے۔ کہ جو خدا اتنی زبردست عظیم الشان کائنات کو زمین وآسمانوں کو پیدا کرسکتا ہے، جو کوئی آسان کام نہیں ہے، اس کے لئے تمہیں مرنے کے بعد دوبارہ پیدا کرنا کیا مشکل ہوسکتا ہے۔&&(تفسیر کبیر)&&
  37,12,آیت ۱۲ کی تشریح:{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم سے فرمایا جارہا ہے کہ آپ صلی اللہ علیہ و آلہ وسلم تو اپنے پاک دل ودماغ کی وجہ سے ان کے آخرت کے انکار پر تعجب کے سمندر میں ڈوب جاتے ہیں مگر یہ لوگ ایسے ناپاک دل ودماغ والے ہیں کہ آخرت اور قیامت کو اس قدر محال عقلی سمجھتے ہیں ۔ کہ اس کا مذاق اُڑاتے ہیں ۔ معلوم ہوا کہ مذاق اڑانا، نہ ماننے سے بھی کہیں زیادہ بری چیز ہے۔ یہ کفر کا اونچا درجہ ہے۔&&(تفسیر نمونہ)&&
  37,22,آیت نمبر۲۲:ظالموں اور ان کے ساتھیوں سے اولین معنی میں اصل مراد وہ لوگ ہیں جنہوں نے انبیاء علیہم السلام اور آئمہ اہل بیت علیہم السلام پر ظلم کیا، اور <<ازواجھم>>سے مراد ان کے ساتھی بھی ہیں اور ان ہی جیسے تمام لوگ بھی ہیں ۔ &&(تفسیر نورالثقلین)&&!!<<ظالم>> سے مراد وہ لوگ جنہوں نے دوسری پر ظلم کیا۔ دوسروں کا حق مارا دل آزاری کی قتل وغارت کا بازار گرم کیا۔ غرض قرآن کی زبان میں ہر وہ فاسق وفاجر گنہگار ظالم، بدکار ظالم کہلاتا ہے جو خدا کے مقابلے پر سرکشی اور نافرمانی کی زندگی اختیار کرتا ہے۔&&(تفسیر کبیر)&&جھوٹے معبود تین قسم کے ہیں :(۱) اوہ انسان اور وہ شیاطین جو یہ جانتے ہیں کہ لوگ خدا کو چھوڑکر ان کی بندگی غلامی کریں ۔ یہی مجرموں کے ساتھ واصل جہنم ہوں گے۔(۲) جھوٹے خدا جو پتھر اور درخت سے بنائے گئے تھے۔(۳) وہ معبود جن کو دنیا میں پوجا کیا مگر وہ اس پر ہرگز راضی نہ تھے بلکہ وغیرہ اللہ کی پوجاپاٹ سے لوگوں کو روکتے تھے۔ جیسے حضرت عیسیٰ علیہ السلام یا فرشتے۔ اس قسم کے معبود ہرگز جہنم میں مجرموں کے ساتھ داخل نہ ہوں گے۔ &&(تفسیر کبیر، مجمع البیان)&&
  37,24,آیت نمبر۲۴:{{ امیرالمومنین حضرت امام علی ابن ابی طالب علیہ السلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے اس آیت کی تفسیر کرتے ہوئے فرمایا: کوئی انسان قیامت کے دن ایک قدم بھی آگے نہ بڑھاسکے گا جب تک کہ اس سے ان چار باتوں کے بارے میں سوال نہ کیا جائے:(۱) جوانی کس کام میں گزاری۔(۲) عمر بھر کیا کچھ کیا۔(۳) مال کہاں سے کس طرح کمایا؟(۴) اور میرے اہل بیت علیہم السلام کی محبت کے بارے میں پوچھا جائے گا۔(ان کا حق محبت ادا کیا یانہ کیا)؟&&(تحف الغول، تفسیر نورالثقلین، تفسیر انوار النجف، امالی عیون الاخبار الرضا، علل الشرائع)&&}}{{نیز آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا: اس آیت کا مطلب یہ بھی ہے کہ علی علیہ السلام کی ولایت کے بارے میں سوال کیا جائے گا۔ کہ مانا کہ نہ مانا اور مانا تو اس کے علمی تقاضوں کو کس حد تک پورا کیا؟&&(تفسیر صافی ، تفسیر قمی)&&}}کس بات کے پوچھنے کے لئے روکا جائے گا؟:بعض مفسرین نے کہا: بدعتین ایجاد کرنےوالوں کو روکا جائے گا۔&&(تفہیم)&&برے اعمال انجام دینے والوں کو روکا جائے۔&&(مجمع کبیر)&&توحید کے بارے میں سوال کرنے کے لئے روکا جائے گا۔&&(تفسیر کبیر)&&نعمتوں خاص کر جوانی عمر، مال کے غلط استعمال کے سوال کے لئے روکا جائے گا۔ &&(تبیان)&&حضرت امام علی علیہ السلام کی ولایت کے بارے میں پوچھنے کے لئے روکا جائے گا۔ اس روایت کے بارے میں اہل سنت نے بھی لکھا ہے کہ حضرت علی علیہ السلام کی ولایت کے بارے سوال کیا جائے گا۔ مثلاً &&(صواعق محرقہ ۱۴۷)&&&& (شواہد التنزیل، تذکرۃ الخواص علامہ سیط ابن جوزی ص ۲۱تفسیر روح المعانی ، کفایۃ الخصال، ابو نعیم اصفہانی۔ شیعہ کتب میں عیوان الاخبار الرضا علیہ السلام ، تفسیر نورالثقلین وغیرہ)&&!!طریق اہل سنت کی روایات:{{صواعق محرقہ، میں ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: روزِ قیامت علی علیہ السلام کی ولایت کے بارے میں پوچھنے کے لئے روکا جائے گا۔&&(صواعق محرقہ ابن حجر مکی بروایت حضرت ابوبکرؓ)&&{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: قیامت کے دن ہر شخص سے چار چیزوں کے بارے میں ضرور پوچھا جائے گا۔(۱)عمر کو کہاں خرچ کیا؟(۲) جسم کو کن کاموں میں استعمال کیا؟ (۳) مال کیسے کمایا اور کہا خرچ کیا؟ (۴) میرے اہل بیت علیہم السلام سے محبت کی؟ ان کا حق ادا کیا؟ایک شخص نے عرض کی: یارسول اللہ اہل بیت علیہم السلام کی محبت کی نشانی کیا ہے؟آپ صلی اللہ علیہ و آلہ وسلم نے حضرت امام علی علیہ السلام کے سر پر ہاتھ رکھ کر فرمایا: ان کی محبت،، پھر حضرت عمرؓ نے یہی سوال کیا۔ آپ صلی اللہ علیہ و آلہ وسلم نے حضرت امام علی علیہ السلام کے سر پا ہاتھ رکھ کر فرمایا: میرے اہل  بیت علیہم السلام کی محبت کی نشانی یہ ہےکہ جو اس جوان علی علیہ السلام سے محبت کرتا ہے۔ میرے بعد میری محبت کی نشانی اس جوان کے ساتھ محبت کرنا ہے۔ مجھے اس ذات کی قسم! جس نے مجھے نبی صلی اللہ علیہ و آلہ وسلم برحق بناکر بھیجا ہے کہ کسی انسان کی کوئی نیکی قبول نہ ہوگی جب تک اس سے محبت علی علیہ السلام کا سوال نہ کیا جائے گا ، اور وہ علی علیہ السلام کا محب ثابت نہ ہوجائے۔&&(تفسیر درمنثور سیوطی، تفسیر برہان)&&}}{{ابو سعید خدری سے روایت ہے کہ: جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: اہل محشر کو علی ابن ابی طالب علیہ السلام کی ولایت کے بارے میں پوچھنا کے لئے روکا جائے گا۔&&(تفسیر مجمع البیان)&&}}{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: روز قیامت حکم خدا سے صراط کے کنارے دوفرشتے کھڑے ہوں ے، جو ہر شخص سے علی علیہ السلام ابن ابی طالب علیہ السلام کی سند دیکھیں گے پس صراط پر سے سالم وہی گزر سکے گا جس کے پاس علی علیہ السلام کی لکھی ہوئی جہنم سے بری ہونے کی تصدیق ہوگی، اور ج س کے پاس یہ برات نامہ نہ ہوگا، وہ اُلٹے منہ جہنم میں جھونک دیا جائے گا۔&&(تفسیر برہان برروایت ابوسعید خدری)&&}}{{ان ابن مالک نے بیان کیا کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:روزِ محشر صراط کو جہنم کے اوپر بچھایا جائے گا اور اس کے اوپر سے صرف وہی شخص گزر سکے گا جس کے پاس علی علیہ السلام کی ولایت کا پروانہ راہ داری ہوگا۔&&(تفسیر برہان ، تفسیر انوار النجف)&&}}!!صراط پرچوکیاں قائم ہوںگی:{{حضرت ابن عباس سے روایت ہے کہ: روزِ محشر صراط پر چوکیاں قائم ہوگی۔ داروغہ، جہنم مالک کو ساتوں طبقے جہنم کے بھڑکانےکا حکم ہوگا اور رضوان کو جنت کے آٹھوں درجات سجانے کا حکم ہوگا، میکائیل علیہ السلام کو جہنم کے اوپر صراط بچھانے کا حکم ہوگا اور جبرائیل علیہ السلام کو عرش کے نیچے میزان عدل قائم کرنے کا فرمان خداوندی جاری ہوگا، صراط پر چوکیاں قائم کی جائیں گی، ہر چوکی پرستر ہزار فرشتے معین ہوں گے۔ ہر چوکی پر امت محمدی صلی اللہ علیہ و آلہ وسلم سے سوالات ہوں گے۔ پہلی چوکی پر حضرت امام علی علیہ السلام کی ولایت کے بارے میں سوال ہوگا اور جب آل محمد صلی اللہ علیہ و آلہ وسلم پوچھی جائے گی۔ جو کامیاب ہوگا وہ بجلی کی تیزی کی طرح اس مقام کو پار کرجائے گا، اور جو ناکام (حب آل محمد نہ رکھتا) ہوگا اے الٹا کرکے جہنم میں پھینک دیا جائے گا اگرچہ وہ ستر صدیقوں کے برابر نیکیاں ہی کیوں نہ لایا ہو۔ دوسری چوکی پر نماز، تیسری چوکی پر زکوٰۃ، چوتھی چوکی پر روزوں ، پانچویں چوکی پر حج، چھٹی چوکی پر جہاد، ساتویں چوکی پر لوگوں کے ساتھ عدل وانصاف کے بارے میں سوالات کیے جائیں ۔ جو پاس وکامیاب ہوتا جائے گا وہ بجلی کی طرح ہر چوکی کو عبور کرتا ہوا (جنت میں داخل ہوجائے گا) اور جو فیل اور ناکام ہوگا وہ نیچے جہنم میں گر کر عذاب کا مزہ چکھے گا۔ اس روایت سے پتہ چلتا ہے نماز روزہ وغیرہ جملہ اعمال کا سوال صرف ولایت علی علیہ السلام اور محب آل محمد صلی اللہ علیہ و آلہ وسلم ہی سے ہوگا، ورنہ بصورت دیگر وہ پہلی ہی چوکی سے جہنم رسید ہوں گے۔&&(ابن شہر آشوب، تفسیر انوار النجف)&&}}
  37,37,آیت نمبر۳۷:رسولوں صلی اللہ علیہ و آلہ وسلم کی تصدیق کرنے کے تین معنی ہیں (۱) یعنی ہمارے رسول صلی اللہ علیہ و آلہ وسلم نے کبھی کسی سابق رسول علیہ السلام کی مخالفت نہیں فرمائی(۲) ہمارے نبی علیہ السلام آخر کوئی نئی نرالی بات لے کر نہیں آئے، بلکہ ساری باتیں وہی پیش فرمائیں جو گزشتہ انبیا علیہم السلام نے سکھائی پڑھائی تھیں ۔ (۳) ہمارے رسول ان تمام خبروں کے صحیح مصداق ہیں جو گزشتہ رسولوں علیہم السلام نے ان کے بارے میں بتائی تھیں ۔&&(تفسیر کبیر)&&
  37,41,آیت ۴۱:مخلصین،وہ ہوتے ہیں جن کا ہر کام صرف اور صرف خدا کے لئے اپنے نفس کی مخالفت میں ہوتا ہے۔ علامہ طباطبائی نے لکھا: خدا کا مطلب یہ ہے کہ تمام لوگ تو اپنے اپنے اعمال کا اجر پائیں گے، خدا کے خالص بندوں کے سوا کیوں کہ ان کے خلوص کی وجہ سے خدا نے ان کو اپنے لئے پسند فرمالیا۔ ان کا دل خدا کی ذات کے سوا کسی سے تعلق نہیں رکھتا، خدا کے سوا کسی چیز کا خیال ان کے دل میں رچا بسا نہیں ۔ اسی لئے ان کے لئے خداوندِ عالم نے فرمایا:<< اولیک لھم رزق>> معلوم،، یعنی : ان کی روزی خالص اور مخصوص ہے۔ اہل جنت سے بھی ان کا حصہ الگ تھلگ ہے۔
  37,49,آیت نمبر۴۹:&&(عربی محاور ے میں شراب سے بھرے پیالے کو<<کاس>> کہتے ہیں ۔ شراب سے خالی پیالے کو<<قدح>> یا <<اناء>> کہتے ہیں ۔)&&(قرطبی)&&جنت کے حوروں کو شتر مرخ کے انڈوں سے تشبیہ اس لئے دی گئی ہے کہ شتر مرغ اپنے انڈوں کو اپنے پروں میں چھپائے رکھتی ہے۔ اسی لئے اس کے انڈے ہر قسم کے گردوغبار سے پاک صاف رہتے ہیں پھر ان کا رنگ بھی زردی مائل زعفرانی سفید ہوتا ہے، اور یہ رنگ جسم کے رنگوں میں سب سے زیادہ خوبصورت اور دلکش سمجھا جاتا ہے۔&&(تفسیر صافی)&&۔ آنحضرت صلی اللہ علیہ و آلہ وسلم نے اس آیت کا مطلب یہ فرمایا کہ: ان کی نرمی اور نزاکت اس جھلی جیسی ہوگی جو انڈے کے چھلکے اور اس کے گودے کے درمیان ہوتی ہے۔&&(ابن جریر از ام سلمہؓ)&&
  37,50,آیت ۵۰ کی تشریح:افرادی اور مادی لذتیں کتنی ہی بڑی اور زیادہ کیوں نہ ہوں ۔ مگر کافی نہیں ہوسکتیں ۔ ہم مشرلوں ، ہم خیالوں ، دوستوں ، ساتھیوں ، رشتہ داروں کا اجتماعی لطف لذتوں کی لذت میں کئی کئی گناہ اضافہ کردیتا ہے۔&&(تفسیر ماجدی)&&
  37,55,آیت نمبر۵۵:جھک کرجھانکنے کے لفظ سے محققین نے نتیجے نکالے کہ:(۱)جنت بلند مقام پر ہے جبکہ جہنم پستی میں ہے۔(۲)اہل جنت جب چاہیں گے اہل جہنم کا تماشا دیکھ لیں گے۔ &&(مرشد تھانوی)&&پس جب وہ مومن جنت سے جہنم کی طرف جھانکے گا تواس کو اپناوہ ساتھی جہنم کے وسط میں معذب نظر آئے گا تو یہ مومن اس سے کہے کہ تو تو مجھے بھی گمراہ کرنے پر مصر تھا۔ اگر اللہ کے احسانات مجھ پر نہ ہوتے ہو تو میں بھی تیری طرح تباہ وبرباد ہوجاتا۔ پھر مومن اللہ کے فضل وکرم کا شکر ادا کرے گا تو اس کو دوہری لذت حاصل ہوگی۔ &&(تفسیر انوار النجف)&&
  37,62,آیت نمبر۶۲:<<زقوم>>ایک خاردار ، بدبودار اور کڑوا پودہ ہے جس کو پنجابی زبان میں تھوہر ’ کہاجاتا ہے یہ جہنمیوں کو کھلایا جائے گا۔ عرب میں چونکہ یہ پودا موجودنہ تھا۔ ابن زبعری نے قریشیوں سے کہا کہ بربر کی زبان میں کھجور اور مکھن کو زقوم کہا جاتاہے ۔ لہٰذا ابوجہل نے اپنی کنیز سے کہا کہ زقوم تیار کرکے لے آ۔ تو وہ فورا کھجور اور مکھن لے آئی ۔ ابوجہل نے لوگوں کے سامنے وہ پیالہ رکھ کر کہا کہ یہی وہ زقوم ہے جس سے محمد صلی اللہ علیہ و آلہ و سلم تم کو ڈراتا ہے۔&&(تفسیر انوار النجف)&&
  37,83,آیت نمبر۸۳:تمہیں یہ نام شیعہ مبارک ہو:{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السلام نے فرمایا: تمہیں یہ نام شیعہ مبارک ہو۔عرض کیا گیا کہ لوگ تو ہم پر عیب لگاتے ہیں ۔ امام علیہ السلام نے فرمایا: کیا تم نے خداوند عالم کا یہ قول نہیں پڑھا کہ : ابراہیم علیہ السلام بھی نوح علیہ السلام کے شیعہ تھے۔ پھر خداوند عالم نے قرآن میں یہ فرمایا کہ :<<ہٰذَا مِنْ شِيْعَتِہٖ وَہٰذَا مِنْ عَدُوِّہٖ۰ۚ فَاسْتَغَاثَہُ الَّذِيْ مِنْ شِيْعَتِہٖ عَلَي الَّذِيْ مِنْ عَدُوِّہٖ>>&&(سورۃ القصص آیت ۱۵ پ۲۰)&&}} یعنی : یہ ایک تو موسٰی علیہ السلام کے شیعوں میں سے تھا، اور وہ دوسرا موسیٰ علیہ السلام کے دشمنوں میں سے تھا اور جو موسیٰ کے شیعوں میں سے تھا اس نے فریاد کی موسیٰ سے اپنے دشمن میں سے تھا۔ &&(تفسیر صافی، تفسیر مجمع البیان ، تفسیر قمی، تفسیر انوار النجف)&&معلوم ہوا کسی نبی یا ولی کا طرف دار یا دوست خدا کے نزدیک شیعہ کہلاتا ہے اور نبی یا امام کا دشمن عدو کہلاتا ہے۔ &&(موئف)&&<<شیعہ>>کے لفظی معنی <<طرفدار>> تابعدار اور پیروکار ہوتے ہیں ۔ &&(لسان العرب)&& مطلب یہ ہے کہ حضرت ابراہیم علیہ السلام ، حضرت نوح علیہ السلام کے شیعہ یعنی طرفدار اور پیروکار تھے۔ گویا حضرت ابراہیم علیہ السلام عقائد اور اصول دین میں حضرت نوح علیہ السلام سے متحد تھے۔ &&(تفسیر کبیر ، مدارک، قرطبی،بیضادی)&&انوار ائمہ اہلبیت علیہم السلام اور ان کے دوست :{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے ورایت ہے آپ نے فرمایا کہ : ’’ خداوند عالم کے حکم سے ، جب حضرت ابراہیم علیہ السلام کی نگاہوں سے پردے اٹھے تو انہوں نے عرش کے پہلو میں ایک نور چمکتا دیکھا۔ پوچھا: مالک ! یہ کس کانور؟ خداوند تعالیٰ نے ارشاد فرمایا: یہ محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کا نور ہے جو تمام مخلوقات میں میراسب سے زیادہ پسندیدہ اور چنیدہ ومنتخب ہے۔،،پھر اس کے پہلو میں ایک نور اور دیکھا، پوچھا:یہ کس کانور ہے؟اللہ تعالیٰ نے ارشاد فرمایا: یہ علی ابن ابی طالب علیہ السلام کا نور ہے جو میرے دین کا مددگار ہے۔،،پھر اس کے پہلو میں تین نور اور چمکتے دیکھے تو عرض کی : یہ انوار کن کے ہیں ؟اللہ عزشانہ نے ارشاد فرمایا: ایک فاطمہ علیہا السلام کا نور ہے جواپنے پیروکاروں اور شیعوں کو جہنم کے عذاب سے آزاد کرائیں گی، اور دو نور حسن علیہ السلام اور حسین علیہ السلام کے ہیں جوان کی فرزند ہیں ۔،،پھر حضرت ابراہیم علیہ السلام نے عرض کی :اے میرے پروردگار !ان پانچوں انوار کے چاروں طرف کن لوگوں کے نور ہیں ؟،، ارشاد رب العزت ہوا: علی  ابن الحسین علیہ السلام سے لے کر امام مہدی (عج ) تک ائمہ اہل  بیت علیہم السلام کے نور ہیں ۔ پھرحضرت ابراہیم علیہ السلام نے عرض کی: پالنے والے ! ان تمام انوار کے اطراف وجوانب میں بے حساب انوار کن لوگوں کے ہیں ؟خداوند کریم نے ارشاد فرمایا:یہ ان (چودہ انوار) کے شیعوں کے نور ہیں ۔ حضرت ابراہیم علیہ السلام نے عرض کی: ان کی نشانیاں کیا ہوں گی۔ خدائے تعالیٰ نے ارشاد فرمایا:ان کی نشانیاں یہ پانچ ہوں گی (۱) روزانہ اکیاون رکعت نماز (۱۷فریضہ اور ۳۴ نفل) پڑھنا(۲) نماز میں بسم اللہ بلند آواز سےپڑھنا (۳) رکوع سے پہلے قنوت پڑھنا (۴) دائیں ہاتھ کی انگلی میں انگوٹھی پہنتا (۵) زیارات اربعین پڑھنا یہ سن کر حضرت ابراہیم علیہ السلام نے دعا مانگی کہ خداوند! مجھےبھی علی علیہ السلام کے شیعوں میں قراردے۔ &&(مجمع البیان ، نورالثقلین ، تفسیر انوار النجف)&&}}شیعہ نہیں بلکہ محب اور موالی کہو:{{ایک شخص نے حضرت امام حسین علیہ السلام سے عرض کی: میں آپ علیہ السلام کا شیعہ ہوں ’’ آپ علیہ السلام نے فرمایا: ’’ خدا سے ڈرو ، اور ایسا دعویٰ نہ کرو جس میں خدا تم کو جھوٹا کہے۔ ہمارے شیعہ وہ ہوتے ہیں جو ہر کھوٹ اور برائی سے پاک ہوں البتہ تم ہمارے محب اور موالی کہلایا کرو۔ ،، &&(انوار النجف)&&ا}}{{یک شخص نےامام حسن عسکری علیہ السلام سے عرض کی: میں آپ علیہ السلام کے شیعوں میں سے ہوں ،،امام علیہ السلام نے فرمایا: اگرتم ہمارے بتائے ہوئے (خدا کے ) احکامات کے عملاً پابند ہوتو تمہارا دعوےٰ سچا ہے۔ ورنہ اس قدر بلند دعوے ٰ کرنے کے بعد گناہ کرنا چھوڑ دو، اگر گناہ نہیں چھوڑتے ہوتو خود کوشیعہ نہ کہو، بلکہ یہ کہو کہ میں آپ علیہ السلام کا محب موالی چاہنے والا ہوں ، اور آپ علیہ السلام کے دشمنوں سے الگ اور بیزار ہوں بس یہی کہنا تمہارے لیے بہترہوگا۔&&(تفسیر انوار النجف)&&}}{{ایک شخص نے حضرت امام محمد باقر علیہ السلام کے سامنے کسی دوسرے آدمی پر فخر کرتے ہوئے کہا کہ : میں محمد وآل محمد علیہم السلام کا شیعہ ہوں ۔ امام نے اسے اپنے پاس بلا کر پوچھا: تم اپنے مال کو اپنے اور خرچ کرنا زیادہ پسند کرتے ہو۔ یااپنے مومن بھائی پر؟ اس نے کہا: اپنے اوپر خرچ کرنا زیادہ پسند کرتا ہوں ۔امام علیہ السلام نے فرمایا: پھرتم ہمارے شیعوں میں سے نہیں ہو۔ تم لوگ خود کو ہمارے محب کہا کرو اور ہماری محبت کی وجہ سے نجات کی امید رکھا کرو۔،، &&(تفسیر انوارلنجف)&&}}{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا: فرعون نے حضرت موسٰی علیہ السلام کے ماننے والوں کانام رافضی رکھا تھا کیوں کہ وہ فرعون سے پھر گئے تھے (رفض کے معنی پھر جانا یا چھوڑدینا ) اور رافضی اسے کہتے ہیں جو اللہ کی نا پسندیدہ چیزوں کو چھوڑدیتا ہے، اور خدا کے سامنے جھک جاتا ہے۔،، &&(تفسیر انوار النجف)&&}}{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام علی رضا علیہ السلام نے ان لوگوں سے جو شیعہ ہونے کا دعویٰ کرتے تھے فرمایا: تم نے حضرت امام علی علیہ السلام کے شیعہ ہونے کا دعویٰ کیا ہے، حالانکہ ان کے شیعہ تو امام حسن علیہ السلام ، امام حسین ، سلمانؓ ، ابوذرؓ، عمار ؓ اور محمد ابن ابوبکرؓ جیسے لوگ تھے۔ تم لوگ تو اکثر خدا کے احکامات کے خلاف ورزیاں کرتے رہتے ہو، تو پھر کس منہ سے خود کو علی علیہ السلام کے شیعہ کہتے ہو، اتنے بلند مرتبے کا دعویٰ مت کروجس کی تمہارا عمل تصدیق نہ کرسکے ، ورنہ تم ہلاک ہوجائو گے۔ اس پران لوگوں نے توبہ کی اور عرض کیا کہ ’’ تم آپ علیہ السلام کے محب اور موالی (چاہنے والے) ہیں ، آپ علیہ السلام کے دوستوں کے دوست اور آپ علیہ السلام کے دشمنوں کے دشمن ہیں ۔ امام علیہ السلام نے یہ سن کر فرمایا: مرحبا، اب تم میرے بھائی اور درست ہو۔ پھر آپ علیہ السلام نے ان کواپنے قریب بٹھایا۔&&(تفسیر انوار النجف)&&خدانے فرمایا: ابراہیم علیہ السلام نوح علیہ السلام کے شیعوں میں سے تھے۔،، حالانکہ دونوں میں ۲۶۰۰سال کا فاصلہ تھا۔ اس سے معلوم ہوا کہ پیروی اور محبت کے سامنے وقت اور فاصلہ کی کوئی حقیقت نہیں ہوتی ۔ &&(تفسیر نمونہ)&&}}
  37,84,آیت نمبر۸۴:قلب سلیم کی تعریف:{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا: ’’ قلب سلیم ایسے دل کو کہتے ہیں جو خدا سے اس حالت میں ملاقات کرے کہ اس میں خدا کے سوا کچھ نہ ہو۔،، &&(تفسیر صافی، الکافی)&&}}{{امام علیہ السلام نے مزید فرمایا: جوشخص سچی خالص نیت رکھتا ہے وہ صاحب قلب سلیم ہے۔ کیوں کہ شرک اور شک سے دل کی سلامتی، نیت کو خدا کےلیے خالص کردیتی ہے۔،، &&(تفسیر صافی، الکافی)&&}}قلب سلیم کی اہمیت : کےلیے یہی کافی ہے کہ خداوند عالم نےاس کو قیامت کے دن کےلیے اکیلا سرمایہ نجات قراردیا ہے۔ جیسا کہ خداوند کریم نے قرآن مجید میں ارشاد فرمایا: <<يَوْمَ لَا يَنْفَعُ مَالٌ وَّلَا بَنُوْنَ۸۸ۙ اِلَّا مَنْ اَتَى اللہَ بِقَلْبٍ سَلِيْمٍ>>۸۹ۭ &&(سورۃ الشعراء آیت ۸۸، ۸۹، پارہ ۱۹)&& یعنی : @@اس دن (روزقیامت ) مال اور اولاد کچھ فائدہ نہ پہنچائیں گے ، سوااس کے کہ کوئی شخص قلب سلیم کے ساتھ اللہ کے سامنے حاضرہو۔،،@@دل سے اگر غیراللہ سے دلچسپیوں کو کالعدم کردیا جائے اللہ سے رابطہ بڑھا دیا جائے تو وہ دل قلب سلیم بن جاتاہے۔ {{حضرت امام جعفر صادق علیہ السلام نے فرمایا؛ ’’قلب ،، حرم خدا ہے، خدا کے حرم میں خدا کے غیر کو نہ بسائو۔ ،، &&(بحارالانوارجلد ۷۰۔ ۲۵)&&}}{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا:’’ اگر شاطین اولاد آدم علیہ السلام کو نہ گھیرلیں تو وہ عام ملکوت کو دیکھ لیں ۔،، &&(بحارالا نور جلد ۷۰۔۲۵)&&}}{{نیزفرمایا: خدا کے بندوں کے پاس ایک ظرف ہے جسے دل کہتے ہیں ، ان میں سب سے اچھا وہ دل ہے جو زیادہ صاف وشفاف ، خدا کے دین پر مضبوطی سے جما ہوا، گناہوں سے پاک ، دینی بھائیوں پر مہربان ہو۔&&(بحارالانوار جلد ۷۰)&&}}!!قلب سلیم کے معنی: (۱) ایسا دل جو ہر قسم کی اعتقادی اور اخلاقی بیماری سے پاک اور محفوظ ہو۔ (۲) وہ دل جو ہر قسم کے شرک سے پاک ہو۔ (۳) وہ دل جو ہر قسم کے گناہ ، کینہ ، نفاق سے پاک ہو (۴) وہ دل جو عشق دنیا سے خالی ہو۔(۵)وہ دل جس میں خدا کے سوا کچھ نہ ہو۔ &&(تفسیر نمونہ، تفسیر کبیر، کشاف)&&
  37,88,آیت نمبر۸۸۔۸۹:حضرت ابراہیم علیہ السلام کو جسمانی بیماری نہ تھی:{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: خداکی قسم !نہ تو حضرت ابراہیم علیہ السلام بیمارتھے، اور نہ ہی انہوں نے جھوٹ بولاتھا۔،، &&(تفسیر صافی)&&}} (آپ علیہ السلام کے بیمار کہنے کا مطلب یہ ہوسکتا ہے کہ میں عنقریب بیمار ہونے والا ہوں ) {{فرزند رسول خدا علیہ السلام حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ: ’’ حضرت ابراہیم علیہ السلام کی دعاء اور خواہش پر خداوند عالم نے ان کو وہ سب کچھ دکھادیا جو کربلا میں ہونے والا تھا،اسی لیے انہوں نے فرمایا کہ میں ا س روحانی تکلیف سے بیمار ہوں ۔،، (جسمانی بیماری انہیں لاحق نہ تھی) &&(الکافی)&&}}{{صحیح بخاری میں روایت ہے کہ: حضرت ابراہیم علیہ السلام نے تین جھوٹ بولے۔،، &&(صحیح بخاری)&&}}شاہ عبدالقادر صاحب نے مجبوراًلکھا کہ: جھوٹ اللہ کی راہ میں بھی ہوتا ہے، وہ عذاب نہیں ہوتا، بلکہ ثواب ہوتاہے۔ &&(موضح القرآن)&&اگراس بات کا کوئی قطعی ثبوت نہیں پایا جاتا کہ حضرت ابراہیم علیہ السلام کوکوئی بیماری نہیں تھی،تب آپ پر کہہ سکتے ہیں کہ حضرت ابراہیم علیہ السلام نے جھوٹ بولا،اور اگر کوئی قطعی ثبوت نہیں ہے تو پھران کو جھوٹانہیں کہا جاسکتا ۔&&(تفہیم )&& لیکن اللہ کو اس بات پر کوئی اعتراض نہیں ہے، پھر بندوں کو اعتراض کرنے کی کیا ضرورت ہے۔
  37,97,آیت ۹۷تا آیت ۹۸ کی تشر یح: نمرودیوں نے حضرت ابراہیم علیہ السلام کو اپنے میلہ کی تقریب میں شرک کی دعوت دی، لیکن آپ علیہ السلام نے ان کو یہ کہہ کر ٹال دیا کہ’’ میں بیمار ہوں ،، پس وہ آپ علیہ السلام کی معذرت کو سن کر واپس چلے گئے۔ آپ علیہ السلام کو موقع مل گیا تو سوچا کہ اب میدان خالی ہے سب لوگ جاچکے۔ چنانچہ مندر میں بتوں کے پاس جاکران سے فرمایا:تم کھاتے کیوں نہیں ؟ تم بولتے کیوں نہیں ؟ اس کے بعد اپنی پوری قوت سے ان پر پل پڑے اور ٹکڑے ٹکڑے کردیا۔ جب وہ لوگ واپس ہوئے اور بتوں کو کو ٹوٹا ہوا دیکھا تو سیدھے حضرت ابراہیم علیہ السلام کے پاس آئے اور بولے کہ تم نے ہمارے معبودوں کو توڑ ڈالا، اس لئے ہم تمہیں یہ سزا دیں گے کہ دہکتی بھڑکتی آگ میں تم کو ڈال کر جلادیں گے۔ پھر انہوں نے تو یہ منصوبہ بنالیا لیکن اللہ نے ان لوگوں کو ذلیل کردیا۔
  37,99,آیت نمبر۹۹:حضرت ابراہیم علیہ السلام کا فرمانا کہ: میں اپنے مالک کی طرف جاتا ہوں ،، مطلب یہ ہے کہ میں اپنے پالنے والے مالک کی راہ میں اسی کے حکم سے ہجرت کررہا ہوں ۔&&(مدارک ، کشاف ، تفسیر کبیر)&&مراد یہ ہے کہ میں خدا کے حکم اور اس کے دین کی خاطر ملک شام ہجرت کررہا ہوں اس لیے خدا ضرور میری مدد ہدایت فرمائے گا۔ &&(روح المعانی)&&حضرت اسماعیل علیہ السلام کی پیدائش کے وقت حضرت ابراہیم کی عمر۸۲سال تھی۔ &&(بائیبل ، پیدائش ۱۶:۶)&&حضرت اسحاق پیدائش کے وقت حضرت ابراہیم کی عمر۱۰۰ سال تھی۔ &&(بائیبل ، پیدائش ۲۱:۵)&&
  37,102,آیت نمبر۱۰۲:{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے روایت ہے کہ’’ حضرت ابراہیم علیہ السلام کو صرف خواب بتانے میں کم از کم تین دن تک غور کرنا پڑا، جبکہ حضرت اسماعیل علیہ السلام خواب سنتے ہی، ذبح ہونے کےلیے کیسے تیار ہوگئے؟ اس کی وجہ یہ تھی کہ جس وقت حضرت ابراہیم علیہ السلام یہ خواب دیکھ رہے تھے، تو ہم محمدؐوآل محمد علیہم السلام کانور صاحب ابراہیم سے صلب اسماعیل علیہ السلام میں منتقل ہوچکاتھا۔ یہی وجہ تھی کہ حضرت اسماعیل علیہ السلام خواب سنتے ہی کہنے لگے کہ اے باباجان: اللہ نے جوحکم آپ علیہ السلام کو دیا ہے اس کو بجالائیے میں بالکل تیارہوں ۔&&(تفسیر نورالثقلین، حیات القلوب)&&}}
  37,105,آیت نمبر۱۰۵:واقعاحضرت ابراہیم علیہ السلام نے اپنا خواب سچ کردکھایا ۔ کیوں کہ حضرت ابراہیم علیہ السلام نے خواب میں یہی دیکھا تھا کہ وہ اپنے بیٹے کو ذبح کرہے ہیں ، مگر خداوند کریم ورحیم کا مقصد بچے کی جان لینا نہ تھا، اللہ تعالیٰ کا صل مقصد حضرت ابراہیم علیہ السلام کا امتحان لینا تھا، سووہ مقصداس بات سے پورا ہوگیا کہ حضرت ابراہیم علیہ السلام نے{{ بروایت حضرت امام جعفر صادق علیہ السلام ،، سترہ مرتبہ حضرت اسماعیل علیہ السلام کے گلے پر چھری پھیری اور ہربار جبریل نے چھری چلنے سے پہلے اس کو الٹ الٹ دیا۔،،&&(فصل الخطاب)&&}}
  37,107,آیت نمبر۱۰۷:ذبح عظیم مقصد رحیم:{{فرزندرسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام علی الرضا علیہ السلام سے روایت ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: ’’جب خداوند کریم نے حضرت اسماعیل علیہ السلام کی جگہ دنبہ بھیجا تو حضرت ابراہیم علیہ السلام نے سوچا کہ اگر میرا بیٹا ذبح ہوجاتا تو میرا دل رکھتا۔ اس طرح مجھے مصیبتیں برداشت کرنے والے صابرین کا ثواب ملتا، اور اعلیٰ ترین درجات حاصل ہوتے۔ یہ خیال آتے ہی خداوند قدیر نے حضرت ابراہیم علیہ السلام سے دریافت کیا: اے ابراہیم علیہ السلام ! تم کو میری مخلوق میں سب سے زیادہ محبوب کون ہے؟ حضرت ابراہیم علیہ السلام نے عرض کی: اے میرے مالک!تو نے اپنی مخلوق میں حضرت محمدمصطفےٰ صلی اللہ علیہ و آلہ وسلم سے زیادہ محبوب کسی کو پیدا ہی نہیں کیا(اس لئے مجھے بھی تیری ساری مخلوق میں حضرت محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم سب سے زیادہ محبوب ہیں )خداوند قدیر نے دریافت کیا: اے ابراہیم علیہ السلام !تمہیں محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم زیادہ عزیز ہیں یا تمہاری ذات ؟ عرض کی : وہی زیادہ عزیز ہیں ۔،،پھر دریافت کیا: اے ابراہیم !تم کو تمہاری اولاد زیادہ محبوب ہے یا محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کی اولاد؟،،عرض کی: محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کی اولاد زیادہ محبوب ہے۔،، ارشاد ہوا: اے ابراہیم ! تمہارادل محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کی اولاد کے ذبح ہونے سے زیادہ غمزدہ ہوگا یا تمہارے ہاتھ سے تمہارے بیٹے کے ذبح ہونے پر؟ عرض کی: محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کی اولاد کا ظلم سے ذبح ہونا میرے دل کو زیادہ غمزدہ کردے گا۔،،پھرارشاد ہوا: اے ابراہیم علیہ السلام !ایک گروہ ایسا بھی ہوگا جو خود کو امت محمد صلی اللہ علیہ و آلہ وسلم سمجھے گا مگر محمد صلی اللہ علیہ و آلہ وسلم کے بعد ان ہی کے فرزند دلبند حسین علیہ السلام کو اس طرح ذبح کرے گا جس طرح مینڈھے کو ذبح کیا جاتاہے۔ حضرت ابراہیم علیہ السلام یہ بات سن کر سخت مضطرب وپریشان ہوئے، ضبط غم نہ ہوسکا ان کے دل میں ایک سخت درد اٹھا اور وہ بے قابو ہوکر دہاڑیں مارمار کررونے لگے۔خداوند کریم ورحیم نے فرمایا: چونکہ تم نے اپنے بیٹے پر محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم کی فرزند کو ترجیح دی ہے اس لیے ہم نے تمہارے لیے اپنے اوپر وہی اعلیٰ درجات کے ثواب کو عطا کرنا واجب قراردیا جو مصائب برداشت کرنے والوں کو ملتے ہیں ۔پھر امام علیہ السلام نے فرمایا: بس یہی مطلب ہے اللہ کےاس قول کا کہ : وفدینہٰ بذبح عظیم ،،&&(تفسیر صافی، عیون الاخبار الرضا علیہ السلام ، تفسیر نورالثقلین ، تفسیر انوار النجف)&&}}سوال :اب سوال یہ پیدا ہوتا ہے کہ امام حسین علیہ السلام حضرت اسماعیل علیہ السلام کا فدیہ قرار پائےـ؟ ،، جواب :یہ ہے کہ یہاں ’’بذبح،،میں ’’ب،،صلہ کی نہیں ہے بلکہ سببیہ ہے یعنی ایک عظیم فرمانی کے سبب سے ہم نے اسماعیل علیہ السلام کو بچالیا، ۔،، کیونکہ حضرت اسماعیل علیہ السلام کی نسل ہے ہی یہ قربانی ہونے والی تھی، جو مثالی فربانی ہوگی۔اس لیے اس عظیم قربانی کے سبب سے ہم نے اسماعیل کےلیے دنبہ کا فدیہ بھیج دیا۔ &&(فصل الخطاب)&&[[اللہ اللہ بائے بسم اللہ پدر، معنی ذبح عظیم آمد پسر]]&&(اقبال)&&
  37,112,آیت نمبر۱۱۲:ذبیح اللہ کے واقعہ کے بعد حضرت اسحاق کی بشارت اس امر کی دلیل ہے کہ پہلی بشارت حضرت اسماعیل علیہ السلام کی تھی۔{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: اے بنی ہاشم ! کہیں ایسا نہ ہو کہ قیامت کے روز باقی لوگ تو میرے پاس اپنے نیک اعمال کے ساتھ آئیں اور تم اپنے نسب ، خاندان اور رشتہ داری کا تعلق جتاتے ہوئے آئو۔،، &&(تفسیر روح البیان ، تفسیر نمونہ)&&}}{{جناب امیرالمومنین علیہ السلام نے فرمایا: جسے عمل پیچھے چھوڑ دے اسے نسب آگے نہیں بڑھ سکتا۔ ،، &&(نہج البلاغہ کلمات قصار)&&}}
  37,123,آیت نمبر۱۲۳:حضرت الیاس کا ذکر:حضرت الیاس علیہ السلام ایک مشہور اسرائیلی نبی گذرے ہیں ۔ توراۃ میں ان کا نام ’’ ایلیا،، ہے۔ ان کا زمانہ ۸۷۶۔ ۸۵۴قبل مسیح علیہ السلام ہے، توراۃ میں ان کے کرامات اور معجزات کا ذکر کتاب سلاطین میں آیا ہے۔ یہودیوں کا عقیدہ ہے کہ ان کو حضرت ادریس علیہ السلام کی طرح آسمان پر زندہ اٹھالیا گیا۔&&(تفسیر ماجدی)&&حضرت الیاس علیہ السلام نے شہر بعلبک میں تبلیغ کی لکھا ہے کہ بعلبک میں بعل نامی ایک بت تھا جس کی لمبائی بیس ہاتھ کے برابر تھی (تقریبا دس گز) جو پورے کا پورا سونے کا بناہوا تھا۔ کیوں کہ اس بت کانام بعل تھا، اور ’’بک ،، معنی ’’شہر،،کے تھے ، اس لئے اس شہر کانام بعلبک ہوگیا۔&&(تفسیر روح المعانی)&&آج یہ شہر لبنان کا حصہ ہے اور شام کی سرحد پرواقع ہے۔ &&(تفسیر نمونہ)&& کتاب،،بحرالمصائب،، اور سرورالمومنین ،، میں ہے کہ ،، جب چند منازل طے کرتے ہوئے (کربلاء کالٹا ہوا قافلہ) اہل بیت علیہئ السلام طاہرین بعلبک پہنچے اور اس شہر کے لوگوں نے اظہار مسرت اور شادمانی کیا تو جناب زینب علیہ السلام اور جناب ام کلثوم علیہ السلام نےان لوگوں پر نفریں کی ۔،، &&(مظلومہ کربلاء ص۱۷۴)&&!!حضرت الیاس علیہ السلام کے بارے میں بیشمار داستانیں گھڑی گئی ہیں جو کتابوں میں ہیں مگر قابل اعتماد نہیں ۔&&(تفسیر مجمع البیان ، تفسیر المیزان، روح المعانی، تفسیر کبیر، تفسیر فی طلال ، اعلام القرآن ، نمونہ)&&منقول ہے کہ حضرت الیاس علیہ السلام حضرت ہارون ابن عمران علیہ السلام کی اولاد سے تھے اور الیسع علیہ السلام پیغمبر کے چچا زاد بھائی تھے۔ جب بنی اسرائیل میں گمراہی اور سرکشی حد سے بڑھی تو خداوند کریم نے پہلے حضرت حزقیل علیہ السلام کو بھیجا ، ان کے بعد حضرت الیاس علیہ السلام معبوث ہوئے۔ حضرت یوشع علیہ السلام نے شام کو فتح کیا تو شام کے علاقے کو نبی اسرائیل کے قبائل میں تقسیم کردیا۔ جو قبیلہ میں آباد ہواتھا حضرت الیاس علیہ السلام ان کی طرف بھیجے گئے تھے۔ &&(تفسیر انوار النجف)&&
  37,124,آیت نمبر۱۲۴:حضرت الیاس علیہ السلام ، نبی اسرائیل کے انبیاء میں سے تھے۔ ان کا زمانہ ۸۷۵؁ سے ۸۵۰ قبل مسیح تھا اس زمانے میں فلسطین میں بنی اسرائیل کے نام سے حکومت قائم ہوچکی تھی۔ اور سامریہ اس کا صدر مقام تھا۔ ملک میں شرک ، بت پرستی ظلم وجور اور فسق وفجور کا بازار گرم تھا۔ اسی عام بنی اسرائیل کے بادشاہ اخی اب ahabنے لبنان کے بادشاہ کی لڑکی ایزیل سے شادی رچالی، وہ مشرکہ تھی جس کی محبت میں یہ بادشاہ بھی مشرک ہوگیا۔ اس نے سامریہ بعل کا مندراور مذبح تعمیر کیا۔ خدائے واحد کی عبادت کی بجائے بعل کی عبادت رائج کردی۔ اسرائیلی شہروں میں علانیہ بعل بت کے نام کی قربانیاں کی جانے لگیں ایسے ماحول میں حضرت الیاس علیہ السلام نمودار ہوئے اور بادشاہ کو خبردار کیا کہ تیرے ظلم اور شرک کی وجہ سے اب اسرائیل پر بارش کا ایک قطرہ بھی نہ برسے گا جب ساڑھے تین سال تک بارش نہ ہوئی تو اخی بادشاہ کے ہوش ٹھکانے آگئے اور اس نے حضرت الیاس علیہ السلام کو بلوایا اور ان سے بارش کی دعا کی درخواست کی، اور شرک سے توبہ کی ۔ حضرت الیاس علیہ السلام نے کہا کہ بعل کے پجاری بعل کے نام پر قربانی پیش کریں ، اور میں اللہ العالمین کےلیے قربانی پیش کروں گا، دونوں میں سے جس کی قربانی بغیر کسی انسان کے آگے لگائے ازخود بھسم ہوجائے گی اسی کا معبود سچا خدامانا جائے گا۔ کوہ کارمل پر بعل کے ساڑھے آٹھ پجاری (گرو) جمع ہوئے اور سارے شہر کے لوگوں کے سامنے حضرت الیاس علیہ السلام کی قربانی ازخود بھسم ہوگئی ۔ اس طرح حضرت الیاس علیہ السلام نے ڈنکے کی چوٹ پر ثابت کردیا کہ بعل جھوٹا خدا ہے، اصل خداوہی اکیلااللہ ہے۔ اس کے بعد حضرت الیاس علیہ السلام نے مجمع عام میں بعل کے پجاریوں کو قتل کرادیا اور پھر بارش کےلئے دعا کی جو قبول ہوئی۔ مگر کچھ ہی عرصے بعد بادشاہ پراس کی مشرکہ بیوی کا قبضہ ہوگیا۔ ملکہ نے حضرت الیاس علیہ السلام کو قتل کرانے کی کوشش شروع کردی ۔ حضرت الیاس علیہ السلام نے مجبورا ملک کو چھوڑکر کوہ سینا کے دامن میں پناہ لی اور خدا سے دعامانگی ۔ پر وردگار !نبی اسرائیل نے تیرے عہدے کو توڑا اور تیرے بندوں کو قتل کیا اب میں اکیلا بچا ہوں ۔ ،، &&(بائیبل ،سلاطین،باب،۱۷،۱۸،۱۹،۲۱،۱،۱تواریخ باب۲۱)&&ایک مرتبہ آنحضرت صلی اللہ علیہ و آلہ وسلم پہاڑ پر تشریف لے گئے تو پہاڑ کی چوٹی پرایک شخص کو دیکھا جو یہ دعامانگ رہا تھا کہ :اے اللہ !مجھے امت مرحومہ مغفورہ میں داخل فرما۔ جب حضوراکرم صلی اللہ علیہ و آلہ وسلم اس بزرگ کے پاس پہنچے تو وہ آپ صلی اللہ علیہ و آلہ وسلم کو دیکھ کر کھڑا ہوگیا بغلگیر ہو اور عرض کہ : میں سال بھرمیں صرف ایک دفعہ کھانا کھانا ہوں اور ابھی میرے کھانے کا وقت ہے ۔ چنانچہ اچانک آسمان سے ایک دستر خوان اترا اور حضوراکرم صلی اللہ علیہ و آلہ وسلم اس شخص کے ساتھ کھانا تناول فرمایا: معلوم ہوا کہ وہ حضرت الیاس علیہ السلام پیغمبر تھے۔ &&(تفسیر انوار النجف)&&
  37,130,آیت ۱۳۰ کی تشریح: آل یاسین سے :مراد حضرت الیاس علیہ السلام پیغمبر بھی ہیں اور آل محمد علیہ السلام بھی ہیں کیوں کہ یاسین سے مراد حضرت محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم ہیں ۔ کیوں کہ یاسین محمد علیہ السلام ہیں ، اس لیے یاسین ، آل یاسین یعنی آل محمد مراد ہیں ۔ &&(معانی الاخبار شیخ صدوق، تفسیر صافی، تفسیر قمی، تفسیر انوار النجف)&&{{جناب امیرالمومنین علیہ السلام فرمایا کرتے تھے: یاسین محمد مصطفےٰ صلی اللہ علیہ و آلہ وسلم ہیں ۔ اور آل یاسین ہم (ائمہ اہل بیت علیہم السلام)ہیں ۔&&(تفسیر نورالثقلین)&&}}{{حضرت ابن عباس ؓنے فرمایا: آل یاسین سے مراد آل محمد علیہم السلام ہیں کیوں کہ یاسین محمد صلی اللہ علیہ وآلہ وسلم کے اسماء میں سے ایک اسم ہے۔ &&(الجوامع)&&}}!!عام تفاسیر اہل سنت کے اعتبار سے آل یاسین حضرت الیاس علیہ السلام ہی کانام ہے جیسے ابراہیم علیہ السلام کا دوسرانام ابراھام تھا۔ &&(تفسیر کبیر)&&
  37,137,آیت ۱۳۷۔ ۱۳۸ کی تشریح:قوم لوط کی بستیاں الٹی ہوئی نظرآتی تھیں شام کی راہ میں ۔ &&(موضح القرآن)&&{{جناب امیرالمومنین علیہ السلام نے فرمایا: سبق حاصل کرنے کے مواقع تو بہت ہیں ، مگر سبق حاصل کرنے والے کتنے کم ہیں۔،، &&(نہج البلاغہ کلمات قصار ۲۹۷)&&}}{{ حضرت امام جعفر صادق علیہ السلام نے فرمایا: جب تم قرآن کی آیتیں پڑھتے ہوتو اصل میں تم ان آثار کے پاس سے گذرتے ہو۔،، (گویا تم ان آثارقوم اور بربادی کو اپنی آنکھوں سے دیکھ رہے ہو۔ اس طرح قرآن پڑھنا چاہیے) && ( تفسیر نورالثقلین جلد۴، روضۃ الکافی)&&}}!!حضرت یونس کا قصہ:حضرت یونس علیہ السلام پیغمبر نے اپنی قوم سے تنگ آکر بد دعا کی اور اپنی قوم کو خدا کے حکم سے عذاب کے آنے کی خبرسنائی۔ مگر خداسے اجازت لیے بغیر شہر چھوڑکر چلے گئے۔ وہ یہ سمجھے کہ جب خدانے اپنے عذاب بھیجنے کی خبردے دی تواب میرااس شہر میں رکنے کا کیا جواز ہے۔ عذاب الہٰی سے بچنے کےلیے شہر سے چلے گئے۔ حالانکہ ان کو شہر چھوڑنے کی الگ سے اجازت لینی چاہیے تھی۔ یہی ان کا ترک اولیٰ تھا۔ (اصل میں حضرت یونس علیہ السلام نے اپنی قوم کو ان کی بدکرداری کی وجہ سے خدا کے عذاب خبردی کہ بدھ کے دن عذاب آئے گا۔ اور خود وہاں سے چلے گئے۔ جب وہ عذاب کا وقت گذرگیا تب بستی میں واپس آئے تو دیکھا کہ سب لوگ ہنسی خوشی سے چل پھررہے ہیں ، عذاب آنے کے آثار نہ دیکھے بس اس شرمندگی کی وجہ سے کہ لوگ ان کی جھوٹا تصور کریں گے اور مذاق اڑائیں گے، وہ اس بستی سے واپس دریا کی طرف چلے گئے۔ روایت میں یہ بھی ہے کہ شہر کے ایک عابد نے حضرت یونس علیہ السلام کوخداسے اجازت لیے بغیر شہر کو چھوڑنے سے روکا تھامگر انہوں نے اجازت لینے کی ضرورت نہ سمجھا۔غرض جب حضرت یونس علیہ السلام نے شہر چھوڑدیا تو ایک عالم نے (جس کانام تنوخاتھا۔) قوم کو سمجھایا کہ کمبختو! خدا عذاب بس آیا ہی چاہتا ہے جو تمہارا تیاپا بچا کرکے رکھ دے گا۔ عذاب کے ابتدائی آثار دیکھ کر قوم نے اس عالم سے پوچھا کہ اب ہم کیا کریں ؟ عالم نے کہا کہ ساری قوم مل کر خدا سےاپنی خطائوں اور بدکاریوں کی معافی مانگے۔ قوم نے اس کے کہنے پر سچے دل سے معافیاں مانگیں ، تو خدانے عذاب کو ٹال دیا۔ ادھر حضرت یونس علیہ السلام دریا پر پہنچے اور کشتی پر سوار ہوگئے۔ &&(قصص الانبیاء تفسیر کبیر، حیات القلوب)&&کشتی طوفان میں گھرگئی، تنگ آکرکشتی والوں نے قرعہ ڈالا کہ کس کے گناہوں کی وجہ سے طوفان نے گھیررکھا ہے جب بھی قرعہ ڈالا گیا حضرت یونس علیہ السلام ہی کانام نکلا۔ &&(فصل الخطاب ، تفسیر تبیان)&&منقول ہے کہ جب کشتی دریا میں پہنچی تو ایک بڑی مچھلی نے سرنکالا۔ حضرت یونس علیہ السلام کشتی کے کنارے پر تھے ڈرکر دوسری طرف چلے گئے ۔ مچھلی اسی طرف آگئی ۔ ملاحوں نے کہا کہ ہم میں سے کوئی آدمی اپنے آقا سے بھاگا جارہا ہے جب تک اس کو دریا میں نہ ڈالا جائے گا یہ مچھلی پیچھا نہ چھوڑے گی۔ جب قرعہ اندازی کی گئی تو حضرت یونس علیہ السلام کانام، نکلا پس آپ علیہ السلام نے دریا میں چھلانگ لگادی اور مچھلی نے ان کو نگل لیا۔ {{حضرت امام محمد باقر  علیہ السلام نے فرمایا کہ حضرت یونس علیہ السلام مچھلی کے شکم میں ایک ہفتہ رہے۔ اور بحرقلزم ، بحرمصر اور بحرطبرستان کی سیر کرانے کے بعد دریائے دجلہ کے کنارے پر ان کو اگل دیا۔ وہاں بحکم خدا کدو کا پودا اُگا۔ ایک ہفتہ اس کے سائے میں رہے۔ &&(نورالثقلین ، انوار النجف)&&}}
  37,143,آیت نمبر۱۴۳:{{جناب امیرالمومنین علیہ السلام نے فرمایا: مچھلی حضرت یونس علیہ السلام کولے کر زمین کے نیچے ایسی جگہ سے گذری جہاں قارون زمین دوز ہو کر عذاب میں مبتلا تھا۔ اس نے حضرت یونس علیہ السلام کی تسبیح <<(لاالہ الا انت سبحنک انی کنت من الظلمین)>>کی آواز سن کر اپنے اوپر موکل فرشتے سے کچھ مہلت مانگی، جو اسے بحکم پروردگار روزانہ قد آدم کے برابر زمین کے نیچے کی طرف دھکیلتا جارہا تھا۔ پس فرشتے نے اسےمہلت دی تو قارون نے حضرت یونس علیہ السلام سے پوچھا کون ہو؟ آپ نے فرمایا: بس یونس ۔۔۔ قارون نے حضرت موسیٰ علیہ السلام وہارون اور کلثوم (جواس کی طرف منسوب تھی) کے متعلق دریافت کیا؟ انہوں نے جواب دیا: وہ سب مرچکے ہیں ۔،، ان کے ارمان میں قارون نے ایک آپ سرد آہ کھینچی ۔بہرکیف مچھلی نے دریا کے کنارے پر حضرت یونس علیہ السلام کو اگل دیا۔ چونکہ آپ علیہ السلام کی کھال اور گوشت خراب ہوچکاتھا، تواللہ تعالیٰ نے ان کےلیے کدو کی بیلدار پودا اگادیا جس کے سائے میں آپ علیہ السلام دھوپ کی تکلیف سے محفوظ رہے۔ جب آپ علیہ السلام بالکل صحتمند ہوگئے تو کدو کی بیل خشک ہوگئی۔ حضرت یونس علیہ السلام اس پر زنجیدہ ہوئے پس وحی ہوئی کہ اس پودے پرتم نے کوئی محنت نہ کی تھی اور اس کے خشک ہونے پر رنجیدہ ہورہے ہومگرایک لاکھ سے زیادہ آدمیوں پر عذاب کی بددعا کرنے پر غمزدہ کیوں نہ ہوئے ۔ اب وہ سب مومن ہوچکے ہیں ، لہٰذا اپنی قوم میں واپس جاکر ان کو احکام دین سکھائو۔ اس حکم پر آپ علیہ السلام وہاں سے چل دیے راہ میں ایک چروا ہا ملا اس سے آپ علیہ السلام نے کہا کہ جاکر میری قوم کو اطلاع دو۔ وہ بولا، آپ کون ہیں ،، یونس بن متی ہوں ۔،، وہ بولا کہ: وہ تو دریا میں غرق ہوگئے ہیں ۔ فرمایا: اگر تمہارے ریوڑ کی بکری میرے حق میں گواہی دے ، تب تو تم مان لوگے؟ غرض بکری نے گواہی دی۔ چرواہے نے گواہی پر یقین کیا اور بستی میں جاکر قوم کو حضرت یونس علیہ السلام کی واپس کی اطلاع دی۔ پس وہ لوگ آپ علیہ السلام کی خدمت میں حاضر ہوئے اور نہایت عزت واحترام سے آپ علیہ السلام کو اپنی بستی میں لے گئے۔ &&(تفسیر انوار النجف)&&ایک شخص نے جناب رسول خدا صلی اللہ علیہ و آلہ وسلم سے دریافت کیا: کیا آپ صلی اللہ علیہ و آلہ وسلم کدو کو پسند فرماتے ہیں ۔،، ؟آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’ہاں ،،کیوں کہ یہ میرے بھائی یونس علیہ السلام کی سبزی ہے۔ (اس لیے میں بھی اسے پسند کرتا ہوں )&&(تفسیر روح البیان جلد۷)&&
  37,147,آیت نمبر۱۴۷:{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: حضرت یونس علیہ السلام بن متی تیس سال کی عمر میں معبوث برسالت ہوئے ۔ ۳۳سال مسلسل تبلیغ کرتے رہے، صرف ۲ آدمی ایمان لائے۔ حالانکہ وہ لوگ ایک لاکھ سے زیادہ تھے۔ موصل کے علاقے نینوا میں رہتے تھے۔ ایمان لانے والوں میں ایک عالم جس کا نام تنوخا تھا، اور دوسرا عابد جس کا نام روبیل تھا۔ آخر کارتنگ آکرعابد کے مشورہ پر بددعا کی ، مگر عالم کے روکنے کے باوجود خدا کے عذاب بھیجنے کے وعدے کوسن کو شہر سے نکل پڑے وہ عابد آپ علیہ السلام کے ساتھ لیکن عذاب کے آثار جب نمودار ہوئے تو عالم نے پوری قوم کو جمع کرکے توبہ کی طرف رغبت دلائی۔ سب نے مل کرتوبہ کرلی۔ عذاب ٹل گیا اور جب حضرت یونس جائز لینے کے بعد واپس آئے توشہر میں حسب سابق چہل پہل دیکھی توکسی سے عذاب کے بارے میں دریافت کرنے پر معلوم ہواکہ عذاب آچکاتھا لیکن لوگوں نے توبہ کرلی، عذاب ٹل گیا۔ اب لوگ یونس علیہ السلام کی تلاش میں ہیں تاکہ ان سے معافی مانگیں ، یہ سن کر آپ علیہ السلام دریا کی طرف چلے گئے کشتی پر سوار ہوئے۔ ایک مچھلی نے سرنکال کر منھ کھولا تو یونس علیہ السلام ڈرکر کشتی کے دوسرے کنارے پر چلے گئے۔ مچھلی بھی اس طرف آگئی۔ ملاح بولے کہ ہم میں سے آدمی اپنے آقا سے بھاگ رہا ہے۔ جب تک اس کو دریا میں نہ ڈال دیاجائے یہ مچھلی نہ چھوڑے گی، چنانچہ ڈالا یونس علیہ السلام کا نام نکلا آپ علیہ السلام دریا میں کودگئے اور مچھلی نےان کو نگل لیا۔ &&(تفسیر عیاشی، انوار النجف)&&}}
  37,148,آیت ۱۴۸کی تشریح:مشہور مفسر قتادہ فرماتے ہیں کہ : کوئی بستی ایسی نہیں گذری جس پر اس کے بسنے والوں کے کفر کی وجہ سے عذاب آجانے کے بعد لوگ ایمان لے آئے ہوں اور انہوں چھوڑدیا گیا ہو۔ یہ بات صرف حضرت یونس علیہ السلام کی قوم کے ساتھ ہوئی ، کیوں کہ انہوں نے عذاب کے ابتدائی آثار کو دیکھ کرتوبہ کی ٹھان لی۔ &&(ابن کثیر جلد ۲)&&حضرت یونس علیہ السلام موصل کے علاقے نینوا کے لوگوں کی طرف بھیجے گئے تھے۔ یہ کافر ومشرک لوگ تھے۔ اس لیے انہوں نے حضرت یونس علیہ السلام کو جھٹلایا مسلسل نہ ماننے پر بددعا کی ۔ خدا کے بتانے پر حضرت یونس علیہ السلام نے قوم سے کہا کہ آج سے تیسرے دن تم پر خدا کا عذاب آئے گا۔ اور پھر تیسرا دن آنے سے پہلے خدا سے اجازت لیے بغیر آدھی رات کو بستی سے نکل گئے۔ حضرت یونس علیہ السلام کا قوم سے ناراض ہوکر نکل جانا حرام کام نہ تھا، مگر انہیں اس کا حکم نہ دیا گیا تھا۔ (اس لیے وہ ترک اولیٰ ہوا، گناہ ہوا) اب رہا یہ سوال کہ: پھر حضرت یونس علیہ السلام نے خود کو<<’’ انی کنت من الظلمین ،،>> یعنی میں ظالموں میں سے تھا۔،، کیوں کہا۔؟اس کا مطلب یہ ہوا کہ میری خطا (ترک اولیٰ) یہ تھی کہ میں اجازت یاحکم کے آنے سے پہلے ہی ہجرت کرنے میں جلدی کر بیٹھا۔ اس طرح انہوں نے اپنے گناہ &&(ترک اولیٰ)&& سے توبہ فرمائی۔ &&(روح المعانی جلد ۱۷، از مفسرآلوسی)&&اشرف علی تھانوی صاحب نے لکھا: حضرت یونس علیہ السلام نے شہر سے سفر کرنے کے لیے خدا حکم انتظار نہ کیا۔،، &&(مرشدی)&&
  37,158,آیت۱۵۸: <<وجعلوا بینہ>>:اس کی تفسیر میں چند اقوال ہیں :(۱) زندیق اور بے دین لوگوں نے کہا تھا کہ ،، اللہ اور شیطان (جوقوم جن سے ہے) دونوں بھائی ہیں ۔ نور ، خیراور نفع مند چیزوں کاخالق اللہ ہے۔ اور ظلمت، شر اور نقصان دہ چیزوں کا خالق شیطان ہے۔ (۲) مشرکین مکہ نے چونکہ فرشتوں کو اللہ کی بیٹیاں تجویز کیا تھا پس فرشتوں کو آنکھوں سے اوجھل ہونے کی بناء پر جن کہا گیا ہے۔ اور جن کے اصل معنی ہیں ۔،، نظر نہ آنے والی چیز۔(۳) جن لوگوں نے شیطان کی اطاعت کی گویا انہوں نے شیطان کو اللہ کے برابر سمجھ لیا اور اللہ اور شیطان کے درمیان معبود ہونے کا رشتہ بنالیا۔ بہرحال جو قول بھی ہوخدا نے اس کی پر زور تردید فرمائی ہے اور ساتھ ہی تنبیہ کی ہے کہ جن چیزوں کو تم اللہ کا رشتہ دار سمجھتے ہو خواہ فرشتے ہوں یا جن سب ہی میرے سامنے حاضر کیے جائیں گے۔ &&(تفسیر انوار النجف)&& مخلصین کا طریقہ حمدوتسبیح:{{جناب امیر المومنین حضرت امام علی ابن ابی طالب علیہ السلام نے اللہ کی حمد ان الفاظ میں فرمائی: اللہ تعالیٰ نے نہ تو عقلوں کو اپنی حقیقت سے آگاہ فرمایا ، اور نہ ان کو اپنی معرفت سے بازرکھا۔ اللہ ان لوگوں کی باتوں سے بلند وبرتر ہے جواسے مخلوقات کے ساتھ تشبیہ دیتے ہیں یا اللہ کا انکار کرتے ہیں ۔ بلند فکر کریں تک اللہ کے دامن کبریائی تک نہیں پہنچ سکتیں ۔اللہ کو حدوں میں محدود نہیں کیا جاسکتا، کوئی صاحب عقل اپنے خیالات میں اللہ کی تصویر کشی نہیں کرسکتا۔ حواس اللہ کے ادراک سے عاجز ہیں ۔ تغیروتبدل اللہ کے لیے نہیں (وہ ان کا خالق ہے) زمانہ گذرنے سے اس کے وجود میں کوئی تبدیلی واقع نہیں ہوتی۔ اللہ کی توصیف نہ تو اعضاء وجوارح کے ذریعہ ہوسکتی ہے اور نہ عوارض کے ساتھ۔ اللہ کے لیے نہ کوئی حدبندی ممکن ہے اور نہ کوئی انقطاع یا انتہاء۔ اگر کوئی شخص یہ کہے کہ اللہ کہاں ہے؟ تو گویااس نے کسی شے کا تصور کیا (جوباطل ہے کیونکہ اللہ کوئی شئے نہیں ) اب اگر کوئی یہ پوچھے کہ اللہ کس شئے پر ہے؟تو گویا اس نے کسی جگہ کو اللہ سے خالی سمجھا (یہ بھی غلط ہے) اللہ ہر چیز کے ساتھ ہے لیکن اس کا ساتھی ہوکر نہیں ۔ اللہ ہرچیز سےالگ ہے، مگر اس سے جدا ہوکر نہیں ۔۔۔الخ &&(از نہج البلاغہ خطبہ، ۱۸۶)&&{{ فرزند رسول اللہ حضرت امام علی ابن الحسین علیہ السلام (زین العابدین) علیہ السلام ،، نے فرمایا: ’’ حمد مخصوص اللہ کےلیے ہے جس نے ہر چیز کو پیدا کیا بغیر اس کے کہ خود اس کی کوئی ابتداء ہو یا وہ وجود میں آخری ہو۔ کوئی موجود اللہ سے پہلے نہیں ۔ وہ ایسی عظیم ذات یا ہستی ہے کہ دیکھنے والوں کی نگاہیں اسے دیکھنے سے قاصرہیں ، اور توصیف کرنے والوں کی عقلیں اس کی (حقیقی) تعریف وحمد کرنے سے عاجز ہیں ۔ &&(صحیفہ ،سجادیہ پہلی دعا)&&}}یہ ہے مخلصین کا طریقہ حمدوتسبیح الہٰی &&(موئف)&&( سبحان اللہ)
  37,162,آیت۱۶۲ کا دوسرا مطلب (ترجمہ) یہ ہے کہ؛ @@پس تم اور تمہاری یہ عبادت ، اس پر تم کسی کو فتنے میں نہیں ڈال سکتے مگر صرف اس کو جو دوزخ کی بھڑکتی آگ میں جھلسنے والا ہو۔ ،،@@ جب اس طرح ترجمہ کیا جائے گا تو مطلب یہ ہوگا کہ: فرشتے اپنے پجاریوں سے کہہ رہے ہیں کہ : اے احمقو! تم جوہماری پوجا وپاٹ کررہے ہواور ہمیں اللہ رب العالمین کی اولاد قراردے رہے ہو، اس سے تم ہمیں فتنے میں نہیں ڈال سکتے۔ اس سے تو کوئی ایسا احمق ہی فتنے میں پڑسکتا ہے جس کی شامت سر پر آچکی ہو۔ &&(تفہیم القرآن ، تفسیر کبیر)&&
  37,164,آیت ۱۶۴کی تشریح:مطلب یہ ہے کہ فرشتے کہہ رہے ہیں کہ @@’’ اے احمقو! تم ہمیں اللہ کی بیٹیاں بک رہے ہو جبکہ اللہ کی اولاد ہونا تو درکنار، ہم نے خدا نے جس کا جودرجہ مقرر کردیا ہے ، ہم ذرہ برابر اس سے آگے بڑھنے کا تصور تک نہیں کرسکتے ۔ @@&&(تفسیر کبیر)&&بعض روایات سے ، جو ائمہ اہل بیت علیہم السلام سے مروی ہیں ، ان سے مراد ائمہ اہل  بیت علیہم السلام بھی ہیں ۔ممکن ہے یہ تفسیر اس لیے کی گئی ہو کہ ائمہ اہل  بیت علیہم السلام فرشتوں کی طرح معصوم اور نورانی ہستیال ہیں ۔ فرشتوں کی طرح ائمہ معصومین علیہم السلام بھی اپنی اپنی الگ الگ ذمہ داریاں اور فرائض رکھتے ہیں ۔ &&(تفسیر نمونہ)&&<<’’ ومامنا،،الخ۔>> یہ ملائکہ کا قول ہے یا یہ کہ جبریل علیہ السلام نے حضور صلی اللہ علیہ و آلہ وسلم اکرم کو خبردی کہ ہم میں سے ہرایک کا مقام معین اور معلوم ہے کہ اس سے ہم تجاوز نہیں کرسکتے ۔&&( انوار النجف)&&{{اور تفسیر برہان،،میں فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام سے مروی ہے کہ یہ آیات آل محمد علیہم السلام کے اوصیاء اور ائمہ معصومین علیہم السلام کے متعلق ہیں ۔ چنانچہ آپ علیہ السلام نے اس حدیث کے راوی شہاب سے فرمایا: <<’’یاشہاب نحن شجرۃ النبوۃ ومعدن الرسالۃ ومختلف الملائکۃ ونحن عہداللہ وذمتہ ونحن دائع اللہ وحجۃ کنا انوارا اصفوفا حول العرش نسبح اللہ فسبح الملائکۃ بتسبیحنا الیٰ ان ھبطناالیٰ الارض فسبحناوسبح اہل الارض ۔۔ ۔الخ>>۔ترجمہ: اے شہاب! ہم نبوت کا شجر ، رسالت کی کان اور فرشتوں کی آماجگاہ (ٹھہرنے اور اترنے کی جگہ ) ہیں ۔ ہم اللہ کا عہدوذمہ ہیں اور ہم اللہ کی امانت وحجت ہیں ۔ ہم حالت انوار میں عرش الہٰی کے چاروں طرف صف بستہ حالت میں اللہ کی تسبیح کرتے تھے پس ہماری تسبیح کوسن کر فرشتوں نے بھی تسبیح کی۔ پھر جب ہم عالم انوار سے زمین کی طرف بھیجے گئے تو ہم نے زمین پر بھی اللہ کی تسبیح پڑھی، اور اہل زمین نے بھی ہم ہی سے تسبیح وعبادت سیکھی ۔پس &&(اے شہاب!)&& ہم ہی صف بستہ عبادت کرنے والے ہیں ۔ اور ہم ہی اللہ کی تسبیح وپاکی بیان کرنے والے ہیں ۔ ،، اس کے بعد آپ علیہ السلام نے فرمایا: جس نے ہمارے ساتھ وفا کی تواس نے اللہ سے کیے ہوئے عہد کی وفا کی۔ اور جس نے ہمارے ساتھ وفا نہ کی ، اس نے اللہ کے ساتھ کیے ہوئے عہد اور ذمہ کر ٹھکرادیا۔ ،،پس اگر ان آیات کو مقولہ فرشتوں کا قراردیاجائے ظاہری طورپر، توان کا باطن ائمہ طاہرین  علیہم السلام   کی ذوات مقدسہ کے علاوہ اور کوئی نہیں ہوسکتا ۔ &&(تفسیر انوارا لنجف بحوالہ تفسیر برہان )&&}}{{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: تمام آسمانوں میں ایک بالشت بھرجگہ بھی ایسی نہیں ہے جہاں کوئی نہ کوئی فرشتہ خداوند عالم کی نماز یا تسبیح میں مصروف نہ ہو۔ ،، &&(تفسیر قرطبی جلد۸، تفسیر درمنثور، تفسیر المیزان جلد۱۷،)&& }}{{فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السلام نے فرمایا: اللہ تعالیٰ نے ایسے فرشتے بھی پیدا کیے ہیں جن کا آدھا جسم برف کا ہے اور آدھا آگ کا۔ ان کی تسبیح یہ ہے: اے اللہ پاک ! جس نے برف اور آگ میں الفت پیدا کردی تو ہمیں اپنی عبادت اور تسبیح پر قائم رکھ ۔ ،، &&(روح الحیات ص ۸۰)&&}}
  37,173,آیت ۱۷۳کی تشریح:’’ اللہ کی فوج،، سے مراد وہ مومنین ہیں جو اللہ کے رسول صلی اللہ علیہ و آلہ وسلم کی پیروی کریں اور ان کا ساتھ دیں ۔نیزوہ تمام غیبی طاقتیں بھی اللہ کا شکر ہیں جن کے ذریعہ خدا مومنین کی مدد فرماتا ہے ۔ مگر اللہ کی اس امداد اور غلبہ کا مطلب ہر گز یہ نہیں ہواکرتا کہ ہرنبی اور اس کے ماننے والے ہر زمانے میں سیاسی طور پر بھی غالب رہتے ہیں ۔ کیوں کہ سیاسی غلبہ ، کامیابی کی صرف ایک صورت ہے ورنہ اخلاقی غلبہ انبیاء اور سچے مومنین کو ہمیشہ حاصل رہتا ہے ۔تمام گھڑے ہوئے فلسفے کچھ مدت تک زور دکھانے کے بعد اپنی موت آپ مرجاتے ہیں ، مگر جوابدی حقیقتیں ابنیاء کرام علیہم السلام صدیوں سے پیش فرماتے آئے ہیں وہ پہلے بھی اٹل تھیں اور آج بھی اٹل ہیں ، اور ہمیشہ اسی طرح اٹل رہنے والی ہیں ۔ &&(تفسیر کبیر، تفسیر مجمع البیان، تفہیم القرآن)&&[[حقیقت ابدی ہے مقام شبیری ،بدلتے رہتے ہیں انداز کوئی وشامی]]&&(اقبال)&&
  37,179,آیت ۱۷۹کی تشریح:حضوراکرم صلی اللہ علیہ و آلہ وسلم کو تسلی دی جارہی ہے کہ رسولوں کے ساتھ ہمارا وعدہ ہے کہ آخر کار فتح حق کی ہوگی۔ لہٰذا آپ صلی اللہ علیہ و آلہ وسلم ان کی باتوں سے درگذر کیجئے اور وقت کا انتظار کیجئے، نتیجہ جب سامنے آئے گا تو سب دیکھ لیں گے۔ اور عذاب الہٰی مانگنے والے بھی اپنا اپنا انجام دیکھ لیں گے، اس لیے فی الوقت آپ صلی اللہ علیہ و آلہ وسلم ان لوگوں کی احمقانہ دل شکن باتوں سے درگذر فرماکے منھ موڑلیجئے۔ &&(تفسیر انوارالنجف،مجمع البیان)&&
  37,180,آیت نمبر۱۸۰:{{جناب رسالت مآب صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: جوشخص روزقیامت اپنی میزان کو (نیک اعمال سے) وزنی دیکھنا چاہے تواسے ہر مجلس کے اختتام کلام پر ان تینوں آیات۱۸۰۔۱۸۱۔ ۱۸۲۔کی تلاوت کرنی چاہیے۔ &&(تفسیر انوار النجف علامہ حسین بخش جاڑا)&&}}آیت ۱۸۰ میں تین چیزوں کی معرفت کرائی گئی ہے۔ (۱) خدا ہر عیب سے پاک ہے۔ یہ مفہوم <<سبحٰن >>کے لفظ کے اندر موجود ہے۔ (۲) خدا <<رب>> ہے یعنی سب کا مالک ، سب کا پالنے والا، سب پررحم کرنے والا سب کو فیض ، فائدئے پہنچا کر منزل کمال تک لے جانے والا ۔ (۳) آخرمیں انسان کا سب سے بڑا مسئلہ اس کی نجات اخروی ہے تواس کی طرف رب العالمین کہہ کر اطمینان دلایا، اور والحمدللہ آخر میں فرماکر سکون بخشا۔ &&(تفسیر کبیرامام رازی)&&}}{{جناب امیر المومنین علیہ السلام اور حضرت امام محمد باقر علیہ السلام سے متعدد روایات ہیں کہ: جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا کہ :،، جو شخص یہ چاہتاہے کہ قیامت کے دن اس کو بھرپورا اور کامل ترین پیمانے سے اجردیاجائے تو وہ جس محفل سے اٹھے اس کے آخرمیں یہ تین آیتیں پڑھے: سُبْحٰنَ رَبِّكَ رَبِّ الْعِزَّۃِ عَمَّا يَصِفُوْنَ۱۸۰ۚ وَسَلٰمٌ عَلَي الْمُرْسَلِيْنَ۱۸۱ۚ وَالْحَـمْدُ لِلہِ رَبِّ الْعٰلَمِيْنَ۱۸۲ۧ &&(تفسیر مجمع البیان ، اصول کافی ، من لایحضرۃ الفقیہ ، نورالثقلین جلد۴)&&}}{{کسی نے فرزند رسول اللہ حضرت امام محمد باقر علیہ السلام  سے دریافت کیا کہ: خداوند عالم نے سب سے پہلی کیا چیز پیدا کی تھی؟ کوئی کہتا ہے کہ قدرت کوئی کہتا ہے’’علم،، اور کوئی’’ارواح ،، بتاتا ہے۔ ،، امام علیہ السلام نے فرمایا: کسی نے بھی صحیح نہیں بتایا: اللہ تھا اور کوئی چیز نہ تھی لیکن اس کے باوجود اللہ قادر بھی تھا، عزیز بھی تھا، حالاں کہ ابھی اللہ نے عزت کو اور قدرت ) کو پیدا نہیں کیا تھا۔ ( یعنی وہ اپنی ذات میں بالفعل قدرت بھی رکھتا تھا اور علم بھی جبکہ وہ نہ علم کا محتاج تھا ، نہ قدرت کا ) یہی وہ چیز ہے جسے اللہ نے یوں ارشاد فرمایا؛ <<سُبْحٰنَ رَبِّكَ رَبِّ الْعِزَّۃِ عَمَّا يَصِفُوْنَ۱۸۰ۚ ،، >>یعنی@@ ’’تیرا پالنے والا مالک عزۃ وقدرت کی ان توصیفوں سے پاک ومنزہ ہے جو وہ (مشرکین وغیرہ) بیان کیا کرتے ہیں ۔ @@[[ اے برتر از قیاس گمان وخیال وہم ۔ازہر چہ گفتہ ایم وشنیدیم وخواندہ ایم ]]
