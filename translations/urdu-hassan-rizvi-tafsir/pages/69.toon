  69,1,آیت نمبر۱۔۲: << الحآقّۃ>> سے مراد وہ چیز ہوتی ہے جو ضرور ہوکر رہے۔&&(بیضاوی)&&یہاں مراد حشر و نشر کا ہونا ہے جس دن جزاء ،سزا ملے گی۔ &&(مفردات امام راغب)&&<<الحآقّۃ >> سے مراد وہ وقت ہے جس کا واقع ہونا تحقیق شدہ ہے۔ یعنی : جس کا ہونا لازمی ہے۔ یہ وہ وقت ہوگا ،جب ہر ہر معاملے کی حقیقت پوری پوری طرح کھل جائے گی۔اورجزاء ،سزا جیسے حقیقی دائمی کام واقع ہوں گے ،مگر ہم اس کی حقیقت کو پوری طرح نہیں سمجھ سکتے۔&&(بیضاوی ۔ تفسیر صافی)<<&&الحآقۃ>> کے دوسرے معنی:تفسیر علی ابنِ ابراہیم میں ہے کہ :<< الحآقہ>> <<اَلْحَذَر بِنُزُولِ الْعَذَابِ>> ۔ یعنی : <<الحذر>> یعنی عذاب الٰہی کے اترنے سے ڈرو۔&&(تفسیر علی ابنِ ابراہیم) && ]]حذر اے چیرہ دستاں سخت ہیں قدرت کی تعزیریں[[ ۔&&(اقبال)&& جس طرح قرآن میں فرعون پر عذاب کے بارے میں ارشاد ہوا:<<وَحَاقَ بِاٰلِ فِرْعَوْنَ سُوْۗءُ الْعَذَابِ۴۵@@>>اور آلِ فرعون پر بہت بڑا عذاب نازل ہوا۔یا  بہت بُرے عذاب نے آلِ فرعون کو ہر طرف سے گھیر لیا۔@@(سورہ۴۰ المومن آیت ۴۵ پارہ ۳۴) &&
  69,3,آیت نمبر۳: مطلب یہ ہے کہ تم قیامت جیسی کھڑا کھڑا دینے والی چیز کی حقیقت کا پورا پورا ادراک نہیں کرسکتے۔ وہ کس قدر ہولناک اور اہم چیز ہے جس میں ہماری زندگی کے ابدی ،سرمدی ،دائمی فیصلے ہوں گے۔ ایک گروہ ہمیشہ ہمیشہ کے لیے جنتوں کی طرف جارہا ہوگا،اور دوسرا (باغی و طاغی) گروہ جہنم کی طرف۔&&(تفسیر صافی)&& کلام کے تیور از خود بتارہے ہیں کہ اصل تخاطب اُن لوگوں سے ہے جو قیامت اور آنے والی دوسری زندگی کے منکر ہیں ،اُن سے کہا جارہا ہے کہ تم جس بات کا انکار پر انکار کررہے ہو ، وہ ضرور بالضرور ہوکر رہے گی۔&&(تفہیم)&&کیوں کہ وہی غرضِ تخلیق ہے ۔ اگر جزاء ،سزا نہیں ہے تو پھر یہ ساری تخلیقاتِ عالم بے مقصد،عبث اور بے معنی ہوجاتی ہے اور بے معنی و بے مقصد کام ایسا خالق نہیں کرتا جو حکیمِ مطلق بھی ہو اور ہر عیب سے پاک بھی ہو۔&&(مولف)&&<<مَآ اَدْرٰک>> یعنی : تجھے کیا معلوم ؟ یہ الفاظ وہاں بولے جاتے ہیں جہاں مطلب معلوم ہوتا ہے،اور جہاں مطلب معلوم ہوتا ہے،اور جہاں مطلب معلوم یا مسلّم نہیں ہوتا وہاں << عرب وَمَا یُدْرِیْکَ>>کے الفاظ بولتے ہیں ۔&&(تفسیر مجمع البیان ،قرطبی ،تفسیر کبیر)&&
  69,4,آیت نمبر۴:<<قارعۃ >> کے معنی کھڑکھڑا ،کھڑکھڑا دینے والی چیز ،ہلا ہلا مارنے والی چیز اِس سے مراد ایسی حالت ہے جو بُری طرح ڈرا اور ہلا کر رکھ دے ،اور تمام ستاروں کو توڑ پھوڑ ڈالے ۔ &&(تفسیر صافی)&& <<القارعۃ>> کا لفظ قرع سے نکلا ہے جس کے معنی ٹھوکنا ،کوٹنا ،کھڑ کھڑانا ، ایک چیز کو دوسری چیز پر دے مارنا ہوتے ہیں ۔ قیامت کے دن سیارے سیاروں پر دے مارے جائیں گے اور سخت ہولناک مناظر رونما ہوں گے۔&&(مفردات امام راغب ۔ تفسیر کبیر ۔ تفہیم۔ مجمع البیان) &&!!عاد و ثمود کی قومیں اپنے اپنے زمانے میں عرب کی سب سے بڑی دولتمند اور ترقی یافتہ قومیں تھیں ۔ اُن کا اصل جرم آخرت کو نہ ماننا تھا۔ توحید کے نہ ماننے کے بعد یہ سب سے بڑا جرم ہوتا ہے۔ خداوندِ عالم نے اس جرم میں اُن کا حشر نشر کردیا۔ &&[[مٹے نامیوں کے نشاں کیسے کیسے]]&&(تفسیر ماجدی)&&
  69,7,آیت نمبر۷:<< حُسُوْمًا >> حَسم سے بنا ہے۔ جس کے معنی کسی چیز کو بالکل ختم کردینا ہوتا ہے ۔ مطلب یہ ہے کہ آٹھ دنوں کی سخت آندھی نے اُس عظیم قوم کی با رونق زندگی کو بالکل تباہ و برباد کردیا۔ اُن کی پوری زندگی ،معاشرے اور بستی کے جڑے اُکھاڑ پھینکا۔ [[خس کم جہاں پاک کردیا]]۔ نتیجہ یہ ہوا کہ اگر تم اُن کو دیکھتے تو یہ دیکھتے کہ ساری کی ساری قوم اور ساری بستی منہ بل اوندھی گری پڑی ہے۔ (اور لوگ کھجور کہ کھوکھلے پرانے تنوں کی طرح چت پٹ پڑے ہیں )۔&&(تفسیر نمونہ۔ مفردات امام راغب)&&
  69,8,آیت ۸ میں خداوندِعالم کا پڑھنے والوں سے یہ پوچھنا کہ :  اب کیا تمہیں کوئی باقی بچا نظر آتا ہے؟ یہ سوال کرنا انداز ہے اِس بات کو بتانے کا اُن میں کوئی نہ بچ سکا سب کے سب ڈھیرے ہوگئے۔&&(فصل الخطاب)&& باقی قومیں حضرت نوح علیہ السلام کے ساتھ بچنے والوں کی اولادیں ہیں ۔اِس لیے فرمایا:  ہم نے تم کو کشتی میں سوار کیا۔  مطلب یہ ہے کہ آج تم دنیا میں اسی لیے موجود ہوکہ ہم نے ایمان لانے والوں کو طوفانِ نوح علیہ السلام سے بچالیا تھا۔اِس طرح یہ پیغام دیا کہ: ابدی حقیقتوں اور انبیاء کرام علیہم السلام کو ماننے والے ہی نجات پاسکتے ہیں ہیں ۔&&(تفسیر کبیر ۔ مجمع البیان ۔ تفہیم) &&!!آیت کا حاصل یہ ہے کہ آج نہ تو قومِ عاد کے شہروں کا نام و نشان باقی ہے ،اور نہ اُن کی شاندار عمارتوں کے نشانات باقی ہیں ۔ (آثار قدیمہ والے زمیں کھود کھود کر تلاش کرتے پھرتے ہیں )&&(تفسیر نمونہ)&&
  69,11,آیت نمبر۱۱:شان نزول ! یاد رکھنے والے کان:}}حضرت امام علی ابنِ ابی طالب علیہ السلام سے روایت ہے کہ جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے مجھ سے فرمایا کہ : مجھے اللہ تعالیٰ نے حکم دیا ہے کہ اے علی! میں تمھیں اپنے قریب رکھّوں اور تمھیں اپنے سے دور نہ کروں ،میں تمھیں تعلیم دیتا جاوں گا اور تم اُسے یاد رکھے جاو گے ، اور یہ بات اللہ تعالیٰ کے ذمے ہے کہ تم میری ہر ہر بات یاد رکھو گے۔اِسی پر یہ آیت نازل ہوئی۔&&(تفسیر صافی ۔ تفسیر مجمع البیان) && {{!!{{فرزندِ رسولِ خدا صلی اللہ علیہ و آلہ وسلم حضرت امام ابنِ موسیٰ الرِّضا علیہ السلام سے روایت ہے کہ: جب یہ آیت اُتری تو جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:  اے علی علیہ السلام ! میں نے اللہ تعالیٰ سے یہ دعاء کی تھی کہ وہ تمھارے کان کو یاد رکھنے والا کان قرار دے ۔&&(عیون الخبار الرضا ،الجوامع) && {{پھر }}حضرت امام علی علیہ السلام نے فرمایا:جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم اِس دعاء کے بعد میں نے جو بات بھی سنی پھر کبھی اُسے نہ بھولا۔&&(الکافی ۔ تفسیر قرطبی جلد ۱۰ ص ۴ تا۶ ،مناقب ابنِ مغالی شافعی-مجمع البیان۔ روح البیان -روح المعانی - ابوالفتوح رازی -المیزان) &&{{ جب یہ آیت اُتری تو }}جنابِ رسولِ خداصلی اللہ علیہ و آلہ وسلم نے حضرت امام علی علیہ السلام سے فرمایا:  اے علی! یہ تمہارا کان ہے جس کا ذکر کیاجارہا ہے۔&&(الکافی بروایت امام صادق علیہ السلام){{&&!!عام تفسیر : یعنی یہ وہ کان نہیں ہیں جو سُنی ان سُنی کردیں ۔ مراد ایسے لوگ ہیں جو حقیقتوں ،اور سچائیوں کو کان لگا کرسنتے ہیں ،پھر یاد رکھتے ہیں ۔اِس سے یہ سبق حاص کرتے ہیں اور یہ جانتے ہیں کہ خدا اور رسول صلی اللہ علیہ و آلہ وسلم کی باتوں کو اَن سنی کرنے کا انجام کس قدر ہولناک ہوتا ہے۔&&(تفسیر کبیر ۔ تفہیم)&&
  69,17,آیت نمبر۱۷:عرشِ خدا کو آٹھ فرشتے اُٹھائے ہوئے ہوں گے۔یوں تو حاملانِ عرش چار فرشتے ہیں ۔ مگر قیامت کے دن عرشِ الھٰی اور عدلِ الھٰی کی عظمت ،شان بان دکھانے کے لیے چار فرشتے اور بڑھادئیے جائیں گے۔&&(تفسیر مجمع البیان)&& لیکن }}حضرت ابنِ عباسؓ نے فرمایا کہ: آٹھ فرشتوں سے مراد فرشتوں کی آٹھ صفیں ہیں جوعرشِ الھٰی کو اُٹھائے ہوئے ہوں گے ۔ اُن کی کل تعداد صرف خدا ہی جانتا ہے۔&&(تفسیر ابنِ عباس) &&!!{{بہر حال یہ مسلم ہے کہ عرش پر خداوندِ عالم بیٹھا ہوا نہ ہوگا ،بلکہ عرشِ الھٰی خداوندِ عالم کی خاص تجلیات اور جلال و کمال اور نورِ خاص کاایک مظہر ہے۔ (خاص کر عدلِ الہٰی اور حکومت الہیہ کا)&&(تفسیر مجمع البیان)&&عرشِ الھٰی میں جو وزن ہوگا ،وہ خدا کی ذات کا نہ ہوگا،بلکہ عدل ،نورِ خاص اور ہیبت و حلال الھٰی کی وجہ سے ہوگا۔ کیوں کہ قیامت کے دن خدا وندِ عالم کی شانِ جبروتی کا کامل ظہور ہوگا مگر اس کی حقیقت کو ہم پوری طرح نہیں سمجھ سکتے۔ (اسی چیز کو بعض مفسرین نے خدا کا دیدار قراردیا ہے)&&(تفسیر ماجدی)&& &&(مولف)&& غرض یہ آیت <<متشابہات>> میں سے ہے ،کیوں کہ اِس کے معنی متعین کرنا ناممکن ہے۔ ہم یہ بات پوری طرح نہیں جان سکتے کہ عرشِ الھٰی کیا چیز ہے؟ اور نہ اُس کو فرشتوں کا اٹھانا ہم سمجھ سکتے ہیں ،مگر یہ بات یاد رکھنے کی ہے کہ آیت میں کہیں بھی یہ نہیں بتایا گیا ہے کہ عرش پر اللہ میاں تشریف فرما رہے ہوں گے۔ کیوں کہ خدا کی ذات جسم و جسمانیت ،جہت اور مقام سے ارفع و اعلیٰ ہے۔ اِس لیے ہم بس اِس آیت سے اتنا سمجھ سکتے ہیں کہ ساری حکومت اور اختیارات صرف اور صرف خدا کے ہاتھ میں ہوں گے ۔ اِسی بات کو سمجھانے کے لیے وہی نقشہ پیش کیا گیا ہے جو ہماری دنیا میں بادشاہی کا نقشہ ہوتا ہے۔ اِسی لیے ہمیں سمجھانے کے لیے وہی اصطلاحیں بھی پیش کی گئی ہیں جو ہماری زُبان میں سلطنت کے لیے لازمی ہوتی ہیں ۔ کیوں کہ انسانی اِس قسم کے نقشے اور اصطلاحوں کی مدد سے خدا کی کائنات عالم پر سلطنت کو سمجھانے اور ہمارے ذہن سے قریب تر کرنے کے لیے استعمال کیے گئے ہیں ،اِس کو بالکل عین لفظی معنوں میں لینا ٹھیک نہ ہوگا۔&&(تفسیر کبیر ۔ مجمع البیان ،تفہیم ،انوارالنجف) }} !!&& جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:  اِس وقت چار افراد ہیں جو عرش الھٰی کو اُٹھائے ہوئے ہیں ،قیامت کے دن چار افراد کو اور بڑھادیا جائے گا اور وہ آٹھ ہوجائیں گے۔(تفسیر اہلِ بیت علیہ السلام : &&(تفسیر علی ابنِ ابراہیم جلد۲) &&{{نیز }}آںحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا کہ:  قیامت کے دن عرشِ الھٰی کو اُٹھانے والے چار اولین میں سے ہوں گے ،اور چار آخرین میں ہوں گے۔ اولین میں نوح علیہ السلام ،ابراہیم علیہ السلام ،موسٰی علیہ السلام اور عیسٰی علیہ السلام ہوں گے،اور آخرین میں سے محّمدصلی اللہ علیہ و آلہ وسلم ،علی علیہ السلام ،حسن علیہ السلام اور حسین علیہ السلام ہوں گے ۔&&(تفسیر مجمع البیان)&&!! {{تاویل نمبر۱:{{فرزندِ رسولِ خداصلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السلام سے روایت ہے کہ: حاملینِ عرش سے مراد علمِ خدا کے متحمل ہیں ۔ اُن آٹھ میں سے چار تو ہم وآل محمدصلی اللہ علیہ و آلہ وسلم ) میں سے ہیں ،اور چار پچھلوں میں سے ہیں جنھیں خدا چاہے۔&&(تفسیر نورالثقلین جلد ۵ ) &&!! تاویل نمبر۲: }}حضرت امام علی ابنِ ابی طالب علیہ السلام نے فرمایا:  حاملینِ عرش علماء اور دانشمند ہیں ،جنھیں خداوندِ عالم نے اپنے علم کی تعلیم دی ہے۔&&(تفسیر نورالثقلین جلد ۵){{&&!!ان حدیثوں سے معلوم ہوتا ہے کہ عرشِ الھٰی سے مراد اللہ کا علم و قدرت ہے پس جو انسان اور فرشتے جتنا زیادہ علم اور قدرت رکھتے ہوں گے ،اُتنا ہی وہ عرش کا زیادہ حصہ اٹھائے ہوں گے۔ معلوم ہوا کہ عرشِ الھٰی بادشاہوں جیسا تخت و سلطنت نہیں ہے بلکہ علمِ الھٰی اور قدرتِ الھٰی ہے۔&&(تفسیر نمونہ)&&
  69,19,آیت نمبر۱۹:نامہ اعمال سیدھے ہاتھ میں :جس کسی کو قیامت کے دن اُس کا نامہ اعمال اُس کے داہنے ہاتھ میں دیا جائے گا اِس کا مطلب یہ ہوگا کہ اُس کا حساب بے باق ہے ۔ وہ اللہ کی بارگاہ میں مجرم کی حیثیت سے نہیں ،بلکہ تابعدار غلام کی حیثیت سے پیش ہوگا۔ ہر شخص پر مرتے ہی یہ بات کُھل جاتی ہے کہ وہ ایک تابعدار غلام کی حیثیت سے اپنے مالک کے پاس لے جایا جا رہا ہے یا سرکش غلام یامجرم کی طرح۔ پھر موت کے بعد سے قیامت تک انسان کے ساتھ یا تو مہمانوں جیسا سلوک ہوتا رہے گا یا مجرموں جیسا۔ اِسی لیے جناب رسولِ خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:  قبر یا تو جنت کے باغوں میں سے ایک باغ ہوتی ہے ،یا جہنم کے گڑھوں میں سے ایک گڑھا۔&&(الحدیث) &&(تفسیر کبیر ،مجمع البیان ،تفہیم)&&سوال یہ ہے کہ:جو مومنین قیامت کے دن یہ پکار رہے ہوں گے کہ: لوگو! آو ،ہمارا نامہ اعمال پڑھو۔تو کیا اُن کے نامہ اعمال میں کوئی گناہ نہیں ہوگا؟جواب اِس کا:}}جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم کی اِس حدیث میں ملتا ہے کہ: فرمایا:  خداوندِ عالم پہلے (نیک) بندوں سے اُن کے گناہوں کا اقرار لے گا،پھر فرمائے گا کہ: میں نے تمھارے یہ گناہ دنیا میں بھی چھپائے رکھّے تھے،اور آج میں اِن کو معاف کرتا ہوں ۔اِس کے بعد صرف اُن کی لکھی ہوئی نیکیاں اُن کے ہاتھ میں دے دی جائیں گی۔&&(فی ظلال القرآن جلد۸){{&&دوسرے مفسرین نے یہ لکھا کہ خداوندِ کریم اپنی رحمت ،فضل و کرم کی وجہ سے مومنین کے گناہوں کو نیکیوں سے بدلے دے گا۔&&(تفسیر نمونہ)&&
  69,24,آیت نمبر۲۴:شانِ نزول آیت۲۴:اہلِ کتاب کا ایک عالم جناب رسولِ خداصلی اللہ علیہ و آلہ وسلم سے آکر کہنے لگا  اے ابو القاسم! کیا آپ کا یہ خیال ہے کہ جنت کے لوگ کھائیں پئیں گے؟}}حضور اکرم صلی اللہ علیہ و آلہ وسلم نے فرمایا:جسکے قبضے میں میری جان ہے اُس خدا کی قسم ،جنت کے ہر آدمی کو کھانے پینے اور جماع کرنے کی سو۱۰۰ سو ۱۰۰ آدمیوں کی طاقت عطا کی جائے گی۔اُس شخص نے پوچھا:  اگر ایسا ہوتا تو پھر (بیت الخلاء جانے کی) حاجت بھی محسوس ہوگی؟حضور اکرم صلی اللہ علیہ و آلہ وسلم نے فرمایا:  صرف ایک پسینہ جاری ہوگا جس کی خوشبو مشک کی سی ہوگی۔&&(تفسیر صافی بحوالہ مجمع البیان) &&{{ !!معلوم ہوا کہ جنت کی غذائیں لذت میں تو انتہائی لذیذ ہوں گی مگر حقیقت میں انتہائی لطیف ہوں گی۔،&&(مولف)&&
  69,27,آیت نمبر۲۷:مطلب یہ ہے کہ کاش مجھے یہ خبر ہی نہ ہوتی کہ حساب کتاب کیا چیز ہوتی ہے یا حساب کتاب کی نوبت ہی نہ آتی۔ کیوں کہ میرے پاس نافرمانیوں ،گناہوں کے سوا کچھ نہیں ہے۔دوسرا مطلب یہ ہے کہ میں نے دنیا میں نہ کھبی سوچا کہ ایک دن میرا حساب کتاب حشر نشر بھی ہوسکتا ہے۔ اور جن لوگوں کے داہنے ہاتھ میں نامہ اعمال دیا جائے گا،وہ کہیں گے کہ مجھے تو پہلے ہی خبر تھی کہ میرا حساب کتاب (ضرور) ہوگا۔ (یہاں دونوں کی کیفیات بیان کی گئی ہیں )&&(فصل الخطاب)&&
  69,28,آیت نمبر۲۸۔۲۹: پچھلی آیات میں کافر ،گنہگار ،مجرم کی باتوں کو بیان کیا گیا ہے کہ:  کاش میرا عمال نامہ مجھے نہ دیا گیا ہوتا یعنی کاش نامہ اعمال دے کر قیامت کے دن سب کے سامنے ذلیل و رسوا نہ کیا جاتا۔ کاش یہ دکھایا ہی نہ جاتا کہ میرا حساب کتاب کیا ہے؟ کاش جزاء و سزا کا کوئی نظام ہی نہ ہوتا کاش مجھے نہ بتایا جاتا کہ میں نے دنیا میں کیا کیا بدمعاشیاں کی تھیں ۔پھر اگلی آیت میں بتایا گیا کہ اُ سنے آخر میں کہا کہ کاش میری موت ہی میرا خاتمہ کردیتی۔مگر یہ ساری تمنائیں صرف سزا دیکھنے کی وجہ سے پیدا ہورہی ہیں ،جو لاحاصل ہیں ۔ اُن کی یہ تمنائیں بےفائدہ ہیں ان کی کوئی حقیقت نہیں ۔ (اب تو بد اعمالیوں کی سزا ملنی ہیں ہے۔)&&(تفسیر کبیر ۔ مجمع البیان ۔ تفہیم) &&اب اِن آیات ۲۸۔۲۹ میں بتایا جارہا ہے کہ منکرینِ آخرت کافروں کہ کہنے کا مطلب یہ ہے کہ:  نہ مال میرے کام آیا ،نہ مقام،نہ منصب ،نہ عزّت ،نہ اثر ،نہ رسوخ آج میں خالی ہاتھ خدا کے سامنے حاضر ہوں ۔ نجات کے تمام راستے بند ہوچکے ہیں ۔)&&تفسیر نمونہ) &&!!معلوم ہوا کہ آخرت کو برباد کرنے والی دو ۲ چیزیں ہوا کرتی ہیں ۔ (۱) مال واولاد ،اور (۲) عزت و مقام ۔ جاہ و جلال ۔ اسی لیے ان دونوں کا ذکر خاص طور پر کیا گیا ہے۔&&(تفسیر ماجدی)&& !!مجرموں کا یہ کہنا: <<ھَلَکَ عَنّیْ سُلُطٰنِیَہْ >> میری ساری سلطنت جاتی رہی۔یعنی اقتدار ،طاقت ،قوت ختم ہوگئی۔پھر سلطان کا لفظ دلیل اور حجت کے لیے بھی استعمال ہوتاہے ،اور اقتدار اور حکومت کے لیے بھی ۔ اگر یہاں دلیل اور حجت کے معنی لیے جائیں تو مجرم کے کہنے کا مطلب یہ ہوگا کہ:  جو دلیلیں اور ثبوت میں اپنی حقانیت اور برتری کے ثابت کرنے کے لیے دنیا میں پیش کیا کرتا تھا،وہ دلیلیں یہاں نہیں چل سکتیں ۔ میرے پاس اب اپنی صفائی پیش کرنے کے لیے کوئی دلیل یا حجت یا ثبوت موجود نہیں ہے۔اب میرے جرائم پوری پوری طرح ثابت ہوگئے۔ اب کٹ حجتیاں بھی نہیں چل سکتیں ۔پھر یہ کہ یہاں نہ میراکوئی لشکر ہے ،نہ مرا کوئی حکم ماننے والا ہے۔ میں یہاں ایک لاچار غلام کی طرح کھڑا ہوں ،جو اپنے بچانے کے لیے کوئی چال بازی نہیں کرسکتا۔&&(تفسیر کبیر ،مجمع البیان ،تفہیم)&& !!عبرت انگیز تاریخی واقعات:ہارون رشید عظیم عباّسی خلیفہ بیمار ہوا تو اُس کا پیشاب طبیب کے سامنے رکھا گیا۔ طبیب نے کہا: اِس پیشاب کی شیشی والے سے کہدو کہ وہ اپنی وصیت کردے۔ کیو ں کہ اُس کی طاقت ختم ہوچکی ہے۔ اُس کی بنیاد کھوکھلی ہوچکی ہے۔ہارون رشید طبیب کہ یہ کلمات سن کر اپنی زندگی سے مایوس ہوگیا،اور ایک شعر پڑھنے لگا جس کا مطلب یہ ہے: طبیب اپنی موت کا تو دفاع نہیں کرسکتا ،اگر وہ دفاع کی قدرت رکھتا تو خود اپنی اپنی بیماریوں سے کیسے مرتا؟پھر ہارون رشید نے اپنی قبر اپنے بستر کے پاس بنوائی ،اور قبر دیکھ کر یہی آیت<< مَآ اَغْنٰى عَنِّيْ مَالِيَہْ۲۸ ہَلَكَ عَنِّيْ سُلْطٰنِيَہْ>> بار بار پڑھتا رہا اور حسرت و یاس کے عالم میں مرگیا۔&&(سفینتہ البحار جلد ادنیٰ)!! &&شیخ بہائی نے لکھا کہ: ایک شخص نے ایک دن اپنی عمر کا حساب لگایا تو ۰۰ ۲۱۵ دن نکلے ۔ کہنے لگا : وائے ہو مجھ پر اگر میں نے ہر روز صرف ایک ہی گناہ کیا ہے تو بھی اکیس ہزار پانچ سو گناہ کرچکا ہوں ۔ اتنے کچھ گناہوں کے ساتھ خدا سے کس طرح ملوں گا۔ میرا کیا حشر نشر ہوگا؟ اُسی وقت چیخ ماری اور مرگیا۔&&(سفینہ ۔ البحار) ]] &&سرِ عرش کانپ اُٹھّا ،دلِ عصمتِ ملائک ۔۔۔۔جو میں ساتھ لے کہ پہنچا چشمِ گناہگاری[[۔&&(جوش)&&۔مگر اس کا علاج میر انیسؒ نے لکھا:۔]]رحمت کا تری اُمیدوار آیا ہوں ۔۔۔-منہ ڈھانپے کفن سے شرمسار آیا ہوں ۔چلنے نہ دیا بارِ گنہ نے پیدل ۔ اِس واسطے کاندھوں پہ سوار آیا ہوں[[ &&(میر انیسؒ)&&
  69,32,آیت ۳۲کے بارے میں {{فرزندِ رسولِ صلی اللہ علیہ و آلہ وسلم امام جعفر صادق علیہ السلام سے روایت ہے کہ: اُس زنجیر کی لمبائی ستّر ہاتھ ہے۔ اگر اُس کی ایک کڑی بھی دنیا پر رکھدی جائے تو ساری کی ساری دنیا اُس کی گرمی سے پگھل جائے۔&&(الامان ،الحفیظ)&&(عام تفسیر) &&(تفسیر صافی ۔ تفسیر قمی)&&{{
  69,34,آیت ۳۴ میں بتایا کہ:یہاں پر خداآخرت کی سزائیں دینے کے وجوہات بیان فرمارہا ہے۔ (۱) آخرت کی سزائیں ملنے کا سب پہلا سبب خدا ،رسول صلی اللہ علیہ و آلہ وسلم اور آخرت کو دل سے ماننا یعنی : ابدی حقیقتوں کو سمجھنے کی کوششیں نہ کرنا۔(۲) انسانوں کے حقوق مارنا۔ خاص طور پر غرباء ،فقراء مساکین اور یتیموں کے حقوق۔(۳) غریبوں ،کمزوروں ،مظلوموں کی مدد نہ کرنا۔ اب اس آئینے میں ہر شخص اپنی شکل دیکھ لے۔[[ لے کرعمل کا جائزہ ،صبح و مسا کبھی تو ہم ۔اپنی بھی شکل دیکھتے آئینہ مجاز میں ]]۔&&(ماجد نور بریلوی)!&&(۴)خود کسی بھوکے غریب کو کھانا کھلانا تو درکنار ، وہ اتنا غریب دشمن انسان ہے کہ کسی سے یہ کہنا بھی پسندن ہ کرتا تھا کہ کسی بھوکے کو روٹی ہی دے دو۔&&(تفسیر کبیر ۔ تفہیم ۔ فصل الخطاب)&&!!قرآن پر اعراب حضرت علی علیہ السلام کے حکم سے لگائے گئے:صعصعہ بن صوحان کہتے ہیں کہ ایک عرب نے حضرت امام علی علیہ السلام کے سامنے یہ آیت۳۷ اِس طرح پڑھی<<لَا یاْکُلُہُ اِلَّا خَاطِوْن خاطون>> کے معنی قدم اٹھانے والے کہ ہوتے ہیں ۔اِس پر }}حضرت امام علی علیہ السلام نے فرمایا: قدم تو سب اُٹھاتے ہیں ۔ تو کیا خدا سب چلنے والوں کو جہنم کی غذا کھلائے گا؟ پھر فرمایا:  اے شخص! خَاطِون نہیں بلکہ<<اِلَّا الْخٰطِوْنَ >> یعنی : سوا خطا کرنے والوں کے {{۔اِس کے بعد حضرت امام علی علیہ السلام نے ابو الاسود کو ،جو ایک بڑا ادیب تھا ،حکم دیا کہ اس وقت عربی زبان سے ناواقف لوگ بھی مسلمان ہوگئے ہیں اُن کے لیے ایسا کام کروکہ وہ قرآن پڑھنے میں غلطی نہ کریں ۔اِس حکم پر ابوالاسود نے الفاظ ِ قرآن پر اعراب : یعنی : زبر ،زیر ،پیش لگائے۔&&(تفسیر نمونہ)&&
  69,38,آیت ۳۸ میں << فَلَا >> (یعنی نہیں ) یعنی تم لوگ جو کچھ بھی سمجھ رہے ہو،بات وہ نہیں ہے بلکہ بات کچھ اور ہے۔&&(تفہیم ۔ تفسیر کبیر )&&
  69,39,آیت ۳۹:خداوندِ عالم کا فرمانا کہ:  میں قسم کھاتا ہوں اُس کی جسے تم دیکھ رہے ہو اور جس کو تم نہیں دیکھتے۔اِس سے معلوم ہوا کہ کائنات عالم کا ایک بہت بڑا حصّہ وہ ہے جسے ہم نہیں دیکھ سکتے۔مثلاَ ماہرین کے نزدیک صرف پانچ ہزار ستارے ہم دیکھ سکتے ہیں ،باقی اربوں ،کھربوں ستارے ہیں جن کو ہم نہیں دیکھ سکتے۔ پانی کے ایک قطرے میں لاکھوں جاندار موجود ہیں ۔ اِس حالت میں یہ عقل دشمنی ہے کہ ہم اپنے آپ کو صرف ظاہری محسوسات تک محدود کردیں اور اُ س عالم کو ماننے سے انکار کردیں جسے ہم ظاہری آنکھوں سے نہیں دیکھ سکتے۔ مثلا عالمِ ارواح کا وجود عقلی و نقلی ،بلکہ تجرباتی دلائل سے ثابت ہوچکا ہے کہ وہ ہمارے عالمِ جسم سے کہیں زیادہ وسیع و عریض ہے۔&&(تفسیر نمونہ)&&
  69,40,آیت ۴۰ :عرب محاورہ میں قسم کھانے کا مطلب صرف کلام میں زور شور اور تاکید پیدا کرنا بھی ہوتا ہے ۔ اب کیوں کہ قرآن کو لانے ولے فرشتے جبریل علیہ السلام تھے جو دکھائی نہ دیتے تھے،اور قرآن کو پہنچانے اور سمجھانے والے رسولِ خداصلی اللہ علیہ و آلہ وسلم تھے ۔ اِس لیے قرآن کی حقّانیت کو ثابت کرنے کے لیے دو قسموں کے ذریعہ توجّہ دلائی گئی<< رسولِ کریم>> (عزت والا پیغام لانے والا) سے مراد جبریل علیہ السلام امین ہیں ۔&&(تفسیر کبیر بقول ابنِ مسیّب ،مقاتل ،ابنِ قتیبہ ،بحر) && خداوندِ عالم نے قرآن کو رسولِ کریم یعنی جبریل علیہ السلام کا قول یا کلام کیوں فرمایا؟حقیقتاً یہ خدا کا قول ہے جس کو جبریل علیہ السلام لے کر آئے۔ اور آیت ۴۳ میں واضح طور پر فرمایا کہ یہ ربّ العالمین کا نازل کیا ہوا کلام ہے ۔یہ لفظِ رسول از خود بتا رہا ہے کہ یہ قرآن در اصل نہ جبریل علیہ السلام کا کلام ہے ،نہ محّمد مصطفیٰ صلی اللہ علیہ و آلہ وسلم کا ۔ اِن دونوں کی حیثیت صرف پیغام پہنچانے والے کی ہے ،پیغام کسی اور کا ہے (پیغامبر یہ دونوں ہیں ۔)
  69,41,آیت۱ ۴۔۴۲ : شانِ نزول: ابوجہل کہا کرتا تھا کہ محّمد صلی اللہ علیہ و آلہ وسلم شاعر ہے اور قرآن شاعری ہے عقبہ یا عتبہ کہا کرتا تھا کہ محّمد صلی اللہ علیہ و آلہ وسلم کاہن ہیں ۔یہ ٹھیک ہے کہ قرآن کے الفاظ میں بلا کی ہم آہنگی ہے ،خوبصورتی اور موزونیت ہے جو کانوں کو اچھی لگتی ہے اور عقل و روح پر اثر کرتی ہے۔ مگر قرآن شاعری نہیں ہے ،ٹھوس حقائق کو پیش کرتا ہے ۔ اسی طرح کاہنوں کی مسجع ،مقفّٰی بے معنی جنتر منتر کا بھی قرآن سے کوئی تعلق ہی نہیں ہے کہانت و شاعری میں کوئی استدعال نہیں ہوتا ،جبکہ قرآن میں بلا کا استدلال اور منطقی ارتباط پایا جاتا ہے صرف قرآن کی جاذبیت اور فصاحت و بلاغت کی وجہ سے اس کو شاعری یا کہانت نہیں کہا جاسکتا۔ ظاہری قرآن کی جاذبیت اور فصاحت و بلاغت کی وجہ سے اس کو شاعری یا کہانت نہیں کہا جاسکتا۔ ظاہری مشابہت وہ بھی صرف الفاظ کے ظاہری تراش خراش کی وجہ سے قرآن کو شاعری یا کہانت قرار نہیں دے سکتے۔&&(تفسیر نمونہ)&&]]پرواز ہے دونوں کی اِسی ایک فضا میں۔۔۔۔ کرگس کا جہاں اور ہے ،شاہیں کا جہاں اور[[ &&(اقبال)&&
  69,43,آیت نمبر۴۳:قرآن مجید خداوندِ عالم کا ہی کلام ہے:ثبوت یہ ہیں کہ (۱) قرآن کو وہ شخص پیش کر رہا ہے جس کی شرافت و صداقت مسلم تھی۔ ایسے شخص سے یہ توقع ہی نہیں کی جاسکتی تھی کہ وہ اپنے مالک پر اتنا بڑا جھوٹ باندھے کہ خدا کا کلام نہ ہو ،اور وہ اپنے کلام کو خدا کا کلام کہے۔(۲) سب دیکھ رہے تھے کہ رسول ؐ جو پیغام پیش فرمارہے ہیں اُس میں اُن کا کوئی ذاتی مفاد نہ تھا،بلکہ حقیقت یہ تھی کہ اُنھوں نے اسلام اور قرآن کی خاطر اپنی عزّت ،دولت،تجارت خاندانی مفادات ،عیش و آرام سب کچھ برباد کردیا۔ جس شخص کو سارا شہر مکّہ آنکھوں پر بٹھاتا تھا ،اُسے ہر قسم کی سہولت کی پیش کش بھی کی جارہی تھی ،پھر وہ ہر طرح کی مصیبت برداشت کررہا ہو ۔(۳) سب دیکھ رہے تھے کہ جو قرآن پر ایمان لے آتا ہے اُس کی زندگی یک لخت بدل جاتی ہے ،کسی شاعر،کاہن کے کلام میں کبھی یہ اثر نہیں ہوا کرتا کہ وہ زندگی اور معاشرے میں اخلاقی انقلابات معجزانہ انداز میں برپا کر دے۔ اور اُس کے ماننے والے اُس کے پیغام کے لیے ہر قسم کے مصائب برداشت کرنے پر مستعد اور کمر بستہ ہوجائیں ۔(۴)عرب خوب اچّھی طرح جانتے تھے کہ شاعری کیا بلا ہے ،اِس لیے قرآن شاعری نہیں ہے کہانت اور جادو کے جنتر منتر بھی وہ خوب جانتے تھے۔ قرآن سے اِن خرافات کو دور کی بھی نسبت نہ تھی۔(۵) یہ بھی عرب خوب جانتے تھے کہ دنیا میں کوئی شخص اتنا فصیح و بلیغ نہ تھا جو قرآن جیسا کلام بناسکے۔(۶) وہ لوگ خوب جانتے تھے کہ رسول صلی اللہ علیہ و آلہ وسلم کے کلام انداز کیا ہوتا ہے اور قرآن اُس سے سراسر مختلف ہے۔(۷) زمین سے لیکر آسمان تک کا نظامِ قدرت اور یہ عظیم الشان کارخانہ ہستی جس میں زبردست حکیمانہ قوانین اور ہمہ گیر نظم و ضبط نظر آتا ہے ،شرک و انکار کو رد کر رہا تھا ،اور توحید اور قرآن کے پیغام کو ثابت کررہا تھا ۔ آخرت کے شواہد پیش کررہا تھا ۔ (۸) نظامِ کائنات ازخود بتا رہا ہے کہ ایک دن اُس کو ختم ہونا ہے،قیامت ضرور برپا ہونے والی ،اور عقل بتا رہی تھی کہ محمد صلی اللہ علیہ و آلہ وسلم اللہ کے سچے رسول ؐ ہیں ۔ ان دونوں حق کی قسم کھا کر یہ بات کہی گئی ہے کہ قرآ۔ ایک لحاظ سے محّمد مصطفیٰ صلی اللہ علیہ و آلہ وسلم اللہ اور جبریل علیہ السلام کا قول ہے ۔ مگر دراصل عالمین کے پالنے والے مالک کا قول ہے۔&&(تفسیر کبیر ۔ مجمع البیان)&&
  69,45,آیت ۴۵ میں ہے کہ : ہم اس کا داہنا ہاتھ پکڑ لیتے ۔اس کا مطلب :عرب محاورے کے مطابق سختی اور قوت کے ساتھ بدلہ لینے کے ہوتے ہیں ۔یعنی: اگر نبی صلی اللہ علیہ و آلہ وسلم نے قرآن خود گھڑ کر ہماری طرف منسوب کر دیا ہوتا تو ہم ان سے بڑی سختی کے ساتھ بدلہ لیتے۔&&(تفسیر صافی ۔ تفسیر قمی)&&
  69,46,آیت ۴۶ کی تشریح:پہلے تو یہ بتا یا گیا تھا کہ (۱) قرآن عالمین کے پالنے والے مالک کی طرف سے اُتارا گیا ہے۔پھر بتایا گیا ہے کہ (۲) ہمارے رسول صلی اللہ علیہ و آلہ وسلم کی کیا مجال کہ وہ اپنی طرف سے کوئی بات خود بناکر ہماری طرف منسوب کرسکے۔ اصل میں یہ ایک بے حد بلیغ انداز ہے رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی صداقت اور حقّانیت کو ثابت کرنے کا۔&&(فصل الخطاب)&& یاد رہے کہ یہ کوئی عام اصول نہیں بتایا جارہے ہے ۔ مطلب یہ ہے کہ جو کوئی بھی نبوت یا امامت کو جھو ٹا دعوٰی کرے گا کہ،ہم اُس کے ساتھ یہی سلوک کریں گے ۔ یہ صرف رسولِ خدا صلی اللہ علیہ و آلہ وسلم کی حقّانیت کابیان ہے۔&&(تفسیر کبیر) && رہا وہ شخص جو نبّوت کا جھو ٹا دعویدار ہے ،نہ معجزہ رکھتا ہے ،نہ حقانیت کی کوئی دلیل رکھتا ہے ،تو خدا کو کوئی ضرورت نہیں ہے کہ اُس کو فوراً ہلاک کردے۔ خدا اُس کے ذریعہ لوگوں کی عقل و نظر کا امتحان لیتا ہے کیوں کہ وہ ایک طرح سے شیطان کا ایجنٹ ہوتا ہے۔ ہر وہ شخص جو حق اور حقانیت کے معیار کو جانتا ہے ،ایسے نبی یا امام کے جھوٹے دعوے کو از خود جھوٹ سمجھ سکتا ہے۔&&(تفسیر نمونہ)&&
  69,47,آیت ۴۷ کی تشریح:اصل بات اِس آیت میں یہ بتائی ہے کہ ہمارا نبی صلی اللہ علیہ و آلہ وسلم اپنی طرف سے ہماری وحی میں کوئی کمی یا زیادتی نہیں کرسکتا۔ بغرضِ محال اگر وہ ایسا کرتا تو ہم اُس کو سخت سزا (یعنی شہ رگِ گردن کاٹ) دیتے۔ مگر اس بات کو ایسے بلیغ انداز میں بیان فرمایا ہے کہ آنکھوں کے سامنے یہ نقشہ پھر جاتا ہے۔ (اس طرح کلام کی اہمیت اور نبی ؐکی حقانیت و صداقت کا انداز لگایا جاسکتا ہے ۔ایک بادشاہ کا مقرر کیا ہوا افسر ،بادشاہ کے نام پر کوئی جعلی بیان بناکر لوگوں کے سامنے پیش کردے تو بادشاہ کس طرح اُس کا ہاتھ پکڑ کر اُس کا سر اُڑا دیتا ہے۔مگر کچھ لوگوں نے اِس آیت سے غلط نتیجہ نکالا کہ: اگر کوئی شخص نبوت کا دعوٰے کرے اور اُس کی گردن نہ کٹے،تو سمجھ لو کہ وہ اپنے دعوے میں سچّا ہے ۔ حالانکہ،جھوٹے خدائی کے دعوٰے دار بھی گذرے ہیں ،جو برسوں دندناتے رہے تو یہ بات اُن کی صداقت کا ثبوت نہیں ہوسکتی۔ (یہ دلیل صرف سچے رسول صلی اللہ علیہ و آلہ وسلم کی صداقت کو مزید ثابت کرنے کے لیے دی گئی ہے)۔ &&(تفسیر کبیر۔ تفہیم)&&
  69,48,آیت نمبر۴۸:خداوندِ عالم کا یہ فرمانا کہ قرآن حقیقتاً بُرائی سے بچنے والے <<متقین>> کے لیے نصیحت کا سبق ہے یعنی : قرآن صرف اُن لوگوں کو بُرے کاموں سے بچا سکتا ہے جو بُرے نتائج سے بچنا چاہتے ہیں ۔&&(تفہیم ۔ تفسیر کبیر)&&
  69,49,آیت ۴۹ ،۵۰ ۔ مطلب یہ ہے کہ ابدی حقیقتوں کو جھٹلانے والوں کو بالآخر خوب خوب پچھتانا پڑے گا اِس لیے کہ اُنھوں نے قرآن کوجھوٹ سمجھا،اِس لیے خدا نے اُن کوئی اہمیت نہیں دی۔&&(تفہیم)&& !!قرآن منکرینِ قرآن لیے قیامت کا دن حسرت و یاس کا سامان بن جائے گا۔ اس لیے کہ قیامت کے دن قرآن کی عظمت نمایاں ہوکر سامنے آچکی ہوگی،منکرینِ قرآن ازخود سمجھ لیں گے کہ اُنھوں نے اپنی ضد،ہٹ دھرمی ،مادّی مفادات،کِبرو غفلت کی وجہ سے خدا کی کتنی عظیم نعمت کا انکار کیاتھا۔ اور اُس کے نتیجے میں کیسے کیسے دردناک عذاب کے مستحق بن گئے۔پھر ساتھ ساتھ وہ اُن لوگوں کے بڑے بڑے مرتبے بھی دیکھیں گے جو قرآن کو زُبان اور دل سے بھی مانتے تھے ،اور اپنے اعمال و افعال سے بھی اُس وقت وہ منکرین سخت افسوس کریں گے<<وَيَوْمَ يَعَضُّ الظَّالِمُ عَلٰي يَدَيْہِ يَقُوْلُ يٰلَيْتَنِي اتَّخَذْتُ مَعَ الرَّسُوْلِ سَبِيْلًا۲۷ يٰوَيْلَتٰى لَيْتَنِيْ لَمْ اَتَّخِذْ فُلَانًا خَلِيْلًا>>۲۸ @@اور اُس دن ظالم (منکرین) (سخت افسوس کے عالم میں )اپنے ہاتھ (اپنے ہی دانتوں سے )کاٹ کاٹ ڈالیں گے اور کہیں گے ہائے افسوس مجھ پر ،کاش میں نے رسول ؐکے بتائے ہوئے راستے کو اختیار کیاہوتا۔ ہائے افسوس ،کاش میں نے فلاں کو اپنا دوست نہ بنایا ہوتا@@۔&&(سورہ فرقا ن آیت ۲۷۔۲۸)&& &&(تفسیر نمونہ)&&
  69,51,آیت نمبر۵۱:<<حق الیقین>>یعنی: سچا،واقعی،حقیقی یقین۔ یہ یقین کی آخری منزل ہے یقین کی تین قسمین یا منزلیں ہیں ۔(۱) علم الیقین (۲) عین الیقین (۳) حق الیقین۔(۱) علم الیقین یہ ہے کہ ہمیں عقلی دلائل سے یقین حاصل ہوجائے ۔ مثلا آگ کا یقین دھواں اُٹھتا ہوا دیکھ کر ہوجاتا ہے۔ یا کوئی سچا آدمی بتادے کے فلاں جگہ آگ لگی ہوئی ہے۔(۲) عین الیقین جب ہم آگ کے شعلے لپکتے ہوئے اپنی آنکھوں سے دیکھیں ۔ یہ عین الیقین ہوگیا۔ (۳) حق الیقین: جب ہم آگ کے قریب پہنچ جائیں اور آگ کی گرمی کو محسوس کرنے لگیں تو اِس کو حق الیقین کہتے ہیں ۔ (اِس کے بعد ایک منزل<<فنا فی اللہ>> کی ہے ،جیسے لوہا آگ میں پڑا رہے یہاں تک کہ آگ کے سارے اور اوصاف اُس میں منتقل ہوجائیں ۔ یعنی لوہے کو دیکھیں تو وہ آگ کے لال انگارےکی طرح خود بھی لال نظر آنے لگے۔اِس آیت میں خدا وند عالم یہ فرما رہا ہے کہ قرآن کے بتلائے ہوئے حقائق ،حق الیقین ہیں یعنی سو فیصد سچے ،حقیقی اور یقینی۔ مگر یہ عقل کے اندھے پھربھی قرآن کے بتلائے ہوئے حقائق اور خود قرآن کی سچائی کا انکار کر رہے ہیں ۔ گویا ایسے لوگ از خود گمراہ ہیں ۔ اُن کی گمراہی اور غلطی کی کوئی حد ہے نہ حساب۔ یعنی بے حد اور بے حساب۔&&(تفسیر نمونہ)&&!!حق اور یقین ایک ہی چیز ہیں ۔ اور حق کی یقین کی طرف اضافت اِس طرح ہے جس طرح مسجد الجامع میں ،مسجد کی جامع کی طرف اضافت ہے۔ یا دار الآخرۃ میں دار کی آخرت کی طرف اضافت ہے۔
  69,52,آیت نمبر۵۲:پچھلی آیات میں قرآن مجید کی چار صفات بیان کی گئی ہیں :(۱) پہلے فرمایا کہ :  قرآن،عالمین کے پالنے والے مالک کا اُتارا ہوا ہے ۔ قرآن کی یہ صف تمام لوگوں کے لیے ہے ۔ کیوں کہ کائنات کا مالک سب کا مالک ہے اِس لیے قرآن بھی سب کی ہدایت کے لیے اُتارا گیاہے۔ جیسے دریا سب کے لیے بہایا جاتا ہے ،سورج سب کے لیے چمکایا جاتا ہے۔ اب یہ اور بات ہے کہ کوئی اپنی آنکھ خود بند کرکے سورج کی روشنی سے فائدے حاصل نہ کرے۔(۲) قرآن کی دوسری صفت یہ فرمائی کہ:  قرآن متقین کے لیے سامانِ نصیحت ہے ،سبق حاصل کرنے کا ذریعہ ہے۔قرآن کی یہ صفت صرف متقین کے لیے ہے۔ اس لیے کہ ،صرف وہی لوگ قرآن سے نصیحت اور سبق حاصل کرتے ہیں جو ابدی تباہیوں سے بچنا چاہتے ہیں ۔ جن کو تباہ ہوجانے کی کوئی فکر ہی نہ ہو،وہ قرآن سے نصیحت یا سبق حاصل نہیں کرپاتے۔ مثلاً ڈاکٹر کتنا ہی حاذق اور عالم ہو،مگر جس شخص کو اپنی صحت کی پرواہ ہی نہ ہو ،وہ اُس کے پاس کبھی نہ جائے گا،اور اس طرح اس کے علم سے اُس مریض کوکوئی فائدہ نہ ہوگا۔(۳) قرآن کی تیسری صفت یہ بتلائی کہ: قرآن کافروں کے لیے حسرت و ندامت کا باعث ہے،یہ صفت قرآن کو نہ ماننے والوں کے لیے ہے کہ وہ قرآن کو نہ مان کر قیامت کے دن سخت حسرت و ملال کے عالم میں ہاتھ مل رہے ہوں گے۔(۴)اور قرآن کی چوتھی صفت یہ بیان کی گئی کہ: قرآن حق الیقین ہے ۔قرآن کی چوتھی صفت خاصانِ خدا،عرفاء مفکرین اور مقربین کے لیے ہے جو قرآن کے مطالب پر غور و فکر کرنے کے بعد خداوندِ عالم کی توفیقات کی وجہ سے قرآن کے الفاظ و معانی کو سو۱۰۰ فیصد سچی حقیقت دل سے مان لیتے ہیں ،اور پھر اُس پر عمل کرنے کی پوری پوری کوشش کرتے ہیں ۔&&(تفسیر نمونہ۔ تفسیر کبیر۔ تفسیر مجمع البیان)&& ]]یہ بات کسی کو نہیں معلوم کہ مومن۔۔۔۔قاری نظر آتا حقیقت میں ہے قرآں[[&&(اقبال)&& اِس آخری صفت کے اوّلین مصداق محمد صلی اللہ علیہ و آلہ وسلم وآلِ محمد علیہم السلام ہیں ۔ اس لئے کہ حضورِ اکرم صلی اللہ علیہ و آلہ وسلم نے اُن حضرات علیہم السلام کو قرآن کا ساتھی قرار دیا ہے کہ }}فرمایا:  میں تم میں دو بہت قیمتی چیزیں چھوڑے جارہا ہوں (۱) اللہ کی کتاب (قرآن) (۲) اور دوسری میری عزت (اولاد) اہلبیت علیہم السلام ۔ جب تک تم اِن دونوں سے تعلق جوڑے رکھو گے کبھی ہرگز گمراہ نہ ہوگے۔ اور یہ دونوں کبھی ہرگز ایک دوسرے سے جدا نہ ہوں گے،یہاں تک کہ میرے پاس حوضِ کوثر پر لوٹ کر آئیں گے۔&& (صحیح مسلم ۔ صواعقِ محرقہ) ]]{{&& اہلبیتِ پاک کے ہر سانس کو اے مدّعی ۔ہاں ملا کر دیکھ لے آیات ِقرآنی کے ساتھ[[۔&&(قمر جلالویؒ)&&
