  46,1,آیت نمبر۱:>>حا میم<< کے الفاظ (حروف) بیان کرنے سے اس طرف اشارہ ہوسکتا ہے کہ اس قدر سادہ حروف تہجی سے قرآن جیسی اس قدر عظیم کتاب کا وجود میں لانا کتنا بڑا معجزہ ہے۔ &&(تفسیر نمونہ)&& جب خدا کی شان قدرت یہ ہے کہ وہ حروف تہجی کے الفاظ استعمال فرما کر قرآن جیسی عظیم کتاب بنادیتا ہے تو انسان جیسی عظیم مخلوق اگر قرآن پر عمل کرے ، تو خدا اس کو کیا سے کیا بنادے گا؟ (سبحان اللہ) &&(مولف)&&
  46,3,آیت نمبر ۳ :}}خدا وند عالم کا فرما ن ہےکہ: ہم نے نہیں پیدا کیا آسمانوں اور  زمین کو ان کے درمیان کی چیزوں کو مگر حق بجانب{{۔ یعنی : ہم نے تمام کائنات کو بے مقصد، خواہ مخواہ، غلط طور پر نہیں پیدا کیا۔ &&(تفسیر تبیان)&& خدا وندِ عالم نے کائنات کی ہر چیز کو پیدا کیاکوئی بھی چیز از خود، اتفاقاً پیدا نہیں ہوئی ہے۔ اس بات سے دہریت کا عقیدہ باطل کردیا اور  روح اور  مادے کے قدیم ہونے کے تصور کو بھی رد کردیا۔خدا وندِ عالم نے یہ فرما کر ، کہ ہم نے ہر چیز کو برحق ( یعنی ) با مقصد پیدا کیا ہے ۔ اس بات کی قطعاً تردید فرما دی کہ کائنات کی تخلیق کا کوئی مقصد نہیں ۔ اس طرح آخرت کو ثابت کردیا ، تاکہ لوگ خدا کی عبادت کریں ۔پھر ہر شخص کو آخرت میں اس کے نیک و بد اعمال کا بدلہ دیا جائے۔{{ جناب سیدہ فاطمہ الزہریٰ علیہا السّلام نے اپنے خطبہ میں فرمایا: تمام ترحمد اس خدا کے لیے ہے جس نے ہمیں نعمتوں سے نوازا، اور  اس کا شکر خاص طور پر اس بات پر ہے کہ اس نے ہم پر وحی اور  الہام فرما کر ہماری ہدایت فرمائی۔ خدا وندِ عالم نے اس کائنات کو اپنی قدرت سے پیدا فرمایا، اور  اپنی مشیت سے اس کو جاری فرمایا۔ یہ سب کچھ اس نے اپنی کسی ضرورت کو پورا کرنے کے لیے نہیں پیدا کیا۔ اور  نہ اس کو ان کے صورت دینے سے کوئی فائدہ حاصل کرنا مقصود تھا۔ بلکہ مقصد یہ تھا کہ اس تخلیق سے اس کی حکمت انسانوں پر ثابت ہوجائے اور  ان کو خدا کی اطاعت کی ترغیب و تنبیہ دی جائے۔ پھر اس نے اپنی اطاعت پر اجر و ثواب اور  نافرمانی پر اپنی سزا دینا مقرر فرمایا۔&&(خطبہ جناب فاطمہ زہریٰ علیہ السّلام)&& }}
  46,4,آیت نمبر۴:{{ فرزندِ رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفر صادق علیہ السّلام سے روایت ہے کہ: علمی آثار << (اَثٰرَۃٍ مِّنْ عِلْمٍ ) >> سے اولین مراد اوصیاءانبیا ء علیہم السّلام کا علم ہے ۔&&(علم الا وصیا الانبیاء علیہم السّلام)&& &&(تفسیر نوراثقلین جلد۵)&& }} !!{{ فرزندِ رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام محمد باقر علیہ السّلام نے روایت فرمایا ہے کہ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا: یہاں کتاب سے مراد توراۃ وانجیل ہیں ، اور  علمی آثار سے مراد انبیاء کرام علیہم السّلام اور  اولیا عظام کا علم ہے۔ &&(تفسیر کبیر امام رازی)&& }} ّ}}خدا وندِ عالم کا فرمان ہےکہ: کوئی علمی روایت پیش کرو ، اگر تم سچے ہو}}۔ یعنی پہلے کے کسی مستند صاحب علم کا بیان ہی پیش کرو جس میں بتایا گیا ہو کہ اللہ کے سوا کسی اور  نے بھی کائنات کی کسی چیزکو پیدا کیا ہے۔&&(تفسیر جلالین فصل الخطاب) &&
  46,5,آیت نمبر۵:خداونِد عالم کا فرمان ہےکہ:جھوٹے خدا ان کی پکار سے بے خبر ہیں ۔ دنیا بھر میں جتنے مشرکین ہیں وہ تین قسم کے جھوٹے خدائوں کو پکارتے ہیں (۱)بے روح بے عقل مخلوقات یابت۔ وہ نہ سن سکتے ہیں ، نہ سمجھ سکتے ہیں اس لیے وہ بے خبر ہیں ۔(۲) بزرگ انسانوں کی ارواح، جو خدا کے عبادت گزار اطاعت کرنے والے نیک لوگ تھے۔ لوگ ان کو خدا سمجھ کر پکارتے ہیں ، خدا وندِ عالم ان کی آوازیں ان بزرگوں تک نہیں پہنچنے دیتا اس لیے وہ ان کی فریادوں سے بے خبر ہیں ۔ اور  پکار سننے کی تکلیف نہیں دینا چاہتا۔(۳)تیسرے قسم کے جھوٹے خدا وہ ہیں جو خود خدائی کے دعوے کیا کرتے تھے ۔ وہ جابر بادشاہ امیر سردار وڈیرے حکمراں لوگ یا جھوٹے مذہبی پیشوا وغیرہ۔ وہ بھلا ان فریاد کرنے والوں کی فریادیں کیا سنیں گے جبکہ وہ خود خدا تعالٰے کے ہاں گرفتارِ عذاب ہیں ۔ اپنے کیے کی سخت سزائیں بھگت رہے ہیں ۔ بھلا وہ ان کی پکار کیسے سن سکتے ہیں ۔نتیجہ: اس سے یہ ثابت ہوگیا کہ جو واقعاً خدائے بزرگ و برتریں کے نیک بندے ہیں ، خداوندِ عالم ان کو ان لوگوں کی دعائیں اور  وہ نیک اعمال کے تحفے پہنچا دیتا ہے جو دنیا کے لوگ ان کے لیے انجام دیتے ہیں ۔ اسی طرح برے لوگوں کو وہ لعنیتں پہنچادیتا ہے جو لوگ دنیا میں ان پر بھیجتے ہیں تاکہ ان کی تکلیفوں میں اور  اضافہ ہو۔ غرض ثابت ہوگیا کہ مردے سنتے ہیں ، احساس رکھتے ہیں ۔ &&(تفہیم تفسیر کبیر، مجمع البیان، انوارالخف)&&
  46,6,آیت نمبر۶:کافروں کا قرآن کو جادو کہنا یہ بتا رہا ہے کہ قرآن کافروں کے نزدیک بھی ایک غیر معمولی چیز تھی۔ یعنی خارق عادت تھی، جسے جادو کے بجائے انھیں معجزہ کہنا چاہئیے تھا۔اصل میں ان کا قرآن کو جادو کہنا ایک طرح سے قرآن کو معجزہ ماننا ہے۔ &&(فصل الخطاب)&& اصل میں قرآن مجید زبان اور  بیان میں اس قدرشدید اور  زبردست اثر رکھتا تھا کہ عرب خوب اچھی طرح سے سمجھ چکے تھے کہ یہ کلام کسی بشر کا نہیں ہوسکتا۔ حتیٰ کہ جاہلیت عرب کےبڑے بڑے مانے ہوئے شعراء نے تو کعبہ میں سورۃ کوثر کے نیچے یہ مصرعہ لکھ دیا تھا:<< ماھذا کلام البشر >> (یہ کلام بشر کا نہیں ہوسکتا۔) &&( سیرت ابن ہشام ، تاریخ طبری)&&
  46,8,آیت نمبر۸:{{خداوند عالم کا جناب رسول خدا صلی اللہ علیہ و آلہ وسلم سے یہ کہلوانا کہ: ’’خدا میرے اور  تمھارے درمیان گواہی دینے کےلیے بہت کافی ہے‘‘}}۔ اس کے معنی یہ ہیں کہ خداوند عالم کی طرف سے یہ بات ایک نہ ایک دن ثابت ہو کر رہے گی کہ رسول اکرم صلی اللہ علیہ و آلہ وسلم کا دعویٰ بالکل سچا ہے۔ کہ ایک نہ ایک دن سب کو خدا کے سامنے حساب دینا ہے، اور  یہ قرآن خدا ہی کا کلام ہے۔&&(تبیان)&& رہا یہ سوال کہ خدا تمھیں ، مجھے (رسول صلی اللہ علیہ و آلہ وسلم کو) جھٹلانے کی سز افوراً کیوں نہیں دیتا؟ تووہ اس لیے ہے کہ خدا تمھیں موقع پرموقع اور  مہلت پر مہلت دیے چلاجا رہا ہے تاکہ شاید تم خدا،رسول صلی اللہ علیہ و آلہ وسلم اور قرآن کے حق ہونے کے انکارسے باز آجاؤ عقل کا ناخن لو، اس طرح ہمیشہ ہمیشہ کی تباہی سے بچ جاؤ۔ تاکہ خدا تمھیں معاف فرمادے کیونکہ وہ غفور رحیم ہے۔&&(تفسیر مجمع البیان)&&
  46,9,آیت نمبر۹:آیت کا پیغام یہ ہے کہ جناب رسول صلی اللہ علیہ و آلہ وسلم خدا سے کہلوایا جا رہا ہے کہ میری تعلیم کوئی نئی نرالی انوکھی تعلیم نہیں ہے۔ بنیادی طور پر میری تمام تعلیمات وہی ہیں جو تم انبیاء کرام علیہم السّلام ہمیشہ سے دیتے چلے آئے ہیں میں پہلا رسول صلی اللہ علیہ و آلہ وسلم نہیں ہوں،مجھ سے پہلے بھی انبیاء علیہم السّلام و مرسلین آتے رہے ہیں اور  تم ان کی رسالت کو جانتے اور  مانتے رہےہو۔&&(تبیان بقول ابن عباسؓ ،مجاہدقتادہ)&& جب مجھ سے پہلے مجھ جیسے بہت سے ا نبیاء کرام علیہم السّلام گزرچکے ہیں توپھر تم میری رسالت کا انکار کس بنیاد پر کررہے ہو؟ &&(تفسیر جلالین)&& اور  جناب رسول خدا صلی اللہ علیہ و آلہ وسلم سے یہ کہلوانا کہ :’’مجھے یہ خبر نہیں ہے کہ میرے اور  تمھارے ساتھ کیا ہونا ہے‘‘ ؟ یعنی : میں ذاتی طور پر اپنے علم وقیاس سے کچھ نہیں جانتا کہ میرے اور  تمھارے ساتھ کیا ہوگا؟ جو کچھ جانتا ہوں خدا کے دیے ہوئے علم سے جانتا ہوں ۔اب جو مشرکین کے ساتھ خود اپنے آپ صلی اللہ علیہ و آلہ وسلم کو بھی شریک کرلیا، تویہ ایک کھلا ہوا انداز رواداری بھی ہے،اور  انتہاء درجہ کی انکساری اور  شان بندگی بھی۔&&(فصل الخطاب)&&
  46,10,آیت نمبر۱۰:آیت کااستدلال:اس آیت میں اسی قسم کا استدلال ہے جیسا کہ {{ حضرت امام  علی ابن ابی طالب علیہ السّلام نے ایک منکر خدا سے فرمایا تھا کہ اگرخدا نہ ہوا تو ہمیں وہاں خدا کے اقرار سے کوئی نقصان نہ پہنچے گا اور اگر خدا موجود ہوا جبکہ تم اس کے وجود و صفات کاانکار کررہے ہو، تو پھر تم سوچ لوکہ تمھاراکیا حشر نشر ہوگا؟ &&(تفسیر جلالین)&& }} بنی اسرائیل کے گواہ سے مراد:حضرت موسٰی علیہ السّلام ہیں ۔ &&(ابن جریر، معالم)&& بعض مفسرین نے عبداللہ بن سلام کومراد لیا ہے ۔حالانکہ عبداللہ بن سلام نے تو مدینہ میں اسلام قبول کیاتھا ،جبکہ سورۃ مکی ہے۔ &&(تفسیر تبیان)&& !!خداوند عالم کاقانون ہدایت:آخر میں خداوند عالم نے یہ فرماکر کہ ’’خدا بے انصاف لوگوں کوہدایت نہیں فرمایا کرتا‘‘. اپنے اس قانون ہدایت کا اعلان فرمایا ہے کہ جولوگ انصاف کے ساتھ غور و فکر نہیں کرتے ،تعصبات اور  اپنے مفادات کی عینک چڑھائے رکھتے ہیں , تو خداوند تعالیٰ زبردستی ان کوسیدھے راستے پرنہیں لگائے گا۔ ایسے لوگ ہمیشہ خدا کی توفیقات وہدایات سے محروم رہتے ہیں ۔ &&(تفسیر ماجدی، فصل الخطاب)&& مدینہ میں یھودیوں کی کسی عید کا دن تھا جناب رسول خدا صلی اللہ علیہ و آلہ وسلم ان کے کنیسہ (عبادت گاہ) میں تشریف لے گئے ۔ پھر {{ آپ صلی اللہ علیہ و آلہ وسلم نے ان کومخاطب کرکے فرمایا: ’’اے قوم یھود!تم اپنے بارہ آدمی میرے سامنے لاؤ جو خدا کی وحدانیت اور  میری نبوت کی گواہی دیں اس طرح خداوند کریم تمام دنیا کے یھودیوں سے اپناغضب اٹھا لے گا‘‘۔ سارے یھودی خاموش رہے۔ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے یہی بات تین مرتبہ دہرائی،مگر کسی نے جواب نہ دیا۔ پھر آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’تم لوگوں نے حق بیان کرنے سے انکار کیا ہے جبکہ خداوند عالم نے مجھے >>حاشر<< اور >>عاقب<< (کے القاب سے توراۃ میں ) یاد فرمایا ہے۔ چاہے تم ایمان لے آو یا تکذیب کرو‘‘۔ یہ فرما کر آپ صلی اللہ علیہ و آلہ وسلم اٹھےاور  واپس جانے لگے ابھی کنیسہ سے آپ نے صرف ایک قدم باہر نکالاتھا کہ ایک یھودی ان میں سےآیا اور  اس نے آواز دی:’’اےمحمد صلی اللہ علیہ و آلہ وسلم !ٹھہر جاؤ۔ پھر یھودیوں سے کہا: ’’تم مجھے کیسا آدمی پاتے ہو؟ سارے یھودیوں نے کہا خدا کی قسم ہمارے درمیان تم سے بڑا کوئی عالم نہیں ہے۔ اس یھودی عالم نے کہاـ :ـ’’میں خدا کو گواہ بنا کر کہتا ہوں کہ یہ وہی پیغمبر صلی اللہ علیہ و آلہ وسلم ہیں جن کا اکثر ذکر توراۃ و انجیل میں آچکا ہے۔ یہ سنتے ہی سارے یھودیوں نے اسے خوب جی بھرکے گالیاں دیں ۔ "آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا: تم سب جھوٹے ہو اقرارکے بعد تمھارا انکار قبول نہیں ہے"۔&&(تفسیر مراغی جلد۲۶)&& }}
  46,11,آیت نمبر۱۱ : ایت کاشان نزول :یہ آیت حضرت ابوذرغفاریؓ کے بارے میں اتری ہے جب وہ مکہ میں اسلام لائے توکفار قریش نے کہاکہ اگر اسلام کوئی اچھی چیز ہوتا تو شہر کے بڑے بڑے امیر سردار اسلام قبول کرلیتے ،رہے یہ صحرا کے رہنے والے کنگلے فقیر تو ان کے اسلام لانے کی کوئی حقیقت و قیمت نہیں ہے ۔کیونکہ یہ بے وقعت لوگ ہیں اگراسلام واقعی سچا دین ہوتو یہ معمولی لوگ ہم سے آگے نہیں بڑھ سکتے تھے۔ یہ طنز تھا حضرت ابوذرغفاریؓ پر جو صحرا نشین قبیلے کے فرد تھے۔ ان کے علاوہ صہیبؓ رومی، بلالؓ حبشی، عمارؓ یاسربھی غریب و نادار لوگ تھے جواسلام لائے تھے پھر جب عبداللہ بن سلام جیسے علماء ایمان لائے توان باتوں سے قریش بری طرح چڑنے لگے اور  کہنے لگے کہ اگراسلام کوئی چیز ہوتا تو یہ فقیر ونادار ہم سے آگے نہیں بڑھ سکتے تھے۔&&(تفسیر قرطبی ،جلد۹،مجمع البیان)&& [[ آکے ہوتے ہیں جومسجد میں صف آرا‘ تو غریب ۔ زحمتِ روزہ جو کرتے ہیں گوارہ‘ تو غریب ۔ نام لیتا ہے اگرکوئی ہمارا‘ تو غریب ۔ سجدہ کرتے ہے اگر کوئی ہمارا‘ تو غریب ۔ امراء نشۂ دولت میں ہیں غافل ہم سے ۔ دیں ہمارا جوہے قائم ۔ غرباء کے دم سے ]] &&(جواب شکوہ ازعلامہ اقبالؔ)&&!! وہ دوسرا استدلال یہ پیش کرتے تھے کہ یہ قرآن پرانا جھوٹ ہے۔ وہ اسے نیا جھوٹ اس لیے نہیں کہہ سکتے تھے کہ تمام آسمانی کتابوں میں ہمیشہ سے یہی توحید ،رسالت اور آخرت کا پیغام دیا جاتا رہا ہے اس لیے قرآن کو انھوں نے پرانا جھوٹ کہا۔ ان کا مطلب یہ تھاکہ سارے سر پھر ے انبیاء علیہم السّلام (معاذ اللہ) یہی خرافات بکتے چلے آئے ہیں کہ خدا اکیلا( ایک) ہے۔ ہم اللہ کا پیغام سنانے آئے ہیں اور  ایک دن تمھیں اللہ کے سامنے اپنے اعمال کاحساب کتاب دینا ہوگا۔ یہ سب پرانے گھڑے گھڑائے جھوٹ ہیں ۔&&( تفسیر کبیر، تفہیم، مجمع البیان ،انوار النجف)&&
  46,13,آیت نمبر۱۳:کامیابی کی دو۲ شرطیں :(۱) ایمان لانا۔(۲) پھر اس پرقائم رہنا۔اصل میں یہ ان لوگوں کی تعریف کی جارہی ہے جو ہمیشہ حق پرڈٹے رہتے ہیں کبھی باطل سے نہیں دبتے ۔دوسرے الفا ظ میں یوں کہاجاسکتا ہے کہ کسی دورکے یزید کی بیعت نہیں کرتے ۔ دنیا والے انھیں ضدی کہتےہیں مگر قرآن ان کی تعریف کررہاہے اور ان کے کردار کومثالی حیثیت سے پیش کررہا ہے۔ &&(فصل الخطاب)&& [[ ؂ستیزہ کاررہا ہے ازل سے تا امروز۔چراغ مصطفوی صلی اللہ علیہ و آلہ وسلم سے شرار بولہبی۔موسٰی علیہ السّلام وفعون وشبیر علیہ السّلام ویزید۔؂ایں دو قوت از حیات آمد پدید۔]] (اقبالؔ)
  46,15,آیت نمبر۱۵:{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام نے اپنے آبائے طاہرین علیہ السّلام کے حوالوں سے روایت فرمایا ہے کہ:حضرت امام حسین علیہ السّلام کی ولادت:!!جب حضرت امام حسین علیہ السّلام اپنی والدہ ماجدہ طاہرہ جناب فاطمہ زہریٰ علیہا السّلام کے حمل میں تھے توجبریل علیہ السّلام نے جناب رسول خداصلی اللہ علیہ و آلہ وسلم کواللہ تبارک وتعالیٰ کا یہ پیغام سنایا کہ عنقریب جوبچہ جناب فاطمہ زہریٰ علیہا السّلام کے ہاں تولید ہوگا آپ صلی اللہ علیہ و آلہ وسلم کی امت اسے قتل کردے گی۔اس بنا پر جناب سیدہ طاہرہ علیہ السّلام کو رنج ہوا۔ اسی لیے یہ آیت نازل ہوئی۔ پھر جبریل علیہ السّلام ،جناب رسول خداصلی اللہ علیہ و آلہ وسلم کے پاس یہ خوشخبری لائے کہ اللہ تبارک وتعالیٰ آپ صلی اللہ علیہ و آلہ وسلم پر سلام بھیجتا ہے اور یہ خوشخبری دیتا ہے کہ وہ اس بچے (امام حسین علیہ السّلام ) کی اولاد میں امامت ‘ولایت اور وجاہت کوقراردے گا۔( امام حسین علیہ السّلام نے کسی عورت کا دودھ نہیں پیا): اس پر جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’میں راضی ہوں ‘‘ پھرجب جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے یہ خبر جناب فاطمہ زہریٰ علیہا السّلام کو سنائی تو وہ بھی راضی ہوگئیں ۔ اور  امام حسین علیہ السّلام نے کسی عورت کا دودھ نہیں پیا۔ حضوراکرم صلی اللہ علیہ و آلہ وسلم اپنا انگوٹھا ان کے منھ میں دیدیتے تھے جس سے دودھ جاری ہوتا تھا، اور  وہی ان کی غذا تھی ۔لہٰذا ان کا گوشت اور خون پیغمبراکرم صلی اللہ علیہ و آلہ وسلم کے خون سے ہے۔&&(تفسیر انوار النجف ج۱۳،ص۲۴)&& یہ آیت امام حسین علیہ السّلام کی دعاء قرارپائی }}۔ {{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ : اگرامام حسین علیہ السّلام نے << ’’اَصْلِحْ لِيْ فِيْ ذُرِّيَّتِيْ >> (میری اولاد میں سے کچھ کی اصلاح فرمادے کے بجائے << ’’اَصْلِحْ لِيْ ذُرِّيَّتِيْ ‘‘ >> (میری پوری اولاد کی اصلاح فرمادے) فرمایا ہوتا توآپ علیہ السّلام کی ساری کی ساری اولاد ’’امام‘‘ ہوتی۔ نیز یہ کہ سواحضرت یحییٰ علیہ السّلام اور  امام حسین علیہ السّلام کے کوئی بچہ چھ ماہ کا پیدا ہوکر زندہ نہیں رہا۔ &&(تفسیر صافی ص۴۶۳بحوالہ کافی)&& }} محققین نے لکھا: کیونکہ حمل اور  دودھ بڑھائی کی مدت یہاں تیس مہینے بنائی گئی ہے۔ اور  دوسری جگہ قرآن مجید میں جو دودھ بڑھائی کی مدت<< ’’حَوْلَیْنِ کَامَلَیْنِ‘‘ >> @@ (پورے دوسال) @@ بتائے ہیں ۔ اب اگر تیس مہینوں میں سے دوسال کے چوبیس مہینے نکال دیے جائیں توصرف چھ مہینے بچتے ہیں اس سے معلوم ہوا کہ قرآن مجید کی رو سے کم سے کم مدت حمل چھ مہینے ہے۔ &&(تفسیر تبیان، انوارالنجف)&&!! نتائج وتعلیمات:(۱) ماں کاحق باپ کے حق سے زیادہ ہے۔ کیونکہ ماں بچے کیلئے باپ سے کہیں زیادہ تکلیفیں برداشت کرتی ہے۔ {{ اسی لیے روایت میں ہے کہ ایک صحابی نے جناب رسول خداصلی اللہ علیہ و آلہ وسلم کی خدمت میں عرض کیا کہ خدا کے بعد مجھ پرسب سے زیادہ کس کا حق ہے؟ آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا:<< اُمُّکَ >>: تیری ماں کا۔ انھوں نے پھردریافت کیاکہ :پھر کس کا؟آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا:<< اُمُّکَ >>: تیری ماں کا۔انھوں نے پھر دریافت کیاکہ : پھر کس کا؟آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا:<< اُمُّکَ >>: تیری ماں کا۔جب چوتھی مرتبہ بھی یہی دریافت کیا گیا تو آنحضرت صلی اللہ علیہ و آلہ وسلم نے فرمایا:<< اَبُوْکَ >> (اب تیرے باپ کا حق ہے) &&(بخاری، مسلم ،ابودائود، ترمذی، ابن ماجہ ،مسنداحمد، ادب المفرد ،تفسیرکبیر، تفسیر مجمع البیان ،تفسیر روح المعانی جلد۲۶۔ اصول کافی) && }}(۲)دوسرانتیجہ یہ نکلاکہ بچہ استقرار حمل کے بعد چھ مہینے میں بھی پیدا ہوسکتا ہے۔
  46,16,آیت نمبر۱۶:خداوند عالم کا مومن کےلیے یہ فرمان ہے کہ اور  ان کی غلطیوں کومعاف کردیں گے۔ اس سے محققین نے نتیجہ نکالا کہ خداوند عالم کے ان الفاظ سے خارجیوں کا یہ عقیدہ باطل ہوگیا کہ:’’ مومن وہ ہوتا ہے جوگناہ نہیں کرتا‘‘۔ &&(تفسیر کبیرامام رازی)&& خلوص عمل کا اجر:مطلب یہ ہے کہ جن لوگوں کی یہ دعا یا یہ آرزو تھی۔ (ا) انھوں نے جودنیا میں اچھے کام کیے ہوں گے ان میں ہرکام کا اجر ہم وہ دیں گے جوان کاسب سے بہترین عمل ہوگا، یعنی ان کے گھٹیاعمل کابدلہ بھی سب سے بڑھیاعمل کے برابر دیں گے۔ (۲)دوسرا کام ہم یہ کریں گے کہ ان کی لغزشوں ،گناہوں ،کمزوریوں ،خطائوں پرانھیں نہیں پکڑیں گے ،یہ بالکل اسی طرح سے ہے جیسے کوئی سخی شریف آقا اپنے خادموں کی چھوٹی چھوٹی خطائوں کواس لیے نظرانداز کردیتا ہے کہ انھوں نے کوئی بڑا کارنامہ کیا ہوتا ہے۔(۳)یہ کہ ہم ان کوہرحال میں جنت والوں میں قرار دیں گے اس کو کہتے ہیں قدردانی ،اور  ہمارامالک سخی کریم ہے کہ مخلص خادموں کی کس قدر عزت افزائی اور  قدردانی فرما رہا ہے۔ &&(تفسیر مجمع البیان ،انوار النجف، تفہیم ،تفسیر کبیر) && !!خدائے کریم کے شاکربندوں کےلیے عطائیں :(۱)خداوند کریم و رحیم نے ارشاد فرمایا: ’’ہم ان کے بہترین اعمال قبول فرماتے ہیں ‘‘۔ یعنی ان کے اعمال کی قبولیت کی ضمانت دی جارہی ہے۔ {{ فرزندرسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ :ـ’’وہ عمل چھوٹاعمل نہیں ہوسکتا جس کوخدائے بزرگ وبرترین کی بارگاہ میں شرف قبولیت حاصل ہوجائے ‘‘۔ &&(الحدیث النبوی)&& }} (۲)دوسرے یہ کہ ’’ایسے لوگوں کے دوسرے تیسرے، چوتھے، درجے کے نیک اعمال کا ثواب بھی ان کے اول درجے کے بہترین اعمال کے برابر دیا جائے گا۔ یعنی ان کے کم درجے کے نیک اعمال کوبلندوبرتر Upgrade کردیاجائے گا۔(۳)ایسے لوگ اصحاب جنت میں سے ہوں گے۔(۴)اور  یہ بات یقینی طورپر ہوگی، کیونکہ ان کےلیے تاکیداً فرمایا:’’ان سے یہ کیا جانے والاوعدہ سچا وعدہ ہے‘‘۔(۵)ان کے گناہوں کومعاف کردیا جائے گا۔کیونکہ خود فرمایا:’’ہم ان کے گناہوں سے درگزرکریں گے‘‘ ۔ اب اس کے بعد کیا نعمت اور  کونسی کامیابی باقی رہ گئی ہے؟ [[ مقامِ ہمسفروں سے ہو اس قدر آگے۔کہ سمجھے منزلِ مقصود کارواں تجھ کو ]] (اقبالؔ) اس سے ثابت ہواکہ دین وایمان کاحاصل جذبہ شکرہے۔{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ : ’’جوشخص یہ چاہتا ہے کہ اس کی نعمتوں میں مسلسل اضافہ ہی ہوتا چلا جائے اور کبھی کمی نہ ہواس کوچاہئیے کہ وہ خداوند عالم کی عطا کرد ہ نعمتوں کا شکربجا لاتا رہے ‘‘۔ &&(الحدیث النبوی)&& }} !!{{ فرزندرسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام حسین علیہ السّلام نے فرمایا: ’’عبادتیں تین قسم کی ہیں :(۱) << ’’اِنَّ قَوْمًا عَبَدُواللہَ رَغْبَۃً فَتِلْکَ عَبَادَۃُا؛لتُّجَّارِ‘‘ >> (ایک جماعت نے اللہ کی عبادت ثواب کی رغبت اور امید میں کی ،یہ تاجروں جیسی عبادت ہے۔)(۲)<< ’’وَاِنَّ قَوْمًا عَبَدُواللہَ رَھْبَۃً فَتِلْکَ عِبَادَۃُ الْعَبِیْدِ‘‘ >> (اور ایک گروہ نے اللہ کی عبادت عذاب کے خوف سے کی، یہ غلاموں جیسی عبادت ہے۔)(۳) <<’’وَاِنَّ قَوْمًا عَبَدُواللہَ شُکْرًا فَتِلْکَ عَبَادَۃُ الْاَحْرَارِ‘‘ >> (اور ایک جماعت نے اللہ کی عبادت ازراہ شکرگذاری کی، یہ (البتہ) آزاد اور  شریف لوگوں جیسی عبادت ہے۔) << ’’وَتِلْکَ اَفْضَلُ الْعِبَادَۃِ‘‘ >> (اور یہ سب سے افضل عبادت ہے‘‘۔ &&(تحفۃ العقول ،الکافی، بلاغۃ الحسین علیہ السّلام ص۲۲۲)&& }} !!{{جناب امیرالمومنین حضرت امام  علی ابن ابی طالب علیہ السّلام نے اللہ تعالیٰ سے مناجات میں عرض کیا ۔’’مالک! میں تیری عبادت جہنم کے خوف سے نہیں کرتا ،نہ تیری عبادت جنت کے لالچ میں کرتاہوں بلکہ میں تیری عبادت صرف اس لیے کرتا ہوں کہ << ’’اَنْتَ اَھْلٌ لِلْعِبَادَۃِ‘‘ >> (توعبادت کے لائق ہے۔) &&(نہج البلاغہ)&& }}!! {{جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:’’کھانا کھا کراللہ تعالیٰ کا شکرادا کرنے کا ثواب ایسا ہے جیسے اللہ کےلیے روزہ رکھنے کا ثواب ‘‘۔ صاحب عافیت کاعافیت پرشکرادا کرنا ایسا ہے جیسے کوئی مبتلائے بلاہواور اس پر صبر کرے، اور مالدار کا شکرادا کرنا ایسا ہے کہ جیسے کوئی حالت فقر میں قانع رہا ہو۔&&(روح الحیات ،علامہ مجلسیؒ)&& }} !!{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام نے فرمایا: ’’بندے کوہرنعمت پرزبان سے الحمدللہ کہناچاہئیے اور اللہ تعالیٰ اگردولت عطا فرمائے تواس کا شکرادا کرنا یہ ہے کہ ضرورت مندوں کی مدد کرے۔……الخ &&(روح الحیات ص۲۶۳)&& }}
  46,17,آیت نمبر۱۷:اُف:ناگواری کی شکل میں سب سے چھوٹا لفظ ’’اُف‘‘ بولاجاتا ہے۔ اللہ تعالیٰ نے اس لفظ کوبھی ماں باپ کے سامنے بولناحرام کردیا۔ {{ نیزفرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’اگر>>اُف<< سے بھی کوئی چھوٹا لفظ ناگواری کے اظہار کےلیے ہوتا توخداوند بزرگ وبرتر اس کوبھی (والدین کے بارے میں )حرام قراردیتا‘‘ ۔ &&(الحدیث)&& }} اس سے خداوند عالم کی بارگاہ میں ماں باپ کا مقام اور احترام کی حد کا اندازہ لگایا جا سکتا ہے۔ گویا خداوند تعالیٰ نے ماں باپ کے سامنے ادنیٰ سے ادنیٰ تنگدلی کے اظہار کوبھی منع فرمایا ہے۔ &&(تفسیر ماجدی)&& عربی میں >>اُف<< کا لفظ جی گھٹنے اور تنگدلی ہونے کے اظہار کےلیے بولا جاتا ہے۔&&(لغت القرآن نعمانی، بقول تغلب ادر اصمعی)&&!! بنی اُمیہ کی تحریف:’’امیرشام نے اپنے مدینے کے گورنر کوخط لکھا کہ لوگوں سے میرے بیٹے یزید کےلیے بیعت لو‘‘۔ جب یہ خط ملا تو مروان نے سارے اہل مدینہ کوجمع کیا اور  امیرشام کا خط پڑھ کرسنایا۔ حضرت عبدالرحمٰن بن ابوبکرؓ بھی تشریف فرما تھے۔ انھوں نے بلند آواز میں فرمایا کہ امیرشام کا یہ کام ہرقل اور  کسریٰ (رو م اور ایران کے بادشاہوں کا لقب ہے) بادشاہوں جیسا ہے وہ لوگ بھی اپنے بیٹوں ہی کو اپنا جانشین بناتے تھے، چاہے وہ کتنے ہی نا اہل کیوں نہ ہوں ۔ یہ سن کرمروان نے غصے میں چلا کر عبدالرحمٰن بن ابوبکرؓ سے کہا: ’’خاموش رہ، تو وہی ہے جس کے بارے میں قرآن کی یہ آیت اتری ہے۔ پھراس نے اسی آیت کوپڑھا: یعنی :’’جوشخص اپنے ماں باپ سے کہتا ہے کہ >>ف<< کیا مصیبت ہے۔ میں تم دونوں سے تنگ آچکا ہوں ‘‘۔ حضرت عائشہؓ (ام المومنین) نے مروان سے خطاب کرکے فرمایا: توجھوٹا ہے میں خوب جانتی ہوں کہ یہ آیت کس کی شان میں اتری تھی۔ اگر تو کہے تواس کا نام ونسب بھی بتادوں :؟ البتہ یہ سن لےکہ خدا و رسول صلی اللہ علیہ و آلہ وسلم نے تیرے باپ پراس وقت لعنت کی تھی جب تواس کی پشت میں تھا۔ یہ تو در اصل خدا و رسول صلی اللہ علیہ و آلہ وسلم کی لعنت تجھ پر ہے‘‘۔ &&(تفسیر روح النجنان ابوالفتوح رازی جلد۱۰،تفسیر قرطبی ج۹،ص۶۰۱۷)&& یاد رہے کہ حضرت عائشہؓ کا اشارہ قرآن کی اس آیت کی طرف تھا جس میں بنی امیہ کو >>شجر ملعونہ<<فرمایا گیا ہے۔ << ’’وَالشَّجَرَۃَ الْمَلْعُوْنَۃَ فِي الْقُرْاٰنِ۰……الخ‘‘ >> یاد رہے کہ مروان حکم کا بیٹا تھا۔ ابی العاص کا پوتا تھا اور  امیہ کا پڑپوتا تھا۔ &&(تفسیر نمونہ) && گویا بنی امیہ کاچشم و چراغ تھا۔ &&(مؤلف)&& شان نزول آیت ۱۷:اس آیت کی شان نزول مستند طریقے سے نہیں آئی ہے صرف نقل منقول کی حیثیت سے عبدالرحمٰن ابن ابوبکرؓ کا نام آیا ہے۔کیونکہ کتب تاریخ میں لکھا ہے کہ جب عبدالرحمٰن ابن ابوبکرؓ نے یزید کی بیعت کرنے سے انکار کردیا توامیرشام نے کہا کہ اس کےبارے میں تو یہ آیت اتری ہے ۔(پھراسی آیت کو پڑھا)اس پر جناب عائشہؓ نے انکار کردیا اور  فرمایا کہ نہیں ۔بلکہ یہ آیت دوسرے شخص کے بارے میں اتری ہے، عبدالرحمٰن ابن ابی بکرؓ کے بارے میں نہیں اتری ہے۔ بہرحال آیت کا مضمون بھی کسی خاص نام سے نہیں آیا ہے نہ کسی خاص آدمی کا ذکر معلوم ہوتا ہے۔ اب جو شخص بھی ایسا ہوگا،آیت اسی پرچسپاں ہوجائےگی۔&&(فصل الخطاب ،مجمع البیان)&& مقصد یہ ہےکہ اللہ تعالیٰ نے آیت مجیدہ میں والدین سے نیکی کرنے کاحکم دیا ہےاور  والدہ کے خصوصی حق کا الگ تذکرہ فرمایا ہے ۔گویا والدہ کے حق میں زیادہ تاکید فرمائی ہے۔ پس اولاد پرواجب ہے کہ اپنے والد ین کے حقوق کے پیش نظران کی کماحقہ خدمت بجالائیں جب انسان اپنی جوان اولاد کےذریعہ سے اپنے والدین کے حقوق کوعملی طورپرسمجھنے کے قابل ہوتا ہے تواپنے حقوق سے عہدہ برآ ہونے کےلیے اپنے پروردگار سے توفیق کا طالب ہوتا ہے جس کا ذکر آیت مجیدہ میں فرمایا گیا ہے……الخ۔&&(انوار النجف)&&
  46,18,آیت نمبر۱۸:{{ فرزند رسول خداصلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سےروایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا:’’ قیامت کے آنے (اور  معذب قسم کے لوگوں ) کی علامت یہ ہے کہ وہ لوگ نجوم پر یقین رکھتے ہوں گے اور خداوند عالم کی قضاوقدر کوجھٹلائیں گے ۔ حقیقی علم مٹ جائے گا اور  جہالت کاغلبہ ہوگا خمر (شراب) نوشی اور  زناکاری عام ہوگی۔ مردکم اور عورتیں زیادہ ہوجائیں گی۔ یہاں تک کہ پچاس عورتوں پر صرف ایک مرد ہوگا۔&&(الکافی)&& ( یعنی جیسے بکریوں کے ریوڑ میں ایک بکرا ہوتا ہے۔) }}
  46,20,آیت نمبر۲۰:دنیا میں مزے اڑانے والے:خداوند عالم کا فرمانا:’’تم نے اپنے حصے کی نعمتوں سے خوب خوب فائدہ اور مزہ اٹھا لیا‘‘۔ عربی میں << ’’اِسْتَمْتَاعْ‘‘ >> کا لفظ لذت اٹھانے اور  مزہ لینے کےلیے استعمال ہوتا ہے۔ لذت اٹھانا گناہ نہیں ہوتا، لیکن وہ لذتیں مراد ہیں جوخدائے تعالیٰ اور آخرت کوبھلانے کی وجہ حرام چیزوں سے حاصل کی جاتی ہے۔مطلب یہ ہے کہ تم نے خداوند بزرگ وبرتر اور  آخرت کو بھلا کرحرام لذتوں سے جی بھرکے مزہ لے لیاحلال وحرام کا کوئی فرق باقی نہ رکھا۔ اب اس مزے کا اصل مزہ چکھوجوتمھیں ذلیل کرنے والی سزا سے ملے گا۔ اصل میں یہ لطیف طنزہے۔ &&(تفسیر صافی)&& {{ جناب رسول خداصلی اللہ علیہ و آلہ وسلم کے سامنے کھجور اور گھی ملاہوا حلوہ پیش کیا گیا۔آپ صلی اللہ علیہ و آلہ وسلم نے اس کوکھانے سے انکار فرما دیا۔ دریافت کیا گیا کہ کیا یہ حرام ہے؟‘‘آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’نہیں ، لیکن میں نے اس بات کوپسند نہیں کیا کہ کہیں میرا نفس اس کا شوقین (عادی) نہ ہوجائے ‘‘ ۔ پھرآنحضرت صلی اللہ علیہ و آلہ وسلم نے اسی آیت کو تلاوت فرمایا۔ &&(المحاسن) && }} محققین نے اس آیت سے نتیجہ نکالاکہ (۱)لذات دنیا میں کھوجانا غفلت اور  خداوندعالم سے دوری کاسبب ہوتا ہے، اور یہ سب سے بڑاخطرہ ہے۔ && (مرشد تھانوی) && {{ ایک دفعہ حضرت عمرؓ نے حضور اکرم صلی اللہ علیہ و آلہ وسلم کو کھجورکی چٹائی پرلیٹے ہوئے دیکھا آپ صلی اللہ علیہ و آلہ وسلم کے بدن کا کچھ حصہ مٹی پرہے اور  سراقدس کے نیچے کھجور کے کچھ پتے ہیں ۔ حضرت عمرؓ نے عرض کی: آپ صلی اللہ علیہ و آلہ وسلم اللہ کے رسول ہیں, اللہ تعالیٰ کی بہترین مخلوق ہیں ،قیصر وکسریٰ (روم وعجم کے بادشاہ) تو سونے کے تختوں اور  ریشمی بستر وں پر سوئیں اور  آپ صلی اللہ علیہ و آلہ وسلم کی یہ حالت زار ہے؟ حضور اکرم صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: وہ ایسے لوگ ہیں جن کے طیبات (نعمتیں ) اسی دنیا میں دے دیے گئے جوجلد ختم ہوجائیں گے جبکہ خداوند تعالیٰ نے ہمارے طیبات (نعمتوں ) کو آخرت کےلیے ذخیرہ کررکھا ہے۔ &&(تفسیر مجمع البیان جلد۹ص۸۸) && }} !!ایک دفعہ {{ حضرت امام علی علیہ السّلام نے بھنی ہوئی کلیجی اور  نرم روٹی کی خواہش ظاہرفرمائی ۔حضرت امام حسین علیہ السّلام نے کلیجی بھنوا کر نرم روٹی پکوائی اور  حضرت علیہ السّلام کی خدمت میں پیش کی اتنے میں ایک سائل نے دروازے پردستک دی حضرت امام علی علیہ السّلام نے حکم دیا کہ یہ سارا کھانا سائل کودے دیاجائے، ایسا نہ ہوکہ کل روزقیامت ہم اپنا نامہ اعمال پڑھیں تو اس میں لکھاہو:<< ’’ اَذْہَبْتُمْ طَيِّبٰتِكُمْ……الخ‘‘>> تم اپنی طیبات کے مزے دنیا ہی میں حاصل کرچکے "۔ &&(سفینۃ البحار جلد۲مادہ کبد)&& }}
  46,21,آیت نمبر۲۱: << احقاف >>:<<’’حقف‘‘ >> کی جمع ہے عربی میں حقف ایسے ریتلے مستطیل اور  اونچے میدان کو کہتے ہیں جس کے اونچے نیچے ٹیلے ہوں ۔ &&(تفسیر صافی ،مفردات القرآن راغب)&& <<’’اَحْقَافِ‘‘>> سے یہاں مراد قوم عاد کاعلاقہ ہے جوشقوق سے اجفر تک چار منزلوں میں پھیلا ہواتھا۔ خداوند عالم نے حضرت ھود علیہ السّلام پیغمبر کویہاں بھیجا۔ مگر لوگوں نے دولتمند ہونے کی وجہ سے ان کی ایک نہ سنی۔ خداوند تعالیٰ نے تنبیہ کے طورپر سات سال کے لیے بارش کوروک دیا۔ جس سے قحط پڑگیا۔ مگر وہ پھربھی نہ مانے۔ آخر کار ان کے تمام شہر سے برکت اٹھ گئی۔حضرت ھود علیہ السّلام نے لاکھ سمجھایا، ڈرایا کہ اب تواللہ تعالیٰ سے معافی مانگ لو ہوش میں آجاؤ ،اللہ تعالیٰ کی اطاعت کی طرف لوٹ آؤ۔ مگر انھوں نے ایک نہ سنی۔آخر کارخداوند عالم نے حضرت ھود علیہ السّلام کو وحی فرمائی کہ اب ان پر ہوا کے ذریعہ براعذاب آئے گا۔ کچھ دیر بعد بادل امڈ آئے۔ پوری قوم ناچنے گانے لگی ۔مگران بادلوں سے باران رحمت کے بجائے خوب آگ برسی۔ اس سے قبل حضرت ھود علیہ السّلام مومنین کولے کروہاں سے محفوظ مقام پرچلے گئے تھے۔ ہوا نے ان منکروں کی لاشیں پہلے مٹی میں دبائیں ۔ پھرمٹی بنا کرلاشوں کوسمندرمیں پھینک دیا۔ &&(تفسیر قمی ،تفسیر کبیر ،تفسیر نمونہ،تفسیر مجمع البیان ،تفسیر انوار النجف)&& حضرت ھودعلیہ السّلام کا پیغام:(۱)حضرت ھود علیہ السّلام کا پیغام: << ’’لَا تَعْبُدُوْٓا اِلَّا اللہَ۰ۭ ‘‘ >>تھا یعنی : @@(اللہ کے سوا کسی کی بندگی نہ کرو۔) @@ یعنی : عاجزانہ اطاعت نہ کرو۔یہ خالص توحید کا پیغام ہے۔ (۲)پھرفرمایا: میں تمھارے بارے میں ایک برے دن کی سزا سے ڈرتا ہوں ۔ گویا قیامت کے دن سے ڈرایا جا رہا ہے۔ مگرقوم نے کہا: کیا تواس لیے آیا ہے کہ ہمیں ہمارے معبودوں سے پھیردے۔(۳)حضرت ھود علیہ السّلام نے لاکھ سمجھایاکہ ’’اب توخدا سے معافی مانگ لو اور  اس کی طرف (اطاعت کی طرف) لوٹ آؤ۔ &&(القرآن سورۃ ھود۔ آیت ۵۲، پارہ ۱۲)&&
  46,28,آیت نمبر۲۸:{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام نے فرمایا:’’ ہماری شفاعت ،بغیر خداوند عالم کی اطاعت کے تم تک نہیں پہنچ سکتی‘‘ ۔ &&(اصول کافی) && یعنی : ہم خدا کی اجازت سے صرف اور صرف ان کی شفاعت کرسکتےہیں جواللہ کی اطاعت کرتےہیں ۔ البتہ اس میں کچھ کمی یاخامی رہ جاتی ہے ۔اس کوہم شفاعت سے پورا کردیں گے۔ &&(مؤلف)&& }}
  46,29,آیت نمبر۲۹:قرآن اور  حضوراکرم صلی اللہ علیہ و آلہ وسلم جنوں کےلیے بھی ذریعہ ہدایت ہیں :ان آیات سے ثابت ہوگیا کہ یہ جنات حضرت موسٰی علیہ السّلام اور آسمانی کتابوں کوپہلے سے مانتے تھے، اس لیے قرآن کے سننے کے بعد ان کو یہ محسوس ہواکہ یہ وہی تعلیم ہے جوپچھلے انبیاء کرام علیہم السّلام دیتے چلے آرہے ہیں اسی لیے وہ قرآن اور ہمارے رسول صلی اللہ علیہ و آلہ وسلم پر ایمان لے آئے۔&&( تفسیرنمونہ، تفسیر مجمع البیان ،تفسیر کبیر، تفہیم)&&!! دوسری شان نزول:یہ لکھی ہے کہ اور یہ ممکن ہے کہ یہ دوسرا وقعہ ہوا ہوکہ ایک دفعہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم مکہ سے طائف کے بازار عکاظ میں تشریف لے گئے ۔ زید بن حارثہ آپ صلی اللہ علیہ و آلہ وسلم کے ساتھ تھے۔ جب وہاں کسی نے آنحضرت صلی اللہ علیہ و آلہ وسلم کی دعوت قبول نہ کی تومکہ کی طرف واپس ہوئے ۔جب وادی مجنہ میں پہنچے توآپ صلی اللہ علیہ و آلہ وسلم نے نماز تہجدپڑھی۔ توجنوں کا ایک گروہ آپ صلی اللہ علیہ و آلہ وسلم کے پاس سے گزر رہاتھا ،انھوں نے جب قرآت قرآن کی آواز سنی توقیام کیا اور قرأت سننے میں مصروف ہوگئے اور ایک دوسرے سے کہنے لگے کہ خاموشی سے غور وتوجہ کے ساتھ سنو، یہ سن کروہ بہت متاثرہوئے۔ جب آنحضرت صلی اللہ علیہ و آلہ وسلم نے قرأت ختم کی، تووہ اپنی قوم کی طرف چلے گئے ۔جاکر ان کواسلام قبول کرنے کی دعوت دی۔ چنانچہ وہ سب حضور اکرم صلی اللہ علیہ و آلہ وسلم کی خدمت میں  حاضر ہوکرایمان لائے اور آپ صلی اللہ علیہ و آلہ وسلم نے ان کواسلام کے احکامات تعلیم فرمائے۔ پھرسورہ جن نازل ہوئی اور  آنحضرت صلی اللہ علیہ و آلہ وسلم نے ان پرایک والی بھی مقررفرمایا اور  وہ وقتاً فوقتاً حضوراکرم صلی اللہ علیہ و آلہ وسلم کی خدمت میں حاضر ہو کر مسائل بھی دریافت کیا کرتے تھے۔ پھر آنحضرت صلی اللہ علیہ و آلہ وسلم نے ان کی تعلیم حضرت امام  علی ابن ابی طالب علیہ السّلام کے سپرد فرمائی ۔ پس جنوں میں بھی مسلمان ،مومن، یھودی، نصرانی ،مجوسی وغیرہ ہرقسم کے افراد ہوا کرتے ہیں ۔اور  یہ سب جآن کی اولاد ہیں ۔ اس بات سے صاف ظاہرہے کہ حضوراکرم صلی اللہ علیہ و آلہ وسلم جس طرح انسانوں کے نبی تھے اسی طرح جنوں کے بھی نبی تھے۔ لہٰذا آنحضرت صلی اللہ علیہ و آلہ وسلم کے بعد آپ صلی اللہ علیہ و آلہ وسلم کا قائم مقام وجانشین وہی ہوسکتا ہے جوانسانوں اور جنوں دونوں کواسلامی مسائل سے مطمئن کرسکے۔&&( تفسیر نورالثقلین جلد۵، تفسیر علی ابن ابراہیم، تفسیرانوارالنجف)&& نیز قوم جن کے رؤسا میں سے نو افراد جو حضوراکرم صلی اللہ علیہ و آلہ وسلم کی خدمت میں حاضرہوئے تھے جنھوں نے کفرکوچھوڑکرایمان واسلام کوقبول کرلیا تھا۔ ان میں سے ایک نصیبین کا رہنے والا تھا اور باقی آٹھ اجحر کے علاقے سے عمروبن عامر کی اولاد سے تھے جن کے نام یہ ہیں ۔(۱)شضاۃ(۲) مضاۃ(۳)مہسا(۴)رزبان(۵)مزمان(۶)یضاہ(۷)ہاضب اور  (۸)عمرو اور یہ قوم آنحضرت صلی اللہ علیہ و آلہ وسلم کی خدمت میں وادی نخل یا وادی مجنہ میں حاضر ہوئی، ان کے بعد اکہترہزار جن آئےجنھوں نے آنحضرت صلی اللہ علیہ و آلہ وسلم کی بیعت کی تھی۔ &&(اور  یہ فضل حضرت سلیمان علیہ السّلام سے بدرجہا بہترتھا) &&(تفسیر برہان بروایت احتجاع طبرسیؒ، تفسیر انوارالنجف)&& !!قرآن مجید کی حقانیت پرجنوں کا استدلال:جنوں نے قرآن مجید کی حقانیت پر سات دلیلیں بیان کیں :(۱) قرآن مجید پچھلے انبیاء علیہم السّلام کی تعلیمات سے ہم آہنگ ہے۔(۲)قرآن مجید حق کی طرف بلاتا ہے۔(۳)قرآن مجید کی تعلیمات سیدھے راستے پرچلنے کی ہدایت کرتی ہیں ۔ اور سیدھا راستہ دکھاتی ہیں ۔(۴)قرآن مجید کی تعلیمات پرعمل کرنے سے خداوند تعالیٰ پچھلے گناہ معاف کردیتا ہے ۔کیونکہ … قرآن مجید کی تعلیمات پر عمل کرنے سے انسان وجن سب کی اصلاح احوال ہوجاتی ہے۔ (۵)قرآن مجید کی تعلیمات پرعمل کرکے انسان وجن خداوندعالم کے دردناک عذاب سے بچ جاتا ہے۔ جوسب سے بڑی کامیابی ہے۔(۶)قرآن مجید کی تعلیمات کوجوشخص نہیں مانے گا وہ ہرگز خداوند عالم کے عذاب سے نہ بچ سکے گا۔(۷)قرآن مجید اور اس کے احکامات کوماننا اس لیے ضروری ہے کہ خدائےبزرگ وبرتر کے سوا ہمارا کوئی سرپرست اور  مددگار نہیں ہے۔ اس سے دشمنی مول لے کرہم تباہی سے ہرگز نہیں بچ سکتے۔&&(تفسیر نمونہ، مطابق، ۳۰،۳۱،۳۲)&&!! قرآن مجید کوغورسے سننے کا اثر:ملاحظہ فرمائیں کہ جنوں نے حضوراکرم صلی اللہ علیہ و آلہ وسلم سے کسی معجزے کا مطالبہ نہیں کیا صرف اور صرف قرآن مجید کوغورسے سن کراس قدرمتاثر ہوئے کہ فوراً ایمان لے آئے۔ اس سے معلوم ہواکہ جوشخص طلب حق رکھتا ہوگا اور وہ قرآن مجید کوغورسے پڑھے یا سنے گا، وہ ضرور اس پر ایمان لے آئیگا براہوعقل سے کام نہ لینے والوں کااور طلب حق نہ رکھنے والوں کا،اور دنیا طلبی اور مفاد پرستی کی وجہ سے حق کی مخالفت کرنے والوں کا،{{ (حضوراکرم صلی اللہ علیہ و آلہ وسلم نے ارشاد فرمایا: قرآن مجید اپنے پڑھنے اور غورسے سننے والوں کی روزقیامت شفاعت کرے گا اور  خداوند کریم سے کہے گا کہ میرے قاریوں اور بغورسننے اور عمل کرنے والوں )کوبہترین مقام عطا فرمائیے‘‘۔ اللہ تعالیٰ اس کی سفارش کوقبول فرمائے گا) &&(مؤلف)&&۔ &&(الحدیث از روح الحیات)&& }}
  46,35,آیت نمبر۳۵:صبروبرداشت سے کام لینے کا مشورہ:خداوند عالم کے اس ارشاد سے کہ آپ صلی اللہ علیہ و آلہ وسلم صبروبرداشت سے کام لیجئیے جس طرح عزم وہمت والے (اولوالعزم) رسولوں علیہ السّلام نے صبرسے کام لیا تھا۔ محققین نے نتیجہ نکالاکہ : صبر کا درجہ اتنا بلند ہے کہ یہ انبیاء کرام علیہم السّلام اور  ائمہ طاہرین علیہ السّلام کی خصوصیت ہے( خاص طورسے اولوالعزم رسولوں علیہ السّلام کی خصوصیت ہے۔) اولوالعزم پیغمبروں سے مراد صاحبان شریعت پیغمبر علیہ السّلام ہیں ،جنھوں نے اپنی شریعتوں کے پھیلانے ،سمجھانے اور پہنچانے میں سخت کوششیں کیں ۔ ہرقسم کی تکلیفیں برداشت کیں اور ہرحال میں ثابت قدم رہے۔ &&(تفسیر صافی)&&!!اوالعزم پیغمبر علیہ السّلام پانچ ہیں : {{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ :’’اوالعزم انبیاء کرا م علیہ السّلام پانچ ہیں : (۱) حضرت نوح علیہ السّلام (۲)حضرت ابراہیم علیہ السّلام (۳)حضرت موسیٰ علیہ السّلام (۴)حضرت عیسیٰ علیہ السّلام (۵)حضرت محمد مصطفیٰ صلی اللہ علیہ و آلہ وسلم )یہ حضرات علیہ السّلام اس لیے اوالعزم ہوئے کہ سب کتاب اور شریعت دونوں کے ساتھ بھیجے گئے اور  وہ پیغمبر علیہ السّلام جوحضرت نوح علیہ السّلام تک آئے وہ اسی کتاب اور شریعت کےپھیلانے والے تھے جوحضرت نوح علیہ السّلام کوعطا ہوئی تھی۔ پھر جب حضرت ابراہیم علیہ السّلام کے پاس کتاب اور شریعت آئی توحضرت نوح علیہ السّلام والی کتاب اور شریعت منسوخ کردی گئی، پھرحضرت ابراہیم علیہ السّلام والی کتاب اور  شریعت پرعمل ہوتا رہا۔ یہاں تک کہ حضرت موسٰی علیہ السّلام پرتوراۃ اور شریعت آئی۔اسی طرح ہوتا رہا، یہاں تک کہ حضرت محمد مصطفیٰ صلی اللہ علیہ و آلہ وسلم قرآن مجید اور  شریعت لائے پس آنحضرت صلی اللہ علیہ و آلہ وسلم نے جس چیز کوحلال بتایا ،وہ قیامت تک حلال رہے گی اور جس چیز کوحرام بتایا وہ قیامت تک حرام رہے گی۔ &&(الکافی، تفسیر مجمع البیان ،انوارالنجف ،برہان)&& }} !!کارِ رسالت میں صبر کرو:خداوندعالم کاجناب رسول خداصلی اللہ علیہ و آلہ وسلم سے یہ فرماناکہ: ’’اور ان کے معاملے میں جلدی نہ کرو‘‘ ۔ مطلب یہ ہے کہ اے نبی صلی اللہ علیہ و آلہ وسلم !جس طرح تم سے پہلے انبیاء کرام علیہم السّلام نے اپنی قوموں کی بے رخی اور  ایذا رسانیوں کوبرسوں برداشت کیا اور صبروسکون کے ساتھ ان کوسمجھاتے ہی رہے، اسی طرح تم بھی صبر وسکون کے ساتھ ان کوسمجھاتے رہو۔ یہ مت سوچوکہ یہ لوگ جلدی سے تمهاری باتیں مان لیں گے ،یا پھرخدائے تعالیٰ جلدی سے اپناعذاب نازل کردے گا۔ اصلاحی کام جلدی کے نہیں  ہوتے ،اس کے نتائج دیرسے برآمد ہوا کرتے ہیں عقل ونصیحت کی باتیں آہستہ آہستہ سمجھ ہیں آتی ہیں ۔ &&(تفسیر کبیر تفہیم ،مجمع البیان ،تفسیر نمونہ)&& جناب رسول خداصلی اللہ علیہ و آلہ وسلم کاعزم اور صبر:طائف سے واپسی پرلوگوں نے آپ صلی اللہ علیہ و آلہ وسلم پرپتھر مارے ،طنز کسے ،سرسے پائوں تک لہولہاں کردیا۔ جبریل علیہ السّلام تشریف لائے اور کہا: ’’ آپ صلی اللہ علیہ و آلہ وسلم بددعا کےلیے ہاتھ اٹھا دیں تومیں ان سب کونیست ونابود کردوں ۔ آپ صلی اللہ علیہ و آلہ وسلم نے دعاء کےلیے ہاتھ اٹھا دیے اور عرض کی:<< اَللّٰھُمَّ اھْدِقَوْمِیْ فَاِنَّھُمْ لَایَعُلَمُوْنَا >> اے اللہ !میری قوم کوہدایت عطافرما کیوں کہ وہ (مجھے) نہیں جانتے ۔ پھرآپ صلی اللہ علیہ و آلہ وسلم نے یوں دعا کی:’’مالک !میں اپنی کمزوریوں ،ناتوانیوں اور مجبوریوں ،بے احترامیوں کی تجھ ہی سے شکایت کرتا ہوں اے سب سے زیادہ رحم کرنےوالے !توہی کمزوروں کا پالنے والا مالک ہے توہی میرا پالنے والامالک ہے ،تومجھےکس کے حوالے کرے گا؟ کیا دوردراز کے ان رہنے والوںکے حوالے کرے گا جومجھے غصے سے دیکھتے ہیں ،یا میرے دشمنوں کے حوالے کرے گا۔ اگرتومجھ سے راضی ہوجائے تومیرے لیے یہ بہت کافی ہوگا۔&&(سیرابن ہشام جلد۲)&& یہ اخلاص فی العمل کی اعلیٰ ترین مثال ہے۔ &&(مؤلف)&& {{ حضرت امام  علی ابن ابی طالب علیہ السّلام فرماتے ہیں : رہبروں پرصبر و استقامت فرض ہے کیونکہ خداوند عالم نے جناب رسول خداصلی اللہ علیہ و آلہ وسلم سے فرمایا: آپ صلی اللہ علیہ و آلہ وسلم صبرکریں جیسے اولوالعزم رسولوں علیہ السّلام نے صبرکیا: اور خداوند عالم نے یہ بھی فرمایا: ’’رسول اللہ صلی اللہ علیہ و آلہ وسلم کی ذات تمھارے لیے بہترین نمونہ ہے (اس لیے تم سب کوان کی پیروی کرنی چاہیے۔ &&(تفسیر نورالثقلین جلد۵ ،احتجاج)&& }} !![[تیری معراج کہ تو لوح وقلم تک پہنچا۔میری معراج کہ میں تیرے قدم تک پہنچا ]] ۔ {{ حضرت محمد صلی اللہ علیہ و آلہ وسلم کے ذکر سے شروع ہونے والا سورہ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ : ’’جوشخص ہمارے اور ہمارے دشمنوں کے احوال دیکھنا چاہے اسے سورۃ محمد صلی اللہ علیہ و آلہ وسلم کی تلاوت کرنی چاہئیے‘‘ ۔ امام علیہ السّلام کے الفاظ سے از خود ثابت ہوگیا کہ تلاوت کے معنی بلا سمجھے پڑھنے کے نہیں ہوتے بلکہ سمجھ کرپڑھنے کے ہوتے ہیں۔آپ صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’کیوں کہ اس سورۃ کی ایک آیت ہمارے حق میں ہے اور ایک آیت ہمارے دشمنوں کے بارے میں ہے‘‘ ۔ &&(تفسیر مجمع البیان ،روح المعانی جلد۲۶،ص۳۳از آلوسی، تفسیر درمنثور سیوطی جلد۶،ص۴۶)&& }} اس حدیث سے معلوم ہواکہ ایمان کا کامل نمومہ ائمہ اہل بیت علیہم السّلام رسول خدا صلی اللہ علیہ و آلہ وسلم ہیں اور  کفر ونفاق کا کامل اور مجسم نمونہ بنی امیہ کے خلفاء اور ان کے طرف دار ہیں ۔کیونکہ سورۃ محمد صلی اللہ علیہ و آلہ وسلم میں مومن اور منافق گروہوں کے بارے میں بحث کی گئی ہے۔ اس لیے ان میں سب سےواضح ان دو مصداقوں کی طرف اشارہ ہے۔ دوسرے معنی میں اس سورۃ کی آیتیں تمام مومنین اور  منافقین پرصادق آتی ہیں ۔&& (تفسیر نمونہ)&& {{ جناب رسول خدا صلی اللہ علیہ و آلہ وسلم نے فرمایا:’’جوشخص سورۃ محمد صلی اللہ علیہ و آلہ وسلم کی تلاوت کرے گا( یعنی سمجھ کرپڑھے گا) اس کاخداوند کریم پریہ حق بن جاتا ہے۔ کہ خدائے بزرگ وبرتر اسے جنت کی نہروں سے سیراب کرے‘‘ ۔ &&(تفسیر مجمع البیان)&& }} !!{{ فرزند رسول خدا صلی اللہ علیہ و آلہ وسلم حضرت امام جعفرصادق علیہ السّلام سے روایت ہے کہ جناب رسول خداصلی اللہ علیہ و آلہ وسلم نے فرمایا: ’’جوشخص سورۃ محمد کی تلاوت کرے گا۔(۱)کبھی شک وشبہ اس کے دین میں داخل نہ ہوگا(ان الفاظ سے ثابت ہواکہ تلاوت کرنے کے معنی صرف الفاظ کوپڑھنا نہیں ہوتا بلکہ سمجھ کر پڑھنا ہوتا ،تاکہ سمجھ کرعمل بھی کرے )(۲)خداوند عالم اس کوکبھی دین کے معاملے میں دوسروں کا محتاج نہ کرے گا۔ اس کو بادشاہ کاخوف نہ ہوگا۔(۳)آخرعمر تک شرک وکفر سے محفوظ رہے گا۔ اور (۴)جب مرے گا توخداوند عالم ایک ہزار فرشتوں کوحکم دےگا اکہ اس کی قبر میں جاکر نمازادا کریں اور ان تمام نمازوں کا ثواب مرنے والے کے نامہ اعمال میں لکھیں ۔(۵)پھریہ ایک ہزار فرشتے قیامت تک اسی کے ساتھ ساتھ رہیں  گے۔ (۶)اور  روز قیامت اسے امن وامان کی (محفوظ) جگہ لاکرکھڑاکریں  گے۔(۷)وہ شخص ہمیشہ اللہ تعالیٰ اور  محمد مصطفیٰ صلی اللہ علیہ و آلہ وسلم کی امان میں رہے گا۔ &&(تفسیر نورالثقلین جلد۵،کتاب ثواب الاعمال)&& }}
