quran[15]{c,v,t}:
  112,1,"Айт (оо, Мухаммад:) Ал – Аллах жалгыз!"
  112,2,"Аллах – Сомад (Беймуктаж)"
  112,3,"Ал туубаган жана да туулбаган!"
  112,4,"Жана эч ким Ага тең эмес!"
  113,1,"Айт (оо, Мухаммад): «Таң Раббисинен коргоо тилеймин:[1]"
  113,2,"(Өзү) жараткан (зыяндуу) нерселердин жамандыгынан...,"
  113,3,"Каптап кирген учурдагы (караңгы) түндүн жамандыгынан...,[1]"
  113,4,"Түйүндөргө дем салган сайкырчылардын жамандыгынан...,"
  113,5,"Сугун арткан учурда, көрө албаган кишинин жамандыгынан.[1]"
  114,1,"Айткын (оо, Мухаммад): «Мен инсандардын Раббисинен"
  114,2,"Инсандардын падышасынан;"
  114,3,"инсандардын (сыйынууга татыктуу болгон) Кудайынан коргоо тилеймин –"
  114,4,"(Аллахтын ысымы айтылганда) жашынып калуучунун[1] жамандыгынан."
  114,5,"Ал (шайтан) адамдардын көкүрөгүнө азгырык салат."
  114,6,"Алар (азгыруучу шайтандар) жиндерден жана адамдардан болот.[1]"