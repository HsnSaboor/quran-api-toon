quran[29]{c,v,t}:
  91,1,والشمس وضحىها
  91,2,والقمر اذا تلىها
  91,3,والنهار اذا جلىها
  91,4,واليل اذا يغشىها
  91,5,والسماء وما بنىها
  91,6,والارض وما طحىها
  91,7,ونفس وما سوىها
  91,8,فالهمها فجورها وتقوىها
  91,9,قد افلح من زكىها
  91,10,وقد خاب من دسىها
  91,11,كذبت ثمود بطغوىها
  91,12,اذ انبعث اشقىها
  91,13,فقال لهم رسول الله ناقة الله وسقيها
  91,14,فكذبوه فعقروها فدمدم عليهم ربهم بذنبهم فسوىها
  91,15,ولا يخاف عقبها
  92,1,واليل اذا يغشى
  92,2,والنهار اذا تجلى
  92,3,وما خلق الذكر والانثى
  92,4,ان سعيكم لشتى
  92,5,فاما من اعطى واتقى
  92,6,وصدق بالحسنى
  92,7,فسنيسره لليسرى
  92,8,واما من بخل واستغنى
  92,9,وكذب بالحسنى
  92,10,فسنيسره للعسرى
  92,11,وما يغني عنه ماله اذا تردى
  92,12,ان علينا للهدى
  92,13,وان لنا للاخرة والاولى
  92,14,فانذرتكم نار ا تلظى