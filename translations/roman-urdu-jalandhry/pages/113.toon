quran[3]{c,v,t}:
  113,0,shuru allah ka naam le kar jo bara meharban nihayat reham wala hai
  113,1,kaho ke mein subah ke perwar-digaar ki panah mangta hon
  113,2,har cheez ki badi se jo is ne peda ki
  113,3,aur shab tareqi ki buraiee se jab is ka andhera chhaa jaye
  113,4,aur gandon par ( parh parh kar ) phoonknay valyon ki buraiee se
  113,5,aur hasad karne walay ki buraiee se jab hasad karne lagey
