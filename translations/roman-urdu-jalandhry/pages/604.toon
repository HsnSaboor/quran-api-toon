quran[15{c,v,t}:
112,1,kaho ke woh ( zaat pak jis ka naam ) allah ( hai ) aik hai
112,2,mabood barhaq jo be niaz hai
112,3,nah kisi ka baap hai aur nah kisi ka beta
112,4,aur koi is ka humsar nahi
113,1,kaho ke mein subah ke perwar-digaar ki panah mangta hon
113,2,har cheez ki badi se jo is ne peda ki
113,3,aur shab tareqi ki buraiee se jab is ka andhera chhaa jaye
113,4,aur gandon par ( parh parh kar ) phoonknay valyon ki buraiee se
113,5,aur hasad karne walay ki buraiee se jab hasad karne lagey
114,1,kaho ke mein logon ke perwar-digaar ki panah mangta hon
114,2,( yani ) logon ke haqeeqi badshah ki
114,3,logon ke mabood barhaq ki
114,4,( shetan ) waswasa andaaz ki buraiee se jo ( khuda ka naam sun kar ) peechay hatt jata hai
114,5,jo logon ke dilon mein was wasay dalta hai
114,6,woh jinnaat mein se ( ho ) ya insanon mein se
