quran[25{c,v,t}:
78,31,(۳۱) (لیکن یہ بھی) حقیقت ہے کہ متقین بُرائیوں سے بچنے والوں کے لئے کامیابی ہی کامیابی ہے۔
78,32,(۳۲) (اُن کے لئے) باغات (ہی باغات) اور انگور کی بیلیں ہوں گی۔ (انگور کھانے کو ملیں گے۔)
78,33,(۳۳) اور نوجوان ہم عمر لڑکیاں ہیں۔
78,34,(۳۴) شراب سے بھرے اور چھلکتے جام ہیں۔
78,35,(۳۵) وہ وہاں کسی قسم کی کوئی بیہودہ، بدمزہ، گندی اور جھوٹی بات نہیں سنیں گے۔
78,36,(۳۶) یہ صلہ ہوگا تمہارے پالنے والے مالک کی طرف کا، وہ بھی بطورِ عطا وانعام، جو بہت کافی بھی ہو گا اور اُن کے حسبِ حال بھی
78,37,(۳۷) (اُس عظیم ذات کی طرف سے) جو آسمانوں اور زمین، اور اُن کے درمیان کی تمام چیزوں کا مالک ہے، اور جو حد سے زیادہ مہربان، فیض پہنچانے والا ہے، اور (ایسا زبردست ہے، کہ) کسی کو اُس کے سامنے بولنے کی مجال نہیں۔
78,38,(۳۸) جس دن روح اور فرشتے صف باندھے کھڑے ہوں گے، کوئی بات تک نہیں کرسکے گا، سوا اُس کے جسے خدائے مہربان بولنے کی اجازت دے، اور جو ٹھیک ٹھیک بات کہے۔
78,39,(۳۹) وہ دن سچی حقیقت ہے لہٰذا اَب جو چاہے اپنے پالنے والے مالک کی طرف پلٹنے کا راستہ اختیار کر لے (یعنی پلٹنے کا سامان مہیّا کر لے)
78,40,(۴۰) (لو اَب) ہم نے تمہیں اپنی سزا سے ڈرا کر خبردار کر دیا ہے، جو بالکل قریب آ لگی ہے۔ جس دن ہر آدمی  وہ سب کچھ دیکھ لے گا جو اُس کے ہاتھوں نے آگے بھیجا ہے، اور حق کا منکر، کافر، چیخے گا کہ کاش میں مٹی ہوتا، (یعنی مر کر ہمیشہ کے لئے مٹی ہوجاتا اور دوبارہ زندہ نہ کیا جاتا۔)
79,1,(۱) قسم ہے ان (فرشتوں) کی جو (جسم کے اندر) ڈوب ڈوب کر (روح) کھینچتے ہیں،
79,2,(۲) وہ بھی بڑے آرام، آسانی اور آہستگی سے۔
79,3,(۳) اور جو (ہر جگہ) بڑی تیزی سے تَیرتے پھرتے ہیں۔
79,4,(۴) اور قسم ہے (اُن فرشتوں کی جو خدا کے حکم کو بجا لانے میں) دوڑ دوڑ کر ایک دوسرے سے آگے بڑھ جانے والے ہیں۔
79,5,(۵) اور (کائنات کے تمام کاموں کا انتظام) بندوبست کرنے والے ہیں۔
79,6,(۶) کہ قیامت کے دن کا زبر دست زلزلے کا جھٹکا ہلا ہلا مارے گا۔
79,7,(۷) اور اُس کے پیچھے ایک اور سخت ہنگامے اورمصیبت والا جھٹکا پڑے گا۔
79,8,(۸) اُس دن کچھ دل تو خوف سے کانپ کانپ رہے ہوں گے۔
79,9,(۹) اُن کی نگاہیں جھکی اور سہمی ہوئی ہوں گی۔
79,10,(۱۰) یہ وہ احمق ہوں گے جو کہتے ہیں کہ: کیا واقعی ہم پلٹا کر پہلی صورت میں واپس لائے جائیں گے؟
79,11,(۱۱) کیا جب ہم پُرانی کھوکھلی ہڈّیاں بن چکے ہوں گے؟ (تو پھر زندہ کر کے دوبارہ لائے جائیں گے؟)
79,12,(۱۲) پھر کہتے ہیں ’’(کہ اگر کہیں ایسا ہو گیا تو ہماری) وہ واپسی تو بہت نقصان والی ہو گی۔‘‘
79,13,(۱۳) حالانکہ (وہ واپسی تو اتنی آسان سی بات ہے کہ) بس ایک زور دار ڈانٹ پڑے گی۔
79,14,(۱۴) تو یکایک یہ سب کے سب ایک کھلے ہوئے میدان میں  کھڑے ہوں گے۔
79,15,(۱۵) (قیامت کے اِنکار کا انجام سمجھنے کے لئے) کیا تمہیں موسیٰؑ کے قصّے کی خبر پہنچی ہے؟
