quran[7{c,v,t}:
28,78,(۷۸)(اس پرقارون نے)کہا": یہ سب کچھ تو مجھے (خداکی وجہ سے نہیں بلکہ) اُس علم وہُزمندی کی وجہ سے ملا ہے جو میرے پاس ہے۔‘‘ کیا اُس (احمق)کو معلوم نہ تھا کہ اللہ اس سے پہلے بہت سی ایسی نسلوں اور قوموں کو (اُن کے اسی تکبّر اور ناشکری کی وجہ سے) ہلاک وبرباد کرچکاہے، جواُس سے کہیں زیادہ طاقت ور اورسرمایہ دار تھیں ۔ ایسے مجرموں سے تو اُن کے گناہ بھی نہیں پوچھے جاتے ۔( یعنی بلا حساب کتاب ، بلا تاخیر ،مرتے ہی ، فورا جہنم میں جھونک دئے جاتے ہیں۔ )
28,79,(۷۹)پس (ایک دن) وہ (احمق) اپنی قوم کے سامنے اپنے پورے سازو سامان اور ٹھاٹ باٹ کے ساتھ نکلا۔ توجولوگ دنیا کی زندگی کے طلب گارتھے \\'وہ (اُسے دیکھ کر للچاگئےاور) کہنے لگے: کاش ہمارے لیے بھی وہی کچھ ہوتا جو قارون کو دیا گیاہے۔ یقینًا یہ بڑا ہی خوش نصیب ہے۔( یا ) بڑے نصیبے والا۔
28,80,(۸۰)مگر جن کو (حقیقت کا) علم عطا کیا گیا تھا \\'اُنہوں نے کہا: افسوس ہے تمہاری حالت پر، اللہ کے ہاں کا صلہ (اِس سے) کہیں بہتر ہے، اُس کے لیے جو ابدی حقیقتوں کودل سے مانے اور اچّھے اچّھے کام کرے۔ اور یہ دولتِ ابدی ،صبر اور برداشت کرنے والوں کے سوا کسی کونہیں ملتی۔‘‘ (معلوم ہواکہ علم کی حقیقت، ابدی حقائق کوجاننا\\' ہے، اور اَبَدی حقیقی کامیابی ایمان \\'عمل او رصبر پرمنحصرہے۔)
28,81,(۸۱)آخِرکار ہم نے اُس کواور اُس کے گھرکو زمین کے اندر دھنسا دیا۔تواب اُس کے حامیوں کا کوئی گروہ نہ تھا ، جواللہ کے مقابلےپراُس کی مددکرتا۔ اورنہ وہ خودہی اپنے لیے کچھ کرسکا۔
28,82,(۸۲)اور وہ لوگ جو کل اُس (قارون ) کے مقام ومنزلت کی تمنّا کررہے تھے،اب کہنے لگے": افسوس ہماری حالت پر، ہم بھول ہی گئے کہ اللہ اپنے بندوں میں سے جس بندے کا رزق چاہتاہے بڑھا کر کشادہ کردیتاہے، اورجس کےلیے چاہتاہے تنگی کردیتا ہے۔( یا ) جسے چاہتا ہے وسیع رزق دیتاہے اور جسے چاہیتا ہے نپا تلا رزق دیتا ہے۔ اگراللہ نے ہم پر احسان نہ کیا ہوتا تو ہمیں بھی (اُسی کی طرح)زمین میں دھنسادیتا۔افسوس ہے کہ ہم کو تو یاد ہی نہ رہا کہ کافر کبھی حقیقی اَبَدی بھرپور کامیابی اورہرطرح کی بھلائی حاصل نہیں کرسکتے۔‘‘
28,83,(۸۳)وہ آخرت کا گھر توہم اُن لوگوں کےلیے قراردیتے ہیں جو زمین میں دوسروں پر چھاجانے کی خواہش نہیں رکھتے ، اورنہ (زمین پر) فساد یا خرابیاں پھیلانا چاہتے ہیں ۔ اورانجام کی بہتری اور بھلائی ، دھونس جمانے اور دوسرون پر چھا جانے کی توبُری خواہش سے بچتے رہنے والے "متّقین" کےلیے ہے۔
28,84,(۸۴)غرض جو کوئی بھی نیکی اور بھلائی لے کر (وہاں ) آئے گا ، \\' تواُس کےلیے (وہاں ) اُس سے کہیں بہتر بھلائی اور بہتری ہے ۔ اور جو وہاں بُرائی کے ساتھ آئے گا تو بُرائیاں کرنے والوں کو بالکل ویسے ہی بدلے کے سوا کچھ اورنہ ملے گا جیسے کام وہ کیا کرتے تھے۔( یا ) برائیاں کرنے والوں کو بالکل ویسا ہی بدلہ ملے گا جیسے برے کام وہ کیا کرتے تھے۔
