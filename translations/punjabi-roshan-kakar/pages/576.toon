quran[30]{c,v,t,f}:
  74,18,"بیشک اوہنے سوچ وچار کیتی تے تجویز لائی ۔"
  74,19,"فیر ماریا جاوے ! اوہنے کیسی تجویز لائی ۔"
  74,20,"مڑ ماریا جاوے ! اوہنے کیسی گل بنائی ؟"
  74,21,"مڑ کے اوہنے ویکھیا ۔"
  74,22,"مڑ کے اوہنے گھوری وٹی تے مونھ وگاڑیا ۔"
  74,23,"مڑ کے کنڈ پھیری تے متکبر ہویا ۔"
  74,24,"فیر اوہنے کہیا : ایہہ ( قرآن ) تے جادو سوا کجھ نئیں جیہڑا منڈھوں ٹردا آ رہیا اے ۔"
  74,25,"ایہہ کجھ نئیں بشر دے کلام توں سوا ۔"
  74,26,"میں چھیتی اوہنوں سقر ( دوزخ ) وچ سٹاں گا ۔"
  74,27,"تے تینوں کیہہ پتا ہووے سقر کیہہ اے ؟"
  74,28,"اوہ ( اگ ) نہ کسے نوں ولاؤندی نہ کجھ تھاں چھڈدی ۔"
  74,29,"چمڑی لُوہ کے رکھ دیندی اے ۔"
  74,30,"اوہدے تے اُنی ( 19 ) (دربان ) مقرر نیں ۔"
  74,31,"تے اسیں دوزخ دے دربان فرشتیاں سوا ہور نئیں بنائے ، تے نئیں بنائی اسیں اوہناں دی تعداد ای کافراں لئی آزمائش تاں جے کتاب دتے گئے چنگی طرحاں یقین کر لین تے ایمان والے ایمان چ ہور ودھ جان ، تے جنھاں نوں کتاب ملی تے ایمان والے شک وچ نہ پَین ، تے تاں پئی جنھاں دے دلاں چ روگ اے نالے کافر کہن : ایہدی مثال نال اللہ کیہڑا ارادہ کیتا اے ؟ اُنجے ای اللہ جنھوں چاہوے گمراہ کردا اے تے جنھوں چاہوے ہدایت دیندا اے ۔ تے تیرے رب دے لشکراں نوں اوہدے سوا کوئی نئیں جان دا ۔ تے نئیں ایہہ ( گلاں ) پر بشر لئی نصیحت ای ۔"
  74,32,"ہرگز نئیں ! قسم اے چن دی ۔"
  74,33,"تے رات دی جدوں پِچھاں مڑے ۔"
  74,34,"تے تڑکے دی جدوں اوہ چانن کرے ۔"
  74,35,"بیشک اوہ ( دوزخ ) وڈیاں شیواں وچوں اک اے ۔"
  74,36,"آدمی نوں ڈراؤن والی اے ۔"
  74,37,"اوہدے لئی ( ڈراوا ) جیہڑا تہاڈے وچوں اگے ( نیکی ول ) ودھنا یا پیچھے ہٹنا چاہوے ۔"
  74,38,"ہر شخص اپنے کمائے بدلے گہنے پیا اے ۔"
  74,39,"سوائے سجّے ( پاسے ) والیاں دے ۔"
  74,40,"اوہ باغاں وچ ہون گے ، آپس وچ سوال کرن گے ۔"
  74,41,"مجرماں کولوں ۔"
  74,42,"تہانوں کیس شے سقر ( دوزخ ) وچ واڑیا ؟"
  74,43,"اوہ کہن گے : اسیں نماز پڑھن والیاں چوں نئیں سی ۔"
  74,44,"تے نہ اسیں مسکین نوں کھانا کھواندے سی ۔"
  74,45,"تے اسیں بیہودہ بکن والیاں نال بکواس چ لگے ہوندے سی ۔"
  74,46,"تے اسیں حساب دے دن دا انکار کردے ہوندے سی ۔"
  74,47,"ایتھوں تیکر پئی سانوں موت آن پھڑیا ۔"
