quran[7]{c,v,t,f}:
  60,12,"اوہنوں سخت طاقتاں والے سکھایا ۔"
  60,13,"بڑے ذہن ( جبرائیل ) نے ، فیر اوہ اچا ہویا ۔"
  61,1,"تے اوہ اسمان دے اُچے کنڈے تے سی ۔"
  61,2,"مڑ کے اوہ نیڑے ہویا ، فیر اتر آیا ۔"
  61,3,"فیر ہو گیا دو کماناں دی وِتھ تے سگوں بوہتا نیڑے ۔"
  61,4,"فیر اوہنے اوس ( اللہ ) دے بندے ول وحی کیتی جو وی وحی کیتی ۔"
  61,5,"اوس ول دھوکا نہیں کھادا جو اوہنے ویکھیا ۔"