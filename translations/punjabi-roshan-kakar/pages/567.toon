quran[26]{c,v,t,f}:
  69,9,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,10,"دونویں ہرے کچال ۔"
  69,11,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,12,"اوہناں دونواں وچ جوش ماردے دو چشمے نیں ۔"
  69,13,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,14,"اوہناں دونواں وچ سوادی پَھل ہون گے ، تے کھجوراں تے انار وی ۔"
  69,15,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,16,"اوہناں وچ کئی خوب سیرت تے خوبصورت ناراں نیں ۔"
  69,17,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,18,"حوراں تنبوواں وچ ڈکیاں ہوئیاں ۔"
  69,19,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,20,"ایس توں پہلوں اوہناں نوں کسے انسان نے ہتھ نئیں لایا ہووے گا تے نہ جناں نے ۔"
  69,21,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,22,"اوہ انج دے قالیناں تے تکیے لا کے ( بیٹھے ہون گے ) جیہڑے ہرے ، نادر ودھیا نیں ۔"
  69,23,"فیر تسی دونویں اپنے رب دیاں کیہڑیاں کیہڑیاں نعمتاں دا انکار کرو گے ؟"
  69,24,"بڑا مقدس اے تیرے رب دا ناں جیہڑا بڑی وڈیائی تے عزت والا اے ۔"
  69,25,"اللہ دے ناں نال ( شروع ) جیہڑا حدوں مہربان ، بوہت رحم والا اے ۔"
  69,26,"جدوں واقع ہون والی ( قیامت ) واقع ہووے گی ۔"
  69,27,"اوہدے واقع ہون وچ کوئی جھوٹھ نئیں ۔"
  69,28,"ہیٹھان کرن والی ( کِتیوں ) اُتے چکن والی ۔"
  69,29,"جدوں دھرتی سخت ہلائی جاوے گی سخت ہلانا ۔"
  69,30,"تے پہاڑ چکنا چور ہو جان گے ٹٹ ٹٹ کے ۔"
  69,31,"فیر کھلری ہوئی گھٹا بن جان گے ۔"
  69,32,"تے تہاڈیاں تن قِسماں ہو جان گئیاں ۔"
  69,33,"سو سجّے ہتھ والے کیا ( خوش نصیب نیں ) سجّے ہتھ والے ۔"
  69,34,"تے کھبے ہتھ والے کیسے ( بدنصیب نیں ) کھبے ہتھ والے ۔"