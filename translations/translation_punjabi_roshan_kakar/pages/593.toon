quran[23]{c,v,t,f}:
  89,1,"بیشک تہاڈے نال جیس ( ( قیامت ) دا وعدہ کیتا جاندا اے اوہ اٹل اے ۔"
  89,2,"فیر جدوں تارے بے نور ہو جان گے ۔"
  89,3,"تے جدوں اسمان پاڑ دتا جاوے گا ۔"
  89,4,"تے جدوں پہاڑ ( غبار کر کے ) اڈائے جان گے ۔"
  89,5,"تے جدوں ( اوہ ویلا آوے گا ) جیہڑا رسولاں نال متھیا گیا اے ۔"
  89,6,"کس دن تک اوہ کھلیارے گئے سی ۔"
  89,7,"فیصلے دے دیہاڑے لئی ۔"
  89,8,"تے تہانوں کیہہ خبر فیصلے دا دیہاڑا کیہہ اے ؟"
  89,9,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  89,10,"بھلا اسیں اگلیاں نوں تباہ نئیں کیتا ؟"
  89,11,"مڑ کے اسیں ہوراں نوں اوہناں دے پچھے لاؤندے رہے ۔"
  89,12,"اسیں مجرماں نال اُنجے کر دے آں ۔"
  89,13,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  89,14,"بھلا اسیں تہانوں بے قدرے پانی ( منی ) توں نئیں بنایا ؟"
  89,15,"فیر اسیں اوہنوں اک سانبھی ہوئی تھاویں رکھیا ۔"
  89,16,"اک مقرر اندازے تیکر ۔"
  89,17,"فیر اسیں اندازہ لایا تے اسیں چنگا اندازہ لاؤن والے آں ۔"
  89,18,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  89,19,"بھلا اسیں زمین سمیٹن والی نئیں بنائی ۔"
  89,20,"جیوندیاں توں تے مُردیاں نوں ؟"
  89,21,"تے اسیں ایہدے وچ اُچے اُچے پہاڑ بنائے تے تہانوں واہوا مِٹھا پانی پیایا ۔"
  89,22,"اوس دن جھٹھلاؤن والیاں لئی وڈی بربادی اے ۔"
  89,23,"( آکھیا جاوے گا : ) چلو اوس ( عذاب ) ول جیہدا تسی انکار کردے سو ۔"