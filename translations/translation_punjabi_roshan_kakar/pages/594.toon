quran[27]{c,v,t,f}:
  89,24,"ٹر جاؤ تن شاخاں والی چھاں ( دھوئیں ) ول ۔"
  89,25,"نہ چھاں کرن والی تے نہ لمپ توں بچاوے ۔"
  89,26,"بیشک اوہ ( دوزخ ) چنگیاڑے سٹے گی جینویں اچے محل ۔"
  89,27,"جینویں واقعی اوہ پیلے اوٹھ ہؤن ۔"
  89,28,"اوس دن جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  89,29,"ایہہ ( اوہ ) دیہاڑا اے پئی ( لوک ) بول نئیں سکن گے ۔"
  89,30,"تے نہ اوہناں نوں اجازت دتی جاوے گی سو اوہ عذر کر لَین ۔"
  90,1,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  90,2,"ایہہ فیصلے دا دیہاڑا اے ، اسیں تہانوں تے اگلیاں نوں کٹھے کراں گے ۔"
  90,3,"فیر جے تہاڈے کول کوئی چال اے فیر میرے خلاف چلاؤ ۔"
  90,4,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  90,5,"بیشک پرہیزگار چھانواں تے چشمیاں وچ ہون گے ۔"
  90,6,"تے من مرضی دے میوے ملن گے ۔"
  90,7,"( آکھیا جاوے گا : ) مزے نال کھاؤ تے پیؤ ، اوہدے بدلے جیہڑے تسی کم کر دے رہئے ۔"
  90,8,"بیشک اسیں نیکاں نوں اوسے طرحاں بدلہ دینے آں ۔"
  90,9,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  90,10,"( جھٹھلان والیو ! ) تسی ( دنیا وچ ) تھوڑا چِر کھا لو تے ہنڈا ورت لؤ ، بیشک تسی مجرم او ۔"
  90,11,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  90,12,"تے جدوں اوہناں نوں آکھیا جاوے رکوع کرو تے اوہ رکوع نئیں کر دے ۔"
  90,13,"اوس دیہاڑے جھٹھلان والیاں لئی وڈی بربادی اے ۔"
  90,14,"فیر ایس ( قرآن ) توں بعد اوہ کیہڑی گل تے ایمان لیاؤن گے ؟"
  90,15,"اللہ دے ناں نال ( شروع ) جیہڑا حدوں مہربان ، بوہت رحم والا اے ۔"
  90,16,"آپس وچ اوہ کاہدے بارے سوال کردے نیں ؟"
  90,17,"( کیہہ ) اوس وڈی خبر بارے"
  90,18,"جیہدے وچ اوہ سب آپو وچ پاٹے ہوئے نیں"
  90,19,"ہرگز نئیں ! چھیتی اوہناں نوں پتا لگ جاوے گا"
  90,20,"مڑ ہرگز نئیں ! ہنے اوہ جان لین گے"