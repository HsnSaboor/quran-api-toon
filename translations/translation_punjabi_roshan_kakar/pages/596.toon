quran[26]{c,v,t,f}:
  92,15,"اوہدے ( جنت ) وچ نہ کوئی بیہودہ گل سنن نوں تے نہ جھٹھلانا"
  92,16,"بدلے چ صلہ تیرے رب ولوں اوہناں نوں کافی ہوسی"
  92,17,"جیہڑا رب اے اسماناں تے زمین دا تے اوہناں وچکار ساریاں شیواں دا ، بوہت مہربان اے ، اوہ اوہدے نال کوئی گل کرن دی واہ نہ رکھسن"
  92,18,"جیس دیہاڑے جبریل تے ( سبھے ) فرشتے صفاں بنھ کھلون گے ، اوہدے نال کوئی گل نہ کر سکے گا پر جنھوں رحمن اجازے دیوے گا ، تے اوہ ٹھیک گل کہوے گا"
  92,19,"اوہ دیہاڑا برحق اے ، سو جیہڑا چاہوے اپنے رب ول ٹکانا بنا لوے"
  92,20,"بیشک اسیں تہانوں نیڑے آپجے عذاب توں ڈرا دتا اے ، جیس دیہاڑے بندہ اوہ ( سب کجھ ) ویکھ لوے گا جیہڑا اوہدے دونواں ہتھاں اگے گھلیا ، تے کافر کہوے گا ہائے کِتے ! میں ( مڑ ) مٹی ہو رہندا ۔"
  92,21,"اللہ دے ناں نال ( شروع ) جیہڑا حدوں مہربان ، بوہت رحم والا اے ۔"
  93,1,"قسم ایں ڈُب کے سختی نال ( جان ) کھچ لیاؤن والیاں دی"
  93,2,"تے سہج نال گنڈ کھولن والیاں دی"
  93,3,"تے تیزی نال تردیاں دی"
  93,4,"فیر ودھ کے اگے لنگھن والیاں دی"
  93,5,"فیر کم دا گویڑ لون والیاں دی"
  93,6,"جیس دن ( دھرتی ) ڈاہڈی کمبے گی پہلے صور"
  93,7,"اوہدے پچھے آئے گی پچھوں آؤن والی ( قرنائی واج )"
  93,8,"کئیاں دلاں نوں اوس دن دھڑکی لگی ہووے گی"
  93,9,"اوہناں دیاں اکھاں نیویاں ہون گئیاں"
  93,10,"اوہ ( کافر ) کہندے نیں : بھلا بیشک اسیں لازمی پہلی حالت چ پرتائے جاناں ؟"
  93,11,"بھلا جدوں اسیں گلیاں ہڈیاں ہو جانواں گے ؟"
  94,1,"جہندے ( تے ) تد اوہ واپسی گھاٹے والی ہووے گی"
  94,2,"سو اوہ ( قیامت ) بیشک اک ای بھبکی ہووے گی"
  94,3,"فیر یکدم اوہ دھرتی اُتے موجود ہون گے"
  94,4,"بھلا تہاڈے کول موسیٰ دی گل آئی اے ؟"
  94,5,"جدوں اوہدے رب نے اوہنوں پاک وادی طویٰ وچ سدیا سی"
  94,6,"( پئی ) فرعون ول جاؤ ، بیشک اوہ ( کفر چ ) حدوں لنگ گیا اے"
  94,7,"فیر ( اوہنوں ) بھلا : کیہہ توں ایہہ چاہناں ایں پئی پاک ہو جاویں"
  94,8,"تے میں تیرے رب ول تینوں راہ وکھاواں سو توں ڈر جاویں"