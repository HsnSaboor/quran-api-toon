quran[16{c,v,t}:
7,105,Haqeequn 'alaaa al laaa aqoola 'alal laahi illal haqq; qad ji'tukum bibaiyinatim mir Rabbikum fa arsil ma'iya Baneee Israaa'eel
7,106,Qaala in kunta ji'ta bi Aayatin faati bihaaa in kunta minas saadiqeen
7,107,Qa alqaa 'asaahu fa izaa hiya su'baanum mubeen
7,108,Wa naza'a yadahoo fa izaa hiya baidaaa'u linnaazireen (section 13)
7,109,Qaalal mala-u min qawmi Fir'awna inna haazaa lasaa hirun 'aleem
7,110,Yureedu ai yukhrijakum min ardikum famaazaa taamuroon
7,111,Qaalooo arjih wa akhaahu wa arsil filmadaaa'ini haashireen
7,112,Yaatooka bikulli saahirin 'aleem
7,113,Wa jaaa'as saharatu Fir'awna qaaloo inna lanaa la ajjran in kunnaa nahnul ghaalibeen
7,114,Qaala na'am wa innakum laminal muqarrabeen
7,115,Qaaloo yaa Moosaaa immaaa an tulqiya wa immaaa an nakoona nahnul mulqeen
7,116,Qaala alqoo falam maaa alqaw saharooo a'yunannaasi wastarhaboohum wa jaaa'oo bisihrin 'azeem
7,117,Wa awhainaaa ilaa Moosaaa an alqi 'asaaka fa izaa hiya talqafu maa yaafikoon
7,118,Fawaqa'al haqqu wa batala maa kaanoo ya'maloon
7,119,Faghuliboo hunaalika wanqalaboo saaghireen
7,120,Wa ulqiyas saharatu saajideen
