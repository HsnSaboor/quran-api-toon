quran[27{c,v,t}:
83,35,'Alal araaa'iki yanzuroon
83,36,Hal suwwibal kuffaaru maa kaanoo yaf'aloon
84,1,Izas samaaa'un shaqqat
84,2,Wa azinat li Rabbihaa wa huqqat
84,3,Wa izal ardu muddat
84,4,Wa alqat maa feehaa wa takhallat
84,5,Wa azinat li Rabbihaa wa huqqat
84,6,Yaaa ayyuhal insaanu innaka kaadihun ilaa Rabbika kad han famulaaqeeh
84,7,Fa ammaa man ootiya kitaabahoo biyameenih
84,8,Fasawfa yuhaasabu hi saabai yaseeraa
84,9,Wa yanqalibu ilaaa ahlihee masrooraa
84,10,Wa ammaa man ootiya kitaabahoo waraaa'a zahrih
84,11,Fasawfa yad'oo subooraa
84,12,Wa yaslaa sa'eeraa
84,13,Innahoo kaana feee ahlihee masrooraa
84,14,Innahoo zanna al lai yahoor
84,15,Balaaa inna Rabbahoo kaana bihee baseeraa
84,16,Falaaa uqsimu bishshafaq
84,17,Wallaili wa maa wasaq
84,18,Walqamari izat tasaq
84,19,Latarkabunna tabaqan 'an tabaq
84,20,Famaa lahum laa yu'minoon
84,21,Wa izaa quri'a 'alaihimul Quraanu laa yasjudoon�(make sajda)
84,22,Balil lazeena kafaroo yukazziboon
84,23,Wallaahu a'lamu bimaa yoo'oon
84,24,Fabashshirhum bi'azaabin aleem
84,25,Illal lazeena aamanoo wa 'amilus saalihaati lahum ajrun ghairu mamnoon
