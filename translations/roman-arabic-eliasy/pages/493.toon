quran[13{c,v,t}:
43,48,Wa maa nureehim min aayatin illaa hiya akbaru min ukhtihaa wa akhaznaahum bil'azaabi la'allahum yarji'oon
43,49,Wa qaaloo yaaa ayyuhas saahirud'u lanaa Rabbaka bimaa 'ahida 'indaka innanaa lamuhtadoon
43,50,Falammaa kashafnaa 'anhumul 'azaaba izaa hum yankusoon
43,51,Wa naadaa Fir'awnu fee qawmihee qaala yaa qawmi alaisa lee mulku Misra wa haazihil anhaaru tajree min tahtee afalaa tubsiroon
43,52,Am ana khairum min haazal lazee huwa maheenunw wa laa yuakaadu yubeen
43,53,Falaw laa ulqiya 'alaihi aswiratum min zahabin awjaaa'a ma'ahul malaaa'ikatu muqtarineen
43,54,Fastakhaffa qawmahoo fa ataa'ooh; innahum kaanoo qawman faasiqeen
43,55,Falammaaa aasafoonan taqamnaa minhum fa aghraqnaahum ajma'een
43,56,Faja'alnaahum salafanw wa masalal lil aakhireen�(section 5)
43,57,Wa lammaa duribab nu Maryama masalan izaa qawmu ka minhu yasidoon
43,58,Wa qaalooo 'a-aalihatunaa khairun am hoo; maa daraboohu laka illaa jadalaa; balhum qawmun khasimoon
43,59,In huwa illaa 'abdun an'amnaa 'alaihi wa ja'alnaahu masalal li Baneee Israaa'eel
43,60,Wa law nashaaa'u laja'alnaa minkum malaaa'ikatan fil ardi yakhlufoon
