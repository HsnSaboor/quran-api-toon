quran[3]{c,v,t}:
  81,0,Bismillaahir Rahmaanir Raheem
  81,1,Izash shamsu kuwwirat
  81,2,Wa izan nujoomun kadarat
  81,3,Wa izal jibaalu suyyirat
  81,4,Wa izal 'ishaaru 'uttilat
  81,5,Wa izal wuhooshu hushirat
  81,6,Wa izal bihaaru sujjirat
  81,7,Wa izan nufoosu zuwwijat
  81,8,Wa izal maw'oodatu su'ilat
  81,9,Bi ayyi zambin qutilat
  81,10,Wa izas suhufu nushirat
  81,11,Wa izas samaaa'u kushitat
  81,12,Wa izal jaheemu su'-'irat
  81,13,Wa izal jannatu uzlifat
  81,14,'Alimat nafsum maaa ahdarat
  81,15,Falaaa uqsimu bil khunnas
  81,16,Al jawaaril kunnas
  81,17,Wallaili izaa 'as'as
  81,18,Wassubhi izaa tanaffas
  81,19,Innahoo laqawlu rasoolin kareem
  81,20,Zee quwwatin 'inda zil 'arshi makeen
  81,21,Mutaa'in samma ameen
  81,22,Wa maa saahibukum bimajnoon
  81,23,Wa laqad ra aahu bilufuqil mubeen
  81,24,Wa maa huwa 'alal ghaibi bidaneen
  81,25,Wa maa huwa biqawli shaitaanir rajeem
  81,26,Fa ayna tazhaboon
  81,27,In huwa illaa zikrul lil'aalameen
  81,28,Liman shaaa'a minkum ai yastaqeem
  81,29,Wa maa tashaaa'oona illaaa ai yashaaa 'al laahu Rabbul 'Aalameen
