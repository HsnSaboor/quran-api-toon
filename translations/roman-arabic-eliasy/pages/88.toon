quran[3]{c,v,t}:
  88,0,Bismillaahir Rahmaanir Raheem
  88,1,Hal ataaka hadeesul ghaashiyah
  88,2,Wujoohuny yawma 'izin khaashi'ah
  88,3,'Aamilatun naasibah
  88,4,Taslaa naaran haamiyah
  88,5,Tusqaa min 'aynin aaniyah
  88,6,Laisa lahum ta'aamun illaa min daree'
  88,7,Laa yusminu wa laa yughnee min joo'
  88,8,Wujoohuny yawma 'izin naa'imah
  88,9,Lisa'yihaa raadiyah
  88,10,Fee jannatin 'aaliyah
  88,11,Laa tasma'u feehaa laaghiyah
  88,12,Feehaa 'aynun jaariyah
  88,13,Feehaa sururum marfoo'ah
  88,14,Wa akwaabum mawdoo 'ah
  88,15,Wa namaariqu masfoofah
  88,16,Wa zaraabiyyu mabsoosah
  88,17,Afalaa yanzuroona ilalibili kaifa khuliqat
  88,18,Wa ilas samaaa'i kaifa rufi'at
  88,19,Wa ilal jibaali kaifa nusibat
  88,20,Wa ilal ardi kaifa sutihat
  88,21,Fazakkir innama anta Muzakkir
  88,22,Lasta 'alaihim bimusaitir
  88,23,Illaa man tawallaa wa kafar
  88,24,Fa yu'azzibuhul laahul 'azaabal akbar
  88,25,Innaa ilainaaa iyaabahum
  88,26,Summa inna 'alainaa hisaabahum
