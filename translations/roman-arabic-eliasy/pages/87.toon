quran[3]{c,v,t}:
  87,0,Bismillaahir Rahmaanir Raheem
  87,1,Sabbihisma Rabbikal A'laa
  87,2,Allazee khalaqa fasawwaa
  87,3,Wallazee qaddara fahadaa
  87,4,Wallazeee akhrajal mar'aa
  87,5,Faja'alahoo ghusaaa'an ahwaa
  87,6,Sanuqri'uka falaa tansaaa
  87,7,Illaa maa shaaa'al laah; innahoo ya'lamul jahra wa maa yakhfaa
  87,8,Wa nu-yassiruka lilyusraa
  87,9,Fazakkir in nafa'atizzikraa
  87,10,Sa yazzakkaru maiyakhshaa
  87,11,Wa yatajannabuhal ashqaa
  87,12,Allazee yaslan Naaral kubraa
  87,13,Summa laa yamootu feehaa wa laa yahyaa
  87,14,Qad aflaha man tazakkaa
  87,15,Wa zakaras ma Rabbihee fasallaa
  87,16,Bal tu'siroonal hayaatad dunyaa
  87,17,Wal Aakhiratu khairunw wa abqaa
  87,18,Inna haazaa lafis suhu fil oolaa
  87,19,Suhufi Ibraaheema wa Moosaa
