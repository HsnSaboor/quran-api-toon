quran[25{c,v,t}:
37,52,Yaqoolu a'innnaka laminal musaddiqeen
37,53,'A-izaa mitnaa wa kunnaa turaabanw wa 'izaaman 'ainnaa lamadeenoon
37,54,Qaala hal antum muttali'oon
37,55,Fattala'a fara aahu fee sawaaa'il Jaheem
37,56,Qaala tallaahi in kitta laturdeen
37,57,Wa law laa ni'matu Rabbee lakuntu minal muhdareen
37,58,Afamaa nahnu bimaiyiteen
37,59,Illa mawtatanal oola wa maa nahnu bimu'azzabeen
37,60,Inna haazaa falya'ma lil'aamiloon
37,61,Limisli haaza falya'ma lil 'aamiloon
37,62,Azaalika khairun nuzulan am shajaratuz Zaqqom
37,63,Innaa ja'alnaahaa fitnatal lizzaalimeen
37,64,Innahaa shajaratun takhruju feee aslil Jaheem
37,65,Tal'uhaa ka annahoo ru'oosush Shayaateen
37,66,Fa innahum la aakiloona minhaa famaali'oona minhal butoon
37,67,Summa inna lahum 'alaihaa lashawbam min hameem
37,68,Summa inna marji'ahum la ilal Jaheem
37,69,Innahum alfaw aabaaa'ahum daaalleen
37,70,Fahum 'alaa aasaarihim yuhra'oon
37,71,Wa laqad dalla qablahum aksarul awwaleen
37,72,Wa laqad arsalnaa feehim munzireen
37,73,Fanzur kaifa kaana 'aaqibatul munzareen
37,74,Illaa 'ibaadal laahil mukhlaseen�(section 2)
37,75,Wa laqad naadaanaa Noohun falani'mal mujeeboon
37,76,Wa jajainaahu wa ahlahoo minal karbil 'azeem
