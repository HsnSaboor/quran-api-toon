quran[29{c,v,t}:
70,11,Yubassaroonahum; ya waddul mujrimu law yaftadee min 'azaabi yawma'izim bibaneeh
70,12,Wa saahibatihee wa akheeh
70,13,Wa faseelathil latee tu'weeh
70,14,Wa man fil ardi jamee'an summa yunjeeh
70,15,Kallaa innahaa lazaa
70,16,Nazzaa'atal lishshawaa
70,17,Tad'oo man adbara wa tawallaa
70,18,W jama'a fa aw'aa
70,19,Innal insaana khuliqa haloo'aa
70,20,Izaa massahush sharru jazoo'aa
70,21,Wa izaa massahul khairu manoo'aa
70,22,Illal musalleen
70,23,Allazeena hum 'alaa Salaatihim daaa'imoon
70,24,Wallazeena feee amwaalihim haqqum ma'loom
70,25,Lissaaa 'ili walmahroom
70,26,Wallazeena yusaddiqoona bi yawmid Deen
70,27,Wallazeena hum min 'azaabi Rabbihim mushfiqoon
70,28,Inna 'azaaba Rabbihim ghairu maamoon
70,29,Wallazeena hum lifuroo jihim haafizoon
70,30,Illaa 'alaaa azwaajihim aw maa malakat aymaanuhum fainnahum ghairu maloomeen
70,31,Famanib taghaa waraaa'a zaalika fa ulaaa'ika humul 'aadoon
70,32,Wallazeena hum li amaa naatihim wa 'ahdihim raa'oon
70,33,Wallazeena hum bishahaadaatihim qaaa'imoon
70,34,Wallazeena hum 'alaa salaatihim yuhaafizoon
70,35,Ulaaa'ika fee jannaatim mukramoon
70,36,Famaa lil lazeena kafaroo qibalaka muhti'een
70,37,'Anil yameeni wa 'anish shimaali 'izeen
70,38,Ayatma'u kullum ri'im minhum anyyudkhala jannata Na'eem
70,39,Kallaaa innaa khalaq nahum mimmaa ya'lamoon
