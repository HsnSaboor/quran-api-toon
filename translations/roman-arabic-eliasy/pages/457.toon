quran[22{c,v,t}:
38,62,Wa qaaloo ma lanaa laa naraa rijaalan kunnaa na'udduhum minal ashraar
38,63,Attakhaznaahum sikh riyyan am zaaghat 'anhumul absaar
38,64,Inna zaalika lahaqqun takhaasumu Ahlin Naar�(section 4)
38,65,Qul innamaaa ana munzirunw wa maa min ilaahim illal laahul Waahidul Qahhaar
38,66,Rabbus samaawaati wal ardi wa maa bainahumal 'Azeezul Ghaffaar
38,67,Qul huwa naba'un 'azeem
38,68,Antum 'anhu mu'ridoon
38,69,Maa kaana liya min 'ilmim bilmala il a'laaa iz yakhtasimoon
38,70,Iny-yoohaaa ilaiya illaaa annnamaaa ana nazeerum mubeen
38,71,Iz qaala Rabbuka lilmalaaa'ikati innee khaaliqum basharam min teen
38,72,Fa-iza sawwaituhoo wa nafakhtu feehi mir roohee faqa'oo lahoo saajideen
38,73,Fasajadal malaaa'ikatu kulluhum ajma'oon
38,74,Illaaa Iblees; istakbara wa kaana minal kaafireen
38,75,Qaala yaaa Ibleesu maa man'aka an tasjuda limaa khalaqtu biyadai; astakbarta am kunta min 'aaleen
38,76,Qaala ana khairum minah; khalaqtanee min naarinw wa khalaqtahoo min teen
38,77,Qaala fakhruj minhaa fainnaka rajeem
38,78,Wa inna 'alaika la'nateee ilaa Yawmid Deen
38,79,Qaala Rabbi fa anzirneee ilaa Yawmi yub'asoon
38,80,Qaala fa innaka minal munzareen
38,81,Ilaa Yawmil waqtil ma'loom
38,82,Qaala fabi'izzatika la ughwiyannahum ajma'een
38,83,Illaa 'ibaadaka minhumul mukhlaseen
