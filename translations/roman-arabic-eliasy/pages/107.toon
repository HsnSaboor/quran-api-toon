quran[3]{c,v,t}:
  107,0,Bismillaahir Rahmaanir Raheem
  107,1,Ara-aital lazee yu kazzibu bid deen
  107,2,Fa zaalikal lazi yadu'ul-yateem
  107,3,Wa la ya huddu 'alaa ta'amil miskeen
  107,4,Fa wai lul-lil mu salleen
  107,5,Al lazeena hum 'an salaatihim sahoon
  107,6,Al lazeena hum yuraa-oon
  107,7,Wa yamna'oonal ma'oon
