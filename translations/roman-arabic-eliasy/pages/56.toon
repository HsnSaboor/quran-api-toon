quran[3]{c,v,t}:
  56,0,Bismillaahir Rahmaanir Raheem
  56,1,Izaa waqa'atil waaqi'ah
  56,2,Laisa liwaq'atihaa kaazibah
  56,3,Khafidatur raafi'ah
  56,4,Izaa rujjatil ardu rajjaa
  56,5,Wa bussatil jibaalu bassaa
  56,6,Fakaanat habaaa'am mumbassaa
  56,7,Wa kuntum azwaajan salaasah
  56,8,Fa as haabul maimanati maaa as haabul maimanah
  56,9,Wa as haabul mash'amati maaa as haabul mash'amah
  56,10,Wassaabiqoonas saabiqoon
  56,11,Ulaaa'ikal muqarraboon
  56,12,Fee Jannaatin Na'eem
  56,13,Sullatum minal awwaleen
  56,14,Wa qaleelum minal aa khireen
  56,15,'Alaa sururim mawdoonah
  56,16,Muttaki'eena 'alaihaa mutaqabileen
  56,17,Yatoofu 'alaihim wildaa num mukkhalladoon
  56,18,"Bi akwaabinw wa abaareeq, wa kaasim mim ma'een"
  56,19,Laa yusadda'oona 'anhaa wa laa yunzifoon
  56,20,Wa faakihatim mimmaa yatakhaiyaroon
  56,21,Wa lahmi tairim mimmaa yashtahoon
  56,22,Wa hoorun'een
  56,23,Ka amsaalil lu'lu'il maknoon
  56,24,Jazaaa'am bimaa kaanoo ya'maloon
  56,25,Laa yasma'oona feehaa laghwanw wa laa taaseemaa
  56,26,Illaa qeelan salaaman salaamaa
  56,27,Wa as haabul yameeni maaa as haabul Yameen
  56,28,Fee sidrim makhdood
  56,29,Wa talhim mandood
  56,30,Wa zillim mamdood
  56,31,Wa maaa'im maskoob
  56,32,Wa faakihatin kaseerah
  56,33,Laa maqtoo'atinw wa laa mamnoo'ah
  56,34,Wa furushim marfoo'ah
  56,35,Innaaa anshaanaahunna inshaaa'aa
  56,36,Faja'alnaahunna abkaaraa
  56,37,'Uruban atraabaa
  56,38,Li as haabil yameen
  56,39,Sullatum minal awwa leen
  56,40,Wa sullatum minal aakhireen
  56,41,Wa as haabush shimaali maaa as haabush shimaal
  56,42,Fee samoominw wa hameem
  56,43,Wa zillim miny yahmoom
  56,44,Laa baaridinw wa laa kareem
  56,45,Innaahum kaanoo qabla zaalika mutrafeen
  56,46,Wa kaanoo yusirroona 'alal hinsil 'azeem
  56,47,Wa kaanoo yaqooloona a'izaa mitnaa wa kunnaa turaabanw wa izaaman'ainnaa lamab'oosoon
  56,48,Awa aabaaa'unal awwaloon
  56,49,Qul innal awwaleena wal aakhireen
  56,50,Lamajmoo'oona ilaa meeqaati yawmim ma'loon
  56,51,summa innakum ayyuhad daaalloonal mukazziboon
  56,52,La aakiloona min shaja rim min zaqqoom
  56,53,Famaali'oona minhal butoon
  56,54,Fashaariboona 'alaihi minal hameem
  56,55,Fashaariboona shurbal heem
  56,56,Haazaa nuzuluhum yawmad deen
  56,57,Nahnu khalaqnaakum falaw laa tusaddiqoon
  56,58,Afara'aytum maa tumnoon
  56,59,'A-antum takhluqoo nahooo am nahnul khaaliqoon
  56,60,Nahnu qaddarnaa baina kumul mawta wa maa nahnu bimasbooqeen
  56,61,'Alaaa an nubaddila amsaalakum wa nunshi'akum fee maa laa ta'lamoon
  56,62,Wa laqad 'alimtumun nash atal oolaa falaw laa tazakkaroon
  56,63,Afara'aytum maa tahrusoon
  56,64,'A-antum tazra'oonahooo am nahnuz zaari'ooon
  56,65,Law nashaaa'u laja'al naahu hutaaman fazaltum tafakkahoon
  56,66,Innaa lamughramoon
  56,67,Bal nahnu mahroomoon
  56,68,Afara'aytumul maaa'allazee tashraboon
  56,69,'A-antum anzaltumoohu minal muzni am nahnul munziloon
  56,70,Law nashaaa'u ja'alnaahu ujaajan falaw laa tashkuroon
  56,71,Afara'aytumun naaral latee tooroon
  56,72,'A-antum anshaatum shajaratahaaa am nahnul munshi'oon
  56,73,Nahnu ja'alnaahaa tazkira tanw wa mataa'al lilmuqween
  56,74,Fasabbih bismi Rabbikal 'azeem
  56,75,Falaa uqsimu bimaawaa qi'innujoom
  56,76,Wa innahoo laqasamul lawta'lamoona'azeem
  56,77,Innahoo la quraanun kareem
  56,78,Fee kitaabim maknoon
  56,79,Laa yamassuhooo illal mutahharoon
  56,80,Tanzeelum mir Rabbil'aalameen
  56,81,Afabihaazal hadeesi antum mudhinoon
  56,82,Wa taj'aloona rizqakum annakum tukazziboon
  56,83,Falaw laaa izaa balaghatil hulqoom
  56,84,Wa antum heena'izin tanzuroon
  56,85,Wa nahnu aqrabu ilaihi minkum wa laakil laa tubsiroon
  56,86,Falaw laaa in kuntum ghira madeeneen
  56,87,Tarji'oonahaaa in kuntum saadiqeen
  56,88,Fa ammaaa in kaana minal muqarrabeen
  56,89,Farawhunw wa raihaa nunw wa jannatu na'eem
  56,90,Wa ammaaa in kaana min as haabil yameen
  56,91,Fasalaamul laka min as haabil yameen
  56,92,Wa ammaaa in kaana minal mukazzibeenad daaalleen
  56,93,Fanuzulum min hameem
  56,94,Wa tasliyatu jaheem
  56,95,Inna haaza lahuwa haqqul yaqeen
  56,96,Fasabbih bismi rabbikal 'azeem
