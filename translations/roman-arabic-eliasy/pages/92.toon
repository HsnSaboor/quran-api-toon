quran[3]{c,v,t}:
  92,0,Bismillaahir Rahmaanir Raheem
  92,1,Wallaili izaa yaghshaa
  92,2,Wannahaari izaa tajalla
  92,3,Wa maa khalaqaz zakara wal unthaa
  92,4,Inna sa'yakum lashattaa
  92,5,Fa ammaa man a'taa wattaqaa
  92,6,Wa saddaqa bil husnaa
  92,7,Fasanu yassiruhoo lilyusraa
  92,8,Wa ammaa mam bakhila wastaghnaa
  92,9,Wa kazzaba bil husnaa
  92,10,Fasanu yassiruhoo lil'usraa
  92,11,Wa maa yughnee 'anhu maaluhooo izaa taraddaa
  92,12,Inna 'alainaa lal hudaa
  92,13,Wa inna lanaa lal Aakhirata wal oolaa
  92,14,Fa anzartukum naaran talazzaa
  92,15,Laa yaslaahaaa illal ashqaa
  92,16,Allazee kazzaba wa tawallaa
  92,17,Wa sa yujannnabuhal atqaa
  92,18,Allazee yu'tee maalahoo yatazakkaa
  92,19,Wa maa li ahadin 'indahoo min ni'matin tujzaaa
  92,20,Illab tighaaa'a wajhi rabbihil a 'laa
  92,21,Wa lasawfa yardaa
