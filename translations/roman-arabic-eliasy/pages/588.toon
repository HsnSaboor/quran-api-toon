quran[28{c,v,t}:
83,7,Kallaaa inna kitaabal fujjaari lafee Sijjeen
83,8,Wa maa adraaka maa Sijjeen
83,9,Kitaabum marqoom
83,10,Wailuny yawma'izil lil mukazzibeen
83,11,Allazeena yukazziboona bi yawmid deen
83,12,Wa maa yukazzibu biheee illaa kullu mu'tadin aseem
83,13,Izaa tutlaa'alaihi aayaatunaa qaala asaateerul awwaleen
83,14,Kallaa bal raana 'alaa quloobihim maa kaanoo yaksiboon
83,15,Kallaaa innahum 'ar Rabbihim yawma'izil lamah jooboon
83,16,Summa innahum lasaa lul jaheem
83,17,Summa yuqaalu haazal lazee kuntum bihee tukazziboon
83,18,Kallaaa inna kitaabal abraari lafee'Illiyyeen
83,19,Wa maaa adraaka maa 'Illiyyoon
83,20,Kitaabum marqoom
83,21,Yashhadu hul muqarra boon
83,22,Innal abraara lafee Na'eem
83,23,'Alal araaa'iki yanzuroon
83,24,Ta'rifu fee wujoohihim nadratan na'eem
83,25,Yusqawna mir raheeqim makhtoom
83,26,Khitaamuhoo misk; wa fee zaalika falyatanaafasil Mutanaafisoon
83,27,Wa mizaajuhoo min Tasneem
83,28,'Ainaiy yashrabu bihal muqarraboon
83,29,Innal lazeena ajramoo kaanoo minal lazeena aamanoo yadhakoon
83,30,Wa izaa marroo bihim yataghaamazoon
83,31,Wa izan qalabooo ilaaa ahlihimun qalaboo fakiheen
83,32,Wa izaa ra awhum qaalooo inna haaa'ulaaa'i ladaaal loon
83,33,Wa maaa ursiloo 'alaihim haafizeen
83,34,Fal yawmal lazeena aamanoo minal kuffaari yadhakoon
