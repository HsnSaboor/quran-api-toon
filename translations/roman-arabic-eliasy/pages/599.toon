quran[18{c,v,t}:
98,8,Jazaa-uhum inda rabbihim jan naatu 'adnin tajree min tahtihal an haaru khalideena feeha abada; radiy-yallaahu 'anhum wa ra du 'an zaalika liman khashiya rabbah
99,1,Izaa zul zilatil ardu zil zaalaha
99,2,Wa akh rajatil ardu athqaalaha
99,3,Wa qaalal insaanu ma laha
99,4,Yawmaa izin tuhad dithu akhbaaraha
99,5,Bi-anna rabbaka awhaa laha
99,6,Yawma iziy yas durun naasu ash tatal liyuraw a'maalahum
99,7,Famaiy ya'mal mithqala zarratin khai raiy-yarah
99,8,Wa maiy-y'amal mithqala zarratin sharraiy-yarah
100,1,Wal'aadi yaati dabha
100,2,Fal moori yaati qadha
100,3,Fal mugheeraati subha
100,4,Fa atharna bihee naq'a
100,5,Fawa satna bihee jam'a
100,6,Innal-insana lirabbihee lakanood
100,7,Wa innahu 'alaa zaalika la shaheed
100,8,Wa innahu lihubbil khairi la shadeed
100,9,Afala ya'lamu iza b'uthira ma filquboor
