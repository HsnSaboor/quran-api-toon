quran[3]{c,v,t}:
  55,0,Bismillaahir Rahmaanir Raheem
  55,1,Ar Rahmaan
  55,2,'Allamal Quran
  55,3,Khalaqal insaan
  55,4,'Allamalhul bayaan
  55,5,Ashshamsu walqamaru bihusbaan
  55,6,Wannajmu washshajaru yasjudan
  55,7,Wassamaaa'a rafa'ahaa wa wada'al Meezan
  55,8,Allaa tatghaw fil meezaan
  55,9,Wa aqeemul wazna bilqisti wa laa tukhsirul meezaan
  55,10,Wal arda wada'ahaa lilanaame
  55,11,Feehaa faakihatunw wan nakhlu zaatul akmaam
  55,12,Walhabbu zul 'asfi war Raihaanu
  55,13,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,14,Khalaqal insaana min salsaalin kalfakhkhaari
  55,15,Wa khalaqal jaaan mim maarijim min naar
  55,16,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,17,Rabbul mashriqayni wa Rabbul maghribayni
  55,18,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,19,Marajal bahrayni yalta qiyaani
  55,20,Bainahumaa barzakhul laa yabghiyaan
  55,21,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,22,Yakhruju minhumal lu 'lu u wal marjaanu
  55,23,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,24,Wa lahul jawaaril mun sha'aatu fil bahri kal a'laam
  55,25,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,26,Kullu man 'alaihaa faan
  55,27,Wa yabqaa wajhu rabbika zul jalaali wal ikraam
  55,28,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,29,Yas'aluhoo man fissamaawaati walard; kulla ywmin huwa fee shaan
  55,30,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,31,Sanafrughu lakum ayyuhas saqalaan
  55,32,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,33,Yaa ma'sharal jinni wal insi inis tata'tum an tanfuzoo min aqtaaris samaawaati wal ardi fanfuzoo; laa tanfuzoona illaa bisultaan
  55,34,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,35,Yursalu 'alaikumaa shuwaazum min naarifiw-wa nuhaasun falaa tantasiraan
  55,36,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,37,Fa-izan shaqqatis samaaa'u fakaanat wardatan kaddihaan
  55,38,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,39,Fa-yawma'izil laa yus'alu 'an zambiheee insunw wa laa jaann
  55,40,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,41,Yu'raful mujrimoona biseemaahum fa'yu'khazu binna waasi wal aqdaam
  55,42,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,43,Haazihee jahannamul latee yukazzibu bihal mujrimoon
  55,44,Yatoofoona bainahaa wa baina hameemim aan
  55,45,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,46,Wa liman khaafa maqaama rabbihee jannataan
  55,47,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,48,Zawaataaa afnaan
  55,49,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,50,Feehimaa 'aynaani tajriyaan
  55,51,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,52,Feehimaa min kulli faakihatin zawjaan
  55,53,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,54,Muttaki'eena 'alaa furushim bataaa'inuhaa min istabraq; wajanal jannataini daan
  55,55,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,56,Feehinna qaasiratut tarfi lam yatmishunna insun qablahum wa laa jaaann
  55,57,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,58,ka annahunnal yaaqootu wal marjaan
  55,59,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,60,Hal jazaaa'ul ihsaani illal ihsaan
  55,61,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,62,Wa min doonihimaa jannataan
  55,63,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,64,Mudhaaammataan
  55,65,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,66,Feehimaa 'aynaani nad daakhataan
  55,67,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,68,Feehimaa faakihatunw wa nakhlunw wa rummaan
  55,69,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,70,Feehinna khairaatun hisaan
  55,71,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,72,Hoorum maqsooraatun fil khiyaam
  55,73,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,74,Lam yatmis hunna insun qablahum wa laa jaaann
  55,75,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,76,Muttaki'eena 'alaa rafratin khudrinw wa 'abqariyyin hisaan
  55,77,Fabi ayyi aalaaa'i Rabbikumaa tukazzibaan
  55,78,Tabaarakasmu Rabbika Zil-Jalaali wal-Ikraam
