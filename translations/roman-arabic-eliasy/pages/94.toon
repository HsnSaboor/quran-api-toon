quran[3]{c,v,t}:
  94,0,Bismillaahir Rahmaanir Raheem
  94,1,Alam nashrah laka sadrak
  94,2,Wa wa d'ana 'anka wizrak
  94,3,Allazee anqada zahrak
  94,4,Wa raf 'ana laka zikrak
  94,5,Fa inna ma'al usri yusra
  94,6,Inna ma'al 'usri yusra
  94,7,Fa iza faragh ta fansab
  94,8,Wa ilaa rabbika far ghab
