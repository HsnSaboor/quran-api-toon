quran[3]{c,v,t}:
  95,0,Bismillaahir Rahmaanir Raheem
  95,1,Wat teeni waz zaitoon
  95,2,Wa toori sineen
  95,3,Wa haazal balad-il ameen
  95,4,Laqad khalaqnal insaana fee ahsani taqweem
  95,5,Thumma ra dad naahu asfala saafileen
  95,6,Ill-lal lazeena aamanoo wa 'amilus saalihaati; falahum ajrun ghairu mamnoon
  95,7,Fama yu kaz zibuka b'adu bid deen
  95,8,Alai sal laahu bi-ahkamil haakimeen
