quran[3]{c,v,t}:
  93,0,Bismillaahir Rahmaanir Raheem
  93,1,Wad duhaa
  93,2,Wal laili iza sajaa
  93,3,Ma wad da'aka rabbuka wa ma qalaa
  93,4,Walal-aakhiratu khairul laka minal-oola
  93,5,Wa la sawfa y'uteeka rabbuka fatarda
  93,6,Alam ya jidka yateeman fa aawaa
  93,7,Wa wa jadaka daal lan fahada
  93,8,Wa wa jadaka 'aa-ilan fa aghnaa
  93,9,Fa am mal yateema fala taqhar
  93,10,Wa am mas saa-ila fala tanhar
  93,11,Wa amma bi ni'mati rabbika fahad dith
