quran[25{c,v,t}:
82,1,Izas samaaa'un fatarat
82,2,Wa izal kawaakibun tasarat
82,3,Wa izal bihaaru fujjirat
82,4,Wa izal qubooru bu'sirat
82,5,'Alimat nafsum maa qaddamat wa akhkharat
82,6,Yaaa ayyuhal insaaanu maa gharraka bi Rabbikal kareem
82,7,Allazee khalaqaka fasaw waaka fa'adalak
82,8,Feee ayye sooratim maa shaaa'a rakkabak
82,9,Kalla bal tukazziboona bid deen
82,10,Wa inna 'alaikum lahaa fizeen
82,11,Kiraaman kaatibeen
82,12,Ya'lamoona ma taf'aloon
82,13,Innal abraara lafee na'eem
82,14,Wa innal fujjaara lafee jaheem
82,15,Yaslawnahaa Yawmad Deen
82,16,Wa maa hum 'anhaa bighaaa 'ibeen
82,17,Wa maaa adraaka maa Yawmud Deen
82,18,Summa maaa adraaka maa Yawmud Deen
82,19,Yawma laa tamliku nafsul linafsin shai'anw walamru yawma'izil lillaah
83,1,Wailul lil mutaffifeen
83,2,Allazeena izak taaloo 'alan naasi yastawfoon
83,3,Wa izaa kaaloohum aw wazanoohum yukhsiroon
83,4,Alaa yazunnu ulaaa'ika annahum mab'oosoon
83,5,Li Yawmin 'Azeem
83,6,Yawma yaqoomun naasu li Rabbil 'aalameen
