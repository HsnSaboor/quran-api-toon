quran[27{c,v,t}:
89,24,Yaqoolu yaa laitanee qaddamtu lihayaatee
89,25,Fa Yawma izil laa yu'azzibu 'azaabahooo ahad
89,26,Wa laa yoosiqu wasaaqa hooo ahad
89,27,Yaaa ayyatuhan nafsul mutma 'innah
89,28,Irji'eee ilaa Rabbiki raadiyatam mardiyyah
89,29,Fadkhulee fee 'ibaadee
89,30,Wadkhulee jannatee
90,1,Laaa uqsimu bihaazal balad
90,2,Wa anta hillum bihaazal balad
90,3,Wa waalidinw wa maa walad
90,4,Laqad khalaqnal insaana fee kabad
90,5,Ayahsabu al-lai yaqdira 'alaihi ahad
90,6,Yaqoolu ahlaktu maalal lubadaa
90,7,Ayahsabu al lam yarahooo ahad
90,8,Alam naj'al lahoo 'aynayn
90,9,Wa lisaananw wa shafatayn
90,10,Wa hadaynaahun najdayn
90,11,Falaq tahamal-'aqabah
90,12,Wa maaa adraaka mal'aqabah
90,13,Fakku raqabah
90,14,Aw it'aamun fee yawmin zee masghabah
90,15,Yateeman zaa maqrabah
90,16,Aw miskeenan zaa matrabah
90,17,Summa kaana minal lazeena aamanoo wa tawaasaw bissabri wa tawaasaw bilmarhamah
90,18,Ulaaa'ika As-haabul maimanah
90,19,Wallazeena kafaroo bi aayaatinaa hum as-haabul Mash'amah
90,20,Alaihim naarum mu'sadah
