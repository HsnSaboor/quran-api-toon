quran[3]{c,v,t}:
  80,0,Bismillaahir Rahmaanir Raheem
  80,1,'Abasa wa tawallaa
  80,2,An jaa-ahul 'a-maa
  80,3,Wa maa yudreeka la'allahu yaz zakkaa
  80,4,Au yaz zak karu fatanfa 'ahuz zikraa
  80,5,Amma manis taghnaa
  80,6,Fa-anta lahu tasaddaa
  80,7,Wa ma 'alaika allaa yaz zakka
  80,8,Wa amma man jaa-aka yas'a
  80,9,"Wahuwa yakhshaa,"
  80,10,Fa-anta 'anhu talah haa
  80,11,Kalla innaha tazkirah
  80,12,Faman shaa a zakarah
  80,13,"Fi suhufim mukar rama,"
  80,14,"Marfoo'atim mutah hara,"
  80,15,Bi'aidee safara
  80,16,Kiraamim bararah
  80,17,Qutilal-insanu maa akfarah
  80,18,Min aiyyi shai-in Khalaq
  80,19,Min nutfah; khalaqahu faqad-darah
  80,20,Thummas sabeela yas-sarah
  80,21,Thumma amatahu fa-aqbarah
  80,22,Thumma iza shaa-a ansharah
  80,23,Kalla lamma yaqdi maa amarah
  80,24,Falyanzuril insanu ilaa ta-amih
  80,25,Anna sabab nalmaa-a sabba
  80,26,Thumma sha qaqnal-arda shaqqa
  80,27,Fa ambatna feeha habba
  80,28,Wa 'inabaw-wa qadba
  80,29,Wa zaitoonaw wanakh la'
  80,30,Wa hadaa-iqa ghulba
  80,31,Wa faki hataw-wa abba
  80,32,Mata'al-lakum wa li-an'amikum
  80,33,Faiza jaa-atis saakhah
  80,34,Yauma yafir-rul mar-u min akheeh
  80,35,Wa ummihee wa abeeh
  80,36,Wa sahi batihee wa baneeh
  80,37,Likul limri-im-minuhm yaumaa-izin shaa nuy-yughneeh
  80,38,Wujoo huny-yauma-izim-musfira;
  80,39,Dahi katum mustab shirah
  80,40,Wa wujoohuy yauma-izin 'alaiha ghabar a
  80,41,Tarhaquha qatarah
  80,42,Ulaa-ika humul-kafa ratul-fajarah
