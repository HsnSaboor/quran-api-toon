quran[7]{c,v,t}:
  107,1,"Rajt (Muħammad) lil dak li jgiddeb il-Gudizzju"
  107,2,"Huwa dak li jaħqar lill-iltim"
  107,3,"uma jħeggigx (lill-oħrajn) biex jitimgħu l-fqir"
  107,4,"Mela kastig kbir għal dawk (ta' wicc b'ieħor) li (taparsi) jitolbu"
  107,5,"illi ma jagħtux kas tat-talb tagħhom"
  107,6,"dawklijħobbu jidhru (u jagħmlu kollox għal għajnejn in- nies)"
  107,7,"jicħdu l-karita"
