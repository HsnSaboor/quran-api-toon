quran[11]{c,v,t}:
  100,1,"(Naħilfu) fuq iz-zwiemel lebbieta meta jilhgu"
  100,2,"ujtajru x-xrar (fil-giri kbir tagħhom)"
  100,3,"u jaħbtu (għall-għadu) mas-sebħ"
  100,4,"ujqanqlu bih (bil-giri) għabra kbira"
  100,5,"ubih jidħlu f'nofs ta' gemgħa (minn ta' l-għadu)"
  100,6,"(naħilfir) li l-bniedem tabilħaqq ingrat lejn Sidu"
  100,7,"uhuwa tabilħaqq xhud għal dan"
  100,8,"uhuwa tabilħaqq qalil fl-imħabba tal-gid (vsarerjaliji)"
  100,9,"Mela ma jafx li meta jixxerred dak li hemm fl-oqbra"
  100,10,"ujsir magħruf dak li hemm fil-qlub"
  100,11,"dakinhar Sidhom tabilħaqq ikun jaf sew bihom"
