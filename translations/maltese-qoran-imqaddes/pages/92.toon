quran[21]{c,v,t}:
  92,1,"(Naħilfu) fuq il-lejl meta jgħatti (id-dawl bid-dalma tiegħu)"
  92,2,"ufuq in-nhar meta jinkixef (u jxerred id-dawl tiegħu)"
  92,3,"ufuq Min ħalaq lir-ragel u lill-mara"
  92,4,"lir-tħabrik tagħkom huwa tabilħaqq ta' bosta għamliet"
  92,5,"Melamin jagħti (minn gidu) u jibza' minn Alla"
  92,6,"ujemmen fl-aħjar (ħlas fil-Genna)"
  92,7,"senħaffulu (il-mixja) lejn triq il-gid (kotran fil-Genna)"
  92,8,"Izda min jixxaħħaħ u jaħseb li ma għandux bzonn /li/ Alla"
  92,9,"ujgiddeb l-aħjar (ħlas fil-Genna)"
  92,10,"Aħna senħaffulu (il-mixja) lejn it-triq l-iebsa"
  92,11,"Majiswilux gidu meta jinqered (fl-/ 7/e 77i)"
  92,12,"Tabilħaqq f'idejna t-tmexxija t-tajba"
  92,13,"u tagħna, tabilħaqq, l-Aħħar (Ħajja) u l-ewwel"
  92,14,"Għalhekk wissejtkom dwar Nar iħeggeg"
  92,15,"Majinxtewiex fih għajr l-agħar bniedem"
  92,16,"(ligiddeb fis-sewwa) u ma tax kas"
  92,17,"U se jitwarrab minnu l-aktar gust"
  92,18,"lijagħti gidu (biex) jissaffa"
  92,19,"ulejn ħadd ma kien obbligat ta' xi pjacir li jistħoqq jitħallas"
  92,20,"ħliefi jixtieq Wicc Sidu, l-Ogħla"
  92,21,"Huwa tabilħaqq jithenna (fil-Gennajl)"
