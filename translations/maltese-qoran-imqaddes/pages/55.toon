quran[78]{c,v,t}:
  55,1,"(Alla) Kollu Ħniena"
  55,2,"għallem il-Qoran"
  55,3,"Ħalaq il-bniedem"
  55,4,"għallmu t-taħdit"
  55,5,"Ix-xemx u l-qamar (jifħarrku) b'kalkolu (ezatt)"
  55,6,"ul-kwiekeb u s-sigar jinxteħtu (quddiem Alla bil-qima)"
  55,7,"U s-sema (Alla)-refgħu (mingħajr kolorni), u qiegħed il- mizien (għall-għarfien tas-sewwa, taz-zejjed u tan-nieqes)"
  55,8,"biex ma tagħtux uzin ħazin"
  55,9,"Agħtu l-uzin bil-gustizzja, u la tagħtux uzin nieqest"
  55,10,"L-art (A/la) qegħedha għall-ħlejjaq"
  55,11,"fiha frottu sigar tal-palm bl-għenieqed (taz-tamar)"
  55,12,"u l-qmuħ bil-ħliefa u x-xtieli b'riħa tfuħ"
  55,13,"Melaliema għotjiet ta' Sidkom tgiddbu (u ticħdu intom il- bnedmin u l-ginn)"
  55,14,"Ħalaq il-bniedem minn tafal (niexef) li jcencel (meta tħabbat fuqu), bħall-fuħħar"
  55,15,"u ħalaq lill-gini minn nar bla duħħan"
  55,16,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,17,"Sid iz-zewg inħawi tat-tlugħ (tax-xemx u l-qamar). u z- zewg inħawi ta' l-inzul (irinn fejn jinzlu x-xemx u l-qamar)"
  55,18,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,19,"Ħalla z-zewgt ibħra (dak mieleħ u dak ħelu) jimirħu u jiltaqgħu"
  55,20,"bejniethom hemm barrikata li ma jaqbzuhiex"
  55,21,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,22,"Minnhom it-tnejn (miz-zewgt ibħra) joħorgu l-perli u l- qroll"
  55,23,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,24,"Tiegħu l-imriekeb merfugħa, bħall-igbla, fil-baħar"
  55,25,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,26,"Kulmin jinsab fuqha (l-art) għad jintemm"
  55,27,"ujibqa' Wicc Sidek, li tiegħu hi l-glorja u l-gieħ"
  55,28,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,29,"(Jitolbuh fl-għajnuna) dawk li jinsabu fis-smewwiet u fl- ) art; ta' kuljum Huwa f'xi għemil (mill-għemejjel divini I tiegħu)"
  55,30,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,31,"Senieħdu ħsiebkom (u nagħmlu ħaqq minnkom f'Jum il- Qawmien), intom il-bnedmin u l-ginnt"
  55,32,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,33,"Ja gemgħat tal-ginn u tan-nies, jekk tistgħu tinfdu l-inħawi tas-smewwiet u l-art (biex forsi taħarbu l-kastig ta' Alla), mela infdu(kors)i M'intomx se tinfdu(hor), jekk mhux bis- setgħa (tagħnajl)"
  55,34,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,35,"Jintbagħtu fuqkom it-tnejn (dakinhar ta' Jum il-Qawmien) ilsna tan-nar bla duħħan u ram (imdewweb li jissawwab fuqkom), u ma tħarsux lilkom infuskom"
  55,36,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,37,"U meta s-sema jixxaqqaq (f'Jum il-Qawmien) ikun (minn lewn il-) warda, bħall-gild l-aħmar"
  55,38,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,39,"Dakinhar ebda bniedem jew ginn ma jkun mistoqsi dwar id-dnub tiegħu (għaliex ikunu magħrufin il-ħatjin)"
  55,40,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,41,"Il-ħatjin jingħarfu mill-marki tagħhom, u jittieħdu mill- bziebez u mis-saqajn (ir jinxteħtu fl-Infern)"
  55,42,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,43,"Dan hu l-Infern li jgiddbu l-ħatjin"
  55,44,"iduru bejnu (nar l-Infern) u bejn l-ilma li ma jistax jagħli aktar"
  55,45,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,46,"U għal min jibza' li għad iqum quddiem Sidu (il-Mulej) hemm zewg Gonna (waħda għalih u oħra għal niesu)"
  55,47,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,48,"(F'dawn iz-zewg Gonna jinsabu sigar) bi friegħi (mifruxin u bil- frott)"
  55,49,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,50,"Fihomit-tnejn jinsabu zewg għejun ta' ilma gieri"
  55,51,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,52,"Fihomit-tnejn hemm zewg (għamliet) minn kull frotta"
  55,53,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,54,"Mimdudin (ikunu l-gusti) fuq sodod infurrati bl- imbrukkat, u l-frott taz-zewg Gonna jinsab fil-qrib. (u jinqata', kotran, mingħajr tbatija)"
  55,55,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,56,"Fihom (fiz-zewg Gonna) jinsabu nisa li jgħakksu għajnejhom (u jħarsu biss lejn zwieghom), u li, qabilhom, ma messhom la bniedem u lanqas ginn"
  55,57,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,58,"(Dawk in-nisa sbieħ) bħall-gjacint u l-qroll"
  55,59,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,60,"Jaqawil-ħlas tat-tjieba ma huwiex it-tjieba"
  55,61,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,62,"Inqasminn dawn it-tnejn, hemm zewg Gonna (oħra)"
  55,63,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,64,"Jagħtu fl-iswed (daqskemm hemm ħdura u sigar fihom)"
  55,65,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,66,"Fihom it-tnejn hemm zewg għejun ta' ilma jgelgel kotran"
  55,67,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,68,"Fihomit-tnejn hemm frott, sigar tal-palm u rummien"
  55,69,"Melaliema għorjiet ta' Sidkom tgiddbu"
  55,70,"Fihomit-tnejn hemm ħwejjeg tajbin u sbieħ"
  55,71,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,72,"Nisa sbieħ b'għajnejn kbar (imsejħa ħar) mizmuma fit-tined kbar"
  55,73,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,74,"Qabilhom (qabel zwieghom) ma messhom la bniedem u lanqas ginn"
  55,75,"Mela liema għotjiet ta' Sidkom tgiddbu"
  55,76,"Mimdudin (il-gusti) fuq imħaded ħodor u twapet ħoxnin, sbieħ"
  55,77,"Melaliema għotjiet ta' Sidkom tgiddbu"
  55,78,"Mbierek Isem Sidek, li tiegħu hi l-glorja u l-gieħ"
