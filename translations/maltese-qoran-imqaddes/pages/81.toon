quran[29]{c,v,t}:
  81,1,"Metax-xemx tintewa (ts ma ddawwalx aktar)"
  81,2,"meta l-kwiekeb jiddallmu u jaqgħu"
  81,3,"umeta l-igbla jitneħħew"
  81,4,"umeta l-gemliet b'għaxar xhur tqala jitħallew mitluqin"
  81,5,"umeta l-bhejjem salvaggi jingabru"
  81,6,"umeta l-ibħra jsiru ħuggiega"
  81,7,"u meta l-erwieħ jitlaqqgħu ma' dawk li huma bħalhom (it- tajbin mat-tajbin, u l-ħziena mal-ħziena)"
  81,8,"u meta t-tifla midfuna hajja tkun mistoqsija"
  81,9,"għal liema dnub inqatlet"
  81,10,"u meta l-pagni (bl-għemejjel ta' kulħadd) jinfetħu"
  81,11,"u meta s-sema jinqala' (mrinzi posti)"
  81,12,"u meta n-Nar iħeggeg jitkebbes aktar"
  81,13,"umeta l-Genna titqarreb (/ejn it-tajbin)"
  81,14,"(dakinhar kull) ruħ tagħraf dak (it-tajjeb jew il-ħazin) li ħejjiet"
  81,15,"Tabilħaqq naħlef fuq il-kwiekeb li jidhru billejl (i' jinfibew binhar)"
  81,16,"il-gerrejja li (wara l-giri tagħhom fis-sema) jinħbew"
  81,17,"u (naħlef) fuq il-lejl meta jersaq"
  81,18,"ufuq is-sebħ meta jdawwal"
  81,19,"li (il-Qoran) tabilħaqq huwa kliem ta' Mibgħut ta' gieħ (l- anglu Gabrijel li wassal ir-Rivelazzjoni)"
  81,20,"(anglu) mogħni b'qawwa, imqiegħed fis-sod għand Dak tat- Tron (Alla)"
  81,21,"lihuwa obdut hemmhekk (fis-smewwiet, mill-angli), u fidil"
  81,22,"Seħibkom (Muħammad, ja nies Qurajx) ma huwiex mignun"
  81,23,"u (Muħammad) tassew rah (lill-anglu Gabrijel) fix-xefaq car"
  81,24,"Ma huwiex xhiħ fil-mistur (u jkabbar kulma jitnizzel. lilu mis-sema)"
  81,25,"u (dan il-Qoran) ma huwiex kliem xitan misħut"
  81,26,"Mela fejn sejrin (bi ħsiebkom u kliemkom)"
  81,27,"Dan mahuwiex għajr tifkira ( 4 fwissija) lill-ħolqien"
  81,28,"għal min minnkom irid jimxi dritt"
  81,29,"Umatridux. ħlief jekk irid Alla Sid il-ħolqien"
