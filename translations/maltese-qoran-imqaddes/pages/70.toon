quran[44]{c,v,t}:
  70,1,"Xiħadd (pagan) talab il-kastig (ta' Alla) li (zgur) gej"
  70,2,"għal dawk li ma jemmnux, u ma għandux min izommu foni//i jseħħ"
  70,3,"(kastig) minn Alla li għandu turgien it-tlugħ"
  70,4,"L-angli u r-ruħ (l-anglu Gabrijel) jitilgħu lejh f'Jum twil daqs ħamsin elf sena (Jum il-Qawmien)"
  70,5,"Mela stabar (Muħammad) b'sabar tajjeb (kif jixraq; u tħallix lill-pagani jkidduk)"
  70,6,"Huma tabilħaqq li (il-kastig) jarawh imbiegħed"
  70,7,"izda Aħna narawh qrib"
  70,8,"Fil-Jum meta s-sema jkun bħar-ram imdewweb"
  70,9,"ul-igbla jkunu bħas-suf"
  70,10,"il-ħabib ma jistaqsix għal ħabibfi"
  70,11,"(għalkemm) ikunu mgiegħla jħarsu lejn xulxin (i jagħrfir lil xulxin). Dakinhar il-ħati jkun jixtieq jinfeda mill-kastig b'uliedu (billi jibgħat lilhom għall-kastig)"
  70,12,"u b'seħbitu (martu u b'ħuh)"
  70,13,"ubi qrabatu li tawh kenn"
  70,14,"u b'kulmin jinsab fl-art, Imbagħad (jirtama (i dan) jeħilsu (mill- kastig tan-Nar iħeggeg)"
  70,15,"Melale' Hija tabilħaqq Ħuggiega"
  70,16,"litaqla' l-gilda tar-ras"
  70,17,"ussejjaħ lil-min ta dahru u ma tax widen (lifl-Mibgħutin ta' Alla)"
  70,18,"u/gema' (il-gid tad-dinja) u refgħu (u ma tax lill-fqar)"
  70,19,"Il-bniedem tabilħaqq inħalaq imbezza' (u dejjem għandu xi ħaga li tkiddu)"
  70,20,"Meta jmissu d-deni (sew jekk mard u sew jekk faqar, arah) bla sabar u tama"
  70,21,"u meta jmissu l-gid (sew jekk saħħa u sew jekk għana, arah) izommu għalih biss"
  70,22,"ħlief dawk li jitolbu"
  70,23,"Dawkli dejjem medhija fit-talb tagħhom"
  70,24,"udawkli f'gidhom hemm jedd magħruf (iz-zakar, li hi l-karita li l- Mislem obbligat jagħti)"
  70,25,"lit-tallab u lill-imcaħħad"
  70,26,"udawk li jemmnu f'Jum il-Ħaqq"
  70,27,"uli huma mbezzgħin mill-kastig ta' Sidhom"
  70,28,"tabilħaqq li l-kastig ta' Sidhom ma fihx serħan il-moħħ"
  70,29,"u dawk li jħarsu l-partijiet privati ta' gisimhom fminx arti sesswali illegali"
  70,30,"(furma jersqux) ħlief lejn zwieghom, jew lejn dawk (in-nisa Isiera) li għandhom f'idejhom, u għalhekk ma humiex ta' min ilumhom"
  70,31,"izda min ifittex aktar minn dak (li huwa permess), dawk ikunu (il- ħarjin) li jaqbzu l-limiti"
  70,32,"u dawk li jħarsu l-onesta u rsrabta tagħhom (li jkunu fidili ma' nieshom)"
  70,33,"u dawk li jwettqu x-xhidiet tagħhom"
  70,34,"udawklli jħarsu t-talb tagħhom"
  70,35,"dawkikunu f'Gonna mweggħini"
  70,36,"Xi gralhom (Muħammad) dawk li ma jemmnux, gejjin jgħagglu (u jiccassaw) lejk"
  70,37,"fuq il-lemin u fuq ix-xellug, f'gemgħat (sħaħ)"
  70,38,"Jaqaw kull wieħed minnhom jittama li jidħol fi Gnien il-hena"
  70,39,"Mela let Aħna tabilħaqq ħlaqniehom minn dak li jafu (minn nitfa ta' sperma, u għalhekk ma għandhomx għalfejn jitkabbru)"
  70,40,"Jiena tabilħaqq naħlef b'Sid l-inħawi minn fejn titla' x- xemx u minn fejn tinzel illi Aħna għandna s-setgħa"
  70,41,"linbiddluhom ma' (min hu) aħjar minnhom, u m'Aħniex se ningħelbu"
  70,42,"Mela ħallihom (Muħammad) iħawdu u jilagħbu (bil-kliem fieragħ) sa ma jsibu l-Jum tagħhom li kienu mwegħdin"
  70,43,"fil-Jum meta joħorgu mill-oqbra, mgħagglin, qishom iħaffu lejn xi ħagra mwaqqfa (biex jagħtuha qima)"
  70,44,"b'ħarsithom 'l isfel jegħlibhom it-tkasbir. Dak huwa l-Jum li kienu mwegħdinl"
