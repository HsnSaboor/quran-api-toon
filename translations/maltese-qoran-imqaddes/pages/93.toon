quran[11]{c,v,t}:
  93,1,"(Naħilfur) fuq id-dawl ta' l-għodwa"
  93,2,"ufuq il-lejl ħiemed u mudlam"
  93,3,"Matelqekx Sidek (Muħammad), u (lilek) ma bagħadx"
  93,4,"Tabilħaqq li l-Aħħar (ħajja) hija aħjar għalik mill-ewwel"
  93,5,"uSidek tabilħaqq se jagħtik, u inti tithenna"
  93,6,"(Jaqaw ma sabekx iltim u ta/k) kenn"
  93,7,"usabek mitluf u wriek it-triq"
  93,8,"usabek fil-ħtiega u ta(k) il-gid"
  93,9,"Melalill-iltim la taħqarx"
  93,10,"ulit-tallab la ccanfarx u la tkeccix"
  93,11,"ul-grazzja ta' Sidek xandarhal"
