quran[96]{c,v,t}:
  56,1,"Metal-Grajja (ta' Jun il-Qawmien) isseħħ"
  56,2,"uħadd ma jista' jgiddeb meta sseħħ"
  56,3,"litmizzel (lil uħud fl-Infern) u tgħolli (oħrajn fil-Genna)"
  56,4,"metal-art tithezzez sewwa"
  56,5,"ul-igbla jitfarrku"
  56,6,"ujsiru għabra mxerrda (mar-riħ)"
  56,7,"(dakinhar) tkunu tliet gemgħat (dawk li jigu l-ewwel. fl- għemejjel tajba, imbagħad nies il-lemin, jigifieri l-bqija tan- nies li jidħlu l-Genna, u nies ix-xellug li jmorru l-Infern)"
  56,8,"Niesil-lemin (taf xejn) min huma nies il-lemin"
  56,9,"Uniesix-xellug ( 1a/xejn) min huma nies ix-xellug"
  56,10,"U dawk li jisbqu (lil kulħadd fl-għemejjel tajba) ikunu dawk li jisbqu (lil kulħadd fit-tgawdija fil-Genna)"
  56,11,"Dawk huma li jitqarrbu (lejn 4/la)"
  56,12,"fil-Gonna ta' l-hena"
  56,13,"(ta' l-ewwel ikunu) gemgħa kbira mill-(gnus) tal-qedem"
  56,14,"uftitmill-(g 115) ta' l-aħħar (li gew wara)"
  56,15,"Fuq divani (iqiegħdu) minsuga (bid-deheb u bil-ħaga prezzjuz)"
  56,16,"mimdudin fuqhom, quddiem xulxin"
  56,17,"jduru magħhom (biex jaqduhom) zgħazagħ subien li qatt ma jmutu"
  56,18,"bi bwieqi, buqari u tazza (bl-iffen inbid migjub) minn għajn (mill-għejun kotrana tal-Genna)"
  56,19,"la tugagħhom rashom bih u lanqas jiskru"
  56,20,"U (ikollhom) frott (kotran), minn kulma jagħzlu"
  56,21,"ulaħam it-tajr, minn kulma jixtiequ"
  56,22,"unisa sbieħ b'għajnejn kbar"
  56,23,"bħall-perli mkennin"
  56,24,"(dan kollu) bi ħlas ta' dak (il-gid) li kienu jagħmlu"
  56,25,"Fiha (fil-Genna) la jisimgħu kliem ta' frugħa u lanqas ħtija"
  56,26,"(majjisimgħux) għajr il-kliem: sliem (is aktar) sliem"
  56,27,"U nies il-lemin (taf xejn) min huma nies il-lemin"
  56,28,"(Huma jkunu fid-dell) f'nofs sigar bla xewk (u mimli frott)"
  56,29,"(taħt) sigar tal-banana mgħobbija frott"
  56,30,"(ujkunu f) dell dejjiem"
  56,31,"(ufgrib) ilma jgelgel"
  56,32,"ufrott kotran"
  56,33,"(li) la jintemm, u lanqas ikun projbit"
  56,34,"U (jimteddu) fuq sodod merfugħa"
  56,35,"Tabilħaqq li (fin-nisa tal-Genna) ħlaqniehom bħala ħolqien (gdid)"
  56,36,"u għamilniehom vergni"
  56,37,"ujħobbu biss lil zwieghom; u (jkunu) tamparhom"
  56,38,"(nisasafja) għal nies il-lemin"
  56,39,"(Huma) gemgħa kbira mill-(gnus) tal-qedem"
  56,40,"u gemgħa kbira mill-(g/us) ta' l-aħħar (li gew wara)"
  56,41,"Uniesix-xellug (af xejn) min huma nies ix-xellug"
  56,42,"(Dawn) ikunu f'riħ jaħraq u ilma jagħli"
  56,43,"(u jkunu) f'dell id-duħħan sewdien"
  56,44,"delljili la hu biered u lanqas sabiħ"
  56,45,"Qabel dak (il-kastig, meta kienu għadhom fid-dinja) huma tabilħaqq kienu fi tgawdija u f'lussu kbir, I"
  56,46,"ukienu jwebbsu rashom fid-dnub il-kbir (il-paganizmu)"
  56,47,"Kienu jgħidu: 'Jaqaw meta mmutu u nsiru trab u għadam, tabilħaqq għad nitqajmu mill-mewt"
  56,48,"umissirijietna tal-qedem ukoll"
  56,49,"Għid(ilhom Muħammad): ''Tabilħaqq li l-gnus tal-qedem u. ta' l-aħħar (li gew warajhom)"
  56,50,"tassew jingemgħu ( 4 jitqajmu) għall-waqt ta' Jum magħruf"
  56,51,"Imbagħad tabilħaqq li intom, ja mitlufin. li giddibtu (il- qawmien mill-imwiet)"
  56,52,"setieklu minn sigar taz-zaqgiim (li jikber biss f'qiegħ l-Infern u li l-frott tiegħu huwa wisq ħazin)"
  56,53,"usetimlew zaqqkom bih"
  56,54,"u fuqu (dak l-ikel mis-sigra ħazina) tixorbu ilma jagħli"
  56,55,"utixorbu (kemm tifilħu minnu) bħalma jixrob il-gemel għatxanl"
  56,56,"Dan hemm imħejji għalihom f'Jum il-Ħaqql"
  56,57,"Aħna ħlaqniekom (mix-xejn). Mela għaliex ma temmnux (/i se nqajmukom għal ħajja gdida)"
  56,58,"Ħabbruni: dik iz-zerriegħa (ta' l-isperma) li-xxerrdu (minn gisimkom, u minnha jitnisslu l-ulied)"
  56,59,"jaqaw intom toħolquha, jew Aħna l-Ħallieqa"
  56,60,"Aħna ordnajna l-mewt fostkom u ħadd ma jgħaddina (jew iwaqqafna)"
  56,61,"(ekk irridu nistgħu neqirdikom) u nibdlukom b'nies bħalkom, u (f'kum il-Qawmien) nerggħu nagħmlukom (ħolqien gdid) b'mod li ma tafux"
  56,62,"Intom tassew tafu l-ewwel ħolqien, Mela kif ma tiftakrux (Iz Alla joħloq ukoll it-tieni ħolqien)"
  56,63,"Ħabbruni: dak li tizirgħu"
  56,64,"jaqaw intom tkabbruh, jew Aħna dawk li nikabbru"
  56,65,"Kieku ridna, (dan il-mizrugħ) għamilnieh karfa, u kontu tibqgħu tistagħgbu (i tgħidu)"
  56,66,"S'Aħna tassew tellifini"
  56,67,"Le, (mhux biss, anzi) aħna mcaħħdini"
  56,68,"Ħabbrumi: l-ilma li tixorbu"
  56,69,"jaqaw intom nizziltuh mis-sħab, jew Aħna li nnizzlub"
  56,70,"Kieku ridna, (dan l-ilma) konna nagħmluh mielaħ fir ma jinxtorobx). Mela kif ma tizzux ħajr"
  56,71,"Ħabbruni: in-nar li tkebbsu"
  56,72,"jaqaw intom kabbartu s-sigra tiegħu (biex ikollkom l-injam xi tqabbdu u x'itfeħu fih), jew Aħna kabbarnieha"
  56,73,"Aħna (in-nar tad-dinja) għamilnieh tifkira. (tan-nar ta' l- Infern): u kumdita għal dawk li jterrqu u jsiefru"
  56,74,"Mela sebbaħ b'Isem Sidek ta' kobor bla tarfl"
  56,75,"Tabilħaqq naħlef fuq l-imkejjen ta' nzul il-kwiekeb"
  56,76,"u(din) hija tabilħaqq ħalfa kbira, kieku tafu"
  56,77,"li tabilħaqq huwa Qoran ta' gieħ"
  56,78,"(li jinsab) fi Ktieb imħares (għand Alla)"
  56,79,"majjmissuhx għajr l-imsaffijin"
  56,80,"tinzil (b 'Rivelazzjoni) minn Sid il-ħolqien"
  56,81,"Jaqaw intom tgiddbu dan il-kliem (dwar il-Qoran)"
  56,82,"u tagħmlu l-għajxien tagħkom billi tgiddbu (il-Qoran, minflok tizzu ħajr ta' kulma Alla għamel magħkom)"
  56,83,"Mela meta (ir-ruħ) tasal sal-gerzuma (ta' dak li wasal biex imut)"
  56,84,"uintom, dak il-ħin, tkunu qegħdin tħarsu"
  56,85,"u- Aħna nkunu eqreb lejh minnkom, izda ma tarawx"
  56,86,"jekk intom meħlusin mill-ħaqq, (kif tgħidu)"
  56,87,"għaliex ma tregggħuhiex lura (fir-ruħ tal-mejjef biex ma jsirx ħaqq minnha), jekk qegħdin tgħidu s-sewwa"
  56,88,"Mela jekk (il-mejjet) ikun minn dawk li tqarrbu (/ejn Alla bl-għemejjel tajba tagħhom)"
  56,89,"(ikollu) mistrieħ, gid u Gonna ta' hena (fl-Għeden)"
  56,90,"U jekkikun minn nies il-lemin"
  56,91,"(jingħad lilu): ''Sliem lilek minn nies il-lemint"
  56,92,"Izda jekk ikun minn. dawk li giddbu (is-sewwa), il- mitlufin"
  56,93,"il-merħba (li jingħata tkun) ta' ilma jagħli"
  56,94,"uħruq fin-Nar iħeggeg (ta' l-Infernji)"
  56,95,"Tabilħaqq lidan (kollu li ħabbarnielek, Muħammad) huwa s-sewwa kollu minnul"
  56,96,"Mela sebbaħ Isem Sidek, il-Kbir bla qjiesl"
