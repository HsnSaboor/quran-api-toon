quran[19]{c,v,t}:
  96,1,"Aqra (Muħammad) f'Isem Sidek li ħalaq"
  96,2,"ħalaq lill-bniedem minn demm magħqud"
  96,3,"Aqral Sidek huwa l-Aktar ta' gieħ"
  96,4,"li-għallem bil-pinna"
  96,5,"għallem lill-bniedem dak li ma jafx"
  96,6,"Tabilħaqq li l-bniedem igib ruħu ħazin wisq"
  96,7,"għaliex jaħseb li stagħna (i: ma jeħtiegx lil Alla)"
  96,8,"Tabilħaqq lejn Sidek il-wasla lural"
  96,9,"Rajt (Muħammad) lil dak ('Abiz Gahi)' li ma jħallix"
  96,10,"qaddej meta jitlob"
  96,11,"Rajtjekk kienx fit-triq it-tajba"
  96,12,"jewjordnax il-biza' ta' Allaz"
  96,13,"Rajt (Muħammad) jekk giddibx (il-Qoran) u ta(h) dahru"
  96,14,"Melamajafx li Alla jara' I"
  96,15,"Lel Jekk mhux se jieqaf (illi jfixkel lill-Misilmin), se naqbdufh) mill-bezbuza"
  96,16,"bezbuza giddieba u ħatja (u nixħadi fin-Nar)l"
  96,17,"Imbagħad ħalli jsejjaħ lil sħabu (għall-għajnuna) l"
  96,18,"Aħna nsejħu lill-angli tal-kastig (biex jixħtuh fin-Nar)"
  96,19,"Let Tismax minnu (u (a titlaqx it-talb) izda nxteħet fl-art u ersaq (lejn Alla)"
