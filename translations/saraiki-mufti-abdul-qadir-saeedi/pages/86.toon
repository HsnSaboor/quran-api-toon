quran[7{c,v,t}:
4,45,تے اللہ ݙاڈھا ڄاݨدے تُہاݙے دشمنیں کوں تے اللہ (تہاݙا) حمایتی کافی ہے تے اللہ مددگار کافی اے
4,46,یہودیں وچوں کجھ لوک بدلا ݙیندن (اللہ دے) کلمات اوندی جا کنوں تے آکھدن اساں سݨیا تے نہ منیا تے سݨو تُہاکوں نہ سُنڑیجے تے (آکھدن) راعنا اپݨی زبانیں کوں وَٹ ݙیندے ہوئے تے دین اچ اعتراض کریندے ہوئے تے جیکر او آکھن ہا اساں سُنڑیا تے تابعداری کیتی تے (سوہݨا )اساݙی ڳالھ سݨو تے ساݙے اتے نظر (کرم) فرماؤ تاں انہیں واسطے چنڳا تے درست ہووے ہا لیکن انہیں تے (تاں) اللہ لعنت وسائی اے انہیں دےکفر دی وجہ نال لہٰذا ایمان ناں انیسن سوائے چند لوکیں دے
4,47,اے کتاب والو ایمان آنو اُوں تے جو اساں اتاریے اوندی تصدیق کرݨ والا اے جو تُہاݙے کول اے (ایمان آنو) ایں کنوں پہلے جو اساں شکلاں وڳاڑ ݙیوں تے اونکوں اوندی پُٹھ ݙے پھیرݙیوں یا انہیں تے لعنت وساؤں جیویں چَھݨ چَھݨ والیں تے لعنت وسائی ہاسے اتے اللہ دا حکم پورا تھی تے رہندے
4,48,بے شک اللہ اے ڳالھ نہیں معاف کریندا جو اُوندے نال شرک کیتا ونڄے تے ایں دے سوا بخش ݙیندے جینکوں چاہے تے جیرھا اللہ نال شرک کرے تاں یقیناً اُوں وݙے جرم دا بہتان ٻدھے
4,49,کیا تیں نہیں ݙٹھا انہیں کوں جیرھے پاک صاف بنڑیندن آپ کوں بلکہ اللہ پاک بنڑیندے جینکوں چاہے تے انہیں تے دھاڳے جتنا ظلم نہ کیتا ویسے
4,50,ݙیکھو کیویں اللہ تے کوڑدا بہتان گھڑی کھڑن تے (انہیں دے کیتے)ایہو چٹ پدھرا گناہ ݙھیر اے
4,51,کیا تُساں او نہیں ݙٹھے جنھیں کوں کتاب (الٰہی)دا حصہ ݙتا ڳیا ایمان انیندن بت تے شیطان تے تے آکھدن کافریں دے بارے جو ایہے مسلمانیں کنوں زیادہ سدھے رستے تے ہن
