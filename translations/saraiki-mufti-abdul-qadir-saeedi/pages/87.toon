quran[8{c,v,t}:
4,52,اے او ہن جنھیں تےاللہ لعنت کیتی اے تے جیں تے اللہ لعنت وساوے توں کݙاہیں اوند اکوئی مددگار نہ پیسیں
4,53,کیا انہیں دا کوئی حصہ اے خدائی اچ (جے اینویں ہوندا)تاں اے نہ ݙیندے لوکیں کوں تِل جتنا
4,54,یا اے لوکیں نال حسد کریندن اُوں چیز تے جو اللہ نے انہیں کوں اپݨے فضل نال ݙتے اساں تاں یقیناً ݙتی اے ابراہیم دی اولاد کوں کتاب تے حکمت تے انہیں کوں ݙتے سے وݙا ملک
4,55,پچھے انہیں وچوں کئی اُوں تے ایمان گھن اے تے انہیں وچوں کئی اُوں کنوں منہ پھیر ڳے تے (انہیں کیتے)بھڑکدی بھا کافی اے
4,56,بے شک جنھیں ساݙیں ایتیں نال کفر کیتے اساں انہیں کوں داخل کریسوں بھا وچ جیں ویلھے انہیں دے چم سڑ ڳل (پک) ویسن اساں انہیں کوں چم بدلا ݙیسوں ٻے تاکہ عذاب چکھدے رہن بے شک اللہ غالب اے حکمت والا اے
4,57,تے جنھیں ایمان آندے تے چنڳیں کم کیتے نیں عنقریب اساں انہیں کوں باغیں (بہشتیں) وچ داخل کریسوں جیں تلے نہراں وہندیاں پن اُوندے وچ ہمیشہ رہسن انہیں کیتے اُوندے (بہشت) اچ پاک صاف بیویاں ہن تے اساں انہیں کوں گھاٹی چھاں اچ داخل کریسوں
4,58,بے شک اللہ تُہاکوں حکم ݙیندے جو امانتاں اُوندے مالکیں کوں پہنچا ݙیو تے جیں ویلھے فیصلہ کرو لوکیں دے درمیان تاں انصاف دا فیصلہ کرو یقیناً اللہ تُہاکوں کے جھی چنڳی نصیحت فرمیندے بے شک اللہ سݨݨ والا ݙیکھݨ والا اے
4,59,اے ایمان والو حکم منو اللہ دا تے تابعداری کرو رسول اللہ دی تے حاکم دی جیرھا تُہاݙے وچوں اے ول جیکر جھڳڑا کرو کہیں معاملے وچ تاں اُوں دا رجوع کرو اللہ دی طرف تے رسول اللہ دی طرف جے تُساں اللہ کوں تے قیامت دے ݙینہہ کوں منیندو ایہو چنڳا اے تے سوہݨا نتیجہ اے
