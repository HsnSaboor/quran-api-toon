quran[6{c,v,t}:
4,122,تے جنھیں ایمان آندے تے نیک عمل کیتے نیں عنقریب انہیں کوں اساں داخل کریسوں بہشتیں وچ جیں تلے نہراں وہندیاں پن اُوندے وچ ہمیشہ رہسن اللہ دا وعدہ سچا اے تے اللہ کنوں ڳالھ اچ کون سچا اے
4,123,نہ تُہاݙے خیالیں تے ہے (چھٹکارا) تے نہ اہل کتاب دے خام خیالیں تے تے جیرھا برا کم کرے اُوندا بدلہ چیسے تے اپݨے واسطے نہ پیسے اللہ دے سوا کوئی دوست تے نہ کوئی مددی
4,124,تے جیرھا نیک عمل کرے مرد ہووے یا عورت شرط ہے جو مومن ہووے تاں او لوک بہشت اچ ویسن تے انہیں تے تل جتنا وی ظلم نہ کیتا ویسے
4,125,تے کون سوہنڑیں دین والا اے اُوں کنوں جیں اپݨا منہ اللہ کیتے جھکا ݙتے اتے اونیکو کار ہے تے دین ابراہیمی دی تابعداری کیتی ہس جیرھا ہر غلط کنوں منہ پھیرݨ والا اے تے اللہ ابراہیم کوں دوست بݨا گدھے
4,126,تے اللہ دا اے جو کجھ اسمانیں وچ اے تے جو کجھ زمینیں وچ اے تے اللہ ہر شے کوں احاطہ کرݨ والا اے
4,127,تے (اے حبیب) تُساں کنوں فتویٰ پُچھدن عورتیں دے بارے فرما ݙیو اللہ تُہاکوں فتویٰ ݙیندے انہیں دے بارے تے جیرھا تُہاݙے اُتے پڑھیا ویندے کتاب (قرآن)وچ یتیم بچیاں دے بارے جو تُساں انہیں کوں ݙیندے نوھے جو انہیں کیتے مقرر کیتا ڳے تے شوق رکھدو جو انہیں نال نکاح کرو (مال بٹورݨ سانگے) تے کمزور ٻالیں دے بارے وی (رب تُہاکوں فتویٰ ݙیندے )تے اے جو قائم رہو یتیمیں واسطے انصاف نال تےجو وی تُساں نیکی کرو تاں یقیناً اللہ اونکوں ڄاݨدے
