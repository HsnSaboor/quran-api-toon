quran[5{c,v,t}:
66,8,اے ایمان والو توبہ کرو اللہ دی طرف خالص پکی توبہ قریب اے کہ تُہاݙا رب مٹا ݙیوے تُساں کنوں تُہاݙے گناہ اتے داخل کرے تُہاکوں باغیں وچ جنھیں تلے جاری ان نہراں جیں ݙینہہ رسوا نہ کریسے اللہ (اپݨے) نبی کوں اتے انہیں کوں جیرھے اُوندے نال ایمان والے ہن انہیں دانور دوڑدا ہوسے انہیں دے اڳوں اتے سڄے پاسوں آکھسن اے ساݙا رب کامل کر ݙے ساݙے واسطے ساݙا نور اتے ساکوں بخش ݙے بے شک توں ہر شے تے قادر ہیں
66,9,اے نبی جہاد کرو کافریں اتے منافقیں نال اتے انہیں تے سختی کرو اتے انہیں دا ٹکاݨہ دوزخ اے اے کے جھا برا ٹکاݨہ اے
66,10,بیان فرمائی اے اللہ نے مثال کافریں واسطے نوح دی گھر والی اتے لوط دی گھر والی دی ݙوہیں ہن ساݙے ݙو نیک صالح بندیں (نبییں) دے نکاح اچ ول انہیں خیانت کیتی انہیں نبییں نال (دین اچ) پِچھے نہ فائدہ ݙتا انہیں کوں نبییں اللہ دے سامݨے کہیں شے دا اتے فرمایا ڳیا ݙوہیں دوزخ اچ داخل تھیوو داخل تھیوݨ والیں نال
66,11,اتے بیان فرمائی اللہ نے مومنیں واسطے مثال فرعون دی گھر والی دی جیں ویلھے آکھیس میݙا رب بݨا میݙے واسطے اپݨے کول گھر جنت اچ اتےمیکوں بچا فرعون کنوں اتے اُوندے کم کنوں اتے میکوں نجات ݙے ظالم قوم کنوں
66,12,اتے عمران دی (پاک) دھی مریم دی (مثال) جیں محفوظ رکھیا اپݨی عزت کوں ول پھوک ݙتوسے اُوندے (گریبان) اچ اپݨی (طرفوں خاص) روح اتے تصدیق کیتس اپݨے رب دے کلمات تے اُوندے کتابیں دی اتے او فرماں برداریں وچوں ہئی
