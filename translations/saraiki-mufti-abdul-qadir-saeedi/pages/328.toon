quran[9{c,v,t}:
21,73,اتے انہیں کوں پیشوا بݨایوسے (لوکیں کوں) ہدایت ݙیندے ہن ساݙے حکم نال تے انہیں ݙے چنڳے کمیں دی وحی کیتوسے تے نماز دی پابندی دی تے زکوٰۃ ݙیوݨ دی تے او ساݙے عبادت گزار ہن
21,74,اتے لوط کوں اساں حکومت تے علم ݙتا تے اونکوں اُوں وستی کنوں بچایوسے جیرھےٻہوں برے کم کریندے ہن بے شک او ٻہوں گندی تے فاسق قوم ہئی
21,75,اتے اونکوں داخل کر گدھو سے اپݨی رحمت وچ بے شک او نیکیں وچوں ہا
21,76,اتے نوح کوں (یاد کرو) جݙاں ایں کنوں پہلے پکاریا ہس پِچھے اساں اوندی دعا قبول کیتی تے اونکوں تے اُوندے اہل و عیال کوں وݙی سختی کنوں بچا گدھوسے
21,77,تے اوندی مدد کیتوسے اُوں قوم دے مقابلے جنھیں ساݙیا ں آیتاں جھٹلایاں ہن بے شک او بری قوم ہن لہٰذا انہیں سب کوں غرق کر ݙتوسے
21,78,تے داؤد تے سلیمان کوں (یا د کرو) جݙاں او کھیتی بارے فیصلہ کر ریہے ہن جیں ویلھے (رات کوں) اُوندے وچ کجھ لوکیں دیا ں ٻکریاں چھُٹ ڳیاں ہن تے اساں انہیں دے فیصلے تے موجو دہاسے
21,79,ول اوندی سمجھ ݙتوسے سلیمان کوں تے ہر ہک کوں اساں حکومت تے علم ݙتا ہاتے پابند کر ݙتوسے داؤد نال پہاڑ اتے پکھی تسبیح آکھدے ہن (ذکر کریندے ہن) تے اے اساں کرݨ والے ہاسے
21,80,تے اساں اونکوں سکھایا لباس (زرہ) تیار کرݨ تُہاݙے واسطے تاکہ تُہاکوں تہاݙی (جنگ دے) وار کنوں محفوظ کرے ول کیا تُساں شکر کرݨ والے ہو
21,81,اتے سلیمان واسطے پابند کیتوسے تیز ہوا چلدی ہئی اُوندے حکم نال اُوں زمین ݙے جیندے وچ اساں برکتاں رکھیاں اتے اساں ہر شئے کوں ڄاݨدے سے
