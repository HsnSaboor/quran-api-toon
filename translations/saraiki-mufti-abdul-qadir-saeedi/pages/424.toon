quran[7{c,v,t}:
33,44,انہیں دی دعا جیں ݙینہہ اُونکوں ملسن سلام ہوسے اتے انہیں واسطے تیار کیتس عزتیں والا ثواب
33,45,اے نبی بے شک اساں تُہاکوں بھیڄے گواہ (حاضر) بݨاتے اتے خوشخبری ݙیوݨ والا تے ݙر سݨاوݨ والا
33,46,اتے اللہ ݙے دعوت ݙیوݨ والا اُوندے حکم نال اتے روشن کرݨ والا سجھ بݨاتے
33,47,اتے مومنیں کوں خوشخبری ݙیو جو بے شک انہیں واسطے اللہ دی طرفوں وݙا فضل اے
33,48,اتے ڳالھ نہ منو کافریں تے منافقیں دی اتے در گزر کرو انہیں دے ستاوݨ کوں اتے اللہ تے بھروسہ رکھو اتے اللہ کافی اے کم بݨاوݨ والا
33,49,اے ایمان والو جیں ویلھے نکاح کرو مومن عورتیں نال ول انہیں کوں طلاق ݙے ݙیو انہیں کوں ہتھ لاوݨ توں پہلے تاں تُہاݙے واسطے انہیں تے کوئی عدت کینی جیرھی تُساں گنڑو لہٰذا انہیں کوں سامان ݙیو اتے انہیں کوں سوہنڑیں طریقے نال چھوڑ ݙیو
33,50,اے نبی (سوہنڑاں) بے شک اساں تُہاݙے واسطے حلال کر ݙتن تُہاݙیاں گھر والیاں جنھیں دے تُساں مہر ادا کیتن اتے تُہاݙیاں ٻانھیاں جو اللہ نے تُہاݙے واسطے غنیمت عطا فرمائی اے اتے تُہاݙے چاچے دا دھیاں اتے تُہاݙی بوا دیاں دھیاں اتے تُہاݙے مامیں دیاں دھیاں اتے تُہاݙی ماسیں دیاں دھیاں جنھیں تُہاݙے نال ہجرت کیتی اے اتے مسلمان عورت جیکر نذر کرے اپݨی جان نبی (پاک) دی بارگاہ اچ جیکر نبی ارادہ فرماوے اُوندے نال نکاح دا اے (حکم) تُہاݙے واسطے خاص اے ٻئے مومنیں دے سوا بے شک ساکوں معلوم اے جو اساں مقرر کیتے مسلمانیں تے انہیں دے گھر والیں اتے انہیں دے ٻانھیں بارے تاکہ تُہاݙے اُتے کوئی حرج نہ ہووے اتے اللہ بخشݨ والا اے رحم والا اے
