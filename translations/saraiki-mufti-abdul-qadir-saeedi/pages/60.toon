quran[3]{c,v,t}:
  60,0,اللہ دے ناں نال (شروع کرینداں) جو ٻہوں مہربان ݙاڈھا رحیم اے
  60,1,اے ایمان والو نہ بݨاؤ میݙے دشمنیں تے اپݨے دشمنیں کوں دوست تُساں بھجیندو انہیں ݙے (ڳالھیں) دوستی نال حالانکہ انہیں انکار کر ݙتے اُوں حق دا جو تُہاݙے کول اے کڈھیے نے رسول کوں تے تُہاکوں (صرف) ایں واسطے جو تُساں ایمان آندے اللہ نال جو تُہاݙا رب اے جیکر تُساں نکلیو میݙے راہ اچ جہاد واسطے اتے میݙی رضا دی طلب واسطے (تاں انہیں کوں دوست نہ بݨاؤ) تُساں لُک تے انہیں ݙے پیغام ݙیندو دوستی دا اتے میں ڄاݨداں جو تُساں لُکائے اتے جو تُساں ظاہر کیتے اتے جیرھا اے کجھ کریسے تُساں وچوں تاں بے شک او گمراہ تھی ڳے سدھے راہ کنوں
  60,2,جیکر تُہاݙے اتے قابو پاون تاں تُہاݙے دشمن ہوسن اتے تُساں ݙے اپݨے ہتھ تے اپݨیاں زباناں لمبیاں کریسن برائی نال اتے پسند کریندن جو کاش تُساں وی کافر تھی ونڄو
  60,3,اصلوں نہ فائدہ ݙیسن تُہاکوں تُہاݙے رشتے اتے نہ تُہاݙیاں اولاداں قیامت دے ݙینہہ جدائی کر ݙیسے (اللہ) تُہاݙے درمیان اتے اللہ جو تُساں کریندو ݙیکھݨ والا اے
  60,4,بے شک تُہاݙے واسطے بہترین نمونہ اے ابراہیم اتے اُوندے ساتھیں وچ جیں ویلھے آکھ ݙتونے اپݨی قوم کوں بے شک اساں بیزار اُوں تُساں کنوں وی اتے انہیں کنوں جنہیں دی تُساں عبادت کریندو اللہ دے سوا اساں تُہاݙا انکار کیتا اتے ظاہر تھی ڳئی ساݙے تے تُہاݙے درمیان دشمنی تے بغض ہمیشہ جے تئیں تُساں ایمان نہ آنو اللہ واحد تے مگر ابراہیم دا فرمان اپݨے باپ واسطے (مستثنیٰ اے) جو ضرور بخشش منگساں میں تیݙے واسطے اتے میں مالک نہیں تیݙے واسطے اللہ دے مقابلے کہیں شے دا اے ساݙا رب تیݙے اتے بھروسہ کیتے سے اتے تیں ݙے رجوع کیتے سے اتے تیں ݙے ہی رجو ع اے (سب دا)
  60,5,اے ساݙا رب ساکوں فتنہ (ازمائش) نہ بݨا انہیں کافریں واسطے اتے ساکوں بخش اے ساݙا رب بے شک توں ہی غالب حکمت والا ایں
  60,6,بے شک تُہاݙے واسطے انہیں وچ بہترین نمونہ اے اُوندے واسطے جو امید رکھدے اللہ تے ݙینہہ قیامت دی اتے جیرھا پھر ونڄے ول بے شک اللہ ای بے نیاز اے تعریفیں والا اے
  60,7,قریب اے کہ اللہ پیدا کر ݙیوے تُہاݙے درمیان تے انہیں دے درمیان جنھیں نال انہیں وچوں تُہاݙی دشمنی اے دوستی (پیدا کر ݙیوے) اتے اللہ قادر اے اتے اللہ بخشݨ والا اے رحیم اے
  60,8,اللہ تُہاکوں نہیں روکیندا انہیں کنوں جنھیں تُہاݙے نال دین اچ لڑائی نہیں کیتی اتے تُہاکوں نانھے کڈھیا تُہاݙیں گھریں کنوں جو تُساں انہیں نال بھلائی کرو اتے انصاف کرو انہیں نال بے شک اللہ انصاف والیں کوں پسند کریندے
  60,9,بے شک تُہاکوں روکیندے اللہ انہیں کنوں جنھیں تُہاݙے نال برائی کیتی اے دین اچ اتے تُہاکوں کڈھیے نے تُہاݙے گھریں کنوں اتے مدد کیتی ہے نے تُہاݙے کڈھݨ تے (روکیندے ایں کنوں) جو تُساں انہیں کوں دوست بݨاؤ اتے جیرھا انہیں کوں دوست بݨاوے تاں او لوک ظالم ہن
  60,10,اے ایمان والو جیں ویلھے تُساں کنے مومن عورتاں آون کافریں دا ملک چھوڑ تے ول انہیں کوں ازماؤ (ایمان اچ) اللہ ڄاݨدے انہیں دے ایمان کوں ول جیکر معلوم کر گھنو انہیں کوں مومن ول نہ ولا بھیڄو انہیں کوں کافریں ݙے نہ اے حلال ان انہیں (کافریں) واسطے اتے نہ او حلال ان انہیں (مومن عورتیں) واسطے اتے ݙے ݙیو انہیں (کافریں) کوں جو انہیں خرچ کیتے اتے کوئی گناہ نہیں تُہاݙے اتے جیکر تُساں انہیں نال نکاح کرو جݙاں تُساں انہیں کوں ݙے ݙیو انہیں دے مہر اتے نہ روکو کافر رَنیں کوں نکاح نال (اپݨے کول) اتے منگ گھنو جو تُساں خرچ کیتے اتے کافر ای منگ گھنن جو انہیں خرچ کیتے اے اللہ دا حکم اے فیصلہ فرمیندے تُہاݙے درمیان اتے اللہ علم والا اے حکمت والا اے
  60,11,اتے جیکر نکل ونڄے تُساں کنوں کوئی تُہاݙے گھر والیں کنوں کافریں ݙے ول تُساں غنیمت آنو تاں انہیں کوں ݙیو جنھیں دیاں گھر والیاں چلیاں ڳن اتنا جتنا انہیں خرچ کیتے اتے ݙرو اللہ کنوں جیں تے تُساں ایمان رکھدو
  60,12,اے نبی جیں ویلھے تُہاݙے کول آون مومن عورتاں بیعت کرن تُہاݙی ایں شرط تے جو شریک نہ کرن اللہ نال کہیں شے کوں اتے نہ چوری کرن اتے نہ بدکاری کرن اتے نہ اپݨی اولاد قتل کرن اتے نہ آنن کوئی بہتان جو انہیں گھڑیا ہووے اپݨے ہتھیں پیریں دے درمیان (مقام ولادت اچ) اتے نہ نافرمانی کرن تُہاݙی کہیں نیکی وچ ول انہیں دی بیعت گھن گھنو اتے انہیں واسطے اللہ کنوں بخشش منگو بے شک اللہ بخشݨ والا رحیم اے
  60,13,اے ایمان والو دوست نہ بݨاؤ اُوں قوم کوں جنھیں تے اللہ غضب نازل فرمائے بے شک مایوس تھی ڳن آخرت کنوں جیویں مایوس تھی ڳن کافر قبریں والیں کنوں
