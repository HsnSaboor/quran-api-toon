quran[3]{c,v,t}:
  42,0,اللہ دے ناں نال (شروع کرینداں) جو ٻہوں مہربان ݙاڈھا رحیم اے
  42,1,حا میم
  42,2,عین سین قاف
  42,3,ہیں طرح وحی فرمیندے تُہاݙی طرف تے انہاں دی طرف جو تُساں کنوں پہلے ہن اللہ غالب حکمت والا
  42,4,ہوندا اے جو اسمانیں وچ اے اتے جو زمین اچ اے اتے اُوہو بلند اے عظمت والا اے
  42,5,قریب ان کہ اسمان پھٹ پون اپݨے اُتوں اتے فرشتے (وی) تسبیح آکھدن اپݨے رب دی حمد نال اتے بخشش منگدن انہاں واسطے جیرھے زمین اچ ان سݨو بے شک اللہ ای بخشݨ والا اے رحم کرݨ والا اے
  42,6,اتے جنھیں بݨا گِدھن اُوندے سوا ٻئے دوست اللہ نگہبان اے انہیں (دے اعمال) تے اتے آپ انہیں تے نگران نوھے
  42,7,اتے اینویں اساں وحی کیتے تُساں ݙے قرآن عربی تاکہ ݙر سݨاؤ تمام وستیں دے مُنڈھ (مکہ) کوں اتے اُوندے چودھار کوں اتے ݙر سُݨاؤ کٹھے تھیوݨ دے ݙینہہ کنوں جیں وچ کوئی شک نہیں ہک ٹولہ جنت وچ تے ہک ٹولہ دوزخ اچ ہوسے
  42,8,اتے جیکر اللہ چہندا تاں انہیں (سب) کوں ہکا جماعت بݨا ݙیوے ہا لیکن او داخل کریندے اپݨی رحمت وچ جینکوں چاہے اتے ظالمیں واسطے کوئی دوست نہ ہوسے تے نہ کوئی مددگار
  42,9,کیا انہیں بݨائن اُوں (اللہ) دے سوا دوست پِچھے اللہ ای والی اے اتے اُوہو زندہ کریندے مردے اتے اُوہو ہر شے تے قادر اے
  42,10,اتے جو اختلاف کرو تُساں کہیں شے وچ تاں اُوندا فیصلہ اللہ دی طرف اے اُوہو اللہ میݙا رب اے میں ہوں تے بھروسہ کیتے اتے میں ہوندی طرف رجوع کرینداں
  42,11,بݨاوݨ والا اے اسمانیں تے زمینیں دا بݨائس تُہاݙے واسطے تُہاݙے وچوں جوڑے اتے جانوریں وچوں جوڑے (بݨائس) تُہاکوں کِھنڈیندے زمین اچ اُوندی مثل کوئی شے کینی اتے اُوہو سݨݨ والا اے ݙیکھݨ والا اے
  42,12,ہوندی ملک ان کنجیاں اسمانیں تے زمینیں دیاں فراخ کریندے روزی جیندے واسطے چاہے اتے تنگ کر ݙیندے (جیندے واسطے چاہے) یقیناً اُوہو ہر شے کوں ڄاݨݨ والا اے
  42,13,مقرر فرمائس تُہاݙے واسطے دین وچوں او جیندا حکم ݙتا ہس نوح کوں اتے او جیندی اساں وحی کیتی تُساں ݙے اتے جیندا حکم اساں ݙتا ہا ابراہیم تے موسیٰ تے عیسیٰ (علیہ السلام) کوں جو دین کوں قائم رکھو اتے ایندے وچ تفرقہ نہ سَٹّو بھاری اے مشرکیں تے او جیندی طرف تُساں انہیں کوں سݙیندو اللہ چُݨ گھندے اپݨے (قُرب) ݙے جینکوں چاہے اتے رہنمائی کریندے اُوندی طرف اُونکوں جیرھا رجوع کرے (اُوں ݙے)
  42,14,اتے نہیں تفرقہ پاتا انہیں ایندے بعد کہ آڳیا انہیں کنے علم آپس دے حسد دی وجہ نال اتے جیکر کلمہ پہل نہ کر چکا ہووے ہا تیݙے رب دی طرفوں ہک مدت مقرر تک تاں فیصلہ کر ݙتا ڳیا ہووے ہا انہیں دے درمیان اتے بے شک جنھیں کوں وارث بݨایا ڳے کتاب دا انہیں دے بعد تاں البتہ ہک دھوکے سَٹّݨ والے شک اچ ہن
  42,15,لہٰذا ہیں دی طرف سݙو اتے ثابت قدم رہو جیویں تُہاکوں حکم ݙتا ڳے اتے اتباع نہ کرو انہیں دی خواہشات دی اتے فرما ݙیو میں ایمان آندا اُوں تے جو اللہ نے اُتاری کوئی کتاب اتے میکوں حکم ݙتا ڳے جو انصاف کراں تُہاݙے درمیان اللہ ساݙا ای رب اے اتے تُہاݙا ای رب اے ساݙے واسطے ساݙے عمل اتے تُہاݙے واسطے تُہاݙے عمل کوئی جھڳڑا نہیں ساݙے تے تُہاݙے درمیان اللہ کٹھا کریسے اساں سب کوں اتے ہوں ݙے رجوع اے (سب دا)
  42,16,اتے جیرھے لوک جھڳڑدن اللہ دے بارے ایندے بعد کہ اُوندی دعوت قبول کر گدھی ڳئی اے انہاں دی دلیل بے بنیاد اے انہیں دے رب دے نزدیک اتے انہیں تے غضب اے اتے انہیں دے واسطے سخت عذاب اے
  42,17,اللہ ہے جیں کتاب اُتاری اے حق نال اتے (انصاف دا) ترازو اتے (اے مخاطب) تیکوں کیا معلوم شاید قیامت قریب ہووے
  42,18,جلدی منگدن اینکوں اُوہے جیرھے اینکوں نہیں منیندے اتے جنھیں ایمان آندے (قیامت تے) او ایں کنوں ݙردن اتے ڄاݨدن جو بے شک ایہا حق اے خبردار یقیناً جیرھے قیامت اچ شک کریندن او دور دی گمراہی وچ ہن
  42,19,اللہ ٻہوں نرمی فرماوݨ والا اے اپݨے بندیں تے روزی ݙیندے جینکوں چاہے اتے اُوہو قوت والا عزت والا اے
  42,20,جیرھا ارادہ کرے آخرت دی کھیتی دا اساں ودھارا کریسوں اُوندی کھیتی وچ اتے جیرھا ارادہ کرے دنیا دی کھیتی دا اُونکوں ݙیسوں اُوندے وچوں اتے نہ ہے اُوندے واسطے آخرت اچ کوئی حصہ
  42,21,کیا انہیں واسطے شریک ہن جنھیں مقرر کر ݙتے انہیں واسطے دین وچ (رستہ) جیں دی اللہ اجازت نہیں ݙتی اتے جیکر فیصلے دا وعدہ نہ ہووے ہا تاں (اتھائیں) فیصلہ کر ݙتا ڳیا ہووے ہا انہیں دے درمیان اتے بے شک ظالمیں واسطے درد ناک عذاب اے
  42,22,آپ ݙیکھسو ظالمیں کوں ݙریے ہوئے ہوسن اُوں (کردار) کنوں جو کمائے نیں حالانکہ او واقع تھی تے رہسے انہیں تے اتے جنھیں ایمان آندے اتے نیک عمل کیتن بہشت دے باغیں وچ ہوسن انہیں واسطے جو چہسن انہیں دے رب کنے ہے ایہو تاں وݙا فضل اے
  42,23,ایہا اے او چیز جیندی خوشخبری ݙیندے اللہ اپݨے انہیں بندیں کوں جنھیں ایمان آندے اتےنیک عمل کیتن فرما ݙیو میں تُساں کنوں نہیں منگدا ایں (تبلیغ رسالت) تے کوئی مزدوری مگر قرابت دی محبت اتے جیرھا کماوے نیکی اساں ودھیسوں اُوندے واسطے اُوندے وچ حسن بے شک اللہ ٻہوں بخشݨ والا قدردان اے
  42,24,کیا اے آکھدن جو بہتان ٻدھیس اللہ تے کوڑا پِچھے جیکر اللہ چاہے مہر کر ݙیوے تُہاݙے دل تے (حفاظت دی) اتے اللہ مٹیندے باطل کوں اتے ثابت رکھدے حق کوں اپݨے کلمات نال بے شک او ڄاݨݨ والا اے سینیں دے راز
  42,25,اتے اُوہو اے جو قبول کریندے توبہ اپݨے بندیں دی اتے درگزر کریندے گناہیں کنوں اتے ڄاݨدے جو تُساں کریندو
  42,26,اتے دعا قبول کریندے انہیں دی جنھیں ایمان آندے اتے نیک عمل کیتن اتے انہیں کوں زیادہ ݙیندے اپݨے فضل نال اتے کافریں واسطے تاں سخت عذاب اے
  42,27,اتے جیکر فراخ کر ݙیندا اللہ روزی اپݨے (سب) بندیں تے تاں فساد برپا کر ݙیون ہا زمین اچ لیکن او اُتریندے اندازے تے جتنا چاہے بے شک او اپݨے بندیں دی خبر رکھݨ والا ݙیکھݨ والا اے
  42,28,اتے اُوہو اے جو مینہ وسیندے ایندے بعد جو مایوس تھی ویندن اتے کھنڈا ݙیندے اپݨی رحمت اتے اُوہو مددگار اے تعریف کیتا ہویا اے
  42,29,اتے ہوں (دی قدرت) دے نشانیں وچوں اے اسمانیں تے زمینیں دا پیدا کرݨ اتے جو انہیں وچ کھنڈائس کوئی جاندار اتے او انہیں دے کٹھا کرݨ تے جݙاں چاہے قادر اے
  42,30,اتے جو تُہاکوں پُڄی اے کوئی مصیبت تاں او اُوندی وجہ نال اے جو کمائے تُہاݙے ہتھیں اتے او تاں درگزر کر ݙیندے ٻہوں کجھ کنوں
  42,31,اتے نہ تُساں عاجز کر سڳدو (اللہ کوں) زمین اچ اتے نہ تُہاݙا اللہ دے سوا کوئی دوست تے نہ کوئی مددگار اے
  42,32,اتے اُوندیں (قدرت دی) نشانیں وچوں ان دریا وچ چلݨ والیاں (ٻیڑیاں) پہاڑیں وانگے
  42,33,جیکر چاہے کھڑا ݙیوے ہوا کوں ول او کھڑیاں رہ ونڄن اُوندی پُٹھ تے بے شک ایندے وچ نشانیاں ہن ہر وݙے صابر شاکر واسطے
  42,34,یا تباہ کر ݙیوے انہیں کوں لوکیں دے کردار دی وجہ نال اتے او درگزر کریندے ٻہوں کجھ کنوں
  42,35,اتے او ڄاݨ گھنن جیرھے جھڳڑدن ساݙیں ایتیں وچ جو انہیں واسطے بھڄݨ دی کوئی جا کینی
  42,36,تو جو کُجھ تُہاکوں ݙتا ڳے او نفع اے دنیاوی زندگی دا (تھوڑا) اتے جو اللہ دے کول اے او بہتر اے اتے باقی رہݨ والا اے انہیں واسطے جنھیں ایمان آندے اتے اپݨے رب تے بھروسہ رکھدن
  42,37,اتے جیرھے بچدے رہندن کبیرہ گناہیں تے بے حیائی دے کمیں کنوں اتے جیں ویلھے کوڑیج ونڄن تاں معاف کر ݙیندن
  42,38,اتے جنھیں حکم منیئے اپݨے رب دا اتے نماز قائم کیتی اے اتے انہیں دے کم انہیں دے درمیان مشورے تے ہن اتے جو اساں انہیں کوں رزق ݙتے (اُوندے وچوں) خرچ کریندن (اللہ دے راہ تے)
  42,39,اتے او کہ جیں ویلھے انہیں تے زیادتی پُڄے بدلہ گھندن
  42,40,اتے برائی دا بدلہ برائی اے ہوندی مثل پِچھے جیرھا معاف کر ݙیوے اتے اصلاح کرے تاں اُوندا اجر اللہ تے بے شک او ظالمیں کوں دوست نہیں رکھدا
  42,41,اتے البتہ جیں بدلہ گدھے اپݨے مظلوم ہووݨ دے بعد تاں انہیں لوکیں تے کوئی (گرفت دا) رستہ نہیں
  42,42,بے شک (گرفت دا) رستہ تاں انہیں تے ہے جیرھے لوکیں تے ظلم کریندن اتے زمین اچ سر کشی کریندن نا حق انہیں واسطے درد ناک عذاب اے
  42,43,اتے البتہ جیرھا صبر کرے اتے معاف کر ݙیوے تاں یقیناً اے (وݙی) ہمت دے کمیں وچوں اے
  42,44,اتے جینکوں اللہ گمراہ کرے تاں اُوندے واسطے کوئی حمایتی نہیں اُوندے بعد اتے توں ݙیکھسیں ظالمیں کوں جیرھے ویلھے عذاب ݙیکھسن (ویڑے تھی تے) آکھسن کیا واپس ولݨ دا کوئی رستہ ہے
  42,45,اتے تُساں انہیں کوں ݙیکھسو پیش کیتے ویسن اُوں (دوزخ) تے سر سٹیا ہویا ذلت کنوں ݙیکھدے ہوسن لُکیں اکھیں نال (چوری چوری) اتے مومن آکھسن بے شک (حقیقی) گھاٹے والے اُوہے ہن جنھیں گھاٹے وچ پاتے آپ کوں اتے اپݨے اہل و عیال کوں قیامت دے ݙینہہ سݨو بے شک ظالم ہمیشہ دے عذاب اچ ہوسن
  42,46,اتے نہ ہوسن انہیں واسطے کوئی دوست جو انہیں دی مدد کرن اللہ دے مقابلے اتے جینکوں اللہ گمراہ کرے تاں اُوندے واسطے کوئی رستہ کینی
  42,47,من گھنو حکم اپݨے رب دا ایں کنوں پہلے کہ او ݙینہہ آ ونڄے جینکوں اللہ دی طرفوں ٹل ونڄݨ نہیں نہ تُہاݙے واسطے اُوں ݙینہہ کوئی پناہ دی جاہ ہوسے اتے نہ کوئی انکار (دی جرات)
  42,48,ول وی جیکر او منہ پھیرن تاں اساں تُہاکوں انہیں تے نگران بݨاتے نہیں بھیڄا تُہاݙے اُتے تاں صرف پُڄا ݙیوݨ اے اتے بے شک اساں جیں ویلھے چکھا ؤں انسان کوں اپݨی طرفوں کوئی رحمت اُوں تے خوش تھیندے اتےجے انہیں کوں کوئی تکلیف پُڄے اُوندے سبب جو انہیں دےہتھیں اڳوتے بھیڄے تاں یقیناً انسان وݙا ناشکرا اے
  42,49,اللہ دے واسطے ہے بادشاہی اسمانیں تے زمینیں دی پیدا کریندے جو چاہے جینکوں چاہے دھیاں عطا کرے اتے جینکوں چاہے پُتر عطا کرے
  42,50,یا ملیئے جُلیئے ݙیندے انہیں کوں دھیاں پُتر اتے جینکوں چاہے کر ݙیوے سنڈھ بے شک او ڄاݨݨ والا اے قادر اے
  42,51,اتے نہیں کہیں انسان دے لائق جو اُوندے نال ڳالھ کرے اللہ مگر وحی دے ذریعے پردے پچھوں یا بھیڄے کوئی قاصد (فرشتہ) ول وحی کرے او (فرشتہ) اُوندے حکم نال جو او چاہے بے شک او اُچی شان والا اے حکمت والا اے
  42,52,اتے اینویں اساں وحی کیتی تُہاݙی طرف روح (افزا کلام) دی اپݨے حکم نال نہ (ایں کنوں پہلے) آپ ڄاݨدےہاوے کتاب کیا ہے اتے نہ ایمان (کیا ہے) اتے لیکن اساں اینکوں نور بݨائے ایندے نال ہدایت ݙیندوں جینکوں چاہوں اپݨے بندیں وچوں اتے یقیناً آپ ہدایت ݙیندو (اے حبیب) سدھے راہ ݙے
  42,53,اللہ دی راہ (ݙے) او جیندے واسطے سب کُجھ اے جو اسمانیں وچ اے اتے جو زمین وچ اے سݨ گھنو اللہ دی طرف ای لوٹدن تمام کم
