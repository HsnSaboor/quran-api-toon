quran[19{c,v,t}:
73,1,اے چادر ویڑھݨ والے محبوب
73,2,قیام کرو (نماز اچ) رات کوں مگر تھوڑا
73,3,ادھی رات یا ایں کنوں کُجھ کم کر ݙیو
73,4,یا کُجھ زیادہ کر ݙیو ایں کنوں اتے خوب ٹھہر ٹھہر تے پڑھو قرآن
73,5,بے شک اساں عنقریب اِلقا کریسوں تُہاݙے اتے بھاری کلام
73,6,بے شک رات دا اٹھݨ (نفس کوں) سخت لتاڑݨ والا اے اتے ٻہوں درست ڳالھ والا اے
73,7,بے شک تُہاکوں ݙینہہ اچ وݙے وݙے کم ان
73,8,اتے ذکر کرو اپݨے رب دا ناں اتے علیحدہ تھی ونڄو اُوندی طرف مکمل
73,9,رب اے مشرق تے مغرب دا کوئی عبادت دے لائق نہیں اُوندے سوا لہٰذا ہوں کوں کارساز بݨاؤ
73,10,اتے صبر کرو جو کافر آکھدن تے انہیں کوں چھوڑو اچھی طرح چھوڑن
73,11,اتے میں تے چھوڑو جھُٹلاوݨ والے دنیاداریں کوں اتے انہیں کوں کُجھ مہلت ݙیو
73,12,بے شک ساݙے کول باری جو لان ان تے بھڑکدی بھا اے
73,13,اتے کھاݨا ڳل گھوٹو اتے عذاب درد ناک
73,14,جیں ݙینہہ کنب ویسن زمین تے پہاڑ اتے تھی ویسن پہاڑ ٹٻہ وہندی ریت دا
73,15,بے شک اساں بھیڄا تُساں ݙے (شانیں والا) رسول تُہاݙے اتے گواہ جیویں بھڄیوسے فرعون ݙے رسول
73,16,ول نافرمانی کیتی فرعون اُوں رسول دی ول پکڑیوسے اُونکوں سخت پکڑ نال
73,17,ول کیویں بچسو جیکر کفر کرو اُوں ݙینہہ جیرھا کر ݙیسے ٻالیں کوں ٻُڈھا
73,18,اسمان پھٹ ویسے اُوندے نال اُوندا وعدہ تھی تے رہسے
73,19,بے شک اے نصیحت اے پِچھے جیرھا چاہے بݨاوے اپݨے رب ݙے رستہ
