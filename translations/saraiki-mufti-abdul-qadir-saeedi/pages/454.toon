quran[10{c,v,t}:
38,17,(اے حبیب) صبر کر اُوں تے جو آکھدن اتے یاد کرو ساݙے بندے داؤد کوں جو قوت والا ہا بے شک او رجوع کرݨ والا ہا
38,18,بے شک اساں پابند کر ݙتوسے اُوندے نال پہاڑ تسبیح آکھدے ہن شام سویرے
38,19,اتے (پابند کیتوسے) پرندے کٹھے تھی ویندے ہن سب اُوندے فرمان بردار ہن
38,20,اتے مضبوط کیتوسے اُوندی بادشاہی تے اُونکوں ݙتوسے حکمت اتے اٹل واضح گفتگو (دی صلاحیت)
38,21,اتے کیا اَئی اے تُہاݙے کول خبر مقدمے دے فریقین دی جݙاں کندھی ٹپ ائے ہن عبادت خانے دی
38,22,جݙاں داخل تھے ہن داؤد تے اتے (آپ) گھبرا ڳے ہن انہیں کنوں انہیں آکھیا فکر نہ کرو (اساں) ݙو فریق اُوں زیادتی کیتی اے ساݙے ہک نے ݙوجھے تے لہٰذا آپ فیصلہ فرما ݙیو ساݙے درمیان حق دا تے نا انصافی نہ کرو اتے ساکوں سدھے راہ دی رہنمائی چا کرو
38,23,حق اے ہے اے میݙا بھرا اے ایندیا ں ودھانوے دُنبیاں ہن تے میݙی ہک دنبی اے ول آکھیُس اے وی میݙے حوالے کر ݙے اتے میݙے اُتے دباؤ پاتس گفتگو وچ
38,24,آپ فرمایا یقیناً ایں زیادتی کیتی اے تیݙی دُنبی منگ تے اپݨے دُنبیں وچ رلاوݨ واسطے اتے بے شک اکثر حصے دار زیادتی کریندن بعض انہیں دے بعض تے مگر جنھیں ایمان آندے اتے نیک عمل کیتن اتے او ٻہوں تھوڑے ہن اتے سمجھ گدھا داؤد جو بے شک اساں اُونکوں ازمائے لہٰذا بخشش منگیس اپݨے رب کنوں اتے ڈھیہ ڳیا سجدے وچ تے رجوع کیتس
38,25,ول اساں اُونکوں اے معاف کر ݙتا اتے یقیناً اُونکوں ساݙے نزدیک قُرب اے اتے اچھا ٹکاݨہ اے
38,26,اے داؤد بے شک اساں تیکوں نائب بنڑائے زمین اچ لہٰذا فیصلےکرو لوکیں دے درمیان انصاف نال اتے خواہش دے پچھوں نہ لڳو کہ او تیکوں گمراہ کر ݙیسے اللہ دے راہ کنوں بے شک جیرھے گمراہ تھیندن اللہ دے رستے کنوں انہیں واسطے سخت عذاب اے ایں وجہ نال کہ انہیں بھلا ݙتے حساب دا ݙینہہ
