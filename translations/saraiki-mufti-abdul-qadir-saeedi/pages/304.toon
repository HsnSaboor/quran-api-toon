quran[13{c,v,t}:
18,98,اکھیس اے میݙے رب دی رحمت اے پر جیں ویلھے میݙے رب دا وعدہ آیا اینکوں ریزہ ریزہ کر ݙیسے اتےمیݙے رب دا وعدہ سچا اے
18,99,اتے اُوں ݙینہہ اساں چھوڑ یسوں انہیں دے بعض کوں چھولیں وانگے چڑھدے اوسن ہک ٻئے تے اتے پھوکا ماریا ویسے صور وچ ول اساں انہیں سب کوں کٹھا کر ݙیسوں
18,100,اتے اُوں ݙینہہ دوزخ کوں کافریں واسطے سامݨے پیش کریسوں
18,101,او (کافر) جنھیں دیاں اکھیں میݙے ذکر کنوں پردیں وچ ہن اتے او سݨݨ دی ہمت نہ رکھدے ہن
18,102,ول کیا کافریں ایہو سمجھے جو بݨا گھنسن میݙے بندیں کوں میݙے سوا مددگار بے شک اساں دوزخ کوں تیار کیتے سے کافریں دی مہمانی واسطے
18,103,فرما ݙیو (اے حبیب) کیا تُہاکوں ݙساؤں عمل اچ گھاٹے والیں دے بارے
18,104,او جنھیں دی ساری کوشش دنیاوی زندگی وچ گم تھی ڳئی اتے او سمجھدن جواو ٻہوں چنڳا کم کریندےپن
18,105,اے لوک ان جنھیں انکار کر ݙتے اپݨے رب دی ایتیں دا اتے اوندی ملاقات دا تاں ضائع تھی ڳن انہیں دے عمل لہٰذا انہیں واسطے اساں قیامت دے ݙینہہ کوئی ترکڑی مقرر (قائم) نہ کریسوں
18,106,اے لوک انہیں دا بدلہ دوزخ اے ایں واسطے جو انہیں کفر کیتے اتے میݙیں ایتیں تے رسولیں کوں مذاق چابنڑائے نیں
18,107,بے شک جنھیں ایمان آندے اتے نیک عمل کیتے نے انہیں واسطے فردوس دے باغات مہمانی ان
18,108,انہیں (باغیں)وچ ہمیشہ رہسن اتھوں بدلݨ نہ چہسن
18,109,(اے حبیب) فرما ݙیو جیکر سمندر مس بنڑ ونڄے میݙے رب دے کلمات واسطے تاں سمندر ختم تھی ویسے ایں توں پہلے کہ میݙے رب دے کلمات ختم تھیون توڑیں اساں ایندی مثل ٻئی مس آنوں
18,110,(اے حبیب) فرما ݙیو (کافریں کوں) میں (خدا نہیں) تُساں جیھا بشر آں (کیونکہ) میں ݙے وحی کیتی ویندی اے کہ بے شک تہاݙ ا معبود ہکو معبود اے لہٰذا جیرھا امید رکھدے اپݨے رب دی ملاقات دی تاں اونکوں چہیدا اے کہ نیک عمل کرے اتے اپݨے رب دی عبادت اچ کہیں کوں شریک نہ کرے۔١١٠
