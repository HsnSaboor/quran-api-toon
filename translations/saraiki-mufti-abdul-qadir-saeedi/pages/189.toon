quran[7{c,v,t}:
9,14,تُساں انہیں دے خلاف لڑو اللہ انہیں کوں تُہاݙے ہتھوں عذاب ݙیسے تے انہیں کوں ذلیل کریسے تے انہیں دے خلاف تہاݙی مدد کریسے تے مسلمانیں دا ہاں ٹھار ݙیسے
9,15,تے انہیں دے دلیں دی کاوڑ کڈھ ݙیسے تے اللہ رحمت دا رجوع فرماوے جیں تے چاہے تے اللہ علم والا اے حکمت والا اے
9,16,کیا تُساں ایہو خیال کیتے جو تُہاکوں چھوڑ ݙتا ویسے حالانکہ ڄاݨ سُنڄاݨ نہیں کرائی اللہ انہیں دی جنھیں تُساں وچوں جہاد کرݨیں تے جنھیں اللہ تے اُوندے رسول تے مومنیں دے سوا کہیں کوں راز دار نہیں بݨایا تے اللہ کوں تُہاݙے سب کم دی خبر اے
9,17,مشرکیں کوں (حق) نہیں پُہنچدا جو اللہ دیاں مسجداں آباد کرن حالانکہ او گواہ ہن اپݨیں جانیں تے کفر دے اے لوک انہیں دے عمل ضائع تھی ڳن تےدوزخ اچ اے ہمیشہ رہسن
9,18,اللہ دیاں مسجداں تاں بس اُوہے آباد کر سڳدن جنھیں اللہ اتے قیامت تے ایمان آندے تے نماز دی پابندی کیتی اے تے زکوٰۃ ݙتی اے تے خدا دے سوا کہیں کنوں نہیں ݙریے پِچھے قریب اے جو اے لوک ہدایت پا ونڄݨ والیں وچوں تھی پوِن
9,19,کیا تُساں حاجییں کوں پاݨی پلاوݨ تے کعبہ کوں آباد کرݨ والے کوں اُوں وانگے بنڑا گدھے جیں اللہ تے قیامت تے ایمان آندے تے اللہ دے راہ تے جہا دکیتے اللہ دے نزدیک اے ہُوں جہے نہیں تے اللہ ظالم قوم کوں ہدایت نہیں ݙیندا
9,20,جنھیں ایمان آندے تے ہجرت کیتی اے تے اللہ دے راہ تے جہاد کیتے اپݨے مالیں تے جانیں نال وݙے درجے والے ان اللہ دے نزدیک تے ایہے لوک کامیاب ان
