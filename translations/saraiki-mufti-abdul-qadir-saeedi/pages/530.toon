quran[22{c,v,t}:
54,28,اتے انہیں کوں ݙسا ݙیو بے شک پاݨی حصے تے ہے انہیں دے درمیان ہر ہک اپݨی واری تے حاضر تھیوے
54,29,ول سݙیو نے اپݨے ساتھی کوں ول اُوں حملہ کیتا تے لتاں کپ (تے مار) سٹیس
54,30,ول کیویں ہا میݙا عذاب تے میݙا ݙراوݨ
54,31,بے شک بھیڄوسے انہیں تے ہک چکاٹ ول تھی ڳے جیویں لوڑھے لتاڑیے ہوئے (دا چورا)
54,32,اتے بے شک اساں سوکھا کر ݙتے قرآن یاد گیری واسطے ول ہے کوئی نصیحت قبول کرݨ والا
54,33,جُھٹلایا لوط دی قوم ݙر سݨاوݨ والیں (رسولیں) کوں
54,34,یقیناً اساں بھیڄا انہیں تے پتھراؤ (دا مینہ) مگر لوط دے گھر والے انہیں کوں بچا گدھوسے وݙے ویلھے کوں
54,35,احسان کریندے ہوئے اپݨی طرفوں اینویں اساں بدلہ ݙیندوں اُونکوں جیرھا شکر کرے
54,36,اتے بے شک لوط انہیں کوں ݙرایا ہا اساݙی پکڑ کنوں ول شک کیتونے ݙر سݨاوݨ والیں وچ
54,37,اتے بے شک اُونکوں وندلاوݨ لڳے اُوندے مہمانیں دے بارے ول مِٹا ݙتوسے انہیں دیاں اکھیں ول چکھو میݙا عذاب تے میݙا ݙراوݨ
54,38,اتے بے شک آیا انہیں تے صبح صبح عذاب باقی رہݨ والا
54,39,ول چکھو میݙا عذاب اتے میݙے ݙراوݨ (دی چس)
54,40,اتے بے شک اساں سوکھا کر ݙتے قرآن یاد گیری واسطے ول ہے کوئی نصیحت قبول کرݨ والا
54,41,اتے بے شک اَئے فرعون والیں کنے ݙرسݨاوݨ والے (موسیٰ)
54,42,جُھٹلایونے ساݙیاں ایتاں ساریاں ول انہیں کوں پکڑیوسے جیویں غالب طاقت والا پکڑیندے
54,43,کیا تُہاݙے کافر چنڳے ہن انہیں کنوں یا تُہاݙے واسطے معافی لکھی ہوئی اے (اسمانی) کتابیں وچ
54,44,یا آکھدن جو اساں سارے رل تے بدلہ گھن گھنسوں
54,45,عنقریب شکست ݙتی ویسے سب کوں اتے پھریسن کنڈ (بھڄ ویسن)
54,46,بلکہ قیامت انہیں دے وعدے دا وقت اے اتے قیامت وݙی خوفناک اتے ݙاڈھی کوڑی اے
54,47,بے شک مجرم گمراہی تے پاڳل پن اچ ہن
54,48,جیں ݙینہہ گھیلیے ویسن بھا وچ منہ دے بھر (فرمایا ویسے) چکھو دوزخ دا عذاب
54,49,بے شک اساں ہر چیز پیدا کیتی اے ہک اندازے تے
