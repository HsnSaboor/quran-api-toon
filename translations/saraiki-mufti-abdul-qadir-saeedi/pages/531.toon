quran[22{c,v,t}:
54,50,اتے نہیں ہوندا ساݙا کم مگر ہک لمحہ جیویں اکھ جھمکݨ
54,51,اتے اساں ہلاک کر ݙتن کئی تُساں جہے ول ہے کوئی نصیحت قبول کرݨ والا
54,52,اتے جو چیز وی انہیں کیتی اے اعمال نامے وچ موجود ہے
54,53,اتے ہر چھوٹی تے وݙی چیز لکھی ہوئی اے
54,54,بے شک پرہیزگار باغیں اتے نہریں وچ ہوسن
54,55,سچی محفل اچ عظیم قدرت والے بادشاہ دے کول
55,1,رحمٰن نے
55,2,اپݨے حبیب کوں) قرآن سکھایا
55,3,انسان (کامل محمد ﷺ) کوں پیدا فرمایس
55,4,اُوں کوں کل (ما کان وما یکون دا) بیان سکھایس
55,5,سجھ تے چندر حساب نال (چلدے) ہن
55,6,اتے ٻُوٹے تے درخت سجدہ کریندن
55,7,اتے اسمان کوں بلند فرمائس تے تُلاوڑہ رکھیس
55,8,جو تولݨ اچ وادھا گھاٹا نہ کرو
55,9,اتے وزن کوں قائم رکھو انصاف نال اتے وزن اچ گھٹکی نہ کرو
55,10,اتے زمین کوں رکھیس لوکیں واسطے
55,11,اُوندے وچ پھل ہن اتے کھجیاں (ٻوہارے دے) سیپوں والیاں
55,12,اتے دانے بھوں والے (سٹے) اتے خوشبودار پھل
55,13,ول اپݨے رب دی کیرھی کیرھی نعمت کوں کوڑا کریسو
55,14,پیدا کیتس انسان کوں سُکی (کھڑکدی) مٹی کنوں جیویں ٹھیکری
55,15,اتے پیدا کیتس چن کوں بھا دے خالص (بغیر دھوں والے) شعلے کنوں
55,16,ول اپݨے رب دی کیرھی کیرھی نعمت کوں کوڑا کریسو
