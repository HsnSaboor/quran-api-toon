quran[3]{c,v,t}:
  34,0,اللہ دے ناں نال (شروع کرینداں) جو ٻہوں مہربان ݙاڈھا رحیم اے
  34,1,ساریاں تعریفاں اللہ دیاں جیندے واسطے ہے سب جو اسمانیں وچ اے اتے جو زمین وچ اے ہوندی تعریف اے آخرت وچ وی اتے اُوہو حکمت والا اے خبردار اے
  34,2,او ڄاݨدے جو کجھ زمین اچ داخل تھیندے تے جو اُوں کنوں نکلدے اتے جو کجھ اسمان کنوں لہندے اتے جو اُتے ویندے اسمان اچ اتے اُوہو رحم کرݨ والا اے بخشݨ والا اے
  34,3,اتے کافریں آکھیا اساں کنے قیامت نہ اوسے فرما ݙیو ہا اَوسے میݙے رب غیب ڄاݨݨ والے دی قسم تُساں کنے (قیامت) ضرور اوسے اُوں کنوں چُھپّی کینی ذرے جتنا چیز وی اسمانیں وچ اتے نہ زمینیں وچ اتے نہ ایں کنوں چھوٹی چیز تے نہ ایں کنوں وݙی چیز مگر واضح بیان کرݨ والی کتاب اچ ہے
  34,4,تاکہ (اللہ) اچھی جزا ݙیوے انہیں کوں جنھیں ایمان آندے اتے نیک عمل کیتن اے لوک ان جنھیں واسطے بخشش اے اتے عزت دی روزی اے
  34,5,اتے جنھیں کوشش کیتی اے ساݙیں ایتیں وچ (جُھٹلا تے ساکوں) عاجز کرݨ دی انہیں لوکیں واسطے عذابیں وچوں درد ناک عذاب اے
  34,6,اتے او ڄاݨدن جنھیں کوں علم ݙتا ڳے کہ جو تُساں ݙے نازل کیتا ڳے تُہاݙے رب دی طرفوں او حق اے اتے راہ ݙکھیندے اُوندی طرف جیرھا غالب اےساریں تعریفیں دے لائق اے
  34,7,اتے کافریں آکھیا (ہک ٻےکوں) کیا تُہاکوں او بندہ ݙساؤں جیرھا تُہاکوں خبر ݙیندے جو جیں ویلھے تُساں (مار تے) ذرہ ذرہ کر ݙتے ویسو ول تُساں یقیناً نویں پیدا کیتے ویسو
  34,8,یا تاں اللہ تے کوڑا بہتان بدھس یا اُونکوں جنون اے (ایویں کینی) بلکہ جیرھے آخرت تے ایمان نہیں انیندے او (قیامت اچ) عذاب اچ اتے (اڄ) لمبی گمراہی وچ ان
  34,9,کیا انہیں کینی ݙٹھا جو انہیں دے سامݨے ہے اَتے جو انہیں دے پچھوں اے اسمان تے زمین جیکر اساں چاہوں انہیں کو ں غرق کر ݙیوں زمین اچ یا سٹ ݙیوں انہیں تے اسمان دا کوئی ٹوٹا یقیناً ایندے وچ نشانی اے ہر اُوں بندے واسطےجیرھا (اللہ ݙے) رجوع کرݨ والا اے
  34,10,اتے بے شک اساں داؤد کوں اپݨی طرفوں وݙا فضل عطا فرمایا اے پہاڑ و تسبیح کرو اُوندے نال رل تے اتے پرندیں کوں وی (حکم ݙتوسے)اتے اُوندے واسطے لوہا نرم کرݙتوسے
  34,11,جو بݨا کُھلیاں زرہیں اتے اندازہ صحیح رکھ کڑیئیں وچ اتے نیک عمل کریندے رہو بے شک میں جو تُساں عمل کریندو ݙیکھݨ والا ہاں
  34,12,اتے سلیمان واسطے(پابند کیتوسے)ہوا اُوندا سویرے دا سفر ہک مہینے دا اتے شام دا سفر ہک مہینے دا اتے پگھار تے جاری کیتوسے اُوندے واسطےچشمہ ترامیں دا اتے جنیں وچوں (پابند کیتوسے) جیرھے کم کریندے ہن اُوندے اڳوں اُوندے رب دے حکم نال اتے جیرھا انہیں وچوں پھرے ساݙے حکم کنوں اساں اُونکوں بھا دا عذاب چکھیسوں
  34,13,بنڑیندے ہن اُوندے واسطے جو او چاہے ہا (مثلاً) پکے مکان اتے مجسمے اتے وݙے وݙے کُنال جیویں تا لاب اتے وݙیاں دیڳاں ٹِکا تے رکھیاں ہویاں شکر دا عمل کرو اے داؤد دی اولاد اتے میݙیں بندیں وچوں تھوڑے ہن شکر کرݨ والے
  34,14,ول جیں ویلھے اساں سلیمان تے موت دا فیصلہ کیتا نہ پتہ ݙتا انہیں (جنیں) کوں اُوندی موت تےمگر زمین دے ہک کیڑے (سیوی کوں) اُوندا سوٹا کھمدی ہئی ول جیں ویلھے زمین تے آیا (سلیمان دا جسم) ول جنیں کوں پتہ لڳیا جو جیکر غیب ڄاݨدے ہوون ہا تاں نہ رہن ہا ذلت والے عذاب اچ
  34,15,بے شک سبا والیں واسطے انہیں دے وطن اچ نشانی ہئی ݙوہیں (پاسے) باغ سڄے پاسوں تے کھٻے پاسوں کھاؤ اپݨے رب دا ݙتا رزق تے اُوندا شکر کرو صاف ستھرا ملک اے اتے ٻہوں بخشݨ والا رب اے
  34,16,ول انہیں منہ پھیر گدھا تاں انہیں تے بھڄیوسے چھل بندھ والی (سخت) اتے ݙتوسے انہیں دے باغیں دے بدلے ݙو باغ کَوڑے بے مزہ پھلیں والے اتے لایاں اتے تھوڑیاں جیاں (کانڑیاں) ٻیریں
  34,17,ایہو بدلہ انہیں کوں ݙتوسے ایندا جو انہیں نا شکری کیتی اتے اساں نہیں بدلہ ݙیندے (ایجھا) مگر نا شکریں کوں
  34,18,اتے بنڑایوسے انہیں دے درمیان اتے انہیں وستیں دے درمیان جتھاں اساں برکتاں رکھین کئی ظاہراً وستیاں (رستے تے) اتے اندازہ رکھیوسے اُوندے وچ سفر دا چلدے رہو انہیں وچ راتیں ݙیہاں امن نال
  34,19,پِچھے اکھیونے ساݙا رب دوری پاݙے ساݙیں سفریں وچ اتے (اے آکھ تے) انہیں آپ تے ظلم کیتا ول انہیں کوں (عبرت دی) کہانی بݨا ݙتوسے اتے انہیں کوں پورا کھنڈا پنڈا کر ݙتوسے یقیناً ایندے وچ نشانیاں ہن ہر صبر شکر کرݨ والے واسطے
  34,20,اتے بے شک سچا کر ݙکھایا انہیں تے شیطان اپݨا دعویٰ کیونکہ او اُوندے پچھوں لڳ پے مگر ہک ٹولہ مومنیں وچوں (حق تے رہ ڳیا)
  34,21,اتے نہ ہا شیطان کوں انہیں تے کوئی قابو مگر (ایں واسطے تھیا) کہ اساں واضح کر ݙیوں جو کون آخرت کوں منیندے اتے کون اُوندے بارے شک اچ اے اتے تیݙا رب ہر شے تے نگہبان اے
  34,22,فرما ݙیو سݙو انہیں کوں جنھیں کوں سمجھی کھڑو اللہ دے سو ا(معبود) او تاں ذرے دے مالک ای کینی نہ اسمانیں وچ اتے نہ زمینیں وچ اتے نہ انہیں کوں انہیں وچ کوئی شراکت اے اتے نہ او ندا انہیں وچوں کوئی مددگار اے
  34,23,اتے کوئی شفاعت فائدہ نہ ݙیسے اُوں کنے مگر جیں دے واسطے او اجازت ݙیوے حتٰی کہ جیں ویلھےخوف دور کیتا ویندے انہیں دے دلیں کنوں آکھدن کیا فرمائے تُہاݙے رب آکھدن حق فرمائس اتے اُوہو بلند اے بزرگی والا اے
  34,24,فرما ݙیو کون تُہاکوں روزی ݙیندے اسمانیں کنوں تے زمینیں کنوں فرما ݙیو اللہ اتے بے شک اساں یا تُساں یا ہدایت تے یا کھلی گمراہی وچ (آپ سوچو کون ایݙے تے کون اوݙے)
  34,25,فرما ݙیو تُساں کنوں نہ پچھیا ویسے اُوندے بارے جو (تُہاݙے گمان اچ)اساں جرم کیتے اتے اساں کنوں نہ پچھیا ویسے جو تُساں جرم کیتے
  34,26,فرما ݙیو کٹھا کریسے ساکوں ساݙا رب ول فیصلہ فرمیسے ساݙے درمیان حق دا اتے اُوہو وݙا فیصلہ کر ݨ والا ڄاݨݨ والا اے
  34,27,فرما ݙیو میکوں ݙکھاؤ ہاں اُوہے جنھیں کوں تُساں اُوندے نال رلائے شریک بݨا تے اصلوں نہ بلکہ اُوہو اللہ اے غالب اے حکمت والا اے
  34,28,اتے (اے حبیب) اساں تُہاکوں نہیں بھیڄا مگر ایسی رسالت نال جیرھی تمام لوکیں واسطےکافی اے خوشخبری ݙیوݨ والا تے ݙر سݨاوݨ والا تے لیکن اکثر لوک نہیں ڄاݨدے
  34,29,اتے آکھدن اُوہو وعدہ کݙاں اے جیکر تُساں سچے او
  34,30,فرما ݙیو تُہاݙے واسطے ہک ݙینہہ دا وعدہ ہے اُوں کنوں نہ ہک لحظہ پچھی تے ہٹ سڳسو اتے نہ اڳی تے ودھ سڳسو
  34,31,اتے کافریں آکھیے جو اساں اصلوں نہ منیسوں ایں قرآن کوں اتے نہ انہیں (کتابیں)کوں جیرھیاں ایں کنوں پہلےہن اتے کاش توں ݙیکھیں (انہیں دی حالت)جیں ویلھے ظالم کھڑے کیتے ویسن اپݨے رب دے سامݨے مریسن ہک ٻئے تے ڳالھیں (الزام) کمزور (ماتحت لوک) آکھسن اکڑیلیں (وݙیریں) کوں جیکر تُساں نہ ہوندے تاں اساں مسلمان ہوووں ہا
  34,32,اکڑیل (وݙیرے) اکھیسن کمزوریں (ماتحتیں) کوں کیا اساں تُہاکوں روکیا ہاسے ہدایت کنوں جݙاں تُساں کنے (ہدایت)آڳئی ہی بلکہ تُساں خود مجرم ہاوے
  34,33,اتے کمزور آکھسن اکڑیلیں کوں بلکہ (تُہاݙی)راتیں ݙیہاں سازش ہئی جݙاں تُساں ساکوں حکم ݙیندے ہاوے جو اساں اللہ دا انکار کروں تے اُوندے شریک بݨاؤں اتے شرمساری لُکیسن جݙاں عذاب ݙیکھسن اتے اساں ڳٹ مار ݙیسوں انہیں دے گردنیں وچ جنھیں کفر کیتا نہ بدلہ ݙتے ویسن مگر ہوندا جو او عمل کریندے ہن
  34,34,اتے اساں نہیں بھیڄا کہیں وستی وچ کوئی ݙر سݨاوݨ والا مگر اتھاں دے دنیا داریں آکھیا اساں بے شک اُوندا انکار کریندوں جو تُہاݙے نال بھیڄا ڳے
  34,35,اتے اکھیونے اساں وݙے مال اولاد والے اوں اتے ساکوں عذاب نہ ݙتا ویسے
  34,36,فرما ݙیو یقیناً میݙا رب روزی فراخ کریندے جیندے واسطے چاہے اتے تنگ کریندے (جیندے واسطے چاہے)تے لیکن اکثر لوک نہیں ڄاݨدے
  34,37,اتے (یاد رکھو) نہ تُہاݙے مال تے نہ تُہاݙی اولاد ایسی چیز اے جیرھی تُہاکوں ساݙے قریب کر ݙیوے مگر او جیں ایمان آندا اتے نیک عمل کیتے تاں انہیں واسطے ݙوڑا ثواب اے اُوندا بدلہ جو کیتے نیں اتے اُوہے (بہشت دے) چوٻاریں وچ امن نال ہوسن
  34,38,اتےجیرھے لوک کوشش کریندن ساݙیں ایتیں وچ (جُھٹلا تے ساکوں) عاجز کرݨ دی او لوک عذاب اچ پیش کیتے ویسن
  34,39,فرما ݙیو بے شک میݙا رب فراخ کریندے روزی جیندی چاہے اپݨے بندیں وچوں اتے تنگ کریندے (جیندے واسطے چاہے) اتے تُساں جو چیز وی خرچ کریسوتاں او اُوندے بدلے ٻئی ݙیسے اتے اُوہو بہتر روزی ݙیوݨ والا اے
  34,40,اتے جیں ݙینہہ انہیں سب کوں کٹھا کریسےول فرشتیں کوں فرمیسے کیا ایہے تُہاݙی عبادت کریندے ہن
  34,41,آکھسن توں پاک ایں (ہر عیب کنوں) توں ساݙا مالک ایں نہ ایہے بلکہ اے تاں جنیں دی عبادت کریندے ہن انہیں دے اکثر انہیں تے یقین رکھدے ہن
  34,42,تاں اڄ کوئی مالک نہیں بعض تُہاݙے ہک ٻے واسطے کہیں نفع نقصان دے اتے اساں فرمیسوں ظالمیں کوں چکھو بھا دا عذاب جیرھا تُساں جھٹلیندے ہاوے
  34,43,اتے جیں ویلھے انہیں تے پڑھیاں ونڄن ساݙیاں واضح ایتاں آکھدن اے نہیں مگر ایسا انسان جیرھا چہندے جو تُہاکوں پھیر ݙیوے اتھوں جنھیں دی عبادت تُہاݙے پیو ݙاݙے کریندے ہن اتے اکھیونے اے (قرآن) نہیں مگر ہک گھڑیا ہویا جادو اتے کافریں حق دے بارے (ہمیشہ ایہو) آکھیے جݙاں ای انہیں کنے اے آئے کہ اے نہیں مگر کھلا جادو
  34,44,اتے نہ اساں انہیں کوں کوئی کتاباں ݙتیاں ہن جنھیں کوں او پڑھن ہا اتےنہ اساں انہیں ݙے تُساں کنوں پہلےکوئی ݙر سݨاوݨ والا بھیڄے
  34,45,اتےانہیں وی جھٹلایا ہا جیرھے انہیں کنوں پہلے ہن اتے ایہے تاں نہیں پہنچے اُوندے ݙہویں حصے کوں جو اساں انہیں کوں ݙتا ہا ول انہیں میݙیں رسولیں کوں جھٹلایا ول کیویں رہا میݙا انکار (انہیں) واسطے
  34,46,فرما ݙیو (اے لوکو) میں تُہاکوں ہکا نصیحت کرینداں جو کھڑے تھی ونڄو اللہ (دی معرفت) واسطے ݙو ݙو تےہک ہک ول غور نال سوچو (مَن گِھنسو جو) تُہاݙے ساتھی کوں پاڳل پن کینی اے نہیں مگر (واضح) ݙر سݨاوݨ والا تُہاکوں سخت عذاب کنوں پہلے
  34,47,فرما ݙیو جو میں تُساں کنوں کوئی اجرت منگی ہووم تاں او تُہاݙی میݙا اجر نہیں مگر اللہ کنے اتے اُوہو ہر شے تے نگہبان اے
  34,48,فرما ݙیو یقیناً میݙا رب اِلقا فرمیندے حق دا او سب غیب ڄاݨݨ والا اے
  34,49,فرما ݙیو حق آڳے اتے باطل نہ پہلے رہے اتےنہ ول رہسے
  34,50,فرما ݙیو جے میں گمراہ تھی ڳیاں (تُہاݙے گمان اچ) تاں میݙی گمراہی دا وبال میݙے اُتے ہے اتے جیکر میں ہدایت تے ہاں تاں ایں وجہ نال جو میݙا رب میں ݙے وحی فرمیندے بے شک اُوہو سݨݨ والا اے نیڑے ہے
  34,51,کاش توں ݙیکھیں جیں ویلھے اے گھبرا ویسن (قیامت اچ) پِچھے بچ ای نہ سڳسن اتے نیڑے والی جا توں پکڑیے ویسن
  34,52,اتےآکھسن اساں ایں تے ایمان آندا اتے انہیں کوں کتھوں لبھسے (ایمان)پرے والی جا کنوں
  34,53,حالانکہ اُوندا انکار کر چکن ایں کنوں پہلے (دنیا وچ) اتے (اینویں) انڑ ݙٹھیاں مریندے کھڑن پرے والی جاہ توں
  34,54,اتے رکاوٹ پاݙتی ویسے انہیں دے درمیان تے اُوندے درمیان جو او چہندے ہوسن جیویں انہیں دے ہم پیالہ لوکیں نال کیتا ڳیا بے شک او ٻہوں دھوکے وچ پاوݨ والے شک اچ ہن
