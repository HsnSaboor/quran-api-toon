quran[5{c,v,t}:
22,1,اے لوکو ݙرو اپݨے رب کنوں بے شک قیامت دا کنباٹ وݙی (اوکھی) شے ہے
22,2,جیں ݙینہ توں اونکوں ݙیکھسیں بھل ویسے ہر کھیر پلاوݨ والی اُوں ٻال کوں جیکوں کھیر پلایا ہس تے سٹ ݙیسے ہر حاملہ اپݨے حمل کوں اتے توں ݙیکھسیں لوکیں کوں (جیویں) نشے وچ (ہوون) حالانکہ او نشے وچ نہ ہوسن لیکن اللہ دا عذاب سخت اے
22,3,اتے کجھ لوک اوہن جیرھے اللہ دے بارے جھڳڑا کریندن بغیر علم دے اتے پیروی کریندن ہر سرکش شیطان دی
22,4,اوندے اتے تاں اے لکھ ݙتا ڳے جو جیرھا وی ایندے نال دوستی رکھسے تاں اے اونکوں گمراہ کریسے اتے اونکوں دوزخ دے عذاب ݙے راہ ݙکھیسے
22,5,اے لوکو جیکر تُساں شک اچ ہووو (قیامت اچ) اٹھݨ دے بارے تاں (اے غور کرو جو) اساں تُہاکوں پیدا کیتے مٹی کنوں ول بدبو والے پلید پاݨی کنوں ول خون دے لوتھڑے کنوں ول گوشت دی ٻوٹی کنوں کوئی جسم مکمل تھیا ہویا تے کوئی نا مکمل تھیا ہویا تاکہ تُہاݙے واسطے ظاہر کر ݙیوں (اپݨیاں نشانیاں) اتے تُہاکوں ثابت رکھدوں رحم وچ جیکوں چاہوں ہک مدد مقرر تک ول تُہاکوں ٻاہر کڈھیندوں ٻال ہوندو ولا (پلیندوں) تاکہ تُساں اپݨی جوانی کوں پہنچو اتے کجھ تُہاݙے وچوں فوت کیتے ویندن تے کجھ ولائے ویندن نکمی حیاتی ݙے تاکہ کجھ نہ ڄاݨن ڄاݨ گھنݨ دے بعد وی اتے توں ݙیکھدیں زمین کوں سکی رنڑاٹ ول جیں ویلھے اُوں تے پاݨی اتاروں تروتازہ تھی ویندی اےاتے پُھنڈ ویندی اے اتے ہر قسم دے تازے سبزے ڄویندی اے
