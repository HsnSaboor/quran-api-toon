quran[8{c,v,t}:
18,54,اتے اساں بے شک بدل بدل تے بیان کیتن ایں قرآن اچ لوکیں واسطے ہر قسم دیاں مثالاں اتے انسان ہر شے کنوں زیادہ جھیڑے کار اے
18,55,اتے کیرھی شے لوکیں کوں روکیے جو ایمان آنن جݙاں انہیں کنے ہدایت آڳئی اتے اپݨے رب کنوں بخشش منگن مگر ایہو جو انہیں کنے پہلیں دا طریقہ آوے یا انہیں کنے عذاب سامݨے کنوں آوے (یا طرح طرح دا عذاب آوے)
18,56,اتے اساں نہیں بھڄیندے رسولیں کوں مگر خوشخبری ݙیوݨ والے تے ݙر سݨاوݨ والے اتے کافر جھڳڑدن باطل (دلائل) نال تاکہ اُوندے نال حق کوں مٹا ݙیوں اتے انہیں بنڑا گدھے میݙیں ایتیں کوں اتےجیں شے نال ݙرائے ڳن (اونکوں) مذاق
18,57,اتے اُوں کنوں زیادہ ظالم کون اے جینکوں رب دے ایتیں نال نصیحت کیتی ونڄے ول اُوں کنوں منہ پھیر گھنے اتے اونکوں بھلا ݙیوے جو اُوندے ہتھیں اڳی تے بھیڄے بے شک اساں انہیں دے دلیں تے پردے سٹ ݙتن جو ایں (قرآن) کوں نہ سمجھ سڳن اتے انہیں دے کنیں وچ ٻوجھ (ٻوڑ) اتے جیکر (اے حبیب) انہیں کو ہدایت ݙے سݙو ول وی کݙاہیں ہدایت نہ پیسن
18,58,اتے تیݙا رب بخشݨ والا اے رحمت والا اے جیکر انہیں کوں پکڑے ہا انہیں دے کرتوت تے تاں انہیں کوں جلدی عذاب ݙے ݙیوے ہا بلکہ انہیں واسطے وعدے دا وقت اے ہر گز نہ پیسن اُوندے سوا (اوں وقت) کوئی پناہ دی جا
18,59,اتے اے وستیاں ان انہیں (دے وسدیں) کوں ہلاک کر ݙتے سے جݙاں ظلم کیتے نیں اتے انہیں دی ہلاکت دا ہک وعدہ رکھیا ہاسے
18,60,اتے (یاد کرو) جݙاں موسیٰ فرمایا اپݨے جوان (خادم) کوں میں ہمیشہ ٹُردا رہساں حتٰی کہ ݙو سمندریں دے ملݨ دی جا تے پہنچاں یا ٻہوں مدت ٹُردا رِہاں
18,61,ول جݙاں پہنچ ڳے ݙو دریاویں دے ملاپ تے اپݨی مچھی بُھل ڳے تاں مچھی اپݨا رستہ دریا اچ بݨا گدھا سُرنگ بݨاتے
