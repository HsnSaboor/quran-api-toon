quran[6{c,v,t}:
7,52,تے بے شک اساں انہیں کنیں کتاب آندی اونکوں تفصیل نال بیان کیتوسے وݙے علم نال ہدایت تے رحمت ہئی ایماندار قوم واسطے
7,53,کیا دی انتظار اچ ان ایہو (کتاب دے ݙسائے ہوئے) انجام دی جیں ݙینہہ ایندا انجام سامݨے آیا ناں ایہے جیرھے اینکوں پہلے بھلائی کھڑن آکھسن بے شک ساݙے رب دے رسول حق گھن تے آئن ول کیا اساݙےکیتے کوئی سفارشی ہن جیرھے ساݙے واسطے سفارش کرن یا ساکوں ولا پَٹھیا ونڄے پِچھے اساں چنڳے کم کریسوں اُوں دے خلاف جو پہلے کریندے ہاسے انہیں آپ کوں گھاٹے وچ سٹیے تے انہیں کنوں گم تھی ڳے اوبہتان جیرھے ٻدھی کھڑے ہن
7,54,بے شک تہاݙا رب اللہ ہےجیں اسمان تے زمیناں چھ ݙینہہ وچ بݨائن پِچھے توجہ فرمایس عرش تے رات نال ݙینہہ کوں کڄیندے جلدی نال اُوندے پچھوں لڳدے تے (پیدا کیتس)سِجھ تے چندر تے تاریں کوں تے تابع ہن اُوندے حکم دے سݨو ہوندے واسطے ہے پیدا کرݨ تے حکم کرݨ اللہ برکتیں والا ہے جیرھا سارے جہانیں دا رب ہے
7,55,اپنے رب کنوں دعا منگو زاری نال تے آہستہ بے شک او زیادتی کرݨ والیں کوں پسند نہیں کریندا
7,56,اتے زمین اچ فساد نہ کرو اوندی اصلاح دے بعد تے اُوں کنوں دعا منگو ݙردئیں اتے امید رکھین٘دے ہوئے بے شک اللہ دی رحمت نیکی کرݨ والیں دے قریب اے
7,57,او او ذات اے جیرھا ہوائیں بھجیندے خوشخبری ݙیوݨ والیاں اوندی رحمت کنوں پہلے حتیٰ کہ جیں ویلھے (ہوائیں) چیندیئن باری جُھڑ کوں اساں اونکوں نیندوں سُنڄ شہریں ݙے ول اُوندے نال پانی اتریندوں ول اُوندے نال ہر قسم دے پھل کڈھیندوں اینویں اساں مردے زندہ کریسوں تاکہ تُساں نصیحت منو
