quran[26{c,v,t}:
75,20,ہرگز نہ بلکہ تُساں پسند کریندو جلدی والی (دنیا) کوں
75,21,اتے چھوڑیندو آخرت کوں
75,22,کئی چہرے اُوں ݙینہہ تروتازہ ہوسن
75,23,اپݨے رب کوں ݙیکھدے ہوسن
75,24,اتے کُجھ چہرے اُوں ݙینہہ بُتھے ہوسن
75,25,گمان کریسن جو انہیں نال چیل توڑ معاملہ کیتا ویسے
75,26,ہا ہا جیں ویلھے پہنچسے (ساہ) نِیڑی کوں
75,27,اتے آکھیا ویسے کوئی ہےدم جھاڑ والا
75,28,اتے سمجھ ویسے جو ایہا جدائی دی گھڑی اے
75,29,اتے ویڑھیڄ ویسے پنی کوں پنی
75,30,تیݙے رب ݙے اُوں ݙینہہ ونڄݨ اے
75,31,پِچھے نہ سچ منیس اتے نہ نماز پڑھی اس
75,32,اتے لیکن جھٹلائس اتے پھریے
75,33,ول ڳے پیا اپݨے گھر ݙے اکڑیندا ہویا
75,34,نیڑے ہے تیݙے واسطے (خرابی) ول نیڑے ہے
75,35,ول نیڑے ہے تیݙے واسطے ول نیڑے ہے
75,36,کیا انسان اے خیال کریندے جو بے کار چھوڑیا ویسے
75,37,کیا او قطرہ نہ ہا پلید پاݨی دا جو ٹپکا یاڳیا
75,38,ول خون دا لوتھڑا ہا ول (اُونکوں) پیدا کیتس تے درست بݨائس
75,39,ول اُوں کنوں ݙو قسماں بݨائس مر د تے عورت
75,40,کیا او قادر نہیں جو مُردے جِوا سڳے
76,1,بے شک اَئے انسان تے ہک وقت زمانے وچ جو اے کوئی شے نہ ہا جیندا ذکر تھیوے
76,2,بے شک اساں پیدا کیتے انسان کوں ملیے ہوئے پلید قطرے کنوں جو اُونکوں ازماؤں پِچھے اُونکوں بݨائے سے سݨݨ والا ݙیکھݨ والا
76,3,بے شک اساں اُونکوں ہدایت ݙتی اے رستے دی (ہُنڑ) یا شکر کرے یا ناشکری کرݨ والا ہووے
76,4,بے شک اساں تیار کر رکھین کافریں واسطے زنجیراں تے ڳٹ اتے بھڑکدی بھا
76,5,بے شک نیک پیسن (شراب) اُوں پیالے کنوں جیندی ملاوٹ کافور دی ہوسے
