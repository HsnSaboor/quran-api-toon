quran[6{c,v,t}:
7,82,ول (ٻیا ) جواب تاں اوندی قوم کنیں نہ ہا بس ایہو اکھیونے جو انہیں کوں کڈھو اپݨی وستی کنوں اے وݙے پاک صاف بنڑدن
7,83,پِچھے اساں اونکوں (لوط کوں)تےاوندے گھر والیں کوں نجات ݙتی سوا اوندی گھر والی دے او پچھی تے رہݨ والیں وچوں ہئی
7,84,تے انہیں تے پتھریں دا مینہ وسایوسے ول ݙیکھ کیویں انجام تھیا مجرمیں دا
7,85,تے مدین دے پاسے (بھڄوسے) انہیں دی برادری دے (مہربان) شعیب کوں فرمایس اےمیݙی قوم اللہ دی عبادت کرو تہاݙا ہوندے سوا کوئی معبود نہیں یقیناً تُساں کنے تہا ݙے رب دی طرفوں پکی دلیل آڳئی اے لہٰذا بھرتول پوری پوری کرو تےلوکیں کوں انہیں دیاں چیزاں گھٹا تےنہ ݙیو تے زمین اچ اوندی اصلاح دے بعد فساد نہ کھنڈاؤ اتے تہاݙ ے کیتے چنڳا اے جے تُساں ایمان دار بݨو
7,86,تے ہر دڳ تے ایں نہ ٻہو جو (رہ ویندیں کوں ) ݙراؤ تے انہیں کوں اللہ دے راہ کنوں روکو جیرھے ایمان آنن اُوں تے تے اُوندے وچ ݙِنگ ودے کڈھو تے یاد کرو جݙاں تُساں تھوڑے ہاوے ول تُہاکوں ڈھڳ کر ݙتس تے (اے وی )ݙیکھو جو فسادیں دا انجام کیویں تھیا
7,87,تےجیکر تُساں وچوں ہک ٹولہ اُوں تے ایمان گھن ائے جو میکوں ݙے تے بھیڄا ڳے تے ٻیا ٹولہ ایمان نہیں گھن آیا تاں صبر کرو حتٰی کہ اللہ اساݙے وچالے فیصلہ کر ݙیوے تے اُوہو ݙاڈھا چنڳا فیصلہ کرݨ والا اے
