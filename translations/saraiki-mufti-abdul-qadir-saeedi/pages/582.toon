quran[30{c,v,t}:
78,1,کیا دے بارے ہک ٻئے کنوں پچھدے ودن
78,2,وݙی خبر دے بارے
78,3,اُوہا جیندے وچ او اختلاف کریندن
78,4,یقین اے عنقریب ڄاݨ گھنسن
78,5,ول یقین اے عنقریب ڄاݨ گھنسن
78,6,کیا اساں زمین کوں وچھاوݨا نہیں بݨایا
78,7,اتے پہاڑیں کوں میکھاں
78,8,اتے تُہاکوں پیدا کیتے جوڑا جوڑا (مرد عورت)
78,9,اتے بݨائے سے تُہاݙی نیندر کوں آرام
78,10,اتے بݨائے سے رات کوں پردہ کڄݨ والی
78,11,اتے بݨائے سے ݙینہہ کوں روزی دا وقت
78,12,اتے بݨائے سے تُہاݙے اُتے مضبوط سَت (اسمان)
78,13,اتے بݨائے سے (انہیں وچ) ہک ݙاڈھا چمکدا چراغ
78,14,اتے اُتاریے سے جُھڑیں کنوں پاݨی ݙاڈھا وٹیجݨ والا
78,15,تاکہ کڈھوں اُوندے نال داݨے اتے ساول
78,16,اتے گھاٹے باغ
78,17,بے شک فیصلے دا ݙینہہ ہے مقرر وقت
78,18,جیں ݙینہہ پُھوکا ماریا ویسے صور اچ ول آ ویسو تُساں فوجیں دیاں فوجاں
78,19,اتے کھولیا ویسے اسمان تے تھی ویسے دروازے ای دروازے
78,20,اتے چلائے ویسن پہاڑ ول تھی ویسن ریت (پاݨٰی دا دھوکہ)
78,21,بے شک دوزخ تاڑ اچ اے
78,22,اکڑیلیں دا ٹکاݨہ اے
78,23,رہسن اُوندے وچ مدتاں بے شمار
78,24,نہ چکھسن اُوندے وچ ٹھڈھ اتے نہ پیوݨ دی شے
78,25,مگر ٻڑکدا پاݨی تے پُوں
78,26,بدلہ (گناہیں دا) پورا پورا
78,27,بے شک او حساب دی امید ای نہ رکھدے ہن
78,28,اتے جھٹلایا ہانیں ساݙیں ایتیں کوں ٻہوں
78,29,اتے ہر شے کوں ڳݨ تے اساں لکھ رکھیے
78,30,ول چکھو (عذاب) ہرگز نہ ودھیسوں تُہاݙے واسطے مگر عذاب
