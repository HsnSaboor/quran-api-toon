quran[3]{c,v,t}:
  74,0,اللہ دے ناں نال (شروع کرینداں) جو ٻہوں مہربان ݙاڈھا رحیم اے
  74,1,اے چادر ویڑھݨ والے محبوب
  74,2,اُٹھو تے ݙر سݨاؤ
  74,3,اتے اپݨے رب دی تکبیر آکھو
  74,4,اتے اپݨے کپڑے پاک رکھو
  74,5,اتے بتیں کوں چھوڑی رکھو
  74,6,اتے احسان نہ کرو ٻہوں گھنن واسطے
  74,7,اتے اپݨے رب واسطے صبر کرو
  74,8,ول جیں ویلھے پھوکا ماریا ویسے صور اچ
  74,9,پِچھے او ݙینہہ اوکھا ݙینہہ ہوسے
  74,10,کافریں تے سوکھا نہ ہوسے
  74,11,میݙے اتے چھوڑو اُونکوں جینکوں میں پیدا کیتم کلہا (بے سامان)
  74,12,اتے اُونکوں ٻہوں مال ݙتم
  74,13,اتے پُتر حاضر رہݨ والے
  74,14,اتے اُونکوں ٻہوں کُجھ تیار کر ݙتم
  74,15,ول ای طمع رکھدے جو زیادہ ݙیواں
  74,16,اصلوں نہ بے شک او ساݙیں ایتیں دا دشمن اے
  74,17,عنقریب اُونکوں چڑھیساں (بھا دے) صعود (پہاڑ) تے
  74,18,بے شک اُوں سوچے اتے اندازہ لاتس
  74,19,پِچھے مرے شالا کیویں اندازہ لاتس
  74,20,ول مرے شالا کیویں اندازہ لاتس
  74,21,پِچھے ݙٹھس
  74,22,ول (متھے) وٹ پاتس تے منہ وٹائس
  74,23,ول کنڈ پھیری اس اتے آکڑ کیتی اس
  74,24,ول آکھیس اے نہیں مگر جادو جو نقل تھیندا اے
  74,25,اے نہیں مگر آدمی دی ڳالھ
  74,26,عنقریب سٹیساں اینکوں دوزخ اچ
  74,27,اتے تیکو ں کیا معلوم دوزخ کیا ہے
  74,28,نہ باقی رکھے تے نہ چھوڑے
  74,29,چم لہا گھنے بندے دا
  74,30,اُوں تے اُنوی (فرشتے مقرر) ان
  74,31,اتے نہیں کیتے اساں دوزخ دے دربان مگر فرشتے اتے نسے بݨائی انہیں دی تعداد مگر ازمائش انہیں کافریں واسطے تاکہ یقین کر گھنن جنھیں کوں ݙتی ڳئی اے کتاب اتے زیادہ تھیوے ایمان والیں دا ایمان اتے نہ شک کرن جنھیں کوں کتاب ݙتی ڳئی اے اتے مومن اتے تاکہ آکھن او جنھیں دے دلیں وچ بیماری اے اتے کافر کیا ارادہ کیتے اللہ ایں مثال نال اینویں گمراہ کریندے اللہ جینکوں چاہے اتے ہدایت ݙیندے جینکوں چاہے اتے نہیں ڄاݨدا تیݙے رب دے لشکر کوں مگر اُوہو اتے نہیں اے مگر نصیحت آدمی واسطے
  74,32,ہا ہا چندر دی قسم
  74,33,اتے (قسم)رات دی جیں ویلھے پھر ونڄے
  74,34,اتے صبح دی جیں ویلھے روشن تھیوے
  74,35,بے شک اے (دوزخ) وݙیں نشانیں وچوں ہک اے
  74,36,ݙراوا ہے آدمی واسطے
  74,37,اُوندے واسطے جیرھا تُساں وچوں چاہے جو اڳوتے ونڄے یا پچھوتے رہے
  74,38,ہر جان بدلے اپݨٰی کمائی دے گِروی ہوسے
  74,39,مگر سڄے ہتھ والے
  74,40,بہشتیں وچ پچھسن
  74,41,مجرمیں کنوں
  74,42,کیرھی شے نیتا تُہاکوں دوزخ اچ
  74,43,آکھسن اساں نماز نہ پڑھدے ہاسے
  74,44,اتے مسکینیں کوں کھاݨا نہ ݙیندے ہاسے
  74,45,اتے مشغول رہندے ہاسے (بے ہودگی اچ) مشغول رہݨ والیں نال
  74,46,اتے جُھٹلیندے ہاسے جزا دے ݙینہہ کوں
  74,47,حتٰی کہ اساں کنے موت آڳئی
  74,48,پِچھے انہیں کوں فائدہ نہ ݙیسے شفاعت شفاعت کرݨ والیں دی
  74,49,ول کیا ہے انہیں کوں نصیحت کنوں منہ پھیری ودن
  74,50,جیویں او کھوتے ہوون ترٹھے ہوئے
  74,51,جو بھڄے ویندے ہوون شیر کنوں
  74,52,بلکہ چہندے ہر ہک انہیں (کافریں) وچوں جو اُونکوں ݙتا ونڄے (اسمانی) صحیفہ کُھلیا ہویا
  74,53,اصلوں ناں بلکہ اے آخرت کنوں نہیں ݙردے
  74,54,ہا ہا بے شک اے (قرآن) نصیحت اے
  74,55,پِچھے جیرھا چاہے اے نصیحت قبول کرے
  74,56,اتے نہ نصیحت قبول کریسن مگر جو چاہے اللہ او لائق اے کہ (اُوں کنوں) ݙریا ونڄے اتے اُوہو بخشݨ دے لائق اے
