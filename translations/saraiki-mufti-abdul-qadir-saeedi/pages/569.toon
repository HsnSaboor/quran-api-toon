quran[29{c,v,t}:
70,11,(حالانکہ) انہیں کوں ݙکھاݙتے ویسن مجرم پسند کریسے کاش فدیہ ݙے ݙیوے اڄ دے ݙینہہ دے عذاب دے بدلے اپݨا پُتر
70,12,اتے اپݨی گھر والی تے اپݨے بھرا
70,13,تے اپݨا خاندان جیرھا (اوکھے ویلھے) اُونکوں پناہ ݙیندا ہا
70,14,اتے جو وی زمین اچ اے سارا ول (ایہو بدلہ) اُونکوں بچا گھنے
70,15,اصلوں ناں بے شک او بھڑکدی بھا ہے
70,16,کھلی ادھوڑݨ والی اے
70,17,سݙیسے اُونکوں جیں کنڈ ڈتی ہئی تے منہ پھیریا ہا
70,18,اتے (مال) کٹھا کیتا ہا اتے محفوظ کر رکھیا ہا
70,19,بے شک انسان پیدا کیتا ڳے بے صبرا حریص
70,20,جیں ویلھے اُونکوں پہنچے تکلیف گھبرا ویندے
70,21,اتے جیں ویلھے اُونکوں پہنچے بھلائی روک رکھدے (کنجوسی کریندے)
70,22,مگر نمازی
70,23,جیرھے جو اپݨے نمازیں تے پابندی کریندن
70,24,اتے او جنھیں دے مالیں وچ حق مقرر اے
70,25,سوالی واسطے اتے محروم واسطے
70,26,اتےجیرھے سچ منیندن ݙینہہ جزا (قیامت) کوں
70,27,اتے او جیرھے اپݨے رب دے عذاب کنوں ݙردے رہندن
70,28,بے شک عذاب انہیں دے رب دا بے خوفی دی شے نہیں
70,29,اتے او جیرھے اپݨے ننگ دی حفاظت کریندن
70,30,مگر اپݨے گھر والیں تے یا (ٻانھیاں) جو مالک ان انہیں دے ہتھ پِچھے بے شک انہیں تے ملامت نہیں (ایندے وچ)
70,31,پِچھے جیرھا طلب کرے ایندےسوا کوں تاں او لوک حد کنوں ودھݨ والن
70,32,اتے او جیرھےا پݨے امانتیں اتے وعدیں دی حفاظت کریندن
70,33,اتے او جیرھے اپݨے گواہیں تے قائم رہندن
70,34,اتے او جیرھے اپݨے نمازیں تے پابندی کریندن
70,35,انہیں لوکیں کوں بہشتیں وچ عزتاں ݙتیاں ویسن
70,36,پِچھے کیا ہے انہیں کافریں کوں تُہاݙی طرف (سر چاتے) بھڄے امدن
70,37,سڄے پاسوں تے کھٻے پاسوں ٹولے ٹولے
70,38,کیا لالچ کریندے ہر شخص انہیں وچوں جو داخل کیتا ویسے نعمتیں والی بہشت اچ
70,39,اصلوں ناں بے شک اساں جتھوں پیدا کیتے انہیں کوں (خود) ڄاݨدن
