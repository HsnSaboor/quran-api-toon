quran[32{c,v,t}:
86,1,قسم اے اسمان دی اتے رات کوں آوݨ والے دی
86,2,اتے تیکوں کیا معلوم رات کوں آوݨ والا کیا ہے
86,3,ݙاڈھا چمکدا تارا
86,4,کوئی جان نہیں مگر اُوندے اُتے نگہبان ہے
86,5,ول ݙیکھݨا چہیدا اے انسان کوں جو کیا کنوں بݨایا ڳے
86,6,پیدا کیتا ڳے ٹپکدے پاݨی کنوں
86,7,جو نکلدے کنڈ اتے سینے دے درمیان وچوں
86,8,بے شک او ایندے ولاوݨ تے (ول پیدا کرݨ تے) وی ضرور قادر اے
86,9,جیں ݙینہہ ظاہر کیتیاں ویسن لُکیاں ڳالھیں
86,10,پِچھے نہ ہوسے اُونکوں کوئی زور اتےنہ کوئی مددگار
86,11,قسم اے بارش والے اسمان دی
86,12,اتے (پیدا وار واسطے)پھٹݨ والی زمین دی
86,13,بے شک اے (قرآن) فیصلہ کرݨ والا کلام اے
86,14,اتےاے کوئی کھل مذاق نہیں
86,15,بے شک اے (کافر) وی سازش کریندے پن
86,16,اتےمیں وی تدبیر فرمینداں
86,17,پِچھے ڈھل ݙیو کافریں کوں انہیں کوں کجھ مُہلت ݙیو
87,1,پاکی بیان کرو اپݨے رب دی جو اعلیٰ ہے سب توں
87,2,جیں پیدا فرمائے ول درست بݨائس
87,3,اتےجیں اندازے تے رکھیا ول ہدایت ݙتی
87,4,اتے جیں (جانوریں دا) چارہ کڈھیا
87,5,ول اُونکوں سُکا کالی جھانڑ والا کر ݙتس
87,6,ہُنڑ اساں تُہاکوں پڑھیسوں ولا نہ بھلسو
87,7,مگر جو اللہ چاہے بے شک او ڄاݨدے ہر ظاہر تے ہر چُھپیے کوں
87,8,اتے اسانی کر ݙیسوں تُہاکوں ایں اسانی ( دِین اسلام واسطے)
87,9,پِچھے تُساں نصیحت کرو جے نصیحت فائدہ ݙیوے
87,10,عنقریب نصیحت قبول کریسے جو ݙردے (اللہ کنوں)
87,11,اتے ایں کنوں پرے رہسے وݙا بد بخت
87,12,جیرھا داخل تھیسے وݙی بھا وچ
87,13,ول اتھاں نہ مرسے اتے نہ جیسے
87,14,بے شک کامیاب تھیا جو پاک بنڑیا
87,15,اتے یاد کیتس اپݨے رب دا ناں تے نماز پڑھیس
