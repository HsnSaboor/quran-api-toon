quran[17{c,v,t}:
103,1,قسم اے (محبوب دے) زمانے دی
103,2,بے شک انسان گھاٹے وچ اے
103,3,مگر جیرھے ایمان گھن ائے اتے نیک عمل کیتونے اتے ہک ٻئے کوں حق دی نصیحت کیتونے اتے ہک ٻئے کوں صبر دی نصیحت کیتونے
104,1,تباہی اے ہر طعنہ مارݨ والے کنڈھ پچھوں گلہ کرݨ والے واسطے
104,2,جیں مال کٹھا کیتے اتے اُونکوں ڳݨ ڳݨ تے رکھیس
104,3,خیال کریندے کہ بے شک اُوندا مال اُونکوں (دنیا وچ) ہمیشہ رکھسے
104,4,اصلوں ناں او ضرور سٹیا ویسے حطمہ (لتاڑݨ والی) وچ
104,5,اتے تیکوں کیا پتہ حطمہ کیا ہے
104,6,اللہ دی بھڑکائی ہوئی بھا ہے
104,7,جیرھی چڑھ ویسے دلیں تے
104,8,بے شک او انہیں تے بند کر ݙتی ویسے
104,9,وݙے وݙے تھمبیں (دی شکل) اچ
105,1,(اے حبیب) کیا آپ نوھے ݙٹھا تُہاݙے ر ب کیویں کیتے ہا تھی والیں نال
105,2,کیا نسی کیتا انہیں دے فریب کوں تباہی وچ
105,3,اتے بھیڄ ݙتس انہیں تے پرندے ٹلے دے ٹلے
105,4,مریندے ہن انہیں کوں پتھر گرم کھنگر دے
105,5,پِچھے کر ݙتس انہیں کوں کھادے ہوئے بھونہہ وانگے
