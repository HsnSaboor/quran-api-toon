quran[18{c,v,t}:
73,20,بے شک آپ دا رب ڄاݨدے بے شک آپ قیام کریندو رات دے ݙو تہائیں دے قریب تے اُوندا ادھا تے اُوندی تہائی تے ہک ٹولہ انہیں وچوں وی جیرھے تُہاݙے نال ان اتے اللہ اندازہ کریندے رات تے ݙینہہ دا اُونکوں معلوم اے جو تُساں اینکوں گݨ نہ سڳسو ول رجوع فرمائس تُہاݙے اتے لہٰذا پڑھو جتنا سوکھا لڳے قرآن وچوں اُونکوں معلوم اے جو تُساں وچوں کُجھ بیمار ہوسن اتے ٻئے سفر کریسن زمین اچ تلاش کریسن اللہ دا فضل (رزق حلال) اتے ٻئے جہاد کریسن اللہ دے رستے وچہ لہٰذا پڑھو جو سوکھا لڳے اُوندے وچوں اتے نماز قائم کرو اتے زکوٰۃ ادا کرو اتے اللہ کوں قرض حسنہ ݙیو۔ اتے جو اڳوتے بھڄیوسے اپݨے واسطے کوئی بھلائی اُونکوں پیسو اللہ دے کول بہتر اتے وݙے ثواب والی اتے بخشش منگو اللہ کنوں۔ بے شک اللہ بخشݨ والا اے رحیم اے۔
74,1,اے چادر ویڑھݨ والے محبوب
74,2,اُٹھو تے ݙر سݨاؤ
74,3,اتے اپݨے رب دی تکبیر آکھو
74,4,اتے اپݨے کپڑے پاک رکھو
74,5,اتے بتیں کوں چھوڑی رکھو
74,6,اتے احسان نہ کرو ٻہوں گھنن واسطے
74,7,اتے اپݨے رب واسطے صبر کرو
74,8,ول جیں ویلھے پھوکا ماریا ویسے صور اچ
74,9,پِچھے او ݙینہہ اوکھا ݙینہہ ہوسے
74,10,کافریں تے سوکھا نہ ہوسے
74,11,میݙے اتے چھوڑو اُونکوں جینکوں میں پیدا کیتم کلہا (بے سامان)
74,12,اتے اُونکوں ٻہوں مال ݙتم
74,13,اتے پُتر حاضر رہݨ والے
74,14,اتے اُونکوں ٻہوں کُجھ تیار کر ݙتم
74,15,ول ای طمع رکھدے جو زیادہ ݙیواں
74,16,اصلوں نہ بے شک او ساݙیں ایتیں دا دشمن اے
74,17,عنقریب اُونکوں چڑھیساں (بھا دے) صعود (پہاڑ) تے
