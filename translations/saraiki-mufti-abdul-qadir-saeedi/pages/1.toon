quran[3]{c,v,t}:
  1,1,اللہ دے ناں نال (شروع کرینداں) جو ٻہوں مہربان ݙاڈھا رحیم اے
  1,2,ساریاں تعریفاں اللہ دیاں جو مالک اے سارے جہانیں دا
  1,3,ݙاڈھا مہربان وݙا رحیم
  1,4,مالک اے ݙینہہ جزا دا
  1,5,(یا اللہ توفیق ݙے)صرف تیݙی عبادت کروں اتے صرف تیں کنوں مدد منگوں
  1,6,ساکوں (ہمیشہ)سدھے راہ تے چلا
  1,7,انہیں دا راہ جنھیں تے تیں انعام فرمائے انہیں دا (راہ)نہ جنھیں تے غضب کیتا ڳیا اتے نہ گمراہیں دا(راہ)
