quran[28{c,v,t}:
74,48,پِچھے انہیں کوں فائدہ نہ ݙیسے شفاعت شفاعت کرݨ والیں دی
74,49,ول کیا ہے انہیں کوں نصیحت کنوں منہ پھیری ودن
74,50,جیویں او کھوتے ہوون ترٹھے ہوئے
74,51,جو بھڄے ویندے ہوون شیر کنوں
74,52,بلکہ چہندے ہر ہک انہیں (کافریں) وچوں جو اُونکوں ݙتا ونڄے (اسمانی) صحیفہ کُھلیا ہویا
74,53,اصلوں ناں بلکہ اے آخرت کنوں نہیں ݙردے
74,54,ہا ہا بے شک اے (قرآن) نصیحت اے
74,55,پِچھے جیرھا چاہے اے نصیحت قبول کرے
74,56,اتے نہ نصیحت قبول کریسن مگر جو چاہے اللہ او لائق اے کہ (اُوں کنوں) ݙریا ونڄے اتے اُوہو بخشݨ دے لائق اے
75,1,میں قسم فرمینداں ݙینہہ قیامت دی
75,2,اتے قسم چینداں (آپکوں) ملامت کرݨ والی جان دی
75,3,کیا انسان اے خیال رکھدے جو اصلوں نہ جمع کریسوں اُوندیاں ہݙیاں
75,4,کیوں نہ (اساں) قادر اُوں ایں تے جو درست کر ݙیوں اُوندے انگلیں دے ݙوڈے
75,5,بلکہ انسان چہندے جو برائیاں کریندا رہے اُوندے سامنے
75,6,پچھدے کݙاں ہے ݙینہہ قیامت دا
75,7,پِچھے جیں ویلھے اکھ چُند ھیج ویسے
75,8,اتے چندر پکڑیج ویسے
75,9,اتے سجھ تے چندر کٹھا کر ݙتا ویسے
75,10,انسان آکھسے اڄ کتھاں اے بھڄݨ دی جاہ
75,11,ہرگز نہ کوئی پناہ نہیں
75,12,تیݙے رب ݙے ای اُوں ݙینہہ ٹکاݨہ اے
75,13,خبر ݙتی ویسے انسان کوں اُوں ݙینہہ جو اڳوتے بھیڄس تے جو پچھی تے چھوڑیس
75,14,بلکہ انسان خود ای اپݨے حال کوں ݙیکھݨ والا اے
75,15,توڑیں پیش کر ے تمام عذر
75,16,ہرگز نہ ہلاؤ ایں (قرآن) دے نال اپݨی زبان کوں تاکہ اینکوں جلدی پڑھو
75,17,بے شک ساݙے اتے ہے ایندا جمع کرݨ تے اینکوں پڑھݨ
75,18,ول جیں ویلھے اساں اینکوں پڑھوں ول اتباع کرو اُوں پڑھیے ہوئے دی
75,19,ول یقیناً ساݙے اتے ہے ایندا بیان کرݨ
