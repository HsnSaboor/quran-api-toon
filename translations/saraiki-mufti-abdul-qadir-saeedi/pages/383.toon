quran[13{c,v,t}:
27,64,یا کون اے جیرھا ابتداءً مخلوق پیدا کریندے ول اونکوں ولا پیدا کریسے اتے کون تُہاکوں روزی ݙیندے اسمان تے زمین وچوں کیا کوئی معبود ہے اللہ دے نال فرما ݙیو آنو اپݨٰی دلیل جیکر تُساں سچے او
27,65,فرما ݙیو نہیں ڄاݨدا جو وی اسمانیں تے زمینیں وچ اے (بغیر اللہ دی عطا دے) غیب کوں مگر اللہ اتے اے نہیں ڄاݨدے کݙاں اُٹھائے ویسن
27,66,کیا انہیں دا علم آخرت دے معاملے وچ توڑ پڄ ڳے (کیناں) بلکہ او شک اچ ہن ایندے بارے بلکہ او ایں کنوں اندھے ہن
27,67,اتے کافریں آکھیا کیا جیں ویلھے اساں مٹی تھی ویسوں تے ساݙے پیو ݙاݙے وی کیا اساں (ولا) کݙھے ویسوں
27,68,بے شک ایہو وعدہ تاں ساکوں وی ݙتا ڳے اتے ساݙے پیو ݙاݙے کوں وی ایں کنوں پہلے (ݙتا ڳے) اے نہیں مگر پہلیں دے (کوڑے) قصے
27,69,فرما ݙیو سیر کرو زمین وچ ول ݙیکھو کیویں ہا انجام مجرمیں دا
27,70,اتے (اے حبیب) انہیں تے غم نہ کرو اتے نہ دل تنگ تھیوو ایں کنوں جو اے مکر کریندن
27,71,اتے آکھدن ایہو وعدہ کݙاں (پورا تھیسے) جیکر تُساں سچے او
27,72,فرما ݙیو قریب اے جو تُہاݙے پچھوں آڳیا ہووے اُوں (وعدہ) دا کجھ جیندی تُساں اٻاہل مچیندو
27,73,بے شک تیݙا رب فضل والا اے لوکیں تے اتے لیکن انہیں دے اکثر لوک شکر نہیں کریندے
27,74,اتے بے شک تیڈا رب ضرور ڄاݨدے جو لُکیندن انہیں دے سینے اتے جو ظاہر کریندن
27,75,اتےنہیں کوئی چھپی چیز اسمان وچ تے زمین اچ مگر بیان کرݨ والی کتاب اچ موجود اے
27,76,بے شک اے قرآن بیان کریندے بنی اسرائیل تے اکثر او ڳالھیں جیندے وچ اختلاف کریندن
