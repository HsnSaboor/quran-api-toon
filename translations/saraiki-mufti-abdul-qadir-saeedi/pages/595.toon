quran[29{c,v,t}:
91,1,قسم اے سجھ دی تے اُوندی روشنی دی
91,2,اتے چندر دی جݙاں اُوندے پچھوں آوے
91,3,اتے ݙینہہ دی جݙاں اُونکوں چمکاوے
91,4,اتے رات دی جݙاں اُونکوں کڄ گِھنے
91,5,اتے اسمان دی اتے اُوندی جیں اُونکوں بݨائے
91,6,اتے زمین دی تے اُوندی جیں اُونکوں وچھائے
91,7,اتے جان دی اتے جیں اُونکوں درست بݨائے
91,8,ول اُوندے دل اچ پاتی اس اُوندی بد کرداری تے اُوندی پرہیزگاری
91,9,بے شک کامیاب تھیا جیں اُونکوں پاک بنڑایا
91,10,اتے بے شک ذلیل تھیا جیں اُونکوں گناہیں وچ پُوریا
91,11,جُھٹلایا ثمود اپݨی سرکشی نال (اپݨے رسول کوں)
91,12,جݙاں اُٹھی کھڑا انہیں دا وݙا بدبخت
91,13,ول انہیں کوں فرمایا اللہ دے رسول (بچو) اللہ دی ݙاچی کنوں تے اُوندی پاݨی دی واری کنوں
91,14,ول (وی) اُونکوں جُھٹلایونے ول اُونکوں کَپ ٹُک ݙتونے پِچھے ہلاکت سٹی انہیں تے انہیں دے رب انہیں دے گناہ دی وجہ نال پِچھے (تباہ کر تے) برابر کر ݙتس اُوں (وستی کوں)
91,15,اتے او نہیں فکر کریندا اُوندے انجام دی
92,1,قسم رات دی جݙاں چھا ونڄے
92,2,اتے (قسم) ݙینہہ دی جݙاں چمکے
92,3,اتے (قسم) اُوندی جیں نر مادی کوں پیدا کیتے
92,4,بے شک تُہاݙی کوشش مختلف اے
92,5,پِچھے او جیں (اللہ دے راہ تے) ݙتا اتے ݙر پیا
92,6,اتے سچ منیُس اچھی ڳالھ کوں
92,7,تاں ضرور کر ݙیسوں اُوندے واسطے (حاصل کرن) آسان راہ
92,8,اتے لیکن جیں کنجوسی کیتی اتے بے پرواہ بݨٰیا رہا
92,9,اتے اچھی ڳالھ کوں جُھٹلایُس
92,10,تاں ضرور اُوندے واسطے مہیا کر ݙیسوں اوکھا راہ
92,11,اتے کہیں کم نہ اوسے اُونکوں اُوندا مال جݙاں ڈھسے (ہلاکت اچ)
92,12,بے شک ساݙے اُتے ہے رہنمائی کرݨ
92,13,اتے بے شک ساݙے ای ملک اے آخرت تے دنیا
92,14,پِچھے میں ݙر ائے تُہاکوں بھڑکدی بھا کنوں
