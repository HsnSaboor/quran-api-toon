quran[6{c,v,t}:
2,191,اتے انہیں کوں قتل کر ݙیو جتھاں انہیں کوں ملو اتے انہیں کوں کڈھ ݙیو اُوں جا کنوں جتھوں انہٰیں تُہاکوں کڈھیے اتے (کفر دا) فتنہ قتل کنوں زیادہ سخت اے اتے انہیں نال جنگ نہ کرو مسجد حرام (کعبہ)دے نزدیک جے تئیں او تُہاݙے نال اُوندے وچ جنگ نہ کرن اتے جیکر او تُہاݙے نال جنگ کرن ول انہیں کوں قتل کر ݙیو اینویں سزا اے کافریں دی
2,192,ول جے او رُک ونڄن تاں بے شک اللہ ٻہوں بخشݨ والا ݙاڈھا رحیم اے
2,193,اتے انہیں نال جنگ کرو او تئیں جو فتنہ (فساد)نہ رہے اتے دین (دا نام)صرف اللہ واسطے تھی ونڄے ول جیکر او رک ونڄن تاں کوئی زیادتی نہیں مگر ظالمیں تے
2,194,عزت والا مہینہ عزت والے مہینے دا بدلہ اے اتے عزتاں دا بدلہ (ہوندے ) پِچھے جیرھا تُہاݙے اتے زیادتی کرے تاں تُساں اُوں تے زیادتی کرو جتناں او تُہاݙے اتے زیادتی کیتی اے اتے اللہ کنوں ݙرو تے ڄاݨ گھنو بے شک اللہ پرہیزگاریں نال اے
2,195,اتے اللہ دے رستے خرچ کرو اتے آپ کوں اپݨے ہتھیں ہلاکت اچ نہ سٹو اتے نیکی کرو بے شک اللہ نیکی کرݨ والیں نال محبت کریندے
2,196,اتے پورا کرو حج تے عمرہ اللہ(دی رضا دے)واسطے ول جیکر روک ݙتے ونڄو تاں(بھیڄو )جو سوکھی حاصل تھیوے قربانی کنوں اتے نہ مُناؤ اپݨے سر حتیٰ کہ قربانی دا جانور اپݨی (ذبح دی)جاہ تے پہنچ ونڄے ول جیرھا تُساں وچوں بیمار اے یا اونکوں کوئی تکلیف اے اُوندے سر اچ (تے وال مُناوے) تاں فدیہ ہے روزے یا صدقہ یا قربانی ول جݙاں پُر امن ہووو پِچھے جیرھا نفع چاوے حج نال عمرے ملاوݨ دا ول (قربانی ݙیوے)جو آسان ہووے قربانی وچوں ول جیرھا نہ پاوے (قربانی)تاں (اوں تے)روزے ہن ترے ݙینہہ حج دے دوران اتے ست (ݙینہہ)جیں ویلھے تُساں گھر ول اؤ اے پورے ݙاہ تھیسن اے (حکم)اوندے واسطے ہے جیں دا گھر بار مکے وچ نہ ہووے اتے اللہ کنوں ݙرو اتے ڄاݨ گھنو بے شک اللہ سخت سزا ݙیوݨ والا ہے
