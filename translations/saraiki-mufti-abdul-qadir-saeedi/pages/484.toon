quran[5{c,v,t}:
42,11,بݨاوݨ والا اے اسمانیں تے زمینیں دا بݨائس تُہاݙے واسطے تُہاݙے وچوں جوڑے اتے جانوریں وچوں جوڑے (بݨائس) تُہاکوں کِھنڈیندے زمین اچ اُوندی مثل کوئی شے کینی اتے اُوہو سݨݨ والا اے ݙیکھݨ والا اے
42,12,ہوندی ملک ان کنجیاں اسمانیں تے زمینیں دیاں فراخ کریندے روزی جیندے واسطے چاہے اتے تنگ کر ݙیندے (جیندے واسطے چاہے) یقیناً اُوہو ہر شے کوں ڄاݨݨ والا اے
42,13,مقرر فرمائس تُہاݙے واسطے دین وچوں او جیندا حکم ݙتا ہس نوح کوں اتے او جیندی اساں وحی کیتی تُساں ݙے اتے جیندا حکم اساں ݙتا ہا ابراہیم تے موسیٰ تے عیسیٰ (علیہ السلام) کوں جو دین کوں قائم رکھو اتے ایندے وچ تفرقہ نہ سَٹّو بھاری اے مشرکیں تے او جیندی طرف تُساں انہیں کوں سݙیندو اللہ چُݨ گھندے اپݨے (قُرب) ݙے جینکوں چاہے اتے رہنمائی کریندے اُوندی طرف اُونکوں جیرھا رجوع کرے (اُوں ݙے)
42,14,اتے نہیں تفرقہ پاتا انہیں ایندے بعد کہ آڳیا انہیں کنے علم آپس دے حسد دی وجہ نال اتے جیکر کلمہ پہل نہ کر چکا ہووے ہا تیݙے رب دی طرفوں ہک مدت مقرر تک تاں فیصلہ کر ݙتا ڳیا ہووے ہا انہیں دے درمیان اتے بے شک جنھیں کوں وارث بݨایا ڳے کتاب دا انہیں دے بعد تاں البتہ ہک دھوکے سَٹّݨ والے شک اچ ہن
42,15,لہٰذا ہیں دی طرف سݙو اتے ثابت قدم رہو جیویں تُہاکوں حکم ݙتا ڳے اتے اتباع نہ کرو انہیں دی خواہشات دی اتے فرما ݙیو میں ایمان آندا اُوں تے جو اللہ نے اُتاری کوئی کتاب اتے میکوں حکم ݙتا ڳے جو انصاف کراں تُہاݙے درمیان اللہ ساݙا ای رب اے اتے تُہاݙا ای رب اے ساݙے واسطے ساݙے عمل اتے تُہاݙے واسطے تُہاݙے عمل کوئی جھڳڑا نہیں ساݙے تے تُہاݙے درمیان اللہ کٹھا کریسے اساں سب کوں اتے ہوں ݙے رجوع اے (سب دا)
