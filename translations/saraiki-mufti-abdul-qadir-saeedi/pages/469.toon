quran[9{c,v,t}:
40,17,اڄ بدلہ ݙتا ویسےہر جان کوں جو کمائس (کہیں تے) ظلم نہ ہوسے اڄ بے شک اللہ جلد حساب گھنݨ والا اے
40,18,(اے حبیب) انہیں کوں ݙراؤ نیڑے آوݨ والی (قیامت) دے ݙینہہ کنوں جݙاں دِل سنگھ اچ پھس ویسن غم دے بھریے نہ ظالمیں واسطے کوئی دوست ہوسے تے نہ سفارشی جیندی ڳالھ منی ونڄے
40,19,او ڄاݨدے خیانت والیں اکھیں کوں اتے جو کُجھ دل لُکیندن
40,20,اتے اللہ فیصلہ فرمیندے حق دا اتے جنھیں دی اے عبادت کریندن اُوں (اللہ) دے سوا او کوئی فیصلہ نہیں کر سڳدے بے شک اللہ ای سݨݨ والا ݙیکھݨ والا اے
40,21,کیا انہیں سیر سفر نہیں کیتا زمین اچ ول ݙیکھن ہا کیویں ہا انہیں دا انجام جیرھے انہیں کنوں پہلے ہن او انہیں کنوں زیادہ ہن طاقت اچ اتے زمین تے اپݨے اثرات چھوڑݨ اچ ول انہیں کوں اللہ پکڑیا انہیں دے گناہ دے سبب اتے نہ ہا انہیں کوں اللہ کنوں کوئی بچاوݨ والا
40,22,اے ایں واسطے کہ انہیں کنے امدےرہے انہٰیں دے رسول روشن دلائل نال تے انہیں انکار کیتا ول انہیں کوں اللہ پکڑیا بے شک او طاقت والا سخت سزا ݙیوݨ والا اے
40,23,اتے بے شک اساں بھیڄا موسیٰ کوں اپݨے ایات تے روشن دلائل نال
40,24,فرعون تے ہامان تے قارون ݙے ول انہیں آکھیا (اے) جادوگر اے وݙا کوڑا اے
40,25,ول جیں ویلھے حق آندس ساݙی طرفوں انہیں آکھیا قتل کر ݙیو انہیں دے پُتریں کوں جنھیں ایندے نال ایمان آندے اتے زندہ چھوڑو انہیں دیاں دھیاں اتے نہیں سازش کافریں دی مگر گمراہی وچ
