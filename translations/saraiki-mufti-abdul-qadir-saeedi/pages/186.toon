quran[6{c,v,t}:
8,70,اے نبی انہیں کوں فرماؤ جیرھے تُہاݙے ہتھ اچ قیدی ان جیکر اللہ جاݨدا تُہاݙے دلیں اچ کوئی چنڳائی تاں تُہاکوں ہوں کنوں چنڳا ݙیسے جو تُساں کنوں گدھا ڳے تے تُہاکوں بخش ݙیسے تے اللہ بخشݨ والا اے رحیم اے
8,71,تے جیکر تُہاݙے نال دھوکے بازی دا ارادہ کرن تاں اللہ نال ای تاں ایں توں پہلے دھوکہ کیتے نیں پِچھے اللہ انہیں تے قابو ݙے ݙتے تے اللہ علم حکمت والا اے
8,72,یقیناً جنھیں ایمان آندے تے ہجرت کیتی اے نیں تے اپݨے مالیں تے جانیں نال اللہ دے راہ تے جہاد کیتے نیں تےجنھیں لوکیں انہیں کوں جاہ ݙتی اے تے مدد کیتی اے او لوک ہک ݙوجھے دے دوست ان (وارث ان) تے جنھیں ایمان آندے تے ہجرت نہیں کیتی تُہاݙے واسطے انہیں دی وراثت اچوں کجھ نہیں جے تئیں ہجرت نہ کرن تے جیکر تُساں کنوں دین اچ مدد منگن تاں تُہاݙے اُتے مدد کرݨ لازم اے مگر اُوں قوم دے خلاف جنھیں دا تُہاݙے نال معاہدہ اے تے اللہ تُہاݙے سب عملیں کوں ݙیکھݨ والا اے
8,73,تے جیرھے کافر ان او ہک ٻئے دےوارث ان جے تُساں اینویں نہ کریسو زمین اچ فتنہ تے وݙا فساد تھیسے
8,74,تےجنھیں ایمان آندے تے ہجرت کیتی اے تے اللہ دے راہ تے اپݨے مالیں تے جانیں نال جہاد کیتے نے تے او جنھیں انہیں لوکیں کوں جاہ ݙتی اے تے مدد کیتی اے او لوک سچے مومن ان انہیں کیتے بخشش اے تے عزت والی روزی اے
8,75,تے جنھیں ایں دے بعد ایمان آندے تے ہجرت کیتی اے تے تُہاݙے نال رَل تے جہاد کیتے تاں او وی تُساں وچوں ان تے رشتہ دار ہک ٻئے دے زیادہ نزدیک ان اللہ دی کتاب اچ بے شک اللہ ہر شے کوں ڄاݨݨ والا اے
