quran[7{c,v,t}:
66,1,اے نبی (کریم) کیوں حرام کریندو جو چیز حلال کیتی اے اللہ تُہاݙے واسطے خوشنودی چہندو اپݨے گھر والیں دی اتے اللہ بخشݨ والا رحم کرݨ والا اے
66,2,بے شک مقرر فرما ݙتے اللہ تُہاݙے واسطے تُہاݙیں قسمیں دا کھولݨ اتے اللہ تُہاݙا مددگار اے اتے اُوہو علم والا اے حکمت والا اے
66,3,اتے جیں ویلھے راز داری اچ فرمائی نبی (کریم) نے اپݨی ہک گھر والی کوں ہک ڳالھ ول جیں ویلھے او ڳالھ ݙسا ٻیٹھی (ٻی کوں) اتے اُونکوں اللہ نے ظاہر کر ݙتا (اپݨے) نبی تے تاں (نبی پاک نے) کُجھ اُوندے وچوں ݙسایا اتے کجھ کنوں اعراض فرمایا ول جیں ویلھے نبی نے اے ڳالھ اُونکوں ݙسائی عرض کیتس تُہاکوں اے کیں ݙسائے فرمایا میکوں ݙسائے وݙے علم والے خبر رکھݨ والے (اللہ)
66,4,جیکر تُساں رجو ع کر گھنو (بہتر) کہ بے شک (راہ کنوں) ہٹ ڳن تُہاݙے دل اتے جیکر تعاون کرو ہک ٻئے دا آپ دے خلاف تاں بے شک اللہ ای اُوندا مددگار اے اتے جبریل اتے نیک مومن اتے فرشتے سارے اُوندے بعد مددگار ان
66,5,جیکر آپ تُہاکوں طلا ق ݙے ݙیون تاں قریب اے کہ آپ دا رب تُہاݙے بدلے انہاں کوں گھر والیاں ݙیسے جیرھیاں تُساں کنوں بہتر فرماں بردار ایماندار ادب والیاں توبہ والیاں عبادت گزار روزے دار کئی رنڈڑ تے کئی کنواریاں
66,6,اے ایمان والو بچاؤ آپ کوں تے اپݨے گھر والیں کوں اُوں بھا کنوں جیندا ٻالݨ آدمی تے پتھر ان اُوں تے فرشتے مقرر ان سخت مزاج طاقتور نافرمانی نہیں کریندے اللہ دی جو انہیں کوں حکم کرے اتے (فوراً) کریندن جو انہیں کوں حکم ݙتا ونڄے
66,7,اے کافرو اڄ کوئی عذر نہ پیش کرو بے شک تُہاکوں بدلہ ݙتا ویسے جو تُساں کریندے ہاوے
