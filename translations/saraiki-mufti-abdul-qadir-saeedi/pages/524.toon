quran[17{c,v,t}:
52,15,کیا ایہو جادو اے یا تُساں نوھے ݙیکھ سڳدے
52,16,ایندے وچ داخل تھیوو پِچھے صبر کرو یا نہ صبر کرو تُہاݙے اتے برابر اے بے شک تُہاکوں بدلہ ݙتا ویندے اُوندا جو تُساں کریندے ہاوے
52,17,بے شک پرہیز گار بہشتیں اتے نعمتیں وچ ہوسن
52,18,خوش ہوسن اُوں تے جو ݙتے انہیں کوں انہیں دے رب اتے بچیسے انہیں کوں انہیں دا رب دوزخ دے عذاب کنوں
52,19,کھاؤ تے پیوو مزے نال اُوندا بدلہ جو تُساں کریندے ہاوے
52,20,آسرا لاوݨ والے ہوسن لائن اچ وچھے ہوئے پلنگیں تے تے نکاح کر ݙیسوں انہیں کوں گوری چیرویں اکھ والیاں (حوراں) نال
52,21,اتے جنھیں ایمان آندے اتے انہیں دی اتباع کیتی اے انہیں دی اولاد ایمان نال ملیسوں انہیں نال انہیں دیاں اولاداں اتے کمی نہ کریسوں انہیں دے عملیں وچوں کہیں شے دی ہر انسان (کافر) جو کمائس اُوندے بدلے گروی ہوسے
52,22,اتے انہیں دی مدد کریسوں پھلیں تے گوشت نال جتھوں او چہسن
52,23,ہک ٻئے کنوں کھسیسن (مذاق نال) بہشت اچ پیالے نہ اتھاں بیہودہ ڳالھ ہوسے اتے نہ گناہ
52,24,اتے چکر لیسن انہیں تے انہیں دے غلام گویا او چھپے موتی ان (لُکیے موتی)
52,25,اتے متوجہ تھیسن بعض انہیں دے بعض تے ہک ٻئے کنوں پُچھسن (حال)
52,26,آکھسن یقیناً اساں ایں کنوں پہلے (دنیا وچ)اپݨے گھر اچ ݙر دے ہاسے (اپݨے انجام کنوں)
52,27,ول احسان کیتے ساݙے اتے اللہ اتے ساکوں بچائس لُکھ (والی دوزخ) دے عذاب کنوں
52,28,بے شک اساں ایں کنوں پہلے ہونکوں سݙیندے ہاسے یقیناً اُوہو احسان فرماوݨ والا مہربان اے
52,29,پِچھے نصیحت فرماؤ آپ اپݨے رب دے فضل نال نہ کاہن او نہ مجنون
52,30,کیا اے آکھدن جو شاعر اے اساں انتظار کریندوں ایندے نال زمانے دے حادثات دا
52,31,فرماݙیو انتظار کرو پِچھے میں وی تُہاݙے نال انتظار کرݨ والیں وچوں ہاں
