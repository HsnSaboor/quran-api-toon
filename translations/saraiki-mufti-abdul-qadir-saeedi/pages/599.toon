quran[18{c,v,t}:
98,8,انہیں دا ثواب انہیں دے رب دے نزدیک (ہمیشہ) وسݨ دیاں بہشتاں ہن جنھیں تلے نہراں جاری ان اُوندے وچ ہمیشہ رہسن اللہ انہیں کنوں راضی اتے او اللہ تے خوش اے (انعام) اُوندے واسطے جو ݙر پے اپݨے رب کنوں
99,1,جیں ویلھے کنبا ݙتی ویسے زمین سخت کنبا وݨ
99,2,اتے کڈ ھ ݙیسےزمین اپݨے سارے بار
99,3,اتے (حیران تھی تے) آکھے انسان اینکوں کیا تھی ڳے
99,4,اُوں ݙینہہ بیان کریسے (زمین) اپݨیاں خبراں
99,5,کیونکہ بے شک تیݙے رب اُونکوں حکم ݙتے
99,6,اُوں ݙینہہ ولسن لوک مختلف حالتیں وچ تاکہ انہیں کوں ݙکھائے ونڄن انہیں دے اعمال
99,7,پِچھے جیرھا کریسے ذرے جتنا نیکی اُونکوں ݙیکھسے
99,8,اتے جیرھا کریسے ذرے جتنا برائی اُونکوں وی ݙیکھسے
100,1,قسم اے دوڑݨ والے (گھوڑیں) دی ہوکدے ہوئے
100,2,ول پتھر وچوں بھا کڈھݨ والیں دی کُھریں نال
100,3,ول حملہ کرݨ والیں دی صبح دے وقت
100,4,ول پٹیندن اُوں وقت دھوڑ
100,5,ول پہہ ویندن اُوں وقت (دشمن دی) جماعت اچ
100,6,بے شک انسان اپݨے رب دا وݙا نا شکرا اے
100,7,اتے بے شک او ایں تے (آپ) گواہ اے
100,8,اتے بے شک او مال دی محبت اچ سخت اے
100,9,کیا او نہیں ڄاݨدا جݙاں اٹھائے ویسن جو قبریں وچ ان
