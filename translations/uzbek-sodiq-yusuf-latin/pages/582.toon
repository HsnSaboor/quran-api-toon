quran[30]{c,v,t}:
  78,1,"Nima haqida so`rashadi?"
  78,2,"Ulkan, muhim xabar haqida."
  78,3,"Shunday xabarki, ular uning haqida ixtilofdadirlar."
  78,4,"Yo`q! Ular tezda bilurlar."
  78,5,"Yana yo`q! Ular tezda bilurlar!{1}",footnotes:1:(Mushriklar azobni tortganlarida qayta tirilish nima ekanligini, uning bo`lishi hech shubhasiz haq ekanini albatta biladilar.)
  78,6,"Yerni beshikdek moslab qo`ymadikmi?"
  78,7,"Va tog`larni qoziq (qilib qo`ymadikmi?)."
  78,8,"Va sizlarni juft qilib yaratdik."
  78,9,"Va uyqularingizni rohat qilib qo`ydik."
  78,10,"Va kechasini libos qildik."
  78,11,"Va kunduzni maosh (tirikchilik) vaqti qildik."
  78,12,"Tepangizga yetti mustahkam(osmon)ni bino qildik."
  78,13,"Va shu'la taratuvchi chiroq ham qildik."
  78,14,"Va siqilgan(bulut)lardan oquvchi suvlar tushirdik."
  78,15,"U(suv) bilan don va nabotot chiqarishimiz uchun."
  78,16,"Va daraxtlari bir-biriga kirishgan bo`stonlar."
  78,17,"Albatta, ajrim kuni vaqti belgilangan edi."
  78,18,"U kunda surga puflanur va sizlar to`p-to`p bo`lib kelursiz."
  78,19,"Osmon yorilib eshiklar ochilur."
  78,20,"Tog`lar o`rnidan ko`chirilib, sarobga aylanur."
  78,21,"Albatta, jahannam poylab turuvchidir."
  78,22,"Tug`yonga ketganlarning qaytar joyidir."
  78,23,"Ular (unda) zamonlar bo`yi qolarlar."
  78,24,"Ular (unda) sovuqni ham, sharobni ham tatiy olmaslar."
  78,25,"Magar qaynoq suv va yiringni (tatirlar)."
  78,26,"Muvofiq jazo o`laroq."
  78,27,"Chunki, ular hisob-kitob bo`lishiga ishonmasdilar."
  78,28,"Va Bizning oyatlarimizni yolg`on deyishgan edi, yolg`on!"
  78,29,"Biz har bir narsani kitobga jamlab qo`yganmiz."
  78,30,"Bas, tatib ko`ringlar, sizlarga azobdan boshqa hech narsani ziyoda qilmasmiz."
