quran[32]{c,v,t}:
  86,1,"Osmon bilan qasam va toriq bilan qasam."
  86,2,"Toriq nimaligini senga ne bildirdi?"
  86,3,"U, nur sochib turuvchi yulduzdir."
  86,4,"Hech bir jon yo`qki, uning hifz qilib turuvchisi bo`lmasa."
  86,5,"Inson nimadan yaralganiga nazar solsin."
  86,6,"U otilib chiquvchi suvdan yaralgandir."
  86,7,"U (suv) sulb (orqa umurtqa) va taroib (ko`krak suyagi) orasidan chiqadir."
  86,8,"Albatta, U zot uni qayta tiriltirishga qodirdir."
  86,9,"Sirlar fosh bo`ladigan kundadir."
  86,10,"Bas (o`shanda) u(inson)da quvvat ham, nusrat beruvchi ham bo`lmaydir."
  86,11,"Qaytuvchi sohibi bo`lgan osmon bilan qasam."
  86,12,"Yorib chiquvchi egasi bo`lgan yer bilan qasam."
  86,13,"Albatta, u (Qur'on) ajratuvchi so`zdir."
  86,14,"Va u hazil emasdir."
  86,15,"Albatta, ular hiyla qiladir."
  86,16,"Va Men ham «hiyla» qilurman.{1}",footnotes:1:(Ya'ni, hiylasiga yarasha jazo berurman.)
  86,17,"Bas, kofirlarga muhlat ber. Ha, ularga ozgina muhlat ber.{1}",footnotes:1:(Ya'ni, ularga azob kelmayotganidan shoshilma, hammasining vaqti, soati bor.)
  87,1,"Oliy qadar bo`lgan Robbing ismini poklab yod et."
  87,2,"U yaratgan va mutanosib qilgan Zotdir."
  87,3,"U, o`lchov bilan qilgan va hidoyatga boshlagan Zotdir."
  87,4,"U, o`t-o`lanni chiqargan Zotdir."
  87,5,"Bas, uni qoraygan xashak qilgan Zotdir."
  87,6,"Biz senga (Qur'onni) qiroat qildiramiz, bas, sen uni esdan chiqarmassan."
  87,7,"Illo, Alloh xohlaganini. Albatta, U oshkorni ham, maxfiy narsalarni ham biladir."
  87,8,"Va seni oson yo`lga muyassar qilamiz."
  87,9,"Bas, agar eslatish manfaat bersa, eslatgin."
  87,10,"Albatta, U zotdan qo`rqqan esga oladir."
  87,11,"Va badbaxtgina undan chetda bo`ladir."
  87,12,"U katta olovga kiradir."
  87,13,"So`ngra, uning ichida o`lmay ham, tirilmay ham qoladir."
  87,14,"Haqiqatan, kim pok bo`lsa, yutuq topadir."
  87,15,"Va Robbi ismini zikr qilsa va namoz o`qisa hamdir."
