quran[42]{c,v,t}:
  80,1,"Aftini burishtirdi va yuz o`girdi."
  80,2,"Ko`zi ko`r kishi huzuriga kelganda."
  80,3,"Qayerdan bilasan, ehtimol, u poklanar."
  80,4,"Yoki nasihat olar va mav'iza unga manfaat berar."
  80,5,"Ammo istig`no qilganga bo`lsa..."
  80,6,"Sen u tomonga intilasan."
  80,7,"U poklanmasa, seni hech kim malomat qilmas."
  80,8,"Ammo huzuringga shoshilib kelgan."
  80,9,"Va U zotdan qo`rqqan holda bo`lgandan esa..."
  80,10,"Bas, Sen undan mashg`ul bo`lasan."
  80,11,"Yo`q! Albatta ular (Qur'on oyatlari) eslatmadir."
  80,12,"Kim xohlasa, uni eslaydir."
  80,13,"Hurmatlangan sahifalardadir."
  80,14,"Oliy qadardirlar, poklangandirlar."
  80,15,"Elchi(farishta)lar qo`llaridadir."
  80,16,"Ular hurmatlangan va o`ta yaxshidirlar."
  80,17,"Insonga la'nat bo`lsin, uning kofirligi qandoq shiddatli bo`ldi."
  80,18,"Uni qaysi narsadan yaratdi?"
  80,19,"Nutfadan uni yaratdi va uni o`lchovli qildi."
  80,20,"So`ngra, chiqish yo`lini oson qildi."
  80,21,"So`ngra o`ldirdi va qabrga kirgazdi."
  80,22,"So`ngra (qachon) xohlasa, uni qayta tiriltiradi."
  80,23,"Yo`q, undoq emas! U o`ziga U zot qilgan amrni bajarmadi."
  80,24,"Inson o`z taomiga nazar solsin."
  80,25,"Albatta, Biz suvni rosa quyib qo`yibmiz."
  80,26,"So`ngra yerni o`ziga xos yordik."
  80,27,"Biz unda donni."
  80,28,"Va uzum va ko`klarni."
  80,29,"Va zaytun va xurmolarni."
  80,30,"Va tig`iz bog`larni."
  80,31,"Va mevalaru o`t-o`lanlarni o`stirib qo`ydik."
  80,32,"Sizlarga va chorvalaringizga manfaat va lazzat bo`lsin, deb."
  80,33,"Vaqtiki kar qiluvchi ovoz kelsa."
  80,34,"U kunda kishi o`z aka-ukasidan."
  80,35,"Va onasi va otasidan."
  80,36,"Va xotini va bola-chaqasidan qochadi."
  80,37,"U kunda ulardan har bir shaxsni ovora qiluvchi o`z ishi bor."
  80,38,"U kunda porloq chehralar bor."
  80,39,"Ular kulgu bilan to`la, yetgan xushxabardan xursand."
  80,40,"U kunda bir chehralar borki, ularni g`ubor bosgan."
  80,41,"Ustini zulmat qoplagan."
  80,42,"Ular, ana o`shalar, kofirlar va fojirlardir."
