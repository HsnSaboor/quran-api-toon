quran[15]{c,v,t}:
  112,1,"Ayt: «U Alloh yagonadir."
  112,2,"Alloh — Comaddir.{1}",footnotes:1:(Hojatlarni va rag`batlarni qondiruvchidir.)
  112,3,"U tug`magan va tug`ilmagan."
  112,4,"Va Unga hech kim teng bo`lmagan».{1}",footnotes:1:(Alloh taologa biror zot na zotida, na sifatida va na amalida teng bo`lgan emas, bo`lolmaydi ham.)
  113,1,"«Tong Robbisidan panoh so`rayman."
  113,2,"U yaratgan narsalar yomonligidan."
  113,3,"Va kirib kelgan qorong`u kechaning yomonligidan."
  113,4,"Va tugunlarga dam soluvchilar yomonligidan.{1}",footnotes:1:(Sehrgarlar birovni sehrlab zarar yetkazmoqchi bo`lsa, ip olib, o`qiydigan narsasini o`qib, dam solib, ipni bir tugib, yana bir dam solib, yana tugib, oxiriga yetkazar ekan.)
  113,5,"Va hasad qilgan hasadchining yomonligidan», deb ayt."
  114,1,"«Odamlar Robbisidan..."
  114,2,"Odamlar podshohidan..."
  114,3,"Odamlar Ilohidan panoh so`rayman..."
  114,4,"Berkinib, ko`rinib turuvchi vasvasachining..."
  114,5,"Odamlar qalblariga vasvasa soladiganning..."
  114,6,"Jinlar va odamlardan bo`lganning yomonligidan», deb ayt.{1}",footnotes:1:(Oyatda zikr qilingan «berkinib, ko`rib turuvchi»dan murod shaytondir.)
