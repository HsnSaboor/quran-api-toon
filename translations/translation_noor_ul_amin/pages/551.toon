quran[7]{c,v,t,f}:
  60,12,"یہ انہیں زبردست قوتوں والے «<a href=455> فرشتہ </a>»  ( جبرائیل ؑ )  نے سکھایا ہے"
  60,13,"وہ «<a href=455> فرشتہ </a>» جسمانی اور عقلی اعتبارسے کمال کو پہنچاہوا ہے ،  پھروہ نمودار ہوا"
  61,1,"اور وہ «<a href=106> بلند </a>» «<a href=10> آسمان </a>» کے کناروں پر تھا"
  61,2,"پھروہ «<a href=619> نزدیک </a>» ہوااوراترگیا"
  61,3,"پس وہ دوکمانوں کے فاصلے پر یا اس سے بھی «<a href=636> زیادہ </a>»  ( رسول اﷲؐ )  کے قریب ہوگیا"
  61,4,"پھر اللہ نے اپنے بندے کی طرف وحی کی جو کرناتھی"
  61,5,"( رسول اﷲ )  نےجو کچھ دیکھا تھا اس کے «<a href=324> دل </a>» نے اسے جھٹلایانہیں"