quran[9]{c,v,t,f}:
  64,1,"اور یہ کہ وہی ہنساتا ہے اور رلاتا ہے"
  64,2,"اور یہ کہ وہی مارتا اور «<a href=381> زندہ </a>» کرتا ہے"
  64,3,"اور یہ کہ اسی نے نرمادہ اور دونوں قسمیں پیداکیں"
  64,4,"ایک قطرہ نطفہ سے جب کہ وہ  ( رحم میں  )  ٹپکایاجاتا ہے"
  64,5,"اور یہ کہ دوسری بارزندہ کرنا بھی اس کے ذمہ ہے"
  64,6,"اور یہ کہ وہی دولت مند بناتا اور محتاج بناتا ہے"
  64,7,"اور یہ کہ وہی شعریٰ  ( ستارے )  کا رب ہے"
  64,8,"اور یہ کہ ا سی نے  ( قوم )  عاداولیٰ کو «<a href=646> ہلاک </a>» کیا"
  64,9,"اور ثمودکوبھی حتیٰ کہ کوئی «<a href=79> باقی </a>» نہ چھوڑا"