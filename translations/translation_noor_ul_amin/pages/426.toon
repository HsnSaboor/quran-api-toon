quran[8]{c,v,t,f}:
  33,55,"جوان ایمان والوں کے لئے «<a href=644> ہدایت </a>» اور خوشخبری ہیں"
  33,56,"جونمازقائم کرتے ہیں اور زکٰوۃاداکرتے ہیں اور «<a href=2> آخرت </a>» پر «<a href=658> یقین </a>» رکھتے ہیں"
  33,57,"اورجو لوگ «<a href=2> آخرت </a>» پر ایما ن نہیں رکھتے ہم نے ان کے لئے ان کے «<a href=42> اعمال </a>» کو «<a href=306> خوبصورت </a>» بنادیالہٰذاوہ اندھے بنے پھرتے ہیں"
  33,58,"یہی لوگ ہیں «<a href=236> جن </a>» کے لئے براعذاب ہے اور «<a href=2> آخرت </a>» میں وہی سب سے «<a href=636> زیادہ </a>» خسارہ میں رہیں گے"
  33,59,"اور  ( اے نبی )  آپ یہ «<a href=470> قرآن </a>» ایک حکیم وعلیم ہستی کی طرف سے پارہے ہیں"
  33,60,"جب موسیٰ نے اپنے گھروالوں سے کہاکہ :مجھے «<a href=12> آگ </a>» سی نظرآرہی ہے میں ابھی وہاں سے کوئی «<a href=293> خبر </a>» لاتا ہوں یاکوئی دہکتا «<a href=654> ہوا </a>» انگارا لاتا ہوں تاکہ تم سینک سکو"
  33,61,"پھرجب وہ وہاں پہنچے تو آوازآئی کہ’’مبارک ہے وہ جو اس «<a href=12> آگ </a>» میں ہے اورجو اس کے اردگردہے اور «<a href=142> پاک </a>» ہے اللہ جو سب جہان والوں کا رب ہے"
  33,62,"موسیٰ میں ہی اللہ ہوں سب پر «<a href=447> غالب </a>» اور حکمت والا"