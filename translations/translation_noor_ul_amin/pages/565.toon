quran[27]{c,v,t,f}:
 68,16,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,17,"اس نے ( میٹھے اور کھاری پانی کے ) دوایسے سمندروں کو جاری کیا جوبظاہرآپس میں ( ایک دوسرے سے ) ملے ہوئے ہیں"
 68,18,"ان ( دونوں پانیوں ) کے درمیان پر دہ ہے جس سے وہ تجاوز نہیں کرتے"
 68,19,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,20,"ان دونوں ( سمندروں ) میں سے موتی اور مرجان نکلتے ہیں"
 68,21,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,22,"اور اللہ ہی کی ( ملکیت میں ) ہیں وہ جہازجوسمندروں میں پہاڑکی طرح کھڑے ہوئے ( چل پھررہے ) ہیں"
 68,23,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے؟"
 68,24,"ہرچیزجوزمین پر ہے ختم ہوجانے والی ہے"
 68,25,"اور فقط آپ کے رب کی ذات ہی باقی رہ جائے گی جو عزت اور بزرگی والی ہے"
 68,26,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے ؟"
 68,27,"آسمانوں اور زمین میں جو بھی ہیں سب اسی سے مانگتے ہیں وہ ہرروزایک نئی شان میں ہے"
 68,28,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے؟"
 68,29,"اے جن وانس! عنقریب ہم فارغ ہوکر ( تمہاری طرف متوجہ ) ہوجائینگے"
 68,30,"پس ( اے جن و انس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے"
 68,31,"اے جن وانس کے گروہ! اگر تم میں آسمانوں اور زمین کے کناروں سے باہرنکل جانے کی طاقت ہے تونکل بھاگ جائو! تم انتہائی زورکے بغیربھی نہیں نکل سکوگے"
 68,32,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,33,"( اگرتم بھاگنے کی کوشش کروگے تو ) تم پر آگ کے شعلے اور سخت دھواں چھوڑاجائے گاپھرتم بچائونہ کرسکوگے"
 68,34,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے؟"
 68,35,"پھرجب ( قیامت کے دن ) آسمان پھٹ کرسرخ چمڑے کی مانندگلابی رنگ کاہوجائے گا"
 68,36,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,37,"اس دن کسی انسان یا جن سے اس کے گناہ کے بارے میں نہیں پوچھاجائے گا"
 68,38,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
 68,39,"مجرم اپنے چہرے کے نشانوں سے پہچانے جائیں گے انہیں پیشانی کے بالوں اور قدموں سے پکڑا جائے گا"
 68,40,"پس ( اے جن وانس ) تم اپنے رب کی کن کن نعمتوں کو جھٹلائو گے؟"
 68,41,"یہ وہ جہنم ہے جس کو مجرم جھٹلاتے تھے"
 68,42,"وہ اس جہنم اور کھولتے ہوئے پانی کے درمیان چکر لگائیں گے"