quran[20]{c,v,t,f}:
  50,16,"یہ «<a href=356> رات </a>» اور «<a href=326> دن </a>» ،  سورج اور چاندسب اللہ کی نشانیاں ہیں لوگو!تم سورج کو سجدہ نہ کرو اور نہ «<a href=254> چاند </a>» کو اور اس اللہ کو سجدہ کرو جس نے انہیں «<a href=180> پیدا </a>» کیا  ،  اگرتم صرف اسی کی «<a href=439> عبادت </a>» کرتے ہو"
  50,17,"پس اگریہ لوگ تکبرکی وجہ سے اللہ کی «<a href=439> عبادت </a>» نہ کریں تو  ( نہ کریں )  وہ فرشتےجو آپ کے رب کے «<a href=141> پاس </a>» ہیں  ،  وہ «<a href=356> رات </a>» «<a href=326> دن </a>» اس کی پاکی «<a href=126> بیان </a>» کرتے ہیں اور تھکتے نہیں ہیں"
  50,18,"اوراللہ کی نشانیوں میں سے یہ ہے کہ تم دیکھتے ہوکہ «<a href=379> زمین </a>» مردہ ہے پھرہم اس پر «<a href=144> پانی </a>» برساتے ہیں تووہ حرکت میں آتی اور پھول جاتی ہے جس نے اس «<a href=379> زمین </a>» کو «<a href=381> زندہ </a>» کیا وہ یقینامردوں کو بھی «<a href=381> زندہ </a>» کرسکتا ہے کیونکہ وہ ہرچیزپرقادر ہے"
  50,19,"بلاشبہ جو لوگ ہماری آیات سے غلط مفہوم لیتے ہیں وہ ہم سے پوشیدہ نہیں ہیں بھلاوہ شخص جو جہنم میں ڈالاجائے گاوہ بہتر ہے یاوہ جو «<a href=476> قیامت </a>» کے «<a href=326> دن </a>» امن وامان سے آئیگا ؟ تم جو چاہتے ہو کرو ،  جو تم کرتے ہو اللہ اسے خوب دیکھ رہا ہے"
  50,20,"بیشک «<a href=236> جن </a>» لوگوں نے «<a href=470> قرآن </a>» کا «<a href=60> انکار </a>» کیا  ،  جب وہ ان کے «<a href=141> پاس </a>» آیا  ( وہ ہم سے پوشیدہ نہیں ہیں  )  حالانکہ یہ ایک زبردست «<a href=485> کتاب </a>» ہے"
  50,21,"جس میں باطل نہ آگے سے راہ پاسکتا ہے اور نہ «<a href=179> پیچھے </a>» سے یہ حکمت والے اور «<a href=547> لائق </a>» ستائش اللہ کی طرف سے نازل «<a href=654> ہوا </a>» ہے"
  50,22,"آپ سے بھی وہی کہا جارہا ہےجو آپ سے «<a href=162> پہلے </a>» رسولوں کو کہاجاچکا ہے بلاشبہ آپکارب «<a href=591> معاف </a>» کردینے والا بھی ہے اور دردناک «<a href=440> عذاب </a>» دینے والابھی"
  50,23,"اوراگرہم اس «<a href=470> قرآن </a>» کی زبان غیر عربی بنادیتے توکافر کہتے کہ اس کی آیات واضح کیوں نہیں یہ «<a href=485> کتاب </a>» عجمی زبان میں اور مخاطب عربی کے لئے  ،  آپ کہہ دیجئے کہ جو ایمان لائے ان کے لئے یہ ہدایات اور شفا ہے اورجو ایمان نہیں لاتے ان کے کانوں کے لئے یہ بہرہ پن ،  اور ان کی آنکھوں کا «<a href=58> اندھا </a>» پن ہے ،  وہ ایسے ہیں جیسے کہیں دورجگہ سے انہیں پکارا جارہا ہو"
  50,24,"ہم نے موسیٰ کو «<a href=485> کتاب </a>» دی تھی تو اس میں اختلاف کیا گیا اوراگرآپ کے رب کی طرف سے «<a href=162> پہلے </a>» سے طے شدہ نہ ہوتا تو ان کے «<a href=321> درمیان </a>» «<a href=461> فیصلہ </a>» چکا دیاجاتا اور بیشک وہ لوگ «<a href=470> قرآن </a>» کی صداقت کے بارے میں گہرے «<a href=420> شک </a>» میں مبتلا ہیں"
  50,25,"جس نے کوئی «<a href=634> نیک </a>» عمل کیا اس کافائدہ اسی کو ہوگا اور اگربرائی کرے اس کا وبال اسی پر ہے اور آپ کارب بندوں پر ظلم کرنے والا نہیں"
  50,26,"قیامت کاعلم اللہ تعالیٰ ہی کی طرف لوٹایاجاتا ہے اورجو بھی «<a href=170> پھل </a>» اپنے شگوفہ سے نکلتا ہے یامادہ حاملہ ہوتی یابچہ جنتی ہے تویہ سب کچھ اللہ ہی کے علم سے ہوتا ہے اور جس «<a href=326> دن </a>» اللہ پکارے گاکہاں ہیں میرے «<a href=418> شریک </a>» ’’وہ کہیں گے‘‘ہم آپ سے کہہ چکے ہیں کہ  ( آج )  ہم میں سے کوئی  ( ایسی )  گواہی دینے والا نہیں"
  50,27,"اور «<a href=236> جن </a>» جھوٹے معبودوں کو وہ «<a href=162> پہلے </a>» پکاراکرتے تھے وہ سب ان سے «<a href=529> گم </a>» ہو جائینگے اور «<a href=658> یقین </a>» کر لیں گے کہ اب ان کے لئے کوئی جائے «<a href=156> پناہ </a>» نہیں"
  50,28,"انسان اپنے لئے بھلائی کی دعاکرنے سے نہیں تھکتا اور اگر اسے کوئی «<a href=202> تکلیف </a>» پہنچے تومایوس اور «<a href=324> دل </a>» شکستہ ہوجاتا ہے"
  50,29,"اوراگرتکلیف پہنچنے کے بعدہم اسے اپنی رحمت کاذائقہ دیں توکہنے لگتا ہے کہ میں اس کامستحق تھا اور میں نہیں سمجھتا کہ کبھی «<a href=476> قیامت </a>» بھی آئیگی اور اگرمجھے اپنے رب کے «<a href=141> پاس </a>» جاناہی پڑا تووہا ں بھی میرے لئے بھلائی ہی ہوگی ہم ایسے کافروں کو ضرور بتلا دینگے کہ وہ کیا کرتے تھے اور انہیں شدیدعذاب کامزہ چکھائیں گے"
  50,30,"اور جب ہم «<a href=3> انسان </a>» پر انعام کرتے ہیں تومنہ موڑ لیتا ہے اور پہلوپھیر کر چل دیتا ہے اور جب کوئی «<a href=202> تکلیف </a>» پہنچتی ہے تولمبی چوڑی «<a href=323> دعا </a>» ئیں مانگنے لگتا ہے"
  50,31,"آپ پوچھئے بھلادیکھو اگر یہ «<a href=470> قرآن </a>» اللہ تعالیٰ کی طرف سے ہو اور تم نے اس سے «<a href=60> انکار </a>» کیا تواس سے بڑھ کرگمراہ کون ہو گا جو اس کی «<a href=574> مخالفت </a>» میں «<a href=328> دور </a>» تک چلا گیا ہو"
  50,32,"عنقریب ہم انہیں کائنات میں اپنی نشانیاں دکھلائیں گے اور ان کی اپنی ذات میں بھی دکھائیں گے یہاں تک کہ ان پر واضح ہوجائے گاکہ یہ حق ہے کیا یہ «<a href=71> بات </a>» «<a href=480> کافی </a>» نہیں کہ آپ کارب ہرچیز سے باخبر ہے"
  50,33,"سُن لو!یہ لوگ اپنے رب کی ملاقات سے «<a href=420> شک </a>» میں ہیں  ( اور )  سُن لوکہ اللہ تعالیٰ ہرچیزکااحاطہ کئے ہوئے ہے"
  50,34,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  50,35,"حم"