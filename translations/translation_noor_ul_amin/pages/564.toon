quran[19]{c,v,t,f}:
  67,27,"قادرمطلق بادشاہ کے «<a href=141> پاس </a>» «<a href=441> عزت </a>» کے مقام میں  ( ہوں گے )"
  67,28,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  67,29,"نہایت مہربا ن اللہ ہے"
  67,30,"( جس نے  )  «<a href=470> قرآن </a>» سکھلایا"
  68,1,"انسان کو «<a href=180> پیدا </a>» کیا"
  68,2,"( پھر )  اسے «<a href=114> بولنا </a>» سکھلایا"
  68,3,"سورج اور «<a href=254> چاند </a>» ایک «<a href=593> مقرر </a>» حساب سے ہیں"
  68,4,"اور ستارے اور «<a href=319> درخت </a>»  ( اپنے رب کو  )  سجدہ کرتے ہیں"
  68,5,"اور «<a href=10> آسمان </a>» کو  ( «<a href=273> چھت </a>» بناکر )  اونچا کیا  اور «<a href=193> ترازو </a>» بنایا"
  68,6,"تاکہ تم تولنے میں «<a href=282> زیادتی </a>» نہ کرو"
  68,7,"اور وزن کو «<a href=59> انصاف </a>» سے تولو اور «<a href=193> ترازو </a>» میں ڈنڈی نہ مارو"
  68,8,"اور «<a href=379> زمین </a>» کو اس نے ساری «<a href=303> مخلوق </a>» کے لئے بنایا"
  68,9,"جس میں میوے ہیں اور خوشوں میں لپٹے «<a href=510> کھجور </a>» والے «<a href=319> درخت </a>» ہیں"
  68,10,"اور بھوسے والااناج  ( یعنی جانوروں اور انسانوں کی «<a href=307> خوراک </a>» )  اور خوشبودارپھول ہیں"
  68,11,"پس  ( اے «<a href=236> جن </a>» وانس )  تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
  68,12,"اس نے «<a href=3> انسان </a>» کو سڑی «<a href=568> مٹی </a>» سے «<a href=180> پیدا </a>» کیا  ہےجو ٹھیکری کی طرح تھی"
  68,13,"اور جنوں کو «<a href=12> آگ </a>» کے شعلے سے «<a href=180> پیدا </a>» کیا"
  68,14,"پس  ( اے «<a href=236> جن </a>» وانس )  تم اپنے رب کی کن کن نعمتوں کو جھٹلائوگے؟"
  68,15,"وہ دونوں مشرقوں کابھی رب ہے اور دونوں مغربوں کا بھی"