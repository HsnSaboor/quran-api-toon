quran[14]{c,v,t,f}:
 109,1,"اور جب دوسروں کو ماپ کریاتول کر دیتے ہیں توگٹھادیتے ہیں"
 109,2,"کیا وہ خیال نہیں کرتے کہ وہ ( دو با رہ زندہ کرکے ) اٹھا ئے جانے والے ہیں"
 109,3,"ایک بڑے دن کے لئے"
 109,4,"جب سب لوگ اپنے رب کے حضور کھڑے ہوں گے"
 109,5,"ہرگزنہیں ، بدکردارلوگوں کے اعمال نامے قیدخانے کے دفتر میں ہوں گے"
 109,6,"اورآپ کیا جانیں کہ وہ قیدخانے کادفتر کیا ہے"
 110,1,"ایک کتاب ہے لکھی ہوئی"
 110,2,"اس دن جھٹلانے والوں کے لئے ہلاکت ہے"
 110,3,"جویوم جزا کو جھٹلاتے ہیں"
 111,1,"اورایسے صرف وہی ( شخص ) جھٹلاتا ہے ، جوحدسے بڑھنے والا گنہگار ہے"
 111,2,"اور جب اس پر ہماری آیات پڑھی جاتی ہیں توکہتا ہے کہ یہ توپہلے لوگوں کے قصے ہیں"
 111,3,"ہرگزیہ بات نہیں بلکہ ان لوگوں کے دلوں پر ان کے برے اعمال کازنگ لگ گیا ہے"
 111,4,"یقیناایسے لوگ اس دن اپنے رب ( کے دیدارسے ) محروم رکھے جائینگے"
 111,5,"پھریقینایہ جہنم میں گرنے والے ہیں"