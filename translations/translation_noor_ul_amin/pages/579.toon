quran[20]{c,v,t,f}:
  76,6,"ایک ایسا رسول جو تمہیں اللہ کی واضح آیات پڑھ کرسناتا ہے تاکہ ایمان لانے والوں اور «<a href=634> نیک </a>» عمل کرنے والوں کو تاریکیوں سے نکا ل کرروشنی کی طرف لائے اور جو شخص اللہ پر ایمان لائے اور «<a href=634> نیک </a>» عمل کرے اللہ اسے ایسی جنتوں میں «<a href=313> داخل </a>» کرے گا «<a href=236> جن </a>» کے «<a href=633> نیچے </a>» نہریں بہہ رہی ہیں یہ ان میں «<a href=652> ہمیشہ </a>» رہیں گے  ،  اللہ نے ایسے شخص کے لئے بہت اچھارزق «<a href=213> تیار </a>» رکھا ہے"
  76,7,"اللہ وہ ہے جس نے سات «<a href=10> آسمان </a>» بنائے اور انہی کی مانند «<a href=379> زمین </a>» بھی ،  ان  ( آسما نو ں اور «<a href=379> زمین </a>» )  کے «<a href=321> درمیان </a>» اللہ کاحکم نازل ہوتا رہتا ہے تاکہ تم جان لوکہ اللہ یقینا ہرچیز پر قادر ہے اور یہ کہ اللہ اپنے علم کے ذریعے ہر چیز کو گھیرے ہوئے ہے"
  76,8,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  76,9,"اے نبی!آپ اس چیز کو کیوں «<a href=284> حرام </a>» بناتے ہیں جسے اللہ نے آپ کے لئے حلا ل کیا ہے ،  کیا آپ اپنی بیویوں کی خوشی چاہتے ہیں اور اللہ بخشنے والارحم کرنے والا ہے"
  76,10,"اللہ نے  تمہار ے  لئے تمہاری قسموں کاکفارہ اداکرنے کی «<a href=28> اجازت </a>» دید ی ہے  ( یعنی کفارہ ادا کر کے اس «<a href=481> کام </a>» کو کرنے کی «<a href=28> اجازت </a>» دید ی ہے جسے نہ کرنے کی «<a href=472> قسم </a>» کھائی ہو )  اللہ تمہارا «<a href=577> مدد </a>» گار ہے اور وہ سب کچھ جاننے والا ،  حکمت والا ہے"
  76,11,"جب نبی نے اپنی کسی «<a href=130> بیوی </a>» سے ایک راز کی «<a href=71> بات </a>» کہی اس «<a href=130> بیوی </a>» نے وہ «<a href=71> بات </a>»  ( آگے )  بتلادی اور یہ معاملہ اللہ تعالیٰ نے نبی پر  ظا ہر کردیااب نبی نے  ( اس «<a href=130> بیوی </a>» کو  )  کچھ «<a href=71> بات </a>» توجتلادی اور کچھ نہ جتلائی پھر جب نبی نے اسے بتلایاتووہ پوچھنے لگی کہ’’آپکو اس کی کس نے خبردی؟  ( نبی نے )  کہا: مجھے اس اللہ نے بتایا ہےجو ہرچیزکاجاننے والا اور پوری خبررکھنے والا ہے"
  76,12,"( اے نبی کی دونوں بیویو )  اگرتم دونوں اللہ کے حضور توبہ کرتی ہو  ( توبہترہے )  یقیناتمہارے «<a href=324> دل </a>» حق سے ہٹ گئے ہیں اور اگرتم نبی کے خلاف محاظ آرائی کروگی تواللہ ان کا «<a href=577> مدد </a>» گار ہے اور جبرائیل اور «<a href=634> نیک </a>» مومنین  ( سب نبی کے )  مددگارہیں اور ان کے علاوہ فرشتے بھی ان کے «<a href=577> مدد </a>» گار ہیں"
  76,13,"اگرنبی تمہیں طلاق دے دیں تو «<a href=52> امید </a>» ہے کہ ان کارب  ( تمہارے بدلے )  انہیں تم سے «<a href=636> زیادہ </a>» اچھی بیویاں دے دے ،  جومسلمان ،  مومن ،  «<a href=40> اطاعت </a>» گزار ،  توبہ کرنے والیاں  ،  «<a href=439> عبادت </a>» گزار ،  اور روزہ دارہوں شادی شدہ ہوں یاکنواریاں ہوں"
  76,14,"اے ایمان والو! اپنے آپ کو اپنے اہل وعیال کو اس «<a href=12> آگ </a>» سے بچائو «<a href=236> جن </a>» کا «<a href=67> ایندھن </a>» آدمی اور «<a href=146> پتھر </a>» ہیں  ،  اس  ( «<a href=12> آگ </a>» )  پرسخت «<a href=324> دل </a>» اور بے رحم فرشتے «<a href=593> مقرر </a>» ہیں  ،  اللہ انہیں جو «<a href=288> حکم </a>» دے وہ اس کی «<a href=612> نافرمانی </a>» نہیں کرتے اور وہی کچھ کرتے ہیںجو انہیں «<a href=288> حکم </a>» دیا جاتا ہے"
  76,15,"( اس «<a href=326> دن </a>» اللہ کافروں سے فرمائے گا )  اے کافرو!آج بہانے مت بنائوتمہیں ویسابدلہ دیاجائے گاجیسے تم عمل کرتے رہے"
  76,16,"اے ایمان والو!اللہ کے حضورصدق «<a href=324> دل </a>» سے توبہ کروامیدہے کہ تمہارا رب تم سے تمہاری برائیاں دورکردے اور تمہیں ایسی جنتوں میں «<a href=313> داخل </a>» کرے «<a href=236> جن </a>» کے «<a href=633> نیچے </a>» نہریں بہہ رہی ہیں ا س «<a href=326> دن </a>» اللہ نبی کو اوران لوگوں کو جوا س کے ساتھ ایمان لائے ہیں رسوانہیں کرے گاان کانوران کے آگے اور دائیں دوڑرہاہوگاوہ کہیں گے:’’اے ہمارے رب ہمارے لئے ہمارا نور پورا کردے اور ہمیں بخش دے یقینا تو  ہر چیز پر قادر ہے"
  76,17,"اے نبی!کافروں اور منافقوں سے جہادکرواوران پر «<a href=392> سختی </a>» کرو ،  ان کی «<a href=156> پناہ </a>» گاہ جہنم ہےجو بہت براٹھکانہ ہے"
  76,18,"اللہ تعالیٰ کافروں کے لئے نوح اور لوط کی بیویوں کی مثال «<a href=126> بیان </a>» کرتا ہے وہ دونوں ہمارے بندوں میں سے دونیک بندوں کے «<a href=625> نکاح </a>» میں تھیں مگر انہوں نے اپنے شوہروں سے «<a href=311> خیانت </a>» کی تووہ اللہ کے مقابلے میں ان دونوں کے کچھ «<a href=481> کام </a>» نہ آسکے اور ان سے کہاجائے گاکہ تم دونوں  ( عورتیں  )  «<a href=12> آگ </a>» میں «<a href=313> داخل </a>» ہونے والوں کے ساتھ «<a href=313> داخل </a>» ہو جائو"
  76,19,"نیز اللہ تعالیٰ ایمان والوں کے لئے فرعون کی «<a href=130> بیوی </a>» کی مثال «<a href=181> پیش </a>» کرتا ہے جب اس نے دعاکی کہ اے میرے رب میرے لئے اپنے «<a href=141> پاس </a>» «<a href=237> جنت </a>» میں ایک گھربنادے اور مجھے فرعون اور اس کے عمل سے «<a href=616> نجات </a>» دے اور ان ظالموں سے بھی «<a href=616> نجات </a>» دے‘‘"
  76,20,"اور مریم بنت عمران کی  ( بھی مثال ہے )  جس نے اپنی «<a href=417> شرم گاہ </a>» کی «<a href=286> حفاظت </a>» کی پھرہم نے اس کے «<a href=57> اندر </a>» اپنی روح «<a href=171> پھونک </a>» دی اور اس  ( مریم )  نے اپنے رب کی شریعت کی اور  اس کی کتابوں کی تصدیق کی اور وہ «<a href=40> اطاعت </a>» گزار تھی"
  76,21,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  76,22,"بابرکت ہے وہ ذات جس کے «<a href=640> ہاتھ </a>» میں  ( کائنات کی )  سلطنت ہے اور وہ ہرچیزپرقادر ہے"
  76,23,"جس نے موت وحیات کو اسلئے «<a href=180> پیدا </a>» کیا  ہے کہ تمہیں آزمائے کہ تم میں سے کون اچھے عمل کرتا ہے اور وہ ہر چیزپرغالب ہے اور بخش دینے والا ہے"
  76,24,"اسی نے سات «<a href=10> آسمان </a>» تہہ بہ تہہ پیداکئے تم رحمن کی «<a href=180> پیدا </a>» کردہ چیزوں میں کوئی بے ربطی نہ دیکھوگے ذرا  ( «<a href=10> آسمان </a>» کی طرف )  دوبارہ دیکھو ،  کیا تمہیں اس میں کوئی «<a href=422> شگاف </a>» نظرآتا ہے؟"
  76,25,"پھر اسے بار بار دیکھو ،  تمہاری «<a href=627> نگاہ </a>» تھک کرناکام پلٹ آئیگی"