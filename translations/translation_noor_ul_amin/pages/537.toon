quran[23]{c,v,t,f}:
 56,77,"اور رات کو اور سجدے کے بعدبھی اس کی تسبیح کیجئے"
 56,78,"اور سنو! جس دن پکارنے والا قریب ہی سے پکارے گا"
 56,79,"سب لوگ اس زوردارآواز کو ٹھیک ٹھیک سُن لیں گے یہی ( زمین سے دوبارہ ) نکلنے کادن ہوگا"
 56,80,"بلا شبہ ہم ہی زندہ کرتے اور مارتے ہیں اور سب کو ہماری طرف ہی لوٹ کرآنا ہے"
 56,81,"جس دن زمین ان پر سے پھٹ جائے گی اور لوگ قبروں سے نکل کرتیزی کے ساتھ دوڑنے لگیں گے اور اس طرح اکٹھا کرنا ہمارے لئے آ سان ہے"
 56,82,"جویہ کہہ رہے ہیں ہم اسے خوب جانتے ہیں آپ جبرتوکر نہیں سکتے لہٰذاآپ قرآن کے ذریعے اس کو نصیحت کیجیےجو میرے عذاب کے وعدہ سے ڈرتا ہے"
 56,83,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 56,84,"ان ہوائوں کی قسم جو گرداڑاتی ہیں"
 56,85,"ان بادلوں کی قسم جو بارش کاپانی اٹھائے پھرتی ہیں"
 56,86,"ان کشتیوں کی قسم جو سمندرمیں آرام کیساتھ چلتی رہتی ہیں"
 56,87,"ان فرشتوں کی قسم جو اللہ کے حکم سے مختلف کام کرتے ہیں"
 56,88,"بیشک جسکاتم سے وعدہ کیا جاتا ہے وہ سچا ہے"
 56,89,"بیشک روز جزا ضرور واقع ہوگی"
 56,90,"راستوں والے آسمان کی قسم"
 56,91,"تم حقیقت کے خلاف باتوں میں پڑگئے ہو"
 56,92,"اس دن پر ایمان لانے سے وہی شخص پھیر دیاجاتا ہےجو خیرکی توفیق سے پھیردیاگیا ہے"
 56,93,"بے سندباتیں کرنے والے غارت کردیئے گئے"
 56,94,"جوغفلت میں ہیں اور بھولے ہوئے ہیں"
 56,95,"پوچھتے ہیں جزا و سزاکادن کب ہوگا؟"
 56,96,"ہاں یہ وہ دن ہے جس دن یہ آگ پر تپائے جائینگے"
 57,1,"اپنی شرارت کا ذائقہ چکھو یہی وہ عذاب ہے جس کے لئے تم جلدی مچاتے تھے"
 57,2,"بلاشبہ پرہیزگار ( اس دن ) باغوں اور چشموں میں ہوں گے"
 57,3,"جوکچھ ان کارب انہیں دے گاوہ لے لیں گے بیشک وہ لوگ اس سے پہلے ( دنیا میں ) نیک کام کرنے والے تھے"