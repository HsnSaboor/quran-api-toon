quran[23]{c,v,t,f}:
  56,77,"اور «<a href=356> رات </a>» کو اور سجدے کے بعدبھی اس کی تسبیح کیجئے"
  56,78,"اور سنو! جس «<a href=326> دن </a>» پکارنے والا قریب ہی سے پکارے گا"
  56,79,"سب لوگ اس زوردارآواز کو ٹھیک ٹھیک سُن لیں گے یہی  ( «<a href=379> زمین </a>» سے دوبارہ  )  نکلنے کادن ہوگا"
  56,80,"بلا شبہ ہم ہی «<a href=381> زندہ </a>» کرتے اور مارتے ہیں اور سب کو ہماری طرف ہی لوٹ کرآنا ہے"
  56,81,"جس «<a href=326> دن </a>» «<a href=379> زمین </a>» ان پر سے پھٹ جائے گی اور لوگ قبروں سے نکل کرتیزی کے ساتھ دوڑنے لگیں گے اور اس طرح «<a href=48> اکٹھا </a>» کرنا ہمارے لئے آ سان ہے"
  56,82,"جویہ کہہ رہے ہیں ہم اسے خوب جانتے ہیں آپ جبرتوکر نہیں سکتے لہٰذاآپ «<a href=470> قرآن </a>» کے ذریعے اس کو «<a href=622> نصیحت </a>» کیجیےجو میرے «<a href=440> عذاب </a>» کے وعدہ سے ڈرتا ہے"
  56,83,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  56,84,"ان ہوائوں کی «<a href=472> قسم </a>» جو گرداڑاتی ہیں"
  56,85,"ان بادلوں کی «<a href=472> قسم </a>» جو «<a href=75> بارش </a>» کاپانی اٹھائے پھرتی ہیں"
  56,86,"ان کشتیوں کی «<a href=472> قسم </a>» جو سمندرمیں «<a href=4> آرام </a>» کیساتھ چلتی رہتی ہیں"
  56,87,"ان فرشتوں کی «<a href=472> قسم </a>» جو اللہ کے «<a href=288> حکم </a>» سے «<a href=575> مختلف </a>» «<a href=481> کام </a>» کرتے ہیں"
  56,88,"بیشک جسکاتم سے وعدہ کیا جاتا ہے وہ سچا ہے"
  56,89,"بیشک روز جزا ضرور واقع ہوگی"
  56,90,"راستوں والے «<a href=10> آسمان </a>» کی قسم"
  56,91,"تم حقیقت کے خلاف باتوں میں پڑگئے ہو"
  56,92,"اس «<a href=326> دن </a>» پر ایمان لانے سے وہی شخص پھیر دیاجاتا ہےجو خیرکی «<a href=208> توفیق </a>» سے پھیردیاگیا ہے"
  56,93,"بے سندباتیں کرنے والے غارت کردیئے گئے"
  56,94,"جوغفلت میں ہیں اور بھولے ہوئے ہیں"
  56,95,"پوچھتے ہیں جزا و سزاکادن کب ہوگا؟"
  56,96,"ہاں یہ وہ «<a href=326> دن </a>» ہے جس «<a href=326> دن </a>» یہ «<a href=12> آگ </a>» پر تپائے جائینگے"
  57,1,"اپنی شرارت کا ذائقہ چکھو یہی وہ «<a href=440> عذاب </a>» ہے جس کے لئے تم «<a href=234> جلدی </a>» مچاتے تھے"
  57,2,"بلاشبہ پرہیزگار  ( اس «<a href=326> دن </a>» )  باغوں اور چشموں میں ہوں گے"
  57,3,"جوکچھ ان کارب انہیں دے گاوہ لے لیں گے بیشک وہ لوگ اس سے «<a href=162> پہلے </a>»  ( «<a href=327> دنیا </a>» میں  )  «<a href=634> نیک </a>» «<a href=481> کام </a>» کرنے والے تھے"