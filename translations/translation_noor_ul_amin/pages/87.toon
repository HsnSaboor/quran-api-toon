quran[8]{c,v,t,f}:
  4,52,"رات کی «<a href=472> قسم </a>» جب وہ چھاجائے"
  4,53,"اور «<a href=326> دن </a>» کی جبکہ وہ روشن ہو"
  4,54,"اوراس ذات کی جس نے نراور مادہ پیداکئے"
  4,55,"بیشک تمہاری کو ششیں «<a href=575> مختلف </a>» ہوتی ہیں"
  4,56,"پس جس نے  ( اللہ کی راہ میں اپنامال )  دیا اور تقویٰ «<a href=34> اختیار </a>» کیا"
  4,57,"اور بھلی باتوں کی تصدیق کی"
  4,58,"تو ہم اسے «<a href=9> آسان </a>» راہ پر چلنے کی سہولت دینگے"
  4,59,"اور جس نے کنجوسی کی اور  ( اللہ سے )  بے پر واہ بنارہا"