quran[8]{c,v,t,f}:
 4,52,"رات کی قسم جب وہ چھاجائے"
 4,53,"اور دن کی جبکہ وہ روشن ہو"
 4,54,"اوراس ذات کی جس نے نراور مادہ پیداکئے"
 4,55,"بیشک تمہاری کو ششیں مختلف ہوتی ہیں"
 4,56,"پس جس نے ( اللہ کی راہ میں اپنامال ) دیا اور تقویٰ اختیار کیا"
 4,57,"اور بھلی باتوں کی تصدیق کی"
 4,58,"تو ہم اسے آسان راہ پر چلنے کی سہولت دینگے"
 4,59,"اور جس نے کنجوسی کی اور ( اللہ سے ) بے پر واہ بنارہا"