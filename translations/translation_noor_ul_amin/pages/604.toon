quran[15]{c,v,t,f}:
 112,1,"پھر ( انہیں ) کہا جائے گا: یہی ( جہنم ) وہ چیز ہے جسے تم جھٹلاتے تھے"
 112,2,"ہرگز نہیں نیک لوگوں کا اعمال نامہ بلند پایہ لوگوں کے دفتر میں ہے"
 112,3,"اورآپ کیا جانیں کہ بلندپایہ لوگوں کا دفتر کیا ہے"
 112,4,"وہ ایک کتاب ہے لکھی ہوئی"
 113,1,"جسکے پاس مقرب ( فرشتے ) حاضررہتے ہیں"
 113,2,"بلاشبہ نیک لوگ ( جنت کی ) نعمتوں میں ہوں گے"
 113,3,"تختوں پر بیٹھے نظارہ کرینگے"
 113,4,"آپ ان کے چہروں پر خوشحالی کی رونق معلوم کرینگے"
 113,5,"انہیں سربمہر خالص شراب پلائی جائے گی"
 114,1,"جس پر مشک کی مہرہوگی ، پس سبقت کرنے والوں کو ( ان نعمتوں کے حصول کے لئے ) سبقت کرنی چاہیے"
 114,2,"اوراس شراب میں تسنیم کی آ میزش ہوگی"
 114,3,"یہ ایک چشمہ ہے جس سے مقرب لوگ پئیں گے"
 114,4,"مجرم لوگ ( دنیا میں ) ایمانداروں پر ہنساکرتے تھے"
 114,5,"اور جب ان کے پاس سے گزرتے تو ایک دوسرے کو آنکھیں مار کر اشارے کرتے"
 114,6,"اور اپنے گھروں کو لوٹتے توان کامزاق اڑاتے ہوئے واپس جاتے"