quran[11]{c,v,t,f}:
  40,67,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  40,68,"ان فرشتوں کی «<a href=472> قسم </a>» جو  ( آسمانوں میں  )  صفیں باندھے ہوئے ہیں"
  40,69,"پھران کی جو  ( بادلوں کو  )  زبردست ڈانٹ کے ذریعے ہانکتے ہیں"
  40,70,"پھر ان فرشتوں کی «<a href=472> قسم </a>» جو ذکرِ اللہ کی تلاوت کرتے ہیں"
  40,71,"بلاشبہ تمہارا معبود ایک ہی ہے"
  40,72,"جوآسمانوں اور «<a href=379> زمین </a>» اور ان کے «<a href=321> درمیان </a>» کی ہرچیزکارب ہے اور دنیاکے ان تمام مقامات کارب ہے جہاں سے سورج نکلتا ہے"
  40,73,"بلاشبہ ہم نے «<a href=10> آسمان </a>» ِدنیاکو ستاروں کے ذریعے «<a href=306> خوبصورت </a>» بنایا ہے"
  40,74,"اوراس  ( «<a href=10> آسمان </a>» اور دنیاکو )  ہرطرف سے سرکش شیطان سے محفوظ بنادیا ہے"
  40,75,"وہ شیاطین «<a href=438> عالم </a>» بالا کی باتیں سُن ہی نہیں سکتے اور  ( اگر یہ باتیں «<a href=402> سننا </a>» چاہیں تو )  ہر طرف سے ان پر  ( شہاب )  پھینکے جاتے ہیں"
  40,76,"تاکہ وہ بھاگ کھڑے ہوں اور ان کے لئے دائمی «<a href=440> عذاب </a>» ہے"
  40,77,"تاہم اگرکوئی  ( شیطان )  «<a href=71> بات </a>» لے اڑے توایک تیزشعلہ اس کے «<a href=179> پیچھے </a>» لگ جاتا ہے"