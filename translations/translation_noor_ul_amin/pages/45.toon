quran[5]{c,v,t,f}:
  2,265,"لہٰذاآپ «<a href=426> صبر </a>» کیجئے اللہ کاوعدہ سچاہے ،  ایسانہ ہوکہ جو لوگ  ( اللہ پر  )  «<a href=658> یقین </a>» نہیں کرتے وہ آپ کو «<a href=647> ہلکا </a>» بنا دیں  ( یعنی آپ میں اعتمادکی کمی کاباعث بنیں  )"
  2,266,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  2,267,"الم"
  2,268,"یہ اس «<a href=485> کتاب </a>» کی آیتیں ہیںجو حکمتوں کاخزانہ ہے"
  2,269,"جونیکی کرنے والوں کے لئے «<a href=644> ہدایت </a>» اور رحمت ہیں"