quran[6]{c,v,t,f}:
  3,78,"اس «<a href=326> دن </a>» کچھ چہرے «<a href=264> چمک </a>» دمک رہے ہوں گے"
  3,79,"ہنستے ہوئے «<a href=308> خوش </a>» وخرم"
  3,80,"اور کچھ چہروں پر اس «<a href=326> دن </a>» غبارپڑی ہوگی"
  3,81,"اور «<a href=407> سیاہی </a>» چھا رہی ہوگی"
  3,82,"یہ وہ لوگ ہوں گےجو کافراور بدکار ہیں"
  3,83,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"