quran[6]{c,v,t,f}:
  60,6,"اور «<a href=356> رات </a>» کو بھی اس کی تسبیح کیجئے اور ستاروں کے غروب ہونے کے بعدبھی"
  60,7,"شروع اللہ کے «<a href=614> نام </a>» سے جو بڑا «<a href=600> مہربان </a>» اور نہایت رحم کرنے والا ہے"
  60,8,"ستارے کی «<a href=472> قسم </a>» جب وہ گرتا ہے"
  60,9,"تمہارے صاحب  ( یعنی رسول اﷲ )  نہ توگمراہ ہوئے اور نہ بھٹکے ہیں"
  60,10,"وہ نہ ہی اپنی «<a href=305> خواہش </a>» سے کوئی «<a href=71> بات </a>» کہتے ہیں"
  60,11,"جوکہتے ہیں وحی ہوتی ہے ان پر نازل کردہ"