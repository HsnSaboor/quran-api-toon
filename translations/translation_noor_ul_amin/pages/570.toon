quran[15]{c,v,t,f}:
 70,40,"اوراگرتم سمجھوتویقینایہ ایک بہت بڑی قسم ہے"
 70,41,"کہ یہ قرآن بلاشبہ بلندپایہ ( کتاب ) ہے"
 70,42,"جولوح محفوظ میں درج ہے"
 70,43,"جسے پاکیزہ لوگوں ( یعنی فرشتوں ) کے سواکوئی نہیں چھوسکتا ( یعنی شیطان وہاں تک نہیں پہنچ سکتے )"
 70,44,".یہ رب العالمین کی طرف سے نازل ہوا ہے"
 71,1,"کیا تم اس کلامِ الٰہی کے ( احکامات کے ) سلسلے میں ( کافروں کے ساتھ ) نرم رویہ اختیار کرتے ہو ( اسلئے کہ وہ تمہارے دین میں داخل ہوجائیں )"
 71,2,"تم نے اپنی روزی یہ بنالی ہے کہ تم قرآن کو جھٹلاتے ہو"
 71,3,"پس جب کسی کی روح حلق تک پہنچ جاتی ہے"
 71,4,"اوراس وقت تم اسے ( مجبوربن کر ) دیکھ رہے ہوتے ہو"
 71,5,"اور ہم اس وقت تم سے بھی زیادہ اس کے قریب ہوتے ہیں لیکن تم دیکھ نہیں سکتے"
 71,6,"پھر اگرتم کسی کے تابعِ فرمان نہیں ہو"
 71,7,"اوراگرتم ( دعوے میں ) سچے ہوتواس روح کو واپس ( اس انسان میں ) کیوں نہیں لے آتے"
 71,8,"ہاں اگروہ مرنے والا ( اللہ کے ) مقرب بندوں میں سے ہو"
 71,9,"تواس کے لئے آرام اور عمدہ رزق اور نعمتوں والی جنت ہوگی"
 71,10,"اوراگروہ دائیں ہاتھ والوں میں سے ہوگا"