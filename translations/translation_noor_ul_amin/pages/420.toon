quran[7]{c,v,t,f}:
 33,16,"بیشک آپکارب سب پر غالب اور رحم کرنے والا ہے"
 33,17,"بلاشبہ یہ ( قرآن ) رب العالمین کانازل کردہ ہے"
 33,18,"جسے امانت دارفرشتہ ( یعنی جبرائیل ) لے کرآپ کے دل پر نازل ہوا"
 33,19,"تاکہ آپ ڈرا نے والوں میں شامل ہوجائیں"
 33,20,"جوکہ صاف عربی زبان ہے"
 33,21,"اور یقینااسکاذکراگلے نبیوں کی کتابوں میں موجود ہے"
 33,22,"کیا ان ( اہل مکہ ) کے لئے یہ نشانی ( کافی ) نہیں کہ اس ( قرآن ) کو بنی اسرائیل کے علماء بھی جانتے ہیں"