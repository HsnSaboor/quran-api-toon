quran[4]{c,v,t,f}:
  2,58,"اورقسم ہے «<a href=356> رات </a>» کی جب «<a href=186> تاریکی </a>» گہری ہوجاتی ہے"
  2,59,"( اے نبی )  آپ کے رب نے نہ آپ کو چھوڑا اور نہ ناراض ہوا"
  2,60,"اور یقیناآخرت آپ کے لئے دنیاسے بہترہے"
  2,61,"اورآپ کارب جلدہی آ پ کو اتناکچھ عطاکردے گاکہ آپ «<a href=308> خوش </a>» ہوجائینگے"