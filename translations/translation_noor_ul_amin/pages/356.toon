quran[10]{c,v,t,f}:
 24,44,"اور میری زبان سے گرہ کھول دے"
 24,45,"تاکہ وہ لوگ میری بات سمجھ سکیں"
 24,46,"اور میرے خاندان سے میرا مددگا ر مقرر کر دے"
 24,47,"ہارون میرابھائی ہے"
 24,48,"اس کے ذریعے میری قوت کو بڑھادے"
 24,49,"اور میری دعوتی مہم میں اسے میرے ساتھ شریک کردے"
 24,50,"تاکہ ہم تیری خوب تسبیح بیان کریں"
 24,51,"اور خوب تیراچرچاکریں"
 24,52,"بلاشبہ توہمیں دیکھ رہا ہے"
 24,53,"اللہ تعالیٰ نے فرمایا: ’’اے موسیٰ !جو کچھ تم نے مانگاوہ تمہیں دیا جاتا ہے"