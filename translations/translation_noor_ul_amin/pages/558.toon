quran[5]{c,v,t,f}:
 65,1,"اور غفلت میں مبتلا ہنس کھیل رہے ہو"
 65,2,"پس اللہ کے آگے سجدہ کرو اور اسی کی عبادت کرو"
 65,3,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 65,4,"قیامت قریب آگئی اور چاندپھٹ ( کردوٹکڑے ہو ) گیا"
 65,5,"اور یہ ( کفار ) کوئی معجزہ ( یعنی چاندکے دوٹکڑے ہونے کا ) دیکھ لیں توبھی منہ پھیرلیتے ہیں اور کہتے ہیں کہ’’یہ ایک جادو ( جومحمد نے کیا ) ہےجو پہلے سے چلاآ رہا ہے‘‘"