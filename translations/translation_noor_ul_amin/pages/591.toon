quran[32]{c,v,t,f}:
 86,1,"اسلئے جب ہم اس کی قرأ ت پوری کرلیں توپھر اسی طرح آپ پڑھ لیاکریں"
 86,2,"پھراس کامطلب سمجھادینابھی ہمارے ذمہ ہے"
 86,3,"ہرگز نہیں بلکہ تم لوگ جلد حاصل ہونے والی چیز ( دنیا ) چاہتے ہو"
 86,4,"اورآخرت کو چھوڑدیتے ہو"
 86,5,"اس دن کئی چہرے تروتازہ ہوں گے"
 86,6,"اپنے رب کو دیکھ رہے ہوں گے"
 86,7,"اور کئی چہرے پر یشان ہوں گے"
 86,8,"انہیں یقین ہوجائے گاکہ انہیں کسی بھاری مصیبت میں گرفتار کیا جائے گا"
 86,9,"ہرگز نہیں ، جب ( جان ) ہنسلی تک پہنچ جاتی ہے"
 86,10,"اور کہاجائے گاکہ ہے کوئی جھاڑپھونک کرنے والا ؟"
 86,11,"اور مرنے والوں کو یقین ہو جاتا ہے کہ یہ اس کی جدائی کاوقت ہے"
 86,12,"اورایک پنڈلی دوسری سے جڑجاتی ہے"
 86,13,"اس دن تیرے رب کی طرف تیری روانگی ہوتی ہے"
 86,14,"اس دن نہ تو ( اس نے قرآن اور رسول کی ) تصدیق کی اور نہ نماز ادا کی"
 86,15,"بلکہ ( وحی کو الٹا ) جھٹلا دیا اور منہ موڑ لیا"
 86,16,"پھراکڑتا ہوا اپنے اہل خانہ کی طرف چل دیا"
 86,17,"افسوس ہے تجھ پر"
 87,1,"پھرافسوس ہے تجھ پر"
 87,2,"کیا انسان نے یہ سمجھ رکھا ہے کہ اسے بے کار چھوڑ دیاجائے گا ( بلکہ اسے اللہ نے اپنی بندگی اور اطاعت کے لئے پیدا کیا ہے )"
 87,3,"کیا وہ ایک نطفہ نہ تھاجو ( ماں کے رحم میں ) ٹپکایا گیا تھا؟"
 87,4,"پھر وہ لوتھڑا ہوگیا ، پھراللہ نے اسے ٹھیک ( انسان ) بنادیا"
 87,5,"پھراس سے مرد اور عورت دوقسمیں بنادیں"
 87,6,"کیا وہ اس بات پر قادرنہیں کہ پھرسے مردوں کو زندہ کردے"
 87,7,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 87,8,"انسان پر ( لامتناہی ) زمانہ سے کبھی ایک وقت بھی ایسانہیں آیاجب وہ کوئی قابل ذکر چیز تھا؟"
 87,9,"ہم نے انسان کو ( مرد اور عورت کے ) مخلوط نطفہ سے پیدا کیا تاکہ ہم اسے آزمائیں پھراسے سننے اور دیکھنے والا بنادیا"
 87,10,"بیشک ہم نے راہ راست کی طرف اس کی راہنمائی کردی ہے ، چاہےتووہ شکرگزاربنے اور چاہےنہ شکری کرے"
 87,11,"بلاشبہ ہم نے کافروں کے لئے زنجیریں ، طوق اور بھڑکتی آگ تیاررکھی ہے"
 87,12,"بلاشبہ نیک لوگ ( جنت میں ٹھنڈی ) شراب کے ایسے جام پئیں گے جس میں کافورکی آمیزش ہو گی"
 87,13,"وہ ایک چشمہ ہے جس میں اللہ کے بندے پئیں گے اور جہاں چاہیں گے اس کی شاخیں نکال لیں گے"
 87,14,"جواپنی نذریں پوری کرتے ہیں اور اس ( قیامت کے ) دن سے ڈرتے ہیں جس کی آفت ہرسوُپھیلی ہوگی"
 87,15,"اوراپنے لئے کھانے کی طلب ہونے کے باوجود مسکین ، یتیم اور قیدی کو کھاناکھلادیتے ہیں"