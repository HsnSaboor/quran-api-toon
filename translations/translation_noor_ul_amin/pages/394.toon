quran[7]{c,v,t,f}:
  28,71,"اس «<a href=326> دن </a>» اہل «<a href=237> جنت </a>» کاہی ٹھکانہ اور دوپہرکو «<a href=4> آرام </a>» کرنے کامقام بہتر ہوگا"
  28,72,"اس «<a href=326> دن </a>» «<a href=10> آسمان </a>» پھٹ کرایک «<a href=73> بادل </a>» نمودار ہوگا اور گروہ درگروہ فرشتے اتارے جائینگے"
  28,73,"اس «<a href=326> دن </a>» حقیقی «<a href=72> بادشاہی </a>» رحمن ہی کی ہوگی اور یہ «<a href=326> دن </a>» کافروں کے لئے بڑا «<a href=391> سخت </a>» «<a href=326> دن </a>» ہوگا"
  28,74,"اس «<a href=326> دن </a>» ظالم اپنے ہاتھوں کو کاٹے گا اور کہے گا:کاش!میں رسول کی راہ پر چلا ہوتا"
  28,75,"ہائے افسوس!کاش میں نے فلاں شخص کو اپنادوست نہ بنایاہوتا"
  28,76,"اس نے تو میرے «<a href=141> پاس </a>» «<a href=622> نصیحت </a>» آ جانے کے بعد مجھے بہکادیا اور شیطان توانسان کو مصیبت پڑنے پر چھوڑجانے والا ہے"
  28,77,"اور رسول کہیں گے:’’میرے رب! میری قوم کے یہی لوگ ہیں جنھوں نے اس «<a href=470> قرآن </a>» کو بالکل چھوڑدیاتھا"