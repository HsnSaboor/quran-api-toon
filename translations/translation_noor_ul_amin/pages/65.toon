quran[6]{c,v,t,f}:
  3,116,"برجوں والے «<a href=10> آسمان </a>» کی قسم"
  3,117,"اوراس «<a href=326> دن </a>» کی جس کاوعدہ کیا گیا ہے"
  3,118,"اور دیکھنے والے کی اور دیکھی جانے والی چیزکی"
  3,119,"کہ خندقوں والے «<a href=646> ہلاک </a>» ہوگئے"
  3,120,"وہ ایک «<a href=12> آگ </a>» تھی «<a href=67> ایندھن </a>» والی"
  3,121,"جسکے کنارے وہ  ( کافربیٹھے اہل ایمان کے جلنے کاتماشہ )  دیکھ رہے تھے"