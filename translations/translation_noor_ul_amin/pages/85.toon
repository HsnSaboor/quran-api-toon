quran[7]{c,v,t,f}:
  4,38,"اور «<a href=326> دن </a>» کی جب وہ  ( سورج کو  )  نمایاں کردے"
  4,39,"اور «<a href=356> رات </a>» کی «<a href=472> قسم </a>» جب وہ  ( سورج کو  )  چھپالیتی ہے"
  4,40,"اور «<a href=10> آسمان </a>» کی اور اس ذات کی «<a href=472> قسم </a>» جس نے اسے بنایا"
  4,41,"اور «<a href=379> زمین </a>» کی اور اس ذات کی «<a href=472> قسم </a>» جس نے اسے بچھایا"
  4,42,"اور نفس کی اور اس ذات کی «<a href=472> قسم </a>» جس نے اسے «<a href=320> درست </a>» کرکے ٹھیک بنایا"
  4,43,"پھرسمجھ دی اس کو «<a href=97> برائی </a>» کی اور «<a href=486> بچ </a>» کرچلنے کی"
  4,44,"یقیناوہ شخص «<a href=482> کامیاب </a>» ہوگاجس نے اپنے نفس کو گناہوں سے «<a href=142> پاک </a>» کیا"