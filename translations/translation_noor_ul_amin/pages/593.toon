quran[23]{c,v,t,f}:
  89,1,"بیشک جس  ( «<a href=476> قیامت </a>» )  کاتم سے وعدہ کیا جاتا ہے وہ ضرورواقع ہوگی"
  89,2,"جب ستارے بے نورہوجائیں گے"
  89,3,"اور «<a href=10> آسمان </a>» پھاڑدیا جائے گا"
  89,4,"اور «<a href=160> پہاڑ </a>» «<a href=268> ریزہ </a>» ریزہ کرکے اڑادیئے جائیں گے"
  89,5,"اور رسولوں  ( کی حاضری )  کاوقت   آ پہنچے گا"
  89,6,"بھلاکس «<a href=326> دن </a>» کے لئے  ( ان امور میں  )  تاخیر کی گئی"
  89,7,"فیصلے کے «<a href=326> دن </a>» کے لئے"
  89,8,"اور آپ کیا جانیں کہ «<a href=461> فیصلہ </a>» کادن کیا ہے؟"
  89,9,"اس «<a href=326> دن </a>» جھٹلانے والوں کے لئے تباہی ہے"
  89,10,"کیا ہم نے «<a href=162> پہلے </a>» لوگوں کو «<a href=646> ہلاک </a>» نہیں کرڈالا؟"
  89,11,"پھر انہی کے «<a href=179> پیچھے </a>» بعدوالوں کو چلتا کریں گے"
  89,12,"ہم مجرموں سے ایساہی برتائو کیا کرتے ہیں"
  89,13,"اس «<a href=326> دن </a>» جھٹلا نے والوں کے لئے تباہی ہے"
  89,14,"کیا ہم نے تمہیں حقیرپانی سے «<a href=180> پیدا </a>» نہیں کیا ؟"
  89,15,"پھراسے ایک محفوظ «<a href=232> جگہ </a>»  ( یعنی «<a href=565> ماں </a>» کے رحم میں  )  میں ٹھہرائے رکھا"
  89,16,"ایک معین «<a href=639> وقت </a>» تک"
  89,17,"پھرہم نے  ( اس کے اعضاء کا )  مناسب «<a href=56> اندازہ </a>» لگایا ،  توہم کیا ہی اچھے «<a href=56> اندازہ </a>» کر نے والے ہیں"
  89,18,"اس «<a href=326> دن </a>» جھٹلانے والوں کے لئے تباہی ہے"
  89,19,"کیا ہم نے «<a href=379> زمین </a>» کو سمیٹ کر رکھنے والی نہیں بنادیا؟"
  89,20,"زندوں کو بھی اور مردوں کو بھی ؟"
  89,21,"اوراس میں بلندوبالا «<a href=160> پہاڑ </a>» جما دئیے ،  اور تمہیں میٹھاپانی پلایا"
  89,22,"اس «<a href=326> دن </a>» جھٹلانے والوں کے لئے تباہی ہے"
  89,23,"( انہیں کہا جائے گا )  چلو اسی  ( جہنم )  کی طرف جسے تم جھٹلا دیاکرتے تھے"