quran[10]{c,v,t,f}:
  23,18,"البتہ جو ایمان لایا اور «<a href=634> نیک </a>» عمل کرے گاتواسے «<a href=31> اچھا </a>» «<a href=95> بدلہ </a>» ملے گااوراسے ہم اپنے «<a href=9> آسان </a>» «<a href=481> کام </a>» کرنے کو کہیں گے"
  23,19,"پھروہ «<a href=385> سامان </a>» لے کرایک اور راہ پر چل پڑا"
  23,20,"حتیٰ کہ وہ سورج نکلنے کی «<a href=232> جگہ </a>» جا پہنچا اسے لگاکہ سورج ایسی قوم پر طلوع ہورہا ہے کہ ان کے درمیا ن ہم نے کوئی آڑنہیں بنائی"
  23,21,"واقعہ ایساہی تھا اور ذوالقرنین کے حالات کی ہمیں خبرہے"
  23,22,"پھروہ ایک اور راہ پر «<a href=385> سامان </a>» لے کرچل پڑا"
  23,23,"یہاں تک کہ جب وہ دوبلندپہاڑوں کے «<a href=321> درمیان </a>» پہنچاتوان کے اندرونی «<a href=227> جانب </a>» ایسے لوگوں کو پایاجوکوئی «<a href=71> بات </a>» بھی نہیں سمجھتے تھے"
  23,24,"وہ کہنے لگے:’’اے ذوالقرنین !بیشک یاجوج اور ماجوج نے اس سرزمین میں «<a href=459> فساد </a>» مچارکھا ہے اگرہم آپ کو کچھ چندہ «<a href=48> اکٹھا </a>» کردیں تو کیا آ پ ہمارے اور ان کے «<a href=321> درمیان </a>» ایک «<a href=342> دیوار </a>» بنا دیں گے؟ ‘‘"
  23,25,"ذوالقرنین نے کہا :’’میرے رب نےجو مجھے «<a href=475> قوت </a>» دے رکھی ہے وہ بہت ہے تم بس جسمانی «<a href=429> طاقت </a>» سے میری «<a href=577> مدد </a>» کرو تو میں ان کے اور تمہارے «<a href=321> درمیان </a>» ایک موٹی اور «<a href=590> مضبوط </a>» دیواربنا دونگا"
  23,26,"مجھے لوہے کی چادریں لادو چنانچہ اس نے ان کو گھا ٹیوں کے «<a href=321> درمیان </a>» برابرکردیا توکہا ،  «<a href=12> آگ </a>» دہکائوحتیٰ کہ جب وہ آ گ بن گئیں توکہامیرے «<a href=141> پاس </a>» پگھلاہواتانبالائوتاکہ اس پر ڈال دوں ‘‘"
  23,27,"پھر یاجو ج اور ماجوج نہ تواس کے اوپر چڑھ سکے اور نہ ہی اس میں سوراخ بناس کے"