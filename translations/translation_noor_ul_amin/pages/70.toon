quran[4]{c,v,t,f}:
  3,154,"پس آپ «<a href=622> نصیحت </a>» کیجئے اگر «<a href=622> نصیحت </a>» نفع دے"
  3,155,"جو  ( آدمی اللہ سے )  ڈرتا ہے وہ «<a href=622> نصیحت </a>» «<a href=465> قبول </a>» کرلے گا"
  3,156,"اور بد بخت «<a href=51> الگ </a>» رہیگا"
  3,157,"اور بڑی «<a href=12> آگ </a>» میں «<a href=313> داخل </a>» ہوگا"