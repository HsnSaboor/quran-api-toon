quran[10]{c,v,t,f}:
 27,89,"اورجو لوگ اپنی بیویوں پر زناکی تہمت لگائیں اور ان کے اپنے سوا ان کے پاس کوئی گواہ نہ ہو تو ایساآدمی اللہ کی قسم کھا کر چار مرتبہ گواہی دے کہ وہ بیشک اپنی بات میں س چاہے"
 27,90,"اور پانچویں دفعہ یوں کہے کہ اگر وہ جھوٹا ہوتواس پر اللہ کی لعنت ہو"
 27,91,"اوراس عورت پر ( جس پر الزام ہے ) سے سزا یوں ٹل سکتی ہے کہ وہ چاردفعہ اللہ کی قسم کھاکرگواہی دے کــہـــــ اس کا خاوند جھوٹا ہے"
 27,92,"اور پانچویں دفعہ یوں کہے کہ اگراس کا خاوندسچاہوتومجھ پر اللہ کاغضب نازل ہو"
 27,93,"اور اگرتم پر اللہ کافضل اور اس کی رحمت نہ ہوتی ( تویہ معاملہ تم پر پیچیدہ بن جاتا ) توتم شدیدمشقت میں پڑجاتے اور بیشک اللہ توبہ قبول کرنے والا اور حکیم ہے"
 28,1,"بیشک جن لوگوں نے ( عائشہ پر ) تہمت لگائی ہے وہ تم میں سے ہی ایک ٹولہ ہے تم لوگ اس بہتان تراشی کو اپنے لئے برانہ سمجھوبلکہ اس میں تمہارے لئے خیرہے ، ان میں سے ہرآدمی کو اپنے کئے کے مطابق گناہ ہوگااوران میں سےجو اس تہمت کے بڑے حصہ کاذمہ داربنا اس کے لئے عذاب عظیم ہے"
 28,2,"جب تم نے یہ قصہ سناتومومن مردوں اور عورتوں نے اپنے ہی جیسے مومن مردوں اور عورتوں کے بارے میں اپنے دل میں اچھی بات کیوں نہ سوچی اور یوں کیوں نہ کہہ دیاکہ:’’یہ توصاف بہتان ہے‘‘"
 28,3,"پھریہ تہمت لگانے والے اس پر چارگواہ کیوں نہ لاس کے پھر جب یہ گواہ نہیں لاس کے تواللہ کے ہاں یہی جھوٹے ہیں"
 28,4,"اوراگرتم پر دنیااورآخرت میں اللہ کا فضل اور اس کی رحمت نہ ہوتی تواس بارے میں تمہاری چہ مہ گوئیوں کی وجہ سے ایک بڑاعذاب آ لیتا"
 28,5,"جب تم اپنی زبانوں سے اس بہتان کو اُچھالتے تھے اور اپنے منہ سے وہ کہہ رہے تھے جس کے متعلق تمہیں علم نہ تھا اور تم اسے معمولی سمجھ رہے تھے ، حالانکہ وہ اللہ کے ہاں بہت بڑی بات تھی"