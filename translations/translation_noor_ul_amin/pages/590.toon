quran[22]{c,v,t,f}:
 85,1,"ہر گز نہیں بلکہ ( اصل بات یہ ہے کہ یہ لوگ ) آخرت سے نہیں ڈرتے"
 85,2,"ہرگز نہیں ! یہ ( قرآن ) تو ایک نصیحت ہے"
 85,3,"اب جس کاجی چاہےاسے قبول کرے"
 85,4,"اور جب تک اللہ نہیں چاہےگاوہ نصیحت نہیں حاصل کرینگے ، وہی ہے جس سے ڈرنا چاہیےاور وہی ہے معاف کرنے والا"
 85,5,"شروع اللہ کے نام سے جو بڑا مہربان اور نہایت رحم کرنے والا ہے"
 85,6,"میں قیا مت کے دن کی قسم کھاتا ہوں"
 85,7,"اور میں ملامت کرنیوالے نفس کی قسم کھاتا ہوں ( کہ قیامت آکے رہے گی )"
 85,8,"کیا انسان سمجھتا ہے کہ ہم اس کی ہڈیاں اکٹھی نہ کر سکیں گے"
 85,9,"کیوں نہیں ہم تواس پر قادر ہیں کہ ( پھرسے ) اس کے انگلیوں کے پور پور تک درست بنائیں دیں"
 85,10,"بلکہ انسان یہ چاہتا ہے کہ وہ مزید بداعمالیاں کرتارہے"
 85,11,"پوچھتا ہے کہ قیامت کادن کب ہوگا؟"
 85,12,"تو ( اس کاجواب یہ ہے کہ ) جب آنکھیں چندھیاجائیں گی"
 85,13,"اور چاندبے نور ہوجائے گا"
 85,14,"اور سورج اور چاند ملا دئیے جائیں گے"
 85,15,"اس وقت انسان کہے گا کہاں بھاگ کر جائوں"
 85,16,"ہرگز نہیں ( اسے کوئی پناہ کی جگہ نہ ملے گی )"
 85,17,"اس دن آپ کے رب کی طرف جاکر ٹھہرنا ہوگا"
 85,18,"اس دن انسان کو اس کے تمام اعمال کی خبردی جائے گی کہ اس نے آگے کیا بھیجا ہے اور پیچھے کیا چھوڑا ہے"
 85,19,"بلکہ انسان اپنے آپ سے خوب باخبرہے"
 85,20,"خواہ وہ کتنی ہی معذرتیں پیش کرے"
 85,21,"( اے نبی ) اس وحی کو جلدی یادکرنے کے لئے اپنی زبان کو حرکت نہ دیجئے"
 85,22,"اس کو ( دل میں ) جمع کرنا اور زبان سے پڑھوا دینا ہمارے ذمہ ہے"