quran[18]{c,v,t,f}:
 98,8,"جو چاہےاسے یاد کرلے"
 99,1,"وہ قابل احترام صحیفوں میں ہے"
 99,2,"وہ ( صحیفے ) جوبلندمقام پر ہیں ، اور پاکیزہ ہیں"
 99,3,"وہ ایسے لکھنے والے ( فرشتوں کے ) ہاتھوں میں ہیں"
 99,4,"جومعزز اور نیک ہیں"
 99,5,"لعنت ہوانسان پر وہ کیسامنکرحق ہے؟"
 99,6,"اللہ نے اسے کس چیزسے پیدا کیا"
 99,7,"نطفہ سے ، اللہ نے اسے پیدا کیا پھر اس کی تقدیر مقرر کی"
 99,8,"پھر اس کے لئے ( ماں کے رحم سے نکلنے کے ) راستے کو آسان بنایا"
 100,1,"پھراسے موت دی اور اسے قبر میں پہنچا دیا"
 100,2,"پھرجب وہ چاہےگااسے دوبارہ زندہ اٹھائے گا"
 100,3,"ہر گز نہیں ، اس نے وہ ذمہ داری پوری نہیں کی جس کا اللہ نے اسے حکم دیاتھا"
 100,4,"انسان کو چاہیے کہ وہ اپنے کھانے کی طرف دیکھے"
 100,5,"ہم نے پانی برسایا"
 100,6,"پھرعجیب طرح سے زمین کو پھاڑا"
 100,7,"تواس میں سے ہم نے اناج بھی اگایا"
 100,8,"اور انگور بھی اور ترکاریاں"
 100,9,"اور زیتون اور کجھور"