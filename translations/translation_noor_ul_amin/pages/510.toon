quran[9]{c,v,t,f}:
  47,30,"جس «<a href=326> دن </a>» ظالموں کو ان کی معذرت کچھ بھی «<a href=452> فائدہ </a>» نہ دیگی اور ان کے لئے لعنت بھی ہے اور براگھرہے"
  47,31,"اور ہم نے موسیٰ کو «<a href=485> کتاب </a>» «<a href=644> ہدایت </a>»  ( تورات )  دی اور بنی اسرائیل کو «<a href=485> کتاب </a>»  ( تورات )  کا وارث بنا دیا"
  47,32,"جواہل «<a href=442> عقل </a>» کے لئے «<a href=644> ہدایت </a>» اور «<a href=622> نصیحت </a>» تھی"
  47,33,"پس آپ «<a href=426> صبر </a>» کریں بلا شبہ اللہ کاوعدہ س چاہےاور اپنے «<a href=531> گناہ </a>» کی معافی مانگتے رہیے اور صبح وشام اپنے رب کی حمد سے اس کی تسبیح کیجئے"
  47,34,"جو لوگ بغیرکسی «<a href=325> دلیل </a>» کےجو ان کے «<a href=141> پاس </a>» آئی ہواللہ کی آیات میں جھگڑاکرتے ہیں ان کے دلوں میں تکبربھراہوتا ہے مگروہ اپنا مقصدکبھی حاصل نہ کرپائیں گے لہٰذاآپ  ( ان کی شرارتوں سے )  اللہ کی «<a href=156> پناہ </a>» مانگئے بلا شبہ وہ سننے والادیکھنے والا ہے"
  47,35,"آسمانوں اور «<a href=379> زمین </a>» کو «<a href=180> پیدا </a>» کرنا انسانوں کے «<a href=180> پیدا </a>» کرنے سے «<a href=636> زیادہ </a>» بڑاکام ہے لیکن اکثرلوگ نہیں جانتے"
  47,36,"اور نابینا اور بینا یکساں نہیں ہوسکتے اور وہ لوگ جو ایمان لائیں اور اچھے عمل کریں وہ اور برے «<a href=481> کام </a>» کر نے والے یکساں نہیں ہوسکتے  ( مگر )  تم لوگ «<a href=494> کم </a>» «<a href=622> نصیحت </a>» «<a href=465> قبول </a>» کرتے ہو"
  47,37,"بلا شبہ «<a href=476> قیامت </a>» آ نے والی ہے جس میں کوئی «<a href=420> شک </a>» نہیں لیکن اکثرلوگ ایمان نہیں لاتے"
  47,38,"آپ کے رب نے فرمایا ہے :مجھے پکارومیں تمہاری «<a href=323> دعا </a>» «<a href=465> قبول </a>» کرونگاجولوگ میری «<a href=439> عبادت </a>» سے «<a href=613> ناک </a>» بھویں چڑھاتے ہیں عنقریب «<a href=354> ذلیل </a>» وخوارہوکرجہنم میں «<a href=313> داخل </a>» ہوں گے"