quran[22]{c,v,t}:
  85,1,"قسم ہے آسمان کی جو برجوں والا ہے۔"
  85,2,"اور قسم ہے اس دن کی جس کا وعدہ کیا گیا ہے۔"
  85,3,"اور قسم ہے حاضر ہونے والے کی اور اس کی جس کے پاس حاضر ہوا جائے۔"
  85,4,"ہلاک ہوگئے وہ کھائیوں والے۔"
  85,5,"وہ آگ جو بڑی ایندھن والی تھی۔"
  85,6,"جبکہ وہ اس (کے کناروں) پر بیٹھے ہوئے تھے۔"
  85,7,"اور مومنین کے ساتھ وہ جو کچھ کر رہے تھے خود اس کا نظارہ بھی کر رہے تھے۔"
  85,8,"اور وہ نہیں انتقام لے رہے تھے ان سے مگر اس لیے کہ وہ ایمان لے آئے تھے اللہ پر جو زبردست ہے اور اپنی ذات میں خود ستودہ صفات ہے۔"
  85,9,"جس کے لیے بادشاہی ہے آسمانوں کی اور زمین کی۔  اور اللہ تو ہرچیز پر خود گواہ ہے۔"
  85,10,"یقینا جن لوگوں نے ظلم و ستم توڑا مومن مردوں اور مومن عورتوں پر پھر انہوں نے توبہ بھی نہیں کی  تو ان کے لیے ہوگا جہنم کا عذاب اور جلا ڈالنے والا عذاب۔"
  85,11,"یقینا وہ لوگ جو ایمان لائے اور جنہوں نے نیک عمل کیے  ان کے لیے وہ باغات ہوں گے جن کے نیچے نہریں بہتی ہوں گی۔ یہ ہے اصل بڑی کامیابی۔"
  85,12,"یقینا تیرے رب کی پکڑ بڑی سخت ہے۔"
  85,13,"وہی ہے جو پہلی مرتبہ پیدا کرتا ہے اور وہی اعادہ بھی کرے گا۔"
  85,14,"اور وہ بخشنے والا بھی ہے محبت کرنے والا بھی ہے۔"
  85,15,"عرش کا مالک ہے بڑی شان والا ہے۔"
  85,16,"وہ جو ارادہ کرلے کر گزرنے والا ہے۔"
  85,17,"کیا آپ کے پاس لشکروں کی خبر پہنچی ہے ؟"
  85,18,"فرعون اور ثمود (کے لشکروں) کی ؟"
  85,19,"لیکن یہ کافر جو ہیں یہ جھٹلانے ہی میں لگے رہیں گے۔"
  85,20,"جبکہ اللہ ان کو گھیرے میں لیے ہوئے ہے۔"
  85,21,"بلکہ یہ تو قرآن ہے بہت عزت والا۔"
  85,22,"لوحِ محفوظ میں (نقش ہے)۔"