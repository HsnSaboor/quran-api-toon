quran[26{c,v,t}:
53,1,قسم ہے تارے دِی جدوں او ڈِگے (غروب ہووے)
53,2,نئیں گمرا ہویا ساتھی (رسول) تہاڈا تے نہ رستے توں بھٹکیا ہے
53,3,تے نئیں بول دا خواہش اپنی نال
53,4,نئیں او (بول دا) مگر صاف وحی جیہڑی بھیجی جاندِی ہے
53,5,سکھایا اوس نوں سخت قوَتاں والے (فرشتے) نے
53,6,پوری قوت والا ہے پھر او پورا (اصلی صورت وچ) نظر آیا
53,7,تے او آسمان دے بلند کنارے اُتے سی
53,8,پھر قریب ہویا بس اتر آیا
53,9,پھر او سی فاصلہ برابر دو کمان دے یا ایس توں وِی قریب
53,10,پھر وحی پہنچائی طرف اپنے بندے دِی جیہڑی پہچاؤنی سی
53,11,نئیں جھوٹ بولیا دل نے جو کجھ ویکھیا
53,12,کہیہ پھر جھگڑا کردے ہو تسیں اوس (پیغمبر) نال اوپر اس چیز دے پئی ویکھی ہے
53,13,تے البتہ یقینا ویکھیا ہے اس نوں اوہنے اک واری ہور
53,14,قریب سدرۃُالمُنتہیٰ دے
53,15,اس دے قریب جنت الماویٰ ہے
53,16,جس وقت پئی ڈھکیا سی بیری نوں جو کجھ ڈھک رہیا سی
53,17,نہ تے نظر ہٹی تے نہ زیادہ وَدھ گئی
53,18,تحقیق ویکھیا اس نے رَب اپنے دِیاں نشانیاں وچوں بہشتاں نوں
53,19,کہیہ پھر ویکھیا تساں لات تے عزیٰ نوں
53,20,تے منات تیسرے پچھلے نوں
53,21,کہیہ تہاڈے واسطےبیٹے ہن تے اوہدھے (اللہ) واسطے بیٹیاں
53,22,ایس طریقے نال تے ایہ پھر بڑی بھیڑی وَنڈ ہوئی
53,23,ایہ (معبود) وڈےناں ہی ناں ہن جنہاں نوں تساں تے پیو دادے تہاڈے نے مقرر کر لیا ہے اللہ نے تے ایہناں دِی (معبود ہون دِی)کوئی دلیل نئیں بھیجی نئیں پیروی کردے ایہ مگر گمان (ظن) دِی تے اس چیز دِی پئی چاہوندے نے ایہناں دے جی تے البتہ تحقیق آئی ایہناں کول ایہناں دے رَب دِی طرفوں ہدایت
53,24,کہیہ انسان نوں اس دِی ہر تمنا مل جاندِی ہے
53,25,پھر اللہ دےاختیار وچ ہے آخرت تے دِنیا دِی
53,26,تے کنے ای فرشتے ہن وچ آسماناں دے پئی ذرا وی کم نئیں آؤندِی سفارش اوہناں دِی مگر ایس توں بعد پئی اجازت دِیوے اللہ واسطے جس دے چاہوے تے راضی ہووے
