quran[9{c,v,t}:
48,1,بے شک اَساں تہانوں اک کُھلم کُھلا فتح دتی
48,2,تاکہ اللہ تعالیٰ تہاڈیاں ساریاں اَگلیاں پچھلیاں خطاواں معاف فرما دِیوے تے تہاڈے اُتے اپنیاں نعمتاں (احسانات) پوریاں کر دِیوے تےوَکھاوے تہانوں صراط مستقیم (رَاہ سِدھی)
48,3,تے اللہ تہانوں ایسا غلبہ دِیوے جس وچ عزت ہی عزت ہے
48,4,اوہو ذات ہے جس نے نازل کیتی تسکین وچ دِلاں مومناں دے تاکہ اوہناں دے پہلے ایمان دے نال اوہناں دا ایمان ہور زیادہ ہووے تے واسطے اللہ دے ہین لشکر آسماناں دے تے زمین دے تے ہے اللہ جانن والا حکمت والا
48,5,تاکہ داخل کرےایمان والَیاں نوں تے ایمان والِیاں نوں بہشتاں وِچ وَگدِیاںنیں تھلے اونہاں دے نہراںہمیشہ رہن والے وچ اوس دے تے تاکہ دور (معاف) کر دِیوے بُرائیاں اوہناں دِیاں تے ایہ ہے نزدِیک اللہ دے مُراد پاؤنا وَڈا
48,6,تے عذاب دِیوے منافق مَرداں نوں تے منافق عورتاں نوں تے مُشرک مَرداں نوں تے مُشرک عورتاں نوں جیہڑے اللہ دے نال بڑے بُرے گمان رَکھدے ہین اوہناں اُتے بُرا وقت آؤن والا ہےتے آخرت وِچ اللہ اوہناں اُتے غضبناک ہووے گا تے لعنت کیتی اوہناں اُتے تے تیار کیتی واسطے اوہناں دے جہنم تے بڑا ہی بُرا ٹھکانا ہے
48,7,تے واسطے اللہ دے ہن لشکر آسماناں دے تے زمین دے تے ہے اللہ غالب حکمت والا
48,8,تحقیق بھیجیا اَساں تینوں (سوہنیا) گواہی دِین والا تے خوشخبری دِین والا تے ڈراؤن والا
48,9,تاکہ تسیں لوک ایمان لیاؤ اللہ اُتےتے رسول اوس دے اُتے تے مدد کرو اوس دِی تے تعظیم کرو تے تسبیح کرو اللہ پاک دِی صبح تے شام
