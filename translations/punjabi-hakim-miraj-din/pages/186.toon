quran[6{c,v,t}:
8,70,اے نبی تہاڈے قبضے وچ جیہڑے قیدِی ہن تسیں اوہناں نوں دس دِیو جے کر معلوم کرے گا اللہ وچ دِلاں تہاڈیاں دے بھلیائی (ایمان) دِیوے گا تہانوں بھلیائی (بہتر) اوس چیز نالوں پئی لئی گئی ہے تہاڈے توں تے بخشے گا تہانوں تے اللہ بخشن والا مہرَبان ہے
8,71,تے جے کر ارادہ کرن خیانت (عہد شکنی) تیری دا پھر خیانت (عہد شکنی) کیتی سی اوہناں نے اللہ نال پہلوں پھر قادر کیتا ایہناں اُتے (اللہ نے ایہناں نوں گرفتار کرا دِتا) تے اللہ علم والا حکمت والا ہے
8,72,بے شک جیہڑے لوک ایمان لیائے تے حجرت کیتی تے جہاد کیتا نال مالاں اَپنیاں دے تے جاناں اَپنیاں دے وچ رستے اللہ دے تے جنہاں لوکاں نے جگہ دتی تے مدد کیتی ایہ لوک بعضے اوہناں دے دوست ہن بعض دے تے جیہڑے لوک ایمان لیائے تے حجرت کیتی تہاڈا اوہناں دِی میراث دا کوئی تعلق نئیں جِنّاں چر پئی او حجرت نہ کرن تے جے کر مدد چاہون تہاڈے توں وچ دِین دے پھر تہاڈے ذمہ ہے مدد کرنا مگر اوس قوم دے مقابلے وچ نئیں پئی تہاڈے تے اوہناں دے درمیان باہم عہد (صلح دا) ہووے تے اللہ نال اوس چیزدے پئی کردے ہو ویکھن والا ہے
8,73,تےجیہڑے لوک پئی کافر ہوئے بعضے اوہناں دے دوست دار (وارث) ہن بعض دے اَگر نہ کروگے (مسلمانو) اوس کم (حکم مذکورہ) نوں تے پھیلے گا فتنہ وچ زمین دے تے فساد بڑا وَڈا
8,74,تےجیہڑے لوک پئی ایمان لیائے تے حجرت کیتی تے جہاد کیتا وچ رَاہ اللہ دے تے جنہاں لوکاں نے پئی جگہ دتی تے مدد کیتی ایہو لوک ہن ایمان دا پورا پوراحق اد کرن والے واسطے اوہناں دے بخشش ہے تے رزق ہے باکرامت (جنتاں دے میوے)
8,75,تےجیہڑے لوک پئی ایمان لیائےبعد اوس توں (حجرت نبی توں بعد) تے حجرت کیتی تے جہاد کیتا نال تہاڈے بس ایہ لوک تہاڈے وچوں ہن تےجیہڑے لوک رشتہ دار ہن کتاب اللہ وچ اک دوسرے (دِی میراث) دے زیادہ حق دار ہن بے شک اللہ نال ہر شے دے خوب جانن والا ہے
