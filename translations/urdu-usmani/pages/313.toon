quran[12]{c,v,t,f}:
  23,115,"سو کیا تم خیال رکھتے ہو کہ ہم نے تم کو بنایا کھیلنے کو اور تم ہمارے پاس پھر کر نہ آؤ گے {1}.",footnotes:1:[دوسری زندگی کے بغیر حیات دنیا بے مقصد ہے:یعنی دنیا میں تو نیکی بدی کا پورا نتیجہ نہیں ملتا۔ اگر اس زندگی کے بعد دوسری زندگی نہ ہو تو گویا یہ سب کارخانہ محض کھیل تماشہ اور بے نیتجہ تھا۔ سو حق تعالیٰ کی جناب اس سے بہت بلند ہے کہ ا سکی نسبت ایسا رکیک خیال کیا جائے۔]
  23,116,"سو بہت اوپر ہے اللہ وہ بادشاہ سچا کوئی حاکم نہیں اس کے سوائے مالک اس عزت کے تخت کا {1}.",footnotes:1:[دوسری زندگی کے بغیر حیات دنیا بے مقصد ہے:جب وہ بالاوبرتر، شہنشاہ، مالک علی الاطلاق ہے تو ہو نہیں سکتا کہ وفاداروں اور مجرموں کو یوں کسمپرسی کی حالت میں چھوڑ دے۔]
  23,117,"اور جو کوئی پکارے اللہ کے ساتھ دوسرا حاکم جس کی سند نہیں اس کے پاس سو اس کا حساب ہے اس کے رب کے نزدیک {1} بیشک بھلا نہ ہو گا منکروں کا.",footnotes:1:[دوسری زندگی کے بغیر حیات دنیا بے مقصد ہے:یعنی وہاں حساب ہو کر مقدار جرم کے موافق سزا دی جائے گی۔]
  25,61,"بڑی برکت ہے اسکی جس نے بنائے آسمان میں برج {1} اور رکھا اس میں چراغ {2} اور چاند اجالا کرنے والا.",footnotes:1:[آسمان میں برجوں کی تخلیق:یعنی بڑے بڑے ستارے، یا آسمانی قلعے جن میں فرشتے پہرہ دیتے ہیں۔ یا ممکن ہے سورج کی بارہ منزلیں مراد ہوں جو اہل ہیأت نے بیان کی ہیں۔ حضرت شاہ صاحبؒ لکھتے ہیں کہ آسمان کے بارہ حصے، ان کا نام برج، ہر ایک پر ستاروں کا پتہ، یہ حدیں رکھی ہیں حساب کو۔ (موضح)۔],footnotes:2:[یعنی سورج، شاید نور و حرارت کے جمع ہونے اور صفت احراق رکھنے کی وجہ سے اس کو چراغ فرمایا وَّ جَعَلَ الۡقَمَرَ فِیۡہِنَّ  نُوۡرًا وَّ جَعَلَ الشَّمۡسَ سِرَاجًا (نوح۔۱۶)۔]
  25,62,"اور وہی ہے جس نے بنائے رات اور دن بدلتے سدلتے {1} اس شخص کے واسطے کہ چاہو دھیان رکھنا یا چاہے شکر کرنا {2}.",footnotes:1:[گھٹنے بڑھنے یا آنے کو بدلنا سدلنا فرمایا، یا یہ مطلب ہے کہ ایک کو دوسرے کا بدل بنایا ہے۔ مثلاً دن کا کا م رہ گیا، رات کو کر لیا، رات کا وظیفہ رہ گیا، دن میں پورا کر دیا۔ کما ورد فی الحدیث۔],footnotes:2:[لیل و نہار کی تبدیلی اللہ کی معرفت کیلئے ہے:یعنی چاند سورج وغیرہ کا الٹ پھیر اور رات دن کا ادل بدل اس لئے ہے کہ اس میں دھیان کر کے لوگ خداوند قدیر کی معرفت کا سراغ لگائیں کہ یہ سب تصرفات و تقلبات عظیمہ اسی کے دست قدرت کی کارسازیاں ہیں۔ اور رات دن کے فوائد و انعامات کو دیکھ کر اس کی شکرگذاری کی طرف متوجہ ہوں۔ چنانچہ رحمٰن کے مخلص بندے جن کا ذکر آگے آتا ہے، ایسا ہی کرتے ہیں۔]
  25,63,"اور بندے رحمٰن کے وہ ہیں جو چلتے ہیں زمین پر دبے پاؤں {1} اور جب بات کرنے لگیں ان سے بے سمجھ لوگ تو کہیں صاحب سلامت {2}.",footnotes:1:[رحمٰن کے بندے اور انکے اوصاف:یعنی مشرکین کی طرح رحمٰن کا نام سن کر ناک بھویں نہیں چڑھاتے، بلکہ ہر فعل و قول سے بندگی کا اظہار کرتے ہیں ان کی چال ڈھال سے تواضع، متانت، خاکساری اور بے تکلفی ٹپکتی ہے، متکبروں کی طرح زمین پر اکڑ کر نہیں چلتے۔ یہ مطلب نہیں کہ ریا و تصنع سے بیماروں کی طرح قدم اٹھاتے ہیں۔ کیونکہ حضور کی جو رفتار احادیث میں منقول ہے، اسکی تائید نہیں کرتی۔],footnotes:2:[جہلاء کی بات کا جواب نرمی سے:یعنی کم عقل اور بے ادب لوگوں کی بات کا جواب عفو و صفح سے دیتے ہیں۔ جب کوئی جہالت کی گفتگو کرے تو ملائم بات اور صاحب سلامت کہہ کر الگ ہو جاتے ہیں۔ ایسوں سے منہ نہیں لگتے۔ نہ ان میں شامل ہوں نہ ان سے لڑیں ان کا شیوہ وہ نہیں جو جاہلیت میں کسی نے کہا تھا؎  الَا یَجْھَلَنْ اَحَدٌ  عَلَیْنَا، فنجھَلْ فَوْقَ جَھْلِ الْجَاھِلِیْنا ۔ یہ تو رحمان کے ان مخلص بندوں کا دن تھا، آگے رات کی کیفیت بیان فرماتے ہیں۔]
  26,34,"بولا اپنے گرد کے سرداروں سے یہ تو کوئی جادوگر ہے پڑھا ہوا"
  26,35,"چاہتا ہے کہ نکال دے تم کو تمہارے دیس سے اپنے جادو کے زور سے سو اب کیا حکم دیتے ہو {1}.",footnotes:1:[فرعون کا حواس باختہ ہونا:یا تو خدائی کے دعوے تھے، یا اتنی جلد ایسا حواس باختہ ہو گیا کہ اپنے غلاموں اور پرستاروں کے احکام پر چلنے کے لئے آمادہ ہو گیا۔]
  26,36,"بولے ڈھیل دے اسکو اور اسکے بھائی کو اور بھیجدے شہروں میں نقیب"
  27,7,"جب کہا موسٰی نے اپنے گھر والوں کو میں نے دیکھی ہے آگ {1} اب لاتا ہوں تمہارے پاس وہاں سے کچھ خبر یا لاتا ہوں انگارا سلگا کر شاید تم سینکو {2}.",footnotes:1:[حضرت موسٰی علیہ السلام کا آگ لینے کیلئے پہاڑ پر جانا:یہ "مدین" سے جاتےہوئے "وادی طُوی" کے قریب پہنچ کر کہا جبکہ سخت سردی کی اندھیری رات میں راستہ بھول گئے تھے۔ مفصل واقعہ سورہ طٰہٰ کے فوائد میں گذر چکا۔ ملاحظہ کر لیا جائے۔],footnotes:2:[یعنی رستہ کی خبر لاتا ہوں اگر  آگ کے پاس کوئی موجود ہوا ورنہ کم ازکم سینکنے کے لئے ایک انگارا لے آؤں گا۔]
  27,8,"پھر جب پہنچا اسکے پاس آواز ہوئی کہ برکت ہے اس پر جو کوئی کہ آگ میں ہے اور جو اسکے آس پاس ہے {1} اور پاک ہے وہ ذات اللہ کی جو رب سارے جہان کا {2}.",footnotes:1:[تجلی الٰہی کی روشنی:وہاں پہنچ کر معلوم ہوا کہ یہ دنیا کی آگ نہیں، بلکہ غیبی اور نورانی آگ ہے جس کے اندر نور الہٰی ظاہر ہو رہا تھا، یا اس کی تجلی چمک رہی تھی۔ شاید وہ ہی ہو جس کو حدیث میں فرمایا حِجَابُہٗ النَّار یا حِجَابُہُ النّورُ پھر غیب سے آواز آئی اَنْ بُوْرِکَ مَنْ فِیْ النَّارِ وَمَنْ حَوْلَھَا یعنی زمین کا یہ ٹکڑا مبارک، آگ میں جو تجلی ہے وہ بھی مبارک، اور اس کے اندر یا اس کے آس پاس جو ہستیاں ہیں مثلاً فرشتے یا خود موسٰیؑ وہ سب مبارک ہیں۔ یہ غالبًا موسٰیؑ کو مانوس کرنے کے لئے بطور اعزاز و اکرام کے فرمایا۔],footnotes:2:[آگ میں تجلی کی حقیقت:یعنی مکان، جہت، جسم، صورت اور رنگ وغیرہ سمات حدوث سے اللہ کی ذات پاک ہے۔ آگ میں اس کی تجلی کے یہ معنی نہیں کہ معاذ اللہ اس کی ذات پاک آگ میں حلول کر آئی؟ آفتاب عالمتاب قلعی دار آئینہ میں متجلی ہوتا ہے لیکن کون احمق کہہ سکتا ہے کہ اتنا بڑا کرہ شمسی چھوٹے سے آئینہ میں سما گیا؟]
  27,9,"اے موسٰی وہ میں اللہ ہوں زبردست حکمتوں والا {1}.",footnotes:1:[حق تعالٰی کا حضرت موسٰی علیہ السلام سے خطاب:یعنی اس وقت تجھ سے کلام کرنے والا میں ہوں، یہ سب واقعہ مفصلًا سورہ "طٰہٰ" میں گذر چکا۔]
