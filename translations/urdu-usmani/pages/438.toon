quran[9]{c,v,t,f}:
  43,85,"اور بڑی برکت ہے اسکی جس کا راج ہے آسمانوں میں اور زمین میں اور جو کچھ انکے بیچ میں ہے اور اسی کے پاس ہے خبر قیامت کی {1} اور اسی تک پھر کر پہنچ جاؤ گے {2}.",footnotes:1:[یعنی قیامت کب آئے گی؟ اس کا علم صرف اسی مالک کو  ہے۔],footnotes:2:[یعنی وہاں پہنچ کر سب کی نیکی بدی کا حساب ہو جائے گا۔]
  43,86,"اور اختیار نہیں رکھتے وہ لوگ جنکو یہ پکارتے ہیں سفارش کا مگر جس نے گواہی دی سچی اور انکو خبر تھی {1}.",footnotes:1:[اللہ کے آگے سفارش کا حق:یعنی اتنی سفارش کر سکتے ہیں کہ جس نے انکے علم کے موافق کلمہ اسلام کہا اس کی گواہی دیں۔ بغیر کلمہ اسلام کسی کے حق میں ایک حرف سفارش کا نہیں کہہ سکتے  اور اتنی سفارش بھی صالحین کریں گے جو سچائی کو جانتے اور اسکو زبان و دل سے مانتے ہیں دوسروں کو اجازت نہیں۔]
  43,87,"اور اگر تو ان سے پوچھے کہ انکو کس نے بنایا تو کہیں گے اللہ نے پھر کہاں سے الٹ جاتے ہیں {1}.",footnotes:1:[انکا خالق کون ہے:یعنی جب بنانے  والا ایک اللہ ہے تو بندگی کا مستحق کوئی دوسرا کیونکر ہو گیا۔ عبادت نام ہے انتہائی تذلل کا۔ وہ اسی کا حق ہونا چاہئے جو انتہائی عظمت رکھتا ہے۔ عجیب بات مقدمات کو تسلیم کرتے ہیں اور نتیجہ سے انکار۔]
  50,10,"اور کھجوریں لنبی اُن کا خوشہ ہے تہ بہ تہ {1}.",footnotes:1:[زمین اور اسکی نعمتوں میں غور کرو:یعنی بڑی کثرت اور افراط سے جن کا خوشہ دیکھنے میں بھی بھلا معلوم ہو تا ہے۔]
  50,11,"روزی دینے کو بندوں کے اور زندہ کیا ہم نے اُس سے ایک مردہ دیس کو  یونہی ہو گا نکل کھڑے ہونا {1}.",footnotes:1:[زمین اور اسکی نعمتوں میں غور کرو:یعنی بارش برسا کر مردہ زمین کو زندہ کر دیا۔ اسی طرح قیامت کے دن مردے زندہ کر دیے جائیں گے۔]
  50,12,"جھٹلا چکے ہیں اُن سے پہلے نوح کی قوم اور کنوے والے اور ثمود"
  51,4,"پھر بانٹنے والیاں حکم سے {1}.",footnotes:1:[ہواؤں کی قسم:یعنی اوّل زور کی ہوائیں اور آندھیاں چلتی ہیں جن سے غبار  وغیرہ اڑتا ہے اور بادل بنتے ہیں، پھر ان میں پانی بنتا ہے۔ اس بوجھ کو اٹھائے پھرتی ہیں۔ پھر برسنے کے قریب نرم ہوا چلتی ہے پھر اللہ کے حکم کے موافق بارش میں  جس جگہ کا جتنا حصہ ہوتا ہے وہ تقسیم کرتی ہیں۔ ان ہواؤں کی اللہ قسم کھاتا ہے ۔ بعض علماء نے  "ذاریات"  سے ہوائیں "حاملات" سے بادل "جاریات" سے ستارے اور "مقسمات" سے فرشتے مراد لئے ہیں۔ گویا مقسم بہ کی ترتیب نیچے اوپر کو ہوئی اور حضرت علیؓ وغیرہ سے منقول ہے کہ "ذاریات" ہوائیں"، "حاملات" بادل،  "جاریات" کشتیاں اور "مقسمات" فرشتے ہیں جو اللہ کے حکم سے رزق وغیرہ تقسیم کرتے ہیں۔]
  51,5,"بیشک جو وعدہ کیا ہے تم سے سچ ہے"
  51,6,"اور بیشک انصاف ہونا ضرور ہے {1}.",footnotes:1:[آخرت کا وعدہ سچا ہے:یعنی یہ ہواؤں اور بارش وغیرہ کا نظام شاہد ہے کہ آخرت کا وعدہ سچا، اور انصاف ہونا ضروری ہے۔ جب اس دنیا میں ہوا تک بے نتیجہ نہیں چلتی تو کیا اتنا بڑا کارخانہ یوں ہی بے نتیجہ چل رہا ہے؟ یقیناً اس کا کوئی عظیم الشان انجام ہوگا۔ اسی کو آخرت کہتے ہیں۔]
