quran[12]{c,v,t,f}:
  37,70,"سو  وہ انہی کے قدموں پر دوڑتے ہیں {1}.",footnotes:1:[اندھی تقلید:یعنی پچھلے کافر اگلوں کی اندھی تقلید میں گمراہ ہوئے۔ جس راہ پر انہیں چلتے دیکھا اسی پر دوڑ پڑے کنواں کھائی کچھ نہ دیکھا۔]
  37,71,"اور بہک چکے ہیں ان سے پہلے بہت لوگ اگلے"
  37,72,"اور ہم نے بھیجے ہیں ان میں ڈر سنانے والے"
  38,49,"یہ ایک مذکور ہو چکا {1} اور تحقیق ڈر والوں کے لیے ہے اچھا ٹھکانا.",footnotes:1:[یعنی یہ مذکور تو انبیاء کا تھا۔ آگے عام متقین کا انجام سن لو۔]
  38,50,"باغ ہیں سدا بسنے کے کھول رکھے ہیں انکے واسطے دروازے {1}.",footnotes:1:[جنت کے کھلے دروازے:حضرت شاہ صاحبؒ لکھتے ہیں "جب بہشت میں داخل ہوں گے ہر کوئی بدون بتائے اپنے گھر میں چلا جائے گا" آواز دے کر دروازہ کھلوانے کی ضرورت نہ پڑے گا۔]
  38,51,"تکیہ لگائے ہوئے بیٹھے ہیں ان میں میوے بہت اور شراب {1}.",footnotes:1:[یعنی قسم قسم کے میوے، پھل اور پینے کی چیزیں حسب خواہش غلمان حاضر کر یں گے۔]
  39,34,"ان کے لئے ہے جو وہ چاہیں اپنے رب کے پاس یہ ہے بدلا نیکی والوں کا"
  39,35,"تاکہ اتار دے اللہ ان پر سے برے کام جو انہوں نے کئے تھے اور بدلہ میں دے ان کو ثواب بہتر کاموں کا جو وہ کرتے تھے {1}.",footnotes:1:[محسنین کا اجر:یعنی اللہ تعالیٰ متقین و محسنین کو  ان کے بہتر کاموں کا بدلہ دے گا اور غلطی سے جو برا کام ہو گیا وہ  معاف کرے گا (تنبیہ) شاید اَسۡوَاَ اور اَحۡسَنِ (صیغہ تفصیل) اس لئے اختیار فرمایا کہ بڑے درجہ والوں کی ادنیٰ بھلائی اوروں کی بھلائیوں سے اور ادنیٰ برائی اوروں کی برائیوں سے بھاری سمجھی جاتی ہے۔ واللہ اعلم۔]
  39,36,"کیا اللہ بس نہں اپنے بندہ کو اور تجھ کو ڈراتے ہیں ان سے جو اس کے سوائے ہیں اور جسکو  راہ بھلائے اللہ تو کوئی نہیں اسکو راہ دینے والا"
  40,13,"وہی ہے تم کو دکھلاتا اپنی نشانیاں اور اتارتا ہے تمہارے واسطے آسمان سے روزی اور سوچ وہی کرے جو رجوع رہتا ہو {1}.",footnotes:1:[رزق رسانی میں اللہ کی نشانیاں:یعنی اس کی عظمت و وحدانیت کی نشانیاں ہر چیز میں ظاہر ہیں۔ ایک اپنی روزی ہی کے مسئلہ کو آدمی سمجھ لے جس کا سامان آسمان سے ہوتا رہتا ہے  تو سب کچھ سمجھ میں آ جائے۔ لیکن جب ادھر رجوع ہی نہ ہو اور غور و فکر سے کام ہی نہ لے تو کیا خاک سمجھ حاصل ہو سکتی ہے۔]
  40,14,"سو پکارو اللہ کو خالص کر کر اسکے واسطے بندگی اور پڑے برا مانیں منکر {1}.",footnotes:1:[رزق رسانی میں اللہ کی نشانیاں:یعنی بندوں کو چاہئے سمجھ سے کام لیں۔ اور ایک خدا کی طرف رجوع ہو کر اسی کو پکاریں، اس کی بندگی میں کسی کو شریک نہ کریں۔ بیشک مخلص بندوں کے اس موحدانہ طرز عمل سے کافر و مشرک ناک بھوں چڑھائیں گے کہ سارے دیوتا اڑا کر صرف ایک ہی خدا رہنے دیا گیا مگر پکا مُؤحِّد وہ ہی ہے جو مشرکین کے مجمع میں توحید کا نعرہ بلند کرے۔ اور ان کے برا ماننے کی اصلًا پروا نہ کرے۔]
  40,15,"وہی ہے اونچے درجوں والا مالک عرش کا اتارتا ہے بھید کی بات اپنے حکم سے جس پر چاہے اپنے بندوں میں {1} تاکہ وہ ڈرائے ملاقات کے دن سے {2}.",footnotes:1:[القائے روح:بھید کی بات سے وحی مراد ہے جو اول انبیاء علیہم السلام پر اترتی ہے اور ان کے ذریعے سے دوسرے بندوں کو پہنچ جاتی ہے۔ چنانچہ قیامت تک اسی طرح پہنچتی رہے گی۔],footnotes:2:[یعنی جس دن تمام اولین و آخرین مل کر اللہ تعالیٰ کی پیشی میں حاضر ہوں گے اور ہر ایک شخص اپنے اچھے یا برے عمل سے ملاقات کرے گا۔]
