quran[6]{c,v,t,f}:
  6,130,"اے جماعت جنوں کی اور انسانوں کی کیا نہیں پہنچے تھے تمہارے پاس رسول تمہی میں سے کہ سناتے تھے تم کو میرے حکم اور ڈراتے تھے تم کو اس دن کے پیش آنے سے {1} کہیں گے کہ ہم نے اقرار کر لیا اپنے گناہ کا اور ان کو دھوکا دیا دنیا کی زندگی نے {2} اور قائل ہو گئے اپنے اوپر اس بات کے کہ وہ کافر تھے {3}.",footnotes:1:[یعنی دنیا کی لذات و شہوات نے انہیں آخرت سے غافل],footnotes:2:[بنا دیا۔ کبھی خیال بھی نہ آیا کہ اس احکم الحاکمین],footnotes:3:[کے سامنے جانا ہے جو ذرہ ذرہ کا حساب لے گا۔]
  6,131,"یہ اس واسطے کہ تیرا رب ہلاک کرنے والا نہیں بستیوں کو انکے ظلم پر اور وہاں کے لوگ بے خبر ہوں"
  6,132,"اور ہر ایک کے لئے درجے ہیں انکے عمل کے اور تیرا رب بیخبر نہیں ان کے کام سے {1}.",footnotes:1:[یعنی خدا کی یہ عادت نہیں کہ بدون آگاہ اور خبردار کئے کسی کو اس کے ظلم و عصیان پر دنیا یا آخرت میں پکڑ  کر ہلاک کر دے اسی لئے رسول اور نذیر بھیجے کہ وہ خوب کھول کر تمام جن و انس کو ان کے بھلے برے اور آغاز و انجام سے خبردار کر دیں۔ پھر جس درجہ کا کسی کا عمل ہو گا حق تعالیٰ اس کے ساتھ ویسا ہی معاملہ کرے گا۔]
  7,40,"بیشک جنہوں نے جھٹلایا ہماری آیتوں کو اور ان کے مقابلہ میں تکبر کیا نہ کھولے جائیں گے انکے لئےدروازے آسمان کے {1} اور نہ داخل ہوں گے جنت میں یہاں تک کہ گھس جائے اونٹ سوئی کے ناکے میں {2} اور ہم یوں بدلا دیتے ہیں گنہگاروں کو.",footnotes:1:[کفار کی ارواح:یعنی نہ زندگی میں ان کے اعمال کے لئے آسمانی قبول و رفعت حاصل ہے۔ نہ موت کے بعد ان کی ارواح کو آسمان پر چڑھنے کی اجازت ہے۔ حدیث صحیح میں ہے کہ "بعد موت کافر کی روح کو آسمان کی جانب سے سجین کی طرف دھکے دیے جاتے ہیں اور مومن کی روح ساتویں آسماں تک صعود کرتی ہے" مفصل احوال کتب احادیث میں ملاحظہ کرو۔],footnotes:2:[کفار جنت میں داخل نہیں ہو سکتے:یہ تعلیق بالمحال کے طور پر فرمایا۔ ہر زبان کے محاورات میں ایسی امثال موجود ہیں جن میں کسی چیز کے محال ہونے کو دوسری محال چیز پر معلق کر کے ظاہر کرتے ہیں۔ یعنی جس طرح یہ ناممکن ہے کہ اونٹ اپنی اسی ایسی کلانی اور جسامت پر رہے اور سوئی کا ناکہ ایسا ہی تنگ اور چھوٹا ہو۔ اس کے باوجود اونٹ سوئی کے ناکے میں داخل ہو جائے۔ اسی طرح ان مکذبین و مستکبرین کا جنت میں داخل ہونا محال ہے کیونکہ حق تعالیٰ جہنم میں ان کے "خلود" کی خبر دے چکا ہے اور علم الہٰی میں یہ ہی سزا ان کے لئے ٹھہر چکی ہے۔ پھر خدا کے علم اور اخبار کے خلاف کیسے وقوع میں آسکتا ہے۔]
  7,41,"انکے واسطے دوزخ کا بچھونا ہے اور اوپر سے اوڑھنا {1} اور ہم یوں بدلا دیتے ہیں ظالموں کو.",footnotes:1:[یعنی ہر طرف سے آگ محیط ہو گی، کسی کروٹ چین نہ ملے گا۔]
  7,42,"اور جو ایمان لائے اور کیں نیکیاں ہم بوجھ نہیں رکھتے کسی پر مگر اس کی طاقت کے موافق وہی ہیں جنت میں رہنے والے وہ اسی میں ہمیشہ رہیں گے {1}.",footnotes:1:[آخرت میں مومنین کا حال: لَا نُکَلِّفُ نَفۡسًا اِلَّا وُسۡعَہَاۤ جملہ معترضہ ہے جس سے درمیان میں متنبہ فرما دیا کہ ایمان و عمل صالح جس پر اتنا عظیم الشان صلہ مرحمت ہوتا ہے کوئی ایسی مشکل چیز نہیں جو انسان کی طاقت سے باہر ہو، یا یہ مطلب ہے کہ ہر آدمی سے عمل صالح اسی قدر مطلوب ہے جتنا اس کی مقدرت اور طاقت میں ہو ، اس سے زائد کا مطالبہ نہیں کیا جا رہا۔]
