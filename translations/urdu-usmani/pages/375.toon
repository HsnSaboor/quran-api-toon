quran[16]{c,v,t,f}:
  26,220,"بیشک وہی ہے سننے والا جاننے والا"
  26,221,"میں بتلاؤں تم کو کس پر اترتے ہیں شیطان"
  26,222,"اترتے ہیں ہر جھوٹے گنہگار پر {1}.",footnotes:1:[شیطان کس پر اترتے ہیں؟:یہاں پھر قرآن کے صدق اور عظمت شان پر تنبیہ فرمائی۔ یعنی ایسے ساجدین اور تہجد گذاروں کے امام کو جو اللہ کے معاملہ میں اپنے اور بیگانے کی کوئی پروا نہ کرے۔ اور ساری دنیا سے ٹوٹ کر اکیلے خدا پر بھروسہ رکھے، کیا یہ کہا جا سکتا ہے کہ (معاذ اللہ) شیطان ان پر وحی لاتا تھا؟ میں تم کو بتلاؤں کہ شیطانی وحی کس قسم کےلوگوں پر آتی ہے۔ وہ آتی ہے جھوٹوں پر، بدمعاشوں اور بدکاروں پر، کیونکہ شیطان سچے اور نیک آدمیوں سے بیزار ہے کہ یہ اس کو برا جانتے ہیں۔ جھوٹے دغابازوں سے خوش ہے جو اس کی مرضی کے موافق ہیں۔ بھلا سب سچوں سے زیادہ سچے اور تمام نیکوں سے بڑھ کر نیک انسان کو شیطانی وحی سے کیا نسبت، حضور ﷺ کا صدق  و امانت، اتقا، پاکبازی، خداترسی، تو وہ اوصاف ہیں جو بچپن سے لیکر دعوئے نبوت تک آپ کی ساری قوم کو تسلیم تھے حتیٰ کہ "الصادق الامین" آپ کا لقب ہی پڑ گیا تھا۔]
  33,73,"تاکہ عذاب کرے اللہ منافق مردوں کو اور عورتوں کو اور شرک والے مردوں کو اور عورتوں کو اور معاف کرے اللہ ایمان دار مردوں کو اور عورتوں کو اور ہے اللہ بخشنے والا مہربان {1}.",footnotes:1:[میرے نزدیک اس جگہ وَ یَتُوۡبَ اللّٰہُ عَلَی الۡمُؤۡمِنِیۡنَ الخ کے معنی معاف کرنے کے نہ لئے جائیں بلکہ ان کے حال پر متوجہ ہونےاور مہربانی فرمانے کےلیں تو بہتر ہے جیسے لَقَدۡ تَّابَ اللّٰہُ عَلَی النَّبِیِّ وَ الۡمُہٰجِرِیۡنَ (التوبہ۔۱۱۷) میں لئے گئے ہیں۔ تو یہ مومنین کاملین کا بیان ہوا۔ اور کَانَ اللّٰہُ  غَفُوۡرًا  رَّحِیۡمًا میں قاصرین و مقصرین کے حال کی طرف اشارہ فرما دیا۔ واللہ تعالیٰ اعلم۔ نسال اللہ تعالیٰ ان یتوب علینا ویغفرلنا ویثیبنا بالفوزالعظیم۔ انہ جل جلالہ و عم نوالہ غفور الرحیم۔]
  34,52,"اور کہنے لگیں ہم نے اسکو یقین مان لیا اور اب کہاں انکا ہاتھ پہنچ سکتا ہے بعید جگہ سے {1}.",footnotes:1:[آخرت میں کفار کا انعام:یعنی اس وقت کہیں گے کہ ہمیں پیغمبر کی باتوں پر یقین آ گیا اب ہم ایمان لاتے ہیں۔ حالانکہ اب ایمان کیسا؟ وہ موقع دور گیا جب ایمان لا کر اپنے کو  بچا سکتے تھے۔ اب ان کا ہاتھ اتنی دور کہاں پہنچ سکتا ہے جو وہاں سے ایمان کو  اٹھا لائیں۔ مطلب یہ کہ ایمان مقبول و منجی وہ ہے جو موت سے پہلے اس دنیا میں حاصل ہو۔ آخرت میں تو آنکھوں سے دیکھ کر سب ہی کو یقین آ جائے گا۔ اس میں کیا کمال ہوا۔]
  34,53,"اور اس سے منکر رہے پہلے سے اور پھینکتے رہے بن دیکھے نشانہ پر دور کی جگہ سے {1}.",footnotes:1:[کفار کو جواب:یعنی پہلے جب ایمان لانے کا وقت تھا (انکار پر تلے رہے اور یوں ہی اٹکل کے تیر چلاتے رہے دنیا میں رہ کر ہمیشہ بے تحقیق باتیں کیں۔ سچی اور تحقیقی باتوں کو قبول نہ کیا۔ اب پچتانے سے کیا حاصل۔]
  34,54,"اور رکاوٹ پڑ گئ ان میں اور ان کی آرزو میں {1} جیسا کہ کیا گیا ہے انکے طریقہ  والوں کے ساتھ اس سے پہلے وہ لوگ تھے ایسے تردد میں جو چین نہ لینے دے {2}.",footnotes:1:[<strong>ابدی ناکامی:</strong>],footnotes:2:[یعنی جس چیز کی آرزو رکھتے ہیں مثلاً ایمان مقبول یا نجات، یا دنیا کی طرف واپس جانا، یا دنیوی لذتیں اور عیش و آرام ۔ ان چیزوں کے اور ان کفار کے درمیان سخت روک قائم کر دی گئ۔ کبھی ان تک نہیں پہنچ سکتے۔]
  35,37,"اور وہ چلائیں اس میں اے رب ہم کو نکال کہ ہم کچھ بھلا کر لیں وہ نہیں جو کرتے رہے {1} کیا ہم نے عمر نہ دی تھی تمکو اتنی کہ جس میں سوچ لے جس کو سوچنا ہو او رپہنچا تمہارے پاس ڈرانے  والا اب چکھو کہ کوئی نہیں گنہگاروں کا مددگار {2}.",footnotes:1:[اہل دوزخ کی فریاد:یعنی اس وقت تو اسی کو بھلا سمجھتے تھے پر اب وہ کام نہ کریں گے۔ ذرا دوزخ سےنکال دیجئے تو ہم خوب نیکیاں سمیٹ کر لائیں اور فرمانبردار بن کر حاضر ہوں۔],footnotes:2:[حق تعالٰی کا جواب:یہ جواب دوزخیوں کو  دیا جائے گا۔ یعنی ہم نے تم کو عقل دی تھی جس سے سمجھتے اور کافی عمر دی جس میں سوچنا چاہتے تو سب نیک و بد سوچ کر سیدھا راستہ اختیار کر سکتے تھے۔ حتٰی کہ تم میں کے بہت سے تو ساٹھ ستر برس دنیا میں زندہ رہ کر مرے۔ پھر اوپر سے ایسے اشخاص اور حالات بھیجے جو برے انجام سے ڈراتے اور خواب غفلت سے بیدار کرتے رہیں۔ کیا اس کے بعد بھی کوئی عذر باقی رہا اب پڑے عذاب کا مزہ چکھتے رہو اور کسی طرف سے مدد کی توقع  نہ رکھو۔]
  35,38,"اللہ بھید جاننے والا ہے آسمانوں کا اور زمین کا اس کو خوب معلوم ہے جو بات ہے دلوں میں {1}.",footnotes:1:[اللہ دلوں کی بات جانتا ہے:یعنی اسے بندوں کے سب کھلے چھپے احوال و افعال اور دلوں کے بھید معلوم ہیں۔ کسی کی نیت اور استعداد اس سے پوشیدہ نہیں اسی کے موافق معاملہ کرتا ہے اور وہ یہ بھی جانتا ہے کہ جو لوگ اب چلا رہے ہیں کہ ہمیں چھوڑ دو، پھر ایسی خطا نہ کریں گے، وہ اپنےدعوے میں جھوٹے ہیں۔اگر ستر دفعہ لوٹائے جائیں تب بھی شرارت سے باز نہیں آ سکتے۔ ان کے مزاجوں کی افتاد ہی ایسی ہے۔ وَ لَوۡ رُدُّوۡا لَعَادُوۡا لِمَا نُہُوۡا عَنۡہُ وَ اِنَّہُمۡ  لَکٰذِبُوۡنَ (انعام۔۲۸)]
  35,39,"وہی ہے جس نے کیا تمکو قائم مقام زمین میں {1} پھر جو کوئی ناشکری کرے تو اس پر  پڑے اسکی ناشکری اور منکروں کو نہ بڑھے گی  انکے انکار سے ان کے  رب کے سامنے مگر بیزاری اور منکروں کو نہ بڑھے گا انکے انکار سے مگر نقصان {2}.",footnotes:1:[یعنی اگلی امتوں کی جگہ تم کو زمین پر آباد کیا اور ان کے بعد ریاست دی۔ چاہئے اب اس کا حق ادا کرو۔],footnotes:2:[یعنی کفر و ناشکری اور اللہ کی آیات کے انکار سے اس کا کچھ نقصان نہیں۔ وہ ہمارے حمد و شکر سے مستغنی ہے۔ البتہ ناشکری کرنے والے پر اس کے فعل کا وبال پڑتا ہے۔ کفر کا انجام بجز اس کے کچھ نہیں کہ اللہ کی طرف سے برابر ناراضی اور بیزاری بڑھتی جائے اور کافر کے نقصان  و خسران میں روز بروز اضافہ ہوتا رہے۔]
  36,22,"اور مجھ کو کیا ہوا کہ میں بندگی نہ کروں اسکی جس نے مجھ کو بنایا {1} اور اسی کی طرف سب پھر جاؤ گے {2}.",footnotes:1:[ایک مرد صالح کی حمایت اور فہمائش:یہ اپنے اوپر رکھ کر دوسروں کو سنایا۔ یعنی تم کو آخر کیا ہوا کہ جس نے پیدا کیا اس کی بندگی نہ کرو۔],footnotes:2:[یعنی یہ مت سمجھنا کہ پیدا کر کے آزاد چھوڑ دیا ہے اب کچھ مطلب اس سے نہیں رہا۔ نہیں سب کو مرے پیچھے اسی کے پاس واپس جانا ہے۔ اس وقت کی فکر رکھو۔]
  36,23,"بھلا میں پکڑوں اس کے سوائے اوروں کو پوجنا کہ اگر مجھ پر چاہے رحمٰن تکلیف تو کچھ کام نہ آئے مجھ کو ان کی سفارش اور نہ وہ مجھ کو چھڑائیں"
  36,24,"تو تو میں بھٹکتا رہوں صریح {1}.",footnotes:1:[ایک مرد صالح کی حمایت اور فہمائش:یعنی کس قدر صریح گمراہی ہے کہ اس مہربان اور قادر مطلق پروردگار کو چھوڑ کر ایسی چیزوں کی پرستش کی جائے جو خدا کی بھیجی ہوئی کسی تکلیف سے نہ بذات خود چھڑا سکیں نہ سفارش کر کے نجات دلا سکیں۔]
  37,7,"اور بچاؤ بنایا ہر شیطان سر کش سے {1}.",footnotes:1:[ستاروں کی رونق:یعنی تاروں سے آسمان کی زینت و آرائش ہے۔ اور بعض تاروں کے ذریعہ سے جو ٹوٹتے ہیں شیطانوں کو  روکنے اور دفع کرنے کا کام بھی لیا جاتا ہے یہ ٹوٹنے والے ستارے کیا ہیں۔ آیا کواکب نوریہ کے علاوہ کوئی مستقل نوع کواکب کی ہے یا کواکب نوریہ کی شعاعوں ہی سے ہوا متکیّف ہو کر ایک طرح کی آتش سوزاں  پیدا ہو جاتی ہے  یا خود کواکب کے اجزاء ٹوٹ کر گرتے ہیں؟ اس میں علماء و حکماء کے مختلف اقوال ہیں۔ بہرحال ان کی حقیقت کچھ ہی کیوں نہ ہو، رجم شیاطین کا کام بھی ان سے لیا جاتا ہے اسکی کچھ تفصیل سورہ "حجر" کے فوائد میں گذر چکی ملاحظہ کر لیجائے۔]
  37,8,"سن نہیں سکتے اوپرکی مجلس تک اور پھینکے جاتےہیں ان پر ہر طرف سے"
  37,9,"بھگانے کو {1} اور ان پر مار ہے ہمیشہ کو {2}.",footnotes:1:[ملاء اعلٰی اور شیاطین:اوپر کی مجلس سے مراد فرشتوں کی مجلس ہے۔ یعنی شیاطین کو یہ قدرت نہیں دی گئ کہ فرشتوں کی مجلس میں پہنچ کر کوئی بات وحی الہٰی کی سن آئیں۔ جب ایسا ارادہ کر کے اوپر آسمانوں کے قریب پہنچنے کی کوشش کرتے ہیں تو جس طرف سے جاتے ہیں ادھر ہی سے فرشتے دھکے دے کر اور مار مار کر بھگا دیتے ہیں۔],footnotes:2:[یعنی دنیا میں ہمشیہ یوں ہی مار پڑتی رہے گی اور آخرت کا دائمی عذاب الگ رہا۔]
