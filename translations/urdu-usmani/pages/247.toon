quran[12]{c,v,t,f}:
  16,112,"اور بتلائی اللہ نے ایک مثال (مثل) ایک بستی تھی چین امن سے {1} چلی آتی تھی اسکو روزی فراغت کی ہر جگہ سے {2} پھر ناشکری کی اللہ کے احسانوں کی پھر چکھایا اس کو اللہ نے مزہ کہ ان کے تن کے کپڑے ہو گئے بھوک اور ڈر بدلہ اس کا جو وہ کرتے تھے {3}.",footnotes:1:[ایک بستی کی مثال:یعنی نہ باہر سے دشمن کا کھٹکا نہ اندر سے کسی طرح کی فکر و تشویش ۔ خوب امن چین سے زندگی گذرتی تھی۔],footnotes:2:[یعنی کھانے کے لئے غلے اور  پھل وغیرہ کھنچے چلے آتے تھے ، ہر چیز کی افراط تھی ، گھر بیٹھے دنیا کی نعمتیں ملتی تھیں۔],footnotes:3:[اس بستی کے رہنے والوں نے خدا کے انعامات کی قدر نہ پہچانی ، دنیا کے مزوں میں پڑ کر ایسے غافل اور بدمست ہوئے کہ منعم حقیقی کا دھیان بھی نہ آیا۔ بلکہ اس کے مقابلہ میں بغاوت کی ٹھان لی ، آخر خدا تعالیٰ نے ان کی ناشکری اور کفران نعمت کا مزہ چکھایا ۔ یعنی امن چین کی جگہ خوف و ہراس نے اور فراخ روزی کی جگہ بھوک اور قحط کی مصیبت نے ان کو اس طرح گھیر لیا ، جیسے کپڑا پہننے والے کے بدن کو گھیر لیتا ہے ایک دم کو بھوک اور ڈر ان سےجدا نہ ہوتا تھا۔]
  16,113,"اور ان کے پاس پہنچ چکا رسول انہی میں کا پھر اس کو جھٹلایا پھر آ پکڑا انکو عذاب نے اور وہ گنہگار تھے {1}.",footnotes:1:[ایک بستی کی مثال:ظاہری نعمتوں کےعلاوہ جو اوپر مذکور ہوئیں ایک بڑی بھاری باطنی نعمت بھی ان کو دی گئ تھی ، یعنی انہی کی قوم و نسبت میں سے ایک رسول بھیجا گیا ، جس کا اتباع کر کے وہ خدا کی خوشنودی کے بڑے اونچے مقامات حاصل کر سکتے تھے۔ انہوں نے اتباع و تصدیق کی جگہ اس کی تکذیب و مخالفت پر کمر باندھ لی اور اس طرح پستی میں گرتے چلے گئے ، آخر قدیم سنت اللہ کے موافق ظالموں اور گنہگاروں کو عذاب نے آ پکڑا پھر کسی کی کوئی تدبیر پیش نہ گئ۔ بعض مفسرین کہتے ہیں کہ ان آیات میں کسی معین بستی کا تذکرہ نہیں ۔ محض بطور تمثیل کسی تباہ شدہ بستی کا لاعلی التعیین حوالہ دیکر یا ایک ایسی بستی کا وجود فرض کر کے کفار مکہ کو آگاہ کیا گیا ہے کہ تم نے ایسا کیا تو تمہارے ساتھ بھی ایسا ہی معاملہ ہو سکتا ہے۔ کفران نعمت اور تکذیب و عداوت رسول کی سزا سے بے فکر نہ ہوں۔ بعض علماء کے نزدیک اس مثال میں بستی سے مراد مکہ معظمہ ہے جہاں ہر قسم کا امن چین تھا اور باوجود وادی غیر ذی روح ہونے کے طرح طرح کے پھل اور میوے کھنچے چلے آتے تھے۔ اَوَ لَمۡ نُمَکِّنۡ لَّہُمۡ حَرَمًا اٰمِنًا یُّجۡبٰۤی  اِلَیۡہِ  ثَمَرٰتُ  کُلِّ شَیۡءٍ (القصص۔۵۷) اہل مکہ نے ان نعمتوں کی کچھ قدر نہ جانی ، شرک و عصیان ، بے حیائی ، اور اوہام پرستی میں منہمک ہو گئے ، پھر خدا تعالیٰ نے سب سے بڑی نعمت محمد رسول اللہ ﷺ کی صرت میں بھیجی ، اس کے انکار و تکذیب میں کوئی دقیقہ اٹھا نہ رکھا۔  اَلَمۡ تَرَ اِلَی الَّذِیۡنَ بَدَّلُوۡا نِعۡمَتَ اللّٰہِ کُفۡرًا  وَّ اَحَلُّوۡا  قَوۡمَہُمۡ  دَارَ  الۡبَوَارِ (ابراہیم ۔۲۸) آخر خدا تعالیٰ نے امن و اطمینان کے بجائے مسلمان مجاہدین کا خوف اور فراخ روزی کی جگہ سات سال کا قحط ان پر مسلط کر دیا ۔ جس میں کتے اور مردار تک کھانے کی نوبت آ گئ۔ پھر "بدر" کے معرکہ میں غازیان اسلام کے ہاتھوں خدا کا عذاب ان پر ٹوٹ پڑا۔ ادھر تو یہ ہوا دوسری طرف جو لوگ ان ظالموں کے جوروستم سے تنگ آ کر گھر بار چھوڑ بھاگے تھے ان کو خدا نے بہتر ٹھکانا دیا۔ دشمنوں کے  خوف سے مامون و مصئون بنایا ، روزی کے دروازے کھول دیے ، زبردست دشمنوں پر فتح عنایت کی ، بلکہ اقلیموں کا بادشاہ اور متقیوں کا امام بنا دیا ۔ شاید اسی لئے ان آیات میں مکہ والوں کا حال سنا کر اگلی آیت فَکُلُوۡا مِمَّا رَزَقَکُمُ اللّٰہُ الخ میں مسلمانوں کا خطاب فرمایا ہے کہ تم اس قسم کی حرکات سے بچتے رہنا جن کی بدولت مکہ والوں پر مصیبت ٹوٹی۔]
  16,114,"سو کھاؤ جو روزی دی تم کو اللہ نے حلال اور پاک اور شکر کرو اللہ کے احسان کا اگر تم اسی کو پوجتے ہو {1}.",footnotes:1:[اللہ کی نعمتوں کا شکر ادا کرو:یعنی جس کو خدا کی پرستش کا دعویٰ ہو ، اسے لائق ہے کہ خد اکی دی ہوئی حلال و طیب روزی سے تمتع کرے اور اس کا احسان مان کر شکر گذار بندہ بنے۔ حلال کو حرام نہ سمجھے اور نعمتوں سےمنتفع ہوتے وقت منعم حقیقی کو نہ بھولے۔ بلکہ اس پر اور اس کےبھیجے ہوئے پیغمبروں پر ایمان لائے ۔ اور اسی کے احکام و ہدایات کی پابندی کرے۔]
  17,79,"اور کچھ رات جاگتا رہ قرآن کے ساتھ یہ زیادتی ہے تیرے لئے {1} قریب ہے کہ کھڑا کر دے تجھ کو تیرا رب مقام محمود میں {2}.",footnotes:1:[حضرت شاہ صاحبؒ لکھتے ہیں "یعنی " نیند سے جاگ کر (تہجد میں) قرآن پڑھا کر ۔ یہ حکم سب سے زیادہ تجھ پر کیا ہے کہ تجھ کو مرتبہ (سب سے) بڑا دینا ہے۔],footnotes:2:[آنحضرت صلی اللہ علیہ وسلم کے لئے مقام محمود:"مقام محمود" شفاعت عظمیٰ کا مقام ہے ۔ جب کوئی پیغمبر نہ بول سکے گا۔ تب آنحضرت ﷺ سے عرض کر کے خلقت کو تکلیف سے چھڑائیں گے  ۔ اس وقت ہر شخص کی زبان پر آپ کی حمد (تعریف) ہو گی۔ اور حق تعالیٰ بھی آپ کی تعریف کرے گا۔ گویا شان محمدیت کا پورا پورا ظہور اس وقت ہو گا۔ (تنبیہ) "مقام محمود" کی یہ تفسیر صحیح حدیثوں میں آئی ہے ۔ اور بخاری و مسلم اور دیگر کتب حدیث میں شفاعت کبریٰ کا نہایت مفصل بیان موجود ہے ۔ شارحین نے حضور ﷺ کے لئے دس قسم کی شفاعتیں ثابت کی ہیں۔ فتح الباری میں ملاحظہ کر لیا جائے۔]
  17,80,"اور کہہ اے رب داخل کر مجھ کو سچا داخل کرنا اور نکال مجھ کو سچا نکالنا {1} اور عطا کر دے مجھ کو اپنے پاس سے حکومت کی مدد {2}.",footnotes:1:[آنحضرت صلی اللہ علیہ وسلم کو ایک دعا کی تعلیم:یعنی جہاں مجھے پہنچانا ہے (مثلاً مدینہ میں) نہایت آبرو اور خوبی و خوش اسلوبی سے پہنچا کہ حق کا بول بالا رہے۔ اور جہاں سے نکالنا یعنی علیحدہ کرنا ہو (مثلاً مکے سے ) تو وہ بھی آبرو اور خوبی و خوش اسلوبی سے ہو کہ دشمن ذلیل و خوار اور دوست ، شاداں و فرحاں ہوں ۔ اور بہر صورت سچائی کی فتح اور جھوٹ کا سر نیچا ہو۔],footnotes:2:[یعنی غلبہ اور تسلط عنایت فرما جس کے ساتھ تیری مدد و نصرت ہو ۔ تاکہ حق کا بول بالا رہے اور معاندین ذلیل و پست ہوں۔ دنیا میں کوئی قانون ہو ، سماوی یا ارضی اس کےنفاذ کے لئے ایک درجہ میں ضروری ہے کہ حکومت کی مدد ہو ۔ جو لوگ دلائل و براہین سننے اور آفتاب کی طرح حق واضح ہو چکنے کے بعد بھی ضد و عناد پر قائم رہیں ان کے ضرر و فساد کو حکومت کی مدد ہی روک سکتی ہے۔ اسی لئے سورہ حدید میں فرمایا۔ لَقَدۡ  اَرۡسَلۡنَا  رُسُلَنَا بِالۡبَیِّنٰتِ وَ اَنۡزَلۡنَا مَعَہُمُ  الۡکِتٰبَ وَ الۡمِیۡزَانَ لِیَقُوۡمَ النَّاسُ بِالۡقِسۡطِ ۚ  وَ اَنۡزَلۡنَا الۡحَدِیۡدَ فِیۡہِ بَاۡسٌ شَدِیۡدٌ وَّ مَنَافِعُ لِلنَّاسِ الیٰ آخر ہا (حدید۔۲۵)۔]
  17,81,"اور کہہ آیا سچ اور نکل بھاگا جھوٹ بیشک جھوٹ ہے نکل بھاگنے والا {1}.",footnotes:1:[غلبہ حق کی پیشگوئی:یہ عظیم الشان پیشگوئی مکہ میں کی گئ جہاں بظاہر کوئی سامان غلبہ حق کا نہ تھا۔ یعنی کہدو قرآن کریم مومنین کو بشارتیں سناتا ہوا اور باطل کو کچلتا ہوا آ پہنچا بس سمجھ لو کہ اب دین حق غالب ہوا اور کفر بھاگا۔ نہ صرف مکہ سے بلکہ سارے عرب سے ۔ حدیث میں ہے کہ نبی کریم ﷺ جب مکہ میں فاتحانہ داخل ہوئے اس وقت کعبہ کے گرد تین سو ساٹھ بت رکھے ہوئے تھے۔ آپ ایک چھڑی سے سب پر ضرب لگاتے اور فرماتے تھے ۔ جَاءَ الْحَقُّ وَزَھَقَ الْبَاطِلُ اِنَّ الْبَاطِلَ کَانَ زَھُوْقًا۔ جَاءَالْحَقُّ وَمَا یُبْدِئُ الْبَاطِلُ وَمَا یُعِیْدُ ہر ایک اوندھے منہ گر جاتا تھا۔ اس طرح قرآن کی ایک پیشگوئی پوری ہوئی اور دوسری کا اعلان کیا گیا کہ جو کفر کعبہ سے نکل بھاگا ہے ۔ آئندہ کبھی واپس نہ آئے گا ۔ والحمدللہ علیٰ ذٰلک۔]
  18,46,"مال اور بیٹے رونق ہیں دنیا کی زندگی میں اور باقی رہنے والی نیکیوں کا بہتر ہے تیرے رب کے یہاں بدلا اور بہتر ہے توقع {1}.",footnotes:1:[مال و اولاد اور باقی رہنے والی نیکیاں:یعنی مرنے کے بعد مال و اولاد وغیرہ کام نہیں آتے صرف وہ نیکیاں کام آتی ہیں جن کا اثر یا ثواب آئندہ باقی رہنے والا ہو۔ حدیث میں سُبْحَانَ اللّٰہِ وَالْحَمْدُ لِلّٰہِ وَلَآ اِلٰہَ اِلَّااللّٰہُ وَاللّٰہُ اَکْبَرْ وَلَا حَوْلَ وَلَا قُوَّۃَ اِلَّا بِاللّٰہِ ان کلمات کو باقیات صالحات فرمایا۔ یہ محض مثال کے طور پر ہے۔ ورنہ تمامی اعمال حسنہ اس میں داخل ہیں۔ موضح القرآن میں ہے "رہنے والی نیکیاں یہ کہ علم سکھا جائے جو جاری رہے یا کوئی نیک رسم چلا جائے یا مسجد ، کنواں ، سرائے ، باغ ، کھیت وقف کر جائے یا اولاد کو تربیت کر کے صالح چھوڑ جائے ، اسی قسم کے کام ہیں جن پر خدا کے ہاں بہترین بدلہ مل سکتا ہے اور انسان عمدہ توقعات قائم کر سکتا ہے۔ دنیا کی فانی و زائل خوشحالی پر لمبی چوڑی امیدیں باندھنا عقلمندی نہیں۔]
  18,47,"اور جس دن ہم چلائیں پہاڑ اور تو دیکھے زمین کو کھلی ہوئی {1} اور گھیر ملائیں ہم انکو پھر نہ چھوڑیں ان میں سے ایک کو {2}.",footnotes:1:[قیامت کے دن پہاڑ اور زمین کا حال:یعنی جب قیامت آئے گی پہاڑ جیسی سخت مخلوق بھی اپنی جگہ سے چلائی جائے گی بلکہ اس کی بھاری بھاری چٹانیں دھنی ہوئی اون کی طرح فضا میں اڑتی پھریں گی ۔ غرض زمین کےسارے ابھار مٹ کر سطح ہموار اور کھلی ہو ئی رہ جائے گی۔],footnotes:2:[یعنی کوئی شخص خدائی عدالت سے غیر حاضر نہ ہو سکے گا۔]
  18,48,"اور سامنے آئیں تیرے رب کے صف باندھ کر آ پہنچے تم ہمارے پاس جیسے ہم نے بنایا تھا تم کو پہلی بار نہیں تم تو کہتے تھے کہ نہ مقرر کریں گے ہم تمہارے لئے کوئی وعدہ {1}.",footnotes:1:[محشرمیں امتوں کی صفیں:منکرین بعث کو تفریع و توبیخ کے طور پر یہ کہا جائے گا کہ تم تو قیامت وغیرہ کو محض ڈھکوسہ سمجھتے تھے آج سب جتھا اور اثاثہ چھوڑ کر ننگ دھڑنگ کہاں آ پہنچے ۔ اور "جیسا بنایا تھا پہلی بار" میں یہ بھی داخل ہے کہ بدن میں کچھ زخم و نقصان وغیرہ نہ رہے گا ۔ حدیث میں ہے کہ محشر میں کل ایک سو بیس صفیں ہوں گی جن میں اسی امت محمدیہ کی ہیں۔]
  19,7,"اے زکریا ہم تجھ کو خوشخبری سناتے ہیں ایک لڑکے کی جس کا نام ہے یحیٰی نہیں کیا ہم نے پہلے اس نام کا کوئی {1}.",footnotes:1:[حضرت یحیٰی علیہ السلام کی بشارت:یعنی دعا قبول ہوئی اور لڑکے کی بشارت پہنچی۔ جس کا نام (یحیٰی) قبل از ولادت حق تعالیٰ نے تجویز فرما دیا ۔ نام بھی ایسا انوکھا جو ان سے پہلے کسی کا نہ رکھا گیا تھا۔ بعض سلف نے یہاں "سمّی" کے معنی "شبیہ" کے لئے ہیں یعنی اس شان و صفت کا کوئی شخص ان سے پہلے نہیں ہوا تھا۔ شاید یہ مطلب ہو کہ بوڑھے مرد اور بانجھ عورت سے کوئی ایسا لڑکا اس وقت تک پیدا نہیں کیا گیا تھا۔ یا بعض خاص احوال و صفات (مثلًا رقت قلب اور غلبہ بکا وغیرہ) میں ان کی مثال پہلے نہ گذری ہو گی۔ واللہ اعلم۔]
  19,8,"بولا اے رب کہاں سے ہو گا مجھ کو لڑکا اور میری عورت بانجھ ہے اور میں بوڑھا ہو گیا یہاں تک کہ اکڑ گیا {1}.",footnotes:1:[حضرت زکریا علیہ السلام کا تعجب:آدمی کا قاعدہ ہے کہ جب غیر متوقع اور غیر معمولی خوشخبری سنے تو مزید طمانیت و استلذاذ کے لئے بار بار پوچھتا اور کھود کرید کیا کرتا ہے ۔ اس تحقیق و تفحص سے لذت تازہ حاصل ہوتی اور بات خوب پکی ہو جاتی ہے یہ ہی منشا حضرت زکریا کے سوال کا تھا۔ حضرت شاہ صاحبؒ لکھتے ہیں "انوکھی چیز مانگتے تعجب نہ آیا ۔ جب سنا کہ ملے گی تب تعجب کیا۔ "]
  19,9,"کہا یونہی ہو گا {1} فرما دیا تیرے رب نے وہ مجھ پر آسان ہے اور تجھ کو پیدا کیا میں نے پہلے سے اور نہ تھا تو کوئی چیز {2}.",footnotes:1:[حضرت زکریا علیہ السلام کا تعجب:تعجب کی کوئی بات نہیں ۔ ان ہی حالات میں اولاد مل جائے گی اور مشیت ایزدی پوری ہو کر رہے گی۔],footnotes:2:[اللہ کی قدرت کاملہ:یہ فرشتہ نے کہا ۔ یعنی تمہارے نزدیک ظاہری اسباب کے اعتبار سے ایک چیز مشکل ہو تو خدا کے یہاں مشکل نہیں اس کی قدرت عظیمہ کے سامنے سب آسان ہے۔ انسان اپنی ہستی ہی کو دیکھ لے ۔ ایک زمانہ تھا کہ یہ کوئی چیز نہ تھی اس کا نام و نشان بھی کوئی نہ جانتا تھا۔ حق تعالیٰ اس کو پردہ عدم سے وجود میں لایا ۔ پھر جو قادر مطلق لاشے محض کو شے بنا دے ۔ کیا وہ بوڑھے مرد اور بانجھ عورت سے بچہ پیدا نہیں کر سکتا ۔ اس پر تو بطریق اولیٰ قدرت ہونی چاہیئے۔]
