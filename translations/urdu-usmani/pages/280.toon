quran[12]{c,v,t,f}:
  20,88,"پھر بنا نکالا اُنکے واسطے ایک بچھڑا ایک دھڑ جسمیں آواز گائے کی پھر کہنے لگے یہ معبود ہے تمہارا اور معبود ہے موسٰی کا سو وہ بھول گیا {1}.",footnotes:1:زیورات اور سونے کا بچھڑا:یعنی موسٰیؑ سے بھول ہوئی کہ خدا تعالیٰ سے ہم کلام ہونے کے لئے طور پر گئے۔ خدا تو یہاں موجود ہے۔ یعنی یہ ہی بچھڑا۔ الیعاذ باللہ۔ شایدیہ قول انہیں سے سخت غالیوں کا ہو گا۔
  20,89,"بھلا یہ لوگ نہیں دیکھتے کہ وہ جواب تک نہیں دیتا اُنکو کسی بات کا اور اختیار نہیں رکھتا اُنکے برے کا اور نہ بھلے کا {1}.",footnotes:1:زیورات اور سونے کا بچھڑا:یعنی اندھوں کو اتنی موٹی بات بھی نہیں سوجھتی کہ جو مورتی نہ کسی سے بات کر سکے نہ کسی کو ادنیٰ ترین نفع نقصان پہنچانے کا اختیار رکھے ، وہ معبود یا خدا کس طرح بن سکتی ہے۔
  20,90,"اور کہا تھا اُنکو ہارون نے پہلے سے اے قوم بات یہی ہے کہ تم بہک گئے اس بچھڑے سے اور تمہارا رب تو رحمٰن ہے سو میری راہ چلو اور مانو بات میری {1}.",footnotes:1:قوم کو حضرت ہارون کی تنبیہ:یعنی حضرت ہارونؑ نرمی سے زبانی فہمائش کر چکے تھے کہ جس بچھڑے پر تم مفتون ہو رہے ہو ، وہ خدا نہیں ہو سکتا ۔ تمہارا پروردگار اکیلا رحمٰن ہے۔ جس نے اب تک خیال کرو کس قدر رحمتوں کی بارش تم پر کی ہے۔ اسے چھوڑ کر کدھر جا رہے ہو۔ میں موسٰیؑ کا جانشین ہوں اور خود نبی ہوں ۔ اگر اپنا بھلا چاہتے ہو تو لازم ہے کہ میری راہ چلو اور میری بات مانو۔ سامری کے اغواء میں مت آؤ۔
  21,64,"پھر سوچے اپنے جی میں پھر بولے لوگو تم ہی بے انصاف ہو {1}.",footnotes:1:کفار کی شرمندگی:یعنی سمجھےکہ بیکار پتھر پوجنے سے کیا حاصل یا یہ مطلب ہو کہ تم نے خود اپنے اوپر ظلم کیا کہ باوجود ابراہیمؑ کی دھمکی سننے کے یوں ہی لاپروائی سے بت خانہ کھلا چھوڑ کر چلےگئے اپنے معبودوں کی حفاظت کا کوئی سامان کر کے نہ گئے ۔ کذا قال ابن کثیرؒ۔
  21,65,"پھر اوندھے ہو گئے سر جھکا کر {1} تو تو جانتا ہے جیسا یہ بولتے ہیں {2}.",footnotes:1:[کفار کی شرمندگی:یعنی شرمندگی سے آنکھ نہیں ملا سکتے۔],footnotes:2:[کفار کا جواب:یعنی جان بوجھ کر ہم سے ایسی نا ممکن بات کا مطالبہ کیوں کرتا ہے ۔ کہیں پتھر بھی بولےہیں ؟]
  21,66,"بولا کیا پھر تم پوجتے ہو اللہ سے ورے ایسے کو جو تمہارا کچھ بھلا کرنے نہ برا"
  22,40,"وہ لوگ جنکو  نکالا  اُنکے گھروں سے اور دعویٰ کچھ نہیں سوائے اسکے کہ وہ کہتے ہیں ہمارا رب اللہ ہے {1} اور اگر نہ ہٹایا کرتا اللہ لوگوں کو ایک کو دوسرے سے تو ڈھائے جاتے تکئے اور مدرسے اور عبادت خانے اور مسجدیں جن میں نام پڑھا جاتا ہے اللہ کا بہت اور اللہ مقرر مدد کرے گا اُسکی جو مدد کرے گا اُسکی بیشک اللہ زبردست ہے زور  والا {2}.",footnotes:1:[<strong>مہاجرین کی مدح:</strong>],footnotes:2:[یعنی مسلمان مہاجرین جو اپنے گھروں سے نکالے گئے ان کا کوئی جرم نہ تھا نہ ان پر کسی کا کوئی دعویٰ تھا، بجز اس کے کہ وہ اکیلے ایک خدا کو اپنا رب کیوں کہتے ہیں۔ اینٹ پتھروں کو کیوں نہیں پوجتے ۔گویا ان پر سب سے بڑا اور سنگین الزام اگر لگایا جا سکتا ہے تو یہ ہی کہ ہر طرف سے ٹوٹ کر ایک خدا کے کیوں ہو رہے۔]
  22,41,"وہ لوگ کہ اگر ہم اُنکو قدرت دیں ملک میں تو وہ قائم رکھیں نماز اور دیں زکوٰۃ اور حکم کر دیں بھلے کام کا اور منع کریں برائی سے {1} اور اللہ کے اختیار میں ہے آخر  ہر کام کا {2}.",footnotes:1:[مہاجرین کی فضیلت اور انکے اقتدار کی پیشگوئی:یہ اُن ہی مسلمانوں کا بیان ہے جن پر ظلم ہوئے اور جن کو گھروں سے نکالا گیا۔ یعنی خدا ان کی مدد کیوں نہ کرے گا جبکہ وہی ایسی قوم ہے کہ اگر ہم اسے زمین کی سلطنت دے دیں تب بھی خدا سے غافل نہ ہوں۔ بذات خود بدنی و مالی نیکیوں میں لگے رہیں اور دوسروں کو بھی اسی راہ پر ڈالنےکی کوشش کریں۔ چنانچہ حق تعالیٰ نے ان کو زمین کی حکومت عطا کی اور جو پیشین گوئی کی گئ تھی حرف بحرف سچی ہوئی ۔ فللہ الحمد علیٰ ذلک۔ اس آیت سے صحابہؓ خصوصًا مہاجرین اور ان میں اخص خصوص کے طور پر حضرات خلفائے  راشدینؓ کی حقانیت اور مقبولیت و منقبت ثابت ہوئی۔],footnotes:2:[یعنی گو آج مسلمان کمزور اور کافر غالب و قوی نظر آتے ہیں۔لیکن اللہ تعالیٰ کے قبضہ میں ہےکہ آخرکار انہیں منصور و غالب کر دے یا یہ مطلب کہ یہ امت خدا کا دین قائم کرے گی ایک مدت تک آخر اللہ ہی جانے کیا ہوگا۔]
  22,42,"اور اگر تجھ کو جھٹلائیں تو اُن سے پہلے جھٹلا چکی ہے نوح کی قوم اور عاد اور ثمود"
  23,16,"پھر تم قیامت کے دن کھڑے کئےجاؤ گے {1}.",footnotes:1:وجود انسانی کا بقاء و فنا:جس نے پہلی مرتبہ پیدا کیا تھا وہ ہی دوبارہ بنا کر کھڑا کرے گا۔ تا پہلے وجود کی مستور قوتیں اور اعمال کے نتائج اپنی کامل ترین صورتوں میں ظاہر ہو کر ثابت کر دیں کہ یہ اتنا بڑا کارخانہ کوئی بے کار اور  بے نتیجہ ڈھونگ نہیں بنایا گیا تھا۔
  23,17,"اور ہم نے بنائے ہیں تمہارے اوپر سات رستے {1} اور ہم نہیں ہیں خلق سے بے خبر {2}.",footnotes:1:[سات راستوں کی تخلیق:"طرائق" کے معنی بعض مفسرین و لغویین کے نزدیک طبقات کے ہیں۔ یعنی آسمان کے سات طبقے اوپر نیچے بنائے  فہذا کما قال کَیۡفَ خَلَقَ اللّٰہُ  سَبۡعَ سَمٰوٰتٍ طِبَاقًا (نوح۔۱۵) اور بعض نے طرائق کو راستوں کےمعنی میں لیا ہے یعنی سات آسمان بنائے جو فرشتوں کی گذرگاہیں ہیں۔ بعض معاصر مصنفین نے "سبع طرائق" سے سات سیاروں کے مدارات مراد لئے ہیں۔ واللہ اعلم۔],footnotes:2:[خلق کی نگرانی:ہر چیز پورے انتظام و احکام اور خبرداری سے بنائی ہے اور اس کی حفاظت و بقاء کے طریقوں سے ہم پورے با خبر ہیں۔ اجرام سماویہ اور مخلوقات سفلیہ میں کوئی چیز نہیں جو ہمارے احاطہ علم و قدرت سے باہر ہو، ورنہ سارا انتظام ہی درہم و برہم ہو جائے یَعۡلَمُ مَا یَلِجُ  فِی الۡاَرۡضِ وَ مَا یَخۡرُجُ مِنۡہَا وَ مَا یَنۡزِلُ مِنَ السَّمَآءِ  وَ مَا یَعۡرُجُ فِیۡہَا الخ (حدید۔۴)]
  23,18,"اور اتارا ہم نے آسمان سے پانی ماپ کر {1} پھر اُسکو ٹھہرا دیا زمین میں {2} اور ہم اُسکو لیجائیں تو لیجا سکتے ہیں {3}.",footnotes:1:[پانی کے ذخائر:نہ اس قدر  زیادہ کہ دنیا بے وقت اور بے موقع تباہ ہو جائے اور نہ اتنا کم کہ ضروریات کو کافی نہ ہو۔],footnotes:2:[یعنی بارش کا پانی زمین اپنے اندر جذب کر لیتی ہے جس کو ہم کنواں وغیرہ کھود کر نکالتے ہیں۔],footnotes:3:[یعنی نہ اتارنا چاہیں تو نہ اتاریں اور اتارنے کے بعد تم کو اس سے منتفع ہونے کی دسترس نہ دیں مثلًا اس قدر گہرا کر دیں کہ تم نکالنے میں کامیاب نہ ہو سکو، یا خشک کر کے ہوا میں اڑا دیں ، یا کھارا اور کڑوا کر دیں، تو ہم یہ سب کچھ کر سکتے ہیں۔]
