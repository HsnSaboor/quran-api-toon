quran[25]{c,v,t}:
  78,31,"بیشک ڈر والوں کو اُنکی مراد ملنی ہے"
  78,32,"باغ ہیں اور انگور"
  78,33,"اور نوجوان عورتیں ایک عمر کی سب{1}",footnotes:1:<strong class=h>متّقین پر مختلف انعامات:</strong>یعنی نوخاستہ عورتیں جن کی جوانی پورے اُبھار پر ہوگی اور سب ایک ہی سن وسال کی ہونگی۔
  78,34,"اور پیالے چھلکتے ہوئے{1}",footnotes:1:<strong class=h>متّقین پر مختلف انعامات:</strong>یعنی شراب طہور کے لبریز جام۔
  78,35,"نہ سنیں گے وہاں بک بک اور نہ مکرانا{1}",footnotes:1:<strong class=h>جنّت میں جھوٹ اور لغو نہیں ہوگا:</strong>یعنی جنّت میں بیہودہ بکواس یاجھوٹ فریب کچھ نہ ہوگا۔ نہ کوئی کسی سے جھگڑیگا کہ جھوٹ بولنے اور مکرنے کی ضرورت پیش آئے۔
  78,36,"بدلا ہے تیرے رب کا دیا ہوا حساب سے{1}",footnotes:1:یعنی رتی رتی کا حساب ہو کر بدلہ ملیگا اور بہت کافی بدلہ ملیگا۔
  78,37,"جو رب ہے آسمانوں کا اور زمین کا اور جو کچھ اُنکے بیچ میں ہے بڑی رحمت والا{1} قدرت نہیں کہ کوئی اُس سے بات کرے{2}",footnotes:1:یہ بدلہ بھی محض بخشش اور رحمت سے ہے ورنہ ظاہر ہے اللہ پر کسی کا قرض یا جبر نہیں۔ آدمی اپنے عمل کی بدولت عذاب سے بچ جائے یہ ہی مشکل ہے۔ رہی جنت، وہ تو خالص اس کے فضل ورحمت سے ملتی ہے اس کو ہمارے عمل کا بدلہ قرار دینا یہ دوسری ذرہ نوازی اور عزت افزائی ہے۔|2:<strong class=h>اللہ کی عظمت وجلال:</strong>یعنی باوجوداس قدر لطف ورحمت کے عظمت وجلال ایسا ہے کہ کوئی اسکے سامنے لب نہیں ہلا سکتا۔
  78,38,"جس دن کھڑی ہو روح اور فرشتے قطار باندھ کر{1} کوئی نہیں بولتا مگر جس کو حکم دیا رحمٰن نے اور بولا بات ٹھیک{2}",footnotes:1:<strong class=h>رُوح اور فرشتوں کی قطار:</strong>روح فرمایا جانداروں کو یا "رُوح القدس" (جبریل) مراد ہوں اور بعض مفسرین کے نزدیک وہ رُوح اعظم مراد ہے جس سے بیشمار روحوں کا انشعاب ہوا ہے۔ واللہ اعلم۔|2:یعنی اس کے دربار میں جو  بولے گا اس کے حکم سے بولے گا اور بات بھی وہ ہے کہے گا جو ٹھیک اور معقول ہو مثلًا کسی غیر مستحق کی سفارش نہ کرے گا۔ مستحق سفارش کے وہ ہی ہیں جنہوں نے دنیا میں سب باتوں سے زیادہ سچّی اور ٹھیک بات کہی تھی یعنی لاالہٰ الا اللہ محمد رسول اللہ۔
  78,39,"وہ دن ہے برحق پھر جو کوئی چاہے بنا رکھے اپنے رب کے پاس ٹھکانا{1}",footnotes:1:یعنی وہ دن آنا تو ضروری ہے۔اب جو کوئی اپنی بہتری چاہے اس وقت کی تیاری کر رکھے۔
  78,40,"ہم نے خبر سنا دی تم کو ایک آفت نزدیک آنے والی کی جس دن دیکھ لے گا آدمی جو آگے بھیجا اُسکے ہاتھوں نے{1} اور کہے گا کافر کسی طرح میں مٹی ہوتا{2}",footnotes:1:یعنی سب اچھے برے۔اگلے پچھلے اعمال سامنے ہونگے۔|2:<strong class=h>کافر کہے گا میں مٹی ہوتا:</strong>یعنی مٹی ہی رہتا، آدمی نہ بنتا، کہ آدمی بن کر ہی اس حساب و کتاب کی مصیبت میں گرفتار ہونا پڑا۔
  79,1,"قسم ہے گھسیٹ لانے والوں کی غوطہ لگا کر{1}",footnotes:1:<strong class=h>رُوح گھسیٹنے والے فرشتے:</strong>یعنی ان فرشتوں کی قسم جو کافر کی رگوں میں گھس کر اس کی جان سختی سے گھسیٹ کر نکالیں۔
  79,2,"اور بند چھڑا دینے والوں کی کھول کر{1}",footnotes:1:<strong class=h>نیکوں کی رُوح کا بند کھولنے والے:</strong>یعنی جو فرشتے مؤمن کے بدن سے جان کی گرہ کھول دیں، پھر وہ اپنی خوشی سے عالم پاک کی طرف دوڑے جیسے کسی کے بند کھول دیے جائیں تو آزاد ہو کر بھاگتا ہے۔ مگر یاد رہے یہ ذکر روح کا ہے بدن کا نہیں، نیک خوشی سے عالم قدس کی طرف دوڑتا ہے، بد بھاگتا ہے، پھر گھسیٹا جاتا ہے۔
  79,3,"اور پیرنے والوں کی تیزی سے"
  79,4,"پھر آگے بڑھنے والوں کی دوڑ کر{1}",footnotes:1:<strong class=h>خلاؤں میں تیرنے والے فرشتے:</strong>یعنی جو فرشتے روحوں کو لے کر زمین سے آسمان کی طرف اس سرعت وسہولت سے چلتے ہیں گویا بے روک ٹوک پانی پر تیر رہے ہیں۔ پھران ارواح کے باب میں جو خدا کا حکم ہوتا ہے اس کے امتثال کے لئے تیزی کے ساتھ دوڑ کر آگے بڑھتے ہیں۔
  79,5,"پھر کام بنانے والوں کی حکم سے{1}",footnotes:1:<strong class=h>کاموں کی تدبیر کرنے والے فرشتے:</strong>یعنی اس کے بعد ان ارواح کے متعلق ثواب کا حکم ہو یا عقاب کا دونوں امروں میں سے ہر امر کی تدبیر و انتظام کرتے ہیں یا مطلقًا وہ فرشتے مراد ہوں جو عالم تکوین کی تدبیر و انتظام پر مسلط ہیں۔ والظاہر ہو الاول<span class=indopak> النّٰزِعٰتِ </span><span class=indopak> وَّالنّٰشِطٰتِ </span>وغیرہ کی تعیین میں بہت اقوال ہیں۔ ہم نے مترجمؒ مذاق پر تقریر کر دی۔
  79,6,"جس دن کانپے کانپنے والی{1}",footnotes:1:یعنی زمین میں بھونچال آئے پہلی دفعہ صور  پھونکنے سے۔
  79,7,"اُسکے پیچھے آئے دوسری{1}",footnotes:1:<strong class=h>قیامت کے بھونچال:</strong>حضرت شاہ صاحبؒ لکھتے ہیں یعنی لگاتار یکے بعد دیگرے، بھونچال چلے آئیں اور اکثر مفسرین نے "رادفۃ " سے صور کا دوسرا نفخہ مراد لیا ہے۔ واللہ اعلم۔
  79,8,"کتنے دل اُس دن دھڑکتے ہیں"
  79,9,"اُنکی آنکھیں جھک رہی ہیں{1}",footnotes:1:<strong class=h>دھڑکنے والے دل اور  جھکی آنکھیں:</strong>یعنی اضطراب اور گھبراہٹ سے دل دھڑکتے ہونگے اور ذلت وندامت کے مارے آنکھیں جھک رہی ہونگی۔
  79,10,"لوگ کہتے ہیں کیا ہم پھر آئیں گے الٹے پاؤں"
  79,11,"کیا جب ہم ہو چکیں ہڈیاں کھوکھری"
  79,12,"بولے تو تو یہ پھر آنا ہے ٹوٹے کا{1}",footnotes:1:<strong class=h>دوسری زندگی پر کفّار کا استہزاء:</strong>یعنی قبر کے گڑھے میں پہنچ کر کیا پھر ہم الٹے پاؤں زندگی کی طرف واپس کیے جائیں گے۔ ہم تو نہیں سمجھ سکتے کہ کھوکھری ہڈیوں میں دوبارہ جان پڑجائیگی۔ ایسا ہوا تو یہ صورت ہمارے لئے بڑے ٹوٹے اور خسارہ کی ہو گی۔  کیونکہ ہم نے اس زندگی کے لئے کوئی سامان نہیں کیا" یہ تمسخر سے کہتے تھے یعنی مسلمان ہماری نسبت ایسا سمجھتے ہیں حالانکہ وہاں مرنے کے بعد سرے سے دوسری زندگی ہی نہیں نقصان اور خسارہ کا کیا ذکر۔
  79,13,"سو وہ تو صرف ایک جھڑکی ہے"
  79,14,"پھر تبھی وہ آ رہیں میدان میں{1}",footnotes:1:<strong class=h>معمولی جھڑکی سے سب جمع ہو جائیں گے:</strong>یعنی یہ لوگ اسے بہت مشکل کام سمجھ رہے ہیں۔ حالانکہ اللہ کے ہاں یہ سب کام دم بھر میں ہو جائینگے جہاں ایک ڈانٹ پلائی یعنی صور پھونکا اسی وقت بلا توقف سب اگلے پچھلے میدان حشر میں کھڑے دکھائی دینگے۔ آگے اُس کی ایک مختصر سی جھڑکی اور معمولی سی ڈانٹ کا ذکر کیا جاتا ہے جو دنیا میں ایک بڑے متکبر کو دی گئ تھی۔ یا یوں کہیے کہ ان منکرین کو سنایا جا رہا ہے کہ تم سے پہلے بڑے زبردست منکروں کا کیا حشر ہوا۔
  79,15,"کیا پہنچی ہے تجھ کو بات موسٰی کی{1}",footnotes:1:یہ قصّہ کئ جگہ مفصل گزر چکا۔