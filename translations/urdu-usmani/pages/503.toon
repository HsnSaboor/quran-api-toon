quran[19]{c,v,t,f}:
  83,34,"سو آج ایمان والے منکروں سے ہنستے ہیں {1}.",1:[آخرت میں مومنین کفّار پر ہنسیں گے:یعنی قیامت کے دن مسلمان ان کافروں پر ہنستے ہیں کہ یہ لوگ کیسے کو تاہ اندیش اور احمق تھے جو خسیس اور فانی چیر کو نفیس اور باقی نعمتوں پر ترجیح دی۔ آخر آج دوزخ میں کس طرح عذاب دائم کا مزہ چکھ رہے ہیں۔]
  83,35,"تختوں پر بیٹھے دیکھتے ہیں {1}.",1:[یعنی اپنی خوشحالی اور کافروں کی بدحالی کا نظارہ کر رہے ہیں۔]
  83,36,"اب بدلا پایا ہے منکروں نے جیسا کہ کچھ کرتے تھے {1}.",1:[آج منکروں کو ان کے اعمال کا بدلہ مل گیا:یعنی جو دنیا میں مسلمانوں کی ہنسی اڑاتے تھے، آج ان کا حال قابل مضحکہ ہو رہا ہے، اور مسلمان ان کی گذشتہ حماقتوں کا خیال کر کے ہنستے ہیں۔]
  87,19,"صحیفوں میں ابراہیم کے اور موسٰی کے {1}.",1:[یہ تعلیم حضرت ابراہیم علیہ السلام و موسی علیہ السلام کے صحیفوں میں موجود ہے:یعنی یہ مضمون( قَدْ اَفْلَحَ مَنْ تَزَکیّٰ سے یہاں تک ) اگلی کتابوں میں بھی مذکور ہے جو کسی وقت منسوخ نہیں ہوا، نہ بدلا گیا۔ اس اعتبار سے اور  زیادہ مؤکد ہوگیا۔ (تنبیہ) بعض روایات ضعیفہ میں ہے کہ ابراہیمؑ پر دس صحیفے اور موسیٰؑ  پر "توراۃ" کے علاوہ دس صحیفے نازل ہوئے تھے خدا جانے کہاں تک صحیح ہے۔]
  88,16,"اور مخمل کے نہالچے جگہ جگہ پھیلے ہوئے {1}.",1:[مخملی فرش:تاکہ جس وقت جہاں چاہیں آرام کریں اور ایک جگہ سے  دوسری جگہ جانے کی کلفت نہ اٹھائیں۔]
  88,17,"بھلا کیا نظر نہیں کرتے اونٹوں پر کہ کیسے بنائے ہیں {1}.",1:[اونٹ کی تخلیق پر غور کرو:کہ ہیأۃ اور خاصیت دونوں اور جانوروں کی نسبت اس میں عجیب ہیں جن کی تفصیل تفسیر عزیزی میں دیکھنے کے قابل ہے۔]
  88,18,"اور آسمان پر کہ کیسا اُس کو بلند کیا ہے {1}.",1:[بدون ظاہری ستون اور کھمبے کے۔]
  89,13,"پھر پھینکا اُن پر تیرے رب نے کوڑا عذاب کا {1}.",1:[ان سب نے فساد برپا کیا اور ہلاک ہوئے:یعنی ان قوموں نے عیش و دولت اور زور و قوت کے نشے میں مست ہو کر مُلکوں میں خوب اودھم مچایا۔ بڑی بڑی شرارتیں کیں، اور ایسا سر  اٹھایا، گویا ان کے سروں پر کوئی حاکم ہی نہیں؟ ہمیشہ اسی حال میں رہنا ہے! کبھی اس ظلم و شرارت کا خمیازہ بھگتنا نہیں پڑے گا؟  آخر جب انکے کفروتکبر اور جوروستم کا پیمانہ لبریز ہوگیا اور مہلت ودرگزر کا کوئی موقع باقی نہ رہا۔ دفعۃً خداوند قہار نے ان پر اپنے عذاب کا کوڑا برسا دیا۔ ان کی سب قوت اور بڑائی خاک میں مل گئ، اور وہ سازوسامان کچھ کام نہ آیا۔]
  89,14,"بیشک تیرا رب لگا ہے گھات میں {1}.",1:[اللہ ان کی گھات میں ہے:یعنی جیسے کوئی شخص گھات میں پوشیدہ رہ کر آنے جانے والوں کی خبر رکھتا ہے کہ فلاں کیونکر گزرا اور کیا کرتا ہوا گیا، اور فلاں کیا لایا اور کیا لے گیا، پھر وقت آنے پر ان معلومات کے موافق معاملہ کرتا ہے۔ اسی طرح سمجھ لو کہ حق تعالیٰ انسانوں کی آنکھوں سے پوشیدہ رہ کر سب بندوں کے ذرہ ذرہ احوال و اعمال دیکھتا ہے، کوئی حرکت و سکون اس سے مخفی نہیں، ہاں سزا دینے میں جلدی نہیں کرتا، غافل بندے سمجھتے ہیں کہ بس کوئی دیکھنے اور پوچھنے والا نہیں۔ جو چاہو بے دھڑک کیے جاؤ۔ حالانکہ وقت آنے پر ان کا سارا کچا چٹھا کھول دیتا ہے اور ہر ایک سے انہی اعمال کے موافق معاملہ کرتا ہے جو شروع سے اس کے زیر نظر تھے اس وقت پتہ لگتا ہے کہ وہ سب ڈھیل تھی اور بندوں کا امتحان تھا کہ دیکھیں کن حالات میں کیا کچھ کرتے ہیں اور ایک عارضی حالت پر نظر کرکے آخری انجام کو تو نہیں بھولتے۔]
  89,15,"سو آدمی جو ہے جب جانچے اُسکو رب اُس کا پھر اُس کو عزت دے اور اُسکو نعمت دے تو کہے میرے رب نے مجھ کو عزت دی {1}.",1:[نعمت کے وقت انسان کی خود پسندی:یعنی میں اسی لائق تھا اس لئے عزت دی۔]
  90,7,"کیا خیال رکھتا ہے کہ دیکھا نہیں اسکو کسی نے {1}.",1:[یعنی اللہ سب دیکھ رہا ہے۔ جتنا مال جس جگہ جس نیت سے خرچ کیا ہے۔ جھوٹی شیخی بگھارنے سے کچھ فائدہ نہیں۔]
  90,8,"بھلا ہم نے نہیں دیں اُسکو دو آنکھیں {1}.",1:[کیا ہم نے اس کو دو آنکھیں نہیں دیں:یعنی جس نے دیکھنے کو آنکھیں دیں، کیا وہ خود دیکھتا نہ ہوگا؟ یقینًا جو سب کو بینائی دے وہ سب سے بڑھ کر بینا ہونا چاہیئے۔]
  90,9,"اور زبان اور دو ہونٹ {1}.",1:[کیا زبان اور ہونٹ نہیں بنائے:جن سے بات کرنے اور کھانے پینے میں مدد لیتا ہے۔]
  91,4,"اور رات کی جب اسکو ڈھانک لیوے {1}.",1:[مخلوقات کی قسمیں:یعنی جب رات کی تاریکی خوب چھاجائے اور سورج کی روشنی کا کچھ نشان دکھائی نہ دے۔]
  91,5,"اور آسمان کی اور جیسا کہ اُسکو بنایا {1}.",1:[مخلوقات کی قسمیں:یعنی جس شان و عظمت کا اس کو بنایا۔ اور بعض کے نزدیک مَابَنٰھَا سے مراد اس کا بنانے والا ہے۔]
  91,6,"اور زمین کی اور جیسا کہ اُسکو پھیلایا {1}.",1:[مخلوقات کی قسمیں:یعنی جس حکمت سے اس کو پھیلا کر مخلوق کی بودوباش کے قابل کیا۔ یہاں بھی بعض نے مَاطَحٰھَا سے اس کا پھیلانے والا مراد لیا ہے۔]
  92,1,"قسم رات کی جب چھا جائے"
  92,2,"اور دن کی جب روشن ہو"
  92,3,"اور اُسکی جو اُس نے پیدا کئے نر اور مادہ"
