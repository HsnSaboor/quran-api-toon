quran[9]{c,v,t,f}:
  41,12,"پھر کر دیے وہ سات آسمان دو دن میں {1} اور اتارا ہر آسمان میں حکم اُس کا {2} اور رونق دی ہم نے سب سے ورلے آسمان کو چراغوں سے اور محفوظ کر دیا یہ سادھا ہوا ہے زبردست خبردار کا {3}.",1:[<strong class=h>ہر آسمان کو اسکے حکم کی وحی:</strong>یعنی جو حکم جس آسمان کے مناسب تھا۔],2:[حضرت شاہ صاحبؒ لکھتے ہیں "یہ رب کو معلوم ہے کہ وہاں کون مخلوق بستی ہے اور انکا کیا اسلوب (اور رنگ ڈھنگ) ہے اتنی زمین میں ہزاراں ہزار کارخانے ہیں،],3:[تو اتنے بڑے آسمان کب خالی پڑے ہوں گے"۔]
  41,13,"پھر اگر وہ ٹلائیں تو تو کہہ میں نے خبر سنادی تمکو  ایک سخت عذاب کی جیسے عذاب آیا عاد اور ثمود پر {1}.",1:[یعنی کفار مکہ اگر ایسی عظیم الشان آیات سننے کے بعد بھی نصیحت قبول کرنے اور توحید و اسلام کی راہ اختیار کرنے سے اعراض کرتے رہیں تو فرما دیجئے کہ میں تم کو آگاہ کرتا ہوں کہ تمہارا انجام بھی "عاد" و "ثمود" وغیرہ اقوام معذبین کی طرح ہو سکتا ہے۔]
  41,14,"جب آئے انکے پاس رسول آگے سے اور پیچھے سے {1} کہ نہ پوجو کسی کو سوائے اللہ کے کہنے لگے اگر ہمارا رب چاہتا تو بھیجتا فرشتے سو ہم تمہارا لایا ہوا نہیں مانتے {2}.",1:[یعنی ہر طرف سے۔ شاید بہت رسول آئے ہوں گے مگر مشہور یہ ہی دو رسول ہیں۔ حضرت ہود اور حضرت صالح علی نبینا و علیہما الصلوٰۃ والسلام۔ اور یا مِنۡۢ بَیۡنِ اَیۡدِیۡہِمۡ وَ مِنۡ خَلۡفِہِمۡ سے مراد یہ ہو کہ ان کو ماضی اور مستقبل کی باتیں سمجھاتے ہوئے آئے۔ کوئی جہت اور کوئی پہلو نصیحت و فہمائش کا نہیں چھوڑا۔],2:[رسول اللہ کے بشر ہونے پر اعتراض:یعنی خدا کا رسول بشر کیسے ہو سکتا ہے ۔ اگر اللہ کو واقعی رسول بھیجنا تھا تو آسمان سے کسی فرشتہ کو بھیجتا۔ بہرحال تم اپنے زعم کے موافق جو باتیں خدا کی طرف سے لائے ہو ہم ان کے ماننے کے لئے تیار نہیں۔]
  41,15,"سو  وہ جو عاد تھے وہ تو غرور کرنے لگے ملک میں ناحق اور کہنے لگے کون ہے ہم سے زیادہ زور میں {1} کیا دیکھتے نہیں کہ اللہ جس نے انکو بنایا وہ زیادہ ہے ان سے زور میں اور تھے ہماری نشانیوں سے منکر {2}.",1:[قوم عاد کا غرور و تکبر:شاید رسولوں نے جو عذاب کی دھمکی دی ہو گی اس کے جواب میں یہ کہا کہ ہم سے زیادہ زورآور کون ہے جس سے ہم خوف کھائیں کیا ہم جیسے طاقتور انسانوں پر تم اپنا رعب جما سکتے ہو؟ حضرت شاہ صاحبؒ لکھتے ہیں "ان کے جسم بہت بڑے بڑے ہوتے تھے۔ بدن کی قوت پر غرور آیا۔ غرور کا دم بھرنا اللہ کے ہاں وبال لاتا ہے"۔],2:[یعنی دل میں ان کا حق ہونا سمجھتے تھے، مگر ضد اور عناد سے انکار کرتے چلے جاتے تھے۔]
  41,16,"پھر بھیجی ہم نے ان پر ہوا بڑے زور کی کئ دن جو مصیبت کے تھے تاکہ چکھائیں انکو رسوائی کا عذاب دنیا کی زندگانی میں {1} اور آخرت کے عذاب میں تو  پوری رسوائی ہے اور انکو کہیں مدد نہیں {2}.",1:[آندھی کا طوفان:حضرت شاہ صاحبؒ لکھتے ہیں "ان کا غرور توڑنے کو ایک کمزور مخلوق سے ان کو تباہ کرا دیا۔ سات رات اور آٹھ دن مسلسل ہوا کا طوفان چلتا رہا۔ درخت، آدمی، مکان، مواشی کوئی چیز نہ چھوڑی۔],2:[یعنی آخرت کی رسوائی تو بہت ہی بڑی ہے جو کسی کے ٹالے نہیں ٹلے گی، نہ وہاں کوئی مدد کر سکے گا۔ ہر ایک کو اپنی فکر پڑی ہو گی محبت و ہمدردی کے بڑے بڑے مدعی آنکھیں چرائیں گے۔]
  41,17,"اور وہ جو ثمود تھے سو ہم نے انکو راہ بتلائی پھر انکو خوش لگا اندھا رہنا راہ سوجھنے سے {1} پھر پکڑ  انکو کڑک نے ذلت کے عذاب کی بدلا اس کا جو کماتے تھے {2}.",1:[قوم ثمود کا اندھا پن:یعنی نجات کا راستہ جو ہمارے پیغمبر نے بتلایا تھا اس سے آنکھیں بند کر لیں اور اندھا رہنے کو پسند کیا۔ آخر اللہ تعالیٰ نے انکی پسند کی ہوئی حالت میں انہیں پڑا چھوڑ دیا۔],2:[یعنی زلزلہ آیا جس کے ساتھ سخت ہولناک آواز تھی، اس آواز سے جگر پھٹ گئے۔]
  41,18,"اور بچا دیا ہم نے ان لوگوں کو جو یقین لائے تھے اور بچ کر چلتے تھے {1}.",1:[قوم ثمود کا اندھا پن:یعنی جو لوگ ایمان لائے اور بدی کے راستہ سے بچ کر چلتے تھے انکو اللہ نے صاف بچا لیا۔ نزول عذاب کے وقت ان پر ذرا آنچ بھی نہیں آئی۔]
  41,19,"اور جس دن جمع ہوں گے دشمن اللہ کے دوزخ  پر تو انکی جماعتیں بنائی جائیں گی {1}.",1:[جہنم کے قریب کفار کی جماعتیں:یعنی ہر ایک قسم کے مجرموں کی الگ جماعت ہو گی اور یہ سب جماعتیں ایک دوسرے کے انتظار میں جہنم کے قریب روکی جائیں گی۔]
  41,20,"یہاں تک کہ جب پہنچیں اس پر بتائیں گے انکو انکے کان اور انکی آنکھیں اور انکے چمڑے جو کچھ وہ کرتے تھے {1}.",1:[کفار کے خلاف انکے اعضاء کی گواہی:دنیا میں کانوں سے آیات تنزیلیہ سنیں اور آنکھوں سے آیات تکوینیہ دیکھیں مگر کسی کو نہ مانا۔ ہر بُن مُو سے خُدا کی کی نافرمانی کرتے رہے۔ یہ خبر نہ تھی کہ گناہوں کا یہ سارا ریکارڈ خود انہی کی ذات میں محفوظ ہے جو وقت پر کھول دیا جائے گا۔ روایات سے معلوم ہوتا ہے کہ محشر میں کفار اپنے جرائم کا زبان سے انکار کریں گے۔ اس وقت حکم ہو گا کہ ان کے اعضاء کی شہادت پیش کی جائے جن کے ذریعے سے گناہ کئے تھے۔ چنانچہ ہر ایک عضو شہادت دے گا۔ اور اس طرح زبان کی تکذیب ہو جائے گی۔ تب مبہوت و حیران ہو کر اپنے اعضاء کو کہے گا (کمبختو!) دور ہو جاؤ! تمہاری ہی طرف سے تو میں جھگڑتا اور مدافعت کر رہا تھا۔ (تم خود ہی اپنے جرموں کا اعتراف کرنے لگے)]
