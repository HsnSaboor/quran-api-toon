quran[15]{c,v,t,f}:
  55,73,"پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے"
  55,74,"نہیں ہاتھ لگایا  اُنکو کسی آدمی نے اُن سے پہلے اور نہ کسی جن نے"
  55,75,"پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے"
  56,64,"کیا تم اُسکو کر تے ہو کھیتی یا ہم ہیں کھیتی کر دینے والے {1}.",footnotes:1:[زمین سے تم اگاتے ہو یا ہم:یعنی بظاہر  بیج زمین میں تم ڈالتے ہو لیکن زمین کے اندر اس کی پرورش کرنا پھر باہر نکال کر ایک لہلہاتی کھیتی بنادینا کس کاکام ہے اس کے متعلق تو ظاہری اور سطحی دعوٰی بھی تم نہیں کر سکتے کہ ہماری تیار کی ہوئی ہے۔]
  56,65,"اگر ہم چاہیں تو کر ڈالیں اُسکو روندا ہوا گھانس پھر تم سارے دن رہو باتیں بناتے"
  56,66,"ہم تو قرضدار رہ گئے"
  64,16,"سو  ڈرو اللہ سے جہاں تک ہو سکے اور سنو اور مانو {1} اور خرچ کرو اپنے بھلے کو {2} اور جسکو بچا دیا اپنے جی کے لالچ سے سو وہ لوگ وہی مراد کو پہنچے {3}.",footnotes:1:[امتحان میں کامیابی پر اجرِ عظیم:یعنی اللہ سے ڈر کر جہاں تک ہوسکے اس جانچ میں ثابت قدم رہو اور اس کی بات سنو اور مانو۔],footnotes:2:[یعنی اللہ کی راہ میں خرچ کرنے سے تمہارا ہی بھلا ہوگا۔],footnotes:3:[یعنی مراد کو وہ ہی شخص پہنچتا ہے جس کو اللہ تعالیٰ اس کے دل کے لالچ سے بچادے اور حرص و بخل سے محفوظ رکھے۔]
  64,17,"اگر قرض دو اللہ کو اچھی طرح پر قرض دینا وہ دونا کر دے تم کو اور تم کو بخشے {1} اور اللہ قدردان ہے تحمل والا {2}.",footnotes:1:[اللہ کو قرض حسنہ:یعنی اللہ کی راہ میں اخلاص اور نیک نیتی سے طیب مال خرچ کرو تو اللہ اس سے کہیں زیادہ دیگا اور تمہاری کوتاہیوں کو معاف فرمائے گا۔ اس طرح کا مضمون پہلے کئ جگہ گذر چکا ہے۔ وہیں ہم نے پوری تقریر کی ہے۔],footnotes:2:[تھوڑے عمل پر دوگنا ثواب:قدردانی کی بات یہ ہے کہ تھوڑے عمل پر بہت سا ثواب دیتا ہے، اور تحمل یہ کہ گناہ دیکھ کر فورًا عذاب نہیں بھیجتا۔ پھر بہت سے مجرموں کو بالکل معاف اور بہتیروں کی سزا میں تخفیف کرتا ہے۔]
  64,18,"جاننے والا پوشیدہ اور ظاہر کا زبردست حکمت والا {1}.",footnotes:1:[یعنی اسی کو ظاہری اعمال اور باطنی نیتوں کی خبر ہے اپنی زبردست قوت اور حکمت سے اس کے مناسب بدلہ دیگا۔]
  66,7,"اے منکر ہونے والو مت بہانے بتلاؤ آج کے دن وہی بدلا پاؤ گے جو تم کرتے تھے {1}.",footnotes:1:[آخرت میں کوئی حیلہ بہانہ نہیں چلے گا:یعنی قیامت کے دن جب جہنم کا عذاب سامنے ہوگا، اس وقت منکروں سے کہا جائے گا کہ حیلے بہانے مت بتلاؤ۔ آج کوئی بہانہ چلنے والا نہیں بلکہ جو کچھ کرتے تھے اس کی پوری پوری سزا بھگتنے کا دن ہے۔ ہماری طرف سے کوئی ظلم زیادتی نہیں۔ تمہارے ہی اعمال ہیں جو عذاب کی صورت میں نظر آرہے ہیں۔]
  66,8,"اے ایمان والو توبہ کرو اللہ کی طرف صاف دل کی توبہ {1} امید ہے تمہارا رب اتار دے تم پر سے تمہاری برائیاں اور  داخل کرے تم کو باغوں میں جنکے نیچے بہتی ہیں نہریں جس دن کہ اللہ ذلیل نہ کرے گا نبی کو اور اُن لوگوں کو جو یقین لاتے ہیں اُسکے ساتھ {2} اُنکی روشنی دوڑتی ہے اُنکے آگے اور اُنکے داہنے {3} کہتے ہیں اے رب ہمارے پوری کر دے ہماری روشنی اور معاف کر ہم کو بیشک تو سب کچھ کر سکتا ہے {4}.",footnotes:1:[توبۃ النصوح کی تعریف:صاف دل کی توبہ یہ کہ دل میں پھر گناہ کا خیال نہ رہے۔ اگر توبہ کے بعد ان ہی خرافات کا خیال پھر آیا تو سمجھو کہ توبہ میں کچھ کسر رہ گئ ہے۔ اور گناہ کی جڑ دل سے نہیں نکلی رزقنا اللّٰہ منھا حظا وافرابفضلہ وعونہ وھو علٰی کل شئ قدیر ۔],footnotes:2:[یعنی نبی ﷺ کا کہنا کیا۔ اس کے ساتھیوں کو بھی ذلیل نہ کریگا۔ بلکہ نہایت اعزارواکرام سے فضل و شرف کے بلند مناصب پر سرفراز فرمائے گا۔],footnotes:3:[اس کا بیان سورۃ "حدید" میں ہو چکا۔],footnotes:4:[یعنی ہماری روشنی آخر تک قائم رکھیے، بجھنے نہ دیجئے۔ جیسے منافقین کی نسبت سورۃ "حدید" میں بیان ہوچکا کہ روشنی بجھ جائیگی اور اندھیرے میں کھڑے رہ جائیں گے۔ مفسرین نے عمومًا یہ ہی لکھا ہے لیکن حضرت شاہ صاحبؒ  اَتْمِمْ لَنَا نُوْرَنَا کی مراد بیان کرتے ہوئے لکھتے ہیں کہ "روشنی ایمان کی دل میں ہے، دل سے بڑھے تو سارے بدن میں، پھر گوشت پوست میں "(سرایت کرے)۔]
  66,9,"اے نبی لڑائی کر منکروں سے اور دغابازوں سے اور سختی کر اُن پر {1} اور اُن کا گھر دوزخ ہے اور بری جگہ جا پہنچے {2}.",footnotes:1:[کفار پر سختی کی تاکید:حضرت ﷺکا خلق اور نرم خوئی یہاں تک بڑھی ہوئی تھی کہ اللہ تعالیٰ اوروں کو فرماتا ہے تحمل کرو۔ اور آپﷺ کو فرماتا ہے کہ سختی کرو۔],footnotes:2:[پہلے مؤمنین کا ٹھکانا بتلایا تھا۔ یہاں ان کے بالمقابل کفار و منافقین کا گھر بتلا دیا۔]
  67,4,"پھر لوٹا کر نگاہ کر  دو دو بار لوٹ آئے گی تیرے پاس تیری نگاہ رد ہو کر تھک کر {1}.",footnotes:1:[تمہاری نگاہیں تھک جائیں گی:یعنی ممکن ہے ایک آدھ مرتبہ دیکھنے میں نگاہ خطا کر جائے، اس لئے پوری کوشش سے باربار دیکھ، کہیں کوئی رخنہ دکھائی نہیں دیتا خوب غوروفکر اور نظر کر کہ قدرت کے انتظام میں کہیں انگلی رکھنے کی جگہ تو نہیں۔ یاد رکھ ! تیری نگاہ تھک جائیگی اور ذلیل ودرماندہ ہو کر واپس آ جائیگی۔ لیکن خدائی مصنوعات و انتظامات میں کوئی عیب و قصور نہ نکال سکے گی۔]
  67,5,"اور ہم نے رونق دی سب سے ورلے آسمان کو چراغوں سے {1} اور اُن سے کر رکھی ہے ہم نے پھینک مار شیطانوں کے واسطے {2} اور رکھا ہے اُنکے واسطے عذاب دہکتی آگ کا {3}.",footnotes:1:[یعنی آسمان کی طرف دیکھو! رات کے وقت ستاروں کی جگمگاہٹ سے کیسی رونق و شان معلوم ہوتی ہے۔ یہ قدرتی چراغ ہیں جن سے دنیاکے بہت سے منافع  وابستہ ہیں۔],footnotes:2:[یہ مضمون سورۃ "حجر" وغیرہ میں کئ جگہ بہت تفصیل سے گذر چکا ہے۔],footnotes:3:[یعنی دنیا میں شہاب پھینکے جاتے ہیں اور آخرت میں اُن کے لئےدوزخ کی آگ تیار ہے۔]
  67,6,"اور جو لوگ منکر ہوئے اپنے رب سے اُنکے واسطے ہے عذاب دردناک اور بری جگہ جا پہنچے {1}.",footnotes:1:[یعنی کافروں کا ٹھکانابھی شیاطین کے ساتھ اسی دوزخ میں ہے۔]
