quran[27{c,v,t}:
37,25,٢٥۔ کیا ہوا تم کو (کہ) ایک دوسرے کی مدد نہیں کرتے۔
37,26,٢٦۔ کوئی نہیں (بلکہ) ، وہ آج آپ (خود) کو پکڑواتے ہیں۔
37,27,٢٧۔ اور منہ کیا بعضوں نے بعضوں کی طرف، لگے پوچھنے (تکرار کرنے) ۔
37,28,٢٨۔ بولے، تم ہی تھے کہ آتے تھے ہم پر داہنے سے۔
37,29,٢٩۔ وہ بولے ! کوئی نہیں ! پر تم ہی نہ تھے یقین لانے والے۔
37,30,٣٠۔ اور ہمارا تم پر کچھ زور نہ تھا۔ پر تم ہی تھے لوگ بےحد چلنے والے (سرکش) ۔
37,31,٣١۔ سو ثابت ہوئی ہم پر بات ہمارے رب کی۔ (کہ اب) ہم کو مزہ چکھنا (عذاب کا) ۔
37,32,٣٢۔ پھر ہم نے تم کو گمراہ کیا، (کیونکہ) ہم تھے آپ گمراہ۔
37,33,٣٣۔ سو وہ اس دن تکلیف (عذاب) میں (ایک دوسرے کے) شریک ہیں۔
37,34,٣٤۔ ہم ایسا کچھ کرتے ہیں گنہگاروں کے حق میں۔
37,35,٣٥۔ وہ تھے، کہ ان سے جب کوئی کہتا، کسی کی بندگی نہیں سوا اللہ کے، تو غرور کرتے۔
37,36,٣٦۔ اور کہتے، کیا ہم چھوڑ دیں گے اپنے ٹھاکروں (معبودوں) کو ؟ کہے کے ایک شاعر دیوانے کے۔
37,37,٣٧۔ کوئی نہیں ! وہ لایا ہے سچا دین، اور سچ مانا ہے سب رسولوں کو۔
37,38,٣٨۔ تم کو چکھنی (ہے) دکھ والی مار (دردناک عذاب) ۔
37,39,٣٩۔ اور وہی بدلہ پاؤ گے جو کچھ تم کرتے تھے۔
37,40,٤٠۔ مگر جو بندے اللہ کے ہیں چنے ہوئے۔
37,41,٤١۔ وہ جو ہیں ان کی روزی ہے مقرر۔
37,42,٤٢۔ میوے، اور ان کی عزت ہے۔
37,43,٤٣۔ باغوں میں نعمت کے۔
37,44,٤٤۔ تختوں (بیٹھے مسندوں) پر ایک دوسرے کے سامنے۔
37,45,٤٥۔ لوگ لئے پھرتے ہیں ان کے پاس پیالے شراب نتھرے کے۔
37,46,٤٦۔ سفید رنگ مزہ دیتے پینے والوں کو۔
37,47,٤٧۔ نہ اس میں سر پھرتا (خمار) ہے، اور نہ وہ اس سے بہکتے ہیں۔
37,48,٤٨۔ اور ان کے پاس ہیں عورتیں، نیچی نگاہ رکھتیاں بڑی آنکھوں والیاں۔
37,49,٤٩۔ گویا وہ انڈے ہیں چھپے دھرے (رکھے) ۔
37,50,٥٠۔ پھر منہ کیا ایک نے دوسرے کی طرف، لگے پوچھنے۔
37,51,٥١۔ بولا، ایک بولنے والا ان میں مجھ کو تھا ایک ساتھی (ہم نشین) ۔
