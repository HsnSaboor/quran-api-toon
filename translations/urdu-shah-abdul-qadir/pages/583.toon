quran[25{c,v,t}:
78,31,٣١۔ بیشک ڈر والوں (متقیوں) کو مراد ملنی ہے۔
78,32,٣٢۔ باغ ہیں اور انگور،
78,33,٣٣۔ اور نوجوان عورتیں ایک عمر سب کی،
78,34,٣٤۔ اور پیالہ چھلکتا،
78,35,٣٥۔ نہ سنیں گے وہاں بکنا (بیہودہ بات) اور نہ مکرانا (جھوٹ) ۔
78,36,٣٦۔ بدلہ ہے، تیرے رب کا دیا حساب سے،
78,37,٣٧۔ جو رب ہے آسمانوں کا اور زمین کا اور جو ان کے بیچ ہے بڑی مہر (محبت) والا، (لیکن) قدرت نہیں کہ کوئی اس سے بات کرے۔
78,38,٣٨۔ جس دن کھڑی ہو روح اور فرشتے قطار ہو کر۔ کوئی نہیں بولتا، مگر جس کا حکم دیا رحمٰن نے، اور بولا بات ٹھیک۔
78,39,٣٩۔ وہ دن ہے تحقیق (بر حق) ، پھر جو کوئی چاہے، بنا رکھے اپنے رب کے پاس ٹھکانا۔
78,40,٤٠۔ ہم نے خبر سنا دی تم کو ایک آفت (عذاب) نزدیک کی، جس دن دیکھ لے گا آدمی جو آگے بھیجا اس کے ہاتھوں نے، اور کہے منکر کسی طرح میں مٹی ہوتا۔ ہم نے خبر سنا دی تم کو ایک آفت (عذاب) نزدیک کی، جس دن دیکھ لے گا آدمی جو آگے بھیجا اس کے ہاتھوں نے،
79,1,١۔ قسم ہے ( ان فرشتوں کی) گھسیٹ لانے والوں کی (روح کو) ، ڈوب کر۔
79,2,٢۔ اور بند چھڑا دینے والوں (فرشتوں) کی، کھول کر۔
79,3,٣۔ اور پیرنے (تیرنے) والوں کی پیرنے (تیرنے) پر۔
79,4,٤۔ پھر آگے بڑھتے (سبقت لے جاتے) دوڑ کر۔
79,5,٥۔ پھر کام بتاتے حکم (احکام الٰہی) سے۔
79,6,٦۔ جس دن کانپے کانپنے والی (زمین) ،
79,7,٧۔ اس کے پیچھے دوسری (دوسرا جھٹکا) ۔
79,8,٨۔ کتنے دل اس دن دھڑکتے ہیں۔
79,9,٩۔ ان کے تیور خوفزدہ ہیں۔
79,10,١٠۔ لوگ کہتے ہیں : کیا ہم پھر آئیں گے الٹے پاؤں (پہلی حالت میں) ؟
79,11,١١۔ کیا جب ہو چکیں ہم ہڈیاں کھوکھری (کھوکھلی) ؟
79,12,١٢۔ بولے تو تو یہ پھر آنا ٹوٹا (خسارہ) ہے۔
79,13,١٣۔ سو وہ تو ایک جھڑکی (ڈانٹ) ہے۔
79,14,١٤۔ پھر تبھی وہ آ رہے میدان (حشر) میں۔
79,15,١٥۔ کچھ پہنچی ہے تجھ کو بات موسیٰ کی ؟
