quran[7{c,v,t}:
6,125,١٢٥۔ سو جس کو اللہ چاہے کہ راہ دے، کھول دے اس کا سینہ حکم برداری کو۔ اور جس کو چاہے کہ راہ سے بھلا دے اس کا سینہ کر دے تنگ خفہ (گھٹا ہوا) ، گویا زور سے چڑھتا ہے آسمان پر۔ اسی طرح ڈالے گا اللہ عذاب یقین نہ لانے والوں پر۔
6,126,١٢٦۔ اور یہ ہے راہ ترے رب کی سیدھی۔ ہم نے کھول (واضح کر) دیئے نشان دھیان (نصیحت قبول) کرنے والوں کو۔
6,127,١٢٧۔ ان کو ہے سلامتی کا گھر اپنے رب کے ہاں، اور وہ ان کا مددگار ہے، بدلہ ان کے کئے کا۔
6,128,١٢٨۔ اور جس دن جمع کریں گے ان سب کو۔ اے جماعت جنوں کی ! تم نے بہت کچھ لیا (بہکا کر) انسانوں سے۔ اور بولے ان کے دوستدار انسان، اے رب ہمارے ! کام نکالا ہم میں ایک نے دوسرے سے اور پہنچے اپنے وعد، کو، جو تو نے ہمارا ٹھہرایا تھا۔ فرما دے گا آگ ہے گھر تمہارا، رہا کرو اس میں، مگر جو چاہے اللہ، (بیشک) تیرا رب حکمت والا خبردار ہے۔
6,129,١٢٩۔ اور اس طرح ہم ساتھ ملا دیں گے گنہگاروں کو ایک دوسرے کا، بدلہ ان کی کمائی کا۔
6,130,١٣٠۔ اے جماعت جنوں اور انسانوں کی کیا تم کو نہیں پہنچے تھے رسول تمہارے اندر کے (جو تم میں سے تھے) ، سناتے تم کو میرا حکم اور ڈراتے یہ دن سامنے آنے سے۔ بولے، ہم نے مانے اپنے گناہ، اور ان کو بہکایا دنیا کی زندگی نے، اور قائل ہوئے اپنے گناہ پر، کہ وہ تھے منکر۔
6,131,١٣١۔ یہ اس واسطے کہ تیرا رب ہلاک کرنے والا نہیں بستیوں کو ظلم سے اور وہاں کے لوگ بیخبر ہوں۔
