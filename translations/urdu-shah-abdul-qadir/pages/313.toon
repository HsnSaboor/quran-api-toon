quran[25{c,v,t}:
20,13,١٣۔ اور میں نے تجھ کو پسند کیا، سو تو سنتا رہ جو حکم ہو۔
20,14,١٤۔ میں جو ہوں، میں اللہ ہوں، کسی کی بندگی نہیں سوا میرے، سو میری بندگی کر اور نماز کھڑی رکھ میری یاد کو (کے لئے) ۔
20,15,١٥۔ قیامت مقرر (یقیناً ) آنی ہے، میں چھپا رکھتا ہوں اس کو، کہ بدلہ ملے ہر جی کو جو وہ کماتا ہے۔
20,16,١٦۔ سو کہیں تجھ کو نہ روک دے اس سے، وہ جو یقین نہیں رکھتا اس کا اور پیچھے پڑا ہے اپنے مزوں کے، (اگر ایسا کیا) پھر تو پٹکا (ہلاکت میں پڑ) جائے۔
20,17,١٧۔ اور یہ کیا ہے تیرے داہنے ہاتھ میں اے موسیٰ ؟
20,18,١٨۔ بولا یہ میری لاٹھی ہے۔ اس پر ٹیکتا ہوں، اور پتے جھاڑتا ہوں اس سے، اپنی بکریوں پر، اور میرے اس میں کتنے کام ہیں اور۔
20,19,١٩۔ فرمایا، ڈال دے اس کو اے موسیٰ !
20,20,٢٠۔ تو اس کو ڈال دیا، پھر تب ہی وہ سانپ ہے دوڑتا۔
20,21,٢١۔ فرمایا پکڑ لے اس کو اور نہ ڈر۔ ہم پھیر (لوٹا) دیں گے اس کو پہلے حال پر۔
20,22,٢٢۔ اور لگا اپنے ہاتھ بازو سے کہ نکلے چٹا (سفید) ہو کر، نہ کچھ بری طرح (بغیر کسی تکلیف کے) ، ایک نشانی اور۔
20,23,٢٣۔ کہ دکھاتے جائیں ہم تجھ کو اپنی نشانیاں بڑی۔
20,24,٢٤۔ جا طرف فرعون کے، کہ اس نے سر اٹھایا (سرکش ہوگیا) ۔
20,25,٢٥۔ بولا، اے رب کشادہ کر میرا سینہ۔
20,26,٢٦۔ اور آسان کر میرا کام۔
20,27,٢٧۔ اور کھول گرہ میری زبان سے۔
20,28,٢٨۔ کہ بوجھیں میری بات۔
20,29,٢٩۔ اور دے مجھ کو ایک کام بٹانے والا، میرے گھر (خاندان) کا۔
20,30,٣٠۔ ہارون میرا بھائی۔
20,31,٣١۔ اس سے بندھا میری کمر (مضبوط کر میرے ہاتھ) ۔
20,32,٣٢۔ اور شریک کر اس کو میرے کام کا۔
20,33,٣٣۔ کہ تیری پاک ذات کا بیان کریں ہم بہت سا۔
20,34,٣٤۔ اور یاد کریں تجھ کو بہت سا۔
20,35,٣٥۔ تو تو ہے ہم کو خوب دیکھتا۔
20,36,٣٦۔ فرمایا، ملا تجھ کو تیرا سوال اے موسیٰ ۔
20,37,٣٧۔ اور احسان کیا ہم نے تجھ پر ایک بار اور،
