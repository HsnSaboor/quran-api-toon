quran[27{c,v,t}:
37,127,١٢٧۔ پھر اس کو جھٹلایا، سو وہ پکڑے آتے ہیں۔
37,128,١٢٨۔ مگر جو بندے ہیں اللہ کے چنے۔
37,129,١٢٩۔ اور باقی رکھا اس پر پچھلی خلق میں۔
37,130,١٣٠۔ کہ سلام ہے الیاس پر۔
37,131,١٣١۔ ہم یوں دیتے ہیں بدلہ نیکی کرنے والوں کو۔
37,132,١٣٢۔ وہ ہے ہمارے بندوں ایماندار میں۔
37,133,١٣٣۔ اور تحقیق (بلاشبہ) لوط ہے رسولوں میں۔
37,134,١٣٤۔ جب بچا دیا ہم نے اس کو اور اس کے گھر والوں کو سارے۔
37,135,١٣٥۔ مگر ایک بڑھیا رہ گئی (پیچھے) رہنے والوں میں۔
37,136,١٣٦۔ پھر اکھاڑ مارا ہم نے دوسروں کو۔
37,137,١٣٧۔ اور تم گذرتے ہو ان پر صبح کے وقت۔
37,138,١٣٨۔ اور رات کو (بھی) ۔ پھر (بھی) کیا (تم) نہیں بوجھتے (سمجھتے) ؟
37,139,١٣٩۔ اور تحقیق (بلاشبہ) یونس ہے رسولوں میں۔
37,140,١٤٠۔ جب بھاگ کر پہنچا اس بھری کشتی پر۔
37,141,١٤١۔ پھر قرعہ ڈلوایا، تو ہوگیا الزام کھایا (ہار گیا) ۔
37,142,١٤٢۔ پھر لقمہ کیا اس کو مچھلی نے، اور وہ الاہنا کھایا (ملامت زدہ) تھا۔
37,143,١٤٣۔ پھر اگر نہ ہوتا کہ وہ تھا یاد کرتا پاک ذات کو۔
37,144,١٤٤۔ تو رہتا اس کے پیٹ میں، جس دن تک مردے جیویں۔
37,145,١٤٥۔ پھر ڈال دیا ہم نے اس کو پٹپڑ (چٹیل) میدان میں اور وہ بیمار تھا۔
37,146,١٤٦۔ اور اگایا ہم نے اس پر ایک درخت بیل کا (بیلدار) ۔
37,147,١٤٧۔ اور بھیجا اس کو لاکھ آدمیوں پر یا زیادہ۔
37,148,١٤٨۔ پھر وہ یقین لائے، پھر ہم نے ان کو برتنے (فائدہ) دیا ایک وقت تک۔
37,149,١٤٩۔ اب ان سے پوچھ، کیا تیرے رب کے ہاں بیٹیاں اور ان کے ہاں بیٹے۔
37,150,١٥٠۔ یا ہم نے بنایا فرشتوں کو عورت، اور یہ دیکھتے تھے۔
37,151,١٥١۔ سنتا ہے ! یہ اپنا جھوٹ بنایا کہتے ہیں۔
37,152,١٥٢۔ کہ اللہ کی اولاد ہوئی، اور یہ بیشک جھوٹے ہیں۔
37,153,١٥٣۔ کیا پسند کیں بیٹیاں بیٹوں سے۔
