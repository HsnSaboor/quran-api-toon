quran[15{c,v,t}:
112,1,١۔ تو کہہ، وہ اللہ ایک ہے۔
112,2,٢۔ اللہ بےنیاز ہے۔
112,3,٣۔ نہ کسی کو جنا، نہ کسی سے جنا۔
112,4,٤۔ اور نہیں اس کے جوڑ کا کوئی۔
113,1,١۔ تو کہہ، میں پناہ میں آیا صبح کے رب کی۔
113,2,٢۔ ہر چیز کی بدی سے جو اس نے بنائی۔
113,3,٣۔ اور بدی سے اندھیرے کی جب سمٹ آئے۔
113,4,٤۔ اور بدی سے عورتوں کی، جو گرہوں میں پھونکیں۔
113,5,٥۔ اور بدی سے برا چاہنے والے کی جب لگے ہونسنے (حسد کرنے) ۔
114,1,١۔ تو کہہ، میں پناہ میں آیا لوگوں کے رب کی۔
114,2,٢۔ لوگوں کے بادشاہ کی۔
114,3,٣۔ لوگوں کے پوجے (معبود) کی۔
114,4,٤۔ بدی سے اس کی، جو سنکارے (وسوسہ ڈالے) اور چھپ جائے۔
114,5,٥۔ وہ جو خیال (وسوسہ) ڈالتا ہے لوگوں کے دل میں۔
114,6,٦۔ (خواہ ہو) جِنوں میں (سے) اور آدمیوں میں (سے) ۔
