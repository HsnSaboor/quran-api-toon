quran[30{c,v,t}:
78,1,١۔ کیا بات پوچھتے ہیں لوگ آپس میں ؟
78,2,٢۔ (کیا ہے) وہ بڑی خبر ؟
78,3,٣۔ جس میں وہ کئی طرف (اختلاف) ہو رہے ہیں۔
78,4,٤۔ یوں نہیں ! اب جان لیں گے۔
78,5,٥۔ پھر بھی یوں نہیں ! اب جان لیں گے۔
78,6,٦۔ (کیا) ہم نے نہیں بنائی زمین بچھونا ؟
78,7,٧۔ اور پہاڑ (اس کی) میخیں ؟
78,8,٨۔ اور تم کو بنایا جوڑے جوڑے،
78,9,٩۔ اور بنائی نیند تمہاری دفع ماندگی (باعث سکون) ،
78,10,١٠۔ اور بنائی رات اوڑھنا (پردہ پوش) ،
78,11,١١۔ اور بنایا دن روزگار کو۔
78,12,١٢۔ پھر چنی تم سے اوپر سات چنائی (آسمان) مضبوط،
78,13,١٣۔ اور بنایا ایک چراغ چمکتا،
78,14,١٤۔ اور اتارا نچڑتی بدلیوں سے پانی کا ریلا (بارش) ،
78,15,١٥۔ (تا) کہ نکالیں اس سے اناج اور سبزہ،
78,16,١٦۔ اور باغ پتوں میں لپٹ رہے۔
78,17,١٧۔ بیشک دن فیصلے کا ہے ایک وقت ٹھہر رہا (مقرر) ۔
78,18,١٨۔ جس دن پھونکیں نر سنگا (بگل، صور) ، پھر چلے آؤ جٹ جٹ (فوج در فوج) ۔
78,19,١٩۔ اور کھولا جائے آسمان، تو ہوجائیں دروازے۔
78,20,٢٠۔ اور چلائے جائیں پہاڑ، تو ہوجائیں ریت۔
78,21,٢١۔ بیشک دوزخ ہے تاک میں،
78,22,٢٢۔ شریروں کا ٹھکانا،
78,23,٢٣۔ رہتے ہیں اس میں قرنوں (مدتوں) ۔
78,24,٢٤۔ نہ چکھیں وہاں کچھ مزہ ٹھنڈک کا، اور نہ ملے کچھ پینا،
78,25,٢٥۔ مگر گرم پانی اور بہتی پیپ۔
78,26,٢٦۔ (یہ) بدلہ ہے پورا۔
78,27,٢٧۔ وہ تھے توقع نہ رکھتے (کسی) حساب کی،
78,28,٢٨۔ اور جھٹلائیں ہماری آیتیں مکرا (جھوٹ سمجھ) کر۔
78,29,٢٩۔ اور ہر چیز ہم نے گِن رکھی لکھ کر۔
78,30,٣٠۔ اب چکھو کہ ہم بڑھاتے نہ جائیں گے تم پر مگر مار (عذاب) ۔
