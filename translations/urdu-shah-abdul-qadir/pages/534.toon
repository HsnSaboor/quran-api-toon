quran[27{c,v,t}:
55,68,٦٨۔ ان میں میوہ اور کھجوریں اور انار۔
55,69,٦٩۔ پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے ؟
55,70,٧٠۔ سب باغوں میں نیک عورتیں ہیں خوبصورت۔
55,71,٧١۔ پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے ؟
55,72,٧٢۔ گوریاں رکی رہتیاں (ٹھہرائی ہوئی) خیموں میں۔
55,73,٧٣۔ پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے ؟
55,74,٧٤۔ نہیں بیاہا ان کو کسی آدمی نے ان سے پہلے، نہ کسی جِنّ نے۔
55,75,٧٥۔ پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے ؟
55,76,٧٦۔ لگے بیٹھے سبز چاندنیوں (قالینوں) پر اور چھاپے کی خوش طرح (نادر) ۔
55,77,٧٧۔ پھر کیا کیا نعمتیں اپنے رب کی جھٹلاؤ گے ؟
55,78,٧٨۔ بڑی برکت ہے نام کو تیرے رب کے جو بزرگی رکھتا ہے تعظیم والا۔ بڑی برکت ہے نام کو تیرے رب کے جو بزرگی رکھتا ہے تعظیم والا
56,1,١۔ جب ہو پڑے (پیش آئے) ہو پڑنے والی (پیش آنے والا واقعہ) ،
56,2,٢۔ نہیں اس کے ہو پڑنے میں جھوٹ،
56,3,٣۔ اتارتی ہے چڑھاتی (تہہ و بالا کرنے والا) ،
56,4,٤۔ جب لرزے زمین کپکپا کر،
56,5,٥۔ اور ٹکڑے ہوں پہاڑ ٹوٹ کر،
56,6,٦۔ پھر ہوجائیں گرد اڑتی (مانند غبار) ،
56,7,٧۔ اور تم ہوجاؤ (گروہ) تین قسم۔
56,8,٨۔ پھر داہنے والے، کیسے (خوش نصیب) داہنے والے ؟
56,9,٩۔ اور بائیں والے ؟ کیسے (بد نصیب) بائیں والے ؟
56,10,١٠۔ اور اگاڑی (سبقت لے جانے) والے سو اگاڑی (سبقت لے جانے) والے،
56,11,١١۔ وہ لوگ ہیں پاس والے (مقرب) ،
56,12,١٢۔ (رہیں گے) باغوں میں نعمت کے،
56,13,١٣۔ انبوہ (بہت) ہے پہلوں میں،
56,14,١٤۔ اور تھوڑے ہیں پچھلوں میں،
56,15,١٥۔ بیٹھے ہیں پلنگوں پر، سونے سے بنے،
56,16,١٦۔ تکیے دیئے ان پر، (بیٹھے) ایک دوسرے کے سامنے،
