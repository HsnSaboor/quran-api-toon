quran[29{c,v,t}:
37,154,١٥٤۔ کیا ہوا تم کو ؟ کیا انصاف کرتے ہو ؟
37,155,١٥٥۔ کیا تم دھیان نہیں کرتے ہو ؟
37,156,١٥٦۔ (کیا) تم پاس کوئی سند ہے کھلی ؟
37,157,١٥٧۔ تو لاؤ اپنی کتاب اگر ہو تم سچے۔
37,158,١٥٨۔ اور ٹھہرایا ہے اس میں اور جنوں میں ناتا (نسب) ۔ اور جنوں کو معلوم ہے کہ وہ پکڑے آتے ہیں۔
37,159,١٥٩۔ اللہ نرالا (پاک) ہے ان باتوں سے، جو بناتے ہیں۔
37,160,١٦٠۔ مگر جو بندے ہیں اللہ کے چنے۔
37,161,١٦١۔ سو تم اور جن کو تم پوجتے ہو۔
37,162,١٦٢۔ اس کے ہاتھ سے بہکا نہیں لے (جا) سکتے۔
37,163,١٦٣۔ مگر اسی کو جو پیٹھنے (داخل ہونے) والا ہے آگ میں۔
37,164,١٦٤۔ اور ہم میں جو ہے اس کو ایک ٹھکانا ہے مقرر۔
37,165,١٦٥۔ اور ہم جو ہیں، ہم ہی ہیں قطار باندھنے والے۔
37,166,١٦٦۔ اور ہم جو ہیں ہم ہی ہیں پاکی بولنے (تسبیح کرنے) والے۔
37,167,١٦٧۔ اور یہ تو کہتے تھے۔
37,168,١٦٨۔ اگر ہم پاس احوال ہوتا پہلے لوگوں کا۔
37,169,١٦٩۔ تو ہم ہوتے بندے اللہ کے چنے۔
37,170,١٧٠۔ سو اس سے منکر ہوگئے، اب آگے جان لیں گے۔
37,171,١٧١۔ اور پہلے ہوچکا ہمارا حکم اپنے بندوں کے حق میں، جو رسول ہیں۔
37,172,١٧٢۔ بیشک انہی کو مدد ہونی ہے۔
37,173,١٧٣۔ اور ہمارا لشکر جو ہے، بیشک وہی زبر (غالب) ہے۔
37,174,١٧٤۔ سو تو ان سے پھر یا (ان کو ان کے حال پر چھوڑ دو) ایک وقت تک۔
37,175,١٧٥۔ اور ان کو دیکھتا رہ کہ آگے (یہ بھی) دیکھ لیں گے۔
37,176,١٧٦۔ کیا ہماری آفت شتاب (جلدی) مانگتے ہیں ؟
37,177,١٧٧۔ پھر جب آ اترے گی ان کے میدان میں، تو بری صبح ہوگی ڈرائے گیوں (ہوؤں) کی۔
37,178,١٧٨۔ اور پھر یا ان سے (ان کو ان کے حال پر چھوڑ دو) ایک وقت تک۔
37,179,١٧٩۔ اور (تو) دیکھتا رہ، اب آگے (وہ بھی) دیکھ لیں گے۔
37,180,١٨٠۔ پاک ذات ہے تیرے رب کی، عزت کا صاحب، پاک ہے ان باتوں سے جو کرتے ہیں۔
37,181,١٨١۔ اور سلام ہے رسولوں پر۔
37,182,١٨٢۔ اور سب خوبی اللہ کو، جو رب ہے سارے جہان کا۔
