quran[12{c,v,t}:
97,1,١۔ ہم نے یہ (قرآن) اتارا شب قدر میں۔
97,2,٢۔ اور تو کیا سمجھا کیا ہے شب قدر ؟
97,3,٣۔ شب قدر بہتر ہے ہزار مہینے سے۔
97,4,٤۔ اترتے ہیں فرشتے اور روح اس میں اپنے رب کے حکم سے، ہر کام پر۔
97,5,٥۔ امان ہے وہ رات صبح کے نکلنے تک۔
98,1,١۔ نہ تھے وہ لوگ، جو منکر ہیں کتاب والے اور شریک والے (مشرک) باز آتے، جب تک کہ پہنچے ان کو کھلی بات۔
98,2,٢۔ (یعنی) ایک رسول اللہ کا پڑھتا ورق (صحیفے) پاک۔
98,3,٣۔ اس میں لکھی کتابیں (تحریریں) مضبوط (درست) ۔
98,4,٤۔ اور پھوٹے (بٹے فرقوں میں) جو ہیں، جن کو ملی ہے کتاب، سو جب آ چکی ان کو کھلی بات،
98,5,٥۔ اور ان کو حکم یہی ہوا کہ عبادت کریں اللہ کی،
98,6,٦۔ وہ جو منکر ہوئے کتاب والے اور شریک والے (مشرک) ، دوزخ کی آگ میں، سدا رہیں اس میں۔ وہ لوگ ہیں بدتر سب خلق (مخلوق) کے۔
98,7,٧۔ وہ لوگ جو یقین لائے اور کئے بھلے کام، وہ لوگ بہتر ہیں سب خلق (مخلوق) کے۔
