quran[25{c,v,t}:
37,52,٥٢۔ کہتا، کیا تو (ایسی باتوں پر) یقین کرتا ہے ؟
37,53,٥٣۔ کیا جب (ہم) مر گئے اور ہوگئے مٹی اور ہڈیاں، کیا ہم کو بدلہ ملنا ہے ؟
37,54,٥٤۔ کہنے لگا، بھلا تم جھانک کر دیکھو گے (خبر ہے وہ کہاں ہے) ۔
37,55,٥٥۔ پھر جھانکا تو اس کو دیکھا بیچوں بیچ دوزخ کے۔
37,56,٥٦۔ بولا قسم اللہ کی ! تو تو لگا تھا کہ مجھ کو گڑھے (ہلاکت) میں ڈالے۔
37,57,٥٧۔ اور اگر نہ ہوتا میرے رب کا فضل تو میں بھی ہوتا ان میں، جو پکڑے آئے۔
37,58,٥٨۔ کیا (یہ واقع نہیں کہ) اب ہم کو نہیں مرنا ؟
37,59,٥٩۔ مگر (سوائے) جو پہلی بار مر (ہم) چکے، اور ہم کو تکلیف نہیں پہنچنی۔
37,60,٦٠۔ بیشک یہی ہے بڑی مراد ملنی۔
37,61,٦١۔ ایسی چیزوں (کامیابی) کے واسطے، چاہئیے محنت (عمل) کریں محنت (عمل کرنے) والے۔
37,62,٦٢۔ بھلا یہ بہتر ہے مہمانی یا درخت سیہنڈ (زَقَّوم) کا۔
37,63,٦٣۔ ہم نے اس کو رکھا ہے خراب (آزمائش) کرنا ظالموں کا۔
37,64,٦٤۔ وہ ایک درخت ہے کہ نکلتا ہے دوزخ کی جڑ میں (تہ سے) ۔
37,65,٦٥۔ اس کا شگوفہ جیسے سر شیطانوں کے۔
37,66,٦٦۔ سو وہ کھائیں گے اس میں سے، پھر بھریں گے اس سے پیٹ۔
37,67,٦٧۔ پھر ان کو اس کے اوپر ملونی (آمیزش) جلتے پانی کی۔
37,68,٦٨۔ پھر ان کو لے جانا آگ کے ڈھیر (جہنم) میں۔
37,69,٦٩۔ انہوں نے پائے اپنے باپ دادے بہکے ہوئے۔
37,70,٧٠۔ سو وہ انہی کے قدموں پر دوڑتے ہیں۔
37,71,٧١۔ اور بہک چکے ہیں ان سے آگے، بہت لوگ پہلے۔
37,72,٧٢۔ اور ہم نے بھیجے ہیں ان میں ڈر سنانے والے۔
37,73,٧٣۔ اب دیکھ ! کیسا ہوا آخر ڈرائے ہوؤں کا۔
37,74,٧٤۔ مگر جو بندے اللہ کے ہیں چنے۔
37,75,٧٥۔ اور ہم کو پکارا تھا نوح نے، سو کیا خوب پہنچنے والے ہیں پکار پر۔
37,76,٧٦۔ اور بچا دیا اس کو اور اس کے گھر کو، اس بڑی گھبراہٹ سے۔
