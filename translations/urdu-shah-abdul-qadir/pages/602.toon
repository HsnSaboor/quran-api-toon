quran[14{c,v,t}:
106,1,١۔ اس واسطے کہ ہلا (مانوس کر) رکھا قریش کو،
106,2,٢۔ ہلا (مانوس کر) رکھنا ان کو کوچ (تجارتی سفر) سے جاڑے کے اور گرمی کے،
106,3,٣۔ تو چاہئیے بندگی کریں اس گھر کے رب کی،
106,4,٤۔ جس نے ان کو کھانا دیا بھوک میں، اور امن دیا ڈر میں۔
107,1,١۔ تو نے دیکھا ! وہ جو جھٹلاتا ہے انصاف ہونا،
107,2,٢۔ سو وہی ہے جو دھکیلتا ہے یتیم کو،
107,3,٣۔ اور نہیں تاکید کرتا محتاج کے کھانے پر۔
107,4,٤۔ پھر خرابی ہے ان نمازیوں کی ،
107,5,٥۔ جو اپنی نماز سے بیخبر ہیں،
107,6,٦۔ وہ جو دکھاوا کرتے ہیں۔
107,7,٧۔ اور مانگے نہ دیں برتنے کی چیز۔
108,1,١۔ ہم نے تم کو دی کوثر۔
108,2,٢۔ سو نماز پڑھ اپنے رب کے آگے، اور قربانی کر۔
108,3,٣۔ بیشک جو بیری (دشمن) ہے تیرا، وہی رہا پیچھا کٹا (بے نام و نشان) ۔
