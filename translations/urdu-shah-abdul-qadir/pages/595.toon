quran[29{c,v,t}:
91,1,١۔ قسم ہے سورج کی اور اس کی دھوپ چڑھنے کی،
91,2,٢۔ اور چاند کی جب آئے اس کے (سورج) پیچھے،
91,3,٣۔ اور دن کی جب اس کو روشن کرے،
91,4,٤۔ اور رات کی، جب اس کو ڈھانپ لے،
91,5,٥۔ اور آسمان کی، اور جیسا اس کو بنایا،
91,6,٦۔ اور زمین کی، اور جیسا اس کو پھیلایا،
91,7,٧۔ اور جی (نفس انسانی) کی، اور جیسا اس کو ٹھیک بنایا،
91,8,٨۔ پھر سمجھ دی اس کو ڈھٹائی (بدی) کی، اور بچ چلنے (پرہیزگاری) کی۔
91,9,٩۔ مراد کو پہنچا جس نے اس کو سنوارا۔
91,10,١٠۔ اور نامراد ہوا، جس نے اس کو خاک میں ملایا۔
91,11,١١۔ جھٹلایا ثمود نے اپنی شرارت سے،
91,12,١٢۔ جب اٹھ کھڑا ہوا ان میں بڑا بدبخت۔
91,13,١٣۔ پھر کہا ان کو اللہ کے رسول نے خبردار ہو اللہ کی اونٹنی سے، اور اس کے پینے کی باری سے !
91,14,٤۔ پھر انہوں نے اس کو جھٹلایا، پھر وہ کاٹ (ہلاک کر) ڈالی، پھر الٹ مارا ان پر ان کے رب نے (بسبب) ان کے گناہ سے، پھر برابر کردیا
91,15,١٥۔ اور وہ نہیں ڈرتا کہ پیچھا کریں گے۔
92,1,١۔ قسم ہے رات کی جب چھا جائے،
92,2,٢۔ اور دن کی جب روشن ہو،
92,3,٣۔ اور اس (حکمت) کی جو اس نے پیدا کئے نر اور مادہ۔
92,4,٤۔ تمہاری کمائی بھانت بھانت (مختلف قسم) ہے۔
92,5,٥۔ جو جس نے دیا اور ڈر رکھا،
92,6,٦۔ اور سچ جانا بھلی بات کو،
92,7,٧۔ تو اس کو ہم سہج سہج پہنچا دیں گے آسانی میں۔
92,8,٨۔ اور جس نے نہ دیا، اور بےپروا رہا،
92,9,٩۔ اور جھوٹ جانا بھلی بات کو،
92,10,١٠۔ سو اس کو ہم سہج سہج پہنچا دیں گے سختی میں۔
92,11,١١۔ اور کام نہ آئے گا اس کو مال اس کا، جب گڑھے (دوزخ) میں گرے گا۔
92,12,١٢۔ ہمارا ذمہ ہے سوجھا (بتا) دینا،
92,13,١٣۔ اور ہمارے ہاتھ ہے پچھلی (آخرت) اور پہلی (دنیا) ۔
92,14,١٤۔ سو میں نے سنا دی تم کو خبر ایک تپتی آگ کی،
