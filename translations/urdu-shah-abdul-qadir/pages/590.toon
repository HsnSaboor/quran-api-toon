quran[22{c,v,t}:
85,1,١۔ قسم ہے آسمان کی جس میں برج ہیں،
85,2,٢۔ اور اس دِن (قیامت) کی جس کا وعدہ ہے،
85,3,٣۔ اور حاضر ہونے (دیکھنے) والے کی، اور جس پر حاضر ہوئیں (دیکھی جانے والی چیز کی) ۔
85,4,٤۔ مارے جائیو (ہلاک کردیئے) کھائیاں کھودنے والے ؟
85,5,٥۔ آگ بھری ایندھن سے۔
85,6,٦۔ جب (کہ) وہ اس پر (اس کے گرد) بیٹھے،
85,7,٧۔ اور جو کچھ وہ کرتے مسلمانوں سے، سامنے دیکھتے،
85,8,٨۔ اور ان سے بدلہ نہ لیتے تھے، مگر اسی کا کہ یقین لائے اللہ پر، جو زبردست ہے خوبیوں سراہا،
85,9,٩۔ جس کا راج ہے آسمانوں میں اور زمین میں۔ اور اللہ کے سامنے ہے ہر چیز۔
85,10,١٠۔ جو دین سے بھٹکانے لگے ایمان والے مردوں کو اور عورتوں کو، پھر توبہ نہ کی تو ان کو عذاب ہے دوزخ کا، اور ان کو عذاب ہے آگ لگی کا۔
85,11,١١۔ جو لوگ یقین لائے اور کیں بھلائیاں، ان کو باغ ہیں جن کے نیچے بہتی نہریں۔ یہ ہے بڑی مراد ملنی۔
85,12,١٢۔ بیشک تیرے رب کی پکڑ سخت ہے۔
85,13,١٣۔ بیشک وہی کرے (پیدا) پہلی مرتبہ اور دوسری،
85,14,١٤۔ اور وہی ہے بخشتا، محبت کرتا۔
85,15,١٥۔ مالک تخت کا بڑی شان والا۔
85,16,١٦۔ کر ڈالتا جو چاہے۔
85,17,١٧۔ کچھ پہنچی تجھ کو بات ان لشکروں کی ؟
85,18,١٨۔ فرعون اور ثمود کی۔
85,19,١٩۔ کوئی نہیں ! بلکہ منکر جھٹلاتے ہیں،
85,20,٢٠۔ اور اللہ نے ان کے گرد (ہر طرف) سے گھیرا ہے۔
85,21,٢١۔ کوئی نہیں ! یہ قرآن ہے بڑی شان والا،
85,22,٢٢۔ لکھا تختی میں جس کی نگہبانی ہے۔
