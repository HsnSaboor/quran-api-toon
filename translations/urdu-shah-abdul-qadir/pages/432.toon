quran[8{c,v,t}:
34,32,٣٢۔ کہنے لگے بڑائی کرنے والے کمزور گنے گاؤں کو، کیا ہم نے روک رکھا تھا تم کو سوجھ کی بات (ہدایت) سے ؟ تمہارے پاس پہنچے پیچھے، کوئی نہیں ! تم ہی تھے گنہگار۔
34,33,٣٣۔ وہ کہنے لگے کمزور گنے گئے، بڑائی کرنے والوں کو، کوئی نہیں ! پر فریب سے رات دن کے، جب تم ہم کو حکم کرتے، کہ ہم نہ مانیں اللہ کو اور ٹھہرائیں اس کے ساتھ برابر کے۔ اور چھپے چھپے پچھتانے لگے، جب دیکھا عذاب۔ اور ہم نے ڈالے ہیں طوق گردنوں میں منکروں کے۔ وہی بدلہ پاتے ہیں، جو کرتے تھے۔
34,34,٣٤۔ اور نہیں بھیجا ہم نے کسی بستی میں کوئی ڈرانے والا، مگر کہنے لگے ہیں وہاں کے آسودہ لوگ، ہم تمہارے ہاتھ بھیجا نہیں مانتے۔
34,35,٣٥۔ اور کہنے لگے، ہم کو زیادہ ہے مال اور اولاد، اور ہم پر آفت نہیں آنی۔
34,36,٣٦۔ تو کہہ، میرا رب ہے جو پھیلا دیتا ہے روزی جس کو چاہے، اور ماپ کردیتا ہے (جس کو چاہے) ، لیکن بہت لوگ سمجھ نہیں رکھتے۔
34,37,٣٧۔ اور تمہارے مال اور تمہاری اولاد، وہ نہیں کہ نزدیک کردیں ہمارے پاس تمہارا درجہ، پر جو کوئی یقین لایا، اور بھلا کام کیا۔ سو ان کو ہے بدلہ دونا ان کے کئے (اعمال) پر، اور وہ جھروکوں (جنت کے دریچوں) میں بیٹھے ہیں خاطر جمع (اطمینان) سے۔
34,38,٣٨۔ اور جو لوگ دوڑتے ہیں ہماری آیتوں کے ہرانے (نیچا دکھانے) کو، وہ مار میں پکڑے آتے ہیں۔
34,39,٣٩۔ تو کہہ، میرا رب پھیلا (کشادہ کر) دیتا ہے روزی، جس کو چاہے اپنے بندوں میں، اور ماپ کردیتا ہے اس کو (جس کو چاہے) ۔ اور جو خرچ کرتے ہو کچھ چیز، وہ اس کا عوض دیتا ہے، اور وہ بہتر ہے روزی دینے والا۔
