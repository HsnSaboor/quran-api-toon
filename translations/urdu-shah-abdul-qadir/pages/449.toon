quran[26{c,v,t}:
37,77,٧٧۔ اور رکھی اس کی اولاد وہی رہ جانے والی۔
37,78,٧٨۔ اور باقی رکھا اس پر (کے لئے) پچھلی خلق (نسلوں) میں۔
37,79,٧٩۔ کہ سلام ہے نوح پر سارے جہان والوں میں۔
37,80,٨٠۔ ہم یوں بدلہ دیتے ہیں نیکی والوں کو۔
37,81,٨١۔ وہ ہے ہمارے بندوں ایماندار میں۔
37,82,٨٢۔ پھر ڈبویا ہم نے دوسروں کو۔
37,83,٨٣۔ اور اسی کی راہ والوں میں ہے ابراہیم۔
37,84,٨٤۔ جب آیا اپنے رب پاس، لے کر دل نروگا (بے روگ) ۔
37,85,٨٥۔ جب کہا اپنے باپ کو، اور اس کی قوم کو تم کیا پوجتے ہو ؟
37,86,٨٦۔ کیوں جھوٹ (خود) بنائے حاکموں کو اللہ کے سوا چاہتے ہو ؟
37,87,٨٧۔ پھر کیا خیال (گمان) کیا ہے تم نے جہان کے صاحب کو ؟
37,88,٨٨۔ پھر نگاہ کی ایک بار تاروں میں۔
37,89,٨٩۔ پھر کہا میں بیمار ہوں۔
37,90,٩٠۔ پھر الٹے (واپس) گئے اس سے پیٹھ دے (الٹے پاؤں اس کو چھوڑ) کر۔
37,91,٩١۔ پھر جا گھسا ان کے بتوں میں، پھر بولا، تم کیوں نہیں کھاتے۔
37,92,٩٢۔ تم کو کیا (ہوا) ہے کہ نہیں بولتے۔
37,93,٩٣۔ پھر گھسا ان پر مارتا داہنے ہاتھ سے۔
37,94,٩٤۔ پھر لوگ آئے اس پر دوڑ کر گھبراتے۔
37,95,٩٥۔ بولا، کیوں پوجتے ہو ؟ جو آپ تراشتے ہو۔
37,96,٩٦۔ اور اللہ نے بنایا تم کو، اور جو تم بناتے ہو۔
37,97,٩٧۔ بولے چنو اس کے واسطے ایک چنائی، پھر ڈالو اس کو آگ کے ڈھیر میں۔
37,98,٩٨۔ پھر چاہنے لگے اس پر برا داؤ، پھر ہم نے ڈالا انہی کو نیچے۔
37,99,٩٩۔ اور بولا میں جاتا ہوں اپنے رب کی طرف، وہ مجھ کو راہ دے گا۔
37,100,١٠٠۔ اے رب ! بخش مجھ کو کوئی نیک بیٹا۔
37,101,١٠١۔ پھر خوشخبری دی ہم نے اس کو ایک لڑکے کی، جو ہوگا تحمل والا۔
37,102,١٠٢۔ پھر جب پہنچا اس کے ساتھ دوڑنے (کی عمر) کو، کہا اے بیٹے ! میں دیکھتا ہوں خواب میں کہ تجھ کو ذبح کرتا ہوں، پھر دیکھ (سوچ) تو، تو کیا دیکھتا (خیال رکھتا) ہے ؟ بولا اے باپ ! کر ڈال جو تجھ کو حکم ہوتا ہے۔ تو مجھ کو پائے گا اگر اللہ نے چاہا، سہارنے (صبر کرنے) والا۔
