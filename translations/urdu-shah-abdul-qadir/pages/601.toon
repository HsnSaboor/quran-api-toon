quran[17{c,v,t}:
103,1,١۔ قسم اترتے دن (زمانے) کی۔
103,2,٢۔ مقرر انسان پر ٹوٹا (خسارہ) ہے۔
103,3,٣۔ مگر جو یقین لائے اور کئے بھلے کام، اور آپس میں تقید (نصیحت) کیا سچے دین کا، اور آپس میں تقید (تلقین) کیا سہار (صبر) کا۔
104,1,١۔ خرابی ہے ہر طعنے دیتے عیب چنتے کی۔
104,2,٢۔ جس نے سمیٹا مال اور گِن گِن رکھا،
104,3,٣۔ خیال رکھتا ہے کہ اس کا مال سدا رہے گا اس کے ساتھ۔
104,4,٤۔ کوئی نہیں ! اس کو پھینکنا ہے اس روندنے والی (حطمہ) میں۔
104,5,٥۔ اور تو کیا بوجھا ؟ کون ہے روندنے والی (حطمہ) ؟
104,6,٦۔ آگ ہے اللہ کی سلگائی۔
104,7,٧۔ وہ جو جھانک لیتی ہے دل۔
104,8,٨۔ ان کو اس میں موندا (ڈھانک دیا) ہے،
104,9,٩۔ لمبے لمبے ستونوں میں۔
105,1,١۔ نہ دیکھا کیسا کیا تیرے رب نے، ہاتھی والوں سے ؟
105,2,٢۔ نہ کردیا ان کا داؤ غلط ؟
105,3,٣۔ اور بھیجے ان پر اڑتے جانور تنگ تنگ (جھنڈ) ۔
105,4,٤۔ پھینکتے ان پر پتھریاں کھنگر (کنکر) کی ؟
105,5,٥۔ پھر کر ڈالا ان کو جیسے بھس کھایا ہوا۔
