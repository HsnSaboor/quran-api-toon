quran[3]{c,v,t}:
  56,0,١۔ شروع اللہ کے نام سے جو بڑا مہربان نہایت رحم والا (ہے) ۔
  56,1,١۔ جب ہو پڑے (پیش آئے) ہو پڑنے والی (پیش آنے والا واقعہ) ،
  56,2,٢۔ نہیں اس کے ہو پڑنے میں جھوٹ،
  56,3,٣۔ اتارتی ہے چڑھاتی (تہہ و بالا کرنے والا) ،
  56,4,٤۔ جب لرزے زمین کپکپا کر،
  56,5,٥۔ اور ٹکڑے ہوں پہاڑ ٹوٹ کر،
  56,6,٦۔ پھر ہوجائیں گرد اڑتی (مانند غبار) ،
  56,7,٧۔ اور تم ہوجاؤ (گروہ) تین قسم۔
  56,8,٨۔ پھر داہنے والے، کیسے (خوش نصیب) داہنے والے ؟
  56,9,٩۔ اور بائیں والے ؟ کیسے (بد نصیب) بائیں والے ؟
  56,10,١٠۔ اور اگاڑی (سبقت لے جانے) والے سو اگاڑی (سبقت لے جانے) والے،
  56,11,١١۔ وہ لوگ ہیں پاس والے (مقرب) ،
  56,12,١٢۔ (رہیں گے) باغوں میں نعمت کے،
  56,13,١٣۔ انبوہ (بہت) ہے پہلوں میں،
  56,14,١٤۔ اور تھوڑے ہیں پچھلوں میں،
  56,15,١٥۔ بیٹھے ہیں پلنگوں پر، سونے سے بنے،
  56,16,١٦۔ تکیے دیئے ان پر، (بیٹھے) ایک دوسرے کے سامنے،
  56,17,١٧۔ لئے پھرتے ہیں ان پاس لڑکے سدا رہنے والے۔
  56,18,١٨۔ آبخورے (ساغر) اور تتَّیَّان (صراحی) ۔ اور پیالہ (جام) نتھری شراب کا،
  56,19,١٩۔ سر نہ دکھے جس سے، اور نہ بکنا (عقل بد کے) لگے،
  56,20,٢٠۔ اور میوہ جونسا چن (جسے پسند کریں) لیں،
  56,21,٢١۔ اور گوشت اڑتے جانوروں کا، جس قسم کو جی چاہے۔
  56,22,٢٢۔ اور گوریاں (حوریں) بڑی آنکھوں والیاں۔
  56,23,٢٣۔ کئی برابر (ایسی جیسے) لپٹے موتی کے۔
  56,24,٢٤۔ بدلہ اس کا جو (اعمال) کرتے تھے۔
  56,25,٢٥۔ نہیں سنتے وہاں بکنا (بے ہودہ بات) اور نہ جھوٹ لگانا،
  56,26,٢٦۔ مگر ایک بولنا سلام سلام۔
  56,27,٢٧۔ اور داہنے والے، کیسے (خوش نصیب) داہنے والے ؟
  56,28,٢٨۔ رہتے (رہیں گے) بیری کے درختوں کانٹے جھاڑے ہوؤں (بے خار) میں،
  56,29,٢٩۔ اور کیلے تہہ بر تہہ،
  56,30,٣٠۔ اور چھاؤں لمبی (دور تک پھیلی ہوئی) ،
  56,31,٣١۔ اور پانی بہایا (رواں، جاری) ،
  56,32,٣٢۔ اور میوہ بہت،
  56,33,٣٣۔ نہ ٹوٹا (ختم ہوا) اور نہ روکا (بلا روک ٹوک) ،
  56,34,٣٤۔ پھر بچھونے (نشست گاہیں) اونچے۔
  56,35,٣٥۔ ہم نے وہ عورتیں اٹھائیں (پیدا کیں) ایک اٹھان پر (نئے سرے سے) ،
  56,36,٣٦۔ پھر کیا (بنایا) ان کو کنواریاں،
  56,37,٣٧۔ پیار دلاتیاں (عاشق زار) ایک عمر کی (ہم سن) ،
  56,38,٣٨۔ (یہ ہوگا) واسطے داہنے والوں کے۔
  56,39,٣٩۔ انبوہ ہے (بہت ہوں گے) پہلوں میں
  56,40,٤٠۔ اور انبوہ ہے (بہت ہوں گے) پچھلوں میں،
  56,41,٤١۔ اور بائیں والے۔ کیسے (بد نصیب) بائیں والے ؟
  56,42,٤٢۔ آنچ (لو) کی بھاپ (لپٹ) میں، جلتے (کھولتے) پانی میں،
  56,43,٤٣۔ اور چھاؤں میں دھوئیں کی،
  56,44,٤٤۔ (جو) نہ ٹھنڈی اور نہ عزت کی (آرام دہ) ۔
  56,45,٤٥۔ وہ لوگ تھے اس سے پہلے آسودہ (خوشحال) ،
  56,46,٤٦۔ اور ضد (اصرار) کرتے اس بڑے گناہ پر،
  56,47,٤٧۔ اور تھے کہتے کیا جب ہم مر گئے اور ہوگئے مٹی اور ہڈیاں، کیا ہم کو پھر اٹھانا ہے ؟
  56,48,٤٨۔ کیا ہمارے باپ دادوں کو بھی (جو) اگلے (پہلے گزر چکے) ؟
  56,49,٤٩۔ تو کہہ، (بلاشبہ) اگلے اور پچھلے (بھی) ،
  56,50,٥٠۔ سب اکھٹے ہونے ہیں ایک دن مقرر کے وقت پر
  56,51,٥١۔ پھر تم جو چاہو، اے بہکو (گمراہ) جھٹلانے والو !
  56,52,٥٢۔ البتہ کھاؤ گے ایک درخت سیہنڈ (زقّوم) کے سے،
  56,53,٥٣۔ پھر بھرو گے اس سے پیٹ،
  56,54,٥٤۔ پھر پیو گے اس پر ایک جلتا (کھولتا) پانی،
  56,55,٥٥۔ پھر پیو گے جیسے پیئیں اونٹ تون سے (پیاسے) ۔
  56,56,٥٦۔ یہ مہمانی ہے ان کی انصاف کے دن (روز جزا) ۔
  56,57,٥٧۔ ہم (ہی) نے تم کو بنایا (پیدا کیا) ، پھر کیوں نہیں سچ مانتے۔
  56,58,٥٨۔ بھلا دیکھو جو پانی ٹپکاتے (نطفہ ڈالتے) ہو،
  56,59,٥٩۔ اب تم اس (بچہ) کو بناتے (پیدا کرتے) ہو یا ہم بنانے (پیدا کرنے والے) والے ؟
  56,60,٦٠۔ ہم نے ٹھہرا دیا تم میں مرنا، اور ہم ہار (عاجز) نہیں رہے ،
  56,61,٦١۔ اس سے کہ بدل لائیں تمہاری طرح کے اور اٹھا کھڑا (پیدا) کریں تم کو، جہاں (ایسی شکل و صورت) تم نہیں جانتے۔
  56,62,٦٢۔ اور جان چکے ہو پہلا اٹھان (پیدائش) ، پھر کیوں نہیں یاد (سبق حاصل) کرتے ؟
  56,63,٦٣۔ بھلا دیکھو تو ! جو بوتے ہو ؟
  56,64,٦٤۔ کیا تم اس کو کرتے (اگاتے) ہو کھیتی یا ہم ہیں کھیتی کرنے والے۔
  56,65,٦٥۔ اگر ہم چاہیں کہ کر ڈالیں اس کو روندن (بھس) ، پھر تم سارے دن رہو باتیں بناتے،
  56,66,٦٦۔ ہم قرضدار رہ گئے (چٹی پڑگئی) ،
  56,67,٦٧۔ بلکہ ہم بدنصیب ہوئیے،
  56,68,٦٨۔ بھلا دیکھو تو ! پانی جو تم پیتے ہو،
  56,69,٦٩۔ کیا تم نے اتارا اس کو بادل سے یا ہم ہیں اتارنے والے ؟
  56,70,٧٠۔ اگر ہم چاہیں اس کو کردیں کھارا، پھر کیوں نہیں حق مانتے ؟
  56,71,٧١۔ بھلا دیکھو تو ! آگ جو سلگاتے ہو ؟
  56,72,٧٢۔ کیا تم نے اٹھایا (پیدا کیا) اس کا درخت، یا ہم ہیں اٹھانے (پیدا کرنے) والے،
  56,73,٧٣۔ ہم نے وہ بنائے یاد دلانے کو، اور برتنے کو جنگل (حاجت) والوں کے۔
  56,74,٧٤۔ سو بول پاکی (تسبیح کر) اپنے رب کے نام کی، جو سب سے بڑا۔
  56,75,٧٥۔ سو میں قسم کھاتا ہوں تارے ڈوبنے کی،
  56,76,٧٦۔ اور یہ قسم ہے اگر سمجھو تو بڑی قسم،
  56,77,٧٧۔ بیشک یہ قرآن ہے عزت والا،
  56,78,٧٨۔ لکھا چھپی (محفوظ) کتاب میں،
  56,79,٧٩۔ اس کو وہی چھوتے ہیں جو پاک بنے ہیں،
  56,80,٨٠۔ اتارا ہے جہان کے صاحب سے۔
  56,81,٨١۔ اب کیا اس بات میں تم سستی کرتے ہو ؟
  56,82,٨٢۔ اور اپنا حصہ یہی لیتے ہو کہ تم جھٹلاتے ہو،
  56,83,٨٣۔ پھر کیوں نہ جس وقت جان پہنچے حلق کو،
  56,84,٨٤۔ اور تم اس وقت دیکھتے ہو،
  56,85,٨٥۔ اور ہم اس کے پاس ہیں تم سے زیادہ، پر تم نہیں دیکھتے۔
  56,86,٨٦۔ پھر کیوں اگر تم نہیں کسی کے حکم میں،
  56,87,٨٧۔ کیوں نہیں پھیر لیتے اس کو ؟ اگر ہو تم سچے۔
  56,88,٨٨۔ سو جو اگر وہ ہوا پاس والوں (مقربین) میں،
  56,89,٨٩۔ تو راحت ہے اور روزی ہے اور باغ نعمت کا۔
  56,90,٩٠۔ اور جو اگر وہ ہوا داہنے والوں (اصحاب الیمین) میں
  56,91,٩١۔ تو سلامتی پہنچے تجھ کو داہنے والوں سے۔
  56,92,٩٢۔ اور جو اگر وہ ہوا جھٹلانے والوں بہکوں (گمراہ) میں،
  56,93,٩٣۔ تو مہمانی ہے جلتا (کھولتا) پانی،
  56,94,٩٤۔ اور پیٹھانا (پہنچانا) آگ میں۔
  56,95,٩٥۔ بیشک یہ باتیں یہی ہے لائق یقین کے۔
  56,96,٩٦۔ سو بول پاکی (تسبیح کر) اپنے رب کے نام سے، جو سب سے بڑا۔ بیشک یہ قرآن ہے عزت والا، لکھا چھپی (محفوظ) کتاب میں، اس کو وہی چھوتے ہیں جو پاک بنے ہیں،
