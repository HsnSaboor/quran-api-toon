quran[24{c,v,t}:
37,1,١۔ قسم صف باندھنے والوں کی قطار ہو کر۔
37,2,٢۔ پھر ڈانٹنے والوں کی جھڑک کر۔
37,3,٣۔ پھر پڑھنے والوں کی یاد کر۔
37,4,٤۔ بیشک حاکم تمہارا ایک ہے۔
37,5,٥۔ رب آسمانوں کا اور زمین کا، اور جو ان کے بیچ ہے، اور رب مشرقوں کا۔
37,6,٦۔ ہم نے رونق دی ورلے (نزدیکی) آسمان کو ایک رونق، جو تارے ہیں۔
37,7,٧۔ اور بچاؤ بنایا ہر شیطان سرکش سے۔
37,8,٨۔ سن نہیں سکتے اوپر کی مجلس تک، اور پھینکے (مارے ہانکے) جاتے ہیں ہر طرف سے ،
37,9,٩۔ ہانکے (دھکارے) گئے۔ اور ان کو مار ہے ہمیشہ۔
37,10,١٠۔ مگر جو اچک لایا جھپ سے، پھر پیچھے لگا اس کو انگارہ چمکتا (شہاب ثاقب) ۔
37,11,١١۔ اب پوچھ ان سے، یہ مشکل ہیں بنانے، یا جتنی خلقت ہم نے بنائی۔ ہم ہی نے ان کو بنایا ہے ایک گارے چمکتے (لیس دار) سے۔
37,12,١٢۔ بلکہ تو رہتا ہے ( اللہ کے کرشموں سے) اچنبھے میں، اور وہ کرتے ہیں ٹھٹھے (ہنسی مذاق) ۔
37,13,١٣۔ اور جب (انہیں) سمجھائیے نہیں سوچتے (سمجھتے) ۔
37,14,١٤۔ اور جب دیکھیں کچھ نشانی، ہنسی میں ڈال دیتے ہیں۔
37,15,١٥۔ اور کہتے ہیں، اور کچھ نہیں، یہ جادو ہے کھلا۔
37,16,١٦۔ کیا جب ہم مر گئے اور ہوگئے مٹی اور ہڈیاں ؟ کیا ہم کو پھر اٹھانا ہے۔
37,17,١٧۔ کیا اور ہمارے باپ دادوں کو اگلے ؟
37,18,١٨۔ تو کہہ، ہاں ! اور تم ذلیل ہو گے۔
37,19,١٩۔ سو وہ تو یہی ہے ایک جھڑکی (زور کی آواز) ، پھر تبھی یہ لگیں گے (قبر سے اٹھ کر) دیکھنے۔
37,20,٢٠۔ اور کہیں گے اے خرابی ہماری ! یہ آیا دن۔
37,21,٢١۔ یہ ہے دن فیصلے کا جس کو تم جھٹلاتے تھے۔
37,22,٢٢۔ (حکم ہوگا) جمع کرو گنہگاروں کو، اور ان کے جوڑوں (ساتھیوں) کو، اور جو کچھ پوجتے تھے۔
37,23,٢٣۔ اللہ کے سوا، پھر چلاؤ ان کو راہ پر دوزخ کی۔
37,24,٢٤۔ اور کھڑا رکھو ان کو، ان سے پوچھنا ہے۔
