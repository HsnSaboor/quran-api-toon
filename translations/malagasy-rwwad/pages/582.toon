quran[30]{c,v,t}:
  78,1,"Ny amin'inona moa no ifanontanian'izy ireo ?"
  78,2,"Ny amin'ilay vaovao lehibe."
  78,3,"Izay tsy mampifanaraka azy ireo."
  78,4,"Tsia! Mbola ho fantatr'izy ireo."
  78,5,"Tsia! Mbola ho fantatr'izy ireo marimarina tokoa."
  78,6,"Moa ve tsy nataoko ho toeram-pialan-tsasatra ny tany?"
  78,7,"Ary ireo tendrombohitra ho toy ny andry iankinany?"
  78,8,"Ary nohariako ho lahy sy vavy ianareo."
  78,9,"Ary nataoko ho fialan-tsasatra ho anareo ny torimasonareo."
  78,10,"Ary nataoko ho toy ny firakotra ho anareo ny aizin'ny alina."
  78,11,"Ary nataoko ho fitadiavam-pivelomana ho anareo ny atoandro."
  78,12,"Ary naoriko eo amboninareo ireo lanitra fito sosona mafy orina."
  78,13,"Ary nasiako jiro manazava izay mafana sy mahery vaika."
  78,14,"Ary narotsako avy amin'ny rahona matevina ny rano sesehana."
  78,15,"Mba hampitsiriako amin'ny alalan'izany ireo voa mahavelona sy zava-maniry isan-karazany."
  78,16,"Sy ireo saha mahate ho tia."
  78,17,"Eny! Efa voafaritra ny andron'ny fitsarana."
  78,18,"Ilay andro hitsofana ny anjomara ka hahatongavanareo amin'ny andiany maro."
  78,19,"Ary ho sokafana ny lanitra ka hisian'ireo varavarana maro."
  78,20,"Ary hihetsika ireo tendrombohitra ka lasa hanana endrika mamitaka ny maso."
  78,21,"ny helo dia miambina fatratra,"
  78,22,"mba honenan'ireo mpikomy,"
  78,23,"ka hitoetra ao izy ireo an-jato taonany maro mifanesy,"
  78,24,"dia tsy hahatsapa hatsiaka na hanendry zava-pisotro mihitsy,"
  78,25,"afa tsy ny rano mangotraka sy ireo tsiranoka maimbo,"
  78,26,"izany no valin'asa tsy ara-drariny"
  78,27,"Tsy mba nieritreritra ny fitsarana farany izy ireo,"
  78,28,"nataon'izy ireo ho lainga mandrakariva ny faminaniana nalefako,"
  78,29,"Ny zava-drehetra anefa dia efa noraiketiko an-tsoratra avokoa,"
  78,30,"koa dia andramo ary! Tsy hanampy anareo na oviana na oviana Aho afa-tsy ny sazy,"