quran[17]{c,v,t}:
  103,1,"Mianiana Aho amin'ny fotoana."
  103,2,"Fa tena marina, ny olombelona dia ao anatin'ny fahaverezana."
  103,3,"Afa-tsy ireo izay nino sy nanao ny asa soa ary nifanananatra ny amin'ny fahamariana, sy nifananatra ihany koa tamim-paharetana."
  104,1,"Loza ho an'izay mpanendrikendrika sy mpifosa !"
  104,2,"Izay nanangona harena sy nanisa izany."
  104,3,"Mihevitra izy fa ny harena dia hampaharitra azy mandrakizay."
  104,4,"Tsia ! Tsy maintsy hatsipiko ao anaty Afo izy."
  104,5,"Moa fantatrao va izany Afo izany ?"
  104,6,"Izany dia Afon'I Allah miredareda !"
  104,7,"izay miantefa hatrany am-po."
  104,8,"Ka hanepotra azy ireo."
  104,9,"Ao anaty fefy mijoalajoala no sady mivelatra."
  105,1,"Moa tsy fantatrao va nanao ahoana no nanaovan'ny Tomponareo ireo olon'ny elefanta ?"
  105,2,"Moa va tsy nataony nanjavona ny teti-dratsin'izy ireo ?"
  105,3,"Ka nandefasany andiam-borona maro mifanesy izy ireo,"
  105,4,"Izay nitoraka tanimanga avy amin'ny Afobe azy ireo."
  105,5,"Ka nanao azy ireo ho toy ny ravi-mololo voatsakotsako."