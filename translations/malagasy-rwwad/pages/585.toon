quran[42]{c,v,t}:
  80,1,"Niketrona izy dia nihodina,"
  80,2,"satria tonga teo aminy ilay jamba,"
  80,3,"tsy fantatrao angamba izy tonga mba hanadio ny fanahiny! Sao dia mba misy fahatsampan-tena ao aminy,"
  80,4,"Na koa mahatsapa tena izy amin'ny fahampatsiahivana,"
  80,5,"Ho an'izay manana ny ampy kosa,"
  80,6,"dia nanatona azy am-pahazotoana ianao,"
  80,7,"nefa tsy tsininao ny tsy fahadiovany,"
  80,8,"fa izay tonga nanantona anao am-pahavitrihana kosa,"
  80,9,"sady feno fahatahorana an'I Allah,"
  80,10,"dia tsy noheverinao ny momba azy,"
  80,11,"Tsia! Aza manao toy izany intsony ianao! Raha ny tena marina ity dia fampahatsiahivana fotsiny ihany,"
  80,12,"ka izay maniry izany dia hahatsiaro,"
  80,13,"izay voarakitra ao amin'ny takelaka manan-kaja,"
  80,14,"sy manan-danja ary feno fahadiovana,"
  80,15,"eo am-pelan-tanan'ireo anjely,"
  80,16,"mendrika sy mpakato,"
  80,17,"Loza anie ho an'izay olombelona mikomy ny amin'izany,"
  80,18,"Fa avy tamin'inona moa no nahariana azy?"
  80,19,"avy tamin'ny piti-dranon'aina no nahariana azy, ary avy eo dia nofaritany ny anjaran'io olona io,"
  80,20,"ary avy eo dia nakamorainy ny lalan-kombany,"
  80,21,"Dia nampandaloviny fahafatesana izy ary nalevina,"
  80,22,"koa raha sitrak'I Allah dia mbola hatsangany amin'ny maty izy,"
  80,23,"Nefa indrisy! Fa tsy nanatanteraka ireo izay nandidiana azy izy!"
  80,24,"Aoka anefa ny olombelona handinika ireo sakafo fivelomany,"
  80,25,"nampidiniko ihany koa ny rano sesehena,"
  80,26,"Avy eo, nataoko mba hahavokatra ny tany,"
  80,27,"ka nampitsimoako avy ao ireo voa mahavelona,"
  80,28,"dia ny voaloboka sy ny anana amam-bilona,"
  80,29,"ny hazo ny oliva sy ny hazo ny antrendry"
  80,30,"ireo saha midoroboka,"
  80,31,"voankazo sy karazan'ahitra,"
  80,32,"mba hahasoa anareo sy ireo biby fiompinareo,"
  80,33,"koa rehefa ho tonga ilay antso tsy hifandrenesana,"
  80,34,"amin'ny andro izay handosiran'olombelona ny rahalahiny,"
  80,35,"ny reniny sy ny rainy;"
  80,36,"ary ny vady aman-janany."
  80,37,"ny olona tsirairay amin'izy ireo, amin'izay andro izay dia ny hahasoa ny tenany no himasoany."
  80,38,"hisy amin'izany andro izany ireo endrika feno hazavana,"
  80,39,"faly sy mirana,"
  80,40,"ao koa anefa, amin'izay andro izay, ireo endrika mihosom-bovoka,"
  80,41,"sy mivalo mainty,"
  80,42,"Izy ireo no tsy mpino sy tsy mataho-tody,"