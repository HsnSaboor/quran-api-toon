quran[3]{c,v,t}:
  114,0,Allah ke naam se jo Rehman o Raheem hai
  114,1,"kaho, mein panah mangta hon insanon ke Rab"
  114,2,insanon ke badshah
  114,3,insanon ke haqeeqi mabood ki
  114,4,uss waswasa daalnay walay ke shar se jo baar baar palat kar aata hai
  114,5,jo logon ke dilon mein was wasay dalta hai
  114,6,khuwa woh jinno mein se ho ya insanon mein se
