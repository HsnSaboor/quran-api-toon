quran[3]{c,v,t}:
  109,0,Allah ke naam se jo Rehman o Raheem hai
  109,1,keh do ke ae kafroo
  109,2,mein unn ki ibadat nahi karta jin ki ibadat tum karte ho
  109,3,aur nah tum uss ki ibadat karne walay ho jis ki ibadat mein karta hon
  109,4,aur nah mein unn ki ibadat karne wala hon jin ki ibadat tum ne ki hai
  109,5,aur nah tum uss ki ibadat karne walay ho jis ki ibadat mein karta hon
  109,6,tumahray liye tumhara deen hai aur mere liye mera deen
