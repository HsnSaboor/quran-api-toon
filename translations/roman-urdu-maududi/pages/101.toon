quran[3]{c,v,t}:
  101,0,Allah ke naam se jo Rehman o Raheem hai
  101,1,azeem haadsa !
  101,2,kya hai woh azeem haadsa ?
  101,3,tum kya jano ke woh azeem haadsa kya hai ?
  101,4,woh din jab log bikhare hue parwano ki terhan
  101,5,aur pahar rang barang ke dhunkay huway oon ki terhan hon ge
  101,6,phir jis ke plrhe bhaari hon ge
  101,7,woh dil pasand aish mein hoga
  101,8,aur jis ke plrhe halkay hon ge
  101,9,is ki jaye qarar gehri khayi hogi
  101,10,aur tumhe kya khabar ke woh kya cheez hai ?
  101,11,bharakti hui aag
