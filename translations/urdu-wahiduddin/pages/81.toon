quran[29]{c,v,t}:
  81,1,"جب سورج لپیٹ دیاجائے گا"
  81,2,"اور جب ستارے بے نور ہوجائیں گے"
  81,3,"اور جب پہاڑ چلائے جائیں گے"
  81,4,"اور جب دس مہینہ کی حاملہ اونٹنیاں آوارہ پھریں گی"
  81,5,"اور جب وحشی جانور اكٹھا ہو جائیں گے"
  81,6,"اور جب سمندر بھڑکادئے جائیں گے"
  81,7,"اور جب ایک ایک قسم کے لوگ اكٹھا کيے جائیں گے"
  81,8,"اور جب زندہ گاڑی ہوئی لڑکی سے پوچھا جائے گا"
  81,9,"کہ وہ کس قصور میں ماری گئی"
  81,10,"اور جب اعمال نامے کھولے جائیں گے"
  81,11,"اور جب آسمان کھل جائے گا"
  81,12,"اور دوزخ بھڑکائی جائے گی"
  81,13,"اور جب جنت قریب لائی جائے گی"
  81,14,"ہر شخص جان لے گا کہ وہ کیا لے کر آیا ہے"
  81,15,"پس نہیں ، میں قسم کھاتا ہوں پیچھے ہٹنے والے"
  81,16,"چلنے والے اور چھپ جانے والے ستاروں کی"
  81,17,"اور رات کی جب وہ جانے لگے"
  81,18,"اور صبح کی جب وہ آنے لگے"
  81,19,"کہ یہ ایک باعزت رسول کا لایا ہو ا کلام ہے"
  81,20,"قوت والا، عرش والے کے نزدیک بلند مرتبہ ہے"
  81,21,"اس کی بات مانی جاتی ہے،وہ امانت دار ہے"
  81,22,"اور تمھارا ساتھی دیوانہ نہیں"
  81,23,"اور اس نے اس کو کھلے افق میں دیکھا ہے"
  81,24,"اور وہ غیب کی باتوں کا حریص نہیں"
  81,25,"اوروہ شیطان مردود کاقول نہیں"
  81,26,"پھر تم کدھر جارہے ہو"
  81,27,"یہ تو بس عالم والوں کے لیے ایک نصیحت ہے"
  81,28,"اس کے لیے جو تم میں سے سیدھا چلنا چاہے"
  81,29,"اور تم نہیں چاہ سکتے، مگر یہ کہ اللہ رب االعالمین چاہے"
