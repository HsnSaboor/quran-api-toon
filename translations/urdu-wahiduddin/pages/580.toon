quran[25]{c,v,t}:
  76,26,"اور رات کوبھی اس کوسجدہ کرواور اس کی تسبیح کرو رات کے طویل حصہ میں"
  76,27,"یہ لوگ جلدی ملنے والی چیز کو چاہتے ہیں اور انھوں نے چھوڑ رکھا ہے اپنے پیچھے ایک بھاری دن کو"
  76,28,"ہم ہی نے ان کو پیداکیا اور ہم ہی نے ان کے جوڑ بند مضبوط کيے،اور جب ہم چاہیں گے انھیں جیسے لوگ ان کی جگہ بدل لائیں گے"
  76,29,"یہ ایک نصیحت ہے پس جو شخص چاہے، اپنے رب کی طرف راستہ اختیار کرلے"
  76,30,"اور تم نہیں چاہ سکتے مگر یہ کہ اللہ چاہےبے شک اللہ جاننے والا، حکمت والا ہے"
  76,31,"وہ جس کو چاہتا ہے اپنی رحمت میں داخل کرتا ہے، اور ظالموں کے لیے اس نے دردناک عذاب تیار کررکھا ہے"
  77,1,"قسم ہے ہواؤں کی جو چھوڑدی جاتی ہیں"
  77,2,"پھر وہ طوفانی رفتار سے چلتی ہیں"
  77,3,"اور بادلوں کو اُٹھاکر پھیلاتی ہیں"
  77,4,"پھر معاملہ کو جدا کرتی ہیں"
  77,5,"پھر یاد دہانی ڈالتی ہیں"
  77,6,"عذر کے طور پر یا ڈراوے کے طور پر"
  77,7,"جو وعدہ تم سے کیا جارہا ہے وہ ضرور واقع ہونے والا ہے"
  77,8,"پس جب ستارے بے نور ہوجائیں گے"
  77,9,"اور جب آسمان پھٹ جائے گا"
  77,10,"اورجب پہاڑ ریزہ ریزہ کردئے جائیں گے"
  77,11,"اورجب پیغمبر وقتِ معین پر جمع کيے جائیں گے"
  77,12,"کس دن کے لیے وہ ٹالے گئے ہیں"
  77,13,"فیصلہ کے دن کے لیے"
  77,14,"اور تم کو کیا خبر کہ فیصلہ کادن کیا ہے"
  77,15,"تباہی ہے اس دن جھٹلانے والوں کے لیے"
  77,16,"کیا ہم نے اگلوں کو ہلاک نہیں کیا"
  77,17,"پھر ہم ان کے پیچھے بھیجتے ہیں پچھلوں کو"
  77,18,"ہم مجرموں کے ساتھ ایسا ہی کرتے ہیں"
  77,19,"خرابی ہے اس دن جھٹلانے والوں کے لیے"