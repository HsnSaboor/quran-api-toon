quran[11]{c,v,t}:
  101,1,"(د زړونو) ټکوونکی."
  101,2,"څه دی (د زړونو) ټکوونکی؟"
  101,3,"او څه پوهه کړې ته چې څه دی (د زړونو) ټکوونکی؟"
  101,4,"هغه ورځ ده چې خلک به د خورو ورو پتنګانو غوندې وي."
  101,5,"او غرونه به د شيندل شويو رنګه وړيو غوندې وي."
  101,6,"نو بيا چې د چا تلې درنې شي."
  101,7,"نو هغه به په خوشحاله ژوند کې وي."
  101,8,"او د چا چې تلې سپکې شي."
  101,9,"نو د هغه د ورتګ ځای به ژوره کنده وي."
  101,10,"او ته څه خبر يې چې هغه څه ده."
  101,11,"سور اور دی."
