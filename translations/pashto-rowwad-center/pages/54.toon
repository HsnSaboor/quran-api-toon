quran[55]{c,v,t}:
  54,1,"قيامت رانېږدې شو او سپوږمۍ وچاوده."
  54,2,"او هغوى چې كومه نښانه وويني، مخ ترې واړوي، وايي دا خو له پخوا نه راروانې كوډې دي."
  54,3,"او درواغ يې ګڼي او خپلو هوسونو پسې ځي او هر كار (په خپل وخت) په ځاى كېدونكى دى."
  54,4,"او بېشكه هغوى ته له (پخوانيو) خبرونو هغه څه راغلي چې په هغو كې نصيحت (يا له كفره ايسارېدل) و."
  54,5,"د پوره هوښيارۍ خبرې، خو دې وېروونكو هم څه ګټه ونه كړه."
  54,6,"نو مخ ترې واړوه، هغه ورځ چې يو بلونكى د ډېر ناخوښه شي لور ته بلنه كوي."
  54,7,"په خړو خوارو سترګو به له قبرونو راوزي، لكه هغوى چې خواره واره ملخان وي."
  54,8,"د بلونكي خواته ځغلېدونكي وي، كافران به وايي دا يوه سخته ورځ ده."
  54,9,"له هغوى مخكې د نوح قوم (حق) درواغ وګڼلو، بيا يې زموږ بنده درواغجن وباله، وېلې لېونى او (له خلكو) ايسار شوى دى."
  54,10,"نو هغه خپل پالونکي ته دعا وكړه چې زه بالكل بې وسه شوى يم نو بدل واخله."
  54,11,"بيا موږ په زښتو ډېرو اوبو د آسمان دروازې پرانېستلې."
  54,12,"او له ځمكې مو چينې روانې كړې، نو دواړه ډوله اوبه پر يوه ټاكل شوي كار سره يو ځاى شوې."
  54,13,"او دى (نوح) مو پر دړو (تختو) او مېخونو والا (بېړۍ) سپور كړ."
  54,14,"چې زموږ تر سترګو لاندې چلېدله، د هغه چا لپاره بدله چې نا شکري يې شوى وه [د الله ناشکري شوې وه، چا چې نا شکري کړې د هغوی لپاره دا عذاب سزا وه]"
  54,15,"او په رېښتيا هغه مو د يوې نښانې په توګه پرېښوده، نو آيا څوک درس اخيستونكى شته؟"
  54,16,"نو زما عذاب او وېرول څنګه وو؟"
  54,17,"او بېشكه موږ قرآن د پوهېدلو (تلاوت) لپاره آسان كړى نو آيا څوک نصيحت اخيستونكى شته؟"
  54,18,"عاديانو هم درواغ وګڼلو نو زما عذاب او وېرول څنګه وو؟"
  54,19,"په يوه پرله پسې شومه ورځ كې مو سخته سيلۍ پرې والوزوله."
  54,20,"چې خلک به يې داسې راوېستل لكه چې د كجورو له بېخه را اېستل شوي تنې چې وي."
  54,21,"نو زما عذاب او وېرول څنګه وو؟"
  54,22,"او بېشكه موږ قرآن د پوهېدو لپاره آسان كړى نوآيا څوک نصيحت اخيستونكى شته؟"
  54,23,"ثموديانو هم وېروونكي درواغجن وګڼل."
  54,24,"نو ويل يې چې آيا موږ په خپلو كې (يوازې) د يو سړي خبره ومنو؟ بيا خو به موږ هرومرو په غلطۍ او ليونتوب كې يو."
  54,25,"آيا زموږ ترمنځ يوازې پر هغه وحي راپرېوته؟ نه، بلكې دى په خپله ډېر درواغجن او كبرجن دى."
  54,26,"دا دى سبا به هغوى پوه شي چې ډېر درواغجن كبرجن څوك دى؟"
  54,27,"بېشکه موږ د هغوى د ازمويښت لپاره يوه اوښه لېږونکي يو، نو ته يې (اى صالحه) انتظار كوه او صبر وكړه."
  54,28,"او خبر يې كړه چې دا اوبه يې ترمنځه وېشل شوې دي، هر وار څښلو ته به (خپل خاوند) حاضرېدونكى وي."
  54,29,"خو هغوى خپل ملګري ته نارې كړې نو را ويې نيوله او پښې يې ترې غوڅې كړې."
  54,30,"نو زما عذاب او وېرول څنګه وو؟"
  54,31,"بېشكه موږ پر هغوى يوه چيغه راولېږله نو داسې شول لكه د غوجل مات رامات واښه."
  54,32,"او بېشكه قرآن مو د پوهېدو لپاره آسان كړى دى نو آيا څوك عبرت اخيستونكى شته؟"
  54,33,"د لوط قوم وېروونكي درواغجن وګڼل."
  54,34,"موږ پر هغوى كاڼي وروونكى باد ور ولېږلو، (مګر) پرته د لوط له كورنۍ چې سباوون مهال مو وژغورله."
  54,35,"زموږ له خوا د لورينې په توګه. څوك چې شكر باسي موږ همداسې بدله وركوو."
  54,36,"او پرته له شکه هغوی يې زموږ له نيولو وېرولي وو خو هغوى په وېروونكو شک وکړ."
  54,37,"او له هغه يې د مېلمنو د ورسپارلو غوښتنه وکړه خو موږ يې سترګې ړندې كړې نو (اوس) زما د عذاب او وېرولو خوند وڅكئ."
  54,38,"او په رېښتيا چې سهار وختي پر هغوى يو پاتېدونكى عذاب راغلو او تباه يې كړل."
  54,39,"نو زما د عذاب او وېرولو خوند وڅكئ."
  54,40,"او په رېښتيا موږ قرآن د نصيحت لپاره آسانه كړى دى نو آيا څوك درس اخيستونكى شته؟"
  54,41,"او بېشكه فرعونيانو ته وېروونكي ورغلي وو."
  54,42,"هغوى زموږ ګردې نښانې درواغ وګڼلې نو بيا مو د برلاسي قادر (الله) په نيولو سره راګير كړل."
  54,43,"آيا ستاسو كافران تر هغوى غوره دي يا تاسو ته په پخوانيو كتابونو كې څه خلاصون راغلى دى؟"
  54,44,"(او) كه هغوى وايي چې موږ يو بل سره مرستيال غچ اخېستونكى ټولى يو؟"
  54,45,"دا ټولى به زر ماتې وخوري او شاوې به واړوي."
  54,46,"په اصل كې قيامت د هغوى د ژمنې ټاكلى وخت دى او قيامت ډېر سخت او تريخ دى."
  54,47,"بېشکه دا مجرمان په بې لارۍ او ليونتوب (يا بل اور) كې دي."
  54,48,"هغه ورځ چې هغوى پړمخ په اور كې كشول كيږي چې (اوس) د دوزخ اور د رسېدلو مزه وڅكئ."
  54,49,"بېشكه موږ هر شى په يوه ټاكلې اندازه پيدا كړي."
  54,50,"او زموږ امر پرته له يو وار بل شان نه دى، لكه د ستر ګو رپ."
  54,51,"او په رېښتيا موږ ستاسي (مخكېني) سيالان هم تباه كړي دي نو آيا څوك عبرت اخېستونكى شته؟"
  54,52,"او هر څه چې هغوى كړي په كتابو كې دي."
  54,53,"او هره وړه غټه (پېښه) ليكل شوې ده."
  54,54,"بېشكه متقيان به په باغونو او ويالو كې وي."
  54,55,"د رېښتينولۍ او عزت په مجلس كې، د لوى قدرت والا پاچا پر وړاندې."
