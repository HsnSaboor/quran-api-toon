quran[40]{c,v,t}:
  75,1,"زه د قيامت په ورځ قسم كوم."
  75,2,"او زه پر ملامتوونكي نفس قسم كوم."
  75,3,"آيا انسان دا ګومان كوي چې موږ به يې هډوكي راټول نه كړو؟"
  75,4,"ولې نه، موږ خو آن د هغو بندونو (او ګوتو سرونو) پر سم برابرولو ځواکمن يو."
  75,5,"خو (منكر) انسان غواړي چې وړاندې هم بدكارونه ترسره كړي."
  75,6,"پوښتنه كوي: چې د قيامت ورځ به كله وي؟"
  75,7,"نو كله چې سترګې خړې شي."
  75,8,"او سپوږمۍ توره شي."
  75,9,"او لمر او سپوږمۍ يو ځاى كړل شي."
  75,10,"په هغه ورځ به (دا) انسان ووايي: د تېښتې ځاى چېرې دى؟"
  75,11,"هيڅكله نه، د پناه ځاى نشته."
  75,12,"هغه ورځ (يوازې) ستا د پالونکي لور ته د تمځاى دى."
  75,13,"خبر به ورکړی شي انسان ته په دغه ورځ په هغه عمل چې مخکې یې لیږلی دی او وروسته یې پریښی دی."
  75,14,"بلكې انسان خپله هم پر ځان ليدونكى دى."
  75,15,"كه څه هم (ډېر) عذرونه وړاندې كړي."
  75,16,"ته پرې ژر ژر ژبه مه خوځوه چې بيړه پرې وكړې."
  75,17,"بېشكه د هغه جمع كول او پر تا لوستل يې زموږ پر ذمه دي."
  75,18,"نو كله چې هغه موږ ولوست، بيايې ته ورپسې لوله."
  75,19,"بيا په رېښتيا د هغه څرګند بيانول هم پر موږ دي."
  75,20,"داسې نده، بلکه تاسو د دنیا سره مینه کوئ."
  75,21,"او آخرت پرېږدئ."
  75,22,"په هغه ورځ به ځينې مخونه تازه وي."
  75,23,"خپل پالونکي ته به كتونكي وي."
  75,24,"او ځينې مخونه به هغه ورځ بدرنګه وي."
  75,25,"ګومان به كوي چې ملاماتوونكى چلند به ورسره وكړى شي."
  75,26,"هيڅكله نه، كله چې مرۍ ته (سا) ورسيږي."
  75,27,"او وويل شي: څوك دى دم چوف كوونكى؟"
  75,28,"او ګومان وكړي چې همدا بېلتون دى."
  75,29,"او پنډۍ په پنډۍ پورې ونښلي."
  75,30,"همغه ورځ ستا د پالونکي لور ته روانېدل دي."
  75,31,"هغه خو نه باور درلود او نه يې لمونځ كړى و."
  75,32,"خو درواغجن يې وباله او مخ يې واړولو."
  75,33,"بيا په (ډېره) لويۍ خپل كاله (کورنۍ) ته لاړ."
  75,34,"همدا درسره وړ دي، تا سره ښايي."
  75,35,"بيا هم ستا وړ دي، له تا سره ښايي."
  75,36,"آيا انسان دا ګڼي چې خوشې (چيټي) به پرېښودل شي؟"
  75,37,"آيا هغه د منۍ يو څاڅكى نه و چې څڅول كيږي (په رحم کې)."
  75,38,"بيا د وينو يوه ټوټه شو نو الله جوړ او سم برابر كړ."
  75,39,"بيايې له هغه څخه جوړه پيدا كړه، نارينه او ښځينه."
  75,40,"آيا هغه پر دې نه دى قادر چې مړي راژوندي كړي؟"
