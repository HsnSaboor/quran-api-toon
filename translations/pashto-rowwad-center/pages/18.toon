quran[110]{c,v,t}:
  18,1,"ثنا ستاينه الله ته ده چې پر خپل بنده دغه كتاب نازل كړ او په هغه كې يې كوم كوږوالى پرېنښود."
  18,2,"سم برابر دى، تر څو (خلک) د هغه (الله) له سخت عذاب څخه ووېروي، او هغو مومنانو ته چې سم كارونه كوي، زېرى وركړي چې يقيناً دوى لره ډېره ښه بدله (د جنت) ده."
  18,3,"په هغه كې به تر تله پاتې کېدونكي وي."
  18,4,"او هغه كسان هم ووېروي چې وايي: الله زوى نیولی."
  18,5,"په دې كې نه دوى څه پوهه لري، نه يې پلرونه، ډېره لويه (غلطه) خبره يې له خولي راوځي، خو پرته له دروغو بل څه نه وايي."
  18,6,"نو ښايې ته له ډېره غمه د هغوى په وروسته ګرځېدو د خپل ځان وژونكى يې، كه په دې خبره يې ايمان رانه وړلو."
  18,7,"څه چې پر دې ځمكه دي هغه مو د هغې لپاره ښكلا ګرځولې، تر څو هغوى وازميو چې كوم يو يې په عمل كې ډېر غوره دى."
  18,8,"او څه چې پر هغې دي، يقيناً موږ يې هوار ډاګ جوړونكي يو."
  18,9,"آيا ته انګېرې چې د سمڅې او تختې والا زموږ له عجيبه نښانو څخه دي؟"
  18,10,"كله چې هغو زلميانو سمڅې ته پناه يوړه نو ويې ويل: زموږ ربه! له خپل لوري دې موږ ته رحمت راكړه او په (دې) كار كې مو سمون راوله."
  18,11,"نو هغوى مو په هماغې سمڅه كې یو شمېر كلونو پورې په درانده خوب ويده كړل."
  18,12,"بيا مو را پاڅول ترڅو وګورو د هغو له دوو ډلونه كومه يوه د خپلې استوګنې موده ښه شميرلاى شي."
  18,13,"موږ یې ریښتیني کیسه درته کوو، هغوى څو تنه زلميان وو چې پر خپل پروردګار يې ايمان راوړى و او موږ یې هدايت لا ور زیات کړ."
  18,14,"او د هغوى زړونه مو لا هغه مهال ورټينـګ كړي و كله چې دوى پاڅېدل او ويې ويل: زموږ رب خو هماغه د آسمانو او ځمكې رب دى، هېڅكله به له هغه پرته بل معبود راونه بولو، كنه بيا خو به مو ډېره غلطه خبره كړي وي."
  18,15,"زموږ دې قوم خو د الله نه پرته نور معبودان نيولي دي، د هغوى لپاره ولې كوم څرګند دليل نه راوړي؟ نو څوک به له هغه چا ډېر ظالم وي چې الله پورې دروغ تړي؟"
  18,16,"نو كله چې تاسو له دوى او له هغو چې دوى يې الله نه پرته لمانځي، ګوښه شوئ نو هغې سمڅې ته پناه يوسئ، ستاسو رب به خپل رحمت درباندې راخپور كړي او ستاسو چارو ته به سمون راوړي."
  18,17,"او كله چې لمر راخېژي نو ته به ګورې چې د دوى سمڅه پرېږدي، ښۍ خواته ترې اوړي او چې پرېوځي نو په كيڼه خوا ترې اوړي او هغوى يې په يوه ارت (پراخه) ميدان كې دي دا د الله له نښانو (يوه) ده. چاته چې الله نېغه لار وښوده نو هماغه لار موندونكى دى او څوک چې یې بې لارې كړي نو بيا به كوم لارښود ملګرى ورته ونه مومې."
  18,18,"او ته به يې ويښ ګڼي خو هغوى ويده دي او موږ يې په ښي او كيڼ لوري اړوو را اړوو اوسپى يې د غار په خوله كې غوړولې څنګلې پروت دى كه (يو ځل) سر ورښكاره كړې نو خامخا به په تېښته ترې راوګرځې او ډېر به يې له وېرې ډک شې."
  18,19,"او په همدې (عجيبه) توګه مو راويښ هم كړل چې خپلو كې سره وپوښتي، نو يوه يې وويل: څومره به (دلته) ځنډېدلي ياست؟ ويلې يوه يا نيمه ورځ، بيا يې سره وويل: الله ښه پوه دى چې څومره ځنډېدلي ياست، خو يو كس مو له دغو سپينو روپيو سره ښار ته واستوئ چې وګوري كوم يوه سره ښه پاک خواړه دي نو بيا دې له هماغه نه څه خواړه درته راوړي او نرمي او هوښياري دې كوي او هېڅوک دې نه درباندې خبروي."
  18,20,"ځكه چې دوى كه درباندې خبر او برلاسي شول نو يا به مو سنګسار كوي يا به مو د هغوى دين ته وراړوي او بيا به هېڅكله بريالي نه شئ."
  18,21,"او همداسې مو (خلک) پرې خبر كړل، څو وپوهېږي چې د الله وعده ریښتينې ده او دا چې په قيامت كې شک نشته، كله چې دوى په دې كې سره شخړه كوله نو ځينو وويل: په دوى يو دېوال جوړ كړئ، رب يې ډېر ښه پرې عالم دى خو هغو كسانو چې د دوى په كار برلاسي شوي وو، وويل: خامخا به يو مسجد (عبادت ځاى) پرې جوړوو."
  18,22,"ځينې به ووايي هغوى درې وو، څلورم يې سپى دى، ځينې به وايي پنځه دي شپږم يې سپى دى، (دا ټول) د غیبو ګزارونه (بې دليله خبرې) دي، او ځينې به وايي اوه دي، اتم يې سپى دى، ورته ووايه: زما رب يې په شمېر ډېر ښه پوه دى، له كمو خلكو پرته بل چاته نه دي معلوم، نو د هغوى په هكله له سرسري خبرو پرته چا سره چېړ مه كوه اومه له هېچا د دوى په هكله فتوىٰ غواړه."
  18,23,"او د يو شي په هكله دا مه وايه چې زه به سبا خامخا دا (كار) كوم."
  18,24,"پرته له دې چې د الله اراده وشي، او كله چې درنه هېر شي نو خپل رب دې يادوه او دا وايه چې: ښايي خپل رب مې د نېكۍ خواته د ډېرې نږدې لارې ښوونه راته وكړي."
  18,25,"او هغوى په خپله سمڅه كې درې سوه كاله پاتې شول، او دوى نهه نور هم پرې ورزيات كړي دي."
  18,26,"ورته ووايه: الله ډېر ښه ورباندې پوه دى چې دوى څومره ځنډېدلي دي، د آسمانونو او ځمكې غيب ټول هغه لره دي، څومره ښه ليدونكى او اورېدونكى دى، له هغه پرته دوى لره څوک دوست نشته او نه په خپله واكمنۍ كې څوک شريكوي."
  18,27,"او (يوازې) هماغه څه ولوله چې ستا د رب له كتابه درته وحى شوي، د الله د خبرو هېڅ بدلوونكى نشته او نه به هېڅكله له هغه پرته بل د پناه ځاى ومومې."
  18,28,"او خپل ځان دې له هغو خلكو سره ټينـګ كړه چې سبا بېګا خپل رب رابولي، د هغه رضا غواړي او له هغوى سترګې مه اړوه، آيا ته د دنيايي ژوند ښكلا غواړې؟ او د داسې كس مه منه چې موږ د هغه زړه له خپله ياده غافل كړى او په خپل هوس پسې روان شوى او كار يې (يو مخ) تباهي او زياتى دى."
  18,29,"او ووايه دا حق دى ستاسو د رب له خوا، نو څوک چې غواړي ودې مني او څوک چې غواړي نه دې مني، يقيناً موږ ظالمانو ته داسې اور چمتو كړى چې پردې يې له هغوى نه راچاپېر دي او كه (له تندې) فرياد كوي نو په داسې اوبو به يې پالنه وشي لكه د تېلو خټ چې مخونه وريتوي، (دا) ډېر بد څښاك او ناوړه استوګنځى دى."
  18,30,"يقيناً هغه خلک چې ايمان يې راوړى او سم كارونه يې كړي، نو موږ خو د هغه چا اجر نه ضايع كوو چې په عمل كې غوره وي."
  18,31,"هغوى لپاره همېشني جنتونه دي چى لاندې به يې ويالې بهيږي، هلته به د سرو زرو په وښيو (بنګړو) سينګار كړى شي او د نريو ورېښمو او اطلسو (مخملو) شنې جامې به واغوندي، هلته به يې پر تختونو تكيه وهلې وي، ډېر ښه اجر او غوره استوګنځى دى."
  18,32,"او هغوى ته يو مثال بيان كړه، لكه دوه تنه سړي وو، چې يوه ته يې موږ د انګورو دوه باغونه وركړي او هغه مو د كجورو په ونو پوښلي وو او د هغو ترمنځ مو كرونده پيدا كړې وه."
  18,33,"دواړو باغونو به خپلې مېوې پوره وركولې او هېڅ شى به يې نه ترې كمول، او د هغو په منځ كې مو يوه وياله هم وبهوله."
  18,34,"او (ښه) مېوه يې درلوده، نو هغه خپل ملګري ته په خبرو اترو كې وويل: زه له تانه هم په مال كې زيات او هم په مېړونو (کسانو) كې پتمن يم."
  18,35,"او خپل باغ ته ننوتلو په داسې حال كې چې پر خپل ځان ظلم كوونكى و، وېلې: زه خو ګومان نه كوم چې دا به كله هم پناه شي."
  18,36,"او ګومان نه كوم چې قيامت دې راتلونكى وي او خامخا كه خپل رب ته ورستون كړى شوم نو حتماً به له دې هم لاغوره ځاى بيا مومم."
  18,37,"ملګري يې په خبرو اترو كې ورته وويل: آيا له هغه ذاته منكر شوې چې ته يې له خاورې بيا له نطفې پيدا او وروسته يې سم روغ سړى جوړ كړې."
  18,38,"لیکن هماغه الله زما پالونکی دی، او خپل پالونکي سره هېڅوک هم نه شریکوم."
  18,39,"او كله چې ته خپل باغ ته ننوتې، ولې دې ونه ويل: ما شاء الله د الله نه پرته بل ځواک نشته، كه ته مې لا هم په مال او اولاد كې له ځانه كم ګڼي."
  18,40,"نو لرې نه ده چې رب مې ستا له باغه ماته غوره څه راكړي او (ستا) په هغه له اسمانه كوم آفت راكوز كړي چې ښویه ميدان وګرځي."
  18,41,"يا يې اوبه (په زمكه) ډوبې شې او بيا يې په هېڅ شان ونه لټولاى شې."
  18,42,"او (همداسې وشول) مېوه يې (ټوله) تباه شوه نو سبا يې په هغه لګښت لاسونه مروړل چې په هغه يې كړى و، او هغه (باغ) په خپلو څپرو باندې نسكور غورځېدلى و، ويلې ارمان چې له خپل رب سره مې څوک شريک نه وى ګڼلى."
  18,43,"او (بيا نو) د ده كومه داسې ډله نه وه چې مرسته يې كړې واى او نه يې خپله د ځان څه مرسته كولى شوه."
  18,44,"دلته نو ټوله واكمني الله لره ثابته شوه، هماغه (الله) هم په ثواب (وركولو) كې غوره دى او هم په انجام كې."
  18,45,"او دوى ته د دنيايي ژوند مثال بيان كړه، لكه له اسمانه چې اوبه راتويې كړو نو په دې سره د زمكې شنيلي سره ګډ شي (له ګڼوالي) او بيا سبا وچ خلي خځلې شي چې بادونه يې الوځوي او الله په هر څه قادر دى."
  18,46,"دا مال او زامن خو د دنيايي ژوند ښكلا ده او پايښت لرونكې نېكۍ ستا له رب سره هم په ثواب كې غوره دي او هم د هيلې له پلوه."
  18,47,"او هغه ورځ چې غرونه وخوځوو او زمكه لغړه ووينې او دوى (ټول) داسې راغونډ كړو چې له هغو نه يو هم پرېنږدو."
  18,48,"او (ټول به) ستا د رب حضور ته كتار كتار وړاندې كړى شي، دا دى تاسو خو داسى راته راغلئ لكه ړومبى ځل مو چې پيدا كړي وئ، بلكې تاسو لا داسې ګڼلې وه چې د وعدې هېڅ وخت به درته ونه ټاكو."
  18,49,"او (د عمل) كتاب به كېښودل شي نو ته به مجرمان ګورې چې له هغه څه نه وېرېدونكي دي، كوم چې په هغه (كتاب) كې دي او وايي به هاى زموږ بده بخته دا څنګه ليكنه ده چې (زموږ) وړه او غټه يې بې شمېرلو نه ده پريښې، او څه يې چې كړي وو حاضر به يې ومومي او ستا رب په هېچا ظلم نه كوي."
  18,50,"او كله چې موږ ملايكو ته وويل: آدم ته سجده وكړئ نو له ابليس پرته ټولو سجده وكړه، هغه له پېريانو و نو (ځكه) د خپل رب له حكمه ووت، نو آيا اوس تاسو هغه او ځوځات يې له ما پرته خپل واكمنان جوړوئ حال دا چې هغوى مو غليمان دي، هغه د ظالمانو لپاره ناوړه بدل دى."
  18,51,"هغوى مې نه د اسمانو او زمكې پيدا كولو وخت كې حاضر كړي وو او نه مې خپله د دوى په پيدا كولو كې (شريک كړي وو) او نه داسې بې لاره كوونكي خپل مرستيالان نيسم."
  18,52,"او هغه ورځ چې (الله) ووايي: (اوس) راوبلئ هغه چې ما سره مو شريكان ګڼلي وو، نو دوى به يې راوبلي خو هغوى به ځواب ورنكړي او موږ به د دوى ترمنځ د هلاكت يوه كنده منځ ته راوړو."
  18,53,"او دا مجرمان به هغه اور وويني نو يقين به يې راشي چې دوى حتماً پكې ورغورځېدونكي دي او له هغه د اړخ ته كېدو څه لورى به ونه مومي."
  18,54,"او یقینا موږ په دې قرآن كې خلكو ته هر قسم بیان کړی دی، خو انسان له هر شي زيات جګړه مار دى."
  18,55,"او كله چې خلكو ته هدايت راغى نو څه شي له دې ايسار كړل چې ايمان راوړي او خپل رب نه بخښنه وغواړي؟ پرته له دې چې (هماغه) د پخوانيو (مجرمانو) دستور (چې هلاكت دى) ورسره وشي يا مخامخ عذاب ورته راشي."
  18,56,"او موږ رسولان له دې پرته چې زېرى وركوونكي به وى، بل څه لپاره نه لېږو، او كافران د باطل په وسيله د حق له منځه وړلو لپاره جګړه كوي او زما پر آيتونو او هغو اخطارونو چې دوى ته وركړى شوي ملنډې وهي."
  18,57,"او تر هغه به لا بل كوم ظالم وي چې د خپل رب په آيتونو نصيحت ورته وشي خو دى ترې مخ واړوي او هغه څه هېر كړي چې خپلو لاسو يې وړاندې لېږلي، بې شکه موږ د هغوى په زړونو پردې اچولې چې ورباندې پوه نه شي او په غوږنو كې يې كوڼوالى دى او كه ته يې سمې لارې ته رابولي بيا هم هېڅكله، دوى لار موندونكي نه دي."
  18,58,"او ستا رب بخښونكى، د رحمت خاوند دى، كه په هغه ګناه يې نيولي واى چې كړې يې ده نو سمدلاسه به يې عذاب ورته رالېږلى و، خو هغوى لره يوه نېټه ټاکل شوې چې بيا به له هغه پرته بل د پټېدو ځاى ونه مومي."
  18,59,"او دا كلي موږ هغه وخت تباه كړل چې كله يې ظلم وكړ او د دوى د هلاكت لپاره مو يوه نېټه ټاكلې وه."
  18,60,"او كله چې موسىٰ خپل ځوان (خدمتګار) ته وويل: تر هغه به ځمه چې د دواړو سيندونو يو ځاى كېدو (سيمې) ته ورسېږم، كنه تر ډېرو زمانو به همداسې روان يم."
  18,61,"نو كله چې دواړه د سيندونو يو ځاى كېدو حد ته ورسېدل، خپل كب (ماهي) يې هېر كړ، نو (کب) په سمندر كې يې د يو سرنګ په شان خپله لار ونيوله."
  18,62,"نو كله چې تېر شول خپل ځوان (خدمتګار) ته يې وويل: راوړه هغه زموږ سبا نارى! په دې سفر كې خو له ډېرې ستومانۍ سره مخامخ شولو."
  18,63,"(ځوان خدمتګار) وویل: تا وليدل؟ كله چې هغه لوى ګټ سره مو دمه كړې وه، نو هماغلته كب رانه هېر شو، او له شيطانه پرته بل هېڅ شي نه دى رانه هېر كړى چې په ياد يې ولرم، او (كب) په عجيبه توګه سمندر كې خپله لار ونيوله."
  18,64,"موسىٰ -عليه السلام- وويل: موږ خو همدا غوښتل، نو دواړه قدم په قدم په شا راستانه شول."
  18,65,"نو زموږ له بندګانو يې يو بنده وموندلو چې هغه ته مو له خپل لوري رحمت وركړى و او له خپلې خوا مو په يو (خاص) علم پوه كړى و."
  18,66,"موسىٰ -علیه السلام- هغه ته وويل: آيا زه دې متابعت وكړم تر څو ماته هم د سمې لارې هغه علم راوښيي چې تاته دركړى شوى؟"
  18,67,"هغه وویل: ته له ماسره صبر نشې كولاى."
  18,68,"او په هغه څه به څنګه صبر وكړې چې ته نه يې ترې خبر."
  18,69,"موسىٰ -علیه السلام- وويل: ان شاء الله (که الله وغواړي) ما به صابر ومومې او په هېڅ كار كې به دې سرغړونه ونه كړم."
  18,70,"ويلې: (ښه) نو كه په ما پسې ځې، بيا به مې تر هغه په يو شي كې نه پوښتې چې ما يې خپله يادونه درته نه وي كړې."
  18,71,"نو دواړه روان شول تر دې چې په بېړۍ كې سپاره شول نو هغه (خضر) سورى پكې وكړ، (موسىٰ -علیه السلام-) وويل: د دې لپاره دې سورۍ كړه چې خلک يې ډوب كړې؟ تا خو يو سخت (بد) كار وكړ."
  18,72,"هغه وويل: نه مې و درته ويلي چې ته به ما سره صبر ونكړى شې؟"
  18,73,"(موسىٰ -علیه السلام ـ) ورته وويل: په هغه څه مې مه نيسه چې رانه هېر شوې وي او زما په (دې) كار كې سختي مه راباندې كوه."
  18,74,"بيا روان شول تر دې چې له يو هلک سره مخ شول، نو هغه يې ووژلو! (موسىٰ- علیه السلام-) وويل: آيا تا يو بې ګناه كس د بل كس د بدل نه پرته ووژلو؟ دا خو دې يو بد كار وكړ."
  18,75,"هغه وويل: ما نه وو درته ويلي چې ته ما سره صبر نه شې كولاى."
  18,76,"موسىٰ -علیه السلام- وويل: كه له دې وروسته مې په څه كې وپوښتلې نو بيا مې مه ملګرى كوه، اوس خو زما له خوا عذر درته ورسېدلې."
  18,77,"بيا روان شول، تر دې چې د يوه كلي خلكو ته ورسېدل، او د هغه ځاى له خلكو يې خواړه وغوښتل خو هغوى يې له مېلمه كولو ډډه وكړه، بيا يې (هلته) يو دېوال پكې وليد چې غورځېدو ته چمتو و، نو هغه يې نېغ كړ، (موسىٰ -علیه السلام-) وويل: كه تا غوښتي واى، په دې به دې مزدوري اخيستې وه."
  18,78,"(خضر -عليه السلام-) ووېل: همدا زما او ستا ترمنځ بېلتون دى، اوس به دې د هغو خبرو په حقيقت خبر كړم چې تا صبر نه شو پرې كولاى."
  18,79,"هر چې بېړۍ (کښتۍ) ده، نو د څو كسو مسكينانو وه چې په سمندر كې يې كار كولو نو ما وغوښتل چې عيب جنه يې كړم او ترې وړاندې يو پاچا و چې هره بېړۍ به يې په زور اخيستله."
  18,80,"او هر چې هلک و، نو مور او پلار يې مومنان وو، موږ پرې وډارېدو چې (هسې به مور او پلار) سركښۍ او كفر ته ورټېل وهي."
  18,81,"نو ومو غوښتل چې رب يې په بدل كې له هغه ډېر پاک او په صله رحمۍ كې لا ښه اولاد وركړي."
  18,82,"او هر چې دېوال دی، نو هغه د دوو يتيمانو دی په دې ښار كې، چې تر لاندې د هغوى خزانه ده او د دوى پلار يو ښه سړى و، نو ستا رب وغوښتل چې (كله) دوى ځوانۍ ته ورسيږي نو خپله خزانه به راوباسي، دا ستا د رب په رحمت سره (شوي دي) او ماله ځانه څه نه دي كړي، دا و د هغو كارونو حقيقت چې تا پرې صبر ونه شو كړاى."
  18,83,"او له تانه د ذوالقرنين په هكله پوښتنه کوي، ورته وايه زه به يې څه حال درته واوروم."
  18,84,"بې شکه موږ هغه ته په زمكه كې قدرت وركړى و او هر ډول اسباب مو وركړي وو."
  18,85,"نو روان شو په یوه لاره."
  18,86,"تر دې چې د لمر ډوبېدو تر حده ورسېدلو، او هغه يې داسې وموندلو چې په يوه توره چيكړه چينه كې ډوبيږي او ورسره يې يو قوم هم وموندو، موږ وويل: ای ذوالقرنينه! (خوښه دې) يا يې په عذاب كړه او يا ورسره ښه چلند ونيسه."
  18,87,"هغه وويل: هر هغه څوک چې له دوى نه ظلم وكړي نو موږ به هغه ته څه سزا وركړو، بيا به د خپل رب لور ته ورستون كړى شي او هغه به (لا) سخته سزا وركړي."
  18,88,"خو څوک چې ايمان راوړي او سم كارونه وكړي نو د هغه لپاره غوره بدله ده او موږ به هم په خپلو چارو كې اسانه حكم وركړو."
  18,89,"بیا په (یوه بله) لاره روان شو."
  18,90,"تر دې چې د لمر خاته حد ته ورسېدو نو هغه يې ولېدو چې په يو داسې قوم راخيژي چې له هغه نه د پټېدو څه شى مو نه و وركړى."
  18,91,"همداسې و، او له هغه سره چې څه و، موږ ته يې علم و."
  18,92,"بیا په (یوه بله) لاره روان شو."
  18,93,"تر دې چې دوو غرونو منځ ته ورسېدو، نو له هغو سره يې داسې يو قوم بياموندو چې نږدې نه وه چې (د ذوالقرنين) په خبره وپوهېږي."
  18,94,"دوی وویل: ای ذوالقرنین! بی شکه چې یاجوج او ماجوج فساد کوونکي دي په زمکه کې نو آیا موږ تاته محصول (خرچه) درکړو چې ته زموږ او د هغوی تر منځ یو غټ دېوال جوړ کړې؟"
  18,95,"هغه وويل: زما رب چې ماته د كوم شي وس راكړى، هغه غوره دى نو تاسو ما سره په (ځاني) طاقت مرسته وكړئ چې ستاسو او د هغوی ترمنځ يو دېوال جوړ كړم."
  18,96,"ماته اوسپنيزې تختېراوړئ تر دې چې هغه د دواړو غرونو ترمنځ (دېوال) برابر كړ، وېلې: (اوس) پو كړئ، تر دې چې هغه يې (بالكل) اور وګرځولو، وېلې: راوړئ چې اوس ويلې شوې تامبه (مس یا پیتل) پرې واچوم."
  18,97,"نو بيا هغوى (يأجوج او مأجوج) نه ورباندې راختلى شول او نه يې پكې سورى كولى شو."
  18,98,"(ذوالقرنين) وويل: دا زما د رب له خوا يوه مهرباني ده، نو كله چې زما د رب وعده راشي نو دا به هوار ميده ميده كړي او زما د رب وعده رښتينې ده."
  18,99,"او په هغه ورځ به خلک پرېږدو چې (د څپو په څېر) يو بل كې سره ګډ شي او شپېلۍ به پو كړى شي نو ټول به (يو ځاى) راغونډ كړو."
  18,100,"او په هماغه ورځ به كافرانو ته جهنم ورمخې ته كړو."
  18,101,"هغوى چې زما له ياده (نصيحته) يې سترګې په پردو كې وې او (حق خبره يې) اورېدلى هم نه شوه."
  18,102,"نو آيا هغه خلک چې كافر شوي دا ګومان کوي چې له ما پرته زما بندګان خپل ملګري (معبودان) ونيسي؟ د دغه شان كافرانو د مېلمستيا لپاره مو جهنم تيار كړى دى."
  18,103,"ورته ووايه: چې آيا په عمل كې تر ټولو تاواني خلک دروښيم؟"
  18,104,"هغوى (دي) چې په دنيايي ژوند كې يې ټولې هڅې بې لارې شوې دي خو دا ګومان كوي چې دوى ښه كارونه كوي."
  18,105,"دا هغه كسان دي چې د خپل رب له آيتونو او هغه سره مخامېدلو نه منكر شول او ټول عملونه يې عبث لاړل نو موږ به هغوى ته د قيامت په ورځ څه وزن ورنكړو."
  18,106,"(خبره) دا ده چې سزا د دوی جهنم ده، په دې چې كافر شوي او زما پر آيتونو او رسولانو يې ملنډې وهلې دي."
  18,107,"يقيناً هغو كسانو چې ايمان راوړى او سم كارونه يې كړي، د هغوى لپاره به د فردوس باغونه مېلمستيا وي."
  18,108,"تل به پكى اوسېدونكي وي، هېڅكله به له هغه ځايه بدلېدل ونه غواړي."
  18,109,"ووايه: كه چېرې سمندر زما د رب د خبرو سياهي شي نو هغه به هم ختمه شي، له هغه مخكې چې زما د رب خبرې پاى ته ورسېږي، كه څه هم همدومره ورسره نوره كومكي راوړو."
  18,110,"ووايه: خبره دا ده چې زه خو ستاسو په شان يو انسان يم، ماته وحى شوې چې بې شكه ستاسو معبود هماغه يو معبود دى، نو هر څوک چې له خپل رب سره د ملاقات هيله لري هغه دې سم كارونه وكړي او د خپل رب په عبادت كې دې بل هېڅوك نه شريكوي."
