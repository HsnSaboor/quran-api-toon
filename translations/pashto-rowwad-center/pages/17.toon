quran[111]{c,v,t}:
  17,1,"پاك دى هغه ذات چې يوه شپه يې خپل بنده له مسجد حرام نه تر هغه لرې مسجد (اقصی) پورې بوتللو چې د هغه چاپېريال مو بركتي كړى دى، تر څو پر هغه خپلې ځينې نښانې وګورو، په حقيقت كې هماغه د هر څه اورېدونكى او ليدونكى دى."
  17,2,"موږ له دې مخكې موسى (علیه السلام) ته كتاب وركړى و، او هغه مو د بني اسرائيلو لپاره د هدايت وسيله ګرځولى و، له دې سپارښت سره چې له ما څخه پرته بل څوک خپل معتمد (ذمه وار) مه نيسئ."
  17,3,"تاسي د هغو خلكو ځوځات (اولاده) ياست چې موږ له نوح سره په بېړۍ كې سپاره كړي وو، او نوح يو شكر كوونكى بنده و."
  17,4,"او موږ په خپل كتاب كې بني اسرائيل پر دې هم خبر كړي وو چې تاسي به په ځمكه كې دوه ځله ډېر لوى فساد راولاړ كړئ، او لويه سركښي به وکړئ."
  17,5,"نو كله چې د هغو د لومړۍ سركښۍ وخت راغى؛ نو اى بني اسرائيلو موږ ستاسي د مقابلې لپاره خپل داسې بندګان راپاڅول چې په جنګ كې ډېر زورور وو او هغوى ستاسي په هېواد كې په ننوتلو هر لوري ته خواره شول، دا يوه پوره كېدونكې وعده وه."
  17,6,"له دې وروسته موږ تاسي ته پر هغو د برلاسۍ موقع دركړه او له تاسو سره مو د مال او اولاد په دركولو مرسته وكړه او ستاسي شمير مو هم ډېر زيات كړ."
  17,7,"(ګورئ!) كه تاسو ښېګڼه وكړه نو هم خپلو ځانو سره مو وكړه، او كه بدى مو وكړه نو هم خپل ځان سره، نو كله چې وروستۍ (دويمه) نېټه راغله (بيا مو دښمن برلاسى كړ) چې ستاسو مخونه در بدرنګ كړي او مسجد (بيت المقدس) ته هماغسې ننوځي لكه چې اول ځل ورننوتلي وو او پر څه چې برلاسي شي هغه تبا كړي، په پوره تبا کولو سره."
  17,8,"ښايي رب مو اوس رحم درباندې وكړي او كه بېرته (فساد ته) وګرځېدئ موږ به هم (ستاسو عذاب ته) در وګرځو او كافرانو ته مو جهنم بندي خانه ګرځولې ده."
  17,9,"يقيناً دا قرآن هغې لارې ته ښوونه كوي چې سمه سيده ده، او هغو مومنانو ته چې سم كارونه كوي دا زېرى وركوي چې بې شكه د دوى لپاره لويه بدله ده."
  17,10,"او دا چې كوم خلک په آخرت باور نه كوي هغوی ته مو دردناک عذاب چمتو كړيدى."
  17,11,"انسان په هغه شان بدي غواړي څرنګه چې د خير غوښتل یې دي، انسان ډېر تلوار كوونكى دى."
  17,12,"(ګورئ!) شپه او ورځ مو دوه نښانې ګرځولې دي، د شپې نښانه مو بې نوره وګرځوله او دورځې نښانه مو روښانه كړه، تر څو تاسي د خپل رب فضل ولټولى شئ او د مياشتو كلونو حساب معلوم كړاى شئ، په دغه ډول موږ هر شى په تفصيل سره يو له بله بېل كړيدی."
  17,13,"او د هر انسان بخت (تالې) مو خپله د هغه په غاړه كې زوړندې كړې دي او د قيامت په ورځ خو به هغه ته يو ليک راوباسو چې (تيار) پرانيستى به يې ومومي."
  17,14,"(ورته به وویل شي) ولوله خپله عمل نامه؛ نن د خپلې محاسبې لپاره ته په خپله كافي يې."
  17,15,"څوک چى سمه لاره ونيسي نو هغه په نېغه لار سميږي صرف د ځان لپاره او څوک چې بې لارې شو نو هم د خپل ځان پر ضرر بې لارى شو، او هېڅ پېټى وړونكى به د بل پېټى وانخلي، او موږ هم تر هغو څوک نه عذابوو چې كوم رسول مو نه وي ورلېږلى."
  17,16,"او كله چې غواړو كوم كلى تباه كړو نو بډايانو ته يې امر كوو نو بيا هغوى پكې سرغړونې پيل كړي نو خبره پرې ثابته شي بيا يې سم (بشپړ) تباه كړو."
  17,17,"او له نوح (علیه السلام) وروسته مو څومره نسلونه تباه كړي دى؟ او يوازې ستا رب د خپلو بندګانو په ګناهونو د باخبره ليدونكي په توګه بس دى."
  17,18,"څوک چې د سملاسې ګټې غوښتنه كوي نو چاته چې د څه وركول وغواړو (په دې دنیا يې) زر وركوو، بيا جهنم ورته (برخه) ګرځوو، چې رټلى ديكه شوى به ورننوځي."
  17,19,"او چا چې آخرت وغوښت او د هغه لپاره يې هڅه وكړه، مناسبه هڅه، او دى مومن هم وي نو د داسې خلكو هڅه په مننې سره منل شوې ده."
  17,20,"هرې ډلې سره مرسته كوو، دغې سره هم او هغې سره هم، ستا د رب له وركړې نه، او ستا د رب وركړې لره مخه نيول كېده نشته."
  17,21,"ګوره څنګه مو (په دنيا كې) ځينو ته پر ځينو فضيلت وركړى، او آخرت خو خامخا په درجو كې هم ډېر لوى دى او هم په غوره والي كې."
  17,22,"الله سره بل معبود شريک مه نيسه، كنه بيا به كېنې پړ او بې ملاتړه."
  17,23,"او ستا رب حكم كړى دى چې له هغه پرته بل څوک مه لمانځئ، او مور پلار سره ښېګڼه كوئ، كه تا سره يو له هغو يا دواړه يې زړښت ته ورسېږي نو هغوئ ته اُف قدرې هم مه وايه، رټه يې مه او هغوى سره په درناوى خبرې كوه."
  17,24,"او په رحمت سره هغوى دواړو ته مات غاړى اوسه او داسې وايه چې اى زما ربه، پر دواړو داسې رحم وكړې لكه زه يې چې وړوكى روزلى يم."
  17,25,"ستاسي رب په هغه څه ډېر ښه پوه دى چې په زړونو كې مو دي، كه تاسو صالحان اوسئ نو بې شكه هغه توبه كوونكو لپاره بخښونكى دى."
  17,26,"او خپلوانو ته يې حق وركوه، او مسكين او لاروي ته هم، او بې ځايه لګښتونه مه كوه."
  17,27,"يقيناً بې ځايه لګښت كوونكي د شيطانانو ورونه دي، او شيطان خو د خپل رب ناشكره دى."
  17,28,"او كه تا له هغو نه څنګ كولو د خپل رب د رحمت د لټون په هيله، نو بيا هغوى ته پسته نرمه خبره وكړه."
  17,29,"او خپل لاس دې مه تر غاړې تړلى نيسه او مه يې داسې بشپړ پرانيستى چې بيا پړ او پښېمانه كېنې."
  17,30,"بې شكه ستا رب چاته چې وغواړي روزى پراخوي او (يا يې) تنګوي، هغه پر خپلو بندګانو ښه باخبر ليدونكى دى."
  17,31,"او خپل اولاد مو د نېستۍ له وېرې مه وژنئ، موږ هغوى ته هم روزي وركوو او تاسو ته هم، د هغوى وژل خو يقيناً لويه ګناه ده."
  17,32,"او زنا ته مه نږدې كېږئ هغه يو ډېر ناوړه كار او بده لاره ده."
  17,33,"او هغه كس مه وژنئ چې الله (یې قتل) حرام كړى دى مګر په حقه، او هر څوک چې په ظلم سره ووژل شو نو یقیناً موږ يې وارث ته (د بدل اخيستلو) ځواک وركړى خو په وژلو كې به زياتى نه كوي، بې شكه هغه سره مرسته شوې ده."
  17,34,"او د يتيم مال ته مه ورنږدې كېږئ مګر په هغه توګه چې ډېره ښه وي، تر هغو چې خپلې ځوانۍ ته ورسېږي او په ژمنه وفا كوئ، د ژمنې په هكله يقيناً پوښتنه كېدونكې ده."
  17,35,"او چې پيمانه كوئ نو پوره يې وركوئ او په سمه تله تول كوئ، دا ښه او په انجام كې ډېره غوره (طريقه) ده."
  17,36,"او په هغه څه پسې مه كېږه چې تاته يې پوهه نه وي، غوږ، سترګې او زړه دا ټول پوښتېدونكي دي."
  17,37,"او د لويي په نخرو په زمكه كې مه ګرځه، بې شكه ته نه زمكه څيرولى شې او نه په هسكوالي غرونو ته رسېدلى شې."
  17,38,"د دې ټولو چارو بدي ستا د رب په وړاندې ناخوښه ده."
  17,39,"دا هغه د حكمت خبرې دي چې خپل رب دې تاته وحى كړې دي، او (پام كوه) الله سره كوم بل معبود مه نيسه، كنه بيا به جهنم كې پړ او ټېله شوى غورځول كېږې."
  17,40,"آيا رب مو تاسو ته زامن در پېرزو كړل او خپل ځان ته يې ملايكې لوڼې ونيولې، يقيناً تاسو ډېره لويه (غلطه) خبره كوئ."
  17,41,"او موږ په دې قرآن كې راز راز بيان وكړ چې خلک پند واخلي، خو له حقه تښتېدلو پرته نور څه نه ور زياتوي."
  17,42,"ورته ووايه چې كه هغه (الله) سره نور معبودان هم واى لكه دوى چې وايي نو بيا خو به هغه هم حتماً د عرش څښتن (مقام) ته لار لټولې وه."
  17,43,"هغه لره پاکي ده، او له هغو خبرو ډېر پورته دى چې دوى يې وايي."
  17,44,"اوه واړه اسمانونه، زمكه او څه چې په هغو كې دي، ټول د هغه پاكي وايي او داسې هېڅ شى نشته چې له ستاينې سره د هغه پاكي نه وايي خو تاسي يې په تسبيح نه پوهېږئ بې شكه هغه د ډېر زغم والا بخښونكى دى."
  17,45,"او كله چې ته قرآن لولې نو ستا او په آخرت ايمان نه راوړونكو ترمنځ يوه پټه پرده اچوو."
  17,46,"او په زړونو يې داسې پردې وراچوو چې دوى ورباندې پوه نه شي او په غوږو كې يې كوڼوالى، او كله چې ته په قرآن كې يوازې خپل رب يادوې نو هغوى بيا په كركه شاته وګرځي."
  17,47,"موږ يې د غوږ نيولو په غرض ښه پوه يو كله چې دوى تاته غوږ نيسي او كله چې هغوى پټې خبرې كوي، هغه مهال چې دا ظالمان وايي تاسي خو له يو كوډو وهلي سړي پرته بل چا پسې روان نه ياست."
  17,48,"ګوره دوى تا پورې څنګه مثالونه وايي، دوى بې لارې شول، نو بيا د لار موندلو وس نه لري."
  17,49,"او دوى وايي: كله چې موږ ميده خاورې او هډوكي شو نو آيا موږ به په نوي پېدایښت بيا راپاڅول شو؟"
  17,50,"ورته ووايه: (ځئ) كاڼي يا اوسپنې شئ."
  17,51,"او يا كوم بل داسې مخلوق چې ستاسو په سینو (زړونو) كې ډېر لوى (كلك) ښكاري، نو بيا به هم دوى وايي: څوک مو بېرته راولي؟ ورته وايه هماغه ذات چې په لومړي ځل يې پيدا كړي یاست، بيا به نو سرونه درته خوځوي وايي به دا به نو كله وي؟ ورته وايه: ښايي هغه نږدې وي."
  17,52,"كومه ورځ چې تاسو راوبلي نو تاسو به يې له ستاينې سره بلنه ومنئ او ګومان به كوئ چې له څه كم وخته پرته نه یاست ځنډېدلي."
  17,53,"او زما بندګانو ته ووايه چې دوى دې هغه خبره كوي كومه چې ډېره ښه وي، يقيناً شيطان يې ترمنځ شر جوړوي، بې شكه شيطان د انسان يو څرګند غليم دى."
  17,54,"ستاسو رب ډېر ښه درباندې پوه دى، كه خوښه يې شي رحم به درباندې وكړي يا يې كه وغوښتل په عذاب به مو كړي او ته مو پر دوى څارونكى نه يې ټاكلى."
  17,55,"او ستا رب په هغه چا ډېر ښه پوه دى چې په آسمانو او زمكه كې دي، او موږ ځينو نبيانو ته پر ځينو غټه مرتبه وركړې ده او موږ داود ته زبور وركړى ؤ."
  17,56,"ورته ووايه: هغه معبودان مو راوبلئ چې تاسي يې له هغه (الله) پرته (خپل چارواكي) ګڼئ، نو نه خو د ضرر لرې کولو څه توان لري او نه د راګرځولو."
  17,57,"دوى چې چاته بلنه وركوي هغوى خو په خپله د خپل رب لور ته وسيله لټوي چې كوم يو (هغه ته) ډېر ورنږدې دى او د رحمت هيله يې كوي او له عذابه يې ويريږي، يقيناً ستا د رب عذاب د وېرې وړ دى."
  17,58,"او داسې كوم كلى به نه وى چې موږ يې له قيامت ورځې نه مخكې تباه كوونكي يا سخت عذاب وركوونكي نه يو، دا په (الهي) كتاب كې ليكل شوي دى."
  17,59,"او موږ د نښانو له لېږلو نه بل څه نه يو ايسار كړي مګر دا چې له دوې مخكې خلكو هغه دروغ ګڼلي وو، او (لكه چې) ثموديانو ته مو په څرګنده اوښه راوستله خو هغوى ظلم پرې وكړ او (دا) نښانې موږ پرته له وېرولو د بل څه لپاره نه لېږو."
  17,60,"او كله چې موږ درته وويل: بې شكه ستا رب دا خلک را ايسار كړي دي، او دغه څه چې تاته مو ښودلي دى او هغه ونه چې په دې قرآن كې لعنت پرې شوى، موږ د دې خلكو لپاره صرف يوه فتنه ګرځولې او دوى بيا بيا وېروو خو پرته د لويې سركښي نه بل څه نه ورزياتوي."
  17,61,"او كله مو چې ملايكو ته وويل: آدم ته سجده وكړئ نو ټولو سجده وكړه پرته له ابليسه، ويې ویل: آیا زه هغه چاته سجده وكړم چې تا له خټې پيدا كړى؟"
  17,62,"ويې ويل: خبر راكړه! دا (كوم يو) چې دې پر ما غوره وګرځولو، (آیا د دې وړ دی؟) كه زه خو دې د قيامت تر ورځې پورې وځنډولم نو خامخا به يې له كمو پرته د اولادې سټه وباسم."
  17,63,"(الله تعالی) وويل: ځه (لاړ شه) خو له هغوى نه چې هر چا ستا تابعداري وكړه نو بې شكه ستاسو لپاره به جهنم بشپړه سزا وي."
  17,64,"او له هغوى نه چې هر څوک په خپله بلنه ښويولاى شې ويې ښويوه، خپل سپاره او پلي دې ورباندې راوله، په مالو او ځانو كې ورسره شريک شه او وعدې وركړه، او (حال دا چې) د شيطان وعدې له دوكې پرته بل څه نه دي."
  17,65,"بې شكه زما پر (سوچه) بندګانو به ستا كوم برلاسى نه وي، او ستا رب د ساتونكي په توګه بس دى."
  17,66,"ستاسو رب هغه دى چې په سمندر كې بېړۍ درته روانوي تر څو د هغه فضل (حلال رزق) ولټوئ، يقيناً هغه پر تاسو مهربان دى."
  17,67,"او كله چې په سمندر كې څه كړاو در ورسېږي، له هغه (الله) پرته ټول هغه (معبودان) چې تاسو يې رابلئ، درنه ورک شي، خو چې بيا مو كله وچې ته راوژغوري نو ترې څنګ كوئ او انسان خو دى ناشكره."
  17,68,"آيا له دې بې غمه ياستئ چې د وچې په كومه څنډه كې به مو پر زمكه ننباسي، يا به كاڼي اورونكې سيلۍ درباندې راولي بيا به څوک خپل ساتونكى ملاتړ ونه مومئ."
  17,69,"يا له دې نه بې غمه ياست چې يو ځل بيا مو سمندر ته ورولي او سخت توپاني باد درباندې را والوزوي او ډوب مو كړي، د هغه كفر په سبب چې تاسو كړى، بيا به ځان ته داسې څوک ونه مومئ چې ستاسو په اړه له موږ څخه پوښتونكى وي."
  17,70,"او بې شكه د آدم خېلخانې ته مو ډېر عزت وركړى او هغوى ته مو په وچه او لمده كې سپرلۍ وركړي دي او د پاكيزه شيانو روزي مو وركړې ده او پر زياترو هغو شيانو مو غوره والی وركړى، چې موږ پيدا كړي."
  17,71,"هغه ورځ چې هره ډله به له خپل امام (رسول يا مشر) سره وبولو، نو د چا كتاب چې په ښي لاس وركړى شو نو هغوى به خپل كتاب لولي او د خرما د زړي نري تار په اندازه ظلم به هم نه ورسره كيږي."
  17,72,"او څوک چې په دې دنيا كې ړوند وي (له حقه)، نو هغه به آخرت كې هم ړوند وي بلکې لا ډېر زيات لار وركى به وي."
  17,73,"او حقيقتاً نږدې و چې دوى دې په فتنه كې واچوې، له هغې وحې دې واړوي چې موږ درلېږلې تر څو پر موږ پورې بل څه وتړې، او بيا به يې نو خامخا په دوستۍ نيولى وې."
  17,74,"او كه ته مو ټينـګ كړى نه واى نو نږدې وه چې د دوى لور ته لږ وركوږ شوى واى."
  17,75,"بيا به مو حتماً په ژوند كې هم دوه برابره عذاب درڅكلى واى او په مړينه (آخرت) كې هم دوه برابره، بيا به دې زموږ پر خلاف كوم مرستندوى نه واى موندلى."
  17,76,"او بى شكه نږدې و چې دوى دې له دغې زمكې (سيمې) وښویوي څو ترې دې وباسي، خو بيا به خپله دوى هم له تا وروسته ونه ځنډيږى، مګر ډېر لږ."
  17,77,"دا زموږ کړنلاره ده د هغو رسولانو په هكله چې له تا مخكې مو لېږلي وو او زموږ د کړنلارې څه بدلون به نه مومې."
  17,78,"لمونځ كوه د لمر له زواله د شپې ترږمۍ پورې او د سهار قرائت هم كوه، بې شكه د سهار د قرائت شاهدي ويل كيږي."
  17,79,"او د شپې تهجد كوه چې ستا لپاره نفل دي، ښايي چې رب دې يو ستايلي مقام ته ولېږي."
  17,80,"او ووايه چې ای زما ربه! هر چېرته مې چې ننباسې نو له رښتينولۍ سره مې ننباسه او چې له هره ځايه مې باسې نو له رښتينولۍ سره مې وباسه او له خپل لوري ماته يو قوت مرستندوى وګرځوه."
  17,81,"او وايه چې حق راغى او باطل له منځه ولاړ، يقيناً باطل له منځه تلونكى دى."
  17,82,"او موږ د دې قرآن په لړ كې هغه څه نازلوو چې د مومنانو لپاره شفا او رحمت دى خو ظالمانو ته له تاوانه پرته بل څه نه ورزياتوي."
  17,83,"او كله چې په انسان پېرزوينه كوو نو مخ ګرځوي او لرې شي، او چې كله بدي ورته ورسېږې نو بيا ناهيلى وي."
  17,84,"ورته ووايه چې هر څوک په خپله كړنلاره عمل كوي، نو (يوازې) رب مو ښه پوه دى چې څوک پر سمه لار دى."
  17,85,"او هغوى د روح په هكله له تا پوښتنه كوي، ورته وايه: روح خو زما د رب له امر (له علم يا پيدايښته) ده او تاسو ته له پوهنې څه نه دې دركړل شوي مګر ډېر لږ."
  17,86,"او كه موږ وغواړو هغه څه به درنه يوسو چې تاته مو وحى كړي بيا به زموږ پر خلاف كوم وكيل (ملاتړ) په دې هكله ونه مومې."
  17,87,"خو ستا د رب رحمت دى، يقيناً پر تا د هغه ستره پېرزوينه ده."
  17,88,"ورته ووايه كه دا ګرد انسانان او پېريان په دې راغونډ شي چې د دې قرآن مثال راوړي، نو را به يې نه وړي كه څه هم يو د بل مرستيالان هم شي."
  17,89,"او حقيقتاً موږ په دې قرآن كې خلكو ته هر ډول مثال بيان كړ، خو زياترو خلكو پرته له انكاره (او ناشكرۍ) بل څه ونه منل."
  17,90,"او ويې ويل: تر هغو به دې ونه منو چې له دې ځمكې دې يوه چينه راته بهولې نه وي."
  17,91,"يا ستا لپاره د كجورو او انګورو يو باغ وي چې په منځ كې يې بهېدلې ويالې روانې كړې."
  17,92,"يا ته پر موږ اسمان ټوټه ټوټه راوغورځوې لكه چې دعوه كوې، يا الله او پرښتې موږ ته مخامخ راولې."
  17,93,"يا ستا لپاره د سرو زرو يو كور وي، يا ته اسمان ته وخېژې، او لا په ختلو دې هم باور نه كوو، څو چې يو داسې كتاب موږ ته را نازل نه كړې چې موږ یې ولولو! ورته ووايه: زما رب لره پاكي ده، آيا زه له يو رالېږل شوي انسان پرته بل څه يم؟!"
  17,94,"او كله چې دغو خلكو ته هدايت راغى نو له ايمان راوړلو نه كوم بل شي ايسار نه كړل پرته له دې چې ويل به يې: آيا الله يو انسان د رسول په توګه رالېږلى؟"
  17,95,"ورته وايه: كه چېرې په ځمكه كې ملايكې ډاډه ګرځېداى راګرځېداى نو خامخا به مو پر هغوى له اسمانه كوم ملايک د رسول په توګه ور نازل كړى واى."
  17,96,"ورته ووايه: زما او ستاسو ترمنځ (يوازې) الله د شاهد په توګه بس دى، بې شكه هماغه پر خپلو بندګانو ښه باخبر ليدونكى دى."
  17,97,"او چاته چې الله سمه لار ښيي نو همدى لار موندونكى دى او څوک چې بې لارې كړي نو بيا به له هغه پرته څوک دوستان ورته ونه مومې، او د قيامت په ورځ به يې پړمخې ړانده، ګونګيان او كاڼه راغونډوو، استوګنځى به يې جهنم وي، هر كله چې لږ غلی شى لا به يې لمبې زياتوو."
  17,98,"همدا يې سزا ده ځكه چې دوى زموږ په آيتونو كافر شوي او ويلي يې وو: آيا كله چې موږ رژېدلي هډوكي او خاورې شو نو بيا به له نوي سره راپاڅولى شو."
  17,99,"آيا نه ګوري چې كوم الله اسمانونه او ځمكه پيدا كړي هغه په دې هم قادر دى چې د دوى په شان څه پيدا كړي (خو) د دوى لپاره يې نېټه ټاكلې ده چې هېڅ شک پكې نشته، خو دا ظالمان له انكاره پرته بل څه نه مني."
  17,100,"ورته ووايه كه ستاسو په لاس كې زما د رب د رحمتونو خزانې واى نو د لګښت له وېرې به مو هغه هم (په كنجوسۍ سره) ساتلې واى او انسان خو دى تنګ زړى."
  17,101,"او موسىٰ (علیه السلام) ته مو نهه څرګندې نښانې وركړې وې نو له بنى اسرائيلو پوښتنه وكړه كله چې دوى ته ورغى نو فرعون ورته وويل: ای موسىٰ زه ګومان كوم چې په تا كوډې شوې دي."
  17,102,"وېلې ته خو پوهېږي چې دغه سترګې پرانيستونكې نښانې د اسمانو او ځمكى له رب نه پرته بل چا نه دي نازلې كړې او ای فرعونه په تا مې د تباه كېدونكي ګومان دى."
  17,103,"نو ويې غوښتل (فرعون) چې دوى (بنى اسرائيل) له هغې ځمكې وشړي، نو بيا مو هغه (فرعون) او څوک چې ورسره وو، ټول ډوب كړل."
  17,104,"او له هغه وروسته مو بني اسرائيلو ته وويل چې په هغه ځمكه كې تاسو اوسېږئ، نو كله چې د آخرت نېټه راشي، تاسو به ټول يوځاى راحاضر كړو."
  17,105,"او په حقه مو نازل كړى او په حقه نازل شوى او ته مو له زېري وركونكي او وېرونكي پرته بل څه نه يې لېږلى."
  17,106,"او قرآن مو بېل بېل كړ چې وخت پر وخت يې په خلكو ولولې او هغه مو كرار كرار نازل كړ."
  17,107,"ورته وايه چې كه تاسو يې منئ يا يې نه منئ خو له دې مخكې چې چاته علم وركړى شوى، كله چې دا پر هغو لوستل كيږي نو پړمخې په سجده پرېوځي."
  17,108,"او وايي زموږ رب لره پاكي ده، بې شكه زموږ د رب وعده ترسره كېدونكې ده."
  17,109,"او پړمخې پرېوځي، ژاړي او عاجزي يې لاپسې زياتيږي."
  17,110,"ورته ووايه: الله راوبولئ يا رحمن، هر يو چې رابلئ نو د هغه ډېر ښه نومونه دي، او لمونځ دې مه په لوړ اواز كوه او مه په ډېر ټيټ، بلكې د دې ترمنځ يوه (منځنۍ) لار ونيسه."
  17,111,"او وايه: هغه الله لره ستاينه ده چې نه يې څوک زوى نيولى، نه يې په باچاهۍ كې څوک شريک شته او نه يې د بې وسۍ له امله څوک ملاتړ شته، او د هغه لويي وايه، بشپړه لويي."
