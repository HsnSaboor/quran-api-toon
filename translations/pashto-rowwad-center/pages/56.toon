quran[96]{c,v,t}:
  56,1,"كله چې قيامت راپېښ شي."
  56,2,"چې پېښېدلو كې يې هيڅ درواغ نشته."
  56,3,"هغه ښكته كوونكى او پورته كوونكى دى."
  56,4,"كله چې ځمكه په سختو لړزولو ولړزول شي."
  56,5,"او غرونه يومخ ميده ميده ورژول شي."
  56,6,"نو خوره وره دوړه به شي."
  56,7,"او تاسو به درې ډلې شئ."
  56,8,"نو د ښي لاس والا خلک، څومره ښه دي د ښي لاس والا خلک!"
  56,9,"او د كيڼ (چپ) لاس والا خلک! څومره بد دي د كيڼ (چپ) لاس والا خلک!"
  56,10,"او مخکې کېدونکي خو مخکې کېدونکي دي."
  56,11,"همدوى نېږدې كړى شوي دي."
  56,12,"د نعمتونو والا جنتو كې به وي."
  56,13,"(د هغوى) لويه ډله به له لومړنيو وي."
  56,14,"او لږ به له وروستنيو (خلكو) وي."
  56,15,"پر زرينو او بدل شوو تختونو به وي."
  56,16,"پر هغو يو بل ته مخامخ ډډه وهونكي (ناست) وي."
  56,17,"تل (پاتې) هلكان به ورباندې ګرځي راګرځي."
  56,18,"له ګيلاسونو او كوزو سره، او د روانو (بهېدونكو شرابو) له جامونو سره."
  56,19,"چې نه ترې سر خوږى كيږي او نه بې هوښه كيږي."
  56,20,"او مېوې، له هغو نه چې هغوى يې خوښوي."
  56,21,"او د مرغانو غوښې، كومې چې زړه يې غواړي."
  56,22,"او د غټو سترګو والا حورې."
  56,23,"لكه د پټو ساتل شوو ملغرو غوندې."
  56,24,"د دوى د هغو عملونو په بدله كې چې كول يې."
  56,25,"نه به چټيات پكې اوري او نه د ګناه څه خبره."
  56,26,"پرته له سلام، سلام ويلو."
  56,27,"او د ښي لاس والا خلک! څومره ښه دي ښي لاس والا خلک!"
  56,28,"په بې اغزيو بېرو كې به وي."
  56,29,"او له بېخه تر سره په ډكو ډكو كيلو كې به وي."
  56,30,"او په اوږده غځېدلي سيوري كې به وي."
  56,31,"او را تويېدونكو اوبو كې به وي."
  56,32,"او ډېرو مېوو كې."
  56,33,"چې نه ختمېدونكې او نه ترې ايسارېدونكې دي."
  56,34,"او اوچتو فرشو كې به وي."
  56,35,"بېشکه موږ هغه (حورې) په يو ځانګړي پيدايښت سره پيدا كړې دي."
  56,36,"او هغوى مو (تل) پېغلې ګرځولې دي."
  56,37,".(مېړونو ته) ګرانې همزولې"
  56,38,"د ښي لاس والا خلكو لپاره."
  56,39,"یوه لويه ډله له مخکېنيو څخه."
  56,40,"او بله لويه ډله له وروستنيو خلكو څخه."
  56,41,"او د كيڼ (چپ) لاس والا خلک! څومره بد دي د كيڼ (چپ) لاس والا خلک!"
  56,42,"په توده هوا او خوټېدلو اوبو كې."
  56,43,"او د تور لوګي په سيوري كې به وي."
  56,44,"چې نه به سوړ وي او نه عزت راحت والا."
  56,45,"بېشكه هغوى له دې مخکې نازولي خوشاله وو."
  56,46,"او پر لويه ګناه (كفر) به يې ټينګار كولو."
  56,47,"او هغوى به ويل: آيا كله چې مړه شو او خاورې هډوكې يو نو آيا بيا به راپورته كېدونكي يو؟"
  56,48,"آيا زموږ مخکني پلرونه هم؟"
  56,49,"ورته ووايه: بېشكه مخکني او وروستني (ټول)."
  56,50,"هرومرو د يوې ټاكلې ورځې وخت ته را يو ځاى كېدونكي دي."
  56,51,"بيا به هرومرو تاسي اې لار وركو درواغ ګڼونكو!"
  56,52,"هرومرو د زقوم له ونې خوراک كوونكي ياست."
  56,53,"او له هغې به د خپلو ګېډو ډكوونكي ياست."
  56,54,"بيا به پر هغه (خوراک) د خوټېدونكو اوبو څښونكي ياست."
  56,55,"او څښونكي هم د تږو اوښانو غوندي څښاک."
  56,56,"د قيامت په ورځ د هغوى مېلمستيا همدغه ده!"
  56,57,"تاسي (ټول) خو موږ راپيدا كړئ نو ولې باور نه كوئ؟"
  56,58,"آيا هغه مني ته مو پام كړئ چې تاسي يې څڅوئ؟"
  56,59,"آيا تاسي يې پيدا كوئ، كه موږ پيدا كوونكي يو؟"
  56,60,"(همدا) موږ ستاسو ترمنځ مرګ ټاكلى او موږ له دې څخه عاجز كېدونكي نه يو."
  56,61,"چې ستاسو غوندې نور خلک به مو په بدل كې راولو او تاسي به له سره په داسې حالت پيدا كړو چې تاسي نه پرې پوهېږئ."
  56,62,"او پرته له شکه تاسو ته خو لومړنی پيدايښت معلوم دى، نو ولې عبرت نه اخلئ؟"
  56,63,"آيا نو د هغه څه خبر به راكړئ چې تاسي يې كرئ؟"
  56,64,"آيا تاسي يې راشنه كوئ كه موږ يې زرغونوونكي يو؟"
  56,65,"كه موږ وغواړو هرومرو به هغه وچ ټوټه ټوټه كړو بيا به (ټوله ورځ) تعجب سره خبرې كوئ."
  56,66,"چې بېشكه موږ تاواني شولو."
  56,67,"بلكې موږ بيخې بې برخې يو."
  56,68,"آيا هغه اوبه مو ليدلې چې (تل) يې تاسو څښئ؟"
  56,69,"آيا هغه تاسي له ورېځو راتويې كړې دي كه موږ يې را وروونكي يو؟"
  56,70,"كه موږ وغواړو هغه به تروې ترخې كړو نو ولې شكر نه باسئ؟"
  56,71,"آيا هغه اور ته مو كتلي چې تاسي يې بلوئ؟"
  56,72,"آيا تاسي يې ونه راپيدا كړې ده كه موږ يې پيدا كوونكي يو؟"
  56,73,"هغه خو موږ عبرت او د مسافرو لپاره ګټوره ګرځولې ده."
  56,74,"نو د خپل لوى پالونکي په نوم پاکي بيانوه."
  56,75,"نو زه د ستورو د پرېوتلو پر ځايونو قسم كوم."
  56,76,"او كه پوهېږئ دا په رېښتيا لوى قسم دى."
  56,77,"چې پرته له شکه دا يو عزتمن قرآن دى."
  56,78,"چې په يو پټ ساتل شوي كتاب كې دى."
  56,79,"هغه ته پرته له ډېرو پاکو بل څوك لاس نه وروړي."
  56,80,"د رب العالمين له خوا نازل شوى دى."
  56,81,"آيا نو تاسي د دې خبرى (قرآن) سپک ګڼونكي ياست؟"
  56,82,"او (يوازې دا خبره) خپله برخه ګرځوئ چې درواغ يې ګڼئ."
  56,83,"نو ولې هغه وخت چې (روح) مرۍ ته ورسيږي."
  56,84,"او تاسي هغه وخت (په سترګو) ګورئ."
  56,85,"او موږ له تاسي زيات ورنېږدې يو خو تاسي نه وينئ."
  56,86,"نو كه تاسي ته جزا نه دركول كيږي."
  56,87,"ولې (هغه روح) نه راستنوئ كه تاسي رښتيني ياست."
  56,88,"نو بيا كه چېرې هغه (الله ته) له نېږدې كړى شوو څخه وي."
  56,89,"نو هوسايي، ښه روزي او نعمتونو والا جنت دى."
  56,90,"او كه هغه له ښي لاس والا كسانو څخه وي."
  56,91,"نو (بيا هم) تاته سلامتي ده چې د ښي لاس والا خلكو څخه يې."
  56,92,"خو كه چېرې له درواغ ګڼونكو لار وركو څخه وي."
  56,93,"نو (هغه ته) د خوټېدونكو اوبو مېلمستيا ده."
  56,94,"او دوزخ ته ورننه اېستل دي."
  56,95,"يقيناً همدا حق او يقيني ده."
  56,96,"د خپل لوى پالونکي په نوم پاکي بيانوه."
