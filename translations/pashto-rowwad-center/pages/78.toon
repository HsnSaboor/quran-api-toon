quran[40]{c,v,t}:
  78,1,"د څه په اړه دوی پوښتنې کوي (یو له بل نه)."
  78,2,"د هغه لوى خبر په اړه."
  78,3,"هغه چې دوى پكې سره اختلاف كوونكي دي."
  78,4,"هيڅكله نه، ژر به هغوى پوه شي."
  78,5,"بیا هېڅكله نه، ډېره ژر به دوې ته څرګنده شي."
  78,6,"آيا موږ ځمكه فرش نه ده ګرځولې."
  78,7,"او غرونه مېخونه؟"
  78,8,"او تاسي مو جوړه جوړه پيدا كړي ياست."
  78,9,"او ګرځولی دی موږ خوب ستاسو آرام."
  78,10,"او ګرځولې ده موږ شپې لره جامه."
  78,11,"او ګرځولې ده موږ ورځ وخت د ګټلو د روزۍ."
  78,12,"او جوړ کړي مو دي ستاسې له پاسه اووه آسمانونه کلک."
  78,13,"او جوړ کړی دی موږ چراغ ځلیدونکی."
  78,14,"او له ډكو ورېځو مو پرله پسې اوبه را ورولې دي."
  78,15,"ترڅو پرې غلې دانې او شنه ګيا راوټوكوو."
  78,16,"او ګڼ باغونه."
  78,17,"بېشكه د پرېكړې ورځ يو ټاكلى وخت دى."
  78,18,"كومه ورځ چې په شپېلۍ كې پو كړى شي نو بيا به تاسي ډلې ډلې راځئ."
  78,19,"او آسمان به پرانيستل شي نو دروازې دروازې به وي."
  78,20,"او روان به کړی شي غرونه نو شي به په څېر د شګې."
  78,21,"بېشكه چې دوزخ يو څارنځى دى."
  78,22,"د سركښانو استوګنځى دی."
  78,23,"اوسیږي به هغه کې تر ډیرې مودې پورې."
  78,24,"نه به يخوالى پكى وڅكي او نه څښاك."
  78,25,"پرته له خوټېدلو اوبو او زوو."
  78,26,"سمه برابره بدله ده."
  78,27,"په رېښتيا هغوى د هيڅ حساب هيله نه درلوده."
  78,28,"او زموږ آيتونه يې دروغ ګڼلي وو."
  78,29,"او موږ هرڅه په شمېر ليكلي وو."
  78,30,"نو ويې څكئ! اوس به موږ پرته له عذابه نور څه در زيات نه كړو."
  78,31,"یقینا متقیانو لره ځای د کامیابۍ دی."
  78,32,"باغونه او انګور دي."
  78,33,"او نوې پېغلې همزولې دي."
  78,34,"او ډك ډك جامونه."
  78,35,"نه به هلته چټيات پكې اوري او نه دروغ."
  78,36,"ستا د پالونکي لخوا بدله او پوره پوره لورېينه."
  78,37,"د آسمانونو، ځمكې او د هغو ترمنځ شيانو ډېر مهربان پالونکی دى، هغوى به له هغه سره د خبرو كولو وس نه لري."
  78,38,"هغه ورځ چې روح او پرېښتې كتار كتار ودريږي، هيڅوك به خبرې نه كوي له هغه چا پرته چې رحمان اجازه وركړې وي او سمې خبرې به كوي."
  78,39,"دا حقه ورځ ده نو چې د چا خوښه وي د خپل پالونکي لور ته د ورګرځېدو لار دې ونيسي."
  78,40,"بېشكه موږ له (راتلونكي) نېږدې عذابه ووېرولئ هغه ورځ چې هرسړى به هغه څه وويني چې خپلو لاسونو يې وړاندې لېږلي او كافر به وايي: كاشكې زه خاورې واى."
