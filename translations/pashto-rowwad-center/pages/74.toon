quran[56]{c,v,t}:
  74,1,"اې په جامه كې ځان نغښتونكيه!"
  74,2,"پاڅېږه او خبرداری وركړه."
  74,3,"او د خپل پالونکي لويي بيان كړه."
  74,4,"او خپلې جامې پاكې وساته."
  74,5,"او له هري پلیتۍ نه ډډه وکړه."
  74,6,"او داسې ښېګڼه مه كوه چې د بدل زياتوالی غواړې."
  74,7,"او پالونکي ته دې صبر كوه."
  74,8,"نو كله چې په شپېلۍ كې پو كړل شي."
  74,9,"بيا به دغه ورځ سخته ورځ وي."
  74,10,"چې پر كافرانو به آسانه نه وي."
  74,11,"ما او هغه سره پرېږده چې يوازې مې پيدا كړی."
  74,12,"او بيا مې ډېر مال وركړ."
  74,13,"او حاضر (چمتو) زامن."
  74,14,"او پراخه پراختيا مې وركړه."
  74,15,"(خو) بيا هم هيله كوي چې لا يې ورزيات كړم."
  74,16,"هيڅكله نه، هغه خو زموږ د آيتونو دښمن و."
  74,17,"عذاب به ورکړم عذاب سخت [د غره ختلو ته به یې اړ کړم]"
  74,18,"هغه سوچ وكړ او څه خبره يې جوړه كړه."
  74,19,"نو تباه دې شي، څرنګه اندازه یي ولګوله."
  74,20,"بيا دې تباه شي، څنګه خبره يې جوړه كړه."
  74,21,"بيايې وكتل."
  74,22,"بيا یې تندی تريو کړ او ښه یې تریو کړ."
  74,23,"بیا يې شا واړوله او كبر يې وكړ."
  74,24,"نو ويې ويل: دا له هغو كوډو پرته بل څه نه دي چې له پخوا نه راروانې دي."
  74,25,"دا د بشر له وينا پرته بل څه نه دي!"
  74,26,"(الله فرمايي) ژر به يې دوزخ ته ننباسم."
  74,27,"او ته څه پوهېږې چې سقر څه دى؟"
  74,28,"هغه يې نه پاتې کوي او نه يې خوشې كوي."
  74,29,"د پوستكي سوځوونكى دى."
  74,30,"پر هغه نولس (پرېښتې) ټاكل شوې دي."
  74,31,"او موږ د دوزخ دا څوكيداران پرته له پرېښتو بل څوك نه دي ګومارلي او د هغو شمېر مو هم يوازې د كافرانو لپاره ازمویښت ګرځولى، تر څو اهل كتاب يقين وكړي او د مومنانو ايمان زيات شي او اهل كتاب او مومنان څه شک ونه كړي او د دې لپاره چې په زړه ناروغان او كافران ووايي چې الله په دې بيان سره څه غوښتي دي؟ په همدې ډول چا ته چې الله وغواړي بې لارې كوي يې او چا ته چې وغواړي هدايت ورته كوي او ستا د رب لښكرې له هغه پرته بل چا ته نه دي معلومې او هغه (دوزخ) بل څه نه دى مګر د بشر لپاره يو نصيحت."
  74,32,"هيڅكله نه، قسم دى په سپوږمۍ."
  74,33,"او په شپه چې بېرته وګرځي."
  74,34,"او په سهار چې رڼا شي."
  74,35,"چې په رېښتيا هغه (دوزخ) له سترو شيانو څخه يو دى."
  74,36,"د انسانانو لپاره وېروونكى دی."
  74,37,"له تاسي څخه د هغه چا لپاره چې پرمختګ غواړي يا وروسته كېدل."
  74,38,"هر څوک په خپلو کړو اعمالو کې نيولی شوی دی، يا به يې اعمال تباه کوي او يا به يې خلاصوي او له تباهۍ به يې ژغوري."
  74,39,"پرته له ښي لاس والا و."
  74,40,"چې جنتو كې به سره پوښتي."
  74,41,"د مجرمانو په باره کې."
  74,42,"چې دوزخ ته څه شي بوتلئ؟"
  74,43,"هغوى به وايي: موږ خو له لمونځ كوونكو څخه نه وو."
  74,44,"او نه مو مسكين ته خواړه وركول."
  74,45,"او غلطو بحث كوونكو سره يوځاى موږ هم بحثونه كول."
  74,46,"او د جزا ورځ مو درواغ ګڼله."
  74,47,"تر دې چې همغه يقيني شى [مرګ] راته راغى."
  74,48,"نو بيا به د سپارښت كوونكو سپارښت څه ګټه ور ونه رسوي."
  74,49,"نو څه پرې شوي چې له دې نصيحته مخ اړوونكي دي؟"
  74,50,"هغوی لكه ترېدلي خره داسې دي."
  74,51,"چې له زمري تښتېدلي وي."
  74,52,"اصلاً هغوى هر يو غواړي چې (ځانګړي) پرانيستي ليكونه وركړل شي."
  74,53,"هيڅكله نه، په اصل كې هغوى له آخرته نه وېريږي."
  74,54,"هيڅكله نه، دا خو يو نصيحت دى."
  74,55,"نو د چا چې خوښه وي درس دې ترې واخلي."
  74,56,"او هغوى څه درس نه شي اخيستلاى پرته له دې چې الله وغواړي، همغه د دې وړ دى چې ترې وېره وشي او همغه د بخښلو واک لري."
