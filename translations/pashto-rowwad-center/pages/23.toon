quran[118]{c,v,t}:
  23,1,"پرته له شکه هغه مومنان بريالي شول."
  23,2,"هغوی (مومنان) چې په خپلو لمونځونو کې عاجزي کوونکي ویریدونکي دي (له الله تعالی څخه)."
  23,3,"او هغوى چې له چټياتو ډډه كونكي دي."
  23,4,"او هغوى چې زكات ورکوونکي دي."
  23,5,"هغه كسان چې د خپلو شرم ځايونو ساتونکي دي."
  23,6,"پرته له مېرمنو او وينځو يې چې په هغو كې دوى د ملامتۍ وړ نه دي."
  23,7,"نو چا چې ولټاوه پرته لدې نه نو همدغه کسان له حد نه تېریدونکي دي."
  23,8,"او هغوى چې د خپلو امانتونو او ژمنو خيال ساتونكي دي."
  23,9,"او هغوى چې (تل) د خپلو لمونځونو ساتنه كوي"
  23,10,"همدوى وارثان دي."
  23,11,"چې په ميراث كې به فردوس ومومي اوپه هغې كې به د تل لپاره هستوګن وي."
  23,12,"او بې شکه پیدا کړی موږ انسان له چاڼ کړی شوې خټې نه."
  23,13,"بيا مو هغه د يو څاڅكي په بڼه محكم خوندي ځاى كې كېښود."
  23,14,"بيا مو هغه څاڅكى د وينې يوه ټوټه وګرځوله، بيا مو هغه ټوټه د غوښې يوه بوټۍ وګرځوله، چې له بوټۍ مو هډوكي پيدا كړل نو هډوكو ته مو غوښه ور واغوستله، بيا مو هغه يو بل مخلوق جوړ كړ نو الله ډېر بركتناك دى، تر ټولو غوره پيدا كوونكى دی."
  23,15,"بيا له هغه وروسته تاسو هرومرو مړه كېدونكي ياست."
  23,16,"بيا به تاسو هرومرو د قيامت په ورځ راپاڅول كيږئ."
  23,17,"او موږ ستاسي د پاسه اوه لارې جوړې كړې دي او (تر هغو لاندې) مخلوق څخه موږ بې خبره نه يو."
  23,18,"او له ااسمانه مو په يوه ټاكلې اندازه اوبه را اوورولې او هغه مو په ځمكه كې ودرولې او په له منځه وړلو يې هم بې شکه موږ قادر يو."
  23,19,"بيا مو تاسو ته په هغو سره د كجورو او انګورو باغونه پيدا كړل چې په هغو كې ستاسي لپاره ډېرې مېوى دي او له همدغو نه تاسو خوراك كوئ."
  23,20,"او هغه ونه موهم پيدا كړه چې له ښایسته غر څخه راوځي، د خوړونكو لپاره له غوړيو او ترکارۍ سره را زرغونيږي."
  23,21,"او رېښتيا چې ستاسي لپاره په څارويو كې هم يو درس شته، چې د هغو په خیټو كې څه دي، له هغو موږ تاسو ته يو (پاك) شى درڅښو او تاسو ته په هغو كې ډېرې ګټې دي او خوراك هم ترې كوئ."
  23,22,"او په دغو (څارويو) او بېړئ باندې بارول كېږئ هم."
  23,23,"او بېشكه موږ نوح د هغه خپل قوم ته ورواستلو نو ورته ويې ويل: ای زما قومه! الله ولمانځئ، له هغه پرته ستاسو كوم بل معبود نشته، اّيا تاسو نه وېرېږئ؟"
  23,24,"نو د هغه د قوم هغو سردارانو – چې كافر شوي وو وويل: دا ستاسو په شان يو انسان نه پرته بل څه نه دى! غواړي چې پر تاسي لوړتيا ولري او الله خو كه غوښتي واى نو پرېښتې به يې رالېږلې وې، دا خبره خو مو پخوانيو پلرونو كې هم نه وه اورېدلې."
  23,25,"هغه بل څه نه دى مګر يو داسې سړى چې په هغه ليونتوب دى نو تر يو څه وخته هغه ته انتظار وكړئ."
  23,26,"نوح وويل: ای زما پالونکيه! پرهغه څه مې مرسته وکړه چې هغوی پرې درواغجن وګڼلم."
  23,27,"نو هغه ته مو وحې وكړه چې زموږ تر څارنې لاندې یې او زموږ په وحى بېړۍ جوړه كړه کله چې زموږ امر راغی او تنور وخوټېد، نو له ټولو (ځناورو) څخه جوړه جوړه، دوه دوه ورننباسه او خپله كورنۍ هم، پرته له هغه چا چې په اړه يې (د عذاب) خبره ړومبۍ شوې ده او چا چې ظلم كړى، د هغوی په اړه له ماسره خبره مه كوه، هغوى يقيناً ډوبېدونكي دي."
  23,28,"نو كله چې ته او هغه څوك چې درسره وي، پر بېړۍ سم برابر شوئ نو بيا ووايه چې هغه الله لره ستاينه ده چې موږ يې له ظالمانو وژغورلو."
  23,29,"او ووايه پروردګاره! ما په بركتناك ځاى كې ښكته كړه او ته ډېر ښه ځاى وركوونكى يې."
  23,30,"بې شكه په دې كې یقینًا دلیلونه (نښې) دي او بې شكه موږ خامخا ازمېښت كوونكي یو."
  23,31,"بيا موږ له هغو وروسته نور قومونه راپورته كړل."
  23,32,"نو په هغوی كې مو له هغوى څخه رسول واستولو چې الله ولمانځئ، ستاسو لپاره له هغه پرته بل معبود نشته، آيا تاسو نه وېرېږئ؟"
  23,33,"او د هغه د قوم هغو مشرانو چې کفر يې کړی و، له آخرت سره مخامخ كېدل يې دروغ ګڼلي وو او د دنيا په ژوند كې مو سو كاله كړي وو، داسې وويل: دغه ستاسو په شان له يو انسان پرته بل څه نه دى، هغه څه خوري چې تاسو يې خورئ او هغه څه څښي چې تاسو يې څښئ."
  23,34,"او كه ستاسو په شان يو بشر ته مو غاړه كېښوده نو بيا به تاسو هرومرو تاوانيان ياست."
  23,35,"آيا هغه دا ژمنه درسره كوي چې كه تاسو كله مړه او خاورې او هډوكي شوئ نو (بيا به) را اېستل كېږئ."
  23,36,"لرې ده، بيخي لرې ده دغه ژمنه چې له تاسي سره كېږي."
  23,37,"نور څه نه دي، همدا زموږ د دنيا ژوند دى چې مرو او (تر څه وخته) ژوند كوو، خو بيا ژوندي راپورته كېدونكي نه يو."
  23,38,"دا هم يوازې داسې يو سړى دی چې پر الله يې درواغ تړلي او موږ يې منونكي نه يو."
  23,39,"وويل (نوح) ای زما پالونکيه! پرهغه څه مې مرسته وکړه چې هغوی پرې درواغجن وګڼلم."
  23,40,"ويې فرمايل: لږ وخت وروسته به هغوى هرومرو پښېمانه شي."
  23,41,"پس ونیول په پاى کې دوی لره له حق سره سم يوې سترې چغې او موږ هغوى نيزوړو غوندې وغورځول، ايسته دې وي ظالم قوم!"
  23,42,"بيا مو له هغوى وروسته نور ولسونه را پيدا كړل."
  23,43,"نشي مخکې کیدلی هیڅ قوم له خپلې مقررې وعدې او نه ترې وروسته پاتې کیدلی شي."
  23,44,"بيا مو پرله پسې خپل رسولان واستول، كله به چې يو قوم ته د هغوى رسول ورغلو، هغه به يې درواغجن وباله، نو موږ هم يو پر بل پسې تباه كړل، تر دې چې له هغوى مو افسانې جوړې كړې نو تباهي (يا له رحمته لرې والى) دې وي پر داسې خلكو چې ايمان نه راوړي."
  23,45,"بيا مو موسىٰ او ورور يې هارون له خپلو نښانو او ښكاره دليل سره ولېږل."
  23,46,"فرعون او سردارانو ته يې، خو هغوى لويي وكړه او دوى كبرجن خلك وو."
  23,47,"نو هغوى وويل: آيا موږ پر داسې دوو کسانو ايمان راوړو چې زموږ غوندې انسانان دي او قوم يې زموږ مريان دي."
  23,48,"بيايې هغوى دواړه درواغجن وګڼل؛ نو له تباه کېدونکو وګرځېدل."
  23,49,"او بې شكه موسىٰ ته مو كتاب وركړ تر څو هغوى سمه لار ومومي."
  23,50,"او موږ د مريم زوى او مور يې نښانه وګرځول او هغوى ته مو په يوه داسې هسكه ځمكه كې ځاى وركړ چې د كراري او روانو چينو والا وه."
  23,51,"ای رسولانو! له پاكو شيانو خوراك كوئ او سم عملونه وكړئ (د قران او سنت موافق)، بې شکه زه پر هغه څه ښه پوه يم چې کوئ يې."
  23,52,"او همدغه ستاسو امت يو امت دى او زه مو پالونکی يم را څخه ووېرېږئ."
  23,53,"خو بيا يې خپل دين سره ټوټه ټوټه كړ، هرې ډلې سره چې څه وو پرهماغه خوشحاله وه."
  23,54,"نو تر يوې نېټې يې په خپل غفلت كې همداسې ډوب پرېږده."
  23,55,"آيا دوى دا انګېري چې موږ په مالونواولادونو كې له دوى سره مرسته كوو."
  23,56,"چې موږ د هغوى لپاره په ښېګڼه كې هڅه كوو؟ نه، بلكې هغوى نه پوهيږي."
  23,57,"بې شكه هغه خلك چې د خپل پالونکي له وېرې لړزېدونكي وي."
  23,58,"او هغوى چې د خپل پالونکي پر آيتونو ايمان راوړي."
  23,59,"او هغوى چې له خپل پالونکي سره څه نه شريكوي."
  23,60,"او هغوى چې وركوي، څه چې وركوي حال دا چې زړونه يې په دې وېره کې وي چې دوى د خپل رب لور ته ورګرځېدونكي دي."
  23,61,"همدا خلك په ښېګڼو كې منډې ترړې وهي او همدوى ور وړاندې كېدونكي دي."
  23,62,"او موږ هيڅوك د هغه له توانه پورته نه مکلفوو، او له موږ سره يو داسې كتاب دى چې رېښتيا بيانوي او په دوى به هيڅ ظلم ونه شي."
  23,63,"خو د هغوى زړونه له دې څخه په غفلت كې دي او څه نور عملونه يې هم شته چې كوونكي يې دي."
  23,64,"تر دې چې عياشان يې په سزا كې راګير كړو نو بيا به يو دم په رمباړو شي."
  23,65,"نن رمباړې مه وهئ (اوس به) زموږ لخوا څه مرسته درنه کړل شي."
  23,66,"زموږ آيتونه خو پرتاسو لوستل كېدل خو تاسو به پر پوندو شاته ګرځېدئ."
  23,67,"پر هغه لويي کوونکي وئ، د شپى كيسې به مو پرې جوړولې، سپكې سپورې مو پرې وېلې."
  23,68,"نو آيا هغوى په دې وينا څه غور نه دى كړى، كه هغوى ته يو داسې څه راغلي چې پخوانيو پلرونو ته يې نه وو راغلي."
  23,69,"يا يې خپل رسول نه دى پېژندلى نو (ځكه) ترې نټه کوونکي دي."
  23,70,"او يا دوى وايي چې په هغه (كې) لېونتوب دى؟ نه بلكې هغوی ته يې حق راوړى او د هغوى ډېری د حق ناخوښوونكي دي."
  23,71,"او كه حق د هغوى په هوسونو پسې تللى وى نو هرومرو به اسمانونه، ځمكه او څه چې په هغو كې دي، ګډ وډ شوي وو. خو، نه، موږ هغوى ته يې ذكر (نصيحت) راوړى او هغوى له خپله ذكر څخه مخ ګرځوونكي دي."
  23,72,"آيا ته له دوی نه څه اجر غواړې؟ ستا لپاره ستا د رب دركړه ډېره ښه ده او هغه ډېر ښه روزي دركوونكى دى."
  23,73,"او بې شکه ته خو يې سمې نېغى لارې ته رابولې."
  23,74,"او هغه خلك چې آخرت نه مني له همدې سمې لارې كږېدونكي دي."
  23,75,"او كه پر هغوى رحم وكړو او كوم كړاو چې ورباندې پروت دى، هغه ترې لرې كړو، لا به خپله ناړامۍ كې ټينـګ شي، پریشان او لالهانده به وي."
  23,76,"او بې شکه هغوی مو په عذاب كې راګير كړل، خو نه يې خپل پالونکي ته غاړه كېښوده او نه يې عاجزي وكړه."
  23,77,"تر دې چې پر هغوى د يوې سختې سزا دروازه ورپرانېزو؛ نو بيا به يو دم پكې ناهيلى وي."
  23,78,"او دى هماغه ذات دى چې تاسو ته يې غوږونه، سترګې او زړونه پيدا كړي، خو تاسو ډېر لږ شكر وباسئ."
  23,79,"او هماغه ذات دى چې تاسو يې په ځمكه كې خپاره كړي ياست او (بيا به) هماغه ته ورغونډېږئ."
  23,80,"اوهماغه ذات دى چې ژوندي كوي او مړه كوي او د شپې ورځې اړول د هغه په لاس کې دي؛ نو آيا له عقل کار نه اخلئ؟"
  23,81,"خو هغوى هماغسې وايي لكه پخوانيو يې چې ويلي وو."
  23,82,"هغوى ویل: آیا كله چې موږ مړه شو او خاورې او هډوكې شو، آیا موږ به په رښتیا یقینًا بیا راژوندي كولى شو."
  23,83,"بې شکه دغه ژمنه له موږ سره هم وشوه او له دې مخکې زموږ له پلرو سره هم، خو دا هماغه د پخوانيو له كيسو پرته بل څه نه دي."
  23,84,"ورته ووايه! (ښه نو) چا لره دي ځمكه او څه چې پكې دي؟ كه چېرې تاسو پوهېږئ."
  23,85,"ژر به هغوی ووايي: الله لره. ورته ووايه: نو آيا تاسو پند نه اخلئ؟"
  23,86,"ورته ووايه: د اوو آسمانونو او لوى عرش څښتن څوك دى؟"
  23,87,"ژر به هغوی ووايي: د الله دي، ورته ووايه: نو آيا تاسو نه وېرېږئ."
  23,88,"ورته ووايه: كه پوهېږئ څوك دى هغه ذات چې د هر شي واكمني يې په لاس كې ده او هغه پناه وركوي خو د هغه په مقابل كې څوك (چاته) پناه نه شي وركولى."
  23,89,"ژر به ووايي: الله دى، ورته وايه: نو له كومې خوا جادو درباندې كيږي."
  23,90,"بلكې موږ حق ورته راوړى خو هغوى (په خپله) درواغجن دي."
  23,91,"الله هيڅوك په اولاد نه دى نيولى، او نه له هغه سره بل معبود شته، (كنه) بيا به هر معبود له خپل مخلوق سره (بېل شوى) تللى و او يو پر بل به يي لوړتيا كوله الله لره پاكي ده، له هغه څه چې ورته بيانوي يې."
  23,92,"پر پټو او ښکاره و پوه دی، له هغه څه ډېر اوچت دى چې هغوى يې ورسره شريكوي."
  23,93,"ووايه: ای زما پالونکيه! كه هغه سزا راووينې چې له هغوی سره يې ژمنه كيږي."
  23,94,"ای زما پالونکيه! ما خو په ظالمانو خلكو كې مه شاملوه."
  23,95,"او بې شكه موږ پر دې قادر يو چې د كوم عذاب ژمنه هغوی سره كوو، هغه تا ته وښايو."
  23,96,"د بدۍ ايسارول په هغه توګه كوه چې ډېره غوره وي، موږ په هغه څه ډېر پوه يو چې دوى يې بيانوي."
  23,97,"او وايه چې اى زما ربه! د شيطان له وسوسو په تا پورې پناه غواړم."
  23,98,"او له دې نه هم پناه غواړم چې هغوى ما ته راشي."
  23,99,"تر هغه چې كوم يوه ته يې مرګ راشي، وايې اې زما ربه! بېرته مې وګرځوې."
  23,100,"ښايي په خپله شاته پريښې (دنيا كې) ښه كارونه وكړم، هيڅكله نه، دا يوه خبره ده چې هغه يې کوونکی دی. او (اوس) د هغوى په مخكې يوه پرده ده، تر هغې ورځې چې بيا ژوندي راپاڅول كيږي."
  23,101,"نو كله چې په شپېلۍ كې پوکی وشي بيا به يې هغه ورځ نه ترمنځ څه خپلوي وي او نه به پوښتنې سره كوي."
  23,102,"نو د چا تلې چې درنې شوې، هماغه خلك برى موندونكي دي."
  23,103,"او د چا چې تلې سپكې شي نو همدغه خلك دي چې خپل ځانونه يې تاواني كړي، په جهنم كې به تل اوسېدونكي وي."
  23,104,"اور به يې مخونه سوځوي او هغوی به بد شکله پكې پراته وي."
  23,105,"آيا زموږ آيتونه پر تاسو نه لوستل كېدل چې تاسو به هغه درواغ ګڼل."
  23,106,"وايي به ای زموږ پالونکيه! (رښتيا چې) خپله بد مرغي راباندې غالبه شوې وه او موږ له حق څخه بې لارې خلك وو."
  23,107,"ای زموږ ربه! له دې مو وباسه، كه بيا مو هماغسې وكړل؛ نو موږ به خامخا ظالمان يو."
  23,108,"وبه فرمايي: لرې چوپ شئ او مه راسره غږيږئ."
  23,109,"بې شكه زما بندګانو كې يوه ډله وه: ويل به يې زموږ ربه! موږ ايمان راوړى نو بخښنه راته وكړه او رحم راباندې وكړه او همدا ته له ټولو زيات مهربانه يې."
  23,110,"نو تاسو دومره ملنډې ورباندې وهلې چې آن زما ياد يې در څخه هېر كړ او تاسو به ورپورې خندل."
  23,111,"بې شکه نن مې هغوى ته په همدې صبر دا بدله وركړه چې همدوى بريالي دي."
  23,112,"الله به ووايي: په ځمكه كې مو څومره وخت تېر کړ؟ د كلونو په شمېر."
  23,113,"هغوى به وايي: يوه ورځ يا د ورځې څه برخه به ځنډېدلي يو؛ نو شمېرونكي وپوښته!"
  23,114,"وبه وايي: نه یاست پاتې شوي مګر لږ، كه تاسو (هغه وخت) پوهېدلى."
  23,115,"نو آیا تاسو دا ګومان كړی و چې موږ عبث (چټي) پيدا كړي ياست او تاسو به موږ ته نه راګرځئ."
  23,116,"نو الله اوچت دى، رېښتينى پاچا، له هغه پرته بل الله نشته، هماغه د لوى (يا عزتمن) عرش څښتن دى."
  23,117,"او څوك چې له الله سره بل معبود رابولي چې په اړه يې كوم دليل هم ورسره نشته؛ نو حساب يې له خپل رب سره دى، پرته له شکه چې داسې كافران نه بريالي کيږي."
  23,118,"او ووايه: ای زما پالونکيه بخښنه او رحم وكړې او ته تر ټولو زيات مهربان يې."
