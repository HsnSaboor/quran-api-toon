quran[36]{c,v,t}:
  83,1,"د ډنډه وهونکو (تول او پیمانه کمونکو) لپاره تباهي ده."
  83,2,"هغه کسان کله چې (ځانونو ته) پر خلکو پېمانه کوي پوره يې اخلي."
  83,3,"او کله چې هغوی ته پېمانه يا تول ورکوي بيا يې کموي."
  83,4,"ايا دوی باور نه کوي چې بېرته به را پاڅول کيږي."
  83,5,"يوې لويې ورځې ته."
  83,6,"په کومه چې به خلک د ټولو کايناتو پالونکي ته دريږي."
  83,7,"هيڅکله نه، پرته له شکه د بې لارې خلکو عملنامې به د بندې خونې په (کتاب)کې وي."
  83,8,"او ته څه خبر يې چې د زندان هغه دفتر څه دی."
  83,9,"يو ليکلی کتاب دی."
  83,10,"په هغه ورځ درواغ ګڼونکو ته تباهي ده."
  83,11,"هغه کسان چې د بدلې ورځ دروغ ګڼي."
  83,12,"او هغه دروغ نه ګڼي پرته له تيري کوونکي ګناهګار څخه."
  83,13,"کله چې زموږ ایتونه پرې لوستل کيږي وايي د پخوانيو کيسې دي."
  83,14,"هيڅکله نه، د هغوی پر زړونو هغه څه زنګ اچولی چې هغوی به کول."
  83,15,"هيڅکله نه، پرته له شکه هغه ورځ به هغوی د خپل پالونکي له ليدلو بې برخې وي."
  83,16,"بيا به هغوی هرومرو دوزخ ته ور ننوتونکي وي."
  83,17,"بيا به وويل شي: دا هغه څه دي چې تاسې دروغ ګڼل."
  83,18,"داسې نه ده، د نېکانو عملنامې به هرومرو په عليين کې وي."
  83,19,"او ته څه خبر يې چې عليين څه دی."
  83,20,"يو ليکل شوی کتاب دی."
  83,21,"چې يوازې يې مقربې پرېښتې ليدنه کولای شي."
  83,22,"پرته له شکه نېکان په نعمتونو کې وي."
  83,23,"پر تختونو باندې به وي ګورې به."
  83,24,"په مخونو کې به يې د نعمتونو تازه ګي پېژنې."
  83,25,"پر هغوی به سوچه مهر کړل شوي شراب څښل کيږي."
  83,26,"مهر به يې مشک وي، او په همدې کې دې سيالي کوونکي سره سيالي وکړي."
  83,27,"او ګډون به يې له تسنيم (چینې څخه) وي."
  83,28,"دا يوه چينه ده چې الله ته نېږدې خلک به ترې څښاک کوي."
  83,29,"بېشکه هغو کسانو چې جرم يې کړی پر هغو کسانو پورې خندل چې ايمان يې راوړی وو."
  83,30,"او کله به چې پر هغوی تېرېدل؛ نو يو بل ته به يې سترګکونه وهل."
  83,31,"او خپلو کورونو ته به چې ور ستنېدل خوشحاله به ورستنېدل."
  83,32,"او کله به يې چې هغوی (مسلمانان) وليدل ويل به يې: په رېښتيا چې دغه خلک لار ورکي شوي دي."
  83,33,"حال دا چې هغوی پرې څارونکي نه وو لېږل شوي."
  83,34,"نو نن به هغه کسان چې ايمان يې راوړی پر کافرانو پورې خاندي."
  83,35,"پر تختونو به ناست د هغوی ننداره کوي."
  83,36,"آیا کافرانو ته د هغه څه ثواب ورکړل شو چې کول يې؟"
