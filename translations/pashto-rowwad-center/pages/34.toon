quran[54]{c,v,t}:
  34,1,"ټولې ستاینې خاص الله لره دي، چې یوازې د هغه په اختیار کې دي څه چې په اسمانونو کې دي او څه چې په ځمکه کې دي، او په آخرت كې هم هغه لره ستاينه ده، هغه حكمت والا او باخبره دى."
  34,2,"پوهيږي پر هغه څه چې په ځمكه كې ننوځي او څه چې ترې راوځي او څه چې له آسمانه راكوزيږي او څه ورپورته کیږي او همغه مهربان بخښونكى دى."
  34,3,"او كافران وايي چې موږ ته به قيامت رانه شي! ورته ووايه: ولې نه، په رب مې دې قسم وي چې د غيبو عالم دى هرومرو به درته راشي، له هغه څخه نه په آسمانونو او نه پر ځمكه كې د يوې ذرې په اندازه څه نه پټيږي، او نه به له دې كوچنى او نه (ترې) لوى څه داسې شى وي چې هغه په يو څرګند كتاب كې نه وي."
  34,4,"د دې لپاره چې هغو خلكو ته بدله وركړي چې ايمان يې راوړى او ښه كارونه يې كړي، د هغوى لپاره بخښنه او غوره روزي ده."
  34,5,"او هغوى چې زموږ د آيتونو په را لاندې كولو كې او له مینځه وړلو کې يې هلې ځلې كړې دي، هغوى لپاره ناوړه دردوونکی عذاب دى."
  34,6,"او چا ته چې پوهه وركړى شوې هغوى ويني چې ستا د رب لخوا څه درته نازل شوي هغه حق دي او د برلاسي ستايلي (ذات) لوري ته ښوونه كوي."
  34,7,"او هغو کسانو چې کفر کړی وويل: آيا تاسي ته يو داسې سړى دروښايو چې هغه مو په دې خبروي چې كله تاسي پوره ذرې ذرې شئ نو تاسي به په يو نوي پيدايښت كې راشئ!"
  34,8,"آیا پر الله يې درواغ تړلي یا په هغه كې ليونتوب دى؟ (نه) بلكې هغوى چې آخرت نه مني په عذاب او (له حقه) په لېري بې لاريتوب كې دي."
  34,9,"ايا دوى هغه اسمان او ځمكه نه دي ليدلي چې له دوی وړاندې او وروسته راچاپېر شوي دي؟ كه موږ وغواړو نو دوى به په ځمكه ننباسو، يا به د اسمان څه ټوټې پر دوى را وغورځوو، په حقيقت كې په دې كې د هر هغه بنده لپاره يوه نښانه ده چې د الله طرف ته ورګرځېدونكى وي."
  34,10,"او موږ داود (علیه السلام) ته له خپل لوري فضيلت وركړى و، اې غرونو له هغه سره تسبيح تكراروئ او (اې) مرغانو (تاسو هم)، او هغه ته مو اوسپنه پسته كړه."
  34,11,"چې ښې ښې (پوره) زغرې جوړوه او په اوبدلو كې اندازه ساته او (تاسي ټول) ښه ښه كارونه كوئ، بې شكه زه ستاسي د كړو وړو ليدونكى يم."
  34,12,"او سليمان (علیه السلام) ته مو باد تابع كړى و چې د سهار مزل يې هم د مياشتې و او د ماښام يې هم د يوې مياشتې او هغه ته مو د تانبې چينه (هم) بیولې وه، او تابع کړي وو موږ د پېريانو څخه چې د خپل رب په حكم يې د هغه پر وړاندې كار كولو، او څوك چې په دوی کې زموږ د حکم څخه سرغړونه وکړي، هغه ته به د بل شوي اور عذاب ور وڅكو."
  34,13,"سليمان (علیه السلام) به چې څه غوښتل هغه به دوى ورته جوړولو (لکه) عبادتخانې، مجسمې (څېرې)، د حوضونو په څېر خانكونه او په نغريو ولاړو دېګونه، اې د داود (علیه السلام) كورنۍ (د دې) شكرانې لپاره (نېك) عمل كوئ او زما بندګانو كې لږ شكر وېستونكي دي."
  34,14,"بيا كله چې موږ پر سليمان (علیه السلام) د مرګ فيصله وكړه، نو پېريانو ته د هغه د مرګ خبر وركوونكى بل څه نه و پرته له هغه چینجي چې د هغه امسا يې خوړله، په دې ډول كله چې سليمان (علیه السلام) راولوېده، نو (خلکو ته) پېریان څرګند شول چې كه دوى په غيبو پوهېدلی نو دغه سپکونکی عذاب كې به نه وو پاتې شوي."
  34,15,"د سبا (قوم) لپاره د هغوى په هېواد كې (لويه) نښانه وه، ښۍ او كيڼې خواته دوه باغونه وو (ورته وويل شول) خورئ د خپل رب له روزۍ څخه او شكر يې وباسئ، دا پاكيزه ښار او هغه بخښونكى رب دى."
  34,16,"خو هغوى مخ واړولو نو يو زورور سيلاب مو ورباندې راخوشې کړ، او د هغوى دوه باغونه مو په داسې دوو باغونو وربدل كړل چې بې خونده مېوه، او د غز (ونې) او لږ څه بيره يې درلوده."
  34,17,"د هغوى په ناشكرۍ مو همدا بدله وركړه او موږ پرته له ناشكره بل چا ته (داسې) بدله نه وركوو."
  34,18,"او موږ د دوى او هغو كليو ترمنځ چې بركت مو پكې اچولى دى څه نور (په لاره) څرګند كلي هم آباد كړي او (د) تګ راتګ (پړاوونه) مو پكې اندازه كړي وو، (چې) د شپې او ورځې بې غمه پكې ګرځئ."
  34,19,"(خو) بيا هغوى وويل: زموږ ربه! زموږ سفرونه لرې كړه او په خپلو ځانونو يې ظلم وكړ نو بيا مو هغوى (پخوانۍ) کيسې وګرځول او په بشپړ ډول مو سره وپاشل، بې شكه په دې كې هرومرو د هر صبرناك شكر اېستونكي لپاره (ډېرې) نښانې دي."
  34,20,"او په رېښتيا چې ابليس پر هغوى خپل ګومان رښتيا وموند، چې د مؤمنانو له يوې ډلې پرته ډېرو يې پيروي وكړه."
  34,21,"او (حال دا چې) د ابليس خو پر هغوى كوم زور هم نه و، خو يوازې د دې لپاره چې معلوم كړو [خلکو ته] څوك په آخرت ايمان لري له هغو نه چې د آخرت په اړه په شك كې دي او ستا پالونکی په هر څه ساتونكى دى."
  34,22,"ووايه: راوبولئ كوم چې تاسي له الله پرته (معبودان) انګېرلي، هغوى خو د يوې ذرې په اندازه څه په واك كې نه لري، نه په آسمانونو كې او نه په زمكه كې او نه يې په دې دواړو كې څه برخه شته او نه له هغوى څوك د الله مرستندوى دى."
  34,23,"او د هغه پر وړاندې سپارښتنه هم چاته ګټه نه رسوي پرته له هغه چې اجازه يې ورته كړې وي، تر هغو چې له زړونو يې وېره لېرې شي، وايي: ستاسو رب څه وويل؟ (په ځواب كې) ورته وايي حق (يې وويل) او همغه ډېر اوچت او لوى دى."
  34,24,"ورته ووايه: تاسي ته له آسمانونو او زمكې څوك روزي دركوي؟ (خپله) ورته ووايه: الله، او دا چې په موږ اوتاسو کې څوک په پوره هدایت دی او يا څرګند بې لارېتوب کې دی."
  34,25,"ووايه: تاسي له هغو بدو نه پوښتل كيږئ چې موږ كړي وي او له هغو موږ نه پوښتل كيږو چې تاسو يې كوئ."
  34,26,"ووايه زموږ پالونکی به مو راغونډوي بيا به په حقه سره زموږ تر منځ پرېکړه كوي او همغه ډېر پوه ښه پرېکړه كوونكى دى."
  34,27,"ووايه: ماته راوښايئ هغه چې تاسو د شريكانو په توګه ورسره نښلولي دي، خو نه؛ بلکې په اصل كې برلاسى او د حكمت والا همغه الله دى."
  34,28,"او ته مو ټولو خلكو ته پرته له يو زېري وركونكي او وېروونكي بل څه نه يې لېږلى خو زياتره خلك نه پوهيږي."
  34,29,"او هغوى وايي: كه تاسو ریښتيني ياست نو دا ژمنه به كله وي؟"
  34,30,"ووايه ستاسو لپاره د ژمنې يوه ټاكلې ورځ ده چې نه به يو ساعت ترې وروسته كېږئ او نه به وړاندې كېږئ."
  34,31,"او كوم كسان چې كافر شوي وايي هيڅكله به نه په دې قرآن ايمان راوړو او نه په هغه چې ترې مخكې و. او كه ته دا ظالمان ووينې چې د خپل رب په وړاندې درول شوي، يو بل ته خبره ورګرځوي، څوك چې كمزوري ګڼل شوي وو هغوى به لويي غوښتونكو ته وايي چې كه تاسو نه واى موږ به هرومرو مؤمنان وو."
  34,32,"لويي غوښتونكي به ضعيفانو ته وايي چې آيا له هغه وروسته هم موږ له هدايته ايسار كړي وئ چې درته راغى؟ خو نه په اصل كې (خپله) تاسو مجرمان وئ."
  34,33,"او (بيا به) كمزوري ګڼل شوي كسان لويي غوښتونكو ته وايي چې نه په اصل كې همدا ستاسو د شپې ورځې چلونه وو چې موږ ته مو امر كولو تر څو پر الله كفر وکړو او هغه سره شريكان وګرځوو، او كله چې عذاب وويني نو هغوى (ټول) به په پټه (ډېره) پښيماني وكړي، او كوم كسان چې كافر شوي دي په غاړو كې به يې ځنځيرونه ورواچوو، آيا هغوی ته له هغو عملونو پرته چې هغوى به كول د بل څه بدله وركول كيږي؟"
  34,34,"او په هر كلي كې چې موږ څوك خبردارى وركوونكى لېږلى له دې پرته بل څه نه و چې سوكاله خلكو به يې ويل: له څه شي سره چې تاسي رالېږل شوي ياست موږ له هغه منكر يو."
  34,35,"او ويل به يې موږ په مالونو او اولادونو كې ډېر زيات يو او موږ په عذابېدونكي نه يو."
  34,36,"ووايه: په رېښتيا زما رب چا ته چې وغواړي روزي يې پراخوي او (يا يې) تنګوي خو زياتره خلك نه پوهيږي."
  34,37,"نه دي مالونه ستاسي او نه اولادونه ستاسي په هغه درجه کې چې موږ ته مو نزدې کړي په نزدیوالي سره، لیکن هغه چا چې ایمان راوړی وي اونیک عملونه یې کړي وي، پس دوی لره به د دوی د کړنې له امله دو چنده بدله وي، او هغوى به بې غمه په دنګو ماڼيو كې وي."
  34,38,"او كوم كسان چې زموږ د آيتونو په كمزوري كولو كې هلې ځلې كوي، هغوى په عذاب كې حاضرېدونکي دي."
  34,39,"ورته ووايه: یقینا زما رب روزي پراخوي چا ته چې وغواړي له خپلو بندګانو او (يا يې) ورته تنګوي او هغه څه چې تاسو يې (په خير كې) لګوئ نو هغه (الله) يې بدله دركوي او همغه تر ټولو ښه روزي وركونكى دى."
  34,40,"او هغه ورځ چې دوى ټول راغونډ كړي بيا به پرېښتو ته وايي آيا دې خلكو ستاسي عبادت كولو؟"
  34,41,"هغوى به وايي: تا لره پاكي ده، ته زموږ دوست يې نه هغوى، (زمونږ عبادت یې نه دی کړی) بلکې د پېريانو عبادت یې کاوه زياترو يې پر هغوى ايمان درلود."
  34,42,"نو نن به تاسې د يو بل لپاره د هيڅ ګټې او تاوان واك نه لرئ او كومو خلكو چې ظلم كړى موږ به هغوى ته ووايو: (اوس) د هغه اور عذاب وڅكئ چې تاسو به درواغ ګڼلو."
  34,43,"او كله چې پر هغوى زموږ څرګند آيتونه لوستل كيږي، وايي دا بل څه نه دي پرته له يو داسې سړي چې غواړي له هغه څه مو راوګرځوي چې ستاسو پلرونو به یې عبادت کاوه، او وايي به: دا له ځانه جوړ شوو درواغو پرته بل څه نه دي. او كوم خلك چې كافر شوي دي كله چې حق ورته راغى (نو) ويلې دا خو له ښكاره كوډو پرته بل هيڅ نه دي!"
  34,44,"موږ له تا مخكې دوی ته نه څه كتابونه وركړي وو چې هغه یې لوستل، او نه مو ورته څوك وېروونكى وراستولى و."
  34,45,"او له دوى مخكې خلكو هم (زموږ خبره) دروغ ګڼلې وه او هغوى ته مو چې څومره وركړي وو، دوى يې لسمې (برخې) ته هم نه دي رسېدلي خو چې زما رسولان يې دروغجن وګڼل نو بيا زما عذاب څنګه و؟"
  34,46,"ورته ووايه: زه تاسي ته يوازې د يوې خبرې نصيحت كوم: دا چې الله ته دوه دوه ودرېږئ او (يا) يو يو، بيا (ښه) سوچ وكړئ، ستاسي په (دې) ملګري كې خو څه ليونتوب نشته، هغه خو د يو سخت عذاب پر وړاندې ستاسو لپاره له يو وېروونكي پرته بل څه نه دى."
  34,47,"ورته وايه: که څه مزدوري مې درڅخه وغوښته [په دې دعوت] هغه دې ستاسو وي، زما بدله له الله پرته پر بل چا نه ده، او همغه پر هر څه شاهد دى."
  34,48,"ووايه: بېشكه زما رب حق په کلکه بیانوي، پر پټو ډېر ښه پوه دی."
  34,49,"ووايه: حق راغى، او باطل (معبود) نه لومړی څه پيدا كړي دي او نه يې بيا پيدا كولاى شي."
  34,50,"ووايه: كه زه بې لارې شوى يم نو د بې لارې كېدو تاوان مې پر خپل ځان دى او كه په سمه لار يم نو د هغې وحي په واسطه چې زما رب يې راته كوي، بېشكه همغه ښه اورېدونكى رانېږدې دى."
  34,51,"که چیرته تا (دا حالت) لیدلای (ای مخاطبه!) چې كله ووېريږي [ملک الموت یا عذاب ورته راشۍ] پټېدلای به نه شي، او په كوم نېږدې ځاى كې به راګير كړى شي."
  34,52,"وايي به: موږ پرې ايمان راوړى دى، نو څرنکه به شي دوی لپاره (له مرګ وروسته د ایمان رانیول) له لېرې ځایه (له دنیا څخه)؟"
  34,53,"حال دا چې مخکې ترې منكر شوي وو، او له لېرې ځايه به يې د غيبو ويشتل كول."
  34,54,"او د هغوى او غوښتنو تر منځ يې پرده جوړه شوې ده لكه چې لا مخکې يې په سيالانو دا كار شوى و، بېشكه هغوى هم په زړه نا زړه كوونكي شك كې وو."
