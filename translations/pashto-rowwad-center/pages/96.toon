quran[19]{c,v,t}:
  96,1,"ولوله د خپل هغه پالونکي پر نوم چې پيدا يې کړ."
  96,2,"انسان يې د وينې له ټوټې پيداکړ."
  96,3,"ولوله! او ستا پالونکی ډېر مهربانه دی."
  96,4,"هغه چې پر قلم يې ښوونه ورکړه."
  96,5,"انسان يې پر هغه څه پوه کړ چې نه پرې پوهېدلو."
  96,6,"نه داسې نه ده، انسان هرومرو سرکښي کوي."
  96,7,"کله چې ځان مالدار وویني."
  96,8,"بېشکه ستا د پالونکي لوري ته ورګرځېدل دي."
  96,9,"آيا هغه څوک دې ليدلی چې ايساروي."
  96,10,"بنده لره کله لمونځ کوي."
  96,11,"آيا ته يې وينې که هغه پر سمه لار وي."
  96,12,"آو يا پر ځان ساتنه (تقوا) امر کوي."
  96,13,"آيا پام دې دی که هغه سړی درواغ ګني يا مخ اړوي."
  96,14,"آيا هغه نه پوهيږي چې الله هرڅه ويني."
  96,15,"هيڅکله نه، داسې نه ده، که هغه ترې ايسار نه شو، موږ به يې هرومرو د تندي له وېښتانو را ونيسو."
  96,16,"له درواغجن خطا کار تندي څخه."
  96,17,"بيا دې خپل مجلسي ياران راوبولي."
  96,18,"زر ده چې موږ به هم د عذاب پرېښتې را وغواړو."
  96,19,"نه؛ داسې نه ده د هغه خبره مه منه، (اوخپل الله ته) سجده کوه، ور نېږدې شه."
