quran[21]{c,v,t}:
  92,1,"قسم دی پر شپه کله چې را خپره شي."
  92,2,"او په ورځ قسم کله چې رڼا شي."
  92,3,"او د نارينه او ښځينه په پيدايښت قسم."
  92,4,"بېشکه ستاسو هڅې راز راز دي."
  92,5,"نو هغه څوک چې ور یې کړ حق او تقوا یې وکړه."
  92,6,"او ښه خبره يې رېښتيا وبلله."
  92,7,"نو خامخا اسانه به کړو هغه لار د اسانۍ."
  92,8,"او چاچې بخيلي وکړه او (له خپل الله يې) بې پروايي وکړه."
  92,9,"او ښه خبره يې درواغ وګڼله."
  92,10,"نو زر ده چې هغه به سختې لارې ته تيار کړو."
  92,11,"او مال به يې هيڅ شی ترې ايسار نه کړي کله چې هغه تباه شي."
  92,12,"بېشکه لارښوونه پر موږ ده."
  92,13,"او پرته له شکه آخرت او دنيا هم موږ لره دي."
  92,14,"نو تاسې مو له لمبه وهونکي اور څخه وېرولي ياست."
  92,15,"چې يوازې ډېر بدمرغه خلک به ورننوځي."
  92,16,"هغه چې درواغ يې وګڼل او مخ يې واړولو."
  92,17,"او ډېر پرهېزګار به ترې په څنګ کړل شي."
  92,18,"کوم چې د ځان پاکولو لپاره خپل مال ورکوي."
  92,19,"او له هغه سره د هيچا کومه ښېګڼه نه وي چې بدله يې ورکړی شي."
  92,20,"مګر د خپل رب د مخ د لټولو د پاره چې په ټول مخلوق اوچت دی."
  92,21,"او زر ده چې هغه به راضي شي."
