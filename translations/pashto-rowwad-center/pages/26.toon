quran[227]{c,v,t}:
  26,1,"طسم."
  26,2,"دا د هغه څرګند كتاب آيتونه دي."
  26,3,"اى محمده! ښايي ته پدې غم كې خپل ځان بايلې چې دغه خلك ايمان نه راوړي."
  26,4,"كه موږ وغواړونو له اسمانه داسې نښانه نازلولى شو چې د دوى غاړې د هغې پر وړاندې ښكته شي."
  26,5,"او نه راځي دوی ته هېڅ یاداښت د رحمن له لورې چې نوی وي (د هغه راتلل) مګر دوی له هغه څخه مخ اړوونکي دي."
  26,6,"نو اوس چې درواغ يې وګڼلو ډېر زر به د هغه څه خبرونه ورته راشي چې ملنډې به يې پرې وهلې."
  26,7,"آیا دوی نه ګوري ځمکې ته چې څومره رازرغون کړي دي موږ په هغې کې د هر قسم ګټور بوټي څخه."
  26,8,"په دې كې خو په رېښتيا (لويه) نښانه ده، خو ډېری يې منونكي نه دي."
  26,9,"او بې شكه همغه ستا رب ښه مهربان برلاسى دى."
  26,10,"او هغه مهال چې ستا رب غږ وکړ موسى ته چې لاړ شه قوم ظالمانو ته."
  26,11,"د فرعون قوم ته! آيا هغوى نه ويريږي؟"
  26,12,"ويې ويل زما ربه! زه ډارېږم چې درواغجن به مې وګڼي."
  26,13,"او سينه مې (هم) تنګيږي او ژبه مې نه ګرځي نو هارون ته يې ولېږه (وحی)."
  26,14,"او پر ما باندې د هغوی لخوا د يو جرم تور هم شته، ځكه نو زه ويريږم چې هغوى به ما ووژني."
  26,15,"الله وويل: هېڅكله نه، نو دواړه زموږ له نښانو سره ورشئ، موږ درسره يو، د (هر څه) اورېدونكي."
  26,16,"نو ورشئ دواړه فرعون ته ورته او وايئ چې موږ رالیږل شوي یو د مخلوقاتو د پالونكي لخوا."
  26,17,"چې ته بني اسرائيل له موږ سره ولېږې."
  26,18,"وېلې: آيا ته مو له ځان سره وړوكى ونه روزلې او د خپل عمر ډېر كلونه دې راسره تېر (نه) كړل."
  26,19,"او ها چې كړى دې و هغه كار دې هم وكړ او ته له ناشكرانو څخه يې."
  26,20,"(موسى) وويل: ما هغه وخت كړى و چې زه له ناپوهانو وم."
  26,21,"بيا چې كله ووېرېدم نو درڅخه وتښتېدم، نو خپل رب مې حكم (علم) راكړ او په رسولانو كې يې شامل كړم."
  26,22,"او (آيا) دا كومه پېرزوينه ده چې پر ما يې احسان باروې دا چې بني اسرائيل دې مريان كړي."
  26,23,"فرعون وويل: او دا رب العالمين لاڅه دى؟"
  26,24,"وېلې د آسمانو، ځمكې او د هغو تر منځ د ټولو شيانو پالونكى، كه تاسو باور كوونكي ياست."
  26,25,"فرعون خپلو شاوخوا خلكو ته وويل: تاسو نه اورئ؟"
  26,26,"موسى وويل: ستاسو پالونكى او ستاسو د مخکېنيو پلرونو پالونكى دی."
  26,27,"فرعون وويل: يقيناً ستاسو دا رسول چې درته رالېږل شوى بالكل ليونى دى."
  26,28,"موسى وويل: د ختيځ، لويديځ او د هغو تر منځ شيانو رب دى، كه تاسو عقل كاروئ."
  26,29,"فرعون وويل: كه له ما پرته دې بل معبود ونيولو، هرومرو به دې له بنديانو وګرځوم."
  26,30,"موسى وويل: كه څه هم يو څرګند شى درته راوړم."
  26,31,"ويې ويل: كه ته رښتينى يې نو رايې وړه!"
  26,32,"نو ګذاره یې کړه لکړه (امسا) خپله؛ نو هغه يو دم ښكاره ښامار و."
  26,33,"او چې خپل لاس يې راوويستو نو هغه (ټولو) كتونكو ته روڼ ځلاند و."
  26,34,"فرعون خپلو چاپېرو سردارانو ته وويل: بې شكه چې دا سړى هرومرو يو پوه كوډګر دى."
  26,35,"غواړي چې په خپلو كوډو تاسي له خپلې ځمكې وباسي؛ نو تاسو څه حكم كوئ؟"
  26,36,"هغوى وويل: دى او ورور يې ايسار كړه او ولیږه ښارونو ته راټولوونکي."
  26,37,"چې هر يو پوه كوډګر درته راولي."
  26,38,"بيا نو د يوې معلومې ورځې په ټاكلي وخت كوډګران راټول كړى شول."
  26,39,"او خلكو ته وويل شول چې تاسې به راټوليږئ؟"
  26,40,"چې ښايې موږ كوډګرو پسې لاړ شو، كه چېرې هغوى برلاسي شول."
  26,41,"نو كوډګر چې راغلل فرعون ته يې وويل: موږ ته خو به څه بدله وي كه چېرې موږ بريالي شولو؟"
  26,42,"وېلې هو او بيا به تاسي (زموږ) له نېږدې كسانو ياستئ."
  26,43,"موسى ورته وويل: څه چې غورځوئ هغه وغورځوئ."
  26,44,"نو (له واره يې) خپلې رسۍ او لکړې (امساګانې) وغورځولې او ويې ويل: په عزت د فرعون (قسم چې) همدا موږ به بريالي يو!"
  26,45,"بيا موسى خپله امسا وغورځوله نو په ناڅاپي ډول هغې د هغو د دروغو كارنامې خوړلې تيرولې."
  26,46,"نو كوډګر (سملاسي) په سجده پرېوتل."
  26,47,"وېلې: موږ په رب العالمين ايمان راوړ."
  26,48,"د موسى او هارون پر رب."
  26,49,"وېلې (فرعون): (ښه) تاسي بيا د هغه ومنله مخكې لدې چې زه اجازه درته وكړم؟ خامخا همدى ستاسو هماغه مشر دى چې كوډې يې در زده كړي دي، نو زر به پوه شئ، زه به هرومرو ستاسي لاسونه او پښې چپه غوڅ كړم او ټول به په دار وځړوم."
  26,50,"هغوى وويل هېڅ تاوان نه دى، موږ د خپل رب لور ته ورتلونكي يو."
  26,51,"او موږ هيله من يو چې زموږ رب به زموږ ګناهونه وبخښي ځكه چې موږ تر ټولو مخكې ايمان راوړی دى."
  26,52,"او موسى ته مو وحى وكړه چې (شپه په شپه) زما بندګان درسره روان كړه، (او) تاسو به هرومرو له څټه پلټل كېږئ."
  26,53,"بيا نو فرعون (ټولو) ښارونو ته ماسلان ولېږل."
  26,54,"چې دغه (بني اسرائيل) يوه ډله لږ كسان دي."
  26,55,"او بې شكه موږ يې ډېر په غوسه كړي يو."
  26,56,"او موږ يوه چمتو بيداره ډله يو."
  26,57,"پس وویستل دوی لره موږ له باغونو او چینو څخه."
  26,58,"او له خزانو او ښه هستوګنځي څخه."
  26,59,"همدارنګه وشول او بني اسرائيل مو د هغو (شيانو) وارثان وګرځول."
  26,60,"پس روان شول (فرعونیان) هغوی پسې د لمر ختو پر مهال."
  26,61,"كله چې دواړه ډلې سره مخامخ شوې، د موسى ملګرو وويل: چې (دا دى) موږ خو ګيرېدونكي يو."
  26,62,"وېلې هېڅكله نه! پرته له شکه ما سره مې رب دى، زر به لار راوښايي."
  26,63,"نو موسى ته مو وحي وكړه چې په خپله لکړه (امسا) دې سيند و وهه؛ نو هغه وچاودلو او هره ټوټه لكه لوى غر وه."
  26,64,"او رانږدې کړل موږ هلته نور کسان."
  26,65,"او موسى او څوك چې ورسره وو، ټول مو وژغورل."
  26,66,"بيا مو هغه نور (ټول) غرق كړل."
  26,67,"په دې كې خو په رېښتيا (لوی) پند دی، خو ډېری يې منونكي نه دي."
  26,68,"او بې شكه همغه ستا رب ډیر زورو او مهربان دى."
  26,69,"او په هغوى د ابراهيم خبر (هم) ولوله."
  26,70,"كله چې خپل پلار او قوم ته يې وويل: (دا) څه شى لمانځئ؟"
  26,71,"وېلې: بوتان لمانځو او همداسې به يې په خدمت (او درناوي) لګيا اوسو."
  26,72,"ابراهيم وويل: آيا هغوى ستاسي (خبره) اوري كله يې چې رابولئ؟"
  26,73,"يا څه ګټه يا زيان در رسوي؟"
  26,74,"هغوى وويل: نه، خو خپل پلرونه مو موندلي دي چې همداسې به يې كول."
  26,75,"هغه وويل:نو آيا خبر یاست تاسو په حال د هغه چا چې تاسو یې بندګي کوله."
  26,76,"تاسو او ستاسي پخوانيو پلرونو."
  26,77,"نو هغوى خو ټول زما دښمنان دي، پرته د مخلوقاتو له پالونکي څخه."
  26,78,"هماغه چې زه يې پيدا كړى يم او لارښوونه راته كوي."
  26,79,"هغه ذات چې ماته خوراك او څښاك راكوي."
  26,80,"او چې ناروغ شم، خو هماغه مې روغوي."
  26,81,"او همغه چې مړ كوي مې او بيا مې راژوندى كوي."
  26,82,"او هغه چې زه ترې هيله لرم چې د جزا په ورځ به مې تېروتنې را وبخښي."
  26,83,"زما ربه! ماته حكم (علم او نبوت) راکړه او له صالحانو سره مې يوځاى كړې."
  26,84,"او په وروستيو نسلونو كې د نېكنامۍ يادونه را په برخه كړې."
  26,85,"او د نعمتونو د جنت له وارثانو مې وګرځوې!"
  26,86,"او پلار ته مې بخښنه وكړې، هغه له بې لارو څخه دى."
  26,87,"او په هغه ورځ مې مه شرموې چې خلك راپاڅول كيږي."
  26,88,"همغه ورځ چې نه مال ګټه رسوي او نه زامن."
  26,89,"پرته له دې چې څوك په روغ زړه الله ته ورغلى وي."
  26,90,"او (كله) چې متقيانو ته جنت ورنږدې كړى شي."
  26,91,"او بې لارې شوو ته دوزخ ورڅرګند كړى شي."
  26,92,"او ورته وويل شي: هغه شيان چېرته دي چې تاسو به لمانځل."
  26,93,"له الله پرته، آيا څه مرسته مو كوي؟ يا د خپل ځان مرسته كولاى شي؟"
  26,94,"نو پړمخ به پكې وغورځول شي، هغوى (معبودان يې) او بې لارې شوي كسان."
  26,95,"او د ابليس ټول لښكر."
  26,96,"هلته به خپلو كې شخړه كوي او وايي به."
  26,97,"په الله قسم موږ خو يقيناً په ښكاره بې لارېتوب كې وو."
  26,98,"چې تاسو (باطل معبودان) مو له رب العالمين سره برابرولئ."
  26,99,"او موږ پرته له همغو مجرمانو (مشرانو) بل چا نه يو بې لارې كړي."
  26,100,"نو (اوس) زموږ هيڅوك سپارښتونكى نشته."
  26,101,"او نه څوك مخلص ملګرى."
  26,102,"خو كاشكې كه موږ ته يو ځل (بيا وخت) واى نو موږ به مومنان وو."
  26,103,"په دې كې خو په رېښتيآ (لويه) نښانه ده، خو ډېری يې منونكي نه دي."
  26,104,"او بې شكه همغه ستا رب ښه زورور مهربان دی."
  26,105,"د نوح قوم (هم) رسولان درواغجن وګڼل."
  26,106,"کله چې وویل دوی ته ورور د دوی نوح، آیا ځان نه بچ کوئ (له عذاب څخه)."
  26,107,"زه ستاسي لپاره يو امانتګر پيغمبر يم."
  26,108,"نو تاسو له الله نه ووېرېږئ او زما اطاعت وكړئ."
  26,109,"او په دې له تاسو څه بدله هم نه غواړم زما بدله يوازې د مخلوقاتو پر پالونکي ده."
  26,110,"نو له الله ووېرېږئ او زما خبره ومنئ."
  26,111,"هغوى وويل: آيا موږ به تا منو حال دا چې (يوازې) رذيلانو (خوارانو) ستا پيروي کړې ده."
  26,112,"نوح وويل: او زه څه پوهه لرم په هغه څه چې هغوى به كول."
  26,113,"د هغوى حساب زما له ربه پرته په بل چا نه دى كه تاسو پوهېږئ."
  26,114,"او زه د دې مومنانو شړونكى هم نه يم."
  26,115,"زه له يو څرګند وېروونكي پرته بل څه نه يم."
  26,116,"هغوى وويل: ای نوحه! كه ته له دې (خبرو) منع نه شوې نو خامخا به له ويشتل شويو څخه شې."
  26,117,"هغه ته يې قوم وويل: که چېرې له هغه څه څخه لاس په سر نه شې چې موږ وربولې؛ نو هرومرو به له ښکنځل شويو او په ډبرو له وژل شويو څخه شې."
  26,118,"نو ته زما او د دوى په مینځ كې فیصله وكړه واضحه فیصله او ته ما ته نجات راكړه او هغه چا ته چې له ما سره كوم مومنان دي."
  26,119,"نو موږ هغه او څوك چې ورسره وو په يوه ډكه بېړۍ كې وژغورل."
  26,120,"بيا وروسته مو هغه پاتې كسان غرق كړل."
  26,121,"په دې كې خو په رېښتيا (لويه) نښانه ده، خو ډېری يې منونكي نه دي."
  26,122,"او بې شكه همغه ستا رب ښه مهربان برلاسى دى."
  26,123,"عاديانو رسولان درواغجن وګڼل."
  26,124,"کله چې وویل دوی ته ورور د دوی هود، آیا ځان نه بچ کوئ (له عذاب څخه)."
  26,125,"زه ستاسي لپاره يو امانتګر پيغمبر يم."
  26,126,"نو تاسو له الله نه ووېرېږئ او زما اطاعت وكړئ."
  26,127,"او په دې له تاسو څه بدله هم نه غواړم زما بدله يوازې د مخلوقاتو پر پالونکي ده."
  26,128,"آيا تاسي په هره لوړه يوه نښه جوړوئ (او) چټيات كوئ."
  26,129,"او (داسې) پخې كلاګانې جوړوئ لكه چې تل به ياست."
  26,130,"او چاته چې لاس اچوئ نو په سختۍ (او ظلم) سره يې اچوئ."
  26,131,"نو تاسو له الله نه ووېرېږئ او زما اطاعت وكړئ."
  26,132,"او له هغه ذاته ووېرېږئ چې په هغه څه يې ستاسو مرسته كړې، كوم چې درته معلوم دي."
  26,133,"په څارويو او زامنو يې ستاسو مرسته كړې."
  26,134,"او په باغونو او چينو سره."
  26,135,"زه په رېښتيا پر تاسو د سترې ورځې له عذابه وېرېږم."
  26,136,"هغوى وويل: موږ ته برابره ده كه نصيحت كوې، يا (هيڅ) نصيحت كوونكى نه اوسې."
  26,137,"دا خو همغه د پخوانيو له عادته پرته بل څه نه دي."
  26,138,"او موږ (هېڅكله) عذابېدونكي نه يو."
  26,139,"نو چې درواغجن يې وبللو، هلاك مو كړل، يقيناً په دې كې يوه (ستره) نښانه ده، او زياتره يې ايمان راوړونكي نه وو."
  26,140,"او بې شكه همغه ستا رب ښه مهربان برلاسى دى."
  26,141,"ثموديانو رسولان درواغجن وګڼل."
  26,142,"كله چې ورور يې صالح ورته وويل: آيا نه ډارېريږئ؟"
  26,143,"زه ستاسي لپاره يو امانتګر پيغمبر يم."
  26,144,"نو تاسو له الله نه ووېرېږئ او زما اطاعت وكړئ."
  26,145,"او په دې له تاسو څه بدله هم نه غواړم زما بدله يوازې د مخلوقاتو پر پالونکي ده."
  26,146,"آيا تاسو به په هغو شيانو (او نعمتونو) كې چې دلته دي، بې غمه پرېښودل شئ؟"
  26,147,"په (همدې) باغونو او چينو كې."
  26,148,"او كښتونو او داسې كجورو كې چې وږي يې پاسته او تازه (يا ډك) وي."
  26,149,"او غرونه توږئ، مهارت سره كورونه (پكې) جوړوئ."
  26,150,"نو تاسو له الله نه ووېرېږئ او زما اطاعت وكړئ."
  26,151,"او له برېده اوښتونكو خلكو امر مه منئ."
  26,152,"هغوى چې په ځمكه كې (ايله) فساد خپروي او څه سمون نه راولي."
  26,153,"هغوى ويل: خبره دا ده چې ته يو كوډو وهلى (جادو کړی شوی) انسان يې."
  26,154,"ته (هم) زموږ په شان له يو بشر پرته بل څه نه يې، نو كه رښتينى يې څه نښانه خو راوړه!"
  26,155,"صالح وويل: دا ده اوښه، هغې لره د اوبو څښلو نوبت او ستاسو د څښاك خپله ورځ معلومه ده."
  26,156,"او هغې ته هيڅ ضرر مه رسوئ كنه د لويې ورځې عذاب به مو راګير كړي."
  26,157,"خو هغه يې مړه كړه او هغوى هم بيا پښېمانه شول."
  26,158,"نو عذاب راونيول، په رېښتيا په دې كې خامخا يوه نښانه ده او زياتره يې ايمان راوړونكي نه وو."
  26,159,"او بې شكه همغه ستا رب ښه مهربان برلاسى دى."
  26,160,"د لوط (علیه السلام) قوم رسولان درواغجن وګڼل."
  26,161,"كله چې ورور يې لوط ورته وويل: آیا نه ډارېږئ."
  26,162,"زه ستاسي لپاره يو امانتګر پيغمبر يم."
  26,163,"نو تاسو له الله نه ووېرېږئ او زما اطاعت وكړئ."
  26,164,"او په دې له تاسو څه بدله هم نه غواړم زما بدله يوازې د مخلوقاتو پر پالونکي ده."
  26,165,"آیا راتګ کوئ تاسي (په لواطت کولو) نارینه وو ته له خلکو."
  26,166,"او هغه مېرمنې مو پرېږدئ چې خپل رب مو درته پيدا كړې دي، بلكې تاسي له پولې تېرېدونكي خلك ياست."
  26,167,"هغوى وويل: اى لوطه! كه ايسار نه شوې، خامخا به ته هم له اېستل شويو څخه يې."
  26,168,"هغه وويل: بې شكه زه ستاسي د دې عمل له بدګڼونكو څخه يم."
  26,169,"زما ربه! ما او كورنۍ مې له هغه څه وژغورې چې هغوى يې كوي."
  26,170,"نو هغه او د هغه كورنۍ مو ټول وژغورل."
  26,171,"پرته له يوې بوډى، چې پاتېدونكو كې وه."
  26,172,"بيا مو هغه نور تباه كړل."
  26,173,"او يو باران مو پرې واورولو، نو د هغو وېرول شويو ډېر ناكاره باران وو."
  26,174,"په دې كې خو په رېښتيا (لويه) نښانه ده، خو ډېری يې منونكي نه دي."
  26,175,"او بې شكه همغه ستا رب ښه مهربان برلاسى دى."
  26,176,"د ګڼ ځنګل څښتنانو رسولان درواغجن وګڼل."
  26,177,"كله يې چې ورور شعيب (علیه السلام) ورته وويل: آيا نه ډارېږئ؟"
  26,178,"زه ستاسي لپاره يو امانتګر پيغمبر يم."
  26,179,"نو تاسو له الله نه ووېرېږئ او زما اطاعت وكړئ."
  26,180,"او په دې له تاسو څه بدله هم نه غواړم زما بدله يوازې د مخلوقاتو پر پالونکي ده."
  26,181,"پيمانه پوره وركوئ او له كموونكو مه كېږئ."
  26,182,"او په سمه تله تول كوئ."
  26,183,"او خلكو ته د هغوی شيان كم مه وركوئ، په ځمكه كې فساد مه خپروئ."
  26,184,"او له هغه ذات نه وويريږئ چې تاسي او پخواني نسلونه یې پيداكړي دي."
  26,185,"هغوى ويل: خبره دا ده چې ته يو كوډو وهلى (جادو کړی شوی) انسان يې."
  26,186,"او زموږ په شان يو انسان پرته بل څه نه يې او بې شكه موږ په تا ګومان كوو چې له درواغجنو يې."
  26,187,"نو كه ته رښتينى يې له اسمانه يوه ټوټه پر موږ راوغورځوه."
  26,188,"شعيب وويل: زما رب په هغو كارو ډېر ښه پوه دى چې تاسو يې كوئ."
  26,189,"خو بيا يې دى هم درواغجن وبللو نو د چترۍ (وریځې) والا ورځې عذاب راونيول، بې شكه هغه د يوې لويې ورځې عذاب و."
  26,190,"په دې كې خو په رېښتيا (لويه) نښانه ده، خو ډېری يې منونكي نه دي."
  26,191,"او بې شكه همغه ستا رب ښه مهربان برلاسى دى."
  26,192,"او هغه خامخا د رب العالمين لخوا نازل کړل شوی دی."
  26,193,"چه امانتداره روح (جبريل) ورسره نازل شوى دى."
  26,194,"ستا پر زړه (نازل شو)، د دې لپاره چې ته له وېروونكو واوسې."
  26,195,"په څرګنده عربى ژبه دی."
  26,196,"او بې شکه د پخوانيو خلكو په كتابو كې هم شته."
  26,197,"آيا د هغوى (مكې والو) لپاره دا يوه نښانه نه ده چې د بني اسرائيلو عالمان هم ورباندې پوهيږي."
  26,198,"او كه دا مو په چا عجميانو نازل كړى واى."
  26,199,"هغه پر دوى لوستى واى، بيا به يې هم نه واى منلى."
  26,200,"همدغه شان مو دا (انكار) د مجرمانو په زړونو كې ورننه اېستلى دى."
  26,201,"نو تر هغو يې نه مني ترڅو دردناك عذاب ونه ويني."
  26,202,"بيا كله چې يو ناڅاپه ورته راشي او هغوى خبر هم نه وي."
  26,203,"نو وايي به آيا موږ ته به مهلت راكول كيږي؟"
  26,204,"نو آیا هغوى زموږ د عذاب لپاره بيړه كوي."
  26,205,"آيا نو ته وينې چې كه تر كلونو هغوى ته د ژوند د مزو مهلت وركړو."
  26,206,"بيا هغه (عذاب) ورته راشي چې ژمنه يې ورسره كېدله."
  26,207,"نو بيا به هم د دوی هغه د ګټې توکي له هغوى څه ايسار نه كړي."
  26,208,"او موږ هېڅ كلى هسې نه دى تباه كړى چې هغوى ته وېروونكي نه وي."
  26,209,"د نصيحت كولو لپاره او موږ خو څه ظالمان نه يو."
  26,210,"او دا (قرآن) خو شيطانانو نه دى راوړى."
  26,211,"او نه له هغوى سره وړ دى او نه كولاى شي."
  26,212,"هغوى خو په رېښتيا له دې اورېدلو هم ګوښه كړى شوي دي."
  26,213,"نو الله سره بل معبود مه رابوله كنه بيا به ته هم له عذاب ورکړل شويو څخه شې."
  26,214,"او خپل نږدې خپلوان دې ووېروه."
  26,215,"او هغوى مومنانو ته چې ستا متابعت يې كړى، خپل وزر ښكته كړه."
  26,216,"نو كه له تا يې سرغړونه وكړه، ورته وايه چې زه له هغو كارو بېزار يم چې تاسو يې كوئ."
  26,217,"او پر ډېر مهربان برلاسي (الله) بروسه وكړه."
  26,218,"هغه ذات چې تا وينې كله چې پاڅېږې."
  26,219,"او په سجده كوونكو كې ستا پرېوتل پاڅېدل (ويني)."
  26,220,"بېشكه همغه ښه پوه اورېدونكى دى."
  26,221,"آيا خبر مو كړم چې شيطانان پر چا نازليږي؟"
  26,222,"هغوى په هر درواغ جوړوونكي ګناهګار نازليږي."
  26,223,"اورېدل شوې خبرې (د ځينو) په غوږو كې ور اچوې او زياتره يې درواغجن دي."
  26,224,"او په شاعرانو پسې خو (يوازې) بې لارې خلك ځي."
  26,225,"آيا ته وينې چې دوى په هر ناو كې لالهانده وي."
  26,226,"او هغه څه وايي چې نه يې كوي."
  26,227,"له هغو كسانو پرته چې ايمان يې راوړى، سم كارونه يې كړي، الله يې ډېر ياد كړى او (يوازې) له هغه وروسته يې غچ اخيستى چې ظلم پرې شوى، او چا چې ظلمونه كړي زر به وپوهېږي چې كوم ځاى ته بېرته ورګرځي."
