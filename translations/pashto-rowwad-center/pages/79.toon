quran[46]{c,v,t}:
  79,1,"پر سختۍ (سا) اېستونكو (پرېښتو) قسم."
  79,2,"او پر هغه پرښتو قسم چې وباسي روح د مؤمنانو په آسانه ایستلو سره."
  79,3,"او پر ګړنديو لامبو وهونكو قسم."
  79,4,"بيا پر منډه منډه وړاندې كېدونكو قسم."
  79,5,"بيا د چارو پر سمبالوونكو قسم."
  79,6,"هغه ورځ چې لړزېدونكې ولړزېږي."
  79,7,"چې ورپسې بل وروسته راتلونكى (ټكان) راځي."
  79,8,"ځينې زړونه به هغه ورځ رپېدونکي وي."
  79,9,"سترګې به يې ښكته وي."
  79,10,"هغوى به وايي آيا موږ بېرته مخکېني حالت ته ورګرځيدونكي نه يو؟"
  79,11,"آيا كله چې موږ وراسته هډوكي يو؟"
  79,12,"وېلې دا خو به ډېر تاواني ستنېدل وي."
  79,13,"نو یقینا دا خو یوه چغه ده."
  79,14,"چې بيا به هغوى(ټول) په دې ميدان (ولاړ) وي."
  79,15,"په رښتیا سره راغلی دی تا ته خبر د موسی (علیه السلام)"
  79,16,"کله يې چې پالونکي د طوى په سپېڅلي ناو كې اواز ورته وكړ؟"
  79,17,"چې: فرعون ته ورشه هغه سركښي كړې ده."
  79,18,"بيا ورته ووايه چې آيا ته چمتو يې چې پاك شې."
  79,19,"او چې د خپل پالونکي په خوا لارښوونه درته وكړم چې ته ووېرېږې؟"
  79,20,"نو بيا موسى (علیه السلام) هغه ته ستره نښانه وښوده."
  79,21,"خو درواغجن يې وګڼلو او د هغه خبره يې ونه منله."
  79,22,"بيا يې شا كړه، منډه يې كوله."
  79,23,"نو خلك يې راټول كړل او غږ يې وكړ."
  79,24,"وېلې: همدا زه مو ترټولو اوچت رب يم!"
  79,25,"نو ونیوه ده لره الله تعالی په سزا د آخرت او د دنیا سره."
  79,26,"بېشكه په دې كې هغه چاته هرومرو يو درس دى چې وېريږي."
  79,27,"آيا ستاسې پيدا كول سخت دي، كه د آسمان؟ چې هغه يې جوړ كړى دی."
  79,28,"د هغه چت يې هسك او بيا يې سم برابر كړى."
  79,29,"او تیاره کړې یې ده شپه د هغه او ښکاره کړی یې دی د څاښت وخت."
  79,30,"او له هغه وروسته يې ځمكه وغوړوله."
  79,31,"د هغې اوبه او شينکي يې ترې را واېستل."
  79,32,"او غرونه يې پكې ښخ ودرول."
  79,33,"ستاسو او ستاسو د څارويو د ګټې اخيستنې لپاره."
  79,34,"نو كله چې هغه لوى افت راشي."
  79,35,"هغه ورځ چې انسان ته خپل كړي عملونه ورياد شي."
  79,36,"او دوزخ به هر هغه چا ته څرګند كړى شى چې ويني يې."
  79,37,"بيا نو چا چې سركښي كړې وي."
  79,38,"او دنيوي ژوند يې غوره ګڼلى وي."
  79,39,"په رېښتيا همدا دوزخ به يې استوګنځى وي."
  79,40,"او څوك چې د خپل پالونکي په مخكې له درېدو ډار شوى او ځان يې له هوسونو ساتلى وي."
  79,41,"نو بېشكه جنت يې استوګنځى دى."
  79,42,"هغوى د قيامت په هكله تا پوښتي چې كله به رامنځته كيږي؟"
  79,43,"په څه کې یې ته د یاداښت د هغې نه."
  79,44,"د هغه وروستۍ (پوهه) ستا د رب لوري ته ده."
  79,45,"ته خو يوازې د هغه چا خبروونكى يې چې ترې ډاريږي."
  79,46,"كله چې هغوى يې وويني نو له يو ماښام يا يو سهار پرته چې نه وي ځنډېدلي."
