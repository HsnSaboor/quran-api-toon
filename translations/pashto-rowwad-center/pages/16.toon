quran[128]{c,v,t}:
  16,1,"د الله فيصله راغله، اوس یې تلوار مه كوئ، هغه پاک دى او له هغه شرك نه پورته او لوړ دى چې دوی يې كوي."
  16,2,"له خپلو بندګانو چاته چې وغواړي، روح د ملايک په واسطه په خپل حكم پرې نازلوي چې (خلک) وپوهوئ، چې له ما پرته بل معبود نشته نو (يوازې) له ما ووېرېږئ."
  16,3,"هغه اسمانونه او ځمكه په حقه پيدا كړيدي، له هغه شرک څخه ډېر پورته او لوړ دى چې دوى يې كوي."
  16,4,"انسان یې له نطفې پېدا كړ، نو ترې یو څرګند جګړه مار جوړ شو."
  16,5,"څاروي یې (هم) پېدا كړيدي، چې په هغو كې تاسي لپاره ګرم پوښاك او نورې ګټې هم شته، او له هغو څخه خوراک هم كوئ."
  16,6,"په هغو كې تاسي لپاره ښكلا ده چې سهار يې د څرولو لپاره لېږئ او ماښام يې بېرته راولئ."
  16,7,"او ستاسو درانه پيټي تر هغې سيمې وړي چې تاسو يې له ډېر كړاو ګاللو پرته نه شئ رسولى، رښتيا چې ستاسو رب خامخا ډېر مهربان خواخوږى دى."
  16,8,"آسونه، كچر او خره يې دې لپاره پيدا كړل چې هم پرې سپاره شئ او هم ښكلا وي، او نور داسې شيان هم پيدا كوي چې تاسو ورباندې نه پوهېږئ."
  16,9,"او پر هماغه الله د سمې لارې ښودل دي، او (سره له دې چې) څه لارې كږې هم دي او كه هغه غوښتي وى نو تاسو ټولو ته به يې هدايت كړى و."
  16,10,"هماغه ذات دى چې له اسمانه یې اوبه ورولي چې هم ستاسو څښاك دى او هم ونې بوټي چې خپل څاروي پكې څروئ."
  16,11,"رازرغونوي (الله تعالی) تاسي ته په دغو اوبو سره کښت (فصل) او زیتون (خونه) او خرماوې او انګور او له هر قسمه میوو څخه، بې شکه په دې کې خامخا دلیلونه دي د هغه قوم لپاره چې د فکر نه کار اخلي."
  16,12,"او تاسي لپاره یې شپه او ورځ، لمر او سپوږمۍ په كار اچولي دي او ټول ستوري هم د هغه په حكم په كار اچول شويدي، په دې كې د هغو خلكو لپاره ډېرې نښانې دي چې له پوهې څخه كار اخلي."
  16,13,"او دا چې هغه تاسي لپاره په ځمكه كې ډېر رنګارنګ شيان پېدا كړيدى، په دې كې هم د هغو خلكو لپاره ارومرو نښانه ده چې درس اخيستونكي دي."
  16,14,"او هغه ذات دى چې تاسو لپاره يې سمندر په كار اچولى څو تازه غوښه ترې وخورئ، او د ښكلا هغه ګاڼه ترې وباسئ چې اغوندئ يې، او ته وينې چې بېړۍ ګانې پكې څېروونكې روانې دي څو تاسو د هغه (الله) د لورينې لټون وكړئ او شكرونه وباسئ."
  16,15,"او په ځمكه كې يې كلک غرونه واچول چى درباندې ونه خوځيږي، او (پيدا كړې يې دى) ويالې او لارې چې تاسو لار ومومئ."
  16,16,"او (پيدا كړې يې دي) علامې (نښانې) او په ستورو سره (هم) دوى لار مومي."
  16,17,"نو آيا هغه څوک چې پيدا كوي د هغه چا په شان دی چې هېڅ هم نه پيدا كوي؟ آيا تاسي پند نه اخلئ؟"
  16,18,"او كه تاسي د الله د نعمتونو شمېرل وغواړئ نه يې شئ شمېرلى، بې شکه هغه ډېر بخښونكى او مهربان دى."
  16,19,"او الله تعالی پوه دی په هغه څه چې تاسو یې پټوئ او په هغه څه چې ښکاره کوئ یې."
  16,20,"او هغوى چې له الله پرته نور څه رابلي، هغه هېڅ نه پيدا كوي بلكې خپله مخلوق دي."
  16,21,"مړه دي، نه ژوندي، او نه پوهيږي چې بيا به كله راپاڅول شي."
  16,22,"په حقه سره ستاسو معبود هماغه يو معبود دى، نو هغوى چې آخرت نه مني، زړونه يې منكر او دوى په لويي كې تللي دي."
  16,23,"شک نشته چې الله ښه پوهيږي په هغه څه چې دوى يې پټوي او په هغه څه چې څرګندوي يې، بې شکه هغه لویي کوونکي نه خوښوي."
  16,24,"او چې ورته وويل شي رب مو څه نازل كړي؟ وايي: د ړومبنيو څه نكلونه (کیسې)."
  16,25,"تر څو د قيامت په ورځ هم خپل پيټي پوره په شا كړي او هم د هغو له پېټو چې په ناپوهي كې دوى بې لارې كړي دي، ګورئ څومره بد پيټي دي چې دوى يې وړي."
  16,26,"له دوى مخكې خلكو هم (دغسې) چلونه جوړ كړي وو خو الله يې د چلونو كلا له بېخه ونړوله، چت يې له پاسه پرې وغورځېد او له يو داسې لوري آفت ورباندې راغى چې دوى نه پوهېدل."
  16,27,"بيا به يې د قيامت په ورځ (نور هم) سپكوي، ورته وايي به چې زما هغه شريكان چېرې دي چې تاسو يې په هكله (مسلمانانو سره) جګړې كولې؟ چاته چې علم وركړى شوى هغوى به وايي: بې شكه چې رسوايي او بدي نن ورځ په همدغو كافرانو ده."
  16,28,"هغوى چې پر خپلو ځانو ظالمان وو نو كله چې یې ملايكې سا اخلي، دوى به سمدلاسه روغه جوړه وړانداې كړي، چې موږ خو هېڅ بد نه كول، ولې نه! يقيناً الله په هغه څه ښه خبر دى چې تاسو به كول."
  16,29,"نو (اوس) د جهنم په دروازو ورننوځئ تلپاتې په هغه كې، د كبرجنو استوګنځى نو خامخا ډېر ناكاره دى."
  16,30,"او (بل لور ته) چا چې نيكي وكړه، هغوى لپاره په دې دنيا هم ښېګڼه ده او د آخرت كور خو حتماً لا غوره دى، او ډېر ښه كور د ځان ساتونكو (له ګناه) دى."
  16,31,"د تل اوسېدو باغونه چې دوى به ورننوځي، ترې لاندې به ويالې بهيږي هلته به دوى لره هر هغه څه وي چې غواړي يې، الله متقيانو ته همدغه شان بدله وركوي."
  16,32,"هغوى چې پاک دي، كله چې ملايكې يې سا اخلي ورته وايي: پر تاسو دې سلام وي، (ځئ) جنت ته ننوځئ، د هغو عملونو په بدل كې چې تاسو به كول."
  16,33,"آيا (اوس) دوى له دې پرته د بل څه انتظار كوي چې يا ملايكې ورته راشي او يا ستا د رب پرېکړه ورته راشي؟ له دوى ړومبنيو خلكو هم دغه شان كړي دي، او الله پر هغوى ظلم نه و كړى، ظلم خو دوى خپله پر ځانو كولو."
  16,34,"نو بيا دوى ته هم د خپلو کړنو شر ورسېد، او هغه څه ترى چاپېر شول چې (پخوا) به يې ملنډې پرې كولې."
  16,35,"او چا چې شرک كړى وايي چې كه الله نه واى غوښتي نه به موږ له هغه پرته څه شى لمانځلی و، نه زموږ پلرونو او نه به مو د هغه له حكمه پرته كوم شى حرام كړى و، له دوى مخكنيو هم دغه شان كول، نو آيا په رسولانو باندې پرته له ښكاره تبليغه نور څه شته؟"
  16,36,"او موږ هر ولس ته يو رسول ولېږه چې الله ولمانځئ او له باطلو معبودانو ځان وساتئ، نو بيا له هغو نه چاته الله سمه لار وښوده، او ځينى يې هغه و چې بې لاريتوب پرې مسلط شو، نو وګرځئ په ځمكه كې او وګورئ چې د دروغ ګڼونكو انجام څنګه شو؟"
  16,37,"كه ته د هغوى لار موندنې ته (هر څومره) حرص هم كوې خو الله هغه چاته هدايت نه كوي چې بې لارې كوي يې، او هغوى لره به څوک مرستندوى نه وي."
  16,38,"او دوى په الله كلک كلک قسمونه وكړل چې بيا به الله هغه يو هم راژوندى نه كړي چې مړ كيږي، ولې نه، دا خو يوه ژمنه ده چې هغه پر ځان منلې، خو زياتره خلک نه پوهيږي."
  16,39,"دې لپاره چې الله هغه څه ورته څرګند كړي چې دوى پكې اختلاف كوي، او كافرانو ته معلومه شي چې بې شكه دوى دروغجن وو."
  16,40,"زموږ وينا خو چې كله د يو شي اراده وكړو، بس چې ورته وايو: شه نو هغه كيږي."
  16,41,"او هغوى چې د الله په لار كې هجرت كړى وروسته له هغه چې ظلم ورباندې شوى، نو خامخا به دنيا كې هم ښه ځاى وركړو او د آخرت بدله خو ډېره لويه ده، كه چېري دوى پوهېدلاى."
  16,42,"هغوى چې صبر يې كړى او په خپل رب بروسه كوي."
  16,43,"او نه دي لیږلي موږ ستا نه مخکې مګر سړي (پېغمبران) چې وحي مو ورته کوله، نو پوښتنه وکړئ د علم والاو نه که چیرته تاسي نه پوهیږئ."
  16,44,"هغوى مو هم له ښكاره نښانو او كتابونو سره لېږلي وو، او تاته مو دغه ذكر (قرآن) درنازل كړ چې هغه څه ورته بيان كړې چې دوى لپاره نازل شوي او تر څو دوى خپله هم څه فكر وكړي."
  16,45,"آيا هغه خلک چې ناوړه چلونه جوړوي، له دې بې غمه دي چې الله به يې په ځمكه ښخ كړي؟ يا به له كوم داسې لوري عذاب پرې راشي چې دوى پوه هم نه شي."
  16,46,"يا به يې هسې ګرځېدو راګرځېدو كې ګير كړي، بيا به دوى عاجزونكي نه وي."
  16,47,"يا به يې په وېره كې ونيسي، په يقين سره ستا رب ډېر مهربان لوروونکی دى."
  16,48,"اّيا دوى د الله كوم پيدا كړى شى هم نه ويني چې څنګه يې سيورى له ښۍ او كيڼې خوا الله ته په سجده كولو پرېوځي؟ حال دا چې (ټول) عاجزي كوونكي دي."
  16,49,"او هماغه الله ته سجدې كوي څه چې په آسمانونو او ځمكه كې دي له خوځېدونكو حيواناتو او ملايكو پورې په داسې حال كې چې دوى (هېڅ) لويي نه كوي."
  16,50,"دپاسه يې خپل رب نه وېريږي او څه چې ورته امر كيږي ترسره كوي يې."
  16,51,"او الله وايي چې دوه معبودان مه نيسئ، بې شكه چې هماغه يو معبود دى، نو يوازې مانه ووېرېږئ."
  16,52,"او هماغه لره دي څه چې په آسمانوو كې دي او څه چې په ځمكه كې دي، او دين (تسليمي) سوچه هماغه لره ده، نو آيا پرته له الله بل چانه وېره كوئ؟"
  16,53,"او په تاسي چې كومه لورينه (نعمت) ده هم د الله له لوري ده او بيا چې څه كړاو درته رسي هم هغه ته زارۍ كوئ."
  16,54,"خو بيا چې هغه كړاو درنه لرې كړي، يو دم ستاسو څه خلک خپل رب سره شريكان نيسي."
  16,55,"څو چې د هغو نعمتونو ناشكري وكړي، چې موږ وركړي نو مزې وكړئ، زر به وپوهېږئ."
  16,56,"او موږ چې څه ور روزي كړي له هغو نه، هغه څه ته برخه ټاكي چې (كوم دليل يې) ورته معلوم نه دى، نو په الله قسم چې وبه پوښتل شئ له هغو دروغو نه چې تاسو به تړل."
  16,57,"اودوى الله لپاره لوڼي ټاكي، پاکي ده هغه (الله) لره! او دوى لپاره هغه څه دي چې غواړي يې."
  16,58,"او كله چې كوم يو ته يې د لور زېرى وشي، مخ يې تک تور واوړي او له غوسې ډک وي."
  16,59,"له خلكو نه پټ ګرځي له هغه ناكاره خبر له امله چې ده اورېدلى، آيا (لور يې) له شرم سره سره وساتي او كه په خاوره كې يې ومنډي؟ ګورئ! څومره ناوړه حكم دى چې دوى يې (د الله په هكله) كوي."
  16,60,"هغوى لره چې په آخرت باور نه لري ناكاره صفتونه دي، او الله لره خو تر ټولو غوره صفتونه دي، او هماغه حكمت والا برلاسى دى."
  16,61,"او كه چېرى الله تعالی خلک د هغوى په ظلم سره سمدلاسه رانيولاى نو د ځمكې پر مخ به هېڅ ساكښ نه و پاتې، خو هغه يې تر يوه ټاكلي وخته ځنډوي بيا چې كله يې همغه نېټه راشي نو يو ساعت هم نه وروسته كيږي او نه ړومبى كيږي."
  16,62,"او دوى هغه څه الله ته ټاكي چې خپله يې بد ګڼي، او ژبې يې دا دروغ بيانوي چې دوى لپاره ښېګڼه ده، په حقيقت كې دوى لپاره یوازې اور دى، او دوى تر ټولو مخكې ورغورځېدونكى دي."
  16,63,"په الله قسم له تا مخكې مو هم ډېرو قومونو ته رسولان لېږلي دي، بيا يې شيطان بد عملونه ورته ښايسته كړل، نو نن ورځ يې هم هماغه دوست دی، او دوى لپاره دردناک عذاب دى."
  16,64,"او موږ له دې پرته بل څه لپاره دا كتاب نه دى نازل كړى چې ته هغه څه ورته روښانه كړې چې دوى پكې اختلاف كوي، او (بل دا چې) مومنانو لپاره به لارښوونه او رحمت وي."
  16,65,"او الله له اسمانه اوبه را واورولې او دا مړه ځمكه يې پرې ژوندۍ كړه، په دې كې خو يقيناً هغو خلكو ته (لويه) نښه ده چې (خبره) اوري."
  16,66,"او په دې څارويو كې هم تاسو لپاره خامخا يو درس شته، د هغو په ګېډو كې له څه شيانو د خوشيو او وينې له منځه تاسو ته سوچه پۍ درڅښو چې د څښونكو لپاره آسانه په خوند تېرېدونكې دي."
  16,67,"او (همداسې) د كجورو او انګورو له مېوو چې تاسو هم نېشه يي مواد او هم ښه روزي ترې لاس ته كوئ، يقيناً په دې كې هغو خلكو ته (لويه) نښه ده چې عقل كاروي."
  16,68,"او ستا رب د شاتو مچۍ ته په زړه كې ورواچوله چې په غرونو، ونو او هغو څپرو كې چې خلک يې لوړې جوړوي، كورونه جوړ كړه."
  16,69,"بيا د هر ډول مېوو نه خوراک كوه او د خپل رب په هوارو كړيو لارو روانه اوسه، د دوى له ګېدو د بېلا بېلو رنګونو يو څښاک راوځي چې په هغه كې خلكو لپاره شفا ده، يقيناً په دې كې هغو خلكو ته (لويه) نښه ده چې فكر كوي."
  16,70,"او الله تاسو پيدا كړئ بيا مو پوره اخلي (مړه کوي مو) او له تاسو نه څوک بد (د ذلت) عمر ته پريږدي، چې له پوهېدو وروسته بيا په هېڅ ونه پوهيږي، بې شكه الله ډېر پوه ځواکمن دى."
  16,71,"او الله له تاسو نه ځينو ته پر ځينو باندې په روزي كې زيات والى وركړى دى، نو چاته چې زيات والى وركړ شوى هغوى د خپلو مريانو لور ته د دې روزۍ ورګرځونكي نه دي په داسې شان چې هغوى ټول پكې يو برابر شي، نو آيا د الله له (دغې) پېرزوينې منكريږي؟"
  16,72,"او الله تاسو ته له خپله جنسه مېرمنې پيدا كړې او له مېرمنو يې زامن او لمسي دركړي او له ښو پاكيزه شيانو يې روزي دركړې ده، نو آيا دوى باطل مني او د الله له پېرزوينې انكار كوي."
  16,73,"او له الله پرته د هغه شي بندګي كوي چې د هغه په لاس كې نه له اسمان نه دوى ته څه روزي وركول شته، نه له ځمكې نه او نه دا كار د هغوى له وسې پوره دى."
  16,74,"نو الله لپاره مثالونه مه جوړوئ، بې شکه الله پوهيږي، او تاسو نه پوهيږئ."
  16,75,"الله يو مثال راوړي: لكه د چا په ملكيت كې يو مريى دى چې خپله څه واک نه لري او بل څوک داسې چې هغه ته مو له خپله لوري غوره روزي وركړې او دى په پټه او ښكاره لګښت ترې كوي، آيا دوى سره برابر دي؟ الله لره ستاينه ده، بلكې زياتره يې نه پوهيږي."
  16,76,"او الله يو (بل) مثال راوړي: لكه دوه كسان دي چې يو يې ګونګ دى، هېڅ نه شي كولاى او په خپل څښتن باندې هسې پېټى دى، هرې خوا ته يې چې استوي څه خير نه راوړي، آيا دى او هغه كس چې په عدالت حكم كوي او په سمه سيده لار برابر دى، سره يو شان كېداى شي؟"
  16,77,"او د اسمانو او ځمكې غيب الله لره دي، او د قيامت معامله لكه د سترګو رپ لا څه چې ډېره نږدې ده، بې شكه الله په هر څه قادر دى."
  16,78,"او الله تاسو د خپلو ميندو له ګېډو په داسې حال كې راووېستئ چې په هېڅ هم نه پوهېدئ او هغه تاسو ته غوږونه، سترګې او زړونه دركړل چې شكر وباسئ."
  16,79,"آيا دوى الوتونكو ته نه دي كتلي چې څنګه د اسمان په هوا كې مسخر شوي دي؟ الله نه پرته يې بل هېڅوک نه ساتي، يقيناً په دې كې ايمان راوړونكو ته ډېرې نښې دي."
  16,80,"او الله مو كورونه آرام ځايونه درته وګرځول او د څارويو له پوستكو يې داسې كورونه درته پيدا كړل چې د كوچېدو او دېره كېدو په ورځ يې سپک مومئ او د هغو له وړيو، اون او وژغنو يې ستاسي د ګټې وړ سامان پيدا كړ تر يوې ټاكلې نېټى پورې."
  16,81,"او له هغو شيانو چې ده پيدا كړي ستاسي لپاره يې سيوري برابر كړل، په غرونو كې يې پناه ځايونه درته جوړ كړل او داسې كميسونه چې له ګرمۍ مو ساتي او هغه كميسونه چې (په جنګ كې) ستاسي ساتنه كوي، په دې ډول خپل نعمتونه درباندې تماموي ښايي چې تاسو غاړه كيږدئ."
  16,82,"نو كه دوى مخ اړوي نو پر تا هم له څرګند تبليغه پرته بل څه نشته."
  16,83,"دوى د الله نعمت (ښه) پېژني خو بيا ترې منكريږي او زياتره يې كافران دي."
  16,84,"او هغه ورځ چې له هر امت نه يو شاهد راپاڅوو نو بيا به كافرانو ته نه (د څه ويلو) اجازه وي او نه به د توبې غوښتنه ترې وكړى شي."
  16,85,"او كله چې ظالمان هغه عذاب وګوري نو بيا به نه ورباندې سپک كړى شي او نه به مهلت وركړى شي."
  16,86,"او كله چې مشركان خپل (باطل) شريكان وويني وايي به: اى زموږ ربه! همدا زموږ هغه (انګېرلي) شريكان وو چې له تا پرته مو رابلل، نو هغوى به دا خبره ور وړاندې كړي چې يقيناً تاسي (خپله) دروغجن ياست."
  16,87,"او په هغه ورځ به الله ته سوله وړاندې كړي او هغه ټول دروغ به يې له منځه ولاړ شي چې دوى به (دنيا كې) جوړول."
  16,88,"څوک چې خپله هم كافر شوي او (نور يې هم) د الله له لارې اړولي هغو ته به د عذاب له پاسه عذاب ورزياتوو، په دې چې دوى به فساد كولو."
  16,89,"او هغه ورځ چې موږ به هر امت كې خپله له هغوى نه يو شاهد ورباندې راپاڅوو، او تا به پر همدغو خلكو د شاهد په توګه راولو، او (د همدې لپاره) موږ دا كتاب پر تا نازل كړ چې په ډاګه د هر شي څرګندونكى، لارښوونه، رحمت او زېرى دى مسلمانانو ته."
  16,90,"يقيناً الله د عدل، ښېګڼې او خپلوانو ته د وركړې امر كوي او له بې حيايي، بدۍ او تيري نه منع كوي، هغه تاسو ته نصيحت كوي تر څو درس واخلئ."
  16,91,"د الله ژمنه پوره كوئ، كله چې ژمنه سره كوئ او خپلې لوړې (قسمونه) له ټينګولو وروسته مه ماتوئ، كله چې تاسو الله (هم) درباندې شاهد نيولى وي، بې شكه الله خو په هغه څه پوهيږي چې تاسو يې كوئ."
  16,92,"او د هغې ښځې په شان مه كيږئ چې خپل ورېشلي تارونه به يې له مزي كولو وروسته بېرته سپخول، خپل منځ كې مو قسمونه د ټګۍ وسيله ګرځوئ تر څو يو قوم د بل قوم نه زياته ګټه ترلاسه كړي، (حال دا چې) الله مو په دې سره ازميښت كوي او د قيامت په ورځ به حتماً هغه څه در څرګند كړي چې تاسو پكې اختلاف كولو."
  16,93,"او كه الله غوښتي واى نو تاسو به يې خامخا يو امت ګرځولى وای خو چاته يې چې خوښه شي بې لارې كوي يې، او چاته چې وغواړي سمه لار ورښيي او خامخا به له هغه څه وپوښتل شئ چې تاسو به كول."
  16,94,"او خپل منځ كې مو قسمونه د غولونې وسيله مه ګرځوئ كنه بيا به كوم قدم له ټينګېدو وروسته وښوييږي او په دې به كړاو وڅكئ چې خلک مو د الله له لارې اړولي او ستاسو لپاره به لوى عذاب وي."
  16,95,"او د الله ژمنه په لږه غوندې بيه مه پلورئ، بې شكه څه چې الله سره دي هغه درته غوره دي كه تاسو پوهېږئ."
  16,96,"څه چې تاسو سره دي هغه ختميږي او څه چې الله سره دي، هغه باقي دي، او هغوى چې صبر كړى خامخا به يې د هغو نېكو عملونو په سر بدله وركړو چې هغوى به كول."
  16,97,"چا چې نېک عمل وكړ، كه نارينه وي كه ښځينه خو چې مومن وي نو حتماً به ښه ژوند ورباندې تېر كړو او (آخرت كې به) د هغو نېكو عملونو چې دوى به كول، ښه بدله وركړو."
  16,98,"نو كله چې ته قرأن لولې، له رټل شوي شيطانه په الله پورې پنا وغواړه."
  16,99,"حقيقت كې د ده په هغه چا څه برلاسى نشته چې ايمان يې راوړى او په خپل رب بروسه كوي."
  16,100,"د هغه برلاسى خو پر هغو كسانو دى چې له ده سره ملګرتيا كوي او هغوى چې له (الله) سره شريک جوړونكې دي."
  16,101,"او كله چې د يو آيت پر ځاى بل آيت بدل كړو او الله ښه پوه دى چې څه رانازل كړي نو دوى وايي چې ته دروغ تړونكى يې، بلكى زياتره يې نه پوهيږي."
  16,102,"ورته ووايه دا خو سپېڅلې پرښتې په رښتيني ډول ستا د رب له خوا نازل كړى دى، تر څو مومنان پرې ټينـګ او د امر منونكو لپاره هدايت او زېرى وي."
  16,103,"او موږ پوهېږو چې دوى وايي: كوم انسان ده ته ښوونه كوي! خو حال دا چې كوم كس ته دوى اشاره كوي، د هغه ژبه عجمي، او دا څرګنده عربى ژبه ده."
  16,104,"بې شكه الله هغو كسانو ته هدايت نه كوي چې د الله پر آيتونو باور نه کوي، او دوى لره به دردناک عذاب وي."
  16,105,"په حقيقت كې هغه كسان دروغ جوړوي چې د الله پر آيتونو ايمان نه راوړي او همدوى دروغجنان دي."
  16,106,"څوک چې له ايمانه وروسته يې الله نه منكر شي، پرته له هغه چې مجبور كړى شي او زړه يې پر ايمان ډاډه وي (نو بيا خو خير دى) خو چا چې د زړه په خوښۍ سره كفر ومنلو، نو پر هغوى د الله له لوري غضب دى، او دوى (ټولو) ته ستر عذاب."
  16,107,"دا ځكه چې هغوى د آخرت په مقابل كې د دنيا ژوند غوره وګڼلو او دا چې الله دغسې كافرانو خلكو ته (د ژغورنې) لار نه ښيي."
  16,108,"دا هماغه خلک دي چې الله يې پر زړونو، غوږونو او سترګو مهر وهلى دى او همدوى غافلان دي."
  16,109,"حتمى ده چې همدوى به په آخرت كې تاوانيان وي."
  16,110,"خو بيا (بل لور ته) چا چې هجرت وكړ له هغه وروسته چې وځورېدل، بيا يې جهاد وكړ او صبر يې وكړ نو يقيناً له دې وروسته ستا رب بخښونكى مهربان دى."
  16,111,"هغه ورځ چې هر ساكښ به راځي او د خپل ځان لپاره به جګړه كوي او هر چاته به د خپل عمل پوره بدله وركړل شي او په دوى به (هېڅ) ظلم نه كيږي."
  16,112,"او الله د يو كلي مثال بيانوي چې بې غمه ډاډه پروت و، او له هر لوري پرېمانه روزي ورته راتله خو بيا يې د الله د نعمتونو ناشكري وكړه نو الله د لوږې او ډار خوند وروڅكلو د هغو عملونو په وجه چې دوى به كول."
  16,113,"او دوى ته له خپل قوم څخه يو رسول هم ورغلى و خو دروغجن يې وګڼلو نو عذاب راګير كړل په داسې حال کې چې دوى ظالمان وو."
  16,114,"نو له هغه څه نه چې الله در روزي كړي دي حلال پاک شيان خورئ، كه چېرې تاسو د هغه (رښتینی) عبادت كوئ."
  16,115,"هغه خو پر تاسو یوازې مرداره، وينه، د خنزير غوښه او هغه څه حرام كړي چې د غير الله نوم پرې اخيستل شوى وي. نو كه څوک مجبور شو نو چى سركښي او زياتى كوونكى نه وي نو بيا الله بخښونكى مهربان دى."
  16,116,"او هغه څه ته چې خپله يې ستاسو ژبې په دروغو بيانوي دا حلال او دا حرام مه واياست چې په الله پورې دروغ تړئ، يقيناً هغوى چې الله پورې دروغ تړي (هېڅكله) نه بريالي كيږي."
  16,117,"دا لږه ګټه اخيستنه ده، بيا به د دوى لپاره دردناک عذاب دى."
  16,118,"او (خاص) پر يهودو مو هغه څه حرام كړي چې مخكې مو درته بيان كړي دي، او موږ خو څه ظلم نه دى پرې كړى، خپله دوى پر ځانو ظلم كولو."
  16,119,"بيا هم ستا رب هغو كسانو لپاره چې په ناپوهۍ سره يې ناوړه عمل وكړ، بيا يې له هغه وروسته توبه وكړه او سم كارونه يې وكړل نو يقيناً ستا رب له هغه وروسته خامخا بخښونكى مهربان دى."
  16,120,"بې شكه ابراهيم (په يوازې ځان) يو امت و، الله ته غاړه اېښودونكى حق پلوى (سړى) و، او (هېڅكله) له مشركانو څخه نه و."
  16,121,"د هغه د نعمتونو شكر وېستونكى و، الله هغه غوره او سمې لارې ته وربرابر كړ."
  16,122,"په دنيا كې مو ښيګڼه وركړه او په اخرت كې به يقيناً له صالحانو څخه وي."
  16,123,"بيا مو تاته (هم) دا وحى وكړه چې د ابراهيم د دين تابعداري كوه چې حق پلوى و، او له مشركانو نه و."
  16,124,"خبره دا ده چې د خالي ورځې (درناوى) پر هغو خلكو ټاكل شوى و چې هغوى پكې اختلاف وكړ، او ستا رب به خامخا د قيامت په ورځ د هغوى ترمنځ په هغه څه كې فيصله وكړي چې دوى پكې اختلاف كولو."
  16,125,"بلنه كوه د خپل رب لارې ته په حكمت او غوره نصيحت او (خلكو سره) په ډېره ښه توګه بحث كوه، يقيناً هماغه ستا رب په هغه چا هم ډېر ښه پوه دى چې د ده له لارې اوښتى او همدى په لار موندونكو هم ښه پوه دى."
  16,126,"كه تاسې کسات اخلئ نو هغه شان کسات واخلئ چې څومره پر تاسي تيرى شوى وي؛ خو كه تاسې صبر وكړئ نو په دې كې شک نشته چې دا د صبر كوونكو لپاره ډيره ښه ده."
  16,127,"او صبر كوه او ستا صبر د الله له توفيقه پرته په بل څه نه دى او د دوى په (حال) مه خپه كيږه، او په هغو دسيسو چې دوى يې كوي زړه تنګى كېږه مه."
  16,128,"بې شكه الله هغو كسانو سره (مل) دى چې تقوى كوي او هغوى چې نيک چاري دي."
