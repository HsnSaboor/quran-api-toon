quran[182]{c,v,t}:
  37,1,"قسم دى په هغه پرېښتو چې صفونه جوړوي، صفونه."
  37,2,"بيا په سختۍ سره شړونكو (ملايكو) قسم."
  37,3,"بیا په ذکر (قرآن) لوستونکو (پرېښتو) قسم."
  37,4,"چې بېشكه ستاسو معبود يو دى."
  37,5,"د اسمانو، ځمكې او د هغو تر منځه شيانو رب او د ختيځونو رب."
  37,6,"يقيناً موږ د دنيا اسمان ښكلى كړى د ستورو په ښايست."
  37,7,"او له هر سرکښ شيطانه مو په ساتنه خوندي كړى دى."
  37,8,"پاسني مخلوق ته غوږ نه شي اېښودلاى او له هرې خوا ويشتل كيږي."
  37,9,"رټلی کیدی شي په رټني سره او دوی لره عذاب پيوست کېدونکی دی."
  37,10,"پرته له دې چې كه څوك تښتوونكى كومه خبره وتښتوي نو يوه سوځونكې لمبه ورپسې شي."
  37,11,"نو ويې پوښته چې اّيا د دوى پيدا كېدل به ګران وي كه هغه (نور مخلوق) چې موږ پيدا كړي؟ موږ خو هغوى له سرېښناكې خټې پيدا كړي."
  37,12,"بلكې ته تعجب كوې او دوى ملنډې وهي."
  37,13,"او كله چې نصيحت ورته وشي نه يې مني."
  37,14,"او كله چې كومه نښانه وويني ملنډې وهي."
  37,15,"او دوى وويل: دا خو له ښكاره كوډو پرته بل څه نه دي."
  37,16,"اّيا كله چې موږ ومرو، خاورې او هډوكې شو نو بيا به ژوندي راپاڅول كيږو؟"
  37,17,"او اّيا پلرونه زموږ لومړني؟"
  37,18,"ورته ووايه هو او تاسي به ذلیله هم ياست."
  37,19,"یقینا (قيامت) يوه چيغه [پوکی دی شپیلۍ کې] بيا به دوى ګوري (چې څه ورسره كيږي)."
  37,20,"او وايي به هاى زموږ تباهۍ دا خو د جزا ورځ ده."
  37,21,"(ورته وبه ويل شي) دا هماغه د فيصلې ورځ ده چې تاسي به دروغ ګڼله."
  37,22,"راغونډ كړئ هغه کسان چې ظلم یې كړى او ملګري يې او (ټول) هغه چې دوى به یې عبادت کولو."
  37,23,"له الله نه پرته، بيا يې د جهنم لارې ته ور سم كړئ."
  37,24,"او ويې دروئ، یقینا له دوی پوښتنه کېدونکې ده."
  37,25,"په تاسو څه شوي چې يو بل سره مرسته نه كوئ؟"
  37,26,"بلكې هغوى نن تسليم شوي دى. ."
  37,27,"او هغوى به يو بل ته مخ كړي، پوښتنې به كوي."
  37,28,"وايي به (كشران) همدا تاسو به له ښۍ خوا (د ښېګڼې په نامه) موږ ته راتلئ."
  37,29,"(مشران به) وايي په اصل كې خپله تاسو ايمان راوړونكي نه وئ."
  37,30,"او پر تاسو خو زموږ كوم برلاسى نه و، خو خپله سرکښه خلك وئ."
  37,31,"نو (اوس) پر موږ ټولو زموږ د رب (هغه) خبره ثابته شوه چې موږ به (د عذاب) څكونكي يو."
  37,32,"نو موږ خپله هم بې لارې وو او تاسي مو هم بې لارې كړئ."
  37,33,"نو په هغه ورځ به هغوى (ټول) په عذاب كې سره شريك وي."
  37,34,"موږ په مجرمانو همداسې چارې كوو."
  37,35,"هغوى داسې وو چې كله به ورته وويل شول چې: له الله پرته كوم بل د عبادت لایق نشته، نو لويي به يې كوله."
  37,36,"او دوى به ويل چې اّيا موږ به د يو لېوني شاعر لپاره د خپلو باطلو معبودانو پرېښودونكي يو؟"
  37,37,"بلكې هغه له حق سره راغلى او د ټولو پېغمبرانو تصديق يې كړى."
  37,38,"(او) تاسي به يقيناً د دردناك عذاب څكونكي ياست."
  37,39,"او له هغه پرته چې تاسو به كول، بله بدله نه دركول كيږي."
  37,40,"پرته د الله له سوچه بندګانو."
  37,41,"د هغوى لپاره يوه ټاكل شوې روزي ده."
  37,42,"يعنې مېوې، او هغوى به عزتمن وي."
  37,43,"نعمت والا جنتونو كې."
  37,44,"په تختونو به يو بل ته مخامخ ناست وي."
  37,45,"د روانو شرابو ګيلاسونه به ورباندې ګرځول كيږي."
  37,46,"تك سپين، د څښونكو لپاره خوندور."
  37,47,"نه به وي په هغې کې آفتونه او نه به دوی لره د هغې (شرابو) له امله قی ورځي."
  37,48,"او هغوى سره به ښكته نظر اچونكې غټ سترګې (حورې) وي."
  37,49,"لكه هغوى چې پټې ساتل شوې هګۍ وي."
  37,50,"نو دوى به يو پر بل رامخ كړي تپوسونه به كوي."
  37,51,"په دوى كې به يو ويونكى وايي چې يقيناً زما يو ملګرى ؤ."
  37,52,"هغه به ويل چې اّيا ته (د قيامت) له تصديقونكو څخه يې؟"
  37,53,"اّيا كله چې موږ (ګډ وډ) خاورې او هډوكي شو بيا به موږ جزا موندونكي يو؟"
  37,54,"(بيا به) وايي اّيا تاسو وركتونكي ياست؟"
  37,55,"نو چې ور وګوري هغه به د دوزخ په منځ كې وويني."
  37,56,"وايي به والله تا خو نږدې زه هم تباه كړى وم."
  37,57,"او كه زما د رب لورينه نه واى، خامخا به زه هم په جهنم كې حاضر كړى شوى وم."
  37,58,"(ښه) نو اوس موږ (بل وار) مړه كېدونكي نه يو؟"
  37,59,"پرته زموږ له هماغه لومړي مرګه او موږ عذابېدونكي هم نه يو؟"
  37,60,"(نو چې داسې وي) دا خو يقيناً لوى برى دى."
  37,61,"د دې په شان (نعمتونو) لپاره دې عمل كوونكي عمل وكړي."
  37,62,"اّيا دا غوره دي په مېلمستيا کې که ونه د زقوم؟"
  37,63,"موږ هغه د ظالمانو لپاره يوه فتنه (يا عذاب) ګرځولې ده."
  37,64,"هغه يوه (داسې) ونه ده چې د دوزخ په تل كې راوځي."
  37,65,"د هغې مېوې د شيطانانو (يا مارانو) سرونو غوندې دي."
  37,66,"نو هغوى به يې خوړونكي او هغې نه ګېډه ډكونكي وي."
  37,67,"بيا به دوى لره پر هغه د پاسه خامخا د خوټېدلو اوبو ورګډول وي."
  37,68,"بيا به د دوى ورتګ خامخا د دوزخ په لور وي."
  37,69,"بېشكه هغوى خپل پلرونه بې لارې موندلي وو."
  37,70,"نو د هغو په پلونو به يې منډې وهلې."
  37,71,"او خامخا له دوى مخكې هم زياتره لومړني خلك بې لارې شوي وو."
  37,72,"او په هغوى كې مو هم وېرونكي (پېغمبران) لېږلي وو."
  37,73,"نو ګوره چې د هغو وېرول شوو انجام څنګه شو؟"
  37,74,"مګر بنده ګان د الله تعالی چې بچ ساتلی شوي دي."
  37,75,"او بېشكه موږ ته نوح آواز وكړ نو موږ ښه ځواب وركونكي يو."
  37,76,"او موږ هغه او كورنۍ يې له ستر كړاو څخه وژغورل."
  37,77,"او د ده اولاده مو پاتېدونكې وګرځوله."
  37,78,"او په وروستنو كې مو د هغه ښه نوم پرېښودلو."
  37,79,"په ټولو مخلوقاتو كې دې پر نوح سلام وي."
  37,80,"نېكانو ته موږ همداسې بدله وركوو."
  37,81,"هغه يقيناً زموږ له مومنو بندګانو څخه و."
  37,82,"بيا مو هغه نور غرق كړل."
  37,83,"او بېشكه د هغه له تابعدارانو څخه ابراهيم و."
  37,84,"كله چې خپل رب ته له روغ زړه سره راغى."
  37,85,"كله چې هغه خپل پلار او قوم ته وويل: دا څه دي چې تاسي يې عبادت كوئ؟"
  37,86,"اّيا له الله پرته په دروغو جوړ شوي معبودان غواړئ."
  37,87,"نو څه ګمان دی ستاسو په رب د عالمینو باندې."
  37,88,"بيا يې په ستورو كې يو نظر واچولو."
  37,89,"وېلې: زه خو ناروغ يم."
  37,90,"نو روان شول دوی د هغه نه شا ګرځوونکي."
  37,91,"نو دى پټ پټ د هغوى معبودانو [بوتان] ته ورغلو وېلې: آيا تاسي نه خورئ؟"
  37,92,"څه شوي دي پر تاسي خبرې هم نه كوئ؟"
  37,93,"نو پيل یې وکړ د هغوی په وهلو په ښې لاس سره."
  37,94,"نو هغوى په منډه ورته رامخه كړه."
  37,95,"وېلې اّيا د هغه څه عبادت کوئ چې په خپله يې تراشئ؟"
  37,96,"حال دا چې تاسو هم الله پيدا كړي ياست او څه چې كوئ هغه هم."
  37,97,"هغوى ويل: ده ته يوه ودانۍ جوړه كړئ بيا يې په اور كې واچوئ."
  37,98,"خو چې په ده يې هغه چل كول وغوښتل نو موږ هغوى لاندې كړل."
  37,99,"او ده وويل: زه د خپل رب په لوري تلونكى يم، زر به هغه لار راوښايي."
  37,100,"زما ربه! ما ته صالح اولاد راكړه."
  37,101,"نو موږ د يو زغمونكي هلك زېرى وركړ."
  37,102,"بيا كله چې له ده سره د منډې ترړې توانایي ته ورسېد، وېلې: زما زويه! زه خوب كې وينم چې تا حلالوم! نو ګوره چې ستا څه خيال دى؟ وېلې پلاره څه چې درته امر شوى هماغه وكړه، ان شاء الله ما به له صابرانو ومومې."
  37,103,"نو كله چې دواړو ومنله او په اړخ يې وغورځولو."
  37,104,"نو موږ ورغږ كړ چې ای ابراهيمه!"
  37,105,"دا دى خوب خو دې رښتيا كړ، يقيناً موږ (هم) نيكانو ته دغه شان بدله وركوو."
  37,106,"بېشكه دا يو څرګند ازميښت و."
  37,107,"او موږ د هغه په فديه (قربانۍ) كې ستره حلاله وركړه."
  37,108,"او په وروستنو كې مو د هغه ښه ياد پرېښود."
  37,109,"په ابراهيم دې سلام وي."
  37,110,"نېكانو ته همداسې بدله وركوو."
  37,111,"هغه يقيناً زموږ له مومنو بندګانو څخه و."
  37,112,"او هغه ته مو په اسحاق زېرى وركړ، له صالحانو څخه يو نبي دی."
  37,113,"او موږ په ده او اسحاق بركت اچولى و. او د هغوى دواړو له اولاده ځينې نېك، او څوك د خپل ځان لپاره ښكاره ظالم دي."
  37,114,"او بېشکه موږ پر موسى او هارون احسان كړى و."
  37,115,"هغوى دواړه او قوم يې موږ د لوى غم نه ژغورلي وو."
  37,116,"او مرسته مو د دوی وكړه چې بيا همدوى برلاسي شول."
  37,117,"او هغوى ته مو څرګند كتاب وركړ."
  37,118,"او دواړو ته مو سيده لاره ورښوولې وه."
  37,119,"او پر هغوى مو وروستنو خلكو كې (دا خبره) پرېښوده."
  37,120,"(چې) پر موسى او هارون دې سلام وي."
  37,121,"نېكانو ته موږ همداسې بدله وركوو."
  37,122,"پېشكه هغوى دواړه زموږ له مومنو بندګانو څخه وو."
  37,123,"او بېشكه الياس له استول شوو رسولانو څخه و."
  37,124,"كله چې يې خپل قوم ته وويل اّيا نه وېرېږئ؟"
  37,125,"اّيا تاسو بعل (نومى بت) رابلئ او تر ټولو غوره خالق پرېږدئ؟"
  37,126,"يعنى الله چې ستاسو او ستاسو د ړومبنيو پلرونو رب دى."
  37,127,"خو هغه يې دروغجن وګڼلو نو دوى به خامخا (په عذاب كې) د حاضر کړای شوو څخه وي. ."
  37,128,"پرته د الله له سوچه بندګانو."
  37,129,"او په وروستنو كې مو د هغه (ښه نوم) پرېښودلو."
  37,130,"په الياسين دې سلام وي."
  37,131,"نېكانو ته موږ همداسې بدله وركوو."
  37,132,"هغه يقيناً زموږ له مومنو بندګانو څخه و."
  37,133,"او بېشكه لوط له استول شوو رسولانو څخه و."
  37,134,"كله چې هغه او د هغه ټوله كورنۍ مو وژغورله."
  37,135,"پرته له يوې بوډۍ چې پاتېدونكو كې وه."
  37,136,"بيا مو نور تباه كړل."
  37,137,"او يقيناً تاسو ورتېریږئ په دوی باندې د سبا په وخت کې."
  37,138,"او د شپې هم، نو اّيا عقل نه چلوئ؟"
  37,139,"او بېشكه يونس له رسولانو څخه و."
  37,140,"كله چې هغې ډكې بېړۍ ته وروتښتېد."
  37,141,"بيا يې چې پچه واچوله نو له بايلونكو څخه شو."
  37,142,"بيا ماهي (کب) ده لره روغ تېر کړ په داسې حال کې چې دی ملامتونكى و."
  37,143,"نو كه چېرې هغه له تسبيح ويونكو څخه نه وى."
  37,144,"خامخا به د هغه ګېډه كې د بيا راپاڅېدو تر ورځې ځنډېدلى و."
  37,145,"بيا موږ په ناروغه حالت ډاګ ميدان كې وغورځولو."
  37,146,"او د كدو يو بوټى مو ورباندې را زرغون كړ."
  37,147,"هغه موږ سل زره يا څه زياتو (خلكو) ته ور استولى و."
  37,148,"نو هغوى ايمان راوړ، بيا مو تر څه وخته مهلت او سوكالي وركړه."
  37,149,"نو ته يې وپوښته، اّيا ستا رب لره به لورګانې وي او دوى لره زامن؟"
  37,150,"(او) كه نه، دوى حاضر وو چې موږ ملايكې ښځينه پيدا كړل."
  37,151,"خبر اوسه یقینا دوى له خپلو ځینو درواغو داسې وايي."
  37,152,"چې الله بچى راوړى حال دا چې دوى حتماً دروغجن دي."
  37,153,"اّيا لورګانې يې پر زامنو غوره وګڼلې."
  37,154,"په تاسو څه شوي؟ څنګه فيصله كوئ؟"
  37,155,"اّيا نو پند نه اخلئ؟"
  37,156,"ايا تاسو سره كوم ښكاره دليل دی؟"
  37,157,"كه رښتيني ياست نو خپل كتاب مو راوړئ!"
  37,158,"او دوى د الله او پيريانو ترمنځ نسب (خپلوي) جوړ كړی، پداسې حال كې چې پيريان ښه پوهېږي چې دوی به خامخا حاضر کړی شي په عذاب کې."
  37,159,"الله لره پاكي ده له هغه څه چې دوى يې بيانوي."
  37,160,"پرته د الله له سوچه بندګانو."
  37,161,"نو بېشكه تاسو او هغه چې عبادت يې کوئ."
  37,162,"په دې (شرك) سره (د هيچا) بې لارې كوونكي نه ياست."
  37,163,"پرته له هغه چې (خپله) دوزخ ته ننوتونكى دى."
  37,164,"او (ملايکې وايي) له موږ نه هيڅوك داسې نشته چې ټاكلى ځاى يې نه وي."
  37,165,"او بېشكه موږ (په عبادت كې) كتار جوړوونكي يو."
  37,166,"او بېشکه موږ تسبيح ويونكي يو."
  37,167,"او بېشكه دوى (كافرانو) به ويل."
  37,168,"چې كه موږ سره له پخوانيو نه كوم ذكر وى."
  37,169,"نو (اوس به) موږ خامخا د الله سوچه بندګان وو."
  37,170,"خو بيا په هغه (قراّن) كافر شول نو زر به پوه شي."
  37,171,"او بېشكه زموږ خبره د خپلو استول شوو بندګانو په هكله لا پخوا شوې وه."
  37,172,"چې يقيناً هغوى سره به خامخا مرسته كيږي."
  37,173,"او یقینا همدا زموږ لښکر به برلاسى شي."
  37,174,"نو تر څه وخته له هغوى نه مخ وګرځوه."
  37,175,"او هغوى ته ګوره زر به دوى هم (خپل انجام) وګوري."
  37,176,"نو آيا دوى زموږ د عذاب لپاره بيړه كوي؟"
  37,177,"خو هغه وخت چې د دوى پر ميدان (عذاب) راپرېوځي نو بيا به د وېرول شوو ډېر بد سبا وي."
  37,178,"او تر څه وخته له دوى څخه مخ وګرځوه."
  37,179,"او ليدونكى اوسه، ډېر زربه دوى پخپله وويني."
  37,180,"ستا رب لره پاكي ده چې د (ډېر) عزت والا رب دى، له هغو خبرو نه چې دوى يې بيانوي."
  37,181,"او سلام دى پراستول شوو (رسولانو)."
  37,182,"او د ټولو مخلوقاتو رب، الله لره ستاينه ده."
