quran[44]{c,v,t}:
  70,1,"يو غوښتونكي د (هرومرو) پېښېدونكي عذاب غوښتنه وكړه."
  70,2,"چې هغه د كافرانو لپاره دى (او) هيڅوك يې ايساروونکی نشته."
  70,3,"د مرتبو څښتن الله له لوري."
  70,4,"هغه ته پرېښتې او روح ورخېژي په هغه ورځ چې اندازه يې پنځوس زره كاله ده."
  70,5,"نو ته صبر كوه، ښه صبر."
  70,6,"هغوى خو يې لېرې انګېري."
  70,7,"خو موږ يې نېږدې وينو."
  70,8,"هغه ورځ چې اسمان ويلې شوې كلايي غوندې شي."
  70,9,"او غرونه به د ټكول شوې وړۍ غوندې وي."
  70,10,"او پوښتنه به نشې کولی یو دوست له بل دوست نه."
  70,11,"ټول به ښودلی کیږي دوی ته، ارمان به کوي مجرم چې د هغې ورځې له عذابه د خلاصیدو په موخه خپل زامن په فدیه كې وركړي."
  70,12,"او مېرمن او وروڼه يې."
  70,13,"او خپله هغه كورنۍ چې هغه ته يې ځاى وركولو."
  70,14,"او څوك چې په ځمكه كې دي هغه ټول، چې هغه وژغوري."
  70,15,"هيڅكله [نه شي کیدای چې مجرم دي په فدیه خلاص شي]، هغه (اور) خو لمبې وهونكی دى."
  70,16,"ویستونکی د اندامونو پوستکي لره."
  70,17,"هر هغه څوك رابولي چې شايې ګرځولې او مخ يې اړولى."
  70,18,"او مال يې راټول كړى او زېرمه كړى دى."
  70,19,"په رېښتيا انسان بې حوصلې حرصناک پيدا شوى."
  70,20,"چې بدي ور ورسي فرياد كوونكى وي."
  70,21,"او چې ښېګڼه ورته ورسيږي نو بخيلي كوونكى شي."
  70,22,"پرته له لمونځ كوونكو."
  70,23,"هغوى چې پر خپلو لمونځونو تل كلك وي."
  70,24,"او چې په مالونو كې يې ټاكلې برخه وي"
  70,25,"د سوالګر او بې وزله لپاره."
  70,26,"او هغه کسان چې ریښتونې ګڼي ورځ د جزا."
  70,27,"او هغوى چې د خپل پالونکي له عذابه وېرېدونكي وي."
  70,28,"بېشكه چې د خپل پالونکي عذاب يې د بې غمۍ شى نه دى."
  70,29,"او هغوى چې د خپلو عورتونو ساتونكي وي."
  70,30,"پرته له خپلو مېرمنو او مينځو يې چې دوى پكې ملامتېدونكي نه دي."
  70,31,"نو چا چې ولټاوه پرته لدې نه نو دغه کسان دوی له حد نه تېریدونکي دي."
  70,32,"او هغوى چې د خپلو امانتونو او ژمنو خيال ساتونكي دي."
  70,33,"او هغوى چې پر خپلو شاهديو ټينګ ولاړ دي."
  70,34,"او هغوى چې د خپل لمانځه ساتنه كوي."
  70,35,"دغه كسان به په جنتونو كې عزتمن اوسېدونكي وي."
  70,36,"نو دا كافران له څه امله ستا په لور ځغلېدونكي دي."
  70,37,"چې له ښي او كيڼ لورې ډلې ډلې ناست دي."
  70,38,"آيا د هغوى هر كس هيله لري چې نعمتونو والا جنت ته به ننه اېستل شي؟"
  70,39,"هيڅكله نه، بېشكه هغوى مو له يو داسې شي پيدا كړي چې هغوى پرې پوهيږي."
  70,40,"نو نه، زه قسم كوم د ختيځونو او لوېديځونو پر رب چې موږ بالكل قادر يو."
  70,41,"په دې كار چې د هغوى په بدل كې ترې غوره خلك راولو او موږ بايلونكي (عاجز) نه يو."
  70,42,"نو پرېږده يې چې خپلې ناندرۍ او لوبې كوي تر دې چې خپلې هغې ورځې سره مخامخ شي، چې لوظ يې ورسره كيږي."
  70,43,"هغه ورځ چې په منډه به (له قبرونو) راوځي، لكه د بتانو درشلو ته چې ورځغلي."
  70,44,"سترګې به يې ټيټې او ذلت به پرې راخپور وي، دا همغه ورځ ده چې هغوى سره يې ژمنه كېدله."
