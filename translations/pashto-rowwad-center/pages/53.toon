quran[62]{c,v,t}:
  53,1,"قسم په ستوري کله چې پریوزي."
  53,2,"چې ستاسو ملګرى (رسول الله) نه بې لارې شوى او نه په غلطه (عقيده) دى."
  53,3,"او نه له خپله هوسه غږيږي."
  53,4,"دا له وحي پرته بل څه نه دي چې ورته رالېږل كيږي."
  53,5,"ډېر ځواكمنې (پرېښتې) ور ښوولې ده."
  53,6,"چې د زور څښتنه ده، نو سيده ودرېده."
  53,7,"او هغه د آسمان پر اوچتو څنډو و."
  53,8,"بيا نېږدې او ښه رانیږدې شو."
  53,9,"نو د دوو ليندو ترمنځ يا تر هغه هم ورنېږدې شو."
  53,10,"نو د هغه (الله) بنده ته يې وحي كړل څه يې چې وحي كړل."
  53,11,"د هغه زړه درواغ نه دي ويلي په هغه څه كې چې ليدلي يې و."
  53,12,"آيا په هغه څه كې ورسره ناندرۍ وهئ چې هغه يې ويني؟"
  53,13,"او يقيناً يو ځل مخكې يې هم ليدلى دى."
  53,14,"د آخرنۍ (لرې) بېرې (ونې) خواته."
  53,15,"چې له هغې سره جنت الماوٰى دى."
  53,16,"هغه وخت چې بېره يې پټه كړې وه هغه څه چې پرې خپور شوى و."
  53,17,"(د هغه) سترګې نه کږې شوې او نه له بريده واوښتې."
  53,18,"په رېښتيا د خپل پالونکي څه سترې نښانې يې وليدې."
  53,19,"آيا تاسي لات او عزى ليدلي [آیا د هغوی څه قدرت لویوالی شته]؟"
  53,20,"او بل دريم منات؟"
  53,21,"آيا تاسي لره به زامن او د هغه به لوڼې (لورګانې) وي؟"
  53,22,"دا خو بيا ډېر بې انصافه وېش دى!"
  53,23,"دا پرته له يو څه نومونو بل څه نه دي چې تاسو او پلرونو مو اېښي دي، الله كوم دليل پرې نه دى نازل كړى. هغوى پرته له ګومان او نفسي غوښتنې بل څه پسې نه دي روان او پرته له شکه د هغوى د پالونکي له خوا لارښوونه ورغلې ده."
  53,24,"آيا (هغه كافر) انسان چې د څه هيله كوي همغه به ورته رسېدونكى وي؟"
  53,25,"نو (يوازې) الله لره دي آخرت او دنيا."
  53,26,"او په آسمانو كې څومره پرېښتې دي چې سپارښتنه يې هيڅ ګټه نه شي رسولاى، مګر له هغه وروسته چې الله اجازه وركړي چاته چې وغواړي او پرې رضا شي."
  53,27,"بېشكه هغه كسان چې پر آخرت ايمان نه لري، په پرېښتو ښځينه نومونه ږدي."
  53,28,"او حال دا چې هغوى لره پرې څه پوهه نشته، له ګومانه پرته بل څه پسې نه ځي او په رېښتيا ګومان د حق پر وړاندې هيڅ كار نه شي وركولاى."
  53,29,"نو له هغه چا مخ وګرځوه چې زموږ له ياده يې مخ اړولى او له دنيوي ژونده پرته بل څه نه غواړي."
  53,30,"همدا يې د پوهې وروستی بريد دى. بېشكه هماغه ستا پالونکی په هغه چا ډېر ښه پوه دى چې له لارې يې اوښتى او همغه پر لار موندونكو ښه پوه دى."
  53,31,"او په آسمانونو او ځمكه كې چې څه دي هغه (يوازې) الله لره دي. تر څو بد عمله كسانو ته د خپلو عملو بدله وركړي او چا چې ښه كړي هغه ته په ښو سره بدله وركړي."
  53,32,"هغوى چې له غټو ګناهونو او بې شرميو ځان ساتي پرته له وړو وړو ګناهونو. بېشكه ستا رب د بخښنې پراخوونكى دى. هغه پر تاسي ښه پوه و چې كله يې له ځمكې راپيدا كړئ او كله چې تاسي د خپلو ميندو ګېډو كې (پټ) واړه بچيان واست. نو د خپلو ځانو پاكي مه بيانوئ، همغه متقيان ښه پېژني."
  53,33,"آيا هغه دې وليد چې مخ يې واړولو؟"
  53,34,"او لږ (خيرات، زكات) يې وركړ او (نور څه يې) ايسار كړل."
  53,35,"آيا هغه سره د پټو پوهه ده چې (هر څه) ويني."
  53,36,"كه په هغه څه نه دى خبر شوى چې د موسى په پاڼو كې و."
  53,37,"او د هغه ابراهيم (پاڼو كې)، چې وفا يې وكړه."
  53,38,"دا چې هيڅوك به د بل چا بار نه وړي؟"
  53,39,"او دا چې انسان ته بل څه نشته پرته له هغې بدلې چې خپله يې هڅه كړې وي."
  53,40,"او بېشكه چې دا هڅه به يې زر وليدل شي."
  53,41,"بيا به پوره پوره بدله وركړل شي."
  53,42,"او دا چې (همغه) ستا د رب لور ته ور رسېدل دي."
  53,43,"او دا چې هغه (خلک) خندوي او ژړوي."
  53,44,"او دا چې همغه مړه كوي او ژوندي كوي."
  53,45,"او دا چې همغه دوې جوړې پيدا كړې دي نارينه او ښځينه."
  53,46,"له يو څاڅكې (مني) چې وڅڅول شي."
  53,47,"او دا چې بل وار پيدا كول هم پر هغه دي."
  53,48,"او دا چې بېشكه همغه شتمن كوي او پانګه وركوي."
  53,49,"او دا چې په رېښتيا هغه د شِعرا (ستوري) رب دى."
  53,50,"او دا چې همغه لومړني عاديان هلاك كړي دي."
  53,51,"او ثموديان چې (څوک يې ترې) پرېنښودل."
  53,52,"او له دې مخکې د نوح قوم. بېشكه چې همدوى ډېر ظالمان او سركښان وو."
  53,53,"او نسكور شوي كلي (همده) لاندې وغورځول."
  53,54,"بيا يې پټ كړل په هغه څه چې پټ يې كړل."
  53,55,"نو د خپل رب پر كوم كوم نعمت شک كوې؟"
  53,56,"دا (نبى عليه السلام) يو وېرونكى دى له مخکېنيو وېروونكو څخه."
  53,57,"راتلونكى (قيامت) رانېږدې شو."
  53,58,"له الله پرته بل څوک د هغه (د وخت) راښكاروونكى نشته."
  53,59,"آيا نو تاسي له دې خبرې تعجب كوئ؟"
  53,60,"او خاندئ خو ژاړئ نه؟"
  53,61,"او تاسي چټي لوبې كوئ."
  53,62,"نو الله ته سجده وكړئ او عبادت وكړئ."
