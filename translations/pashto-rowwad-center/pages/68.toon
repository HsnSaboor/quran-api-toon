quran[52]{c,v,t}:
  68,1,"ن قسم دى پر قلم او پر هغه څه چې ليكي يې."
  68,2,"نه يې ته په نعمت د رب ستا لیونی."
  68,3,"او بېشكه ستا لپاره هرومرو نه ختمېدونكې بدله ده."
  68,4,"او ته په رېښتيا پر سترو اخلاقو (سم) يې."
  68,5,"نو زر دی چې به ته هم ووینې او هغوى به هم وويني."
  68,6,"چې له تاسو په كوم يوه كې لېونتوب دى."
  68,7,"په رېښتيا همغه ستا رب په هغه چا ښه پوه دى چې له لارې يې اوښتى او همغه په لار موندونكو هم ښه پوه دى."
  68,8,"نو د درواغ ګڼونكو پيروي مه کوه."
  68,9,"هغوى غواړي چې ته نرمي وكړې نو هغوى به هم نرمي وکړي."
  68,10,"او مه د هر قسم خور سپك (سړي) پيروي کوه."
  68,11,"چې عیب ویونکی، او د خبرو وړونكى راوړونكى [چغلي کوونکی] وي."
  68,12,"د نېكۍ ايساروونكى، تېرى كوونكى ډیر بد کاره وي."
  68,13,"بد زبانه سخت زړی دی (او) له دې (ټولو) وروسته ارمونی (حرامي) هم دى."
  68,14,"په دې چې هغه د مال او زامنو څښتن دى."
  68,15,"كله چې زموږ آيتونه پرې لوستل کيږي، وايي د پخوانيو کيسې دي."
  68,16,"موږ به يې زر پر پوزه داغ وركېږدو."
  68,17,"په رېښتيا چې هغوى (مكى والا) مو داسې وازمويل لكه د يو بڼ څښتنان مو چې ازمويلي وو، کله چې هغوى قسم وكړ چې هرومرو به يې سهار وختي مېوې شكوي."
  68,18,"او ان شاء الله يې نه ويل."
  68,19,"نو راغی د شپې په هغې باندې د شپې راتلونکی عذاب له طرفه د رب ستا نه او دوی ویده وو."
  68,20,"نو د رېبلي كښت غوندې شو."
  68,21,"بيا يې سهار يو بل ته نارې كړې."
  68,22,"چې خپل كښت ته به وختي ځئ كه د مېوې راټولوونكي ياست."
  68,23,"نو روان شول او پټ پټ سره غږېدل."
  68,24,"چې نن خو به هلته يو بې وزله هم درباندې رانه شي."
  68,25,"او سهار وختي په ايسارولو (ښه) برلاسي روان شول."
  68,26,"خو كله يې چې وليد، وېلې: هرومرو مو لار غلطه كړې."
  68,27,"نه، بلكې موږ (لكه چې) بې برخې شوي يو."
  68,28,"تر ټولو منځني (غوره) يې وويل: ما نه درته ويل چې ولې تسبيح نه وايئ؟"
  68,29,"(بيا) هغوى (ټولو) وويل: زموږ پالونکي لره پاكي ده، په رېښتيا موږ ظالمان وو."
  68,30,"نو ځينو يې پر ځينو پړه سره اچوله."
  68,31,"دوی وویل: هاى بربادي ده موږ لره، یقینا موږ یو د حد نه تېریدونکي."
  68,32,"ښايي زموږ رب په بدل كې ترې ښه (باغ) راكړي، موږ د خپل رب لور ته ورګرځو."
  68,33,"عذاب همداسې وي او د آخرت عذاب له دې هم لا ډېر لوى دی، خو كاشكې هغوى پوهېدلاى."
  68,34,"پرته له شکه د ځان ساتونکو لپاره يې له خپل پالونکي سره له نعمتونو ډك جنتونه دي."
  68,35,"نو آيا موږ به مسلمانان د مجرمانو په څېر كړو."
  68,36,"څه درباندې شوي؟ دا څنګه پرېکړه كوئ؟"
  68,37,"آيا له تاسي سره كوم كتاب دى چې په هغه کې لوستل کوئ."
  68,38,"چې تاسې لپاره هلته هرومرو همغه څه دي چې خوښوئ يې؟"
  68,39,"يا تاسې لره تر قيامته پر موږ دا ژمنې دي چې ستاسو لپاره به همغه څه وي چې تاسې خپله يې پرېكړه كوئ؟"
  68,40,"ويې پوښته چې كوم يو يې په دې خبره ضامن دى."
  68,41,"يا د هغوى څه شريكان دي (چې ذمه يې وهلې) نو خپل شريكان دې راولي، كه هغوى رېښتيني وي."
  68,42,"په كومه ورځ چې سخته وېره راشي او هغوى سجدې كولو ته وبلل شي نو بيا به يې نه شي كولاى."
  68,43,"سترګې به يې ټېټې او رسوايي به پرې خپرېدونكې وي. حال دا چې (په دنيا كې) سجدې ته بلل كېدل او هغوى روغ جوړ وو."
  68,44,"نو ته ما او هغه څوك سره پرېږده چې دا خبره درواغ ګڼي. موږ به يې داسې په كرار كرار راونيسو چې هغوى به نه پوهيږي."
  68,45,"او مهلت وركوم، بېشکه زما تدبير (پلان) ډېر پوخ دى."
  68,46,"آيا ته څه بدله ترې غواړې چې هغوى د تاوان تر پېټي لاندې درانه شوي."
  68,47,"يا له هغوى سره د پټو پوهه ده چې هغوى يې ليكي."
  68,48,"نو د خپل رب حكم ته صبر كوه او د ماهی والا غوندې مه كېږه چې نارې يې كړې او له غمه ډك شوى و."
  68,49,"كه د هغه د پالونکي لخوا لورينه ورباندې نه واى شوې نو هرومرو به ملامت شوى په يوه سپېره ډاګ غورځېدلى و."
  68,50,"خو خپل پالونکي يې غوره کړ او له نېکانو يې وګرځولو."
  68,51,"او كله چې هغه کسان چې کفر يې کړی دا نصيحت اوري نو نېږدې وي چې په خپلو سترګو دې له ځايه وښويوي او وايي چې هغه هرومرو لېونى دى."
  68,52,"حال دا چې هغه د ټولو نړيوالو لپاره پرته له يو پنده بل څه نه دى."
