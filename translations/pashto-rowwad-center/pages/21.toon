quran[112]{c,v,t}:
  21,1,"نږدې شوی خلکو ته حساب د هغوی او دوی په غفلت کې، مخ ګرځوونکي دي."
  21,2,"او نه راځي دوی ته هېڅ نصېحت د دوی د رب له طرفه چې نوي وي د هغه راتلل، مګر دوی ورته غوږ نیسي په داسې حال کې چې لوبې کوي."
  21,3,"مشغول وي د هغوی زړونه (په نورو خبرو)، او پټې مشورې وکړې ظالمانو خلکو، (او وایي) نه دی دا مګر ستاسي په څېر یو بنده دی، آیا راتلل کوئ تاسي جادو ته او حال دا دی چې تاسي پوهه یاستئ."
  21,4,"وویل (پېغمبر) رب زما عالم دی پر هره وینا په آسمان کې وي او که په ځمکه کې، او هغه هر څه اوري په هر څه پوه دی."
  21,5,"بلکې دوی ویلي وو: دا ګډوډ خوبونه دي، بلکې دا یې د ځانه جوړ کړي، بلکې دا شاعر دی؛ پس رادې وړي موږ ته یوه معجزه (چې موږ یې غواړو) په شان د هغو (معجزو) چې لېږل شوي وو (په هغو سره) پخواني رسولان."
  21,6,"اېمان نه دی راوړی د دوی نه مخکې کلیو والا کوم چې موږ هلاک کړي، نو آیا دوی به اېمان راوړي؟"
  21,7,"او نه دي لیږلي موږ تانه مخکې مګر سړي (پېغمبران) چې وحې مو ورته کوله، نو پوښتنه وکړئ د علم والاو نه که چیرته تاسي نه پوهیږئ."
  21,8,"او نه وو ګرځولي موږ (دغه پخواني رسولان) داسې جسدونه چې نه يې طعام خوړلو، او نه وو دوی تل پاتې کیدونکي."
  21,9,"بیا مو هغو (رسولانو) سره وعده رښتیا کړه، نو بچ کړل موږ دوی او هغه څوک چې موږ غوښتل، او هلاک کړل موږ د حده تیرېدونکي خلک."
  21,10,"یقېنا نازل کړی موږ تاسي ته یو کتاب چې په هغه کې ستاسي نصېحت دی، ولې د عقل نه کار نه اخلئ؟"
  21,11,"او څومره ډېر کلي مو هلاک کړي چې ظالمان وو، او له هغوی وروسته مو نور قومونه پیدا کړل."
  21,12,"پس هر کله چې دوی زموږ عذاب ولید، نو یو دم یې ترې څخه منډې کړلې."
  21,13,"(وويل شول) مه تښتئ او هغو ځايونو ته راوګرځى چې تاسو ته پكې ښه ژوند دركړى شوى و او خپلو كورو ته هم، ښايي تاسو وپوښتل شئ."
  21,14,"وبه وايي ای هلاکته زموږ! بې شکه موږ ظالمان وو."
  21,15,"نو دوى تر هغه دا نارې وهلې چې (ښه) رېبلي يخ مړه مو وغورځول."
  21,16,"او موږ دا آسمان، زمكه او څه يې چې ترمنځه دي، داسې نه دي پيدا كړي چې لوبې کوونکي وو."
  21,17,"كه چېرې موږ غوښتي وى چې یوه مشغله جوړه كړو نو له خپله لوري به مو جوړه کړې وه، كه موږ د دې كار كوونكي وى."
  21,18,"خو موږ په باطل باندې د حق ګوزار كوو چې د هغه سرماتوي (په دماغو یې وهي) او يو دم هغه له منځه تلونكى شي او تاسو لره د هغو خبرو له كبله تباهي ده چې خپله يې جوړوئ."
  21,19,"او هغه لره دي هر هغه څوک چې په اسمانونو او زمكه كې دي، او هغه څوک (ملايک) چې له هغه سره دي نه يې له عبادته لويي كوي او نه ستومانه كيږي."
  21,20,"شپه او ورځ تسبيح وايي، نه سستيږي."
  21,21,"آيا دوى د زمكې (له شيانو) نه ځانته معبودان نيولي چې هغوى به هم (مړي) راپاڅوي؟"
  21,22,"كه (په آسمان او زمكه كې) الله نه پرته نور معبودان هم واى نو دواړه به وران (ګډوډ) شوي وى، نو الله د عرش پالونكي لره هغو خبرو نه پاكي ده چې دوى يې جوړوي."
  21,23,"دى چې څه كوي له هغه نه پوښتل كيږي خو دوى ټول به پوښتل كيږي."
  21,24,"آيا له هغه پرته يې نور معبودان نيولي؟ ورته ووايه! دليل مو راوړئ! دا (قرآن) د هغه چا بيان دى چې ما سره دي او د هغو چې له ما مخكې وو، بلكې زياتره يې له حقه نا خبره دي نو (ځكه) مخ اړونكي دي."
  21,25,"او له تا مخكې مو هېڅ داسې رسول نه دى لېږلى چې هغه ته مو دا وحى نه وې كړې چې يقيناً له ما پرته بل معبود نشته نو (یوازې) زما عبادت كوئ."
  21,26,"او دوى وويل: رحمان اولاد لري! هغه لره پاكي ده، (نه) بلكى هغوى خو عزتمن بندګان دي."
  21,27,"له هغه نه په خبرو كې نه وړاندې كيږي او د هغه په امر كار كوي."
  21,28,"هغه څه هم ورته معلوم دي چې د هغوى په وړاندې دي او هغه هم چې تر شا يې دي، او پرته له هغه چا چې (د الله ورته) رضا وي، بل د هېچا سپارښتنه نه كوي او د هغه له وېرې ډارېدونكي دي."
  21,29,"او له هغو نه كه هر څوک دا ووايي چې زه له هغه (الله) پرته (په خپله) معبود يم، نو هغه ته د جهنم سزا وركوو، همدغه شان بدله به (ټولو) ظالمانو ته وركوو."
  21,30,"آيا هغو كسانو چې كافر شوي دا نه دي ليدلي چې آسمانونه او زمكه سره نښتي وو بيا موږ سره بېل كړل، او له اوبو نه مو هر ژوندى شى پيدا كړ، نو آيا دوى ايمان نه راوړي؟"
  21,31,"او په زمكه مو محکم غرونه پيدا كړل چې په دوى ونه خوخيږي او په هغى كې مو ارتې لارې جوړې كړې چې ښايي لارې ومومي."
  21,32,"او اسمان مو يو خوندي چت جوړ كړ خو دوى يې له نښانو مخ ګرځوونكي دي."
  21,33,"او دى هماغه ذات دى چې شپه، ورځ، لمر او سپوږمۍ يې پيدا كړي دي، دا ټول په يو مدار (ګرځندۍ) كې لامبو وهي."
  21,34,"او له تا مخكې مو هم كوم بشر ته همېشنى ژوند نه دى وركړى، نو كه ته مړ شوې، آيا دوى به تل پاتې کېدونكي وي."
  21,35,"هر ساكښ د مرګ څكونكى دى او موږ په بدو او ښو (حالاتو كې) ستاسو ازميښت كوو او بيا زموږ لور ته راګرځول كېږئ."
  21,36,"او كله چې دا كافران دې وويني نو په تا پورې ملنډې وهي، وايي دا هماغه دى چې ستاسو معبودان (په بدۍ سره) يادوي؟ او حال دا چې (خپله) د رحمان په يادولو هم كافر دي."
  21,37,"انسان پيدا دى له تلوار (بې صبرۍ) څخه، خو زه به خپلې نښانې زر دروښيم، نو تلوار مه كوئ."
  21,38,"او دوى وايي: دا وعده به كله وي؟ كه تاسو رښتيني ياست."
  21,39,"كاشكې دغو كافرانو ته معلومه وى، هغه وخت چې نه به له خپلو مخونو اور ايسارولى شي، نه له شاګانو خپلو، او نه به څه مرسته ورسره كېداى شي."
  21,40,"بلكې ناڅاپي به ورته راشي او حيران به يې كړي نو نه به يې ايسارولى شي او نه به څه مهلت وركول كيږي."
  21,41,"او له تا مخكې هم په رسولانو ملنډې وهل شوې دي، خو چا چې په هغوى ملنډې وهلې وې، هغه څه (عذاب) ورباندې راپرېوت چې دوى به پرې ملنډې وهلې."
  21,42,"ورته ووايه څوک مو د شپې او د ورځې له رحمن څخه ژغورلى شي، خو هغوى د خپل رب له ياده مخ ګرځوونكي دي."
  21,43,"يا دوى لره له موږه پرته څه نور معبودان شته چې ساتي يې، هغوي خو نه د ځان مرسته كولاى شي او نه له موږه ژغورل كېداى شي."
  21,44,"خو خبره دا ده چې موږ دوى او پلرونو ته يې دومره د ژوند وسايل وركړل چې زمانه پرې اوږده شوه، آيا دوى نه ويني چې موږ له هرې خوا زمكه راكموو؟ نو آيا دوى برلاسي كېدونكي دي؟"
  21,45,"ووايه: خبره دا ده چې زه خو په وحى سره اخطار دركوم، او كاڼه چې وېرول كيږي نو بلنه نه اوري."
  21,46,"او كه ستا د رب له عذابه خو لږ تپ هغوى ته ور ورسېدو نو بيا به خامخا ووايي چې هاى زموږ بده بخته! رښتيا چې موږ ظالمان وو."
  21,47,"او موږ به د قيامت ورځې ته د انصاف تلې ږدو، نو بيا به په هيچا هېڅ ظلم ونه شي كه (څه هم يو عمل) د اوري دانې په اندازه وي، موږ به يې راوړو، او پوره یو موږ حساب کوونکي."
  21,48,"او موسىٰ او هارون -علیهما السلام- ته مو فرقان (د حق او باطل بېلوونكى کتاب)، رڼايي او د متقيانو لپاره نصيحت وركړى و."
  21,49,"هغوى چې په پټه له خپل رب نه وېريږي او له قيامته هم ډارېدونكي وي."
  21,50,"او دغه بركتي ذكر (قرآن) موږ نازل كړى دى، نو آيا تاسو ترې منكر ياست؟"
  21,51,"او ابراهيم -علیه السلام- ته مو لا مخكې ځيركتیا (لارښوونه) وركړى وه او موږ ښه ورباندې پوه وو."
  21,52,"كله چې هغه خپل پلار او قوم ته وويل: دا بتان څه دي چې تاسو يې عبادت ته ټينـګ ولاړ ياست؟"
  21,53,"هغوى وويل: موږ خپل پلرونه د دغو په لمانځنه موندلي دي."
  21,54,"(ابراهيم -علیه السلام-) وويل: په حقيقت كې تاسو او پلرونه مو (ټول) په څرګند بې لارې توب كې ياست."
  21,55,"دوی وویل: آیا تا مونږ ته حق (خبره) راوړې او که ته له لوبو کوونکو څخه یې؟"
  21,56,"وویل (ابراهیم -علیه السلام-): ستاسو رب خو هماغه د آسمانونو او زمكې رب دى چې پيدا كړي یې دي، او زه په دې خبره شاهدي ويونكى يم."
  21,57,"او په الله قسم چې ستاسو بتانو ته به څه تدبیر جوړوم، له هغه وروسته چې په څټ (چېرته) ولاړ شئ."
  21,58,"نو هغه (بتان) يې د لوى (بت) نه پرته (ټول) ټوټه ټوټه كړل، چې ښايې بيا دوى هغه (لوى) ته ورشي."
  21,59,"(كله چې راغلل) ویې ویل: زموږ په معبودانو دا (كار) چا كړى؟ بې شكه هغه له ظالمانو څخه دى."
  21,60,"(څه خلكو) وويل: موږ له يو زلمي چې ابراهيم يې بولي، اورېدلي چې هغوى به يې يادول."
  21,61,"هغوى وويل: نو د خلكو د سترګو وړاندې يې راولئ، چې هغوى وګوري."
  21,62,"بيا يې ورته وويل: آيا زموږ په معبودانو دا كار تا كړى ای ابراهيمه!"
  21,63,"(ابراهیم -علیه السلام-) وویل: بلكې دغه لوى يې كړي دي، نو هغوی وپوښتئ كه خبرې كوي."
  21,64,"نو بيا هغوى پر خپلو ځانو ورتاو شول، سره ويې ويل: يقيناً همدا تاسو ظالمان ياست."
  21,65,"بيا په خپلو سرو نسكور كړى شول ویې ویل: ته خو ښه پوهېږې چې دوى نه غږيږي."
  21,66,"(ابراهيم -علیه السلام-) وويل: نو آيا الله نه پرته هغه څه لمانځئ چې نه د څه شي ګټه در رسولاى شي او نه تاوان؟"
  21,67,"افسوس (او هلاکت دی) تاسو لره، او هغه څه لره چې له الله پرته يې لمانځئ، آيا نو تاسو عقل نه كاروئ."
  21,68,"هغوى وويل: ويې سوځوئ او د خپلو معبودانو مرسته وكړئ، كه چېرې د څه (کار) كوونكي ياست."
  21,69,"موږ وويل: ای اوره! په ابراهيم -علیه السلام- باندې سوړ او سلامت شه."
  21,70,"او هغوى په (ابراهيم -علیه السلام-) باندې څه چل كول غوښتل خو موږ دوى په خپله سخت تاواني كړل."
  21,71,"او موږ هغه (ابراهيم) او لوط (عليهما السلام) هغې سيمې لور ته وژغورل چې په هغې كې مو د نړيوالو لپاره بركتونه اچولي دي."
  21,72,"او هغه ته مو اسحاق وركړ او يعقوب په هغه سربېره، او دوی ټول مو نېكان ګرځولي وو."
  21,73,"او هغوی مو داسې امامان وګرځول چې زموږ په امر سره يې لارښوونه كوله، او د ښو چارو او لمانځه ترسره كولو او زكات وركولو وحى مو ورته وكړه، او هغوى (خاص) زموږ لمانځونكي وو."
  21,74,"او لوط -علیه السلام- ته مو (هم) حكم (نبوت) او پوهه وركړې وه، او له هغه كلي مو وژغولو چې بدكاري يې كوله، رښتيا چې هغوى يو ناوړه فاسق قوم و."
  21,75,"او هغه (لوط) مو په خپل رحمت كې داخل كړ، يقيناً هغه له نېكانو څخه و."
  21,76,"او نوح -عليه السلام- (ياد كړه) چې لا مخكې يې غږ (راته) كړى و، نو موږ يې دعا قبوله كړه، او دی او د ده كورنۍ مو له لوى كړاو څخه وژغورل."
  21,77,"او موږ د هغه قوم په مقابل كې د ده مرسته وكړه چې زموږ آيتونه يې دروغ ګڼلي وو، بې شكه هغوى ناوړه خلک وو نو ټول مو غرق كړل."
  21,78,"او داود او سليمان -علیهما السلام- (درياد كړه) چې كله يې د يو كښت په هكله فيصله كوله، كوم کې چې د يو قوم پسونه د شپې ګډ شوي وو، او موږ د هغوى فيصلې ته حاضر و."
  21,79,"نو په هغې مو سليمان -علیه السلام- وپوهوه، او دوى هر يوه ته مو حكم او پوهه وركړې وه، او له داود سره مو غرونه او مرغان هم تابع كړي و چې تسبيح به يې ويله، او موږ د دې كاركوونكي و."
  21,80,"او هغه ته مو ستاسي لپاره د زغرو جوړول ورزده كړي و چې تاسو له خپله جنګه وساتي، نو آيا تاسو شكر وېستونكي ياست؟"
  21,81,"او سليمان -علیه السلام- ته مو توند باد تابع كړى و چې د ده په امر به هغې زمكې ته روان و چې بركت مو پكې ايښى و او موږ په هر څه پوه يو."
  21,82,"او له شيطانانو مو ځينې داسې ورته تابع كړي وو چې د هغه لپاره يې (په سیندونو کې) غوټې وهلې او له دې پرته يې نور كارونه هم كول او موږ د هغوى ساتونكي وو."
  21,83,"او ايوب -علیه السلام- (در ياد كړه) كله چې یې خپل رب ته غږ وكړ چې ماته مرض رارسېدلى، او ته خو له هر چا ډېر مهربان يې."
  21,84,"نو د هغه دعا مو قبوله كړه او تكليف مو ترې لرې كړ، او د ده خپله كورنۍ مو هم وركړه او هماغومره نور هم ورسره، (دا) زموږ له لوري يو رحمت و او د عبادت كوونكو لپاره يو نصيحت."
  21,85,"او اسماعيل، ادريس او ذوالكفل، دوی ټول له صابرانو څخه وو."
  21,86,"هغوى مو په خپل رحمت كې داخل كړي وو، يقيناً هغوى له نېكانو څخه وو."
  21,87,"او كب والا (درياد كړه) كله چې په غوسه ولاړ (له خپل قومه) نو ده ګومان كړى و چې موږ به څه تنګون نه پرې راولو، نو په تيارو كې يې نارې كړې چې: (له تا پرته بل معبود نشته، تا لره پاكي ده، زه په خپله له ظالمانو څخه وم)."
  21,88,"نو موږ يې دعا قبوله كړه، او له غمه مو خلاص كړ او موږ مومنان همدغسې ژغورو."
  21,89,"او زكريا (در ياد كړه) كله چې یې خپل رب ته غږ وکړ: زما ربه ما يوازې مه پرېږده او ته ډېر غوره وارث يې."
  21,90,"نو موږ يې سوال قبول كړ، يحيىٰ مو وركړ او د هغه مېرمن مو ورته (له شنډوالي) روغه كړه، بې شكه هغوى (ټولو) په نېكيو كې بيړه كوله او موږ يې (د ثواب) په مينه او (له عذاب نه) په وېره وربللو، او خاص موږ ته غاړه اېښودونكي وو."
  21,91,"او هغې (جينۍ) چې د خپل فرج (مخصوصه اندام) ساتنه يې كړې وه، نو موږ له خپل روح نه پكې پو كړل او دا او زوى يې موږ د ټولو خلكو لپاره نښانه وګرځول."
  21,92,"بې شكه دغه ستاسو امت دى، یوازې يو امت، او زه ستاسو رب يم نو ما ولمانځئ."
  21,93,"او هغوى خپل (د دين) كار سره ټوټې ټوټې كړ، ټول زموږ خوا ته راستنېدونكي دي."
  21,94,"نو څوک چې له ښو كارونو څه وكړي، په داسى حال كې چې هغه مومن وي نو د هغه د هلو ځلو بې قدري به ونه شي او موږ هغه لره ليكونكي يو."
  21,95,"او يو كلى چې موږ هلاک كړى وي، دا پرې حرامه ده چې بېرته دې راوګرځي."
  21,96,"تر هغه پورې چې یأجوج او مأجوج را پرانيستل شي او له هرې لوړې په منډه منډه راكوزيږي."
  21,97,"او رښتينې وعده رانږدې شوه، نو يو دم به د هغو كسانو سترګې بوټې بوټې راووځي چې كافران شوي وو، (وايي به) چې هاى زموږ بده بخته! موږ خو له دې نه په غفلت كې و، بلکې موږ ظالمان وو."
  21,98,"يقيناً تاسو او هغه چې تاسو يې له الله پرته لمانځئ، د جهنم خشاك ياست، تاسو هماغلته ورننوتونكي ياست."
  21,99,"دوى كه (رښتیني) معبودان وى، هلته (جهنم ته) به نه وو ورننوتلي، او دا ټول به تل پكې پراته وي."
  21,100,"هلته به د دوى چغې سورې وي او هېڅ به پكى نه اوري."
  21,101,"خو هغه كسان چې د هغوى لپاره زموږ له خوا نېكي (جنت) مخكې (ليكل) شوې ده، نو دوې به له هغه نه لرې كړى شوي وي."
  21,102,"دوى به يې كشار هم نه اوري، او په هغو شيانو كې به تل تر تله اوسېدونكي وي چې زړونه يې غواړي."
  21,103,"ها د سترې وارخطايي وخت به يې هم نه غمجن كوي او ملايكان به ورسره مخامخ كيږي (وايي به) دا ستاسو هماغه ورځ ده چې وعده يې درسره كېدله."
  21,104,"هغه ورځ چې موږ آسمان داسې راونغاړو لكه د ليكل شويو پاڼو نغښتل، څنګه چې ړومبى ځل پيدايښت مو پيل كړى و، هماغسې به يې بيا راګرځوو، دا په موږ وعده ده موږ خامخا د دې كار كوونكي يو."
  21,105,"او موږ له ذکر (لوح محفوظ) نه وروسته په زبور كې ليكلي و چې دا زمكه به زموږ نېکان بندګان په ميراث وړي."
  21,106,"يقيناً په دې كې د عبادت كوونكو خلكو لپاره پوره خبرتيا ده."
  21,107,"او نه یې لېږلی مونږ ته؛ مګر رحمت د ټولو خلکو لپاره."
  21,108,"ورته ووايه: بې شکه ماته وحي كېږي چې ستاسو معبود یوازې هماغه يو معبود دى، نو آيا تاسو غاړه اېښودونكي ياست؟"
  21,109,"نو كه مخ يې وګرځولو، بيا ورته ووايه چې ما خو ټول يو برابر خبر كړئ، او زه نه پوهېږم، د كوم شي چې تاسو سره وعده كيږي هغه نږدې دى كه لرې."
  21,110,"هغه (الله) په جهر خبره هم پوهيږي او په هغه هم چې تاسو يې پټوئ."
  21,111,"او زه نه پوهېږم ښايي دا (ځنډېدل) ستاسو لپاره ازميښت او تر يوى نېټې پورې د ګټې اخيستلو يوه موقع وي."
  21,112,"(رسول) وويل: زما ربه! په حقه فيصله وكړه! او زموږ رب ډېر مهربان دی، او مرسته ترې غوښتی شي، په هغو خبرو كې چې تاسو يې بيانوئ."
