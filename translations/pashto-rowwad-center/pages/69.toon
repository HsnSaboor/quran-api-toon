quran[52]{c,v,t}:
  69,1,"یقینې آفت راتلونکی"
  69,2,"څه لوی دی یقیني آفت راتلونکی؟"
  69,3,"او څه پوهه کړې ته چې څه شی دی یقیني راتلونکی آفت؟"
  69,4,"دروغ ګڼلی و ثموديانو او عاديانو د زړونو ټکوونکی آفت"
  69,5,"نو ثموديان په يوه بې اندازې سخته چغه تباه شول"
  69,6,"او هر چه عاديان و نو هلاک کړی شول په تېزې سیلۍ د حد نه تېریدونکې"
  69,7,"چې الله هغه پرله پسې اوه شپى او اته ورځې ورباندې ګمارلې وه، نو دا خلك به دې پكې داسې پرېوتي ليدل لكه چې د كجورو ورستې تنې چې وي"
  69,8,"نو آيا (اوس) د هغوى څوك پاتې شوي وينې؟"
  69,9,"او راتګ کړی و فرعون او څوك چې ترې مخكې و او نسكور شوو كليو هم په لویه ګناه سره"
  69,10,"نو سرغړونه یې وکړه د خپل پالونکي د رسول، نو ونیول (الله) دوی په نیولو سختو سره"
  69,11,"كله چې اوبه ډېرې طوفاني شوې نو موږ تاسي سپاره کړئ په روانې بېړۍ کې"
  69,12,"تر څو ستاسو لپاره يې درس وګرځوو او عبرت واخلي پند اخیستونکي غوږونه"
  69,13,"نو كله چې په شپېلۍ كې پو كړى شي يو ځل پوكى"
  69,14,"او پورته کړل شي زمكه او غرونه، نو وبه ټکول شي په ټکولو په یو ځل"
  69,15,"نو پدغه ورځ به رامنځ ته شي رامنځ ته کېدونکی آفت"
  69,16,"او وبه چوي آسمان، نو هغه به پدغه ورځ کمزوری وي"
  69,17,"او پرېښتې به يې پر څنډو وي او ستا د پالونکي عرش به په هغه ورځ اتو پرېښتو پر ځانونو دپاسه بار كړى وي"
  69,18,"په هغه ورځ به تاسي ور وړاندې كړاى شئ، ستاسي له عمله به هيڅ راز پټ پاتې نه شي"
  69,19,"نو د چا عملنامه چې د هغه په ښي لاس وركړل شوه، وايي به: ها، واخلئ زما عملنامه ولولئ!"
  69,20,"پرته له شکه ما انګېرلې وه چې له خپل حساب سره مخامخ کېدونكى يم"
  69,21,"نو بيا به هغه په خوشاله ژوندانه كې وي"
  69,22,"په اوچت جنت کې"
  69,23,"چې مېوې به يې (لاس ته) نېږدې وي"
  69,24,"خورئ، څښئ (ښه) په خوند سره، د هغو عملونو په بدله كې چې په تېرو ورځو كې مو وړاندې لېږلي وو"
  69,25,"او د چا كتاب چې د هغه په كيڼ (چپ) لاس وركړل شي، نو وايي به: ارمان چې كتاب مې نه واى راكړل شوى"
  69,26,"او نه پوهېدلی چې څه به وي حساب زما"
  69,27,"كاشكې هغه (مرګ ) ختموونكى واى ما لره"
  69,28,"مال مې هم څه رانه ايسار نه كړل"
  69,29,"واكمني مې هم تباه شوه"
  69,30,"(وبه ويل شي) راويې نيسئ او ځنځير ورواچوئ"
  69,31,"بيا يې دوزخ ته ورننباسئ"
  69,32,"بيا يې په يو داسې ځنځير كې چې اويا ګزه يې اندازه وي، ځوړند کړئ"
  69,33,"بېشکه هغه پر لوى الله ايمان نه درلود"
  69,34,"او هڅول یې نه کوله بې وزله ته په خوړو وركولو"
  69,35,"نو نشته نن ده لره دلته کوم مخلص دوست"
  69,36,"او نه له زوو پرته څه خواړه"
  69,37,"چې له ګناهګارانو پرته يې بل څوك نه خوري"
  69,38,"نو داسې نده، زه قسم كوم پر هر هغه څه چې تاسې يې وينئ"
  69,39,"او پر هغه څه چې نه يې وينئ"
  69,40,"چې بېشكه دا د يو عزتمن استازي وينا ده"
  69,41,"او د كوم شاعر خبره نه ده تاسي بيخې لږ ايمان راوړئ"
  69,42,"او نه د كاهن (تالې كتونكي، غيب ويونكي) خبره ده، تاسې لږ پند اخلئ"
  69,43,"دا د رب العالمين لخوا نازل شوى"
  69,44,"او كه چېرې ده له ځانه موږ پسې څه خبرې جوړې كړې واى"
  69,45,"هرومرو به مو هغه په ښي لاس رانيولى واى"
  69,46,"بيا به مو د هغه د زړه رګ ترې غوڅ كړى واى"
  69,47,"نو بيا به له تاسي هيڅوك له دې كاره زموږ ايساروونكي نه وو"
  69,48,"او په رېښتيا دا د ځان ساتونکو لپاره يو پند دى"
  69,49,"او بېشكه موږ پوهېږو چې له تاسي څه كسان درواغ ګڼونكي دي"
  69,50,"او هغه پر کافرانو پښېماني ده"
  69,51,"او دا يقيني حق دى"
  69,52,"نو د خپل لوى پالونکي پر نوم پاکي بيانوه"
