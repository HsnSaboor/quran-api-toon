quran[42]{c,v,t}:
  80,1,"وه ترش رو ہوا اور منھ موڑ لیا."
  80,2,"(صرف اس لئے) کہ اس کے پاس ایک نابینا آیا.",footnotes:344964:1
  80,3,"تجھے کیا خبر شاید وه سنور جاتا.",footnotes:344965:1
  80,4,"یا نصیحت سنتا اور اسے نصیحت فائده پہنچاتی."
  80,5,"جو بے پرواہی کرتا ہے.",footnotes:344966:1
  80,6,"اس کی طرف تو تو پوری توجہ کرتا ہے.",footnotes:344967:1
  80,7,"حالانکہ اس کے نہ سنورنے سے تجھ پر کوئی الزام نہیں.",footnotes:344968:1
  80,8,"اور جو شخص تیرے پاس دوڑتا ہوا آتا ہے.",footnotes:344969:1
  80,9,"اور وه ڈر (بھی) رہا ہے.",footnotes:344970:1
  80,10,"تو اس سے بےرخی برتتا ہے.",footnotes:344971:1
  80,11,"یہ ٹھیک نہیں قرآن تو نصیحت (کی چیز) ہے.",footnotes:344972:1
  80,12,"جو چاہے اس سے نصیحت لے.",footnotes:344973:1
  80,13,"(یہ تو) پر عظمت صحیفوں میں (ہے).",footnotes:344974:1
  80,14,"جو بلند وبالا اور پاک صاف ہے.",footnotes:344975:1
  80,15,"ایسے لکھنے والوں کے ہاتھوں میں ہے.",footnotes:344976:1
  80,16,"جو بزرگ اور پاکباز ہیں.",footnotes:344977:1
  80,17,"اللہ کی مار انسان پر کیسا ناشکرا ہے.",footnotes:344978:1
  80,18,"اسے اللہ نے کس چیز سے پیدا کیا."
  80,19,"اسے) ایک نطفہ سے پیدا کیا،پھراس کا اندازہ مقررکیا .",footnotes:344979:1|344980:2
  80,20,"پھر اس کے لئے راستہ آسان کیا.",footnotes:344981:1
  80,21,"پھر اسے موت دی اور پھر قبر میں دفن کیا."
  80,22,"پھر جب چاہے گا اسے زنده کر دے گا.",footnotes:344982:1
  80,23,"ہرگز نہیں(1) ۔ اس نے اب تک اللہ کے حکم کی بجا آوری نہیں کی."
  80,24,"انسان کو چاہئے کہ اپنے کھانے کو دیکھے.",footnotes:344983:1
  80,25,"کہ ہم نے خوب پانی برسایا."
  80,26,"پھر پھاڑا زمین کو اچھی طرح."
  80,27,"پھر اس میں سے اناج اگائے."
  80,28,"اور انگور اور ترکاری."
  80,29,"اور زیتون اور کھجور."
  80,30,"اور گنجان باغات."
  80,31,"اور میوه اور (گھاس) چاره (بھی اگایا).",footnotes:344984:1
  80,32,"تمہارے استعمال وفائدے کے لئے اور تمہارے چوپایوں کے لئے."
  80,33,"پس جب کہ کان بہرے کر دینے والی (قیامت) آجائے گی.",footnotes:344985:1
  80,34,"اس دن آدمی اپنے بھائی سے."
  80,35,"اور اپنی ماں اور اپنے باپ سے."
  80,36,"اور اپنی بیوی اور اپنی اولاد سے بھاگے گا."
  80,37,"ان میں سے ہر ایک کو اس دن ایسی فکر (دامن گیر) ہوگی جو اس کے لئے کافی ہوگی.",footnotes:344986:1
  80,38,"اس دن بہت سے چہرے روشن ہوں گے."
  80,39,"(جو) ہنستے ہوئے اور ہشاش بشاش ہوں گے.",footnotes:344987:1
  80,40,"اور بہت سے چہرے اس دن غبار آلود ہوں گے."
  80,41,"جن پر سیاہی چڑھی ہوئی ہوگی.",footnotes:344988:1
  80,42,"وه یہی کافر بدکردار لوگ ہوں گے.",footnotes:344989:1
