quran[26]{c,v,t}:
  88,1,"کیا تجھے بھی چھپا لینے والی (قیامت) کی خبر پہنچی ہے.",footnotes:345110:1
  88,2,"اس دن بہت سے چہرے ذلیل ہوں گے.",footnotes:345111:1
  88,3,"(اور) محنت کرنے والے تھکے ہوئے ہوں گے.",footnotes:345112:1
  88,4,"وه دہکتی ہوئی آگ میں جائیں گے."
  88,5,"اور نہایت گرم چشمے کا پانی ان کو پلایا جائے گا.",footnotes:345113:1
  88,6,"ان کے لئے سوائے کانٹے دار درختوں کے اور کچھ کھانے کو نہ ہوگا.",footnotes:345114:1
  88,7,"جو نہ موٹا کرے گا نہ بھوک مٹائے گا."
  88,8,"بہت سے چہرے اس دن تروتازه اور (آسوده حال) ہوں گے."
  88,9,"اپنی کوشش پر خوش ہوں گے."
  88,10,"بلند وبالا جنتوں میں ہوں گے."
  88,11,"جہاں کوئی بیہوده بات نہیں سنیں گے."
  88,12,"جہاں بہتا ہوا چشمہ ہوگا."
  88,13,"(اور) اس میں اونچے اونچے تخت ہوں گے."
  88,14,"اور آبخورے رکھے ہوئے (ہوں گے)."
  88,15,"اور ایک قطار میں لگے ہوئے تکیے ہوں گے."
  88,16,"اور مخملی مسندیں پھیلی پڑی ہوں گی.",footnotes:345115:1
  88,17,"کیا یہ اونٹوں کو نہیں دیکھتے کہ وه کس طرح پیدا کیے گئے ہیں.",footnotes:345116:1
  88,18,"اور آسمان کو کہ کس طرح اونچا کیا گیا ہے.",footnotes:345117:1
  88,19,"اور پہاڑوں کی طرف کہ کس طرح گاڑ دیئے گئے ہیں.",footnotes:345118:1
  88,20,"اور زمین کی طرف کہ کس طرح بچھائی گئی ہے.",footnotes:345119:1
  88,21,"پس آپ نصیحت کر دیا کریں (کیونکہ) آپ صرف نصیحت کرنے والے ہیں.",footnotes:345120:1
  88,22,"آپ کچھ ان پر داروغہ نہیں ہیں.",footnotes:345121:1
  88,23,"ہاں! جو شخص روگردانی کرے اور کفر کرے."
  88,24,"اسے اللہ تعالیٰ بہت بڑا عذاب دے گا.",footnotes:345122:1
  88,25,"بیشک ہماری طرف ان کا لوٹنا ہے."
  88,26,"پھر بیشک ہمارے ذمہ ہے ان سے حساب لینا.",footnotes:345123:1
