quran[6]{c,v,t}:
  114,1,"آپ کہہ دیجئے! کہ میں لوگوں کے پروردگار کی پناه میں آتا ہوں.",footnotes:345338:1
  114,2,"لوگوں کے مالک کی (اور).",footnotes:345339:1
  114,3,"لوگوں کے معبود کی (پناه میں).",footnotes:345340:1
  114,4,"وسوسہ ڈالنے والے پیچھے ہٹ جانے والے کے شر سے.",footnotes:345341:1
  114,5,"جو لوگوں کے سینوں میں وسوسہ ڈالتا ہے."
  114,6,"(خواه) وه جن میں سے ہو یا انسان میں سے.",footnotes:345342:1
