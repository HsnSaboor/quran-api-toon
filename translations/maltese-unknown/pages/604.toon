quran[15]{c,v,t}:
  112,1,"Għid (Muħammad): Huwa Alla wieħed"
  112,2,"Allalilejh kulħadd idur fil-ħtiega"
  112,3,"lajiledu lanqas jitwieled"
  112,4,"ubħalu ma għandu lil-ħaddi"
  113,1,"Għid (Muħammad): Nistkenn f'Sid is-sebħ"
  113,2,"mill-ħazen ta' dak li ħalaq"
  113,3,"mill-ħazen ta' dlam il-lejl meta jinfirex"
  113,4,"mill-ħazen ta' dawk (is-sħaħar) li jonfħu fl-għoqod"
  113,5,"umill-ħazen ta' l-għajjur meta jgħir"
  114,1,"Għid (Muħammad): Nistkenn f'Sid in-nies"
  114,2,"Sultan in-nies"
  114,3,"Alla tan-nies"
  114,4,"mill-ħazen tal-fesfies li (wara li jfes/es) dlonk jinħeba"
  114,5,"lijfesfes fi qlub in-nies"
  114,6,"(tfesfis gej) mill-ginn u min-nies (qarrieqa)"