quran[15]{c,v,t}:
  112,1,"Кажи [о, Мухаммед]: “Той е Аллах Единствения,"
  112,2,"Аллах e Вечен и от всички Търсен!"
  112,3,"Нито е раждал, нито е роден,"
  112,4,"и няма равен Нему.”"
  113,1,"Кажи: “Търся убежище при Повелителят на зората"
  113,2,"от злото на онова, което Той е създал,"
  113,3,"и от злото на тъмната нощ, когато тя настъпи,"
  113,4,"и от злото на духащи по възлите [магьосници],"
  113,5,"и от злото на завистник, когато той завижда!”"
  114,1,"Кажи: “Търся убежище при Повелителят на хората,"
  114,2,"Властелина на хората,"
  114,3,"Аллаха на хората,"
  114,4,"от злото на изкусителя, отстъпващия,"
  114,5,"който нашепва в гърдите на хората,"
  114,6,"от джиновете и от хората!”"