quran[29]{c,v,t}:
  81,1,"Rehefa tsy hisy fahazavana intsony ny masoandro,"
  81,2,"rehefa hanjavona ny famirapiratan'ireo kintana,"
  81,3,"rehefa hihetsika hiala amin'ny toerany ireo tendrombohitra,"
  81,4,"rehefa tsy raharahiana intsony ireo rameva akaiky hiteraka,"
  81,5,"rehefa tafavory ireo bibidia,"
  81,6,"rehefa manjary nirehitra ny ranomasina,"
  81,7,"rehefa voatambatra araka ny sokajiny avy ny fanahy,"
  81,8,"rehefa hanontaniana ireo zazavavy nalevim-belona hoe:"
  81,9,"mba fahotana inona loatra no antony namonoana azy?"
  81,10,"rehefa nampahalalana ireo takela-piraketana ny asa vita,"
  81,11,"rehefa voaesotra ny lanitra,"
  81,12,"rehefa haredareda ny afo,"
  81,13,"rehefa hampanantonina ny mpino ny Paradisa,"
  81,14,"dia samy hahafantatra ny nataony ny tsirairay avy!"
  81,15,"Tsia! Mianiana Aho amin'ireo andian-kintana."
  81,16,"Izay mandeha amin'ny lalana izorany ka indraindray mipoitra ary indraindray manjavona."
  81,17,"Sy amin'ny alina rehefa mandrakotra,"
  81,18,"ny maraina rehefa miposaka mitondra tsio-drivotra,"
  81,19,"tena marina, izany dia tenin'ilay iraka mendrika,"
  81,20,"izay matanjaka sy manan-danja lehibe eo anatrehan'ny tompon'ny fiandrianana,"
  81,21,"Mpakato izy sady itokisana,"
  81,22,"tsy marary saina velively akory ny sakaizanareo,"
  81,23,"izay efa nahita ny anjely Gabriela tokoa teny am-param-bodi-lanitra mazava."
  81,24,"Ary izy dia tsy kahihitra ka hitana ho azy irery ny faminaniana izay tonga taminy,"
  81,25,"izany dia tsy tenin'ilay demony izay voahozona!"
  81,26,"koa aiza ary no hombanareo,"
  81,27,"Tsy inona akory ity faminaniana ity afa-tsy fampahatsiahivana an'izao tontolo izao,"
  81,28,"Ho an'izay manam-paniriana ny hanaraka ny fahitsiana aminareo,"
  81,29,"Tsy hanam-pahefana ny amin'izany ianareo raha tsy sitrak'I Allah tompon'izao tontolo izao."