quran[27]{c,v,t}:
  95,1,"Mianiana Aho amin'ny aviavy sy ny hazon'oliva."
  95,2,"Sy amin'ny tendrombohitra Sinay."
  95,3,"Amin'ity tanàna mandry fahalemana ity."
  95,4,"Fa noharianay ho tonga lafatra tokoa ny olombelona."
  95,5,"Ary naverinay any amin'ny farany ambany indrindra."
  95,6,"afa-tsy izay nino sy nanao asa soa no tsy hitsahatra ka hahazo valisoa tsy manam-petra."
  95,7,"Koa raha izany ary, inona no andainganao ny Andro farany ?"
  95,8,"Moa tsy Allah va no mpitsara mendrika indrindra?"
  96,1,"Vakio amin'ny anaran'ny Tomponao ilay Nahary."
  96,2,"Nahary ny olombelona tamin'ny vongan-drà."
  96,3,"Vakio fa ny Tomponao dia be fitsimbinana."
  96,4,"Izay nampianatra tamin'ny alalan'ny penina."
  96,5,"Nampianatra ny olombelona ireo zavatra tsy fantany."
  96,6,"Tsia ! indrisy anefa fa mihoa-pefy tokoa ny olombelona."
  96,7,"Rehefa nahita ny tenany ho mahavita tena."
  96,8,"kanefa any amin'ny Tomponao tokoa no hiverenana."
  96,9,"Moa va hitanao ilay mandrara."
  96,10,"Ny mpanompo rehefa hivavaka ?"
  96,11,"Moa fantatrao va raha toa ka ao anatin'ny fahitsiana izy."
  96,12,"Na naniraka ho amin'ny fahatahorana an'I Allah."
  96,13,"Moa va hitanao raha tsy nino sy nandà izy?"
  96,14,"Ary moa va tsy fantany fa mahita azy tokoa Allah ?"
  96,15,"Tsia ! Raha tsy mijanona amin'zany izy dia hosintoniko eo amin'ny sangany !"
  96,16,"Dia ilay sangan'ny mpandainga sy mpanota !"
  96,17,"Ka tokony hiantso ireo mpiandany aminy izy."
  96,18,"Fa ho antsoiko ihany koa ireo Anjely mpiambina ny Afobe."
  96,19,"Tsia ! Aza mankàto azy ireo ianao fa miankohofa ary manatona Tompo Allah."