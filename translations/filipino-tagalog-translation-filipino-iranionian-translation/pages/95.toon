quran[8]{c,v,t}:
  95,1,"lbut ko Tin a go so Zayton,"
  95,2,"Go so Palao a Torsina,"
  95,3,"Go giyangkai a lngud a (Mak­ka a) Panarigan,"
  95,4,"Ka Sabunsabunar a Inadun Ami so Manosiya si-i ko lubi a mapiya a bontal,"
  95,5,"Oriyan niyan na Pakakasowin Ami sukaniyan ko lubi a mababa ko manga bababa,"
  95,6,"Inonta so Miyamaratiyaya go Pinggalubuk iran so manga Pipiya: Ka adun a bagiyan niran a balas a di Puthaman."
  95,7,"Na antawa-a i Maphaki ongkir iyan Ruka ko oriyan naya, so Ko­koman?"
  95,8,"Ba di so Allah i lubi a Maontol i Kokoman ko manga Kokoman?"
