quran[21]{c,v,t,f}:
  88,22,"Ma tihid adigu mid qasab ku leh."
  88,23,"Qofkiise (Xaqa) ka jeesada oo gaalooba;"
  88,24,"Wuxuu Alle ku cadaabi cadaab aad u weyn."
  89,19,"Waxaad cuntaan dhaxalka cunid xaqdarro ah."
  89,20,"Oo aad jeceshihiin Maalka jaceyl daran."
  89,21,"Mayee! Marka dhulka laga dhigo budo,"
  90,13,"Waa addoon la xoreeyo."
  90,14,"Ama siinta cunno maalin gaajo (abaar) jirto."
  90,15,"Agoon kuu dhow."
  91,10,"Waxaa khasaari qofka xumeeya naftiisa."
  91,11,"Thamuud waxay beeniyeen (Xaqa) kibirkoodii darti."
  91,12,"Markuu soo baxay koodii uga sharka badnaa (si uu hasha u dilo)."
  92,7,"Waxaan u fududeyneynaa jidka fudud (Islaamka)."
  92,8,"Qofkiise ku bakheyla (maalka) oo isu arka mid deeqtoon (iskibriya)."
  92,9,"Oo beeniya tan wanaagga badan ee fiican (Jannada)."
  93,4,"Aakhiro baa kaaga khayr badan noloshatan (hore ee adduunka)."
  93,5,"Rabbigaa baa ku siin (khayr badan), waadna raalli noqon."
  93,6,"Miyuusan ku helin adigoo agoon ah oo ku hoyaadin?"
  94,1,"Miyaanaan kuu waasicinnin (Nabi Muxammadow) laabtaada?"
  94,2,"Oo sidaa kaaga dejin culeyskii ku saarnaa{2},"
  94,3,"Kaasoo cusleeyey dhabarkaaga,"