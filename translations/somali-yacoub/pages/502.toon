quran[19]{c,v,t,f}:
  79,46,"Maalinta ay arkayaan waxay ahaan sida inaysan ku negaadin (adduunka) waxaan ahayn galab ama barqadeed."
  83,31,"Markay u laabtaanna ehelkooda waxay laaban jireen iyagoo ku maaweeleysanaya,"
  83,32,"Markay arkaan (mu'miniinta) waxay odhan jireen: Kuwakanu waa kuwo lunsan."
  83,33,"Ma loo dirsan inay gaar ka hayaan iyo ilaalo (mu’miniinta) dushooda."
  87,16,"Waxaadse door biddaan nolosha adduunkan;"
  87,17,"Aakhiro baase khayr badan oo baaqi ah."
  87,18,"Hubaal (hadal)kani wuxuu ku yaal Kututbtii hore,"
  88,13,"Iyo sariirro la kor yeelay."
  88,14,"Iyo koobab diyaar laga dhigay."
  88,15,"Iyo barkimooyin la safay."
  89,10,"Iyo (siduu u galay) Fircoon, ee lahaa (Boqortooyada iyo ciidammada tirada badan iyo dhismooyin dhaadheer iyo) tiirar ( xabsiyo la geeyo dadka oo lagu caddibo)?"
  89,11,"Kuwaasoo ku xadgudbay dhulka."
  89,12,"Oo ku badiyey fasahaad dhexdeeda?"
  90,4,"Waxaan abuurnay aadmiga isagoo dhib iyo howl (kala kulmi nolosha adduunka)."
  90,5,"Ma wuxuu moodaa inaysan cidna awood ku dul lahayn?"
  90,6,"Wuxuu leeyahay (isagoo ku faani): Waxaan lumiyey maal tiro badan."
  91,1,"Waxaan (waa Alle'e) ku dhaartay qorraxda iyo caddaanta barqadeeda;"
  91,2,"Iyo dayaxa markuu raaco (qorraxda)."
  91,3,"Iyo maalinta markay muujiso (arlada) oo ifiso."
