quran[23]{c,v,t,f}:
  88,25,"Hubaal waa Xaggayaga meel noqodkoodu;"
  88,26,"Markaas hubaal Annagay na saaran tahay xisaabintooda."
  89,22,"Oo (Allaah) Rabbigaa yimaado iyo (sidoo kale) malaa’igta oo saf saf ah."
  89,23,"Oo la keeno Maalintaas Naarta. Maalintaas buu Aadmigu (gaalku) waansami, maxayse waantoobidda (markaa) u tari?"
  89,24,"Wuxuu odhan: Alla haddaan u soo hormarsan lahaa wanaag noloshaydatan (Aakhirada)."
  90,16,"Ama miskiin dhulka yaal."
  90,17,"Haddana ka mid ah kuwa (Xaqa) rumeeyey, oo iskula dardaarma sugnaanta iyo samirka, oo (sidoo kale) iskula dardaarma naxariista (iyo is jeclaanta)."
  90,18,"Waa kuwaas qolada Midigta (Jannada)."
  91,13,"Markaasuu Rasuulkii Alle (Nabi Saalix) ku yidhi : Iska daaya Hasha Ilaahay (ha dilana) oo siiya waraabkeeda."
  91,14,"Wayse beeniyeen oo boqna gooyeen hashii (dileen). Markaasuu Rabbigood u baabbi’yey denbigoodii dartiis, oo dhulka la simay (ama ka wada simay ciqaabkii)."
  91,15,"Kama uuna cabsado cidhibteeda ( cidhibta kuwa uu halaagay oo wax loo soo raacdo ama looga daba yimaado, waayo waa Adkaadaha aan laga adkaan)."
  92,10,"Waxaan u fududeyneynaa jidka xun (dhabbaha Naarta);"
  92,11,"Maalkiisu wax uma taro markuu halaagsamo."
  92,12,"Annagaa (Alle ah) wax hanuuninna,"
  93,7,"Oo ku helin adigoo habowsan oo kuma hanuunin?"
  93,8,"Oo ku helin adigoo caydh ah oo kuma hodmin?"
  93,9,"Ee agoon, ha dhibin."
  94,4,"Oo aanaan kor yeelin meeqaankaaga?"
  94,5,"Dhibka waxaa la socda faraj."
  94,6,"Waxaa dhibka la socda faraj."
  95,1,"Waxaan (waa Alle'e) ku dhaartay Tiinka iyo Zaytuunka.",1:[Waana tilmaan sidoo kale halkay ka baxaan ee Falastiin ee ah halka laga soo saaray Ciise c.s. Nabi ahaan.],2:[]
  95,2,"Iyo Buurta Siinaay96496>1.",1:[. Ee ah halkuu Alle kula hadlay Muuse c.s.],2:[]
  95,3,"Iyo magaaladan Aaminka ah (Makkah){1},",1:[. Ee Nabi Muxammad laga soo doortay Rasuul Alle ahaan.],2:[]
