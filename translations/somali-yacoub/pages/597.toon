quran[27]{c,v,t,f}:
  95,1,"Waxaan (waa Alle'e) ku dhaartay Tiinka iyo Zaytuunka<sup foot_note="337746">{1}</sup>.",footnotes:1:Waana tilmaan sidoo kale halkay ka baxaan ee Falastiin ee ah halka laga soo saaray Ciise c.s. Nabi ahaan.|337747:
  95,2,"Iyo Buurta Siinaay<sup foot_note="&lt;sup">2</sup>96496&gt;1.",footnotes:337748:. Ee ah halkuu Alle kula hadlay Muuse c.s.|337749:
  95,3,"Iyo magaaladan Aaminka ah (Makkah){2},",footnotes:2:. Ee Nabi Muxammad laga soo doortay Rasuul Alle ahaan.|337751:
  95,4,"Waxaan u abuurnay Aadmiga qaab kan u wanaagsan."
  95,5,"Misna waxaan u celinnay hooseeyayaasha kan u hooseeya{3}.",footnotes:337752:. Naarta gudaheeda ama da'da asaasqnimada.|337753:
  95,6,"Kuwase (Xaqa) rumeeya oo samaha fala, waxay leeyihiin jar aan weligi go’ynin (Janno)."
  95,7,"Maxaa kugu xamaabri (aadmigow) inaad beeniso arrinka is abaal marinta (Aakhiro)?"
  95,8,"Sow ma aha Alle Kan u wanaagsan inta wax xukunta? (Haayoo, wuu Yahay)."
  96,1,"Ku akhri Magaca (Alle) Rabbigaa, ee abuuray (wax waliba)."
  96,2,"Ka abuuray aadmiga xinjir."
  96,3,"Akhri! Rabbigaa waa Sharaf Badnaha,"
  96,4,"(Dadka) baray sida wax loogu qoro qalinka."
  96,5,"Baray Aadmiga wax uusan aqoon."
  96,6,"Mayee! Aadmigu (kan gaalka ahi) wuu xadgudbaa oo kibraa."
  96,7,"Markuu isku ogaado Hodantinnimo iyo deeqtoonaan."
  96,8,"Hubaal! Waa xagga (Alle) Rabbigaa noqodku."
  96,9,"Ka warran midka ka reeba."
  96,10,"Addoon (Alle) oo tukan salaad?"
  96,11,"Bal ka warran hadduu ku sugan yahay (addoonkaa) jid toosan?"
  96,12,"Amaba uu amro Alle ka cabsiga iyo xume ka dhowrsiga?"
  96,13,"Bal ka warran hadduu kaasina (gaalka ahi) beeniyo Xaqa, kana jeesado?"
  96,14,"Mawuusan ogeyn in Alle arko?"
  96,15,"Mayee! Haddii uusan meel joogin, waxaanu hubaal qaban foodda,"
  96,16,"Food beenley ah oo gefley ah."
  96,17,"Ha u yeedho golihiisa."
  96,18,"Waxaanu u yeedhi malaa’ig daran."
  96,19,"Mayee, ha adeecin oo sujuud, una dhowow (Alle)."