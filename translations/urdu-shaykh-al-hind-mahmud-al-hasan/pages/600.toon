translation[21]{c,v,t}:
100,10,"اور تحقیق ہووے جو کچھ کہ جیوں میں ہے {8}"
100,11,"بیشک اُنکے رب کو اُنکی اُس دن سب خبر ہے {9}"
101,1,وہ کھڑکھڑا ڈالنے والی
101,2,کیا ہے وہ کھڑ کھڑا ڈالنے والی
101,3,"اور تو کیا سمجھا کیا ہے وہ کھڑ کھڑا ڈالنے والی {1}"
101,4,"جس دن ہوویں لوگ جیسے پتنگے بکھرے ہوئے {2}"
101,5,"اور ہوویں پہاڑ جیسے رنگی ہوئی اون دُھنی ہوئی {3}"
101,6,سو جسکی بھاری ہوئیں تولیں
101,7,"تو وہ رہے گا من مانتے گذران میں {4}"
101,8,اور جسکی ہلکی ہوئیں تولیں
101,9,تو اُس کا ٹھکانہ گڑھا ہے
101,10,اور تو کیا سمجھا وہ کیا ہے
101,11,"آگ ہے دہکتی ہوئی {5}"
102,1,غفلت میں رکھا تم کو بہتایت کی حرص نے
102,2,"یہاں تک کہ جا دیکھیں قبریں {1}"
102,3,کوئی نہیں آگے جان لو گے
102,4,"پھر بھی کوئی نہیں آگے جان لو گے {2}"
102,5,"کوئی نہیں اگر جانو تم یقین کر کے {3}"
102,6,بیشک تم کو دیکھنا ہے دوزخ
102,7,"پھر دیکھنا ہے اُسکو یقین کی آنکھ سے {4}"
102,8,"پھر پوچھیں گے تم سے اُس دن آرام کی حقیقت {5}"
