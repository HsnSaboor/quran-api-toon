quran[7]{c,v,t}:
1,1,"اللہ کے نام سے شروع جو نہایت مہربان ہمیشہ رحم فرمانے والا ہے"
1,2,"سب تعریفیں اللہ کے لئے ہیں جو پالنے والا سارے جہان کا"
1,3,بےحد مہربان نہایت رحم والا
1,4,"مالک روز جزا کا"
1,5,"تیری ہی ہم بندگی کرتے ہیں اور تجھی سے مدد چاہتے ہیں"
1,6,بتلا ہم کو راہ سیدھی
1,7,"راہ ان لوگوں کی جن پر تو نے فضل فرمایا جن پر نہ تیرا غصہ ہوا اور نہ وہ گمراہ ہوئے"
