translation[27]{c,v,t}:
89,24,"کہے کیا اچھا ہوتا جو میں کچھ آگے بھیجدیتا اپنی زندگی میں {21}"
89,25,پھر اُس دن عذاب نہ دے اُس کا سا کوئی
89,26,"اور نہ باندھ کر رکھے اُس کا سا باندھنا کوئی {22}"
89,27,اے وہ جی جس نے چین پکڑ لیا
89,28,پھر چل اپنے رب کی طرف تو اس سے راضی وہ تجھ سے راضی
89,29,پھر شامل ہو میرے بندوں میں
89,30,"اور داخل ہو میری بہشت میں {23}"
90,1,"قسم کھاتا ہوں میں اس شہر کی {1}"
90,2,"اور تجھ پر قید نہیں رہے گی اس شہر میں {2}"
90,3,"اور قسم ہے جنتے کی اور جو اس نے جنا {3}"
90,4,"تحقیق ہم نے بنایا آدمی کو محنت میں {4}"
90,5,"کیا خیال رکھتا ہے وہ کہ اُس پر بس نہ چلے گا کسی کا {5}"
90,6,"کہتا ہے میں نے خرچ کر ڈالا مال ڈھیروں {6}"
90,7,"کیا خیال رکھتا ہے کہ دیکھا نہیں اسکو کسی نے {7}"
90,8,"بھلا ہم نے نہیں دیں اُسکو دو آنکھیں {8}"
90,9,"اور زبان اور دو ہونٹ {9}"
90,10,"اور دکھلا دیں اُسکو دو گھاٹیاں {10}"
90,11,"سو نہ دھمک سکا گھاٹی پر {11}"
90,12,اور توکیا سمجھا کیا ہے وہ گھاٹی
90,13,"چھڑانا گردن کا {12}"
90,14,"یا کھلانا بھوک کے دن میں {13}"
90,15,"یتیم کو جو قرابت والا ہے {14}"
90,16,"یا محتاج کو جو خاک میں رل رہا ہے {15}"
90,17,"پھر ہووے ایمان والوں میں {16} جو تاکید کرتے ہیں آپس میں تحمل کی اور تاکید کرتے ہیں رحم کھانے کی {17}"
90,18,"وہ لوگ ہیں بڑے نصیب والے {18}"
90,19,"اور جو منکر ہوئے ہماری آیتوں سے وہ ہیں کمبختی والے {19}"
90,20,"اُنہی کو آگ میں موند دیا ہے {20}"
