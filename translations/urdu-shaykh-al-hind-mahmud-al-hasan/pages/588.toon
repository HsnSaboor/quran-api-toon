translation[28]{c,v,t}:
83,7,"ہر گز نہیں {4} بیشک اعمالنامہ گنہگاروں کا سجین میں ہے"
83,8,اور تجھ کو کیا خبر ہے کیا ہے سجین
83,9,"ایک دفتر ہے لکھا ہوا {5}"
83,10,خرابی ہے اُس دن جھٹلانے والوں کی
83,11,جو جھوٹ جانتے ہیں انصاف کے دن کو
83,12,"اور اسکو جھٹلاتا ہے وہی جو بڑھ نکلنے والا گنہگار ہے {6}"
83,13,"جب سنائے اسکو ہماری آیتیں کہے نقلیں ہیں پہلوں کی {7}"
83,14,"کوئی نہیں پر زنگ پکڑ گیا ہے اُنکے دلوں پر جو وہ کماتے تھے {8}"
83,15,"کوئی نہیں وہ اپنے رب سے اُس دن روک دیے جائیں گے {9}"
83,16,پھر مقرر وہ گرنے والے ہیں دوزخ میں
83,17,پھر کہا جائے گا یہ وہی ہے جسکو تم جھوٹ جانتے تھے
83,18,"ہرگز نہیں {10} بیشک اعمالنامہ نیکوں کاعلیین میں ہے"
83,19,اور تجھ کو کیاخبر ہے کیا ہے علیین
83,20,"ایک دفتر ہے لکھا ہوا {11}"
83,21,"اُسکو دیکھتے ہیں نزدیک والے یعنی فرشتے {12}"
83,22,بیشک نیک لوگ ہیں آرام میں
83,23,"تختوں پر بیٹھے دیکھتے ہوں گے {13}"
83,24,"پہچان لے تو اُنکے منہ پر تازگی آرام کی {14}"
83,25,"انکو پلائی جاتی ہے شراب خالص مہر لگی ہوئی {15}"
83,26,"جسکی مہر جمتی ہے مشک پر {16} اور اُس پر چاہیے کہ ڈھکیں ڈھکنے والے {17}"
83,27,اور اُسکی ملونی ہے تسنیم سے
83,28,"وہ ایک چشمہ ہے جس سے پیتے ہیں نزدیک والے {18}"
83,29,"وہ لوگ جو گنہگار ہیں تھے ایمان والوں سے ہنسا کرتے {19}"
83,30,"اور جب ہو کر نکلتے انکے پاس کو تو آپس میں آنکھ مارتے {20}"
83,31,"اور جب پھر کر جاتے اپنے گھر پھر جاتے باتیں بناتے {21}"
83,32,"اور جب اُنکو دیکھتے کہتے بیشک یہ لوگ بہک رہے ہیں {22}"
83,33,"اور اُنکو بھیجا نہیں اُن پر نگہبان بنا کر {23}"
83,34,"سو آج ایمان والے منکروں سے ہنستے ہیں {24}"
