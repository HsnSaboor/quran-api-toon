quran[26]{c,v,t}:
53,1,"قسم ہے تارے کی جب گرے {1}"
53,2,"بہکا نہیں تمہارا رفیق اور نہ بے راہ چلا {2}"
53,3,اور نہیں بولتا اپنے نفس کی خواہش سے
53,4,"یہ تو حکم ہے بھیجا ہوا {3}"
53,5,"اُسکو سکھلایا ہے سخت قوتوں والے نے زورآور نے {4}"
53,6,پھر سیدھا بیٹھا
53,7,"اور وہ تھا اُونچے کنارے پر آسمان کے {5}"
53,8,پھر نزدیک ہوا اور لٹک آیا
53,9,پھر رہ گیا فرق دو کمان کی برابر یا اس سے بھی نزدیک
53,10,"پھر حکم بھیجا اللہ نے اپنے بندہ پر جو بھیجا {6}"
53,11,"جھوٹ نہیں کہا رسول کے دل نے جو دیکھا {7}"
53,12,"اب کیا تم اُس سے جھگڑتے ہو اُس پر جو اُس نے دیکھا {18}"
53,13,اور اُسکو اُس نے دیکھا ہے اترتے ہوئے ایک بار اور بھی
53,14,سدرۃ المنتہٰی کے پاس
53,15,"اُس کے پاس ہے بہشت آرام سے رہنے کی {9}"
53,16,"جب چھا رہا تھا اُس بیری پر جو کچھ چھا رہا تھا {10}"
53,17,"بہکی نہیں نگاہ اور نہ حد سے بڑھی {11}"
53,18,"بیشک دیکھے اُس نے اپنے رب کے بڑے نمونے {12}"
53,19,بھلا دیکھو تو لات اور عزّیٰ کو
53,20,"اور منات تیسرے پچھلے کو {13}"
53,21,کیا تم کو تو ملے بیٹے اور اُسکو بیٹیاں
53,22,"یہ بانٹا تو بہت بھونڈا {14}"
53,23,"یہ سب نام ہیں جو رکھ لئے ہیں تم نے اور تمہارے باپ دادوں نے اللہ نے نہیں اتاری اُنکی کوئی سند {15} محض اٹکل پرچلتے ہیں اور جو جیوں کی امنگ ہے اور پہنچی ہے اُنکو اُنکے رب سے راہ کی سوجھ {16}"
53,24,کہیں آدمی کو ملتا ہے جوکچھ چاہے
53,25,"سو اللہ کے ہاتھ ہے سب بھلائی پچھلی اور پہلی {17}"
53,26,"اور بہت فرشتے ہیں آسمانوں میں کچھ کام نہیں آتی اُنکی سفارش مگر جب حکم دے اللہ جسکے واسطے چاہے اور پسند کرے {18}"
