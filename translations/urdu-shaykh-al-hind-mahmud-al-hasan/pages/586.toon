translation[29]{c,v,t}:
81,1,"جب سورج کی دھوپ تہہ ہو جائے {1}"
81,2,"اور جب تارے میلے ہو جائیں {2}"
81,3,"اور جب پہاڑ چلائے جائیں {3}"
81,4,"اور جب بیاتی اونٹنیاں چھٹی پھریں {4}"
81,5,"اور جب جنگل کے جانوروں میں رول پڑ جائے {5}"
81,6,"اور جب دریا جھونکے جائیں {6}"
81,7,"اور جب جیوں کے جوڑے باندھے جائیں {7}"
81,8,اور جب بیٹی جیتی گاڑ دی گئ کو پوچھیں
81,9,"کہ کس گناہ پر وہ ماری گئ {8}"
81,10,اور جب اعمالنامے کھولے جائیں
81,11,"اور جب آسمان کا پوست اتار لیں {9}"
81,12,اور جب دوزخ دہکائی جائے
81,13,"اور جب بہشت پاس لائی جائے {10}"
81,14,"جان لے گا ہر ایک جی جو لے کر آیا {11}"
81,15,سو قسم کھاتا ہوں میں پیچھے ہٹ جانے والوں
81,16,"سیدھے چلنے دبک جانے والوں کی {12}"
81,17,"اور رات کی جب پھیل جائے {13}"
81,18,"اور صبح کی جب دم بھرے {14}"
81,19,مقرر یہ کہا ہے ایک بھیجے ہوئے عزت والے کا
81,20,قوت والا عرش کے مالک کے پاس درجہ پانے والا
81,21,"سب کا مانا ہوا وہاں کا معتبر {15}"
81,22,"اور یہ تمہارا رفیق کچھ دیوانہ نہیں {16}"
81,23,"اور اس نے دیکھا ہے اُس فرشتہ کو آسمان کے کھلے کنارہ کے پاس {17}"
81,24,"اور یہ غیب کی بات بتانے میں بخیل نہیں {18}"
81,25,"اور یہ کہا ہوا نہیں کسی شیطان مردود کا {19}"
81,26,"پھر تم کدھر چلے جا رہے ہو {20}"
81,27,"یہ تو ایک نصیحت ہے جہان بھر کے واسطے {21}"
81,28,"جو کوئی چاہے تم میں سے کہ سیدھا چلے {22}"
81,29,"اور تم جبھی چاہو کہ چاہے اللہ سارے جہان کا مالک {23}"
