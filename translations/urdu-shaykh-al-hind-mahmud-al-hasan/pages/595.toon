translation[29]{c,v,t}:
91,1,قسم سورج اور اُسکے دھوپ چڑھنے کی
91,2,"اور چاند کی جب آئے سورج کے پیچھے {1}"
91,3,"اور دن کی جب اُسکو روشن کر لے {2}"
91,4,"اور رات کی جب اسکو ڈھانک لیوے {3}"
91,5,"اور آسمان کی اور جیسا کہ اُسکو بنایا {4}"
91,6,"اور زمین کی اور جیسا کہ اُسکو پھیلایا {5}"
91,7,"اور جی کی اور جیسا کہ اُسکو ٹھیک بنایا {6}"
91,8,"پھر سمجھ دی اُسکو ڈھٹائی کی اور بچ کر چلنے کی {7}"
91,9,"تحقیق مراد کو پہنچا جس نے اُسکو سنوار لیا {8}"
91,10,"اور نامراد ہوا جس نے اُسکو خاک میں ملا چھوڑا {9}"
91,11,"جھٹلایا ثمود نے اپنی شرارت سے [۰ا]"
91,12,"جب اٹھ کھڑا ہوا اُن میں کا بڑ ابدبخت {11}"
91,13,"پھر کہاں اُنکو اللہ کے رسول نے خبردار ہو اللہ کی اونٹنی سے اور اُسکی پانی پینے کی باری سے {12}"
91,14,"پھر انہوں نے اُسکو جھٹلایا پھر پاؤں کاٹ ڈالے اُسکے پھر الٹ مارا اُن پر اُنکے رب نے بسبب اُنکے گناہوں کے پھر برابر کر دیا سب کو {13}"
91,15,"اور وہ نہیں ڈرتا پیچھا کرنے سے {14}"
92,1,قسم رات کی جب چھا جائے
92,2,اور دن کی جب روشن ہو
92,3,اور اُسکی جو اُس نے پیدا کئے نر اور مادہ
92,4,"تمہاری کمائی طرح طرح پر ہے {1}"
92,5,سو جس نے دیا اور ڈرتا رہا
92,6,اور سچ جانا بھلی بات کو
92,7,"تو اُسکو ہم سہج سہج پہنچا دیں گے آسانی میں {2}"
92,8,اور جس نے نہ دیا اور بے پروا رہا
92,9,اور جھوٹ جانا بھلی بات کو
92,10,"سو اُسکو ہم سہج سہج پہنچا دیں گے سختی میں {3}"
92,11,"اور کام نہ آئے گا اُسکے مال اُس کا جب گڑھے میں گرے گا {4}"
92,12,ہمارا ذمہ ہے راہ سجھا دینا
92,13,"اور ہمارے ہاتھ میں ہے آخرت اور دنیا {5}"
92,14,"سو میں نے سنا دی تم کو خبر ایک بھڑکتی ہوئی آگ کی {6}"
