translation[25]{c,v,t}:
78,31,بیشک ڈر والوں کو اُنکی مراد ملنی ہے
78,32,باغ ہیں اور انگور
78,33,"اور نوجوان عورتیں ایک عمر کی سب {24}"
78,34,"اور پیالے چھلکتے ہوئے {25}"
78,35,"نہ سنیں گے وہاں بک بک اور نہ مکرانا {26}"
78,36,"بدلا ہے تیرے رب کا دیا ہوا حساب سے {27}"
78,37,"جو رب ہے آسمانوں کا اور زمین کا اور جو کچھ اُنکے بیچ میں ہے بڑی رحمت والا {28} قدرت نہیں کہ کوئی اُس سے بات کرے {29}"
78,38,"جس دن کھڑی ہو روح اور فرشتے قطار باندھ کر {30} کوئی نہیں بولتا مگر جس کو حکم دیا رحمٰن نے اور بولا بات ٹھیک {31}"
78,39,"وہ دن ہے برحق پھر جو کوئی چاہے بنا رکھے اپنے رب کے پاس ٹھکانا {32}"
78,40,"ہم نے خبر سنا دی تم کو ایک آفت نزدیک آنے والی کی جس دن دیکھ لے گا آدمی جو آگے بھیجا اُسکے ہاتھوں نے {33} اور کہے گا کافر کسی طرح میں مٹی ہوتا {34}"
79,1,"قسم ہے گھسیٹ لانے والوں کی غوطہ لگا کر {1}"
79,2,"اور بند چھڑا دینے والوں کی کھول کر {2}"
79,3,اور پیرنے والوں کی تیزی سے
79,4,"پھر آگے بڑھنے والوں کی دوڑ کر {3}"
79,5,"پھر کام بنانے والوں کی حکم سے {4}"
79,6,"جس دن کانپے کانپنے والی {5}"
79,7,"اُسکے پیچھے آئے دوسری {6}"
79,8,کتنے دل اُس دن دھڑکتے ہیں
79,9,"اُنکی آنکھیں جھک رہی ہیں {7}"
79,10,لوگ کہتے ہیں کیا ہم پھر آئیں گے الٹے پاؤں
79,11,کیا جب ہم ہو چکیں ہڈیاں کھوکھری
79,12,"بولے تو تو یہ پھر آنا ہے ٹوٹے کا {8}"
79,13,سو وہ تو صرف ایک جھڑکی ہے
79,14,"پھر تبھی وہ آ رہیں میدان میں {9}"
79,15,"کیا پہنچی ہے تجھ کو بات موسٰی کی {10}"
