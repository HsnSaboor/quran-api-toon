translation[2]{c,v,t}:
  83,35,"تختوں پر بیٹھے دیکھتے ہیں [۲۵]"
  83,36,"اب بدلا پایا ہے منکروں نے جیسا کہ کچھ کرتے تھے [۲۶]"
  84,1,"جب  آسمان پھٹ جائے"
  84,2,"اور سن لے حکم اپنے رب کا وہ آسمان اسی لائق ہے{1}"
  84,3,"اور جب زمین پھیلا دی جائے{1}"
  84,4,"اور نکال ڈالے جو کچھ اُس میں ہے اور خالی ہو جائے{1}"
  84,5,"اور سن لے حکم اپنے رب کا اور وہ زمین اسی لائق ہے{1}"
  84,6,"اے آدمی تجھ کو تکلیف اٹھانی ہے اپنے رب تک پہنچنے میں سہہ سہہ کر اُس سے ملنا ہے{1}"
  84,7,"سو جس کو ملا اعمالنامہ اس کا داہنے ہاتھ میں"
  84,8,"تو اُس سے حساب لیں گے آسان حساب{1}"
  84,9,"اور پھر کر آئے گا اپنے لوگوں کے پاس خوش ہو کر{1}"
  84,10,"اور جس کو ملا اس کا اعمالنامہ پیٹھ کے پیچھے سے{1}"
  84,11,"سو وہ پکارے گا موت موت{1}"
  84,12,"اور پڑے گا  آگ میں"
  84,13,"وہ رہا تھا اپنے گھر میں بے غم{1}"
  84,14,"اُس نے خیال کیا تھا کہ پھر کر نہ جائے گا{1}"
  84,15,"کیوں نہیں اُس کا رب اُسکو دیکھتا تھا{1}"
  84,16,"سو قسم کھاتا ہوں شام کی سرخی کی"
  84,17,"اور رات کی اور جو چیزیں اُس میں سمٹ آتی ہیں{1}"
  84,18,"اور چاند کی جب پورا بھر جائے{1}"
  84,19,"کہ تم کو  چڑھنا ہے سیڑھی پر سیڑھی{1}"
  84,20,"پھر کیا ہوا ہے اُنکو جو یقین نہیں لاتے{1}"
  84,21,"اور جب پڑھیے انکے پا س قرآن مجید وہ سجدہ نہیں کرتے{1}"
  84,22,"اوپر سے اور یہ کہ منکر جھٹلاتے ہیں"
  84,23,"اور اللہ خوب جانتا ہے جو اندر بھر رکھتے ہیں{1}"
  84,24,"سو خوشی سنا دے اُنکو عذاب دردناک کی{1}"
  84,25,"مگر جو لوگ کہ یقین لائے اور کام کئے بھلے اُنکے لئے ثواب ہے بے انتہا{1}"
