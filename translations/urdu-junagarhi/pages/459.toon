quran[21]{c,v,t,f}:
  53,52,"اور اس سے پہلے قوم نوح کو، یقیناً وه بڑے ﻇالم اور سرکش تھے."
  53,53,"اور مؤتفکہ (شہر یا الٹی ہوئی بستیوں کو) اسی نے الٹ دیا.{1}.",footnotes:1:[اس سےمراد حضرت لوط (عليه السلام) کی بستیاں ہیں، جن کو ان پر الٹ دیا گیا۔]
  53,54,"پھر اس پر چھا دیا جو چھایا.{1}.",footnotes:1:[یعنی اس کے بعد ان پر پتھروں کی بارش ہوئی۔]
  54,43,"(اے قریشیو!) کیا تمہارے کافر ان کافروں سے کچھ بہتر ہیں{1}؟ یا تمہارے لیے اگلی کتابوں میں چھٹکارا لکھا ہوا ہے؟{2}",footnotes:1:[یہ استفہام انکار یعنی نفی کے لیے ہے۔ یعنی اے اہل عرب ! تمہارے کافر، گزشتہ کافروں سے، بہتر نہیں ہیں، جب وہ اپنے کفر کی وجہ سے ہلاک کر دیئے گئے، تو تم جب کہ تم ان سے بدتر ہو، عذاب سے سلامتی کی امید کیوں رکھتے ہو؟,],footnotes:2:[- زُبُرٌ سے مراد گزشتہ انبیا پرنازل شدہ کتابیں ہیں۔ یعنی کیا تمہاری بابت کتب منزلہ میں صراحت کر دی گئی ہے کہ یہ قریش یا عرب،جو مرضی کرتے رہیں، ان پر غالب نہیں آئے گا۔]
  54,44,"یا یہ کہتے ہیں کہ ہم غلبہ پانے والی جماعت ہیں.{1}.",footnotes:1:[تعداد کی کثرت اور وسائل قوت کی وجہ سے، کسی اور کا ہم پر غالب آنے کا امکان نہیں۔ یا مطلب ہے کہ ہمارا معاملہ مجتمع ہے، ہم دشمن سے انتقام لینے پرقادر ہیں۔]
  54,45,"عنقریب یہ جماعت شکست دی جائےگی اور پیٹھ دے کر بھاگے گی.{1}.",footnotes:1:[اللہ نے ان کے زعم باطل کی تردید فرمائی، جماعت سے مراد کفار مکہ ہیں۔ چنانچہ بدر میں انہیں شکست ہوئی اور یہ پیٹھ دےکربھاگے، روسائے شرک اور اساطین کفر ہلاک کردیئے گئے۔ جنگ بدر کے موقعے پرجب نبی ﹲ نہایت الحاح وزاری سے اپنے خیمے میں مصروف دعا تھےتو حضرت ابوبکر (رضي الله عنه) نے فرمایا «حَسْبُكَ يَا رَسُولَ اللهِ! أَلْحَحْتَ عَلَى رَبِّكَ»۔ بس کیجئے! اللہ کے رسول ! آپ نے رب کے سامنے بہت الحاح وزاری کرلی۔ چنانچہ آپ صلی اللہ علیہ وسلم خیمے سے باہر تشریف لائے تو آپ کی زبان مبارک پر یہی آیت تھی۔ (البخاري، تفسير سورة اقتربت الساعة)۔]
  55,37,"پس جب کہ آسمان پھٹ کر سرخ ہو جائے جیسے کہ سرخ چمڑه.{1}.",footnotes:1:[قیامت والے دن آسمان پھٹ پڑے گا، فرشتے زمین پر اترآئیں گے، اس دن یہ نار جہنم کی شدت حرارت سے پگھل کر سرخ نری کے چمڑے کر طرح ہو جائے گا۔ دِهَانٌ ،سرخ چمڑہ۔]
  55,38,"پس تم اپنے رب کی کس کس نعمت کو جھٹلاؤ گے؟"
  55,39,"اس دن کسی انسان اورکسی جن سے اس کے گناہوں کی پرسش نہ کی جائے گی.{1}.",footnotes:1:[یعنی جس وقت وہ قبروں سےباہر نکلیں گے۔ ورنہ بعد میں موقف حساب میں ان سے باز پرس کی جائے گی۔ بعض نے اس کا مطلب یہ بیان کیا ہے کہ گناہوں کی بابت نہیں پوچھا جائے گا، کیونکہ ان کا تو پورا ریکارڈ فرشتوں کے پاس بھی ہوگا اور اللہ کے علم میں بھی۔ البتہ پوچھا جائے گا کہ تم نے یہ کیوں کیے؟ یا یہ مطلب ہے، ان سے نہیں پوچھا جائے گا بلکہ انسانی اعضا خودبول کر ہر بات بتلائیں گے۔]
  56,28,"وه بغیرکانٹوں کی بیریوں."
  56,29,"اور تہ بہ تہ کیلوں."
  56,30,"اور لمبے لمبے سایوں.{1}.",footnotes:1:[جیسے ایک حدیث میں ہے کہ (جنت کے ایک درخت کے سائے تلے ایک گھوڑ سوار سو سال تک چلتا رہے گا، تب بھی، وہ سایہ ختم نہیں ہوگا)۔ (صحيح بخاري، تفسير سورة الواقعة ، مسلم ، كتاب الجنة ، باب إن في الجنة شجرة....)۔]
  57,19,"اللہ اوراس کے رسول پر جو ایمان رکھتے ہیں وہی لوگ اپنے رب کے نزدیک صدیق{1} اور شہید ہیں ان کے لیے ان کا اجر اور ان کا نور ہے، اور جو لوگ کفر کرتے ہیں اور ہماری آیتوں کوجھٹلاتے ہیں وه جہنمی ہیں..",footnotes:1:[بعض مفسرین نے یہاں وقف کیا ہے۔ اور آگے وَالشُّهَدَاءُ کو الگ جملہ قرار دیا ہے صدیقیت کمال ایمان اور کمال صدق و صفا کا نام ہے۔ حدیث میں آتا ہے کہ (آدمی ہمیشہ سچ بولتا ہے اور سچ ہی کی تلاش اور کوشش میں رہتا ہے۔ حتیٰ کہ اللہ کے ہاں اسے صدیق لکھ دیا جاتا ہے (متفق عليه ، مشكاة ، كتاب الآداب ، باب حفظ اللسان) ایک اور حدیث میں صدیقین کا وہ مقام بیان کیا گیا ہے جو جنت میں انہیں حاصل ہوگا۔ فرمایا ”جنتی، اپنے سے اوپر کے بالاخانے والوں کو اس طرح دیکھیں گے، جیسے چمکتے ہوئے مشرقی یامغربی ستارے کو تم آسمان کے کنارے پر دیکھتے ہو، یعنی ان کے درمیان درجات کا اتنا فرق ہوگا“، صحابہ نےپوچا: یہ انبیاء کے درجات ہوں گے جن کو دوسرے حاصل نہیں کر سکیں گے؟ آپ ﹲ نے فرمایا ”ہاں، قسم ہے اس ذات کی جس کے ہاتھ میں میری جان ہے یہ وہ لوگ ہیں جو اللہ پر ایمان لائے اور پیغمبروں کی تصدیق کی“۔(صحيح بخاري، كتاب بدء الخلق ، باب ما جاء في صفة الجنة وأنها مخلوقة) یعنی ایمان اور تصدیقی کا حق ادا کیا۔ (فتح الباری)۔]
  57,20,"خوب جان رکھو کہ دنیا کی زندگی صرف کھیل تماشا زینت اور آپس میں فخر (و غرور) اور مال واوﻻد میں ایک کا دوسرے سے اپنے آپ کو زیاده بتلانا ہے، جیسے بارش اور اس کی پیداوار کسانوں{1} کو اچھی معلوم ہوتی ہے پھر جب وه خشک ہو جاتی ہے تو زرد رنگ میں اس کو تم دیکھتے ہو پھر وه بالکل چورا چورا ہو جاتی ہے{2} اور آخرت میں سخت عذاب{3} اور اللہ کی مغفرت اور رضامندی ہے{4} اور دنیا کی زندگی بجز دھوکے کے سامان کے اور کچھ بھی تو نہیں.{5}",footnotes:1:[كُفَّارٌ، کسانوں کو کہا گیا ہے، اس لیے کہ اس کے لغوی معنی ہیں چھپانے والے۔ کافروں کے دلوں میں اللہ کا اور آخرت کا انکار چھپا ہوتا ہے، اس لیے انہیں کافر کہا جاتا ہے۔ اور کاشﺖ کاروں کے لیے یہ لفظ بولا گیا ہے کہ وہ بھی زمین میں بیج بوتے یعنی انہیں چھپا دیتے ہیں۔,],footnotes:2:[- یہاں دنیا کی زندگی کو سرعت زوال میں کھیتی سے تشبیہ دی گئی ہے کہ جس طرح کھیتی جب شاداب ہوتی ہے تو بڑی بھلی لگتی ہے، کاشﺖ کار اسے دیکھ کر بڑے خوش ہوتےہیں۔ لیکن وہ بہت ہی جلد خشک اور زرد رو ہوکر چورا چورا ہو جاتی ہے۔ اسی طرح دنیا کی زیب وزینت ، مال اور اولاد دیگر چیزیں انسان کاﺩل لبھاتی ہیں۔ لیکن یہ زندگی چند روزہ ہی ہے۔ اس کو بھی ثبات و قرار نہیں۔,],footnotes:3:[- یعنی اہل کفر وعصیان کےلیے، جو دنیا کےکھیل کود میں ہی مصروف رہے اور اسی کو انہوں نے حاصل زندگی سمجھا۔,],footnotes:4:[- یعنی اہل ایمان وطاعت کے لیے، جنہوں نے دنیاکو ہی سب کچھ نہیں سمجھا، بلکہ اسے عارضی، فانی اور دارالامتحان سمجھتے ہوئے اللہ کی ہدایات کے مطابق اس میں زندگی گزاری۔,],footnotes:5:[- لیکن اس کے لیے جواس کےدھوکے میں مبتلا رہا اور آخرت کے لیے کچھ نہیں کیا۔ لیکن جس نے اس حیات دنیا کو طلب آخرت کے لیے استعمال کیا تو اس لیے یہی دنیا، اس سے بہتر زندگی حاصل کرنے کا ذریعہ ثابت ہو گی۔]
  57,21,"(آؤ) دوڑو اپنے رب کی مغفرت کی طرف اور اس جنت کی طرف{1} جس کی وسعت آسمان وزمین کی وسعت کے برابر ہے{2} یہ ان کے لیے بنائی ہے جو اللہ پر اور اس کے رسولوں پر ایمان رکھتے ہیں۔ یہ اللہ کا فضل ہے جسے چاہے دے{3} اور اللہ بڑے فضل واﻻ ہے.{4}",footnotes:1:[یعنی اعمال صالحہ اور توبہ النصوح کی طرف کیونکہ یہی چیزیں مغفرت رب کا ذریعہ ہیں,],footnotes:2:[- اور جس کا عرض اتنا ہو، اس کا طول کتنا ہو گا؟ کیونکہ طول، عرض سے زیادہ ہی ہوتا ہے۔,],footnotes:3:[- ظاہر ہے اس کی چاہت اسی کے لیے ہوتی ہے جو کفرومعصیت سے توبہ کرکے ایمان وعمل صالح کی زندگی اختیار کر لیتاہے، اسی لیے وہ ایسےلوگوں کو ایمان اور اعمال صالحہ کی توفیق سے بھی نواز دیتا ہے۔,],footnotes:4:[- وہ جس پر چاہتا ہے،اپنا فضل فرماتا ہے، جس کو وہ کچھ دے، کوئی روک نہیں سکتا اور جس سے روک لے، اسے کوئی دے نہیں سکتا، تمام خیر اسی کے ہاتھ میں ہے، وہی کریم مطلق اور جواد حقیقی ہے جس کے ہاں بخل کا تصور نہیں۔]
  58,13,"کیا تم اپنی سرگوشی سے پہلے صدقہ نکالنے سے ڈر گئے؟ پس جب تم نے یہ نہ کیا اور اللہ تعالیٰ نے بھی تمہیں معاف فرما دیا{1} تو اب (بخوبی) نمازوں کو قائم رکھو زکوٰة دیتے رہا کرو اور اللہ تعالیٰ کی اور اس کے رسول کی تابعداری کرتے رہو{2}۔ تم جو کچھ کرتے ہو اس (سب) سے اللہ (خوب) خبردار ہے.",footnotes:1:[یہ امر گو استحباباً تھا، پھر بھی مسلمانوں کے لیے شاق تھا، اس لیے اللہ تعالیٰ نے جلد ہی اسے منسوخ فرما دیا۔,],footnotes:2:[- یعنی فرائض واحکام کی پابندی، اس صدقے کا بدل بن جائے گی، جسے اللہ نے تمہاری تکلیف کے لیے معاف فرما دیا ہے۔]
  58,14,"کیا تو نے ان لوگوں کو نہیں دیکھا؟ جنہوں نے اس قوم سے دوستی کی جن پر اللہ غضبناک ہوچکا ہے{1}، نہ یہ (منافق) تمہارے ہی ہیں نہ ان کے ہیں{2} باوجود علم کے پھر بھی جھوٹ پر قسمیں کھا رہے ہیں.{3}",footnotes:1:[جن پر اللہ کا غضب نازل ہوا، وہ قرآن کریم کی صراحت کے مطابق یہود ہیں۔ اور ان سے دوستی کرنے والے منافقین ہیں۔ یہ آیات اس وقت نازل ہوئیں، جب مدینے میں منافقین کا بھی زور تھا اور یہودیوں کی سازشیں بھی عروج پر تھیں۔ ابھی یہود کو جلا وطن نہیں کیا گیا تھا۔,],footnotes:2:[- یعنی یہ منافقین مسلمان ہیں اور نہ دین کے لحاظ سے یہودی ہی ہیں۔ پھر یہ کیوں یہودیوں سے دوستی کرتے ہیں؟ صرف اس لیے کہ ان کے اور یہود کے درمیان نبی (صلى الله عليه وسلم) اور اسلام کی عداوت قدر مشترک ہے۔,],footnotes:3:[- یعنی قسمیں کھا کر مسلمانوں کو باور کراتے ہیں کہ ہم بھی تمہاری طرح مسلمان ہیں یا یہودیوں سے ان کے رابطے نہیں ہیں۔]
  58,15,"اللہ تعالیٰ نے ان کے لیے سخت عذاب تیار کر رکھا ہے، تحقیق جو کچھ یہ کر رہے ہیں برا کر رہے ہیں.{1}.",footnotes:1:[یعنی یہودیوں سے دوستانہ تعلق رکھنے اور جھوٹی قسمیں کھانے کی وجہ سے۔]
  59,4,"یہ اس لیے کہ انہوں نے اللہ تعالیٰ کی اور اس کے رسول کی مخالفت کی اور جو بھی اللہ کی مخالفت کرے گا تو اللہ تعالیٰ بھی سخت عذاب کرنے واﻻ ہے."
  59,5,"تم نے کھجوروں کے جو درخت کاٹ ڈالے یا جنہیں تم نے ان کی جڑوں پر باقی رہنے دیا۔ یہ سب اللہ تعالیٰ کے فرمان سے تھا اور اس لیے بھی کہ فاسقوں کو اللہ تعالیٰ رسوا کرے.{1}.",footnotes:1:[لِينَةٍ، کھجور کی ایک قسم ہے، جیسے عجوہ، برنی وغیرہ کھجوروں کی قسمیں ہیں۔ یا عام کھجور کا درخت مراد ہے۔ دوران محاصرہ نبی (صلى الله عليه وسلم) کے حکم سے مسلمانوں نے بنو نضیر کے کھجوروں کے درختوں کو آگ لگا دی، کچھ کاٹ ڈالے اور کچھ چھوڑ دیئے۔ جس سے مقصود دشمن کی آڑ کو ختم کرنا۔ اور یہ واضح کرنا تھا کہ اب مسلمان تم پر غالب ہیں، وہ تمہارے اموال وجائیداد میں جس طرح چاہیں، تصرف کرنے پر قادر ہیں۔ اللہ تعالیٰ نے بھی مسلمانوں کی اس حکمت عملی کی تصویب فرمائی اور اسے یہود کی رسوائی کا ذریعہ قرار دیا۔]
  59,6,"اور ان کا جو مال اللہ تعالیٰ نے اپنے رسول کے ہاتھ لگایا ہے جس پر نہ تو تم نے اپنے گھوڑے دوڑائے ہیں اور نہ اونٹ بلکہ اللہ تعالیٰ اپنے رسول کو جس پر چاہے غالب کر دیتا ہے{1}، اور اللہ تعالیٰ ہر چیز پر قادر ہے..",footnotes:1:[بنو نضیر کا یہ علاقہ، جو مسلمانوں کے قبضے میں آیا، مدینے سے تین چار میل کے فاصلے پر تھا، یعنی مسلمانوں کو اس کے لیے لمبا سفر کرنے کی ضرورت پیش نہیں آئی۔ یعنی اس میں مسلمانوں کو اونٹ اور گھوڑے دوڑانے نہیں پڑے۔ اسی طرح لڑنے کی بھی نوبت نہیں آئی اور صلح کے ذریعے سے یہ علاقہ فتح ہوگیا، یعنی اللہ نے اپنے رسول (صلى الله عليه وسلم) کو بغیر لڑے ان پر غالب فرما دیا۔ اس لیے یہاں سے حاصل ہونے والے مال کو فَيْء قرار دیا گیا، جس کا حکم غنیمت سے مختلف ہے۔ گویا وہ مال فَيْءٌ ہے، جو دشمن بغیر لڑے چھوڑ کر بھاگ جائے یا صلح کے ذریعے سے حاصل ہو۔ اور جو مال باقاعدہ لڑائی اور غلبہ حاصل کرنے کے بعد ملے، وہ غنیمت ہے۔]
