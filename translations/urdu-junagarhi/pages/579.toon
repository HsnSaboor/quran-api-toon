quran[20]{c,v,t,f}:
  76,6,"جو ایک چشمہ ہے{1}۔ جس سے اللہ کے بندے پئیں گے اس کی نہریں نکال لے جائیں گے{2} (جدھر چاہیں).",footnotes:1:[<strong>ابرار کے لئے چشمہ کا فور کی شراب:</strong>یعنی جام شراب پئیں گے جس میں تھوڑا سا کافور ملایا جائیگا۔ یہ کافور دنیا کا نہیں بلکہ جنت کا ایک خاص چشمہ ہے جو خاص طور پر اللہ کے مقرب و مخصوص بندوں کو ملے گا۔ شاید اس کو ٹھنڈا، خوشبودار، مفرح اور سفید رنگ ہونے کی وجہ سے کافور کہتے ہونگے۔,]footnotes:2:[<strong>چشمہ کا بہنا عباداللہ کے اختیار میں:</strong>یعنی وہ چشمہ ان بندوں کے اختیار میں ہوگا جدھر اشارہ کریں گے اسی طرف کو اس کی نالی بہنے لگے گی۔ بعض کہتے ہیں کہ اس کا اصل منبع حضور پرنور محمد رسول ﷺ کے قصر میں ہوگا۔ وہاں سے سب انبیاء و مؤمنین کے مکانوں تک اس کی نالیاں پہنچائی جائیں گی۔ واللہ اعلم۔ آگے ابرار کی خصلتیں بیان فرمائی ہیں۔]
  76,7,"جو نذر پوری کرتے ہیں{1} اور اس دن سے ڈرتے ہیں جس کی برائی چاروں طرف پھیل جانے والی ہے.{2}",footnotes:1:[<strong>منّت کو پورا کرنے والے:</strong>یعنی جو منت مانی ہو اسے پورا کرتے ہیں۔ ظاہر ہے کہ جب خود اپنی لازم کی ہوئی چیز کو پورا کرینگے تو اللہ کی لازم کی ہوئی باتوں کو کیسے چھوڑ سکتے ہیں۔,]footnotes:2:[یعنی اس دن کی سختی اور برائی درجہ بدرجہ سب کو عام ہوگی۔ کوئی شخص بالکلیہ محفوظ نہ رہیگا۔ الا من شاء اللّٰہ ۔]
  76,8,"اور اللہ تعالیٰ کی محبت{1} میں کھانا کھلاتے ہیں مسکین، یتیم اور قیدیوں کو.",footnotes:1:یا طعام کی محبت کے باوجود وہ اللہ کی رضا کے لیے ضرورت مندوں کو کھانا کھلاتے ہیں، قیدی اگر غیر مسلم ہو تب بھی اس کے ساتھ حسن سلوک کی تاکید ہے جیسے جنگ بدر کے کافر قیدیوں کی بابت نبی (صلى الله عليه وسلم) نے صحابہ کو حکم دیا کہ ان کی تکریم کرو۔ چنانچہ صحابہ پہلے ان کو کھانا کھلاتے، خود بعد میں کھاتے۔ (ابن کثیر) اسی طرح غلام اور نوکر چاکر بھی اسی ذیل میں آتے ہیں جن کے ساتھ حسن سلوک کی تاکید ہے۔ آپ (صلى الله عليه وسلم) کی آخری وصیت یہی تھی کہ ”نماز اور اپنے غلاموں کا خیال رکھنا“۔ (ابن ماجه، کتاب الوصایا، باب هل أوصی رسول الله صلى الله عليه وسلم)
  76,9,"ہم تو تمہیں صرف اللہ تعالیٰ کی رضامندی کے لیے کھلاتے ہیں نہ تم سے بدلہ چاہتے ہیں نہ شکر گزاری."
  76,10,"بیشک ہم اپنے پروردگار سے اس دن کا خوف کرتے ہیں{1} جو اداسی اور سختی واﻻ ہوگا.",footnotes:1:حضرت ابن عباس (رضي الله عنه) نے قمطریر کے معنی طویل کے کئے ہیں، عبوس، سخت یعنی وہ دن نہایت سخت ہوگا اور سختیوں اور ہولناکیوں کی وجہ سے کافروں پر بڑا لمبا ہوگا (ابن کثیر)
  76,11,"پس انہیں اللہ تعالیٰ نے اس دن کی برائی سے بچا لیا{1} اور انہیں تازگی اور خوشی پہنچائی.{2}",footnotes:1:[جیسا کہ وہ اس کے شر سے ڈرتے تھے اور اس سے بچنے کے لئے اللہ کی اطاعت کرتے تھے۔,]footnotes:2:[تازگی چہروں پر ہوگی اور خوشی دلوں میں، جب انسان کا دل مسرت سے لبریز ہوتا ہے تو اس کا چہرہ بھی مسرت سے گلنار ہو جاتا ہے۔ نبی (صلى الله عليه وسلم) کے بارے میں آتا ہے کہ جب آپ (صلى الله عليه وسلم) خوش ہوتے تو آپ کا چہرۂ مبارک اس طرح روشن ہوتا گویا چاند کا ٹکڑا ہے۔ (البخاری، کتاب المغازی، باب غزوة تبوک، مسلم، کتاب التوبة)]
  76,12,"اور انہیں ان کے صبر{1} کے بدلے جنت اور ریشمی لباس عطا فرمائے.",footnotes:1:صبر کا معنی ہے دین کے راستے میں جو تکلفیں آئیں انہیں خندہ پیشانی سے برداشت کرنا اللہ کی اطاعت میں نفس کی خواہشات اور لذات کو قربان کرنا اور معصیتوں سے اجتناب کرنا۔
  76,13,"یہ وہاں تختوں پر تکیے لگائے ہوئے بیٹھیں گے۔ نہ وہاں آفتاب کی گرمی دیکھیں گے نہ جاڑے کی سختی.{1}",footnotes:1:زَمْهَرِير، سخت جاڑے کو کہتے ہیں۔ مطلب یہ ہے کہ وہاں ہمیشہ ایک ہی موسم رہے گا اور وہ ہے موسم بہار، نہ سخت گرمی اور نہ کڑاکے کی سردی۔
  76,14,"ان جنتوں کے سائے ان پر جھکے ہوئے ہوں گے{1} اور ان کے (میوے اور) گچھے نیچے لٹکائے ہوئے ہوں گے.{2}",footnotes:1:[گو وہاں سورج کی حرارت نہیں ہوگی، اس کے باوجود درختوں کے سائے ان پر جھکے ہوئے ہوں گے یا یہ مطلب ہے کہ ان کی شاخیں ان کے قریب ہونگی۔,]footnotes:2:[یعنی درختوں کے پھل، گوش برآواز فرماں بردار کی طرح انسان کا جب کھانے کو جی چاہے گا تو وہ جھک کر اتنے قریب ہو جائیں گے کہ بیٹھے، لیٹے بھی انہیں توڑ لے۔ ابن کثیر)]
  76,15,"اور ان پر چاندی کے برتنوں اور ان جاموں کا دور کرایا جائے گا{1} جو شیشے کے ہوں گے.{2}",footnotes:1:[یعنی خادم انہیں لے کر جنتیوں کے درمیان پھریں گے۔,]footnotes:2:[]
  76,16,"شیشے بھی چاندی کے جن کو (ساقی نے) اندازے سے ناپ رکھا ہوگا.{1}",footnotes:1:یعنی یہ برتن اور آب خورے چاندی اور شیشے سے بنے ہونگے، نہایت نفیس اور نازک۔ گویا یہ صنعت ایسی ہے کہ جس کی کوئی نظیر دنیا میں نہیں ہے۔
  76,17,"اور انہیں وہاں وه جام پلائے جائیں گے جن کی آمیزش زنجبیل کی ہوگی.{1}",footnotes:1:زَنْجَبِیْل (سونٹھ، خشک ادرک) کو کہتے ہیں۔ یہ گرم ہوتی ہے اس کی آمیزش سے ایک خوشگوار تلخی پیدا ہو جاتی ہے۔ علاوہ ازیں عربوں کی یہ مرغوب چیز ہے۔ چنانچہ ان کے قہوہ میں بھی زنجبیل شامل ہوتی ہے۔ مطلب یہ ہے کہ جنت میں ایک وہ شراب ہوگی جو ٹھنڈی ہوگی جس میں کافور کی آمیزش ہوگی اور دوسری شراب گرم، جس میں زنجبیل کی ملاوٹ ہوگی۔
  76,18,"جنت کی ایک نہر سے جس کا نام سلسبیل ہے.{1}",footnotes:1:یعنی اس شراب زنجبیل کی بھی ایک نہر ہوگی جسے سلسبیل کہا جاتا ہے۔
  76,19,"اور ان کے ارد گرد گھومتے پھرتے ہوں گے وه کم سن بچے جو ہمیشہ رہنے والے ہیں{1} جب تو انہیں دیکھے تو سمجھے کہ وه بکھرے ہوئے سچے موتی ہیں.{2}",footnotes:1:[یعنی ہمیشہ لڑکے رہیں گے یا جنتیوں سے کبھی چھینے نہ جائیں گے۔,]footnotes:2:[<strong>بکھرے موتیوں کی طرح خوبصورت لڑکے:</strong>یعنی اپنے حسن و جمال صفائی اور آب و تاب میں اِدھر اُدھر پھرتے ہوئے ایسے خوش منظر معلوم ہونگے گویا بہت سے چمکدار خوبصورت موتی زمین پر بکھیر دیئے گئے۔]
  76,20,"تو وہاں جہاں کہیں بھی نظر ڈالے گا{1} سراسر نعمتیں اور عظیم الشان سلطنت ہی دیکھے گا.",footnotes:1:ثم ظرف مکان ہے، واذا رأیت ثم، أي: هناك یعنی وہاں جنت میں جہاں کہیں بھی دیکھو گے۔
  76,21,"ان کے جسموں پر سبز باریک اور موٹے ریشمی کپڑے ہوں گے{1} اور انہیں چاندی کے کنگن کا زیور پہنایا جائے گا{2}۔ اور انہیں ان کا رب پاک صاف شراب پلائے گا.",footnotes:1:[<strong>جنّت کے لباس:</strong>یعنی باریک اور دبیز دونوں قسم کے ریشم کے لباس جنتیوں کو ملیں گے۔,]footnotes:2:[<strong>چاندی کے کنگن:</strong>اس سورت میں تین جگہ چاندی کے برتنوں اور زیور وغیرہ کا ذکر آیا ہے۔ دوسری جگہ سونے کے بیان کئے گئے ہیں۔ ممکن ہے یہ بھی ہوں اور وہ بھی، کسی کو یہ ملیں، کسی کو  وہ۔ یا کبھی یہ کبھی وہ۔]
  76,22,"(کہا جائے گا) کہ یہ ہے تمہارے اعمال کا بدلہ اور تمہاری کوشش کی قدر کی گئی."
  76,23,"بیشک ہم نے تجھ پر بتدریج قرآن نازل کیا ہے.{1}",footnotes:1:یعنی ایک ہی مرتبہ نازل کرنے کی بجائے حسب ضرورت مختلف اوقات میں نازل کیا۔ اس کا دوسرا مطلب یہ بھی ہو سکتا ہے کہ یہ قرآن ہم نے نازل کیا ہے، یہ تیرا اپنا گھڑا ہوا نہیں ہے، جیسا کہ مشرکین دعویٰ کرتے ہیں۔
  76,24,"پس تو اپنے رب کے حکم پر قائم ره{1} اور ان میں سے کسی گنہگار یا ناشکرے کا کہا نہ مان.{2}",footnotes:1:[<strong>کفّار پر صبر کیجئے:</strong>تاکہ آپ ﷺ کا دل مضبوط رہے اور لوگ بھی آہستہ آہستہ اپنے نیک و بد کو سمجھ لیں۔ اور معلوم کر لیں کہ جنت کن اعمال کی بدولت ملتی ہے۔ اگر اس طرح سمجھانے پر بھی نہ مانیں اور اپنی ضد و عناد ہی پر قائم رہیں تو آپ اپنے پروردگار کے حکم پر برابر جمے رہئے۔ اور آخری فیصلہ کا انتظار کیجئے۔,]footnotes:2:[<strong>قریش کے سرداروں کی بات نہ مانئے:</strong>عتبہ اور ولید وغیرہ کفار قریش آپ ﷺ کو دنیوی لالچ دے کر اور چکنی چپڑی باتیں بنا کر چاہتے تھے کہ فرض تبلیغ و دعوت سے باز رکھیں۔ اللہ نے متنبہ فرمادیا۔ کہ آپ ان میں سے کسی کی بات نہ مانیں۔ کیونکہ کسی گنہگار فاسق یا ناشکر کافر کا کہا ماننے سے نقصان کے سوا کچھ حاصل نہیں۔ ایسے شریروں اور بدبختوں کی بات پر کان دھرنا نہیں چاہیئے۔]
  76,25,"اور اپنے رب کے نام کا صبح وشام ذکر کیا کر.{1}",footnotes:1:صبح و شام سے مراد ہے، تمام اوقات میں اللہ کا ذکر کر۔ یا صبح سے مراد فجر کی نماز اور شام سے عصر کی نماز ہے۔
