quran[9]{c,v,t,f}:
  26,73,"یا تمہیں نفع نقصان بھی پہنچا سکتے ہیں.{1}.",footnotes:1:[یعنی اگر تم ان کی عبادت ترک کردو تو کیا وہ تمہیں نقصان پہنچاتے ہیں؟]
  26,74,"انہوں نے کہا یہ (ہم کچھ نہیں جانتے) ہم تو اپنے باپ دادوں کو اسی طرح کرتے پایا.{1}.",footnotes:1:[جب وہ حضرت ابراہیم (عليه السلام) کے سوال کا کوئی معقول جواب نہیں دے سکتے تو یہ کہہ کر چھٹکارا حاصل کرلیا۔ جیسے آج بھی لوگوں کو قرآن و حدیث کی بات بتلائی جائے تو یہی عذر پیش کیا جاتا ہے کہ ہمارے خاندان میں تو ہمارے آباواجداد سے یہی کچھ ہوتا آرہا ہے، ہم اسے نہیں چھوڑ سکتے۔]
  26,75,"آپ نے فرمایا کچھ خبر بھی{1} ہے جنہیں تم پوج رہے ہو..",footnotes:1:[أَفَرَأَيْتُمْ؟ کے معنی ہیں فَهَلْ أَبْصَرْتُمْ وَتَفَكَّرْتُمْ؟ کیا تم نے غوروفکر کیا؟]
  27,46,"آپ نے فرمایا اے میری قوم کے لوگو! تم نیکی سے پہلے برائی کی جلدی کیوں مچا رہے{1} ہو؟ تم اللہ تعالیٰ سےاستغفار کیوں نہیں کرتے تاکہ تم پر رحم کیا جائے..",footnotes:1:[یعنی ایمان قبول کرنے کے بجائے تم کفر ہی پر کیوں اصرار کر رہے ہو، جو عذاب کا باعث ہے۔ علاوہ ازیں اپنے عناد و سرکشی کی وجہ سے کہتے بھی تھے کہ ہم پر عذاب لے آ۔ جس کے جواب میں حضرت صالح (عليه السلام) نے یہ کہا۔]
  27,47,"وه کہنے لگے ہم تو تیری اور تیرے ساتھیوں کی بدشگونی لے رہے{1} ہیں؟ آپ نے فرمایا تمہاری بدشگونی اللہ کے ہاں{2} ہے، بلکہ تم فتنے میں پڑے ہوئے لوگ ہو.{3}",footnotes:1:[اطَّيَّرْنَا اصل میں تَطَيَّرْنَا ہے۔ اس کی اصل طیر (اڑنا) ہے۔ عرب جب کسی کام کا یا سفر کا ارادہ کرتے تو پرندے کو اڑاتے اگر وہ دائیں جانب اڑتا تو اسے نیک شگون سمجھتے اور وہ کام کرگزرتے یا سفر پر روانہ ہو جاتے اور اگر بائیں جانب اڑتا تو اسے بدشگونی سمجھتے اور اس کام یا سفر سے رک جاتے (فتح القدیر) اسلام میں یہ بدشگونی اور نیک شگونی جائز نہیں ہے البتہ تفاؤل جائز ہے۔,],footnotes:2:[- یعنی اہل ایمان نحوست کا باعث نہیں ہیں جیسا کہ تم سمجھتے ہو بلکہ اس کا اصل سبب اللہ ہی کے پاس ہے، کیونکہ قضا و تقدیر اسی کےاختیار میں ہے۔ مطلب یہ ہے کہ تمہیں جونحوست (قحط وغیرہ) پہنچی ہے، وہ اللہ کی طرف سے ہے اور اس کا سبب تمہارا کفر ہے۔ (فتح القدیر)۔,],footnotes:3:[- یا گمراہی میں ڈھیل دے کر تمہیں آزمایا جائے۔]
  27,48,"اس شہر میں نو سردار تھے جو زمین میں فساد پھیلاتے رہتے تھے اور اصلاح نہیں کرتے تھے."
  28,19,"پھر جب اپنے اور اس کے دشمن کو پکڑنا چاہا{1} وه فریادی کہنے لگا کہ{2} موسیٰ (علیہ السلام) کیا جس طرح تو نے کل ایک شخص کو قتل کیا ہے مجھے بھی مار ڈالنا چاہتا ہے، تو تو ملک میں ﻇالم وسرکش ہونا ہی چاہتا ہے اور تیرا یہ اراده ہی نہیں کہ ملاپ کرنے والوں میں سے ہو.",footnotes:1:[یعنی حضرت موسیٰ (عليه السلام) نے چاہا کہ قبطی کو پکڑ لیں، کیونکہ وہی حضرت موسیٰ (عليه السلام) اور بنی اسرائیل کا دشمن تھا، تاکہ لڑائی زیادہ نہ بڑھے۔,],footnotes:2:[- فریادی (اسرائیلی) سمجھا کہ موسیٰ (عليه السلام) شاید اسے پکڑنے لگے ہیں تو وہ بول اٹھا کہ اے موسیٰ ! أَتُرِيدُ أَنْ تَقْتُلَنِي ...... جس سے قبطی کے علم میں یہ بات آگئی کہ کل جو قتل ہوا تھا، اس کا قاتل موسیٰ (عليه السلام) ہے، اس نے جاکر فرعون کو بتلا دیا جس پر فرعون نے اس کے بدلے میں موسیٰ (عليه السلام) کو قتل کرنے کا عزم کرلیا۔]
  28,20,"شہر کے پرلے کنارے سے ایک شخص دوڑتا ہوا آیا{1} اور کہنے لگا اے موسیٰ! یہاں کے سردار تیرے قتل کا مشوره کر رہے ہیں، پس تو بہت جلد چلا جا مجھے اپنا خیر خواه مان..",footnotes:1:[یہ آدمی کون تھا؟ بعض کے نزدیک یہ فرعون کی قوم سے تھا جو درپردہ حضرت موسیٰ (عليه السلام) کا خیر خواہ تھا۔ اور ظاہر ہے سرداروں کے مشورے کی خبر ایسے ہی آدمی کے ذریعے آنا زیادہ قرین قیاس ہے۔ بعض کے نزدیک یہ موسیٰ (عليه السلام) کا قریبی رشتے دار اور اسرائیلی تھا۔ اور اقصائے شہر سے مراد منف ہے جہاں فرعون کا محل اور دارالحکومت تھا اور یہ شہر کے آخری کنارے پر تھا۔]
  28,21,"پس موسیٰ (علیہ السلام) وہاں سے خوفزده ہوکر دیکھتے بھالتے نکل کھڑے ہوئے{1}، کہنے لگے اے پروردگار! مجھے ﻇالموں کے گروه سے بچا لے.{2}",footnotes:1:[جب حضرت موسیٰ (عليه السلام) کے علم میں یہ بات آئی تو وہاں سے نکل کھڑے ہوئے تاکہ فرعون کی گرفت میں نہ آسکیں۔,],footnotes:2:[- یعنی فرعون اور اس کے درباریوں سے، جنہوں نے باہم حضرت موسیٰ (عليه السلام) کے قتل کا مشورہ کیا تھا۔ کہتے ہیں کہ حضرت موسیٰ (عليه السلام) کو کوئی علم نہ تھا کہ کہاں جانا ہے؟ کیوں کہ مصر چھوڑنے کا یہ حادثہ بالکل اچانک پیش آیا، پہلے سے کوئی خیال یا منصوبہ نہیں تھا، چنانچہ اللہ نے گھوڑے پر ایک فرشتہ بھیج دیا، جس نے انہیں راستے کی نشاندہی کی، وَاللهُ أَعْلَمُ۔ (ابن کثیر)]
