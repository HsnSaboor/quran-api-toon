quran[14]{c,v,t,f}:
  89,28,"تو اپنے رب کی طرف{1} لوٹ چل اس طرح کہ تو اس سے راضی وه تجھ سے خوش..",footnotes:1:[یعنی اس کے اجر وثواب اور ان نعمتوں کی طرف جو اس نے اپنے بندوں کے لئے جنت میں تیار کی ہے۔ بعض کہتے ہیں قیامت والے دن کہا جائے گا بعض کہتے ہیں کہ موت کے وقت بھی فرشتے خوشخبری دیتے ہیں، اسی طرح قیامت والے دن بھی اسے یہ کہا جائے گا جو یہاں مذکور ہے۔ حافظ ابن کثیر نے ابن عسا کرکے حوالے سے نقل کیا ہے کہ نبی کریم (صلى الله عليه وسلم) نے ایک آدمی کو یہ دعا پڑھنے کا حکم دیا ”اللَّهُمَّ إِنِّي أَسْأَلُكَ نَفْسًا، بِكَ مُطْمَئِنَّةً، تُؤْمِنُ بِلِقَائِكَ، وَتَرْضَى بِقَضَائِكَ وَتَقْنَعُ بِعَطَائِكَ“۔ (ابن كثير)۔]
  89,29,"پس میرے خاص بندوں میں داخل ہو جا."
  89,30,"اور میری جنت میں چلی جا."
  92,16,"جس نے جھٹلایا اور (اس کی پیروی سے) منھ پھیر لیا.{1}.",footnotes:1:[اس آیت سے مرجئہ فرقے نے (جو ایک باطل فرقہ گزرا ہے) استدلال کیا ہے کہ جہنم میں صرف کافر ہی جائیں گے۔ کوئی مسلمان چاہے کتنا ہی گناہ گار ہو، وہ جہنم میں نہیں جائے گا۔ لیکن یہ عقیدہ ان نصوص صریحہ کے خلاف ہے جن سے معلوم ہوتا ہے کہ بہت سے مسلمان بھی، جن کو اللہ تعالیٰ کچھ سزا دینا چاہے گا، کچھ عرصے کے لئے جہنم میں جائیں گے، پھر وہ نبی (صلى الله عليه وسلم) ، ملائکہ اور دیگر صالحین کی شفاعت سے نکال لئے جائیں گے، یہاں حصر کے انداز میں جو کہا گیا ہے، اس کا مطلب ہے کہ جو لوگ پکے کافر اور نہایت بدبخت ہیں، جہنم دراصل ان ہی کے لئے بنائی گئی ہے، جس میں وہ لازمی اور حتمی طور پر اور ہمیشہ کے لئے داخل ہوں گے۔ اگر کچھ نافرمان قسم کے مسلمان جہنم میں جائیں گے تو وہ لازمی اور حتمی طور پر اور ہمیشہ کے لئے نہیں جائیں گے، بلکہ بطور سزا ان کا یہ دخول عارضی ہوگا۔ ( فتح القدیر )۔]
  92,17,"اور اس سے ایسا شخص دور رکھا جائے گا جو بڑا پرہیزگار ہو گا. {1}.",footnotes:1:[" یعنی جہنم سے دور رہے گا اور جنت میں داخل ہوگا۔"]
  92,18,"جو پاکی حاصل کرنے کے لئے اپنا مال دیتا ہے. {1}.",footnotes:1:[" یعنی جو اپنا مال اللہ کے حکم کے مطابق خرچ کرتا ہے تاکہ اس کا نفس بھی اور اس کا مال بھی پاک ہو جائے۔"]
  95,7,"پس تجھے اب روز جزا کے جھٹلانے پر کون سی چیز آماده کرتی ہے.{1}.",footnotes:1:[یہ انسان سے خطاب ہے، زجر وتوبیخ کے لئے۔ کہ اللہ نے تجھے بہترین صورت میں پیدا کیا اور وہ تجھے اس کے برعکس قعر مذلت میں بھی گرانے کی قدرت رکھتا ہے۔ اس کا مطلب ہے کہ اس کے لئے دوبارہ پیدا کرنا کوئی مشکل نہیں۔ اس کے بعد بھی تو قیامت اور جزا کا انکار کرتا ہے؟]
  95,8,"کیا اللہ تعالیٰ (سب) حاکموں کا حاکم نہیں ہے.{1}.",footnotes:1:[جو کسی پر ظلم نہیں کرتا اور اس کے عدل ہی کا یہ تقاضا ہے کہ وہ قیامت برپا کرے اور ان کی داد رسی کرے جن پر دنیا میں ظلم ہوا۔ پہلے گزر چکا ہے کہ ایک ضعیف حدیث میں اس کا یہ جواب دینا منقول ہے۔ بَلَى، وَأَنَا عَلَى ذَلِكَ مِنَ الشَّاهِدِينَ ) ( الترمذي ) ۔]
  96,4,"جس نے قلم کے ذریعے (علم) سکھایا.{1}.",footnotes:1:[قَلَمٌ کے معنی ہیں قطع کرنا، تراشنا، قلم بھی پہلے زمانے میں تراش کر ہی بنائے جاتے تھے، اس لئے آلۂ کتابت کو قلم سے تعبیر کیا۔ کچھ علم تو انسان کے ذہن میں ہوتا ہے، کچھ کا اظہار زبان کے ذریعے سے ہوتا ہے اور کچھ انسان قلم سے کاغذ پر لکھ لیتا ہے۔ ذہن وحافظہ میں جو ہوتا ہے، وہ انسان کے ساتھ ہی چلا جاتا ہے۔ زبان سے جس کا اظہار کرتا ہے، وہ بھی محفوظ نہیں رہتا۔ البتہ قلم سے لکھا ہوا، اگر وہ کسی وجہ سے ضائع نہ ہو تو ہمیشہ محفوظ رہتا ہے، اسی قلم کی بدولت تمام علوم، پچھلے لوگوں کی تاریخیں اور اسلاف کا علمی ذخیرہ محفوظ ہے۔ حتیٰ کہ آسمانی کتابوں کی حفاظت کا بھی ذریعہ ہے۔ اس سے قلم کی اہمیت محتاج وضاحت نہیں رہتی۔ اسی لئے اللہ نے سب سے پہلے قلم کو پیدا کیا اور اس کو تمام مخلوقات کی تقدیر لکھنے کا حکم دیا۔]
  96,5,"جس نے انسان کو وه سکھایا جسے وه نہیں جانتا تھا."
  96,6,"سچ مچ انسان تو آپے سے باہر ہو جاتا ہے."
  97,1,"یقیناً ہم نے اسے شب قدر میں نازل فرمایا.{1}.",footnotes:1:[یعنی اتارنے کا آغاز کیا، یا لوح محفوظ سے اس بیت العزت میں، جو آسمان پر ہے، ایک ہی مرتبہ اتار دیا۔ اور وہاں سے حسب وقائع نبی (صلى الله عليه وسلم) پر اترتا رہا تا آنکہ 23 سال میں پورا ہوگیا۔ اور لیلتہ القدر رمضان میں ہی ہوتی ہے، جیسا کہ قرآن کی آیت «شَهْرُ رَمَضَانَ الَّذِي أُنْزِلَ فِيهِ الْقُرْآنُ» (البقرة: 185 ) سے واضح ہے۔]
  97,2,"تو کیا سمجھا کہ شب قدر کیا ہے؟{1}.",footnotes:1:[اس استفہام سے اس رات کی عظمت واہمیت واضح ہے، گویاکہ مخلوق اس کی تہ تک پوری طرح نہیں پہنچ سکتی، یہ صرف ایک اللہ ہی ہے جو اس کو جانتا ہے۔]
  97,3,"شب قدر ایک ہزار مہینوں سے بہتر ہے.{1}.",footnotes:1:[یعنی اس ایک رات کی عبادت ہزار مہینوں کی عبادت سے بہتر ہے اور ہزار مہینے 83 سال 4 مہینے بنتے ہیں۔ یہ امت محمدیہ پر اللہ کا کتنا احسان عظیم ہے کہ مختصر عمر میں زیادہ سے زیادہ ثواب حاصل کرنے کے لئے کیسی سہولت عطا فرما دی۔]
