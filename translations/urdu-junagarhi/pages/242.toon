quran[9]{c,v,t,f}:
  16,97,"جو شخص نیک عمل کرے مرد ہو یا عورت، لیکن باایمان ہو تو ہم اسے یقیناً نہایت بہتر زندگی عطا فرمائیں گے{1}۔ اور ان کے نیک اعمال کا بہتر بدلہ بھی انہیں ضرور ضرور دیں گے..",footnotes:1:[حیات طیبہ (بہتر زندگی) سے مراد دنیا کی زندگی ہے، اس لئے آخرت کی زندگی کا ذکر اگلے جملے میں ہے اور مطلب یہ ہے کہ ایک مومن باکردار کو صالحانہ اور متقیانہ زندگی گزارنے اور اللہ کی عبادت و اطاعت اور زہد و قناعت میں جو لذت و حلاوت محسوس ہوتی ہے، وہ ایک کافر اور نافرمان کو دنیا بھر کی آسائشوں اور سہولتوں کے باوجود میسر نہیں آتی، بلکہ وہ ایک گونہ قلق و اضطراب کا شکار رہتا ہے۔«وَمَنْ أَعْرَضَ عَنْ ذِكْرِي فَإِنَّ لَهُ مَعِيشَةً ضَنْكًا» ( طه:124) ”جس نے میری یاد سے اعراض کیا اس کا گزران تنگی والا ہوگا“۔]
  16,98,"قرآن پڑھنے کے وقت راندے ہوئے شیطان سے اللہ کی پناه طلب کرو.{1}.",footnotes:1:[خطاب اگرچہ نبی (صلى الله عليه وسلم) سے ہے لیکن مخاطب ساری امت ہے۔ یعنی تلاوت کے آغاز میں أَعُوذُ بِاللهِ مِنَ الشَّيِطَانِ الرَّجِيمِ پڑھا جائے۔]
  16,99,"ایمان والوں اور اپنے پروردگار پر بھروسہ رکھنے والوں پر اس کا زور مطلقاً نہیں چلتا."
  17,64,"ان میں سے تو جسے بھی اپنی آواز سے بہکا سکے بہکا{1} لے اور ان پر اپنے سوار اور پیادے چڑھا ﻻ{2} اور ان کے مال اور اوﻻد میں سے اپنا بھی ساجھا لگا{3} اور انہیں (جھوٹے) وعدے دے لے{4}۔ ان سے جتنے بھی وعدے شیطان کے ہوتے ہیں سب کے سب سراسر فریب ہیں.{5}",footnotes:1:[آواز سے مراد پر فریب دعوت یا گانے، موسیقی اور لہو و لعب کے دیگر آلات ہیں، جن کے ذریعے سے شیطان بکثرت لوگوں کو گمراہ کر رہا ہے۔,],footnotes:2:[- ان لشکروں سے مراد، انسانوں اور جنوں کے وہ سوار اور پیادے لشکر ہیں جو شیطان کے چیلے اور اس کے پیروکار ہیں اور شیطان ہی کی طرح انسانوں کو گمراہ کرتے ہیں، یا مراد ہے ہر ممکن ذرائع جو شیطان گمراہ کرنے کے لئے استعمال کرتا ہے۔,],footnotes:3:[- مال میں شیطان کی مشارکت کا مطلب حرام ذریعے سے مال کمانا اور حرام طریقے سے خرچ کرنا ہے اور اسی طرح مویشیوں کو بتوں کے ناموں پر وقف کر دینا مثلًا بحیرہ، سائبہ وغیرہ اور اولاد میں شرکت کا مطلب، زنا کاری، عبدالات، عبدالعزیٰ وغیرہ نام رکھنا، غیر اسلامی طریقے سے ان کی تربیت کرنا کہ برے اخلاق و کردار کے حامل ہوں، ان کو تنگ دستی کے خوف سے ہلاک یا زندہ درگور کر دینا، اولاد کو مجوسی، یہودی و نصرانی وغیرہ بنانا اور بغیر مسنون دعا پڑھے بیوی سے ہم بستری کرنا وغیرہ وغیرہ ہے۔ ان تمام صورتوں میں شیطان کی شرکت ہو جاتی ہے۔,],footnotes:4:[- کہ کوئی جنت و دوزخ نہیں ہے، یا مرنے کے بعد دوبارہ زندگی نہیں ہے وغیرہ۔,],footnotes:5:[- غُرُورٌ (فریب) کا مطلب ہوتا ہے غلط کام کو اس طرح مزین کرکے دکھانا کہ وہ اچھا اور درست لگے۔]
  17,65,"میرے سچے بندوں پر تیرا کوئی قابو اور بس نہیں{1}۔ تیرا رب کارسازی کرنے واﻻ کافی ہے.{2}",footnotes:1:[بندوں کی نسبت اپنی طرف کی، بطور شرف اور اعزاز کے ہے، جس سے معلوم ہوا کہ اللہ کے خاص بندوں کو شیطان بہکانے میں ناکام رہتا ہے۔,],footnotes:2:[- یعنی جو صحیح معنوں میں اللہ کا بندہ بن جاتا ہے، اسی پر اعتماد اور توکل کرتا ہے تو اللہ بھی اس کا دوست اور کار ساز بن جاتا ہے۔]
  17,66,"تمہارا پروردگار وه ہے جو تمہارے لئے دریا میں کشتیاں چلاتا ہے تاکہ تم اس کا فضل تلاش کرو۔ وه تمہارے اوپر بہت ہی مہربان ہے.{1}.",footnotes:1:[یہ اس کا فضل اور رحمت ہی ہے کہ اس نے سمندر کو انسانوں کے تابع کر دیا اور وہ اس پر کشتیاں اور جہاز چلا کر ایک ملک سے دوسرے ملک میں آتے جاتے اور کاروبار کرتے ہیں، نیز اس نے ان چیزوں کی طرف رہنمائی بھی فرمائی جن میں بندوں کے لئے منافع اور مصالح ہیں۔]
  18,31,"ان کے لئے ہمیشگی والی جنتیں ہیں، ان کے نیچے نہریں جاری ہوں گی، وہاں یہ سونے کے کنگن پہنائے جائیں گے{1} اور سبز رنگ کے نرم وباریک اور موٹے ریشم کے لباس پہنیں گے{2}، وہاں تختوں کے اوپر تکیے لگائے ہوئے ہوں گے۔ کیا خوب بدلہ ہے، اور کس قدر عمده آرام گاه ہے.",footnotes:1:[زمانہ نزول قرآن اور اس سے ما قبل رواج تھا کہ بادشاہ، رؤسا سردران قبائل اپنے ہاتھوں میں سونے کے کڑے پہنتے تھے، جس سے ان کی امتیازی حیثیت نمایاں ہوتی تھی۔ اہل جنت کو بھی سونے کے کڑے پہنائے جائیں گے۔,],footnotes:2:[- سُنْدُس باریک ریشم اور إِسْتَبْرَق موٹا ریشم۔ دنیا میں مردوں کے لئے سونا اور ریشمی لباس ممنوع ہیں، جو لوگ اس حکم پر عمل کرتے ہوئے دنیا میں ان محرمات سے اجتناب کریں گے، انہیں جنت میں یہ ساری چیزیں میسر ہونگی۔ وہاں کوئی چیز ممنوع نہیں ہوگی بلکہ اہل جنت جس چیز کی خواہش کریں گے، وہ موجود ہوگی۔«وَلَكُمْ فِيهَا مَا تَشْتَهِي أَنْفُسُكُمْ وَلَكُمْ فِيهَا مَا تَدَّعُونَ»۔ جس چیز کو تمہارا جی چاہے اور جو کچھ تم مانگو سب جنت میں موجود ہے۔]
  18,32,"اور انہیں ان دو شخصوں کی مثال بھی سنا دے{1} جن میں سے ایک کو ہم نے دو باغ انگوروں کے دے رکھے تھے اور جنہیں کھجوروں کے درختوں سے ہم نے گھیر رکھا{2} تھا اور دونوں کے درمیان کھیتی لگا رکھی تھی.{3}",footnotes:1:[مفسرین کا اس میں اختلاف ہے کہ یہ دو شخص کون تھے؟ اللہ تعالٰی نے تفہیم کے لئے بطور مثال ان کا تذکرہ کیا ہے یا واقعی دو شخص ایسے تھے؟ اگر تھے تو یہ بنی اسرائیل میں گزرے ہیں یا اہل مکہ میں تھے، ان میں ایک مومن اور دوسرا کافر تھا۔,],footnotes:2:[- جس طرح چار دیواری کے ذریعے سے حفاظت کی جاتی ہے، اس طرح ان باغوں کے چاروں طرف کھجوروں کے درخت تھے، جو باڑ اور چار دیواری کا کام دیتے تھے۔,],footnotes:3:[- یعنی دونوں باغوں کے درمیان کھیتی تھی جن سے غلہ جات کی فصلیں حاصل کی جاتی تھیں۔ یوں دونوں باغ غلے اور میووں کے جامع تھے۔]
  18,33,"دونوں باغ اپنا پھل خوب ﻻئے اور اس میں کسی طرح کی کمی نہ کی{1} اور ہم نے ان باغوں کے درمیان نہر جاری کر رکھی تھی.{2}",footnotes:1:[یعنی اپنی پیداوار میں کوئی کمی نہیں کرتے تھے بلکہ بھرپور پیداوار دیتے تھے۔,],footnotes:2:[- تاکہ باغوں کو سیراب کرنے میں کوئی انقطاع واقع نہ ہو۔ یا بارانی علاقوں کی طرح بارش کے محتاج نہ رہیں۔]
