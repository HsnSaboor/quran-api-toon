quran[9]{c,v,t,f}:
  23,100,"کہ اپنی چھوڑی ہوئی دنیا میں جا کر نیک اعمال کر لوں{1}، ہرگز ایسا نہیں ہوگا{2}، یہ تو صرف ایک قول ہے جس کا یہ قائل{3} ہے، ان کے پس پشت تو ایک حجاب ہے، ان کے دوباره جی اٹھنے کے دن تک.{4}",footnotes:1:[یہ آرزو، ہر کافر موت کے وقت، دوبارہ اٹھائے جانے کے وقت، بارگاہ الٰہی میں قیامت کے وقت اور جہنم میں دھکیل دیئے جانے کے وقت کرتا ہے اور کرے گا، لیکن اس کا کوئی فائدہ نہیں ہوگا۔ قرآن کریم میں اس مضمون کو متعدد، جگہ بیان کیا گیا ہے۔ مثلاً   سورۂ منافقون:10-11،   ابراھیم:44،   اعراف: 53،    السجدة: 12۔     الانعام: 27-28۔الشوریٰ: 24۔ المؤمن: 11- 12۔ فاطر: 37 وغیرها من الآیات۔,],footnotes:2:[- کَلَّا، ڈانٹ ڈپٹ کے لئے ہے یعنی ایسا کبھی نہیں ہو سکتا کہ انہیں دوبارہ دنیا میں بھیج دیا جائے۔,],footnotes:3:[- اس کے ایک معنی تو یہ ہیں کہ ایسی بات ہے کہ جو ہر کافر نزع (جان کنی) کے وقت کہتا ہے۔ دوسرے معنی ہیں کہ یہ صرف بات ہی بات ہے عمل نہیں، اگر انہیں دوبارہ بھی دنیا میں بھیج دیا جائے تو ان کا یہ قول، قول ہی رہے گا عمل اصلاح کی توفیق انہیں پھر نصیب نہیں ہوگی،جیسے دوسرے مقام پر فرمایا: «وَلَوْ رُدُّوا لَعَادُوا لِمَا نُهُوا عَنْهُ» (  الأنعام ،28) ”اگر انہیں دنیا میں لوٹا دیا جائے تو یہ پھر وہی کام کریں گے جن سے انہیں منع کیا گیا تھا“۔ کافر دنیا میں اپنے خاندان اور قبیلے کے پاس جانے کی آرزو نہیں کرے گا، بلکہ عمل صالح کے لئے دنیا میں آنے کی آرزو کرے گا۔ اس لئے زندگی کے لمحات کو غنیمت جانتے ہوئے زیادہ سے زیادہ عمل صلاح کر لئے جائیں تاکہ کل قیامت کو یہ آرزو کرنے کی ضرورت پیش نہ آئے (ابن کثیر),],footnotes:4:[- دو چیزوں کے درمیان حجاب اور آڑ کو برزخ کہا جاتا ہے۔ دنیا کی زندگی اور آخرت کی زندگی کے درمیان جو وقفہ ہے، اسے یہاں برزخ سے تعبیر کیا گیا ہے۔ کیونکہ مرنے کے بعد انسان کا تعلق دنیا کی زندگی سے ختم ہو جاتا ہے اور آخرت کی زندگی کا آغاز اس وقت ہوگا جب تمام انسانوں کو دوبارہ زندہ کیا جائے گا۔ یہ درمیان کی زندگی ہے۔ انسان کا وجود جہاں بھی اور جس شکل میں بھی ہوگا، بظاہر وہ مٹی میں مل کر مٹی بن چکا ہوگا، یا راکھ بنا کر ہواؤں میں اڑا دیا یا دریاؤں میں بہا دیا ہوگا یا کسی جانور کی خوراک بن گیا ہوگا، مگر اللہ تعالٰی سب کو ایک نیا وجود عطا فرما کر میدان محشر میں جمع فرمائے گا۔]
  23,101,"پس جب کہ صور پھونک دیا جائے گا اس دن نہ تو آپس کے رشتے دار ہی رہیں گے، نہ آپس کی پوچھ گچھ.{1}.",footnotes:1:[محشر کی ہولناکیوں کی وجہ سے ابتداء ایسا ہوگا، بعد میں وہ ایک دوسرے کو پہچانیں گے بھی اور ایک دوسرے سے پوچھ گچھ بھی کریں گے۔]
  23,102,"جن کی ترازو کا پلہ بھاری ہوگیا وه تو نجات والے ہوگئے."
  25,46,"پھر ہم نے اسے آہستہ آہستہ اپنی طرف کھینچ لیا.{1}.",footnotes:1:[یعنی وہ سایہ آہستہ آہستہ ہم اپنی طرف کھینچ لیتے ہیں اور اس کی جگہ رات کا گمبھیر اندھیرا چھا جاتا ہے۔]
  25,47,"اور وہی ہے جس نے رات کو تمہارے لیے پرده بنایا{1}۔ اور نیند کو راحت بنائی{2}۔ اور دن کو اٹھ کھڑے ہونے کا وقت.{3}",footnotes:1:[یعنی لباس، جس طرح لباس انسانی دھانچے کو چھپالیتا ہے، اسی طرح رات تمہیں اپنی تاریکی میں چھپالیتی ہے۔,],footnotes:2:[- سبات کے معنی کاٹنےکے ہوتے ہیں۔ نیند انسان کے جسم کو عمل سے کاﭦ دیتی ہے، جس سےاس کو راحت میسر آتی ہے۔ بعض کےنزدیک سبات کے معنی تمدد پھیلنے کے ہیں۔ نیند میں بھی انسان دراز ہو جاتا ہے، اس لیے اسے سبات کہا (ایسرالتفاسیرو فتح القدیر)۔,],footnotes:3:[- یعنی نیند، جو موت کی بہن ہے، دن کو انسان اس نیند سے بیدار ہو کر کاروبار اور تجارت کے لیےپھراٹھ کھڑا ہوتا ہے۔ حدیث میں آتا ہے کہ نبی (صلى الله عليه وسلم) صبح بیدار ہوتے تو یہ دعا پڑھتے۔ «الْحَمْدِ للهِ الَّذِي أَحْيَانَا بَعْدَمَا أَمَاتَنَا وَإِلَيهِ النُّشُورُ» (رواه البخاري- مشكاة، كتاب الدعوات) ”تمام تعریفیں اس اللہ کے لیے ہیں جس نے ہمیں مارنے کے بعد زندہ کیا اور اسی کی طرف اکٹھے ہونا ہے“۔]
  25,48,"اور وہی ہے جو باران رحمت سے پہلے خوش خبری دینے والی ہواؤں کو بھیجتا ہے اور ہم آسمان سے پاک پانی برساتے ہیں.{1}.",footnotes:1:[طَهُورٌ (بِفَتْحِ الطَّاءِ) فعول کے وزن پر آلے کے معنی میں ہے یعنی ایسی چیز جس سے پاکیزگی حاصل کی جاتی ہے۔ جیسے وضو کے پانی کو وضو اورایندھن کو وقود کہا جاتا ہے، اس معنی میں پانی طاہر (خود بھی پاک) اور مطہر (دوسروں کو پاک کرنے والا) بھی ہے۔ حدیث میں بھی ہے «إِنَّ الْمَاءَ طَهُورٌ لا يُنَجِّسُه شَيْءٌ» (أبو داود والترمذي ـ نمبر 66 النسائي و ابن ماجه وصححه الألباني في السنن) ”پانی پاک ہے، اسے کوئی چیز ناپاک نہیں کرتی“ ہاں اگر اس کا رنگ یابو یاذائقہ بدل جائے تو ایسا پانی ناپاک ہے۔ كَمَا فِي الحَدِيثِ۔]
  26,19,"پھر تو اپنا وه کام کر گیا جو کر گیا اور تو ناشکروں میں ہے.{1}.",footnotes:1:[پھر ہمارا ہی کھا کر ہماری ہی قوم کے ایک آدمی کو قتل کرکے ہماری ناشکری بھی کی۔]
  26,20,"(حضرت) موسیٰ (علیہ السلام) نے جواب دیا کہ میں نے اس کام کو اس وقت کیا تھا جبکہ میں راه بھولے ہوئے لوگوں میں سے تھا.{1}.",footnotes:1:[یعنی یہ قتل ارادتاً نہیں تھا بلکہ ایک گھونسہ ہی تھا جو اسے مارا گیا تھا، جس سے اس کی موت ہی واقع ہوگئی۔ علاوہ ازیں یہ واقعہ بھی نبوت سے قبل کا ہے جب کہ مجھ کو علم کی یہ روشنی نہیں دی گئی تھی۔]
  26,21,"پھر تم سے خوف کھا کر میں تم میں سے بھاگ گیا، پھر مجھے میرے رب نے حکم و علم عطا فرمایا اور مجھے اپنے پیغمبروں میں سے کر دیا.{1}.",footnotes:1:[یعنی پہلے جو کچھ ہوا، اپنی جگہ، لیکن اب میں اللہ کا رسول ہوں، اگر میری اطاعت کرے گا تو بچ جائے گا، بصورت دیگر ہلاکت تیرا مقدر ہوگی۔]
