quran[18]{c,v,t,f}:
  50,43,"ہم ہی جلاتے ہیں اور ہم ہی مارتے ہیں{1} اور ہماری ہی طرف لوٹ پھر کر آنا ہے.{2}",footnotes:1:[یعنی دنیا میں موت سےہمکنار کرنا اور آخرت میں زندہ کر دینا، یہ ہمارا ہی کام ہے، اس میں کوئی ہمارا شریک نہیں ہے۔,],footnotes:2:[- وہاں ہم ہر شخص کو اس کے عملوں کے مطابق جزا دیں گے۔ٍ]
  50,44,"جس دن زمین پھٹ جائے گی اور یہ دوڑتے ہوئے{1} (نکل پڑیں گے) یہ جمع کر لینا ہم پر بہت ہی آسان ہے..",footnotes:1:[- یعنی اس آواز دینے والے کی طرف دوڑیں گے۔ جس نےآواز دی ہوگی۔ مُسْرِعِينَ إِلَى الْمُنَادِي الَّذِي نَادَاهُمْ (فتح القدير) نبی (صلى الله عليه وسلم) نے فرمایا، جب زمین پھٹے گی تو سب سے پہلے زندہ ہو کر نکلنے والا میں ہوں گا أَنَا أَوَّلُ مَنْ تَنْشَقُّ عَنْهُ الأَرْضُ (صحيح مسلم، كتاب الفضائل، باب تفضيل نبينا صلى الله عليه وسلم على جميع الخلائق)۔]
  50,45,"یہ جو کچھ کہہ رہے ہیں ہم بخوبی جانتے ہیں اور آپ ان پر جبر کرنے والے نہیں{1}، تو آپ قرآن کے ذریعے انہیں سمجھاتے رہیں جو میرے وعید (ڈرانے کے وعدوں) سے ڈرتے ہیں.{2}",footnotes:1:[یعنی آپ (صلى الله عليه وسلم) اس بات کے مکلف نہیں ہیں کہ ان کو ایمان لانے پر مجبور کریں۔ بلکہ آپ (صلى الله عليه وسلم) کا کام صرف تبلیغ ودعوت ہے، وہ کرتے رہیں۔,],footnotes:2:[- یعنی آپ (صلى الله عليه وسلم) کی دعوت وتذکیر سے وہی نصیحت حاصل کرے گا جو اللہ سے اور اس کی وعیدوں سے ڈرتا اور اس کے وعدوں پر یقین رکھتا ہوگا۔ اسی لئےحضرت قتادہ یہ دعا فرمایا کرتے تھے «اللَّهُمَّ اجْعَلْنَا مِمَّنْ يَخَافُ وَعِيدَكَ ، وَيَرْجُو مَوْعُودَكَ يَا بَارُّ يَا رَحِيمُ» ”اے اللہ ہمیں ان لوگوں میں سےکر جو تیرے وعیدوں سے ڈرتے اور تیرے وعدوں کی امید رکھتے ہیں۔ اے احسان کرنے والے رحم فرمانے والے“۔]
  51,37,"اور وہاں ہم نے ان کے لیے جو درد ناک عذاب کا ڈر رکھتے ہیں ایک (کامل) علامت چھوڑی.{1}.",footnotes:1:[یہ آیت یا کامل علامت وہ آثار عذاب ہیں جو ان ہلاک شدہ بستیوں میں ایک عرصے تک باقی رہے۔ اور یہ علامت بھی انہی کے لیے ہیں جو عذاب الٰہی سے ڈرنے والے ہیں، کیونکہ وعظ ونصیحت کا اثر بھی وہی قبول کرتے اور آیات میں غور وفکر بھی وہی کرتے ہیں۔]
  51,38,"موسیٰ (علیہ السلام کے قصے) میں (بھی ہماری طرف سے تنبیہ ہے) کہ ہم نے اسے فرعون کی طرف کھلی دلیل دے کر بھیجا."
  51,39,"پس اس نےاپنے بل بوتے پر منھ موڑا{1} اور کہنے لگا یہ جادوگر ہے یا دیوانہ ہے..",footnotes:1:[جانب اقویٰ کو رکن کہتے ہیں۔ یہاں مراد اس کی اپنی قوت اور لشکر ہے۔]
  52,28,"ہم اس سے پہلے ہی اس کی عبادت کیا کرتے تھے{1}، بیشک وه محسن اور مہربان ہے..",footnotes:1:[یعنی صرف اسی ایک کی عبادت کرتے تھے، اس کے ساتھ کسی کو شریک نہیں ٹھہراتے تھے، یا یہ مطلب ہے کہ اسی سے عذاب جہنم سے بچنے کے لیے دعا کرتے تھے۔]
  52,29,"تو آپ سمجھاتے رہیں کیونکہ آپ اپنے رب کے فضل سے نہ تو کاہن ہیں نہ دیوانہ.{1}.",footnotes:1:[اس میں نبی صلی اللہ علیہ وسلم کو تسلی دی جا رہی ہے کہ آپ وعظ وتبلیغ اورنصیحت کا کام کرتے رہیں اور یہ آپ کی بابت جوکچھ کہتے رہتےہیں، ان کی طرف کان نہ دھریں، اس لیے کہ آپ اللہ کے فضل سےکاہن ہیں نہ دیوانہ (جیساکہ یہ کہتے ہیں) بلکہ آپ پر باقاعدہ ہماری طرف سے وحی آتی ہے، جو کہ کاہنپر نہیں آتی، آپ جو کلام لوگوں کو سناتے ہیں، وہ دانش وبصیرت کا آئینہ دارہوتا ہے، ایک دیوانے سے اس طرح گفتگو کیونکر ممکن ہے؟]
  52,30,"کیا کافر یوں کہتے ہیں کہ یہ شاعر ہے ہم اس پر زمانے کے حوادث (یعنی موت) کا انتظار کر رہے ہیں.{1}.",footnotes:1:[رَيْبٌ کے معنی ہیں حوادث ، مَنُونٌ، موت کےناموں میں سے ایک نام ہے۔ مطلب ہے کہ قریش مکہ اس انتظار میں ہیں کہ زمانے کےحوادث سے شاید اس محمد (صلی اللہ علیہ وسلم) کو موت آ جائے اور ہمیں چین نصیب ہو جائے، جو اس کی دعوت توحید نے ہم سے چھین لیاہے۔]
  53,22,"یہ تو اب بڑی بےانصافی کی تقسیم ہے.{1}.",footnotes:1:[ضِيزَى حق وصواب سے ہٹی ہوئی۔]
  53,23,"دراصل یہ صرف نام ہیں جو تم نے اور تمہارے باپ دادوں نے ان کے رکھ لیے ہیں اللہ نے ان کی کوئی دلیل نہیں اتاری۔ یہ لوگ تو صرف اٹکل کے اور اپنی نفسانی خواہشوں کے پیچھے پڑے ہوئے ہیں۔ اور یقیناً ان کے رب کی طرف سے ان کے پاس ہدایت آ چکی ہے."
  53,24,"کیا ہر شخص جو آرزو کرے اسے میسر ہے؟{1}.",footnotes:1:[یعنی یہ جو چاہتے ہیں کہ ان کے یہ معبود انہیں فائدہ پہنچائیں اور ان کی سفارش کریں یہ ممکن ہی نہیں ہے۔]
  54,13,"اور ہم نے اسے تختوں اور کیلوں والی (کشتی) پر سوار کر لیا.{1}.",footnotes:1:[دُسُرٌ دِسَارٌ کی جمع، وہ رسیاں، جن سے کشتی کے تحتے باندھے گئے یا وہ کیلیں اورمیخیں جن سے کشتی کو جوڑا گیا۔]
  54,14,"جو ہماری آنکھوں کے سامنے چل رہی تھی۔ بدلہ اس کی طرف سے جس کا کفر کیا گیا تھا."
  54,15,"اور بیشک ہم نے اس واقعہ کو نشانی بنا کر{1} باقی رکھا پس کوئی ہے نصیحت حاصل کرنے واﻻ.{2}",footnotes:1:[تَرَكْنَاهَا میں ضمیر کا مرجع سفینہ ہے۔ یا فعلہ یعنی تَرَكْنَا هَذِهِ الْفِعْلَةَ الَّتِي فَعَلْنَاهَا بِهِمْ عِبْرَةً وَّمَوْعِظَةً (فتح القدير)۔,],footnotes:2:[- مُدَّكِرٍ،اصل میں مُذْتَكِرٍ ہے۔ تاکو ڈال سے بدل دیا گیا اور ذال معجمہ کو دال بناکر، دال کا دال میں ادغام کر دیا گیا۔ معنی ہیں عبرت پکڑنے اورنصیحت حاصل کرنے والا۔ (فتح القدیر)۔]
  55,7,"اسی نے آسمان کو بلند کیا اور اسی نے ترازو رکھی.{1}.",footnotes:1:[یعنی زمین میں انصاف رکھا، جس کا اس نے لوگوں کو حکم دیا، جیسے فرمایا: لَقَدْ أَرْسَلْنَا رُسُلَنَا بِالْبَيِّنَاتِ وَأَنْزَلْنَا مَعَهُمُ الْكِتَابَ وَالْمِيزَانَ لِيَقُومَ النَّاسُ بِالْقِسْطِ (الحديد: 25)۔]
  55,8,"تاکہ تم تولنے میں تجاوز نہ کرو.{1}.",footnotes:1:[- یعنی انصاف سے تجاوز نہ کرو۔]
  55,9,"انصاف کے ساتھ وزن کو ٹھیک رکھو اور تول میں کم نہ دو."