quran[9]{c,v,t,f}:
  23,103,"اور جن کے ترازو کا پلہ ہلکا ہوگیا یہ ہیں وه جنہوں نے اپنا نقصان آپ کر لیا جو ہمیشہ کے لئے جہنم واصل ہوئے."
  23,104,"ان کے چہروں کو آگ جھلستی رہے گی{1} اور وه وہاں بدشکل بنے ہوئے ہوں گے.{2}",footnotes:1:[چہرے کا ذکر اس لئے کیا ہے کہ یہ انسانی وجود کا سب سے اہم اور اشرف حصہ ہے، ورنہ جہنم تو پورے جسم کو ہی محیط ہوگی۔,],footnotes:2:[- کَلَحً کے معنی ہوتے ہیں ہونٹ سکڑ کر دانت ظاہر ہو جائیں۔ ہونٹ گویا دانتوں کا لباس ہیں، جب یہ جہنم کی آگ سے سمٹ اور سکڑ جائیں گے تو دانت ظاہر ہو جائیں گے، جس سے انسان کی صورت بدشکل اور ڈراؤنی ہو جائے گی۔]
  23,105,"کیا میری آیتیں تمہارے سامنے تلاوت نہیں کی جاتی تھیں؟ پھر بھی تم انہیں جھٹلاتے تھے."
  25,49,"تاکہ اس کے ذریعے سے مرده شہر کو زنده کردیں اوراسے ہم اپنی مخلوقات میں سے بہت سے چوپایوں اور انسانوں کو پلاتے ہیں."
  25,50,"اور بے شک ہم نے اسےان کے درمیان طرح طرح سے بیان کیا تاکہ{1} وه نصیحت حاصل کریں، مگر پھر بھی اکثر لوگوں نے سوائے ناشکری کے مانا نہیں.{2}",footnotes:1:[یعنی قرآن کریم کو۔ اور بعض نے صَرَّفْنَاه ُ ہ میں ھا کا مرجع بارش قرار دیا ہے، جس کا مطلب یہ ہوگا کہ بارش کو ہم پھیر پھیر کر برساتے ہیں یعنی کبھی ایک علاقے میں، کبھی دوسرے علاقے میں۔ حتیٰ کہ بعض دفعہ ایسا بھی ہوتا ہے کہ کبھی ایک ہی شہر کے ایک حصے میں بارش ہوتی ہے، دوسروں میں نہیں ہوتی اور کبھی دوسرے حصوں میں ہوتی ہے، پہلے حصے میں نہیں ہوتی یہ اللہ کی حکمت و مشیت ہے، وہ جس طرح چاہتا ہے، کہیں بارش برساتا ہے اور کہیں نہیں اور کبھی کسی علاقے میں اور کبھی کسی اور علاقے میں۔,],footnotes:2:[- اور ایک کفر اور ناشکری یہ بھی ہے کہ بارش کو مشیت الٰہی کی بجائے ستاروں کی گردش کا نتیجہ قرار دیا جائے، جیسا کہ اہل جاہلیت کہا کرتے تھے۔ کما فی الحدیث۔]
  25,51,"اگر ہم چاہتے تو ہر بستی میں ایک ڈرانے واﻻ بھیج{1} دیتے..",footnotes:1:[لیکن ہم نے ایسا نہیں کیا اور صرف آپ کو ہی تمام بستیوں بلکہ تمام انسانوں کے لیے نذیر بنا کر بھیجا ہے۔]
  26,22,"مجھ پر تیرا کیا یہی وه احسان ہے؟ جسے تو جتا رہا ہے جبکہ تو نے بنی اسرائیل کو غلام بنا رکھا ہے.{1}.",footnotes:1:[- یعنی یہ اچھا احسان ہے جو تو مجھے جتلا رہاہے کہ مجھے تو یقیناً تو نے غلام نہیں بنایا اور آزاد چھوڑے رکھا لیکن میری پوری قوم کو غلام بنا رکھا ہے۔ اس ظلم عظیم کے مقابلے میں اس احسان کی آخر حیثیت کیا ہے؟]
  26,23,"فرعون نے کہا رب العالمین کیا (چیز) ہے؟{1}.",footnotes:1:[یہ اس نے بطور استفہام کے نہیں ، بلکہ استکبار اور استنکار کے طور پر کہا ، کیونکہ اس کا دعوی تو یہ تھا«مَا عَلِمْتُ لَكُمْ مِنْ إِلَهٍ غَيْرِي» ( القصص۔ 38) «میں اپنے سوا تمہارے لئے کوئی اور معبود جانتا ہی نہیں»۔]
  26,24,"(حضرت) موسیٰ (علیہ السلام) نے فرمایا وه آسمانوں اور زمین اور ان کے درمیان کی تمام چیزوں کا رب ہے، اگر تم یقین رکھنے والے ہو."