quran[30]{c,v,t,f}:
  74,18,"اس نے غور کرکے تجویز کی.{1}",footnotes:1:[یعنی قرآن اور نبی (صلى الله عليه وسلم) کا پیغام سن کر، اس نے اس امر پر غور کیا کہ میں اس کا جواب دوں؟ اور اپنے جی میں اس نے وہ تیار کیا۔]
  74,19,"اسے ہلاکت ہو کیسی (تجویز) سوچی؟"
  74,20,"وه پھر غارت ہو کس طرح اندازه کیا.{1}",footnotes:1:[یہ اس کے حق میں بد دعائیہ کلمے ہیں، کہ ہلاک ہو، مارا جائے، کیا بات اس نے سوچی ہے؟]
  74,21,"اس نے پھر دیکھا.{1}",footnotes:1:[یعنی پھر غور کیا کہ قرآن کا رو کس طرح ممکن ہے۔]
  74,22,"پھر تیوری چڑھائی اور منھ بنایا.{1}",footnotes:1:[یعنی جواب سوچتے وقت چہرے کی سلوٹیں بدلیں، اور منہ بسورا، جیسا کہ عمومًا کسی مشکل بات پر غور کرتے وقت آدمی ایسا کرتا ہے۔]
  74,23,"پھر پیچھے ہٹ گیا اور غرور کیا.{1}",footnotes:1:[یعنی حق سے اعرض کیا اور ایمان لانے سے تکبر کیا۔]
  74,24,"اور کہنے لگا تو یہ صرف جادو ہے جو نقل کیا جاتا ہے.{1}",footnotes:1:[یعنی کسی سے یہ سیکھ آیا ہے اور وہاں سے نقل کر لایا ہے اور دعویٰ کر دیا کہ اللہ کا نازل کردہ ہے۔]
  74,25,"سوائے انسانی کلام کے کچھ بھی نہیں ہے."
  74,26,"میں عنقریب اسے دوزخ میں ڈالوں گا."
  74,27,"اور تجھے کیا خبر کہ دوزخ کیا چیز ہے؟{1}",footnotes:1:[دوزخ کے ناموں یا درجات ایک کا نام سَقَرُ بھی ہے۔]
  74,28,"نہ وه باقی رکھتی ہے نہ چھوڑتی ہے.{1}",footnotes:1:[ان کے جسموں پر گوشت چھوڑے گی نہ ہڈی، یا مطلب ہے جہنمیوں کو زندہ چھوڑے گی نہ مردہ'لا یموت فیھا و لا یحیٰ]
  74,29,"کھال کو جھلسا دیتی ہے."
  74,30,"اور اس میں انیس (فرشتے مقرر) ہیں.{1}",footnotes:1:[یعنی جہنم پر بطور دربان ١٩ فرشتے مقرر ہیں]
  74,31,"ہم نے دوزخ کے داروغے صرف فرشتے رکھے ہیں۔ اور ہم نے ان کی تعداد صرف کافروں کی آزمائش کے لیے مقرر کی ہے{1} تاکہ اہل کتاب یقین کرلیں{2}، اوراہل ایمان کے ایمان میں اضافہ ہو جائے{3} اور اہل کتاب اور اہل ایمان شک نہ کریں اور جن کے دلوں میں بیماری ہے وه اور کافر کہیں کہ اس بیان سے اللہ تعالیٰ کی کیا مراد ہے{4}؟ اسی طرح اللہ تعالیٰ جسے چاہتا ہے گمراه کرتا ہے اور جسے چاہتا ہے ہدایت دیتا ہے{5}۔ تیرے رب کے لشکروں کو اس کے سوا کوئی نہیں جانتا{6}، یہ تو کل بنی آدم کے لیے سراسر پند ونصیحت ہے.{7}",footnotes:1:[<strong>انیس کے عدد پر کفّار کا استہزاء اور اس کا جواب:</strong>انیس کا عدد سن کر مشرکین ٹھٹھا کرنے لگے کہ ہم ہزاروں ہیں۔ انیس ہمارا کیا کر لیں گے۔ بہت ہوا ہم میں سے دس دس ان کے ایک ایک کے مقابلہ میں ڈٹ جائیں گے۔ ایک پہلوان بولا کہ سترہ کو تو میں اکیلا کافی ہوں، دو کا تم مل کر تیا پانچا کر لینا۔ اس پر یہ آیت اتری۔ یعنی وہ انیس تو ہیں مگر آدمی نہیں فرشتہ ہیں۔ جن کی قوت کا یہ حال ہے کہ ایک فرشتہ نے قوم لُوط کی ساری بستی کو ایک بازو پر اٹھا کر پٹک دیا تھا۔,],footnotes:2:[<strong>اس عدد میں حکمت ہے:</strong>یعنی کافروں کو عذاب دینے کے لئے انیس کی گنتی خاص حکمت سے رکھی ہے جس کی طرف عَلَیْھَا تِسْعَۃَ عَشَرَ کے فائدہ میں اشارہ کیا جاچکا ہے اور اس گنتی کے بیان کرنے میں منکروں کی جانچ ہے۔ دیکھتے ہیں کہ کون اس کو سن کر ڈرتا ہے اور کون ہنسی مذاق اڑاتا ہے۔,],footnotes:3:[<strong>استیقانِ اہل کتاب:</strong>اہل کتاب کو پہلے سے یہ عدد معلوم ہوگا جیسا کہ ترمذی کی ایک روایت میں ہے یا کم از کم کتب سماویہ کے ذریعہ اتنا تو جانتے تھے کہ فرشتوں میں کس قدر طاقت ہے۔ انیس بھی تھوڑے نہیں۔ اور یہ کہ انواعِ تعذیب کے اعتبار سے مختلف فرشتے دوزخ پر مامور ہونے چاہئیں یہ کام تنہا ایک کا نہیں بہر حال اس بیان سے اہل کتاب کے دلوں میں قرآن کی حقیت کا یقین پیدا ہوگا۔ اور یہ دیکھ کر مومنین کا ایمان بڑھے گا اور ان دونوں جماعتوں کو قرآن کے بیان میں کوئی شک و تردد نہیں رہیگا۔ نہ مشرکین کے استہزاء و تمسخر سے وہ کچھ دھوکا کھائیں گے۔,],footnotes:4:[ الَّذِیْنَ فِیْ قُلُوْبِھِمْ مَّرَضٌ سے منافقین یا ضعیف الایمان مراد ہیں اور الْکٰفِرُوْنَ سے کھلے ہوئے منکر۔,],footnotes:5:[یعنی انیس کے بیان سے کیا غرض تھی۔ بھلا ایسی بے تکی اور غیر موزوں بات کو کون مان سکتا ہے۔ (العیاذ باللہ)۔,],footnotes:6:[یعنی ایک ہی چیز سے بداستعداد آدمی گمراہ ہوجاتا ہے اور سلیم الطبع راہ پالیتا ہے جسے ماننا مقصود نہ ہو وہ کام کی بات کو ہنسی مذاق میں اڑا دیتا ہے اور جس کے دل میں خوف خدا اور نور توفیق ہو اس کے ایمان و یقین میں ترقی ہوتی ہے۔,],footnotes:7:[<strong>اللہ کے لشکر:</strong>یعنی اللہ کے بیشمار لشکروں کی تعداد اسی کو معلوم ہے۔ انیس تو صرف کارکنان جہنم کے افسر بتلائے ہیں۔]
  74,32,"سچ کہتا ہوں{1} قسم ہے چاند کی.{2}",footnotes:1:[کلا یہ اہل مکہ کے خیالات کی نفی ہے یعنی جو وہ سمجھتے ہیں کہ ہم فرشتوں کو مغلوب کر لیں گے ہر گز ایسا نہیں ہوگا۔,],footnotes:2:[]
  74,33,"اور رات کی جب وه پیچھے ہٹے."
  74,34,"اور صبح کی جب کہ روشن ہو جائے."
  74,35,"کہ (یقیناً وه جہنم) بڑی چیزوں میں سے ایک ہے.{1}",footnotes:1:[یہ جواب قسم ہے کُبَر، کُبْرَیٰ کی جمع ہے تین نہایت اہم چیزوں کی قسموں کے بعد اللہ نے جہنم کی بڑائی اور ہولناکی کو بیان کیا ہے جس سے اس کی بڑائی میں کوئی شک نہیں رہتا۔]
  74,36,"بنی آدم کو ڈرانے والی."
  74,37,"(یعنی) اسے{1} جو تم میں سے آگے بڑھنا چاہے یا پیچھے ہٹنا چاہے.{2}",footnotes:1:[یعنی یہ جہنم ڈرانے والی ہے یا نذیر سے مراد نبی کریم (صلى الله عليه وسلم) ہیں یا قرآن بھی اپنے بیان کردہ وعد و وعید کے اعتبار سے انسانوں کے لئے نذیر ہے۔,],footnotes:2:[یعنی ایمان واطاعت میں آگے بڑھنا چاہیے یا اس سے پیچھے ہٹنا چاہیے مطلب ہے کہ انداز ہر ایک کے لیے ہے جو ایمان لائے یا کفر کرے۔]
  74,38,"ہر شخص اپنے اعمال کے بدلے میں گروی ہے.{1}",footnotes:1:[رہن گروی کو کہتے ہیں یعنی ہر شخص اپنے عمل کا گروی ہے، وہ عمل اسے عذاب سے چھڑا لے گا، (اگر نیک ہوگا) یا ہلاک کروا دے گا۔ (اگر برا ہے)]
  74,39,"مگر دائیں ہاتھ والے.{1}",footnotes:1:[یعنی وہ اپنے گناہوں کے اسیر نہیں ہوں گے بلکہ اپنے نیک اعمال کی وجہ سے آزاد ہونگے۔]
  74,40,"کہ وه بہشتوں میں (بیٹھے ہوئے) گناه گاروں سے."
  74,41,"سوال کرتے ہوں گے.{1}",footnotes:1:[فی الجنات،اصحاب الیمین سے غال ہےاہل جنت بالاخانوں میں بیٹھے، جہنمیوں سے سوال کریں گے۔]
  74,42,"تمہیں دوزخ میں کس چیز نے ڈاﻻ."
  74,43,"وه جواب دیں گے کہ ہم نمازی نہ تھے."
  74,44,"نہ مسکینوں کو کھانا کھلاتے تھے.{1}",footnotes:1:[نماز حقوق اللہ میں سے اور مساکین کو کھانا کھلانا حقوق العباد میں سے ہے مطلب یہ ہوا کہ ہم نے اللہ کے حقوق ادا کیے نہ بندوں کے۔]
  74,45,"اور ہم بحﺚ کرنے والے (انکاریوں) کا ساتھ دے کر بحﺚ مباحثہ میں مشغول رہا کرتے تھے.{1}",footnotes:1:[یعنی کج بحثی اور گمراہی کی حمایت میں سرگرمی سے حصہ لیتے تھے۔]
  74,46,"اور روز جزا کو جھٹلاتے تھے."
  74,47,"یہاں تک کہ ہمیں موت آگئی.{1}",footnotes:1:[یقین کے معنی موت کے ہیں، جیسے دوسرے مقام پر ہے۔ واعبد ربک حتی یاتیک الیقین» (الحجر: 99)]
