quran[18]{c,v,t,f}:
  88,19,"اور پہاڑوں کی طرف کہ کس طرح گاڑ دیئے گئے ہیں.{1}.",footnotes:1:[یعنی کس طرح انہیں زمین پر میخوں کی طرح گاڑ دیا گیا ہے تاکہ زمین حرکت نہ کرے۔ نیز ان میں جو معدنیات اور دیگر منافع ہیں، وہ اس کے علاوہ ہیں۔]
  88,20,"اور زمین کی طرف کہ کس طرح بچھائی گئی ہے.{1}.",footnotes:1:[یعنی کس طرح اسے ہموار کرکے انسان کے رہنے کے قابل بنایا ہے، وہ اس پر چلتا پھرتا، کاروبار کرتا اور فلک بوس عمارتیں تعمیر کرتا ہے۔]
  88,21,"پس آپ نصیحت کر دیا کریں (کیونکہ) آپ صرف نصیحت کرنے والے ہیں.{1}.",footnotes:1:[یعنی آپ کا کام صرف تذکیر اور تبلیغ ودعوت ہے، اس کے علاوہ یا اس سے بڑھ کر نہیں۔]
  89,16,"اور جب وه اس کو آزماتا ہے اس کی روزی تنگ کر دیتا ہے تو وه کہنے لگتا ہے کہ میرے رب نے میری اہانت کی (اور ذلیل کیا).{1}.",footnotes:1:[یعنی وہ تنگی میں مبتلا کرکے آزماتا ہے تو اللہ کے بارے میں بدگمانی کا اظہار کرتا ہے۔]
  89,17,"ایسا ہرگز نہیں بلکہ (بات یہ ہے) کہ تم (ہی) لوگ یتیموں کی عزت نہیں کرتے.{1}.",footnotes:1:[یعنی بات اس طرح نہیں ہے جیسے لوگ سمجھتے ہیں۔ اللہ تعالیٰ مال اپنے محبوب بندوں کو بھی دیتا ہے اور ناپسندیدہ افراد کو بھی، تنگی میں بھی وہ اپنوں اور بیگانوں دونوں کو مبتلا کرتا ہے۔ اصل مدار دونوں حالتوں میں اللہ کی اطاعت پر ہے۔ جب اللہ مال دے تو اللہ کا شکر کرے، تنگی آئے تو صبر کرے۔]
  89,18,"اور مسکینوں کے کھلانے کی ایک دوسرے کو ترغیب نہیں دیتے."
  90,10,"ہم نے دکھا دیئے اس کو دونوں راستے.{1}.",footnotes:1:[یعنی خیر کی بھی اور شر کی بھی اور ایمان کی بھی، سعادت کی بھی اور شقاوت کی بھی۔ جیسے فرمایا، إِنَّا هَدَيْنَاهُ السَّبِيلَ إِمَّا شَاكِرًا وَإِمَّا كَفُورًا (الدهر: 3 ) نَجْدٌ کے معنی ہیں، اونچی جگہ۔ اس لئے بعض نے یہ ترجمہ کیا ہے ”ہم نے انسان کی ( ماں کے ) دو پستانوں کی طرف رہنمائی کر دی“ یعنی وہ عالم شیر خوارگی میں ان سے اپنی خوراک حاصل کرے۔ لیکن پہلا مفہوم زیادہ صحیح ہے۔]
  90,11,"سو اس سے نہ ہو سکا کہ گھاٹی میں داخل ہوتا.{1}.",footnotes:1:[عَقَبَةٌ گھاٹی کو کہتے ہیں یعنی وہ راستہ جو پہاڑ میں ہو۔ یہ عام طور پر نہایت دشوار گزار ہوتا ہے۔ یہ جملہ یہاں استفہام بمعنی انکار کے مفہوم میں ہے۔ یعنی أَفَلا اقْتَحَمَ الْعَقَبَةَ کیا وہ گھاٹی میں داخل نہیں ہوا؟ مطلب ہے نہیں ہوا۔ یہ ایک مثال ہے اس محنت ومشقت کی وضاحت کے لئے جو نیکی کے کاموں کے لئے ایک انسان کو شیطان کے وسوسوں اور نفس کے شہوانی تقاضوں کے خلاف کرنی پڑتی ہے، جیسے گھاٹی پر چڑھنے کے لئے سخت جد وجہد کی ضرورت ہوتی ہے۔ (فتح القدیر) ۔]
  90,12,"اور کیا سمجھا کہ گھاٹی ہے کیا؟."
  91,7,"قسم ہے نفس کی اور اسے درست بنانے کی.{1}.",footnotes:1:[یا جس نے اسے درست کیا۔ درست کرنے کا مطلب ہے، اسے متناسب الاعضاء بنایا، بےڈھبا اور بےڈھنگا نہیں بنایا۔]
  91,8,"پھر سمجھ دی اس کو بدکاری کی اور بچ کر چلنے کی.{1}.",footnotes:1:[الہام کا مطلب یا تو یہ ہے کہ انہیں اچھی طرح سمجھا دیا اور انہیں انبیا علیہم السلام اور آسمانی کتابوں کے ذریعے سے خیر وشر کی پہچان کروا دی۔ یا مطلب ہے کہ ان کی عقل اور فطرت میں خیر اور شر، نیکی اور بدی کا شعور ودیعت کر دیا۔ تاکہ وہ نیکی کو اپنائیں اور بدی سے اجتناب کریں۔]
  91,9,"جس نے اسے پاک کیا وه کامیاب ہوا.{1}.",footnotes:1:[شرک سے، معصیت سے اور اخلاقی آلائشوں سے پاک کیا، وہ آخروی فوز وفلاح سے ہمکنار ہوگا۔]
  92,4,"یقیناً تمہاری کوشش مختلف قسم کی ہے.{1}.",footnotes:1:[یعنی کوئی اچھے عمل کرتا ہے، جس کا صلہ جنت ہے اور کوئی برے عمل کرتا ہے جس کا بدلہ جہنم ہے۔ یہ جواب قسم ہے شَتَّى، شَتِيتٌ کی جمع ہے، جیسے مَرِيضٌ کی جمع مَرْضَى۔]
  92,5,"جس نے دیا (اللہ کی راه میں) اور ڈرا (اپنے رب سے).{1}.",footnotes:1:[یعنی خیر کے کاموں میں خرچ کرے گا اور محارم سے بچے گا۔]
  92,6,"اور نیک بات کی تصدیق کرتا رہے گا.{1}.",footnotes:1:[یا اچھے صلے کی تصدیق کرے گا، یعنی اس بات پر یقین رکھے گا کہ انفاق اور تقویٰ کا اللہ کی طرف سے عمدہ صلہ ملے گا۔]
  93,1,"قسم ہے چاشت کے وقت کی.{1}.",footnotes:1:[چاشت ( ضُحًى) اس وقت کو کہتے ہیں، جب سورج بلند ہوتا ہے۔ یہاں مراد پورا دن ہے۔]
  93,2,"اور قسم ہے رات کی جب چھا جائے.{1}.",footnotes:1:[سَجَى کے معنی ہیں سکن، جب ساکن ہو جائے۔ یعنی جب اندھیرا مکمل چھا جائے، کیونکہ اس وقت ہر چیز ساکن ہو جاتی ہے۔]
  93,3,"نہ تو تیرے رب نے تجھے چھوڑا ہے اور نہ وه بیزار ہو گیا ہے.{1}.",footnotes:1:[جیسا کہ کافر سمجھ رہے ہیں۔]
