quran[15]{c,v,t,f}:
  37,151,"آگاه رہو! کہ یہ لوگ صرف اپنی افترا پردازی سے کہہ رہے ہیں."
  37,152,"کہ اللہ تعالی کی اوﻻد ہے۔ یقیناً یہ محض جھوٹے ہیں."
  37,153,"کیا اللہ تعالی نے اپنے لیے بیٹیوں کو بیٹوں پر ترجیح دی.{1}.",footnotes:1:[جب کہ یہ خود اپنے لئے بیٹیاں نہیں، بیٹے پسند کرتے ہیں۔]
  43,40,"کیا پس تو بہرے کو سنا سکتا ہے یا اندھے کو راه دکھا سکتا ہے اور اسے جو کھلی گمراہی میں ہو.{1}.",footnotes:1:[یعنی جس کے لیے شقاوت ابدی لکھ دی گئی ہے، وہ وعظ ونصیحت کے اعتبار سے بہرہ اور اندھا ہے، تیری دعوت وتبلیغ سے وہ راہ راست پر نہیں آسکتا۔ یہ استفہام انکاری ہے۔ جس طرح بہرہ سننے سے، نابینا دیکھنے سے محروم ہے، اسی طرح کھلی گمراہی میں مبتلا حق کی طرف آنے سے محروم ہے۔ یہ نبی (صلى الله عليه وسلم) کو تسلی ہے تاکہ ایسے لوگوں کے کفر سے آپ زیادہ تشویش محسوس نہ کریں۔]
  43,41,"پس اگر ہم تجھے یہاں سے{1} لے بھی جائیں تو بھی ہم ان سے بدلہ لینے والے ہیں.{2}",footnotes:1:[یعنی تجھے موت آجائے، قبل اس کے کہ ان پر عذاب آئے، یا تجھے مکے سے نکال لے جائیں۔,],footnotes:2:[- دنیا میں ہی، اگر ہماری مشیت متقاضی ہوئی، بصورت دیگر عذاب اخروی سے تو وہ کسی صورت نہیں بچ سکتے۔]
  43,42,"یا جو کچھ ان سے وعده کیا ہے{1} وه تجھے دکھا دیں ہم ان پر بھی قدرت رکھتے ہیں.{2}",footnotes:1:[یعنی تیری موت سے قبل ہی، یا مکے میں ہی تیرے رہتے ہوئے ان پر عذاب بھیج دیں۔,],footnotes:2:[- یعنی ہم جب چاہیں ان پر عذاب نازل کرسکتے ہیں، کیونکہ ہم ان پر قادر ہیں۔ چنانچہ آپ کی زندگی میں ہی بدر کی جنگ میں کافر عبرت ناک شکست، اور ذلت سے دوچار ہوئے۔]
  44,25,"وه بہت سے باغات{1} اور چشمے چھوڑ گئے..",footnotes:1:[كَمْ، خبر یہ ہے جو تکثیر کا فائدہ دیتا ہے۔ دریائے نیل کے دونوں طرف باغات اور کھیتوں کی کثرت تھی، عالی شان مکانات اور خوش حالی کے آثار تھے۔ سب کچھ یہیں دنیا میں ہی رہ گیا اور عبرت کے لیے صرف فرعون اور اس کی قوم کا نام رہ گیا۔]
  44,26,"اور کھیتیاں اور راحت بخش ٹھکانے."
  44,27,"اور وه آرام کی چیزیں جن میں عیش کررہے تھے."
  45,16,"یقیناً ہم نے بنی اسرائیل کو کتاب، حکومت{1} اور نبوت دی تھی، اور ہم نے انہیں پاکیزه (اور نفیس) روزیاں دی تھیں{2} اور انہیں دنیا والوں پر فضیلت دی تھی.{3}",footnotes:1:[کتاب سے مراد تورات، حکم سے حکومت وبادشاہت یا فہم وقضا کی وہ صلاحیت ہے جو فصل خصومات اور لوگوں کے درمیان فیصلے کرنے کے لیے ضروری ہے۔,],footnotes:2:[- وہ روزیاں جو ان کے لیے حلال تھیں اور ان ہی میں من وسلویٰ کا نزول بھی تھا۔,],footnotes:3:[- یعنی ان کے زمانے کے اعتبار سے۔]
  45,17,"اور ہم نے انہیں دین کی صاف صاف دلیلیں دیں{1}، پھر انہوں نے اپنے پاس علم کے پہنچ جانے کے بعد آپس کی ضد بحﺚ سے ہی اختلاف برپا کر ڈاﻻ{2}، یہ جن جن چیزوں میں اختلاف کر رہے ہیں ان کا فیصلہ قیامت والے دن ان کے درمیان (خود) تیرا رب کرے گا.{3}",footnotes:1:[کہ یہ حلال ہیں اور یہ حرام۔ یا معجزات مراد ہیں۔ یا نبی (صلى الله عليه وسلم) کی بعثت کا علم، آپ کی نبوت کے شواہد اور آپ کی ہجرت گاہ کی تعیین مراد ہے۔,],footnotes:2:[- بَغْيًا بَيْنَهُمْ کا مطلب، آپس میں ایک دوسرے سے حسد اور بغض وعناد کا مظاہرہ کرتے ہوئے یا جاہ ومنصب کی خاطر۔ انہوں نے اپنے دین میں، علم آجانے کے باوجود، اختلاف یا نبی (صلى الله عليه وسلم) کی رسالت سے انکار کیا۔,],footnotes:3:[- یعنی اہل حق کو اچھی جزا اور اہل باطل کو بری جزا دے گا۔]
  45,18,"پھر ہم نے آپ کو دین کی (ﻇاہر) راه پر قائم کردیا{1}، سو آپ اسی پر لگے رہیں اور نادانوں کی خواہشوں کی پیروی میں نہ پڑیں.{2}",footnotes:1:[شریعت کے لغوی معنی ہیں، راستہ ملت اور منہاج۔ شاہراہ کو بھی شارع کہا جاتا ہے کہ وہ مقصد ومنزل تک پہنچاتی ہے۔ پس شریعت سے یہاں مراد، وہ دین ہے جو اللہ نے اپنے بندوں کے لیے مقرر فرمایا ہے تاکہ لوگ اس پر چل کر اللہ کی رضا کا مقصد حاصل کرلیں۔ آیت کا مطلب ہے۔ ہم نے آپ کو دین کے ایک واضح راستے یا طریقے پر قائم کردیا ہے جو آپ کو حق تک پہنچا دے گا۔,],footnotes:2:[- جو اللہ کی توحید اور اس کی شریعت سے ناواقف ہیں۔ مراد کفار مکہ اور ان کے ساتھی ہیں۔]
  46,4,"آپ کہہ دیجئے! بھلا دیکھو تو جنہیں تم اللہ کے سوا پکارتے ہو مجھے بھی تو دکھاؤ کہ انہوں نے زمین کا کون سا ٹکڑا بنایا ہے یا آسمانوں میں ان کا کون سا حصہ ہے{1}؟ اگر تم سچے ہو تو اس سے پہلے ہی کی کوئی کتاب یا کوئی علم ہی جو نقل کیا جاتا ہو، میرے پاس ﻻؤ.{2}",footnotes:1:[أَرَأَيْتُمْ بمعنی أَخْبِرُونِي یا أَرُونِي یعنی اللہ کو چھوڑ کر جن بتوں یا شخصیات کی تم عبادت کرتے ہو، مجھے بتلاؤ یا دکھلاؤ کہ انہوں نے زمین وآسمان کی پیدائش میں کیا حصہ لیا ہے؟ مطلب یہ ہے کہ جب آسمان وزمین کی پیدائش میں بھی ان کا کوئی حصہ نہیں ہے بلکہ مکمل طور پر ان سب کا خالق صرف ایک اللہ ہے تو پھر تم ان غیر حق معبودوں کو اللہ کی عبادت میں کیوں شریک کرتے ہو؟,],footnotes:2:[- یعنی کسی نبی پر نازل شدہ کتاب میں یا کسی منقول روایت میں یہ بات لکھی ہو تو وہ لاکر دکھاؤ تاکہ تمہاری صداقت واضح ہو سکے۔ بعض نے أَثَارَةٍ مِنْ عِلْمٍ کے معنی واضح علمی دلیل کے کئے ہیں، اس صورت میں کتاب سے نقلی دلیل اور أَثَارَةٍ مِنْ عِلْمٍ سے عقلی دلیل مراد ہوگی۔ یعنی کوئی عقلی اور نقلی دلیل پیش کرو۔ پہلے معنی اس کے اثر سے ماخوذ ہونے کی بنیاد پر روایت کے کیے گئے ہیں یا بَقِيَّةٍ مِنْ عِلْمٍ پہلے انبیاء علیہم السلام کی تعلیمات کا باقی ماندہ حصہ جو قابل اعتماد ذریعے سے نقل ہوتا آیا ہو، اس میں یہ بات ہو۔]
  46,5,"اور اس سے بڑھ کر گمراه اور کون ہوگا؟ جو اللہ کے سوا ایسوں کو پکارتا ہے جو قیامت تک اس کی دعا قبول نہ کر سکیں بلکہ ان کے پکارنے سے محض بےخبر ہوں.{1}.",footnotes:1:[یعنی یہی سب سے بڑے گمراہ ہیں جو پتھر کی مورتیوں کو یا فوت شدہ اشخاص کو مدد کے لئے پکارﺗے ہیں جو قیامت تک جواب دینے سے قاصر ہیں۔ اور قاصر ہی نہیں، بلکہ بالکل بےخبر ہیں۔]
  46,6,"اور جب لوگوں کو جمع کیا جائے گا تو یہ ان کے دشمن ہو جائیں گے اور ان کی پرستش سے صاف انکار کر جائیں گے.{1}.",footnotes:1:[یہ مضمون قرآن کریم میں متعدد مقامات پر بیان کیا گیا ہے۔ مثلاً  سورۂ یونس: 29۔  سورۂ مریم: 81۔ 82۔  سورۂ عنکبوت:25 وغیرھا من الآیات۔ دنیا میں ان معبودوں کی دو قسمیں ہیں۔ ایک تو غیر ذی روح جمادات ونباتات اور مظاہر قدرت (سورج، آگ وغیرہ) ہیں، اللہ تعالیٰ ان کو زندگی اور قوت گویائی عطا فرمائے گا، اور یہ چیزیں بول کر بتلائیں گی کہ ہمیں قطعاً اس بات کا علم نہیں ہے کہ یہ ہماری عبادت کرتے اور ہمیں تیری خدائی میں شریک گردانتے تھے۔ بعض کہتے ہیں کہ زبان قال سے نہیں، زبان حال سے وہ اپنے جذبات کا اظہار کریں گی۔ واللہ اعلم۔ معبودوں کی دوسری قسم وہ ہے جو انبیا علیہم السلام، ملائکہ اور صالحین میں سے ہیں۔ جیسے عیسیٰ، حضرت عزیر علیہما السلام اور دیگر عباد اللہ الصالحین ہیں، یہ اللہ کی بارگاہ میں اسی طرح کا جواب دیں گے جیسے حضرت عیسیٰ (عليه السلام) کا جواب قرآن کریم میں منقول ہے۔ علاوہ ازیں شیطان بھی انکار کریں گے۔ جیسے قرآن میں ان کا قول نقل کیا گیا ہے۔ «تَبَرَّأْنَا إِلَيْكَ مَا كَانُوا إِيَّانَا يَعْبُدُونَ» (القصص: 63) ”ہم تیرے سامنے (اپنے عابدین سے) اظہار براء ت کرتے ہیں، یہ ہماری عبادت نہیں کرتے تھے“۔]
