quran[12]{c,v,t,f}:
  56,70,"اگر ہماری منشا ہو تو ہم اسے کڑوا زہر کردیں پھر تم ہماری شکرگزاری کیوں نہیں کرتے؟{1}.",footnotes:1:[یعنی اس احسان پر ہماری اطاعت کر کے ہمارا عملی شکر اداکیوں نہیں کرتے؟]
  56,71,"اچھا ذرا یہ بھی بتاؤ کہ جو آگ تم سلگاتے ہو."
  56,72,"اس کے درخت کو تم نے پیدا کیا ہے یا ہم اس کے پیدا کرنے والے ہیں؟{1}.",footnotes:1:[کہتے ہیں عرب میں دو درخت ہیں، مرخ اور عفار، ان دونوں سے ٹہنیاں لے کر، ان کو آپس میں رگڑا جائے تو اس سےآگ کے شرارے نکلتے ہیں۔]
  67,10,"اور کہیں گے اگر ہم سنتے ہوتے یا عقل رکھتے ہوتے تو دوزخیوں میں (شریک) نہ ہوتے.{1}.",footnotes:1:[یعنی غور اور توجہ سے سنتے اور ان کی باتوں اور نصیحتوں کو آویزہ گوش بنا لیتے، اسی طرح اللہ کی دی ہوئی عقل سے بھی سوچنے سمجھنے کا کام لیتے تو آج ہم دوزخ والوں میں شامل نہ ہوتے۔]
  67,11,"پس انہوں نے اپنے جرم کا اقبال کر لیا{1}۔ اب یہ دوزخی دفع ہوں (دور ہوں).{2}",footnotes:1:[جس کی بنا پر مستحق عذاب قرار پائے اور وہ ہے کفر اور انبیاء علیہم السلام کی تکذیب۔,],footnotes:2:[- یعنی اب ان کے لئے اللہ اور اس کی رحمت سے دوری ہی دوری ہے۔]
  67,12,"بیشک جو لوگ اپنے پروردگار سےغائبانہ طور پر ڈرتے رہتے ہیں ان کے لیے بخشش ہے اور بڑا ﺛواب ہے.{1}.",footnotes:1:[یہ اہل کفر وتکذیب کے مقابلے میں اہل ایمان کا اور ان نعمتوں کا ذکر ہے جو انہیں قیامت والے دن اللہ کے ہاں ملیں گی۔ بالغیب کا ایک مطلب یہ ہے کہ انہوں نے اللہ کو دیکھا تو نہیں لیکن پیغمبروں کی تصدیق کرتے ہوئے وہ اللہ عذاب سے ڈرتے رہے دوسرا مطلب یہ بھی ہو سکتا ہے کہ لوگوں کی نظروں سے غائب یعنی خلوتوں میں اللہ سے ڈرتے رہے۔]
  68,4,"اور بیشک تو بہت بڑے (عمده) اخلاق پر ہے.{1}.",footnotes:1:[فریضہ نبوت کی ادائیگی میں جتنی زیادہ تکلیفیں برداشت کیں اور دشمنوں کی باتیں سنی ہیں اس پر اللہ تعالٰی کی طرف سے نہ ختم ہونے والا اجر ہے۔من کے معنی قطع کرنے کے ہیں۔]
  68,5,"پس اب تو بھی دیکھ لے گا اور یہ بھی دیکھ لیں گے.{1}.",footnotes:1:[یعنی جب حق واضح ہو جائے گا اور سارے پردے اٹھ جائیں گے اور یہ قیامت کے دن ہوگا بعض نے اسے جنگ بدر سے متعلق فرمایا ہے۔]
  68,6,"کہ تم میں سے کون فتنہ میں پڑا ہوا ہے."
  69,1,"ﺛابت ہونے والی.{1}.",footnotes:1:[یہ قیامت کے ناموں میں سے ایک نام ہے۔ اس میں امر الٰہی ثابت ہوگا اور خود یہ بھی بہر صورت وقوع پذیر ہونے والی ہے، اس لئے اسے الْحَاَقَّۃُ سے تعبیر فرمایا۔]
  69,2,"ﺛابت ہونے والی کیا ہے؟{1}.",footnotes:1:[یہ لفظًا استفہام ہے لیکن اس کا مقصد قیامت کی عظمت اور شان بیان کی گئی ہے۔]
  69,3,"اور تجھے کیا معلوم ہے کہ وه ﺛابت شده کیا ہے؟{1}.",footnotes:1:[یعنی کس ذریعے سے تجھے اس کی پوری حقیقت سے آگاہی حاصل ہو؟مطلب اس کے علم کی نفی ہے۔گویا کہ تجھے اس کا علم نہیں، کیونکہ تو نے ابھی اسے دیکھا ہے اور نہ اس کی ہولناکیوں کا مشاہدہ کیا ہے، گویا مخلوقات کے دائرہ علم سے باہر ہے (فتح القدیر)بعض کہتے ہیں کہ قرآن میں جس کی بابت بھی صیغہ ماضی ما ادراک استعمال کیا گیا ہے، اس کے بیان کر دیا گیا ہے اور جس کو مضارع کے صیغے وما یدریک کے ذریعے سے بیان کیا گیا اس کا علم لعگوں کو نہیں دیا گیاہے(فتح القدیر وایسر التفاسیر)]
