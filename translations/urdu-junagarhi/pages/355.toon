quran[12]{c,v,t,f}:
  26,160,"قوم لوط{1} نے بھی نبیوں کو جھُٹلایا..",footnotes:1:[حضرت لوط (عليه السلام) ، حضرت ابراہیم (عليه السلام) کے بھائی ھاران بن آذر کے بیٹے تھے۔ ان کو حضرت ابراہیم (عليه السلام) ہی کی زندگی میں نبی بنا کر بھیجا گیا تھا۔ ان کی قوم (سدوم) اور (عموریہ) میں رہتی تھی۔ یہ بستیاں شام کے علاقے میں تھیں۔]
  26,161,"ان سے ان کے بھائی لوط (علیہ السلام) نے کہا کیا تم اللہ کا خوف نہیں رکھتے؟"
  26,162,"میں تمہاری طرف امانت دار رسول ہوں."
  30,52,"بیشک آپ مردوں کو نہیں سنا سکتے{1} اور نہ بہروں کو (اپنی) آواز سنا سکتے ہیں{2} جب کہ وه پیٹھ پھیر کر مڑ گئے ہوں.{3}",footnotes:1:[یعنی جس طرح مردے فہم وشعور سے عاری ہوتے ہیں، اسی طرح یہ آپ (صلى الله عليه وسلم) کی دعوت کو سمجھنے اور اسےقبول کرنے سے قاصر ہیں۔,],footnotes:2:[- یعنی آپ (صلى الله عليه وسلم) کا وعظ ونصیحت ان کے لئے بےاثر ہے جس طرح کوئی بہرہ ہو، اسے تم اپنی بات نہیں سنا سکتے۔,],footnotes:3:[- یہ ان کے اعراض وانحراف کی مزید وضاحت ہے کہ مردہ اور بہرہ ہونے کے ساتھ وہ پیٹھ پھیر کر جانے والے ہیں، حق کی بات ان کے کانوں میں کس طرح پڑ سکتی اور کیوں کر ان کے دل ودماغ میں سما سکتی ہے؟]
  30,53,"اور نہ آپ اندھوں کو ان کی گمراہی سے ہدایت کرنے والے{1} ہیں آپ تو صرف ان ہی لوگوں کو سناتے ہیں جو ہماری آیتوں پر ایمان رکھتے{2} ہیں پس وہی اطاعت کرنے والے ہیں.{3}",footnotes:1:[اس لئے کہ یہ آنکھوں سے کما حقہ فائدہ اٹھانے سے یابصیرت (دل کی بینائی) سے محروم ہیں۔ یہ گمراہی کی جس دلدل میں پھنسے ہوئے ہیں، اس سے کس طرح نکلیں؟,],footnotes:2:[- یعنی یہی سن کر ایمان لانے والے ہیں، اس لئے کہ اہل تفکر وتدبر ہیں اور آثار قدرت سے موثر حقیقی کی معرفت حاصل کر لیتے ہیں۔,],footnotes:3:[- یعنی حق کے آگے سر تسلیم خم کر دینے والے اور اس کے پیروکار۔]
  30,54,"اللہ تعالیٰ وه ہے جس نے تمہیں کمزوری کی حالت{1} میں پیدا کیا پھر اس کمزوری کے بعد توانائی{2} دی، پھر اس توانائی کے بعد کمزوری اور بڑھاپا دیا{3} جو چاہتا ہے پیدا کرتا ہے{4}، وه سب سے پورا واقف اور سب پر پورا قادر ہے.",footnotes:1:[یہاں سے اللہ تعالیٰ اپنی قدرت کا ایک اور کمال بیان فرما رہا ہے اور وہ ہے مختلف اطوار سےانسان کی تخلیق۔ ضعف (کمزوری کی حالت) سےمراد نطفہ یعنی قطرۂ آب ہے یا عالم طفولیت۔,],footnotes:2:[- یعنی جوانی، جس میں قوائے عقلی وجسمانی تکمیل ہو جاتی ہے۔,],footnotes:3:[- کمزوری سے مراد کہولت کی عمر ہے جس میں عقلی وجسمانی قوتوں میں نقصان کا آغاز ہو جاتا ہے اور بڑھاپے سے مراد شیخوخت کا وہ دور ہے جس میں ضعف بڑھ جاتا ہے۔ ہمت پست، ہاتھ پیروں کی حرکت وگرفت کمزور،بال سفید اور تمام ظاہری وباطنی صفات متغیر ہو جاتی ہیں۔ قرآن نے انسان کے یہ چار بڑےاطوار بیان کیے ہیں،بعض علما نے دیگر چھوٹے چھوٹے اطوار بھی شمار کر کے انہیں قدرے تفصیل سے بیان کیا ہے جو قرآن کےاجمال کی توضیح اور اس کے اعجاز بیان کی شرح ہے مثلاً امام ابن کثیر فرماتے ہیں کہ انسان یکے بعد دیگرے ان حالات واطوار سےگزرتا ہے۔ اس کی اصل مٹی ہے۔ یعنی اس کے باپ آدم (عليه السلام) کی تخلیق مٹی سے ہوئی تھی۔ یا انسان جو کچھ کھاتا ہے، جس سے وہ منی پیدا ہوتی ہے جو رحم مادر میں جاکر اس کے وجود وتخلیق کا باعث بنتی ہے، وہ سب مٹی ہی کی پیداوار ہے پھر وہ نطفہ، نطفہ سے علقہ، پھر مضغہ، پھر ہڈیاں، جنہیں گوشت کا لباس پہنایا جاتا ہے۔ پھر اس میں روح پھونکی جاتی ہے۔ پھر ماں کے پیٹ سے اس حال میں نکلتا ہے کہ نحیف ونزار اور نہایت نرم ونازک ہوتا ہے۔ پھر بتدریج نشوونما پاتا، بچپن، بلوغت اور جوانی کو پہنچتا ہے اور پھر بتدریج رجعت قہقریٰ کا عمل شروع ہو جاتا ہے، کہولت، شیخوخت اور پھر کبر سنی (بڑھاپا) تا آنکہ موت اسے اپنی آغوش میں لے لیتی ہے۔,],footnotes:4:[- انہی اشیاء میں ضعف وقوت بھی ہے۔ جس سے انسان گزرتا ہے جیسا کہ ابھی تفصیل بیان ہوئی ہے۔]
  32,22,"اس سے بڑھ کر ﻇالم کون ہے جسے اللہ تعالیٰ کی آیتوں سے وعﻆ کیا گیا پھر{1} بھی اس نے ان سے منھ پھیر لیا، (یقین مانو) کہ ہم بھی گناه گاروں سے انتقام لینے والے ہیں..",footnotes:1:[یعنی اللہ کی آیتیں سن کر جو ایمان واطاعت کی موجب ہیں، جو شخص ان سے اعراض کرتا ہے، اس سے بڑا ظالم کون ہے؟ یعنی یہی سب سے بڑا ظالم ہے۔]
  32,23,"بیشک ہم نے موسیٰ کو کتاب دی، پس آپ کو ہرگز اس کی ملاقات میں شک{1} نہ کرنا چاہئے اور ہم نے اسے{2} بنی اسرائیل کی ہدایت کا ذریعہ بنایا.",footnotes:1:[کہا جاتا ہے کہ یہ اشارہ ہے اس ملاقات کی طرف جو معراج کی رات نبی (صلى الله عليه وسلم) اور حضرت موسیٰ (عليه السلام) کے درمیان ہوئی، جس میں حضرت موسیٰ (عليه السلام) نے نمازوں میں تخفیف کرانے کا مشورہ دیا تھا۔,],footnotes:2:[- (اسے) سے مراد کتاب (تورات) ہے یا خود حضرت موسیٰ (عليه السلام) ۔]
  32,24,"اور جب ان لوگوں نے صبر کیا تو ہم نے ان میں سے ایسے پیشوا بنائے جو ہمارے حکم سے لوگوں کو ہدایت کرتے تھے، اور وه ہماری آیتوں پر یقین رکھتے تھے.{1}.",footnotes:1:[اس آیت سے صبر کی فضیلت واضح ہے۔ صبر کا مطلب ہے اللہ کے اوامر کے بجا لانے اور ترک زواجر میں اور اللہ کے رسولوں کی تصدیق اور ان کے اتباع میں جو تکلیفیں آئیں، انہیں خندہ پیشانی سے جھیلنا۔ اللہ نے فرمایا، ان کے صبر کرنے اور آیات الٰہی پر یقین رکھنے کی وجہ سے ہم نے ان کو دینی امامت اور پیشوائی کے منصب پر فائز کیا۔ لیکن جب انہوں نے اس کے برعکس تبدیل وتحریف کا ارتکاب شروع کر دیا، تو ان سے یہ مقام سلب کر لیا گیا۔ چنانچہ اس کے بعد ان کے دل سخت ہوگئے، پھر ان کا عمل صالح رہا اور نہ ان کا اعتقاد صحیح۔]
  33,13,"ان ہی کی ایک جماعت نے ہانک لگائی کہ اے مدینہ والو{1}! تمہارے لئے ٹھکانہ نہیں چلو لوٹ چلو{2}، اور ان کی ایک اور جماعت یہ کہہ کر نبی ﴿صلی اللہ علیہ وسلم﴾ سے اجازت مانگنے لگی کہ ہمارے گھر غیر محفوظ ہیں{3}، حاﻻنکہ وه (کھلے ہوئے اور) غیر محفوظ نہ تھے (لیکن) ان کا پختہ اراده بھاگ کھڑے ہونے کا تھا.{4}",footnotes:1:[یثرب اس پورے علاقے کا نام تھا، مدینہ اسی کا ایک حصہ تھا، جسے یہاں یثرب سے تعبیر کیا گیا ہے۔ کہا جاتا ہے کہ اس کا نام یثرب اس لئے پڑا کہ کسی زمانے میں عمالقہ میں سے کسی نے یہاں پڑاو کیا تھا جس کا نام یثرب بن عمیل تھا۔ (فتح القدیر)۔,],footnotes:2:[- یعنی مسلمانوں کے لشکر میں رہنا تو سخت خطرناک ہے، اپنے اپنے گھروں کو واپس لوٹ جاؤ۔,],footnotes:3:[- یعنی بنو قریظہ کی طرف سے حملے کا خطرہ ہے یوں اہل خانہ کی جان ومال اور آبرو خطرے میں ہے۔,],footnotes:4:[- یعنی جو خطرہ وہ ظاہر کر رہے ہیں، نہیں ہے وہ اس بہانے سے راہ فرار چاہتے ہیں۔ عَوْرَةٌ کے لغوی اور معروف معنی کے لئے دیکھئے،  سورۂ نور، آیت 58 کا حاشیہ۔]
  33,14,"اور اگر مدینے کے اطراف سے ان پر (لشکر) داخل کیے جاتے پھر ان سے فتنہ طلب کیا جاتا تو یہ ضرور اسے برپا کر دیتے اور نہ لڑتے مگر تھوڑی مدت.{1}.",footnotes:1:[یعنی مدینے یا ان کے گھروں میں چاروں طرف سے دشمن داخل ہو جائیں اور ان سے مطالبہ کریں کہ تم کفر وشرک کی طرف دوبارہ واپس آجاؤ، تو یہ ذرا توقف نہ کریں گے اور اس وقت گھروں کے غیر محفوظ ہونے کا عذر بھی نہیں کریں گے بلکہ فوراً مطالبۂ شرک کے سامنے جھک جائیں۔ مطلب یہ ہے کہ کفر وشرک ان کو مرغوب ہے اور اس کی طرف یہ لپکتے ہیں۔]
  33,15,"اس سے پہلے تو انہوں نے اللہ سے عہد کیا تھا کہ پیٹھ نہ پھیریں گے{1}، اور اللہ تعالیٰ سے کیے ہوئے وعده کی باز پرس ضرور{2} ہوگی.",footnotes:1:[بیان کیا جاتا ہے کہ منافقین جنگ بدر تک مسلمان نہیں ہوئے۔ لیکن جب مسلمان فاتح ہوکر اور مال غنیمت لے کر واپس آئے تو انہوں نے نہ صرف یہ کہ اسلام کا اظہار کیا بلکہ یہ عہد بھی کیا کہ آئندہ جب بھی کفار سے معرکہ پیش آیا تو وہ مسلمانوں کے ساتھ مل کر ضرور لڑیں گے، یہاں ان کو وہی عہد یاد کرایا گیا ہے۔,],footnotes:2:[- یعنی اسےپورا کرنے کا ان سے مطالبہ کیا جائے گا اور عدم وفا پر سزا کے وہ مستحق ہوں گے۔]
