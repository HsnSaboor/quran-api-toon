quran[30]{c,v,t,f}:
  74,37,"(یعنی) اسے{1} جو تم میں سے آگے بڑھنا چاہے یا پیچھے ہٹنا چاہے.{2}",footnotes:1:[یعنی یہ جہنم ڈرانے والی ہے یا نذیر سے مراد نبی کریم (صلى الله عليه وسلم) ہیں یا قرآن بھی اپنے بیان کردہ وعد و وعید کے اعتبار سے انسانوں کے لئے نذیر ہے۔,],footnotes:2:[- یعنی ایمان واطاعت میں آگے بڑھنا چاہیے یا اس سے پیچھے ہٹنا چاہیے مطلب ہے کہ انداز ہر ایک کے لیے ہے جو ایمان لائے یا کفر کرے۔]
  74,38,"ہر شخص اپنے اعمال کے بدلے میں گروی ہے.{1}.",footnotes:1:[رہن گروی کو کہتے ہیں یعنی ہر شخص اپنے عمل کا گروی ہے، وہ عمل اسے عذاب سے چھڑا لے گا، (اگر نیک ہوگا) یا ہلاک کروا دے گا۔ (اگر برا ہے)]
  74,39,"مگر دائیں ہاتھ والے.{1}.",footnotes:1:[یعنی وہ اپنے گناہوں کے اسیر نہیں ہوں گے بلکہ اپنے نیک اعمال کی وجہ سے آزاد ہونگے۔]
  75,34,"افسوس ہے تجھ پر حسرت ہے تجھ پر."
  75,35,"وائے ہے اور خرابی ہے تیرے لیے.{1}.",footnotes:1:[یہ کلمہ وعید سے کہا جاتا ہے کہ اس کی اصل ہے، اللہ تجھے ایسی چیز سے دو چار کرے جسے تو ناپسند کرے۔]
  75,36,"کیا انسان یہ سمجھتا ہے کہ اسے بیکار چھوڑ دیا جائے گا.{1}.",footnotes:1:[یعنی اس کو کسی چیز کا حکم دیا جائے گا، نہ کسی چیز سے منع کیا جائے گا، نہ اس کا محاسبہ ہوگا۔ یا اس کی قبر میں ہمیشہ کے لئے چھوڑ دیا جائے گا، وہاں سے اسے دوبارہ زندہ نہیں کیا جائے گا۔]
  76,28,"ہم نے انہیں پیدا کیا اور ہم نے ہی ان کے جوڑ اور بندھن مضبوط کیے{1} اور ہم جب چاہیں ان کے عوض ان جیسے اوروں کو بدل ﻻئیں.{2}",footnotes:1:[یعنی ان کی پیدائش کو مضبوط بنایا، یا ان کے جوڑوں کو، رگوں کو اور پٹھوں کے ذریعے سے، ایک دوسرے کے ساتھ ملا دیا، بلفظ دیگر، ان کا مانجھا کڑا کیا۔,],footnotes:2:[- یعنی ان کو ہلاک کرکے ان کی جگہ کسی اور قوم کو پیدا کردیں یا اس سے مطلب قیامت کے دن دوبارہ پیدائش ہے۔]
  76,29,"یقیناً یہ تو ایک نصیحت ہے پس جو چاہے اپنے رب کی راه لے لے.{1}.",footnotes:1:[یعنی اس قرآن سے ہدایت حاصل کرے۔]
  76,30,"اور تم نہ چاہو گے مگر یہ کہ اللہ تعالیٰ ہی چاہے{1} بیشک اللہ تعالیٰ علم واﻻ باحکمت ہے.{2}",footnotes:1:[یعنی تم میں سے کوئی اس بات پر قادر نہیں ہے کہ وہ ہدایت کی راہ لگا لے، اپنے لئے کسی نفع کو جاری کر لے، ہاں اگر اللہ چاہے تو ایسا ممکن ہے، اس کی مشیت کے بغیر تم کچھ نہیں کر سکتے۔ البتہ صحیح قصد و نیت پر وہ اجر ضرور عطا فرماتا ہے ”إنَّما الأَعمالُ بالنِّيَّات، وإِنَّمَا لِكُلِّ امرئٍ مَا نَوَى“ اعمال کا دارو مدار، نیتوں پر ہے، ہر آدمی کے لئے وہ ہے جس کی وہ نیت کرے\"۔,],footnotes:2:[- چوں کہ وہ علیم وحکیم ہے اس لیے اس کے ہر کام میں حکمت ہوتی ہے بنابریں ہدایت اور گمراہی کے فیصلے بھی یوں ہی نہیں ہو جاتے بلکہ جس کو ہدایت دی جاتی ہے وہ واقعی اس کا مستحق ہوتا ہے اور جس کے حصے میں گمراہی آتی ہے وہ حقیقتا اسی کے لائق ہوتا ہے۔]
  77,25,"کیا ہم نے زمین کو سمیٹنے والی نہیں بنایا؟"
  77,26,"زندوں کو بھی اور مردوں کو بھی.{1}.",footnotes:1:[یعنی زمین زندوں کو اپنی پشت پر اور مردوں کو اپنے اندر سمیٹ لیتی ہے۔]
  77,27,"اور ہم نے اس میں بلند وبھاری پہاڑ بنادیے{1} اور تمہیں سیراب کرنے واﻻ میٹھا پانی پلایا..",footnotes:1:[رواسي راسية کی جمع۔ ثاوبت، جمے ہوئے پہاڑ، شامخات، بلند۔]
  78,22,"سرکشوں کا ٹھکانہ وہی ہے."
  78,23,"اس میں وه مدتوں تک پڑے رہیں گے.{1}.",footnotes:1:[أَحْقَابٌ ، حُقُبٌ کی جمع ہے، بمعنی زمانہ۔ مراد ابد اور ہمیشگی ہے۔ ابد الاباد تک وہ جہنم میں ہی رہیں گے۔ یہ سزا کافروں اور مشرکوں کے لئے ہے۔]
  78,24,"نہ کبھی اس میں خنکی کا مزه چکھیں گے، نہ پانی کا."
  79,16,"جب کہ انہیں ان کے رب نے پاک میدان طویٰ میں پکارا.{1}.",footnotes:1:[یہ اس وقت کا واقعہ ہے جب حضرت موسیٰ (عليه السلام) مدین سے واپس آگ کی تلاش میں کوہ طور پر پہنچ گئے تھے تو وہاں ایک درخت کی اوٹ سے اللہ تعالیٰ نےموسیٰ (عليه السلام) سے کلام فرمایا، جیسا کہ اس کی تفصیل سورۂ طہ کے آغاز میں گزری طُوَى اسی جگہ کا نام ہے، ہم کلامی کا مطلب نبوت ورسالت سےنوازنا ہے۔ یعنی موسیٰ (عليه السلام) آگ لینے گئے اور اللہ تعالیٰ نے انہیں رسالت عطا فرما دی۔]
  79,17,"(کہ) تم فرعون کے پاس جاؤ اس نے سرکشی اختیار کر لی ہے.{1}.",footnotes:1:[یعنی کفر ومعصیت اور تکبر میں حد سےتجاوز کر گیا ہے۔]
  79,18,"اس سے کہو کہ کیا تو اپنی درستگی اور اصلاح چاہتا ہے.{1}.",footnotes:1:[یعنی کیا ایسا راستہ اور طریقہ تو پسندکرتا ہےجس سے تیری اصلاح ہو جائے اور وہ یہ ہے کہ مسلمان اور مطیع ہو جا۔]
  80,13,"(یہ تو) پر عظمت صحیفوں میں (ہے).{1}.",footnotes:1:[یعنی لوح محفوظ میں، کیوں کہ وہیں سے یہ قرآن اترتا ہے۔ یا مطلب ہے کہ یہ صحیفے اللہ کے ہاں بڑےمحترم ہیں کیوں کہ وہ علم وحکمت سے پر ہیں۔]
  80,14,"جو بلند وباﻻ اور پاک صاف ہے.{1}.",footnotes:1:[مَرْفُوعَةٍ اللہ کے ہاں رفیع القدر ہیں، یا شبہات اور تناقض سے بلند ہیں۔ مُطَهَّرَةٍ، وہ بالکل پاک ہیں کیوں کہ انہیں پاک لوگوں ( فرشتوں ) کے سوا کوئی چھوتا ہی نہیں، یا کمی بیشی سے پاک ہے۔]
  80,15,"ایسے لکھنے والوں کے ہاتھوں میں ہے.{1}.",footnotes:1:[سَفَرَةٍ، سَافِرٌ کی جمع ہے، یہ سفارت سے ہے۔ مراد یہاں وہ فرشتے ہیں جو اللہ کی وحی اس کےرسولوں تک پہنچاتے ہیں۔ یعنی اللہ اور اس کےرسول کے درمیان سفارت کا کام کرتے ہیں۔ یہ قرآن ایسے سفیروں کے ہاتھوں میں ہےجو اسے لوح محفوظ سے نقل کرتے ہیں۔]
  81,10,"اور جب نامہٴ اعمال کھول دیئے جائیں گے.{1}.",footnotes:1:[موت کے وقت یہ صحیفے لپیٹ دیئے جاتے ہیں، پھر قیامت والے دن حساب کےلئے کھول دیئے جائیں گے، جنہیں ہر شخص دیکھ لے گا بلکہ ہاتھوں میں پکڑا دیئے جائیں گے ۔]
  81,11,"اور جب آسمان کی کھال اتار لی جائے گی.{1}.",footnotes:1:[یعنی وہ اس طرح ادھیڑ دیئے جائیں گےجس طرح چھت ادھیڑ دی جاتی ہے۔]
  81,12,"اور جب جہنم بھڑکائی جائے گی."
  82,4,"اور جب قبریں (شق کر کے) اکھاڑ دی جائیں گی.{1}.",footnotes:1:[یعنی قبروں سے مردے زندہ ہو کر باہر نکل آئیں گے۔ بُعْثِرَتْ، اکھیڑ دی جائیں گی، یا ان کی مٹی پلٹ دی جائے گی۔]
  82,5,"(اس وقت) ہر شخص اپنے آگے بھیجے ہوئے اور پیچھے چھوڑے ہوئے (یعنی اگلے پچھلے اعمال) کو معلوم کر لے گا.{1}.",footnotes:1:[یعنی جب مذکورہ امور واقع ہوں گے تو انسان کو اپنے تمام کیے دھرے کا علم ہو جائے گا، جو بھی اچھا یا برا عمل اس نے کیا ہوگا، وہ سامنے آجائے گا، پیچھے چھوڑےہوئے عمل سے مراد اپنے کردار وعمل کے اچھی یا برے نمونے ہیں جو دنیا میں وہ چھوڑ آیا اور لوگ ان نمونوں پر عمل کرتے ہیں۔ یہ نمونے اگر اچھے ہیں تو اس کےمرنے کے بعد ان نمونوں پر جو لوگ بھی عمل کریں گے، اس کا ثواب اسے بھی پہنچتا رہے گا اور اگر برے نمونے اپنے پیچھے چھوڑ گیا ہے تو جو جو بھی اسے اپنائے گا، ان کا گناہ بھی اس شخص کو پہنچتا رہے گا، جس کی مساعی سے وہ برا طریقہ یا کام رائج ہوا ۔]
  82,6,"اے انسان! تجھے اپنے رب کریم سے کس چیز نے بہکایا.{1}.",footnotes:1:[یعنی کس چیز نےتجھے دھوکے اور فریب میں مبتلا کر دیا کہ تو نے اس رب کے ساتھ کفر کیا، جس نے تجھ پر احسان کیا اور تجھے وجود بخشا، تجھے عقل وفہم عطا کی اور اسباب حیات تیرے لئے مہیا کئے۔]
  83,1,"بڑی خرابی ہے ناپ تول میں کمی کرنے والوں کی."
  83,2,"کہ جب لوگوں سے ناپ کر لیتے ہیں تو پورا پورا لیتے ہیں."
  83,3,"اور جب انہیں ناپ کر یا تول کر دیتے ہیں تو کم دیتے ہیں.{1}.",footnotes:1:[یعنی لینے اور دینے کے الگ الگ پیمانے رکھنا اور اس طرح ڈنڈی مار کر ناپ تول میں کمی کرنا، بہت بڑی اخلاقی بیماری ہے جس کا نتیجہ دین وآخرت میں تباہی ہے۔ ایک حدیث میں ہے، جو قوم ناپ تول میں کمی کرتی ہے، تو اس پر قحط سالی، سخت محنت اور حکمرانوں کا ظلم مسلط کر دیا جاتا ہے۔ ( ابن ماجه ، نمبر 4019 ذكره الألباني في الصحيحة نمبر 106 من عدة طرق وله شواهد) ۔]
