quran[9]{c,v,t,f}:
  15,73,"پس سورج نکلتے نکلتے انہیں ایک بڑے زور کی آواز نے پکڑ لیا.{1}.",footnotes:1:[ایک چنگھاڑ نے، جب کہ سورج طلوع ہو چکا تھا، ان کا خاتمہ کر دیا۔ بعض کہتے ہیں کہ یہ زوردار آواز حضرت جبرائیل (عليه السلام) کی تھی۔]
  15,74,"بالﺂخر ہم نے اس شہر کو اوپر تلے کر دیا{1} اور ان لوگوں پر کنکر والے پتھر{2} برسائے.",footnotes:1:[کہا جاتا ہے کہ ان کی بستیوں کو زمین سے اٹھا کر اوپر آسمان پر لے جایا گیا اور وہاں سے ان کو الٹا کر کے زمین پر پھینک دیا گیا۔ یوں اوپر والا حصہ نیچے اور نچلا حصہ اوپر کر کے تہ و بالا کر دیا گیا، اور کہا جاتا ہے کہ اس سے مراد محض اس بستی کا چھتوں سمیت زمین بوس ہو جانا ہے۔,],footnotes:2:[- اس کے بعد کنکر قسم کے مخصوص پتھر برسائے گئے۔ اس طرح گویا تین قسم کے عذابوں سے انہیں دوچار کر کے نشان عبرت بنا دیا گیا۔]
  15,75,"بلاشبہ بصیرت والوں کے لیے{1} اس میں بہت سی نشانیاں ہیں..",footnotes:1:[گہری نظر سے جائزہ لینے اور غور وفکر کرنے والوں کو مُتَوَسِّمِیْنَ کہا جاتا ہے۔ مُتَوَسِّمِیْنَ کے لئے اس واقعے میں عبرت کے پہلو اور نشانیاں ہیں۔]
  16,52,"آسمانوں میں اور زمین میں جو کچھ ہے سب اسی کا ہے اور اسی کی عبادت ﻻزم ہے{1}، کیا پھر تم اس کے سوا اوروں سے ڈرتے ہو؟.",footnotes:1:[اسی کی عبادت و اطاعت دائمی اور لازم ہے۔ وَاصِبٌ کے معنی ہمیشگی کے ہیں «وَلَهُمْ عَذَابٌ وَاصِبٌ» (الصافات:9) ”ان کے لئے عذاب ہے ہمیشہ کا“، اور اس کا وہی مطلب ہے جو دوسرے مقامات پر بیان کیا گیا ہے۔ «فَاعْبُدِ اللَّهَ مُخْلِصًا لَهُ الدِّينَ، أَلا لِلَّهِ الدِّينُ الْخَالِصُ» (الزمر: 2۔3) ”پس اللہ کی عبادت کرو، اسی کے لئے بندگی کو خالص کرتے ہوئے، خبردار! اسی کے لئے خالص بندگی ہے“۔]
  16,53,"تمہارے پاس جتنی بھی نعمتیں ہیں سب اسی کی دی ہوئی ہیں{1}، اب بھی جب تمہیں کوئی مصیبت پیش آجائے تو اسی کی طرف نالہ وفریاد کرتے ہو.{2}",footnotes:1:[جب سب نعمتوں کا دینے والا صرف ایک اللہ ہے تو پھر عبادت کسی اور کی کیوں؟,],footnotes:2:[- اس کا مطلب یہ ہے کہ اللہ کے ایک ہونے کا عقیدہ قلب ووجدان کی گہرائیوں میں راسخ ہے جو اس وقت ابھر کر سامنے آ جاتا ہے جب ہر طرف سے مایوسی کے بادل گہرے ہو جاتے ہیں۔]
  16,54,"اور جہاں اس نے وه مصیبت تم سے دفع کر دی تم میں سے کچھ لوگ اپنے رب کے ساتھ شرک کرنے لگ جاتے ہیں."
  17,19,"اور جس کا اراده آخرت کا ہو اور جیسی کوشش اس کے لئے ہونی چاہیئے، وه کرتا بھی ہو اور وه باایمان بھی ہو، پس یہی لوگ ہیں جن کی کوشش کی اللہ کے ہاں پوری قدردانی کی جائے گی.{1}.",footnotes:1:[اللہ تعالٰی کے ہاں قدر دانی کے لئے تین چیزیں یہاں بیان کی گئی ہیں: (1)۔ ارادہ آخرت، یعنی اخلاص اور اللہ کی رضا جوئی، (2)۔ ایسی کوشش جو اس کے لائق ہو، یعنی سنت کے مطابق، (3)۔ ایمان کیونکہ اس کے بغیر تو کوئی عمل بھی قابل التفات نہیں۔ یعنی قبولیت عمل کے لئے ایمان کے ساتھ اخلاص اور سنت نبوی کے مطابق ہونا ضروری ہے۔]
  17,20,"ہر ایک کو ہم بہم پہنچائے جاتے ہیں انہیں بھی اور ا نہیں بھی تیرے پروردگار کے انعامات میں سے۔ تیرے پروردگار کی بخشش رکی ہوئی نہیں ہے.{1}.",footnotes:1:[یعنی دنیا کا رزق اور اس کی آسائشیں ہم بلا تفریق مومن اور کافر، طالب دنیا اور طالب آخرت سب کو دیتے ہیں۔ اللہ کی نعمتیں کسی سے بھی روکی نہیں جاتیں۔]
  17,21,"دیکھ لے کہ ان میں ایک کو ایک پر ہم نے کس طرح فضیلت دے رکھی ہے اور آخرت تو درجوں میں اور بھی بڑھ کر ہے اور فضیلت کے اعتبار سے بھی بہت بڑی ہے.{1}.",footnotes:1:[تاہم دنیا کی چیزیں کسی کو کم، کسی کو زیادہ ملتی ہیں، اللہ تعالٰی اپنی حکمت و مصلحت کے مطابق یہ روزی تقسیم فرماتا ہے۔ تاہم آخرت میں درجات کا یہ تفاضل زیادہ واضح اور نمایاں ہوگا اور وہ اس طرح کہ اہل ایمان جنت میں اور اہل کفر جہنم میں جائیں گے۔]
