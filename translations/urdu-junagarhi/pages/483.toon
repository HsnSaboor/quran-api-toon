quran[27]{c,v,t,f}:
  68,34,"پرہیزگاروں کے لیے ان کے رب کے پاس نعمتوں والی جنتیں ہیں."
  68,35,"کیا ہم مسلمانوں کو مثل گناه گاروں کے کردیں گے.{1}.",footnotes:1:[مشرکین مکہ کہتے تھے کہ اگر قیامت ہوئی تو وہاں بھی ہم مسلمانوں سے بہتر ہی ہونگے، جیسے دنیا میں ہم مسلمانوں سے زیادہ آسودہ حال ہیں۔ اللہ تعالٰی نے ان کے جواب میں فرمایا، یہ کس طرح ممکن ہے ہم مسلمانوں کو یعنی اپنے فرماں برداروں کو مجرموں یعنی نافرمانوں کی طرح کر دیں گے مطلب یہ ہے کہ یہ کبھی نہیں ہوسکتا کہ اللہ تعالٰی عدل وانصاف کے خلاف دونوں کو یکساں کردے۔]
  68,36,"تمہیں کیا ہوگیا، کیسے فیصلے کر رہے ہو؟"
  69,31,"پھر اسے دوزخ میں ڈال دو.{1}.",footnotes:1:[اللہ ملائکہ جہنم کو حکم دے گا۔]
  69,32,"پھر اسے ایسی زنجیر میں جس کی پیمائش ستر ہاتھ کی ہے جکڑ دو.{1}.",footnotes:1:[یہ ذراع (ہاتھ) یہ کتنا ہوگا اس کی وضاحت ممکن نہیں تاہم اس سے اتنا معلوم ہوا کہ زنجیر کی لمبائی ستر ذراع ہوگی۔]
  69,33,"بیشک یہ اللہ عظمت والے پرایمان نہ رکھتا تھا.{1}.",footnotes:1:[- یہ مذکورہ سزا کی علت یا مجرم کے جرم کا بیان ہے۔]
  70,25,"مانگنے والوں کا بھی اور سوال سے بچنے والوں کا بھی.{1}.",footnotes:1:[محروم میں وہ شخص بھی داخل ہے جو رزق سے ہی محروم ہے وہ بھی جو کسی آفت سماوی وارضی کی زد میں آکر اپنی پونجی سے محروم ہوگیا اور وہ بھی جو ضرورت مند ہونے کے باوجود اپنی صفت تعفف کی وجہ سے لوگوں کی عطا اور صدقات سے محروم رہتا ہے۔]
  70,26,"اور جو انصاف کے دن پر یقین رکھتے ہیں.{1}.",footnotes:1:[یعنی وہ اس کا انکار کرتے ہیں نہ اس میں شک وشبہ کا اظہار۔]
  70,27,"اور جو اپنے رب کے عذاب سے ڈرتے رہتے ہیں.{1}.",footnotes:1:[یعنی اطاعت اور اعمال صالحہ کے باوجود اللہ کی عظمت وجلالت کے پیش نظر اس کی گرفت سے لرزاں وترساں رہتے ہیں اور یقین رکھتے ہیں کہ جب تک اللہ کی رحمت ہمیں اپنے دامن میں نہیں ڈھانک لے گی ہمارے یہ اعمال نجات کے لیے کافی نہیں ہوں گے جیسا کہ اس مفہوم کی حدیث پہلے گزر چکی ہے۔]
  71,22,"اور ان لوگوں نے بڑا سخت فریب کیا.{1}.",footnotes:1:[یہ مکر یا فریب کیا تھا ؟بعض کہتے ہیں ان کا بعض لوگوں کو حضرت نوح (عليه السلام) کے قتل پر ابھارنا تھا بعض کہتے ہیں کہ مال واولاد کی وجہ سے جس فریب نفس کا وہ شکار ہوئے حتی کہ بعض نے کہا کہ اگر یہ حق پر نہ ہوتے تو ان کو یہ نعمتیں کیوں میسر آتیں؟ اور بعض کے نزدیک ان کے بڑوں کا یہ کہنا تھا کہ تم اپنے معبودوں کی عبادت مت چھوڑنا، بعض کے نزدیک ان کا کفر ہی، بڑا مکر تھا۔]
  71,23,"اور کہا انہوں نے کہ ہرگز اپنے معبودوں کو نہ چھوڑنا اور نہ ود اور سواع اور یغوث اور یعوق اور نسر کو (چھوڑنا).{1}.",footnotes:1:[یہ قوم نوح (عليه السلام) کے وہ لوگ تھے جن کی وہ عبادت کرتے تھے اور ان کی اتنی شہرت ہوئی کہ عرب میں بھی ان کی پوجا ہوتی رہی، چنانچہ ود دومة الجندل میں قبیلہ کلب کا، سواع ساحل بحر کے قبیلہ ھذیل کا، یغوث سبا کے قریب جرف جگہ میں مراد اور بنی غطیف کا، یعوق، ہمدان قبیلے کا اور نسر، حمیر قبیلہ ذوالکلاع کا معبود رہا۔ (ابن کثیرو فتح القدیر) یہ پانچوں قوم نوح (عليه السلام) کے نیک آدمیوں کے نام تھے، جب یہ مر گئے تو شیطان نے ان کے عقیدت مندوں کو کہا کہ ان کی تصوریں بنا کر تم اپنے گھروں اور دکانوں میں رکھ لو تاکہ ان کی یاد تازہ رہے اور ان کے تصور سے تم بھی ان کی طرح نیکیاں کرتے رہو، جب یہ تصویریں بنا کر رکھنے والے فوت ہوگئے تو شیطان نے ان کی نسلوں کو یہ کہہ کر کہ شرک میں ملوث کر دیا کہ تمہارے آباء تو ان کی عبادت کرتے تھے جن کی تصویریں تمہارے گھروں میں لٹک رہی ہیں چنانچہ انہوں نے ان کی پوجا شروع کر دی (صحیح بخاری، تفسیر سورة نوح)]
  71,24,"اور انہوں نے بہت سے لوگوں کو گمراه کیا (الٰہی) تو ان ﻇالموں کی گمراہی اور بڑھا.{1}.",footnotes:1:[أَضَلُّوا کا فاعل (مرجع) قوم نوح کے رؤسا ہیں۔ یعنی انہوں نے بہت سے لوگوں کو گمراہ کیا اور اس کا مرجع یہی مذکورہ پانچ بت ہیں، اس کا مطلب ہوگا کہ ان کے سبب بہت سے لوگ گمراہی میں مبتلا ہوئے۔ جیسے ابراہیم (عليه السلام) نے بھی کہا تھا۔«رَبِّ إِنَّهُنَّ أَضْلَلْنَ كَثِيرًا مِنَ النَّاسِ» ( ابراھیم: 36)]
  72,19,"اور جب اللہ کا بنده اس کی عبادت کے لیے کھڑا ہوا تو قریب تھا کہ وه بھیڑ کی بھیڑ بن کر اس پر پل پڑیں.{1}.",footnotes:1:[عَبْدُاللّٰہِ سے مراد رسول اللہ (صلى الله عليه وسلم) ہیں اور مطلب ہے کہ انس و جن مل کر چاہتے ہیں کہ اللہ کے اس نور کو اپنی پھونکوں سے بجھا دیں، لیکن امام ابن کثیر نے اسے رجوع کرنا قرار دیا ہے۔]
  72,20,"آپ کہہ دیجئے کہ میں تو صرف اپنے رب ہی کو پکارتا ہوں اور اس کے ساتھ کسی کو شریک نہیں کرتا.{1}.",footnotes:1:[یعنی جب سب آپ کی عداوت پر اتر آئے ہیں تو آپ کہہ دو کہ میں تو صرف اپنے رب کی عبادت کرتا ہوں اسی سے پناہ طلب کرتا ہوں اور اسی پر بھروسہ کرتا ہوں۔]
  72,21,"کہہ دیجئے کہ مجھے تمہارے کسی نقصان نفع کا اختیار نہیں.{1}.",footnotes:1:[یعنی مجھے تمہاری ہدایت یا گمراہی کا یا کسی اور نفع نقصان کا اختیار نہیں ہے میں تو صرف اس کا ایک بندہ ہوں جسے اللہ نے وحی ورسالت کے لیے چن لیا ہے۔]
  73,13,"اور حلق میں اٹکنے واﻻ کھانا ہے اور درد دینے واﻻ عذاب ہے.{1}.",footnotes:1:[انکال ،نکل کی جمع ہے قیود (بیڑیاں) اور بعض نے اغلال کے معنی میں لیا ہے ۔یعنی طوق، جحیما 'بھڑکتی آگ ذَا غُصَّةٍ حلق میں اٹک جانے والا، نہ حلق سے نیچے اترے اور نہ باہر نکلے۔ یہ زَ قُّوْم کا کھانا ہوگا۔ ضَرِیْع ایک کانٹے دار جھاڑی ہے جو سخت بدبو دار اور زہریلی ہوتی ہے۔]
  73,14,"جس دن زمین اور پہاڑ تھرتھرا جائیں گے اور پہاڑ مثل بھربھری ریت کے ٹیلوں کے ہوجائیں گے.{1}.",footnotes:1:[یعنی یہ عذاب اس دن ہوگا جس دن زمین پہاڑ بھونچال سے تہ وبالا ہو جائیں گے اور بڑے بڑے پر ہیبت پہاڑ ریت کے ٹیلوں کی طرح بےحثییت ہو جائیں گے۔ کثیب ریت کا ٹیلا، مھیلا کا معنی بھربھری پیروں کے نچیے سے نکل جانے والی ریت۔]
  73,15,"بیشک ہم نے تمہاری طرف بھی تم پر گواہی دینے واﻻ{1} رسول بھیج دیا ہے جیسے کہ ہم نے فرعون کے پاس رسول بھیجا تھا..",footnotes:1:[جو قیامت والے دن تمہارے اعمال کی گواہی دے گا۔]
  74,10,"جو کافروں پر آسان نہ ہوگا.{1}.",footnotes:1:[یعنی قیامت کا دن کافروں پر بھاری ہوگا کیونکہ اس روز کفر کا نتیجہ انہیں بھگتنا ہوگا، جو جرم وہ دنیا میں کرتے رہے ہونگے۔]
  74,11,"مجھے اور اسے چھوڑ دے جسے میں نے اکیلا پیدا کیا ہے.{1}.",footnotes:1:[یہ کلمہ وعید و تہدید ہے کہ اسے، جسے میں نے ماں کے پیٹ میں اکیلا پیدا کیا، اس کے پاس مال تھا نہ اولاد، اور مجھے اکیلا چھوڑ دو، یعنی میں خود ہی اس سے نمٹ لوں گا، کہتے ہیں کہ یہ ولید بن مغیرہ کی طرف اشارہ ہے۔ یہ کفر و طغیان میں بہت بڑھا ہوا تھا، اس لئے اس کا خصوصی طور پر ذکر کیا ہے۔ واللہ عالم۔]
  74,12,"اور اسے بہت سا مال دے رکھا ہے."
  75,7,"پس جس وقت کہ نگاه پتھرا جائے گی.{1}.",footnotes:1:[دہشت اور حیرانی سے برق ،تحیر و اندھش جیسے موت کے وقت عام طور پر ہوتا ہے۔]
  75,8,"اور چاند بے نور ہو جائے گا.{1}.",footnotes:1:[جب چاند کو گرہن لگ جاتا ہے تو اس وقت بھی وہ بےنور ہو جاتا ہے۔ لیکن جو علامات قیامت میں سے ہے، جب ہوگا تو اس کے بعد اس میں روشنی نہیں آئے گی۔]
  75,9,"اور سورج اور چاند جمع کردیئے جائیں گے.{1}.",footnotes:1:[یعنی بےنوری میں۔ مطلب ہے کہ چاند کی طرح سورج کی روشنی بھی ختم ہو جائے گی۔]
  76,1,"یقیناً گزرا ہے انسان پر ایک وقت زمانے میں{1} جب کہ یہ کوئی قابل ذکر چیز نہ تھا..",footnotes:1:[ھل بمعنی قد ہے جیسا کہ ترجمے سے واضح ہے ،الانسان سے مراد 'بعض کے نزدیک ابو البشیر یعنی انسان اول حضرت آدم ہیں اور حِیْن (ایک وقت) سے مراد، روح پھونکے جانے سے پہلے کا زمانہ ہے، جو چالیس سال ہے اور اکثر مفسرین کے نزدیک الانسان کا لفظ بطور جنس کے استعمال ہوا ہے اور حِیْن، سے مراد حمل یعنی رحم مادر کی مدت ہے جس میں وہ قابل ذکر چیز نہیں ہوتا۔ اس میں گویا انسان کو متنبہ کیا گیا ہے کہ وہ ایک پیکر حسن و جمال کی صورت میں جب باہر آتا ہے تو رب کے سامنے اکڑتا اور اتراتا ہے، اسے اپنی حیثیت یاد رکھنی چاہیے کہ میں تو وہی ہوں جب میں عالم نیست میں تھا، تو مجھے کون جانتا تھا؟]
  76,2,"بیشک ہم نے انسان کو ملے جلے نطفے سے امتحان کے لیے{1} پیدا کیا اور اس کو سنتا دیکھتا بنایا.{2}.",footnotes:1:[<strong>مخلوط پانی سے انسان کی تخلیق:</strong>یعنی مرد اور عورت کے دو رنگے پانی سے پیدا کیا۔ (تنبیہ) اَمْشَاجٍ کے معنی مخلوط کے ہیں۔ نطفہ جن عذاؤں کا خلاصہ ہے وہ مختلف چیزوں سے مرکب ہوتی ہیں اس لئے عورت کے پانی سے قطع نظر کرکے بھی اُس کا اَمْشَاجٍ کہہ سکتے ہیں۔,],footnotes:2:[<strong>الٹ پھیر کے بعد دیکھنے سننے والا بنا دیا:</strong>یعنی نطفہ سے جما ہوا خون ، پھر اس سے گوشت کا لوتھڑا بنایا۔ اسی طرح کئ طرح کے الٹ پھیر کرنے کے بعد اس درجہ میں پہنچا دیا کہ اب وہ کانوں سےسنتا اور آنکھوں سے دیکھتا ہے اور  ان قوتوں سے وہ کام لیتا ہے جو کوئی دوسرا حیوان نہیں لے سکتا۔ گویا اور سب اس کے سامنے بہرے اور اندھے ہیں (تنبیہ) نَّبْتَلِیْہِ کے معنی اکثر مفسرین نے امتحان و آزمائش کے لئے ہیں۔ یعنی آدمی کا بنانا اس غرض سے تھا کہ اس کو احکام کا مکلف اور امرونہی کا مخاطب بنا کر امتحان لیا جائے اور دیکھا جائے کہ کہاں تک مالک کے احکام کی تعمیل میں وفاداری دکھلاتا ہے۔ اسی لئے اس کو سننے، دیکھنے، اور سمجھنے کی وہ قوتیں دی گئیں جن پر تکلیف شرعی کامدار ہے۔]
  76,3,"ہم نے اسے راه دکھائی اب خواه وه شکر گزار بنے خواه ناشکرا.{1}.",footnotes:1:[یعنی اسے سماعت اور بصارت کی قوتیں عطا کیں، تاکہ وہ سب کچھ دیکھ سکے اور سن سکے اور اس کے بعد اطاعت یا انکاری دونوں راستوں میں کسی ایک کا انتخاب کر سکے۔]
