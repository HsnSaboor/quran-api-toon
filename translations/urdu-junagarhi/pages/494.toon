quran[31]{c,v,t,f}:
  74,43,"وه جواب دیں گے کہ ہم نمازی نہ تھے."
  74,44,"نہ مسکینوں کو کھانا کھلاتے تھے.{1}.",footnotes:1:[نماز حقوق اللہ میں سے اور مساکین کو کھانا کھلانا حقوق العباد میں سے ہے مطلب یہ ہوا کہ ہم نے اللہ کے حقوق ادا کیے نہ بندوں کے۔]
  74,45,"اور ہم بحﺚ کرنے والے (انکاریوں) کا ساتھ دے کر بحﺚ مباحثہ میں مشغول رہا کرتے تھے.{1}.",footnotes:1:[یعنی کج بحثی اور گمراہی کی حمایت میں سرگرمی سے حصہ لیتے تھے۔]
  75,40,"کیا (اللہ تعالیٰ) اس (امر) پر قادر نہیں کہ مردے کو زنده کردے.{1}.",footnotes:1:[یعنی جواللہ انسان کو اس طرح مختلف اطوار سے گزار کر پیدا فرماتا ہے کیا مرنے کے بعد دوبارہ اسے زندہ کرنے پر قادر نہیں ہے؟]
  77,31,"جو در اصل نہ سایہ دینے واﻻ ہے اور نہ شعلے سے بچاسکتا ہے.{1}.",footnotes:1:[- یعنی جہنم کی حرارت سے بچنا بھی ممکن نہیں ہوگا۔]
  77,32,"یقیناً دوزخ چنگاریاں پھینکتی ہے جو مثل محل کے ہیں.{1}.",footnotes:1:[اس کا ایک ترجمہ ہے جو لکڑی کے بوٹے یعنی بھاری ٹکڑے کے مثل ہیں۔ (بوٹے بمعنی شہتیر کے ٹکڑے، جسے گیلی بھی کہتے ہیں)۔]
  77,33,"گویا کہ وه زرد اونٹ ہیں.{1}.",footnotes:1:[صفر، أصفر (زرد) کی جمع ہے، لیکن عرب میں اس کا استعمال اسود کے معنی میں بھی ہے۔ اس معنی کی بناء پر مطلب یہ ہے کہ اس کی ایک ایک چنگاڑی اتنی اتنی بڑی ہوگی جیسے محل یا قلعہ۔ پھر ہر چنگاڑی کے مذید اتنے بڑے بڑے ٹکڑے ہو جائیں گے جیسے اونٹ ہوتے ہیں۔]
  78,28,"اور بے باکی سے ہماری آیتوں کی تکذیب کرتے تھے."
  78,29,"ہم نے ہر ایک چیز کو لکھ کر شمار کر رکھا ہے.{1}.",footnotes:1:[یعنی لوح محفوظ میں۔ یا وہ ریکارڈ مراد ہے جو فرشتے لکھتے رہے۔ پہلا مفہوم زیادہ صحیح ہے، جیسا کہ دوسرے مقام پر فرمایا وَكُلَّ شَيْءٍ أحْصَيْنَاهُ فِي إِمَامٍ مُبِينٍ (  يس:12) ۔]
  78,30,"اب تم (اپنے کیے کا) مزه چکھو ہم تمہارا عذاب ہی بڑھاتے رہیں گے.{1}.",footnotes:1:[عذاب بڑھانے کا مطلب ہے کہ اب یہ عذاب دائمی ہے۔ جب ان کے چمڑے گل جائیں گے تو دوسرے بدل دیئے جائیں گے۔ (  النساء:56 ) جب آگ بجھنے لگے گی، تو پھر بھڑ کا دی جائے گی۔ بنی اسرائیل:97)۔]
  79,22,"پھر پلٹا دوڑ دھوپ کرتے ہوئے.{1}.",footnotes:1:[یعنی اس نے ایمان واطاعت سےاعراض ہی نہیں کیا بلکہ زمین میں فساد پھیلانے اور موسیٰ (عليه السلام) کا مقابلہ کرنے کی سعی کرتا رہا، چنانچہ جادوگروں کو جمع کرکے ان کا مقابلہ حضرت موسیٰ (عليه السلام) سےکرایا، تاکہ موسیٰ (عليه السلام) کو جھوٹا ثابت کیا جا سکے۔]
  79,23,"پھر سب کو جمع کرکے پکارا.{1}.",footnotes:1:[اپنی قوم کو، یا قتال ومحاربہ کے لئے اپنے لشکروں کو، یا جادوگروں کو مقابلے کے لئے جمع کیا اور ہٹ دھرمی کا مظاہرہ کرتے ہوئے اپنی ربوبیت اعلیٰ کا علان کیا۔]
  79,24,"تم سب کا رب میں ہی ہوں."
  80,19,"اسے) ایک نطفہ{1} سے پیدا کیا،پھراس کا اندازہ مقررکیا .{2}",footnotes:1:[یعنی جس کی پیدائش ایسے حقیر قطرۂ آب سے ہوئی ہے، کیا اسے تکبر زیب دیتا ہے؟,],footnotes:2:[- اس کا مطلب ہے کہ اس کے مصالح نفس اسے مہیا کیے، اس کو دو ہاتھ دو پیر اوردو آنکھیں اور دیگر آلات وخواص عطا کیے۔]
  80,20,"پھر اس کے لئے راستہ آسان کیا.{1}.",footnotes:1:[یعنی خیر اور شر کے راستے اس کے لئے واضح کر دیئے۔ بعض کہتے ہیں اس سے مراد ماں کے پیٹ سے نکلنے کا راستہ ہے۔ لیکن پہلا مفہوم زیادہ صحیح ہے۔]
  80,21,"پھر اسے موت دی اور پھر قبر میں دفن کیا."
  81,16,"چلنے پھرنے والے چھپنے والے ستاروں کی.{1}.",footnotes:1:[اس سے مراد ستارے خُنَّسٌ، خَنَسَ سے ہے جس کے معنی پیچھےہٹنے کے ہیں۔ یہ ستارے دن کے وقت اپنے منظر سے پیچھے ہٹ جاتے ہیں اور نظر نہیں آتے۔ اور یہ زخل، مشتری، مریخ، زہرہ، عطارد ہیں، یہ خاص طور پر سورج کے رخ پر ہوتے ہیں بعض کہتے ہیں کہ سارے ہی ستارےمراد ہیں، کیوں کہ سب ہی اپنے غائب ہونے کی جگہ پر غائب ہو جاتے ہیں یا دن کو چھپے رہتے ہیں الْجَوَارِ چلنے والے، الْكُنَّسِ چھپ جانے والے، جیسے ہرن اپنے مکان اور مسکن میں چھپ جاتا ہے۔]
  81,17,"اور رات کی جب جانے لگے.{1}.",footnotes:1:[عَسْعَسَ، اضداد میں سے ہے، یعنی آنے اور جانے دونوں معنوں میں اس کا استعمال ہوتا ہے، تاہم یہاں جانے کے معنی میں ہے۔]
  81,18,"اور صبح کی جب چمکنے لگے.{1}.",footnotes:1:[یعنی جب اس کا ظہور وطلوع ہو جائے، یا وہ پھٹ اور نکل آئے۔]
  82,10,"یقیناً تم پر نگہبان عزت والے."
  82,11,"لکھنے والے مقرر ہیں."
  82,12,"جوکچھ تم کرتے ہو وه جانتے ہیں.{1}.",footnotes:1:[یعنی تم جو جزا وسزا کے منکر ہو، لیکن تمہیں معلوم ہونا چاہئے کہ تمہارا ہر قول اور ہر فعل نوٹ ہو رہا ہے۔ اللہ کی طرف سے فرشتے تم پر بطور نگران مقرر ہیں جو تمہاری ہر اس بات کو جانتے ہیں جو تم کرتے ہو۔ یہ گویا انسانون کو تنبیہ ہے کہ ہر عمل اور بات سے پہلےسوچ لو کہ وہ غلط تو نہیں۔ یہ وہی بات ہے جو پہلے گزر چکی ہے مثلاً عَنِ الْيَمِينِ وَعَنِ الشِّمَالِ قَعِيدٌ]
  83,7,"یقیناً بدکاروں کا نامہٴ اعمال سِجِّينٌ میں ہے.{1}.",footnotes:1:[سِجِّينٌ، بعض کہتے ہیں سِجْنٌ ( قید خانہ ) سے ہے، مطلب ہے کہ قید خانے کی طرح ایک نہایت تنگ مقام ہے اور بعض کہتے ہیں کہ یہ زمین کے سب سے نچلے حصے میں ایک جگہ ہے، جہاں کافروں، ظالموں اور مشرکوں کی روحیں اور ان کے اعمال نامے جمع اور محفوظ ہوتے ہیں۔ اسی لئے آگے اسے (لکھی ہوئی کتاب) قرار دیا ہے۔]
  83,8,"تجھے کیا معلوم سِجِّينٌ کیا ہے؟"
  83,9,"(یہ تو) لکھی ہوئی کتاب ہے."
  84,4,"اور اس میں جو ہے اسے وه اگل دے گی اور خالی ہو جائے گی.{1}.",footnotes:1:[یعنی اس میں جو مردے دفن ہیں، سب زندہ ہو کر باہر نکل آئیں گے جو خزانے اس کے بطن میں موجود ہیں، وہ انہیں ظاہر کر دے گی، اور خود بالکل خالی ہو جائے گی۔]
  84,5,"اور اپنے رب کے حکم پر کان لگائے گی{1} اور اسی کے ﻻئق وه ہے..",footnotes:1:[یعنی القا اور تخلی کا جو حکم اسے دیا جائے گا، وہ اس کے مطابق عمل کرے گی ۔]
  84,6,"اے انسان! تو اپنے رب سے ملنے تک یہ کوشش اور تمام کام اور محنتیں کرکے اس سے ملاقات کرنے واﻻ ہے.{1}.",footnotes:1:[- یہاں انسان بطور جنس کے ہے جس میں مومن اور کافر دونوں شامل ہیں۔ کدح،سخت محنت کو کہتے ہیں، وہ محنت خیر کے کاموں کے لئے ہو یا شر کےلئے۔ مطلب یہ ہے کہ جب مذکورہ چیزیں ظہور پذیر ہوں گی یعنی قیامت آجائے گی تو اے انسان تو نے جو بھی، اچھا یا برا عمل کیا ہوگا، وہ تو اپنے سامنے پالے گا اور اسی کے مطابق تجھے اچھی یا بری جزا بھی ملے گی۔ آگے اس کی مزید تفصیل ووضاحت ہے۔]
  85,1,"برجوں والے آسمان کی قسم!{1}.",footnotes:1:[بُرُوجٌ، بُرْجٌ محل کی جمع ہے۔ بُرْجٌ کے اصل معنی ہیں ظہور۔ یہ کواکب کی منزلیں ہیں جنہیں ان کے محل اور قصور کی حیثیت حاصل ہے۔ ظاہر اور نمایاں ہونے کی وجہ سے انہیں بروج کہا جاتا ہے۔ تفصیل کے لئےدیکھئے  الفرقان،61 کا حاشیہ۔ بعض نے بروج سے مراد ستارے لئے ہیں۔ یعنی ستارے والے آسمان کی قسم۔ بعض کے نزدیک اس سے آسمان کے دروازے یا چاند کی منزلیں مراد ہیں ۔( فتح القدیر )۔]
  85,2,"وعده کیے ہوئے دن کی قسم!{1}.",footnotes:1:[اس سے مراد بالاتفاق قیامت کا دن ہے۔]
  85,3,"حاضر ہونے والے اور حاضر کئے گئے کی قسم!{1}.",footnotes:1:[شَاهِدٍ اور مَشْهُودٍ کی تفسیر میں بہت اختلاف ہے۔ امام شوکانی نے احادیث وآثار کی بنیاد پر کہا ہے کہ شاہد سے مراد جمعہ کا دن ہے، اس دن جس نےجو بھی عمل کیا ہوگا یہ قیامت کے دن اس کی گواہی دے گا۔ اور مشہود سے عرفے (9 ذوالحجہ ) کا دن ہے جہاں لوگ حج کے لئے جمع اور حاضر ہوتے ہیں۔]
