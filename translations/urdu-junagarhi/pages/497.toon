quran[34]{c,v,t,f}:
  74,52,"بلکہ ان میں سے ہر شخص چاہتا ہے کہ اسے کھلی ہوئی کتابیں دی جائیں.{1}.",footnotes:1:یعنی ہر ایک کے ہاتھ میں اللہ کی طرف سے ایک ایک کتاب مفتوح نازل ہو جس میں لکھا ہو کہ محمد (صلی اللہ علیہ وسلم) اللہ کے رسول ہیں۔ بعض نے اس کا مفہوم یہ بیان کیا ہے کہ بغیر عمل کے یہ عذاب سے چھٹکارہ چاہتے ہیں، یعنی ہر ایک کو پروانہ نجات مل جائے۔ (ابن کثیر)
  74,53,"ہرگز ایسا نہیں (ہوسکتا بلکہ) یہ قیامت سے بے خوف ہیں.{1}.",footnotes:1:یعنی ان کے فساد کی وجہ سے ان کا آخرت پر عدم ایمان اور اس کی تکذیب ہے جس نے انہیں بےخوف کر دیا ہے۔
  74,54,"سچی بات تو یہ ہے کہ یہ (قرآن) ایک نصیحت ہے.{1}.",footnotes:1:لیکن اس کے لئے جو اس قرآن کے واعظ اور نصیحت سے عبرت حاصل کرنا چاہے۔
  77,40,"وائے ہے اس دن جھٹلانے والوں کے لیے."
  77,41,"بیشک پرہیزگار لوگ سایوں میں ہیں{1} اور بہتے چشموں میں..",footnotes:1:یعنی درختوں اور محلات کے سائے، آگ کے دھوئیں کا سایہ نہیں ہوگا جیسے مشرکین کے لئے ہوگا۔
  77,42,"اور ان میووں میں جن کی وه خواہش کریں. {1}.",footnotes:1:[" ہر قسم کے پھل، جب بھی خواہش کریں گے، آ موجود ہونگے۔"]
  78,37,"(اس رب کی طرف سے ملے گا جو کہ) آسمانوں کا اور زمین کا اور جو کچھ ان کے درمیان ہے ان کا پروردگار ہے اور بڑی بخشش کرنے واﻻ ہے۔ کسی کو اس سے بات چیت کرنے کا اختیار نہیں ہوگا.{1}.",footnotes:1:یعنی اس کی عظمت، ہیبت اور جلالت اتنی ہوگی کہ ابتداءً اس سےکسی کو بات کرنے کی ہمت نہ ہوگی، اسی لئے اس کی اجازت کے بغیر کوئی شفاعت کے لئے بھی لب کشائی نہیں کر سکے گا۔
  78,38,"جس دن روح اور فرشتے صفیں باندھ کر کھڑے ہوں گے{1} تو کوئی کلام نہ کر سکے گا مگر جسے رحمٰن اجازت دے دے اور وه ٹھیک بات زبان سے نکالے.{2}",footnotes:1:[یہاں جبرائیل (عليه السلام) سمیت رُوحٌ کے کئی مفہوم بیان کئے گئے ہیں، امام ابن کثیر نے بنو آدم ( انسان ) کو اشبہ ( قرین قیاس ) قرار دیا ہے۔,]footnotes:2:[- یہ اجازت اللہ تعالیٰ ان فرشتوں کو اور اپنے پیغمبروں کو عطا فرمائے گا اور وہ جو بات کریں گی حق وصواب ہی ہوگی، یا یہ مفہوم ہے کہ، اجازت صرف اسی کےبارے میں دی جائے گی جس نے درست بات کہی ہو۔ یعنی کلمہ توحید کا اقراری رہا ہو۔]
  78,39,"یہ دن حق ہے{1} اب جو چاہے اپنے رب کے پاس (نیک اعمال کر کے) ٹھکانا بنالے.{2}",footnotes:1:[یعنی لا محالہ آنے والا ہے۔,]footnotes:2:[- یعنی اس آنے والے دن کو سامنےرکھتے ہوئے ایمان وتقویٰ کی زندگی اختیار کرے تاکہ اس روز وہاں اس کو اچھا ٹھکانہ مل جائے۔]
  79,31,"اس میں سے پانی اور چاره نکالا."
  79,32,"اور پہاڑوں کو (مضبوط) گاڑ دیا."
  79,33,"یہ سب تمہارے اور تمہارے جانوروں کے فائدے کے لئے (ہیں)."
  80,28,"اور انگور اور ترکاری."
  80,29,"اور زیتون اور کھجور."
  80,30,"اور گنجان باغات."
  81,25,"اور یہ قرآن شیطان مردود کا کلام نہیں.{1}.",footnotes:1:جس طرح نجومیوں کے پاس شیطان آتے ہیں اور آسمانوں کی بعض چوری چھپی باتیں ادھوری شکل میں انہیں بتلا دیتے ہیں۔ قرآن ایسا نہیں ہے۔
  81,26,"پھر تم کہاں جا رہے ہو.{1}.",footnotes:1:یعنی کیوں اس سےاعراض کرتے ہو ؟ اور اس کی اطاعت نہیں کرتے ؟
  81,27,"یہ تو تمام جہان والوں کے لئے نصیحت نامہ ہے."
  82,19,"(وه ہے) جس دن کوئی شخص کسی شخص کے لئے کسی چیز کا مختار نہ ہوگا، اور (تمام تر) احکام اس روز اللہ کے ہی ہوں گے.{1}.",footnotes:1:یعنی دنیا میں تو اللہ نے عارضی طور پر، آزمانے کے لئے، انسانوں کو کم وبیش کے کچھ فرق کے ساتھ اختیارات دے رکھے ہیں۔ لیکن قیامت والےدن تمام اختیارات کلیتاً صرف اور صرف اللہ کےپاس ہوں گے۔ جیسے فرمایا لِمَنِ الْمُلْكُ الْيَوْمَ لِلَّهِ الْوَاحِدِ الْقَهَّارِ ۔ ( سورۂ مؤمن:16 ) چنانچہ نبی (صلى الله عليه وسلم) نے اپنی پھوپھی حضرت صفیہ (رضی الله عنها) اور اپنی صاحبزادی حضرت فاطمہ (رضی الله عنها) کو فرما دیا تھا، ”لا أَمْلِكُ لَكُمْ مِنَ اللهِ شَيْئًا“ (صحيح مسلم، كتاب الإيمان) اور بنی ہاشم اور بنی عبدالمطلب کو بھی متنبہ فرما دیا، ”أَنْقِذُوا أَنْفُسَكُمْ مِنَ النَّارِ، وَاللهِ لا أَمْلِكُ لَكُمْ مِنَ اللهِ شَيْئًا“ (مسلم ، كتاب مذكور ، بخاري ، سورة الشعراء ) ۔
  83,16,"پھر یہ لوگ بالیقین جہنم میں جھونکے جائیں گے."
  83,17,"پھر کہہ دیا جائے گا کہ یہی ہے وه جسے تم جھٹلاتے رہے."
  83,18,"لرگزنہیں،بےشک نیکوکاروں کے اعمال نامے علییں میں ہیں .{1}.",footnotes:1:عِلِّيِّينُ، عُلُوٌّ ( بلندی ) سے ہے۔ یہ سِجِّينٌ کے برعکس، آسمانوں میں یا جنت میں یا سدرۃ المنتہیٰ یا عرش کے پاس جگہ ہے جہاں نیک لوگوں کی روحیں اور ان کے اعمال نامے محفوظ ہیں، جس کے پاس مقرب فرشتے حاضر ہوتے ہیں۔
  84,13,"یہ شخص اپنے متعلقین میں (دنیا میں) خوش تھا.{1}.",footnotes:1:یعنی دنیا میں اپنی خواہشات میں مگن اور اپنے گھر والوں کےدرمیان بڑا خوش تھا۔
  84,14,"اس کا خیال تھا کہ اللہ کی طرف لوٹ کر ہی نہ جائے گا.{1}.",footnotes:1:یہ اس کے خوش ہونے کی علت ہے۔ یعنی آخرت پر اس کا عقیدہ ہی نہیں تھا ۔ حور کےمعنی ہیں، لوٹنا۔ جس طرح نبی (صلى الله عليه وسلم) کی دعا ہے اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنَ الْحَورِ بَعْدَ الْكَورِ(صحيح مسلم، الحج، باب ما يقول إذا ركب إلى سفر الحج وغيره، ترمذي، ابن ماجه ) مسلم میں بعد الكون ہے۔ مطلب ہے، اس بات سے میں پناہ مانگتا ہوں کہ ایمان کے بعد کفر، اطاعت کے بعد معصیت یاخیر کے بعد شر کی طرف لوٹوں۔
  84,15,"کیوں نہیں{1}، حاﻻنکہ اس کا رب اسے بخوبی دیکھ رہا تھا.{2}",footnotes:1:[ایک ترجمہ اس کا یہ بھی ہے کہ یہ کیسے ہو سکتا ہے کہ یہ نہ لوٹے اور دوبارہ زندہ نہ ہو، یا بَلَى، کیوں نہیں، یہ ضرور اپنے رب کی طرف لوٹے گا۔,]footnotes:2:[- یعنی اس سے اس کا کوئی عمل مخفی نہیں تھا۔]
  85,10,"بیشک جن لوگوں نے مسلمان مردوں اور عورتوں کو ستایا پھر توبہ (بھی) نہ کی تو ان کے لئے جہنم کا عذاب ہے اور جلنے کا عذاب ہے."
  85,11,"بیشک ایمان قبول کرنے والوں اور نیک کام کرنے والوں کے لئے وه باغات ہیں۔ جن کے نیچے نہریں بہہ رہی ہیں۔ یہی بڑی کامیابی ہے."
  85,12,"یقیناً تیرے رب کی پکڑ بڑی سخت ہے.{1}.",footnotes:1:یعنی جب وہ اپنے ان دشمنوں کی گرفت پر آئے جو اس کے رسولوں کی تکذیب کرتے اور ان کے حکموں کی مخالفت کرتے ہیں۔ تو پھر اس کی گرفت سے انہیں کوئی نہیں بچا سکتا۔
  86,4,"کوئی ایسا نہیں جس پر نگہبان فرشتہ نہ ہو.{1}.",footnotes:1:یعنی ہر نفس پر اللہ کی طرف سے فرشتے مقرر ہیں جو اس کے اچھے یا برے سارے عمل لکھتے ہیں۔ بعض کہتے ہیں، یہ انسانوں کی حفاظت کرنے والے فرشتے ہیں، جیسا کہ سورۂ رعد کی آیت نمبر ۔ 11 سے معلوم ہوتا ہے کہ انسان کی حفاظت کے لئے بھی انسان کے آگے پیچھے فرشتے ہوتے ہیں، جس طرح قول وفعل لکھنے والے ہوتے ہیں۔
  86,5,"انسان کو دیکھنا چاہئے کہ وه کس چیز سے پیدا کیا گیا ہے."
  86,6,"وه ایک اچھلتے پانی سے پیدا کیا گیا ہے.{1}.",footnotes:1:یعنی منی سے، جو قضائے شہوت کے بعد زور سے نکلتی ہے۔ یہی قطرۂ آب ( منی ) رحم عورت میں جاکر، اگر اللہ کا حکم ہوتا ہے تو، حمل کا باعث بنتا ہے۔
  87,1,"اپنے بہت ہی بلند اللہ کے نام کی پاکیزگی بیان کر.{1}.",footnotes:1:یعنی ایسی چیزوں سے اللہ کی پاکیزگی جو اس کے لائق نہیں ہے۔ حدیث میں آتا ہے کہ نبی (صلى الله عليه وسلم) اس کے جواب میں پڑھا کرتے تھے، سُبْحَانَ رَبِّيَ الأَعْلَى (مسند أحمد، 1/ 232 ۔ أبو داود، كتاب الصلاة، باب الدعاء في الصلاة، وقال الألباني صحيح ) ۔
  87,2,"جس نے پیدا کیا اور صحیح سالم بنایا.{1}.",footnotes:1:دیکھئے سورۃ الانفطار کا حاشیہ نمبر۔ 7
  87,3,"اور جس نے (ٹھیک ٹھاک) اندازه کیا اور پھر راه دکھائی.{1}.",footnotes:1:یعنی نیکی اور بدی کی۔ اس طرح ضروریات زندگی کی۔ یہ ہدایت حیوانات کو بھی عطا فرمائی۔ قَدَرٌ کا مفہوم ہے۔ اشیا کی جنسوں، ان کی انواع وصفات اور خصوصیات کا اندازہ فرما کر انسان کی بھی ان کی طرف رہنمائی فرما دی تاکہ انسان ان سے استفادہ کر سکے۔