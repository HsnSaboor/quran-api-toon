quran[25]{c,v,t,f}:
  79,43,"آپ کو اس کے بیان کرنے سے کیا تعلق؟{1}.",1:[یعنی آپ کو اس کی بابت یقینی علم نہیں ہے، اس لئے آپ کا اس کو بیان کرنے سے کیا تعلق؟ اس کا یقینی علم تو صرف اللہ ہی کے پاس ہے۔]
  79,44,"اس کے علم کی انتہا تو اللہ کی جانب ہے."
  79,45,"آپ تو صرف اس سے ڈرتے رہنے والوں کو آگاه کرنے والے ہیں.{1}.",1:[یعنی آپ کا کام صرف انذار ( ڈرانا ) ہے، نہ کہ غیب کی خبریں دینا، جن میں قیامت کا علم بھی ہے جو اللہ نے کسی کو بھی نہیں دیا۔ مَنْ يَخْشَاهَا اس لئے کہا کہ انذار وتبلیغ سے اصل فائدہ وہی اٹھاتے ہیں جن کے دلوں میں اللہ کا خوف ہوتا ہے، ورنہ انذار وتبلیغ کا حکم تو ہر ایک کے لئےہے۔]
  80,40,"اور بہت سے چہرے اس دن غبار آلود ہوں گے."
  80,41,"جن پر سیاہی چڑھی ہوئی ہوگی.{1}.",1:[یعنی ذلت اور معائینہ عذاب سے ان کے چہرے غبار آلود، کدورت زدہ اور سیاہ ہوں گے، جیسے محزون اور نہایت غمگین آدمی کا چہرہ ہوتا ہے۔]
  80,42,"وه یہی کافر بدکردار لوگ ہوں گے.{1}.",1:[یعنی اللہ کا، رسولوں کا اور قیامت کا انکار کرنے والے بھی تھے اور بدکردار اور بداطوار بھی۔ اللَّهُمَّ! لا تَجْعَلْنَا مِنْهُمْ ۔]
  83,28,"(یعنی) وه چشمہ جس کا پانی مقرب لوگ پیئں گے."
  83,29,"گنہگار لوگ ایمان والوں کی ہنسی اڑایا کرتے تھے.{1}.",1:[یعنی انہیں حقیر جانتے ہوئے ان کا استہزا کرتے اور مذاق اڑاتے تھے۔]
  83,30,"اور ان کے پاس سے گزرتے ہوئے آپس میں آنکھ کےاشارے کرتے تھے.{1}.",1:[غَمْزٌ کے معنی ہوتے ہیں، پلکوں اور ابروں سے اشارہ کرنا۔ یعنی ایک دوسرے کو اپنی پلکوں اور ابروں سے اشارہ کر کے ان کی تحقیرا ور ان کے مذہب پر طعن کرتے۔]
  84,25,"ہاں ایمان والوں اور نیک اعمال والوں کو بے شمار اور نہ ختم ہونے واﻻ اجر ہے."
  85,22,"لوح محفوظ میں (لکھا ہوا).{1}.",1:[یعنی لوح محفوظ میں لکھا ہوا ہے، جہاں فرشتے اس کی حفاظت پر مامور ہیں، اللہ تعالیٰ حسب ضرورت واقتضا اسے نازل فرماتا ہے۔]
  86,16,"اور میں بھی ایک چال چل رہا ہوں.{1}.",1:[یعنی میں ان کی چالوں اور سازشوں سے غافل نہیں ہوں، میں بھی ان کے خلاف تدبیر کر رہا ہوں یا ان کی چالوں کا توڑ کر رہا ہوں۔ كَيْدٌ خفیہ تدبیر کو کہتے ہیں، جو برے مقصد کے لئے ہو تو بری ہے اور مقصد نیک ہو تو بری نہیں۔]
  86,17,"تو کافروں کو مہلت دے{1} انہیں تھوڑے دنوں چھوڑ دے..",1:[یعنی ان کے لئے تعجیل عذاب کا سوال نہ کر، بلکہ انہیں کچھ مہلت دے دے۔ رُوَيْدًا : قَلَيلا یا قَرِيبًا یہ امہال واستدراج بھی کافروں کے حق میں اللہ کی طرف سے ایک کید کی صورت ہے جیسے فرمایا سَنَسْتَدْرِجُهُمْ مِنْ حَيْثُ لا يَعْلَمُونَ]
  87,13,"جہاں پھر نہ وه مرے گا نہ جئےگا{1}، (بلکہ حالت نزع میں پڑا رہے گا)..",1:[ان کے برعکس جو لوگ صرف اپنے گناہوں کی سزا بھگتنے کے لئے عارضی طور پر جہنم میں رہ گئے ہوں گے انہیں اللہ تعالیٰ ایک طرح کی موت دے دے گا۔ حتیٰ کہ وہ آگ میں جل کر کوئلہ ہو جائیں گے، پھر اللہ تعالیٰ انبیا وغیرہ کی سفارش سے ان کو گروہوں کی شکل میں نکالے گا، ان کو جنت کی نہر میں ڈالا جائے گا، جنتی بھی ان پر پانی ڈالیں گے، جس سے وہ اس طرح جی اٹھیں گے جیسے سیلاب کے کوڑے پردانہ اگ آتا ہے ۔ (صحيح مسلم، كتاب الإيمان، باب إثبات الشفاعة وإخراج الموحدين من النار)۔]
  87,14,"بیشک اس نے فلاح پالی جو پاک ہوگیا.{1}.",1:[جنہوں نے اپنے نفس کو اخلاق رذیلہ سے اور دلوں کو شرک ومعصیت کی آلودگی سے پاک کر لیا۔]
  87,15,"اور جس نے اپنے رب کا نام یاد رکھا اور نماز پڑھتا رہا."
  88,10,"بلند وباﻻ جنتوں میں ہوں گے."
  88,11,"جہاں کوئی بیہوده بات نہیں سنیں گے."
  88,12,"جہاں بہتا ہوا چشمہ ہوگا."
  89,7,"ستونوں والے ارم کے ساتھ.{1}.",1:[إِرَمَ، عَادٍ سے عطف بیان یا بدل ہے۔ یہ قوم عاد کے دادا کا نام ہے۔ ان کا سلسلہ نسب ہے، عاد بن عوص بن ارم بن سام بن نوح۔ ( فتح القدیر ) اس کا مقصد یہ وضاحت ہے کہ یہ عاد اولیٰ ہے۔ ذات العماد ( ستونوں والے ) سے اشارہ ہے ان کی قوت وطاقت اور دراز قامتی کی طرف۔]
  89,8,"جس کی مانند (کوئی قوم) ملکوں میں پیدا نہیں کی گئی.{1}.",1:[یعنی ان جیسی دراز قامت اور قوت وطاقت والی قوم کوئی اور پیدا نہیں ہوئی۔ یہ قوم کہا کرتی تھی مَنْ أَشَدُّ مِنَّا قُوَّةً ( حم السجدة،: 15 ) (ہم سے زیادہ کوئی طاقت ور ہے) ؟۔]
  89,9,"اور ثمودیوں کے ساتھ جنہوں نے وادی میں بڑے بڑے پتھر تراشے تھے.{1}.",1:[یہ حضرت صالح (عليه السلام) کی قوم تھی، اللہ نے اسے پتھر تراشنے کی خاص صلاحیت وقوت عطا کی تھی، حتیٰ کہ یہ لوگ پہاڑوں کو تراش کر ان میں اپنی رہائش گاہیں تعمیر کر لیتے تھے، جیسا کہ قرآن نے کہا ہے وَتَنْحِتُونَ مِنَ الْجِبَالِ بُيُوتًا فَارِهِينَ (  الشعراء: 149 ) ۔]
  90,1,"میں اس شہر کی قسم کھاتا ہوں.{1}.",1:[اس سے مراد مکہ مکرمہ ہے جس میں اس وقت، جب اس سورت کا نزول ہوا، نبی کریم (صلى الله عليه وسلم) کا قیام تھا، آپ (صلى الله عليه وسلم) کا مولد بھی یہی شہر تھا۔ یعنی اللہ نے آپ (صلى الله عليه وسلم) کو مولد ومسکن کی قسم کھائی، جس سے اس کی عظمت کی مزید وضاحت ہوتی ہے۔]
  90,2,"اور آپ اس شہر میں مقیم ہیں.{1}.",1:[یہ اشارہ ہے اس وقت کی طرف جب مکہ فتح ہوا، اس وقت اللہ نے نبی (صلى الله عليه وسلم) کے لئے اس بلد حرام میں قتال کو حلال فرما دیا تھا جب کہ اس میں لڑائی کی اجازت نہیں ہے چنانچہ حدیث میں ہے، نبی (صلى الله عليه وسلم) نے فرمایا (اس شہر کو اللہ نے اس وقت سے حرمت والا بنایا ہے، جب سے اس نے آسمان وزمین پیدا کیے۔ پس یہ اللہ کی ٹھہرائی ہوئی حرمت سے قیامت تک حرام ہے، نہ اس کا درخت کاٹا جائے نہ اس کے کانٹے اکھیڑے جائیں، میرے لئے اسے صرف دن کی ایک ساعت کے لئے حلال کیا گیا تھا اور آج اس کی حرمت پھر اسی طرح لوٹ آئی ہے، جیسے کل تھی ۔۔۔ اگر کوئی یہاں قتال کے لئے دلیل میں میری لڑائی کو پیش کرے تو اس سےکہو کہ اللہ کے رسول کو تو اس کی اجازت اللہ نے دی تھی جب کہ تمہیں یہ اجازت اس نے نہیں دی)۔ ( صحيح بخاري، كتاب العلم ، باب ليبلغ الشاهد منكم الغائب- مسلم، كتاب الحج، باب تحريم مكة ...) اس اعتبار سے معنی ہوں گے وَأَنْتَ حِلٌّ بِهَذَا الْبَلَدِ فِي الْمُسْتَقْبَلِ یہ جملہ معترضہ ہے۔]
  90,3,"اور (قسم ہے) انسانی باپ اور اوﻻد کی.{1}.",1:[بعض نے اس سے مراد حضرت آدم (عليه السلام) اور ان کی اولاد لی ہے، اور بعض کے نزدیک یہ عام ہے، ہر باپ اور اس کی اولاد اس میں شامل ہے۔]
