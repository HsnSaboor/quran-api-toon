quran[4]{c,v,t}:
  9,37,"۔نَسِی چھےٚ کفرس منٛز اکھ مز ید کا فر انہٕ حر کت ییٚمہِ سٍتۍ یِم کٲفر لُکھ چِھ گمرٲہی منٛز مبتلا کر نہٕ یِوان، کُنہِ ؤرِیہِ چِھ أکِس ریٚتس حلال کران ۔تہٕ کُنہِ ؤرِیہِ چِھ تتھ حرا م کران،تا کہ اللہ تعالیٰ سٕندٮ۪ن حرام کر نہٕ آمتیٚن ریٚتن ہُند تعداد تہِ کر ن پوٗرٕ،تہٕ اللہ تعالیٰ سُند حرام کر نہٕ آمُت کر ن حلال تہِ ۔عر بس منٛز ٲس نَسِی دوٚ یہِ قٔسمٕچ۔اکھ صورت ٲس یہِ زِ جنگ و جد ل تہٕ غا رت گر ی تہٕ خو نٕکۍ انتقام ہیٚنہٕ خٲطرٕ ٲسۍ کُنہِ حرام ریٚتس حلال دِوان قرار،تہٕ امہِ بد لہٕ کُنہِ حلال ریٚتس حرام کٔرِ تھ ریٚتن ہُند تعداد پوٗرٕ کران۔دوٚ یِم صورت ٲس یہِ زِ قمر ی ؤرِ یس ٲسۍ شمسی ؤری مطٲبق بناو نہٕ مۅ کھہٕ اَتھ کبیسہ ہُک اکھ ریٚتھ بڑاوان تاکہ حج گژِھہ أکۍ سٕے مو سمس منٛزیِوان روزُن ،تہٕ  تِم گژھن تِمو تکلیفو نِشہِ بچنۍ ،یِم قمر ی حسا بہٕ مطٲبق  مختلف مو سمن منٛز حجُک گردش کران روز نہٕ سٍتۍ پیش چِھ یِوان۔یِتھہٕ پٲٹھۍ اوس حج ، 33 ہَن ؤرِین تام پننِس اصلی وقتس خلا ف دوٚ یمیٚن تٲریخن منٛز سپدان روزان تہٕ صرف اوس ژۅ یہِ ترٛہِمہِ 34 ؤرِ یہِ اکہِ لٹہِ پننِس اصلی تٲر یخس یعنی ذی الحجہ کِس نٔوِ مِس تہٕ دٔہِمِس تٲریخس پٮ۪ٹھ ادا سپدان۔نبی صلی اللہ علیہ وسلمو ییٚمہِ ؤرِ یہِ حجتہ الوادع کوٚر مُت چُھ ،تمہِ ؤرِ یہِ اوس پننیٚن اصلی تار یخن پٮ۪ٹھ حج آمُت تہٕ تمی وقتہٕ پٮ۪ٹھہٕ آو نَسِی ہُند طر یقہ ممنو ع کر نہٕ  تِہندۍ بُرٕ اعمال چِھ تِہٕندِ خٲطرٕ خۅ ش کرٕ وُنۍ بنا و نہٕ آمٕتۍ تہٕ اللہ تعالیٰ چُھنہٕ منکر ینِ حقن ہدا یت دِوان ۔ع"
  9,38,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت۔ یِم آیات چِھ رکوع ،9 کِس ٲخرس تام غزوۂ تبو ک چہِ تیٲری ہٕندِ وقتہٕ نٲزِل گٔمٕتۍ تۅہیہِ کیا سَپدُو ،زِ ییٚلہِ تۅہیہِ اللہ تعالیٰ سٕنزِ وَتہِ منٛزنیر نہٕ خٲطرٕ وَننہٕ آو،تہٕ توٚہۍ گٔو زمینس سٍتۍ لٲرِ تھ؟ کیا ٲخرت کِس مقا بلس منٛز کٔروٕہ تۅہیہِ دُنیا ہٕچ زند گی پسند؟ اگر یہِ کتھ چھےٚ تیٚلہِ گژِھہ تۅہیہِ پے آسٕنۍ ، زِ دُنیٲوی زند گی ہُند یہِ سورُے ساز و سامان نیرِ ٲخرتس منٛز واریاہ کم،"
  9,39,"۔اگر توٚہۍ ؤتھِو نہٕ ،تیٚلہِ دِیَو اللہ تعالیٰ تۅہیہِ دگ تُلوُن عذا ب،تہٕ تُہنزِ جایہِ تُلہِ بیٚیہِ کٲنٛسہِ دٔرِس،تہٕ توٚہۍ ہیٚکِو نہٕ خُدا یس  کانٛہہ نقصا ن واتنٲوِتھ،سُہ چُھ پرٛتھ چیز س پٮ۪ٹھ قدرت تھاوان۔"
  9,40,"۔تۅہیہِ اگر نبی صلی اللہ علیہ وسلمس  مدد کوٚرُو نہٕ تیٚلہِ چُھنہٕ کانٛہہ پرواے ،خُدا ین چُھ تَس تمہِ وقتہٕ مدد کوٚر مُت ییٚلہِ کٲفِر و سُہ کٔڑِتھ اوس ژُھنمُت ، ییٚلہِ سُہ صرف دۅ ن منٛز دوٚ یُم اوس ، ییٚلہِ تِم دۅ شو ے غا رس منٛز ٲسۍ ،ییٚلہِ سُہ پننِس سٲتھِیَس ونان اوس زِ غم مَہ کر اللہ تعالیٰ چُھ اَسہِ سٍتۍ۔ یہِ ذکر چھےٚ تمہِ ساعتٕچ ییٚلہِ کفارِ مکہ چِھ نبی صلی اللہ علیہ وسلمن ہٕندِ قتلُک قصد کران تہٕ حضور صلی اللہ علیہ وسلم  چِھ عین تمی رٲژ یۅ سہٕ قتلہٕ خٲطرٕ مقرر ٲس کر نہٕ آمٕژ مکہ منٛزٕ نیرِ تھ غارِ ثو رس منٛز تر ٮ۪ن دۅ ہن کھٔٹِتھ روزان تہٕ امہِ پتہٕ چِھ مد ینس کُن ہجر ت کران۔تمہِ وقتہٕ چِھ صرف حضرت ابو بکر رضی اللہ غا رس منٛز تِمن سٍتۍ آسان  تمہِ وقتہٕ کوٚر خُدا ین تَس پٮ۪ٹھ سکو ن ِ قلب نٲزِل تہٕ تس کوٚرُن تِمو لشکرَو و سٍتۍ مدد یِم تۅہیہِ اَتھہِ ٲسِو نہٕ یِوان، تہٕ کٲفر ن سپٕز نا کٲمی  تہٕ اللہ تعالیٰ سُند کلمہ چُھ تھوٚدُے، اللہ تعالیٰ چُھ زبردست بیٚیہِ دانان تہٕ بینا۔"