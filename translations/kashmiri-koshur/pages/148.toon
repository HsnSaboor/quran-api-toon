quran[5]{c,v,t}:
  6,147,"۔وۅ نۍ اگر تِم تۅہیہِ بُتھ پھرن تیٚلہِ ؤنِو تِمن زِ تُہندِس ربّ سٕندِ رحمتُک دا من چُھ وسیع ،تہٕ مجر  مَو نِشہِ یِیہِ نہٕ تٔمۍ سُند عذا ب وا پس پھِر نہٕ۔"
  6,148,"۔یِم مشر ک لُکھ وَنن تُہٕنز ن یِمن کتھن ہٕندِس جوا بس منٛز ضرور زِ اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ نہ کرہَو أسۍ شر ک تہٕ نہ کر ہَن سٲنۍ مٲلۍ بُڈِ بب، تہٕ نہ ٹھہرا وٕ ہَو أسۍ کانٛہہ چیز حرام۔یعنی تِم کر ن پنُن جُر م تہٕ پننہِ غلط کٲر ی خٲطرٕ سُے پر ون عُذر پیش یُس ہمیشہ چِھ مُجر م تہٕ غلط کار لُکھ  پیش کران روٗدِمٕتۍ۔ تِم ونن زِ سٲنِس حقس منٛز چھےٚ اللہ تعالیٰ سٕنز مشیت یٔہے زِ أسۍ گژھو شر ک کرٕنۍ تہٕ یِم چیز اسہِ حرا م چِھ ٹھہرٲوِمٕتۍ تِم ٹھہراووکھ حرام۔نَتہٕ اگر اللہ تعالیٰ ییٚژھہ ہے نہٕ زِ أسۍ گٔژھۍ یہِ کرٕنۍ تیٚلہِ کِتھہٕ پٲٹھۍ اوس ممکن زِ سانہِ دٔسۍ گژھن یِمہٕ کامہِ سرزد۔لہٰذا چِھ أسۍ اللہ تعالیٰ سٕندِس  مشیّتس مطٲبق یہِ سورُے کینٛہہ کران، امہِ موجو ب چِھ صحیح کران۔وۅ نۍ اگر اَمِیُک الزام لگہِ سُہ لگہِ نہٕ اسہِ ، سُہ لگہِ خُدا یس ۔تہٕ یِکینژھاہ أسۍ کران چِھ ، أسۍ چِھ یی کر نہٕ خٲطرٕ مجبور تِکیازِ امہِ ورٲے بیٚیہِ کینٛہہ کرُن چُھ سانہِ طا قتہٕ نِشہِ نیٚبر۔ یِژَے کتھہٕ بنٲوۍ بنٲوۍ اوس یِمن بروٗنٹھمیو لُکو تہِ حقس انکار کوٚر مُت یوٚت تام زن ٲخرکار سانہِ عذا بُک مزٕہ تِمو وُچھ،یِمن ؤنِو  کیا تۅہیہِ نِشہِ چھا کانٛہہ علم یُس اسہِ برونٛہہ کنہِ پیش ہیٚکِو کٔرِتھ؟ توٚہۍ چِھو صرف گُما نس پٮ۪ٹھ پکا ن تہٕ ژھر ے قیا س آرٲیِیہِ چِھو کران۔"
  6,149,"۔پتہٕ ؤنوتُہٕندس اتھ حُجت کِس مقا بلس منٛزحقیقت رس یعنی پوٗرٕ غٲلب حُجت چھےٚ خُدا یس نِشہِ ، بے شک ہرگاہ اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ دِیہِ ہیٚو تۅہیہِ سارِنٕے ہدا یت۔ یعنی توٚہۍ یۅسہٕ حُجت پننہِ عذرٕ رٔنگۍ پیش چِھو کران زِ اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ کر ہَو نہٕ أسۍ شر ک۔امہِ نِشہِ چَھنہٕ پوٗرٕ کتھہ ادا سپدان۔پوٗرٕ کتھ اگر وَنٕنۍ چِھو یَژھان تیٚلہِ ؤنِو یِتھہٕ پٲٹھۍ زِ اگر اللہ تعالیٰ ییٚژِھہ ہے تیٚلہِ دِیہِ ہے اسہِ سارِنٕے ہدایت۔دوٚیِمیٚن لفظن منٛز  وَنَو زِ توٚہۍ چِھو نہٕ پننہِ اِنتخا ب نِشہِ سِیٔز وتھ اختیار کر نہٕ خٲطرٕ تیار، بلکہ چِھو یہِ یژھان زِ خُدا ین یِتھہٕ پٲٹھۍ فر شتہٕ چِھ پیدٲیشی طور سیزِ وتہِ پٮ۪ٹھ پکن وٲلۍ بنٲوِمٕتۍ، تِتھے پٲٹھۍ گوٚژُھو تۅہیہِ تہِ بناوُن۔ بے شک اگر یہِ مشیّت اللہ تعالیٰ سٕنز انسان سٕندِس حقس منٛز آسِہے ،تیٚلہِ ہیٚکہِ ہے سُہ ضرور یہِ کٔرِتھ ۔مگر یہِ چَھنہٕ تٔمۍ سٕنز مشیّت ۔لہٰذا یۅسہٕ گُمرٲہی تۅہیہِ پانہٕ پا نس خٲطرٕ چَھو پسند کٔر مٕژ،اللہ تعالیٰ تہِ دِیو تۅہیہِ أتھۍ منٛز روزنہٕ۔"
  6,150,"۔یِمن ؤنِو زِ أنِیوٗکھ پنٕنۍ تِم گواہ یِم امہِ کتھہِ ہٕنز شہا دت دِن،زِ خُدا ے نٕے چِھ یِم چیز حرام کٔرۍ مٕتۍ۔ پتہٕ اگر تِم شہادت دِن تیٚلہِ دی زیٚو نہٕ توٚہۍ تِمن سٍتۍ شہادت ،یعنی اگر تِم شہا دتٕچ ذمہٕ دٲر ی سمجھان آسن تہٕ زانان آسن زِ شہادت چھےٚ اَمی کتھہِ ہٕنز دِنۍ ییٚمیُک علم انسانس آسہِ ،تیٚلہِ کر ن نہٕ تِم ہر گز یہِ شہادت دِنُک جُر ات ۔ البتہ اگر تِم لُکھ شہادتِٕچ ذمہ دٲر ی محسو س کر نہٕ ورٲے ضِدس لایِنہٕ یِن زِ اللہ تعالیٰ سُند ناو ہیٚتھ کر ن نہٕ اَپٕز گوٲہی دِنس ہِر اسہٕ، تیٚلہِ بٔنۍ زیٚو نہٕ تِہندس اتھ اَپزِس منٛز تِہندۍ سٲتھی۔ تہٕ ہر گز پٔکۍ زِ یٚو نہٕ تِہندِٮ۪ن خوٲہشا تن پتہٕ پتہٕ یِمو سا نیٚن آیاتن بُتھ چُھ پھِیرُمُت ،تہٕ یِم ٲخر تٕکۍ مُنکر چِھ ، بیٚیہِ یِم با قین چِھ پننِس ربّ سُند ہمسر برابر بناوان۔ع"
  6,151,"۔اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو زِ ؤلِو بہٕ بوزناوَو تُہٕندۍ ربّن کیا پابند یہِ چھےٚ تۅہیہِ پٮ۪ٹھ عٲید کرِمَژٕ:یعنی تُہندِس ربّ سٕنزٕ عٲید کر نہٕ آمژٕ پابند یہِ چَھنہٕ تمہٕ یِمن منٛز توٚہۍ گرفتار چِھو، بلکہ چھےٚ اصلی پابند یہِ نۅ مہٕ یہِ زِ تس سٍتۍ مَہ کٔرِیوٗن کانٛہہ شر یک، تہٕ مٲلِس ماجہِ سٍتۍ کٔرِو نیک سلوک، بیٚیہِ مَہ کٔرِیوٗکھ پنٕنۍ اولاد غر یبی ہٕندِ ڈرٕ کِنۍ قتل،أسۍ چِھو تۅہیہِ تہِ رزق دِوان تہٕ  تِمن تہِ دِمَو،تہٕ بے شر می ہٕنز ن کتھن مَہ گٔژِھو نکھہٕ تہِ خوا ہ تِمہٕ نَنہِ وانہٕ ٲسِتن یا ژھا یہِ پٲٹھۍ ،دراصل چُھ لفظفواحش  استعمال سپُد مُت ییٚمیُک اِطلا ق تِمن تمام کامیٚن پٮ۪ٹھ چُھ سپدان یِہنز بُرٲیی بالکل واضح چھےٚ۔قرآنس منٛز چُھ زِ نا، قومِ لوٗطٕچ عمل، ننگے روزُن ،اَپٕز تہمت تہٕ یس سٍتۍ مٲلۍ نکاح کوٚر مُت آسہِ تس سٍتۍ نکا ح کرُن فحش کامیٚن منٛز شما ر کر نہٕ آمُت۔حدیث شر یفس منٛز چُھ ژوٗرِ ،شراب نو شی تہٕ بیٚچھہِ نَس فواحش وَننہٕ آمُت۔یِتھے پٲٹھۍ چھےٚ تمام شر مناک کامہِ تہِ فوٲحشن منٛز شٲمل تہٕ اللہ تعالیٰ سُند ارشاد چُھ یہِ زِ یژٕھہ کامہِ نہ گژھن نَنہِ وانہٕ یِنہِ کر نہٕ تہٕ نَہ ژھایہِ پٲٹھۍ تہٕ بیٚیہِ کانٛہہ زُو یُس خُدا ین محتر م چُھ ٹھہر وو مُت مَہ کٔرِیوٗن ہلاک مگر حقہٕ سان، یِمہٕ چھےٚ کتھہٕ یُہُند ہدایت تٔمۍ تۅہیہِ کوٚرمُت چُھو بنان چُھ زِ توٚہۍ ہِیٚیو عقلہِ کٲم۔"