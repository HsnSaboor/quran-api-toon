quran[3]{c,v,t}:
  4,176,"اے نبی صلی اللہ علیہ وسلم۔لوٗکھ چِھو تۅہیہِ ﴿کَلاَ لہ کِس معا ملس منٛز فُتویٰ ﴾پٕرژھان۔ ﴿کَلا لہ کِس معنیس منٛز چُھ اختلاف۔کینژھن ہٕنز راے چھےٚ زِ کلالہ چُھ سُہ شخص یُس لاو لد آسہِ تہٕ یس مو ل بُڈِ بب زند ہ آسہِ نہٕ۔تہٕ کینژھن ہٕنز را ے چھےٚ سُہ شخص یُس لاولد مرِ تس چِھ کَلا لہ ونان ۔ البتہ عا م فقہا ہو چھےٚ حضرت ابو بکر رضی اللہ عنہہ ہَن ہٕنٛز یہِ را ے تسلیم کٔر مٕژ زِ اَمِیُک اطلا ق چُھ گۅڈ نِکسٕے صورتس پٮ۪ٹھ سپدان تہٕ خۅد بذا ت چُھ قرآن نِشہِ تہِ امِیُک تٲیید سپدان تِکیازِ یتھ جایہِ چھےٚ کَلا لہ سٕنز بیٚنہِ نصف تر کٕچ وٲرث قرار دِنہٕ آمٕژ۔حالانکہ اگر کَلالہ سُند مو ل زند ہ آسہِ تیٚلہِ چُھنہٕ بیٚنہِ موٗلۍ کانٛہہ حصہ واتان۔﴾  ؤنِو ، اللہٰ چُھو تۅہیہِ کلا لس متعلق فتویٰ دِوان، اگر کانٛہہ شخص بے اولاد مَرِ ،تہٕ تس آسہِ اکھ بیٚنہِ، تیٚلہِ میلہِ تس امہِ تر کہٕ منٛزٕ نصف،﴿یتھ جایہِ چُھ تِمن با ین بیٚنیٚن ہُند ذکر سپدان یِم میتس سٍتۍ ماجہِ تہٕ مٲلِس دۅ شوٕ نۍ منٛز ، یا آسن صرف مٲلۍ سٕندۍ کِنۍ مشتر کہ۔ حضرت ابو بکر صد یق رضی اللہ عنہ چِھ اکہِ ساعتہٕ أکِس خطبس منٛز امہِ معنے یِچ وضا حت کران تہٕ صحا بو رضی اللہ عنہ منٛزٕ کوٚر نہٕ کٲنٛسہِ اتھ سٍتۍ اختلا ف ، أتھۍ بنیادس پٮ۪ٹھ چُھ سارِنٕے اَتھ مسلس پٮ۪ٹھ اتفا ق﴾ تہٕ اگر بیٚنہِ بے اولاد مرِ تیٚلہِ آسہِ بو ے تٔمۍ سُند وٲرث، ﴿یعنی بو ے آسہِ تٔمۍ سٕندِ پوٗرٕ ما لُک وٲرث اگر بیٚیہِ کانٛہہ صا حب فر یضہ آسہِ نہٕ ۔ تہٕ اگر کانٛہہ صا حب فر یضہ موجو د آسہِ ، مثلاً خاندار، تیٚلہِ میلہِ تٔمۍ سُند حصہ نکھہٕ والنہٕ پتہٕ با قی تمام تر کہٕ بٲیِس۔﴾ اگر میت سٕنزٕ وٲرث زٕ ہ بیٚنہِ آسن،تیٚلہِ آسن تِمہٕ تر کہٕ ﴿پتھ کُن تراونہٕ آمتہِ ﴾ منٛزٕ زٕ ہ تہٲیی ہٕنز حقدار ﴿یۅ ہے حُکم چُھ دۅ یو کھۅ تہٕ زیادہ بیٚنیٚن خٲطرٕ تہِ ﴾،تہٕ اگر واریاہ بٲے بیٚنہِ آسن، تیٚلہِ میلہِ مستوراتن اکھ حصہ تہٕ مردن زٕہ حصہ،اللہ تعالیٰ چُھ تُہندِ خٲطرٕ احکامن وضا حت کران ، تاکہ توٚہۍ روٗزِ و نہٕ وَتہِ ڈٔلِتھ پکان،تہٕ اللہ تعالیٰ چُھ پرٛتھ چیزُک علم تھاوان۔ ع"
  5,1,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت، بٔندِ شن ہٕنز  کٔرِو پوٗرٕ پٲٹھۍ پابند ی ﴿ یعنی تِمن حدوٗدن تہٕ رُکا وٹن ہٕنز پابند ی کٔرِ و یِمہٕ تۅہیہِ پٮ۪ٹھ عٲید چھےٚ کر نہٕ آمٕژ۔﴾ تُہِندِ خٲطرٕ چِھ چارو ٲے قسمٕکۍ سٲر ی جانو ر حلال کر نہٕ آمٕتۍ۔﴿  اَنعا م   ﴿یعنی چار وٲے﴾ لفظ چُھ عر بی زبٲنۍ منٛز اونٹ ، گاو ، تیٖر تہٕ ژھاو لیٚن با پت وَننہٕ یِوان ۔تہٕ  بہیمہ ہُک اطلا ق چُھ پرٛتھ کٲنٛسہِ گا سہٕ کھیٚنہٕ وٲلِس جانورس پٮ۪ٹھ سپدان۔ چا ر وٲے قسمٕکۍ سٲر ی جانور آے تۅہیہِ پٮ۪ٹھ حلال کر نہٕ۔ اَمِیُک چُھ مطلب یہِ زِ تِم سٲر ی چر ند جانور چِھ تۅہیہِ پٮ۪ٹھ حلال یِم چاروٲے قٔسمٕکۍ آسن یعنی یِمن نہٕ نو کل دند آسن،حیوٲنۍ غذا بجا یہِ آسن کُلۍ کٔٹۍ گا سہٕ کھیوان تہٕ با قی حیوٲنۍ خصو صیا تن منٛز آسن چارواین سٍتۍ ہِشر تھاوان۔ اَمِچ وضا حت چھےٚ نبی صلی اللہ علیہ وسلمو پننیٚن احکامن اندر فر مٲومٕژ یِمن منٛز تِمو صلی اللہ علیہ وسلمو درندٕہ ، شکٲر ۍ پرند ہ تہٕ مُردار کھیٚنہٕ وٲلۍ جانور حرا م چِھ قرار دِتمٕتۍ﴾ سِوا ے تِم یِم برونٹھ کُن پٔکِتھ تۅہیہِ وَننہٕ یِن، البتہٕ حرا م کِس حا لتس منٛز مَہ کٔرِ و پا نس پٮ۪ٹھ شکار حلال ۔بے شک یُس حُکم اللہ تعالیٰ چُھ یژھان سُہ چُھ دِوان ۔"
  5,2,"۔اے لوٗکو ،یِمو ایمان چُھو اوٚ نمُت، خُدا پرستی ہٕنزٕ نشٲنیہِ مَہ کٔرِ یوٗکھ بے حُر مت ،﴿پرٛتھ کانٛہہ سُہ چیز  یُس کُنہِ مسلکٕچ یا عقیدٕچ یا طر زِ فِکر تہٕ عملہِ ہٕنز یا کُنہِ نظا مٕچ نما یند گی آسہِ کران تتھ وَنو تمِیُک شعار ، تِکیازِ سُہ چُھ تمہِ خٲطرٕ علا مت یا نشٲنی ہٕنز کٲم دِوان۔سر کٲرۍ جھنڈٕ ، فو جِچ تہٕ پو لسیٕچ وردی ،سکہٕ ، نوٹ تہٕ مُہرٕ چھےٚ حکو متن ہٕندۍ شعایر۔گر جا ، قر با ن گا ہ تہٕ صلیب چھےٚ مسیحتٕکۍ شعا یر۔ژھوگ، یو نہِ تہٕ مند ر چِھ بر ہمنیتٕکۍ شعا یر۔زیوٗٹھ مس ریش،کوٚر تہٕ کِر پان چِھ سکھ مذہبٕکۍ شعا یر۔دۅ کُر تہٕ درٚوت چُھ اشترا کیتُک شعا ر۔یِم سٲر ی مسلک چِھ پننیٚن پننیٚن پیر و کار ن نِشہِ پننیٚن یِمن شعا یر ن ہٕندِ احترا مُک مطا لبہٕ کران ۔ اگر کانٛہہ شخص کُنہِ نظا م کیو شعا یر و منٛزٕ کُنِچ تو ہین چُھ کران، تیٚلہِ چھےٚ یہِ امہِ کتھہِ ہٕنزِ علا مت زِ  دراصل چُھ سُہ تتھ نظا مَس خلا ف دُشمنی تھاوان، تہٕ ہرگاہ سُہ تو ہین کر ن وول اَمی نظا مُک آسہِ ، تیٚلہِ چُھ تٔمۍ سُند یہِ کار پننِس نظا مَس سٍتۍ اِرتداد تہٕ بغا وتُک معنی تھاوان۔شعایر اللہ  نِشہِ چُھ مُراد تِمہٕ سٲری علا مت تہٕ نِشٲنیہِ یِمہٕ شِر کس ، کُفرس تہٕ دہر یتس مُقابلہٕ خٲلص خُدا پرستی ہٕندِ مسلکٕچ نمٲیند گی آسن کران۔﴾ حرا م ریٚتو منٛزٕ مَہ کرِ یوٗن کانٛہہ حلال، قر بٲنی ہٕندٮ۪ن جانور ن پٮ۪ٹھ مَہ کٔرِ ودوست درٲزی، تِمن جانور ن پٮ۪ٹھ مَہ   ترٲوِ و اَتھہٕ یِہنزن گرد نن منٛز نذرِ خدا و ند ی ہٕندِ علا مت کہ طور پٹہٕ آسن گٔنڈِتھ، نَہ مَہ لٲگِو تِمن لُکن اتھہٕ یِم پننِس ربّ سٕندِ فضلہٕ خٲطرٕ تہٕ تٔمۍ سٕنزِ خۅشنو د ی ہٕندِس تلا شس منٛز محتر م  مکا نس ﴿کعبس ﴾ کُن آسن گژھان، آ، ییٚلہِ احرا مٕچ حالت اَند واتہِ تیٚلہِ ہیٚکِو ۍشکار کٔرِ تھ۔ تہٕ وُچِھو ، زِ أکۍ دٔرۍ یُس تُہندِ خٲطرٕ مسجدِ حرا مُک دروازٕ بند چُھ کوٚر مُت اتھ پٮ۪ٹھ گژِھہ نہٕ تُہُند شرارت تۅہیہِ تیوٗتاہ مشتعل کرُن۔توٚہۍ تہِ لٲگِو تِہندِس مقا بلس منٛز تِمہٕ حر کتہٕ کر نہِ یِمہٕ نہٕ شوٗبن۔﴿چو نکہ کُفارَو ٲسۍ اَمہِ وقتہٕ مُسلمان رکٲوِ مٕتۍ کعبٕچ زیارت کر نہٕ نِشہِ تہٕ مُسلمان ٲسۍ حج کر نہٕ نِشہِ تا م محر و م کر نہٕ آمٕتۍ ،اَمہِ موجو ب سپُد مُسلمانن منٛز یہِ خیا ل پٲدٕ زِ یِمن کٲفر قبیلن ہٕنزٕ وَتہٕ اسلامی مقبو ضا تَو کِنۍ چھےٚ پکان،أسۍ تہِ رُکا ووکھ تِم حجِ نِشہِ تہٕ حج کِس وقتس اندر ترٛا وَو یِہندٮ۪ن قبیلن چھا پہٕ۔ مگر یہِ آیت نٲزِل کٔرِ تھ تھٲوۍ خُدا ین یِم اَمہِ خیا لہٕ نِشہِ با ز۔﴾ نَہ ! یِمہٕ کامہِ نیکی تہٕ خُدا تر سی ہٕنزٕ چھےٚ تِمن منٛز کٔرِ و سارِنٕے سٍتۍ تعاوُن تہٕ یِمہٕ کامہِ گنا ہ زیادتی ہٕنزٕ چھےٚ تِمن منٛز مَہ کٔرِ و کٲنٛسہِ سٍتۍ تعاوُن۔خُدا یس کھۅٗژِو، تٔمۍ سُند سزا چُھ سٮ۪ٹھاہ سخت۔"