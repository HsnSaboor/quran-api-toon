quran[4]{c,v,t}:
  24,28,"۔پتہٕ اگر تَتہِ کانٛہہ وُچھوٗن نہٕ، تیٚلہِ مَہ سپدِ و دٲخل یوٚت تام نہٕ تۅہیہِ اجازت یِیہِ دِنہٕ۔ یعنی کٲنٛسہِ ہٕندِس خٲلی گھر س منٛز چُھنہٕ اَژُن جا یز، اِلّایہِ زِ مکان مٲلِکن آسہِ پانہٕ امہِ کتھہِ ہُند اجا زت دِیتمُت۔ مثلاً تٔمۍ آسہِ تۅہیہِ ووٚ نمُت زِ اگر بہٕ تَتہِ آسہِ نہٕ تیٚلہِ بِہزیٚو توٚہۍ میٲنِس کُٹھِس منٛز، یا سُہ آسہِ بیٚیہِ کُنہِ جایہِ تہٕ تۅہیہِ سوزیٚو شیٚچھ زِ توٚہۍ تھٲوِ و تشر یف بہٕ وا تہٕ وُنی تہٕ اگر تۅہیہِ وَننہٕ یِیہِ زِ واپس گٔژِھو، تیٚلہِ نیرِ و واپس، یہِ چُھ تُہندِ خٲطرٕ زیادہ پاک طر یقہٕ ،  یعنی یہِ گژِھہ نہٕ تۅہیہِ نا گوار گژُھن۔ أکِس انسانس چُھ حق زِ اگر سُہ کٲنٛسہِ سمکھُن ییٚژِھہ نہٕ سُہ ہیٚکہِ انکار کٔرِ تھ، یا کانٛہہ آورِ یا آسِیٚس، تیٚلہِ ہیٚکہِ معذرت کٔرِ تھ۔ تہٕ یِکینژھاہ توٚہۍ کران چِھو ، اللہ تعالیٰ چُھ تتھ ٹھیک پٲٹھۍ زانان۔"
  24,29,"۔البتہ اتھ منٛز چُھنہٕ  تُہٕندِخٲطرٕ کانٛہہ حر ج،زِ تِتھیٚن گھر ن منٛز أژِو یِمن منٛز نہٕ کانٛہہ روزان آسہِ ، تہٕ یِمن منٛز تُہندِ فٲیدُک  یا کامہِ ہُند کانٛہہ چیز آسہِ  امہِ نِشہِ چِھ مُراد ہو ٹل، سراے، مہمان خا نہٕ ، دُکان، مسا فر خا نہٕ بیترِ ، ییٚتہِ لُکن دٲخل سپد نُک عام اجازت آسہِ توٚہۍ یِکینژھاہ ظٲہر چِھو کران تہٕ یِکینژھاہ چُھپا وان چِھو، اللہ تعالیٰ چُھ سورُے زانان۔"
  24,30,"۔اے نبی صلی اللہ علیہ وسلم ، مو من مردن ؤنِو زِ پننہِ نظرٕ تھٲوِ ن بچٲوِ تھ ،  در اصل چُھ غَضِّ بصرُک حکم آمُت دِنہٕ ییٚمیُک تر جمہٕ عام پٲٹھۍ نظر بۅ ن تھا وٕنۍ یا بۅ ن کُن وُچُھن کر نہٕ چُھ یِوان ۔ در اصل چُھنہٕ امہِ حُکمُک مطلب پرٛتھ وقتہٕ بۅ ن کُنُے وُچُھن بلکہ چُھ پوٗرٕ پٲٹھۍ مُدے گٔنڈِ تھ نہ وُچُھن، یا وُچھنہٕ خٲطرٕ پننہِ أچھ با لکل آزا د تراونُک۔ یہِ مفہو م چُھ نظر بچا و نہٕ سٍتۍ ٹھیک پٲٹھۍ ادا سپدان۔ یعنی یُس چیز وُچُھن منٲسب آسہِ نہٕ، تمہِ نِشہِ گژِھہ نظر ڈالٕنۍ ، یہِ نہ کینٛہہ زِ انسان روزِ بۅ ن کُنُے وُچھان یا تھا وِ پنٕنۍ نظر دٔچُھن یا کھۅ وُر کُن۔تہٕ یہِ کتھ چھےٚ سیا ق و سبا ق نِشہِ تہِ پے لگا ن زِ یہِ پا بند ی یتھ چیز س پٮ۪ٹھ عٲید چھےٚ کر نہٕ آمٕژ، سُہ چُھ مردن ہُند مستوٗراتن کُن وُچُھن ، یا دوٚ یمیٚن لُکن ہٕندِس سترس نظر تراوٕنۍ، یا فحش چیز ن پٮ۪ٹھ نظر جما وٕ نۍ تہٕ پننیٚن شر مگا ہن ہٕنز کٔرِ ن حفا ظت، یہِ چُھ تِہندِ خٲطرٕ زیادہ پٲکیز ہ طر یقہ، یِکینژھاہ تِم کران چِھ ، اللہ تعالیٰ چُھ تمہِ نِشہِ با خبرروزان۔"
  24,31,"۔اے نبی صلی اللہ علیہ وسلم ،مو من مستوٗراتن ؤنِو پننہِ نظرٕ تھٲوِ ن بچٲوِ تھ، تہٕ پننیٚن شر مگا ہن کٔرِن حفا ظت یہِ کتھ گژِھ در نظر روزٕ نۍ زِ شر یعتِ الہٰی چُھنہٕ مستوٗراتن نِشہِ یُتُے مُطالبہٕ کران یُس تٔمۍ مردن چُھ کوٚر مُت۔یعنی نظر بچاوٕ نۍ تہٕ شر مگا ہن حفا ظت کرٕنۍ، بلکہ چُھ سُہ یِمن بیٚیہِ تہِ کینٛہہ مطا لبہٕ کران یِم تٔمۍ مردن چِھنہٕ کٔرِ مٕتۍ۔ امہِ نِشہِ چُھ صا ف ظٲہر زِ اتھ معا ملس منٛز چَھنہٕ زٔنۍ تہٕ مرد یکسان۔ تہٕ پنُن بنا و سنگھا ر مَہ ہٲوِ ن ، سواے تہِ یہِ پا نے ظٲہر سپدِ،تہٕ پننیٚن سیَنن پٮ۪ٹھ  تھٲوِ ن پننیٚن کلہٕ دَجن ڈپٹن ہٕنزٕ لوٗنچہِ ترٲوِتھ۔ تِمہٕ مَہ کٔرِن پنُن بنا و سنگھا ر ظٲہر، مگر یِمن لُکن برونٛہہ کَنہِ: خا ندار ، مو ل، خا ندارن ہٕنٛدۍ مٲلۍ۔مٲلۍ سٕندِس مفہو مس منٛز چُھ بُڈِ بب ، بَڈٕ بُڈِ بب، ماجہِ بُڈِ بب،ماجہِ بُڈٕ بُڈِ بب شٲمل۔ لہٰذا ہیٚکہِ اکھ زٔنۍ پننِس خا ندار سٕندِس مٲلۍ  بُڈِ ببس تہٕ تٔمۍ سٕندِس ماجہِ بُڈِ ببس برونٛہہ کُن تہِ تِتھے پٲٹھۍ یِتھ، یِتھہٕ پٲٹھۍ پننِس مٲلِس  یا ہیرٕ با بس برونٛہہ کُن چھےٚ یِوان۔ پننیٚن نیچو ٮ۪ن، خا ندارن ہٕندٮ۪ن نیچو ٮ۪ن،  نیچو ٮ۪ن منٛز چِھ زُرۍ، زُر ٮ۪ن ہٕنٛدۍ شُر ۍ سٲر ی شٲمل۔ تہٕ اتھ معا ملس منٛز چَھنہٕ پننِس تہٕ وۅ رس  منٛز کانٛہہ فر ق۔ پننیٚن وۅرٕ شُر ٮ۪ن ہٕندٮ۪ن شُرٮ۪ن برونٛہہ کنہِ تہِ ہیٚکہِ اَکھ زٔنۍ تِتھے پٲٹھۍ آزادی سان زینتُک اظہا ر کٔرِ تھ یِتھہٕ پٲٹھۍ خۅد پننیٚن شُر ٮ۪ن تہٕ زُر ٮ۪ن برونٛہہ کنہِ ہیٚکہِ کٔرِ تھ۔  پننیٚن با ین۔   با ین منٛز چِھ پنٕنۍ تہٕ وۅ رٕ سٲر ی شٲمل با ین ہٕنٛد ٮ۪ن شُر ٮ۪ن ، بینیٚن ہٕندٮ۪ن شُر ٮ۪ن۔بایَو بییٚنو نِشہِ چُھ مُراد تر شوٕ نۍ قسمن ہٕندۍ بٲے بیٚنہِ، تہٕ تِہند ٮ۪ن شُر ین تہٕ زُر ٮ۪ن سارِنٕے پٮ۪ٹھ چُھ یِہند ٮ۪ن اولا د ن ہُند اِطلا ق سپدان  تِمہٕ مستوٗراتہٕ تہِ یِمن سٍتۍ وۅ تھا ن بیٚہوان چھےٚ، امہِ نِشہِ چُھ پٲنۍ پا نے یہِ ظٲہر سپدان زِ آوا رہ  تہٕ بد اطوا ر زنانن برونٛہہ کنہِ پزِ نہٕ شر یف مسلمان مستوٗراتن پننہِ  زینتُک اظہا ر کرُن پنٕنۍ لو نڈ ی غلا م، تِم زیرِ دست ماتحت خد متگار مرد، یِم نہٕ بیٚیہِ کُنہِ قسمُک غر ض آسن تھا وان  یعنی زیرِ دست آسنہٕ کِس بُنیا دس پٮ۪ٹھ آسہِ نہٕ تِمن متعلق یہِ شک کر نٕچ گُنجٲیش زِ تِم ہیٚکن امہِ گھر چن مستوٗراتن ہٕندِس معا ملس منٛز کُنہِ نا پا ک خو اہشہِ ہٕنز ہمت کٔرِ تھ۔ تہٕ تِم شُر ۍ یِم نہٕ وُنہِ مستوٗراتن ہٕنٛز و پو شیدٕہ کتھو نِشہِ وٲقف آسن  گٔمٕتۍ۔ تِمہٕ مَہ پکِن زمینس پٮ۪ٹھ پنٕنۍ کھۅر ہٕکہٕ تراوان تراوان زِ یۅسہٕ پنٕنۍ زنیت تِمو چُھپٲوِ تھ آسہِ تھٲومٕژ تمیُک لگہِ لُکن پے۔اے مو منو ، توٚہۍ سٲری کٔرِو رٔلِتھ اللہ تعالیٰ ہس برونٛہہ کنہِ تو بہ، اُمید چھےٚ زِ فلا ح لٔبِو۔"