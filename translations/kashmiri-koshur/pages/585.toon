quran[42]{c,v,t}:
  80,1,"نا گُوٲری تہٕ بے رُخی وَر تٲوٕن"
  80,2,"اتھ کتھہِ پٮ۪ٹھ زِ سُہ نا بینا آو تِمن نِشہِ ﴿ اَمہِ پتہٕ یِم آیات چھِ تِمو نِشہِ چُھ پَے لگا ن زِ بے رُخی تہٕ ناگوٲ ری ور تا وَن وٲلۍ ٲسۍ خۅد پانہٕ نبی صلی اللہ علیہ وسلم۔یَس نا بینا شخصہٕ سُنٛد ذکر یَتھ جایہ کر نہٕ آمُت چُھ تِم ٲسۍ حضرت ابنِ اُمِ مکتو م رضی اللہ تعالیٰ عنہ یِم حضرت خد یجہ رضی اللہ تعالیٰ عنھاہس پۅ پھتٕرۍ بٲے ٲسۍ۔ نبی صلی للہ علیہ وسلم ٲسۍ اَمہِ ساعتہٕ مکہٕ کیٚن کُفارن ہٕنٛد ٮ۪ن بڈٮ۪ن بڈ ٮ۪ن سردارن دینِ اسلامٕچ دعوت دِنس منٛز مشغول زِ أتھۍ دوران چھِ حضرت ابنِ اُمِ مکتو م رضی اللہ تعالیٰ ﴿نا بینا﴾ حٲ ضر سپدان،تہٕ تِم چھِ کینٛہہ سوال پٕرٚ ژٕھنۍ ہیٚوان۔حضور صلی اللہ علیہ وسلمن چھےٚ اَتھ مو قعس پٮ۪ٹھ تِہٕنٛز یہِ مدا خلت نا گوار گژھا   ن﴾"
  80,3,"تۅ ہیہِ کیا خبر چھےٚ ، بنا ن چُھ سُہ سُد ھرِ ہا"
  80,4,"یا کرِ ہا نصیحتس پٮ۪ٹھ غور تہٕ تٔمۍ سٕنٛدِ خٲطرٕ آسہِ ہے نصیحت کرٕ نۍ فٲ یدٕہ مند؟"
  80,5,"یُس شخص لا پروٲہی ورتاوان چُھ،"
  80,6,"تَس کُن چھِو توٚہۍ توجہ دِوان،"
  80,7,"حالانکہ ہر گاہ سُہ سُد ھرِ نہٕ کینٛہہ ،تَمہِ پتہٕ کیا ذمہٕ دٲری چھےٚ تۅہیہِ پٮ۪ٹھ تٔمۍ سٕنٛز؟"
  80,8,"تہٕ یُس پانہٕ تۅہیہِ کُن دَوان چُھ یِوان"
  80,9,"کھۅ ژان چُھ آسان،"
  80,10,"تٔمِس نِشہِ چھِوتوٚہۍ بے رُخی ورتاوان"
  80,11,"ہرگز نہٕ،یہِ چھےٚ اکھ نصیحت ،﴿یعنی یہِ مَہ کٔرِو ہر گز تہِ۔ یِمَو لُکو خدا ے آسہِ مٔشروومُت تہٕ پننِس دُنیٲوی و جا ہَتس پٮ۪ٹھ آسیٚکھ پھۅ کھ تہٕ نَشہِ کھوٚتمُت تِمن مَہ دِیو اہمیت۔اسلامٕچ تعلیم چھَنہٕ سُہ چیز کینٛہہ زِ یُس اَمہِ نِشہِ بُتھ پِھرِ تس یِیہِ یہِ آپر وانہٕ۔ بیٚیہِ نَہ چھےٚ تُہٕنٛز یہِ شان زِ یِم مغرور لُکھ اسلامس کُن اَننہٕ خٲطرٕ کٔرِو کُنہِ اندازٕ ہ کوشش ،ییٚمہِ سٍتۍیِم اَتھ غلط فہمی منٛز ہیٚنہٕ یِن زِ تُہنٛد کانٛہہ غر ض چُھ یِمن تَل پھٔسِتھ زِ ییٚلہِ یِم مانَن تہٕ دعوت پکہِ برونٛہہ ،ییٚلہِ نہٕ یِم ما نَن تیٚلہِ گژِھہ دعوت نا کام۔ حق چُھ یِمن نِشہِ تیوٗتاہ بے نیاز یوتاہ یِم حقہٕ نِشہِ بے نیا ز چھِ ﴾"
  80,12,"یَس خۅ ش کرِ سُہ رَٹہِ اَتھ،"
  80,13,"یہِ چھےٚ تِمن صحیفن اندر در ج یِم مکر م چھِ،"
  80,14,"تھدِ پا یِکۍ چھِ ، یِم پٲکیزٕ ہ چھِ ﴿ یعنی یِم چھِ پرٛتھ قسمہٕ کہ ملا وٹ نِشہِ پاک، یِمن منٛز چھےٚ خا لص حقٕچ تعلیم پیش کر نہٕ آمٕژ۔کُنہِ نو عیتٕکۍ باطل تہٕ فٲ سد خیا لات تہٕ نظر یا ت چھِنہٕ یِمن منٛز أژِتھ ہیٚکۍ مٕتۍ﴾"
  80,15,"تِمن کٲ تِبن ہٕنٛد ٮ۪ن اَتھن منٛز چھِ روزان"
  80,16,"یِم معز ز تہٕ نیک چھِ ﴿ مُراد چھِ تِم فر شتہٕ یِم قرآن کیٚن یِمن صحیفَن اللہ تعالیٰ سٕنٛدِ براہِ راست ہدا یت مطٲبق لیٚکھان ٲسۍ ،یِمن ٲسۍحفا ظت کران تہٕ رسول اللہ صلی اللہ علیہ وسلمن تام ٲسۍ تَمی آیہِ واتناوان ییٚمہِ آیہِ تِم ٲسۍ﴾"
  80,17,"لعنت ٲسِن انسا نَس پٮ۪ٹھ،کِیُتھ سخت مُنکرِ حق چُھ یہِ ﴿ ییٚتہِ پٮ۪ٹھہٕ چُھ عِتا بُک ﴿ شرا رتُک ﴾ رۅخ براہِ راست تِمن کٲفر ن کُن پھیران یِم حقہٕ نِشہِ بے نیٲزی ورتاوان ٲسۍ۔ اَمہِ بر نٛہہ اوس سورٕہ شروع سپد نہٕ پٮ۪ٹھہٕ آیت 16 ہَس تام رسول اللہ صلی اللہ علیہ وسلمن خطاب، تہٕ عِتا ب اوس در پردٕ ہ کٲ فر ن کُن۔ اَمیُک اندازِ بیان اوس یہِ زِ اے نبی صلی اللہ علیہ وسلم ،اکھ حقُک طٲلِب أکِتھ کُن ترٛٲوِتھ کمن لُکن پٮ۪ٹھ چھِو پنُن تو جہ دِوان۔یِم چھِ دعوتِ حق کہ نقطہ نظرٕ کِنۍ بالکل بے قدر و قٍمت۔ یِہٕنٛز چھَنہٕ یہِ حیثیتٕے زِ تۅہیہِ ہیوٗ عظیم القدر پیغمبر کرِ قرآن ہیوٗ بلند مر تبہٕ وول چیز یِمن بر ونٛہہ کنہِ پیش﴾"
  80,18,"کمہِ چیزٕ نِشہِ کوٚر یہِ اللہ تعالیٰ ہن پٲدٕ"
  80,19,"نطفہِ کہ اکہِ قطرٕ نِشہِ ، کوٚر یہِ اللہ تعالیٰ ہَن پٲدٕ ،پتہٕ کوٚرُن أمۍ سُنٛد تقدیر مقرر،"
  80,20,"پتہٕ کٔرٕ ن أمۍ سٕنٛدِ خٲطرٕ زند گی ہٕنٛز وَتھ آسان"
  80,21,"پتہٕ دُتنَس موت تہٕ واتنو وُن قبرِ اندر"
  80,22,"پتہٕ ییٚلہِ سُہ ییٚژھِہ ، سُہ ہیٚکہِ أمِس دوبارٕ کھڑا ﴿ زندٕہ ﴾ کٔرِتھ"
  80,23,"ہر گز نہٕ ، أمۍ کوٚر نہٕ سُہ فر ض پوٗرٕ ییٚمُیک اللہ تعالیٰ ہَن أمِس حکم اوس دُیٚتمُت"
  80,24,"پتہٕ وُچھِتَن یہِ انسان ذرا پننِس خۅرا کس کُن"
  80,25,"اَسہِ ترٛ وو زمینس پٮ۪ٹھ سٮ۪ٹھاہ آب ﴿ امہِ نِشہِ چُھ مُراد روٗد﴾"
  80,26,"پتہٕ کٔر زمین چاک عجیب پٲٹھۍ،"
  80,27,"پتہٕ وۅ پدٲوۍ تَمہِ منٛزٕ اناج،"
  80,28,"تہٕ دَچھ تہٕ تر کا رِ،"
  80,29,"تہٕ زیتو ن تہٕ کھٔزٕر"
  80,30,"بیٚیہِ گٔنۍ باغ"
  80,31,"تہٕ قٔسم وار میوٕہ تہٕ گا سہٕ۔"
  80,32,"تُہٕنٛدِ خٲطرٕ تہٕ تُہٕنٛدٮ۪ن چا ر واین خٲطرٕ زند گی ہٕنٛدِ سامانہٕ رٔنگۍ"
  80,33,"ٲخر کار ییٚلہِ سۅ زَر پاوَن وا جِنۍ آواز بُلند سپدِ﴿ مُراد چُھ ٲخر ی نفخِ صورٕ چ قیا مت کر ن وا جِنۍ آواز یۅ سہٕ بُلند سَپدا نٕے تمام موٗدِ مٕتۍ انسا ن زندٕہ گژھن"
  80,34,"تَمہِ دۅہ ژَلہِ انسان پننِس بٲ یِس نِشہِ ،"
  80,35,"پننہِ ماجہِ تہٕ پننِس مٲلِس نِشہِ"
  80,36,"تہٕ پننہِ خاندارِنہِ تہٕ پننِس اَو لا دَس نِشہِ"
  80,37,"تَمہِ دۅہ یِیہِ یِمو منٛزٕ پرٛتھ شخصس پٮ۪ٹھ تِیُتھ اکھ وقت زِ تَس آسہِ نہٕ پننہِ ورٲے بیٚیہِ کٲنٛسہِ ہُنٛد ہوش"
  80,38,"کینٛہہ بُتۍ آسن تَمہِ دۅہ پرٛزلان،"
  80,39,"ہشاش بشاش تہٕ خو ش و خُرم آسن"
  80,40,"تہٕ کینٛژھن بُتھیٚن پٮ۪ٹھ آسہِ تَمہِ دۅہ میٚژ وُڈان"
  80,41,"تہٕ سیٲ ہی آیٚکھ مٔتھِتھ"
  80,42,"یِمے آسن کٲفر ن تہٕ فٲ جر لُکھ"