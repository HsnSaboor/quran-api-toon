quran[7]{c,v,t}:
  66,1,"۔اے نبی صلی اللہ علیہ وسلم،توٚہۍ کیا زِ چِھو سُہ چیز حرام کران یُس خُدا ین چُھ تُہندِ خٲطرٕ حلال کوٚر مُت؟ ﴿ یہِ چُھنہٕ در اصل سوال کینٛہہ بلکہ چُھ نا پسند ید گی ہُند اظہا ر ۔یعنی یہِ چُھنہٕ مقصد زِ نبی صلی اللہ علیہ وسلمن نِشہِ یِیہِ یہِ در یافت کر نہٕ زِ تۅہیہِ صلی اللہ علیہ وسلم کیازِ کٔرٕ و یہِ کٲم، بلکہ چُھ مقصد حضور ن صلی اللہ علیہ وسلم اتھ کتھہِ پٮ۪ٹھ تنبیہ کرُن زِ اللہ تعالیٰ سُند حلال کر نہٕ آمُت چیز پا نس پٮ۪ٹھ حرام کر نٕچ یۅسہٕ حر کت تۅہیہِ کٔرٕو ،سۅ چھےٚ خُدایس نا پسند ۔ چو نکہ تُہنز حیثیت ٲس نہٕ أکِس عام انسان سٕنز کینٛہہ بلکہ ٲس أکِس رسول سٕنز۔تُہُند پا نس پٮ۪ٹھ کانٛہہ چیز حرام کر نہٕ سٍتۍ ہیٚکہِ ہے یہِ خطرٕ ہ پٲدٕ سپدِتھ زِ اُمّت  لاگہِ ہے یہِ چیز حرام یا کم از کم مکر وہ سمجُھن ۔امہِ موجو ب چُھ اللہ تعالیٰ حضور ن صلی اللہ علیہ وسلم اتھ حرکتس پٮ۪ٹھ گرفت فرماوان تہٕ تِمن چُھ اَمہِ تحر یم نِشہِ باز روزنُک حکم دِوان۔اَمہِ سٍتۍ چھےٚ یہِ کتھ تہِ واضح سپدان زِ حضور صلی اللہ علیہ وسلمن تہِ اوس نہٕ بطورِ خۅد کُنہِ چیز س حلال یا حرام کر نُک اختیار۔﴾ ﴿کیا امہِ موجو ب زِ ﴾ توٚہۍ چِھو پننیٚن گھر وا جِنیٚن ہٕنز خو شی یژھان ؟ ﴿ امہِ نِشہِ چُھ پے لگا ن زِ حضور صلی اللہ علیہ وسلمو اوس نہٕ یہِ تحر یم پننہِ کُنہِ خوٲہِشہِ ہٕندِس بِنا ہس پٮ۪ٹھ کوٚر مُت ،بلکہ اوس تِہنز و گھر واجِنیٚو یوٚژھمُت زِ حضور صلی اللہ علیہ وسلم کرن یہِ تہٕ حضور وصلی اللہ علیہ وسلمو اوس محض تِمہٕ خۅش کر نہٕ موجو ب اکھ حلال چیز پا نس پٮ۪ٹھ حرام کوٚر مُت۔حد یث کیو معتبر روایتو نِشہِ چُھ پے لگا ن زِ رسول صلی اللہ علیہ وسلمن ہٕنزِ أکِس گھر واجِنہِ ﴿حضر ت زینب رضی اللہ عنہا ہس﴾ اوس کتہِ تام پٮ۪ٹھہٕ ما چھ ووتمُت، یُس حضور صلی اللہ علیہ وسلمن پسند اوس۔اَمہِ موجو ب ٲسۍ حضور صلی اللہ علیہ وسلم خلا فِ معمو ل تِمن نِشہِ ژیر تام تشر یف تھٲوِتھ۔اَتھ پٮ۪ٹھ سپُد با قی اَزواجِ مطہرا تن رشک تہٕ کُنی کتھ کٔرِ تھ کٔر تِمَو حضور  صلی اللہ علیہ وسلمن ما چِھچ نفر ت تہٕ اَمہِ پتہٕ چِھ حضور صلی اللہ علیہ وسلم یہِ استعمال نَہ کر نُک عہد کران﴾ اللہ تعالیٰ چُھ معا ف کر ن وول تہٕ رحم فر ماون وول۔"
  66,2,"۔ خُداین چُھ تۅہیہِ لُکن خٲطرٕ پننیٚن قسمَن ہٕنزٕ پا بند ی نِشہِ نیر نُک طر یقہٕ مُقر ر کوٚر مُت۔﴿ مطلب چُھ یہِ زِ کفّارٕ دِتھ یُس طر یقہٕ قسمن ہٕنزِ پا بند ی منٛزٕ نیر نُک خُداین سورۂ ما یدہ آیت 89،منٛز مُقرر چُھ کوٚر مُت، تتھ  مطٲبق عمل کٔرِتھ پُھٹرٲوِ و توٚہۍ سُہ عہد یُس تۅہیہِ حلال چیز پانس پٮ۪ٹھ حرا م کر نہٕ خٲطرٕ چُھو کوٚر مُت﴾ اللہ تعالیٰ چُھ تُہُند کار ساز ، تہٕ  تۅہیہِ سُے چُھ زانن وول تہٕ حکمت وول۔"
  66,3,"۔﴿ تہٕ یہِ معا ملہٕ تہِ چُھ قٲبِل توجّہ زِ ﴾ نبی صلی اللہ علیہ وسلمو ٲس اکھ رازٕچ کتھ پننہِ أکِس خاندارِنہِ ؤنمٕژ۔پتہٕ ییٚلہِ تمہِ خا ندارِ نہِ ﴿ کس تام ﴾ سُہ راز ووٚ ن، تہٕ خُداین دِیُت نبی صلی اللہ علیہ وسلمس سُہ ﴿راز افشا کر نُک ﴾ اطلا ع، نبی صلی اللہ علیہ وسلمو کٔر اَتھ پٮ۪ٹھ کُنہِ حد س تام ﴿ سۅ خا ندارِ نۍ ﴾ خبردار ،تہٕ کُنہِ حدس تام کوٚرُکھ تس در گُزر۔ پتہٕ ییٚلہِ نبی صلی اللہ علیہ وسلمو تس ﴿ راز افشا کر نٕچ ﴾ یہِ کتھ ؤنۍ ، تمہِ پُرٚژھ تۅہیہِ کٔمۍ دِژ نَو اَمِچ خبر ؟ نبی صلی اللہ علیہ وسلو فر موو " مےٚ دِژ تٔمۍ خبر یُس سورُے کینٛہہ چُھ زانان تہٕ وارٕہ پٲٹھۍ چُھ با خبر۔" ﴿ کُنہِ روایت نِشہِ چُھنہٕ تعیّن سان یہِ پے لگان زِ سۅ رازٕ چ کتھ کیا ٲس ۔تہٕ ییٚمہِ مقصد خٲطرٕ یہِ آیت نٲزِل چھےٚ گٔمٕژ تمہِ لحا ظہٕ چَھنہٕ موٗلی اَتھ سوا لس کانٛہہ  اہمیت زِ سۅ رازٕچ کتھ  کیا ٲس ۔اصلی غر ض ییٚمہِ خٲطرٕ یہِ معا ملہٕ قرآنِ مجیدس منٛز چھُ بیان کر نہٕ آمُت، سُہ چُھ ازوا جِ مطہراتن تہٕ با لوا سطہٕ مُسلمانن ہٕندین تمام ذمہٕ دار لُکن ہٕنز ن خا ندارِ نیٚن اَتھ کتھہِ پٮ۪ٹھ تنبیہ کرُن زِ تِمہٕ مَہ ہیٚیِین رازن ہٕندِس حفا ظتس منٛز لا پروٲہی کٲم۔یۅسہٕ ہستی یٖژاہ بٔڑ ذمہٕ دارانہٕ حیثیت آسہِ تھا وان ، تٔمۍ سٕندِ گھرٕ منٛز راز افشا گژھن چُھ تیوٗتُے خطر نا ک آسان ۔ کتھ ٲسِتن اہم یا ٲسِتن غیر اہم ، اگر رازٕ چ حفا ظت کر نس منٛز لا پرواہی ہُنٛد عادت گژِھہ ،تیٚلہِ ہیٚکہِ غیر اہم کتھن ہٕندۍ پٲٹھۍ کُنہِ ساعتہٕ اہم کتھ تہِ نٔنۍ نیٖرِ تھ۔﴾"
  66,4,"۔اگر توٚہۍ دۅ شو ے خُدایس نِشہِ تو بہٕ چَھو کران ﴿ تیٚلہِ چُھ یہِ تُہندِ خٲطرٕ بہتر ﴾ تِکیازِ تُہٕندۍ دِل چِھ سیٚزِ وَتہِ نِشہِ ڈٔلمٕتۍ ، ﴿ حضرت عمر رضی اللہ عنہ سٕندِ روایت مُطا بق چُھ یِمو دۅ شوٕ یَو نِشہِ مُراد حضرت عا یشہ رضی اللہ عنہا تہٕ حضرت حفصہ رضۍ اللہ تعالیٰ عنھا، تہٕ سیٚزِ وَتہِ نِشہِ ڈلنُک مطلب یُس حضر ت عمر رضی اللہ عنہ چِھ بیا ن کران ، سُہ چُھ یہِ زِ یِمَو دۅ شوٕ یو اوس نبی کر یم صلی اللہ علیہ وسلمس سٍتۍ زیادے جُر تہٕ سان لوگمُت پیش یُن ،یُس خُداین نا پسند کوٚر تہٕ یِمن کوٚرُن تنبیہ﴾ تہٕ اگر تۅہیہِ نبی صلی اللہ علیہ وسلمن ہٕندِس مقا بلس منٛز دوٚر بنو وُو ، تیٚلہِ زٲنِو اللہ تعالیٰ چُھ تٔمۍ سُند مو لیٰ، تہٕ تَمہِ پتہٕ چِھ جبر یل علیہ السلام تہٕ تمام صا لح اہلِ ایمان تہٕ سٲری فر شتہٕ تٔمۍ سٕندۍ سٲتھی تہٕ مددگار۔ ﴿ مطلب چُھ یہِ زِ رسول اللہ صلی اللہ علیہ وسلمن ہٕندِس مقا بلس منٛز دوٚر بنٲوِتھ کٔرِ و توٚہۍ پان سٕے نقصا ن ، تِکیازِ ییٚمۍ سُند مو لیٰ اللہ تعالیٰ چُھ تہٕ یَس سٍتۍ جبر یل علیہ السلام ،فر شتہٕ تہٕ تمام صا لح اہلِ ایمان آسن تٔمۍ سٕندِس مقا بلس منٛز دوٚر بنٲوِتھ ہیٚکہِ نہٕ کانٛہہ کا میا ب سپدِتھ﴾"
  66,5,"۔دوٗر چُھنہٕ زِ اگر نبی صلی اللہ علیہ وسلم تۅہیہِ سارِ نٕے خا ندارِ نیٚن طلا ق دِیہِ ، تیٚلہِ کرِاللہ تعالیٰ تِمن تُہندِ بد لہٕ تِژٕھہ خا ندار نہِ عطا یِمہٕ تُہندِ کھۅتہٕ بہتر آسن ۔ ﴿ اَمہِ نِشہِ چُھ پے لگا ن زِ قصور اوس نہٕ صرف حضر ت عا یشہ رضی اللہ عنہا تہٕ حضر ت حفصہ رضی اللہ عنہاسُندُے یوت، بلکہ آسہٕ با قی ازواجِ مطہرات تہِ کم کاسہٕ قصور وار،اَمی موجو ب چُھ یتھ آیتس منٛز یِمن دۅ ن پتہٕ با قی سارِنٕے ازواجن تہِ تنبیہ کر نہٕ آمُت۔حدیثو نِشہِ چُھ پے لگا ن زِ تمہِ ساعتہٕ ٲسۍ حضور صلی اللہ علیہ وسلم خاندارنیٚن تیوٗتاہ نا راض سپدٕ مٕتۍ زِ  أکِس ریٚتس ژوٚٹ تِمو صلی اللہ علیہ وسلمو تِمن سٍتۍ تعلق ،تہٕ صحا بن رضی اللہ عنہ منٛز چُھ مشہو ر سپدان زِ حضور صلی اللہ صلی اللہ علیہ وسلمو چُھ یِمن طلا ق دِیتمُت﴾ یِمہٕ پکہٕ مسلمان، با ایمان، اطا عت گُزار ،تو بہٕ کر ن واجِنہِ ، عبادت گُزار ، تہٕ روزہ دار، خواہ وۅ رزٕٲسِتن یا اَنٔہرِ شہِ۔"
  66,6,"۔اے لوٗکو یِمو ایمان چُھ اوٚنمُت، بچٲوِ و پنُن اہل وعیا ل تمہِ نارٕ نِشہِ ، ییٚمیُک زالُن آسن  انسان تہٕ کنہِ ، ﴿ یہِ آیت چھےٚ وَنان زِ أکِس شخصہٕ سٕنز ذمہٕ دٲری چَھنہٕ صرف پنٕنۍ ذاتٕے یٲژ اللہ تعالیٰ سٕندِ عذا ب نِشہِ بچا و نہٕ چہِ کوٗشِشہِ تا مٕے محدوٗد ، بلکہ چھےٚ أمۍ سٕنز کٲم یِتہِ زِ فطر تٕکۍ نظا من ییٚمہِ خا ندان چہِ سر برٲہی ہُند بار أمِس پٮ۪ٹھ تر و مُت چُھ،تتھ تہِ دِیِن سُہ پننِس استطا عت کِس حدس تام تِژھہ تعلیم و تر بیت ، ییٚمہِ سٍتۍتِم اللہ تعالیٰ سٕندۍ پسند یدٕہ انسان بنَن ، تہٕ اگر تِم جہنم چہِ وَتہِ پٮ۪ٹھ گژھان آسن ، تیٚلہِ یوٚت تام أمِس تام آسہِ یِمن کٔرِن رُکا و نٕچ کوٗشش۔" جہنمُک زالُن آسن کنہِ " اَمہِ نِشہِ چُھ مُراد شاید کولہٕ ژِنہِ ۔ ابنِ مسعود رضی اللہ عنہ ، ابن عبا س رضی اللہ عنہ ، مُجا ھد رحمتُ اللہِ علیہ، امام محمد البا قر رحمتُ اللہ علیہ تہٕ سُدّی رحمتُ اللہ علیہ چھِ ونن  زِ یِمہٕ آسن گند ھک کنہِ۔﴾ یَتھ  پٮ۪ٹھ سٮ۪ٹھاہ تُند خُو تہٕ سخت گیر فر شتہٕ آسن مُقرر، یِم زٕ ہٕنۍ اللہ تعالیٰ سٕندِ حُکمٕچ نا فر مٲنی چِھنہٕ کران،تہٕ یُس حُکم تہِ یِمن دِنہٕ چُھ یِوان تَتھ چِھ بجا اَنان۔تمہِ وقتہٕ یِیہِ وَننہٕ زِ ﴾"
  66,7,"۔اے کٲفر و ، اَزمَہ کٔرِو عذر پیش، تۅہیہِ چُھو تِیُتُھے بد لہٕ دِنہٕ یِوان یٕژھہ عملہٕ توٚہۍ کران ٲسِو۔ع"