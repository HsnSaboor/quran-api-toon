quran[9]{c,v,t}:
  46,6,"۔تہٕ ییٚلہِ سٲری انسان جمع یِن کر نہٕ،تمہِ وقتہٕ آسن تِم پننیٚن ناد لا ین والیٚن ہٕندۍ دُشمن، تہٕ تِہندِ س عبا دتس آسن مُنکر۔﴿یعنی تِم ونن صا ف صاف زِ نَہ اوس اسہِ یِمن زانٛہہ ووٚ نمُت زِ توٚہۍ لٲیِو مددٕ خٲطرٕ اَسہِ ناد،أسۍ چِھو تۅہیہِ حا جت روٲیی کر ن وٲلۍ ،تہٕ نَہ چھےٚ اسہِ یہِ خبر زِ یِم ٲسۍ اسہِ ناد لایان ،یِمو چِھ أسۍ پا نے حا جت روا بنٲوِمٕتۍ تہٕ پا نے چُھکھ اسہِ نا د دِیُن لوگمُت۔﴾"
  46,7,"۔یِمن لُکن ییٚلہِ سٲنۍ آیات چِھ صا ف صاف بوزناو نہٕ یِوان، تہٕ حق چُھ یِمن برونٛہہ کُن واتان ، تیٚلہِ چِھ یِم کٲفر لُکھ تتھ متعلق ونان زِ یہِ چُھ ٹا کارٕ ہ جود۔"
  46,8,"۔کیا تِہُند وَنُن چھا یہِ زِ رسولن چُھ یہِ پا نے بنو ومُت؟ یِمن ؤنِو،  اگر مےٚ یہِ پانہٕ چُھ بنو و مُت تیٚلہِ ہیٚکِو نہٕ توٚہۍ مےٚ خُداے سٕنزِ تھپہِ نِشہِ بچٲوِتھ، یِمہٕ کتھہٕ توٚہۍ بناوان چِھو اللہ تعالیٰ چُھ تِمن وارٕ پٲٹھۍ زانان، مےٚ تہٕ تۅہیہِ در میان چُھ سُے گوٲہی دِنہٕ خٲطرٕ کٲفی، تہٕ سُہ چُھ سٮ۪ٹھاہ در گُزر کر ن وول تہٕ رحم کر ن وول ۔﴿یتھ جایہِ چھےٚ یہِ کتھ زٕہ معنی دِوان،اکھ یہِ زِ یہِ اللہ تعالیٰ سُندُے رحم تہٕ تٔمۍ سُندُے در گُزر ییٚمۍ کِںۍ تِٕ لُکھ زمینس اندر شاہ چھِ کھالان یِمن اللہ تعالیٰ سٕندِس کلامس افترا قرار دِنس منٛز کانٛہہ خوف چھُنہٕ،نتہٕ اگر کانٛہہ کانٛہہ بے رحم تہٕ سخت گیر خُداے ییٚمہِ کاینا تُک مٲلِک آسِہے ،تیٚلہِ آسِہے نہٕ یِژٕھ حر کتہٕ کرن والیٚن اکھ شہہ کھٲلِتھ دوٚ یُم شہہ کھا لُن نصیب گژھان۔دوٚ یُم مطلب چُھس یِتہِ زِ اے ظٲلِمو، اگر وُنہِ تہِ یِیِو امہِ ہٹ دھر می نِشہِ با ز تیٚلہِ چُھ خُداےسٕندِ رحمتُک دروازٕہ تُہندِ خٲطرٕ یلہٕ ،تہٕ یِکینژھاہ تۅہیہِ وُنُیستام کوٚر مُت چُھو سُہ ہیٚکہِ معا ف سپدِتھ۔﴾"
  46,9,"۔یِمن ؤنِو ، بہٕ چُھس نہٕ کانٛہہ نوٚو رسُول ، ﴿یعنی یِتھہٕ پٲٹھۍ گۅڈٕ سٲری رسول انسانٕے آسان ٲسۍ ، تہٕ خُدٲیی صفا تن تہٕ اختیاراتن منٛز اوس نہٕ تِہُند کانٛہہ حصّہٕ آسان ، تِیتُھے رسول چُھس بٕتہِ ۔﴾ مےٚ چَھنہٕ پے زِ پگاہ کیا چُھ تۅہیہِ سٍتۍ سپدن وول تہٕ مےٚ سٍتۍ کیا چھُ سپدن وول ،بہٕ چھُس صرف تٔمی  وحی ہٕنزپیروی کران یۅسہٕ مےٚ نِش سوزنہٕ چھےٚ یِوان، تہٕ بہٕ چُھس نہٕ أکِس صا ف صا ف خبردار کر ن وٲلۍ سٕندِ ورٲے بیٚیہِ کِہِنۍ۔"
  46,10,"۔اے نبی صلی اللہ علیہ وسلم،یِمن ؤنِو  زانٛہہ سوٗنچوٕ تۅہیہِ زِ اگر یہِ کلا م اللہ تعالیٰ سٕندی طر فہٕ اوس تہٕ تۅہیہِ کوٚرُو اَتھ انکار۔﴿تیٚلہِ کُس انجام آسہِ تُہُند؟﴾ تہٕ أتھۍ ہِوِس أکِس کلا مَس پٮ۪ٹھ چھےٚ بنی اسرٲیلٕکۍ أکۍ گواہن شہا دت تہِ دِژمٕژ۔ تٔمۍ اوٚ ن ایمان تہٕ توٚہۍ روٗدِو پننِس تکبر س منٛزٕ ے۔﴿یتھ جایہِ  چُھنہٕ گواہ نِشہِ مُراد کانٛہہ خا ص شخص کینٛہہ بلکہ چُھ اِسرٲیلُک اکھ عام اِنسان مُراد۔ خُداے سٕندِ اِرشادُک مُدعا چُھ یہِ زِ قرآن مجید یۅسہٕ تعلیم تۅہیہِ برونٛہہ کنہِ پیش چُھ کران،یہِ چُھنہٕ کانٛہہ نوٚو چیز یُس دُنیا ہس منٛز گۅڈ نچہِ لٹہِ تۅہی یوت برونٛہہ کنہِ آسہِ پیش کر نہٕ آمُت، تہٕ توٚہۍ ہیٚکِو یہِ عذر کٔرِ تھ زِ أسۍ کِتھہٕ پٲٹھۍ مانَو یِمہٕ کتھہٕ یِمہٕ انسٲنی زُرِیا تس برونٛہہ کُن آمژے آسہٕ نہٕ۔ییٚمہِ برونٛہہ چِھ یِمے تعلیمات یِتھے پٲٹھۍ وحی ہٕندِ ذریعہ بنی اسرٲیلس برونٛہہ کُن تورات تہٕ دوٚیِمیٚن آسمٲنی کتا بن ہٕنزِ شکلہِ منٛز آمٕتۍ، تہٕ تِہِندۍ أکۍ عام انسانن چِھ یِم مٲنِمٕتۍ۔﴾ یِتھیٚن ظٲلِمن چُھنہٕ اللہ تعالیٰ ہدا یت دِوان۔ع"
  46,11,"۔ یِمو لُکو ماننہٕ نِشہِ انکار چُھ کوٚر مُت تِم چِھ ایمان اَنن والیٚن متعلق ونان زِ اگر یہِ کتا ب مانٕنۍ جان کٲم آسِہے تیٚلہِ ہیکہَن نہٕ یِم لُکھ اتھ کامہِ منٛز اسہِ برونٛہہ گٔژِھتھ۔﴿ تِہُند مطلب اوس زِ قرآنِ مجید س پٮ۪ٹھ چُھ کینژھو نا سمجھ لُکو ایمان اوٚ نمُت ،نَتہٕ اگر یہِ کانٛہہ جان کٲم آسِہے تیٚلہِ کتہِ روزٕ ہن اسہِ ہِوٗۍ دٲنشوَر لُکھ یہِ ما ننہٕ نِشہِ پتھ۔﴾چونکہ تِمو کوٚر نہٕ تَمہِ نِشہِ ہدایت حاصل امہِ مو جو ب وَنن تِم ضروٗر زِ یہِ چُھ پرون اَپُز۔"
  46,12,"۔حالانکہ امہِ برونٛہہ چھےٚ موسیٰ علیہ السلام سٕنز کتا ب رہنما تہٕ رحمت بٔنِتھ آمٕژ، تہٕ یہِ کتا ب چھےٚ تتھ تصدیق کر ن واجِنۍ آمٕژ عر بی زبٲنۍ منٛز، تاکہ ظٲلِمن کرِ خبردار تہٕ نیک رٔوِشہِ پٮ۪ٹھ پکن والیٚن دِیہِ بشارت۔ پٔزِ پٲٹھۍ یِمو لُکو ووٚن زِ اللہ تعالیٰ ہٕے یوت چُھ سون ربّ،پتہٕ روٗدۍ تتھ پٮ۪ٹھ ڈاڈ کٔرِتھ ، تِہندِ خٲطرٕ نہٕ چُھ کانٛہہ خو ف تہٕ نَہ سپدن تِم غمگین۔"
  46,13,"۔یِتھۍ لُکھ چِھ جنّتس منٛز گژھن وٲلۍ، ییٚتہِ تِم ہمیشہِ روزن پننیو تِمو اعما لو ہٕندِ بد لہٕ یِم تِم دُنیا ہس منٛز چِھ روٗدِمٕتۍ کران۔"
  46,14,"۔اَسہِ کوٚر انسانس ہدایت زِ سُہ کٔرِن پننِس مٲلِس ما جہِ سٍتۍ نیک برتاو۔ تٔمۍ سٕنزِ ما جہِ تھو و سُہ تکلیف تُلِتھ پننہِ یٔڈ منٛز،تہٕ تکلیف تُلِتھٕے دِ یتُنَس زَنم ، تہٕ أمۍ سُند حمل تہٕ دۅد تراو نا و نس منٛز لگۍ تٕرٛہ ﴿30﴾ ریٚتھ۔ یوٚت تام سُہ پننِس پوٗرٕ طا قتس ووت، تہٕ گوٚو ژتجی وُہُر، پتہٕ ووٚ ن تٔمۍ  اے میا نہِ ربّہٕ ، مےٚ دِ تو فیق زِ بہٕ کرٕ چا نیٚن تِمن نعمتن ہُند شُکر یِمہٕ ژےٚ مےٚ تہٕ میٲنِس مٲلِس ما جہِ عطا فر ما و یٚتھ، تہٕ تِژھ نیک عمل کرٕ ییٚمہِ سٍتۍ ژٕ رٲضۍ گژھکھ، تہٕ میٲنۍ اولا د بنا وُکھ نیک تہٕ مےٚ دِ سکو ن ، بہٕ چُھس چٲنِس در بارس منٛز توبہٕ کران تہٕ بہٕ چُھس تا بع فر مان﴿ مُسلم ﴾ بندو منٛزٕ ۔"