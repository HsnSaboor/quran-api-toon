quran[5]{c,v,t}:
  66,8,"۔ اے لوٗکو یِمو ایمان چُھو اوٚ نمُت، خُدایس نِشہِ کٔرِ و تو بہٕ ، خٲلص تو بہٕ، دوٗر چُھنہٕ زِ اللہ تعالیٰ کرِ تُہنزٕ بُرٲیِیہِ دوٗر، تہٕ تۅہیہِ کر یو تِتھیٚن جنّتن منٛز دٲخل یِمن بٔنۍ کِنۍ کۅلہٕ آسن پکا ن ۔ یہِ آسہِ سُہ دۅہ ییٚلہِ اللہ تعالیٰ پننِس نبی صلی اللہ علیہ وسلمس تہٕ تِمن لُکن یِمو تِمن سٍتۍ ایمان چُھ اوٚ نمُت ، رُسوا کرِنہٕ ۔یعنی تِہنزن نیک عملن ہُند اجر کرِ نہٕ ضا یع۔ کفّارن تہٕ مُنا فقن دِیہِ نہٕ ہر گز یہِ وَننُک مو قع زِ یِمو با ایمان لُکو کٔر خُدا پرستی تہِ ، امیُک کیا مُعا و ضہٕ میوٗلُکھ۔رُسوٲیی یِیہِ بٲغین تہٕ نا فر مانن ہٕندِس حصّس منٛز ،نَہ کہ وفا دارن تہٕ فر ماں بردارن ہٕندِس حصّس منٛز۔  تِہُند نُو ر آسہِ تِمن برونٛہہ برونٛہہ،تہٕ تِمن دٔچِھنۍ کِنۍ دَوان ، تہٕ تِم آسن وانان زِ اے سانہِ ربّہٕ ،سو ن نُور کر سانہِ خٲطرٕ مکمل تہٕ اَسہِ کردر گُزر، ژٕ چُھکھ پرٛتھ چیز س پٮ۪ٹھ قدر ت تھا وان۔"
  66,9,"۔ اے نبی صلی اللہ علیہ وسلم، کُفّارن تہٕ مُنا فقن سٍتۍ کٔرِ و جہا د، تہٕ تِمن سٍتۍ یِیِو سختی سان پیش، تِہُند ٹھکا نہٕ چُھ جہنم تہٕ سُہ چُھ سٮ۪ٹھاہ بُرٕہ ٹِھکا نہٕ ۔"
  66,10,"۔اللہ تعالیٰ چُھ کٲفر ن ہٕندِس معا ملس منٛز نوح علیہ السلام تہٕ لوط علیہ السلام سٕنز ن خا ندارِنیٚن بطورِ مثال پیش کران۔تِمہٕ آسہٕ سا نیٚن دۅ ن صا لح بند ن ہٕندِس زو جیتس منٛز، مگر تِمو کٔر پننیٚن تِمن خا ندارن سٍتۍ خیا نت۔ یہِ خیا نت چَھنہٕ اَتھ معنِیس منٛز زِ تِمو ٲس بد کٲری کٔر مٕژ بلکہ چھےٚ اَتھ معنیس منٛز زِ تِمو دیُت نہٕ ایمان چہِ وَتہِ منٛز حضر ت نو ح علیہ السلام تہٕ حضر ت لو ط علیہ السّلا مس ساتھ، بلکہ روزٕ تِہندِس مقا بلس منٛز دین کیٚن دشمنن ساتھ دِوان ۔ تہٕ تِم آے نہٕ اللہ تعالیٰ سٕندِس مقا بلس منٛز تِمن رَژھ تہِ بکار۔ دۅ شوٕنۍ آو وَننہٕ زِ گٔژِھو نارس منٛز گژھن والیٚن سٍتۍ توٚہۍ تہِ۔"
  66,11,"۔ تہٕ اہلِ ایمانن ہٕندِس معا ملس منٛز چُھ اللہ تعالیٰ فر عو ن سٕنزِ خاندارِ نہِ ہٕنز مثا ل پیش کران، ییٚلہِ تمہِ دُعا کوٚر" اے میا نہِ ربّہٕ ، میا نہِ خٲطرٕ بنا و  پا نس نِشہِ  جنتس منٛز اکھ گھرٕ ،تہٕ مےٚ بچا و فر عو نس تہٕ تٔمۍ سٕنزِ عملہِ نِشہِ تہٕ ظٲلِم قو مہٕ نِشہِ دِم نجا ت"۔"
  66,12,"۔تہٕ بیٚیہِ چُھ مثا ل دِوان عمرا ن سٕنزِ کورِ مر یم سٕنز  بنان چُھ زِ مر یم علیہا السلام سٕندِس مٲلۍ سُند ناو آسہِ ہے عمران، نَتہٕ آسہِ تِمن علیہا السلامن عمرا ن سٕنز کوٗر امہِ موجو ب وَننہٕ آمُت زِ سۅ ٲس آلِ عمران منٛزٕ  ییٚمہِ پننہِ شر م گا ہٕچ حفا ظت ٲس کٔر مٕژ۔یہِ چُھ یہوٗدٮ۪ن ہٕندِ تمہِ الزامُک تردید زِ حضرت عیسیٰ علیہ السلامن ہٕنز پیدٲیش ٲس معا ذاللہ گُنا ہُک نتیجہِ۔سورۂ نسا آیت  156،ہس منٛز چُھ یِمن ظٲلِمن ہُند یہِ الزام عظیم بہتا ن قرار دِنہٕ آمُت پتہٕ چھوٚک اَسہِ تس منٛز پنُن روح پھۅ کھ دِتھ۔یعنی اَمہِ ورٲے زِ تس آسہِ ہے کٲنٛسہِ مردس سٍتۍ کانٛہہ تعلق ،تِہنزِ بچہِ دانہِ منٛز ترٛ وو اَسہِ پننہِ طر فہٕ اکھ زُو۔ تہٕ تٔمۍ کوٚر پننِس ربّ سٕندٮ۪ن ارشاداتن تہٕ تٔمۍ سٕنز ن کتا بن ہُند تصدیق ، تہٕ سۅ ٲس اطا عت گُزار لُکو منٛزٕ ۔ ع  ییٚمہِ مقصدٕ خٲطرٕ یتھ جا یہِ حضرت مر یم علیہا السلام مِثا لہِ رٔنگۍ چھےٚ پیش کر نہٕ آمٕژ، سُہ چُھ یہِ زِ خُدا ین ٲس سۅ أکِس شدید آز مٲیشہِ منٛز ترٲومٕژ، تِکیازِ اللہ تعالیٰ سٕندِ معجزہ سٍتۍ روٗز سۅ حٲملہٕ مگر تمہِ نٚو مروو صبرٕ سان اللہ تعالیٰ سٕنزِ مر ضی برونٛہہ کنہِ پنُن کلہٕ۔"