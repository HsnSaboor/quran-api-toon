quran[5]{c,v,t}:
  24,32,"۔تۅہیہِ منٛزٕ یِم لُکھ نیترٕ ورٲے آسن، تہٕ تُہنز ولو نڈیَو تہٕ غلا مَو منٛزٕ یِم صا لح آسن ،تِہِندۍ نکا ح کٔرِ واگر تِم غر یب آسن،اللہ تعالیٰ کرِ تِمن پننہِ فضلہٕ سٍتۍ غنی اللہ تعالیٰ چُھ سٮ۪ٹھاہ وُسعت وول تہٕ علم وول۔"
  24,33,"۔تہٕ یِم نِکا حُک مو قع لبن نہٕ تِمن پزِ زِ عفّت مٲبی  پا کدا منی کٔرِن اختیار، یوٚت تام زن اللہ تعالیٰ تِمن پننہِ فضل سٍتۍ غنی کرِ۔تہٕ تُہٕند یٚو مملوٗ کَو غلا مَو  منٛزٕ یِم مکا تبتُک در خوا ست کر ن، تِمن سٍتۍ کٔرِ و مکا تبت، مکا تبتُک مطلب چُھ یہِ زِ کانٛہہ غلام یا لو نڈ ی کرِ پننِس مٲلِکس اکھ مُعا و ضہٕ ادا کر نٕچ پیشکس، تہٕ ییٚلہِ مٲلِک یہِ قبو ل کرِ،تیٚلہِ گژَھن دۅ شوٕنۍ در میان شر ٲیط یِنۍ لیٚکھنہٕ اگر تۅہیہِ پے آسیٚو زِ یِمن منٛز چُھ  رٕژَر۔رٕژرٕ نِشہِ چُھ مُراد زٕہ چیز: اکھ یہِ زِ غلا مس منٛز آسہِ مالِ کتا بت ادا کر نٕچ صلٲحیت۔ دوٚیُم یہِ زِ أمِس منٛز آسہِ تیٖژھا دیا نت تہٕ راست بٲزی زِ تٔمۍ سٕندِس قَو لس پٮ۪ٹھ یِیہِ اعتماد کٔرِ تھ معا ہدہ کر نہٕ۔ تہٕ  تِمن دِیِو تمہِ مالہٕ منٛز یُس خدا ین تۅہیہِ چُھنو دُیتمُتیہِ چُھ عا م حُکم ، مٲلِک تہِ کٔرِ ن کینٛہہ نَتہٕ کینٛہہ رقم معا ف ، مسلمان تہِ کٔرِن یِمن مدد۔ بیت المال منٛزٕ تہِ گژِھہ یِمن اعا نت کر نہٕ یُن۔تہٕ پننہِ لونڈ یہِ مَہ کٔرِ یوٗکھ بد کٲر ی پٮ۪ٹھ مجبور جٲہلیّت  کِس زمانس منٛز ٲسۍ اہلِ عر ب پننیو  لو نڈیَو ہٕندِ ذر یعہ بد کٲر ی ہُند پیشہ کرناوان ، تہٕ تِہنز کمٲے ٲسۍ کھیٚوان، اسلامَس منٛز آو یہِ پیشہ ممنو ع قرار دِنہٕ۔ ییٚلہِ زن تِمہٕ پانہٕ آسن پاک دا من یژھان روزُن مطلب چُھ یہِ زِ اگر لو نڈی خۅد پننہِ مر ضی بد کٲر ی ہٕنز مر تکب سپدِ تیٚلہِ چھےٚ سۅ پننہِ جُر مٕچ پانہٕ ذمہ دار۔ قانو ن رٹہٕ تٔمِسٕے تٔمۍ سٕندِس جُر مس پٮ۪ٹھ ، البتہ اگر أمۍ سُند مٲلک جبر کٔرِ تھ أمِس یہِ پیشہ اختیار کر ناوِ ، تیٚلہِ چھےٚ ذمہ دٲر ی مٲلِک سٕنز تہٕ سُے یِیہِ رٹنہٕ  تاکہ تۅہیہِ گژھنَو دُنیٲوی فٲیدٕ ہ حٲصل، تہٕ یُس اکھا تِمن مجبو ر کرِ، تیٚلہِ چُھ امہِ جبرٕ پتہٕ اللہ تعالیٰ تِہندِ خٲطرٕ غفورو رحیم۔"
  24,34,"۔اسہِ چِھ صا ف صا ف ہدا یت دِنہٕ وٲلۍ آیات تۅہیہِ نِشہِ سوٗزِ مٕتۍ، تہٕ تِمن قو من ہٕنزٕ عبرت ناک مِثالہٕ تہِ چھےٚ تۅہیہِ برونٛہہ کنہِ پیش کرِ مَژٕ، یِم تۅہیہِ برونٛہہ چِھ گُزر یمٕتۍ، تہٕ تِمہٕ نصیحت چھےٚ اسہِ کرِ مٕژ، یِمہٕ کھۅژن والیٚن ہٕندِ خٲطرٕ چھےٚ آسان۔ ع"
  24,35,"۔ اللہ تعالیٰ چُھ آسما نن ہُنٛد تہٕ زمینُک نُور۔ یعنی کایناتس منٛز یِکینژھاہ تہِ ظٲہر چُھ سُہ چُھ تٔمۍ سٕندۍ نورٕ کہ بدولتہٕ۔ کا یناتس منٛز چھےٚ تٔمۍ سٕندِ نوٗرٕچ مِثال تِژھ زنتہٕ أکِس طا قس منٛز آسہِ ژونگ تھٲوِ تھ، ژو نگ آسہِ أکِس قندیلس منٛز،تہٕ قند یلُک حال آسہِ یہِ زنتہٕ مۅ ختٕکۍ پٲٹھۍ اکھ پرٛزلہٕ وُن تارُک، تہٕ سُہ ژو نگ آسہِ زیتو ن کہ اکہِ تِتھہِ مبا رک کُلۍ کہ تیٖلہٕ سٍتۍ روشن یِوان کر نہٕ، یُس نہ شر قی آسہِ نہ غر بی  یعنی ییٚمیُک بُتھ نَہ آسہِ مشر قس کُن تہٕ نَہ آسہِ مغربس  کُن ، ییٚمہِ کِس تیٖلس پٲنۍ پانے آسہِ ریٚہہ ہیٚوان، چا ہے تتھ متہٕ لٔگۍ تن نار،یِتھہٕ پٲٹھۍ  آسن گا شس پٮ۪ٹھ گا ش  ہُر نٕکۍ تمام اسباب جمع گٔمٕتۍ۔ ییٚمہِ مثا لہِ سٍتۍ چھےٚ ژٲنِگس اللہ تعالیٰ سٕندِ س ذا تس سٍتۍ تہٕ طا قس چھےٚ کا یناتس سٍتۍ تشبیہ دِنہٕ آمٕژ، تہٕ فا نو س نِشہِ چُھ مُراد سُہ پردہ یتھ منٛز حضر تِ حقن پنُن پان چُھ خلقن ہٕنزِ نظرِ نِشہِ ژھا یہِ تھو و مُت۔ گو یا یہِ پردٕہ چُھنہٕ فی الحقیقت نا راضگی ہُند کینٛہہ، یہِ چُھ شدّتِ ظہو رُک پردٕہ، خلقن ہٕنز نظر چھےٚ یہِ وُچھِنس امہِ موجو ب عٲجز زِ نوٗر چُھ تیوٗتاہ شد ید تہٕ وسیع تہٕ محیط ییٚمیُک ادراک محدوٗد أچھ گا ش ہیٚکن نہٕ کٔرِ تھ۔روٗد یہِ مضمو ن زِ  ژو نگ آسہِ تِتھہِ زیتو ن کُلۍ کہ تیٖلہِ سٍتۍ روشن یِوان کر نہٕ یُس نہ شر قی آسہِ نہ غر بی ، یہِ چُھ صرف ژانگہِ چہ روشنی ہٕندِ کما لہٕ تہٕ امہِ کہ شدّتُک تصّور دِنہٕ خٲطرٕ۔ تِکیازِ پرٲنِس زمانس منٛز ٲس زیادہ کھۅتہٕ زیادہ روشنی روغن زیتو ن کیٚو ژانگیو سٍتۍ حا صل یِوان کر نہٕ،تہٕ یِمن منٛز اوس روشن تر ین ژو نگ سُہ آسان یُس بُلند تہٕ کُھلہٕ جایہِ ہٕندِ کُلہِ منٛزٕ کڑنہٕ آمتہِ تیٖلُک آسِہے۔ تہٕ یُس یہِ فر ماو نہٕ آو زِ  ییٚمہِ کِس تیٖلس  پا نۍ پانے آسہِ ریٚہہ ہیٚوان ، چا ہے تتھ متہٕ لٔگۍ تن نار، امہِ نِشہِ تہِ چُھ مقصد ژانگہِ کہ گا شُک زیادہ کھۅتہٕ زیادہ تیز تصّور دِیُن۔ اللہ تعالیٰ یَس پننِس نوٗرس کُن یژھان چُھ رہنمٲیی چُھس فر ماوان، سُہ چُھ لُکن مِثا لو سٍتۍ کتھ سمجھاوان۔تہٕ سُہ چُھ پرٛتھ چیز نِشہِ خو ب وٲقف۔"
  24,36,"۔تٔمۍ سٕندِس نوٗرس کُن ہدا یات لبن وٲلۍ چِھ تِمن گھر ن منٛز لبنہٕ یِوان یِمن بُلند کر نُک ، تہٕ یِمن منٛز پننہِ ناوٕ چ ذِکر کر نُک خُدا ین اِذن چُھ دِیتمُت، تِمن منٛز چِھ صُبحس تہٕ شا مس تٔمۍ سٕنز تسبیح کران،"