quran[8]{c,v,t}:
  33,36,"۔کٲنٛسہِ مو من مردس تہٕ کٲنٛسہِ مو من خا تو نہ چُھنہٕ یہِ حق زِ ، ییٚلہِ اللہ تعالیٰ تہٕ تٔمۍ سُند رسو ل صلی اللہ علیہ وسلم کُنہِ معا ملُک فٲصلہٕ کر ن، تہٕ پتہٕ روزِ تس پننِس تتھ معا ملس منٛز خۅد فٲصلہِ کر نُک کانٛہہ اختیارحٲصل۔ تہٕ یُس اکھا ہ اللہ تعالیٰ تہٕ تٔمۍ سٕندِس رسول صلی اللہ علیہ وسلم سٕنز نا فر مٲنی کرِ ، تیٚلہِ پیوٚ و سُہ ٹا کارٕ ہ گُمرٲہی منٛز۔"
  33,37,"۔اے نبی صلی اللہ علیہ وسلم ، یا د کٔرِ و سُہ مو قع ییٚلہِ توٚہۍ تس شخصس ٲسِو ونان یس پٮ۪ٹھ خُدا ین تہٕ تۅ ہیہِ احسا ن اوسُو کوٚر مُت زِ، پنٕنۍ خا ندارِ نۍ مَہ ترا وُن تہٕ خُدا یس کھۅژ۔ ﴿ تس شخصس نِشہِ چُھ مُراد حضر ت زید بن حا رثہ رضی اللہ عنہ یِم رسول اللہ صلی اللہ علیہ وسلمن ہٕندۍ آزاد کر نہٕ آمٕتۍ غلا م تہٕ تِہندۍ منگتہٕ نیچِو ۍ ٲسۍ۔تہٕ تِہنزِ خا ندار نہِ نِشہِ چُھ مُراد حضر ت زینب رضی اللہ عنہا یۅسہٕ حضور صلی اللہ علیہ وسلمن ہٕنز پۅ پھتٕر بیٚنہِ ٲس ، تہٕ حضو رصلی اللہ علیہ وسلمن اوس تِہُند نکا ح حضر ت زید رضی اللہ تعالیٰ عنہ ہس سٍتۍ کوٚر مُت۔ مگر دۅ شوٕ نۍ ٲس نہٕ پانہٕ وٲنۍ برابری یِوان تہٕ حضرت زید رضی اللہ عنہ ٲسۍ تِمن طلا ق یژھان دِیُن ﴾تمہِ وقتہٕ  ٲسِو توٚہۍ سۅ کتھ دِلس منٛز چُھپٲوِتھ یۅسہٕ اللہ تعالیٰ اوس ظٲہر  کرٕ نۍ یژھان، توٚہۍ ٲسِو لُکن کھۅژان، حا لانکہ اللہ تعالیٰ چُھ اَمِیُک زیا دہ حقدار زِ توٚہۍ کھوٚژِ و تس ﴿ یعنی اللہ  تعالیٰ سٕنز مر ضی ٲس یہِ زِ ییٚلہِ حضر ت زید رضی اللہ عنہ حضر ت زینب رضی اللہ عنہا ہس طلا ق دِ ہن ، پتہٕ پھُٹرا وہن رسول اللہ صلی اللہ  علیہ وسلم خۅد تِمن سٍتۍ نکاح کٔرِ تھ عر بُک سُہ پرٛ و ن رسم، ییٚمہِ کِنۍ منگتہٕ نیٚچواصلی نیٚچواوس سمجھنہٕ یِوان ۔ مگر حضو ر صلی اللہ علیہ وسلم  ٲسۍ امہِ اندیشہِ کِنۍ اتھ آز مٲیشہِ منٛز ہیٚنہٕ یِنہٕ نِشہِ بچُن یژھان زِ اہلِ عر ب کر ن سخت نکتہٕ چینی۔اَمی مو جو ب چِھ حضور صلی اللہ علیہ وسلم کو شش فر ماوان زِ زید رضی اللہ عنہ گٔژھۍ نہٕ پننہِ خا ندارِ طلا ق دِنۍ۔  پتہٕ ییٚلہِ زید رضی اللہ عنہ چُھ تس نِشہِ پنُن حا جت پوٗرٕ کران ﴿ یعنی طلا ق دِنٕچ خو ٲہش یۅسہٕ تِمن ٲس سۅ کٔر تِمو پوٗرٕ، تہٕ پننہِ طلا ق دِنہٕ آمژِ خا ندارِ نہِ سٍتۍ روٗد نہٕ تِمن کانٛہہ رشتہٕ با قی﴾پتہٕ کوٚر اسہِ تس ﴿ طلا ق دِنہٕ آمژِ خا تونہِ ﴾ ہُند نکا ح تۅہیہِ سٍتۍ،تاکہ مو نن پٮ۪ٹھ روزِ نہٕ پننیٚن منگتہٕ نیچو ٮ۪ن ہٕنز ن خا ندارِ نیٚن ہٕندِس معا ملس منٛز کانٛہہ تنگی، ییٚلہِ زَ ن تِمو تِمن نِشہِ پنُن حا جت پوٗرٕ آسہِ کوٚر مُت۔ تہٕ اللہ تعالیٰ سٕندِس حُکمس اوس بہر  حال عملہِ منٛز یُن۔"
  33,38,"۔نبی صلی اللہ علیہ وسلمس پٮ۪ٹھ چَھنہٕ کُنہِ تِژِھہ کامہِ منٛز کانٛہہ رُکا وٹ یۅسہٕ خُدا ین تٔمۍ سٕندِ خٲطرٕ مُقرر آسہِ کٔرمٕژ۔یۅ ہے اللہ تعالیٰ سُند سُنّت چُھ تِمن سارِ نٕے انبیا ہن علیھم السلامن ہٕندِس معا ملس منٛز روٗد مُت یِم گۅڈٕ چِھ گُزر یمٕتۍ، تہٕ اللہ تعالیٰ سُند حُکم چُھ اکھ قطعی طے سپُدمُت فٲ صلہٕ آسان ۔﴿ یہِ چُھ اللہ تعالی سُند سنّت تِمن لُکن خٲطرٕ ﴾"
  33,39,"۔یِم اللہ تعالیٰ سٕندۍ پیغا مات وا تنا وان چِھ تہٕ تٔسۍ چِھ کھۅژان، تہٕ أکِس خُدا یس ورٲے چِھنہٕ کٲنٛسہِ کھۅژان، تہٕ محا سبہٕ خٲطرٕ چُھ بس اللہ تعالیٰ ہٕے کٲفی۔"
  33,40,"۔﴿لوٗکو ﴾ محمد صلی اللہ علیہ وسلم چِھنہٕ تُہند یٚو مردَو منٛزٕ کٲنٛسہِ ہٕندۍ مٲلۍ ، مگر یِم چِھ اللہ تعالیٰ سٕندۍ رسول صلی اللہ علیہ وسلم بیٚیہِ چِھ خا تم النبیّن ، تہٕ اللہ تعالیٰ چُھ پرٛتھ چیزُک علم تھا و ن وول۔ع۔ ﴿ یتھ أکِس کتھہِ منٛز چُھ تِمن تمام اعتراضن موٗل آمُت ژٹنہٕ یِم اعترا ض مخا لف ٲسۍ نبی صلی اللہ علیہ وسلمن ہٕندِس اتھ نکاحس پٮ۪ٹھ کرا ن ۔ تِہُند گۅٚنِیُک اعتراض اوس یہِ زِ تِمو صلی اللہ علیہ وسلم کوٚر پننہِ نۅ شہِ سٍتۍ نکا ح۔امہِ کِس جوا بس منٛز چُھ فر ما و نہٕ آمُت زِ  محمد صلی اللہ علیہ وسلم چِھنہٕ تُہند یٚو مردَو منٛزٕ کٲنٛسہِ ہٕندۍ مٲلۍ۔ یعنی ییٚلہِ سُہ نیچُو ے اوس نہٕ تیٚلہِ  کِتھہٕ پٲٹھۍ ہیٚکہِ ہے تٔمۍ سٕنزِ مطلّقہ ہس سٍتۍ نکا ح حرا م ٲسِتھ؟ دوٚ یُم اعترا ض اوس یہِ زِ اگر منگتہٕ نیچُو اصلی نیچُو چُھنہٕ ، تمہِ پتہٕ تہِ اوس نہٕ تٔمۍ سٕنزِ ترا و نہٕ آمٕژِ زَنہِ سٍتۍ نکا ح کرُن ضرور ی کینٛہہ۔ امہِ کِس جوا بس منٛز آو فر ما و نہٕ مگر تِم چِھ اللہ تعالیٰ سٕندۍ رسول  ، یعنی رسول آسنہٕ کہ حیثیت اوس تِمن پٮ۪ٹھ یہِ فر ض عٲید سپدان زِ یُس حلال چیز تُہٕند یٚو رسمو خوا ہ مخوا ہ حرا م چُھ کوٚر مُت، تمہِ کِس با رس منٛز کر ن تمام تعصبّا تن خٲتمہ ، تہٕ امہِ کِس حلال آسنہٕ کِس معا ملس منٛز گژھن نہٕ کُنہِ شکٕچ گُنجٲ یش پتھ کُن تھا وٕنۍ۔ پتہٕ آو مز ید تٲکیدٕ خٲطرٕ فر ما و نہٕ  تہٕ تِم صلی اللہ علیہ وسلم چِھ خا تم النبیّن، یعنی تِمن پتہٕ چُھنہٕ کانٛہہ رسولٕے یِنہٕ وول تہٕ کانٛہہ نبی ینٕچ چَھنہٕ کتھٕے زِ اگر قا نو ن تہٕ معا شرُک کانٛہہ اِصلا ح تِہندِس زمانس منٛز نا فذ کٔر نہٕ نِشہِ روزِ ، تیٚلہِ کرِ امہِ پتہٕ یِنہٕ وول نبی یہِ کسر پوٗرٕ ، لہٰذا اوس یہِ بیٚیہِ تہِ ضرور ی بنیو مُت زِ امہِ جا ہلیت کہ رسمُک خٲتِمہٕ کر ہَن تِم پا نے۔ امہِ پتہٕ آو مز ید زور دِتھ فر ما و نہٕ زِ  اللہ تعالیٰ چُھ پرٛتھ چیزُک علم تھا وان۔ یعنی خُدا یس چھےٚ پے زِ امہِ ساعتہٕ کیا زِ اوس محمد صلی اللہ علیہ وسلمن ہٕند ذریعہِ یہِ جا ہلیتُک رسم ختم کرُن ضروری ، تہٕ یہِ رسم ختم نہ کر نس منٛز کیا قبا حت ٲس۔﴾"
  33,41,"۔اے لوٗکو یِمو ایمان چُھو اوٚ نمُت ، اللہ تعالیٰ  کٔرِ یوٗن کثر ت سان یاد،"
  33,42,"۔تہٕ صُبح و شا م روٗزِ و تٔمۍ سٕنٛز تسبیح کران۔"
  33,43,"۔ سُے چُھ یُس تۅہیہِ پٮ۪ٹھ رحمت چُھ فر ماوان تہٕ تٔمۍ سٕندۍ ملٲیِک چِھ تُہٕندِ خٲطرٕ رحمتُک دُعا کرا ن، تاکہ سُہ اَنیو تۅہیہِ اَنہِ گٹَو منٛزٕ گا شس کُن کٔڑِ تھ، سُہ چُھ مو نن پٮ۪ٹھ سٮ۪ٹھاہ مہر بان۔"