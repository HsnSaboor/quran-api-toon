quran[4]{c,v,t}:
  2,142,"۔ نادان لُکھ وَنن ضروٗر : یِمن کیا گوٚو زِ یتھ قبلس کُن رۅ خ کٔرِ تھ یِم گۅڈٕ ہ نماز پرا ن ٲسۍ ،تَمہِ نِشہِ پھیٖرۍ اچا نک ؟ ﴿نبی صلی اللہ علیہ وسلم روٗدۍ ہجرت پتہٕ مد ینہٕ طیّبس منٛز شۅ را ہن یا سَد ہن ریٚتن تام بیتُ المقدّسس کُن رۅ خ کٔرِ تھ نمازِ پرا ن ۔ پتہٕ آو کعبس کُن بُتھ کٔرِ تھ نماز پر نُک حُکم ۔﴾ اے نبی صلی اللہ علیہ وسلم، یِمن وَنِو : مشر ق تہٕ مغر ب سورُے چُھ اللہ تعالیٰ سُنٛد، اللہ تعالیٰ تعالیٰ یس یژھان چُھ، تَس چُھ سِیٔز وَتھ ہاوان ۔"
  2,143,"۔تہٕ یِتھے پٲٹھۍ بنٲوِو اَسہِ توٚہۍ مسلمان اکھ  اُمّتِ وَسط۔ ﴿ اُمّتِ وَسط نِشہِ چُھ مُراد تِژھ اکھ اعلیٰ تہٕ حدٕ کھۅتہٕ شر یف چھۅ کھ، یۅسہٕ عد ل و انصا فس تہٕ در میانہٕ رٔوِشہِ پٮ۪ٹھ قٲیِم آسہِ ، یۅسہٕ دُنیا کیٚن قو من در میان صدرٕ سٕنٛز حیثیت آسہِ تھاوان، ییٚمہِ سُنٛد تعلق سارِنٕے سٍتۍ حقُک تہٕ پز رُک یکسا ن تعلق آسہِ ، تہٕ نا حق تہٕ ناروا تعلق آسیٚس نہٕ کٲنٛسہِ سٍتۍ ۔﴾ تا کہ توٚہۍ ٲسِو لُکن پٮ۪ٹھ گواہ تہٕ رسول آسہِ تۅہیہِ پٮ۪ٹھ گواہ ﴿اَمہِ نِشہِ چُھ مُراد یہِ زِ ٲخرتس منٛز ییٚلہِ سٲرِسٕے انسانی زُر یا تس یِیہِ یِکہٕ وَٹہٕ حسا ب ہیٚنہٕ، تمہِ وقتہٕ دِیہِ رسول تُہٕنٛدِ س ذمہٕ دار نُما یندٕہ سٕنٛدِ حیثیت تۅہیہِ پٮ۪ٹھ گوٲہی زِ صحیح فکرِ ہٕںز،صا لح عملن ہنٛز تہٕ عد ل کہ نظا مٕچ یوسہٕ تعلیم اَسہِ تس دِژ مٕژ ٲس، کیا سۅ واتنٲواتٔمۍ کانٛہہ کمی کر نہٕ ورٲے اند ہیٚتھ سٲرٕ ے ،تہٕ عملاً تہِ ہووا تٔمۍ اَتھ مطا بق کٲم کٔرِ تھ۔ اَمہِ پتہٕ آسیٚو تۅہیہِ رسول سٕندِ قٲیِم مقا م سٕندِ حیثیت عا م انسانن پٮ۪ٹھ گواہ سٕندِ حیثیت وۅ تُھن تہٕ یہِ شہادت آسیٚو دِنۍ زِ رسولن یِکینٛژھاہ تۅہیہِ تام واتنو و مُت اوس ، سُہ واتنو وا تۅہیہِ لُکن تام تہٕ یِکینٛژھاہ رسولن تۅہیہِ عمل کٔرِ تھ ہو و مُت اُوسنَو ، تہِ ہووٕ و اتۅ ہیہِ تِمن عمل کٔرِ تھ  تہٕ اَتھ منٛز ما کٔرٕ و کانٛہہ کوتٲہی ﴾۔گۅڈٕہ یَتھ اَندس کُن توٚہۍ رۅخ ٲسِو کران سُہ اوس اَسہِ صِرف یہِ وُچھنہٕ خٲطرٕ قبلہٕ مُقرر کوٚر مُت زِ کُس چُھ رسول سٕنٛز پیر وی کرا ن تہٕ کُس چُھ پوٚت پھیران، اوس تہِ یہِ معا ملہٕ بڈٕ سخت، مگر تِمن لُکن خٲطرٕ سپُد نہٕ رَژھ تہِ سخت ثٲبت ،یِم اللہ تعالیٰ سٕندِ ہدا یت نِشہِ فیض یا ب ٲسۍ ،اللہ تعالیٰ کرِ نہٕ تُہنٛدِ س اَتھ ایمانس ہر گز ضا یع، پَژھ کٔرِو زِ اللہ تعالیٰ چُھ لُکن ہٕنٛدِس حقس منٛز سٮ۪ٹھاہ شفیق تہٕ رحیم ۔"
  2,144,"۔اے نبی صلی اللہ علیہ وسلم، اَمہِ تُہٕنٛدِ رویُک بار بار آسمانس کُن وۅ تُھن چِھ أسۍ وُچھان، رٔٹِو، تٔتھۍ قبلس کُن چِھو أسۍ توٚہۍ پھِرا ن، یُس توٚہۍ پسند چِھو کران۔پھِرِ و مسجد حرا مَس کُن پنُن رۅ خ وۅ نۍ ییٚتہِ توٚہۍ ٲسِو ، تٔتھۍ کُن أسۍ زیٚو رۅ خ کٔرِ تھ نماز پرا ن﴿یہِ چُھ سُہ اصلی حکم ،یُس قبلہ بدلاونس متعلق دِنہٕ اوس آمُت ۔یہِ حُکم سپُد رجب یا شعبا ن ، 2 ہجر ی منٛز نٲزِل۔ نبی صلی اللہ علیہ وسلم چِھ أکِس صحا بی رضی اللہ عنہ  سُند دعوتس پٮ۪ٹھ گٔمٕتۍ آسان۔ تَتہِ چُھ ظُہر نماز ہُنٛد وقت واتان تہٕ نبی صلی اللہ علیہ وسلم چِھ  لُکن نماز پرناو نہٕ خٲطرٕ کھڑا سپدان۔زٕ ہ رکٲژ آسکھ پر ناوِ مژٕ تہٕ ترٛییٚمہِ رکٲژ منٛز چھےٚ تمی ساعتہٕ و حی ہٕندِ ذر یعہ یہِ آیت نٲزِل سپدان تہٕ تمی وقتہٕ چِھ نبی صلی اللہ  علیہ وسلم تہٕ سٲر ی لُکھ یِم تِہٕندِس اِقتداہس منٛز جما عتس منٛز ٲسۍ بیت المقدس نِشہِ کعبس کُن پنُن رۅ خ پھِرا ن۔ اَمہِ پتہٕ آو مد ینس دٔچِھنۍ کھووٕ رۍ اَمیُک ڈنڈ وٗرٕ دِنہٕ تہٕ یُس یہِ فر ماو نہٕ چُھ آمُت زِ  چا نہِ رۅ یُک با ر بار اَسمانس کُن وۅ تُھن چِھ أچھۍ وُچھان  بیٚیہِ یہِ زِ تٔتھۍ قبلس کُن چِھو أسۍ پھِرا ن ، یُس توٚہۍ پسند چِھو کران  اَمہِ نِشہِ چُھ صا ف پے لگا ن زِ قبلہ بد لا و نُک حُکم یِنہٕ برونٛہہ ٲسۍ نبی صلی اللہ علیہوسلم اَمِکۍ مُنتظر ۔ ﴾یِم لُکھ یِمن کتا ب ٲس دِنہٕ آمٕژ تِم چِھ وارٕ پٲٹھۍ زانان زِ ﴿قبلہ بد لاو نُک یہِ ﴾ حُکم چُھ تِہنٛدِ س ربّ سٕندۍ طر فہٕ تہٕ بیٚیہِ چُھ بر حق مگر امہِ با و جو د یِکینٛژھاہ تِم کران چِھ ، اللہ تعالیٰ چُھنہٕ تَمہِ نِشہِ بے خبر کینٛہہ ۔"
  2,145,"۔توٚہۍ أنۍ تَو یِمن اہلِ کتا بن نِشہِ کانٛہہ تہِ نِشٲنی ، یہِ چُھنہٕ ممکن زِ یِم لا گن تُہٕندِ قبلٕچ  پیر وی کرٕنۍ تہٕ یِمو منٛزٕ چُھنہٕ کانٛہہ دوٚ ر تہِ دوٚ یِمہ سٕندِ قبلٕچ  پیروی کر نہٕ خٲطرٕ تیار تہٕ اگر تۅہیہِ تَمہِ عِلمہٕ پتہٕ یُس تۅہیہِ نِش آمُت چُھ، تِہنٛز ن خوٲہشا تن ہٕنٛز پیر وی کٔرٕ و تیٚلہِ گژِھہ یقیناً تُہُند شُما ر ظٲلِمن منٛز ۔"