quran[5]{c,v,t}:
  60,1,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت۔  مُفسِر ن ہُند چُھ اتھ کتھہِ پٮ۪ٹھ اتفاق زِ یِم آیات ٲسۍ تمہِ ساعتہٕ نٲزِل سپٕدمٕتۍ ییٚلہِ مکہٕ کیٚن مشر کن ہٕندِناوٕ حا طِب بن ابی بلتعہ رضی اللہ عنہ سُند خط رَٹنہٕ آو ، یتھ منٛز تِمو قبل اَز وقت دُشمن ٲسۍ مُطلع کٔرِ مٕتۍ زِ رسول اللہ صلی اللہ علیہ وسلم چِھ مکّس پٮ۪ٹھ حملہٕ کر ن وٲلۍ۔ مَہ بنٲوِ یوٗکھ میٲنۍ تہٕ پنٕنۍ دشمن دوست ۔توٚہۍ چِھو تِمن دوستی ہُند پیغام سوزان، حالانکہ یُس حق تۅہیہِ نِشہِ ووتمُت چُھ، سُہ ماننہٕ نِشہِ چُھ تِمَو انکار کوٚر مُت۔تہٕ تِہٕنز رٔوِش چھےٚ یہِ زِ تِم چِھ رسول صلی اللہ علیہ وسلمس تہٕ خۅد تۅہیہِ صرف اَتھ قصورس پٮ۪ٹھ جلا وطن کران زِ تۅہیہِ چُھو پننِس ربّس ،خدا یس پٮ۪ٹھ ایمان اوٚ نمُت  لہٰذا مَہ کٔرِ و تِمن سٍتۍ دوستی اگر توٚہۍ میانہِ وَتہِ منٛز جہا د کر نہٕ خٲطرٕ تہٕ میانہِ رضا خٲطرٕ  وطن ترٲوِتھ گھر و منٛزٕ  درٛا مٕتۍ چِھو۔ توٚہۍ چِھو ژوٗرِ پٲٹھۍ تِمن دوستی ہُنٛد پیغام سوزان، حالانکہ یِکینٛژھاہ توٚہۍ ژوٗرِ پٲٹھۍ چِھو کران تہٕ یِکینٛژھاہ نَنہِ وانہٕ چِھو کران، پرٛتھ کانٛہہ چیز چُھس بہٕ وارٕ پٲٹھۍ زانان۔ یُس شخص تہِ تۅہیہِ منٛزٕ یہِ کرِ۔ سُہ ڈوٚل پٔزِ پٲٹھۍ سیٚزِ وَتہِ نِشہِ ۔"
  60,2,"۔تِہُند رٔوِیہِ چُھ یہِ زِ اگر تۅہیہِ پٮ۪ٹھ قا بو حٲصل گژھیٚکھ ،تیٚلہِ کر ن تۅہیہِ سٍتۍ دشمنی، تہٕ اَتھو تہٕ زیٚوِ سٍتۍ دِ نَو بُرٲیی سان آزار۔ تِم چِھ یی یژھان زِ کُنہِ پٲٹھۍ گٔژِھو توٚہۍ کٲفر سپدٕنۍ۔"
  60,3,"۔قیا مت کہ دۅہ نَہ یِن تُہٕنزٕ رشتہٕ دٲر یہِ کُنہِ بکا ر تہٕ نَہ تُہندۍ اولاد۔چو نکہ حضر ت حاطِب رضی اللہ عنہ ہَن ٲس یہِ کٲم امہِ مو جو ب کٔر مٕژ زِ مکّس منٛز یُس تِہُند اہلِ عیا ل اوس سُہ گوٚژھ جنگ کِس مو قعس پٮ۪ٹھ محفو ظ روزُن ۔اَمہِ مو جو ب آو فر ما و نہٕ زِ ییٚمہِ آل اولادٕ خٲطرٕ ژےٚ یہِ کٲم کٔرِ تھ سُہ چُھنہٕ ٲخرتس منٛز بکار یِنہٕ وول ۔  تمہِ دۅہ ترٛا وِ اللہ تعالیٰ تۅہیہِ در میان جُدٲیی،یعنی دُنیا ہٕکۍ تمام رشتہٕ تعلقات تہٕ رابطہٕ یِن تَتہِ پُھٹراونہٕ۔ ہر کانٛہہ شخص سپدِ پننِس ذٲتی حیثیتس منٛز پیش تہٕ پرٛتھ کٲنٛسہِ آسہِ پننُے یوت حسا ب دِیُن۔لہٰذا پزِ نہٕ دُنیا ہس منٛز کٲنٛسہِ أکِس تہِ کُنہِ رشتہٕ دٲری یا دوستی یا جتّھ بند ی خٲطرٕ کانٛہہ نا جٲیز کٲم کرٕ نۍ، تِکیازِ پننہِ کرِ مَتِیُک سزا آسہِ تس پا نسٕے تُلُن،أمۍ سٕنزِ ذٲتی ذمہ دٲری منٛز سپدِ نہٕ بیٚیہِ کانٛہہ شر یک  تہٕ سُے چُھ تُہندٮ۪ن اعمالن ہُند وُچھن وول۔"
  60,4,"۔ تۅہیہِ لُکن خٲطرٕ چُھ ابراہیم علیہ السلام تہٕ تٔمۍ سٕندٮ۪ن سٲتھِیَن منٛز اکھ رُت نمو نہٕ، تِمو ووٚن پننِس قو مَس صا ف "أسۍ چِھ پورٕ پٲٹھۍ بے زارتۅہیہِ تہٕ تِمن تُہٕندٮ۪ن معبوٗدن یِم توٚہۍ اللہ تعالیٰ ترٲوِتھ پوٗزان چھوٗکھ، اسہِ کوٚر تۅہیہِ سٍتۍ کُفُر یعنی أسۍ چِھ تُہٕندۍ کٲفر ، أسۍ نہ چِھو توٚہۍ حقس پٮ۪ٹھ مانان تہٕ نہ تُہُند دین  تہٕ اسہِ تہٕ تۅہیہِ در میان گوٚو ہمیشہ خٲطرٕ عداوت تہٕ مُژُ کر ی،یوٚت تام نہٕ توٚہۍ کُنِس خدایس پٮ۪ٹھ ایمان أنِو۔" مگر ابراہیم علیہ السلام سُند پننِس مٲلِس یہِ وَنُن  چُھ امہِ نِشہِ مُستثنٰی  زِ " بہٕ کرٕ تُہند خٲطرٕ ضروٗر مغفر تُک در خوا ست، تہٕ خُدایس نِشہِ  کینٛہہ حٲصل کرُن چُھنہٕ مےٚ تام"۔ دوٚ یِمیٚن لفظن منٛز چُھ امیُک یہِ مطلب زِ تُہندِ خٲطرٕ چھےٚ حضر ت ابرا ہیم علیہ السلامن ہٕنز یہِ کتھ قٲبل تقلید زِ تِمو کوٚر پننِس مُشر ک تہٕ کٲفر قومس صاف صاف بے زٲری ہُنٛد تہٕ تعلق ژٹنُک اعلان،مگر تِہٕنز یہِ کتھ چھَنہٕ تقلیدس قٲبل زِ تِمَو کوٚر پننِس مشرک مٲلۍ سٕندِ خٲطرٕ دُعا کر نُک وعدٕہ تہٕ عملاً کوٚرُکھ تٔمۍ سٕندِس حقس منٛز دُعا۔تہٕ ابراہیم علیہ السلامن تہٕ اصحابِ ابراہیمن ہُند دعا اوس یہِ زِ " اے سانہِ ربّہٕ ، ژےٚ پٮ۪ٹھ کوٚر اَسہِ بھر و سہٕ تہٕ ژیے کُن کوٚر اَسہِ رجوع تہٕ چٲنۍ سٕے در بارس منٛز چُھ اسہِ واپس پھیرُن۔"
  60,5,"۔ اے سا نہِ ربّہٕ ، اسہِ مَہ بناو کٲفرن خٲطرٕ فِتنہٕ۔کٲفر ن خٲطرٕ اہلِ ایمانن ہٕندِس فِتنہٕ بَننَس ہیٚکن واریاہ صوٗرتہٕ ٲسِتھ ۔مثلاً یہِ زِ کٲفر یِن یِمن پٮ۪ٹھ غٲلب تہٕ پننِس غلبس دِن امہِ کتھہِ ہٕنز دلیل قرار زِ أسۍ چِھ حقس پٮ۪ٹھ تہٕ اہلِ ایمان چِھ برسرِ بٲطِل۔نَتہٕ یہِ زِ اہلِ ایمانن پٮ۪ٹھ بَڈِ کٲفر ن ہُند ظُلم و ستم تِہندِ برداشت کہ حدٕ کھۅتہٕ  ژوٚر ، تہٕ ٲخر کار ییٚلہِ تِم تِمن نِشہِ پھُٹن تہٕ پتہٕ گژھن پننہِ دین و اخلا قُک سودا کر نہٕ مۅکھہٕ مجبو ر۔ نَتہٕ یہِ زِ دین حق کِس نُما یند گی ہٕندِس بُلند مقا مس پٮ۪ٹھ فٲیز سپد نہٕ با وجود آسن اہلِ ایمان تمہِ اخلا قی فضیلت نِشہِ محروم یۅسہِ اَمہِ مُقا مہٕ خٲطرٕ شایانِ چھےٚ تہٕ دُنیا ہس یِن یِہندِ س سیر ت و کردارس منٛز تِمے عیب اَتھہِ یِم جٲہلیت کِس مُعا شرس منٛز عام پٲٹھۍ پٔھہلِتھ آسن۔امہِ سٍتۍ میلہِ کٲفر ن یہِ ونُک مو قع زِ اتھ دینس منٛز کیا خوبی چھےٚ ٲخر سۅ یۅ سہٕ اَتھ سٲنِس کُفرس پٮ۪ٹھ شر ف آسہِ عطا کران؟ تہٕ اے سانہِ ربّہٕ ، سانیٚن قصورن کردرگُزر، بے شک چُھکھ ژٕے زبردست تہٕ دانا۔""