quran[6]{c,v,t}:
  60,6,"۔یِمنٕے لُکن ہٕندِس طر زِ عملس منٛز چُھ تُہندِ خٲطرٕ بیٚیہِ پرٛتھ تس شخصس خٲطرٕ رُت نمو نہٕ، یُس اللہ تعالیٰ سُند تہٕ ٲخرت کہ دۅ ہُک اُمید وار آسہِ ۔ تہٕ اگر اَمہِ نِشہِ کانٛہہ بُتھ آسہِ پھِران، تیٚلہِ چُھ اللہ تعالیٰ بے نیاز تہٕ پننِس ذا تس منٛز چُھ پا نہٕ محمو د۔ع"
  60,7,"۔دوٗر چُھنہٕ زِ اللہ تعالیٰ تراوِ تۅہیہِ تہٕ تِمن لُکن در میان محبت یِمن سٍتۍ اَز تۅہیہِ دُشمنی چَھو موٚلۍ ہِیٔژ مٕژ۔﴿پٮ۪ٹھہٕ کنہِ کیٚن آیتن منٛز چھےٚ مُسلمانن پننیٚن کٲفر رِشتہٕ دارن سٍتۍ تعلق ژٹنُک تلقین کر نہٕ پتہٕ یہِ اُمید تہِ دِنہٕ آمٕژ زِ تِیُتھ وقت تہِ ہیٚکہِ یِتھ ییٚلہِ تُہٕندۍ یِمے رشتہٕ دار بنَن مسلمان ،تہٕ أزِچ دشمنی گژِھہ پتہٕ محبتس منٛز تبدیل ﴾ اللہ تعالیٰ چُھ قدرت تھا وان بیٚیہِ چُھ سُہ بخشن وول تہٕ رحم کر ن وول۔"
  60,8,"۔اللہ تعالیٰ چُھو نہٕ تۅہیہِ امہِ کتھہِ نِشہِ رُکاوان زِ یِمو دین کِس معا ملس منٛز تۅہیہِ سٍتۍ جنگ چُھنہٕ کوٚر مُت،تہٕ یِمو توٚہۍ چَھہَو نہٕ پننیو گھر و منٛز کٔڑِ مٕتۍ، زِ توٚہۍ کٔرِ و تِمن لُکن سٍتۍ نیکی تہٕ انصا فُک وَرتاو۔ اللہ تعالیٰ چُھ انصا ف کر ن والیٚن پسند کران، ﴿مطلب چُھ یہِ زِ یُس شخص تۅہیہِ سٍتۍ عداوت چُھنہٕ ورتاوان ، انصا فُک تقا ضہٕ چُھ یہِ زِ توٚہۍ تہِ مَہ ورتٲوِ و تَس سٍتۍ عداوت ۔دشمن تہٕ غیر دشمن أکِس در جس منٛز تھا وُن تہٕ دۅ شوٕنۍ سٍتۍ اَکوے سلو ک کرُن چُھنہٕ انصا ف ۔ تۅہیہِ چُھو تِمن لُکن سٍتۍ سخت رٔوِیہِ ورتا و نُک حق، یِمو ایمان اننہٕ کِس پا داشس منٛز تۅہیہِ پٮ۪ٹھ ظُلم کٔرۍ تہٕ توٚہۍ کٔرِ ہَو وطنہٕ منٛز نیرنس پٮ۪ٹھ مجبور،تہٕ وطنہٕ منٛزٕ نیر نہٕ پتہٕ تہِ روٗدِو تِم پتے۔مگر یِمو لُکو اتھ ظُلمس منٛز حصّہ نیوٗو نہٕ ، انصا ف چُھ یہِ زِ توٚہۍ کٔرِو تِمن سٍتۍ رُت برتا و ،تہٕ رشتہٕ تہٕ برداری ہٕندِ لحا ظہٕ یِم تِہِندۍ حقوق تۅہیہِ پٮ۪ٹھ چِھ عٲید سپدان تِم ادا کر نس منٛز مَہ کٔرِو کمی۔﴾"
  60,9,"۔ سُہ ییٚمہِ کتھہِ نِشہِ تۅہیہِ رُکاوان چُھ، سۅ چھےٚ یہِ زِ یِمو دین کِس معا ملس منٛز تۅہیہِ سٍتۍ جنگ چُھ کوٚر مُت ،تہٕ  توٚہۍ چَھہَو تُہند یو گھر و منٛزٕ کٔڑِتھ ژٕ ھنِمٕتۍ، تہٕ تُہندِ س کڑنس منٛز چُھکھ اکھ أکِس مدد کوٚر مُت زِ توٚہۍ کٔرِو تِمن لُکن سٍتۍ دوستی۔ تِمن سٍتۍ یِم لُکھ دوستی کر ن تِمے چِھ ظٲلِم۔"
  60,10,"۔اے لوٗکو یِمو ایمان چُھو اوٚنمُت،ییٚلہِ مو من مستوٗراتہٕ ہجرت کٔرِ تھ تۅہیہِ نِشہِ یِن،تیٚلہِ کٔرِو ﴿ تِہندِ مو من آسنُک تحقیق،تہٕ تِہندِ ایمانٕچ حقیقت چُھ بس اللہ تعالیٰ بہتر زانان۔پتہٕ ییٚلہِ تۅہیہِ پے لگیو تِمہٕ چھےٚ مو من، تیٚلہِ مَہ کٔرِ یوٗکھ تِمہٕ کُفّارن کُن واپس ۔﴿صلح حُدیبیہ پتہٕ روٗدۍ گۅڈٕہ گۅڈٕ ہ مُسلمان مَرد مکّہ پٮ۪ٹھہٕ مدینس کُن ژٔلۍ ژٔلۍ یِوان تہٕ تِم ٲسۍ معا ہدٕہ کیو شرٲیطو مُطا بق واپس یِوان کر نہٕ ۔پتہٕ گوٚو مُسلمان مستوٗراتن ہٕندِ یِنُک سلسلہٕ شروع،تہٕ کٲفرو کوٚر معا ہدُک حوالہٕ دِتھ تِہنزِ واپسی ہُند تہِ مُطا لبہٕ۔اتھ پٮ۪ٹھ سپُد یہِ سوال پٲدٕ زِ کیا معا ہدُک اطلاق چھا مستوٗراتن پٮ۪ٹھ تہِ سپدان؟ خُداین چُھ اَمی سوالُک جواب یتھ جایہِ دِ یتمُت زِ اگر تِمہٕ مُسلمان آسن تہٕ اَمِیُک یِیہِ اطمنان کر نہٕ زِ پٔزِ پٲٹھۍ چھےٚ تِمہٕ ایمان خٲطرٕ ے ہجرت کٔرِتھ آمژٕ،بیٚیہِ کُنہِ چیزن چَھنہٕ تِمہٕ اَنہِ مژٕ، تِمہٕ گژھن نہٕ واپس یِنہِ کر نہٕ ۔ یہِ حکم آو اَتھ بِنا ہس پٮ۪ٹھ دِنہٕ زِ معا ہدٕ کۍ یِم شرٲیط لیٛکھنہٕ ٲسۍ آمٕتۍ تِمن منٛز اوس رَجُلّ ﴿مرد﴾ لفظ لیٛکھنہٕ آمُت یِتھہٕ پٲٹھۍ زَن بخا ری ہٕندِس روایتس منٛز چُھ آمُت۔﴾ نَہ چھےٚ تِمہٕ کٲفر ن خٲطرٕ حلال تہٕ نَہ چِھ کٲفر تِہندِ خٲطرٕ۔تِہند یو کٲفر خا ندارَو یِم مَہر تِمن دِتۍ مٕتۍ ٲسۍ تِم کٔرِ و تِمن واپس۔تہٕ تِمن سٍتۍ نکا ح کر نس چُھنہٕ تۅہیہِ پٮ۪ٹھ کانٛہہ گناہ، ییٚلہِ زَن توٚہۍ تِہندۍ مَہر کٔرِو تِمن ادا۔ ﴿ مطلب چُھ یہِ زِ تِہند ٮ۪ن کٲفر خا ندارن یِم مَہر تِمن واپس یِن سوزنہٕ، تِمے یِن نہٕ یِہِندۍ مَہر شُمار کرنہٕ بلکہ وۅ نۍ یُس مُسلمان تہِ یِمو منٛزٕکٲنٛسہِ خا تونہِ سٍتۍ نکا ح ییژِھہ کرُن ،سُہ دِیِن تس مَہر تہٕ کٔرِن نکا ح۔﴾تہٕ پانہٕ تہِ مَہ تھٲوِیوٗکھ توٚہۍ کٲفر زنانہٕ پننِس نِکا حس منٛز رُکٲوِتھ ۔یِم مَہر تۅہیہِ پننیٚن کٲفر خا ندارِ نیٚن دِتِمٕتۍ ٲسِو، تِمن مٔنگِو تِم واپس، تہٕ یِم مہر کٲفرو ٲسۍ پننین مسلمان خاندارنین دِتۍ مٕتۍ تِم مٔنگِن تِمن واپس، یہِ چُھ اللہ تعالیٰ سُند حُکم ،سُہ چُھ تۅہیہِ در میان فٲصلہٕ کران، تہٕ سُہ چُھ زانن وول تہٕ حکمت وول۔"
  60,11,"۔تہٕ اگر تُہنز و کٲفر خاندارِ نیو ہٕند یو مَہر و منٛزٕ کٲفر ن نِشہِ تۅہیہِ کینٛہہ واپس میلہِ نہٕ، تہٕ پتہٕ واتہِ تُہنزٕ نو بت تیٚلہِ یِمن لُکن ہٕنزٕ خا ندارِنہِ تور چھےٚ روز مژٕ، تِمن  کٔرِو تیوٗتاہ رقم ادا یُس تِہندٮ۪ن دِنہٕ آمتیٚن مَہر ن یوت آسہِ۔ تہٕ تس خُدایس روٗزِ و کھۅژان یَس پٮ۪ٹھ تۅہیہِ ایمان چُھو اوٚنمُت۔"