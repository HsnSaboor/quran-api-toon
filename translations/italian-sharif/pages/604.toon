quran[15]{c,v,t}:
  112,1,"Di’: “Lui, Allāh è l’Unico."
  112,2,"Allāh è l`Assoluto!"
  112,3,"Mai generò, né fu generato"
  112,4,"né Gli è pari nessuno»."
  113,1,"Di’: «Mi rifugio presso il Dio dell’albore"
  113,2,"dal male di ciò che ha creato,"
  113,3,"e dal male della notte quando si estende,"
  113,4,"e dalle azioni malvagie delle streghe,"
  113,5,"e dal male dell’invidioso quando invidia!”"
  114,1,"Di’: „Mi rifugio presso il Dio degli uomini,"
  114,2,"Sovrano degli uomini,"
  114,3,"Divinità degli uomini,"
  114,4,"dal male del subdolo Tentatore,"
  114,5,"che mormora nel petto degli uomini,"
  114,6,"dei demoni e degli uomini!”"