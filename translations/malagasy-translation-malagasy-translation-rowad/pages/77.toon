quran[50]{c,v,t}:
  77,1,"Mianiana amin'ireo nalefa nifanesy Aho."
  77,2,"Izay mifofofofo mafy !"
  77,3,"Ary niparitaka tanteraka (tamin'ny toerana rehetra)."
  77,4,"Mianiana amin'ireo mpanasaraka mazava (ny tsara sy ny ratsy) Aho,"
  77,5,"Izay mandefa fampahatsiarovana."
  77,6,"ho fialan-tsiny, na ho fampitandremana !"
  77,7,"fa tsy azo ialana izay nampanantenana anareo."
  77,8,"Rahoviana àry vao ho voafafa ireo kintana,"
  77,9,"ary hitriatra ny lanitra ?"
  77,10,"ka ho levona ireo tendrombohitra."
  77,11,"ary voafaritra ny fotoanan'ireo Iraka."
  77,12,"Andro inona àry no nanemorana izany ?"
  77,13,"Amin'ny andron'ny fanapahan-kevitra !"
  77,14,"Fa iza no hilaza aminao ny andron'ny fanapahan-kevitra !"
  77,15,"Loza ho an'ireo izay mpandà izany andro farany izany."
  77,16,"Moa tsy naringanay va ireo voalohany ?"
  77,17,"Moa tsy nampanarahanay azy ireo va ireo farany,"
  77,18,"toy izany no ataonay amin'ireo mpanao ratsy."
  77,19,"loza ho an'ireo izay mpandà izany andro farany izany."
  77,20,"Tsy noharianay tamin'ny tsiranoka ratsy va ianareo,"
  77,21,"izay napetrakay tamin'ny toerana voaaro,"
  77,22,"nandritra ny fotoana efa fantatra ?"
  77,23,"Toy izany no nandaharanay azy, fa tonga lafatra tokoa ny fandaharana ataonay."
  77,24,"loza ho an'ireo izay mpandà izany andro farany izany."
  77,25,"Tsy nataonay toerana hipetrahan'ny rehetra ve ny tany ?"
  77,26,"ireo velona, sy ireo maty ?"
  77,27,"Ary tsy nataonay mafy orina tsara va, ireo tendrombohitra avo eo aminy ? Ary tsy nampisotronay ranomamy va ianareo ?"
  77,28,"loza ho an'ireo izay mpandà izany andro farany izany."
  77,29,"Mandehana àry any amin'izay nolazainareo ho lainga."
  77,30,"mandehana any amin'ny aloka misy rantsana telo,"
  77,31,"izahay sady tsy manaloka, no sady tsy miaro amin'ny lel'afo."
  77,32,"satria hatsipy ny pitik'afo lehibe, tahaka ny lapa."
  77,33,"ka ho toy ny rameva mavo."
  77,34,"loza ho an'ireo izay mpandà amin'izany andro farany izany."
  77,35,"ilay andro izay tsy hahafahan'izy ireo miteny,"
  77,36,"ary tsy hahazoan'izy ireo alalana hiala tsiny."
  77,37,"loza ho an'ireo izay mpandà an'izany andro farany izany."
  77,38,"Io no andron'ny fanapahan-kevitra, izay hamorianay anareo sy ireo taloha."
  77,39,"Raha manana hafetsena ianareo, dia manaova àry hafetsena Amiko."
  77,40,"loza ho an'ireo izay mpandà izany andro farany izany."
  77,41,"ho amin'ny aloka sy loharano tokoa ireo vonto-pinoana,"
  77,42,"ao koa ireo voankazo arak'izay irin'izy ireo."
  77,43,"Mihinàna sy misotroa finaritra àry ianareo, noho izay nataonareo."
  77,44,"Toy izany no Hamalinay soa ireo mpanao soa."
  77,45,"loza ho an'ireo izay mpandà an'izany andro farany izany."
  77,46,"Mihinàna, ary mifalia kely ; fa mpanao ratsy tokoa ianareo."
  77,47,"loza ho an'ireo izay mpandà an'izany andro farany izany."
  77,48,"ka rehefa tenenina izy ireo hoe : ""Miondreha ianareo"", dia tsy miondrika izy ireo."
  77,49,"loza ho an'ireo izay mpandà izany andro farany izany."
  77,50,"Fa inona àry no teny hinoan'izy ireo ankoatr'izany ?"
