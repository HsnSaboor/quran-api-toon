quran[11]{c,v,t}:
  93,1,"Mianiana Aho amin'ny misandratr'andro."
  93,2,"Sy ny amin'ny alina mikitroka."
  93,3,"Fa tsy nandao sy tsy nankahala anao ny Tomponao,"
  93,4,"Ny fiainana any ankoatra dia tsara lavitra ho anao nohon'ny fiainana eto an-tany."
  93,5,"Hanome fahasoavana ho anao ny Tomponao ka dia ho afa-po tokoa ianao noho izany."
  93,6,"Moa va tsy hitany tao anatin'ny fahakambotiana ianao ka tsy noraisiny ?"
  93,7,"Hitany tao anaty fahaverezana ianao ka dia notarihiny."
  93,8,"ary hitany tao anatin'ny fahantrana lalina ianao ka dia nomeny ny ampy."
  93,9,"Koa aza manao tsindry hazo lena ny kamboty."
  93,10,"Ary aza atosi-boho-tanana ny mpangataka,"
  93,11,"Fa lazao kosa ireo fahasoavan'ny Tomponao."
