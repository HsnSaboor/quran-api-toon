quran[8]{c,v,t}:
  95,1,"Mianiana Aho amin'ny aviavy sy ny hazon'oliva."
  95,2,"Sy amin'ny tendrombohitra Sinay."
  95,3,"Amin'ity tanàna mandry fahalemana ity."
  95,4,"Fa noharianay ho tonga lafatra tokoa ny olombelona."
  95,5,"Ary naverinay any amin'ny farany ambany indrindra."
  95,6,"afa-tsy izay nino sy nanao asa soa no tsy hitsahatra ka hahazo valisoa tsy manam-petra."
  95,7,"Koa raha izany ary, inona no andainganao ny Andro farany ?"
  95,8,"Moa tsy Allah va no mpitsara mendrika indrindra?"
