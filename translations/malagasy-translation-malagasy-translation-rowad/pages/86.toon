quran[17]{c,v,t}:
  86,1,"Mianiana amin’ny lanitra, sy amin’ny kintana fitarik’andro Aho."
  86,2,"Moa mba fantatrao va izany kintana fitarik’andro izany?"
  86,3,"Ilay kintana feno famirapiratana."
  86,4,"Eny! Tsy misy fanahy ka tsy manana mpiambina,"
  86,5,"Koa tokony handinika ny olombelona, avy amin'inona tokoa moa no nahariana azy?"
  86,6,"Nohariana avy amin'ny ranon'aina mifantsitsitra izy."
  86,7,"izay mivoaka avy eo anelanelan'ny taolan-damosina sy ny tehezana."
  86,8,"tena marina fa Izy Allah dia mahafehy amin'ny fananganana azy amin'ny maty,"
  86,9,"amin'ny Andro izay hamborahana ireo miafina rehetra tao am-po,"
  86,10,"ka tsy hananan'ny olombelona hery sy mpamonjy,"
  86,11,"Mianiana Aho amin'ny lanitra izay mampisy ny orana,"
  86,12,"sy ny tany izay mampitsiry ireo zava-maniry,"
  86,13,"fa ny Koroany masina dia teny manavaka ny marina amin'ny lainga,"
  86,14,"ary tsy vazivazy tsy misy fotony velively akory,"
  86,15,"Mampiasa ny hafetsen-dratsiny tokoa izy ireo (ireo tsy mpino),"
  86,16,"Izaho koa anefa dia mamaly azy ireo ny amin'izany,"
  86,17,"Koa omeo fe-potoana ireo tsy mpino, fe-potoana kely ihany."
