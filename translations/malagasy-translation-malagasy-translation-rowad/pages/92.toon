quran[21]{c,v,t}:
  92,1,"Mianiana Aho amin'ny alina mikitroka,"
  92,2,"Amin'ny andro rehefa miposaka mamiratra izy,"
  92,3,"Amin'ny nahariana ny lahy sy ny vavy."
  92,4,"Fa raha ny tena marina, ny asanareo dia samihafa,"
  92,5,"Ary ho an'ilay malala-tanana sy manam-patahorana an'I Allah."
  92,6,"Ary manamarina ny fisian'ny valisoa tsara indrindra."
  92,7,"Ary ho amorako ho azy ireo ny lalana mankany amin'ny fahamorana."
  92,8,"Fa ho an'ireo izay kahihitra sy miseho ho mahavita tena kosa."
  92,9,"Ary mandà ny fisian'ny valisoa tsara indrindra,"
  92,10,"Dia ho amorako ho azy ireo ny lalana mankany amin'ny fahasarotana."
  92,11,"Ary tsy hahavita na inona aminy ny hareny rehefa hatsipy ao anaty Afobe izy."
  92,12,"Tena adidinay tokoa ny fitarihana."
  92,13,"Anay tanteraka ny fiainana eto an-tany sy any ankoatra."
  92,14,"Noho izany dia efa nampitandremako ilay afo milelalela ianareo."
  92,15,"Ka tsy handoro afa-tsy ireo voahozona,"
  92,16,"Dia izay tsy nino sy nandà izany."
  92,17,"Ary hanalavitra izany kosa ny be fahatahorana an'i Tompo Allah."
  92,18,"Dia izay manome ny hareny mba hanadiovana ny fanahiny,"
  92,19,"Ary tsy misy na iza na iza eo anatrehany ka ahazo valim-pahasoavana."
  92,20,"Afa-tsy nohon'ny fikatsahana ny tavan'ny Tompony Avo indrindra irery ihany."
  92,21,"Eny ! Ho afa-po tsy ho ela izy."
