quran[8]{c,v,t}:
  102,1,"Variana amin'ny fanangonan-karena tokoa ianareo."
  102,2,"Eny , mandra-pahatongavanareo ao am-pasana."
  102,3,"Tsia , mbola ho fantatrareo !"
  102,4,"Eny , mbola ho fantatrareo marimarina tokoa !"
  102,5,"Raha toa ka fantatrareo am-pahalalana marina."
  102,6,"dia ho hitanareo tokoa ny afobe"
  102,7,"ka ho hatrehin’ny masonareo marina izany."
  102,8,"Ka amin'izany fotoana izany dia tsy maintsy hanontaniana ny amin'ireo harena maro be ianareo."
