quran[26]{c,v,t}:
  88,1,"Moa ve tonga taminao ny tantaran'ilay mpandrakotra?"
  88,2,"hisy endrika amin'izay fotoana izay ho ao anatin'ny fahatahorana,"
  88,3,"sahirana sy torovana,"
  88,4,"ka ho dorana ao anaty afo miredareda,"
  88,5,"hampisotroina avy amin'ny loharano mangotraka,"
  88,6,"ary tsy hanan-tsakafo afa tsy karazan-tsilo izy ireo."
  88,7,"ka tsy hampatavy azy ireo izany no koa tsy hanala ny hanoanana,"
  88,8,"hisy koa ireo endrika amin'izay fotoana izay ho ao anatin'ny fiadanana,"
  88,9,"faly tamin'ny ezaka vitany,"
  88,10,"hiditra ny Paradisa mendrika tokoa,"
  88,11,"ka tsy haheno ao anatin'izany ireo teny maloto,"
  88,12,"hita ao anatin'izany koa ny loharano mikoriana,"
  88,13,"fandriana avo toerana,"
  88,14,"ary kaopy efa voahomana,"
  88,15,"ireo ondana tsara lahatra,"
  88,16,"ireo lamaka mivelatra,"
  88,17,"moa tsy nodinihin'izy ireo ny rameva, ahoana ny fomba nahariana azy?"
  88,18,"ary ny lanitra, nanao ahoana ny fomba nampiakarana azy?"
  88,19,"Ireo ny tendrombohitra, nanao ahoana ny fomba nametrahana azy?"
  88,20,"ary ny tany, ahoana ny fomba nampitoviana azy?"
  88,21,"Koa mampahatsiahiva ! Fa raha ny tena marina dia mpampahatsiahy ihany ianao."
  88,22,"Fa tsy mpifehy azy ireo ianao."
  88,23,"afa-tsy izay manome lamosina sy mpikomy."
  88,24,"Satria Allah dia hanasazy azy amin'ny famaizana mafy tokoa."
  88,25,"Tena marina! Any Amiko no hiverenan'izy ireo indray."
  88,26,"Ary eo am-pelatanako ny fitsaràna azy ireo."
