quran[19]{c,v,t}:
  87,1,"Ankalazao ny anaran'ny Tomponao, ilay Avo indrindra!"
  87,2,"izay nahary sy nandavorary,"
  87,3,"Ilay nandahatra sy nitantana,"
  87,4,"Izay nampitsiry ny vilona,"
  87,5,"ka nanao izany ho maina sy malazo avy eo,"
  87,6,"hampamakianay ianao mba tsy hanadino,"
  87,7,"afa-tsy izay sitrak'I Allah ho hadinonao ihany satria Izy no mahalala ny mibaribary sy izay miafina,"
  87,8,"Eny! Hotarihiko ianao ho any amin'ny lalan'ny fahamorana,"
  87,9,"Ary mampahatsiahiva ! Raha toa ka ilaina ny fampahatsiahivana."
  87,10,"fa hahatsiaro izany izay manam-pahatahorana"
  87,11,"Hanalavitra izany kosa ireo olon'ny fijaliana,"
  87,12,"izay ho dorana amin'ny afo be,"
  87,13,"avy eo dia sady tsy ho faty izy ireo ao no sady tsy ho velona ihany koa!"
  87,14,"Nahazo fandresena tokoa izay manadio ny tenany,"
  87,15,"sy nahatsiaro ny anaran'ny Tompony ka nivavaka,"
  87,16,"nefa indrisy! Ankafizinareo kokoa ny fiainana ety an-tany,"
  87,17,"kanefa ny fiainana any ankoatra dia tsara lavitra no mandrakizay."
  87,18,"Izany rehetra efa voalaza tamin’ireo rakitsoratra Masina teo aloha,"
  87,19,"dia ny rakitsoratr’i Abrahama sy ny an’i Mosesy"
