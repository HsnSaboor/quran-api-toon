quran[7]{c,v,t}:
  107,1,"Tahukah kamu (orang) yang mendustakan agama?"
  107,2,"Maka itulah orang yang menghardik anak yatim,"
  107,3,"dan tidak mendorong memberi makan orang miskin."
  107,4,"Maka celakalah orang yang salat,"
  107,5,"(yaitu) orang-orang yang lalai terhadap salatnya,",footnotes:308232:1
  107,6,"yang berbuat riya’,",footnotes:308236:1
  107,7,"dan enggan (memberikan) bantuan.",footnotes:308240:1
