quran[64]{c,v,t}:
  84,1,İzessemaunşakkat
  84,2,Ve ezinet lirabbiha ve hukkat
  84,3,Ve izel´ardu muddet
  84,4,Ve elkat ma fiyha ve tehallet
  84,5,Ve ezinet lirabbiha ve hukkat
  84,6,Ya eyyuhel´insanu inneke kadihun ila rabbike kedhan femulakıyhi
  84,7,Femma men utiye kitabehu biyemiynihi
  84,8,Fesevfe yuhasebu hısaben yesiyren
  84,9,Ve yenkalibu ila ehlihi mesruren
  84,10,Ve emma men utiye kitabehu verae zahrihi
  84,11,Fesevfe yed´u suburen
  84,12,Ve yasla se´ıyren
  84,13,İnnehu kane fiy ehlihi mesruren
  84,14,İnnehu zanne en len yehure
  84,15,Bela inne rabbehu kane bihi basıyren
  84,16,Fela uksimü bişşefekı
  84,17,Velleyli ve ma veseka
  84,18,Velkameri izetteseka
  84,19,Leterkebunne tabekan ´an tabekın
  84,20,Femalehum la yu´minune
  84,21,Ve iza kurie ´aleyhimülkur´anu la yescudune
  84,22,Belilleziyne keferu yukezzibune
  84,23,Vallahu a´lemu bima yu´une
  84,24,Febeşşirhüm bi´azabin eliymin
  84,25,İllelleziyne amenu ve ´amilussalihati lehum erun gayru memnunin
  85,1,Vessemai zatilbüruci
  85,2,Velyevmilmev´udi
  85,3,Ve şahidin ve meşhudin
  85,4,Kutile ashabül´uhdudi
  85,5,En nari zatelvekudi
  85,6,İz hüm ´aleyha ku´udün
  85,7,Ve hüm ´ala ma yef´alune bilmü´miniyne şühudün
  85,8,Ve ma nekamu minhüm illa en yü´minu billahil´aziyzilhamiydi
  85,9,Elleziy lehu mülküssemavati vel´ardı vallahü ´ala külli şey´in şehiydün
  85,10,İnnelleziyne fetenülmü´miniyne velmü´minati sümme lem yetubu felehüm ´azabü cehenneme ve lehüm ´azabülhariykı
  85,11,İnnelleziyne amenu ve ´amilussalihati lehüm cennatün tecriy min tahtihel´enharü zalikelfevzülkebiyrü
  85,12,İnne batşe rabbike leşediydün
  85,13,İnnehu hüve yübdiü ve yü´ıydü
  85,14,Ve hüvelğafurülvedudü
  85,15,Zül´arşilmeciydü
  85,16,Fa´´alün lima yüriydü
  85,17,Hel etake hadiysülcünudi
  85,18,Fir´avne ve semude
  85,19,Belilleziyne keferu fiy tekziybin
  85,20,Vallahü min veraihim muhıytun
  85,21,Bel hüve kur´anün meciydün
  85,22,Fiy levhın mahfuzın
  86,1,Vessemai vettarikı
  86,2,Ve ma edrake mettariku
  86,3,Ennecmüssakıbü
  86,4,İn küllü nefsin lemma ´aleyha hafizun
  86,5,Felyenzuril´insanü mimme hulika
  86,6,Hulika min main dafikın
  86,7,Yahrücü min beynissulbi vetteraibi
  86,8,İnnehu ´ala rec´ıhı lekadirün
  86,9,Yevme tüblesserairü
  86,10,Fema lehu min kuvvetin ve la nasırin
  86,11,Vessemai zatirrec´ı
  86,12,Vel´ardı zatissad´ı
  86,13,İnnehu likavlün faslün
  86,14,Ve ma hüve bilhezli
  86,15,İnnehüm yekiydune keyden
  86,16,Ve ekiydü keyden
  86,17,Femehhililkafiriyne emhilhüm rüveyden