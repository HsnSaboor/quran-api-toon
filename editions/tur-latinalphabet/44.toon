quran[59]{c,v,t}:
  44,1,Ha mım
  44,2,Vel kitabil mübiyn
  44,3,İnna enzelnahü fı leyletim mübaraketin inna künna münzirın
  44,4,Fıha yüfraku küllü emrin hakiym
  44,5,Emram min ındina inna künna mürsiliyn
  44,6,Rahmeten mir rabbik innehu hüves semiy´ul aliym
  44,7,Rabbis semavati vel erdı ve ma beynehüma in küntüm mukıniyn
  44,8,La ilahe illa hüve yuhyı ve yümiyt rabbüküm ve rabbü abaikümül evveliyn
  44,9,Bel hüm fı şekkiy yel´abun
  44,10,Fertekıb yevme te´tis semaü bi dühanim mübiyn
  44,11,Yağşen nas haza azabün eliym
  44,12,Rabbenekşif annel azabe inna mü´minun
  44,13,Enna lehümüz zikra ve kad caehüm rasulüm mübiyn
  44,14,Sümme tevellev anhü ve kalu muallemüm mecnun
  44,15,İnna kaşifül azib kaliylen inneküm aidun
  44,16,Yevme nebtışül batşetel kübra inna müntekımun
  44,17,Ve le kad fetenna kablehüm kavme fir´avne ve caehüm rasulün keriym
  44,18,En eddu ileyye ıbadellah inni leküm rasulün emiyn
  44,19,Ve el la ta´lu alellah innı atıküm bi sültanim mübiyn
  44,20,Ve innı uztü bi rabbı ve rabbiküm en tercumun
  44,21,Ve il lem tü´minu lı fa´tezilun
  44,22,Fe dea rabbehu enne haülai kavmüm mücrimun
  44,23,Fe esri bi ıbadı leylen inneküm müttebeun
  44,24,Vetrukil bahra rahva innehüm cündüm muğrakun
  44,25,Kem teraku min cennativ ve uyun
  44,26,Ve züruıv ve mekamin keriym
  44,27,Ve na´metin kanu fiyha fakihiyn
  44,28,Kezalike ve evrasnaha kavmen ahariyn
  44,29,Fema beket aleyhimüs semaü vel erdu vema kanu münzariyn
  44,30,Ve le kad necceyna benı israiyle minel azabil mühiyn
  44,31,Min fir´avn innehu kane aliyem minel müsrifiyn
  44,32,Ve lekadıhternahüm ala ılmin alel alemiyn
  44,33,Ve ateynahüm minel ayati ma fıhi belaüm mübiyn
  44,34,İnne haülai le yekülün
  44,35,İn hiye illa mevtetünel ula ve ma nahnü bi münşeriyn
  44,36,Fe´tu bi abaina in küntüm sadikıyn
  44,37,E hüm hayrun em kamü tübbeıv vellezıne min kablihim ehleknahüm innehüm kanu mücrimiyn
  44,38,Ve ma halaknes semavati vel erda ve ma beynehüma laıbiyn
  44,39,Ma halaknahüma illa bil hakkı ve lakinne ekserahüm la ya´lemun
  44,40,İnne yevmel fasli mıkatühüm ecmeıyn
  44,41,Yevme la yuğni mevlen ammevlen şey´ev ve la hüm yünsarun
  44,42,İlla mer rahımellah innehu hüvel aziyzür rahıym
  44,43,İnne şeceratez zekkum
  44,44,Taamül esiym
  44,45,Kel mühl yağlı fil bütun
  44,46,Ke ğalyil hamiym
  44,47,Huzuhü fa´tiluhü ila sevail cehıym
  44,48,Sümme subbu fevka ra´sihı min azabil hamiym
  44,49,Zuk inneke entel aziyzül keriym
  44,50,İnne haza ma küntüm bihı temterun
  44,51,İnnel müttekıyne fı mekamin emiyn
  44,52,Fi cennativ ve uyun
  44,53,Yelbesune min sündüsiv ve istebrakım mütekabiliyn
  44,54,Kezali ve zevvecnahüm bi hurin ıyn
  44,55,Yed´une fiha bi külli fakihetin aminiyn
  44,56,La yezukune fiyhel mevte illel mevtetel ula ve vekahüm azabel cehıym
  44,57,Fadlem mir rabbik zalike hüvel fevzül azıym
  44,58,Fe innema yessernahü bi lisanike leallehüm yetezekkerun
  44,59,Fertekıb innehüm mirtek