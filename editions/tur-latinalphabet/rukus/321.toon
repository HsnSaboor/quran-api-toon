quran[18]{c,v,t}:
  26,105,Kezzebet kavmü nuhınil murselın
  26,106,İz kale lehüm ehuhüm nuhun ela tettekun
  26,107,İnni leküm rasulün emın
  26,108,Fettekullahe ve etıy´un
  26,109,Ve ma es´elüküm aleyhi min ecr in ecriye illa ala rabbil alemın
  26,110,Fettekullahe ve etıy´un
  26,111,Kalu enü´minü leke vettebeakel erzelun
  26,112,Kale vema ılmı bima kanu ya´melun
  26,113,İn hısabühüm illa ala rabbı lev teş´urun
  26,114,Ve ma ene bi taridil mü´minın
  26,115,İn ene illa nezırum mübın
  26,116,Kalu le il lem tentehi ya nuhu le tekunenne minel mercumın
  26,117,Kale rabbi inne kavmı kezzebun
  26,118,Fettah beynı ve beynehüm fethav ve neccinı ve mem meıye minel mü´minın
  26,119,Fe enceynahü ve mem meahu fil fülkil meşhun
  26,120,Sümme ağrakna ba´dül bakıyn
  26,121,İnne fı zalik le ayeh ve ma kane ekseruhüm mü´minın
  26,122,Ve inne rabbeke le hüvel azızür rahıym