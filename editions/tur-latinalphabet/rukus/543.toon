quran[11]{c,v,t}:
  101,1,El kariah
  101,2,Mel kariah
  101,3,Ve ma edrake mel kariah
  101,4,Yevme yekunün nasü kelferaşil mebsus
  101,5,Ve tekunül cibalü kelıhnil menfuş
  101,6,Fe emma men sekulet mevazınüh
  101,7,Fe hüve fi ıyşetir radıyeh
  101,8,Ve emma men haffet mevazınüh
  101,9,Fe ümmühu havıyeh
  101,10,Ve ma edrake mahiyeh
  101,11,Narun hamiyeh