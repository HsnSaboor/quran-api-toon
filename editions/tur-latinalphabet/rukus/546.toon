quran[9]{c,v,t}:
  104,1,Veylül li külli hümezetil lümezeh
  104,2,Ellezıcemea malev ve addedeh
  104,3,Yahsebü enne malehu ahledeh
  104,4,Kella le yümbezenne fil hutameh
  104,5,Ve ma edrake mel hutameh
  104,6,Narullahil mukadeh
  104,7,Elleti tettaliu alel ef´ideh
  104,8,İnneha aleyhim mü´sadeh
  104,9,Fi amedim mümeddedeh