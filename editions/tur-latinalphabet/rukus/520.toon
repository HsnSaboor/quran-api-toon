quran[26]{c,v,t}:
  79,1,Vennazi´ati ğarken
  79,2,Vennaşitati neştan
  79,3,Vessabihati sebhan
  79,4,Fessabikati sebkan
  79,5,Felmudebbirati emren
  79,6,Yevme tercufurracifetu
  79,7,Tetbe´uherradifetu
  79,8,Kulubun yevmeizin vacifetun
  79,9,Ebsaruha haşi´atun
  79,10,Yekulune einna lemerdudune fiylhafireti
  79,11,Eiza kunna ´ızamen nehıreten
  79,12,Kalu tilke izen kerretun hasiretun
  79,13,Feinnema hiye zecretun vahıdetun
  79,14,Feiza hum bissahireti
  79,15,Hel etake hadiysu musa
  79,16,İz nadahu rabbuhu bilvadilmukaddesi tuven
  79,17,İzheb ila fir´avne innehu tağa
  79,18,Fekul hel leke ila en tezekka
  79,19,Ve ehdiyeke ila rabbike fetahşa
  79,20,Feerahul´ayetelkubra
  79,21,Fekezzebe ve ´asa
  79,22,Summe edbere yes´a
  79,23,Fehaşere fenada
  79,24,Fekale ene rabbukumul´a´la
  79,25,Feehazehullahu nekalel´ahıreti vel´ula
  79,26,İnne fiy zalike le´ubreten limen yahşa