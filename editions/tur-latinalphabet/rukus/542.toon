quran[11]{c,v,t}:
  100,1,Vel adiyati dabha
  100,2,Fel muriyati kadha
  100,3,Fel muğırati subha
  100,4,Fe eserne bihı nak´a
  100,5,Fe vesatne bihı cem´a
  100,6,İnnelinsane li rabbihı le kenud
  100,7,Ve innehu ala zalike le şehıd
  100,8,Ve innehu li hubbil hayri le şedıd
  100,9,E fe la ya´lemü iza bu´sira ma fil kubur
  100,10,Ve hussıle ma fis sudur
  100,11,İnne rabbehüm bihim yevmeizin le habir