quran[8]{c,v,t}:
  99,1,İza zülziletil erdu zilzaleha
  99,2,Ve ahracetilerdu eskaleha
  99,3,Ve kalel insanü ma leha
  99,4,Yevmeizin tühaddisü ahbaraha
  99,5,Bienne rabbeke evha leha
  99,6,Yevmeiziy yasdürun nasü eştatel li yürav a´malehüm
  99,7,Fe mey ya´mel miskale zerratin hayray yerah
  99,8,Ve mey ya´mel miskale zerratin şerray yerah