quran[31]{c,v,t}:
  79,16,ÄḞz nadahu rabbuhu bilvadilmukaddesi tuven
  79,17,ÄḞzheb ila firÂṀavne innehu taÄa
  79,18,Fekul hel leke ila en tezekka
  79,19,Ve ehdiyeke ila rabbike fetahÅa
  79,20,FeerahulÂṀayetelkubra
  79,21,Fekezzebe ve ÂṀasa
  79,22,Summe edbere yesÂṀa
  79,23,FehaÅere fenada
  79,24,Fekale ene rabbukumulÂṀaÂṀla
  79,25,Feehazehullahu nekalelÂṀahÄḟreti velÂṀula
  79,26,ÄḞnne fiy zalike leÂṀubreten limen yahÅa
  79,27,Eentum eÅeddu halkan emissemaÂṀu benaha
  79,28,RefeÂṀa semkeha fesevvaha
  79,29,Ve aÄtaÅe leyleha ve ahrece duhaha
  79,30,VelÂṀarda baÂṀde zalike dehaha
  79,31,Ahrece minha aeha ve merÂṀaha
  79,32,Velcibale ersaha
  79,33,MetaÂṀan lekum ve lienÂṀamikum
  79,34,Feiza caetittammetulkubra
  79,35,Yevme yetezekkerulÂṀinsanu ma seÂṀa
  79,36,Ve burrizetilcehÄḟymu limen yera
  79,37,Feemma men taÄa
