quran[11]{c,v,t}:
  101,1,"´Başa çarpıp patlak verecek olan´ (kâria: kıyamet)"
  101,2,Nedir o ´çarpıp patlak verecek olan´
  101,3,Sana o ´çarpıp patlak verecek olan´ı bildiren nedir
  101,4,"İnsanların, ´her yana dağılmış´ pervaneler gibi olacakları gün"
  101,5,Ve dağların da ´etrafa saçılmış´ renkli yünler gibi olacakları (gün)
  101,6,"İşte, kimin tartıları ağır basarsa"
  101,7,"Artık o, hoşnut olunan bir hayat içindedir"
  101,8,Kimin de tartıları hafif kalırsa
  101,9,Artık onun da anası (son durağı) «hâviye»dir (uçurum)
  101,10,Onun ne olduğunu (mahiyetini) sana bildiren nedir
  101,11,"O, kızgın bir ateştir"