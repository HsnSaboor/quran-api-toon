quran[11]{c,v,t}:
  93,1,Eebe wuxuu ku dhaartay Barqinka
  93,2,Iyo Habeenku markuu xasilo (Madoobaado)
  93,3,Inaan Eebe ka tagin Nabiyow kuuna cadhoonin
  93,4,Aakharana kaaga khayr badan Aduunka
  93,5,Eebaana ku siindoona (wanaag) waadna raalli noqon
  93,6,Miyuusan ku helin Eebahaa Adigoo Agoon ah oosan ku dhawaynin
  93,7,Miyuunase ku helin Adigoo baadi ah oosan ku hanuuninin
  93,8,Miyuunase ku helin Adigoo caydhi ah oosna ku hodminin (kuu waxyoonin)
  93,9,Ee Agoonta ha xoogin (hana dhihin)
  93,10,Ka wax su'aalina ha canaanan
  93,11,Nicmada Eebahaana ka sheekee (ku mahadi)