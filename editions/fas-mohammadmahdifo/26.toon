quran[227]{c,v,t}:
  26,1,طا، سين، ميم
  26,2,اين است آيه‌هاى كتاب روشنگر
  26,3,"شايد تو از اينكه [مشركان‌] ايمان نمى‌آورند، جان خود را تباه سازى"
  26,4,اگر بخواهيم، معجزه‌اى از آسمان بر آنان فرود مى‌آوريم، تا در برابر آن، گردنهايشان خاضع گردد
  26,5,"و هيچ تذكر جديدى از سوى [خداى‌] رحمان برايشان نيامد جز اينكه همواره از آن روى برمى‌تافتند"
  26,6,"[آنان‌] در حقيقت به تكذيب پرداختند، و به زودى خبر آنچه كه بدان ريشخند مى كردند، بديشان خواهد رسيد"
  26,7,مگر در زمين ننگريسته‌اند كه چه قدر در آن از هر گونه جفتهاى زيبا رويانيده‌ايم؟
  26,8,"قطعاً در اين [هنرنمايى‌] عبرتى است و[لى‌] بيشترشان ايمان‌آورنده نيستند"
  26,9,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,10,"و [ياد كن‌] هنگامى را كه پروردگارت موسى را ندا درداد كه به سوى قوم ستمكار برو"
  26,11,قوم فرعون؛ آيا پروا ندارند؟
  26,12,"گفت: «پروردگارا، مى‌ترسم مرا تكذيب كنند،"
  26,13,و سينه‌ام تنگ مى‌گردد، و زبانم باز نمى‌شود، پس به سوى هارون بفرست
  26,14,"و [از طرفى‌] آنان بر [گردن‌] من خونى دارند و مى‌ترسم مرا بكشند.»"
  26,15,"فرمود: «نه، چنين نيست؛ نشانه‌هاى ما را [براى آنان‌] بِبَريد كه ما با شما شنونده‌ايم.»"
  26,16,"پس به سوى فرعون برويد و بگوييد: «ما پيامبر پروردگار جهانيانيم،"
  26,17,فرزندان اسرائيل را با ما بفرست.»
  26,18,"[فرعون‌] گفت: «آيا تو را از كودكى در ميان خود نپرورديم و ساليانى چند از عمرت را پيش ما نماندى؟"
  26,19,"و [سرانجام‌] كار خود را كردى، و تو از ناسپاسانى.»"
  26,20,"گفت: «آن را هنگامى مرتكب شدم كه از گمراهان بودم،"
  26,21,و چون از شما ترسيدم، از شما گريختم، تا پروردگارم به من دانش بخشيد و مرا از پيامبران قرار داد
  26,22,"و [آيا] اينكه فرزندان اسرائيل را بنده [خود] ساخته‌اى نعمتى است كه منّتش را بر من مى‌نهى؟»"
  26,23,"فرعون گفت: «و پروردگار جهانيان چيست؟»"
  26,24,"گفت: «پروردگار آسمانها و زمين و آنچه ميان آن دو است-اگر اهل يقين باشيد.»"
  26,25,"[فرعون‌] به كسانى كه پيرامونش بودند گفت: «آيا نمى‌شنويد؟»"
  26,26,"[موسى دوباره‌] گفت: «پروردگار شما و پروردگار پدران پيشين شما.»"
  26,27,"[فرعون‌] گفت: «واقعاً اين پيامبرى كه به سوى شما فرستاده شده، سخت ديوانه است.»"
  26,28,"[موسى‌] گفت: «پروردگار خاور و باختر و آنچه ميان آن دو است-اگر تعقّل كنيد.»"
  26,29,"[فرعون‌] گفت: «اگر خدايى غير از من اختيار كنى قطعاً تو را از [جمله‌] زندانيان خواهم ساخت.»"
  26,30,"گفت: «گر چه براى تو چيزى آشكار بياورم؟»"
  26,31,"گفت: «اگر راست مى‌گويى آن را بياور.»"
  26,32,پس عصاى خود بيفكند و بناگاه آن اژدرى نمايان شد
  26,33,و دستش را بيرون كشيد و بناگاه آن براى تماشاگران سپيد مى‌نمود
  26,34,"[فرعون‌] به سرانى كه پيرامونش بودند گفت: «واقعاً اين ساحرى بسيار داناست"
  26,35,مى‌خواهد با سحر خود، شما را از سرزمينتان بيرون كند، اكنون چه رأى مى‌دهيد؟»
  26,36,"گفتند: «او و برادرش را در بند دار و گردآورندگان را به شهرها بفرست،"
  26,37,تا هر ساحر ماهرى را نزد تو بياورند.»
  26,38,پس ساحران براى موعدِ روزى معلوم گردآورى شدند
  26,39,"و به توده مردم گفته شد: «آيا شما هم جمع خواهيد شد؟"
  26,40,بدين اميد كه اگر ساحران غالب شدند از آنان پيروى كنيم؟»
  26,41,"و چون ساحران پيش فرعون آمدند، گفتند: «آيا اگر ما غالب آييم واقعاً براى ما مزدى خواهد بود؟»"
  26,42,"گفت: «آرى، و در آن صورت شما حتماً از [زمره‌] مقرّبان خواهيد شد.»"
  26,43,"موسى به آنان گفت: «آنچه را شما مى‌اندازيد بيندازيد.»"
  26,44,"پس ريسمانها و چوبدستى‌هايشان را انداختند و گفتند: «به عزّت فرعون كه ما حتماً پيروزيم.»"
  26,45,پس موسى عصايش را انداخت و بناگاه هر چه را به دروغ برساخته بودند بلعيد
  26,46,در نتيجه، ساحران به حالت سجده درافتادند
  26,47,"گفتند: «به پروردگار جهانيان ايمان آورديم"
  26,48,پروردگار موسى و هارون.»
  26,49,"گفت: « [آيا] پيش از آنكه به شما اجازه دهم به او ايمان آورديد؟ قطعاً او همان بزرگ شماست كه به شما سحر آموخته است. به زودى خواهيد دانست. حتماً دستها و پاهاى شما را از چپ و راست خواهم بريد و همه‌تان را به دار خواهم آويخت.»"
  26,50,"گفتند: «باكى نيست، ما روى به سوى پروردگار خود مى‌آوريم"
  26,51,"ما اميدواريم كه پروردگارمان گناهانمان را بر ما ببخشايد، [چرا] كه نخستين ايمان‌آورندگان بوديم.»"
  26,52,"و به موسى وحى كرديم كه: «بندگان مرا شبانه حركت ده، زيرا شما مورد تعقيب قرار خواهيد گرفت.»"
  26,53,"پس فرعون مأمورانِ جمع‌آورىِ [خود را] به شهرها فرستاد،"
  26,54,"[و گفت:] «اينها عده‌اى ناچيزند"
  26,55,و راستى آنها ما را بر سر خشم آورده‌اند،
  26,56,"و[لى‌] ما همگى به حال آماده‌باش درآمده‌ايم.»"
  26,57,سرانجام، ما آنان را از باغستانها و چشمه‌سارها،
  26,58,و گنجينه‌ها و جايگاه‌هاى پر ناز و نعمت بيرون كرديم
  26,59,"[اراده ما] چنين بود، و آن [نعمتها] را به فرزندان اسرائيل ميراث داديم"
  26,60,پس هنگام برآمدن آفتاب، آنها را تعقيب كردند
  26,61,"چون دو گروه، همديگر را ديدند، ياران موسى گفتند: «ما قطعاً گرفتار خواهيم شد.»"
  26,62,"گفت: «چنين نيست، زيرا پروردگارم با من است و به زودى مرا راهنمايى خواهد كرد.»"
  26,63,"پس به موسى وحى كرديم: «با عصاى خود بر اين دريا بزن.» تا از هم شكافت، و هر پاره‌اى همچون كوهى سترگ بود"
  26,64,و ديگران را بدانجا نزديك گردانيديم
  26,65,و موسى و همه كسانى را كه همراه او بودند نجات داديم؛
  26,66,آنگاه ديگران را غرق كرديم
  26,67,"مسلماً در اين [واقعه‌] عبرتى بود، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,68,و قطعاً پروردگار تو همان شكست‌ناپذير مهربان است
  26,69,و بر آنان گزارش ابراهيم را بخوان
  26,70,"آنگاه كه به پدر خود و قومش گفت: «چه مى‌پرستيد؟»"
  26,71,"گفتند: «بتانى را مى‌پرستيم و همواره ملازم آنهاييم.»"
  26,72,"گفت: «آيا وقتى دعا مى‌كنيد، از شما مى‌شنوند؟"
  26,73,يا به شما سود يا زيان مى‌رسانند؟»
  26,74,"گفتند: «نه، بلكه پدران خود را يافتيم كه چنين مى‌كردند.»"
  26,75,"گفت: «آيا در آنچه مى‌پرستيده‌ايد تأمّل كرده‌ايد؟"
  26,76,شما و پدران پيشين شما؟
  26,77,قطعاً همه آنها -جز پروردگار جهانيان- دشمن منند
  26,78,آن كس كه مرا آفريده و همو راهنماييم مى‌كند،
  26,79,و آن كس كه او به من خوراك مى‌دهد و سيرابم مى‌گرداند،
  26,80,و چون بيمار شوم او مرا درمان مى‌بخشد،
  26,81,و آن كس كه مرا مى‌ميراند و سپس زنده‌ام مى‌گرداند،
  26,82,و آن كس كه اميد دارم روز پاداش، گناهم را بر من ببخشايد.»
  26,83,پروردگارا، به من دانش عطا كن و مرا به صالحان ملحق فرماى،
  26,84,"و براى من در [ميان‌] آيندگان آوازه نيكو گذار،"
  26,85,و مرا از وارثان بهشت پر نعمت گردان،
  26,86,و بر پدرم ببخشاى كه او از گمراهان بود،
  26,87,"و روزى كه [مردم‌] برانگيخته مى‌شوند رسوايم مكن"
  26,88,روزى كه هيچ مال و فرزندى سود نمى‌دهد،
  26,89,مگر كسى كه دلى پاك به سوى خدا بياورد
  26,90,"و [آن روز] بهشت براى پرهيزگاران نزديك مى‌گردد"
  26,91,و جهنم براى گمراهان نمودار مى‌شود
  26,92,"و به آنان گفته مى‌شود: «آنچه جز خدا مى‌پرستيديد كجايند؟"
  26,93,آيا ياريتان مى‌كنند يا خود را يارى مى‌دهند؟
  26,94,"پس آنها و همه گمراهان در آن [آتش‌] افكنده مى‌شوند،"
  26,95,"و [نيز] همه سپاهيان ابليس"
  26,96,"آنها در آنجا با يكديگر ستيزه مى‌كنند [و] مى‌گويند"
  26,97,«سوگند به خدا كه ما در گمراهى آشكارى بوديم،
  26,98,آنگاه كه شما را با پروردگار جهانيان برابر مى‌كرديم،
  26,99,و جز تباهكاران ما را گمراه نكردند،
  26,100,در نتيجه شفاعتگرانى نداريم،
  26,101,و نه دوستى نزديك
  26,102,و اى كاش كه بازگشتى براىِ ما بود و از مؤمنان مى‌شديم
  26,103,"حقاً در اين [سرگذشت درس‌] عبرتى است و[لى‌] بيشترشان مؤمن نبودند"
  26,104,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,105,قوم نوح پيامبران را تكذيب كردند
  26,106,"چون برادرشان نوح به آنان گفت: «آيا پروا نداريد؟"
  26,107,من براى شما فرستاده‌اى در خور اعتمادم؛
  26,108,از خدا پروا كنيد و فرمانم ببريد،
  26,109,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,110,پس، از خدا پروا كنيد و فرمانم ببريد.»
  26,111,"گفتند: «آيا به تو ايمان بياوريم و حال آنكه فرومايگان از تو پيروى كرده‌اند؟»"
  26,112,"[نوح‌] گفت: «به [جزئيات‌] آنچه مى‌كرده‌اند چه آگاهى دارم؟"
  26,113,حسابشان -اگر درمى‌يابيد- جز با پروردگارم نيست
  26,114,و من طردكننده مؤمنان نيستم
  26,115,"من جز هشداردهنده‌اى آشكار [بيش‌] نيستم.»"
  26,116,"گفتند: «اى نوح، اگر دست برندارى قطعاً از [جمله‌] سنگسارشدگان خواهى بود.»"
  26,117,"گفت: «پروردگارا، قوم من مرا تكذيب كردند؛"
  26,118,ميان من و آنان فيصله ده، و من و هر كس از مؤمنان را كه با من است نجات بخش.»
  26,119,پس او و هر كه را در آن كشتى آكنده با او بود، رهانيديم؛
  26,120,آنگاه باقى‌ماندگان را غرق كرديم
  26,121,"قطعاً در اين [ماجرا درس‌] عبرتى بود، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,122,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,123,"عاديان، پيامبران [خدا] را تكذيب كردند"
  26,124,"آنگاه كه برادرشان هود به آنان گفت: «آيا پروا نداريد؟"
  26,125,من براى شما فرستاده‌اى در خور اعتمادم
  26,126,از خدا پروا كنيد و فرمانم ببريد
  26,127,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,128,"آيا بر هر تپه‌اى بنايى مى‌سازيد كه [در آن‌] دست به بيهوده‌كارى زنيد؟"
  26,129,و كاخهاى استوار مى‌گيريد به اميد آنكه جاودانه بمانيد؟
  26,130,"و چون حمله‌ور مى‌شويد [چون‌] زورگويان حمله‌ور مى‌شويد؟"
  26,131,پس، از خدا پروا داريد و فرمانم ببريد
  26,132,و از آن كس كه شما را به آنچه مى‌دانيد مدد كرد پروا داريد
  26,133,"شما را به [دادن‌] دامها و پسران مدد كرد،"
  26,134,"و به [دادن‌] باغها و چشمه‌ساران؛"
  26,135,من از عذاب روزى هولناك بر شما مى‌ترسم
  26,136,"گفتند: «خواه اندرز دهى و خواه از اندرزدهندگان نباشى براى ما يكسان است"
  26,137,اين جز شيوه پيشينيان نيست
  26,138,و ما عذاب نخواهيم شد.»
  26,139,"پس تكذيبش كردند و هلاكشان كرديم. قطعاً در اين [ماجرا درس‌] عبرتى بود، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,140,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,141,"ثموديان، پيامبران [خدا] را تكذيب كردند؛"
  26,142,"آنگاه كه برادرشان صالح به آنان گفت: «آيا پروا نداريد؟"
  26,143,من براى شما فرستاده‌اى در خور اعتمادم
  26,144,از خدا پروا كنيد و فرمانم ببريد
  26,145,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,146,آيا شما را در آنچه اينجا داريد آسوده رها مى‌كنند؟
  26,147,در باغها و در كنار چشمه‌ساران،
  26,148,و كشتزارها و خرمابنانى كه شكوفه‌هايشان لطيف است؟
  26,149,و هنرمندانه براى خود از كوهها خانه‌هايى مى‌تراشيد
  26,150,از خدا پروا كنيد و فرمانم ببريد
  26,151,و فرمان افراطگران را پيروى مكنيد
  26,152,آنان كه در زمين فساد مى‌كنند و اصلاح نمى‌كنند.»
  26,153,"گفتند: «قطعاً تو از افسون‌شدگانى"
  26,154,"تو جز بشرى مانند ما [بيش‌] نيستى. اگر راست مى‌گويى معجزه‌اى بياور"
  26,155,"گفت: «اين ماده‌شترى است كه نوبتى از آب او راست و روزى معين نوبت آب شماست"
  26,156,و به آن گزندى مرسانيد كه عذاب روزى هولناك شما را فرو مى‌گيرد
  26,157,پس آن را پى كردند و پشيمان گشتند
  26,158,"آنگاه آنان را عذاب فرو گرفت. قطعاً در اين [ماجرا] عبرتى است، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,159,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,160,قوم لوط فرستادگان را تكذيب كردند
  26,161,"آنگاه برادرشان لوط به آنان گفت: «آيا پروا نداريد؟"
  26,162,من براى شما فرستاده‌اى در خور اعتمادم
  26,163,از خدا پروا داريد و فرمانم ببريد
  26,164,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,165,آيا از ميان مردم جهان، با مردها در مى‌آميزيد؟
  26,166,"و آنچه را پروردگارتان از همسرانتان براى شما آفريده وامى‌گذاريد؟ [نه،] بلكه شما مردمى تجاوزكاريد"
  26,167,"گفتند: «اى لوط، اگر دست برندارى، قطعاً از اخراج‌شدگان خواهى بود.»"
  26,168,"گفت: «به راستى من دشمن كردار شمايم"
  26,169,پروردگارا، مرا و كسان مرا از آنچه انجام مى‌دهند رهايى بخش.»
  26,170,پس او و كسانش را همگى، رهانيديم
  26,171,"جز پيرزنى كه از باقى‌ماندگان [در خاكستر آتش‌] بود"
  26,172,سپس ديگران را سخت هلاك كرديم
  26,173,"و بر [سر] آنان بارانى [از آتش گوگرد] فرو ريختيم. و چه بد بود باران بيم‌داده‌شدگان"
  26,174,"قطعاً در اين [عقوبت‌] عبرتى است، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,175,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,176,اصحاب ايكه فرستادگان را تكذيب كردند
  26,177,"آنگاه كه شعيب به آنان گفت: «آيا پروا نداريد؟"
  26,178,من براى شما فرستاده‌اى در خور اعتمادم
  26,179,از خدا پروا داريد و فرمانم ببريد
  26,180,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,181,پيمانه را تمام دهيد و از كم‌فروشان مباشيد
  26,182,و با ترازوى درست بسنجيد
  26,183,و از ارزش اموال مردم مكاهيد و در زمين سر به فساد بر مداريد
  26,184,"و از آن كس كه شما و خلق [انبوه‌] گذشته را آفريده است پروا كنيد.»"
  26,185,"گفتند: «تو واقعاً از افسون‌شدگانى.»"
  26,186,"«و تو جز بشرى مانند ما [بيش‌] نيستى، و قطعاً تو را از دروغگويان مى‌دانيم"
  26,187,"پس اگر از راستگويانى، پاره‌اى از آسمان بر [سر] ما بيفكن.»"
  26,188,"[شعيب‌] گفت: «پروردگارم به آنچه مى‌كنيد داناتر است.»"
  26,189,"پس او را تكذيب كردند، و عذابِ روزِ ابر [آتشبار] آنان را فرو گرفت. به راستى آن، عذاب روزى هولناك بود"
  26,190,"قطعاً در اين [عقوبت درسِ‌] عبرتى است، و[لى‌] بيشترشان ايمان آورنده نبودند"
  26,191,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,192,"و راستى كه اين [قرآن‌] وحى پروردگار جهانيان است"
  26,193,«روح الامين» آن را بر دلت نازل كرد،
  26,194,"تا از [جمله‌] هشداردهندگان باشى؛"
  26,195,به زبان عربى روشن،
  26,196,"و [وصف‌] آن در كتابهاى پيشينيان آمده است"
  26,197,آيا براى آنان، اين خود دليلى روشن نيست كه علماى بنى‌اسرائيل از آن اطّلاع دارند؟
  26,198,و اگر آن را بر برخى از غير عرب زبانان نازل مى‌كرديم،
  26,199,و پيامبر آن را برايشان مى‌خواند به آن ايمان نمى‌آوردند
  26,200,"اين گونه در دلهاى گناهكاران، [انكار را] راه مى‌دهيم"
  26,201,كه به آن نگروند تا عذاب پردرد را ببينند،
  26,202,كه به طور ناگهانى -در حالى كه بى‌خبرند- بديشان برسد
  26,203,"و بگويند: «آيا مهلت خواهيم يافت؟»"
  26,204,پس آيا عذاب ما را به شتاب مى‌خواهند؟
  26,205,مگر نمى‌دانى كه اگر سالها آنان را برخوردار كنيم،
  26,206,"و آنگاه آنچه كه [بدان‌] بيم داده مى‌شوند بديشان برسد،"
  26,207,"آنچه از آن برخوردار مى‌شدند، به كارشان نمى‌آيد [و عذاب را از آنان دفع نمى‌كند]؟"
  26,208,و هيچ شهرى را هلاك نكرديم مگر آنكه براى آن هشداردهندگانى بود
  26,209,"[تا آنان را] تذكر [دهند]؛ و ما ستمكار نبوده‌ايم"
  26,210,و شيطانها آن را فرود نياورده‌اند
  26,211,"و آنان را نسزد و نمى‌توانند [وحى كنند]"
  26,212,"در حقيقت آنها از شنيدن، معزول [و محروم‌]اند"
  26,213,پس با خدا، خداى ديگر مخوان كه از عذاب‌شدگان خواهى شد
  26,214,و خويشان نزديكت را هشدار ده
  26,215,و براى آن مؤمنانى كه تو را پيروى كرده‌اند، بال خود را فرو گستر
  26,216,"و اگر تو را نافرمانى كردند، بگو: «من از آنچه مى‌كنيد بيزارم.»"
  26,217,"و بر [خداىِ‌] عزيزِ مهربان توكل كن،"
  26,218,"آن كس كه چون [به نماز] برمى‌خيزى تو را مى‌بيند،"
  26,219,"و حركت تو را در ميان سجده‌كنندگان [مى‌نگرد]"
  26,220,او همان شنواى داناست
  26,221,آيا شما را خبر دهم كه شياطين بر چه كسى فرود مى‌آيند؟
  26,222,بر هر دروغزن گناهكارى فرود مى‌آيند،
  26,223,"كه [دزدانه‌] گوش فرا مى‌دارند و بيشترشان دروغگويند،"
  26,224,و شاعران را گمراهان پيروى مى‌كنند
  26,225,آيا نديده‌اى كه آنان در هر واديى سرگردانند؟
  26,226,و آنانند كه چيزهايى مى‌گويند كه انجام نمى‌دهند
  26,227,مگر كسانى كه ايمان آورده و كارهاى شايسته كرده و خدا را بسيار به ياد آورده و پس از آنكه مورد ستم قرار گرفته‌اند يارى خواسته‌اند. و كسانى كه ستم كرده‌اند به زودى خواهند دانست به كدام بازگشتگاه برخواهند گشت