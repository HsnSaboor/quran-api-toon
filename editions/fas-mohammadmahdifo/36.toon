quran[83]{c,v,t}:
  36,1,"يس‌[/ياسين‌]"
  36,2,سوگند به قرآن حكمت‌آموز،
  36,3,"كه قطعاً تو از [جمله‌] پيامبرانى،"
  36,4,بر راهى راست
  36,5,"[و كتابت‌] از جانب آن عزيز مهربان نازل شده است،"
  36,6,تا قومى را كه پدرانشان بيم‌داده نشدند و در غفلت ماندند، بيم دهى
  36,7,"آرى، گفته [خدا] در باره بيشترشان محقق گرديده است، در نتيجه آنها نخواهند گرويد"
  36,8,ما در گردنهاى آنان، تا چانه‌هايشان، غُلهايى نهاده‌ايم، به طورى كه سرهايشان را بالا نگاه داشته و ديده فرو هشته‌اند
  36,9,"و [ما] فراروى آنها سدى و پشت سرشان سدى نهاده و پرده‌اى بر [چشمان‌] آنان فرو گسترده‌ايم، در نتيجه نمى‌توانند ببينند"
  36,10,"و آنان را چه بيم دهى [و] چه بيم ندهى، به حالشان تفاوت نمى‌كند: نخواهند گرويد"
  36,11,"بيم دادن تو، تنها كسى را [سودمند] است كه كتاب حق را پيروى كند و از [خداى‌] رحمان در نهان بترسد. [چنين كسى را] به آمرزش و پاداشى پر ارزش مژده ده"
  36,12,"آرى! ماييم كه مردگان را زنده مى‌سازيم و آنچه را از پيش فرستاده‌اند، با آثار [و اعمال‌]شان درج مى‌كنيم، و هر چيزى را در كارنامه‌اى روشن برشمرده‌ايم"
  36,13,"[داستان‌] مردم آن شهرى را كه رسولان بدانجا آمدند براى آنان مَثَل زن"
  36,14,"آنگاه كه دو تن سوى آنان فرستاديم، و[لى‌] آن دو را دروغزن پنداشتند، تا با [فرستاده‌] سومين [آنان را] تأييد كرديم، پس [رسولان‌] گفتند: «ما به سوى شما به پيامبرى فرستاده شده‌ايم.»"
  36,15,"[ناباوران آن ديار] گفتند: «شما جز بشرى مانند ما نيستيد، و [خداى‌] رحمان چيزى نفرستاده، و شما جز دروغ نمى‌پردازيد.»"
  36,16,"گفتند: «پروردگار ما مى‌داند كه ما واقعاً به سوى شما به پيامبرى فرستاده شده‌ايم.»"
  36,17,"و بر ما [وظيفه‌اى‌] جز رسانيدن آشكار [پيام‌] نيست"
  36,18,"پاسخ دادند: «ما [حضور] شما را به شگون بد گرفته‌ايم. اگر دست برنداريد، سنگسارتان مى‌كنيم و قطعاً عذاب دردناكى از ما به شما خواهد رسيد.»"
  36,19,"[رسولان‌] گفتند: «شومىِ شما با خود شماست. آيا اگر شما را پند دهند [باز كفر مى‌ورزيد]؟ نه! بلكه شما قومى اسرافكاريد.»"
  36,20,"و [در اين ميان‌] مردى از دورترين جاى شهر دوان دوان آمد، [و] گفت: «اى مردم، از اين فرستادگان پيروى كنيد"
  36,21,"از كسانى كه پاداشى از شما نمى‌خواهند و خود [نيز] بر راه راست قرار دارند، پيروى كنيد"
  36,22,"آخر چرا كسى را نپرستم كه مرا آفريده است و [همه‌] شما به سوى او بازگشت مى‌يابيد؟"
  36,23,"آيا به جاى او خدايانى را بپرستم كه اگر [خداى‌] رحمان بخواهد به من گزندى برساند، نه شفاعتشان به حالم سود مى‌دهد و نه مى‌توانند مرا برهانند؟"
  36,24,در آن صورت، من قطعاً در گمراهى آشكارى خواهم بود
  36,25,"من به پروردگارتان ايمان آوردم. [اقرار] مرا بشنويد.»"
  36,26,"[سرانجام به جرم ايمان كشته شد، و بدو] گفته شد: «به بهشت درآى.» گفت: «اى كاش، قوم من مى‌دانستند،"
  36,27,كه پروردگارم چگونه مرا آمرزيد و در زمره عزيزانم قرار داد.»
  36,28,"پس از [شهادت‌] وى هيچ سپاهى از آسمان بر قومش فرود نياورديم و [پيش از اين هم‌] فروفرستنده نبوديم"
  36,29,"تنها يك فرياد بود و بس. و بناگاه [همه‌] آنها سرد بر جاى فسردند"
  36,30,دريغا بر اين بندگان! هيچ فرستاده‌اى بر آنان نيامد مگر آنكه او را ريشخند مى‌كردند
  36,31,مگر نديده‌اند كه چه بسيار نسلها را پيش از آنان هلاك گردانيديم كه ديگر آنها به سويشان بازنمى‌گردند؟
  36,32,و قطعاً همه آنان در پيشگاه ما احضار خواهند شد
  36,33,و زمين مرده، برهانى است براى ايشان، كه آن را زنده گردانيديم و دانه از آن برآورديم كه از آن مى‌خورند
  36,34,"و در آن [زمين‌] باغهايى از درختان خرما و تاك قرار داديم و چشمه‌ها در آن روان كرديم"
  36,35,"تا از ميوه آن و [از] كاركرد دستهاى خودشان بخورند، آيا باز [هم‌] سپاس نمى‌گزارند؟"
  36,36,"پاك [خدايى‌] كه از آنچه زمين مى‌روياند و [نيز] از خودشان و از آنچه نمى‌دانند، همه را نر و ماده گردانيده است"
  36,37,"و نشانه‌اى [ديگر] براى آنها شب است كه روز را [مانند پوست‌] از آن برمى‌كنيم و بناگاه آنان در تاريكى فرو مى‌روند"
  36,38,"و خورشيد به [سوى‌] قرارگاه ويژه خود روان است. تقدير آن عزيز دانا اين است"
  36,39,و براى ماه منزلهايى معين كرده‌ايم، تا چون شاخك خشك خوشه خرما برگردد
  36,40,نه خورشيد را سزد كه به ماه رسد، و نه شب بر روز پيشى جويد، و هر كدام در سپهرى شناورند
  36,41,"و نشانه‌اى [ديگر] براى آنان اينكه: ما نياكانشان را در كشتى انباشته، سوار كرديم"
  36,42,"و مانند آن براى ايشان مركوبها[ى ديگرى‌] خلق كرديم"
  36,43,و اگر بخواهيم غرقشان مى‌كنيم و هيچ فريادرسى نمى‌يابند و روى نجات نمى‌بينند
  36,44,"مگر رحمتى از جانب ما [شامل آنها گردد] و تا چندى [آنها را] برخوردار سازيم"
  36,45,"و چون به ايشان گفته شود: «از آنچه در پيش رو و پشت سر داريد بترسيد، اميد كه مورد رحمت قرار گيريد» [نمى‌شنوند]"
  36,46,و هيچ نشانه‌اى از نشانه‌هاى پروردگارشان بر آنان نيامد، جز اينكه از آن رويگردان شدند
  36,47,"و چون به آنان گفته شود: «از آنچه خدا به شما روزى داده انفاق كنيد»، كسانى كه كافر شده‌اند، به آنان كه ايمان آورده‌اند، مى‌گويند: «آيا كسى را بخورانيم كه اگر خدا مى‌خواست [خودش‌] وى را مى‌خورانيد؟ شما جز در گمراهىِ آشكارى [بيش‌] نيستيد.»"
  36,48,"و مى‌گويند: «اگر راست مى‌گوييد، پس اين وعده [عذاب‌] كى خواهد بود؟»"
  36,49,"جز يك فرياد [مرگبار] را انتظار نخواهند كشيد كه هنگامى كه سرگرم جدالند غافلگيرشان كند"
  36,50,آنگاه نه توانايى وصيّتى دارند و نه مى‌توانند به سوى كسان خود برگردند
  36,51,و در صور دميده خواهد شد، پس بناگاه از گورهاى خود شتابان به سوى پروردگار خويش مى‌آيند
  36,52,"مى‌گويند: «اى واى بر ما، چه كسى ما را از آرامگاهمان برانگيخت؟ اين است همان وعده خداى رحمان، و پيامبران راست مى‌گفتند.»"
  36,53,"[باز هم‌] يك فرياد است و بس؛ و بناگاه همه در پيشگاه ما حاضر آيند"
  36,54,امروز بر كسى هيچ ستم نمى‌رود، جز در برابر آنچه كرده‌ايد پاداشى نخواهيد يافت
  36,55,در اين روز، اهل بهشت كار و بارى خوش در پيش دارند
  36,56,آنها با همسرانشان در زير سايه‌ها بر تختها تكيه مى‌زنند
  36,57,"در آنجا براى آنها [هر گونه‌] ميوه است و هر چه دلشان بخواهد"
  36,58,"از جانب پروردگار[ى‌] مهربان [به آنان‌] سلام گفته مى‌شود"
  36,59,"و اى گناهكاران، امروز [از بى‌گناهان‌] جدا شويد"
  36,60,اى فرزندان آدم، مگر با شما عهد نكرده بودم كه شيطان را مپرستيد، زيرا وى دشمن آشكار شماست؟
  36,61,و اينكه مرا بپرستيد؛ اين است راه راست
  36,62,"و [او] گروهى انبوه از ميان شما را سخت گمراه كرد؛ آيا تعقل نمى‌كرديد؟"
  36,63,اين است جهنّمى كه به شما وعده داده مى‌شد
  36,64,"به [جرم‌] آنكه كفر مى‌ورزيديد، اكنون در آن درآييد"
  36,65,امروز بر دهانهاى آنان مُهر مى‌نهيم، و دستهايشان با ما سخن مى‌گويند، و پاهايشان بدانچه فراهم مى‌ساختند گواهى مى‌دهند
  36,66,"و اگر بخواهيم، هر آينه فروغ از ديدگانشان مى‌گيريم تا در راه [كج‌] بر هم پيشى جويند؛ ولى [راه راست را] از كجا مى‌توانند ببينند؟"
  36,67,"و اگر بخواهيم، هرآينه ايشان را در جاى خود مسخ مى‌كنيم [به گونه‌اى‌] كه نه بتوانند بروند و نه برگردند"
  36,68,"و هر كه را عمر دراز دهيم، او را [از نظر] خلقت فروكاسته [و شكسته‌] گردانيم، آيا نمى‌انديشند؟"
  36,69,"و [ما] به او شعر نياموختيم و در خور وى نيست، اين [سخن‌] جز اندرز و قرآنى روشن نيست"
  36,70,"تا هر كه را [دلى‌] زنده است بيم دهد، و گفتار [خدا] در باره كافران محقق گردد"
  36,71,آيا نديده‌اند كه ما به قدرت خويش براى ايشان چهارپايانى آفريده‌ايم تا آنان مالك آنها باشند؟
  36,72,و آنها را براى ايشان رام گردانيديم. از برخى‌شان سوارى مى‌گيرند و از بعضى مى‌خورند
  36,73,و از آنها سودها و نوشيدنيها دارند. پس چرا شكرگزار نيستيد؟
  36,74,"و غير از خدا[ى يگانه‌] خدايانى به پرستش گرفتند، تا مگر يارى شوند"
  36,75,"[ولى بتان‌] نمى‌توانند آنان را يارى كنند و آنانند كه براى [بتان‌] چون سپاهى احضار شده‌اند"
  36,76,پس، گفتار آنان تو را غمگين نگرداند كه ما آنچه را پنهان و آنچه را آشكار مى‌كنند، مى‌دانيم
  36,77,مگر آدمى ندانسته است كه ما او را از نطفه‌اى آفريده‌ايم، پس بناگاه وى ستيزه‌جويى آشكار شده است
  36,78,"و براى ما مَثَلى آورد و آفرينش خود را فراموش كرد؛ گفت: «چه كسى اين استخوانها را كه چنين پوسيده است زندگى مى‌بخشد؟»"
  36,79,"بگو: «همان كسى كه نخستين‌بار آن را پديد آورد و اوست كه به هر [گونه‌] آفرينشى داناست.»"
  36,80,"همو كه برايتان در درخت سبزفام اخگر نهاد كه از آن [چون نيازتان افتد] آتش مى‌افروزيد"
  36,81,"آيا كسى كه آسمانها و زمين را آفريده توانا نيست كه [باز] مانند آنها را بيافريند؟ آرى، اوست آفريننده دانا"
  36,82,"چون به چيزى اراده فرمايد، كارش اين بس كه مى‌گويد: «باش»؛ پس [بى‌درنگ‌] موجود مى‌شود"
  36,83,"پس [شكوهمند و] پاك است آن كسى كه ملكوت هر چيزى در دست اوست، و به سوى اوست كه بازگردانيده مى‌شويد"