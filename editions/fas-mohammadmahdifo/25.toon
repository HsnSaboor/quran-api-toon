quran[77]{c,v,t}:
  25,1,"بزرگ [و خجسته‌] است كسى كه بر بنده خود، فرقان [=كتاب جداسازنده حق از باطل‌] را نازل فرمود، تا براى جهانيان هشداردهنده‌اى باشد"
  25,2,همان كس كه فرمانروايى آسمانها و زمين از آنِ اوست، و فرزندى اختيار نكرده و براى او شريكى در فرمانروايى نبوده است، و هر چيزى را آفريده و بدان گونه كه درخور آن بوده اندازه‌گيرى كرده است
  25,3,و به جاى او خدايانى براى خود گرفته‌اند كه چيزى را خلق نمى‌كنند و خود خلق شده‌اند و براى خود نه زيانى را در اختيار دارند و نه سودى را، و نه مرگى را در اختيار دارند و نه حياتى و نه رستاخيزى را
  25,4,"و كسانى كه كفر ورزيدند، گفتند: «اين [كتاب‌] جز دروغى كه آن را بربافته [چيزى‌] نيست، و گروهى ديگر او را بر آن يارى كرده‌اند.» و قطعاً [با چنين نسبتى‌] ظلم و بهتانى به پيش آوردند"
  25,5,"و گفتند: «افسانه‌هاى پيشينيان است كه آنها را براى خود نوشته، و صبح و شام بر او املا مى‌شود.»"
  25,6,"بگو: «آن را كسى نازل ساخته است كه راز نهانها را در آسمانها و زمين مى‌داند، و هموست كه همواره آمرزنده مهربان است.»"
  25,7,"و گفتند: «اين چه پيامبرى است كه غذا مى‌خورد و در بازارها راه مى‌رود؟ چرا فرشته‌اى به سوى او نازل نشده تا همراه وى هشداردهنده باشد؟"
  25,8,"يا گنجى به طرف او افكنده نشده يا باغى ندارد كه از [بار و بَر] آن بخورد؟» و ستمكاران گفتند: « جز مردى افسون‌شده را دنبال نمى‌كنيد.»"
  25,9,بنگر چگونه براى تو مَثَلها زدند و گمراه شدند؛ در نتيجه نمى‌توانند راهى بيابند
  25,10,"بزرگ [و خجسته‌] است كسى كه اگر بخواهد بهتر از اين را براى تو قرار مى‌دهد: باغهايى كه جويبارها از زير [درختان‌] آن روان خواهد بود، و براى تو كاخها پديد مى‌آورد"
  25,11,"[نه!] بلكه [آنها] رستاخيز را دروغ خواندند، و براى هر كس كه رستاخيز را دروغ خوانَد آتش سوزان آماده كرده‌ايم"
  25,12,"چون [دوزخ‌] از فاصله‌اى دور، آنان را ببيند، خشم و خروشى از آن مى‌شنوند"
  25,13,"و چون آنان را در تنگنايى از آن به زنجير كشيده بيندازند، آنجاست كه مرگ [خود] را مى‌خواهند"
  25,14,"«امروز يك بار هلاك [خود] را مخواهيد و بسيار هلاك [خود] را بخواهيد.»"
  25,15,"بگو: «آيا اين [عقوبت‌] بهتر است يا بهشت جاويدان كه به پرهيزگاران وعده داده شده است كه پاداش و سرانجام آنان است؟»"
  25,16,"جاودانه هر چه بخواهند در آنجا دارند. پروردگار تو مسؤول [تحقق‌] اين وعده است"
  25,17,"و روزى كه آنان را با آنچه به جاى خدا مى‌پرستند، محشور مى‌كند، پس مى‌فرمايد: «آيا شما اين بندگان مرا به بيراهه كشانديد يا خود گمراه شدند؟»"
  25,18,"مى‌گويند: «منزهى تو، ما را نسزد كه جز تو دوستى براى خود بگيريم، ولى تو آنان و پدرانشان را برخوردار كردى تا [آنجا كه‌] ياد [تو] را فراموش كردند و گروهى هلاك‌شده، بودند.»"
  25,19,"قطعاً [خدايانتان‌] در آنچه مى‌گفتيد، شما را تكذيب كردند؛ در نتيجه نه مى‌توانيد [عذاب را از خود] دفع كنيد و نه [خود را] يارى نماييد و هر كس از شما شرك ورزد عذابى سهمگين به او مى‌چشانيم"
  25,20,"و پيش از تو پيامبران [خود] را نفرستاديم جز اينكه آنان [نيز] غذا مى‌خوردند و در بازارها راه مى‌رفتند، و برخى از شما را براى برخى ديگر [وسيله‌] آزمايش قرار داديم. آيا شكيبايى مى‌كنيد؟ و پروردگار تو همواره بيناست"
  25,21,"و كسانى كه به لقاى ما اميد ندارند، گفتند: «چرا فرشتگان بر ما نازل نشدند يا پروردگارمان را نمى‌بينيم؟» قطعاً در مورد خود تكبر ورزيدند و سخت سركشى كردند"
  25,22,"روزى كه فرشتگان را ببينند، آن روز براى گناهكاران بشارتى نيست، و مى‌گويند: «دور و ممنوع [آيد از رحمت خدا].»"
  25,23,"و به هر گونه كارى كه كرده‌اند مى‌پردازيم و آن را [چون‌] گَردى پراكنده مى‌سازيم"
  25,24,آن روز، جايگاه اهل بهشت بهتر و استراحتگاهشان نيكوتر است
  25,25,و روزى كه آسمان با ابرى سپيد از هم مى‌شكافد و فرشتگان نزول يابند
  25,26,"آن روز، فرمانروايى بحق، از آنِ [خداىِ‌] رحمان است و روزى است كه بر كافران بسى دشوار است"
  25,27,"و روزى است كه ستمكار دستهاى خود را مى‌گزد [و] مى‌گويد: «اى كاش با پيامبر راهى برمى‌گرفتم.»"
  25,28,"«اى واى، كاش فلانى را دوست [خود] نگرفته بودم"
  25,29,"او [بود كه‌] مرا به گمراهى كشانيد پس از آنكه قرآن به من رسيده بود.» و شيطان همواره فروگذارنده انسان است"
  25,30,"و پيامبر [خدا] گفت: «پروردگارا، قوم من اين قرآن را رها كردند.»"
  25,31,و اين گونه براى هر پيامبرى دشمنى از گناهكاران قرار داديم، و همين بس كه پروردگارت راهبر و ياور توست
  25,32,"و كسانى كه كافر شدند، گفتند: «چرا قرآن يكجا بر او نازل نشده است؟» اين گونه [ما آن را به تدريج نازل كرديم‌] تا قلبت را به وسيله آن استوار گردانيم، و آن را به آرامى [بر تو] خوانديم"
  25,33,"و براى تو مَثَلى نياوردند، مگر آنكه [ما] حق را با نيكوترين بيان براى تو آورديم"
  25,34,كسانى كه -به رو درافتاده- به سوى جهنم رانده مى‌شوند، آنان بدترين جاى و گم‌ترين راه را دارند
  25,35,"و به يقين [ما] به موسى كتاب [آسمانى‌] عطا كرديم، و برادرش هارون را همراه او دستيار[ش‌] گردانيديم"
  25,36,"پس گفتيم: «هر دو به سوى قومى كه نشانه‌هاى ما را به دروغ گرفتند برويد.» پس [ما] آنان را به سختى هلاك نموديم"
  25,37,"و قوم نوح را آنگاه كه پيامبران [خدا] را تكذيب كردند غرقشان ساختيم، و آنان را براى [همه‌] مردم عبرتى گردانيديم و براى ستمكاران عذابى پر درد آماده كرده‌ايم"
  25,38,"و [نيز] عاديان و ثموديان و اصحاب رَسّ و نسلهاى بسيارى ميان اين [جماعتها] را [هلاك كرديم‌]"
  25,39,و براى همه آنان مَثَلها زديم و همه را زير و زَبَر كرديم
  25,40,"و قطعاً بر شهرى كه باران بلا بر آن بارانده شد گذشته‌اند؛ مگر آن را نديده‌اند؟ [چرا،] ولى اميد به زنده‌شدن ندارند"
  25,41,"و چون تو را ببينند، جز به ريشخندت نگيرند، [كه:] «آيا اين همان كسى است كه خدا او را به رسالت فرستاده است؟"
  25,42,چيزى نمانده بود كه ما را از خدايانمان -اگر بر آن ايستادگى نمى‌كرديم- منحرف كند. «و هنگامى كه عذاب را مى‌بينند به زودى خواهند دانست چه كسى گمراه‌تر است
  25,43,"آيا آن كس كه هواى [نفس‌] خود را معبود خويش گرفته است ديدى؟ آيا [مى‌توانى‌] ضامن او باشى؟"
  25,44,يا گمان دارى كه بيشترشان مى‌شنوند يا مى‌انديشند؟ آنان جز مانند ستوران نيستند، بلكه گمراه‌ترند
  25,45,آيا نديده‌اى كه پروردگارت چگونه سايه را گسترده است؟ و اگر مى‌خواست، آن را ساكن قرار مى‌داد، آنگاه خورشيد را بر آن دليل گردانيديم
  25,46,"سپس آن [سايه‌] را اندك اندك به سوى خود بازمى‌گيريم"
  25,47,"و اوست كسى كه شب را براى شما پوششى قرار داد و خواب را [مايه‌] آرامشى. و روز را زمان برخاستن [شما] گردانيد"
  25,48,"و اوست آن كس كه بادها را نويدى پيشاپيش رحمت خويش [=باران‌] فرستاد و از آسمان، آبى پاك فرود آورديم،"
  25,49,تا به وسيله آن سرزمينى پژمرده را زنده گردانيم و آن را به آنچه خلق كرده‌ايم -از دامها و انسانهاى بسيار- بنوشانيم
  25,50,"و قطعاً آن [پند] را ميان آنان گوناگون ساختيم تا توجه پيدا كنند، و[لى ] بيشتر مردم جز ناسپاسى نخواستند"
  25,51,و اگر مى‌خواستيم قطعاً در هر شهرى هشداردهنده‌اى برمى‌انگيختيم
  25,52,"پس، از كافران اطاعت مكن، و با [الهام گرفتن از] قرآن با آنان به جهادى بزرگ بپرداز"
  25,53,"و اوست كسى كه دو دريا را موج‌زنان به سوى هم روان كرد: اين يكى شيرين [و] گوارا و آن يكى شور [و] تلخ است؛ و ميان آن دو، مانع و حريمى استوار قرار داد"
  25,54,"و اوست كسى كه از آب، بشرى آفريد و او را [داراى خويشاوندى‌] نسبى و دامادى قرار داد، و پروردگار تو همواره تواناست"
  25,55,"و غير از خدا چيزى را مى‌پرستند كه نه سودشان مى‌دهد و نه زيانشان مى‌رساند؛ و كافر همواره در برابر پروردگار خود همپشت [شيطان‌] است"
  25,56,و تو را جز بشارتگر و بيم‌دهنده نفرستاديم
  25,57,"بگو: «بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم، جز اينكه هر كس بخواهد راهى به سوى پروردگارش [در پيش‌] گيرد.»"
  25,58,و بر آن زنده كه نمى‌ميرد توكل كن و به ستايش او تسبيح گوى؛ و همين بس كه او به گناهان بندگانش آگاه است
  25,59,"همان كسى كه آسمانها و زمين، و آنچه را كه ميان آن دو است، در شش روز آفريد. آنگاه بر عرش استيلا يافت. رحمتگر عام [اوست‌]. در باره وى از خبره‌اى بپرس [كه مى‌داند]"
  25,60,"و چون به آنان گفته شود: «[خداى‌] رحمان را سجده كنيد»، مى‌گويند: «رحمان چيست؟ آيا براى چيزى كه ما را [بدان‌] فرمان مى‌دهى سجده كنيم؟» و بر رميدنشان مى‌افزايد"
  25,61,"[فرخنده و] بزرگوار است آن كسى كه در آسمان برجهايى نهاد، و در آن، چراغ و ماهى نوربخش قرار داد"
  25,62,و اوست كسى كه براى هر كس كه بخواهد عبرت گيرد يا بخواهد سپاسگزارى نمايد، شب و روز را جانشين يكديگر گردانيد
  25,63,و بندگان خداى رحمان كسانى‌اند كه روى زمين به نرمى گام برمى‌دارند؛ و چون نادانان ايشان را طرف خطاب قرار دهند به ملايمت پاسخ مى‌دهند
  25,64,و آنانند كه در حال سجده يا ايستاده، شب را به روز مى‌آورند
  25,65,"و كسانى‌اند كه مى‌گويند: «پروردگارا، عذاب جهنم را از ما بازگردان كه عذابش سخت و دايمى است"
  25,66,و در حقيقت، آن بد قرارگاه و جايگاهى است
  25,67,"و كسانى‌اند كه چون انفاق كنند، نه ولخرجى مى‌كنند و نه تنگ مى‌گيرند، و ميان اين دو [روش‌] حد وسط را برمى‌گزينند"
  25,68,"و كسانى‌اند كه با خدا معبودى ديگر نمى‌خوانند و كسى را كه خدا [خونش را] حرام كرده است جز به حق نمى‌كُشند، و زنا نمى‌كنند، و هر كس اينها را انجام دهد سزايش را دريافت خواهد كرد"
  25,69,براى او در روز قيامت عذاب دو چندان مى‌شود و پيوسته در آن خوار مى‌ماند
  25,70,مگر كسى كه توبه كند و ايمان آورد و كار شايسته كند. پس خداوند بديهايشان را به نيكيها تبديل مى‌كند، و خدا همواره آمرزنده مهربان است
  25,71,و هر كس توبه كند و كار شايسته انجام دهد، در حقيقت به سوى خدا بازمى‌گردد
  25,72,و كسانى‌اند كه گواهى دروغ نمى‌دهند؛ و چون بر لغو بگذرند با بزرگوارى مى‌گذرند
  25,73,و كسانى‌اند كه چون به آيات پروردگارشان تذكر داده شوند، كر و كور روى آن نمى‌افتند
  25,74,"و كسانى‌اند كه مى‌گويند: «پروردگارا، به ما از همسران و فرزندانمان آن ده كه مايه روشنى چشمان [ما] باشد، و ما را پيشواى پرهيزگاران گردان.»"
  25,75,"اينانند كه به پاس آنكه صبر كردند، غرفه‌[هاى بهشت را] پاداش خواهند يافت و در آنجا با سلام و درود مواجه خواهند شد"
  25,76,در آنجا، جاودانه خواهند ماند. چه خوش قرارگاه و مقامى
  25,77,"بگو: «اگر دعاى شما نباشد، پروردگارم هيچ اعتنايى به شما نمى‌كند. در حقيقت شما به تكذيب پرداخته‌ايد و به زودى [عذاب بر شما] لازم خواهد شد.»"