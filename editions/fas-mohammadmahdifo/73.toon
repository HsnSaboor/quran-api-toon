quran[20]{c,v,t}:
  73,1,اى جامه به خويشتن فرو پيچيده،
  73,2,به پا خيز شب را مگر اندكى،
  73,3,نيمى از شب يا اندكى از آن را بكاه،
  73,4,"يا بر آن [نصف‌] بيفزاى و قرآن را شمرده شمرده بخوان"
  73,5,در حقيقت ما به زودى بر تو گفتارى گرانبار القا مى‌كنيم
  73,6,"قطعاً برخاستن شب، رنجش بيشتر و گفتار [در آن هنگام‌] راستين‌تر است"
  73,7,"[و] تو را، در روز، آمد و شدى دراز است"
  73,8,و نام پروردگار خود را ياد كن و تنها به او بپرداز
  73,9,"[اوست‌] پروردگار خاور و باختر، خدايى جز او نيست، پس او را كارساز خويش اختيار كن"
  73,10,و بر آنچه مى‌گويند شكيبا باش و از آنان با دورى گزيدنى خوش فاصله بگير
  73,11,و مرا با تكذيب‌كنندگان توانگر واگذار و اندكى مهلتشان ده
  73,12,در حقيقت پيش ما زنجيرها و دوزخ،
  73,13,و غذايى گلوگير و عذابى پر درد است
  73,14,روزى كه زمين و كوهها به لرزه درآيند و كوهها به سان ريگ روان گردند
  73,15,بى‌گمان، ما به سوى شما فرستاده‌اى كه گواه بر شماست روانه كرديم، همان گونه كه فرستاده‌اى به سوى فرعون فرستاديم
  73,16,"[ولى‌] فرعون به آن فرستاده عصيان ورزيد، پس ما او را به سختى فرو گرفتيم"
  73,17,پس اگر كفر بورزيد، چگونه از روزى كه كودكان را پير مى‌گرداند، پرهيز توانيد كرد؟
  73,18,"آسمان از [بيم‌] آن [روز] در هم شكافد؛ وعده او انجام يافتنى است"
  73,19,"قطعاً اين [آيات‌] اندرزى است، تا هر كه بخواهد به سوى پروردگار خود راهى در پيش گيرد"
  73,20,"در حقيقت، پروردگارت مى‌داند كه تو و گروهى از كسانى كه با تواند، نزديك به دو سوم از شب يا نصف آن يا يك سوم آن را [به نماز] برمى‌خيزيد، و خداست كه شب و روز را اندازه‌گيرى مى‌كند. [او ]مى‌داند كه [شما] هرگز حساب آن را نداريد، پس بر شما ببخشود، [اينك‌] هر چه از قرآن ميسر مى‌شود بخوانيد. [خدا] مى‌داند كه به زودى در ميانتان بيمارانى خواهند بود، و [عده‌اى‌] ديگر در زمين سفر مى‌كنند [و] در پى روزى خدا هستند، و [گروهى‌] ديگر در راه خدا پيكار مى‌نمايند. پس هر چه از [قرآن‌] ميسر شد تلاوت كنيد و نماز را برپا داريد و زكات را بپردازيد و وام نيكو به خدا دهيد؛ و هر كار خوبى براى خويش از پيش فرستيد آن را نزد خدا بهتر و با پاداشى بيشتر باز خواهيد يافت. و از خدا طلب آمرزش كنيد كه خدا آمرزنده مهربان است"