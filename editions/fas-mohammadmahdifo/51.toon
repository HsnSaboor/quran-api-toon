quran[60]{c,v,t}:
  51,1,سوگند به بادهاى ذره‌افشان،
  51,2,و ابرهاى گرانبار،
  51,3,و سبك سيران،
  51,4,"و تقسيم‌كنندگان كار[ها]،"
  51,5,كه آنچه وعده داده شده‌ايد راست است،
  51,6,"و [روز] پاداش واقعيت دارد"
  51,7,سوگند به آسمان مشبّك،
  51,8,"كه شما [درباره قرآن‌] در سخنى گوناگونيد"
  51,9,"[بگوى‌] تا هر كه از آن برگشته، برگشته باشد"
  51,10,مرگ بر دروغپردازان
  51,11,همانان كه در ورطه نادانى بى‌خبرند
  51,12,"پرسند: «روز پاداش كى است؟»"
  51,13,"همان روز كه آنان بر آتش، عقوبت [و آزموده‌] شوند"
  51,14,"عذاب [موعود] خود را بچشيد، اين است همان [بلايى‌] كه با شتاب خواستار آن بوديد"
  51,15,پرهيزگاران در باغها و چشمه سارانند
  51,16,آنچه را پروردگارشان عطا فرموده مى‌گيرند، زيرا كه آنها پيش از اين نيكوكار بودند
  51,17,و از شب اندكى را مى‌غنودند
  51,18,"و در سحرگاهان [از خدا] طلب آمرزش مى‌كردند"
  51,19,"و در اموالشان براى سائل و محروم حقى [معين‌] بود"
  51,20,"و روى زمين براى اهل يقين نشانه‌هايى [متقاعدكننده‌] است،"
  51,21,و در خود شما؛ پس مگر نمى‌بينيد؟
  51,22,و روزى شما و آنچه وعده داده شده‌ايد در آسمان است
  51,23,پس سوگند به پروردگار آسمان و زمين، كه واقعاً او حق است همان گونه كه خود شما سخن مى‌گوييد
  51,24,آيا خبر مهمانان ارجمند ابراهيم به تو رسيد؟
  51,25,"چون بر او درآمدند؛ پس سلام گفتند. گفت: «سلام، مردمى ناشناسيد.»"
  51,26,"پس آهسته به سوى زنش رفت و گوساله‌اى فربه [و بريان‌] آورد"
  51,27,"آن را به نزديكشان برد [و] گفت: «مگر نمى‌خوريد؟»"
  51,28,"و [در دلش‌] از آنان احساس ترسى كرد. گفتند: «مترس.» و او را به پسرى دانا مژده دادند"
  51,29,"و زنش با فريادى [از شگفتى‌] سر رسيد و بر چهره خود زد و گفت: «زنى پير نازا [چگونه بزايد]؟»"
  51,30,"گفتند: «پروردگارت چنين فرموده است. او خود حكيم داناست.»"
  51,31,"[ابراهيم‌] گفت: «اى فرستادگان، مأموريت شما چيست؟»"
  51,32,"گفتند: «ما به سوى مردمى پليدكار فرستاده شده‌ايم،"
  51,33,"تا سنگهايى از گِل رُس بر [سر] آنان فرو فرستيم"
  51,34,"[كه‌] نزد پروردگارت براى مسرفان نشان‌گذارى شده است"
  51,35,"پس هر كه از مؤمنان در آن [شهرها] بود بيرون برديم"
  51,36,"و[لى‌] در آنجا جز يك خانه از فرمانبران [خدا بيشتر] نيافتيم"
  51,37,و در آنجا براى آنها كه از عذاب پر درد مى‌ترسند، عبرتى به جاى گذاشتيم
  51,38,"و [نيز] در [ماجراى‌] موسى، چون او را با حجتى آشكار به سوى فرعون گسيل داشتيم"
  51,39,"پس [فرعون‌] با اركان [دولت‌] خود روى برتافت و گفت: «[اين شخص،] ساحر يا ديوانه‌اى است.»"
  51,40,"[تا] او و سپاهيانش را گرفتيم و آنان را در دريا افكنديم در حالى كه او [در آخرين لحظه‌] نكوهشگر [خود] بود"
  51,41,"و در [ماجراى‌] عاد [نيز]، چون بر [سر] آنها آن باد مُهلِك را فرستاديم"
  51,42,به هر چه مى‌وزيد آن را چون خاكستر استخوان مرده مى‌گردانيد
  51,43,"و در [ماجراى‌] ثمود [نيز عبرتى بود]، آنگاه كه به ايشان گفته شد: «تا چندى برخوردار شويد.»"
  51,44,"تا [آنكه‌] از فرمان پروردگار خود سر برتافتند و در حالى كه آنها مى‌نگريستند، آذرخش آنان را فرو گرفت"
  51,45,در نتيجه نه توانستند به پاى خيزند و نه طلب يارى كنند
  51,46,"و قوم نوح [نيز] پيش از آن [اقوام نامبرده همين گونه هلاك شدند]، زيرا آنها مردمى نافرمان بودند"
  51,47,"و آسمان را به قدرت خود برافراشتيم، و بى‌گمان، ما [آسمان‌]گستريم"
  51,48,و زمين را گسترانيده‌ايم و چه نيكو گسترندگانيم
  51,49,"و از هر چيزى دو گونه [يعنى نر و ماده‌] آفريديم، اميد كه شما عبرت گيريد"
  51,50,پس به سوى خدا بگريزيد، كه من شما را از طرف او بيم‌دهنده‌اى آشكارم
  51,51,و با خدا معبودى ديگر قرار مدهيد كه من از جانب او هشداردهنده‌اى آشكارم
  51,52,"بدين سان بر كسانى كه پيش از آنها بودند هيچ پيامبرى نيامد جز اينكه گفتند: «ساحر يا ديوانه‌اى است.»"
  51,53,"آيا همديگر را به اين [سخن‌] سفارش كرده بودند؟ [نه!] بلكه آنان مردمى سركش بودند"
  51,54,پس، از آنان روى بگردان، كه تو در خور نكوهش نيستى
  51,55,و پند ده، كه مؤمنان را پند سود بخشد
  51,56,و جن و انس را نيافريدم جز براى آنكه مرا بپرستند
  51,57,از آنان هيچ روزيى نمى‌خواهم، و نمى‌خواهم كه مرا خوراك دهند
  51,58,خداست كه خود روزى بخش نيرومند استوار است
  51,59,"پس براى كسانى كه ستم كردند بهره‌اى است از عذاب، همانند بهره عذاب ياران [قبلى‌]شان. پس [بگو:] در خواستن عذاب از من، شتابزدگى نكنند"
  51,60,پس واى بر كسانى كه كافر شده‌اند از آن روزى كه وعده يافته‌اند