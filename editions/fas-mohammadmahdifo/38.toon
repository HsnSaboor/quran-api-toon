quran[88]{c,v,t}:
  38,1,صاد. سوگند به قرآن پراندرز
  38,2,آرى، آنان كه كفر ورزيدند در سركشى و ستيزه‌اند
  38,3,"چه بسيار نسلها كه پيش از ايشان هلاك كرديم كه [ما را] به فرياد خواندند، و[لى‌] ديگر مجال گريز نبود"
  38,4,"و از اينكه هشداردهنده‌اى از خودشان برايشان آمده درشگفتند، و كافران مى گويند: «اين، ساحرى شيّاد است"
  38,5,"آيا خدايان [متعدد] را خداى واحدى قرار داده؟ اين واقعاً چيز عجيبى است.»"
  38,6,"و بزرگانشان روان شدند [و گفتند:] «برويد و بر خدايان خود ايستادگى نماييد كه اين امر قطعاً هدف [ما]ست"
  38,7,"[از طرفى‌] اين [مطلب‌] را در آيين اخير [عيسوى هم‌] نشنيده‌ايم، اين [ادّعا] جز دروغ‌بافى نيست"
  38,8,"آيا از ميان ما قرآن بر او نازل شده است؟» [نه!] بلكه آنان در باره قرآنِ من دودلند. [نه،] بلكه هنوز عذاب [مرا] نچشيده‌اند"
  38,9,آيا گنجينه‌هاى رحمت پروردگار ارجمندِ بسيار بخشنده تو نزد ايشان است؟
  38,10,"آيا فرمانروايى آسمانها و زمين و آنچه ميان آن دو است از آنِ ايشان است؟ [اگر چنين است‌] پس [با چنگ زدن‌] در آن اسباب به بالا روند"
  38,11,"اين سپاهك دسته‌هاى دشمن در آنجا [=بَدْر] در هم شكستنى‌اند"
  38,12,"پيش از ايشان قوم نوح و عاد و فرعونِ صاحب [عمارت و] خرگاهها تكذيب كردند"
  38,13,"و ثمود و قوم لوط و اصحاب ايكه [نيز به تكذيب پرداختند] آنها دسته‌هاى مخالف بودند"
  38,14,"هيچ كدام نبودند كه پيامبران [ما] را تكذيب نكنند، پس عقوبت [من بر آنان‌] سزاوار آمد"
  38,15,"و اينان جز يك فرياد را انتظار نمى‌بَرند كه هيچ [مجال‌] سر خاراندنى در آن نيست"
  38,16,"و گفتند: «پروردگارا، پيش از [رسيدن‌] روز حساب، بهره ما را [از عذاب‌] به شتاب به ما بده.»"
  38,17,"بر آنچه مى‌گويند صبر كن، و داوود، بنده ما را كه داراى امكانات [متعدّد] بود به ياد آور؛ آرى، او بسيار بازگشت‌كننده [به سوى خدا] بود"
  38,18,"ما كوهها را با او مسخّر ساختيم [كه‌] شامگاهان و بامدادان خداوند را نيايش مى‌كردند"
  38,19,"و پرندگان را از هر سو [بر او] گرد [آورديم‌] همگى [به نواى دلنوازش‌] به سوى او بازگشت‌كننده [و خدا را ستايشگر] بودند"
  38,20,و پادشاهيش را استوار كرديم و او را حكمت و كلام فيصله‌دهنده عطا كرديم
  38,21,"و آيا خبر دادخواهان -چون از نمازخانه [او] بالا رفتند- به تو رسيد؟"
  38,22,"وقتى [به طور ناگهانى‌] بر داوود درآمدند، و او از آنان به هراس افتاد، گفتند: «مترس، [ما] دو مدّعى [هستيم‌] كه يكى از ما بر ديگرى تجاوز كرده، پس ميان ما به حق داورى كن، و از حق دور مشو، و ما را به راه راست راهبر باش.»"
  38,23,"«اين [شخص‌] برادر من است. او را نود و نه ميش، و مرا يك ميش است، و مى‌گويد: آن را به من بسپار، و در سخنورى بر من غالب آمده است.»"
  38,24,"[داوود] گفت: «قطعاً او در مطالبه ميش تو [اضافه‌] بر ميش‌هاى خودش، بر تو ستم كرده، و در حقيقت بسيارى از شريكان به همديگر ستم روا مى‌دارند، به استثناى كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، و اينها بس اندكند، و داوود دانست كه ما او را آزمايش كرده‌ايم. پس، از پروردگارش آمرزش خواست و به رو درافتاد و توبه كرد"
  38,25,"و بر او اين [ماجرا] را بخشوديم؛ و در حقيقت براى او پيش ما تقرّب و فرجامى خوش خواهد بود"
  38,26,"اى داوود، ما تو را در زمين خليفه [و جانشين‌] گردانيديم؛ پس ميان مردم به حق داورى كن، و زنهار از هوس پيروى مكن كه تو را از راه خدا به در كند. در حقيقت كسانى كه از راه خدا به در مى‌روند، به [سزاى‌] آنكه روز حساب را فراموش كرده‌اند عذابى سخت خواهند داشت"
  38,27,"و آسمان و زمين و آنچه را كه ميان اين دو است به باطل نيافريديم، اين گمان كسانى است كه كافر شده [و حق‌پوشى كرده‌]اند، پس واى از آتش بر كسانى كه كافر شده‌اند"
  38,28,"يا [مگر] كسانى را كه گرويده و كارهاى شايسته كرده‌اند، چون مفسدان در زمين مى‌گردانيم، يا پرهيزگاران را چون پليدكاران قرار مى‌دهيم؟"
  38,29,"[اين‌] كتابى مبارك است كه آن را به سوى تو نازل كرده‌ايم تا در [باره‌] آيات آن بينديشند، و خردمندان پند گيرند"
  38,30,"و سليمان را به داوود بخشيديم. چه نيكو بنده‌اى. به راستى او توبه‌كار [و ستايشگر] بود"
  38,31,"هنگامى كه [طرف‌] غروب، اسبهاى اصيل را بر او عرضه كردند،"
  38,32,"[سليمان‌] گفت: «واقعاً من دوستى اسبان را بر ياد پروردگارم ترجيح دادم تا [هنگام نماز گذشت و خورشيد] در پس حجاب ظلمت شد.»"
  38,33,"[گفت: « اسبها] را نزد من باز آوريد.» پس شروع كرد به دست كشيدن بر ساقها و گردن آنها [و سرانجام وقف كردن آنها در راه خدا]"
  38,34,و قطعاً سليمان را آزموديم و بر تخت او جسدى بيفكنديم؛ پس به توبه باز آمد
  38,35,"گفت: «پروردگارا، مرا ببخش و مُلكى به من ارزانى دار كه هيچ كس را پس از من سزاوار نباشد، در حقيقت، تويى كه خود بسيار بخشنده‌اى.»"
  38,36,پس باد را در اختيار او قرار داديم كه هر جا تصميم مى‌گرفت، به فرمان او نرم، روان مى‌شد
  38,37,"و شيطانها را [از] بنّا و غواص،"
  38,38,"تا [وحشيان‌] ديگر را كه جفت جفت با زنجيرها به هم بسته بودند [تحت فرمانش درآورديم‌]"
  38,39,"[گفتيم:] «اين بخشش ماست، [آن را] بى‌شمار ببخش يا نگاه دار.»"
  38,40,و قطعاً براى او در پيشگاه ما تقرّب و فرجام نيكوست
  38,41,"و بنده ما ايوب را به ياد آور، آنگاه كه پروردگارش را ندا داد كه: «شيطان مرا به رنج و عذاب مبتلا كرد.»"
  38,42,"[به او گفتيم:] «با پاى خود [به زمين‌] بكوب، اينك اين چشمه‌سارى است سرد و آشاميدنى.»"
  38,43,"و [مجدداً] كسانش را و نظاير آنها را همراه آنها به او بخشيديم، تا رحمتى از جانب ما و عبرتى براى خردمندان باشد"
  38,44,"[و به او گفتيم:] «يك بسته تركه به دستت برگير و [همسرت را] با آن بزن و سوگند مشكن.» ما او را شكيبا يافتيم. چه نيكوبنده‌اى! به راستى او توبه‌كار بود"
  38,45,و بندگان ما ابراهيم و اسحاق و يعقوب را كه نيرومند و ديده‌ور بودند به يادآور
  38,46,ما آنان را با موهبت ويژه‌اى -كه يادآورى آن سراى بود- خالص گردانيديم
  38,47,و آنان در پيشگاه ما جداً از برگزيدگان نيكانند
  38,48,"و اسماعيل و يسع و ذوالكفل را به ياد آور [كه‌] همه از نيكانند"
  38,49,اين يادكردى است، و قطعاً براى پرهيزگاران فرجامى نيك است
  38,50,"باغهاى هميشگى در حالى كه درهاى [آنها] برايشان گشوده‌است"
  38,51,"در آنجا تكيه مى‌زنند [و] ميوه‌هاى فراوان و نوشيدنى در آنجا طلب مى‌كنند"
  38,52,"و نزدشان [دلبران‌] فروهشته‌نگاه همسال است"
  38,53,اين است آنچه براى روز حساب به شما وعده داده مى‌شد
  38,54,"[مى‌گويند:] «در حقيقت، اين روزىِ ماست و آن را پايانى نيست.»"
  38,55,"اين است [حال بهشتيان‌] و [اما] براى طغيانگران واقعاً بد فرجامى است"
  38,56,به جهنّم درمى‌آيند، و چه بد آرامگاهى است
  38,57,اين جوشاب و چركاب است، بايد آن را بچشند
  38,58,"و از همين گونه، انواع ديگر [عذابها]"
  38,59,"اينها گروهى‌اند كه با شما به اجبار [در آتش‌] درمى‌آيند. بدا به حال آنها، زيرا آنان داخل آتش مى‌شوند"
  38,60,"[به رؤساى خود] مى‌گويند: «بلكه بر خود شما خوش مباد! اين [عذاب‌] را شما خود براى ما از پيش فراهم آورديد، و چه بد قرارگاهى است.»"
  38,61,"مى‌گويند: «پروردگارا، هر كس اين [عذاب‌] را از پيش براى ما فراهم آورده، عذاب او را در آتش دو چندان كن.»"
  38,62,"و مى‌گويند: «ما را چه شده است كه مردانى را كه ما آنان را از [زمره‌] اشرار مى‌شمرديم نمى‌بينيم؟"
  38,63,"آيا آنان را [در دنيا] به ريشخند مى‌گرفتيم يا چشمها[ى ما] بر آنها نمى‌افتد؟»"
  38,64,اين مجادله اهل آتش قطعاً راست است
  38,65,"بگو: «من فقط هشداردهنده‌اى هستم، و جز خداى يگانه قهار معبودى ديگر نيست"
  38,66,پروردگار آسمانها و زمين و آنچه ميان آن دو است، همان شكست‌ناپذير آمرزنده
  38,67,"بگو: «اين خبرى بزرگ است،"
  38,68,"[كه‌] شما از آن روى برمى‌تابيد"
  38,69,مرا در باره ملاء اعلى هيچ دانشى نبود آنگاه كه مجادله مى‌كردند
  38,70,"به من هيچ [چيز] وحى نمى‌شود، جز اينكه من هشداردهنده‌اى آشكارم"
  38,71,"آنگاه كه پروردگارت به فرشتگان گفت: «من بشرى را از گِل خواهم آفريد"
  38,72,"پس چون او را [كاملاً] درست كردم و از روح خويش در آن دميدم، سجده‌كنان براى او [به خاك‌] بيفتيد.»"
  38,73,پس همه فرشتگان يكسره سجده كردند
  38,74,"مگر ابليس [كه‌] تكبر نمود و از كافران شد"
  38,75,"فرمود: «اى ابليس، چه چيز تو را مانع شد كه براى چيزى كه به دستان قدرت خويش خلق كردم سجده آورى؟ آيا تكبر نمودى يا از [جمله‌] برترى‌جويانى؟»"
  38,76,"گفت: «من از او بهترم؛ مرا از آتش آفريده‌اى و او را از گِل آفريده‌اى.»"
  38,77,"فرمود: «پس، از آن [مقام‌] بيرون شو، كه تو رانده‌اى"
  38,78,و تا روز جزا لعنت من بر تو باد.»
  38,79,"گفت: «پروردگارا، پس مرا تا روزى كه برانگيخته مى‌شوند مهلت ده.»"
  38,80,"فرمود: «در حقيقت، تو از مهلت‌يافتگانى،"
  38,81,تا روز معين معلوم.»
  38,82,"[شيطان‌] گفت: «پس به عزّت تو سوگند كه همگى را جداً از راه به در مى‌برم،"
  38,83,مگر آن بندگان پاكدل تو را.»
  38,84,"فرمود: «حق [از من‌] است و حق را مى‌گويم"
  38,85,هرآينه جهنّم را از تو و از هر كس از آنان كه تو را پيروى كند، از همگى‌شان، خواهم انباشت.»
  38,86,"بگو: «مزدى بر اين [رسالت‌] از شما طلب نمى‌كنم و من از كسانى نيستم كه چيزى از خود بسازم و به خدا نسبت دهم"
  38,87,"اين [قرآن‌] جز پندى براى جهانيان نيست"
  38,88,و قطعاً پس از چندى خبر آن را خواهيد دانست.»