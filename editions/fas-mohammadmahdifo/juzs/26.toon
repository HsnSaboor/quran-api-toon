quran[195]{c,v,t}:
  46,1,حاء، ميم
  46,2,فرو فرستادن اين كتاب، از جانب خداى ارجمند حكيم است
  46,3,"[ما] آسمانها و زمين و آنچه را كه ميان آن دو است جز به حق و [تا] زمانى معيّن نيافريديم، و كسانى كه كافر شده‌اند، از آنچه هشدار داده شده‌اند رويگردانند"
  46,4,"بگو: «به من خبر دهيد، آنچه را به جاى خدا فرا مى‌خوانيد به من نشان دهيد كه چه چيزى از زمين [را] آفريده يا [مگر] آنان را در [كار] آسمانها مشاركتى است؟ اگر راست مى‌گوييد، كتابى پيش از اين [قرآن ]يا بازمانده‌اى از دانش نزد من آوريد.»"
  46,5,و كيست گمراه‌تر از آن كس كه به جاى خدا كسى را مى‌خواند كه تا روز قيامت او را پاسخ نمى‌دهد، و آنها از دعايشان بى‌خبرند؟
  46,6,و چون مردم محشور گردند، دشمنان آنان باشند و به عبادتشان انكار ورزند
  46,7,"و چون آيات روشن ما بر ايشان خوانده شود، آنان كه چون حقيقت به سويشان آمد منكر آن شدند، گفتند: «اين سحرى آشكار است.»"
  46,8,"يا مى‌گويند: «اين [كتاب‌] را بربافته است.» بگو: «اگر آن را بربافته باشم؛ در برابر خدا اختيار چيزى براى من نداريد. او آگاه‌تر است به آنچه [با طعنه‌] در آن فرو مى‌رويد. گواه بودن او ميان من و شما بس است، و اوست آمرزنده مهربان.»"
  46,9,"بگو: «من از [ميان‌] پيامبران، نودرآمدى نبودم و نمى‌دانم با من و با شما چه معامله‌اى خواهد شد. جز آنچه را كه به من وحى مى‌شود، پيروى نمى‌كنم؛ و من جز هشداردهنده‌اى آشكار [بيش‌] نيستم.»"
  46,10,"بگو: «به من خبر دهيد، اگر اين [قرآن‌] از نزد خدا باشد و شما بدان كافر شده باشيد و شاهدى از فرزندان اسرائيل به مشابهت آن [با تورات‌] گواهى داده و ايمان آورده باشد، و شما تكبّر نموده باشيد [آيا باز هم شما ستمكار نيستيد؟] البته خدا قوم ستمگر را هدايت نمى‌كند.»"
  46,11,"و كسانى كه كافر شدند، به آنان كه گرويده‌اند گفتند: «اگر [اين دين‌] خوب بود، بر ما بدان پيشى نمى‌گرفتند.» و چون بدان هدايت نيافته‌اند، به زودى خواهند گفت: «اين دروغى كهنه است.»"
  46,12,"و [حال آنكه‌] پيش از آن، كتاب موسى، راهبر و [مايه‌] رحمتى بود؛ و اين [قرآن‌] كتابى است به زبان عربى كه تصديق‌كننده [آن‌] است، تا كسانى را كه ستم كرده‌اند هشدار دهد و براى نيكوكاران مژده‌اى باشد"
  46,13,"محققاً كسانى كه گفتند: «پروردگار ما خداست» سپس ايستادگى كردند، بيمى بر آنان نيست و غمگين نخواهند شد"
  46,14,ايشان اهل بهشتند كه به پاداش آنچه انجام مى‌دادند جاودانه در آن مى‌مانند
  46,15,"و انسان را [نسبت‌] به پدر و مادرش به احسان سفارش كرديم. مادرش با تحمّل رنج به او باردار شد و با تحمّل رنج او را به دنيا آورد. و باربرداشتن و از شيرگرفتن او سى ماه است، تا آنگاه كه به رشد كامل خود برسد و به چهل سال برسد، مى‌گويد: «پروردگارا، بر دلم بيفكن تا نعمتى را كه به من و به پدر و مادرم ارزانى داشته‌اى سپاس گويم و كار شايسته‌اى انجام دهم كه آن را خوش دارى، و فرزندانم را برايم شايسته گردان؛ در حقيقت، من به درگاه تو توبه آوردم و من از فرمان‌پذيرانم.»"
  46,16,"اينانند كسانى كه بهترين آنچه را انجام داده‌اند از ايشان خواهيم پذيرفت و از بديهايشان درخواهيم گذشت؛ در [زمره‌] بهشتيانند؛ [همان‌] وعده راستى كه بدانان وعده داده مى‌شده است"
  46,17,"و آن كس كه به پدر و مادر خود گويد: «اف بر شما، آيا به من وعده مى‌دهيد كه زنده خواهم شد و حال آنكه پيش از من نسلها سپرى [و نابود] شدند.» و آن دو به [درگاه‌] خدا زارى مى‌كنند: «واى بر تو، ايمان بياور. وعده [و تهديد] خدا حق است.» و[لى پسر] پاسخ مى‌دهد: «اينها جز افسانه‌هاى گذشتگان نيست.»"
  46,18,"آنان كسانى‌اند كه گفتار [خدا] عليه ايشان -همراه با امتهايى از جنيان و آدميان كه پيش از آنان روزگار به سر بردند- به حقيقت پيوست، بى‌گمان آنان زيانكار بودند"
  46,19,"و براى هر يك در [نتيجه‌] آنچه انجام داده‌اند درجاتى است، و تا [خدا پاداش‌] اعمالشان را تمام بدهد؛ و آنان مورد ستم قرار نخواهند گرفت"
  46,20,"و آن روز كه آنهايى را كه كفر ورزيده‌اند، بر آتش عرضه مى‌دارند [به آنان مى گويند:] «نعمتهاى پاكيزه خود را در زندگى دنيايتان [خودخواهانه‌] صَرف كرديد و از آنها برخوردار شديد؛ پس امروز به [سزاى ]آنكه در زمين بناحق سركشى مى‌نموديد و به سبب آنكه نافرمانى مى‌كرديد، به عذاب خفت‌[آور] كيفر مى‌يابيد.»"
  46,21,"و برادر عاديان را به ياد آور، آنگاه كه قوم خويش را در ريگستان بيم داد -در حالى كه پيش از او و پس از او [نيز] قطعاً هشداردهندگانى گذشته بودند- كه: «جز خدا را مپرستيد؛ واقعاً من بر شما از عذاب روزى هولناك مى‌ترسم.»"
  46,22,"گفتند: «آيا آمده‌اى كه ما را از خدايانمان برگردانى؟ پس اگر راست مى‌گويى، آنچه به ما وعده مى‌دهى [بر سرمان‌] بياور.»"
  46,23,"گفت: «آگاهى فقط نزد خداست، و آنچه را بدان فرستاده شده‌ام به شما مى‌رسانم، ولى من شما را گروهى مى‌بينم كه در جهل اصرار مى‌ورزيد.»"
  46,24,"پس چون آن [عذاب‌] را [به صورت‌] ابرى روى‌آورنده به سوى واديهاى خود ديدند، گفتند: «اين ابرى است كه بارش‌دهنده ماست.» [هود گفت: «نه،] بلكه همان چيزى است كه به شتاب خواستارش بوديد: بادى است كه در آن عذابى پر درد [نهفته‌] است"
  46,25,همه چيز را به دستور پروردگارش بنيان‌كن مى‌كند.» پس چنان شدند كه جز سراهايشان ديده نمى‌شد. اين چنين گروه بدكاران را سزا مى‌دهيم
  46,26,"و به راستى در چيزهايى به آنان امكانات داده بوديم كه به شما در آنها [چنان‌] امكاناتى نداده‌ايم، و براى آنان گوش و ديده‌ها و دلهايى [نيرومندتر از شما] قرار داده بوديم، و[لى‌] چون به نشانه‌هاى خدا انكار ورزيدند [نه‌] گوششان و نه ديدگانشان و نه دلهايشان، به هيچ وجه به دردشان نخورد، و آنچه ريشخندش مى‌كردند به سرشان آمد"
  46,27,و بى‌گمان، همه شهرهاى پيرامون شما را هلاك كرده و آيات خود را گونه‌گون بيان داشته‌ايم، اميد كه آنان بازگردند
  46,28,"پس چرا آن كسانى را كه غير از خدا، به منزله معبودانى، براى تقرّب [به خدا] اختيار كرده بودند، آنان را يارى نكردند بلكه از دستشان دادند؟ و اين بود دروغ آنان و آنچه برمى‌بافتند"
  46,29,"و چون تنى چند از جِن را به سوى تو روانه كرديم كه قرآن را بشنوند؛ پس چون بر آن حاضر شدند [به يكديگر] گفتند: «گوش فرا دهيد.» و چون به انجام رسيد، هشداردهنده به سوى قوم خود بازگشتند"
  46,30,"گفتند: «اى قوم ما، ما كتابى را شنيديم كه بعد از موسى نازل شده [و] تصديق‌كننده [كتابهاى‌] پيش از خود است، و به سوى حق و به سوى راهى راست راهبرى مى‌كند"
  46,31,"اى قوم ما، دعوت‌كننده خدا را پاسخ [مثبت‌] دهيد و به او ايمان آوريد تا [خدا] برخى از گناهانتان را بر شما ببخشايد و از عذابى پر درد پناهتان دهد"
  46,32,"و كسى كه دعوت‌كننده خدا را اجابت نكند، در زمين درمانده‌كننده [خدا] نيست و در برابر او دوستانى ندارد. آنان در گمراهى آشكارى‌اند"
  46,33,"مگر ندانسته‌اند كه آن خدايى كه آسمانها و زمين را آفريده و در آفريدن آنها درمانده نگرديد؛ مى‌تواند مردگان را [نيز] زنده كند؟ آرى، اوست كه بر همه چيز تواناست"
  46,34,"و روزى كه كافران بر آتش عرضه مى‌شوند [از آنان مى‌پرسند:] «آيا اين راست نيست؟» مى‌گويند: «سوگند به پروردگارمان كه آرى.» مى‌فرمايد: «پس به [سزاى‌] آنكه انكار مى‌كرديد عذاب را بچشيد.»"
  46,35,"پس همان گونه كه پيامبران نستوه، صبر كردند، صبر كن، و براى آنان شتابزدگى به خرج مده. روزى كه آنچه را وعده داده مى‌شوند بنگرند، گويى كه آنان جز ساعتى از روز را [در دنيا] نمانده‌اند؛ [اين‌] ابلاغى است. پس آيا جز مردم نافرمان هلاكت خواهند يافت؟"
  47,1,"كسانى كه كفر ورزيدند و [مردم را] از راه خدا باز داشتند، [خدا] اعمال آنان را تباه خواهد كرد"
  47,2,"و آنان كه ايمان آورده و كارهاى شايسته كرده‌اند و به آنچه بر محمد [ص‌] نازل آمده گرويده‌اند -[كه‌] آن خود حق [و] از جانب پروردگارشان است- [خدا نيز] بديهايشان را زدود و حال [و روز]شان را بهبود بخشيد"
  47,3,"اين بدان سبب است كه آنان كه كفر ورزيدند، از باطل پيروى كردند، و كسانى كه ايمان آوردند از همان حق -كه از جانب پروردگارشان است- پيروى كردند. اين گونه خدا براى [بيدارى‌] مردم مثالهايشان را مى‌زند"
  47,4,"پس چون با كسانى كه كفر ورزيده‌اند برخورد كنيد، گردنها[يشان‌] را بزنيد. تا چون آنان را [در كشتار] از پاى درآورديد، پس [اسيران را] استوار در بند كشيد؛ سپس يا [بر آنان‌] منّت نهيد [و آزادشان كنيد] و يا فديه [و عوض از ايشان بگيريد]، تا در جنگ، اسلحه بر زمين گذاشته شود. اين است [دستور خدا]؛ و اگر خدا مى‌خواست، از ايشان انتقام مى‌كشيد، ولى [فرمان پيكار داد] تا برخى از شما را به وسيله برخى [ديگر] بيازمايد، و كسانى كه در راه خدا كشته شده‌اند، هرگز كارهايشان را ضايع نمى‌كند"
  47,5,به زودى آنان را راه مى‌نمايد و حالشان را نيكو مى‌گرداند
  47,6,و در بهشتى كه براى آنان وصف كرده، آنان را درمى‌آورد
  47,7,اى كسانى كه ايمان آورده‌ايد، اگر خدا را يارى كنيد ياريتان مى‌كند و گامهايتان را استوار مى‌دارد
  47,8,"و كسانى كه كفر ورزيدند، نگونسارى بر آنان باد؛ و [خدا] اعمالشان را برباد داد"
  47,9,"اين بدان سبب است كه آنان آنچه را خدا نازل كرده است خوش نداشتند، و [خدا نيز] كارهايشان را باطل كرد"
  47,10,"مگر در زمين نگشته‌اند، تا ببينند فرجام كسانى كه پيش از آنها بودند به كجا انجاميده است؟ خدا زير و زبرشان كرد و كافران را نظاير [همين كيفرها در پيش‌] است"
  47,11,"چرا كه خدا سرپرست كسانى است كه ايمان آورده‌اند، ولى كافران را سرپرست [و يارى‌] نيست"
  47,12,"خدا كسانى را كه ايمان آورده و كارهاى شايسته كرده‌اند، در باغهايى كه از زير [درختان‌] آنها نهرها روان است درمى‌آورد، و [حال آنكه‌] كسانى كه كافر شده‌اند، [در ظاهر] بهره مى‌برند و همان گونه كه چارپايان مى‌خورند، مى‌خورند، و[لى ]جايگاه آنها آتش است"
  47,13,"و بسا شهرها كه نيرومندتر از آن شهرى بود كه تو را [از خود] بيرون راند، كه ما هلاكشان كرديم و براى آنها يار [و ياورى‌] نبود"
  47,14,آيا كسى كه بر حجتى از جانب پروردگار خويش است، چون كسى است كه بدى كردارش براى او زيبا جلوه داده شده و هوسهاى خود را پيروى كرده‌اند؟
  47,15,"مَثَل بهشتى كه به پرهيزگاران وعده داده شده [چون باغى است كه‌] در آن نهرهايى است از آبى كه [رنگ و بو و طعمش‌] برنگشته؛ و جويهايى از شيرى كه مزه‌اش دگرگون نشود؛ و رودهايى از باده‌اى كه براى نوشندگان لذتى است؛ و جويبارهايى از انگبين ناب. و در آنجا از هر گونه ميوه براى آنان [فراهم‌] است و [از همه بالاتر] آمرزش پروردگار آنهاست. [آيا چنين كسى در چنين باغى دل‌انگيز] مانند كسى است كه جاودانه در آتش است و آبى جوشان به خوردشان داده مى‌شود [تا] روده‌هايشان را از هم فرو پاشد؟"
  47,16,"و از ميان [منافقان‌] كسانى‌اند كه [در ظاهر] به [سخنان‌] تو گوش مى‌دهند، ولى چون از نزد تو بيرون مى‌روند، به دانش يافتگان مى‌گويند: «هم اكنون چه گفت؟» اينان همانانند كه خدا بر دلهايشان مهر نهاده است و از هوسهاى خود پيروى كرده‌اند"
  47,17,"و[لى‌] آنان كه به هدايت گراييدند [خدا] آنان را هر چه بيشتر هدايت بخشيد و [توفيق‌] پرهيزگارى‌شان داد"
  47,18,"آيا [كافران‌] جز اين انتظار مى‌برند كه رستاخيز به ناگاه بر آنان فرا رسد؟ و علامات آن اينك پديد آمده است. پس اگر [رستاخيز] بر آنان دررسد، ديگر كجا جاى اندرزشان است؟"
  47,19,"پس بدان كه هيچ معبودى جز خدا نيست؛ و براى گناه خويش آمرزش جوى؛ و براى مردان و زنان با ايمان [طلب مغفرت كن‌]؛ و خداست كه فرجام و م‌آل [هر يك از] شما را مى‌داند"
  47,20,"و كسانى كه ايمان آورده‌اند مى‌گويند: «چرا سوره‌اى [در باره جهاد] نازل نمى شود؟» اما چون سوره‌اى صريح نازل شد و در آن نام كارزار آمد، آنان كه در دلهايشان مرضى هست، مانند كسى كه به حال بيهوشى مرگ افتاده به تو مى‌نگرند"
  47,21,"[ولى‌] فرمان‌پذيرى و سخنى شايسته برايشان بهتر است. و چون كار به تصميم كشد، قطعاً خير آنان در اين است كه با خدا راست‌[دل‌] باشند"
  47,22,"پس [اى منافقان،] آيا اميد بستيد كه چون [از خدا] برگشتيد [يا سرپرست مردم شديد] در [روى‌] زمين فساد كنيد و خويشاونديهاى خود را از هم بگسليد؟"
  47,23,"اينان همان كسانند كه خدا آنان را لعنت نموده و [گوش دل‌] ايشان را ناشنوا و چشمهايشان را نابينا كرده است"
  47,24,"آيا به آيات قرآن نمى‌انديشند؟ يا [مگر] بر دلهايشان قفلهايى نهاده شده است؟"
  47,25,"بى‌گمان، كسانى كه پس از آنكه [راه‌] هدايت بر آنان روشن شد [به حقيقت‌] پشت كردند، شيطان آنان را فريفت و به آرزوهاى دور و درازشان انداخت"
  47,26,"چرا كه آنان به كسانى كه آنچه را خدا نازل كرده خوش نمى‌داشتند، گفتند: «ما در كار [مخالفت‌] تا حدودى از شما اطاعت خواهيم كرد.» و خدا از همداستانى آنان آگاه است"
  47,27,"پس چگونه [تاب مى‌آورند] وقتى كه فرشتگان [عذاب‌]، جانشان را مى‌ستانند و بر چهره و پشت آنان تازيانه مى‌نوازند؟"
  47,28,زيرا آنان از آنچه خدا را به خشم آورده پيروى كرده‌اند و خرسنديش را خوش نداشتند؛ پس اعمالشان را باطل گردانيد
  47,29,آيا كسانى كه در دلهايشان مرضى هست، پنداشتند كه خدا هرگز كينه آنان را آشكار نخواهد كرد؟
  47,30,"و اگر بخواهيم، قطعاً آنان را به تو مى‌نمايانيم، در نتيجه ايشان را به سيماى [حقيقى‌]شان مى‌شناسى و از آهنگ سخن به [حال‌] آنان پى خواهى برد؛ و خداست كه كارهاى شما را مى‌داند"
  47,31,"و البته شما را مى‌آزماييم تا مجاهدان و شكيبايان شما را باز شناسانيم، و گزارشهاى [مربوط به‌] شما را رسيدگى كنيم"
  47,32,"كسانى كه كافر شدند و [مردم را] از راه خدا باز داشتند و پس از آنكه راه هدايت بر آنان آشكار شد، با پيامبر [خدا] در افتادند، هرگز به خدا گزندى نمى‌رسانند؛ و به زودى [خدا] كرده‌هايشان را تباه خواهد كرد"
  47,33,"اى كسانى كه ايمان آورده‌ايد، خدا را اطاعت كنيد و از پيامبر [او نيز] اطاعت نماييد، و كرده‌هاى خود را تباه مكنيد"
  47,34,آنان كه كفر ورزيدند و مانع راه خدا شدند، سپس در حال كفر مردند، هرگز خدا از آنان درنخواهد گذشت
  47,35,"پس سستى نورزيد و [كافران را] به آشتى مخوانيد [كه‌] شما برتريد و خدا با شماست و از [ارزش‌] كارهايتان هرگز نخواهد كاست"
  47,36,"زندگى اين دنيا لهو و لعبى بيش نيست، و اگر ايمان بياوريد و پروا بداريد [خدا] پاداش شما را مى‌دهد و اموالتان را [در عوض‌] نمى‌خواهد"
  47,37,"اگر [اموال‌] شما را بخواهد و به اصرار از شما طلب كند بخل مى‌ورزيد، و كينه‌هاى شما را برملا مى‌كند"
  47,38,"شما همان [مردمى‌] هستيد كه براى انفاق در راه خدا فرا خوانده شده‌ايد. پس برخى از شما بخل مى‌ورزند، و هر كس بخل ورزد تنها به زيان خود بخل ورزيده، و [گرنه‌] خدا بى‌نياز است و شما نيازمنديد؛ و اگر روى برتابيد [خدا] جاى شما را به مردمى غير از شما خواهد داد كه مانند شما نخواهند بود"
  48,1,"ما تو را پيروزى بخشيديم [چه‌] پيروزى درخشانى"
  48,2,تا خداوند از گناه گذشته و آينده تو درگذرد و نعمت خود را بر تو تمام گرداند و تو را به راهى راست هدايت كند
  48,3,و تو را به نصرتى ارجمند يارى نمايد
  48,4,اوست آن كس كه در دلهاى مؤمنان آرامش را فرو فرستاد تا ايمانى بر ايمان خود بيفزايند. و سپاهيان آسمانها و زمين از آن خداست، و خدا همواره داناى سنجيده‌كار است
  48,5,"تا مردان و زنانى را كه ايمان آورده‌اند در باغهايى كه از زير [درختان‌] آن جويبارها روان است، درآورد و در آن جاويدان بدارد، و بديهايشان را از آنان بزدايد؛ و اين [فرجام نيك‌] در پيشگاه خدا كاميابى بزرگى است"
  48,6,"و [تا] مردان و زنان نفاق‌پيشه و مردان و زنان مشرك را كه به خدا گمان بد برده‌اند، عذاب كند؛ بد زمانه بر آنان باد. و خدا بر ايشان خشم نموده و لعنتشان كرده و جهنم را براى آنان آماده گردانيده و [چه‌] بد سرانجامى است،"
  48,7,و سپاهيان آسمانها و زمين از آن خداست، و خدا همواره شكست‌ناپذير سنجيده‌كار است
  48,8,"[اى پيامبر،] ما تو را [به سمت‌] گواه و بشارتگر و هشداردهنده‌اى فرستاديم"
  48,9,"تا به خدا و فرستاده‌اش ايمان آوريد و او را يارى كنيد و ارجش نهيد، و [خدا] را بامدادان و شامگاهان به پاكى بستاييد"
  48,10,در حقيقت، كسانى كه با تو بيعت مى‌كنند، جز اين نيست كه با خدا بيعت مى‌كنند؛ دست خدا بالاى دستهاى آنان است. پس هر كه پيمان‌شكنى كند، تنها به زيان خود پيمان مى‌شكند، و هر كه بر آنچه با خدا عهد بسته وفادار بماند، به زودى خدا پاداشى بزرگ به او مى‌بخشد
  48,11,"برجاى‌ماندگان باديه‌نشين به زودى به تو خواهند گفت: «اموال ما و كسانمان ما را گرفتار كردند، براى ما آمرزش بخواه.» چيزى را كه در دلهايشان نيست بر زبان خويش مى‌رانند. بگو: «اگر خدا بخواهد به شما زيانى يا سودى برساند چه كسى در برابر او براى شما اختيار چيزى را دارد؟ بلكه [اين‌] خداست كه به آنچه مى‌كنيد همواره آگاه است"
  48,12,"[نه چنان بود،] بلكه پنداشتيد كه پيامبر و مؤمنان هرگز به خانمان خود بر نخواهند گشت، و اين [پندار] در دلهايتان نمودى خوش يافت، و گمان بد كرديد، و شما مردمى در خور هلاكت بوديد.»"
  48,13,"و هر كس به خدا و پيامبر او ايمان نياورده است [بداند كه‌] ما براى كافران آتشى سوزان آماده كرده‌ايم"
  48,14,"و فرمانروايى آسمانها و زمين از آن خداست: هر كه را بخواهد مى‌بخشايد و هر كه را بخواهد عذاب مى‌كند، و خدا همواره آمرزنده مهربان است"
  48,15,"چون به [قصد] گرفتن غنايم روانه شديد، به زودى برجاى‌ماندگان خواهند گفت: «بگذاريد ما [هم‌] به دنبال شما بياييم.» [اين گونه‌] مى‌خواهند دستور خدا را دگرگون كنند. بگو: «هرگز از پى ما نخواهيد آمد. آرى، خدا از پيش در باره شما چنين فرموده.» پس به زودى خواهند گفت: «[نه،] بلكه بر ما رشگ مى‌بريد.» [نه چنين است‌] بلكه جز اندكى درنمى‌يابند"
  48,16,"به برجاى‌ماندگان باديه‌نشين بگو: «به زودى به سوى قومى سخت زورمند دعوت خواهيد شد كه با آنان بجنگيد يا اسلام آورند. پس اگر فرمان بريد خدا شما را پاداش نيك مى‌بخشد، و اگر -همچنان كه پيشتر پشت كرديد- [باز هم‌] روى بگردانيد، شما را به عذابى پردرد معذب مى‌دارد.»"
  48,17,"بر نابينا گناهى نيست و بر لنگ گناهى نيست و بر بيمار گناهى نيست [كه در جهاد شركت نكنند]؛ و هر كس خدا و پيامبر او را فرمان برد، وى را در باغهايى كه از زير [درختان‌] آن نهرهايى روان است درمى‌آورد، و هر كس روى برتابد، به عذابى دردناك معذبش مى‌دارد"
  48,18,به راستى خدا هنگامى كه مؤمنان، زير آن درخت با تو بيعت مى‌كردند از آنان خشنود شد، و آنچه در دلهايشان بود بازشناخت و بر آنان آرامش فرو فرستاد و پيروزى نزديكى به آنها پاداش داد
  48,19,"و [نيز] غنيمتهاى فراوانى خواهند گرفت، و خدا همواره نيرومند سنجيده‌كار است"
  48,20,"و خدا به شما غنيمتهاى فراوان [ديگرى‌] وعده داده كه به زودى آنها را خواهيد گرفت، و اين [پيروزى‌] را براى شما پيش انداخت، و دستهاى مردم را از شما كوتاه ساخت، و تا براى مؤمنان نشانه‌اى باشد و شما را به راه راست هدايت كند"
  48,21,"و [غنيمتهاى‌] ديگر[ى نيز هست‌] كه شما بر آنها دست نيافته‌ايد [و] خدا بر آنها نيك احاطه دارد، و همواره خداوند بر هر چيزى تواناست"
  48,22,و اگر كسانى كه كافر شدند، به جنگ با شما برخيزند، قطعاً پشت خواهند كرد، و ديگر يار و ياورى نخواهند يافت
  48,23,سنّت الهى از پيش همين بوده، و در سنّت الهى هرگز تغييرى نخواهى يافت
  48,24,و اوست همان كسى كه در دل مكه -پس از پيروزكردن شما بر آنان- دستهاى آنها را از شما و دستهاى شما را از ايشان كوتاه گردانيد، و خدا به آنچه مى‌كنيد همواره بيناست
  48,25,"آنها بودند كه كفر ورزيدند و شما را از مسجد الحرام بازداشتند و نگذاشتند قربانى [شما] كه بازداشته شده بود به محلش برسد، و اگر [در مكه‌] مردان و زنان با ايمانى نبودند كه [ممكن بود] بى‌آنكه آنان را بشناسيد، ندانسته پايمالشان كنيد و تاوانشان بر شما بماند [فرمان حمله به مكه مى‌داديم‌] تا خدا هر كه را بخواهد در جوار رحمت خويش درآورد. اگر [كافر و مؤمن‌] از هم متمايز مى‌شدند، قطعاً كافران را به عذاب دردناكى معذب مى‌داشتيم"
  48,26,"آنگاه كه كافران در دلهاى خود، تعصّب [آن هم‌] تعصّب جاهليّت ورزيدند، پس خدا آرامش خود را بر فرستاده خويش و بر مؤمنان فرو فرستاد، و آرمان تقوا را ملازم آنان ساخت، و [در واقع‌] آنان به [رعايت ]آن [آرمان‌] سزاوارتر و شايسته [اتصاف به‌] آن بودند، و خدا همواره بر هر چيزى داناست"
  48,27,"حقاً خدا رؤياى پيامبر خود را تحقّق بخشيد [كه ديده بود:] شما بدون شكّ، به خواست خدا در حالى كه سر تراشيده و موى [و ناخن‌] كوتاه كرده‌ايد، با خاطرى آسوده در مسجد الحرام درخواهيد آمد. خدا آنچه را كه نمى‌دانستيد دانست، و غير از اين، پيروزى نزديكى [براى شما] قرار داد"
  48,28,"اوست كسى كه پيامبر خود را به [قصد] هدايت، با آيين درست روانه ساخت، تا آن را بر تمام اديان پيروز گرداند و گواه‌بودن خدا كفايت مى‌كند"
  48,29,"محمد [ص‌] پيامبر خداست؛ و كسانى كه با اويند، بر كافران، سختگير [و] با همديگر مهربانند. آنان را در ركوع و سجود مى‌بينى. فضل و خشنودى خدا را خواستارند. علامت [مشخصّه‌] آنان بر اثر سجود در چهره‌هايشان است. اين صفت ايشان است در تورات، و مثَل آنها در انجيل چون كشته‌اى است كه جوانه خود برآورد و آن را مايه دهد تا ستبر شود و بر ساقه‌هاى خود بايستد و دهقانان را به شگفت آورد، تا از [انبوهى‌] آنان [خدا] كافران را به خشم دراندازد. خدا به كسانى از آنان كه ايمان آورده و كارهاى شايسته كرده‌اند، آمرزش و پاداش بزرگى وعده داده‌است"
  49,1,"اى كسانى كه ايمان آورده‌ايد، در برابر خدا و پيامبرش [در هيچ كارى‌] پيشى مجوييد و از خدا پروا بداريد كه خدا شنواى داناست"
  49,2,اى كسانى كه ايمان آورده‌ايد، صدايتان را بلندتر از صداى پيامبر مكنيد، و همچنانكه بعضى از شما با بعضى ديگر بلند سخن مى‌گوييد با او به صداى بلند سخن مگوييد، مبادا بى‌آنكه بدانيد كرده‌هايتان تباه شود
  49,3,كسانى كه پيش پيامبر خدا صدايشان را فرو مى‌كشند همان كسانند كه خدا دلهايشان را براى پرهيزگارى امتحان كرده است؛ آنان را آمرزش و پاداشى بزرگ است
  49,4,"كسانى كه تو را از پشت اتاقها[ى مسكونى تو] به فرياد مى‌خوانند، بيشترشان نمى‌فهمند"
  49,5,و اگر صبر كنند تا بر آنان درآيى، مسلماً برايشان بهتر است و خدا آمرزنده و مهربان است
  49,6,"اى كسانى كه ايمان آورده‌ايد، اگر فاسقى برايتان خبرى آورد، نيك وارسى كنيد، مبادا به نادانى گروهى را آسيب برسانيد و [بعد،] از آنچه كرده‌ايد پشيمان شويد"
  49,7,"و بدانيد كه پيامبر خدا در ميان شماست. اگر در بسيارى از كارها از [رأى و ميل‌] شما پيروى كند، قطعاً دچار زحمت مى‌شويد، ليكن خدا ايمان را براى شما دوست‌داشتنى گردانيد و آن را در دلهاى شما بياراست و كفر و پليدكارى و سركشى را در نظرتان ناخوشايند ساخت. آنان [كه چنين‌اند] ره‌يافتگانند"
  49,8,"[و اين‌] بخششى از خدا و نعمتى [از اوست‌]، و خدا داناى سنجيده‌كار است"
  49,9,"و اگر دو طايفه از مؤمنان با هم بجنگند، ميان آن دو را اصلاح دهيد، و اگر [باز] يكى از آن دو بر ديگرى تعدّى كرد، با آن [طايفه‌اى‌] كه تعدّى مى‌كند بجنگيد تا به فرمان خدا بازگردد. پس اگر باز گشت، ميان آنها را دادگرانه سازش دهيد و عدالت كنيد، كه خدا دادگران را دوست مى‌دارد"
  49,10,در حقيقت مؤمنان با هم برادرند، پس ميان برادرانتان را سازش دهيد و از خدا پروا بداريد، اميد كه مورد رحمت قرار گيريد
  49,11,"اى كسانى كه ايمان آورده‌ايد، نبايد قومى قوم ديگر را ريشخند كند، شايد آنها از اينها بهتر باشند، و نبايد زنانى زنان [ديگر] را [ريشخند كنند ]، شايد آنها از اينها بهتر باشند، و از يكديگر عيب مگيريد، و به همديگر لقبهاى زشت مدهيد؛ چه ناپسنديده است نام زشت پس از ايمان. و هر كه توبه نكرد آنان خود ستمكارند"
  49,12,"اى كسانى كه ايمان آورده‌ايد، از بسيارى از گمانها بپرهيزيد كه پاره‌اى از گمانها گناه است، و جاسوسى مكنيد، و بعضى از شما غيبت بعضى نكند؛ آيا كسى از شما دوست دارد كه گوشت برادر مرده‌اش را بخورد؟ از آن كراهت داريد. [پس‌] از خدا بترسيد، كه خدا توبه‌پذير مهربان است"
  49,13,اى مردم، ما شما را از مرد و زنى آفريديم، و شما را ملّت ملّت و قبيله قبيله گردانيديم تا با يكديگر شناسايى متقابل حاصل كنيد. در حقيقت ارجمندترين شما نزد خدا پرهيزگارترين شماست. بى‌ترديد، خداوند داناى آگاه است
  49,14,"[برخى از] باديه‌نشينان گفتند: «ايمان آورديم.» بگو: «ايمان نياورده‌ايد، ليكن بگوييد: اسلام آورديم. و هنوز در دلهاى شما ايمان داخل نشده است. و اگر خدا و پيامبر او را فرمان بريد از [ارزش‌] كرده‌هايتان چيزى كم نمى‌كند. خدا آمرزنده مهربان است.»"
  49,15,"در حقيقت، مؤمنان كسانى‌اند كه به خدا و پيامبر او گرويده و [ديگر] شكّ نياورده و با مال و جانشان در راه خدا جهاد كرده‌اند؛ اينانند كه راستكردارند"
  49,16,"بگو: «آيا خدا را از دين‌[دارى‌] خود خبر مى‌دهيد؟ و حال آنكه خدا آنچه را كه در زمين است مى‌داند، و خدا به همه چيز داناست"
  49,17,"از اينكه اسلام آورده‌اند بر تو منّت مى‌نهند؛ بگو: «بر من از اسلام‌آوردنتان منّت مگذاريد، بلكه [اين‌] خداست كه با هدايت‌كردن شما به ايمان، بر شما منّت مى‌گذارد، اگر راستگو باشيد"
  49,18,"خداست كه نهفته آسمانها و زمين را مى‌داند و خدا[ست كه‌] به آنچه مى‌كنيد بيناست.»"
  50,1,قاف، سوگند به قرآن باشكوه،
  50,2,"[كه آنان نگرويدند،] بلكه از اينكه هشداردهنده‌اى از خودشان برايشان آمد، در شگفت شدند و كافران گفتند: «اين [محمّد و حكايت معاد] چيزى عجيب است»"
  50,3,"«آيا چون مُرديم و خاك شديم [زنده مى‌شويم‌]؟ اين بازگشتى بعيد است.»"
  50,4,"قطعاً دانسته‌ايم كه زمين [چه مقدار] از اجسادشان فرو مى‌كاهد. و پيش ما كتاب ضبطكننده‌اى است"
  50,5,"[نه،] بلكه حقيقت را، وقتى برايشان آمد، دروغ خواندند، و آنها در كارى سردرگم [مانده‌]اند"
  50,6,مگر به آسمان بالاى سرشان ننگريسته‌اند كه چگونه آن را ساخته و زينتش داده‌ايم و براى آن هيچ گونه شكافتگى نيست
  50,7,"و زمين را گسترديم و در آن لنگر[آسا كوه‌]ها فرو افكنديم و در آن از هر گونه جفت دل‌انگيز رويانيديم"
  50,8,"[تا] براى هر بنده توبه‌كارى بينش‌افزا و پندآموز باشد"
  50,9,"و از آسمان، آبى پر بركت فرود آورديم، پس بدان [وسيله‌] باغها و دانه‌هاى دروكردنى رويانيديم"
  50,10,"و درختان تناور خرما كه خوشه‌[هاى‌] روى هم چيده دارند"
  50,11,"[اينها همه‌] براى روزىِ بندگان [من‌] است، و با آن [آب‌] سرزمين مرده‌اى را زنده گردانيديم؛ رستاخيز [نيز] چنين است"
  50,12,پيش از ايشان قوم نوح و اصحاب رَسّ و ثمود،
  50,13,و عاد و فرعون و برادران لوط،
  50,14,"و بيشه‌نشينان و قوم تُبّع به تكذيب پرداختند؛ همگى فرستادگان [ما] را به دروغ گرفتند و [در نتيجه‌] تهديد [من‌] واجب آمد"
  50,15,"مگر از آفرينش نخستين [خود] به تنگ آمديم؟ [نه!] بلكه آنها از خلق جديد در شبهه‌اند"
  50,16,"و ما انسان را آفريده‌ايم و مى‌دانيم كه نفس او چه وسوسه‌اى به او مى‌كند، و ما از شاهرگ [او] به او نزديكتريم"
  50,17,"آنگاه كه دو [فرشته‌] دريافت‌كننده از راست و از چپ، مراقب نشسته‌اند"
  50,18,"[آدمى‌] هيچ سخنى را به لفظ درنمى‌آورد مگر اينكه مراقبى آماده نزد او [آن را ضبط مى‌كند]"
  50,19,و سكرات مرگ، به راستى در رسيد؛ اين همان است كه از آن مى‌گريختى؛
  50,20,"و در صور دميده شود؛ اين است روز تهديد [من‌]"
  50,21,"و هر كسى مى‌آيد [در حالى كه‌] با او سوق‌دهنده و گواهى‌دهنده‌اى است"
  50,22,"[به او مى‌گويند:] «واقعاً كه از اين [حال‌] سخت در غفلت بودى. و[لى‌] ما پرده‌ات را [از جلوى چشمانت‌] برداشتيم و ديده‌ات امروز تيز است.»"
  50,23,"و [فرشته‌] همنشين او مى‌گويد: «اين است آنچه پيش من آماده است [و ثبت كرده‌ام‌].»"
  50,24,"[به آن دو فرشته خطاب مى‌شود:] «هر كافر سرسختى را در جهنم فروافكنيد،"
  50,25,"[هر] بازدارنده از خيرى، [هر] متجاوز شكاكى"
  50,26,"كه با خداوند، خدايى ديگر قرار داد. [اى دو فرشته،] او را در عذاب شديد فرو افكنيد"
  50,27,"[شيطان‌] همدمش مى‌گويد: «پروردگار ما، من او را به عصيان وانداشتم، ليكن [خودش‌] در گمراهى دور و درازى بود.»"
  50,28,"[خدا] مى‌فرمايد: «در پيشگاه من با همديگر مستيزيد [كه‌] از پيش به شما هشدار داده بودم"
  50,29,"پيش من حكم دگرگون نمى‌شود، و من [نسبت‌] به بندگانم بيدادگر نيستم.»"
  50,30,"آن روز كه [ما] به دوزخ مى‌گوييم: «آيا پر شدى؟» و مى‌گويد: «آيا باز هم هست؟»"
  50,31,و بهشت را براى پرهيزگاران نزديك گردانند، بى‌آنكه دور باشد
  50,32,"[و به آنان گويند:] اين همان است كه وعده يافته‌ايد [و] براى هر توبه‌كار نگهبان [حدود خدا] خواهد بود"
  50,33,"آنكه در نهان از خداى بخشنده بترسد و با دلى توبه‌كار [باز] آيد"
  50,34,"به سلامت [و شادكامى‌] در آن درآييد [كه‌] اين روز جاودانگى است"
  50,35,"هر چه بخواهند در آنجا دارند، و پيش ما فزونتر [هم‌] هست"
  50,36,"و چه بسا نسلها كه پيش از ايشان هلاك كرديم كه [بس‌] نيرومندتر از اينان بودند و در شهرها پرسه زده بودند [اما سرانجام‌] مگر گريزگاهى بود؟"
  50,37,"قطعاً در اين [عقوبتها] براى هر صاحبدل و حق نيوشى كه خود به گواهى ايستد، عبرتى است"
  50,38,و در حقيقت، آسمانها و زمين و آنچه را كه ميان آن دو است در شش هنگام آفريديم و احساس ماندگى نكرديم
  50,39,و بر آنچه مى‌گويند صبر كن، و پيش از برآمدن آفتاب و پيش از غروب، به ستايش پروردگارت تسبيح گوى
  50,40,"و پاره‌اى از شب و به دنبال سجود [به صورت تعقيب و نافله‌] او را تسبيح گوى"
  50,41,و روزى كه منادى از جايى نزديك ندا درمى‌دهد، به گوش باش
  50,42,"روزى كه فرياد [رستاخيز] را به حق مى‌شنوند، آن [روز] روز بيرون آمدن [از زمين‌] است"
  50,43,ماييم كه خود، زندگى مى‌بخشيم و به مرگ مى‌رسانيم و برگشت به سوى ماست
  50,44,"روزى كه زمين به سرعت از [اجساد] آنان جدا و شكافته مى‌شود؛ اين حشرى است كه بر ما آسان خواهد بود"
  50,45,"ما به آنچه مى‌گويند داناتريم، و تو به زور وادارنده آنان نيستى؛ پس به [وسيله‌] قرآن هر كه را از تهديد [من‌] مى‌ترسد پند ده"
  51,1,سوگند به بادهاى ذره‌افشان،
  51,2,و ابرهاى گرانبار،
  51,3,و سبك سيران،
  51,4,"و تقسيم‌كنندگان كار[ها]،"
  51,5,كه آنچه وعده داده شده‌ايد راست است،
  51,6,"و [روز] پاداش واقعيت دارد"
  51,7,سوگند به آسمان مشبّك،
  51,8,"كه شما [درباره قرآن‌] در سخنى گوناگونيد"
  51,9,"[بگوى‌] تا هر كه از آن برگشته، برگشته باشد"
  51,10,مرگ بر دروغپردازان
  51,11,همانان كه در ورطه نادانى بى‌خبرند
  51,12,"پرسند: «روز پاداش كى است؟»"
  51,13,"همان روز كه آنان بر آتش، عقوبت [و آزموده‌] شوند"
  51,14,"عذاب [موعود] خود را بچشيد، اين است همان [بلايى‌] كه با شتاب خواستار آن بوديد"
  51,15,پرهيزگاران در باغها و چشمه سارانند
  51,16,آنچه را پروردگارشان عطا فرموده مى‌گيرند، زيرا كه آنها پيش از اين نيكوكار بودند
  51,17,و از شب اندكى را مى‌غنودند
  51,18,"و در سحرگاهان [از خدا] طلب آمرزش مى‌كردند"
  51,19,"و در اموالشان براى سائل و محروم حقى [معين‌] بود"
  51,20,"و روى زمين براى اهل يقين نشانه‌هايى [متقاعدكننده‌] است،"
  51,21,و در خود شما؛ پس مگر نمى‌بينيد؟
  51,22,و روزى شما و آنچه وعده داده شده‌ايد در آسمان است
  51,23,پس سوگند به پروردگار آسمان و زمين، كه واقعاً او حق است همان گونه كه خود شما سخن مى‌گوييد
  51,24,آيا خبر مهمانان ارجمند ابراهيم به تو رسيد؟
  51,25,"چون بر او درآمدند؛ پس سلام گفتند. گفت: «سلام، مردمى ناشناسيد.»"
  51,26,"پس آهسته به سوى زنش رفت و گوساله‌اى فربه [و بريان‌] آورد"
  51,27,"آن را به نزديكشان برد [و] گفت: «مگر نمى‌خوريد؟»"
  51,28,"و [در دلش‌] از آنان احساس ترسى كرد. گفتند: «مترس.» و او را به پسرى دانا مژده دادند"
  51,29,"و زنش با فريادى [از شگفتى‌] سر رسيد و بر چهره خود زد و گفت: «زنى پير نازا [چگونه بزايد]؟»"
  51,30,"گفتند: «پروردگارت چنين فرموده است. او خود حكيم داناست.»"