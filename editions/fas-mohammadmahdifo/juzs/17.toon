quran[190]{c,v,t}:
  21,1,"براى مردم [وقت‌] حسابشان نزديك شده است، و آنان در بى‌خبرى رويگردانند"
  21,2,هيچ پند تازه‌اى از پروردگارشان نيامد، مگر اينكه بازى‌كنان آن را شنيدند
  21,3,"در حالى كه دلهايشان مشغول است. و آنانكه ستم كردند پنهانى به نجوا برخاستند كه: «آيا اين [مرد] جز بشرى مانند شماست؟ آيا ديده و دانسته به سوى سحر مى‌رويد؟»"
  21,4,"[پيامبر] گفت: «پروردگارم [هر] گفتار[ى‌] را در آسمان و زمين مى‌داند، و اوست شنواى دانا.»"
  21,5,"بلكه گفتند: «خوابهاى شوريده است، [نه‌] بلكه آن را بربافته، بلكه او شاعرى است. پس همان گونه كه براى پيشينيان هم عرضه شد، بايد براى ما نشانه‌اى بياورد.»"
  21,6,"قبل از آنان [نيز مردم‌] هيچ شهرى -كه آن را نابود كرديم- [به آيات ما] ايمان نياوردند. پس آيا اينان [به معجزه‌] ايمان مى‌آورند؟"
  21,7,"و پيش از تو [نيز] جز مردانى را كه به آنان وحى مى‌كرديم گسيل نداشتيم. اگر نمى‌دانيد از پژوهندگان كتابهاى آسمانى بپرسيد"
  21,8,"و ايشان را جسدى كه غذا نخورند قرار نداديم و جاويدان [هم‌] نبودند"
  21,9,"سپس وعده [خود] به آنان را راست گردانيديم و آنها و هر كه را خواستيم نجات داديم و افراطكاران را به هلاكت رسانيديم"
  21,10,در حقيقت، ما كتابى به سوى شما نازل كرديم كه ياد شما در آن است. آيا نمى‌انديشيد؟
  21,11,"و چه بسيار شهرها را كه [مردمش‌] ستمكار بودند در هم شكستيم، و پس از آنها قومى ديگر پديد آورديم"
  21,12,پس چون عذاب ما را احساس كردند، بناگاه از آن مى‌گريختند
  21,13,"[هان‌] مگريزيد، و به سوى آنچه در آن متنعّم بوديد و [به سوى‌] سراهايتان بازگرديد، باشد كه شما مورد پرسش قرار گيريد"
  21,14,"گفتند: «اى واى بر ما، كه ما واقعاً ستمگر بوديم.»"
  21,15,سخنشان پيوسته همين بود، تا آنان را دروشده بى‌جان گردانيديم
  21,16,و آسمان و زمين و آنچه را كه ميان آن دو است به بازيچه نيافريديم
  21,17,اگر مى‌خواستيم بازيچه‌اى بگيريم، قطعاً آن را از پيش خود اختيار مى‌كرديم
  21,18,بلكه حق را بر باطل فرو مى‌افكنيم، پس آن را در هم مى‌شكند، و بناگاه آن نابود مى‌گردد. واى بر شما از آنچه وصف مى‌كنيد
  21,19,و هر كه در آسمانها و زمين است براى اوست، و كسانى كه نزد اويند از پرستش وى تكبّر نمى‌ورزند و درمانده نمى‌شوند
  21,20,شبانه روز، بى‌آنكه سستى ورزند، نيايش مى‌كنند
  21,21,"آيا براى خود خدايانى از زمين اختيار كرده‌اند كه آنها [مردگان را] زنده مى‌كنند؟"
  21,22,"اگر در آنها [=زمين و آسمان‌] جز خدا، خدايانى [ديگر] وجود داشت، قطعاً [زمين و آسمان‌] تباه مى‌شد. پس منزّه است خدا، پروردگار عرش، از آنچه وصف مى‌كنند"
  21,23,"در آنچه [خدا] انجام مى‌دهد چون و چرا راه ندارد، و[لى‌] آنان [=انسانها] سؤال خواهند شد"
  21,24,"آيا به جاى او خدايانى براى خود گرفته‌اند؟ بگو: «برهانتان را بياوريد.» اين است يادنامه هر كه با من است و يادنامه هر كه پيش از من بوده. [نه!] بلكه بيشترشان حق را نمى‌شناسند و در نتيجه از آن رويگردانند"
  21,25,"و پيش از تو هيچ پيامبرى نفرستاديم مگر اينكه به او وحى كرديم كه: «خدايى جز من نيست، پس مرا بپرستيد.»"
  21,26,"و گفتند: «[خداى‌] رحمان فرزندى اختيار كرده.» منزّه است او. بلكه [فرشتگان‌] بندگانى ارجمندند،"
  21,27,كه در سخن بر او پيشى نمى‌گيرند، و خود به دستور او كار مى‌كنند
  21,28,"آنچه فراروى آنان و آنچه پشت سرشان است مى‌داند، و جز براى كسى كه [خدا] رضايت دهد، شفاعت نمى‌كنند و خود از بيم او هراسانند"
  21,29,"و هر كس از آنان بگويد: «من [نيز] جز او خدايى هستم»، او را به دوزخ كيفر مى‌دهيم. [آرى‌] سزاى ستمكاران را اين گونه مى‌دهيم"
  21,30,"آيا كسانى كه كفر ورزيدند ندانستند كه آسمانها و زمين هر دو به هم پيوسته بودند، و ما آن دو را از هم جدا ساختيم، و هر چيز زنده‌اى را از آب پديد آورديم؟ آيا [باز هم‌] ايمان نمى‌آورند؟"
  21,31,"و در زمين كوههايى استوار نهاديم تا مبادا [زمين‌] آنان [=مردم‌] را بجنباند، و در آن راههايى فراخ پديد آورديم، باشد كه راه يابند"
  21,32,"و آسمان را سقفى محفوظ قرار داديم، و[لى‌] آنان از [مطالعه در] نشانه‌هاى آن اِعراض مى‌كنند"
  21,33,"و اوست آن كسى كه شب و روز و خورشيد و ماه را پديد آورده است. هر كدام از اين دو در مدارى [معيّن‌] شناورند"
  21,34,"و پيش از تو براى هيچ بشرى جاودانگى [در دنيا] قرار نداديم. آيا اگر تو از دنيا بروى آنان جاويدانند؟"
  21,35,هر نفسى چشنده مرگ است، و شما را از راه آزمايش به بد و نيك خواهيم آزمود، و به سوى ما بازگردانيده مى‌شويد
  21,36,"و كسانى كه كافر شدند، چون تو را ببينند فقط به مسخره‌ات مى‌گيرند [و مى‌گويند:] «آيا اين همان كس است كه خدايانتان را [به بدى‌] ياد مى‌كند؟» در حالى كه آنان خود، ياد [خداى‌] رحمان را منكرند"
  21,37,"انسان از شتاب آفريده شده است. به زودى آياتم را به شما نشان مى‌دهم. پس [عذاب را] به شتاب از من مخواهيد"
  21,38,"و مى‌گويند: «اگر راست مى‌گوييد، اين وعده [قيامت‌] كى خواهد بود؟»"
  21,39,"كاش آنان كه كافر شده‌اند مى‌دانستند آنگاه كه آتش را نه از چهره‌هاى خود و نه از پشتشان بازنمى‌توانند داشت، و خود مورد حمايت قرار نمى‌گيرند [چه حالى خواهند داشت‌]"
  21,40,"بلكه [آتش‌] به طور ناگهانى به آنان مى‌رسد و ايشان را بهت‌زده مى‌كند [به گونه‌اى‌] كه نه مى‌توانند آن را برگردانند و نه به آنان مهلت داده مى‌شود"
  21,41,"و مسلمّاً پيامبران پيش از تو [نيز] مورد ريشخند قرار گرفتند، پس كسانى كه آنان را مسخره مى‌كردند، [سزاى‌] آنچه كه آن را به ريشخند مى‌گرفتند گريبانگيرشان شد"
  21,42,"بگو: «چه كسى شما را شب و روز از [عذاب‌] رحمان حفظ مى‌كند؟» [نه‌] بلكه آنان از ياد پروردگارشان رويگردانند"
  21,43,"آيا براى آنان خدايانى غير از ماست كه از ايشان حمايت كنند؟ [آن خدايان‌] نه مى‌توانند خود را يارى كنند و نه از جانب ما يارى شوند"
  21,44,"[نه‌] بلكه اينها و پدرانشان را برخوردار كرديم تا عمرشان به درازا كشيد. آيا نمى‌بينند كه ما مى‌آييم و زمين را از جوانب آن فرو مى‌كاهيم؟ آيا باز هم آنان پيروزند؟"
  21,45,"بگو: «من شما را فقط به وسيله وحى هشدار مى‌دهم.» و[لى‌] چون كران بيم داده شوند، دعوت را نمى‌شنوند"
  21,46,"و اگر شمه‌اى از عذاب پروردگارت به آنان برسد، خواهند گفت: «اى واى بر ما كه ستمكار بوديم.»"
  21,47,"و ترازوهاى داد را در روز رستاخيز مى‌نهيم، پس هيچ كس [در] چيزى ستم نمى‌بيند، و اگر [عمل‌] هموزن دانه خردلى باشد آن را مى‌آوريم و كافى است كه ما حسابرس باشيم"
  21,48,"و در حقيقت، به موسى و هارون فرقان داديم و [كتابشان‌] براى پرهيزگاران روشنايى و اندرزى است"
  21,49,"[همان‌] كسانى كه از پروردگارشان در نهان مى‌ترسند و از قيامت هراسناكند"
  21,50,"و اين [كتاب‌] -كه آن را نازل كرده‌ايم- پندى خجسته است. آيا باز هم آن را انكار مى‌كنيد؟"
  21,51,"و در حقيقت، پيش از آن، به ابراهيم رشد [فكرى‌]اش را داديم و ما به [شايستگى‌] او دانا بوديم"
  21,52,"آنگاه كه به پدر خود و قومش گفت: «اين مجسمه‌هايى كه شما ملازم آنها شده‌ايد چيستند؟»"
  21,53,"گفتند: «پدران خود را پرستندگان آنها يافتيم.»"
  21,54,"گفت: «قطعاً شما و پدرانتان در گمراهى آشكارى بوديد.»"
  21,55,"گفتند: «آيا حق را براى ما آورده‌اى يا تو از شوخى‌كنندگانى؟»"
  21,56,"گفت: «[نه‌] بلكه پروردگارتان، پروردگار آسمانها و زمين است، همان كسى كه آنها را پديد آورده است، و من بر اين [واقعيت‌] از گواهانم"
  21,57,و سوگند به خدا كه پس از آنكه پشت كرديد و رفتيد، قطعاً در كار بتانتان تدبيرى خواهم كرد.»
  21,58,پس آنها را -جز بزرگترشان را- ريز ريز كرد، باشد كه ايشان به سراغ آن بروند
  21,59,"گفتند: «چه كسى با خدايان ما چنين [معامله‌اى‌] كرده، كه او واقعاً از ستمكاران است؟»"
  21,60,"گفتند: «شنيديم جوانى، از آنها [به بدى‌] ياد مى‌كرد كه به او ابراهيم گفته مى‌شود.»"
  21,61,"گفتند: «پس او را در برابر ديدگان مردم بياوريد، باشد كه آنان شهادت دهند.»"
  21,62,"گفتند: «اى ابراهيم، آيا تو با خدايان ما چنين كردى؟»"
  21,63,"گفت: «[نه‌] بلكه آن را اين بزرگترشان كرده است، اگر سخن مى‌گويند از آنها بپرسيد.»"
  21,64,"پس به خود آمده و [به يكديگر] گفتند: «در حقيقت، شما ستمكاريد.»"
  21,65,"سپس سرافكنده شدند [و گفتند:] «قطعاً دانسته‌اى كه اينها سخن نمى‌گويند.»"
  21,66,"گفت: «آيا جز خدا چيزى را مى‌پرستيد كه هيچ سود و زيانى به شما نمى‌رساند؟"
  21,67,اف بر شما و بر آنچه غير از خدا مى‌پرستيد. مگر نمى‌انديشيد؟»
  21,68,"گفتند: «اگر كارى مى‌كنيد، او را بسوزانيد و خدايانتان را يارى دهيد.»"
  21,69,"گفتيم: «اى آتش، براى ابراهيم سرد و بى‌آسيب باش.»"
  21,70,"و خواستند به او نيرنگى بزنند و[لى‌] آنان را زيانكارترين [مردم‌] قرار داديم"
  21,71,"و او و لوط را [براى رفتن‌] به سوى آن سرزمينى كه براى جهانيان در آن بركت نهاده بوديم، رهانيديم"
  21,72,"و اسحاق و يعقوب را [به عنوان نعمتى‌] افزون به او بخشوديم و همه را از شايستگان قرار داديم"
  21,73,و آنان را پيشوايانى قرار داديم كه به فرمان ما هدايت مى‌كردند، و به ايشان انجام دادن كارهاى نيك و برپاداشتن نماز و دادن زكات را وحى كرديم و آنان پرستنده ما بودند
  21,74,"و به لوط حكمت و دانش عطا كرديم و او را از آن شهرى كه [مردمش‌] كارهاى پليد [جنسى‌] مى‌كردند نجات داديم. به راستى آنها گروه بد و منحرفى بودند"
  21,75,و او را در رحمت خويش داخل كرديم، زيرا او از شايستگان بود
  21,76,"و نوح را [ياد كن‌] آنگاه كه پيش از [ساير پيامبران‌] ندا كرد، پس ما او را اجابت كرديم، و وى را با خانواده‌اش از بلاى بزرگ رهانيديم"
  21,77,و او را در برابر مردمى كه نشانه‌هاى ما را به دروغ گرفته بودند پيروزى بخشيديم، چرا كه آنان مردم بدى بودند، پس همه ايشان را غرق كرديم
  21,78,"و داوود و سليمان را [ياد كن‌] هنگامى كه در باره آن كشتزار -كه گوسفندان مردم شب‌هنگام در آن چريده بودند- داورى مى‌كردند، و [ما] شاهد داورى آنان بوديم"
  21,79,"پس آن [داورى‌] را به سليمان فهمانديم، و به هر يك [از آن دو] حكمت و دانش عطا كرديم، و كوهها را با داوود و پرندگان به نيايش واداشتيم، و ما كننده [اين كار] بوديم"
  21,80,"و به [داوود] فن زره [سازى‌] آموختيم، تا شما را از [خطرات‌] جنگتان حفظ كند. پس آيا شما سپاسگزاريد؟"
  21,81,"و براى سليمان، تندباد را [رام كرديم‌] كه به فرمان او به سوى سرزمينى كه در آن بركت نهاده بوديم جريان مى‌يافت، و ما به هر چيزى دانا بوديم"
  21,82,"و برخى از شياطين بودند كه براى او غواصى و كارهايى غير از آن مى‌كردند، و ما مراقب [حال‌] آنها بوديم"
  21,83,"و ايوب را [ياد كن‌] هنگامى كه پروردگارش را ندا داد كه: «به من آسيب رسيده است و تويى مهربانترين مهربانان.»"
  21,84,"پس [دعاى‌] او را اجابت نموديم و آسيب وارده بر او را برطرف كرديم، و كسان او و نظيرشان را همراه با آنان [مجدداً] به وى عطا كرديم [تا] رحمتى از جانب ما و عبرتى براى عبادت‌كنندگان [باشد]"
  21,85,"و اسماعيل و ادريس و ذوالكفل را [ياد كن‌] كه همه از شكيبايان بودند"
  21,86,و آنان را در رحمت خود داخل نموديم، چرا كه ايشان از شايستگان بودند
  21,87,"و «ذوالنون» را [ياد كن‌] آنگاه كه خشمگين رفت و پنداشت كه ما هرگز بر او قدرتى نداريم، تا در [دل‌] تاريكيها ندا درداد كه: «معبودى جز تو نيست، منزّهى تو، راستى كه من از ستمكاران بودم.»"
  21,88,"پس [دعاى‌] او را برآورده كرديم و او را از اندوه رهانيديم، و مؤمنان را [نيز] چنين نجات مى‌دهيم"
  21,89,"و زكريّا را [ياد كن‌] هنگامى كه پروردگار خود را خواند: «پروردگارا، مرا تنها مگذار و تو بهترين ارث برندگانى.»"
  21,90,"پس [دعاى‌] او را اجابت نموديم، و يحيى را بدو بخشيديم و همسرش را براى او شايسته [و آماده حمل‌] كرديم، زيرا آنان در كارهاى نيك شتاب مى‌نمودند و ما را از روى رغبت و بيم مى‌خواندند و در برابر ما فروتن بودند"
  21,91,"و آن [زن را ياد كن‌] كه خود را پاكدامن نگاه داشت، و از روح خويش در او دميديم و او و پسرش را براى جهانيان آيتى قرار داديم"
  21,92,اين است امت شما كه امتى يگانه است، و منم پروردگار شما، پس مرا بپرستيد
  21,93,"و[لى‌] دينشان را ميان خود پاره پاره كردند. همه به سوى ما بازمى‌گردند"
  21,94,"پس هر كه كارهاى شايسته انجام دهد و مؤمن [هم‌] باشد، براى تلاش او ناسپاسى نخواهد بود، و ماييم كه به سود او ثبت مى‌كنيم"
  21,95,"و بر [مردم‌] شهرى كه آن را هلاك كرده‌ايم، بازگشتشان [به دنيا] حرام است"
  21,96,"تا وقتى كه يأجوج و مأجوج [راهشان‌] گشوده شود و آنها از هر پشته‌اى بتازند،"
  21,97,"و وعده حق نزديك گردد، ناگهان ديدگان كسانى كه كفر ورزيده‌اند خيره مى‌شود [و مى‌گويند:] «اى واى بر ما كه از اين [روز] در غفلت بوديم، بلكه ما ستمگر بوديم.»"
  21,98,در حقيقت، شما و آنچه غير از خدا مى‌پرستيد، هيزم دوزخيد. شما در آن وارد خواهيد شد
  21,99,"اگر اينها خدايانى [واقعى‌] بودند در آن وارد نمى‌شدند، و حال آنكه جملگى در آن ماندگارند"
  21,100,"براى آنها در آنجا ناله‌اى زار است و در آنجا [چيزى‌] نمى‌شنوند"
  21,101,"بى‌گمان كسانى كه قبلا از جانب ما به آنان وعده نيكو داده شده است از آن [آتش‌] دور داشته خواهند شد"
  21,102,صداى آن را نمى‌شنوند، و آنان در ميان آنچه دلهايشان بخواهد جاودانند
  21,103,"دلهره بزرگ، آنان را غمگين نمى‌كند و فرشتگان از آنها استقبال مى‌كنند [و به آنان مى‌گويند:] اين همان روزى است كه به شما وعده مى‌دادند"
  21,104,روزى كه آسمان را همچون در پيچيدن صفحه نامه‌ها در مى‌پيچيم. همان گونه كه بار نخست آفرينش را آغاز كرديم، دوباره آن را بازمى‌گردانيم. وعده‌اى است بر عهده ما، كه ما انجام‌دهنده آنيم
  21,105,و در حقيقت، در زبور پس از تورات نوشتيم كه زمين را بندگان شايسته ما به ارث خواهند برد
  21,106,"به راستى در اين [امور] براى مردم عبادت‌پيشه ابلاغى [حقيقى‌] است"
  21,107,و تو را جز رحمتى براى جهانيان نفرستاديم
  21,108,"بگو: «جز اين نيست كه به من وحى مى‌شود كه خداى شما خدايى يگانه است. پس آيا مسلمان مى‌شويد؟»"
  21,109,"پس اگر روى برتافتند بگو: «به [همه‌] شما به طور يكسان اعلام كردم، و نمى‌دانم آنچه وعده داده شده‌ايد آيا نزديك است يا دور.»"
  21,110,"[آرى،] او سخن آشكار را مى‌داند و آنچه را پوشيده مى‌داريد مى‌داند"
  21,111,"و نمى‌دانم، شايد آن براى شما آزمايشى و تا چند گاهى [وسيله‌] برخوردارى باشد"
  21,112,"گفت: «پروردگارا، [خودت‌] به حق داورى كن، و به رغم آنچه وصف مى‌كنيد، پروردگار ما همان بخشايشگر دستگير است.»"
  22,1,اى مردم، از پروردگار خود پروا كنيد، چرا كه زلزله رستاخيز امرى هولناك است
  22,2,"روزى كه آن را ببينيد، هر شيردهنده‌اى آن را كه شير مى‌دهد [از ترس‌] فرو مى‌گذارد، و هر آبستنى بار خود را فرو مى‌نهد، و مردم را مست مى‌بينى و حال آنكه مست نيستند، ولى عذاب خدا شديد است"
  22,3,و برخى از مردم در باره خدا بدون هيچ علمى مجادله مى‌كنند و از هر شيطان سركشى پيروى مى‌نمايند
  22,4,"بر [شيطان‌] مقرر شده است كه هر كس او را به دوستى گيرد، قطعاً او وى را گمراه مى‌سازد و به عذاب آتشش مى‌كشاند"
  22,5,"اى مردم، اگر در باره برانگيخته شدن در شكّيد، پس [بدانيد] كه ما شما را از خاك آفريده‌ايم، سپس از نطفه، سپس از علقه، آنگاه از مضغه، داراى خلقت كامل و [احياناً] خلقت ناقص، تا [قدرت خود را] بر شما روشن گردانيم. و آنچه را اراده مى‌كنيم تا مدتى معين در رحمها قرار مى‌دهيم، آنگاه شما را [به صورت‌] كودك برون مى‌آوريم، سپس [حيات شما را ادامه مى‌دهيم‌] تا به حد رشدتان برسيد، و برخى از شما [زودرس‌] مى‌ميرد، و برخى از شما به غايت پيرى مى‌رسد به گونه‌اى كه پس از دانستن [بسى چيزها] چيزى نمى‌داند. و زمين را خشكيده مى‌بينى و[لى‌] چون آب بر آن فرود آوريم به جنبش درمى‌آيد و نمو مى‌كند و از هر نوع [رستنيهاى‌] نيكو مى‌روياند"
  22,6,"اين [قدرت نماييها] بدان سبب است كه خدا خود حق است، و اوست كه مردگان را زنده مى‌كند و [هم‌] اوست كه بر هر چيزى تواناست"
  22,7,"و [هم‌] آنكه رستاخيز آمدنى است [و] شكى در آن نيست، و در حقيقت، خداست كه كسانى را كه در گورهايند برمى‌انگيزد"
  22,8,"و از [ميان‌] مردم كسى است كه در باره خدا بدون هيچ دانش و بى‌هيچ رهنمود و كتاب روشنى به مجادله مى‌پردازد،"
  22,9,"[آن هم‌] از سرِ نِخْوت، تا [مردم را] از راه خدا گمراه كند. در اين دنيا براى او رسوايى است، و در روز رستاخيز او را عذاب آتش سوزان مى‌چشانيم"
  22,10,"اين [كيفر] به سزاى چيزهايى است كه دستهاى تو پيش فرستاده است و [گرنه‌] خدا به بندگان خود بيدادگر نيست"
  22,11,"و از ميان مردم كسى است كه خدا را فقط بر يك حال [و بدون عمل‌] مى‌پرستد. پس اگر خيرى به او برسد بدان اطمينان يابد، و چون بلايى بدو رسد روى برتابد. در دنيا و آخرت زيان ديده است. اين است همان زيان آشكار"
  22,12,به جاى خدا چيزى را مى‌خواند كه نه زيانى به او مى‌رساند و نه سودش مى‌دهد. اين است همان گمراهى دور و دراز
  22,13,كسى را مى‌خواند كه زيانش از سودش نزديكتر است. وه چه بد مولايى و چه بد دمسازى
  22,14,"بى‌گمان، خدا كسانى را كه گرويده و كارهاى شايسته كرده‌اند به باغهايى درمى‌آورد كه از زير [درختان‌] آن رودبارها روان است. خدا هر چه بخواهد انجام مى‌دهد"
  22,15,"هر كه مى‌پندارد كه خدا [پيامبرش‌] را در دنيا و آخرت هرگز يارى نخواهد كرد [بگو] تا طنابى به سوى سقف كشد [و خود را حلق‌آويز كند] سپس [آن را] بِبُرَد. آنگاه بنگرد كه آيا نيرنگش چيزى را كه مايه خشم او شده از ميان خواهد برد؟"
  22,16,"و بدين گونه [قرآن‌] را [به صورت‌] آياتى روشنگر نازل كرديم، و خداست كه هر كه را بخواهد راه مى‌نمايد"
  22,17,كسانى كه ايمان آوردند و كسانى كه يهودى شدند و صابئى‌ها و مسيحيان و زرتشتيان و كسانى كه شرك ورزيدند، البته خدا روز قيامت ميانشان داورى خواهد كرد، زيرا خدا بر هر چيزى گواه است
  22,18,"آيا ندانستى كه خداست كه هر كس در آسمانها و هر كس در زمين است، و خورشيد و ماه و [تمام‌] ستارگان و كوهها و درختان و جنبندگان و بسيارى از مردم براى او سجده مى‌كنند؟ و بسيارى‌اند كه عذاب بر آنان واجب شده است. و هر كه را خدا خوار كند او را گرامى‌دارنده‌اى نيست، چرا كه خدا هر چه بخواهد انجام مى‌دهد"
  22,19,"اين دو [گروه،] دشمنان يكديگرند كه در باره پروردگارشان با هم ستيزه مى‌كنند، و كسانى كه كفر ورزيدند، جامه‌هايى از آتش برايشان بريده شده است [و] از بالاى سرشان آب جوشان ريخته مى‌شود"
  22,20,"آنچه در شكم آنهاست با پوست [بدن‌]شان بدان گداخته مى‌گردد"
  22,21,"و براى [وارد كردن ضربت بر سر] آنان گرزهايى آهنين است"
  22,22,"هر بار بخواهند از [شدت‌] غم، از آن بيرون روند در آن باز گردانيده مى‌شوند [كه هان‌] بچشيد عذاب آتش سوزان را"
  22,23,"خدا كسانى را كه ايمان آورده و كارهاى شايسته كرده‌اند در باغهايى كه از زير [درختان‌] آن نهرها روان است درمى‌آورد: در آنجا با دستبندهايى از طلا و مرواريد آراسته مى‌شوند، و لباسشان در آنجا از پرنيان است"
  22,24,"و به گفتار پاك هدايت مى‌شوند و به سوى راه [خداى‌] ستوده هدايت مى‌گردند"
  22,25,"بى‌گمان، كسانى كه كافر شدند و از راه خدا و مسجدالحرام -كه آن را براى مردم، اعم از مقيم در آنجا و باديه‌نشين، يكسان قرار داده‌ايم- جلو گيرى مى‌كنند، و [نيز] هر كه بخواهد در آنجا به ستم [از حق ]منحرف شود، او را از عذابى دردناك مى‌چشانيم"
  22,26,"و چون براى ابراهيم جاى خانه را معين كرديم [بدو گفتيم:] «چيزى را با من شريك مگردان و خانه‌ام را براى طواف‌كنندگان و قيام‌كنندگان و ركوع‌كنندگان [و] سجده‌كنندگان پاكيزه دار.»"
  22,27,"و در ميان مردم براى [اداى‌] حج بانگ برآور تا [زايران‌] پياده و [سوار] بر هر شتر لاغرى -كه از هر راه دورى مى‌آيند- به سوى تو روى آورند،"
  22,28,تا شاهد منافع خويش باشند، و نام خدا را در روزهاى معلومى بر دامهاى زبان‌بسته‌اى كه روزىِ آنان كرده است ببرند. پس، از آنها بخوريد و به درمانده مستمند بخورانيد
  22,29,"سپس بايد آلودگى خود را بزدايند و به نذرهاى خود وفا كنند و بر گِرد آن خانه كهن [=كعبه‌] طواف به جاى آورند"
  22,30,"اين است [آنچه مقرر شده‌] و هر كس مقررات خدا را بزرگ دارد، آن براى او نزد پروردگارش بهتر است، و براى شما دامها حلال شده است، مگر آنچه بر شما خوانده مى‌شود. پس، از پليدى بتها دورى كنيد، و از گفتار باطل اجتناب ورزيد"
  22,31,"در حالى كه گروندگان خالص به خدا باشيد؛ نه شريك‌گيرندگان [براى‌] او! و هر كس به خدا شرك ورزد چنان است كه گويى از آسمان فرو افتاده و مرغان [شكارى‌] او را ربوده‌اند يا باد او را به جايى دور افكنده است"
  22,32,"اين است [فرايض خدا] و هر كس شعاير خدا را بزرگ دارد در حقيقت، آن [حاكى‌] از پاكى دلهاست"
  22,33,"براى شما در آن [دامها] تا مدتى معين سودهايى است، سپس جايگاه [قربانى‌كردن آنها و ساير فرايض‌] در خانه كهن [=كعبه‌] است"
  22,34,"و براى هر امتى مناسكى قرار داديم، تا نام خدا را بر دامهاى زبان‌بسته‌اى كه روزى آنها گردانيده ياد كنند. پس [بدانيد كه‌] خداى شما خدايى يگانه است، پس به [فرمان‌] او گردن نهيد. و فروتنان را بشارت ده"
  22,35,"همانان كه چون [نام‌] خدا ياد شود، دلهايشان خشيت يابد و [آنان كه‌] بر هر چه برسرشان آيد صبر پيشه‌گانند و برپا دارندگان نمازند، و از آنچه روزيشان داده‌ايم انفاق مى‌كنند"
  22,36,"و شتران فربه را براى شما از [جمله‌] شعاير خدا قرار داديم: در آنها براى شما خير است. پس نام خدا را بر آنها -در حالى كه برپاى ايستاده‌اند- ببَريد و چون به پهلو درغلتيدند از آنها بخوريد و به تنگدست [سائل‌] و به بينوا[ى غير سائل ]بخورانيد. اين گونه آنها را براى شما رام كرديم، اميد كه شكرگزار باشيد"
  22,37,"هرگز [نه‌] گوشتهاى آنها و نه خونهايشان به خدا نخواهد رسيد، ولى [اين‌] تقواى شماست كه به او مى‌رسد. اين گونه [خداوند] آنها را براى شما رام كرد، تا خدا را به پاس آنكه شما را هدايت نموده به بزرگى ياد كنيد، و نيكوكاران را مژده ده"
  22,38,قطعاً خداوند از كسانى كه ايمان آورده‌اند دفاع مى‌كند، زيرا خدا هيچ خيانتكار ناسپاسى را دوست ندارد
  22,39,"به كسانى كه جنگ بر آنان تحميل شده، رخصت [جهاد] داده شده است، چرا كه مورد ظلم قرار گرفته‌اند، و البته خدا بر پيروزى آنان سخت تواناست"
  22,40,"همان كسانى كه بناحق از خانه‌هايشان بيرون رانده شدند. [آنها گناهى نداشتند] جز اينكه مى‌گفتند: «پروردگار ما خداست» و اگر خدا بعضى از مردم را با بعض ديگر دفع نمى‌كرد، صومعه‌ها و كليساها و كنيسه‌ها و مساجدى كه نام خدا در آنها بسيار برده مى‌شود، سخت ويران مى‌شد، و قطعاً خدا به كسى كه [دين‌] او را يارى مى‌كند، يارى مى‌دهد، چرا كه خدا سخت نيرومند شكست‌ناپذير است"
  22,41,همان كسانى كه چون در زمين به آنان توانايى دهيم، نماز برپا مى‌دارند و زكات مى‌دهند و به كارهاى پسنديده وامى‌دارند، و از كارهاى ناپسند باز مى‌دارند، و فرجام همه كارها از آنِ خداست
  22,42,"و اگر تو را تكذيب كنند، قطعاً پيش از آنان قوم نوح و عاد و ثمود [نيز] به تكذيب پرداختند"
  22,43,"و [نيز] قوم ابراهيم و قوم لوط"
  22,44,"و [همچنين‌] اهل مدين. و موسى تكذيب شد، پس كافران را مهلت دادم، سپس [گريبان‌] آنها را گرفتم. بنگر، عذاب من چگونه بود؟"
  22,45,"و چه بسيار شهرها را -كه ستمكار بودند- هلاكشان كرديم و [اينك‌] آن [شهرها] سقفهايش فرو ريخته است، و [چه بسيار] چاههاى متروك و كوشكهاى افراشته را"
  22,46,آيا در زمين گردش نكرده‌اند، تا دلهايى داشته باشند كه با آن بينديشند يا گوشهايى كه با آن بشنوند؟ در حقيقت، چشمها كور نيست ليكن دلهايى كه در سينه‌هاست كور است
  22,47,"و از تو با شتاب تقاضاى عذاب مى‌كنند، با آنكه هرگز خدا وعده‌اش را خلاف نمى كند، و در حقيقت، يك روز [از قيامت‌] نزد پروردگارت مانند هزار سال است از آنچه مى‌شمريد"
  22,48,"و چه بسا شهرى كه مهلتش دادم، در حالى كه ستمكار بود؛ سپس [گريبان‌] آن را گرفتم، و فرجام به سوى من است"
  22,49,"بگو: «اى مردم، من براى شما فقط هشداردهنده‌اى آشكارم.»"
  22,50,پس آنان كه گرويده و كارهاى شايسته كرده‌اند، آمرزش و روزىِ نيكو براى ايشان خواهد بود
  22,51,"و كسانى كه در [تخطئه‌] آيات ما مى‌كوشند [و به خيال خود] عاجزكنندگان ما هستند، آنان اهل دوزخند"
  22,52,"و پيش از تو [نيز] هيچ رسول و پيامبرى را نفرستاديم جز اينكه هر گاه چيزى تلاوت مى‌نمود، شيطان در تلاوتش القاىِ [شبهه‌] مى‌كرد. پس خدا آنچه را شيطان القا مى‌كرد محو مى‌گردانيد، سپس خدا آيات خود را استوار مى‌ساخت، و خدا داناى حكيم است"
  22,53,"تا آنچه را كه شيطان القا مى‌كند، براى كسانى كه در دلهايشان بيمارى است و [نيز] براى سنگدلان آزمايشى گرداند، و ستمگران در ستيزه‌اى بس دور و درازند"
  22,54,"و تا آنان كه دانش يافته‌اند بدانند كه اين [قرآن‌] حق است [و] از جانب پروردگار توست. و بدان ايمان آورند و دلهايشان براى او خاضع گردد. و به راستى خداوند كسانى را كه ايمان آورده‌اند، به سوى راهى راست راهبر است"
  22,55,"و[لى‌] كسانى كه كفر ورزيده‌اند، همواره از آن در ترديدند، تا بناگاه قيامت براى آنان فرا رسد، يا عذاب روزى بدفرجام به سراغشان بيايد"
  22,56,"در آن روز، پادشاهى از آنِ خداست: ميان آنان داورى مى‌كند، و [در نتيجه‌] كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند در باغهاى پرناز و نعمت خواهند بود"
  22,57,و كسانى كه كفر ورزيده و نشانه‌هاى ما را دروغ پنداشته‌اند، براى آنان عذابى خفّت‌آور خواهد بود
  22,58,و آنان كه در راه خدا مهاجرت كرده‌اند، و آنگاه كشته شده يا مرده‌اند، قطعاً خداوند به آنان رزقى نيكو مى‌بخشد. و راستى اين خداست كه بهترين روزى‌دهندگان است
  22,59,آنان را به جايگاهى كه آن را مى‌پسندند درخواهد آورد، و شك نيست كه خداوند دانايى بردبار است
  22,60,آرى چنين است، و هر كس نظير آنچه بر او عقوبت رفته است دست به عقوبت زند، سپس مورد ستم قرار گيرد، قطعاً خدا او را يارى خواهد كرد، چرا كه خدا بخشايشگر و آمرزنده است
  22,61,"اين بدان سبب است كه خدا شب را در روز درمى‌آورد و روز را [نيز] در شب درمى‌آورد، و خداست كه شنواى بيناست"
  22,62,"[آرى،] اين بدان سبب است كه خدا خود حق است و آنچه به جاى او مى‌خوانند آن باطل است، و اين خداست كه والا و بزرگ است"
  22,63,آيا نديده‌اى كه خدا از آسمان، آبى فرو فرستاد و زمين سرسبز گرديد؟ آرى، خداست كه دقيق و آگاه است
  22,64,"آنچه در آسمانها و آنچه در زمين است از آنِ اوست، و در حقيقت، اين خداست كه خود بى‌نياز ستوده‌[صفات‌] است"
  22,65,"آيا نديده‌اى كه خدا آنچه را در زمين است به نفع شما رام گردانيد، و كشتيها در دريا به فرمان او روانند، و آسمان را نگاه مى‌دارد تا [مبادا] بر زمين فرو افتد، مگر به اذن خودش [باشد]. در حقيقت، خداوند نسبت به مردم سخت رئوف و مهربان است"
  22,66,"و اوست كه شما را زندگى بخشيد، سپس شما را مى‌ميراند، و باز زندگى [نو] مى دهد. حقا كه انسان سخت ناسپاس است"
  22,67,براى هر امتى مناسكى قرار داديم كه آنها بدان عمل مى‌كنند، پس نبايد در اين امر با تو به ستيزه برخيزند، به راه پروردگارت دعوت كن، زيرا تو بر راهى راست قرار دارى
  22,68,"و اگر با تو مجادله كردند، بگو: «خدا به آنچه مى‌كنيد داناتر است.»"
  22,69,خدا روز قيامت در مورد آنچه با يكديگر در آن اختلاف مى‌كرديد، داورى خواهد كرد
  22,70,"آيا ندانسته‌اى كه خداوند آنچه را در آسمان و زمين است مى‌داند؟ اينها [همه‌] در كتابى [مندرج‌] است. قطعاً اين بر خدا آسان است"
  22,71,"و به جاى خدا چيزى را مى‌پرستند كه بر [تأييد] آن حجّتى نازل نكرده و بدان دانشى ندارند، و براى ستمكاران ياورى نخواهد بود"
  22,72,"و چون آيات روشن ما بر آنان خوانده مى‌شود، در چهره كسانى كه كفر ورزيده‌اند [اثر] انكار را تشخيص مى‌دهى: چيزى نمانده كه بر كسانى كه آيات ما را برايشان تلاوت مى‌كنند حمله‌ور شوند. بگو: «آيا شما را به بدتر از اين خبر دهم؟ [همان ]آتش است كه خدا آن را به كسانى كه كفر ورزيده‌اند وعده داده، و چه بد سرانجامى است.»"
  22,73,"اى مردم، مَثَلى زده شد. پس بدان گوش فرا دهيد: كسانى را كه جز خدا مى‌خوانيد هرگز [حتى‌] مگسى نمى‌آفرينند، هر چند براى [آفريدن‌] آن اجتماع كنند، و اگر آن مگس چيزى از آنان بربايد نمى‌توانند آن را بازپس گيرند. طالب و مطلوب هر دو ناتوانند"
  22,74,قدر خدا را چنانكه در خور اوست نشناختند. در حقيقت، خداست كه نيرومند شكست‌ناپذير است
  22,75,خدا از ميان فرشتگان رسولانى برمى‌گزيند، و نيز از ميان مردم. بى‌گمان خدا شنواى بيناست
  22,76,"آنچه در دسترس آنان و آنچه پشت سرشان است مى‌داند و [همه‌] كارها به خدا بازگردانيده مى‌شود"
  22,77,اى كسانى كه ايمان آورده‌ايد، ركوع و سجود كنيد و پروردگارتان را بپرستيد و كار خوب انجام دهيد، باشد كه رستگار شويد
  22,78,"و در راه خدا چنانكه حق جهاد [در راه‌] اوست جهاد كنيد، اوست كه شما را [براى خود] برگزيده و در دين بر شما سختى قرار نداده است. آيين پدرتان ابراهيم [نيز چنين بوده است‌] او بود كه قبلاً شما را مسلمان ناميد، و در اين [قرآن نيز همين مطلب آمده است‌] تا اين پيامبر بر شما گواه باشد و شما بر مردم گواه باشيد. پس نماز را برپا داريد و زكات بدهيد و به پناه خدا رويد. او مولاى شماست؛ چه نيكو مولايى و چه نيكو ياورى"