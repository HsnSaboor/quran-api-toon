quran[202]{c,v,t}:
  23,1,به راستى كه مؤمنان رستگار شدند،
  23,2,همانان كه در نمازشان فروتنند،
  23,3,و آنان كه از بيهوده رويگردانند،
  23,4,و آنان كه زكات مى‌پردازند،
  23,5,و كسانى كه پاكدامنند،
  23,6,مگر در مورد همسرانشان يا كنيزانى كه به دست آورده‌اند، كه در اين صورت بر آنان نكوهشى نيست
  23,7,پس هر كه فراتر از اين جويد، آنان از حد درگذرندگانند
  23,8,و آنان كه امانتها و پيمان خود را رعايت مى‌كنند،
  23,9,و آنان كه بر نمازهايشان مواظبت مى‌نمايند،
  23,10,آنانند كه خود وارثانند،
  23,11,همانان كه بهشت را به ارث مى‌برند و در آنجا جاودان مى‌مانند
  23,12,و به يقين، انسان را از عصاره‌اى از گِل آفريديم
  23,13,"سپس او را [به صورت‌] نطفه‌اى در جايگاهى استوار قرار داديم"
  23,14,"آنگاه نطفه را به صورت علقه درآورديم. پس آن علقه را [به صورت‌] مضغه گردانيديم، و آنگاه مضغه را استخوانهايى ساختيم، بعد استخوانها را با گوشتى پوشانيديم، آنگاه [جنين را در] آفرينشى ديگر پديد آورديم. آفرين باد بر خدا كه بهترين آفرينندگان است"
  23,15,"بعد از اين [مراحل‌] قطعاً خواهيد مُرد"
  23,16,آنگاه شما در روز رستاخيز برانگيخته خواهيد شد
  23,17,"و به راستى [ما] بالاى سر شما هفت راه [آسمانى‌] آفريديم و از [كار] آفرينش غافل نبوده‌ايم"
  23,18,"و از آسمان، آبى به اندازه [معيّن‌] فرود آورديم، و آن را در زمين جاى داديم، و ما براى از بين بردن آن مسلّماً تواناييم"
  23,19,پس براى شما به وسيله آن باغهايى از درختان خرما و انگور پديدار كرديم كه در آنها براى شما ميوه‌هاى فراوان است و از آنها مى‌خوريد
  23,20,و از طور سينا درختى برمى‌آيد كه روغن و نان خورشى براى خورندگان است
  23,21,"و البته براى شما در دامها[ى گلّه درس‌] عبرتى است: از [شيرى‌] كه در شكم آنهاست، به شما مى‌نوشانيم، و براى شما در آنها سودهاى فراوان است و از آنها مى‌خوريد"
  23,22,و بر آنها و بر كشتيها سوار مى‌شويد
  23,23,"و به يقين نوح را به سوى قومش فرستاديم. پس [به آنان‌] گفت: «اى قوم من، خدا را بپرستيد. شما را جز او خدايى نيست. مگر پروا نداريد؟»"
  23,24,"و اشراف قومش كه كافر بودند گفتند: «اين [مرد] جز بشرى چون شما نيست، مى‌خواهد بر شما برترى جويد، و اگر خدا مى‌خواست قطعاً فرشتگانى مى‌فرستاد. [ما]در ميان پدران نخستين خود، چنين [چيزى‌] نشنيده‌ايم.»"
  23,25,"او نيست جز مردى كه در وى [حال‌] جنون است، پس تا چندى در باره‌اش دست نگاه داريد"
  23,26,"[نوح‌] گفت: «پروردگارا، از آن روى كه دروغزنم خواندند مرا يارى كن.»"
  23,27,"پس به او وحى كرديم كه: زير نظر ما و [به‌] وحى ما كشتى را بساز، و چون فرمان ما دررسيد و تنور به فوران آمد، پس در آن از هر نوع [حيوانى‌] دو تا [يكى نر و ديگرى ماده‌] با خانواده‌ات -بجز كسى از آنان كه حكم [عذاب ] بر او پيشى گرفته است- وارد كن، در باره كسانى كه ظلم كرده‌اند با من سخن مگوى، زيرا آنها غرق خواهند شد"
  23,28,"و چون تو با آنان كه همراه تواند بر كشتى نشستى بگو: «ستايش خدايى را كه ما را از [چنگ‌] گروه ظالمان رهانيد.»"
  23,29,"و بگو: «پروردگارا، مرا در جايى پربركت فرود آور [كه‌] تو نيكترين مهمان‌نوازانى.»"
  23,30,"در حقيقت، در اين [ماجرا] عبرتهايى است، و قطعاً ما آزمايش‌كننده بوديم"
  23,31,"سپس، بعد از آنان نسل‌[هايى‌] ديگر پديد آورديم"
  23,32,"و در ميانشان پيامبرى از خودشان روانه كرديم كه: خدا را بپرستيد. جز او براى شما معبودى نيست. آيا سرِ پرهيزگارى نداريد؟"
  23,33,"و اشراف قومش كه كافر شده، و ديدار آخرت را دروغ پنداشته بودند، و در زندگى دنيا آنان را مرفّه ساخته بوديم گفتند: «اين [مرد] جز بشرى چون شما نيست: از آنچه مى‌خوريد، مى‌خورد؛ و از آنچه مى‌نوشيد، مى‌نوشد"
  23,34,و اگر بشرى مثل خودتان را اطاعت كنيد در آن صورت قطعاً زيانكار خواهيد بود
  23,35,"آيا به شما وعده مى‌دهد كه وقتى مُرديد و خاك و استخوان شديد [باز] شما [از گور زنده‌] بيرون آورده مى‌شويد؟"
  23,36,وه، چه دور است آنچه كه وعده داده مى‌شويد
  23,37,جز اين زندگانى دنياى ما چيزى نيست. مى‌ميريم و زندگى مى‌كنيم و ديگر برانگيخته نخواهيم شد
  23,38,او جز مردى كه بر خدا دروغ مى‌بندد نيست، و ما به او اعتقاد نداريم.»
  23,39,"گفت: «پروردگارا، از آن روى كه مرا دروغزن خواندند ياريم كن.»"
  23,40,"فرمود: «به زودى سخت پشيمان خواهند شد.»"
  23,41,"پس فرياد [مرگبار] آنان را به حقّ فرو گرفت، و آنها را [چون‌] خاشاكى كه بر آب افتد، گردانيديم. دور باد [از رحمت خدا] گروه ستمكاران"
  23,42,آنگاه پس از آنان نسلهاى ديگرى پديد آورديم
  23,43,هيچ امّتى نه از اجل خود پيشى مى‌گيرد و نه باز پس مى‌ماند
  23,44,"باز فرستادگان خود را پياپى روانه كرديم. هر بار براى [هدايت‌] امتى پيامبرش آمد، او را تكذيب كردند؛ پس [ما امتهاى سركش را] يكى پس از ديگرى آورديم و آنها را مايه عبرت [و زبانزد مردم‌] گردانيديم. دور باد [از رحمت خدا] مردمى كه ايمان نمى‌آورند"
  23,45,سپس موسى و برادرش هارون را با آيات خود و حجتى آشكار فرستاديم،
  23,46,"به سوى فرعون و سران [قوم‌] او، ولى تكبّر نمودند و مردمى گردنكش بودند،"
  23,47,"پس گفتند: «آيا به دو بشر كه مثل خود ما هستند و طايفه آنها بندگان ما مى‌باشند ايمان بياوريم؟»"
  23,48,در نتيجه، آن دو را دروغزن خواندند، پس از زمره هلاك‌شدگان گشتند
  23,49,"و به يقين، ما به موسى كتاب [آسمانى‌] داديم، باشد كه آنان به راه راست روند"
  23,50,"و پسر مريم و مادرش را نشانه‌اى گردانيديم و آن دو را در سرزمين بلندى كه جاى زيست و [داراى‌] آب زلال بود جاى داديم"
  23,51,اى پيامبران، از چيزهاى پاكيزه بخوريد و كار شايسته كنيد، كه من به آنچه انجام مى‌دهيد دانايم
  23,52,و در حقيقت، اين امّت شماست كه امتى يگانه است، و من پروردگار شمايم؛ پس، از من پروا داريد
  23,53,"تا كار [دين‌]شان را ميان خود قطعه قطعه كردند [و] دسته دسته شدند: هر دسته‌اى به آنچه نزدشان بود، دل خوش كردند"
  23,54,پس آنها را در ورطه گمراهى‌شان تا چندى واگذار
  23,55,آيا مى‌پندارند كه آنچه از مال و پسران كه بديشان مدد مى‌دهيم،
  23,56,"[از آن روى است كه‌] مى‌خواهيم به سودشان در خيرات شتاب ورزيم؟ [نه،] بلكه نمى‌فهمند"
  23,57,در حقيقت، كسانى كه از بيم پروردگارشان هراسانند،
  23,58,و كسانى كه به نشانه‌هاى پروردگارشان ايمان مى‌آورند،
  23,59,و آنان كه به پروردگارشان شرك نمى‌آورند،
  23,60,"و كسانى كه آنچه را دادند [در راه خدا] مى‌دهند، در حالى كه دلهايشان ترسان است [و مى‌دانند] كه به سوى پروردگارشان بازخواهند گشت،"
  23,61,آنانند كه در كارهاى نيك شتاب مى‌ورزند و آنانند كه در انجام آنها سبقت مى‌جويند
  23,62,و هيچ كس را جز به قدر توانش تكليف نمى‌كنيم، و نزد ما كتابى است كه به حق سخن مى‌گويد و آنان مورد ستم قرار نخواهند گرفت
  23,63,"[نه،] بلكه دلهاى آنان از اين [حقيقت‌] در غفلت است، و آنان غير از اين [گناهان‌] كردارهايى [ديگر] دارند كه به انجام آن مبادرت مى‌ورزند"
  23,64,تا وقتى خوشگذرانانِ آنها را به عذاب گرفتار ساختيم، بناگاه به زارى درمى‌آيند
  23,65,امروز زارى مكنيد كه قطعاً شما از جانب ما يارى نخواهيد شد
  23,66,در حقيقت، آيات من بر شما خوانده مى‌شد و شما بوديد كه همواره به قهقرا مى‌رفتيد
  23,67,"در حالى كه از [پذيرفتن‌] آن تكبّر مى‌ورزيديد و شب هنگام [در محافل خود] بدگويى مى‌كرديد"
  23,68,"آيا در [عظمت‌] اين سخن نينديشيده‌اند، يا چيزى براى آنان آمده كه براى پدران پيشين آنها نيامده است؟"
  23,69,"يا پيامبر خود را [درست‌] نشناخته و [لذا] به انكار او پرداخته‌اند؟"
  23,70,"يا مى‌گويند او جنونى دارد؟ [نه،] بلكه [او] حق را براى ايشان آورده و[لى‌] بيشترشان حقيقت را خوش ندارند"
  23,71,"و اگر حق از هوسهاى آنها پيروى مى‌كرد، قطعاً آسمانها و زمين و هر كه در آنهاست تباه مى‌شد. [نه!] بلكه يادنامه‌شان را به آنان داده‌ايم، ولى آنها از [پيروى‌] يادنامه خود رويگردانند"
  23,72,يا از ايشان مزدى مطالبه مى‌كنى؟ و مزد پروردگارت بهتر است، و اوست كه بهترين روزى‌دهندگان است
  23,73,و در حقيقت، اين تويى كه جدّاً آنها را به راه راست مى‌خوانى
  23,74,"و به راستى كسانى كه به آخرت ايمان ندارند، از راه [درست‌] سخت منحرفند"
  23,75,"و اگر ايشان را ببخشاييم، و آنچه از صدمه بر آنان [وارد آمده‌] است برطرف كنيم، در طغيان خود كوردلانه اصرار مى‌ورزند"
  23,76,"و به راستى ايشان را به عذاب گرفتار كرديم و[لى‌] نسبت به پروردگارشان فروتنى نكردند و به زارى درنيامدند"
  23,77,"تا وقتى كه درى از عذاب دردناك بر آنان گشوديم، بناگاه ايشان در آن [حال‌] نوميد شدند"
  23,78,و اوست آن كس كه براى شما گوش و چشم و دل پديد آورد. چه اندك سپاسگزاريد
  23,79,و اوست آن كس كه شما را در زمين پديد آورد، و به سوى اوست كه گرد آورده خواهيد شد
  23,80,و اوست آن كس كه زنده مى‌كند و مى‌ميراند، و اختلاف شب و روز از اوست. مگر نمى‌انديشيد؟
  23,81,"[نه،] بلكه آنان [نيز] مثل آنچه پيشينيان گفته بودند، گفتند"
  23,82,"گفتند: «آيا چون بميريم و خاك و استخوان شويم، آيا واقعاً باز ما زنده خواهيم شد؟"
  23,83,"درست همين را قبلاً به ما و پدرانمان وعده دادند. اين جز افسانه‌هاى پيشينيان [چيزى‌] نيست.»"
  23,84,"بگو: «اگر مى‌دانيد [بگوييد] زمين و هر كه در آن است به چه كسى تعلق دارد؟»"
  23,85,"خواهند گفت: «به خدا.» بگو: «آيا عبرت نمى‌گيريد؟»"
  23,86,"بگو: «پروردگار آسمانهاى هفتگانه و پروردگار عرش بزرگ كيست؟»"
  23,87,"خواهند گفت: «خدا.» بگو: «آيا پرهيزگارى نمى‌كنيد؟»"
  23,88,"بگو: «فرمانروايى هر چيزى به دست كيست؟ و اگر مى‌دانيد [كيست آنكه‌] او پناه مى‌دهد و در پناه كسى نمى‌رود؟»"
  23,89,"خواهند گفت: «خدا.» بگو: «پس چگونه دستخوش افسون شده‌ايد؟»"
  23,90,"[نه!] بلكه حقيقت را بر ايشان آورديم، و قطعاً آنان دروغگويند"
  23,91,"خدا فرزندى اختيار نكرده و با او معبودى [ديگر] نيست، و اگر جز اين بود، قطعاً هر خدايى آنچه را آفريده [بود] باخود مى‌برد، و حتماً بعضى از آنان بر بعضى ديگر تفوّق مى‌جستند. منزه است خدا از آنچه وصف مى‌كنند"
  23,92,"داناى نهان و آشكار، و برتر است از آنچه [با او] شريك مى‌گردانند"
  23,93,"بگو: «پروردگارا، اگر آنچه را كه [از عذاب‌] به آنان وعده داده شده است به من نشان دهى،"
  23,94,پروردگارا، پس مرا در ميان قوم ستمكار قرار مده.»
  23,95,و به راستى كه ما تواناييم كه آنچه را به آنان وعده داده‌ايم بر تو بنمايانيم
  23,96,بدى را به شيوه‌اى نيكو دفع كن. ما به آنچه وصف مى‌كنند داناتريم
  23,97,"و بگو: «پروردگارا، از وسوسه‌هاى شيطانها به تو پناه مى‌برم"
  23,98,"و پروردگارا، از اينكه [آنها] به پيش من حاضر شوند به تو پناه مى‌برم.»"
  23,99,"تا آنگاه كه مرگ يكى از ايشان فرا رسد، مى‌گويد: «پروردگارا، مرا بازگردانيد،"
  23,100,شايد من در آنچه وانهاده‌ام كار نيكى انجام دهم. نه چنين است، اين سخنى است كه او گوينده آن است و پشاپيش آنان برزخى است تا روزى كه برانگيخته خواهند شد
  23,101,"پس آنگاه كه در صور دميده شود، [ديگر] ميانشان نسبت خويشاوندى وجود ندارد، و از [حال‌] يكديگر نمى‌پرسند"
  23,102,"پس كسانى كه كفه ميزان [اعمال‌] آنان سنگين باشد، ايشان رستگارانند"
  23,103,"و كسانى كه كفه ميزان [اعمال‌]شان سبك باشد، آنان به خويشتن زيان زده [و] هميشه در جهنم مى‌مانند"
  23,104,آتش چهره آنها را مى‌سوزاند، و آنان در آنجا ترش‌رويند
  23,105,"آيا آيات من بر شما خوانده نمى‌شد و [همواره‌] آن را مورد تكذيب قرار نمى‌داديد؟"
  23,106,"مى‌گويند: «پروردگارا، شقاوت ما بر ما چيره شد و ما مردمى گمراه بوديم.»"
  23,107,"پروردگارا، ما را از اينجا بيرون بر، پس اگر باز هم [به بدى‌] برگشتيم، در آن صورت ستمگر خواهيم بود"
  23,108,"مى‌فرمايد: «[برويد] در آن گم شويد و با من سخن مگوييد.»"
  23,109,"در حقيقت، دسته‌اى از بندگان من بودند كه مى‌گفتند: «پروردگارا، ايمان آورديم. بر ما ببخشاى و به ما رحم كن [كه‌] تو بهترينِ مهربانى.»"
  23,110,"و شما آنان [=مؤمنان‌] را به ريشخند گرفتيد، تا [با اين كار] ياد مرا از خاطرتان بردند و شما بر آنان مى‌خنديديد"
  23,111,"من [هم‌] امروز به [پاس‌] آنكه صبر كردند، بدانان پاداش دادم. آرى، ايشانند كه رستگارانند"
  23,112,"مى‌فرمايد: «چه مدت به عدد سالها در زمين مانديد؟»"
  23,113,"مى‌گويند: «يك روز يا پاره‌اى از يك روز مانديم. از شمارگران [خود] بپرس.»"
  23,114,"مى‌فرمايد: «جز اندكى درنگ نكرديد، كاش شما مى‌دانستيد.»"
  23,115,آيا پنداشتيد كه شما را بيهوده آفريده‌ايم و اينكه شما به سوى ما بازگردانيده نمى‌شويد؟
  23,116,"پس والاست خدا، فرمانرواى برحق، خدايى جز او نيست. [اوست‌] پروردگار عرش گرانمايه"
  23,117,و هر كس با خدا معبود ديگرى بخواند، براى آن برهانى نخواهد داشت، و حسابش فقط با پروردگارش مى‌باشد، در حقيقت، كافران رستگار نمى‌شوند
  23,118,"و بگو: «پروردگارا، ببخشاى و رحمت كن [كه‌] تو بهترين بخشايندگانى"
  24,1,"[اين‌] سوره‌اى است كه آن را نازل و آن را فرض گردانيديم و در آن آياتى روشن فرو فرستاديم، باشد كه شما پند پذيريد"
  24,2,"به هر زن زناكار و مرد زناكارى صد تازيانه بزنيد، و اگر به خدا و روز بازپسين ايمان داريد، در [كار] دين خدا، نسبت به آن دو دلسوزى نكنيد، و بايد گروهى از مؤمنان در كيفر آن دو حضور يابند"
  24,3,"مرد زناكار، جز زن زناكار يا مشرك را به همسرى نگيرد، و زن زناكار، جز مرد زناكار يا مشرك را به زنى نگيرد، و بر مؤمنان اين [امر] حرام گرديده است"
  24,4,و كسانى كه نسبت زنا به زنان شوهردار مى‌دهند، سپس چهار گواه نمى‌آورند، هشتاد تازيانه به آنان بزنيد، و هيچگاه شهادتى از آنها نپذيريد، و اينانند كه خود فاسقند
  24,5,"مگر كسانى كه بعد از آن [بهتان‌] توبه كرده و به صلاح آمده باشند كه خدا البته آمرزنده مهربان است"
  24,6,"و كسانى كه به همسران خود نسبت زنا مى‌دهند، و جز خودشان گواهانى [ديگر] ندارند، هر يك از آنان [بايد] چهار بار به خدا سوگند ياد كند كه او قطعاً از راستگويان است"
  24,7,"و [گواهى در دفعه‌] پنجم اين است كه [شوهر بگويد:] لعنت خدا بر او باد اگر از دروغگويان باشد"
  24,8,"و از [زن،] كيفر ساقط مى‌شود، در صورتى كه چهار بار به خدا سوگند ياد كند كه [شوهر] او جداً از دروغگويان است"
  24,9,"و [گواهى‌] پنجم آنكه خشم خدا بر او باد اگر [شوهرش‌] از راستگويان باشد"
  24,10,"و اگر فضل و رحمت خدا بر شما نبود و اينكه خدا توبه‌پذير سنجيده‌كار است [رسوا مى‌شديد]"
  24,11,"در حقيقت، كسانى كه آن بهتان [داستان اِفك‌] را [در ميان‌] آوردند، دسته‌اى از شما بودند. آن [تهمت‌] را شرّى براى خود تصوّر مكنيد بلكه براى شما در آن مصلحتى [بوده‌] است. براى هر مردى از آنان [كه در اين كار دست داشته‌] همان گناهى است كه مرتكب شده است، و آن كس از ايشان كه قسمت عمده آن را به گردن گرفته است عذابى سخت خواهد داشت"
  24,12,"چرا هنگامى كه آن [بهتان‌] را شنيديد، مردان و زنان مؤمن گمان نيك به خود نبردند و نگفتند: «اين بهتانى آشكار است»؟"
  24,13,"چرا چهار گواه بر [صحت‌] آن [بهتان‌] نياوردند؟ پس چون گواهان [لازم‌] را نياورده‌اند، اينانند كه نزد خدا دروغگويانند"
  24,14,"و اگر فضل خدا و رحمتش در دنيا و آخرت بر شما نبود، قطعاً به [سزاى‌] آنچه در آن به دخالت پرداختيد، به شما عذابى بزرگ مى‌رسيد"
  24,15,"آنگاه كه آن [بهتان‌] را از زبان يكديگر مى‌گرفتيد و با زبانهاى خود چيزى را كه بدان علم نداشتيد، مى‌گفتيد و مى‌پنداشتيد كه كارى سهل و ساده است با اينكه آن [امر] نزد خدا بس بزرگ بود"
  24,16,"و [گر نه‌] چرا وقتى آن را شنيديد نگفتيد: «براى ما سزاوار نيست كه در اين [موضوع‌] سخن گوييم. [خداوندا،] تو منزهى، اين بهتانى بزرگ است.»"
  24,17,خدا اندرزتان مى‌دهد كه هيچ گاه ديگر مثل آن را -اگر مؤمنيد- تكرار نكنيد
  24,18,"و خدا براى شما آيات [خود] را بيان مى‌كند، و خدا داناى سنجيده‌كار است"
  24,19,"كسانى كه دوست دارند كه زشتكارى در ميان آنان كه ايمان آورده‌اند، شيوع پيدا كند، براى آنان در دنيا و آخرت عذابى پر درد خواهد بود، و خدا[ست كه‌] مى‌داند و شما نمى‌دانيد"
  24,20,"و اگر فضل و رحمت خدا بر شما نبود و اينكه خدا رئوف و مهربان است [مجازات سختى در انتظارتان بود]"
  24,21,"اى كسانى كه ايمان آورده‌ايد، پاى از پى گامهاى شيطان منهيد، و هر كس پاى بر جاى گامهاى شيطان نهد [بداند كه‌] او به زشتكارى و ناپسند وامى‌دارد، و اگر فضل خدا و رحمتش بر شما نبود، هرگز هيچ كس از شما پاك نمى‌شد، ولى [اين‌] خداست كه هر كس را بخواهد پاك مى‌گرداند و خدا[ست كه‌] شنواى داناست"
  24,22,"و سرمايه‌داران و فراخ‌دولتان شما نبايد از دادن [مال‌] به خويشاوندان و تهيدستان و مهاجران راه خدا دريغ ورزند، و بايد عفو كنند و گذشت نمايند. مگر دوست نداريد كه خدا بر شما ببخشايد؟ و خدا آمرزنده مهربان است"
  24,23,"بى‌گمان، كسانى كه به زنان پاكدامن بى‌خبر [از همه جا] و با ايمان نسبت زنا مى‌دهند، در دنيا و آخرت لعنت شده‌اند، و براى آنها عذابى سخت خواهد بود،"
  24,24,در روزى كه زبان و دستها و پاهايشان، بر ضد آنان براى آنچه انجام مى‌دادند، شهادت مى‌دهند
  24,25,آن روز خدا جزاى شايسته آنان را به طور كامل مى‌دهد و خواهند دانست كه خدا همان حقيقت آشكار است
  24,26,زنان پليد براى مردان پليدند، و مردان پليد براى زنان پليد. و زنان پاك براى مردان پاكند، و مردان پاك براى زنان پاك. اينان از آنچه در باره ايشان مى‌گويند بر كنارند، براى آنان آمرزش و روزىِ نيكو خواهد بود
  24,27,اى كسانى كه ايمان آورده‌ايد، به خانه‌هايى كه خانه‌هاى شما نيست داخل مشويد تا اجازه بگيريد و بر اهل آن سلام گوييد. اين براى شما بهتر است، باشد كه پند گيريد
  24,28,"و اگر كسى را در آن نيافتيد، پس داخلِ آن مشويد تا به شما اجازه داده شود؛ و اگر به شما گفته شد: «برگرديد» برگرديد، كه آن براى شما سزاوارتر است، و خدا به آنچه انجام مى‌دهيد داناست"
  24,29,بر شما گناهى نيست كه به خانه‌هاى غيرمسكونى -كه در آنها براى شما استفاده‌اى است- داخل شويد، و خدا آنچه را آشكار و آنچه را پنهان مى‌داريد مى‌داند
  24,30,"به مردان با ايمان بگو: «ديده فرو نهند و پاكدامنى ورزند، كه اين براى آنان پاكيزه‌تر است، زيرا خدا به آنچه مى‌كنند آگاه است.»"
  24,31,"و به زنان با ايمان بگو: «ديدگان خود را [از هر نامحرمى‌] فرو بندند و پاكدامنى ورزند و زيورهاى خود را آشكار نگردانند مگر آنچه كه طبعاً از آن پيداست. و بايد روسرى خود را بر گردن خويش [فرو ]اندازند، و زيورهايشان را جز براى شوهرانشان يا پدرانشان يا پدران شوهرانشان يا پسرانشان يا پسران شوهرانشان يا برادرانشان يا پسران برادرانشان يا پسران خواهرانشان يا زنان [همكيش‌] خود يا كنيزانشان يا خدمتكاران مرد كه [از زن‌] بى‌نيازند يا كودكانى كه بر عورتهاى زنان وقوف حاصل نكرده‌اند، آشكار نكنند؛ و پاهاى خود را [به گونه‌اى به زمين‌] نكوبند تا آنچه از زينتشان نهفته مى‌دارند معلوم گردد. اى مؤمنان، همگى [از مرد و زن‌] به درگاه خدا توبه كنيد، اميد كه رستگار شويد"
  24,32,بى‌همسران خود، و غلامان و كنيزان درستكارتان را همسر دهيد. اگر تنگدستند، خداوند آنان را از فضل خويش بى‌نياز خواهد كرد، و خدا گشايشگر داناست
  24,33,"و كسانى كه [وسيله‌] زناشويى نمى‌يابند، بايد عفت ورزند تا خدا آنان را از فضل خويش بى‌نياز گرداند. و از ميان غلامانتان، كسانى كه در صددند با قرارداد كتبى، خود را آزاد كنند، اگر در آنان خيرى [و توانايى پرداخت مال‌] مى‌يابيد، قرارِ بازخريدِ آنها را بنويسيد، و از آن مالى كه خدا به شما داده است به ايشان بدهيد [تا تدريجاً خود را آزاد كنند]، و كنيزان خود را -در صورتى كه تمايل به پاكدامنى دارند- براى اينكه متاع زندگى دنيا را بجوييد، به زنا وادار مكنيد، و هر كس آنان را به زور وادار كند، در حقيقت، خدا پس از اجبار نمودن ايشان، [نسبت به آنها] آمرزنده مهربان است"
  24,34,و قطعاً به سوى شما آياتى روشنگر و خبرى از كسانى كه پيش از شما روزگار به سر برده‌اند، و موعظه‌اى براى اهل تقوا فرود آورده‌ايم
  24,35,خدا نور آسمانها و زمين است. مَثَل نور او چون چراغدانى است كه در آن چراغى، و آن چراغ در شيشه‌اى است. آن شيشه گويى اخترى درخشان است كه از درخت خجسته زيتونى كه نه شرقى است و نه غربى، افروخته مى‌شود. نزديك است كه روغنش -هر چند بدان آتشى نرسيده باشد- روشنى بخشد. روشنىِ بر روى روشنى است. خدا هر كه را بخواهد با نور خويش هدايت مى‌كند، و اين مَثَلها را خدا براى مردم مى‌زند و خدا به هر چيزى داناست
  24,36,"در خانه‌هايى كه خدا رخصت داده كه [قدر و منزلت‌] آنها رفعت يابد و نامش در آنها ياد شود. در آن [خانه‌]ها هر بامداد و شامگاه او را نيايش مى‌كنند"
  24,37,مردانى كه نه تجارت و نه داد و ستدى، آنان را از ياد خدا و برپا داشتن نماز و دادن زكات، به خود مشغول نمى‌دارد، و از روزى كه دلها و ديده‌ها در آن زيرورو مى‌شود مى‌هراسند
  24,38,"تا خدا بهتر از آنچه انجام مى‌دادند، به ايشان جزا دهد و از فضل خود بر آنان بيفزايد، و خدا[ست كه‌] هر كه را بخواهد بى‌حساب روزى مى‌دهد"
  24,39,و كسانى كه كفر ورزيدند، كارهايشان چون سرابى در زمينى هموار است كه تشنه، آن را آبى مى‌پندارد، تا چون بدان رسد آن را چيزى نيابد و خدا را نزد خويش يابد و حسابش را تمام به او دهد و خدا زودشمار است
  24,40,"يا [كارهايشان‌] مانند تاريكيهايى است كه در دريايى ژرف است كه موجى آن را مى‌پوشاند [و] روى آن موجى [ديگر] است [و] بالاى آن ابرى است. تاريكيهايى است كه بعضى بر روى بعضى قرار گرفته است. هر گاه [غرقه‌] دستش را بيرون آورد، به زحمت آن را مى‌بيند، و خدا به هر كس نورى نداده باشد او را هيچ نورى نخواهد بود"
  24,41,"آيا ندانسته‌اى كه هر كه [و هر چه‌] در آسمانها و زمين است براى خدا تسبيح مى‌گويند، و پرندگان [نيز] در حالى كه در آسمان پر گشوده‌اند [تسبيح او مى‌گويند]؟ همه ستايش و نيايش خود را مى‌دانند، و خدا به آنچه مى‌كنند داناست"
  24,42,"و فرمانروايى آسمانها و زمين از آنِ خداست، و بازگشت [همه‌] به سوى خداست"
  24,43,"آيا ندانسته‌اى كه خدا[ست كه‌] ابر را به آرامى مى‌راند، سپس ميان [اجزاء] آن پيوند مى‌دهد، آنگاه آن را متراكم مى‌سازد، پس دانه‌هاى باران را مى‌بينى كه از خلال آن بيرون مى‌آيد، و [خداست كه‌] از آسمان از كوههايى [از ابر يخ‌زده ]كه در آنجاست تگرگى فرو مى‌ريزد؛ و هر كه را بخواهد بدان گزند مى‌رساند، و آن را از هر كه بخواهد باز مى‌دارد. نزديك است روشنىِ برقش چشمها را بِبَرَد"
  24,44,"خداست كه شب و روز را با هم جابجا مى‌كند. قطعاً در اين [تبديل‌] براى ديده‌وران [درس‌] عبرتى است"
  24,45,"و خداست كه هر جنبنده‌اى را [ابتدا] از آبى آفريد. پس پاره‌اى از آنها بر روى شكم راه مى‌روند و پاره‌اى از آنها بر روى دو پا و بعضى از آنها بر روى چهار [پا] راه مى‌روند. خدا هر چه بخواهد مى‌آفريند. در حقيقت، خدا بر هر چيزى تواناست"
  24,46,قطعاً آياتى روشنگر فرود آورده‌ايم، و خدا هر كه را بخواهد به راه راست هدايت مى‌كند
  24,47,"و مى‌گويند: «به خدا و پيامبر [او] گرويديم و اطاعت كرديم.» آنگاه دسته‌اى از ايشان پس از اين [اقرار] روى برمى‌گردانند، و آنان مؤمن نيستند"
  24,48,و چون به سوى خدا و پيامبر او خوانده شوند، تا ميان آنان داورى كند، بناگاه دسته‌اى از آنها روى برمى‌تابند
  24,49,و اگر حق به جانب ايشان باشد، به حال اطاعت به سوى او مى‌آيند
  24,50,"آيا در دلهايشان بيمارى است، يا شك دارند، يا از آن مى‌ترسند كه خدا و فرستاده‌اش بر آنان ستم ورزند؟ [نه،] بلكه خودشان ستمكارند"
  24,51,"گفتار مؤمنان -وقتى به سوى خدا و پيامبرش خوانده شوند تا ميانشان داورى كند- تنها اين است كه مى‌گويند: «شنيديم و اطاعت كرديم.» اينانند كه رستگارند"
  24,52,و كسى كه خدا و فرستاده او را فرمان برد، و از خدا بترسد و از او پروا كند؛ آنانند كه خود كاميابند
  24,53,"و با سوگندهاى سخت خود به خدا سوگند ياد كردند كه اگر به آنان فرمان دهى، بى شك [براى جهاد] بيرون خواهند آمد. بگو: «سوگند مخوريد. اطاعتى پسنديده [بهتر است‌] كه خدا به آنچه مى‌كنيد داناست.»"
  24,54,"بگو: «خدا و پيامبر را اطاعت كنيد. پس اگر پشت نموديد، [بدانيد كه‌] بر عهده اوست آنچه تكليف شده و بر عهده شماست آنچه موظّف هستيد. و اگر اطاعتش كنيد راه خواهيد يافت، و بر فرستاده [خدا] جز ابلاغ آشكار [مأموريتى‌] نيست"
  24,55,"خدا به كسانى از شما كه ايمان آورده و كارهاى شايسته كرده‌اند، وعده داده است كه حتماً آنان را در اين سرزمين جانشين [خود] قرار دهد؛ همان گونه كه كسانى را كه پيش از آنان بودند جانشين [خود] قرار داد، و آن دينى را كه برايشان پسنديده است به سودشان مستقر كند، و بيمشان را به ايمنى مبدل گرداند، [تا] مرا عبادت كنند و چيزى را با من شريك نگردانند، و هر كس پس از آن به كفر گرايد؛ آنانند كه نافرمانند"
  24,56,"و نماز را برپا كنيد و زكات را بدهيد و پيامبر [خدا] را فرمان بريد تا مورد رحمت قرار گيريد"
  24,57,"و مپندار كسانى كه كفر ورزيدند [ما را] در زمين درمانده مى‌كنند؛ جايگاهشان در آتش است و چه بد بازگشتگاهى است"
  24,58,"اى كسانى كه ايمان آورده‌ايد، قطعاً بايد غلام و كنيزهاى شما و كسانى از شما كه به [سنِ‌] بلوغ نرسيده‌اند سه بار در شبانه روز از شما كسب اجازه كنند: پيش از نماز بامداد، و نيمروز كه جامه‌هاى خود را بيرون مى‌آوريد، و پس از نماز شامگاهان. [اين،] سه هنگام برهنگى شماست، نه بر شما و نه بر آنان گناهى نيست كه غير از اين [سه هنگام‌] گرد يكديگر بچرخيد [و با هم معاشرت نماييد]. خداوند آيات [خود] را اين گونه براى شما بيان مى‌كند، و خدا داناى سنجيده‌كار است"
  24,59,"و چون كودكان شما به [سنِ‌] بلوغ رسيدند، بايد از شما كسب اجازه كنند؛ همان گونه كه آنان كه پيش از ايشان بودند كسب اجازه كردند. خدا آيات خود را اين گونه براى شما بيان مى‌دارد، و خدا داناى سنجيده‌كار است"
  24,60,"و بر زنان از كار افتاده‌اى كه [ديگر] اميد زناشويى ندارند گناهى نيست كه پوشش خود را كنار نهند [به شرطى كه‌] زينتى را آشكار نكنند؛ و عفّت ورزيدن براى آنها بهتر است، و خدا شنواى داناست"
  24,61,"بر نابينا و لنگ و بيمار و بر شما ايرادى نيست كه از خانه‌هاى خودتان بخوريد، يا از خانه‌هاى پدرانتان يا خانه‌هاى مادرانتان يا خانه‌هاى برادرانتان يا خانه‌هاى خواهرانتان يا خانه‌هاى عموهايتان يا خانه‌هاى عمّه‌هايتان يا خانه‌هاى داييهايتان يا خانه‌هاى خاله‌هايتان يا آن [خانه‌هايى‌] كه كليدهايش را در اختيار داريد يا [خانه‌] دوستتان. [هم چنين‌] بر شما باكى نيست كه با هم بخوريد يا پراكنده. پس چون به خانه‌هايى [كه گفته شد ]درآمديد، به يكديگر سلام كنيد؛ درودى كه نزد خدا مبارك و خوش است. خداوند آيات [خود] را اين گونه براى شما بيان مى‌كند، اميد كه بينديشيد"
  24,62,جز اين نيست كه مؤمنان كسانى‌اند كه به خدا و پيامبرش گرويده‌اند، و هنگامى كه با او بر سر كارى اجتماع كردند، تا از وى كسب اجازه نكنند نمى‌روند. در حقيقت، كسانى كه از تو كسب اجازه مى‌كنند؛ آنانند كه به خدا و پيامبرش ايمان دارند. پس چون براى برخى از كارهايشان از تو اجازه خواستند، به هر كس از آنان كه خواستى اجازه ده و برايشان آمرزش بخواه كه خدا آمرزنده مهربان است
  24,63,"خطاب كردن پيامبر را در ميان خود، مانند خطاب كردن بعضى از خودتان به بعضى [ديگر] قرار مدهيد. خدا مى‌داند [چه‌] كسانى از شما دزدانه [از نزد او] مى‌گريزند. پس كسانى كه از فرمان او تمرّد مى‌كنند بترسند كه مبادا بلايى بديشان رسد يا به عذابى دردناك گرفتار شوند"
  24,64,"هش‌دار كه آنچه در آسمانها و زمين است از آنِ خداست. به يقين آنچه را كه بر آنيد مى‌داند، و روزى كه به سوى او بازگردانيده مى‌شوند آنان را [از حقيقت‌] آنچه انجام داده‌اند خبر مى‌دهد، و خدا به هر چيزى داناست"
  25,1,"بزرگ [و خجسته‌] است كسى كه بر بنده خود، فرقان [=كتاب جداسازنده حق از باطل‌] را نازل فرمود، تا براى جهانيان هشداردهنده‌اى باشد"
  25,2,همان كس كه فرمانروايى آسمانها و زمين از آنِ اوست، و فرزندى اختيار نكرده و براى او شريكى در فرمانروايى نبوده است، و هر چيزى را آفريده و بدان گونه كه درخور آن بوده اندازه‌گيرى كرده است
  25,3,و به جاى او خدايانى براى خود گرفته‌اند كه چيزى را خلق نمى‌كنند و خود خلق شده‌اند و براى خود نه زيانى را در اختيار دارند و نه سودى را، و نه مرگى را در اختيار دارند و نه حياتى و نه رستاخيزى را
  25,4,"و كسانى كه كفر ورزيدند، گفتند: «اين [كتاب‌] جز دروغى كه آن را بربافته [چيزى‌] نيست، و گروهى ديگر او را بر آن يارى كرده‌اند.» و قطعاً [با چنين نسبتى‌] ظلم و بهتانى به پيش آوردند"
  25,5,"و گفتند: «افسانه‌هاى پيشينيان است كه آنها را براى خود نوشته، و صبح و شام بر او املا مى‌شود.»"
  25,6,"بگو: «آن را كسى نازل ساخته است كه راز نهانها را در آسمانها و زمين مى‌داند، و هموست كه همواره آمرزنده مهربان است.»"
  25,7,"و گفتند: «اين چه پيامبرى است كه غذا مى‌خورد و در بازارها راه مى‌رود؟ چرا فرشته‌اى به سوى او نازل نشده تا همراه وى هشداردهنده باشد؟"
  25,8,"يا گنجى به طرف او افكنده نشده يا باغى ندارد كه از [بار و بَر] آن بخورد؟» و ستمكاران گفتند: « جز مردى افسون‌شده را دنبال نمى‌كنيد.»"
  25,9,بنگر چگونه براى تو مَثَلها زدند و گمراه شدند؛ در نتيجه نمى‌توانند راهى بيابند
  25,10,"بزرگ [و خجسته‌] است كسى كه اگر بخواهد بهتر از اين را براى تو قرار مى‌دهد: باغهايى كه جويبارها از زير [درختان‌] آن روان خواهد بود، و براى تو كاخها پديد مى‌آورد"
  25,11,"[نه!] بلكه [آنها] رستاخيز را دروغ خواندند، و براى هر كس كه رستاخيز را دروغ خوانَد آتش سوزان آماده كرده‌ايم"
  25,12,"چون [دوزخ‌] از فاصله‌اى دور، آنان را ببيند، خشم و خروشى از آن مى‌شنوند"
  25,13,"و چون آنان را در تنگنايى از آن به زنجير كشيده بيندازند، آنجاست كه مرگ [خود] را مى‌خواهند"
  25,14,"«امروز يك بار هلاك [خود] را مخواهيد و بسيار هلاك [خود] را بخواهيد.»"
  25,15,"بگو: «آيا اين [عقوبت‌] بهتر است يا بهشت جاويدان كه به پرهيزگاران وعده داده شده است كه پاداش و سرانجام آنان است؟»"
  25,16,"جاودانه هر چه بخواهند در آنجا دارند. پروردگار تو مسؤول [تحقق‌] اين وعده است"
  25,17,"و روزى كه آنان را با آنچه به جاى خدا مى‌پرستند، محشور مى‌كند، پس مى‌فرمايد: «آيا شما اين بندگان مرا به بيراهه كشانديد يا خود گمراه شدند؟»"
  25,18,"مى‌گويند: «منزهى تو، ما را نسزد كه جز تو دوستى براى خود بگيريم، ولى تو آنان و پدرانشان را برخوردار كردى تا [آنجا كه‌] ياد [تو] را فراموش كردند و گروهى هلاك‌شده، بودند.»"
  25,19,"قطعاً [خدايانتان‌] در آنچه مى‌گفتيد، شما را تكذيب كردند؛ در نتيجه نه مى‌توانيد [عذاب را از خود] دفع كنيد و نه [خود را] يارى نماييد و هر كس از شما شرك ورزد عذابى سهمگين به او مى‌چشانيم"
  25,20,"و پيش از تو پيامبران [خود] را نفرستاديم جز اينكه آنان [نيز] غذا مى‌خوردند و در بازارها راه مى‌رفتند، و برخى از شما را براى برخى ديگر [وسيله‌] آزمايش قرار داديم. آيا شكيبايى مى‌كنيد؟ و پروردگار تو همواره بيناست"