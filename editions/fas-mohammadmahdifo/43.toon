quran[89]{c,v,t}:
  43,1,حاء، ميم
  43,2,سوگند به كتاب روشنگر
  43,3,ما آن را قرآنى عربى قرار داديم، باشد كه بينديشيد
  43,4,"و همانا كه آن در كتاب اصلى [=لوح محفوظ] به نزد ما سخت والا و پر حكمت است"
  43,5,"آيا به [صِرف‌] اينكه شما قومى منحرفيد [بايد] قرآن را از شما باز داريم؟"
  43,6,"و چه بسا پيامبرانى كه در [ميان‌] گذشتگان روانه كرديم"
  43,7,و هيچ پيامبرى به سوى ايشان نيامد، مگر اينكه او را به ريشخند مى‌گرفتند
  43,8,و نيرومندتر از آنان را به هلاكت رسانيديم و سنّت پيشينيان تكرار شد
  43,9,"و اگر از آنان بپرسى: «آسمانها و زمين را چه كسى آفريده؟» قطعاً خواهند گفت: «آنها را همان قادر دانا آفريده است.»"
  43,10,همان كسى كه اين زمين را براى شما گهواره‌اى گردانيد و براى شما در آن راهها نهاد، باشد كه راه يابيد
  43,11,"و آن كس كه آبى به اندازه از آسمان فرود آورد، پس به وسيله آن، سرزمينى مرده را زنده گردانيديم؛ همين گونه [از گورها] بيرون آورده مى‌شويد"
  43,12,"و همان كسى كه جفتها را يكسره آفريد، و براى شما از كشتيها و دامها [وسيله‌اى كه‌] سوار شويد قرار داد"
  43,13,"تا بر پشت آن‌[ها] قرار گيريد، پس چون بر آن‌[ها] برنشستيد، نعمت پروردگار خود را ياد كنيد و بگوييد: «پاك است كسى كه اين را براى ما رام كرد و[گرنه‌] ما را ياراى [رام‌ساختن‌] آنها نبود.»"
  43,14,«و به راستى كه ما به سوى پروردگارمان بازخواهيم گشت.»
  43,15,"و براى او بعضى از بندگان [خدا] را جزئى [چون فرزند و شريك‌] قرار دادند. به راستى كه انسان بس ناسپاس آشكار است"
  43,16,آيا از آنچه مى‌آفريند، خود، دخترانى برگرفته و به شما پسران را اختصاص داده است؟
  43,17,"و چون يكى از آنان را به آنچه به [خداى‌] رحمان نسبت مى‌دهد خبر دهند، چهره او سياه مى‌گردد، در حالى كه خشم و تأسف خود را فرو مى‌خورد"
  43,18,"آيا كسى [را شريك خدا مى‌كنند] كه در زر و زيور پرورش يافته و در [هنگام‌] مجادله، بيانش غير روشن است؟"
  43,19,"و فرشتگانى را كه خود، بندگان رحمانند، مادينه [و دختران او] پنداشتند. آيا در خلقت آنان حضور داشتند؟ گواهى ايشان به زودى نوشته مى‌شود و [از آن‌] پرسيده خواهند شد"
  43,20,"و مى‌گويند: «اگر [خداى‌] رحمان مى‌خواست، آنها را نمى‌پرستيديم.» آنان به اين [دعوى‌] دانشى ندارند [و] جز حدس نمى‌زنند"
  43,21,"آيا به آنان پيش از آن [قرآن‌] كتابى داده‌ايم كه بدان تمسك مى‌جويند؟"
  43,22,"[نه،] بلكه گفتند: «ما پدران خود را بر آيينى يافتيم و ما [هم با] پى گيرى از آنان، راه يافتگانيم.»"
  43,23,"و بدين گونه در هيچ شهرى پيش از تو هشداردهنده‌اى نفرستاديم مگر آنكه خوشگذرانان آن گفتند: «ما پدران خود را بر آيينى [و راهى‌] يافته‌ايم و ما از پى ايشان راهسپريم.»"
  43,24,"گفت «هر چند هدايت كننده‌تر از آنچه پدران خود را بر آن يافته‌ايد براى شما بياورم؟» گفتند: «ما [نسبت‌] به آنچه بدان فرستاده شده‌ايد كافريم.»"
  43,25,پس، از آنان انتقام گرفتيم. پس بنگر فرجام تكذيب‌كنندگان چگونه بوده است
  43,26,"و چون ابراهيم به [نا]پدرى خود و قومش گفت: «من واقعاً از آنچه مى‌پرستيد بيزارم،"
  43,27,"مگر [از] آن كس كه مرا پديد آورد؛ و البته او مرا راهنمايى خواهد كرد.»"
  43,28,"و او آن را در پى خود سخنى جاويدان كرد، باشد كه آنان [به توحيد] بازگردند"
  43,29,بلكه اينان و پدرانشان را برخودارى دادم تا حقيقت و فرستاده‌اى آشكار به سويشان آمد
  43,30,"و چون حقيقت به سويشان آمد، گفتند: «اين افسونى است و ما منكر آنيم.»"
  43,31,"و گفتند: «چرا اين قرآن بر مردى بزرگ از [آن‌] دو شهر فرود نيامده است؟»"
  43,32,"آيا آنانند كه رحمت پروردگارت را تقسيم مى‌كنند؟ ما [وسايل‌] معاش آنان را در زندگى دنيا ميانشان تقسيم كرده‌ايم، و برخى از آنان را از [نظر] درجات، بالاتر از بعضى [ديگر] قرار داده‌ايم تا بعضى از آنها بعضى [ديگر] را در خدمت گيرند، و رحمت پروردگار تو از آنچه آنان مى‌اندوزند بهتر است"
  43,33,"و اگر نه آن بود كه [همه‌] مردم [در انكار خدا] امتى واحد گردند، قطعاً براى خانه‌هاى آنان كه به [خداى‌] رحمان كفر مى‌ورزيدند، سقفها و نردبانهايى از نقره كه بر آنها بالا روند قرار مى‌داديم"
  43,34,و براى خانه‌هايشان نيز درها و تختهايى كه بر آنها تكيه زنند
  43,35,"و زر و زيورهاى [ديگر نيز]. و همه اينها جز متاع زندگى دنيا نيست، و آخرت پيش پروردگار تو براى پرهيزگاران است"
  43,36,"و هر كس از ياد [خداى‌] رحمان دل بگرداند، بر او شيطانى مى‌گماريم تا براى وى دمسازى باشد"
  43,37,"و مسلماً آنها ايشان را از راه باز مى‌دارند و [آنها] مى‌پندارند كه راه يافتگانند"
  43,38,"تا آنگاه كه او [با دمسازش‌] به حضور ما آيد، [خطاب به شيطان‌] گويد: «اى كاش ميان من و تو، فاصله خاور و باختر بود، كه چه بد دمسازى هستى!»"
  43,39,"و امروز هرگز [پشيمانى‌] براى شما سود نمى‌بخشد، چون ستم كرديد؛ در حقيقت، شما در عذاب، مشترك خواهيد بود"
  43,40,پس آيا تو مى‌توانى كران را شنوا كنى، يا نابينايان و كسى را كه همواره در گمراهى آشكارى است راه نمايى؟
  43,41,"پس اگر ما تو را [از دنيا] ببريم، قطعاً از آنان انتقام مى‌كشيم،"
  43,42,"يا [اگر] آنچه را به آنان وعده داده‌ايم به تو نشان دهيم؛ حتماً ما بر آنان قدرت داريم"
  43,43,پس به آنچه به سوى تو وحى شده است چنگ دَرْزَنْ، كه تو بر راهى راست قرار دارى
  43,44,"و به راستى كه [قرآن‌] براى تو و براى قوم تو [مايه‌] تذكّرى است، و به زودى [در مورد آن‌] پرسيده خواهيد شد"
  43,45,"و از رسولان ما كه پيش از تو گسيل داشتيم جويا شو؛ آيا در برابر [خداى‌] رحمان، خدايانى كه مورد پرستش قرار گيرند مقرر داشته‌ايم؟"
  43,46,"و همانا موسى را با نشانه‌هاى خويش به سوى فرعون و سران [قوم‌] او روانه كرديم. پس گفت: «من فرستاده پروردگار جهانيانم.»"
  43,47,پس چون آيات ما را براى آنان آورد، ناگهان ايشان بر آنها خنده زدند
  43,48,"و [ما] نشانه‌اى به ايشان نمى‌نموديم مگر اينكه آن از نظير [و مشابه‌] آن بزرگتر بود، و به عذاب گرفتارشان كرديم تا مگر به راه آيند"
  43,49,"و گفتند: «اى فسونگر، پروردگارت را به [پاس‌] آنچه با تو عهد كرده، براى ما بخوان، كه ما واقعاً به راه درست درآمده‌ايم.»"
  43,50,و چون عذاب را از آنها برداشتيم، بناگاه آنان پيمان شكستند
  43,51,"و فرعون در [ميان‌] قوم خود ندا درداد [و] گفت: «اى مردم [كشور] من، آيا پادشاهى مصر و اين نهرها كه از زير [كاخهاى‌] من روان است از آنِ من نيست؟ پس مگر نمى‌بينيد؟"
  43,52,"آيا [نه‌] من از اين كس كه خود بى‌مقدار است و نمى‌تواند درست بيان كند بهترم؟"
  43,53,پس چرا بر او دستبندهايى زرين آويخته نشده؟ يا با او فرشتگانى همراه نيامده‌اند؟
  43,54,"پس قوم خود را سبك‌مغز يافت [و آنان را فريفت‌] و اطاعتش كردند، چرا كه آنها مردمى منحرف بودند"
  43,55,و چون ما را به خشم درآوردند، از آنان انتقام گرفتيم و همه آنان را غرق كرديم
  43,56,"و آنان را پيشينه‌اى [بد] و عبرتى براى آيندگان گردانيديم"
  43,57,"و هنگامى كه [در مورد] پسر مريم مثالى آورده شد، بناگاه قوم تو از آن [سخن‌] هِلهِله درانداختند [و اعراض كردند]،"
  43,58,"و گفتند: «آيا معبودان ما بهترند يا او؟» آن [مثال‌] را جز از راه جدل براى تو نزدند، بلكه آنان مردمى جدل‌پيشه‌اند"
  43,59,"[عيسى‌] جز بنده‌اى كه بر وى منت نهاده و او را براى فرزندان اسرائيل سرمشق [و آيتى‌] گردانيده‌ايم نيست"
  43,60,"و اگر بخواهيم قطعاً به جاى شما فرشتگانى كه در [روى‌] زمين جانشين [شما] گردند قرار دهيم"
  43,61,"و همانا آن، نشانه‌اى براى [فهم‌] رستاخيز است، پس زنهار در آن ترديد مكن، و از من پيروى كنيد؛ اين است راه راست"
  43,62,و مبادا شيطان شما را از راه به در برد، زيرا او براى شما دشمنى آشكار است
  43,63,"و چون عيسى دلايل آشكار آورد، گفت: «به راستى براى شما حكمت آوردم، و تا در باره بعضى از آنچه در آن اختلاف مى‌كرديد برايتان توضيح دهم. پس، از خدا بترسيد و فرمانم ببريد.»"
  43,64,در حقيقت، خداست كه خود پروردگار من و پروردگار شماست. پس او را بپرستيد؛ اين است راه راست
  43,65,"تا [آنكه‌] از ميانشان، احزاب دست به اختلاف زدند، پس واى بر كسانى كه ستم كردند از عذاب روزى دردناك"
  43,66,"آيا جز [اين‌] انتظار مى‌برند كه رستاخيز -در حالى كه حدس نمى‌زنند- ناگهان بر آنان در رسد؟"
  43,67,در آن روز، ياران -جز پرهيزگاران- بعضى‌شان دشمن بعضى ديگرند
  43,68,اى بندگان من، امروز بر شما بيمى نيست و غمگين نخواهيد شد
  43,69,همان كسانى كه به آيات ما ايمان آورده و تسليم بودند
  43,70,شما با همسرانتان شادمانه داخل بهشت شويد
  43,71,"سينيهايى از طلا و جام‌هايى در برابر آنان مى‌گردانند، و در آنجا آنچه دلها آن را بخواهند و ديدگان را خوش آيد [هست‌] و شما در آن جاودانيد"
  43,72,"و اين است همان بهشتى كه به [پاداش‌] آنچه مى‌كرديد ميراث يافتيد"
  43,73,در آنجا براى شما ميوه‌هايى فراوان خواهد بود كه از آنها مى‌خوريد
  43,74,بى‌گمان، مجرمان در عذاب جهنم ماندگارند
  43,75,"[عذاب‌] از آنان تخفيف نمى‌يابد و آنها در آنجا نوميدند"
  43,76,و ما بر ايشان ستم نكرديم، بلكه خود ستمكار بودند
  43,77,"و فرياد كشند: «اى مالك، [بگو:] پروردگارت جان ما را بستاند.» پاسخ دهد: « شما ماندگاريد.»"
  43,78,قطعاً حقيقت را برايتان آورديم، ليكن بيشتر شما حقيقت را خوش نداشتيد
  43,79,"يا در كارى ابرام ورزيده‌اند؟ ما [نيز] ابرام مى‌ورزيم"
  43,80,"آيا مى‌پندارند كه ما راز آنها و نجوايشان را نمى‌شنويم؟ چرا، و فرشتگان ما پيش آنان [حاضرند و] ثبت مى‌كنند"
  43,81,"بگو: «اگر براى [خداى‌] رحمان فرزندى بود، خود من نخستين پرستندگان بودم.»"
  43,82,"پروردگار آسمانها و زمين [و] پروردگار عرش، از آنچه وصف مى‌كنند منزه است"
  43,83,پس آنان را رها كن تا در ياوه‌گويى خود فرو روند و بازى كنند تا آن روزى را كه بدان وعده داده مى‌شوند ديدار كنند
  43,84,و اوست كه در آسمان خداست و در زمين خداست، و هموست سنجيده‌كار دانا
  43,85,و خجسته است كسى كه فرمانروايى آسمانها و زمين و آنچه ميان آن دو است از آنِ اوست، و علم قيامت پيش اوست و به سوى او برگردانيده مى‌شويد
  43,86,"و كسانى كه به جاى او مى‌خوانند [و مى‌پرستند] اختيار شفاعت ندارند، مگر آن كسانى كه آگاهانه به حق گواهى داده باشند"
  43,87,"و اگر از آنان بپرسى: «چه كسى آنان را خلق كرده؟» مسلماً خواهند گفت: «خدا.» پس چگونه [از حقيقت‌] بازگردانيده مى‌شوند؟"
  43,88,"و گويد: «اى پروردگار من، اينها جماعتى‌اند كه ايمان نخواهند آورد.»"
  43,89,"[و خدا فرمود:] از ايشان روى برتاب و بگو: «به سلامت.» پس زودا كه بدانند"