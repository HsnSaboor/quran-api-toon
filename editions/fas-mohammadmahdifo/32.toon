quran[30]{c,v,t}:
  32,1,الف، لام، ميم
  32,2,"نازل شدن اين كتاب -كه هيچ [جاى‌] شك در آن نيست- از طرف پروردگار جهانهاست"
  32,3,"آيا مى‌گويند: «آن را بربافته است»؟ [نه چنين است‌] بلكه آن حقّ و از جانب پروردگار توست، تا مردمى را كه پيش از تو بيم‌دهنده‌اى براى آنان نيامده است هشدار دهى، اميد كه راه يابند"
  32,4,"خدا كسى است كه آسمانها و زمين و آنچه را كه ميان آن دو است، در شش هنگام آفريد، آنگاه بر عرش [قدرت‌] استيلا يافت، براى شما غير از او سرپرست و شفاعتگرى نيست؛ آيا باز هم پند نمى‌گيريد؟"
  32,5,"كار [جهان‌] را از آسمان [گرفته‌] تا زمين، اداره مى‌كند؛ آنگاه [نتيجه و گزارش آن‌] در روزى كه مقدارش -آن چنان كه شما [آدميان‌] برمى‌شماريد- هزار سال است، به سوى او بالا مى‌رود"
  32,6,اوست داناى نهان و آشكار، كه شكوهمند مهربان است
  32,7,همان كسى كه هر چيزى را كه آفريده است نيكو آفريده، و آفرينش انسان را از گِل آغاز كرد؛
  32,8,"سپس [تداوم‌] نسل او را از چكيده آبى پست مقرر فرمود؛"
  32,9,آنگاه او را درست‌اندام كرد، و از روح خويش در او دميد، و براى شما گوش و ديدگان و دلها قرار داد؛ چه اندك سپاس مى‌گزاريد
  32,10,"و گفتند: «آيا وقتى در [دلِ‌] زمين گم شديم، آيا [باز] ما در خلقت جديدى خواهيم بود؟» [نه،] بلكه آنها به لقاى پروردگارشان [و حضور او] كافرند"
  32,11,"بگو: «فرشته مرگى كه بر شما گمارده شده، جانتان را مى‌ستاند، آنگاه به سوى پروردگارتان بازگردانيده مى‌شويد.»"
  32,12,"و كاش هنگامى را كه مجرمان پيش پروردگارشان سرهاشان را به زير افكنده‌اند مى‌ديدى [كه مى‌گويند:] «پروردگارا، ديديم و شنيديم؛ ما را بازگردان تا كار شايسته كنيم، چرا كه ما يقين داريم.»"
  32,13,"و اگر مى‌خواستيم، حتماً به هر كسى [از روى جبر] هدايتش را مى‌داديم، ليكن سخن من محقَقَ گرديده كه: «هر آينه جهنم را از همه جنيان و آدميان خواهم آكند.»"
  32,14,"پس به [سزاى‌] آنكه ديدار اين روزتان را از ياد برديد [عذاب را] بچشيد؛ ما [نيز] فراموشتان كرديم، و به [سزاى‌] آنچه انجام مى‌داديد عذاب جاودان را بچشيد"
  32,15,"تنها كسانى به آيات ما مى‌گروند كه چون آن [آيات‌] را به ايشان يادآورى كنند، سجده‌كنان به روى درمى‌افتند، و به ستايش پروردگارشان تسبيح مى‌گويند و آنان بزرگى نمى‌فروشند"
  32,16,"پهلوهايشان از خوابگاهها جدا مى‌گردد [و] پروردگارشان را از روى بيم و طمع مى‌خوانند، و از آنچه روزيشان داده‌ايم انفاق مى‌كنند"
  32,17,"هيچ كس نمى‌داند چه چيز از آنچه روشنى‌بخش ديدگان است به [پاداش‌] آنچه انجام مى‌دادند براى آنان پنهان كرده‌ام"
  32,18,آيا كسى كه مؤمن است، چون كسى است كه نافرمان است؟ يكسان نيستند
  32,19,"اما كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، به [پاداش‌] آنچه انجام مى‌دادند در باغهايى كه در آن جايگزين مى‌شوند، پذيرايى مى‌گردند"
  32,20,"و اما كسانى كه نافرمانى كرده‌اند، پس جايگاهشان آتش است. هر بار كه بخواهند از آن بيرون بيايند، در آن بازگردانيده مى‌شوند و به آنان گفته مى‌شود: «عذاب آن آتشى را كه دروغش مى‌پنداشتيد بچشيد.»"
  32,21,"و قطعاً غير از آن عذاب بزرگتر، از عذاب اين دنيا [نيز] به آنان مى‌چشانيم، اميد كه آنها [به خدا] بازگردند"
  32,22,"و كيست بيدادگرتر از آن كس كه به آيات پروردگارش پند داده شود [و] آنگاه از آن روى بگرداند؟ قطعاً ما از مجرمان انتقام‌كِشنده‌ايم"
  32,23,"و به راستى [ما] به موسى كتاب داديم. پس در لقاى او [با خدا]ترديد مكن، و آن [كتاب‌] را براى فرزندان اسرائيل [مايه‌] هدايت قرار داديم"
  32,24,"و چون شكيبايى كردند و به آيات ما يقين داشتند، برخى از آنان را پيشوايانى قرار داديم كه به فرمان ما [مردم را] هدايت مى‌كردند"
  32,25,در حقيقت، پروردگار تو، خود روز قيامت در آنچه با يكديگر در باره آن اختلاف مى‌كردند، ميانشان داورى خواهد كرد
  32,26,"آيا براى آنان روشن نگرديده كه چه بسيار نسلها را پيش از آنها نابود گردانيديم [كه اينان‌] در سراهايشان راه مى‌روند؟ قطعاً در اين [امر] عبرتهاست، مگر نمى‌شنوند؟"
  32,27,آيا ننگريسته‌اند كه ما باران را به سوى زمين باير مى‌رانيم، و به وسيله آن كِشته‌اى را برمى‌آوريم كه دامهايشان و خودشان از آن مى‌خورند؟ مگر نمى‌بينند؟
  32,28,"و مى‌پرسند: «اگر راست مى‌گوييد، اين پيروزى [شما] چه وقت است؟»"
  32,29,"بگو: «روز پيروزى، ايمان كسانى كه كافر شده‌اند سود نمى‌بخشد و آنان مهلت نمى‌يابند.»"
  32,30,پس، از ايشان روى برتاب و منتظر باش كه آنها نيز در انتظارند