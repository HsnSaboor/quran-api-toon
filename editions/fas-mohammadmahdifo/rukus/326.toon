quran[36]{c,v,t}:
  26,192,"و راستى كه اين [قرآن‌] وحى پروردگار جهانيان است"
  26,193,«روح الامين» آن را بر دلت نازل كرد،
  26,194,"تا از [جمله‌] هشداردهندگان باشى؛"
  26,195,به زبان عربى روشن،
  26,196,"و [وصف‌] آن در كتابهاى پيشينيان آمده است"
  26,197,آيا براى آنان، اين خود دليلى روشن نيست كه علماى بنى‌اسرائيل از آن اطّلاع دارند؟
  26,198,و اگر آن را بر برخى از غير عرب زبانان نازل مى‌كرديم،
  26,199,و پيامبر آن را برايشان مى‌خواند به آن ايمان نمى‌آوردند
  26,200,"اين گونه در دلهاى گناهكاران، [انكار را] راه مى‌دهيم"
  26,201,كه به آن نگروند تا عذاب پردرد را ببينند،
  26,202,كه به طور ناگهانى -در حالى كه بى‌خبرند- بديشان برسد
  26,203,"و بگويند: «آيا مهلت خواهيم يافت؟»"
  26,204,پس آيا عذاب ما را به شتاب مى‌خواهند؟
  26,205,مگر نمى‌دانى كه اگر سالها آنان را برخوردار كنيم،
  26,206,"و آنگاه آنچه كه [بدان‌] بيم داده مى‌شوند بديشان برسد،"
  26,207,"آنچه از آن برخوردار مى‌شدند، به كارشان نمى‌آيد [و عذاب را از آنان دفع نمى‌كند]؟"
  26,208,و هيچ شهرى را هلاك نكرديم مگر آنكه براى آن هشداردهندگانى بود
  26,209,"[تا آنان را] تذكر [دهند]؛ و ما ستمكار نبوده‌ايم"
  26,210,و شيطانها آن را فرود نياورده‌اند
  26,211,"و آنان را نسزد و نمى‌توانند [وحى كنند]"
  26,212,"در حقيقت آنها از شنيدن، معزول [و محروم‌]اند"
  26,213,پس با خدا، خداى ديگر مخوان كه از عذاب‌شدگان خواهى شد
  26,214,و خويشان نزديكت را هشدار ده
  26,215,و براى آن مؤمنانى كه تو را پيروى كرده‌اند، بال خود را فرو گستر
  26,216,"و اگر تو را نافرمانى كردند، بگو: «من از آنچه مى‌كنيد بيزارم.»"
  26,217,"و بر [خداىِ‌] عزيزِ مهربان توكل كن،"
  26,218,"آن كس كه چون [به نماز] برمى‌خيزى تو را مى‌بيند،"
  26,219,"و حركت تو را در ميان سجده‌كنندگان [مى‌نگرد]"
  26,220,او همان شنواى داناست
  26,221,آيا شما را خبر دهم كه شياطين بر چه كسى فرود مى‌آيند؟
  26,222,بر هر دروغزن گناهكارى فرود مى‌آيند،
  26,223,"كه [دزدانه‌] گوش فرا مى‌دارند و بيشترشان دروغگويند،"
  26,224,و شاعران را گمراهان پيروى مى‌كنند
  26,225,آيا نديده‌اى كه آنان در هر واديى سرگردانند؟
  26,226,و آنانند كه چيزهايى مى‌گويند كه انجام نمى‌دهند
  26,227,مگر كسانى كه ايمان آورده و كارهاى شايسته كرده و خدا را بسيار به ياد آورده و پس از آنكه مورد ستم قرار گرفته‌اند يارى خواسته‌اند. و كسانى كه ستم كرده‌اند به زودى خواهند دانست به كدام بازگشتگاه برخواهند گشت