quran[39]{c,v,t}:
  37,75,و نوح، ما را ندا داد، و چه نيك اجابت‌كننده بوديم
  37,76,و او و كسانش را از اندوه بزرگ رهانيديم
  37,77,"و [تنها] نسل او را باقى گذاشتيم"
  37,78,"و در ميان آيندگان [آوازه نيك‌] او را بر جاى گذاشتيم"
  37,79,درود بر نوح در ميان جهانيان
  37,80,ما اين گونه نيكوكاران را پاداش مى‌دهيم
  37,81,به راستى او از بندگان مؤمن ما بود
  37,82,سپس ديگران را غرق كرديم
  37,83,و بى‌گمان، ابراهيم از پيروان اوست
  37,84,"آنگاه كه با دلى پاك به [پيشگاه‌] پروردگارش آمد"
  37,85,"چون به پدر[خوانده‌] و قوم خود گفت: «چه مى‌پرستيد؟"
  37,86,"آيا غير از آنها، به دروغ، خدايانى [ديگر] مى‌خواهيد؟"
  37,87,پس گمانتان به پروردگار جهانها چيست؟»
  37,88,پس نظرى به ستارگان افكند،
  37,89,"و گفت: «من كسالت دارم!»"
  37,90,پس پشت‌كنان از او روى برتافتند
  37,91,"تا نهانى به سوى خدايانشان رفت و [به ريشخند] گفت: «آيا غذا نمى‌خوريد؟"
  37,92,شما را چه شده كه سخن نمى‌گوييد؟!»
  37,93,پس با دست راست، بر سر آنها زدن گرفت
  37,94,تا دوان دوان سوى او روى‌آور شدند
  37,95,"[ابراهيم‌] گفت: «آيا آنچه را مى‌تراشيد، مى‌پرستيد؟"
  37,96,با اينكه خدا شما و آنچه را كه برمى‌سازيد آفريده است!»
  37,97,"گفتند: «برايش [كوره‌]خانه‌اى بسازيد و در آتشش بيندازيد»"
  37,98,"پس خواستند به از نيرنگى زنند؛ و[لى‌] ما آنان را پست گردانيديم"
  37,99,"و [ابراهيم‌] گفت: «من به سوى پروردگارم رهسپارم، زودا كه مرا راه نمايد!»"
  37,100,"«اى پروردگار من! مرا [فرزندى‌] از شايستگان بخش.»"
  37,101,پس او را به پسرى بردبار مژده داديم
  37,102,"و وقتى با او به جايگاه «سعى» رسيد، گفت: «اى پسرك من! من در خواب [چنين‌] مى‌بينم كه تو را سَرْ مى‌بُرم، پس ببين چه به نظرت مى‌آيد؟» گفت: «اى پدر من! آنچه را مأمورى بكن! ان شاء الله مرا از شكيبايان خواهى يافت.»"
  37,103,"پس وقتى هر دو تن دردادند [و همديگر را بدرود گفتند] و [پسر] را به پيشانى بر خاك افكند،"
  37,104,او را ندا داديم كه اى ابراهيم
  37,105,"رؤيا[ى خود] را حقيقت بخشيدى! ما نيكوكاران را چنين پاداش مى‌دهيم"
  37,106,راستى كه اين همان آزمايش آشكار بود
  37,107,و او را در ازاى قربانى بزرگى باز رهانيديم
  37,108,"و در [ميان‌] آيندگان براى او [آوازه نيك‌] به جاى گذاشتيم"
  37,109,درود بر ابراهيم
  37,110,نيكوكاران را چنين پاداش مى‌دهيم
  37,111,در حقيقت، او از بندگان با ايمان ما بود
  37,112,"و او را به اسحاق كه پيامبرى از [جمله‌] شايستگان است مژده داديم"
  37,113,"و به او و به اسحاق بركت داديم، و از نسل آن دو برخى نيكوكار و [برخى‌] آشكارا به خود ستمكار بودند"