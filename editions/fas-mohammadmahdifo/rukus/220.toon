quran[19]{c,v,t}:
  15,26,و در حقيقت، انسان را از گِلى خشك، از گِلى سياه و بدبو، آفريديم
  15,27,و پيش از آن، جن را از آتشى سوزان و بى‌دود خلق كرديم
  15,28,"و [ياد كن‌] هنگامى را كه پروردگار تو به فرشتگان گفت: «من بشرى را از گِلى خشك، از گِلى سياه و بدبو، خواهم آفريد"
  15,29,پس وقتى آن را درست كردم و از روح خود در آن دميدم، پيش او به سجده درافتيد
  15,30,پس فرشتگان همگى يكسره سجده كردند،
  15,31,جز ابليس كه خوددارى كرد از اينكه با سجده‌كنندگان باشد
  15,32,"فرمود: «اى ابليس، تو را چه شده است كه با سجده‌كنندگان نيستى؟»"
  15,33,"گفت: «من آن نيستم كه براى بشرى كه او را از گِلى خشك، از گِلى سياه و بدبو، آفريده‌اى، سجده كنم.»"
  15,34,"فرمود: «از اين [مقام‌] بيرون شو كه تو رانده‌شده‌اى"
  15,35,و تا روز جزا بر تو لعنت باشد
  15,36,"گفت: «پروردگارا، پس مرا تا روزى كه برانگيخته خواهند شد مهلت ده.»"
  15,37,"فرمود: «تو از مهلت‌يافتگانى،"
  15,38,"تا روز [و] وقت معلوم"
  15,39,"گفت: «پروردگارا، به سبب آنكه مرا گمراه ساختى، من [هم گناهانشان را] در زمين برايشان مى‌آرايم و همه را گمراه خواهم ساخت،"
  15,40,مگر بندگان خالص تو از ميان آنان را.»
  15,41,"فرمود: «اين راهى است راست [كه‌] به سوى من [منتهى مى‌شود]"
  15,42,در حقيقت، تو را بر بندگان من تسلّطى نيست، مگر كسانى از گمراهان كه تو را پيروى كنند،
  15,43,و قطعاً وعده‌گاه همه آنان دوزخ است،
  15,44,"[دوزخى‌] كه براى آن هفت در است، و از هر درى بخشى معين از آنان [وارد مى‌شوند]"