quran[25]{c,v,t}:
  37,114,و در حقيقت، بر موسى و هارون منت نهاديم
  37,115,و آن دو و قومشان را از اندوه بزرگ رهانيديم
  37,116,و آنان را يارى داديم تا ايشان غالب آمدند
  37,117,و آن دو را كتاب روشن داديم
  37,118,و هر دو را به راه راست هدايت كرديم
  37,119,"و براى آن دو در [ميان‌] آيندگان [نام نيك‌] به جاى گذاشتيم"
  37,120,درود بر موسى و هارون
  37,121,ما نيكوكاران را چنين پاداش مى‌دهيم،
  37,122,زيرا آن دو از بندگان با ايمان ما بودند
  37,123,"و به راستى الياس از فرستادگان [ما] بود"
  37,124,"چون به قوم خود گفت: «آيا پروا نمى‌داريد؟"
  37,125,آيا «بعل» را مى‌پرستيد و بهترين آفرينندگان را وامى‌گذاريد؟
  37,126,"[يعنى:] خدا را كه پروردگار شما و پروردگار پدران پيشين شماست؟"
  37,127,"پس او را دروغگو شمردند، و قطعاً آنها [در آتش‌] احضار خواهند شد"
  37,128,مگر بندگان پاكدين خدا
  37,129,"و براى او در [ميان‌] آيندگان [آوازه نيك‌] به جاى گذاشتيم"
  37,130,درود بر پيروان الياس
  37,131,ما نيكوكاران را اين گونه پاداش مى‌دهيم،
  37,132,زيرا او از بندگان با ايمان ما بود
  37,133,و در حقيقت، لوط از زمره فرستادگان بود
  37,134,آنگاه كه او و همه كسانش را رهانيديم
  37,135,"جز پيرزنى كه در ميان باقى‌ماندگان [و خاكسترشدگان‌] بود"
  37,136,سپس ديگران را هلاك كرديم
  37,137,و در حقيقت، شما بر آنان صبحگاهان
  37,138,و شامگاهان مى‌گذريد! آيا به فكر فرو نمى‌رويد؟