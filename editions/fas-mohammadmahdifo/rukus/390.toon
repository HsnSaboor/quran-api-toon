quran[44]{c,v,t}:
  37,139,و در حقيقت، يونس از زمره فرستادگان بود
  37,140,آنگاه كه به سوى كشتى پر، بگريخت
  37,141,"پس [سرنشينان‌] با هم قرعه انداختند و [يونس‌] از باختگان شد"
  37,142,"[او را به دريا افكندند] و عنبرماهى او را بلعيد در حالى كه او نكوهشگر خويش بود"
  37,143,و اگر او از زمره تسبيح‌كنندگان نبود،
  37,144,"قطعاً تا روزى كه برانگيخته مى‌شوند، در شكم آن [ماهى‌] مى‌ماند"
  37,145,پس او را در حالى كه ناخوش بود به زمين خشكى افكنديم
  37,146,"و بر بالاى [سرِ] او درختى از [نوع‌] كدوبُن رويانيديم"
  37,147,"و او را به سوى يكصدهزار [نفر از ساكنان نينوا] يا بيشتر روانه كرديم"
  37,148,پس ايمان آوردند و تا چندى برخوردارشان كرديم
  37,149,"پس، از مشركان جويا شو: آيا پروردگارت را دختران و آنان را پسران است؟"
  37,150,يا فرشتگان را مادينه آفريديم و آنان شاهد بودند؟
  37,151,هش‌دار كه اينان از دروغ پردازى خود قطعاً خواهند گفت
  37,152,«خدا فرزند آورده!» در حالى كه آنها قطعاً دروغگويانند
  37,153,"آيا [خدا] دختران را بر پسران برگزيده است؟"
  37,154,شما را چه شده؟ چگونه داورى مى‌كنيد؟
  37,155,آيا سرِ پند گرفتن نداريد؟
  37,156,"يا دليلى آشكار [در دست‌] داريد؟"
  37,157,پس اگر راست مى‌گوييد كتابتان را بياوريد
  37,158,"و ميان خدا و جن‌ها پيوندى انگاشتند و حال آنكه جنيان نيك دانسته‌اند كه [براى حساب پس‌دادن،] خودشان احضار خواهند شد"
  37,159,خدا منزه است از آنچه در وصف مى‌آورند
  37,160,به استثناى بندگان پاكدل خدا
  37,161,"در حقيقت، شما و آنچه [كه شما آن را] مى‌پرستيد،"
  37,162,بر ضد او گمراه‌گر نيستيد،
  37,163,مگر كسى را كه به دوزخ رفتنى است
  37,164,"و هيچ يك از ما [فرشتگان‌] نيست مگر [اينكه‌] براى او [مقام و] مرتبه‌اى معيّن است"
  37,165,"و در حقيقت، ماييم كه [براى انجام فرمان خدا] صف بسته‌ايم"
  37,166,و ماييم كه خود تسبيح‌گويانيم
  37,167,"و [مشركان‌] به تأكيد مى‌گفتند"
  37,168,"«اگر پند [نامه‌ا]ى از پيشينيان نزد ما بود،"
  37,169,قطعاً از بندگان خالص خدا مى‌شديم!»
  37,170,"ولى [وقتى قرآن آمد] به آن كافر شدند، و زودا كه بدانند"
  37,171,"و قطعاً فرمان ما در باره بندگان فرستاده ما از پيش [چنين‌] رفته است"
  37,172,"كه آنان [بر دشمنان خودشان‌] حتماً پيروز خواهند شد"
  37,173,و سپاه ما هرآينه غالب‌آيندگانند
  37,174,"پس تا مدتى [معيّن‌] از آنان روى برتاب"
  37,175,و آنان را بنگر كه خواهند ديد
  37,176,آيا عذاب ما را شتابزده خواستارند؟
  37,177,"[پس هشدارداده‌شدگان را] آنگاه كه عذاب به خانه آنان فرود آيد چه بد صبحگاهى است"
  37,178,"و از ايشان تا مدتى [معيّن‌] روى برتاب"
  37,179,و بنگر كه خواهند ديد
  37,180,منزه است پروردگار تو، پروردگار شكوهمند، از آنچه وصف مى‌كنند
  37,181,و درود بر فرستادگان
  37,182,و ستايش، ويژه خدا، پروردگار جهانهاست