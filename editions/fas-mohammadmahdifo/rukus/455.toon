quran[23]{c,v,t}:
  51,1,سوگند به بادهاى ذره‌افشان،
  51,2,و ابرهاى گرانبار،
  51,3,و سبك سيران،
  51,4,"و تقسيم‌كنندگان كار[ها]،"
  51,5,كه آنچه وعده داده شده‌ايد راست است،
  51,6,"و [روز] پاداش واقعيت دارد"
  51,7,سوگند به آسمان مشبّك،
  51,8,"كه شما [درباره قرآن‌] در سخنى گوناگونيد"
  51,9,"[بگوى‌] تا هر كه از آن برگشته، برگشته باشد"
  51,10,مرگ بر دروغپردازان
  51,11,همانان كه در ورطه نادانى بى‌خبرند
  51,12,"پرسند: «روز پاداش كى است؟»"
  51,13,"همان روز كه آنان بر آتش، عقوبت [و آزموده‌] شوند"
  51,14,"عذاب [موعود] خود را بچشيد، اين است همان [بلايى‌] كه با شتاب خواستار آن بوديد"
  51,15,پرهيزگاران در باغها و چشمه سارانند
  51,16,آنچه را پروردگارشان عطا فرموده مى‌گيرند، زيرا كه آنها پيش از اين نيكوكار بودند
  51,17,و از شب اندكى را مى‌غنودند
  51,18,"و در سحرگاهان [از خدا] طلب آمرزش مى‌كردند"
  51,19,"و در اموالشان براى سائل و محروم حقى [معين‌] بود"
  51,20,"و روى زمين براى اهل يقين نشانه‌هايى [متقاعدكننده‌] است،"
  51,21,و در خود شما؛ پس مگر نمى‌بينيد؟
  51,22,و روزى شما و آنچه وعده داده شده‌ايد در آسمان است
  51,23,پس سوگند به پروردگار آسمان و زمين، كه واقعاً او حق است همان گونه كه خود شما سخن مى‌گوييد