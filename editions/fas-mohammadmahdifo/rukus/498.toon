quran[33]{c,v,t}:
  68,1,نون، سوگند به قلم و آنچه مى‌نويسند،
  68,2,"[كه‌] تو، به لطف پروردگارت، ديوانه نيستى"
  68,3,و بى‌گمان، تو را پاداشى بى‌منت خواهد بود
  68,4,و راستى كه تو را خويى والاست
  68,5,به زودى خواهى ديد و خواهند ديد،
  68,6,"[كه‌] كدام يك از شما دستخوش جنونيد"
  68,7,"پروردگارت خود بهتر مى‌داند چه كسى از راه او منحرف شده، و [هم‌] او به راه يافتگان داناتر است"
  68,8,پس، از دروغزنان فرمان مبر
  68,9,دوست دارند كه نرمى كنى تا نرمى نمايند
  68,10,و از هر قسم خورنده فرو مايه‌اى فرمان مبر
  68,11,"[كه‌] عيبجوست و براى خبرچينى گام برمى‌دارد،"
  68,12,مانع خير، متجاوز، گناه پيشه،
  68,13,"گستاخ، [و] گذشته از آن زنازاده است،"
  68,14,به صرف اينكه مالدار و پسردار است،
  68,15,"چون آيات ما بر او خوانده شود، گويد: «افسانه‌هاى پيشينيان است.»"
  68,16,"زودا كه بر بينى‌اش داغ نهيم [و رسوايش كنيم‌]"
  68,17,"ما آنان را همان گونه كه باغداران را آزموديم، مورد آزمايش قرار داديم، آنگاه كه سوگند خوردند كه صبح برخيزند و [ميوه‌] آن [باغ‌] را حتماً بچينند"
  68,18,"و[لى‌] «ان شاء الله» نگفتند"
  68,19,"پس در حالى كه آنان غنوده بودند، بلايى از جانب پروردگارت بر آن [باغ‌] به گردش در آمد"
  68,20,"و [باغ،] آفت زده [و زمين باير] گرديد"
  68,21,"پس [باغداران‌] بامدادان يكديگر را صدا زدند،"
  68,22,"كه: «اگر ميوه مى‌چينيد، بامدادان به سوى كشت خويش رويد.»"
  68,23,پس به راه افتادند و آهسته به هم مى‌گفتند
  68,24,"«كه: امروز نبايد در باغ بينوايى بر شما در آيد.»"
  68,25,"و صبحگاهان در حالى كه خود را بر منع [بينوايان‌] توانا مى‌ديدند، رفتند"
  68,26,"و چون [باغ‌] را ديدند، گفتند: «قطعاً ما راه گم كرده‌ايم"
  68,27,"[نه‌] بلكه ما محروميم"
  68,28,"خردمندترينشان گفت: «آيا به شما نگفتم: چرا خدا را به پاكى نمى‌ستاييد؟»"
  68,29,"گفتند: «پروردگارا، تو را به پاكى مى‌ستاييم، ما واقعاً ستمگر بوديم. «"
  68,30,پس بعضى‌شان رو به بعضى ديگر آوردند و همديگر را به نكوهش گرفتند
  68,31,"گفتند: «اى واى بر ما كه سركش بوده‌ايم"
  68,32,اميد است كه پروردگار ما بهتر از آن را به ما عوض دهد، زيرا ما به پروردگارمان مشتاقيم
  68,33,"عذاب [دنيا] چنين است، و عذاب آخرت، اگر مى‌دانستند قطعاً بزرگتر خواهد بود"