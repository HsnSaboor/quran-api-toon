quran[49]{c,v,t}:
  52,1,سوگند به طور،
  52,2,و كتابى نگاشته شده،
  52,3,در طومارى گسترده؛
  52,4,"سوگند به آن خانه آباد [خدا]؛"
  52,5,"سوگند به بام بلند [آسمان‌]،"
  52,6,"و آن درياى سرشار [و افروخته‌]،"
  52,7,كه عذاب پروردگارت واقع‌شدنى است؛
  52,8,آن را هيچ بازدارنده‌اى نيست
  52,9,روزى كه آسمان سخت در تب و تاب افتد،
  52,10,"و كوهها [جمله‌] به حركت درآيند"
  52,11,پس واى بر تكذيب‌كنندگان در آن روز
  52,12,آنان كه به ياوه سرگرمند
  52,13,"روزى كه به سوى آتش جهنم كشيده مى‌شوند [چه‌] كشيدنى"
  52,14,"[و به آنان گويند:] «اين همان آتشى است كه دروغش مى‌پنداشتيد"
  52,15,"آيا اين افسون است؟ يا شما [درست‌] نمى‌بينيد؟"
  52,16,به آن درآييد؛ خواه بشكيبيد يا نشكيبيد، به حال شما يكسان است. تنها به آنچه مى‌كرديد مجازات مى‌يابيد.»
  52,17,"پرهيزگاران در باغهايى و [در] ناز و نعمتند"
  52,18,به آنچه پروردگارشان به آنان داده دلشادند، و پروردگارشان آنها را از عذاب دوزخ مصون داشته است
  52,19,"[به آنان گويند:] «به [پاداش‌] آنچه به جاى مى‌آورديد بخوريد و بنوشيد؛ گواراتان باد!»"
  52,20,بر تختهايى رديف هم تكيه زده‌اند و حوران درشت‌چشم را همسر آنان گردانده‌ايم
  52,21,"و كسانى كه گرويده و فرزندانشان آنها را در ايمان پيروى كرده‌اند، فرزندانشان را به آنان ملحق خواهيم كرد و چيزى از كار[ها]شان را نمى‌كاهيم. هر كسى در گرو دستاورد خويش است"
  52,22,"با [هر نوع‌] ميوه و گوشتى كه دلخواه آنهاست آنان را مدد [و تقويت‌] مى‌كنيم"
  52,23,"در آنجا جامى از دست هم مى‌ربايند [و بر سرش همچشمى مى‌كنند] كه در آن نه ياوه گويى است و نه گناه"
  52,24,"و براى [خدمت‌] آنان پسرانى است كه بر گردشان همى‌گردند، انگارى آنها مرواريدى‌اند كه [در صدف‌] نهفته است"
  52,25,"و برخى‌شان رو به برخى كنند [و] از هم پرسند،"
  52,26,"گويند: «ما پيشتر در ميان خانواده خود بيمناك بوديم"
  52,27,"پس خدا بر ما منت نهاد و ما را از عذاب گرم [مرگبار] حفظ كرد"
  52,28,ما از ديرباز او را مى‌خوانديم، كه او همان نيكوكار مهربان است.»
  52,29,پس اندرز ده كه تو به لطف پروردگارت نه كاهنى و نه ديوانه
  52,30,"يا مى‌گويند: «شاعرى است كه انتظار مرگش را مى‌بريم [و چشم به راه بد زمانه بر اوييم‌].»"
  52,31,"بگو: «منتظر باشيد كه من [نيز] با شما از منتظرانم.»"
  52,32,"آيا پندارهايشان آنان را به اين [موضعگيرى‌] وا مى‌دارد يا [نه،] آنها مردمى سركشند؟"
  52,33,"يا مى‌گويند: «آن را بربافته.» [نه،] بلكه باور ندارند"
  52,34,پس اگر راست مى‌گويند، سخنى مثل آن بياورند
  52,35,"آيا از هيچ خلق شده‌اند؟ يا آنكه خودشان خالق [خود] هستند؟"
  52,36,"آيا آسمانها و زمين را [آنان‌] خلق كرده‌اند؟ [نه،] بلكه يقين ندارند"
  52,37,"آيا ذخاير پروردگار تو پيش آنهاست؟ يا ايشان تسلط [تام‌] دارند؟"
  52,38,"آيا نردبانى دارند كه بر آن [بر شوند و] بشنوند؟ پس بايد شنونده آنان برهانى آشكار بياورد"
  52,39,آيا خدا را دختران است و شما را پسران؟
  52,40,"آيا از آنها مزدى مطالبه مى‌كنى و آنان از [تعهّد اداى‌] تاوان گرانبارند؟"
  52,41,"آيا [علم‌] غيب پيش آنهاست و آنها مى‌نويسند؟"
  52,42,"يا مى‌خواهند نيرنگى بزنند؟ و [لى‌] آنان كه كافر شده‌اند، خود دچار نيرنگ شده‌اند"
  52,43,"آيا ايشان را جز خدا معبودى است؟ منزّه است خدا از آنچه [با او] شريك مى‌گردانند"
  52,44,"و اگر پاره‌سنگى را در حال سقوط از آسمان ببينند مى‌گويند: «ابرى متراكم است.»"
  52,45,پس بگذارشان تا به آن روزى كه در آن بيهوش مى‌افتند برسند
  52,46,روزى كه نيرنگشان به هيچ‌وجه به كارشان نيايد و حمايت نيابند
  52,47,"و در حقيقت، غير از اين [مجازات‌]، عذابى [ديگر] براى كسانى كه ظلم كرده‌اند خواهد بود، ولى بيشترشان نمى‌دانند [كه آن عذاب چيست‌]"
  52,48,"و در برابر دستور پروردگارت شكيبايى پيشه كن كه تو خود در حمايت مايى و هنگامى كه [از خواب‌] بر مى‌خيزى به نيايش پروردگارت تسبيح گوى"
  52,49,"و [نيز] پاره‌اى از شب، و در فروشدن ستارگان تسبيح‌گوى او باش"