quran[33]{c,v,t}:
  43,24,"گفت «هر چند هدايت كننده‌تر از آنچه پدران خود را بر آن يافته‌ايد براى شما بياورم؟» گفتند: «ما [نسبت‌] به آنچه بدان فرستاده شده‌ايد كافريم.»"
  43,25,پس، از آنان انتقام گرفتيم. پس بنگر فرجام تكذيب‌كنندگان چگونه بوده است
  43,26,"و چون ابراهيم به [نا]پدرى خود و قومش گفت: «من واقعاً از آنچه مى‌پرستيد بيزارم،"
  43,27,"مگر [از] آن كس كه مرا پديد آورد؛ و البته او مرا راهنمايى خواهد كرد.»"
  43,28,"و او آن را در پى خود سخنى جاويدان كرد، باشد كه آنان [به توحيد] بازگردند"
  43,29,بلكه اينان و پدرانشان را برخودارى دادم تا حقيقت و فرستاده‌اى آشكار به سويشان آمد
  43,30,"و چون حقيقت به سويشان آمد، گفتند: «اين افسونى است و ما منكر آنيم.»"
  43,31,"و گفتند: «چرا اين قرآن بر مردى بزرگ از [آن‌] دو شهر فرود نيامده است؟»"
  43,32,"آيا آنانند كه رحمت پروردگارت را تقسيم مى‌كنند؟ ما [وسايل‌] معاش آنان را در زندگى دنيا ميانشان تقسيم كرده‌ايم، و برخى از آنان را از [نظر] درجات، بالاتر از بعضى [ديگر] قرار داده‌ايم تا بعضى از آنها بعضى [ديگر] را در خدمت گيرند، و رحمت پروردگار تو از آنچه آنان مى‌اندوزند بهتر است"
  43,33,"و اگر نه آن بود كه [همه‌] مردم [در انكار خدا] امتى واحد گردند، قطعاً براى خانه‌هاى آنان كه به [خداى‌] رحمان كفر مى‌ورزيدند، سقفها و نردبانهايى از نقره كه بر آنها بالا روند قرار مى‌داديم"
  43,34,و براى خانه‌هايشان نيز درها و تختهايى كه بر آنها تكيه زنند
  43,35,"و زر و زيورهاى [ديگر نيز]. و همه اينها جز متاع زندگى دنيا نيست، و آخرت پيش پروردگار تو براى پرهيزگاران است"
  43,36,"و هر كس از ياد [خداى‌] رحمان دل بگرداند، بر او شيطانى مى‌گماريم تا براى وى دمسازى باشد"
  43,37,"و مسلماً آنها ايشان را از راه باز مى‌دارند و [آنها] مى‌پندارند كه راه يافتگانند"
  43,38,"تا آنگاه كه او [با دمسازش‌] به حضور ما آيد، [خطاب به شيطان‌] گويد: «اى كاش ميان من و تو، فاصله خاور و باختر بود، كه چه بد دمسازى هستى!»"
  43,39,"و امروز هرگز [پشيمانى‌] براى شما سود نمى‌بخشد، چون ستم كرديد؛ در حقيقت، شما در عذاب، مشترك خواهيد بود"
  43,40,پس آيا تو مى‌توانى كران را شنوا كنى، يا نابينايان و كسى را كه همواره در گمراهى آشكارى است راه نمايى؟
  43,41,"پس اگر ما تو را [از دنيا] ببريم، قطعاً از آنان انتقام مى‌كشيم،"
  43,42,"يا [اگر] آنچه را به آنان وعده داده‌ايم به تو نشان دهيم؛ حتماً ما بر آنان قدرت داريم"
  43,43,پس به آنچه به سوى تو وحى شده است چنگ دَرْزَنْ، كه تو بر راهى راست قرار دارى
  43,44,"و به راستى كه [قرآن‌] براى تو و براى قوم تو [مايه‌] تذكّرى است، و به زودى [در مورد آن‌] پرسيده خواهيد شد"
  43,45,"و از رسولان ما كه پيش از تو گسيل داشتيم جويا شو؛ آيا در برابر [خداى‌] رحمان، خدايانى كه مورد پرستش قرار گيرند مقرر داشته‌ايم؟"
  43,46,"و همانا موسى را با نشانه‌هاى خويش به سوى فرعون و سران [قوم‌] او روانه كرديم. پس گفت: «من فرستاده پروردگار جهانيانم.»"
  43,47,پس چون آيات ما را براى آنان آورد، ناگهان ايشان بر آنها خنده زدند
  43,48,"و [ما] نشانه‌اى به ايشان نمى‌نموديم مگر اينكه آن از نظير [و مشابه‌] آن بزرگتر بود، و به عذاب گرفتارشان كرديم تا مگر به راه آيند"
  43,49,"و گفتند: «اى فسونگر، پروردگارت را به [پاس‌] آنچه با تو عهد كرده، براى ما بخوان، كه ما واقعاً به راه درست درآمده‌ايم.»"
  43,50,و چون عذاب را از آنها برداشتيم، بناگاه آنان پيمان شكستند
  43,51,"و فرعون در [ميان‌] قوم خود ندا درداد [و] گفت: «اى مردم [كشور] من، آيا پادشاهى مصر و اين نهرها كه از زير [كاخهاى‌] من روان است از آنِ من نيست؟ پس مگر نمى‌بينيد؟"
  43,52,"آيا [نه‌] من از اين كس كه خود بى‌مقدار است و نمى‌تواند درست بيان كند بهترم؟"
  43,53,پس چرا بر او دستبندهايى زرين آويخته نشده؟ يا با او فرشتگانى همراه نيامده‌اند؟
  43,54,"پس قوم خود را سبك‌مغز يافت [و آنان را فريفت‌] و اطاعتش كردند، چرا كه آنها مردمى منحرف بودند"
  43,55,و چون ما را به خشم درآوردند، از آنان انتقام گرفتيم و همه آنان را غرق كرديم
  43,56,"و آنان را پيشينه‌اى [بد] و عبرتى براى آيندگان گردانيديم"