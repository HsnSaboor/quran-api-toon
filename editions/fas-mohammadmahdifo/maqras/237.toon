quran[75]{c,v,t}:
  87,1,نام پروردگار والاى خود را به پاكى بستاى
  87,2,همان كه آفريد و هماهنگى بخشيد
  87,3,و آنكه اندازه‌گيرى كرد و راه نمود
  87,4,و آنكه چمنزار را برآورد؛
  87,5,"و پس [از چندى‌] آن را خاشاكى تيره‌گون گردانيد"
  87,6,"ما بزودى [آيات خود را به وسيله سروش غيبى‌] بر تو خواهيم خواند، تا فراموش نكنى؛"
  87,7,جز آنچه خدا خواهد، كه او آشكار و آنچه را كه نهان است مى‌داند
  87,8,"و براى تو آسانترين [راه‌] را فراهم مى‌گردانيم"
  87,9,پس پند ده، اگر پند سود بخشد
  87,10,آن كس كه ترسد، بزودى عبرت گيرد
  87,11,و نگون‌بخت، خود را از آن دور مى‌دارد؛
  87,12,همان كس كه در آتشى بزرگ در آيد؛
  87,13,آنگاه نه در آن مى‌ميرد و نه زندگانى مى‌يابد
  87,14,رستگار آن كس كه خود را پاك گردانيد؛
  87,15,و نام پروردگارش را ياد كرد و نماز گزارد
  87,16,"ليكن [شما] زندگى دنيا را بر مى‌گزينيد؛"
  87,17,"با آنكه [جهان‌] آخرت نيكوتر و پايدارتر است"
  87,18,"قطعاً در صحيفه‌هاى گذشته اين [معنى‌] هست،"
  87,19,صحيفه‌هاى ابراهيم و موسى
  88,1,آيا خبر «غاشيه» به تو رسيده است؟
  88,2,در آن روز، چهره‌هايى زبونند،
  88,3,"كه تلاش كرده، رنج [بيهوده‌] برده‌اند"
  88,4,"[ناچار] در آتشى سوزان درآيند"
  88,5,از چشمه‌اى داغ نوشانيده شوند
  88,6,خوراكى جز خار خشك ندارند،
  88,7,"[كه‌] نه فربه كند، و نه گرسنگى را باز دارد"
  88,8,در آن روز، چهره‌هايى شادابند
  88,9,از كوشش خود خشنودند
  88,10,در بهشت برين‌اند
  88,11,سخن بيهوده‌اى در آنجا نشنوند
  88,12,در آن، چشمه‌اى روان باشد
  88,13,تختهايى بلند در آنجاست
  88,14,و قدحهايى نهاده شده
  88,15,"و بالشهايى پهلوى هم [چيده‌]"
  88,16,"و فرشهايى [زربفت‌] گسترده"
  88,17,آيا به شتر نمى‌نگرند كه چگونه آفريده شده؟
  88,18,و به آسمان كه چگونه برافراشته شده؟
  88,19,و به كوه‌ها كه چگونه برپا داشته شده؟
  88,20,و به زمين كه چگونه گسترده شده است؟
  88,21,پس تذكر ده كه تو تنها تذكردهنده‌اى
  88,22,بر آنان تسلّطى ندارى،
  88,23,مگر كسى كه روى بگرداند و كفر ورزد،
  88,24,كه خدا او را به آن عذاب بزرگتر عذاب كند
  88,25,در حقيقت، بازگشت آنان به سوى ماست،
  88,26,"آنگاه حساب [خواستن از] آنان به عهده ماست"
  89,1,سوگند به سپيده‌دم،
  89,2,و به شبهاى دهگانه،
  89,3,و به جفت و تاق،
  89,4,و به شب، وقتى سپرى شود
  89,5,"آيا در اين، براى خردمند [نياز به‌] سوگندى [ديگر] است؟"
  89,6,مگر ندانسته‌اى كه پروردگارت با عاد چه كرد؟
  89,7,با عمارات ستون‌دار ارم،
  89,8,كه مانندش در شهرها ساخته نشده بود؟
  89,9,و با ثمود، همانان كه در درّه، تخته‌سنگها را مى‌بريدند؟
  89,10,"و با فرعون، صاحب خرگاه‌ها [و بناهاى بلند]؟"
  89,11,همانان كه در شهرها سر به طغيان برداشتند،
  89,12,و در آنها بسيار تبهكارى كردند
  89,13,"[تا آنكه‌] پروردگارت بر سر آنان تازيانه عذاب را فرونواخت،"
  89,14,زيرا پروردگار تو سخت در كمين است
  89,15,"اما انسان، هنگامى كه پروردگارش وى را مى‌آزمايد، و عزيزش مى‌دارد و نعمت فراوان به او مى‌دهد، مى‌گويد: «پروردگارم مرا گرامى داشته است.»"
  89,16,"و اما چون وى را مى‌آزمايد و روزى‌اش را بر او تنگ مى‌گرداند، مى‌گويد: «پروردگارم مرا خوار كرده است.»"
  89,17,ولى نه، بلكه يتيم را نمى‌نوازيد؛
  89,18,"و بر خوراك‌[دادن‌] بينوا همديگر را بر نمى‌انگيزيد؛"
  89,19,"و ميراث [ضعيفان‌] را چپاولگرانه مى‌خوريد؛"
  89,20,و مال را دوست داريد، دوست داشتنى بسيار
  89,21,نه چنان است، آنگاه كه زمين، سخت در هم كوبيده شود،
  89,22,"و [فرمان‌] پروردگارت و فرشته‌[ها] صف‌درصف آيند،"
  89,23,"و جهنم را در آن روز [حاضر] آورند، آن روز است كه انسان پند گيرد؛ و[لى‌] كجا او را جاى پندگرفتن باشد؟"
  89,24,"گويد: «كاش براى زندگانى خود [چيزى‌] پيش فرستاده بودم.»"
  89,25,پس در آن روز هيچ كس چون عذاب‌كردن او، عذاب نكند
  89,26,و هيچ كس چون دربندكشيدن او، دربند نكشد
  89,27,اى نفس مطمئنّه،
  89,28,خشنود و خداپسند به سوى پروردگارت بازگرد،
  89,29,و در ميان بندگان من درآى،
  89,30,و در بهشت من داخل شو