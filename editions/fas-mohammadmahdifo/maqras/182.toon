quran[31]{c,v,t}:
  38,21,"و آيا خبر دادخواهان -چون از نمازخانه [او] بالا رفتند- به تو رسيد؟"
  38,22,"وقتى [به طور ناگهانى‌] بر داوود درآمدند، و او از آنان به هراس افتاد، گفتند: «مترس، [ما] دو مدّعى [هستيم‌] كه يكى از ما بر ديگرى تجاوز كرده، پس ميان ما به حق داورى كن، و از حق دور مشو، و ما را به راه راست راهبر باش.»"
  38,23,"«اين [شخص‌] برادر من است. او را نود و نه ميش، و مرا يك ميش است، و مى‌گويد: آن را به من بسپار، و در سخنورى بر من غالب آمده است.»"
  38,24,"[داوود] گفت: «قطعاً او در مطالبه ميش تو [اضافه‌] بر ميش‌هاى خودش، بر تو ستم كرده، و در حقيقت بسيارى از شريكان به همديگر ستم روا مى‌دارند، به استثناى كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، و اينها بس اندكند، و داوود دانست كه ما او را آزمايش كرده‌ايم. پس، از پروردگارش آمرزش خواست و به رو درافتاد و توبه كرد"
  38,25,"و بر او اين [ماجرا] را بخشوديم؛ و در حقيقت براى او پيش ما تقرّب و فرجامى خوش خواهد بود"
  38,26,"اى داوود، ما تو را در زمين خليفه [و جانشين‌] گردانيديم؛ پس ميان مردم به حق داورى كن، و زنهار از هوس پيروى مكن كه تو را از راه خدا به در كند. در حقيقت كسانى كه از راه خدا به در مى‌روند، به [سزاى‌] آنكه روز حساب را فراموش كرده‌اند عذابى سخت خواهند داشت"
  38,27,"و آسمان و زمين و آنچه را كه ميان اين دو است به باطل نيافريديم، اين گمان كسانى است كه كافر شده [و حق‌پوشى كرده‌]اند، پس واى از آتش بر كسانى كه كافر شده‌اند"
  38,28,"يا [مگر] كسانى را كه گرويده و كارهاى شايسته كرده‌اند، چون مفسدان در زمين مى‌گردانيم، يا پرهيزگاران را چون پليدكاران قرار مى‌دهيم؟"
  38,29,"[اين‌] كتابى مبارك است كه آن را به سوى تو نازل كرده‌ايم تا در [باره‌] آيات آن بينديشند، و خردمندان پند گيرند"
  38,30,"و سليمان را به داوود بخشيديم. چه نيكو بنده‌اى. به راستى او توبه‌كار [و ستايشگر] بود"
  38,31,"هنگامى كه [طرف‌] غروب، اسبهاى اصيل را بر او عرضه كردند،"
  38,32,"[سليمان‌] گفت: «واقعاً من دوستى اسبان را بر ياد پروردگارم ترجيح دادم تا [هنگام نماز گذشت و خورشيد] در پس حجاب ظلمت شد.»"
  38,33,"[گفت: « اسبها] را نزد من باز آوريد.» پس شروع كرد به دست كشيدن بر ساقها و گردن آنها [و سرانجام وقف كردن آنها در راه خدا]"
  38,34,و قطعاً سليمان را آزموديم و بر تخت او جسدى بيفكنديم؛ پس به توبه باز آمد
  38,35,"گفت: «پروردگارا، مرا ببخش و مُلكى به من ارزانى دار كه هيچ كس را پس از من سزاوار نباشد، در حقيقت، تويى كه خود بسيار بخشنده‌اى.»"
  38,36,پس باد را در اختيار او قرار داديم كه هر جا تصميم مى‌گرفت، به فرمان او نرم، روان مى‌شد
  38,37,"و شيطانها را [از] بنّا و غواص،"
  38,38,"تا [وحشيان‌] ديگر را كه جفت جفت با زنجيرها به هم بسته بودند [تحت فرمانش درآورديم‌]"
  38,39,"[گفتيم:] «اين بخشش ماست، [آن را] بى‌شمار ببخش يا نگاه دار.»"
  38,40,و قطعاً براى او در پيشگاه ما تقرّب و فرجام نيكوست
  38,41,"و بنده ما ايوب را به ياد آور، آنگاه كه پروردگارش را ندا داد كه: «شيطان مرا به رنج و عذاب مبتلا كرد.»"
  38,42,"[به او گفتيم:] «با پاى خود [به زمين‌] بكوب، اينك اين چشمه‌سارى است سرد و آشاميدنى.»"
  38,43,"و [مجدداً] كسانش را و نظاير آنها را همراه آنها به او بخشيديم، تا رحمتى از جانب ما و عبرتى براى خردمندان باشد"
  38,44,"[و به او گفتيم:] «يك بسته تركه به دستت برگير و [همسرت را] با آن بزن و سوگند مشكن.» ما او را شكيبا يافتيم. چه نيكوبنده‌اى! به راستى او توبه‌كار بود"
  38,45,و بندگان ما ابراهيم و اسحاق و يعقوب را كه نيرومند و ديده‌ور بودند به يادآور
  38,46,ما آنان را با موهبت ويژه‌اى -كه يادآورى آن سراى بود- خالص گردانيديم
  38,47,و آنان در پيشگاه ما جداً از برگزيدگان نيكانند
  38,48,"و اسماعيل و يسع و ذوالكفل را به ياد آور [كه‌] همه از نيكانند"
  38,49,اين يادكردى است، و قطعاً براى پرهيزگاران فرجامى نيك است
  38,50,"باغهاى هميشگى در حالى كه درهاى [آنها] برايشان گشوده‌است"
  38,51,"در آنجا تكيه مى‌زنند [و] ميوه‌هاى فراوان و نوشيدنى در آنجا طلب مى‌كنند"