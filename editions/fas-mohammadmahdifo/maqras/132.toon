quran[30]{c,v,t}:
  21,83,"و ايوب را [ياد كن‌] هنگامى كه پروردگارش را ندا داد كه: «به من آسيب رسيده است و تويى مهربانترين مهربانان.»"
  21,84,"پس [دعاى‌] او را اجابت نموديم و آسيب وارده بر او را برطرف كرديم، و كسان او و نظيرشان را همراه با آنان [مجدداً] به وى عطا كرديم [تا] رحمتى از جانب ما و عبرتى براى عبادت‌كنندگان [باشد]"
  21,85,"و اسماعيل و ادريس و ذوالكفل را [ياد كن‌] كه همه از شكيبايان بودند"
  21,86,و آنان را در رحمت خود داخل نموديم، چرا كه ايشان از شايستگان بودند
  21,87,"و «ذوالنون» را [ياد كن‌] آنگاه كه خشمگين رفت و پنداشت كه ما هرگز بر او قدرتى نداريم، تا در [دل‌] تاريكيها ندا درداد كه: «معبودى جز تو نيست، منزّهى تو، راستى كه من از ستمكاران بودم.»"
  21,88,"پس [دعاى‌] او را برآورده كرديم و او را از اندوه رهانيديم، و مؤمنان را [نيز] چنين نجات مى‌دهيم"
  21,89,"و زكريّا را [ياد كن‌] هنگامى كه پروردگار خود را خواند: «پروردگارا، مرا تنها مگذار و تو بهترين ارث برندگانى.»"
  21,90,"پس [دعاى‌] او را اجابت نموديم، و يحيى را بدو بخشيديم و همسرش را براى او شايسته [و آماده حمل‌] كرديم، زيرا آنان در كارهاى نيك شتاب مى‌نمودند و ما را از روى رغبت و بيم مى‌خواندند و در برابر ما فروتن بودند"
  21,91,"و آن [زن را ياد كن‌] كه خود را پاكدامن نگاه داشت، و از روح خويش در او دميديم و او و پسرش را براى جهانيان آيتى قرار داديم"
  21,92,اين است امت شما كه امتى يگانه است، و منم پروردگار شما، پس مرا بپرستيد
  21,93,"و[لى‌] دينشان را ميان خود پاره پاره كردند. همه به سوى ما بازمى‌گردند"
  21,94,"پس هر كه كارهاى شايسته انجام دهد و مؤمن [هم‌] باشد، براى تلاش او ناسپاسى نخواهد بود، و ماييم كه به سود او ثبت مى‌كنيم"
  21,95,"و بر [مردم‌] شهرى كه آن را هلاك كرده‌ايم، بازگشتشان [به دنيا] حرام است"
  21,96,"تا وقتى كه يأجوج و مأجوج [راهشان‌] گشوده شود و آنها از هر پشته‌اى بتازند،"
  21,97,"و وعده حق نزديك گردد، ناگهان ديدگان كسانى كه كفر ورزيده‌اند خيره مى‌شود [و مى‌گويند:] «اى واى بر ما كه از اين [روز] در غفلت بوديم، بلكه ما ستمگر بوديم.»"
  21,98,در حقيقت، شما و آنچه غير از خدا مى‌پرستيد، هيزم دوزخيد. شما در آن وارد خواهيد شد
  21,99,"اگر اينها خدايانى [واقعى‌] بودند در آن وارد نمى‌شدند، و حال آنكه جملگى در آن ماندگارند"
  21,100,"براى آنها در آنجا ناله‌اى زار است و در آنجا [چيزى‌] نمى‌شنوند"
  21,101,"بى‌گمان كسانى كه قبلا از جانب ما به آنان وعده نيكو داده شده است از آن [آتش‌] دور داشته خواهند شد"
  21,102,صداى آن را نمى‌شنوند، و آنان در ميان آنچه دلهايشان بخواهد جاودانند
  21,103,"دلهره بزرگ، آنان را غمگين نمى‌كند و فرشتگان از آنها استقبال مى‌كنند [و به آنان مى‌گويند:] اين همان روزى است كه به شما وعده مى‌دادند"
  21,104,روزى كه آسمان را همچون در پيچيدن صفحه نامه‌ها در مى‌پيچيم. همان گونه كه بار نخست آفرينش را آغاز كرديم، دوباره آن را بازمى‌گردانيم. وعده‌اى است بر عهده ما، كه ما انجام‌دهنده آنيم
  21,105,و در حقيقت، در زبور پس از تورات نوشتيم كه زمين را بندگان شايسته ما به ارث خواهند برد
  21,106,"به راستى در اين [امور] براى مردم عبادت‌پيشه ابلاغى [حقيقى‌] است"
  21,107,و تو را جز رحمتى براى جهانيان نفرستاديم
  21,108,"بگو: «جز اين نيست كه به من وحى مى‌شود كه خداى شما خدايى يگانه است. پس آيا مسلمان مى‌شويد؟»"
  21,109,"پس اگر روى برتافتند بگو: «به [همه‌] شما به طور يكسان اعلام كردم، و نمى‌دانم آنچه وعده داده شده‌ايد آيا نزديك است يا دور.»"
  21,110,"[آرى،] او سخن آشكار را مى‌داند و آنچه را پوشيده مى‌داريد مى‌داند"
  21,111,"و نمى‌دانم، شايد آن براى شما آزمايشى و تا چند گاهى [وسيله‌] برخوردارى باشد"
  21,112,"گفت: «پروردگارا، [خودت‌] به حق داورى كن، و به رغم آنچه وصف مى‌كنيد، پروردگار ما همان بخشايشگر دستگير است.»"