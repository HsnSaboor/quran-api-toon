quran[32]{c,v,t}:
  21,51,"و در حقيقت، پيش از آن، به ابراهيم رشد [فكرى‌]اش را داديم و ما به [شايستگى‌] او دانا بوديم"
  21,52,"آنگاه كه به پدر خود و قومش گفت: «اين مجسمه‌هايى كه شما ملازم آنها شده‌ايد چيستند؟»"
  21,53,"گفتند: «پدران خود را پرستندگان آنها يافتيم.»"
  21,54,"گفت: «قطعاً شما و پدرانتان در گمراهى آشكارى بوديد.»"
  21,55,"گفتند: «آيا حق را براى ما آورده‌اى يا تو از شوخى‌كنندگانى؟»"
  21,56,"گفت: «[نه‌] بلكه پروردگارتان، پروردگار آسمانها و زمين است، همان كسى كه آنها را پديد آورده است، و من بر اين [واقعيت‌] از گواهانم"
  21,57,و سوگند به خدا كه پس از آنكه پشت كرديد و رفتيد، قطعاً در كار بتانتان تدبيرى خواهم كرد.»
  21,58,پس آنها را -جز بزرگترشان را- ريز ريز كرد، باشد كه ايشان به سراغ آن بروند
  21,59,"گفتند: «چه كسى با خدايان ما چنين [معامله‌اى‌] كرده، كه او واقعاً از ستمكاران است؟»"
  21,60,"گفتند: «شنيديم جوانى، از آنها [به بدى‌] ياد مى‌كرد كه به او ابراهيم گفته مى‌شود.»"
  21,61,"گفتند: «پس او را در برابر ديدگان مردم بياوريد، باشد كه آنان شهادت دهند.»"
  21,62,"گفتند: «اى ابراهيم، آيا تو با خدايان ما چنين كردى؟»"
  21,63,"گفت: «[نه‌] بلكه آن را اين بزرگترشان كرده است، اگر سخن مى‌گويند از آنها بپرسيد.»"
  21,64,"پس به خود آمده و [به يكديگر] گفتند: «در حقيقت، شما ستمكاريد.»"
  21,65,"سپس سرافكنده شدند [و گفتند:] «قطعاً دانسته‌اى كه اينها سخن نمى‌گويند.»"
  21,66,"گفت: «آيا جز خدا چيزى را مى‌پرستيد كه هيچ سود و زيانى به شما نمى‌رساند؟"
  21,67,اف بر شما و بر آنچه غير از خدا مى‌پرستيد. مگر نمى‌انديشيد؟»
  21,68,"گفتند: «اگر كارى مى‌كنيد، او را بسوزانيد و خدايانتان را يارى دهيد.»"
  21,69,"گفتيم: «اى آتش، براى ابراهيم سرد و بى‌آسيب باش.»"
  21,70,"و خواستند به او نيرنگى بزنند و[لى‌] آنان را زيانكارترين [مردم‌] قرار داديم"
  21,71,"و او و لوط را [براى رفتن‌] به سوى آن سرزمينى كه براى جهانيان در آن بركت نهاده بوديم، رهانيديم"
  21,72,"و اسحاق و يعقوب را [به عنوان نعمتى‌] افزون به او بخشوديم و همه را از شايستگان قرار داديم"
  21,73,و آنان را پيشوايانى قرار داديم كه به فرمان ما هدايت مى‌كردند، و به ايشان انجام دادن كارهاى نيك و برپاداشتن نماز و دادن زكات را وحى كرديم و آنان پرستنده ما بودند
  21,74,"و به لوط حكمت و دانش عطا كرديم و او را از آن شهرى كه [مردمش‌] كارهاى پليد [جنسى‌] مى‌كردند نجات داديم. به راستى آنها گروه بد و منحرفى بودند"
  21,75,و او را در رحمت خويش داخل كرديم، زيرا او از شايستگان بود
  21,76,"و نوح را [ياد كن‌] آنگاه كه پيش از [ساير پيامبران‌] ندا كرد، پس ما او را اجابت كرديم، و وى را با خانواده‌اش از بلاى بزرگ رهانيديم"
  21,77,و او را در برابر مردمى كه نشانه‌هاى ما را به دروغ گرفته بودند پيروزى بخشيديم، چرا كه آنان مردم بدى بودند، پس همه ايشان را غرق كرديم
  21,78,"و داوود و سليمان را [ياد كن‌] هنگامى كه در باره آن كشتزار -كه گوسفندان مردم شب‌هنگام در آن چريده بودند- داورى مى‌كردند، و [ما] شاهد داورى آنان بوديم"
  21,79,"پس آن [داورى‌] را به سليمان فهمانديم، و به هر يك [از آن دو] حكمت و دانش عطا كرديم، و كوهها را با داوود و پرندگان به نيايش واداشتيم، و ما كننده [اين كار] بوديم"
  21,80,"و به [داوود] فن زره [سازى‌] آموختيم، تا شما را از [خطرات‌] جنگتان حفظ كند. پس آيا شما سپاسگزاريد؟"
  21,81,"و براى سليمان، تندباد را [رام كرديم‌] كه به فرمان او به سوى سرزمينى كه در آن بركت نهاده بوديم جريان مى‌يافت، و ما به هر چيزى دانا بوديم"
  21,82,"و برخى از شياطين بودند كه براى او غواصى و كارهايى غير از آن مى‌كردند، و ما مراقب [حال‌] آنها بوديم"