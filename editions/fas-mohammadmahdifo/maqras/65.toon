quran[29]{c,v,t}:
  7,88,"سران قومش كه تكبر مى‌ورزيدند، گفتند: «اى شعيب، يا تو و كسانى را كه با تو ايمان آورده‌اند، از شهر خودمان بيرون خواهيم كرد؛ يا به كيش ما برگرديد.» گفت: «آيا هر چند كراهت داشته باشيم؟»"
  7,89,"اگر بعد از آنكه خدا ما را از آن نجات بخشيده [باز] به كيش شما برگرديم، در حقيقت به خدا دروغ بسته‌ايم؛ و ما را سزاوار نيست كه به آن بازگرديم، مگر آنكه خدا، پروردگار ما بخواهد. [كه‌] پروردگار ما از نظر دانش بر هر چيزى احاطه دارد. بر خدا توكل كرده‌ايم. بار پروردگارا، ميان ما و قوم ما به حق داورى كن كه تو بهترين داورانى.»"
  7,90,"و سران قومش كه كافر بودند گفتند: «اگر از شعيب پيروى كنيد، در اين صورت قطعاً زيانكاريد.»"
  7,91,پس زمين‌لرزه آنان را فرو گرفت، و در خانه‌هايشان از پا درآمدند
  7,92,"كسانى كه شعيب را تكذيب كرده بودند، گويى خود در آن [ديار] سكونت نداشتند. كسانى كه شعيب را تكذيب كرده بودند، خود، همان زيانكاران بودند"
  7,93,"پس [شعيب‌] از ايشان روى برتافت و گفت: «اى قوم من، به راستى كه پيامهاى پروردگارم را به شما رسانيدم و پندتان دادم؛ ديگر چگونه بر گروهى كه كافرند دريغ بخورم؟»"
  7,94,و در هيچ شهرى، پيامبرى نفرستاديم مگر آنكه مردمش را به سختى و رنج دچار كرديم تا مگر به زارى درآيند
  7,95,"آنگاه به جاى بدى [=بلا]، نيكى [=نعمت‌] قرار داديم تا انبوه شدند و گفتند: «پدران ما را [هم مسلماً به حكم طبيعت‌] رنج و راحت مى‌رسيده است.» پس در حالى كه بى خبر بودند بناگاه [گريبان‌] آنان را گرفتيم"
  7,96,"و اگر مردم شهرها ايمان آورده و به تقوا گراييده بودند، قطعاً بركاتى از آسمان و زمين برايشان مى‌گشوديم، ولى تكذيب كردند؛ پس به [كيفر] دستاوردشان [گريبان‌] آنان را گرفتيم"
  7,97,آيا ساكنان شهرها ايمن شده‌اند از اينكه عذاب ما شامگاهان -در حالى كه به خواب فرو رفته‌اند- به آنان برسد؟
  7,98,و آيا ساكنان شهرها ايمن شده‌اند از اينكه عذاب ما نيمروز -در حالى كه به بازى سرگرمند- به ايشان دررسد؟
  7,99,"آيا از مكر خدا خود را ايمن دانستند؟ [با آنكه‌] جز مردم زيانكار [كسى‌] خود را از مكر خدا ايمن نمى‌داند"
  7,100,"مگر براى كسانى كه زمين را پس از ساكنان [پيشين‌] آن به ارث مى‌برند، باز ننموده است كه اگر مى‌خواستيم آنان را به [كيفر] گناهانشان مى‌رسانديم و بر دلهايشان مُهر مى‌نهاديم تا ديگر نشنوند"
  7,101,"اين شهرهاست كه برخى از خبرهاى آن را بر تو حكايت مى‌كنيم. در حقيقت، پيامبرانشان دلايل روشن برايشان آوردند. اما آنان به آنچه قبلاً تكذيب كرده بودند [باز] ايمان نمى‌آوردند. اين گونه خدا بر دلهاى كافران مُهر مى‌نهد"
  7,102,"و در بيشتر آنان عهدى [استوار] نيافتيم و بيشترشان را جداً نافرمان يافتيم"
  7,103,"آنگاه بعد از آنان، موسى را با آيات خود به سوى فرعون و سران قومش فرستاديم. ولى آنها به آن [آيات‌] كفر ورزيدند. پس ببين فرجام مفسدان چگونه بود"
  7,104,"و موسى گفت: «اى فرعون، بى‌ترديد، من پيامبرى از سوى پروردگار جهانيانم.»"
  7,105,"شايسته است كه بر خدا جز [سخن‌] حق نگويم. من در حقيقت دليلى روشن از سوى پروردگارتان براى شما آورده‌ام، پس فرزندان اسرائيل را همراه من بفرست"
  7,106,"[فرعون‌] گفت: «اگر معجزه‌اى آورده‌اى، پس اگر راست مى‌گويى آن را ارائه بده.»"
  7,107,"پس [موسى‌] عصايش را افكند و بناگاه اژدهايى آشكار شد"
  7,108,"و دست خود را [از گريبان‌] بيرون كشيد و ناگهان براى تماشاگران سپيد [و درخشنده‌] بود"
  7,109,"سران قوم فرعون گفتند: «بى‌شك، اين [مرد] ساحرى داناست.»"
  7,110,مى‌خواهد شما را از سرزمينتان بيرون كند. پس چه دستور مى‌دهيد؟
  7,111,"گفتند: «او و برادرش را بازداشت كن، و گردآورندگانى را به شهرها بفرست"
  7,112,تا هر ساحر دانايى را نزد تو آرند
  7,113,"و ساحران نزد فرعون آمدند [و] گفتند: «[آيا] اگر ما پيروز شويم براى ما پاداشى خواهد بود؟»"
  7,114,"گفت: «آرى، و مسلماً شما از مقربان [دربار من‌] خواهيد بود.»"
  7,115,"گفتند: «اى موسى، آيا تو مى‌افكنى و يا اينكه ما مى‌افكنيم؟»"
  7,116,"گفت: «شما بيفكنيد.» و چون افكندند، ديدگان مردم را افسون كردند و آنان را به ترس انداختند و سحرى بزرگ در ميان آوردند"