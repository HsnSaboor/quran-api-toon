quran[67]{c,v,t}:
  90,1,سوگند به اين شهر،
  90,2,و حال آنكه تو در اين شهر جاى دارى؛
  90,3,"سوگند به پدرى [چنان‌] و آن كسى را كه به وجود آورد؛"
  90,4,براستى كه انسان را در رنج آفريده‌ايم
  90,5,آيا پندارد كه هيچ كس هرگز بر او دست نتواند يافت؟
  90,6,"گويد: «مال فراوانى تباه كردم.»"
  90,7,آيا پندارد كه هيچ كس او را نديده است؟
  90,8,آيا دو چشمش نداده‌ايم؟
  90,9,و زبانى و دو لب
  90,10,"و هر دو راه [خير و شر] را بدو نموديم"
  90,11,"و[لى‌] نخواست از گردنه [عاقبت‌نگرى‌] بالا رود"
  90,12,"و تو چه دانى كه آن گردنه [سخت‌] چيست؟"
  90,13,بنده‌اى را آزادكردن،
  90,14,يا در روز گرسنگى، طعام‌دادن
  90,15,به يتيمى خويشاوند،
  90,16,يا بينوايى خاك‌نشين
  90,17,علاوه بر اين از زمره كسانى باشد كه گرويده و يكديگر را به شكيبايى و مهربانى سفارش كرده‌اند؛
  90,18,اينانند خجستگان
  90,19,و كسانى كه به انكار نشانه‌هاى ما پرداخته‌اند، آنانند ناخجستگان شوم
  90,20,بر آنان آتشى سرپوشيده احاطه دارد
  91,1,سوگند به خورشيد و تابندگى‌اش،
  91,2,"سوگند به مه چون پى [خورشيد] رود"
  91,3,"سوگند به روز چون [زمين را] روشن گرداند،"
  91,4,سوگند به شب چو پرده بر آن پوشد،
  91,5,سوگند به آسمان و آن كس كه آن را برافراشت،
  91,6,سوگند به زمين و آن كس كه آن را گسترد،
  91,7,سوگند به نفس و آن كس كه آن را درست كرد؛
  91,8,سپس پليدكارى و پرهيزگارى‌اش را به آن الهام كرد،
  91,9,كه هر كس آن را پاك گردانيد، قطعاً رستگار شد،
  91,10,و هر كه آلوده‌اش ساخت، قطعاً درباخت
  91,11,"[قوم‌] ثمود به سبب طغيان خود به تكذيب پرداختند"
  91,12,"آنگاه كه شقى‌ترينشان بر[پا] خاست"
  91,13,"پس فرستاده خدا به آنان گفت: «زنهار! ماده‌شتر خدا و [نوبت‌] آب‌خوردنش را [حرمت نهيد]»"
  91,14,"و[لى‌] دروغزنش خواندند و آن [ماده‌شتر] را پى كردند، و پروردگارشان به [سزاى‌] گناهشان بر سرشان عذاب آورد و آنان را با خاك يكسان كرد"
  91,15,و از پيامد كار خويش، بيمى به خود راه نداد
  92,1,سوگند به شب چون پرده افكند،
  92,2,سوگند به روز چون جلوه‌گرى آغازد،
  92,3,"و [سوگند به‌] آنكه نر و ماده را آفريد،"
  92,4,كه همانا تلاش شما پراكنده است
  92,5,"اما آنكه [حق خدا را] داد و پروا داشت،"
  92,6,"و [پاداش‌] نيكوتر را تصديق كرد،"
  92,7,بزودى راه آسانى پيش پاى او خواهيم گذاشت
  92,8,و اما آنكه بخل ورزيد و خود را بى‌نياز ديد،
  92,9,"و [پاداش‌] نيكوتر را به دروغ گرفت،"
  92,10,بزودى راه دشوارى به او خواهيم نمود
  92,11,"و چون هلاك شد، [ديگر] مال او به كارش نمى‌آيد"
  92,12,همانا هدايت بر ماست
  92,13,و در حقيقت، دنيا و آخرت از آن ماست
  92,14,پس شما را به آتشى كه زبانه مى‌كشد هشدار دادم
  92,15,"جز نگون‌بخت‌تر[ين مردم‌] در آن درنيايد"
  92,16,همان كه تكذيب كرد و رخ برتافت
  92,17,"و پاك‌رفتارتر[ين مردم‌] از آن دور داشته خواهد شد"
  92,18,"همان كه مال خود را مى‌دهد [براى آنكه‌] پاك شود،"
  92,19,و هيچ كس را به قصد پاداش‌يافتن نعمت نمى‌بخشد،
  92,20,"جز خواستن رضاى پروردگارش كه بسى برتر است [منظورى ندارد]"
  92,21,و قطعاً بزودى خشنود خواهد شد
  93,1,سوگند به روشنايى روز،
  93,2,سوگند به شب چون آرام گيرد،
  93,3,"[كه‌] پروردگارت تو را وانگذاشته، و دشمن نداشته است"
  93,4,و قطعاً آخرت براى تو از دنيا نيكوتر خواهد بود
  93,5,و بزودى پروردگارت تو را عطا خواهد داد، تا خرسند گردى
  93,6,مگر نه تو را يتيم يافت، پس پناه داد؟
  93,7,و تو را سرگشته يافت، پس هدايت كرد؟
  93,8,و تو را تنگدست يافت و بى‌نياز گردانيد؟
  93,9,"و اما [تو نيز به پاس نعمت ما] يتيم را ميازار،"
  93,10,و گدا را مران،
  93,11,"و از نعمت پروردگار خويش [با مردم‌] سخن گوى"