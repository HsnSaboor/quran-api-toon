quran[44]{c,v,t}:
  38,52,"و نزدشان [دلبران‌] فروهشته‌نگاه همسال است"
  38,53,اين است آنچه براى روز حساب به شما وعده داده مى‌شد
  38,54,"[مى‌گويند:] «در حقيقت، اين روزىِ ماست و آن را پايانى نيست.»"
  38,55,"اين است [حال بهشتيان‌] و [اما] براى طغيانگران واقعاً بد فرجامى است"
  38,56,به جهنّم درمى‌آيند، و چه بد آرامگاهى است
  38,57,اين جوشاب و چركاب است، بايد آن را بچشند
  38,58,"و از همين گونه، انواع ديگر [عذابها]"
  38,59,"اينها گروهى‌اند كه با شما به اجبار [در آتش‌] درمى‌آيند. بدا به حال آنها، زيرا آنان داخل آتش مى‌شوند"
  38,60,"[به رؤساى خود] مى‌گويند: «بلكه بر خود شما خوش مباد! اين [عذاب‌] را شما خود براى ما از پيش فراهم آورديد، و چه بد قرارگاهى است.»"
  38,61,"مى‌گويند: «پروردگارا، هر كس اين [عذاب‌] را از پيش براى ما فراهم آورده، عذاب او را در آتش دو چندان كن.»"
  38,62,"و مى‌گويند: «ما را چه شده است كه مردانى را كه ما آنان را از [زمره‌] اشرار مى‌شمرديم نمى‌بينيم؟"
  38,63,"آيا آنان را [در دنيا] به ريشخند مى‌گرفتيم يا چشمها[ى ما] بر آنها نمى‌افتد؟»"
  38,64,اين مجادله اهل آتش قطعاً راست است
  38,65,"بگو: «من فقط هشداردهنده‌اى هستم، و جز خداى يگانه قهار معبودى ديگر نيست"
  38,66,پروردگار آسمانها و زمين و آنچه ميان آن دو است، همان شكست‌ناپذير آمرزنده
  38,67,"بگو: «اين خبرى بزرگ است،"
  38,68,"[كه‌] شما از آن روى برمى‌تابيد"
  38,69,مرا در باره ملاء اعلى هيچ دانشى نبود آنگاه كه مجادله مى‌كردند
  38,70,"به من هيچ [چيز] وحى نمى‌شود، جز اينكه من هشداردهنده‌اى آشكارم"
  38,71,"آنگاه كه پروردگارت به فرشتگان گفت: «من بشرى را از گِل خواهم آفريد"
  38,72,"پس چون او را [كاملاً] درست كردم و از روح خويش در آن دميدم، سجده‌كنان براى او [به خاك‌] بيفتيد.»"
  38,73,پس همه فرشتگان يكسره سجده كردند
  38,74,"مگر ابليس [كه‌] تكبر نمود و از كافران شد"
  38,75,"فرمود: «اى ابليس، چه چيز تو را مانع شد كه براى چيزى كه به دستان قدرت خويش خلق كردم سجده آورى؟ آيا تكبر نمودى يا از [جمله‌] برترى‌جويانى؟»"
  38,76,"گفت: «من از او بهترم؛ مرا از آتش آفريده‌اى و او را از گِل آفريده‌اى.»"
  38,77,"فرمود: «پس، از آن [مقام‌] بيرون شو، كه تو رانده‌اى"
  38,78,و تا روز جزا لعنت من بر تو باد.»
  38,79,"گفت: «پروردگارا، پس مرا تا روزى كه برانگيخته مى‌شوند مهلت ده.»"
  38,80,"فرمود: «در حقيقت، تو از مهلت‌يافتگانى،"
  38,81,تا روز معين معلوم.»
  38,82,"[شيطان‌] گفت: «پس به عزّت تو سوگند كه همگى را جداً از راه به در مى‌برم،"
  38,83,مگر آن بندگان پاكدل تو را.»
  38,84,"فرمود: «حق [از من‌] است و حق را مى‌گويم"
  38,85,هرآينه جهنّم را از تو و از هر كس از آنان كه تو را پيروى كند، از همگى‌شان، خواهم انباشت.»
  38,86,"بگو: «مزدى بر اين [رسالت‌] از شما طلب نمى‌كنم و من از كسانى نيستم كه چيزى از خود بسازم و به خدا نسبت دهم"
  38,87,"اين [قرآن‌] جز پندى براى جهانيان نيست"
  38,88,و قطعاً پس از چندى خبر آن را خواهيد دانست.»
  39,1,"نازل شدن [اين كتاب‌] از جانب خداى شكست‌ناپذير سنجيده‌كار است"
  39,2,"ما [اين‌] كتاب را به حق به سوى تو فرود آورديم، پس خدا را -در حالى كه اعتقاد [خود] را براى او خالص‌كننده‌اى- عبادت كن"
  39,3,"آگاه باشيد: آيين پاك از آنِ خداست، و كسانى كه به جاى او دوستانى براى خود گرفته‌اند [به اين بهانه كه:] ما آنها را جز براى اينكه ما را هر چه بيشتر به خدا نزديك گردانند، نمى‌پرستيم، البته خدا ميان آنان در باره آنچه كه بر سر آن اختلاف دارند، داورى خواهد كرد. در حقيقت، خدا آن كسى را كه دروغ‌پرداز ناسپاس است هدايت نمى‌كند"
  39,4,"اگر خدا مى‌خواست براى خود فرزندى بگيرد، قطعاً از [ميان‌] آنچه خلق مى‌كند، آنچه را مى‌خواست برمى‌گزيد. منزّه است او، اوست خداى يگانه قهار"
  39,5,آسمانها و زمين را به حق آفريد. شب را به روز درمى‌پيچد، و روز را به شب درمى‌پيچد و آفتاب و ماه را تسخير كرد. هر كدام تا مدتى معين روانند. آگاه باش كه او همان شكست‌ناپذير آمرزنده است
  39,6,"شما را از نفسى واحد آفريد، سپس جفتش را از آن قرار داد، و براى شما از دامها هشت قسم پديد آورد. شما را در شكمهاى مادرانتان آفرينشى پس از آفرينشى [ديگر] در تاريكيهاى سه گانه: [مَشيمه و رحم و شكم‌] خلق كرد. اين است خدا، پروردگار شما، فرمانروايى [و حكومت مطلق‌] از آنِ اوست. خدايى جز او نيست، پس چگونه [و كجا از حق‌] برگردانيده مى‌شويد؟"
  39,7,"اگر كفر ورزيد، خدا از شما سخت بى‌نياز است و براى بندگانش كفران را خوش نمى‌دارد، و اگر سپاس داريد آن را براى شما مى‌پسندد، و هيچ بردارنده‌اى بار [گناه‌] ديگرى را برنمى‌دارد، آنگاه بازگشت شما به سوى پروردگارتان است، و شما را به آنچه مى‌كرديد خبر خواهد داد، كه او به راز دلها داناست"