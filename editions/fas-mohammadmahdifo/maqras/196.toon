quran[26]{c,v,t}:
  42,51,"و هيچ بشرى را نرسد كه خدا با او سخن گويد جز [از راه‌] وحى يا از فراسوى حجابى، يا فرستاده‌اى بفرستد و به اذن او هر چه بخواهد وحى نمايد. آرى، اوست بلندمرتبه سنجيده‌كار"
  42,52,"وهمين گونه، روحى از امر خودمان به سوى تو وحى كرديم. تو نمى‌دانستى كتاب چيست و نه ايمان [كدام است؟] ولى آن را نورى گردانيديم كه هر كه از بندگان خود را بخواهيم به وسيله آن راه مى‌نماييم، و به راستى كه تو به خوبى به راه راست هدايت مى‌كنى"
  42,53,"راه همان خدايى كه آنچه در آسمانها و آنچه در زمين است از آنِ اوست. هش‌دار كه [همه‌] كارها به خدا بازمى‌گردد"
  43,1,حاء، ميم
  43,2,سوگند به كتاب روشنگر
  43,3,ما آن را قرآنى عربى قرار داديم، باشد كه بينديشيد
  43,4,"و همانا كه آن در كتاب اصلى [=لوح محفوظ] به نزد ما سخت والا و پر حكمت است"
  43,5,"آيا به [صِرف‌] اينكه شما قومى منحرفيد [بايد] قرآن را از شما باز داريم؟"
  43,6,"و چه بسا پيامبرانى كه در [ميان‌] گذشتگان روانه كرديم"
  43,7,و هيچ پيامبرى به سوى ايشان نيامد، مگر اينكه او را به ريشخند مى‌گرفتند
  43,8,و نيرومندتر از آنان را به هلاكت رسانيديم و سنّت پيشينيان تكرار شد
  43,9,"و اگر از آنان بپرسى: «آسمانها و زمين را چه كسى آفريده؟» قطعاً خواهند گفت: «آنها را همان قادر دانا آفريده است.»"
  43,10,همان كسى كه اين زمين را براى شما گهواره‌اى گردانيد و براى شما در آن راهها نهاد، باشد كه راه يابيد
  43,11,"و آن كس كه آبى به اندازه از آسمان فرود آورد، پس به وسيله آن، سرزمينى مرده را زنده گردانيديم؛ همين گونه [از گورها] بيرون آورده مى‌شويد"
  43,12,"و همان كسى كه جفتها را يكسره آفريد، و براى شما از كشتيها و دامها [وسيله‌اى كه‌] سوار شويد قرار داد"
  43,13,"تا بر پشت آن‌[ها] قرار گيريد، پس چون بر آن‌[ها] برنشستيد، نعمت پروردگار خود را ياد كنيد و بگوييد: «پاك است كسى كه اين را براى ما رام كرد و[گرنه‌] ما را ياراى [رام‌ساختن‌] آنها نبود.»"
  43,14,«و به راستى كه ما به سوى پروردگارمان بازخواهيم گشت.»
  43,15,"و براى او بعضى از بندگان [خدا] را جزئى [چون فرزند و شريك‌] قرار دادند. به راستى كه انسان بس ناسپاس آشكار است"
  43,16,آيا از آنچه مى‌آفريند، خود، دخترانى برگرفته و به شما پسران را اختصاص داده است؟
  43,17,"و چون يكى از آنان را به آنچه به [خداى‌] رحمان نسبت مى‌دهد خبر دهند، چهره او سياه مى‌گردد، در حالى كه خشم و تأسف خود را فرو مى‌خورد"
  43,18,"آيا كسى [را شريك خدا مى‌كنند] كه در زر و زيور پرورش يافته و در [هنگام‌] مجادله، بيانش غير روشن است؟"
  43,19,"و فرشتگانى را كه خود، بندگان رحمانند، مادينه [و دختران او] پنداشتند. آيا در خلقت آنان حضور داشتند؟ گواهى ايشان به زودى نوشته مى‌شود و [از آن‌] پرسيده خواهند شد"
  43,20,"و مى‌گويند: «اگر [خداى‌] رحمان مى‌خواست، آنها را نمى‌پرستيديم.» آنان به اين [دعوى‌] دانشى ندارند [و] جز حدس نمى‌زنند"
  43,21,"آيا به آنان پيش از آن [قرآن‌] كتابى داده‌ايم كه بدان تمسك مى‌جويند؟"
  43,22,"[نه،] بلكه گفتند: «ما پدران خود را بر آيينى يافتيم و ما [هم با] پى گيرى از آنان، راه يافتگانيم.»"
  43,23,"و بدين گونه در هيچ شهرى پيش از تو هشداردهنده‌اى نفرستاديم مگر آنكه خوشگذرانان آن گفتند: «ما پدران خود را بر آيينى [و راهى‌] يافته‌ايم و ما از پى ايشان راهسپريم.»"