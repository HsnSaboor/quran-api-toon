quran[64]{c,v,t}:
  94,1,آيا براى تو سينه‌ات را نگشاده‌ايم؟
  94,2,"و بار گرانت را از [دوش‌] تو برنداشتيم؟"
  94,3,"[بارى‌] كه [گويى‌] پشت تو را شكست"
  94,4,و نامت را براى تو بلند گردانيديم
  94,5,"پس [بدان كه‌] با دشوارى، آسانى است"
  94,6,آرى، با دشوارى، آسانى است
  94,7,پس چون فراغت يافتى، به طاعت دركوش؛
  94,8,و با اشتياق، به سوى پروردگارت روى آور
  95,1,"سوگند به [كوه‌] تين و زيتون،"
  95,2,و طور سينا،
  95,3,"و اين شهر امن [و امان‌]،"
  95,4,"[كه‌] براستى انسان را در نيكوترين اعتدال آفريديم"
  95,5,"سپس او را به پست‌ترين [مراتب‌] پستى بازگردانيديم؛"
  95,6,مگر كسانى را كه گرويده و كارهاى شايسته كرده‌اند، كه پاداشى بى‌منّت خواهند داشت
  95,7,"پس چه چيز، تو را بعد [از اين‌] به تكذيب جزا وامى‌دارد؟"
  95,8,آيا خدا نيكوترين داوران نيست؟
  96,1,بخوان به نام پروردگارت كه آفريد
  96,2,انسان را از عَلَق آفريد
  96,3,"بخوان، و پروردگار تو كريمترين [كريمان‌] است"
  96,4,همان كس كه به وسيله قلم آموخت
  96,5,"آنچه را كه انسان نمى‌دانست [بتدريج به او] آموخت"
  96,6,حقاً كه انسان سركشى مى‌كند،
  96,7,همين كه خود را بى‌نياز پندارد
  96,8,در حقيقت، بازگشت به سوى پروردگار توست
  96,9,آيا ديدى آن كس را كه باز مى‌داشت،
  96,10,بنده‌اى را آنگاه كه نماز مى‌گزارد؟
  96,11,چه پندارى اگر او بر هدايت باشد،
  96,12,"يا به پرهيزگارى وادارد [براى او بهتر نيست‌]؟"
  96,13,"[و باز] آيا چه پندارى [كه‌] اگر او به تكذيب پردازد و روى برگرداند [چه كيفرى در پيش دارد]؟"
  96,14,مگر ندانسته كه خدا مى‌بيند؟
  96,15,"زنهار، اگر باز نايستد، موى پيشانى [او] را سخت بگيريم؛"
  96,16,"[همان‌] موى پيشانى دروغزن گناه‌پيشه را"
  96,17,"[بگو] تا گروه خود را بخواند"
  96,18,بزودى آتشبانان را فرا خوانيم
  96,19,"زنهار! فرمانش مَبَر، و سجده كن، و خود را [به خدا] نزديك گردان"
  97,1,"ما [قرآن را] در شب قدر نازل كرديم"
  97,2,و از شب قدر، چه آگاهت كرد
  97,3,شب قدر از هزار ماه ارجمندتر است
  97,4,"در آن [شب‌] فرشتگان، با روح، به فرمان پروردگارشان، براى هر كارى [كه مقرّر شده است‌] فرود آيند؛"
  97,5,"[آن شب‌] تا دمِ صبح، صلح و سلام است"
  98,1,كافران اهل كتاب و مشركان، دست‌بردار نبودند تا دليلى آشكار بر ايشان آيد
  98,2,"فرستاده‌اى از جانب خدا كه [بر آنان‌] صحيفه‌هايى پاك را تلاوت كند،"
  98,3,كه در آنها نوشته‌هاى استوار است
  98,4,و اهل كتاب دستخوش پراكندگى نشدند، مگر پس از آنكه برهان آشكار براى آنان آمد
  98,5,"و فرمان نيافته بودند جز اينكه خدا را بپرستند، و در حالى كه به توحيد گراييده‌اند، دين [خود] را براى او خالص گردانند، و نماز برپا دارند و زكات بدهند، و دين [ثابت و] پايدار همين است"
  98,6,"كسانى از اهل كتاب كه كفر ورزيده‌اند و [نيز] مشركان در آتش دوزخند، [و] در آن همواره مى‌مانند؛ اينانند كه بدترين آفريدگانند"
  98,7,در حقيقت كسانى كه گرويده و كارهاى شايسته كرده‌اند، آنانند كه بهترين آفريدگانند
  98,8,"پاداش آنان نزد پروردگارشان باغهاى هميشگى است كه از زير [درختان‌] آن، نهرها روان است، جاودانه در آن «همى» مانند؛ خدا از آنان خشنود است و [آنان نيز] از او خشنود، اين [پاداش‌] براى كسى است كه از پروردگارش بترسد"
  99,1,"آنگاه كه زمين به لرزش [شديد] خود لرزانيده شود،"
  99,2,و زمين بارهاى سنگين خود را برون افكند،
  99,3,"و انسان گويد: «[زمين‌] را چه شده است؟»"
  99,4,"آن روز است كه [زمين‌] خبرهاى خود را باز گويد"
  99,5,"[همان گونه‌] كه پروردگارت بدان وحى كرده است"
  99,6,"آن روز، مردم [به حال‌] پراكنده برآيند تا [نتيجه‌] كارهايشان به آنان نشان داده شود"
  99,7,"پس هر كه هموزن ذرّه‌اى نيكى كند [نتيجه‌] آن را خواهد ديد"
  99,8,"و هر كه هموزن ذرّه‌اى بدى كند [نتيجه‌] آن را خواهد ديد"
  100,1,"سوگند به ماديانهائى كه با همهمه تازانند و با سم‌[هاى‌] خود از سنگ آتش مى‌جهانند"
  100,2,"و برق [از سنگ‌] همى جهانند،"
  100,3,و صبحگاهان هجوم آرند،
  100,4,"و با آن [يورش‌]، گردى برانگيزند،"
  100,5,"و بدان [هجوم‌]، در دل گروهى درآيند،"
  100,6,كه انسان نسبت به پروردگارش سخت ناسپاس است،
  100,7,"و او خود بر اين [امر]، نيك گواه است"
  100,8,و راستى او سخت شيفته مال است