quran[45]{c,v,t}:
  36,60,اى فرزندان آدم، مگر با شما عهد نكرده بودم كه شيطان را مپرستيد، زيرا وى دشمن آشكار شماست؟
  36,61,و اينكه مرا بپرستيد؛ اين است راه راست
  36,62,"و [او] گروهى انبوه از ميان شما را سخت گمراه كرد؛ آيا تعقل نمى‌كرديد؟"
  36,63,اين است جهنّمى كه به شما وعده داده مى‌شد
  36,64,"به [جرم‌] آنكه كفر مى‌ورزيديد، اكنون در آن درآييد"
  36,65,امروز بر دهانهاى آنان مُهر مى‌نهيم، و دستهايشان با ما سخن مى‌گويند، و پاهايشان بدانچه فراهم مى‌ساختند گواهى مى‌دهند
  36,66,"و اگر بخواهيم، هر آينه فروغ از ديدگانشان مى‌گيريم تا در راه [كج‌] بر هم پيشى جويند؛ ولى [راه راست را] از كجا مى‌توانند ببينند؟"
  36,67,"و اگر بخواهيم، هرآينه ايشان را در جاى خود مسخ مى‌كنيم [به گونه‌اى‌] كه نه بتوانند بروند و نه برگردند"
  36,68,"و هر كه را عمر دراز دهيم، او را [از نظر] خلقت فروكاسته [و شكسته‌] گردانيم، آيا نمى‌انديشند؟"
  36,69,"و [ما] به او شعر نياموختيم و در خور وى نيست، اين [سخن‌] جز اندرز و قرآنى روشن نيست"
  36,70,"تا هر كه را [دلى‌] زنده است بيم دهد، و گفتار [خدا] در باره كافران محقق گردد"
  36,71,آيا نديده‌اند كه ما به قدرت خويش براى ايشان چهارپايانى آفريده‌ايم تا آنان مالك آنها باشند؟
  36,72,و آنها را براى ايشان رام گردانيديم. از برخى‌شان سوارى مى‌گيرند و از بعضى مى‌خورند
  36,73,و از آنها سودها و نوشيدنيها دارند. پس چرا شكرگزار نيستيد؟
  36,74,"و غير از خدا[ى يگانه‌] خدايانى به پرستش گرفتند، تا مگر يارى شوند"
  36,75,"[ولى بتان‌] نمى‌توانند آنان را يارى كنند و آنانند كه براى [بتان‌] چون سپاهى احضار شده‌اند"
  36,76,پس، گفتار آنان تو را غمگين نگرداند كه ما آنچه را پنهان و آنچه را آشكار مى‌كنند، مى‌دانيم
  36,77,مگر آدمى ندانسته است كه ما او را از نطفه‌اى آفريده‌ايم، پس بناگاه وى ستيزه‌جويى آشكار شده است
  36,78,"و براى ما مَثَلى آورد و آفرينش خود را فراموش كرد؛ گفت: «چه كسى اين استخوانها را كه چنين پوسيده است زندگى مى‌بخشد؟»"
  36,79,"بگو: «همان كسى كه نخستين‌بار آن را پديد آورد و اوست كه به هر [گونه‌] آفرينشى داناست.»"
  36,80,"همو كه برايتان در درخت سبزفام اخگر نهاد كه از آن [چون نيازتان افتد] آتش مى‌افروزيد"
  36,81,"آيا كسى كه آسمانها و زمين را آفريده توانا نيست كه [باز] مانند آنها را بيافريند؟ آرى، اوست آفريننده دانا"
  36,82,"چون به چيزى اراده فرمايد، كارش اين بس كه مى‌گويد: «باش»؛ پس [بى‌درنگ‌] موجود مى‌شود"
  36,83,"پس [شكوهمند و] پاك است آن كسى كه ملكوت هر چيزى در دست اوست، و به سوى اوست كه بازگردانيده مى‌شويد"
  37,1,"سوگند به صف بستگان -كه صفى [با شكوه‌] بسته‌اند"
  37,2,و به زجركنندگان -كه به سختى زجر مى‌كنند
  37,3,"و به تلاوت‌كنندگان [آيات الهى‌]"
  37,4,كه قطعاً معبود شما يگانه است
  37,5,پروردگار آسمانها و زمين و آنچه ميان آن دو است، و پروردگار خاورها
  37,6,ما آسمان اين دنيا را به زيور اختران آراستيم
  37,7,"و [آن را] از هر شيطان سركشى نگاه داشتيم"
  37,8,"[به طورى كه‌] نمى‌توانند به انبوه [فرشتگان‌] عالَم بالا گوش فرا دهند، و از هر سوى پرتاب مى‌شوند"
  37,9,با شدت به دور رانده مى‌شوند، و برايشان عذابى دايم است
  37,10,"مگر كسى كه [از سخن بالاييان‌] يكباره استراق سمع كند، كه شهابى شكافنده از پى او مى‌تازد"
  37,11,"پس، [از كافران‌] بپرس: آيا ايشان [از نظر] آفرينش سخت‌ترند يا كسانى كه [در آسمانها] خلق كرديم؟ ما آنان را از گِلى چسبنده پديد آورديم"
  37,12,"بلكه عجب مى‌دارى و [آنها] ريشخند مى‌كنند"
  37,13,و چون پند داده شوند عبرت نمى‌گيرند
  37,14,و چون آيتى ببينند به ريشخند مى‌پردازند
  37,15,"و مى‌گويند: «اين جز سحرى آشكار نيست.»"
  37,16,"«آيا چون مرديم و خاك و استخوانهاى [خُرد] گرديديم، آيا راستى برانگيخته مى‌شويم؟"
  37,17,و همين طور پدران اوّليه ما؟!»
  37,18,"بگو: «آرى! در حالى كه شما خواريد!»"
  37,19,و آن تنها يك فرياد است و بس! و بناگاه آنان به تماشا خيزند
  37,20,"و مى‌گويند: «اى واى بر ما! اين است روز جزا!»"
  37,21,اين است همان روز داورى كه آن را تكذيب مى‌كرديد