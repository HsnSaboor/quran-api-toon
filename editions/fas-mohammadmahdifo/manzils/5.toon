quran[856]{c,v,t}:
  26,1,طا، سين، ميم
  26,2,اين است آيه‌هاى كتاب روشنگر
  26,3,"شايد تو از اينكه [مشركان‌] ايمان نمى‌آورند، جان خود را تباه سازى"
  26,4,اگر بخواهيم، معجزه‌اى از آسمان بر آنان فرود مى‌آوريم، تا در برابر آن، گردنهايشان خاضع گردد
  26,5,"و هيچ تذكر جديدى از سوى [خداى‌] رحمان برايشان نيامد جز اينكه همواره از آن روى برمى‌تافتند"
  26,6,"[آنان‌] در حقيقت به تكذيب پرداختند، و به زودى خبر آنچه كه بدان ريشخند مى كردند، بديشان خواهد رسيد"
  26,7,مگر در زمين ننگريسته‌اند كه چه قدر در آن از هر گونه جفتهاى زيبا رويانيده‌ايم؟
  26,8,"قطعاً در اين [هنرنمايى‌] عبرتى است و[لى‌] بيشترشان ايمان‌آورنده نيستند"
  26,9,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,10,"و [ياد كن‌] هنگامى را كه پروردگارت موسى را ندا درداد كه به سوى قوم ستمكار برو"
  26,11,قوم فرعون؛ آيا پروا ندارند؟
  26,12,"گفت: «پروردگارا، مى‌ترسم مرا تكذيب كنند،"
  26,13,و سينه‌ام تنگ مى‌گردد، و زبانم باز نمى‌شود، پس به سوى هارون بفرست
  26,14,"و [از طرفى‌] آنان بر [گردن‌] من خونى دارند و مى‌ترسم مرا بكشند.»"
  26,15,"فرمود: «نه، چنين نيست؛ نشانه‌هاى ما را [براى آنان‌] بِبَريد كه ما با شما شنونده‌ايم.»"
  26,16,"پس به سوى فرعون برويد و بگوييد: «ما پيامبر پروردگار جهانيانيم،"
  26,17,فرزندان اسرائيل را با ما بفرست.»
  26,18,"[فرعون‌] گفت: «آيا تو را از كودكى در ميان خود نپرورديم و ساليانى چند از عمرت را پيش ما نماندى؟"
  26,19,"و [سرانجام‌] كار خود را كردى، و تو از ناسپاسانى.»"
  26,20,"گفت: «آن را هنگامى مرتكب شدم كه از گمراهان بودم،"
  26,21,و چون از شما ترسيدم، از شما گريختم، تا پروردگارم به من دانش بخشيد و مرا از پيامبران قرار داد
  26,22,"و [آيا] اينكه فرزندان اسرائيل را بنده [خود] ساخته‌اى نعمتى است كه منّتش را بر من مى‌نهى؟»"
  26,23,"فرعون گفت: «و پروردگار جهانيان چيست؟»"
  26,24,"گفت: «پروردگار آسمانها و زمين و آنچه ميان آن دو است-اگر اهل يقين باشيد.»"
  26,25,"[فرعون‌] به كسانى كه پيرامونش بودند گفت: «آيا نمى‌شنويد؟»"
  26,26,"[موسى دوباره‌] گفت: «پروردگار شما و پروردگار پدران پيشين شما.»"
  26,27,"[فرعون‌] گفت: «واقعاً اين پيامبرى كه به سوى شما فرستاده شده، سخت ديوانه است.»"
  26,28,"[موسى‌] گفت: «پروردگار خاور و باختر و آنچه ميان آن دو است-اگر تعقّل كنيد.»"
  26,29,"[فرعون‌] گفت: «اگر خدايى غير از من اختيار كنى قطعاً تو را از [جمله‌] زندانيان خواهم ساخت.»"
  26,30,"گفت: «گر چه براى تو چيزى آشكار بياورم؟»"
  26,31,"گفت: «اگر راست مى‌گويى آن را بياور.»"
  26,32,پس عصاى خود بيفكند و بناگاه آن اژدرى نمايان شد
  26,33,و دستش را بيرون كشيد و بناگاه آن براى تماشاگران سپيد مى‌نمود
  26,34,"[فرعون‌] به سرانى كه پيرامونش بودند گفت: «واقعاً اين ساحرى بسيار داناست"
  26,35,مى‌خواهد با سحر خود، شما را از سرزمينتان بيرون كند، اكنون چه رأى مى‌دهيد؟»
  26,36,"گفتند: «او و برادرش را در بند دار و گردآورندگان را به شهرها بفرست،"
  26,37,تا هر ساحر ماهرى را نزد تو بياورند.»
  26,38,پس ساحران براى موعدِ روزى معلوم گردآورى شدند
  26,39,"و به توده مردم گفته شد: «آيا شما هم جمع خواهيد شد؟"
  26,40,بدين اميد كه اگر ساحران غالب شدند از آنان پيروى كنيم؟»
  26,41,"و چون ساحران پيش فرعون آمدند، گفتند: «آيا اگر ما غالب آييم واقعاً براى ما مزدى خواهد بود؟»"
  26,42,"گفت: «آرى، و در آن صورت شما حتماً از [زمره‌] مقرّبان خواهيد شد.»"
  26,43,"موسى به آنان گفت: «آنچه را شما مى‌اندازيد بيندازيد.»"
  26,44,"پس ريسمانها و چوبدستى‌هايشان را انداختند و گفتند: «به عزّت فرعون كه ما حتماً پيروزيم.»"
  26,45,پس موسى عصايش را انداخت و بناگاه هر چه را به دروغ برساخته بودند بلعيد
  26,46,در نتيجه، ساحران به حالت سجده درافتادند
  26,47,"گفتند: «به پروردگار جهانيان ايمان آورديم"
  26,48,پروردگار موسى و هارون.»
  26,49,"گفت: « [آيا] پيش از آنكه به شما اجازه دهم به او ايمان آورديد؟ قطعاً او همان بزرگ شماست كه به شما سحر آموخته است. به زودى خواهيد دانست. حتماً دستها و پاهاى شما را از چپ و راست خواهم بريد و همه‌تان را به دار خواهم آويخت.»"
  26,50,"گفتند: «باكى نيست، ما روى به سوى پروردگار خود مى‌آوريم"
  26,51,"ما اميدواريم كه پروردگارمان گناهانمان را بر ما ببخشايد، [چرا] كه نخستين ايمان‌آورندگان بوديم.»"
  26,52,"و به موسى وحى كرديم كه: «بندگان مرا شبانه حركت ده، زيرا شما مورد تعقيب قرار خواهيد گرفت.»"
  26,53,"پس فرعون مأمورانِ جمع‌آورىِ [خود را] به شهرها فرستاد،"
  26,54,"[و گفت:] «اينها عده‌اى ناچيزند"
  26,55,و راستى آنها ما را بر سر خشم آورده‌اند،
  26,56,"و[لى‌] ما همگى به حال آماده‌باش درآمده‌ايم.»"
  26,57,سرانجام، ما آنان را از باغستانها و چشمه‌سارها،
  26,58,و گنجينه‌ها و جايگاه‌هاى پر ناز و نعمت بيرون كرديم
  26,59,"[اراده ما] چنين بود، و آن [نعمتها] را به فرزندان اسرائيل ميراث داديم"
  26,60,پس هنگام برآمدن آفتاب، آنها را تعقيب كردند
  26,61,"چون دو گروه، همديگر را ديدند، ياران موسى گفتند: «ما قطعاً گرفتار خواهيم شد.»"
  26,62,"گفت: «چنين نيست، زيرا پروردگارم با من است و به زودى مرا راهنمايى خواهد كرد.»"
  26,63,"پس به موسى وحى كرديم: «با عصاى خود بر اين دريا بزن.» تا از هم شكافت، و هر پاره‌اى همچون كوهى سترگ بود"
  26,64,و ديگران را بدانجا نزديك گردانيديم
  26,65,و موسى و همه كسانى را كه همراه او بودند نجات داديم؛
  26,66,آنگاه ديگران را غرق كرديم
  26,67,"مسلماً در اين [واقعه‌] عبرتى بود، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,68,و قطعاً پروردگار تو همان شكست‌ناپذير مهربان است
  26,69,و بر آنان گزارش ابراهيم را بخوان
  26,70,"آنگاه كه به پدر خود و قومش گفت: «چه مى‌پرستيد؟»"
  26,71,"گفتند: «بتانى را مى‌پرستيم و همواره ملازم آنهاييم.»"
  26,72,"گفت: «آيا وقتى دعا مى‌كنيد، از شما مى‌شنوند؟"
  26,73,يا به شما سود يا زيان مى‌رسانند؟»
  26,74,"گفتند: «نه، بلكه پدران خود را يافتيم كه چنين مى‌كردند.»"
  26,75,"گفت: «آيا در آنچه مى‌پرستيده‌ايد تأمّل كرده‌ايد؟"
  26,76,شما و پدران پيشين شما؟
  26,77,قطعاً همه آنها -جز پروردگار جهانيان- دشمن منند
  26,78,آن كس كه مرا آفريده و همو راهنماييم مى‌كند،
  26,79,و آن كس كه او به من خوراك مى‌دهد و سيرابم مى‌گرداند،
  26,80,و چون بيمار شوم او مرا درمان مى‌بخشد،
  26,81,و آن كس كه مرا مى‌ميراند و سپس زنده‌ام مى‌گرداند،
  26,82,و آن كس كه اميد دارم روز پاداش، گناهم را بر من ببخشايد.»
  26,83,پروردگارا، به من دانش عطا كن و مرا به صالحان ملحق فرماى،
  26,84,"و براى من در [ميان‌] آيندگان آوازه نيكو گذار،"
  26,85,و مرا از وارثان بهشت پر نعمت گردان،
  26,86,و بر پدرم ببخشاى كه او از گمراهان بود،
  26,87,"و روزى كه [مردم‌] برانگيخته مى‌شوند رسوايم مكن"
  26,88,روزى كه هيچ مال و فرزندى سود نمى‌دهد،
  26,89,مگر كسى كه دلى پاك به سوى خدا بياورد
  26,90,"و [آن روز] بهشت براى پرهيزگاران نزديك مى‌گردد"
  26,91,و جهنم براى گمراهان نمودار مى‌شود
  26,92,"و به آنان گفته مى‌شود: «آنچه جز خدا مى‌پرستيديد كجايند؟"
  26,93,آيا ياريتان مى‌كنند يا خود را يارى مى‌دهند؟
  26,94,"پس آنها و همه گمراهان در آن [آتش‌] افكنده مى‌شوند،"
  26,95,"و [نيز] همه سپاهيان ابليس"
  26,96,"آنها در آنجا با يكديگر ستيزه مى‌كنند [و] مى‌گويند"
  26,97,«سوگند به خدا كه ما در گمراهى آشكارى بوديم،
  26,98,آنگاه كه شما را با پروردگار جهانيان برابر مى‌كرديم،
  26,99,و جز تباهكاران ما را گمراه نكردند،
  26,100,در نتيجه شفاعتگرانى نداريم،
  26,101,و نه دوستى نزديك
  26,102,و اى كاش كه بازگشتى براىِ ما بود و از مؤمنان مى‌شديم
  26,103,"حقاً در اين [سرگذشت درس‌] عبرتى است و[لى‌] بيشترشان مؤمن نبودند"
  26,104,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,105,قوم نوح پيامبران را تكذيب كردند
  26,106,"چون برادرشان نوح به آنان گفت: «آيا پروا نداريد؟"
  26,107,من براى شما فرستاده‌اى در خور اعتمادم؛
  26,108,از خدا پروا كنيد و فرمانم ببريد،
  26,109,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,110,پس، از خدا پروا كنيد و فرمانم ببريد.»
  26,111,"گفتند: «آيا به تو ايمان بياوريم و حال آنكه فرومايگان از تو پيروى كرده‌اند؟»"
  26,112,"[نوح‌] گفت: «به [جزئيات‌] آنچه مى‌كرده‌اند چه آگاهى دارم؟"
  26,113,حسابشان -اگر درمى‌يابيد- جز با پروردگارم نيست
  26,114,و من طردكننده مؤمنان نيستم
  26,115,"من جز هشداردهنده‌اى آشكار [بيش‌] نيستم.»"
  26,116,"گفتند: «اى نوح، اگر دست برندارى قطعاً از [جمله‌] سنگسارشدگان خواهى بود.»"
  26,117,"گفت: «پروردگارا، قوم من مرا تكذيب كردند؛"
  26,118,ميان من و آنان فيصله ده، و من و هر كس از مؤمنان را كه با من است نجات بخش.»
  26,119,پس او و هر كه را در آن كشتى آكنده با او بود، رهانيديم؛
  26,120,آنگاه باقى‌ماندگان را غرق كرديم
  26,121,"قطعاً در اين [ماجرا درس‌] عبرتى بود، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,122,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,123,"عاديان، پيامبران [خدا] را تكذيب كردند"
  26,124,"آنگاه كه برادرشان هود به آنان گفت: «آيا پروا نداريد؟"
  26,125,من براى شما فرستاده‌اى در خور اعتمادم
  26,126,از خدا پروا كنيد و فرمانم ببريد
  26,127,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,128,"آيا بر هر تپه‌اى بنايى مى‌سازيد كه [در آن‌] دست به بيهوده‌كارى زنيد؟"
  26,129,و كاخهاى استوار مى‌گيريد به اميد آنكه جاودانه بمانيد؟
  26,130,"و چون حمله‌ور مى‌شويد [چون‌] زورگويان حمله‌ور مى‌شويد؟"
  26,131,پس، از خدا پروا داريد و فرمانم ببريد
  26,132,و از آن كس كه شما را به آنچه مى‌دانيد مدد كرد پروا داريد
  26,133,"شما را به [دادن‌] دامها و پسران مدد كرد،"
  26,134,"و به [دادن‌] باغها و چشمه‌ساران؛"
  26,135,من از عذاب روزى هولناك بر شما مى‌ترسم
  26,136,"گفتند: «خواه اندرز دهى و خواه از اندرزدهندگان نباشى براى ما يكسان است"
  26,137,اين جز شيوه پيشينيان نيست
  26,138,و ما عذاب نخواهيم شد.»
  26,139,"پس تكذيبش كردند و هلاكشان كرديم. قطعاً در اين [ماجرا درس‌] عبرتى بود، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,140,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,141,"ثموديان، پيامبران [خدا] را تكذيب كردند؛"
  26,142,"آنگاه كه برادرشان صالح به آنان گفت: «آيا پروا نداريد؟"
  26,143,من براى شما فرستاده‌اى در خور اعتمادم
  26,144,از خدا پروا كنيد و فرمانم ببريد
  26,145,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,146,آيا شما را در آنچه اينجا داريد آسوده رها مى‌كنند؟
  26,147,در باغها و در كنار چشمه‌ساران،
  26,148,و كشتزارها و خرمابنانى كه شكوفه‌هايشان لطيف است؟
  26,149,و هنرمندانه براى خود از كوهها خانه‌هايى مى‌تراشيد
  26,150,از خدا پروا كنيد و فرمانم ببريد
  26,151,و فرمان افراطگران را پيروى مكنيد
  26,152,آنان كه در زمين فساد مى‌كنند و اصلاح نمى‌كنند.»
  26,153,"گفتند: «قطعاً تو از افسون‌شدگانى"
  26,154,"تو جز بشرى مانند ما [بيش‌] نيستى. اگر راست مى‌گويى معجزه‌اى بياور"
  26,155,"گفت: «اين ماده‌شترى است كه نوبتى از آب او راست و روزى معين نوبت آب شماست"
  26,156,و به آن گزندى مرسانيد كه عذاب روزى هولناك شما را فرو مى‌گيرد
  26,157,پس آن را پى كردند و پشيمان گشتند
  26,158,"آنگاه آنان را عذاب فرو گرفت. قطعاً در اين [ماجرا] عبرتى است، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,159,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,160,قوم لوط فرستادگان را تكذيب كردند
  26,161,"آنگاه برادرشان لوط به آنان گفت: «آيا پروا نداريد؟"
  26,162,من براى شما فرستاده‌اى در خور اعتمادم
  26,163,از خدا پروا داريد و فرمانم ببريد
  26,164,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,165,آيا از ميان مردم جهان، با مردها در مى‌آميزيد؟
  26,166,"و آنچه را پروردگارتان از همسرانتان براى شما آفريده وامى‌گذاريد؟ [نه،] بلكه شما مردمى تجاوزكاريد"
  26,167,"گفتند: «اى لوط، اگر دست برندارى، قطعاً از اخراج‌شدگان خواهى بود.»"
  26,168,"گفت: «به راستى من دشمن كردار شمايم"
  26,169,پروردگارا، مرا و كسان مرا از آنچه انجام مى‌دهند رهايى بخش.»
  26,170,پس او و كسانش را همگى، رهانيديم
  26,171,"جز پيرزنى كه از باقى‌ماندگان [در خاكستر آتش‌] بود"
  26,172,سپس ديگران را سخت هلاك كرديم
  26,173,"و بر [سر] آنان بارانى [از آتش گوگرد] فرو ريختيم. و چه بد بود باران بيم‌داده‌شدگان"
  26,174,"قطعاً در اين [عقوبت‌] عبرتى است، و[لى‌] بيشترشان ايمان‌آورنده نبودند"
  26,175,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,176,اصحاب ايكه فرستادگان را تكذيب كردند
  26,177,"آنگاه كه شعيب به آنان گفت: «آيا پروا نداريد؟"
  26,178,من براى شما فرستاده‌اى در خور اعتمادم
  26,179,از خدا پروا داريد و فرمانم ببريد
  26,180,"و بر اين [رسالت‌] اجرى از شما طلب نمى‌كنم. اجر من جز بر عهده پروردگار جهانيان نيست"
  26,181,پيمانه را تمام دهيد و از كم‌فروشان مباشيد
  26,182,و با ترازوى درست بسنجيد
  26,183,و از ارزش اموال مردم مكاهيد و در زمين سر به فساد بر مداريد
  26,184,"و از آن كس كه شما و خلق [انبوه‌] گذشته را آفريده است پروا كنيد.»"
  26,185,"گفتند: «تو واقعاً از افسون‌شدگانى.»"
  26,186,"«و تو جز بشرى مانند ما [بيش‌] نيستى، و قطعاً تو را از دروغگويان مى‌دانيم"
  26,187,"پس اگر از راستگويانى، پاره‌اى از آسمان بر [سر] ما بيفكن.»"
  26,188,"[شعيب‌] گفت: «پروردگارم به آنچه مى‌كنيد داناتر است.»"
  26,189,"پس او را تكذيب كردند، و عذابِ روزِ ابر [آتشبار] آنان را فرو گرفت. به راستى آن، عذاب روزى هولناك بود"
  26,190,"قطعاً در اين [عقوبت درسِ‌] عبرتى است، و[لى‌] بيشترشان ايمان آورنده نبودند"
  26,191,و در حقيقت، پروردگار تو همان شكست‌ناپذير مهربان است
  26,192,"و راستى كه اين [قرآن‌] وحى پروردگار جهانيان است"
  26,193,«روح الامين» آن را بر دلت نازل كرد،
  26,194,"تا از [جمله‌] هشداردهندگان باشى؛"
  26,195,به زبان عربى روشن،
  26,196,"و [وصف‌] آن در كتابهاى پيشينيان آمده است"
  26,197,آيا براى آنان، اين خود دليلى روشن نيست كه علماى بنى‌اسرائيل از آن اطّلاع دارند؟
  26,198,و اگر آن را بر برخى از غير عرب زبانان نازل مى‌كرديم،
  26,199,و پيامبر آن را برايشان مى‌خواند به آن ايمان نمى‌آوردند
  26,200,"اين گونه در دلهاى گناهكاران، [انكار را] راه مى‌دهيم"
  26,201,كه به آن نگروند تا عذاب پردرد را ببينند،
  26,202,كه به طور ناگهانى -در حالى كه بى‌خبرند- بديشان برسد
  26,203,"و بگويند: «آيا مهلت خواهيم يافت؟»"
  26,204,پس آيا عذاب ما را به شتاب مى‌خواهند؟
  26,205,مگر نمى‌دانى كه اگر سالها آنان را برخوردار كنيم،
  26,206,"و آنگاه آنچه كه [بدان‌] بيم داده مى‌شوند بديشان برسد،"
  26,207,"آنچه از آن برخوردار مى‌شدند، به كارشان نمى‌آيد [و عذاب را از آنان دفع نمى‌كند]؟"
  26,208,و هيچ شهرى را هلاك نكرديم مگر آنكه براى آن هشداردهندگانى بود
  26,209,"[تا آنان را] تذكر [دهند]؛ و ما ستمكار نبوده‌ايم"
  26,210,و شيطانها آن را فرود نياورده‌اند
  26,211,"و آنان را نسزد و نمى‌توانند [وحى كنند]"
  26,212,"در حقيقت آنها از شنيدن، معزول [و محروم‌]اند"
  26,213,پس با خدا، خداى ديگر مخوان كه از عذاب‌شدگان خواهى شد
  26,214,و خويشان نزديكت را هشدار ده
  26,215,و براى آن مؤمنانى كه تو را پيروى كرده‌اند، بال خود را فرو گستر
  26,216,"و اگر تو را نافرمانى كردند، بگو: «من از آنچه مى‌كنيد بيزارم.»"
  26,217,"و بر [خداىِ‌] عزيزِ مهربان توكل كن،"
  26,218,"آن كس كه چون [به نماز] برمى‌خيزى تو را مى‌بيند،"
  26,219,"و حركت تو را در ميان سجده‌كنندگان [مى‌نگرد]"
  26,220,او همان شنواى داناست
  26,221,آيا شما را خبر دهم كه شياطين بر چه كسى فرود مى‌آيند؟
  26,222,بر هر دروغزن گناهكارى فرود مى‌آيند،
  26,223,"كه [دزدانه‌] گوش فرا مى‌دارند و بيشترشان دروغگويند،"
  26,224,و شاعران را گمراهان پيروى مى‌كنند
  26,225,آيا نديده‌اى كه آنان در هر واديى سرگردانند؟
  26,226,و آنانند كه چيزهايى مى‌گويند كه انجام نمى‌دهند
  26,227,مگر كسانى كه ايمان آورده و كارهاى شايسته كرده و خدا را بسيار به ياد آورده و پس از آنكه مورد ستم قرار گرفته‌اند يارى خواسته‌اند. و كسانى كه ستم كرده‌اند به زودى خواهند دانست به كدام بازگشتگاه برخواهند گشت
  27,1,"طا، سين. اين است آيات قرآن و [آيات‌] كتابى روشنگر،"
  27,2,"كه [مايه‌] هدايت و بشارت براى مؤمنان است"
  27,3,همانان كه نماز برپا مى‌دارند و زكات مى‌دهند و خود به آخرت يقين دارند
  27,4,"كسانى كه به آخرت ايمان ندارند، كردارهايشان را در نظرشان بياراستيم [تا همچنان‌] سرگشته بمانند"
  27,5,"آنان كسانى‌اند كه عذاب سخت براى ايشان خواهد بود، و در آخرت، خود زيانكارترين [مردم‌]اند"
  27,6,و حقاً تو قرآن را از سوى حكيمى دانا دريافت مى‌دارى
  27,7,"[يادكن‌] هنگامى را كه موسى به خانواده خود گفت: «من آتشى به نظرم رسيد، به زودى براى شما خبرى از آن خواهم آورد، يا شعله آتشى براى شما مى‌آورم، باشد كه خود را گرم كنيد.»"
  27,8,"چون نزد آن آمد، آوا رسيد كه: «خجسته [و مبارك گرديد] آنكه در كنار اين آتش و آنكه پيرامون آن است، و منزه است خدا، پروردگار جهانيان.»"
  27,9,«اى موسى، اين منم خداى عزيز حكيم.»
  27,10,و عصايت را بيفكن. پس چون آن را همچون مارى ديد كه مى‌جنبد، پشت گردانيد و به عقب بازنگشت. «اى موسى، مترس كه فرستادگان پيش من نمى‌ترسند
  27,11,"ليكن كسى كه ستم كرده سپس -بعد از بدى- نيكى را جايگزين [آن‌] گردانيده، [بداند] كه من آمرزنده مهربانم"
  27,12,"و دستت را در گريبانت كن تا سپيد بى‌عيب بيرون آيد. [اينها] از [جمله‌] نشانه‌هاى نُه‌گانه‌اى است [كه بايد] به سوى فرعون و قومش [ببَرى‌]، زيرا كه آنان مردمى نافرمانند"
  27,13,"و هنگامى كه آيات روشنگر ما به سويشان آمد گفتند: «اين سحرى آشكار است.»"
  27,14,و با آنكه دلهايشان بدان يقين داشت، از روى ظلم و تكبر آن را انكار كردند. پس ببين فرجام فسادگران چگونه بود
  27,15,"و به راستى به داوود و سليمان دانشى عطا كرديم، و آن دو گفتند: «ستايش خدايى را كه ما را بر بسيارى از بندگان باايمانش برترى داده است.»"
  27,16,"و سليمان از داوود ميراث يافت و گفت: «اى مردم، ما زبان پرندگان را تعليم يافته‌ايم و از هر چيزى به ما داده شده است. راستى كه اين همان امتياز آشكار است.»"
  27,17,"و براى سليمان سپاهيانش از جن و انس و پرندگان جمع‌آورى شدند و [براى رژه‌] دسته دسته گرديدند"
  27,18,"تا آنگاه كه به وادى مورچگان رسيدند. مورچه‌اى [به زبان خويش‌] گفت: «اى مورچگان، به خانه‌هايتان داخل شويد، مبادا سليمان و سپاهيانش -نديده و ندانسته- شما را پايمال كنند.»"
  27,19,"[سليمان‌] از گفتار او دهان به خنده گشود و گفت: «پروردگارا، در دلم افكن تا نعمتى را كه به من و پدر و مادرم ارزانى داشته‌اى سپاس بگزارم، و به كار شايسته‌اى كه آن را مى‌پسندى بپردازم، و مرا به رحمت خويش در ميان بندگان شايسته‌ات داخل كن.»"
  27,20,"و جوياى [حال‌] پرندگان شد و گفت: «مرا چه شده است كه هدهد را نمى‌بينم؟ يا شايد از غايبان است؟"
  27,21,قطعاً او را به عذابى سخت عذاب مى‌كنم يا سرش را مى‌برم مگر آنكه دليلى روشن براى من بياورد
  27,22,"پس ديرى نپاييد كه [هدهد آمد و] گفت: «از چيزى آگاهى يافتم كه از آن آگاهى نيافته‌اى، و براى تو از «سبا» گزارشى درست آورده‌ام"
  27,23,"من [آنجا] زنى را يافتم كه بر آنها سلطنت مى‌كرد و از هر چيزى به او داده شده بود و تختى بزرگ داشت"
  27,24,"او و قومش را چنين يافتم كه به جاى خدا به خورشيد سجده مى‌كنند، و شيطان اعمالشان را برايشان آراسته و آنان را از راه [راست‌] باز داشته بود، در نتيجه [به حق‌] راه نيافته بودند"
  27,25,"[آرى، شيطان چنين كرده بود] تا براى خدايى كه نهان را در آسمانها و زمين بيرون مى‌آورد و آنچه را پنهان مى‌داريد و آنچه را آشكار مى‌نماييد مى‌داند، سجده نكنند؛"
  27,26,خداى يكتا كه هيچ خدايى جز او نيست، پروردگار عرش بزرگ است.»
  27,27,"گفت: «خواهيم ديد آيا راست گفته‌اى يا از دروغگويان بوده‌اى.»"
  27,28,«اين نامه مرا ببر و به سوى آنها بيفكن، آنگاه از ايشان روى برتاب، پس ببين چه پاسخ مى‌دهند.»
  27,29,"[ملكه سبا] گفت: «اى سران [كشور] نامه‌اى ارجمند براى من آمده است،"
  27,30,"كه از طرف سليمان است و [مضمون آن‌] اين است: به نام خداوند رحمتگر مهربان"
  27,31,بر من بزرگى مكنيد و مرا از در اطاعت درآييد.»
  27,32,"گفت: «اى سران [كشور] در كارم به من نظر دهيد كه بى‌حضور شما [تا به حال‌] كارى را فيصله نداده‌ام.»"
  27,33,"گفتند: «ما سخت نيرومند و دلاوريم، و[لى‌] اختيار كار با توست، بنگر چه دستور مى‌دهى؟»"
  27,34,"[ملكه‌] گفت: «پادشاهان چون به شهرى درآيند، آن را تباه و عزيزانش را خوار مى‌گردانند، و اين گونه مى‌كنند.»"
  27,35,"«و [اينك‌] من ارمغانى به سويشان مى‌فرستم و مى‌نگرم كه فرستادگان [من‌] با چه چيز بازمى‌گردند.»"
  27,36,"و چون [فرستاده‌] نزد سليمان آمد، [سليمان‌] گفت: «آيا مرا به مالى كمك مى‌دهيد؟ آنچه خدا به من عطا كرده، بهتر است از آنچه به شما داده‌است. [نه،] بلكه شما به ارمغان خود شادمانى مى‌نماييد"
  27,37,"به سوى آنان بازگرد كه قطعاً سپاهيانى بر [سر] ايشان مى‌آوريم كه در برابر آنها تاب ايستادگى نداشته باشند و از آن [ديار] به خوارى و زبونى بيرونشان مى‌كنيم.»"
  27,38,"[سپس‌] گفت: «اى سران [كشور] كدام يك از شما تخت او را -پيش از آنكه مطيعانه نزد من آيند- براى من مى‌آورد؟»"
  27,39,"عفريتى از جن گفت: «من آن را پيش از آنكه از مجلس خود برخيزى براى تو مى‌آورم و بر اين [كار] سخت توانا و مورد اعتمادم.»"
  27,40,"كسى كه نزد او دانشى از كتاب [الهى‌] بود، گفت: «من آن را پيش از آنكه چشم خود را بر هم زنى برايت مى‌آورم.» پس چون [سليمان‌] آن [تخت‌] را نزد خود مستقر ديد، گفت: «اين از فضل پروردگار من است، تا مرا بيازمايد كه آيا سپاسگزارم يا ناسپاسى مى‌كنم. و هر كس سپاس گزارد، تنها به سود خويش سپاس مى‌گزارد، و هر كس ناسپاسى كند، بى‌گمان پروردگارم بى‌نياز و كريم است.»"
  27,41,"گفت: «تخت [ملكه‌] را برايش ناشناس گردانيد تا ببينيم آيا پى مى‌برد يا از كسانى است كه پى نمى‌برند.»"
  27,42,"پس وقتى [ملكه‌] آمد، [بدو] گفته شد: «آيا تخت تو همين گونه است؟» گفت: «گويا اين همان است و پيش از اين، ما آگاه شده و از در اطاعت درآمده بوديم.»"
  27,43,"و [در حقيقت قبلاً] آنچه غير از خدا مى‌پرستيد مانع [ايمان‌] او شده بود و او از جمله گروه كافران بود"
  27,44,"به او گفته شد: «وارد ساحت كاخ [پادشاهى‌] شو.» و چون آن را ديد، بركه‌اى پنداشت و ساقهايش را نمايان كرد. [سليمان‌] گفت: «اين كاخى مفروش از آبگينه است.» [ملكه‌] گفت: «پروردگارا، من به خود ستم كردم و [اينك‌] با سليمان در برابر خدا، پروردگار جهانيان، تسليم شدم.»"
  27,45,"و به راستى، به سوى ثمود، برادرشان صالح را فرستاديم كه: «خدا را بپرستيد.» پس به ناگاه آنان دو دسته متخاصم شدند"
  27,46,"[صالح‌] گفت: «اى قوم من، چرا پيش از [جستن‌] نيكى، شتابزده خواهان بدى هستيد؟ چرا از خدا آمرزش نمى‌خواهيد؟ باشد كه مورد رحمت قرار گيريد.»"
  27,47,"گفتند: «ما به تو و به هر كس كه همراه توست شگون بد زديم.» گفت: «سرنوشت خوب و بدتان پيش خداست، بلكه شما مردمى هستيد كه مورد آزمايش قرار گرفته‌ايد.»"
  27,48,و در آن شهر، نُه دسته بودند كه در آن سرزمين فساد مى‌كردند و از در اصلاح درنمى‌آمدند
  27,49,"[با هم‌] گفتند: «با يكديگر سوگند بخوريد كه: حتماً به [صالح‌] و كسانش شبيخون مى‌زنيم، سپس به ولىّ او خواهيم گفت: ما در محل قتل كسانش حاضر نبوديم، و ما قطعاً راست مى‌گوييم.»"
  27,50,"و دست به نيرنگ زدند و [ما نيز] دست به نيرنگ زديم و خبر نداشتند"
  27,51,"پس بنگر كه فرجام نيرنگشان چگونه بود: ما آنان و قومشان را همگى هلاك كرديم"
  27,52,"و اين [هم‌] خانه‌هاى خالى آنهاست به [سزاى‌] بيدادى كه كرده‌اند. قطعاً در اين [كيفر] براى مردمى كه مى‌دانند عبرتى خواهد بود"
  27,53,و كسانى را كه ايمان آورده و تقوا پيشه كرده بودند رهانيديم
  27,54,"و [ياد كن‌] لوط را كه چون به قوم خود گفت: «آيا ديده و دانسته مرتكب عمل ناشايست [لواط] مى‌شويد؟"
  27,55,"آيا شما به جاى زنان، از روى شهوت با مردها در مى‌آميزيد؟ [نه!] بلكه شما مردمى جهالت‌پيشه‌ايد.»"
  27,56,"و[لى‌] پاسخ قومش غير از اين نبود كه گفتند: «خاندان لوط را از شهرتان بيرون كنيد كه آنها مردمى هستند كه به پاكى تظاهر مى‌نمايند.»"
  27,57,"پس او و خانواده‌اش را نجات داديم، جز زنش را كه مقدّر كرديم از باقى‌ماندگان [در خاكستر آتش‌] باشد"
  27,58,"و بارانى [از سجّيل‌] بر ايشان فرو باريديم، و باران هشدارداده‌شدگان، چه بد بارانى بود"
  27,59,"بگو: «سپاس براى خداست، و درود بر آن بندگانش كه [آنان را] برگزيده است.» آيا خدا بهتر است يا آنچه [با او] شريك مى‌گردانند؟"
  27,60,"[آيا آنچه شريك مى‌پندارند بهتر است‌] يا آن كس كه آسمانها و زمين را خلق كرد و براى شما آبى از آسمان فرود آورد، پس به وسيله آن، باغهاى بهجت‌انگيز رويانيديم. كار شما نبود كه درختانش را برويانيد. آيا معبودى با خداست؟ [نه،] بلكه آنان قومى منحرفند"
  27,61,"[آيا شريكانى كه مى‌پندارند بهتر است‌] يا آن كس كه زمين را قرارگاهى ساخت و در آن رودها پديد آورد و براى آن، كوه‌ها را [مانند لنگر] قرار داد، و ميان دو دريا برزخى گذاشت؟ آيا معبودى با خداست؟ [نه،] بلكه بيشترشان نمى‌دانند"
  27,62,"يا [كيست‌] آن كس كه درمانده را -چون وى را بخواند- اجابت مى‌كند، و گرفتارى را برطرف مى‌گرداند، و شما را جانشينان اين زمين قرار مى‌دهد؟ آيا معبودى با خداست؟ چه كم پند مى‌پذيريد"
  27,63,"يا آن كس كه شما را در تاريكيهاى خشكى و دريا راه مى‌نمايد و آن كس كه بادها[ى باران زا] را پيشاپيش رحمتش بشارتگر مى‌فرستد؟ آيا معبودى با خداست؟ خدا برتر [و بزرگتر] است از آنچه [با او ]شريك مى‌گردانند"
  27,64,"يا آن كس كه خلق را آغاز مى‌كند و سپس آن را بازمى‌آورد، و آن كس كه از آسمان و زمين به شما روزى مى‌دهد؟ آيا معبودى با خداست؟ بگو: «اگر راست مى‌گوييد، برهان خويش را بياوريد.»"
  27,65,"بگو: «هر كه در آسمانها و زمين است -جز خدا- غيب را نمى‌شناسند و نمى‌دانند كى برانگيخته خواهند شد؟»"
  27,66,"[نه،] بلكه علم آنان در باره آخرت نارساست؛ [نه،] بلكه ايشان در باره آن ترديد دارند؛ [نه،] بلكه آنان در مورد آن كوردلند"
  27,67,"و كسانى كه كفر ورزيدند، گفتند: «آيا وقتى ما و پدرانمان خاك شديم، آيا حتماً [زنده از گور] بيرون آورده مى‌شويم؟"
  27,68,در حقيقت، اين را به ما و پدرانمان قبلاً وعده داده‌اند؛ اين جز افسانه‌هاى پيشينيان نيست.»
  27,69,"بگو: «در زمين بگرديد و بنگريد فرجام گنه‌پيشگان چگونه بوده است.»"
  27,70,و بر آنان غم مخور، و از آنچه مكر مى‌كنند تنگدل مباش
  27,71,"و مى‌گويند: «اگر راست مى‌گوييد، اين وعده كى خواهد بود؟»"
  27,72,"بگو: «شايد برخى از آنچه را به شتاب مى‌خواهيد در پى شما باشد.»"
  27,73,"و راستى پروردگارت بر [اين‌] مردم داراى بخشش است، ولى بيشترشان سپاس نمى‌دارند"
  27,74,و در حقيقت، پروردگار تو آنچه را در سينه‌هايشان نهفته و آنچه را آشكار مى‌دارند نيك مى‌داند
  27,75,"و هيچ پنهانى در آسمان و زمين نيست، مگر اينكه در كتابى روشن [درج‌] است"
  27,76,بى‌گمان، اين قرآن بر فرزندان اسرائيل بيشتر آنچه را كه آنان در باره‌اش اختلاف دارند حكايت مى‌كند
  27,77,و به راستى كه آن، رهنمود و رحمتى براى مؤمنان است
  27,78,در حقيقت، پروردگار تو طبق حكم خود ميان آنان داورى مى‌كند، و اوست شكست‌ناپذير دانا
  27,79,پس بر خدا توكل كن كه تو واقعاً بر حق آشكارى
  27,80,البته تو مردگان را شنوا نمى‌گردانى، و اين ندا را به كران -چون پشت بگردانند- نمى‌توانى بشنوانى
  27,81,"و راهبر كوران [و بازگرداننده‌] از گمراهى‌شان نيستى. تو جز كسانى را كه به نشانه‌هاى ما ايمان آورده‌اند و مسلمانند، نمى‌توانى بشنوانى"
  27,82,"و چون قول [عذاب‌] بر ايشان واجب گردد، جنبنده‌اى را از زمين براى آنان بيرون مى‌آوريم كه با ايشان سخن گويد كه: مردم [چنانكه بايد] به نشانه‌هاى ما يقين نداشتند"
  27,83,و آن روز كه از هر امتى، گروهى از كسانى را كه آيات ما را تكذيب كرده‌اند محشور مى‌گردانيم، پس آنان نگاه داشته مى‌شوند تا همه به هم بپيوندند
  27,84,"تا چون [همه كافران‌] بيايند، [خدا] مى‌فرمايد: «آيا نشانه‌هاى مرا به دروغ گرفتيد و حال آنكه از نظر علم، بدانها احاطه نداشتيد؟ آيا [در طول حيات‌] چه مى‌كرديد؟»"
  27,85,"و به [كيفر] آنكه ستم كردند، حكم [عذاب‌] بر آنان واجب گردد، در نتيجه ايشان دَم برنيارند"
  27,86,"آيا نديده‌اند كه ما شب را قرار داده‌ايم تا در آن بياسايند، و روز را روشنى‌بخش [گردانيديم‌]؟ قطعاً در اين [امر] براى مردمى كه ايمان مى‌آورند مايه‌هاى عبرت است"
  27,87,و روزى كه در صور دميده شود، پس هر كه در آسمانها و هر كه در زمين است به هراس افتد، مگر آن كس كه خدا بخواهد. و جملگى با زبونى رو به سوى او آورند
  27,88,"و كوهها را مى‌بينى [و] مى‌پندارى كه آنها بى‌حركتند و حال آنكه آنها ابرآسا در حركتند. [اين‌] صُنعِ خدايى است كه هر چيزى را در كمال استوارى پديد آورده است. در حقيقت، او به آنچه انجام مى‌دهيد آگاه است"
  27,89,هر كس نيكى به ميان آورد، پاداشى بهتر از آن خواهد داشت، و آنان از هراس آن روز ايمنند
  27,90,"و هر كس بدى به ميان آورد، به رو در آتش [دوزخ‌] سرنگون شوند. آيا جز آنچه مى‌كرديد سزا داده مى‌شويد؟"
  27,91,من مأمورم كه تنها پروردگار اين شهر را كه آن را مقدس شمرده و هر چيزى از آنِ اوست پرستش كنم، و مأمورم كه از مسلمانان باشم،
  27,92,"و اينكه قرآن را بخوانم. پس هر كه راه يابد تنها به سود خود راه يافته است؛ و هر كه گمراه شود بگو: «من فقط از هشداردهندگانم.»"
  27,93,"و بگو: «ستايش از آنِ خداست. به زودى آياتش را به شما نشان خواهد داد و آن را خواهيد شناخت.» و پروردگار تو از آنچه مى‌كنيد غافل نيست"
  28,1,طا، سين، ميم
  28,2,اين است آيات كتاب روشنگر
  28,3,"[بخشى‌] از گزارش [حال‌] موسى و فرعون را براى [آگاهى‌] مردمى كه ايمان مى‌آورند، به درستى بر تو مى‌خوانيم"
  28,4,"فرعون در سرزمين [مصر] سر برافراشت، و مردم آن را طبقه طبقه ساخت؛ طبقه‌اى از آنان را زبون مى‌داشت: پسرانشان را سر مى‌بريد، و زنانشان را [براى بهره‌كشى‌] زنده بر جاى مى‌گذاشت، كه وى از فسادكاران بود"
  28,5,"و خواستيم بر كسانى كه در آن سرزمين فرو دست شده بودند منّت نهيم و آنان را پيشوايان [مردم‌] گردانيم، و ايشان را وارث [زمين‌] كنيم،"
  28,6,"و در زمين قدرتشان دهيم و [از طرفى‌] به فرعون و هامان و لشكريانشان آنچه را كه از جانب آنان بيمناك بودند، بنمايانيم"
  28,7,"و به مادر موسى وحى كرديم كه: «او را شير ده، و چون بر او بيمناك شدى او را در نيل بينداز، و مترس و اندوه مدار كه ما او را به تو بازمى‌گردانيم و از [زمره‌] پيمبرانش قرار مى‌دهيم.»"
  28,8,"پس خاندان فرعون، او را [از آب‌] برگرفتند تا سرانجام دشمنِ [جانِ‌] آنان و مايه اندوهشان باشد. آرى، فرعون و هامان و لشكريان آنها خطاكار بودند"
  28,9,"و همسر فرعون گفت: «[اين كودك‌] نور چشم من و تو خواهد بود. او را مكشيد. شايد براى ما سودمند باشد يا او را به فرزندى بگيريم، ولى آنها خبر نداشتند"
  28,10,"و دل مادر موسى [از هر چيز، جز از فكر فرزند] تهى گشت. اگر قلبش را استوار نساخته بوديم تا از ايمان‌آورندگان باشد، چيزى نمانده بود كه آن [راز] را افشا كند"
  28,11,"و به خواهر [موسى‌] گفت: «از پى او برو.» پس او را از دور ديد، در حالى كه آنان متوجه نبودند"
  28,12,"و از پيش، شير دايگان را بر او حرام گردانيده بوديم. پس [خواهرش آمد و] گفت: «آيا شما را بر خانواده‌اى راهنمايى كنم كه براى شما از وى سرپرستى كنند و خيرخواه او باشند؟»"
  28,13,"پس او را به مادرش بازگردانيديم تا چشمش [بدو] روشن شود و غم نخورد و بداند كه وعده خدا درست است، ولى بيشترشان نمى‌دانند"
  28,14,و چون به رشد و كمال خويش رسيد، به او حكمت و دانش عطا كرديم، و نيكوكاران را چنين پاداش مى‌دهيم
  28,15,"و داخل شهر شد بى‌آنكه مردمش متوجه باشند. پس دو مرد را با هم در زد و خورد يافت: يكى، از پيروان او و ديگرى از دشمنانش [بود]. آن كس كه از پيروانش بود، بر ضد كسى كه دشمن وى بود، از او يارى خواست. پس موسى مشتى بدو زد و او را كشت. گفت: «اين كار شيطان است، چرا كه او دشمنى گمراه‌كننده [و] آشكار است.»"
  28,16,"گفت: «پروردگارا، من بر خويشتن ستم كردم، مرا ببخش.» پس خدا از او درگذشت كه وى آمرزنده مهربان است"
  28,17,"[موسى‌] گفت: «پروردگارا به پاس نعمتى كه بر من ارزانى داشتى هرگز پشتيبان مجرمان نخواهم بود.»"
  28,18,"صبحگاهان در شهر، بيمناك و در انتظار [حادثه‌اى‌] بود. ناگاه همان كسى كه ديروز از وى يارى خواسته بود [باز] با فرياد از او يارى خواست. موسى به او گفت: «به راستى كه تو آشكارا گمراهى.»"
  28,19,"و چون خواست به سوى آنكه دشمن هر دوشان بود حمله آورد، گفت: «اى موسى، آيا مى‌خواهى مرا بكشى چنانكه ديروز شخصى را كشتى؟ تو مى‌خواهى در اين سرزمين فقط زورگو باشى، و نمى‌خواهى از اصلاحگران باشى.»"
  28,20,"و از دورافتاده‌ترين [نقطه‌] شهر، مردى دوان دوان آمد [و] گفت: «اى موسى، سران قوم در باره تو مشورت مى‌كنند تا تو را بكشند. پس [از شهر] خارج شو. من جداً از خيرخواهان توام.»"
  28,21,"موسى ترسان و نگران از آنجا بيرون رفت [در حالى كه مى‌]گفت: «پروردگارا، مرا از گروه ستمكاران نجات بخش.»"
  28,22,"و چون به سوى [شهر] مدين رو نهاد [با خود] گفت: «اميد است پروردگارم مرا به راه راست هدايت كند.»"
  28,23,"و چون به آب مدين رسيد، گروهى از مردم را بر آن يافت كه [دامهاى خود را ] آب مى‌دادند، و پشت سرشان دو زن را يافت كه [گوسفندان خود را] دور مى‌كردند. [موسى‌] گفت: «منظورتان [از اين كار ]چيست؟» گفتند: « [ما به گوسفندان خود] آب نمى‌دهيم تا شبانان [همگى گوسفندانشان را] برگردانند، و پدر ما پيرى سالخورده است.»"
  28,24,"پس براى آن دو، [گوسفندان را] آب داد، آنگاه به سوى سايه برگشت و گفت: «پروردگارا، من به هر خيرى كه سويم بفرستى سخت نيازمندم.»"
  28,25,"پس يكى از آن دو زن -در حالى كه به آزرم گام بر مى‌داشت- نزد وى آمد [و] گفت: «پدرم تو را مى‌طلبد تا تو را به پاداش آب‌دادن [گوسفندان‌] براى ما، مزد دهد.» و چون [موسى‌] نزد او آمد و سرگذشت [خود] را بر او حكايت كرد، [وى‌] گفت: «مترس كه از گروه ستمگران نجات يافتى.»"
  28,26,"يكى از آن دو [دختر] گفت: «اى پدر، او را استخدام كن، چرا كه بهترين كسى است كه استخدام مى‌كنى: هم نيرومند [و هم‌] در خور اعتماد است.»"
  28,27,"[شعيب‌] گفت: «من مى‌خواهم يكى از اين دو دختر خود را [كه مشاهده مى‌كنى‌] به نكاح تو در آورم، به اين [شرط] كه هشت سال براى من كار كنى، و اگر ده سال را تمام گردانى اختيار با تو است، و نمى‌خواهم بر تو سخت گيرم، و مرا ان شاء الله از درستكاران خواهى يافت.»"
  28,28,"[موسى‌] گفت: «اين [قرار داد] ميان من و تو باشد كه هر يك از دو مدت را به انجام رسانيدم، بر من تعدى [روا] نباشد، و خدا بر آنچه مى‌گوييم وكيل است.»"
  28,29,"و چون موسى آن مدت را به پايان رسانيد و همسرش را [همراه‌] برد، آتشى را از دور در كنار طور مشاهده كرد، به خانواده خود گفت: «[اينجا] بمانيد، كه من آتشى از دور ديدم، شايد خبرى از آن يا شعله‌اى آتش برايتان بياورم، باشد كه خود را گرم كنيد.»"
  28,30,"پس چون به آن [آتش‌] رسيد، از جانب راست وادى، در آن جايگاه مبارك، از آن درخت ندا آمد كه: «اى موسى، منم، من، خداوند، پروردگار جهانيان.»"
  28,31,"و [فرمود:] «عصاى خود را بيفكن.» پس چون ديد آن مِثْل مارى مى‌جنبد، پشت كرد و برنگشت. «اى موسى، پيش آى و مترس كه تو در امانى.»"
  28,32,"«دست خود را به گريبانت ببر تا سپيد بى‌گزند بيرون بيايد، و [براى رهايى ] از اين هراس بازويت را به خويشتن بچسبان. اين دو [نشانه‌] دو برهان از جانب پروردگار تو است [كه بايد] به سوى فرعون و سران [كشور] او [ببرى‌]، زيرا آنان همواره قومى نافرمانند.»"
  28,33,"گفت: «پروردگارا، من كسى از ايشان را كشته‌ام، مى‌ترسم مرا بكشند"
  28,34,و برادرم هارون از من زبان‌آورتر است، پس او را با من به دستيارى گسيل دار تا مرا تصديق كند، زيرا مى‌ترسم مرا تكذيب كنند.»
  28,35,"فرمود: «به زودى بازويت را به [وسيله‌] برادرت نيرومند خواهيم كرد و براى شما هر دو، تسلطى قرار خواهيم داد كه با [وجود] آيات ما، به شما دست نخواهند يافت شما و هر كه شما را پيروى كند چيره خواهيد بود.»"
  28,36,"پس چون موسى آيات روشن ما را براى آنان آورد، گفتند: «اين جز سحرى ساختگى نيست و از پدران پيشين خود چنين [چيزى‌] نشنيده‌ايم.»"
  28,37,"و موسى گفت: «پروردگارم به [حال‌] كسى كه از جانب او رهنمودى آورده و [نيز] كسى كه فرجام [نيكوىِ‌] آن سرا براى اوست، داناتر است. در حقيقت، ظالمان رستگار نمى‌شوند.»"
  28,38,"و فرعون گفت: «اى بزرگان قوم، من جز خويشتن براى شما خدايى نمى‌شناسم. پس اى هامان؛ برايم بر گل آتش بيفروز و برجى [بلند] براى من بساز، شايد به [حال‌] خداى موسى اطّلاع يابم، و من جداً او را از دروغگويان مى‌پندارم.»"
  28,39,و او و سپاهيانش در آن سرزمين به ناحق سركشى كردند و پنداشتند كه به سوى ما بازگردانيده نمى‌شوند
  28,40,تا او و سپاهيانش را فرو گرفتيم و آنان را در دريا افكنديم، بنگر كه فرجام كار ستمكاران چگونه بود
  28,41,و آنان را پيشوايانى كه به سوى آتش مى‌خوانند گردانيديم، و روز رستاخيز يارى نخواهند شد
  28,42,"و در اين دنيا لعنتى بدرقه [نام‌] آنان كرديم و روز قيامت [نيز] ايشان از [جمله‌] زشت‌رويانند"
  28,43,"و به راستى، پس از آنكه نسلهاى نخستين را هلاك كرديم، به موسى كتاب داديم كه [دربردارنده‌] روشنگرى‌ها و رهنمود و رحمتى براى مردم بود، اميد كه آنان پند گيرند"
  28,44,"و چون امر [پيامبرى‌] را به موسى واگذاشتيم، تو در جانب غربى [طور] نبودى و از گواهان [نيز] نبودى"
  28,45,"ليكن ما نسلهايى پديد آورديم و عمرشان طولانى شد. و تو در ميان ساكنان [شهر] مَدْين مقيم نبودى تا آيات ما را بر ايشان بخوانى، ليكن ما بوديم كه فرستنده [پيامبران‌] بوديم"
  28,46,"و آندم كه [موسى را] ندا درداديم، تو در جانب طور نبودى، ولى [اين اطّلاع تو] رحمتى است از پروردگار تو، تا قومى را كه هيچ هشداردهنده‌اى پيش از تو برايشان نيامده است بيم دهى، باشد كه آنان پندپذيرند"
  28,47,"و اگر نبود كه وقتى به [سزاى‌] پيش‌فرست دستهايشان مصيبتى به ايشان برسد، بگويند: «پروردگارا، چرا فرستاده‌اى به سوى ما نفرستادى تا از احكام تو پيروى كنيم و از مؤمنان باشيم» [قطعاً در كيفر آنان شتاب مى‌كرديم‌]"
  28,48,"پس چون حق از جانب ما برايشان آمد، گفتند: «چرا نظير آنچه به موسى داده شد، به او داده نشده است؟» آيا به آنچه قبلاً به موسى داده شد كفر نورزيدند؟ گفتند: «دو ساحر با هم ساخته‌اند.» و گفتند: «ما همه را منكريم.»"
  28,49,"بگو: «پس اگر راست مى‌گوييد، كتابى از جانب خدا بياوريد كه از اين دو هدايت كننده‌تر باشد تا پيرويش كنم.»"
  28,50,پس اگر تو را اجابت نكردند، بدان كه فقط هوسهاى خود را پيروى مى‌كنند؛ و كيست گمراه‌تر از آنكه بى‌راهنمايى خدا از هوسش پيروى كند؟ بى‌ترديد خدا مردم ستمگر را راهنمايى نمى‌كند
  28,51,و به راستى، اين گفتار را براى آنان پى در پى و به هم پيوسته نازل ساختيم، اميد كه آنان پند پذيرند
  28,52,"كسانى كه قبل از آن، كتاب [آسمانى‌] به ايشان داده‌ايم، آنان به [قرآن‌] مى‌گروند"
  28,53,"و چون بر ايشان فرو خوانده مى‌شود، مى‌گويند: «بدان ايمان آورديم كه آن درست است [و] از طرف پروردگار ماست؛ ما پيش از آن [هم‌] از تسليم‌شوندگان بوديم.»"
  28,54,"آنانند كه به [پاس‌] آنكه صبر كردند و [براى آنكه‌] بدى را با نيكى دفع مى‌نمايند و از آنچه روزى‌شان داده‌ايم انفاق مى‌كنند، دو بار پاداش خواهند يافت"
  28,55,"و چون لغوى بشنوند از آن روى برمى‌تابند و مى‌گويند: «كردارهاى ما از آنِ ما و كردارهاى شما از آنِ شماست، سلام بر شما، جوياى [مصاحبت‌] نادانان نيستيم.»"
  28,56,در حقيقت، تو هر كه را دوست دارى نمى‌توانى راهنمايى كنى، ليكن خداست كه هر كه را بخواهد راهنمايى مى‌كند، و او به راه‌يافتگان داناتر است
  28,57,"و گفتند: «اگر با تو از [نورِ] هدايت پيروى كنيم، از سرزمين خود ربوده خواهيم شد.» آيا آنان را در حرمى امن جاى نداديم كه محصولات هر چيزى -كه رزقى از جانب ماست- به سوى آن سرازير مى‌شود؟ ولى بيشترشان نمى‌دانند"
  28,58,"و چه بسيار شهرها كه هلاكش كرديم، [زيرا] زندگى خوش، آنها را سرمست كرده بود. اين است سراهايشان كه پس از آنان -جز براى عدّه كمى- مورد سكونت قرار نگرفته، و ماييم كه وارث آنان بوديم"
  28,59,"و پروردگار تو [هرگز] ويرانگر شهرها نبوده است تا [پيشتر] در مركز آنها پيامبرى برانگيزد كه آيات ما را بر ايشان بخواند، و ما شهرها را -تا مردمشان ستمگر نباشند- ويران‌كننده نبوده‌ايم"
  28,60,"و هر آنچه به شما داده شده است، كالاى زندگى دنيا و زيور آن است، و[لى‌] آنچه پيش خداست بهتر و پايدارتر است؛ مگر نمى‌انديشيد؟"
  28,61,"آيا كسى كه وعده نيكو به او داده‌ايم و او به آن خواهد رسيد، مانند كسى است كه از كالاى زندگى دنيا بهره‌مندش گردانيده‌ايم [ولى‌] او روز قيامت از [جمله‌] احضارشدگان [در آتش‌] است؟"
  28,62,"و [به ياد آور] روزى را كه آنان را ندا مى‌دهد و مى‌فرمايد: «آن شريكان من، كه مى‌پنداشتيد كجايند؟»"
  28,63,"آنان كه حكم [عذاب‌] بر ايشان واجب آمده، مى‌گويند: «پروردگارا، اينانند كسانى كه گمراه كرديم، گمراهشان كرديم همچنانكه خود گمراه شديم، [از آنان‌] به سوى تو بيزارى مى‌جوييم، ما را نمى‌پرستيدند [بلكه پندار خود را دنبال مى‌كردند].»"
  28,64,"و [به آنان‌] گفته مى‌شود: «شريكان خود را فرا خوانيد.» [پس آنها را مى‌خوانند] ولى پاسخشان نمى‌دهند و عذاب را مى‌بينند [و آرزو مى‌كنند كه‌] اى كاش هدايت‌يافته بودند"
  28,65,"و روزى را كه [خدا] آنان را ندا درمى‌دهد و مى‌فرمايد: «فرستادگان [ما] را چه پاسخ داديد؟»"
  28,66,پس در آن روز اخبار بر ايشان پوشيده گردد و از يكديگر نمى‌توانند بپرسند
  28,67,و امّا كسى كه توبه كند و ايمان آورد و به كار شايسته پردازد، اميد كه از رستگاران باشد
  28,68,"و پروردگار تو هر چه را بخواهد مى‌آفريند و برمى‌گزيند، و آنان اختيارى ندارند. منزه است خدا، و از آنچه [با او] شريك مى‌گردانند برتر است"
  28,69,و آنچه را سينه‌هايشان پوشيده يا آشكار مى‌دارد، پروردگارت مى‌داند
  28,70,"و اوست خدا[يى كه‌] جز او معبودى نيست. در اين [سراى‌] نخستين و در آخرت، ستايش از آنِ اوست، و فرمان، او راست و به سوى او بازگردانيده مى‌شويد"
  28,71,"بگو: «هان، چه مى‌پنداريد اگر خدا تا روز رستاخيز شب را بر شما جاويد بدارد؛ جز خداوند كدامين معبود براى شما روشنى مى‌آورد؟ آيا نمى‌شنويد؟»"
  28,72,"بگو: «هان، چه مى‌پنداريد اگر خدا تا روز قيامت روز را بر شما جاويد بدارد؛ جز خداوند كدامين معبود براى شما شبى مى‌آورد كه در آن آرام گيريد، آيا نمى‌بينيد؟»"
  28,73,"و از رحمتش برايتان شب و روز را قرار داد تا در اين [يك‌] بياراميد و [در آن يك‌] از فزون‌بخشى او [روزى خود] بجوييد، باشد كه سپاس بداريد"
  28,74,"و [ياد كن‌] روزى را كه ندايشان مى‌كند و مى‌فرمايد: «آن شريكان كه مى‌پنداشتيد كجايند؟»"
  28,75,"و از ميان هر امتى گواهى بيرون مى‌كشيم و مى‌گوييم: «برهان خود را بياوريد.» پس بدانند كه حقّ از آنِ خداست، و آنچه برمى‌بافتند از دستشان مى‌رود"
  28,76,"قارون از قوم موسى بود و بر آنان ستم كرد، و از گنجينه‌ها آن قدر به او داده بوديم كه كليدهاى آنها بر گروه نيرومندى سنگين مى‌آمد، آنگاه كه قوم وى بدو گفتند: «شادى مكن كه خدا شادى‌كنندگان را دوست نمى‌دارد"
  28,77,و با آنچه خدايت داده سراى آخرت را بجوى و سهم خود را از دنيا فراموش مكن، و همچنانكه خدا به تو نيكى كرده نيكى كن و در زمين فساد مجوى كه خدا فسادگران را دوست نمى‌دارد
  28,78,"[قارون‌] گفت: «من اينها را در نتيجه دانش خود يافته‌ام.» آيا وى ندانست كه خدا نسلهايى را پيش از او نابود كرد كه از او نيرومندتر و مال‌اندوزتر بودند؟ و[لى اين گونه‌] مجرمان را [نيازى‌] به پرسيده شدن از گناهانشان نيست"
  28,79,"پس [قارون‌] با كوكبه خود بر قومش نمايان شد؛ كسانى كه خواستار زندگى دنيا بودند گفتند: «اى كاش مثل آنچه به قارون داده شده به ما [هم‌] داده مى‌شد، واقعاً او بهره بزرگى [از ثروت‌] دارد.»"
  28,80,"و كسانى كه دانش [واقعى‌] يافته بودند، گفتند: «واى بر شما! براى كسى كه گرويده و كار شايسته كرده پاداش خدا بهتر است، و جز شكيبايان آن را نيابند.»"
  28,81,"آنگاه [قارون‌] را با خانه‌اش در زمين فرو برديم، و گروهى نداشت كه در برابر [عذاب‌] خدا او را يارى كنند و [خود نيز] نتوانست از خود دفاع كند"
  28,82,"و همان كسانى كه ديروز آرزو داشتند به جاى او باشند، صبح مى‌گفتند: «واى، مثل اينكه خدا روزى را براى هر كس از بندگانش كه بخواهد گشاده يا تنگ مى‌گرداند، و اگر خدا بر ما منّت ننهاده بود، ما را [هم‌] به زمين فرو برده بود؛ واى، گويى كه كافران رستگار نمى‌گردند.»"
  28,83,"آن سراى آخرت را براى كسانى قرار مى‌دهيم كه در زمين خواستار برترى و فساد نيستند، و فرجام [خوش‌] از آنِ پرهيزگاران است"
  28,84,"هر كس نيكى به ميان آورد، براى او [پاداشى‌] بهتر از آن خواهد بود، و هر كس بدى به ميان آورد، كسانى كه كارهاى بد كرده‌اند جز سزاى آنچه كرده‌اند نخواهند يافت"
  28,85,"در حقيقت، همان كسى كه اين قرآن را بر تو فرض كرد، يقيناً تو را به سوى وعده‌گاه بازمى‌گرداند. بگو: «پروردگارم بهتر مى‌داند چه كس هدايت آورده و چه كس در گمراهى آشكارى است؟»"
  28,86,و تو اميدوار نبودى كه بر تو كتاب القا شود، بلكه اين رحمتى از پروردگار تو بود. پس تو هرگز پشتيبان كافران مباش
  28,87,و البته نبايد تو را از آيات خدا -بعد از آنكه بر تو نازل شده است- باز دارند، و به سوى پروردگارت دعوت كن، و زنهار از مشركان مباش
  28,88,و با خدا معبودى ديگر مخوان. خدايى جز او نيست. جز ذات او همه چيز نابودشونده است. فرمان از آنِ اوست. و به سوى او بازگردانيده مى‌شويد
  29,1,الف، لام، ميم
  29,2,آيا مردم پنداشتند كه تا گفتند ايمان آورديم، رها مى‌شوند و مورد آزمايش قرار نمى‌گيرند؟
  29,3,"و به يقين، كسانى را كه پيش از اينان بودند آزموديم، تا خدا آنان را كه راست گفته‌اند معلوم دارد و دروغگويان را [نيز] معلوم دارد"
  29,4,آيا كسانى كه كارهاى بد مى‌كنند، مى‌پندارند كه بر ما پيشى خواهند جست؟ چه بد داورى مى‌كنند
  29,5,"كسى كه به ديدار خدا اميد دارد [بداند كه‌] اَجَل [او از سوى‌] خدا آمدنى است، و اوست شنواى دانا"
  29,6,و هر كه بكوشد، تنها براى خود مى‌كوشد، زيرا خدا از جهانيان سخت بى‌نياز است
  29,7,و كسانى كه ايمان آورده، و كارهاى شايسته كرده‌اند، قطعاً گناهانشان را از آنان مى زداييم، و بهتر از آنچه مى‌كردند پاداششان مى‌دهيم
  29,8,"و به انسان سفارش كرديم كه به پدر و مادر خود نيكى كند، و[لى‌] اگر آنها با تو دركوشند تا چيزى را كه بدان علم ندارى با من شريك گردانى، از ايشان اطاعت مكن. سرانجامتان به سوى من است، و شما را از [حقيقت‌] آنچه انجام مى‌داديد باخبر خواهم كرد"
  29,9,و كسانى كه گرويده و كارهاى شايسته كرده‌اند، البتّه آنان را در زمره شايستگان درمى‌آوريم
  29,10,"و از ميان مردم كسانى‌اند كه مى‌گويند: «به خدا ايمان آورده‌ايم» و چون در [راه‌] خدا آزار كشند، آزمايش مردم را مانند عذاب خدا قرار مى‌دهند؛ و اگر از جانب پروردگارت پيروزى رسد حتماً خواهند گفت: «ما با شما بوديم.» آيا خدا به آنچه در دلهاى جهانيان است داناتر نيست؟"
  29,11,"و قطعاً خدا كسانى را كه ايمان آورده‌اند مى‌شناسد، و يقيناً منافقان را [نيز] مى‌شناسد"
  29,12,"و كسانى كه كافر شده‌اند، به كسانى كه ايمان آورده‌اند مى‌گويند: «راه ما را پيروى كنيد و گناهانتان به گردن ما.» و[لى‌] چيزى از گناهانشان را به گردن نخواهند گرفت؛ قطعاً آنان دروغگويانند"
  29,13,"و قطعاً بارهاى گران خودشان و بارهاى گران [ديگر] را با بارهاى گران خود برخواهند گرفت، و مسلّماً روز قيامت از آنچه به دروغ برمى‌بستند پرسيده خواهند شد"
  29,14,و به راستى، نوح را به سوى قومش فرستاديم، پس در ميان آنان نهصد و پنجاه سال درنگ كرد، تا طوفان آنها را در حالى كه ستمكار بودند فرا گرفت
  29,15,"و او را با كشتى‌نشينان برهانيديم و آن [سفينه‌] را براى جهانيان عبرتى گردانيديم"
  29,16,"و [ياد كن‌] ابراهيم را چون به قوم خويش گفت: «خدا را بپرستيد و از او پروا بداريد؛ اگر بدانيد اين [كار] براى شما بهتر است.»"
  29,17,"واقعاً آنچه را كه شما سواى خدا مى‌پرستيد جز بتانى [بيش‌] نيستند و دروغى برمى‌سازيد. در حقيقت، كسانى را كه جز خدا مى‌پرستيد اختيار روزى شما را در دست ندارند. پس روزى را پيش خدا بجوييد و او را بپرستيد و وى را سپاس گوييد، كه به سوى او بازگردانيده مى‌شويد"
  29,18,"و اگر تكذيب كنيد، قطعاً امّتهاى پيش از شما [هم‌] تكذيب كردند، و بر پيامبر [خدا] جز ابلاغ آشكار [وظيفه‌اى‌] نيست"
  29,19,"آيا نديده‌اند كه خدا چگونه آفرينش را آغاز مى‌كند سپس آن را باز مى‌گرداند؟ در حقيقت، اين [كار] بر خدا آسان است"
  29,20,"بگو: «در زمين بگرديد و بنگريد چگونه آفرينش را آغاز كرده است سپس [باز ] خداست كه نشأه آخرت را پديد مى‌آورد؛ خداست كه بر هر چيزى تواناست.»"
  29,21,هر كه را بخواهد عذاب و هر كه را بخواهد رحمت مى‌كند و به سوى او بازگردانيده مى شويد
  29,22,"و شما نه در زمين و نه در آسمان درمانده‌كننده [او] نيستيد، و جز خدا براى شما يار و ياورى نيست"
  29,23,و كسانى كه آيات خدا و لقاى او را منكر شدند، آنانند كه از رحمت من نوميدند و ايشان را عذابى پر درد خواهد بود
  29,24,"و پاسخ قومش جز اين نبود كه گفتند: «بكشيدش يا بسوزانيدش.» ولى خدا او را از آتش نجات بخشيد. آرى، در اين [نجات بخشى خدا] براى مردمى كه ايمان دارند قطعاً دلايلى است"
  29,25,"و [ابراهيم‌] گفت: «جز خدا، فقط بتهايى را اختيار كرده‌ايد كه آن هم براى دوستى ميان شما در زندگى دنياست، آنگاه روز قيامت بعضى از شما بعضى ديگر را انكار و برخى از شما برخى ديگر را لعنت مى‌كنند و جايتان در آتش است و براى شما ياورانى نخواهد بود.»"
  29,26,"پس لوط به او ايمان آورد و [ابراهيم‌] گفت: «من به سوى پروردگار خود روى مى آورم، كه اوست ارجمند حكيم.»"
  29,27,"و اسحاق و يعقوب را به او عطا كرديم و در ميان فرزندانش پيامبرى و كتاب قرار داديم و در دنيا پاداشش را به او بخشيديم و قطعاً او در آخرت [نيز] از شايستگان خواهد بود"
  29,28,"و [ياد كن‌] لوط را هنگامى كه به قوم خود گفت: «شما به كارى زشت مى‌پردازيد كه هيچ يك از مردم زمين در آن [كار] بر شما پيشى نگرفته است"
  29,29,"آيا شما با مردها درمى‌آميزيد و راه [توالد و تناسل‌] را قطع مى‌كنيد و در محافل [اُنس‌] خود پليدكارى مى‌كنيد؟» و[لى‌] پاسخ قومش جز اين نبود كه گفتند: «اگر راست مى گويى عذاب خدا را براى ما بياور.»"
  29,30,"[لوط] گفت: «پروردگارا، مرا بر قوم فسادكار غالب گردان.»"
  29,31,"و چون فرستادگان ما براى ابراهيم مژده آوردند، گفتند: «ما اهل اين شهر را هلاك خواهيم كرد، زيرا مردمش ستمكار بوده‌اند.»"
  29,32,"گفت: «لوط [نيز] در آنجاست.» گفتند: «ما بهتر مى‌دانيم چه كسانى در آنجا هستند؛ او و كسانش را -جز زنش كه از باقى ماندگان [در خاكستر آتش‌] است- حتماً نجات خواهيم داد.»"
  29,33,"و هنگامى كه فرستادگان ما به سوى لوط آمدند، به علت [حضور] ايشان ناراحت شد و دستش از [حمايت‌] آنها كوتاه گرديد. گفتند: «مترس و غم مدار كه ما تو و خانواده‌ات را -جز زنت كه از باقى‌ماندگان [در خاكستر آتش‌] است- حتماً مى رهانيم"
  29,34,"ما بر مردم اين شهر به [سزاى‌] فسقى كه مى‌كردند، عذابى از آسمان فرو خواهيم فرستاد"
  29,35,"و از آن [شهر سوخته‌] براى مردمى كه مى‌انديشند نشانه‌اى روشن باقى گذاشتيم"
  29,36,"و به سوى [مردم‌] مَدْيَن، برادرشان شعيب را [فرستاديم‌]. گفت: «اى قوم من، خدا را بپرستيد و به روز بازپسين اميد داشته باشيد و در زمين سر به فساد برمداريد.»"
  29,37,پس او را دروغگو خواندند و زلزله آنان را فرو گرفت و بامدادان در خانه‌هايشان از پا درآمدند
  29,38,"و عاد و ثمود را [نيز هلاك نموديم‌]. قطعاً [فرجام آنان‌] از سراهايشان بر شما آشكار گرديده است، و شيطان كارهايشان را در نظرشان بياراست و از راه بازشان داشت با آنكه [در كار دنيا] بينا بودند"
  29,39,"و قارون و فرعون و هامان را [هم هلاك كرديم‌]. و به راستى موسى براى آنان دلايل آشكار آورد، و[لى آنها] در آن سرزمين سركشى نمودند و [با اين همه بر ما] پيشى نجستند"
  29,40,"و هر يك [از ايشان‌] را به گناهش گرفتار [عذاب‌] كرديم: از آنان كسانى بودند كه بر [سر] ايشان بادى همراه با شن فرو فرستاديم؛ و از آنان كسانى بودند كه فرياد [مرگبار] آنها را فرو گرفت؛ و برخى از آنان را در زمين فرو برديم؛ و بعضى را غرق كرديم؛ و [اين‌] خدا نبود كه بر ايشان ستم كرد بلكه خودشان بر خود ستم مى‌كردند"
  29,41,"داستان كسانى كه غير از خدا دوستانى اختيار كرده‌اند، همچون عنكبوت است كه [با آب دهان خود] خانه‌اى براى خويش ساخته، و در حقيقت -اگر مى‌دانستند- سست‌ترين خانه‌ها همان خانه عنكبوت است"
  29,42,خدا مى‌داند هر آنچه را كه جز او مى‌خوانند، و هم اوست شكست‌ناپذير سنجيده‌كار
  29,43,"و اين مَثَلها را براى مردم مى‌زنيم و[لى‌] جز دانشوران آنها را درنيابند"
  29,44,"خداوند آسمانها و زمين را به حق آفريد. قطعاً در اين [آفرينش‌] براى مؤمنان عبرتى است"
  29,45,آنچه از كتاب به سوى تو وحى شده است بخوان، و نماز را برپا دار، كه نماز از كار زشت و ناپسند باز مى‌دارد، و قطعاً ياد خدا بالاتر است، و خدا مى‌داند چه مى‌كنيد
  29,46,"و با اهل كتاب، جز به [شيوه‌اى‌] كه بهتر است، مجادله مكنيد -مگر [با] كسانى از آنان كه ستم كرده‌اند- و بگوييد: «به آنچه به سوى ما نازل شده و [آنچه‌] به سوى شما نازل گرديده، ايمان آورديم؛ و خداى ما و خداى شما يكى است و ما تسليم اوييم.»"
  29,47,"و همچنين ما قرآن را بر تو نازل كرديم. پس آنان كه بديشان كتاب داده‌ايم بدان ايمان مى‌آورند، و از ميان اينان كسانى‌اند كه به آن مى‌گروند، و جز كافران [كسى‌] آيات ما را انكار نمى‌كند"
  29,48,"و تو هيچ كتابى را پيش از اين نمى‌خواندى و با دست [راست‌] خود [كتابى‌] نمى‌نوشتى، و گر نه باطل‌انديشان قطعاً به شك مى‌افتادند"
  29,49,"بلكه [قرآن‌] آياتى روشن در سينه‌هاى كسانى است كه علم [الهى‌] يافته‌اند، و جز ستمگران منكر آيات ما نمى‌شوند"
  29,50,"و گفتند: «چرا بر او از جانب پروردگارش نشانه‌هايى [معجزه‌آسا] نازل نشده است؟» بگو: «آن نشانه‌ها پيش خداست، و من تنها هشداردهنده‌اى آشكارم.»"
  29,51,"آيا براى ايشان بس نيست كه اين كتاب را كه بر آنان خوانده مى‌شود بر تو فرو فرستاديم؟ در حقيقت، در اين [كار] براى مردمى كه ايمان دارند، رحمت و يادآورى است"
  29,52,"بگو: «كافى است خدا ميان من و شما شاهد باشد. آنچه را كه در آسمانها و زمين است مى‌داند، و آنان كه به باطل گرويده و خدا را انكار كرده‌اند همان زيانكارانند.»"
  29,53,"و از تو به شتاب درخواست عذاب [الهى را] دارند، و اگر سرآمدى معين نبود، قطعاً عذاب به آنان مى‌رسيد و بى‌آنكه خبردار شوند غافلگيرشان مى‌كرد"
  29,54,و شتابزده از تو عذاب مى‌خواهند، و حال آنكه جهنم قطعاً بر كافران احاطه دارد
  29,55,"آن روز كه عذاب از بالاى [سر] آنها و از زير پاهايشان آنها را فرو گيرد، و [خدا] مى‌فرمايد: « [نتيجه‌] آنچه را مى‌كرديد بچشيد.»"
  29,56,«اى بندگان من كه ايمان آورده‌ايد، زمين من فراخ است؛ تنها مرا بپرستيد.»
  29,57,هر نفسى چشنده مرگ است، آنگاه به سوى ما بازگردانيده خواهيد شد
  29,58,و كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، قطعاً آنان را در غرفه‌هايى از بهشت جاى مى‌دهيم كه از زير آنها جويها روان است، جاودان در آنجا خواهند بود؛ چه نيكوست پاداش عمل‌كنندگان
  29,59,همان كسانى كه شكيبايى ورزيده و بر پروردگارشان توكل نموده‌اند
  29,60,و چه بسيار جاندارانى كه نمى‌توانند متحمّل روزى خود شوند. خداست كه آنها و شما را روزى مى‌دهد، و اوست شنواى دانا
  29,61,"و اگر از ايشان بپرسى: «چه كسى آسمانها و زمين را آفريده و خورشيد و ماه را [چنين‌] رام كرده است؟» حتماً خواهند گفت: «الله»؛ پس چگونه [از حق‌] بازگردانيده مى‌شوند؟"
  29,62,"خدا بر هر كس از بندگانش كه بخواهد روزى را گشاده مى‌گرداند و [يا] بر او تنگ مى‌سازد، زيرا خدا به هر چيزى داناست"
  29,63,"و اگر از آنان بپرسى: «چه كسى از آسمان، آبى فرو فرستاده و زمين را پس از مرگش به وسيله آن زنده گردانيده است؟» حتماً خواهند گفت: «الله.» بگو: «ستايش از آنِ خداست با اين همه، بيشترشان نمى‌انديشند"
  29,64,"اين زندگى دنيا جز سرگرمى و بازيچه نيست، و زندگى حقيقى همانا [در] سراى آخرت است؛ اى كاش مى‌دانستند"
  29,65,"و هنگامى كه بر كشتى سوار مى‌شوند، خدا را پاكدلانه مى‌خوانند، و[لى‌] چون به سوى خشكى رساند و نجاتشان داد، بناگاه شرك مى‌ورزند"
  29,66,بگذار تا به آنچه بِديشان داده‌ايم انكار آورند و بگذار تا برخوردار شوند، زودا كه بدانند
  29,67,"آيا نديده‌اند كه ما [براى آنان‌] حرمى امن قرار داديم و حال آنكه مردم از حوالى آنان ربوده مى‌شوند؟ آيا به باطل ايمان مى‌آورند و به نعمت خدا كفر مى‌ورزند؟"
  29,68,"و كيست ستمكارتر از آن كس كه بر خدا دروغ بندد يا چون حق به سوى او آيد آن را تكذيب كند؟ آيا جاى كافران [در] جهنم نيست؟"
  29,69,و كسانى كه در راه ما كوشيده‌اند، به يقين راه‌هاى خود را بر آنان مى‌نماييم و در حقيقت، خدا با نيكوكاران است
  30,1,الف، لام، ميم
  30,2,روميان شكست خوردند،
  30,3,"در نزديكترين سرزمين، و[لى‌] بعد از شكستشان، در ظرف چند سالى، به زودى پيروز خواهند گرديد"
  30,4,"[فرجام‌] كار در گذشته و آينده از آن خداست، و در آن روز است كه مؤمنان از يارى خدا شاد مى‌گردند"
  30,5,هر كه را بخواهد يارى مى‌كند، و اوست شكست‌ناپذير مهربان
  30,6,وعده خداست. خدا وعده‌اش را خلاف نمى‌كند، ولى بيشتر مردم نمى‌دانند
  30,7,از زندگى دنيا، ظاهرى را مى‌شناسند، و حال آنكه از آخرت غافلند
  30,8,"آيا در خودشان به تفكر نپرداخته‌اند؟ خداوند آسمانها و زمين و آنچه را كه ميان آن دو است، جز به حق و تا هنگامى معين، نيافريده است، و [با اين همه‌] بسيارى از مردم لقاى پروردگارشان را سخت منكرند"
  30,9,آيا در زمين نگرديده‌اند تا ببينند فرجام كسانى كه پيش از آنان بودند، چگونه بوده است؟ آنها بس نيرومندتر از ايشان بودند، و زمين را زير و رو كردند و بيش از آنچه آنها آبادش كردند آن را آباد ساختند، و پيامبرانشان دلايل آشكار برايشان آوردند. بنابراين خدا بر آن نبود كه بر ايشان ستم كند، ليكن خودشان بر خود ستم مى‌كردند
  30,10,"آنگاه فرجام كسانى كه بدى كردند [بسى‌] بدتر بود، [چرا] كه آيات خدا را تكذيب كردند و آنها را به ريشخند مى‌گرفتند"
  30,11,خداست كه آفرينش را آغاز و سپس آن را تجديد مى‌كند، آنگاه به سوى او بازگردانيده مى‌شويد
  30,12,و روزى كه قيامت برپا شود مجرمان نوميد مى‌گردند
  30,13,و براى آنان از شريكانشان شفيعانى نيست، و خود منكر شريكان خود مى‌شوند
  30,14,"و روزى كه رستاخيز برپا گردد، آن روز [مردم‌] پراكنده مى‌شوند"
  30,15,اما كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، در گلستانى، شادمان مى‌گردند
  30,16,و اما كسانى كه كافر شده و آيات ما و ديدار آخرت را به دروغ گرفته‌اند، پس آنان در عذاب حاضر آيند
  30,17,پس خدا را تسبيح گوييد آنگاه كه به عصر درمى‌آييد و آنگاه كه به بامداد درمى‌شويد
  30,18,و ستايش از آنِ اوست در آسمانها و زمين و شامگاهان و وقتى كه به نيمروز مى‌رسيد
  30,19,"زنده را از مرده بيرون مى‌آورد، و مرده را از زنده بيرون مى‌آورد، و زمين را بعد از مرگش زنده مى‌سازد؛ و بدين گونه [از گورها] بيرون آورده مى‌شويد"
  30,20,"و از نشانه‌هاى او اين است كه شما را از خاك آفريد؛ پس بناگاه شما [به صورت‌] بشرى هر سو پراكنده شديد"
  30,21,"و از نشانه‌هاى او اينكه از [نوع‌] خودتان همسرانى براى شما آفريد تا بدانها آرام گيريد، و ميانتان دوستى و رحمت نهاد. آرى، در اين [نعمت‌] براى مردمى كه مى‌انديشند قطعاً نشانه‌هايى است"
  30,22,"و از نشانه‌هاى [قدرت‌] او آفرينش آسمانها و زمين و اختلاف زبانهاى شما و رنگهاى شماست. قطعاً در اين [امر نيز] براى دانشوران نشانه‌هايى است"
  30,23,"و از نشانه‌هاى [حكمت‌] او خواب شما در شب و [نيم‌] روز و جستجوى شما [روزى خود را] از فزون‌بخشى اوست. در اين [معنى نيز] براى مردمى كه مى‌شنوند، قطعاً نشانه‌هايى است"
  30,24,"و از نشانه‌هاى او [اينكه‌] برق را براى شما بيم‌آور و اميدبخش مى‌نماياند، و از آسمان به تدريج آبى فرو مى‌فرستد، كه به وسيله آن، زمين را پس از مرگش زنده مى‌گرداند. در اين [امر هم‌] براى مردمى كه تعقل مى‌كنند، قطعاً نشانه‌هايى است"
  30,25,"و از نشانه‌هاى او اين است كه آسمان و زمين به فرمانش برپايند؛ پس چون شما را با يك بار خواندن فرا خوانَد، بناگاه [از گورها] خارج مى‌شويد"
  30,26,و هر كه در آسمانها و زمين است از آنِ اوست؛ همه او را گردن نهاده‌اند
  30,27,"و اوست آن كس كه آفرينش را آغاز مى‌كند و باز آن را تجديد مى‌نمايد؛ و اين [كار] بر او آسانتر است. و در آسمانها و زمين نمونه والا[ى هر صفت برتر] از آن اوست، و اوست شكست‌ناپذير سنجيده‌كار"
  30,28,"[خداوند] براى شما از خودتان مَثَلى زده است: آيا در آنچه به شما روزى داده‌ايم شريكانى از بردگانتان داريد كه در آن [مال با هم‌] مساوى باشيد و همان طور كه شما از يكديگر بيم داريد از آنها بيم داشته باشيد؟ اين گونه، آيات خود را براى مردمى كه مى‌انديشند، به تفصيل بيان مى‌كنيم"
  30,29,"نه، [اين چنين نيست‌] بلكه كسانى كه ستم كرده‌اند، بدون هيچ گونه دانشى هوسهاى خود را پيروى كرده‌اند. پس آن كس را كه خدا گمراه كرده، چه كسى هدايت مى‌كند؟ و براى آنان ياورانى نخواهد بود"
  30,30,پس روى خود را با گرايش تمام به حق، به سوى اين دين كن، با همان سرشتى كه خدا مردم را بر آن سرشته است. آفرينش خداى تغييرپذير نيست. اين است همان دين پايدار، ولى بيشتر مردم نمى‌دانند
  30,31,به سويش توبه بريد و از او پروا بداريد و نماز را برپا كنيد و از مشركان مباشيد
  30,32,از كسانى كه دين خود را قطعه قطعه كردند و فرقه فرقه شدند؛ هر حزبى بدانچه پيش آنهاست دلخوش شدند
  30,33,و چون مردم را زيانى رسد، پروردگار خود را، در حالى كه به درگاه او توبه مى‌كنند، مى‌خوانند، و آنگاه كه از جانب خود رحمتى به آنان چشانيد، بناگاه دسته‌اى از ايشان به پروردگارشان شرك مى‌آورند
  30,34,"بگذار تا به آنچه بدانها عطا كرده‌ايم كفران ورزند. [بگو:] برخوردار شويد، زودا كه خواهيد دانست"
  30,35,"يا [مگر] حجّتى بر آنان نازل كرده‌ايم كه آن [حجّت‌] در باره آنچه با [خدا] شريك مى‌گردانيده‌اند سخن مى‌گويد؟"
  30,36,"و چون مردم را رحمتى بچشانيم، بدان شاد مى‌گردند؛ و چون به [سزاى‌] آنچه دستاورد گذشته آنان است، صدمه‌اى به ايشان برسد، بناگاه نوميد مى‌شوند"
  30,37,"آيا ندانسته‌اند كه [اين‌] خداست كه روزى را براى هر كس كه بخواهد فراخ يا تنگ مى‌گرداند؟ قطعاً در اين [امر] براى مردمى كه ايمان مى‌آورند عبرتهاست"
  30,38,"پس حق خويشاوند و تنگدست و در راه‌مانده را بده. اين [انفاق‌] براى كسانى كه خواهان خشنودى خدايند بهتر است، و اينان همان رستگارانند"
  30,39,"و آنچه [به قصد] ربا مى‌دهيد تا در اموال مردم سود و افزايش بردارد، نزد خدا فزونى نمى‌گيرد؛ و[لى‌] آنچه را از زكات -در حالى كه خشنودى خدا را خواستاريد- داديد، پس آنان همان فزونى‌يافتگانند [و مضاعف مى‌شود]"
  30,40,"خدا همان كسى است كه شما را آفريد، سپس به شما روزى بخشيد، آنگاه شما را مى‌ميراند و پس از آن زنده مى‌گرداند. آيا در ميان شريكان شما كسى هست كه كارى از اين [قبيل‌] كند؟ منزه است او، و برتر است از آنچه [با وى‌] شريك مى‌گردانند"
  30,41,"به سبب آنچه دستهاى مردم فراهم آورده، فساد در خشكى و دريا نمودار شده است، تا [سزاى‌] بعضى از آنچه را كه كرده‌اند به آنان بچشاند، باشد كه بازگردند"
  30,42,"بگو: «در زمين بگرديد و بنگريد فرجام كسانى كه پيشتر بوده [و] بيشترشان مشرك بودند چگونه بوده است.»"
  30,43,"پس به سوى اين دين پايدار روى بياور، پيش از آنكه روزى از جانب خدا فرا رسد كه برگشت‌ناپذير باشد، و در آن روز [مردم‌] دسته دسته مى‌شوند"
  30,44,"هر كه كفر ورزد، كفرش به زيان اوست، و كسانى كه كار شايسته كنند، [فرجام نيك را] به سود خودشان آماده مى‌كنند"
  30,45,"تا [خدا] كسانى را كه ايمان آورده و كارهاى شايسته كرده‌اند، به فضل خويش پاداش دهد، كه او كافران را دوست نمى‌دارد"
  30,46,"و از نشانه‌هاى او اين است كه بادهاى بشارت‌آور را مى‌فرستد، تا بخشى از رحمتش را به شما بچشاند و تا كشتى به فرمانش روان گردد، و تا از فضل او [روزى‌] بجوييد، و اميد كه سپاسگزارى كنيد"
  30,47,و در حقيقت، پيش از تو فرستادگانى به سوى قومشان گسيل داشتيم، پس دلايل آشكار برايشان آوردند، و از كسانى كه مرتكب جرم شدند انتقام گرفتيم، و يارى‌كردن مؤمنان بر ما فرض است
  30,48,خدا همان كسى است كه بادها را مى‌فرستد و ابرى برمى‌انگيزد و آن را در آسمان -هر گونه بخواهد- مى‌گستراند و انبوهش مى‌گرداند، پس مى‌بينى باران از لابلاى آن بيرون مى‌آيد. و چون آن را به هر كس از بندگانش كه بخواهد، رسانيد، بناگاه آنان شادمانى مى‌كنند
  30,49,"و قطعاً پيش از آنكه بر ايشان فرو ريزد، [آرى،] پيش از آن سخت نوميد بودند"
  30,50,پس به آثار رحمت خدا بنگر كه چگونه زمين را پس از مرگش زنده مى‌گرداند. در حقيقت، هم اوست كه قطعاً زنده‌كننده مردگان است، و اوست كه بر هر چيزى تواناست
  30,51,"و اگر بادى [آفت‌زا] بفرستيم و [كِشت خود را] زردشده ببينند، قطعاً پس از آن كفران مى‌كنند"
  30,52,و در حقيقت، تو مردگان را شنوا نمى‌گردانى، و اين دعوت را به كران -آنگاه كه به ادبار پشت مى‌گردانند- نمى‌توانى بشنوانى
  30,53,و تو كوران را از گمراهى‌شان به راه نمى‌آورى. تو تنها كسانى را مى‌شنوانى كه به آيات ما ايمان مى‌آورند و خود تسليمند
  30,54,خداست آن كس كه شما را ابتدا ناتوان آفريد، آنگاه پس از ناتوانى قوّت بخشيد، سپس بعد از قوّت، ناتوانى و پيرى داد. هر چه بخواهد مى‌آفريند و هموست داناى توانا
  30,55,"و روزى كه رستاخيز بر پا شود، مجرمان سوگند ياد مى‌كنند كه جز ساعتى [بيش‌] درنگ نكرده‌اند؛ [در دنيا هم‌] اين گونه به دروغ كشانيده مى‌شدند"
  30,56,"و[لى‌] كسانى كه دانش و ايمان يافته‌اند، مى‌گويند: «قطعاً شما [به موجب آنچه‌] در كتاب خدا[ست‌] تا روز رستاخيز مانده‌ايد، و اين، روز رستاخيز است ولى شما خودتان نمى‌دانستيد.»"
  30,57,"و در چنين روزى، [ديگر] پوزش آنان كه ستم كرده‌اند سود نمى‌بخشد، و بازگشت به سوى حق از آنان خواسته نمى‌شود"
  30,58,"و به راستى در اين قرآن براى مردم از هر گونه مَثَلى آورديم، و چون براى ايشان آيه‌اى بياورى، آنان كه كفر ورزيده‌اند حتماً خواهند گفت: «شما جز بر باطل نيستيد.»"
  30,59,اين گونه، خدا بر دلهاى كسانى كه نمى‌دانند مُهر مى‌نهد
  30,60,پس صبر كن كه وعده خدا حق است، و زنهار تا كسانى كه يقين ندارند، تو را به سبكسرى واندارند
  31,1,الف، لام، ميم
  31,2,اين است آيات كتاب حكمت‌آموز،
  31,3,"[كه‌] براى نيكوكاران رهنمود و رحمتى است،"
  31,4,"[همان‌] كسانى كه نماز برپا مى‌دارند و زكات مى‌دهند، و [هم‌] ايشانند كه به آخرت يقين دارند"
  31,5,آنانند كه از جانب پروردگارشان از هدايت برخوردارند، و ايشانند كه رستگارانند
  31,6,"و برخى از مردم كسانى‌اند كه سخن بيهوده را خريدارند تا [مردم را] بى‌[هيچ‌] دانشى از راه خدا گمراه كنند، و [راه خدا] را به ريشخند گيرند؛ براى آنان عذابى خواركننده خواهد بود"
  31,7,"و چون آيات ما بر او خوانده شود، با نِخوت روى برمى‌گرداند، چنانكه گويى آن را نشنيده [يا] گويى در گوشهايش سنگينى است؛ پس او را از عذابى پر درد خبر ده"
  31,8,در حقيقت، كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، باغهاى پر نعمت خواهند داشت،
  31,9,كه در آن جاودان مى‌مانند؛ وعده خداست كه حق است و هموست شكست‌ناپذير سنجيده‌كار
  31,10,"آسمانها را بى‌هيچ ستونى كه آن را ببينيد خلق كرد و در زمين كوههاى استوار بيفكند تا [مبادا زمين‌] شما را بجنباند، و در آن از هر گونه جنبنده‌اى پراكنده گردانيد، و از آسمان آبى فرو فرستاديم و از هر نوع [گياه‌] نيكو در آن رويانيديم"
  31,11,"اين، خلق خداست. [اينك‌] به من نشان دهيد كسانى كه غير از اويند چه آفريده‌اند؟ [هيچ!] بلكه ستمگران در گمراهى آشكارند"
  31,12,"و به راستى، لقمان را حكمت داديم كه: خدا را سپاس بگزار و هر كه سپاس بگزارد، تنها براى خود سپاس مى‌گزارد؛ و هر كس كفران كند، در حقيقت، خدا بى‌نياز ستوده است"
  31,13,"و [ياد كن‌] هنگامى را كه لقمان به پسر خويش -در حالى كه وى او را اندرز مى‌داد- گفت: «اى پسرك من، به خدا شرك مياور كه به راستى شرك ستمى بزرگ است.»"
  31,14,"و انسان را در باره پدر و مادرش سفارش كرديم؛ مادرش به او باردار شد، سستى بر روى سستى. و از شير باز گرفتنش در دو سال است. [آرى، به او سفارش كرديم‌] كه شكرگزارِ من و پدر و مادرت باش كه بازگشت [همه‌] به سوى من است"
  31,15,"و اگر تو را وادارند تا در باره چيزى كه تو را بدان دانشى نيست به من شرك ورزى، از آنان فرمان مبر، و[لى‌] در دنيا به خوبى با آنان معاشرت كن، و راه كسى را پيروى كن كه توبه‌كنان به سوى من بازمى‌گردد؛ و [سرانجام‌] بازگشت شما به سوى من است، و از [حقيقت‌] آنچه انجام مى‌داديد شما را با خبر خواهم كرد"
  31,16,"«اى پسرك من، اگر [عمل تو] هموزن دانه خَردلى و در تخته‌سنگى يا در آسمانها يا در زمين باشد، خدا آن را مى‌آورد، كه خدا بس دقيق و آگاه است"
  31,17,"اى پسرك من، نماز را برپا دار و به كار پسنديده وادار و از كار ناپسند باز دار، و بر آسيبى كه بر تو وارد آمده است شكيبا باش. اين [حاكى‌] از عزم [و اراده تو در] امور است"
  31,18,"و از مردم [به نِخوت‌] رُخ برمتاب، و در زمين خرامان راه مرو كه خدا خودپسند لافزن را دوست نمى‌دارد"
  31,19,و در راه‌رفتن خود ميانه‌رو باش، و صدايت را آهسته‌ساز، كه بدترين آوازها بانگ خران است
  31,20,"آيا ندانسته‌ايد كه خدا آنچه را كه در آسمانها و آنچه را كه در زمين است، مسخّر شما ساخته و نعمتهاى ظاهر و باطن خود را بر شما تمام كرده است؟ و برخى از مردم در باره خدا بى‌[آنكه‌] دانش و رهنمود و كتابى روشن [داشته باشند] به مجادله برمى‌خيزند"
  31,21,"و چون به آنان گفته شود: «آنچه را كه خدا نازل كرده پيروى كنيد»، مى‌گويند: «[نه!] بلكه آنچه كه پدرانمان را بر آن يافته‌ايم پيروى مى‌كنيم»؛ آيا هر چند شيطان آنان را به سوى عذاب سوزان فرا خواند؟"
  31,22,و هر كس خود را -در حالى كه نيكوكار باشد- تسليم خدا كند، قطعاً در ريسمان استوارترى چنگ درزده، و فرجام كارها به سوى خداست
  31,23,"و هر كس كفر ورزد، نبايد كفر او تو را غمگين گرداند. بازگشتشان به سوى ماست، و به [حقيقت‌] آنچه كرده‌اند آگاهشان خواهيم كرد. در حقيقت، خدا به راز دلها داناست"
  31,24,"[ما] آنان را اندكى برخوردار مى‌سازيم، سپس ايشان را در عذابى پر فشار درمانده مى‌كنيم"
  31,25,"و اگر از آنها بپرسى: «چه كسى آسمانها و زمين را آفريده است؟ مسلماً خواهند گفت: «خدا.» بگو: «ستايش از آنِ خداست» ولى بيشترشان نمى‌دانند"
  31,26,"آنچه در آسمانها و زمين است از آنِ خداست، در حقيقت، خدا همان بى‌نياز ستوده‌[صفات‌] است"
  31,27,و اگر آن چه درخت در زمين است قلم باشد و دريا را هفت درياى ديگر به يارى آيد، سخنان خدا پايان نپذيرد. قطعاً خداست كه شكست‌ناپذير حكيم است
  31,28,"آفرينش و برانگيختن شما [در نزد ما] جز مانند [آفرينش‌] يك تن نيست، كه خدا شنواى بيناست"
  31,29,"آيا نديده‌اى كه خدا شب را در روز درمى‌آورد، و روز را [نيز] در شب درمى‌آورد، و آفتاب و ماه را تسخير كرده است [كه‌] هر يك تا وقت معلومى روانند و [نيز] خدا به آنچه مى‌كنيد آگاه است؟"
  31,30,"اين‌[ها همه‌] دليل آن است كه خدا خود حق است و غير از او هر چه را كه مى‌خوانند باطل است، و خدا همان بلندمرتبه بزرگ است"
  31,31,"آيا نديده‌اى كه كشتيها به نعمت خدا در دريا روان مى‌گردند تا برخى از نشانه‌هاى [قدرت‌] خود را به شما بنماياند؟ قطعاً در اين [قدرت نمايى،] براى هر شكيباى سپاسگزارى، نشانه‌هاست"
  31,32,"و چون موجى كوه‌آسا آنان را فرا گيرد، خدا را بخوانند و اعتقاد [خود] را براى او خالص گردانند، و[لى‌] چون نجاتشان داد و به خشكى رساند برخى از آنان ميانه‌رو هستند، و نشانه‌هاى ما را جز هر خائن ناسپاسگزارى انكار نمى‌كند"
  31,33,"اى مردم، از پروردگارتان پروا بداريد، و بترسيد از روزى كه هيچ پدرى به كار فرزندش نمى‌آيد، و هيچ فرزندى [نيز] به كار پدرش نخواهد آمد. آرى، وعده خدا حق است. زنهار تا اين زندگى دنيا شما را نفريبد، و زنهار تا شيطان شما را مغرور نسازد"
  31,34,"در حقيقت، خداست كه علم [به‌] قيامت نزد اوست، و باران را فرو مى‌فرستد، و آنچه را كه در رحمهاست مى‌داند و كسى نمى‌داند فردا چه به دست مى‌آورد، و كسى نمى‌داند در كدامين سرزمين مى‌ميرد. در حقيقت، خداست [كه‌] داناى آگاه است"
  32,1,الف، لام، ميم
  32,2,"نازل شدن اين كتاب -كه هيچ [جاى‌] شك در آن نيست- از طرف پروردگار جهانهاست"
  32,3,"آيا مى‌گويند: «آن را بربافته است»؟ [نه چنين است‌] بلكه آن حقّ و از جانب پروردگار توست، تا مردمى را كه پيش از تو بيم‌دهنده‌اى براى آنان نيامده است هشدار دهى، اميد كه راه يابند"
  32,4,"خدا كسى است كه آسمانها و زمين و آنچه را كه ميان آن دو است، در شش هنگام آفريد، آنگاه بر عرش [قدرت‌] استيلا يافت، براى شما غير از او سرپرست و شفاعتگرى نيست؛ آيا باز هم پند نمى‌گيريد؟"
  32,5,"كار [جهان‌] را از آسمان [گرفته‌] تا زمين، اداره مى‌كند؛ آنگاه [نتيجه و گزارش آن‌] در روزى كه مقدارش -آن چنان كه شما [آدميان‌] برمى‌شماريد- هزار سال است، به سوى او بالا مى‌رود"
  32,6,اوست داناى نهان و آشكار، كه شكوهمند مهربان است
  32,7,همان كسى كه هر چيزى را كه آفريده است نيكو آفريده، و آفرينش انسان را از گِل آغاز كرد؛
  32,8,"سپس [تداوم‌] نسل او را از چكيده آبى پست مقرر فرمود؛"
  32,9,آنگاه او را درست‌اندام كرد، و از روح خويش در او دميد، و براى شما گوش و ديدگان و دلها قرار داد؛ چه اندك سپاس مى‌گزاريد
  32,10,"و گفتند: «آيا وقتى در [دلِ‌] زمين گم شديم، آيا [باز] ما در خلقت جديدى خواهيم بود؟» [نه،] بلكه آنها به لقاى پروردگارشان [و حضور او] كافرند"
  32,11,"بگو: «فرشته مرگى كه بر شما گمارده شده، جانتان را مى‌ستاند، آنگاه به سوى پروردگارتان بازگردانيده مى‌شويد.»"
  32,12,"و كاش هنگامى را كه مجرمان پيش پروردگارشان سرهاشان را به زير افكنده‌اند مى‌ديدى [كه مى‌گويند:] «پروردگارا، ديديم و شنيديم؛ ما را بازگردان تا كار شايسته كنيم، چرا كه ما يقين داريم.»"
  32,13,"و اگر مى‌خواستيم، حتماً به هر كسى [از روى جبر] هدايتش را مى‌داديم، ليكن سخن من محقَقَ گرديده كه: «هر آينه جهنم را از همه جنيان و آدميان خواهم آكند.»"
  32,14,"پس به [سزاى‌] آنكه ديدار اين روزتان را از ياد برديد [عذاب را] بچشيد؛ ما [نيز] فراموشتان كرديم، و به [سزاى‌] آنچه انجام مى‌داديد عذاب جاودان را بچشيد"
  32,15,"تنها كسانى به آيات ما مى‌گروند كه چون آن [آيات‌] را به ايشان يادآورى كنند، سجده‌كنان به روى درمى‌افتند، و به ستايش پروردگارشان تسبيح مى‌گويند و آنان بزرگى نمى‌فروشند"
  32,16,"پهلوهايشان از خوابگاهها جدا مى‌گردد [و] پروردگارشان را از روى بيم و طمع مى‌خوانند، و از آنچه روزيشان داده‌ايم انفاق مى‌كنند"
  32,17,"هيچ كس نمى‌داند چه چيز از آنچه روشنى‌بخش ديدگان است به [پاداش‌] آنچه انجام مى‌دادند براى آنان پنهان كرده‌ام"
  32,18,آيا كسى كه مؤمن است، چون كسى است كه نافرمان است؟ يكسان نيستند
  32,19,"اما كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، به [پاداش‌] آنچه انجام مى‌دادند در باغهايى كه در آن جايگزين مى‌شوند، پذيرايى مى‌گردند"
  32,20,"و اما كسانى كه نافرمانى كرده‌اند، پس جايگاهشان آتش است. هر بار كه بخواهند از آن بيرون بيايند، در آن بازگردانيده مى‌شوند و به آنان گفته مى‌شود: «عذاب آن آتشى را كه دروغش مى‌پنداشتيد بچشيد.»"
  32,21,"و قطعاً غير از آن عذاب بزرگتر، از عذاب اين دنيا [نيز] به آنان مى‌چشانيم، اميد كه آنها [به خدا] بازگردند"
  32,22,"و كيست بيدادگرتر از آن كس كه به آيات پروردگارش پند داده شود [و] آنگاه از آن روى بگرداند؟ قطعاً ما از مجرمان انتقام‌كِشنده‌ايم"
  32,23,"و به راستى [ما] به موسى كتاب داديم. پس در لقاى او [با خدا]ترديد مكن، و آن [كتاب‌] را براى فرزندان اسرائيل [مايه‌] هدايت قرار داديم"
  32,24,"و چون شكيبايى كردند و به آيات ما يقين داشتند، برخى از آنان را پيشوايانى قرار داديم كه به فرمان ما [مردم را] هدايت مى‌كردند"
  32,25,در حقيقت، پروردگار تو، خود روز قيامت در آنچه با يكديگر در باره آن اختلاف مى‌كردند، ميانشان داورى خواهد كرد
  32,26,"آيا براى آنان روشن نگرديده كه چه بسيار نسلها را پيش از آنها نابود گردانيديم [كه اينان‌] در سراهايشان راه مى‌روند؟ قطعاً در اين [امر] عبرتهاست، مگر نمى‌شنوند؟"
  32,27,آيا ننگريسته‌اند كه ما باران را به سوى زمين باير مى‌رانيم، و به وسيله آن كِشته‌اى را برمى‌آوريم كه دامهايشان و خودشان از آن مى‌خورند؟ مگر نمى‌بينند؟
  32,28,"و مى‌پرسند: «اگر راست مى‌گوييد، اين پيروزى [شما] چه وقت است؟»"
  32,29,"بگو: «روز پيروزى، ايمان كسانى كه كافر شده‌اند سود نمى‌بخشد و آنان مهلت نمى‌يابند.»"
  32,30,پس، از ايشان روى برتاب و منتظر باش كه آنها نيز در انتظارند
  33,1,اى پيامبر، از خدا پروا بدار و كافران و منافقان را فرمان مبر، كه خدا همواره داناى حكيم است
  33,2,و آنچه را كه از جانب پروردگارت به سوى تو وحى مى‌شود، پيروى كن كه خدا همواره به آنچه مى‌كنيد آگاه است
  33,3,"و بر خدا اعتماد كن، همين بس كه خدا نگهبان [تو]ست"
  33,4,"خداوند براى هيچ مردى در درونش دو دل ننهاده است، و آن همسرانتان را كه مورد «ظهار» قرار مى‌دهيد مادران شما نگردانيده، و پسرخواندگانتان را پسران [واقعى‌] شما قرار نداده است. اين، گفتار شما به زبان شماست، و[لى‌] خدا حقيقت را مى‌گويد، و او[ست كه‌] به راه راست هدايت مى‌كند"
  33,5,"آنان را به [نام‌] پدرانشان بخوانيد، كه اين نزد خدا عادلانه‌تر است، و اگر پدرانشان را نمى‌شناسيد پس برادران دينى و موالى شمايند، و در آنچه اشتباهاً مرتكب آن شده‌ايد بر شما گناهى نيست، ولى در آنچه دلهايتان عمد داشته است [مسؤوليد ]و خداست كه همواره آمرزنده مهربان است"
  33,6,"پيامبر به مؤمنان از خودشان سزاوارتر [و نزديكتر] است و همسرانش مادران ايشانند، و خويشاوندان [طبق‌] كتاب خدا، بعضى [نسبت‌] به بعضى اولويت دارند [و] بر مؤمنان و مهاجران [مقدّمند]، مگر آنكه بخواهيد به دوستان [مؤمن‌] خود [وصيت يا ]احسانى كنيد، و اين در كتاب [خدا] نگاشته شده است"
  33,7,"و [ياد كن‌] هنگامى را كه از پيامبران پيمان گرفتيم، و از تو و از نوح و ابراهيم و موسى و عيسى پسر مريم، و از [همه‌] آنان پيمانى استوار گرفتيم"
  33,8,تا راستان را از صدقشان باز پرسد، و براى كافران عذابى دردناك آماده كرده است
  33,9,"اى كسانى كه ايمان آورده‌ايد، نعمت خدا را بر خود به ياد آريد، آنگاه كه لشكرهايى به سوى شما [در]آمدند، پس بر سر آنان تندبادى و لشكرهايى كه آنها را نمى‌ديديد فرستاديم، و خدا به آنچه مى‌كنيد همواره بيناست"
  33,10,"هنگامى كه از بالاى [سر] شما و از زير [پاى‌] شما آمدند، و آنگاه كه چشمها خيره شد و جانها به گلوگاهها رسيد و به خدا گمانهايى [نابجا] مى‌برديد"
  33,11,"آنجا [بود كه‌] مؤمنان در آزمايش قرار گرفتند و سخت تكان خوردند"
  33,12,"و هنگامى كه منافقان و كسانى كه در دلهايشان بيمارى است مى‌گفتند: «خدا و فرستاده‌اش جز فريب به ما وعده‌اى ندادند.»"
  33,13,"و چون گروهى از آنان گفتند: «اى مردم مدينه، ديگر شما را جاى درنگ نيست، برگرديد.» و گروهى از آنان از پيامبر اجازه مى‌خواستند و مى‌گفتند: «خانه‌هاى ما بى‌حفاظ است» و[لى خانه‌هايشان‌] بى‌حفاظ نبود، [آنان‌] جز گريز [از جهاد] چيزى نمى‌خواستند"
  33,14,"و اگر از اطراف [مدينه‌] مورد هجوم واقع مى‌شدند و آنگاه آنان را به ارتداد مى‌خواندند، قطعاً آن را مى‌پذيرفتند و جز اندكى در اين [كار] درنگ نمى‌كردند؛"
  33,15,"با آنكه قبلاً با خدا سخت پيمان بسته بودند كه پشت [به دشمن‌] نكنند، و پيمان خدا همواره بازخواست دارد"
  33,16,"بگو: «اگر از مرگ يا كشته شدن بگريزيد، هرگز اين گريز براى شما سود نمى‌بخشد، و در آن صورت جز اندكى برخوردار نخواهيد شد.»"
  33,17,"بگو: «چه كسى مى‌تواند در برابر خدا از شما حمايت كند اگر او بخواهد براى شما بد بياورد يا بخواهد شما را رحمت كند؟ و غير از خدا براى خود يار و ياورى نخواهند يافت.»"
  33,18,"خداوند كارشكنان [و مانع‌شوندگان‌] شما و آن كسانى را كه به برادرانشان مى گفتند: «نزد ما بياييد» و جز اندكى روى به جنگ نمى‌آورند [خوب‌] مى‌شناسد"
  33,19,"بر شما بخيلانند، و چون خطر فرا رسد آنان را مى‌بينى كه مانند كسى كه مرگ او را فرو گرفته، چشمانشان در حدقه مى‌چرخد [و] به سوى تو مى‌نگرند؛ و چون ترس برطرف شود شما را با زبانهايى تند نيش مى‌زنند؛ بر مال حريصند. آنان ايمان نياورده‌اند و خدا اعمالشان را تباه گردانيده، و اين [كار] همواره بر خدا آسان است"
  33,20,"اينان [چنين‌] مى‌پندارند كه دسته‌هاى دشمن نرفته‌اند، و اگر دسته‌هاى دشمن بازآيند آرزو مى‌كنند: كاش ميان اعراب باديه‌نشين بودند و از اخبار [مربوط به‌] شما جويا مى‌شدند، و اگر در ميان شما بودند، جز اندكى جنگ نمى‌كردند"
  33,21,"قطعاً براى شما در [اقتدا به‌] رسول خدا سرمشقى نيكوست: براى آن كس كه به خدا و روز بازپسين اميد دارد و خدا را فراوان ياد مى‌كند"
  33,22,"و چون مؤمنان دسته‌هاى دشمن را ديدند، گفتند: «اين همان است كه خدا و فرستاده‌اش به ما وعده دادند و خدا و فرستاده‌اش راست گفتند»، و جز بر ايمان و فرمانبردارى آنان نيفزود"
  33,23,"از ميان مؤمنان مردانى‌اند كه به آنچه با خدا عهد بستند صادقانه وفا كردند. برخى از آنان به شهادت رسيدند و برخى از آنها در [همين‌] انتظارند و [هرگز عقيده خود را] تبديل نكردند"
  33,24,"تا خدا راستگويان را به [پاداش‌] راستى‌شان پاداش دهد، و منافقان را اگر بخواهد، عذاب كند يا بر ايشان ببخشايد كه خدا همواره آمرزنده مهربان است"
  33,25,"و خداوند آنان را كه كفر ورزيده‌اند، بى‌آنكه به مالى رسيده باشند، به غيظ [و حسرت‌] برگرداند، و خدا [زحمت‌] جنگ را از مؤمنان برداشت، و خدا همواره نيرومند شكست‌ناپذير است"
  33,26,"و كسانى از اهل كتاب را كه با [مشركان‌] همپُشتى كرده بودند، از دژهايشان به زير آورد و در دلهايشان هراس افكند: گروهى را مى‌كشتيد و گروهى را اسير مى‌كرديد"
  33,27,و زمينشان و خانه‌ها و اموالشان و سرزمينى را كه در آن پا ننهاده بوديد به شما ميراث داد، و خدا بر هر چيزى تواناست
  33,28,"اى پيامبر، به همسرانت بگو: «اگر خواهان زندگى دنيا و زينت آنيد، بياييد تا مَهرتان را بدهم و [خوش و] خُرّم شما را رها كنم"
  33,29,و اگر خواستار خدا و فرستاده وى و سراى آخرتيد، پس به راستى خدا براى نيكوكاران شما پاداش بزرگى آماده گردانيده است
  33,30,اى همسران پيامبر، هر كس از شما مبادرت به كار زشتِ آشكارى كند، عذابش دو چندان خواهد بود؛ و اين بر خدا همواره آسان است
  33,31,و هر كس از شما خدا و فرستاده‌اش را فرمان بَرَد و كار شايسته كند، پاداشش را دو چندان مى‌دهيم و برايش روزىِ نيكو فراهم خواهيم ساخت
  33,32,"اى همسران پيامبر، شما مانند هيچ يك از زنان [ديگر] نيستيد، اگر سر پروا داريد پس به ناز سخن مگوييد تا آنكه در دلش بيمارى است طمع ورزد؛ و گفتارى شايسته گوييد"
  33,33,"و در خانه‌هايتان قرار گيريد و مانند روزگار جاهليت قديم زينتهاى خود را آشكار مكنيد و نماز برپا داريد و زكات بدهيد و خدا و فرستاده‌اش را فرمان بريد. خدا فقط مى‌خواهد آلودگى را از شما خاندان [پيامبر ]بزدايد و شما را پاك و پاكيزه گرداند"
  33,34,"و آنچه را كه از آيات خدا و [سخنان‌] حكمت‌[آميز] در خانه‌هاى شما خوانده مى‌شود ياد كنيد. در حقيقت، خدا همواره دقيق و آگاه است"
  33,35,"مردان و زنان مسلمان، و مردان و زنان با ايمان، و مردان و زنان عبادت‌پيشه، و مردان و زنان راستگو، و مردان و زنان شكيبا، و مردان و زنان فروتن، و مردان و زنان صدقه‌دهنده، و مردان و زنان روزه‌دار، و مردان و زنان پاكدامن، و مردان و زنانى كه خدا را فراوان ياد مى‌كنند، خدا براى [همه‌] آنان آمرزشى و پاداشى بزرگ فراهم ساخته است"
  33,36,و هيچ مرد و زن مؤمنى را نرسد كه چون خدا و فرستاده‌اش به كارى فرمان دهند، براى آنان در كارشان اختيارى باشد؛ و هر كس خدا و فرستاده‌اش را نافرمانى كند قطعاً دچار گمراهى آشكارى گرديده است
  33,37,"و آنگاه كه به كسى كه خدا بر او نعمت ارزانى داشته بود و تو [نيز] به او نعمت داده بودى، مى‌گفتى: «همسرت را پيش خود نگاه دار و از خدا پروا بدار» و آنچه را كه خدا آشكاركننده آن بود، در دل خود نهان مى‌كردى و از مردم مى‌ترسيدى، با آنكه خدا سزاوارتر بود كه از او بترسى. پس چون زيد از آن [زن‌] كام برگرفت [و او را ترك گفت‌] وى را به نكاح تو درآورديم تا [در آينده‌] در مورد ازدواج مؤمنان با زنان پسرخواندگانشان -چون آنان را طلاق گفتند- گناهى نباشد، و فرمان خدا صورت اجرا پذيرد"
  33,38,"بر پيامبر در آنچه خدا براى او فرض گردانيده گناهى نيست. [اين‌] سنّت خداست كه از ديرباز در ميان گذشتگان [معمول‌] بوده، و فرمان خدا همواره به اندازه مقرر [و متناسب با توانايى‌] است"
  33,39,همان كسانى كه پيامهاى خدا را ابلاغ مى‌كنند و از او مى‌ترسند و از هيچ كس جز خدا بيم ندارند. و خدا براى حسابرسى كفايت مى‌كند
  33,40,محمّد پدر هيچ يك از مردان شما نيست، ولى فرستاده خدا و خاتم پيامبران است. و خدا همواره بر هر چيزى داناست
  33,41,اى كسانى كه ايمان آورده‌ايد، خدا را ياد كنيد، يادى بسيار
  33,42,و صبح و شام او را به پاكى بستاييد
  33,43,اوست كسى كه با فرشتگان خود بر شما درود مى‌فرستد تا شما را از تاريكيها به سوى روشنايى برآورد، و به مؤمنان همواره مهربان است
  33,44,درودشان -روزى كه ديدارش كنند- سلام خواهد بود، و براى آنان پاداشى نيكو آماده كرده است
  33,45,"اى پيامبر، ما تو را [به سِمَت‌] گواه و بشارتگر و هشداردهنده فرستاديم،"
  33,46,و دعوت‌كننده به سوى خدا به فرمان او، و چراغى تابناك
  33,47,و مؤمنان را مژده دِه كه براى آنان از جانب خدا بخشايشى فراوان خواهد بود
  33,48,"و كافران و منافقان را فرمان مبر، و از آزارشان بگذر و بر خدا اعتماد كن و كارسازى [چون‌] خدا كفايت مى‌كند"
  33,49,اى كسانى كه ايمان آورده‌ايد، اگر زنان مؤمن را به نكاح خود درآورديد، آنگاه پيش از آنكه با آنان همخوابگى كنيد، طلاقشان داديد، ديگر بر عهده آنها عده‌اى كه آن را بشماريد، نيست؛ پس مَهْرشان را بدهيد و خوش و خرّم آنها را رها كنيد
  33,50,"اى پيامبر، ما براى تو آن همسرانى را كه مَهْرشان را داده‌اى حلال كرديم، و [كنيزانى‌] را كه خدا از غنيمت جنگى در اختيار تو قرار داده، و دختران عمويت و دختران عمه‌هايت و دختران دايى تو و دختران خاله‌هايت كه با تو مهاجرت كرده‌اند، و زن مؤمنى كه خود را [داوطلبانه‌] به پيامبر ببخشد-در صورتى كه پيامبر بخواهد او را به زنى گيرد. [اين ازدواج از روى بخشش‌] ويژه توست نه ديگر مؤمنان. ما نيك مى‌دانيم كه در مورد زنان و كنيزانشان چه بر آنان مقرر كرده‌ايم، تا براى تو مشكلى پيش نيايد، و خدا همواره آمرزنده مهربان است"
  33,51,"نوبت هر كدام از آن زنها را كه مى‌خواهى به تأخير انداز و هر كدام را كه مى‌خواهى پيش خود جاى ده، و بر تو باكى نيست كه هر كدام را كه ترك كرده‌اى [دوباره‌] طلب كنى. اين نزديكتر است براى اينكه چشمانشان روشن گردد و دلتنگ نشوند و همگى‌شان به آنچه به آنان داده‌اى خشنود گردند، و آنچه در دلهاى شماست خدا مى‌داند، و خدا همواره داناى بردبار است"
  33,52,"از اين پس، ديگر [گرفتن‌] زنان و نيز اينكه به جاى آنان، زنان ديگرى بر تو حلال نيست، هر چند زيبايى آنها براى تو مورد پسند افتد، به استثناى كنيزان، و خدا همواره بر هر چيزى مراقب است"
  33,53,"اى كسانى كه ايمان آورده‌ايد، داخل اتاقهاى پيامبر مشويد، مگر آنكه براى [خوردن‌] طعامى به شما اجازه داده شود، [آن هم‌] بى‌آنكه در انتظار پخته‌شدن آن باشيد؛ ولى هنگامى كه دعوت شديد داخل گرديد، و وقتى غذا خورديد پراكنده شويد بى‌آنكه سرگرم سخنى گرديد. اين [رفتار] شما پيامبر را مى‌رنجاند و[لى‌] از شما شرم مى‌دارد، و حال آنكه خدا از حق‌[گويى‌] شرم نمى‌كند، و چون از زنان [پيامبر] چيزى خواستيد از پشت پرده از آنان بخواهيد؛ اين براى دلهاى شما و دلهاى آنان پاكيزه‌تر است، و شما حق نداريد رسول خدا را برنجانيد، و مطلقاً [نبايد] زنانش را پس از [مرگ‌] او به نكاح خود درآوريد، چرا كه اين [كار] نزد خدا همواره [گناهى‌] بزرگ است"
  33,54,اگر چيزى را فاش كنيد يا آن را پنهان داريد قطعاً خدا به هر چيزى داناست
  33,55,"بر زنان در مورد پدران و پسران و برادران و پسران برادران و پسران خواهران و زنان [همكيش‌] و بردگانشان گناهى نيست [كه ديده شوند]؛ و بايد از خدا پروا بداريد كه خدا همواره بر هر چيزى گواه است"
  33,56,خدا و فرشتگانش بر پيامبر درود مى‌فرستند. اى كسانى كه ايمان آورده‌ايد، بر او درود فرستيد و به فرمانش بخوبى گردن نهيد
  33,57,بى‌گمان، كسانى كه خدا و پيامبر او را آزار مى‌رسانند، خدا آنان را در دنيا و آخرت لعنت كرده و برايشان عذابى خفت‌آور آماده ساخته است
  33,58,"و كسانى كه مردان و زنان مؤمن را بى‌آنكه مرتكب [عمل زشتى‌] شده باشند آزار مى‌رسانند، قطعاً تهمت و گناهى آشكار به گردن گرفته‌اند"
  33,59,"اى پيامبر، به زنان و دخترانت و به زنان مؤمنان بگو: «پوششهاى خود را بر خود فروتر گيرند. اين براى آنكه شناخته شوند و مورد آزار قرار نگيرند [به احتياط] نزديكتر است، و خدا آمرزنده مهربان است"
  33,60,"اگر منافقان و كسانى كه در دلهايشان مرضى هست و شايعه‌افكنان در مدينه، [از كارشان‌] باز نايستند، تو را سخت بر آنان مسلط مى‌كنيم تا جز [مدتى‌] اندك در همسايگى تو نپايند"
  33,61,از رحمت خدا دور گرديده و هر كجا يافته شوند گرفته و سخت كشته خواهند شد
  33,62,"در باره كسانى كه پيشتر بوده‌اند [همين‌] سنّت خدا [جارى بوده‌] است؛ و در سنّت خدا هرگز تغييرى نخواهى يافت"
  33,63,"مردم از تو در باره رستاخيز مى‌پرسند؛ بگو: «علم آن فقط نزد خداست.» و چه مى دانى؟ شايد رستاخيز نزديك باشد"
  33,64,خدا كافران را لعنت كرده و براى آنها آتش فروزانى آماده كرده است
  33,65,جاودانه در آن مى‌مانند، نه يارى مى‌يابند و نه ياورى
  33,66,"روزى كه چهره‌هايشان را در آتش زيرورو مى‌كنند، مى‌گويند: «اى كاش ما خدا را فرمان مى‌برديم و پيامبر را اطاعت مى‌كرديم.»"
  33,67,"و مى‌گويند: «پروردگارا، ما رؤسا و بزرگتران خويش را اطاعت كرديم و ما را از راه به در كردند.»"
  33,68,«پروردگارا، آنان را دو چندان عذاب ده و لعنتشان كن لعنتى بزرگ.»
  33,69,"اى كسانى كه ايمان آورده‌ايد، مانند كسانى مباشيد كه موسى را [با اتهام خود] آزار دادند، و خدا او را از آنچه گفتند مبرّا ساخت و نزد خدا آبرومند بود"
  33,70,اى كسانى كه ايمان آورده‌ايد، از خدا پروا داريد و سخنى استوار گوييد
  33,71,تا اعمال شما را به صلاح آورد و گناهانتان را بر شما ببخشايد، و هر كس خدا و پيامبرش را فرمان برد قطعاً به رستگارى بزرگى نايل آمده است
  33,72,"ما امانت [الهى و بار تكليف‌] را بر آسمانها و زمين و كوهها عرضه كرديم، پس، از برداشتن آن سر باز زدند و از آن هراسناك شدند، و[لى‌] انسان آن را برداشت؛ راستى او ستمگرى نادان بود"
  33,73,"[آرى، چنين است‌] تا خدا مردان و زنان منافق، و مردان و زنان مشرك را عذاب كند و توبه مردان و زنان با ايمان را بپذيرد، و خدا همواره آمرزنده مهربان است"
  34,1,"سپاس خدايى را كه آنچه در آسمانها و آنچه در زمين است از آنِ اوست، و در آخرت [نيز] سپاس از آنِ اوست، و هم اوست سنجيده‌كار آگاه"
  34,2,"آنچه در زمين فرو مى‌رود و آنچه از آن بر مى‌آيد و آنچه از آسمان فرو مى‌شود و آنچه در آن بالا مى‌رود [همه را] مى‌داند، و اوست مهربان آمرزنده"
  34,3,"و كسانى كه كافر شدند، گفتند: «رستاخيز براى ما نخواهد آمد.» بگو: «چرا، سوگند به پروردگارم كه حتماً براى شما خواهد آمد. [همان‌] داناى نهان‌[ها] كه هموزن ذره‌اى، نه در آسمانها و نه در زمين، از وى پوشيده نيست، و نه كوچكتر از آن و نه بزرگتر از آن است مگر اينكه در كتابى روشن [درج شده‌] است.»"
  34,4,تا كسانى را كه ايمان آورده و كارهاى شايسته كرده‌اند به پاداش رساند؛ آنانند كه آمرزش و روزىِ خوش برايشان خواهد بود
  34,5,"و كسانى كه در [ابطال‌] آيات ما كوشش مى‌ورزند كه ما را درمانده كنند، برايشان عذابى از بلايى دردناك باشد"
  34,6,"و كسانى كه از دانش بهره يافته‌اند، مى‌دانند كه آنچه از جانب پروردگارت به سوى تو نازل شده، حق است و به راه آن عزيز ستوده‌[صفات‌] راهبرى مى‌كند"
  34,7,"و كسانى كه كفر ورزيدند، گفتند: «آيا مردى را به شما نشان دهيم كه شما را خبر مى‌دهد كه چون كاملا متلاشى شديد، [باز] قطعاً در آفرينشى جديد خواهيد بود؟"
  34,8,"آيا [اين مرد] بر خدا دروغى بسته يا جنونى در اوست؟ «[نه!] بلكه آنان كه به آخرت ايمان ندارند در عذاب و گمراهى دور و درازند"
  34,9,"آيا به آنچه -از آسمان و زمين- در دسترسشان و پشت سرشان است ننگريسته‌اند؟ اگر بخواهيم آنان را در زمين فرو مى‌بريم، يا پاره‌سنگهايى از آسمان بر سرشان مى‌افكنيم. قطعاً در اين [تهديد] براى هر بنده توبه‌كارى عبرت است"
  34,10,"و به راستى داوود را از جانب خويش مزيتى عطا كرديم. [و گفتيم:] اى كوهها، با او [در تسبيح خدا] همصدا شويد، و اى پرندگان [هماهنگى كنيد]. و آهن را براى او نرم گردانيديم"
  34,11,"[كه‌] زره‌هاى فراخ بساز و حلقه‌ها را درست اندازه‌گيرى كن. و كار شايسته كنيد، زيرا من به آنچه انجام مى‌دهيد بينايم"
  34,12,"و باد را براى سليمان [رام كرديم:] كه رفتن آن بامداد، يك ماه، و آمدنش شبانگاه، يك ماه [راه‌] بود، و معدن مس را براى او ذوب [و روان‌] گردانيديم، و برخى از جن به فرمان پروردگارشان پيش او كار مى‌كردند، و هر كس از آنها از دستور ما سر برمى‌تافت، از عذاب سوزان به او مى‌چشانيديم"
  34,13,"[آن متخصصان‌] براى او هر چه مى‌خواست: از نمازخانه‌ها و مجسمه‌ها و ظروف بزرگ مانند حوضچه‌ها و ديگهاى چسبيده به زمين مى‌ساختند. اى خاندان داوود، شكرگزار باشيد. و از بندگان من اندكى سپاسگزارند"
  34,14,"پس چون مرگ را بر او مقرر داشتيم، جز جنبنده‌اى خاكى [=موريانه‌] كه عصاى او را [به تدريج‌] مى‌خورد، [آدميان را] از مرگ او آگاه نگردانيد، پس چون [سليمان‌] فرو افتاد براى جنيان روشن گرديد كه اگر غيب مى‌دانستند، در آن عذاب خفت‌آور [باقى‌] نمى‌ماندند"
  34,15,"قطعاً براى [مردم‌] سبا در محل سكونتشان نشانه [رحمتى‌] بود: دو باغستان از راست و چپ [به آنان گفتيم:] از روزى پروردگارتان بخوريد و او را شكر كنيد. شهرى است خوش و خدايى آمرزنده"
  34,16,"پس روى گردانيدند، و بر آن سيل [سدّ] عَرِم را روانه كرديم، و دو باغستان آنها را به دو باغ كه ميوه‌هاى تلخ و شوره‌گز و نوعى از كُنار تنك داشت تبديل كرديم"
  34,17,"اين [عقوبت‌] را به [سزاى‌] آنكه كفران كردند به آنان جزا داديم؛ و آيا جز ناسپاس را به مجازات مى‌رسانيم؟"
  34,18,"و ميان آنان و ميان آبادانيهايى كه در آنها بركت نهاده بوديم شهرهاى متصل به هم قرار داده بوديم، و در ميان آنها مسافت را، به اندازه، مقرر داشته بوديم. در اين [راه‌]ها، شبان و روزان آسوده‌خاطر بگرديد"
  34,19,"تا گفتند: «پروردگارا، ميان [منزلهاى‌] سفرهايمان فاصله انداز.» و بر خويشتن ستم كردند. پس آنها را [براى آيندگان، موضوع‌] حكايتها گردانيديم، و سخت تارومارشان كرديم؛ قطعاً در اين [ماجرا] براى هر شكيباى سپاسگزارى عبرتهاست"
  34,20,"و قطعاً شيطان گمان خود را در مورد آنها راست يافت. و جز گروهى از مؤمنان، [بقيه‌] از او پيروى كردند"
  34,21,"و [شيطان‌] را بر آنان تسلطى نبود، جز آنكه كسى را كه به آخرت ايمان دارد از كسى كه در باره آن در ترديد است باز شناسيم. و پروردگار تو بر هر چيزى نگاهبان است"
  34,22,"بگو: «كسانى را كه جز خدا [معبود خود] پنداشته‌ايد بخوانيد؛ هموزن ذرّه‌اى نه در آسمانها و نه در زمين مالك نيستند، و در آن دو شركتى ندارند، و براى وى از ميان آنان هيچ پشتيبانى نيست.»"
  34,23,"و شفاعتگرى در پيشگاه او سود نمى‌بخشد، مگر براى آن كس كه به وى اجازه دهد. تا چون هراس از دلهايشان برطرف شود، مى‌گويند: «پروردگارتان چه فرمود؟» مى گويند: «حقيقت؛ و هموست بلندمرتبه و بزرگ.»"
  34,24,"بگو: «كيست كه شما را از آسمانها و زمين روزى مى‌دهد؟» بگو: «خدا؛ و در حقيقت يا ما، يا شما بر هدايت يا گمراهى آشكاريم.»"
  34,25,"بگو: «[شما] از آنچه ما مرتكب شده‌ايم بازخواست نخواهيد شد، و [ما نيز] از آنچه شما انجام مى‌دهيد بازخواست نخواهيم شد.»"
  34,26,"بگو: «پروردگارمان ما و شما را جمع خواهد كرد؛ سپس ميان ما به حق داورى مى كند، و اوست داور دانا.»"
  34,27,"بگو: «كسانى را كه [به عنوان‌] شريك به او ملحق گردانيده‌ايد، به من نشان دهيد.» چنين نيست، بلكه اوست خداى عزيز حكيم"
  34,28,"و ما تو را جز [به سمت‌] بشارتگر و هشداردهنده براى تمام مردم، نفرستاديم؛ ليكن بيشتر مردم نمى‌دانند"
  34,29,"و مى‌گويند: «اگر راست مى‌گوييد، اين وعده چه وقت است؟»"
  34,30,"بگو: «ميعاد شما روزى است كه نه ساعتى از آن پس توانيد رفت، و نه پيشى توانيد جُست.»"
  34,31,"و كسانى كه كافر شدند گفتند: «نه به اين قرآن و نه به آن [توراتى‌] كه پيش از آن است هرگز ايمان نخواهيم آورد.» و اى كاش بيدادگران را هنگامى كه در پيشگاه پروردگارشان بازداشت شده‌اند مى‌ديدى [كه چگونه‌] برخى از آنان با برخى [ديگر جدل و] گفتگو مى‌كنند؛ كسانى كه زيردست بودند به كسانى كه [رياست و] برترى داشتند، مى‌گويند: «اگر شما نبوديد قطعاً ما مؤمن بوديم.»"
  34,32,"كسانى كه [رياست و] برترى داشتند، به كسانى كه زيردست بودند، مى‌گويند: «مگر ما بوديم كه شما را از هدايت -پس از آنكه به سوى شما آمد- بازداشتيم؟ [نه،] بلكه خودتان گناهكار بوديد.»"
  34,33,"و كسانى كه زيردست بودند به كسانى كه [رياست و] برترى داشتند، مى‌گويند: «[نه،] بلكه نيرنگ شب و روز [شما بود] آنگاه كه ما را وادار مى‌كرديد كه به خدا كافر شويم و براى او همتايانى قرار دهيم.» و هنگامى كه عذاب را ببينند پشيمانى خود را آشكار كنند. و در گردنهاى كسانى كه كافر شده‌اند غُلها مى‌نهيم؛ آيا جز به سزاى آنچه انجام مى‌دادند مى‌رسند؟"
  34,34,"و [ما] در هيچ شهرى هشداردهنده‌اى نفرستاديم جز آنكه خوشگذرانان آنها گفتند: «ما به آنچه شما بدان فرستاده شده‌ايد كافريم.»"
  34,35,"و گفتند: «ما دارايى و فرزندانمان از همه بيشتر است و ما عذاب نخواهيم شد.»"
  34,36,"بگو: «پروردگار من است كه روزى را براى هر كس كه بخواهد گشاده يا تنگ مى گرداند؛ ليكن بيشتر مردم نمى‌دانند.»"
  34,37,"و اموال و فرزندانتان چيزى نيست كه شما را به پيشگاه ما نزديك گرداند، مگر كسانى كه ايمان آورده و كار شايسته كرده باشند. پس براى آنان دو برابر آنچه انجام داده‌اند پاداش است و آنها در غرفه‌ها[ى بهشتى‌] آسوده خاطر خواهند بود"
  34,38,"و كسانى كه در [ابطال‌] آيات ما مى‌كوشند كه [ما را به خيال خود] درمانده كنند؛ آنانند كه در عذاب احضار مى‌شوند"
  34,39,"بگو: «در حقيقت، پروردگار من است كه روزى را براى هر كس از بندگانش كه بخواهد گشاده يا براى او تنگ مى‌گرداند. و هر چه را انفاق كرديد عوضش را او مى‌دهد. و او بهترين روزى دهندگان است.»"
  34,40,"و [ياد كن‌] روزى را كه همه آنان را محشور مى‌كند، آنگاه به فرشتگان مى‌فرمايد: «آيا اينها بودند كه شما را مى‌پرستيدند؟»"
  34,41,"مى‌گويند: «منزّهى تو، سرپرست ما تويى نه آنها بلكه جنّيان را مى‌پرستيدند؛ بيشترشان به آنها اعتقاد داشتند.»"
  34,42,"اكنون براى يكديگر سود و زيانى نداريد، و به كسانى كه ستم كرده‌اند مى‌گوييم: «بچشيد عذاب آتشى را كه آن را دروغ مى‌شمرديد.»"
  34,43,"و چون آيات تابناك ما بر آنان خوانده مى‌شود مى‌گويند: «اين جز مردى نيست كه مى‌خواهد شما را از آنچه پدرانتان مى‌پرستيدند باز دارد.» و [نيز] مى‌گويند: «اين جز دروغى بربافته نيست.» و كسانى كه به حق -چون به سويشان آمد- كافر شدند مى‌گويند: «اين جز افسونى آشكار نيست.»"
  34,44,و ما كتابهايى به آنان نداده بوديم كه آن را بخوانند، و پيش از تو هشداردهنده‌اى به سويشان نفرستاده بوديم
  34,45,"و كسانى كه پيش از اينان بودند، [نيز] تكذيب كردند، در حالى كه اينان به ده‌يك آنچه بديشان داده بوديم نرسيده‌اند. [آرى،] فرستادگانِ مرا دروغ شمردند؛ پس چگونه بود كيفر من؟"
  34,46,"بگو: «من فقط به شما يك اندرز مى‌دهم كه: دو دو و به تنهايى براى خدا به پا خيزيد، سپس بينديشيد كه رفيق شما هيچ گونه ديوانگى ندارد. او شما را از عذاب سختى كه در پيش است جز هشداردهنده‌اى [بيش‌] نيست"
  34,47,"بگو: «هر مزدى كه از شما خواستم آن از خودتان مزد من جز بر خدا نيست، و او بر هر چيزى گواه است.»"
  34,48,"بگو: «بى‌گمان، پروردگارم حقيقت را القا مى‌كند؛ [اوست‌] داناى نهانها.»"
  34,49,"بگو: «حق آمد و [ديگر] باطل از سر نمى‌گيرد و برنمى‌گردد.»"
  34,50,"بگو: «اگر گمراه شوم، فقط به زيان خود گمراه شده‌ام، و اگر هدايت يابم [اين از بركتِ‌] چيزى است كه پروردگارم به سويم وحى مى‌كند، كه اوست شنواى نزديك.»"
  34,51,"و اى كاش مى‌ديدى هنگامى را كه [كافران‌] وحشت‌زده‌اند [آنجا كه راهِ‌] گريزى نمانده است و از جايى نزديك گرفتار آمده‌اند"
  34,52,"و مى‌گويند: «به او ايمان آورديم.» و چگونه از جايى [چنين‌] دور، دست يافتن [به ايمان‌] براى آنان ميسّر است؟"
  34,53,"و حال آنكه پيش از اين منكر او شدند، و از جايى دور، به ناديده [تير تهمت‌] مى‌افكندند"
  34,54,"و ميان آنان و ميان آنچه [به آرزو] مى‌خواستند حايلى قرار مى‌گيرد؛ همان گونه كه از ديرباز با امثال ايشان چنين رفت، زيرا آنها [نيز] در دودلىِ سختى بودند"
  35,1,"سپاس خداى را كه پديدآورنده آسمان و زمين است [و] فرشتگان را كه داراى بالهاى دوگانه و سه‌گانه و چهارگانه‌اند پيام‌آورنده قرار داده است. در آفرينش، هر چه بخواهد مى‌افزايد، زيرا خدا بر هر چيزى تواناست"
  35,2,"هر رحمتى را كه خدا براى مردم گشايد، بازدارنده‌اى براى آن نيست، و آنچه را كه باز دارد، پس از [باز گرفتن‌] گشاينده‌اى ندارد، و اوست همان شكست‌ناپذير سنجيده‌كار"
  35,3,"اى مردم، نعمت خدا را بر خود ياد كنيد. آيا غير از خدا آفريدگارى است كه شما را از آسمان و زمين روزى دهد؟ خدايى جز او نيست. پس چگونه [از حق‌] انحراف مى‌يابيد؟"
  35,4,"و اگر تو را تكذيب كنند، قطعاً پيش از تو [هم‌] فرستادگانى تكذيب شدند. و [همه‌] كارها به سوى خدا بازگردانيده مى‌شود"
  35,5,"اى مردم، همانا وعده خدا حق است. زنهار تا اين زندگى دنيا شما را فريب ندهد، و زنهار تا [شيطانِ‌] فريبنده شما را در باره خدا نفريبد"
  35,6,"در حقيقت، شيطان دشمن شماست، شما [نيز] او را دشمن گيريد. [او] فقط دار و دسته خود را مى‌خوانَد تا آنها از ياران آتش باشند"
  35,7,كسانى كه كفر ورزيده‌اند، عذابى سخت خواهند داشت. و كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، براى آنان آمرزش و پاداشى بزرگ است
  35,8,"آيا آن كس كه زشتى كردارش براى او آراسته شده و آن را زيبا مى‌بيند [مانند مؤمن نيكوكار است‌]؟ خداست كه هر كه را بخواهد بى‌راه مى‌گذارد و هر كه را بخواهد هدايت مى‌كند. پس مبادا به سبب حسرتها[ى گوناگون‌] بر آنان، جانت [از كف ]برود؛ قطعاً خدا به آنچه مى‌كنند داناست"
  35,9,"و خدا همان كسى است كه بادها را روانه مى‌كند؛ پس [بادها] ابرى را برمى‌انگيزند، و [ما] آن را به سوى سرزمينى مرده رانديم، و آن زمين را بدان [وسيله‌]، پس از مرگش زندگى بخشيديم؛ رستاخيز [نيز ]چنين است"
  35,10,هر كس سربلندى مى‌خواهد، سربلندى يكسره از آنِ خداست. سخنان پاكيزه به سوى او بالا مى‌رود، و كار شايسته به آن رفعت مى‌بخشد. و كسانى كه با حيله و مكر كارهاى بد مى‌كنند، عذابى سخت خواهند داشت، و نيرنگشان خود تباه مى‌گردد
  35,11,"و خدا[ست كه‌] شما را از خاكى آفريد، سپس از نطفه‌اى، آنگاه شما را جفت جفت گردانيد، و هيچ مادينه‌اى بار نمى‌گيرد و بار نمى‌نهد مگر به علم او. و هيچ سالخورده‌اى عمر دراز نمى‌يابد و از عمرش كاسته نمى‌شود، مگر آنكه در كتابى [مندرج ]است. در حقيقت، اين [كار] بر خدا آسان است"
  35,12,"و دو دريا يكسان نيستند: اين يك، شيرين تشنگى‌زدا [و] نوشيدنش گواراست؛ و آن يك، شور تلخ‌مزه است؛ و از هر يك گوشتى تازه مى‌خوريد و زيورى كه آن را بر خود مى‌پوشيد بيرون مى‌آوريد؛ و كشتى را در آن، موج‌شكاف مى‌بينى تا از فضل او [روزى خود را] جستجو كنيد، و اميد كه سپاس بگزاريد"
  35,13,"شب را به روز درمى‌آورد و روز را به شب درمى‌آورد، و آفتاب و ماه را تسخير كرده است [كه‌] هر يك تا هنگامى معين روانند؛ اين است خدا پروردگار شما؛ فرمانروايى از آنِ اوست. و كسانى را كه بجز او مى‌خوانيد، مالك پوست هسته خرمايى [هم ]نيستند"
  35,14,"اگر آنها را بخوانيد، دعاى شما را نمى‌شنوند، و اگر [فرضاً] بشنوند اجابتتان نمى‌كنند، و روز قيامت شركِ شما را انكار مى‌كنند؛ و [هيچ كس‌] چون [خداى‌] آگاه، تو را خبردار نمى‌كند"
  35,15,اى مردم، شما به خدا نيازمنديد، و خداست كه بى‌نياز ستوده است
  35,16,"و اگر بخواهد شما را مى‌بَرد و خلقى نو [بر سر كار] مى‌آورد"
  35,17,"و اين [امر] براى خدا دشوار نيست"
  35,18,"و هيچ باربَردارنده‌اى بار [گناه‌] ديگرى را برنمى‌دارد، و اگر گرانبارى [ديگرى را به يارى‌] به سوى بارش فرا خواند چيزى از آن برداشته نمى‌شود، هر چند خويشاوند باشد. [تو] تنها كسانى را كه از پروردگارشان در نهان مى‌ترسند و نماز برپا مى‌دارند، هشدار مى‌دهى؛ و هر كس پاكيزگى جويد تنها براى خود پاكيزگى مى‌جويد، و فرجام [كارها] به سوى خداست"
  35,19,و نابينا و بينا يكسان نيستند،
  35,20,و نه تيرگيها و روشنايى،
  35,21,و نه سايه و گرماى آفتاب
  35,22,و زندگان و مردگان يكسان نيستند. خداست كه هر كه را بخواهد شنوا مى‌گرداند؛ و تو كسانى را كه در گورهايند نمى‌توانى شنوا سازى
  35,23,"تو جز هشداردهنده‌اى [بيش‌] نيستى"
  35,24,"ما تو را بحق، [به سِمَت‌] بشارتگر و هشداردهنده گسيل داشتيم، و هيچ امتى نبوده مگر اينكه در آن هشداردهنده‌اى گذشته است"
  35,25,"و اگر تو را تكذيب كنند، قطعاً كسانى كه پيش از آنها بودند [نيز] به تكذيب پرداختند. پيامبرانشان دلايل آشكار و نوشته‌ها و كتاب روشن براى آنان آوردند"
  35,26,آنگاه كسانى را كه كافر شده بودند فرو گرفتم؛ پس چگونه بود كيفر من؟
  35,27,"آيا نديده‌اى كه خدا از آسمان، آبى فرود آورد و به [وسيله‌] آن ميوه‌هايى كه رنگهاى آنها گوناگون است بيرون آورديم؟ و از برخى كوهها، راهها [و رگه‌ها]ى سپيد و گلگون به رنگهاى مختلف و سياه پر رنگ [آفريديم‌]"
  35,28,"و از مردمان و جانوران و دامها كه رنگهايشان همان گونه مختلف است [پديد آورديم‌]. از بندگان خدا تنها دانايانند كه از او مى‌ترسند. آرى، خدا ارجمند آمرزنده است"
  35,29,در حقيقت، كسانى كه كتاب خدا را مى‌خوانند و نماز برپا مى‌دارند و از آنچه بديشان روزى داده‌ايم، نهان و آشكارا انفاق مى‌كنند، اميد به تجارتى بسته‌اند كه هرگز زوال نمى‌پذيرد
  35,30,تا پاداششان را تمام بديشان عطا كند و از فزون‌بخشى خود در حق آنان بيفزايد كه او آمرزنده حق‌شناس است
  35,31,"و آنچه از كتاب به سوى تو وحى كرده‌ايم، خود حق [و] تصديق‌كننده [كتابهاى‌] پيش از آن است. قطعاً خدا نسبت به بندگانش آگاه بيناست"
  35,32,"سپس اين كتاب را به آن بندگان خود كه [آنان را] برگزيده بوديم، به ميراث داديم؛ پس برخى از آنان بر خود ستمكارند و برخى از ايشان ميانه‌رو، و برخى از آنان در كارهاى نيك به فرمان خدا پيشگامند؛ و اين خود توفيق بزرگ است"
  35,33,"[در] بهشتهاى هميشگى [كه‌] به آنها درخواهندآمد. در آنجا با دستبندهايى از زر و مرواريد زيور يابند و در آنجا جامه‌شان پَرنيان خواهد بود"
  35,34,"و مى‌گويند: «سپاس خدايى را كه اندوه را از ما بزدود، به راستى پروردگار ما آمرزنده [و] حق‌شناس است؛"
  35,35,"همان [خدايى‌] كه ما را به فضل خويش در سراى ابدى جاى داد. در اينجا رنجى به ما نمى‌رسد و در اينجا درماندگى به ما دست نمى‌دهد"
  35,36,"و[لى‌] كسانى كه كافر شده‌اند، آتش جهنم براى آنان خواهد بود. حكم به مرگ بر ايشان [جارى‌] نمى‌شود تا بميرند، و نه عذاب آن از ايشان كاسته شود. [آرى،] هر ناسپاسى را چنين كيفر مى‌دهيم"
  35,37,"و آنان در آنجا فرياد برمى‌آورند: «پروردگارا، ما را بيرون بياور، تا غير از آنچه مى‌كرديم، كار شايسته كنيم.» مگر شما را [آن قدر] عمر دراز نداديم كه هر كس كه بايد در آن عبرت گيرد، عبرت مى‌گرفت؛ و [آيا ]براى شما هشداردهنده نيامد؟ پس بچشيد كه براى ستمگران ياورى نيست"
  35,38,"خدا[ست كه‌] داناى نهان آسمانها و زمين است، و اوست كه به راز دلها داناست"
  35,39,اوست آن كس كه شما را در اين سرزمين جانشين گردانيد. پس هر كس كفر ورزد كفرش به زيان اوست، و كافران را كفرشان جز دشمنى نزد پروردگارشان نمى‌افزايد، و كافران را كفرشان غير از زيان نمى‌افزايد
  35,40,"بگو: «به من خبر دهيد از شريكان خودتان كه به جاى خدا مى‌خوانيد؛ به من نشان دهيد كه چه چيزى از زمين را آفريده‌اند؟ يا آنان در [كار] آسمانها همكارى داشته‌اند؟ يا به ايشان كتابى داده‌ايم كه دليلى بر [حقّانيّت‌] خود از آن دارند؟» [نه،] بلكه ستمكاران جز فريب به يكديگر وعده نمى‌دهند"
  35,41,همانا خدا آسمانها و زمين را نگاه مى‌دارد تا نيفتند، و اگر بيفتند بعد از او هيچ كس آنها را نگاه نمى‌دارد؛ اوست بردبار آمرزنده
  35,42,"و با سوگندهاى سخت خود به خدا سوگند ياد كردند كه اگر هرآينه هشداردهنده‌اى براى آنان بيايد، قطعاً از هر يك از امتها[ى ديگر] راه‌يافته‌تر شوند، و[لى‌] چون هشداردهنده‌اى براى ايشان آمد، جز بر نفرتشان نيفزود"
  35,43,"[انگيزه‌] اين كارشان فقط گردنكشى در [روى‌] زمين و نيرنگ زشت بود، و نيرنگ زشت جز [دامن‌] صاحبش را نگيرد. پس آيا جز سنّت [و سرنوشت شوم‌] پيشينيان را انتظار مى‌برند؟ و هرگز براى سنّت خدا دگرگونى نخواهى يافت"
  35,44,"آيا در زمين نگرديده‌اند تا فرجام [كار] كسانى را كه پيش از ايشان [زيسته‌] و نيرومندتر از ايشان بودند بنگرند؟ و هيچ چيز، نه در آسمانها و نه در زمين، خدا را درمانده نكرده است، چرا كه او همواره داناى تواناست"
  35,45,"و اگر خدا مردم را به [سزاى‌] آنچه انجام داده‌اند مؤاخذه مى‌كرد، هيچ جنبنده‌اى را بر پشت زمين باقى نمى‌گذاشت؛ ولى تا مدتى معين مهلتشان مى‌دهد، و چون اجلشان فرا رسد خدا به [كار] بندگانش بيناست"
  36,1,"يس‌[/ياسين‌]"
  36,2,سوگند به قرآن حكمت‌آموز،
  36,3,"كه قطعاً تو از [جمله‌] پيامبرانى،"
  36,4,بر راهى راست
  36,5,"[و كتابت‌] از جانب آن عزيز مهربان نازل شده است،"
  36,6,تا قومى را كه پدرانشان بيم‌داده نشدند و در غفلت ماندند، بيم دهى
  36,7,"آرى، گفته [خدا] در باره بيشترشان محقق گرديده است، در نتيجه آنها نخواهند گرويد"
  36,8,ما در گردنهاى آنان، تا چانه‌هايشان، غُلهايى نهاده‌ايم، به طورى كه سرهايشان را بالا نگاه داشته و ديده فرو هشته‌اند
  36,9,"و [ما] فراروى آنها سدى و پشت سرشان سدى نهاده و پرده‌اى بر [چشمان‌] آنان فرو گسترده‌ايم، در نتيجه نمى‌توانند ببينند"
  36,10,"و آنان را چه بيم دهى [و] چه بيم ندهى، به حالشان تفاوت نمى‌كند: نخواهند گرويد"
  36,11,"بيم دادن تو، تنها كسى را [سودمند] است كه كتاب حق را پيروى كند و از [خداى‌] رحمان در نهان بترسد. [چنين كسى را] به آمرزش و پاداشى پر ارزش مژده ده"
  36,12,"آرى! ماييم كه مردگان را زنده مى‌سازيم و آنچه را از پيش فرستاده‌اند، با آثار [و اعمال‌]شان درج مى‌كنيم، و هر چيزى را در كارنامه‌اى روشن برشمرده‌ايم"
  36,13,"[داستان‌] مردم آن شهرى را كه رسولان بدانجا آمدند براى آنان مَثَل زن"
  36,14,"آنگاه كه دو تن سوى آنان فرستاديم، و[لى‌] آن دو را دروغزن پنداشتند، تا با [فرستاده‌] سومين [آنان را] تأييد كرديم، پس [رسولان‌] گفتند: «ما به سوى شما به پيامبرى فرستاده شده‌ايم.»"
  36,15,"[ناباوران آن ديار] گفتند: «شما جز بشرى مانند ما نيستيد، و [خداى‌] رحمان چيزى نفرستاده، و شما جز دروغ نمى‌پردازيد.»"
  36,16,"گفتند: «پروردگار ما مى‌داند كه ما واقعاً به سوى شما به پيامبرى فرستاده شده‌ايم.»"
  36,17,"و بر ما [وظيفه‌اى‌] جز رسانيدن آشكار [پيام‌] نيست"
  36,18,"پاسخ دادند: «ما [حضور] شما را به شگون بد گرفته‌ايم. اگر دست برنداريد، سنگسارتان مى‌كنيم و قطعاً عذاب دردناكى از ما به شما خواهد رسيد.»"
  36,19,"[رسولان‌] گفتند: «شومىِ شما با خود شماست. آيا اگر شما را پند دهند [باز كفر مى‌ورزيد]؟ نه! بلكه شما قومى اسرافكاريد.»"
  36,20,"و [در اين ميان‌] مردى از دورترين جاى شهر دوان دوان آمد، [و] گفت: «اى مردم، از اين فرستادگان پيروى كنيد"
  36,21,"از كسانى كه پاداشى از شما نمى‌خواهند و خود [نيز] بر راه راست قرار دارند، پيروى كنيد"
  36,22,"آخر چرا كسى را نپرستم كه مرا آفريده است و [همه‌] شما به سوى او بازگشت مى‌يابيد؟"
  36,23,"آيا به جاى او خدايانى را بپرستم كه اگر [خداى‌] رحمان بخواهد به من گزندى برساند، نه شفاعتشان به حالم سود مى‌دهد و نه مى‌توانند مرا برهانند؟"
  36,24,در آن صورت، من قطعاً در گمراهى آشكارى خواهم بود
  36,25,"من به پروردگارتان ايمان آوردم. [اقرار] مرا بشنويد.»"
  36,26,"[سرانجام به جرم ايمان كشته شد، و بدو] گفته شد: «به بهشت درآى.» گفت: «اى كاش، قوم من مى‌دانستند،"
  36,27,كه پروردگارم چگونه مرا آمرزيد و در زمره عزيزانم قرار داد.»
  36,28,"پس از [شهادت‌] وى هيچ سپاهى از آسمان بر قومش فرود نياورديم و [پيش از اين هم‌] فروفرستنده نبوديم"
  36,29,"تنها يك فرياد بود و بس. و بناگاه [همه‌] آنها سرد بر جاى فسردند"
  36,30,دريغا بر اين بندگان! هيچ فرستاده‌اى بر آنان نيامد مگر آنكه او را ريشخند مى‌كردند
  36,31,مگر نديده‌اند كه چه بسيار نسلها را پيش از آنان هلاك گردانيديم كه ديگر آنها به سويشان بازنمى‌گردند؟
  36,32,و قطعاً همه آنان در پيشگاه ما احضار خواهند شد
  36,33,و زمين مرده، برهانى است براى ايشان، كه آن را زنده گردانيديم و دانه از آن برآورديم كه از آن مى‌خورند
  36,34,"و در آن [زمين‌] باغهايى از درختان خرما و تاك قرار داديم و چشمه‌ها در آن روان كرديم"
  36,35,"تا از ميوه آن و [از] كاركرد دستهاى خودشان بخورند، آيا باز [هم‌] سپاس نمى‌گزارند؟"
  36,36,"پاك [خدايى‌] كه از آنچه زمين مى‌روياند و [نيز] از خودشان و از آنچه نمى‌دانند، همه را نر و ماده گردانيده است"
  36,37,"و نشانه‌اى [ديگر] براى آنها شب است كه روز را [مانند پوست‌] از آن برمى‌كنيم و بناگاه آنان در تاريكى فرو مى‌روند"
  36,38,"و خورشيد به [سوى‌] قرارگاه ويژه خود روان است. تقدير آن عزيز دانا اين است"
  36,39,و براى ماه منزلهايى معين كرده‌ايم، تا چون شاخك خشك خوشه خرما برگردد
  36,40,نه خورشيد را سزد كه به ماه رسد، و نه شب بر روز پيشى جويد، و هر كدام در سپهرى شناورند
  36,41,"و نشانه‌اى [ديگر] براى آنان اينكه: ما نياكانشان را در كشتى انباشته، سوار كرديم"
  36,42,"و مانند آن براى ايشان مركوبها[ى ديگرى‌] خلق كرديم"
  36,43,و اگر بخواهيم غرقشان مى‌كنيم و هيچ فريادرسى نمى‌يابند و روى نجات نمى‌بينند
  36,44,"مگر رحمتى از جانب ما [شامل آنها گردد] و تا چندى [آنها را] برخوردار سازيم"
  36,45,"و چون به ايشان گفته شود: «از آنچه در پيش رو و پشت سر داريد بترسيد، اميد كه مورد رحمت قرار گيريد» [نمى‌شنوند]"
  36,46,و هيچ نشانه‌اى از نشانه‌هاى پروردگارشان بر آنان نيامد، جز اينكه از آن رويگردان شدند
  36,47,"و چون به آنان گفته شود: «از آنچه خدا به شما روزى داده انفاق كنيد»، كسانى كه كافر شده‌اند، به آنان كه ايمان آورده‌اند، مى‌گويند: «آيا كسى را بخورانيم كه اگر خدا مى‌خواست [خودش‌] وى را مى‌خورانيد؟ شما جز در گمراهىِ آشكارى [بيش‌] نيستيد.»"
  36,48,"و مى‌گويند: «اگر راست مى‌گوييد، پس اين وعده [عذاب‌] كى خواهد بود؟»"
  36,49,"جز يك فرياد [مرگبار] را انتظار نخواهند كشيد كه هنگامى كه سرگرم جدالند غافلگيرشان كند"
  36,50,آنگاه نه توانايى وصيّتى دارند و نه مى‌توانند به سوى كسان خود برگردند
  36,51,و در صور دميده خواهد شد، پس بناگاه از گورهاى خود شتابان به سوى پروردگار خويش مى‌آيند
  36,52,"مى‌گويند: «اى واى بر ما، چه كسى ما را از آرامگاهمان برانگيخت؟ اين است همان وعده خداى رحمان، و پيامبران راست مى‌گفتند.»"
  36,53,"[باز هم‌] يك فرياد است و بس؛ و بناگاه همه در پيشگاه ما حاضر آيند"
  36,54,امروز بر كسى هيچ ستم نمى‌رود، جز در برابر آنچه كرده‌ايد پاداشى نخواهيد يافت
  36,55,در اين روز، اهل بهشت كار و بارى خوش در پيش دارند
  36,56,آنها با همسرانشان در زير سايه‌ها بر تختها تكيه مى‌زنند
  36,57,"در آنجا براى آنها [هر گونه‌] ميوه است و هر چه دلشان بخواهد"
  36,58,"از جانب پروردگار[ى‌] مهربان [به آنان‌] سلام گفته مى‌شود"
  36,59,"و اى گناهكاران، امروز [از بى‌گناهان‌] جدا شويد"
  36,60,اى فرزندان آدم، مگر با شما عهد نكرده بودم كه شيطان را مپرستيد، زيرا وى دشمن آشكار شماست؟
  36,61,و اينكه مرا بپرستيد؛ اين است راه راست
  36,62,"و [او] گروهى انبوه از ميان شما را سخت گمراه كرد؛ آيا تعقل نمى‌كرديد؟"
  36,63,اين است جهنّمى كه به شما وعده داده مى‌شد
  36,64,"به [جرم‌] آنكه كفر مى‌ورزيديد، اكنون در آن درآييد"
  36,65,امروز بر دهانهاى آنان مُهر مى‌نهيم، و دستهايشان با ما سخن مى‌گويند، و پاهايشان بدانچه فراهم مى‌ساختند گواهى مى‌دهند
  36,66,"و اگر بخواهيم، هر آينه فروغ از ديدگانشان مى‌گيريم تا در راه [كج‌] بر هم پيشى جويند؛ ولى [راه راست را] از كجا مى‌توانند ببينند؟"
  36,67,"و اگر بخواهيم، هرآينه ايشان را در جاى خود مسخ مى‌كنيم [به گونه‌اى‌] كه نه بتوانند بروند و نه برگردند"
  36,68,"و هر كه را عمر دراز دهيم، او را [از نظر] خلقت فروكاسته [و شكسته‌] گردانيم، آيا نمى‌انديشند؟"
  36,69,"و [ما] به او شعر نياموختيم و در خور وى نيست، اين [سخن‌] جز اندرز و قرآنى روشن نيست"
  36,70,"تا هر كه را [دلى‌] زنده است بيم دهد، و گفتار [خدا] در باره كافران محقق گردد"
  36,71,آيا نديده‌اند كه ما به قدرت خويش براى ايشان چهارپايانى آفريده‌ايم تا آنان مالك آنها باشند؟
  36,72,و آنها را براى ايشان رام گردانيديم. از برخى‌شان سوارى مى‌گيرند و از بعضى مى‌خورند
  36,73,و از آنها سودها و نوشيدنيها دارند. پس چرا شكرگزار نيستيد؟
  36,74,"و غير از خدا[ى يگانه‌] خدايانى به پرستش گرفتند، تا مگر يارى شوند"
  36,75,"[ولى بتان‌] نمى‌توانند آنان را يارى كنند و آنانند كه براى [بتان‌] چون سپاهى احضار شده‌اند"
  36,76,پس، گفتار آنان تو را غمگين نگرداند كه ما آنچه را پنهان و آنچه را آشكار مى‌كنند، مى‌دانيم
  36,77,مگر آدمى ندانسته است كه ما او را از نطفه‌اى آفريده‌ايم، پس بناگاه وى ستيزه‌جويى آشكار شده است
  36,78,"و براى ما مَثَلى آورد و آفرينش خود را فراموش كرد؛ گفت: «چه كسى اين استخوانها را كه چنين پوسيده است زندگى مى‌بخشد؟»"
  36,79,"بگو: «همان كسى كه نخستين‌بار آن را پديد آورد و اوست كه به هر [گونه‌] آفرينشى داناست.»"
  36,80,"همو كه برايتان در درخت سبزفام اخگر نهاد كه از آن [چون نيازتان افتد] آتش مى‌افروزيد"
  36,81,"آيا كسى كه آسمانها و زمين را آفريده توانا نيست كه [باز] مانند آنها را بيافريند؟ آرى، اوست آفريننده دانا"
  36,82,"چون به چيزى اراده فرمايد، كارش اين بس كه مى‌گويد: «باش»؛ پس [بى‌درنگ‌] موجود مى‌شود"
  36,83,"پس [شكوهمند و] پاك است آن كسى كه ملكوت هر چيزى در دست اوست، و به سوى اوست كه بازگردانيده مى‌شويد"