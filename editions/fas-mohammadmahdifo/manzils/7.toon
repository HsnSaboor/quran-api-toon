quran[1606]{c,v,t}:
  50,1,قاف، سوگند به قرآن باشكوه،
  50,2,"[كه آنان نگرويدند،] بلكه از اينكه هشداردهنده‌اى از خودشان برايشان آمد، در شگفت شدند و كافران گفتند: «اين [محمّد و حكايت معاد] چيزى عجيب است»"
  50,3,"«آيا چون مُرديم و خاك شديم [زنده مى‌شويم‌]؟ اين بازگشتى بعيد است.»"
  50,4,"قطعاً دانسته‌ايم كه زمين [چه مقدار] از اجسادشان فرو مى‌كاهد. و پيش ما كتاب ضبطكننده‌اى است"
  50,5,"[نه،] بلكه حقيقت را، وقتى برايشان آمد، دروغ خواندند، و آنها در كارى سردرگم [مانده‌]اند"
  50,6,مگر به آسمان بالاى سرشان ننگريسته‌اند كه چگونه آن را ساخته و زينتش داده‌ايم و براى آن هيچ گونه شكافتگى نيست
  50,7,"و زمين را گسترديم و در آن لنگر[آسا كوه‌]ها فرو افكنديم و در آن از هر گونه جفت دل‌انگيز رويانيديم"
  50,8,"[تا] براى هر بنده توبه‌كارى بينش‌افزا و پندآموز باشد"
  50,9,"و از آسمان، آبى پر بركت فرود آورديم، پس بدان [وسيله‌] باغها و دانه‌هاى دروكردنى رويانيديم"
  50,10,"و درختان تناور خرما كه خوشه‌[هاى‌] روى هم چيده دارند"
  50,11,"[اينها همه‌] براى روزىِ بندگان [من‌] است، و با آن [آب‌] سرزمين مرده‌اى را زنده گردانيديم؛ رستاخيز [نيز] چنين است"
  50,12,پيش از ايشان قوم نوح و اصحاب رَسّ و ثمود،
  50,13,و عاد و فرعون و برادران لوط،
  50,14,"و بيشه‌نشينان و قوم تُبّع به تكذيب پرداختند؛ همگى فرستادگان [ما] را به دروغ گرفتند و [در نتيجه‌] تهديد [من‌] واجب آمد"
  50,15,"مگر از آفرينش نخستين [خود] به تنگ آمديم؟ [نه!] بلكه آنها از خلق جديد در شبهه‌اند"
  50,16,"و ما انسان را آفريده‌ايم و مى‌دانيم كه نفس او چه وسوسه‌اى به او مى‌كند، و ما از شاهرگ [او] به او نزديكتريم"
  50,17,"آنگاه كه دو [فرشته‌] دريافت‌كننده از راست و از چپ، مراقب نشسته‌اند"
  50,18,"[آدمى‌] هيچ سخنى را به لفظ درنمى‌آورد مگر اينكه مراقبى آماده نزد او [آن را ضبط مى‌كند]"
  50,19,و سكرات مرگ، به راستى در رسيد؛ اين همان است كه از آن مى‌گريختى؛
  50,20,"و در صور دميده شود؛ اين است روز تهديد [من‌]"
  50,21,"و هر كسى مى‌آيد [در حالى كه‌] با او سوق‌دهنده و گواهى‌دهنده‌اى است"
  50,22,"[به او مى‌گويند:] «واقعاً كه از اين [حال‌] سخت در غفلت بودى. و[لى‌] ما پرده‌ات را [از جلوى چشمانت‌] برداشتيم و ديده‌ات امروز تيز است.»"
  50,23,"و [فرشته‌] همنشين او مى‌گويد: «اين است آنچه پيش من آماده است [و ثبت كرده‌ام‌].»"
  50,24,"[به آن دو فرشته خطاب مى‌شود:] «هر كافر سرسختى را در جهنم فروافكنيد،"
  50,25,"[هر] بازدارنده از خيرى، [هر] متجاوز شكاكى"
  50,26,"كه با خداوند، خدايى ديگر قرار داد. [اى دو فرشته،] او را در عذاب شديد فرو افكنيد"
  50,27,"[شيطان‌] همدمش مى‌گويد: «پروردگار ما، من او را به عصيان وانداشتم، ليكن [خودش‌] در گمراهى دور و درازى بود.»"
  50,28,"[خدا] مى‌فرمايد: «در پيشگاه من با همديگر مستيزيد [كه‌] از پيش به شما هشدار داده بودم"
  50,29,"پيش من حكم دگرگون نمى‌شود، و من [نسبت‌] به بندگانم بيدادگر نيستم.»"
  50,30,"آن روز كه [ما] به دوزخ مى‌گوييم: «آيا پر شدى؟» و مى‌گويد: «آيا باز هم هست؟»"
  50,31,و بهشت را براى پرهيزگاران نزديك گردانند، بى‌آنكه دور باشد
  50,32,"[و به آنان گويند:] اين همان است كه وعده يافته‌ايد [و] براى هر توبه‌كار نگهبان [حدود خدا] خواهد بود"
  50,33,"آنكه در نهان از خداى بخشنده بترسد و با دلى توبه‌كار [باز] آيد"
  50,34,"به سلامت [و شادكامى‌] در آن درآييد [كه‌] اين روز جاودانگى است"
  50,35,"هر چه بخواهند در آنجا دارند، و پيش ما فزونتر [هم‌] هست"
  50,36,"و چه بسا نسلها كه پيش از ايشان هلاك كرديم كه [بس‌] نيرومندتر از اينان بودند و در شهرها پرسه زده بودند [اما سرانجام‌] مگر گريزگاهى بود؟"
  50,37,"قطعاً در اين [عقوبتها] براى هر صاحبدل و حق نيوشى كه خود به گواهى ايستد، عبرتى است"
  50,38,و در حقيقت، آسمانها و زمين و آنچه را كه ميان آن دو است در شش هنگام آفريديم و احساس ماندگى نكرديم
  50,39,و بر آنچه مى‌گويند صبر كن، و پيش از برآمدن آفتاب و پيش از غروب، به ستايش پروردگارت تسبيح گوى
  50,40,"و پاره‌اى از شب و به دنبال سجود [به صورت تعقيب و نافله‌] او را تسبيح گوى"
  50,41,و روزى كه منادى از جايى نزديك ندا درمى‌دهد، به گوش باش
  50,42,"روزى كه فرياد [رستاخيز] را به حق مى‌شنوند، آن [روز] روز بيرون آمدن [از زمين‌] است"
  50,43,ماييم كه خود، زندگى مى‌بخشيم و به مرگ مى‌رسانيم و برگشت به سوى ماست
  50,44,"روزى كه زمين به سرعت از [اجساد] آنان جدا و شكافته مى‌شود؛ اين حشرى است كه بر ما آسان خواهد بود"
  50,45,"ما به آنچه مى‌گويند داناتريم، و تو به زور وادارنده آنان نيستى؛ پس به [وسيله‌] قرآن هر كه را از تهديد [من‌] مى‌ترسد پند ده"
  51,1,سوگند به بادهاى ذره‌افشان،
  51,2,و ابرهاى گرانبار،
  51,3,و سبك سيران،
  51,4,"و تقسيم‌كنندگان كار[ها]،"
  51,5,كه آنچه وعده داده شده‌ايد راست است،
  51,6,"و [روز] پاداش واقعيت دارد"
  51,7,سوگند به آسمان مشبّك،
  51,8,"كه شما [درباره قرآن‌] در سخنى گوناگونيد"
  51,9,"[بگوى‌] تا هر كه از آن برگشته، برگشته باشد"
  51,10,مرگ بر دروغپردازان
  51,11,همانان كه در ورطه نادانى بى‌خبرند
  51,12,"پرسند: «روز پاداش كى است؟»"
  51,13,"همان روز كه آنان بر آتش، عقوبت [و آزموده‌] شوند"
  51,14,"عذاب [موعود] خود را بچشيد، اين است همان [بلايى‌] كه با شتاب خواستار آن بوديد"
  51,15,پرهيزگاران در باغها و چشمه سارانند
  51,16,آنچه را پروردگارشان عطا فرموده مى‌گيرند، زيرا كه آنها پيش از اين نيكوكار بودند
  51,17,و از شب اندكى را مى‌غنودند
  51,18,"و در سحرگاهان [از خدا] طلب آمرزش مى‌كردند"
  51,19,"و در اموالشان براى سائل و محروم حقى [معين‌] بود"
  51,20,"و روى زمين براى اهل يقين نشانه‌هايى [متقاعدكننده‌] است،"
  51,21,و در خود شما؛ پس مگر نمى‌بينيد؟
  51,22,و روزى شما و آنچه وعده داده شده‌ايد در آسمان است
  51,23,پس سوگند به پروردگار آسمان و زمين، كه واقعاً او حق است همان گونه كه خود شما سخن مى‌گوييد
  51,24,آيا خبر مهمانان ارجمند ابراهيم به تو رسيد؟
  51,25,"چون بر او درآمدند؛ پس سلام گفتند. گفت: «سلام، مردمى ناشناسيد.»"
  51,26,"پس آهسته به سوى زنش رفت و گوساله‌اى فربه [و بريان‌] آورد"
  51,27,"آن را به نزديكشان برد [و] گفت: «مگر نمى‌خوريد؟»"
  51,28,"و [در دلش‌] از آنان احساس ترسى كرد. گفتند: «مترس.» و او را به پسرى دانا مژده دادند"
  51,29,"و زنش با فريادى [از شگفتى‌] سر رسيد و بر چهره خود زد و گفت: «زنى پير نازا [چگونه بزايد]؟»"
  51,30,"گفتند: «پروردگارت چنين فرموده است. او خود حكيم داناست.»"
  51,31,"[ابراهيم‌] گفت: «اى فرستادگان، مأموريت شما چيست؟»"
  51,32,"گفتند: «ما به سوى مردمى پليدكار فرستاده شده‌ايم،"
  51,33,"تا سنگهايى از گِل رُس بر [سر] آنان فرو فرستيم"
  51,34,"[كه‌] نزد پروردگارت براى مسرفان نشان‌گذارى شده است"
  51,35,"پس هر كه از مؤمنان در آن [شهرها] بود بيرون برديم"
  51,36,"و[لى‌] در آنجا جز يك خانه از فرمانبران [خدا بيشتر] نيافتيم"
  51,37,و در آنجا براى آنها كه از عذاب پر درد مى‌ترسند، عبرتى به جاى گذاشتيم
  51,38,"و [نيز] در [ماجراى‌] موسى، چون او را با حجتى آشكار به سوى فرعون گسيل داشتيم"
  51,39,"پس [فرعون‌] با اركان [دولت‌] خود روى برتافت و گفت: «[اين شخص،] ساحر يا ديوانه‌اى است.»"
  51,40,"[تا] او و سپاهيانش را گرفتيم و آنان را در دريا افكنديم در حالى كه او [در آخرين لحظه‌] نكوهشگر [خود] بود"
  51,41,"و در [ماجراى‌] عاد [نيز]، چون بر [سر] آنها آن باد مُهلِك را فرستاديم"
  51,42,به هر چه مى‌وزيد آن را چون خاكستر استخوان مرده مى‌گردانيد
  51,43,"و در [ماجراى‌] ثمود [نيز عبرتى بود]، آنگاه كه به ايشان گفته شد: «تا چندى برخوردار شويد.»"
  51,44,"تا [آنكه‌] از فرمان پروردگار خود سر برتافتند و در حالى كه آنها مى‌نگريستند، آذرخش آنان را فرو گرفت"
  51,45,در نتيجه نه توانستند به پاى خيزند و نه طلب يارى كنند
  51,46,"و قوم نوح [نيز] پيش از آن [اقوام نامبرده همين گونه هلاك شدند]، زيرا آنها مردمى نافرمان بودند"
  51,47,"و آسمان را به قدرت خود برافراشتيم، و بى‌گمان، ما [آسمان‌]گستريم"
  51,48,و زمين را گسترانيده‌ايم و چه نيكو گسترندگانيم
  51,49,"و از هر چيزى دو گونه [يعنى نر و ماده‌] آفريديم، اميد كه شما عبرت گيريد"
  51,50,پس به سوى خدا بگريزيد، كه من شما را از طرف او بيم‌دهنده‌اى آشكارم
  51,51,و با خدا معبودى ديگر قرار مدهيد كه من از جانب او هشداردهنده‌اى آشكارم
  51,52,"بدين سان بر كسانى كه پيش از آنها بودند هيچ پيامبرى نيامد جز اينكه گفتند: «ساحر يا ديوانه‌اى است.»"
  51,53,"آيا همديگر را به اين [سخن‌] سفارش كرده بودند؟ [نه!] بلكه آنان مردمى سركش بودند"
  51,54,پس، از آنان روى بگردان، كه تو در خور نكوهش نيستى
  51,55,و پند ده، كه مؤمنان را پند سود بخشد
  51,56,و جن و انس را نيافريدم جز براى آنكه مرا بپرستند
  51,57,از آنان هيچ روزيى نمى‌خواهم، و نمى‌خواهم كه مرا خوراك دهند
  51,58,خداست كه خود روزى بخش نيرومند استوار است
  51,59,"پس براى كسانى كه ستم كردند بهره‌اى است از عذاب، همانند بهره عذاب ياران [قبلى‌]شان. پس [بگو:] در خواستن عذاب از من، شتابزدگى نكنند"
  51,60,پس واى بر كسانى كه كافر شده‌اند از آن روزى كه وعده يافته‌اند
  52,1,سوگند به طور،
  52,2,و كتابى نگاشته شده،
  52,3,در طومارى گسترده؛
  52,4,"سوگند به آن خانه آباد [خدا]؛"
  52,5,"سوگند به بام بلند [آسمان‌]،"
  52,6,"و آن درياى سرشار [و افروخته‌]،"
  52,7,كه عذاب پروردگارت واقع‌شدنى است؛
  52,8,آن را هيچ بازدارنده‌اى نيست
  52,9,روزى كه آسمان سخت در تب و تاب افتد،
  52,10,"و كوهها [جمله‌] به حركت درآيند"
  52,11,پس واى بر تكذيب‌كنندگان در آن روز
  52,12,آنان كه به ياوه سرگرمند
  52,13,"روزى كه به سوى آتش جهنم كشيده مى‌شوند [چه‌] كشيدنى"
  52,14,"[و به آنان گويند:] «اين همان آتشى است كه دروغش مى‌پنداشتيد"
  52,15,"آيا اين افسون است؟ يا شما [درست‌] نمى‌بينيد؟"
  52,16,به آن درآييد؛ خواه بشكيبيد يا نشكيبيد، به حال شما يكسان است. تنها به آنچه مى‌كرديد مجازات مى‌يابيد.»
  52,17,"پرهيزگاران در باغهايى و [در] ناز و نعمتند"
  52,18,به آنچه پروردگارشان به آنان داده دلشادند، و پروردگارشان آنها را از عذاب دوزخ مصون داشته است
  52,19,"[به آنان گويند:] «به [پاداش‌] آنچه به جاى مى‌آورديد بخوريد و بنوشيد؛ گواراتان باد!»"
  52,20,بر تختهايى رديف هم تكيه زده‌اند و حوران درشت‌چشم را همسر آنان گردانده‌ايم
  52,21,"و كسانى كه گرويده و فرزندانشان آنها را در ايمان پيروى كرده‌اند، فرزندانشان را به آنان ملحق خواهيم كرد و چيزى از كار[ها]شان را نمى‌كاهيم. هر كسى در گرو دستاورد خويش است"
  52,22,"با [هر نوع‌] ميوه و گوشتى كه دلخواه آنهاست آنان را مدد [و تقويت‌] مى‌كنيم"
  52,23,"در آنجا جامى از دست هم مى‌ربايند [و بر سرش همچشمى مى‌كنند] كه در آن نه ياوه گويى است و نه گناه"
  52,24,"و براى [خدمت‌] آنان پسرانى است كه بر گردشان همى‌گردند، انگارى آنها مرواريدى‌اند كه [در صدف‌] نهفته است"
  52,25,"و برخى‌شان رو به برخى كنند [و] از هم پرسند،"
  52,26,"گويند: «ما پيشتر در ميان خانواده خود بيمناك بوديم"
  52,27,"پس خدا بر ما منت نهاد و ما را از عذاب گرم [مرگبار] حفظ كرد"
  52,28,ما از ديرباز او را مى‌خوانديم، كه او همان نيكوكار مهربان است.»
  52,29,پس اندرز ده كه تو به لطف پروردگارت نه كاهنى و نه ديوانه
  52,30,"يا مى‌گويند: «شاعرى است كه انتظار مرگش را مى‌بريم [و چشم به راه بد زمانه بر اوييم‌].»"
  52,31,"بگو: «منتظر باشيد كه من [نيز] با شما از منتظرانم.»"
  52,32,"آيا پندارهايشان آنان را به اين [موضعگيرى‌] وا مى‌دارد يا [نه،] آنها مردمى سركشند؟"
  52,33,"يا مى‌گويند: «آن را بربافته.» [نه،] بلكه باور ندارند"
  52,34,پس اگر راست مى‌گويند، سخنى مثل آن بياورند
  52,35,"آيا از هيچ خلق شده‌اند؟ يا آنكه خودشان خالق [خود] هستند؟"
  52,36,"آيا آسمانها و زمين را [آنان‌] خلق كرده‌اند؟ [نه،] بلكه يقين ندارند"
  52,37,"آيا ذخاير پروردگار تو پيش آنهاست؟ يا ايشان تسلط [تام‌] دارند؟"
  52,38,"آيا نردبانى دارند كه بر آن [بر شوند و] بشنوند؟ پس بايد شنونده آنان برهانى آشكار بياورد"
  52,39,آيا خدا را دختران است و شما را پسران؟
  52,40,"آيا از آنها مزدى مطالبه مى‌كنى و آنان از [تعهّد اداى‌] تاوان گرانبارند؟"
  52,41,"آيا [علم‌] غيب پيش آنهاست و آنها مى‌نويسند؟"
  52,42,"يا مى‌خواهند نيرنگى بزنند؟ و [لى‌] آنان كه كافر شده‌اند، خود دچار نيرنگ شده‌اند"
  52,43,"آيا ايشان را جز خدا معبودى است؟ منزّه است خدا از آنچه [با او] شريك مى‌گردانند"
  52,44,"و اگر پاره‌سنگى را در حال سقوط از آسمان ببينند مى‌گويند: «ابرى متراكم است.»"
  52,45,پس بگذارشان تا به آن روزى كه در آن بيهوش مى‌افتند برسند
  52,46,روزى كه نيرنگشان به هيچ‌وجه به كارشان نيايد و حمايت نيابند
  52,47,"و در حقيقت، غير از اين [مجازات‌]، عذابى [ديگر] براى كسانى كه ظلم كرده‌اند خواهد بود، ولى بيشترشان نمى‌دانند [كه آن عذاب چيست‌]"
  52,48,"و در برابر دستور پروردگارت شكيبايى پيشه كن كه تو خود در حمايت مايى و هنگامى كه [از خواب‌] بر مى‌خيزى به نيايش پروردگارت تسبيح گوى"
  52,49,"و [نيز] پاره‌اى از شب، و در فروشدن ستارگان تسبيح‌گوى او باش"
  53,1,"سوگند به اختر [= قرآن‌] چون فرود مى‌آيد،"
  53,2,"[كه‌] يار شما نه گمراه شده و نه در نادانى مانده؛"
  53,3,و از سر هوس سخن نمى‌گويد
  53,4,اين سخن بجز وحيى كه وحى مى‌شود نيست
  53,5,"آن را [فرشته‌] شديدالقوى به او فرا آموخت،"
  53,6,"[سروش‌] نيرومندى كه [مسلّط] درايستاد"
  53,7,در حالى كه او در افق اعلى بود؛
  53,8,سپس نزديك آمد و نزديكتر شد،
  53,9,"تا [فاصله‌اش‌] به قدر [طول‌] دو [انتهاى‌] كمان يا نزديكتر شد؛"
  53,10,آنگاه به بنده‌اش آنچه را بايد وحى كند، وحى فرمود
  53,11,"آنچه را دل ديد انكار[ش‌] نكرد"
  53,12,آيا در آنچه ديده است با او جدال مى‌كنيد؟
  53,13,و قطعاً بار ديگرى هم او را ديده است،
  53,14,نزديك سدرالمنتهى،
  53,15,در همان جا كه جنةالمأوى است
  53,16,آنگاه كه درخت سدر را آنچه پوشيده بود، پوشيده بود
  53,17,"ديده [اش‌] منحرف نگشت و [از حدّ] در نگذشت"
  53,18,"به راستى كه [برخى‌] از آيات بزرگ پروردگار خود را بديد"
  53,19,به من خبر دهيد از لات و عزّى،
  53,20,و منات آن سومين ديگر،
  53,21,"آيا [به خيالتان‌] براى شما پسر است و براى او دختر؟"
  53,22,در اين صورت، اين تقسيم نادرستى است
  53,23,"[اين بتان‌] جز نامهايى بيش نيستند كه شما و پدرانتان نامگذارى كرده‌ايد [و] خدا بر [حقّانيّت‌] آنها هيچ دليلى نفرستاده است. [آنان‌] جز گمان و آنچه را كه دلخواهشان است پيروى نمى‌كنند، با آنكه قطعاً از جانب پروردگارشان هدايت برايشان آمده است"
  53,24,مگر انسان آنچه را آرزو كند دارد؟
  53,25,آن سرا و اين سرا از آن خداست
  53,26,"و بسا فرشتگانى كه در آسمانهايند [و] شفاعتشان به كارى نيايد، مگر پس از آنكه خدا به هر كه خواهد و خشنود باشد اذن دهد"
  53,27,در حقيقت، كسانى كه آخرت را باور ندارند، فرشتگان را در نامگذارى به صورت مؤنّث نام مى‌نهند
  53,28,"و ايشان را به اين [كار] معرفتى نيست. جز گمان [خود] را پيروى نمى‌كنند، و در واقع، گمان در [وصول به‌] حقيقت هيچ سودى نمى‌رساند"
  53,29,پس، از هر كس كه از ياد ما روى برتافته و جز زندگى دنيا را خواستار نبوده است، روى برتاب
  53,30,"اين منتهاى دانش آنان است. پروردگار تو، خود به [حال‌] كسى كه از راه او منحرف شده داناتر، و او به كسى كه راه يافته [نيز] آگاه‌تر است"
  53,31,"و هر چه در آسمانها و هر چه در زمين است از آن خداست، تا كسانى را كه بد كرده‌اند، به [سزاى‌] آنچه انجام داده‌اند كيفر دهد، و آنان را كه نيكى كرده‌اند، به نيكى پاداش دهد"
  53,32,"آنان كه از گناهان بزرگ و زشتكاريها -جز لغزشهاى كوچك- خوددارى مى‌ورزند، پروردگارت [نسبت به آنها] فراخ‌آمرزش است. وى از آن دم كه شما را از زمين پديد آورد و از همان‌گاه كه در شكمهاى مادرانتان [در زهدان‌] نهفته بوديد به [حال ]شما داناتر است، پس خودتان را پاك مشماريد. او به [حال‌] كسى كه پرهيزگارى نموده داناتر است"
  53,33,"پس آيا آن كسى را كه [از جهاد] روى برتافت ديدى؟"
  53,34,"و اندكى بخشيد و [از باقى‌] امتناع ورزيد"
  53,35,آيا علم غيب پيش اوست و او مى‌بيند؟
  53,36,"يا بدانچه در صحيفه‌هاى موسى [آمده‌] خبر نيافته است؟"
  53,37,"و [نيز در نوشته‌هاى‌] همان ابراهيمى كه وفا كرد"
  53,38,كه هيچ بردارنده‌اى بار گناه ديگرى را بر نمى‌دارد
  53,39,و اينكه براى انسان جز حاصل تلاش او نيست
  53,40,"و [نتيجه‌] كوشش او به زودى ديده خواهد شد"
  53,41,سپس هر چه تمامتر وى را پاداش دهند
  53,42,"و اينكه پايان [كار] به سوى پروردگار توست"
  53,43,و هم اوست كه مى‌خنداند و مى‌گرياند
  53,44,و هم اوست كه مى‌ميراند و زنده مى‌گرداند
  53,45,"و هم اوست كه دو نوع مى‌آفريند: نر و ماده،"
  53,46,از نطفه‌اى چون فرو ريخته شود
  53,47,"و هم پديد آوردن [عالم‌] ديگر بر [عهده‌] اوست"
  53,48,"و هم اوست كه [شما را] بى‌نياز كرد و سرمايه بخشيد"
  53,49,و هم اوست پروردگار ستاره «شِعرى»
  53,50,و هم اوست كه عاديان قديم را هلاك كرد
  53,51,"و ثمود را [نيز هلاك كرد] و [كسى را] باقى نگذاشت"
  53,52,"و پيشتر [از همه آنها] قوم نوح را، زيرا كه آنان ستمگرتر و سركش‌تر بودند"
  53,53,"و شهرها[ى سَدوم و عاموره‌] را فرو افكند"
  53,54,"پوشاند بر آن [دو شهر، از باران گوگردى‌] آنچه را پوشاند"
  53,55,پس به كدام يك از نعمتهاى پروردگارت ترديد روا مى‌دارى؟
  53,56,"اين [پيامبر نيز] بيم‌دهنده‌اى از [جمله‌] بيم‌دهندگان نخستين است"
  53,57,"[وه چه‌] نزديك گشت قيامت"
  53,58,جز خدا كسى آشكاركننده آن نيست
  53,59,آيا از اين سخن عجب داريد؟
  53,60,و مى‌خنديد و نمى‌گرييد؟
  53,61,و شما در غفلتيد
  53,62,پس خدا را سجده كنيد و بپرستيد
  54,1,نزديك شد قيامت و از هم شكافت ماه
  54,2,"و هر گاه نشانه‌اى ببينند روى بگردانند و گويند: «سحرى دايم است.»"
  54,3,"و به تكذيب دست زدند و هوسهاى خويش را دنبال كردند، و [لى‌] هر كارى را [آخر] قرارى است"
  54,4,"و قطعاً از اخبار، آنچه در آن مايه انزجار [از كفر] است به ايشان رسيد"
  54,5,"حكمت بالغه [حق اين بود]، ولى هشدارها سود نكرد"
  54,6,"پس، از آنان روى برتاب. روزى كه داعى [حق‌] به سوى امرى دهشتناك دعوت مى‌كند،"
  54,7,"در حالى كه ديدگان خود را فروهشته‌اند، چون ملخهاى پراكنده از گورها[ى خود] برمى‌آيند"
  54,8,"به سرعت سوى آن دعوتگر مى‌شتابند. كافران مى‌گويند: «امروز [چه‌] روز دشوارى است.»"
  54,9,"پيش از آنان، قوم نوح [نيز] به تكذيب پرداختند و بنده ما را دروغزن خواندند و گفتند: «ديوانه‌اى است.» و [بسى‌] آزار كشيد"
  54,10,"تا پروردگارش را خواند كه: «من مغلوب شدم؛ به داد من برس!»"
  54,11,پس درهاى آسمان را به آبى ريزان گشوديم
  54,12,"و از زمين چشمه‌ها جوشانيديم تا آب [زمين و آسمان‌] براى امرى كه مقدّر شده بود به هم پيوستند"
  54,13,"و او را بر [كشتى‌] تخته‌دار و ميخ‌آجين سوار كرديم"
  54,14,"[كشتى‌] زير نظر ما روان بود. [اين‌] پاداش كسى بود كه مورد انكار واقع شده بود"
  54,15,"و به راستى آن [سفينه‌] را بر جاى نهاديم [تا] عبرتى [باشد]؛ پس آيا پندگيرنده‌اى هست؟"
  54,16,"پس چگونه بود عذاب من و هشدارها[ى من‌]؟"
  54,17,و قطعاً قرآن را براى پندآموزى آسان كرده‌ايم؛ پس آيا پندگيرنده‌اى هست؟
  54,18,"عاديان به تكذيب پرداختند. پس چگونه بود عذاب من و هشدارها[ى من‌]؟"
  54,19,"ما بر [سر] آنان در روز شومى، به طور مداوم، تندبادى توفنده فرستاديم،"
  54,20,"[كه‌] مردم را از جا مى‌كند؛ گويى تنه‌هاى نخلى بودند كه ريشه‌كن شده بودند"
  54,21,"پس چگونه بود عذاب من و هشدارها[ى من‌]؟"
  54,22,و قطعاً قرآن را براى پندآموزى آسان كرده‌ايم، پس آيا پندگيرنده‌اى هست؟
  54,23,قوم ثمود هشداردهندگان را تكذيب كردند
  54,24,"و گفتند: «آيا تنها بشرى از خودمان را پيروى كنيم؟ در اين صورت، ما واقعاً در گمراهى و جنون خواهيم بود.»"
  54,25,"«آيا از ميان ما [وحى‌] بر او القا شده است؟ [نه،] بلكه او دروغگويى گستاخ است.»"
  54,26,به زودى فردا بدانند دروغگوى گستاخ كيست
  54,27,"ما براى آزمايش آنان [آن‌] ماده‌شتر را فرستاديم و [به صالح گفتيم:]«مراقب آنان باش و شكيبايى كن"
  54,28,"و به آنان خبر ده كه آب ميانشان بخش شده‌است: هر كدام را آب به نوبت خواهد بود.»"
  54,29,"پس رفيقشان را صدا كردند و [او] شمشير كشيد و [شتر را] پى كرد"
  54,30,"پس چگونه بود عذاب من و هشدارها[ى من‌]؟"
  54,31,"ما بر [سر]شان يك فرياد [مرگبار] فرستاديم و چون گياه خشكيده [كومه‌ها] ريزريز شدند"
  54,32,و قطعاً قرآن را براى پندآموزى آسان كرديم؛ پس آيا پندگيرنده‌اى هست؟
  54,33,قوم لوط هشداردهندگان را تكذيب كردند
  54,34,"ما بر [سر] آنان سنگبارانى [انفجارى‌] فروفرستاديم [و] فقط خانواده لوط بودند كه سحرگاهشان رهانيديم"
  54,35,"[و اين‌] رحمتى از جانب ما بود؛ هر كه سپاس دارد، بدين‌سان [او را] پاداش مى‌دهيم"
  54,36,"و [لوط] آنها را از عذاب ما سخت بيم داده بود، و[لى‌] در تهديدها[ى ما] به جدال برخاستند"
  54,37,"و از مهمان‌[هاى‌] او كام دل خواستند، پس فروغ ديدگانشان را سترديم و [گفتيم:] «[مزه‌] عذاب و هشدارهاى مرا بچشيد.»"
  54,38,و به راستى كه سپيده‌دم عذابى پيگير به سر وقت آنان آمد
  54,39,پس عذاب و هشدارهاى مرا بچشيد
  54,40,و قطعاً قرآن را براى پندآموزى آسان كرديم؛ پس آيا پندگيرنده‌اى هست؟
  54,41,و در حقيقت هشداردهندگان به جانب فرعونيان آمدند
  54,42,"[اما آنها] همه معجزات ما را تكذيب كردند، تا چون زبردستى زورمند [گريبان‌] آنان را گرفتيم"
  54,43,"آيا كافران شما، از اينان [كه برشمرديم‌] برترند، يا شما را در نوشته‌ها[ى آسمانى‌] خط امانى است؟"
  54,44,"يا مى‌گويند: «ما همگى انتقام‌گيرنده [و يار و ياور همديگر]يم!»"
  54,45,زودا كه اين جمع در هم شكسته شود و پشت كنند
  54,46,"بلكه موعدشان قيامت است و قيامت [بسى‌] سخت‌تر و تلخ‌تر است"
  54,47,قطعاً بزهكاران در گمراهى و جنونند
  54,48,"روزى كه در آتش به رو كشيده مى‌شوند [و به آنان گفته مى‌شود:] «لهيب آتش را بچشيد [و احساس كنيد].»"
  54,49,ماييم كه هر چيزى را به اندازه آفريده‌ايم
  54,50,"و فرمان ما جز يك بار نيست [آن هم‌] چون چشم به هم زدنى"
  54,51,و هم مسلكان شما را سخت به هلاكت رسانديم؛ پس آيا پندگيرنده‌اى هست؟
  54,52,"و هر چه كرده‌اند در كتابها[ى اعمالشان درج‌] است"
  54,53,"و هر خرد و بزرگى [در آن‌] نوشته شده"
  54,54,در حقيقت، مردم پرهيزگار در ميان باغها و نهرها،
  54,55,در قرارگاه صدق، نزد پادشاهى توانايند
  55,1,"[خداى‌] رحمان،"
  55,2,قرآن را ياد داد
  55,3,انسان را آفريد،
  55,4,به او بيان آموخت
  55,5,"خورشيد و ماه بر حسابى [روان‌]اند"
  55,6,و بوته و درخت چهره‌سايانند
  55,7,و آسمان را برافراشت و ترازو را گذاشت،
  55,8,تا مبادا از اندازه درگذريد
  55,9,و وزن را به انصاف برپا داريد و در سنجش مكاهيد
  55,10,و زمين را براى مردم نهاد
  55,11,"در آن، ميوه [ها] و نخلها با خوشه‌هاى غلاف دار،"
  55,12,و دانه‌هاى پوست‌دار و گياهان خوشبوست
  55,13,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,14,انسان را از گل خشكيده‌اى سفال مانند، آفريد
  55,15,و جن را از تشعشعى از آتش خلق كرد
  55,16,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,17,پروردگار دو خاور و پروردگار دو باختر
  55,18,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,19,"دو دريا را [به گونه‌اى‌] روان كرد [كه‌] با هم برخورد كنند"
  55,20,ميان آن دو، حد فاصلى است كه به هم تجاوز نمى‌كنند
  55,21,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,22,"از هر دو [دريا] مرواريد و مرجان برآيد"
  55,23,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,24,و او راست در دريا سفينه‌هاى بادبان‌دار بلند همچون كوهها
  55,25,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,26,"هر چه بر [زمين‌] است فانى‌شونده است"
  55,27,و ذات باشكوه و ارجمند پروردگارت باقى خواهد ماند
  55,28,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,29,هر كه در آسمانها و زمين است از او درخواست مى‌كند. هر زمان، او در كارى است
  55,30,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,31,اى جن و انس، زودا كه به شما بپردازيم
  55,32,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,33,"اى گروه جنّيان و انسيان، اگر مى‌توانيد از كرانه‌هاى آسمانها و زمين به بيرون رخنه كنيد، پس رخنه كنيد. [ولى‌] جز با [به دست آوردن‌] تسلطى رخنه نمى‌كنيد"
  55,34,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,35,"بر سر شما شراره‌هايى از [نوع‌] تفته آهن و مس فرو فرستاده خواهد شد، و [از كسى‌] يارى نتوانيد طلبيد"
  55,36,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,37,پس آنگاه كه آسمان از هم شكافد و چون چرم گلگون گردد
  55,38,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,39,در آن روز، هيچ انس و جنى از گناهش پرسيده نشود
  55,40,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,41,تبهكاران از سيمايشان شناخته مى‌شوند و از پيشانى و پايشان بگيرند
  55,42,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,43,اين است همان جهنمى كه تبهكاران آن را دروغ مى‌خواندند
  55,44,"ميان [آتش‌] و ميان آب جوشان سرگردان باشند"
  55,45,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,46,و هر كس را كه از مقام پروردگارش بترسد دو باغ است
  55,47,پس كداميك از نعمتهاى پروردگارتان را منكريد؟
  55,48,كه داراى شاخسارانند
  55,49,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,50,"در آن دو [باغ‌] دو چشمه روان است"
  55,51,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,52,"در آن دو [باغ‌] از هر ميوه‌اى دو گونه است"
  55,53,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,54,"بر بسترهايى كه آستر آنها از ابريشم درشت‌بافت است، تكيه آنند و چيدن ميوه [از] آن دو باغ [به آسانى‌] در دسترس است"
  55,55,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,56,"در آن [باغها، دلبرانى‌] فروهشته‌نگاهند كه دست هيچ انس و جنى پيش از ايشان به آنها نرسيده است"
  55,57,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,58,گويى كه آنها ياقوت و مرجانند
  55,59,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,60,مگر پاداش احسان جز احسان است؟
  55,61,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,62,"و غير از آن دو [باغ‌]، دو باغ [ديگر نيز] هست"
  55,63,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,64,"كه از [شدّت‌] سبزى سيه‌گون مى‌نمايد"
  55,65,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,66,"در آن دو [باغ‌] دو چشمه همواره جوشان است"
  55,67,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,68,در آن دو، ميوه و خرما و انار است
  55,69,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,70,"در آنجا [زنانى‌] نكوخوى و نكورويند"
  55,71,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,72,"حورانى پرده‌نشين در [دل‌] خيمه‌ها"
  55,73,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,74,دست هيچ انس و جنى پيش از ايشان به آنها نرسيده است
  55,75,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,76,بر بالش سبز و فرش نيكو تكيه زده‌اند
  55,77,پس كدام يك از نعمتهاى پروردگارتان را منكريد؟
  55,78,خجسته باد نام پروردگار شكوهمند و بزرگوارت،
  56,1,آن واقعه چون وقوع يابد،
  56,2,"[كه‌] در وقوع آن دروغى نيست"
  56,3,"پست‌كننده [و] بالابرنده است"
  56,4,"چون زمين با تكان [سختى‌] لرزانده شود،"
  56,5,"و كوهها [جمله‌] ريزه ريزه شوند،"
  56,6,و غبارى پراكنده گردند،
  56,7,و شما سه دسته شويد
  56,8,ياران دست راست، كدامند ياران دست راست؟
  56,9,و ياران چپ؛ كدامند ياران چپ؟
  56,10,و سبقت‌گيرندگان مقدمند؛
  56,11,"آنانند همان مقربان [خدا]،"
  56,12,در باغستانهاى پر نعمت
  56,13,گروهى از پيشينيان،
  56,14,و اندكى از متأخران
  56,15,بر تختهايى جواهرنشان،
  56,16,كه روبروى هم بر آنها تكيه داده‌اند
  56,17,"بر گردشان پسرانى جاودان [به خدمت‌] مى‌گردند،"
  56,18,"با جامها و آبريزها و پياله‌[ها]يى از باده ناب روان"
  56,19,"[كه‌] نه از آن دردسر گيرند و نه بى‌خرد گردند"
  56,20,و ميوه از هر چه اختيار كنند
  56,21,و از گوشت پرنده هر چه بخواهند
  56,22,و حوران چشم‌درشت،
  56,23,مثل لؤلؤ نهان ميان صدف،
  56,24,"[اينها] پاداشى است براى آنچه مى‌كردند"
  56,25,"در آنجا نه بيهوده‌اى مى‌شنوند و نه [سخنى‌] گناه‌آلود"
  56,26,سخنى جز سلام و درود نيست
  56,27,و ياران راست؛ ياران راست كدامند؟
  56,28,"در [زير] درختان كُنار بى‌خار،"
  56,29,و درختهاى موز كه ميوه‌اش خوشه خوشه روى هم چيده است
  56,30,و سايه‌اى پايدار
  56,31,و آبى ريزان
  56,32,و ميوه‌اى فراوان،
  56,33,نه بريده و نه ممنوع
  56,34,و همخوابگانى بالا بلند
  56,35,ما آنان را پديد آورده‌ايم پديد آوردنى،
  56,36,و ايشان را دوشيزه گردانيده‌ايم،
  56,37,شوى دوست همسال،
  56,38,براى ياران راست
  56,39,كه گروهى از پيشينيانند،
  56,40,و گروهى از متأخران
  56,41,و ياران چپ؛ كدامند ياران چپ؟
  56,42,"در [ميان‌] باد گرم و آب داغ"
  56,43,و سايه‌اى از دود تار
  56,44,نه خنك و نه خوش
  56,45,اينان بودند كه پيش از اين ناز پروردگان بودند
  56,46,و بر گناه بزرگ پافشارى مى‌كردند
  56,47,"و مى‌گفتند: «آيا چون مرديم و خاك واستخوان شديم، واقعاً [باز] زنده مى‌گرديم؟"
  56,48,"يا پدران گذشته ما [نيز]؟»"
  56,49,"بگو: «در حقيقت، اولين و آخرين،"
  56,50,قطعاً همه در موعد روزى معلوم گرد آورده شوند.»
  56,51,آنگاه شما اى گمراهان دروغپرداز،
  56,52,قطعاً از درختى كه از زقّوم است خواهيد خورد
  56,53,و از آن شكمهايتان را خواهيد آكند
  56,54,و روى آن از آب جوش مى‌نوشيد؛
  56,55,"[مانند] نوشيدن اشتران تشنه"
  56,56,اين است پذيرايى آنان در روز جزا
  56,57,ماييم كه شما را آفريده‌ايم، پس چرا تصديق نمى‌كنيد؟
  56,58,"آيا آنچه را [كه به صورت نطفه‌] فرو مى‌ريزيد ديده‌ايد؟"
  56,59,آيا شما آن را خلق مى‌كنيد يا ما آفريننده‌ايم؟
  56,60,ماييم كه ميان شما مرگ را مقدر كرده‌ايم و بر ما سبقت نتوانيد جست؛
  56,61,"[و مى‌توانيم‌] امثال شما را به جاى شما قرار دهيم و شما را [به صورت‌] آنچه نمى‌دانيد پديدار گردانيم"
  56,62,و قطعاً پديدار شدن نخستين خود را شناختيد؛ پس چرا سر عبرت گرفتن نداريد؟
  56,63,آيا آنچه را كشت مى‌كنيد، ملاحظه كرده‌ايد؟
  56,64,"آيا شما آن را [بى‌يارى ما] زراعت مى‌كنيد، يا ماييم كه زراعت مى‌كنيم؟"
  56,65,"اگر بخواهيم قطعاً خاشاكش مى‌گردانيم، پس در افسوس [و تعجب‌] مى‌افتيد"
  56,66,"[و مى‌گوييد:] «واقعاً ما زيان زده‌ايم،"
  56,67,بلكه ما محروم شدگانيم.»
  56,68,آيا آبى را كه مى‌نوشيد ديده‌ايد؟
  56,69,"آيا شما آن را از [دل‌] ابر سپيد فرود آورده‌ايد، يا ما فرودآورنده‌ايم؟"
  56,70,اگر بخواهيم آن را تلخ مى‌گردانيم، پس چرا سپاس نمى‌داريد؟
  56,71,آيا آن آتشى را كه برمى‌افروزيد ملاحظه كرده‌ايد؟
  56,72,"آيا شما [چوب‌] درخت آن را پديدار كرده‌ايد، يا ما پديدآورنده‌ايم؟"
  56,73,"ما آن را [مايه‌] عبرت و [وسيله‌] استفاده براى بيابانگردان قرار داده‌ايم"
  56,74,پس به نام پروردگار بزرگت تسبيح گوى
  56,75,"نه [چنين است كه مى‌پنداريد]، سوگند به جايگاه‌هاى [ويژه و فواصل معيّن‌] ستارگان"
  56,76,اگر بدانيد، آن سوگندى سخت بزرگ است
  56,77,"كه اين [پيام‌] قطعاً قرآنى است ارجمند،"
  56,78,در كتابى نهفته،
  56,79,كه جز پاك‌شدگان بر آن دست ندارند،
  56,80,وحيى است از جانب پروردگار جهانيان
  56,81,"آيا شما اين سخن را سبك [و سست‌] مى‌گيريد؟"
  56,82,"و تنها نصيب خود را در تكذيب [آن‌] قرار مى‌دهيد؟"
  56,83,"پس چرا آنگاه كه [جان شما] به گلو مى‌رسد،"
  56,84,و در آن هنگام خود نظاره گريد
  56,85,"و ما به آن [محتضر] از شما نزديكتريم ولى نمى‌بينيد"
  56,86,"پس چرا، اگر شما بى‌جزا مى‌مانيد [و حساب و كتابى در كار نيست‌]،"
  56,87,"اگر راست مى‌گوييد، [روح‌] را برنمى‌گردانيد؟"
  56,88,"و اما اگر [او] از مقربان باشد،"
  56,89,"[در] آسايش و راحت و بهشت پر نعمت [خواهد بود]"
  56,90,و اما اگر از ياران راست باشد،
  56,91,از ياران راست بر تو سلام باد
  56,92,و اما اگر از دروغزنان گمراه است،
  56,93,پس با آبى جوشان پذيرايى خواهد شد،
  56,94,"و [فرجامش‌] درافتادن به جهنم است"
  56,95,"اين است همان حقيقت راست [و] يقين"
  56,96,پس به نام پروردگار بزرگ خود تسبيح گوى
  57,1,آنچه در آسمانها و زمين است، خدا را به پاكى مى‌ستايند، و اوست ارجمند حكيم
  57,2,"فرمانروايى آسمانها و زمين از آنِ اوست: زنده مى‌كند و مى‌ميراند، و او بر هر چيزى تواناست"
  57,3,اوست اول و آخر و ظاهر و باطن، و او به هر چيزى داناست
  57,4,"اوست آن كس كه آسمانها و زمين را در شش هنگام آفريد؛ آنگاه بر عرش استيلا يافت. آنچه در زمين درآيد و آنچه از آن برآيد و آنچه در آن بالارود [همه را] مى‌داند. و هر كجا باشيد او با شماست، و خدا به هر چه مى‌كنيد بيناست"
  57,5,"فرمانروايى [مطلق‌] آسمانها و زمين از آن اوست، و [جمله‌] كارها به سوى خدا بازگردانيده مى‌شود"
  57,6,"شب را در روز درمى‌آورد و روز را [نيز] در شب درمى‌آورد، و او به راز دلها داناست"
  57,7,"به خدا و پيامبر او ايمان آوريد، و از آنچه شما را در [استفاده از] آن، جانشين [ديگران‌] كرده، انفاق كنيد. پس كسانى از شما كه ايمان آورده و انفاق كرده باشند، پاداش بزرگى خواهند داشت"
  57,8,"و شما را چه شده كه به خدا ايمان نمى‌آوريد و [حال آنكه‌] پيامبر [خدا] شما را دعوت مى‌كند تا به پروردگارتان ايمان آوريد، و اگر مؤمن باشيد، بى‌شك [خدا] از شما پيمان گرفته است"
  57,9,"او همان كسى است كه بر بنده خود آيات روشنى فرو مى‌فرستد، تا شما را از تاريكيها به سوى نور بيرون كشاند. و در حقيقت، خدا [نسبت‌] به شما سخت رئوف و مهربان است"
  57,10,"و شما را چه شده كه در راه خدا انفاق نمى‌كنيد و [حال آنكه‌] ميراث آسمانها و زمين به خدا تعلق دارد؟ كسانى از شما كه پيش از فتح [مكه‌] انفاق و جهاد كرده‌اند، [با ديگران‌] يكسان نيستند. آنان از [حيث ]درجه بزرگتر از كسانى‌اند كه بعداً به انفاق و جهاد پرداخته‌اند. و خداوند به هر كدام وعده نيكو داده است، و خدا به آنچه مى‌كنيد آگاه است"
  57,11,"كيست آن كس كه به خدا وامى نيكو دهد تا [نتيجه‌اش را] براى وى دوچندان گرداند و او را پاداشى خوش باشد؟"
  57,12,"آن روز كه مردان و زنان مؤمن را مى‌بينى كه نورشان پيشاپيششان و به جانب راستشان دوان است. [به آنان گويند:] «امروز شما را مژده باد به باغهايى كه از زير [درختان‌] آن نهرها روان است، در آنها جاودانيد. اين است همان كاميابى بزرگ"
  57,13,"آن روز، مردان و زنان منافق به كسانى كه ايمان آورده‌اند مى‌گويند: «ما را مهلت دهيد تا از نورتان [اندكى‌] برگيريم.» گفته مى‌شود: «بازپس برگرديد و نورى درخواست كنيد.» آنگاه ميان آنها ديوارى زده مى‌شود كه آن را دروازه‌اى است: باطنش رحمت است و ظاهرش روى به عذاب دارد"
  57,14,"[دو رويان،] آنان را ندا درمى‌دهند: «آيا ما با شما نبوديم؟» مى‌گويند: «چرا، ولى شما خودتان را در بلا افكنديد و امروز و فردا كرديد و ترديد آورديد و آرزوها شما را غرّه كرد تا فرمان خدا آمد و [شيطان ]مغروركننده، شما را در باره خدا بفريفت"
  57,15,"پس امروز نه از شما و نه از كسانى كه كافر شده‌اند عوضى پذيرفته نمى‌شود: جايگاهتان آتش است؛ آن سزاوار شماست و چه بد سرانجامى است.»"
  57,16,"آيا براى كسانى كه ايمان آورده‌اند هنگام آن نرسيده كه دلهايشان به ياد خدا و آن حقيقتى كه نازل شده نرم [و فروتن‌] گردد و مانند كسانى نباشند كه از پيش بدانها كتاب داده شد و [عمر و] انتظار بر آنان به درازا كشيد، و دلهايشان سخت گرديد و بسيارى از آنها فاسق بودند؟"
  57,17,"بدانيد كه خدا زمين را پس از مرگش زنده مى‌گرداند. به راستى آيات [خود] را براى شما روشن گردانيده‌ايم، باشد كه بينديشيد"
  57,18,"در حقيقت، مردان و زنان صدقه‌دهنده و [آنان كه‌] به خدا وامى نيكو داده‌اند، ايشان را [پاداش‌] دو چندان گردد، و اجرى نيكو خواهند داشت"
  57,19,"و كسانى كه به خدا و پيامبران وى ايمان آورده‌اند، آنان همان راستينانند و پيش پروردگارشان گواه خواهند بود [و] ايشان راست اجر و نورشان؛ و كسانى كه كفر ورزيده و آيات ما را تكذيب كرده‌اند آنان همدمان آتشند"
  57,20,"بدانيد كه زندگى دنيا، در حقيقت، بازى و سرگرمى و آرايش و فخرفروشى شما به يكديگر و فزون‌جويى در اموال و فرزندان است. [مثَل آنها] چون مثَل بارانى است كه كشاورزان را رستنى آن [باران‌] به شگفتى اندازد، سپس [آن كشت‌] خشك شود و آن را زرد بينى، آنگاه خاشاك شود. و در آخرت [دنيا پرستان را] عذابى سخت است و [مؤمنان را] از جانب خدا آمرزش و خشنودى است، و زندگانى دنيا جز كالاى فريبنده نيست"
  57,21,"[براى رسيدن‌] به آمرزشى از پروردگارتان و بهشتى كه پهنايش چون پهناى آسمان و زمين است [و] براى كسانى آماده شده كه به خدا و پيامبرانش ايمان آورده‌اند، بر يكديگر سبقت جوييد. اين فضل خداست كه به هر كس بخواهد آن را مى‌دهد، و خداوند را فزون‌بخشى بزرگ است"
  57,22,"هيچ مصيبتى نه در زمين و نه در نفسهاى شما [= به شما] نرسد، مگر آنكه پيش از آنكه آن را پديد آوريم، در كتابى است. اين [كار] بر خدا آسان است"
  57,23,"تا بر آنچه از دست شما رفته اندوهگين نشويد و به [سبب‌] آنچه به شما داده است شادمانى نكنيد، و خدا هيچ خودپسند فخرفروشى را دوست ندارد"
  57,24,همانان كه بخل مى‌ورزند و مردم را به بخل ورزيدن وامى‌دارند. و هر كه روى گرداند قطعاً خدا بى‌نياز ستوده است
  57,25,"به راستى [ما] پيامبران خود را با دلايل آشكار روانه كرديم و با آنها كتاب و ترازو را فرود آورديم تا مردم به انصاف برخيزند، و آهن را كه در آن براى مردم خطرى سخت و سودهايى است، پديد آورديم، تا خدا معلوم بدارد چه كسى در نهان، او و پيامبرانش را يارى مى‌كند. آرى، خدا نيرومند شكست ناپذير است"
  57,26,"و در حقيقت، نوح و ابراهيم را فرستاديم و در ميان فرزندان آن دو، نبوت و كتاب را قرار داديم: از آنها [برخى‌] راه‌ياب [شد]ند، و[لى‌] بسيارى از آنان بدكار بودند"
  57,27,"آنگاه به دنبال آنان پيامبران خود را، پى‌درپى، آورديم، و عيسى پسر مريم را در پى [آنان‌] آورديم و به او انجيل عطا كرديم، و در دلهاى كسانى كه از او پيروى كردند رأفت و رحمت نهاديم و [اما] ترك دنيايى كه از پيش خود درآوردند ما آن را بر ايشان مقرّر نكرديم مگر براى آنكه كسب خشنودى خدا كنند، با اين حال آن را چنانكه حقّ رعايت آن بود منظور نداشتند. پس پاداش كسانى از ايشان را كه ايمان آورده بودند بدانها داديم و[لى‌] بسيارى از آنان دستخوش انحرافند"
  57,28,"اى كسانى كه ايمان آورده‌ايد، از خدا پروا داريد و به پيامبر او بگرويد تا از رحمت خويش شما را دو بهره عطا كند و براى شما نورى قرار دهد كه به [بركت‌] آن راه سپريد و بر شما ببخشايد، و خدا آمرزنده مهربان است"
  57,29,"تا اهل كتاب بدانند كه به هيچ وجه فزون‌بخشى خدا در [حيطه‌] قدرت آنان نيست و فضل [و عنايت، تنها] در دست خداست: به هر كس بخواهد آن را عطا مى‌كند، و خدا داراى كرم بسيار است"
  58,1,"خدا گفتار [زنى‌] را كه در باره شوهرش با تو گفتگو و به خدا شكايت مى‌كرد شنيد؛ و خدا گفتگوى شما را مى‌شنود، زيرا خدا شنواى بيناست"
  58,2,"از ميان شما كسانى كه زنانشان را «ظهار» مى‌كنند [و مى‌گويند: پشت تو چون پشت مادر من است‌] آنان مادرانشان نيستند. مادران آنها تنها كسانى‌اند كه ايشان را زاده‌اند، و قطعاً آنها سخنى زشت و باطل مى‌گويند، و[لى‌] خدا مسلماً درگذرنده آمرزنده است"
  58,3,"و كسانى كه زنانشان را ظهار مى‌كنند، سپس از آنچه گفته‌اند پشيمان مى‌شوند، بر ايشان [فرض‌] است كه پيش از آنكه با يكديگر همخوابگى كنند، بنده‌اى را آزاد گردانند. اين [حكمى‌] است كه بدان پند داده مى‌شويد، و خدا به آنچه انجام مى‌دهيد آگاه است"
  58,4,"و آن كس كه [بر آزادكردن بنده‌] دسترسى ندارد، بايد پيش از تماس [با زن خود] دو ماه پياپى روزه بدارد؛ و هر كه نتواند، بايد شصت بينوا را خوراك بدهد. اين [حكم‌] براى آن است كه به خدا و فرستاده او ايمان بياوريد، و اين است حدود خدا. و كافران را عذابى پردرد خواهد بود"
  58,5,"بى‌گمان، كسانى كه با خدا و فرستاده او مخالفت مى‌كنند ذليل خواهند شد، همان‌گونه كه آنان كه پيش از ايشان بودند ذليل شدند، و به راستى آيات روشن [خود] را فرستاده‌ايم، و كافران را عذابى خفت‌آور خواهد بود"
  58,6,"روزى كه خداوند همه آنان را بر مى‌انگيزد و به آنچه كرده‌اند آگاهشان مى‌گرداند. خدا [كارهايشان را] برشمرده است و حال آنكه آنها آن را فراموش كرده‌اند، و خدا بر هر چيزى گواه است"
  58,7,"آيا ندانسته‌اى كه خدا آنچه را كه در آسمانها و آنچه را كه در زمين است مى‌داند؟ هيچ گفتگوى محرمانه‌اى ميان سه تن نيست مگر اينكه او چهارمين آنهاست، و نه ميان پنج تن مگر اينكه او ششمين آنهاست، و نه كمتر از اين [عدد] و نه بيشتر، مگر اينكه هر كجا باشند او با آنهاست. آنگاه روز قيامت آنان را به آنچه كرده‌اند آگاه خواهد گردانيد، زيرا خدا به هر چيزى داناست"
  58,8,"آيا كسانى را كه از نجوا منع شده بودند، نديدى كه باز بدانچه از آن منع گرديده‌اند، برمى‌گردند و با همديگر به [منظور] گناه و تعدّى و سرپيچى از پيامبر، محرمانه گفتگو مى‌كنند و چون به نزد تو آيند، تو را بدانچه خدا به آن [شيوه‌] سلام نگفته سلام مى‌دهند و در دلهاى خود مى‌گويند: «چرا به آنچه مى‌گوييم خدا ما را عذاب نمى‌كند؟» جهنم براى آنان كافى است؛ در آن درمى‌آيند، و چه بد سرانجامى است"
  58,9,"اى كسانى كه ايمان آورده‌ايد، چون با يكديگر محرمانه گفتگو مى‌كنيد، به [قصد] گناه و تعدى و نافرمانى پيامبر با همديگر محرمانه گفتگو نكنيد، و به نيكوكارى و پرهيزگارى نجوا كنيد، و از خدايى كه نزد او محشور خواهيد گشت پروا داريد"
  58,10,"چنان نجوايى صرفاً از [القاآت‌] شيطان است، تا كسانى را كه ايمان آورده‌اند دلتنگ گرداند، و[لى‌] جز به فرمان خدا هيچ آسيبى به آنها نمى‌رساند، و مؤمنان بايد بر خدا اعتماد كنند"
  58,11,"اى كسانى كه ايمان آورده‌ايد، چون به شما گفته شود: «در مجالس جاى باز كنيد»، پس جاى باز كنيد تا خدا براى شما گشايش حاصل كند، و چون گفته شود: «برخيزيد»، پس برخيزيد. خدا [رتبه‌] كسانى از شما را كه گرويده و كسانى را كه دانشمندند [بر حسب‌] درجات بلند گرداند، و خدا به آنچه مى‌كنيد آگاه است"
  58,12,"اى كسانى كه ايمان آورده‌ايد، هرگاه با پيامبر [خدا] گفتگوى محرمانه مى‌كنيد، پيش از گفتگوى محرمانه خود صدقه‌اى تقديم بداريد. اين [كار] براى شما بهتر و پاكيزه‌تر است؛ و اگر چيزى نيافتيد بدانيد كه خدا آمرزنده مهربان است"
  58,13,"آيا ترسيديد كه پيش از گفتگوى محرمانه خود صدقه‌هايى تقديم داريد؟ و چون نكرديد و خدا [هم‌] بر شما بخشود، پس نماز را برپا داريد و زكات را بدهيد و از خدا و پيامبر او فرمان بريد، و خدا به آنچه مى‌كنيد آگاه است"
  58,14,"آيا نديده‌اى كسانى را كه قومى را كه مورد خشم خدايند به دوستى گرفته‌اند؟ آنها نه از شمايند و نه از ايشان، و به دروغ سوگند ياد مى‌كنند و خودشان [هم‌] مى‌دانند"
  58,15,خدا براى آنان عذابى سخت آماده كرده است. راستى كه چه بد مى‌كردند
  58,16,"سوگندهاى خود را [چون‌] سپرى قرار داده بودند و [مردم را] از راه خدا بازداشتند و [در نتيجه‌] براى آنان عذابى خفت‌آور است"
  58,17,"در برابر خداوند نه از اموالشان و نه از اولادشان هرگز كارى ساخته نيست. آنها دوزخى‌اند [و] در آن جاودانه [مى‌مانند]"
  58,18,"روزى كه خدا همه آنان را برمى‌انگيزد، همان‌گونه كه براى شما سوگند ياد مى‌كردند براى او [نيز] سوگند ياد مى‌كنند و چنان پندارند كه حق به جانب آنهاست. آگاه باش كه آنان همان دروغگويانند"
  58,19,شيطان بر آنان چيره شده و خدا را از يادشان برده است؛ آنان حزب شيطانند. آگاه باش كه حزب شيطان همان زيانكارانند
  58,20,"در حقيقت، كسانى كه با خدا و پيامبر او به دشمنى برمى‌خيزند، آنان در [زمره‌] زبونان خواهند بود"
  58,21,"خدا مقرّر كرده است كه: «حتماً من و فرستادگانم چيره خواهيم گرديد.» آرى، خدا نيرومند شكست‌ناپذير است"
  58,22,"قومى را نيابى كه به خدا و روز بازپسين ايمان داشته باشند [و] كسانى را كه با خدا و رسولش مخالفت كرده‌اند -هر چند پدرانشان يا پسرانشان يا برادرانشان يا عشيره آنان باشند- دوست بدارند. در دل اينهاست كه [خدا] ايمان را نوشته و آنها را با روحى از جانب خود تأييد كرده است، و آنان را به بهشتهايى كه از زير [درختان‌] آن جويهايى روان است در مى‌آورد؛ هميشه در آنجا ماندگارند؛ خدا از ايشان خشنود و آنها از او خشنودند؛ اينانند حزب خدا. آرى، حزب خداست كه رستگارانند"
  59,1,آنچه در آسمانها و در زمين است تسبيح‌گوى خداى هستند، و اوست شكست‌ناپذير سنجيده‌كار
  59,2,"اوست كسى كه، از ميان اهل كتاب كسانى را كه كفر ورزيدند در نخستين اخراج [از مدينه‌] بيرون كرد. گمان نمى‌كرديد كه بيرون روند و خودشان گمان داشتند كه دژهايشان در برابر خدا مانع آنها خواهد بود، و[لى‌] خدا از آنجايى كه تصوّر نمى‌كردند بر آنان درآمد و در دلهايشان بيم افكند، [به طورى كه‌] خود به دست خود و دست مؤمنان خانه‌هاى خود را خراب مى‌كردند. پس اى ديده‌وران، عبرت گيريد"
  59,3,"و اگر خدا اين جلاى وطن را بر آنان مقرّر نكرده بود، قطعاً آنها را در دنيا عذاب مى‌كرد و در آخرت [هم‌] عذاب آتش داشتند"
  59,4,"اين [عقوبت‌] براى آن بود كه آنها با خدا و پيامبرش در افتادند؛ و هر كس با خدا درافتد؛ [بداند كه‌] خدا سخت‌كيفر است"
  59,5,"آنچه درخت خرما بريديد يا آنها را [دست نخورده‌] بر ريشه‌هايشان بر جاى نهاديد، به فرمان خدا بود، تا نافرمانان را خوار گرداند"
  59,6,"و آنچه را خدا از آنان به رسم غنيمت عايد پيامبر خود گردانيد، [شما براى تصاحب آن‌] اسب يا شترى بر آن نتاختيد، ولى خدا فرستادگانش را بر هر كه بخواهد چيره مى‌گرداند، و خدا بر هر كارى تواناست"
  59,7,"آنچه خدا از [دارايى‌] ساكنان آن قريه‌ها عايد پيامبرش گردانيد، از آن خدا و از آن پيامبر [او] و متعلق به خويشاوندان نزديك [وى‌] و يتيمان و بينوايان و درراه‌ماندگان است، تا ميان توانگران شما دست به دست نگردد. و آنچه را فرستاده [او] به شما داد، آن را بگيريد و از آنچه شما را باز داشت، بازايستيد و از خدا پروا بداريد كه خدا سخت‌كيفر است"
  59,8,"[اين غنايم، نخست‌] اختصاص به بينوايان مهاجرى دارد كه از ديارشان و اموالشان رانده شدند: خواستار فضل خدا و خشنودى [او] مى‌باشند و خدا و پيامبرش را يارى مى‌كنند. اينان همان مردم درست كردارند"
  59,9,"و [نيز] كسانى كه قبل از [مهاجران‌] در [مدينه‌] جاى گرفته و ايمان آورده‌اند؛ هر كس را كه به سوى آنان كوچ كرده دوست دارند؛ و نسبت به آنچه به ايشان داده شده است در دلهايشان حسدى نمى‌يابند؛ و هر چند در خودشان احتياجى [مبرم ]باشد، آنها را بر خودشان مقدّم مى‌دارند. و هر كس از خسّت نفس خود مصون ماند، ايشانند كه رستگارانند"
  59,10,"و [نيز] كسانى كه بعد از آنان [=مهاجران و انصار] آمده‌اند [و] مى‌گويند: «پروردگارا، بر ما و بر آن برادرانمان كه در ايمان آوردن بر ما پيشى گرفتند ببخشاى، و در دلهايمان نسبت به كسانى كه ايمان آورده‌اند [هيچ گونه‌] كينه‌اى مگذار! پروردگارا، راستى كه تو رئوف و مهربانى.»"
  59,11,"مگر كسانى را كه به نفاق برخاستند نديدى كه به برادران اهل كتاب خود -كه از در كفر درآمده بودند- مى‌گفتند: «اگر اخراج شديد، حتماً با شما بيرون خواهيم آمد، و بر عليه شما هرگز از كسى فرمان نخواهيم برد؛ و اگر با شما جنگيدند، حتماً شما را يارى خواهيم كرد.» و خدا گواهى مى‌دهد كه قطعاً آنان دروغگويانند"
  59,12,"اگر [يهود] اخراج شوند، آنها با ايشان بيرون نخواهند رفت، و اگر با آنان جنگيده شود [منافقان،] آنها را يارى نخواهند كرد، و اگر ياريشان كنند حتماً [در جنگ‌] پشت خواهند كرد و [ديگر] يارى نيابند"
  59,13,شما قطعاً در دلهاى آنان بيش از خدا مايه هراسيد، چرا كه آنان مردمانى‌اند كه نمى‌فهمند
  59,14,"[آنان، به صورت‌] دسته جمعى، جز در قريه‌هايى كه داراى استحكاماتند، يا از پشت ديوارها، با شما نخواهند جنگيد. جنگشان ميان خودشان سخت است. آنان را متحد مى‌پندارى و[لى‌] دلهايشان پراكنده است، زيرا آنان مردمانى‌اند كه نمى‌انديشند"
  59,15,"درست مانند همان كسانى كه اخيرا [در واقعه بدر] سزاى كار [بد] خود را چشيدند؛ و آنان را عذاب دردناكى خواهد بود"
  59,16,"چون حكايت شيطان كه به انسان گفت: «كافر شو.» و چون [وى‌] كافر شد، گفت: «من از تو بيزارم، زيرا من از خدا، پروردگار جهانيان، مى‌ترسم.»"
  59,17,و فرجام هردوشان آن است كه هر دو در آتش، جاويد مى‌مانند؛ و سزاى ستمگران اين است
  59,18,"اى كسانى كه ايمان آورده‌ايد، از خدا پروا داريد؛ و هر كسى بايد بنگرد كه براى فردا[ى خود] از پيش چه فرستاده است؛ و [باز] از خدا بترسيد. در حقيقت، خدا به آنچه مى‌كنيد آگاه است"
  59,19,"و چون كسانى مباشيد كه خدا را فراموش كردند و او [نيز] آنان را دچار خودفراموشى كرد؛ آنان همان نافرمانانند"
  59,20,دوزخيان با بهشتيان يكسان نيستند؛ بهشتيانند كه كاميابانند
  59,21,"اگر اين قرآن را بر كوهى فرومى‌فرستاديم، يقيناً آن [كوه‌] را از بيم خدا فروتن [و] از هم‌پاشيده مى‌ديدى. و اين مَثَلها را براى مردم مى‌زنيم، باشد كه آنان بينديشند"
  59,22,اوست خدايى كه غير از او معبودى نيست، داننده غيب و آشكار است، اوست رحمتگر مهربان
  59,23,"اوست خدايى كه جز او معبودى نيست، همان فرمانرواى پاك سلامت‌[بخش، و] مؤمن [به حقيقت حقه خود كه‌] نگهبان، عزيز، جبّار [و] متكبّر [است‌]. پاك است خدا از آنچه [با او] شريك مى‌گردانند"
  59,24,"اوست خداى خالق نوساز صورتگر [كه‌] بهترين نامها [و صفات‌] از آنِ اوست. آنچه در آسمانها و زمين است [جمله‌] تسبيح او مى‌گويند و او عزيز حكيم است"
  60,1,"اى كسانى كه ايمان آورده‌ايد، دشمن من و دشمن خودتان را به دوستى برمگيريد [به طورى‌] كه با آنها اظهار دوستى كنيد، و حال آنكه قطعاً به آن حقيقت كه براى شما آمده كافرند [و] پيامبر [خدا] و شما را [از مكه‌] بيرون مى‌كنند كه [چرا ]به خدا، پروردگارتان ايمان آورده‌ايد، اگر براى جهاد در راه من و طلب خشنودى من بيرون آمده‌ايد. [شما] پنهانى با آنان رابطه دوستى برقرار مى‌كنيد در حالى كه من به آنچه پنهان داشتيد و آنچه آشكار نموديد داناترم. و هر كس از شما چنين كند، قطعاً از راه درست منحرف گرديده است"
  60,2,اگر بر شما دست يابند، دشمن شما باشند و بر شما به بدى دست و زبان بگشايند و آرزو دارند كه كافر شويد
  60,3,"روز قيامت نه خويشان شما و نه فرزندانتان هرگز به شما سود نمى‌رسانند. [خدا] ميانتان فيصله مى‌دهد، و خدا به آنچه انجام مى‌دهيد بيناست"
  60,4,"قطعاً براى شما در [پيروى از] ابراهيم و كسانى كه با اويند سرمشقى نيكوست: آنگاه كه به قوم خود گفتند: «ما از شما و از آنچه به جاى خدا مى‌پرستيد بيزاريم. به شما كفر مى‌ورزيم و ميان ما و شما دشمنى و كينه هميشگى پديدار شده تا وقتى كه فقط به خدا ايمان آوريد.» جز [در] سخن ابراهيم [كه‌] به [نا]پدر[ى‌] خود [گفت:] «حتماً براى تو آمرزش خواهم خواست، با آنكه در برابر خدا اختيار چيزى را براى تو ندارم.» «اى پروردگار ما! بر تو اعتماد كرديم و به سوى تو بازگشتيم و فرجام به سوى توست"
  60,5,"پروردگارا، ما را وسيله آزمايش [و آماج آزار] براى كسانى كه كفر ورزيده‌اند مگردان، و بر ما ببخشاى كه تو خود تواناى سنجيده‌كارى.»"
  60,6,"قطعاً براى شما در [پيروى از] آنان سرمشقى نيكوست [يعنى‌] براى كسى كه به خدا و روز بازپسين اميد مى‌بندد. و هر كس روى برتابد [بداند كه‌] خدا همان بى‌نياز ستوده‌[صفات‌] است"
  60,7,"اميد است كه خدا ميان شما و ميان كسانى از آنان كه [ايشان را] دشمن داشتيد، دوستى برقرار كند، و خدا تواناست، و خدا آمرزنده مهربان است"
  60,8,"[اما] خدا شما را از كسانى كه در [كار] دين با شما نجنگيده و شما را از ديارتان بيرون نكرده‌اند، باز نمى‌دارد كه با آنان نيكى كنيد و با ايشان عدالت ورزيد، زيرا خدا دادگران را دوست مى‌دارد"
  60,9,"فقط خدا شما را از دوستى با كسانى باز مى‌دارد كه در [كار] دين با شما جنگ كرده و شما را از خانه‌هايتان بيرون رانده و در بيرون‌راندنتان با يكديگر همپشتى كرده‌اند. و هر كس آنان را به دوستى گيرد، آنان همان ستمگرانند"
  60,10,"اى كسانى كه ايمان آورده‌ايد، چون زنان با ايمان مهاجر، نزد شما آيند آنان را بيازماييد. خدا به ايمان آنان داناتر است. پس اگر آنان را باايمان تشخيص داديد، ديگر ايشان را به سوى كافران بازنگردانيد: نه آن زنان بر ايشان حلالند و نه آن [مردان‌] بر اين زنان حلال. و هر چه خرج [اين زنان‌] كرده‌اند به [شوهران‌] آنها بدهيد، و بر شما گناهى نيست كه -در صورتى كه مَهرشان را به آنان بدهيد- با ايشان ازدواج كنيد، و به پيوندهاى قبلى كافران متمسك نشويد [و پايبند نباشيد ]و آنچه را شما [براى زنان مرتد و فرارى خود كه به كفار پناهنده شده‌اند] خرج كرده‌ايد، [از كافران‌] مطالبه كنيد، و آنها هم بايد آنچه را خرج كرده‌اند [از شما] مطالبه كنند. اين حكم خداست [كه‌] ميان شما داورى مى‌كند، و خدا داناى حكيم است"
  60,11,"و در صورتى كه [زنى‌] از همسران شما به سوى كفار رفت [و كفار مَهر مورد مطالبه شما را ندادند] و شما غنيمت يافتيد؛ پس به كسانى كه همسرانشان رفته‌اند، معادل آنچه خرج كرده‌اند بدهيد، و از آن خدايى كه به او ايمان داريد بترسيد"
  60,12,"اى پيامبر، چون زنان باايمان نزد تو آيند كه [با اين شرط] با تو بيعت كنند كه چيزى را با خدا شريك نسازند، و دزدى نكنند، و زنا نكنند، و فرزندان خود را نكشند، و بچه‌هاى حرامزاده پيش دست و پاى خود را با بهتان [و حيله‌] به شوهر نبندند، و در [كار] نيك از تو نافرمانى نكنند، با آنان بيعت كن و از خدا براى آنان آمرزش بخواه، زيرا خداوند آمرزنده مهربان است"
  60,13,اى كسانى كه ايمان آورده‌ايد، مردمى را كه خدا بر آنان خشم رانده، به دوستى مگيريد. آنها واقعاً از آخرت سلب اميد كرده‌اند، همان گونه كه كافران اهل گور قطع اميد نموده‌اند
  61,1,آنچه در آسمانها و آنچه در زمين است به تسبيح خدا مى‌پردازند، و اوست ارجمند حكيم
  61,2,اى كسانى كه ايمان آورده‌ايد، چرا چيزى مى‌گوييد كه انجام نمى‌دهيد؟
  61,3,نزد خدا سخت ناپسند است كه چيزى را بگوييد و انجام ندهيد
  61,4,در حقيقت، خدا دوست دارد كسانى را كه در راه او صف در صف، چنانكه گويى بنايى ريخته شده از سرب‌اند، جهاد مى‌كنند
  61,5,"و [ياد كن‌] هنگامى را كه موسى به قوم خود گفت: «اى قوم من، چرا آزارم مى‌دهيد، با اينكه مى‌دانيد من فرستاده خدا به سوى شما هستم؟» پس چون [از حق‌] برگشتند، خدا دلهايشان را برگردانيد، و خدا مردم نافرمان را هدايت نمى‌كند"
  61,6,"و هنگامى را كه عيسى پسر مريم گفت: «اى فرزندان اسرائيل، من فرستاده خدا به سوى شما هستم. تورات را كه پيش از من بوده تصديق مى‌كنم و به فرستاده‌اى كه پس از من مى‌آيد و نام او «احمد» است بشارتگرم.» پس وقتى براى آنان دلايل روشن آورد، گفتند: «اين سحرى آشكار است.»"
  61,7,و چه كسى ستمگرتر از آن كس است كه با وجود آنكه به سوى اسلام فراخوانده مى شود، بر خدا دروغ مى‌بندد؟ و خدا مردم ستمگر را راه نمى‌نمايد
  61,8,مى‌خواهند نور خدا را با دهان خود خاموش كنند و حال آنكه خدا -گر چه كافران را ناخوش افتد- نور خود را كامل خواهد گردانيد
  61,9,اوست كسى كه فرستاده خود را با هدايت و آيين درست روانه كرد، تا آن را بر هر چه دين است فائق گرداند، هر چند مشركان را ناخوش آيد
  61,10,اى كسانى كه ايمان آورده‌ايد، آيا شما را بر تجارتى راه نمايم كه شما را از عذابى دردناك مى‌رهاند؟
  61,11,"به خدا و فرستاده او بگرويد و در راه خدا با مال و جانتان جهاد كنيد. اين [گذشت و فداكارى‌] اگر بدانيد، براى شما بهتر است"
  61,12,"تا گناهانتان را بر شما ببخشايد، و شما را در باغهايى كه از زير [درختان‌] آن جويبارها روان است و [در] سراهايى خوش، در بهشتهاى هميشگى درآورد. اين [خود] كاميابى بزرگ است"
  61,13,"و [رحمتى‌] ديگر كه آن را دوست داريد: يارى و پيروزى نزديكى از جانب خداست. و مؤمنان را [بدان‌] بشارت ده"
  61,14,"اى كسانى كه ايمان آورده‌ايد، ياران خدا باشيد، همان گونه كه عيسى‌بن‌مريم به حواريون گفت: «ياران من در راه خدا چه كسانى‌اند؟» حواريون گفتند: «ما ياران خداييم.» پس طايفه‌اى كفر ورزيدند، و كسانى را كه گرويده بودند، بر دشمنانشان يارى كرديم تا چيره شدند"
  62,1,آنچه در آسمانها و آنچه در زمين است، خدايى را كه پادشاه پاك ارجمند فرزانه است، تسبيح مى‌گويند
  62,2,"اوست آن كس كه در ميان بى‌سوادان فرستاده‌اى از خودشان برانگيخت، تا آيات او را بر آنان بخواند و پاكشان گرداند و كتاب و حكمت بديشان بياموزد، و [آنان‌] قطعاً پيش از آن در گمراهى آشكارى بودند"
  62,3,"و [نيز بر جماعتهايى‌] ديگر از ايشان كه هنوز به آنها نپيوسته‌اند. و اوست ارجمند سنجيده‌كار"
  62,4,اين فضل خداست، آن را به هر كه بخواهد عطا مى‌كند و خدا داراى فضل بسيار است
  62,5,"مثل كسانى كه [عمل به‌] تورات بر آنان بار شد [و بدان مكلف گرديدند] آنگاه آن را به كار نبستند، همچون مثل خرى است كه كتابهايى را برپشت مى‌كشد. [وه‌] چه زشت است وصف آن قومى كه آيات خدا را به دروغ گرفتند. و خدا مردم ستمگر را راه نمى‌نمايد"
  62,6,"بگو: «اى كسانى كه يهودى شده‌ايد، اگر پنداريد كه شما دوستان خداييد نه مردم ديگر، پس اگر راست مى‌گوييد درخواست مرگ كنيد.»"
  62,7,"و[لى‌] هرگز آن را به سبب آنچه از پيش به دست خويش كرده‌اند، آرزو نخواهند كرد، و خدا به [حال‌] ستمگران داناست"
  62,8,"بگو: «آن مرگى كه از آن مى‌گريزيد، قطعاً به سر وقت شما مى‌آيد؛ آنگاه به سوى داناى نهان و آشكار بازگردانيده خواهيد شد، و به آنچه [در روى زمين‌] مى‌كرديد، آگاهتان خواهد كرد.»"
  62,9,اى كسانى كه ايمان آورده‌ايد، چون براى نماز جمعه ندا درداده شد، به سوى ذكر خدا بشتابيد، و داد و ستد را واگذاريد. اگر بدانيد اين براى شما بهتر است
  62,10,"و چون نماز گزارده شد، در [روى‌] زمين پراكنده گرديد و فضل خدا را جويا شويد و خدا را بسيار ياد كنيد، باشد كه شما رستگار گرديد"
  62,11,"و چون داد و ستد يا سرگرميى ببينند، به سوى آن روى‌آور مى‌شوند، و تو را در حالى كه ايستاده‌اى ترك مى‌كنند. بگو: «آنچه نزد خداست از سرگرمى و از داد و ستد بهتر است، و خدا بهترين روزى دهندگان است.»"
  63,1,"چون منافقان نزد تو آيند گويند: «گواهى مى‌دهيم كه تو واقعاً پيامبر خدايى.» و خدا [هم‌] مى‌داند كه تو واقعاً پيامبر او هستى، و خدا گواهى مى‌دهد كه مردم دوچهره سخت دروغگويند"
  63,2,"سوگندهاى خود را [چون‌] سپرى بر خود گرفته و [مردم را] از راه خدا بازداشته‌اند. راستى كه آنان چه بد مى‌كنند"
  63,3,"اين بدان سبب است كه آنان ايمان آورده، سپس به انكار پرداخته‌اند و در نتيجه بر دلهايشان مُهر زده شده و [ديگر] نمى‌فهمند"
  63,4,"و چون آنان را ببينى، هيكلهايشان تو را به تعجب وا مى‌دارد، و چون سخن گويند به گفتارشان گوش فرا مى‌دهى گويى آنان شمعك‌هايى پشت بر ديوارند [كه پوك شده و درخور اعتماد نيستند]: هر فريادى را به زيان خويش مى‌پندارند. خودشان دشمنند؛ از آنان بپرهيز؛ خدا بكشدشان؛ تا كجا [از حقيقت‌] انحراف يافته‌اند"
  63,5,"و چون بديشان گفته شود: «بياييد تا پيامبر خدا براى شما آمرزش بخواهد»، سرهاى خود را بر مى‌گردانند، و آنان را مى‌بينى كه تكبركنان روى برمى‌تابند"
  63,6,"براى آنان يكسان است: چه برايشان آمرزش بخواهى يا برايشان آمرزش نخواهى، خدا هرگز بر ايشان نخواهد بخشود. خدا فاسقان را راهنمايى نمى‌كند"
  63,7,"آنان كسانى‌اند كه مى‌گويند: «به كسانى كه نزد پيامبر خدايند انفاق مكنيد تا پراكنده شوند، و حال آنكه گنجينه‌هاى آسمانها و زمين از آنِ خداست ولى منافقان درنمى‌يابند"
  63,8,"مى‌گويند: «اگر به مدينه برگرديم، قطعاً آنكه عزتمندتر است آن زبون‌تر را از آنجا بيرون خواهد كرد.» و[لى‌] عزت از آن خدا و از آن پيامبر او و از آن مؤمنان است؛ ليكن اين دورويان نمى‌دانند"
  63,9,"اى كسانى كه ايمان آورده‌ايد، [زنهار] اموال شما و فرزندانتان شما را از ياد خدا غافل نگرداند، و هر كس چنين كند، آنان خود زيانكارانند"
  63,10,"و از آنچه روزى شما گردانيده‌ايم، انفاق كنيد، پيش از آنكه يكى از شما را مرگ فرا رسد و بگويد: «پروردگارا، چرا تا مدتى بيشتر [اجل‌] مرا به تأخير نينداختى تا صدقه دهم و از نيكوكاران باشم؟»"
  63,11,"و[لى‌] هر كس اجلش فرا رسد، هرگز خدا [آن را] به تأخير نمى‌افكند، و خدا به آنچه مى‌كنيد آگاه است"
  64,1,هر چه در آسمانها و هر چه در زمين است خدا را تسبيح مى‌گويند. او راست فرمانروايى و او راست سپاس و او بر هر چيزى تواناست
  64,2,اوست آن كس كه شما را آفريد؛ برخى از شما كافرند و برخى مؤمن و خدا به آنچه مى‌كنيد بيناست
  64,3,آسمانها و زمين را به حق آفريد و شما را صورتگرى كرد و صورتهايتان را نيكوآراست، و فرجام به سوى اوست
  64,4,"آنچه را كه در آسمانها و زمين است مى‌داند، و آنچه را كه پنهان مى‌كنيد و آنچه را كه آشكار مى‌داريد [نيز] مى‌داند، و خدا به راز دلها داناست"
  64,5,آيا خبر كسانى كه پيش از اين كفر ورزيدند، و فرجام بد كارشان را چشيدند و عذاب پر دردى خواهند داشت، به شما نرسيده است؟
  64,6,"اين [بدفرجامى‌] از آن روى بود كه پيامبرانشان دلايل آشكار برايشان مى‌آوردند و[لى‌] آنان [مى‌]گفتند: «آيا بشرى ما را هدايت مى‌كند؟» پس كافر شدند و روى گردانيدند و خدا بى‌نيازى نمود، و خدا بى‌نياز ستوده‌است"
  64,7,"كسانى كه كفر ورزيدند، پنداشتند كه هرگز برانگيخته نخواهند شد. بگو: «آرى، سوگند به پروردگارم، حتماً برانگيخته خواهيد شد، سپس شما را به [حقيقت‌] آنچه كرده‌ايد قطعاً واقف خواهند ساخت، و اين بر خدا آسان است.»"
  64,8,پس به خدا و پيامبر او و آن نورى كه ما فرو فرستاديم ايمان آوريد، و خدا به آنچه مى‌كنيد آگاه است
  64,9,"روزى كه شما را براى روز گردآورى، گرد مى‌آورد، آن [روز]، روز حسرت [خوردن‌] است، و هر كس به خدا ايمان آورده، و كار شايسته‌اى كرده باشد، بديهايش را از او بسترد، و او را در بهشتهايى كه از زير [درختان‌] آن جويبارها روان است درآورد. در آنجا بمانند. اين است همان كاميابى بزرگ"
  64,10,"و كسانى كه كفر ورزيده، و آيات ما را تكذيب كرده‌اند، آنان اهل آتشند [و ] در آن ماندگار خواهند بود، و چه بد سرانجامى است"
  64,11,"هيچ مصيبتى جز به اذن خدا نرسد، و كسى كه به خدا بگرود، دلش را به راه آورد، و خدا[ست كه‌] به هر چيزى داناست"
  64,12,"و خدا را فرمان بريد و پيامبر [او] را اطاعت نماييد، و اگر روى بگردانيد، بر پيامبر ما فقط پيام‌رسانى آشكار است"
  64,13,"خدا[ست كه‌] جز او معبودى نيست، و مؤمنان بايد تنها بر خدا اعتماد كنند"
  64,14,اى كسانى كه ايمان آورده‌ايد، در حقيقت برخى از همسران شما و فرزندان شما دشمن شمايند، از آنان بر حذر باشيد، و اگر ببخشاييد و درگذريد و بيامرزيد، به راستى خدا آمرزنده مهربان است
  64,15,"اموال شما و فرزندانتان صرفاً [وسيله‌] آزمايشى [براى شما]يند، و خداست كه نزد او پاداشى بزرگ است"
  64,16,"پس تا مى‌توانيد از خدا پروا بداريد و بشنويد و فرمان ببريد، و مالى براى خودتان [در راه خدا] انفاق كنيد، و كسانى كه از خسّت نفس خويش مصون مانند، آنان رستگارانند"
  64,17,"اگر خدا را وامى نيكو دهيد، آن را براى شما دو چندان مى‌گرداند و بر شما مى‌بخشايد، و خدا[ست كه‌] سپاس‌پذير بردبار است"
  64,18,"داناى نهان و آشكار [و] ارجمند سنجيده‌كار است"
  65,1,"اى پيامبر، چون زنان را طلاق گوييد، در [زمان‌بندى‌] عدّه آنان طلاقشان گوييد و حساب آن عدّه را نگه داريد، و از خدا، پروردگارتان بترسيد. آنان را از خانه‌هايشان بيرون مكنيد، و بيرون نروند مگر آنكه مرتكب كار زشت آشكارى شده باشند. اين است احكام الهى. و هر كس از مقررات خدا [پاى‌] فراتر نهد، قطعاً به خودش ستم كرده است. نمى‌دانى، شايد خدا پس از اين، پيشامدى پديد آورد"
  65,2,"پس چون عدّه آنان به سر رسيد، [يا] به شايستگى نگاهشان داريد، يا به شايستگى از آنان جدا شويد، و دو تن [مرد] عادل را از ميان خود گواه گيريد، و گواهى را براى خدا به پا داريد. اين است اندرزى كه به آن كس كه به خدا و روز بازپسين ايمان دارد، داده مى‌شود، و هر كس از خدا پروا كند، [خدا] براى او راه بيرون‌شدنى قرار مى‌دهد"
  65,3,و از جايى كه حسابش را نمى‌كند، به او روزى مى‌رساند، و هر كس بر خدا اعتماد كند او براى وى بس است. خدا فرمانش را به انجام‌رساننده است. به راستى خدا براى هر چيزى اندازه‌اى مقرر كرده است
  65,4,"و آن زنان شما كه از خون‌ديدن [ماهانه‌] نوميدند، اگر شك داريد [كه خون مى‌بينند يا نه؟] عدّه آنان سه ماه است، و [دخترانى‌] كه [هنوز] خون نديده‌اند [نيز عدّه‌شان سه ماه است‌]، و زنان آبستن مدّتشان اين است كه وضع حمل كنند، و هر كس از خدا پروا دارد [خدا] براى او در كارش تسهيلى فراهم سازد"
  65,5,اين است فرمان خدا كه آن را به سوى شما فرستاده است؛ و هر كس از خدا پروا كند، بديهايش را از او بزدايد و پاداشش را بزرگ گرداند
  65,6,"همانجا كه [خود] سكونت داريد، به قدر استطاعت خويش آنان را جاى دهيد و به آنها آسيب [و زيان‌] مرسانيد تا عرصه را بر آنان تنگ كنيد. و اگر باردارند خرجشان را بدهيد تا وضع حمل كنند. و اگر براى شما [بچه‌] شير مى‌دهند مزدشان را به ايشان بدهيد و به شايستگى ميان خود به مشورت پردازيد، و اگر كارتان [در اين مورد] با هم به دشوارى كشيد [زن‌] ديگرى [بچّه را] شير دهد"
  65,7,"بر توانگر است كه از دارايى خود هزينه كند، و هر كه روزى او تنگ باشد بايد از آنچه خدا به او داده خرج كند. خدا هيچ كس را جز [به قدر] آنچه به او داده است تكليف نمى‌كند. خدا به زودى پس از دشوارى آسانى فراهم مى‌كند"
  65,8,"و چه بسيار شهرها كه از فرمان پروردگار خود و پيامبرانش سر پيچيدند و از آنها حسابى سخت كشيديم و آنان را به عذابى [بس‌] زشت عذاب كرديم"
  65,9,تا كيفر زشت عمل خود را چشيدند، و پايان كارشان زيان بود
  65,10,خدا براى آنان عذابى سخت آماده كرده است. پس اى خردمندانى كه ايمان آورده‌ايد، از خدا بترسيد. راستى كه خدا سوى شما تذكارى فرو فرستاده است
  65,11,"پيامبرى كه آيات روشنگر خدا را بر شما تلاوت مى‌كند، تا كسانى را كه ايمان آورده و كارهاى شايسته كرده‌اند از تاريكيها به سوى روشنايى بيرون برد، و هر كس به خدا بگرود و كار شايسته كند او را در باغهايى كه از زير [درختان‌] آن جويبارها روان است، درمى‌آورد، جاودانه در آن مى‌مانند. قطعاً خدا روزى را براى او خوش كرده است"
  65,12,"خدا همان كسى است كه هفت آسمان و همانند آنها هفت زمين آفريد. فرمان [خدا] در ميان آنها فرود مى‌آيد، تا بدانيد كه خدا بر هر چيزى تواناست، و به راستى دانش وى هر چيزى را در بر گرفته است"
  66,1,"اى پيامبر، چرا براى خشنودى همسرانت، آنچه را خدا براى تو حلال گردانيده حرام مى‌كنى؟ خدا[ست كه‌] آمرزنده مهربان است"
  66,2,"قطعاً خدا براى شما [راه‌] گشودن سوگندهايتان را مقرر داشته است، و خدا سرپرست شماست، و اوست داناى حكيم"
  66,3,"و چون پيامبر با يكى از همسرانش سخنى نهانى گفت، و همين كه وى آن را [به زن ديگر] گزارش داد و خدا [پيامبر] را بر آن مطلع گردانيد [پيامبر] بخشى از آن را اظهار كرد و از بخشى [ديگر] اعراض نمود. پس چون [مطلب‌] را به آن [زن‌] خبر داد، وى گفت: «چه كسى اين را به تو خبر داده؟» گفت: «مرا آن داناى آگاه خبر داده است.»"
  66,4,"اگر [شما دو زن‌] به درگاه خدا توبه كنيد [بهتر است‌]، واقعاً دلهايتان انحراف پيدا كرده است. و اگر عليه او به يكديگر كمك كنيد، در حقيقت، خدا خود سرپرست اوست، و جبرئيل و صالح مؤمنان [نيز ياور اويند] و گذشته از اين، فرشتگان [هم ]پشتيبان [او] خواهند بود"
  66,5,"اگر پيامبر، شما را طلاق گويد، اميد است پروردگارش همسرانى بهتر از شما: مسلمان، مؤمن، فرمانبر، توبه كار، عابد، روزه‌دار، بيوه و دوشيزه به او عوض دهد"
  66,6,"اى كسانى كه ايمان آورده‌ايد، خودتان و كسانتان را از آتشى كه سوخت آن، مردم و سنگهاست حفظ كنيد: بر آن [آتش‌] فرشتگانى خشن [و] سختگير [گمارده شده‌] اند. از آنچه خدا به آنان دستور داده سرپيچى نمى‌كنند و آنچه را كه مأمورند انجام مى‌دهند"
  66,7,اى كسانى كه كافر شده‌ايد، امروز عذر نياوريد، در واقع به آنچه مى‌كرديد كيفر مى‌يابيد
  66,8,"اى كسانى كه ايمان آورده‌ايد، به درگاه خدا توبه‌اى راستين كنيد، اميد است كه پروردگارتان بديهايتان را از شما بزدايد و شما را به باغهايى كه از زير [درختان‌] آن جويبارها روان است درآورد. در آن روز خدا پيامبر [خود] و كسانى را كه با او ايمان آورده بودند خوار نمى‌گرداند: نورشان از پيشاپيش آنان، و سمت راستشان، روان است. مى‌گويند: «پروردگارا، نور ما را براى ما كامل گردان و بر ما ببخشاى، كه تو بر هر چيز توانايى.»"
  66,9,"اى پيامبر، با كافران و منافقان جهاد كن و بر آنان سخت گير [كه‌] جاى ايشان در جهنّم خواهد بود و چه بد سرانجامى است"
  66,10,"خدا براى كسانى كه كفر ورزيده‌اند، آن نوح و آن لوط را مَثَل آورده [كه‌] هر دو در نكاح دو بنده از بندگان شايسته ما بودند و به آنها خيانت كردند، و كارى از دست [شوهران‌] آنها در برابر خدا ساخته نبود، و گفته شد: «با داخل شوندگان داخل آتش شويد.»"
  66,11,"و براى كسانى كه ايمان آورده‌اند، خدا همسر فرعون را مثل آورده، آنگاه كه گفت: «پروردگارا، پيش خود در بهشت خانه‌اى برايم بساز، و مرا از فرعون و كردارش نجات ده، و مرا از دست مردم ستمگر برهان.»"
  66,12,و مريم دخت عمران را، همان كسى كه خود را پاكدامن نگاه داشت و در او از روح خود دميديم و سخنان پروردگار خود و كتابهاى او را تصديق كرد و از فرمانبرداران بود
  67,1,"بزرگوار [و خجسته‌] است آنكه فرمانروايى به دست اوست و او بر هر چيزى تواناست"
  67,2,همانكه مرگ و زندگى را پديد آورد تا شما را بيازمايد كه كدامتان نيكوكارتريد، و اوست ارجمند آمرزنده
  67,3,"همان كه هفت آسمان را طبقه طبقه بيافريد. در آفرينش آن [خداى‌] بخشايشگر هيچ گونه اختلاف [و تفاوتى‌] نمى‌بينى. بازبنگر، آيا خلل [و نقصانى‌] مى‌بينى؟"
  67,4,باز دوباره بنگر تا نگاهت زبون و درمانده به سويت بازگردد
  67,5,"و در حقيقت، آسمان دنيا را با چراغهايى زينت داديم و آن را مايه طرد شياطين [= قواى مزاحم‌] گردانيديم و براى آنها عذاب آتش فروزان آماده كرده‌ايم"
  67,6,و كسانى كه به پروردگارشان انكار آوردند، عذاب آتش جهنم خواهند داشت و چه بد سرانجامى است
  67,7,چون در آنجا افكنده شوند، از آن خروشى مى‌شنوند در حالى كه مى‌جوشد
  67,8,"نزديك است كه از خشم شكافته شود. هر بار كه گروهى در آن افكنده شوند، نگاهبانان آن از ايشان پرسند: «مگر شما را هشدار دهنده‌اى نيامد؟»"
  67,9,"گويند: «چرا، هشدار دهنده‌اى به سوى ما آمد و[لى‌] تكذيب كرديم و گفتيم: خدا چيزى فرو نفرستاده است، شما جز در گمراهى بزرگ نيستيد.»"
  67,10,"و گويند: «اگر شنيده [و پذيرفته‌] بوديم يا تعقل كرده بوديم در [ميان‌] دوزخيان نبوديم.»"
  67,11,پس به گناه خود اقرار مى‌كنند. و مرگ باد بر اهل جهنم
  67,12,كسانى كه در نهان از پروردگارشان مى‌ترسند، آنان را آمرزش و پاداشى بزرگ خواهد بود
  67,13,"و [اگر] سخن خود را پنهان داريد، يا آشكارش نماييد، در حقيقت وى به راز دلها آگاه است"
  67,14,آيا كسى كه آفريده است نمى‌داند؟ با اينكه او خود باريك بين آگاه است
  67,15,"اوست كسى كه زمين را براى شما رام گردانيد، پس در فراخناى آن رهسپار شويد و از روزى [خدا] بخوريد و رستاخيز به سوى اوست"
  67,16,"آيا از آن كس كه در آسمان است ايمن شده‌ايد كه شما را در زمين فرو برد، پس بناگاه [زمين‌] به تپيدن افتد؟"
  67,17,"يا از آن كس كه در آسمان است ايمن شده‌ايد كه بر [سر] شما تندبادى از سنگريزه فرو فرستد؟ پس به زودى خواهيد دانست كه بيم دادن من چگونه است"
  67,18,"و پيش از آنان [نيز] كسانى به تكذيب پرداختند پس عذاب من چگونه بود؟"
  67,19,"آيا در بالاى سرشان به پرندگان ننگريسته‌اند [كه گاه‌] بال مى‌گسترند و [گاه‌] بال مى‌آنند؟ جز خداى رحمان [كسى‌] آنها را نگاه نمى‌دارد، او به هر چيزى بيناست"
  67,20,"يا آن كسى كه خود براى شما [چون‌] سپاهى است كه ياريتان مى‌كند، جز خداى رحمان كيست؟ كافران جز گرفتار فريب نيستند"
  67,21,"يا كيست آن كه به شما روزى دهد اگر [خدا] روزى خود را [از شما] باز دارد؟ [نه‌] بلكه در سركشى و نفرت پافشارى كردند"
  67,22,پس آيا آن كس كه نگونسار راه مى‌پيمايد هدايت يافته تر است يا آن كس كه ايستاده بر راه راست مى‌رود؟
  67,23,"بگو: «اوست آن كس كه شما را پديد آورده و براى شما گوش و ديدگان و دلها آفريده است. چه كم سپاسگزاريد.»"
  67,24,"بگو: «اوست كه شما را در زمين پراكنده كرده، و به نزد او [ست كه‌] گرد آورده خواهيد شد.»"
  67,25,"و مى‌گويند: «اگر راست مى‌گوييد، اين وعده كى خواهد بود؟»"
  67,26,"بگو: «علم [آن‌] فقط پيش خداست و من صرفاً هشدار دهنده‌اى آشكارم.»"
  67,27,"و آنگاه كه آن [لحظه موعود] را نزديك ببينند، چهره‌هاى كسانى كه كافر شده‌اند در هم رود، و گفته شود: «اين است همان چيزى كه آن را فرا مى‌خوانديد»"
  67,28,"بگو: «به من خبر دهيد، اگر خدا مرا و هر كه را با من است هلاك كند يا ما را مورد رحمت قرار دهد، چه كسى كافران را از عذابى پر درد پناه خواهد داد؟»"
  67,29,"بگو: «اوست خداى بخشايشگر، به او ايمان آورديم، و بر او توكل كرديم. و به زودى خواهيد دانست چه كسى است كه خود در گمراهى آشكارى است.»"
  67,30,"بگو: «به من خبر دهيد، اگر آب [آشاميدنى‌] شما [به زمين‌] فرو رود، چه كسى آب روان برايتان خواهد آورد؟»"
  68,1,نون، سوگند به قلم و آنچه مى‌نويسند،
  68,2,"[كه‌] تو، به لطف پروردگارت، ديوانه نيستى"
  68,3,و بى‌گمان، تو را پاداشى بى‌منت خواهد بود
  68,4,و راستى كه تو را خويى والاست
  68,5,به زودى خواهى ديد و خواهند ديد،
  68,6,"[كه‌] كدام يك از شما دستخوش جنونيد"
  68,7,"پروردگارت خود بهتر مى‌داند چه كسى از راه او منحرف شده، و [هم‌] او به راه يافتگان داناتر است"
  68,8,پس، از دروغزنان فرمان مبر
  68,9,دوست دارند كه نرمى كنى تا نرمى نمايند
  68,10,و از هر قسم خورنده فرو مايه‌اى فرمان مبر
  68,11,"[كه‌] عيبجوست و براى خبرچينى گام برمى‌دارد،"
  68,12,مانع خير، متجاوز، گناه پيشه،
  68,13,"گستاخ، [و] گذشته از آن زنازاده است،"
  68,14,به صرف اينكه مالدار و پسردار است،
  68,15,"چون آيات ما بر او خوانده شود، گويد: «افسانه‌هاى پيشينيان است.»"
  68,16,"زودا كه بر بينى‌اش داغ نهيم [و رسوايش كنيم‌]"
  68,17,"ما آنان را همان گونه كه باغداران را آزموديم، مورد آزمايش قرار داديم، آنگاه كه سوگند خوردند كه صبح برخيزند و [ميوه‌] آن [باغ‌] را حتماً بچينند"
  68,18,"و[لى‌] «ان شاء الله» نگفتند"
  68,19,"پس در حالى كه آنان غنوده بودند، بلايى از جانب پروردگارت بر آن [باغ‌] به گردش در آمد"
  68,20,"و [باغ،] آفت زده [و زمين باير] گرديد"
  68,21,"پس [باغداران‌] بامدادان يكديگر را صدا زدند،"
  68,22,"كه: «اگر ميوه مى‌چينيد، بامدادان به سوى كشت خويش رويد.»"
  68,23,پس به راه افتادند و آهسته به هم مى‌گفتند
  68,24,"«كه: امروز نبايد در باغ بينوايى بر شما در آيد.»"
  68,25,"و صبحگاهان در حالى كه خود را بر منع [بينوايان‌] توانا مى‌ديدند، رفتند"
  68,26,"و چون [باغ‌] را ديدند، گفتند: «قطعاً ما راه گم كرده‌ايم"
  68,27,"[نه‌] بلكه ما محروميم"
  68,28,"خردمندترينشان گفت: «آيا به شما نگفتم: چرا خدا را به پاكى نمى‌ستاييد؟»"
  68,29,"گفتند: «پروردگارا، تو را به پاكى مى‌ستاييم، ما واقعاً ستمگر بوديم. «"
  68,30,پس بعضى‌شان رو به بعضى ديگر آوردند و همديگر را به نكوهش گرفتند
  68,31,"گفتند: «اى واى بر ما كه سركش بوده‌ايم"
  68,32,اميد است كه پروردگار ما بهتر از آن را به ما عوض دهد، زيرا ما به پروردگارمان مشتاقيم
  68,33,"عذاب [دنيا] چنين است، و عذاب آخرت، اگر مى‌دانستند قطعاً بزرگتر خواهد بود"
  68,34,براى پرهيزگاران، نزد پروردگارشان باغستانهاى پر ناز و نعمت است
  68,35,پس آيا فرمانبرداران را چون بدكاران قرار خواهيم داد؟
  68,36,شما را چه شده؟ چگونه داورى مى‌كنيد؟
  68,37,يا شما را كتابى هست كه در آن فرا مى‌گيريد،
  68,38,كه هر چه را برمى‌گزينيد، براى شما در آن خواهد بود؟
  68,39,"يا اينكه شما تا روز قيامت [از ما] سوگندهايى رسا گرفته‌ايد كه هر چه دلتان خواست حكم كنيد؟"
  68,40,"از آنان بپرس: كدامشان ضامن اين [ادعا] يند؟"
  68,41,يا شريكانى دارند؟ پس اگر راست مى‌گويند شريكانشان را بياورند
  68,42,"روزى كه كار، زار [و رهايى دشوار] شود و به سجده فرا خوانده شوند و در خود توانايى نيابند"
  68,43,"ديدگانشان به زير افتاده، خوارى آنان را فرو مى‌گيرد، در حالى كه [پيش از اين‌] به سجده دعوت مى‌شدند و تندرست بودند"
  68,44,"پس مرا با كسى كه اين گفتار را تكذيب مى‌كند واگذار. به تدريج آنان را به گونه‌اى كه در نيابند [گريبان‌] خواهيم گرفت،"
  68,45,"و مهلتشان مى‌دهم، زيرا تدبير من [سخت‌] استوار است"
  68,46,آيا از آنان مزدى درخواست مى‌كنى، و آنان خود را زير بار تاوان، گرانبار مى‌يابند؟
  68,47,"يا [علم‌] غيب پيش آنهاست و آنها مى‌نويسند؟"
  68,48,"پس در [امتثال‌] حكم پروردگارت شكيبايى ورز، و مانند همدم ماهى [=يونس‌] مباش، آنگاه كه اندوه زده ندا درداد"
  68,49,"اگر لطفى از جانب پروردگارش تدارك [حال‌] او نمى‌كرد، قطعاً نكوهش شده بر زمين خشك انداخته مى‌شد"
  68,50,پس پروردگارش وى را برگزيد و از شايستگانش گردانيد
  68,51,"و آنان كه كافر شدند، چون قرآن را شنيدند چيزى نمانده بود كه تو را چشم بزنند، و مى‌گفتند: «او واقعاً ديوانه‌اى است.»"
  68,52,"و حال آنكه [قرآن‌] جز تذكارى براى جهانيان نيست"
  69,1,آن رخ دهنده
  69,2,چيست آن رخ دهنده؟
  69,3,و چه دانى كه آن رخ دهنده چيست؟
  69,4,ثمود و عاد، آن حادثه كوبنده را تكذيب كردند
  69,5,"اما ثمود به [سزاى‌] سركشى [خود] به هلاكت رسيدند"
  69,6,"و اما عاد، به [وسيله‌] تندبادى توفنده سركش هلاك شدند"
  69,7,"[كه خدا] آن را هفت شب و هشت روز پياپى بر آنان بگماشت: در آن [مدت‌] مردم را فرو افتاده مى‌ديدى، گويى آنها تنه‌هاى نخلهاى ميان تهى‌اند"
  69,8,آيا از آنان كسى را بر جاى مى‌بينى؟
  69,9,"و فرعون و كسانى كه پيش از او بودند و [مردم‌] شهرهاى سرنگون شده [سدوم و عاموره‌] مرتكب خطا شدند"
  69,10,"و از امر فرستاده پروردگارشان سرپيچى كردند، و [خدا هم‌] آنان را به گرفتنى سخت، فرو گرفت"
  69,11,ما، چون آب طغيان كرد، شما را بر كشتى سوار نموديم
  69,12,"تا آن را براى شما [مايه‌] تذكرى گردانيم و گوشهاى شنوا آن را نگاه دارد"
  69,13,پس آنگاه كه در صور يك بار دميده شود
  69,14,و زمين و كوه‌ها از جاى خود برداشته شوند و هر دوى آنها با يك تكان ريز ريز گردند
  69,15,"پس آن روز است كه واقعه [آنچنانى‌] وقوع يابد"
  69,16,و آسمان از هم بشكافد، و در آن روز است كه آن از هم گسسته باشد
  69,17,"و فرشتگان در اطراف [آسمان‌]اند، و عرش پروردگارت را آن روز، هشت [فرشته ] بر سر خود بر مى‌دارند"
  69,18,"در آن روز، شما [به پيشگاه خدا] عرضه مى‌شويد، [و] پوشيده‌اى از شما پوشيده نمى‌ماند"
  69,19,"اما كسى كه كارنامه‌اش به دست راستش داده شود، گويد: «بياييد و كتابم را بخوانيد"
  69,20,من يقين داشتم كه به حساب خود مى‌رسم
  69,21,پس او در يك زندگى خوش است
  69,22,در بهشتى برين،
  69,23,"[كه‌] ميوه هايش در دسترس است"
  69,24,"بخوريد و بنوشيد، گواراتان باد، به [پاداش‌] آنچه در روزهاى گذشته انجام داديد"
  69,25,"و اما كسى كه كارنامه‌اش به دست چپش داده شود، گويد: «اى كاش كتابم را دريافت نكرده بودم"
  69,26,و از حساب خود خبردار نشده بودم
  69,27,"اى كاش آن [مرگ‌] كار را تمام مى‌كرد"
  69,28,مال من، مرا سودى نبخشيد
  69,29,"قدرت من از [كف‌] من برفت"
  69,30,"[گويند:] «بگيريد او را و در غل كشيد"
  69,31,آنگاه ميان آتشش اندازيد
  69,32,پس در زنجيرى كه درازى آن هفتاد گز است وى را در بند كشيد
  69,33,چرا كه او به خداى بزرگ نمى‌گرويد
  69,34,و به اطعام مسكين تشويق نمى‌كرد
  69,35,پس امروز او را در اينجا حمايتگرى نيست
  69,36,و خوراكى جز چركابه ندارد،
  69,37,كه آن را جز خطاكاران نمى‌خورند
  69,38,"پس نه [چنان است كه مى‌پنداريد]، سوگند ياد مى‌كنم به آنچه مى‌بينيد،"
  69,39,و آنچه نمى‌بينيد،
  69,40,"كه [قرآن‌] قطعاً گفتار فرستاده‌اى بزرگوار است"
  69,41,"و آن گفتار شاعرى نيست [كه‌] كمتر [به آن‌] ايمان داريد"
  69,42,"و نه گفتار كاهنى [كه‌] كمتر [از آن‌] پند مى‌گيريد"
  69,43,"[پيام‌] فرودآمده‌اى است از جانب پروردگار جهانيان"
  69,44,"و اگر [او] پاره‌اى گفته‌ها بر ما بسته بود،"
  69,45,دست راستش را سخت مى‌گرفتيم،
  69,46,سپس رگ قلبش را پاره مى‌كرديم،
  69,47,"و هيچ يك از شما مانع از [عذاب‌] او نمى‌شد"
  69,48,"و در حقيقت، [قرآن‌] تذكارى براى پرهيزگاران است"
  69,49,"و ما به راستى مى‌دانيم كه از [ميان‌] شما تكذيب‌كنندگانى هستند"
  69,50,و آن واقعاً بر كافران حسرتى است
  69,51,"و اين [قرآن‌]، بى‌شبهه، حقيقتى يقينى است"
  69,52,"پس به [پاس‌] نام پروردگار بزرگت تسبيح گوى"
  70,1,پرسنده‌اى از عذاب واقع‌شونده‌اى پرسيد،
  70,2,"كه اختصاص به كافران دارد [و] آن را بازدارنده‌اى نيست"
  70,3,"[و] از جانب خداوند صاحب درجات [و مراتب‌] است"
  70,4,فرشتگان و روح، در روزى كه مقدارش پنجاه هزار سال است به سوى «او» بالا مى‌روند
  70,5,پس صبر كن، صبرى نيكو
  70,6,"زيرا آنان [عذاب‌] را دور مى‌بينند،"
  70,7,"و [ما] نزديكش مى‌بينيم"
  70,8,روزى كه آسمانها چون فلز گداخته شود،
  70,9,و كوهها چون پشم زده گردد،
  70,10,"و هيچ دوست صميمى از دوست صميمى [حال‌] نپرسد،"
  70,11,آنان را به ايشان نشان مى‌دهند. گناهكار آرزو مى‌كند كه كاش براى رهايى از عذاب آن روز، مى توانست پسران خود را عوض دهد،
  70,12,"و [نيز] همسرش و برادرش را،"
  70,13,و قبيله‌اش را كه به او پناه مى‌دهد،
  70,14,"و هر كه را كه در روى زمين است همه را [عوض مى‌داد] و آنگاه خود را رها مى‌كرد"
  70,15,"نه چنين است. [آتش‌] زبانه مى‌كشد،"
  70,16,پوست سر و اندام را بركننده است
  70,17,هر كه را پشت كرده و روى برتافته،
  70,18,"و گرد آورده و انباشته [و حسابش را نگاه داشته‌] فرا مى‌خواند"
  70,19,"به راستى كه انسان سخت آزمند [و بى‌تاب‌] خلق شده است"
  70,20,چون صدمه‌اى به او رسد عجز و لابه كند
  70,21,و چون خيرى به او رسد بخل ورزد
  70,22,غير از نمازگزاران
  70,23,همان كسانى كه بر نمازشان پايدارى مى‌كنند
  70,24,و همانان كه در اموالشان حقى معلوم است،
  70,25,براى سائل و محروم
  70,26,و كسانى كه روز جزا را باور دارند
  70,27,و آنان كه از عذاب پروردگارشان بيمناكند
  70,28,چرا كه از عذاب پروردگارشان ايمن نمى‌توانند بود
  70,29,و كسانى كه دامن خود را حفظ مى‌كنند،
  70,30,"مگر بر همسران خود يا كنيزانشان كه [در اين صورت‌] مورد نكوهش نيستند"
  70,31,"و هر كس پا از اين [حد] فراتر نهد، آنان همان از حد درگذرندگانند"
  70,32,و كسانى كه امانتها و پيمان خود را مراعات مى‌كنند
  70,33,و آنان كه بر شهادتهاى خود ايستاده‌اند
  70,34,و كسانى كه بر نمازشان مداومت مى‌ورزند
  70,35,"آنها هستند كه در باغهايى [از بهشت‌]، گرامى خواهند بود"
  70,36,چه شده است كه آنان كه كفر ورزيده‌اند، به سوى تو شتابان،
  70,37,"گروه گروه، از راست و از چپ [هجوم مى‌آورند]؟"
  70,38,آيا هر يك از آنان طمع مى‌بندد كه در بهشت پر نعمت درآورده شود؟
  70,39,"نه چنين است. ما آنان را از آنچه [خود] مى‌دانند آفريديم"
  70,40,"[هرگز،] به پروردگار خاوران و باختران سوگند ياد مى‌كنم كه ما تواناييم،"
  70,41,كه به جاى آنان بهتر از ايشان را بياوريم؛ و بر ما پيشى نتوانند جست
  70,42,پس بگذارشان ياوه گويند و بازى كنند تا روزى را كه وعده داده شده‌اند ملاقات نمايند
  70,43,"روزى كه از گورها[ى خود] شتابان برآيند، گويى كه آنان به سوى پرچمهاى افراشته مى دوند"
  70,44,"ديدگانشان فرو افتاده، [غبار] مذلّت آنان را فرو گرفته است. اين است همان روزى كه به ايشان وعده داده مى‌شد"
  71,1,"ما نوح را به سوى قومش فرستاديم كه: «قومت را، پيش از آنكه عذابى دردناك به آنان رسد، هشدار ده.»"
  71,2,"[نوح‌] گفت: «اى قوم من، من شما را هشدار دهنده‌اى آشكارم،"
  71,3,كه خدا را بپرستيد و از او پروا داريد و مرا فرمان بريد
  71,4,"[تا] برخى از گناهانتان را بر شما ببخشايد و [اجل‌] شما را تا وقتى معين به تأخير اندازد. اگر بدانيد، چون وقت مقرر خدا برسد، تأخير بر نخواهد داشت"
  71,5,"[نوح‌] گفت: «پروردگارا، من قوم خود را شب و روز دعوت كردم،"
  71,6,و دعوت من جز بر گريزشان نيفزود
  71,7,و من هر بار كه آنان را دعوت كردم تا ايشان را بيامرزى، انگشتانشان را در گوشهايشان كردند و رداى خويشتن بر سر كشيدند و اصرار ورزيدند و هر چه بيشتر بر كبر خود افزودند
  71,8,سپس من آشكارا آنان را دعوت كردم
  71,9,"باز من به آنان اعلام نمودم و در خلوت [و] پوشيده نيز به ايشان گفتم"
  71,10,"و گفتم: از پروردگارتان آمرزش بخواهيد كه او همواره آمرزنده است"
  71,11,"[تا] بر شما از آسمان باران پى در پى فرستد"
  71,12,و شما را به اموال و پسران، يارى كند، و برايتان باغها قرار دهد و نهرها براى شما پديد آورد
  71,13,شما را چه شده است كه از شكوه خدا بيم نداريد؟
  71,14,و حال آنكه شما را مرحله به مرحله خلق كرده است
  71,15,مگر ملاحظه نكرده‌ايد كه چگونه خدا هفت آسمان را تُوبرتُو آفريده است؟
  71,16,"و ماه را در ميان آنها روشنايى‌بخش گردانيد و خورشيد را [چون‌] چراغى قرار داد"
  71,17,"و خدا[ست كه‌] شما را [مانند] گياهى از زمين رويانيد؛"
  71,18,"سپس شما را در آن بازمى‌گرداند و بيرون مى‌آورد بيرون‌آوردنى [عجيب‌]"
  71,19,"و خدا زمين را براى شما فرشى [گسترده‌] ساخت،"
  71,20,تا در راههاى فراخ آن برويد.»
  71,21,"نوح گفت: «پروردگارا، آنان نافرمانى من كردند و كسى را پيروى نمودند كه مال و فرزندش جز بر زيان وى نيفزود"
  71,22,و دست به نيرنگى بس بزرگ زدند
  71,23,"و گفتند: زنهار، خدايان خود را رها مكنيد، و نه «وَدّ» را واگذاريد و نه «سُواع» و نه «يَغُوث» و نه «يَعُوق» و نه «نَسْر» را"
  71,24,"و بسيارى را گمراه كرده‌اند. [بار خدايا،] جز بر گمراهى ستمكاران ميفزاى.»"
  71,25,"[تا] به سبب گناهانشان غرقه گشتند و [پس از مرگ‌] در آتشى درآورده شدند و براى خود، در برابر خدا يارانى نيافتند"
  71,26,"و نوح گفت: «پروردگارا، هيچ كس از كافران را بر روى زمين مگذار،"
  71,27,چرا كه اگر تو آنان را باقى گذارى، بندگانت را گمراه مى‌كنند و جز پليدكار ناسپاس نزايند
  71,28,پروردگارا، بر من و پدر و مادرم و هر مؤمنى كه در سرايم درآيد، و بر مردان و زنان با ايمان ببخشاى، و جز بر هلاكت ستمگران ميفزاى.»
  72,1,"بگو: «به من وحى شده است كه تنى چند از جنّيان گوش فرا داشتند و گفتند: راستى ما قرآنى شگفت‌آور شنيديم"
  72,2,"[كه‌] به راه راست هدايت مى‌كند. پس به آن ايمان آورديم و هرگز كسى را شريك پروردگارمان قرار نخواهيم داد"
  72,3,و اينكه او، پروردگار والاى ما، همسر و فرزندى اختيار نكرده است
  72,4,"و [شگفت‌] آنكه كم خرد ما، در باره خدا سخنانى ياوه مى‌سرايد"
  72,5,و ما پنداشته بوديم كه انس و جن هرگز به خدا دروغ نمى‌بندند
  72,6,و مردانى از آدميان به مردانى از جن پناه مى‌بردند و بر سركشى آنها مى‌افزودند
  72,7,"و آنها [نيز] آن گونه كه [شما] پنداشته‌ايد، گمان بردند كه خدا هرگز كسى را زنده نخواهد گردانيد"
  72,8,و ما بر آسمان دست يافتيم و آن را پر از نگهبانان توانا و تيرهاى شهاب يافتيم
  72,9,"و در [آسمان‌] براى شنيدن، به كمين مى‌نشستيم، [اما] اكنون هر كه بخواهد به گوش باشد، تير شهابى در كمين خود مى‌يابد"
  72,10,"و ما [درست‌] نمى‌دانيم كه آيا براى كسانى كه در زمينند بدى خواسته شده يا پروردگارشان برايشان هدايت خواسته است؟"
  72,11,و از ميان ما برخى درستكارند و برخى غير آن، و ما فرقه‌هايى گوناگونيم
  72,12,"و ما مى‌دانيم كه هرگز نمى‌توانيم در زمين خداى را به ستوه آوريم، و هرگز او را با گريز [خود] درمانده نتوانيم كرد"
  72,13,"و ما چون هدايت را شنيديم بدان گرويديم؛ پس كسى كه به پروردگار خود ايمان آورد، از كمى [پاداش‌] و سختى بيم ندارد"
  72,14,"و از ميان ما برخى فرمانبردار و برخى از ما منحرفند: پس كسانى كه به فرمانند، آنان در جستجوى راه درستند،"
  72,15,ولى منحرفان، هيزم جهنم خواهند بود.»
  72,16,"و اگر [مردم‌] در راه درست، پايدارى ورزند، قطعاً آب گوارايى بديشان نوشانيم"
  72,17,"تا در اين باره آنان را بيازماييم، و هر كس از ياد پروردگار خود دل بگرداند، وى را در قيد عذابى [روز]افزون درآورد"
  72,18,و مساجد ويژه خداست، پس هيچ كس را با خدا مخوانيد
  72,19,و همين كه «بنده خدا» برخاست تا او را بخواند، چيزى نمانده بود كه بر سر وى فرو افتند
  72,20,"بگو: «من تنها پروردگار خود را مى‌خوانم و كسى را با او شريك نمى‌گردانم.»"
  72,21,"بگو: «من براى شما اختيار زيان و هدايتى را ندارم.»"
  72,22,"بگو: «هرگز كسى مرا در برابر خدا پناه نمى‌دهد و هرگز پناهگاهى غير از او نمى‌يابم"
  72,23,"[وظيفه من‌] تنها ابلاغى از خدا و [رساندن‌] پيامهاى اوست.» و هر كس خدا و پيامبرش را نافرمانى كند قطعاً آتش دوزخ براى اوست و جاودانه در آن خواهند ماند"
  72,24,"[باش‌] تا آنچه را وعده داده مى‌شوند ببينند، آنگاه دريابند كه ياور چه كسى ضعيف‌تر و كدام يك شماره‌اش كمتر است"
  72,25,"بگو: «نمى‌دانم آنچه را كه وعده داده شده‌ايد نزديك است يا پروردگارم براى آن زمانى نهاده است؟»"
  72,26,داناى نهان است، و كسى را بر غيب خود آگاه نمى‌كند،
  72,27,"جز پيامبرى را كه از او خشنود باشد، كه [در اين صورت‌] براى او از پيش رو و از پشت سرش نگاهبانانى بر خواهد گماشت،"
  72,28,"تا معلوم بدارد كه پيامهاى پروردگار خود را رسانيده‌اند؛ و [خدا] بدانچه نزد ايشان است احاطه دارد و هر چيزى را به عدد شماره كرده است"
  73,1,اى جامه به خويشتن فرو پيچيده،
  73,2,به پا خيز شب را مگر اندكى،
  73,3,نيمى از شب يا اندكى از آن را بكاه،
  73,4,"يا بر آن [نصف‌] بيفزاى و قرآن را شمرده شمرده بخوان"
  73,5,در حقيقت ما به زودى بر تو گفتارى گرانبار القا مى‌كنيم
  73,6,"قطعاً برخاستن شب، رنجش بيشتر و گفتار [در آن هنگام‌] راستين‌تر است"
  73,7,"[و] تو را، در روز، آمد و شدى دراز است"
  73,8,و نام پروردگار خود را ياد كن و تنها به او بپرداز
  73,9,"[اوست‌] پروردگار خاور و باختر، خدايى جز او نيست، پس او را كارساز خويش اختيار كن"
  73,10,و بر آنچه مى‌گويند شكيبا باش و از آنان با دورى گزيدنى خوش فاصله بگير
  73,11,و مرا با تكذيب‌كنندگان توانگر واگذار و اندكى مهلتشان ده
  73,12,در حقيقت پيش ما زنجيرها و دوزخ،
  73,13,و غذايى گلوگير و عذابى پر درد است
  73,14,روزى كه زمين و كوهها به لرزه درآيند و كوهها به سان ريگ روان گردند
  73,15,بى‌گمان، ما به سوى شما فرستاده‌اى كه گواه بر شماست روانه كرديم، همان گونه كه فرستاده‌اى به سوى فرعون فرستاديم
  73,16,"[ولى‌] فرعون به آن فرستاده عصيان ورزيد، پس ما او را به سختى فرو گرفتيم"
  73,17,پس اگر كفر بورزيد، چگونه از روزى كه كودكان را پير مى‌گرداند، پرهيز توانيد كرد؟
  73,18,"آسمان از [بيم‌] آن [روز] در هم شكافد؛ وعده او انجام يافتنى است"
  73,19,"قطعاً اين [آيات‌] اندرزى است، تا هر كه بخواهد به سوى پروردگار خود راهى در پيش گيرد"
  73,20,"در حقيقت، پروردگارت مى‌داند كه تو و گروهى از كسانى كه با تواند، نزديك به دو سوم از شب يا نصف آن يا يك سوم آن را [به نماز] برمى‌خيزيد، و خداست كه شب و روز را اندازه‌گيرى مى‌كند. [او ]مى‌داند كه [شما] هرگز حساب آن را نداريد، پس بر شما ببخشود، [اينك‌] هر چه از قرآن ميسر مى‌شود بخوانيد. [خدا] مى‌داند كه به زودى در ميانتان بيمارانى خواهند بود، و [عده‌اى‌] ديگر در زمين سفر مى‌كنند [و] در پى روزى خدا هستند، و [گروهى‌] ديگر در راه خدا پيكار مى‌نمايند. پس هر چه از [قرآن‌] ميسر شد تلاوت كنيد و نماز را برپا داريد و زكات را بپردازيد و وام نيكو به خدا دهيد؛ و هر كار خوبى براى خويش از پيش فرستيد آن را نزد خدا بهتر و با پاداشى بيشتر باز خواهيد يافت. و از خدا طلب آمرزش كنيد كه خدا آمرزنده مهربان است"
  74,1,اى كشيده رداى شب بر سر،
  74,2,برخيز و بترسان
  74,3,و پروردگار خود را بزرگ دار
  74,4,و لباس خويشتن را پاك كن
  74,5,و از پليدى دور شو
  74,6,و منّت مگذار و فزونى مطلب
  74,7,و براى پروردگارت شكيبايى كن
  74,8,پس چون در صور دميده شود،
  74,9,"آن روز [چه‌] روز ناگوارى است"
  74,10,بر كافران آسان نيست
  74,11,"مرا با آنكه [او را] تنها آفريدم واگذار"
  74,12,و دارايى بسيار به او بخشيدم،
  74,13,"و پسرانى آماده [به خدمت، دادم‌]،"
  74,14,"و برايش [عيش خوش‌] آماده كردم"
  74,15,"باز [هم‌] طمع دارد كه بيفزايم"
  74,16,ولى نه، زيرا او دشمن آيات ما بود
  74,17,"به زودى او را به بالارفتن از گردنه [عذاب‌] وادار مى‌كنم"
  74,18,"آرى، [آن دشمن حق‌] انديشيد و سنجيد"
  74,19,"كشته بادا، چگونه [او] سنجيد؟"
  74,20,"[آرى،] كشته بادا، چگونه [او] سنجيد"
  74,21,آنگاه نظر انداخت
  74,22,سپس رو ترش نمود و چهره در هم كشيد
  74,23,آنگاه پشت گردانيد و تكبّر ورزيد،
  74,24,"و گفت: «اين [قرآن‌] جز سحرى كه [به برخى‌] آموخته‌اند نيست"
  74,25,اين غير از سخن بشر نيست.»
  74,26,زودا كه او را به سَقَر در آورم
  74,27,و تو چه دانى كه آن سَقَر چيست؟
  74,28,نه باقى مى‌گذارد و نه رها مى‌كند
  74,29,پوستها را سياه مى‌گرداند
  74,30,"[و] بر آن [دوزخ‌]، نوزده [نگهبان‌] است"
  74,31,"و ما موكّلان آتش را جز فرشتگان نگردانيديم، و شماره آنها را جز آزمايشى براى كسانى كه كافر شده‌اند قرار نداديم، تا آنان كه اهل كتابند يقين به هم رسانند، و ايمان كسانى كه ايمان آورده‌اند افزون گردد، و آنان كه كتاب به ايشان داده شده و [نيز] مؤمنان به شك نيفتند، و تا كسانى كه در دلهايشان بيمارى است و كافران بگويند: «خدا از اين وصف‌كردن، چه چيزى را اراده كرده است؟» اين گونه، خدا هر كه را بخواهد بيراه مى‌گذارد و هر كه را بخواهد هدايت مى كند، و [شماره‌] سپاهيان پروردگارت را جز او نمى‌داند، و اين [آيات‌] جز تذكارى براى بشر نيست"
  74,32,"نه چنين است [كه مى‌پندارند!] سوگند به ماه،"
  74,33,و سوگند به شامگاه چون پشت كند،
  74,34,و سوگند به بامداد چون آشكار شود،
  74,35,"كه آيات [قرآن‌] از پديده‌هاى بزرگ است"
  74,36,بشر را هشداردهنده است
  74,37,هر كه از شما را كه بخواهد پيشى جويد يا بازايستد
  74,38,هر كسى در گرو دستاورد خويش است،
  74,39,بجز ياران دست راست
  74,40,در ميان باغها. از يكديگر مى‌پرسند،
  74,41,درباره مجرمان
  74,42,"«چه چيز شما را در آتش [سَقَر] درآورد؟»"
  74,43,"گويند: «از نمازگزاران نبوديم،"
  74,44,و بينوايان را غذا نمى‌داديم،
  74,45,با هرزه‌درايان هرزه‌درايى مى‌كرديم،
  74,46,و روز جزا را دروغ مى‌شمرديم،
  74,47,تا مرگ ما در رسيد.»
  74,48,از اين رو شفاعت شفاعت‌كنندگان به حال آنها سودى نمى‌بخشد
  74,49,چرا آنها از تذكر روى گردانند؟
  74,50,گويى گورخرانى رميده‌اند،
  74,51,كه از (مقابل) شيرى فرار كرده‌اند
  74,52,بلكه هر كدام از آنها انتظار دارد نامه جداگانه‌اى (از سوى خدا) براى او فرستاده شود
  74,53,چنين نيست كه آنان مى‌گويند، بلكه آنها از آخرت نمى‌ترسند
  74,54,چنين نيست كه آنها مى‌گويند، آن (قرآن) يك تذكر و يادآورى است
  74,55,هر كس بخواهد از آن پند مى‌گيرد؛
  74,56,و هيچ كس پند نمى‌گيرد مگر اينكه خدا بخواهد؛ او اهل تقوا و اهل آمرزش است
  75,1,سوگند به روز قيامت،
  75,2,و سوگند به (نفس لوّامه و) وجدان بيدار و ملامتگر (كه رستاخيز حقّ است)
  75,3,آيا انسان مى‌پندارد كه هرگز استخوانهاى او را جمع نخواهيم كرد؟
  75,4,آرى قادريم كه (حتى خطوط سر) انگشتان او را موزون و مرتّب كنيم
  75,5,(انسان شك در معاد ندارد) بلكه او مى‌خواهد (آزاد باشد و بدون ترس از دادگاه قيامت) در تمام عمر گناه كند
  75,6,"(از اين‌رو) مى‌پرسد: «قيامت كى خواهد بود»"
  75,7,"(بگو:) در آن هنگام كه چشمها از شدّت وحشت به گردش در آيد،"
  75,8,و ماه بى‌نور گردد،
  75,9,و خورشيد و ماه يك جا جمع شوند،
  75,10,"آن روز انسان مى‌گويد: «راه فرار كجاست؟!»"
  75,11,هرگز چنين نيست، راه فرار و پناهگاهى وجود ندارد
  75,12,آن روز قرارگاه نهايى تنها بسوى پروردگار تو است؛
  75,13,و در آن روز انسان را از تمام كارهايى كه از پيش يا پس فرستاده آگاه مى‌كنند
  75,14,بلكه انسان خودش از وضع خود آگاه است،
  75,15,هر چند (در ظاهر) براى خود عذرهايى بتراشد
  75,16,"زبانت را بخاطر عجله براى خواندن آن [= قرآن‌] حركت مده،"
  75,17,چرا كه جمع‌كردن و خواندن آن بر عهده ماست
  75,18,پس هر گاه آن را خوانديم، از خواندن آن پيروى كن
  75,19,سپس بيان (و توضيح) آن (نيز) بر عهده ماست
  75,20,چنين نيست كه شما مى‌پنداريد (و دلايل معاد را كافى نمى‌دانيد)؛ بلكه شما دنياى زودگذر را دوست داريد (و هوسرانى بى‌قيد و شرط را)
  75,21,و آخرت را رها مى‌كنيد
  75,22,(آرى) در آن روز صورتهايى شاداب و مسرور است،
  75,23,و به پروردگارش مى‌نگرد
  75,24,و در آن روز صورتهايى عبوس و در هم كشيده است،
  75,25,زيرا مى‌داند عذابى در پيش دارد كه پشت را در هم مى‌شكند
  75,26,چنين نيست (كه انسان مى‌پندارد! او ايمان نمى‌آورد) تا موقعى كه جان به گلوگاهش رسد،
  75,27,"و گفته شود: «آيا كسى هست كه(اين بيمار را از مرگ) نجات دهد؟!»"
  75,28,و به جدائى از دنيا يقين پيدا كند،
  75,29,و ساق پاها (از سختى جان دادن) به هم بپيچد
  75,30,(آرى) در آن روز مسير همه بسوى (دادگاه) پروردگارت خواهد بود
  75,31,"(در آن روز گفته مى‌شود:) او هرگز ايمان نياورد و نماز نخواند،"
  75,32,بلكه تكذيب كرد و روى‌گردان شد،
  75,33,سپس بسوى خانواده خود باز گشت در حالى كه متكبّرانه قدم برمى‌داشت
  75,34,(با اين اعمال) عذاب الهى براى تو شايسته‌تر است، شايسته‌تر
  75,35,سپس عذاب الهى براى تو شايسته‌تر است، شايسته‌تر
  75,36,آيا انسان گمان مى‌كند بى‌هدف رها مى‌شود؟
  75,37,آيا او نطفه‌اى از منى كه در رحم ريخته مى‌شود نبود؟
  75,38,سپس بصورت خون‌بسته در آمد، و خداوند او را آفريد و موزون ساخت،
  75,39,و از او دو زوج مرد و زن آفريد
  75,40,آيا چنين كسى قادر نيست كه مردگان را زنده كند؟
  76,1,آيا زمانى طولانى بر انسان گذشت كه چيز قابل ذكرى نبود؟
  76,2,ما انسان را از نطفه مختلطى آفريديم، و او را مى‌آزماييم؛ (بدين جهت) او را شنوا و بينا قرار داديم
  76,3,ما راه را به او نشان داديم، خواه شاكر باشد (و پذيرا گردد) يا ناسپاس
  76,4,ما براى كافران، زنجيرها و غُلها و شعله‌هاى سوزان آتش آماده كرده‌ايم
  76,5,به يقين ابرار (و نيكان) از جامى مى‌نوشند كه با عطر خوشى آميخته است،
  76,6,"چشمه‌اى كه بندگان خدا از آن مى‌نوشند و [به دلخواه خويش‌] جاريش مى‌كنند"
  76,7,"[همان بندگانى كه‌] به نذر خود وفا مى‌كردند، و از روزى كه گزند آن فراگيرنده است مى‌ترسيدند"
  76,8,"و به [پاس‌] دوستى [خدا]، بينوا و يتيم و اسير را خوراك مى‌دادند"
  76,9,«ما براى خشنودى خداست كه به شما مى‌خورانيم و پاداش و سپاسى از شما نمى‌خواهيم
  76,10,ما از پروردگارمان از روز عبوسى سخت، هراسناكيم.»
  76,11,"پس خدا [هم‌] آنان را از آسيب آن روز نگاه داشت و شادابى و شادمانى به آنان ارزانى داشت"
  76,12,"و به [پاس‌] آنكه صبر كردند، بهشت و پرنيان پاداششان داد"
  76,13,"در آن [بهشت‌] بر تختها[ى خويش‌] تكيه زنند. در آنجا نه آفتابى بينند و نه سرمايى"
  76,14,"و سايه‌ها[ى درختان‌] به آنان نزديك است، و ميوه‌هايش [براى چيدن‌] رام"
  76,15,و ظروف سيمين و جامهاى بلورين، پيرامون آنان گردانده مى‌شود
  76,16,"جامهايى از سيم كه درست به اندازه [و با كمال ظرافت‌] آنها را از كار در آورده‌اند"
  76,17,و در آنجا از جامى كه آميزه زنجبيل دارد به آنان مى‌نوشانند
  76,18,از چشمه‌اى در آنجا كه «سلسبيل» ناميده مى‌شود
  76,19,و بر گرد آنان پسرانى جاودانى مى‌گردند. چون آنها را ببينى، گويى كه مرواريدهايى پراكنده‌اند
  76,20,"و چون بدانجا نگرى [سرزمينى از] نعمت و كشورى پهناور مى‌بينى"
  76,21,"[بهشتيان را] جامه‌هاى ابريشمى سبز و ديباى ستبر در بر است و پيرايه آنان دستبندهاى سيمين است و پروردگارشان باده‌اى پاك به آنان مى‌نوشاند"
  76,22,"اين [پاداش‌] براى شماست و كوشش شما مقبول افتاده است"
  76,23,در حقيقت، ما قرآن را بر تو به تدريج فرو فرستاديم
  76,24,پس در برابر فرمان پروردگارت شكيبايى كن، و از آنان گناهكار يا ناسپاسگزار را فرمان مبر
  76,25,و نام پروردگارت را بامدادان و شامگاهان ياد كن
  76,26,"و بخشى از شب را در برابر او سجده كن و شب‌[هاى‌] دراز، او را به پاكى بستاى"
  76,27,"اينان دنياى زودگذر را دوست دارند، و روزى گرانبار را [به غفلت‌] پشت سر مى‌افكنند"
  76,28,"ماييم كه آنان را آفريده و پيوند مفاصل آنها را استوار كرده‌ايم، و چون بخواهيم، [آنان را] به نظايرشان تبديل مى‌كنيم"
  76,29,"اين [آيات،] پندنامه‌اى است. تا هر كه خواهد، راهى به سوى پروردگار خود پيش گيرد"
  76,30,"و تا خدا نخواهد، [شما] نخواهيد خواست؛ قطعاً خدا داناى حكيم است"
  76,31,هر كه را خواهد، به رحمت خويش در مى‌آورد، و براى ظالمان عذابى پردرد آماده كرده است
  77,1,سوگند به فرستادگان پى‌درپى،
  77,2,كه سخت توفنده‌اند
  77,3,و سوگند به افشانندگان افشانگر،
  77,4,"كه [ميان حق و باطل‌] جداگرند،"
  77,5,و القاكننده وحى‌اند
  77,6,خواه عذرى باشد يا هشدارى
  77,7,كه آنچه وعده يافته‌ايد قطعاً رخ خواهد داد
  77,8,پس وقتى كه ستارگان محو شوند،
  77,9,و آنگاه كه آسمان بشكافد،
  77,10,و آنگاه كه كوه‌ها از جا كنده شوند،
  77,11,و آنگاه كه پيمبران به ميقات آيند،
  77,12,براى چه روزى تعيين وقت شده است؟
  77,13,براى روز داورى
  77,14,و تو چه دانى كه روز داورى چيست؟
  77,15,آن روز واى بر تكذيب‌كنندگان
  77,16,مگر پيشينيان را هلاك نكرديم؟
  77,17,سپس از پى آنان پسينيان را مى‌بريم
  77,18,با مجرمان چنين مى‌كنيم
  77,19,آن روز واى بر تكذيب‌كنندگان
  77,20,مگر شما را از آبى بى‌مقدار نيافريديم؟
  77,21,پس آن را در جايگاهى استوار نهاديم،
  77,22,تا مدّتى معيّن
  77,23,و توانا آمديم، و چه نيك تواناييم
  77,24,آن روز واى بر تكذيب‌كنندگان
  77,25,مگر زمين را محل اجتماع نگردانيديم؟
  77,26,چه براى مردگان چه زندگان
  77,27,و كوه‌هاى بلند در آن نهاديم و به شما آبى گوارا نوشانيديم
  77,28,آن روز واى بر تكذيب‌كنندگان
  77,29,برويد به سوى همان چيزى كه آن را تكذيب مى‌كرديد
  77,30,"برويد به سوى [آن‌] دود سه شاخه،"
  77,31,"نه سايه‌دار است و نه از شعله [آتش‌] حفاظت مى‌كند"
  77,32,"[دوزخ‌] چون كاخى [بلند] شراره مى‌افكند،"
  77,33,گويى شترانى زرد رنگند
  77,34,آن روز واى بر تكذيب‌كنندگان
  77,35,اين، روزى است كه دم نمى‌زنند
  77,36,و رخصت نمى‌يابند تا پوزش خواهند
  77,37,آن روز واى بر تكذيب‌كنندگان
  77,38,"اين [همان‌] روز داورى است شما و [جمله‌] پيشينيان را گرد مى‌آوريم"
  77,39,پس اگر حيلتى داريد، در برابر من بسگاليد
  77,40,آن روز واى بر تكذيب‌كنندگان
  77,41,اهل تقوا در زير سايه‌ها و بر كنار چشمه‌سارانند،
  77,42,با هر ميوه‌اى كه خوش داشته باشند
  77,43,"به [پاداش‌] آنچه مى‌كرديد، بخوريد و بياشاميد؛ گواراتان باد"
  77,44,ما نيكوكاران را چنين پاداش مى‌دهيم
  77,45,آن روز واى بر تكذيب‌كنندگان
  77,46,"[اى كافران،] بخوريد و اندكى برخوردار شويد كه شما گناهكاريد"
  77,47,"[ولى‌] آن روز واى بر تكذيب‌كنندگان"
  77,48,"و چون به آنان گفته شود: «ركوع كنيد»، به ركوع نمى‌روند"
  77,49,آن روز واى بر تكذيب‌كنندگان
  77,50,"پس به كدامين سخن پس از [قرآن‌] ايمان مى‌آورند؟"
  78,1,درباره چه چيز از يكديگر مى‌پرسند؟
  78,2,از آن خبر بزرگ،
  78,3,كه در باره آن با هم اختلاف دارند
  78,4,نه چنان است، به زودى خواهند دانست
  78,5,باز هم نه چنان است، بزودى خواهند دانست
  78,6,آيا زمين را گهواره‌اى نگردانيديم؟
  78,7,"و كوهها را [چون‌] ميخهايى [نگذاشتيم‌]؟"
  78,8,و شما را جفت آفريديم
  78,9,"و خواب شما را [مايه‌] آسايش گردانيديم"
  78,10,"و شب را [براى شما] پوششى قرار داديم"
  78,11,"و روز را [براى‌] معاش [شما] نهاديم"
  78,12,"و بر فراز شما هفت [آسمان‌] استوار بنا كرديم"
  78,13,و چراغى فروزان گذارديم
  78,14,و از ابرهاى متراكم، آبى ريزان فرود آورديم،
  78,15,تا بدان دانه و گياه برويانيم،
  78,16,و باغهاى در هم پيچيده و انبوه
  78,17,"قطعاً وعدگاه [ما با شما] روز داورى است"
  78,18,روزى كه در «صور» دميده شود، و گروه گروه بياييد؛
  78,19,"و آسمان، گشوده و درهايى [پديد] شود؛"
  78,20,"و كوهها را روان كنند، و [چون‌] سرابى گردند"
  78,21,"[آرى،] جهنم [از دير باز] كمينگاهى بوده،"
  78,22,"[كه‌] براى سركشان، بازگشتگاهى است"
  78,23,روزگارى دراز در آن درنگ كنند
  78,24,در آنجا نه خنكى چشند و نه شربتى،
  78,25,جز آب جوشان و چركابه‌اى
  78,26,"كيفرى مناسب [با جرم آنها]"
  78,27,"آنان بودند كه به [روز] حساب اميد نداشتند؛"
  78,28,و آيات ما را سخت تكذيب مى‌كردند
  78,29,"و حال آنكه هر چيزى را برشمرده [به صورت‌] كتابى در آورده‌ايم"
  78,30,"پس بچشيد كه جز عذاب، هرگز [چيزى‌] بر شما نمى‌افزاييم"
  78,31,مسلماً پرهيزگاران را رستگارى است
  78,32,باغچه‌ها و تاكستانها،
  78,33,و دخترانى همسال با سينه‌هاى برجسته،
  78,34,و پياله‌هاى لبالب
  78,35,"در آنجا نه بيهوده‌اى شنوند، و نه [يكديگر را] تكذيب [كنند]"
  78,36,"[اين است‌] پاداشى از پروردگار تو، عطايى از روى حساب"
  78,37,پروردگار آسمانها و زمين و آنچه ميان آن دو است، بخشايشگرى كه كس را ياراى خطاب با او نيست
  78,38,"روزى كه «روح» و فرشتگان به صف مى‌ايستند، و [مردم‌] سخن نگويند، مگر كسى كه [خداى‌] رحمان به او رخصت دهد، و سخن راست گويد"
  78,39,"آن [روز]، روز حق است؛ پس هر كه خواهد، راه بازگشتى به سوى پروردگار خود بجويد"
  78,40,"ما شما را از عذابى نزديك هشدار داديم: روزى كه آدمى آنچه را با دست خويش پيش فرستاده است بنگرد؛ و كافر گويد: «كاش من خاك بودم.»"
  79,1,"سوگند به فرشتگانى كه [از كافران‌] به سختى جان ستانند،"
  79,2,"و به فرشتگانى كه جان [مؤمنان‌] را به آرامى گيرند،"
  79,3,"و به فرشتگانى كه [در درياى بى‌مانند] شناكنان شناورند،"
  79,4,"پس در پيشى گرفتن [در فرمان خدا] سبقت‌گيرنده‌اند،"
  79,5,"و كار [بندگان‌] را تدبير مى‌كنند"
  79,6,آن روز كه لرزنده بلرزد،
  79,7,"و از پى آن لرزه‌اى [دگر] افتد،"
  79,8,در آن روز، دلهايى سخت هراسانند
  79,9,ديدگان آنها فرو افتاده
  79,10,"گويند: «آيا [باز] ما به [مغاك‌] زمين برمى‌گرديم؟"
  79,11,"آيا وقتى ما استخوان‌ريزه‌هاى پوسيده شديم [زندگى را از سر مى‌گيريم‌]؟»"
  79,12,"[و با خود] گويند: «در اين صورت، اين برگشتى زيان‌آور است.»"
  79,13,"و[لى‌] در حقيقت، آن [بازگشت، بسته به‌] يك فرياد است [و بس‌]"
  79,14,و بناگاه آنان در زمين هموار خواهند بود
  79,15,آيا سرگذشت موسى بر تو آمد؟
  79,16,آنگاه كه پروردگارش او را در وادى مقدس «طوى» ندا درداد
  79,17,«به سوى فرعون برو كه وى سر برداشته است؛
  79,18,"و بگو: آيا سر آن دارى كه به پاكيزگى گرايى،"
  79,19,و تو را به سوى پروردگارت راه نمايم تا پروا بدارى؟»
  79,20,"پس معجزه بزرگ [خود] را بدو نمود"
  79,21,"و[لى فرعون‌] تكذيب نمود و عصيان كرد"
  79,22,"سپس پشت كرد [و] به كوشش برخاست،"
  79,23,"و گروهى را فراهم آورد [و] ندا درداد،"
  79,24,"و گفت: «پروردگار بزرگتر شما منم!»"
  79,25,"و خدا [هم‌] او را به كيفر دنيا و آخرت گرفتار كرد"
  79,26,"در حقيقت، براى هر كس كه [از خدا] بترسد، در اين [ماجرا] عبرتى است"
  79,27,"آيا آفرينش شما دشوارتر است يا آسمانى كه [او] آن را برپا كرده است؟"
  79,28,"سقفش را برافراشت و آن را [به اندازه معين‌] درست كرد،"
  79,29,و شبش را تيره و روزش را آشكار گردانيد،
  79,30,و پس از آن، زمين را با غلتانيدن گسترد،
  79,31,آبش و چراگاهش را از آن بيرون آورد،
  79,32,و كوهها را لنگر آن گردانيد،
  79,33,"[تا وسيله‌] استفاده براى شما و دامهايتان باشد"
  79,34,پس آنگاه كه آن هنگامه بزرگ دررسد،
  79,35,"[آن‌] روز است كه انسان آنچه را كه در پى آن كوشيده است به ياد آورد"
  79,36,و جهنم براى هر كه بيند آشكار گردد
  79,37,اما هر كه طغيان كرد،
  79,38,و زندگى پست دنيا را برگزيد،
  79,39,پس جايگاه او همان آتش است
  79,40,و اما كسى كه از ايستادن در برابر پروردگارش هراسيد، و نفس خود را از هوس باز داشت
  79,41,پس جايگاه او همان بهشت است
  79,42,در باره رستاخيز از تو مى‌پرسند كه فرارسيدنش چه وقت است؟
  79,43,تو را چه به گفتگو در آن
  79,44,علم آن با پروردگار تو است
  79,45,تو فقط كسى را كه از آن مى‌ترسد هشدار مى‌دهى
  79,46,روزى كه آن را مى‌بينند، گويى كه آنان جز شبى يا روزى درنگ نكرده‌اند
  80,1,چهره در هم كشيد و روى گردانيد،
  80,2,كه آن مرد نابينا پيش او آمد؛
  80,3,و تو چه دانى، شايد او به پاكى گرايد،
  80,4,يا پند پذيرد و اندرز سودش دهد
  80,5,اما آن كس كه خود را بى‌نياز مى‌پندارد،
  80,6,تو بدو مى‌پردازى؛
  80,7,"با آنكه اگر پاك نگردد، بر تو [مسؤوليتى‌] نيست"
  80,8,و اما آن كس كه شتابان پيش تو آمد،
  80,9,"در حالى كه [از خدا] مى‌ترسيد،"
  80,10,تو از او به ديگران مى‌پردازى
  80,11,"زنهار [چنين مكن‌] اين [آيات‌] پندى است"
  80,12,تا هر كه خواهد، از آن پند گيرد
  80,13,در صحيفه‌هايى ارجمند،
  80,14,والا و پاك‌شده،
  80,15,به دست فرشتگانى،
  80,16,ارجمند و نيكوكار
  80,17,كشته باد انسان، چه ناسپاس است
  80,18,او را از چه چيز آفريده است؟
  80,19,از نطفه‌اى خلقش كرد و اندازه مقررش بخشيد
  80,20,سپس راه را بر او آسان گردانيد
  80,21,آنگاه به مرگش رسانيد و در قبرش نهاد
  80,22,سپس چون بخواهد او را برانگيزد
  80,23,ولى نه! هنوز آنچه را به او دستور داده، به جاى نياورده است
  80,24,پس انسان بايد به خوراك خود بنگرد،
  80,25,كه ما آب را به صورت بارشى فرو ريختيم؛
  80,26,"آنگاه زمين را با شكافتنى [لازم‌] شكافتيم؛"
  80,27,پس در آن، دانه رويانيديم
  80,28,و انگور و سبزى،
  80,29,و زيتون و درخت خرما،
  80,30,و باغهاى انبوه،
  80,31,و ميوه و چراگاه،
  80,32,"[تا وسيله‌] استفاده شما و دامهايتان باشد"
  80,33,پس چون فرياد گوش‌خراش دررسد؛
  80,34,روزى كه آدمى از برادرش،
  80,35,و از مادرش و پدرش
  80,36,و از همسرش و پسرانش مى‌گريزد،
  80,37,در آن روز، هر كسى از آنان را كارى است كه او را به خود مشغول مى‌دارد
  80,38,در آن روز، چهره‌هايى درخشانند،
  80,39,"خندان [و] شادانند"
  80,40,و در آن روز، چهره‌هايى است كه بر آنها غبار نشسته،
  80,41,"[و] آنها را تاريكى پوشانده است؛"
  80,42,آنان همان كافران بدكارند
  81,1,آنگاه كه خورشيد به هم درپيچد،
  81,2,و آنگه كه ستارگان همى‌تيره شوند،
  81,3,و آنگاه كه كوهها به رفتار آيند
  81,4,وقتى شتران ماده وانهاده شوند،
  81,5,و آنگه كه وحوش را همى‌گرد آرند،
  81,6,درياها آنگه كه جوشان گردند،
  81,7,و آنگاه كه جانها به هم درپيوندند،
  81,8,پرسند چو زان دخترك زنده به‌گور
  81,9,به كدامين گناه كشته شده است؟
  81,10,و آنگاه كه نامه‌ها زهم بگشايند،
  81,11,و آنگاه كه آسمان زجا كنده شود،
  81,12,و آنگه كه جحيم را برافروزانند،
  81,13,و آنگه كه بهشت را فرا پيش آرند،
  81,14,هر نَفْس بداند چه فراهم ديده
  81,15,نه، نه! سوگند به اختران گردان،
  81,16,"[كز ديده‌] نهان شوند و از نو آيند،"
  81,17,سوگند به شب چون پشت گرداند،
  81,18,سوگند به صبح چون دميدن گيرد،
  81,19,"كه [قرآن‌] سخن فرشته بزرگوارى است"
  81,20,"نيرومند [كه‌] پيش خداوند عرش، بلندپايگاه است"
  81,21,"در آنجا [هم‌] مطاع [و هم‌] امين است"
  81,22,و رفيق شما مجنون نيست؛
  81,23,"و قطعاً آن [فرشته وحى‌] را در افق رخشان ديده"
  81,24,و او در امر غيب بخيل نيست
  81,25,"و [قرآن‌] نيست سخن ديو رجيم"
  81,26,پس به كجا مى‌رويد؟
  81,27,"اين [سخن‌] بجز پندى براى عالميان نيست؛"
  81,28,براى هر يك از شما كه خواهد به راه راست رود
  81,29,"و تا خدا، پروردگار جهانها، نخواهد، [شما نيز] نخواهيد خواست"
  82,1,آنگاه كه آسمان زهم بشكافد،
  82,2,و آنگاه كه اختران پراكنده شوند،
  82,3,و آنگاه كه درياها از جا بركنده گردند،
  82,4,و آنگاه كه گورها زير و زبر شوند،
  82,5,هر نفسى آنچه را پيش فرستاده و بازپس گذاشته، بداند
  82,6,اى انسان، چه چيز تو را در باره پروردگار بزرگوارت مغرور ساخته؟
  82,7,"همان كس كه تو را آفريد، و [اندام‌] تو را درست كرد، و [آنگاه‌] تو را سامان بخشيد"
  82,8,و به هر صورتى كه خواست، تو را تركيب كرد
  82,9,"با اين همه، شما منكر [روز] جزاييد"
  82,10,"و قطعاً بر شما نگهبانانى [گماشته شده‌]اند"
  82,11,"[فرشتگان‌] بزرگوارى كه نويسندگان [اعمال شما] هستند؛"
  82,12,آنچه را مى‌كنيد، مى‌دانند
  82,13,قطعاً نيكان به بهشت اندرند
  82,14,و بى‌شك، بدكاران در دوزخند
  82,15,روز جزا در آنجا درآيند،
  82,16,"و از آن [عذاب‌] دور نخواهند بود"
  82,17,و تو چه دانى كه چيست روز جزا؟
  82,18,باز چه دانى كه چيست روز جزا؟
  82,19,روزى كه كسى براى كسى هيچ اختيارى ندارد؛ و در آن روز، فرمان از آنِ خداست
  83,1,واى بر كم‌فروشان،
  83,2,كه چون از مردم پيمانه ستانند، تمام ستانند؛
  83,3,و چون براى آنان پيمانه يا وزن كنند، به ايشان كم دهند
  83,4,مگر آنان گمان نمى‌دارند كه برانگيخته خواهند شد؟
  83,5,"[در] روزى بزرگ"
  83,6,روزى كه مردم در برابر پروردگار جهانيان به پاى ايستند
  83,7,"نه چنين است [كه مى‌پندارند]، كه كارنامه بدكاران در «سجّين» است"
  83,8,و تو چه دانى كه «سجّين» چيست؟
  83,9,كتابى است نوشته‌شده
  83,10,واى بر تكذيب‌كنندگان در آن هنگام
  83,11,آنان كه روز جزا را دروغ مى‌پندارند
  83,12,و جز هر تجاوزپيشه گناهكارى آن را به دروغ نمى‌گيرد
  83,13,"[همان كه‌] چون آيات ما بر او خوانده شود، گويد: «[اينها] افسانه‌هاى پيشينيان است.»"
  83,14,نه چنين است، بلكه آنچه مرتكب مى‌شدند زنگار بر دلهايشان بسته است
  83,15,زهى پندار، كه آنان در آن روز، از پروردگارشان سخت محجوبند
  83,16,آنگاه به يقين، آنان به جهنم درآيند
  83,17,"سپس [به ايشان‌] گفته خواهد شد: «اين همان است كه آن را به دروغ مى‌گرفتيد.»"
  83,18,نه چنين است، در حقيقت، كتاب نيكان در «علّيّون» است
  83,19,و تو چه دانى كه «علّيّون» چيست؟
  83,20,كتابى است نوشته‌شده
  83,21,مقرّبان آن را مشاهده خواهند كرد
  83,22,"براستى نيكوكاران در نعيم [الهى‌] خواهند بود"
  83,23,"بر تختها [نشسته‌] مى‌نگرند"
  83,24,"از چهره‌هايشان طراوت نعمت [بهشت‌] را درمى‌يابى"
  83,25,از باده‌اى مُهر شده نوشانيده شوند
  83,26,"[باده‌اى كه‌] مُهر آن، مُشك است، و در اين [نعمتها] مشتاقان بايد بر يكديگر پيشى گيرند"
  83,27,"و تركيبش از [چشمه‌] «تسنيم» است"
  83,28,"چشمه‌اى كه مقرّبان [خدا] از آن نوشند"
  83,29,"[آرى، در دنيا] كسانى كه گناه مى‌كردند، آنان را كه ايمان آورده بودند به ريشخند مى‌گرفتند"
  83,30,و چون بر ايشان مى‌گذشتند، اشاره چشم و ابرو با هم رد و بدل مى‌كردند
  83,31,"و هنگامى كه نزد خانواده‌[هاى‌] خود بازمى‌گشتند، به شوخ‌طبعى مى‌پرداختند"
  83,32,"و چون مؤمنان را مى‌ديدند، مى‌گفتند: «اينها [جماعتى‌] گمراهند.»"
  83,33,"و حال آنكه آنان براى بازرسى [كار]شان فرستاده نشده بودند"
  83,34,"و[لى‌] امروز، مؤمنانند كه بر كافران خنده مى‌زنند"
  83,35,"بر تختها[ى خود نشسته‌]، نظاره مى‌كنند"
  83,36,"[تا ببينند] آيا كافران به پاداش آنچه مى‌كردند رسيده‌اند؟"
  84,1,آنگاه كه آسمان زهم بشكافد،
  84,2,"و پروردگارش را فرمان برد و [چنين‌] سزد"
  84,3,و آنگاه كه زمين كشيده شود،
  84,4,و آنچه را كه در آن است بيرون افكند و تهى شود،
  84,5,"و پروردگارش را فرمان برد و [چنين‌] سزد"
  84,6,اى انسان، حقاً كه تو به سوى پروردگار خود بسختى در تلاشى، و او را ملاقات خواهى كرد
  84,7,اما كسى كه كارنامه‌اش به دست راستش داده شود،
  84,8,بزودى‌اش حسابى بس آسان كنند،
  84,9,و شادمان به سوى كسانش باز گردد
  84,10,و اما كسى كه كارنامه‌اش از پشت سرش به او داده شود،
  84,11,"زودا كه هلاك [خويش‌] خواهد،"
  84,12,و در آتش افروخته درآيد
  84,13,"او در [ميان‌] خانواده خود شادمان بود"
  84,14,او مى‌پنداشت كه هرگز برنخواهد گشت
  84,15,آرى، در حقيقت، پروردگارش به او بينا بود
  84,16,نه، نه، سوگند به شفق،
  84,17,"سوگند به شب و آنچه [شب‌] فروپوشاند،"
  84,18,"سوگند به ماه چون [بَدر] تمام شود،"
  84,19,كه قطعاً از حالى به حالى برخواهيد نشست
  84,20,پس چرا آنان باور نمى‌دارند؟
  84,21,و چون بر آنان قرآن تلاوت مى‌شود چهره بر خاك نمى‌سايند؟
  84,22,"[نه!] بلكه آنان كه كفر ورزيده‌اند، تكذيب مى‌كنند"
  84,23,و خدا به آنچه در سينه دارند داناتر است
  84,24,پس آنان را از عذابى دردناك خبر ده،
  84,25,مگر كسانى كه گرويده و كارهاى شايسته كرده‌اند، كه آنان را پاداشى بى‌منّت خواهد بود
  85,1,سوگند به آسمان آكنده ز برج،
  85,2,و به روز موعود،
  85,3,و به گواه و مورد گواهى،
  85,4,مرگ بر آدم‌سوزان خندق
  85,5,"همان آتش مايه‌دار [و انبوه‌]"
  85,6,"آنگاه كه آنان بالاى آن [خندق به تماشا] نشسته بودند"
  85,7,"و خود بر آنچه بر [سر] مؤمنان مى‌آوردند، گواه بودند"
  85,8,و بر آنان عيبى نگرفته بودند جز اينكه به خداى ارجمند ستوده ايمان آورده بودند
  85,9,"همان [خدايى‌] كه فرمانروايى آسمانها و زمين از آن اوست و خدا[ست كه‌] بر هر چيزى گواه است"
  85,10,كسانى كه مردان و زنان مؤمن را آزار كرده و بعد توبه نكرده‌اند، ايشان راست عذاب جهنم، و ايشان راست عذاب سوزان
  85,11,"كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، براى آنان باغهايى است كه از زير [درختان‌] آن جويها روان است؛ اين است [همان‌] رستگارى بزرگ"
  85,12,آرى، عقاب پروردگارت سخت سنگين است
  85,13,"هم اوست كه [آفرينش را] آغاز مى‌كند و بازمى‌گرداند"
  85,14,"و اوست آن آمرزنده دوستدار [مؤمنان‌]"
  85,15,صاحب ارجمند عرش
  85,16,هر چه را بخواهد انجام مى‌دهد
  85,17,"آيا حديث [آن‌] سپاهيان"
  85,18,فرعون و ثمود بر تو آمد؟
  85,19,"[نه،] بلكه آنان كه كافر شده‌اند در تكذيب‌اند؛"
  85,20,با آنكه خدا از هر سو بر ايشان محيط است
  85,21,آرى، آن قرآنى ارجمند است،
  85,22,كه در لوحى محفوظ است
  86,1,سوگند به آسمان و آن اختر شبگرد
  86,2,و تو چه دانى كه اختر شبگرد چيست؟
  86,3,آن اختر فروزان
  86,4,"هيچ كس نيست مگر اينكه نگاهبانى بر او [گماشته شده‌] است"
  86,5,پس انسان بايد بنگرد كه از چه آفريده شده است؟
  86,6,از آب جهنده‌اى خلق شده،
  86,7,"[كه‌] از صلب مرد و ميان استخوانهاى سينه زن بيرون مى‌آيد"
  86,8,"در حقيقت، او [= خدا] بر بازگردانيدن وى بخوبى تواناست"
  86,9,"آن روز كه رازها [همه‌] فاش شود،"
  86,10,پس او را نه نيرويى ماند و نه يارى
  86,11,سوگند به آسمان بارش‌انگيز،
  86,12,"سوگند به زمين شكافدار [آماده كشت‌]،"
  86,13,"[كه‌] در حقيقت، قرآن گفتارى قاطع و روشنگر است؛"
  86,14,و آن شوخى نيست
  86,15,آنان دست به نيرنگ مى‌زنند
  86,16,"و [من نيز] دست به نيرنگ مى‌زنم"
  86,17,پس كافران را مهلت ده، و كمى آنان را به حال خود واگذار
  87,1,نام پروردگار والاى خود را به پاكى بستاى
  87,2,همان كه آفريد و هماهنگى بخشيد
  87,3,و آنكه اندازه‌گيرى كرد و راه نمود
  87,4,و آنكه چمنزار را برآورد؛
  87,5,"و پس [از چندى‌] آن را خاشاكى تيره‌گون گردانيد"
  87,6,"ما بزودى [آيات خود را به وسيله سروش غيبى‌] بر تو خواهيم خواند، تا فراموش نكنى؛"
  87,7,جز آنچه خدا خواهد، كه او آشكار و آنچه را كه نهان است مى‌داند
  87,8,"و براى تو آسانترين [راه‌] را فراهم مى‌گردانيم"
  87,9,پس پند ده، اگر پند سود بخشد
  87,10,آن كس كه ترسد، بزودى عبرت گيرد
  87,11,و نگون‌بخت، خود را از آن دور مى‌دارد؛
  87,12,همان كس كه در آتشى بزرگ در آيد؛
  87,13,آنگاه نه در آن مى‌ميرد و نه زندگانى مى‌يابد
  87,14,رستگار آن كس كه خود را پاك گردانيد؛
  87,15,و نام پروردگارش را ياد كرد و نماز گزارد
  87,16,"ليكن [شما] زندگى دنيا را بر مى‌گزينيد؛"
  87,17,"با آنكه [جهان‌] آخرت نيكوتر و پايدارتر است"
  87,18,"قطعاً در صحيفه‌هاى گذشته اين [معنى‌] هست،"
  87,19,صحيفه‌هاى ابراهيم و موسى
  88,1,آيا خبر «غاشيه» به تو رسيده است؟
  88,2,در آن روز، چهره‌هايى زبونند،
  88,3,"كه تلاش كرده، رنج [بيهوده‌] برده‌اند"
  88,4,"[ناچار] در آتشى سوزان درآيند"
  88,5,از چشمه‌اى داغ نوشانيده شوند
  88,6,خوراكى جز خار خشك ندارند،
  88,7,"[كه‌] نه فربه كند، و نه گرسنگى را باز دارد"
  88,8,در آن روز، چهره‌هايى شادابند
  88,9,از كوشش خود خشنودند
  88,10,در بهشت برين‌اند
  88,11,سخن بيهوده‌اى در آنجا نشنوند
  88,12,در آن، چشمه‌اى روان باشد
  88,13,تختهايى بلند در آنجاست
  88,14,و قدحهايى نهاده شده
  88,15,"و بالشهايى پهلوى هم [چيده‌]"
  88,16,"و فرشهايى [زربفت‌] گسترده"
  88,17,آيا به شتر نمى‌نگرند كه چگونه آفريده شده؟
  88,18,و به آسمان كه چگونه برافراشته شده؟
  88,19,و به كوه‌ها كه چگونه برپا داشته شده؟
  88,20,و به زمين كه چگونه گسترده شده است؟
  88,21,پس تذكر ده كه تو تنها تذكردهنده‌اى
  88,22,بر آنان تسلّطى ندارى،
  88,23,مگر كسى كه روى بگرداند و كفر ورزد،
  88,24,كه خدا او را به آن عذاب بزرگتر عذاب كند
  88,25,در حقيقت، بازگشت آنان به سوى ماست،
  88,26,"آنگاه حساب [خواستن از] آنان به عهده ماست"
  89,1,سوگند به سپيده‌دم،
  89,2,و به شبهاى دهگانه،
  89,3,و به جفت و تاق،
  89,4,و به شب، وقتى سپرى شود
  89,5,"آيا در اين، براى خردمند [نياز به‌] سوگندى [ديگر] است؟"
  89,6,مگر ندانسته‌اى كه پروردگارت با عاد چه كرد؟
  89,7,با عمارات ستون‌دار ارم،
  89,8,كه مانندش در شهرها ساخته نشده بود؟
  89,9,و با ثمود، همانان كه در درّه، تخته‌سنگها را مى‌بريدند؟
  89,10,"و با فرعون، صاحب خرگاه‌ها [و بناهاى بلند]؟"
  89,11,همانان كه در شهرها سر به طغيان برداشتند،
  89,12,و در آنها بسيار تبهكارى كردند
  89,13,"[تا آنكه‌] پروردگارت بر سر آنان تازيانه عذاب را فرونواخت،"
  89,14,زيرا پروردگار تو سخت در كمين است
  89,15,"اما انسان، هنگامى كه پروردگارش وى را مى‌آزمايد، و عزيزش مى‌دارد و نعمت فراوان به او مى‌دهد، مى‌گويد: «پروردگارم مرا گرامى داشته است.»"
  89,16,"و اما چون وى را مى‌آزمايد و روزى‌اش را بر او تنگ مى‌گرداند، مى‌گويد: «پروردگارم مرا خوار كرده است.»"
  89,17,ولى نه، بلكه يتيم را نمى‌نوازيد؛
  89,18,"و بر خوراك‌[دادن‌] بينوا همديگر را بر نمى‌انگيزيد؛"
  89,19,"و ميراث [ضعيفان‌] را چپاولگرانه مى‌خوريد؛"
  89,20,و مال را دوست داريد، دوست داشتنى بسيار
  89,21,نه چنان است، آنگاه كه زمين، سخت در هم كوبيده شود،
  89,22,"و [فرمان‌] پروردگارت و فرشته‌[ها] صف‌درصف آيند،"
  89,23,"و جهنم را در آن روز [حاضر] آورند، آن روز است كه انسان پند گيرد؛ و[لى‌] كجا او را جاى پندگرفتن باشد؟"
  89,24,"گويد: «كاش براى زندگانى خود [چيزى‌] پيش فرستاده بودم.»"
  89,25,پس در آن روز هيچ كس چون عذاب‌كردن او، عذاب نكند
  89,26,و هيچ كس چون دربندكشيدن او، دربند نكشد
  89,27,اى نفس مطمئنّه،
  89,28,خشنود و خداپسند به سوى پروردگارت بازگرد،
  89,29,و در ميان بندگان من درآى،
  89,30,و در بهشت من داخل شو
  90,1,سوگند به اين شهر،
  90,2,و حال آنكه تو در اين شهر جاى دارى؛
  90,3,"سوگند به پدرى [چنان‌] و آن كسى را كه به وجود آورد؛"
  90,4,براستى كه انسان را در رنج آفريده‌ايم
  90,5,آيا پندارد كه هيچ كس هرگز بر او دست نتواند يافت؟
  90,6,"گويد: «مال فراوانى تباه كردم.»"
  90,7,آيا پندارد كه هيچ كس او را نديده است؟
  90,8,آيا دو چشمش نداده‌ايم؟
  90,9,و زبانى و دو لب
  90,10,"و هر دو راه [خير و شر] را بدو نموديم"
  90,11,"و[لى‌] نخواست از گردنه [عاقبت‌نگرى‌] بالا رود"
  90,12,"و تو چه دانى كه آن گردنه [سخت‌] چيست؟"
  90,13,بنده‌اى را آزادكردن،
  90,14,يا در روز گرسنگى، طعام‌دادن
  90,15,به يتيمى خويشاوند،
  90,16,يا بينوايى خاك‌نشين
  90,17,علاوه بر اين از زمره كسانى باشد كه گرويده و يكديگر را به شكيبايى و مهربانى سفارش كرده‌اند؛
  90,18,اينانند خجستگان
  90,19,و كسانى كه به انكار نشانه‌هاى ما پرداخته‌اند، آنانند ناخجستگان شوم
  90,20,بر آنان آتشى سرپوشيده احاطه دارد
  91,1,سوگند به خورشيد و تابندگى‌اش،
  91,2,"سوگند به مه چون پى [خورشيد] رود"
  91,3,"سوگند به روز چون [زمين را] روشن گرداند،"
  91,4,سوگند به شب چو پرده بر آن پوشد،
  91,5,سوگند به آسمان و آن كس كه آن را برافراشت،
  91,6,سوگند به زمين و آن كس كه آن را گسترد،
  91,7,سوگند به نفس و آن كس كه آن را درست كرد؛
  91,8,سپس پليدكارى و پرهيزگارى‌اش را به آن الهام كرد،
  91,9,كه هر كس آن را پاك گردانيد، قطعاً رستگار شد،
  91,10,و هر كه آلوده‌اش ساخت، قطعاً درباخت
  91,11,"[قوم‌] ثمود به سبب طغيان خود به تكذيب پرداختند"
  91,12,"آنگاه كه شقى‌ترينشان بر[پا] خاست"
  91,13,"پس فرستاده خدا به آنان گفت: «زنهار! ماده‌شتر خدا و [نوبت‌] آب‌خوردنش را [حرمت نهيد]»"
  91,14,"و[لى‌] دروغزنش خواندند و آن [ماده‌شتر] را پى كردند، و پروردگارشان به [سزاى‌] گناهشان بر سرشان عذاب آورد و آنان را با خاك يكسان كرد"
  91,15,و از پيامد كار خويش، بيمى به خود راه نداد
  92,1,سوگند به شب چون پرده افكند،
  92,2,سوگند به روز چون جلوه‌گرى آغازد،
  92,3,"و [سوگند به‌] آنكه نر و ماده را آفريد،"
  92,4,كه همانا تلاش شما پراكنده است
  92,5,"اما آنكه [حق خدا را] داد و پروا داشت،"
  92,6,"و [پاداش‌] نيكوتر را تصديق كرد،"
  92,7,بزودى راه آسانى پيش پاى او خواهيم گذاشت
  92,8,و اما آنكه بخل ورزيد و خود را بى‌نياز ديد،
  92,9,"و [پاداش‌] نيكوتر را به دروغ گرفت،"
  92,10,بزودى راه دشوارى به او خواهيم نمود
  92,11,"و چون هلاك شد، [ديگر] مال او به كارش نمى‌آيد"
  92,12,همانا هدايت بر ماست
  92,13,و در حقيقت، دنيا و آخرت از آن ماست
  92,14,پس شما را به آتشى كه زبانه مى‌كشد هشدار دادم
  92,15,"جز نگون‌بخت‌تر[ين مردم‌] در آن درنيايد"
  92,16,همان كه تكذيب كرد و رخ برتافت
  92,17,"و پاك‌رفتارتر[ين مردم‌] از آن دور داشته خواهد شد"
  92,18,"همان كه مال خود را مى‌دهد [براى آنكه‌] پاك شود،"
  92,19,و هيچ كس را به قصد پاداش‌يافتن نعمت نمى‌بخشد،
  92,20,"جز خواستن رضاى پروردگارش كه بسى برتر است [منظورى ندارد]"
  92,21,و قطعاً بزودى خشنود خواهد شد
  93,1,سوگند به روشنايى روز،
  93,2,سوگند به شب چون آرام گيرد،
  93,3,"[كه‌] پروردگارت تو را وانگذاشته، و دشمن نداشته است"
  93,4,و قطعاً آخرت براى تو از دنيا نيكوتر خواهد بود
  93,5,و بزودى پروردگارت تو را عطا خواهد داد، تا خرسند گردى
  93,6,مگر نه تو را يتيم يافت، پس پناه داد؟
  93,7,و تو را سرگشته يافت، پس هدايت كرد؟
  93,8,و تو را تنگدست يافت و بى‌نياز گردانيد؟
  93,9,"و اما [تو نيز به پاس نعمت ما] يتيم را ميازار،"
  93,10,و گدا را مران،
  93,11,"و از نعمت پروردگار خويش [با مردم‌] سخن گوى"
  94,1,آيا براى تو سينه‌ات را نگشاده‌ايم؟
  94,2,"و بار گرانت را از [دوش‌] تو برنداشتيم؟"
  94,3,"[بارى‌] كه [گويى‌] پشت تو را شكست"
  94,4,و نامت را براى تو بلند گردانيديم
  94,5,"پس [بدان كه‌] با دشوارى، آسانى است"
  94,6,آرى، با دشوارى، آسانى است
  94,7,پس چون فراغت يافتى، به طاعت دركوش؛
  94,8,و با اشتياق، به سوى پروردگارت روى آور
  95,1,"سوگند به [كوه‌] تين و زيتون،"
  95,2,و طور سينا،
  95,3,"و اين شهر امن [و امان‌]،"
  95,4,"[كه‌] براستى انسان را در نيكوترين اعتدال آفريديم"
  95,5,"سپس او را به پست‌ترين [مراتب‌] پستى بازگردانيديم؛"
  95,6,مگر كسانى را كه گرويده و كارهاى شايسته كرده‌اند، كه پاداشى بى‌منّت خواهند داشت
  95,7,"پس چه چيز، تو را بعد [از اين‌] به تكذيب جزا وامى‌دارد؟"
  95,8,آيا خدا نيكوترين داوران نيست؟
  96,1,بخوان به نام پروردگارت كه آفريد
  96,2,انسان را از عَلَق آفريد
  96,3,"بخوان، و پروردگار تو كريمترين [كريمان‌] است"
  96,4,همان كس كه به وسيله قلم آموخت
  96,5,"آنچه را كه انسان نمى‌دانست [بتدريج به او] آموخت"
  96,6,حقاً كه انسان سركشى مى‌كند،
  96,7,همين كه خود را بى‌نياز پندارد
  96,8,در حقيقت، بازگشت به سوى پروردگار توست
  96,9,آيا ديدى آن كس را كه باز مى‌داشت،
  96,10,بنده‌اى را آنگاه كه نماز مى‌گزارد؟
  96,11,چه پندارى اگر او بر هدايت باشد،
  96,12,"يا به پرهيزگارى وادارد [براى او بهتر نيست‌]؟"
  96,13,"[و باز] آيا چه پندارى [كه‌] اگر او به تكذيب پردازد و روى برگرداند [چه كيفرى در پيش دارد]؟"
  96,14,مگر ندانسته كه خدا مى‌بيند؟
  96,15,"زنهار، اگر باز نايستد، موى پيشانى [او] را سخت بگيريم؛"
  96,16,"[همان‌] موى پيشانى دروغزن گناه‌پيشه را"
  96,17,"[بگو] تا گروه خود را بخواند"
  96,18,بزودى آتشبانان را فرا خوانيم
  96,19,"زنهار! فرمانش مَبَر، و سجده كن، و خود را [به خدا] نزديك گردان"
  97,1,"ما [قرآن را] در شب قدر نازل كرديم"
  97,2,و از شب قدر، چه آگاهت كرد
  97,3,شب قدر از هزار ماه ارجمندتر است
  97,4,"در آن [شب‌] فرشتگان، با روح، به فرمان پروردگارشان، براى هر كارى [كه مقرّر شده است‌] فرود آيند؛"
  97,5,"[آن شب‌] تا دمِ صبح، صلح و سلام است"
  98,1,كافران اهل كتاب و مشركان، دست‌بردار نبودند تا دليلى آشكار بر ايشان آيد
  98,2,"فرستاده‌اى از جانب خدا كه [بر آنان‌] صحيفه‌هايى پاك را تلاوت كند،"
  98,3,كه در آنها نوشته‌هاى استوار است
  98,4,و اهل كتاب دستخوش پراكندگى نشدند، مگر پس از آنكه برهان آشكار براى آنان آمد
  98,5,"و فرمان نيافته بودند جز اينكه خدا را بپرستند، و در حالى كه به توحيد گراييده‌اند، دين [خود] را براى او خالص گردانند، و نماز برپا دارند و زكات بدهند، و دين [ثابت و] پايدار همين است"
  98,6,"كسانى از اهل كتاب كه كفر ورزيده‌اند و [نيز] مشركان در آتش دوزخند، [و] در آن همواره مى‌مانند؛ اينانند كه بدترين آفريدگانند"
  98,7,در حقيقت كسانى كه گرويده و كارهاى شايسته كرده‌اند، آنانند كه بهترين آفريدگانند
  98,8,"پاداش آنان نزد پروردگارشان باغهاى هميشگى است كه از زير [درختان‌] آن، نهرها روان است، جاودانه در آن «همى» مانند؛ خدا از آنان خشنود است و [آنان نيز] از او خشنود، اين [پاداش‌] براى كسى است كه از پروردگارش بترسد"
  99,1,"آنگاه كه زمين به لرزش [شديد] خود لرزانيده شود،"
  99,2,و زمين بارهاى سنگين خود را برون افكند،
  99,3,"و انسان گويد: «[زمين‌] را چه شده است؟»"
  99,4,"آن روز است كه [زمين‌] خبرهاى خود را باز گويد"
  99,5,"[همان گونه‌] كه پروردگارت بدان وحى كرده است"
  99,6,"آن روز، مردم [به حال‌] پراكنده برآيند تا [نتيجه‌] كارهايشان به آنان نشان داده شود"
  99,7,"پس هر كه هموزن ذرّه‌اى نيكى كند [نتيجه‌] آن را خواهد ديد"
  99,8,"و هر كه هموزن ذرّه‌اى بدى كند [نتيجه‌] آن را خواهد ديد"
  100,1,"سوگند به ماديانهائى كه با همهمه تازانند و با سم‌[هاى‌] خود از سنگ آتش مى‌جهانند"
  100,2,"و برق [از سنگ‌] همى جهانند،"
  100,3,و صبحگاهان هجوم آرند،
  100,4,"و با آن [يورش‌]، گردى برانگيزند،"
  100,5,"و بدان [هجوم‌]، در دل گروهى درآيند،"
  100,6,كه انسان نسبت به پروردگارش سخت ناسپاس است،
  100,7,"و او خود بر اين [امر]، نيك گواه است"
  100,8,و راستى او سخت شيفته مال است
  100,9,مگر نمى‌داند كه چون آنچه در گورهاست بيرون ريخته گردد،
  100,10,و آنچه در سينه‌هاست فاش شود،
  100,11,"در چنان روزى پروردگارشان به [حال‌] ايشان نيك آگاه است؟"
  101,1,كوبنده،
  101,2,چيست كوبنده؟
  101,3,و تو چه دانى كه كوبنده چيست؟
  101,4,"روزى كه مردم چون پروانه‌[هاى‌] پراكنده گردند،"
  101,5,و كوه‌ها مانند پشم زده‌شده رنگين شود
  101,6,اما هر كه سنجيده‌هايش سنگين برآيد،
  101,7,پس وى در زندگى خوشى خواهد بود
  101,8,و اما هر كه سنجيده‌هايش سبك بر آيد،
  101,9,پس جايش «هاويه» باشد
  101,10,و تو چه دانى كه آن چيست؟
  101,11,آتشى است سوزنده
  102,1,تفاخر به بيشترداشتن، شما را غافل داشت
  102,2,"تا كارتان [و پايتان‌] به گورستان رسيد"
  102,3,نه چنين است، زودا كه بدانيد
  102,4,باز هم نه چنين است، زودا كه بدانيد
  102,5,هرگز چنين نيست، اگر علم‌اليقين داشتيد
  102,6,به يقين دوزخ را مى‌بينيد
  102,7,سپس آن را قطعاً به عين‌اليقين درمى‌يابيد
  102,8,"سپس در همان روز است كه از نعمت [روى زمين‌] پرسيده خواهيد شد"
  103,1,"سوگند به عصر [غلبه حق بر باطل‌]،"
  103,2,كه واقعاً انسان دستخوش زيان است؛
  103,3,مگر كسانى كه گرويده و كارهاى شايسته كرده و همديگر را به حق سفارش و به شكيبايى توصيه كرده‌اند
  104,1,واى بر هر بدگوى عيبجويى،
  104,2,كه مالى گرد آورد و برشمردش
  104,3,پندارد كه مالش او را جاويد كرده،
  104,4,ولى نه! قطعاً در آتش خردكننده فرو افكنده خواهد شد
  104,5,و تو چه دانى كه آن آتش خردكننده چيست؟
  104,6,"آتش افروخته خدا[يى‌] است"
  104,7,"[آتشى‌] كه به دلها مى‌رسد"
  104,8,آنان را در ميان فرامى‌گيرد
  104,9,"[آتشى كه‌] در ستونهايى دراز است"
  105,1,مگر نديدى پروردگارت با پيلداران چه كرد؟
  105,2,آيا نيرنگشان را بر باد نداد؟
  105,3,و بر سر آنها، دسته دسته پرندگانى «اَبابيل» فرستاد
  105,4,"[كه‌] بر آنان سنگهايى از گل [سخت‌] مى‌افكندند"
  105,5,"و [سرانجام، خدا] آنان را مانند كاه جويده‌شده گردانيد"
  106,1,براى الفت‌دادن قريش،
  106,2,"الفتشان هنگام كوچ زمستان و تابستان، [خدا پيلداران را نابود كرد]"
  106,3,پس بايد خداوندِ اين خانه را بپرستند؛
  106,4,"همان [خدايى‌] كه در گرسنگى غذايشان داد، و از بيم [دشمن‌] آسوده‌خاطرشان كرد"
  107,1,"آيا كسى را كه [روز] جزا را دروغ مى‌خواند، ديدى؟"
  107,2,اين همان كس است كه يتيم را بسختى مى‌راند،
  107,3,و به خوراك‌دادن بينوا ترغيب نمى‌كند
  107,4,پس واى بر نمازگزارانى
  107,5,كه از نمازشان غافلند،
  107,6,آنان كه ريا مى‌كنند،
  107,7,"و از [دادن‌] زكات [و وسايل و مايحتاج خانه‌] خوددارى مى‌ورزند"
  108,1,"ما تو را [چشمه‌] كوثر داديم،"
  108,2,پس براى پروردگارت نماز گزار و قربانى كن
  108,3,دشمنت خود بى‌تبار خواهد بود
  109,1,"بگو: «اى كافران،"
  109,2,آنچه مى‌پرستيد، نمى‌پرستم
  109,3,و آنچه مى‌پرستم، شما نمى‌پرستيد
  109,4,و نه آنچه پرستيديد من مى‌پرستم
  109,5,و نه آنچه مى‌پرستم شما مى‌پرستيد
  109,6,دين شما براى خودتان، و دين من براى خودم.»
  110,1,چون يارى خدا و پيروزى فرا رسد،
  110,2,و ببينى كه مردم دسته‌دسته در دين خدا درآيند،
  110,3,پس به ستايش پروردگارت نيايشگر باش و از او آمرزش خواه، كه وى همواره توبه‌پذير است
  111,1,بريده باد دو دست ابولهب، و مرگ بر او باد
  111,2,دارايى او و آنچه اندوخت، سودش نكرد
  111,3,بزودى در آتشى پرزبانه درآيد
  111,4,"و زنش، آن هيمه‌كش [آتش فروز]،"
  111,5,بر گردنش طنابى از ليف خرماست
  112,1,"بگو: «اوست خداى يگانه،"
  112,2,"خداى صمد [ثابت - متعالى‌]،"
  112,3,"[كسى را] نزاده، و زاده نشده است،"
  112,4,و هيچ كس او را همتا نيست.»
  113,1,"بگو: «پناه مى‌برم به پروردگار سپيده دم،"
  113,2,از شرّ آنچه آفريده،
  113,3,و از شرّ تاريكى چون فراگيرد،
  113,4,و از شرّ دمندگان افسون در گره‌ها،
  113,5,"و از شرّ [هر] حسود، آنگاه كه حسد ورزد.»"
  114,1,"بگو: «پناه مى‌برم به پروردگار مردم،"
  114,2,پادشاه مردم،
  114,3,معبود مردم،
  114,4,از شرّ وسوسه‌گر نهانى؛
  114,5,آن كس كه در سينه‌هاى مردم وسوسه مى‌كند،
  114,6,"چه از جنّ و [چه از] انس.»"