quran[842]{c,v,t}:
  37,1,"سوگند به صف بستگان -كه صفى [با شكوه‌] بسته‌اند"
  37,2,و به زجركنندگان -كه به سختى زجر مى‌كنند
  37,3,"و به تلاوت‌كنندگان [آيات الهى‌]"
  37,4,كه قطعاً معبود شما يگانه است
  37,5,پروردگار آسمانها و زمين و آنچه ميان آن دو است، و پروردگار خاورها
  37,6,ما آسمان اين دنيا را به زيور اختران آراستيم
  37,7,"و [آن را] از هر شيطان سركشى نگاه داشتيم"
  37,8,"[به طورى كه‌] نمى‌توانند به انبوه [فرشتگان‌] عالَم بالا گوش فرا دهند، و از هر سوى پرتاب مى‌شوند"
  37,9,با شدت به دور رانده مى‌شوند، و برايشان عذابى دايم است
  37,10,"مگر كسى كه [از سخن بالاييان‌] يكباره استراق سمع كند، كه شهابى شكافنده از پى او مى‌تازد"
  37,11,"پس، [از كافران‌] بپرس: آيا ايشان [از نظر] آفرينش سخت‌ترند يا كسانى كه [در آسمانها] خلق كرديم؟ ما آنان را از گِلى چسبنده پديد آورديم"
  37,12,"بلكه عجب مى‌دارى و [آنها] ريشخند مى‌كنند"
  37,13,و چون پند داده شوند عبرت نمى‌گيرند
  37,14,و چون آيتى ببينند به ريشخند مى‌پردازند
  37,15,"و مى‌گويند: «اين جز سحرى آشكار نيست.»"
  37,16,"«آيا چون مرديم و خاك و استخوانهاى [خُرد] گرديديم، آيا راستى برانگيخته مى‌شويم؟"
  37,17,و همين طور پدران اوّليه ما؟!»
  37,18,"بگو: «آرى! در حالى كه شما خواريد!»"
  37,19,و آن تنها يك فرياد است و بس! و بناگاه آنان به تماشا خيزند
  37,20,"و مى‌گويند: «اى واى بر ما! اين است روز جزا!»"
  37,21,اين است همان روز داورى كه آن را تكذيب مى‌كرديد
  37,22,كسانى را كه ستم كرده‌اند، با همرديفانشان و آنچه غير از خدا مى‌پرستيده‌اند،
  37,23,گِرد آوريد و به سوى راه جهنم رهبرى‌شان كنيد
  37,24,و بازداشتشان نماييد كه آنها مسؤولند
  37,25,شما را چه شده است كه همديگر را يارى نمى‌كنيد؟
  37,26,"[نه!] بلكه امروز آنان از در تسليم درآمدگانند"
  37,27,"و بعضى روى به بعضى ديگر مى‌آورند [و] از يكديگر مى‌پرسند"
  37,28,"[و] مى‌گويند: «شما [ظاهراً] از درِ راستى با ما درمى‌آمديد [و خود را حق به جانب مى‌نموديد]!»"
  37,29,"[متّهمان‌] مى‌گويند: «[نه!] بلكه با ايمان نبوديد"
  37,30,و ما را بر شما هيچ تسلطى نبود، بلكه خودتان سركش بوديد
  37,31,"پس فرمان پروردگارمان بر ما سزاوار آمد؛ ما واقعاً بايد [عذاب را] بچشيم"
  37,32,و شما را گمراه كرديم، زيرا خودمان گمراه بوديم!»
  37,33,پس، در حقيقت، آنان در آن روز در عذاب شريك يكديگرند
  37,34,"[آرى،] ما با مجرمان چنين رفتار مى‌كنيم"
  37,35,"چرا كه آنان بودند كه وقتى به ايشان گفته مى‌شد: «خدايى جز خداى يگانه نيست»، تكبر مى‌ورزيدند"
  37,36,"و مى‌گفتند: «آيا ما براى شاعرى ديوانه دست از خدايانمان برداريم؟!»"
  37,37,"ولى نه! [او] حقيقت را آورده و فرستادگان را تصديق كرده است"
  37,38,در واقع، شما عذاب پر درد را خواهيد چشيد
  37,39,و جز آنچه مى‌كرديد جزا نمى‌يابيد
  37,40,مگر بندگان پاكدل خدا
  37,41,آنان روزىِ معيّن خواهند داشت
  37,42,"[انواع‌] ميوه‌ها! و آنان مورد احترام خواهند بود"
  37,43,در باغهاى پر نعمت
  37,44,"بر سريرها در برابر همديگر [مى‌نشينند]"
  37,45,با جامى از باده ناب پيرامونشان به گردش درمى‌آيند؛
  37,46,"[باده‌اى‌] سخت سپيد كه نوشندگان را لذتى [خاص‌] مى‌دهد؛"
  37,47,"نه در آن فساد عقل است و نه ايشان از آن به بدمستى [و فرسودگى‌] مى‌افتند"
  37,48,"و نزدشان [دلبرانى‌] فروهشته‌نگاه و فراخ‌ديده باشند"
  37,49,"[از شدّت سپيدى‌] گويى تخم شتر مرغ [زير پَرَ]ند"
  37,50,پس برخى‌شان به برخى روى نموده و از همديگر پرس‌وجو مى‌كنند
  37,51,"گوينده‌اى از آنان مى‌گويد: «راستى من [در دنيا] همنشينى داشتم،"
  37,52,"[كه به من‌] مى‌گفت: «آيا واقعاً تو از باوردارندگانى؟"
  37,53,"آيا وقتى مُرديم و خاك و [مشتى‌] استخوان شديم، آيا واقعاً جزا مى‌يابيم؟»"
  37,54,"[مؤمن‌] مى‌پرسد: «آيا شما اطلاع داريد [كجاست‌]؟»"
  37,55,پس اطلاع حاصل مى‌كند، و او را در ميان آتش مى‌بيند
  37,56,"[و] مى‌گويد: «به خدا سوگند، چيزى نمانده بود كه تو مرا به هلاكت اندازى"
  37,57,"و اگر رحمت پروردگارم نبود، هرآينه من [نيز] از احضارشدگان بودم.»"
  37,58,"[و از روى شوق مى‌گويد:] «آيا ديگر روى مرگ نمى‌بينيم،"
  37,59,جز همان مرگ نخستين خود؟ و ما هرگز عذاب نخواهيم شد؟
  37,60,راستى كه اين همان كاميابى بزرگ است!»
  37,61,"براى چنين [پاداشى‌] بايد كوشندگان بكوشند"
  37,62,آيا از نظر پذيرايى اين بهتر است يا درخت زقوم؟
  37,63,"در حقيقت، ما آن را براى ستمگران [مايه آزمايش و] عذابى گردانيديم"
  37,64,آن، درختى است كه از قعر آتش سوزان مى‌رويد،
  37,65,ميوه‌اش گويى چون كله‌هاى شياطين است،
  37,66,"پس [دوزخيان‌] حتماً از آن مى‌خورند و شكمها را از آن پر مى‌كنند،"
  37,67,سپس ايشان را بر سر آن، آميغى از آب جوشان است؛
  37,68,آنگاه بازگشتشان بى‌گمان به سوى دوزخ است
  37,69,آنها پدران خود را گمراه يافتند،
  37,70,پس ايشان به دنبال آنها مى‌شتابند
  37,71,و قطعاً پيش از آنها بيشتر پيشينيان به گمراهى افتادند
  37,72,و حال آنكه مسلماً در ميانشان هشداردهندگانى فرستاديم
  37,73,پس ببين فرجام هشدارداده‌شدگان چگونه بود
  37,74,به استثناى بندگان پاكدل خدا
  37,75,و نوح، ما را ندا داد، و چه نيك اجابت‌كننده بوديم
  37,76,و او و كسانش را از اندوه بزرگ رهانيديم
  37,77,"و [تنها] نسل او را باقى گذاشتيم"
  37,78,"و در ميان آيندگان [آوازه نيك‌] او را بر جاى گذاشتيم"
  37,79,درود بر نوح در ميان جهانيان
  37,80,ما اين گونه نيكوكاران را پاداش مى‌دهيم
  37,81,به راستى او از بندگان مؤمن ما بود
  37,82,سپس ديگران را غرق كرديم
  37,83,و بى‌گمان، ابراهيم از پيروان اوست
  37,84,"آنگاه كه با دلى پاك به [پيشگاه‌] پروردگارش آمد"
  37,85,"چون به پدر[خوانده‌] و قوم خود گفت: «چه مى‌پرستيد؟"
  37,86,"آيا غير از آنها، به دروغ، خدايانى [ديگر] مى‌خواهيد؟"
  37,87,پس گمانتان به پروردگار جهانها چيست؟»
  37,88,پس نظرى به ستارگان افكند،
  37,89,"و گفت: «من كسالت دارم!»"
  37,90,پس پشت‌كنان از او روى برتافتند
  37,91,"تا نهانى به سوى خدايانشان رفت و [به ريشخند] گفت: «آيا غذا نمى‌خوريد؟"
  37,92,شما را چه شده كه سخن نمى‌گوييد؟!»
  37,93,پس با دست راست، بر سر آنها زدن گرفت
  37,94,تا دوان دوان سوى او روى‌آور شدند
  37,95,"[ابراهيم‌] گفت: «آيا آنچه را مى‌تراشيد، مى‌پرستيد؟"
  37,96,با اينكه خدا شما و آنچه را كه برمى‌سازيد آفريده است!»
  37,97,"گفتند: «برايش [كوره‌]خانه‌اى بسازيد و در آتشش بيندازيد»"
  37,98,"پس خواستند به از نيرنگى زنند؛ و[لى‌] ما آنان را پست گردانيديم"
  37,99,"و [ابراهيم‌] گفت: «من به سوى پروردگارم رهسپارم، زودا كه مرا راه نمايد!»"
  37,100,"«اى پروردگار من! مرا [فرزندى‌] از شايستگان بخش.»"
  37,101,پس او را به پسرى بردبار مژده داديم
  37,102,"و وقتى با او به جايگاه «سعى» رسيد، گفت: «اى پسرك من! من در خواب [چنين‌] مى‌بينم كه تو را سَرْ مى‌بُرم، پس ببين چه به نظرت مى‌آيد؟» گفت: «اى پدر من! آنچه را مأمورى بكن! ان شاء الله مرا از شكيبايان خواهى يافت.»"
  37,103,"پس وقتى هر دو تن دردادند [و همديگر را بدرود گفتند] و [پسر] را به پيشانى بر خاك افكند،"
  37,104,او را ندا داديم كه اى ابراهيم
  37,105,"رؤيا[ى خود] را حقيقت بخشيدى! ما نيكوكاران را چنين پاداش مى‌دهيم"
  37,106,راستى كه اين همان آزمايش آشكار بود
  37,107,و او را در ازاى قربانى بزرگى باز رهانيديم
  37,108,"و در [ميان‌] آيندگان براى او [آوازه نيك‌] به جاى گذاشتيم"
  37,109,درود بر ابراهيم
  37,110,نيكوكاران را چنين پاداش مى‌دهيم
  37,111,در حقيقت، او از بندگان با ايمان ما بود
  37,112,"و او را به اسحاق كه پيامبرى از [جمله‌] شايستگان است مژده داديم"
  37,113,"و به او و به اسحاق بركت داديم، و از نسل آن دو برخى نيكوكار و [برخى‌] آشكارا به خود ستمكار بودند"
  37,114,و در حقيقت، بر موسى و هارون منت نهاديم
  37,115,و آن دو و قومشان را از اندوه بزرگ رهانيديم
  37,116,و آنان را يارى داديم تا ايشان غالب آمدند
  37,117,و آن دو را كتاب روشن داديم
  37,118,و هر دو را به راه راست هدايت كرديم
  37,119,"و براى آن دو در [ميان‌] آيندگان [نام نيك‌] به جاى گذاشتيم"
  37,120,درود بر موسى و هارون
  37,121,ما نيكوكاران را چنين پاداش مى‌دهيم،
  37,122,زيرا آن دو از بندگان با ايمان ما بودند
  37,123,"و به راستى الياس از فرستادگان [ما] بود"
  37,124,"چون به قوم خود گفت: «آيا پروا نمى‌داريد؟"
  37,125,آيا «بعل» را مى‌پرستيد و بهترين آفرينندگان را وامى‌گذاريد؟
  37,126,"[يعنى:] خدا را كه پروردگار شما و پروردگار پدران پيشين شماست؟"
  37,127,"پس او را دروغگو شمردند، و قطعاً آنها [در آتش‌] احضار خواهند شد"
  37,128,مگر بندگان پاكدين خدا
  37,129,"و براى او در [ميان‌] آيندگان [آوازه نيك‌] به جاى گذاشتيم"
  37,130,درود بر پيروان الياس
  37,131,ما نيكوكاران را اين گونه پاداش مى‌دهيم،
  37,132,زيرا او از بندگان با ايمان ما بود
  37,133,و در حقيقت، لوط از زمره فرستادگان بود
  37,134,آنگاه كه او و همه كسانش را رهانيديم
  37,135,"جز پيرزنى كه در ميان باقى‌ماندگان [و خاكسترشدگان‌] بود"
  37,136,سپس ديگران را هلاك كرديم
  37,137,و در حقيقت، شما بر آنان صبحگاهان
  37,138,و شامگاهان مى‌گذريد! آيا به فكر فرو نمى‌رويد؟
  37,139,و در حقيقت، يونس از زمره فرستادگان بود
  37,140,آنگاه كه به سوى كشتى پر، بگريخت
  37,141,"پس [سرنشينان‌] با هم قرعه انداختند و [يونس‌] از باختگان شد"
  37,142,"[او را به دريا افكندند] و عنبرماهى او را بلعيد در حالى كه او نكوهشگر خويش بود"
  37,143,و اگر او از زمره تسبيح‌كنندگان نبود،
  37,144,"قطعاً تا روزى كه برانگيخته مى‌شوند، در شكم آن [ماهى‌] مى‌ماند"
  37,145,پس او را در حالى كه ناخوش بود به زمين خشكى افكنديم
  37,146,"و بر بالاى [سرِ] او درختى از [نوع‌] كدوبُن رويانيديم"
  37,147,"و او را به سوى يكصدهزار [نفر از ساكنان نينوا] يا بيشتر روانه كرديم"
  37,148,پس ايمان آوردند و تا چندى برخوردارشان كرديم
  37,149,"پس، از مشركان جويا شو: آيا پروردگارت را دختران و آنان را پسران است؟"
  37,150,يا فرشتگان را مادينه آفريديم و آنان شاهد بودند؟
  37,151,هش‌دار كه اينان از دروغ پردازى خود قطعاً خواهند گفت
  37,152,«خدا فرزند آورده!» در حالى كه آنها قطعاً دروغگويانند
  37,153,"آيا [خدا] دختران را بر پسران برگزيده است؟"
  37,154,شما را چه شده؟ چگونه داورى مى‌كنيد؟
  37,155,آيا سرِ پند گرفتن نداريد؟
  37,156,"يا دليلى آشكار [در دست‌] داريد؟"
  37,157,پس اگر راست مى‌گوييد كتابتان را بياوريد
  37,158,"و ميان خدا و جن‌ها پيوندى انگاشتند و حال آنكه جنيان نيك دانسته‌اند كه [براى حساب پس‌دادن،] خودشان احضار خواهند شد"
  37,159,خدا منزه است از آنچه در وصف مى‌آورند
  37,160,به استثناى بندگان پاكدل خدا
  37,161,"در حقيقت، شما و آنچه [كه شما آن را] مى‌پرستيد،"
  37,162,بر ضد او گمراه‌گر نيستيد،
  37,163,مگر كسى را كه به دوزخ رفتنى است
  37,164,"و هيچ يك از ما [فرشتگان‌] نيست مگر [اينكه‌] براى او [مقام و] مرتبه‌اى معيّن است"
  37,165,"و در حقيقت، ماييم كه [براى انجام فرمان خدا] صف بسته‌ايم"
  37,166,و ماييم كه خود تسبيح‌گويانيم
  37,167,"و [مشركان‌] به تأكيد مى‌گفتند"
  37,168,"«اگر پند [نامه‌ا]ى از پيشينيان نزد ما بود،"
  37,169,قطعاً از بندگان خالص خدا مى‌شديم!»
  37,170,"ولى [وقتى قرآن آمد] به آن كافر شدند، و زودا كه بدانند"
  37,171,"و قطعاً فرمان ما در باره بندگان فرستاده ما از پيش [چنين‌] رفته است"
  37,172,"كه آنان [بر دشمنان خودشان‌] حتماً پيروز خواهند شد"
  37,173,و سپاه ما هرآينه غالب‌آيندگانند
  37,174,"پس تا مدتى [معيّن‌] از آنان روى برتاب"
  37,175,و آنان را بنگر كه خواهند ديد
  37,176,آيا عذاب ما را شتابزده خواستارند؟
  37,177,"[پس هشدارداده‌شدگان را] آنگاه كه عذاب به خانه آنان فرود آيد چه بد صبحگاهى است"
  37,178,"و از ايشان تا مدتى [معيّن‌] روى برتاب"
  37,179,و بنگر كه خواهند ديد
  37,180,منزه است پروردگار تو، پروردگار شكوهمند، از آنچه وصف مى‌كنند
  37,181,و درود بر فرستادگان
  37,182,و ستايش، ويژه خدا، پروردگار جهانهاست
  38,1,صاد. سوگند به قرآن پراندرز
  38,2,آرى، آنان كه كفر ورزيدند در سركشى و ستيزه‌اند
  38,3,"چه بسيار نسلها كه پيش از ايشان هلاك كرديم كه [ما را] به فرياد خواندند، و[لى‌] ديگر مجال گريز نبود"
  38,4,"و از اينكه هشداردهنده‌اى از خودشان برايشان آمده درشگفتند، و كافران مى گويند: «اين، ساحرى شيّاد است"
  38,5,"آيا خدايان [متعدد] را خداى واحدى قرار داده؟ اين واقعاً چيز عجيبى است.»"
  38,6,"و بزرگانشان روان شدند [و گفتند:] «برويد و بر خدايان خود ايستادگى نماييد كه اين امر قطعاً هدف [ما]ست"
  38,7,"[از طرفى‌] اين [مطلب‌] را در آيين اخير [عيسوى هم‌] نشنيده‌ايم، اين [ادّعا] جز دروغ‌بافى نيست"
  38,8,"آيا از ميان ما قرآن بر او نازل شده است؟» [نه!] بلكه آنان در باره قرآنِ من دودلند. [نه،] بلكه هنوز عذاب [مرا] نچشيده‌اند"
  38,9,آيا گنجينه‌هاى رحمت پروردگار ارجمندِ بسيار بخشنده تو نزد ايشان است؟
  38,10,"آيا فرمانروايى آسمانها و زمين و آنچه ميان آن دو است از آنِ ايشان است؟ [اگر چنين است‌] پس [با چنگ زدن‌] در آن اسباب به بالا روند"
  38,11,"اين سپاهك دسته‌هاى دشمن در آنجا [=بَدْر] در هم شكستنى‌اند"
  38,12,"پيش از ايشان قوم نوح و عاد و فرعونِ صاحب [عمارت و] خرگاهها تكذيب كردند"
  38,13,"و ثمود و قوم لوط و اصحاب ايكه [نيز به تكذيب پرداختند] آنها دسته‌هاى مخالف بودند"
  38,14,"هيچ كدام نبودند كه پيامبران [ما] را تكذيب نكنند، پس عقوبت [من بر آنان‌] سزاوار آمد"
  38,15,"و اينان جز يك فرياد را انتظار نمى‌بَرند كه هيچ [مجال‌] سر خاراندنى در آن نيست"
  38,16,"و گفتند: «پروردگارا، پيش از [رسيدن‌] روز حساب، بهره ما را [از عذاب‌] به شتاب به ما بده.»"
  38,17,"بر آنچه مى‌گويند صبر كن، و داوود، بنده ما را كه داراى امكانات [متعدّد] بود به ياد آور؛ آرى، او بسيار بازگشت‌كننده [به سوى خدا] بود"
  38,18,"ما كوهها را با او مسخّر ساختيم [كه‌] شامگاهان و بامدادان خداوند را نيايش مى‌كردند"
  38,19,"و پرندگان را از هر سو [بر او] گرد [آورديم‌] همگى [به نواى دلنوازش‌] به سوى او بازگشت‌كننده [و خدا را ستايشگر] بودند"
  38,20,و پادشاهيش را استوار كرديم و او را حكمت و كلام فيصله‌دهنده عطا كرديم
  38,21,"و آيا خبر دادخواهان -چون از نمازخانه [او] بالا رفتند- به تو رسيد؟"
  38,22,"وقتى [به طور ناگهانى‌] بر داوود درآمدند، و او از آنان به هراس افتاد، گفتند: «مترس، [ما] دو مدّعى [هستيم‌] كه يكى از ما بر ديگرى تجاوز كرده، پس ميان ما به حق داورى كن، و از حق دور مشو، و ما را به راه راست راهبر باش.»"
  38,23,"«اين [شخص‌] برادر من است. او را نود و نه ميش، و مرا يك ميش است، و مى‌گويد: آن را به من بسپار، و در سخنورى بر من غالب آمده است.»"
  38,24,"[داوود] گفت: «قطعاً او در مطالبه ميش تو [اضافه‌] بر ميش‌هاى خودش، بر تو ستم كرده، و در حقيقت بسيارى از شريكان به همديگر ستم روا مى‌دارند، به استثناى كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، و اينها بس اندكند، و داوود دانست كه ما او را آزمايش كرده‌ايم. پس، از پروردگارش آمرزش خواست و به رو درافتاد و توبه كرد"
  38,25,"و بر او اين [ماجرا] را بخشوديم؛ و در حقيقت براى او پيش ما تقرّب و فرجامى خوش خواهد بود"
  38,26,"اى داوود، ما تو را در زمين خليفه [و جانشين‌] گردانيديم؛ پس ميان مردم به حق داورى كن، و زنهار از هوس پيروى مكن كه تو را از راه خدا به در كند. در حقيقت كسانى كه از راه خدا به در مى‌روند، به [سزاى‌] آنكه روز حساب را فراموش كرده‌اند عذابى سخت خواهند داشت"
  38,27,"و آسمان و زمين و آنچه را كه ميان اين دو است به باطل نيافريديم، اين گمان كسانى است كه كافر شده [و حق‌پوشى كرده‌]اند، پس واى از آتش بر كسانى كه كافر شده‌اند"
  38,28,"يا [مگر] كسانى را كه گرويده و كارهاى شايسته كرده‌اند، چون مفسدان در زمين مى‌گردانيم، يا پرهيزگاران را چون پليدكاران قرار مى‌دهيم؟"
  38,29,"[اين‌] كتابى مبارك است كه آن را به سوى تو نازل كرده‌ايم تا در [باره‌] آيات آن بينديشند، و خردمندان پند گيرند"
  38,30,"و سليمان را به داوود بخشيديم. چه نيكو بنده‌اى. به راستى او توبه‌كار [و ستايشگر] بود"
  38,31,"هنگامى كه [طرف‌] غروب، اسبهاى اصيل را بر او عرضه كردند،"
  38,32,"[سليمان‌] گفت: «واقعاً من دوستى اسبان را بر ياد پروردگارم ترجيح دادم تا [هنگام نماز گذشت و خورشيد] در پس حجاب ظلمت شد.»"
  38,33,"[گفت: « اسبها] را نزد من باز آوريد.» پس شروع كرد به دست كشيدن بر ساقها و گردن آنها [و سرانجام وقف كردن آنها در راه خدا]"
  38,34,و قطعاً سليمان را آزموديم و بر تخت او جسدى بيفكنديم؛ پس به توبه باز آمد
  38,35,"گفت: «پروردگارا، مرا ببخش و مُلكى به من ارزانى دار كه هيچ كس را پس از من سزاوار نباشد، در حقيقت، تويى كه خود بسيار بخشنده‌اى.»"
  38,36,پس باد را در اختيار او قرار داديم كه هر جا تصميم مى‌گرفت، به فرمان او نرم، روان مى‌شد
  38,37,"و شيطانها را [از] بنّا و غواص،"
  38,38,"تا [وحشيان‌] ديگر را كه جفت جفت با زنجيرها به هم بسته بودند [تحت فرمانش درآورديم‌]"
  38,39,"[گفتيم:] «اين بخشش ماست، [آن را] بى‌شمار ببخش يا نگاه دار.»"
  38,40,و قطعاً براى او در پيشگاه ما تقرّب و فرجام نيكوست
  38,41,"و بنده ما ايوب را به ياد آور، آنگاه كه پروردگارش را ندا داد كه: «شيطان مرا به رنج و عذاب مبتلا كرد.»"
  38,42,"[به او گفتيم:] «با پاى خود [به زمين‌] بكوب، اينك اين چشمه‌سارى است سرد و آشاميدنى.»"
  38,43,"و [مجدداً] كسانش را و نظاير آنها را همراه آنها به او بخشيديم، تا رحمتى از جانب ما و عبرتى براى خردمندان باشد"
  38,44,"[و به او گفتيم:] «يك بسته تركه به دستت برگير و [همسرت را] با آن بزن و سوگند مشكن.» ما او را شكيبا يافتيم. چه نيكوبنده‌اى! به راستى او توبه‌كار بود"
  38,45,و بندگان ما ابراهيم و اسحاق و يعقوب را كه نيرومند و ديده‌ور بودند به يادآور
  38,46,ما آنان را با موهبت ويژه‌اى -كه يادآورى آن سراى بود- خالص گردانيديم
  38,47,و آنان در پيشگاه ما جداً از برگزيدگان نيكانند
  38,48,"و اسماعيل و يسع و ذوالكفل را به ياد آور [كه‌] همه از نيكانند"
  38,49,اين يادكردى است، و قطعاً براى پرهيزگاران فرجامى نيك است
  38,50,"باغهاى هميشگى در حالى كه درهاى [آنها] برايشان گشوده‌است"
  38,51,"در آنجا تكيه مى‌زنند [و] ميوه‌هاى فراوان و نوشيدنى در آنجا طلب مى‌كنند"
  38,52,"و نزدشان [دلبران‌] فروهشته‌نگاه همسال است"
  38,53,اين است آنچه براى روز حساب به شما وعده داده مى‌شد
  38,54,"[مى‌گويند:] «در حقيقت، اين روزىِ ماست و آن را پايانى نيست.»"
  38,55,"اين است [حال بهشتيان‌] و [اما] براى طغيانگران واقعاً بد فرجامى است"
  38,56,به جهنّم درمى‌آيند، و چه بد آرامگاهى است
  38,57,اين جوشاب و چركاب است، بايد آن را بچشند
  38,58,"و از همين گونه، انواع ديگر [عذابها]"
  38,59,"اينها گروهى‌اند كه با شما به اجبار [در آتش‌] درمى‌آيند. بدا به حال آنها، زيرا آنان داخل آتش مى‌شوند"
  38,60,"[به رؤساى خود] مى‌گويند: «بلكه بر خود شما خوش مباد! اين [عذاب‌] را شما خود براى ما از پيش فراهم آورديد، و چه بد قرارگاهى است.»"
  38,61,"مى‌گويند: «پروردگارا، هر كس اين [عذاب‌] را از پيش براى ما فراهم آورده، عذاب او را در آتش دو چندان كن.»"
  38,62,"و مى‌گويند: «ما را چه شده است كه مردانى را كه ما آنان را از [زمره‌] اشرار مى‌شمرديم نمى‌بينيم؟"
  38,63,"آيا آنان را [در دنيا] به ريشخند مى‌گرفتيم يا چشمها[ى ما] بر آنها نمى‌افتد؟»"
  38,64,اين مجادله اهل آتش قطعاً راست است
  38,65,"بگو: «من فقط هشداردهنده‌اى هستم، و جز خداى يگانه قهار معبودى ديگر نيست"
  38,66,پروردگار آسمانها و زمين و آنچه ميان آن دو است، همان شكست‌ناپذير آمرزنده
  38,67,"بگو: «اين خبرى بزرگ است،"
  38,68,"[كه‌] شما از آن روى برمى‌تابيد"
  38,69,مرا در باره ملاء اعلى هيچ دانشى نبود آنگاه كه مجادله مى‌كردند
  38,70,"به من هيچ [چيز] وحى نمى‌شود، جز اينكه من هشداردهنده‌اى آشكارم"
  38,71,"آنگاه كه پروردگارت به فرشتگان گفت: «من بشرى را از گِل خواهم آفريد"
  38,72,"پس چون او را [كاملاً] درست كردم و از روح خويش در آن دميدم، سجده‌كنان براى او [به خاك‌] بيفتيد.»"
  38,73,پس همه فرشتگان يكسره سجده كردند
  38,74,"مگر ابليس [كه‌] تكبر نمود و از كافران شد"
  38,75,"فرمود: «اى ابليس، چه چيز تو را مانع شد كه براى چيزى كه به دستان قدرت خويش خلق كردم سجده آورى؟ آيا تكبر نمودى يا از [جمله‌] برترى‌جويانى؟»"
  38,76,"گفت: «من از او بهترم؛ مرا از آتش آفريده‌اى و او را از گِل آفريده‌اى.»"
  38,77,"فرمود: «پس، از آن [مقام‌] بيرون شو، كه تو رانده‌اى"
  38,78,و تا روز جزا لعنت من بر تو باد.»
  38,79,"گفت: «پروردگارا، پس مرا تا روزى كه برانگيخته مى‌شوند مهلت ده.»"
  38,80,"فرمود: «در حقيقت، تو از مهلت‌يافتگانى،"
  38,81,تا روز معين معلوم.»
  38,82,"[شيطان‌] گفت: «پس به عزّت تو سوگند كه همگى را جداً از راه به در مى‌برم،"
  38,83,مگر آن بندگان پاكدل تو را.»
  38,84,"فرمود: «حق [از من‌] است و حق را مى‌گويم"
  38,85,هرآينه جهنّم را از تو و از هر كس از آنان كه تو را پيروى كند، از همگى‌شان، خواهم انباشت.»
  38,86,"بگو: «مزدى بر اين [رسالت‌] از شما طلب نمى‌كنم و من از كسانى نيستم كه چيزى از خود بسازم و به خدا نسبت دهم"
  38,87,"اين [قرآن‌] جز پندى براى جهانيان نيست"
  38,88,و قطعاً پس از چندى خبر آن را خواهيد دانست.»
  39,1,"نازل شدن [اين كتاب‌] از جانب خداى شكست‌ناپذير سنجيده‌كار است"
  39,2,"ما [اين‌] كتاب را به حق به سوى تو فرود آورديم، پس خدا را -در حالى كه اعتقاد [خود] را براى او خالص‌كننده‌اى- عبادت كن"
  39,3,"آگاه باشيد: آيين پاك از آنِ خداست، و كسانى كه به جاى او دوستانى براى خود گرفته‌اند [به اين بهانه كه:] ما آنها را جز براى اينكه ما را هر چه بيشتر به خدا نزديك گردانند، نمى‌پرستيم، البته خدا ميان آنان در باره آنچه كه بر سر آن اختلاف دارند، داورى خواهد كرد. در حقيقت، خدا آن كسى را كه دروغ‌پرداز ناسپاس است هدايت نمى‌كند"
  39,4,"اگر خدا مى‌خواست براى خود فرزندى بگيرد، قطعاً از [ميان‌] آنچه خلق مى‌كند، آنچه را مى‌خواست برمى‌گزيد. منزّه است او، اوست خداى يگانه قهار"
  39,5,آسمانها و زمين را به حق آفريد. شب را به روز درمى‌پيچد، و روز را به شب درمى‌پيچد و آفتاب و ماه را تسخير كرد. هر كدام تا مدتى معين روانند. آگاه باش كه او همان شكست‌ناپذير آمرزنده است
  39,6,"شما را از نفسى واحد آفريد، سپس جفتش را از آن قرار داد، و براى شما از دامها هشت قسم پديد آورد. شما را در شكمهاى مادرانتان آفرينشى پس از آفرينشى [ديگر] در تاريكيهاى سه گانه: [مَشيمه و رحم و شكم‌] خلق كرد. اين است خدا، پروردگار شما، فرمانروايى [و حكومت مطلق‌] از آنِ اوست. خدايى جز او نيست، پس چگونه [و كجا از حق‌] برگردانيده مى‌شويد؟"
  39,7,"اگر كفر ورزيد، خدا از شما سخت بى‌نياز است و براى بندگانش كفران را خوش نمى‌دارد، و اگر سپاس داريد آن را براى شما مى‌پسندد، و هيچ بردارنده‌اى بار [گناه‌] ديگرى را برنمى‌دارد، آنگاه بازگشت شما به سوى پروردگارتان است، و شما را به آنچه مى‌كرديد خبر خواهد داد، كه او به راز دلها داناست"
  39,8,"و چون به انسان آسيبى رسد، پروردگارش را -در حالى كه به سوى او بازگشت‌كننده است- مى‌خواند؛ سپس چون او را از جانب خود نعمتى عطا كند، آن [مصيبتى‌] را كه در رفع آن پيشتر به درگاه او دعا مى‌كرد، فراموش مى‌نمايد و براى خدا همتايانى قرار مى‌دهد تا [خود و ديگران را] از راه او گمراه گرداند. بگو: «به كفرت اندكى برخوردار شو كه تو از اهل آتشى.»"
  39,9,"[آيا چنين كسى بهتر است‌] يا آن كسى كه او در طول شب در سجده و قيام اطاعت [خدا] مى‌كند [و] از آخرت مى‌ترسد و رحمت پروردگارش را اميد دارد؟ بگو: «آيا كسانى كه مى‌دانند و كسانى كه نمى‌دانند يكسانند؟» تنها خردمندانند كه پندپذيرند"
  39,10,"بگو: «اى بندگان من كه ايمان آورده‌ايد، از پروردگارتان پروا بداريد. براى كسانى كه در اين دنيا خوبى كرده‌اند، نيكى خواهد بود، و زمين خدا فراخ است. بى‌ترديد، شكيبايان پاداش خود را بى‌حساب [و] به تمام خواهند يافت.»"
  39,11,"بگو: «من مأمورم كه خدا را -در حالى كه آيينم را براى او خالص گردانيده‌ام- بپرستم،"
  39,12,و مأمورم كه نخستين مسلمانان باشم.»
  39,13,"بگو: «من اگر به پروردگارم عصيان ورزم، از عذاب روزى هولناك مى‌ترسم.»"
  39,14,"بگو: «خدا را مى‌پرستم در حالى كه دينم را براى او بى‌آلايش مى‌گردانم"
  39,15,"پس هر چه را غير از او مى‌خواهيد، بپرستيد «[ولى به آنان‌] بگو:» زيانكاران در حقيقت كسانى‌اند كه به خود و كسانشان در روز قيامت زيان رسانده‌اند؛ آرى، اين همان خسران آشكار است.»"
  39,16,"آنها از بالاى سرشان چترهايى از آتش خواهند داشت و از زير پايشان [نيز] طبق‌هايى [آتشين است‌]، اين [كيفرى‌] است كه خدا بندگانش را به آن بيم مى‌دهد. اى بندگان من، از من بترسيد"
  39,17,"و[لى‌] آنان كه خود را از طاغوت به دور مى‌دارند تا مبادا او را بپرستند و به سوى خدا بازگشته‌اند آنان را مژده باد، پس بشارت ده به آن بندگان من كه"
  39,18,به سخن گوش فرامى‌دهند و بهترين آن را پيروى مى‌كنند؛ اينانند كه خدايشان راه نموده و اينانند همان خردمندان
  39,19,"پس آيا كسى كه فرمان عذاب بر او واجب آمده [كجا روى رهايى دارد]؟ آيا تو كسى را كه در آتش است مى‌رهانى؟"
  39,20,"ليكن كسانى كه از پروردگارشان پروا داشتند، براى ايشان غرفه‌هايى است كه بالاى آنها غرفه‌هايى [ديگر] بنا شده است؛ نهرها از زير آن روان است. وعده خداست؛ خدا خلاف وعده نمى‌كند"
  39,21,"مگر نديده‌اى كه خدا از آسمان، آبى فرود آورد پس آن را به چشمه‌هايى كه در [طبقات زيرين‌] زمين است راه داد، آنگاه به وسيله آن كشتزارى را كه رنگهاى آن گوناگون است بيرون مى‌آورد، سپس خشك مى‌گردد، آنگاه آن را زرد مى‌بينى، سپس خاشاكش مى‌گرداند. قطعاً در اين [دگرگونيها] براى صاحبان خرد عبرتى است"
  39,22,"پس آيا كسى كه خدا سينه‌اش را براى [پذيرش‌] اسلام گشاده، و [در نتيجه‌] برخوردار از نورى از جانب پروردگارش مى‌باشد [همانند فرد تاريكدل است‌]؟ پس واى بر آنان كه از سخت‌دلى ياد خدا نمى‌كنند؛ اينانند كه در گمراهى آشكارند"
  39,23,"خدا زيباترين سخن را [به صورت‌] كتابى متشابه، متضمّن وعد و وعيد، نازل كرده است. آنان كه از پروردگارشان مى‌هراسند، پوست بدنشان از آن به لرزه مى‌افتد، سپس پوستشان و دلشان به ياد خدا نرم مى‌گردد. اين است هدايت خدا، هر كه را بخواهد، به آن راه نمايد، و هر كه را خدا گمراه كند او را راهبرى نيست"
  39,24,"پس آيا آن كس كه [به جاى دستها] با چهره خود، گزند عذاب را روز قيامت دفع مى‌كند [مانند كسى است كه از عذاب ايمن است‌]؟ و به ستمگران گفته مى‌شود: «آنچه را كه دستاوردتان بوده است بچشيد.»"
  39,25,"كسانى [هم‌] كه پيش از آنان بودند به تكذيب پرداختند، و از آنجا كه حدس نمى‌زدند عذاب برايشان آمد"
  39,26,پس خدا در زندگى دنيا رسوايى را به آنان چشانيد، و اگر مى‌دانستند، قطعاً عذاب آخرت بزرگتر است
  39,27,و در اين قرآن از هر گونه مثَلى براى مردم آورديم، باشد كه آنان پندگيرند
  39,28,قرآنى عربى، بى‌هيچ كژى؛ باشد كه آنان راه تقوا پويند
  39,29,"خدا مثَلى زده است: مردى است كه چند خواجه ناسازگار در [مالكيّت‌] او شركت دارند [و هر يك او را به كارى مى‌گمارند] و مردى است كه تنها فرمانبر يك مرد است. آيا اين دو در مثَل يكسانند؟ سپاس خداى را. [نه،] بلكه بيشترشان نمى‌دانند"
  39,30,"قطعاً تو خواهى مُرد، و آنان [نيز] خواهند مُرد؛"
  39,31,سپس شما روز قيامت پيش پروردگارتان مجادله خواهيد كرد
  39,32,"پس كيست ستمگرتر از آن كس كه بر خدا دروغ بست، و [سخن‌] راست را چون به سوى او آمد، دروغ پنداشت؟ آيا جاى كافران در جهنّم نيست؟"
  39,33,و آن كس كه راستى آورد و آن را باور نمود؛ آنانند كه خود پرهيزگارانند
  39,34,براى آنان، هر چه بخواهند پيش پروردگارشان خواهد بود. اين است پاداش نيكوكاران
  39,35,تا خدا، بدترين عملى را كه كرده‌اند، از ايشان بزدايد، و آنان را به بهترين كارى كه مى‌كرده‌اند، پاداش دهد
  39,36,"آيا خدا كفايت‌كننده بنده‌اش نيست؟ و [كافران‌] تو را از آنها كه غير اويند مى‌ترسانند و هر كه را خدا گمراه گرداند برايش راهبرى نيست"
  39,37,و هر كه را خدا هدايت كند گمراه‌كننده‌اى ندارد. مگر خدا نيست كه نيرومند كيفرخواه است؟
  39,38,"و اگر از آنها بپرسى: «چه كسى آسمانها و زمين را خلق كرده؟» قطعاً خواهند گفت: «خدا.» بگو: «[هان‌] چه تصور مى‌كنيد، اگر خدا بخواهد صدمه‌اى به من برساند؛ آيا آنچه را به جاى خدا مى‌خوانيد، مى‌توانند صدمه او را برطرف كنند؛ يا اگر او رحمتى براى من اراده كند آيا آنها مى‌توانند رحمتش را بازدارند؟» بگو: «خدا مرا بس است. اهل توكّل تنها بر او توكّل مى‌كنند.»"
  39,39,"بگو: «اى قوم من، شما بر حسب امكانات خود عمل كنيد، من [نيز] عمل مى‌كنم، پس به زودى خواهيد دانست"
  39,40,"[كه‌] چه كس را عذابى كه رسوايش كند خواهد آمد و عذابى پايدار بر او نازل مى‌شود.»"
  39,41,"ما اين كتاب را براى [رهبرى‌] مردم به حق بر تو فروفرستاديم. پس هر كس هدايت شود، به سود خود اوست، و هر كس بيراهه رود، تنها به زيان خودش گمراه مى‌شود، و تو بر آنها وكيل نيستى"
  39,42,"خدا روح مردم را هنگام مرگشان به تمامى باز مى‌ستاند، و [نيز] روحى را كه در [موقع‌] خوابش نمرده است [قبض مى‌كند]؛ پس آن [نفسى‌] را كه مرگ را بر او واجب كرده نگاه مى‌دارد، و آن ديگر [نفسها] را تا هنگامى معيّن [به سوى زندگى دنيا] بازپس مى‌فرستد. قطعاً در اين [امر] براى مردمى كه مى‌انديشند نشانه‌هايى [از قدرت خدا]ست"
  39,43,"آيا غير از خدا شفاعتگرانى براى خود گرفته‌اند؟ بگو: «آيا هر چند اختيار چيزى را نداشته باشند و نينديشند؟»"
  39,44,"بگو: «شفاعت، يكسره از آن خداست. فرمانروايى آسمانها و زمين خاص اوست؛ سپس به سوى او باز گردانيده مى‌شويد.»"
  39,45,و چون خدا به تنهايى ياد شود، دلهاى كسانى كه به آخرت ايمان ندارند، منزجر مى‌گردد، و چون كسانى غير از او ياد شوند، بناگاه آنان شادمانى مى‌كنند
  39,46,"بگو: «بار الها، اى پديدآورنده آسمانها و زمين، [اى‌] داناى نهان و آشكار، تو خود در ميان بندگانت بر سر آنچه اختلاف مى‌كردند، داورى مى‌كنى.»"
  39,47,"و اگر آنچه در زمين است، يكسره براى كسانى كه ظلم كرده‌اند باشد و نظيرش [نيز] با آن باشد، قطعاً [همه‌] آن را براى رهايى خودشان از سختى عذاب روز قيامت خواهند داد، و آنچه تصوّر[ش را ]نمى‌كردند، از جانب خدا بر ايشان آشكار مى‌گردد"
  39,48,"و [نتيجه‌] گناهانى كه مرتكب شده‌اند، برايشان ظاهر مى‌شود، و آنچه را كه بدان ريشخند مى‌كردند، آنها را فرا مى‌گيرد"
  39,49,"و چون انسان را آسيبى رسد، ما را فرا مى‌خواند؛ سپس چون نعمتى از جانب خود به او عطا كنيم مى‌گويد: «تنها آن را به دانش خود يافته‌ام». نه چنان است، بلكه آن آزمايشى است، ولى بيشترشان نمى‌دانند"
  39,50,"قطعاً كسانى كه پيش از آنان بودند [نيز] اين [سخن‌] را گفتند و آنچه به دست آورده بودند، كارى برايشان نكرد"
  39,51,"تا [آنكه‌] كيفر آنچه مرتكب شده بودند، بديشان رسيد و كسانى از اين [گروه‌] كه ستم كرده‌اند، به زودى نتايج سوء آنچه مرتكب شده‌اند، بديشان خواهد رسيد و آنان درمانده‌كننده [ما] نيستند"
  39,52,"آيا ندانسته‌اند كه خداست كه روزى را براى هر كس كه بخواهد، گشاده يا تنگ مى‌گرداند؟ قطعاً در اين [اندازه‌گيرى‌] براى مردمى كه ايمان دارند نشانه‌هايى [از حكمت‌] است"
  39,53,"بگو: «اى بندگان من -كه بر خويشتن زياده‌روى روا داشته‌ايد- از رحمت خدا نوميد مشويد. در حقيقت، خدا همه گناهان را مى‌آمرزد، كه او خود آمرزنده مهربان است"
  39,54,و پيش از آنكه شما را عذاب در رسد، و ديگر يارى نشويد، به سوى پروردگارتان بازگرديد، و تسليم او شويد
  39,55,و پيش از آنكه به طور ناگهانى و در حالى كه حدس نمى‌زنيد شما را عذاب دررسد، نيكوترين چيزى را كه از جانب پروردگارتان به سوى شما نازل آمده است پيروى كنيد.»
  39,56,"تا آنكه [مبادا] كسى بگويد: «دريغا بر آنچه در حضور خدا كوتاهى ورزيدم؛ بى‌ترديد من از ريشخندكنندگان بودم.»"
  39,57,"يا بگويد: «اگر خدايم هدايت مى‌كرد، مسلماً از پرهيزگاران بودم.»"
  39,58,"يا چون عذاب را ببيند، بگويد: «كاش مرا برگشتى بود تا از نيكوكاران مى‌شدم.»"
  39,59,"[به او گويند:] آرى، نشانه‌هاى من بر تو آمد و آنها را تكذيب كردى و تكبّر ورزيدى و از [جمله‌] كافران شدى"
  39,60,و روز قيامت كسانى را كه بر خدا دروغ بسته‌اند رو سياه مى‌بينى، آيا جاى سركشان در جهنم نيست؟
  39,61,"و خدا كسانى را كه تقوا پيشه كرده‌اند، به [پاس‌] كارهايى كه مايه رستگارى‌شان بوده، نجات مى‌دهد. عذاب به آنان نمى‌رسد و غمگين نخواهند گرديد"
  39,62,خدا آفريدگار هر چيزى است، و اوست كه بر هر چيز نگهبان است
  39,63,كليدهاى آسمان و زمين از آن اوست، و كسانى كه نشانه‌هاى خدا را انكار كردند، آنانند كه زيانكارانند
  39,64,"بگو: «اى نادانان، آيا مرا وادار مى‌كنيد كه جز خدا را بپرستم؟»"
  39,65,"و قطعاً به تو و به كسانى كه پيش از تو بودند وحى شده است: «اگر شرك ورزى حتماً كردارت تباه و مسلماً از زيانكاران خواهى شد.»"
  39,66,بلكه خدا را بپرست و از سپاسگزاران باش
  39,67,"و خدا را آنچنان كه بايد به بزرگى نشناخته‌اند، و حال آنكه روز قيامت زمين يكسره در قبضه [قدرت‌] اوست، و آسمانها در پيچيده به دست اوست؛ او منزّه است و برتر است از آنچه [با وى‌] شريك مى‌گردانند"
  39,68,و در صور دميده مى‌شود، پس هر كه در آسمانها و هر كه در زمين است بيهوش درمى‌افتد، مگر كسى كه خدا بخواهد؛ سپس بار ديگر در آن دميده مى‌شود و بناگاه آنان بر پاى ايستاده مى‌نگرند
  39,69,"و زمين به نور پروردگارش روشن گردد، و كارنامه [اعمال در ميان‌] نهاده شود، و پيامبران و شاهدان را بياورند، و ميانشان به حق داورى گردد، و مورد ستم قرار نگيرند"
  39,70,"و هر كسى [نتيجه‌] آنچه انجام داده است به تمام بيابد و او به آنچه مى‌كنند داناتر است"
  39,71,"و كسانى كه كافر شده‌اند، گروه گروه به سوى جهنّم رانده شوند، تا چون بدان رسند، درهاى آن [به رويشان‌] گشوده گردد و نگهبانانش به آنان گويند: «مگر فرستادگانى از خودتان بر شما نيامدند كه آيات پروردگارتان را بر شما بخوانند و به ديدار چنين روزى شما را هشدار دهند؟» گويند: «چرا»، ولى فرمان عذاب بر كافران واجب آمد"
  39,72,"و گفته شود: «از درهاى دوزخ درآييد، جاودانه در آن بمانيد؛ وه چه بد [جايى‌] است جاى سركشان!»"
  39,73,"و كسانى كه از پروردگارشان پروا داشته‌اند، گروه گروه به سوى بهشت سوق داده شوند، تا چون بدان رسند و درهاى آن [به رويشان‌] گشوده گردد و نگهبانان آن به ايشان گويند: «سلام بر شما، خوش آمديد، در آن درآييد [و] جاودانه [بمانيد].»"
  39,74,"و گويند: «سپاس خدايى را كه وعده‌اش را بر ما راست گردانيد و سرزمين [بهشت‌] را به ما ميراث داد، از هر جاى آن باغ [پهناور] كه بخواهيم جاى مى‌گزينيم.» چه نيك است پاداش عمل‌كنندگان"
  39,75,"و فرشتگان را مى‌بينى كه پيرامون عرش به ستايش پروردگار خود تسبيح مى‌گويند و ميانشان به حق داورى مى‌گردد و گفته مى‌شود: «سپاس، ويژه پروردگار جهانيان است.»"
  40,1,حاء، ميم
  40,2,فرو فرستادن اين كتاب، از جانب خداى ارجمند داناست،
  40,3,"[كه‌] گناه‌بخش و توبه‌پذير [و] سخت‌كيفر [و] فراخ‌نعمت است. خدايى جز او نيست. بازگشت به سوى اوست"
  40,4,"جز آنهايى كه كفر ورزيدند [كسى‌] در آيات خدا ستيزه نمى‌كند، پس رفت و آمدشان در شهرها تو را دستخوش فريب نگرداند"
  40,5,"پيش از اينان قوم نوح، و بعد از آنان دسته‌هاى مخالف [ديگر] به تكذيب پرداختند، و هر امّتى آهنگ فرستاده خود را كردند تا او را بگيرند، و به [وسيله‌] باطل جدال نمودند تا حقيقت را با آن پايمال كنند. پس آنان را فرو گرفتم؛ آيا چگونه بود كيفر من؟"
  40,6,و بدين سان فرمان پروردگارت در باره كسانى كه كفر ورزيده بودند، به حقيقت پيوست كه ايشان همدمان آتش خواهند بود
  40,7,"كسانى كه عرش [خدا] را حمل مى‌كنند، و آنها كه پيرامون آنند، به سپاس پروردگارشان تسبيح مى‌گويند و به او ايمان دارند و براى كسانى كه گرويده‌اند طلب آمرزش مى‌كنند: «پروردگارا، رحمت و دانش [تو بر] هر چيز احاطه دارد؛ كسانى را كه توبه كرده و راه تو را دنبال كرده‌اند ببخش و آنها را از عذاب آتش نگاه دار.»"
  40,8,«پروردگارا، آنان را در باغهاى جاويد كه وعده‌شان داده‌اى، با هر كه از پدران و همسران و فرزندانشان كه به صلاح آمده‌اند، داخل كن، زيرا تو خود ارجمند و حكيمى
  40,9,و آنان را از بديها نگاه دار، و هر كه را در آن روز از بديها حفظ كنى، البته رحمتش كرده‌اى؛ و اين همان كاميابى بزرگ است.»
  40,10,"كسانى كه كافر بوده‌اند مورد ندا قرار مى‌گيرند كه: «قطعاً دشمنى خدا از دشمنى شما نسبت به همديگر سخت‌تر است، آنگاه كه به سوى ايمان فرا خوانده مى‌شديد و انكار مى‌ورزيديد.»"
  40,11,"مى‌گويند: «پروردگارا، دو بار ما را به مرگ رسانيدى و دو بار ما را زنده گردانيدى. به گناهانمان اعتراف كرديم؛ پس آيا راه بيرون‌شدنى [از آتش‌] هست؟»"
  40,12,"اين [كيفر] از آن روى براى شماست كه چون خدا به تنهايى خوانده مى‌شد، كفر مى‌ورزيديد؛ و چون به او شرك آورده مى‌شد، آن را باور مى‌كرديد. پس [امروز] فرمان از آن خداىِ والاىِ بزرگ است"
  40,13,"اوست آن كس كه نشانه‌هاى خود را به شما مى‌نماياند و براى شما از آسمان روزى مى‌فرستد، و جز آن كس كه توبه‌كار است [كسى‌] پند نمى‌گيرد"
  40,14,پس خدا را پاكدلانه فرا خوانيد، هر چند ناباوران را ناخوش افتد
  40,15,"بالابرنده درجات، خداوند عرش، به هر كس از بندگانش كه خواهد آن روح [=فرشته‌] را، به فرمان خويش مى‌فرستد، تا [مردم را] از روز ملاقات [با خدا] بترساند"
  40,16,آن روز كه آنان ظاهر گردند، چيزى از آنها بر خدا پوشيده نمى‌ماند. امروز فرمانروايى از آنِ كيست؟ از آنِ خداوند يكتاى قهّار است
  40,17,"امروز هر كسى به [موجب‌] آنچه انجام داده است كيفر مى‌يابد. امروز ستمى نيست؛ آرى، خدا زودشمار است"
  40,18,"و آنها را از آن روز قريب‌[الوقوع‌] بترسان، آنگاه كه جانها به گلوگاه مى‌رسد در حالى كه اندوه خود را فرو مى‌خورند. براى ستمگران نه يارى است و نه شفاعتگرى كه مورد اطاعت باشد"
  40,19,"[خدا] نگاههاى دزدانه و آنچه را كه دلها نهان مى‌دارند، مى‌داند"
  40,20,"و خداست كه به حق داورى مى‌كند، و كسانى را كه در برابر او مى‌خوانند [عاجزند و] به چيزى داورى نمى‌كنند؛ در حقيقت، خداست كه خود شنواى بيناست"
  40,21,"آيا در زمين نگرديده‌اند تا ببينند فرجام كسانى كه پيش از آنها [زيسته‌]اند چگونه بوده است؟ آنها از ايشان نيرومندتر [بوده‌] و آثار [پايدارترى‌] در روى زمين [از خود باقى گذاشتند]، با اين همه، خدا آنان را به كيفر گناهانشان گرفتار كرد و در برابر خدا حمايتگرى نداشتند"
  40,22,"اين [كيفر] از آن روى بود كه پيامبرانشان دلايل آشكار برايشان مى‌آوردند ولى [آنها] انكار مى‌كردند. پس خدا [گريبان‌] آنها را گرفت، زيرا او نيرومند سخت‌كيفر است"
  40,23,و به يقين، موسى را با آيات خود و حجّتى آشكار فرستاديم،
  40,24,"به سوى فرعون و هامان و قارون، [امّا آنان‌] گفتند: «افسونگرى شيّاد است.»"
  40,25,"پس وقتى حقيقت را از جانب ما براى آنان آورد، گفتند: «پسران كسانى را كه با او ايمان آورده‌اند بكشيد و زنانشان را زنده بگذاريد.» و[لى‌] نيرنگ كافران جز در گمراهى نيست"
  40,26,"و فرعون گفت: «مرا بگذاريد موسى را بكشم تا پروردگارش را بخواند. من مى‌ترسم آيين شما را تغيير دهد يا در اين سرزمين فساد كند.»"
  40,27,"و موسى گفت: «من از هر متكبرى كه به روز حساب عقيده ندارد، به پروردگار خود و پروردگار شما پناه برده‌ام.»"
  40,28,"و مردى مؤمن از خاندان فرعون كه ايمان خود را نهان مى‌داشت، گفت: «آيا مردى را مى‌كشيد كه مى‌گويد: پروردگار من خداست؟ و مسلماً براى شما از جانب پروردگارتان دلايل آشكارى آورده، و اگر دروغگو باشد دروغش به زيان اوست، و اگر راستگو باشد برخى از آنچه به شما وعده مى‌دهد به شما خواهد رسيد، چرا كه خدا كسى را كه افراطكار دروغزن باشد هدايت نمى‌كند"
  40,29,"اى قوم من، امروز فرمانروايى از آنِ شماست [و] در اين سرزمين مسلطيد، و[لى‌] چه كسى ما را از بلاى خدا -اگر به ما برسد- حمايت خواهد كرد؟» فرعون گفت: «جز آنچه مى‌بينم، به شما نمى‌نمايم، و شما را جز به راه راست راهبر نيستم.»"
  40,30,"و كسى كه ايمان آورده بود، گفت: «اى قوم من، من از [روزى‌] مثل روز دسته‌ها[ى مخالف خدا] بر شما مى‌ترسم"
  40,31,"[از سرنوشتى‌] نظير سرنوشت قوم نوح و عاد و ثمود، و كسانى كه پس از آنها [آمدند]. و [گرنه‌] خدا بر بندگان [خود] ستم نمى‌خواهد"
  40,32,"و اى قوم من، من بر شما از روزى كه مردم يكديگر را [به يارى هم‌] ندا درمى‌دهند، بيم دارم"
  40,33,"روزى كه پشت‌كنان [به عنف‌] بازمى‌گرديد، براى شما در برابر خدا هيچ حمايتگرى نيست؛ و هر كه را خدا گمراه كند او را راهبرى نيست.»"
  40,34,"و به يقين، يوسف پيش از اين، دلايل آشكار براى شما آورد، و از آنچه براى شما آورد همواره در ترديد بوديد تا وقتى كه از دنيا رفت، گفتيد: «خدا بعد از او هرگز فرستاده‌اى را برنخواهد انگيخت.» اين گونه، خدا هر كه را افراطگر شكّاك است، بى راه مى‌گذارد"
  40,35,"كسانى كه در باره آيات خدا -بدون حجتى كه براى آنان آمده باشد- مجادله مى‌كنند، [اين ستيزه‌] در نزد خدا و نزد كسانى كه ايمان آورده‌اند [مايه‌] عداوت بزرگى است. اين گونه، خدا بر دل هر متكبر و زورگويى مُهر مى‌نهد"
  40,36,"و فرعون گفت: «اى هامان، براى من كوشكى بلند بساز، شايد من به آن راهها برسم"
  40,37,"راههاى [دستيابى به‌] آسمانها، تا از خداى موسى اطلاع حاصل كنم و من او را سخت دروغپرداز مى‌پندارم.» و اين گونه براى فرعون، زشتى كارش آراسته شد و از راه [راست‌] بازماند؛ و نيرنگ فرعون جز به تباهى نينجاميد"
  40,38,"و آن كس كه ايمان آورده بود گفت: «اى قوم من، مرا پيروى كنيد تا شما را به راه درست هدايت كنم"
  40,39,"اى قوم من، اين زندگى دنيا تنها كالايى [ناچيز] است، و در حقيقت، آن آخرت است كه سراى پايدار است"
  40,40,هر كه بدى كند، جز به مانند آن كيفر نمى‌يابد؛ و هر كه كار شايسته كند -چه مرد باشد يا زن- در حالى كه ايمان داشته باشد، در نتيجه آنان داخل بهشت مى‌شوند و در آنجا بى‌حساب روزى مى‌يابند
  40,41,"و اى قوم من، چه شده است كه من شما را به نجات فرا مى‌خوانم و [شما] مرا به آتش فرا مى‌خوانيد؟"
  40,42,مرا فرا مى‌خوانيد تا به خدا كافر شوم و چيزى را كه بدان علمى ندارم با او شريك گردانم؛ و من شما را به سوى آن ارجمند آمرزنده دعوت مى‌كنم
  40,43,"آنچه مرا به سوى آن دعوت مى‌كنيد، به ناچار نه در دنيا و نه در آخرت [درخور] خواندن نيست، و در حقيقت، برگشت ما به سوى خداست، و افراطگران همدمان آتشند"
  40,44,"پس به زودى آنچه را به شما مى‌گويم به ياد خواهيد آورد. و كارم را به خدا مى‌سپارم؛ خداست كه به [حال‌] بندگان [خود] بيناست.»"
  40,45,پس خدا او را از عواقب سوء آنچه نيرنگ مى‌كردند حمايت فرمود، و فرعونيان را عذاب سخت فرو گرفت
  40,46,"[اينك هر] صبح و شام بر آتش عرضه مى‌شوند، و روزى كه رستاخيز بر پا شود [فرياد مى‌رسد كه:] «فرعونيان را در سخت‌ترين [انواع‌] عذاب درآوريد.»"
  40,47,"و آنگاه كه در آتش شروع به آوردن حجّت مى‌كنند، زيردستان به كسانى كه گردنكش بودند، مى‌گويند: «ما پيرو شما بوديم؛ پس آيا مى‌توانيد پاره‌اى از اين آتش را از ما دفع كنيد؟»"
  40,48,"كسانى كه گردنكشى مى‌كردند، مى‌گويند: «[اكنون‌] همه ما در آن هستيم. خداست كه ميان بندگان [خود] داورى كرده است.»"
  40,49,"و كسانى كه در آتشند، به نگهبانان جهنّم مى‌گويند: «پروردگارتان را بخوانيد تا يك روز از اين عذاب را به ما تخفيف دهد.»"
  40,50,"مى‌گويند: «مگر پيامبرانتان دلايل روشن به سوى شما نياوردند؟» مى‌گويند: «چرا.» مى‌گويند: «پس بخوانيد. و[لى‌] دعاى كافران جز در بيراهه نيست.»"
  40,51,در حقيقت، ما فرستادگان خود و كسانى را كه گرويده‌اند، در زندگى دنيا و روزى كه گواهان برپاى مى‌ايستند قطعاً يارى مى‌كنيم؛
  40,52,"[همان‌] روزى كه ستمگران را پوزش‌طلبى‌شان سود نمى‌دهد، و براى آنان لعنت است، و برايشان بدفرجامى آن سراى است"
  40,53,و قطعاً موسى را هدايت داديم، و به فرزندان اسرائيل تورات را به ميراث نهاديم؛
  40,54,"[كه‌] رهنمود و يادكردى براى خردمندان است"
  40,55,پس صبر كن كه وعده خدا حق است و براى گناهت آمرزش بخواه و به سپاس پروردگارت، شامگاهان و بامدادان ستايشگر باش
  40,56,"در حقيقت، آنان كه در باره نشانه‌هاى خدا -بى‌آنكه حجّتى برايشان آمده باشد- به مجادله برمى‌خيزند در دلهايشان جز بزرگنمايى نيست [و] آنان به آن [بزرگى كه آرزويش را دارند] نخواهند رسيد. پس به خدا پناه جوى، زيرا او خود شنواى بيناست"
  40,57,"قطعاً آفرينش آسمانها و زمين بزرگتر [و شكوهمندتر] از آفرينش مردم است، ولى بيشتر مردم نمى‌دانند"
  40,58,"و نابينا و بينا يكسان نيستند، و كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند [نيز] با [مردم‌] بدكار [يكسان‌] نيستند؛ چه اندك پند مى‌پذيريد"
  40,59,در حقيقت، رستاخيز قطعاً آمدنى است؛ در آن ترديدى نيست، ولى بيشتر مردم ايمان نمى‌آورند
  40,60,"و پروردگارتان فرمود: «مرا بخوانيد تا شما را اجابت كنم. در حقيقت، كسانى كه از پرستش من كبر مى‌ورزند به زودى خوار در دوزخ درمى‌آيند.»"
  40,61,"خدا [همان‌] كسى است كه شب را براى شما پديد آورد تا در آن آرام گيريد، و روز را روشنى‌بخش [قرار داد]. آرى، خدا بر مردم بسيار صاحب‌تفضل است، ولى بيشتر مردم سپاس نمى‌دارند"
  40,62,"اين است خدا، پروردگار شما [كه‌] آفريننده هر چيزى است: خدايى جز او نيست. پس چگونه [از او] بازگردانيده مى‌شويد؟"
  40,63,"كسانى كه نشانه‌هاى خدا را انكار مى‌كردند، اين گونه [از خدا] رويگردان مى‌شوند"
  40,64,"خدا [همان‌] كسى است كه زمين را براى شما قرارگاه ساخت و آسمان را بنايى [گردانيد] و شما را صورتگرى كرد و صورتهاى شما را نيكو نمود و از چيزهاى پاكيزه به شما روزى داد. اين است خدا پروردگار شما! بلندمرتبه و بزرگ است خدا، پروردگار جهانيان"
  40,65,"اوست [همان‌] زنده‌اى كه خدايى جز او نيست. پس او را در حالى كه دين [خود] را براى وى بى‌آلايش گردانيده‌ايد بخوانيد. سپاس‌[ها همه‌] ويژه خدا پروردگار جهانيان است"
  40,66,"بگو: «من نهى شده‌ام از اينكه جز خدا كسانى را كه [شما] مى‌خوانيد پرستش كنم [آن هم‌] هنگامى كه از جانب پروردگارم مرا دلايل روشن رسيده باشد، و مأمورم كه فرمانبر پروردگار جهانيان باشم.»"
  40,67,"او همان كسى است كه شما را از خاكى آفريد، سپس از نطفه‌اى، آنگاه از علقه‌اى، و بعد شما را [به صورت‌] كودكى برمى‌آورد، تا به كمال قوّت خود برسيد و تا سالمند شويد، و از ميان شما كسى است كه مرگ پيش‌رس مى‌يابد، و تا [بالاخره‌] به مدتى كه مقرّر است برسيد، و اميد كه در انديشه فرو رويد"
  40,68,"او همان كسى است كه زنده مى‌كند و مى‌ميراند، و چون به كارى حكم كند، همين قدر به آن مى‌گويد: «باش.» بى‌درنگ موجود مى‌شود"
  40,69,"آيا كسانى را كه در [ابطال‌] آيات خدا مجادله مى‌كنند نديده‌اى [كه‌] تا كجا [از حقيقت‌] انحراف حاصل كرده‌اند؟"
  40,70,"كسانى كه كتاب [خدا] و آنچه را كه فرستادگان خود را بدان گسيل داشته‌ايم تكذيب كرده‌اند، به زودى خواهند دانست؛"
  40,71,"هنگامى كه غلها در گردنهايشان [افتاده‌] و [با] زنجيرها كشانيده مى‌شوند،"
  40,72,"در ميان جوشاب. [و] آنگاه در آتش برافروخته مى‌شوند"
  40,73,"آنگاه به آنان گفته مى‌شود: «آنچه را در برابر خدا [با او] شريك مى‌ساختيد كجايند؟»"
  40,74,"مى‌گويند: «گمشان كرديم، بلكه پيشتر [هم‌] ما چيزى را نمى‌خوانديم.» اين گونه خدا كافران را بى‌راه مى‌گذارد"
  40,75,"اين [عقوبت‌] به سبب آن است كه در زمين به ناروا شادى و سرمستى مى‌كرديد و بدان سبب است كه [سخت به خود] مى‌نازيديد"
  40,76,"از درهاى دوزخ درآييد، در آن جاودان [بمانيد]. چه بد است جاى سركشان"
  40,77,"پس صبر كن كه وعده خدا راست است. پس -چه پاره‌اى از آنچه را كه به آنان وعده داده‌ايم، به تو بنمايانيم، چه تو را از دنيا ببريم- [در هر صورت آنان‌] به سوى ما بازگردانيده مى‌شوند"
  40,78,"و مسلّماً پيش از تو فرستادگانى را روانه كرديم. برخى از آنان را [ماجرايشان را] بر تو حكايت كرده‌ايم و برخى از ايشان را بر تو حكايت نكرده‌ايم، و هيچ فرستاده‌اى را نرسد كه بى‌اجازه خدا نشانه‌اى بياورد. پس چون فرمان خدا برسد به حق داورى مى‌شود، و آنجاست كه باطل‌كاران زيان مى‌كنند"
  40,79,"خدا [همان‌] كسى است كه چهارپايان را براى شما پديد آورد تا از برخى از آنها سوارى گيريد و از برخى از آنها بخوريد"
  40,80,"و در آنها براى شما سودهاست تا با [سوار شدن بر] آنها به مقصودى كه در دلهايتان است برسيد، و بر آنها و بر كشتى حمل مى‌شويد"
  40,81,"و نشانه‌هاى [قدرت‌] خويش را به شما مى‌نماياند. پس كدام يك از آيات خدا را انكار مى‌كنيد؟"
  40,82,"آيا در زمين نگشته‌اند تا ببينند فرجام كسانى كه پيش از آنان بودند چگونه بوده است؟ [آنها به مراتب از حيث تعداد،] بيشتر از آنان، و [از حيث‌] نيرو و آثار در روى زمين، استوارتر بودند، و[لى‌] آنچه به دست مى‌آوردند، به حالشان سودى نبخشيد"
  40,83,"و چون پيامبرانشان دلايل آشكار برايشان آوردند، به آن چيز [مختصرى‌] از دانش كه نزدشان بود خرسند شدند، و [سرانجام‌] آنچه به ريشخند مى‌گرفتند آنان را فروگرفت"
  40,84,"پس چون سختى [عذاب‌] ما را ديدند گفتند: «فقط به خدا ايمان آورديم و بدانچه با او شريك مى‌گردانيديم كافريم.»"
  40,85,"و[لى‌] هنگامى كه عذاب ما را مشاهده كردند، ديگر ايمانشان براى آنها سودى نداد. سنّت خداست كه از [ديرباز] در باره بندگانش چنين جارى شده، و آنجاست كه ناباوران زيان كرده‌اند"
  41,1,حاء، ميم
  41,2,"وحى [نامه‌]اى است از جانب [خداى‌] رحمتگر مهربان"
  41,3,كتابى است كه آيات آن، به روشنى بيان شده. قرآنى است به زبان عربى براى مردمى كه مى‌دانند
  41,4,"بشارتگر و هشداردهنده است. و[لى‌] بيشتر آنان رويگردان شدند، در نتيجه [چيزى را] نمى‌شنوند"
  41,5,"و گفتند: «دلهاى ما از آنچه ما را به سوى آن مى‌خوانى سخت محجوب و مهجور است. و در گوشهاى ما سنگينى و ميان ما و تو پرده‌اى است؛ پس تو كار خود را بكن ما [هم‌] كار خود را مى‌كنيم.»"
  41,6,"بگو: «من، بشرى چون شمايم، جز اينكه به من وحى مى‌شود كه خداى شما خدايى يگانه است. پس مستقيماً به سوى او بشتابيد و از او آمرزش بخواهيد. و واى بر مشركان.»"
  41,7,همان كسانى كه زكات نمى‌دهند و آنان كه به آخرت ناباورند
  41,8,كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند آنان را پاداشى بى‌پايان است
  41,9,"بگو: «آيا اين شماييد كه واقعاً به آن كسى كه زمين را در دو هنگام آفريد، كفر مى‌ورزيد و براى او همتايانى قرار مى‌دهيد؟ اين است پروردگار جهانيان.»"
  41,10,"و در [زمين‌]، از فراز آن [لنگرآسا] كوهها نهاد و در آن خير فراوان پديد آورد، و مواد خوراكى آن را در چهار روز اندازه‌گيرى كرد [كه‌] براى خواهندگان، درست [و متناسب با نيازهايشان‌] است"
  41,11,"سپس آهنگ [آفرينش‌] آسمان كرد، و آن بخارى بود. پس به آن و به زمين فرمود: «خواه يا ناخواه بياييد.» آن دو گفتند: «فرمان‌پذير آمديم.»"
  41,12,"پس آنها را [به صورت‌] هفت آسمان، در دو هنگام مقرّر داشت و در هر آسمانى كار [مربوط به‌] آن را وحى فرمود، و آسمان [اين‌] دنيا را به چراغها آذين كرديم و [آن را نيك‌] نگاه داشتيم؛ اين است اندازه‌گيرى آن نيرومند دانا"
  41,13,"پس اگر روى برتافتند بگو: «شما را از آذرخشى چون آذرخش عاد و ثمود بر حذر داشتم.»"
  41,14,"چون فرستادگان [ما] از پيش رو و از پشت سرشان بر آنان آمدند [و گفتند:] «زنهار، جز خدا را مپرستيد»، گفتند: «اگر پروردگار ما مى‌خواست، قطعاً فرشتگانى فرومى‌فرستاد، پس ما به آنچه بدان فرستاده شده‌ايد كافريم.»"
  41,15,"و امّا عاديان، به ناحق، در زمين سر برافراشتند و گفتند: «از ما نيرومندتر كيست؟» آيا ندانسته‌اند كه آن خدايى كه خلقشان كرده خود از ايشان نيرومندتر است؟ و در نتيجه آيات ما را انكار مى‌كردند"
  41,16,پس بر آنان تندبادى توفنده در روزهايى شوم فرستاديم تا در زندگى دنيا عذاب رسوايى را بدانان بچشانيم و قطعاً عذاب آخرت رسواكننده‌تر است و آنان يارى نخواهند شد
  41,17,"و اما ثموديان: پس آنان را راهبرى كرديم و[لى‌] كوردلى را بر هدايت ترجيح دادند، پس به [كيفر] آنچه مرتكب مى‌شدند صاعقه عذاب خفت‌آور آنان را فروگرفت"
  41,18,و كسانى را كه ايمان آورده بودند و پروا مى‌داشتند رهانيديم
  41,19,"و [ياد كن‌] روزى را كه دشمنان خدا به سوى آتش گردآورده و بازداشت [و دسته دسته تقسيم‌] مى‌شوند"
  41,20,تا چون بدان رسند، گوششان و ديدگانشان و پوستشان به آنچه مى‌كرده‌اند، بر ضدّشان گواهى دهند
  41,21,"و به پوست [بدن‌] خود مى‌گويند: «چرا بر ضدّ ما شهادت داديد؟» مى‌گويند: «همان خدايى كه هر چيزى را به زبان درآورده ما را گويا گردانيده است، و او نخستين بار شما را آفريد و به سوى او برگردانيده مى‌شويد.»"
  41,22,"و [شما] از اينكه مبادا گوش و ديدگان و پوستتان بر ضدّ شما گواهى دهند [گناهانتان را] پوشيده نمى‌داشتيد ليكن گمان داشتيد كه خدا بسيارى از آنچه را كه مى‌كنيد نمى‌داند"
  41,23,و همين بود گمانتان كه در باره پروردگارتان برديد؛ شما را هلاك كرد و از زيانكاران شديد
  41,24,پس اگر شكيبايى نمايند جايشان در آتش است و اگر از در پوزش درآيند مورد اجابت قرار نمى‌گيرند
  41,25,"و براى آنان دمسازانى گذاشتيم، و آنچه در دسترس ايشان و آنچه در پى آنان بود در نظرشان زيبا جلوه دادند و فرمان [عذاب‌] در ميان امّتهايى از جن و انس كه پيش از آنان روزگار به سر برده بودند، بر ايشان واجب آمد، چرا كه آنها زيانكاران بودند"
  41,26,"و كسانى كه كافر شدند گفتند: «به اين قرآن گوش مدهيد و سخن لغو در آن اندازيد، شايد شما پيروز شويد.»"
  41,27,و قطعاً كسانى را كه كافر شده‌اند عذابى سخت مى‌چشانيم و حتماً آنها را به بدتر از آنچه مى‌كرده‌اند جزا مى‌دهيم
  41,28,"آرى، سزاى دشمنان خدا همان آتش است كه در آن، منزل هميشگى دارند. [اين‌] جزا به كيفر آن است كه نشانه‌هاى ما را انكار مى‌كردند"
  41,29,"و كسانى كه كفر ورزيدند گفتند: «پروردگارا، آن دو [گمراه‌گرى‌] از جن و انس كه ما را گمراه كردند به ما نشان ده تا آنها را زير قدمهايمان بگذاريم تا زبون شوند.»"
  41,30,"در حقيقت، كسانى كه گفتند: «پروردگار ما خداست»؛ سپس ايستادگى كردند، فرشتگان بر آنان فرود مى‌آيند [و مى‌گويند:] «هان، بيم مداريد و غمين مباشيد، و به بهشتى كه وعده يافته بوديد شاد باشيد"
  41,31,"در زندگى دنيا و در آخرت دوستانتان ماييم، و هر چه دلهايتان بخواهد در [بهشت‌] براى شماست، و هر چه خواستار باشيد در آنجا خواهيد داشت؛"
  41,32,روزىِ آماده‌اى از سوى آمرزنده مهربان است.»
  41,33,"و كيست خوشگفتارتر از آن كس كه به سوى خدا دعوت نمايد و كار نيك كند و گويد: «من [در برابر خدا] از تسليم‌شدگانم»؟"
  41,34,"و نيكى با بدى يكسان نيست. [بدى را] آنچه خود بهتر است دفع كن؛ آنگاه كسى كه ميان تو و ميان او دشمنى است، گويى دوستى يكدل مى‌گردد"
  41,35,"و اين [خصلت‌] را جز كسانى كه شكيبا بوده‌اند نمى‌يابند، و آن را جز صاحب بهره‌اى بزرگ، نخواهد يافت"
  41,36,و اگر دمدمه‌اى از شيطان تو را از جاى درآورد، پس به خدا پناه ببر كه او خود شنواى داناست
  41,37,"و از نشانه‌هاى [حضور] او شب و روز و خورشيد و ماه است؛ نه براى خورشيد سجده كنيد و نه براى ماه، و اگر تنها او را مى‌پرستيد آن خدايى را سجده كنيد كه آنها را خلق كرده است"
  41,38,پس اگر كبر ورزيدند، كسانى كه در پيشگاه پروردگار تواند شبانه‌روز او را نيايش مى‌كنند و خسته نمى‌شوند
  41,39,"و از [ديگر] نشانه‌هاى او اين است كه تو زمين را فسرده مى‌بينى و چون باران بر آن فروريزيم به جنبش درآيد و بردمد. آرى، همان كسى كه آن را زندگى بخشيد قطعاً زنده‌كننده مردگان است. در حقيقت، او بر هر چيزى تواناست"
  41,40,"كسانى كه در [فهم و ارائه‌] آيات ما كژ مى‌روند بر ما پوشيده نيستند. آيا كسى كه در آتش افكنده مى‌شود بهتر است يا كسى كه روز قيامت آسوده‌خاطر مى‌آيد؟ هر چه مى‌خواهيد بكنيد كه او به آنچه انجام مى‌دهيد بيناست"
  41,41,"كسانى كه به اين قرآن -چون بديشان رسيد- كفر ورزيدند [به كيفر خود مى‌رسند] و به راستى كه آن كتابى ارجمند است"
  41,42,"از پيش روى آن و از پشت سرش باطل به سويش نمى‌آيد؛ وحى [نامه‌]اى است از حكيمى ستوده‌[صفات‌]"
  41,43,به تو جز آنچه به پيامبران پيش از تو گفته شده است گفته نمى‌شود. به راستى كه پروردگار تو داراى آمرزش و دارنده كيفرى پر درد است
  41,44,"و اگر [اين كتاب را] قرآنى غير عربى گردانيده بوديم، قطعاً مى‌گفتند: «چرا آيه‌هاى آن روشن بيان نشده؟ كتابى غير عربى و [مخاطب آن‌] عرب زبان؟» بگو: «اين [كتاب‌] براى كسانى كه ايمان آورده‌اند رهنمود و درمانى است، و كسانى كه ايمان نمى‌آورند در گوشهايشان سنگينى است و قرآن برايشان نامفهوم است، و [گويى‌] آنان را از جايى دور ندا مى‌دهند"
  41,45,"و به راستى موسى را كتاب [تورات‌] داديم، پس در آن اختلاف واقع شد، و اگر از جانب پروردگارت فرمان [مهلت‌] سبقت نگرفته بود، قطعاً ميانشان داورى شده بود؛ و در حقيقت آنان در باره آن به شكّى سخت دچارند"
  41,46,"هر كه كار شايسته كند، به سود خود اوست؛ و هر كه بدى كند، به زيان خود اوست، و پروردگار تو به بندگان [خود] ستمكار نيست"
  41,47,"دانستن هنگام رستاخيز فقط منحصر به اوست، و ميوه‌ها از غلافهايشان بيرون نمى‌آيند و هيچ مادينه‌اى بار نمى‌گيرد و بار نمى‌گذارد مگر آنكه او به آن علم دارد. و روزى كه [خدا] آنان را ندا مى‌دهد: «شريكان من كجايند؟» مى‌گويند: «با بانگ رسا به تو مى‌گوييم كه هيچ گواهى از ميان ما نيست.»"
  41,48,"و آنچه از پيش مى‌خواندند، از [نظر] آنان ناپديد مى‌شود و مى‌دانند كه آنان را روى گريز نيست"
  41,49,"انسان از دعاى خير خسته نمى‌شود، و چون آسيبى به او رسد مأيوس [و] نوميد مى‌گردد"
  41,50,"و اگر از جانب خود رحمتى -پس از زيانى كه به او رسيده است- بچشانيم، قطعاً خواهد گفت: «من سزاوار آنم و گمان ندارم كه رستاخيز برپا شود، و اگر هم به سوى پروردگارم بازگردانيده شوم، قطعاً نزد او برايم خوبى خواهد بود. « پس بدون شكّ، كسانى را كه كفران كرده‌اند، به آنچه انجام داده‌اند آگاه خواهيم كرد، و مسلماً از عذابى سخت به آنان خواهيم چشانيد"
  41,51,و چون انسان را نعمت بخشيم، روى برتابد و خود را كنار كشد، و چون آسيبى بدو رسد دست به دعاى فراوان بردارد
  41,52,"بگو: «به من خبر دهيد، اگر [قرآن‌] از نزد خدا [آمده‌] باشد و آن را انكار كرده باشيد، چه كسى گمراه‌تر از آن كس خواهد بود كه به مخالفتى دور و دراز [دچار] آمده باشد؟»"
  41,53,"به زودى نشانه‌هاى خود را در افقها[ى گوناگون‌] و در دلهايشان بديشان خواهيم نمود، تا برايشان روشن گردد كه او خود حق است. آيا كافى نيست كه پروردگارت خود شاهد هر چيزى است؟"
  41,54,آرى، آنان در لقاى پروردگارشان ترديد دارند. آگاه باش كه مسلماً او به هر چيزى احاطه دارد
  42,1,حاء، ميم،
  42,2,عين، سين، قاف
  42,3,اين گونه، خداى نيرومند حكيم به سوى تو و به سوى كسانى كه پيش از تو بودند، وحى مى‌كند
  42,4,آنچه در آسمانها و آنچه در زمين است از آنِ اوست و او بلندمرتبه بزرگ است
  42,5,"چيزى نمانده كه آسمانها از فرازشان بشكافند و [حال آنكه‌] فرشتگان به سپاس پروردگارشان تسبيح مى‌گويند و براى كسانى كه در زمين هستند آمرزش مى‌طلبند. آگاه باش، در حقيقت خداست كه آمرزنده مهربان است"
  42,6,و كسانى كه به جاى او دوستانى براى خود گرفته‌اند، خدا بر ايشان نگهبان است و تو بر آنان گمارده نيستى
  42,7,"و بدين گونه قرآن عربى به سوى تو وحى كرديم تا [مردم‌] مكّه و كسانى را كه پيرامون آنند هشدار دهى، و از روز گردآمدن [خلق‌] -كه ترديدى در آن نيست- بيم دهى؛ گروهى در بهشتند و گروهى در آتش"
  42,8,و اگر خدا مى‌خواست، قطعاً آنان را امتى يگانه مى‌گردانيد، ليكن هر كه را بخواهد، به رحمت خويش درمى‌آورد و ستمگران نه يارى دارند و نه ياورى
  42,9,آيا به جاى او دوستانى براى خود گرفته‌اند؟ خداست كه دوست راستين است، و اوست كه مردگان را زنده مى‌كند، و هموست كه بر هر چيزى تواناست
  42,10,"و در باره هر چيزى اختلاف پيدا كرديد، داوريش به خدا [ارجاع مى‌گردد]. چنين خدايى پروردگار من است. بر او توكل كردم و به سوى او بازمى‌گردم"
  42,11,"پديدآورنده آسمانها و زمين است. از خودتان براى شما جفتهايى قرار داد، و از دامها [نيز] نر و ماده [قرار داد]. بدين وسيله شما را بسيار مى‌گرداند. چيزى مانند او نيست و اوست شنواى بينا"
  42,12,كليدهاى آسمانها و زمين از آنِ اوست. براى هر كس كه بخواهد روزى را گشاده يا تنگ مى‌گرداند. اوست كه بر هر چيزى داناست
  42,13,"از [احكام‌] دين، آنچه را كه به نوح در باره آن سفارش كرد، براى شما تشريع كرد و آنچه را به تو وحى كرديم و آنچه را كه در باره آن به ابراهيم و موسى و عيسى سفارش نموديم كه: «دين را برپا داريد و در آن تفرقه‌اندازى مكنيد.» بر مشركان آنچه كه ايشان را به سوى آن فرا مى‌خوانى، گران مى‌آيد. خدا هر كه را بخواهد، به سوى خود برمى‌گزيند، و هر كه را كه از در توبه درآيد، به سوى خود راه مى‌نمايد"
  42,14,"و فقط پس از آنكه علم برايشان آمد، راه تفرقه پيمودند [آن هم‌] به صرف حسد [و برترى جويى‌] ميان همديگر. و اگر سخنى [داير بر تأخير عذاب‌] از جانب پروردگارت تا زمانى معيّن، پيشى نگرفته بود، قطعاً ميانشان داورى شده بود. و كسانى كه بعد از آنان كتاب [تورات‌] را ميراث يافتند واقعاً در باره او در ترديدى سخت [دچار]اند"
  42,15,"بنابراين به دعوت پرداز، و همان گونه كه مأمورى ايستادگى كن، و هوسهاى آنان را پيروى مكن و بگو: «به هر كتابى كه خدا نازل كرده است ايمان آوردم و مأمور شدم كه ميان شما عدالت كنم؛ خدا پروردگار ما و پروردگار شماست؛ اعمال ما از آنِ ما و اعمال شما از آنِ شماست؛ ميان ما و شما خصومتى نيست؛ خدا ميان ما را جمع مى‌كند، و فرجام به سوى اوست"
  42,16,"و كسانى كه در باره خدا پس از اجابت [دعوت‌] او به مجادله مى‌پردازند، حجّتشان پيش پروردگارشان باطل است، و خشمى [از خدا] برايشان است و براى آنان عذابى سخت خواهد بود"
  42,17,خدا همان كسى است كه كتاب و وسيله سنجش را به حق فرود آورد، و تو چه مى‌دانى شايد رستاخيز نزديك باشد
  42,18,كسانى كه به آن ايمان ندارند شتابزده آن را مى‌خواهند، و كسانى كه ايمان آورده‌اند، از آن هراسناكند و مى‌دانند كه آن حقّ است. بدان كه آنان كه در مورد قيامت ترديد مى‌ورزند، قطعاً در گمراهى دور و درازى‌اند
  42,19,"خدا نسبت به بندگانش مهربان است: هر كه را بخواهد روزى مى‌دهد و اوست نيرومند غالب"
  42,20,"كسى كه كِشت آخرت بخواهد، براى وى در كِشته‌اش مى‌افزاييم، و كسى كه كِشت اين دنيا را بخواهد به او از آن مى‌دهيم و[لى‌] در آخرت او را نصيبى نيست"
  42,21,"آيا براى آنان شريكانى است كه در آنچه خدا بدان اجازه نداده، برايشان بنياد آيينى نهاده‌اند؟ و اگر فرمان قاطع [در باره تأخير عذاب در كار] نبود مسلماً ميانشان داورى مى‌شد؛ و براى ستمكاران شكنجه‌اى پر درد است"
  42,22,"[در قيامت‌] ستمگران را از آنچه انجام داده‌اند، هراسناك مى‌بينى و [جزاى عملشان‌] به آنان خواهد رسيد، و كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند در باغهاى بهشتند. آنچه را بخواهند نزد پروردگارشان خواهند داشت؛ اين است همان فضل عظيم"
  42,23,"اين همان [پاداشى‌] است كه خدا بندگان خود را كه ايمان آورده و كارهاى شايسته كرده‌اند [بدان‌] مژده داده است. بگو: «به ازاى آن [رسالت‌] پاداشى از شما خواستار نيستم، مگر دوستى در باره خويشاوندان.» و هر كس نيكى به جاى آورد [و طاعتى اندوزد]، براى او در ثواب آن خواهيم افزود. قطعاً خدا آمرزنده و قدرشناس است"
  42,24,"آيا مى‌گويند: «بر خدا دروغى بسته است؟» پس اگر خدا بخواهد بر دلت مُهر مى نهد؛ و خدا باطل را محو و حقيقت را با كلمات خويش پا برجا مى‌كند. اوست كه به راز دلها داناست"
  42,25,و اوست كسى كه توبه را از بندگان خود مى‌پذيرد و از گناهان درمى‌گذرد و آنچه مى‌كنيد مى‌داند
  42,26,"و [درخواست‌] كسانى را كه ايمان آورده و كارهاى شايسته انجام داده‌اند اجابت مى‌كند و از فضل خويش به آنان زياده مى‌دهد، و[لى‌] براى كافران عذاب سختى خواهد بود"
  42,27,"و اگر خدا روزى را بر بندگانش فراخ گرداند، مسلماً در زمين سر به عصيان برمى‌دارند، ليكن آنچه را بخواهد به اندازه‌اى [كه مصلحت است‌] فرو مى‌فرستد. به راستى كه او به [حال‌] بندگانش آگاهِ بيناست"
  42,28,"و اوست كسى كه باران را -پس از آنكه [مردم‌] نوميد شدند- فرود مى‌آورد، و رحمت خويش را مى‌گسترد و هموست سرپرست ستوده"
  42,29,"و از نشانه‌هاى [قدرت‌] اوست آفرينش آسمانها و زمين و آنچه از [انواع‌] جنبنده در ميان آن دو پراكنده است، و او هرگاه بخواهد بر گردآوردن آنان تواناست"
  42,30,"و هر [گونه‌] مصيبتى به شما برسد به سبب دستاورد خود شماست، و [خدا] از بسيارى درمى‌گذرد"
  42,31,"و شما در زمين درمانده كننده [خدا] نيستيد، و جز خدا شما را سرپرست و ياورى نيست"
  42,32,و از نشانه‌هاى او سفينه‌هاى كوه‌آسا در درياست
  42,33,"اگر بخواهد باد را ساكن مى‌گرداند و [سفينه‌ها] بر پشت [آب‌] متوقف مى‌مانند. قطعاً در اين [امر] براى هر شكيباى شكرگزارى نشانه‌هاست"
  42,34,"يا به [سزاى‌] آنچه [كشتى‌نشينان‌] مرتكب شده‌اند هلاكشان كند، و[لى‌] از بسيارى درمى‌گذرد"
  42,35,"و [تا] آنان كه در آيات ما مجادله مى‌كنند، بدانند كه ايشان را [روى‌] گريزى نيست"
  42,36,"و آنچه به شما داده شده، برخوردارى [و كالاى‌] زندگى دنياست، و آنچه پيش خداست براى كسانى كه گرويده‌اند و به پروردگارشان اعتماد دارند بهتر و پايدارتر است"
  42,37,و كسانى كه از گناهان بزرگ و زشتكاريها خود را به دور مى‌دارند و چون به خشم درمى‌آيند درمى‌گذرند
  42,38,"و كسانى كه [نداى‌] پروردگارشان را پاسخ [مثبت‌] داده و نماز برپا كرده‌اند و كارشان در ميانشان مشورت است و از آنچه روزيشان داده‌ايم انفاق مى‌كنند"
  42,39,"و كسانى كه چون ستم بر ايشان رسد، يارى مى‌جويند [و به انتقام بر مى‌خيزند]"
  42,40,"و جزاى بدى، مانند آن، بدى است. پس هر كه درگذرد و نيكوكارى كند، پاداش او بر [عهده‌] خداست. به راستى او ستمگران را دوست نمى‌دارد"
  42,41,"و هر كه پس از ستم [ديدن‌] خود، يارى جويد [و انتقام گيرد] راه [نكوهشى‌] بر ايشان نيست"
  42,42,"راه [نكوهش‌] تنها بر كسانى است كه به مردم ستم مى‌كنند، و در [روى‌] زمين به ناحق سر برمى‌دارند. آنان عذابى دردناك [در پيش‌] خواهند داشت"
  42,43,"و هر كه صبر كند و درگذرد، مسلماً اين [خويشتن دارى، حاكى‌] از اراده قوى [در] كارهاست"
  42,44,"و هر كه را خدا بى‌راه گذارد، پس از او يار [و ياور]ى نخواهد داشت، و ستمگران را مى‌بينى كه چون عذاب را بنگرند مى‌گويند: «آيا راهى براى برگشتن [به دنيا] هست؟»"
  42,45,"آنان را مى‌بينى [كه چون‌] بر [آتش‌] عرضه مى‌شوند، از [شدت‌] زبونى، فروتن شده‌اند: زيرچشمى مى‌نگرند. و كسانى كه گرويده‌اند مى‌گويند: «در حقيقت، زيانكاران كسانى‌اند كه روز قيامت خودشان و كسانشان را دچار زيان كرده‌اند.» آرى، ستمكاران در عذابى پايدارند"
  42,46,"و جز خدا براى آنان دوستانى [ديگر] نيست كه آنها را يارى كنند، و هر كه را خدا بى‌راه كذارد هيچ راهى براى او نخواهد بود"
  42,47,"پيش از آنكه روزى فرا رسد كه آن را از جانب خدا برگشتى نباشد، پروردگارتان را اجابت كنيد. آن روز نه براى شما پناهى و نه برايتان [مجال‌] انكارى هست"
  42,48,"پس اگر روى برتابند، ما تو را بر آنان نگهبان نفرستاده‌ايم. بر عهده تو جز رسانيدن [پيام‌] نيست، و ما چون رحمتى از جانب خود به انسان بچشانيم، بدان شاد و سرمست گردد، و چون به [سزاى‌] دستاورد پيشين آنها، به آنان بدى رسد، انسان ناسپاسى مى‌كند"
  42,49,"فرمانروايى [مطلق‌] آسمانها و زمين از آنِ خداست؛ هر چه بخواهد مى‌آفريند؛ به هر كس بخواهد فرزند دختر و به هركس بخواهد فرزند پسر مى‌دهد"
  42,50,"يا آنها را پسر[ان‌] و دختر[انى‌] توأم با يكديگر مى‌گرداند، و هر كه را بخواهد عقيم مى‌سازد. اوست داناى توانا"
  42,51,"و هيچ بشرى را نرسد كه خدا با او سخن گويد جز [از راه‌] وحى يا از فراسوى حجابى، يا فرستاده‌اى بفرستد و به اذن او هر چه بخواهد وحى نمايد. آرى، اوست بلندمرتبه سنجيده‌كار"
  42,52,"وهمين گونه، روحى از امر خودمان به سوى تو وحى كرديم. تو نمى‌دانستى كتاب چيست و نه ايمان [كدام است؟] ولى آن را نورى گردانيديم كه هر كه از بندگان خود را بخواهيم به وسيله آن راه مى‌نماييم، و به راستى كه تو به خوبى به راه راست هدايت مى‌كنى"
  42,53,"راه همان خدايى كه آنچه در آسمانها و آنچه در زمين است از آنِ اوست. هش‌دار كه [همه‌] كارها به خدا بازمى‌گردد"
  43,1,حاء، ميم
  43,2,سوگند به كتاب روشنگر
  43,3,ما آن را قرآنى عربى قرار داديم، باشد كه بينديشيد
  43,4,"و همانا كه آن در كتاب اصلى [=لوح محفوظ] به نزد ما سخت والا و پر حكمت است"
  43,5,"آيا به [صِرف‌] اينكه شما قومى منحرفيد [بايد] قرآن را از شما باز داريم؟"
  43,6,"و چه بسا پيامبرانى كه در [ميان‌] گذشتگان روانه كرديم"
  43,7,و هيچ پيامبرى به سوى ايشان نيامد، مگر اينكه او را به ريشخند مى‌گرفتند
  43,8,و نيرومندتر از آنان را به هلاكت رسانيديم و سنّت پيشينيان تكرار شد
  43,9,"و اگر از آنان بپرسى: «آسمانها و زمين را چه كسى آفريده؟» قطعاً خواهند گفت: «آنها را همان قادر دانا آفريده است.»"
  43,10,همان كسى كه اين زمين را براى شما گهواره‌اى گردانيد و براى شما در آن راهها نهاد، باشد كه راه يابيد
  43,11,"و آن كس كه آبى به اندازه از آسمان فرود آورد، پس به وسيله آن، سرزمينى مرده را زنده گردانيديم؛ همين گونه [از گورها] بيرون آورده مى‌شويد"
  43,12,"و همان كسى كه جفتها را يكسره آفريد، و براى شما از كشتيها و دامها [وسيله‌اى كه‌] سوار شويد قرار داد"
  43,13,"تا بر پشت آن‌[ها] قرار گيريد، پس چون بر آن‌[ها] برنشستيد، نعمت پروردگار خود را ياد كنيد و بگوييد: «پاك است كسى كه اين را براى ما رام كرد و[گرنه‌] ما را ياراى [رام‌ساختن‌] آنها نبود.»"
  43,14,«و به راستى كه ما به سوى پروردگارمان بازخواهيم گشت.»
  43,15,"و براى او بعضى از بندگان [خدا] را جزئى [چون فرزند و شريك‌] قرار دادند. به راستى كه انسان بس ناسپاس آشكار است"
  43,16,آيا از آنچه مى‌آفريند، خود، دخترانى برگرفته و به شما پسران را اختصاص داده است؟
  43,17,"و چون يكى از آنان را به آنچه به [خداى‌] رحمان نسبت مى‌دهد خبر دهند، چهره او سياه مى‌گردد، در حالى كه خشم و تأسف خود را فرو مى‌خورد"
  43,18,"آيا كسى [را شريك خدا مى‌كنند] كه در زر و زيور پرورش يافته و در [هنگام‌] مجادله، بيانش غير روشن است؟"
  43,19,"و فرشتگانى را كه خود، بندگان رحمانند، مادينه [و دختران او] پنداشتند. آيا در خلقت آنان حضور داشتند؟ گواهى ايشان به زودى نوشته مى‌شود و [از آن‌] پرسيده خواهند شد"
  43,20,"و مى‌گويند: «اگر [خداى‌] رحمان مى‌خواست، آنها را نمى‌پرستيديم.» آنان به اين [دعوى‌] دانشى ندارند [و] جز حدس نمى‌زنند"
  43,21,"آيا به آنان پيش از آن [قرآن‌] كتابى داده‌ايم كه بدان تمسك مى‌جويند؟"
  43,22,"[نه،] بلكه گفتند: «ما پدران خود را بر آيينى يافتيم و ما [هم با] پى گيرى از آنان، راه يافتگانيم.»"
  43,23,"و بدين گونه در هيچ شهرى پيش از تو هشداردهنده‌اى نفرستاديم مگر آنكه خوشگذرانان آن گفتند: «ما پدران خود را بر آيينى [و راهى‌] يافته‌ايم و ما از پى ايشان راهسپريم.»"
  43,24,"گفت «هر چند هدايت كننده‌تر از آنچه پدران خود را بر آن يافته‌ايد براى شما بياورم؟» گفتند: «ما [نسبت‌] به آنچه بدان فرستاده شده‌ايد كافريم.»"
  43,25,پس، از آنان انتقام گرفتيم. پس بنگر فرجام تكذيب‌كنندگان چگونه بوده است
  43,26,"و چون ابراهيم به [نا]پدرى خود و قومش گفت: «من واقعاً از آنچه مى‌پرستيد بيزارم،"
  43,27,"مگر [از] آن كس كه مرا پديد آورد؛ و البته او مرا راهنمايى خواهد كرد.»"
  43,28,"و او آن را در پى خود سخنى جاويدان كرد، باشد كه آنان [به توحيد] بازگردند"
  43,29,بلكه اينان و پدرانشان را برخودارى دادم تا حقيقت و فرستاده‌اى آشكار به سويشان آمد
  43,30,"و چون حقيقت به سويشان آمد، گفتند: «اين افسونى است و ما منكر آنيم.»"
  43,31,"و گفتند: «چرا اين قرآن بر مردى بزرگ از [آن‌] دو شهر فرود نيامده است؟»"
  43,32,"آيا آنانند كه رحمت پروردگارت را تقسيم مى‌كنند؟ ما [وسايل‌] معاش آنان را در زندگى دنيا ميانشان تقسيم كرده‌ايم، و برخى از آنان را از [نظر] درجات، بالاتر از بعضى [ديگر] قرار داده‌ايم تا بعضى از آنها بعضى [ديگر] را در خدمت گيرند، و رحمت پروردگار تو از آنچه آنان مى‌اندوزند بهتر است"
  43,33,"و اگر نه آن بود كه [همه‌] مردم [در انكار خدا] امتى واحد گردند، قطعاً براى خانه‌هاى آنان كه به [خداى‌] رحمان كفر مى‌ورزيدند، سقفها و نردبانهايى از نقره كه بر آنها بالا روند قرار مى‌داديم"
  43,34,و براى خانه‌هايشان نيز درها و تختهايى كه بر آنها تكيه زنند
  43,35,"و زر و زيورهاى [ديگر نيز]. و همه اينها جز متاع زندگى دنيا نيست، و آخرت پيش پروردگار تو براى پرهيزگاران است"
  43,36,"و هر كس از ياد [خداى‌] رحمان دل بگرداند، بر او شيطانى مى‌گماريم تا براى وى دمسازى باشد"
  43,37,"و مسلماً آنها ايشان را از راه باز مى‌دارند و [آنها] مى‌پندارند كه راه يافتگانند"
  43,38,"تا آنگاه كه او [با دمسازش‌] به حضور ما آيد، [خطاب به شيطان‌] گويد: «اى كاش ميان من و تو، فاصله خاور و باختر بود، كه چه بد دمسازى هستى!»"
  43,39,"و امروز هرگز [پشيمانى‌] براى شما سود نمى‌بخشد، چون ستم كرديد؛ در حقيقت، شما در عذاب، مشترك خواهيد بود"
  43,40,پس آيا تو مى‌توانى كران را شنوا كنى، يا نابينايان و كسى را كه همواره در گمراهى آشكارى است راه نمايى؟
  43,41,"پس اگر ما تو را [از دنيا] ببريم، قطعاً از آنان انتقام مى‌كشيم،"
  43,42,"يا [اگر] آنچه را به آنان وعده داده‌ايم به تو نشان دهيم؛ حتماً ما بر آنان قدرت داريم"
  43,43,پس به آنچه به سوى تو وحى شده است چنگ دَرْزَنْ، كه تو بر راهى راست قرار دارى
  43,44,"و به راستى كه [قرآن‌] براى تو و براى قوم تو [مايه‌] تذكّرى است، و به زودى [در مورد آن‌] پرسيده خواهيد شد"
  43,45,"و از رسولان ما كه پيش از تو گسيل داشتيم جويا شو؛ آيا در برابر [خداى‌] رحمان، خدايانى كه مورد پرستش قرار گيرند مقرر داشته‌ايم؟"
  43,46,"و همانا موسى را با نشانه‌هاى خويش به سوى فرعون و سران [قوم‌] او روانه كرديم. پس گفت: «من فرستاده پروردگار جهانيانم.»"
  43,47,پس چون آيات ما را براى آنان آورد، ناگهان ايشان بر آنها خنده زدند
  43,48,"و [ما] نشانه‌اى به ايشان نمى‌نموديم مگر اينكه آن از نظير [و مشابه‌] آن بزرگتر بود، و به عذاب گرفتارشان كرديم تا مگر به راه آيند"
  43,49,"و گفتند: «اى فسونگر، پروردگارت را به [پاس‌] آنچه با تو عهد كرده، براى ما بخوان، كه ما واقعاً به راه درست درآمده‌ايم.»"
  43,50,و چون عذاب را از آنها برداشتيم، بناگاه آنان پيمان شكستند
  43,51,"و فرعون در [ميان‌] قوم خود ندا درداد [و] گفت: «اى مردم [كشور] من، آيا پادشاهى مصر و اين نهرها كه از زير [كاخهاى‌] من روان است از آنِ من نيست؟ پس مگر نمى‌بينيد؟"
  43,52,"آيا [نه‌] من از اين كس كه خود بى‌مقدار است و نمى‌تواند درست بيان كند بهترم؟"
  43,53,پس چرا بر او دستبندهايى زرين آويخته نشده؟ يا با او فرشتگانى همراه نيامده‌اند؟
  43,54,"پس قوم خود را سبك‌مغز يافت [و آنان را فريفت‌] و اطاعتش كردند، چرا كه آنها مردمى منحرف بودند"
  43,55,و چون ما را به خشم درآوردند، از آنان انتقام گرفتيم و همه آنان را غرق كرديم
  43,56,"و آنان را پيشينه‌اى [بد] و عبرتى براى آيندگان گردانيديم"
  43,57,"و هنگامى كه [در مورد] پسر مريم مثالى آورده شد، بناگاه قوم تو از آن [سخن‌] هِلهِله درانداختند [و اعراض كردند]،"
  43,58,"و گفتند: «آيا معبودان ما بهترند يا او؟» آن [مثال‌] را جز از راه جدل براى تو نزدند، بلكه آنان مردمى جدل‌پيشه‌اند"
  43,59,"[عيسى‌] جز بنده‌اى كه بر وى منت نهاده و او را براى فرزندان اسرائيل سرمشق [و آيتى‌] گردانيده‌ايم نيست"
  43,60,"و اگر بخواهيم قطعاً به جاى شما فرشتگانى كه در [روى‌] زمين جانشين [شما] گردند قرار دهيم"
  43,61,"و همانا آن، نشانه‌اى براى [فهم‌] رستاخيز است، پس زنهار در آن ترديد مكن، و از من پيروى كنيد؛ اين است راه راست"
  43,62,و مبادا شيطان شما را از راه به در برد، زيرا او براى شما دشمنى آشكار است
  43,63,"و چون عيسى دلايل آشكار آورد، گفت: «به راستى براى شما حكمت آوردم، و تا در باره بعضى از آنچه در آن اختلاف مى‌كرديد برايتان توضيح دهم. پس، از خدا بترسيد و فرمانم ببريد.»"
  43,64,در حقيقت، خداست كه خود پروردگار من و پروردگار شماست. پس او را بپرستيد؛ اين است راه راست
  43,65,"تا [آنكه‌] از ميانشان، احزاب دست به اختلاف زدند، پس واى بر كسانى كه ستم كردند از عذاب روزى دردناك"
  43,66,"آيا جز [اين‌] انتظار مى‌برند كه رستاخيز -در حالى كه حدس نمى‌زنند- ناگهان بر آنان در رسد؟"
  43,67,در آن روز، ياران -جز پرهيزگاران- بعضى‌شان دشمن بعضى ديگرند
  43,68,اى بندگان من، امروز بر شما بيمى نيست و غمگين نخواهيد شد
  43,69,همان كسانى كه به آيات ما ايمان آورده و تسليم بودند
  43,70,شما با همسرانتان شادمانه داخل بهشت شويد
  43,71,"سينيهايى از طلا و جام‌هايى در برابر آنان مى‌گردانند، و در آنجا آنچه دلها آن را بخواهند و ديدگان را خوش آيد [هست‌] و شما در آن جاودانيد"
  43,72,"و اين است همان بهشتى كه به [پاداش‌] آنچه مى‌كرديد ميراث يافتيد"
  43,73,در آنجا براى شما ميوه‌هايى فراوان خواهد بود كه از آنها مى‌خوريد
  43,74,بى‌گمان، مجرمان در عذاب جهنم ماندگارند
  43,75,"[عذاب‌] از آنان تخفيف نمى‌يابد و آنها در آنجا نوميدند"
  43,76,و ما بر ايشان ستم نكرديم، بلكه خود ستمكار بودند
  43,77,"و فرياد كشند: «اى مالك، [بگو:] پروردگارت جان ما را بستاند.» پاسخ دهد: « شما ماندگاريد.»"
  43,78,قطعاً حقيقت را برايتان آورديم، ليكن بيشتر شما حقيقت را خوش نداشتيد
  43,79,"يا در كارى ابرام ورزيده‌اند؟ ما [نيز] ابرام مى‌ورزيم"
  43,80,"آيا مى‌پندارند كه ما راز آنها و نجوايشان را نمى‌شنويم؟ چرا، و فرشتگان ما پيش آنان [حاضرند و] ثبت مى‌كنند"
  43,81,"بگو: «اگر براى [خداى‌] رحمان فرزندى بود، خود من نخستين پرستندگان بودم.»"
  43,82,"پروردگار آسمانها و زمين [و] پروردگار عرش، از آنچه وصف مى‌كنند منزه است"
  43,83,پس آنان را رها كن تا در ياوه‌گويى خود فرو روند و بازى كنند تا آن روزى را كه بدان وعده داده مى‌شوند ديدار كنند
  43,84,و اوست كه در آسمان خداست و در زمين خداست، و هموست سنجيده‌كار دانا
  43,85,و خجسته است كسى كه فرمانروايى آسمانها و زمين و آنچه ميان آن دو است از آنِ اوست، و علم قيامت پيش اوست و به سوى او برگردانيده مى‌شويد
  43,86,"و كسانى كه به جاى او مى‌خوانند [و مى‌پرستند] اختيار شفاعت ندارند، مگر آن كسانى كه آگاهانه به حق گواهى داده باشند"
  43,87,"و اگر از آنان بپرسى: «چه كسى آنان را خلق كرده؟» مسلماً خواهند گفت: «خدا.» پس چگونه [از حقيقت‌] بازگردانيده مى‌شوند؟"
  43,88,"و گويد: «اى پروردگار من، اينها جماعتى‌اند كه ايمان نخواهند آورد.»"
  43,89,"[و خدا فرمود:] از ايشان روى برتاب و بگو: «به سلامت.» پس زودا كه بدانند"
  44,1,حاء، ميم
  44,2,سوگند به كتاب روشنگر،
  44,3,"[كه‌] ما آن را در شبى فرخنده نازل كرديم، [زيرا] كه ما هشداردهنده بوديم"
  44,4,"در آن [شب‌] هر [گونه‌] كارى [به نحوى‌] استوار فيصله مى‌يابد"
  44,5,"[اين‌] كارى است [كه‌] از جانب ما [صورت مى‌گيرد]. ما فرستنده [پيامبران‌] بوديم"
  44,6,"[و اين‌] رحمتى از پروردگار توست، كه او شنواى داناست"
  44,7,پروردگار آسمانها و زمين و آنچه ميان آن دو است، اگر يقين داريد
  44,8,خدايى جز او نيست؛ او زندگى مى‌بخشد و مى‌ميراند؛ پروردگار شما و پروردگار پدران شماست
  44,9,ولى نه، آنها به شك و شبهه خويش سرگرمند
  44,10,پس در انتظار روزى باش كه آسمان دودى نمايان برمى‌آورد،
  44,11,كه مردم را فرو مى‌گيرد؛ اين است عذاب پر درد
  44,12,"[مى‌گويند:] «پروردگارا، اين عذاب را از ما دفع كن كه ما ايمان داريم.»"
  44,13,"آنان را كجا [جاى‌] پند[گرفتن‌] باشد، و حال آنكه به يقين براى آنان پيامبرى روشنگر آمده است"
  44,14,"پس، از او روى برتافتند و گفتند: «تعليم‌يافته‌اى ديوانه است.»"
  44,15,"ما اين عذاب را اندكى از شما برمى‌داريم [ولى شما] در حقيقت باز از سر مى‌گيريد"
  44,16,"روزى كه دست به حمله مى‌زنيم، همان حمله بزرگ؛ [آنگاه‌] ما انتقام‌كشنده‌ايم"
  44,17,و به يقين، پيش از آنان قوم فرعون را بيازموديم، و پيامبرى بزرگوار برايشان آمد،
  44,18,"كه [به آنان گفت:] «بندگان خدا را به من بسپاريد، زيرا كه من شما را فرستاده‌اى امينم"
  44,19,و بر خدا برترى مجوييد كه من براى شما حجتى آشكار آورده‌ام
  44,20,و من به پروردگار خود و پروردگار شما پناه مى‌برم از اينكه مرا سنگباران كنيد
  44,21,و اگر به من ايمان نمى‌آوريد، پس، از من كناره گيريد.»
  44,22,"پس پروردگار خود را خواند كه: «اينها مردمى گناهكارند.»"
  44,23,"[فرمود:] «بندگانم را شبانه ببر، زيرا شما مورد تعقيب واقع خواهيد شد"
  44,24,و دريا را هنگامى كه آرام است پشت سر بگذار، كه آنان سپاهى غرق‌شدنى‌اند.»
  44,25,"[وه،] چه باغها و چشمه‌سارانى [كه آنها بعد از خود] بر جاى نهادند،"
  44,26,و كشتزارها و جايگاه‌هاى نيكو،
  44,27,و نعمتى كه از آن برخوردار بودند
  44,28,"[آرى،] اين چنين [بود] و آنها را به مردمى ديگر ميراث داديم"
  44,29,و آسمان و زمين بر آنان زارى نكردند و مهلت نيافتند
  44,30,و به راستى، فرزندان اسرائيل را از عذاب خفت‌آور رهانيديم
  44,31,"از [دست‌] فرعون كه متكبّرى از افراطكاران بود"
  44,32,و قطعاً آنان را دانسته بر مردم جهان ترجيح داديم
  44,33,"و از نشانه‌ها [ى الهى‌] آنچه را كه در آن آزمايشى آشكار بود، بديشان داديم"
  44,34,"هر آينه اين [كافران‌] مى‌گويند"
  44,35,"«جز مرگ نخستين، ديگر [واقعه‌اى‌] نيست و ما زنده‌شدنى نيستيم"
  44,36,"اگر راست مى‌گوييد، پس پدران ما را [باز] آوريد"
  44,37,آيا ايشان بهترند يا قوم «تُبّع» و كسانى كه پيش از آنها بودند؟ آنها را هلاك كرديم، زيرا كه گنهكار بودند
  44,38,و آسمانها و زمين و آنچه را كه ميان آن دو است به بازى نيافريده‌ايم؛
  44,39,آنها را جز به حق نيافريده‌ايم، ليكن بيشترشان نمى‌دانند
  44,40,در حقيقت، روز «جدا سازى» موعد همه آنهاست
  44,41,همان روزى كه هيچ دوستى از هيچ دوستى نمى‌تواند حمايتى كند، و آنان يارى نمى‌شوند،
  44,42,مگر كسى را كه خدا رحمت كرده است، زيرا كه اوست همان ارجمند مهربان
  44,43,آرى! درخت زقوم،
  44,44,خوراك گناه پيشه است
  44,45,چون مس گداخته در شكمها مى‌گدازد؛
  44,46,همانند جوشش آب جوشان
  44,47,او را بگيريد و به ميان دوزخش بكشانيد،
  44,48,آنگاه از عذاب آب جوشان بر سرش فرو ريزيد
  44,49,بچش كه تو همان ارجمند بزرگوارى
  44,50,اين است همان چيزى كه در باره آن ترديد مى‌كرديد
  44,51,"به راستى پرهيزگاران در جايگاهى آسوده [اند]،"
  44,52,در بوستانها و كنار چشمه‌سارها
  44,53,"پرنيان نازك و ديباى ستبر مى‌پوشند [و] برابر هم نشسته‌اند"
  44,54,"[آرى،] چنين [خواهد بود] و آنها را با حوريان درشت‌چشم همسر مى‌گردانيم"
  44,55,"در آنجا هر ميوه‌اى را [كه بخواهند] آسوده خاطر مى‌طلبند"
  44,56,"در آنجا جز مرگ نخستين، مرگ نخواهند چشيد و [خدا] آنها را از عذاب دوزخ نگاه مى‌دارد"
  44,57,"[اين‌] بخششى است از جانب پروردگار تو. اين است همان كاميابى بزرگ"
  44,58,"در حقيقت، [قرآن‌] را بر زبان تو آسان گردانيديم، اميد كه پند پذيرند"
  44,59,پس مراقب باش، زيرا كه آنان هم مراقبند
  45,1,حاء، ميم
  45,2,فرو فرستادن اين كتاب، از جانب خداى ارجمند سنجيده‌كار است
  45,3,به راستى در آسمانها و زمين، براى مؤمنان نشانه‌هايى است
  45,4,"و در آفرينش خودتان و آنچه از [انواع‌] جنبنده‌[ها] پراكنده مى‌گرداند، براى مردمى كه يقين دارند نشانه‌هايى است"
  45,5,"و [نيز در] پياپى آمدن شب و روز، و آنچه خدا از روزى از آسمان فرود آورده و به [وسيله‌] آن، زمين را پس از مرگش زنده گردانيده است؛ و [همچنين در] گردش بادها [به هر سو،] براى مردمى كه مى‌انديشند نشانه‌هايى است"
  45,6,"اين‌[ها]ست آيات خدا كه به راستى آن را بر تو مى‌خوانيم. پس، بعد از خدا و نشانه‌هاى او به كدام سخن خواهند گرويد؟"
  45,7,واى بر هر دروغزن گناه‌پيشه
  45,8,"[كه‌] آيات خدا را كه بر او خوانده مى‌شود، مى‌شنود و باز به حال تكبر -چنانكه گويى آن را نشنيده است- سماجت مى‌ورزد. پس او را از عذابى پردرد خبر ده"
  45,9,و چون از نشانه‌هاى ما چيزى بداند، آن را به ريشخند مى‌گيرد. آنان عذابى خفت‌آور خواهند داشت
  45,10,پيشاپيش آنها دوزخ است، و نه آنچه را اندوخته و نه آن دوستانى را كه غير از خدا اختيار كرده‌اند، به كارشان مى‌آيد، و عذابى بزرگ خواهند داشت
  45,11,اين رهنمودى است؛ و كسانى كه آيات پروردگارشان را انكار كردند، بر ايشان عذابى دردناك از پليدى است
  45,12,"خدا همان كسى است كه دريا را به سود شما رام گردانيد، تا كشتيها در آن به فرمانش روان شوند، و تا از فزون بخشى او [روزى خويش را] طلب نماييد، و باشد كه سپاس داريد"
  45,13,"و آنچه را در آسمانها و آنچه را در زمين است به سود شما رام كرد؛ همه از اوست. قطعاً در اين [امر] براى مردمى كه مى‌انديشند نشانه‌هايى است"
  45,14,"به كسانى كه ايمان آورده‌اند بگو تا از كسانى كه به روزهاى [پيروزى‌] خدا اميد ندارند درگذرند، تا [خدا هر] گروهى را به [سبب‌] آنچه مرتكب مى‌شده‌اند به مجازات رساند"
  45,15,هر كه كارى شايسته كند، به سود خود اوست، و هر كه بدى كند به زيانش باشد. سپس به سوى پروردگارتان برگردانيده مى‌شويد
  45,16,"و به يقين، فرزندان اسرائيل را كتاب [تورات‌] و حكم و پيامبرى داديم و از چيزهاى پاكيزه روزيشان كرديم و آنان را بر مردم روزگار برترى داديم"
  45,17,"و دلايل روشنى در امر [دين‌] به آنان عطا كرديم، و جز بعد از آنكه علم برايشان [حاصل‌] آمد، [آن هم‌] از روى رشك و رقابت ميان خودشان، دستخوش اختلاف نشدند. قطعاً پروردگارت روز قيامت ميانشان در باره آنچه در آن اختلاف مى‌كردند، داورى خواهد كرد"
  45,18,"سپس تو را در طريقه آيينى [كه ناشى‌] از امر [خداست‌] نهاديم. پس آن را پيروى كن، و هوسهاى كسانى را كه نمى‌دانند پيروى مكن"
  45,19,"آنان هرگز در برابر خدا از تو حمايت نمى‌كنند [و به هيچ وجه به كار تو نمى‌آيند ] و ستمگران بعضى‌شان دوستان بعضى [ديگر]ند، و خدا يار پرهيزگاران است"
  45,20,"اين [كتاب‌] براى مردم، بينش‌بخش و براى قومى كه يقين دارند، رهنمود و رحمتى است"
  45,21,"آيا كسانى كه مرتكب كارهاى بد شده‌اند پنداشته‌اند كه آنان را مانند كسانى قرار مى‌دهيم كه ايمان آورده و كارهاى شايسته كرده‌اند [به طورى كه‌] زندگى آنها و مرگشان يكسان باشد؟ چه بد داورى مى‌كنند"
  45,22,"و خدا آسمانها و زمين را به حق آفريده است، و تا هر كسى به [موجب‌] آنچه به دست آورده پاداش يابد، و آنان مورد ستم قرار نخواهند گرفت"
  45,23,پس آيا ديدى كسى را كه هوس خويش را معبود خود قرار داده و خدا او را دانسته گمراه گردانيده و بر گوش او و دلش مُهر زده و بر ديده‌اش پرده نهاده است؟ آيا پس از خدا چه كسى او را هدايت خواهد كرد؟ آيا پند نمى‌گيريد؟
  45,24,"و گفتند: «غير از زندگانى دنياى ما [چيز ديگرى‌] نيست؛ مى‌ميريم و زنده مى‌شويم، و ما را جز طبيعت هلاك نمى‌كند.» و[لى‌] به اين [مطلب‌] هيچ دانشى ندارند [و] جز [طريق‌] گمان نمى‌سپرند"
  45,25,"و چون آيات روشن ما بر آنان خوانده شود، دليلشان همواره جز اين نيست كه مى گويند: «اگر راست مى‌گوييد پدران ما را [حاضر] آوريد.»"
  45,26,"بگو: «خدا[ست كه‌] شما را زندگى مى‌بخشد، سپس مى‌ميراند، آنگاه شما را به سوى روز رستاخيز -كه ترديدى در آن نيست- گرد مى‌آورد، ولى بيشتر مردم [اين را] نمى‌دانند.»"
  45,27,و فرمانروايى آسمانها و زمين از آن خداست، و روزى كه رستاخيز بر پا شود، آن روز است كه باطل‌انديشان زيان خواهند ديد
  45,28,"و هر امتى را به زانو در آمده مى‌بينى؛ هر امتى به سوى كارنامه خود فراخوانده مى‌شود [و بديشان مى‌گويند:] «آنچه را مى‌كرديد امروز پاداش مى‌يابيد"
  45,29,اين است كتاب ما كه عليه شما به حق سخن مى‌گويد. ما از آنچه مى‌كرديد، نسخه بر مى‌داشتيم.»
  45,30,و اما كسانى كه ايمان آورده و كارهاى شايسته كرده‌اند، پس پروردگارشان آنان را در جوار رحمت خويش داخل مى‌گرداند. اين همان كاميابى آشكار است
  45,31,"و اما كسانى كه كافر شدند [بدانها مى‌گويند:] «پس مگر آيات من بر شما خوانده نمى‌شد؟ و[لى‌] تكبر نموديد و مردمى بدكار بوديد.»"
  45,32,"و چون گفته شد: «وعده خدا راست است و شكى در رستاخيز نيست»، گفتيد: «ما نمى‌دانيم رستاخيز چيست. جز گمان نمى‌ورزيم و ما يقين نداريم.»"
  45,33,"و [حقيقت‌] بديهايى كه كرده‌اند، بر آنان پديدار مى‌شود و آنچه را كه بدان ريشخند مى‌كردند، آنان را فرو مى‌گيرد"
  45,34,"و گفته شود: «همان‌گونه كه ديدار امروزتان را فراموش كرديد، امروز شما را فراموش خواهيم كرد، و جايگاهتان در آتش است و براى شما ياورانى نخواهد بود.»"
  45,35,"اين بدان سبب است كه شما آيات خدا را به ريشخند گرفتيد و زندگى دنيا فريبتان داد. پس امروز نه از اين [آتش‌] بيرون آورده مى‌شوند، و نه عذرشان پذيرفته مى‌گردد"
  45,36,"پس سپاس از آن خداست: پروردگار آسمانها و پروردگار زمين، پروردگار جهانيان"
  45,37,و در آسمانها و زمين، بزرگى از آن اوست، و اوست شكست‌ناپذير سنجيده‌كار
  46,1,حاء، ميم
  46,2,فرو فرستادن اين كتاب، از جانب خداى ارجمند حكيم است
  46,3,"[ما] آسمانها و زمين و آنچه را كه ميان آن دو است جز به حق و [تا] زمانى معيّن نيافريديم، و كسانى كه كافر شده‌اند، از آنچه هشدار داده شده‌اند رويگردانند"
  46,4,"بگو: «به من خبر دهيد، آنچه را به جاى خدا فرا مى‌خوانيد به من نشان دهيد كه چه چيزى از زمين [را] آفريده يا [مگر] آنان را در [كار] آسمانها مشاركتى است؟ اگر راست مى‌گوييد، كتابى پيش از اين [قرآن ]يا بازمانده‌اى از دانش نزد من آوريد.»"
  46,5,و كيست گمراه‌تر از آن كس كه به جاى خدا كسى را مى‌خواند كه تا روز قيامت او را پاسخ نمى‌دهد، و آنها از دعايشان بى‌خبرند؟
  46,6,و چون مردم محشور گردند، دشمنان آنان باشند و به عبادتشان انكار ورزند
  46,7,"و چون آيات روشن ما بر ايشان خوانده شود، آنان كه چون حقيقت به سويشان آمد منكر آن شدند، گفتند: «اين سحرى آشكار است.»"
  46,8,"يا مى‌گويند: «اين [كتاب‌] را بربافته است.» بگو: «اگر آن را بربافته باشم؛ در برابر خدا اختيار چيزى براى من نداريد. او آگاه‌تر است به آنچه [با طعنه‌] در آن فرو مى‌رويد. گواه بودن او ميان من و شما بس است، و اوست آمرزنده مهربان.»"
  46,9,"بگو: «من از [ميان‌] پيامبران، نودرآمدى نبودم و نمى‌دانم با من و با شما چه معامله‌اى خواهد شد. جز آنچه را كه به من وحى مى‌شود، پيروى نمى‌كنم؛ و من جز هشداردهنده‌اى آشكار [بيش‌] نيستم.»"
  46,10,"بگو: «به من خبر دهيد، اگر اين [قرآن‌] از نزد خدا باشد و شما بدان كافر شده باشيد و شاهدى از فرزندان اسرائيل به مشابهت آن [با تورات‌] گواهى داده و ايمان آورده باشد، و شما تكبّر نموده باشيد [آيا باز هم شما ستمكار نيستيد؟] البته خدا قوم ستمگر را هدايت نمى‌كند.»"
  46,11,"و كسانى كه كافر شدند، به آنان كه گرويده‌اند گفتند: «اگر [اين دين‌] خوب بود، بر ما بدان پيشى نمى‌گرفتند.» و چون بدان هدايت نيافته‌اند، به زودى خواهند گفت: «اين دروغى كهنه است.»"
  46,12,"و [حال آنكه‌] پيش از آن، كتاب موسى، راهبر و [مايه‌] رحمتى بود؛ و اين [قرآن‌] كتابى است به زبان عربى كه تصديق‌كننده [آن‌] است، تا كسانى را كه ستم كرده‌اند هشدار دهد و براى نيكوكاران مژده‌اى باشد"
  46,13,"محققاً كسانى كه گفتند: «پروردگار ما خداست» سپس ايستادگى كردند، بيمى بر آنان نيست و غمگين نخواهند شد"
  46,14,ايشان اهل بهشتند كه به پاداش آنچه انجام مى‌دادند جاودانه در آن مى‌مانند
  46,15,"و انسان را [نسبت‌] به پدر و مادرش به احسان سفارش كرديم. مادرش با تحمّل رنج به او باردار شد و با تحمّل رنج او را به دنيا آورد. و باربرداشتن و از شيرگرفتن او سى ماه است، تا آنگاه كه به رشد كامل خود برسد و به چهل سال برسد، مى‌گويد: «پروردگارا، بر دلم بيفكن تا نعمتى را كه به من و به پدر و مادرم ارزانى داشته‌اى سپاس گويم و كار شايسته‌اى انجام دهم كه آن را خوش دارى، و فرزندانم را برايم شايسته گردان؛ در حقيقت، من به درگاه تو توبه آوردم و من از فرمان‌پذيرانم.»"
  46,16,"اينانند كسانى كه بهترين آنچه را انجام داده‌اند از ايشان خواهيم پذيرفت و از بديهايشان درخواهيم گذشت؛ در [زمره‌] بهشتيانند؛ [همان‌] وعده راستى كه بدانان وعده داده مى‌شده است"
  46,17,"و آن كس كه به پدر و مادر خود گويد: «اف بر شما، آيا به من وعده مى‌دهيد كه زنده خواهم شد و حال آنكه پيش از من نسلها سپرى [و نابود] شدند.» و آن دو به [درگاه‌] خدا زارى مى‌كنند: «واى بر تو، ايمان بياور. وعده [و تهديد] خدا حق است.» و[لى پسر] پاسخ مى‌دهد: «اينها جز افسانه‌هاى گذشتگان نيست.»"
  46,18,"آنان كسانى‌اند كه گفتار [خدا] عليه ايشان -همراه با امتهايى از جنيان و آدميان كه پيش از آنان روزگار به سر بردند- به حقيقت پيوست، بى‌گمان آنان زيانكار بودند"
  46,19,"و براى هر يك در [نتيجه‌] آنچه انجام داده‌اند درجاتى است، و تا [خدا پاداش‌] اعمالشان را تمام بدهد؛ و آنان مورد ستم قرار نخواهند گرفت"
  46,20,"و آن روز كه آنهايى را كه كفر ورزيده‌اند، بر آتش عرضه مى‌دارند [به آنان مى گويند:] «نعمتهاى پاكيزه خود را در زندگى دنيايتان [خودخواهانه‌] صَرف كرديد و از آنها برخوردار شديد؛ پس امروز به [سزاى ]آنكه در زمين بناحق سركشى مى‌نموديد و به سبب آنكه نافرمانى مى‌كرديد، به عذاب خفت‌[آور] كيفر مى‌يابيد.»"
  46,21,"و برادر عاديان را به ياد آور، آنگاه كه قوم خويش را در ريگستان بيم داد -در حالى كه پيش از او و پس از او [نيز] قطعاً هشداردهندگانى گذشته بودند- كه: «جز خدا را مپرستيد؛ واقعاً من بر شما از عذاب روزى هولناك مى‌ترسم.»"
  46,22,"گفتند: «آيا آمده‌اى كه ما را از خدايانمان برگردانى؟ پس اگر راست مى‌گويى، آنچه به ما وعده مى‌دهى [بر سرمان‌] بياور.»"
  46,23,"گفت: «آگاهى فقط نزد خداست، و آنچه را بدان فرستاده شده‌ام به شما مى‌رسانم، ولى من شما را گروهى مى‌بينم كه در جهل اصرار مى‌ورزيد.»"
  46,24,"پس چون آن [عذاب‌] را [به صورت‌] ابرى روى‌آورنده به سوى واديهاى خود ديدند، گفتند: «اين ابرى است كه بارش‌دهنده ماست.» [هود گفت: «نه،] بلكه همان چيزى است كه به شتاب خواستارش بوديد: بادى است كه در آن عذابى پر درد [نهفته‌] است"
  46,25,همه چيز را به دستور پروردگارش بنيان‌كن مى‌كند.» پس چنان شدند كه جز سراهايشان ديده نمى‌شد. اين چنين گروه بدكاران را سزا مى‌دهيم
  46,26,"و به راستى در چيزهايى به آنان امكانات داده بوديم كه به شما در آنها [چنان‌] امكاناتى نداده‌ايم، و براى آنان گوش و ديده‌ها و دلهايى [نيرومندتر از شما] قرار داده بوديم، و[لى‌] چون به نشانه‌هاى خدا انكار ورزيدند [نه‌] گوششان و نه ديدگانشان و نه دلهايشان، به هيچ وجه به دردشان نخورد، و آنچه ريشخندش مى‌كردند به سرشان آمد"
  46,27,و بى‌گمان، همه شهرهاى پيرامون شما را هلاك كرده و آيات خود را گونه‌گون بيان داشته‌ايم، اميد كه آنان بازگردند
  46,28,"پس چرا آن كسانى را كه غير از خدا، به منزله معبودانى، براى تقرّب [به خدا] اختيار كرده بودند، آنان را يارى نكردند بلكه از دستشان دادند؟ و اين بود دروغ آنان و آنچه برمى‌بافتند"
  46,29,"و چون تنى چند از جِن را به سوى تو روانه كرديم كه قرآن را بشنوند؛ پس چون بر آن حاضر شدند [به يكديگر] گفتند: «گوش فرا دهيد.» و چون به انجام رسيد، هشداردهنده به سوى قوم خود بازگشتند"
  46,30,"گفتند: «اى قوم ما، ما كتابى را شنيديم كه بعد از موسى نازل شده [و] تصديق‌كننده [كتابهاى‌] پيش از خود است، و به سوى حق و به سوى راهى راست راهبرى مى‌كند"
  46,31,"اى قوم ما، دعوت‌كننده خدا را پاسخ [مثبت‌] دهيد و به او ايمان آوريد تا [خدا] برخى از گناهانتان را بر شما ببخشايد و از عذابى پر درد پناهتان دهد"
  46,32,"و كسى كه دعوت‌كننده خدا را اجابت نكند، در زمين درمانده‌كننده [خدا] نيست و در برابر او دوستانى ندارد. آنان در گمراهى آشكارى‌اند"
  46,33,"مگر ندانسته‌اند كه آن خدايى كه آسمانها و زمين را آفريده و در آفريدن آنها درمانده نگرديد؛ مى‌تواند مردگان را [نيز] زنده كند؟ آرى، اوست كه بر همه چيز تواناست"
  46,34,"و روزى كه كافران بر آتش عرضه مى‌شوند [از آنان مى‌پرسند:] «آيا اين راست نيست؟» مى‌گويند: «سوگند به پروردگارمان كه آرى.» مى‌فرمايد: «پس به [سزاى‌] آنكه انكار مى‌كرديد عذاب را بچشيد.»"
  46,35,"پس همان گونه كه پيامبران نستوه، صبر كردند، صبر كن، و براى آنان شتابزدگى به خرج مده. روزى كه آنچه را وعده داده مى‌شوند بنگرند، گويى كه آنان جز ساعتى از روز را [در دنيا] نمانده‌اند؛ [اين‌] ابلاغى است. پس آيا جز مردم نافرمان هلاكت خواهند يافت؟"
  47,1,"كسانى كه كفر ورزيدند و [مردم را] از راه خدا باز داشتند، [خدا] اعمال آنان را تباه خواهد كرد"
  47,2,"و آنان كه ايمان آورده و كارهاى شايسته كرده‌اند و به آنچه بر محمد [ص‌] نازل آمده گرويده‌اند -[كه‌] آن خود حق [و] از جانب پروردگارشان است- [خدا نيز] بديهايشان را زدود و حال [و روز]شان را بهبود بخشيد"
  47,3,"اين بدان سبب است كه آنان كه كفر ورزيدند، از باطل پيروى كردند، و كسانى كه ايمان آوردند از همان حق -كه از جانب پروردگارشان است- پيروى كردند. اين گونه خدا براى [بيدارى‌] مردم مثالهايشان را مى‌زند"
  47,4,"پس چون با كسانى كه كفر ورزيده‌اند برخورد كنيد، گردنها[يشان‌] را بزنيد. تا چون آنان را [در كشتار] از پاى درآورديد، پس [اسيران را] استوار در بند كشيد؛ سپس يا [بر آنان‌] منّت نهيد [و آزادشان كنيد] و يا فديه [و عوض از ايشان بگيريد]، تا در جنگ، اسلحه بر زمين گذاشته شود. اين است [دستور خدا]؛ و اگر خدا مى‌خواست، از ايشان انتقام مى‌كشيد، ولى [فرمان پيكار داد] تا برخى از شما را به وسيله برخى [ديگر] بيازمايد، و كسانى كه در راه خدا كشته شده‌اند، هرگز كارهايشان را ضايع نمى‌كند"
  47,5,به زودى آنان را راه مى‌نمايد و حالشان را نيكو مى‌گرداند
  47,6,و در بهشتى كه براى آنان وصف كرده، آنان را درمى‌آورد
  47,7,اى كسانى كه ايمان آورده‌ايد، اگر خدا را يارى كنيد ياريتان مى‌كند و گامهايتان را استوار مى‌دارد
  47,8,"و كسانى كه كفر ورزيدند، نگونسارى بر آنان باد؛ و [خدا] اعمالشان را برباد داد"
  47,9,"اين بدان سبب است كه آنان آنچه را خدا نازل كرده است خوش نداشتند، و [خدا نيز] كارهايشان را باطل كرد"
  47,10,"مگر در زمين نگشته‌اند، تا ببينند فرجام كسانى كه پيش از آنها بودند به كجا انجاميده است؟ خدا زير و زبرشان كرد و كافران را نظاير [همين كيفرها در پيش‌] است"
  47,11,"چرا كه خدا سرپرست كسانى است كه ايمان آورده‌اند، ولى كافران را سرپرست [و يارى‌] نيست"
  47,12,"خدا كسانى را كه ايمان آورده و كارهاى شايسته كرده‌اند، در باغهايى كه از زير [درختان‌] آنها نهرها روان است درمى‌آورد، و [حال آنكه‌] كسانى كه كافر شده‌اند، [در ظاهر] بهره مى‌برند و همان گونه كه چارپايان مى‌خورند، مى‌خورند، و[لى ]جايگاه آنها آتش است"
  47,13,"و بسا شهرها كه نيرومندتر از آن شهرى بود كه تو را [از خود] بيرون راند، كه ما هلاكشان كرديم و براى آنها يار [و ياورى‌] نبود"
  47,14,آيا كسى كه بر حجتى از جانب پروردگار خويش است، چون كسى است كه بدى كردارش براى او زيبا جلوه داده شده و هوسهاى خود را پيروى كرده‌اند؟
  47,15,"مَثَل بهشتى كه به پرهيزگاران وعده داده شده [چون باغى است كه‌] در آن نهرهايى است از آبى كه [رنگ و بو و طعمش‌] برنگشته؛ و جويهايى از شيرى كه مزه‌اش دگرگون نشود؛ و رودهايى از باده‌اى كه براى نوشندگان لذتى است؛ و جويبارهايى از انگبين ناب. و در آنجا از هر گونه ميوه براى آنان [فراهم‌] است و [از همه بالاتر] آمرزش پروردگار آنهاست. [آيا چنين كسى در چنين باغى دل‌انگيز] مانند كسى است كه جاودانه در آتش است و آبى جوشان به خوردشان داده مى‌شود [تا] روده‌هايشان را از هم فرو پاشد؟"
  47,16,"و از ميان [منافقان‌] كسانى‌اند كه [در ظاهر] به [سخنان‌] تو گوش مى‌دهند، ولى چون از نزد تو بيرون مى‌روند، به دانش يافتگان مى‌گويند: «هم اكنون چه گفت؟» اينان همانانند كه خدا بر دلهايشان مهر نهاده است و از هوسهاى خود پيروى كرده‌اند"
  47,17,"و[لى‌] آنان كه به هدايت گراييدند [خدا] آنان را هر چه بيشتر هدايت بخشيد و [توفيق‌] پرهيزگارى‌شان داد"
  47,18,"آيا [كافران‌] جز اين انتظار مى‌برند كه رستاخيز به ناگاه بر آنان فرا رسد؟ و علامات آن اينك پديد آمده است. پس اگر [رستاخيز] بر آنان دررسد، ديگر كجا جاى اندرزشان است؟"
  47,19,"پس بدان كه هيچ معبودى جز خدا نيست؛ و براى گناه خويش آمرزش جوى؛ و براى مردان و زنان با ايمان [طلب مغفرت كن‌]؛ و خداست كه فرجام و م‌آل [هر يك از] شما را مى‌داند"
  47,20,"و كسانى كه ايمان آورده‌اند مى‌گويند: «چرا سوره‌اى [در باره جهاد] نازل نمى شود؟» اما چون سوره‌اى صريح نازل شد و در آن نام كارزار آمد، آنان كه در دلهايشان مرضى هست، مانند كسى كه به حال بيهوشى مرگ افتاده به تو مى‌نگرند"
  47,21,"[ولى‌] فرمان‌پذيرى و سخنى شايسته برايشان بهتر است. و چون كار به تصميم كشد، قطعاً خير آنان در اين است كه با خدا راست‌[دل‌] باشند"
  47,22,"پس [اى منافقان،] آيا اميد بستيد كه چون [از خدا] برگشتيد [يا سرپرست مردم شديد] در [روى‌] زمين فساد كنيد و خويشاونديهاى خود را از هم بگسليد؟"
  47,23,"اينان همان كسانند كه خدا آنان را لعنت نموده و [گوش دل‌] ايشان را ناشنوا و چشمهايشان را نابينا كرده است"
  47,24,"آيا به آيات قرآن نمى‌انديشند؟ يا [مگر] بر دلهايشان قفلهايى نهاده شده است؟"
  47,25,"بى‌گمان، كسانى كه پس از آنكه [راه‌] هدايت بر آنان روشن شد [به حقيقت‌] پشت كردند، شيطان آنان را فريفت و به آرزوهاى دور و درازشان انداخت"
  47,26,"چرا كه آنان به كسانى كه آنچه را خدا نازل كرده خوش نمى‌داشتند، گفتند: «ما در كار [مخالفت‌] تا حدودى از شما اطاعت خواهيم كرد.» و خدا از همداستانى آنان آگاه است"
  47,27,"پس چگونه [تاب مى‌آورند] وقتى كه فرشتگان [عذاب‌]، جانشان را مى‌ستانند و بر چهره و پشت آنان تازيانه مى‌نوازند؟"
  47,28,زيرا آنان از آنچه خدا را به خشم آورده پيروى كرده‌اند و خرسنديش را خوش نداشتند؛ پس اعمالشان را باطل گردانيد
  47,29,آيا كسانى كه در دلهايشان مرضى هست، پنداشتند كه خدا هرگز كينه آنان را آشكار نخواهد كرد؟
  47,30,"و اگر بخواهيم، قطعاً آنان را به تو مى‌نمايانيم، در نتيجه ايشان را به سيماى [حقيقى‌]شان مى‌شناسى و از آهنگ سخن به [حال‌] آنان پى خواهى برد؛ و خداست كه كارهاى شما را مى‌داند"
  47,31,"و البته شما را مى‌آزماييم تا مجاهدان و شكيبايان شما را باز شناسانيم، و گزارشهاى [مربوط به‌] شما را رسيدگى كنيم"
  47,32,"كسانى كه كافر شدند و [مردم را] از راه خدا باز داشتند و پس از آنكه راه هدايت بر آنان آشكار شد، با پيامبر [خدا] در افتادند، هرگز به خدا گزندى نمى‌رسانند؛ و به زودى [خدا] كرده‌هايشان را تباه خواهد كرد"
  47,33,"اى كسانى كه ايمان آورده‌ايد، خدا را اطاعت كنيد و از پيامبر [او نيز] اطاعت نماييد، و كرده‌هاى خود را تباه مكنيد"
  47,34,آنان كه كفر ورزيدند و مانع راه خدا شدند، سپس در حال كفر مردند، هرگز خدا از آنان درنخواهد گذشت
  47,35,"پس سستى نورزيد و [كافران را] به آشتى مخوانيد [كه‌] شما برتريد و خدا با شماست و از [ارزش‌] كارهايتان هرگز نخواهد كاست"
  47,36,"زندگى اين دنيا لهو و لعبى بيش نيست، و اگر ايمان بياوريد و پروا بداريد [خدا] پاداش شما را مى‌دهد و اموالتان را [در عوض‌] نمى‌خواهد"
  47,37,"اگر [اموال‌] شما را بخواهد و به اصرار از شما طلب كند بخل مى‌ورزيد، و كينه‌هاى شما را برملا مى‌كند"
  47,38,"شما همان [مردمى‌] هستيد كه براى انفاق در راه خدا فرا خوانده شده‌ايد. پس برخى از شما بخل مى‌ورزند، و هر كس بخل ورزد تنها به زيان خود بخل ورزيده، و [گرنه‌] خدا بى‌نياز است و شما نيازمنديد؛ و اگر روى برتابيد [خدا] جاى شما را به مردمى غير از شما خواهد داد كه مانند شما نخواهند بود"
  48,1,"ما تو را پيروزى بخشيديم [چه‌] پيروزى درخشانى"
  48,2,تا خداوند از گناه گذشته و آينده تو درگذرد و نعمت خود را بر تو تمام گرداند و تو را به راهى راست هدايت كند
  48,3,و تو را به نصرتى ارجمند يارى نمايد
  48,4,اوست آن كس كه در دلهاى مؤمنان آرامش را فرو فرستاد تا ايمانى بر ايمان خود بيفزايند. و سپاهيان آسمانها و زمين از آن خداست، و خدا همواره داناى سنجيده‌كار است
  48,5,"تا مردان و زنانى را كه ايمان آورده‌اند در باغهايى كه از زير [درختان‌] آن جويبارها روان است، درآورد و در آن جاويدان بدارد، و بديهايشان را از آنان بزدايد؛ و اين [فرجام نيك‌] در پيشگاه خدا كاميابى بزرگى است"
  48,6,"و [تا] مردان و زنان نفاق‌پيشه و مردان و زنان مشرك را كه به خدا گمان بد برده‌اند، عذاب كند؛ بد زمانه بر آنان باد. و خدا بر ايشان خشم نموده و لعنتشان كرده و جهنم را براى آنان آماده گردانيده و [چه‌] بد سرانجامى است،"
  48,7,و سپاهيان آسمانها و زمين از آن خداست، و خدا همواره شكست‌ناپذير سنجيده‌كار است
  48,8,"[اى پيامبر،] ما تو را [به سمت‌] گواه و بشارتگر و هشداردهنده‌اى فرستاديم"
  48,9,"تا به خدا و فرستاده‌اش ايمان آوريد و او را يارى كنيد و ارجش نهيد، و [خدا] را بامدادان و شامگاهان به پاكى بستاييد"
  48,10,در حقيقت، كسانى كه با تو بيعت مى‌كنند، جز اين نيست كه با خدا بيعت مى‌كنند؛ دست خدا بالاى دستهاى آنان است. پس هر كه پيمان‌شكنى كند، تنها به زيان خود پيمان مى‌شكند، و هر كه بر آنچه با خدا عهد بسته وفادار بماند، به زودى خدا پاداشى بزرگ به او مى‌بخشد
  48,11,"برجاى‌ماندگان باديه‌نشين به زودى به تو خواهند گفت: «اموال ما و كسانمان ما را گرفتار كردند، براى ما آمرزش بخواه.» چيزى را كه در دلهايشان نيست بر زبان خويش مى‌رانند. بگو: «اگر خدا بخواهد به شما زيانى يا سودى برساند چه كسى در برابر او براى شما اختيار چيزى را دارد؟ بلكه [اين‌] خداست كه به آنچه مى‌كنيد همواره آگاه است"
  48,12,"[نه چنان بود،] بلكه پنداشتيد كه پيامبر و مؤمنان هرگز به خانمان خود بر نخواهند گشت، و اين [پندار] در دلهايتان نمودى خوش يافت، و گمان بد كرديد، و شما مردمى در خور هلاكت بوديد.»"
  48,13,"و هر كس به خدا و پيامبر او ايمان نياورده است [بداند كه‌] ما براى كافران آتشى سوزان آماده كرده‌ايم"
  48,14,"و فرمانروايى آسمانها و زمين از آن خداست: هر كه را بخواهد مى‌بخشايد و هر كه را بخواهد عذاب مى‌كند، و خدا همواره آمرزنده مهربان است"
  48,15,"چون به [قصد] گرفتن غنايم روانه شديد، به زودى برجاى‌ماندگان خواهند گفت: «بگذاريد ما [هم‌] به دنبال شما بياييم.» [اين گونه‌] مى‌خواهند دستور خدا را دگرگون كنند. بگو: «هرگز از پى ما نخواهيد آمد. آرى، خدا از پيش در باره شما چنين فرموده.» پس به زودى خواهند گفت: «[نه،] بلكه بر ما رشگ مى‌بريد.» [نه چنين است‌] بلكه جز اندكى درنمى‌يابند"
  48,16,"به برجاى‌ماندگان باديه‌نشين بگو: «به زودى به سوى قومى سخت زورمند دعوت خواهيد شد كه با آنان بجنگيد يا اسلام آورند. پس اگر فرمان بريد خدا شما را پاداش نيك مى‌بخشد، و اگر -همچنان كه پيشتر پشت كرديد- [باز هم‌] روى بگردانيد، شما را به عذابى پردرد معذب مى‌دارد.»"
  48,17,"بر نابينا گناهى نيست و بر لنگ گناهى نيست و بر بيمار گناهى نيست [كه در جهاد شركت نكنند]؛ و هر كس خدا و پيامبر او را فرمان برد، وى را در باغهايى كه از زير [درختان‌] آن نهرهايى روان است درمى‌آورد، و هر كس روى برتابد، به عذابى دردناك معذبش مى‌دارد"
  48,18,به راستى خدا هنگامى كه مؤمنان، زير آن درخت با تو بيعت مى‌كردند از آنان خشنود شد، و آنچه در دلهايشان بود بازشناخت و بر آنان آرامش فرو فرستاد و پيروزى نزديكى به آنها پاداش داد
  48,19,"و [نيز] غنيمتهاى فراوانى خواهند گرفت، و خدا همواره نيرومند سنجيده‌كار است"
  48,20,"و خدا به شما غنيمتهاى فراوان [ديگرى‌] وعده داده كه به زودى آنها را خواهيد گرفت، و اين [پيروزى‌] را براى شما پيش انداخت، و دستهاى مردم را از شما كوتاه ساخت، و تا براى مؤمنان نشانه‌اى باشد و شما را به راه راست هدايت كند"
  48,21,"و [غنيمتهاى‌] ديگر[ى نيز هست‌] كه شما بر آنها دست نيافته‌ايد [و] خدا بر آنها نيك احاطه دارد، و همواره خداوند بر هر چيزى تواناست"
  48,22,و اگر كسانى كه كافر شدند، به جنگ با شما برخيزند، قطعاً پشت خواهند كرد، و ديگر يار و ياورى نخواهند يافت
  48,23,سنّت الهى از پيش همين بوده، و در سنّت الهى هرگز تغييرى نخواهى يافت
  48,24,و اوست همان كسى كه در دل مكه -پس از پيروزكردن شما بر آنان- دستهاى آنها را از شما و دستهاى شما را از ايشان كوتاه گردانيد، و خدا به آنچه مى‌كنيد همواره بيناست
  48,25,"آنها بودند كه كفر ورزيدند و شما را از مسجد الحرام بازداشتند و نگذاشتند قربانى [شما] كه بازداشته شده بود به محلش برسد، و اگر [در مكه‌] مردان و زنان با ايمانى نبودند كه [ممكن بود] بى‌آنكه آنان را بشناسيد، ندانسته پايمالشان كنيد و تاوانشان بر شما بماند [فرمان حمله به مكه مى‌داديم‌] تا خدا هر كه را بخواهد در جوار رحمت خويش درآورد. اگر [كافر و مؤمن‌] از هم متمايز مى‌شدند، قطعاً كافران را به عذاب دردناكى معذب مى‌داشتيم"
  48,26,"آنگاه كه كافران در دلهاى خود، تعصّب [آن هم‌] تعصّب جاهليّت ورزيدند، پس خدا آرامش خود را بر فرستاده خويش و بر مؤمنان فرو فرستاد، و آرمان تقوا را ملازم آنان ساخت، و [در واقع‌] آنان به [رعايت ]آن [آرمان‌] سزاوارتر و شايسته [اتصاف به‌] آن بودند، و خدا همواره بر هر چيزى داناست"
  48,27,"حقاً خدا رؤياى پيامبر خود را تحقّق بخشيد [كه ديده بود:] شما بدون شكّ، به خواست خدا در حالى كه سر تراشيده و موى [و ناخن‌] كوتاه كرده‌ايد، با خاطرى آسوده در مسجد الحرام درخواهيد آمد. خدا آنچه را كه نمى‌دانستيد دانست، و غير از اين، پيروزى نزديكى [براى شما] قرار داد"
  48,28,"اوست كسى كه پيامبر خود را به [قصد] هدايت، با آيين درست روانه ساخت، تا آن را بر تمام اديان پيروز گرداند و گواه‌بودن خدا كفايت مى‌كند"
  48,29,"محمد [ص‌] پيامبر خداست؛ و كسانى كه با اويند، بر كافران، سختگير [و] با همديگر مهربانند. آنان را در ركوع و سجود مى‌بينى. فضل و خشنودى خدا را خواستارند. علامت [مشخصّه‌] آنان بر اثر سجود در چهره‌هايشان است. اين صفت ايشان است در تورات، و مثَل آنها در انجيل چون كشته‌اى است كه جوانه خود برآورد و آن را مايه دهد تا ستبر شود و بر ساقه‌هاى خود بايستد و دهقانان را به شگفت آورد، تا از [انبوهى‌] آنان [خدا] كافران را به خشم دراندازد. خدا به كسانى از آنان كه ايمان آورده و كارهاى شايسته كرده‌اند، آمرزش و پاداش بزرگى وعده داده‌است"
  49,1,"اى كسانى كه ايمان آورده‌ايد، در برابر خدا و پيامبرش [در هيچ كارى‌] پيشى مجوييد و از خدا پروا بداريد كه خدا شنواى داناست"
  49,2,اى كسانى كه ايمان آورده‌ايد، صدايتان را بلندتر از صداى پيامبر مكنيد، و همچنانكه بعضى از شما با بعضى ديگر بلند سخن مى‌گوييد با او به صداى بلند سخن مگوييد، مبادا بى‌آنكه بدانيد كرده‌هايتان تباه شود
  49,3,كسانى كه پيش پيامبر خدا صدايشان را فرو مى‌كشند همان كسانند كه خدا دلهايشان را براى پرهيزگارى امتحان كرده است؛ آنان را آمرزش و پاداشى بزرگ است
  49,4,"كسانى كه تو را از پشت اتاقها[ى مسكونى تو] به فرياد مى‌خوانند، بيشترشان نمى‌فهمند"
  49,5,و اگر صبر كنند تا بر آنان درآيى، مسلماً برايشان بهتر است و خدا آمرزنده و مهربان است
  49,6,"اى كسانى كه ايمان آورده‌ايد، اگر فاسقى برايتان خبرى آورد، نيك وارسى كنيد، مبادا به نادانى گروهى را آسيب برسانيد و [بعد،] از آنچه كرده‌ايد پشيمان شويد"
  49,7,"و بدانيد كه پيامبر خدا در ميان شماست. اگر در بسيارى از كارها از [رأى و ميل‌] شما پيروى كند، قطعاً دچار زحمت مى‌شويد، ليكن خدا ايمان را براى شما دوست‌داشتنى گردانيد و آن را در دلهاى شما بياراست و كفر و پليدكارى و سركشى را در نظرتان ناخوشايند ساخت. آنان [كه چنين‌اند] ره‌يافتگانند"
  49,8,"[و اين‌] بخششى از خدا و نعمتى [از اوست‌]، و خدا داناى سنجيده‌كار است"
  49,9,"و اگر دو طايفه از مؤمنان با هم بجنگند، ميان آن دو را اصلاح دهيد، و اگر [باز] يكى از آن دو بر ديگرى تعدّى كرد، با آن [طايفه‌اى‌] كه تعدّى مى‌كند بجنگيد تا به فرمان خدا بازگردد. پس اگر باز گشت، ميان آنها را دادگرانه سازش دهيد و عدالت كنيد، كه خدا دادگران را دوست مى‌دارد"
  49,10,در حقيقت مؤمنان با هم برادرند، پس ميان برادرانتان را سازش دهيد و از خدا پروا بداريد، اميد كه مورد رحمت قرار گيريد
  49,11,"اى كسانى كه ايمان آورده‌ايد، نبايد قومى قوم ديگر را ريشخند كند، شايد آنها از اينها بهتر باشند، و نبايد زنانى زنان [ديگر] را [ريشخند كنند ]، شايد آنها از اينها بهتر باشند، و از يكديگر عيب مگيريد، و به همديگر لقبهاى زشت مدهيد؛ چه ناپسنديده است نام زشت پس از ايمان. و هر كه توبه نكرد آنان خود ستمكارند"
  49,12,"اى كسانى كه ايمان آورده‌ايد، از بسيارى از گمانها بپرهيزيد كه پاره‌اى از گمانها گناه است، و جاسوسى مكنيد، و بعضى از شما غيبت بعضى نكند؛ آيا كسى از شما دوست دارد كه گوشت برادر مرده‌اش را بخورد؟ از آن كراهت داريد. [پس‌] از خدا بترسيد، كه خدا توبه‌پذير مهربان است"
  49,13,اى مردم، ما شما را از مرد و زنى آفريديم، و شما را ملّت ملّت و قبيله قبيله گردانيديم تا با يكديگر شناسايى متقابل حاصل كنيد. در حقيقت ارجمندترين شما نزد خدا پرهيزگارترين شماست. بى‌ترديد، خداوند داناى آگاه است
  49,14,"[برخى از] باديه‌نشينان گفتند: «ايمان آورديم.» بگو: «ايمان نياورده‌ايد، ليكن بگوييد: اسلام آورديم. و هنوز در دلهاى شما ايمان داخل نشده است. و اگر خدا و پيامبر او را فرمان بريد از [ارزش‌] كرده‌هايتان چيزى كم نمى‌كند. خدا آمرزنده مهربان است.»"
  49,15,"در حقيقت، مؤمنان كسانى‌اند كه به خدا و پيامبر او گرويده و [ديگر] شكّ نياورده و با مال و جانشان در راه خدا جهاد كرده‌اند؛ اينانند كه راستكردارند"
  49,16,"بگو: «آيا خدا را از دين‌[دارى‌] خود خبر مى‌دهيد؟ و حال آنكه خدا آنچه را كه در زمين است مى‌داند، و خدا به همه چيز داناست"
  49,17,"از اينكه اسلام آورده‌اند بر تو منّت مى‌نهند؛ بگو: «بر من از اسلام‌آوردنتان منّت مگذاريد، بلكه [اين‌] خداست كه با هدايت‌كردن شما به ايمان، بر شما منّت مى‌گذارد، اگر راستگو باشيد"
  49,18,"خداست كه نهفته آسمانها و زمين را مى‌داند و خدا[ست كه‌] به آنچه مى‌كنيد بيناست.»"