quran[11]{c,v,t}:
  101,1,كوبنده،
  101,2,چيست كوبنده؟
  101,3,و تو چه دانى كه كوبنده چيست؟
  101,4,"روزى كه مردم چون پروانه‌[هاى‌] پراكنده گردند،"
  101,5,و كوه‌ها مانند پشم زده‌شده رنگين شود
  101,6,اما هر كه سنجيده‌هايش سنگين برآيد،
  101,7,پس وى در زندگى خوشى خواهد بود
  101,8,و اما هر كه سنجيده‌هايش سبك بر آيد،
  101,9,پس جايش «هاويه» باشد
  101,10,و تو چه دانى كه آن چيست؟
  101,11,آتشى است سوزنده