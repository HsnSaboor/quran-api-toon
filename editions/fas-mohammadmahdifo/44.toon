quran[59]{c,v,t}:
  44,1,حاء، ميم
  44,2,سوگند به كتاب روشنگر،
  44,3,"[كه‌] ما آن را در شبى فرخنده نازل كرديم، [زيرا] كه ما هشداردهنده بوديم"
  44,4,"در آن [شب‌] هر [گونه‌] كارى [به نحوى‌] استوار فيصله مى‌يابد"
  44,5,"[اين‌] كارى است [كه‌] از جانب ما [صورت مى‌گيرد]. ما فرستنده [پيامبران‌] بوديم"
  44,6,"[و اين‌] رحمتى از پروردگار توست، كه او شنواى داناست"
  44,7,پروردگار آسمانها و زمين و آنچه ميان آن دو است، اگر يقين داريد
  44,8,خدايى جز او نيست؛ او زندگى مى‌بخشد و مى‌ميراند؛ پروردگار شما و پروردگار پدران شماست
  44,9,ولى نه، آنها به شك و شبهه خويش سرگرمند
  44,10,پس در انتظار روزى باش كه آسمان دودى نمايان برمى‌آورد،
  44,11,كه مردم را فرو مى‌گيرد؛ اين است عذاب پر درد
  44,12,"[مى‌گويند:] «پروردگارا، اين عذاب را از ما دفع كن كه ما ايمان داريم.»"
  44,13,"آنان را كجا [جاى‌] پند[گرفتن‌] باشد، و حال آنكه به يقين براى آنان پيامبرى روشنگر آمده است"
  44,14,"پس، از او روى برتافتند و گفتند: «تعليم‌يافته‌اى ديوانه است.»"
  44,15,"ما اين عذاب را اندكى از شما برمى‌داريم [ولى شما] در حقيقت باز از سر مى‌گيريد"
  44,16,"روزى كه دست به حمله مى‌زنيم، همان حمله بزرگ؛ [آنگاه‌] ما انتقام‌كشنده‌ايم"
  44,17,و به يقين، پيش از آنان قوم فرعون را بيازموديم، و پيامبرى بزرگوار برايشان آمد،
  44,18,"كه [به آنان گفت:] «بندگان خدا را به من بسپاريد، زيرا كه من شما را فرستاده‌اى امينم"
  44,19,و بر خدا برترى مجوييد كه من براى شما حجتى آشكار آورده‌ام
  44,20,و من به پروردگار خود و پروردگار شما پناه مى‌برم از اينكه مرا سنگباران كنيد
  44,21,و اگر به من ايمان نمى‌آوريد، پس، از من كناره گيريد.»
  44,22,"پس پروردگار خود را خواند كه: «اينها مردمى گناهكارند.»"
  44,23,"[فرمود:] «بندگانم را شبانه ببر، زيرا شما مورد تعقيب واقع خواهيد شد"
  44,24,و دريا را هنگامى كه آرام است پشت سر بگذار، كه آنان سپاهى غرق‌شدنى‌اند.»
  44,25,"[وه،] چه باغها و چشمه‌سارانى [كه آنها بعد از خود] بر جاى نهادند،"
  44,26,و كشتزارها و جايگاه‌هاى نيكو،
  44,27,و نعمتى كه از آن برخوردار بودند
  44,28,"[آرى،] اين چنين [بود] و آنها را به مردمى ديگر ميراث داديم"
  44,29,و آسمان و زمين بر آنان زارى نكردند و مهلت نيافتند
  44,30,و به راستى، فرزندان اسرائيل را از عذاب خفت‌آور رهانيديم
  44,31,"از [دست‌] فرعون كه متكبّرى از افراطكاران بود"
  44,32,و قطعاً آنان را دانسته بر مردم جهان ترجيح داديم
  44,33,"و از نشانه‌ها [ى الهى‌] آنچه را كه در آن آزمايشى آشكار بود، بديشان داديم"
  44,34,"هر آينه اين [كافران‌] مى‌گويند"
  44,35,"«جز مرگ نخستين، ديگر [واقعه‌اى‌] نيست و ما زنده‌شدنى نيستيم"
  44,36,"اگر راست مى‌گوييد، پس پدران ما را [باز] آوريد"
  44,37,آيا ايشان بهترند يا قوم «تُبّع» و كسانى كه پيش از آنها بودند؟ آنها را هلاك كرديم، زيرا كه گنهكار بودند
  44,38,و آسمانها و زمين و آنچه را كه ميان آن دو است به بازى نيافريده‌ايم؛
  44,39,آنها را جز به حق نيافريده‌ايم، ليكن بيشترشان نمى‌دانند
  44,40,در حقيقت، روز «جدا سازى» موعد همه آنهاست
  44,41,همان روزى كه هيچ دوستى از هيچ دوستى نمى‌تواند حمايتى كند، و آنان يارى نمى‌شوند،
  44,42,مگر كسى را كه خدا رحمت كرده است، زيرا كه اوست همان ارجمند مهربان
  44,43,آرى! درخت زقوم،
  44,44,خوراك گناه پيشه است
  44,45,چون مس گداخته در شكمها مى‌گدازد؛
  44,46,همانند جوشش آب جوشان
  44,47,او را بگيريد و به ميان دوزخش بكشانيد،
  44,48,آنگاه از عذاب آب جوشان بر سرش فرو ريزيد
  44,49,بچش كه تو همان ارجمند بزرگوارى
  44,50,اين است همان چيزى كه در باره آن ترديد مى‌كرديد
  44,51,"به راستى پرهيزگاران در جايگاهى آسوده [اند]،"
  44,52,در بوستانها و كنار چشمه‌سارها
  44,53,"پرنيان نازك و ديباى ستبر مى‌پوشند [و] برابر هم نشسته‌اند"
  44,54,"[آرى،] چنين [خواهد بود] و آنها را با حوريان درشت‌چشم همسر مى‌گردانيم"
  44,55,"در آنجا هر ميوه‌اى را [كه بخواهند] آسوده خاطر مى‌طلبند"
  44,56,"در آنجا جز مرگ نخستين، مرگ نخواهند چشيد و [خدا] آنها را از عذاب دوزخ نگاه مى‌دارد"
  44,57,"[اين‌] بخششى است از جانب پروردگار تو. اين است همان كاميابى بزرگ"
  44,58,"در حقيقت، [قرآن‌] را بر زبان تو آسان گردانيديم، اميد كه پند پذيرند"
  44,59,پس مراقب باش، زيرا كه آنان هم مراقبند