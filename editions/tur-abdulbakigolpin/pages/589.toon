quran[27]{c,v,t}:
  83,35,Tahtlar üstünden bakarlar
  83,36,"Cezalandılar mı kafirler, yaptıklarına karşılık"
  84,1,Gök yarılıp çatlayınca
  84,2,Ve Rabbini dinleyip itaat ederek sözünü haklayınca
  84,3,"Ve yeryüzü, dümdüz çekilince"
  84,4,Ve içindekileri atıp boşalınca
  84,5,Ve Rabbini dinleyip itaat ederek sözünü haklayınca
  84,6,"Ey insan, şüphe yok ki sen, Rabbine ulaşmak için meşakkatler içinde didinirdurursun da sonunda ona kavuşursun"
  84,7,"Ama kimin kitabı, sağ yanından verilirse"
  84,8,"Artık onun hesabı, kolayca görülür"
  84,9,Ve ailesinin yanına sevinç içinde döner
  84,10,"Ve ama kimin kitabı, ardından verilirse"
  84,11,"O, helak olmasını diler"
  84,12,Ve cehenneme atılır
  84,13,"Şüphe yok ki o, ailesinin içinde sevinmedeydi"
  84,14,"Şüphe yok ki o, öldükten sonra tekrar hayata dönmeyeceğini sanırdı"
  84,15,"Evet, şüphe yok ki Rabbi, onu görürdü"
  84,16,Andolsun gün battıktan sonraki kızıllığa
  84,17,Ve geceye ve gecenin kapladıklarına
  84,18,"Ve aya, dolunay olunca"
  84,19,Elbette geçeceksiniz bir halden bir hale
  84,20,Artık ne oldu onlara da inanmıyorlar
  84,21,Ve onlara Kur'an okununca secde etmiyorlar
  84,22,"Hayır, kafir olanlar, yalanlıyorlar"
  84,23,"Ve Allah, daha iyi bilir, gönüllerinde ne var"
  84,24,Artık müjdele onları elemli bir azapla
  84,25,Ancak inananlar ve iyi işlerde bulunanlar başka; onlar içindir başa kakılmıyan mükafat