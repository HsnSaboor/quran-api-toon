quran[25]{c,v,t}:
  55,1,Rahman
  55,2,Kur'an'ı öğretti
  55,3,insanı halketti
  55,4,"ona dilleri, konuşmayı belletti"
  55,5,"Güneş ve ay, hesapla hareket eyler"
  55,6,Ve gövdesiz bitki ve gövdeli ağaç secde eder
  55,7,Ve göğü yüceltti ve ölçüyü koydu
  55,8,"Ölçüde, tartıda insafsızlık etmeyin"
  55,9,"Teraziyi doğru tutun, adaletle tartın ve eksik tartmayın"
  55,10,Yeryüzünü alçalttı halka
  55,11,"Orada meyveler ve lifli, kabuklu hurmalar var"
  55,12,Yapraklı taneler var ve güzel kokulu otlar
  55,13,Artık Rabbinizin nimetlerinden hangisini yalanlayabilirsiniz
  55,14,"İyice pişmiş gibi kupkuru balçıktan, insanı halketti"
  55,15,"Ve cinleri, coşup kaynayan ateşten yarattı"
  55,16,Artık Rabbinizin nimetlerinden hangisini yalanlıyabilirsiniz
  55,17,Rabbidir iki doğunun ve Rabbidir iki batının
  55,18,Artık Rabbinizin nimetlerinden hangisini yalanlayabilirsiniz
  55,19,"İki denizi salmıştır, nerdeyse karışacaklar"
  55,20,"Fakat aralarında bir berzah var, birbirlerine karışmazlar"
  55,21,Artık Rabbinizin nimetlerinden hangisini yalanlıyabilirsiniz
  55,22,Her ikisinden de inci ve mercan çıkar
  55,23,Artık Rabbinizin nimetlerinden hangisini yalanlayabilirsiniz
  55,24,Ve onundur denizde akıp giden dağlar gibi gemiler
  55,25,Artık Rabbinizin nimetlerinden hangisini yalanlayabilirsiniz