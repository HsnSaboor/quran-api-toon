quran[38]{c,v,t}:
  56,1,Ansızın kopacak kıyamet kopunca
  56,2,Kopacağına dair söylenen sözlerde yalan yok
  56,3,"Halkı alçaltır, yüceltir"
  56,4,Yeryüzü şiddetli bir sarsıntıyla sarsılınca
  56,5,"Ve dağlar, paramparça olunca"
  56,6,Dağılmış zerre zerre toz haline gelince
  56,7,Artık üç bölük olursunuz siz
  56,8,"Sağ taraf ehli, ama ne de sağ taraf ehli"
  56,9,"Ve sol taraf ehli, ama ne de sol taraf ehli"
  56,10,Ve bir de ileri geçenler ki herkesi geçmişlerdir
  56,11,Onlardır mabutlarına yaklaştırılanlar
  56,12,Naim cennetlerinde
  56,13,Öncekilerin birçoğu
  56,14,Sonra gelenlerdense azı onlardan
  56,15,"Altınlarla, mücevherlerle bezenmiş tahtlarda otururlar"
  56,16,"Onlara yaslanırlar, birbirlerine karşı"
  56,17,İhtiyarlamıyan delikanlı hizmetçiler dolaşır etraflarında
  56,18,Kaynağından doldurulmuş şaraplarla dolu taslarla ve ibriklerle ve kadehlerle
  56,19,O şaraptan başları da ağrımaz ve sarhoş da olmazlar
  56,20,Beğendikleri meyvelerden
  56,21,İstedikleri kuş etlerinden sunulur onlara
  56,22,Ve onlara kara gözlü huriler de var ki
  56,23,Sanki haznelerde saklanmış inciler
  56,24,Yaptıklarına karşılık
  56,25,"Orada boş ve çirkin bir söz de duymazlar, günaha ait bir söz de"
  56,26,"Ancak, esenlik size, esenlik denir"
  56,27,"Ve sağ taraf ehli, ama ne de sağ taraf ehli"
  56,28,Dikensiz sedir ağaçlarıyla
  56,29,Ve meyveleri birbirine yaslanıp istiflenmiş muz ağaçlarıyla dolu bir yerdedir onlar
  56,30,Ve uzayıp giden bir gölgelik
  56,31,Ve çağlayaçağlaya akan sular
  56,32,Ve birçok meyveler
  56,33,"Ne biter, zamanları geçer, ne yiyene yeme denir, yeter"
  56,34,ve yüksek döşekler
  56,35,"Şüphe yok ki biz, onların eşlerini de yeniden yarattık"
  56,36,"Onları, kız oğlan kız olarak halkettik"
  56,37,"Cilveli, şirin sözlü, eşlerine aşık ve onlarla yaşıt kıldık"
  56,38,Sağ taraf ehli için