quran[182]{c,v,t}:
  37,1,"وَٱلصَّـٰٓفَّـٰتِ صَفّٗا (وَالصَّافَّاتِ: قَسَمٌ بِالمَلَائِكَةِ حِينَ تَصُفُّ فيِ عِبَادَتِهَا)"
  37,2,"فَٱلزَّـٰجِرَٰتِ زَجۡرٗا (فَالزَّاجِرَاتِ: قَسَمٌ بِالمَلَائِكَةِ حِينَ تَزْجُرُ السَّحَابَ، وَتَسُوقُهُ)"
  37,3,"فَٱلتَّـٰلِيَٰتِ ذِكۡرًا (فَالتَّالِيَاتِ: قَسَمٌ بِالمَلَائِكَةِ حِينَ تَتْلُو ذِكْرَ اللهِ، وَكَلَامَهُ)"
  37,4,إِنَّ إِلَٰهَكُمۡ لَوَٰحِدٞ
  37,5,رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ وَمَا بَيۡنَهُمَا وَرَبُّ ٱلۡمَشَٰرِقِ
  37,6,إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنۡيَا بِزِينَةٍ ٱلۡكَوَاكِبِ
  37,7,"وَحِفۡظٗا مِّن كُلِّ شَيۡطَٰنٖ مَّارِدٖ (مَّارِدٍ: جِنِّيًّ مُتَمَرِّدٍ، خَارجٍ عَنِ الطَّاعَةِ)"
  37,8,"لَّا يَسَّمَّعُونَ إِلَى ٱلۡمَلَإِ ٱلۡأَعۡلَىٰ وَيُقۡذَفُونَ مِن كُلِّ جَانِبٖ (وَيُقْذَفُونَ: يُرْجَمُونَ)"
  37,9,"دُحُورٗاۖ وَلَهُمۡ عَذَابٞ وَاصِبٌ (دُحُورًا: طَرْدًا لِلشَّيَاطِينِ عَنِ الاِسْتِمَاعِ, وَاصِبٌ: دَائِمٌ مُوجِعٌ)"
  37,10,"إِلَّا مَنۡ خَطِفَ ٱلۡخَطۡفَةَ فَأَتۡبَعَهُۥ شِهَابٞ ثَاقِبٞ (خَطِفَ الْخَطْفَةَ: اخْتَلَسَ الكَلِمَةَ؛ مُسَارَقَةً بِسُرْعَةٍ, شِهَابٌ: مَا يُرَى كَالكَوْكَبِ يَنْقَضُّ مِنَ السَّمَاءِ بِسُرْعَةٍ, ثَاقِبٌ: مُضِيءٌ)"
  37,11,"فَٱسۡتَفۡتِهِمۡ أَهُمۡ أَشَدُّ خَلۡقًا أَم مَّنۡ خَلَقۡنَآۚ إِنَّا خَلَقۡنَٰهُم مِّن طِينٖ لَّازِبِۭ (خَلَقْنَاهُم: خَلَقْنَا أَبَاهُمْ آدَمَ - عليه السلام -, لَّازِبٍ: لَزِجٍ يَلْتَصِقُ بَعْضُهُ بِبَعْضٍ)"
  37,12,بَلۡ عَجِبۡتَ وَيَسۡخَرُونَ
  37,13,وَإِذَا ذُكِّرُواْ لَا يَذۡكُرُونَ
  37,14,وَإِذَا رَأَوۡاْ ءَايَةٗ يَسۡتَسۡخِرُونَ
  37,15,وَقَالُوٓاْ إِنۡ هَٰذَآ إِلَّا سِحۡرٞ مُّبِينٌ
  37,16,أَءِذَا مِتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَءِنَّا لَمَبۡعُوثُونَ
  37,17,أَوَءَابَآؤُنَا ٱلۡأَوَّلُونَ
  37,18,"قُلۡ نَعَمۡ وَأَنتُمۡ دَٰخِرُونَ (دَاخِرُونَ: صَاغِرُونَ، أَذِلَّاءُ)"
  37,19,"فَإِنَّمَا هِيَ زَجۡرَةٞ وَٰحِدَةٞ فَإِذَا هُمۡ يَنظُرُونَ (زَجْرَةٌ: نَفْخَةٌ)"
  37,20,وَقَالُواْ يَٰوَيۡلَنَا هَٰذَا يَوۡمُ ٱلدِّينِ
  37,21,هَٰذَا يَوۡمُ ٱلۡفَصۡلِ ٱلَّذِي كُنتُم بِهِۦ تُكَذِّبُونَ
  37,22,"۞ٱحۡشُرُواْ ٱلَّذِينَ ظَلَمُواْ وَأَزۡوَٰجَهُمۡ وَمَا كَانُواْ يَعۡبُدُونَ (احْشُرُوا: اجْمَعُوا, وَأَزْوَاجَهُمْ: نُظَرَاءَهُمْ، وَقُرَنَاءَهُمْ فيِ الدُّنْيَا)"
  37,23,"مِن دُونِ ٱللَّهِ فَٱهۡدُوهُمۡ إِلَىٰ صِرَٰطِ ٱلۡجَحِيمِ (فَاهْدُوهُمْ: سُوقُوهُمْ سَوْقًا عَنِيفًا)"
  37,24,"وَقِفُوهُمۡۖ إِنَّهُم مَّسۡـُٔولُونَ (وَقِفُوهُمْ: احْبِسُوهُمْ قَبْلَ أَنْ يَصِلُوا إِلَى جَهَنَّمَ)"
  37,25,مَا لَكُمۡ لَا تَنَاصَرُونَ
  37,26,بَلۡ هُمُ ٱلۡيَوۡمَ مُسۡتَسۡلِمُونَ
  37,27,وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ
  37,28,"قَالُوٓاْ إِنَّكُمۡ كُنتُمۡ تَأۡتُونَنَا عَنِ ٱلۡيَمِينِ (عَنِ الْيَمِينِ: مِنْ قِبَلِ الحَقِّ وَالدِّينِ)"
  37,29,قَالُواْ بَل لَّمۡ تَكُونُواْ مُؤۡمِنِينَ
  37,30,"وَمَا كَانَ لَنَا عَلَيۡكُم مِّن سُلۡطَٰنِۭۖ بَلۡ كُنتُمۡ قَوۡمٗا طَٰغِينَ (سُلْطَانٍ: حُجَّةٍ، أَوْ قُوَّةٍ, طَاغِينَ: مُجَاوِزِينَ الحَدَّ فيِ العِصْيَانِ)"
  37,31,"فَحَقَّ عَلَيۡنَا قَوۡلُ رَبِّنَآۖ إِنَّا لَذَآئِقُونَ (فَحَقَّ عَلَيْنَا: وَجَبَ عَلَيْنَا)"
  37,32,فَأَغۡوَيۡنَٰكُمۡ إِنَّا كُنَّا غَٰوِينَ
  37,33,فَإِنَّهُمۡ يَوۡمَئِذٖ فِي ٱلۡعَذَابِ مُشۡتَرِكُونَ
  37,34,إِنَّا كَذَٰلِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِينَ
  37,35,إِنَّهُمۡ كَانُوٓاْ إِذَا قِيلَ لَهُمۡ لَآ إِلَٰهَ إِلَّا ٱللَّهُ يَسۡتَكۡبِرُونَ
  37,36,وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓاْ ءَالِهَتِنَا لِشَاعِرٖ مَّجۡنُونِۭ
  37,37,بَلۡ جَآءَ بِٱلۡحَقِّ وَصَدَّقَ ٱلۡمُرۡسَلِينَ
  37,38,إِنَّكُمۡ لَذَآئِقُواْ ٱلۡعَذَابِ ٱلۡأَلِيمِ
  37,39,وَمَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ
  37,40,"إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ (الْمُخْلَصِينَ: الَّذِينَ أَخْلَصُوا فِي عِبَادَةِ اللهِ؛ فَأَخْلَصَهُمْ، وَاخْتَصَّهُمْ بِرَحْمَتِهِ)"
  37,41,أُوْلَـٰٓئِكَ لَهُمۡ رِزۡقٞ مَّعۡلُومٞ
  37,42,فَوَٰكِهُ وَهُم مُّكۡرَمُونَ
  37,43,فِي جَنَّـٰتِ ٱلنَّعِيمِ
  37,44,عَلَىٰ سُرُرٖ مُّتَقَٰبِلِينَ
  37,45,"يُطَافُ عَلَيۡهِم بِكَأۡسٖ مِّن مَّعِينِۭ (بِكَاسٍ: بِخَمْرٍ, مِن مَّعِينٍ: مِنْ أَنْهَارٍ جَارِيَةٍ لَا يَخَافُونَ انْقِطَاعَهَا)"
  37,46,بَيۡضَآءَ لَذَّةٖ لِّلشَّـٰرِبِينَ
  37,47,"لَا فِيهَا غَوۡلٞ وَلَا هُمۡ عَنۡهَا يُنزَفُونَ (لَا فِيهَا غَوْلٌ: لَيْسَ فِيهَا مَا يَغْتَالُ عُقُولَهُمْ, وَلَا هُمْ عَنْهَا يُنزَفُونَ: لَا يَسْكَرُونَ، وَلَا تَضُرُّ أَبْدَانَهُمْ)"
  37,48,"وَعِندَهُمۡ قَٰصِرَٰتُ ٱلطَّرۡفِ عِينٞ (قَاصِرَاتُ الطَّرْفِ: عَفِيفاتٌ لَا يَنْظُرْنَ إِلَى غَيْرِ أَزْوَاجِهِنَّ, عِينٌ: حِسَانُ الأَعْيُنِ)"
  37,49,"كَأَنَّهُنَّ بَيۡضٞ مَّكۡنُونٞ (مَّكْنُونٌ: لَمْ تَمَسَّهُ الأَيْدِي)"
  37,50,فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ
  37,51,"قَالَ قَآئِلٞ مِّنۡهُمۡ إِنِّي كَانَ لِي قَرِينٞ (قَرِينٌ: صَاحِبٌ مُلَازِمٌ لِي)"
  37,52,يَقُولُ أَءِنَّكَ لَمِنَ ٱلۡمُصَدِّقِينَ
  37,53,"أَءِذَا مِتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَءِنَّا لَمَدِينُونَ (لَمَدِينُونَ: لَمَجْزِيُّونَ، وَمُحَاسَبُونَ)"
  37,54,قَالَ هَلۡ أَنتُم مُّطَّلِعُونَ
  37,55,فَٱطَّلَعَ فَرَءَاهُ فِي سَوَآءِ ٱلۡجَحِيمِ
  37,56,"قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرۡدِينِ (إِنْ كِدتَّ: إِنَّكَ قَارَبْتَ, لَتُرْدِينِ: لَتُهْلِكُنِي بِضَلَالِكَ، وَإِغْوَائِكَ)"
  37,57,"وَلَوۡلَا نِعۡمَةُ رَبِّي لَكُنتُ مِنَ ٱلۡمُحۡضَرِينَ (الْمُحْضَرِينَ: مَنْ أُحْضِرُوا فِي العَذَابِ مَعَكَ)"
  37,58,أَفَمَا نَحۡنُ بِمَيِّتِينَ
  37,59,إِلَّا مَوۡتَتَنَا ٱلۡأُولَىٰ وَمَا نَحۡنُ بِمُعَذَّبِينَ
  37,60,إِنَّ هَٰذَا لَهُوَ ٱلۡفَوۡزُ ٱلۡعَظِيمُ
  37,61,لِمِثۡلِ هَٰذَا فَلۡيَعۡمَلِ ٱلۡعَٰمِلُونَ
  37,62,"أَذَٰلِكَ خَيۡرٞ نُّزُلًا أَمۡ شَجَرَةُ ٱلزَّقُّومِ (نُّزُلًا: ضِيَافَةً, شَجَرَةُ الزَّقُّومِ: شَجَرَةٌ خَبِيثَةٌ، مَلْعُونَةٌ، مِنْ طَعَامِ أَهْلِ النَّارِ)"
  37,63,"إِنَّا جَعَلۡنَٰهَا فِتۡنَةٗ لِّلظَّـٰلِمِينَ (فِتْنَةً: ابْتِلَاءً لَهُمْ؛ حَيْثُ كَذَّبُوا بِوُجُودِ شَجَرَةٍ فيِ النَّارِ)"
  37,64,"إِنَّهَا شَجَرَةٞ تَخۡرُجُ فِيٓ أَصۡلِ ٱلۡجَحِيمِ (أَصْلِ الْجَحِيمِ: قَعْرِ جَهَنَّمَ)"
  37,65,"طَلۡعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّيَٰطِينِ (طَلْعُهَا: ثَمَرُهَا)"
  37,66,فَإِنَّهُمۡ لَأٓكِلُونَ مِنۡهَا فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ
  37,67,"ثُمَّ إِنَّ لَهُمۡ عَلَيۡهَا لَشَوۡبٗا مِّنۡ حَمِيمٖ (لَشَوْبًا: لَخَلْطًا، وَمِزَاجًا, حَمِيمٍ: مِنْ مَاءٍ حَارٍّ بَالِغِ الحَرَارَةِ)"
  37,68,ثُمَّ إِنَّ مَرۡجِعَهُمۡ لَإِلَى ٱلۡجَحِيمِ
  37,69,"إِنَّهُمۡ أَلۡفَوۡاْ ءَابَآءَهُمۡ ضَآلِّينَ (أَلْفَوْا: وَجَدُوا)"
  37,70,"فَهُمۡ عَلَىٰٓ ءَاثَٰرِهِمۡ يُهۡرَعُونَ (يُهْرَعُونَ: يُسْرِعُونَ فِي مُتَابَعَتِهِمْ عَلَى الضَّلَالِ)"
  37,71,وَلَقَدۡ ضَلَّ قَبۡلَهُمۡ أَكۡثَرُ ٱلۡأَوَّلِينَ
  37,72,وَلَقَدۡ أَرۡسَلۡنَا فِيهِم مُّنذِرِينَ
  37,73,فَٱنظُرۡ كَيۡفَ كَانَ عَٰقِبَةُ ٱلۡمُنذَرِينَ
  37,74,إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ
  37,75,وَلَقَدۡ نَادَىٰنَا نُوحٞ فَلَنِعۡمَ ٱلۡمُجِيبُونَ
  37,76,وَنَجَّيۡنَٰهُ وَأَهۡلَهُۥ مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ
  37,77,وَجَعَلۡنَا ذُرِّيَّتَهُۥ هُمُ ٱلۡبَاقِينَ
  37,78,"وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ (وَتَرَكْنَا عَلَيْهِ: أَبْقَيْنَا لَهُ ذِكْرًا جَمِيلًا, فِي الْآخِرِينَ: فِيمَنْ جَاءَ بَعْدَهُ مِنَ النَّاسِ)"
  37,79,سَلَٰمٌ عَلَىٰ نُوحٖ فِي ٱلۡعَٰلَمِينَ
  37,80,إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,81,إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ
  37,82,ثُمَّ أَغۡرَقۡنَا ٱلۡأٓخَرِينَ
  37,83,"۞وَإِنَّ مِن شِيعَتِهِۦ لَإِبۡرَٰهِيمَ (شِيعَتِهِ: مَنْ تَابَعَهُ عَلَى دِينِهِ، وَمِنْهَاجِهِ)"
  37,84,"إِذۡ جَآءَ رَبَّهُۥ بِقَلۡبٖ سَلِيمٍ (سَلِيمٍ: بَرِيءٍ مِنْ كُلِّ اعْتِقَادٍ بَاطِلٍ، وَخُلُقٍ ذَمِيمٍ)"
  37,85,إِذۡ قَالَ لِأَبِيهِ وَقَوۡمِهِۦ مَاذَا تَعۡبُدُونَ
  37,86,"أَئِفۡكًا ءَالِهَةٗ دُونَ ٱللَّهِ تُرِيدُونَ (أَئِفْكًا آلِهَةً: أَتُرِيدُونَ آلِهَةً مُخْتَلَقَةً تَعْبُدُونَهَا؟)"
  37,87,فَمَا ظَنُّكُم بِرَبِّ ٱلۡعَٰلَمِينَ
  37,88,"فَنَظَرَ نَظۡرَةٗ فِي ٱلنُّجُومِ (فَنَظَرَ: رَفَعَ بَصَرَهُ إِلَى النُّجُومِ مَتَفَكِّرًا فِيمَا يَعْتَذِرُ بِهِ مِنَ الخُرُوجِ مَعَهُمْ)"
  37,89,"فَقَالَ إِنِّي سَقِيمٞ (سَقِيمٌ: مَرِيضٌ؛ وَهَذَا تَعْرِيضٌ مِنْهُ؛ أَرَادَ: أَنِّي لَا أَخْلُو مِنْ سَقَمٍ كَعَادَةِ النَّاسِ أَوْ أَنِّي ضَعِيفٌ، أَوْ سَقِيمُ القَلْبِ مِنْ عِبَادَتِكُمْ غَيْرَ اللهِ)"
  37,90,فَتَوَلَّوۡاْ عَنۡهُ مُدۡبِرِينَ
  37,91,"فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمۡ فَقَالَ أَلَا تَأۡكُلُونَ (فَرَاغَ إِلَى آلِهَتِهِمْ: مَالَ بِخُفْيَةٍ مُسْرِعًا إِلَى الأَصْنَامِ)"
  37,92,مَا لَكُمۡ لَا تَنطِقُونَ
  37,93,"فَرَاغَ عَلَيۡهِمۡ ضَرۡبَۢا بِٱلۡيَمِينِ (بِالْيَمِينِ: بِيَدِهِ اليُمْنَى)"
  37,94,"فَأَقۡبَلُوٓاْ إِلَيۡهِ يَزِفُّونَ (يَزِفُّونَ: يَعْدُونَ مُسْرِعِينَ غَاضِبِينَ)"
  37,95,قَالَ أَتَعۡبُدُونَ مَا تَنۡحِتُونَ
  37,96,وَٱللَّهُ خَلَقَكُمۡ وَمَا تَعۡمَلُونَ
  37,97,قَالُواْ ٱبۡنُواْ لَهُۥ بُنۡيَٰنٗا فَأَلۡقُوهُ فِي ٱلۡجَحِيمِ
  37,98,فَأَرَادُواْ بِهِۦ كَيۡدٗا فَجَعَلۡنَٰهُمُ ٱلۡأَسۡفَلِينَ
  37,99,وَقَالَ إِنِّي ذَاهِبٌ إِلَىٰ رَبِّي سَيَهۡدِينِ
  37,100,رَبِّ هَبۡ لِي مِنَ ٱلصَّـٰلِحِينَ
  37,101,"فَبَشَّرۡنَٰهُ بِغُلَٰمٍ حَلِيمٖ (بِغُلَامٍ حَلِيمٍ: هُوَ: إِسْمَاعِيلُ - عليه السلام)"
  37,102,"فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعۡيَ قَالَ يَٰبُنَيَّ إِنِّيٓ أَرَىٰ فِي ٱلۡمَنَامِ أَنِّيٓ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ قَالَ يَـٰٓأَبَتِ ٱفۡعَلۡ مَا تُؤۡمَرُۖ سَتَجِدُنِيٓ إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّـٰبِرِينَ (بَلَغَ مَعَهُ السَّعْيَ: وَصَلَ دَرَجَةَ العَمَلِ مَعَهُ، وَقَضَاءِ حَوَائِجِهِ)"
  37,103,"فَلَمَّآ أَسۡلَمَا وَتَلَّهُۥ لِلۡجَبِينِ (أَسْلَمَا: اسْتَسْلَمَا لِأَمْرِ اللهِ, وَتَلَّهُ لِلْجَبِينِ: أَلْقَاهُ عَلَى جَانِبِ جَبْهَتِهِ عَلَى الأَرْضِ)"
  37,104,وَنَٰدَيۡنَٰهُ أَن يَـٰٓإِبۡرَٰهِيمُ
  37,105,قَدۡ صَدَّقۡتَ ٱلرُّءۡيَآۚ إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,106,"إِنَّ هَٰذَا لَهُوَ ٱلۡبَلَـٰٓؤُاْ ٱلۡمُبِينُ (الْبَلَاءُ الْمُبِينُ: الاِخْتِبَارُ الشَّاقُّ الَّذِي أَبَانَ عَنْ صِدْقِ إِيمَانِهِ)"
  37,107,"وَفَدَيۡنَٰهُ بِذِبۡحٍ عَظِيمٖ (وَفَدَيْنَاهُ: جَعَلْنَا بَدِيلًا عَنْهُ, بِذِبْحٍ: بِكَبْشٍ)"
  37,108,"وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ (وَتَرَكْنَا عَلَيْهِ فِي الْآخِرِينَ: أَبْقَيْنَا لَهُ ذِكْرًا حَسَنًا فِيمَنْ جَاءَ بَعْدَهُ)"
  37,109,سَلَٰمٌ عَلَىٰٓ إِبۡرَٰهِيمَ
  37,110,كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,111,إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ
  37,112,وَبَشَّرۡنَٰهُ بِإِسۡحَٰقَ نَبِيّٗا مِّنَ ٱلصَّـٰلِحِينَ
  37,113,وَبَٰرَكۡنَا عَلَيۡهِ وَعَلَىٰٓ إِسۡحَٰقَۚ وَمِن ذُرِّيَّتِهِمَا مُحۡسِنٞ وَظَالِمٞ لِّنَفۡسِهِۦ مُبِينٞ
  37,114,وَلَقَدۡ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَٰرُونَ
  37,115,"وَنَجَّيۡنَٰهُمَا وَقَوۡمَهُمَا مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ (الْكَرْبِ الْعَظِيمِ: الغَرَقِ فِي البَحْرِ، وَالعُبُودِيَّةِ لِفِرْعَوْنَ)"
  37,116,وَنَصَرۡنَٰهُمۡ فَكَانُواْ هُمُ ٱلۡغَٰلِبِينَ
  37,117,وَءَاتَيۡنَٰهُمَا ٱلۡكِتَٰبَ ٱلۡمُسۡتَبِينَ
  37,118,وَهَدَيۡنَٰهُمَا ٱلصِّرَٰطَ ٱلۡمُسۡتَقِيمَ
  37,119,وَتَرَكۡنَا عَلَيۡهِمَا فِي ٱلۡأٓخِرِينَ
  37,120,سَلَٰمٌ عَلَىٰ مُوسَىٰ وَهَٰرُونَ
  37,121,إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,122,إِنَّهُمَا مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ
  37,123,وَإِنَّ إِلۡيَاسَ لَمِنَ ٱلۡمُرۡسَلِينَ
  37,124,إِذۡ قَالَ لِقَوۡمِهِۦٓ أَلَا تَتَّقُونَ
  37,125,"أَتَدۡعُونَ بَعۡلٗا وَتَذَرُونَ أَحۡسَنَ ٱلۡخَٰلِقِينَ (أَتَدْعُونَ بَعْلًا: أَتَعْبُدُونَ الصَّنَمَ المُسَمَّى: «بَعْلًا»)"
  37,126,ٱللَّهَ رَبَّكُمۡ وَرَبَّ ءَابَآئِكُمُ ٱلۡأَوَّلِينَ
  37,127,"فَكَذَّبُوهُ فَإِنَّهُمۡ لَمُحۡضَرُونَ (لَمُحْضَرُونَ: لَمَجْمُوعُونَ لِلْحِسَابِ، وَالعِقَابِ)"
  37,128,إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ
  37,129,وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ
  37,130,"سَلَٰمٌ عَلَىٰٓ إِلۡ يَاسِينَ (إِلْ يَاسِينَ: هُوَ: إِلْيَاسُ نَفْسُهُ، أَوْ: هُوَ وَأَتْبَاعُهُ)"
  37,131,إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,132,إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ
  37,133,وَإِنَّ لُوطٗا لَّمِنَ ٱلۡمُرۡسَلِينَ
  37,134,إِذۡ نَجَّيۡنَٰهُ وَأَهۡلَهُۥٓ أَجۡمَعِينَ
  37,135,"إِلَّا عَجُوزٗا فِي ٱلۡغَٰبِرِينَ (الْغَابِرِينَ: البَاِقينَ فِي العَذَابِ)"
  37,136,ثُمَّ دَمَّرۡنَا ٱلۡأٓخَرِينَ
  37,137,وَإِنَّكُمۡ لَتَمُرُّونَ عَلَيۡهِم مُّصۡبِحِينَ
  37,138,وَبِٱلَّيۡلِۚ أَفَلَا تَعۡقِلُونَ
  37,139,وَإِنَّ يُونُسَ لَمِنَ ٱلۡمُرۡسَلِينَ
  37,140,"إِذۡ أَبَقَ إِلَى ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ (أَبَقَ: هَرَبَ مِنْ بَلَدِهِ مِنْ غَيْرِ إِذْنِ رَبِّهِ, الْفُلْكِ: السَّفِينَةِ, الْمَشْحُونِ: المَمْلُوءِ أَمْتِعَةً، وَرُكَّابًا)"
  37,141,"فَسَاهَمَ فَكَانَ مِنَ ٱلۡمُدۡحَضِينَ (فَسَاهَمَ: اقْتَرَعَ رُكَّابُ السَّفِينَةِ؛ لِتَخْفِيفِ الحُمُولَةِ خَوْفَ الغَرَقِ, الْمُدْحَضِينَ: المَغْلُوبِينَ بِالقُرْعَةِ)"
  37,142,"فَٱلۡتَقَمَهُ ٱلۡحُوتُ وَهُوَ مُلِيمٞ (فَالْتَقَمَهُ: ابْتَلَعَهُ, مُلِيمٌ: آتٍ بِمَا يُلَامُ عَلَيْهِ)"
  37,143,"فَلَوۡلَآ أَنَّهُۥ كَانَ مِنَ ٱلۡمُسَبِّحِينَ (الْمُسَبِّحِينَ: العَابِدِينَ الذَّاكِرِينَ، الَّذِينَ يَقُولُ أَحَدُهُم - إِذَا وَقَعَ فِي كُرْبَةٍ -: {لَّا إِلَهَ إِلَّا أَنتَ سُبْحَانَكَ إِنِّي كُنتُ مِنَ الظَّالِمِينَ} [الأنبياء]"
  37,144,لَلَبِثَ فِي بَطۡنِهِۦٓ إِلَىٰ يَوۡمِ يُبۡعَثُونَ
  37,145,"۞فَنَبَذۡنَٰهُ بِٱلۡعَرَآءِ وَهُوَ سَقِيمٞ (فَنَبَذْنَاهُ: فَطَرَحْنَاهُ مِنْ بَطْنِ الحُوتِ, بِالْعَرَاءِ: بِالأَرْضِ الخَالِيَةِ مِنَ الشَّجَرِ وَالبِنَاءِ, سَقِيمٌ: ضَعِيفُ البَدَنِ)"
  37,146,"وَأَنۢبَتۡنَا عَلَيۡهِ شَجَرَةٗ مِّن يَقۡطِينٖ (يَقْطِينٍ: قَرْعٍ)"
  37,147,"وَأَرۡسَلۡنَٰهُ إِلَىٰ مِاْئَةِ أَلۡفٍ أَوۡ يَزِيدُونَ (أَوْ يَزِيدُونَ: بَلْ يَزِيدُونَ)"
  37,148,"فَـَٔامَنُواْ فَمَتَّعۡنَٰهُمۡ إِلَىٰ حِينٖ (فَمَتَّعْنَاهُمْ إِلَى حِينٍ: أَبْقَيْنَاهُمْ أَحْيَاءً مُتَمَتِّعِينَ إِلَى بُلُوغِ آجَالِهِمْ)"
  37,149,فَٱسۡتَفۡتِهِمۡ أَلِرَبِّكَ ٱلۡبَنَاتُ وَلَهُمُ ٱلۡبَنُونَ
  37,150,أَمۡ خَلَقۡنَا ٱلۡمَلَـٰٓئِكَةَ إِنَٰثٗا وَهُمۡ شَٰهِدُونَ
  37,151,"أَلَآ إِنَّهُم مِّنۡ إِفۡكِهِمۡ لَيَقُولُونَ (إِفْكِهِمْ: كَذِبِهِمْ)"
  37,152,وَلَدَ ٱللَّهُ وَإِنَّهُمۡ لَكَٰذِبُونَ
  37,153,"أَصۡطَفَى ٱلۡبَنَاتِ عَلَى ٱلۡبَنِينَ (أَصْطَفَى: أَيَخْتَارُ؟)"
  37,154,"مَا لَكُمۡ كَيۡفَ تَحۡكُمُونَ (مَا لَكُمْ كَيْفَ تَحْكُمُونَ: بِئْسَ الحُكْمُ مَا تَحْكُمُونَهُ)"
  37,155,أَفَلَا تَذَكَّرُونَ
  37,156,"أَمۡ لَكُمۡ سُلۡطَٰنٞ مُّبِينٞ (سُلْطَانٌ: حُجَّةٌ)"
  37,157,فَأۡتُواْ بِكِتَٰبِكُمۡ إِن كُنتُمۡ صَٰدِقِينَ
  37,158,"وَجَعَلُواْ بَيۡنَهُۥ وَبَيۡنَ ٱلۡجِنَّةِ نَسَبٗاۚ وَلَقَدۡ عَلِمَتِ ٱلۡجِنَّةُ إِنَّهُمۡ لَمُحۡضَرُونَ (الْجِنَّةِ: المَلَائِكَةِ، سُمُّوا بِذَلِكَ؛ لِاجْتِنَانِهِمْ عَنِ الأَبْصَارِ, نَسَبًا: قَرَابَةً, لَمُحْضَرُونَ: إِنَّ الكُفَّارَ سَيُحْضَرُونَ لِلْعَذَابِ يَوْمَ القِيَامَةِ)"
  37,159,"سُبۡحَٰنَ ٱللَّهِ عَمَّا يَصِفُونَ (سُبْحَانَ اللَّهِ: تَنْزِيهًا للهِ)"
  37,160,إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ
  37,161,فَإِنَّكُمۡ وَمَا تَعۡبُدُونَ
  37,162,"مَآ أَنتُمۡ عَلَيۡهِ بِفَٰتِنِينَ (بِفَاتِنِينَ: بِمُضِلِّينَ أَحدًا)"
  37,163,"إِلَّا مَنۡ هُوَ صَالِ ٱلۡجَحِيمِ (صَالِ الْجَحِيمِ: مَنْ يَصْلَى الجَحِيمَ بِدُخُولِهَا وَمُقَاسَاةِ حَرِّهَا)"
  37,164,وَمَامِنَّآ إِلَّا لَهُۥ مَقَامٞ مَّعۡلُومٞ
  37,165,"وَإِنَّا لَنَحۡنُ ٱلصَّآفُّونَ (الصَّافُّونَ: الوَاقِفُونَ صُفُوفًا فِي عِبَادَةِ اللهِ)"
  37,166,"وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ (الْمُسَبِّحُونَ: المُنَزِّهُونَ اللهَ عَنْ كُلِّ مَا لَا يَلِيقُ بِه)"
  37,167,وَإِن كَانُواْ لَيَقُولُونَ
  37,168,"لَوۡ أَنَّ عِندَنَا ذِكۡرٗا مِّنَ ٱلۡأَوَّلِينَ (ذِكْرًا مِّنْ الْأَوَّلِينَ: كِتَابًا مِنْ كُتُبِ الأَنْبِيَاءِ السَّابِقِينَ)"
  37,169,لَكُنَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ
  37,170,فَكَفَرُواْ بِهِۦۖ فَسَوۡفَ يَعۡلَمُونَ
  37,171,وَلَقَدۡ سَبَقَتۡ كَلِمَتُنَا لِعِبَادِنَا ٱلۡمُرۡسَلِينَ
  37,172,إِنَّهُمۡ لَهُمُ ٱلۡمَنصُورُونَ
  37,173,وَإِنَّ جُندَنَا لَهُمُ ٱلۡغَٰلِبُونَ
  37,174,"فَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِينٖ (فَتَوَلَّ عَنْهُمْ: أَعْرِضْ عَمَّنْ عَانَدَ)"
  37,175,وَأَبۡصِرۡهُمۡ فَسَوۡفَ يُبۡصِرُونَ
  37,176,أَفَبِعَذَابِنَا يَسۡتَعۡجِلُونَ
  37,177,"فَإِذَا نَزَلَ بِسَاحَتِهِمۡ فَسَآءَ صَبَاحُ ٱلۡمُنذَرِينَ (بِسَاحَتِهِمْ: بِفِنَائِهِمْ, فَسَاءَ: بِئْسِ)"
  37,178,وَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِينٖ
  37,179,وَأَبۡصِرۡ فَسَوۡفَ يُبۡصِرُونَ
  37,180,سُبۡحَٰنَ رَبِّكَ رَبِّ ٱلۡعِزَّةِ عَمَّا يَصِفُونَ
  37,181,وَسَلَٰمٌ عَلَى ٱلۡمُرۡسَلِينَ
  37,182,وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَٰلَمِينَ