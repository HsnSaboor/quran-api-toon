quran[23]{c,v,t}:
  51,1,"وَٱلذَّـٰرِيَٰتِ ذَرۡوٗا (وَالذَّارِيَاتِ: قَسَمٌ بِالرِّيَاحِ، المُثِيرَاتِ لِلتُّرَابِ)"
  51,2,"فَٱلۡحَٰمِلَٰتِ وِقۡرٗا (فَالْحَامِلَاتِ وِقْرًا: فَالسُّحُبِ الحَامِلَاتِ ثِقَلًا عَظِيمًا مِنَ المَاءِ)"
  51,3,"فَٱلۡجَٰرِيَٰتِ يُسۡرٗا (فَالْجَارِيَاتِ يُسْرًا: فَالسُّفُنِ الَّتِي تَجْرِي فِي البِحَارِ بِيُسْرٍ)"
  51,4,"فَٱلۡمُقَسِّمَٰتِ أَمۡرًا (فَالْمُقَسِّمَاتِ أَمْرًا: فَالمَلَائِكَةِ الَّتِي تُقَسِّمُ أَمْرَ اللهِ فِي خَلْقِهِ)"
  51,5,إِنَّمَا تُوعَدُونَ لَصَادِقٞ
  51,6,"وَإِنَّ ٱلدِّينَ لَوَٰقِعٞ (الدِّينَ: الحِسَابَ، وَالجَزَاءَ)"
  51,7,"وَٱلسَّمَآءِ ذَاتِ ٱلۡحُبُكِ (ذَاتِ الْحُبُكِ: ذَاتِ الخَلْقِ الحَسَنِ، وَذَاتِ الطُّرُقِ الَّتِي تَسِيُر فِيهَا الكَوَاكِبُ)"
  51,8,"إِنَّكُمۡ لَفِي قَوۡلٖ مُّخۡتَلِفٖ (قَوْلٍ مُّخْتَلِفٍ: مُتَنَاقِضٍ، مُضْطَرِبٍ فِي القُرْآنِ وَالرَّسُولِ - صلى الله عليه وسلم)"
  51,9,"يُؤۡفَكُ عَنۡهُ مَنۡ أُفِكَ (يُؤْفَكُ عَنْهُ: يُصْرَفُ عَنِ القُرْآنِ وَالرَّسُولِ - صلى الله عليه وسلم)"
  51,10,"قُتِلَ ٱلۡخَرَّـٰصُونَ (قُتِلَ الْخَرَّاصُونَ: قُتِلَ، وَلُعِنَ الكَذَّابُونَ، الظَّانُّونَ غَيْرَ الحَقِّ)"
  51,11,"ٱلَّذِينَ هُمۡ فِي غَمۡرَةٖ سَاهُونَ (غَمْرَةٍ: جَهْلٍ يَغْمُرُهُمْ, سَاهُونَ: غَافِلُونَ عَنْ أَمْرِ الآخِرَةِ)"
  51,12,"يَسۡـَٔلُونَ أَيَّانَ يَوۡمُ ٱلدِّينِ (يَسْأَلُونَ: سُؤَالَ اسْتِبْعَادٍ وَإِنْكَارٍ, أَيَّانَ يَوْمُ الدِّينِ: مَتَى يَوْمُ الجَزَاءِ؟)"
  51,13,"يَوۡمَ هُمۡ عَلَى ٱلنَّارِ يُفۡتَنُونَ (يُفْتَنُونَ: يُحْرَقُونَ، وَيُعَذَّبُونَ)"
  51,14,"ذُوقُواْ فِتۡنَتَكُمۡ هَٰذَا ٱلَّذِي كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ (فِتْنَتَكُمْ: عَذَابَكُمْ)"
  51,15,إِنَّ ٱلۡمُتَّقِينَ فِي جَنَّـٰتٖ وَعُيُونٍ
  51,16,ءَاخِذِينَ مَآ ءَاتَىٰهُمۡ رَبُّهُمۡۚ إِنَّهُمۡ كَانُواْ قَبۡلَ ذَٰلِكَ مُحۡسِنِينَ
  51,17,"كَانُواْ قَلِيلٗا مِّنَ ٱلَّيۡلِ مَا يَهۡجَعُونَ (يَهْجَعُونَ: يَنَامُونَ)"
  51,18,"وَبِٱلۡأَسۡحَارِ هُمۡ يَسۡتَغۡفِرُونَ (وَبِالْأَسْحَارِ: آخِرِ اللَّيْلِ، قُبَيْلَ الفَجْرِ)"
  51,19,"وَفِيٓ أَمۡوَٰلِهِمۡ حَقّٞ لِّلسَّآئِلِ وَٱلۡمَحۡرُومِ (لِّلسَّائِلِ: لِلْمُحْتَاجِ الَّذِي يَسْأَلُ النَّاسَ, وَالْمَحْرُومِ: الَّذِي لَا يَسْأَلُ النَّاسَ حَيَاءً)"
  51,20,وَفِي ٱلۡأَرۡضِ ءَايَٰتٞ لِّلۡمُوقِنِينَ
  51,21,وَفِيٓ أَنفُسِكُمۡۚ أَفَلَا تُبۡصِرُونَ
  51,22,وَفِي ٱلسَّمَآءِ رِزۡقُكُمۡ وَمَا تُوعَدُونَ
  51,23,"فَوَرَبِّ ٱلسَّمَآءِ وَٱلۡأَرۡضِ إِنَّهُۥ لَحَقّٞ مِّثۡلَ مَآ أَنَّكُمۡ تَنطِقُونَ (إِنَّهُ لَحَقٌّ: إِنَّ مَا وَعَدَكُمْ بِهِ مِنَ الجَزَاءِ لَحَقٌّ ثَابِتٌ)"