quran[33]{c,v,t}:
  68,1,"نٓۚ وَٱلۡقَلَمِ وَمَا يَسۡطُرُونَ (وَالْقَلَمِ: قَسَمٌ بِالقَلَمِ الَّذِي تَكْتُبُ بِهِ المَلَائِكَةُ، وَالنَّاسُ, وَمَا يَسْطُرُونَ: وَالَّذِي يَكْتُبُونَهُ بِالقَلَمِ)"
  68,2,مَآ أَنتَ بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونٖ
  68,3,"وَإِنَّ لَكَ لَأَجۡرًا غَيۡرَ مَمۡنُونٖ (مَمْنُونٍ: مَنْقُوصٍ، وَلَا مُنْقَطِعٍ)"
  68,4,وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٖ
  68,5,فَسَتُبۡصِرُ وَيُبۡصِرُونَ
  68,6,"بِأَييِّكُمُ ٱلۡمَفۡتُونُ (بِأَييِّكُمُ الْمَفْتُونُ: فَي أَيِّ الفَرِيقَيْنِ الفِتْنَةُ، وَالجُنُونُ؟)"
  68,7,إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعۡلَمُ بِٱلۡمُهۡتَدِينَ
  68,8,فَلَا تُطِعِ ٱلۡمُكَذِّبِينَ
  68,9,"وَدُّواْ لَوۡ تُدۡهِنُ فَيُدۡهِنُونَ (تُدْهِنُ: تُلَايِنُ، وَتُصَانِعُ)"
  68,10,"وَلَا تُطِعۡ كُلَّ حَلَّافٖ مَّهِينٍ (حَلَّافٍ: كَثِيرِ الحَلِفِ, مَّهِينٍ: كَذَّابٍ، حَقِيرٍ)"
  68,11,"هَمَّازٖ مَّشَّآءِۭ بِنَمِيمٖ (هَمَّازٍ: مُغْتَابٍ لِلنَّاسِ, مَّشَّاءٍ بِنَمِيمٍ: يَمْشِي بِالنَّمِيمَةِ، وَهِيَ: نَقْلُ الحَدِيثِ بَيْنَ النَّاسِ عَلَى وَجْهِ الإِفْسَادِ)"
  68,12,مَّنَّاعٖ لِّلۡخَيۡرِ مُعۡتَدٍ أَثِيمٍ
  68,13,"عُتُلِّۭ بَعۡدَ ذَٰلِكَ زَنِيمٍ (عُتُلٍّ: فَاحِشٍ، لَئِيمٍ، غَلِيظٍ فيِ كُفْرِهِ, زَنِيمٍ: مَنْسُوبٍ لِغَيْرِ أَبِيهِ)"
  68,14,"أَن كَانَ ذَا مَالٖ وَبَنِينَ (أَن كَانَ: مِنْ أَجْلِ أَنَّهُ كَانَ)"
  68,15,"إِذَا تُتۡلَىٰ عَلَيۡهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلۡأَوَّلِينَ (أَسَاطِيرُ الْأَوَّلِينَ: أَبَاطِيلُهُمْ، وَخُرَافَاتُهُمْ)"
  68,16,"سَنَسِمُهُۥ عَلَى ٱلۡخُرۡطُومِ (سَنَسِمُهُ: سَنَجْعَلُ لَهُ عَلَامَةً لَا تُفَارِقُهُ, الْخُرْطُومِ: أَنْفِهِ)"
  68,17,"إِنَّا بَلَوۡنَٰهُمۡ كَمَا بَلَوۡنَآ أَصۡحَٰبَ ٱلۡجَنَّةِ إِذۡ أَقۡسَمُواْ لَيَصۡرِمُنَّهَا مُصۡبِحِينَ (بَلَوْنَاهُمْ: اخْتَبَرْنَاهُمْ, الْجَنَّةِ: الحَدِيقَةِ, لَيَصْرِمُنَّهَا: لَيَقْطَعُنَّ ثِمَارَ حَدِيقَتِهَا)"
  68,18,"وَلَا يَسۡتَثۡنُونَ (وَلَا يَسْتَثْنُونَ: وَلَا يَنْوُونَ اسْتِثْنَاءَ حِصَّةِ المَسَاكِينِ، وَلَمْ يَقُولُوا: إِنْ شَاءَ اللهُ)"
  68,19,"فَطَافَ عَلَيۡهَا طَآئِفٞ مِّن رَّبِّكَ وَهُمۡ نَآئِمُونَ (فَطَافَ عَلَيْهَا: أَحَاطَ نَازِلًا عَلَيْهَا, طَائِفٌ: نَارٌ أَحْرَقَتْهَا)"
  68,20,"فَأَصۡبَحَتۡ كَٱلصَّرِيمِ (كَالصَّرِيمِ: كَاللَّيْلِ المُظْلِمِ)"
  68,21,"فَتَنَادَوۡاْ مُصۡبِحِينَ (فَتَنَادَوا: نَادَى بَعْضُهُمْ بَعْضًا)"
  68,22,"أَنِ ٱغۡدُواْ عَلَىٰ حَرۡثِكُمۡ إِن كُنتُمۡ صَٰرِمِينَ (أَنِ اغْدُوا: اذْهَبُوا مُبَكِّرِينَ, حَرْثِكُمْ: مَزْرَعَتِكُمْ, صَارِمِينَ: مُصِرِّينَ عَلَى قَطْعِ الثِّمَارِ)"
  68,23,فَٱنطَلَقُواْ وَهُمۡ يَتَخَٰفَتُونَ
  68,24,أَن لَّا يَدۡخُلَنَّهَا ٱلۡيَوۡمَ عَلَيۡكُم مِّسۡكِينٞ
  68,25,"وَغَدَوۡاْ عَلَىٰ حَرۡدٖ قَٰدِرِينَ (عَلَى حَرْدٍ: عَلَى قَصْدِهِمُ السَّيِّئِ فِي مَنْعِ المَسَاكِينِ)"
  68,26,"فَلَمَّا رَأَوۡهَا قَالُوٓاْ إِنَّا لَضَآلُّونَ (لَضَالُّونَ: لَمُخْطِئُونَ فِي طَرِيقِهَا)"
  68,27,بَلۡ نَحۡنُ مَحۡرُومُونَ
  68,28,"قَالَ أَوۡسَطُهُمۡ أَلَمۡ أَقُل لَّكُمۡ لَوۡلَا تُسَبِّحُونَ (أَوْسَطُهُمْ: أَعْدَلُهُمْ، وَخَيْرُهُمْ عَقْلًا وَدِينًا, لَوْلَا تُسَبِّحُونَ: هَلَّا تَذْكُرُونَ اللهَ، وَتَسْتَغْفِرُونَهُ؛ مِنْ فِعْلِكُمْ، وَخُبْثِ نِيَّتِكُمْ)"
  68,29,قَالُواْ سُبۡحَٰنَ رَبِّنَآ إِنَّا كُنَّا ظَٰلِمِينَ
  68,30,"فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَلَٰوَمُونَ (يَتَلَاوَمُونَ: يَلُومُ بَعْضُهُمْ بَعْضًا عَلَى مَا قَصَدُوهُ مِنْ مَنْعٍ لِلْمَسَاكِينِ)"
  68,31,قَالُواْ يَٰوَيۡلَنَآ إِنَّا كُنَّا طَٰغِينَ
  68,32,"عَسَىٰ رَبُّنَآ أَن يُبۡدِلَنَا خَيۡرٗا مِّنۡهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ (رَاغِبُونَ: طَالِبُونَ الخَيْرَ)"
  68,33,"كَذَٰلِكَ ٱلۡعَذَابُۖ وَلَعَذَابُ ٱلۡأٓخِرَةِ أَكۡبَرُۚ لَوۡ كَانُواْ يَعۡلَمُونَ (كَذَلِكَ الْعَذَابُ: مِثْلَ ذَلِكَ العِقَابِ الَّذِي عَاقَبْنَاهُمْ بِهِ نُعَاقِبُ كُلَّ مَنْ بَخِلَ، وَخَالَفَ أَمْرَ اللهِ)"