quran[52]{c,v,t}:
  69,1,EL-HAKKATU
  69,2,MAL-HAKKATU
  69,3,WE MA ‘EDRAKE MAL-HAKKATU
  69,4,KEDHDHEBET THEMUDU WE ‘ADUN BIL-KARI’ATI
  69,5,FE’EMMA THEMUDU FE’UHLIKU BIT-TAGIJETI
  69,6,WE ‘EMMA ‘ADUN FE’UHLIKU BIRIHIN SERSERIN ‘ATIJETIN
  69,7,SEHHAREHA ‘ALEJHIM SEB’A LEJALIN WE THEMANIJETE ‘EJJAMIN HUSUMÆN FETERAL-KAWME FIHA SER’A KE’ENNEHUM ‘A’XHAZU NEHLIN HAWIJETIN
  69,8,FEHEL TERA LEHUM MIN BAKIJETIN
  69,9,WE XHA’E FIR’AWNU WE MEN KABLEHU WEL-MU’UTEFIKATU BIL-HATI’ETI
  69,10,FE’ASEW RESULE RABBIHIM FE’EHADHEHUM ‘EHDHETEN RABIJETEN
  69,11,‘INNA LEMMA TEGAL-MA’U HEMELNAKUM FIL-XHARIJETI
  69,12,LINEXH’ALEHA LEKUM TEDHKIRETEN WE TA’IJEHA ‘UDHUNUN WA’IJETUN
  69,13,FE’IDHA NUFIHA FI ES-SURI NEFHATUN WAHIDETUN
  69,14,WE HUMILETIL-’ERDU WEL-XHIBALU FEDUKKETA DEKKETEN WAHIDETEN
  69,15,FEJEWME’IDHIN WEKA’ATIL-WAKI’ATU
  69,16,WE ENSHEKKATI ES-SEMA’U FEHIJE JEWME’IDHIN WE EHIJETUN
  69,17,WEL-MELEKU ‘ALA ‘ERXHA’IHA WE JEHMILU ‘ARSHE RABBIKE FEWKAHUM JEWME’IDHIN THEMANIJETUN
  69,18,JEWME’IDHIN TU’REDUNE LA TEHFA MINKUM HAFIJETUN
  69,19,FE’EMMA MEN ‘UTIJE KITABEHU BIJEMINIHI FEJEKULU HA’UUM EKRE’U KITABI
  69,20,‘INNI DHENENTU ‘ENNI MULAKIN HISABIJEH
  69,21,FEHUWE FI ‘ISHETIN RADIJETIN
  69,22,FI XHENNETIN ‘ALIJETIN
  69,23,KUTUFUHA DANIJETUN
  69,24,KULU WE ESHREBU HENI’ÆN BIMA ‘ESLEFTUM FIL-’EJJAMIL-HALIJETI
  69,25,WE ‘EMMA MEN ‘UTIJE KITABEHU BISHIMALIHI FEJEKULU JA LEJTENI LEM ‘UTE KITABIH
  69,26,WE LEM ‘EDRI MA HISABIH
  69,27,JA LEJTEHA KANETIL-KADIJETE
  69,28,MA ‘EGNA ‘ANNI MALIH
  69,29,HELEKE ‘ANNI SULTANIH
  69,30,HUDHUHU FEGULLUHU
  69,31,THUMMEL-XHEHIME SELLUHU
  69,32,THUMME FI SILSILETIN DHER’UHA SEB’UNE DHIRA’ÆN FASLUKUHU
  69,33,‘INNEHU KANE LA JU’UMINU BILLAHIL-’ADHIMI
  69,34,WE LA JEHUDDU ‘ALA TA’AMIL-MISKINI
  69,35,FELEJSE LEHUL-JEWME HAHUNA HEMIMUN
  69,36,WE LA TA’AMUN ‘ILLA MIN GISLININ
  69,37,LA JE’KULUHU ‘ILLAL-HATI’UNE
  69,38,FELA ‘UKSIMU BIMA TUBSIRUNE
  69,39,WE MA LA TUBSIRUNE
  69,40,‘INNEHU LEKAWLU RESULIN KERIMIN
  69,41,WE MA HUWE BIKAWLI SHA’IRIN KALILÆN MA TU’UMINUNE
  69,42,WE LA BIKAWLI KAHININ KALILÆN MA TEDHEKKERUNE
  69,43,TENZILUN MIN RABBIL-’ALEMINE
  69,44,WE LEW TEKAWWELE ‘ALEJNA BA’DEL-’EKAWILI
  69,45,LE’EHADHNA MINHU BIL-JEMINI
  69,46,THUMME LEKATA’NA MINHUL-WETINE
  69,47,FEMA MINKUM MIN ‘EHEDIN ‘ANHU HAXHIZINE
  69,48,WE ‘INNEHU LETEDHKIRETUN LILMUTTEKINE
  69,49,WE ‘INNA LENA’LEMU ‘ENNE MINKUM MUKEDHDHIBINE
  69,50,WE ‘INNEHU LEHESRETUN ‘ALEL-KAFIRINE
  69,51,WE ‘INNEHU LEHEKKUL-JEKINI
  69,52,FESEBBIH BIASMI RABBIKEL-’ADHIMI