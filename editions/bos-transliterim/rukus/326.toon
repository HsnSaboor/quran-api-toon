quran[36]{c,v,t}:
  26,192,WE ‘INNEHU LETENZILU RABBIL-’ALEMINE
  26,193,NEZELE BIHI ER-RUHUL-’EMINU
  26,194,‘ALA KALBIKE LITEKUNE MINEL-MUNDHIRINE
  26,195,BILISANIN ‘AREBIJIN MUBININ
  26,196,WE ‘INNEHU LEFI ZUBURIL-’EWWELINE
  26,197,‘EWELEM JEKUN LEHUM ‘AJETEN ‘EN JA’LEMEHU ‘ULEMA’U BENI ‘ISRA’ILE
  26,198,WE LEW NEZZELNAHU ‘ALA BA’DIL-’A’XHEMINE
  26,199,FEKARE’EHU ‘ALEJHIM MA KANU BIHI MU’UMININE
  26,200,KEDHALIKE SELEKNAHU FI KULUBIL-MUXHRIMINE
  26,201,LA JU’UMINUNE BIHI HETTA JEREWL-’ADHABEL-’ELIME
  26,202,FEJE’TIJEHUM BEGTETEN WE HUM LA JESH’URUNE
  26,203,FEJEKULU HEL NEHNU MUNDHERUNE
  26,204,‘EFEBI’ADHABINA JESTA’XHILUNE
  26,205,‘EFERE’EJTE ‘IN METTA’NAHUM SININE
  26,206,THUMME XHA’EHUM MA KANU JU’ADUNE
  26,207,MA ‘EGNA ‘ANHUM MA KANU JUMETTA’UNE
  26,208,WE MA ‘EHLEKNA MIN KARJETIN ‘ILLA LEHA MUNDHIRUNE
  26,209,DHIKRA WE MA KUNNA DHALIMINE
  26,210,WE MA TENEZZELET BIHI ESH-SHEJATINU
  26,211,WE MA JENBEGI LEHUM WE MA JESTETI’UNE
  26,212,‘INNEHUM ‘ANI ES-SEM’I LEMA’ZULUNE
  26,213,FELA TED’U ME’A ELLAHI ‘ILEHÆN ‘AHARE FETEKUNE MINEL-MU’ADHDHEBINE
  26,214,WE ‘ENDHIR ‘ASHIRETEKEL-’EKREBINE
  26,215,WE EHFID XHENAHEKE LIMENI ETTEBE’AKE MINEL-MU’UMININE
  26,216,FE’IN ‘ASEWKE FEKUL ‘INNI BERI’UN MIMMA TA’MELUNE
  26,217,WE TEWEKKEL ‘ALEL-’AZIZI ER-REHIMI
  26,218,EL-LEDHI JERAKE HINE TEKUMU
  26,219,WE TEKALLUBEKE FI ES-SAXHIDINE
  26,220,‘INNEHU HUWE ES-SEMI’UL-’ALIMU
  26,221,HEL ‘UNEBBI’UKUM ‘ALA MEN TENEZZELU ESH-SHEJATINU
  26,222,TENEZZELU ‘ALA KULLI ‘EFFAKIN ‘ETHIMIN
  26,223,JULKUNE ES-SEM’A WE ‘EKTHERUHUM KADHIBUNE
  26,224,WE ESH-SHU’ARA’U JETTEBI’UHUMUL-GAWUNE
  26,225,‘ELEM TERA ‘ENNEHUM FI KULLI WADIN JEHIMUNE
  26,226,WE ‘ENNEHUM JEKULUNE MA LA JEF’ALUNE
  26,227,‘ILLAL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI WE DHEKERU ELLAHE KETHIRÆN WE ENTESERU MIN BA’DI MA DHULIMU WE SEJA’LEMUL-LEDHINE DHELEMU ‘EJJE MUNKALEBIN JENKALIBUNE