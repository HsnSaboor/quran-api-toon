quran[15]{c,v,t}:
  69,38,FELA ‘UKSIMU BIMA TUBSIRUNE
  69,39,WE MA LA TUBSIRUNE
  69,40,‘INNEHU LEKAWLU RESULIN KERIMIN
  69,41,WE MA HUWE BIKAWLI SHA’IRIN KALILÆN MA TU’UMINUNE
  69,42,WE LA BIKAWLI KAHININ KALILÆN MA TEDHEKKERUNE
  69,43,TENZILUN MIN RABBIL-’ALEMINE
  69,44,WE LEW TEKAWWELE ‘ALEJNA BA’DEL-’EKAWILI
  69,45,LE’EHADHNA MINHU BIL-JEMINI
  69,46,THUMME LEKATA’NA MINHUL-WETINE
  69,47,FEMA MINKUM MIN ‘EHEDIN ‘ANHU HAXHIZINE
  69,48,WE ‘INNEHU LETEDHKIRETUN LILMUTTEKINE
  69,49,WE ‘INNA LENA’LEMU ‘ENNE MINKUM MUKEDHDHIBINE
  69,50,WE ‘INNEHU LEHESRETUN ‘ALEL-KAFIRINE
  69,51,WE ‘INNEHU LEHEKKUL-JEKINI
  69,52,FESEBBIH BIASMI RABBIKEL-’ADHIMI