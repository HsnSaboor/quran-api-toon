quran[8]{c,v,t}:
  99,1,‘IDHA ZULZILETIL-’ERDU ZILZALEHA
  99,2,WE ‘EHREXHETIL-’ERDU ‘ETHKALEHA
  99,3,WE KALEL-’INSANU MA LEHA
  99,4,JEWME’IDHIN TUHEDDITHU ‘EHBAREHA
  99,5,BI’ENNE REBBEKE ‘EWHA LEHA
  99,6,JEWME’IDHIN JESDURU EN-NASU ‘ESHTATÆN LIJUREW ‘A’MALEHUM
  99,7,FEMEN JA’MEL MITHKALE DHERRETIN HAJRÆN JEREHU
  99,8,WE MEN JA’MEL MITHKALE DHERRETIN SHERRÆN JEREHU