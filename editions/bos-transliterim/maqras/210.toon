quran[51]{c,v,t}:
  52,24,WE JETUFU ‘ALEJHIM GILMANUN LEHUM KE’ENNEHUM LU’ULU’UUN MEKNUNUN
  52,25,WE ‘EKBELE BA’DUHUM ‘ALA BA’DIN JETESA’ELUNE
  52,26,KALU ‘INNA KUNNA KABLU FI ‘EHLINA MUSHFIKINE
  52,27,FEMENNEL-LAHU ‘ALEJNA WE WEKANA ‘ADHABE ES-SEMUMI
  52,28,‘INNA KUNNA MIN KABLU NED’UHU ‘INNEHU HUWEL-BERRU ER-REHIMU
  52,29,FEDHEKKIR FEMA ‘ENTE BINI’METI RABBIKE BIKAHININ WE LA MEXHNUNIN
  52,30,‘EM JEKULUNE SHA’IRUN NETEREBBESU BIHI REJBEL-MENUNI
  52,31,KUL TEREBBESU FE’INNI ME’AKUM MINEL-MUTEREBBISINE
  52,32,‘EM TE’MURUHUM ‘EHLAMUHUM BIHEDHA ‘EM HUM KAWMUN TAGUNE
  52,33,‘EM JEKULUNE TEKAWWELEHU BEL LA JU’UMINUNE
  52,34,FELJE’TU BIHEDITHIN MITHLIHI ‘IN KANU SADIKINE
  52,35,‘EM HULIKU MIN GAJRI SHEJ’IN ‘EM HUMUL-HALIKUNE
  52,36,‘EM HALEKU ES-SEMAWATI WEL-’ERDE BEL LA JUKINUNE
  52,37,‘EM ‘INDEHUM HAZA’INU RABBIKE ‘EM HUMUL-MUSEJTIRUNE
  52,38,‘EM LEHUM SULLEMUN JESTEMI’UNE FIHI FELJE’TI MUSTEMI’UHUM BISULTANIN MUBININ
  52,39,‘EM LEHUL-BENATU WE LEKUMUL-BENUNE
  52,40,‘EM TES’ELUHUM ‘EXHRÆN FEHUM MIN MEGREMIN MUTHKALUNE
  52,41,‘EM ‘INDEHUMUL-GAJBU FEHUM JEKTUBUNE
  52,42,‘EM JURIDUNE KEJDÆN FE-EL-LEDHINE KEFERU HUMUL-MEKIDUNE
  52,43,‘EM LEHUM ‘ILEHUN GAJRU ELLAHI SUBHANEL-LAHI ‘AMMA JUSHRIKUNE
  52,44,WE ‘IN JEREW KISFÆN MINE ES-SEMA’I SAKITÆN JEKULU SEHABUN MERKUMUN
  52,45,FEDHERHUM HETTA JULAKU JEWMEHUMUL-LEDHI FIHI JUS’AKUNE
  52,46,JEWME LA JUGNI ‘ANHUM KEJDUHUM SHEJ’ÆN WE LA HUM JUNSERUNE
  52,47,WE ‘INNE LILLEDHINE DHELEMU ‘ADHABÆN DUNE DHALIKE WE LEKINNE ‘EKTHEREHUM LA JA’LEMUNE
  52,48,WE ESBIR LIHUKMI RABBIKE FE’INNEKE BI’A’JUNINA WE SEBBIH BIHEMDI RABBIKE HINE TEKUMU
  52,49,WE MINEL-LEJLI FESEBBIHHU WE ‘IDBARE EN-NUXHUMI
  53,1,WE EN-NEXHMI ‘IDHA HEWA
  53,2,MA DELLE SAHIBUKUM WE MA GAWA
  53,3,WE MA JENTIKU ‘ANIL-HEWA
  53,4,‘IN HUWE ‘ILLA WEHJUN JUHA
  53,5,‘ALLEMEHU SHEDIDUL-KUWA
  53,6,DHU MIRRETIN FASTEWA
  53,7,WE HUWE BIL-’UFUKIL-’A’LA
  53,8,THUMME DENA FETEDELLA
  53,9,FEKANE KABE KAWSEJNI ‘EW ‘EDNA
  53,10,FE’EWHA ‘ILA ‘ABDIHI MA ‘EWHA
  53,11,MA KEDHEBEL-FU’UADU MA RE’A
  53,12,‘EFETUMARUNEHU ‘ALA MA JERA
  53,13,WE LEKAD RE’AHU NEZLETEN ‘UHRA
  53,14,‘INDE SIDRETIL-MUNTEHA
  53,15,‘INDEHA XHENNETUL-ME’WA
  53,16,‘IDH JEGSHA ES-SIDRETE MA JEGSHA
  53,17,MA ZAGAL-BESERU WE MA TEGA
  53,18,LEKAD RE’A MIN ‘AJATI RABBIHIL-KUBRA
  53,19,‘EFERE’EJTUMUL-LATE WEL-’UZZA
  53,20,WE MENÆTE ETH-THALITHETEL-’UHRA
  53,21,‘ELEKUMU EDH-DHEKERU WE LEHUL-’UNTHA
  53,22,TILKE ‘IDHÆN KISMETUN DIZA
  53,23,‘IN HIJE ‘ILLA ‘ESMA’UN SEMMEJTUMUHA ‘ENTUM WE ‘ABA’UUKUM MA ‘ENZELEL-LAHU BIHA MIN SULTANIN ‘IN JETTEBI’UNE ‘ILLA EDH-DHENNE WE MA TEHWAL-’ENFUSU WE LEKAD XHA’EHUM MIN RABBIHIMUL-HUDA
  53,24,‘EM LIL’INSANI MA TEMENNA
  53,25,FELILLAHIL-’AHIRETU WEL-’ULA