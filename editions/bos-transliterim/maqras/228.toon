quran[54]{c,v,t}:
  70,19,‘INNEL-’INSANE HULIKA HELU’ÆN
  70,20,‘IDHA MESSEHU ESH-SHERRU XHEZU’ÆN
  70,21,WE ‘IDHA MESSEHUL-HAJRU MENU’ÆN
  70,22,‘ILLAL-MUSELLINE
  70,23,EL-LEDHINE HUM ‘ALA SELATIHIM DA’IMUNE
  70,24,WEL-LEDHINE FI ‘EMWALIHIM HEKKUN MA’LUMUN
  70,25,LILSSA’ILI WEL-MEHRUMI
  70,26,WEL-LEDHINE JUSEDDIKUNE BIJEWMI ED-DINI
  70,27,WEL-LEDHINE HUM MIN ‘ADHABI RABBIHIM MUSHFIKUNE
  70,28,‘INNE ‘ADHABE RABBIHIM GAJRU ME’MUNIN
  70,29,WEL-LEDHINE HUM LIFURUXHIHIM HAFIDHUNE
  70,30,‘ILLA ‘ALA ‘EZWAXHIHIM ‘EW MA MELEKET ‘EJMANUHUM FE’INNEHUM GAJRU MELUMINE
  70,31,FEMENI EBTEGA WERA’E DHALIKE FE’ULA’IKE HUMUL-’ADUNE
  70,32,WEL-LEDHINE HUM LI’MANATIHIM WE ‘AHDIHIM RA’UNE
  70,33,WEL-LEDHINE HUM BISHEHADATIHIM KA’IMUNE
  70,34,WEL-LEDHINE HUM ‘ALA SELATIHIM JUHAFIDHUNE
  70,35,‘ULA’IKE FI XHENNATIN MUKREMUNE
  70,36,FEMALIL-LEDHINE KEFERU KIBELEKE MUHTI’INE
  70,37,‘ANIL-JEMINI WE ‘ANI ESH-SHIMALI ‘IZINE
  70,38,‘EJETMA’U KULLU EMRI’IN MINHUM ‘EN JUDHALE XHENNETE NA’IMIN
  70,39,KELLA ‘INNA HALEKNAHUM MIMMA JA’LEMUNE
  70,40,FELA ‘UKSIMU BIREBBIL-MESHARIKI WEL-MEGARIBI ‘INNA LEKADIRUNE
  70,41,‘ALA ‘EN NUBEDDILE HAJRÆN MINHUM WE MA NEHNU BIMESBUKINE
  70,42,FEDHERHUM JEHUDU WE JEL’ABU HETTA JULAKU JEWMEHUMUL-LEDHI JU’ADUNE
  70,43,JEWME JEHRUXHUNE MINEL-’EXHDATHI SIRA’ÆN KE’ENNEHUM ‘ILA NUSUBIN JUFIDUNE
  70,44,HASHI’ATEN ‘EBSARUHUM TERHEKUHUM DHILLETUN DHALIKEL-JEWMUL-LEDHI KANU JU’ADUNE
  71,1,‘INNA ‘ERSELNA NUHÆN ‘ILA KAWMIHI ‘EN ‘ENDHIR KAWMEKE MIN KABLI ‘EN JE’TIJEHUM ‘ADHABUN ‘ELIMUN
  71,2,KALE JA KAWMI ‘INNI LEKUM NEDHIRUN MUBINUN
  71,3,‘ENI A’BUDU ELLAHE WE ETTEKUHU WE ‘ETI’UNI
  71,4,JEGFIR LEKUM MIN DHUNUBIKUM WE JU’UEHHIRKUM ‘ILA ‘EXHELIN MUSEMMEN ‘INNE ‘EXHELEL-LAHI ‘IDHA XHA’E LA JU’UEHHARU LEW KUNTUM TA’LEMUNE
  71,5,KALE RABBI ‘INNI DE’AWTU KAWMI LEJLÆN WE NEHARÆN
  71,6,FELEM JEZID/HUM DU’A’I ‘ILLA FIRARÆN
  71,7,WE ‘INNI KULLEMA DE’AWTUHUM LITEGFIRE LEHUM XHE’ALU ‘ESABI’AHUM FI ‘ADHANIHIM WE ESTEGSHEW THIJABEHUM WE ‘ESERRU WE ESTEKBERU ESTIKBARÆN
  71,8,THUMME ‘INNI DE’AWTUHUM XHIHARÆN
  71,9,THUMME ‘INNI ‘A’LENTU LEHUM WE ‘ESRERTU LEHUM ‘ISRARÆN
  71,10,FEKULTU ESTEGFIRU REBBEKUM ‘INNEHU KANE GAFFARÆN
  71,11,JURSILI ES-SEMA’E ‘ALEJKUM MIDRARÆN
  71,12,WE JUMDIDKUM BI’EMWALIN WE BENINE WE JEXH’AL LEKUM XHENNATIN WE JEXH’AL LEKUM ‘ENHARÆN
  71,13,MA LEKUM LA TERXHUNE LILLAHI WEKARÆN
  71,14,WE KAD HALEKAKUM ‘ETWARÆN
  71,15,‘ELEM TEREW KEJFE HALEKAL-LAHU SEB’A SEMAWATIN TIBAKÆN
  71,16,WE XHE’ALEL-KAMERE FIHINNE NURÆN WE XHE’ALE ESH-SHEMSE SIRAXHÆN
  71,17,WEL-LAHU ‘ENBETEKUM MINEL-’ERDI NEBATÆN
  71,18,THUMME JU’IDUKUM FIHA WE JUHRIXHUKUM ‘IHRAXHÆN
  71,19,WEL-LAHU XHE’ALE LEKUMUL-’ERDE BISATÆN
  71,20,LITESLUKU MINHA SUBULÆN FIXHAXHÆN
  71,21,KALE NUHUN RABBI ‘INNEHUM ‘ASEWNI WE ETTEBA’U MEN LEM JEZID/HU MALUHU WE WELEDUHU ‘ILLA HASARÆN
  71,22,WE MEKERU MEKRÆN KUBBARÆN
  71,23,WE KALU LA TEDHERUNNE ‘ALIHETEKUM WE LA TEDHERUNNE WEDDÆN WE LA SUWA’ÆN WE LA JEGUTHE WE JA’UKA WE NESRÆN
  71,24,WE KAD ‘EDELLU KETHIRÆN WE LA TEZIDI EDH-DHALIMINE ‘ILLA DELALÆN
  71,25,MIMMA HATI’ATIHIM ‘UGRIKU FE’UDHILU NARÆN FELEM JEXHIDU LEHUM MIN DUNI ELLAHI ‘ENSARÆN
  71,26,WE KALE NUHUN RABBI LA TEDHER ‘ALEL-’ERDI MINEL-KAFIRINE DEJJARÆN
  71,27,‘INNEKE ‘IN TEDHERHUM JUDILLU ‘IBADEKE WE LA JELIDU ‘ILLA FAXHIRÆN KEFFARÆN
  71,28,REBBI EGFIR LI WE LIWALIDEJJE WE LIMEN DEHALE BEJTIJE MU’UMINÆN WE LILMU’UMININE WEL-MU’UMINATI WE LA TEZIDI EDH-DHALIMINE ‘ILLA TEBARÆN