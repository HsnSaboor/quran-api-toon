quran[49]{c,v,t}:
  15,1,‘ELIF-LAM-RA TILKE ‘AJATUL-KITABI WE KUR’ANIN MUBININ
  15,2,RUBEMA JEWEDDUL-LEDHINE KEFERU LEW KANU MUSLIMINE
  15,3,DHERHUM JE’KULU WE JETEMETTA’U WE JULHIHIMUL-’EMELU FESEWFE JA’LEMUNE
  15,4,WE MA ‘EHLEKNA MIN KARJETIN ‘ILLA WE LEHA KITABUN MA’LUMUN
  15,5,MA TESBIKU MIN ‘UMMETIN ‘EXHELEHA WE MA JESTE’HIRUNE
  15,6,WE KALU JA ‘EJJUHAL-LEDHI NUZZILE ‘ALEJHI EDH-DHIKRU ‘INNEKE LEMEXHNUNUN
  15,7,LEW MA TE’TINA BIL-MELA’IKETI ‘IN KUNTE MINE ES-SADIKINE
  15,8,MA NUNEZZILUL-MELA’IKETE ‘ILLA BIL-HEKKI WE MA KANU ‘IDHÆN MUNDHERINE
  15,9,‘INNA NEHNU NEZZELNA EDH-DHIKRE WE ‘INNA LEHU LEHAFIDHUNE
  15,10,WE LEKAD ‘ERSELNA MIN KABLIKE FI SHIJA’IL-’EWWELINE
  15,11,WE MA JE’TIHIM MIN RESULIN ‘ILLA KANU BIHI JESTEHZI’UNE
  15,12,KEDHALIKE NESLUKUHU FI KULUBIL-MUXHRIMINE
  15,13,LA JU’UMINUNE BIHI WE KAD HALET SUNNETUL-’EWWELINE
  15,14,WE LEW FETEHNA ‘ALEJHIM BABÆN MINE ES-SEMA’I FEDHELLU FIHI JA’RUXHUNE
  15,15,LEKALU ‘INNEMA SUKKIRET ‘EBSARUNA BEL NEHNU KAWMUN MESHURUNE
  15,16,WE LEKAD XHE’ALNA FI ES-SEMA’I BURUXHÆN WE ZEJJENNAHA LILNNADHIRINE
  15,17,WE HEFIDHNAHA MIN KULLI SHEJTANIN REXHIMIN
  15,18,‘ILLA MENI ESTEREKA ES-SEM’A FE’ETBE’AHU SHIHABUN MUBINUN
  15,19,WEL-’ERDE MEDEDNAHA WE ‘ELKAJNA FIHA REWASIJE WE ‘ENBETNA FIHA MIN KULLI SHEJ’IN MEWZUNIN
  15,20,WE XHE’ALNA LEKUM FIHA MA’AJISHE WE MEN LESTUM LEHU BIRAZIKINE
  15,21,WE ‘IN MIN SHEJ’IN ‘ILLA ‘INDENA HAZA’INUHU WE MA NUNEZZILUHU ‘ILLA BIKADERIN MA’LUMIN
  15,22,WE ‘ERSELNA ER-RIJAHE LEWAKIHE FE’ENZELNA MINE ES-SEMA’I MA’EN FE’ESKAJNAKUMUHU WE MA ‘ENTUM LEHU BIHAZININE
  15,23,WE ‘INNA LENEHNU NUHJI WE NUMITU WE NEHNUL-WARITHUNE
  15,24,WE LEKAD ‘ALIMNAL-MUSTEKDIMINE MINKUM WE LEKAD ‘ALIMNAL-MUSTE’HIRINE
  15,25,WE ‘INNE REBBEKE HUWE JEHSHURUHUM ‘INNEHU HEKIMUN ‘ALIMUN
  15,26,WE LEKAD HALEKNAL-’INSANE MIN SELSALIN MIN HEME’IIN MESNUNIN
  15,27,WEL-XHANNE HALEKNAHU MIN KABLU MIN NARI ES-SEMUMI
  15,28,WE ‘IDH KALE REBBUKE LILMELA’IKETI ‘INNI HALIKUN BESHERÆN MIN SELSALIN MIN HEME’IIN MESNUNIN
  15,29,FE’IDHA SEWWEJTUHU WE NEFEHTU FIHI MIN RUHI FEKA’U LEHU SAXHIDINE
  15,30,FESEXHEDEL-MELA’IKETU KULLUHUM ‘EXHMA’UNE
  15,31,‘ILLA ‘IBLISE ‘EBA ‘EN JEKUNE ME’A ES-SAXHIDINE
  15,32,KALE JA ‘IBLISU MA LEKE ‘ELLA TEKUNE ME’A ES-SAXHIDINE
  15,33,KALE LEM ‘EKUN LI’SXHUDE LIBESHERIN HALEKTEHU MIN SELSALIN MIN HEME’IIN MESNUNIN
  15,34,KALE FAHRUXH MINHA FE’INNEKE REXHIMUN
  15,35,WE ‘INNE ‘ALEJKEL-LA’NETE ‘ILA JEWMI ED-DINI
  15,36,KALE RABBI FE’ENDHIRNI ‘ILA JEWMI JUB’ATHUNE
  15,37,KALE FE’INNEKE MINEL-MUNDHERINE
  15,38,‘ILA JEWMIL-WEKTIL-MA’LUMI
  15,39,KALE RABBI BIMA ‘EGWEJTENI LE’UZEJJINENNE LEHUM FIL-’ERDI WE LE’UGWIJENNEHUM ‘EXHMA’INE
  15,40,‘ILLA ‘IBADEKE MINHUMUL-MUHLESINE
  15,41,KALE HADHA SIRATUN ‘ALEJJE MUSTEKIMUN
  15,42,‘INNE ‘IBADI LEJSE LEKE ‘ALEJHIM SULTANUN ‘ILLA MENI ETTEBE’AKE MINEL-GAWINE
  15,43,WE ‘INNE XHEHENNEME LEMEW’IDUHUM ‘EXHMA’INE
  15,44,LEHA SEB’ATU ‘EBWABIN LIKULLI BABIN MINHUM XHUZ’UN MEKSUMUN
  15,45,‘INNEL-MUTTEKINE FI XHENNATIN WE ‘UJUNIN
  15,46,EDHULUHA BISELAMIN ‘AMININE
  15,47,WE NEZA’NA MA FI SUDURIHIM MIN GILLIN ‘IHWANÆN ‘ALA SURURIN MUTEKABILINE
  15,48,LA JEMESSUHUM FIHA NESEBUN WE MA HUM MINHA BIMUHREXHINE
  15,49,NEBBI’ ‘IBADI ‘ENNI ‘ENAL-GAFURU ER-REHIMU