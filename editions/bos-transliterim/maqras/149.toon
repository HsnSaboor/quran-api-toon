quran[70]{c,v,t}:
  26,111,KALU ‘ENU’UMINU LEKE WE ETTEBE’AKEL-’ERDHELUNE
  26,112,KALE WE MA ‘ILMI BIMA KANU JA’MELUNE
  26,113,‘IN HISABUHUM ‘ILLA ‘ALA RABBI LEW TESH’URUNE
  26,114,WE MA ‘ENA BITARIDIL-MU’UMININE
  26,115,‘IN ‘ENA ‘ILLA NEDHIRUN MUBINUN
  26,116,KALU LE’IN LEM TENTEHI JA NUHU LETEKUNENNE MINEL-MERXHUMINE
  26,117,KALE RABBI ‘INNE KAWMI KEDHDHEBUNI
  26,118,FAFTEH BEJNI WE BEJNEHUM FETHÆN WE NEXHXHINI WE MEN MA’I MINEL-MU’UMININE
  26,119,FE’ENXHEJNAHU WE MEN ME’AHU FIL-FULKIL-MESHHUNI
  26,120,THUMME ‘EGREKNA BA’DUL-BAKINE
  26,121,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,122,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,123,KEDHDHEBET ‘ADUNL-MURSELINE
  26,124,‘IDH KALE LEHUM ‘EHUHUM HUDUN ‘ELA TETTEKUNE
  26,125,‘INNI LEKUM RESULUN ‘EMINUN
  26,126,FATTEKU ELLAHE WE ‘ETI’UNI
  26,127,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRI ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,128,‘ETEBNUNE BIKULLI RI’IN ‘AJETEN TA’BETHUNE
  26,129,WE TETTEHIDHUNE MESANI’A LE’ALLEKUM TEHLUDUNE
  26,130,WE ‘IDHA BETESHTUM BETESHTUM XHEBBARINE
  26,131,FATTEKU ELLAHE WE ‘ETI’UNI
  26,132,WE ETTEKUL-LEDHI ‘EMEDDEKUM BIMA TA’LEMUNE
  26,133,‘EMEDDEKUM BI’EN’AMIN WE BENINE
  26,134,WE XHENNATIN WE ‘UJUNIN
  26,135,‘INNI ‘EHAFU ‘ALEJKUM ‘ADHABE JEWMIN ‘ADHIMIN
  26,136,KALU SEWA’UN ‘ALEJNA ‘EWE’ADHTE ‘EM LEM TEKUN MINEL-WA’IDHINE
  26,137,‘IN HADHA ‘ILLA HULUKUL-’EWWELINE
  26,138,WE MA NEHNU BIMU’ADHDHEBINE
  26,139,FEKEDHDHEBUHU FE’EHLEKNAHUM ‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,140,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,141,KEDHDHEBET THEMUDUL-MURSELINE
  26,142,‘IDH KALE LEHUM ‘EHUHUM SALIHUN ‘ELA TETTEKUNE
  26,143,‘INNI LEKUM RESULUN ‘EMINUN
  26,144,FATTEKU ELLAHE WE ‘ETI’UNI
  26,145,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRIJE ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,146,‘ETUTREKUNE FI MA HAHUNA ‘AMININE
  26,147,FI XHENNATIN WE ‘UJUNIN
  26,148,WE ZURU’IN WE NEHLIN TEL’UHA HEDIMUN
  26,149,WE TENHITUNE MINEL-XHIBALI BUJUTÆN FARIHINE
  26,150,FATTEKU ELLAHE WE ‘ETI’UNI
  26,151,WE LA TUTI’U ‘EMREL-MUSRIFINE
  26,152,EL-LEDHINE JUFSIDUNE FIL-’ERDI WE LA JUSLIHUNE
  26,153,KALU ‘INNEMA ‘ENTE MINEL-MUSEHHERINE
  26,154,MA ‘ENTE ‘ILLA BESHERUN MITHLUNA FE’TI BI’AJETIN ‘IN KUNTE MINE ES-SADIKINE
  26,155,KALE HEDHIHI NAKATUN LEHA SHIRBUN WE LEKUM SHIRBU JEWMIN MA’LUMIN
  26,156,WE LA TEMESSUHA BISU’IN FEJE’HUDHEKUM ‘ADHABU JEWMIN ‘ADHIMIN
  26,157,FE’AKARUHA FE’ESBEHU NADIMINE
  26,158,FE’EHADHEHUMUL-’ADHABU ‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,159,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,160,KEDHDHEBET KAWMU LUTINL-MURSELINE
  26,161,‘IDH KALE LEHUM ‘EHUHUM LUTUN ‘ELA TETTEKUNE
  26,162,‘INNI LEKUM RESULUN ‘EMINUN
  26,163,FATTEKU ELLAHE WE ‘ETI’UNI
  26,164,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRIJE ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,165,‘ETE’TUNE EDH-DHUKRANE MINEL-’ALEMINE
  26,166,WE TEDHERUNE MA HALEKA LEKUM REBBUKUM MIN ‘EZWAXHIKUM BEL ‘ENTUM KAWMUN ‘ADUNE
  26,167,KALU LE’IN LEM TENTEHI JA LUTU LETEKUNENNE MINEL-MUHREXHINE
  26,168,KALE ‘INNI LI’AMELIKUM MINEL-KALINE
  26,169,REBBI NEXHXHINI WE ‘EHLI MIMMA JA’MELUNE
  26,170,FENEXHXHEJNAHU WE ‘EHLEHU ‘EXHMA’INE
  26,171,‘ILLA ‘AXHUZÆN FIL-GABIRINE
  26,172,THUMME DEMMERNAL-’AHARINE
  26,173,WE ‘EMTERNA ‘ALEJHIM METERÆN FESA’E METERUL-MUNDHERINE
  26,174,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,175,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,176,KEDHDHEBE ‘ESHABUL-’EJKETIL-MURSELINE
  26,177,‘IDH KALE LEHUM SHU’AJBUN ‘ELA TETTEKUNE
  26,178,‘INNI LEKUM RESULUN ‘EMINUN
  26,179,FATTEKU ELLAHE WE ‘ETI’UNI
  26,180,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRIJE ‘ILLA ‘ALA RABBIL-’ALEMINE