quran[1606]{c,v,t}:
  50,1,KAF WEL-KUR’ANIL-MEXHIDI
  50,2,BEL ‘AXHIBU ‘EN XHA’EHUM MUNDHIRUN MINHUM FEKALEL-KAFIRUNE HADHA SHEJ’UN ‘AXHIBUN
  50,3,‘E’IDHA MITNA WE KUNNA TURABÆN DHALIKE REXH’UN BA’IDUN
  50,4,KAD ‘ALIMNA MA TENKUSUL-’ERDU MINHUM WE ‘INDENA KITABUN HEFIDHUN
  50,5,BEL KEDHDHEBU BIL-HEKKI LEMMA XHA’EHUM FEHUM FI ‘EMRIN MERIXHIN
  50,6,‘EFELEM JENDHURU ‘ILA ES-SEMA’I FEWKAHUM KEJFE BENEJNAHA WE ZEJJENNAHA WE MA LEHA MIN FURUXHIN
  50,7,WEL-’ERDE MEDEDNAHA WE ‘ELKAJNA FIHA REWASIJE WE ‘ENBETNA FIHA MIN KULLI ZEWXHIN BEHIXHIN
  50,8,TEBSIRETEN WE DHIKRA LIKULLI ‘ABDIN MUNIBIN
  50,9,WE NEZZELNA MINE ES-SEMA’I MA’EN MUBAREKÆN FE’ENBETNA BIHI XHENNATIN WE HEBBEL-HESIDI
  50,10,WE EN-NEHLE BASIKATIN LEHA TEL’UN NEDIDUN
  50,11,RIZKÆN LIL’IBADI WE ‘EHJEJNA BIHI BELDETEN MEJTÆN KEDHALIKEL-HURUXHU
  50,12,KEDHDHEBET KABLEHUM KAWMU NUHIN WE ‘ESHABU ER-RESSI WE THEMUDU
  50,13,WE ‘ADUN WE FIR’AWNU WE ‘IHWANU LUTIN
  50,14,WE ‘ESHABUL-’EJKETI WE KAWMU TUBBA’IN KULLUN KEDHDHEBE ER-RUSULE FEHEKKA WA’IDI
  50,15,‘EFE’AJINA BIL-HALKIL-’EWWELI BEL HUM FI LEBSIN MIN HALKIN XHEDIDIN
  50,16,WE LEKAD HALEKNAL-’INSANE WE NA’LEMU MA TUWESWISU BIHI NEFSUHU WE NEHNU ‘EKREBU ‘ILEJHI MIN HEBLIL-WERIDI
  50,17,‘IDH JETELEKKAL-MUTELEKKIJANI ‘ANIL-JEMINI WE ‘ANI ESH-SHIMALI KA’IDUN
  50,18,MA JELFIDHU MIN KAWLIN ‘ILLA LEDEJHI REKIBUN ‘ATIDUN
  50,19,WE XHA’ET SEKRETUL-MEWTI BIL-HEKKI DHALIKE MA KUNTE MINHU TEHIDU
  50,20,WE NUFIHA FI ES-SURI DHALIKE JEWMUL-WA’IDI
  50,21,WE XHA’ET KULLU NEFSIN ME’AHA SA’IKUN WE SHEHIDUN
  50,22,LEKAD KUNTE FI GAFLETIN MIN HADHA FEKESHEFNA ‘ANKE GITA’EKE FEBESERUKEL-JEWME HEDIDUN
  50,23,WE KALE KARINUHU HADHA MA LEDEJJE ‘ATIDUN
  50,24,‘ELKIJA FI XHEHENNEME KULLE KEFFARIN ‘ANIDIN
  50,25,MENNA’IN LILHAJRI MU’TEDIN MURIBIN
  50,26,EL-LEDHI XHE’ALE ME’A ELLAHI ‘ILEHÆN ‘AHARE FE’ELKIJAHU FIL-’ADHABI ESH-SHEDIDI
  50,27,KALE KARINUHU REBBENA MA ‘ETGAJTUHU WE LEKIN KANE FI DELALIN BA’IDIN
  50,28,KALE LA TEHTESIMU LEDEJJE WE KAD KADDEMTU ‘ILEJKUM BIL-WA’IDI
  50,29,MA JUBEDDELUL-KAWLU LEDEJJE WE MA ‘ENA BIDHELLAMIN LIL’ABIDI
  50,30,JEWME NEKULU LIXHEHENNEME HEL EMTELE’TI WE TEKULU HEL MIN MEZIDIN
  50,31,WE ‘UZLIFETIL-XHENNETU LILMUTTEKINE GAJRE BA’IDIN
  50,32,HADHA MA TU’ADUNE LIKULLI ‘EWWABIN HEFIDHIN
  50,33,MEN HASHIJE ER-REHMENE BIL-GAJBI WE XHA’E BIKALBIN MUNIBIN
  50,34,EDHULUHA BISELAMIN DHALIKE JEWMUL-HULUDI
  50,35,LEHUM MA JESHA’UNE FIHA WE LEDEJNA MEZIDUN
  50,36,WE KEM ‘EHLEKNA KABLEHUM MIN KARNIN HUM ‘ESHEDDU MINHUM BETSHÆN FENEKKABU FIL-BILADI HEL MIN MEHISIN
  50,37,‘INNE FI DHALIKE LEDHIKRA LIMEN KANE LEHU KALBUN ‘EW ‘ELKA ES-SEM’A WE HUWE SHEHIDUN
  50,38,WE LEKAD HALEKNA ES-SEMAWATI WEL-’ERDE WE MA BEJNEHUMA FI SITTETI ‘EJJAMIN WE MA MESSENA MIN LUGUBIN
  50,39,FASBIR ‘ALA MA JEKULUNE WE SEBBIH BIHEMDI RABBIKE KABLE TULU’I ESH-SHEMSI WE KABLEL-GURUBI
  50,40,WE MINEL-LEJLI FESEBBIHHU WE ‘EDBARE ES-SUXHUDI
  50,41,WE ESTEMI’ JEWME JUNADIL-MUNADI MIN MEKANIN KARIBIN
  50,42,JEWME JESMA’UNE ES-SEJHETE BIL-HEKKI DHALIKE JEWMUL-HURUXHI
  50,43,‘INNA NEHNU NUHJI WE NUMITU WE ‘ILEJNAL-MESIRU
  50,44,JEWME TESHEKKAKUL-’ERDU ‘ANHUM SIRA’ÆN DHALIKE HESHRUN ‘ALEJNA JESIRUN
  50,45,NEHNU ‘A’LEMU BIMA JEKULUNE WE MA ‘ENTE ‘ALEJHIM BIXHEBBARIN FEDHEKKIR BIL-KUR’ANI MEN JEHAFU WA’IDI
  51,1,WE EDH-DHARIJATI DHERWEN
  51,2,FALHAMILATI WIKRÆN
  51,3,FALXHARIJATI JUSRÆN
  51,4,FALMUKASSIMATI ‘EMRÆN
  51,5,‘INNEMA TU’ADUNE LESADIKUN
  51,6,WE ‘INNE ED-DINE LEWAKI’UN
  51,7,WE ES-SEMA’I DHATIL-HUBUKI
  51,8,‘INNEKUM LEFI KAWLIN MUHTELIFIN
  51,9,JU’UFEKU ‘ANHU MEN ‘UFIKE
  51,10,KUTILEL-HARRASUNE
  51,11,EL-LEDHINE HUM FI GAMRETIN SAHUNE
  51,12,JES’ELUNE ‘EJJANE JEWMU ED-DINI
  51,13,JEWME HUM ‘ALA EN-NARI JUFTENUNE
  51,14,DHUKU FITNETEKUM HADHAL-LEDHI KUNTUM BIHI TESTA’XHILUNE
  51,15,‘INNEL-MUTTEKINE FI XHENNATIN WE ‘UJUNIN
  51,16,‘AHIDHINE MA ‘ATAHUM REBBUHUM ‘INNEHUM KANU KABLE DHALIKE MUHSININE
  51,17,KANU KALILÆN MINEL-LEJLI MA JEHXHA’UNE
  51,18,WE BIL-’ESHARI HUM JESTEGFIRUNE
  51,19,WE FI ‘EMWALIHIM HEKKUN LILSSA’ILI WEL-MEHRUMI
  51,20,WE FIL-’ERDI ‘AJATUN LILMUKININE
  51,21,WE FI ‘ENFUSIKUM ‘EFELA TUBSIRUNE
  51,22,WE FI ES-SEMA’I RIZKUKUM WE MA TU’ADUNE
  51,23,FEWEREBBI ES-SEMA’I WEL-’ERDI ‘INNEHU LEHEKKUN MITHLE MA ‘ENNEKUM TENTIKUNE
  51,24,HEL ‘ETAKE HEDITHU DEJFI ‘IBRAHIMEL-MUKREMINE
  51,25,‘IDH DEHALU ‘ALEJHI FEKALU SELAMÆN KALE SELAMUN KAWMUN MUNKERUNE
  51,26,FERAGA ‘ILA ‘EHLIHI FEXHA’E BI’IXHLIN SEMININ
  51,27,FEKARREBEHU ‘ILEJHIM KALE ‘ELA TE’KULUNE
  51,28,FE’EWXHESE MINHUM HIFETEN KALU LA TEHAF WE BESHSHERUHU BIGULAMIN ‘ALIMIN
  51,29,FE’EKBELETI EMRE’ETUHU FI SERRETIN FESEKKET WEXHHEHA WE KALET ‘AXHUZUN ‘AKIMUN
  51,30,KALU KEDHALIKI KALE REBBUKI ‘INNEHU HUWEL-HEKIMUL-’ALIMU
  51,31,KALE FEMA HATBUKUM ‘EJJUHAL-MURSELUNE
  51,32,KALU ‘INNA ‘URSILNA ‘ILA KAWMIN MUXHRIMINE
  51,33,LINURSILE ‘ALEJHIM HIXHARETEN MIN TININ
  51,34,MUSEWWEMETEN ‘INDE RABBIKE LILMUSRIFINE
  51,35,FE’EHREXHNA MEN KANE FIHA MINEL-MU’UMININE
  51,36,FEMA WEXHEDNA FIHA GAJRE BEJTIN MINEL-MUSLIMINE
  51,37,WE TEREKNA FIHA ‘AJETEN LILLEDHINE JEHAFUNEL-’ADHABEL-’ELIME
  51,38,WE FI MUSA ‘IDH ‘ERSELNAHU ‘ILA FIR’AWNE BISULTANIN MUBININ
  51,39,FETEWELLA BIRUKNIHI WE KALE SAHIRUN ‘EW MEXHNUNUN
  51,40,FE’EHADHNAHU WE XHUNUDEHU FENEBEDHNAHUM FIL-JEMMI WE HUWE MULIMUN
  51,41,WE FI ‘ADIN ‘IDH ‘ERSELNA ‘ALEJHIMU ER-RIHEL-’AKIME
  51,42,MA TEDHERU MIN SHEJ’IN ‘ETET ‘ALEJHI ‘ILLA XHE’ALET/HU KALRREMIMI
  51,43,WE FI THEMUDE ‘IDH KILE LEHUM TEMETTA’U HETTA HININ
  51,44,FE’ATEW ‘AN ‘EMRI RABBIHIM FE’EHADHET/HUMU ES-SA’IKATU WE HUM JENDHURUNE
  51,45,FEMA ESTETA’U MIN KIJAMIN WE MA KANU MUNTESIRINE
  51,46,WE KAWME NUHIN MIN KABLU ‘INNEHUM KANU KAWMÆN FASIKINE
  51,47,WE ES-SEMA’E BENEJNAHA BI’EJJDIN WE ‘INNA LEMUSI’UNE
  51,48,WEL-’ERDE FERESHNAHA FENI’MEL-MAHIDUNE
  51,49,WE MIN KULLI SHEJ’IN HALEKNA ZEWXHEJNI LE’ALLEKUM TEDHEKKERUNE
  51,50,FEFIRRU ‘ILA ELLAHI ‘INNI LEKUM MINHU NEDHIRUN MUBINUN
  51,51,WE LA TEXH’ALU ME’A ELLAHI ‘ILEHÆN ‘AHARE ‘INNI LEKUM MINHU NEDHIRUN MUBINUN
  51,52,KEDHALIKE MA ‘ETAL-LEDHINE MIN KABLIHIM MIN RESULIN ‘ILLA KALU SAHIRUN ‘EW MEXHNUNUN
  51,53,‘ETEWASEW BIHI BEL HUM KAWMUN TAGUNE
  51,54,FETEWELLE ‘ANHUM FEMA ‘ENTE BIMELUMIN
  51,55,WE DHEKKIR FE’INNE EDH-DHIKRA TENFA’UL-MU’UMININE
  51,56,WE MA HALEKTUL-XHINNE WEL-’INSE ‘ILLA LIJA’BUDUNI
  51,57,MA ‘URIDU MINHUM MIN RIZKIN WE MA ‘URIDU ‘EN JUT’IMUNI
  51,58,‘INNALL-LLAHE HUWE ER-REZZAKU DHUL-KUWETIL-METINU
  51,59,FE’INNE LILLEDHINE DHELEMU DHENUBÆN MITHLE DHENUBI ‘ESHABIHIM FELA JESTA’XHILUNI
  51,60,FEWEJLUN LILLEDHINE KEFERU MIN JEWMIHIMUL-LEDHI JU’ADUNE
  52,1,WET-TURI
  52,2,WE KITABIN MESTURIN
  52,3,FI REKKIN MENSHURIN
  52,4,WEL-BEJTIL-MA’MURI
  52,5,WE ES-SEKFIL-MERFU’I
  52,6,WEL-BEHRIL-MESXHURI
  52,7,‘INNE ‘ADHABE RABBIKE LEWAKI’UN
  52,8,MA LEHU MIN DAFI’IN
  52,9,JEWME TEMURU ES-SEMA’U MEWRÆN
  52,10,WE TESIRUL-XHIBALU SEJRÆN
  52,11,FEWEJLUN JEWME’IDHIN LILMUKEDHDHIBINE
  52,12,EL-LEDHINE HUM FI HAWDIN JEL’ABUNE
  52,13,JEWME JUDA’’UNE ‘ILA NARI XHEHENNEME DA’’ÆN
  52,14,HEDHIHI EN-NARU ELLETI KUNTUM BIHA TUKEDHDHIBUNE
  52,15,‘EFESIHRUN HADHA ‘EM ‘ENTUM LA TUBSIRUNE
  52,16,ESLEWHA FASBIRU ‘EW LA TESBIRU SEWA’UN ‘ALEJKUM ‘INNEMA TUXHZEWNE MA KUNTUM TA’MELUNE
  52,17,‘INNEL-MUTTEKINE FI XHENNATIN WE NA’IMIN
  52,18,FAKIHINE BIMA ‘ATAHUM REBBUHUM WE WEKAHUM REBBUHUM ‘ADHABEL-XHEHIMI
  52,19,KULU WE ESHREBU HENI’ÆN BIMA KUNTUM TA’MELUNE
  52,20,MUTTEKI’INE ‘ALA SURURIN MESFUFETIN WE ZEWWEXHNAHUM BIHURIN ‘ININ
  52,21,WEL-LEDHINE ‘AMENU WE ETTEBE’AT/HUM DHURRIJETUHUM BI’IMANIN ‘ELHEKNA BIHIM DHURRIJETEHUM WE MA ‘ELETNAHUM MIN ‘AMELIHIM MIN SHEJ’IN KULLU EMRI’IN BIMA KESEBE REHINUN
  52,22,WE ‘EMDEDNAHUM BIFAKIHETIN WE LEHMIN MIMMA JESHTEHUNE
  52,23,JETENAZA’UNE FIHA KE’SÆN LA LEGWUN FIHA WE LA TE’THIMUN
  52,24,WE JETUFU ‘ALEJHIM GILMANUN LEHUM KE’ENNEHUM LU’ULU’UUN MEKNUNUN
  52,25,WE ‘EKBELE BA’DUHUM ‘ALA BA’DIN JETESA’ELUNE
  52,26,KALU ‘INNA KUNNA KABLU FI ‘EHLINA MUSHFIKINE
  52,27,FEMENNEL-LAHU ‘ALEJNA WE WEKANA ‘ADHABE ES-SEMUMI
  52,28,‘INNA KUNNA MIN KABLU NED’UHU ‘INNEHU HUWEL-BERRU ER-REHIMU
  52,29,FEDHEKKIR FEMA ‘ENTE BINI’METI RABBIKE BIKAHININ WE LA MEXHNUNIN
  52,30,‘EM JEKULUNE SHA’IRUN NETEREBBESU BIHI REJBEL-MENUNI
  52,31,KUL TEREBBESU FE’INNI ME’AKUM MINEL-MUTEREBBISINE
  52,32,‘EM TE’MURUHUM ‘EHLAMUHUM BIHEDHA ‘EM HUM KAWMUN TAGUNE
  52,33,‘EM JEKULUNE TEKAWWELEHU BEL LA JU’UMINUNE
  52,34,FELJE’TU BIHEDITHIN MITHLIHI ‘IN KANU SADIKINE
  52,35,‘EM HULIKU MIN GAJRI SHEJ’IN ‘EM HUMUL-HALIKUNE
  52,36,‘EM HALEKU ES-SEMAWATI WEL-’ERDE BEL LA JUKINUNE
  52,37,‘EM ‘INDEHUM HAZA’INU RABBIKE ‘EM HUMUL-MUSEJTIRUNE
  52,38,‘EM LEHUM SULLEMUN JESTEMI’UNE FIHI FELJE’TI MUSTEMI’UHUM BISULTANIN MUBININ
  52,39,‘EM LEHUL-BENATU WE LEKUMUL-BENUNE
  52,40,‘EM TES’ELUHUM ‘EXHRÆN FEHUM MIN MEGREMIN MUTHKALUNE
  52,41,‘EM ‘INDEHUMUL-GAJBU FEHUM JEKTUBUNE
  52,42,‘EM JURIDUNE KEJDÆN FE-EL-LEDHINE KEFERU HUMUL-MEKIDUNE
  52,43,‘EM LEHUM ‘ILEHUN GAJRU ELLAHI SUBHANEL-LAHI ‘AMMA JUSHRIKUNE
  52,44,WE ‘IN JEREW KISFÆN MINE ES-SEMA’I SAKITÆN JEKULU SEHABUN MERKUMUN
  52,45,FEDHERHUM HETTA JULAKU JEWMEHUMUL-LEDHI FIHI JUS’AKUNE
  52,46,JEWME LA JUGNI ‘ANHUM KEJDUHUM SHEJ’ÆN WE LA HUM JUNSERUNE
  52,47,WE ‘INNE LILLEDHINE DHELEMU ‘ADHABÆN DUNE DHALIKE WE LEKINNE ‘EKTHEREHUM LA JA’LEMUNE
  52,48,WE ESBIR LIHUKMI RABBIKE FE’INNEKE BI’A’JUNINA WE SEBBIH BIHEMDI RABBIKE HINE TEKUMU
  52,49,WE MINEL-LEJLI FESEBBIHHU WE ‘IDBARE EN-NUXHUMI
  53,1,WE EN-NEXHMI ‘IDHA HEWA
  53,2,MA DELLE SAHIBUKUM WE MA GAWA
  53,3,WE MA JENTIKU ‘ANIL-HEWA
  53,4,‘IN HUWE ‘ILLA WEHJUN JUHA
  53,5,‘ALLEMEHU SHEDIDUL-KUWA
  53,6,DHU MIRRETIN FASTEWA
  53,7,WE HUWE BIL-’UFUKIL-’A’LA
  53,8,THUMME DENA FETEDELLA
  53,9,FEKANE KABE KAWSEJNI ‘EW ‘EDNA
  53,10,FE’EWHA ‘ILA ‘ABDIHI MA ‘EWHA
  53,11,MA KEDHEBEL-FU’UADU MA RE’A
  53,12,‘EFETUMARUNEHU ‘ALA MA JERA
  53,13,WE LEKAD RE’AHU NEZLETEN ‘UHRA
  53,14,‘INDE SIDRETIL-MUNTEHA
  53,15,‘INDEHA XHENNETUL-ME’WA
  53,16,‘IDH JEGSHA ES-SIDRETE MA JEGSHA
  53,17,MA ZAGAL-BESERU WE MA TEGA
  53,18,LEKAD RE’A MIN ‘AJATI RABBIHIL-KUBRA
  53,19,‘EFERE’EJTUMUL-LATE WEL-’UZZA
  53,20,WE MENÆTE ETH-THALITHETEL-’UHRA
  53,21,‘ELEKUMU EDH-DHEKERU WE LEHUL-’UNTHA
  53,22,TILKE ‘IDHÆN KISMETUN DIZA
  53,23,‘IN HIJE ‘ILLA ‘ESMA’UN SEMMEJTUMUHA ‘ENTUM WE ‘ABA’UUKUM MA ‘ENZELEL-LAHU BIHA MIN SULTANIN ‘IN JETTEBI’UNE ‘ILLA EDH-DHENNE WE MA TEHWAL-’ENFUSU WE LEKAD XHA’EHUM MIN RABBIHIMUL-HUDA
  53,24,‘EM LIL’INSANI MA TEMENNA
  53,25,FELILLAHIL-’AHIRETU WEL-’ULA
  53,26,WE KEM MIN MELEKIN FI ES-SEMAWATI LA TUGNI SHEFA’ATUHUM SHEJ’ÆN ‘ILLA MIN BA’DI ‘EN JE’DHENEL-LAHU LIMEN JESHA’U WE JERDA
  53,27,‘INNEL-LEDHINE LA JU’UMINUNE BIL-’AHIRETI LEJUSEMMUNEL-MELA’IKETE TESMIJETEL-’UNTHA
  53,28,WE MA LEHUM BIHI MIN ‘ILMIN ‘IN JETTEBI’UNE ‘ILLA EDH-DHENNE WE ‘INNE EDH-DHENNE LA JUGNI MINEL-HEKKI SHEJ’ÆN
  53,29,FE’A’RID ‘AN MEN TEWELLA ‘AN DHIKRINA WE LEM JURID ‘ILLAL-HEJÆTE ED-DUNJA
  53,30,DHALIKE MEBLEGUHUM MINEL-’ILMI ‘INNE REBBEKE HUWE ‘A’LEMU BIMEN DELLE ‘AN SEBILIHI WE HUWE ‘A’LEMU BIMENI EHTEDA
  53,31,WE LILLEHI MA FI ES-SEMAWATI WE MA FIL-’ERDI LIJEXHZIJEL-LEDHINE ‘ESA’U BIMA ‘AMILU WE JEXHZIJEL-LEDHINE ‘EHSENU BIL-HUSNA
  53,32,EL-LEDHINE JEXHTENIBUNE KEBA’IREL-’ITHMI WEL-FEWAHISHE ‘ILLAL-LEMEME ‘INNE REBBEKE WASI’UL-MEGFIRETI HUWE ‘A’LEMU BIKUM ‘IDH ‘ENSHE’EKUM MINEL-’ERDI WE ‘IDH ‘ENTUM ‘EXHINNETUN FI BUTUNI ‘UMMEHATIKUM FELA TUZEKKU ‘ENFUSEKUM HUWE ‘A’LEMU BIMENI ETTEKA
  53,33,‘EFERE’EJTEL-LEDHI TEWELLA
  53,34,WE ‘A’TA KALILÆN WE ‘EKDA
  53,35,‘A’INDEHU ‘ILMUL-GAJBI FEHUWE JERA
  53,36,‘EM LEM JUNEBBE’ BIMA FI SUHUFI MUSA
  53,37,WE ‘IBRAHIMEL-LEDHI WE FFA
  53,38,‘ELLA TEZIRU WAZIRETUN WIZRE ‘UHRA
  53,39,WE ‘EN LEJSE LIL’INSANI ‘ILLA MA SA’A
  53,40,WE ‘ENNE SA’JEHU SEWFE JURA
  53,41,THUMME JUXHZAHUL-XHEZA’EL-’EWFA
  53,42,WE ‘ENNE ‘ILA RABBIKEL-MUNTEHA
  53,43,WE ‘ENNEHU HUWE ‘EDHEKE WE ‘EBKA
  53,44,WE ‘ENNEHU HUWE ‘EMATE WE ‘EHJA
  53,45,WE ‘ENNEHU HALEKA EZ-ZEWXHEJNI EDH-DHEKERE WEL-’UNTHA
  53,46,MIN NUTFETIN ‘IDHA TUMNA
  53,47,WE ‘ENNE ‘ALEJHI EN-NESH’ETEL-’UHRA
  53,48,WE ‘ENNEHU HUWE ‘EGNA WE ‘EKNA
  53,49,WE ‘ENNEHU HUWE REBBU ESH-SHI’RA
  53,50,WE ‘ENNEHU ‘EHLEKE ‘ADÆNL-’ULA
  53,51,WE THEMUDE FEMA ‘EBKA
  53,52,WE KAWME NUHIN MIN KABLU ‘INNEHUM KANU HUM ‘EDHLEME WE ‘ETGA
  53,53,WEL-MU’UTEFIKETE ‘EHWA
  53,54,FEGASHSHAHA MA GASHSHA
  53,55,FEBI’EJJI ‘ALA’I RABBIKE TETEMARA
  53,56,HADHA NEDHIRUN MINE EN-NUDHURIL-’ULA
  53,57,‘EZIFETIL-’AZIFETU
  53,58,LEJSE LEHA MIN DUNI ELLAHI KASHIFETUN
  53,59,‘EFEMIN HADHAL-HEDITHI TA’XHEBUNE
  53,60,WE TEDHEKUNE WE LA TEBKUNE
  53,61,WE ‘ENTUM SAMIDUNE
  53,62,FASXHUDU LILLAHI WE A’BUDU
  54,1,EKTEREBETI ES-SA’ATU WE ENSHEKKAL-KAMERU
  54,2,WE ‘IN JEREW ‘AJETEN JU’RIDU WE JEKULU SIHRUN MUSTEMIRRUN
  54,3,WE KEDHDHEBU WE ETTEBA’U ‘EHWA’EHUM WE KULLU ‘EMRIN MUSTEKIRRUN
  54,4,WE LEKAD XHA’EHUM MINEL-’ENBA’I MA FIHI MUZDEXHERUN
  54,5,HIKMETUN BALIGATUN FEMA TUGNI EN-NUDHURU
  54,6,FETEWELLE ‘ANHUM JEWME JED’U ED-DA’I ‘ILA SHEJ’IN NUKURIN
  54,7,HUSHSHA’ÆN ‘EBSARUHUM JEHRUXHUNE MINEL-’EXHDATHI KE’ENNEHUM XHERADUN MUNTESHIRUN
  54,8,MUHTI’INE ‘ILA ED-DA’I JEKULUL-KAFIRUNE HADHA JEWMUN ‘ASIRUN
  54,9,KEDHDHEBET KABLEHUM KAWMU NUHIN FEKEDHDHEBU ‘ABDENA WE KALU MEXHNUNUN WE EZDUXHIRE
  54,10,FEDA’A REBBEHU ‘ENNI MEGLUBUN FANTESIR
  54,11,FEFETEHNA ‘EBWABE ES-SEMA’I BIMA’IN MUNHEMIRIN
  54,12,WE FEXHXHERNAL-’ERDE ‘UJUNÆN FALTEKAL-MA’U ‘ALA ‘EMRIN KAD KUDIRE
  54,13,WE HEMELNAHU ‘ALA DHATI ‘ELWAHIN WE DUSURIN
  54,14,TEXHRI BI’A’JUNINA XHEZA’EN LIMEN KANE KUFIRE
  54,15,WE LEKAD TEREKNAHA ‘AJETEN FEHEL MIN MUDDEKIRIN
  54,16,FEKEJFE KANE ‘ADHABI WE NUDHURI
  54,17,WE LEKAD JESSERNAL-KUR’ANE LILDHDHIKRI FEHEL MIN MUDDEKIRIN
  54,18,KEDHDHEBET ‘ADUN FEKEJFE KANE ‘ADHABI WE NUDHURI
  54,19,‘INNA ‘ERSELNA ‘ALEJHIM RIHÆN SERSERÆN FI JEWMI NEHSIN MUSTEMIRRIN
  54,20,TENZI’U EN-NASE KE’ENNEHUM ‘A’XHAZU NEHLIN MUNKA’IRIN
  54,21,FEKEJFE KANE ‘ADHABI WE NUDHURI
  54,22,WE LEKAD JESSERNAL-KUR’ANE LILDHDHIKRI FEHEL MIN MUDDEKIRIN
  54,23,KEDHDHEBET THEMUDU BIN-NUDHURI
  54,24,FEKALU ‘EBESHERÆN MINNA WAHIDÆN NETTEBI’UHU ‘INNA ‘IDHÆN LEFI DELALIN WE SU’URIN
  54,25,‘E’UULKIJE EDH-DHIKRU ‘ALEJHI MIN BEJNINA BEL HUWE KEDHDHABUN ‘ESHIRUN
  54,26,SEJA’LEMUNE GADÆN MENIL-KEDHDHABUL-’ESHIRU
  54,27,‘INNA MURSILU EN-NAKATI FITNETEN LEHUM FARTEKIBHUM WE ESTEBIR
