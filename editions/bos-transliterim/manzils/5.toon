quran[856]{c,v,t}:
  26,1,TA-SIN-MIM
  26,2,TILKE ‘AJATUL-KITABIL-MUBINI
  26,3,LE’ALLEKE BAHI’UN NEFSEKE ‘ELLA JEKUNU MU’UMININE
  26,4,‘IN NESHE’ NUNEZZIL ‘ALEJHIM MINE ES-SEMA’I ‘AJETEN FEDHELLET ‘A’NAKUHUM LEHA HADI’INE
  26,5,WE MA JE’TIHIM MIN DHIKRIN MINE ER-REHMANI MUHDETHIN ‘ILLA KANU ‘ANHU MU’RIDINE
  26,6,FEKAD KEDHDHEBU FESEJE’TIHIM ‘ENBA’U MA KANU BIHI JESTEHZI’UN
  26,7,‘EWELEM JEREW ‘ILAL-’ERDI KEM ‘ENBETNA FIHA MIN KULLI ZEWXHIN KERIMIN
  26,8,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,9,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,10,WE ‘IDH NADA REBBUKE MUSA ‘ENI E’TIL-KAWME EDH-DHALIMINE
  26,11,KAWME FIR’AWNE ‘ELA JETTEKUNE
  26,12,KALE RABBI ‘INNI ‘EHAFU ‘EN JUKEDHDHIBUNI
  26,13,WE JEDIKU SEDRI WE LA JENTELIKU LISANI FE’ERSIL ‘ILA HARUNE
  26,14,WE LEHUM ‘ALEJJE DHENBUN FE’EHAFU ‘EN JEKTULUNI
  26,15,KALE KELLA FADH/HEBA BI’AJATINA ‘INNA ME’AKUM MUSTEMI’UNE
  26,16,FE’TIJA FIR’AWNE FEKULA ‘INNA RESULU RABBIL-’ALEMINE
  26,17,‘EN ‘ERSIL ME’ANA BENI ‘ISRA’ILE
  26,18,KALE ‘ELEM NUREBBIKE FINA WELIDÆN WE LEBITHTE FINA MIN ‘UMURIKE SININE
  26,19,WE FE’ALTE FA’LETEKEL-LETI FE’ALTE WE ‘ENTE MINEL-KAFIRINE
  26,20,KALE FE’ALTUHA ‘IDHÆN WE ‘ENA MINE ED-DALLIN
  26,21,FEFERERTU MINKUM LEMMA HIFTUKUM FEWEHEBE LI RABBI HUKMÆN WE XHE’ALENI MINEL-MURSELINE
  26,22,WE TILKE NI’METUN TEMUNNUHA ‘ALEJJE ‘EN ‘ABBEDTE BENI ‘ISRA’ILE
  26,23,KALE FIR’AWNU WE MA REBBUL-’ALEMINE
  26,24,KALE REBBU ES-SEMAWATI WEL-’ERDI WE MA BEJNEHUMA ‘IN KUNTUM MUKININE
  26,25,KALE LIMEN HEWLEHU ‘ELA TESTEMI’UNE
  26,26,KALE REBBUKUM WE REBBU ‘ABA’IKUMUL-’EWWELINE
  26,27,KALE ‘INNE RESULEKUMUL-LEDHI ‘URSILE ‘ILEJKUM LEMEXHNUNUN
  26,28,KALE REBBUL-MESHRIKI WEL-MEGRIBI WE MA BEJNEHUMA ‘IN KUNTUM TA’KILUNE
  26,29,KALE LE’INI ETTEHADHTE ‘ILEHÆN GAJRI LE’EXH’ALENNEKE MINEL-MESXHUNINE
  26,30,KALE ‘EWELEW XHI’TUKE BISHEJ’IN MUBININ
  26,31,KALE FE’TI BIHI ‘IN KUNTE MINE ES-SADIKINE
  26,32,FE’ELKA ‘ASAHU FE’IDHA HIJE THU’BANUN MUBINUN
  26,33,WE NEZE’A JEDEHU FE’IDHA HIJE BEJDA’U LILNNADHIRINE
  26,34,KALE LILMELE’I HEWLEHU ‘INNE HADHA LESAHIRUN ‘ALIMUN
  26,35,JURIDU ‘EN JUHRIXHEKUM MIN ‘ERDIKUM BISIHRIHI FEMADHA TE’MURUNE
  26,36,KALU ‘ERXHIHI WE ‘EHAHU WE EB’ATH FIL-MEDA’INI HASHIRINE
  26,37,JE’TUKE BIKULLI SEHHARIN ‘ALIMIN
  26,38,FEXHUMI’A ES-SEHERETU LIMIKATI JEWMIN MA’LUMIN
  26,39,WE KILE LILNNASI HEL ‘ENTUM MUXHTEMI’UNE
  26,40,LE’ALLENA NETTEBI’U ES-SEHERETE ‘IN KANU HUMUL-GALIBINE
  26,41,FELEMMA XHA’E ES-SEHERETU KALU LIFIR’AWNE ‘E’INNE LENA LE’EXHRÆN ‘IN KUNNA NEHNUL-GALIBINE
  26,42,KALE NE’AM WE ‘INNEKUM ‘IDHÆN LEMINEL-MUKARREBINE
  26,43,KALE LEHUM MUSA ‘ELKU MA ‘ENTUM MULKUNE
  26,44,FE’ELKAW HIBALEHUM WE ‘ISIJEHUM WE KALU BI’IZZETI FIR’AWNE ‘INNA LENEHNUL-GALIBUNE
  26,45,FE’ELKA MUSA ‘ASAHU FE’IDHA HIJE TELKAFU MA JE’FIKUNE
  26,46,FE’ULKIJE ES-SEHERETU SAXHIDINE
  26,47,KALU ‘AMENNA BIREBBIL-’ALEMINE
  26,48,REBBI MUSA WE HARUNE
  26,49,KALE ‘AMENTUM LEHU KABLE ‘EN ‘ADHENE LEKUM ‘INNEHU LEKEBIRUKUMUL-LEDHI ‘ALLEMEKUMU ES-SIHRE FELESEWFE TA’LEMUNE LE’UKATTI’ANNE ‘EJDIJEKUM WE ‘ERXHULEKUM MIN HILAFIN WE LE’USELLIBENNEKUM ‘EXHMA’INE
  26,50,KALU LA DEJRE ‘INNA ‘ILA RABBINA MUNKALIBUNE
  26,51,‘INNA NETMA’U ‘EN JEGFIRE LENA REBBUNA HATAJANA ‘EN KUNNA ‘EWWELEL-MU’UMININE
  26,52,WE ‘EWHEJNA ‘ILA MUSA ‘EN ‘ESRI BI’IBADI ‘INNEKUM MUTTEBA’UNE
  26,53,FE’ERSELE FIR’AWNU FIL-MEDA’INI HASHIRINE
  26,54,‘INNE HA’UULA’ LESHIRDHIMETUN KALILUNE
  26,55,WE ‘INNEHUM LENA LEGA’IDHUNE
  26,56,WE ‘INNA LEXHEMI’UN HADHIRUNE
  26,57,FE’EHREXHNAHUM MIN XHENNATIN WE ‘UJUNIN
  26,58,WE KUNUZIN WE MEKAMIN KERIMIN
  26,59,KEDHALIKE WE ‘EWRETHNAHA BENI ‘ISRA’ILE
  26,60,FE’ETBA’UHUM MUSHRIKINE
  26,61,FELEMMA TERA’AL-XHEM’ANI KALE ‘ESHABU MUSA ‘INNA LEMUDREKUNE
  26,62,KALE KELLA ‘INNE MA’IJE RABBI SEJEHDINI
  26,63,FE’EWHEJNA ‘ILA MUSA ‘ENI EDRIB BI’ASAKEL-BEHRE FANFELEKA FEKANE KULLU FIRKIN KALTTEWDIL-’ADHIMI
  26,64,WE ‘EZLEFNA THEMMEL-’AHARINE
  26,65,WE ‘ENXHEJNA MUSA WE MEN ME’AHU ‘EXHMA’INE
  26,66,THUMME ‘EGREKNAL-’AHARINE
  26,67,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,68,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,69,WE ETLU ‘ALEJHIM NEBE’E ‘IBRAHIME
  26,70,‘IDH KALE LI’EBIHI WE KAWMIHI MA TA’BUDUNE
  26,71,KALU NA’BUDU ‘ESNAMÆN FENEDHELLU LEHA ‘AKIFINE
  26,72,KALE HEL JESMA’UNEKUM ‘IDH TED’UNE
  26,73,‘EW JENFA’UNEKUM ‘EW JEDURRUNE
  26,74,KALU BEL WEXHEDNA ‘ABA’ENA KEDHALIKE JEF’ALUNE
  26,75,KALE ‘EFERE’EJTUM MA KUNTUM TA’BUDUNE
  26,76,‘ENTUM WE ‘ABA’UUKUMUL-’EKDEMUNE
  26,77,FE’INNEHUM ‘ADUWUN LI ‘ILLA REBBEL-’ALEMINE
  26,78,EL-LEDHI HALEKANI FEHUWE JEHDINI
  26,79,WEL-LEDHI HUWE JUT’IMUNI WE JESKINI
  26,80,WE ‘IDHA MERIDTU FEHUWE JESHFINI
  26,81,WEL-LEDHI JUMITUNI THUMME JUHJINI
  26,82,WEL-LEDHI ‘ETMA’U ‘EN JEGFIRE LI HATI’ETI JEWME ED-DINI
  26,83,REBBI HEB LI HUKMÆN WE ‘ELHIKNI BIS-SALIHINE
  26,84,WE EXH’AL LI LISANE SIDKIN FIL-’AHIRINE
  26,85,WE EXH’ALNI MIN WERETHETI XHENNETI EN-NA’IMI
  26,86,WE EGFIR LI’EBI ‘INNEHU KANE MINE ED-DALLINE
  26,87,WE LA TUHZINI JEWME JUB’ATHUNE
  26,88,JEWME LA JENFA’U MALUN WE LA BENUNE
  26,89,‘ILLA MEN ‘ETA ELLAHE BIKALBIN SELIMIN
  26,90,WE ‘UZLIFETIL-XHENNETU LILMUTTEKINE
  26,91,WE BURRIZETIL-XHEHIMU LILGAWINE
  26,92,WE KILE LEHUM ‘EJNE MA KUNTUM TA’BUDUNE
  26,93,MIN DUNI ELLAHI HEL JENSURUNEKUM ‘EW JENTESIRUNE
  26,94,FEKUBKIBU FIHA HUM WEL-GAWUNE
  26,95,WE XHUNUDU ‘IBLISE ‘EXHMA’UNE
  26,96,KALU WE HUM FIHA JEHTESIMUNE
  26,97,TE-ELLAHI ‘IN KUNNA LEFI DELALIN MUBININ
  26,98,‘IDH NUSEWWIKUM BIREBBIL-’ALEMINE
  26,99,WE MA ‘EDELLENA ‘ILLAL-MUXHRIMUNE
  26,100,FEMA LENA MIN SHAFI’INE
  26,101,WE LA SEDIKIN HEMIMIN
  26,102,FELEW ‘ENNE LENA KERRETEN FENEKUNE MINEL-MU’UMININE
  26,103,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,104,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,105,KEDHDHEBET KAWMU NUHINL-MURSELINE
  26,106,‘IDH KALE LEHUM ‘EHUHUM NUHUN ‘ELA TETTEKUNE
  26,107,‘INNI LEKUM RESULUN ‘EMINUN
  26,108,FATTEKU ELLAHE WE ‘ETI’UNI
  26,109,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRI ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,110,FATTEKU ELLAHE WE ‘ETI’UNI
  26,111,KALU ‘ENU’UMINU LEKE WE ETTEBE’AKEL-’ERDHELUNE
  26,112,KALE WE MA ‘ILMI BIMA KANU JA’MELUNE
  26,113,‘IN HISABUHUM ‘ILLA ‘ALA RABBI LEW TESH’URUNE
  26,114,WE MA ‘ENA BITARIDIL-MU’UMININE
  26,115,‘IN ‘ENA ‘ILLA NEDHIRUN MUBINUN
  26,116,KALU LE’IN LEM TENTEHI JA NUHU LETEKUNENNE MINEL-MERXHUMINE
  26,117,KALE RABBI ‘INNE KAWMI KEDHDHEBUNI
  26,118,FAFTEH BEJNI WE BEJNEHUM FETHÆN WE NEXHXHINI WE MEN MA’I MINEL-MU’UMININE
  26,119,FE’ENXHEJNAHU WE MEN ME’AHU FIL-FULKIL-MESHHUNI
  26,120,THUMME ‘EGREKNA BA’DUL-BAKINE
  26,121,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,122,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,123,KEDHDHEBET ‘ADUNL-MURSELINE
  26,124,‘IDH KALE LEHUM ‘EHUHUM HUDUN ‘ELA TETTEKUNE
  26,125,‘INNI LEKUM RESULUN ‘EMINUN
  26,126,FATTEKU ELLAHE WE ‘ETI’UNI
  26,127,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRI ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,128,‘ETEBNUNE BIKULLI RI’IN ‘AJETEN TA’BETHUNE
  26,129,WE TETTEHIDHUNE MESANI’A LE’ALLEKUM TEHLUDUNE
  26,130,WE ‘IDHA BETESHTUM BETESHTUM XHEBBARINE
  26,131,FATTEKU ELLAHE WE ‘ETI’UNI
  26,132,WE ETTEKUL-LEDHI ‘EMEDDEKUM BIMA TA’LEMUNE
  26,133,‘EMEDDEKUM BI’EN’AMIN WE BENINE
  26,134,WE XHENNATIN WE ‘UJUNIN
  26,135,‘INNI ‘EHAFU ‘ALEJKUM ‘ADHABE JEWMIN ‘ADHIMIN
  26,136,KALU SEWA’UN ‘ALEJNA ‘EWE’ADHTE ‘EM LEM TEKUN MINEL-WA’IDHINE
  26,137,‘IN HADHA ‘ILLA HULUKUL-’EWWELINE
  26,138,WE MA NEHNU BIMU’ADHDHEBINE
  26,139,FEKEDHDHEBUHU FE’EHLEKNAHUM ‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,140,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,141,KEDHDHEBET THEMUDUL-MURSELINE
  26,142,‘IDH KALE LEHUM ‘EHUHUM SALIHUN ‘ELA TETTEKUNE
  26,143,‘INNI LEKUM RESULUN ‘EMINUN
  26,144,FATTEKU ELLAHE WE ‘ETI’UNI
  26,145,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRIJE ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,146,‘ETUTREKUNE FI MA HAHUNA ‘AMININE
  26,147,FI XHENNATIN WE ‘UJUNIN
  26,148,WE ZURU’IN WE NEHLIN TEL’UHA HEDIMUN
  26,149,WE TENHITUNE MINEL-XHIBALI BUJUTÆN FARIHINE
  26,150,FATTEKU ELLAHE WE ‘ETI’UNI
  26,151,WE LA TUTI’U ‘EMREL-MUSRIFINE
  26,152,EL-LEDHINE JUFSIDUNE FIL-’ERDI WE LA JUSLIHUNE
  26,153,KALU ‘INNEMA ‘ENTE MINEL-MUSEHHERINE
  26,154,MA ‘ENTE ‘ILLA BESHERUN MITHLUNA FE’TI BI’AJETIN ‘IN KUNTE MINE ES-SADIKINE
  26,155,KALE HEDHIHI NAKATUN LEHA SHIRBUN WE LEKUM SHIRBU JEWMIN MA’LUMIN
  26,156,WE LA TEMESSUHA BISU’IN FEJE’HUDHEKUM ‘ADHABU JEWMIN ‘ADHIMIN
  26,157,FE’AKARUHA FE’ESBEHU NADIMINE
  26,158,FE’EHADHEHUMUL-’ADHABU ‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,159,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,160,KEDHDHEBET KAWMU LUTINL-MURSELINE
  26,161,‘IDH KALE LEHUM ‘EHUHUM LUTUN ‘ELA TETTEKUNE
  26,162,‘INNI LEKUM RESULUN ‘EMINUN
  26,163,FATTEKU ELLAHE WE ‘ETI’UNI
  26,164,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRIJE ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,165,‘ETE’TUNE EDH-DHUKRANE MINEL-’ALEMINE
  26,166,WE TEDHERUNE MA HALEKA LEKUM REBBUKUM MIN ‘EZWAXHIKUM BEL ‘ENTUM KAWMUN ‘ADUNE
  26,167,KALU LE’IN LEM TENTEHI JA LUTU LETEKUNENNE MINEL-MUHREXHINE
  26,168,KALE ‘INNI LI’AMELIKUM MINEL-KALINE
  26,169,REBBI NEXHXHINI WE ‘EHLI MIMMA JA’MELUNE
  26,170,FENEXHXHEJNAHU WE ‘EHLEHU ‘EXHMA’INE
  26,171,‘ILLA ‘AXHUZÆN FIL-GABIRINE
  26,172,THUMME DEMMERNAL-’AHARINE
  26,173,WE ‘EMTERNA ‘ALEJHIM METERÆN FESA’E METERUL-MUNDHERINE
  26,174,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,175,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,176,KEDHDHEBE ‘ESHABUL-’EJKETIL-MURSELINE
  26,177,‘IDH KALE LEHUM SHU’AJBUN ‘ELA TETTEKUNE
  26,178,‘INNI LEKUM RESULUN ‘EMINUN
  26,179,FATTEKU ELLAHE WE ‘ETI’UNI
  26,180,WE MA ‘ES’ELUKUM ‘ALEJHI MIN ‘EXHRIN ‘IN ‘EXHRIJE ‘ILLA ‘ALA RABBIL-’ALEMINE
  26,181,‘EWFUL-KEJLE WE LA TEKUNU MINEL-MUHSIRINE
  26,182,WE ZINU BIL-KISTASIL-MUSTEKIMI
  26,183,WE LA TEBHASU EN-NASE ‘ESHJA’EHUM WE LA TA’THEW FIL-’ERDI MUFSIDINE
  26,184,WE ETTEKUL-LEDHI HALEKAKUM WEL-XHIBILLETEL-’EWWELINE
  26,185,KALU ‘INNEMA ‘ENTE MINEL-MUSEHHERINE
  26,186,WE MA ‘ENTE ‘ILLA BESHERUN MITHLUNA WE ‘IN NEDHUNNUKE LEMINEL-KADHIBINE
  26,187,FE’ESKIT ‘ALEJNA KISEFÆN MINE ES-SEMA’I ‘IN KUNTE MINE ES-SADIKINE
  26,188,KALE RABBI ‘A’LEMU BIMA TA’MELUNE
  26,189,FEKEDHDHEBUHU FE’EHADHEHUM ‘ADHABU JEWMI EDH-DHULLETI ‘INNEHU KANE ‘ADHABE JEWMIN ‘ADHIMIN
  26,190,‘INNE FI DHALIKE LE’AJETEN WE MA KANE ‘EKTHERUHUM MU’UMININE
  26,191,WE ‘INNE REBBEKE LEHUWEL-’AZIZU ER-REHIMU
  26,192,WE ‘INNEHU LETENZILU RABBIL-’ALEMINE
  26,193,NEZELE BIHI ER-RUHUL-’EMINU
  26,194,‘ALA KALBIKE LITEKUNE MINEL-MUNDHIRINE
  26,195,BILISANIN ‘AREBIJIN MUBININ
  26,196,WE ‘INNEHU LEFI ZUBURIL-’EWWELINE
  26,197,‘EWELEM JEKUN LEHUM ‘AJETEN ‘EN JA’LEMEHU ‘ULEMA’U BENI ‘ISRA’ILE
  26,198,WE LEW NEZZELNAHU ‘ALA BA’DIL-’A’XHEMINE
  26,199,FEKARE’EHU ‘ALEJHIM MA KANU BIHI MU’UMININE
  26,200,KEDHALIKE SELEKNAHU FI KULUBIL-MUXHRIMINE
  26,201,LA JU’UMINUNE BIHI HETTA JEREWL-’ADHABEL-’ELIME
  26,202,FEJE’TIJEHUM BEGTETEN WE HUM LA JESH’URUNE
  26,203,FEJEKULU HEL NEHNU MUNDHERUNE
  26,204,‘EFEBI’ADHABINA JESTA’XHILUNE
  26,205,‘EFERE’EJTE ‘IN METTA’NAHUM SININE
  26,206,THUMME XHA’EHUM MA KANU JU’ADUNE
  26,207,MA ‘EGNA ‘ANHUM MA KANU JUMETTA’UNE
  26,208,WE MA ‘EHLEKNA MIN KARJETIN ‘ILLA LEHA MUNDHIRUNE
  26,209,DHIKRA WE MA KUNNA DHALIMINE
  26,210,WE MA TENEZZELET BIHI ESH-SHEJATINU
  26,211,WE MA JENBEGI LEHUM WE MA JESTETI’UNE
  26,212,‘INNEHUM ‘ANI ES-SEM’I LEMA’ZULUNE
  26,213,FELA TED’U ME’A ELLAHI ‘ILEHÆN ‘AHARE FETEKUNE MINEL-MU’ADHDHEBINE
  26,214,WE ‘ENDHIR ‘ASHIRETEKEL-’EKREBINE
  26,215,WE EHFID XHENAHEKE LIMENI ETTEBE’AKE MINEL-MU’UMININE
  26,216,FE’IN ‘ASEWKE FEKUL ‘INNI BERI’UN MIMMA TA’MELUNE
  26,217,WE TEWEKKEL ‘ALEL-’AZIZI ER-REHIMI
  26,218,EL-LEDHI JERAKE HINE TEKUMU
  26,219,WE TEKALLUBEKE FI ES-SAXHIDINE
  26,220,‘INNEHU HUWE ES-SEMI’UL-’ALIMU
  26,221,HEL ‘UNEBBI’UKUM ‘ALA MEN TENEZZELU ESH-SHEJATINU
  26,222,TENEZZELU ‘ALA KULLI ‘EFFAKIN ‘ETHIMIN
  26,223,JULKUNE ES-SEM’A WE ‘EKTHERUHUM KADHIBUNE
  26,224,WE ESH-SHU’ARA’U JETTEBI’UHUMUL-GAWUNE
  26,225,‘ELEM TERA ‘ENNEHUM FI KULLI WADIN JEHIMUNE
  26,226,WE ‘ENNEHUM JEKULUNE MA LA JEF’ALUNE
  26,227,‘ILLAL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI WE DHEKERU ELLAHE KETHIRÆN WE ENTESERU MIN BA’DI MA DHULIMU WE SEJA’LEMUL-LEDHINE DHELEMU ‘EJJE MUNKALEBIN JENKALIBUNE
  27,1,TA-SIN TILKE ‘AJATUL-KUR’ANI WE KITABIN MUBININ
  27,2,HUDEN WE BUSHRA LILMU’UMININE
  27,3,EL-LEDHINE JUKIMUNE ES-SELÆTE WE JU’UTUNE EZ-ZEKÆTE WE HUM BIL-’AHIRETI HUM JUKINUNE
  27,4,‘INNEL-LEDHINE LA JU’UMINUNE BIL-’AHIRETI ZEJJENNA LEHUM ‘A’MALEHUM FEHUM JA’MEHUNE
  27,5,‘ULA’IKEL-LEDHINE LEHUM SU’UL-’ADHABI WE HUM FIL-’AHIRETI HUMUL-’EHSERUNE
  27,6,WE ‘INNEKE LETULEKKAL-KUR’ANE MIN LEDUN HEKIMIN ‘ALIMIN
  27,7,‘IDH KALE MUSA LI’HLIHI ‘INNI ‘ANESTU NARÆN SE’ATIKUM MINHA BIHABERIN ‘EW ‘ATIKUM BISHIHABIN KABESIN LE’ALLEKUM TESTELUNE
  27,8,FELEMMA XHA’EHA NUDIJE ‘EN BURIKE MEN FI EN-NARI WE MEN HEWLEHA WE SUBHANEL-LAHI RABBIL-’ALEMINE
  27,9,JA MUSA ‘INNEHU ‘ENALLAHUL-’AZIZUL-HEKIMU
  27,10,WE ‘ELKI ‘ASAKE FELEMMA RE’AHA TEHTEZZU KE’ENNEHA XHANNUN WELLA MUDBIRÆN WE LEM JU’AKKIB JA MUSA LA TEHAF ‘INNI LA JEHAFU LEDEJJEL-MURSELUNE
  27,11,‘ILLA MEN DHELEME THUMME BEDDELE HUSNÆN BA’DE SU’IN FE’INNI GAFURUN REHIMUN
  27,12,WE ‘EDHIL JEDEKE FI XHEJBIKE TEHRUXH BEJDA’E MIN GAJRI SU’IN FI TIS’I ‘AJATIN ‘ILA FIR’AWNE WE KAWMIHI ‘INNEHUM KANU KAWMÆN FASIKINE
  27,13,FELEMMA XHA’ET/HUM ‘AJATUNA MUBSIRETEN KALU HADHA SIHRUN MUBINUN
  27,14,WE XHEHEDU BIHA WE ESTEJKANET/HA ‘ENFUSUHUM DHULMÆN WE ‘ULUWÆN FANDHUR KEJFE KANE ‘AKIBETUL-MUFSIDINE
  27,15,WE LEKAD ‘ATEJNA DAWUDE WE SULEJMANE ‘ILMÆN WE KALAL-HEMDU LILLAHIL-LEDHI FEDDELENA ‘ALA KETHIRIN MIN ‘IBADIHIL-MU’UMININE
  27,16,WE WERITHE SULEJMANU DAWUDE WE KALE JA ‘EJJUHA EN-NASU ‘ULLIMNA MENTIKAT-TEJRI WE ‘UTINA MIN KULLI SHEJ’IN ‘INNE HADHA LEHUWEL-FEDLUL-MUBINU
  27,17,WE HUSHIRE LISULEJMANE XHUNUDUHU MINEL-XHINNI WEL-’INSI WET-TEJRI FEHUM JUZA’UNE
  27,18,HETTA ‘IDHA ‘ETEW ‘ALA WADI EN-NEMLI KALET NEMLETUN JA ‘EJJUHA EN-NEMLU EDHULU MESAKINEKUM LA JEHTIMENNEKUM SULEJMANU WE XHUNUDUHU WE HUM LA JESH’URUNE
  27,19,FETEBESSEME DAHIKÆN MIN KAWLIHA WE KALE RABBI ‘EWZI’NI ‘EN ‘ESHKURE NI’METEKEL-LETI ‘EN’AMTE ‘ALEJJE WE ‘ALA WE E-DEJJE WE ‘EN ‘A’MELE SALIHÆN TERDAHU WE ‘EDHILNI BIREHMETIKE FI ‘IBADIKE ES-SALIHINE
  27,20,WE TEFEKKADET-TEJRE FEKALE MA LI LA ‘ERAL-HUD/HUDE ‘EM KANE MINEL-GA’IBINE
  27,21,LE’U’ADHDHIBENNEHU ‘ADHABÆN SHEDIDÆN ‘EW LE’EDHBEHENNEHU ‘EW LEJE’TIJENI BISULTANIN MUBININ
  27,22,FEMEKETHE GAJRE BA’IDIN FEKALE ‘EHETTU BIMA LEM TUHIT BIHI WE XHI’TUKE MIN SEBE’IIN BINEBE’IIN JEKININ
  27,23,‘INNI WE XHEDTTU EMRE’ETEN TEMLIKUHUM WE ‘UTIJET MIN KULLI SHEJ’IN WE LEHA ‘ARSHUN ‘ADHIMUN
  27,24,WE XHEDTUHA WE KAWMEHA JESXHUDUNE LILSHSHEMSI MIN DUNI ELLAHI WE ZEJJENE LEHUMU ESH-SHEJTANU ‘A’MALEHUM FESEDDEHUM ‘ANI ES-SEBILI FEHUM LA JEHTEDUNE
  27,25,‘ELLA JESXHUDU LILLAHIL-LEDHI JUHRIXHUL-HAB’E FI ES-SEMAWATI WEL-’ERDI WE JA’LEMU MA TUHFUNE WE MA TU’LINUNE
  27,26,ELLAHU LA ‘ILAHE ‘ILLA HUWE REBBUL-’ARSHIL-’ADHIMI
  27,27,KALE SENENDHURU ‘ESEDEKTE ‘EM KUNTE MINEL-KADHIBINE
  27,28,EDH/HEB BIKITABI HADHA FE’ELKIH ‘ILEJHIM THUMME TEWELLE ‘ANHUM FANDHUR MADHA JERXHI’UNE
  27,29,KALET JA ‘EJJUHAL-MELE’U ‘INNI ‘ULKIJE ‘ILEJJE KITABUN KERIMUN
  27,30,‘INNEHU MIN SULEJMANE WE ‘INNEHU BISMI ELLAHI ER-REHMANI ER-REHIMI
  27,31,‘ELLA TA’LU ‘ALEJJE WE ‘TUNI MUSLIMINE
  27,32,KALET JA ‘EJJUHAL-MELE’U ‘EFTUNI FI ‘EMRI MA KUNTU KATI’ATEN ‘EMRÆN HETTA TESH/HEDUNI
  27,33,KALU NEHNU ‘ULU KUWETIN WE ‘ULU BE’SIN SHEDIDIN WEL-’EMRU ‘ILEJKI FANDHURI MADHA TE’MURINE
  27,34,KALET ‘INNEL-MULUKE ‘IDHA DEHALU KARJETEN ‘EFSEDUHA WE XHE’ALU ‘A’IZZETE ‘EHLIHA ‘EDHILLETEN WE KEDHELIKE JEF’ALUNE
  27,35,WE ‘INNI MURSILETUN ‘ILEJHIM BIHEDIJETIN FENADHIRETUN BIME JERXHI’UL-MURSELUNE
  27,36,FELEMMA XHA’E SULEJMANE KALE ‘ETUMIDDUNENI BIMALIN FEMA ‘ATANIJEL-LAHU HAJRUN MIMMA ‘ATAKUM BEL ‘ENTUM BIHEDIJETIKUM TEFREHUNE
  27,37,ERXHI’ ‘ILEJHIM FELENE’TIJENNEHUM BIXHUNUDIN LA KIBELE LEHUM BIHA WE LENUHRIXHENNEHUM MINHA ‘EDHILLETEN WE HUM SAGIRUNE
  27,38,KALE JA ‘EJJUHAL-MELE’U ‘EJJUKUM JE’TINI BI’ARSHIHA KABLE ‘EN JE’TUNI MUSLIMINE
  27,39,KALE ‘IFRJTUN MINEL-XHINNI ‘ENA ‘ATIKE BIHI KABLE ‘EN TEKUME MIN MEKAMIKE WE ‘INNI ‘ALEJHI LEKAWIJUN ‘EMINUN
  27,40,KALEL-LEDHI ‘INDEHU ‘ILMUN MINEL-KITABI ‘ENA ‘ATIKE BIHI KABLE ‘EN JERTEDDE ‘ILEJKE TERFUKE FELEMMA RE’AHU MUSTEKIRRÆN ‘INDEHU KALE HADHA MIN FEDLI RABBI LIJEBLUWENI ‘E’ESHKURU ‘EM ‘EKFURU WE MEN SHEKERE FE’INNEMA JESHKURU LINEFSIHI WE MEN KEFERE FE’INNE
  27,41,KALE NEKKIRU LEHA ‘ARSHEHA NENDHUR ‘ETEHTEDI ‘EM TEKUNU MINEL-LEDHINE LA JEHTEDUNE
  27,42,FELEMMA XHA’ET KILE ‘EHEKEDHA ‘ARSHUKI KALET KE’ENNEHU HUWE WE ‘UTINAL-’ILME MIN KABLIHA WE KUNNA MUSLIMINE
  27,43,WE SEDDEHA MA KANET TA’BUDU MIN DUNI ELLAHI ‘INNEHA KANET MIN KAWMIN KAFIRINE
  27,44,KILE LEHA EDHULI ES-SERHE FELEMMA RE’ET/HU HESIBET/HU LUXHXHETEN WE KESHEFET ‘AN SAKAJHA KALE ‘INNEHU SERHUN MUMERREDUN MIN KAWARIRE KALET RABBI ‘INNI DHELEMTU NEFSI WE ‘ESLEMTU ME’A SULEJMANE LILLAHI RABBIL-’ALEMINE
  27,45,WE LEKAD ‘ERSELNA ‘ILA THEMUDE ‘EHAHUM SALIHÆN ‘ENI A’BUDU ELLAHE FE’IDHA HUM FERIKANI JEHTESIMUNE
  27,46,KALE JA KAWMI LIME TESTA’XHILUNE BIS-SEJJI’ETI KABLEL-HESENETI LEWLA TESTEGFIRUNEL-LAHE LE’ALLEKUM TURHEMUNE
  27,47,KALU ETTEJJERNA BIKE WE BIMEN ME’AKE KALE TA’IRUKUM ‘INDEL-LAHI BEL ‘ENTUM KAWMUN TUFTENUNE
  27,48,WE KANE FIL-MEDINETI TIS’ATU REHTIN JUFSIDUNE FIL-’ERDI WE LA JUSLIHUNE
  27,49,KALU TEKASEMU BILLAHI LENUBEJJITENNEHU WE ‘EHLEHU THUMME LENEKULENNE LIWELIJIHI MA SHEHIDNA MEHLIKE ‘EHLIHI WE ‘INNA LESADIKUNE
  27,50,WE MEKERU MEKRÆN WE MEKERNA MEKRÆN WE HUM LA JESH’URUNE
  27,51,FANDHUR KEJFE KANE ‘AKIBETU MEKRIHIM ‘ENNA DEMMERNAHUM WE KAWMEHUM ‘EXHMA’INE
  27,52,FETILKE BUJUTUHUM HAWIJETEN BIMA DHELEMU ‘INNE FI DHALIKE LE’AJETEN LIKAWMIN JA’LEMUNE
  27,53,WE ‘ENXHEJNAL-LEDHINE ‘AMENU WE KANU JETTEKUNE
  27,54,WE LUTÆN ‘IDH KALE LIKAWMIHI ‘ETE’TUNEL-FAHISHETE WE ‘ENTUM TUBSIRUNE
  27,55,‘E’INNEKUM LETE’TUNE ER-RIXHALE SHEHWETEN MIN DUNI EN-NISA’ BEL ‘ENTUM KAWMUN TEXHHELUNE
  27,56,FEMA KANE XHEWABE KAWMIHI ‘ILLA ‘EN KALU ‘EHRIXHU ‘ALE LUTIN MIN KARJETIKUM ‘INNEHUM ‘UNASUN JETETEHHERUNE
  27,57,FE’ENXHEJNAHU WE ‘EHLEHU ‘ILLA EMRE’ETEHU KADDERNAHA MINEL-GABIRINE
  27,58,WE ‘EMTERNA ‘ALEJHIM METERÆN FESA’E METERUL-MUNDHERINE
  27,59,KULIL-HEMDU LILLAHI WE SELAMUN ‘ALA ‘IBADIHIL-LEDHINE ESTEFA ‘AALLLEHU HAJRUN ‘EMMA JUSHRIKUNE
  27,60,‘EMMEN HALEKA ES-SEMAWATI WEL-’ERDE WE ‘ENZELE LEKUM MINE ES-SEMA’I MA’EN FE’ENBETNA BIHI HEDA’IKA DHATE BEHXHETIN MA KANE LEKUM ‘EN TUNBITU SHEXHEREHA ‘E’ILEHUN ME’A ELLAHI BEL HUM KAWMUN JA’DILUNE
  27,61,‘EMMEN XHE’ALEL-’ERDE KARARÆN WE XHE’ALE HILALEHA ‘ENHARÆN WE XHE’ALE LEHA REWASIJE WE XHE’ALE BEJNEL-BEHREJNI HAXHIZÆN ‘E’ILEHUN ME’A ELLAHI BEL ‘EKTHERUHUM LA JA’LEMUNE
  27,62,‘EMMEN JUXHIBUL-MUDTERRE ‘IDHA DA’AHU WE JEKSHIFU ES-SU’E WE JEXH’ALUKUM HULEFA’EL-’ERDI ‘E’ILEHUN ME’A ELLAHI KALILÆN MA TEDHEKKERUNE
  27,63,‘EMMEN JEHDIKUM FI DHULUMATIL-BERRI WEL-BEHRI WE MEN JURSILU ER-RIJAHE BUSHRÆN BEJNE JEDEJ REHMETIHI ‘E’ILEHUN ME’A ELLAHI TA’ALALLAHU ‘AMMA JUSHRIKUNE
  27,64,‘EMMEN JEBDE’UL-HALKA THUMME JU’IDUHU WE MEN JERZUKUKUM MINE ES-SEMA’I WEL-’ERDI ‘E’ILEHUN ME’A ELLAHI KUL HATU BURHANEKUM ‘IN KUNTUM SADIKINE
  27,65,KUL LA JA’LEMU MEN FI ES-SEMAWATI WEL-’ERDIL-GAJBE ‘ILLALLAHU WE MA JESH’URUNE ‘EJJANE JUB’ATHUNE
  27,66,BEL EDDAREKE ‘ILMUHUM FIL-’AHIRETI BEL HUM FI SHEKKIN MINHA BEL HUM MINHA ‘AMUNE
  27,67,WE KALEL-LEDHINE KEFERU ‘E’IDHA KUNNA TURABÆN WE ‘ABA’UUNA ‘E’INNA LEMUHREXHUNE
  27,68,LEKAD WU’IDNA HADHA NEHNU WE ‘ABA’UUNA MIN KABLU ‘IN HADHA ‘ILLA ‘ESATIRUL-’EWWELINE
  27,69,KUL SIRU FIL-’ERDI FANDHURU KEJFE KANE ‘AKIBETUL-MUXHRIMINE
  27,70,WE LA TEHZEN ‘ALEJHIM WE LA TEKUN FI DEJKIN MIMMA JEMKURUNE
  27,71,WE JEKULUNE META HADHAL-WA’DU ‘IN KUNTUM SADIKINE
  27,72,KUL ‘ASA ‘EN JEKUNE REDIFE LEKUM BA’DUL-LEDHI TESTA’XHILUNE
  27,73,WE ‘INNE REBBEKE LEDHU FEDLIN ‘ALA EN-NASI WE LEKINNE ‘EKTHEREHUM LA JESHKURUNE
  27,74,WE ‘INNE REBBEKE LEJA’LEMU MA TUKINNU SUDURUHUM WE MA JU’LINUNE
  27,75,WE MA MIN GA’IBETIN FI ES-SEMA’I WEL-’ERDI ‘ILLA FI KITABIN MUBININ
  27,76,‘INNE HADHAL-KUR’ANE JEKUSSU ‘ALA BENI ‘ISRA’ILE ‘EKTHEREL-LEDHI HUM FIHI JEHTELIFUNE
  27,77,WE ‘INNEHU LEHUDEN WE REHMETUN LILMU’UMININE
  27,78,‘INNE REBBEKE JEKDI BEJNEHUM BIHUKMIHI WE HUWEL-’AZIZUL-’ALIMU
  27,79,FETEWEKKEL ‘ALA ELLAHI ‘INNEKE ‘ALEL-HEKKIL-MUBINI
  27,80,‘INNEKE LA TUSMI’UL-MEWTA WE LA TUSMI’U ES-SUMME ED-DU’A’E ‘IDHA WE LLEW MUDBIRINE
  27,81,WE MA ‘ENTE BIHADIL-’UMJI ‘AN DELALETIHIM ‘IN TUSMI’U ‘ILLA MEN JU’UMINU BI’AJATINA FEHUM MUSLIMUNE
  27,82,WE ‘IDHA WEKA’AL-KAWLU ‘ALEJHIM ‘EHREXHNA LEHUM DABBETEN MINEL-’ERDI TUKELLIMUHUM ‘ENNE EN-NASE KANU BI’AJATINA LA JUKINUNE
  27,83,WE JEWME NEHSHURU MIN KULLI ‘UMMETIN FEWXHÆN MIMMEN JUKEDHDHIBU BI’AJATINA FEHUM JUZA’UNE
  27,84,HETTA ‘IDHA XHA’U KALE ‘EKEDHDHEBTUM BI’AJATI WE LEM TUHITU BIHA ‘ILMÆN ‘EMMADHA KUNTUM TA’MELUNE
  27,85,WE WEKA’AL-KAWLU ‘ALEJHIM BIMA DHELEMU FEHUM LA JENTIKUNE
  27,86,‘ELEM JEREW ‘ENNA XHE’ALNAL-LEJLE LIJESKUNU FIHI WE EN-NEHARE MUBSIRÆN ‘INNE FI DHALIKE LE’AJATIN LIKAWMIN JU’UMINUNE
  27,87,WE JEWME JUNFEHU FI ES-SURI FEFEZI’A MEN FI ES-SEMAWATI WE MEN FIL-’ERDI ‘ILLA MEN SHA’EL-LAHU WE KULLUN ‘ETEWHU DAHIRINE
  27,88,WE TERAL-XHIBALE TEHSEBUHA XHAMIDETEN WE HIJE TEMURRU MERRE ES-SEHABI SUN’A ELLAHIL-LEDHI ‘ETKANE KULLE SHEJ’IN ‘INNEHU HABIRUN BIMA TEF’ALUNE
  27,89,MEN XHA’E BIL-HESENETI FELEHU HAJRUN MINHA WE HUM MIN FEZA’IN JEWME’IDHIN ‘AMINUNE
  27,90,WE MEN XHA’E BIS-SEJJI’ETI FEKUBBET WUXHUHUHUM FI EN-NARI HEL TUXHZEWNE ‘ILLA MA KUNTUM TA’MELUNE
  27,91,‘INNEMA ‘UMIRTU ‘EN ‘A’BUDE REBBE HEDHIHIL-BELDETIL-LEDHI HERREMEHA WE LEHU KULLU SHEJ’IN WE ‘UMIRTU ‘EN ‘EKUNE MINEL-MUSLIMINE
  27,92,WE ‘EN ‘ETLUWEL-KUR’ANE FEMENI EHTEDA FE’INNEMA JEHTEDI LINEFSIHI WE MEN DELLE FEKUL ‘INNEMA ‘ENA MINEL-MUNDHIRINE
  27,93,WE KULIL-HEMDU LILLAHI SEJURIKUM ‘AJATIHI FETA’RIFUNEHA WE MA REBBUKE BIGAFILIN ‘AMMA TA’MELUNE
  28,1,TA-SIN-MIM
  28,2,TILKE ‘AJATUL-KITABIL-MUBINI
  28,3,NETLU ‘ALEJKE MIN NEBE’I MUSA WE FIR’AWNE BIL-HEKKI LIKAWMIN JU’UMINUNE
  28,4,‘INNE FIR’AWNE ‘ALA FIL-’ERDI WE XHE’ALE ‘EHLEHA SHIJA’ÆN JESTED’IFU TA’IFETEN MINHUM JUDHEBBIHU ‘EBNA’EHUM WE JESTEHJI NISA’EHUM ‘INNEHU KANE MINEL-MUFSIDINE
  28,5,WE NURIDU ‘EN NEMUNNE ‘ALEL-LEDHINE ESTUD’IFU FIL-’ERDI WE NEXH’ALEHUM ‘E’IMMETEN WE NEXH’ALEHUMUL-WARITHINE
  28,6,WE NUMEKKINE LEHUM FIL-’ERDI WE NURIJE FIR’AWNE WE HAMANE WE XHUNUDEHUMA MINHUM MA KANU JEHDHERUNE
  28,7,WE ‘EWHEJNA ‘ILA ‘UMMI MUSA ‘EN ‘ERDI’IHI FE’IDHA HIFTI ‘ALEJHI FE’ELKIHI FIL-JEMMI WE LA TEHAFI WE LA TEHZENI ‘INNA RADDUHU ‘ILEJKI WE XHA’ILUHU MINEL-MURSELINE
  28,8,FALTEKATEHU ‘ALU FIR’AWNE LIJEKUNE LEHUM ‘ADUWÆN WE HEZENÆN ‘INNE FIR’AWNE WE HAMANE WE XHUNUDEHUMA KANU HATI’INE
  28,9,WE KALET EMRE’ETU FIR’AWNE KURRETU ‘AJNIN LI WE LEKE LA TEKTULUHU ‘ASA ‘EN JENFE’ANA ‘EW NETTEHIDHEHU WELEDÆN WE HUM LA JESH’URUNE
  28,10,WE ‘ESBEHE FU’UADU ‘UMMI MUSA FARIGÆN ‘IN KADET LETUBDI BIHI LEWLA ‘EN REBETNA ‘ALA KALBIHA LITEKUNE MINEL-MU’UMININE
  28,11,WE KALET LI’HTIHI KUSSIHI FEBESURET BIHI ‘AN XHUNUBIN WE HUM LA JESH’URUNE
  28,12,WE HERREMNA ‘ALEJHIL-MERADI’A MIN KABLU FEKALET HEL ‘EDULLUKUM ‘ALA ‘EHLI BEJTIN JEKFULUNEHU LEKUM WE HUM LEHU NASIHUNE
  28,13,FEREDEDNAHU ‘ILA ‘UMMIHI KEJ TEKARRE ‘AJNUHA WE LA TEHZENE WE LITA’LEME ‘ENNE WA’DEL-LAHI HEKKUN WE LEKINNE ‘EKTHEREHUM LA JA’LEMUNE
  28,14,WE LEMMA BELEGA ‘ESHUDDEHU WE ESTEWA ‘ATEJNAHU HUKMÆN WE ‘ILMÆN WE KEDHELIKE NEXHZIL-MUHSININE
  28,15,WE DEHALEL-MEDINETE ‘ALA HINI GAFLETIN MIN ‘EHLIHA FEWEXHEDE FIHA REXHULEJNI JEKTETILANI HADHA MIN SHI’ATIHI WE HEDHA MIN ‘ADUWIHI FASTEGATHEHUL-LEDHI MIN SHI’ATIHI ‘ALEL-LEDHI MIN ‘ADUWIHI FEWEKEZEHU MUSA FEKADA ‘ALEJHI KALE HADHA MIN ‘AMELI ESH-SHEJTANI
  28,16,KALE RABBI ‘INNI DHELEMTU NEFSI FAGFIR LI FEGAFERE LEHU ‘INNEHU HUWEL-GAFURU ER-REHIMU
  28,17,KALE RABBI BIMA ‘EN’AMTE ‘ALEJJE FELEN ‘EKUNE DHEHIRÆN LILMUXHRIMINE
  28,18,FE’ESBEHE FIL-MEDINETI HA’IFÆN JETEREKKABU FE’IDHAL-LEDHI ESTENSEREHU BIL-’EMSI JESTESRIHUHU KALE LEHU MUSA ‘INNEKE LEGAWIJUN MUBINUN
  28,19,FELEMMA ‘EN ‘ERADE ‘EN JEBTISHE BIEL-LEDHI HUWE ‘ADUWUN LEHUMA KALE JA MUSA ‘ETURIDU ‘EN TEKTULENI KEMA KATELTE NEFSÆN BIL-’EMSI ‘IN TURIDU ‘ILLA ‘EN TEKUNE XHEBBARÆN FIL-’ERDI WE MA TURIDU ‘EN TEKUNE MINEL-MUSLIHINE
  28,20,WE XHA’E REXHULUN MIN ‘EKSAL-MEDINETI JES’A KALE JA MUSA ‘INNEL-MELE’E JE’TEMIRUNE BIKE LIJEKTULUKE FAHRUXH ‘INNI LEKE MINE EN-NASIHINE
  28,21,FEHAREXHE MINHA HA’IFÆN JETEREKKABU KALE RABBI NEXHXHINI MINEL-KAWMI EDH-DHALIMINE
  28,22,WE LEMMA TEWEXHXHEHE TILKA’E MEDJENE KALE ‘ASA RABBI ‘EN JEHDIJENI SEWA’E ES-SEBIL
  28,23,WE LEMMA WEREDE MA’E MEDJENE WEXHEDE ‘ALEJHI ‘UMMETEN MINE EN-NASI JESKUNE WE WEXHEDE MIN DUNIHIMU EMRE’TEJNI TEDHUDANI KALE MA HATBUKUMA KALETA LA NESKI HETTA JUSDIRE ER-RI’A’U WE ‘EBUNA SHEJHUN KEBIRUN
  28,24,FESEKA LEHUMA THUMME TEWELLA ‘ILA EDH-DHILLI FEKALE RABBI ‘INNI LIMA ‘ENZELTE ‘ILEJJE MIN HAJRIN FEKIRUN
  28,25,FEXHA’ET/HU ‘IHDAHUMA TEMSHI ‘ALA ESTIHJA’IN KALET ‘INNE ‘EBI JED’UKE LIJEXHZIJEKE ‘EXHRE MA SEKAJTE LENA FELEMMA XHA’EHU WE KASSE ‘ALEJHIL-KASESE KALE LA TEHAF NEXHEWTE MINEL-KAWMI EDH-DHALIMINE
  28,26,KALET ‘IHDAHUMA JA ‘EBETI ESTE’XHIRHU ‘INNE HAJRE MENI ESTE’XHERTEL-KAWIJUL-’EMINU
  28,27,KALE ‘INNI ‘URIDU ‘EN ‘UNKIHEKE ‘IHDA EBNETEJJE HATEJNI ‘ALA ‘EN TE’XHURENI THEMANIJETE HIXHEXHIN FE’IN ‘ETMEMTE ‘ASHRÆN FEMIN ‘INDIKE WE MA ‘URIDU ‘EN ‘ESHUKKA ‘ALEJKE SETEXHIDUNI ‘IN SHA’EL-LAHU MINE ES-SALIHINE
  28,28,KALE DHALIKE BEJNI WE BEJNEKE ‘EJJEMAL-’EXHELEJNI KADEJTU FELA ‘UDWANE ‘ALEJJE WEL-LAHU ‘ALA MA NEKULU WE KILUN
  28,29,FELEMMA KADA MUSAL-’EXHELE WE SARE BI’EHLIHI ‘ANESE MIN XHANIBIT-TURI NARÆN KALE LI’HLIHI EMKUTHU ‘INNI ‘ANESTU NARÆN LE’ALLI ‘ATIKUM MINHA BIHABERIN ‘EW XHEDHWETIN MINE EN-NARI LE’ALLEKUM TESTELUNE
  28,30,FELEMMA ‘ETAHA NUDI MIN SHATI’IL-WADIL-’EJMENI FIL-BUK’ATIL-MUBAREKETI MINE ESH-SHEXHERETI ‘EN JA MUSA ‘INNI ‘ENALLAHU REBBUL-’ALEMINE
  28,31,WE ‘EN ‘ELKI ‘ASAKE FELEMMA RE’AHA TEHTEZZU KE’ENNEHA XHANNUN WELLA MUDBIRÆN WE LEM JU’AKKIB JA MUSA ‘EKBIL WE LA TEHAF ‘INNEKE MINEL-’AMININE
  28,32,ESLUK JEDEKE FI XHEJBIKE TEHRUXH BEJDA’E MIN GAJRI SU’IN WE EDMUM ‘ILEJKE XHENAHEKE MINE ER-REHBI FEDHANIKE BURHANANI MIN RABBIKE ‘ILA FIR’AWNE WE MELE’IHI ‘INNEHUM KANU KAWMÆN FASIKINE
  28,33,KALE RABBI ‘INNI KATELTU MINHUM NEFSÆN FE’EHAFU ‘EN JEKTULUNI
  28,34,WE ‘EHI HARUNU HUWE ‘EFSEHU MINNI LISANÆN FE’ERSILHU MA’IJE RID’ÆN JUSEDDIKUNI ‘INNI ‘EHAFU ‘EN JUKEDHDHIBUNI
  28,35,KALE SENESHUDDU ‘ADUDEKE BI’EHIKE WE NEXH’ALU LEKUMA SULTANÆN FELA JESILUNE ‘ILEJKUMA BI’AJATINA ‘ENTUMA WE MENI ETTEBE’AKUMAL-GALIBUNE
  28,36,FELEMMA XHA’EHUM MUSA BI’AJATINA BEJJINATIN KALU MA HADHA ‘ILLA SIHRUN MUFTEREN WE MA SEMI’NA BIHEDHA FI ‘ABA’INAL-’EWWELINE
  28,37,WE KALE MUSA RABBI ‘A’LEMU BIMEN XHA’E BIL-HUDA MIN ‘INDIHI WE MEN TEKUNU LEHU ‘AKIBETU ED-DARI ‘INNEHU LA JUFLIHU EDH-DHALIMUNE
  28,38,WE KALE FIR’AWNU JA ‘EJJUHAL-MELE’U MA ‘ALIMTU LEKUM MIN ‘ILEHIN GAJRI FE’EWKID LI JA HAMANU ‘ALAT-TINI FAXH’AL LI SERHÆN LE’ALLI ‘ETTELI’U ‘ILA ‘ILEHI MUSA WE ‘INNI LE’EDHUNNUHU MINEL-KADHIBINE
  28,39,WE ESTEKBERE HUWE WE XHUNUDUHU FIL-’ERDI BIGAJRIL-HEKKI WE DHENNU ‘ENNEHUM ‘ILEJNA LA JURXHA’UNE
  28,40,FE’EHADHNAHU WE XHUNUDEHU FENEBEDHNAHUM FIL-JEMMI FANDHUR KEJFE KANE ‘AKIBETU EDH-DHALIMINE
  28,41,WE XHE’ALNAHUM ‘E’IMMETEN JED’UNE ‘ILA EN-NARI WE JEWMEL-KIJAMETI LA JUNSERUNE
  28,42,WE ‘ETBA’NAHUM FI HEDHIHI ED-DUNJA LA’NETEN WE JEWMEL-KIJAMETI HUM MINEL-MEKBUHINE
  28,43,WE LEKAD ‘ATEJNA MUSAL-KITABE MIN BA’DI MA ‘EHLEKNAL-KURUNEL-’ULA BESA’IRE LILNNASI WE HUDEN WE REHMETEN LE’ALLEHUM JETEDHEKKERUNE
  28,44,WE MA KUNTE BIXHANIBIL-GARBIJI ‘IDH KADEJNA ‘ILA MUSAL-’EMRE WE MA KUNTE MINE ESH-SHAHIDIN
  28,45,WE LEKINNA ‘ENSHE’NA KURUNÆN FETETAWELE ‘ALEJHIMUL-’UMURU WE MA KUNTE THAWIÆN FI ‘EHLI MEDJENE TETLU ‘ALEJHIM ‘AJATINA WE LEKINNA KUNNA MURSILINE
  28,46,WE MA KUNTE BIXHANIBIT-TURI ‘IDH NADEJNA WE LEKIN REHMETEN MIN RABBIKE LITUNDHIRE KAWMÆN MA ‘ETAHUM MIN NEDHIRIN MIN KABLIKE LE’ALLEHUM JETEDHEKKERUNE
  28,47,WE LEWLA ‘EN TUSIBEHUM MUSIBETUN BIMA KADDEMET ‘EJDIHIM FEJEKULU REBBENA LEWLA ‘ERSELTE ‘ILEJNA RESULÆN FENETTEBI’A ‘AJATIKE WE NEKUNE MINEL-MU’UMININE
  28,48,FELEMMA XHA’EHUMUL-HEKKU MIN ‘INDINA KALU LEWLA ‘UTIJE MITHLE MA ‘UTIJE MUSA ‘EWELEM JEKFURU BIMA ‘UTIJE MUSA MIN KABLU KALU SIHRANI TEDHAHERA WE KALU ‘INNA BIKULLIN KAFIRUNE
  28,49,KUL FE’TU BIKITABIN MIN ‘INDI ELLAHI HUWE ‘EHDA MINHUMA ‘ETTEBI’HU ‘IN KUNTUM SADIKINE
  28,50,FE’IN LEM JESTEXHIBU LEKE FA’LEM ‘ENNEMA JETTEBI’UNE ‘EHWA’EHUM WE MEN ‘EDELLU MIMMENI ETTEBE’A HEWAHU BIGAJRI HUDEN MINEL-LAHI ‘INNALL-LLAHE LA JEHDIL-KAWME EDH-DHALIMINE
  28,51,WE LEKAD WESSELNA LEHUMUL-KAWLE LE’ALLEHUM JETEDHEKKERUNE
  28,52,EL-LEDHINE ‘ATEJNAHUMUL-KITABE MIN KABLIHI HUM BIHI JU’UMINUNE
  28,53,WE ‘IDHA JUTLA ‘ALEJHIM KALU ‘AMENNA BIHI ‘INNEHUL-HEKKU MIN RABBINA ‘INNA KUNNA MIN KABLIHI MUSLIMINE
  28,54,‘ULA’IKE JU’UTEWNE ‘EXHREHUM MERRETEJNI BIMA SEBERU WE JEDRE’UNE BIL-HESENETI ES-SEJJI’ETE WE MIMMA REZEKNAHUM JUNFIKUNE
  28,55,WE ‘IDHA SEMI’UL-LEGWE ‘A’REDU ‘ANHU WE KALU LENA ‘A’MALUNA WE LEKUM ‘A’MALUKUM SELAMUN ‘ALEJKUM LA NEBTEGIL-XHAHILINE
  28,56,‘INNEKE LA TEHDI MEN ‘EHBEBTE WE LEKINNALL-LLAHE JEHDI MEN JESHA’U WE HUWE ‘A’LEMU BIL-MUHTEDINE
  28,57,WE KALU ‘IN NETTEBI’IL-HUDA ME’AKE NUTEHATTEF MIN ‘ERDINA ‘EWELEM NUMEKKIN LEHUM HEREMÆN ‘AMINÆN JUXHBA ‘ILEJHI THEMERATU KULLI SHEJ’IN RIZKÆN MIN LEDUNNA WE LEKINNE ‘EKTHEREHUM LA JA’LEMUNE
  28,58,WE KEM ‘EHLEKNA MIN KARJETIN BETIRET MA’ISHETEHA FETILKE MESAKINUHUM LEM TUSKEN MIN BA’DIHIM ‘ILLA KALILÆN WE KUNNA NEHNUL-WARITHINE
  28,59,WE MA KANE REBBUKE MUHLIKEL-KURA HETTA JEB’ATHE FI ‘UMMIHA RESULÆN JETLU ‘ALEJHIM ‘AJATINA WE MA KUNNA MUHLIKIL-KURA ‘ILLA WE ‘EHLUHA DHALIMUNE
  28,60,WE MA ‘UTITUM MIN SHEJ’IN FEMETA’UL-HEJÆTI ED-DUNJA WE ZINETUHA WE MA ‘INDEL-LAHI HAJRUN WE ‘EBKA ‘EFELA TA’KILUNE
  28,61,‘EFEMEN WE’ADNAHU WA’DÆN HESENÆN FEHUWE LAKIHI KEMEN METTA’NAHU META’AL-HEJÆTI ED-DUNJA THUMME HUWE JEWMEL-KIJAMETI MINEL-MUHDERINE
  28,62,WE JEWME JUNADIHIM FEJEKULU ‘EJNE SHUREKA’IJEL-LEDHINE KUNTUM TEZ’UMUNE
  28,63,KALEL-LEDHINE HEKKA ‘ALEJHIMUL-KAWLU REBBENA HA’UULA’L-LEDHINE ‘EGWEJNA ‘EGWEJNAHUM KEMA GAWEJNA TEBERRE’NA ‘ILEJKE MA KANU ‘IJANA JA’BUDUNE
  28,64,WE KILE ED’U SHUREKA’EKUM FEDE’AWHUM FELEM JESTEXHIBU LEHUM WE RE’EWL-’ADHABE LEW ‘ENNEHUM KANU JEHTEDUNE
  28,65,WE JEWME JUNADIHIM FEJEKULU MADHA ‘EXHEBTUMUL-MURSELINE
  28,66,FE’AMIJET ‘ALEJHIMUL-’ENBA’U JEWME’IDHIN FEHUM LA JETESA’ELUNE
  28,67,FE’EMMA MEN TABE WE ‘AMENE WE ‘AMILE SALIHÆN FE’ASA ‘EN JEKUNE MINEL-MUFLIHINE
  28,68,WE REBBUKE JEHLUKU MA JESHA’U WE JEHTARU MA KANE LEHUMUL-HIJERETU SUBHANEL-LAHI WE TA’ALA ‘AMMA JUSHRIKUNE
  28,69,WE REBBUKE JA’LEMU MA TUKINNU SUDURUHUM WE MA JU’LINUNE
  28,70,WE HUWEL-LAHU LA ‘ILAHE ‘ILLA HUWE LEHUL-HEMDU FIL-’ULA WEL-’AHIRETI WE LEHUL-HUKMU WE ‘ILEJHI TURXHA’UNE
  28,71,KUL ‘ERE’EJTUM ‘IN XHE’ALEL-LAHU ‘ALEJKUMUL-LEJLE SERMEDÆN ‘ILA JEWMIL-KIJAMETI MEN ‘ILEHUN GAJRU ELLAHI JE’TIKUM BIDIJA’IN ‘EFELA TESMA’UNE
  28,72,KUL ‘ERE’EJTUM ‘IN XHE’ALEL-LAHU ‘ALEJKUMU EN-NEHARE SERMEDÆN ‘ILA JEWMIL-KIJAMETI MEN ‘ILEHUN GAJRU ELLAHI JE’TIKUM BILEJLIN TESKUNUNE FIHI ‘EFELA TUBSIRUNE
  28,73,WE MIN REHMETIHI XHE’ALE LEKUMUL-LEJLE WE EN-NEHARE LITESKUNU FIHI WE LITEBTEGU MIN FEDLIHI WE LE’ALLEKUM TESHKURUNE
  28,74,WE JEWME JUNADIHIM FEJEKULU ‘EJNE SHUREKA’IJEL-LEDHINE KUNTUM TEZ’UMUNE
  28,75,WE NEZA’NA MIN KULLI ‘UMMETIN SHEHIDÆN FEKULNA HATU BURHANEKUM FE’ALIMU ‘ENNEL-HEKKA LILLAHI WE DELLE ‘ANHUM MA KANU JEFTERUNE
  28,76,‘INNE KARUNE KANE MIN KAWMI MUSA FEBEGA ‘ALEJHIM WE ‘ATEJNAHU MINEL-KUNUZI MA ‘INNE MEFATIHEHU LETENU’U BIL-’USBETI ‘ULIL-KUWETI ‘IDH KALE LEHU KAWMUHU LA TEFREH ‘INNALL-LLAHE LA JUHIBBUL-FERIHINE
  28,77,WE EBTEGI FIMA ‘ATAKEL-LAHU ED-DAREL-’AHIRETE WE LA TENSE NESIBEKE MINE ED-DUNJA WE ‘EHSIN KEMA ‘EHSENEL-LAHU ‘ILEJKE WE LA TEBGIL-FESADE FIL-’ERDI ‘INNALL-LLAHE LA JUHIBBUL-MUFSIDINE
  28,78,KALE ‘INNEMA ‘UTITUHU ‘ALA ‘ILMIN ‘INDI ‘EWELEM JA’LEM ‘ENNEL-LAHE KAD ‘EHLEKE MIN KABLIHI MINEL-KURUNI MEN HUWE ‘ESHEDDU MINHU KUWETEN WE ‘EKTHERU XHEM’ÆN WE LA JUS’ELU ‘AN DHUNUBIHIMUL-MUXHRIMUNE
  28,79,FEHAREXHE ‘ALA KAWMIHI FI ZINETIHI KALEL-LEDHINE JURIDUNEL-HEJÆTE ED-DUNJA JALEJTE LENA MITHLE MA ‘UTIJE KARUNU ‘INNEHU LEDHU HEDHDHIN ‘ADHIMIN
  28,80,WE KALEL-LEDHINE ‘UTUL-’ILME WEJLEKUM THEWABU ELLAHI HAJRUN LIMEN ‘AMENE WE ‘AMILE SALIHÆN WE LA JULEKKAHA ‘ILLA ES-SABIRUNE
  28,81,FEHASEFNA BIHI WE BIDARIHIL-’ERDE FEMA KANE LEHU MIN FI’ETIN JENSURUNEHU MIN DUNI ELLAHI WE MA KANE MINEL-MUNTESIRINE
  28,82,WE ‘ESBEHEL-LEDHINE TEMENNEW MEKANEHU BIL-’EMSI JEKULUNE WEJKE’ENNEL-LAHE JEBSUTU ER-RIZKA LIMEN JESHA’U MIN ‘IBADIHI WE JEKDIRU LEWLA ‘EN MENNEL-LAHU ‘ALEJNA LEHASEFE BINA WEJKE’ENNEHU LA JUFLIHUL-KAFIRUNE
  28,83,TILKE ED-DARUL-’AHIRETU NEXH’ALUHA LILLEDHINE LA JURIDUNE ‘ULUWÆN FIL-’ERDI WE LA FESADÆN WEL-’AKIBETU LILMUTTEKINE
  28,84,MEN XHA’E BIL-HESENETI FELEHU HAJRUN MINHA WE MEN XHA’E BIS-SEJJI’ETI FELA JUXHZAL-LEDHINE ‘AMILU ES-SEJJI’ATI ‘ILLA MA KANU JA’MELUNE
  28,85,‘INNEL-LEDHI FEREDE ‘ALEJKEL-KUR’ANE LERADDUKE ‘ILA MA’ADIN KUL RABBI ‘A’LEMU MEN XHA’E BIL-HUDA WE MEN HUWE FI DELALIN MUBININ
  28,86,WE MA KUNTE TERXHU ‘EN JULKA ‘ILEJKEL-KITABU ‘ILLA REHMETEN MIN RABBIKE FELA TEKUNENNE DHEHIRÆN LILKAFIRINE
  28,87,WE LA JESUDDUNNEKE ‘AN ‘AJATI ELLAHI BA’DE ‘IDH ‘UNZILET ‘ILEJKE WE ED’U ‘ILA RABBIKE WE LA TEKUNENNE MINEL-MUSHRIKINE
  28,88,WE LA TED’U ME’A ELLAHI ‘ILEHÆN ‘AHARE LA ‘ILAHE ‘ILLA HUWE KULLU SHEJ’IN HALIKUN ‘ILLA WEXHHEHU LEHUL-HUKMU WE ‘ILEJHI TURXHA’UNE
  29,1,‘ELIF-LAM-MIM
  29,2,‘EHESIBE EN-NASU ‘EN JUTREKU ‘EN JEKULU ‘AMENNA WE HUM LA JUFTENUNE
  29,3,WE LEKAD FETENNAL-LEDHINE MIN KABLIHIM FELEJA’LEMENNEL-LAHUL-LEDHINE SEDEKU WE LEJA’LEMENNEL-KADHIBINE
  29,4,‘EM HESIBEL-LEDHINE JA’MELUNE ES-SEJJI’ATI ‘EN JESBIKUNA SA’E MA JEHKUMUNE
  29,5,MEN KANE JERXHU LIKA’EL-LAHI FE’INNE ‘EXHELEL-LAHI LE’ATIN WE HUWE ES-SEMI’UL-’ALIMU
  29,6,WE MEN XHAHEDE FE’INNEMA JUXHAHIDU LINEFSIHI ‘INNALL-LLAHE LEGANIJUN ‘ANIL-’ALEMINE
  29,7,WEL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI LENUKEFFIRENNE ‘ANHUM SEJJI’ATIHIM WE LENEXHZIJENNEHUM ‘EHSENEL-LEDHI KANU JA’MELUNE
  29,8,WE WESSEJNAL-’INSANE BIWALIDEJHI HUSNÆN WE ‘IN XHAHEDAKE LITUSHRIKE BI MA LEJSE LEKE BIHI ‘ILMUN FELA TUTI’HUMA ‘ILEJJE MERXHI’UKUM FE’UNEBBI’UKUM BIMA KUNTUM TA’MELUNE
  29,9,WEL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI LENUDHILENNEHUM FI ES-SALIHINE
  29,10,WE MINE EN-NASI MEN JEKULU ‘AMENNA BILLAHI FE’IDHA ‘UDHIJE FI ELLAHI XHE’ALE FITNETE EN-NASI KE’ADHABI ELLAHI WE LE’IN XHA’E NESRUN MIN RABBIKE LEJEKULUNNE ‘INNA KUNNA ME’AKUM ‘EWELEJSEL-LAHU BI’A’LEME BIMA FI SUDURIL-’ALEMINE
  29,11,WE LEJA’LEMENNEL-LAHUL-LEDHINE ‘AMENU WE LEJA’LEMENNEL-MUNAFIKINE
  29,12,WE KALEL-LEDHINE KEFERU LILLEDHINE ‘AMENU ETTEBI’U SEBILENA WE LNEHMIL HATAJAKUM WE MA HUM BIHAMILINE MIN HATAJAHUM MIN SHEJ’IN ‘INNEHUM LEKADHIBUNE
  29,13,WE LEJEHMILUNNE ‘ETHKALEHUM WE ‘ETHKALÆN ME’A ‘ETHKALIHIM WE LEJUS’ELUNNE JEWMEL-KIJAMETI ‘AMMA KANU JEFTERUNE
  29,14,WE LEKAD ‘ERSELNA NUHÆN ‘ILA KAWMIHI FELEBITHE FIHIM ‘ELFE SENETIN ‘ILLA HAMSINE ‘AMÆN FE’EHADHEHUMUT-TUFANU WE HUM DHALIMUN
  29,15,FE’ENXHEJNAHU WE ‘ESHABE ES-SEFINETI WE XHE’ALNAHA ‘AJETEN LIL’ALEMINE
  29,16,WE ‘IBRAHIME ‘IDH KALE LIKAWMIHI A’BUDU ELLAHE WE ETTEKUHU DHALIKUM HAJRUN LEKUM ‘IN KUNTUM TA’LEMUNE
  29,17,‘INNEMA TA’BUDUNE MIN DUNI ELLAHI ‘EWTHANÆN WE TEHLUKUNE ‘IFKÆN ‘INNEL-LEDHINE TA’BUDUNE MIN DUNI ELLAHI LA JEMLIKUNE LEKUM RIZKÆN FABTEGU ‘INDEL-LAHI ER-RIZKA WE A’BUDUHU WE ESHKURU LEHU ‘ILEJHI TURXHA’UNE
  29,18,WE ‘IN TUKEDHDHIBU FEKAD KEDHDHEBE ‘UMEMUN MIN KABLIKUM WE MA ‘ALA ER-RESULI ‘ILLAL-BELAGUL-MUBINU
  29,19,‘EWELEM JEREW KEJFE JUBDI’U ELLAHUL-HALKA THUMME JU’IDUHU ‘INNE DHALIKE ‘ALA ELLAHI JESIRUN
  29,20,KUL SIRU FIL-’ERDI FANDHURU KEJFE BEDE’EL-HALKA THUMMEL-LAHU JUNSHI’U EN-NESH’ETEL-’AHIRETE ‘INNALL-LLAHE ‘ALA KULLI SHEJ’IN KADIRUN
  29,21,JU’ADHDHIBU MEN JESHA’U WE JERHEMU MEN JESHA’U WE ‘ILEJHI TUKLEBUNE
  29,22,WE MA ‘ENTUM BIMU’XHIZINE FIL-’ERDI WE LA FI ES-SEMA’I WE MA LEKUM MIN DUNI ELLAHI MIN WE LIJIN WE LA NESIRIN
  29,23,WEL-LEDHINE KEFERU BI’AJATI ELLAHI WE LIKA’IHI ‘ULA’IKE JE’ISU MIN REHMETI WE ‘ULA’IKE LEHUM ‘ADHABUN ‘ELIMUN
  29,24,FEMA KANE XHEWABE KAWMIHI ‘ILLA ‘EN KALU EKTULUHU ‘EW HERRIKUHU FE’ENXHAHU ELLAHU MINE EN-NARI ‘INNE FI DHALIKE LE’AJATIN LIKAWMIN JU’UMINUNE
  29,25,WE KALE ‘INNEMA ETTEHADHTUM MIN DUNI ELLAHI ‘EWTHANÆN MEWEDDETE BEJNIKUM FIL-HEJÆTI ED-DUNJA THUMME JEWMEL-KIJAMETI JEKFURU BA’DUKUM BIBA’DIN WE JEL’ANU BA’DUKUM BA’DÆN WE ME’WAKUMU EN-NARU WE MA LEKUM MIN NASIRINE
  29,26,FE’AMENE LEHU LUTUN WE KALE ‘INNI MUHAXHIRUN ‘ILA RABBI ‘INNEHU HUWEL-’AZIZUL-HEKIMU
  29,27,WE WEHEBNA LEHU ‘ISHAKA WE JA’KUBE WE XHE’ALNA FI DHURRIJETIHI EN-NUBUWETE WEL-KITABE WE ‘ATEJNAHU ‘EXHREHU FI ED-DUNJA WE ‘INNEHU FIL-’AHIRETI LEMINE ES-SALIHIN
  29,28,WE LUTÆN ‘IDH KALE LIKAWMIHI ‘INNEKUM LETE’TUNEL-FAHISHETE MA SEBEKAKUM BIHA MIN ‘EHEDIN MINEL-’ALEMINE
  29,29,‘E’INNEKUM LETE’TUNE ER-RIXHALE WE TEKTA’UNE ES-SEBILE WE TE’TUNE FI NADIKUMUL-MUNKERE FEMA KANE XHEWABE KAWMIHI ‘ILLA ‘EN KALU E’TINA BI’ADHABI ELLAHI ‘IN KUNTE MINE ES-SADIKINE
  29,30,KALE RABBI ENSURNI ‘ALEL-KAWMIL-MUFSIDINE
  29,31,WE LEMMA XHA’ET RUSULUNA ‘IBRAHIME BIL-BUSHRA KALU ‘INNA MUHLIKU ‘EHLI HEDHIHIL-KARJETI ‘INNE ‘EHLEHA KANU DHALIMINE
  29,32,KALE ‘INNE FIHA LUTÆN KALU NEHNU ‘A’LEMU BIMEN FIHA LENUNEXHXHIJENNEHU WE ‘EHLEHU ‘ILLA EMRE’ETEHU KANET MINEL-GABIRIN
  29,33,WE LEMMA ‘EN XHA’ET RUSULUNA LUTÆN SI’E BIHIM WE DAKA BIHIM DHER’ÆN WE KALU LA TEHAF WE LA TEHZEN ‘INNA MUNEXHXHUKE WE ‘EHLEKE ‘ILLA EMRE’ETEKE KANET MINEL-GABIRINE
  29,34,‘INNA MUNZILUNE ‘ALA ‘EHLI HEDHIHIL-KARJETI RIXHZÆN MINE ES-SEMA’I BIMA KANU JEFSUKUNE
  29,35,WE LEKAD TEREKNA MINHA ‘AJETEN BEJJINETEN LIKAWMIN JA’KILUNE
  29,36,WE ‘ILA MEDJENE ‘EHAHUM SHU’AJBÆN FEKALE JA KAWMI A’BUDU ELLAHE WE ERXHUL-JEWMEL-’AHIRE WE LA TA’THEW FIL-’ERDI MUFSIDIN
  29,37,FEKEDHDHEBUHU FE’EHADHET/HUMU ER-REXHFETU FE’ESBEHU FI DARIHIM XHATHIMINE
  29,38,WE ‘ADÆN WE THEMUDE WE KAD TEBEJJENE LEKUM MIN MESAKINIHIM WE ZEJJENE LEHUMU ESH-SHEJTANU ‘A’MALEHUM FESEDDEHUM ‘ANI ES-SEBILI WE KANU MUSTEBSIRINE
  29,39,WE KARUNE WE FIR’AWNE WE HAMANE WE LEKAD XHA’EHUM MUSA BIL-BEJJINATI FASTEKBERU FIL-’ERDI WE MA KANU SABIKINE
  29,40,FEKULLÆN ‘EHADHNA BIDHENBIHI FEMINHUM MEN ‘ERSELNA ‘ALEJHI HASIBÆN WE MINHUM MEN ‘EHADHET/HU ES-SEJHETU WE MINHUM MEN HASEFNA BIHIL-’ERDE WE MINHUM MEN ‘EGREKNA WE MA KANEL-LAHU LIJEDHLIMEHUM WE LEKIN KANU ‘ENFUSEHUM JEDHLIMUNE
  29,41,METHELUL-LEDHINE ETTEHADHU MIN DUNI ELLAHI ‘EWLIJA’E KEMETHELIL-’ANKEBUTI ETTEHADHET BEJTÆN WE ‘INNE ‘EWHENEL-BUJUTI LEBEJTUL-’ANKEBUTI LEW KANU JA’LEMUNE
  29,42,‘INNALL-LLAHE JA’LEMU MA JED’UNE MIN DUNIHI MIN SHEJ’IN WE HUWEL-’AZIZUL-HEKIMU
  29,43,WE TILKEL-’EMTHALU NEDRIBUHA LILNNASI WE MA JA’KILUHA ‘ILLAL-’ALIMUNE
  29,44,HALEKAL-LAHU ES-SEMAWATI WEL-’ERDE BIL-HEKKI ‘INNE FI DHALIKE LE’AJETEN LILMU’UMININE
  29,45,ETLU MA ‘UHIJE ‘ILEJKE MINEL-KITABI WE ‘EKIMU ES-SELÆTE ‘INNE ES-SELÆTE TENHA ‘ANIL-FEHSHA’I WEL-MUNKERI WE LEDHIKRU ELLAHI ‘EKBERU WEL-LAHU JA’LEMU MA TESNA’UNE
  29,46,WE LA TUXHADILU ‘EHLEL-KITABI ‘ILLA BI-ETI HIJE ‘EHSENU ‘ILLAL-LEDHINE DHELEMU MINHUM WE KULU ‘AMENNA BIEL-LEDHI ‘UNZILE ‘ILEJNA WE ‘UNZILE ‘ILEJKUM WE ‘ILEHUNA WE ‘ILEHUKUM WAHIDUN WE NEHNU LEHU MUSLIMUNE
  29,47,WE KEDHELIKE ‘ENZELNA ‘ILEJKEL-KITABE FE-EL-LEDHINE ‘ATEJNAHUMUL-KITABE JU’UMINUNE BIHI WE MIN HA’UULA’ MEN JU’UMINU BIHI WE MA JEXHHEDU BI’AJATINA ‘ILLAL-KAFIRUNE
  29,48,WE MA KUNTE TETLU MIN KABLIHI MIN KITABIN WE LA TEHUTTUHU BIJEMINIKE ‘IDHÆN LARTABEL-MUBTILUNE
  29,49,BEL HUWE ‘AJATUN BEJJINATUN FI SUDURIL-LEDHINE ‘UTUL-’ILME WE MA JEXHHEDU BI’AJATINA ‘ILLA EDH-DHALIMUNE
  29,50,WE KALU LEWLA ‘UNZILE ‘ALEJHI ‘AJATUN MIN RABBIHI KUL ‘INNEMAL-’AJATU ‘INDEL-LAHI WE ‘INNEMA ‘ENA NEDHIRUN MUBINUN
  29,51,‘EWELEM JEKFIHIM ‘ENNA ‘ENZELNA ‘ALEJKEL-KITABE JUTLA ‘ALEJHIM ‘INNE FI DHALIKE LEREHMETEN WE DHIKRA LIKAWMIN JU’UMINUNE
  29,52,KUL KEFA BILLAHI BEJNI WE BEJNEKUM SHEHIDÆN JA’LEMU MA FI ES-SEMAWATI WEL-’ERDI WEL-LEDHINE ‘AMENU BIL-BATILI WE KEFERU BILLAHI ‘ULA’IKE HUMUL-HASIRUNE
  29,53,WE JESTA’XHILUNEKE BIL-’ADHABI WE LEWLA ‘EXHELUN MUSEMMEN LEXHA’EHUMUL-’ADHABU WE LEJE’TIJENNEHUM BEGTETEN WE HUM LA JESH’URUNE
  29,54,JESTA’XHILUNEKE BIL-’ADHABI WE ‘INNE XHEHENNEME LEMUHITETUN BIL-KAFIRINE
  29,55,JEWME JEGSHAHUMUL-’ADHABU MIN FEWKIHIM WE MIN TEHTI ‘ERXHULIHIM WE JEKULU DHUKU MA KUNTUM TA’MELUNE
  29,56,JA ‘IBADIJEL-LEDHINE ‘AMENU ‘INNE ‘ERDI WASI’ATUN FE’IJAJE FA’BUDUNI
  29,57,KULLU NEFSIN DHA’IKATUL-MEWTI THUMME ‘ILEJNA TURXHA’UNE
  29,58,WEL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI LENUBEWWI’ENNEHUM MINEL-XHENNETI GUREFÆN TEXHRI MIN TEHTIHAL-’ENHARU HALIDINE FIHA NI’ME ‘EXHRUL-’AMILINE
  29,59,EL-LEDHINE SEBERU WE ‘ALA RABBIHIM JETEWEKKELUNE
  29,60,WE KE’EJJIN MIN DABBETIN LA TEHMILU RIZKAHALLAHU JERZUKUHA WE ‘IJAKUM WE HUWE ES-SEMI’UL-’ALIMU
  29,61,WE LE’IN SE’ELTEHUM MEN HALEKA ES-SEMAWATI WEL-’ERDE WE SEHHARE ESH-SHEMSE WEL-KAMERE LEJEKULUNNEL-LAHU FE’ENNA JU’UFEKUNE
  29,62,ELLAHU JEBSUTU ER-RIZKA LIMEN JESHA’U MIN ‘IBADIHI WE JEKDIRU LEHU ‘INNALL-LLAHE BIKULLI SHEJ’IN ‘ALIMUN
  29,63,WE LE’IN SE’ELTEHUM MEN NEZZELE MINE ES-SEMA’I MA’EN FE’EHJA BIHIL-’ERDE MIN BA’DI MEWTIHA LEJEKULUNNEL-LAHU KULIL-HEMDU LILLAHI BEL ‘EKTHERUHUM LA JA’KILUNE
  29,64,WE MA HEDHIHIL-HEJÆTU ED-DUNJA ‘ILLA LEHWUN WE LA’IBUN WE ‘INNE ED-DAREL-’AHIRETE LEHIJEL-HEJEWANU LEW KANU JA’LEMUNE
  29,65,FE’IDHA REKIBU FIL-FULKI DE’AW ELLAHE MUHLISINE LEHU ED-DINE FELEMMA NEXHXHAHUM ‘ILAL-BERRI ‘IDHA HUM JUSHRIKUNE
  29,66,LIJEKFURU BIMA ‘ATEJNAHUM WE LIJETEMETTA’U FESEWFE JA’LEMUNE
  29,67,‘EWELEM JEREW ‘ENNA XHE’ALNA HEREMÆN ‘AMINÆN WE JUTEHATTEFU EN-NASU MIN HEWLIHIM ‘EFEBIALBATILI JU’UMINUNE WE BINI’METI ELLAHI JEKFURUNE
  29,68,WE MEN ‘EDHLEMU MIMMENI EFTERA ‘ALA ELLAHI KEDHIBÆN ‘EW KEDHDHEBE BIL-HEKKI LEMMA XHA’EHU ‘ELEJSE FI XHEHENNEME METHWEN LILKAFIRINE
  29,69,WEL-LEDHINE XHAHEDU FINA LENEHDIJENNEHUM SUBULENA WE ‘INNALL-LLAHE LEME’AL-MUHSININE
  30,1,‘ELIF-LAM-MIM
  30,2,GULIBETI ER-RUMU
  30,3,FI ‘EDNAL-’ERDI WE HUM MIN BA’DI GALEBIHIM SEJEGLIBUNE
  30,4,FI BID’I SININE LILLAHIL-’EMRU MIN KABLU WE MIN BA’DU WE JEWME’IDHIN JEFREHUL-MU’UMINUNE
  30,5,BINESRI ELLAHI JENSURU MEN JESHA’U WE HUWEL-’AZIZU ER-REHIMU
  30,6,WA’DEL-LAHI LA JUHLIFU ELLAHU WA’DEHU WE LEKINNE ‘EKTHERE EN-NASI LA JA’LEMUNE
  30,7,JA’LEMUNE DHAHIRÆN MINEL-HEJÆTI ED-DUNJA WE HUM ‘ANIL-’AHIRETI HUM GAFILUNE
  30,8,‘EWELEM JETEFEKKERU FI ‘ENFUSIHIM MA HALEKAL-LAHU ES-SEMAWATI WEL-’ERDE WE MA BEJNEHUMA ‘ILLA BIL-HEKKI WE ‘EXHELIN MUSEMMEN WE ‘INNE KETHIRÆN MINE EN-NASI BILIKA’I RABBIHIM LEKAFIRUNE
  30,9,‘EWELEM JESIRU FIL-’ERDI FEJENDHURU KEJFE KANE ‘AKIBETUL-LEDHINE MIN KABLIHIM KANU ‘ESHEDDE MINHUM KUWETEN WE ‘ETHARUL-’ERDE WE ‘AMERUHA ‘EKTHERE MIMMA ‘AMERUHA WE XHA’ET/HUM RUSULUHUM BIL-BEJJINATI FEMA KANEL-LAHU LIJEDHLIMEHUM WE LEKIN KANU ‘ENFUSEHUM J
  30,10,THUMME KANE ‘AKIBETEL-LEDHINE ‘ESA’U ES-SU’A ‘EN KEDHDHEBU BI’AJATI ELLAHI WE KANU BIHA JESTEHZI’UN
  30,11,ELLAHU JEBDE’UL-HALKA THUMME JU’IDUHU THUMME ‘ILEJHI TURXHA’UNE
  30,12,WE JEWME TEKUMU ES-SA’ATU JUBLISUL-MUXHRIMUNE
  30,13,WE LEM JEKUN LEHUM MIN SHUREKA’IHIM SHUFA’A’U WE KANU BISHUREKA’IHIM KAFIRINE
  30,14,WE JEWME TEKUMU ES-SA’ATU JEWME’IDHIN JETEFERREKUNE
  30,15,FE’EMMAL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI FEHUM FI REWDETIN JUHBERUNE
  30,16,WE ‘EMMAL-LEDHINE KEFERU WE KEDHDHEBU BI’AJATINA WE LIKA’IL-’AHIRETI FE’ULA’IKE FIL-’ADHABI MUHDERUNE
  30,17,FESUBHANEL-LAHI HINE TUMSUNE WE HINE TUSBIHUNE
  30,18,WE LEHUL-HEMDU FI ES-SEMAWATI WEL-’ERDI WE ‘ASHIJÆN WE HINE TUDHHIRUNE
  30,19,JUHRIXHUL-HEJJE MINEL-MEJJITI WE JUHRIXHUL-MEJJITE MINEL-HEJJI WE JUHJIL-’ERDE BA’DE MEWTIHA WE KEDHELIKE TUHREXHUNE
  30,20,WE MIN ‘AJATIHI ‘EN HALEKAKUM MIN TURABIN THUMME ‘IDHA ‘ENTUM BESHERUN TENTESHIRUNE
  30,21,WE MIN ‘AJATIHI ‘EN HALEKA LEKUM MIN ‘ENFUSIKUM ‘EZWAXHÆN LITESKUNU ‘ILEJHA WE XHE’ALE BEJNEKUM MEWEDDETEN WE REHMETEN ‘INNE FI DHALIKE LE’AJATIN LIKAWMIN JETEFEKKERUNE
  30,22,WE MIN ‘AJATIHI HALKU ES-SEMAWATI WEL-’ERDI WE EHTILAFU ‘ELSINETIKUM WE ‘ELWANIKUM ‘INNE FI DHALIKE LE’AJATIN LIL’ALIMINE
  30,23,WE MIN ‘AJATIHI MENAMUKUM BIL-LEJLI WE EN-NEHARI WE EBTIGA’UUKUM MIN FEDLIHI ‘INNE FI DHALIKE LE’AJATIN LIKAWMIN JESMA’UNE
  30,24,WE MIN ‘AJATIHI JURIKUMUL-BERKA HAWFÆN WE TEMA’ÆN WE JUNEZZILU MINE ES-SEMA’I MA’EN FEJUHJI BIHIL-’ERDE BA’DE MEWTIHA ‘INNE FI DHALIKE LE’AJATIN LIKAWMIN JA’KILUNE
  30,25,WE MIN ‘AJATIHI ‘EN TEKUME ES-SEMA’U WEL-’ERDU BI’EMRIHI THUMME ‘IDHA DA’AKUM DA’WETEN MINEL-’ERDI ‘IDHA ‘ENTUM TEHRUXHUNE
  30,26,WE LEHU MEN FI ES-SEMAWATI WEL-’ERDI KULLUN LEHU KANITUNE
  30,27,WE HUWEL-LEDHI JEBDE’UL-HALKA THUMME JU’IDUHU WE HUWE ‘EHWENU ‘ALEJHI WE LEHUL-METHELUL-’A’LA FI ES-SEMAWATI WEL-’ERDI WE HUWEL-’AZIZUL-HEKIMU
  30,28,DEREBE LEKUM METHELÆN MIN ‘ENFUSIKUM HEL LEKUM MIN MA MELEKET ‘EJMANUKUM MIN SHUREKA’E FI MA REZEKNAKUM FE’ENTUM FIHI SEWA’UN TEHAFUNEHUM KEHIFETIKUM ‘ENFUSEKUM KEDHALIKE NUFESSILUL-’AJATI LIKAWMIN JA’KILUNE
  30,29,BEL ETTEBE’AL-LEDHINE DHELEMU ‘EHWA’EHUM BIGAJRI ‘ILMIN FEMEN JEHDI MEN ‘EDELLEL-LAHU WE MA LEHUM MIN NASIRINE
  30,30,FE’EKIM WEXHHEKE LILDDINI HENIFÆN FITRETEL-LAHI ELLETI FETERE EN-NASE ‘ALEJHA LA TEBDILE LIHALKI ELLAHI DHALIKE ED-DINUL-KAJJIMU WE LEKINNE ‘EKTHERE EN-NASI LA JA’LEMUNE
  30,31,MUNIBINE ‘ILEJHI WE ETTEKUHU WE ‘EKIMU ES-SELÆTE WE LA TEKUNU MINEL-MUSHRIKINE
  30,32,MINEL-LEDHINE FERREKU DINEHUM WE KANU SHIJA’ÆN KULLU HIZBIN BIMA LEDEJHIM FERIHUNE
  30,33,WE ‘IDHA MESSE EN-NASE DURRUN DE’AW REBBEHUM MUNIBINE ‘ILEJHI THUMME ‘IDHA ‘EDHAKAHUM MINHU REHMETEN ‘IDHA FERIKUN MINHUM BIREBBIHIM JUSHRIKUNE
  30,34,LIJEKFURU BIMA ‘ATEJNAHUM FETEMETTA’U FESEWFE TA’LEMUNE
  30,35,‘EM ‘ENZELNA ‘ALEJHIM SULTANÆN FEHUWE JETEKELLEMU BIMA KANU BIHI JUSHRIKUNE
  30,36,WE ‘IDHA ‘EDHEKNA EN-NASE REHMETEN FERIHU BIHA WE ‘IN TUSIBHUM SEJJI’ETUN BIMA KADDEMET ‘EJDIHIM ‘IDHA HUM JEKNETUNE
  30,37,‘EWELEM JEREW ‘ENNEL-LAHE JEBSUTU ER-RIZKA LIMEN JESHA’U WE JEKDIRU ‘INNE FI DHALIKE LE’AJATIN LIKAWMIN JU’UMINUNE
  30,38,FE’ATI DHAL-KURBA HEKKAHU WEL-MISKINE WE EBNE ES-SEBILI DHALIKE HAJRUN LILLEDHINE JURIDUNE WEXHHEL-LAHI WE ‘ULA’IKE HUMUL-MUFLIHUNE
  30,39,WE MA ‘ATEJTUM MIN RIBÆN LIJERBUWA FI ‘EMWALI EN-NASI FELA JERBU ‘INDEL-LAHI WE MA ‘ATEJTUM MIN ZEKÆTIN TURIDUNE WEXHHEL-LAHI FE’ULA’IKE HUMUL-MUD’IFUNE
  30,40,ELLAHUL-LEDHI HALEKAKUM THUMME REZEKAKUM THUMME JUMITUKUM THUMME JUHJIKUM HEL MIN SHUREKA’IKUM MEN JEF’ALU MIN DHALIKUM MIN SHEJ’IN SUBHANEHU WE TA’ALA ‘AMMA JUSHRIKUNE
  30,41,DHEHEREL-FESADU FIL-BERRI WEL-BEHRI BIMA KESEBET ‘EJDI EN-NASI LIJUDHIKAHUM BA’DEL-LEDHI ‘AMILU LE’ALLEHUM JERXHI’UNE
  30,42,KUL SIRU FIL-’ERDI FANDHURU KEJFE KANE ‘AKIBETUL-LEDHINE MIN KABLU KANE ‘EKTHERUHUM MUSHRIKINE
  30,43,FE’EKIM WEXHHEKE LILDDINIL-KAJJIMI MIN KABLI ‘EN JE’TIJE JEWMUN LA MEREDDE LEHU MINEL-LAHI JEWME’IDHIN JESSEDDA’UNE
  30,44,MEN KEFERE FE’ALEJHI KUFRUHU WE MEN ‘AMILE SALIHÆN FELI’ENFUSIHIM JEMHEDUNE
  30,45,LIJEXHZIJEL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI MIN FEDLIHI ‘INNEHU LA JUHIBBUL-KAFIRINE
  30,46,WE MIN ‘AJATIHI ‘EN JURSILE ER-RIJAHE MUBESHSHIRATIN WE LIJUDHIKAKUM MIN REHMETIHI WE LITEXHRIJEL-FULKU BI’EMRIHI WE LITEBTEGU MIN FEDLIHI WE LE’ALLEKUM TESHKURUNE
  30,47,WE LEKAD ‘ERSELNA MIN KABLIKE RUSULÆN ‘ILA KAWMIHIM FEXHA’UHUM BIL-BEJJINATI FANTEKAMNA MINEL-LEDHINE ‘EXHREMU WE KANE HEKKÆN ‘ALEJNA NESRUL-MU’UMININE
  30,48,ELLAHUL-LEDHI JURSILU ER-RIJAHE FETUTHIRU SEHABÆN FEJEBSUTUHU FI ES-SEMA’I KEJFE JESHA’U WE JEXH’ALUHU KISEFÆN FETERAL-WEDKA JEHRUXHU MIN HILALIHI FE’IDHA ‘ESABE BIHI MEN JESHA’U MIN ‘IBADIHI ‘IDHA HUM JESTEBSHIRUNE
  30,49,WE ‘IN KANU MIN KABLI ‘EN JUNEZZELE ‘ALEJHIM MIN KABLIHI LEMUBLISINE
  30,50,FANDHUR ‘ILA ‘ATHARI REHMETI ELLAHI KEJFE JUHJIL-’ERDE BA’DE MEWTIHA ‘INNE DHALIKE LEMUHJIL-MEWTA WE HUWE ‘ALA KULLI SHEJ’IN KADIRUN
  30,51,WE LE’IN ‘ERSELNA RIHÆN FERE’EWHU MUSFERRÆN LEDHELLU MIN BA’DIHI JEKFURUNE
  30,52,FE’INNEKE LA TUSMI’UL-MEWTA WE LA TUSMI’U ES-SUMME ED-DU’A’E ‘IDHA WE LLEW MUDBIRINE
  30,53,WE MA ‘ENTE BIHADIL-’UMJI ‘AN DELALETIHIM ‘IN TUSMI’U ‘ILLA MEN JU’UMINU BI’AJATINA FEHUM MUSLIMUN
  30,54,ELLAHUL-LEDHI HALEKAKUM MIN DA’FIN THUMME XHE’ALE MIN BA’DI DA’FIN KUWETEN THUMME XHE’ALE MIN BA’DI KUWETIN DA’FÆN WE SHEJBETEN JEHLUKU MA JESHA’U WE HUWEL-’ALIMUL-KADIRU
  30,55,WE JEWME TEKUMU ES-SA’ATU JUKSIMUL-MUXHRIMUNE MA LEBITHU GAJRE SA’ATIN KEDHALIKE KANU JU’UFEKUNE
  30,56,WE KALEL-LEDHINE ‘UTUL-’ILME WEL-’IMANE LEKAD LEBITHTUM FI KITABI ELLAHI ‘ILA JEWMIL-BA’THI FEHEDHA JEWMUL-BA’THI WE LEKINNEKUM KUNTUM LA TA’LEMUNE
  30,57,FEJEWME’IDHIN LA JENFA’UL-LEDHINE DHELEMU MA’DHIRETUHUM WE LA HUM JUSTA’TEBUNE
  30,58,WE LEKAD DEREBNA LILNNASI FI HADHAL-KUR’ANI MIN KULLI METHELIN WE LE’IN XHI’TEHUM BI’AJETIN LEJEKULENNEL-LEDHINE KEFERU ‘IN ‘ENTUM ‘ILLA MUBTILUNE
  30,59,KEDHALIKE JETBA’U ELLAHU ‘ALA KULUBIL-LEDHINE LA JA’LEMUNE
  30,60,FASBIR ‘INNE WA’DEL-LAHI HEKKUN WE LA JESTEHIFFENNEKEL-LEDHINE LA JUKINUNE
  31,1,‘ELIF-LAM-MIM
  31,2,TILKE ‘AJATUL-KITABIL-HEKIMI
  31,3,HUDEN WE REHMETEN LILMUHSININE
  31,4,EL-LEDHINE JUKIMUNE ES-SELÆTE WE JU’UTUNE EZ-ZEKÆTE WE HUM BIL-’AHIRETI HUM JUKINUNE
  31,5,‘ULA’IKE ‘ALA HUDEN MIN RABBIHIM WE ‘ULA’IKE HUMUL-MUFLIHUNE
  31,6,WE MINE EN-NASI MEN JESHTERI LEHWEL-HEDITHI LIJUDILLE ‘AN SEBILI ELLAHI BIGAJRI ‘ILMIN WE JETTEHIDHEHA HUZUEN ‘ULE’IKE LEHUM ‘ADHABUN MUHINUN
  31,7,WE ‘IDHA TUTLA ‘ALEJHI ‘AJATUNA WELLA MUSTEKBIRÆN KE’EN LEM JESMA’HA KE’ENNE FI ‘UDHUNEJHI WEKRÆN FEBESHSHIRHU BI’ADHABIN ‘ELIMIN
  31,8,‘INNEL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI LEHUM XHENNATU EN-NA’IMI
  31,9,HALIDINE FIHA WA’DEL-LAHI HEKKÆN WE HUWEL-’AZIZUL-HEKIMU
  31,10,HALEKA ES-SEMAWATI BIGAJRI ‘AMEDIN TEREWNEHA WE ‘ELKA FIL-’ERDI REWASIJE ‘EN TEMIDE BIKUM WE BETHTHE FIHA MIN KULLI DABBETIN WE ‘ENZELNA MINE ES-SEMA’I MA’EN FE’ENBETNA FIHA MIN KULLI ZEWXHIN KERIMIN
  31,11,HADHA HALKU ELLAHI FE’ERUNI MADHA HALEKAL-LEDHINE MIN DUNIHI BELI EDH-DHALIMUNE FI DELALIN MUBININ
  31,12,WE LEKAD ‘ATEJNA LUKMANEL-HIKMETE ‘ENI ESHKUR LILLAHI WE MEN JESHKUR FE’INNEMA JESHKURU LINEFSIHI WE MEN KEFERE FE’INNALL-LLAHE GANIJUN HEMIDUN
  31,13,WE ‘IDH KALE LUKMANU LIABNIHI WE HUWE JA’IDHUHU JA BUNEJJE LA TUSHRIK BILLAHI ‘INNE ESH-SHIRKE LEDHULMUN ‘ADHIMUN
  31,14,WE WESSEJNAL-’INSANE BIWALIDEJHI HEMELET/HU ‘UMMUHU WEHNÆN ‘ALA WEHNIN WE FISALUHU FI ‘AMEJNI ‘ENI ESHKUR LI WE LIWALIDEJKE ‘ILEJJEL-MESIRU
  31,15,WE ‘IN XHAHEDAKE ‘ALA ‘EN TUSHRIKE BI MA LEJSE LEKE BIHI ‘ILMUN FELA TUTI’HUMA WE SAHIBHUMA FI ED-DUNJA MA’RUFÆN WE ETTEBI’ SEBILE MEN ‘ENABE ‘ILEJJE THUMME ‘ILEJJE MERXHI’UKUM FE’UNEBBI’UKUM BIMA KUNTUM TA’MELUNE
  31,16,JA BUNEJJE ‘INNEHA ‘IN TEKUN MITHKALE HEBBETIN MIN HARDELIN FETEKUN FI SEHRETIN ‘EW FI ES-SEMAWATI ‘EW FIL-’ERDI JE’TI BIHALLAHU ‘INNALL-LLAHE LETIFUN HABIRUN
  31,17,JA BUNEJJE ‘EKIMI ES-SELÆTE WE ‘MUR BIL-MA’RUFI WE ENHE ‘ANIL-MUNKERI WE ESBIR ‘ALA MA ‘ESABEKE ‘INNE DHALIKE MIN ‘AZMIL-’UMURI
  31,18,WE LA TUSA’’IR HADDEKE LILNNASI WE LA TEMSHI FIL-’ERDI MEREHÆN ‘INNALL-LLAHE LA JUHIBBU KULLE MUHTALIN FEHURIN
  31,19,WAKSID FI MESHJIKE WE EGDUD MIN SEWTIKE ‘INNE ‘ENKEREL-’ESWATI LESEWTUL-HEMIRI
  31,20,‘ELEM TEREW ‘ENNEL-LAHE SEHHARE LEKUM MA FI ES-SEMAWATI WE MA FIL-’ERDI WE ‘ESBEGA ‘ALEJKUM NI’AMEHU DHAHIRETEN WE BATINETEN WE MINE EN-NASI MEN JUXHADILU FI ELLAHI BIGAJRI ‘ILMIN WE LA HUDEN WE LA KITABIN MUNIRIN
  31,21,WE ‘IDHA KILE LEHUMU ETTEBI’U MA ‘ENZELEL-LAHU KALU BEL NETTEBI’U MA WEXHEDNA ‘ALEJHI ‘ABA’ENA ‘EWELEW KANE ESH-SHEJTANU JED’UHUM ‘ILA ‘ADHABI ES-SA’IRI
  31,22,WE MEN JUSLIM WEXHHEHU ‘ILA ELLAHI WE HUWE MUHSINUN FEKADI ESTEMSEKE BIL-’URWETIL-WUTHKA WE ‘ILA ELLAHI ‘AKIBETUL-’UMURI
  31,23,WE MEN KEFERE FELA JEHZUNKE KUFRUHU ‘ILEJNA MERXHI’UHUM FENUNEBBI’UHUM BIMA ‘AMILU ‘INNALL-LLAHE ‘ALIMUN BIDHATI ES-SUDURI
  31,24,NUMETTI’UHUM KALILÆN THUMME NEDTERRUHUM ‘ILA ‘ADHABIN GALIDHIN
  31,25,WE LE’IN SE’ELTEHUM MEN HALEKA ES-SEMAWATI WEL-’ERDE LEJEKULUNNEL-LAHU KULIL-HEMDU LILLAHI BEL ‘EKTHERUHUM LA JA’LEMUNE
  31,26,LILLAHI MA FI ES-SEMAWATI WEL-’ERDI ‘INNALL-LLAHE HUWEL-GANIJUL-HEMIDU
  31,27,WE LEW ‘ENNEMA FIL-’ERDI MIN SHEXHERETIN ‘EKLAMUN WEL-BEHRU JEMUDDUHU MIN BA’DIHI SEB’ATU ‘EBHURIN MA NEFIDET KELIMATU ELLAHI ‘INNALL-LLAHE ‘AZIZUN HEKIMUN
  31,28,MA HALKUKUM WE LA BA’THUKUM ‘ILLA KENEFSIN WAHIDETIN ‘INNALL-LLAHE SEMI’UN BESIRUN
  31,29,‘ELEM TERA ‘ENNEL-LAHE JULIXHUL-LEJLE FI EN-NEHARI WE JULIXHU EN-NEHARE FIL-LEJLI WE SEHHARE ESH-SHEMSE WEL-KAMERE KULLUN JEXHRI ‘ILA ‘EXHELIN MUSEMMEN WE ‘ENNEL-LAHE BIMA TA’MELUNE HABIRUN
  31,30,DHALIKE BI’ENNEL-LAHE HUWEL-HEKKU WE ‘ENNE MA JED’UNE MIN DUNIHIL-BATILU WE ‘ENNEL-LAHE HUWEL-’ALIJUL-KEBIRU
  31,31,‘ELEM TERA ‘ENNEL-FULKE TEXHRI FIL-BEHRI BINI’METI ELLAHI LIJURIJEKUM MIN ‘AJATIHI ‘INNE FI DHALIKE LE’AJATIN LIKULLI SEBBARIN SHEKURIN
  31,32,WE ‘IDHA GASHIJEHUM MEWXHUN KALDHDHULELI DE’AW ELLAHE MUHLISINE LEHU ED-DINE FELEMMA NEXHXHAHUM ‘ILAL-BERRI FEMINHUM MUKTESIDUN WE MA JEXHHEDU BI’AJATINA ‘ILLA KULLU HATTARIN KEFURIN
  31,33,JA ‘EJJUHA EN-NASU ETTEKU REBBEKUM WE EHSHEW JEWMÆN LA JEXHZI WE E-DUN ‘AN WELEDIHI WE LA MEWLUDUN HUWE XHAZIN ‘AN WE E-DIHI SHEJ’ÆN ‘INNE WA’DEL-LAHI HEKKUN FELA TEGURRENNEKUMUL-HEJA ETU ED-DUNJA WE LA JEGURRENNEKUM BILLAHIL-GARURU
  31,34,‘INNALL-LLAHE ‘INDEHU ‘ILMU ES-SA’ATI WE JUNEZZILUL-GAJTHE WE JA’LEMU MA FIL-’ERHAMI WE MA TEDRI NEFSUN MADHA TEKSIBU GADÆN WE MA TEDRI NEFSUN BI’EJJI ‘ERDIN TEMUTU ‘INNALL-LLAHE ‘ALIMUN HABIRUN
  32,1,‘ELIF-LAM-MIM
  32,2,TENZILUL-KITABI LA REJBE FIHI MIN RABBIL-’ALEMINE
  32,3,‘EM JEKULUNE EFTERAHU BEL HUWEL-HEKKU MIN RABBIKE LITUNDHIRE KAWMÆN MA ‘ETAHUM MIN NEDHIRIN MIN KABLIKE LE’ALLEHUM JEHTEDUNE
  32,4,ELLAHUL-LEDHI HALEKA ES-SEMAWATI WEL-’ERDE WE MA BEJNEHUMA FI SITTETI ‘EJJAMIN THUMME ESTEWA ‘ALEL-’ARSHI MA LEKUM MIN DUNIHI MIN WE LIJIN WE LA SHEFI’IN ‘EFELA TETEDHEKKERUNE
  32,5,JUDEBBIRUL-’EMRE MINE ES-SEMA’I ‘ILAL-’ERDI THUMME JA’RUXHU ‘ILEJHI FI JEWMIN KANE MIKDARUHU ‘ELFE SENETIN MIMMA TA’UDDUNE
  32,6,DHALIKE ‘ALIMUL-GAJBI WE ESH-SHEHADETIL-’AZIZU ER-REHIMU
  32,7,EL-LEDHI ‘EHSENE KULLE SHEJ’IN HALEKAHU WE BEDE’E HALKAL-’INSANI MIN TININ
  32,8,THUMME XHE’ALE NESLEHU MIN SULALETIN MIN MA’IN MEHININ
  32,9,THUMME SEWWAHU WE NEFEHA FIHI MIN RUHIHI WE XHE’ALE LEKUMU ES-SEM’A WEL-’EBSARE WEL-’EF’IDETE KALILÆN MA TESHKURUNE
  32,10,WE KALU ‘E’IDHA DELELNA FIL-’ERDI ‘E’INNA LEFI HALKIN XHEDIDIN BEL HUM BILIKA’I RABBIHIM KAFIRUNE
  32,11,KUL JETEWEFFAKUM MELEKUL-MEWTIL-LEDHI WUKKILE BIKUM THUMME ‘ILA RABBIKUM TURXHA’UNE
  32,12,WE LEW TERA ‘IDHIL-MUXHRIMUNE NAKISU RU’USIHIM ‘INDE RABBIHIM REBBENA ‘EBSERNA WE SEMI’NA FARXHI’NA NA’MEL SALIHÆN ‘INNA MUKINUNE
  32,13,WE LEW SHI’NA LE’ATEJNA KULLE NEFSIN HUDAHA WE LEKIN HEKKAL-KAWLU MINNI LE’EMLE’ENNE XHEHENNEME MINEL-XHINNETI WE EN-NASI ‘EXHMA’INE
  32,14,FEDHUKU BIMA NESITUM LIKA’E JEWMIKUM HADHA ‘INNA NESINAKUM WE DHUKU ‘ADHABEL-HULDI BIMA KUNTUM TA’MELUNE
  32,15,‘INNEMA JU’UMINU BI’AJATINAL-LEDHINE ‘IDHA DHUKKIRU BIHA HARRU SUXHXHEDÆN WE SEBBEHU BIHEMDI RABBIHIM WE HUM LA JESTEKBIRUNE
  32,16,TETEXHAFA XHUNUBUHUM ‘ANIL-MEDAXHI’I JED’UNE REBBEHUM HAWFÆN WE TEMA’ÆN WE MIMMA REZEKNAHUM JUNFIKUNE
  32,17,FELA TA’LEMU NEFSUN MA ‘UHFIJE LEHUM MIN KURRETI ‘A’JUNIN XHEZA’EN BIMA KANU JA’MELUNE
  32,18,‘EFEMEN KANE MU’UMINÆN KEMEN KANE FASIKÆN LA JESTEWUNE
  32,19,‘EMMAL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI FELEHUM XHENNATUL-ME’WA NUZULÆN BIMA KANU JA’MELUNE
  32,20,WE ‘EMMAL-LEDHINE FESEKU FEME’WAHUMU EN-NARU KULLEMA ‘ERADU ‘EN JEHRUXHU MINHA ‘U’IDU FIHA WE KILE LEHUM DHUKU ‘ADHABE EN-NARIL-LEDHI KUNTUM BIHI TUKEDHDHIBUNE
  32,21,WE LENUDHIKANNEHUM MINEL-’ADHABIL-’EDNA DUNEL-’ADHABIL-’EKBERI LE’ALLEHUM JERXHI’UNE
  32,22,WE MEN ‘EDHLEMU MIMMEN DHUKKIRE BI’AJATI RABBIHI THUMME ‘A’REDE ‘ANHA ‘INNA MINEL-MUXHRIMINE MUNTEKIMUNE
  32,23,WE LEKAD ‘ATEJNA MUSAL-KITABE FELA TEKUN FI MIRJETIN MIN LIKA’IHI WE XHE’ALNAHU HUDEN LIBENI ‘ISRA’ILE
  32,24,WE XHE’ALNA MINHUM ‘E’IMMETEN JEHDUNE BI’EMRINA LEMMA SEBERU WE KANU BI’AJATINA JUKINUNE
  32,25,‘INNE REBBEKE HUWE JEFSILU BEJNEHUM JEWMEL-KIJAMETI FIMA KANU FIHI JEHTELIFUNE
  32,26,‘EWELEM JEHDI LEHUM KEM ‘EHLEKNA MIN KABLIHIM MINEL-KURUNI JEMSHUNE FI MESAKINIHIM ‘INNE FI DHALIKE LE’AJATIN ‘EFELA JESMA’UNE
  32,27,‘EWELEM JEREW ‘ENNA NESUKUL-MA’E ‘ILAL-’ERDIL-XHURUZI FENUHRIXHU BIHI ZER’ÆN TE’KULU MINHU ‘EN’AMUHUM WE ‘ENFUSUHUM ‘EFELA JUBSIRUNE
  32,28,WE JEKULUNE META HADHAL-FETHU ‘IN KUNTUM SADIKINE
  32,29,KUL JEWMEL-FETHI LA JENFA’UL-LEDHINE KEFERU ‘IMANUHUM WE LA HUM JUNDHERUNE
  32,30,FE’A’RID ‘ANHUM WE ENTEDHIR ‘INNEHUM MUNTEDHIRUNE
  33,1,JA ‘EJJUHA EN-NEBIJU ETTEKI ELLAHE WE LA TUTI’IL-KAFIRINE WEL-MUNAFIKINE ‘INNALL-LLAHE KANE ‘ALIMÆN HEKIMÆN
  33,2,WE ETTEBI’ MA JUHA ‘ILEJKE MIN RABBIKE ‘INNALL-LLAHE KANE BIMA TA’MELUNE HABIRÆN
  33,3,WE TEWEKKEL ‘ALA ELLAHI WE KEFA BILLAHI WE KILÆN
  33,4,MA XHE’ALEL-LAHU LIREXHULIN MIN KALBEJNI FI XHEWFIHI WE MA XHE’ALE ‘EZWAXHEKUMUL-LA’I TUDHAHIRUNE MINHUNNE ‘UMMEHATIKUM WE MA XHE’ALE ‘ED’IJA’EKUM ‘EBNA’EKUM DHALIKUM KAWLUKUM BI’EFWAHIKUM WEL-LAHU JEKULUL-HEKKA WE HUWE JEHDI ES-SEBILE
  33,5,ED’UHUM LI’EBA’IHIM HUWE ‘EKSETU ‘INDEL-LAHI FE’IN LEM TA’LEMU ‘ABA’EHUM FE’IHWANUKUM FI ED-DINI WE MEWALIKUM WE LEJSE ‘ALEJKUM XHUNAHUN FIMA ‘EHTE’TUM BIHI WE LEKIN MA TE’AMMEDET KULUBUKUM WE KANEL-LAHU GAFURÆN REHIMÆN
  33,6,EN-NEBIJU ‘EWLA BIL-MU’UMININE MIN ‘ENFUSIHIM WE ‘EZWAXHUHU ‘UMMEHATUHUM WE ‘ULUL-’ERHAMI BA’DUHUM ‘EWLA BIBA’DIN FI KITABI ELLAHI MINEL-MU’UMININE WEL-MUHAXHIRINE ‘ILLA ‘EN TEF’ALU ‘ILA ‘EWLIJA’IKUM MA’RUFÆN KANE DHALIKE FIL-KITABI MESTURÆN
  33,7,WE ‘IDH ‘EHADHNA MINE EN-NEBIJINE MITHAKAHUM WE MINKE WE MIN NUHIN WE ‘IBRAHIME WE MUSA WE ‘ISA EBNI MERJEME WE ‘EHADHNA MINHUM MITHAKÆN GALIDHÆN
  33,8,LIJES’ELE ES-SADIKINE ‘AN SIDKIHIM WE ‘E’ADDE LILKAFIRINE ‘ADHABÆN ‘ELIMÆN
  33,9,JA ‘EJJUHAL-LEDHINE ‘AMENU EDHKURU NI’METEL-LAHI ‘ALEJKUM ‘IDH XHA’ETKUM XHUNUDUN FE’ERSELNA ‘ALEJHIM RIHÆN WE XHUNUDÆN LEM TEREWHA WE KANEL-LAHU BIMA TA’MELUNE BESIRÆN
  33,10,‘IDH XHA’UKUM MIN FEWKIKUM WE MIN ‘ESFELE MINKUM WE ‘IDH ZAGATIL-’EBSARU WE BELEGATIL-KULUBUL-HENAXHIRE WE TEDHUNNUNE BILLAHI EDH-DHUNUNE
  33,11,HUNALIKE EBTULIJEL-MU’UMINUNE WE ZULZILU ZILZALÆN SHEDIDÆN
  33,12,WE ‘IDH JEKULUL-MUNAFIKUNE WEL-LEDHINE FI KULUBIHIM MEREDUN MA WE’ADENALLAHU WE RESULUHU ‘ILLA GURURÆN
  33,13,WE ‘IDH KALET TA’IFETUN MINHUM JA ‘EHLE JETHRIBE LA MUKAME LEKUM FARXHI’U WE JESTE’DHINU FERIKUN MINHUMU EN-NEBIJE JEKULUNE ‘INNE BUJUTENA ‘AWRETUN WE MA HIJE BI’AWRETIN ‘IN JURIDUNE ‘ILLA FIRARÆN
  33,14,WE LEW DUHILET ‘ALEJHIM MIN ‘EKTARIHA THUMME SU’ILUL-FITNETE LE’ATEWHA WE MA TELEBBETHU BIHA ‘ILLA JESIRÆN
  33,15,WE LEKAD KANU ‘AHEDU ELLAHE MIN KABLU LA JUWELLUNEL-’EDBARE WE KANE ‘AHDU ELLAHI MES’ULÆN
  33,16,KUL LEN JENFE’AKUMUL-FIRARU ‘IN FERERTUM MINEL-MEWTI ‘EWIL-KATLI WE ‘IDHÆN LA TUMETTA’UNE ‘ILLA KALILÆN
  33,17,KUL MEN DHAL-LEDHI JA’SIMUKUM MINEL-LAHI ‘IN ‘ERADE BIKUM SU’ÆN ‘EW ‘ERADE BIKUM REHMETEN WE LA JEXHIDUNE LEHUM MIN DUNI ELLAHI WELIJÆN WE LA NESIRÆN
  33,18,KAD JA’LEMU ELLAHUL-MU’AWWIKINE MINKUM WEL-KA’ILINE LI’IHWANIHIM HELUMME ‘ILEJNA WE LA JE’TUNEL-BE’SE ‘ILLA KALILÆN
  33,19,‘ESHIHHETEN ‘ALEJKUM FE’IDHA XHA’EL-HAWFU RE’EJTEHUM JENDHURUNE ‘ILEJKE TEDURU ‘A’JUNUHUM KALLEDHI JUGSHA ‘ALEJHI MINEL-MEWTI FE’IDHA DHEHEBEL-HAWFU SELEKUKUM BI’ELSINETIN HIDADIN ‘ESHIHHETEN ‘ALEL-HAJRI ‘ULA’IKE LEM JU’UMINU FE’EHBETEL-LAHU ‘A’MALEHUM WE
  33,20,JEHSEBUNEL-’EHZABE LEM JEDH/HEBU WE ‘IN JE’TIL-’EHZABU JEWEDDU LEW ‘ENNEHUM BADUNE FIL-’A’RABI JES’ELUNE ‘AN ‘ENBA’IKUM WE LEW KANU FIKUM MA KATELU ‘ILLA KALILÆN
  33,21,LEKAD KANE LEKUM FI RESULI ELLAHI ‘USWETUN HESENETUN LIMEN KANE JERXHU ELLAHE WEL-JEWMEL-’AHIRE WE DHEKEREL-LAHE KETHIRÆN
  33,22,WE LEMMA RE’AL-MU’UMINUNEL-’EHZABE KALU HADHA MA WE’ADENALLAHU WE RESULUHU WE SEDEKAL-LAHU WE RESULUHU WE MA ZADEHUM ‘ILLA ‘IMANÆN WE TESLIMÆN
  33,23,MINEL-MU’UMININE RIXHALUN SEDEKU MA ‘AHEDU ELLAHE ‘ALEJHI FEMINHUM MEN KADA NEHBEHU WE MINHUM MEN JENTEDHIRU WE MA BEDDELU TEBDILÆN
  33,24,LIJEXHZIJEL-LAHU ES-SADIKINE BISIDKIHIM WE JU’ADHDHIBEL-MUNAFIKINE ‘IN SHA’E ‘EW JETUBE ‘ALEJHIM ‘INNALL-LLAHE KANE GAFURÆN REHIMÆN
  33,25,WEREDDEL-LAHUL-LEDHINE KEFERU BIGAJDHIHIM LEM JENALU HAJRÆN WE KEFALLAHUL-MU’UMININEL-KITALE WE KANEL-LAHU KAWIJÆN ‘AZIZÆN
  33,26,WE ‘ENZELEL-LEDHINE DHAHERUHUM MIN ‘EHLIL-KITABI MIN SEJASIHIM WE KADHEFE FI KULUBIHIMU ER-RU’BE FERIKÆN TEKTULUNE WE TE’SIRUNE FERIKÆN
  33,27,WE ‘EWRETHEKUM ‘ERDEHUM WE DIJAREHUM WE ‘EMWALEHUM WE ‘ERDÆN LEM TETE’UHA WE KANEL-LAHU ‘ALA KULLI SHEJ’IN KADIRÆN
  33,28,JA ‘EJJUHA EN-NEBIJU KUL LI’ZWAXHIKE ‘IN KUNTUNNE TURIDNEL-HEJA ETE ED-DUNJA WE ZINETEHA FETA’ALEJNE ‘UMETTI’KUNNE WE ‘USERRIHKUNNE SERAHÆN XHEMILÆN
  33,29,WE ‘IN KUNTUNNE TURIDNEL-LAHE WE RESULEHU WE ED-DAREL-’AHIRETE FE’INNALL-LLAHE ‘E’ADDE LILMUHSINATI MINKUNNE ‘EXHRÆN ‘ADHIMÆN
  33,30,JA NISA’E EN-NEBIJI MEN JE’TI MINKUNNE BIFAHISHETIN MUBEJJINETIN JUDA’AF LEHAL-’ADHABU DI’FEJNI WE KANE DHALIKE ‘ALA ELLAHI JESIRÆN
  33,31,WE MEN JEKNUT MINKUNNE LILLAHI WE RESULIHI WE TA’MEL SALIHÆN NU’UTIHA ‘EXHREHA MERRETEJNI WE ‘A’TEDNA LEHA RIZKÆN KERIMÆN
  33,32,JA NISA’E EN-NEBIJI LESTUNNE KE’EHEDIN MINE EN-NISA’ ‘INI ETTEKAJTUNNE FELA TEHDA’NE BIL-KAWLI FEJETME’AL-LEDHI FI KALBIHI MEREDUN WE KULNE KAWLÆN MA’RUFÆN
  33,33,WE KARNE FI BUJUTIKUNNE WE LA TEBERREXHNE TEBERRUXHEL-XHAHILIJETIL-’ULA WE ‘EKIMNE ES-SELÆTE WE ‘ATINE EZ-ZEKÆTE WE ‘ETI’NEL-LAHE WE RESULEHU ‘INNEMA JURIDU ELLAHU LIJUDH/HIBE ‘ANKUMU ER-RIXHSE ‘EHLEL-BEJTI WE JUTEHHIREKUM TETHIRÆN
  33,34,WE EDHKURNE MA JUTLA FI BUJUTIKUNNE MIN ‘AJATI ELLAHI WEL-HIKMETI ‘INNALL-LLAHE KANE LETIFÆN HABIRÆN
  33,35,‘INNEL-MUSLIMINE WEL-MUSLIMATI WEL-MU’UMININE WEL-MU’UMINATI WEL-KANITINE WEL-KANITATI WE ES-SADIKINE WE ES-SADIKATI WE ES-SABIRINE WE ES-SABIRATI WEL-HASHI’INE WEL-HASHI’ATI WEL-MUTESEDDIKINE WEL-MUTESEDDIKATI WE ES-SA’IMINE WE ES-SA’IMATI WEL-HAFIDHINE
  33,36,WE MA KANE LIMU’UMININ WE LA MU’UMINETIN ‘IDHA KADALLAHU WE RESULUHU ‘EMRÆN ‘EN JEKUNE LEHUMUL-HIJERETU MIN ‘EMRIHIM WE MEN JA’SI ELLAHE WE RESULEHU FEKAD DELLE DELALÆN MUBINÆN
  33,37,WE ‘IDH TEKULU LILLEDHI ‘EN’AMEL-LAHU ‘ALEJHI WE ‘EN’AMTE ‘ALEJHI ‘EMSIK ‘ALEJKE ZEWXHEKE WE ETTEKI ELLAHE WE TUHFI FI NEFSIKE MALLAHU MUBDIHI WE TEHSHA EN-NASE WEL-LAHU ‘EHEKKU ‘EN TEHSHAHU FELEMMA KADA ZEJDUN MINHA WETERÆN ZEWWEXHNAKEHA LIKEJ LA JEKUNE
  33,38,MA KANE ‘ALA EN-NEBIJI MIN HEREXHIN FIMA FEREDEL-LAHU LEHU SUNNETEL-LAHI FIL-LEDHINE HALEW MIN KABLU WE KANE ‘EMRU ELLAHI KADERÆN MEKDURÆN
  33,39,EL-LEDHINE JUBELLIGUNE RISALATI ELLAHI WE JEHSHEWNEHU WE LA JEHSHEWNE ‘EHEDÆN ‘ILLALLAHE WE KEFA BILLAHI HESIBÆN
  33,40,MA KANE MUHEMMEDUN ‘EBA ‘EHEDIN MIN RIXHALIKUM WE LEKIN RESULEL-LAHI WE HATEME EN-NEBIJINE WE KANEL-LAHU BIKULLI SHEJ’IN ‘ALIMÆN
  33,41,JA ‘EJJUHAL-LEDHINE ‘AMENU EDHKURU ELLAHE DHIKRÆN KETHIRÆN
  33,42,WE SEBBIHUHU BUKRETEN WE ‘ESILÆN
  33,43,HUWEL-LEDHI JUSELLI ‘ALEJKUM WE MELA’IKETUHU LIJUHRIXHEKUM MINE EDH-DHULUMATI ‘ILA EN-NURI WE KANE BIL-MU’UMININE REHIMÆN
  33,44,TEHIJETUHUM JEWME JELKAWNEHU SELAMUN WE ‘E’ADDE LEHUM ‘EXHRÆN KERIMÆN
  33,45,JA ‘EJJUHA EN-NEBIJU ‘INNA ‘ERSELNAKE SHAHIDÆN WE MUBESHSHIRÆN WE NEDHIRÆN
  33,46,WE DA’IÆN ‘ILA ELLAHI BI’IDHNIHI WE SIRAXHÆN MUNIRÆN
  33,47,WE BESHSHIRIL-MU’UMININE BI’ENNE LEHUM MINEL-LAHI FEDLÆN KEBIRÆN
  33,48,WE LA TUTI’IL-KAFIRINE WEL-MUNAFIKINE WE DA’ ‘EDHAHUM WE TEWEKKEL ‘ALA ELLAHI WE KEFA BILLAHI WE KILÆN
  33,49,JA ‘EJJUHAL-LEDHINE ‘AMENU ‘IDHA NEKEHTUMUL-MU’UMINATI THUMME TELLEKTUMUHUNNE MIN KABLI ‘EN TEMESSUHUNNE FEMA LEKUM ‘ALEJHINNE MIN ‘IDDETIN TA’TEDDUNEHA FEMETTI’UHUNNE WE SERRIHUHUNNE SERAHÆN XHEMILÆN
  33,50,JA ‘EJJUHA EN-NEBIJU ‘INNA ‘EHLELNA LEKE ‘EZWAXHEKEL-LATI ‘ATEJTE ‘UXHUREHUNNE WE MA MELEKET JEMINUKE MIMMA ‘EFA’EL-LAHU ‘ALEJKE WE BENATI ‘AMMIKE WE BENATI ‘AMMATIKE WE BENATI HALIKE WE BENATI HALATIKEL-LATI HAXHERNE ME’AKE WE EMRE’ETEN MU’UMINETEN ‘IN W
  33,51,TURXHI MEN TESHA’U MINHUNNE WE TU’UWI ‘ILEJKE MEN TESHA’U WE MENI EBTEGAJTE MIMMEN ‘AZELTE FELA XHUNAHE ‘ALEJKE DHALIKE ‘EDNA ‘EN TEKARRE ‘A’JUNUHUNNE WE LA JEHZENNE WE JERDEJNE BIMA ‘ATEJTEHUNNE KULLUHUNNE WEL-LAHU JA’LEMU MA FI KULUBIKUM WE KANEL-LAHU ‘
  33,52,LA JEHILLU LEKE EN-NISA’ MIN BA’DU WE LA ‘EN TEBEDDELE BIHINNE MIN ‘EZWAXHIN WE LEW ‘A’XHEBEKE HUSNUHUNNE ‘ILLA MA MELEKET JEMINUKE WE KANEL-LAHU ‘ALA KULLI SHEJ’IN REKIBÆN
  33,53,JA ‘EJJUHAL-LEDHINE ‘AMENU LA TEDHULU BUJUTE EN-NEBIJI ‘ILLA ‘EN JU’UDHENE LEKUM ‘ILA TA’AMIN GAJRE NADHIRINE ‘INAHU WE LEKIN ‘IDHA DU’ITUM FADHULU FE’IDHA TA’IMTUM FANTESHIRU WE LA MUSTE’NISINE LIHEDITHIN ‘INNE DHALIKUM KANE JU’UDHI EN-NEBIJE FEJESTEHJI
  33,54,‘IN TUBDU SHEJ’ÆN ‘EW TUHFUHU FE’INNALL-LLAHE KANE BIKULLI SHEJ’IN ‘ALIMÆN
  33,55,LA XHUNAHE ‘ALEJHINNE FI ‘ABA’IHINNE WE LA ‘EBNA’IHINNE WE LA ‘IHWANIHINNE WE LA ‘EBNA’I ‘IHWANIHINNE WE LA ‘EBNA’I ‘EHAWATIHINNE WE LA NISA’IHINNE WE LA MA MELEKET ‘EJMANUHUNNE WE ETTEKINEL-LAHE ‘INNALL-LLAHE KANE ‘ALA KULLI SHEJ’IN SHEHIDÆN
  33,56,‘INNALL-LLAHE WE MELA’IKETEHU JUSELLUNE ‘ALA EN-NEBIJI JA ‘EJJUHAL-LEDHINE ‘AMENU SELLU ‘ALEJHI WE SELLIMU TESLIMÆN
  33,57,‘INNEL-LEDHINE JU’UDHUNEL-LAHE WE RESULEHU LE’ANEHUMU ELLAHU FI ED-DUNJA WEL-’AHIRETI WE ‘E’ADDE LEHUM ‘ADHABÆN MUHINÆN
  33,58,WEL-LEDHINE JU’UDHUNEL-MU’UMININE WEL-MU’UMINATI BIGAJRI MA EKTESEBU FEKADI EHTEMELU BUHTANÆN WE ‘ITHMÆN MUBINÆN
  33,59,JA ‘EJJUHA EN-NEBIJU KUL LI’ZWAXHIKE WE BENATIKE WE NISA’IL-MU’UMININE JUDNINE ‘ALEJHINNE MIN XHELABIBIHINNE DHALIKE ‘EDNA ‘EN JU’REFNE FELA JU’UDHEJNE WE KANEL-LAHU GAFURÆN REHIMÆN
  33,60,LE’IN LEM JENTEHIL-MUNAFIKUNE WEL-LEDHINE FI KULUBIHIM MEREDUN WEL-MURXHIFUNE FIL-MEDINETI LENUGRIJENNEKE BIHIM THUMME LA JUXHAWIRUNEKE FIHA ‘ILLA KALILÆN
  33,61,MEL’UNINE ‘EJNEMA THUKIFU ‘UHIDHU WE KUTTILU TEKTILÆN
  33,62,SUNNETEL-LAHI FIL-LEDHINE HALEW MIN KABLU WE LEN TEXHIDE LISUNNETI ELLAHI TEBDILÆN
  33,63,JES’ELUKE EN-NASU ‘ANI ES-SA’ATI KUL ‘INNEMA ‘ILMUHA ‘INDEL-LAHI WE MA JUDRIKE LE’ALLE ES-SA’ATE TEKUNU KARIBÆN
  33,64,‘INNALL-LLAHE LE’ANEL-KAFIRINE WE ‘E’ADDE LEHUM SA’IRÆN
  33,65,HALIDINE FIHA ‘EBEDÆN LA JEXHIDUNE WELIJÆN WE LA NESIRÆN
  33,66,JEWME TUKALLEBU WUXHUHUHUM FI EN-NARI JEKULUNE JA LEJTENA ‘ETA’NA ELLAHE WE ‘ETA’NA ER-RESULA
  33,67,WE KALU REBBENA ‘INNA ‘ETA’NA SADETENA WE KUBERA’ENA FE’EDELLUNA ES-SEBILA
  33,68,REBBENA ‘ATIHIM DI’FEJNI MINEL-’ADHABI WEL-’ANHUM LA’NÆN KEBIRÆN
  33,69,JA ‘EJJUHAL-LEDHINE ‘AMENU LA TEKUNU KALLEDHINE ‘ADHEW MUSA FEBERRE’EHU ELLAHU MIMMA KALU WE KANE ‘INDEL-LAHI WEXHIHÆN
  33,70,JA ‘EJJUHAL-LEDHINE ‘AMENU ETTEKU ELLAHE WE KULU KAWLÆN SEDIDÆN
  33,71,JUSLIH LEKUM ‘A’MALEKUM WE JEGFIR LEKUM DHUNUBEKUM WE MEN JUTI’I ELLAHE WE RESULEHU FEKAD FAZE FEWZÆN ‘ADHIMÆN
  33,72,‘INNA ‘AREDNAL-’EMANETE ‘ALA ES-SEMAWATI WEL-’ERDI WEL-XHIBALI FE’EBEJNE ‘EN JEHMILNEHA WE ‘ESHFEKNE MINHA WE HEMELEHAL-’INSANU ‘INNEHU KANE DHELUMÆN XHEHULÆN
  33,73,LIJU’ADHDHIBEL-LAHUL-MUNAFIKINE WEL-MUNAFIKATI WEL-MUSHRIKINE WEL-MUSHRIKATI WE JETUBEL-LAHU ‘ALEL-MU’UMININE WEL-MU’UMINATI WE KANEL-LAHU GAFURÆN REHIMÆN
  34,1,EL-HEMDU LILLAHIL-LEDHI LEHU MA FI ES-SEMAWATI WE MA FIL-’ERDI WE LEHUL-HEMDU FIL-’AHIRETI WE HUWEL-HEKIMUL-HABIRU
  34,2,JA’LEMU MA JELIXHU FIL-’ERDI WE MA JEHRUXHU MINHA WE MA JENZILU MINE ES-SEMA’I WE MA JA’RUXHU FIHA WE HUWE ER-REHIMUL-GAFURU
  34,3,WE KALEL-LEDHINE KEFERU LA TE’TINA ES-SA’ATU KUL BELA WE RABBI LETE’TIJENNEKUM ‘ALIMIL-GAJBI LA JA’ZUBU ‘ANHU MITHKALU DHERRETIN FI ES-SEMAWATI WE LA FIL-’ERDI WE LA ‘ESGARU MIN DHALIKE WE LA ‘EKBERU ‘ILLA FI KITABIN MUBININ
  34,4,LIJEXHZIJEL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI ‘ULA’IKE LEHUM MEGFIRETUN WE RIZKUN KERIMUN
  34,5,WEL-LEDHINE SE’AW FI ‘AJATINA MU’AXHIZINE ‘ULA’IKE LEHUM ‘ADHABUN MIN RIXHZIN ‘ELIMUN
  34,6,WE JERAL-LEDHINE ‘UTUL-’ILMEL-LEDHI ‘UNZILE ‘ILEJKE MIN RABBIKE HUWEL-HEKKA WE JEHDI ‘ILA SIRATIL-’AZIZIL-HEMIDI
  34,7,WE KALEL-LEDHINE KEFERU HEL NEDULLUKUM ‘ALA REXHULIN JUNEBBI’UKUM ‘IDHA MUZZIKTUM KULLE MUMEZZEKIN ‘INNEKUM LEFI HALKIN XHEDIDIN
  34,8,‘AFTERA ‘ALA ELLAHI KEDHIBÆN ‘EM BIHI XHINNETUN BELIL-LEDHINE LA JU’UMINUNE BIL-’AHIRETI FIL-’ADHABI WE ED-DELALIL-BA’IDI
  34,9,‘EFELEM JEREW ‘ILA MA BEJNE ‘EJDIHIM WE MA HALFEHUM MINE ES-SEMA’I WEL-’ERDI ‘IN NESHE’ NEHSIF BIHIMUL-’ERDE ‘EW NUSKIT ‘ALEJHIM KISEFÆN MINE ES-SEMA’I ‘INNE FI DHALIKE LE’AJETEN LIKULLI ‘ABDIN MUNIBIN
  34,10,WE LEKAD ‘ATEJNA DAWUDE MINNA FEDLÆN JA XHIBALU ‘EWWIBI ME’AHU WET-TEJRE WE ‘ELENNA LEHUL-HEDIDE
  34,11,‘ENI A’MEL SABIGATIN WE KADDIR FI ES-SERDI WE A’MELU SALIHÆN ‘INNI BIMA TA’MELUNE BESIRUN
  34,12,WE LISULEJMANE ER-RIHE GUDUWUHA SHEHRUN WE REWAHUHA SHEHRUN WE ‘ESELNA LEHU ‘AJNEL-KITRI WE MINEL-XHINNI MEN JA’MELU BEJNE JEDEJHI BI’IDHNI RABBIHI WE MEN JEZIG MINHUM ‘AN ‘EMRINA NUDHIKHU MIN ‘ADHABI ES-SA’IRI
  34,13,JA’MELUNE LEHU MA JESHA’U MIN MEHARIBE WE TEMATHILE WE XHIFANIN KALXHEWABI WE KUDURIN RASIJATIN A’MELU ‘ALE DAWUDE SHUKRÆN WE KALILUN MIN ‘IBADIJE ESH-SHEKURU
  34,14,FELEMMA KADEJNA ‘ALEJHIL-MEWTE MA DELLEHUM ‘ALA MEWTIHI ‘ILLA DABBETUL-’ERDI TE’KULU MINSE’ETEHU FELEMMA HARRE TEBEJJENETIL-XHINNU ‘EN LEW KANU JA’LEMUNEL-GAJBE MA LEBITHU FIL-’ADHABIL-MUHINI
  34,15,LEKAD KANE LISEBE’IIN FI MESKENIHIM ‘AJETUN XHENNETANI ‘AN JEMININ WE SHIMALIN KULU MIN RIZKI RABBIKUM WE ESHKURU LEHU BELDETUN TEJJIBETUN WE REBBUN GAFURUN
  34,16,FE’A’REDU FE’ERSELNA ‘ALEJHIM SEJLEL-’ARIMI WE BEDDELNAHUM BIXHENNETEJHIM XHENNETEJNI DHEWATA ‘UKULIN HAMTIN WE ‘ETHLIN WE SHEJ’IN MIN SIDRIN KALILIN
  34,17,DHALIKE XHEZEJNAHUM BIMA KEFERU WE HEL NUXHAZI ‘ILLAL-KEFURE
  34,18,WE XHE’ALNA BEJNEHUM WE BEJNEL-KURA ELLETI BAREKNA FIHA KUREN DHAHIRETEN WE KADDERNA FIHA ES-SEJRE SIRU FIHA LEJALIJE WE ‘EJJAMÆN ‘AMININE
  34,19,FEKALU REBBENA BA’ID BEJNE ‘ESFARINA WE DHELEMU ‘ENFUSEHUM FEXHE’ALNAHUM ‘EHADITHE WE MEZZEKNAHUM KULLE MUMEZZEKIN ‘INNE FI DHALIKE LE’AJATIN LIKULLI SEBBARIN SHEKURIN
  34,20,WE LEKAD SEDDEKA ‘ALEJHIM ‘IBLISU DHENNEHU FE ETTEBA’UHU ‘ILLA FERIKÆN MINEL-MU’UMININE
  34,21,WE MA KANE LEHU ‘ALEJHIM MIN SULTANIN ‘ILLA LINA’LEME MEN JU’UMINU BIL-’AHIRETI MIMMEN HUWE MINHA FI SHEKKIN WE REBBUKE ‘ALA KULLI SHEJ’IN HEFIDHUN
  34,22,KUL ED’UL-LEDHINE ZE’AMTUM MIN DUNI ELLAHI LA JEMLIKUNE MITHKALE DHERRETIN FI ES-SEMAWATI WE LA FIL-’ERDI WE MA LEHUM FIHIMA MIN SHIRKIN WE MA LEHU MINHUM MIN DHEHIRIN
  34,23,WE LA TENFA’U ESH-SHEFA’ATU ‘INDEHU ‘ILLA LIMEN ‘EDHINE LEHU HETTA ‘IDHA FUZZI’A ‘AN KULUBIHIM KALU MADHA KALE REBBUKUM KALUL-HEKKA WE HUWEL-’ALIJUL-KEBIRU
  34,24,KUL MEN JERZUKUKUM MINE ES-SEMAWATI WEL-’ERDI KULI ELLAHU WE ‘INNA ‘EW ‘IJAKUM LE’ALA HUDEN ‘EW FI DELALIN MUBININ
  34,25,KUL LA TUS’ELUNE ‘AMMA ‘EXHREMNA WE LA NUS’ELU ‘AMMA TA’MELUNE
  34,26,KUL JEXHMA’U BEJNENA REBBUNA THUMME JEFTEHU BEJNENA BIL-HEKKI WE HUWEL-FETTAHUL-’ALIMU
  34,27,KUL ‘ERUNIJEL-LEDHINE ‘ELHEKTUM BIHI SHUREKA’E KELLA BEL HUWEL-LAHUL-’AZIZUL-HEKIMU
  34,28,WE MA ‘ERSELNAKE ‘ILLA KAFFETEN LILNNASI BESHIRÆN WE NEDHIRÆN WE LEKINNE ‘EKTHERE EN-NASI LA JA’LEMUNE
  34,29,WE JEKULUNE META HADHAL-WA’DU ‘IN KUNTUM SADIKINE
  34,30,KUL LEKUM MI’ADU JEWMIN LA TESTE’HIRUNE ‘ANHU SA’ATEN WE LA TESTEKDIMUNE
  34,31,WE KALEL-LEDHINE KEFERU LEN NU’UMINE BIHEDHAL-KUR’ANI WE LA BIEL-LEDHI BEJNE JEDEJHI WE LEW TERA ‘IDHI EDH-DHALIMUNE MEWKUFUNE ‘INDE RABBIHIM JERXHI’U BA’DUHUM ‘ILA BA’DINL-KAWLE JEKULUL-LEDHINE ESTUD’IFU LILLEDHINE ESTEKBERU LEWLA ‘ENTUM LEKUNNA MU’UMINI
  34,32,KALEL-LEDHINE ESTEKBERU LILLEDHINE ESTUD’IFU ‘ENEHNU SEDEDNAKUM ‘ANIL-HUDA BA’DE ‘IDH XHA’EKUM BEL KUNTUM MUXHRIMINE
  34,33,WE KALEL-LEDHINE ESTUD’IFU LILLEDHINE ESTEKBERU BEL MEKRUL-LEJLI WE EN-NEHARI ‘IDH TE’MURUNENA ‘EN NEKFURE BILLAHI WE NEXH’ALE LEHU ‘ENDADÆN WE ‘ESERRU EN-NEDAMETE LEMMA RE’EWL-’ADHABE WE XHE’ALNAL-’EGLALE FI ‘A’NAKIL-LEDHINE KEFERU HEL JUXHZEWNE ‘ILLA MA
  34,34,WE MA ‘ERSELNA FI KARJETIN MIN NEDHIRIN ‘ILLA KALE MUTREFUHA ‘INNA BIMA ‘URSILTUM BIHI KAFIRUNE
  34,35,WE KALU NEHNU ‘EKTHERU ‘EMWALÆN WE ‘EWLADÆN WE MA NEHNU BIMU’ADHDHEBINE
  34,36,KUL ‘INNE RABBI JEBSUTU ER-RIZKA LIMEN JESHA’U WE JEKDIRU WE LEKINNE ‘EKTHERE EN-NASI LA JA’LEMUNE
  34,37,WE MA ‘EMWALUKUM WE LA ‘EWLADUKUM BI-ETI TUKARRIBUKUM ‘INDENA ZULFA ‘ILLA MEN ‘AMENE WE ‘AMILE SALIHÆN FE’ULA’IKE LEHUM XHEZA’U ED-DI’FI BIMA ‘AMILU WE HUM FIL-GURUFATI ‘AMINUNE
  34,38,WEL-LEDHINE JES’AWNE FI ‘AJATINA MU’AXHIZINE ‘ULA’IKE FIL-’ADHABI MUHDERUNE
  34,39,KUL ‘INNE RABBI JEBSUTU ER-RIZKA LIMEN JESHA’U MIN ‘IBADIHI WE JEKDIRU LEHU WE MA ‘ENFEKTUM MIN SHEJ’IN FEHUWE JUHLIFUHU WE HUWE HAJRU ER-RAZIKINE
  34,40,WE JEWME JEHSHURUHUM XHEMI’ÆN THUMME JEKULU LILMELA’IKETI ‘EHA’UULA’ ‘IJAKUM KANU JA’BUDUNE
  34,41,KALU SUBHANEKE ‘ENTE WELIJUNA MIN DUNIHIM BEL KANU JA’BUDUNEL-XHINNE ‘EKTHERUHUM BIHIM MU’UMINUNE
  34,42,FALJEWME LA JEMLIKU BA’DUKUM LIBA’DIN NEF’ÆN WE LA DERRÆN WE NEKULU LILLEDHINE DHELEMU DHUKU ‘ADHABE EN-NARI ELLETI KUNTUM BIHA TUKEDHDHIBUN
  34,43,WE ‘IDHA TUTLA ‘ALEJHIM ‘AJATUNA BEJJINATIN KALU MA HADHA ‘ILLA REXHULUN JURIDU ‘EN JESUDDEKUM ‘AMMA KANE JA’BUDU ‘ABA’UUKUM WE KALU MA HADHA ‘ILLA ‘IFKUN MUFTEREN WE KALEL-LEDHINE KEFERU LILHEKKI LEMMA XHA’EHUM ‘IN HADHA ‘ILLA SIHRUN MUBINUN
  34,44,WE MA ‘ATEJNAHUM MIN KUTUBIN JEDRUSUNEHA WE MA ‘ERSELNA ‘ILEJHIM KABLEKE MIN NEDHIRIN
  34,45,WE KEDHDHEBEL-LEDHINE MIN KABLIHIM WE MA BELEGU MI’SHARE MA ‘ATEJNAHUM FEKEDHDHEBU RUSULI FEKEJFE KANE NEKIRI
  34,46,KUL ‘INNEMA ‘A’IDHUKUM BIWAHIDETIN ‘EN TEKUMU LILLAHI METHNA WE FURADA THUMME TETEFEKKERU MA BISAHIBIKUM MIN XHINNETIN ‘IN HUWE ‘ILLA NEDHIRUN LEKUM BEJNE JEDEJ ‘ADHABIN SHEDIDIN
  34,47,KUL MA SE’ELTUKUM MIN ‘EXHRIN FEHUWE LEKUM ‘IN ‘EXHRIJE ‘ILLA ‘ALA ELLAHI WE HUWE ‘ALA KULLI SHEJ’IN SHEHIDUN
  34,48,KUL ‘INNE RABBI JEKDHIFU BIL-HEKKI ‘ALLAMUL-GUJUBI
  34,49,KUL XHA’EL-HEKKU WE MA JUBDI’UL-BATILU WE MA JU’IDU
  34,50,KUL ‘IN DELELTU FE’INNEMA ‘EDILLU ‘ALA NEFSI WE ‘INI EHTEDEJTU FEBIMA JUHI ‘ILEJJE RABBI ‘INNEHU SEMI’UN KARIBUN
  34,51,WE LEW TERA ‘IDH FEZI’U FELA FEWTE WE ‘UHIDHU MIN MEKANIN KARIBIN
  34,52,WE KALU ‘AMENNA BIHI WE ‘ENNA LEHUMUT-TENAWUSHU MIN MEKANIN BA’IDIN
  34,53,WE KAD KEFERU BIHI MIN KABLU WE JEKDHIFUNE BIL-GAJBI MIN MEKANIN BA’IDIN
  34,54,WE HILE BEJNEHUM WE BEJNE MA JESHTEHUNE KEMA FU’ILE BI’ESHJA’IHIM MIN KABLU ‘INNEHUM KANU FI SHEKKIN MURIBIN
  35,1,EL-HEMDU LILLAHI FATIRI ES-SEMAWATI WEL-’ERDI XHA’ILIL-MELA’IKETI RUSULÆN ‘ULI ‘EXHNIHETIN METHNA WE THULATHE WE RUBA’A JEZIDU FIL-HALKI MA JESHA’U ‘INNALL-LLAHE ‘ALA KULLI SHEJ’IN KADIRUN
  35,2,MA JEFTEHI ELLAHU LILNNASI MIN REHMETIN FELA MUMSIKE LEHA WE MA JUMSIK FELA MURSILE LEHU MIN BA’DIHI WE HUWEL-’AZIZUL-HEKIMU
  35,3,JA ‘EJJUHA EN-NASU EDHKURU NI’METEL-LAHI ‘ALEJKUM HEL MIN HALIKIN GAJRU ELLAHI JERZUKUKUM MINE ES-SEMA’I WEL-’ERDI LA ‘ILAHE ‘ILLA HUWE FE’ENNA TU’UFEKUNE
  35,4,WE ‘IN JUKEDHDHIBUKE FEKAD KUDHDHIBET RUSULUN MIN KABLIKE WE ‘ILA ELLAHI TURXHA’UL-’UMURU
  35,5,JA ‘EJJUHA EN-NASU ‘INNE WA’DEL-LAHI HEKKUN FELA TEGURRENNEKUMUL-HEJA ETU ED-DUNJA WE LA JEGURRENNEKUM BILLAHIL-GARURU
  35,6,‘INNE ESH-SHEJTANE LEKUM ‘ADUWUN FE ETTEHIDHUHU ‘ADUWÆN ‘INNEMA JED’U HIZBEHU LIJEKUNU MIN ‘ESHABI ES-SA’IRI
  35,7,EL-LEDHINE KEFERU LEHUM ‘ADHABUN SHEDIDUN WEL-LEDHINE ‘AMENU WE ‘AMILU ES-SALIHATI LEHUM MEGFIRETUN WE ‘EXHRUN KEBIRUN
  35,8,‘EFEMEN ZUJJINE LEHU SU’U ‘AMELIHI FERE’AHU HESENÆN FE’INNALL-LLAHE JUDILLU MEN JESHA’U WE JEHDI MEN JESHA’U FELA TEDH/HEB NEFSUKE ‘ALEJHIM HESERATIN ‘INNALL-LLAHE ‘ALIMUN BIMA JESNA’UNE
  35,9,WEL-LAHUL-LEDHI ‘ERSELE ER-RIJAHE FETUTHIRU SEHABÆN FESUKNAHU ‘ILA BELEDIN MEJJITIN FE’EHJEJNA BIHIL-’ERDE BA’DE MEWTIHA KEDHALIKE EN-NUSHURU
  35,10,MEN KANE JURIDUL-’IZZETE FELILLAHIL-’IZZETU XHEMI’ÆN ‘ILEJHI JES’ADUL-KELIMUT-TEJJIBU WEL-’AMELU ES-SALIHU JERFA’UHU WEL-LEDHINE JEMKURUNE ES-SEJJI’ATI LEHUM ‘ADHABUN SHEDIDUN WE MEKRU ‘ULA’IKE HUWE JEBURU
  35,11,WEL-LAHU HALEKAKUM MIN TURABIN THUMME MIN NUTFETIN THUMME XHE’ALEKUM ‘EZWAXHÆN WE MA TEHMILU MIN ‘UNTHA WE LA TEDA’U ‘ILLA BI’ILMIHI WE MA JU’AMMERU MIN MU’AMMERIN WE LA JUNKASU MIN ‘UMURIHI ‘ILLA FI KITABIN ‘INNE DHALIKE ‘ALA ELLAHI JESIRUN
  35,12,WE MA JESTEWIL-BEHRANI HADHA ‘ADHBUN FURATUN SA’IGUN SHERABUHU WE HEDHA MILHUN ‘UXHAXHUN WE MIN KULLIN TE’KULUNE LEHMÆN TERIJÆN WE TESTEHRIXHUNE HILJETEN TELBESUNEHA WE TERAL-FULKE FIHI MEWAHIRE LITEBTEGU MIN FEDLIHI WE LE’ALLEKUM TESHKURUNE
  35,13,JULIXHUL-LEJLE FI EN-NEHARI WE JULIXHU EN-NEHARE FIL-LEJLI WE SEHHARE ESH-SHEMSE WEL-KAMERE KULLUN JEXHRI LI’XHELIN MUSEMMEN DHELIKUMU ELLAHU REBBUKUM LEHUL-MULKU WEL-LEDHINE TED’UNE MIN DUNIHI MA JEMLIKUNE MIN KITMIRIN
  35,14,‘IN TED’UHUM LA JESMA’U DU’A’EKUM WE LEW SEMI’U MA ESTEXHABU LEKUM WE JEWMEL-KIJAMETI JEKFURUNE BISHIRKIKUM WE LA JUNEBBI’UKE MITHLU HABIRIN
  35,15,JA ‘EJJUHA EN-NASU ‘ENTUMUL-FUKARA’U ‘ILA ELLAHI WEL-LAHU HUWEL-GANIJUL-HEMIDU
  35,16,‘IN JESHE’ JUDH/HIBKUM WE JE’TI BIHALKIN XHEDIDIN
  35,17,WE MA DHALIKE ‘ALA ELLAHI BI’AZIZIN
  35,18,WE LA TEZIRU WAZIRETUN WIZRE ‘UHRA WE ‘IN TED’U MUTHKALETUN ‘ILA HIMLIHA LA JUHMEL MINHU SHEJ’UN WE LEW KANE DHA KURBA ‘INNEMA TUNDHIRUL-LEDHINE JEHSHEWNE REBBEHUM BIL-GAJBI WE ‘EKAMU ES-SELÆTE WE MEN TEZEKKA FE’INNEMA JETEZEKKA LINEFSIHI WE ‘ILA ELLAHIL
  35,19,WE MA JESTEWIL-’A’MA WEL-BESIRU
  35,20,WE LA EDH-DHULUMATU WE LA EN-NUR
  35,21,WE LA EDH-DHILLU WE LAL-HERURU
  35,22,WE MA JESTEWIL-’EHJA’U WE LAL-’EMWATU ‘INNALL-LLAHE JUSMI’U MEN JESHA’U WE MA ‘ENTE BIMUSMI’IN MEN FIL-KUBURI
  35,23,‘IN ‘ENTE ‘ILLA NEDHIRUN
  35,24,‘INNA ‘ERSELNAKE BIL-HEKKI BESHIRÆN WE NEDHIRÆN WE ‘IN MIN ‘UMMETIN ‘ILLA HALA FIHA NEDHIRUN
  35,25,WE ‘IN JUKEDHDHIBUKE FEKAD KEDHDHEBEL-LEDHINE MIN KABLIHIM XHA’ET/HUM RUSULUHUM BIL-BEJJINATI WE BIZ-ZUBURI WE BIL-KITABIL-MUNIRI
  35,26,THUMME ‘EHADHTUL-LEDHINE KEFERU FEKEJFE KANE NEKIRI
  35,27,‘ELEM TERA ‘ENNEL-LAHE ‘ENZELE MINE ES-SEMA’I MA’EN FE’EHREXHNA BIHI THEMERATIN MUHTELIFÆN ‘ELWANUHA WE MINEL-XHIBALI XHUDEDUN BIDUN WE HUMRUN MUHTELIFUN ‘ELWANUHA WE GARABIBU SUDUN
  35,28,WE MINE EN-NASI WE ED-DEWABBI WEL-’EN’AM MUHTELIFUN ‘ELWANUHU KEDHALIKE ‘INNEMA JEHSHA ELLAHE MIN ‘IBADIHIL-’ULEMA’U ‘INNALL-LLAHE ‘AZIZUN GAFURUN
  35,29,‘INNEL-LEDHINE JETLUNE KITABEL-LAHI WE ‘EKAMU ES-SELÆTE WE ‘ENFEKU MIMMA REZEKNAHUM SIRRÆN WE ‘ALANIJETEN JERXHUNE TIXHARETEN LEN TEBURE
  35,30,LIJUWEFFIJEHUM ‘UXHUREHUM WE JEZIDEHUM MIN FEDLIHI ‘INNEHU GAFURUN SHEKURUN
  35,31,WEL-LEDHI ‘EWHEJNA ‘ILEJKE MINEL-KITABI HUWEL-HEKKU MUSEDDIKÆN LIMA BEJNE JEDEJHI ‘INNALL-LLAHE BI’IBADIHI LEHABIRUN BESIRUN
  35,32,THUMME ‘EWRETHNAL-KITABEL-LEDHINE ESTEFEJNA MIN ‘IBADINA FEMINHUM DHALIMUN LINEFSIHI WE MINHUM MUKTESIDUN WE MINHUM SABIKUN BIL-HAJRATI BI’IDHNI ELLAHI DHALIKE HUWEL-FEDLUL-KEBIRU
  35,33,XHENNATU ‘ADNIN JEDHULUNEHA JUHELLEWNE FIHA MIN ‘ESAWIRE MIN DHEHEBIN WE LU’ULU’UÆN WE LIBASUHUM FIHA HERIRUN
  35,34,WE KALUL-HEMDU LILLAHIL-LEDHI ‘EDH/HEBE ‘ANNAL-HEZENE ‘INNE REBBENA LEGAFURUN SHEKURUN
  35,35,EL-LEDHI ‘EHELLENA DAREL-MUKAMETI MIN FEDLIHI LA JEMESSUNA FIHA NESEBUN WE LA JEMESSUNA FIHA LUGUBUN
  35,36,WEL-LEDHINE KEFERU LEHUM NARU XHEHENNEME LA JUKDA ‘ALEJHIM FEJEMUTU WE LA JUHAFFEFU ‘ANHUM MIN ‘ADHABIHA KEDHALIKE NEXHZI KULLE KEFURIN
  35,37,WE HUM JESTERIHUNE FIHA REBBENA ‘EHRIXHNA NA’MEL SALIHÆN GAJREL-LEDHI KUNNA NA’MELU ‘EWELEM NU’AMMIRKUM MA JETEDHEKKERU FIHI MEN TEDHEKKERE WE XHA’EKUMU EN-NEDHIRU FEDHUKU FEMA LILDHDHALIMINE MIN NESIR
  35,38,‘INNALL-LLAHE ‘ALIMU GAJBI ES-SEMAWATI WEL-’ERDI ‘INNEHU ‘ALIMUN BIDHATI ES-SUDURI
  35,39,HUWEL-LEDHI XHE’ALEKUM HALA’IFE FIL-’ERDI FEMEN KEFERE FE’ALEJHI KUFRUHU WE LA JEZIDUL-KAFIRINE KUFRUHUM ‘INDE RABBIHIM ‘ILLA MEKTÆN WE LA JEZIDUL-KAFIRINE KUFRUHUM ‘ILLA HASARÆN
  35,40,KUL ‘ERE’EJTUM SHUREKA’EKUMUL-LEDHINE TED’UNE MIN DUNI ELLAHI ‘ERUNI MADHA HALEKU MINEL-’ERDI ‘EM LEHUM SHIRKUN FI ES-SEMAWATI ‘EM ‘ATEJNAHUM KITABÆN FEHUM ‘ALA BEJJINETIN MINHU BEL ‘IN JA’IDU EDH-DHALIMUNE BA’DUHUM BA’DÆN ‘ILLA GURURÆN
  35,41,‘INNALL-LLAHE JUMSIKU ES-SEMAWATI WEL-’ERDE ‘EN TEZULA WE LE’IN ZALETA ‘IN ‘EMSEKEHUMA MIN ‘EHEDIN MIN BA’DIHI ‘INNEHU KANE HELIMÆN GAFURÆN
  35,42,WE ‘EKSEMU BILLAHI XHEHDE ‘EJMANIHIM LE’IN XHA’EHUM NEDHIRUN LEJEKUNUNNE ‘EHDA MIN ‘IHDAL-’UMEMI FELEMMA XHA’EHUM NEDHIRUN MA ZADEHUM ‘ILLA NUFURÆN
  35,43,ESTIKBARÆN FIL-’ERDI WE MEKRE ES-SEJJI’I WE LA JEHIKUL-MEKRU ES-SEJJI’U ‘ILLA BI’EHLIHI FEHEL JENDHURUNE ‘ILLA SUNNETEL-’EWWELINE FELEN TEXHIDE LISUNNETI ELLAHI TEBDILÆN WE LEN TEXHIDE LISUNNETI ELLAHI TEHWILÆN
  35,44,‘EWELEM JESIRU FIL-’ERDI FEJENDHURU KEJFE KANE ‘AKIBETUL-LEDHINE MIN KABLIHIM WE KANU ‘ESHEDDE MINHUM KUWETEN WE MA KANEL-LAHU LIJU’XHIZEHU MIN SHEJ’IN FI ES-SEMAWATI WE LA FIL-’ERDI ‘INNEHU KANE ‘ALIMÆN KADIRÆN
  35,45,WE LEW JU’UAHIDHU ELLAHU EN-NASE BIMA KESEBU MA TEREKE ‘ALA DHEHRIHA MIN DABBETIN WE LEKIN JU’UEHHIRUHUM ‘ILA ‘EXHELIN MUSEMMEN FE’IDHA XHA’E ‘EXHELUHUM FE’INNALL-LLAHE KANE BI’IBADIHI BESIRÆN
  36,1,JA -SIN
  36,2,WEL-KUR’ANIL-HEKIMI
  36,3,‘INNEKE LEMINEL-MURSELINE
  36,4,‘ALA SIRATIN MUSTEKIMIN
  36,5,TENZILEL-’AZIZI ER-REHIMI
  36,6,LITUNDHIRE KAWMÆN MA ‘UNDHIRE ‘ABA’UUHUM FEHUM GAFILUNE
  36,7,LEKAD HEKKAL-KAWLU ‘ALA ‘EKTHERIHIM FEHUM LA JU’UMINUNE
  36,8,‘INNA XHE’ALNA FI ‘A’NAKIHIM ‘EGLALÆN FEHIJE ‘ILAL-’EDHKANI FEHUM MUKMEHUNE
  36,9,WE XHE’ALNA MIN BEJNI ‘EJDIHIM SEDDÆN WE MIN HALFIHIM SEDDÆN FE’EGSHEJNAHUM FEHUM LA JUBSIRUNE
  36,10,WE SEWA’UN ‘ALEJHIM ‘E’ENDHERTEHUM ‘EM LEM TUNDHIRHUM LA JU’UMINUNE
  36,11,‘INNEMA TUNDHIRU MENI ETTEBE’A EDH-DHIKRE WE HASHIJE ER-REHMENE BIL-GAJBI FEBESHSHIRHU BIMEGFIRETIN WE ‘EXHRIN KERIMIN
  36,12,‘INNA NEHNU NUHJIL-MEWTA WE NEKTUBU MA KADDEMU WE ‘ATHAREHUM WE KULLE SHEJ’IN ‘HSEJNAHU FI ‘IMAMIN MUBININ
  36,13,WE EDRIB LEHUM METHELÆN ‘ESHABEL-KARJETI ‘IDH XHA’EHAL-MURSELUNE
  36,14,‘IDH ‘ERSELNA ‘ILEJHIMU ETHNEJNI FEKEDHDHEBUHUMA FE’AZZEZNA BITHALITHIN FEKALU ‘INNA ‘ILEJKUM MURSELUNE
  36,15,KALU MA ‘ENTUM ‘ILLA BESHERUN MITHLUNA WE MA ‘ENZELE ER-REHMANU MIN SHEJ’IN ‘IN ‘ENTUM ‘ILLA TEKDHIBUNE
  36,16,KALU REBBUNA JA’LEMU ‘INNA ‘ILEJKUM LEMURSELUNE
  36,17,WE MA ‘ALEJNA ‘ILLAL-BELAGUL-MUBINU
  36,18,KALU ‘INNA TETEJJERNA BIKUM LE’IN LEM TENTEHU LENERXHUMENNEKUM WE LEJEMESSENNEKUM MINNA ‘ADHABUN ‘ELIMUN
  36,19,KALU TA’IRUKUM ME’AKUM ‘E’IN DHUKKIRTUM BEL ‘ENTUM KAWMUN MUSRIFUNE
  36,20,WE XHA’E MIN ‘EKSAL-MEDINETI REXHULUN JES’A KALE JA KAWMI ETTEBI’UL-MURSELINE
  36,21,ETTEBI’U MEN LA JES’ELUKUM ‘EXHRÆN WE HUM MUHTEDUNE
  36,22,WE MA LIJE LA ‘A’BUDUL-LEDHI FETERENI WE ‘ILEJHI TURXHA’UNE
  36,23,‘E’ETTEHIDHU MIN DUNIHI ‘ALIHETEN ‘IN JURIDNI ER-REHMANU BIDURRIN LA TUGNI ‘ANNI SHEFA’ATUHUM SHEJ’ÆN WE LA JUNKIDHUNI
  36,24,‘INNI ‘IDHÆN LEFI DELALIN MUBININ
  36,25,‘INNI ‘AMENTU BIREBBIKUM FASMA’UNI
  36,26,KILE EDHULIL-XHENNETE KALE JA LEJTE KAWMI JA’LEMUNE
  36,27,BIMA GAFERE LI RABBI WE XHE’ALENI MINEL-MUKREMINE
  36,28,WE MA ‘ENZELNA ‘ALA KAWMIHI MIN BA’DIHI MIN XHUNDIN MINE ES-SEMA’I WE MA KUNNA MUNZILINE
  36,29,‘IN KANET ‘ILLA SEJHETEN WAHIDETEN FE’IDHA HUM HAMIDUNE
  36,30,JA HESRETEN ‘ALEL-’IBADI MA JE’TIHIM MIN RESULIN ‘ILLA KANU BIHI JESTEHZI’UN
  36,31,‘ELEM JEREW KEM ‘EHLEKNA KABLEHUM MINEL-KURUNI ‘ENNEHUM ‘ILEJHIM LA JERXHI’UNE
  36,32,WE ‘IN KULLUN LEMMA XHEMI’UN LEDEJNA MUHDERUNE
  36,33,WE ‘AJETUN LEHUMUL-’ERDUL-MEJTETU ‘EHJEJNAHA WE ‘EHREXHNA MINHA HEBBÆN FEMINHU JE’KULUNE
  36,34,WE XHE’ALNA FIHA XHENNATIN MIN NEHILIN WE ‘A’NABIN WE FEXHXHERNA FIHA MINEL-’UJUNI
  36,35,LIJE’KULU MIN THEMERIHI WE MA ‘AMILET/HU ‘EJDIHIM ‘EFELA JESHKURUNE
  36,36,SUBHANEL-LEDHI HALEKAL-’EZWAXHE KULLEHA MIMMA TUNBITUL-’ERDU WE MIN ‘ENFUSIHIM WE MIMMA LA JA’LEMUNE
  36,37,WE ‘AJETUN LEHUMUL-LEJLU NESLEHU MINHU EN-NEHARE FE’IDHA HUM MUDHLIMUNE
  36,38,WE ESH-SHEMSU TEXHRI LIMUSTEKARRIN LEHA DHALIKE TEKDIRUL-’AZIZIL-’ALIMI
  36,39,WEL-KAMERE KADDERNAHU MENAZILE HETTA ‘ADE KAL’URXHUNIL-KADIMI
  36,40,LA ESH-SHEMSU JENBEGI LEHA ‘EN TUDRIKEL-KAMERE WE LAL-LEJLU SABIKU EN-NEHARI WE KULLUN FI FELEKIN JESBEHUNE
  36,41,WE ‘AJETUN LEHUM ‘ENNA HEMELNA DHURRIJETEHUM FIL-FULKIL-MESHHUNI
  36,42,WE HALEKNA LEHUM MIN MITHLIHI MA JERKEBUNE
  36,43,WE ‘IN NESHE’ NUGRIKHUM FELA SERIHA LEHUM WE LA HUM JUNKADHUNE
  36,44,‘ILLA REHMETEN MINNA WE META’ÆN ‘ILA HININ
  36,45,WE ‘IDHA KILE LEHUMU ETTEKU MA BEJNE ‘EJDIKUM WE MA HALFEKUM LE’ALLEKUM TURHEMUNE
  36,46,WE MA TE’TIHIM MIN ‘AJETIN MIN ‘AJATI RABBIHIM ‘ILLA KANU ‘ANHA MU’RIDINE
  36,47,WE ‘IDHA KILE LEHUM ‘ENFIKU MIMMA REZEKAKUMU ELLAHU KALEL-LEDHINE KEFERU LILLEDHINE ‘AMENU ‘ENUT’IMU MEN LEW JESHA’U ELLAHU ‘ET’AMEHU ‘IN ‘ENTUM ‘ILLA FI DELALIN MUBININ
  36,48,WE JEKULUNE META HADHAL-WA’DU ‘IN KUNTUM SADIKINE
  36,49,MA JENDHURUNE ‘ILLA SEJHETEN WAHIDETEN TE’HUDHUHUM WE HUM JEHISSIMUNE
  36,50,FELA JESTETI’UNE TEWSIJETEN WE LA ‘ILA ‘EHLIHIM JERXHI’UNE
  36,51,WE NUFIHA FI ES-SURI FE’IDHA HUM MINEL-’EXHDATHI ‘ILA RABBIHIM JENSILUNE
  36,52,KALU JA WEJLENA MEN BE’ATHENA MIN MERKADINA HADHA MA WE’ADE ER-REHMANU WE SEDEKAL-MURSELUNE
  36,53,‘IN KANET ‘ILLA SEJHETEN WAHIDETEN FE’IDHA HUM XHEMI’UN LEDEJNA MUHDERUNE
  36,54,FALJEWME LA TUDHLEMU NEFSUN SHEJ’ÆN WE LA TUXHZEWNE ‘ILLA MA KUNTUM TA’MELUNE
  36,55,‘INNE ‘ESHABEL-XHENNETIL-JEWME FI SHUGULIN FAKIHUNE
  36,56,HUM WE ‘EZWAXHUHUM FI DHILALIN ‘ALEL-’ERA’IKI MUTTEKI’UNE
  36,57,LEHUM FIHA FAKIHETUN WE LEHUM MA JEDDA’UNE
  36,58,SELAMUN KAWLÆN MIN RABBIN REHIMIN
  36,59,WE EMTAZUL-JEWME ‘EJJUHAL-MUXHRIMUNE
  36,60,‘ELEM ‘A’HED ‘ILEJKUM JA BENI ‘ADEME ‘EN LA TA’BUDU ESH-SHEJTANE ‘INNEHU LEKUM ‘ADUWUN MUBINUN
  36,61,WE ‘ENI A’BUDUNI HADHA SIRATUN MUSTEKIMUN
  36,62,WE LEKAD ‘EDELLE MINKUM XHIBILLÆN KETHIRÆN ‘EFELEM TEKUNU TA’KILUNE
  36,63,HEDHIHI XHEHENNEMU ELLETI KUNTUM TU’ADUNE
  36,64,ESLEWHAL-JEWME BIMA KUNTUM TEKFURUNE
  36,65,EL-JEWME NEHTIMU ‘ALA ‘EFWAHIHIM WE TUKELLIMUNA ‘EJDIHIM WE TESH/HEDU ‘ERXHULUHUM BIMA KANU JEKSIBUNE
  36,66,WE LEW NESHA’U LETEMESNA ‘ALA ‘A’JUNIHIM FASTEBEKU ES-SIRATE FE’ENNA JUBSIRUNE
  36,67,WE LEW NESHA’U LEMESEHNAHUM ‘ALA MEKANETIHIM FEMA ESTETA’U MUDIJÆN WE LA JERXHI’UNE
  36,68,WE MEN NU’AMMIRHU NUNEKKIS/HU FIL-HALKI ‘EFELA JA’KILUNE
  36,69,WE MA ‘ALLEMNAHU ESH-SHI’RE WE MA JENBEGI LEHU ‘IN HUWE ‘ILLA DHIKRUN WE KUR’ANUN MUBINUN
  36,70,LIJUNDHIRE MEN KANE HEJJÆN WE JEHIKKAL-KAWLU ‘ALEL-KAFIRINE
  36,71,‘EWELEM JEREW ‘ENNA HALEKNA LEHUM MIMMA ‘AMILET ‘EJDINA ‘EN’AMÆN FEHUM LEHA MALIKUNE
  36,72,WE DHELLELNAHA LEHUM FEMINHA REKUBUHUM WE MINHA JE’KULUNE
  36,73,WE LEHUM FIHA MENAFI’U WE MESHARIBU ‘EFELA JESHKURUNE
  36,74,WE ETTEHADHU MIN DUNI ELLAHI ‘ALIHETEN LE’ALLEHUM JUNSERUNE
  36,75,LA JESTETI’UNE NESREHUM WE HUM LEHUM XHUNDUN MUHDERUNE
  36,76,FELA JEHZUNKE KAWLUHUM ‘INNA NA’LEMU MA JUSIRRUNE WE MA JU’LINUNE
  36,77,‘EWELEM JEREL-’INSANU ‘ENNA HALEKNAHU MIN NUTFETIN FE’IDHA HUWE HASIMUN MUBINUN
  36,78,WE DEREBE LENA METHELÆN WE NESIJE HALKAHU KALE MEN JUHJIL-’IDHAME WE HIJE REMIMUN
  36,79,KUL JUHJIHAL-LEDHI ‘ENSHE’EHA ‘EWWELE MERRETIN WE HUWE BIKULLI HALKIN ‘ALIMUN
  36,80,EL-LEDHI XHE’ALE LEKUM MINE ESH-SHEXHERIL-’EHDERI NARÆN FE’IDHA ‘ENTUM MINHU TUKIDUNE
  36,81,‘EWELEJSEL-LEDHI HALEKA ES-SEMAWATI WEL-’ERDE BIKADIRIN ‘ALA ‘EN JEHLUKA MITHLEHUM BELA WE HUWEL-HALLAKUL-’ALIMU
  36,82,‘INNEMA ‘EMRUHU ‘IDHA ‘ERADE SHEJ’ÆN ‘EN JEKULE LEHU KUN FEJEKUNU
  36,83,FESUBHANEL-LEDHI BIJEDIHI MELEKUTU KULLI SHEJ’IN WE ‘ILEJHI TURXHA’UNE