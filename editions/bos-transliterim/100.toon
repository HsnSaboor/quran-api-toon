quran[11]{c,v,t}:
  100,1,WEL-’ADIJATI DEBHÆN
  100,2,FALMURIJATI KADHÆN
  100,3,FALMUGIRATI SUBHÆN
  100,4,FE’ETHERNE BIHI NEK’ÆN
  100,5,FEWESETNE BIHI XHEM’ÆN
  100,6,‘INNEL-’INSANE LIREBBIHI LEKENUDUN
  100,7,WE ‘INNEHU ‘ALA DHALIKE LESHEHIDUN
  100,8,WE ‘INNEHU LIHUBBIL-HAJRI LESHEDIDUN
  100,9,‘EFELA JA’LEMU ‘IDHA BU’THIRE MA FIL-KUBURI
  100,10,WE HUSSILE MA FI ES-SUDURI
  100,11,‘INNE REBBEHUM BIHIM JEWME’IDHIN LEHABIRUN