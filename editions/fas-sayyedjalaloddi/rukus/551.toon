quran[6]{c,v,t}:
  109,1,"بگو: اى كافران،"
  109,2,نمى‌پرستم آنچه را كه شما مى‌پرستيد
  109,3,و نه شما پرستنده‌ايد آنچه را كه من مى‌پرستم
  109,4,و نه من پرستنده‌ام آنچه را كه شما پرستيده‌ايد
  109,5,و نه شما پرستنده‌ايد آنچه را كه من مى‌پرستم
  109,6,شما راست دين شما و مراست دين من- يعنى نه من در عبادت بتها و خدايان‌ساختگى با شما هماهنگ خواهم شد و نه شما توفيق پرستش خداى يكتاى سزاوار پرستش را خواهيد داشت