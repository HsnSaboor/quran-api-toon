quran[10]{c,v,t}:
  75,31,"O, Peygamberi doğrulamamış, namaz kılmamış, ama yalanlayıp yüz çevirmiş, sonra da salına salına kendinden yana olanlara gitmişti"
  75,32,"O, Peygamberi doğrulamamış, namaz kılmamış, ama yalanlayıp yüz çevirmiş, sonra da salına salına kendinden yana olanlara gitmişti"
  75,33,"O, Peygamberi doğrulamamış, namaz kılmamış, ama yalanlayıp yüz çevirmiş, sonra da salına salına kendinden yana olanlara gitmişti"
  75,34,"Sana yazıklar olsun, yazıklar"
  75,35,"Daha ne olsun, sana yazıklar olsun, yazıklar"
  75,36,İnsanoğlu kendisinin başıboş bırakılacağını mı sanır
  75,37,"O, katılan bir meni damlası değil miydi"
  75,38,"Sonra kan pıhtısı olmuş, sonra Allah onu yaratıp şekil vermişti"
  75,39,"Ondan, erkek, dişi iki cins yaratmıştı"
  75,40,Bunları yapan Allah'ın ölüleri diriltmeye gücü yetmez mi? Elbette yeter