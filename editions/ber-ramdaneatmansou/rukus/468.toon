quran[33]{c,v,t}:
  55,46,"I win iugaden ibeddi zdat Mass is, sin leonanat"
  55,47,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,48,"S tzegzew, d imselîen"
  55,49,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,50,Degs sin i$bula pfeggiven
  55,51,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,52,"Degs yal izwayen, d tiyugiwin"
  55,53,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,54,èélen af imîeôêen ippuêewcen; izwayen n sin leonanat wâan asen
  55,55,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,56,"Dinna, sut usekkud ipsetêin, ur tent innul yiwen, uqbel nnsen, d loenn ne$ d amdan"
  55,57,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,58,Amzun nitenti d lyaqut akked lmeôoan
  55,59,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,60,"Nni$ arraz n wayen ilhan, d ayen ilhan"
  55,61,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,62,Sin leonanat nniven
  55,63,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,64,S tzegzewt isemmxen
  55,65,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,66,Degsen snat n tliwa gguffant
  55,67,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,68,"Degsen izwayen, tizdayin, ôemman"
  55,69,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,70,Degsen tiferni akked ûûam
  55,71,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,72,Tiêuôiyin ized$en di texxamin
  55,73,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,74,"Ur tent innul yiwen, uqbel nnsen, d loenn ne$ d amdan"
  55,75,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,76,Ad élen af imîeôêen izegzawen akked d tôakniwin ilhan
  55,77,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,78,"Iôqa ism n Mass ik, Bab n ccan akked cciâa"