quran[19]{c,v,t}:
  87,1,"Sbuccaâ ism n Mass ik, Aâlayan"
  87,2,"Ixelqen, Issemsaway"
  87,3,"Iwezznen, Inhan"
  87,4,I d Issuff$en takessawt
  87,5,"sinna, Ippara p d asa$uô aberkan"
  87,6,"A k Ness$eô, ur teppu"
  87,7,"siwa ayen Irad Öebbi. Ih, Neppa, Issen ayen ibanen, akked wayen iffren"
  87,8,A k Nawi ar liser
  87,9,Smmekti mi infaâ usmekti
  87,10,A d ismmekti win iugaden
  87,11,Ageswaê ijuneb it
  87,12,Di tmes tabarart mavi ara iô
  87,13,"Degs, ur ipmeppat, ur ippidir"
  87,14,Amarezg n win zeddigen
  87,15,"I ismektayen ism n Mass is, d$a ipéalla"
  87,16,"Maca, tesmenyafem tameddurt n ddunit"
  87,17,"Tif ip laxeôt, a pdum kteô"
  87,18,"Ayagi, illa di tewôeqtin timezwura"
  87,19,Tiwôeqtin n Ibôahim akked Musa