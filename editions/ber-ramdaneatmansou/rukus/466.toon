quran[25]{c,v,t}:
  55,1,Aênin
  55,2,Isseêfev Leqwôan
  55,3,Ixleq amdan
  55,4,Isselmed as ôôkuz
  55,5,"Iîij akked waggur, s leêsab"
  55,6,"Itran akked ttjuô, knan"
  55,7,"Igenni, Issuli t; Issers ed lmizan"
  55,8,Ur xedâat di lmizan
  55,9,"Weznet s tidep, ur ssexsaôet lmizan"
  55,10,Issewsaâ tamurt i imexlaq
  55,11,"Degs izwayen, tizdayin sut tkummiwin"
  55,12,"iâqqayen s usa$uô, iferrawen utebtil"
  55,13,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,14,"Ixleq amdan si talaxt, am ujeqduô"
  55,15,Ixleq loenn seg ujajiê n tmessi
  55,16,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,17,"Mass n sin igmav, Mass n sin ituram"
  55,18,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,19,Iooa sin ilellen ad mqaôaben
  55,20,"Garasen agadir, ur zegren"
  55,21,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,22,"Teff$ent ed, segsen, tyuqat akked lmeôoan"
  55,23,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,24,"IneS lembwabeô pwabnan di yill, am idurar"
  55,25,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"