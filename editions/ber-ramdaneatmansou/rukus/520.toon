quran[26]{c,v,t}:
  79,1,S tid iqelâen $evsent
  79,2,S tid iteddun éewôent
  79,3,S tid ippâumun s sshala
  79,4,S tid ipêizwaren d amêizwer
  79,5,S tid idebbiôen lameô
  79,6,Ass ideg ara d i$eô ûûut
  79,7,a t id ivfeô uvfiô
  79,8,"ulawen, ad rgagin, assen"
  79,9,Ad brunt wallen nnsen
  79,10,"Ad inin: \"day, s tidep, a d nu$al akken nella"
  79,11,Xas nekwni d i$san irkan
  79,12,"Ad inin: \"ayagi, ihi, d tu$alin n lexsaôa"
  79,13,"Neppa, d yiwet n ti$ôi kan"
  79,14,Atnan u$alen ar tmurt
  79,15,Ma tusa k id tedyant n Musa
  79,16,"Mi s d Issawel Mass is di Ïuwa, ta$zut iôqan"
  79,17,"ôuê ar Feôâun, atan ijuô"
  79,18,"Ini: ma tzemrev a ppizdigev"
  79,19,"A k nhu$ ar Mass ik, d$a a ppagwadev"
  79,20,Issenâat as assekni abarar
  79,21,"D$a, iskaddeb, iâuûa"
  79,22,"Sinna, ibren, icqa"
  79,23,"Issemlal ed, iberreê"
  79,24,"Inna: \"d nek ay d mass nnwen aâlayan"
  79,25,"Irra t Öebbi d amedya uâaqeb, di tmezwarut u di tneggarut"
  79,26,"Ih, tagi degs nnqida i win iugaden"