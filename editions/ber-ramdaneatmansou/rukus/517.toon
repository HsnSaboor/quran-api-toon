quran[10]{c,v,t}:
  77,41,"S tidep, di tili akked tliwa, ara ilin wid ipêezziben"
  77,42,"Lfakia, d ayen ccihwan"
  77,43,"Eççet tesswem, di lehna, ilmend n wayen txeddmem"
  77,44,"Ih, akka ay Nepkafi izedganen"
  77,45,"Assen, a nnger inekkaôen"
  77,46,"Eççet, zzhut cwiî kan, kunwi, war ccekk, d ibe$wviyen"
  77,47,"Assen, a nnger inekkaôen"
  77,48,"Ma nnan asen: \"îîinzet\"! Ur îîinizen"
  77,49,"Assen, a nnger inekkaôen"
  77,50,"Ihi, anwa awal, deffir wagi, ara amnen"