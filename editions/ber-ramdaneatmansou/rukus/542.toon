quran[11]{c,v,t}:
  100,1,S tid id ippazalen neffôent
  100,2,"Ifeîîiwjen, ssafagent"
  100,3,Di tûebêit ara d dehment
  100,4,"A$ebbaô, sskarent"
  100,5,"Ar tlemmast n ugraw, kecment"
  100,6,"Ih, amdan, i Mass is, d lkaraâ"
  100,7,"U neppa, ard anagi n waya"
  100,8,"Neppa, s tidep, aîas i iêemmel sâaya"
  100,9,Day ur iéôi ara ar mara d iffe$ i illan deg iéekwan
  100,10,"i illan deg idmaren, a d ivheô meôôa"
  100,11,"S tidep, assen, Mass nnsen, ippuxebbeô fellasen"