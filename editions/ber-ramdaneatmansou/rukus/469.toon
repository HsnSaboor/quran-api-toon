quran[38]{c,v,t}:
  56,1,"Mara d tas, tin ara d iasen"
  56,2,"ef tisin is, ur illi ucehrir"
  56,3,"Tessrusu, treffed"
  56,4,"Ma tenhez tmurt, lhezz iqesêen"
  56,5,idurar ftutsen
  56,6,u$alen d a$ebbaô ippuwezzâen
  56,7,a d tevêum krav leûnaf
  56,8,"at uyeffus. At uyeffus, anwi ten"
  56,9,"At uzelmav. At uzelmav, anwi ten"
  56,10,"Akked imezwura, imezwura"
  56,11,Widak d iqôiben
  56,12,di leonanat isaâdiyen
  56,13,"Seg imenza, deg waîas idsen"
  56,14,"Seg ineggura, drus nnsen"
  56,15,£ef imîeôêen iévan
  56,16,"éélen fellasen, mqabalen"
  56,17,Tezzin asen ilmeéiyen iwekkôen
  56,18,"s tbuqalin, iqbucen, akked lkas n tissit iûfan"
  56,19,"Yis, ur ppavnen, ur sekkôen"
  56,20,"Izwayen, seg wid smenyafen"
  56,21,"Aksum n yifôax, seg win cedhan"
  56,22,Tiêuôiyin lâin
  56,23,am tyaqutin iffren
  56,24,D arraz n wayen xeddmen
  56,25,"Ur din sellen awal n leqbaêa, ne$ n tuccva"
  56,26,"siwa awal n tifrat, tifrat"
  56,27,"At uyeffus, at uyeffus, d acu ten"
  56,28,"Ar tzegwart, war isennanen"
  56,29,Tulmatin iurwen
  56,30,Tili iwsâen
  56,31,Aman ippazalen
  56,32,Aîas n yizwayen
  56,33,"ur zegzawit, ur ppugedlen"
  56,34,Imîeôêen aâlayen
  56,35,D Nekwni itent Ixelqen
  56,36,Nerra tent d tiêuôiyin
  56,37,"pêemmilent, d tizyiwin"
  56,38,i at uyeffus