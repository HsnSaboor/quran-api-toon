quran[78]{c,v,t}:
  55,1,Aênin
  55,2,Isseêfev Leqwôan
  55,3,Ixleq amdan
  55,4,Isselmed as ôôkuz
  55,5,"Iîij akked waggur, s leêsab"
  55,6,"Itran akked ttjuô, knan"
  55,7,"Igenni, Issuli t; Issers ed lmizan"
  55,8,Ur xedâat di lmizan
  55,9,"Weznet s tidep, ur ssexsaôet lmizan"
  55,10,Issewsaâ tamurt i imexlaq
  55,11,"Degs izwayen, tizdayin sut tkummiwin"
  55,12,"iâqqayen s usa$uô, iferrawen utebtil"
  55,13,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,14,"Ixleq amdan si talaxt, am ujeqduô"
  55,15,Ixleq loenn seg ujajiê n tmessi
  55,16,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,17,"Mass n sin igmav, Mass n sin ituram"
  55,18,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,19,Iooa sin ilellen ad mqaôaben
  55,20,"Garasen agadir, ur zegren"
  55,21,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,22,"Teff$ent ed, segsen, tyuqat akked lmeôoan"
  55,23,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,24,"IneS lembwabeô pwabnan di yill, am idurar"
  55,25,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,26,Ad ifut degs kra illan
  55,27,"A d igwri udem n Mass ik, Bab n ccan akked cciâa"
  55,28,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,29,"Teppren T, yal ass, kra illan di tmurt akked igenwan, Neppa la Ixelleq"
  55,30,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,31,"A d Nelhi yidwen, a sin iéayanen"
  55,32,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,33,"A yagraw n leonun akked imdanen, ma tzemrem a pzegrem akin i tmurt akked igenwan, zegret! Ur tepzeggirem siwa ma s udabu"
  55,34,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,35,A d teppewwtem s ijujaê n tmes akked nnêas. Ur tepsellikem iman nnwen
  55,36,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,37,"Ma ifelleq igenni, iu$al d azeggwa$ am u$eggwad"
  55,38,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,39,"assen, amdan ne$ loenn, ur fellas asteqsi $ef ubekkav is"
  55,40,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,41,"Ibe$wviyen, a d banen ar ccwami nnsen. Ad pwaîîfen seg icebbuben akked ivaôen"
  55,42,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,43,D tagi ay d Loahennama i skaddben ibe$wviyen
  55,44,Ad ddewwiôen garas akked wayen ippayzagen
  55,45,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,46,"I win iugaden ibeddi zdat Mass is, sin leonanat"
  55,47,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,48,"S tzegzew, d imselîen"
  55,49,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,50,Degs sin i$bula pfeggiven
  55,51,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,52,"Degs yal izwayen, d tiyugiwin"
  55,53,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,54,èélen af imîeôêen ippuêewcen; izwayen n sin leonanat wâan asen
  55,55,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,56,"Dinna, sut usekkud ipsetêin, ur tent innul yiwen, uqbel nnsen, d loenn ne$ d amdan"
  55,57,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,58,Amzun nitenti d lyaqut akked lmeôoan
  55,59,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,60,"Nni$ arraz n wayen ilhan, d ayen ilhan"
  55,61,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,62,Sin leonanat nniven
  55,63,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,64,S tzegzewt isemmxen
  55,65,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,66,Degsen snat n tliwa gguffant
  55,67,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,68,"Degsen izwayen, tizdayin, ôemman"
  55,69,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,70,Degsen tiferni akked ûûam
  55,71,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,72,Tiêuôiyin ized$en di texxamin
  55,73,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,74,"Ur tent innul yiwen, uqbel nnsen, d loenn ne$ d amdan"
  55,75,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,76,Ad élen af imîeôêen izegzawen akked d tôakniwin ilhan
  55,77,"Anwa seg i$iten n Mass nnwen ara teskiddben, i sin"
  55,78,"Iôqa ism n Mass ik, Bab n ccan akked cciâa"