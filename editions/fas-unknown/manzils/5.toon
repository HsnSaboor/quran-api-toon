quran[856]{c,v,t}:
  26,1,طسم (طا. سین. میم)
  26,2,این آیات کتاب روشن است
  26,3,گویی می خواهی از (شدت غم واندوه) این که آنها ایمان نمی آورند؛ خود را هلاک کنی
  26,4,اگر بخواهیم از آسمان بر آنها نشانه ای نازل می کنیم که گردنهایشان در برابر آن تسلیم (و خاضع) گردد
  26,5,و هیچ پند تازه ای از سوی (خداوند) رحمان برای آنها نمی آید؛ مگر این که از آن روی گردان هستند
  26,6,به راستی آنها تکذیب کردند، پس به زودی اخبار آنچه را که به آن استهزاء (و تمسخر) می کردند؛ به آنها خواهد رسید
  26,7,آیا به زمین ننگریسته اند که چه قدر از هر گونه گیاهان (نیکو و) پر ارزش در آن رویانده ایم ؟
  26,8,بی گمان در این نشانه ی (بزرگی) است، و بیشتر آنها مؤمن نیستند
  26,9,و به راستی پروردگارتو پیروزمند مهربان است
  26,10,و (به یاد بیاور) هنگامی را که پروردگارت موسی را ندا داد که به سوی قوم ستمکار برو،
  26,11,قوم فرعون، آیا آنها نمی ترسند ؟
  26,12,"(موسی) گفت :« پروردگارا ! من می ترسم که مرا تکذیب کنند"
  26,13,و سینه ام تنگ گردد و زبانم باز نشود، پس (برادرم) هارون را (نیز) رسالت ده (تا مرا یاری کند)
  26,14,و آنها بر (گردن) من (ادعای) گناهی دارند، پس می ترسم که مرا بکشند»
  26,15,"(خداوند) فرمود:«چنین نیست، پس شما هر دو با آیات ما بروید، یقیناً ما با شما شنوندگان هستیم"
  26,16,"پس (به نزد) فرعون بروید، و بگویید:«ما فرستاده ی پروردگار جهانیان هستیم،"
  26,17,که بنی اسرائیل را با ما بفرست»
  26,18,"(فرعون) گفت : «آیا ما تو را در کوکی نزد خود پرورش ندادیم، و سالهایی از عمرت را در میان ما نگذراندی؟"
  26,19,و (بالآخره) آن کارت را (که نبایست انجام می دادی) انجام دادی، و تو از ناسپاسانی»
  26,20,"(موسی) گفت : «(من) آن (کار) را آنگاه انجام دادم که من از بی خبران بودم"
  26,21,پس چون از شما ترسیدم از شما فرار کردم، آنگاه پروردگارم به من دانش (و نبوت) بخشید و مرا از پیامبران قرار داد
  26,22,و آیا این نعمتی است که تو بر من منت می گذاری که بنی اسرائیل را برده ی خود ساخته ای؟!»
  26,23,"فرعون گفت :«پروردگار جهانیان چیست؟!»"
  26,24,"(موسی) گفت :« پروردگار آسمانها و زمین و آنچه میان آن دو است، اگر اهل یقین هستید»"
  26,25,"(فرعون) به آنهای که در اطرافش بودند؛ گفت :«آیا نمی شنوید ؟»"
  26,26,"(موسی) گفت :«( او) پروردگار شما و پروردگار نیاکان پیشین شماست"
  26,27,"(فرعون) گفت :« بی تردید پیامبرتان که به سوی شما فرستاده شده دیوانه است»"
  26,28,"(موسی) گفت :«(او) پروردگار مشرق و مغرب و آنچه میان آن دو است، اگر بیندیشید»"
  26,29,"(فرعون) گفت :«اگر معبودی جز من برگزینی، البته تو را از زندانیان قرار خواهم داد»"
  26,30,"(موسی) گفت :« حتی اگر معجزه ای روشنی برای تو آورده باشم ؟!»"
  26,31,"(فرعون) گفت :« پس اگر از راستگویانی، آن را بیاور»"
  26,32,پس (موسی) عصای خود را افکند، که ناگهان آن اژدهایی آشکار شد
  26,33,و دست خود را (در گریبان فرو برد و) بیرون آورد که ناگهان در برابر بینندگان سفید (و روشن) بود
  26,34,"(فرعون) به اشرافی که اطراف او بودند؛ گفت :« بی گمان این (مرد) جادوگر دانایی است"
  26,35,(او) می خواهد با سحرش شما را از سرزمینتان بیرون کند، پس شما چه نظر می دهید ؟!»
  26,36,"گفتند :«(کار) او و برادرش را به تأخیر انداز، و جمع آوری کنندگان را در (همه ی) شهرها بفرست»"
  26,37,تا هر جادوگر ماهر (و) دانایی را نزد تو آورند»
  26,38,پس (سرانجام) جادوگران برای وعده گاه روز معینی گرد آورده شدند
  26,39,"و به مردم گفته شد :«آیا شما (نیز) جمع می شوید،"
  26,40,تا اگر ساحران پیروز شدند، ما از آنها پیروی کنیم؟!»
  26,41,"پس هنگامی که ساحران آمدند، به فرعون گفتند : «اگر ما پیروز شویم، آیا ما پاداشی خواهیم داشت ؟!»"
  26,42,"گفت :«آری، و بی گمان آنگاه شما از مقربان خواهید بود»"
  26,43,"موسی به آنها گفت :«هر چه می خواهید بیفکنید، بیفکنید»"
  26,44,"پس آنها ریسمانها و عصاهای خود را افکندند، و گفتند:« به عزت فرعون، قطعاً ما پیروزیم»"
  26,45,پس موسی عصایش را افکند، ناگهان آنچه را به دروغ بر ساخته بودند، بلعید
  26,46,پس ساحران سجده کنان (به زمین) افتادند
  26,47,"گفتند :« ما به پروردگار جهانیان ایمان آوردیم،"
  26,48,پروردگار موسی و هارون»
  26,49,"(فرعون) گفت:«آیا پیش از آن که به شما اجازه دهم به او ایمان آوردید ؟! مسلماً او بزرگتر شماست که سحر را به شما یاد داده است، پس به زودی خواهید دانست ! دستانتان و پاهایتان را به عکس یکدیگر قطع می کنم، و همه ی شما را به دار می آویزم»"
  26,50,"گفتند :« با کی نیست، ما به سوی پروردگار مان باز می گردیم"
  26,51,ما امیدواریم که پروردگارمان خطاهای ما را ببخشد، که ما از نخستین ایمان آورندگان بودیم»
  26,52,"و به موسی وحی کردیم که : « شبانه بندگانم را (از مصر) بیرون ببر، بی گمان شما تعقیب می شوید»"
  26,53,پس فرعون (چون از ماجرا آگاه گردید) گرد آورندگان (نیرو) را به شهرها فرستاد
  26,54,"(و گفت:) اینها (= بنی اسرائیل) گروهی اندک (و ناچیز) هستند،"
  26,55,و اینها ما را به خشم آورده اند،
  26,56,و ما همگی آماده (و بیدار) هستیم»
  26,57,پس آنها را از باغها و چشمه ها بیرون کردیم
  26,58,و (نیز) از گنجها و منزلگاه نیکو (و قصرهای مجلل بیرون راندیم)
  26,59,(آری) این چنین (کردیم) و بنی اسرائیل را وارث آنها ساختیم
  26,60,پس آنها (صبحگاهان به) هنگام طلوع آفتاب به تعقیبشان پرداختند
  26,61,"پس چون دو گروه یکدیگر را دیدند، یاران موسی گفتند: « یقیناً ما (در چنگال فرعونیان) گرفتار شدیم»"
  26,62,"(موسی) گفت :« چنین نیست، بی گمان پروردگارم با من است، به زودی مرا هدایت خواهد کرد»"
  26,63,"پس به موسی وحی کردیم :«عصایت به دریا بزن» آنگاه (دریا) شکافته شد، پس هر بخشی (از آن) همچون کوه عظیمی شد"
  26,64,و دیگران (= فرعون و فرعونیان) را (نیز) به آنجا نزدیک ساختیم
  26,65,و موسی و همراهانش را همگی نجات دادیم
  26,66,سپس دیگران را غرق کردیم
  26,67,بی گمان در این (ماجرا) نشانه ای (روشن) است
  26,68,و بی تردید پرورگارتو پیروزمند مهربان است
  26,69,و خبر ابراهیم را بر آنها بخوان
  26,70,"هنگامی که به پدرو قومش گفت :«چه چیز را می پرستید ؟!»"
  26,71,"گفتند :« بتهایی را می پرستیم، و پیوسته برای (عبادت) آنها معتکف هستیم"
  26,72,"(ابراهیم) گفت : «آیا هنگامی که آنها را می خوانید (صدای) شما را می شنوند ؟"
  26,73,یا سود وزیانی به شما می رسانند؟!»
  26,74,"گفتند :«(نه) بلکه ما نیاکان خود را یافتیم که چنین می کردند»"
  26,75,"(ابراهیم) گفت :«آیا دیدید چیزهایی را که پیوسته عبادت می کردید،"
  26,76,شما و نیاکان پیشین شما
  26,77,پس همه آنها دشمن من هستند، جز پروردگار جهانیان
  26,78,(همان) کسی که مرا آفرید، پس او مرا هدایت می کند
  26,79,و کسی که او به من غذای می دهد و سیراب می نماید
  26,80,و هنگامی که بیمار شوم پس او مرا شفا می دهد
  26,81,و کسی که مرا می میراند؛ سپس زنده می کند
  26,82,و کسی که امیدوارم گناهانم را در روز جزا برایم ببخشد
  26,83,پروردگارا! به من (دانش و) حکمت ببخش، و مرا به صالحان ملحق کن
  26,84,و برای من در میان آیندگان آوازه نیک (و ذکر خیر) قرار بده
  26,85,و مرا از وارثان بهشت پر نعمت بگردان
  26,86,و پدرم را بیامرز، بی گمان او از گمراهان بود
  26,87,و در روزی که (همه ی مردم) برانگیخته می شوند، مرا رسوا (و شرمنده ) مکن
  26,88,روزی که مال و فرزندان سودی نبخشد
  26,89,مگر کسی که با قلب سلیم (خالی از شرک و کفر و نفاق) به پیشگاه خداوند بیاید»
  26,90,و (در آن روز) بهشت برای پرهیزگاران نزدیک آورده شود
  26,91,و دوزخ برای گمراهان آشکار کنند
  26,92,"و به آنها گفته می شود:« کجا هستند آنچه که به جای خدا پرستش می کردید ؟"
  26,93,آیا آنها شما را یاری می کنند، یا (خود) انتقام می گیرند ؟
  26,94,پس آنها و گمراهان (به رو) در آن افکنده می شوند
  26,95,و(نیز) همه ی لشکریان ابلیس
  26,96,آنها در آنجا در حالی که با یکدیگر مخاصمه می کنند، گویند
  26,97,« به خدا سوگند که ما در گمراهی آشکار بودیم
  26,98,چون شما را با پروردگار جهانیان برابر می دانستیم
  26,99,و کسی جز مجرمان ما را گمراه نکرد
  26,100,پس (اکنون) هیچ شفاعت کنندگانی برای ما نیست
  26,101,و نه هیچ دوست (مخلص و) مهربانی
  26,102,پس ای کاش بار دیگر (به دنیا) باز گردیم، تا از مؤمنان باشیم »
  26,103,بی گمان در این (ماجرا) نشانه ای (روشن) است، و بیشتر آنها مؤمن نبودند
  26,104,و بی تردید پروردگار تو پیروزمند مهربان است
  26,105,قوم نوح پیامبران را تکذیب کردند
  26,106,"هنگامی که برادرشان نوح به آنها گفت :« آیا (از خدا) نمی ترسید؟!»"
  26,107,مسلماً من برای شما پیامبری امین هستم
  26,108,پس از خدا بترسید، و مرا اطاعت کنید
  26,109,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی طلبم، مزد من تنها بر (عهده ی) پروردگار جهانیان است
  26,110,پس از خدا بترسید، و مرا اطاعت کنید»
  26,111,"گفتند:« آیا به تو ایمان بیاوریم در حالی که فرومایگان از تو پیروی کرده اند ؟!»"
  26,112,"(نوح) گفت :« من چه می دانم آنها چه کارها کرده اند"
  26,113,اگر می فهمید، حساب آنها تنها با پروردگار من است
  26,114,و من (هرگز) مؤمنان را طرد نخواهم کرد
  26,115,من جز بیم دهنده ای آشکار نیستم»
  26,116,"گفتند :«ای نوح ! اگر (از دعوتت) دست بر نداری، حتماً سنگسار خواهی شد»"
  26,117,"(نوح) گفت :«پروردگارا ! همانا قوم من، مرا تکذیب کردند"
  26,118,پس میان من وآنها داوری کن، و مرا و مؤمنانی را که با من هستند؛ نجات بده»
  26,119,پس او و کسانی را که همراه او بودند، در (آن) کشتی پر (و انباشته) نجات دادیم
  26,120,سپس بقیه را غرق کردیم
  26,121,بی گمان در این (ماجرا) نشانه ای (روشن) است، و بیشتر آنها مؤمن نبودند
  26,122,و بی تردید پروردگار تو پیروزمند مهربان است
  26,123,(قوم) عاد (نیز) پیامبران (خدا) را تکذیب کردند
  26,124,"هنگامی که برادرشان هود به آنها گفت :«آیا (از خدا) نمی ترسید ؟!»"
  26,125,به راستی من برای شما پیامبری امین هستم
  26,126,پس از خدا بترسید، و مرا اطاعت کنید
  26,127,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی طلبم، مزد من تنها بر (عهده ی) پرودگار جهانیان است
  26,128,آیا بر هر مکان مرتفعی نشانه ای (از روی هوا و هوس و) بیهوده می سازید ؟
  26,129,و قصرها (و قلعه ها) محکم و استوار بنا می کنید، گویی که (در دنیا) جاودانه می مانید
  26,130,و چون (کسی را) کیفر دهید، همچون جباران کیفر می دهید
  26,131,پس از خدا بترسید و مرا اطاعت کنید
  26,132,و از کسی بترسید که شما را به آنچه می دانید مدد کرده است
  26,133,شما را به چهارپایان و فرزندان مدد (و یاری) فرموده است
  26,134,و (همچنین به) باغها و چشمه ها
  26,135,همانا من از عذاب روزی بزرگ بر شما می ترسم! »
  26,136,"گفتند :« برای ما یکسان است، چه ما را پند دهی یا پند ندهی"
  26,137,این جز (همان) روش پیشینیان نیست
  26,138,و ما (هرگز) عذاب نخواهیم شد»
  26,139,پس او (= هود) را تکذیب کردند، در نتیجه ما آنها را هلاک کردیم، بی گمان در این (ماجرا) نشانه ای است، و بیشتر آنها مؤمن نبودند
  26,140,و بی تردید پروردگار تو پیروزمند مهربان است
  26,141,(قوم) ثمود پیامبران (خدا) را تکذیب کردند
  26,142,"هنگامی که برادرشان صالح به آنها گفت :«آیا (از خدا) نمی ترسید ؟"
  26,143,بی گمان من برای شما پیامبری امین هستم
  26,144,پس از خدا بترسید و مرا اطاعت کنید
  26,145,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی طلبم، مزد من تنها بر (عهده ی) پروردگار جهانیان است
  26,146,آیا (می پندارید که) شما در (نعمتهایی) اینجا ایمن رها می کنند ؟
  26,147,در (این) باغها و چشمه ها
  26,148,و (در این) زراعتها و نخلهایی که شکوفه هایش (نرم و) رسیده است ؟
  26,149,و شادمانه از کوهها خانه هایی می تراشید؟
  26,150,پس از خدا بترسید و مرا اطاعت نکنید
  26,151,و فرمان اسراف کاران را اطاعت نکنید
  26,152,(همان) کسانی که در زمین فساد می کنند و اصلاح نمی کنند»
  26,153,"گفتند :«(ای صالح) جز این نیست که تو از جادوشدگانی"
  26,154,تو جز بشری همانند ما نیستی، پس اگر از راستگویانی نشانه ای بیاور»
  26,155,"(صالح) گفت :«این ماده شتری است، که برای او یک نوبت آب خوردن، و برای شما (نیز) نوبت روز معینی است"
  26,156,و (کمترین) آزاری به آن نرسانید، که عذاب روزی بزرگ شما را فرو می گیرد»
  26,157,پس آن را پی کردند، آنگاه (از کرده ی خود) پشیمان شدند
  26,158,پس عذاب (الهی) آنها را فرو گرفت، بی گمان در این (ماجرا) نشانه ای است، و بیشتر آنها مؤمن نبودند
  26,159,و بی تردید پروردگار تو پیروزمند مهربان است
  26,160,قوم لوط (نیز) پیامبران (خدا) را تکذیب کردند
  26,161,"هنگامی که برادرشان لوط به آنها گفت :«آیا (از خدا) نمی ترسید ؟"
  26,162,بی گمان من برای شما پیامبری امین هستم
  26,163,پس از خدا بترسید، و مرا اطاعت کنید
  26,164,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی طلبم، مزد من تنها بر (عهده ی) پروردگار جهانیان است
  26,165,آیا در میان جهانیان شما به سراغ مردان می روید ؟
  26,166,و همسرانی که خدا برای شما آفریده است؛ رها می کنید، بلکه شما قومی متجاوز هستید
  26,167,"گفتند :«ای لوط، اگر دست بر نداری، یقیناً از اخراج شدگان خواهی بود»"
  26,168,"(لوط) گفت : «من دشمن سر سخت عمل شما هستم"
  26,169,پروردگارا ! من و خانواده ام را از (عاقبت) آنچه (اینها) انجام می دهند، نجات بده»
  26,170,پس او وخانواده اش را همگی نجات دادیم
  26,171,مگر پیرزنی که در میان بازماندگان بود
  26,172,سپس دیگران را نابود ساختیم
  26,173,و بر آنها بارانی (از سنگ) بارانیدیم، پس باران بیم داده شدگان چه بد بود
  26,174,بی گمان در این (ماجرا) نشانه ای است، و بیشتر آنها مؤمن نبودند
  26,175,و بی تردید پروردگار تو پیروزمند مهربان است
  26,176,اصحاب ایکه (= قوم شعیب) پیامبران (خدا) را تکذیب کردند
  26,177,"هنگامی که شعیب به آنها گفت :«آیا (از خدا) نمی ترسید ؟"
  26,178,همانا من برای شما پیامبری امین هستم
  26,179,پس از خدا بترسید، و مرا اطاعت کنید
  26,180,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی طلبم، مزد من تنها بر (عهده ی) پروردگار جهانیان است
  26,181,پیمانه را تمام بدهید، و از کاهندگان (و کم فروشان) نباشید
  26,182,و با ترازوی درست وزن کنید
  26,183,و چیزهای مردم را کم ندهید (و حق آنها را ضایع نکنید) و در زمین به فساد نکوشید
  26,184,و از کسی که شما و آفریدگان نخستین را آفرید بترسید
  26,185,"گفتند :«(ای شعیب!) جز این نیست که تو از جادو شدگانی،"
  26,186,تو جز بشری همانند ما نیستی، و تو را از دروغگویان می پنداریم
  26,187,پس اگر از راستگویانی، پاره ی از آسمان را بر (سر) ما بینداز»
  26,188,"(شعیب) گفت :«پروردگارم ! به آنچه انجام می دهید؛ داناتر است"
  26,189,پس او را تکذیب کردند، آنگاه عذاب روز سایه آنها را فرو گرفت، بی گمان آن عذاب روز بزرگی بود
  26,190,بی گمان در این (ماجرا) نشانه ای است، و بیشتر آنها مؤمن نبودند
  26,191,و بی تردید پروردگار تو پیروزمند مهربان است
  26,192,و همانا این (قرآن) نازل شده (از جانب) پروردگار جهانیان است
  26,193,روح الامین (= جبرئیل) آن را فرود آورده است
  26,194,بر قلب تو، تا از هشدار دهندگان باشی
  26,195,(آن را) به زبان عربی روشن (نازل کرد)
  26,196,و همانا (توصیف) آن در کتابهای پیشینیان (نیز آمده) است
  26,197,آیا همین نشانه برای آنها کافی نیست که علمای بنی اسرائیل از آن آگاهند؟
  26,198,و اگر آن را بر بعضی از عجمیان (= غیر عربها) نازل می کردیم
  26,199,پس او آن را برایشان می خواند، به آن ایمان نمی آورند
  26,200,(آری) این گونه آن (تکذیب) را در دلهای مجرمان در آوردیم
  26,201,به آن ایمان نمی آورند تا عذاب دردناک را (با چشم خود) ببینند
  26,202,پس ناگهان در حالی که بی خبرند به سراغ آنها می آید
  26,203,"آنگاه می گویند:«آیا مهلتی به ما داده خواهد شد؟!»"
  26,204,آیا برای عذاب ما شتاب می کنند؟
  26,205,آیا دیدی که اگر سالیانی آنها را (از این زندگی دنیا) بهره مند سازیم
  26,206,سپس آنچه که به آنها وعده داده شده است به سراغشان بیاید
  26,207,این بهره مندیشان (از دنیا) سودی برای آنها نخواهد داشت
  26,208,و هیچ قریه ای را هلاک نکردیم؛ مگراین که هشدار دهندگانی (از پیامبران) داشتند
  26,209,برای پند دادن، و ما هرگز ستمکار نبودیم
  26,210,و شیطانها (هرگز) این (قرآن) را نازل نکرده اند
  26,211,و برای آنها سزاوار نیست؛ و نمی توانند
  26,212,بی گمان آنها از شنیدن (وحی، و استراق سمع) برکنارند
  26,213,پس (ای پیامبر!) هیچ معبودی را با الله مخوان، که از عذاب شدگان خواهی بود
  26,214,و خویشاوندان نزدیکت را هشدار بده
  26,215,و بال (رحمت و فروتنی) خود را برای مؤمنانی که از تو پیروی می کنند؛ بگستر
  26,216,"پس اگر از (فرمان) تو سرپیچی کردند، بگو :«همانا من از آنچه انجام می دهید؛ بیزارم»"
  26,217,و بر خداوند پیروزمند مهربان توکل کن
  26,218,(همان) کسی که تو را به هنگامی که (برای عبادت) بر می خیزی می بیند
  26,219,و (نیز) حرکت (و نشست و بر خاست) تو را میان سجده کنندگان (را می بیند)
  26,220,همانا او شنوای داناست
  26,221,آیا به شما خبردهم که شیاطین بر چه کسی نازل می شوند؟
  26,222,بر هر دروغگوی گنهکار نازل می گردند
  26,223,(به شیاطین) گوش فرا می دهند و بیشترشان دروغگو هستند
  26,224,و شاعران (کسانی) هستند که گمراهان از آنها پیروی می کنند
  26,225,آیا ندیدی که آنها درهر وادیی سرگشته (و حیران) هستند ؟
  26,226,و بی گمان آنها چیزی می گویند که (خود به آن) عمل نمی کنند ؟
  26,227,مگر کسانی که ایمان آوردند و کارهای شایسته انجام دادند و خدا را بسیار یاد کردند، و بعد از آن که ستم دیدند، انتقام گرفتند،(و با شعر خود از اسلام و مسلمین دفاع نمودند)، و کسانی که ستم کردند؛ به زودی خواهند دانست به چه بازگشتگاهی باز می گردند
  27,1,طس (طا. سین) این آیات قرآن و کتاب مبین است
  27,2,که هدایت و بشارت برای مؤمنان است
  27,3,(همان) کسانی که نماز را بر پا می دارند، و زکات را ادا می کنند، و آنان به آخرت یقین دارند
  27,4,بی گمان کسانی که به آخرت ایمان نمی آورند،اعمال شان را برای آنها زینت داده ایم، پس آنها سر گردان می شوند
  27,5,آنها کسانی هستند که عذاب بد (و درد ناک) برای شان است،و آنها در آخرت زیانکارترینند
  27,6,و بی تردید تو (این) قرآن را از سوی (خداوند) حکیم دانا دریافت می داری
  27,7,"(به یاد بیاور) هنگامی را که موسی به خانواده ی خود گفت : «(بایستید) همانا من آتشی (از دور) دیده ام، به زودی خبری از آن برای شما می آورم یا شعله ی آتشی از آن می آورم تا گرم شوید»"
  27,8,"پس چون به آن (آتش) رسید، ندا داده شد که :«مبارک باد کسی که در آتش است و کسی که پیرامون آن است. و منزه است خداوندی که پروردگار جهانیان است"
  27,9,ای موسی! همانا من خداوند پیروزمند حکیم هستم
  27,10,و عصایت را بیفکن- پس چون آن را دید که (با سرعت) می جنبد، گویی که آن ماری است،(ترسید و) به عقب برگشت،و پشت سر خود نگاه نکرد- ای موسی ! نترس، که پیامبران در نزد من نمی ترسند
  27,11,مگر کسی که ستم کند، پس (توبه کند و) بدی را به نیکی تبدیل نماید، پس بی گمان من آمرزنده ی مهربان هستم
  27,12,و دستت در گریبانت فرو کن، که سفید (و در خشنده ی) بی عیب بیرون بیاید، (این معجزه) در زمره ی معجزات نه گانه است، به سوی فرعون و قومش (برو) که آنها قومی فاسقند»
  27,13,"پس چون آیات روشن (و کاملاً آشکار) ما به سراغ آنها آمد؛ گفتند : «این جادویی آشکار است»"
  27,14,و آن را از روی ستم و سرکشی انکار کردند، در حالی که دلهایشان به آن یقین داشت، پس بنگر عاقبت مفسدان چگونه بود
  27,15,"و به راستی به داوود و سلیمان دانش (عظیمی) دادیم، و (آنان) گفتند :« ستایش از آن خدایی است که ما را بر بسیاری از بندگان مؤمن خود برتری بخشید»"
  27,16,"و سلیمان وارث داوود شد، و گفت :«ای مردم ! زبان پرندگان به ما آموخته اند، و از هر چیز به ما عطا شده، بی تردید این فضل آشکاری است»"
  27,17,و برای سلیمان لشکریانش از جن و انس و پرندگان گرد آورده شدند، آنگاه نگاه داشته شدند (تا همه آنها به یکدیگر بپیوندند)
  27,18,"(بعد حرکت کردند) تا هنگامی که به وادی مورچگان رسیدند، مورچه ای گفت:«ای مورچگان ! به لانه های خود بروید تا سلیمان و لشکریانش شما را پایمال نکنند در حالی که نمی فهمند»"
  27,19,"پس (سلیمان) از سخن آن (مورچه) تبسمی کرد (و) خندید، گفت :« پروردگارا ! به من توفیق ده تا شکر نعمتهایی را که بر من وبر پدر و مادرم ارزانی داشته ای بجای آورم، و (توفیق عطا فرما تا) کار(های) شایسته ای که تو خشنود شوی، انجام دهم، ومرا به رحمت خود در( زمره ی) بندگان صالحت در آور »"
  27,20,"و (سلیمان) از حال پرندگان جویا شد، و گفت : «مرا چه شده است که هدهد را نمی بینم، یا اینکه او از غایبان است ؟"
  27,21,قطعاً او را به کیفر شدید کیفر خواهم داد، یا او را ذبح خواهم کرد، یا (باید) دلیلی روشن (برای غیبتش) برای من بیاورد »
  27,22,"پس درنگش چندان طول نکشید (که هدهد آمد) آنگاه گفت : « من به چیزی دست یافته ام که تو به آن دست نیافته ای، و از (سرزمین) سبا برایت خبر قطعی آورده ام"
  27,23,من زنی را یافتم که بر آنها فرمانروایی می کند ، و (به او) از هر گونه نعمتی داده شده است، و تخت عظیمی دارد
  27,24,او وقومش را دیدم که به جای خدا برای خورشید سجده می کنند، و شیطان اعمال آنها را در نظرشان آراسته پس آنها را از راه (خدا) باز داشته است، از این رو آنها هدایت نمی شوند»
  27,25,چرا برای خداوندی سجده نمی کنند که آنچه را در آسمانها و زمین پنهان است بیرون می آورد، و آنچه را پنهان می دارید و آنچه را آشکار می کنید (همه) می داند
  27,26,خداوندی که جز او معبودی نیست، پروردگار عرش عظیم است
  27,27,"(سلیمان) گفت :«اکنون خواهیم دید که آیا راست گفته ای یا از دروغگویان هستی"
  27,28,این نامه ی مرا ببر، و بر آنها بیفکن، سپس از آنها روی بگردان ، پس (در گوشه ای توقف کن) بنگر که چه جواب می دهند»
  27,29,"(ملکه ی سبا) گفت :«ای بزرگان، به راستی نامه ی پر ارزشی به سوی من افکنده شده"
  27,30,"همانا آن (نامه) از سلیمان است، و چنین است : به نام خداوند بخشنده ی مهربان"
  27,31,بر من برتری مجویید، و تسلیم شده نزد من بیایید »
  27,32,"(ملکه) گفت :« ای بزرگان ، در کار من رأی دهید، که من هیچ کار مهمی را بدون حضور (و مشورت) شما تصمیم نگرفته ام (و انجام نداده ام)»"
  27,33,"گفتند :« ما دارای نیروی کافی و جنگجویان با قدرتی هستیم، و اختیار (و تصمیم نهایی) با توست، پس بنگر که چه فرمان می دهی»"
  27,34,"گفت : « بی تردید پادشاهان هنگامی که وارد قریه ای شوند آن را ویران (و تباه) سازند، و عزیزانش را ذلیل می کنند، و این گونه رفتار می کنند"
  27,35,و همانا من هدیه ای برای آنها می فرستم، پس می نگرم که فرستادگان چه جواب می آورند»
  27,36,"پس چون (فرستاده ی ملکه) نزد سلیمان آمد، (سلیمان) گفت:«آیا می خواهید مرا با مال یاری کنید ؟! آنچه خدا به من داده، بهتر است از آنچه به شما داده است. بلکه شما به هدیه تان شادمان می شوید"
  27,37,(اکنون) به سوی آنها باز گرد، پس البته با لشکریانی به سوی آنها خواهیم آمد که قدرت مقابله با آن را نداشته باشند، و بی تردید آنها را از آن (سرزمین) با ذلت و خواری بیرون می کنیم !»
  27,38,"(سلیمان) گفت :«ای بزرگان! کدام یک از شما تخت او را برای من می آورد، پیش از آن که تسلیم شده نزد من آیند ؟»"
  27,39,"عفریتی از جن گفت :« من آن را نزد تو می آورم پیش از آنکه از جایت برخیزی، و همانا من بر آن توانای امین هستم»"
  27,40,"کسی که دانشی از کتاب (الهی) داشت گفت :« من پیش از آن که چشم بر هم زنی، آن را نزد تو می آورم». پس چون (سلیمان) آن (تخت) را نزد خود مستقر دید؛ گفت :«این از فضل پروردگار من است، تا مرا بیازماید که آیا شکراو را به جای می آورم یا ناسپاسی می کنم ! » پس هر که شکر کند، تنها به نفع خود شکر می کند، و هر که ناسپاسی کند پس (به زیان خود نموده است،) بی گمان پروردگار من بی نیاز کریم است"
  27,41,"(سلیمان) گفت :« تخت او را برایش نا شناس کنید، (تا) ببینیم آیا (آن را) باز می شناسد، یا از آنهاست که باز نتوانند شناخت"
  27,42,"پس چون (ملکه ی سبا) آمد، (به او) گفته شد :«آیا تخت تو این گونه است؟» گفت :« گویی همان است، و ما پیش از این هم (به قدرت خداوند و حقانیت سلیمان) دانش یافته بوده ایم، و مسلمان (و فرمانبردار) بودیم"
  27,43,و آنچه به جای خدا می پرستید او را (از ایمان به خدا) باز داشته بود، بی گمان او (= ملکه سبا) از قوم کافران بود
  27,44,"به او گفته شد :« به صحن (قصر) داخل شو» پس هنگامی که آن را دید پنداشت که آب عمیقی است، و دو ساق (پای) خود را برهنه کرد (تا از آب بگذرد، سلیمان) گفت :«(این آب نیست) این صحنی صاف از آبگینه است». (ملکه) گفت :« پروردگارا ! من به خود ستم کردم، و (اینک) با سلیمان برای خداوند پروردگار جهانیان تسلیم شدم»"
  27,45,"و به راستی به سوی (قوم) ثمود، برادرشان صالح را فرستادیم که : خدای یگانه را بپرستید، آنگاه آنها دو گروه شدند که به مخاصمه پرداختند"
  27,46,"(صالح) گفت :« ای قوم من ! چرا پیش از نیکی بر بدی می شتابید (و بجای رحمت، عذاب الهی را می طلبید) چرا از خداوند آمرزش نمی خواهید، تا شاید مود رحمت قرار گیرید ؟!»"
  27,47,"گفتند:« ما به تو و کسانی که با تو هستند فال بد زده ایم» (صالح) گفت :« فال بد شما نزد خداست، بلکه شما گروهی هستید که مورد آزمایش قرار می گیرید»"
  27,48,و در (آن) شهر (حِجر) نه نفر بودند که در زمین فساد می کردند و اصلاح نمی کردند
  27,49,"گفتند :« به خدا سوگند یاد کنید که حتماً بر او (= صالح) و خانواده اش شبیخون می زنیم، (و آنها را می کشیم) سپس به ولی (دم) او می گوییم : ما هنگام هلاکت و نا بودی خانواده اش؛ هرگز حاضر نبودیم (و از آنها خبرنداریم) و بی گمان ما راستگو هستیم»"
  27,50,و آنها (برای قتل صالح و پیروانش) حیله و نیرنگی به کار بردند و ما (نیز) حیله و تدبیری (برای هلاک آنها و نجات صالح و پیروانش ) اندیشیدیم، در حالی که آنها نمی دانستند
  27,51,پس بنگر عاقبت نیرنگشان چه شد ؟! ما آنها و قومشان همگی را نابود کردیم
  27,52,پس این خانه های آنهاست که به سزای ستمی که می کردند خالی مانده است، بی گمان در این (ماجرا) نشانه ای است برای گروهی که می دانند
  27,53,و کسانی را که ایمان آورده، و پرهیزگار بودند، نجات دادیم
  27,54,"و لوط را (به یاد آور) هنگامی که به قومش گفت :«آیا کار بسیار زشت (لواط) مرتکب می شوید؛ در حالی که خود (سرانجام وزشتی آن را) می بینید ؟"
  27,55,آیا شما به جای زنان، از روی شهوت سراغ مردان می روید ؟! بلکه شما مردمی نادان هستید»
  27,56,"پس جواب قومش جز این نبود که (به یکدیگر) گفتند : « خاندان لوط را از قریه ی خود بیرون کنید، که اینها مردمانی (پاکدامن و) پاکیزه جو هستند ! »"
  27,57,آنگاه او و خانوده اش را نجات دادیم؛ مگر همسرش که مقدر کردیم او از باز ماندگان (در آن شهر) باشد
  27,58,و بارانی (از سنگ) بر (سر) آنها باراندیم، پس باران بیم داده شدگان چه بد است
  27,59,"(ای پیامبر) بگو :« حمد و سپاس مخصوص خداوند است، و سلام بر بندگانش، کسانی که او (آنها را) بر گزیده است».آیا خداوند بهتر است یا آن چیزهای که شرک می آورند ؟"
  27,60,(آیا این معبودان باطل شما بهتراند) یا کسی که آسمانها و زمین را آفرید، و از آسمان برای شما آبی نازل کرد، پس با آن باغهای خرم (و زیبا) رویاندیم، که شما هرگز توان رویاندن درختان آن را نداشتید،آیا معبودی دیگری با الله است؟! (نه) بلکه آنها گروهی هستند که (از حق منحرف می شوند و بتها را) همطراز (الله) قرار می دهند
  27,61,(آیا این بتها بهتراند) یا کسی که زمین را قرار گاه ساخت، و میان آن نهرهایی قرار داد، و برای آن کوهها (ی ثابت و استوار) پدید آورد، و میان دو دریا مانعی قرار داد، آیا معبود دیگری با الله است ؟! (نه) بلکه بیشترشان نمی دانند
  27,62,(آیا این بتها بهتراند) یا کسی که (دعای) مضطر (= درمانده) را اجابت می کند؛ چون او را بخواند، و گرفتاری را بر طرف می سازد، و شما را جانشینان زمین قرار می دهد، آیا معبودی دیگری با الله است ؟! چه اندک پند می گیرید
  27,63,(آیا این بتها بهتراند) یا کسی که شما را در تاریکیهای بیابان و دریا هدایت می کند، و کسی که پیش از (باران) رحمت خود بادها را به مژده می فرستد، آیا معبودی دیگر با الله است ؟! الله برتر است از آنچه برای او شریک قرار می دهند
  27,64,"(آیا این معبودان باطل بهتراند) یا کسی که آفرینش را آغاز کرد، سپس آن را (بار دیگر) باز می گرداند، و کسی که شما را از آسمان و زمین روزی می دهد، آیا معبود دیگری با الله است ؟! (ای پیامبر!) بگو :«اگر راست می گویید دلیلتان را بیاورید»"
  27,65,"بگو :« در آسمانها و زمین جز الله هیچ کس غیب نمی داند و (آن معبودان با طل) نمی دانند که کی برانگیخته می شوند"
  27,66,بلکه علم آنها (= مشرکان) درباره ی آخرت به پایان رسیده است (و هیچ اطلاعی ندارند) بلکه آنها در (وقوع) آن شک دارند، بلکه آنها نسبت به آن نابینایند
  27,67,"و کسانی که کافر شدند؛ گفتند :«آیا هنگامی که ما و پدران مان خاک شدیم، آیا (باز زنده می شویم واز گورها) بیرون آورده می شویم؟"
  27,68,به راستی این وعده ای است که از پیش به ما و نیاکان مان داده شده است، این جز افسانه های پیشینیان نیست»
  27,69,"(ای پیامبر!) بگو :« در زمین سیر کنید، پس بنگرید عاقبت مجرمان چگونه بود»"
  27,70,و بر آنها غمگین مباش و از آنچه مکر می ورزند؛ دلتنگ نشو
  27,71,"و می گویند :«اگر راست می گویید، این وعده کی خواهد بود؟!»"
  27,72,"(ای پیامبر!) بگو :« شاید پاره ای از آنچه را که به شتاب می طلبید به شما نزدیک شده باشد»"
  27,73,و بی گمان پروردگار تو نسبت به مردم دارای فضل (و رحمت) است، و لیکن بیشترشان شکر نمی گزارند
  27,74,و بی تردید پروردگار تو آنچه در سینه هایشان پنهان می دارند و آنچه را آشکار می کنند؛ بخوبی می داند
  27,75,و هیچ پنهانی در آسمان و زمین نیست؛ مگر آن که در کتاب روشن (لوح محفوظ، نوشته شده) است
  27,76,بی گمان این قرآن بر بنی اسرائیل بیشتر چیزهایی را که آنها در آن اختلاف دارند، بیان می کند
  27,77,و به راستی آن (قرآن) هدایت و رحمت برای مؤمنان است
  27,78,مسلماً پروردگار تو میان آنها (در قیامت) به حکم خود داوری می کند، و او پیروزمند داناست
  27,79,پس (ای پیامبر!) بر خدا تو کل کن، بی شک تو بر حق آشکار هستی
  27,80,و بی گمان تو نمی توانی (سخنت را) به (گوش) مردگان بشنوانی، و نمی توانی کران را هنگامی که پشت کنان روی می گردانند؛ سخن (وندای خود را) بشنوانی
  27,81,و تو نمی توانی کوران را از گمراهی شان (باز گردانی و) هدایت کنی، تو تنها می توانی (سخن خود را) به کسانی بشنوانی که به آیات ما ایمان دارند؛ پس آنها (در برابر حق) تسلیم شدگان هستند
  27,82,و هنگامی که فرمان (عذاب) بر آنها واقع شود (و حادثه قیامت نزدیک شود) جنبنده ای را از زمین برای آنها بیرون می آوریم که با آنها سخن گوید، که مردم به آیات ما یقین نمی آورند
  27,83,و (به یاد آور) روزی را که ما از هر امتی گروهی را از آنان که آیات ما را تکذیب می کردند؛ محشور می کنیم، آنگاه آنها (به صف) نگاه داشته می شوند
  27,84,"تا هنگامی که (به سرزمین محشر) می آیند (خداوند) می فرماید:« آیا مرا تکذیب کردید در حالی که به آن احاطه علمی نداشتید، یا چه(کاری) بود که می کردید؟!»"
  27,85,و بخاطر ستمی که کرده اند؛ فرمان (عذاب) بر آنها واقع می شود، پس آنها هیچ سخنی نمی گویند
  27,86,آیا ندیدند که ما شب را برای آرامش آنها قرار دادیم، و روز را روشنی بخش (قرار دادیم) بی گمان در این (امور) نشانه های (روشنی) است برای گروهی که ایمان می آورند
  27,87,و (به یاد آور) روزی را که در صور دمیده می شود، پس (تمام) کسانی که در آسمانها و زمین هستند و حشت کنند (و بترسند) جز کسی که خدا بخواهد، و همگی با خواری (و ذلت) به پیشگاه او (تعالی) بیایند
  27,88,و کوهها را می بینی، (و) آنها را جامد (و بی حرکت) پنداری، در حالی که مانند حرکت ابرها در حرکت هستند (این) صنع (و آفرینش) خداوندی است که هر چیزی را محکم (واستوار) ساخته است، بی گمان او از آنچه انجام می دهید؛ با خبر است
  27,89,هر کس که نیکی آورد، پس (پاداشی) بهتر از آن خواهد داشت، و آنان از وحشت آن روز در امان هستند
  27,90,"و هر کس که بدی آورد، پس چهره شان در آتش نگونسار شود، (و به آنها گفته می شود :) آیا جزایی جز آنچه می کردید به شما داده می شود ؟"
  27,91,"(ای پیامبر! بگو:) من فقط مأمورم که پروردگار این شهر (مکه) را عبادت کنم، همان کسی که این (شهر) را حرمت بخشید، و همه چیز از آنِِ اوست، و من مأمورم که از مسلمانان باشم"
  27,92,"و این که قر آن را تلاوت کنم، پس هر کس هدایت شود به نفع خود هدایت شده است، و هر کس که گمراه گردد؛ بگو :« من فقط ازهشدار دهندگان هستم»"
  27,93,"و بگو :«حمد و ستایش مخصوص خداست، به زود آیاتش را به شما نشان می دهد، پس آنها را خواهید شناخت، و پروردگار تو از آنچه انجام می دهید؛ غافل نیست"
  28,1,طسم (طا. سین. میم)
  28,2,این آیات کتاب مبین است
  28,3,از داستان موسی و فرعون به حق بر تو می خوانیم، برای گروهی که ایمان می آورند
  28,4,بی گمان فرعون در زمین برتری جست و اهل آن را گروه گروه کرد، گروهی از آنها را به ضعف و ناتوانی می کشاند، پسرانشان را سر می برید و زنانشان را (برای خدمت) زنده نگه می داشت، بی تردید او از مفسدان بود
  28,5,و می خواهیم بر کسانی که در زمین به استضعاف کشیده شده اند، منت گذاریم و آنان را پیشوایان سازیم، و آنان را وارثان (زمین) قرار دهیم
  28,6,و آنها را در زمین تمکّن (و حکومت) دهیم و به فرعون و هامان و لشکریان آن دو، از (دست) آنها (= بنی اسرائیل) آنچه را که از آن می ترسیدند، نشان دهیم
  28,7,"و به مادر موسی الهام کردیم که : «او را شیر بده، پس هنگامی که بر او ترسیدی، او را به دریا (ی نیل) بینداز، و نترس، و اندوهگین مشو، یقیناً ما او را به تو باز می گردانیم و او را از پیامبران قرار می دهیم »"
  28,8,پس (هنگامی که مادر موسی او را به دریا افکند) خاندان فرعون او را (از آب) بر گرفتند، تا سرانجام دشمن و مایه ی اندوه شان شود، مسلماً فرعون و هامان و لشکریان شان خطا کار بودند
  28,9,"و (آسیه) همسر فرعون گفت :«(این کودک) نور چشم من وتوست! او را نکشید، شاید به ما سود بخشد، یا او را به فرزندی گیریم» و آنان (از عاقبت آن) بی خبر بودند (و نمی فهمیدند)"
  28,10,و قلب مادر موسی (از همه چیز) تهی گشت، اگر دل او را (به ایمان) محکم نکرده بودیم تا از باور دارندگان باشد، نزدیک بود آن (راز) را فاش کند
  28,11,"و (مادر موسی) به خواهر او گفت : «به دنبالش برو» پس (خواهرش) او را از دور دید، در حالی که آنها بی خبر بودند"
  28,12,"و (پستان) همه ی زنان شیر ده را از پیش بر او حرام کردیم، آنگاه (خواهرش) گفت: « آیا شما را به خانواده ای راهنمایی کنم که او را برایتان نگه دارند در حالی که آنها خیر خواه او باشند ؟!»"
  28,13,پس او را به مادرش باز گرداندیم تا چشمش روشن شود و غمگین نباشد، و تا بداند که وعده ی الله حق است، و لیکن بیشتر آنها نمی دانند
  28,14,و چون (موسی) به (مرحله ی بلوغ و) کمال قوت رسید و برومند شد، به او حکمت و علم دادیم، و این گونه نیکوکاران را پاداش می دهیم
  28,15,"او هنگامی به شهر وارد شد که اهل آن در غفلت بودند، ناگهان دو مرد را دید با هم نزاع (و جنگ) می کردند، یکی از آنها از پیروان او بود، و دیگری از دشمنانش، پس آن که از پیروان او بود بر(علیه) کسی که از دشمنانش بود از وی یاری خواست. پس (موسی) به او مشت (محکمی) زد و کارش را ساخت، (ومُرد، موسی) گفت : «این از عمل شیطان بود، بی گمان او دشمن گمراه کننده ی آشکاری است»"
  28,16,"(سپس) گفت :«پروردگارا ! من به خود ستم کردم، پس مرا ببخش» آنگاه (خداوند) او را بخشید، بی تردید او آمرزنده ی مهربان است"
  28,17,"گفت :« پروردگارا ! به شکرانه ی نعمتی که بر من عطا کردی، پس هرگز پشتیبان مجرمان نخواهم بود»"
  28,18,"پس (موسی) در شهر ترسان، و چشم به راه حادثه (شب را) صبح نمود، که ناگهان (دید) همان کسی که دیروز از او یاری خواسته بود، او را فریاد می زند (و کمک می خواهد) موسی به او گفت:« بی گمان تو آشکارا (انسان ماجرا جو و) گمراه هستی»"
  28,19,"پس هنگامی که (موسی) خواست به کسی که دشمن هر دوی آنها بود، حمله برد (و بزند، او فریاد زد و) گفت: «ای موسی ! آیا می خواهی مرا بکشی همان گونه که دیروز کسی را کشتی ؟! تو فقط می خواهی در زمین جبّاری باشی، و نمی خواهی که از مصلحان باشی !»"
  28,20,"و(در این هنگام) مردی از دورترین نقطه ی شهر شتابان آمد (و) گفت : «ای موسی ! همانا بزرگان (و اشراف قوم) درباره ی تو مشورت می کنند؛ تا تو را بکشند، پس بی درنگ (از شهر) بیرون شو، بی تردید من از خیر خواهان تو هستم»"
  28,21,"پس ترسان و چشم به راه حادثه،از شهر بیرون شد، گفت : « پروردگارا ! مرا از قوم ستمکار نجات بده»"
  28,22,"و هنگامی که به (جانب شهر) مدین رو آورد؛ گفت :«امید است پروردگارم مرا به راه راست هدایت کند»"
  28,23,"وچون به (چاه) آب مدین رسید، بر آن (چاه) گروهی از مردم را دید که (چهارپایان خود را) آب می دهند، و در کنار آنان دو زن را دید که (گوسفندان خود را) باز می دارند (و به چاه نزدیک نمی شوند، موسی) گفت :«کار شما چیست ؟ (چرا گوسفندان خود را آب نمی دهید ؟!) گفتند:« ما (آنها را) آب نمی دهیم تا چوپانها باز گردند (و بروند) و پدر ما پیر کهنسال است (و توانایی این کار را ندارد)»"
  28,24,"پس (موسی) برای گوسفندان آن دو آب داد، سپس رو به سایه آورد،آنگاه گفت : « پروردگارا! من هرخیری که بر من بفرستی نیازمند هستم»"
  28,25,"آنگاه یکی از آن دو (زن) در حالی که با نهایت حیا گام بر می داشت، نزد او آمد، گفت :«همانا پدرم تو را دعوت می کند؛ تا مزد آب دادن (گوسفندان) را که برای ما انجام دادی، به تو بدهد» پس چون (موسی) به نزد او آمد و داستان (سرگذشت خود) را بر او حکایت کرد، گفت : « نترس، از گروه ستمکاران نجات یافتی»"
  28,26,"یکی از آن دو (دختر) گفت : « پدرجان ! او را اجیر کن، بی تردید بهترین کسی را که می توانی اجیر کنی، کسی است که نیرومند امین باشد (و او چنین است)»"
  28,27,"(شعیب) گفت : «من می خواهم یکی از این دو دختر را به ازدواج تو در بیاورم به شرطی که هشت سال برای من کار کنی، و اگر (آن را) تا ده سال تمام کنی، پس (لطف و) محبتی از سوی توست، من نمی خواهم بر تو سختگیری کنم، اگر خدا بخواهد مرا از صالحان خواهی یافت"
  28,28,"(موسی) گفت : «این (قرار داد) میان من و تو باشد که هر کدام از این دو مدت را انجام دادم بر من ستمی نخواهد بود، و خداوند بر آنچه می گوییم گواه است»"
  28,29,"پس هنگامی که موسی (آن) مدت (معین) را به پایان رسانید، و همراه خانواده اش حرکت کرد، از سوی (کوه) طور آتشی دید؛ به خانواده اش گفت :« درنگ کنید، همانا من آتشی دیدم، شاید خبری از آن برای شما بیاورم، یا شعله ای از آتش (بیاورم) تا شما (با آن) گرم شوید »"
  28,30,"پس هنگامی که به (نزدیکی) آن رسید، از کرانه ی راست وادی در جایگاه پر برکت، از (میان) یک درخت ندا داده شد که :«ای موسی ! یقیناً من الله، پروردگار جهانیانم"
  28,31,"و اینکه عصایت را بیفکن»- پس چون آن را دید که (با سرعت) می جنبد گوی که آن ماری است، (ترسید و) به عقب برگشت و پشت سر خود را نگاه نکرد - (فرمود: ) «ای موسی ! پیش آی، و نترس، بی گمان تو از ایمنان هستی"
  28,32,دستت را در گریبان خود فرو کن، که سفید (و درخشنده) بی عیب بیرون بیاید، و بازویت را (برای حذر) از ترس به سوی خود (بیار و) جمع کن، پس این دو (معجزه عصا و ید بیضا) دو برهان (روشن) از پروردگارت به سوی فرعون و اشراف (قوم) اوست، بی گمان آنها گروهی فاسق هستند»
  28,33,"(موسی) گفت :« پروردگارا ! همانا من یک تن از آنها را کشته ام، پس می ترسم که مرا بکشند"
  28,34,و برادرم هارون زبانش از من فصیح تر است، پس او را همراه من بفرست تا یاورم باشد و مرا تصدیق کند، زیرا که می ترسم مرا تکذیب کنند»
  28,35,"فرمود:« به زودی بازوی تو را با برادرت قوی (و نیرومند) خواهیم کرد، و برای شما سلطه و برتری قرار می دهیم، پس به سبب آیات ما، بر شما دست نیابند، و شما دو نفر و کسی که از شما پیروی کند؛ پیروزید»"
  28,36,"پس هنگامی که موسی با آیات روشن ما به سوی آنها آمد، گفتند :«این (چیزی) جز سحر ساختگی نیست، و ما چنین چیزی را در نیاکان پیشینیان خود نشنیده ایم»"
  28,37,"و موسی گفت : « پروردگار من از (حال) کسی که هدایت را از نزد او آورده، و کسی که سرانجام سرا(ی دیگر) از آن اوست، داناتر است، بی گمان ستمکاران رستگار نخواهند شد»"
  28,38,"و فرعون گفت :«ای بزرگان! من معبودی جز خودم برای شما نمی شناسم، پس ای هامان! برایم آتشی بر گل بیفروز (و آجر بپز) آنگاه برایم برج بلندی بساز، شاید که از خدای موسی با خبر شوم، و هرچند من گمان می کنم که او از دروغگویان است»"
  28,39,و او (= فرعون) و لشکریانش به ناحق در زمین سرکشی کردند، و پنداشتند که آنها به سوی ما باز گردانده نمی شوند
  28,40,پس (ما) او و لشکریانش را فرو گرفتیم، آنگاه در دریا انداختیم، پس بنگر عاقبت ستمکاران چگونه بود ؟
  28,41,و آنها را پیشوایانی قرار دادیم که به سوی آتش (دوزخ) دعوت می کنند، و روز قیامت یاری نخواهند شد
  28,42,در این دنیا لعنتی به دنبال آنان روانه کردیم؛ و روز قیامت از زشت رویانند
  28,43,و به راستی بعد از آنکه امتهای پیشین را هلاک نمودیم؛ به موسی کتاب (تورات) دادیم که برای مردم بصیرت و هدایت و رحمت باشد، شاید پند گیرند
  28,44,و تو (ای پیامبر!) در ناحیه غربی نبودی، هنگامی که فرمان (نبوت) را به موسی دادیم و تو از حاضران نبودی
  28,45,ولیکن (ما) نسلها آفریدیم که عمر دراز یافتند، و تو در میان اهل مدین اقامت نداشتی که آیات ما را بر آنها بخوانی، و لیکن ما بودیم که (پیامبرانی) می فرستادیم
  28,46,و تو در کنار طور نبودی آنگاه که ندا دادیم، ولی این (وحی) رحمتی از جانب پروردگارت است؛ تا گروهی را بیم دهی که پیش از تو بیم دهنده ای برای آنها نیامده بود، شاید که آنها پند گیرند
  28,47,"و اگر آن نبود که به (سبب) اعمالی که مرتکب شده اند؛ مصیبتی به آنها برسد، آنگاه بگویند :« پروردگارا ! چرا به سوی ما پیامبری نفرستادی تا از آیات تو پیروی کنیم و از مؤمنان باشیم ؟»"
  28,48,"پس هنگامی که حق از نزد ما برای آنها آمد، گفتند :« چرا (به این پیامبر) مانند آنچه به موسی داده شد، داده نشده است ؟!» آیا به آنچه پیش از این به موسی داده شد، کفر نورزیدند؟ گفتند : «این دو (قرآن و تورات) جادوی تأیید کننده یکدیگرند» و گفتند : « همانا ما به هر کدام (ازآنها) کافریم»"
  28,49,"بگو:«اگر راست می گویید، پس کتابی هدایت کننده تر از این دو (کتاب) از نزد خدا بیاورید، تا من از آن پیروی کنم»"
  28,50,پس اگر (این سخن) تو را نپذیرفتند، بدان که آنها فقط از هوسهای خود پیروی می کنند، و گمراه تر از آن کس که هوای نفس خویش را بدون (هیچ) هدایتی از (سوی) خدا پیروی می کند؛ کیست ؟! بی گمان خداوند گروه ستمکاران را هدایت نمی کند
  28,51,و به راستی (ما این) سخن را یکی پس از دیگری برای آنها آوردیم؛ شاید متذکر شوند
  28,52,کسانی که پیش از این (قرآن) به آنان کتاب (آسمانی) داده ایم؛ به آن ایمان می آورند
  28,53,"و چون (قرآن) بر آنها خوانده شود، گویند :«به آن ایمان آوردیم، بی تردید، این حق از سوی پروردگارما است، همانا ما پیش از (نزول) آن هم مسلمان بودیم»"
  28,54,اینان (کسانی اند که) به (سبب) صبری که کرده اند، پاداششان دوبار (به آنان) داده می شود، و (اینها) با نیکیها بدی ها را دفع می کنند، و از آنچه به آنها روزی داده ایم؛ انفاق می کنند
  28,55,"و هنگامی که سخن لغو (و بیهوده) بشوند، از آن روی می گردانند و گویند:«اعمال ما از آن ماست، و اعمال شما از آن شما، سلام بر شما ما خواستار جاهلان نیستیم»"
  28,56,(ای پیامبر!) بی تردید تو هر کس را دوست داری نمی توانی هدایت کنی، ولی خداوند هر کس را بخواهد هدایت می کند، و او به هدایت شدگان آگاه تر است
  28,57,"و (مشرکان) گفتند :«اگر به همراه تو از هدایت پیروی کنیم، ما را از سرزمین مان می ربایند» آیا ما (آنها را) در حرم امنی جایشان ندادیم، که ثمرات (و فرآورده های) هر چیزی (از هر سو) به سوی آن آورده می شود، (این) رزقی است از جانب ما، ولیکن بیشتر آنها نمی دانند"
  28,58,و چه بسیار از قریه ها (و آبادیها) یی را که بر اثر فزونی نعمت، مست و مغرور شده بودند؛ هلاک کردیم، پس این خانه های (ویران شده ی) آنهاست، که بعد از آنها جز اندکی (کسی) در آنها سکونت نکرد، و ما وارث آنها بودیم
  28,59,و پروردگار تو هرگز نابود کننده ی قریه ها (و آبادیها) نبود، تا اینکه در کانون آنها پیامبری بفرستد، که آیات ما را برآنها بخواند، و ما هرگز قریه ها (و آبادیها) را هلاک نکردیم؛ مگر آن که اهالی آن ستمکار بودند
  28,60,و آنچه به شما داده شده، متاع زندگی دنیا و زینت آن است، و آنچه نزد الله است، بهتر و پایدار تر است، آیا نمی اندیشید؟
  28,61,آیا کسی که به او وعده نیک داده ایم، پس او به آن (وعده) خواهد رسید، همانند کسی است که او را از متاع زندگی دنیا بهرمند ساخته ایم، سپس روز قیامت از احضار شدگان (در عذاب) خواهد بود ؟
  28,62,"و روزی که (خداوند) آنان را ندا دهد، آنگاه فرماید: «کجا هستند، شریکانی که برای من می پنداشتید؟!»"
  28,63,"کسانی (از معبودان) که فرمان (عذاب) بر آنان تحقیق یافته است. می گویند:« پروردگارا ! اینها (= عابدان) کسانی اند که گمراه شان کردیم؛ (آری) آنها را گمراه کردیم، همان گونه که (خودمان) گمراه شدیم، از آنها به سوی تو بیزاری می جوییم، آنها (در حقیقت) ما را نمی پرستیدند (بلکه آنها شیطان را پرستش می کردند)»"
  28,64,"و (به عابدان) گفته می شود :«معبودهایتان را (که شریک خدا می پنداشتید) بخوانید (تا شما را یاری کنند)» پس آنها را می خوانند، ولی جوابی به ایشان نمی دهند، و عذاب (الهی) را (با چشم خود) ببینید، (و آرزو کنند) که ای کاش هدایت یافته بودند"
  28,65,"و روزی که (خداوند) آنان را ندا دهد، آنگاه فرماید :«پیامبران را چه پاسخی دادید؟!»"
  28,66,در آن روز همه ی خبرها (و حجتها) بر آنها پوشیده ماند، (و همه چیز را فراموش کنند) پس آنان از یکدیگر نپرسند
  28,67,اما کسی که توبه کرد و ایمان آورد و عمل شایسته انجام داد، پس امید است که از رستگاران باشد
  28,68,و پروردگار تو هر چه بخواهد می آفریند، و (هر چه بخواهد) بر می گزیند، آنان را (هیچ) اختیاری نیست، خداوند منزه و برتر است از آنچه شریک او قرار می دهند
  28,69,و پروردگار تو می داند آنچه را که سینه های آنان پنهان می دارد، و آنچه را آشکار می کنند
  28,70,و او خدایی است که هیچ معبودی (به حق) جز او نیست، ستایش در دنیا و آخرت برای اوست، و حکم (و فرمانروایی) از آن اوست، و (همه ی شما) به سوی او باز گردانده می شوید
  28,71,"(ای پیامبر!) بگو :« به من خبر دهید اگر خداوند شب را تا روز قیامت بر شما پایدار سازد، کیست معبودی جز الله که برای شما روشنی آورد ؟! آیا نمی شنوید؟!»"
  28,72,"بگو :« به من خبر دهید اگر خداوند روز را تا روز قیامت بر شما پایدار گرداند، کیست معبودی جز الله که برای شما شبی آورد که در آن آرام بگیرید؟! آیا نمی بینید؟"
  28,73,و از رحمت خویش شب و روز را برای شما قرار داد، تا در آن (= شب) آرام بگیرید، و تا (در روز) از فضل او (روزی) بجویید، و شاید سپاس گزارید
  28,74,"و روزی که (خداوند) آنان را ندا دهد، آنگاه فرماید :«کجا هستند، شریکانی را که برای من می پنداشتید ؟!»"
  28,75,"و از هر امتی گواهی بر می گزینیم، آنگاه می گوییم : « دلیل خود را بیاورید» آنگاه بدانند که حق از آن خداست، و (تمام) آنچه را افترا می بستند از (نظر) آنان ناپدید شود (و تباه گردد)"
  28,76,"بی گمان قارون از قوم موسی بود، پس بر آنها ستم کرد، آن قدر از گنجها به او داده بودیم که حمل کلید هایش بر گروهی زورمند دشوار (و سنگین) بود . هنگامی که قومش به او گفت: «(به خاطر مالت این همه مغرورانه ) شادی نکن، همانا خداوند شادی کنندگان (مغرور) را دوست ندارد"
  28,77,و در آنچه خدا به تو داده، سرای آخرت را بجوی و بهره ات را از دنیا فراموش نکن، و همانگونه که خداوند به تو نیکی کرده است؛ نیکی کن، و هر گز در زمین در پی فساد مباش، بی گمان خداوند مفسدان را دوست ندارد»
  28,78,"(قارون) گفت :« تنها به سبب دانشی که نزد من است آن (مال و ثروت) به من داده شده است» آیا او نمی دانست که خداوند پیش از او اقوامی را هلاک کرد که از او نیرومندتر و ثروتمندتر بودند؟! و مجرمان از گناهانشان پرسیده نمی شوند"
  28,79,"پس (روزی قارون) با آرایش و زینت خویش بر قومش بیرون آمد، کسانی که خواهان زندگی دنیا بودند، گفتند :«ای کاش همانند آنچه به قارون داده شده است؛ ما نیز داشتیم، به راستی که او بر خوردار از بهره ی عظیمی است»"
  28,80,"و کسانی که دانش به آنها داده شده بود، گفتند :« وای بر شما ! ثواب خدا برای کسی که ایمان آورد و کار شایسته انجام دهد بهتر است، و آن (سخن را کسانی) جز صابران نمی پذیرند»"
  28,81,پس او وخانه اش در زمین فرو بردیم، و هیچ گروهی نداشت که او را در برابر (عذاب) خدا یاری کنند، و خود (نیز) نمی توانست خویش را یاری کند
  28,82,"و کسانی که دیروز آرزو می کردند به جای او باشند، می گفتند :« وای بر ما ! گویی خدا روزی را برای هر کس از بندگانش که بخواهد فراخ می گرداند، و (یا) تنگ می گیرد، اگر خدا بر ما منّت ننهاده بود، بی تردید ما را (نیز به قعر زمین) فرو می برد، ای وای ! گویی کافران هرگز رستگار نمی شوند"
  28,83,(آری) این سرای آخرت را (فقط) برای کسانی قرار می دهیم که نه خواهان برتری جویی هستند ونه خواهان فساد، و سرانجام نیک برای پرهیز گاران است
  28,84,کسی که نیکی آورد، پس برای او پاداش بهتر از آن است، و کسی که بدی آورد، پس کسانی که بدیها انجام دادند، جز (به اندازه) آنچه می کردند، مجازات نخواهند داشت
  28,85,"بی تردید کسی که قرآن را بر تو فرض (و نازل) کرد، قطعاً تو را به جایگاهت (= مکه) باز می گرداند. بگو: « پروردگار من بهتر می داند چه کسی هدایت آورده، و چه کسی در گمراهی آشکار است»"
  28,86,و تو امید نداشتی که کتاب (آسمانی) بر تو القا شود، جز این که رحمت پروردگارت بود، پس هرگز پشتیبان کافران مباش
  28,87,و هرگز (کافران) تو را از آیات خدا، بعد از آن که برتو نازل شد، باز ندارند، و به سوی پروردگارت دعوت کن، و هرگز از مشرکان مباش
  28,88,و معبود دیگری با الله مخوان، هیچ معبودی (به حق) جز او نیست، همه چیز جز روی (= ذات) او نابود می شود، فرمانروایی (تنها) از آن اوست، و (همه) به سوی او باز گردانده می شوید
  29,1,الم (الف. لام. میم)
  29,2,"آیا مردم پنداشتند که چون بگویند: «ایمان آوردیم» (به حال خود) رها می شوند، و آنان آزمایش نمی شوند ؟"
  29,3,و به راستی کسانی را که پیش از آنها بودند؛ آزمودیم، پس البته خداوند کسانی را که راست گفتند معلوم می دارد، و دروغگویان را (نیز) معلوم خواهد داشت
  29,4,آیا کسانی که اعمال بد انجام می دهند؛ گمان کردند که از ما پیشی می گیرند؟ چه بد داوری می کنند
  29,5,کسی که به دیدار خدا امید دارد، پس به راستی که وعده ی خداوند خواهد آمد، و او شنوای داناست
  29,6,کسی که (در راه خدا) جهاد کند، تنها برای (نفع) خودش جهاد می کند، بی گمان خداوند از (همه ی) جهانیان بی نیاز است
  29,7,و کسانی که ایمان آوردند و کارهای شایسته انجام دادند، قطعاً گناهانشان را از آنان می زداییم، و آنان را به بهترین اعمالی که انجام می داند، پاداش می دهیم
  29,8,و انسان را به نیک رفتاری (نسبت) به پدر و مادرش سفارش کردیم، و اگر آن دو(مشرک باشند و) تلاش کنند که تو چیزی را که به آن علم نداری شریک من قرار دهی، پس از آنان اطاعت نکن، بازگشت شما به سوی من است، آنگاه شما را به آنچه انجام می دادید؛ آگاه خواهم کرد
  29,9,و کسانی که ایمان آوردند و کارهای شایسته انجام دادند، هر آیینه آنها را در (زمره ی) صالحان در می آوریم
  29,10,"و از مردم کسانی هستند که می گویند: « به خدا ایمان آورده ایم» پس هنگامی که در راه خدا آزار بیند، آزار (و اذیت) مردم را همچون عذاب خدا بشمار می آورد، و اگر پیروزی از سوی پروردگارت (برای شما) بیاید؛ حتماً می گویند :« به راستی که ما (نیز) با شما بودیم» آیا خداوند به آنچه در سینه های جهانیان است؛ داناتر نیست؟"
  29,11,و مسلماً خداوند کسانی را که ایمان آوردند معلوم می دارد، و یقیناً منافقان را (نیز) معلوم خواهد داشت
  29,12,"و کسانی که کافر شدند به کسانی که ایمان آوردند؛ گفتند :«از راه ما پیروی کنید، و البته ما (بار) گناهانتان را بر می داریم». و آنها هر گز چیزی از گناهان ایشان را بر نخواهند داشت، بی گمان آنها دروغگو هستند"
  29,13,و البته بارهای سنگین (گناهان) خویش را بر می دارند، و (همچنین) بارهای دیگری را با بارهای سنگین خود بر می دارند، و روز قیامت یقیناً از آنچه افترا می بستند پرسیده خواهند شد
  29,14,و به راستی که (ما) نوح را به سوی قومش فرستادیم ، پس او در میان آنان هزار سال به جز پنجاه سال (= نهصد و پنجاه سال) درنگ کرد، آنگاه طوفان (و سیلاب) آنان را فرو گرفت در حالی که ستمکار بودند
  29,15,آنگاه او و سرنشینان کشتی را نجات دادیم، و آن (کشتی) را نشانه (ی عبرتی) برای جهانیان قرار دادیم
  29,16,"و ابراهیم را (نیز فرستادیم)، هنگامی که به قومش گفت :« خدا را بپرستید و از او بترسید، که اگر بدانید این برای شما بهتر است"
  29,17,شما به جای خدا فقط بتها (یی از سنگ و چوب) را می پرستید، و دروغی (بزرگ) به هم می بافید، بی گمان کسانی را که به جای خدا می پرستید، مالک هیچ رزقی برای شما نیستند، پس روزی را تنها (از) نزد خدا طلب کنید، و او را بپرستید، و شکر او را بجای آورید، که به سوی او باز گردانیده می شوید
  29,18,و اگر شما تکذیب کنید (عجیب نیست) به راستی که امتهایی پیش از شما نیز تکذیب کردند، و بر (عهده ی) پیامبر (خدا) چیزی جز تبلیغ آشکار نیست»
  29,19,آیا ندیدند که خدا چگونه آفرینش را آغاز می کند، سپس باز می گرداند؟! بی تردید این (کار) بر خدا آسان است
  29,20,"(ای پیامبر!) بگو :« در زمین بگردید؛ آنگاه بنگرید (خداوند) چگونه آفرینش را آغاز کرد، سپس خداوند (به همین گونه) پیدایش باز پسین را پدید می آورد، بی گمان خداوند بر هر چیز تواناست"
  29,21,هر کس را بخواهد عذاب می کند، و هر کس را بخواهد رحمت می آورد، و (شما) به سوی او باز گردانیده می شوید
  29,22,و شما هرگز نمی توانید ما را در زمین و نه در آسمان به ستوه آورید (و از عقوبت ما فرار کنید) و برای شما جز خدا هیچ کار ساز و یاوری نیست»
  29,23,و کسانی که به آیات خدا و دیدار او کافر شدند، اینانند که از رحمت من نومید هستند، و آنان برای شان عذاب درد ناکی است
  29,24,"آنگاه جواب قوم او (= ابراهیم) جز این نبود که گفتند :«او را بکشید، یا او را بسوزانید» پس خداوند او را از آتش نجات داد، بی گمان در این (ماجرا) نشانه هایی است برای گروهی که ایمان می آورند"
  29,25,"و (ابراهیم) گفت :« شما غیر از خدا بتهایی را برای خود برگزیده اید که مایه ی دوستی و محبت میان شما در زندگی دنیا باشد، سپس روز قیامت برخی از شما برخی (دیگر) را انکار می کند، و برخی از شما برخی (دیگر) را لعنت می کند، و جایگاه شما آتش است، و هیچ یاوری برای شما نخواهد بود"
  29,26,"پس لوط به او (= ابراهیم) ایمان آورد، و (ابراهیم) گفت : « من به سوی پروردگارم هجرت می کنم، بی گمان او پیروزمند حکیم است»"
  29,27,و اسحاق و یعقوب را به او بخشیدیم، و در فرزندانش نبوت و کتاب (آسمانی) قرار دادیم، و پاداش او را در دنیا دادیم، و بی تردید او در آخرت از صالحان است
  29,28,"و لوط را (فرستادیم) هنگامی که به قومش گفت :« بی گمان شما (عمل) بسیار زشتی انجام می دهید، که هیچ کس از جهانیان پیش از شما آن را انجام نداده است"
  29,29,"آیا شما (برای کامجویی) به سراغ مردان می روید، و راه را قطع می کنید، و در محافل خود اعمال نا پسند انجام می دهید ؟!» پس جواب قومش جزاین نبود که گفتند :« اگر از راستگویانی عذاب خدا را برای ما بیاور»"
  29,30,"(لوط) گفت :« پروردگارا ! مرا بر قوم مفسدان یاری فرما»"
  29,31,"و هنگامی که فرستادگان ما ابراهیم را بشارت (تولد فرزند) آوردند، گفتند :« به راستی ما اهل این قریه (سدوم) را هلاک خواهیم کرد، بی شک اهل آن ستمکار بودند»"
  29,32,"(ابراهیم) گفت :«همانا لوط در آنجاست ! » (فرشتگان) گفتند :« ما به هر کس که در آنجاست داناتریم، یقیناً او و خانواده اش را نجات می دهیم، جز همسرش که از بازماندگان خواهد بود»"
  29,33,"و چون فرستادگان ما نزد لوط آمدند، از (دیدن) آنها اندوهگین، و به خاطر آنها دلتنگ شد، و (فرشتگان) گفتند: « نترس، و غمگین مباش، بی گمان ما تو و خانواده ات را نجات خواهیم داد؛ جز همسرت که از بازماندگان خواهد بود"
  29,34,همانا ما بر اهل این قریه به (خاطر) آن که نافرمانی (و گناه) می کردند، عذابی از آسمان فرو خواهیم ریخت»
  29,35,و به راستی از آن (قریه) نشانه (و عبرت) روشنی برای گروهی که خرد می ورزند؛ باقی گذاشتیم
  29,36,"وبه سوی مدین برادرشان شعیب را فرستادیم، پس گفت :«ای قوم من! خدا را بپرستید، و به روز باز پسین امیدوار باشید، و در زمین به فساد نکوشید»"
  29,37,آنگاه او را تکذیب کردند، پس زلزله آنان را فرو گرفت، پس در خانه های خود به رو افتادند (و مردند)
  29,38,و (قوم) عاد و ثمود را (نیز هلاک کردیم) و یقیناً برخی از مساکن (ویران شده ی) آنها برای شما آشکار شده است. و شیطان اعمالشان را برای آنها بیاراست، پس آنها را از راه (خدا) بازداشت در حالی که بینا بودند
  29,39,و قارون و فرعون و هامان را (نیز هلاک کردیم) و به راستی موسی با دلایل روشن نزد آنان آمد، پس آنها در زمین سرکشی کردند و پیشی گیرندگان (بر خدا) نبودند
  29,40,آنگاه هر یک از آنها را به (کیفر) گناهش گرفتیم، پس بر بعضی از آنها طوفانی از سنگریزه فرستادیم، و بعضی از آنها را صیحه (= بانگ مرگبار) فرو گرفت، و بعضی را در زمین فرو بردیم، و بعضی را غرق کردیم، و خداوند هرگز به آنها ستم نکرد، و لیکن آنها (خود) بر خویشتن ستم می کردند
  29,41,مثل کسانی که بجای خدا اولیاء (و دوستانی برای خود) بر گزیدند، همچون مثل عنکبوت است، که خانه ای (برای خود) برگزیده است،و بی گمان سست ترین خانه ها خانه ی عنکبوت است، اگر می دانستند
  29,42,یقیتاً خداوند هر آنچه را که به جای او می خوانند، می داند، و او پیروزمند حکیم است
  29,43,و این مثالهایی است که آنها را برای مردم می زنیم، و جز دانایان آنها را در نمی یابند
  29,44,خداوند آسمانها و زمین را به حق آفرید، بی گمان در این نشانه ی (بزرگ) برای مؤمنان است
  29,45,(ای پیامبر!) آنچه را از (این) کتاب بر تو وحی شده است تلاوت کن، و نماز را بر پا دار، یقیناً نماز (انسان را) از زشتیها و منکر باز می دارد، و البته یاد خدا بزرگتر است، و خداوند آنچه را انجام می دهید؛ می داند
  29,46,"و با اهل کتاب جز به روشی که آن بهتر است مجادله نکنید، مگر کسانی از آنان که ستم کردند، و بگویید :« به آنچه (از سوی خدا) بر ما نازل شده و آنچه بر شما نازل شده، ایمان آورده ایم، و معبود ما و معبود شما یکی است، و ما برای او تسلیم هستیم»"
  29,47,و این گونه کتاب (= قرآن) را بر تو نازل کردیم، پس کسانی که به آنها کتاب (آسمانی) دادیم، به آن ایمان می آورند، و از همین گروه (مشرکان نیز) کسی است که به آن ایمان می آورد، و آیات ما را جز کافران انکار نمی کنند
  29,48,و تو (هرگز) پیش از این (قرآن) هیچ کتابی را نمی خواندی، و با (دست) راست خود چیزی نمی نوشتی، اگر چنین بود، باطل گرایان به شک (و تردید) می افتادند
  29,49,بلکه آن (قرآن) آیات روشنی است که در سینه ی کسانی که دانش داده شده اند، جای دارد، و آیات ما را جز ستمکاران انکار نمی کنند
  29,50,"و گفتند :«چرا نشانه هایی از سوی پروردگارش بر او نازل نشده است ؟!» (ای پیامبر!) بگو :«همانا نشانه ها (همه) نزد خداست (و به فرمان او نازل می شود) و من تنها هشدا دهنده ای آشکار هستم»"
  29,51,آیا برای آنها کافی نیست که همانا ما (این) کتاب (قرآن) را بر تو نازل کردیم که (پیوسته) بر آنها تلاوت می شود؟! بی گمان در این (قرآن) رحمت و پندی است برای کسانی که ایمان می آورند
  29,52,"بگو :«همین بس که خدا میان من و شما گواه است، آنچه را در آسمانها و زمین است می داند، و کسانی به که باطل ایمان آوردند و به خدا کافر شدند، اینان زیانکاران (واقعی) هستند»"
  29,53,و آنها با شتاب عذاب را از تو طلب می کنند، و اگر موعد مقرری تعیین نشده بود، یقیناً عذاب (الهی) به (سراغ) آنها می آمد، و ناگهان در حالی که نمی دانند به (سراغ) آنها خواهد آمد
  29,54,و آنها با شتاب عذاب را از تو می طلبند، و بی گمان جهنم به کافران احاطه دارد
  29,55,"روزی که عذاب آنها را از بالای (سر)شان و از زیر پاهایشان در بر می گیرد، و (خداوند به آنها) می فرماید:« بچشید آنچه را انجام می دادید"
  29,56,ای بندگان من که ایمان آورده اید ! بی گمان زمین من وسیع است، پس تنها مرا بپرستید»
  29,57,هر کسی چشنده ی مرگ است، سپس به سوی ما باز گردانده می شوید
  29,58,و کسانی که ایمان آوردند و کارهای شایسته انجام دادند، قطعاً آنها را در غرفه هایی از بهشت جای می دهیم که نهر ها درزیر آن جاری است، جاودانه در آن خواهند ماند، چه خوب است پاداش عمل کنندگان
  29,59,(همان) کسانی که صبر کردند و تنها بر پروردگارشان توکل می کنند
  29,60,و چه بسیار جنبدگانی که روزی خود را بر دوش نمی گیرند، خداوند به آنها و شما روزی می دهد، و او شنوای داناست
  29,61,"و اگر از آنها بپرسی :«چه کسی آسمانها و زمین را آفریده، و خورشید و ماه را مسخر کرده است ؟!» البته می گویند:«الله» پس چگونه (از حق) منحرف می شوند ؟"
  29,62,خداوند روزی را برای هر کس از بندگانش که بخواهد فراخ می گرداند، و (یا) برایش تنگ می دارد، بی گمان خداوند به همه چیز داناست
  29,63,"و اگر از آنها بپرسی :«چه کسی از آسمان آبی را نازل کرد، آنگاه با آن (آب) زمین را بعد از مردنش زنده کرد ؟» البته می گویند :«الله» بگو :« حمد و ستایش مخصوص خداوند است» بلکه بیشتر آنها در نمی یابند"
  29,64,و این زندگی دنیا (چیزی) جز سرگرمی و بازیچه نیست، و بی تردید اگر می دانستند سرای آخرت همان زندگی (واقعی) است
  29,65,پس هنگامی که در کشتی سوار شوند، خدا را با اخلاص می خوانند، پس چون (خدا) آنها را (با آوردن) به خشکی نجات داد، باز آنان شرک می آورند
  29,66,تا آنچه را به آنها داده ایم؛ کفران کنند، و تا (از لذات زندگی دنیا) بهره گیرند، پس به زودی خواهند دانست
  29,67,آیا ندیدند که همانا ما حرم امنی (برای آنها) قرار دادیم، در حالی که مردم از اطراف آنان ربوده می شوند؟! آیا به باطل ایمان می آورند و به نعمت خدا ناسپاسی می کنند؟
  29,68,و کیست ستمکارتر از آن کسی که بر خدا دروغ بندد یا حق را چون به سوی او آید تکذیب کند ؟! آیا جایگاه کافران در جهنم نیست ؟
  29,69,و کسانی که در راه ما (کوشش و) جهاد کنند؛ قطعاً به راههای خویش هدایت شان می کنیم، و یقیناً خداوند با نیکوکاران است
  30,1,الم (الف. لام. میم)
  30,2,رومیان مغلوب شدند
  30,3,در نزدیکترین سرزمین، و آنها بعد از مغلوب شدنشان به زودی غالب خواهند شد
  30,4,در (ظرف) چند سال؛ پیش از (این پیروزی) و بعد از این (پیروزی) فرمان از آن خداست، و در آن روز مؤمنان شادمان خواهند شد
  30,5,به (سبب) یاری خداوند، و (خداوند) هر که را بخواهد یاری می کند، و او پیروزمند مهربان است
  30,6,خداوند وعده داده است، خداوند هرگز وعده ی خویش را خلاف نمی کند، و لیکن بیشتر مردم نمی دانند
  30,7,آنها فقط ظاهری از زندگی دنیا را می دانند، وآنها از آخرت غافلند
  30,8,آیا در ضمیر خود نیندیشیده اند که (دریابند) خداوند آسمانها و زمین و آنچه را میان آن دو است؛ جز به حق و (تا) زمان معینی نیافریده است؟! و بی تردید بسیاری از مردم به دیدار پروردگارشان (در روز قیامت) نا باورند
  30,9,آیا در زمین گردش نکردند، تا بنگرند عاقبت کسانی که پیش از آنها بودند؛ چگونه بود ؟! (آنها) نیرمند تر از اینان بودند، و در زمین دگرگونی به وجود آوردند و آن را بیشتر از آنچه (اینان) آبادش کرده اند، آباد کردند، و پیامبرانشان با دلایل روشن به سوی آنها آمدند، پس خداوند بر آن نبود که برآنها ستم کند، و لیکن (آنها) به خودشان ستم می کردند
  30,10,سپس سرانجام کسانی که بدی کردند، بدتر شد، که آیات خدا را تکذیب کردند، و آن را به مسخره می گرفتند
  30,11,خداوند آفرینش را آغاز می کند، سپس آن را باز می گرداند، آنگاه به سوی او باز گردانده می شوید
  30,12,و روزی که قیامت بر پا شود، مجرمان نومید شوند
  30,13,و برای آنها از معبودانشان شفیعانی نخواهد بود، و نسبت به معبودانشان (که آنها را همتهای خدا قرار داده بودند) کافر می شوند
  30,14,و روزی که قیامت بر پا شود، آن روز (مردم) از هم جدا می شوند
  30,15,اما کسانی که ایمان آورده اند و کار های شایسته انجام داده اند، آنان در باغی (از بهشت) شادمان و مسرور خواهند بود
  30,16,و اما کسانی که کافر شدند و آیات ما و دیدار آخرت را تکذیب کردند، پس اینان در عذاب (الهی) احضار شوند
  30,17,پس خدا را تسبیح گویید؛ هنگامی که شام می کنید و هنگامی که صبح می کنید
  30,18,و حمد و ستایش مخصوص اوست، در آسمانها و زمین، و عصرگاهان و هنگامی که ظهر می کنید
  30,19,زنده را از مرده بیرون می آورد، و مرده را از زنده بیرون می آورد، و زمین را پس از مردنش زنده می سازد، و همین گونه (روز قیامت از گورها) بیرون آورده می شوید
  30,20,و از نشانه های او (این) است که شما را از خاک آفرید، پس ناگاه شما انسانهای (زیادی شدید و در زمین) پراکنده گشتید
  30,21,و از نشانه های او (این) است که همسرانی از جنس خودتان برای شما آفرید؛ تا به آنها آرام گیرید، و در میانتان مودت و رحمت قرار داد، بی گمان در این (امر) نشانه های است برای گروهی که تفکر می کنند
  30,22,و از نشانه های او آفرینش آسمانها و زمین، و اختلاف زبانهایتان و رنگهایتان است، بی تردید در این نشانه های برای دانایان است
  30,23,و از نشانه های او خوابیدن شما در شب و روز است، و تلاش و بهره جستن شما از فضل اوست، بی شک در این نشانه های است؛ برای گروهی که می شنوند
  30,24,و از نشانه های او (این) است که برق را برای بیم و امید به شما نشان می دهد، و از آسمان آبی نازل می کند، آنگاه زمین را بعد از مردنش به آن (آب) زنده می کند؛ بی گمان در این نشانه های است؛ برای گروهی که می اندیشند
  30,25,و از نشانه های او (این) است که آسمانها وزمین به فرمانش (بر جای) می ایستند، پس هنگامی که با ندایی شما را از زمین فرار خواند، ناگهان شما خارج می شوید
  30,26,و از آن اوست هر که در آسمانها وزمین است، و همگی فرمانبردار او هستند
  30,27,و او کسی است آفرینش را آغاز می کند، سپس آن را باز می گرداند و این (باز گرداندن) بر او آسان تر است، و توصیف برتر در آسمانها و زمین برای اوست، و او پیرزومند حکیم است
  30,28,(خداوند) برای شما از خودتان مثلی زده است؛ آیا بردگانتان در آنچه به شما روزی دادایم، با شما شریک هستند، تا شما در آن برابر (ویکسان) باشید، همانگونه که شما از (شرکای آزاد) خود بیم دارید از آنها هم بیم داشته باشید؟! این چنین آیات را برای گروهی که تعقل می کنند به روشنی بیان می کنیم
  30,29,بلکه ستمکاران بدون علم و آگاهی از هوی و هوسهای خود پیروی کردند، پس آن را که خدا گمراه کرده است چه کسی هدایت می کند؟! و برای آنها هیچ یاوری نخواهد بود
  30,30,پس روی خود را با حق گرایی (و اخلاص) به سوی دین آور، فطرت الهی است، که (خداوند) مردم را بر آن آفریده است، دگرگونی در آفرینش خدا نیست، این است دین استوار، و لیکن بیشتر مردم نمی دانند
  30,31,به سوی او باز گردید، و از او بترسید، و نماز را بر پا دارید، و از مشرکان نباشید
  30,32,از کسانی که دین خود را پاره پاره کردند، و فرقه فرقه شدند، و هر گروهی به آنچه نزد خود دارند؛ خوشحالند
  30,33,و هنگامی که (رنج و) زیانی به مردم برسد پروردگارشان را می خوانند، (و توبه کنان) به سوی او باز می گردند، سپس هنگامی که رحمتی از خودش به آنان بچشاند، ناگاه گروهی از آنان به پروردگارشان شرک می آورند
  30,34,تا به آنچه که به آنها داده ایم؛ کفران کنند ، پس (از لذات دنیا) بهره بگیرید، که به زودی خواهید دانست
  30,35,آیا دلیل محکمی بر آنها نازل کردیم ، پس آن (دلیل) از چیزی که با خدا شریک می سازند، سخن می گوید ؟
  30,36,و هنگامی که رحمتی به مردم بچشانیم به آن خوشحال می شوند، و اگر به خاطر اعمالی که انجام داده اند؛ رنج و مصیبتی به آنها برسد، ناگهان مأیوس می شوند
  30,37,آیا ندیدند که خداوند روزی را برای هر کس که بخواهد فراخ می گرداند، و (یا) تنگ می گیرد؟! بی گمان در این (گشایش و تنگی) نشانه هایی است برای گروهی که ایمان می آورند
  30,38,پس حق خویشاوندان و مسکینان و در راه ماندگان را بده، این برای کسانی که روی خدا می طلبند؛ بهتر است، و اینانند که رستگارند
  30,39,و آنچه (به قصد) ربا می دهید تا در اموال مردم فزونی یابد، نزد خدا فزونی نخواهد یافت، وآنچه را (به عنوان) زکات می پردازید که تنها وجه الله را می طلبید (برکت و فزونی می یابد) پس (کسانی که چنین کنند) اینان فزونی یافتگانند
  30,40,الله همان کسی است که شما را آفرید، آنگاه به شما روزی داد، پس شما را می میراند، آنگاه شما را زنده می کند، آیا هیچ یک از شریکان تان می توانند چیزی از این (کارها) انجام دهند ؟! او منزه و برتر است از آنچه شریک او قرار می دهند
  30,41,به سبب کارهای که مردم انجام داده اند، فساد در خشکی و دریا آشکار شده است، تا (خداوند) جزای بعضی از آنچه را که انجام داده اند، به آنان بچشاند، باشد که آنان (به سوی حق) باز گردند
  30,42,"(ای پیامبر!) بگو :« در زمین سیر کنید، پس بنگرید عاقبت کسانی که پیش از این بودند؛ چگونه بود، بیشتر آنها مشرک بودند"
  30,43,پس روی خود را به آیین پایدار بیاور، پیش از آن که روزی فرا رسد که برایش هیچ بازگشتی از (سوی) خداوند نیست، آن روز (مردم) متفرق شوند
  30,44,کسی که کفر ورزد، پس کفرش بر زیان (خود) اوست، و کسی که کار شایسته انجام دهد، پس برای خودشان آماده می سازند
  30,45,تا (خداوند) کسانی را ایمان آورده اند و کارهای شایسته انجام داده اند از فضل خود پاداش دهد، بی گمان او کافران را دوست نمی دارد
  30,46,و از نشانه های (عظمت) او آن است که بادهای مژده دهنده را می فرستد، و تا از رحمت خود به شما بچشاند، و تا کشتیها به فرمان او حرکت کنند، و تا از فضل او (روزی) بجویید، و باشد که سپاس گویید
  30,47,و به راستی پیش از تو پیامبرانی را به سوی قومشان فرستادیم، پس با دلایل روشن نزدشان آمدند، آنگاه از کسانی که گناه کردند، انتقام گرفتیم، (و مؤمنان را یاری دادیم) و یاری دادن مؤمنان بر (عهده ی) ما بود
  30,48,الله همان کسی است که بادها را می فرستد، آنگاه ابرها را به حرکت در می آورد، سپس آن (ابرها) را در آسمان آن گونه که بخواهد می گستراند، و آن را پاره پاره می گرداند، پس می بینی که دانه های باران از لابه لای آن خارج می شود . پس هنگامی که این (باران حیات بخش) را به هر کس از بندگانش که بخواهد برساند، ناگهان آنان خوشحال می شوند
  30,49,و اگر چه پیش از آن که (باران رحمت) بر آنان نازل شود؛ مأیوس بودند
  30,50,پس به آثار رحمت خدا بنگر که چگونه زمین را بعد از مردنش زنده می کند، یقیناً این (خداوند) زنده کننده ی مردگان است، و او بر همه چیز تواناست
  30,51,و اگر بادی بفرستیم (گرم و سوزان) آنگاه آن (کشتزارها) را زرد شده ببینند، (مأیوس شده، و) پس از آن ناسپاس می شوند
  30,52,پس (ای پیامبر!) تو نمی توانی (سخنت را) به (گوش) مردگان بشنوانی، و نمی توانی کران را هنگامی که پشت کنان روی می گردانند؛ سخن (و ندای خود را) بشنوانی
  30,53,و تو نمی توانی کوران را از گمراهی شان (باز گردانی و) هدایت کنی، تو تنها می توانی (سخن خود را) به کسانی بشنوانی که به آیات ما ایمان دارند، پس آنها (در برابر حق) تسلیم شدگان هستند
  30,54,الله همان کسی است که شما راناتوان آفرید، سپس بعد از ناتوانی، قوت بخشید، و آنگاه بعد از قوت ناتوانی و پیری قرار داد، هرچه بخواهد می آفریند، و او دانای تواناست
  30,55,و روزی که قیامت بر پا شود، مجرمان سوگند یاد می کنند که جز ساعتی (در دنیا) درنگ نکردند! (آری) این گونه (از حقیقت و راه حق) باز گردانده می شوند
  30,56,"و کسانی که دانش و ایمان داده شده اند، گویند: «به راستی شما به فرمان کتاب خدا (لوح محفوظ) تا روز رستاخیز درنگ کردید، پس این روز رستاخیز است، لیکن شما نمی دانستید»"
  30,57,پس آن روز کسانی که ستم کردند؛ عذر خواهی شان سودی ندارد و به آنان مهلت (توبه) داده نخواهد شد
  30,58,"به راستی برای مردم در این قرآن از هر گونه مثلی آوردیم، و اگر نشانه ای برای آنان بیاوری، البته کسانی که کافر شدند، گویند:«شما جز بیهوده گویان نیستید»"
  30,59,این گونه خداوند بر دلهای کسانی که نمی دانند، مهر می نهد
  30,60,پس (ای پیامبر گرامی !) صبر پیشه کن، بی گمان وعده ی خدا حق است، و هرگز کسانی که یقین ندارند تو را سبکسر نگردانند
  31,1,الم (الف. لام. میم)
  31,2,این آیات کتاب حکیم است
  31,3,هدایت ورحمت برای نیکوکاران است
  31,4,کسانی که نماز را بر پا می دارند، و زکات را می پردازند، و آنها به آخرت یقین دارند
  31,5,اینان از جانب پرودگارشان بر هدایت هستند، و اینان رستگارانند
  31,6,و از مردم کسی هست که سخنان بیهوده را می خرد؛ تا به نادانی (مردم را) از راه خدا گمراه سازد، و آن (آیات) را به ریخشند می گیرد، اینان برای شان عذاب خوار کننده است
  31,7,و هنگامی که آیات ما براو خوانده شود، تکبر کنان روی می گرداند، گویی که آن را نشنیده است، گویی در گوشهایش سنگینی است، پس او را به عذابی دردناک بشارت ده
  31,8,بی گمان کسانی که ایمان آوردند و کارهای شایسته انجام دادند، برای آنها باغهای پر نعمت (بهشت) است
  31,9,جاودانه در آن خواهند ماند، وعده ی خداوند راست است، و او پیروزمند حکیم است
  31,10,(خداوند) آسمانها را بدون ستون آفرید که می بینید، و در زمین کوه های استوار افکند تا شما را نلرزاند، و از هرگونه جنبنده ای در آن بپراکند، و از آسمان آبی نازل کردیم، آنگاه در آن ( زمین) هر جفت (گیاه) پر ارزش (و نیکو) رویاندیم
  31,11,این آفرینش خداوند است، پس به من نشان دهید کسانی که غیر او هستند، چه چیزی را آفریده اند؟! بلکه ستمکاران در گمراهی آشکاری هستند
  31,12,"و به راستی به لقمان حکمت دادیم، (و به او گفتیم) که : شکر خدا را به جای آور؛ و هرکس شکر کند تنها به سود خود شکر کرده است، وهر کس که کفران کند، پس بی تردید خداوند بی نیاز ستوده است"
  31,13,"و (به یاد آور) هنگامی را که لقمان به فرزندش در حالی که او را پند می داد، گفت :«ای پسرک من! به خدا شرک نیاور، بی گمان شرک، ستم بزرگی است"
  31,14,و به انسان درباره ی پدر و مادرش سفارش کردیم، مادرش او را با ناتوانی روی ناتوانی حمل کرد، و از شیر باز گرفتنش در دو سال است، (آری، سفارش کردیم) که برای من و برای پدر و مادرت شکر به جای آور که باز گشت (همه ی شما) به سوی من است
  31,15,و اگر آن دو (مشرک باشند و) تلاش کنند که تو چیزی را که به آن علم نداری شریک من قرار دهی، پس از آنان اطاعت نکن، ودر دنیا با آنان به شایستگی رفتار کن، و از راه کسی پیروی کن که (توبه کنان) به سوی من باز آمده است، سپس بازگشت (همه ی) شما به سوی من است، آنگاه شما را از آنچه انجام می دادید؛ آگاه می کنم
  31,16,ای پسرک من! اگر (عمل نیک یا بد) به اندازه سنگینی دانه ی خردل باشد، آنگاه در درون تخته سنگی یا در آسمانها یا در زمین باشد، خداوند آن را (در روز قیامت برای حساب) می آورد، بی گمان خداوند باریک بین آگاه است
  31,17,ای پسرک من! نماز را بر پا دار، و امر به معروف کن و نهی از منکر کن، و بر هر آنچه به تو برسد صبر کن، بی تردید این از کارهای سترگ است
  31,18,و با بی اعتنایی از مردم روی مگردان، و مغرورانه در زمین راه مرو، بی گمان خداوند هیچ متکبر فخروشی را دوست ندارد
  31,19,و در راه رفتنت اعتدال را رعایت کن، و از صدای خود بکا (و هرگز فریاد نزن) زیرا زشت ترین صداها؛ صدای خران است
  31,20,آیا ندیدید که خداوند آنچه را که در آسمانها و آنچه را که در زمین است؛ مسخر شما کرده است، و نعمتهای خود را آشکار و پنهان (بطور فراوان) بر شما ارزانی داشته است؟! و از مردم کسی هست که بدون هیچ دانش و هدایت و کتاب روشنگری درباره ی خدا مجادله می کند
  31,21,"و هنگامی که به آنان گفته شود : «از آنچه خدا نازل کرده است؛ پیروی کنید» گویند: « (نه) بلکه ما از چیزی پیروی می کنیم که نیاکان خود را بر آن یافتیم». آیا حتی اگر شیطان آنان را به سوی عذاب (آتش) سوزان دعوت کند (باز هم ازآنها پیروی می کنند؟)"
  31,22,و کسی که روی خویش را تسلیم خدا کند در حالی که نیکوکار باشد، به راستی به دستگیره ی محکمی چنگ زده است، و سرانجام (همه ی) کارها به سوی خداست
  31,23,و کسی که کافر شود، پس کفر او تو را غمگین نسازد، بازگشت (همه ی) آنان به سوی ماست، پس آنان را از آنچه انجام داده اند؛ آگاه خواهیم کرد، بی تردید خداوند به آنچه درون سینه هاست؛ دانا است
  31,24,آنها را اندکی (از متاع دنیا) بهرمند می کنیم، سپس آنها را به (تحمل) عذاب سختی ناگزیر سازیم
  31,25,"و اگر از آنها بپرسی :« چه کسی آسمانها و زمین را آفرید ؟!» مسلماً می گویند:«الله». بگو :« حمد و ستایش مخصوص خداوند است» بلکه بیشتر آنها نمی دانند"
  31,26,آنچه در آسمانها و زمین است از آن خداست، بی گمان خداوند است که بی نیاز ستوده است
  31,27,و اگر (همه ی) درختان روی زمین قلم شود، و دریا (مرکب گردد) و هفت دریای دیگر به مدد آن بیاید، سخنان خدا پایان نمی یابد، بی تردید خداوند پیروزمند حکیم است
  31,28,آفرینش و بر انگیختن (همه ی) شما (در روز قیامت) جز مانند (آفرینش و زنده کردن) یک تن بیش نیست، بی گمان خداوند شنوای بیناست
  31,29,آیا ندیدی که خداوند شب را در روز داخل می کند، و روز را در شب داخل می گرداند، و خورشید و ماه را مسخر کرده که هر یک تا زمانی معین در حرکت است، و یقیناً خداوند به آنچه انجام می دهید؛ آگاه است
  31,30,این بدان (سبب) است که خداوند حق است، و همانا آنچه به جز او می خوانند؛ باطل است، و همانا خداوند است که بلند مرتبه ی بزرگ است
  31,31,آیا ندیدی که کشتی به (فرمان و) نعمت خدا در دریا حرکت می کند، تا (خداوند) بخشی از نشانه های خود را به شما نشان دهد؟! بی گمان در این برای هر شکیبای سپاسگزار نشانه هایی است
  31,32,و هنگامی که (در دریا) موجی همچون سایه بان آنها را بپوشاند، خدا را با اخلاص می خوانند، پس چون آنها را (با آوردن) به خشکی نجات داد، آنگاه بعضی از آنان راه اعتدال را پیش می گیرند. (و بر ایمان و عهد خود می مانند، در حالی که بعضی دیگر راه کفر را پیش می گیرند) و آیات ما را هیچ کس جزپیمان شکنان ناسپاس؛ انکار نمی کند
  31,33,ای مردم! از پروردگارتان بپرهیزید، و از روزی بترسید که نه پدر کیفر فرزندش را به عهده می گیرید، و نه فرزند چیزی از کیفر (اعمال) پدرش را عهده دار می شود، یقیناً وعده خداوند حق است، پس زندگی دنیا شما را نفریبد، و (شیطان) فریبکار شما را نسبت به خدا نفریبد
  31,34,بی گمان علم (زمان) قیامت نزد خداست، و (او) باران را نازل می کند، و آنچه را که در رحمهاست می داند، و هیچ کس نمی داند فردا چه چیز به دست می آورد، و هیچ کس نمی داند که در کدام سرزمین می میرد، یقیناً خداوند دانای آگاه است
  32,1,الم (الف . لام .میم)
  32,2,نازل شدن (این) کتاب، که در آن هیچ شکی نیست، از سوی پروردگار جهانیان است
  32,3,"آیا می گویند : «(محمد) آن را به دروغ بافته است؟» (نه) بلکه آن حق است، از جانب پرودگار توست، تا هشدار دهی قومی را که پیش از تو هشدار دهنده ای برای شان نیامده است، شاید هدایت شوند"
  32,4,الله کسی است که آسمانها و زمین و آنچه را میان آنهاست در شش روز آفرید، سپس بر عرش قرار گرفت، شما را جز او هیچ کار ساز و شفیعی نیست، آیا پند نمی گیرید؟
  32,5,کار (جهان هستی) را از آسمان تا زمین تدبیر می کند، سپس در روزی که مقدار آن هزار سال از سالهایی است که شما می شمارید؛ به سوی او بالا می رود
  32,6,این (توصیف) دانای پنهان و آشکار، پیروزمند مهربان است
  32,7,(همان) کسی که هر چه را آفرید به نیکوترین (وجه) آفرید، و آفرینش انسان را از گل آغاز کرد
  32,8,سپس نسل او را از عصاره ای از آب نا چیز پدید آورد
  32,9,آنگاه (اندام) او را سامان داد، و از روح خود در آن دمید، و برای شما گوش و چشمها و دلها قرار داد، چه اندک سپاس می گزارید
  32,10,"و (کافران) گفتند :«آیا هنگامی که (مردیم و) در زمین نا پدید شدیم، آیا در آفرینش تازه ای خواهیم بود ؟!» بلکه آنان به دیدار پروردگارشان کافرند"
  32,11,"(ای پیامبر!) بگو :«فرشته ی مرگ که بر شما گماشته شده؛ جانتان را می گیرد، سپس به سوی پروردگارتان باز گردانده می شوید»"
  32,12,"و اگر ببینی مجرمان را هنگامی که در پیشگاه پروردگارشان سرهایشان به زیر افکنده اند، (گویند:) «پروردگارا ! دیدیم، و شنیدیم، پس ما را بازگردان تا کار شایسته ای انجام دهیم، بی گمان ما (به قیامت) یقین داریم»"
  32,13,و اگر می خواستیم به هرکس هدایتش را می دادیم، ولیکن سخن (و وعده ی) من حق است که جهنم را از جنیان و آدمیان همگی پر می کنم
  32,14,پس به کیفر آن که دیدار امروزتان را فراموش کردید، (عذاب را) بچشید، بی گمان ما (نیز) شما را فراموش کردیم. و عذاب جاودان را بخاطر اعمالی که انجام می دادید؛ بچشید
  32,15,تنها کسانی به آیات ما ایمان می آورند که چون به آن پند داده شوند، سجده کنان (به زمین) افتند، و پروردگارشان را به پاکی بستایند، و آنان تکبر نمی کنند
  32,16,پهلوهایشان از بسترها (در دل شب) دور می شود، پروردگارشان را با بیم و امید می خوانند، و از آنچه به آنها روزی داده ایم انفاق می کنند
  32,17,پس هیچ کس نمی داند چه پاداشها(ی عظیمی) که مایه ی روشنی چشمهاست برای آنها نهفته شده است، به؛ (پاس) آنچه که (در دنیا) انجام می دادند
  32,18,آیا کسی که مؤمن است همچون کسی است که فاسق است؟! (نه) هرگز برابر نیستند
  32,19,اما کسانی که ایمان آوردند و کارهای شایسته انجام دادند، پس برای آنها باغهای بهشت جاویدان خواهد بود، (این به عنوان) محل پذیرایی (از آنها) است؛ به پاداش آنچه که انجام می دادند
  32,20,"و اما کسانی که فاسق شدند، پس جایگاهشان آتش (جهنم) است، هرگاه که بخواهند از آن خارج شوند، به آن باز گردانده شوند،و به آنها گفته شود: «بچشید عذاب آتشی را که آن را تکذیب می کردید»"
  32,21,و یقیناً به آنان از عذاب نزدیک (این دنیا) پیش از عذاب بزرگ (آخرت) می چشانیم، شاید باز گردند
  32,22,و کیست ستمکار تر از آن کسی که به آیات پروردگارش پند دهند، آنگاه از آن اعراض کند؟ بی گمان ما از مجرمان انتقام خواهیم گرفت
  32,23,به راستی به موسی کتاب (تورات) دادیم، پس (ای پیامبر گرامی!) از دیدار او (= موسی) در شک و تردید مباش و ما آن (تورات) را (وسیله ی) هدایت برای بنی اسرائیل قرار دادیم
  32,24,و از آنان پیشوایانی قرار دادیم که به فرمان ما (مردم را) هدایت می کردند، چون شکیبایی ورزیدند، و به آیات ما یقین داشتند
  32,25,مسلماً پروردگارتوست که در روز قیامت میان آنها در آنچه اختلاف می کردند؛ داوری می کند
  32,26,آیا برای آنها روشن نشده است که چه نسلهای بسیاری را پیش از آنها هلاک کردیم ؟! که اینان در خانه های (ویران شده ی) آنها راه می روند، بی گمان در این نشانه ها (و عبرتها) است، آیا نمی شنوند؟
  32,27,آیا ندیدند که ما آب را به سوی زمین خشک (و بی گیاه) می رانیم، پس به (وسیله ی) آن کشتزار را بیرون می آوریم، که چهارپایان شان و خودشان از آن می خورند، آیا نمی بینند؟
  32,28,"و گویند:«اگر راستگویید، این پیروزی کی خواهد بود؟!»"
  32,29,"بگو :« روز پیروزی، کسانی که کافر شدند؛ ایمان شان سودی نخواهد داشت، ونه به آنها مهلت داده می شود»"
  32,30,سپس (ای پیامبر!) از آنها روی بگردان، و منتظر باش که آنها (نیز) منتظر هستند
  33,1,ای پیامبر ! از خدا بترس، و از کافران و منافقان اطاعت نکن، بی گمان خداوند دانای حکیم است
  33,2,و از آنچه از سوی پروردگارت به تو وحی می شود؛ پیروی کن، یقیناً خداوند به آنچه انجام می دهید؛ آگاه است
  33,3,و بر خدا توکل کن، و خداوند (به عنوان) کارساز(و مدافع) بسنده است
  33,4,خداوند برای هیچ کس دو قلب در درونش قرار نداده است، و هرگز همسرانتان را که مورد ظهار قرار می دهید؛ مادران شما قرار نداده است، و (نیز) فرزند خوانده های شما را فرزند (حقیقی) شما قرار نداده است، این سخن (باطل) شماست که به دهان خود می گویید، و خداوند سخن حق را می گوید، و او به راه راست هدایت می کند
  33,5,آنها (= فرزند خوانده ها) را به نام پدرانشان بخوانید که این (کار) نزد خدا منصفانه تر است، پس اگر پدرانشان را نمی شناسید، برادران دینی شما، و موالی شما هستند. و در آنچه که (قبلاً) اشتباه کرده اید؛ گناهی بر شما نیست، و لیکن آنچه را که دلهای شما از روی عمد می خواهد (و می گویید، گناه است) و خداوند آمرزنده ی مهربان است
  33,6,پیامبر نسبت به مؤمنان از خودشان سزاوارتر است، و همسران او مادران آنها هستند، و در کتاب خدا خویشاوندان برخی از آنان به برخی (دیگر) از (سایر) مؤمنان و مهاجران سزاوارترند، مگر این که به دوستان تان نیکی کنید (و سهمی از اموال خود را به آنان بدهید) این (حکم) در کتاب (لوح محفوظ) نوشته شده است
  33,7,و (ای پیامبر گرامی ! به یاد آور) هنگامی را که از پیامبران پیمان شان را گرفتیم و (همچنین) از تو و از نوح و ابراهیم و موسی و عیسی بن مریم، و از همه ی آنان پیمان محکمی گرفتیم
  33,8,تا (خداوند) راستگویان را از صدقشان بپرسد، و برای کافران عذابی دردناک آماده کرده است
  33,9,ای کسانی که ایمان آورده اید! نعمت خدا را بر خود به یاد آورید، هنگامی که لشکرهایی به سوی شما آمدند، پس ما تند باد (سختی) بر آنها فرستادیم، و لشکرهایی (از فرشتگان) که آنها را نمی دیدید، (و آنها را درهم کوبیدیم) و خداوند به آنچه انجام می دهید؛ بیناست
  33,10,هنگامی که آنها (= دشمنان) از (سمت) بالای (شهر) شما و از (سمت) پایین (شهر) تان به سوی شما آمدند (و شما را محاصره کردند) و زمانی را که چشمها (از شدت وحشت) خیره شد، و دلها به حنجره ها رسید، و گمان های گوناگونی به خدا می بردید
  33,11,آنجا بود که مؤمنان آزمایش شدند و به سختی تکان خوردند
  33,12,"و (نیز به یاد آورید) هنگامی را که منافقان و کسانی که در دلهایشان بیماری است، می گفتند :«خدا و پیامبرش جز فریب به ما وعده ای نداده است»"
  33,13,"و (نیز) هنگامی که گروهی از آنان گفتند :«ای اهل یثرب ! اینجا جای ماندن شما نیست، پس (به خانه های خود) برگردید» و گروهی از آنان از پیامبر اجازه (ی بازگشت) می خواستند، می گفتند :«بی شک خانه های ما بی حفاظ است» در حالی که بی حفاظ نبود، آنها فقط می خواستند (از جهاد) فرار کنند"
  33,14,و اگر (لشکر دشمنان) از اطراف مدینه بر آنان وارد می شدند (و خانه هایشان را محاصره می کردند) سپس پیشنهاد بازگشت به کفر و شرک (به آنها) می کردند، می پذیرفتند، و جز اندکی برای (انتخاب) آن درنگ نمی کردند
  33,15,و به راستی که آنان پیش از این با خدا عهد کرده بودند که پشت (به دشمن) نکنند، و عهد (و پیمان) خدا باز خواست دارد
  33,16,"(ای پیامبر!) بگو:«اگر از مرگ یا کشته شدن فرار کنید، هرگز فرار سودی به حال شما نخواهد داشت، و آنگاه جز اندکی (از زندگی دنیا) بهره مند نخواهید شد»"
  33,17,"(ای پیامبر!) بگو:«چه کسی است که شما را از(اراده ی) خدا حفظ می کند، اگر (او) برای شما بدی اراده کرده باشد، یا رحمتی برای شما اراده کرده باشد ؟!» و آنها برای خود جز خدا هیچ دوست و یاوری نخواهند یافت"
  33,18,"قطعاً خداوند باز دارندگان را (از جهاد) از شما، و آنان را که به برادران شان گفتند:«به سوی ما بیایید» و جز اندکی به کارزار نمی آیند؛ می شناسد"
  33,19,(در حالی که) آنها بر شما بخل می ورزند، پس هنگامی که (زمان) ترس (پیش) آید، می بینی که به تو نگاه می کنند، در حالی که چشمهایشان (در حدقه) می چرخد، مانند کسی که از (سکرات) مرگ بی هوش شده باشد، پس چون ترس ( و وحشت) بر طرف شد، شما را با زبانهای تیز (و تند خود) می رنجانند، در حالی که بر مال (غنایم) سخت حریص و آزمندند، اینان (هرگز) ایمان نیاورده اند، لذا خداوند اعمالشان را تباه (و نابود) کرد، و این (کار) بر خدا آسان است
  33,20,آنها گمان می کنند که (لشکریان) احزاب (هنوز) نرفته اند، و اگر (لشکریان) احزاب (بار دیگر) بر گردند، آرزو می کنند، ای کاش! آنان در میان اعراب بادیه نشین بودند، که از اخبار شما جویا می شدند، و اگر در میان شما باشند؛ جز اندکی پیکار نکنند
  33,21,یقیناً برای شما در زندگی رسول خدا سرمشق نیکویی است، برای آنان که به خدا و روز آخرت امید دارند، و خدا را بسیار یاد می کنند
  33,22,"و چون مؤمنان (لشکر) احزاب را دیدند، گفتند :« این همان چیزی است که خدا و پیامبرش به ما وعده داده، و خدا و پیامبرش راست گفته اند» و (این امر) جز بر ایمان و تسلیم شان نیفزود"
  33,23,از مؤمنان مردانی هستند که به عهد و پیمانی که با خدا بسته بودند (صادقانه) وفا کردند، پس کسی از آنان هست که پیمان خود را به آخر رساند (وشهید شد) و از آنان کسی هست که در انتظار (و چشم براه) است، و هرگز تغییر و تبدیلی (در پیمان خود) نیاورده اند
  33,24,تا خدا راستگویان را به (خاطر) صدقشان پاداش دهد، و منافقان را اگر بخواهد عذاب کند، یا توبه ی آنها را بپذیرد، بی تردید خداوند آمرزنده ی مهربان است
  33,25,و (در غزوه ی احزاب) خداوند کافران را با خشم شان (از مدینه) باز گرداند، (در حالی) که هیچ خیر و منفعتی نیافتند، و خداوند مؤمنان را از جنگ بی نیاز کرد، (و پیروزی نصیبشان ساخت) و خداوند توانای پیروزمند است
  33,26,و (خداوند) کسانی از اهل کتاب (= یهود بنی قریظه) را که از آنها (= مشرکان) حمایت کرده بودند؛ از قلعه هایشان فرود آورد، و در دلهایشان وحشت انداخت، (و شما) گروهی را می کشتید و گروهی را اسیر می گرفتید
  33,27,و (خداوند) زمین آنان و خانه هایشان و اموالشان را به شما وا گذاشت و (همچنین) زمینی را که در آن گام ننهاده بودید، و خداوند بر هر چیز تواناست
  33,28,"ای پیامبر ! به همسرانت بگو :«اگر شما زندگی دنیا و زینت آن می خواهید، پس بیایید تا (با هدیه ای مناسب) شما را بهرمند سازم، و شما را به طرز نیکوئی رها کنم"
  33,29,و اگر شما خدا و پیامبرش و سرای آخرت را می خواهید، پس (بدانید که) خداوند برای نیکوکارانتان پاداش عظیمی آماده کرده است»
  33,30,ای زنان پیامبر ! هر کس از شما که (گناه) نا شایست آشکاری مرتکب شود، عذاب او دو چندان افزوده می شود، و این بر خدا آسان است
  33,31,و هر کس از شما برای خدا و پیامبرش خضوع (و فرمانبرداری) کند، و عمل صالح انجام دهد، پاداش او را دوبار به او خواهیم داد، و روزی ارزشمندی برای او آماده کرده ایم
  33,32,ای زنان پیامبر! شما مانند هیچ یک از زنان (عادی دیگر) نیستید، اگر پرهیزگاری کنید؛ پس در سخن گفتن نرمی نکنید که آنگاه کسی که در دلش بیماری است؛ طمع کند، و سخن شایسته بگویید
  33,33,و در خانه های خود بمانید، و به شیوه ی جاهلیت نخستین زینتهای خود را آشکار نکنید، و نماز را بر پا دارید، و زکات را بدهید، و خدا و پیامبرش را اطاعت کنید، خداوند قطعاً می خواهد پلیدی را از شما اهل بیت دور کند و چنانکه باید شما را پاک سازد
  33,34,و آنچه را در خانه هایتان از آیات خداوند و حکمت (= سنت پیامبر) خوانده می شود یاد کنید؛ بی گمان خداوند باریک بین آگاه است
  33,35,همانا مردان مسلمان و زنان مسلمان، مردان مؤمن و زنان مؤمن، مردان فرمانبردار و زنان فرمانبردار، مردان راستگو و زنان راستگو، مردان صابر و زنان صابر، مردان با خشوع و زنان با خشوع، مردان صدقه دهنده و زنان صدقه دهنده، مردان روزه دار و زنان روزه دار، مردانی که شرمگاه خود را حفظ می کنند، و زنانی که شرمگاه خود را حفظ می کنند، و مردانی که خدا را بسیار یاد می کنند، و زنانی که خدا را بسیار یاد می کنند، خداوند برای (همه ی) آنان آمرزش و پاداش عظیمی آماده کرده است
  33,36,و هیچ مرد مؤمن و زن مؤمنی را نرسد ؛هنگامی که خدا و پیامبرش کاری را حکم کند، آنکه آنها در کارشان اختیاری باشد، و هرکس خدا و پیامبرش را نافرمانی کند، به راستی که در گمراهی آشکاری گرفتار شده است
  33,37,"و (به یاد بیاور) زمانی را که به آن کس که خدا به او نعمت داده بود، و تو (نیز) به او نعمت داده بودی، می گفتی :«همسرت را نگاه دار و از خدا بترس» و در دل خود چیزی را پنهان می داشتی که خداوند آن را آشکار می کند، و از مردم می ترسیدی؛ در حالی که خداوند سزاوارتر است که از او بترسی، پس چون زید از او حاجت خویش بگزارد، (و طلاقش داد) او را به ازدواج تو در آوردیم؛ تا بر مؤمنان در (باره ی ازدواج با) زنان پسر خواندگان شان هیچ حرجی نباشد؛ هنگامی که حاجت خویش از او بگزارده (و طلاقشان داده) باشند، و فرمان خدا انجام شدنی است"
  33,38,بر پیامبر در آنچه خدا برای او حلال (و مقرر) کرده است؛ هیچ حرجی نیست، این سنت خداوند است در (باره ی) کسانی که پیش از این بوده اند، و فرمان خداوند حساب شده و دقیق است
  33,39,(همان) کسانی که پیامهای خدا را می رسانند و از او می ترسند و از هیچ کس جز او نمی ترسند، و خداوند برای حسابگری (اعمالشان) کافی است
  33,40,محمد (صلی الله علیه و آله و سلم) پدر هیچ یک از مردان شما نیست، و لیکن رسول خدا و خاتم پیامبران است، و خداوند به هر چیز آگاه است
  33,41,ای کسانی که ایمان آورده اید! خدا را بسیار یاد کنید
  33,42,و صبح و شام او را تسبیح گویید
  33,43,او کسی است که بر شما درود می فرستد، و فرشتگانش (نیز بر شما درود می فرستند) تا شما را از تاریکیها به سوی نور بیرون برد، و (خداوند) نسبت به مؤمنان مهربان است
  33,44,تحیت آنان در روزی که با او دیدار می کنند «سلام» است، و برای آنها پاداش ارزشمندی آماده کرده است
  33,45,ای پیامبر! ما تو را گواه، و بشارت دهنده و بیم دهنده فرستادیم
  33,46,و دعوت کننده به سوی خداوند به فرمان او، و چراغی روشنی بخش قرار دادیم
  33,47,و مؤمنان را بشارت ده که برای آنها از سوی خداوند فضل بزرگی است
  33,48,و از کافران و منافقان اطاعت مکن، و آزارشان را واگذار (و به آنا اعتنای نکن) و بر خدا توکل کن، و خداوند (به عنوان) کارساز(و مدافع) بسنده است
  33,49,ای کسانی که ایمان آورده اید! هنگامی که با زنان با ایمان ازدواج کردید، آنگاه پیش از آن که با آنها همبستری کنید، طلاقشان دادید، پس عدّه ای برای شما بر آنها نیست که شما آن را بشمارید، لذا آنها را (با هدیه ی مناسب) بهرمند سازید و به نیکوترین وجه رهایشان کنید
  33,50,ای پیامبر! ما همسرانت را که مهرشان را پرداخته ای برای تو حلال کردیم، و (نیز) کنیزانی را که (از طریق غنایم جنگی) خدا به تو ارزانی داشته است، و دختران عمویت، و دختران عمه هایت و دختران دایی ات، و دختران خاله هایت که با تو هجرت کرده اند، (ازدواج با آنها برای تو حلال کرده ایم) و (نیز) زن مؤمنی را که اگر خود را به پیامبر ببخشد، اگر پیامبر بخواهد او را به زنی گیرد، (این حکم) ویژه ی توست؛ نه دیگر مؤمنان، به راستی که ما می دانیم آنچه را که بر آنها در (باره ی) همسرانشان و کنیزانشان واجب کرده ایم، تا بر تو هیچ حرجی نباشد، و خداوند آمرزنده ی مهربان است
  33,51,(نوبت) هر یک از همسرانت را که بخواهی (می توانی) به تأخیر اندازی، و هر کدام را بخواهی نزد خود جای دهی، و اگر (بعضی) از آنها که بر کنار ساخته ای بخواهی نزد خود جای دهی، هیچ گناهی بر تو نیست، این (گزینش) برای آن که چشم آنان روشن گردد و این که غمگین نباشند، و همگی شان به آنچه به آنان می دهی خشنود گردند، و خدا آنچه را که در دلهای شماست می داند، و خداوند دانای بردبار است
  33,52,بعد از این، (دیگر) هیچ زنی برای تو حلال نیست، و نه (حلال است) آن که همسران دیگری جای گزین آنها کنی، هر چند زیبایی آنها تو را به شگفت آورد، مگر آنچه که (بصورت کنیز) دست تو مالک شد، و خداوند بر همه چیز نگهبان است
  33,53,ای کسانی که ایمان آورده اید! به خانه های پیامبر داخل نشوید؛ مگر آنکه برای (صرف) غذا به شما اجازه داده شود، بی آنکه منتظر پخته شدنش باشید، ولی چون دعوت شدید، داخل شوید، پس هنگامی که غذا خوردید؛ پراکنده شوید، و (بعد از صرف غذا) برای بحث و گفتگو ننشینید، بی گمان این (عمل) پیامبر را آزار می دهد، پس (او) از شما شرم می کند (و چیزی نمی گوید) و خداوند از (بیان) حق شرم نمی کند، و هنگامی که چیزی (از وسایل زندگی به عاریت) خواستید، پس از آنان (= زنان پیامبر) ازپشت پرده بخواهید، این (کار) برای دلهای شما و دلهای آنان پاکیزه تر است، و شما را نرسد که پیامبر خدا را بیازارید، و نه آن که همسرانش را بعد از او هرگز به همسری گیرید، بی تردید این (کار) نزد خدا (گناهی) بزرگ است
  33,54,اگر چیزی را آشکار کنید یا آن را پنهان دارید، پس بی گمان خداوند به هر چیز آگاه است
  33,55,بر آنان (= زنان) گناهی نیست (که) در (حضور) پدرانشان و پسرانشان و برادرانشان و پسران برادرانشان و پسران خواهرانشان و زنان (هم دین) شان و بردگانشان (بدون حجاب باشند) و (ای زنان!) از خدا بترسید، قطعاً خداوند بر همه چیز گواه است
  33,56,بی گمان خدا و فرشتگانش بر پیامبر درود می فرستند؛ ای کسانی که ایمان آورده اید! بر او درود فرستید، و سلام بگویید، سلامی نیکو
  33,57,همانا کسانی که خدا و پیامبرش را آزار می دهند، خداوند آنها را در دنیا و آخرت لعنت کرده، و برای آنها عذاب خوار کننده ای آماده کرده است
  33,58,و کسانی که مردان مؤمن و زنان مؤمن را بی هیچ گناهی که مرتکب شده باشند؛ آزار می دهند، به راستی (بار) بهتان و گناه آشکاری را به دوش کشیده اند
  33,59,"ای پیامبر ! به همسرانت و دخترانت و زنان مؤمنان بگو :«چادرهای خود را بر خویش فرو افکنند، (و با آن سر و صورت و سینه هایشان را بپوشانند) این مناسب تر است تا شناخته شوند؛ پس مورد آزار قرار نگیرند، و خداوند آمرزنده ی مهربان است"
  33,60,اگر منافقان و کسانی که در دلهایشان بیماری است، و شایعه پراکنان در مدینه (از کار خود) باز نایستند، یقیناً تو را بر (ضد) آنها می شورانیم (و بر آنها مسلط می گردانیم) سپس جز اندکی در کنار تو در آن (شهر مدینه) نباشند
  33,61,طرد شدگانند، هر کجا یافت شوند، گرفته خواهند شد، و به سختی کشته خواهند شد
  33,62,(این)سنت خداوند است در (باره ی) کسانی که پیش از این گذشتند، و هرگز برای سنت خدا دگرگونی نخواهی یافت
  33,63,"(ای پیامبر !) مردم تو را از (زمان قیام) قیامت می پرسند، بگو :«علم آن تنها نزد الله است» و تو چه می دانی شاید که قیامت نزدیک باشد"
  33,64,بی تردید خداوند کافران را لعنت کرده، و برای آنها آتش سوزان آماده کرده است
  33,65,که جاودانه در آن خوهند ماند، هیچ دوست و یاوری نخواهند یافت
  33,66,"روزی که صورتهایشان در آتش (جهنم) گردانیده شود (پشیمان می شوند و) می گویند :«ای کاش خدا را اطاعت کرده بودیم، ورسول (خدا) را اطاعت کرده بودیم»"
  33,67,"و گفتند :« پروردگارا ! ما از سروران و بزرگان خود اطاعت کردیم، پس ما را از راه به در بردند(و گمراه کردند)"
  33,68,پروردگارا ! آنها را از عذاب دو چندان ده، و آنها را به لعنتی بزرگ (و سخت) لعنت فرما»
  33,69,ای کسانی که ایمان آورده اید! مانند کسانی نباشید که موسی را آزار دادند، آنگاه خداوند او را از آنچه (در حق او) گفته بودند؛ مبّرا ساخت، و (او) نزد خداوند آبرومند (و صاحب منزلت) بود
  33,70,ای کسانی که ایمان آورده اید! از خدا بترسید، و سخن درست (و حق) بگویید
  33,71,تا (خداوند) کارهایتان را برای تان اصلاح کند، و گناهان تان را بیامرزد، و هرکس که از خدا و پیامبرش اطاعت کند؛ یقیناً به کامیابی عظیمی نائل شده است
  33,72,همانا ما امانت (خویش) را بر آسمانها و زمین و کوهها عرضه داشتیم، پس آنها از تحمل آن سر باز زدند و از آن ترسیدند، و انسان آن را بر دوش گرفت که او بسیار ستمکار نادان است
  33,73,تا (سرانجام) خداوند مردان منافق و زنان منافق و مردان مشرک و زنان مشرک را عذاب کند، و خداوند توبه ی مردان مؤمن و زنان مؤمن را بپذیرد (و از گناهان شان در گذرد) و خداوند آمرزنده ی مهربان است
  34,1,حمد (و ستایش) مخصوص خدایی است که آنچه در آسمانها و آنچه در زمین است از آن اوست، و ستایش در (سرای) آخرت (نیز) از آن اوست ،و او حکیم آگاه است
  34,2,آنچه را که در زمین فرو می رود و آنچه را که از آن بیرون می آید، و آنچه را که از آسمان نازل می شود و آنچه را که در آن بالا می رود؛ می داند، و او مهربان آمرزنده است
  34,3,"و کسانی که کافر شدند، گفتند :« قیامت به سراغ ما نخواهد آمد» (ای پیامبر!) بگو:«آری، به پروردگارم (آن) دانای غیب سوگند که حتماً به سراغ شما خواهد آمد، به اندازه ی ذره ای در آسمانها و در زمین از او پنهان نیست، و نه کوچکتر از آن و نه بزرگتر، مگر (اینکه) در کتابی آشکار (ثبت) است"
  34,4,تا کسانی را که ایمان آورده اند و کارهای شایسته انجام داده اند؛ پاداش دهد، آنان برای شان مغفرت و روزی ارزشمندی است
  34,5,و کسانی که مبارزه کنان در (انکار) آیات ما تلاش کردند (و گمان کردند که ما را به ستوه می آورند) برای آنان عذابی از کیفر دردناک خواهد بود
  34,6,و کسانی که به ایشان علم داده شده است؛ می دانند آنچه را که از سوی پروردگارت بر تو نازل شده، حق است، و به راه (خداوند) پیروزمند ستوده هدایت می کند
  34,7,"و کسانی که کافر شدند، گفتند :«آیا مردی به شما نشان دهیم که به شما خبر می دهد هنگامی که (مردید و) کاملاً متلاشی (و پراکنده) شدید، همانا شما (بار دیگر) در آفرینش تازه ای خواهید بود؟"
  34,8,آیا بر خدا دروغ بسته یا به او دیوانگی است ؟!» (چنین نیست) بلکه کسانی که به آخرت ایمان نمی آورند در عذاب و گمراهی دور و درازی هستند
  34,9,آیا به آنچه پیش روی و آنچه پشت سر آنان از آسمان و زمین است، نگاه نکرده اند ؟! اگر بخواهیم آنها را در زمین فرو می بریم، یا تکه ای از آسمان را بر (سر) آنان می افکنیم، بی گمان در این نشانه ای برای هر بنده ی بازگشت کننده ای است
  34,10,"و به راستی (ما) به داوود از سوی خود فضیلتی (بزرگ) دادیم، (گفتیم:) ای کوهها و ای پرندگان ! با او (در تسبیح گفتن) هم آواز شوید، و آهن را برای او نرم کردیم"
  34,11,(و به او دستور دادیم) که زره های بلند ( و فراخ) بساز و در بافتن (حلقه ها) اندازه نگه دار، و کار شایسته انجام دهید، همانا من به آنچه انجام می دهید؛ بینا هستم
  34,12,و برای سلیمان باد را (مسخر ساختیم) که صبحگاهان مسیر یک ماه را طی می کرد، و شامگاهان مسیر یک ماه را، و چشمه ی مس (مذاب) را برایش روان ساختیم، و از جن کسانی را (مسخر کردیم) که به فرمان پروردگارش در پیش او کار می کردند، و هر که از آنان که از فرمان ما سرپیچی می کرد، او را از عذاب آتش سوزان می چشاندیم
  34,13,"(سلیمان) هر چه می خواست (جن ها) برایش می ساختند: از (قبیل) معبدها، و تمثالها، و کاسه هایی (غذا خوری) همچون حوضها، و دیگهای ثابت (که از بزرگی قابل حمل و نقل نبود، و به آنها گفتیم:) ای آل داوود! سپاس (این همه نعمت را) به جا آوردید، و اندکی از بندگان من سپاسگزارند"
  34,14,پس چون مرگ را بر او (= سلیمان) مقرر داشتیم، (کسی) آنها را از مرگش آگاه نساخت؛ مگر جنبنده ی زمین (= موریانه) که عصایش را می خورد، پس چون (بر زمین) افتاد، جنیان دریافتند که اگر غیب می دانستند در (آن) عذاب خوار کننده نمی ماندند
  34,15,"همانا برای (قوم) سبا در مساکن شان نشانه ای بود، دو باغ (بزرگ) از راست و چپ، (و به آنها گفتیم:) از روزی پروردگارتان بخورید و برای او شکر گزارید، شهری است پاکیزه، و پروردگاری آمرزنده"
  34,16,پس آنها روی گرداندند، آنگاه سیلی ویرانگر را برآنها فرستادیم، و دو باغ (پر میوه) شان را به دو باغ (بی ارزش) با میوه های تلخ و (درختان) شوره گز و اندکی از (درخت) کنار مبّدل ساختیم
  34,17,این کیفر را به (خاطر) آن که نا سپاسی کردند؛ به آنها دادیم، و آیا جز نا سپاسان را مجازات می کنیم؟
  34,18,"و میان آنها و قریه هایی که برکت داده بودیم، قریه هایی (آباد و) به هم پیوسته (بر سر راه) قرار دادیم، و در (میان) آنها آمدو شد مقرر داشتیم (و به آنان گفتیم:) در این (آبادی)ها با امن (و امان) شبها و روزها سفر کنید"
  34,19,"پس گفتند :«پروردگارا ! میان سفرهای ما دوری بیفکن» و بر خویشتن ستم کردند، پس ما آنها را داستانهایی (برای عبرت دیگران) قرار دادیم، و آنان را سخت پراکنده (و متلاشی) ساختیم، بی گمان در این (ماجرا) برای هر صبر کننده ی سپاسگزاری نشانه هایی است"
  34,20,و یقیناً ابلیس گمان خود را در باره ی آنها درست یافت، پس (همگی) از او پیروی کردند؛ جز گروهی (اندک) از مؤمنان
  34,21,و او (= شیطان) را بر آنان هیچ سلطه ای نبود؛ مگر اینکه (خواستیم) معلوم بداریم کسی را که به آخرت ایمان می آورد، از کسی که او از آن در شک (و تردید) است. و پروردگار تو بر همه چیز نگاهبان است
  34,22,"(ای پیامبر!) بگو :«کسانی را که غیر از خدا (معبود خود) می پندارید، (به فریاد) بخوانید، (آنها) هموزن ذره ای در آسمانها و در زمین مالک نیستند، و در (آفرینش و تدبیر) آن دو هیچ شرکتی ندارند، و او (= خداوند) از میان آنها یاور و پشتیبانی ندارد"
  34,23,"و شفاعت نزد او سود نبخشد؛ مگر برای کسی که (او خود) برایش اجازت داده باشد، تا زمانی که اضطراب (و نگرانی) از دلهایشان بر طرف شود، گویند:«پروردگارتان چه گفت ؟» گویند :«حق را (فرمود)، و او بلند مرتبه ی بزرگ است»"
  34,24,"(ای پیامبر! به مشرکان) بگو :«چه کسی شما را از آسمانها و زمین روزی می دهد؟» (در پاسخ) بگو :«الله، و ما یا شما بر (طریق) هدایت یا در گمراهی آشکار هستیم»"
  34,25,"بگو :«شما از گناهی که ما مرتکب شده ایم ؛ باز خواست نمی شوید، و ما (نیز) از آنچه شما انجام می دهید؛ باز خواست نمی شویم»"
  34,26,"بگو :« پروردگار ما، (همه ی) ما (وشما) را گرد می آورد؛ سپس در میان ما به حق داوری می کند، و او داور داناست»"
  34,27,"بگو :«کسانی را که به عنوان شریک به او ملحق ساخته اید؛ به من نشان دهید، (هرگز) چنین نیست، بلکه او خداوند پیروزمند حکیم است"
  34,28,و (ای پیامبر!) ما تو را برای همه ی مردم؛ جز بشارت دهنده و بیم دهنده نفرستادیم، و لیکن بیشتر مردم نمی دانند
  34,29,"و می گویند :«اگر راستگویید؛ این وعده (ی قیامت) کی خواهد بود ؟!»"
  34,30,"بگو :« میعاد شما روزی خواهد بود که نه ساعتی از آن تأخیر می کنید و نه (بر آن ) پیشی می گیرید»"
  34,31,"و کسانی که کافر شدند، گفتند :« ما هرگز به این قرآن ایمان نمی آوریم و نه به آن (کتابهای) که پیش از آن بوده». (ای پیامبر!) اگر ببینی (در در روزقیامت) هنگامی که ستمکاران در پیشگاه پروردگارشان (برای حسابرسی) نگه داشته شده اند، (از حال آنها به شگفت می آیی) برخی از آنها سخن برخی دیگر را پاسخ می دهند (و هر کدام گناه خود را به گردن دیگری می اندازد) کسانی که به استضعاف کشیده شده اند، به کسانی که استکبار (و سرکشی) نمودند، گویند :«اگر شما نبودید ما قطعاً مؤمن بودیم»"
  34,32,"کسانی که سرکشی (و تکبر) کردند (= مستکبران) به کسانی که به استضعاف کشیده شده اند، (= مستضعفان) گویند:«آیا ما شما را از هدایت باز داشتیم بعد از آن که به سراغ شما آمد ؟! (هرگز) بلکه شما خود مجرم بودید»"
  34,33,"و مستضعفان به مستکبران گویند :« بلکه، مکر و حیله شب و روز شما (سبب شد که از هدایت بازمانیم) هنگامی که به ما دستور می دادید که به خدا کافر شویم و برای او همتایانی قرار دهیم». و هنگامی که عذاب (الهی) را ببینند، پشیمانی (خود) را (در دل) پنهان دارند، و ما غلها در گردنهای کسانی که کافر شدند؛ بگذاریم، آیا جز آنچه عمل می کردند، به آنها جزا داده می شود؟"
  34,34,"ما در هیچ قریه ای هشدار دهنده ای نفرستادیم؛ مگر اینکه متنعّمان آنها (که مست ناز و نعمت و قدرت بودند) گفتند: « بی تردید ما به آنچه فرستاده شده اید؛ کافریم »"
  34,35,"و گفتند :«اموال و اولاد ما (از شما) بیشتر است، (و این دلیل آن است که خدا از ما خشنود است) و ما هرگز مجازات نخواهیم شد»"
  34,36,"(ای پیامبر!) بگو :« بی گمان پروردگارم روزی را برای هر کس که بخواهد فراخ و (یا) تنگ می کند، (و این نشانه ی محبت و رضایت خداوند نیست) و لیکن بیشتر مردم نمی دانند»"
  34,37,و اموالتان و اولادتان چیزی نیستند که شما را نزد ما نزدیک و مقّرب سازند، جز کسانی که ایمان آوردند و عمل صالح انجام دهند، پس اینان پاداش مضاعف در برابر کارهای که انجام داده اند؛ دارند، و آنها در غرفه های (بلند بهشتی) در امن و (امان) هستند»
  34,38,و کسانی که مبارزه کنان در (انکار) آیات ما تلاش کردند (و گمان کردند که ما را به ستوده می آورند) اینان در عذاب احضار می شوند
  34,39,"(ای پیامبر!) بگو :« بی گمان پروردگارم روزی را برای هرکس که بخواهد فراخ می گرداند، و (یا) برای او تنگ (و محدود) می سازد، و هر چیزی را (در راه خدا) انفاق کنید، پس او عوض آن را می دهد، و او بهترین روزی دهندگان است»"
  34,40,"و (به یاد آور) روزی را که (خداوند) همه ی آنان را بر می انگیزد، سپس به فرشتگان می گوید :« آیا اینها شما را پرستش می کردند؟!»"
  34,41,"(فرشتگان) گویند :« تو منزهی! (تنها) تو ولی (و کار ساز) ما هستی، نه آنها، (آنان هرگز ما را پرستش نمی کردند) بلکه جن (و شیاطین) را پرستش می کردند، بیشتر شان به آنها ایمان داشتند»"
  34,42,"پس امروز برخی از شما برای برخی دیگر مالک هیچ سود و زیانی نیست، و به کسانی که ستم (= شرک) کردند، می گوییم :« بچشید عذاب آتشی را که آن را تکذیب می کردید»"
  34,43,"و هنگامی که آیات روشن (و واضع) ما بر آنان خوانده شود، گویند:«این (محمد) جز مردی نیست که می خواهد شما را از آنچه نیاکانتان می پرستیدند؛ باز دارد» و گویند:« این (قرآن) جز دروغ بزرگی که به هم بافته شده نیست ». و کسانی که کافر شدند، هنگامی که حق به سراغ آنها آمد، درباره ی آن گفتند :«این (قرآن) جز سحری آشکار نیست»"
  34,44,و ما (پیش از این) چیزی از کتاب (های آسمانی) را به آنها نداده ایم که آن را بخوانند (و بر اساس آن تو را تکذیب کنند) و پیش از تو هیچ هشدار دهنده ای به سوی آنها نفرستادیم
  34,45,و کسانی که پیش از آنها بودند (نیز پیامبران ما را) تکذیب کردند، در حالی که اینها به یک دهم آنچه به آنها داده بودیم؛ نرسیده اند، آنگاه آنها پیامبران مرا تکذیب کردند، (بنگر) مجازات من چگونه بود ؟
  34,46,"(ای پیامبر!) بگو :«همانا من شما را به یک (خصلت) اندرز می دهم، که : دو نفر دو نفر یا یک نفر یک نفر برای خدا بر خیزید، سپس بیندیشید که این همنشین شما (= محمد صلی الله علیه وآله وسلم ) هیچ گونه دیوانگی ای ندارد، او برای شما جز هشدار دهنده ای پیشاپیش عذاب شدید نیست»"
  34,47,"(ای پیامبر!) بگو :«هر مزدی که از شما خواسته ام؛ پس آن برای خود شما باد، پاداش من تنها بر (عهده ی) خداوند است، و او بر همه چیز گواه است»"
  34,48,"(ای پیامبر!)بگو :« بی گمان پروردگارم حق را (بر قلب پیامبران خود) می افکند، (آن پروردگاری که) دانای غیبهاست»"
  34,49,"(ای پیامبر!) بگو :«حق آمد، و (معبودان) باطل نه (آفرینش را) آغاز می کند، و نه (دوباره) باز می گرداند»"
  34,50,"(ای پیامبر!) بگو :«اگر من گمراه شوم، تنها بر زیان خودم گمراه می شوم، و اگر هدایت یابم، پس به (خاطر) آن چیزی است که پروردگارم به من وحی می کند، یقیناً او شنوای نزدیک است»"
  34,51,و (ای پیامبر!) اگر ببینی هنگامی که مضطرب (و نگران) شوند، آنگاه رهایی (از عذاب) نباشد، و از جای نزدیکی گرفته شوند (تعجب خواهی کرد)
  34,52,"و(در آن حال) گویند:« به آن (قرآن) ایمان آوردیم» ولی چگونه می توانند از فاصله ی دور به آن دست یابند؟"
  34,53,در حالی که آنها پیش از این (در دنیا) به آن کافر شدند، و از جای دور نادیده (و بدون آگاهی، نسبتهای ناروایی می داند و تیری) می افکندند
  34,54,و میان آنها و آنچه می خواستند جدایی افکنده شد، همان گونه که از پیش با امثال آنها انجام شد، بی گمان آنها سخت در شک (و تردید) بودند
  35,1,حمد (و ستایش) مخصوص خداوند است، آفرینند ه ی آسمانها و زمین، (کسی) که فرشتگان را رسولانی قرار داد؛ دارای بالهای دوگانه و سه گانه و چهارگانه، هر چه بخواهد در آفرینش می افزاید، بی گمان خداوند بر هر چیزی تواناست
  35,2,(هر) رحمتی را که خدا برای مردم بگشاید، کسی نمی تواند که بازش دارد، وآنچه را باز دارد کسی جز او نمی تواند آن را روان سازد، و او پیروزمند حکیم است
  35,3,ای مردم! نعمت خدا را بر خود به یاد آورید، آیا آفریننده ای جز الله هست که شما را از آسمان و زمین روزی دهد؟! هیچ معبودی جز او نیست، پس چگونه (از حق) منحرف می شوید ؟
  35,4,و اگر تو را تکذیب کنند (غمگین نباش) همانا پیامبران پیش از تو (نیز) تکذیب شدند، و (همه ی) کارها به سوی خدا باز گردانده می شود
  35,5,ای مردم! یقیناً و عده ی خدا حق است، پس زندگی دنیا شما را نفریبد، و (شیطان) فریبکار شما را نسبت به خدا نفریبد
  35,6,مسلماَ شیطان دشمن شماست، پس او را دشمن گیرید، او فقط پیروانش دعوت می کند تا (همه) از اهل آتش سوزان (جهنم) باشند
  35,7,کسانی که کافر شدند، بر ای آنان عذابی سخت است، و کسانی که ایمان آوردند و کارهای شایسته انجام دادند، برای شان آمرزش و پاداش بزرگی است
  35,8,آیا کسی که کردار بدش برای او آراسته شده، پس آن را نیک (و زیبا) می بیند (همانند کسی است که چنین نیست؟) پس بی گمان خداوند هر کس را که بخواهد گمراه می سازد و هر کس را که بخواهد هدایت می کند، پس نباید که جانت به خاطر شدت تأسف (و حسرت) بر آنان از بین برود، بی شک خداوند به آنچه انجام می دهند؛ داناست
  35,9,و الله کسی است که بادها را فرستاد، آنگاه (آن بادها) ابرها را بر می انگیزند، پس آن (ابرها) را به سوی سرزمین مرده راندیم، آنگاه بوسیله ی آن زمین را بعد از مردنش زنده کردیم، بر انگیختن (مردگان از گورها نیز) چنین است
  35,10,کسی که خواهان عزت است، پس (بداند که) عزت همگی از آن خداست، سخن پاکیزه به سوی او بالا می رود، و (خداوند) عمل صالح را بالا می برد، و کسانی که (نقشه و) نیرنگهای بد می کشند، بر ای آنها عذاب سختی است، و نیرنگ (و نقشه های بد) آنها نابود می شود
  35,11,و خداوند شما را از خاک، سپس از نطفه آفرید، آنگاه شما را جفتهای یکدیگر قرار داد، و هیچ ماده ای باردار نمی شود، و نمی زاید؛ مگربه علم او،وهیچ سالخورده ای عمر طولانی نمی کند، و (یا) از عمرش کاسته نمی شود؛ مگر آنکه در کتاب (لوح محفوظ ثبت) است، بی گمان این (کارها) بر خدا آسان است
  35,12,"و (آن) دو دریا یکسان نیستند: این یکی (آبش) شیرین گوارا است که نوشیدنش خوشگوار است، وآن یکی شور تلخ است، و از هر دو گوشتی تازه می خورید، و (از آنها) چیزهایی زینتی بیرون می آورید که می پوشید، و کشتی را در آن (دریا) می بینی که (آبها را) می شکافد (و به سوی مقصد خویش پیش می رود) تا از فضل خدا (روزی) بجویید، و شاید که سپاسگزارید"
  35,13,(او) شب را در روز داخل می کند و روز را در شب داخل می گرداند، و خورشید و ماه را مسخر کرده که هر یک تا زمانی معین در حرکت است، این است الله پروردگار شما، فرمانروایی از آن اوست، و کسانی را که به جای او می خوانید (هموزن) پوست نازک هسته ی خرما مالک نیستند
  35,14,اگر آنها را بخوانید (صدای) خواندن شما را نمی شنوند، و (به فرض) اگر بشنوند به شما پاسخ نمی گویند، و روز قیامت شرک شما را انکار می کنند، و هیچ کس مانند (خداوند) آگاه خبر دارت نمی کند
  35,15,ای مردم ! شما (همگی) به خدا نیازمندید، و (تنها) خداوند است که بی نیاز ستوده است
  35,16,اگر بخواهد شما را (از بین) می برد، و آفرینش تازه ای می آورد
  35,17,و این (کار) بر خداوند دشوار نیست
  35,18,و هیچ کس بار (گناه) دیگری را به دوش نمی کشد، و اگر (شخص) گرانباری (دیگری را) برای حمل بار (گناه) خود بخواند، چیزی از آن (بار) برداشته نمی شود، هر چند خویشاوند (نزدیک او) باشد. تو (ای پیامبر!) تنها کسانی را هشدار می دهی که از پروردگارشان در پنهانی می ترسند، و نماز را بر پا می دارند، و هر کس پاک گردد (و تقوا پیشه کند) پس (بداند که) تنها به سود خویش پاک شده است، و باز گشت (همه) به سوی خداست
  35,19,و نابینا و بینا (هرگز) برابر نیستند
  35,20,و نه تاریکیها و نور،
  35,21,و نه سایه و باد سوزان
  35,22,و (هرگز) زندگان و مرد گان یکسان نیستند، بی گمان خداوند هر کس را بخواهد می شنواند، و تو (ای پیامبر!) نمی توانی (سخنت را) به در گور خفتگان بشنوانی
  35,23,تو جز هشدار دهنده ای نیستی،
  35,24,یقیناً ما تو را به حق بشارت دهنده و هشداردهنده فرستادیم، و هیچ امتی نیست؛ مگر آن که در (میان) آن هشدار دهنده ای (آمده و) گذشته است
  35,25,و اگر تو را تکذیب کنند، (چیز تازه ای نیست) همانا کسانی که پیش از آنان بودند (نیز پیامبران خود را) تکذیب کردند، پیامبران شان با دلایل روشن و نوشته ها (ی مشتمل بر پند و موعظه) و کتاب روشنگر به سراغ آنها آمدند
  35,26,سپس کسانی که کفر ورزیدند؛ فرو گرفتم، پس (بنگر) مجازات من چگونه بود ؟
  35,27,آیا ندیدی همانا خداوند از آسمان آبی نازل کرد که بوسیله ی آن میوه هایی با رنگهای گوناگون (از زمین) بیرون آوردیم، و از کوهها (نیز) راههای (به رنگ) سفید و سرخ رنگارنگ و به غایت سیاه (پدید آوردیم)
  35,28,و همچنین از مردم و جنبندگان و چهارپایان با رنگهای مختلف (پدید آوردیم)، جز این نیست که از میان بندگان خدا دانایان از او می ترسند، بی تردید خداوند پیروزمند آمرزنده است
  35,29,بی گمان کسانی که کلام خدا را تلاوت می کنند و نماز را بر پا می دارند، و از آنچه روزی شان داده ایم؛ پنهان و آشکار انفاق می کنند، به تجارتی (پر سود) که هرگز زیان (و کساد) ندارد؛ امید دارند
  35,30,تا (خداوند) پاداش آنها را به تمامی بدهد و از فضل خود بر آنها بیفزاید، بی گمان او آمرزنده ی سپاسگزار است
  35,31,و (ای پیامبر!) آنچه از (این) کتاب به تو وحی کردیم؛ حق است که تصدیق کننده ی آنچه پیش از آن است، یقیناً خداوند به (حال) بندگانش آگاه بیناست
  35,32,سپس (این) کتاب را به کسانی از بندگان مان که بر گزیده بودیم؛ به میراث دادیم، پس (برخی) از آنان بر خود ستم کردند و (برخی) از آنان میانه رو بودند، و (برخی) از آنان به فرمان خدا در نیکیها پیشتازند، این همان فضل (و بخشایش) بزرگی است
  35,33,(پاداش آنها) باغهای جاویدان (بهشتی) است که به آن وارد می شوند، در آنجا به دستبندهای از طلا و مروارید آراسته می گردند، و لباسهایشان در آنجا حریر است
  35,34,"و گویند :«حمد (و ستایش) مخصوص خداوند است که اندوه را از ما دور کرد، یقیناً پروردگار ما آمرزنده ی سپاسگزار است"
  35,35,(همان) کسی که از فضل خویش ما را در این سرای اقامت (جاویدان) جای داد که در آنجا هیچ رنجی به ما نمی رسد ،و در آنجا هیچ خستگی (و واماندگی) به ما نمی رسد
  35,36,و کسانی که کافر شدند؛ برای آنها آتش جهنم است، نه فرمان (مرگ) بر آن صادر شود تا بمیرند (و راحت گردند) و نه چیزی از عذابش از آنها کاسته شود، این گونه هر نا سپاسی را کیفر می دهیم
  35,37,"و آنها در آن (آتش) فریاد می زنند :«پروردگارا ! ما را بیرون آر تا عمل صالحی انجام دهیم؛ غیر از آنچه انجام می دادیم» (در پاسخ آنان می فرماییم :) آیا آن قدر شما را عمر ندادیم که پند گیرندگان در آن پند گیرند ؟! و هشدار دهنده (نیز) به سراغ شما آمد ؟! پس (طعم عذاب را ) بچشید که برای ستمکاران هیچ یاوری نیست"
  35,38,بی گمان خداوند دانای نهان آسمانها و زمین است و همانا او به آنچه در درون سینه هاست؛ دانا است
  35,39,او کسی است که شما را در زمین جانشینان (پیشینیان) قرار داد، پس هر کس که کافر شود، او به زیان خودش خواهد بود، و کافران را کفرشان جز خشم (و دشمنی) در نزد پروردگارشان (چیزی) نمی افزاید، و (نیز) کافران را کفرشان جز زیان (چیزی) نمی افزاید
  35,40,"(ای پیامبر!) بگو:«آیا معبودانتان که به جای خدا می خوانید؛ دیده اید؟ به من نشان دهید چه چیزی از زمین را آفریده اند؟ یا اینکه در (آفرینش) آسمانها شرکتی دارند؟ یا به آنها کتابی داده ایم که آنها دلیلی از آن (برای شرک خود) دارند ؟» (نه هیچ یک از اینها نیست) بلکه ستمکاران جز فریب به یکدیگر وعده ای نمی دهند"
  35,41,بی تردید خداوند آسمانها و زمین را نگه می دارد از آن که (از نظام خود) منحرف شوند، و اگر منحرف گردند، کسی جز او نمی تواند آنها را نگه دارد، بی گمان او بردبار آمرزنده است
  35,42,و (کفار قریش) با محکمترین سوگند های شان (و با نهایت تأکید) به خدا سوگند یاد کردند که اگر هشدار دهنده ای برای آنان بیاید، از هدایت یافته ترین امتها خواهند بود، پس چون (پیامبر) هشدار دهند ه ای بر آنان آمد، جز (فرار و) نفرت (از حق چیزی) بر آنان نیفزود
  35,43,(اینها) بخاطر استکبار در زمین و نیرنگهای بد (شان) بود، و نیرنگهای بد جز دامنگیر صاحبانش نمی گردد، آنگاه آیا آنان (چیزی) جز سنت (و شیوه خدا با) پیشینیان را انتظار دارند؟! پس هر گز برای سنت (و شیوه ی) خداوند دگرگونی نمی یابی
  35,44,آیا (آنها) در زمین نگشته اند؛ تا ببینند عاقبت کسانی که پیش از آنها بودند؛ چگونه بود ؟! در حالی که آنان از اینان نیرومند تر بودند، و هیچ چیزی در آسمانها و زمین نیست که خدا را ناتوان سازد (و از حوزه ی قدرت او بیرون رود) بی گمان او دانای تواناست
  35,45,و اگر خداوند مردم را به (سبب) آنچه که انجام داده اند؛ مجازات کند، هیچ جنبنده ای را بر روی آن (= زمین) باقی نخواهد گذاشت، ولیکن آنها را تا زمانی معین به تأخیر می اندازد، پس هنگامی که اجل آنها فرا رسد، یقیناً خداوند به بندگانش بیناست
  36,1,یس (یا.سین)
  36,2,سوگند به قرآن حکیم
  36,3,که تو قطعاً از پیامبران (ما) هستی
  36,4,بر راه راست (قرار داری)
  36,5,(این قرآن) فرو فرستاده ی (خداوند) پیروزمند مهربان (است)
  36,6,تا گروهی را هشدار دهی که نیاکانشان هشدار نیافته اند، پس آنان غافلند
  36,7,به راستی فرمان (الهی) بر بیشتر آنان تحقق یافته است، پس آنان ایمان نمی آورند
  36,8,بی گمان ما در گردنهای آنان غلهایی قرار دادیم پس آن (غلها) تا چانه ها است، لذا سرهایشان را بالا نگاه داشته است
  36,9,و پیش روی آنان سدی (= دیواری) و از پشت سرشان (نیز) سدی قراردادیم، آنگاه (دیدگان) آنان را پوشاندیم، لذا آنان نمی بینند
  36,10,و (ای پیامبر) بر آنان یکسان است، چه آنها را هشدار دهی و یا هشدارشان ندهی، ایمان نمی آورند
  36,11,(ای پیامبر) تو تنها کسی را هشدار می دهی که از (این) پند پیروی کند، و در نهان از (خدای) رحمان بترسد، پس او را به آمرزش و پاداشی گرامی بشارت ده
  36,12,یقیناً ماییم که مردگان را زنده می کنیم، و آنچه را (از اعمال نیک و بد) که از پیش فرستاده اند، و آثار (و گامهای) شان را می نویسیم، و همه چیز را در کتاب روشنگر (لوح محفوظ) شمار کرده ایم
  36,13,و (ای پیامبر) برای آنها مثال (و داستان) مردم آن قریه (انطاکیه) را بزن، چون رسولان (ما) بدان جا آمدند
  36,14,"آنگاه که دو نفر (از رسولان) را به سوی آنها فرستادیم، پس آنان را تکذیب کردند، سپس با (فرستادن) سومی (آن دو را) تقویت کردیم، پس گفتند: «همانا ما به سوی شما فرستاده شده ایم»"
  36,15,"(آنها در پاسخ) گفتند: شما جز بشری همانند ما نیستید، و (خداوند) رحمان چیزی را نازل نکرده است، شما فقط دروغ می گویید"
  36,16,"(پیامبران) گفتند:« پروردگار ما می داند که ما قطعاً به سوی شما فرستاده شده ایم"
  36,17,و بر (عهده ی) ما جز رساندن (پیام) آشکار نیست»
  36,18,"(آنها) گفتند: «بی گمان ما شما را به فال بد گرفته ایم، اگر دست بر ندارید البته سنگسارتان خواهیم کرد، و ازسوی ما عذاب (و شکنجه) دردناکی به شما خواهد رسید»"
  36,19,"(پیامبران) گفتند:« شومی (و فال بد) تان با خود شماست، اگر به شما پند داده شود (چنین می گویید، و به فال بد می گیرید؟!) بلکه (حقیقت این است که) شما مردمی اسرافکار هستید»"
  36,20,"و مرد (مؤمنی) از دورترین نقطه شهر شتابان آمد، (و خطاب به مردم) گفت: «ای قوم من! پیامبران (خدا) را پیروی کنید"
  36,21,کسانی را پیروی کنید که از شما مزدی طلب نمی کنند، و خودشان هدایت یافته اند
  36,22,و چه شده است مرا که پرستش نکنم کسی را که مرا آفریده است، (همه) به سوی او باز گردانده می شوید؟
  36,23,آیا غیر از او معبودهایی را بر گزینم که اگر (خداوند) رحمان بخواهد به من زیانی برساند، شفاعت آنها چیزی را از من دفع نمی کند (و کمترین فایده ای برایم ندارد) و مرا نجات نخواهند داد؟
  36,24,(اگر چنین کنم) یقیناً آنگاه من در گمراهی آشکاری خواهم بود
  36,25,من به پروردگارتان ایمان آورده ام، پس (سخنان) مرا بشنوید
  36,26,"(پس او را شهید کردند) به او گفته شد: «وارد بهشت شو» گفت: ای کاش قوم من می دانستند( )،"
  36,27,که پروردگارم مرا آمرزیده و از گرامی شدگان قرار داده است
  36,28,و بعد از او بر قومش هیچ لشکری از آسمان فرو نفرستادیم و ما فرو فرستنده نبودیم
  36,29,(بلکه کیفر آنها) جز یک بانگ مرگبار نبود، پس ناگاه همه خاموش(=هلاك) شدند
  36,30,ای افسوس بر (این) بندگان، هیچ پیامبری به سوی آنها نمی آمد مگر اینکه او را استهزاء می کردند
  36,31,آیا ندیدند که پیش از آنها چه بسیار نسلها را نابود کردیم، که آنها هرگز به سوی ایشان باز نمی گردند؟
  36,32,و همه آنها (برای حساب) نزد ما جمع و احضار می شوند
  36,33,و زمین مرده برای شان نشانه (و عبرتی) است که ما آن را زنده گردانیدیم، و دانه ای (غذایی) که از آن می خورند، بیرون آوردیم
  36,34,و در آن باغهایی از نخلها و انگورها قرار دادیم، و در آن چشمه های جاری ساختیم
  36,35,تا از میوه ی آن بخورند در حالی که دست آنان (در تولید آنها) هیچ دخالتی نداشته است( )، آیا سپاس نمی گویند
  36,36,منزه است کسی که همه ی جفتها را آفرید، از آنچه زمین می رویاند، و از (جنس) خودشان، و از آنچه نمی دانند
  36,37,و شب (نیز) برای آنها نشانه (و عبرتی) است ما روز را از آن بر می کشیم، پس آنگاه همه در تاریکی فرو می روند
  36,38,و خورشید(نیز که) پیوسته به سوی قرار گاهش( ) در حرکت است، این تقدیر (خداوند) پیروزمند داناست
  36,39,و برای ماه منزلگاههای مقدر کرده ایم، تا چون شاخه ی (خشک و) کهنه خرما باز گردد
  36,40,نه خورشید را سزد که به ماه رسد، و نه شب بر روز پیشی می گیرد، و هر یک در مدار خود شناورند
  36,41,نشانه ای (دیگر) برای آنان این است که فرزندانشان را بر کشتی( ) پر بار سوار کردیم
  36,42,و(مرکبهای دیگری) همانند آن برای آنها آفریدیم، که سوار می شوند
  36,43,و اگر بخواهیم آنها را غرق می کنیم، پس آنها را هیچ فریاد رسی نباشد، نه آنها رهایی یابند
  36,44,مگر اینکه رحمتی از سوی ما (شامل حال آنها شود) و تا زمان معینی (از دنیا) بهره بگیرند
  36,45,"و هنگامی که به آنها گفته شود: «از آنچه پیش روی شماست، و از آنچه پشت سر شماست، بترسید، شاید مورد رحمت قرار گیرید» (اعراض می کننند)"
  36,46,و هیچ آیه ای از آیات پروردگارشان برای آنها نیاید مگر آنان از آن روی بگردانند
  36,47,"و هنگامی که به آنها گفته شود: از آنچه خدا به شما روزی داده است، انفاق کنید، کسانی که کافر شدند، به کسانی که ایمان آوردند می گویند: آیا ما کسی را طعام بدهیم که اگر خداوند می خواست، (خود) به او طعام می داد و شما جز در گمراهی آشکار نیستید"
  36,48,"و می گویند: « اگر راست می گویید، این وعده (عذاب) کی خواهد بود؟!»"
  36,49,آنها جز انتظار یک بانگ مرگبار نمی کشند، که آنها را فرو گیرد در حالی که سر گرم جدال (و دشمنی) هستند
  36,50,پس (در آن وقت) نمی توانند وصیتی کنند، و نه به سوی خانواده ی خود باز گردند
  36,51,و (چون بار دیگر) در صور دمیده شود( )، پس ناگهان آنها از قبرها (بیرون آیند) شتابان به سوی پروردگارشان می روند
  36,52,"گویند:« وای بر ما چه کسی ما را از خوابگاهمان بر انگیخت؟!» (به آنها گفته شود:) این همان است که (خداوند) رحمان وعده داده بود، و پیامبران (خدا) راست گفتند"
  36,53,(آن) جز یک بانگ مرگبار نخواهد بود، پس ناگهان همه نزد ما جمع و احضار می شوند
  36,54,پس امروز به هیچ کس ذره ای ستم نخواهند شد، و جز به آنچه عمل می کردید، جزا داده نمی شوید
  36,55,بی گمان اهل بهشت امروز در کاری (لذت بخش) مشغولند (و) شادمان هستند
  36,56,آنها و همسرانشان در سایه هایی (گسترده بهشتی) بر تختها تکیه زده اند
  36,57,برای آنها در آن (= بهشت، انواع) میوه است، و هر چه که بخواهند برایشان (فراهم) است
  36,58,(به آنها گفته می شود) سلام (بر شما باد) این سخنی است از جانب پروردگار مهربان
  36,59,ای گنهکاران امروز(از نیکان) جدا شوید
  36,60,ای فرزندان آدم! آیا با شما پیمان نبستم که شیطان را نپرستید، که او برای شما دشمن آشکار است؟
  36,61,و اینکه مرا بپرستید، این راه مستقیم است
  36,62,و به راستی او گروه زیادی از شما را گمراه ساخت آیا اندیشه نکردید؟
  36,63,این (همان) جهنمی است که به شما وعده داده می شد
  36,64,امروز به سزای کفری که ورزیده اید به آن در آیید
  36,65,امروز بر دهانهایشان مهر می نهیم، و دستهایشان با ما سخن می گویند، و پاهایشان به آنچه می کردند گواهی می دهند
  36,66,و اگر بخواهیم چشمانشان را محو (ونابود) می کنیم، پس شتابان آهنگ راه می کنند، اما چگونه می توانند ببینند؟
  36,67,و اگر بخواهیم آنها را در جایگاهشان مسخ(ومیخ کوب) می کنیم، پس نتوانند که به پیش قدم بر دارند، و نه به عقب باز گردند
  36,68,و هر کس را طول عمر دهیم، در آفرینش دگرگونش کنیم، (و به حالت ناتوانی کودکی بر می گردانیم) آیا اندیشه نمی کنند؟
  36,69,ما (هرگز) شعر به او (= رسول) نیاموخته ایم و شایسته او نیست، این (کتاب چیزی) جز اندرز، و قرآنی روشنگر نیست
  36,70,تا هر کس را که زنده (دل) باشد، بیم دهد و سخن حق بر کافران ثابت شود
  36,71,آیا ندیدند که ما برای آنها از آنچه ساخته ی دست های ماست، چهار پایانی را آفریده ایم، پس آنان مالک آن هستند
  36,72,و آنها را برایشان رام کردیم، پس بر بعضی سوار می شوند، و از (گوشت) بعضی می خورند
  36,73,و برای آنها بهره های دیگر، و نوشیدنیها در آن (حیوانات) است، آیا سپاس نمی گویند؟
  36,74,و آنها غیر از خدا معبودانی (برای خود) بر گزیدند، (به این امید) شاید که یاری شوند
  36,75,آنها قادر به یاری ایشان نیستند، و آنان (= مشرکان) اینها (= معبودان) لشکری احضار شده (و آماده) هستند
  36,76,پس (ای پیامبر) سخن آنان تو را غمگین نسازد، بی گمان ما آنچه را که پنهان می دارند و آنچه را که آشکار می کنند، می دانیم
  36,77,آیا انسان ندیده است که ما او را از نطفه ای آفریده ایم، پس او ستیزه جویی آشکار شده است
  36,78,"و برای ما مثلی زد، و آفرینش خود را فراموش کرد، گفت:« چه کسی (این) استخوانها را (دوباره) زنده می کند در حالی که پوسیده است؟!»"
  36,79,"بگو:« (همان) کسی آن را زنده می کند که نخستین بار آن را پدید آورد، و او به هر آفرینشی داناست،"
  36,80,(همان) کسی که از درخت سبز برای شما آتش پدید آورد، پس آنگاه شما از آن (آتش) می افروزید»
  36,81,آیا کسی که آسمانها و زمین را آفریده است، نمی تواند همانند آنها (= انسانها) را بیافریند؟! آری (می تواند) و او آفریننده ی داناست
  36,82,"جز این نیست که فرمان او، چون چیزی را اراده کند، (این است) که به آن می گوید: «موجود شو» پس (بی درنگ) موجود می شود"
  36,83,پس منزه است، کسی که پادشاهی همه چیز در دست اوست، و (همه) به سوی او باز گردانده می شوید