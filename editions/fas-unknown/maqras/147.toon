quran[51]{c,v,t}:
  26,1,طسم (طا. سین. میم)
  26,2,این آیات کتاب روشن است
  26,3,گویی می خواهی از (شدت غم واندوه) این که آنها ایمان نمی آورند؛ خود را هلاک کنی
  26,4,اگر بخواهیم از آسمان بر آنها نشانه ای نازل می کنیم که گردنهایشان در برابر آن تسلیم (و خاضع) گردد
  26,5,و هیچ پند تازه ای از سوی (خداوند) رحمان برای آنها نمی آید؛ مگر این که از آن روی گردان هستند
  26,6,به راستی آنها تکذیب کردند، پس به زودی اخبار آنچه را که به آن استهزاء (و تمسخر) می کردند؛ به آنها خواهد رسید
  26,7,آیا به زمین ننگریسته اند که چه قدر از هر گونه گیاهان (نیکو و) پر ارزش در آن رویانده ایم ؟
  26,8,بی گمان در این نشانه ی (بزرگی) است، و بیشتر آنها مؤمن نیستند
  26,9,و به راستی پروردگارتو پیروزمند مهربان است
  26,10,و (به یاد بیاور) هنگامی را که پروردگارت موسی را ندا داد که به سوی قوم ستمکار برو،
  26,11,قوم فرعون، آیا آنها نمی ترسند ؟
  26,12,"(موسی) گفت :« پروردگارا ! من می ترسم که مرا تکذیب کنند"
  26,13,و سینه ام تنگ گردد و زبانم باز نشود، پس (برادرم) هارون را (نیز) رسالت ده (تا مرا یاری کند)
  26,14,و آنها بر (گردن) من (ادعای) گناهی دارند، پس می ترسم که مرا بکشند»
  26,15,"(خداوند) فرمود:«چنین نیست، پس شما هر دو با آیات ما بروید، یقیناً ما با شما شنوندگان هستیم"
  26,16,"پس (به نزد) فرعون بروید، و بگویید:«ما فرستاده ی پروردگار جهانیان هستیم،"
  26,17,که بنی اسرائیل را با ما بفرست»
  26,18,"(فرعون) گفت : «آیا ما تو را در کوکی نزد خود پرورش ندادیم، و سالهایی از عمرت را در میان ما نگذراندی؟"
  26,19,و (بالآخره) آن کارت را (که نبایست انجام می دادی) انجام دادی، و تو از ناسپاسانی»
  26,20,"(موسی) گفت : «(من) آن (کار) را آنگاه انجام دادم که من از بی خبران بودم"
  26,21,پس چون از شما ترسیدم از شما فرار کردم، آنگاه پروردگارم به من دانش (و نبوت) بخشید و مرا از پیامبران قرار داد
  26,22,و آیا این نعمتی است که تو بر من منت می گذاری که بنی اسرائیل را برده ی خود ساخته ای؟!»
  26,23,"فرعون گفت :«پروردگار جهانیان چیست؟!»"
  26,24,"(موسی) گفت :« پروردگار آسمانها و زمین و آنچه میان آن دو است، اگر اهل یقین هستید»"
  26,25,"(فرعون) به آنهای که در اطرافش بودند؛ گفت :«آیا نمی شنوید ؟»"
  26,26,"(موسی) گفت :«( او) پروردگار شما و پروردگار نیاکان پیشین شماست"
  26,27,"(فرعون) گفت :« بی تردید پیامبرتان که به سوی شما فرستاده شده دیوانه است»"
  26,28,"(موسی) گفت :«(او) پروردگار مشرق و مغرب و آنچه میان آن دو است، اگر بیندیشید»"
  26,29,"(فرعون) گفت :«اگر معبودی جز من برگزینی، البته تو را از زندانیان قرار خواهم داد»"
  26,30,"(موسی) گفت :« حتی اگر معجزه ای روشنی برای تو آورده باشم ؟!»"
  26,31,"(فرعون) گفت :« پس اگر از راستگویانی، آن را بیاور»"
  26,32,پس (موسی) عصای خود را افکند، که ناگهان آن اژدهایی آشکار شد
  26,33,و دست خود را (در گریبان فرو برد و) بیرون آورد که ناگهان در برابر بینندگان سفید (و روشن) بود
  26,34,"(فرعون) به اشرافی که اطراف او بودند؛ گفت :« بی گمان این (مرد) جادوگر دانایی است"
  26,35,(او) می خواهد با سحرش شما را از سرزمینتان بیرون کند، پس شما چه نظر می دهید ؟!»
  26,36,"گفتند :«(کار) او و برادرش را به تأخیر انداز، و جمع آوری کنندگان را در (همه ی) شهرها بفرست»"
  26,37,تا هر جادوگر ماهر (و) دانایی را نزد تو آورند»
  26,38,پس (سرانجام) جادوگران برای وعده گاه روز معینی گرد آورده شدند
  26,39,"و به مردم گفته شد :«آیا شما (نیز) جمع می شوید،"
  26,40,تا اگر ساحران پیروز شدند، ما از آنها پیروی کنیم؟!»
  26,41,"پس هنگامی که ساحران آمدند، به فرعون گفتند : «اگر ما پیروز شویم، آیا ما پاداشی خواهیم داشت ؟!»"
  26,42,"گفت :«آری، و بی گمان آنگاه شما از مقربان خواهید بود»"
  26,43,"موسی به آنها گفت :«هر چه می خواهید بیفکنید، بیفکنید»"
  26,44,"پس آنها ریسمانها و عصاهای خود را افکندند، و گفتند:« به عزت فرعون، قطعاً ما پیروزیم»"
  26,45,پس موسی عصایش را افکند، ناگهان آنچه را به دروغ بر ساخته بودند، بلعید
  26,46,پس ساحران سجده کنان (به زمین) افتادند
  26,47,"گفتند :« ما به پروردگار جهانیان ایمان آوردیم،"
  26,48,پروردگار موسی و هارون»
  26,49,"(فرعون) گفت:«آیا پیش از آن که به شما اجازه دهم به او ایمان آوردید ؟! مسلماً او بزرگتر شماست که سحر را به شما یاد داده است، پس به زودی خواهید دانست ! دستانتان و پاهایتان را به عکس یکدیگر قطع می کنم، و همه ی شما را به دار می آویزم»"
  26,50,"گفتند :« با کی نیست، ما به سوی پروردگار مان باز می گردیم"
  26,51,ما امیدواریم که پروردگارمان خطاهای ما را ببخشد، که ما از نخستین ایمان آورندگان بودیم»