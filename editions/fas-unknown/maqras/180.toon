quran[62]{c,v,t}:
  37,83,و همانا ابراهیم از پیروان او بود
  37,84,چون با قلب سلیم (خالی از شرک و شک و شهوت) به پیشگاه پروردگارش آمد
  37,85,"چون به پدر وقومش گفت:« چه چیزی را می پرستید؟"
  37,86,آیا به جای خدا، معبودهای دروغین می خواهید؟
  37,87,پس شما نسبت به پروردگار جهانیان چه گمان می برید؟!»
  37,88,پس (ابراهیم) یک نگاه به ستارگان نگریست
  37,89,"آنگاه گفت: « من بیمارم (و با شما به جشن نمی آیم)»"
  37,90,پس آنها پشت کنان از او دور شدند (و رفتند)
  37,91,"آنگاه پنهانی نزد معبودانشان رفت و گفت:« آیا (چیزی) نمی خورید؟"
  37,92,شما را چه شده است که سخن نمی گویید»
  37,93,پس به سوی آنان روی آورد (و) ضربه ای محکم (با دست راست) بر آنها زد (و بجز بت بزرگ همه بتها را درهم شکست)
  37,94,پس آنها (= قومش) شتابان به سوی او روی آوردند
  37,95,"(ابراهیم) گفت: «آیا چیزی را می پرستید که خود تراشیده اید؟"
  37,96,در حالی که خداوند شما را و آنچه را که انجام می دهید (و می سازید) آفریده است؟!»
  37,97,"(بت پرستان) گفتند:« بنای (بلندی) برایش بسازید، و او را در (خرمن) آتش بیفکنید»"
  37,98,پس آنها در حق او نیرنگ و مکر ورزیدند و ما آنها را (مغلوب و) پست ساختیم.(و آتش به فرمان خدا سرد شد)
  37,99,"و(ابراهیم) گفت:« من به سوی پروردگارم می روم، (او) مرا هدایت خواهد کرد"
  37,100,پروردگارا! به من (فرزندی) از صالحان عطا فرما»
  37,101,ما او را به (تولد) پسری بردبار( ) بشارت دادیم
  37,102,"پس هنگامی که (فرزندش) با او به (سن) سعی و کوشش رسید گفت:« ای فرزندم! من در خواب( ) دیدم که تو را قربانی می کنم، ببین، تو چه نظر داری؟!» گفت: «پدرم، به آنچه مأمور شده ای، عمل کن، اگر خدا بخواهد، مرا از صابران خواهی یافت»"
  37,103,پس چون هر دو تسلیم شدند، و (ابراهیم) او را به پیشانی (بر زمین) افکند
  37,104,"و او را ندا دادیم: «ای ابراهیم"
  37,105,یقیناً خواب (خویش) را تحقق بخشیدی». بدون شک ما این گونه نیکوکاران را پاداش می دهیم
  37,106,مسلماً این (خواب) آزمایشی آشکار بود
  37,107,و او را به ذبح بزرگی( ) فدا دادیم
  37,108,و برای او در(میان) امتهای بعد (نام نیک) بر جای نهادیم
  37,109,سلام بر ابراهیم
  37,110,این گونه نیکوکاران را پاداش می دهیم
  37,111,بی گمان او از بندگان مؤمن ما بود
  37,112,و او را به (تولد) اسحاق پیامبری از شایستگان بشارت دادیم
  37,113,و (ما) بر او و اسحاق برکت دادیم، و از دودمان آن دو،(افرادی) نیکوکار بودند، و (افرادی) آشکار بر خود ستم کردند
  37,114,و به راستی (ما) بر موسی و هارون منت نهادیم
  37,115,و آن دو و قومشان را از اندوه بزرگ نجات دادیم
  37,116,و یاریشان کردیم، پس آنان پیروز شدند
  37,117,و به آن دو کتاب روشنگر دادیم
  37,118,و آن دو را به راه راست هدایت کردیم
  37,119,و برای آنان در (میان) امتهای بعد (نام نیک) باقی گذاشتیم
  37,120,سلام بر موسی و هارون
  37,121,بی گمان ما این گونه نیکوکاران را پاداش می دهیم
  37,122,یقیناً آن دو از بندگان مؤمن ما بودند
  37,123,و بی گمان الیاس از رسولان (ما) بود
  37,124,"چون به قومش گفت:« آیا پرهیزگاری نمی کنید؟"
  37,125,"آیا (بت)\" بعل\" را می خوانید، و بهترین آفرینندگان را رها می کنید؟"
  37,126,الله که پروردگار شما و پروردگار نیاکان نخستین شماست
  37,127,پس (آنها) او را تکذیب کردند، و یقیناً (همه) آنان (به جهنم) احضار خواهند شد
  37,128,مگر بندگان مخلص خدا
  37,129,و برای او در (میان) امتهای بعد (نام نیک) باقی گذاشتیم
  37,130,سلام بر «ال یاسین» (= الیاس)
  37,131,ما این گونه نیکوکاران را پاداش می دهیم
  37,132,بی گمان او از بندگان مؤمن ما بود
  37,133,و یقیناً لوط از رسولان (ما) بود
  37,134,هنگامی که او و خانواده اش را همگی نجات دادیم
  37,135,مگر پیرزنی که از باقی ماندگان بود
  37,136,سپس دیگران را هلاک کردیم
  37,137,و شما (پیوسته) صبحگاهان بر (ویرانه های شهرهای) آنها می گذرید
  37,138,و (همچنین) شامگاهان آیا نمی اندیشید؟
  37,139,و یقیناً یونس از رسولان (ما) بود
  37,140,هنگامی به کشتی پر (از مسافر و بار) گریخت
  37,141,پس (اهل کشتی) قرعه زدند، پس (قرعه بنام او افتاد و) مغلوب شد
  37,142,آنگاه ماهی (عظیمی) او را بلعید، در حالی که او سزاوار نکوهش بود
  37,143,پس اگر او از تسبیح گویان نبود
  37,144,یقیناً تا روزی که (مردم) بر انگیخته می شوند، در شکمش باقی می ماند