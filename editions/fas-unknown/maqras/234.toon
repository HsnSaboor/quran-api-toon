quran[71]{c,v,t}:
  80,1,"چهره درهم کشید, وروی بر گردانید"
  80,2,از این که (عبد الله بن ام مکتوم) نابینا به نزدش آمد
  80,3,و (ای پیامبر) چه می دانی شاید که او پاک می شد
  80,4,"یا پندگیرد, واین پند به او نفع می داد"
  80,5,اما آن کس که مجد نیازی نمود
  80,6,پس تو به او روی من آوری
  80,7,"در حالی که اگر او خود را (از کفر) پاک نسازد, چیزی بر تو نیست"
  80,8,اما کسی شتابان به مراغ تو می آید
  80,9,و او (از خدا) می ترسد
  80,10,پس تو از او غافل می شوی (وبه ار تو جه نمی کنی؟)
  80,11,"هرگز چنین نیست, بی گمان این (سوره) تذکر ویاد آوری است"
  80,12,پس هرکس بخواهد از آن پند گیرد
  80,13,در صحیفه های پر ارزشی (ثبت) است
  80,14,بلند پایه وپاکیزه
  80,15,به دست (فرشتگان =) سفیران (وحی است)
  80,16,بزرگوار ونیکو کار
  80,17,"مرگ بر (این) انسان, چقدر نا سپاس است؟"
  80,18,(خداوند) او را از چه چیز آفریده است؟
  80,19,"او را از نطفه ای (نا چیز) آفریده است, آنگاه او را موزون ساخت"
  80,20,سپس راه را برای او آسان نمود
  80,21,"آنگاه (بعد از پایان عمر) او را میراند, پس او را در قبر (پنهان) کرد"
  80,22,سپس هرگاه که بخواهد او را (زیاده می کند و از قبر) بر می انگیزد
  80,23,"هرگز چنین نیست, (که او می پندارد) او هنوز آنچه را که (خدا) فرمان داده, به جای نیاورده است"
  80,24,پس انسان باید به غذای خود بنگرد
  80,25,بی گمان ما آب فراوان (از آسمان) فروریختیم
  80,26,سپس زمین را به نیکی شگافتیم
  80,27,آنگاه در آن دانه (های فراون) رویاندیم
  80,28,وانگور وسبزی (بسیار)
  80,29,و زیتون ونخل
  80,30,وبا غهایی (ابنوه و) پردرخت
  80,31,و(انواع) میوه و علوفه (پدید آوردیم)
  80,32,(همۀ اینها) برای بهره گیری شما وچهار یایانتان است
  80,33,پس هنگامی که (آن) صدای مهیب (قیامت) فرا رسد
  80,34,روزی که انسان از برادرش می گریزد
  80,35,واز ما درش و از پدرش
  80,36,واز زنش وفرزندانش (نیز می گریزد)
  80,37,در آن روز هرکس را کاری است که اورا به خود مشغولش دارد
  80,38,چهره هایی در آن روز گشاده وروشن است
  80,39,خندان وشاد است
  80,40,وچهره هایی در آن روز غبار آلود است
  80,41,سیاهی (وتاریکی) آنهارا پوشانده است
  80,42,اینان همان کافران فاجرند
  81,1,هنگامی که خورشید درهم پیچیده شود
  81,2,وهنگامی که ستارگان بی نور شوند
  81,3,وهنگامی که کوهها به حرکت درآنید
  81,4,وهنگامی که ماده شتران باردار رها شوند
  81,5,وهنگامی که جانوران وحشی گرده آورده شوند
  81,6,وهگامی که دریاها (جوشان و) بر افروخته شود
  81,7,وهنگامی که روحها (باتنها) قرین شوند
  81,8,وهنگامی که از دختر زنده به گورشده پرسیده شود
  81,9,به کدامین گناه کشته شده است؟
  81,10,وهنگامی که نامه های (اعمال) گشوده شود
  81,11,وهنگامی که پرده از روی آسمان برگرفته شود
  81,12,وهنگامی که دوزخ افروخته (وشعله ور) گردد
  81,13,وهنگامی که بهشت نزدیک آورده شود
  81,14,(در آن هنگام) هرکس خواهد دانست چه چیزی را (برای آفرت خود) حاضر (وآماده) کرده است
  81,15,پس سوگند به شارگانی که باز می گردند
  81,16,(شتابان) حرکت می کنند (واز نظر) پنهان می شوند
  81,17,"وسوگند به شب, هنگامی که (تاریکی اش کاسته نودو) پشت کند"
  81,18,"وسوگند به صبح, هنگامی که بد مد"
  81,19,بی گمان این (قرآن) سخن فرستادۀ بزدگوار (= جبرئیل) است
  81,20,"که (مقتدر و) نیرومند است, ونزد (خداوند) صاحب عرش مقام ومنزلت والایی دارد"
  81,21,(در آسمانها) مودر اطاعت (فرشتکان) وامین (وحی) است
  81,22,و (ای مردم) همنشین شما (محمد) دیوانه نیست
  81,23,وبه راستی او (= جبرئیل) را در افق روشن دیده است
  81,24,و او بر (آنچه از طریق) غیب (به او وحی شده) بخیل نیست
  81,25,و این (قرآن) گفتۀ شیطان رانده شده نیست
  81,26,پس به کجا می روید؟
  81,27,این (قرآن) چیزی جز پند واندرز برای جهانیان نیست
  81,28,برای کسی از شما که بخواهد راه راست درپشین گیرد
  81,29,وشما نمی خواهید مگر آنکه پروردگار جهانیان بخواهد