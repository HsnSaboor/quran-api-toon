quran[64]{c,v,t}:
  84,1,هنگامی که آسمان شکافته شود
  84,2,و به (فرمان) پروردگارش گوش دهد (وتسلیم شود) وسزاواراست (که چنین کند)
  84,3,وهنگامی که زمین گسترده (و هموار) شود
  84,4,"و هر چه را درون خود دارد بیرون ریزد, وتهی گردد"
  84,5,و به (فرمان) پروردگارش گوش دهد (وتسلیم شود). وسزاوار است (که چنین کند)
  84,6,"ای انسان! بی گمان تو در راه (رسیدن به) پروردگارت سخت تلاش و کوشش می کنی, پس اورا ملاقات خواهی کرد"
  84,7,پس اما کسی که نامۀ (اعمالش) به دست راستش داده شود
  84,8,"بزودی به حسابی آسان, محاسبه می شود"
  84,9,و شادو مسرور به سوی خانواده اش باز می گردد
  84,10,و اما کسی که نامۀ (اعمالش) از پشت سرش به او داده شود
  84,11,پس بزودی (مرگ و) نابودی را می طلبند
  84,12,و به (آتش) جهنم شعله ور در آید
  84,13,بی گمان او در (دنیا) میان خانوادۀ خود شادمان بود
  84,14,به راستی او گمان می کرد هرگز باز نخواهد گشت
  84,15,"آری, همانا پروردگارش (نسبت) به او بینا بود"
  84,16,پس به شفق سوگند می خورم
  84,17,و سوگند به شاب وآنچه را فرو می پوشد
  84,18,و سوگند به ماه چون (فروفش) کامل شود
  84,19,که شما پیوسته از حالی به حال دیگر (منتقل) می شوید
  84,20,پس آنان را چه شده که ایمان نمی آورند؟
  84,21,وهنگامی که قرأن بر آنها تلاوت شود سجده نمی کنند؟
  84,22,"بلکه کسانی که کافر شدند, پیوسته (آیات الهی را) تکذیب می کنند"
  84,23,و خداوند به آنچه در دل پنهان می دارند داناتراست
  84,24,پس (ای پیامبر) آنان را به عذابی دردناک بشات ده
  84,25,"مگر کسانی که ایمان آوردنده اند و کارهای شایسته انجام داده اند, که برای آنها پاداشی قطع نشدنی است"
  85,1,قسم به آسمان که دارندۀ بر جها است
  85,2,و سوگند به روز موعود (= روز قیامت)
  85,3,"و سوگند به. شاهد (= روز جمعه) و\"مشهود\" (= روز عرفه)"
  85,4,اصحاب اخدود (= خندق داران) به هلاکت (وا بودی) رسیدند
  85,5,(خندقهای پر از) افروخته از هیزمهای بسیار
  85,6,هنگامی که بر (کنارۀ) آن نشسته بودند
  85,7,وآنان آنچه را با مؤمنان انجام می دادند تماشا می کردند
  85,8,"وهیچ ایرادی از آنان نگرفتند, جز اینکه به خداوند پیروزمند ستوده ایمان آورده بودند"
  85,9,"(همان) کسی که فرمانروایی آسمانها وزمین از آنٍ اوست, وخداوند وبر همه چیز گواه است"
  85,10,"به راستی کسانی که مردان مومن را وزنان مؤمنه را شکنجه (وآزار) دادند, سپس توبه نکردند, پس برای آنها عذاب جهنم است, وبرایشان عذاب (آتش) سوزان است"
  85,11,"همانا برای کسانی که ایمان آوردند وکارهای شایسته کردند, باغهایی (از بهشت) است که نهرها زیر (درختان) آن جاری است, واین کامیابابی بزرگ است"
  85,12,به راستی (مجازات و) فرو گرفتن پروردگارت سخت است
  85,13,همانا اوست که (آفریش را) آغاز می کند و دوباره (بعد از مرگ) باز می گرداند
  85,14,و او آمرزندۀ دوستدار است
  85,15,صاحب عرش مجید است
  85,16,آنچه را بخواهد انجام می دهد
  85,17,(ای پیامبر) آیا راستان لشکرها به تو رسیده است
  85,18,(لشکریان) فرعون و(قوم) ثمود؟
  85,19,بلکه کسانی که کافر شدند پیوسته در تکذیب (حق) هستند
  85,20,و خداوند از هر سو بر آنها احاطه دارد
  85,21,بلکه این قرآن مجید است
  85,22,که در لوح محفوظ (نگاشته شده) است
  86,1,سوگند به آسمان و سوگند به طارق (= آنچه در شب آید)
  86,2,و تو چه می دانی طارق چیست؟
  86,3,(همان) ستارۀ در خشان است
  86,4,هیچ کس نیست مگر آنکه بر او نگهبان ومحافظی (از فرشتگان) است
  86,5,پس انسان باید بنگرد که از چه چیز آفریده شده است
  86,6,از یک آب جهنده آفریده شده است
  86,7,که از میان پشت وسینه بیرون می آید
  86,8,بی گمان او (= خداوند) بر باز گردانیدن او (پس از مرگ) قادر است
  86,9,روزی که نهانها آشکار می شود
  86,10,پس اورا هیچ نیرو ویاوری نیست
  86,11,سوگند به آسمان پر باران
  86,12,و سوگند به زمین پر شکاف
  86,13,بی گمان این (قرآن) سخن جدا کنندۀ حق از باطل است
  86,14,و آن (سخن) هزل وبیهوده نیست
  86,15,بی گمان آنها پیوسته حیله ونیرتگ می کنند
  86,16,ومن (هم) حیله (وتدبیر) می کنم
  86,17,"پس کافران را مهلت بده, اندکی آنان را رهاکن"