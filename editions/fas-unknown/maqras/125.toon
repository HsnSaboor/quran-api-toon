quran[54]{c,v,t}:
  20,1,طه (طا. ها)
  20,2,(ای پیامبر! ما) قرآن را برتو نازل نکردیم که به مشقت افتی
  20,3,مگر (آن) یاد آوری برای کسی است که (از خدا) می ترسد
  20,4,(این قرآن) فرو فرستاده شده از سوی کسی که زمین و آسمانهای بلند را آفریده است
  20,5,(خداوند) رحمان (است که) بر عرش قرار گرفت
  20,6,از آن اوست آنچه در آسمانها و آنچه در زمین، و آنچه میان آن دو است، و آنچه زیر خاک (پنهان) است
  20,7,و اگر سخن آشکارا بگویی (یا آن را پنهان داری) بی گمان او (راز) نهان و نهان تر را می داند
  20,8,(او) الله است، که هیچ معبودی جزاو نیست؛ نامهای نیکو از آن اوست
  20,9,و(ای پیامبر!) آیا خبر موسی به تو رسیده است ؟
  20,10,"هنگامی که آتشی را (ازدور) دید، پس به خانواده ی خود گفت: «(لحظه ای) درنگ کنید، همانا من آتشی را دیده ام شاید شعله ای از آن برای شما بیاورم، یا بر آن آتش راهنمایی بیابم»"
  20,11,"پس چون نزد آن (آتش) آمد، ندا داده شد که : «ای موسی"
  20,12,همانا من پروردگار تو هستم، پس کفشهایت را بیرون کن، که تو در وادی مقدس طوی هستی
  20,13,و من تو را (به پیامبری) بر گزیدم، پس به آنچه (بر تو) وحی می شود، گوش فرا ده
  20,14,یقیناً من «الله» هستم، هیچ معبودی (به حق) جز من نیست، پس مرا پرستش کن، و نماز را برای یاد من بر پا دار
  20,15,قطعاً قیامت خواهد آمد، می خواهم (وقت) آن را پنهان دارم، تا هر کس در برابر سعی (و اعمالی) که می کند جزا داده شود
  20,16,پس مبادا کسی که به آن ایمان ندارد، و از هوسهای خود پیروی می کند، تو را از آن باز دارد، که هلاک خواهی شد
  20,17,و ای موسی ! آن چیست به (دست) راستت؟»
  20,18,"گفت: «این عصای من است، بر آن تکیه می کنم، و با آن برای گوسفندانم (برگ درختان) فرو می ریزم، و مرا با آن کارهای دیگری (نیز) است (که بر آورده می کنم)"
  20,19,"فرمود: «ای موسی! آن را بیفکن»"
  20,20,پس (موسی) آن (عصا) را افکند، که ناگهان ماری شد که (به هر سو) می دوید
  20,21,"فرمود :«آن را بگیر و نترس، به زودی آن را به صورت اولش باز می گردانیم"
  20,22,و دستت در بغل خود کن، تا سفید (و) بی عیب بیرون آید، (این نیز) معجزه ی دیگری است
  20,23,تا آیات (و نشانه های) بزرگ خود را به تو نشان دهیم
  20,24,(اینک) به سوی فرعون برو، بی گمان او سرکشی کرده است »
  20,25,"(موسی) گفت : «پروردگارا ! سینه ام را برایم بگشا"
  20,26,و کارم را برایم آسان گردان
  20,27,و گره از زبانم باز کن
  20,28,تا سخنانم را بفهمند
  20,29,و برای من (یاور و) وزیری از خاندانم قرار ده
  20,30,برادرم هارون را
  20,31,به (وسیله ی) او پشت مرا محکم کن،
  20,32,و او را در کار (رسالت) من شریک ساز،
  20,33,تا تو را بسیار تسبیح گوییم،
  20,34,و بسیار تو را یاد کنیم،
  20,35,بی شک تو به (حال) ما خوب بینایی »
  20,36,"فرمود :«ای موسی ! هر چه خواستی به تو داده شد"
  20,37,و به تحقیق ما بار دیگر (نیز) بر تو منت نهاده ایم (و نعمت بخشیده ایم)
  20,38,آن هنگام که به مادرت الهام کردیم، آنچه راکه باید الهام می شد،
  20,39,"که :«او را در صندوقی بگذار، آنگاه آن (صندوق) را به دریا بینداز، تا دریا او را به ساحل افکند، (و) دشمن من و دشمن او، او را برگیرد ». و من محبتی از سوی خود بر تو افکندم و تا در برابر دیدگان من پرورش یابی"
  20,40,"آنگاه که خواهرت می رفت و می گفت : «آیا کسی به شما نشان دهم که سرپرستی اش را به عهده گیرد ؟! » پس تو را به مادرت باز گرداندیم، تا چشمش (به دیدار تو) روشن شود، و اندوهگین نگردد، و (بعدها) تو یک نفر (قبطی) را کشتی، پس (ما) تو را از اندوه (و گرفتاری) نجات دادیم، و بارها (چنانکه باید) تو را آزمودیم. پس (از آن) سالها در میان مردم مدین ماندی، سپس ای موسی! بر (طبق) تقدیر (الهی به اینجا) آمدی"
  20,41,و تو را برای خودم خاص ساختم (و پرورش دادم)
  20,42,(اینک) تو و برادرت با آیات من برو، و در یاد من سستی نکنید
  20,43,به سوی فرعون بروید، بی گمان او سرکشی کرده است
  20,44,پس به نرمی با او سخن بگویید، شاید که او پند گیرد یا (از پروردگارش) بترسد،
  20,45,"(موسی وهارون) گفتند :«پروردگارا ! به راستی ما می ترسیم که بر ما پیش دستی نماید (و قبل از بیان حق ما را آزار دهد) یا طغیان کند»"
  20,46,"فرمود :«نترسید! بی شک من با شما هستم، می شنوم و می بینم"
  20,47,"پس به نز د او بروید و بگویید : ما فرستادگان پروردگارت هستیم، بنی اسرائیل را با ما بفرست، و آنها را آزار و شکنجه نکن، به راستی که ما نشانه ى روشنى از سوی پروردگارت برای تو آورده ایم ، و سلام بر آن کسی که از هدایت پیروی کند"
  20,48,همانا به ما وحی شده که محققاً عذاب (الهی) بر کسی است که (آیات و معجزات را) تکذیب کند، و (از ایمان) روی بگرداند»
  20,49,"(فرعون) گفت :«ای موسی! پروردگار شما کیست ؟»"
  20,50,"(موسی) گفت : «پروردگار ما کسی است که آفرینش هر چیزی را به او ارزانی داشته، سپس (آنها را) هدایت کرده است»"
  20,51,"(فرعون) گفت : «پس حال (و سرنوشت) نسلهای گذشته چه می شود؟ »"
  20,52,"(موسی) گفت :«علم آن نزد پروردگارم در کتابی (ثبت) است، پروردگارم نه اشتباه می کند و نه فراموش می کند"
  20,53,(همان) کسی که زمین را برای شما گهواره (و محل آسایش) قرار داد، و برای شما در آن راههایی ایجاد نمود، و از آسمان آبی فرو فرستاد پس با آن، انواع گوناگون گیاه را (از زمین) بیرون آوردیم
  20,54,بخورید، و (نیز) چهار پایانتان را بچرانید، بی گمان در این (امور) نشانه های برای خردمندان است