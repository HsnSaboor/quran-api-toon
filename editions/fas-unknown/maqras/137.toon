quran[35]{c,v,t}:
  23,1,به راستی مؤمنان رستگار شدند
  23,2,همان کسانی که در نمازشان خاشع (و فروتن) هستند
  23,3,و کسانی که از لغو (و کارهای بیهوده) روی گردانند
  23,4,و کسانی که زکات را انجام می دهند
  23,5,و آنها که شرمگاهشان را حفظ می کنند
  23,6,جز بر همسران شان یا (بر) کنیزان شان، پس بی گمان اینان (در بهره گیری از آنان) ملامت نمی شوند
  23,7,پس کسی که فراتر از این بخواهد، آنانند که تجاوز گرند
  23,8,و کسانی که امانتهای شان و عهد خود را رعایت می کنند
  23,9,و کسانی که برنمازهای شان مواظبت می نمایند
  23,10,(آری) اینانند که وارثند
  23,11,کسانی که (بهشت) فردوس را ارث می برند، و جاودانه در آن خواهند ماند
  23,12,و به راستی انسان را از چکیده ای از گِل آفریدیم
  23,13,سپس او را از نطفه ای در قرار گاهی استوار (= رحم) قرار دادیم
  23,14,سپس نطفه را (به صورت) علقه (= خون بسته) گرداندیم، آنگاه علقه را (به صورت) مضغه (= پاره گوشتی) در آوردیم، آنگاه مضغه را (به صورت) استخوانهایی گردانیدیم، پس بر استخوانها گوشت پوشاندیم، سپس آن را آفرینشی دیگر بخشیدیم، پس (پر برکت و) بزرگوار است، خدایی که بهترین آفرینندگان است
  23,15,سپس مسلماً شما بعد از این خواهید مرد
  23,16,آنگاه یقیناً شما روز قیامت بر انگیخته می شوید
  23,17,وبه راستی بر فرازتان هفت آسمان آفریدیم، و (ما هرگز) از آفرینش (خود) غافل نبوده ایم
  23,18,و از آسمان آبی به اندازه ی معین نازل کردیم، پس آن را در زمین جای دادیم، و بی گمان ما بر ازبین بردن آن کاملاً قادر هستیم
  23,19,پس بوسیله ی آن باغهایی از درختان خرما و انگور برای شما پدید آوردیم، شما را در آن (باغها) میوه های بسیار است، و از آن می خورید
  23,20,و (نیز) درختی را که از طور سینا بیرون می آید (= درخت زیتون) که از آن روغن و (نان) خورش برای خورندگان فراهم می شود
  23,21,و بی گمان برای شما در چهارپایان عبرتی است، از آنچه درونشان است (= از شیر آنها) شما را سیراب می کنیم ؛ و برای شما در آنها منافع فراوان است، و از (گوشت) آنها می خورید
  23,22,و بر آنها و بر کشتیها سوار می شوید
  23,23,"و به راستی (ما) نوح را به سوی قومش فرستادیم، پس (او به آنها) گفت :«ای قوم من! الله را بپرستید، که جز او معبودی برای شما نیست، آیا پرهیز نمی کنید ؟"
  23,24,"پس اشراف قومش، (آن) کسانی که کافر بودند؛ گفتند: «این (مرد) جز بشری همچون شما نیست، که می خواهد بر شما برتری جوید، اگر خدا می خواست، همانا فرشتگانی را نازل می کرد، ما (هرگز) چنین چیزی را در (میان) نیاکان خود نشنیده ایم"
  23,25,او مرد دیوانه ای بیش نیست، پس تا مدتی در باره ی او صبر کنید،
  23,26,"(نوح) گفت : « پروردگارا! مرا در برابر تکذیب آنها یاری کن »"
  23,27,"پس به او وحی کردیدم که : « به دیدگان ما و به وحی ما کشتی بساز، پس هنگامی که فرمان ما فرا رسد، و آب از تنور بجوشد، آنگاه از هرنوع (حیوان) یک جفت (نر و ماده) در کشتی سوار کن و (نیز) خانواده خود را (سوار کن) جز کسی از آنان را که وعده ی (هلاک) از پیش بر او مقرر شده است. و در (باره ی) کسانی که ستم کردند، با من سخن مگو، که آنان غرق شدنی هستند»"
  23,28,"هنگامی که تو و همراهانت بر کشتی سوار شدید؛ بگو:« ستایش برای خدایی است که ما را از قوم ستمگر نجات داد»"
  23,29,"و (نیز) بگو : « پروردگارا ! ما را در منزلگاهی پر برکت فرود آور، و تو بهترین فرود آورندگانی»"
  23,30,بی گمان در این (ماجرا) نشانه هایی است، و (ما) به راستی آزمایش می کنیم
  23,31,سپس قوم دیگری را بعد از آنها به وجود آوردیم
  23,32,"پس از خودشان پیامبری در (میان) آنان فرستایم که : «خدا را بپرستید، که جز او معبودی برای شما نیست، آیا پرهیز نمی کنید ؟! »"
  23,33,"و گروهی از اشراف قومش که کافر بودند، و دیدار آخرت را تکذیب می کردند، ودر زندگی دنیا به آنها نعمت و آسایش داده بودیم، گفتند :«این(مرد) بشری همچون شما است، از آنچه که (شما) می خورید، می خورد، واز آنچه که شما می نوشید، می نوشد"
  23,34,و اگر از بشری همچون خود اطاعت کردید، یقیناً شما زیانکار خواهید شد
  23,35,"آیا (او) به شما وعده می دهد : که همانا شما چون مردید و خاک و استخوانهایی (پوسیده) شدید، (بار دیگر از گور) بیرون آورده می شوید ؟"