quran[21]{c,v,t}:
  92,1,سوگند به شب هنگامی که (همه چیز را) بپوشاند
  92,2,و سوگند به روز هنگامی که آشکار شود
  92,3,و سوگند به آنکه نر وماده را آفرید
  92,4,که یقیناً سعی (وتلاش) شما مختلف است
  92,5,پس اما کسی که (در راه خدا) بخشید وپرهیزگاری کرد
  92,6,و (سخنان) نیک را تصدیق کرد
  92,7,پس ما اورا برای (راه) آسان توفیق می دهیم
  92,8,و اما کسی که بخل ورزید و بی نیازی طلبید
  92,9,و (نیز سخنان) نیک را تکذیب کرد
  92,10,پس بزوری اورا برای (راه) دشوار سوق می دهیم
  92,11,"وهنگامی که سرازیر (جهنم) شود, مالش به حال او سودی نخواهد داشت"
  92,12,مسلماً هدایت (وراهنمائی) کردن بر (عهدۀ) ماست
  92,13,ومحققاً آخرت ودنیا از آنٍ ماست
  92,14,پس من شما را از آتشی شعله ور بیم دادم
  92,15,به آن (آتش کسی) جز بدبخت ترین (مردم) در نیفتد
  92,16,(همان) کسی که (آیات مارا) تکذیب کرد
  92,17,وبزودی پرهیزکار ترین (مردم) از آن دور داشته می شود
  92,18,(همان) کسی مال خود را (در راه خدا) می بخشد تا پاک شود
  92,19,"وهیچ کس را بر او نعمت (وحقی) نیست, تا بخواهد (با انفاق) پاداش دهد"
  92,20,مگر (برای) بدست آوردن وجه (و خشودی) پروردگار برترین
  92,21,وبه راستی خشنود خواهد شد