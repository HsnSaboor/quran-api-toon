quran[15]{c,v,t}:
  112,1,"Реци: „Он је Аллах - Један"
  112,2,Аллах је Уточиште сваком
  112,3,Није родио и рођен није
  112,4,и нико Му раван није!“
  113,1,"Реци: „Тражим уточиште код Господара свитања"
  113,2,од зла онога што Он ствара
  113,3,и од зла мркле ноћи кад разастре тмине
  113,4,и од зла оних које дувају у чворове
  113,5,и од зла завидника кад завиди.“
  114,1,"Реци: „Тражим уточиште код Господара људи"
  114,2,Владара људи
  114,3,Бога људи
  114,4,од зла ђавола – који наноси зле мисли па се скрије
  114,5,који зле мисли уноси у срца људи
  114,6,од духова и од људи.“