quran[856]{c,v,t}:
  26,1,طسم (طا. سین. میم)
  26,2,این آیات کتاب روشن است
  26,3,گویی می‌خواهی از (شدت غم و اندوه) این‌که آن‌ها ایمان نمی‌آورند؛ خود را هلاک کنی
  26,4,اگر بخواهیم از آسمان بر آن‌ها نشانه‌ای نازل می‌کنیم که گردن‌هایشان در برابر آن تسلیم (و خاضع) گردد
  26,5,و هیچ پند تازه‌ای از سوی (الله) رحمان برای آن‌ها نمی‌آید؛ مگر این‌که از آن روی گردان هستند
  26,6,به راستی آن‌ها تکذیب کردند، پس به زودی اخبار آنچه را که به آن استهزاء (و تمسخر) می‌کردند؛ به آن‌ها خواهد رسید
  26,7,آیا به زمین ننگریسته‌اند که چه قدر از هر گونه گیاهان (نیکو و) پر ارزش در آن رویانده‌ایم؟
  26,8,بی‌گمان در این نشانۀ (بزرگی) است، و بیشتر آن‌ها مؤمن نیستند
  26,9,و به راستی پروردگار تو پیروزمند مهربان است
  26,10,و (به یاد بیاور) هنگامی را که پروردگارت موسی را ندا داد که به سوی قوم ستمکار برو،
  26,11,قوم فرعون، آیا آن‌ها نمی‌ترسند؟
  26,12,"(موسی) گفت: «پروردگارا! من می‌ترسم که مرا تکذیب کنند"
  26,13,و سینه‌ام تنگ گردد و زبانم باز نشود، پس (برادرم) هارون را (نیز) رسالت ده (تا مرا یاری کند)
  26,14,و آن‌ها بر (گردن) من (ادعای) گناهی دارند، پس می‌ترسم که مرا بکشند»
  26,15,"(الله) فرمود: «چنین نیست، پس شما هردو با آیات ما بروید، یقیناً ما با شما شنوندگان هستیم"
  26,16,"پس (به نزد) فرعون بروید، و بگویید: «ما فرستادۀ پروردگار جهانیان هستیم،"
  26,17,که بنی اسرائیل را با ما بفرست»
  26,18,"(فرعون) گفت: «آیا ما تو را در کودکی نزد خود پرورش ندادیم، و سال‌هایی از عمرت را در میان ما نگذراندی؟"
  26,19,و (بالاخره) آن کارت را (که نبایست انجام می‌دادی) انجام دادی، و تو از ناسپاسانی»
  26,20,"(موسی) گفت: «(من) آن (کار) را آنگاه انجام دادم که من از بی‌خبران بودم"
  26,21,پس چون از شما ترسیدم از شما فرار کردم، آنگاه پروردگارم به من دانش (و نبوت) بخشید و مرا از پیامبران قرار داد
  26,22,و آیا این نعمتی است که تو بر من منت می‌گذاری که بنی اسرائیل را بردۀ خود ساخته‌ای؟!»
  26,23,"فرعون گفت: «پروردگار جهانیان چیست؟!»"
  26,24,"(موسی) گفت: «پروردگار آسمان‌ها و زمین و آنچه میان آن دو است، اگر اهل یقین هستید»"
  26,25,"(فرعون) به آن‌های که در اطرافش بودند؛ گفت: «آیا نمی‌شنوید؟»"
  26,26,"(موسی) گفت: «(او) پروردگار شما و پروردگار نیاکان پیشین شماست"
  26,27,"(فرعون) گفت: «بی‌تردید پیامبرتان که به سوی شما فرستاده شده دیوانه است»"
  26,28,"(موسی) گفت: «(او) پروردگار مشرق و مغرب و آنچه میان آن دو است، اگر بیندیشید»"
  26,29,"(فرعون) گفت: «اگر معبودی جز من برگزینی، البته تو را از زندانیان قرار خواهم داد»"
  26,30,"(موسی) گفت: «حتی اگر معجزۀ روشنی برای تو آورده باشم؟!»"
  26,31,"(فرعون) گفت: «پس اگر از راستگویانی، آن را بیاور»"
  26,32,پس (موسی) عصای خود را افکند، که ناگهان آن اژد‌هایی آشکار شد
  26,33,و دست خود را (در گریبان فرو برد و) بیرون آورد که ناگهان در برابر بینندگان سفید (و روشن) بود
  26,34,"(فرعون) به اشرافی که اطراف او بودند؛ گفت: «بی‌گمان این (مرد) جادوگر دانایی است"
  26,35,(او) می‌خواهد با سحرش شما را از سرزمین‌تان بیرون کند، پس شما چه نظر می‌دهید؟!»
  26,36,"گفتند: «(کار) او و برادرش را به تأخیر انداز، و جمع آوری کنندگان را در (همۀ) شهر‌ها بفرست»"
  26,37,تا هر جادوگر ماهر (و) دانایی را نزد تو آورند»
  26,38,پس (سر‌انجام) جادوگران برای وعده‌گاه روز معینی گرد آورده شدند
  26,39,"و به مردم گفته شد: «آیا شما (نیز) جمع می‌شوید،"
  26,40,تا اگر ساحران پیروز شدند، ما از آن‌ها پیروی کنیم؟!»
  26,41,"پس هنگامی‌که ساحران آمدند، به فرعون گفتند: «اگر ما پیروز شویم، آیا ما پاداشی خواهیم داشت؟!»"
  26,42,"گفت: «آری، و بی‌گمان آنگاه شما از مقربان خواهید بود»"
  26,43,"موسی به آن‌ها گفت: «هر چه می‌خواهید بیفکنید، بیفکنید»"
  26,44,"پس آن‌ها ریسمان‌ها و عصا‌های خود را افکندند، و گفتند: «به عزت فرعون سوگند که، قطعاً ما پیروزیم»"
  26,45,پس موسی عصایش را افکند، ناگهان آنچه را به دروغ بر ساخته بودند، بلعید
  26,46,پس ساحران سجده‌کنان (به زمین) افتادند
  26,47,"گفتند: «ما به پروردگار جهانیان ایمان آوردیم"
  26,48,پروردگار موسی و هارون»
  26,49,"(فرعون) گفت: «آیا پیش از آن‌که به شما اجازه دهم به او ایمان آوردید؟! مسلماً او بزرگتر شماست که سحر را به شما یاد داده است، پس به زودی خواهید دانست! دستان‌تان و پا‌هایتان را به عکس یکدیگر قطع می‌کنم، و همۀ شما را به دار می‌آویزم»"
  26,50,"گفتند: «باکی نیست، ما به سوی پروردگارمان باز می‌گردیم"
  26,51,ما امیدواریم که پروردگارمان خطاهای ما را ببخشد، که ما از نخستین ایمان آورندگان بودیم»
  26,52,"و به موسی وحی کردیم که: «شبانه بندگانم را (از مصر) بیرون ببر، بی‌گمان شما تعقیب می‌شوید»"
  26,53,پس فرعون (چون از ماجرا آگاه گردید) گرد آورندگان (نیرو) را به شهرها فرستاد
  26,54,"(و گفت:) این‌ها (= بنی اسرائیل) گروهی اندک (و ناچیز) هستند،"
  26,55,و این‌ها ما را به خشم آورده‌اند،
  26,56,و ما همگی آماده (و بیدار) هستیم»
  26,57,پس آن‌ها را از باغ‌ها و چشمه‌‌ها بیرون کردیم
  26,58,و (نیز) از گنج‌ها و منزل‌گاه نیکو (و قصر‌های مجلل بیرون راندیم)
  26,59,(آری) این چنین (کردیم) و بنی اسرائیل را وارث آن‌ها ساختیم
  26,60,پس آن‌ها (صبحگاهان به) هنگام طلوع آفتاب به تعقیب‌شان پرداختند
  26,61,"پس چون دو گروه یکدیگر را دیدند، یاران موسی گفتند: «یقیناً ما (در چنگال فرعونیان) گرفتار شدیم»"
  26,62,"(موسی) گفت: «چنین نیست، بی‌گمان پروردگارم با من است، به زودی مرا هدایت خواهد کرد»"
  26,63,"پس به موسی وحی کردیم: «عصایت را به دریا بزن» آنگاه (دریا) شکافته شد، پس هر بخشی (از آن) همچون کوه عظیمی شد"
  26,64,و دیگران (= فرعون و فرعونیان) را (نیز) به آنجا نزدیک ساختیم
  26,65,و موسی و همراهانش را همگی نجات دادیم
  26,66,سپس دیگران را غرق کردیم
  26,67,بی‌گمان در این (ماجرا) نشانه‌ای (روشن) است، ولی بیشتر مردم ایمان نمی‌آورند
  26,68,و بی‌تردید پرورگارتو پیروزمند مهربان است
  26,69,و خبر ابراهیم را بر آن‌ها بخوان
  26,70,"هنگامی‌که به پدر و قومش گفت: «چه چیز را می‌پرستید؟!»"
  26,71,"گفتند: «بت‌هایی را می‌پرستیم، و پیوسته برای (عبادت) آن‌ها معتکف هستیم"
  26,72,"(ابراهیم) گفت: «آیا هنگامی‌که آن‌ها را می‌خوانید (صدای) شما را می‌شنوند؟"
  26,73,یا سود و زیانی به شما می‌رسانند؟!»
  26,74,"گفتند: «(نه) بلکه ما نیاکان خود را یافتیم که چنین می‌کردند»"
  26,75,"(ابراهیم) گفت: «آیا دیدید چیزهایی را که پیوسته عبادت می‌کردید،"
  26,76,شما و نیاکان پیشین شما
  26,77,پس همۀ آن‌ها دشمن من هستند، جز پروردگار جهانیان
  26,78,(همان) کسی‌که مرا آفرید، پس او مرا هدایت می‌کند
  26,79,و کسی‌که او به من غذا می‌دهد و سیراب می‌نماید
  26,80,و هنگامی‌که بیمار شوم پس او مرا شفا می‌دهد
  26,81,و کسی‌که مرا می‌میراند؛ سپس زنده می‌کند
  26,82,و کسی‌که امیدوارم گناهانم را در روز جزا برایم ببخشد
  26,83,پروردگارا! به من (دانش و) حکمت ببخش، و مرا به صالحان ملحق کن
  26,84,و برای من در میان آیندگان آوازۀ نیک (و ذکر خیر) قرار بده
  26,85,و مرا از وارثان بهشت پر نعمت بگردان
  26,86,و پدرم را بیامرز، بی‌گمان او از گمراهان بود
  26,87,و در روزی‌که (همۀ مردم) برانگیخته می‌شوند، مرا رسوا (و شرمنده) مکن
  26,88,روزی‌که مال و فرزندان سودی نبخشد
  26,89,مگر کسی‌که با قلب سلیم (خالی از شرک و کفر و نفاق) به پیشگاه الله بیاید»
  26,90,و (در آن روز) بهشت برای پرهیزگاران نزدیک آورده شود
  26,91,و دوزخ برای گمراهان آشکار کرده شود
  26,92,"و به آن‌ها گفته می‌شود: «کجا هستند آنچه که به جای الله پرستش می‌کردید؟"
  26,93,آیا آن‌ها شما را یاری می‌کنند، یا (خود) انتقام می‌گیرند؟
  26,94,پس آن‌ها و گمراهان (به رو) در آن افکنده می‌شوند
  26,95,و (نیز) همۀ لشکریان ابلیس
  26,96,آن‌ها در آنجا در حالی‌که با یکدیگر مخاصمه می‌کنند، گویند
  26,97,«به الله سوگند که ما در گمراهی آشکار بودیم
  26,98,چون شما را با پروردگار جهانیان برابر می‌دانستیم
  26,99,و کسی جز مجرمان ما را گمراه نکرد
  26,100,پس (اکنون) هیچ شفاعت کنندگانی برای ما نیست
  26,101,و نه هیچ دوست (مخلص و) مهربانی
  26,102,پس ای کاش بار دیگر (به دنیا) باز گردیم، تا از مؤمنان باشیم»
  26,103,بی‌گمان در این (ماجرا) نشانه‌ای (روشن) است، و بیشتر آن‌ها مؤمن نبودند
  26,104,و بی‌تردید پروردگار تو پیروزمند مهربان است
  26,105,قوم نوح پیامبران را تکذیب کردند
  26,106,"هنگامی‌که برادرشان نوح به آن‌ها گفت: «آیا (از الله) نمی‌ترسید؟!»"
  26,107,مسلماً من برای شما پیامبری امین هستم
  26,108,پس از الله بترسید، و مرا اطاعت کنید
  26,109,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی‌طلبم، مزد من تنها بر (عهدۀ) پروردگار جهانیان است
  26,110,پس از الله بترسید، و مرا اطاعت کنید»
  26,111,"گفتند: «آیا به تو ایمان بیاوریم در حالی‌که فرومایگان از تو پیروی کرده‌اند؟!»"
  26,112,"(نوح) گفت: «من چه می‌دانم آن‌ها چه کار‌ها کرده‌اند"
  26,113,اگر می‌فهمید، حساب آن‌ها تنها با پروردگار من است
  26,114,و من (هرگز) مؤمنان را طرد نخواهم کرد
  26,115,من جز بیم دهندۀ آشکار نیستم»
  26,116,"گفتند: «ای نوح! اگر (از دعوتت) دست بر نداری، حتماً سنگسار خواهی شد»"
  26,117,"(نوح) گفت: «پروردگارا! همانا قوم من، مرا تکذیب کردند"
  26,118,پس میان من و آن‌ها داوری کن، و مرا و مؤمنانی را که با من هستند؛ نجات بده»
  26,119,پس او و کسانی را که همراه او بودند، در (آن) کشتی پر (و انباشته) نجات دادیم
  26,120,سپس بقیه را غرق کردیم
  26,121,بی‌گمان در این (ماجرا) نشانه‌ای (روشن) است، و بیشتر آن‌ها مؤمن نبودند
  26,122,و بی‌تردید پروردگار تو پیروزمند مهربان است
  26,123,(قوم) عاد (نیز) پیامبران (الله) را تکذیب کردند
  26,124,"هنگامی‌که برادر‌شان هود به آن‌ها گفت: «آیا (از الله) نمی‌ترسید؟!»"
  26,125,به راستی من برای شما پیامبری امین هستم
  26,126,پس از الله بترسید، و مرا اطاعت کنید
  26,127,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی‌طلبم، مزد من تنها بر (عهدۀ) پرودگار جهانیان است
  26,128,آیا بر هر مکان مرتفعی نشانه‌ای (از روی هوا و هوس و) بیهوده می‌سازید؟
  26,129,و قصر‌ها (و قلعه‌های) محکم و استوار بنا می‌کنید، گویی که (در دنیا) جاودانه می‌مانید
  26,130,و چون (کسی را) کیفر دهید، همچون جباران کیفر می‌دهید
  26,131,پس از الله بترسید و مرا اطاعت کنید
  26,132,و از کسی بترسید که شما را به آنچه می‌دانید مدد کرده است
  26,133,شما را به چهارپایان و فرزندان مدد (و یاری) فرموده است
  26,134,و (همچنین به) باغ‌ها و چشمه‌‌ها
  26,135,همانا من از عذاب روزی بزرگ بر شما می‌ترسم!»
  26,136,"گفتند: «برای ما یکسان است، چه ما را پند دهی یا پند ندهی"
  26,137,این جز (همان) روش پیشینیان نیست
  26,138,و ما (هرگز) عذاب نخواهیم شد»
  26,139,پس او (= هود) را تکذیب کردند، در نتیجه ما آن‌ها را هلاک کردیم، بی‌گمان در این (ماجرا) نشانه‌ای است، و بیشتر آن‌ها مؤمن نبودند
  26,140,و بی‌تردید پروردگار تو پیروزمند مهربان است
  26,141,(قوم) ثمود پیامبران (الله) را تکذیب کردند
  26,142,"هنگامی‌که برادر‌شان صالح به آن‌ها گفت: «آیا (از الله) نمی‌ترسید؟"
  26,143,بی‌گمان من برای شما پیامبری امین هستم
  26,144,پس از الله بترسید و مرا اطاعت کنید
  26,145,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی‌طلبم، مزد من تنها بر (عهدۀ) پروردگار جهانیان است
  26,146,آیا (می پندارید که) شما در (نعمت‌‌‌هایی) اینجا ایمن رها خواهید شد؟
  26,147,در (این) باغ‌ها و چشمه‌ها
  26,148,و (در این) زراعت‌ها و نخل‌هایی که شکوفه‌هایش (نرم و) رسیده است؟
  26,149,و شادمانه از کوه‌ها خانه‌هایی می‌تراشید؟
  26,150,پس از الله بترسید و مرا اطاعت کنید
  26,151,و فرمان اسراف کاران را اطاعت نکنید
  26,152,(همان) کسانی‌که در زمین فساد می‌کنند و اصلاح نمی‌کنند»
  26,153,"گفتند: «(ای صالح) جز این نیست که تو از جادوشدگانی"
  26,154,تو جز بشری همانند ما نیستی، پس اگر از راستگویانی نشانه‌ای بیاور»
  26,155,"(صالح) گفت: «این ماده شتری است، که برای او یک نوبت آب خوردن، و برای شما (نیز) نوبت روز معینی است"
  26,156,و (کمترین) آزاری به آن نرسانید، که عذاب روزی بزرگ شما را فرو می‌گیرد»
  26,157,پس آن را پی کردند، آنگاه (از کردۀ خود) پشیمان شدند
  26,158,پس عذاب (الهی) آن‌ها را فرو گرفت، بی‌گمان در این (ماجرا) نشانه‌ای است، و بیشتر آن‌ها مؤمن نبودند
  26,159,و بی‌تردید پروردگار تو پیروزمند مهربان است
  26,160,قوم لوط (نیز) پیامبران (الله) را تکذیب کردند
  26,161,"هنگامی‌که برادر‌شان لوط به آن‌ها گفت: «آیا (از الله) نمی‌ترسید؟"
  26,162,بی‌گمان من برای شما پیامبری امین هستم
  26,163,پس از الله بترسید، و مرا اطاعت کنید
  26,164,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی‌طلبم، مزد من تنها بر (عهدۀ) پروردگار جهانیان است
  26,165,آیا در میان جهانیان شما به سراغ مردان می‌روید؟
  26,166,و همسرانی‌که الله برای شما آفریده است؛ رها می‌کنید، بلکه شما قومی متجاوز هستید
  26,167,"گفتند: «ای لوط، اگر دست بر نداری، یقیناً از اخراج شدگان خواهی بود»"
  26,168,"(لوط) گفت: «من دشمن سرسخت عمل شما هستم"
  26,169,پروردگارا! من و خانواده ام را از (عاقبت) آنچه (این‌ها) انجام می‌دهند، نجات بده»
  26,170,پس او و خانواده‌اش را همگی نجات دادیم
  26,171,مگر پیر زنی که در میان بازماندگان بود
  26,172,سپس دیگران را نابود ساختیم
  26,173,و بر آن‌ها بارانی (از سنگ) بارانیدیم، پس باران بیم داده شدگان چه بد بود
  26,174,بی‌گمان در این (ماجرا) نشانه‌ای است، و بیشتر آن‌ها مؤمن نبودند
  26,175,و بی‌تردید پروردگار تو پیروزمند مهربان است
  26,176,اصحاب ایکه (= قوم شعیب) پیامبران (الله) را تکذیب کردند
  26,177,"هنگامی‌که شعیب به آن‌ها گفت: «آیا (از الله) نمی‌ترسید؟"
  26,178,همانا من برای شما پیامبری امین هستم
  26,179,پس از الله بترسید، و مرا اطاعت کنید
  26,180,و من بر (رساندن) این (دعوت) هیچ مزدی از شما نمی‌طلبم، مزد من تنها بر (عهدۀ) پروردگار جهانیان است
  26,181,پیمانه را تمام بدهید، و از کاهندگان (و کم فروشان) نباشید
  26,182,و با ترازوی درست وزن کنید
  26,183,و چیز‌های مردم را کم ندهید (و حق آن‌ها را ضایع نکنید) و در زمین به فساد نکوشید
  26,184,و از کسی‌که شما و آفریدگان نخستین را آفرید بترسید
  26,185,"گفتند: «(ای شعیب!) جز این نیست که تو از جادو شدگانی،"
  26,186,تو جز بشری همانند ما نیستی، و تو را از دروغگویان می‌پنداریم
  26,187,پس اگر از راستگویانی، پاره‌ای از آسمان را بر (سر) ما بینداز»
  26,188,"(شعیب) گفت: «پروردگارم! به آنچه انجام می‌دهید؛ داناتر است"
  26,189,پس او را تکذیب کردند، آنگاه عذاب روز سایه آن‌ها را فرو گرفت، بی‌گمان آن عذاب روز بزرگی بود
  26,190,بی‌گمان در این (ماجرا) نشانه‌ای است، و بیشتر آن‌ها مؤمن نبودند
  26,191,و بی‌تردید پروردگار تو پیروزمند مهربان است
  26,192,و همانا این (قرآن) نازل شده (از جانب) پروردگار جهانیان است
  26,193,روح الامین (= جبرئیل) آن را فرود آورده است
  26,194,بر قلب تو، تا از هشدار دهندگان باشی
  26,195,(آن را) به زبان عربی روشن (نازل کرد)
  26,196,و همانا (توصیف) آن در کتاب‌های پیشینیان (نیز آمده) است
  26,197,"آیا همین نشانه برای آن‌ها کافی نیست که علمای بنی اسرائیل [ مانند عبدالله بن سلام رضی الله عنه و دیگران. (تفسیر ابن کثیر)] از آن (قرآن) آگاهند؟"
  26,198,و اگر آن را بر بعضی از عجمیان (= غیر عرب‌ها) نازل می‌کردیم
  26,199,پس او آن را برایشان می‌خواند، به آن ایمان نمی‌آورند
  26,200,(آری) این گونه آن (تکذیب) را در دل‌های مجرمان در آوردیم
  26,201,به آن ایمان نمی‌آورند تا عذاب دردناک را (با چشم خود) ببینند
  26,202,پس ناگهان در حالی‌که بی‌خبرند به سراغ آن‌ها می‌آید
  26,203,"آنگاه می‌گویند: «آیا مهلتی به ما داده خواهد شد؟!»"
  26,204,آیا برای عذاب ما شتاب می‌کنند؟
  26,205,آیا دیدی که اگر سالیانی آن‌ها را (از این زندگی دنیا) بهره‌مند سازیم
  26,206,سپس آنچه که به آن‌ها وعده داده شده است به سراغ‌شان بیاید
  26,207,این بهره‌مندیشان (از دنیا) سودی برای آن‌ها نخواهد داشت
  26,208,و هیچ قریه‌ای را هلاک نکردیم؛ مگر این‌که هشدار دهندگانی (از پیامبران) داشتند
  26,209,برای پند دادن، و ما هرگز ستمکار نبودیم
  26,210,و شیطان‌ها (هرگز) این (قرآن) را نازل نکرده‌اند
  26,211,و برای آن‌ها سزاوار نیست؛ و نمی‌توانند
  26,212,بی‌گمان آن‌ها از شنیدن (وحی، و استراق سمع) برکنارند
  26,213,پس (ای پیامبر!) هیچ معبودی را با الله مخوان، که از عذاب شدگان خواهی بود
  26,214,و خویشاوندان نزدیکت را هشدار بده
  26,215,و بال (رحمت و فروتنی) خود را برای مؤمنانی‌که از تو پیروی می‌کنند؛ بگستر
  26,216,"پس اگر از (فرمان) تو سرپیچی کردند، بگو: «همانا من از آنچه انجام می‌دهید؛ بیزارم»"
  26,217,و بر الله پیروزمند مهربان توکل کن
  26,218,(همان) کسی‌که تو را به هنگامی‌که (برای عبادت) بر می‌خیزی می‌بیند
  26,219,و (نیز) حرکت (و نشست و بر خاست) تو را میان سجده‌کنندگان (می‌بیند)
  26,220,همانا او شنوای داناست
  26,221,آیا به شما خبردهم که شیاطین بر چه کسی نازل می‌شوند؟
  26,222,بر هر دروغگوی گنهکار نازل می‌گردند
  26,223,(به شیاطین) گوش فرا می‌دهند و بیشترشان دروغگو هستند
  26,224,و شاعران (کسانی) هستند که گمراهان از آن‌ها پیروی می‌کنند
  26,225,آیا ندیدی که آن‌ها در هر وادیی سرگشته (و حیران) هستند؟
  26,226,و بی‌گمان آن‌ها چیزی می‌گویند که (خود به آن) عمل نمی‌کنند؟
  26,227,مگر کسانی‌که ایمان آوردند و کارهای شایسته انجام دادند و الله را بسیار یاد کردند، و بعد از آن که ستم دیدند، انتقام گرفتند، (و با شعر خود از اسلام و مسلمین دفاع نمودند)، و کسانی‌که ستم کردند؛ به زودی خواهند دانست به چه بازگشتگاهی باز می‌گردند
  27,1,طس (طا. سین) این آیات قرآن و کتاب مبین است
  27,2,که هدایت و بشارت برای مؤمنان است
  27,3,(همان) کسانی‌که نماز را بر پا می‌دارند، و زکات را ادا می‌کنند، و آنان به آخرت یقین دارند
  27,4,بی‌گمان کسانی‌که به آخرت ایمان نمی‌آورند، اعمال‌شان را برای آن‌ها زینت داده‌ایم، پس آن‌ها سرگردان می‌شوند
  27,5,آن‌ها کسانی هستند که عذاب بد (و درد ناک) برایشان است، و آن‌ها در آخرت زیانکارترینند
  27,6,و بی‌تردید تو (این) قرآن را از سوی (الله) حکیم دانا دریافت می‌داری
  27,7,"(به یاد بیاور) هنگامی را که موسی به خانوادۀ خود گفت: «(بایستید) همانا من آتشی (از دور) دیده‌ام، به‌زودی خبری از آن برای شما می‌آورم یا شعلۀ آتشی از آن می‌آورم تا گرم شوید»"
  27,8,"پس چون به آن (آتش) رسید، ندا داده شد که: «مبارک باد کسی‌که در آتش است و کسی‌که پیرامون آن است. و منزه است الله که پروردگار جهانیان است"
  27,9,ای موسی! همانا من الله پیروزمند حکیم هستم
  27,10,و عصایت را بیفکن- پس چون آن را دید که (با سرعت) می‌جنبد، گویی که آن ماری است، (ترسید و) به عقب برگشت، و پشت سر خود نگاه نکرد- ای موسی! نترس، که پیامبران در نزد من نمی‌ترسند
  27,11,مگر کسی‌که ستم کند، پس (توبه کند و) بدی را به نیکی تبدیل نماید، پس بی‌گمان من آمرزندۀ مهربان هستم
  27,12,و دستت را در گریبانت فرو کن، که سفید (و درخشندۀ) بی‌عیب بیرون بیاید، (این معجزه) در زمرۀ معجزات نه‌گانه است، به‌سوی فرعون و قومش (برو) که آن‌ها قومی فاسقند»
  27,13,"پس چون آیات روشن (و کاملاً آشکار) ما به سراغ آن‌ها آمد؛ گفتند: «این جادویی آشکار است»"
  27,14,و آن را از روی ستم و سرکشی انکار کردند، در حالی‌که دل‌هایشان به آن یقین داشت، پس بنگر عاقبت مفسدان چگونه بود
  27,15,"و به‌راستی به داوود و سلیمان دانش (عظیمی) دادیم، و (آنان) گفتند: «ستایش از آن الله است که ما را بر بسیاری از بندگان مؤمن خود برتری بخشید»"
  27,16,"و سلیمان وارث داوود شد، و گفت: «ای مردم! زبان پرندگان به ما آموخته شده، و از هر چیز به ما عطا شده، بی‌تردید این فضل آشکاری است»"
  27,17,و برای سلیمان لشکریانش از جن و انس و پرندگان گرد آورده شدند، آنگاه نگاه داشته شدند (تا همۀ آن‌ها به یکدیگر بپیوندند)
  27,18,"(بعد حرکت کردند) تا هنگامی‌که به وادی مورچگان رسیدند، مورچه‌ای گفت: «ای مورچگان! به لانه‌های خود بروید تا سلیمان و لشکریانش شما را پایمال نکنند در حالی‌که نمی‌فهمند»"
  27,19,"پس (سلیمان) از سخن آن (مورچه) تبسمی کرد (و) خندید، گفت: «پروردگارا! به من توفیق ده تا شکر نعمت‌هایی را که بر من و بر پدر و مادرم ارزانی داشتۀ بجای آورم، و (توفیق عطا فرما تا) کار(های) شایسته‌ای که تو خشنود شوی، انجام دهم، و مرا به رحمت خود در (زمرۀ) بندگان صالحت در آور»"
  27,20,"و (سلیمان) از حال پرندگان جویا شد، و گفت: «مرا چه شده است که هدهد را نمی‌بینم، یا اینکه او از غایبان است؟"
  27,21,قطعاً او را به کیفر شدید کیفر خواهم داد، یا او را ذبح خواهم کرد، یا (باید) دلیلی روشن (برای غیبتش) برای من بیاورد»
  27,22,"پس درنگش چندان طول نکشید (که هدهد آمد) آنگاه گفت: «من به چیزی دست یافته‌ام که تو به آن دست نیافته‌ای، و از (سرزمین) سبا برایت خبر قطعی آورده‌ام"
  27,23,من زنی را یافتم که بر آن‌ها فرمانروایی می‌کند، و (به او) از هرگونه نعمتی داده شده است، و تخت عظیمی دارد
  27,24,او و قومش را دیدم که به جای الله برای خورشید سجده می‌کنند، و شیطان اعمال آن‌ها را در نظر‌‌‌‌‌شان آراسته پس آن‌ها را از راه (الله) باز داشته است، از این رو آن‌ها هدایت نمی‌شوند»
  27,25,چرا برای الله سجده نمی‌کنند که آنچه را در آسمان‌ها و زمین پنهان است بیرون می‌آورد، و آنچه را پنهان می‌دارید و آنچه را آشکار می‌کنید (همه را) می‌داند
  27,26,الله که جز او معبودی نیست، پروردگار عرش عظیم است
  27,27,"(سلیمان) گفت: «اکنون خواهیم دید که آیا راست گفته‌ای یا از دروغ‌گویان هستی"
  27,28,این نامۀ مرا ببر، و بر آن‌ها بیفکن، سپس از آن‌ها روی بگردان، پس (در گوشه‌ای توقف کن) بنگر که چه جواب می‌دهند»
  27,29,"(ملکۀ سبا) گفت: «ای بزرگان، به راستی نامۀ پر ارزشی به سوی من افکنده شده"
  27,30,"همانا آن (نامه) از سلیمان است، و چنین است: به نام الله بخشندۀ مهربان"
  27,31,بر من برتری مجویید، و تسلیم شده نزد من بیایید»
  27,32,"(ملکه) گفت: «ای بزرگان، در کار من رأی دهید، که من هیچ کار مهمی را بدون حضور (و مشورت) شما تصمیم نگرفته‌ام (و انجام نداده‌ام)»"
  27,33,"گفتند: «ما دارای نیروی کافی و جنگ‌جویانِ با قدرتی هستیم، و اختیار (و تصمیم نهایی) با توست، پس بنگر که چه فرمان می‌دهی»"
  27,34,"گفت: «بی‌تردید پادشا‌‌‌هان هنگامی‌که وارد قریه‌ای شوند آن را ویران (و تباه) سازند، و عزیزانش را ذلیل می‌کنند، و این گونه رفتار می‌کنند"
  27,35,و همانا من هدیه‌ای برای آن‌ها می‌فرستم، پس می‌نگرم که فرستادگان چه جواب می‌آورند»
  27,36,"پس چون (فرستادۀ ملکه) نزد سلیمان آمد، (سلیمان) گفت: «آیا می‌خواهید مرا با مال یاری کنید؟! آنچه الله به من داده، بهتر است از آنچه به شما داده است. بلکه شما به هدیۀتان شادمان می‌شوید"
  27,37,(اکنون) به سوی آن‌ها باز گرد، پس البته با لشکریانی به سوی آن‌ها خواهیم آمد که قدرت مقابله با آن را نداشته باشند، و بی‌تردید آن‌ها را از آن (سرزمین) با ذلت و خواری بیرون می‌کنیم!»
  27,38,"(سلیمان) گفت: «ای بزرگان! کدام‌یک از شما تخت او را برای من می‌آورد، پیش از آن‌که تسلیم شده نزد من آیند؟»"
  27,39,"عفریتی از جن گفت: «من آن را نزد تو می‌آورم پیش از آنکه از جایت برخیزی، و همانا من بر آن توانای امین هستم»"
  27,40,"کسی‌که دانشی از کتاب (الهی) داشت گفت: «من پیش از آن‌که چشم بر هم زنی، آن را نزد تو می‌آورم». پس چون (سلیمان) آن (تخت) را نزد خود مستقر دید؛ گفت: «این از فضل پروردگار من است، تا مرا بیازماید که آیا شکر او را به جای می‌آورم یا ناسپاسی می‌کنم!» پس هر که شکر کند، تنها به نفع خود شکر می‌کند، و هر که ناسپاسی کند پس (به زیان خود نموده است،) بی‌گمان پروردگار من بی‌نیاز کریم است"
  27,41,"(سلیمان) گفت: «تخت او را برایش ناشناس کنید، (تا) ببینیم آیا (آن را) باز می‌شناسد، یا از آن‌هاست که باز نتوانند شناخت"
  27,42,"پس چون (ملکۀ سبا) آمد، (به او) گفته شد: «آیا تخت تو این گونه است؟» گفت: «گویی همان است، و ما پیش از این هم (به قدرت الله و حقانیت سلیمان) دانش یافته بوده‌ایم، و مسلمان (و فرمانبردار) بودیم"
  27,43,و آنچه به جای الله می‌پرستید او را (از ایمان به الله) باز داشته بود، بی‌گمان او (= ملکه سبا) از قوم کافران بود
  27,44,"به او گفته شد: «به صحن (قصر) داخل شو» پس هنگامی‌که آن را دید پنداشت که آب عمیقی است، و دو ساق (پای) خود را برهنه کرد (تا از آب بگذرد، سلیمان) گفت: «(این آب نیست) این صحنی صاف از آبگینه است». (ملکه) گفت: «پروردگارا! من به خود ستم کردم، و (اینک) با سلیمان برای الله پروردگار جهانیان تسلیم شدم»"
  27,45,"و به راستی به سوی (قوم) ثمود، برادر‌شان صالح را فرستادیم که: الله یگانه را بپرستید، آنگاه آن‌ها دو گروه شدند که به مخاصمه پرداختند"
  27,46,"(صالح) گفت: «ای قوم من! چرا پیش از نیکی بر بدی می‌شتابید (و بجای رحمت، عذاب الهی را می‌طلبید) چرا از الله آمرزش نمی‌خواهید، تا شاید مورد رحمت قرار گیرید؟!»"
  27,47,"گفتند: «ما به تو و کسانی‌که با تو هستند فال بد زده‌ایم» (صالح) گفت: «فال بد شما نزد الله است، بلکه شما گروهی هستید که مورد آزمایش قرار می‌گیرید»"
  27,48,و در (آن) شهر (حِجر) نُه نفر بودند که در زمین فساد می‌کردند و اصلاح نمی‌کردند
  27,49,"گفتند: «به الله سوگند یاد کنید که حتماً بر او (= صالح) و خانواده‌اش شبیخون می‌زنیم، (و آن‌ها را می‌کشیم) سپس به ولی (دم) او می‌گوییم: ما هنگام هلاکت و نابودی خانواده‌اش؛ هرگز حاضر نبودیم (و از آن‌ها خبر نداریم) و بی‌گمان ما راستگو هستیم»"
  27,50,و آن‌ها (برای قتل صالح و پیروانش) حیله و نیرنگی به کار بردند و ما (نیز) حیله و تدبیری (برای هلاک آن‌ها و نجات صالح و پیروانش) اندیشیدیم، در حالی‌که آن‌ها نمی‌دانستند
  27,51,پس بنگر عاقبت نیرنگ‌شان چه شد؟! ما آن‌ها و قوم‌شان همگی را نابود کردیم
  27,52,پس این خانه‌های آن‌هاست که به سزای ستمی که می‌کردند خالی مانده است، بی‌گمان در این (ماجرا) نشانه‌ای است برای گروهی که می‌دانند
  27,53,و کسانی را که ایمان آورده، و پرهیزگار بودند، نجات دادیم
  27,54,"و لوط را (به یاد آور) هنگامی‌که به قومش گفت: «آیا کار بسیار زشت (لواط) مرتکب می‌شوید؛ در حالی‌که خود (سرانجام و زشتی آن را) می‌بینید؟"
  27,55,آیا شما به جای زنان، از روی شهوت سراغ مردان می‌روید؟! بلکه شما مردمی نادان هستید»
  27,56,"پس جواب قومش جز این نبود که (به یکدیگر) گفتند: «خاندان لوط را از قریۀ خود بیرون کنید، که این‌ها مردمانی (پاکدامن و) پاکیزه‌جو هستند!»"
  27,57,آنگاه او و خانواده‌اش را نجات دادیم؛ مگر همسرش که مقدر کردیم او از بازماندگان (در آن شهر) باشد
  27,58,و بارانی (از سنگ) بر (سر) آن‌ها باراندیم، پس باران بیم داده‌شدگان چه بد است
  27,59,"(ای پیامبر) بگو: «حمد و سپاس مخصوص الله است، و سلام بر بندگانش، کسانی‌که او (آن‌ها را) بر گزیده است». آیا الله بهتر است یا آن چیزهای که شرک می‌آورند؟"
  27,60,(آیا این معبودان باطل شما بهترند) یا کسی‌که آسمان‌ها و زمین را آفرید، و از آسمان برای شما آبی نازل کرد، پس با آن باغ‌های خرم (و زیبا) رویاندیم، که شما هرگز توان رویاندن درختان آن را نداشتید، آیا معبودی دیگری با الله است؟! (نه) بلکه آن‌ها گروهی هستند که (از حق منحرف می‌شوند و بت‌ها را) هم‌طراز (الله) قرار می‌دهند
  27,61,(آیا این بت‌ها بهترند) یا کسی‌که زمین را قرارگاه ساخت، و میان آن نهر‌هایی قرار داد، و برای آن کوه‌‌های (ثابت و استوار) پدید آورد، و میان دو دریا مانعی قرار داد، آیا معبود دیگری با الله است؟! (نه) بلکه بیشتر‌شان نمی‌دانند
  27,62,(آیا این بت‌ها بهترند) یا کسی‌که (دعای) مضطر (= درمانده) را اجابت می‌کند؛ چون او را بخواند، و گرفتاری را بر طرف می‌سازد، و شما را جانشینان زمین قرار می‌دهد، آیا معبودی دیگری با الله است؟! چه اندک پند می‌گیرید
  27,63,(آیا این بت‌ها بهترند) یا کسی‌که شما را در تاریکی‌های بیابان و دریا هدایت می‌کند، و کسی‌که پیش از (باران) رحمت خود باد‌ها را به مژده می‌فرستد، آیا معبودی دیگر با الله است؟! الله برتر است از آنچه برای او شریک قرار می‌دهند
  27,64,"(آیا این معبودان باطل بهترند) یا کسی‌که آفرینش را آغاز کرد، سپس آن را (بار دیگر) باز می‌گرداند، و کسی‌که شما را از آسمان و زمین روزی می‌دهد، آیا معبود دیگری با الله است؟! (ای پیامبر!) بگو: «اگر راست می‌گویید دلیل‌تان را بیاورید»"
  27,65,"بگو: «در آسمان‌ها و زمین جز الله هیچ کس غیب نمی‌داند و (آن معبودان باطل) نمی‌دانند که کی برانگیخته می‌شوند"
  27,66,بلکه علم آن‌ها (= مشرکان) دربارۀ آخرت به پایان رسیده است (و هیچ اطلاعی ندارند) بلکه آن‌ها در (وقوع) آن شک دارند، بلکه آن‌ها نسبت به آن نابینایند
  27,67,"و کسانی‌که کافر شدند؛ گفتند: «آیا هنگامی‌که ما و پدران مان خاک شدیم، آیا (باز زنده می‌شویم و از گور‌ها) بیرون آورده می‌شویم؟"
  27,68,به راستی این وعده‌ای است که از پیش به ما و نیاکان‌مان داده شده است، این جز افسانه‌های پیشینیان نیست»
  27,69,"(ای پیامبر!) بگو: «در زمین سیر کنید، پس بنگرید عاقبت مجرمان چگونه بود»"
  27,70,و بر آن‌ها غمگین مباش و از آنچه مکر می‌ورزند؛ دل‌تنگ نشو
  27,71,"و می‌گویند: «اگر راست می‌گویید، این وعده کی خواهد بود؟!»"
  27,72,"(ای پیامبر!) بگو: «شاید پاره‌ای از آنچه را که به شتاب می‌طلبید به شما نزدیک شده‌باشد»"
  27,73,و بی‌گمان پروردگار تو نسبت به مردم دارای فضل (و رحمت) است، و لیکن بیشترشان شکر نمی‌گزارند
  27,74,و بی‌تردید پروردگار تو آنچه در سینه‌هایشان پنهان می‌دارند و آنچه را آشکار می‌کنند؛ بخوبی می‌داند
  27,75,و هیچ پنهانی در آسمان و زمین نیست؛ مگر آن‌که در کتاب روشن (لوح محفوظ، نوشته شده) است
  27,76,بی‌گمان این قرآن بر بنی اسرائیل بیشتر چیزهایی را که آن‌ها در آن اختلاف دارند، بیان می‌کند
  27,77,و به راستی آن (قرآن) هدایت و رحمت برای مؤمنان است
  27,78,مسلماً پروردگار تو میان آن‌ها (در قیامت) به حکم خود داوری می‌کند، و او پیروزمند داناست
  27,79,پس (ای پیامبر!) بر الله توکل کن، بی‌شک تو بر حق آشکار هستی
  27,80,و بی‌گمان تو نمی‌توانی (سخنت را) به (گوش) مردگان بشنوانی، و نمی‌توانی کران را هنگامی‌که پشت‌کنان روی می‌گردانند؛ سخن (و نِدای خود را) بشنوانی
  27,81,و تو نمی‌توانی کوران را از گمراهی‌شان (باز گردانی و) هدایت کنی، تو تنها می‌توانی (سخن خود را) به کسانی بشنوانی که به آیات ما ایمان دارند؛ پس آن‌ها (در برابر حق) تسلیم شدگان هستند
  27,82,و هنگامی‌که فرمان (عذاب) بر آن‌ها واقع شود (و حادثۀ قیامت نزدیک شود) جنبنده‌ای را از زمین برای آن‌ها بیرون می‌آوریم که با آن‌ها سخن گوید، که مردم به آیات ما یقین نمی‌آورند
  27,83,و (به یاد آور) روزی را که ما از هر امتی گروهی را از آنان که آیات ما را تکذیب می‌کردند؛ محشور می‌کنیم، آنگاه آن‌ها (به صف) نگاه داشته می‌شوند
  27,84,"تا هنگامی‌که (به سرزمین محشر) می‌آیند (الله) می‌فرماید: «آیا مرا تکذیب کردید در حالی‌که به آن احاطۀ علمی نداشتید، یا چه (کاری) بود که می‌کردید؟!»"
  27,85,و بخاطر ستمی که کرده‌اند؛ فرمان (عذاب) بر آن‌ها واقع می‌شود، پس آن‌ها هیچ سخنی نمی‌گویند
  27,86,آیا ندیدند که ما شب را برای آرامش آن‌ها قرار دادیم، و روز را روشنی بخش (قرار دادیم) بی‌گمان در این (امور) نشانه‌های (روشنی) است برای گروهی که ایمان می‌آورند
  27,87,و (به یاد آور) روزی را که در صور دمیده می‌شود، پس (تمام) کسانی‌که در آسمان‌ها و زمین هستند وحشت کنند (و بترسند) جز کسی‌که الله بخواهد، و همگی با خواری (و ذلت) به پیشگاه او (تعالی) بیایند
  27,88,و کوه‌ها را می‌بینی، (و) آن‌ها را جامد (و بی‌حرکت) پنداری، در حالی‌که مانند حرکت ابر‌ها در حرکت هستند (این) صنع (و آفرینش) اللهِ است که هر چیزی را محکم (و استوار) ساخته است، بی‌گمان او از آنچه انجام می‌دهید؛ با خبر است
  27,89,هر کس‌که نیکی آورد، پس (پاداشی) بهتر از آن خواهد داشت، و آنان از وحشت آن روز در امان هستند
  27,90,"و هر کس که بدی آورد، پس چهره‌های‌شان در آتش نگونسار شود، (و به آن‌ها گفته می‌شود:) آیا جزایی جز آنچه می‌کردید به شما داده می‌شود؟"
  27,91,"(ای پیامبر! بگو:) من فقط مأمورم که پروردگار این شهر (مکه) را عبادت کنم، همان کسی‌که این (شهر) را حرمت بخشید، و همه چیز از آنِِ اوست، و من مأمورم که از مسلمانان باشم"
  27,92,"و این‌که قرآن را تلاوت کنم، پس هر کس هدایت شود به نفع خود هدایت شده است، و هر کس که گمراه گردد؛ بگو: «من فقط از هشدار ‌دهندگان هستم»"
  27,93,"و بگو: «حمد و ستایش مخصوص الله است، به زود آیاتش را به شما نشان می‌دهد، پس آن‌ها را خواهید شناخت، و پروردگار تو از آنچه انجام می‌دهید؛ غافل نیست"
  28,1,طسم (طا. سین. میم)
  28,2,این آیات کتاب مبین است
  28,3,از داستان موسی و فرعون به حق بر تو می‌خوانیم، برای گروهی که ایمان می‌آورند
  28,4,بی‌گمان فرعون در زمین برتری جست و اهل آن را گروه گروه کرد، گروهی از آن‌ها را به ضعف و ناتوانی می‌کشاند، پسران‌شان را سر می‌برید و زنان‌شان را (برای خدمت) زنده نگه می‌داشت، بی‌تردید او از مفسدان بود
  28,5,و می‌خواهیم بر کسانی‌که در زمین به استضعاف کشیده شده‌اند، منت گذاریم و آنان را پیشوایان سازیم، و آنان را وارثان (زمین) قرار دهیم
  28,6,"و آن‌ها را در زمین تمکّن (و حکومت) دهیم و به فرعون و هامان و لشکریان آن دو، از (دست) آن‌ها (= بنی اسرائیل) آنچه را که از آن می‌ترسیدند، نشان دهیم [ یعنی آن اندیشه‌ای که تخت فرعون و لشکر او به دست یک شخص اسرائیلی نابود خواهد شد ما آن را به حقیقت در آوردیم]"
  28,7,"و به مادر موسی الهام کردیم که: «او را شیر بده، پس هنگامی‌که بر او ترسیدی، او را به دریای (نیل) بینداز، و نترس، و اندوهگین مشو، یقیناً ما او را به تو باز می‌گردانیم و او را از پیامبران قرار می‌دهیم»"
  28,8,پس (هنگامی‌که مادر موسی او را به دریا افکند) خاندان فرعون او را (از آب) بر گرفتند، تا سرانجام دشمن و مایۀ اندوه‌شان شود، مسلماً فرعون و هامان و لشکریان‌شان خطا کار بودند
  28,9,"و (آسیه) همسر فرعون گفت: «(این کودک) نور چشم من و توست! او را نکشید، شاید به ما سود بخشد، یا او را به فرزندی گیریم» و آنان (از عاقبت آن) بی‌خبر بودند (و نمی‌فهمیدند)"
  28,10,و قلب مادر موسی (از همه چیز) تهی گشت، اگر دل او را (به ایمان) محکم نکرده بودیم تا از باور دارندگان باشد، نزدیک بود آن (راز) را فاش کند
  28,11,"و (مادر موسی) به خواهر او گفت: «به دنبالش برو» پس (خواهرش) او را از دور دید، در حالی‌که آن‌ها بی‌خبر بودند"
  28,12,"و (پستان) همۀ زنان شیر‌ده را از پیش بر او حرام کردیم، آنگاه (خواهرش) گفت: «آیا شما را به خانواده‌ای راهنمایی کنم که او را برایتان نگه دارند در حالی‌که آن‌ها خیر خواه او باشند؟!»"
  28,13,پس او را به مادرش باز گرداندیم تا چشمش روشن شود و غمگین نباشد، و تا بداند که وعدۀ الله حق است، و لیکن بیشتر آن‌ها نمی‌دانند
  28,14,و چون (موسی) به (مرحلۀ بلوغ و) کمال قوت رسید و برومند شد، به او حکمت و علم دادیم، و این گونه نیکو‌کاران را پاداش می‌دهیم
  28,15,"او هنگامی به شهر وارد شد که اهل آن در غفلت بودند، ناگهان دو مرد را دید با هم نزاع (و جنگ) می‌کردند، یکی از آن‌ها از پیروان او بود، و دیگری از دشمنانش، پس آن که از پیروان او بود بر (علیه) کسی‌که از دشمنانش بود از وی یاری خواست. پس (موسی) به او مشت (محکمی) زد و کارش را ساخت، (و مُرد، موسی) گفت: «این از عمل شیطان بود، بی‌گمان او دشمن گمراه‌کنندۀ آشکاری است»"
  28,16,"(سپس) گفت: «پروردگارا! من به خود ستم کردم، پس مرا ببخش» آنگاه (الله) او را بخشید، بی‌تردید او آمرزندۀ مهربان است"
  28,17,"گفت: «پروردگارا! به شکرانۀ نعمتی که بر من عطا کردی، پس هرگز پشتیبان مجرمان نخواهم بود»"
  28,18,"پس (موسی) در شهر ترسان، و چشم به راهِ حادثه (شب را) صبح نمود، که ناگهان (دید) همان کسی‌که دیروز از او یاری خواسته بود، او را فریاد می‌زند (و کمک می‌خواهد) موسی به او گفت: «بی‌گمان تو آشکارا (انسان ماجرا جو و) گمراه هستی»"
  28,19,"پس هنگامی‌که (موسی) خواست به کسی‌که دشمن هر دوی آن‌ها بود، حمله برد (و بزند، او فریاد زد و) گفت: «ای موسی! آیا می‌خواهی مرا بکشی همان گونه که دیروز کسی را کشتی؟! تو فقط می‌خواهی در زمین جبّاری باشی، و نمی‌خواهی که از مصلحان باشی!»"
  28,20,"و (در این هنگام) مردی از دورترین نقطۀ شهر شتابان آمد (و) گفت: «ای موسی! همانا بزرگان (و اشراف قوم) دربارۀ تو مشورت می‌کنند؛ تا تو را بکشند، پس بی‌درنگ (از شهر) بیرون شو، بی‌تردید من از خیر خواهان تو هستم»"
  28,21,"پس ترسان و چشم به راه حادثه، از شهر بیرون شد، گفت: «پروردگارا! مرا از قوم ستمکار نجات بده»"
  28,22,"و هنگامی‌که به (جانب شهر) مدین رو آورد؛ گفت: «امید است پروردگارم مرا به راه راست هدایت کند»"
  28,23,"و چون به (چاه) آب مدین رسید، بر آن (چاه) گروهی از مردم را دید که (چهارپایان خود را) آب می‌دهند، و در کنار آنان دو زن را دید که (گوسفندان خود را) باز می‌دارند (و به چاه نزدیک نمی‌شوند، موسی) گفت: «کار شما چیست؟ (چرا گوسفند‌‌ان خود را آب نمی‌دهید؟!) گفتند: «ما (آن‌ها را) آب نمی‌دهیم تا چوپان‌ها باز گردند (و بروند) و پدر ما پیر کهن‌سال است (و توانایی این کار را ندارد)»"
  28,24,"پس (موسی) برای گوسفندان آن دو آب داد، سپس رو به سایه آورد، آنگاه گفت: «پروردگارا! من هر خیری که بر من بفرستی نیازمند هستم»"
  28,25,"آنگاه یکی از آن دو (زن) در حالی‌که با نهایت حیا گام بر می‌داشت، نزد او آمد، گفت: «همانا پدرم تو را دعوت می‌کند؛ تا مزد آب دادن (گوسفندان) را که برای ما انجام دادی، به تو بدهد» پس چون (موسی) به نزد او آمد و داستان (سرگذشت خود) را بر او حکایت کرد، گفت: «نترس، از گروه ستمکاران نجات یافتی»"
  28,26,"یکی از آن دو (دختر) گفت: «پدر جان! او را اجیر کن، بی‌تردید بهترین کسی را که می‌توانی اجیر کنی، کسی است که نیرومند امین باشد (و او چنین است)»"
  28,27,"(شعیب) گفت: «من می‌خواهم یکی از این دو دختر را به ازدواج تو در بیاورم به شرطی‌که هشت سال برای من کار کنی، و اگر (آن را) تا ده سال تمام کنی، پس (لطف و) محبتی از سوی توست، من نمی‌خواهم بر تو سختگیری کنم، اگر الله بخواهد مرا از صالحان خواهی یافت"
  28,28,"(موسی) گفت: «این (قرار داد) میان من و تو باشد که هر کدام از این دو مدت را انجام دادم بر من ستمی نخواهد بود، و الله بر آنچه می‌گوییم گواه است»"
  28,29,"پس هنگامی‌که موسی (آن) مدت (معین) را به پایان رسانید، و همراه خانواده‌اش حرکت کرد، از سوی (کوه) طور آتشی دید؛ به خانواده‌اش گفت: «درنگ کنید، همانا من آتشی دیدم، شاید خبری از آن برای شما بیاورم، یا شعله‌ای از آتش (بیاورم) تا شما (با آن) گرم شوید»"
  28,30,پس هنگامی‌که به (نزدیکی) آن رسید، از کرانۀ راست وادی در جایگاه پر برکت، از (میان) یک درخت ندا داده شد که «ای موسی! یقیناً من الله، پروردگار جهانیانم
  28,31,"و اینکه عصایت را بیفکن»- پس چون آن را دید که (با سرعت) می‌جنبد گویی که آن ماری است، (ترسید و) به عقب برگشت و پشت سر خود را نگاه نکرد - (الله فرمود:) «ای موسی! پیش آی، و نترس، بی‌گمان تو از ایمنان هستی"
  28,32,دستت را در گریبان خود فرو کن، که سفید (و درخشنده) بی‌عیب بیرون بیاید، و بازویت را (برای حذر) از ترس به سوی خود (بیار و) جمع کن، پس این دو (معجزه عصا و ید بیضا) دو برهان (روشن) از پروردگارت به سوی فرعون و اشراف (قوم) اوست، بی‌گمان آن‌ها گروهی فاسق هستند»
  28,33,"(موسی) گفت: «پروردگارا! همانا من یک تن از آن‌ها را کشته‌ام، پس می‌ترسم که مرا بکشند"
  28,34,و برادرم هارون زبانش از من فصیح‌تر است، پس او را همراه من بفرست تا یاورم باشد و مرا تصدیق کند، زیرا که می‌ترسم مرا تکذیب کنند»
  28,35,"(الله) فرمود: «به زودی بازوی تو را با برادرت قوی (و نیرومند) خواهیم کرد، و برای شما سلطه و برتری قرار می‌دهیم، پس به سبب آیات ما، بر شما دست نیابند، و شما دو نفر و کسی‌که از شما پیروی کند؛ پیروزید»"
  28,36,"پس هنگامی‌که موسی با آیات روشن ما به سوی آن‌ها آمد، گفتند: «این (چیزی) جز سحر ساختگی نیست، و ما چنین چیزی را در نیاکان پیشینیان خود نشنیده‌ایم»"
  28,37,"و موسی گفت: «پروردگار من از (حال) کسی‌که هدایت را از نزد او آورده، و کسی‌که سرانجام سرای (دیگر) از آنِ اوست، دانا‌تر است، بی‌گمان ستمکاران رستگار نخواهند شد» [ مراد از «ظالم» مشرک و کافر است. چرا که ظلم یعنی گذاشتن چیزی در جای غیر مختص به خود، و مشرک ظالم شمرده می‌شود چون که کسانی را در مقام الوهیت قرار می‌دهد که لایق آن نیست، و همچنین کافر چون که از حقیقت مقام پروردگار کاملاً جاهل و ناآشنا می‌باشد ظالم شمرده شده‌است]"
  28,38,"و فرعون گفت: «ای بزرگان! من معبودی جز خودم برای شما نمی‌شناسم، پس ای هامان! برایم آتشی بر گِل بیفروز (و آجر بپز) آنگاه برایم برج بلندی بساز، شاید که از الله موسی با خبر شوم، و هرچند من گمان می‌کنم که او از دروغ‌گویان است»"
  28,39,و او (= فرعون) و لشکریانش به ناحق در زمین سر‌کشی کردند، و پنداشتند که آن‌ها به سوی ما باز گردانده نمی‌شوند
  28,40,پس (ما) او و لشکریانش را فرو گرفتیم، آنگاه در دریا انداختیم، پس بنگر عاقبت ستمکاران چگونه بود؟
  28,41,و آن‌ها را پیشوایانی قرار دادیم که به سوی آتش (دوزخ) دعوت می‌کنند، و روز قیامت یاری نخواهند شد
  28,42,در این دنیا لعنتی به دنبال آنان روانه کردیم؛ و روز قیامت از زشت رویانند
  28,43,و به راستی بعد از آنکه امت‌های پیشین را هلاک نمودیم؛ به موسی کتاب (تورات) دادیم که برای مردم بصیرت و هدایت و رحمت باشد، شاید پند گیرند
  28,44,و تو (ای پیامبر!) در ناحیه غربی نبودی، هنگامی‌که فرمان (نبوت) را به موسی دادیم و تو از حاضران نبودی
  28,45,و لیکن (ما) نسل‌هایی آفریدیم که عمر دراز یافتند، و تو در میان اهل مدین اقامت نداشتی که آیات ما را بر آن‌ها بخوانی، و لیکن ما بودیم که (پیامبرانی) می‌فرستادیم
  28,46,و تو در کنار طور نبودی آنگاه که ندا دادیم، ولی این (و حی) رحمتی از جانب پروردگارت است؛ تا گروهی را بیم دهی که پیش از تو بیم‌دهنده‌ای برای آن‌ها نیامده بود، شاید که آن‌ها پند گیرند
  28,47,"و اگر آن نبود که به (سبب) اعمالی‌که مرتکب شده‌اند؛ مصیبتی به آن‌ها برسد، آنگاه بگویند: «پروردگارا! چرا به سوی ما پیامبری نفرستادی تا از آیات تو پیروی کنیم و از مؤمنان باشیم؟»"
  28,48,"پس هنگامی‌که حق از نزد ما برای آن‌ها آمد، گفتند: «چرا (به این پیامبر) مانند آنچه به موسی داده شد، داده نشده است؟!» آیا به آنچه پیش از این به موسی داده شد، کفر نورزیدند؟ گفتند: «این دو (قرآن و تورات) جادوی تأیید کنندۀ یکدیگرند» و گفتند: «همانا ما به هر کدام (ازآن‌ها) کافریم»"
  28,49,"بگو: «اگر راست می‌گویید، پس کتابی هدایت‌کننده‌تر از این دو (کتاب) از نزد الله بیاورید، تا من از آن پیروی کنم»"
  28,50,پس اگر (این سخن) تو را نپذیرفتند، بدان که آن‌ها فقط از هوس‌های خود پیروی می‌کنند، و گمراه‌تر از آن کس که هوای نفس خویش را بدون (هیچ) هدایتی از (سوی) الله پیروی می‌کند؛ کیست؟! بی‌گمان الله گروه ستمکاران را هدایت نمی‌کند
  28,51,و به راستی (ما این) سخن را یکی پس از دیگری برای آن‌ها آوردیم؛ شاید متذکر شوند
  28,52,کسانی‌که پیش از این (قرآن) به آنان کتاب (آسمانی) داده‌ایم؛ به آن ایمان می‌آورند
  28,53,"و چون (قرآن) بر آن‌ها خوانده شود، گویند: «به آن ایمان آوردیم، بی‌تردید، این حق از سوی پروردگار ما است، همانا ما پیش از (نزول) آن هم مسلمان بودیم»"
  28,54,اینان (کسانی‌اند که) به (سبب) صبری که کرده‌اند، پاداش‌شان دوبار (به آنان) داده می‌شود، و (این‌ها) با نیکی‌ها بدی ها را دفع می‌کنند، و از آنچه به آن‌ها روزی داده‌ایم؛ انفاق می‌کنند
  28,55,"و هنگامی‌که سخن لغو (و بیهوده) بشوند، از آن روی می‌گردانند و گویند: «اعمال ما از آن ماست، و اعمال شما از آن شما، سلام بر شما ما خواستار جاهلان نیستیم»"
  28,56,(ای پیامبر!) بی‌تردید تو هر کس را دوست داری نمی‌توانی هدایت کنی، ولی الله هر کس را بخواهد هدایت می‌کند، و او به هدایت شدگان آگاه‌تر است
  28,57,"و (مشرکان) گفتند: «اگر به همراه تو از هدایت پیروی کنیم، ما را از سرزمینمان می‌ربایند» آیا ما (آن‌ها را) در حرم امنی جای‌شان ندادیم، که ثمرات (و فرآورده‌های) هر چیزی (از هر سو) به سوی آن آورده می‌شود، (این) رزقی است از جانب ما، و لیکن بیشتر آن‌ها نمی‌دانند"
  28,58,و چه بسیار از قریه‌ها (و آبادی‌ها) یی را که بر اثر فزونی نعمت، مست و مغرور شده بودند؛ هلاک کردیم، پس این خانه‌های (ویران شدۀ) آن‌هاست، که بعد از آن‌ها جز اندکی (کسی) در آن‌ها سکونت نکرد، و ما وارث آن‌ها بودیم
  28,59,و پروردگار تو هرگز نابود کنندۀ قریه‌ها (و آبادی‌ها) نبود، تا اینکه در کانون آن‌ها پیامبری بفرستد، که آیات ما را برآن‌ها بخواند، و ما هرگز قریه‌ها (و آبادی‌ها) را هلاک نکردیم؛ مگر آن که اهالی آن ستمکار بودند
  28,60,و آنچه به شما داده شده، متاع زندگی دنیا و زینت آن است، و آنچه نزد الله است، بهتر و پایدارتر است، آیا نمی‌اندیشید؟
  28,61,آیا کسی‌که به او وعده نیک داده‌ایم، پس او به آن (وعده) خواهد رسید، همانند کسی است که او را از متاع زندگی دنیا بهرمند ساخته‌ایم، سپس روز قیامت از احضار شدگان (در عذاب) خواهد بود؟
  28,62,"و روزی‌که (الله) آنان را ندا دهد، آنگاه فرماید: «کجا هستند، شریکانی که برای من می‌پنداشتید؟!»"
  28,63,"کسانی (از معبودان) که فرمان (عذاب) بر آنان تحقیق یافته است. می‌گویند: «پروردگارا! این‌ها (= عابدان) کسانی‌اند که گمراهشان کردیم؛ (آری) آن‌ها را گمراه کردیم، همان گونه که (خودمان) گمراه شدیم، از آن‌ها به‌سوی تو بیزاری می‌جوییم، آن‌ها (در حقیقت) ما را نمی‌پرستیدند (بلکه آن‌ها شیطان را پرستش می‌کردند)»"
  28,64,"و (به عابدان) گفته می‌شود: «معبودهای‌تان را (که شریک الله می‌پنداشتید) بخوانید (تا شما را یاری کنند)» پس آن‌ها را می‌خوانند، ولی جوابی به ایشان نمی‌دهند، و عذاب (الهی) را (با چشم خود) ببینید، (و آرزو کنند) که ای کاش هدایت یافته بودند"
  28,65,"و روزی‌که (الله) آنان را ندا دهد، آنگاه فرماید: «پیامبران را چه پاسخی دادید؟!»"
  28,66,در آن روز همۀ خبرها (و حجت‌ها) بر آن‌ها پوشیده ماند، (و همه چیز را فراموش کنند) پس آنان از یکدیگر نپرسند
  28,67,اما کسی‌که توبه کرد و ایمان آورد و عمل شایسته انجام داد، پس امید است که از رستگاران باشد
  28,68,و پروردگار تو هر چه بخواهد می‌آفریند، و (هر چه بخواهد) بر می‌گزیند، آنان را (هیچ) اختیاری نیست، الله منزه و برتر است از آنچه شریک او قرار می‌دهند
  28,69,و پروردگار تو می‌داند آنچه را که سینه‌های آنان پنهان می‌دارد، و آنچه را آشکار می‌کنند
  28,70,و او ذاتی است که هیچ معبودی (به حق) جز او نیست، ستایش در دنیا و آخرت برای اوست، و حکم (و فرمانروایی) از آن اوست، و (همۀ شما) به سوی او باز گردانده می‌شوید
  28,71,"(ای پیامبر!) بگو: «به من خبر دهید اگر الله شب را تا روز قیامت بر شما پایدار سازد، کیست معبودی جز الله که برای شما روشنی آورد؟! آیا نمی‌شنوید؟!»"
  28,72,"بگو: «به من خبر دهید اگر الله روز را تا روز قیامت بر شما پایدار گرداند، کیست معبودی جز الله که برای شما شبی آورد که در آن آرام بگیرید؟! آیا نمی‌بینید؟"
  28,73,و از رحمت خویش شب و روز را برای شما قرار داد، تا در آن (= شب) آرام بگیرید، و تا (در روز) از فضل او (روزی) بجویید، و شاید سپاس گزارید
  28,74,"و روزی‌که (الله) آنان را ندا دهد، آنگاه فرماید: «کجا هستند، شریکانی را که برای من می‌پنداشتید؟!»"
  28,75,"و از هر امتی گواهی بر می‌گزینیم، آنگاه می‌گوییم: «دلیل خود را بیاورید» آنگاه بدانند که حق از آن الله است، و (تمام) آنچه را افترا می‌بستند از (نظر) آنان ناپدید شود (و تباه گردد)"
  28,76,"بی‌گمان قارون از قوم موسی بود، پس بر آن‌ها ستم کرد، آنقدر از گنج‌ها به او داده بودیم که حمل کلید‌هایش بر گروهی زورمند دشوار (و سنگین) بود. هنگامی‌که قومش به او گفت: «(به خاطر مالت این همه مغرورانه) شادی نکن، همانا الله شادی کنندگان (مغرور) را دوست ندارد"
  28,77,"و در آنچه الله به تو داده، سرای آخرت را بجوی و بهره‌ات را از دنیا فراموش نکن [ یعنی در مباحات دنیا نیز اسراف و ولخرجی نکن. مباحات دنیا مانند خوردن، نوشیدن، لباس، خانه، ازدواج و غیره. مطلب اینست که همچنانکه بایستی حق پروردگار را ادا کرد نیز باید حق بدن خود و زن و بچه و مهمان‌ها و غیره را ادا کرد. یعنی باید حق هر حق‌داری را به جای آورد.]، و همان‌گونه که الله به تو نیکی کرده است؛ نیکی کن، و هرگز در زمین در پی فساد مباش، بی‌گمان الله مفسدان را دوست ندارد»"
  28,78,"(قارون) گفت: «تنها به سبب دانشی که نزد من است آن (مال و ثروت) به من داده شده است» آیا او نمی‌دانست که الله پیش از او اقوامی را هلاک کرد که از او نیرومندتر و ثروتمندتر بودند؟! و مجرمان از گناهان‌شان پرسیده نمی‌شوند"
  28,79,"پس (روزی قارون) با آرایش و زینت خویش بر قومش بیرون آمد، کسانی‌که خواهان زندگی دنیا بودند، گفتند: «ای کاش همانند آنچه به قارون داده شده است؛ ما نیز داشتیم، به راستی که او از بهرۀ عظیمی برخوردار است»"
  28,80,"و کسانی‌که دانش به آن‌ها داده شده بود، گفتند: «وای بر شما! ثواب الله برای کسی‌که ایمان آورد و کار شایسته انجام دهد بهتر است، و آن (سخن را کسانی) جز صابران نمی‌پذیرند»"
  28,81,پس او و خانه‌اش را در زمین فرو بردیم، و هیچ گروهی نداشت که او را در برابر (عذاب) الله یاری کنند، و خود (نیز) نمی‌توانست خویش را یاری کند
  28,82,"و کسانی‌که دیروز آرزو می‌کردند به جای او باشند، می‌گفتند: «وای بر ما! گویی الله روزی را برای هر کس از بندگانش که بخواهد فراخ می‌گرداند، و (یا) تنگ می‌گیرد، اگر الله بر ما منّت ننهاده بود، بی‌تردید ما را (نیز به قعر زمین) فرو می‌برد، ای وای! گویی کافران هرگز رستگار نمی‌شوند"
  28,83,(آری) این سرای آخرت را (فقط) برای کسانی قرار می‌دهیم که نه خواهان برتری جویی هستند و نه خواهان فساد، و سرانجام نیک برای پرهیزگاران است
  28,84,کسی‌که نیکی آورد، پس برای او پاداش بهتر از آن است، و کسی‌که بدی آورد، پس کسانی‌که بدی‌ها انجام دادند، جز (به‌اندازۀ) آنچه می‌کردند، مجازات نخواهند داشت
  28,85,"بی‌تردید کسی‌که قرآن را بر تو فرض (و نازل) کرد، قطعاً تو را به جایگاهت (= مکه) باز می‌گرداند. بگو: «پروردگار من بهتر می‌داند چه کسی هدایت آورده، و چه کسی در گمراهی آشکار است»"
  28,86,و تو امید نداشتی که کتاب (آسمانی) بر تو القا شود، جز این‌که رحمت پروردگارت بود، پس هرگز پشتیبان کافران مباش
  28,87,و هرگز (کافران) تو را از آیات الله، بعد از آن که بر تو نازل شد، باز ندارند، و به‌سوی پروردگارت دعوت کن، و هرگز از مشرکان مباش
  28,88,و معبود دیگری با الله مخوان، هیچ معبودی (به حق) جز او نیست، همه چیز جز روی (= ذات) او نابود می‌شود، فرمانروایی (تنها) از آنِ اوست، و (همه) به‌سوی او بازگردانده می‌شوید
  29,1,الم (الف. لام. میم)
  29,2,"آیا مردم پنداشتند که چون بگویند: «ایمان آوردیم» (به حال خود) رها می‌شوند، و آنان آزمایش نمی‌شوند؟"
  29,3,و به راستی کسانی را که پیش از آن‌ها بودند؛ آزمودیم، پس البته الله کسانی را که راست گفتند معلوم می‌دارد، و دروغگویان را (نیز) معلوم خواهد داشت
  29,4,آیا کسانی‌که اعمال بد انجام می‌دهند؛ گمان کردند که از ما پیشی می‌گیرند؟ چه بد داوری می‌کنند
  29,5,کسی‌که به دیدار الله امید دارد، پس به راستی که وعدۀ الله خواهد آمد، و او شنوای داناست
  29,6,کسی‌که (در راه الله) جهاد کند، تنها برای (نفع) خودش جهاد می‌کند، بی‌گمان الله از (همۀ) جهانیان بی‌نیاز است
  29,7,و کسانی‌که ایمان آوردند و کارهای شایسته انجام دادند، قطعاً گناهان‌‌شان را از آنان می‌زداییم، و آنان را به بهترین اعمالی‌که انجام می‌داند، پاداش می‌دهیم
  29,8,و انسان را به نیک رفتاری (نسبت) به پدر و مادرش سفارش کردیم، و اگر آن دو (مشرک باشند و) تلاش کنند که تو چیزی را که به آن علم نداری شریک من قرار دهی، پس از آنان اطاعت نکن، بازگشت شما به سوی من است، آنگاه شما را به آنچه انجام می‌دادید؛ آگاه خواهم کرد
  29,9,و کسانی‌که ایمان آوردند و کارهای شایسته انجام دادند، هر آیینه آن‌ها را در (زمرۀ) صالحان در می‌آوریم
  29,10,"و از مردم کسانی هستند که می‌گویند: «به الله ایمان آورده‌ایم» پس هنگامی‌که در راه الله آزار بیند، آزار (و اذیت) مردم را همچون عذاب الله بشمار می‌آورد، و اگر پیروزی از سوی پروردگارت (برای شما) بیاید؛ حتماً می‌گویند: «به راستی‌که ما (نیز) با شما بودیم» آیا الله به آنچه در سینه‌های جهانیان است؛ داناتر نیست؟"
  29,11,و مسلماً الله کسانی را که ایمان آوردند معلوم می‌دارد، و یقیناً منافقان را (نیز) معلوم خواهد داشت
  29,12,"و کسانی‌که کافر شدند به کسانی‌که ایمان آوردند؛ گفتند: «از راه ما پیروی کنید، و البته ما (بار) گناهان‌تان را بر می‌داریم». و آن‌ها هرگز چیزی از گناهان ایشان را بر نخواهند داشت، بی‌گمان آن‌ها دروغگو هستند"
  29,13,و البته بار‌های سنگین (گناهان) خویش را بر می‌دارند، و (همچنین) بار‌های دیگری را با بارهای سنگین خود بر می‌دارند، و روز قیامت یقیناً از آنچه افترا می‌بستند پرسیده خواهند شد
  29,14,و به راستی‌که (ما) نوح را به سوی قومش فرستادیم، پس او در میان آنان هزار سال به جز پنجاه سال (= نهصد و پنجاه سال) درنگ کرد، آنگاه طوفان (و سیلاب) آنان را فرو گرفت در حالی‌که ستمکار بودند
  29,15,آنگاه او و سرنشینان کشتی را نجات دادیم، و آن (کشتی) را نشانۀ (عبرتی) برای جهانیان قرار دادیم
  29,16,"و ابراهیم را (نیز فرستادیم)، هنگامی‌که به قومش گفت: «الله را بپرستید و از او بترسید، که اگر بدانید این برای شما بهتر است"
  29,17,شما به جای الله فقط بت‌های (از سنگ و چوب) را می‌پرستید، و دروغی (بزرگ) به هم می‌بافید، بی‌گمان کسانی را که به جای الله می‌پرستید، مالک هیچ رزقی برای شما نیستند، پس روزی را تنها (از) نزد الله طلب کنید، و او را بپرستید، و شکر او را بجای آورید، که به سوی او باز گردانیده می‌شوید
  29,18,و اگر شما تکذیب کنید (عجیب نیست) به راستی که امت‌هایی پیش از شما نیز تکذیب کردند، و بر (عهدۀ) پیامبر (الله) چیزی جز تبلیغ آشکار نیست»
  29,19,آیا ندیدند که الله چگونه آفرینش را آغاز می‌کند، سپس باز می‌گرداند؟! بی‌تردید این (کار) بر الله آسان است
  29,20,"(ای پیامبر!) بگو: «در زمین بگردید؛ آنگاه بنگرید (الله) چگونه آفرینش را آغاز کرد، سپس الله (به همین گونه) پیدایش باز پسین را پدید می‌آورد، بی‌گمان الله بر هر چیز تواناست"
  29,21,هر کس را بخواهد عذاب می‌کند، و هر کس را بخواهد مورد رحمت قرار می‌دهد، و (شما) به سوی او باز گردانیده می‌شوید
  29,22,و شما هرگز نمی‌توانید ما را در زمین و نه در آسمان به ستوه آورید (و از عقوبت ما فرار کنید) و برای شما جز الله هیچ کار ساز و یاوری نیست»
  29,23,و کسانی‌که به آیات الله و دیدار او کافر شدند، اینانند که از رحمت من نا امید هستند، و آنان برایشان عذاب درد ناکی است
  29,24,"آنگاه جواب قوم او (= ابراهیم) جز این نبود که گفتند: «او را بکشید، یا او را بسوزانید» پس الله او را از آتش نجات داد، بی‌گمان در این (ماجرا) نشانه‌هایی است برای گروهی‌که ایمان می‌آورند"
  29,25,"و (ابراهیم) گفت: «شما غیر از الله بت‌هایی را برای خود برگزیده‌اید که مایۀ دوستی و محبت میان شما در زندگی دنیا باشد، سپس روز قیامت برخی از شما برخی (دیگر) را انکار می‌کند، و برخی از شما برخی (دیگر) را لعنت می‌کند، و جایگاه شما آتش است، و هیچ یاوری برای شما نخواهد بود"
  29,26,"پس لوط به او (= ابراهیم) ایمان آورد، و (ابراهیم) گفت: «من به سوی پروردگارم هجرت می‌کنم، بی‌گمان او پیروزمند حکیم است»"
  29,27,و اسحاق و یعقوب را به او بخشیدیم، و در فرزندانش نبوت و کتاب (آسمانی) قرار دادیم، و پاداش او را در دنیا دادیم، و بی‌تردید او در آخرت از صالحان است
  29,28,"و لوط را (فرستادیم) هنگامی‌که به قومش گفت: «بی‌گمان شما (عمل) بسیار زشتی انجام می‌دهید، که هیچ کس از جهانیان پیش از شما آن را انجام نداده است"
  29,29,"آیا شما (برای کامجویی) به سراغ مردان می‌روید، و راه را قطع می‌کنید، و در محافل خود اعمال نا پسند انجام می‌دهید؟!» پس جواب قومش جزاین نبود که گفتند: «اگر از راستگویانی عذاب الله را برای ما بیاور»"
  29,30,"(لوط) گفت: «پروردگارا! مرا بر قوم مفسدان یاری فرما»"
  29,31,"و هنگامی‌که فرستادگان ما ابراهیم را بشارت (تولد فرزند) آوردند، گفتند: «به راستی ما اهل این قریه (سدوم) را هلاک خواهیم کرد، بی‌شک اهل آن ستمکار بودند»"
  29,32,"(ابراهیم) گفت: «همانا لوط در آنجاست!» (فرشتگان) گفتند: «ما به هر کس‌که در آنجاست داناتریم، یقیناً او و خانواده‌اش را نجات می‌دهیم، جز همسرش که از بازماندگان خواهد بود»"
  29,33,"و چون فرستادگان ما نزد لوط آمدند، از (دیدن) آن‌ها اندوهگین، و به خاطر آن‌ها دل‌تنگ شد، و (فرشتگان) گفتند: «نترس، و غمگین مباش، بی‌گمان ما تو و خانواده‌ات را نجات خواهیم داد؛ جز همسرت‌که از بازماندگان خواهد بود"
  29,34,همانا ما بر اهل این قریه به (خاطر) آن‌که نافرمانی (و گناه) می‌کردند، عذابی از آسمان فرو خواهیم ریخت»
  29,35,و به راستی از آن (قریه) نشانه (و عبرت) روشنی برای گروهی که خرد می‌ورزند؛ باقی گذاشتیم
  29,36,"و به سوی مدین برادرشان شعیب را فرستادیم، پس گفت: «ای قوم من! الله را بپرستید، و به روز باز پسین امیدوار باشید، و در زمین به فساد نکوشید»"
  29,37,آنگاه او را تکذیب کردند، پس زلزله آنان را فرو گرفت، پس در خانه‌های خود به رو افتادند (و مردند)
  29,38,و (قوم) عاد و ثمود را (نیز هلاک کردیم) و یقیناً برخی از مساکن (ویران شدۀ) آن‌ها برای شما آشکار شده است. و شیطان اعمال‌شان را برای آن‌ها بیاراست، پس آن‌ها را از راه (الله) بازداشت در حالی‌که بینا بودند
  29,39,و قارون و فرعون و هامان را (نیز هلاک کردیم) و به راستی موسی با دلایل روشن نزد آنان آمد، پس آن‌ها در زمین سرکشی کردند و پیشی گیرندگان (بر الله) نبودند
  29,40,آنگاه هر یک از آن‌ها را به (کیفر) گناهش گرفتیم، پس بر بعضی از آن‌ها طوفانی از سنگریزه فرستادیم، و بعضی از آن‌ها را صیحه (= بانگ مرگبار) فرو گرفت، و بعضی را در زمین فرو بردیم، و بعضی را غرق کردیم، و الله هرگز به آن‌ها ستم نکرد، و لیکن آن‌ها (خود) بر خویشتن ستم می‌کردند
  29,41,"مثل کسانی‌که بجای الله، اولیاء (و دوستانی برای خود) برگزیدند، همچون مثل عنکبوت است، که خانه‌ای (برای خود) برگزیده است، و بی‌گمان سست‌ترین خانه‌ها خانۀ عنکبوت است، اگر می‌دانستند. [یعنی همانگونه که خانه عنکبوت سست و ناپایدار و با کوچکترین اشارۀ دست از بین می‌رود، معبودان خود ساخته خود که آن را مشکل‌گشا و حاجت‌روا می‌پندارید بدینگونه تماماً بیهوده و پوچ می‌باشند، چرا که از هر لحاظ قادر به کاری نیستند، بدین سبب آن معبودان غیر از الله متعال مانند خانه عنکبوت ناپایدار می‌باشند و اگر واقعاً آن‌ها قادر به کاری و یا سودبخش بودند چرا نتوانستند ملت‌های گذشته را از نابودی نجات دهند]"
  29,42,یقیناً الله هر آنچه را که به جای او می‌خوانند، می‌داند، و او پیروزمند حکیم است
  29,43,و این مثال‌هایی است که آن‌ها را برای مردم می‌زنیم، و جز دانایان آن‌ها را در نمی‌یابند
  29,44,الله آسمان‌ها و زمین را به حق آفرید، بی‌گمان در این نشانه‌ای (بزرگ) برای مؤمنان است
  29,45,(ای پیامبر!) آنچه را از (این) کتاب بر تو وحی شده است تلاوت کن، و نماز را بر پا دار، یقیناً نماز (انسان را) از زشتی‌ها و منکر باز می‌دارد، و البته یاد الله بزرگ‌تر است، و الله آنچه را انجام می‌دهید؛ می‌داند
  29,46,"و با اهل کتاب جز به روشی‌که آن بهتر است مجادله نکنید، مگر کسانی از آنان که ستم کردند، و بگویید: «به آنچه (از سوی الله) بر ما نازل شده و آنچه بر شما نازل شده، ایمان آورده‌ایم، و معبود ما و معبود شما یکی است، و ما برای او تسلیم هستیم»"
  29,47,و این گونه کتاب (= قرآن) را بر تو نازل کردیم، پس کسانی‌که به آن‌ها کتاب (آسمانی) دادیم، به آن ایمان می‌آورند، و از همین گروه (مشرکان نیز) کسی است که به آن ایمان می‌آورد، و آیات ما را جز کافران انکار نمی‌کنند
  29,48,و تو (هرگز) پیش از این (قرآن) هیچ کتابی را نمی‌خواندی، و با (دست) راست خود چیزی نمی‌نوشتی، اگر چنین بود، باطل گرایان به شک (و تردید) می‌افتادند
  29,49,بلکه آن (قرآن) آیات روشنی است که در سینۀ کسانی‌که دانش داده شده‌اند، جای دارد، و آیات ما را جز ستمکاران انکار نمی‌کنند
  29,50,"و گفتند: «چرا نشانه‌هایی از سوی پروردگارش بر او نازل نشده است؟!» (ای پیامبر!) بگو: «همانا نشانه‌ها (همه) نزد الله است (و به فرمان او نازل می‌شود) و من تنها هشداردهنده‌ای آشکار هستم»"
  29,51,آیا برای آن‌ها کافی نیست که همانا ما (این) کتاب (قرآن) را بر تو نازل کردیم که (پیوسته) بر آن‌ها تلاوت می‌شود؟! بی‌گمان در این (قرآن) رحمت و پندی است برای کسانی‌که ایمان می‌آورند
  29,52,"بگو: «همین بس که الله میان من و شما گواه است، آنچه را در آسمان‌ها و زمین است می‌داند، و کسانی‌که به باطل ایمان آوردند و به الله کافر شدند، اینان زیانکاران (واقعی) هستند»"
  29,53,و آن‌ها با شتاب عذاب را از تو طلب می‌کنند، و اگر موعد مقرری تعیین نشده بود، یقیناً عذاب (الهی) به (سراغ) آن‌ها می‌آمد، و ناگهان در حالی‌‌که نمی‌دانند به (سراغ) آن‌ها خواهد آمد
  29,54,و آن‌ها با شتاب عذاب را از تو می‌طلبند، و بی‌گمان جهنم به کافران احاطه دارد
  29,55,"روزی‌که عذاب آن‌ها را از بالای (سر)شان و از زیر پاهای‌شان در بر می‌گیرد، و (الله به آن‌ها) می‌فرماید: «بچشید آنچه را انجام می‌دادید"
  29,56,ای بندگان من که ایمان آورده‌اید! بی‌گمان زمین من وسیع است، پس تنها مرا بپرستید»
  29,57,هر کسی چشندۀ مرگ است، سپس به سوی ما باز گردانده می‌شوید
  29,58,و کسانی‌که ایمان آوردند و کار‌های شایسته انجام دادند، قطعاً آن‌ها را در غرفه‌هایی از بهشت جای می‌دهیم که نهر‌ها در زیر آن جاری است، جاودانه در آن خواهند ماند، چه خوب است پاداش عمل کنندگان
  29,59,(همان) کسانی‌که صبر کردند و تنها بر پروردگارشان توکل می‌کنند
  29,60,و چه بسیار جنبدگانی‌که روزی خود را بر دوش نمی‌گیرند، الله به آن‌ها و شما روزی می‌دهد، و او شنوای داناست
  29,61,"و اگر از آن‌ها بپرسی: «چه کسی آسمان‌ها و زمین را آفریده، و خورشید و ماه را مسخر کرده است؟!» البته می‌گویند: «الله» پس چگونه (از حق) منحرف می‌شوند؟"
  29,62,الله روزی را برای هر کس از بندگانش که بخواهد فراخ می‌گرداند، و (یا) برایش تنگ می‌دارد، بی‌گمان الله به همه چیز داناست
  29,63,"و اگر از آن‌ها بپرسی: «چه کسی از آسمان آبی را نازل کرد، آنگاه با آن (آب) زمین را بعد از مردنش زنده کرد؟» البته می‌گویند: «الله» بگو: «حمد و ستایش مخصوص الله است» بلکه بیشتر آن‌ها در نمی‌یابند"
  29,64,و این زندگی دنیا (چیزی) جز سرگرمی و بازیچه نیست، و بی‌تردید اگر می‌دانستند سرای آخرت همان زندگی (واقعی) است
  29,65,پس هنگامی‌که در کشتی سوار شوند، الله را با اخلاص می‌خوانند، پس چون (الله) آن‌ها را (با آوردن) به خشکی نجات داد، باز آنان شرک می‌آورند
  29,66,تا آنچه را به آن‌ها داده‌ایم؛ کفران کنند، و تا (از لذات زندگی دنیا) بهره گیرند، پس به زودی خواهند دانست
  29,67,آیا ندیدند که همانا ما حرم امنی (برای آن‌ها) قرار دادیم، در حالی‌که مردم از اطراف آنان ربوده می‌شوند؟! آیا به باطل ایمان می‌آورند و به نعمت الله ناسپاسی می‌کنند؟
  29,68,و کیست ستمکار‌تر از آن کسی‌که بر الله دروغ بندد یا حق را چون به سوی او آید تکذیب کند؟! آیا جایگاه کافران در جهنم نیست؟
  29,69,و کسانی‌که در راه ما (کوشش و) جهاد کنند؛ قطعاً به راه‌های خویش هدایت شان می‌کنیم، و یقیناً الله با نیکوکاران است
  30,1,الم (الف. لام. میم)
  30,2,رومیان مغلوب شدند
  30,3,در نزدیکترین سرزمین، و آن‌ها بعد از مغلوب شدن‌شان به زودی غالب خواهند شد
  30,4,در (ظرف) چند سال؛ پیش از (این پیروزی) و بعد از این (پیروزی) فرمان از آن الله است، و در آن روز مؤمنان شادمان خواهند شد
  30,5,به (سبب) یاری الله، و (الله) هر که را بخواهد یاری می‌کند، و او پیروزمند مهربان است
  30,6,الله وعده داده است، الله هرگز وعدۀ خویش را خلاف نمی‌کند، و لیکن بیشتر مردم نمی‌دانند
  30,7,آن‌ها فقط ظاهری از زندگی دنیا را می‌دانند، و آن‌ها از آخرت غافلند
  30,8,آیا در ضمیر خود نیندیشیده‌اند که (دریابند) الله آسمان‌ها و زمین و آنچه را میان آن دو است؛ جز به حق و (تا) زمان معینی نیافریده است؟! و بی‌تردید بسیاری از مردم به دیدار پروردگارشان (در روز قیامت) نا باورند
  30,9,آیا در زمین گردش نکردند، تا بنگرند عاقبت کسانی‌که پیش از آن‌ها بودند؛ چگونه بود؟! (آن‌ها) نیرومند‌تر از اینان بودند، و در زمین دگرگونی به وجود آوردند و آن را بیشتر از آنچه (اینان) آبادش کرده‌اند، آباد کردند، و پیامبران‌شان با دلایل روشن به سوی آن‌ها آمدند، پس الله بر آن نبود که برآن‌ها ستم کند، و لیکن (آن‌ها) به خود‌شان ستم می‌کردند
  30,10,سپس سرانجام کسانی‌که بدی کردند، بدتر شد، که آیات الله را تکذیب کردند، و آن را به مسخره می‌گرفتند
  30,11,الله آفرینش را آغاز می‌کند، سپس آن را باز می‌گرداند، آنگاه به سوی او باز گردانده می‌شوید
  30,12,و روزی‌که قیامت بر پا شود، مجرمان نا امید شوند
  30,13,و برای آن‌ها از معبودان‌شان شفیعانی نخواهد بود، و نسبت به معبودان‌شان (که آن‌ها را همتای الله قرار داده بودند) کافر می‌شوند
  30,14,و روزی‌که قیامت بر پا شود، آن روز (مردم) از هم جدا می‌شوند
  30,15,اما کسانی‌که ایمان آورده‌اند و کار‌های شایسته انجام داده‌اند، آنان در باغی (از بهشت) شادمان و مسرور خواهند بود
  30,16,و اما کسانی‌که کافر شدند و آیات ما و دیدار آخرت را تکذیب کردند، پس اینان در عذاب (الهی) احضار شوند
  30,17,پس الله را تسبیح گویید؛ هنگامی‌که شام می‌کنید و هنگامی‌که صبح می‌کنید
  30,18,و حمد و ستایش مخصوص اوست، در آسمان‌ها و زمین، و عصرگاهان و هنگامی‌که ظهر می‌کنید
  30,19,زنده را از مرده بیرون می‌آورد، و مرده را از زنده بیرون می‌آورد، و زمین را پس از مردنش زنده می‌سازد، و همین گونه (روز قیامت از گور‌ها) بیرون آورده می‌شوید
  30,20,و از نشانه‌های او (این) است که شما را از خاک آفرید، پس ناگاه شما انسان‌های (زیادی شدید و در زمین) پراکنده گشتید
  30,21,و از نشانه‌های او (این) است‌که همسرانی از جنس خود‌تان برای شما آفرید؛ تا به آن‌ها آرام گیرید، و در میان‌تان مودت و رحمت قرار داد، بی‌گمان در این (امر) نشانه‌های است برای گروهی‌که تفکر می‌کنند
  30,22,و از نشانه‌های او آفرینش آسمان‌ها و زمین، و اختلاف زبان‌هایتان و رنگ‌هایتان است، بی‌تردید در این نشانه‌های برای دانایان است
  30,23,و از نشانه‌های او خوابیدن شما در شب و روز است، و تلاش و بهره جستن شما از فضل اوست، بی‌شک در این نشانه‌های است؛ برای گروهی که می‌شنوند
  30,24,و از نشانه‌های او (این) است که برق را برای بیم و امید به شما نشان می‌دهد، و از آسمان آبی نازل می‌کند، آنگاه زمین را بعد از مردنش به آن (آب) زنده می‌کند؛ بی‌گمان در این نشانه‌های است؛ برای گروهی که می‌اندیشند
  30,25,و از نشانه‌های او (این) است که آسمان‌ها و زمین به فرمانش (بر جای) می‌ایستند، پس هنگامی‌که با ندایی شما را از زمین فرا خواند، ناگهان شما خارج می‌شوید
  30,26,و از آنِ اوست هر که در آسمان‌ها و زمین است، و همگی فرمانبردار او هستند
  30,27,و او کسی است آفرینش را آغاز می‌کند، سپس آن را باز می‌گرداند و این (باز گرداندن) بر او آسان‌تر است، و توصیف برتر در آسمان‌ها و زمین برای اوست، و او پیروزمند حکیم است
  30,28,(الله) برای شما از خود‌تان مَثَلی زده است؛ آیا بردگان‌تان در آنچه به شما روزی دادایم، با شما شریک هستند، تا شما در آن برابر (و یکسان) باشید، همان‌گونه که شما از (شرکای آزاد) خود بیم دارید از آن‌ها هم بیم داشته باشید؟! این چنین آیات را برای گروهی که تعقل می‌کنند به روشنی بیان می‌کنیم
  30,29,بلکه ستمکاران بدون علم و آگاهی از هوی و هوس‌های خود پیروی کردند، پس آن را که الله گمراه کرده است چه کسی هدایت می‌کند؟! و برای آن‌ها هیچ یاوری نخواهد بود
  30,30,پس روی خود را با حق‌گرایی (و اخلاص) به سوی دین آور، فطرت الهی است، که (الله) مردم را بر آن آفریده است، دگرگونی در آفرینش الله نیست، این است دین استوار، و لیکن بیشتر مردم نمی‌دانند
  30,31,به سوی او باز گردید، و از او بترسید، و نماز را بر پا دارید، و از مشرکان نباشید
  30,32,از کسانی‌که دین خود را پاره پاره کردند، و فرقه فرقه شدند، و هر گروهی به آنچه نزد خود دارند؛ خوشحالند
  30,33,و هنگامی‌که (رنج و) زیانی به مردم برسد پروردگار‌شان را می‌خوانند، (و توبه‌کنان) به سوی او باز می‌گردند، سپس هنگامی‌که رحمتی از خودش به آنان بچشاند، ناگاه گروهی از آنان به پروردگارشان شرک می‌آورند
  30,34,تا به آنچه که به آن‌ها داده‌ایم؛ کفران کنند، پس (از لذات دنیا) بهره بگیرید، که به زودی خواهید دانست
  30,35,آیا دلیل محکمی بر آن‌ها نازل کردیم، پس آن (دلیل) از چیزی‌که با الله شریک می‌سازند، سخن می‌گوید؟
  30,36,و هنگامی‌که رحمتی به مردم بچشانیم به آن خوشحال می‌شوند، و اگر به خاطر اعمالی‌که انجام داده‌اند؛ رنج و مصیبتی به آن‌ها برسد، ناگهان مأیوس می‌شوند
  30,37,آیا ندیدند که الله روزی را برای هر کس که بخواهد فراخ می‌گرداند، و (یا) تنگ می‌گیرد؟! بی‌گمان در این (گشایش و تنگی) نشانه‌هایی است برای گروهی که ایمان می‌آورند
  30,38,پس حقِ خویشاوندان و مسکینان و در راه ماندگان را بده، این برای کسانی‌که رضا و روی الله را می‌طلبند؛ بهتر است، و اینانند که رستگارند
  30,39,و آنچه (به قصد) ربا می‌دهید تا در اموال مردم فزونی یابد، نزد الله فزونی نخواهد یافت، و آنچه را (به عنوان) زکات می‌پردازید که تنها وجه الله را می‌طلبید (برکت و فزونی می‌یابد) پس (کسانی‌که چنین کنند) اینان فزونی یافتگانند
  30,40,الله همان کسی است که شما را آفرید، آنگاه به شما روزی داد، پس شما را می‌میراند، آنگاه شما را زنده می‌کند، آیا هیچ یک از شریکان‌تان می‌توانند چیزی از این (کار‌ها) انجام دهند؟! او منزه و برتر است از آنچه شریک او قرار می‌دهند
  30,41,به سبب کار‌های‌که مردم انجام داده‌اند، فساد در خشکی و دریا آشکار شده است، تا (الله) جزای بعضی از آنچه را که انجام داده‌اند، به آنان بچشاند، باشد که آنان (به سوی حق) باز گردند
  30,42,"(ای پیامبر!) بگو: «در زمین سیر کنید، پس بنگرید عاقبت کسانی‌که پیش از این بودند؛ چگونه بود، بیشتر آن‌ها مشرک بودند"
  30,43,پس روی خود را به آیین پایدار بیاور، پیش از آن‌که روزی فرا رسد که برایش هیچ بازگشتی از (سوی) الله نیست، آن روز (مردم) متفرق شوند
  30,44,کسی‌که کفر ورزد، پس کفرش بر زیان (خود) اوست، و کسی‌که کار شایسته انجام دهد، پس برای خودشان آماده می‌سازند
  30,45,تا (الله) کسانی را ایمان آورده‌اند و کارهای شایسته انجام داده‌اند از فضل خود پاداش دهد، بی‌گمان او کافران را دوست نمی‌دارد
  30,46,و از نشانه‌های (عظمت) او آن است که باد‌های مژده‌دهنده را می‌فرستد، و تا از رحمت خود به شما بچشاند، و تا کشتی‌ها به فرمان او حرکت کنند، و تا از فضل او (روزی) بجویید، و باشد که سپاس گویید
  30,47,و به راستی پیش از تو پیامبرانی را به سوی قوم‌شان فرستادیم، پس با دلایل روشن نزد‌شان آمدند، آنگاه از کسانی‌که گناه کردند، انتقام گرفتیم، (و مؤمنان را یاری دادیم) و یاری دادن مؤمنان بر (عهدۀ) ما بود
  30,48,الله همان کسی است که باد‌ها را می‌فرستد، آنگاه ابر‌ها را به حرکت در می‌آورد، سپس آن (ابر‌ها) را در آسمان آن‌گونه که بخواهد می‌گستراند، و آن را پاره پاره می‌گرداند، پس می‌بینی‌که دانه‌های باران از لابه لای آن خارج می‌شود. پس هنگامی‌که این (بارانِ حیات بخش) را به هر کس از بندگانش که بخواهد برساند، ناگهان آنان خوشحال می‌شوند
  30,49,و اگر چه پیش از آن که (باران رحمت) بر آنان نازل شود؛ مأیوس بودند
  30,50,پس به آثار رحمت الله بنگر که چگونه زمین را بعد از مردنش زنده می‌کند، یقیناً این (الله) زنده کنندۀ مردگان است، و او بر همه چیز تواناست
  30,51,و اگر بادی بفرستیم (گرم و سوزان) آنگاه آن (کشتزار‌ها) را زرد شده ببینند، (مأیوس شده، و) پس از آن ناسپاس می‌شوند
  30,52,پس (ای پیامبر!) تو نمی‌توانی (سخنت را) به (گوش) مردگان بشنوانی، و نمی‌توانی کران را هنگامی‌که پشت‌کنان روی می‌گردانند؛ سخن (و ندای خود را) بشنوانی
  30,53,و تو نمی‌توانی کوران را از گمراهی‌شان (باز گردانی و) هدایت کنی، تو تنها می‌توانی (سخن خود را) به کسانی بشنوانی که به آیات ما ایمان دارند، پس آن‌ها (در برابر حق) تسلیم شدگان هستند
  30,54,الله همان کسی است که شما را ناتوان آفرید، سپس بعد از ناتوانی، قوت بخشید، و آنگاه بعد از قوت ناتوانی و پیری قرار داد، هرچه بخواهد می‌آفریند، و او دانای تواناست
  30,55,و روزی‌که قیامت بر پا شود، مجرمان سوگند یاد می‌کنند که جز ساعتی (در دنیا) درنگ نکردند! (آری) این گونه (از حقیقت و راه حق) باز گردانده می‌شوند
  30,56,"و کسانی‌که دانش و ایمان داده شده‌اند، گویند: «به راستی شما به فرمان کتاب الله (لوح محفوظ) تا روز رستاخیز درنگ کردید، پس این روز رستاخیز است، لیکن شما نمی‌دانستید»"
  30,57,پس آن روز کسانی‌که ستم کردند؛ عذر خواهی‌شان سودی ندارد و به آنان مهلت (توبه) داده نخواهد شد
  30,58,"به راستی برای مردم در این قرآن از هر گونه مَثَلی آوردیم، و اگر نشانه‌ای برای آنان بیاوری، البته کسانی‌که کافر شدند، گویند: «شما جز بیهوده گویان نیستید»"
  30,59,این گونه الله بر دل‌های کسانی‌که نمی‌دانند، مهر می‌نهد
  30,60,پس (ای پیامبر گرامی!) صبر پیشه کن، بی‌گمان وعدۀ الله حق است، و هرگز کسانی‌که یقین ندارند تو را سبک‌سر نگردانند
  31,1,الم (الف. لام. میم)
  31,2,این آیات کتاب حکیم است
  31,3,هدایت و رحمت برای نیکوکاران است
  31,4,کسانی‌که نماز را بر پا می‌دارند، و زکات را می‌پردازند، و آن‌ها به آخرت یقین دارند
  31,5,اینان از جانب پرودگار‌شان بر هدایت هستند، و اینان رستگارانند
  31,6,و از مردم کسی هست که سخنان بیهوده را می‌خرد؛ تا به نادانی (مردم را) از راه الله گمراه سازد، و آن (آیات) را به ریخشند می‌گیرد، اینان برایشان عذاب خوارکننده‌ای است
  31,7,و هنگامی‌که آیات ما بر او خوانده شود، تکبر‌کنان روی می‌گرداند، گویا که آن را نشنیده است، گویا در گوش‌هایش سنگینی است، پس او را به عذابی درد‌ناک بشارت ده
  31,8,بی‌گمان کسانی‌که ایمان آوردند و کار‌های شایسته انجام دادند، برای آن‌ها باغ‌های پر نعمت (بهشت) است
  31,9,جاودانه در آن خواهند ماند، وعدۀ الله راست است، و او پیروزمند حکیم است
  31,10,(الله) آسمان‌ها را بدون ستون آفرید که می‌بینید، و در زمین کوه‌های استوار افکند تا شما را نلرزاند، و از هرگونه جنبنده‌ای در آن بپراکند، و از آسمان آبی نازل کردیم، آنگاه در آن (زمین) هر جفت (گیاه) پر ارزش (و نیکو) رویاندیم
  31,11,این آفرینش الله است، پس به من نشان دهید کسانی‌که غیر او هستند، چه چیزی را آفریده‌اند؟! بلکه ستمکاران در گمراهی آشکاری هستند
  31,12,"و به راستی به لقمان حکمت دادیم، (و به او گفتیم) که: شکر الله را به جای آور؛ و هرکس شکر کند تنها به سود خود شکر کرده است، و هر کس که کفران کند، پس بی‌تردید الله بی‌نیاز ستوده است"
  31,13,"و (به یاد آور) هنگامی را که لقمان به فرزندش در حالی‌که او را پند می‌داد، گفت: «ای پسرک من! به الله شرک نیاور، بی‌گمان شرک، ستم بزرگی است"
  31,14,و به انسان دربارۀ پدر و مادرش سفارش کردیم، مادرش او را با ناتوانی روی ناتوانی حمل کرد، و از شیر باز گرفتنش در دو سال است، (آری، سفارش کردیم) که برای من و برای پدر و مادرت شکر به جای آور که باز‌گشت (همۀ شما) به سوی من است
  31,15,و اگر آن دو (مشرک باشند و) تلاش کنند که تو چیزی را که به آن علم نداری شریک من قرار دهی، پس از آنان اطاعت نکن، و در دنیا با آنان به شایستگی رفتار کن، و از راه کسی پیروی کن که (توبه‌کنان) به سوی من باز آمده است، سپس بازگشت (همۀ) شما به سوی من است، آنگاه شما را از آنچه انجام می‌دادید؛ آگاه می‌کنم
  31,16,ای پسرک من! اگر (عمل نیک یا بد) به‌اندازۀ سنگینی دانۀ خردل باشد، آنگاه در درون تختۀ سنگی یا در آسمان‌ها یا در زمین باشد، الله آن را (در روز قیامت برای حساب) می‌آورد، بی‌گمان الله باریک‌بین آگاه است
  31,17,ای پسرک من! نماز را بر پا دار، و امر به معروف کن و نهی از منکر کن، و بر هر آنچه به تو برسد صبر کن، بی‌تردید این از کار‌های سترگ است
  31,18,و با بی اعتنایی از مردم روی مگردان، و مغرورانه در زمین راه مرو، بی‌گمان الله هیچ متکبر خود‌ستای را دوست ندارد
  31,19,و در راه رفتنت اعتدال را رعایت کن، و از صدای خود بکاه (و هرگز فریاد نزن) زیرا زشت‌ترین صدا‌ها؛ صدای خران است
  31,20,آیا ندیدید که الله آنچه را که در آسمان‌ها و آنچه را که در زمین است؛ مسخر شما کرده است، و نعمت‌های خود را آشکار و پنهان (بطور فراوان) بر شما ارزانی داشته است؟! و از مردم کسی هست که بدون هیچ دانش و هدایت و کتاب روشنگری دربارۀ الله مجادله می‌کند
  31,21,"و هنگامی‌که به آنان گفته شود: «از آنچه الله نازل کرده است؛ پیروی کنید» گویند: «(نه) بلکه ما از چیزی پیروی می‌کنیم که نیاکان خود را بر آن یافتیم». آیا حتی اگر شیطان آنان را به سوی عذاب (آتش) سوزان دعوت کند (باز هم ازآن‌ها پیروی می‌کنند؟)"
  31,22,و کسی‌که روی خویش را تسلیم الله کند در حالی‌که نیکو‌کار باشد، به راستی به دستگیرۀ محکمی چنگ زده است، و سرانجام (همۀ) کار‌ها به سوی الله است
  31,23,و کسی‌که کافر شود، پس کفر او تو را غمگین نسازد، بازگشت (همۀ) آنان به سوی ماست، پس آنان را از آنچه انجام داده‌اند؛ آگاه خواهیم کرد، بی‌تردید الله به آنچه درون سینه‌هاست؛ دانا است
  31,24,آن‌ها را اندکی (از متاع دنیا) بهره‌مند می‌کنیم، سپس آن‌ها را به (تحمل) عذاب سختی ناگزیر سازیم
  31,25,"و اگر از آن‌ها بپرسی: «چه کسی آسمان‌ها و زمین را آفرید؟!» مسلماً می‌گویند: «الله». بگو: «حمد و ستایش مخصوصِ الله است» بلکه بیشتر آن‌ها نمی‌دانند"
  31,26,آنچه در آسمان‌ها و زمین است از آنِ الله است، بی‌گمان الله است که بی‌نیاز ستوده است
  31,27,و اگر (همۀ) درختان روی زمین قلم شود، و دریا (مرکب گردد) و هفت دریای دیگر به مدد آن بیاید، سخنان الله پایان نمی‌یابد، بی‌تردید الله پیروزمند حکیم است
  31,28,آفرینش و بر انگیختن (همۀ) شما (در روز قیامت) جز مانند (آفرینش و زنده کردن) یک تن بیش نیست، بی‌گمان الله شنوای بیناست
  31,29,آیا ندیدی‌که الله شب را در روز داخل می‌کند، و روز را در شب داخل می‌گرداند، و خورشید و ماه را مسخر کرده‌که هر یک تا زمانی معین در حرکت است، و یقیناً الله به آنچه انجام می‌دهید؛ آگاه است
  31,30,این بدان (سبب) است که الله حق است، و همانا آنچه به جز او می‌خوانند؛ باطل است، و همانا الله است که بالا و بلند مرتبۀ بزرگ است
  31,31,آیا ندیدی که کشتی به (فرمان و) نعمت الله در دریا حرکت می‌کند، تا (الله) بخشی از نشانه‌های خود را به شما نشان دهد؟! بی‌گمان در این برای هر شکیبای سپاسگزار نشانه‌هایی است
  31,32,و هنگامی‌که (در دریا) موجی همچون سایه‌بان آن‌ها را بپوشاند، الله را با اخلاص می‌خوانند، پس چون آن‌ها را (با آوردن) به خشکی نجات داد، آنگاه بعضی از آنان راه اعتدال را پیش می‌گیرند. (و بر ایمان و عهد خود می‌مانند، در حالی‌که بعضی دیگر راه کفر را پیش می‌گیرند) و آیات ما را هیچ کس جز پیمان‌شکنان ناسپاس؛ انکار نمی‌کند
  31,33,ای مردم! از پروردگار‌تان بترسید، و از روزی بترسید که نه پدر کیفر فرزندش را به عهده می‌گیرید، و نه فرزند چیزی از کیفر (اعمال) پدرش را عهده دار می‌شود، یقیناً وعدۀ الله حق است، پس زندگی دنیا شما را نفریبد، و (شیطان) فریبکار شما را نسبت به الله نفریبد
  31,34,بی‌گمان علم (وقوع) قیامت نزد الله است، و (او) باران را نازل می‌کند، و آنچه را که در رحم‌هاست می‌داند، و هیچ کس نمی‌داند فردا چه چیز به دست می‌آورد، و هیچ کس نمی‌داند که در کدام سرزمین می‌میرد، یقیناً الله دانای آگاه است
  32,1,الم (الف. لام. میم)
  32,2,نازل شدن (این) کتاب، که در آن هیچ شکی نیست، از سوی پروردگار جهانیان است
  32,3,"آیا می‌گویند: «(محمد-صلی الله علیه وسلم-) آن را به دروغ بافته است؟» (نه) بلکه آن حق است، از جانب پرودگار توست، تا هشدار دهی قومی را که پیش از تو هشدار دهنده‌ای برایشان نیامده است، شاید هدایت شوند"
  32,4,الله کسی است که آسمان‌ها و زمین و آنچه را میان آن‌هاست در شش روز آفرید، سپس بر عرش قرار گرفت، شما را جز او هیچ کار ساز و شفیعی نیست، آیا پند نمی‌گیرید؟
  32,5,کار (جهان هستی) را از آسمان تا زمین تدبیر می‌کند، سپس در روزی‌که مقدار آن هزار سال از سال‌هایی است که شما می‌شمارید؛ به سوی او بالا می‌رود
  32,6,این (توصیفِ) دانای پنهان و آشکار، پیروزمند مهربان است
  32,7,(همان) کسی‌که هر چه را آفرید به نیکو‌ترین (وجه) آفرید، و آفرینش انسان را از گِل آغاز کرد
  32,8,سپس نسل او را از عصاره‌ای از آب ناچیز پدید آورد
  32,9,آنگاه (اندام) او را سامان داد، و از روح خود در آن دمید، و برای شما گوش و چشم‌ها و دل‌ها قرار داد، چه اندک سپاس می‌گزارید
  32,10,"و (کافران) گفتند: «آیا هنگامی‌که (مردیم و) در زمین ناپدید شدیم، آیا در آفرینش تازه‌ای خواهیم بود؟!» بلکه آنان به دیدار پروردگارشان کافرند"
  32,11,"(ای پیامبر!) بگو: «فرشتۀ مرگ که بر شما گماشته شده؛ جان‌تان را می‌گیرد، سپس به سوی پروردگارتان باز گردانده می‌شوید»"
  32,12,"و اگر ببینی مجرمان را هنگامی‌که در پیشگاه پروردگارشان سر‌‌‌های‌شان به زیر افکنده‌اند، (گویند:) «پروردگارا! دیدیم، و شنیدیم، پس ما را بازگردان تا کار شایسته‌ای انجام دهیم، بی‌گمان ما (به قیامت) یقین داریم»"
  32,13,و اگر می‌خواستیم به هرکس هدایتش را می‌دادیم، و لیکن سخن (و و عدۀ) من حق است که جهنم را از جنیان و آدمیان همگی پُر می‌کنم
  32,14,پس به کیفر آن‌که دیدار امروزتان را فراموش کردید، (عذاب را) بچشید، بی‌گمان ما (نیز) شما را فراموش کردیم. و عذاب جاودان را بخاطر اعمالی‌که انجام می‌دادید؛ بچشید
  32,15,تنها کسانی به آیات ما ایمان می‌آورند که چون به آن پند داده شوند، سجده‌کنان (به زمین) افتند، و پروردگارشان را به پاکی بستایند، و آنان تکبر نمی‌کنند
  32,16,پهلو‌هایشان از بسترها (در دل شب) دور می‌شود، پروردگار‌شان را با بیم و امید می‌خوانند، و از آنچه به آن‌ها روزی داده‌ایم انفاق می‌کنند
  32,17,پس هیچ کس نمی‌داند چه پاداش‌های (عظیمی) که مایۀ روشنی چشم‌هاست برای آن‌ها نهفته شده است، به (پاس) آنچه که (در دنیا) انجام می‌دادند
  32,18,آیا کسی‌که مؤمن است همچون کسی است که فاسق است؟! (نه) هرگز برابر نیستند
  32,19,اما کسانی‌که ایمان آوردند و کارهای شایسته انجام دادند، پس برای آن‌ها باغ‌های بهشت جاویدان خواهد بود، (این به عنوان) محل پذیرایی (از آن‌ها) است؛ به پاداش آنچه که انجام می‌دادند
  32,20,"و اما کسانی‌که فاسق شدند، پس جایگاه‌شان آتش (جهنم) است، هرگاه که بخواهند از آن خارج شوند، به آن باز گردانده شوند، و به آن‌ها گفته شود: «بچشید عذاب آتشی را که آن را تکذیب می‌کردید»"
  32,21,و یقیناً به آنان از عذاب نزدیک (این دنیا) پیش از عذاب بزرگ (آخرت) می‌چشانیم، شاید باز گردند
  32,22,و کیست ستمکار‌تر از آن کسی‌که به آیات پروردگارش پند داده شد، آنگاه از آن اعراض کند؟ بی‌گمان ما از مجرمان انتقام خواهیم گرفت
  32,23,به راستی به موسی کتاب (تورات) دادیم، پس (ای پیامبر گرامی!) از دیدار او (= موسی) در شک و تردید مباش و ما آن (تورات) را (وسیلۀ) هدایت برای بنی اسرائیل قرار دادیم
  32,24,و از آنان پیشوایانی قرار دادیم که به فرمان ما (مردم را) هدایت می‌کردند، چون شکیبایی ورزیدند، و به آیات ما یقین داشتند
  32,25,مسلماً پروردگار‌‌‌‌‌ توست که در روز قیامت میان آن‌ها در آنچه اختلاف می‌کردند؛ داوری می‌کند
  32,26,آیا برای آن‌ها روشن نشده است که چه نسل‌های بسیاری را پیش از آن‌ها هلاک کردیم؟! که اینان در خانه‌های (ویران شدۀ) آن‌ها راه می‌روند، بی‌گمان در این نشانه‌ها (و عبرت‌ها) است، آیا نمی‌شنوند؟
  32,27,آیا ندیدند که ما آب را به سوی زمین خشک (و بی‌گیاه) می‌رانیم، پس به (وسیلۀ) آن کشتزار را بیرون می‌آوریم، که چهارپایان‌شان و خود‌‌‌‌شان از آن می‌خورند، آیا نمی‌بینند؟
  32,28,"و گویند: «اگر راستگو‌‌یید، این پیروزی کی خواهد بود؟!»"
  32,29,"بگو: «روز پیروزی (هنگام نزول عذاب یا روز قیامت)، کسانی‌که کافر شدند؛ ایمان شان سودی نخواهد داشت، و نه به آن‌ها مهلت داده می‌شود»"
  32,30,سپس (ای پیامبر!) از آن‌ها روی بگردان، و منتظر باش که آن‌ها (نیز) منتظر هستند
  33,1,ای پیامبر! از الله بترس، و از کافران و منافقان اطاعت نکن، بی‌گمان الله دانای حکیم است
  33,2,و از آنچه از سوی پروردگارت به تو وحی می‌شود؛ پیروی کن، یقیناً الله به آنچه انجام می‌دهید؛ آگاه است
  33,3,و بر الله توکل کن، و الله (به عنوان) کارساز (و مدافع) بسنده است
  33,4,"الله برای هیچ‌کس دو قلب در درونش قرار نداده است، و هرگز همسران‌تان را که مورد ظهار قرار می‌دهید؛ مادران شما قرار نداده است [ به سورۀ مجادله آیه 2 و 3 رجوع شود.]، و (نیز) فرزند خوانده‌های شما را فرزند (حقیقی) شما قرار نداده است، این سخن (باطل) شماست که به دهان خود می‌گویید، و الله سخن حق را می‌گوید، و او به راه راست هدایت می‌کند"
  33,5,آن‌ها (= فرزند خوانده‌ها) را به نام پدران‌شان بخوانید که این (کار) نزد الله منصفانه‌تر است، پس اگر پدران‌شان را نمی‌شناسید، برادران دینی شما، و موالی شما هستند. و در آنچه که (قبلاً) اشتباه کرده‌اید؛ گناهی بر شما نیست، و لیکن آنچه را که دل‌های شما از روی عمد می‌خواهد (و می‌گویید، گناه است) و الله آمرزندۀ مهربان است
  33,6,"پیامبر نسبت به مؤمنان از خودشان سزاوار‌تر است، و همسران او مادران آن‌ها هستند، و در کتاب الله خویشاوندان برخی از آنان به برخی (دیگر) از (سایر) مؤمنان و مهاجران سزاوارترند [ یعنی باید مؤمنان پیامبر گرامی صلی الله علیه وسلم را از جان خود بیشتر دوست داشته باشند.]، مگر این‌که به دوستان‌تان نیکی کنید (و سهمی از اموال خود را به آنان بدهید) این (حکم) در کتاب (لوح محفوظ) نوشته شده است"
  33,7,و (ای پیامبر گرامی! به یاد آور) هنگامی را که از پیامبران پیمان شان را گرفتیم و (همچنین) از تو و از نوح و ابراهیم و موسی و عیسی بن مریم، و از همۀ آنان پیمان محکمی گرفتیم
  33,8,تا (الله) راستگویان را از صدق‌شان بپرسد، و برای کافران عذابی دردناک آماده کرده است
  33,9,ای کسانی‌که ایمان آورده‌اید! نعمت الله را بر خود به یاد آورید، هنگامی‌که لشکر‌هایی به سوی شما آمدند، پس ما تند باد (سختی) بر آن‌ها فرستادیم، و لشکر‌هایی (از فرشتگان) که آن‌ها را نمی‌دیدید، (و آن‌ها را درهم کوبیدیم) و الله به آنچه انجام می‌دهید؛ بیناست
  33,10,هنگامی‌که آن‌ها (= دشمنان در غزوۀ احزاب) از (سمت) بالای (شهر) شما و از (سمت) پایین (شهر) تان به سوی شما آمدند (و شما را محاصره کردند) و زمانی را که چشم‌ها (از شدت و حشت) خیره شد، و دل‌ها به حنجره‌ها رسید، و گمان های گوناگونی به الله می‌بردید
  33,11,آنجا بود که مؤمنان آزمایش شدند و به سختی تکان خوردند
  33,12,"و (نیز به یاد آورید) هنگامی را که منافقان و کسانی‌که در دل‌های شان بیماری است، می‌گفتند: «الله و پیامبرش جز فریب به ما وعده‌ای نداده است»"
  33,13,"و (نیز) هنگامی‌که گروهی از آنان گفتند: «ای اهل یثرب! اینجا جای ماندن شما نیست، پس (به خانه‌های خود) برگردید» و گروهی از آنان از پیامبر اجازۀ (بازگشت) می‌خواستند، می‌گفتند: «بی‌شک خانه‌های ما بی حفاظ است» در حالی‌که بی حفاظ نبود، آن‌ها فقط می‌خواستند (از جهاد) فرار کنند"
  33,14,و اگر (لشکر دشمنان) از اطراف مدینه بر آنان وارد می‌شدند (و خانه‌هایشان را محاصره می‌کردند) سپس پیشنهاد بازگشت به کفر و شرک (به آن‌ها) می‌کردند، قطعاً می‌پذیرفتند، و جز اندکی برای (انتخاب) آن درنگ نمی‌کردند
  33,15,و به راستی که آنان پیش از این با الله عهد کرده بودند که پشت (به دشمن) نکنند، و عهد (و پیمان) الله باز خواست دارد
  33,16,"(ای پیامبر!) بگو: «اگر از مرگ یا کشته شدن فرار کنید، هرگز فرار سودی به حال شما نخواهد داشت، و آنگاه جز اندکی (از زندگی دنیا) بهره‌مند نخواهید شد»"
  33,17,"(ای پیامبر!) بگو: «چه کسی است که شما را از (ارادۀ) الله حفظ می‌کند، اگر (او) برای شما بدی اراده کرده باشد، یا رحمتی برای شما اراده کرده باشد؟!» و آن‌ها برای خود جز الله هیچ دوست و یاوری نخواهند یافت"
  33,18,"قطعاً الله باز دارندگان را (از جهاد) از شما، و آنان را که به برادران‌شان گفتند: «به سوی ما بیایید» و جز اندکی به کارزار نمی‌آیند؛ می‌شناسد"
  33,19,(در حالی‌که) آن‌ها بر شما بخل می‌ورزند، پس هنگامی‌که (زمان) ترس (پیش) آید، می‌بینی که به تو نگاه می‌کنند، در حالی‌که چشم‌هایشان (در حدقه) می‌چرخد، مانند کسی‌که از (سکرات) مرگ بی هوش شده باشد، پس چون ترس (و وحشت) بر طرف شد، شما را با زبان‌های تیز (و تند خود) می‌رنجانند، در حالی‌که بر مال (غنایم) سخت حریص و آزمندند، اینان (هرگز) ایمان نیاورده‌اند، لذا الله اعمال‌شان را تباه (و نابود) کرد، و این (کار) بر الله آسان است
  33,20,آن‌ها گمان می‌کنند که (لشکریان) احزاب (هنوز) نرفته‌اند، و اگر (لشکریان) احزاب (بار دیگر) بر گردند، آرزو می‌کنند، ای کاش! آنان در میان اعراب بادیه‌نشین بودند، که از اخبار شما جویا می‌شدند، و اگر در میان شما باشند؛ جز اندکی پیکار نکنند
  33,21,یقیناً برای شما در زندگی رسول الله سرمشق نیکویی است، برای آنان که به الله و روز آخرت امید دارند، و الله را بسیار یاد می‌کنند
  33,22,"و چون مؤمنان (لشکر) احزاب را دیدند، گفتند: «این همان چیزی است که الله و پیامبرش به ما وعده داده، و الله و پیامبرش راست گفته‌اند» و (این امر) جز بر ایمان و تسلیم‌شان نیفزود"
  33,23,از مؤمنان مردانی هستند که به عهد و پیمانی که با الله بسته بودند (صادقانه) وفا کردند، پس کسی از آنان هست که پیمان خود را به آخر رساند (و شهید شد) و از آنان کسی هست که در انتظار (و چشم براه) است، و هرگز تغییر و تبدیلی (در پیمان خود) نیاورده‌اند
  33,24,تا الله راستگویان را به (خاطر) صدق‌شان پاداش دهد، و منافقان را اگر بخواهد عذاب کند، یا توبۀ آن‌ها را بپذیرد، بی‌تردید الله آمرزندۀ مهربان است
  33,25,و (در غزوۀ احزاب) الله کافران را با خشم شان (از مدینه) باز گرداند، (در حالی‌که) هیچ خیر و منفعتی نیافتند، و الله مؤمنان را از جنگ بی‌نیاز کرد، (و پیروزی نصیب‌شان ساخت) و الله توانای پیروزمند است
  33,26,و (الله) کسانی از اهل کتاب (= یهود بنی قریظه) را که از آن‌ها (= مشرکان) حمایت کرده بودند؛ از قلعه‌هایشان فرود آورد، و در دل‌های شان و حشت انداخت، (و شما) گروهی را می‌کشتید و گروهی را اسیر می‌گرفتید
  33,27,و (الله) زمین آنان و خانه‌هایشان و اموال‌شان را به شما وا گذاشت و (همچنین) زمینی را که در آن گام ننهاده بودید، و الله بر هر چیز تواناست
  33,28,"ای پیامبر! به همسرانت بگو: «اگر شما زندگی دنیا و زینت آن می‌خواهید، پس بیایید تا (با هدیه‌ای مناسب) شما را بهرمند سازم، و شما را به طرز نیکوئی رها کنم"
  33,29,و اگر شما الله و پیامبرش و سرای آخرت را می‌خواهید، پس (بدانید که) الله برای نیکوکارانتان پاداش عظیمی آماده کرده است»
  33,30,ای زنان پیامبر! هر کس از شما که (گناه) نا شایست آشکاری مرتکب شود، عذاب او دو چندان افزوده می‌شود، و این بر الله آسان است
  33,31,و هر کس از شما برای الله و پیامبرش خضوع (و فرمانبرداری) کند، و عمل صالح انجام دهد، پاداش او را دوبار به او خواهیم داد، و روزی ارزشمندی برای او آماده کرده‌ایم
  33,32,ای زنان پیامبر! شما مانند هیچ یک از زنان (عادی دیگر) نیستید، اگر پرهیزگاری کنید؛ پس در سخن گفتن نرمی نکنید که آنگاه کسی‌که در دلش بیماری است؛ طمع کند، و سخن شایسته بگویید
  33,33,و در خانه‌های خود بمانید، و به شیو‌ۀ جاهلیت نخستین زینت‌های خود را آشکار نکنید، و نماز را بر پا دارید، و زکات را بدهید، و الله و پیامبرش را اطاعت کنید، الله قطعاً می‌خواهد پلیدی را از شما اهل بیت دور کند و چنانکه باید شما را پاک سازد
  33,34,و آنچه را در خانه‌هایتان از آیات الله و حکمت (= سنت پیامبر) خوانده می‌شود یاد کنید؛ بی‌گمان الله باریک‌بین آگاه است
  33,35,همانا مردان مسلمان و زنان مسلمان، مردان مؤمن و زنان مؤمن، مردان فرمانبردار و زنان فرمانبردار، مردان راستگو و زنان راستگو، مردان صابر و زنان صابر، مردان با خشوع و زنان با خشوع، مردان صدقه دهنده و زنان صدقه دهنده، مردان روزه دار و زنان روزه دار، مردانی‌که شرمگاه خود را حفظ می‌کنند، و زنانی‌که شرمگاه خود را حفظ می‌کنند، و مردانی‌که الله را بسیار یاد می‌کنند، و زنانی‌که الله را بسیار یاد می‌کنند، الله برای (همۀ) آنان آمرزش و پاداش عظیمی آماده کرده است
  33,36,و هیچ مرد مؤمن و زن مؤمنی را نسزد؛ هنگامی‌که الله و پیامبرش کاری را حکم کند، آنکه آن‌ها در کارشان اختیاری باشد، و هرکس الله و پیامبرش را نافرمانی کند، به راستی‌که در گمراهی آشکاری گرفتار شده است
  33,37,"و (به یاد بیاور) زمانی را که به آن کس‌که الله به او نعمت داده بود، و تو (نیز) به او نعمت داده بودی، می‌گفتی: «همسرت را نگاه دار و از الله بترس» و در دل خود چیزی را پنهان می‌داشتی‌که الله آن را آشکار می‌کند، و از مردم می‌ترسیدی؛ در حالی‌که الله سزاوارتر است‌که از او بترسی، پس چون زید (بن حارثه -رضی الله عنه-) از او حاجت خویش بگزارد، (و طلاقش داد) او را به ازدواج تو در آوردیم؛ تا بر مؤمنان در (بارۀ ازدواج با) زنان پسر خواندگان‌شان هیچ حرجی نباشد؛ هنگامی‌که حاجت خویش از او بگزارده (و طلاق‌شان داده) باشند، و فرمان الله انجام شدنی است"
  33,38,بر پیامبر در آنچه الله برای او حلال (و مقرر) کرده است؛ هیچ حرجی نیست، این سنت الله است در (بارۀ) کسانی‌که پیش از این بوده‌اند، و فرمان الله حساب شده و دقیق است
  33,39,(همان) کسانی‌که پیام‌های الله را می‌رسانند و از او می‌ترسند و از هیچ کس جز او نمی‌ترسند، و الله برای حساب‌گری (اعمال‌شان) کافی است
  33,40,محمد ( صلی الله علیه وسلم) پدر هیچ‌یک از مردان شما نیست، و لیکن رسول الله و خاتم پیامبران است، و الله به هر چیز آگاه است
  33,41,ای کسانی‌که ایمان آورده‌اید! الله را بسیار یاد کنید
  33,42,و صبح و شام او را تسبیح گویید
  33,43,او کسی است که بر شما درود می‌فرستد، و فرشتگانش (نیز بر شما درود می‌فرستند) تا شما را از تاریکی‌ها به سوی نور بیرون برد، و (الله) نسبت به مؤمنان مهربان است
  33,44,تحیت آنان در روزی‌که با او دیدار می‌کنند «سلام» است، و برای آن‌ها پاداش ارزشمندی آماده کرده است
  33,45,ای پیامبر! ما تو را گواه، و بشارت‌دهنده و بیم‌دهنده فرستادیم
  33,46,و دعوت کننده به سوی الله به فرمان او، و چراغی روشنی بخش قرار دادیم
  33,47,و مؤمنان را بشارت ده که برای آن‌ها از سوی الله فضل بزرگی است
  33,48,و از کافران و منافقان اطاعت مکن، و آزار‌شان را و اگذار (و به آنان اعتنای نکن) و بر الله توکل کن، و الله (به عنوان) کارساز (و مدافع) بسنده است
  33,49,ای کسانی‌که ایمان آورده‌اید! هنگامی‌که با زنان با ایمان ازدواج کردید، آنگاه پیش از آن‌که با آن‌ها همبستری کنید، طلاق‌شان دادید، پس عده‌ای برای شما بر آن‌ها نیست که شما آن را بشمارید، لذا آن‌ها را (با هدیه‌ای مناسب) بهره‌مند سازید و به نیکوترین وجه رهای‌شان کنید
  33,50,ای پیامبر! ما همسرانت را که مهر‌شان را پرداخته‌ای برای تو حلال کردیم، و (نیز) کنیزانی را که (از طریق غنایم جنگی) الله به تو ارزانی داشته است، و دختران عمویت، و دختران عمه‌هایت و دختران دایی‌ات، و دختران خاله‌هایت که با تو هجرت کرده‌اند، (ازدواج با آن‌ها برای تو حلال کرده‌ایم) و (نیز) زن مؤمنی را که اگر خود را به پیامبر ببخشد، اگر پیامبر بخواهد او را به زنی گیرد، (این حکم) ویژۀ توست؛ نه دیگر مؤمنان، به راستی که ما می‌دانیم آنچه را که بر آن‌ها در (بارۀ) همسران‌شان و کنیزان‌شان واجب کرده‌ایم، تا بر تو هیچ حرجی نباشد، و الله آمرزندۀ مهربان است
  33,51,(نوبت) هر یک از همسرانت را که بخواهی (می‌توانی) به تأخیر اندازی، و هرکدام را بخواهی نزد خود جای دهی، و اگر (بعضی) از آن‌ها که بر کنار ساخته‌ای بخواهی نزد خود جای دهی، هیچ گناهی بر تو نیست، این (گزینش) نزدیکتر است برای آن‌که چشم آنان روشن گردد و این‌که غمگین نباشند، و همگی‌شان به آنچه به آنان می‌دهی خشنود گردند، و الله آنچه را که در دل‌های شماست می‌داند، و الله دانای بردبار است
  33,52,بعد از این، (دیگر) هیچ زنی برای تو حلال نیست، و نه (حلال است) آن‌که همسران دیگری جایگزین آن‌ها کنی، هر چند زیبایی آن‌ها تو را به شگفت آورد، مگر آنچه‌که (بصورت کنیز) دست تو مالک شد، و الله بر همه چیز نگهبان است
  33,53,ای کسانی‌که ایمان آورده‌اید! به خانه‌های پیامبر داخل نشوید؛ مگر آنکه برای (صرف) غذا به شما اجازه داده شود، بی‌آنکه منتظر پخته شدنش باشید، ولی چون دعوت شدید، داخل شوید، پس هنگامی‌که غذا خوردید؛ پراکنده شوید، و (بعد از صرف غذا) برای بحث و گفتگو ننشینید، بی‌گمان این (عمل) پیامبر را آزار می‌دهد، پس (او) از شما شرم می‌کند (و چیزی نمی‌گوید) و الله از (بیان) حق شرم نمی‌کند، و هنگامی‌که چیزی (از وسایل زندگی به عاریت) خواستید، پس از آنان (= زنان پیامبر) از پشت پرده بخواهید، این (کار) برای دل‌های شما و دل‌های آنان پاکیزه‌تر است، و شما را نسزد که پیامبر الله را بیازارید، و نه آن‌که همسرانش را بعد از او هرگز به همسری گیرید، بی‌تردید این (کار) نزد الله (گناهی) بزرگ است
  33,54,اگر چیزی را آشکار کنید یا آن را پنهان دارید، پس بی‌گمان الله به هر چیز آگاه است
  33,55,بر آنان (= زنان) گناهی نیست (که) در (حضور) پدران‌شان و پسران‌شان و برادران‌شان و پسران برادران‌شان و پسران خواهران‌شان و زنان (هم دین) شان و بردگان‌شان (بدون حجاب باشند) و (ای زنان!) از الله بترسید، قطعاً الله بر همه چیز گواه است
  33,56,بی‌گمان الله و فرشتگانش بر پیامبر درود می‌فرستند؛ ای کسانی‌که ایمان آورده‌اید! بر او درود فرستید، و سلام بگویید، سلامی نیکو
  33,57,همانا کسانی‌که الله و پیامبرش را آزار می‌دهند، الله آن‌ها را در دنیا و آخرت لعنت کرده، و برای آن‌ها عذاب خوارکننده‌ای آماده کرده است
  33,58,و کسانی‌که مردان مؤمن و زنان مؤمن را بی هیچ گناهی‌که مرتکب شده باشند؛ آزار می‌دهند، به راستی (بار) بهتان و گناه آشکاری را به دوش کشیده‌اند
  33,59,"ای پیامبر! به همسرانت و دخترانت و زنان مؤمنان بگو: «چادر‌های خود را بر خویش فرو افکنند، (و با آن سر و صورت و سینه‌هایشان را بپوشانند) این مناسب‌تر است تا شناخته شوند؛ پس مورد آزار قرار نگیرند، و الله آمرزندۀ مهربان است"
  33,60,اگر منافقان و کسانی‌که در دل‌های شان بیماری است، و شایعه پراکنان در مدینه (از کار خود) باز نایستند، یقیناً تو را بر (ضد) آن‌ها می‌شورانیم (و بر آن‌ها مسلط می‌گردانیم) سپس جز اندکی در کنار تو در آن (شهر مدینه) نباشند
  33,61,طرد شدگانند، هر کجا یافت شوند، گرفته خواهند شد، و به سختی کشته خواهند شد
  33,62,(این)سنت الله است در (بارۀ) کسانی‌که پیش از این گذشتند، و هرگز برای سنت الله دگرگونی نخواهی یافت
  33,63,"(ای پیامبر!) مردم تو را از (زمان قیام) قیامت می‌پرسند، بگو: «علم آن تنها نزد الله است» و تو چه می‌دانی شاید‌که قیامت نزدیک باشد"
  33,64,بی‌تردید الله کافران را لعنت کرده، و برای آن‌ها آتش سوزان آماده کرده است
  33,65,که جاودانه در آن خوهند ماند، هیچ دوست و یاوری نخواهند یافت
  33,66,"روزی‌که صورت‌هایشان در آتش (جهنم) گردانیده شود (پشیمان می‌شوند و) می‌گویند: «ای کاش الله را اطاعت کرده بودیم، و رسول (الله) را اطاعت کرده بودیم»"
  33,67,"و گفتند: «پروردگارا! ما از سروران و بزرگان خود اطاعت کردیم، پس ما را از راه به در بردند (و گمراه کردند)"
  33,68,پروردگارا! آن‌ها را از عذاب دو چندان ده، و آن‌ها را به لعنتی بزرگ (و سخت) لعنت فرما»
  33,69,ای کسانی‌که ایمان آورده‌اید! مانند کسانی نباشید که موسی را آزار دادند، آنگاه الله او را از آنچه (در حق او) گفته بودند؛ مبّرا ساخت، و (او) نزد الله آبرومند (و صاحب منزلت) بود
  33,70,ای کسانی‌که ایمان آورده‌اید! از الله بترسید، و سخن درست (و حق) بگویید
  33,71,تا (الله) کارهای‌تا‌ن را برایتان اصلاح کند، و گناهان‌تان را بیامرزد، و هرکس‌که از الله و پیامبرش اطاعت کند؛ یقیناً به کامیابی عظیمی نائل شده است
  33,72,همانا ما امانت (خویش) را بر آسمان‌ها و زمین و کوه‌ها عرضه داشتیم، پس آن‌ها از تحمل آن سر باز زدند و از آن ترسیدند، و انسان آن را بر دوش گرفت که او بسیار ستمکار نادان است
  33,73,تا (سرانجام) الله مردان منافق و زنان منافق و مردان مشرک و زنان مشرک را عذاب کند، و الله توبۀ مردان مؤمن و زنان مؤمن را بپذیرد (و از گناهان‌شان در گذرد) و الله آمرزندۀ مهربان است
  34,1,حمد (و ستایش) مخصوصاللهِ است که آنچه در آسمان‌ها و آنچه در زمین است از آنِ اوست، و ستایش در (سرای) آخرت (نیز) از آنِ اوست، و او حکیم آگاه است
  34,2,آنچه را که در زمین فرو می‌رود و آنچه را که از آن بیرون می‌آید، و آنچه را که از آسمان نازل می‌شود و آنچه را که در آن بالا می‌رود؛ می‌داند، و او مهربان آمرزنده است
  34,3,"و کسانی‌که کافر شدند، گفتند: «قیامت به سراغ ما نخواهد آمد» (ای پیامبر!) بگو: «آری، به پروردگارم (آن) دانای غیب سوگند که حتماً به سراغ شما خواهد آمد، به‌اندازۀ ذره‌ای در آسمان‌ها و در زمین از او پنهان نیست، و نه کوچکتر از آن و نه بزرگتر، مگر (اینکه) در کتابی آشکار (ثبت) است"
  34,4,تا کسانی را که ایمان آورده‌اند و کار‌های شایسته انجام داده‌اند؛ پاداش دهد، آنان برایشان مغفرت و روزی ارزشمندی است
  34,5,و کسانی‌که مبارزه‌کنان در (انکار) آیات ما تلاش کردند (و گمان کردند که ما را به ستوه می‌آورند) برای آنان عذابی از کیفر دردناک خواهد بود
  34,6,و کسانی‌که به ایشان علم داده شده است؛ می‌دانند آنچه را که از سوی پروردگارت بر تو نازل شده، حق است، و به راه (الله) پیروزمند ستوده هدایت می‌کند
  34,7,"و کسانی‌که کافر شدند، گفتند: «آیا مردی به شما نشان دهیم که به شما خبر می‌دهد هنگامی‌که (مردید و) کاملاً متلاشی (و پراکنده) شدید، همانا شما (بار دیگر) در آفرینش تازه‌ای خواهید بود؟"
  34,8,آیا بر الله دروغ بسته یا به او دیوانگی است؟!» (چنین نیست) بلکه کسانی‌که به آخرت ایمان نمی‌آورند در عذاب و گمراهی دور و درازی هستند
  34,9,آیا به آنچه پیش روی و آنچه پشت سر آنان از آسمان و زمین است، نگاه نکرده‌اند؟! اگر بخواهیم آن‌ها را در زمین فرو می‌بریم، یا تکه‌ای از آسمان را بر (سر) آنان می‌افکنیم، بی‌گمان در این نشانه‌ای برای هر بندۀ بازگشت کننده‌ای است
  34,10,"و به راستی (ما) به داوود از سوی خود فضیلتی (بزرگ) دادیم، (گفتیم:) ای کوه‌ها و ای پرندگان! با او (در تسبیح گفتن) هم آواز شوید، و آهن را برای او نرم کردیم"
  34,11,(و به او دستور دادیم) که زره‌های بلند (و فراخ) بساز و در بافتن (حلقه‌ها) اندازه نگه دار، و کار شایسته انجام دهید، همانا من به آنچه انجام می‌دهید؛ بینا هستم
  34,12,و برای سلیمان باد را (مسخر ساختیم) که صبحگاهان مسیر یک ماه را طی می‌کرد، و شامگاهان مسیر یک ماه را، و چشمۀ مس (مذاب) را برایش روان ساختیم، و از جن کسانی را (مسخر کردیم) که به فرمان پروردگارش در پیش او کار می‌کردند، و هر که از آنان که از فرمان ما سرپیچی می‌کرد، او را از عذاب آتش سوزان می‌چشاندیم
  34,13,"(سلیمان) هر چه می‌خواست (جن‌ها) برایش می‌ساختند: از (قبیل) معبد‌ها، و تمثال‌ها، و کاسه‌هایی (غذا خوری) همچون حوض‌ها، و دیگ‌های ثابت (که از بزرگی قابل حمل و نقل نبود، و به آن‌ها گفتیم:) ای آل داوود! سپاس (این همه نعمت را) به جا آوردید، و اندکی از بندگان من سپاسگزارند"
  34,14,پس چون مرگ را بر او (= سلیمان) مقرر داشتیم، (کسی) آن‌ها را از مرگش آگاه نساخت؛ مگر جنبندۀ زمین (= موریانه) که عصایش را می‌خورد، پس چون (بر زمین) افتاد، جنیان دریافتند که اگر غیب می‌دانستند در (آن) عذاب خوار کننده نمی‌ماندند
  34,15,"همانا برای (قوم) سبا در مساکن‌شان نشانه‌ای بود، دو باغ (بزرگ) از راست و چپ، (و به آن‌ها گفتیم:) از روزی پروردگار‌تان بخورید و برای او شکر گزارید، شهری است پاکیزه، و پروردگاری آمرزنده"
  34,16,پس آن‌ها روی گرداندند، آنگاه سیلی ویران‌گر را برآن‌ها فرستادیم، و دو باغ (پر میوه) شان را به دو باغ (بی ارزش) با میوه‌های تلخ و (درختان) شوره‌گز و اندکی از (درخت) کنار مبّدل ساختیم
  34,17,این کیفر را به (خاطر) آن‌که نا سپاسی کردند؛ به آن‌ها دادیم، و آیا جز نا سپاسان را مجازات می‌کنیم؟
  34,18,"و میان آن‌ها و قریه‌هایی که برکت داده بودیم، قریه‌هایی (آباد و) به هم پیوسته (بر سر راه) قرار دادیم، و در (میان) آن‌ها آمد‌ و رفت مقرر داشتیم (و به آنان گفتیم:) در این (آبادی‌ها) با امن (و امان) شب‌ها و روز‌ها سفر کنید"
  34,19,"پس گفتند: «پروردگارا‌! میان سفر‌های ما دوری بیفکن» و بر خویشتن ستم کردند، پس ما آن‌ها را داستان‌هایی (برای عبرت دیگران) قرار دادیم، و آنان را سخت پراکنده (و متلاشی) ساختیم، بی‌گمان در این (ماجرا) برای هر صبر کنندۀ سپاسگزاری نشانه‌هایی است"
  34,20,و یقیناً ابلیس گمان خود را دربارۀ آن‌ها درست یافت، پس (همگی) از او پیروی کردند؛ جز گروهی (اندک) از مؤمنان
  34,21,و او (= شیطان) را بر آنان هیچ سلطه‌ای نبود؛ مگر اینکه (خواستیم) معلوم بداریم کسی را که به آخرت ایمان می‌آورد، از کسی‌که او از آن در شک (و تردید) است. و پروردگار تو بر همه چیز نگاهبان است
  34,22,"(ای پیامبر!) بگو: «کسانی را که غیر از الله (معبود خود) می‌پندارید، (به فریاد) بخوانید، (آن‌ها) هم‌وزن ذره‌ای در آسمان‌ها و در زمین مالک نیستند، و در (آفرینش و تدبیر) آن دو هیچ شرکتی ندارند، و او (= الله) از میان آن‌ها یاور و پشتیبانی ندارد"
  34,23,"و شفاعت نزد او سود نبخشد؛ مگر برای کسی‌که (او خود) برایش اجازت داده باشد، تا زمانی‌که اضطراب (و نگرانی) از دل‌های شان بر طرف شود، گویند: «پروردگار‌تان چه گفت؟» گویند: «حق را (فرمود)، و او بالا و بلند مرتبۀ بزرگ است»"
  34,24,"(ای پیامبر! به مشرکان) بگو: «چه کسی شما را از آسمان‌ها و زمین روزی می‌دهد؟» (در پاسخ) بگو: «الله، و ما یا شما بر (طریق) هدایت یا در گمراهی آشکار هستیم»"
  34,25,"بگو: «شما از گناهی‌که ما مرتکب شده‌ایم؛ باز خواست نمی‌شوید، و ما (نیز) از آنچه شما انجام می‌دهید؛ باز خواست نمی‌شویم»"
  34,26,"بگو: « پروردگار ما، (همۀ) ما (و شما) را گرد می‌آورد؛ سپس در میان ما به حق داوری می‌کند، و او داور داناست»"
  34,27,"بگو: «کسانی را که به عنوان شریک به او ملحق ساخته‌اید؛ به من نشان دهید، (هرگز) چنین نیست، بلکه او الله پیروزمندِ حکیم است"
  34,28,و (ای پیامبر!) ما تو را برای همۀ مردم؛ جز بشارت‌دهنده و بیم‌دهنده نفرستادیم، و لیکن بیشتر مردم نمی‌دانند
  34,29,"و می‌گویند: «اگر راستگویید؛ این وعدۀ (قیامت) کی خواهد بود؟!»"
  34,30,"بگو: «میعاد شما روزی خواهد بود که نه ساعتی از آن تأخیر می‌کنید و نه (بر آن) پیشی می‌گیرید»"
  34,31,"و کسانی‌که کافر شدند، گفتند: «ما هرگز به این قرآن ایمان نمی‌آوریم و نه به آن (کتاب‌های) که پیش از آن بوده». (ای پیامبر!) اگر ببینی (در روز قیامت) هنگامی‌که ستمکاران در پیشگاه پروردگار‌شان (برای حساب‌رسی) نگه داشته شده‌اند، (از حال آن‌ها به شگفت می‌آیی) برخی از آن‌ها سخن برخی دیگر را پاسخ می‌دهند (و هر کدام گناه خود را به گردن دیگری می‌اندازد) کسانی‌که به استضعاف کشیده شده‌اند، به کسانی‌که استکبار (و سرکشی) نمودند، گویند: «اگر شما نبودید ما قطعاً مؤمن بودیم»"
  34,32,"کسانی‌که سرکشی (و تکبر) کردند (= مستکبران) به کسانی‌که به استضعاف کشیده شده‌اند، (= مستضعفان) گویند: «آیا ما شما را از هدایت باز داشتیم بعد از آن‌که به سراغ شما آمد؟! (هرگز نه) بلکه شما خود مجرم بودید»"
  34,33,"و مستضعفان به مستکبران گویند: «بلکه، مکر و حیلۀ شب و روز شما (سبب شد که از هدایت بازمانیم) هنگامی‌که به ما دستور می‌دادید که به الله کافر شویم و برای او همتایانی قرار دهیم». و هنگامی‌که عذاب (الهی) را ببینند، پشیمانی (خود) را (در دل) پنهان دارند، و ما غل‌ها در گردن‌های کسانی‌که کافر شدند؛ بگذاریم، آیا جز آنچه عمل می‌کردند، به آن‌ها جزا داده می‌شود؟"
  34,34,"ما در هیچ قریه‌ای هشداردهنده‌ای نفرستادیم؛ مگر اینکه متنعّمان آن‌ها (که مست ناز و نعمت و قدرت بودند) گفتند: «بی‌تردید ما به آنچه فرستاده شده‌اید؛ کافریم»"
  34,35,"و گفتند: «اموال و اولاد ما (از شما) بیشتر است، (و این دلیل آن است که الله از ما خشنود است) و ما هرگز مجازات نخواهیم شد»"
  34,36,"(ای پیامبر!) بگو: «بی‌گمان پروردگارم روزی را برای هر کس‌که بخواهد فراخ و (یا) تنگ می‌کند، (و این نشانۀ محبت و رضایت الله نیست) و لیکن بیشتر مردم نمی‌دانند»"
  34,37,و اموال‌تان و اولاد‌تان چیزی نیستند که شما را نزد ما نزدیک و مقّرب سازند، جز کسانی‌که ایمان آوردند و عمل صالح انجام دادند، پس اینان پاداش مضاعف در برابر کار‌های‌که انجام داده‌اند؛ دارند، و آن‌ها در غرفه‌های (بلند بهشتی) در امن و (امان) هستند»
  34,38,و کسانی‌که مبارزه‌کنان در (انکار) آیات ما تلاش کردند (و گمان کردند‌ که ما را به ستوه می‌آورند) اینان در عذاب احضار می‌شوند
  34,39,"(ای پیامبر!) بگو: «بی‌گمان پروردگارم روزی را برای هرکس‌که بخواهد فراخ می‌گرداند، و (یا) برای او تنگ (و محدود) می‌سازد، و هر چیزی را (در راه الله) انفاق کنید، پس او عوض آن را می‌دهد، و او بهترین روزی دهندگان است»"
  34,40,"و (به یاد آور) روزی را که (الله) همۀ آنان را بر می‌انگیزد، سپس به فرشتگان می‌گوید: «آیا این‌ها شما را پرستش می‌کردند؟!»"
  34,41,"(فرشتگان) گویند: «تو منزهی! (تنها) تو ولی (و کار ساز) ما هستی، نه آن‌ها، (آنان هرگز ما را پرستش نمی‌کردند) بلکه جن (و شیاطین) را پرستش می‌کردند، بیشتر‌‌شان به آن‌ها ایمان داشتند»"
  34,42,"پس امروز برخی از شما برای برخی دیگر مالک هیچ سود و زیانی نیست، و به کسانی‌که ستم (= شرک) کردند، می‌گوییم: «بچشید عذاب آتشی را که آن را تکذیب می‌کردید»"
  34,43,"و هنگامی‌که آیات روشن (و واضح) ما بر آنان خوانده شود، گویند: «این (محمد صلی الله علیه وسلم) جز مردی نیست که می‌خواهد شما را از آنچه نیاکان‌تان می‌پرستیدند؛ باز دارد» و گویند: «این (قرآن) جز دروغ بزرگی‌که به هم بافته شده نیست». و کسانی‌که کافر شدند، هنگامی‌که حق به سراغ آن‌ها آمد، دربارۀ آن گفتند: «این (قرآن) جز سحری آشکار نیست»"
  34,44,و ما (پیش از این) چیزی از کتاب‌های (آسمانی) را به آن‌ها نداده‌ایم که آن را بخوانند (و بر اساس آن تو را تکذیب کنند) و پیش از تو هیچ هشداردهنده‌ای به سوی آن‌ها نفرستادیم
  34,45,و کسانی‌که پیش از آن‌ها بودند (نیز پیامبران ما را) تکذیب کردند، در حالی‌که این‌ها به یک دهم آنچه به آن‌ها داده بودیم؛ نرسیده‌اند، آنگاه آن‌ها پیامبران مرا تکذیب کردند، (بنگر) مجازات من چگونه بود؟
  34,46,"(ای پیامبر!) بگو: «همانا من شما را به یک (خصلت) اندرز می‌دهم، که: دو نفر دو نفر یا یک نفر یک نفر برای الله بر خیزید، سپس بیندیشید که این همنشین شما (= محمد صلی الله علیه وسلم) هیچ‌گونه دیوانگی ندارد، او برای شما جز هشداردهندۀ پیشاپیش عذاب شدید نیست»"
  34,47,"(ای پیامبر!) بگو: «هر مزدی‌که از شما خواسته‌ام؛ پس آن برای خود شما باد، پاداش من تنها بر (عهدۀ) الله است، و او بر همه چیز گواه است»"
  34,48,"(ای پیامبر!) بگو: «بی‌گمان پروردگارم حق را (بر قلب پیامبران خود) می‌افکند، (آن پروردگاری‌که) دانای غیب‌هاست»"
  34,49,"(ای پیامبر!) بگو: «حق آمد، و (معبودان) باطل نه (آفرینش را) آغاز می‌کند، و نه (دوباره) باز می‌گرداند»"
  34,50,"(ای پیامبر!) بگو: «اگر من گمراه شوم، تنها بر زیان خودم گمراه می‌شوم، و اگر هدایت یابم، پس به (خاطر) آن چیزی است که پروردگارم به من وحی می‌کند، یقیناً او شنوای نزدیک است»"
  34,51,و (ای پیامبر!) اگر ببینی هنگامی‌که مضطرب (و نگران) شوند، آنگاه رهایی (از عذاب) نباشد، و از جای نزدیکی گرفته شوند (تعجب خواهی کرد)
  34,52,"و (در آن‌حال) گویند: «به آن (قرآن) ایمان آوردیم» ولی چگونه می‌توانند از فاصلۀ دور به آن دست یابند؟"
  34,53,در حالی‌که آن‌ها پیش از این (در دنیا) به آن کافر شدند، و از جای دور نادیده (و بدون آگاهی، تیری) می‌افکندند
  34,54,و میان آن‌ها و آنچه می‌خواستند جدایی افکنده شد، همان‌گونه که از پیش با امثال آن‌ها انجام شد، بی‌گمان آن‌ها سخت در شک (و تردید) بودند
  35,1,حمد (و ستایش) مخصوص الله است، آفرینندۀ آسمان‌ها و زمین، (کسی) که فرشتگان را رسولانی قرار داد؛ دارای بال‌های دوگانه و سه‌گانه و چهارگانه، هر چه بخواهد در آفرینش می‌افزاید، بی‌گمان الله بر هر چیزی تواناست
  35,2,(هر) رحمتی را که الله برای مردم بگشاید، کسی نمی‌تواند که بازش دارد، و آنچه را باز دارد کسی جز او نمی‌تواند آن را روان سازد، و او پیروزمند حکیم است
  35,3,ای مردم! نعمت الله را بر خود به یاد آورید، آیا آفریننده‌ای جز الله هست که شما را از آسمان و زمین روزی دهد؟! هیچ معبودی جز او نیست، پس چگونه (از حق) منحرف می‌شوید؟
  35,4,و اگر تو را تکذیب کنند (غمگین نباش) همانا پیامبران پیش از تو (نیز) تکذیب شدند، و (همۀ) کار‌ها به سوی الله باز گردانده می‌شود
  35,5,ای مردم! یقیناً وعدۀ الله حق است، پس زندگی دنیا شما را نفریبد، و (شیطان) فریبکار شما را نسبت به الله نفریبد
  35,6,مسلما شیطان دشمن شماست، پس او را دشمن گیرید، او فقط پیروانش را دعوت می‌کند تا (همه) از اهل آتش سوزان (جهنم) باشند
  35,7,کسانی‌که کافر شدند، برای آنان عذابی سخت است، و کسانی‌که ایمان آوردند و کار‌های شایسته انجام دادند، برایشان آمرزش و پاداش بزرگی است
  35,8,آیا کسی‌که کردار بدش برای او آراسته شده، پس آن را نیک (و زیبا) می‌بیند (همانند کسی است که چنین نیست؟) پس بی‌گمان الله هر کس را که بخواهد گمراه می‌سازد و هر کس را که بخواهد هدایت می‌کند، پس نباید که جانت به خاطر شدت تأسف (و حسرت) بر آنان از بین برود، بی‌شک الله به آنچه انجام می‌دهند؛ داناست
  35,9,و الله کسی است که باد‌ها را فرستاد، آنگاه (آن باد‌ها) ابر‌ها را بر می‌انگیزند، پس آن (ابر‌ها) را به سوی سرزمین مرده راندیم، آنگاه بوسیلۀ آن زمین را بعد از مردنش زنده کردیم، بر انگیختن (مردگان از گور‌ها نیز) چنین است
  35,10,کسی‌که خواهان عزت است، پس (بداند که) عزت همگی از آن الله است، سخن پاکیزه به سوی او بالا می‌رود، و (الله) عمل صالح را بالا می‌برد، و کسانی‌که (نقشه و) نیرنگ‌های بد می‌کشند، برای آن‌ها عذاب سختی است، و نیرنگ (و نقشه‌های بد) آن‌ها نابود می‌شود
  35,11,و الله شما را از خاک، سپس از نطفه آفرید، آنگاه شما را جفت‌های یکدیگر قرار داد، و هیچ ماده‌ای باردار نمی‌شود، و نمی‌زاید؛ مگربه علم او، و هیچ سالخورده‌ای عمر طولانی نمی‌کند، و (یا) از عمرش کاسته نمی‌شود؛ مگر آنکه در کتاب (لوح محفوظ ثبت) است، بی‌گمان این (کار‌ها) بر الله آسان است
  35,12,"و (آن) دو دریا یکسان نیستند: این یکی (آبش) شیرین گوارا است که نوشیدنش خوش‌گوار است، و آن یکی شور تلخ است، و از هر دو گوشتی تازه می‌خورید، و (از آن‌ها) چیز‌‌هایی زینتی بیرون می‌آورید که می‌پوشید، و کشتی‌ها را در آن (دریا) می‌بینی که (امواج را) می‌شکافد (و به سوی مقصد خویش پیش می‌رود) تا از فضل الله (روزی) بجویید، و شاید که سپاس گزارید"
  35,13,(او) شب را در روز داخل می‌کند و روز را در شب داخل می‌گرداند، و خورشید و ماه را مسخر کرده که هر یک تا زمانی معین در حرکت است، این است الله پروردگار شما، فرمانروایی از آنِ اوست، و کسانی را که به جای او می‌خوانید (هم‌وزن) پوست نازک هستۀ خرما مالک نیستند
  35,14,اگر آن‌ها را بخوانید (صدای) خواندن شما را نمی‌شنوند، و (به فرض) اگر بشنوند به شما پاسخ نمی‌دهند، و روز قیامت شرک شما را انکار می‌کنند، و هیچ‌کس مانند (الله) آگاه خبردارت نمی‌کند
  35,15,ای مردم! شما (همگی) به الله نیازمندید، و (تنها) الله است که بی‌نیاز ستوده است
  35,16,اگر بخواهد شما را (از بین) می‌برد، و آفرینش تازه‌ای می‌آورد
  35,17,و این (کار) بر الله دشوار نیست
  35,18,و هیچ‌کس بار (گناه) دیگری را به دوش نمی‌کشد، و اگر (شخص) گرانباری (دیگری را) برای حمل بار (گناه) خود بخواند، چیزی از آن (بار) برداشته نمی‌شود، هر چند خویشاوند (نزدیک او) باشد. تو (ای پیامبر!) تنها کسانی را هشدار می‌دهی‌که از پروردگارشان در پنهانی می‌ترسند، و نماز را بر پا می‌دارند، و هر کس پاک گردد (و تقوا پیشه کند) پس (بداند که) تنها به سود خویش پاک شده است، و باز گشت (همه) به سوی الله است
  35,19,و نابینا و بینا (هرگز) برابر نیستند
  35,20,و نه تاریکی‌ها و نور،
  35,21,و نه سایه و باد سوزان
  35,22,و (هرگز) زندگان و مردگان یکسان نیستند، بی‌گمان الله هر کس را بخواهد می‌شنواند، و تو (ای پیامبر!) نمی‌توانی (سخنت را) به در گور خفتگان بشنوانی
  35,23,تو جز هشداردهنده‌ای نیستی،
  35,24,یقیناً ما تو را به حق بشارت‌دهنده و هشدار‌‌دهنده فرستادیم، و هیچ امتی نیست؛ مگر آن‌که در (میان) آن هشداردهنده‌ای (آمده و) گذشته است
  35,25,و اگر تو را تکذیب کنند، (چیز تازه‌ای نیست) همانا کسانی‌که پیش از آنان بودند (نیز پیامبران خود را) تکذیب کردند، پیامبران‌شان با دلایل روشن و نوشته‌های (مشتمل بر پند و موعظه) و کتاب روشنگر به سراغ آن‌ها آمدند
  35,26,سپس کسانی‌که کفر ورزیدند؛ فرو گرفتم، پس (بنگر) مجازات من چگونه بود؟
  35,27,آیا ندیدی همانا الله از آسمان آبی را نازل کرد که بوسیلۀ آن میوه‌هایی با رنگ‌های گوناگون (از زمین) بیرون آوردیم، و از کوه‌ها (نیز) راه‌های (به رنگ) سفید و سرخ رنگارنگ و به غایت سیاه (پدید آوردیم)
  35,28,و همچنین از مردم و جنبندگان و چهارپایان با رنگ‌های مختلف (پدید آوردیم)، جز این نیست که از میان بندگان الله دانایان از او می‌ترسند، بی‌تردید الله پیروزمند آمرزنده است
  35,29,بی‌گمان کسانی‌که کلام الله را تلاوت می‌کنند و نماز را بر پا می‌دارند، و از آنچه روزی‌شان داده‌ایم؛ پنهان و آشکار انفاق می‌کنند، به تجارتی (پر سود) که هرگز زیان (و کساد) ندارد؛ امید دارند
  35,30,تا (الله) پاداش آن‌ها را به تمامی بدهد و از فضل خود بر آن‌ها بیفزاید، بی‌گمان او آمرزندۀ سپاسگزار است
  35,31,و (ای پیامبر!) آنچه از (این) کتاب به تو وحی کردیم؛ حق است که تصدیق کنندۀ آنچه پیش از آن است، یقیناً الله به (حال) بندگانش آگاه بیناست
  35,32,سپس (این) کتاب را به کسانی از بندگان‌مان که بر گزیده بودیم؛ به میراث دادیم، پس (برخی) از آنان بر خود ستم کردند و (برخی) از آنان میانه رَو بودند، و (برخی) از آنان به فرمان الله در نیکی‌ها پیشتازند، این همان فضل (و بخشایش) بزرگی است
  35,33,(پاداش آن‌ها) باغ‌های جاویدان (بهشتی) است که به آن وارد می‌شوند، در آنجا به دستبند‌های از طلا و مروارید آراسته می‌گردند، و لباس‌هایشان در آنجا حریر است
  35,34,"و گویند: «حمد (و ستایش) مخصوص الله است که اندوه را از ما دور کرد، یقیناً پروردگار ما آمرزندۀ سپاس‌گزار است"
  35,35,(همان) کسی‌که از فضل خویش ما را در این سرای اقامت (جاویدان) جای داد که در آنجا هیچ رنجی به ما نمی‌رسد، و در آنجا هیچ خستگی (و واماندگی) به ما نمی‌رسد
  35,36,و کسانی‌که کافر شدند؛ برای آن‌ها آتش جهنم است، نه فرمان (مرگ) بر آن صادر شود تا بمیرند (و راحت گردند) و نه چیزی از عذابش از آن‌ها کاسته شود، این گونه هر ناسپاسی را کیفر می‌دهیم
  35,37,"و آن‌ها در آن (آتش) فریاد می‌زنند: «پروردگارا! ما را بیرون آر تا عمل صالحی انجام دهیم؛ غیر از آنچه انجام می‌دادیم» (در پاسخ آنان می‌فرماییم:) آیا آن قدر شما را عمر ندادیم که پند گیرندگان در آن پند گیرند؟! و هشدار دهنده (نیز) به سراغ شما آمد؟! پس (طعم عذاب را) بچشید که برای ستمکاران هیچ یاوری نیست"
  35,38,بی‌گمان الله دانای نهان آسمان‌ها و زمین است و همانا او به آنچه در درون سینه‌هاست؛ دانا است
  35,39,او کسی است که شما را در زمین جانشینان (پیشینیان) قرار داد، پس هر کس که کافر شود، او به زیان خودش خواهد بود، و کافران را کفر‌شان جز خشم (و دشمنی) در نزد پروردگار‌‌شان (چیزی) نمی‌افزاید، و (نیز) کافران را کفر‌شان جز زیان (چیزی) نمی‌افزاید
  35,40,"(ای پیامبر!) بگو: «آیا معبودان‌تان که به جای الله می‌خوانید؛ دیده‌اید؟ به من نشان دهید چه چیزی از زمین را آفریده‌اند؟ یا اینکه در (آفرینش) آسمان‌ها شرکتی دارند؟ یا به آن‌ها کتابی داده‌ایم که آن‌ها دلیلی از آن (برای شرک خود) دارند؟» (نه هیچ‌یک از این‌ها نیست) بلکه ستمکاران جز فریب به یکدیگر وعده‌ای نمی‌دهند"
  35,41,بی‌تردید الله آسمان‌ها و زمین را نگه می‌دارد از آن‌که (از نظام خود) منحرف شوند، و اگر منحرف گردند، کسی جز او نمی‌تواند آن‌ها را نگه دارد، بی‌گمان او بردبار آمرزنده است
  35,42,و (کفار قریش) با محکم‌ترین سوگند‌های‌شان (و با نهایت تأکید) به الله سوگند یاد کردند که اگر هشداردهنده‌ای برای آنان بیاید، از هدایت یافته‌ترین امت‌ها خواهند بود، پس چون (پیامبر) هشداردهنده‌ای بر آنان آمد، جز (فرار و) نفرت (از حق چیزی) بر آنان نیفزود
  35,43,(این‌ها) بخاطر استکبار در زمین و نیرنگ‌های بد (شان) بود، و نیرنگ‌های بد جز دامن‌گیر صاحبانش نمی‌گردد، آنگاه آیا آنان (چیزی) جز سنت (و شیوۀ الله با) پیشینیان را انتظار دارند؟! پس هرگز برای سنت (و شیوۀ) الله تغیری پیدا نمی‌کنی و هرگز درطرز کار الله دگرگونی نمی‌یابی
  35,44,آیا (آن‌ها) در زمین نگشته‌اند؛ تا ببینند عاقبت کسانی را که پیش از آن‌ها بودند؛ چگونه بود؟! در حالی‌که آنان از اینان نیرومند‌تر بودند، و هیچ چیزی در آسمان‌ها و زمین نیست که الله را ناتوان سازد (و از حوزۀ قدرت او بیرون رود) بی‌گمان او دانای تواناست
  35,45,و اگر الله مردم را به (سبب) آنچه که انجام داده‌اند؛ مجازات کند، هیچ جنبنده‌ای را بر روی آن (= زمین) باقی نخواهد گذاشت، و لیکن آن‌ها را تا زمانی معین به تأخیر می‌اندازد، پس هنگامی‌که اجل آن‌ها فرا رسد، یقیناً الله به بندگانش بیناست
  36,1,یس (یا. سین)
  36,2,سوگند به قرآن حکیم
  36,3,که تو قطعاً از پیامبران (ما) هستی
  36,4,بر راه راست (قرار داری)
  36,5,(این قرآن) فرو فرستادۀ (الله) پیروزمند مهربان (است)
  36,6,تا گروهی را هشدار دهی که نیاکان‌شان هشدار نیافته‌اند، پس آنان غافلند
  36,7,به راستی فرمان (الهی) بر بیشتر آنان تحقق یافته است، پس آنان ایمان نمی‌آورند
  36,8,بی‌گمان ما در گردن‌های آنان غل‌هایی قرار دادیم پس آن (غل‌ها) تا چانه‌ها است، لذا سر‌‌های‌شان را بالا نگاه داشته است
  36,9,و پیش روی آنان سدی (= دیواری) و از پشت سر‌شان (نیز) سدی قراردادیم، آنگاه (دیدگان) آنان را پوشاندیم، لذا آنان نمی‌بینند
  36,10,و (ای پیامبر) بر آنان یکسان است، چه آن‌ها را هشدار دهی و یا هشدار‌شان ندهی، ایمان نمی‌آورند
  36,11,(ای پیامبر) تو تنها کسی را هشدار می‌دهی که از (این) پند پیروی کند، و در نهان از (الله) رحمان بترسد، پس او را به آمرزش و پاداشی گرامی بشارت ده
  36,12,یقیناً ماییم که مردگان را زنده می‌کنیم، و آنچه را (از اعمال نیک و بد) که از پیش فرستاده‌اند، و آثار (و گام‌های) شان را می‌نویسیم، و همه چیز را در کتاب روشنگر (لوح محفوظ) شمار کرده‌ایم
  36,13,و (ای پیامبر) برای آن‌ها مثال (و داستان) مردم آن قریه (انطاکیه) را بزن، چون رسولان (ما) بدان جا آمدند
  36,14,"آنگاه که دو نفر (از رسولان) را به سوی آن‌ها فرستادیم، پس آنان را تکذیب کردند، سپس با (فرستادن) سومی (آن دو را) تقویت کردیم، پس گفتند: «همانا ما به سوی شما فرستاده شده‌ایم»"
  36,15,"(آن‌ها در پاسخ) گفتند: شما جز بشری همانند ما نیستید، و (الله) رحمان چیزی را نازل نکرده است، شما فقط دروغ می‌گویید"
  36,16,"(پیامبران) گفتند: «پروردگار ما می‌داند که ما قطعاً به سوی شما فرستاده شده‌ایم"
  36,17,و بر (عهدۀ) ما جز رساندن (پیام) آشکار نیست»
  36,18,"(آن‌ها) گفتند: «بی‌گمان ما شما را به فال بد گرفته‌ایم، اگر دست بر ندارید البته سنگسارتان خواهیم کرد، و ازسوی ما عذاب (و شکنجۀ) درد‌ناکی به شما خواهد رسید»"
  36,19,"(پیامبران) گفتند: «شومی (و فال بد) تان با خود شماست، اگر به شما پند داده شود (چنین می‌گویید، و به فال بد می‌گیرید؟!) بلکه (حقیقت این است که) شما مردمی اسراف‌کار هستید»"
  36,20,"و مرد (مؤمنی) از دور‌ترین نقطۀ شهر شتابان آمد، (و خطاب به مردم) گفت: «ای قوم من! پیامبران (الله) را پیروی کنید"
  36,21,کسانی را پیروی کنید که از شما مزدی طلب نمی‌کنند، و خود‌شان هدایت یافته‌اند
  36,22,و چه شده است مرا که پرستش نکنم کسی را که مرا آفریده است، (همه) به سوی او باز گردانده می‌شوید؟
  36,23,آیا غیر از او معبود‌هایی را بر گزینم که اگر (الله) رحمان بخواهد به من زیانی برساند، شفاعت آن‌ها چیزی را از من دفع نمی‌کند (و کمترین فایده‌ای برایم ندارد) و مرا نجات نخواهند داد؟
  36,24,(اگر چنین کنم) یقیناً آنگاه من در گمراهی آشکاری خواهم بود
  36,25,من به پروردگارتان ایمان آورده‌ام، پس (سخنان) مرا بشنوید
  36,26,"(پس او را شهید کردند) به او گفته شد: «وارد بهشت شو» گفت: ای کاش قوم من می‌دانستند،"
  36,27,که پروردگارم مرا آمرزیده و از گرامی شدگان قرار داده است
  36,28,و بعد از او بر قومش هیچ لشکری از آسمان فرو نفرستادیم و ما فرو فرستنده نبودیم
  36,29,(بلکه کیفر آن‌ها) جز یک بانگ مرگبار نبود، پس ناگاه همه خاموش (=هلاک) شدند
  36,30,ای افسوس بر (این) بندگان، هیچ پیامبری به سوی آن‌ها نمی‌آمد مگر اینکه او را استهزاء می‌کردند
  36,31,آیا ندیدند که پیش از آن‌ها چه بسیار نسل‌ها را نابود کردیم، که آن‌ها هرگز به سوی ایشان باز نمی‌گردند؟
  36,32,و همۀ آن‌ها (برای حساب) نزد ما جمع و احضار می‌شوند
  36,33,و زمین مرده برایشان نشانه (و عبرتی) است که ما آن را زنده گردانیدیم، و دانۀ (غذایی) که از آن می‌خورند، بیرون آوردیم
  36,34,و در آن باغ‌هایی از نخل‌ها و انگور‌‌ها قرار دادیم، و در آن چشمه‌های جاری ساختیم
  36,35,"تا از میوۀ آن بخورند در حالی‌که دست آنان (در تولید آن‌ها) هیچ دخالتی نداشته است [ و یا: «از دست آورد خود (و آنچه که با دست خود ساخته اند) بخورند».]، آیا سپاس نمی‌گویند"
  36,36,منزه است کسی‌که همۀ جفت‌ها را آفرید، از آنچه زمین می‌رویاند، و از (جنس) خودشان، و از آنچه نمی‌دانند
  36,37,و شب (نیز) برای آن‌ها نشانه (و عبرتی) است ما روز را از آن بر می‌کشیم، پس آنگاه همه در تاریکی فرو می‌روند
  36,38,و خورشید (نیز که) پیوسته به سوی قرار‌‌گاهش در حرکت است، این تقدیر (الله) پیروزمند داناست
  36,39,و برای ماه منزلگاه‌های مقدر کرده‌ایم، تا چون شاخۀ (خشک و) کهنۀ خرما باز گردد
  36,40,نه خورشید را سزد که به ماه رسد، و نه شب بر روز پیشی می‌گیرد، و هر یک در مدار خود شناورند
  36,41,نشانه‌ای (دیگر) برای آنان این است که فرزندان‌شان را بر کشتی پر بار سوار کردیم
  36,42,و (مرکب‌های دیگری) همانند آن برای آن‌ها آفریدیم، که سوار می‌شوند
  36,43,و اگر بخواهیم آن‌ها را غرق می‌کنیم، پس آن‌ها را هیچ فریاد رسی نباشد، و نه آن‌ها رهایی یابند
  36,44,مگر اینکه رحمتی از سوی ما (شامل حال آن‌ها شود) و تا زمان معینی (از دنیا) بهره بگیرند
  36,45,"و هنگامی‌که به آن‌ها گفته شود: «از آنچه پیش روی شماست، و از آنچه پشت سر شماست، بترسید، شاید مورد رحمت قرار گیرید» (اعراض می‌کنند)"
  36,46,و هیچ آیه‌ای از آیات پروردگار‌‌‌شان برای آن‌ها نیاید مگر آنکه از آن روی بگردانند
  36,47,"و هنگامی‌که به آن‌ها گفته شود: از آنچه الله به شما روزی داده، انفاق کنید، کسانی‌که کافر شدند، به کسانی‌که ایمان آوردند می‌گویند: آیا ما کسی را طعام بدهیم که اگر الله می‌خواست، (خود) به او طعام می‌داد و شما جز در گمراهی آشکار نیستید"
  36,48,"و می‌گویند: «اگر راست می‌گویید، این وعده (عذاب) کی خواهد بود؟!»"
  36,49,آن‌ها جز انتظار یک بانگ مرگبار نمی‌کشند، که آن‌ها را فرو گیرد در حالی‌که سرگرم جدال (و دشمنی) هستند
  36,50,پس (در آن وقت) نمی‌توانند وصیتی کنند، و نه به سوی خانوادۀ خود باز گردند
  36,51,و (چون بار دیگر) در صور دمیده شود، پس ناگهان آن‌ها از قبرها (بیرون آیند) شتابان به سوی پروردگارشان می‌روند
  36,52,"گویند: «وای بر ما چه کسی ما را از خوابگاه‌مان بر انگیخت؟!» (به آن‌ها گفته شود:) این همان است که (الله) رحمان وعده داده بود، و پیامبران (الله) راست گفتند"
  36,53,(آن) جز یک بانگ مرگبار نخواهد بود، پس ناگهان همه نزد ما جمع و احضار می‌شوند
  36,54,پس امروز به هیچ کس ذره‌ای ستم نخواهند شد، و جز به آنچه عمل می‌کردید، جزا داده نمی‌شوید
  36,55,بی گمان اهل بهشت امروز در کاری (لذت بخش) مشغولند (و) شادمان هستند
  36,56,آن‌ها و همسران‌شان در سایه‌های (گستردۀ بهشتی) بر تخت‌ها تکیه زده‌اند
  36,57,برای آن‌ها در آن (= بهشت، انواع) میوه است، و هر چه که بخواهند برایشان (فراهم) است
  36,58,(به آن‌ها گفته می‌شود) سلام (بر شما باد) این سخنی است از جانب پروردگار مهربان
  36,59,ای گنهکاران امروز (از نیکان) جدا شوید
  36,60,ای فرزندان آدم! آیا با شما پیمان نبستم که شیطان را نپرستید، که او برای شما دشمن آشکار است؟
  36,61,و اینکه مرا بپرستید، این راه مستقیم است
  36,62,و به راستی او گروه زیادی از شما را گمراه ساخت آیا اندیشه نکردید؟
  36,63,این (همان) جهنمی است که به شما وعده داده می‌شد
  36,64,امروز به سزای کفری که ورزیده‌اید به آن در آیید
  36,65,امروز بر دهآن‌ها یشان مُهر می‌نهیم، و دست‌هایشان با ما سخن می‌گویند، و پا‌هایشان به آنچه می‌کردند گواهی می‌دهند
  36,66,و اگر بخواهیم چشمان‌شان را محو (و نابود) می‌کنیم، پس شتابان قصد راه می‌کنند، اما چگونه می‌توانند ببینند؟
  36,67,و اگر بخواهیم آن‌ها را در جایگاه‌شان مسخ (و میخ کوب) می‌کنیم، پس نتوانند که به پیش قدم بردارند، و نه به عقب باز گردند
  36,68,و هر کس را طول عمر دهیم، در آفرینش دگرگونش کنیم، (و به حالت ناتوانی کودکی بر می‌گردانیم) آیا اندیشه نمی‌کنند؟
  36,69,ما (هرگز) شعر به او (= رسول) نیاموخته‌ایم و شایستۀ او نیست، این (کتاب چیزی) جز اندرز، و قرآنی روشنگر نیست
  36,70,تا هر کس را که زنده (دل) باشد، بیم دهد و سخن حق بر کافران ثابت شود
  36,71,آیا ندیدند که ما برای آن‌ها از آنچه ساختۀ دست‌های ماست، چهار پایانی را آفریده‌ایم، پس آنان مالک آن هستند
  36,72,و آن‌ها را برایشان رام کردیم، پس بر بعضی سوار می‌شوند، و از (گوشت) بعضی می‌خورند
  36,73,و برای آن‌ها بهره‌های دیگر، و نوشیدنی‌ها در آن (حیوانات) است، آیا سپاس نمی‌گویند؟
  36,74,و آن‌ها غیر از الله معبودانی (برای خود) بر گزیدند، (به این امید) شاید که یاری شوند
  36,75,آن‌ها قادر به یاری ایشان نیستند، و آنان (= مشرکان) برای این‌ها (= معبودان) لشکری احضار شده (و آماده) هستند
  36,76,پس (ای پیامبر) سخن آنان تو را غمگین نسازد، بی‌گمان ما آنچه را که پنهان می‌دارند و آنچه را که آشکار می‌کنند، می‌دانیم
  36,77,آیا انسان ندیده است که ما او را از نطفه‌ای آفریده‌ایم، پس او ستیزه جویی آشکار شده است
  36,78,"و برای ما مَثَلی زد، و آفرینش خود را فراموش کرد، گفت: «چه کسی (این) استخوان‌ها را (دوباره) زنده می‌کند در حالی‌که پوسیده است؟!»"
  36,79,"بگو: «(همان) کسی آن را زنده می‌کند که نخستین بار آن را پدید آورد، و او به هر آفرینشی دانا‌ست،"
  36,80,(همان) کسی‌که از درخت سبز برای شما آتش پدید آورد، پس آنگاه شما از آن (آتش) می‌افروزید»
  36,81,آیا کسی‌که آسمان‌ها و زمین را آفریده است، نمی‌تواند همانند آن‌ها (= انسان‌ها) را بیافریند؟! آری (می‌تواند) و او آفرینندۀ دانا‌‌ست
  36,82,"جز این نیست که فرمان او، چون چیزی را اراده کند، (این است) که به آن می‌گوید: «موجود شو» پس (بی درنگ) موجود می‌شود"
  36,83,پس منزه است، کسی‌که پادشاهی همه چیز در دست اوست، و (همه) به سوی او باز گردانده می‌شوید