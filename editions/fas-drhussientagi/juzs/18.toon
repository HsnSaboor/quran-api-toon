quran[202]{c,v,t}:
  23,1,به راستی مؤمنان رستگار شدند
  23,2,همان کسانی‌که در نمازشان خاشع (و فروتن) هستند
  23,3,و کسانی‌که از لغو (و کارهای بیهوده) روی گردانند
  23,4,و کسانی‌که زکات را انجام می‌دهند
  23,5,و آن‌ها که شرمگاهشان را حفظ می‌کنند
  23,6,جز بر همسرانشان یا (بر) کنیزانشان، پس بی‌گمان اینان (در بهره‌گیری از آنان) ملامت نمی‌شوند
  23,7,پس کسی‌که فراتر از این بخواهد، آنانند که تجاوز گرند
  23,8,و کسانی‌که امانت‌هایشان و عهد خود را رعایت می‌کنند
  23,9,و کسانی‌که بر نمازهایشان مواظبت می‌نمایند
  23,10,(آری) اینانند که وارثند
  23,11,کسانی‌که (بهشت) فردوس را ارث می‌برند، و جاودانه در آن خواهند ماند
  23,12,و به راستی انسان را از چکیده‌ای از گِل آفریدیم
  23,13,سپس او را از نطفه‌ای در قرارگاهی استوار (= رحم) قرار دادیم
  23,14,سپس نطفه را (به صورت) علقه (= خون بسته) گرداندیم، آنگاه علقه را (به صورت) مضغه (= پاره گوشتی) درآوردیم، آنگاه مضغه را (به صورت) استخوان‌هایی گردانیدیم، پس بر استخوان‌ها گوشت پوشاندیم، سپس آن را آفرینشی دیگر بخشیدیم، پس (پر برکت و) بزرگوار است، الله که بهترین آفرینندگان است
  23,15,سپس مسلماً شما بعد از این خواهید مرد
  23,16,آنگاه یقیناً شما روز قیامت بر انگیخته می‌شوید
  23,17,و به‌راستی بر فرازتان هفت آسمان آفریدیم، و (ما هرگز) از آفرینش (خود) غافل نبوده‌ایم
  23,18,و از آسمان آبی به‌اندازه‌ای معین نازل کردیم، پس آن را در زمین جای دادیم، و بی‌گمان ما بر از بین بردن آن کاملاً قادر هستیم
  23,19,پس بوسیلۀ آن باغ‌هایی از درختان خرما و انگور برای شما پدید آوردیم، شما را در آن (باغ‌ها) میوه‌های بسیار است، و از آن می‌خورید
  23,20,و (نیز) درختی را که از طور سینا بیرون می‌آید (= درخت زیتون) که از آن روغن و (نان) خورش برای خورندگان فراهم می‌شود
  23,21,و بی‌گمان برای شما در چهارپایان عبرتی است، از آنچه درون‌شان است (= از شیر آن‌ها) شما را سیراب می‌کنیم؛ و برای شما در آن‌ها منافع فراوان است، و از (گوشت) آن‌ها می‌خورید
  23,22,و بر آن‌ها و بر کشتی‌ها سوار می‌شوید
  23,23,"و به راستی (ما) نوح را به سوی قومش فرستادیم، پس (او به آن‌ها) گفت: «ای قوم من! الله را بپرستید، که جز او معبودی برای شما نیست، آیا پرهیز نمی‌کنید؟"
  23,24,"پس اشراف قومش، (آن) کسانی‌که کافر بودند؛ گفتند: «این (مرد) جز بشری همچون شما نیست، که می‌خواهد بر شما برتری جوید، اگر الله می‌خواست، همانا فرشتگانی را نازل می‌کرد، ما (هرگز) چنین چیزی را در (میان) نیاکان خود نشنیده‌ایم"
  23,25,او مرد دیوانه‌ای بیش نیست، پس تا مدتی دربارۀ او صبر کنید،
  23,26,"(نوح) گفت: «پروردگارا! مرا در برابر تکذیب آن‌ها یاری کن»"
  23,27,"پس به او وحی کردیدم که: «به دیدگان ما و به وحی ما کشتی را بساز، پس هنگامی‌که فرمان ما فرا رسد، و آب از تنور بجوشد، آنگاه از هر نوع (حیوان) یک جفت (نر و ماده) در کشتی سوار کن و (نیز) خانواده خود را (سوار کن) جز کسی از آنان را که وعدۀ (هلاک) از پیش بر او مقرر شده است. و در(بارۀ) کسانی‌که ستم کردند، با من سخن مگو، که آنان غرق شدنی هستند»"
  23,28,"هنگامی‌که تو و همراهانت بر کشتی سوار شدید؛ بگو: «ستایش برای الله است که ما را از قوم ستمگر نجات داد»"
  23,29,"و (نیز) بگو: «پروردگارا! ما را در منزلگاهی پر برکت فرود آور، و تو بهترین فرود آورندگانی»"
  23,30,بی‌گمان در این (ماجرا) نشانه‌هایی است، و (ما) به‌راستی آزمایش می‌کنیم
  23,31,سپس قوم دیگری را بعد از آن‌ها به وجود آوردیم
  23,32,"پس از خودشان پیامبری در (میان) آنان فرستادیم که: «الله را بپرستید، که جز او معبودی برای شما نیست، آیا پرهیز نمی‌کنید؟!»"
  23,33,"و گروهی از اشراف قومش که کافر بودند، و دیدار آخرت را تکذیب می‌کردند، و در زندگی دنیا به آن‌ها نعمت و آسایش داده بودیم، گفتند: «این (مرد) بشری همچون شما است، از آنچه که (شما) می‌خورید، می‌خورد، و از آنچه که شما می‌نوشید، می‌نوشد"
  23,34,و اگر از بشری همچون خود اطاعت کردید، یقیناً شما زیان‌کار خواهید شد
  23,35,"آیا (او) به شما وعده می‌دهد: که همانا شما چون مردید و خاک و استخوان‌هایی (پوسیده) شدید، (بار دیگر از گور) بیرون آورده می‌شوید؟"
  23,36,هیهات، هیهات (= دور است، دور است) آنچه به شما وعده داده می‌شود
  23,37,جز زندگی دنیوی ما چیزی نیست، می‌میریم و زنده می‌شویم، و هرگز برانگیخته نخواهیم شد
  23,38,او جز مردی نیست که بر الله دروغ بسته است، و ما به او ایمان نمی‌آوریم»
  23,39,"(پیامبرشان) گفت: «پروردگارا! مرا در برابر تکذیب آن‌ها یاری کن»"
  23,40,"(الله) فرمود: «به‌زودی (از کار خود) پشیمان خواهند شد»"
  23,41,پس صیحه (= بانگ مرگبار) آن‌ها را به حق فرو گرفت، آنگاه آن‌ها را (همچون) خاشاکی (بر سیلاب) قرار دادیم، پس قوم ستمکار (از رحمت الله) دور (و نابود) باد
  23,42,سپس اقوام دیگری را بعد از آن‌ها پدید آوردیم
  23,43,هیچ امتی از اجل خود پیشی نمی‌گیرد، و نه تأخیر می‌کند
  23,44,سپس پیامبران خود را پی در پی فرستادیم، هر زمان پیامبری برای (هدایت) امتی می‌آمد، او را تکذیب می‌کردند، پس (ما نیز) آن‌ها (= امت‌های کافر) را یکی پس از دیگری هلاک کردیم، و آن‌ها را افسانه‌هایی (برای آیندگان) قرار دادیم. پس دور باد قومی که ایمان نمی‌آورند
  23,45,سپس موسی و برادرش هارون را با آیات خود، و دلایل آشکار فرستادیم،
  23,46,به سوی فرعون و اشراف (قوم) او، پس آن‌ها تکبر کردند، و مردمی (سرکش و) برتری جوی بودند
  23,47,"پس گفتند: «آیا (ما) به دو انسان مانند خود ایمان بیاوریم، در حالی‌که قوم آن‌ها بردگان (و زیر دستان) ما هستند؟!»"
  23,48,پس (آن‌ها) آن دو (پیامبر) را تکذیب کردند، سرانجام (همگی) از هلاک شدگان گشتند
  23,49,و به راستی به موسی کتاب (تورات) دادیم، باشد که آنان (= بنی اسرائیل) هدایت شوند
  23,50,و پسر مریم و مادرش را آیتی قرار دادیم، و آن‌ها را در مکانی بلند و هموار که دارای امنیت و آب جاری بود، جای دادیم
  23,51,ای پیامبران! از (غذاهای) پاکیزه بخورید، و کار شایسته انجام دهید، بی‌شک من به آنچه انجام می‌دهید؛ آگاهم
  23,52,و بی‌گمان این امت شما، امت واحدی است، و من پروردگار شما هستم، پس از من بترسید
  23,53,پس آن‌ها در میان خود در کار (دین) شان فرقه فرقه و پراکنده شدند، و هر گروه به آنچه نزد خود دارند؛ خوشحال‌اند
  23,54,پس (ای پیامبر!) آن‌ها را تا مدتی در جهل و غفلت‌شان بگذار
  23,55,آیا گمان می‌کنند که آن مال و فرزندان که با آن‌ها آنان را یاری می‌دهیم
  23,56,برای این است که شتابان خیرات (و نیکی‌ها) به آن‌ها برسانیم؟! (چنین نیست) بلکه آن‌ها (حقیقت را) در‌نمی‌یابند
  23,57,بی‌گمان کسانی‌که از خوف پروردگارشان بیمناک‌اند
  23,58,و کسانی‌که به آیات پروردگارشان ایمان می‌آورند
  23,59,و کسانی‌که به پروردگارشان شرک نمی‌آورند
  23,60,و کسانی‌که (در راه الله) آنچه را باید بدهند، می‌دهند، و (با این حال) دل‌هایشان بیمناک است، که بی‌گمان آنان به‌سوی پروردگار‌شان باز می‌گردند
  23,61,(آری) اینانند که در نیکی‌ها شتاب می‌کنند، و در انجام آن (از دیگران) پیشی می‌گیرند
  23,62,(ما) هیچ کس را جز به‌اندازۀ توانش تکلیف نمی‌کنیم، و نزد ما کتابی است که به حق سخن می‌گوید، و به آن‌ها هیچ ستمی نمی‌شود
  23,63,بلکه دل‌های آن‌ها از این (کتاب) در غفلت است، و آن‌ها جز این؛ اعمال (زشت) دیگری (نیز) دارند که پیوسته آن را انجام می‌دهند
  23,64,تا زمانی که متنعمان آن‌ها را به عذاب گرفتار کنیم، در این هنگام آن‌ها ناله و فریاد سر می‌دهند
  23,65,"(به آن‌ها گفته می‌شود:) امروز فریاد نکنید، یقیناً شما از سوی ما یاری نخواهید شد"
  23,66,به‌راستی آیات من پیوسته بر شما خوانده می‌شد، پس شما (از حق اعراض می‌کردید و) به عقب باز می‌گشتید
  23,67,در حالی‌که در برابر آن تکبر می‌کردید، (و در مجالس) شبانۀ (خود) به بدگویی می‌پرداختید (و افسانه سرایی می‌کردید)
  23,68,آیا (آن‌ها) در این گفتار نیندیشیدند، یا (اینکه) چیزی برای آنان آمده که برای نیاکان نخستین شان نیامده است؟
  23,69,یا (اینکه) پیامبر‌‌شان را نشناخته‌اند، پس او را انکار می‌کنند؟
  23,70,یا می‌گویند او جنون دارد؟ (چنین نیست) بلکه (او) حق را برای آن‌ها آورده است، و بیشترشان از حق کراهت دارند
  23,71,و اگر حق از هوس‌های آن‌ها پیروی کند، آسمان‌ها و زمین و هرکه در آن‌هاست، تباه شوند، بلکه (ما) برای آن‌ها پند و اندرز‌شان آورده‌ایم، پس آن‌ها از پندشان روی گردانند
  23,72,یا (اینکه) تو از آن‌ها مزدی طلب می‌کنی؟ پس پاداش پروردگارت بهتر است، و او بهترین روزی دهندگان است
  23,73,و یقیناً تو آن‌ها را به راه راست دعوت می‌کنی
  23,74,و بی‌گمان کسانی‌که به آخرت ایمان ندارند از (این) راه (راست) منحرف هستند
  23,75,و اگر به آن‌ها رحم کنیم و بلا و رنجی را که بدان گرفتارند، از آن‌ها بر‌طرف سازیم، در طغیان خود لجاجت (و پا‌‌‌فشاری) می‌کنند (و) سرگردان می‌مانند
  23,76,و به راستی (ما) آن‌ها را به عذاب (و بلا) گرفتار ساختیم، (تا بیدار شوند) پس برای پروردگارشان فروتنی ننمودند، و (به درگاهش تضرع و) زاری نکردند
  23,77,تا زمانی‌که دری از عذاب سخت به روی آن‌ها گشودیم، آنگاه آن‌ها در آن به‌کلی ناامید گردند
  23,78,و او کسی است که برای شما گوش و چشم و دل پدید آورد، چه اندک سپاس می‌گزارید
  23,79,و او کسی است که شما را در زمین (آفرید و) پراکنده نمود، و به‌سوی او گرد آورده می‌شوید
  23,80,و او کسی است که زنده می‌کند و می‌میراند، و رفت و آمد شب و روز از آن اوست، آیا نمی‌اندیشید؟
  23,81,(چنین نکردند) بلکه آن‌ها (نیز) مثل آنچه پیشینیان گفته بودند، گفتند
  23,82,"گفتند: «آیا هنگامی‌که مردیم و خاک و استخوان‌های (پوسیده) شدیم، آیا (دوباره) برانگیخته می‌شویم،"
  23,83,به‌راستی این وعده به ما و نیاکان ما از قبل داده شده، این (چیزی) جز افسانه‌های پیشینیان نیست»
  23,84,"(ای پیامبر!) بگو: «اگر می‌دانید، زمین و هرکه در آن است از آنِ کیست؟!»"
  23,85,"به‌زودی خواهند گفت: «(همه) از آن الله است» بگو: «آیا پند نمی‌گیرید؟!»"
  23,86,"بگو: «چه کسی پروردگار آسمان‌های هفتگانه، و پروردگار عرش عظیم است؟!»"
  23,87,"خواهند گفت: «(همه) از آنِ الله است» بگو: «آیا (از الله) نمی‌ترسید؟!»"
  23,88,"بگو: «اگر می‌دانید، چه کسی فرمانروایی همۀ موجودات در دست دارد، و او پناه می‌دهد، و کسی در برابر او پناه داده نمی‌شود؟"
  23,89,"خواهند گفت: «از آن الله است» بگو: «پس چگونه جادو می‌شوید؟!»"
  23,90,(چنین نیست) بلکه حق را برای آن‌ها آوردیم، و بی‌گمان آنان دروغگو هستند
  23,91,الله هرگز فرزندی بر نگزیده است، و هیچ معبود (دیگری) با او نیست، (اگر چنین بود) آنگاه هر معبودی آنچه را که آفریده بود؛ می‌برد، و مسلماً بعضی بر بعضی دیگر برتری می‌جستند، الله منزه (و پاک) است از آنچه آن‌ها توصیف می‌کنند
  23,92,دانای نهان و آشکار است، پس برتر است از آنچه شریک او می‌سازند
  23,93,"(ای پیامبر!) بگو: «پروردگارا! اگر آنچه را که به آن‌ها وعده داده می‌شود، به من نشان دهی"
  23,94,پروردگارا! پس مرا در (زمرۀ) قوم ستمگران قرار مده»
  23,95,و یقیناً ما تواناییم که آنچه را به آن‌ها وعده می‌دهیم؛ به تو نشان دهیم
  23,96,بدی را به روشی که آن بهتر است، دفع کن، ما به آنچه توصیف می‌کنند؛ داناتریم
  23,97,"و بگو: «پروردگارا! من از وسوسه‌های شیطان به تو پناه می‌برم،"
  23,98,و پروردگارا! از اینکه آنان نزد من حاضر شوند، به تو پناه می‌برم»
  23,99,"(کافران پیوسته به راه و روش خود ادامه می‌دهند) تا زمانی‌که مرگ یکی از آن‌ها فرا رسد، گوید: «پروردگارا! مرا (به دنیا) باز گردان،"
  23,100,باشد که در آنچه (در دنیا) ترک (و کوتاهی) کرده‌ام، کار شایسته‌ای انجام دهم». هرگز چنین نیست، بی‌گمان این سخنی است که او به زبان می‌گوید، (و به فرض محال اگر باز گردد، به کارهای گذشته‌اش ادامه می‌دهد) و پشت سر آن‌ها برزخی است تا روزی‌که برانگیخته شوند
  23,101,پس هنگامی‌که در صور دمیده شود، در آن روز هیچ گونه پیوندهای خویشاوندی در میان آن‌ها نخواهد بود، و از (حال) یکدیگر نپرسند
  23,102,و کسانی‌که (کفۀ) ترازوی (اعمال‌) شان سنگین شود، پس آنانند که رستگار هستند
  23,103,و کسانی‌که (کفۀ) ترازوی (اعمال) شان سبک باشد، پس آن‌ها کسانی هستند که (وجود خود را از دست داده و) به خود زیان رسانده‌اند و در جهنم جاودانه خواهند ماند
  23,104,(شعله‌های) آتش چهره‌هایشان را می‌سوزاند، و آن‌ها در آن ترشرو (و عبوس) هستند
  23,105,"(به آن‌ها گفته می‌شود:) مگر آیات من بر شما خوانده نمی‌شد، پس شما آن‌ها را تکذیب می‌کردید؟"
  23,106,"(در پاسخ) گویند: «پروردگارا! بدبختی ما بر ما چیره شد، و ما قومی گمراه بودیم"
  23,107,پروردگارا! ما را از این (جهنم) بیرون کن، پس اگر (به کفر و نافرمانی) باز گردیم، قطعاً ستمکار خواهیم بود»
  23,108,"(الله) می‌فرماید: «در آن گم شوید و با من سخن مگویید"
  23,109,"بی‌گمان گروهی از بندگانم می‌گفتند: پروردگارا! (ما) ایمان آوردیم، پس ما را ببخش و بر ما رحم کن، و تو بهترین رحم کنندگانی"
  23,110,پس شما آن‌ها را به مسخره گرفتید؛ تا یاد مرا فراموش‌تان کردند، و شما به آن‌ها می‌خندیدید
  23,111,همانا من امروز آن‌ها را بخاطر صبری‌که کرده‌اند پاداش دادم، قطعاً آن‌ها کامیاب هستند»
  23,112,"(الله) می‌فرماید: «(شما) چند سال در زمین درنگ کردید؟!»"
  23,113,"گویند: «یک روز، یا قسمتی از یک روز درنگ کرده‌ایم، پس از حسابگران بپرس»"
  23,114,"می‌فرماید: «(آری) اگر می‌دانستید، شما جز مقدار اندکی (در دنیا) درنگ نکردید،"
  23,115,آیا گمان کردید که ما شما را بیهوده آفریده‌ایم، و همانا شما به سوی ما باز گردانده نمی‌شوید؟
  23,116,پس بلند مرتبه (و برتر) است الله که فرمانروای حق است، هیچ معبودی (به حق) جز او نیست، پروردگار عرش کریم است
  23,117,و هر کس که با الله معبود دیگری را بخواند، مسلماً هیچ دلیلی بر (حقانیت) آن نخواهد داشت، جز این نیست که حسابش نزد پروردگارش خواهد بود، یقیناً کافران رستگار نمی‌شوند
  23,118,"و (ای پیامبر) بگو: «پروردگارا! ببخش و رحم کن! و تو بهترین رحم کنندگانی»"
  24,1,(این) سوره‌ای است که آن را نازل کرده‌ایم، و (احکام) آن واجب نموده‌ایم، و در آن آیات روشنی نازل کرده‌ایم، شاید شما پند گیرید
  24,2,هر یک از زن و مرد زنا کار را صد تازیانه بزنید، و اگر به الله و روز آخرت ایمان دارید نباید در (اجرای احکام) دین الله نسبت به آن دو (زن و مرد) رأفت (و رحمت کاذب) داشته باشید، و باید گروهی از مؤمنان بر مجازات‌شان (شاهد و) حاضر باشند
  24,3,مرد زنا کار جز با زن زنا کار یا مشرک ازدواج نمی‌کند، و زن زنا کار را جز مرد زنا کار یا مشرک به ازدواج خود در نمی‌آورد، و این (امر) بر مؤمنان حرام شده است
  24,4,و کسانی‌که زنان پاکدامن را (به زنا) متهم می‌کنند، سپس چهار شاهد نمی‌آورند، پس آن‌ها را هشتاد تازیانه بزنید، و هرگز شهادت‌شان را نپذیرید، و اینانند که فاسق‌اند
  24,5,مگر کسانی‌که بعد از آن توبه کردند، و (اعمال خود را) اصلاح (و جبران) نمودند، پس بی‌گمان الله آمرزندۀ مهربان است
  24,6,و کسانی‌که همسران خود را (به زنا) متهم می‌کنند، و جز خودشان گواهانی ندارند، پس هر یک از آن‌ها باید چهار مرتبه به نام الله سوگند یاد کنند که او از راستگویان است
  24,7,"و پنجمین بار (چنین گوید:) که لعنت الله بر او باد؛ اگر از دروغگویان باشد"
  24,8,و از آن (زن) کیفر (رجم) را دور می‌کند، (به) آن که چهار بار الله را شاهد بگیرد (و سوگند یاد کند) که او (= شوهرش) از دروغگویان است
  24,9,"و بار پنجم (بگوید:) که خشم الله بر او باد؛ اگر (شوهرش) از راستگویان باشد"
  24,10,و اگر فضل الله و رحمت او بر شما نمی‌بود، و اینکه الله توبه‌‌پذیر حکیم است (گرفتار عقوبت الهی می‌شدید)
  24,11,"مسلماً کسانی‌که تهمت بزرگ (دربارۀ ام المؤمنین عایشه -رضی الله عنها-) آوردند، گروهی از خود شما هستند، گمان نکنید که این (ماجرا) برای شما بد است، بلکه آن برای شما خیر است، برای هر کدام از آن‌ها سهمی از گناه است که مرتکب شده است، و کسی از آنان که (بخش) بزرگی (و مهمی)از آن (تهمت) را به عهده داشته است [ عبدالله بن أبی سردسته منافقان، عامل پخش شایعه بود.]، برای او عذاب عظیمی است"
  24,12,"چرا هنگامی‌که این (تهمت) را شنیدید، مردان و زنان مؤمن نسبت به خود گمان خیر نبردند، و نگفتند: این تهمتی (بزرگ و) آشکار است"
  24,13,چرا چهار شاهد بر آن نیاوردند؟! پس چون گواهان را نیاوردند، آنان در نزد الله دروغگویانند
  24,14,و اگر فضل الله و رحمت او در دنیا و آخرت نبود، قطعاً در آنچه به آن پرداختید، عذاب (سخت و) بزرگی به شما می‌رسید
  24,15,زمانی که آن (شایعه) را از زبان یکدیگر می‌گرفتید، و با‌ دهان خود سخنی می‌گفتید که به آن علم (و یقین) نداشتید، و آن را سهل (و کوچک) می‌پنداشتید در حالی‌که آن نزد الله بسیار بزرگ است
  24,16,"چرا هنگامی‌که آن را شنیدید؛ نگفتید: «ما حق نداریم که آن (سخن) را بر زبان آوریم، (الهی) تو منزهی! این بهتان بزرگی است؟!»"
  24,17,الله شما را اندرز می‌دهد که اگر مؤمن هستید؛ هرگز به چنین کاری باز نگردید
  24,18,و الله آیات (خود) را برای شما بیان می‌کند، و الله دانای حکیم است
  24,19,بی‌گمان کسانی‌که دوست دارند زشتی‌ها در (میان) مؤمنان شایع شود، عذاب درد ناکی برای آن‌ها در دنیا و آخرت است، و الله می‌داند و شما نمی‌دانید
  24,20,و اگر فضل الله و رحمت او بر شما نمی‌بود، و اینکه الله رؤوف مهربان است، (عقوبت سختی شما را در بر می‌گرفت)
  24,21,ای کسانی‌که ایمان آوردید! از گام‌های شیطان پیروی نکنید، و هرکس که از گام‌های شیطان پیروی کند، پس بی‌گمان (گمراهش می‌کند، و) او (= شیطان) به فحشا و منکر فرمان می‌دهد، و اگر فضل الله و رحمت او بر شما نمی‌بود، هرگز کسی از شما پاک نمی‌شد، و لیکن الله هر که را بخواهد پاک می‌کند، و الله شنوای داناست
  24,22,"کسانی از میان شما که توانگر و (دارای) وسعت (زندگی) هستند، نباید سوگند بخورند بر آن که به خویشاوندان و مستمندان و مهاجران در راه الله چیزی ندهند، آن‌ها باید عفو کنند و چشم بپوشند [ مسطح بن اثاثه پسر خالۀ ابوبکر صدیق، فردی مسکین بود که ابوبکر مخارج وی را تأمین می‌کرد، او نیز در این شایعه پراکنی شرکت داشت لذا ابوبکر صدیق رضی الله عنه سوگند یاد کرد که دیگر به او کمک نکند، آنگاه الله متعال این آیه را نازل فرمود (تفسیر ابن کثیر).]، آیا دوست نمی‌دارید که الله شما را ببخشد؟! و الله آمرزندۀ مهربان است"
  24,23,بی‌گمان کسانی‌که زنان پاکدامن بی‌خبر (از هرگونه بدکاری و) مؤمن را متهم (به زنا) می‌سازند، در دنیا و آخرت لعنت شده‌اند، و عذاب بزرگی برای آن‌هاست
  24,24,روزی که زبان‌هایشان و دست‌‌هایشان و پا‌هایشان به آنچه می‌کردند بر علیه آن‌ها گواهی می‌دهند
  24,25,آن روز، الله جزای واقعی آن‌ها را به تمام (و بی کم و کاست) می‌دهد، و خواهند دانست که الله همان حق آشکار است
  24,26,زنان ناپاک از آن مردان ناپاکند، و مردان ناپاک (نیز) برای زنان ناپاک هستند، و زنان پاک از آن مردان پاک، و مردان پاک از آن زنان پاک‌اند. اینان از آنچه (مردم دربارۀشان) می‌گویند، مبّرا (و پاک) هستند، برای آن‌ها آمرزش (الهی) و روزی ارزشمندی است
  24,27,ای کسانی‌که ایمان آورده‌اید! وارد خانه‌هایی جز خانه‌های خود نشوید، تا اجازه بگیرید، و بر اهل آن (خانه) سلام کنید، این برای شما بهتر است، باشد که پند گیرید
  24,28,"پس اگر کسی در آن (خانه) نیافتید، وارد نشوید، تا به شما اجازه داده شود، و اگر به شما گفته شد: «باز گردید» پس باز گردید، که آن برای شما پاکیزه‌تر است، و الله به آنچه انجام می‌دهید؛ داناست"
  24,29,و بر شما گناهی نیست که وارد خانه‌هایی غیر مسکونی بشوید، که در آن متاعی دارید، و الله می‌داند آنچه را آشکار می‌سازید و آنچه را پنهان می‌کنید
  24,30,(ای پیامبر!) به مردان مؤمن بگو چشم‌های خود را (از نگاه به نامحرم) فرو گیرند، و شرمگاه‌شان را حفظ کنند، این (کار) برای آن‌ها پاکیز‌ه‌تر است، بی‌گمان الله به آنچه انجام می‌دهند؛ آگاه است
  24,31,و به زنان مؤمن بگو چشم‌های خود را (از نگاه به نامحرم) فرو گیرند، و شرمگاهشان را حفظ کنند، و زینت خود را آشکار نکنند؛ جز آنچه از آن که (طبعاً خودش) نمایان است، و باید (اطراف) مقنعه‌های خود را بر گریبان‌هایشان بیفکنند (تا چهره و گردن و سینه با آن پوشیده گردد) و زینت خود را آشکار نسازند؛ مگر برای شوهرانشان، یا پدرانشان، یا پدر شوهرانشان، یا پسرانشان یا پسران شوهرانشان، یا برادرانشان یا پسران برادرانشان، یا پسران خواهرانشان یا زنان (هم کیش) شان یا بردگانشان یا مردان (سفیه) خدمتکاری که رغبتی (به زنان) ندارند، یا کودکانی‌که بر شرمگاه زنان آگاهی نیافته‌اند، و (زنان) نباید (هنگام راه رفتن) پا‌های خود را (به زمین) بکوبند، تا آنچه از زینت‌شان را که پنهان کرده‌اند، دانسته شود، و ای مؤمنان! همگی به سوی الله توبه کنید، تا رستگار شوید
  24,32,مردان و زنان مجرد (و بی‌همسر) خود را همسر دهید، و (نیز) غلامان و کنیزان‌تان که شایسته (و نیکوکار) هستند، (همسر دهید) اگر فقیر باشند، الله از فضل (و کرم) خویش آن‌ها را بی‌نیاز می‌کند، و الله گشایش دهندۀ آگاه است
  24,33,و کسانی‌که (اسباب و امکانات) ازدواج را نمی‌یابند، باید پاکدامنی پیشه کنند؛ تا الله آنان را از فضل خود بی‌نیاز گرداند، و کسانی از بردگانتان که خواستار مکاتبه (= باز خریدن خویش) هستند، پس با آن‌ها قرار داد ببندید، اگر خیر و صلاح در آن‌ها احساس می‌کنید، و چیزی از مال الله را که به شما داده است؛ به آن‌ها بدهید، و کنیزان خود را که می‌خواهند پاکدامنی کنند، برای بدست آوردن متاع ناچیز زندگانی دنیا به زنا وادار نکنید، و کسی‌که آن‌ها را (بر این کار) مجبور کند، پس بی‌گمان الله بعد از اجبار آن‌ها (برای آنان) آمرزندۀ مهربان است
  24,34,و به راستی ما بر شما آیاتی روشن را نازل کردیم، و مثلی از (حال) کسانی‌که پیش از شما گذشتند، و اندرزی برای پرهیزگاران
  24,35,الله نور آسمان‌ها و زمین است، مَثل نور او همانند چراغدانی است که در آن چراغی (افروخته) باشد، که آن چراغ در (میان) شیشه‌ای است، آن شیشه گویی ستاره‌ای درخشان است، این چراغ با (روغن) درخت پر برکت زیتون افروخته می‌شود، که نه شرقی است و نه غربی، نزدیک است که روغنش بدون تماس با آتش شعله‌‌ور شود، نوری است افزون بر نور، و الله هر کس را بخواهد به نور خود هدایت می‌کند، و الله برای مردم مثل‌ها می‌زند، و الله به هر چیزی آگاه است
  24,36,(این چراغ پر نور) در خانه‌های است که الله اجازه داده است که بلند شود، و نامش در آن‌ها برده شود، (و) صبح و شام در آن‌ها تسبیح او گویند
  24,37,مردانی‌که هیچ تجارت و خرید و فروشی آن‌ها را از یاد الله و برپاداشتن نماز و ادای زکات غافل نمی‌کند، (آن‌ها) از روزی می‌ترسند که در آن دل‌ها و چشم‌ها دگرگون (و بی‌تاب) می‌شود
  24,38,تا الله بهتر از آنچه انجام داده‌اند به آن‌ها پاداش دهد، و از فضل خود بر پاداش آن‌ها بیفزاید، و الله هر کس را که بخواهد بی‌حساب روزی می‌دهد
  24,39,و کسانی‌که کافر شدند؛ اعمال‌شان همچون سرابی است در بیابانی، که (انسان) تشنه (از دور) آن را آب می‌پندارد، تا آنکه به آن نزدیک شود، چیزی نمی‌یابد، و الله را نزد خود یابد که حساب او را کامل بدهد، و الله زود شمار است
  24,40,یا (اعمال‌شان) همچون تاریکی‌هایی در دریای پهناور که موج آن را پوشانده، و بر فراز آن موج دیگری است، (و) بر فراز آن ابری (تاریک) است، تاریکی‌هایی است یکی بر فراز دیگری، (آن گونه که) هرگاه دست خود را بیرون آورد، ممکن نیست آن را ببیند، و کسی را که الله نوری برای او قرار نداده است، پس (هیچ) نوری برای او نیست
  24,41,آیا ندیدی که همۀ آنان که در آسمان‌ها و زمین هستند، و پرندگان بال گسترده، الله را تسبیح می‌گویند. هریک از آن‌ها نماز و تسبیح خود را می‌داند، و الله به آنچه انجام می‌دهند؛ داناست
  24,42,و فرمانروایی آسمان‌ها و زمین از آنِ الله است، و بازگشت (همه) به سوی الله است
  24,43,آیا ندیدی که الله ابر‌هایی را به آرامی می‌راند، سپس بین آن‌ها پیوند می‌دهد، آنگاه آن را متراکم می‌کند، پس قطرۀ (باران) را می‌بینی که از میان آن بیرون می‌شود، و از آسمان، از کوه‌های که در آنجاست، دانه‌های تگرگ نازل می‌کند، پس آن را به هر کس که بخواهد می‌رساند، و آن را از هرکس که بخواهد باز می‌دارد، نزدیک است درخشندگی برق آن (نور) چشم‌ها را (از بین) ببرد
  24,44,الله شب و روز را دگرگون می‌سازد، بی‌گمان در این (امر) برای دیده‌وران عبرتی است
  24,45,و الله هر جنبنده‌ای را از آب آفرید، پس برخی از آن‌ها بر شکم خود راه می‌روند، و برخی بر دو پا راه می‌روند، و برخی از آن‌ها بر چهار (پا) راه می‌روند، الله هر چه را بخواهد می‌آفریند، بی‌گمان الله بر همه چیز تواناست
  24,46,به‌راستی (ما) آیات روشنگری نازل کردیم، و الله هر کس را که بخواهد به راه راست هدایت می‌کند
  24,47,"و (منافقان) می‌گویند: «به الله و به پیامبر (او) ایمان آوردیم، و اطاعت کردیم» سپس گروهی از آن‌ها بعد از این (ادعا) روی گردان می‌شوند، و اینان (در حقیقت) مؤمن نیستند"
  24,48,و هنگامی‌که به‌سوی الله و پیامبرش فرا‌خوانده شوند تا در میانشان داوری کند، ناگهان گروهی از آن‌ها اعراض می‌کنند
  24,49,و اگر حق با آن‌ها باشد، گردن نهاده (با سرعت) به‌سوی او می‌آیند
  24,50,آیا در دل‌هایشان بیماری است؟ یا تردید و شک دارند؟ یا می‌ترسند که الله و پیامبرش بر آن‌ها ستم کنند؟! (نه) بلکه آن‌ها خود‌شان ستمگرند
  24,51,"سخن مؤمنان هنگامی‌که به‌سوی الله و پیامبرش خوانده شوند تا میان آن‌ها داوری کند، فقط این است که می‌گویند: «شنیدیم و اطاعت کردیم» و اینان همان رستگارانند"
  24,52,و کسی‌که الله و پیامبرش را اطاعت کند، و از الله بترسد، و از (مخالفت فرمان) او بپرهیزد، پس اینانند که کامیاب (واقعی) هستند
  24,53,"(منافقان) با (نهایت تأکید و) سخت‌ترین سوگندهایشان، به الله سوگند یاد کردند که اگر به آن‌ها فرمان دهی (برای جهاد) بیرون می‌روند، (ای پیامبر! به آن‌ها) بگو: «سوگند یاد نکنید، طاعت پسندیده (و خالصانه مطلوب) است، بی‌گمان الله به آنچه انجام می‌دهید؛ آگاه است»"
  24,54,"(ای پیامبر!) بگو: «الله را اطاعت کنید، و از پیامبر اطاعت کنید، پس اگر سر پیچی کردید، بر او (= پیامبر) است آنچه که به آن مکلّف شده است، و بر شماست آنچه که بر آن تکلیف شده‌اید، و اگر از او اطاعت کنید؛ هدایت خواهید شد، و بر (عهدۀ) پیامبر (چیزی) جز ابلاغ آشکار نیست»"
  24,55,الله به کسانی از شما که ایمان آوردند و کارهای شایسته انجام دادند؛ وعده داده است که قطعاً آن‌ها را در زمین جانشین (و حکمران) خواهد کرد، همان گونه که کسانی را که پیش از آن‌ها بودند جانشین (و حکمران) ساخت، و دین‌شان را که برای آن‌ها پسندیده است برای آن‌ها استوار (و پا برجا) سازد، و یقیناً (خوف و) ترس‌شان را به آرامش و امنیت مبدل می‌کند، تنها مرا پرستش می‌کنند و چیزی را با من شریک نمی‌سازند، و کسانی‌که بعد از این کافر شوند، اینانند که فاسقند
  24,56,و نماز را بر پا دارید و زکات را بدهید، و پیامبر (الله) را اطاعت کنید، تا شما مورد رحمت قرار گیرید
  24,57,گمان مبر کسانی‌که کافر شدند؛ می‌توانند ما را در زمین به ستوه آورند (و از عقوبت ما فرار کنند) جایگاه‌شان آتش است، و چه بد بازگشتگاهی است
  24,58,"ای کسانی‌که ایمان آورده‌اید! باید بردگان شما، و کسانی از (کودکان) شما که به حد بلوغ نرسیده‌اند، در سه وقت از شما اجازه بگیرند: پیش از نماز صبح، و نیم‌روز هنگامی‌که لباس‌هایتان را بیرون می‌آورید، و بعد از نماز عشا، (این) سه (وقت) وقت عورت (و خلوت) برای شما است. بعد از این (سه وقت) بر شما و بر آن‌ها هیچ گناهی نیست (که بدون اجازه وارد شوند). آن‌ها بر اطراف (و پیرامون) شما در رفت آمدند (و) بعضی بر بعضی دیگر (وارد می‌شوید). این گونه الله آیات (خود) را برای شما بیان می‌کند، و الله دانای حکیم است"
  24,59,و هنگامی‌که کودکان شما به سن بلوغ رسیدند؛ باید اجازه بگیرند، همانند کسانی‌که پیش از آن‌ها بودند، اجازه می‌گرفتند، این گونه الله آیاتش را برای شما بیان می‌کند و الله دانای حکیم است
  24,60,و (پیر) زنان (یائسه) از کار افتاده‌ای که امید ازدواج ندارند، بر آن‌ها گناهی نیست که لباس‌های (رویین) خود را بگذارند، در صورتی‌که زینت (و زیبایی خود) را آشکار نکنند، و اگر خود‌‌ داری کنند (و خود را بپوشانند) برای آن‌ها بهتر است، و الله شنوای داناست
  24,61,بر نابینا گناهی نیست، و بر (افراد) لنگ گناهی نیست، و بر بیمار (نیز) گناهی نیست، و (همچنین) بر خود شما گناهی نیست؛ در آن که از خانه‌های خود، یا خانه‌های پدران‌تان یا خانه‌های مادران‌تان یا خانه‌های برادران‌تان یا خانه‌های خواهران‌تان یا خانه‌های عمو‌هایتان یا خانه‌های عمّه‌هایتان یا خانه‌های دائی‌هایتان یا خانه‌های خاله‌هایتان، یا خانه‌ای که کلیدش در اختیار شماست، یا (خانه‌های) دوستان‌تان (چیزی) بخورید، بر شما گناهی نیست که دسته‌جمعی یا جداگانه (غذا) بخورید، پس هنگامی‌که به خانه‌ها وارد شدید بر خویشتن سلام کنید که تحیتی مبارک (و) پاکیزه از سوی الله (مقرر) است، این گونه الله آیات (خود) را برای شما روشن می‌کند، باشد که شما خرد ورزید
  24,62,مؤمنان (واقعی) کسانی هستند که به الله و پیامبرش ایمان آورده‌اند و هنگامی‌که در کار همگانی با او باشند (به جایی) نمی‌روند تا از او اجازه بگیرند، بی‌گمان کسانی‌که از تو اجازه می‌گیرند، آن‌ها کسانی‌اند که به الله و پیامبرش ایمان آورده‌اند، پس اگر برای بعضی کارهای (مهم) خود از تو اجازه بخواهند، به هرکس از آن‌ها که می‌خواهی اجازه بده، و برایشان از الله آمرزش بخواه، یقیناً الله آمرزندۀ مهربان است
  24,63,صدا زدن پیامبر (الله) را در میان خود همچون صدا‌ زدن یکدیگر قرار ندهید، یقیناً الله کسانی از شما را که پشت‌سر دیگران پنهان می‌شوند، و یکی بعد از دیگری فرار می‌کنند می‌داند، پس کسانی‌که با فرمان او مخالفت می‌کنند؛ باید بترسند از این‌که فتنه‌ای ایشان را فرا گیرد، یا عذابی دردناک به آن‌ها برسد
  24,64,آگاه باشید، بی‌گمان آنچه در آسمان‌ها و زمین است از آن الله است، و یقیناً او آنچه را که شما بر آن هستید؛ می‌داند، و روزی‌که به سوی او باز گردانده می‌شوند، آن‌ها را به آنچه انجام داده‌اند؛ آگاه می‌سازد، و الله به هر چیزی داناست
  25,1,پر برکت و بزرگوار است کسی‌که فرقان (= قرآن) را بر بنده‌اش نازل کرد؛ تا بیم دهندۀ جهانیان باشد
  25,2,(همان) کسی‌که فرمانروایی آسمان‌ها و زمین از آنِ اوست، و فرزندی (برای خود) بر نگزیده است، و در فرمانروایی هیچ شریکی ندارد، و همه چیز را آفرید، پس اندازۀ هر چیز را چنان که می‌باید؛ معین کرده است
  25,3,و (مشرکان) به جای او معبودانی (برای خود) بر گزیدند که چیزی نمی‌آفرینند، و خود‌شان مخلوقند، و مالک زیان و سود خود نیستند، و (نیز) مالک مرگ و حیات و برانگیختن نیستند
  25,4,"و کسانی‌که کافر شدند؛ گفتند: «این (قرآن) جز دروغی نیست که (خود) بافته است، و گروهی دیگر او را بر این (کار) یاری داده‌اند» به راستی آن‌ها (با این سخنشان) ستم و دروغ بزرگی را مرتکب شده‌اند"
  25,5,"و گفتند: «(این همان) افسانه‌های پیشینیان است که آن را رو‌نویسی کرده و هر صبح و شام بر او املا می‌شود»"
  25,6,"(ای پیامبر!) بگو: «کسی آن را نازل کرده که راز (نهان) آسمان‌ها و زمین را می‌داند، بی‌گمان او آمرزندۀ مهربان است"
  25,7,"و گفتند: «این پیامبر را چه شده است که غذا می‌خورد و در بازار‌ها راه می‌رود؟! چرا فرشته‌ای بر او نازل نشده است؛ پس همراه او بیم‌دهنده باشد؟"
  25,8,"یا گنجی (از آسمان) بر او افکنده شود، و یا باغی داشته باشد که از (میوه‌های) آن بخورد؟!» و ستمگران گفتند: «شما فقط از مردی سحر شده پیروی می‌کنید»"
  25,9,بنگر چگونه برای تو مثل‌ها زدند، پس گمراه شدند (آن گونه) که نمی‌توانند راهی را بیابند
  25,10,"پر برکت و بزرگوار است کسی‌که اگر بخواهد برای تو بهتر از این قرار می‌دهد: باغ‌هایی که نهر‌‌ها از زیر (درختان) آن جاری است، و (نیز) برایت کاخ‌هایی (مجلل) قرار می‌دهد"
  25,11,(این‌ها همه بهانه است) بلکه (حقیقت این است که) آن‌ها قیامت را تکذیب کرده‌اند، و (ما) برای کسی‌که قیامت را تکذیب کند، آتش سوزان (جهنم) فراهم کرده‌ایم
  25,12,هنگامی‌که (جهنم) آن‌ها را از مکانی دور ببیند؛ از آن خشم و خروشی (وحشتناک) می‌شنوند
  25,13,و هنگامی‌که دست و پا بسته (با غل و زنجیر) در مکان تنگی از آن انداخته شوند، در آنجا مرگ (و نابودی خود) را به فریاد می‌خوانند
  25,14,"(به آن‌ها گفته شود:) امروز یک بار مرگ (و نابودی) را نخوانید، و (بلکه) بسیار (و بارها) فریادش کنید"
  25,15,"(ای پیامبر!) بگو: «آیا این بهتر است؛ یا بهشت جاویدانی که به پرهیزگاران وعده داده شده است؟! (بهشتی) که پاداش آن‌ها، و باز‌گشت‌گاه‌شان است»"
  25,16,هر چه بخواهند در آنجا برایشان (مهیا) است؛ جاودانه در آن خواهند ماند، این وعده‌ای است بر (عهدۀ) پروردگارت که (تحقق) آن را از او خواسته‌اند
  25,17,"و روزی‌که (همۀ) آن‌ها و آنچه را که به جای الله می‌پرستیدند؛ گرد آورد، پس (به معبودان باطل) می‌فرماید: «آیا شما این بندگان مرا گمراه کردید، یا خود‌شان راه را گم کردند؟!»"
  25,18,"گویند: «تو منزهی! برای ما شایسته نبود که به جای تو (اولیاء و) دوستانی برگزینیم، و لیکن آن‌ها و پدران‌شان را (از نعمت‌ها) بهره‌مند نمودی تا اینکه یاد (تو) را فراموش کردند، و گروهی هلاک (و تباه) شده شدند»"
  25,19,"(الله به آن‌ها می‌فرماید:) به راستی (این معبودان) شما را در آنچه می‌گویید؛ تکذیب کردند، پس (اکنون) نمی‌توانید (عذاب را) برطرف کنید، و نه (از کسی) یاری بجویید، و هرکس از شما که ستم (= شرک) کند، عذاب بزرگی به او می‌چشانیم"
  25,20,(ای پیامبر!) پیش از تو هیچ پیامبری را نفرستادیم، مگر اینکه آن‌ها هم غذا می‌خورند، و در بازارها راه می‌رفتند، و ما بعضی از شما را وسیلۀ آزمایش بعضی دیگر قرار داده‌ایم، آیا صبر می‌کنید؟! و پروردگار تو بیناست