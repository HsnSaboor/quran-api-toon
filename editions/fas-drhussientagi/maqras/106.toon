quran[50]{c,v,t}:
  15,50,و آنکه عذاب من همان عذاب دردناک است
  15,51,و آن‌ها را از مهمانان ابراهیم خبر ده
  15,52,"چون بر او وارد شدند، و سلام گفتند. (ابراهیم) گفت: «همانا ما از شما می‌ترسیم»"
  15,53,"گفتند: «نترس، بی‌گمان ما تو را به پسری دانا بشارت می‌دهیم»"
  15,54,"(ابراهیم) گفت: «آیا به من (این) بشارت می‌دهید با اینکه پیری به من رسیده است؟ پس به چه چیز بشارت می‌دهید؟!»"
  15,55,"گفتند: «تو را به حق بشارت دادیم، پس از نا امیدان نباش»"
  15,56,"(ابراهیم) گفت: «و چه کسی جز گمراهان از رحمت پروردگارش نا امید می‌شود؟!»"
  15,57,"(آنگاه) گفت: «پس ای فرستادگان (الله) مقصود شما چیست؟»"
  15,58,"گفتند: «همانا ما به سوی قوم گنهکار فرستاده شده‌ایم (تا آن‌ها را هلاک کنیم)"
  15,59,جز خاندان لوط که ما حتماً همۀ آن‌ها را نجات خواهیم داد
  15,60,مگر همسر او که مقدر داشتیم او قطعاً از بازماندگان (و هلاکت شوندگان) باشد»
  15,61,پس هنگامی‌که که فرستادگان (الله) نزد خاندان لوط آمدند
  15,62,"(لوط) گفت: «همانا شما گروهی ناشناس هستید!»"
  15,63,"(فرشتگان) گفتند: «بلکه، ما (همان) چیزی را برای تو آورده‌ایم که آن‌ها در آن تردید داشتند"
  15,64,و ما حق را برای تو آورده‌ایم، و ما قطعاً راستگویانیم
  15,65,پس پاسی از شب گذشته خانواده‌ات را با خود بردار، (و از این جا) ببر، و (خودت) به دنبال آن‌ها برو، و کسی از شما پشت سرش ننگرد، و به آن جایی که فرمان یافته‌اید بروید
  15,66,و ما این امر را به او (= لوط) وحی کردیم که همانا صبحگاهان همۀ آن‌ها ریشه کن خواهند شد
  15,67,و اهل شهر شادی‌کنان (به طرف خانۀ لوط) آمدند
  15,68,"(لوط) گفت: «به راستی این‌ها مهمانان من هستند، پس مرا رسوا (و شرمنده) نکنید،"
  15,69,و از الله بترسید و مرا خوار نسازید»
  15,70,"(آن‌ها) گفتند: «مگر ما تو را از (مهمانی و حمایت) مردمان نهی نکرده بودیم؟!»"
  15,71,"(لوط) گفت: «این‌ها دختران (قوم) من هستند، (با آن‌ها ازدواج کنید) اگر انجام دهندۀ کاری (مشروع) هستید»"
  15,72,سوگند به جان تو (ای پیامبر) که آن‌ها در مستی خود سر گردانند
  15,73,پس هنگام طلوع آفتاب صیحه (= بانگ مرگبار) آن‌ها را فرو گرفت
  15,74,آنگاه بالای آن (آبادی‌ها) را پایین قرار دادیم. (و زیر رو کردیم) و بر (سر) آنان سنگ‌های از سنگ گل بارانیدیم
  15,75,بی‌گمان در این (سر گذشت) نشانه‌های برای هوشیاران است
  15,76,و همانا آن (شهرهای ویرانه) بر سر راه (کاروانیان) پا برجاست
  15,77,بی‌گمان در این نشانه‌ای برای مؤمنان است
  15,78,و بی‌شک اصحاب أیکه (= قوم شعیب) ستمکار بودند
  15,79,پس (ما) از آن‌ها انتقام گرفتیم، و (شهرهای ویرانه شده) این دو (قوم) بر سر راه آشکار است
  15,80,و به راستی اصحاب حجر (= قوم ثمود) پیامبران را تکذیب کردند
  15,81,و (ما) آیات خود را به آن‌ها دادیم، پس آن‌ها از آنان روی گردان بودند
  15,82,آن‌ها با خاطری مطمئن و آسوده از کوه‌ها خانه‌هایی (برای خود) می‌تراشیدند
  15,83,پس صبحگاهان صیحه (= بانگ مرگبار) آن‌ها را فرو گرفت
  15,84,و آنچه را به دست آورده بودند (عذاب الهی را) از آن‌ها دفع نکرد
  15,85,و (ما) آسمان‌ها و زمین و آنچه را که میان آن دو است، جز به حق نیافریدیم، و قیامت قطعاً خواهد آمد، پس (ای پیامبر) به طرز شایسته‌ای گذشت کن (و از آن‌ها صرف نظر فرما)
  15,86,بی‌گمان پروردگار تو، همان آفرینندۀ داناست
  15,87,و به راستی (ما) به تو سبع المثانی (= سورۀ فاتحه) و قرآن عظیم دادیم
  15,88,(پس) هرگز چشم خود را به (سوی) آنچه (از نعمت‌ها و متاع دنیوی) که گروه‌هایی از آنان را از آن بهرمند ساخته‌ایم، نیندوز، و بر آن‌ها غمگین نباش، و بال (شفقت) خود را برای مؤمنان فرود آر (و نسبت به آن‌ها فروتن باش)
  15,89,"و بگو: «همانا من هشدار دهندۀ آشکارم»"
  15,90,(و آن‌ها را از عذابی بترسان) همان‌گونه که بر تقسیم‌کنندگان (آیات الهی) نازل کردیم
  15,91,(همان) کسانی‌که قرآن را تقسیم (و بخش، بخش) کردند
  15,92,پس سوگند به پروردگارت، قطعاً (در قیامت) از همه آن‌ها سوال خواهیم کرد
  15,93,از آنچه می‌کردند
  15,94,پس (ای پیامبر!) به آنچه مأمور شده‌ای آشکارا ابلاغ کن، و از مشرکان روی بگردان
  15,95,بی‌گمان ما (شر) مسخره کنندگان را از تو دفع خواهیم کرد
  15,96,کسانی‌که معبود دیگری با الله قرار می‌دهند، پس بزودی خواهند دانست
  15,97,و به راستی ما می‌دانیم که سینه تو (ای پیامبر) از آنچه آن‌ها می‌گویند تنگ می‌شود (و تو را آزرده و نا راحت می‌کند)
  15,98,پس به ستایش پروردگارت تسبیح گوی و از سجده‌کنندگان باش
  15,99,و پروردگارت را عبادت کن تا هنگامی‌که یقین (= مرگ) به سراغت آید