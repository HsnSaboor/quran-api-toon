quran[44]{c,v,t}:
  38,52,و نزد آنان (همسرانی) فرو هشته چشم همسال (که تنها به شوهران خود نظر دارند) است
  38,53,این است چیزهایی‌که برای روز حساب به شما وعده داده می‌شود
  38,54,بی‌گمان این روزی ماست که آن را هیچ پایانی نیست
  38,55,این (پاداش پرهیزگاران) است، و بی‌گمان برای سرکشان بدترین بازگشتگاه است
  38,56,جهنم، که در آن وارد می‌شوند، پس چه بد آرامگاهی است
  38,57,این (عذاب) آب جوشان و چرک و خونابه است، که باید آن را بچشند
  38,58,و (کیفر‌های) دیگر همانند آن به انواع گوناگون (دارند)
  38,59,"(به سرداران آن‌ها گفته می‌شود:) این گروهی است که با شما (به جهنم) وارد می‌شوند، (آن‌ها می‌گویند:) خوش آمد (و گشایش) بر آن‌ها مباد. بی‌گمان آن‌ها داخل شدگان به آتش هستند"
  38,60,"(پیروان) گویند: «بلکه، شما را خوش آمد مباد، که این (عذاب) را پیشاپیش شما برای ما فراهم کرده‌اید، پس چه بد قرارگاهی است»"
  38,61,"(سپس) گویند: پروردگارا! هر کس که این (عذاب) را پیشاپیش برای ما فراهم کرده است، پس عذابی دو چنان در آتش بر او بیفزار»"
  38,62,"و گویند: «ما را چه شده است، مردمانی را که ما آن‌ها را اشرار می‌شمردیم، (در جهنم) نمی‌بینیم؟"
  38,63,آیا آن‌ها را به مسخره گرفتیم یا (اینکه) از نظر‌ها دور مانده‌اند؟!»
  38,64,بی‌گمان این مخاصمه (و گفتگوی) دوزخیان حق (و واقعیت) است
  38,65,"(ای پیامبر) بگو: به درستی که من تنها یک هشدار دهنده‌ام، و هیچ معبودی (به حق) جز الله یکتای قهّار نیست"
  38,66,پروردگار آسمان‌ها و زمین و آنچه میان آن دو است، (آن) پیروزمند آمرزنده»
  38,67,"(ای پیامبر) بگو: «این خبری بزرگ است،"
  38,68,که شما از آن روی می‌گردانید
  38,69,"مـن از سـاکـنان عــالــم بالا (= فرشتگان) چون (دربارۀ آفرینش آدم) با یکدیگر جدال می‌کردند، خبری ندارم [ به سورۀ بقره آیه 30 رجوع کنید]"
  38,70,به من وحی نمی‌شود مگر این‌که من هشداردهنده‌ای آشکار هستم»
  38,71,"(و به یاد آور) هنگامی‌که پروردگارت به فرشتگان گفت: بی‌تردید من بشری را از گِل می‌آفرینم،"
  38,72,پس هنگامی‌که درستش کردم، و از روح خود در آن دمیدم، برای او سجده‌کنان بیفتید»
  38,73,پس فرشتگان همگی یکپارچه سجده کردند
  38,74,جز ابلیس که تکبّر ورزید و از کافران بود
  38,75,"(الله) فرمود: «ای ابلیس! چه چیز مانع تو شد، از آنکه برای آنچه من با دو دست خود آفریده ام، سجده کنی؟ آیا تکبر ورزیدی یا از بلند پایگان هستی؟!»"
  38,76,"گفت: «من از او بهترم، مرا از آتش آفریده‌ای، و او را از گِل آفریده‌ای»"
  38,77,"فرمود: «پس از اینجا بیرون شو، که تو رانده شده‌ای"
  38,78,و همانا لعنت من تا روز قیامت بر تو خواهد بود»
  38,79,"(ابلیس) گفت: «پروردگارا! پس مرا تا روزی‌که (دوباره) برانگیخته می‌شوند، مهلت ده»"
  38,80,"(الله) فرمود: «همانا تو از مهلت یافتگانی،"
  38,81,تا آن روز زمان معین»
  38,82,"(ابلیس) گفت: «پس به عزتت سوگند، که همۀ آن‌ها را گمراه خواهم کرد،"
  38,83,مگر بندگان مخلص تو را، از میان آن‌ها»
  38,84,"(الله) فرمود: «پس (این سخن) حق است، و حق را می‌گویم،"
  38,85,یقیناً جهنم را از تو و از آنان که از تو پیروی کنند، پر خواهم کرد»
  38,86,"(ای پیامبر) بگو: «من بر (رساندن) این (دین) هیچ مزدی از شما در خواست نمی‌کنم، و من از متکلفان نیستم»"
  38,87,این (قرآن) جز پند برای جهانیان نیست
  38,88,و قطعاً خبر (صدق) آن را بعد از مدتی خواهید دانست
  39,1,نازل شدن (این) کتاب از سوی الله پیروزمند حکیم است
  39,2,بی‌گمان ما (این) کتاب را به حق بر تو نازل کردیم، پس الله را پرستش کن و دین را برای او خالص گردان
  39,3,آگاه باشید که دین خالص از آن الله است، و کسانی‌که به جای او معبودان (و اولیای) گرفتند (وگفتند) این‌ها را نمی‌پرستیم جز برای این‌که ما را به الله نزدیک کنند بی‌گمان الله (روز قیامت) میان آن‌ها در آنچه اختلاف داشتند، داوری می‌کند، الله آن کسی را‌ که دروغگوی ناسپاس است، هدایت نمی‌کند
  39,4,اگر (به فرض مُحال) الله می‌خواست فرزندی بگیرد، مسلماً از میان آنچه را می‌آفریند، چیزی را که می‌خواست بر می‌گزید، او پاک و منزه است، او الله یکتای قهار است
  39,5,آسمان‌ها و زمین را به حق آفرید، شب را بر روز می‌پیچد، و روز را بر شب می‌پیچد، و خورشید و ماه را مسخر (و رام) گردانید، هر کدام تا زمانی معین در حرکتند، آگاه باشید، که او پیروزمند آمرزنده است
  39,6,(او) شما را از یک تن آفرید، سپس همسرش را از آن پدید آورد، و از چهار پایان برای شما هشت جفت فرو فرستاد، و شما را در شکم‌های مادران‌تان آفرینشی بعد از آفرینش دیگر، در تاریکی‌های سه‌گانه، می‌آفریند، این الله، پروردگار شماست که فرمانروایی از آنِ اوست، و جز او معبودی (به حق) نیست، پس چگونه (از حق) منحرف (و روی گردان) می‌شوید؟
  39,7,اگر ناسپاسی کنید، پس (بدانید که) الله از شما بی‌نیاز است، و هرگز ناسپاسی را برای بندگانش نمی‌پسندد. و اگر شکر او را به جای آورید آن را برای شما می‌پسندد. و هیچ کس بار گناه دیگررا بر دوش نمی‌کشد، پس بازگشت‌تان به سوی پروردگارتان است، آنگاه شما را به آنچه انجام می‌دادید، آگاه می‌کند، یقیناً او به راز دل‌ها آگاه است