quran[25]{c,v,t}:
  21,51,به راستی (ما) پیش از این به ابراهیم رشد (و راه یابی‌اش) را دادیم، و به (حال) او آگاه بودیم
  21,52,"چون به پدرش و قومش گفت: «این مجسمه‌ها چیست که شما به (پرستش) آن‌ها دل نهاده‌اید؟"
  21,53,"گفتند: «ما پدران خود را پرستش کنندگان آن‌ها یافته‌ایم»"
  21,54,"(ابراهیم) گفت: «به‌راستی شما و پدران‌تان، در گمراهی آشکار بوده‌اید»"
  21,55,"گفتند: «آیا برای ما (سخن) حق را آورده‌ای، یا تو از بازی کنندگانی (و شوخی می‌کنی)؟!»"
  21,56,"گفت: «بلکه پروردگار شما، پروردگار آسمان‌ها و زمین است، آن که آن‌ها را پدید آورد، و من بر این (سخن) از گواهانم"
  21,57,"و (آهسته گفت:) به الله سوگند، بعد از آن که پشت‌کنان روی بگردانید برای (نابودی) بت‌های شما تدبیری خواهم اندیشید"
  21,58,پس (در غیاب بت‌پرستان) همۀ آن‌ها - جز (بت) بزرگ‌شان - را قطعه قطعه کرد، باشد که به سوی او باز گردند
  21,59,"(و هنگامی‌که به بت خانه آمدند و دیدند) گفتند: «هر کسی‌که با معبودان ما چنین کرده است، مسلماً او از ستمکاران است»"
  21,60,"(عده‌ای) گفتند: «شنیدیم جوانی که او را ابراهیم می‌گویند، آن‌ها (= بت‌ها) را (به بدی) یاد می‌کرد»"
  21,61,"گفتند: «پس او را در برابر دیدگان مردم بیاورید، باشد که آن‌ها گواهی دهند»"
  21,62,"(هنگامی‌که ابراهیم را حاضر کردند) گفتند: «ای ابراهیم! آیا تو این (کار) را با معبودان ما کرده‌ای؟!»"
  21,63,"گفت: «بلکه این بزرگ‌شان این (کار) را کرده است، پس از آن‌ها بپرسید اگر سخن می‌گویند!»"
  21,64,"آنگاه (آن‌ها) به خود باز گشتند، پس گفتند: «بی‌گمان شما خود ستمکار هستید»"
  21,65,"سپس (با شرمندگی) سر به زیر انداختند (و گفتند:) «مسلماً تو می‌دانی که این‌ها سخن نمی‌گویند»"
  21,66,"(ابراهیم) گفت: «آیا به جای الله چیزی را می‌پرستید که هیچ نفعی برای شما ندارد، و نه زیانی به شما می‌رساند؟"
  21,67,اف بر شما، و بر آنچه به جای الله می‌پرستید، آیا نمی‌اندیشید؟!»
  21,68,"گفتند: «او را بسوزانید، و معبودان خود را یاری کنید، اگر کنندۀ (کاری) هستید»"
  21,69,"(سرانجام آن‌ها او را به آتش انداختند، ولی ما) گفتیم: «ای آتش! بر ابراهیم سرد و سلامت باش»"
  21,70,و آن‌ها خواستند برای (نابودی) او نیرنگ (خطرناکی) ورزند، پس آن‌ها را زیانکارترین (مردم) قرار دادیم
  21,71,و او و لوط را به سرزمینی که در آن برای جهانیان برکت داده‌ایم، نجات دادیم
  21,72,و اسحاق، و افزون (بر او نوه‌اش) یعقوب را به او بخشیدیم، و همۀ آنان را شایسته قرار دادیم
  21,73,و (نیز) آن‌ها را پیشوایانی قرار دادیم که به‌فرمان ما (مردم را) هدایت می‌کردند، و انجام کارهای نیک و بر پاداشتن نماز و ادای زکات را به آن‌ها وحی کردیم، و آن‌ها (همه) عبادت‌گزار ما بودند
  21,74,و لوط را حکمت (= نبوت) و دانش دادیم، و او را از شهری که (مردمانش) اعمال زشت (و پلید) انجام می‌دادند، نجات دادیم، بی‌شک آن‌ها مردم بدِ فاسقی بودند
  21,75,و او را در رحمت خود داخل کردیم، بی‌گمان او از صالحان بود