quran[11]{c,v,t}:
  12,58,و (چون سرزمین کنعان را خشک سالی فرا گرفت) برادران یوسف (برای تهیۀ گندم به مصر) آمدند، پس بر او وارد شدند، آنگاه او آنان را شناخت، در حالی‌که آن‌ها او را نشناختند
  12,59,"پس چون بار‌هایشان را آماده کرد، (به آنان) گفت: «آن برادری که از پدرتان دارید، (نوبت آینده) نزد من بیاورید، آیا نمی‌بینید که من پیمانه را تمام می‌دهم، و من بهترین میزبان هستم؟"
  12,60,پس اگر او را نزد من نیاوردید، نه پیمانۀ نزد من خواهید داشت، و نه به من نزدیک شوید»
  12,61,"گفتند: «ما در (بار‌ۀ) او با پدرش با اصرار گفتگو خواهیم کرد، و مسلماً این کار را می‌کنیم»"
  12,62,"و (یوسف) به غلامانش گفت: «سرمایه‌شان را در بار‌هایشان بگذارید، شاید هنگامی‌که به سوی خانوادۀ خود، باز گشتند، آن را بشناسند، شاید باز آیند»"
  12,63,"پس چون به سوی پدر‌شان بازگشتند: « گفتند: ای پدرما! پیمانه (غله) از ما باز داشته شده است، پس برادرمان (بنیامین) را با ما بفرست تا سهمی (از غله) بگیریم، و بی‌گمان ما نگهبان او خواهیم بود»"
  12,64,"(یعقوب) گفت: «آیا شما را بر او امین دانم، همان‌گونه که پیش از این نسبت به برادرش (یوسف) امین داشتم، پس الله بهترین نگهبان است، و او مهربان‌ترین مهربانان است»"
  12,65,"و چون بار خود را گشودند، سرمایه‌شان را یافتند که به آن‌ها بازگردانده شده است. گفتند: «ای پدر ما! (ما دیگر) چه می‌خواهیم؟ این سرمایه ماست که به ما باز گردانده شده است، (پس او را با ما بفرست) و برای خانوادۀ خود آذوقه می‌آوریم، و برادرمان را حفظ می‌کنیم، و یک بار شتر افزون خواهیم آورد؛ این پیمانه (برای عزیز مصر، کار) آسانی است"
  12,66,"(یعقوب) گفت: «هرگز او را با شما نمی‌فرستم؛ تا آنکه به نام الله به من پیمان دهید که حتماً او را به نزد من باز خواهید آورد، مگر اینکه قدرت از شما گرفته شود (و خود‌‌‌تان گرفتار آیید) پس چون (تعهد و) پیمان استوار به او دادند، (یعقوب) گفت: «الله بر آنچه می‌گوییم نگهبان است»"
  12,67,"و (همچنین به آن‌ها) گفت: «ای پسران من! از یک در وارد نشوید، بلکه از درهای متفرق داخل شوید، و (من) نمی‌توانم چیزی از (قضای) الله (که مقرر کرده است) از شما دفع کنم، حکم تنها از آن الله است، بر او توکل کرده‌ام، و (همۀ) متوکلان بر او توکل کنند"
  12,68,و چون به همان گونه که پدرشان به آن‌ها دستور داده بود، داخل شدند، ـ (این کار) نمی‌توانست چیزی از (قضای) الله را از آنان دفع کند ــ جز حاجتی (و خواهشی) که در دل یعقوب بود که آن را برآورده کرد، و بی‌گمان او علمی داشت که ما به آموخته بودیم، و لیکن بیشتر مردم نمی‌دانند