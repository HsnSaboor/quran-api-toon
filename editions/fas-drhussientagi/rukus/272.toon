quran[22]{c,v,t}:
  20,55,(ما) شما را از آن (= زمین) آفریدیم، و در آن باز می‌گردانیم، و بار دیگر شما را از آن بیرون می‌آوریم
  20,56,و به راستی (ما) همۀ آیات خود را به او نشان دادیم، پس (او همه را) تکذیب کرد و سر باز زد
  20,57,"گفت: «ای موسی! آیا به نزد ما آمده‌ای که با سحر خود، ما را از سرزمینمان بیرون کنی؟"
  20,58,پس یقیناً ما هم سحری مانند آن برای تو می‌آوریم، پس (هم اکنون) در مکانی هموار (و مقبول همه) موعدی میان ما و خودت قرار بده که نه ما و نه تو از آن تخلف نکنیم،
  20,59,"(موسی) گفت: «موعد شما روز (عید) زینت است و آن که (همۀ) مردم چاشتگاه گرد آورده شوند»"
  20,60,آنگاه فرعون باز گشت، پس (همۀ) مکر و حیله خود را جمع کرد، سپس آمد
  20,61,"موسی به آن‌ها گفت: «وای بر شما! بر الله دروغ نبندید، که شما را با عذابی نابود می‌سازد، و یقیناً کسی‌که (بر الله) افترا بندد، ناکام (و ناامید) می‌شود»"
  20,62,پس آن‌ها در کار‌شان میان خود اختلاف کردند، و راز‌شان را پنهان داشتند
  20,63,"گفتند: «مسلماً این دو (نفر) جادوگرند، می‌خواهند شما را با جادو‌شان از سرزمینتان بیرون کنند، و آیین (و راه و رسم) برتر شما را از بین ببرند"
  20,64,پس (همۀ) حیله (و تدبیر) خود را گرد آورید (و به کار بندید) سپس در یک صف (برای مبارزه) بیایید، و به راستی امروز کسی رستگار خواهد شد که چیره (و غالب) گردد
  20,65,"(ساحران) گفتند: «ای موسی! یا این است که (اول) تو (عصا را) بیفکنی یا آنکه ما کسانی باشیم که اول بیفکنیم؟!»"
  20,66,"(موسی) گفت: «بلکه، (شما) بیفکنید» پس ناگهان ریسمان‌هایشان و عصا‌هایشان از (اثر) سحر‌شان چنان به نظرش رسید که حرکت می‌کند (و می‌دوند)"
  20,67,پس موسی در دل خود ترسی احساس کرد که (مبادا در ایمان مردم خللی ایجاد شود)
  20,68,"گفتیم: «نترس! مسلماً تو (غالب و) برتری،"
  20,69,و آنچه را که در دست راست خود داری بیفکن، تا (تمام) آنچه را که ساخته‌اند، ببلعد، بی‌شک آنچه ساخته‌اند، تنها مکر ساحر است، و ساحر هر جا رود رستگار (و موفق) نخواهد شد»
  20,70,"(پس موسی عصای خود را افکند، ناگهان به مار بزرگی تبدیل شد و همۀ آن‌ها را که ساخته بودند بلعید) آنگاه ساحران (همگی) به سجده افتادند، گفتند: «(ما) به پروردگار هارون و موسی ایمان آوردیم»"
  20,71,"(فرعون) گفت: «آیا پیش از آن که به شما اجازه دهم به او ایمان آوردید؟! بی‌تردید او بزرگ شماست که به شما سحر آموخته است، پس یقیناً دستانتان و پاهایتان را بر خلاف یکدیگر قطع می‌کنم، و شما را بر تنه‌های نخل به دار می‌آویزم، و بی‌شک خواهید دانست که عذاب (و شکنجه) کدام‌یک از ما سخت‌تر است و پایدار‌تر است!»"
  20,72,"گفتند: «سوگند به آن که ما را آفریده است، هرگز تو را بر این دلایل روشنی که برای ما آمده، ترجیح نمی‌دهیم، پس به هر حکمی که می‌خواهی حکم کن، تو تنها می‌توانی در این زندگی دنیا حکم کنی"
  20,73,همانا ما به پروردگارمان ایمان آورده‌ایم تا گناهانمان و آنچه را از سحر که ما را به آن وادار کردی، برای‌مان ببخشاید، و الله بهتر و پایدارتر است»
  20,74,بی‌گمان کسی‌که گناه‌کار به نزد پروردگارش حاضر شود، پس آتش جهنم برای اوست، در آن جا نه می‌میرد، و نه زنده می‌ماند
  20,75,و کسی‌که مؤمن نزد او آید، در حالی‌که کارهای شایسته انجام داده باشد، پس اینان برایشان درجات بلند است
  20,76,باغ‌های جاویدان (بهشتی) که نهر‌ها زیر (درختان) آن جاری است، همیشه در آن خواهند بود، و این است پاداش کسی‌که خود را (از شرک و گناهان) پاک نموده است