quran[11]{c,v,t}:
  101,1,آن واقعه كوبنده
  101,2,"چه كوبنده‌اى! [كه قابل وصف نيست‌]"
  101,3,و تو چه مى‌دانى آن كوبنده چيست
  101,4,روزى كه مردم مانند پروانگان پراكنده باشند
  101,5,و كوه‌ها چون پشم رنگين حلاجى شده شوند
  101,6,پس اما هر كه وزنه اعمالش سنگين باشد
  101,7,پس وى در يك زندگى رضايت بخشى است
  101,8,و اما آنكه وزنه اعمالش سبك شود
  101,9,پس جايگاهش هاويه است
  101,10,و تو چه مى‌دانى آن چيست
  101,11,آتشى سوزنده است