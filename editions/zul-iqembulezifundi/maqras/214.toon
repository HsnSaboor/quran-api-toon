quran[74]{c,v,t}:
  56,1,Khumbula uma isehlakalo sehlakala
  56,2,Akusiwona amanga ukwehlakala kwaso
  56,3,Sehlisa (abanye) siphakamisa (abanye)
  56,4,Khumbula lapho umhlaba unyakaziswa ngokuzamazama
  56,5,Nezintaba zibhidlizwa ziba wuthuli
  56,6,Bese zibawuthuli olusaphazekile
  56,7,Futhi naniyizigaba ezintathu
  56,8,"Manjalo\tabangane\tbangakwesokudla,\tyini\tabangane bangakwesokudla"
  56,9,"Kanye\tnabangane\tbangakwesobunxele,\tyini\tabangane bangakwesobunxele"
  56,10,"Nabedlulelayo\t(ekwenzeni\tizenzo\tezinhle\tkulomhlaba) bangabedlulelayo (empilweni ezayo)"
  56,11,Labo bangabasondele (kuMvelinqangi)
  56,12,Bayongena ezivandeni zentokozo
  56,13,Isixuku sabantu basendulo
  56,14,Kanye nabambalwa kwabangamumva
  56,15,Emibhedeni ephothwe ngegolide
  56,16,Becambalele phezulu kwayo bebhekene
  56,17,Bayobazungeleza abafana bangunaphakade
  56,18,"Nezinkomishi,\tnabojeke\tkanye\tnezingilazi\tzewayini eligobhozayo"
  56,19,Alibaphathisi ngekhanda futhi alibashintshi umqondo
  56,20,Kanye nezithelo abakhetha kuzona
  56,21,Kanye nenyama yezinkukhu abayithandayo
  56,22,Kanye nabesifazane abamhlophe abanamehlo amakhulu amahle
  56,23,Abafana njengobuhlalu obugciniwe
  56,24,Umvuzo ngenxa yalokho ababekwenza
  56,25,Abayizwa lapho phakathi inkulumo eyize noma ukwenza isono
  56,26,"Ngaphandle kwesisho, “ukuthula! Ukuthula!”"
  56,27,"Futhi\tabangane\tbangakwesokudla\t–\tyini\tabangane bangakwesokudla"
  56,28,Bayoba sezihlahleni zomlothi ezingenawo ameva
  56,29,Nezihlahlai ezinezixheke (zezithelo)
  56,30,Kanye nomthunzi owandisiwe (obanzi)
  56,31,Kanye namanzi agobhozayo
  56,32,Kanye nezithelo eziningi
  56,33,Akunqamuki(ukubakhonakwazoizithelo) futhiazenqatshelwe (zitholakala kalula)
  56,34,Nemibhede ephakanyisiwe
  56,35,Ngempela thina (sabadala abesifazane basezulwini) ngendalo
  56,36,Futhi sabenza baba ngabesifazane abamsulwa abangakaze bathintwe
  56,37,Banothando bayalingana ngeminyaka
  56,38,Okwalabo abangakwesokudla
  56,39,Iqembu labantu basendulo
  56,40,Kanye neqembu langamumva
  56,41,"Futhi labo abangasesandleni sobunxele, yini abangane abangakwesobunxele"
  56,42,Bayongena emlilweni oshisayo nasemanzini abilayo
  56,43,Kanye nethunzi lentuthu emnyama
  56,44,Elingapholile futhi elingajabulisi
  56,45,Ngempela bona ngaphambilini kwalokho babephila impilo entofontofo
  56,46,Futhi babephikelela ezonweni ezinkulu
  56,47,"Futhi babethi, “ngakube uma sesifile sabawuthuli namathambo ngempela siyobuye sivuswe kwabafileyo?”"
  56,48,Kanye nabokhokho bethu
  56,49,"Ithi, “ngempela (bayovuswa kwabafileyo) abasemandulo kanye nabangamumva”"
  56,50,Ngempela bayoqoqelwa ndawonye (beqoqelwa) isikhathi sosuku olwaziwayo
  56,51,"Manjalo, ngempela Oh Nina abaphambukayo abaphikayo"
  56,52,Ngempela nizodla esihlahleni sezaqum
  56,53,"Manjalo, nigcwalise izisu (zenu) ngaso"
  56,54,Bese niphuza phezulu kwaso amanzi abilayo
  56,55,Niphuze njengokuphuza kwekameli elomile
  56,56,Lokhu ukujatshuliswa kwabo ngosuku lokwahlulelwa
  56,57,"Thina sanidala, ngakho-ke kungani ningakholwa"
  56,58,Ngakube nikubonile yini lokho enikukhiphayo (ubudoda)
  56,59,Ngakube yinina yini enikudalile noma yithina umdali
  56,60,Thina sakwenza ukufa phakathi kwenu futhi thina asedlulwa
  56,61,Ukuthi sikuguqule ukufana kwenu (silethe enye indalo esikhundleni senu) futhi sinidale nibe yilokho eningakwazi
  56,62,Futhi ngempela senikwazile ukudalwa kokuqala manjalo kungani ningakhumbuli
  56,63,Ngakube nikubonile yini lokho enikutshalayo
  56,64,Ngakube yinina enikwenza ukuthi kumile (kukhule) noma yithina ummilisi
  56,65,"Ukube besithanda, besizokwenza kube wuthuli bese nina niyamangala (niyazisola)"
  56,66,Ngempela thina sisesikweletini
  56,67,Kepha thina siphuciwe
  56,68,Ngakube niwabonile yini amanzi eniwaphuzayo
  56,69,Ngakube yinina yini eniwahlisele phansi ephuma emafini noma yithina umehliseli phansi
  56,70,Ukube besithanda besizowenza abeduma (angaphuzeki) manjalo kungani ningabongi
  56,71,Ngakube niwubonile yini umlilo eniwokhelayo
  56,72,Ngakube yinina yini enenza ukuthi kukhule izihlahla zawo (umhlaba) noma yithina umkhulisi
  56,73,Thina sawenza waba yisikhumbuzo kanye nosizo ezihlalini zasogwadule
  56,74,Ngakho-ke dumisa igama leNkosi yakho enkulu kakhulu