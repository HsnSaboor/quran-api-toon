quran[82]{c,v,t}:
  100,9,Ngakube akazi yini ukuthi ngenkathi kusakazwa lokho okusemangcwabeni
  100,10,Futhi kwenziwa kwaziwa lokho okusezifubeni
  100,11,Ngempela iNkosi yabo ngalolosuku (lokwahlulela) iyazi kabanzi ngabo
  101,1,Ukushaya (kwehora)
  101,2,Yini ukushaya
  101,3,Futhi yini ekwenza wazi ukuthi yini ukushaya (kwehora)
  101,4,Usuku lapho abantu beyobe benjengezimvemvane ezisakaziwe
  101,5,"Futhi\tizintaba\tziyoba\tsengathi\tuvolo\toyimpafumpafu (ziyobhidlika ziqonde)"
  101,6,Mayelana nalowo isisindo(sezenzo) zakhe (ezinhle) ziyosinda
  101,7,Manjalo yena iyongena empilweni ethokozisayo
  101,8,Futhi mayelana nalowo izikalo (zezenzo) zakhe (ezinhle) ziyobalula
  101,9,Manjalo indawo yakhe yokuhlala umgodi wesihogo
  101,10,Futhi yini ekwenza wazi ukuthi kuyini lokho
  101,11,Umlilo ovutha kakhulu
  102,1,Ukuqoqela ndawonye (umnotho) kunenza niphambuke
  102,2,Kuze kube nivakashela emangcwabeni
  102,3,Cha! Niyokwazi
  102,4,Futhi cha! Niyokwazi
  102,5,Cha! Ukube benazi ngolwazi oluqinisekile
  102,6,Ngempela nizosibona isihogo
  102,7,Bese ngempela niyasibona ngamehlo okuqiniseka
  102,8,Bese ngempela ngalolosuku niyabuzwa ngentokozo
  103,1,Ngifunga ngesikhathi
  103,2,Ngempela umuntu usekudukeni (usekulahlekeni)
  103,3,Ngaphandle kwalabo abakholwayo futhi abenza izenzo ezinhle ezilungileyo futhi abayalana ngeqiniso futhi abayalana ngokubekezela
  104,1,Usizi kuyona yonke inhlebi nenhlekisa
  104,2,Lowo ohlanganisa ingcebo futhi ayibale
  104,3,Ucabanga ukuthi ingcebo yakhe iyomenza ukuthi ahlale ingunaphakade
  104,4,Lutho! Ngempela uyophonswa emlilweni wesihogo
  104,5,Futhi yini ekwenza wazi ukuthi yini umlilo wesihogo
  104,6,Ngumlilo kaMvelinqangi obaselwe (ovuthayo)
  104,7,Okuyiwona owenyukela ezinhliziyweni
  104,8,Ngempela wona (umlilo wesihogo) uyobamboza
  104,9,Ezinsikeni ezinwetshiwe
  105,1,Awuzange ubone yini ukuthi iNkosi yakho yabenza kanjani abanikazi bezindlovu
  105,2,Ayizange yini idunge icebo labo na
  105,3,Futhi (iNkosi yakho) yathumela phezu kwabo iqulu lezinyoni
  105,4,Zibajikijela ngamatshe obumba oluqinile
  105,5,Ngakho-ke yabenza kwaba sengathi bawutshani obudliwe (yimfuyo)
  106,1,Ukuvikeleka (kwesizwe) samaQuraysh
  106,2,"Ukuvikeleka\tkwabo\tohambweni\t(lwabo)\tlwasebusika nasehlobo"
  106,3,Ngakho-ke abakhonze iNkosi yalendlu
  106,4,Ekuyiyona eyabanika ukudla (eyabondla) futhi yabaphephisa ekusabeni
  107,1,Ngakube uyambona yini lowo ophika inkolo
  107,2,Lowo uyilowo ochiliza intandane
  107,3,Futhi ongakukhuthazi ukondliwa kwabampofu
  107,4,Yeka usizi kulabo abathandazayo
  107,5,"Labo, bona abangawunaki umthandazo wabo"
  107,6,"Labo, bona ababukisayo (ngezenzo zabo)"
  107,7,Futhi abagodla usizo (nesidingo)
  108,1,Ngempela sakunika inala
  108,2,Ngakho-ke thandaza eNkosini yakho futhi unikele ngokuhlaba isilwane
  108,3,"Ngempela isitha sakho, sona siyanqanyulwa (valwa inzalo)"
  109,1,Yithi oh nina eningakholwayo
  109,2,Angikukhonzi lokho enikukhonzayo
  109,3,Futhi nani anikukhonzi lokho engikhonzayo
  109,4,Futhi nami angisoze ngakhonza lokho enikukhonzayo
  109,5,Futhi nani anisoze nakukhonza lokho engikukhonzayo
  109,6,"Okwenu yinkolo yenu, nokwami yinkolo yami"
  110,1,Uma kufika usizo lukaMvelinqangi nokunqoba
  110,2,Futhi ubona abantu bengena enkolweni kaMvelinqangi ngobuningi
  110,3,"Ngakho-ke ngcwelisa udumo lweNkosi yakho futhi ucele intethelelo kuyona, ngempela yona ngasosonke isikhathi iyakwamukela ukuzisola (kwenceku yayo)"
  111,1,Imisebenzi yezandla zika Abu Lahab iyobhujiswa kanye naye
  111,2,Umnotho wakhe ngeke umsize (ngalutho) kanye nalokho akuzuza izingane zakhe
  111,3,Uyongena emlilweni onamalangabi
  111,4,Kanye nonkosikazi wakhe umthwali wezinkuni zokubasa
  111,5,Entanyeni yakhe kunentambo ewumqhele womlilo
  112,1,Yithi yena unguMvelinqangi oyedwa
  112,2,UMvelinqangi umi ingunaphakade
  112,3,Akazali futhi akazalanga
  112,4,Futhi akekho noyedwa ofana naye
  113,1,"Yithi, “ngicela isiphephelo eNkosini yokusa”"
  113,2,Ebubini balokho (iNkosi) eyakudala
  113,3,Kanye nasebubini bobumnyama ngenkathi bufika (kuqala ukubamnyama)
  113,4,"Kanye\tnasebubini\t(balabo)\tabaphephetha\temafindweni (abenza imilingo)"
  113,5,Kanye nasebubini bonomhawu uma esenomhawu
  114,1,"Yithi, “ngicela isiphephelo ngeNkosi yabantu”"
  114,2,INkosi yesintu
  114,3,UNkulunkulu wesintu
  114,4,Ebubini bomnyenyezi (usathane) uma esehlehlela emumva
  114,5,Lowo onyenyeza ezifubeni zabantu
  114,6,Phakathi kwama-jinn nabantu