quran[17]{c,v,t}:
  86,1,Ngifunga ngesibhakabhaka nangokukhanyayo ebusuku
  86,2,Futhi yini ekwenza wazi ukuthi yini okukhanyayo ebusuku
  86,3,Yinkanyezi ekhanyayo
  86,4,Awukho umphefumulo kepha phezu kwawo kunomlondolozi
  86,5,Ngakho-ke akabheke umuntu ukuthi wadalwa ngani
  86,6,"Wadalwa\tngamanzi\t(uketshezi)\tolukhishwa\t(owesilisa nowesifazane) isidoda"
  86,7,Aphuma phakathi emgogodleni nasezimbanjeni
  86,8,Ngempela yena (uMvelinqangi) uyakwazi ukumphindisela emumva (empilweni)
  86,9,Ngosuku lapho izimfihlo ziyolingwa (ziyovezwa obala)
  86,10,Ngifunga ngakho-ke angeke abenawo amandla nomsizi
  86,11,Futhi ngifunga ngezulu (ngesibhakabhaka) esiletha imvula ngokuphindelela
  86,12,Futhi ngifunga ngomhlaba ngenkathi uqhekeka phakathi
  86,13,Ngempela kona kuyinkulumo ehlukanisayo (okuhle nokubi)
  86,14,Futhi kona akuyiwona umdlalo
  86,15,Ngempela bona benza icebo
  86,16,Futhi nami ngenza icebo
  86,17,"Ngakho-ke\tbanike\tithuba\tabangakholwa,\tbayekwe okwesikhashana ngobumnene"