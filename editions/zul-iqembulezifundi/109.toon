quran[6]{c,v,t}:
  109,1,Yithi oh nina eningakholwayo
  109,2,Angikukhonzi lokho enikukhonzayo
  109,3,Futhi nani anikukhonzi lokho engikhonzayo
  109,4,Futhi nami angisoze ngakhonza lokho enikukhonzayo
  109,5,Futhi nani anisoze nakukhonza lokho engikukhonzayo
  109,6,"Okwenu yinkolo yenu, nokwami yinkolo yami"