quran[10]{c,v,t}:
  77,41,"Ngempela\tabesabayo\t(abalungileyo)\tbasemithunzini nasemithonjeni"
  77,42,Nasezithelweni kulezo abazifisayo
  77,43,Yidlani futhi niphuze (ngokuzanelisa) nangentokozo ngenxa yalokho enanikwenza
  77,44,"Ngempela, kanjalo sibanika umvuzo abenzi bokuhle"
  77,45,Usizi ngalolosuku kwabaphikayo
  77,46,"Yidlani\tnizithokozise\tokwesikhashana\tngempela\tnina niyizigebengu"
  77,47,Usizi ngalolosuku kwabaphikayo
  77,48,"Futhi uma kuthiwa kubona, “khothamani” abakhothami"
  77,49,Usizi ngalolosuku kwabaphikayo
  77,50,Ngakho-ke iyiphi inkulumo abayoyikholwa emva kwayo