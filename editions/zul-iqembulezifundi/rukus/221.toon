quran[16]{c,v,t}:
  15,45,"Ngempela\tabenza\tokulungileyo\tbayohlala\tezivandeni nasemithonjeni yamanzi"
  15,46,"(Kuyothiwa kubona), “Ngenani kusona (isivande) ngokuthula niphephile”"
  15,47,Futhi siyosusa konke okusezifubeni zabo okubi okuyinzondo bahlale njengabazalwane ezihlalweni eziqhwakele ezibhekene
  15,48,Angeke kubathinte ukukhathazeka khona lapho (esivandeni) futhi bona angeke bakhishwe kusona
  15,49,"Zitshele\tizinceku\tzami\tukuthi\tmina\tngiyathethelela nginesihawu"
  15,50,Nokuthi isijeziso sami siyisijeziso esibuhlungu
  15,51,Futhi batshele ngezivakashi zika-Abrahamu
  15,52,"Khumbula ngenkathi zingena kuyena ngakho-ke zathi, “ukuthula” yena wathi “ngempela siyanesaba”"
  15,53,"Izivakashi (izingelosi) zathi, “ungesabi ngempela thina sikulethela izindaba ezimnandi zomfana onolwazi.”"
  15,54,"Wathi (u-Abrahamu), “Ngakube ningilethele izindaba ezimnandi kulapho sengificwe ukukhula (ukuguga) ningitshela izindaba ezimnandi ngani na"
  15,55,Zathi (izingelosi) sikulethele izindabaezimnandingokweqiniso ngakho-ke ungabi ngomunye wabalahlekelwe yithemba
  15,56,Wathi (u-Abrahamu) “ngubani ongalahlekelwa yithemba lomusa weNkosi yakhe ngaphandle kwabadukileyo na?”
  15,57,(U-Abrahamu waphinde) wathi “nizokwenzani (lapha) Oh! Nina! zithunywa na?”
  15,58,"Zathi (izingelosi), “ngempela thina sithunywe ebantwini abayizoni.”"
  15,59,Ngaphandle komndeni kaLothi ngempela sizobasindisa bonke (ekubhujisweni)
  15,60,Ngaphandle konkosikazi wakhe esimthatha njengokuthi ngempela yena ungomunye wabasalela ngemumva