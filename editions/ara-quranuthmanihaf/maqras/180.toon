quran[62]{c,v,t}:
  37,83,۞وَإِنَّ مِن شِيعَتِهِۦ لَإِبۡرَٰهِيمَ
  37,84,إِذۡ جَآءَ رَبَّهُۥ بِقَلۡبࣲ سَلِيمٍ
  37,85,إِذۡ قَالَ لِأَبِيهِ وَقَوۡمِهِۦ مَاذَا تَعۡبُدُونَ
  37,86,أَئِفۡكًا ءَالِهَةࣰ دُونَ ٱللَّهِ تُرِيدُونَ
  37,87,فَمَا ظَنُّكُم بِرَبِّ ٱلۡعَٰلَمِينَ
  37,88,فَنَظَرَ نَظۡرَةࣰ فِي ٱلنُّجُومِ
  37,89,فَقَالَ إِنِّي سَقِيمࣱ‏
  37,90,فَتَوَلَّوۡاْ عَنۡهُ مُدۡبِرِينَ
  37,91,فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمۡ فَقَالَ أَلَا تَأۡكُلُونَ
  37,92,مَا لَكُمۡ لَا تَنطِقُونَ
  37,93,فَرَاغَ عَلَيۡهِمۡ ضَرۡبَۢا بِٱلۡيَمِينِ
  37,94,فَأَقۡبَلُوٓاْ إِلَيۡهِ يَزِفُّونَ
  37,95,قَالَ أَتَعۡبُدُونَ مَا تَنۡحِتُونَ
  37,96,وَٱللَّهُ خَلَقَكُمۡ وَمَا تَعۡمَلُونَ
  37,97,قَالُواْ ٱبۡنُواْ لَهُۥ بُنۡيَٰنࣰ ا فَأَلۡقُوهُ فِي ٱلۡجَحِيمِ
  37,98,فَأَرَادُواْ بِهِۦ كَيۡدࣰ ا فَجَعَلۡنَٰهُمُ ٱلۡأَسۡفَلِينَ
  37,99,وَقَالَ إِنِّي ذَاهِبٌ إِلَىٰ رَبِّي سَيَهۡدِينِ
  37,100,رَبِّ هَبۡ لِي مِنَ ٱلصَّٰلِحِينَ
  37,101,فَبَشَّرۡنَٰهُ بِغُلَٰمٍ حَلِيمࣲ‏
  37,102,فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعۡيَ قَالَ يَٰبُنَيَّ إِنِّيٓ أَرَىٰ فِي ٱلۡمَنَامِ أَنِّيٓ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ قَالَ يَٰٓأَبَتِ ٱفۡعَلۡ مَا تُؤۡمَرُۖ سَتَجِدُنِيٓ إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّٰبِرِينَ
  37,103,فَلَمَّآ أَسۡلَمَا وَتَلَّهُۥ لِلۡجَبِينِ
  37,104,وَنَٰدَيۡنَٰهُ أَن يَٰٓإِبۡرَٰهِيمُ
  37,105,قَدۡ صَدَّقۡتَ ٱلرُّءۡيَآۚ إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,106,إِنَّ هَٰذَا لَهُوَ ٱلۡبَلَٰٓؤُاْ ٱلۡمُبِينُ
  37,107,وَفَدَيۡنَٰهُ بِذِبۡحٍ عَظِيمࣲ‏
  37,108,وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ
  37,109,سَلَٰمٌ عَلَىٰٓ إِبۡرَٰهِيمَ
  37,110,كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,111,إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ
  37,112,وَبَشَّرۡنَٰهُ بِإِسۡحَٰقَ نَبِيࣰّ ا مِّنَ ٱلصَّٰلِحِينَ
  37,113,وَبَٰرَكۡنَا عَلَيۡهِ وَعَلَىٰٓ إِسۡحَٰقَۚ وَمِن ذُرِّيَّتِهِمَا مُحۡسِنࣱ وَظَالِمࣱ لِّنَفۡسِهِۦ مُبِينࣱ‏
  37,114,وَلَقَدۡ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَٰرُونَ
  37,115,وَنَجَّيۡنَٰهُمَا وَقَوۡمَهُمَا مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ
  37,116,وَنَصَرۡنَٰهُمۡ فَكَانُواْ هُمُ ٱلۡغَٰلِبِينَ
  37,117,وَءَاتَيۡنَٰهُمَا ٱلۡكِتَٰبَ ٱلۡمُسۡتَبِينَ
  37,118,وَهَدَيۡنَٰهُمَا ٱلصِّرَٰطَ ٱلۡمُسۡتَقِيمَ
  37,119,وَتَرَكۡنَا عَلَيۡهِمَا فِي ٱلۡأٓخِرِينَ
  37,120,سَلَٰمٌ عَلَىٰ مُوسَىٰ وَهَٰرُونَ
  37,121,إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,122,إِنَّهُمَا مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ
  37,123,وَإِنَّ إِلۡيَاسَ لَمِنَ ٱلۡمُرۡسَلِينَ
  37,124,إِذۡ قَالَ لِقَوۡمِهِۦٓ أَلَا تَتَّقُونَ
  37,125,أَتَدۡعُونَ بَعۡلࣰ ا وَتَذَرُونَ أَحۡسَنَ ٱلۡخَٰلِقِينَ
  37,126,ٱللَّهَ رَبَّكُمۡ وَرَبَّ ءَابَآئِكُمُ ٱلۡأَوَّلِينَ
  37,127,فَكَذَّبُوهُ فَإِنَّهُمۡ لَمُحۡضَرُونَ
  37,128,إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ
  37,129,وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ
  37,130,سَلَٰمٌ عَلَىٰٓ إِلۡ يَاسِينَ
  37,131,إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ
  37,132,إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ
  37,133,وَإِنَّ لُوطࣰ ا لَّمِنَ ٱلۡمُرۡسَلِينَ
  37,134,إِذۡ نَجَّيۡنَٰهُ وَأَهۡلَهُۥٓ أَجۡمَعِينَ
  37,135,إِلَّا عَجُوزࣰ ا فِي ٱلۡغَٰبِرِينَ
  37,136,ثُمَّ دَمَّرۡنَا ٱلۡأٓخَرِينَ
  37,137,وَإِنَّكُمۡ لَتَمُرُّونَ عَلَيۡهِم مُّصۡبِحِينَ
  37,138,وَبِٱلَّيۡلِۚ أَفَلَا تَعۡقِلُونَ
  37,139,وَإِنَّ يُونُسَ لَمِنَ ٱلۡمُرۡسَلِينَ
  37,140,إِذۡ أَبَقَ إِلَى ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ
  37,141,فَسَاهَمَ فَكَانَ مِنَ ٱلۡمُدۡحَضِينَ
  37,142,فَٱلۡتَقَمَهُ ٱلۡحُوتُ وَهُوَ مُلِيمࣱ‏
  37,143,فَلَوۡلَآ أَنَّهُۥ كَانَ مِنَ ٱلۡمُسَبِّحِينَ
  37,144,لَلَبِثَ فِي بَطۡنِهِۦٓ إِلَىٰ يَوۡمِ يُبۡعَثُونَ