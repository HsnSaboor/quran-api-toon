quran[70]{c,v,t}:
  26,111,۞قَالُوٓاْ أَنُؤۡمِنُ لَكَ وَٱتَّبَعَكَ ٱلۡأَرۡذَلُونَ
  26,112,قَالَ وَمَا عِلۡمِي بِمَا كَانُواْ يَعۡمَلُونَ
  26,113,إِنۡ حِسَابُهُمۡ إِلَّا عَلَىٰ رَبِّيۖ لَوۡ تَشۡعُرُونَ
  26,114,وَمَآ أَنَا۠ بِطَارِدِ ٱلۡمُؤۡمِنِينَ
  26,115,إِنۡ أَنَا۠ إِلَّا نَذِيرࣱ مُّبِينࣱ‏
  26,116,قَالُواْ لَئِن لَّمۡ تَنتَهِ يَٰنُوحُ لَتَكُونَنَّ مِنَ ٱلۡمَرۡجُومِينَ
  26,117,قَالَ رَبِّ إِنَّ قَوۡمِي كَذَّبُونِ
  26,118,فَٱفۡتَحۡ بَيۡنِي وَبَيۡنَهُمۡ فَتۡحࣰ ا وَنَجِّنِي وَمَن مَّعِيَ مِنَ ٱلۡمُؤۡمِنِينَ
  26,119,فَأَنجَيۡنَٰهُ وَمَن مَّعَهُۥ فِي ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ
  26,120,ثُمَّ أَغۡرَقۡنَا بَعۡدُ ٱلۡبَاقِينَ
  26,121,إِنَّ فِي ذَٰلِكَ لَأٓيَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ
  26,122,وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ
  26,123,كَذَّبَتۡ عَادٌ ٱلۡمُرۡسَلِينَ
  26,124,إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ هُودٌ أَلَا تَتَّقُونَ
  26,125,إِنِّي لَكُمۡ رَسُولٌ أَمِينࣱ‏
  26,126,فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ
  26,127,وَمَآ أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ
  26,128,أَتَبۡنُونَ بِكُلِّ رِيعٍ ءَايَةࣰ تَعۡبَثُونَ
  26,129,وَتَتَّخِذُونَ مَصَانِعَ لَعَلَّكُمۡ تَخۡلُدُونَ
  26,130,وَإِذَا بَطَشۡتُم بَطَشۡتُمۡ جَبَّارِينَ
  26,131,فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ
  26,132,وَٱتَّقُواْ ٱلَّذِيٓ أَمَدَّكُم بِمَا تَعۡلَمُونَ
  26,133,أَمَدَّكُم بِأَنۡعَٰمࣲ وَبَنِينَ
  26,134,وَجَنَّٰتࣲ وَعُيُونٍ
  26,135,إِنِّيٓ أَخَافُ عَلَيۡكُمۡ عَذَابَ يَوۡمٍ عَظِيمࣲ‏
  26,136,قَالُواْ سَوَآءٌ عَلَيۡنَآ أَوَعَظۡتَ أَمۡ لَمۡ تَكُن مِّنَ ٱلۡوَٰعِظِينَ
  26,137,إِنۡ هَٰذَآ إِلَّا خُلُقُ ٱلۡأَوَّلِينَ
  26,138,وَمَا نَحۡنُ بِمُعَذَّبِينَ
  26,139,فَكَذَّبُوهُ فَأَهۡلَكۡنَٰهُمۡۚ إِنَّ فِي ذَٰلِكَ لَأٓيَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ
  26,140,وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ
  26,141,كَذَّبَتۡ ثَمُودُ ٱلۡمُرۡسَلِينَ
  26,142,إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ صَٰلِحٌ أَلَا تَتَّقُونَ
  26,143,إِنِّي لَكُمۡ رَسُولٌ أَمِينࣱ‏
  26,144,فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ
  26,145,وَمَآ أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ
  26,146,أَتُتۡرَكُونَ فِي مَا هَٰهُنَآ ءَامِنِينَ
  26,147,فِي جَنَّٰتࣲ وَعُيُونࣲ‏
  26,148,وَزُرُوعࣲ وَنَخۡلࣲ طَلۡعُهَا هَضِيمࣱ‏
  26,149,وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بُيُوتࣰ ا فَٰرِهِينَ
  26,150,فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ
  26,151,وَلَا تُطِيعُوٓاْ أَمۡرَ ٱلۡمُسۡرِفِينَ
  26,152,ٱلَّذِينَ يُفۡسِدُونَ فِي ٱلۡأَرۡضِ وَلَا يُصۡلِحُونَ
  26,153,قَالُوٓاْ إِنَّمَآ أَنتَ مِنَ ٱلۡمُسَحَّرِينَ
  26,154,مَآ أَنتَ إِلَّا بَشَرࣱ مِّثۡلُنَا فَأۡتِ بِـَٔايَةٍ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ
  26,155,قَالَ هَٰذِهِۦ نَاقَةࣱ لَّهَا شِرۡبࣱ وَلَكُمۡ شِرۡبُ يَوۡمࣲ مَّعۡلُومࣲ‏
  26,156,وَلَا تَمَسُّوهَا بِسُوٓءࣲ فَيَأۡخُذَكُمۡ عَذَابُ يَوۡمٍ عَظِيمࣲ‏
  26,157,فَعَقَرُوهَا فَأَصۡبَحُواْ نَٰدِمِينَ
  26,158,فَأَخَذَهُمُ ٱلۡعَذَابُۚ إِنَّ فِي ذَٰلِكَ لَأٓيَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ
  26,159,وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ
  26,160,كَذَّبَتۡ قَوۡمُ لُوطٍ ٱلۡمُرۡسَلِينَ
  26,161,إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ لُوطٌ أَلَا تَتَّقُونَ
  26,162,إِنِّي لَكُمۡ رَسُولٌ أَمِينࣱ‏
  26,163,فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ
  26,164,وَمَآ أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ
  26,165,أَتَأۡتُونَ ٱلذُّكۡرَانَ مِنَ ٱلۡعَٰلَمِينَ
  26,166,وَتَذَرُونَ مَا خَلَقَ لَكُمۡ رَبُّكُم مِّنۡ أَزۡوَٰجِكُمۚ بَلۡ أَنتُمۡ قَوۡمٌ عَادُونَ
  26,167,قَالُواْ لَئِن لَّمۡ تَنتَهِ يَٰلُوطُ لَتَكُونَنَّ مِنَ ٱلۡمُخۡرَجِينَ
  26,168,قَالَ إِنِّي لِعَمَلِكُم مِّنَ ٱلۡقَالِينَ
  26,169,رَبِّ نَجِّنِي وَأَهۡلِي مِمَّا يَعۡمَلُونَ
  26,170,فَنَجَّيۡنَٰهُ وَأَهۡلَهُۥٓ أَجۡمَعِينَ
  26,171,إِلَّا عَجُوزࣰ ا فِي ٱلۡغَٰبِرِينَ
  26,172,ثُمَّ دَمَّرۡنَا ٱلۡأٓخَرِينَ
  26,173,وَأَمۡطَرۡنَا عَلَيۡهِم مَّطَرࣰ اۖ فَسَآءَ مَطَرُ ٱلۡمُنذَرِينَ
  26,174,إِنَّ فِي ذَٰلِكَ لَأٓيَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ
  26,175,وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ
  26,176,كَذَّبَ أَصۡحَٰبُ لۡـَٔيۡكَةِ ٱلۡمُرۡسَلِينَ
  26,177,إِذۡ قَالَ لَهُمۡ شُعَيۡبٌ أَلَا تَتَّقُونَ
  26,178,إِنِّي لَكُمۡ رَسُولٌ أَمِينࣱ‏
  26,179,فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ
  26,180,وَمَآ أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيَ إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ