quran[151]{c,v,t}:
  9,93,ہاں اِلزام اوہنا ں تے آوے جیہڑے اپڑآوندے ہوئے (مالدار ہوندے ہوئے)تیرے کولوں چھُٹی مَنگن تے اِس گَل نُوں چَنگا جات ا رہن اوہ پچھے سنگ رہیلن زالڑیاں دے(گھَر وِچ پیٹھن والی عورتاں نال شامل ہونا پسندکَرن )اِس توں مُہر اَللہ نے لائی اوہناں دے قَلباں دے اُتّے تے ہوئے اوہ سَمجھوں عاری)
  9,94,انج دے لوکاں پِچھے جانے اُتےگھَڑنے عُذر (ہزار) تُہاڈے اَگے ،کہہ دے عُذر کَرو ناہ اُکّا، گَل تُہاڈی ہُن ناہ کوئی مَنّی جانی، اَللہ نے ہر گَل تُہاڈی دَس دِتّی اے سانوں ،تے ہُن اَللہ تے پیغمبر اوس دَا ،تَکسن جیہڑے عَمل تُہاڈےہوئے،فیر تُہانوں اوس دے اَگے کِیتا جاسی، جیہڑا جانو(جنانن والا) ہر اوہلے (چُھپےکم دا ) ، اَن اوہلےدَا (ظاہر دا)
  9,95,لاموں (جنگ توں) مُڑ کے جد آوو دے کول اوہناں دے اِیہہ َاللہ دیاں قَسماں کھاسن آکے کول تہاڈےتاں جے کِدھرے اوہناں وَلّوں مُونھ ناہ پھیروں۔اِس کَر کے ہُن اوہناں وَلوں مُونھ اِی پھیرو، ایِہہ گَندے نیں تے دوزخ اِی ٹھاہڑ (رہن دی تھاں) اِہناں دِی اَپنے کَرتوتاں دے بدلے
  9,96,اِیہہ قَسماں ہُن ایس تَوں کھاندے ،توں اِہناں تے راضی تھِیویں جے تُوں راضی وِی ہو جاویں اِہناں اُتّے اَللہ راضی مول(ہرگز) ناہ ہوندا بےزبانے (فاسَق)لوکاں اُتُے
  9,97,اِیہہ تَھل واسی (صحراہی بدو)م خُوب پَکیرے (زیادہ سخت نیں) کُفر اُتّے دو رَنگی َاندر تے اَللہ نے جو کُجھ اپَنے پیغمبر تے نازل کیتا اِس دیاں حَداں ناہ گولن وِچ ماہر اے(دِین دی حدود توں ناواقف نیں)،پر اَللہ وِی تے آپ حَکیم عَلیم اے
  9,98,تَھل واساں(صحرئی بدُو)) دے وِچوں اوبھی جیہڑے راہ خُدا دے وِچ دیوَن نُوں اِک چَٹی جانَن،اوہ ایس اُڈیکے(انتظار کردے نیں )، اَند ر گیڑ کِسے تُس آجاؤ(تُسی کِسے چَکر وِچ آجاؤ)۔مَندا گیڑا اوہناں تے آؤنا(حالاں بدی دا چکر اوہنان تے ای مسلط ہونا اے)،بے شک اَللہ آپ سَمیع ، آپ عَلیم اے
  9,99,تے تَھل واساں (صحراہی بدو) دے وِچوں اوبھی اَللہ تے اِیمان جِنہاں دا، نالے چھیکڑ والے دِن تے ،اوہ جو کُجھ وی خرچ کَریندے (راہِ خُدا دے) جانَن اِس نوں اِک ذَریعہ رِب دے نیڑے ہو جانے دَا ،نالے اِنج دُعائیں لینے دَا پیغمبر کولوں، بے شک اوہناں واہتے اِیہہ خَرچاوَٹ(خرچ) ہے وے نیڑے ڈُھکن دَا اِک رَستہ،ایس طریقے اَللہ اپنے رحمت دے گھَر سر پر داخل اوہناں نوں کَر لیسی، بے شک اَللہ بخشنہارا نالے رحمت کرنے والا
  9,100,رب دے کول سَب تَوں اَگے اوہ جنہاں نیں سَب توں پہلاں ہِجرت کیتی تے اوہ جیہڑے اوہناں نُوں جی آیاں نُوں آکھن والے ہے سَن نالے اوبھی جیہڑے اوہناں دے پِچھے لگَے جیئوں (جیسا) لَگن د َا حق ہوندا اے ، اَللہ اوہناں اُتّے راضی تے اوہ راضی اَللہ دے اُتّے،اوہناں واہتے اَللہ ہین بہشت اسارے(باغ مہیاکیتے) کول جنہاں دے وَگدے پانی، دائم اوہناں دے وچ اوہ رہسن، اِیہہ بڑی اِی جِت اوہناں دِی
  9,101,تیرے آسے پاسے جیہڑے تَھل واسی نیں(صحراہی بَدو) اوہ مُنافق، اِنجے ہین مدینے وِچ وِی لوک مُنافق، دو رَنگی دَا رنگ ا ِہناں تے پَکّا چَڑھیا، تینوں کَیڑ(خبر) اوہناں دِی ناہیں سانوں کَیڑ اوہناں دِی واہوا،اَسی عذاب اوہناں نُوں سرپر دیواں گے دو وَاری ،فیر عَذابے ہور وَڈیرے، وِچ اوہ پیَسن
  9,102,اِنج دے کجُھ لوکی اِہناں وِچوں ،جِنہاں مَن لئَے(تسلیم کیتے) مَند اَپنے(قصوراپنے)،چَنگے ،مَندے دِی کِھچڑی نین عَمل اوہناں دے،ہو سَکدا اے اَللہ کَرے کَرم اوہناں تے،بے شک اوہ غَفور ، رَحیم اے
  9,103,اوہناں دے مالاں دے وِچوں صَدقہ لیندے ہوئے پاک پَوِتّر ر ایہہ سَمجھ اوہنا ں نوں کَرسیں اَندروں باہروں،منگ دُعا اوہناں دے حَق وِچ، اوہناں نُوں تَسکین دُعا تیرے تَوں ہوسی،بے شک اللہ سننے والا جانن والا
  9,104,کی اِہناں نُوں عِلم ناہ اِس دَا،اَللہ ای اے اپَنے بندیاں دِی توبہ نوں منن والانالے دِتیاں خیراتا ں نُوں،بے شک اَللہ بڑا اِی توبہ مَّنن والا نالے رحمت کرنے والا
  9,105,اِیہہ سمجھا دے اوہناں تائیں ، عمَلوں دَسو(توبہ کرکے) اَللہ تَکسی(ویکھے دا ) عَمل تہاڈے،نالے اِس دَا پیغمبر وِی تَکسی نالے مومن لوکی تَکسن(ویکھن دے) ،جھب(فیر) تُساں نے اوس دے اَگے پیش ہونا،ہر اوہلے،اَن اوہلے (ہر چھپے تے کھلے عمل)دَا جاننہارا(جانن والا)، دَس دیوے دَا کی سَن عَمل تُہاڈے
  9,106,تے کُجھ اوبھی ہین جِنہاں دے بارے،رَب اِی جانے جو ہونا ایں،اوہ چاہے تے وِچ عذاب اوہناں نوں پائے ،تے جے چاہے توبہ کَرے قبَول اوہناں دِی ،کیوں جے اللہ آپ عَلیم حکیم اے
  9,107,تے اوہ لوک جِنہاں نے مَسجد پائی ہے وے مومن لوکاں وِچ تَریڑاں (نفاق)پانے واہتے،کُفر کھلاوَن ،پھوٹ پواوَن واہتے،اوہناں دَا اڈُا(کمین گاہ) کر کے جیہڑے پہلاں لڑدے رہے نیں نال اَللہ دے تے اُس دے پیغمبر دے وِی،تے اوہ قَسماں کھاندے ہوئے آکھن دے ۔نیت ٹھیک اَساڈی ہے وے، پر اَللہ اے شاہد اِس تے اوہ سَراسَر جھُوٹھے
  9,108,اِس دے وِچ وَڑیں ناہ اُکّ ا(ہرگز اس وچ داخل ناہ ہونا) پہلے تَوں اِی جیہڑی مَسجد تَقوے تے اُسری(قائم ) ہے وےاُس دے وچ کھَلونا جَچدا، اِس دے وِچ اوہ لوکی ہوندے جِنہاں نُوں سُتھرائی نال محبت ہوندی تے اللہ وِی سُتھرائی لوکاں نال مُحبت رَکھدا ہے وے
  9,109,کی اَللہ دے تَقوے نالے اِس نوں راضی رَکھن اُتّے جِس اُساری(قائم ) کیتی ہووے وِی نِیہہ (بنیاد) اپنی وی،اوہ چنگا ، یا اوہ نیہہ اُساری ہووے جس نے ڈھٹھن ہاری کَنّی والے دَندے تے ا وہ (دندا) نال ای اِس دے دوزخ دِی اَگ اَندر ڈِگے،بے شک اَللہ اوہناں ناہ راہے پاندا، جیہڑے لوکی کَم اَن ہونے کَردے
  9,110,ایہہ اُساری (عمارت)ہے اُساری (بنائی)جیہڑی رَڑکن(دل وچ پھا نس ) بَن کے اوہناں دےاَندراں دے وچ دائم رہسی،جد تائیں اوہناں دے اَندرونے ٹوٹے ٹوٹے ناہ ہوجاسن،اَللہ دِی ذات عَلیم حَکیم اے
  9,111,لَئیاں ہین(خرید لَئی اے) اَللہ نے مومن لوکاں کولوں ،جاناں تے اَموالاں بے شک،جنت دے بَدلے، اَللہ دِی راہ لَڑدے اوہ مارَن یاں آپ مَریوَن(شَہید ہووَن)، وِچ توَراتے ،وِچ اَنجیلے وِچ قُرآنے اِیہوا آیا ، اَللہ ہے اپنے اِس وَعدے اُتے قائم،ا للہ دے نالوں کیہڑا قول اَپنے دَا پکّا، اِس ک؟رکے جو وَنج(سَودا) تُساں اَللہ دے نال کیتا ہے وےخُوشی مَناؤ اِس دے اُ تے ، اِیہوا اِی تے جِت وَڈیری (وَڈّی کامیابی) سَب تَوں ہے وے
  9,112,اِیہہ بپاری اوہ نیں جیہڑے عابد، تائب تے تبلیغی، اُس دے اگے جُھکنے والے،سجدے کرنے والے، چَنگیائی دا آکھن والے مَندیائی توں ٹھاکن والے، رَب دِیاں حَدَّاں دے رَکھوالے، خو شخبری دے ایس طرح دے مومن لوکاں تائیں
  9,113,اےنَبی نُوں زیب ناہ دیوے ناہ اِیمان لِیائے لوکاں نُوں زیبے ۔مُشرک لوکاں دے حَق اَندر َبخشش مَنگن بھاویں سَکّے سَاک(رشتے دار) اِی ہووے،اِس تَوں پِچھے جَد اوہناں دے اُتّے واضح ہو چُکیا اے ،جے اِیہہ لوکی اَگ دے واسی
  9,114,باپ اپنے دے واہتے اِبراہم نَبی دَا بخشش واہتے ، رَب نُوں کہنا اُس وَعدے دَاپالن ہے سی جیہڑا سی اِس تَوں کَروایا،تے جد اُس تے روشن ہویا اوہ اَللہ دَا دُشمن ہےوے۔اوہ اُس توں اِک پاسے ہویا، بے شک اِبراہیم حَلیم طَبیعت والا تے سِی نَرم دِلے دَا
  9,115,اَللہ دَا دَستور نئیں اِیہہ ،قوم کِسے نُوں سِدھا رَستہ دَس کے(ہدیت دے کے ) پُٹھے راہے پائے (گمراہی وچ مُبتلا کرے) جَد تَک ناہ اوہناں نُوں ناہ کھُلم کھُلا دسّے، کیہڑی کیہڑی شے توں رہن اوہ بچ کے،بے شک اَللہ نُوں کیَڑ (خبر) ہے وے اِک اِک شے دِی
  9,116,اِیہہ اَسمان زَمین تمَامی، اَللہ دے اِی ہَتھ وَس ہے نیں(قبضے وچ نیں )،اوہ جَوَائے (زندگی دیندا اے) اوہوا مَارے، اَللہ باجھوں (سوا) ہور تہاڈا ناہ کوئی سائیں ، ناہ ِامدادی
  9,117,نَظر کَرم دِی اَللہ کیتی، وَل نبی دے ، تے اوہناں وَل جیہڑے ہِجرت کَرکےآئے تے اَنصاراں دے وَل جیہڑےاَوکھے ویلے اِس دے پِچھے لگَے،اس دے پِچھے جَد اِک ٹولہ دِل تَریڈے کر لینے دے نیڑے ڈُھک پیا سی،فیر نَظر رحمت دی اوس نے ،اوہناں اُتّے کیتی ،کیوں جے اوہ رؤف رَحیم اوہناں دے حَق وِچ
  9,118,اوہناں تِنّاں اُتّے وی اوس نَظر کَرم دِی کِیتی،جِنہاں بارے گَل اَگیرے چَل کے بنے لَگنی ہے سی (جنہان دا فیصلہ ہونا سی)،اِیہہ زَمین جَدوں کھُل ساری(سار ی وسعت دے باوجود)، اوہناں نُوںسَوڑی(تنگ) ہوندی جاپی تے اوہناں جاناں َلگیاں وِچ شَکنجے آئیاں، اِیہہ محسوس اوہناں نے کیتا۔اَللہ کولوں ہَٹ کے کِدھرے جان اوہناں دَا ناہیں،فیر اَس اوہناں اُتّے کیتی نَظر کَرم دِی، تاں جے توبہ تَاب کَرن اوہ، بے شک اللہ رَج کےتوبہ سُننے والا نالے رحمت کرنے والا
  9,119,اے اِ یمان لیائے لوکو ڈَردے رہو خُدا دے کولوں تے سچیاراں دے نال رَہوو
  9,120,اِیہہ مدینے دے وَسنیکاں دے یا جیہڑے آل دَوالے تَھل واسی(بدو)نیں ،جچدا نئیں سی اوہ رسول اَللہ نُوں چھڈ کے پِچھے رہندےیا اوہ جِنداں(زندگیاں) اَپنیاں نُوں اِس دِی جِندوں اَگے گِن دے، اِس َکر کے جے لَگدی ہے وے جیہڑی تیہہ تھکاوٹ تے بھُکھ رَب دے رَستے دے وِچ اوہناں نوں،وغڑ وغڑیاں کَردے جاندے،کفروناں نُوں کَوڑ دِیواندے یاں دُشمن نُوں چَرکا لاندے اِس دے بَدلے اوہناں دے ناں(نام ) لِکھیا جاندا عَمل چَنگیرا، کیوں جے اَللہ ضائع اُکا کَردا نئیں اَجر اوہناں دے جیہڑے چَنگے کَم کَردے نیں
  9,121,اوہ جیہڑا وِی خَرچہ کَردے تھوڑا یاں بُہتا یاں جنِاّ ں وِی پینڈا (فاصلہ)کَردے۔اِس دَا بَدلہ لِکھیا جاندا ، اَللہ چنگا اَجر اوہناں نُوں دیسی اوہناں دے عَملاں دے پاروں
  9,122,اِیہہ تاں مُمکن ناہیں ہے سی ٹُر پیندے مومَن سارے دے سَارے اِی، پر لوکاں دے اَپنے اَپنے قَبیلے وِچوں کیوں ناہ کجُھ نے آکے اَپنی دِینی سوجھ وَدھائی تاں جے واپس اَپنے اَپنے لوکاں وِچ اُوہ ہوڑ ہَٹک (خبردار )کَر دے تے اوہناں نوں (مَندیائیاں تَوں ) ڈَکدے(بُرائیاں تَوں روکدے)
  9,123,اے اِیمان لِیائے لوکو آسے پاسے ہین تہاڈے کافر جیہڑے ، اِنج اوہناں نوں پے جاؤ، جے زِچ ہوجاوَن اوہ تُہاڈے ہتھوں ،تے اِیہہ چیتے رَکھو اَللہ اوہناں دَا جو اُس دِی مَن دے(متقی)
  9,124,تے جَد سورت نازل ہوندی ہے وے کوئی، اوہناں وِچوں اِنج دے وِی نیں جیہڑے آکھن اس دے پاروں کِس دَا ہے اِیمان وَدھیرا ہویا (ایمان وچ اضافہ ہویا )، پر جیہڑے نے مَّنن والا اوہناں دَا اِیمان وَدھیرا ہو جاندا اے تے اوہناں نوں چا ء چَڑھدا اے(اوہ دِلشاد ہوندے نیں )
  9,125,روگ(نَفاق) جِنہاں دے اَندر ہے وے ، اوہناں دَا گَند اِس توَں ہور زیادہ ہوندا تے اوہناں نے کافر ہوندے اِی مَرنا ایں
  9,126,کی اوہناں نو ں دِسدا ناہیں (نظر نئیں آندا)اِک دو وَاری ہر سَال َاندر اوہ اَزمائش دے وِچ پیندے ،مُڑ وِی توبہ اوہ ناہ کَردے تے ناہ مَت مَن دے(نَصیحت قبول کردے)
  9,127,تے جد سورت نازل ہوندی ہے وے کوئی ایہہ اِک دوجے وَلوں (کہندے ہوئے) کی مُنافق پَن اَساڈا کھُلیا ، اِہناں اُتّے فیر اِک پاسے ہو جاندے نیں،پھیرا اوہناں دے قَلباں اَندر اَللہ پایا کیوں جے اوہ تے سوچوں کورے
  9,128,سوچو اِک رَسُول تُہاڈےوَل ،تُہاڈے وِچوں آیا،جیہڑا کُڑھدا ہے اِس اُتُے، تُسی مُصیبت وِچ پوَو ناہ، چاہ تُہا ڈی اس دے اَندر(تُہاڈی فلاح چاہندا اے)،مومَن لوکاں واہتے اوہ رحمت اِی رحمت ، اوہ شَفقت اِی شَفقت
  9,129,اِس تے وِی جے (اے پیغمبر )اوہ مُونھ موڑن،کہہ دے اَللہ کافی ہے وے ،میرے واہتے،باجھ اس دے (اس دے سوا)مَعبود ناہ کوئی،میں توکل اِس تے کَردا،اوہوا مالک عَرش وَڈّے دَا
  10,1,الف ،لام، را،اوس کتاب دی ایہہ گَلاں حِکمت ِاِی حِکمت اے جیہڑی
  10,2,کی تعجب لوکاں نُوں اِس اُتّے ہے وے،اوہناں وچوں اِک بندے تے وَحی اَساڈے وَلّوں اتری،تاں جے لوکاں نُوں دَبکائے،نالے مومَن لوکاں نُوں ایہہ دے تَسلی ،اوہناں دے رَب کول اُچیرا رُتبہ ہے وے اوہناں وَاہتے،بھاویں کافر ایہوا آکھن ظاہرَم ظاہرا اے کوئی ٹونے کرنے وَالا
  10,3,بے شک رَب تیرا اوہ جس نے چھے دِناں وچ (6دن وچ) اَسماناں نُوں تے دَھرتی نُوں خَلقایا سی،بیٹھ گیا مُڑ تخت اُتُے اوہ ، ہر کَم دِی وَاگ (لگام)اوس دے ہَتھ اے،اس دے اذنوں باجھ سفارش کر ناہ سَکدا کوئی،ایہوا اَللہ ہے تُہاڈا، پالنہار تُہاڈا، کرو عبادت اس دی ،کیوں ناہ مَت تُہانوں آوے
  10,4,اوسے وَل ای َپرت تُہاڈی سَب دِی ہے وے،اللہ دَا ایہہ وَعدہ سَچا، بےشک اوسے اِی پیدائش دَا مُنڈھ بنھیا (پیدائش دی ابتدا کیتی) فیر اس نوں(روزِقیامت) اوہ دُہرائے دَا (دوبارہ پیدا کَرسی) تاں جے سانویں (پورا) تول جزَا اوہناں نُوں دیوے،جیہڑے وَل ایمان لیائے نالے چنگے عَمل کمائے، تے جیہڑے انکاری ہوئے،اوہناں واہتے بَلدَا پِیوَن (کھلودا پانی)نالے مار دُکھاویں (دردناک سزا) کیوں جے کفر اوہناں اَپنایا
  10,5,اوہوا ذات اے جسن،(جس نے ) ضیائی سُورج کیتا،تے نُورانی چَن نُوں کر کے منزل منزل پینڈا اوہدے بھاگیں کیتا (مقررکر دِتیاں )،سال شُماری ،وقت شُماری واہتے،ایہہ جو کجھ اللہ نے رچیا (بنایا ) اے منصوبہ اس دے پچھے، سوجھت والے لوکاں واہتے دَسْدا اے اوہُ نکھیڑے(کھول ) کر کے اَپنیاں گلاں
  10,6,بے شک رَات دِنِاں تےآوَن جاوَن وِچ تے اللہ نے جو وِی رچیا(بنایا) اے زمین اَسماناں دے وِچ ،رَب توں ڈرنے والے لوکاں وَاہتے، اس وِچ پَتے پَکیرے(نشانیاں نیں)
  10,7,ساڈے اَگے پیشی نُوں ،ناہ جیہڑے مَنَؒن ،تے ایس دُنیا وِچ اِی ڈنگ ٹَپانے اُتؒے(دنیا دی زندگی تے ) اوہ مَگن(راضی ) نیں،ایسے تے دِل لا بیٹھے (اس تے مطمئن )،اوہ لوکی جو آیات اَساڈی وَلؒوں غافل ہے نیں،
  10,8,اِنج دیاں دا ،اَگ ای ڈیرا اُوہنا ں دِی کرنی دے پاروں
  10,9,تے جیہڑے ایمان لیائے تے کم اوہناں چَنگے کیتے،رب اوہناں دَا، راہ اوہناں نُوں پا دیوے دَا، اوہناں دے ایمانوں پاروں،سو طرح دِی نعمت دے باغاں دے وَل ، کول جنہاں دے وگدے پانی
  10,10,اوہناں وِچ ترانہ اوہناں دَا َہووے دَا سُبحان اللہ تے آپو وِچ مل دے ہوئے اوہ آکھن دے جِیوو شالا۔ تے گل بات اوہناں دِی ایسے تے مُکے دِی(ختم ہوسی) حَمد اوسے دِی کرنی پھَبدِی ،جو رَب سَب دَا
  10,11,تے جے اللہ لوکاں نال کریندا اُنج بھَن چاہڑن (بُرا معاملہ کرنے )دے وِچوں جلدی جِکن اوہناں تے رحمت کردا، اوہناں دِی مُہلت کَد دِی مُکی ہوندی(ختم ہو جاندی) ،پر اَسی ڈِھل دینے ہے واں اوہناں تائیں ،ساڈے اَگے پیشی ہونے نُوں جا ناہ مَنّن ، اپنی حَد ٹپَنی وَچ ٹھیڈےکھانے واہتے(بھٹکن لئی)
  10,12,ایہہ انسانی شیوا،سِر تے آن بَنے تَاں(سخت وقت جَد آوے )،سانوں واجے مارَن لَگدا۔پاسے پَرنے ، بیٹھے ،کھَلتے(کھڑے ہوندے) تے جَد دُکھ مسافر کَرئیے تے اِنج ٹُردا جِویں کَدے، دُکھ دے ویلے ہال دُھائی ،ساڈے آَگے اوس ناہ پائی،انجے اوہناں دے کرتوں اندر جیہڑے حَداں ٹَپن والے ، کھچ (کشش) اَساں اِک پائی ہوئی اوہناں واہتے
  10,13,اَساں ہلاکت دے مُونھ پائیاں ہیں تہاڈے توں پہلاں وی کِنّیاں نَسلاں،جَد اوہناں نیں پٹھاں چائیاں (ظلم دی روش اختیا ر کیتی) حالاں اوہناں دے کول پیغمبر آے پکیاں گلاں لے کے،پر اوہ منَؒن وَل ناہ آئے،مجر م لوکان نُوں کیتے دا پھل اَساں اِنجے اِی دیندے
  10,14,اوہناں پچھوں اَساں تُہانوں دُنیا دِی چدھراہٹ دِتِؒی تاں جےتکئیے چالے(عمل) کی تُہاڈے ہوندے
  10,15,بول کَھرے جَد اوہناں اَگے ساڈے ہین سُنائے جاندے،ساڈے اَگے پیش ہوَن دا ناہ یقین جنہاں نُوں ، آکھن اس توں وَکھرا اِی قرآن لَیا کے دَس خاں یا ایسے دے وِچ اِی کر تبدیلی کوئی، میں تاں اوس دے پچھے ٹُردا جو کُجھ میرے وَل اُتردَا، میں تاں ڈردَا ، وَڈّے دِن دِی ماروں، اپنے رب توں ایدھر اُودھر ہوندے ہوئے
  10,16,ایبھی دَس نیں ،اللہ دِی جے مَرضی ہوندی،میں ناہ ایہہ سُناندا مول (کَدی وِی ) تُہانوں، تے ناہ جانو (جانن والا) اوہ تہانوں اس دَا کردا،آخر اس توں پہلاں وِی تے میں تُہاڈے وِچ عُمر گُزاری ہے وے ،کی اندازہ اِس توں، ہوندا نئیں تُہانوں
  10,17,تے وَدھ اوس توں کون دَھروئی (ظالم ) ہو سَکدا اے ، اللہ اُتؒے جھوٹھی گل نُوں جیہڑا تَھپؒے یا اِس دی آکھی جُھٹھیارے،بے شک اَللہ اوہناں دی ناہ پوری پاند ا(فلاح نئیں دیندا) جیہڑے حَدَؒاں ٹَپَؒن والے
  10,18,تے اللہ نُوں چھڈ کے لوکی اوہناں دی ہے کرن عبادت جیہڑے اوہناں دے ناہ مَندے ، چَنگے جوغے،تے اوہناں دے بارے کہندے لوکاں نُوں اللہ اَگے،ایہ سفارش ساڈی کرنے والے ہے نیں، کہہ دے اللہ نُوں دِس دے گلاں اوہ،اَسماناں تے دھرتی دے اَندر، جس دَا اوس نوں آپ پتہ ناہ،جیہڑا شِرک تُسی کردے او،اللہ اُچا تے پاک اوس توں
  10,19,تے سَب لوکی پہلاں اِکو کُجھ اِی ہے سن، فیر خیال اوہناں دے پاٹے(مُختلف عقیدے تے مسلک ہوئے)جے تیریڑاں اہناں پاروں ربوں کھُل ناہ ہوندی (جے رب وَلوں ایہہ گل پہلاں توں طے ناہ ہوئی ہوندی)،گَل کَدے دِی اوہ اِک پاسے لگی ہوندی جس دے وِچ لوکا ں دے وچ پاڑاں (اختلاف)
  10,20,انج دِی وِی گل ، لوکی کردے،کیوں عذاب نشانی اِس نُوں کوئی ،اِس دے رب ناہ دِتٓٓی، کہہ دے غیب اللہ دے کول اے ،تُسی اُڈیکو انتظار کرو) میں وی ہاں اُڈیکنہارا نال تُہاڈے
  10,21,جد لوکائی رحمت ساڈی نوں چھکدی ہے اپنے اُتے بیتی ہوئی تنگی پچھوں،تاں آیات(نشانیاں ) اَساڈی بارے گھتکل(چال بازی) سو طر ح دی سوچے،کہہ دے اللہ بھانجی موڑن وچ ترکھا ہے تہاڈے کولوں ،لکھدے رہندے ہین اَساڈے گھلے ہوئے ہر اِک چال تہاڈی
  10,22,اوہواہے جے جل تھل اندر، جیہڑا سفر کراندا ہے جے ، بیڑی (کشتی)وچ وی جد ہوندے او۔تے جد بیری سُدھ وا (موافق ہوا)دی تھاپڑ لے کےتَردی ہے ،خوش ہوندے اِس پاروں لوکی،آجاندی پر جد وا(ہوا) کو ڑی(مخالف) جس توں ٹھلاں (لہراں)اُٹھن تھاں تھاں،سمجھ آون جے اوہ گِھر گھتے(گِھر گئےنیں)،تاں مُڑ اللہ چیتا آوے سچے دِل توں،تے اوہ کہن بچائیں جے کر توں اَسانوں ایس پھسن توں ، شکر کراں دے ساری عمرے
  10,23,تے جد اوہ (اللہ )بچا لیندا اے اوہ پھِردےنیں دنیا دے وچ دھکے(بغاوت) کردے،لوکو سُن لئو۔اے دھکے شاہی ایہہ تہاڈی،اپنی ای آپ اُتے پینی،چار دہاڑے موجاں کر لئو دنیا اُتے،ساڈے وَل ای مُڑ آؤنا اے ،فیر تہانو ں دَس دیواں دے، کی کرتوت تہا ڈے ہے سن
  10,24,اس دنیا دا جیون ہے وےپانی وَرگا ،اَساں اُتارن اس دا کیتا،اسماناں توںجس دے پاروں دھرتی اُتے خوب انگوری (پیدوار)ہوئی جس نوں کھاندے بندے وی نیں ،تے ڈنگر وی ،ایتھوں تک جے جوبن اُتے دھرتی آوے تے رنگ کڈے، تے اس دے وسنیک(مالک) ایہہ سمجھن ایہہ اِساڈے قبضے دے وچ اے،اِک راتیں یا اِک دہاڑے اَمر اَساڈا پر آجاوے تے کر دیووے وڈھی (کٹی ہوئی )پیلی(کھیتی) دے وانگ اس نوں، کل جیویں ناہ ایتھے ہے سی ناہ شےای کوئی،سوچاں والے لوکاں دے کن پائیے انج پتے دی گھلاں، وَکھ وَکھ کر کے
  10,25,اللہ سدّےہر کسے نوں چینی(سلامتی والے ) ڈیرے پاسے پر او جس نوں چاہندا ہے وے ،سدھے راہ تے پا دیندا اے
  10,26,چنگے کم جنہاں نیں کیتے،چنگا پھل اوہناں نوں مِلسی،کجھ وَادھا (مزید )وی مِلسی،ناہ مونھ کالے ناہ خواری ای ہووے دی، جنت واسی(جنتی) ایہوا لوکی،دائم اوہناں اوتھے رہناں
  10,27,اے پر جیہڑے لوکاں نیں کم مندے(بُرے ) کیتے،مند اَجر اوہناں نوں مِلسی اوہناں دے کرتوتاںورگا،اوہناں دے مونہاں تے ذلت،اللہ دے کولوں ناہ ہوس(ہوسی) بچانے والا کوئی،رات ہنری دے جیویں ٹوٹے ہون اوہناں دے چہرے کجے (رات دے سیاہ پردے دے ونگ، تاریکی اوہناں دے مونھ تے ہوسی )،ایہہ لوکی نیں اَگ دے واسی(جہنمی)دائم اس دے وچ اوہ رہسن
  10,28,تے جداَسی اکٹھے سبھناں نؤں اُٹھواساں،فیر آکھاں دے اوہناں تائیں ،جیہڑے لوکاں شرک کمایا،رہےکھلوتے اپنی تھاں تے سنے (ساتھ) شریکاں،فیر اوہناں وچ تریڑ(پردا )اَسی پا دیساں،تے آکھن دے آپ شریک اوہناں دے جیہڑے،پوجا سی کد اَساڈی سی تُس کردے
  10,29,رب اَساڈا تہاڈے وچ اے شاہد کافی،سانوں اس دی خبر ناہ اُکّا، تُسی اَساڈی پوجا کردے ہوندے ہے سی
  10,30,اُس ویلے ہر کوئی اپنے کیتے دی سَٹ تھلے ہوسی،تے سب اپنے اللہ دے اَگے پیش ہوون دے،جیہڑا مولاں ہے اوہناں دا حقا سچا،تے بھُل جائے دی چترائی سب اوہناں نوں(سارے جھوٹھ اُوہناں دے گم ہو جاسن)
  10,31,پچھ اوہناں نوں ،دھرتی تے اسمانوں رزق اوہناں نوں کون ایں دیندا۔کناں تے(سماعت تے ) اَکھیاں تے (بینائی تے)کس دا وَس(اختیار ) اے، موئی(بے جان) شے توں کیہڑا ہے وے جندل(جاندار) کڈدا،تے کیہڑا اے جگ دی واگ سنبھالنہارا(تدبیر کرن والا)،اوہ آکھن دے اللہ ای اے،مُڑ پچھ اوس دی ،اوہ مَن کے کیوں ٹُردے ناہیں
  10,32,سمجھو اللہ ایہوا، ای تاں ہے تہاڈا۔حقا سچا رب تہاڈا،حق توں پچھوں کی رہ جاندا، گماہی دے باجھوں(سوائے)،کدھر نوں اوہ موڑے کھاندے
  10,33,انج رب تیرے دی گل ،نافرنے لوکان بارے نتری(صادق ہوئی) جے مَن ٹرنے والے اوہ ناہ
  10,34,پچھ اُوہناں نوں کون تہاڈے ہے شریکاں وچوں جس نے پہلاں سی ایہہ رچن رچایا(تخیلق دی ابتدا کیتی) فیر اس نوں دہر انا سو(فیر اس دا اعادہ وی کرے)،کدھرے اوپئے ٹھیڈے کھاندے
  10,35,کون تہادے ہے شریکاں وچوں پچھ نیں،جیہڑا حق دے راہ پاسکدا،دَس دے اے اللہ ای ہے ،جیہڑا حق دی راہے پائے،کی مُڑ اوس دے پطھے لگنا چنگا ہے وے جیہڑا حق دی راہے پائےیا اوہ جیہڑے انگلی پھر کے آپوں راہے پیندے،وَگ گئی اے کی تہانوں ککن گل مکاندے ہے او
  10,36,پر چوکھے تے سنی سُنائی دے پچھے ای لگن والے،سنی سُنائی ،پکی پیڈی (حق)دی تھانیویں کد بہہ سکدی اے،اللہ نون معلوم تمامی فعل تہاڈے
  10,37,اے قرآن اَجیہا ناہیں ، اللہ باجھوں ہور کوئی وی گھڑ(تصنیف کر) لےاِس نوں،ایہہ تاں آیا اِس توں پہلاں جو ہے وے ،اوسے نوں تصدیقن والا تے اوہناں ای گلاں دی تفصیل اے،تے کُل رب دے وَلوں بے شک آیا
  10,38,کی کہندے نیں اِس نے آپ اس نوں گھڑیا (تصنیف کیتا )ہے وے، کہہ دے انج دی کوئی سورت گھڑ کے آووبلکہ اللہ باجھوں(اللہ دے سوا) جیہڑے ہین گھمنڈ اس گل دا ، رکھدے، اوہناں نوں وی سنگ رَلاؤ (ساتھ ملاؤ)جے سچے او
  10,39,اے لوکی انکاری ہوئے نیں اِس توں اِہناں دی علم اُڈاری توں اُتے وے،تے ناہ حال حقیقت اِس دا اہناں تائیں پُجیا،اہناں توں پہلاں دے لوکی وی اِنجے انکاری تھیوے،تے توں آپوں تَک لے (ویکھ لے )،انج دیاں لوکاں دی جو حالت ہوئی
  10,40,اوہناں وچوں اوبھی جیہڑے ہین ایمان لیائے۔اوبھی نیں جیہڑے منن وَل ناہ آئے،رب تیرے نوں کیڑ(خبر) فسادی لوکاں دی اے ساری
  10,41,جے ایہہ تیر امن ٹُرن ناہ(تینوں جھٹھلان )، کہہ دے میرا کیتا میرے واہتے،تے اعمال تہاڈے ہین تہاڈے واہتے۔میں جو کرناں اِس دا بھار،تُساں ناہ چانا(تُسی نئیں اُٹھانا) تے جو عمل تہاڈے ہے نیں ،میں بری آں اوہناںوَلوں
  10,42,اِہناں وچوں اوبھی نیں جو گَل تیری نوں سُندے جاپن ،پر توں بولے(بہرے) دی کَنّیں کی پا سکنا ایں، جد عقلوں وہ کوُرا ہووے
  10,43,اِہناں وچوں اوبھی نیں جو تکدے نیںوَل تیرے کی توں اَنھے(اندھے) نوں راہے پاسکنا ایں،ہون بصیرت توں ای ،کن ناہ لینے والے
  10,44,بندیاں نال دھروہ(ظلم )کدے ناہ اللہ کردا،اپنے نال دھروہ(ظلم ) نیں بندے آپوں کردے
  10,45,اوہناں نوں اُٹھویا جاسی، لگسی ،دن دی اِک گھڑی ، آپوں توں وِچھڑے،اِک دوجے نوں پہچانن دے ماوس دہاڑے گھاٹے دے وچ اہناں رہناں جو اللہ دے اَگے پیشی توں منکر سن، تے ناہ سدھے راہ تے ٹرنے والے ہوئے
  10,46,اہناں نال عذابی وعدہ ہے اَساں جو کیتا ہوا،اِک جھلکارا اِس دا، دسیا جا سکدا اے،تیرے ہوندے یا تینوں جے فوت اَساں کر دِتا،تاں وی ساڈے وَل ای پرت اوہناں دی،تے مُڑاللہ اوہناں دے کرتوتاں دا خود شاہد ہوسی،
  10,47,ہر اُمت دے واہتے اِک رسول(اصول الٰہی ہے وے) تے جد اوہ رسول آجاندا لوکاں وچ،ترکڑی(ترازو) اِس دے ہتھ ہوندی اے،پر لوکاں نال دھروہ (ظلم )ناہ اُکا ہوندا
  10,48,ایہہ کہندے نیں کتھے وے اوہ وعدہ ،جے کر اوہ سچا سی
  10,49,کہہ دے مینوں جان اپنی دے دُکھ سُکھ تے وی وَس(اختیار) ناہ کوئی،اللہ جو وی چاہے ،ہوندا،ہر کِسے دے واہتے وقت مقرر ہے وے۔جد اوپ ویلا قوم کَسے تے آجاندا اے،اَگ (پہل) پِچھناہ (تاخیر) وی مُڑ پل دی ہوندی
  10,50,آ کھ اوہناں نوں ،سوچ کدے جے ایہہ کیتی ہے جے،کِسے ویلے وی ،ہے عذاب اوس داآسکدا،راتیں(رات نوں ) یا پرھاتیں(دن وچ)،مجرم کیوں سزائے واہتے سوڑے پیندے(جلدی مچاندے)
  10,51,تے کی اُودوں(اوس ویلے) ای منّو دے جد سِر تے سَٹ آن پوے دی(رب کہے دا) ہن ہتھ پیر پئے جے کاہنوں،تُس تے اِہدے واہتےبُہتے کاہلے ہے سی ،
  10,52,کہیا جاسی فیر اوہناں نوں ،جیہڑے ہوڑ رہے سی(تقاضا کر دے سن)،چکھو ہن عذاب ہمیشی ،ایہہ تہاڈی اپنی کرنی دا پھل اے
  10,53,پچھدے نیں ایہہ تیرے کولوں کی عذاب اوہ اَن ٹل ہے وے،کہہ دے آخو(ہاں)،رب دی سونھ او اَن ٹل (ناہ ٹلن والا)ہے وے ،تے اِس نوں تٗس ٹال ناہ سکنا
  10,54,جے کر ہر دَھروئی (ظالم )ہووے دنیا دی ہر شے دا مالک تے چھَڈوائی دے وچ سب کجھ دیووے(کجھ ناہ بَنسی)۔ویکھن دے جس وقت دھروئی اوہ عذاب کَویں دا ہوندا تے اندروں شرمندہ ہوسن۔پر مقدمے اوہناں دے وچ ڈنڈی مول ناہ ماری جاسی تے پورا انصاف ہووے دا
  10,55,اللہ دا اے ،چیتے رکھو، جو کجھ وی اَسماناں تے دھرتی دے اندر،ایبھ سُن لئو،اللہ دی گَل پَکی ہوندی،بُہتے بھانیویں اِس گَل توں ناواقف
  10,56,اوہوا جَوَاوَن والا(زندگی بخشن والا)،اوہوا مارن والا ہے وے تے پرتن (واپسی) وی اوسے وَل اے
  10,57,لوکو وَل تہاڈے ،رب تہاڈے وَلوں مَت(نصیحت) اوہ آئی ،جس دے وچ شفا تہاڈے انداں دے روگاں(دل دے روگ) دے واہتے اوہ مومن لوکاں واہتے راہ پائی تے رحمت وی اے
  10,58,کہہ دے ایہہ(نزولِ قرآن) اللہ دے فضلوں نالے اس دی رحمت پاروں،جچدا اے جے ،اِس تے ، چاچڑھین تہانوں (خوشی منانی چاہی دی) تے اوہ اِس دے نالوں چنگی ،جو کجھ تُسی اکٹھا کردے
  10,59,کہہ دے ،کی ناہ سار(سوچیا) تہانوں،کی اللہ نے تہاڈے واہتے نازل کیتا رزقوں ، تے تُس آپوں اس دے وچوں ہے حرام اِک شے نوں کیتا، تے حلال اِک شے نوں کہہ دِتا،پچھ نیں ،کی اللہ اِس بارے اذن تہانوں کوئی دِتا یا ایویں ای اللہ دے پئے ،کھاتے پاؤ
  10,60,کَد یقین قیامت بارے اوہناں وَلاں نوں ہو سکدا ، جو بہتاں خدا دے اُتے بنھدے(لاندے)،اللہ تے لوکا ں دے واہتے فضل ای فضل اے،پر اِس دی ناہ قدر پہچانن چوکھے
  10,61,توں کِسے وی حال چ ہوویں، تے قرآنوں کجھ وی پیا سُناندا ہوویں اوہناں تائیں، تے کوئی عمل تُسی پئے کردے ہووو۔اَسی تہاڈے کول ہونے آں،اوس تہاڈے ،اس دے وچوں دُب کے پڑھنے ویلے،تے ناہ چھپیا ہوندا ہے وے رب تیرے توں رتی بھر وی،جو دھرتی دے وچ تے اَسماناں دے وچ ہے وے،نکی توں نکی تے وَڈی توں وَڈی وی چیز ناں کوئی، لوح محفوظ دے اندر ناہ جیہڑی
  10,62,رکھ تسلی اللہ دے جو ہین پیارے، یعنی جوایمان لیائے تے دن ،بچ بچا کے بُرائیاں توں کڈھے(تقوی اختیار کیتا)
  10,63,اوہناں اُتے خوف ناہ چھائے ،ناہ ای اوہ ااَندوہی(انجیدہ) ہوون
  10,64,اوہنان واہتے خوش خبری اے ایس جہانے اوس جہانے،تے بدلیون ( تبدیل ہوون) اللہ دے فرمائے ناہیں،اس توں وَڈٰ ہور مُراد اے کیہڑی
  10,65,تے دل گیر کرن ناہ تینوں کفروناں دیاں گلاں،کیوں جےعزّت ہے سچی ،اللہ کول ای،اوہ سمیع اے اوہ علیم اے
  10,66,چیتےرکھو، اللہ دا اے جو کجھ وی اسماناں وچ اے یادھرتی تے ہے وے، تے اللہ نون چھڈکے جیہڑے ، ہور کِسے نوں کرن پکاراں ا س دا سِیری گِن کے(شریک سمجھ کے)۔اوہ اپنے ای وہماں دے پچھے ٹردے تے اٹکل توں کم لیندے نیں (محض قیاس آرائیاں کردے نیں )
  10,67,اوہوا ای جس تہاڈے واہتے رات بنائی ہے وے تاں جے اِس دے وچ سکون تہانوں لبھے،تے دن چانن والی کیتا،بے شک اس دے وچ پتے دی گلاں ہے نیں ، سُننے والےلوکوں واہتے
  10,68,اوہ کہندے نیں اللہ اِک نوں پُت (بیٹا) بنایا ،اوہ اِہناں گلاں توں پاک اے نالے بے محتاجا،اوسے دا جو کجھ اسماناں وچ اے ،دھرتی وچ اے،اپنی آکھی ناہ سنَد تہاڈے کول اے،کی اللہ دے متھے لاؤ ،جس دا علم تھانوں ناہیں
  10,69,کہہ دے جنہاں اللہ بارے یکڑ مارے،اوہ ناہ مُول فلاحے جاسن
  10,70,چار دِہاڑے ایتھے رہ کے فیر اَساڈے وَل ای اُوہناں مُڑ کی آؤنا،فیر اہناں دے کفر بکن دے پاروں،اَسی چکھاساں اِک عذاب کریڑا(سخت)
  10,71,نوح والی گل کھول سُنا توں اہناں اَگے،قوم اپنی نوں جد کہیا اوس، جے تہانوں کوڑا لگدا (چنگا نئیں لگدا)میرا رہناں،میرا مَتّاں (نصیحتاں )دینا االلہ دی گل بات سُنا کے ،تاں توکل اللہ تے میں کیتا،اپنی گل تےپکے تُس وی رہناں سَنے شریکاں ،تاں جے گل رلے دے وچ ناہ رہے تہاڈی(کوئی پہلو تہاڈی اَکھاں توںچھُپیا ناہ ہووے ) تے مُڑ نبڑو(مقابلہ کرو) نال میرے تےڈِھل (مہلت)ناہ دینا مینوں اُکّا(ہرگز)
  10,72,ویکھ ،انج تہاڈے مونھ موڑن دا کی نقصان اے مینوں،میں تہاتھوں اَجر ناہ کوئی منگیا،اَجر تے مینوں رب توں مِلنا،مینوں تے ایہہ حککم ہویا اے ،میں مَن ٹرنے لوکاں وچوں ہوواں(مسلم ہوواں)
  10,73,تے جد اوہناں نے آکھی ناہ اس دی مَنّی،اَساں بچایاں سنگیاں دے سنگ اِس نوں بیڑی(کَشتی) راہیں،تے اوہناں نوں تھاں مَل(جانشین) اوہناں دا کر دِتّا۔ تے ناہ مَت جنہاں نےگولی سی(آیات نوں تسلیم ناہ کیتا)،غرق اوہناں نوں کیتا،تَک (ویکھ)ہویا انجام اہناں دا کنج دا اَساں جنہاں نوں ویلے سِر آگاہ کیتا سی
  10,74,اِس دے پچھوں وی پیغمبر قوموں قوموں وَل بھیجے تے اوہ لے کے کھَریاں گلاں آئے،پر اوہناں نےکل جنہاں نوں نئیں سی مَنیا،اَج وی اوہناں نوں ،اوہ منن وَل ناہ آئے،انج اَسی مُہراں لادیندے آں،اوہناںدے قلباں اُتے جیہڑے حداں ٹپ جاندے نیں
  10,75,فیر اوہناں توںپچھے گھَلے،موسٰی تے ہارون اَسی سی ، فروعونے تے اِس دے سرداراں وَلّے آیات اپنی دے کے،کیتا پر گھمنڈا اوہناِں نے، کیوں جے حد ٹپ اوہ سَن
  10,76,تے جد سچیائی اوہناں دی صاڈے وَلوں پُجی ہے سی(جد حق ساڈے وَلوں سامنے آیا ) آکھن لگے ایہہ تاں جادو لگّے
  10,77,موسٰی اوہناں نوں سمجھایا،سچی گل دا بھلا ایہہ کیوں ناہ رکھدے او ،جد اوہ پُجی کول تہاڈے،کی جادو انج دا ہوندا اے،کدے فلاحے جادو گر ناہ جاندے
  10,78,آکھن لگے آیا ایں وَل (طرف)اَساڈے ، تاں جے پھیرے سانوں اوس توں ،جس تے ساڈے وڈوڈیرے چَلدے آئے،تے ملکے (ملک)دے وچ تہاڈی چڈھراہٹ ہو جاوے،اَساں آکھے تہاڈے اٗکّا لگنا ناہیں
  10,79,تے فرعون کہیا لے آؤ کول میرے ،ہر ماہر جادو گر دے تائیں
  10,80,تے جد جادوگر آپُجےکہیا اوہناں نوں ایہہ موسٰی نے سٹو جو تُساں نیں سُٹنا
  10,81,تے جد سَٹن اوہناں سَٹے، موسٰی اوہنان نوں جتلایا ہے سَٹ ایہہ تہڈی جادو، تے اللہ کر دیسی اِسن نون بے حقیقت، کیوںجے اللہ مُفسد لوکاں دے عملاں نوں توڑ(کامیاب) ناہ چاہڑے(کرے)
  10,82,اُپنیاں گلاں دے نال اللہ دودھ نوں دودھ کر دیندا،بھانویں حد ٹپ لوکاں نوں ناہ بھاوے
  10,83,پر موسٰی دے نالے تھریڑے(چند)لوک ای لگےقوم اوس دی دے،فرعونے دے تے اُس دے سرداراں دے ڈر پاروں جے اوہ تنگ کرن ناہ کِدھرے اوہناں تائیں تے ملکے (ملک )دے وچ سی فرعونے دی کَوہ بلیندی(غلبہ سی) تے اوہ ہے سی سرکش لوکاں وچوں
  10,84,قوم اپنی نوں موسٰی نے سمجھیا،ویکھو مَن ٹُرے اوہ جے اللہ دی تے اوسے تے کرو بھروسہ تے جد( ہن بن گئے او) رب دی منن والے
  10,85,اوہناں کہیا،اَساں توکل رب تے کیتا،رَبّا ،سانوں ظلمی لوخان دی ناہ سَٹ وچ رکھیں
  10,86,اِہناں بے ایماناں کولوں ، مہر(رحمت) اپنی دے نال بچ اکے سانوں رکھیں
  10,87,فیر اِشارہ ساڈے وَلّوں موسٰی تے اِس دے بھائی نوں ایہہ ہویا۔دونویں وَل (دونوں )ای قوم دے واہتے ، جاپو(مہیا کرو) مصر اندر کجھ ٹھاہراں(مکان) تے قبلے دا کَم اوہناں توں لیندے ہوئے پڑھو نمازاں، خوش خبری دے مومن لوکاں تائیں (جے دِن بدلن دے)
  10,88,تے موسٰی نے رب دے اَگے دِل دی کیتی،ربّا توں ای دِتی ہوئی ،فرعونے نوں تے اُوہدے سردارا ں نوں ایہہ زینت دولت اِ س دُنیاوی جیون اندر،کی اِس واہتے ، بھچلاون(ہٹان ) راہ تیر ی توں،مٹی کر دے مال اوہناں دا رَبّا، تے اوہناں دے دِل شکنجے دے وچ کَس دے، کیوں جے اوہ ناہ منن والے ،جد تَک ناہ اَکھیں َتکسن(ویکھ ناہ لین ) مار دُکھاویں(دردناک عذاب)
  10,89,رَب کہیا جے سُن دعا تہاڈی گھتی تے دِل پکے رکھ کے رہناں تے اوہناں دی راہ ناہ جانا،جیہڑے رَبی علموں کورے
  10,90,فیر اَسی سی اسرائیل کیاں نوں بحروں پاڑ لنگھایا(سمندر توں گُزار دِتا)،تے فرعونے لشکر لے کے اوہناں داسی پچھا کیتا۔تاںجے دے سَوَاد اوہناں نوں،جد اوس جاتا (سمجھیا) ڈُب جاواں گے آکھن لگامَن لیا اوہوا ای اے ،جیہڑا پوجن دے لائق اے،تے جس تے ایمان اے اسرائیل کیاں دا،میں وی تھینا(ہونا) منن والے لوکاں وچوں
  10,91,ہن کس کارے، جد توں پہلاں ہیکڑ (نافرمانی)کیتی،تے توں سی اوہناں وچوں ،جیہڑے وَل فساد مچاندے
  10,92,ہاں اَج پِنڈا (جسم )تیرا بچا کے رکھساں اَسی ڈُبن(ڈب جا ن ) کولوں ،تاں جے آون والڑیاں دے واہتے توں نشانی ہوویں،لوکاں وچوں انج بہتیرے ،کنّاں دے وچ مارن جیہڑے ،دِتی دَسّی ہر اِک کیڑ (نشانی)اَساڈی
  10,93,اسرائیل کیاں دا تاں مُڑ واہوا سوہنی تھانیویں اَساں وسیبا کیتا(چنگا ٹھکانا کیتا )،رزق اوہناں نوں سُتھرا دِتا،تےآپس دے وچ اوہ پاٹے ایہہ قرآن آجانے تے ای،تے ہن رب تیرا ای کَرسی ،حشر دہاڑے کُل نتارے(فیصلے)۔اُس دے بارے ،جس تے اَج اوہ پاٹے(اختلاف کردے نیں)
  10,94,جے تینوں شک اِس بارے جو اَساں اے نازل کیتا تیر ے اُتے ،تاں (تسلی کرلےاپنی) اوہناں پچھ کے ،جیہڑے اہل کتاب،تیرے توں پہلاں دے پئے، پڑھن کتاب(اللہ دی)،رکھ تسلی ،رب تیرے دے وَلوں ای سچائی آئی اے وَل تیرے،توں ناہ ہو، ہن ڈانواں ڈولے لوکاںوچوں﷽
  10,95,ناہ اوہناں دے وچوں رہ ، آیاٹ الٰہی نوں جھٹھیاندے جیہڑے،مَت ہو جاویں گھاٹے کھانے لوکاں وچوں
  10,96,رب تیر دی گَل جنہاں تے ڈُھک کے بیٹھی
  10,97,اوہناں ناہ ایمان لینادا،بھانویں اوہنان کول نشانی ہر طرح دی آوے تے آکر تے اوہناں تَکنی مار دُکھاویں(اوہناںدردناک عذاب ویکھناں)
  10,98,پر اُونج ہویا ،اِنج کدے ناہ،گوٹھ(بستی) کسے ایمان لیایا ہووے (یَرک عذابوں)﷽ تےکھٹی اُس کھٹی ہووے اِک یونس دے لگدے چھڈکے،جد اوہناں ایمان لیاندا اوہنان توں اِس دنیاوچ ای ،دور عذاب خواری وال کر دِتا سی ،تے اوہ مدت تائیں رہے سی موجاں کردے
  10,99,جے رب تیرا ایہوا چاہندا،دنیا والے سب دے سب ای ،ایمانی ہو جاندے،اِس کر کے توں ناہ دبایا (مجبور ناہ کر)لوکاں نوں تاں جے اوہ ایمان لیاون
  10,100,کیوں جے باجھوں اللہ دے کوئی وی ناہ مومن تھیندا،تے جیہڑے ناہ عقلاں ورتن،اوہناں نوں اوہ غضب اپنے دے ہیٹھ لیاسی
  10,101,کہہ دے ویکھو تاں جو کجھ اَسماناں تے دھرتی اندر،پر ناہ جیہڑے لوکاں نے ایمان لیاؤناں،اوہناں اُتے ہر نشانی ،ہر ڈراوا بے اثر اے
  10,102,فیر اُڈیک رہے نیں کی اوہ(کس شے دے منتظر نیں )، اوہ دِہاڑے جیہڑے اوہناںنالوں پہلاں لوکاں ویکھے،کہہ دے فیر اُ ڈیکو ،میں وی تہاڈے نال اُڈیکنہارا ہے وآں
  10,103,اَسی بچاندے رہے آں اپنے پیغمبر نوں تے اوہناں نںجنہاں نے ایمان لیاندا،کیوں جے ہے بچان اوہناںدی ساڈے ذِمے،جیہرے لوکی مومن ہے نیں
  10,104,کہہ دے لوکو جے شک دین میرے دے بارے ہے تہانوں)تاں مُڑ سُن لئو)میں اوہناں دی مُول(ہرگز) عبادت کرسان ناہیں،کردے ہے او ،جس دی پئے تُسی عبادت اللہ نوں اِک پاسے کرکے،میں تاں ہاں عبادت کردا اوس اللہ دی ، جس دے ہتھ ،وَس موت تہاڈی،مینوں تاں اے حکم ہے اوس دا، مومن لوکاں وچوں تھیوا(ہووا)
  10,105,تے ایبھ جے مونھ نوں رکھاں سِدّھا دین (الٰہی وَل ای) ،ہر شے نوں اِک پاسے کر کے ،تے ناہ مشرک لوکاں وچوں ہوواں
  10,106,تے ناہ اللہ نوں چھڈ کے سَدّیں ہور کسے نوں ،جیہڑا تیرے چنگے دا ناہ مندےجوگا۔تے جے انج کیتو ای(کیتا)، تاں ہو جاویں گا توں وی نوفرناں لو کاں وچوں
  10,107,کیوں جے تینوں دکھ کوئی جان اللہ وَلوں آوے اوس دے باجھوں کیہڑا اُس نوں ٹالن والا ہووے،تے جے کر اوہ خیر تیری جو چاہے، کیہڑا ہے وے فضل اُس دے نوںموڑن والا ،اپنے بندیاں وچوں جس نوں چاہے اوہ نوازے،اوہ غفوراے ،اوہ رحیم اے، شک ناہ اِس وچ کوئی
  10,108,اے گَل لوکاں دے کَن پا توں،رب تہاڈے وَلوں ،حق ہن وَل تہاڈے آچُکیا اے،جس نے وی اوہ رستہ نَپیا اپنے واہتے نَپیا،انج ای پُٹھے راہ پیا جو،اُس دی بھُل دا بھار اُس اُتے،میں ناہ مُول(ہر گز نئیں ) وکیل تہاڈے اُتے ہے وآں
  10,109,اے پیغمبر توں ٹُر اُس تے جو تیرے تے نازل ہویا،تے اللہ دے اِک پاسےگَل لانے تائیں (جد تک اللہ فیصلہ کرے)،لے توں کَم صبر دے کولوں،سب توں اچھا اوہ نتارا کرنے والا(اللہ بہترین فیصلہ کرن والا اے)
  11,1,الف لام را-ایہہ کتاب ہے جس وِچ پَکیاں گلاں،ایہوا گَلاں کھول کے (تَھاں تَھاں )دَسیاں،حکمت والے ،کَیڑاں (خبر) رَکَؒھن والے رب نے
  11,2,اَللہ باجھوں ہور کسے دِی کرو عبادت ناہیں،اِس دے وَلؒوں میں آیاہاں وَل تُہاڈے،اِک تَرَاہوَا (ڈران والا) تے خوشخبرا بَن کے
  11,3,ویکھو استغفار کرو رَب اَگے تے مُونھ اوس وَل موڑو،اوہ تُہانوں رَج کھانے نُوں ، واہوا دیسی اِک مِتؒھے ہوئے ویلے تائیں،تے فَضل اپنا ہر اُس بندے اُتؒے کَرسی ،جیہڑا ہَتھ کُشادہ رَکھسی، تےجے کنڈ تُساں چا ء کیتی ، میں ڈَرناں وآں وڈؒے دِن نُوں ،تُسی عذابے جاسو
  11,4,اللہ وَل ای پَرَت تُہاڈی تے اوہ قادر ہر شے اُتؒے
  11,5,تَک اوہناں دے چالے ،ایہہ سینے گھُٹ گھُٹ کے رَکھدے،تاں جے اوہ اَندرونے رَکھن اِس توں خُفیہ،چیتا رَکھ جَد اوہ اوہلا ، موہلا کردے تاں وی اللہ اوہناں دِی ہے گجھی (چھپی) تے اَن گجھی (کھلی) توں وَاقف ہوندا،اوہ تاں ہے دِلاں دَا جانو