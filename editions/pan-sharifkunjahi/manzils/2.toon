quran[695]{c,v,t}:
  5,1,اے اِیمان لیائے لوکو ، کِیتے عہد نِباہو ،ہین حَلال تُہاڈے وَاہتے چَرنے ڈَنگر سارے آڈ (سوائے ) اوہناں دے جِنہاں بارے اَگے چَل کے دَسیا جاسِی، ہاں احرامی حالت اَندر کَرو شکار تُسی ناہ اُکّا، بے شک اَللہ حُکم جِکن دَا (جس طرح)چاہے دیوے
  5,2,اے اِیما ن لِیائےکھُل لَوَو ناہ ( حَرمت نُوں ختم ناہ کَرو) اوہناں بارے ہین شعائر جو اَللہ دے،نا ہ مہنیے حُرمَت والے جیہڑے اوہناں بارے، ناہ قُربانی وَاہتےکَعبے گھَلّے(بھیجے) جاندڑیاں دے بارے،ناہ گَل پَٹیاں والے،ناہ نَذر نِیازاں والےڈَنگراں (مویشی) بارے، ناہ اوہناں لوکاں دے بارےجیہڑے کَرن تجارت یا ں خُوشنودی اُس دِی ڈُھونڈَن بیتُ اللہ دے قَصدی ہووَن، ہاں احرامی حالت وِچوں نِکل آوَن توں تُسی شکارے چڑھ سَکدے او،تے ویکھو اِک ٹولے دا ناہ ویر (دشمنی) تُہانوں حَد ٹَپّن دے وَل لے آوے، بھانویں کَل تُہانوں اوہناں بیتُ اللہ توں آؤنوں ڈَکیا (رُوکیا)،نیکوکاری تے تَقوے وِچ اِک دوجے نال کَرو تعاوَن، کَج عملی(گناہ) تے دَھکے شاہی (زیادتی) دے وِچ کَرو تعاون ناہیں، اَللہ کولوں دَب کے رہنا ، پَکڑ اَللہ دِی ڈَاہڈی
  5,3,ہےحَرام تُہاڈے وَاہتے ڈَنگرمُویا (مردہ) لَہُو تے اودھل ماس (سُور دَا گوشت) ، اوبھی غیر اللہ دَا لے کے ناں(نام) جو کِیتا ہووے،اِنجے جیہڑا سَنگھی گھُٹیاں ،(گلا گھٹ کے) یاں ڈَنڈ کایاں(چوٹ کھا کے) اُچی تھاوں ڈِگیاں یا ں ٹَکرکھایاں یا ں سِنگیایاں(سنگ ماریا) مویا ہووے یاں پاڑے ِ دی دَاہڑن ہووے(درندے نے پھاڑیا ہووے ) تے ناہ ذِبح کَرن دے قابل، ذِبح کِسے دے وی اَستھانے(آستانے) تے کِیتا ڈَنگر، فالی تِیر چلا کے کِیتے حِصے بخرے،نافرمانی والے کَم نیں۔اَج توں دِین تُہاڈے دے وِچ گَڑبڑَدے بارے ایہہ کافربے آسےہوئے اوہناں کولوں خوف ناہ کھاؤ ، کھاؤ خوف میرے اِی کولوں،اَج میں تُہاڈے اِی واہتے دِین تُہاڈا کامل کِیتا۔اَپنی نعمت وِی میں پوری اَج تُہاڈے تے کَر دِتّی ، دِین اِسلام تُہاڈے وَاہتے میں پسند اے کیتا، ویکھو بھُکھوں بے وَس اُتّے ٹھاک (پابندی) ناہ کوئی جے دانستہ اوہ ناہ پُٹھے پاسے جائے،بے شک اَللہ آپ غفور رحیم اے
  5,4,(تیرے کولوں پچھدے ہےنیں کی کی ہے حلال اوہناں نوں،کہہ حلال ہَر چنگی سَتھری،اوہ دَرند پرنڈ شکَاری تُساں جنہاں نوں چالے دَسّے (تربیت کیتی) صید (شکار) کَرن دے ۔ رَب دِی دِتّی سوجھوں یا مُڑ جاچ جنہاں نُوں دَسنہاراں دَسّی،اوہناں دِی پَھڑ رَکھی ہوئی کھا سَکدے او اَللہ دَا ناں (نام) پڑھ کے(اس نوں چھڈن ویلے)،رَہوَو خُدا توں دَب کے، بے شک اَللہ کھاتے تُر تو تُرتی (چھیتی ) میلے(نمٹائے
  5,5,اَج توں ہین حلال تُساں نُوں سب سُتھرِیکاں (پاک شےواں)،طعام حلال کتِابی لوکاں دَا وِی ،انجے ہُن تُہاڈے وَاہتے جِوَیں تُہاڈا اوہناں واہتے،مَومن زالڑیاں(عورتاں) اَشرافاں نالے اوہناں دِیاں اَشرافاں جنہاں وَل کتاب تُہاتھوں پہلاں آئی پَر جَد مہر ادا ہو جاوے تے نِیت ہووے رَسَّن وَسَّن دِی ،ناہ بَدکاری یاں اَشنائی پالن اُتّے کھوہ پَوَے دِی (چھن جاسی) کِیتی اُس دِی نال اِیمان دَھرو جِس کیتا (ایمان دی روش تے چَلن توں انکار کیتا)،اَگے چَل کےاوہنے ہونا گھاٹا کھانے وَالڑیاں چوں
  5,6,اے اِیمان لیائے لوکو ، جَدوں نمازے اُٹھو، مونھ دھوو تے ہَتھ اَپنے وِی ارکاں (کہنیاں) تائیں ،گِلّا ہَتھ سِراں تے پھِیرو(مَسح کَرو)،پیراں نُوں گِٹیاں (ٹخنے) تائیں دھوو،غُسل کَرو جے جَنبی ہووو، جے بیمار یاں رَاہی (مسافر) ہووو، یاں اوہلے ہو کے(رفع حاجت کر کے) آئے ہووو یاں زَالاں نُوں ڈھک کے (بیوی کولوں آئے ہووو)، پانی ناہ مِلدا ہووے تے پاک کِسے مِٹِّی وَل ہو کے ( تلیاں دے نال لا کے)-(ہتھیلی) پھیرو اپنے مونہاں اُتّے ہَتھاں اُتّے ،اَللہ تنگ تٗہانوں کَرنا چاہندا ناہیں، پَر اوہ چاہے پاک تُسی ہو جاؤ تے اوہ اپنی نعمت پوری کرتُہاڈے اُتّے دیوے، تاں جے شُکر گُزار ہو جاؤ
  5,7,"یاد کر اِحسان اَللہ دا جو تہاڈے اُتّے ہویا، تے اوہ پَک (عہد) وِی جیہڑا اوس تہاڈے کولوں پَکوایا سِی (وعدہ لِتّا سی) ،جَد کہیو جے \"اَساں سُنْیا اَساں مَنْیا \"، دَب کے رہوو خُدا دے کولوں، اوہ دِلاں(دل) دِیاں جانے"
  5,8,اے اِیمان لیائے لوکو ،جَم کے رَہوو خُدا دے رَاہے ،گَل وِِہاری (انصاف دی) کَردے ہوئے،اِنج ناہ ہوئے ویر (دشمنی)کِسے دی کھَڑے(لے جاوے) تُہانوں ،عَدلوں ڈولن والے پاسے(نا انصافی وَل) اِیہہ تَقوے دے سَب توں نیڑے(نزدیک)۔رَہوو خُدا توں دَب (ڈر)کے، اَللہ کولوں عَمل تُہاڈے بھُلّے ناہیں،
  5,9,جیہڑے وَل ایمان لیائے نالے چَنگے عَمل کَمائے اوہناں نال خُدا دَا وَعدہ ، بَخشش دَا تے نالے اَجر وَڈیرے دا اے
  5,10,پَر جیہڑے وَل اِنکاری ہوئے آیات اَساڈی نوں جھُٹلایا، اوہ ہووَن دے نر گی(جہنمی)
  5,11,اے اِیمان لیائے لوکو- یاد کَرو اِحسان اَللہ دا اَپنے اُتّے جَد اِک دَھر(گروہ) نے دِلوں اِرادہ اِیہہ کِیتا سِی، چائے (اُٹھائے ) ہَتھ تہاڈے اُتّے، اَللہ نے اوہ ہَتھ تہاڈے وَلّوں ڈَکّے(روکے)،رَب توں دَبکو(ڈرو)، مُومَن ہین توَکل اَللہ تے اِی کَردے
  5,12,"لگی چھُپی ناہ، اِسرائیل کِیاں دے کولوں اَللہ عہد لیا سِی،تے اوہناں وچ کھَلوائے (مقرر کیتے) سَن بارہ اَساں وَڈیرے،اَللہ اِیبھی سِی فرمایا،\"میں تُہاڈا سنگی (ساتھی)، جے کر قائم رَکھیاں تُسا ں صلَاتاں،دیندے رَہیو زَکاتاں،میرے پیغمبراں نُوں مَنّیا (مانا) تے اوہناں دِی بانہوَاں بَنیو (بننا)،اَللہ نُوں بے لوبھا (اچھا) قرضہ جے دِتّو جے،میں تُہاڈے ماڑے دھونے دھو دیواں دَا،اوہناں باگاں (باغاں) وِِچ تُہانوں لے جاوا دَا کول جنہاں دے وَِگدے پانی،اس توں پِِچھے جیہڑے وَل تُہاڈے وچوں مُنکرہوئے اوہ تھَڑکے سِدھی رَاہوں﷽"
  5,13,اِس پاروں جے، اوہ رہے ناہ گَل تے قائم، اَساں اوہناں تے لَعنَت پائی، دِل اوہناں دے پَتھر کِیتے، اوہ گَلاں وِچ ہیرا پھیری سَن جے کر دے،تے جو مَتّاں دِتّیاں سَن (تعلیم دِتّی) بہتڑیاں(وڈا حصہ) اوہ بھُل بیٹھے سَن،نِت خیَانت اوہناں دِی دَا ، حال تیرے تے کھُلدا رہندا،تھوڑے اِی نیں پاک اِس عیبوں ، تُوں اوہناں دِی بھُل بھُلا دے(حَرکتاں توں چَشم پوشی کر)،بے شک اَللہ چَنَگیاں جانے اوہناں نُوں جو نیکی کَردے
  5,14,اپنے تائیں جیہڑے نیں نََصرانی کہندے۔اَساں اوہناں دے کولوں وِِی سِی پَک پَکوایا (پُختہ عہد لیا سِی)،بھُل گئے سِی چوکھی (زیادہ تر) اوبھی جو تَعلیم اوہناں نُوں دِتّی ہے سِی،اَساں اوہناں وِِچ ویر وَدھائے (دشمنی پائی) بُغَض وَدھائے روزِ قیامت تائیں اَللہ جَھبدے اِی اوہناں نُوں دَس دیوے دَا کی ریہے اوہ کارَاں کَردے
  5,15,اہلِ کِتابو، ہے تہاڈے وَل رَسُول اَساڈا آیا جیہڑا دَسدَا پیا تُہانوں کِنّیاں اوہ کِتابی گَلاں تُسی جِنہاں نُوں ریہے لُگاندے (َپردہ پاندے ) تے کِنّیاں نُوں چھیڑے ناہیں (درگزر کردیوے )،اَللہ وَلّو ں ویکھو اِک نُور تُساں وَل آیا، کول کتاب اِک حق دَس(دسن والی) اوہدے
  5,16,اِس دِی رَاہیں ، اَمن آلے راہ اَللہ پائے،اس دِی خوشنودی دے پاسے ٹُردے لوکی تائیں،تے توفیق اوہناں نُوں دے کے نِھیرےوِچوں کَڈ کےِ چانَن والے پاسے کھَڑدا (اندھیرے توں کڈ کے روشنی وچ لے جاندا)، اِنج سِدّھے راہ تے پاندا
  5,17,اوہناں بَکیا کُفر جِنہاں نے مَسیح بِن مَریم تائیں اَللہ جاتا،دَس اوہناں نُوں اوس مَسیح بِن مَریم نُوں تے ماں اوس دِی نُوں بلکہ جو کجُھ دُنیا وِچ اے سبَھے نُوں اِی جے ہلاک اوہ کَرنا چاہے کون اُس نُوں اے ڈَکَّن والا(روکن والا) ،تے اَللہ دے اِی وَس ہے وے شاہی سَاری اَسماناں دِی تے دَھرتی دِی تےدُوآں دے وِچکار ہَر شے دِی، بے شک اَللہ ہَر شے اُتّے قادر ہےوے
  5,18,اِیہہ نَصرانی تے یہودی کہندے ہے نیں ،اَسی خُدا دے پُتر ہے واں اَتے پیارے اوس دے ، پُچھ نیں (اوس توں پُچھ ) مُڑ کیوں اوہ گناہواں اٰتّوں ہے وے وِچ عَذاب تُہانوں پاندا، تے سَچ تاں ایہہ وے باقی دِی مَخلو قے وانگو ں ہو اِنسان تُسی وِی،، دے معافی جِس نُوں چاہے ، دے عَذاب اوہ جِس نُوں چاہے،اَللہ دے ای وَس ہے وے شاہی سَاری اَسماناں دی تے دَھرتی دِی تےدوآں دے وِچکار ہَر شے دی، تے اوسے وَل موڑا کھانا (اوسے کول ای جانا)
  5,19,اہلِ کِتابو، ہے تہاڈے وَل رَسُول اَساڈا آیا ،پیغمبراں دے اِک لَمیرے کھَپے پِِچھوں(مُدتاں بعد) واضح کر کے گَلاں جیہڑا دَسدا ہے وے،تاں جے ایہہ تُسی ناہ آکھو سَاڈے وَل دَلاسے یاں دَبکاوے لے کے ناہ کوئی آیا،تے ہُن آگیا اے کول تُہاڈے اِک دَلاسے دینے وَالا تے دَبکانے وِی والا، بے شک اَللہ ہر کَم کَرنے تے قادر وے
  5,20,تے جَد موسٰی اپنی قوم نُوں ایہہ گَل آکھی،لوکو اوہ اِحسان خُدا دَا یاد کرو خا ں ،سِی تُساں تے جو اوس کِیتا،نَبی بنائے اوس تُہاڈے وِچوں،شاہ بنایا اوس تُہانوں،اوس تُہانوں اوہ کجھ دِتّا جو کِسےنُوں دُنیا وِچ ناہ دِتّا سی
  5,21,لوکو دسّو اوس مُقدس تھانویں چَل کے ،جِس نوں اَللہ ناں (نام) تہاڈے کیتا، کَنڈاں کرکے ناہ مُڑ جاؤ(پچھے ناہ ہٹنا)،مُڑیو تے گھاٹا کھاسَو (نامراد ہوسو)
  5,22,آکھن لگے موسٰی اوتھے ڈا ہڈے لوکاں دَا ڈیرا اے، جَد تَک اوتھوں اوہ ناہ نِکلن ،پیر َاساں ناہ اوتھے پانا۔ جے اوتھوں اوہ ٹُر جاوَن تاں جاساں
  5,23,آخر دو وَلاں (دو شخص) نے اوہناں یَرکے ہویاں(ڈرنےآلیاں ) وِچوں،اَللہ نے اِنعام جِنہاں تے کیتا ہویا ہے سی اِیہہ مَت دِتّی(رائے دتی ) ،اُٹھو ہِمت کَردے ہوئے اوہناں تے کَر دھاوا دیوو۔تے وَستی دے وِچ وَڑ جاؤ (داخل ہو جاؤ) بُوَا (دروازہ )بَھن کے ( توڑ کے)،جا وِڑنے تے غالب اوہناں تے آ جَاسَو، تے جے ہے اِیمان تُساں وِچ، اَللہ اُتے اَپنی چھَڈو(اللہ تے بھروسہ کرو)
  5,24,آکھن لگے موسٰی جانا مول (ہر گز) اَساں ناہ اَندَر جَد تائیں اوہ جابرَ اوتھے،توں جا تے رَب تیرا جائے نال اوہناں دے بھِڑنے(لڑن)۔اَساں پَتَھلّے اِیتھے مارے(اساں تاں ایتھے بیٹھے آں)
  5,25,موسٰی تاں فرَیادی ہویا، رَبّا اَپنی جِنڈڑی(ذات) تے ای وَس(اختیار) اے میرا یاں مُڑ اَپنے بھائی اُتے ،ساڈے وِچ تے اوہناں نافرماناں وِچ نَکھِیڑا کَر دے(نافرناں توں الگ کر دے) حُکم سُنا کے
  5,26,اَللہ حُکم سُنا دِتّا ، جے چالیں وَرہیاں تائیں (چالیس سال تک) اوہناں دے پیر اِس دَھرتی تے لَگن ناہیں، تے ایں تھاں تھاں کھَجل ہو سَن (دَربدر پھِرسَن ،توں افسوسی ہو ناہ اِنہاں نافرناں بارے
  5,27,آدم دے دو پُتراں دی گَل سَچی سَچی کَر اِہناں دے اَگے، جَدوں نیازی، دوآں سی قربانی، پر قبَول اِک وَل دی ہوئی دوجے دی ناہ ہوئی، اوس کہیا میں جانوں مار دیاں دا تینوں،پہلے اَگوں پَرتائی جے (پہلے نے جواب دِتا)، اَللہ نَذر قَبول اُوہناں دِی اِی کَردا اے جیہڑے اُو س توں دَبکن والے (ڈَرنے والے)
  5,28,جے میرے وَل ہَتھ وَدھاسیں(اُٹھاسی) مارن واہتے میں ناہ تینوں مارن واہتے ہَتھ ودھاساں(اُٹھاساں)،مینوں خوف خُدا دا جیہڑا رَب اے سَب دا
  5,29,میری اَپنی اِیہوا مَرضی، بھا ر (گناہ)میرا وِی تے تیرا وی دونویں(دونوں) پین تیرے اُتے اِی تے توں ہو جاوے اَگ وَاسلڑیاں دے وِچوں(دوزخی ہو جاوے) ہے سزا ایِہوا اِی ظُلم کمندڑیاں دِی (ظالماں دِی)
  5,30,نَفس اوس دے بھائی وڈھ (مار) دینے وَل لیاندا تے قتل اس نے کیتا اوس نوں تے اوہ گھاٹل (نقصان اُٹھاونوالے) لوکاں دے سنگ رَلیا (شامل ہویا)
  5,31,فیر اِک کاں(کوا) اُس پاسے اَللہ وَلوں آیا، اوس مِٹی دِی کھَوتَر کیتی(مٹی کھودی) اوس تے اوہنوں وِی ایہہ سُجھی(سمجھ آئی) اِنج بھَرا دِی لاش ٹَکائے(ٹھکانے لائے) ،سوچ آیو سَو، میری قسمت کھوٹی،مینوں اِیناں وِی ناہ سُجھیا (اِس توں پہلاں) جو اِس کاں(کوے )نوں سُجھیا(سمجھ آئی) (لاش بھرادی فیر اوہنے دَفنائی) تے کیتے تے نادم ہونے والے لوکاں دے سَنگ رَلیا
  5,32,ایسے ہونہاری توں ایں (اس وجہ توں) ا<سرائیل کیاں دے اُتے ایہہ گَل کھَولی جِس نے قَتل اوس وَل (شخص) نوں کیتا،قَتل ناہ جِس دے مَتھے ہووے ناہ ایں اوس فَساد مَچایا ہووے کِدھرے، اوہنے سَمجھو سارے لوکاں نوں قَتلایا،تے جس وَل نے وِی جان بَچائی اِک وَل(شخص) دِی وِی اوہنے سَب دی جان بَچائی،بے شک لوکاں وَل رَسُول، اَساڈےوَلوں کھَریاں گَلاں(کھلی کھلی ہدایت) لے کے آئے۔ اِس اُتے وِی چوکھے(زیادہ) لوکی دُنیا دے وِچ دَست دَرازی ہوئے(زیادتیاں کیتیاں)
  5,33,جیہڑے لوکی اَللہ اَتے رَسُول اِس دے نوں لَلکَردے نیں یعنی ہین فَساد مچَاندےپھِردے تھاں تھاں ،ہے سزا اوہناں دِی ایہوا، اُوہ قَتلیوَن،سُولی لَٹکَن یاں اوہناں دے ہَتھ وَڈھیوَن پیر وَڈھیوَن آڈے (مخالف سمتاں وچ)کَرکے یا مُلکوں چِک دِتے جاوَن(جلاوطن کیتے جاون) ،اوہناں واہتے اِیہہ رُسوائی اِس دُنیا دے وِچ ضَرُوری، اَگے چَل کے اوہناں واہتے ہین سزائیں وَڈیاں
  5,34,پر جیہڑے تائب ہو وَن قابو آجاون توں پہلاں اوہناں بارے تے ایہہ سمَجھو جےاَللہ آپ غفور رحیم ایں
  5,35,اے اِیمان لیائے لوکو ، رَہوو دَبی کے(ڈر کے) اَللہ کولوں، اس دے نیڑے کرنے والے رَستے نَپو، اِس دِی راہ وِچ دوڑو بھَجو تاں جے تُسی فلاحے جاؤ(فلاح پاؤ)
  5,36,جیہڑے لوکی کافر ہوئے کول اوہناں دے دُنیا دا سَب کجُھ وِی ہووے ہور اِیناں وِی اوہناں نوں ڈِھیوے کِدھروں (کِتھو لبھے) تے اوہ اِس نوں فِدیہ کَرن عذاب اپنے دا، مول(قیمت)قبول ناہ ہوسی،ہے عذاب اِک اوہناں واہتے دَرداں بھَریا
  5,37,اوہ اَگ چوں نِکلن دِی کوششش کَرسَن پَر ناہ نِکل سَکدے اِس چوں،اوہناں واہتے اوہ عذاب ہمیشی ہوسی(ہمیشہ لئی ہوسی)
  5,38,چور ہووَے یا چورَن ،ہَتھ اوہناں دے وَڈھنے (کٹنے) لازم،اوہناں دے کَرتوتاں پاروں ا ِیہہ سزا اللہ دے وَلوں ،عبرت وجہوں، اوہ عزیز حکیم ہے بے شک
  5,39,ہاں جس نےوِی توبہ کیتی حَد ٹپنی دے پچھے، مُڑ چالے ٹھیک اوس رَکھے، اَللہ اوس دی توبہ مَنّی، بےشک اَللہ آپ غفور رحیم ایں
  5,40,کی معلوم نئیں اِیہہ تینوں ،اَسماناں دی تے دَھرتی دِی ساری شاہی ہے اَللہ دِی، اوہ عذابے جس نوں اوہ مُناسب سَمجھے ، جِس کِسے نوں اوہ مٗناسب سمَجھے بَخشے، بے شک اللہ ہر کاسے تے(ہر شے تے) قادر ہے وے
  5,41,ایویں پے غمَاں وِچ ناہ توں، اے رَسُول اَساڈے اوہناں بارے،ہے بھَج دوڑ جنہاں دِی ساری کافریائی دے واہتے ای بھاویں ہون اوہ اوہناں وِچوں جیہڑے مومن مونہہ دے پر ناہ اَندروں مومن،بھاویں ہون یہودڑیاں چوں، جھوٹھ لئی کَن اہناں دے لگے رہندے،اے کن لاند ے تاں جے اگے جا سُناوَن اِیہہ اوہناں نوں کول ناہ جیہڑے تیرے آئے،اِیہہ توراتی گَلاں تھاواں توں بے تھاویں کَرکےکجُھ دا کُجھ بنا دیندے نیں، تے لوکاں نوں کہندے پھِردے ،انج دا جےکَرحُکم ملے تے مَن لیا جے ، جے ناہ مِلیا تے بَچیا جے، اَللہ جس نوں آپ اَزمائیش دے وِچ پاناچاہے آخر اس دے واہتے توں کی اَللہ کولوںچھوٹ کَرا سیں ،اِیہہ اوہ وَل نیں دِل جنہاں دے اَللہ دھونے ناہیں دُنیا وِچ و ِی اوہناں دے واہتے رُسوائی اَگے چَل کے وِی اوہناں دے لیکھاں دے وِچ عَذاب وَڈیرا
  5,42,جھوٹھ لئی کَن ،رَس اوہناں نوں، رَج کے مال حَرام ایہہ کھاوَن،تے جے کَر تیرے کول اِیہہ آون،تیری مَرضی نیاں بھُگتاویں(فیصلہ کرے) بھاویں ناہ بھُگتاویں اِہناں دےوچ، اوہ ناہ تیرا کجُھ وِگاڑن جوغے ہے نیں،ہاں جے توں نیاں تے آویں (فیصلہ سُناوے) تے توں عَدلوں مول ناہ ڈولیں ، اَللہ نوں تے عَدلی بَندے اِی لگدے نیں چَنگے
  5,43,اُونج اوہناں نوں ایہہ مَجبوری وِی ناہ کوئی تینوں اوہ نیائیں مِتھن(فیصلہ سناون والا بناون) جَد تورات ہے کول اوہناں دے اس دے وِچ ویِ حُکم اَللہ دا جِس توں اوہناں مُونھ پَر تائے(منہ موڑیا) ہوندے سوندے۔ ایہہ ناہ مومن لوکاں دا سَنگ کرنے والے
  5,44,سِی تَورات اَساڈے وَلوں نازل ہوئی اس دے وِچ ہدایت نالے چانن(روشنی) نَبی جنہاں نے آپوں رَب دِی آکھی مَنّی ،وِچ یہودڑیاں دے بھُگتاندے رہے بھُگتانے(معملات دے فیصلے کردے رہے) اوسے نوں اَگے رَکھ کے،اِنج ہور رَبانے اَتے سیَانے کردے کیوں جے اوہ بھی سی کتاب اَللہ دے راکھے،اوہ گواہی وِی اس تے ہے سَن،اَساں کہیا سی ڈَرو ناہ لوکاں کولوں ، دَڑو میرے توں، تے آیات میری نوں کوڈاں مول(حقیر معاوضے تے) ناہ ویچو(ناہ فروخت کرو)، اَللہ دی گھَل اَگے رَکھ کے جیہڑے ناہ پَرہیا بھُگتاوَن اوہ نیں کافر(جیہڑے لوکی اللہ دے نازل کردہ قانون دے مطابق فیصلے ناہ کرن اوہ کافر نیں)
  5,45,سی پابند اَساں اوہناں نوں کیتا، جِند دے بَدلے جِند(جان)،اَکھ(آنکھ) اَکھی دے بَدلے،کَن، کَن دے بَدلے تے دَند (دانت)بَدلے دَند دے پَھٹ(زخم ) دے بَدلے پَھٹ ،ہاں پَر معاف کرے دا جیہڑا، اوس دے اَللہ دھونے دھوسی (اَللہ اس دے گناہ معاف کر سی )،پر ناہ جِس نے پرہیا بھگتائی ،اللہ دِی گھَل اَگے رَکھ کے اوہ ہووے دا نافرمانا
  5,46,اِہناں دے ای پِچھے پچِھے عیسٰی مریم جایا گھَلیا( مَریم دے بیٹے نوں بھیجیا)،اوہناں گَلاں دا تَصدیقی جیہڑی توراتوں ، کول اوہناں دے اَگے ہے سَن،تے اس نوں انجیل سی دِتی جِس دے وِچ ہدایت نالے چانن ہے سی،تے تَصدیقی سی اُس دِی وِی جو تاراتوں کول اوہناں دے ہے سی اَگے،مُتقیاں دے واہتے اوہ مَت بانی(نصیحت) وِی سِی
  5,47,اہلِ انجیلاں تے وِی ایہہ لازم کیتا سی، اس نوں اَگے رکھدے ہوئے اوہ بھُگتان اَپنے بھُگتاوَن(گَلاں دا فیصلہ)، تے ناہ جِس نے بھُگتاناں نوں بھُگتایا ،اَللہ دی گھَل اَگے رکھ کے ،اونج دے ہوسَن حُکم عدولے(فاسق)
  5,48,اَساں کتاب اُتاری ہے وے تیرے اُتے حَقی سَچی، تے جیہڑے اِحکامِ الٰہی لوکاں دے کول اَگے ہے نیں اوہناں دی تَصدیقی بلکہ اوہناں دی نگرانی کرنے والی، اِس کر کے بھُگتا ، بھُگتانے (معملات دے فیصلے کر) ،اللہ دی گھَل اَگے رکھ کے تے اوہناں دے شوقاں دے ناہ پِچھے جائیں اوس نوں چھَڈ کے جو سَچائی کول تیرے وے ،اَساں تہاڈے وچ بنائے سَبھناں واہتے اپنےاپنےراہے باہے(شریعت تے راہِ عمل ) جے اَللہ دی مَرضی ہوندی اوہ تہانوں اِک اُمت وی کر سَکدا سی، پر اوہ تاں اَزمانا چاہےاُس وِچ جو تہانوں دِتّا،اِس کَر کے چَنگیائیاں دے وِچ اِک دوجے توں اَگے لَنگھو، اَللہ وَل اِی پَرت(واپسی) تہاڈی، اوسے دَسنا ،فیر تہانوں جِس وِچ تُسی رہے پاٹے ،اوس دِی اَصل حَقیقت کی سی
  5,49,اوہناں وِچ بھُگتا ، بھُگتانے (معملات دے فیصلے کر) ،اللہ دی گھَل(اللہ دا نازل کردہ قانون) اَگے رَکھ کے تے اوہناں دے شوقاں دے ناہ پچھے جائیں، بچ اوہناں توں، کِدھرے او تھَڑکا ناہ دیوَن (ایدھر اُدھر کرن) اس دے گھَلے حُکم کِسے دے بارے،جے مُونھ موڑَن اِیہہ سَمجھ لے اَللہ دی اے مرضی ہے وے اوہ اپنے کرتوتاں پاروں کِسے اِڑنگے(پکڑ) دے وِچ آوَن،تے لوکوں وِچوں چوکھے نافرنے
  5,50,کی نیاں(فیصلے) اوہ بدوآں والے مُڑچاہوَن،ہور نیائیں کیہڑا چنَگا اَللہ نالوں اہلِ یقیناں واہتے ہووے
  5,51,اے ایمان لیائے لوکوں تُسی یَہودی تے نَصرانی لوکاں نوں ناہ سنگی مَنّو،اوہ تاں اِک دوجے دے سَنگی جِس تہاڈے توں اہناں نوں سَنگی جاتا اوہ اوہناں دے وِچوں ہویا، اللہ راہ کِدے ناہ پائے اوہنوں جو حَداں ٹَپدے
  5,52,توں ویکھیں دا اَندروں میلے۔ ڈوڑ کے رَلدے جا اوہناں وچ،کہندے ،ڈرنے آن، اَسی کِسے چَکر وِچ آجائیے، دور ناہ ویلا، اَللہ فَتح تہانوں دیووے دا یاں کوئی ہور ظَہُور ہووے دا اُس دے وَلوں، جِس دے پاروں اوہ اُس اُتے نادم ہوسَن جو کجُھ اوہناں دے َاندراں (دل وچ ) لگیا ہویا
  5,53,تے اوس ویلے مومن لوک ایہہ آکھن دے،کی ایہہ لوکی اوہوا ای نیں،پَکیاں قسما ں کھا کے جیہڑے رَب دِیاں،ایہہ کہندے سَن جے اوہ نال تہاڈے،اوہناں دا اَج کَکھ رہیا ناہ (سارے عمل ضائع ہوئے )، ہوئے گھاٹل(ناکام) لوکاں وِچوں
  5,54,اے ایمان لیائے لوکو، جو مُرتد تہاڈے وِچوں ہو جاون دے دینوں، اوہناں دی تھاں لے آوے دا اَللہ، اوہناں نوں،حُب(محبت) اوس دِی رَکھدے ہوسَن،حُب(محبت )آپ جنہاں دِی اَللہ رَکھدا ہوسی ،نَرم قَلوب (دل)جِنہاں دے مومن لوکاں واہتے، تے کفروناں تے ڈاہڈے،ہو سن رَب دی راہے لڑنے والے، لَکھ اَلاہمیں ،دیہن اَلاہمیں، دیوَن والے اوہناں نوں پرواہ ناہ ہوسی،اِیہہ صورت تے فَضلاں والی جس دے واہتے چاہے، پیدا کَر دیندا اے اَللہ،بے شک اللہ دا ہَتھ کھُلا ،تے اَللہ جانن والا
  5,55,بے شک ہین تہاڈے سَجن(رفیق) اَللہ تے پیغمبر اوس دا، تے اوبھی ایمان لیائے جیہڑے قائم کردے ہین صلاتاں،دین زکاتاں تے کَم عجزوں لیندے
  5,56,اللہ اَتے رسول اس دے تے اس دے مَنَن والے والڑیاں دے نال مُحبت جیہڑے رَکھدے ،اوہ سارے اَللہ دا ٹولہ تے اوہناں اِی غالب ہونا
  5,57,اے ایمان لیائے لوکواوہناں نوں ناہ یار بنا ؤ جیہڑے تہاڈے دین نوں مَشغولہ تے کھَیڈ سَمجھدے ہوَن یہودی اوہ نصرانی بھاویں کافر ،تے دَبکو اَللہ دے کولوں، جے ایمان تہاڈے اَندر
  5,58,جَدوں نمازے وَل سَد دے ہےاو ،ایہہ بانگاں(آذان) دِی نَقلاں لاہندے،سَچ تاں ایہہ وے ایہہ عقلوں نیں کَورے
  5,59,اہلِ کِتاباں نوں پُچھ ایِناں کی اِس گَلوں تے روہے روہے(وِگڑے)ہو ساڈے تے،ہاں اَسی اللہ نوں من دے نالے اُس نوں جو نازل ساڈے وَل ہویا اے،تے پہلوں وی نازل ہویا ۔سَچ تاں ایہہ وے ہین تہاڈے وچوں چَوکھے نافرمانے
  5,60,کہہ نیں کی تہانوں دَساں سَبھناں توں وَدھ، بھِیڑے کیہڑےاَللہ دے گھَر اجروں ہوسَن،اوہ جنہاں تے اَللہ دی پھَٹکار ہووے دِی تے غَضب اس دا،جنہاں نوں باندَر تے خَنزیرے وَرگا اوس کَر دِتّا،تے اوبھی طاغوتےدی مَن ٹُرنے والے جیہڑے،اوہناں دی تھاں بُہتی بھِیڑی(زیادہ بُری)،سدھی راہ توں اوہ تھِڑکے (بھٹکے)ہوئے چوکھے
  5,61,جَدوں تہاڈے کول ایہہ آوَن آکھن اِیمان لیائے حالاں اوہ کافَر اِی آئے تے اُونجے ای اُوتھوں اُٹھے، اَللہ نوں معلوم ہے ڈاہڈا جو کُجھ اوہ لُکاندے
  5,62,اوہناں وِچوں چوکھے تکسیں ،مَند کاری تے حَد ٹپَنے وَل دوڑ جنہاں دی،کھان حرام اوہ ڈاہڈے ، کَم جنہاں دے ماڑے
  5,63,کیوں اِہنان نوں وَرجن(روکن) ناہ رَبّانے اَتے پروہت اوہناں دے کُوڑ کمَانوں (گناہواں توں ) اَتے حَرام اِی کھائی جانوں، ڈاہدے ماڑے کَم اوہناں دے
  5,64,کہن یہودی اَللہ دے ہَتھ بَدھے (بندھے)ہوئے، بَدھے ہوئے ہَتھ اوہناں دے اپنے ایِ نیں ، اِس بَکواسوں ہے پھَٹکار اوہناں دے اُتے، اَللہ دے ہَتھ کھَلے، خرچ کرے اوہ جیوں کَر چاہے ، ہاںتیرے وَل رب ِدی گھَل توں ، سر پھیری تے کُفر وَدھیرا چوکھڑیاں وچ ہو جان ا ایں،پ ر اَساں اوہناں دے اَندر ویر (دشمنی ) وَدھایا بغض وَدھایا تا قیامت رہنے والا، تے جَد وی جنگی اَگ مچائی اوہناں ،اللہ آپ بُجھا دیووے دا، دُنیا وِچ فَساد مچانے کار (کم ) اوہناں دی ، تے اللہ نوں بھاون ناہیں مول فَساد مچاوَن والے
  5,65,اہلِ کِتابی جے اِیمان کَدے لے آؤندے تے رَب کولوں ڈردے تے اَساں دھو دینے سن اوہناں دے دھونے،تے اوہناں دے میوے بھَریاں باگاں(باغاں) وچ لَوَاندے ڈیرے
  5,66,جے کھَلوندے اوہ تورات ،اَنجیل اُتے نالے اوہناں وَل اجوکی ربی گھَل تے فیر اوہ اُتلے وِی تھَلڑے وِی کھاوَن کھاندے ،اِہناں وچ سِدھے راہے وِی نیں ، پَر چوکھےنیں مَند کارے اِی
  5,67,اے پیغمبر رَب تیرے نیں جو کجھ تیرے وَل گھَلیا اے اوہ اَپڑا(پہنچا) لوکاں تائیں وَرنہ اس دا تُوں سُنیہا (پیغام )را ہے رَکھیا ۔ ،لوکاں کولوں اَللہ تینوں آپ بچاسی ،بے شک َاللہ ناہ کُفروناں نوں راہ پاندا
  5,68,اہلِ کِتاباں نوں اے دَس دے کَدرے وِی ناہ ٹک سَکنا ایں جد تائیں توراتی تے اَنجیلی دَس(دَسیاں گَلاں) نوں نالے اپنے وَل آئی اجوکی گھَل نوں پَکیاں کَرکے ناہ پھَڑیو جے،اونج تیرے وَل رَب تیرے دی آئی گھل توں ،سرپھیری تے ،کُفر وَدھیرا چوکھڑیاں وِچ جاگ اُٹھنا ایں، جِس تے تینوں جُھرنے (افسوس ) دی ناہ لوڑ(ضرورت)کوئی اے
  5,69,مومن جیہڑے ،یا ں یَہودی ،صابی یاں نَصرانی ۔اللہ نوں جے اوہ مَن دے نیں نالے چھیکڑ دِن نوں نالے اوہناں دے کَم چنگے نیں، ناہ کوئی خوف اوہناں نوں ہوسی، ناہ ہوسی کوئی جھورا (رنج)
  5,70,اسرائیل کیاں دے کولوں پَکا قول اَساں کَروایا۔اوہناں وَل پیغمبر گھَلے،اے پر کَدے وِی کوئی اوہناں وَل پیغمبر آیا،اَن بھوندی گل (خواہشات دے خلاف) لے کے اَکناں نے اُس نوں جھُٹلایا اِکناں نے مَتھا لایا
  5,71,اِیہہ خیال اوہناں نوں ہے سی ،کی کسِے کُجھ سَانوں کہنا۔اس کرکے اوہناں نے ـ(جو آئی کیتی) ناہ تکیا ناہ سُنیا،مُڑ وِی اَللہ کَم لیا دَرگزری کولوں (جَد اوہ نادم ہوئے)،پر ہُن اَگے نالوں چوکھے اَنھے(اندھے) بولے، ا َللہ َسب دِی کَرنی نوں اے ویکھن والا
  5,72,اوہنان گل کُفر دِی آکھی جِن کہیا عیسٰی بن مریم اَللہ،حالاں آپ کہیا سی اُس نے اسرائیل کیاں نوں،کَرو عبادت اَللہ دِی اوہ رَب میرا نالے اوہ تہاڈا اے ،اے پر جس نے اَللہ دا کوئی سِیری(شریک ) کیتا، جَنت دا دَر اَللہ وَلوں بند اُس اُتے، ا َگ ٹکانا اوس دا ،حَد ٹپَنے لوکاں دا کِس بھارا چکنا،
  5,73,اوہ لوکی وِی کافر جیہڑے اَللہ نُوں تِنّاں وچوں تِیجا (تیسرا)گِن دے،اوس اِکلے (اکیلے )توں وَکھ(علاوہ) ناہ مَعبود اے کوئی،۔جے اوہ اَپنی اِس بَکواسوں باز ناہ آئے تے اِک عذاب بڑا دُکھ دا، اِنہاں کفروناں نوں آٹوئے دا
  5,74,کیوں ناہ اَللہ دے وَل پَرتن (پلٹن) توبہ کَردے بَخشش مَنگد دے،اوہ غفور رحیم اے
  5,75,اِک رَسولوں وَدھ ناہ مَسیح مریم جایا، اس توں پہلاں کِنّے اِی پیغمبر آئے ،ماں اس دی سَچیارن(راست باز) ہے سی ،دونویں(دونوں) رَوٹی ٹُکر کھاندے۔تَک کِنج اَسی نُکتے اوہناں نوں سمجھاندے،ایبھی تَک اوہ مونھ کِدھرے چائی(اُٹھائے) جاندے
  5,76,کہہ اَللہ نُوں چھَڈ کے ،کی اوہناں نوں پوجو ناہ نُقصان پچانے (دیون)والے تہانوں جیہڑے ناہ نَفع اِی۔ اِیدھر اَللہ سُننے والا ،جانَن والا
  5,77,اہلِ کِتاباں نوں سمجھا توں دین اپنے وِچ حَد ناہ ٹَپن،ناہ اوہناں دے شوقن دے لَڑ لَگن جیہڑے پہلاں دے راہ بھُلے ہوئے تے کِنّیاں نوں گُمراہیا (گمراہ کیتا)ہے ،سِدھے راہوں
  5,78,اسرائیل کیاں دے وِچوں کافر ہوئے لوکاں اُتے تےلعنت پائی سی داود نَبی نیں ، عیسٰی بن مریم نیں،نافرمانی کَرنے پاروں تے حَد ٹپن پاروں
  5,79,ٹھاکن (روکن) وَل اوہ آندے نئیں سی کَم بُرا سی جَد کوئی کردا،تے اوہ جو کُجھ کَردے ہے سِی اَت بُرا سِی
  5,80,اوہناں وِچوں چوکھے وَلاں نوں ویکھیں دا کفروناں دے نال یَرانے (دوستیاں) لاہندے ہوئے،ڈاہڈا مندا (بُرا عمل)جو اِہناں نے اپنے وَلوں اَگے گھَلیا ، ہے اَللہ ناراض اوہناں توں جِس دے پاروں، وِچ عذاب سَدا اوہ رہسن
  5,81,جےاِیمان اِہناں دا ہوندا اَللہ تے پیغمبر اُتے تے اوس اُتے جو وی اُس تے نازل ہویا،تے اوہناں دے نال (کفروناں دے نال) یَرانے (دوستیاں )اِیہہ ناہ لاندے۔سَچ تاں اے وے چَوکھے اِہناں وِچوں ہے نیں ،نافرمانے
  5,82,توں ویکھیں دا مومن لوکاں دے حق اَندرہین یہودی تے مشرک ،سَبھناں نالوں وَدھ کے ویری(دشمن)، اِیبھی تَکسیں مومن لوکاں دے حق اَندر ،اوہناں وِچ خَلوس زیادہ جو کہندے نیں اَسی اَنصاری،کیوں جے اوہناں دے وچ کجُھ عالم تےکُجھ راہب نیں بے آ کڑ(عاجز)
  5,83,تے جس ویلے اوہ سُندے نیں پیغمبر وَل آئی شے نوں،تاں اوہناں دی اَکھاں (آنکھوں) وِچوں اَتھروں (آنسو)وَگن لگ پیندے نیں اوس عرفانوں جو اوہناں نوں حق دا ہووے تے اوہ آکھن اے رَب ساڈے ہے اِیمان تیرے تے ساڈا ،توں گواہواں دے وِچ ساڈا ناں (نام) وِی لِکھ لے
  5,84,کیوں ناہ مَنَیے(تسلیم کراں) اَس (اَسی) اَللہ نوں تے اُوس سَچ نُوں جو اَساڈے کول آیا اے،جَد اَساڈی خواہش ہے وے،رب اَساڈا ،سانوں نیکاکاراں دے سنگ رَلائے(شامل کرے)
  5,85,اوہناں دِی اِس گَل پاروں اِی،اَللہ اوہناں نوں اوہ جَنَّتاں دے دِتّیاں ،کو ل جنہاؐں دے وَگدے پانی ،دائم اُوتھے رہسن۔وَل وَرتائے وَالڑیاں نوں(نیک رویہ اختیا ر کرن والیاں نوں) اَجر ملے اُس رَنگ دا
  5,86,تے جیہڑے انکاری ہوئے تے آیات اَساڈی نوں ناہ مَنیا (تسلیم کیتا) اوہ اَگ واسی (جہنمی )
  5,87,اے اِیمان لیائے لوکوں ناہ حَرام کَرو اوہ سُتھریکاں(پاک چیزاں) اَللہ وَلوں جو حلال تہاڈے اُتے۔اِنج ناہ حدوں لَنگھو، حداں لَنگھن والے ناہ اللہ نو ں بھاوَن
  5,88,اَللہ نے جو رزق حلال طیب دِتّا اوس نوں کھاؤ، اوس دا جھَاکا رکھدے ہو ئے ہے ایمان تہاڈا جس تے
  5,89,اَللہ پَکڑ ناہ اوہناں قَسماں بارے کَر سی، اینویں جو تہاڈے مُونہاں وِچوں نکلن،ہاں اوہناں تے پَکڑ کَردا دِلوں جنہاں نو ں چاسَو ، دَس مَسکیناں دِی روٹی ، بھَج (کفارہ)بھَر ہے وے اِس دِی، عام گھَراں وِچ جیہڑی آپوں کھاندے ہے او، یا اوہناں نوں جو ڑے دیوو،اِک بُردے (غلام) یا چُنڈ چھَڈنی(قیدی دی رہائی)،جِس نوں اے توفیق ناہ ہووے،تِنـ(تین) دِہاڑے روزے رکھے،قسَماں بارے ایہہ تہاڈی بھَج (کفارہ )بھر(ادا کرنا) ہے وے ،ہے قَسماں دا پالن لازم،اَللہ گَلاں اپنیاں نوں کھولے انج تہاڈے اَگے تاں جے اوس دے شُکر گزارو
  5,90,اےایمان لیائے لوکو نَشہ تے جوئے بازی،د<یوا سَتھانی (آستانے)، فالی کانی(فال تے پانسے) کَم سارے ای مَندے تے شیطانی، پراں پراں (دُور دُور ) اِی رَہوو اِنہاں توں۔تاں جے پھَل چنگیرا پاؤ (فلاح نصیب ہووے)
  5,91,شیطانےدِی مَرضی ایہوا نَشیاں راہے بُغض عَداوت اوہ تہاڈے دِل وِچ پا دیوے تے ڈَک دیوے(روک دیوے) رَب رَب کَرنے اَتے صَلاتوں،کی اِہناں توں باز آ جاسَو
  5,92,آکھے لَگو اَللہ دے تے پیغمبر دے ،اپنا آپ بَچا کے رَکھو،تے جے او مُر او دھر نوں وَگے تا ں اِیہہ سَمجھو ہے رَسُول اَساڈے اُتے گَل اَپڑانے (پہنچا دین )دَی پَابندی
  5,93,جیہڑے وَل ایمان لیائے نالے چنگے عمل کمائے اوہناں اُتے بھار ناہ پیسی(گَرفت ناہ ہوسی) پہلاں پیتے کھَادے بارے،جے اَگوں توں جھَاکا رَکھیا (حَرام توں بَچےرہے )تے گَل مَنّی رَکھی (ایمان تے ثابت قدم رہے )تے کَم چنگے کیتے ہَور زَیادہ جھاکا رکھیا تے گل مَنّی رَکھی،ہَور زَیادہ جھَاکا رَکھیا تے وَرتایا چنَگا (نیک رَویہ رَکھیا)،اَللہ نوں تے وَل وَرتارے والے ( نیک کردار) وَارا کھَاندے(پسند نیں)
  5,94,اے اِیمان لیائے لوکو،اَللہ ہے تہانوں کُجھ اَزماناں چاہندا، اوس شکَارے بارے جو ہَتھاں یا نیزے دِی سَٹ(زد ) وِچ ہَووے تاں جے اَللہ جان لَوَے جے کیہڑا ا س دا ہے،اوہلے وی جھَاکا رَکھدا(غائبانہ وی اللہ توں ڈردا اے)،تے اَگوں توں جِس کسِےوِی حَد ٹَپی ، اوہ عَذاب دُکھا ں دا تَکسی(دردناک سزا ملسی)
  5,95,اے ایمان لیائے لوکو کَرو شکار ناہ کوئی جےاِحرامی ہوو-تے دانستہ جِس اِنج کیتا اوس دِی چَٹی اِنجے دَا چوپایہ کوئی،عَدلی بندے دو، تہاڈے اپنے وچوں گَل مُکا سَن(فیصلہ کرسن) اوہ چوپایہ قُربانی نوں کَعبے تیک (تک) لے جایا جاسِی،یا مُڑ بھَج بھر (کفارہ دے) مسکیناں نوں ہے کھَوانا کھانا ،یاں برابر اس دے روزے تاں جے اَپنے کیتے دَا پَھل آپوں چَکھے، پہلاں جو ہویا، سَو ہویا ، اَللہ پھیر ی لیک (لکیر پھیری) اوس اُتے، ہاں جس مُڑکے انِجے کیتا، اَللہ اس نوں بھَج سی (بدلہ لیسی)، بے شک اَللہ زور آوراے تے اوہ بَدلہ لے سَکدا اے
  5,96,جَل(پانی دا) شکار حلال تہانوں کَم دا (ٹھیک اے) اوہ طعام (کھانا) تہاڈے واہتے نالےرَاہیاں(قافلے والے ) واہتے اے، پر ہے حرام، تھلوچی صید(خشکی دا شکار) تہانوںجَد تائیں اِحرامی ہوو۔تے اَللہ دَا جھَا کا رَکھو (اَللہ دِی نافرمانی توں بچو)جِس دے کول اَکھٹیاں ہونا(حاضر ہونا)
  5,97,حُرمت والے کَعبے نُوں لوکاں واہتے اَللہ نے کھلہار بنایا(قیام دا ذریعہ بنایا)، بعض مہینے ٹھاکل(اوہناں وچ لڑنا حرام ) کیتے ،کوہل چڑھاوے (قربانی دے جانور) تے َ پٹیاکل(ـجنہاں دے گلے وچ پٹے قربانی لئی ) اُوس رَوَاجے اِیہہ اِس پاروں تاں جے سَمجھو اَللہ نوں ایں کُل پتے نیں (معلوم اے) اَسماناں دی تے دَھرتی دی ہر اِک شے دی وَرتوں بارے یعنی کس توں کی کَم (کام)لینا ،اوہوا خوب سَمجھدا اے
  5,98,اِیبھی سَمجھو پَکڑ اَللہ دِی ڈاہڈی ہے وے ۔اونج اوہ بخشنہار(بخشن والا) وِی اے ، مہری(رحم دل) وِی اے
  5,99,پیغمبر دے ذمے گَل اَپڑا(پیغام پہنچا ) دینا اے، پر اَللہ نوں سَار (خبر)تہاڈی ہر دَس (کھلے حالات )تے اَن دَس دِی(چھپے حالات )
  5,100,دَس اوہناں پاک ،پلیت (ناپاک) کَدے ناہ تُلدےاِکو وَٹے،چَوکھ پَلیتاں دی(ناپاک دی اکثریت)لَکھ تینوں دے بھَچلاوے(فریفتہ)، سُوجھک لوکو (عقل مندوں) اَللہ دَا اِی جھَارا رَکھو (اَللہ دِی نافرمانی توں بچو) تاں جے تُسی فَلاحے جاؤ
  5,101,اے اِیمان لیائے لوکو اوہناں چیزاں بار ے پَڑچول کرو ناہ(ناہ معلوم کرو) جِنہاں توں جے پَردا لَتھے(ظاہر ہوں) دِل گِیر ہووو، جے اوہناں دے بارے پُچھو(معلوم کرسو) ہُن قُرآن اُتریندے ویلے(نازل ہوندے ویلے) اوہ تہاڈے تے بے پَردا کر دیواں گے، اَللہ بَخش دِتاّ اِیہہ پُچھنا۔اوہ غَفُور حلیم اے بے شک
  5,102,اِکنّاں اِنجے دِی پُچھ تہاڈے توں پہلاں وِی اِنج دِی گَلاں دے بارے کیتی،پر اوہ اوہناں تے چَل سَکے ناہ
  5,103,"ٹور ٹُری ناہ اَللہ وَلوں، کَن چِریاں دِی،تے سانہاں دی (سائبہ )تے جُٹ جَمیاں دِی(وصیلہ) یا ں دَس جَمیاں دی(حام), پر وَل جیہڑے کافر ہے نیں اوہ بُہتان اَللہ دے اُتے بَنھدے رہندے ،تے اوہناں وِچوں مورَکھ چَوکھے (اکثر بے عقلے)"
  5,104,اوہناں نوں جَد کوئی آکھے ،اَللہ دِی گھَل وَل آجاؤ، یاں پیغمبر دے وَل ہو جائؤ،آکھن سَاڈے واہتے کافی جس تے ڈِ ھٹَّا (ویکھیا)وَڈکڑیاں نوں(باپ دادا،نوں)بھانو یں وَڈکے ہوَن ا وہناں دے بلکل عِلموں کَورے تے ناہ رَستہ جانن والے
  5,105,"اے ایمان لیائے لوکو , ہر اِک دا بھار(بوجھ) ہر اِک دے سِر تے،سدھے راہ تے جے تُسی اوہ، ناہ وِگاڑ(نقصان ) تہاڈا سَکسِی جیہڑا رَاہوں بے رَاہیا ہویا ، پَرت(پلٹنا ) تہاڈی اَللہ وَل اِی اے سَبھناں دِی، اوہ تہانوں دَس دیوے دا کی تُسی رہے کَردے"
  5,106,اے اِیمان لیائے لوکو ،آؤندی جاپے موت کِسے نوں جے کر، وَقت وَصیت دو اِتباری بَندے پاہن گَواہی، پینڈے (سفر) اَندر موت مصیبت سِر تے آوے ،کوئی وِی دو ہو سَکدے نیں جے کَر شک شُبہ پے جاؤ تے بَعد نَمَازوں روک لَوَو نیں تے اوہناں توں قسَم چکُا کے اَکھواؤ جے ،ناہ گَواہی اوہ وِ یچن دے لالچ کر کے ناہ ایں رَبوں فرض شہادت اوہ لُکاسَن لَکھ قَریبی وِی کوئی ہووے، مَت مَندکاراں دے وِچ رَلئیے
  5,107,تے جے مَغروں(بَعد وِچ) اے کُھل جاوے ،دوآں نے اِی پَاپ کمَایا تے دو ہَور کھَلَون اوہناں دی تھاَویں اوہناں چوں ،اُلٹ جنہاں دےتُری گَواہی پہلڑیاں دی، تے اوہ قَسم خُدا دِی کھَا کےآکھن ہے گَواہی ساڈی پہلے دوآں نالوں سَچی،حَد اَسی ناہ ٹَپی ، جے ٹَپئیے تے ظالم اَسی شُمارے جائیے
  5,108,اِیہہ طَریقہ سَچو سَچ گواہی واہتے بُہتا نیڑے ،لوکی ڈرسَن دو جلَیاں(متاثرہ) لوکاں دِی قسَماں کَٹن(تردید کرن) پہلڑیاں دِیاں قسَماں،ویکھو دَب کے رَہوَو خُدا توں (اَللہ توں ڈرو)تے اے َگل کَنّیں پا ؤ(غَور نال سُنو) بے شک اَللہ نافرناں نوں ناہ کَدے ہدا یت دیوے
  5,109,پیغمبراں نُوں اِک دِن اللہ کَٹھیاں کَرسِی(جمع کَرسی) تے اِیہہ پُچھسی(اِیہہ پوچھے دا) ،گَل تہاڈی کِویں اِہناں نے پلَّے بَدّھی ، اوہ آکھن دے ناہ عِلم اَسانوں، توں ایں توں ایں اوہلڑیاں(پوشہدہ حقیقتاں )نوں جانن والا
  5,110,عیسٰی مریم جائے نوں مُڑ اَللہ کہسی، چیتے کَر اِنعام تِرے تے جو میں کیتے نالے تیر ی مَاں تے،جَدوں مُقدس روح نوں تیری بانہہ بَنایا، تں لوکاں نال گَلاں کَردا پَکی عُمرےکَچی عمُرے، جانہار کِتاب اَتے حِکمت دا کیتا توراتے دا اِنجیلے دا، چیتے کَر جَد تو ں مِٹی توں چِڑی بناندا تے مُڑ اوسے نوں پھُکیا کے میرے اَذنوں اوہ چِڑی ہو جاند ی ہے سی، اَنھے کوہڑے توں میرے اذنوں توں وَل کَردا(ٹھیک کردا) ،مَریاں نوں اُس حالوں کَڈدا میرے اَذنوں،چیتے کَر جَد اِسرائیل کیاں دے شَر نُوں دُور تیرے توں کَر دِتُا سِی،توں جَد حُکم الٰہی لے کے کول اوہناں دے پجوں(آیا) تے اوہناں دے وِچوں جیہڑے مُنکر سِی اوہ آکھن لگے ایہہ تاں سِدھم سِدھا جادو
  5,111,یاد ہووی دا جیہڑے لوکی حوَاری تیرے ہوئے اوہناں دے سی میں اِی دِل وِچ پایا،میں نوں مَنّن میرے پیغمبر نو ں مَنّن،تے اِعلانی اوہ ہوئے سن،ہے ایمان اَسی لے آندا تے اِقرار اَسی کَردے آں ہاں اَسی مَن ٹُرنے(مسلم)
  5,112,تے جد چھَڑیاں(حَواریاں) مَریم جائے کولوں پُچھیا ، کی رَب تیرا کر سَکدا اے،اَسماناں توں سَاڈے واہتے کھاوَن گھَلے(کھانا بھیجے)،اوس کہیا سی ڈَرو خُدا توں جے ایمان تہاڈے اندر
  5,113,آکھن لگے دِل کَردا اے جے اَسمانی کھاوَن کھائیے تے انج دِل کھَلوَون سَاڈے،تے اِیہہ سَمجھ اَسانوں لَگے توں اَسانوں سَچ دَسیا سِی، تے اس اُتے تِرے شہادت سَاڈی
  5,114,مَریم جائے عیسٰی مُڑ اِیہہ دُعا مَنگی،اے رَب سَاڈے توں اَساں وَل گَھل اَسمانوں کھاوِن جِس توں سَاڈی عید ہوجَاوے،اگَلے پِشلے(پچھلے) جیہڑے اوہناں دِی وِی ہووے۔نالے اِک نشانی ہووے تیرے وَلوں،توں دے رزق اَسانوں،بے شک توں اِی رَازق، سبَھناں توں وَدھ کے(بہترین رازق اے)
  5,115,اللہ نے اس تے فرمایا،میں تہاڈے وَل آ اس نوں گھَلن ولا،مُڑ جس نے ناشکری کیتی مار اجیہی(ایسی)دیساں جو کِسی نوں مِلسی ناہیں دُنیا اَندر
  5,116,تے جَد اَللہ عیسٰی بن مریم نُوں کہسی ،کی لوکاں نُوں توں اِس پاسے لایا ،جے مینوں تے ماں میری نوں مَعبودبناؤ، چھَڈ کے اَللہ تائیں،اوہ آکھے دَا تَسبیحاں دے لائق توں ایں ، میں کِکَن(کس طرح) اوہ کہہ سَکدا سَاں جیہڑی مینوں زیب ناہ دیوے،تے جے اِیہہ کہیا میں ہوسی،تینوں وِی مَعلوم اِی ہوسی، توں تاں میرے دِل دِیاں جانیں میں ناہ تیرے اَندر دِی دَا جانو ہے واں،توں ایں توں ایں کُل غیباں دَا جانن والا
  5,117,میں کہیا اوہناں نُوں اوہوا اَمر (حکم ) تیرا جو مینوں ہویا یَعنی کَرو عِبادت اَللہ دِی اِی جیہڑا رَب تہاڈا تے جَدتیک انِہاں وِچ ہے سَاں میں ،پہرہ وِی اِس دا دِتّا پَر جَد میرا ویلا پورا توں کَر دِتّا۔توں آپوںسِی کیڑ(نگرانی) اوہناں دِی رَکھن والا ایں(ہے ) توں ہر شے نوں تَکدا رہنے والا(نگران)
  5,118,اِہناں نُوں جے ہُن عَذابے پانا چاہیں،اوہ بَندے نیں تیرے،تے جے کَریں مَعاف اِہناں نوں،تیرے اَپنے ہَتھ وَس ہے وے(تیرے اختیار وچ اے)۔ہَر کَم دی توں حِکمت جانیں
  5,119,مُڑ اَللہ فَرماسی سَچیاں نُوں ایں سَچ تے پہرا دینے پاروں اَج لَبھتاں نیں جَنتاں اوہناںواہتے ہوسَن کول جِنہاں دے وَگدے پانی،دائم اوہناں دے وِچ رہسن' اوہناں اُتے رَب رَاضی تےرَب اُتے اوہ رَاضی، اے بَڑی ای وَڈّی بامرادی (کامیابی)ہے وے
  5,120,اَسماناں تے، دَھرتئ تے ، تے جو کجُھ دوآں دے وِچکارا ے سَب تے حُکم خُدا دا چَلدا ،اوہ قادر ہر شے دے اُتے
  6,1,حَمد اَللہ دِی کَرنی پھَبدی جِس دھرتی اَسمان بنائے ،اَتے انھیرے چانَنْ (اندھیر تے روشنی) ،کافر لوکی مُڑ وِی اَپنے رَب دے سَانویں(ہمسر) دُوجڑیاں(دوسریاں ) نُوں گِن دے(ٹھیراندے نیں)
  6,2,اوہوا اے جِس مِٹّی وِچوں ہے تہانوں پیدا کیتا تے ہر اِک دَا ویلا اوس نے مِتھیا ہویا(مدت مقررکیتی ہوئی) ہَور اِک ویلا وِی اوس نے مِتھیا ہویا ہے وے ، مُڑ وِی شک نا ہ جان تہاڈے
  6,3,دَھرتی تے اَسماناں َاندر اَللہ ای اے جیہڑا جانے چھُپت (چھُپی گَلاں )،اَچھُپت(کھُلی گَلاں) تہاڈی ساری، نالے کَسَب(عمل) تُہاڈے
  6,4,اَپنے رَب دی آیت کیہڑی اوس دِیاں آیاتاں وِچوں آئی ،مُونھ ناہ جِس توں اوہناں موڑے
  6,5,ہُن اوہناں کول ایہہ حق آیا تے اس بارے وِی اوہناں دَا اوہوا چَالا(اوہی سلوک)،پَر اوہ جِس نوں چَگھ رہے نیں(مذاق سمجھدے نیں) اِس دَا اِک حقیقت ہونا اِک دِن کھُل جاسِی
  6,6,تَکیا ناہ نیں اَساں اوہناں توں پہلاں ہوئے کِنّے مَار مُکائے(کتنے ہلاک کیتے)،جِویں (جس طرح) اوہناں دِی ٹُوہر بنائی سِی(اقتدار دِتا سی)دُنیا تے اونی(اتنی) اَجے(ابھی) تہاڈی اَساں بنائی ناہیں، اوہناں اُتّے اَساں وَسائے جَھڑیاں بَدَّل(خوب بارش کیتی)، نَدیاں نالے کول وَگائے(چلائے) ،پَر اوہناں دِی اَت چاہی توں (گناہواں توں)بےٹُہرا (تباہ تے ذلیل) اوہناں نوں کیتا،تے دُوجڑیاں (دوسراں )دے سِر پَگ(پگڑی) رکھ دِتّی
  6,7,کاغَذ اُتّے لِکھی وِی جے نازل اَسی کِتاب کَریندے،تے اوہ ہَتھیں ٹوہ وِی لیندے(ہَتھ نال چھُو وِی لیندے)تاں وِی اِیہہ اِنکاری کہندے اِیہہ تاں گَل بھچلاوے والی(جادو اے)
  6,8,اوہ کہندے نیں اِس دے وَل آخر فَرشتہ کیوں ناہ آیا،جے آ جاندا کَدے فَرشتہ ،تاں گَل ساری مُکی ہوندی(فیصلہ ہو جاندا) تے ناہ مُہلت ایہہ مِل سَکدی
  6,9,جے فَرشتے نُوں پیغمبر کَر کے گھَلدے، شَکل اِس دِی وِی ہونی سِی مَردانی،تے اَج والا فیر بھُلیکا(شبہ) رہنا ہے سِی اوہناں وَاہتے
  6,10,تیرے نالوں پہلاں دے پیغمبراں نُوں اِیہناں چَگھیا،(مذاق اُڑایا) پَر جِس نُوں چَگھدے رہے سِی،چَگھن والے اوسے گَل دِی سَٹ (زد) وِ چ آئے
  6,11,کہہ جَگ (زمین)تے ٹُر پھِر کے ویکھو ،حال ہویا کی جھُٹھیالاں دَا (جھُٹلان والیاں دا)
  6,12,پُچھ اَسماناں تے دَھرتی دِی ہَر شے کِس دِی، کہہ اَللہ دی، شیوَا اوس نے رحمت بھَریا ،رَکھیا ہویا، اونج اوس روز قیامت ، کَٹھیاں (جمع کرنا) ہے تہانوں سَب نُوں کَرنا، اس دے بارے شَک ناہ کوئی،اَپنیاں(اپنی) جاناں جِنہاں خَسارے وِچ رَکھیاں ، اوہ ناہ مَنسَن
  6,13,اوسے دَے وَس رات دِہاڑ اَندر سُکھ پانے والا جیہڑ، تے اوہ سَب دِی سُننے والا ،جانَنْ والا
  6,14,کہہ دے کِو یں بنَاوَاں اَللہ نُوں چھَڈ کے ،کِسے ہَور، نوں سائیں،جیہڑا سرجنہار(خالق) اَسماناں تے دَھرتی دَا۔ رِزقاوے(رزق دیوے) رِزقِیوے ناہیں (رزق لیوے ناہ) کہہ دے ایوا (ایہی ( اَمر(حکم ) ہے مینوں جے میں پہلاں سِر سَٹ ہَووَاں(سِرِ جھُکاوَن والا) تے ناہ مُشرک لوکاں وِچوں تھِیواں(ٓشامل ہوواں)
  6,15,کہہ دے ڈَرنا جے میں نافرمانی کِیتی، وَڈے دِن سزائیں پَاسَاں
  6,16,جو سَزاؤں اوس دِن بَچیا ، اُس تے اوہنے رحمت کیتی ، اِس توں وَڈِّی بامرادی کی ہو سَکدی اے
  6,17,تے جے اَللہ تینوں کوئی تَنگی دیوے ،کون اوہ ٹالے،اُس دے باجھوں(اس دے سوا)۔تے جے سَوکھا سَاہ کَرے(بھلائی کرے)،اوہ کَر سَکدا اے،اوہ ہَر کَم تے قادر ہے وے
  6,18,اِس دے بَندے اُس دے وَس نیں(اختیار وچ نیں) اوہ حَکیم خَبیر(باخبر ) اے
  6,19,پُچھ گَواہی سَب توں وَڈِّی کِس دی، دَس گواہ تہاڈے میرے وِچ اَللہ اے تے وَحی اوسے اِی قرآن مِرے تے کیتا،تاں جے کَن تہاڈے کھُولا اِس دِی رَاہیں، تے ہَر اوس دے۔ جِس تائیں(تک) اے قُرآن اَپڑے(پہنچے)۔کی گَواہی دے سَکدے او ہَور کوئی وِی ہے مَعبود اَللہ دَا سیری(شریک)۔میں تاں اِیہہ ناہ کہساں، میرا پلّہ(دامن ) پاک تہاڈے شِرکوں
  6,20,اَساں کِتاب جِنہاں نُوں دِتِّی اوس نوں اَپنے جَمیاں وَانگ پَچھانَن، تے اوہوا ناہ مَنَّن اُس نوں اَپنے واہتے گھَاٹ (خسارہ )جِنہاں نے بِیجی(بویا)
  6,21,اِس توںَودھ کے ظَالم کیہڑا ،بہُتان خُدا تے بَدھا(لایا) یاں اُس دِی آیات اِس نے جھُٹھیائیاں(جھوٹی سمجھی)،بےشک ظُلمی نئیں فَلاحے پانے
  6,22,جَد اِکٹھا کَرساں تے مُشرک لوکوں توں پُچھساں ،کِتھے اوہ شریک تہاڈے ہے سِی جِنہاں دا ، زعم تہانوں، عُذر اوہناں دَا ،اِک ناہ چَلسِی
  6,23,آڈ (جھُوٹ بولن دے )اِس توں جے آکھن قسَم خُدایا تیری اَسی ناہ مُشرک ہے سِی
  6,24,وَیکھ کِکَن(کیسے) اپنی آکھی توں ہُن پھِردے،اوہناں دی سب کوڑ اُساری (جھوٹھے معبود ) گھُرل(گم ) ہو وَنجنی(ہو جانی)
  6,25,اوہناں وِچ اِی گَل تِری کَن لا کے سُننے والے پر اوہناں دے اَسا ں دِلاں تے پَردے چاہڑے(ڈال دِتے ) تے اوہ سَمجھن ناہیں اِس نوں ،اوہناں دے کَنّاں وِچ جَپھے،میری ہر نشانی نوں وی، تَک لینے تے اوہ ناہ مَنسَن اوہناں تائیں اِیتھے تک جے، نا ل تِرے اوہ بحثن آکے،اوہ کافر ایہہ آکھن، ایہہ تاں، اوہوا پہلےقِصے
  6,26,لوکاں نوں وِی اس توں رَوکَن تے آپوں وی اِس توں نَسَّن(دوڑن)،اَپنا اِی نُقصان کَرن اوہ ،ایہہ ناہ سَمجھن
  6,27,توں تَصَّور کَر اوہ ویلا ،جَد وں کھَلوسَن اَگ دے دَندے ،تے ایہہ کہسن، کَدے پِشاں نُوں پَرتن ہووے(دُنیا وِچ واپسی ہووے)،اپنے رَب دِی آگاہیاں جھُٹھلائیے ناہیں تے ہوجائیے باایماناں وِچوں
  6,28,کیوں جے ہُن اوہ گھُنڈ چکَیوے (پردے اُٹھ گئے)پہلاں جیہڑے اوہناں نے سِی کیتے ہوئے پَر جے اِیہہ پَرتیون(پلٹن)،اوہوا ٹھاکے(منع) کَم کَرن دے، اوہ گَل توں پھِرجانے والے،
  6,29,اوہ کہندے نیں دُنیا تَک اِی ہے حیَاتی ،مُڑ کِس اُٹھنا
  6,30,توں تَصوَر کَراوہ ویلا،جَدوں کھَلوسَن رَب دے اَگے،اوہ پُچھے دا ،کی ا یہہ اُٹھ حقیقت ناہیں، تے بول اُٹھسَن اَپنے رَب دِی قَسم اَسانوں اِیہہ حقیقت ہے وے،رَب فرماسی اَپنے اِنکاراں دے پاروں ،اَج عَذاب اِیہہ چَکھو
  6,31,جھو ٹھ جِنہاں نے ،میل (ملاقات) اَللہ دَا جاتا(سمجھیا)ہے سی اوہ گھَاٹے وِچ ہوسِن جَد اوہ ویلا آجائے دَا اَچن چیتی(اچانک)اوہ آکھن دے تَلیاں مَلدے کِڈا بھِیڑا سَاتھوں اِس دے بارے ہویا، بھَار اَپنے اوہ کَنڈاں اُتے چائے ہوسَن(اپنی پٹھ تے بوجھ چکیا ہوسی( تے کِڈا اِی بھِیڑا اوہ بھَار چائے ہوسَن
  6,32,ایہہ جَگ جیون مَن پرچاوا،چھیکڑ واسا اوہناں واہتے چَنگا جھَاک (جھاکا) جِنہاں وِچ رَب دی،کیوں ناہ سَمجھ تہانوں آوے
  6,33,سار (خبر ) اَسانوں،لوکاں دِی گَل بات کرے اَندوہی (رنجیدہ)تینوں ، او اِی اِنکار تیرا ناہ کَردے اوہ ظَالم تے اَللہ دِی آگاہیاں ے اِنکاری ہے نیں
  6,34,تیتھوں پہلاں دے پیغمبراں دِی اوہناں نے ناہ مَنّی، صَبر اوہناں وی کیتا سِی جھُٹھیار اوہناں دِی اُتے تے دُکھیاوَن اُتےآخر بوہڑ(مدد) اَساڈی ہوئی ،کون اَللہ دے وعدے ٹالے،پیغمبراں دِی وَرتی وچوں(نال جو پیش آیا)تیرے وَل وِی کجھ اَپڑیوی(کوئی خبر پہنچی)
  6,35,کَر نا ہ اوہناں دِی مُونھ پھیری، توں دِل اَپنا بھَاری،توںزویں ( زَمین) وِچ جے سُرنگ وِی لاکے یاں اَسمانوں پوڑھی دَھر کے لے نشانی کوئی آویں اوہناں واہتے اے لاحاصَل،جے منظور خُدا نوں ہوندا اوہ اِک راہے سَب نوں پاند، ہو ناہ ایس حقیقت توں بےخبرے لوکاں وِچوں
  6,36,گَل اوہوا اِی مَنّن جیہڑے َکنّاں دے وِچ پاوَن،رہ گئے ہٹل(ناہ مننن والے مُردے وانگوں)،رَب اوہناں نوں کُھلّی چھُٹی دِتّی ہوئی،اوہ اوس اَگے آخر پیش ہووَن دے
  6,37,اِعتراض اوہنا نوں اِیہہ وے ،کیوں ناہ اِس دےرب نَشانی اِس دے وَل اُتاری،کہہ دے بےشک اَللہ اِس تے قادر ہے وے نازل کرے نشانی کوئی، پَر چَوکھے انجام ناہ اِس دا جانن والے(اکثریت نادانی وچ مبتلا نیں)
  6,38,دَھرتی اُتے دے چَوپائے (زمین تے چلن والے جانور)اَتے پَکھیرو(پرندے) پَنکھاں دے نال اُڈَن والے ،وانگ تہاڈے ای ٹولے نیں،اوہناں دِی وِی لِکھی اَند ر(تقدیر)کَسَر ناہ کوئی رَکھی،(تے کی اِیہہہ نشانی تھوڑی اے) تے ہَر اِک نیں(جیہڑے نشانی مَنگدے) رَب اپنے وَل اوڑک (اَخیر)جانا
  6,39,تے آیات اَساڈی نوں ناہ گولن والے(ناہ َمّنن والے) بولے(بہرے)،گونگے وِچ ہَنھیرے(تاریکی وِچ)جِس نوں اَللہ چاہے کرے کراہے(بھَٹکا دیوے) جس نوں چاہے سدھے راہ تے پائے
  6,40,دَس اوہنا ں نوں اَللہ وَلّوں جَد وں مُصیبت آپیندی جےیا فیر وَقت اَخیری آوے،غور کر وخاں ،کیوں ناہ نام لَباں (ہونٹاں )تے آوے بِن اللہ دے ،جے وے سَچ تہاڈے پلّے
  6,41,اوسے نوں اِی سَچ تاں ایہہ وے،تُسی پُکارو ،تے اوہ ٹالے جو تُس چاہو جے اوہ چاہے،تَدوں (ایس موقعے تے)شَریک بنانے بھُلو
  6,42,اَساں تِرے توں پہلاں دے وِی لوکاں وَل پیغمبر گھَلے تے لوکاں نوں بیماری تے تَنگ دَستی دے رَگڑے دِتّے،تاں جے عجَزی ہووَن
  6,43,کیوں ناہ اوہناں زاری(عاجزی)کیتی جَد اَساں سی رَگڑا دِتّا،دِل اوہناں دے پَتھر ہوئے تے شیطاںسَجا کے دَسے اوہناں نوں کَرتوت اوہناں دے
  6,44,مُڑ جَد مَت اَساڈی بھُلے،سَاڈے وَلّوں دَر(دروازے)ہر شے دے اوہناں اُتے حالاں کھُلّے،پھِٹ گئے سی سَاڈی رَجواں (زیادہ) دِتّاکھا کے،کیتی پَکڑ اَچانک اِنج دِی ،واہ (تدبیر) اوہناں دَا ناہ کوئی چلّے
  6,45,جَڑ وَڈھیوی(جڑ کٹ دِتّی) اوہناں دِی جِن (جنہاں) ظُلم کمایا،حَمد اَللہ دِی اِی کرنی پھَبدی، جیہڑا رَب اے سَب دا
  6,46,کہہ کَدے ایہہ سوچ آئی جے کھس لوے (چھین لے) جے سُن(سُننا)تَک(ویکھنا) اللہ،مہر دِلاں دے اُتے لاوے،کیہڑا باجھ(سوا) خدا دے جیہڑا اوہ دیوےپرتا(واپس)تہانوں،ویکھ اَساں کنج اَپنیاں گلاں موڑ پرت کے دسدے جائیے تے اوہ مُڑ وِی مونھ بھواندیں(منہ موڑدے نیں)
  6,47,کہہ َکدے اِیہہ سوچ آئی جے اچن چیت(اچانک) عَذاب الٰہی آگھیرےیا لَلکر کے(علانیہ)،ظُلمی لوکاں اِی ہَلاکت دے وِچ پینا
  6,48,اَساںہمیش پیغمبر گھَلےڈَھارسئے وِی( ڈھارس دین والےوِی ) دَبکاؤو وِی(دَبکا لان والے وِی ) تے جِن مَنیا (ایمان لیائے)تے مُڑ کیتی آپ سَواری(طرزِعمل ٹھیک کیتا)،خوف کوئی ناہ اوہناں تائیں ناہ دِلگیری
  6,49,پَر جِنہاں آیات اَساڈی نوں جھُٹھیایا اپَنی نافرنی پاروں ہے عَذاب اوہناں نُوں ٹوہنا
  6,50,کہہ دے میں ناہ کہناں میرے کول خزانے ہین خدائی،ناہ میں غیباں جانن والا ،ناہ میں کہناں میں فَرشتہ،میں تاں بس اوسے تے چَلاّں ،جو میرے تے نازل ہویا، ہا ں اِیہہ دَس نیں، اَ نّھا (اندھا) اَتے سَجاکھا(اَکھاں والا) اِک جیہا ناہ ہووے،کیوں ناہ سَوچو
  6,51,اس دے راہیں توں دَبکا اوہناں نُوں ،جیہڑے خوف اِیہہ رَکھدے اللہ اَگے پیش ہووَن دا تےناہ اَللہ توں اَڈ (سوا)کوئی حامی ہوسی یاں شَفاعت کرنے والا،ہو سَکدا اےوَاگاں مَنّن (خُدا تَرسی دی راہ اختیار کَرن)
  6,52,اوہناں نُوں ناہ پَراں(دور) ہَٹا توں جیہڑے رَب رَب کَرنے والے رَات ،دِہاڑے،تے اوہدی خوشنودی مَنگن،اوہناں دا ناہ لیکھا تیرے کھاتے ناہ ایں اوہناں دے کھاتے وچ تیرا لیکھا ، جے ہَٹاسیں پَراں(دُور کَرسَوں) اوہناں نوں ،ناانصافاں وِچوں ہَوسیں
  6,53,کجُھ نوں کجُھ دی راہیں وِچ َازمائیش وی ہاں پاندے ،تاں جے اوس کھٹَالی وِچوں نِکلن لوکی آکھن،ایہہ اوہ وَل نیں سَاڈے وِچوں ،کَرم جِنا ں تے اَللہ کیتا،کی اَللہ نُوں خَبر ناہ چَوکھی ،اس دے شَاکر کیہڑے
  6,54,تیرے کول جَدوں وِی آوَن ساڈی دَسّاں مَنّن والے(ساڈی آیات تے ایمان لیان والے)۔جی آیاں توں آخ اوہناں نُوں،رحم بھَریا شیوا رَب تیرے دَا ہے وے،ایسے کرکے بھُل بھُلیکھے بند ہ کوئی ،کوہجا چالا (بُرا کم) چَل اِی بیٹھے ، پَر تائب ہوجائے تے سُدھرِیوے اُس تو ں پِچھے(سُدھرِ جاوے اوس توں بعد)ا وہدے واہتے اوہ غفور رَحیم اے بے شک
  6,55,اِنج اَسی اپنی آیات کھول سُنائیے، تاں جے جُرمی لوکاں(مجرم لوکاں) دی راہ صاف نظر آجاوے
  6,56,کہہ دے ہے منَاعی(منع کیتا) مینوں۔میں اوہنا ں دِی کَراں عِبادت رَب نوں چھَڈ کے ،تُسی پُکارنہار جِنہاں دے،کہہ دے میں تہاڈے شوقاں دے ناہ پچِھے لَگّن والا،ا ِنج کراں گمراہ ہو جاواں، تے ناہ راہ لَبھیاں چوں رہساں(سدہی راہ تے چلن والیاں وچ ناہ رہساں)
  6,57,کہہ دے اِیہہ قُرآن دَلیل پَکیری(پکی) مینوں رَب نے دِتُی،تے اوس نوں ای جھُٹھیایا جے،سوڑ (جلدی) تہانوں جِس دِی، اوہ وَس(اختیار) میرے ناہیں،حُکم خُدا دے ہَتھ اَپنے وِچ، اوہ حق آکھن والا ہے وے،ہے نیائیں(فیصلہ کرن والا) وی اوہ چَنگا، سَبھناں نالوں
  6,58,کہہ دے جِس دِی سوڑ تہانوں اوہ جے میرے ہَتھ وِچ ہوندی،گَل تہاڈے میرے وِچ وِی مکی ہوندی(مُک جاندی) تے اللہ ای بہتر جانے،ظلمی لوکاں نال ،کِویں گَل اوس مُکانی(معاملہ کنج کرنا)
  6,59,غیب دیا ں نیںُ کنجیاں کول اوسے دے۔اوہناں دَا عِلم اوسے نوں ایں،اوہوا جَل تَھل (بحر وبر )دِی گَل جانے،اوس دے عِلموں باجھ (بغیر) ،ناہ پَتہ ڈِکدا(گردا) کوئی،مِٹّی دے ڈِھڈ وِچ دَا دانہ،سُکّا گِلا جو کجھ وِی اے،اوہ کِتاب مُبین اَندر اے
  6,60,راتین مویاں(روح قَبض کردا) اوہ تہانوں کَردا،اوہ جانے تُسی دِہاڑی جو کجھ کیتا،دِنے (دِن وچ) تہانوں کھُلیاں چھَڈی رَکھدا ہے وےمِتھی ہوئی مُہلت تائیں تے اوسے اِی وَل تہاڈی پَرت(واپسی) ہونی جے،فیر اوہ تہانوں دَسّے دا جو وِی کاراں کَردے رہے او
  6,61,او غالب اے،اُس دے وَس وچ اُس دے بَندے،تے نِگران تہاڈے تے اوہ لائی رَکھے،جَد تہاڈے وِچون موت کِسے تے آوےاوہ فرشتے سَاڈڑیاں دی راہیں پورا ہوندا ہے وے(اوہ فرشتے جان کڈلیندے نیں)، تے اوہ کَرن کھُنجائی(کوتاہی) نائیں
  6,62,فیر اَللہ دے وَل پَرتائے جاندے نیں اوہ،جو اہناں دا سَچا سائیں(حقیقی آقا)،ہاںحُکم اوسے دا اِی چَلدا،تے، اوہ چھیتل(جلدی) کھاتے میلن(حساب کرن) وچ ہے وے بہت زیادہ(تیزاے)
  6,63,کون بَچاندا پُچھ تُساں نوں جَل تَھل(خشکی تے پانی) دی اوکڑ(مصیبت) دےاَندر،گِڑگِڑاندے اوسے دے اَگے کرو دُعائیں،اَندرو اَندر وِی اے آکھو اِس توں جے بچایا اوس نے، ہوسَاں شُکرگزاراں وِچوں
  6,64,کہہ اِللہ اِی اِس توں وِی تے ہَر تَکلیفوں ہے نَجاتاں دیوَن والا،فیر اوس دے تُسی شَریک بنائے پھِردے
  6,65,کہہ دے اِس تے اوہ قادر اے،گھَلّےہے عَذاب اَسمانوں یاں تہاڈے پیراں بیٹھوں یاں تہانوں پاڑے تے مُڑ اِک دوجے دا ڈاہڈ پنے (طاقت)نُوں چَکھو،ویکھو کِنج اَساں پھیر پھِرا کے نکُتے لوکاں اَگے رَکھدے تاں جے اوہ سَمجھن
  6,66,قوم تِری اِی نَابر (اِنکاری) اس توں ہون کھَلوتی،حلاں ایہہ تاں حق اے،کہہ دے میں وَکیل تہاڈا ناہیں
  6,67,ہر گل دا اے وَقت مُقرر،لاہد(خبر) تہانوں جھِب(عنقریب) ہو جاسِی
  6,68,توں جَد ویکھیں لوک آیات اَساڈی نال حُجتاں کَردے،کَر کِناراں اوہناں کولوں جَد تائیں ناہ اوہ رَویہ اَپنا بَدلن اس دے بارے،تے جے کَر شیطان بھُلا دے (نصیحت اساڈی) ،یاد آوَن تے اوہناں ظَالم لوکاں کولوں اُٹھ جا
  6,69,تَقوے والے لوکاں اُتے بھَار ناہ اِنج دے لوکاں دی کیتی دا، نَصیحت کَرنی بَن دِی ،شاید اوہ ہدایت پاوَن
  6,70,چھَڈ اوہناں نوں جیہڑے دین اپنے نوں گِن دے نیں مَشغولہ تے جَگ جیون(دنیا دی زندگی) پچھے بھُلے، اوہناں نوں توں دیہہ قُرآنی ایہہ نَصیحت جے ہر اِک نے اپنا کیتا پانا،جِند کِسے دا ناہ کوئی اَللہ باجھوں حامی ناہ کوئی سَفارش کرَنے والا،جے عِوضانے دی گَل ٹورے کِسے قسم دی وِی،عِوضا نہ لیا ناہ جاسی اِس دے کولوں ، ایہہ لوکی تے کرتوتاں توں ہین شکنجے جانے،اوہناں واہتے کھَولر پانی تےعذاب دُکھادا ں ہوسی نابر(انکار حق)ہونے پاروں
  6,71,پُچھ اوہناں توں کی اَللہ نوں چھَڈ کے اوہناں دا سمرن کرئیے(اوہناں نوں پکارئیے )جیہڑے ناہ تے نفع پچاون ناہ نقصان پچاون جوگے ،تے جَد اللہ راہے سانوں پا دِتّا اے ،کیوں اَسی پچھڑوئیں ٹُرئیے(اُلٹے پیر پھر ئیے)،اوس دے وَانگوں جِسن (جس نوں) بڈاوے(شیطان) بھُلے پاوَن (بھٹکا دیوے)جنگل بیلےتے سنگی پئے وَاجاں(آوازاں دین) مارن ،ایدھر آ توں سِدھی واٹے(راہے)،کہہ دے سِدھی راہ تے راہ رَباّنی ہے وے،حُکم اَسانوں، کُل عَالم دے رَب اَگے ای سیس نوائیے(سِر جھُکا ئیے )
  6,72,پکَے اَسی نمازی بنئیے(بن جائیے) تے اوس کولوں دبئیے(دب جائیے)،اوہوا اِی ،اے اُٹھ کے جِس دے وَل جانا ایں
  6,73,اِیہہ اسَمان اِیہہ دَھرتی اوسے بَرحق پیدا کیتے تے جَد کہسی ہو جا ،تے ہو جاسی بَر حق اوس دا کہنا، اوسے دِی ای اوس دِہاڑے چَلسی، جَد قرنائے پھُوک وَجیسی(صورپھونکیا جاسی)،عِلم ہے اوس نُوں دِس (ظاہری)اَن دِس د َا (پوشیدہ) اوہ حَکیم خَبیر اے
  6,74,آذَر باپ اَپنے نُوں جَد اِبراہیم کہیا جِس ویلے،توں معبود بُتاں نوں مَنّیا ،کاہنوں (کیوں ) توں تے قوم تِری وِی جاپے گُمراہی وِچ ظَاہرم ظَاہرا(کھلی گمراہی وِچ پے گئے اوو)
  6,75,اِنجے اَساں زَمینی تے اسَمانی شاہی دے کجُھ جلَوے اوس نوں دَسّے(وکھائے) تاں جے او ہ پَک مَنّن والے لوکاں وِچوں تھِیوے
  6,76,تے جَد رات پئی تے اُس اُتے اوس اِک تارا تَکیا، د ِل وچ آیا اِیہہ رَب میرا، جَد اوہ ڈُبیا (غروب ہویا )، آکھن لَگُا ڈُبن ہاراں نال تعلق میرا کَاہدا
  6,77,چَن(چاند) چَمکدا مُڑ اوس تکیا ،تے جاتا (سمجھیا) اِیہہ جے یہہ رَب میرا، اوہ ڈُبّا (غروب ہویا)تے اوس کہیا جے مہنوں ،رَب میرا نا ہ رَستہ دَسّے تے میں گُمراہواں دے سَنگ رَلساں(شامل ہوساں)
  6,78,فیر چَمکدار سُورَج تَکیا ۔تے اس جاتا، اِیہہ رَب میرا، اِیہہ سَبھناں توں وڈّا ، اوہ ڈُبّا ،آکھن لَگّا لوکو میں ناہ سِیری شرک تہاڈے دے وچ اُکّا
  6,79,میں مُونھ اَپنا اوس وَل کیتا، جِسن(جس نے) بنائے نے اَسمان سَنے دَھرتی ،میں اِک واگا ، ناہ مشرک لوکاں وِچوں
  6,80,قوم اوہدی، نال اس دے کُھڑبی(جھگڑی) اوس کہیا کی کُھڑبو میرے نال اَللہ توں ، حالاں اوس رَاہ مینوں پایا،میں خوف ناہ کھَاواں اوہنا ں توں، جیہڑے اُس دے سیری دَسّو ، رَبّوں جے کجھ آن بنے تاں، گَل وَکھری اے،رَب میرے دَا عَلم ہر شے تے چھایا ہویا،کی ناہ مَت (سمجھ) تہانوں آسی
  6,81,کِویں ڈرا میں اوہناں توں،تُسی جِنہاں دی سِیر بناؤ نال اَللہ دے جَد ناہ خوف تہانوں اَللہ نال شریک رَلالینے تے،ناہ پروا نہ کوئی نازل ہے جِنہاں دے بارے ہویا وَل تہاڈے ، تے ہُن دَسّو، ساڈے دوآں وچوں سَوکھا اِطمینانی ہو سَکدا اے کیہڑا ،جے کر عِلم تہانوں ہے وے
  6,82,جیہڑے وَل ایمان لیاوَن تے ناہ کِھچڑی(شامل) نال ظُلم ( شرک) دے اِس نُوں کَردے،اِطمینان نصیب اوہناں دے ،اوہ اِی سِدھے راہ تے
  6,83,اپنی اے دلیل اَساں سی ابراہیم تِئیں (نوں)سمَجھائی لوکاں دِی گَل ڈَکّن(روکن) واہتے،جس دے چاہئیے درجے اَسی وَدھاندے جائیے، رَب حکیم علیم ترا اے شک ناہ کوئی
  6,84,فیر اَسا ں اسحاقؐ ،یعقوب ؐعطا کیتے سَن اُس نوں ،اوہناں نوں وِی راہے پایا،جس تے پہلاں ہے سی نوحؐ نوں پایا،تے اوسے دِی نَسلوں ای داؤد ؐاَتے سلیمانؐ اَتے ایوب ؐتے یوسف ؐ،موسٰی ؐتے ہارونؐ ہوراں نوں،انِج اِسی احسان شناساں دَا مُل پائیے (بدلہ دیندے آں)
  6,85,ذکریا ؐتے یحیٰیؐ تے الیاسؐ تئیں وِی سارے اِی سَن صَالح،
  6,86,اِسماعیلؐ تے یسعؐ، یونسؐ، لوط ؐتے سَبھناں نوں کُل جَگ اُتے اَساں فَضیلت دِتّی،
  6,87,اوہناں دے وَڈیاں دے وِچوں،جَمیاںوچوں ،بھاَئیاں وِچوں (راہ ایسے ای پائے)،اَساں اوہناں نوں چون بنایا (چُن لیا)،رَستے سِدھے لایا
  6,88,ایہہ ہدایت رَبی ہے وے اَپنے بَندیاں وِچوں جِس نوں چاہے دیوے،تے جے اوبھی سیری مَندے(شرک کردے)،کیتی کُتری ،کھُو پے جاندی(کیتا کرایا غارت ہو جاندا)
  6,89,ایہہ اوہ وَل سی(لوک سن)، اَساں کِتاب جِنہاں نُوں سَنے (ساتھ)حکومت اَتے نَبوت دِتّی،تے ہُن جے اِیہہ لوکی اس دے لینے توں اِنکاری ہے نیں،ہور اَجیہے لوکاں نوں اِیہہ سَونپ دیاں دے جو اِس دے ناہ نابر (منکر)ہوسَن
  6,90,اوہ لوکی سَن اَللہ راہ جنہاں نوں پایا،اوہناں دے ای طور طریقے نوں اپَنا توں(اوسے راہ تے چل)،کہہ ،ناہ اَجر تہاڈے کولوں اِس دَا مَنگاں،اِیہہ تا ں اِک نَصیحت ہے کُل عَالم واہتے
  6,91,اَللہ بارے اوہناں اَندازہ جَچواں(ٹھیک) لایا ناہیں جَد اوہ آکھن اَللہ نازل بَشرتے کَردا ناہیں۔کہہ دے کِس کِتاب اُتاری سِی ،موسٰیؐ جو لے کے آیا سِی چَانن اَتے ہَدایت سِی جو لوکاں واہتے، اِسدے ٹانویں ٹانویں ٹوٹے دَسو، تے باقی دَا چَوکھا حِصہ گُم کر جاؤ اَج تہانوں عِلم ناہ جِس دَا ،سِی وَڈ وَڈیر تہاڈے وِی بھُل بیٹھے، اوس وِچ اِیہوا دَس تہانوں پائی ہے سی،تے ہُن توں ایں دَس دےاوہ اُتاری سِی اَللہ نے،تے اوہناں نوں توں چھَڈ دے ٹَامک ٹوئیاں مارن واہتے
  6,92,اِیہہ کتاب اُترین(نازل کردہ) اَساڈی بَرکت والی تے سَچیاون والی(تصدیق کران والی)،پہلاں جو کجَھ کول اوہناں دے، مَکیاں نوں(مکَے والے) تے ہَور دوآلے وَالڑیاں نوں (نالے اطراف والے) دَھمکانے،دَبکانے واہتے اوہناں نوںوِی چھیکڑ تے اِیمان جنہاں دا ،تے اِس نوں وِی مَنّن تے ناہ کھُنجن دین صَلاتاں(نمازاں ناہ چھڈن)
  6,93,تے اِس نالوں وَدھ کے بَد راہ کون ہو سَکدا اے جو بہتان خُدا تے آپوں گھَڑ کے بَنھے(لاوے)یاں وَحی اَپنے تے بِن اُترے اِی گَل کَرے اوہ،یا ں اوہ آکھے میں وی اَللہ وَرگی نازل کر سَکدا اے نازل کَرنی، اَنج دے کُوڑے(جھوٹھے) لوکاں نُوں جِس ویلے تَکسیں جان کُندن دی بے سُرتی وِچ(مرنے ویلے)اوہناں وَل فرشتے ہَتھ وَدھاندے ہوسَن(کہندے ہوئے)جِنداں(جان) کَرو حَوالے سَاڈے اَج تہانوں وَٹے (بدلے) دے وِچ اِک عذاب خواری والا پلَّے پینا، اَللہ اُتے جھُوٹھ مَڑہن(تہمت لان) دے پاروں تے آیات اَساڈی نوں ناہ کجُھ مِتھن(منن ) دے پاروں
  6,94,ہائیں اَج اَساڈے اَگے پیش ہوئے اوہ کَلّم کلّے(اَکیلے)،جکِن(جس طرح) اَکلّے جَمن(پیدائش) ویلے ہے سی،ساڈا دِتَا چھڈ آئے اوہ پچھے ،ناہ ای نال سفارش کار ای دِسدا (نظر آیندا اے) ہے وے، کل تہانوں زُعم جِنہاں دے بارے ہے سی اوہناں دَا ہے ہَتھ تہاڈے کمَاں (کم)اَندر،سانجھ تہاڈے نال اوہناں دِی ٹوٹے ہوئی، چھَڈ گئے اوہ مان تَران جنہاں دا سی جے
  6,95,اَللہ اِی اے گِٹکاں(گھٹلی) دَانے پاڑن والا، نِر جندل (مُردے)توں جِندل(زندہ) کَڈھے تے نِر جِندل(مُردے) نوں جِندل (زندہ)دے وچوں،اِیہہ جے اللہ،کِدھرے جے مونھ چائی جاؤ
  6,96,اِیہوا ، اے پوہ پھَٹالا (تاریکی توں صُبح کَڈن والا)،رات بنائی اوسے نے آرام کَرن نوں،ویلا دَسدے نیں چَن سُورج، اِیہہ تقدیر خُدائی اوس دی جو عَزیزعَلیم ایں
  6,97,تارے اوس تہاڈے واہتے ہین بنائے، تاں جے راہ اوہناں دی راہیں(ذریعے) لبَھو(ڈھونڈو) جَلاں تھَلاں ( پانی تے خشکی ) دے نھِرے (تاریکی)اَندر ،اَساں نکھیڑے (کھول)کَرکے نکُتے سمَجھائے شوق جنہاں نوں ہے جانن دا ،اوہنا ں واہتے
  6,98,اوہوا اِی اے جِسن تہانوں اِکی نَفسوں پیدا کیتا،ٹھاہر بنائی(رہن دہی تھاں)،سونپ بنائ ی(مَرن توں بعد رہن دی تھاں)پتے(نشانیاں) اَساں نیںوَکھ وَکھ کے سوچن والے لوکائی(لوکاں) نوں دَسّے﷽
  6,99,اوہوا اِی اَسماناں توں پانی جہڑا گھَلّے،اس دے نال اُگیندل کَڈی (اُگائی) اُس ہَر شےوِی اِس دے وِچوں،اِک نوں ہریاول اِی رَکھئیے ،اِک چوں دانے تِہوِاں تِہوَاں کَڈئیے،کھَجیوں(کھجور) گابھے نئیوندے گچُھے،باغ اَنگوری، زیتونی اَتے اَناری اِک دوجے نال رَلدے وِی تے ناہ رَلدے وِی پَھل نوں ویکھو ،مُڑ ویکھو اوہ جَد پَکیندے(پَکدے)،مَننے والے لوکاں واہتے نکُتے اِیہناں دے اَندر نیں
  6,100,اَللہ دے نال رَلاون جِنّ ،جِنہاں نُوں اوسے نے اِی پیدا کیتا،دِھیاں ،پُتر وی گَھَڑِیو نیں(جھوٹم جھوٹ بنا دِتے)بے سَمجھی توں،اوہ تَسبیحاں دے لائق اے تے اِہناں دے ٹیوے(جھوٹی گَلّاں) لانے توں اُچا
  6,101,اَسماناں تے دَھرتی دا اوہوا ،اوہ مُنڈھ بنَھن والا (پہلی وَاری بَناوَن والا موجد)،اُس دَا جَم (بیٹا) کِویں مُمکن ایں ، زال(شریک زندگی) ناہ جِس دِی ہووے کوئی،ہے مُخلوق اونج ہَر شے اوس دِی تے علم اوس نوں ہر اِک شے دَا
  6,102,اَللہ اِہناں صِفتاں والا ،رَب تہاڈا باجھ اُ س دے مَعبود ناہ کوئی،ہر شے دِا اوہ خَالق،سَو اوسے دِی کَرو عِبادت ،ہر اِک چیز حوالے اُس دے
  6,103,لوئیں دَرک کَرن ناہ او س دِی(نگاہ اوس دی وُسعت نوں ویکھ نئیں سَکدی) ،اوہ اَکھیاں نوں دَرکے(اوہ نگاہ نوں پا لیندا ا ے)،اوہ لَطیف خَبیر اے
  6,104,آچُکیاں نیں کول تہاڈے اَکھیاں کھولنہاراں، رَب تہاڈے وَلوں،کَم (کام)لیا جس نے اَکھیاں توں ،جان اوس دِی نے کھَٹیا(بھلا ہوا)،جس نے انھیاں وَانگ گُزاری ،اوس نے کجھ ناہ و َٹیا(کجھ نفع ناہ حاصل کیتا)، میں تہاڈے تے ناہ راکھا (پاسبان) لَگّا ہویا
  6,105,اِنج اَسی آیات اپنی مُڑ مُڑ لوکاں نُوں دَسدے ،تاں جے لوکی مَنّن،توں تے دَرس اسانوں دِتّا ہے سِی،تے جوسَوجھے(صاحب علم) ۔گَل اوہناں تے کھّلّے
  6,106,اے مُحمدؐ ۔ ٹُر اوس اُتے وَحی ترے تے جو آئی رَب ترے دے وَلوں ، ویخ (ویکھ)کوئی معبود ناہ اوس بِن۔ مُشرک لوکا ں کولوں ہو جَا لانبے(دور)
  6,107,جے اَللہ ناہ چاہندا ، اے مُشرک ناہ ہو ندے، اوہناں تے رَکھوال(پاسبان) اَساں ناہ کیتا تینوں،ناہ توں چارہ ساز اوہناں دَا
  6,108,مُشرک نام جِنہاں دے جَپدے(پکاردے)، اوہناں بارے ماڑا بول (گالی) ناہ بولو، نا سمجھی توں اِیہہ مَندیاسَن (بُری گل کہسن) اَللہ نوں کجُھ ہَو ر وَدھا کے،ہَر ٹولے دے واہتے طور طریقے اس دے ہین اَساں کھِچ والے (خوشنما)کیتے، پر ہے پرت خُدا دےوَل ای اوڑک(اخیر) سَب دی ،اوتھے سَب دے عمل اوہناں دے اوہ جتَاسی
  6,109,اوہ خدا دی وَڈیاں وَڈیاں قَسماں کھَاندے ہوئے آکھن جے اوہناں وَل خاص نشانی کوئی آوےاوہ یَقین اُس تے کرَ جاسَن،کہہ دے اَللہ دے کول نشانی تَمامی(ساریاں)،اِیہہ معلوم تہانوں ناہیں جے اوہ نشانی آ وِی جاوَن ، ایہہ ناہ مَنن
  6,110,اَساں اوہناں دے دِل ،دیدے(اَکھاں) کَر دیساں ٹُھڈے(پیران دی ٹھوکراں) کھَانے چوغے(لئی)،جِویں سَن اوہ ایمان لیاوَنوں پہلاں تے اوہناں نوں چھَڈ دیواں دے اپنی گُمراہی دے اَندر بھَمبل بھوسے کھانے واہتے
  6,111,اَسی فرشتے وِی جے اہناں وَل اُتارے ہوندے ، تے مُردے وِی نال اِہناں دے گَلّاں کَردے،دُنیا دِی ہر شے لِیا کے اوہناں دے اَگے رَکھ دیندے۔مَنن والی ناہ اوہناں دی ٹاکی ہے سی،ہاں جے رَب دِی مَرضی ہووے (تاں گَل وَکھری) اونج اوہناں چوں چَوکھے گَل ناہ گولن والے(ناہ دانائی دی گلاں کرن والے)
  6,112,اِنجے ہَر نَبی دے دُشمن ہو ندے آئے اِنسانی تے شیطانی جِنّاں چوں۔اِک دوجے تَک اوہ اَپراندے(دیندے) اُتوں پَکیاں وِچوں جھَکیاں گَلّاں ،جے ناہ ترے رَب دِی اِیہوا مَرضی ہوندی ،مول ناہ کَردے
  6,113,اوہناں نوں توں کُوڑ اَسارن واہتے چھَڈ دے،(اوہنا ں دے حال تے چھڈ دے)تاں جے دِل جھُکیون(دل مائل ہوں) اوہناں وَل اوہناں دے جیہڑے چھیکڑ(آخرت) نوں ناہ مَن دے،تے اوہ چامل چامل ہوون(ا خوشنما دھوکےتے راضی ہوون) تے اوہ کھَٹی جاوَن جو کُجھ کھَٹی جاندے
  6,114,کی میں غیر اَللہ نوں مَن دا پھِراں نیائیں(فیصلہ کرن والا) جد اُتاری اوس تہاڈے وَل کِتاب ، اوہ سَب تَفصیلاں جِس دے اَندر،تے مَعلوم اوہناں ہے وے ،کول کِتاب جِنہاں دے پہلاں، تھیں ناہ (نہ ہو) اِس کرکے توں شَکی لوکاں وِچوں
  6,115,رَب ترے دِی گَلاں مکمل سچائیو ں تےعَدلوں ،سُخن اس دے تبدیلن والا کیہڑا۔اوہ سَمیع اے اوہ عَلیم اے
  6,116,تے جے اوہناں دِی مَن ٹُرسیں (مَرضی تے چَلسی) جیہڑے دُنیا دے وِچ چَوکھے،تینوں رب دی راہوں توں اِیدھر اُودھر کَر سَن،اوہ ظنّاں دی اُنگل لَّگے(گمان دی راہ تے چلے) تے اَٹکلئیے(تے قیاس ارائیاں کردے رہندے)
  6,117,رَب ترا اِی بہتر جانے کیہڑا اِس دی راہوں ہَٹیا، اوہوا جانے سُدھ راہیاں نوں
  6,118,ویکھو کھاؤ اوس توں جِس چوں ناں (نام )اَللہ دَا پَڑھیا ہووے جے حُکم اُس دے مَن دے(تسلیم کردے)ہے او
  6,119,تے ناہ کیہڑی گَلّوں کھاؤ ، تَکبیر ہووے جِس تے آکھی،تَفصیلاً جَددَسیا ہے وے، کی حَرام تہاڈے اُتے،مَجبوری دِی حالَت وَکھری، چَوکھے لوکی مَن مَرضی کَروَاندے ہوئے دُوجَڑیاں(دوسریاں) نوں بھُلُے پاندے(گمراہ کردے)،اَللہ خوب اوہناں نوں جانے (دانستہ) جو حَداں ٹَپدے(حَد توں گزُرن والے)
  6,120,بَچو گناہوں ظاہرا بھانویں خُفیہ ہووے ،ہین گناہ کماندے جیہڑے،اِس سودے دِی وَٹک (بدلہ)) اوہناں دی جھولی پیسی
  6,121,بے تَکبیری شے ناہ کھاؤ ،نافرمانی اِیہہ بِن جاسی،تے بَد باطن لوک ضرور اے اَپنے سَنگیاں (ساتھیاں)دے سَنگ پاندے نال ترے اوہ رٹّا پاون (جھگڑا کرن )،جے توں اوہنان دی منّی(گل قبول کیتی) تے مُشرک تھِیسیں(ہوجاسی)
  6,122,کل تائیں(تک) بے بُود (وجود ناہ سی )سی جیہڑا،مُڑ اَساں جَوَایاں اُس نوں (زندگی بخشی)،اوہدے واہتے چانن کیتا، جِس دِی رَاہیں لوکاں وِچ اوہ ٹُردا ، پھِردا ، اس وَرگا ناہ گِنیا جاسی، جیہڑا وِچ ہَنھرے ہے وے تے ہُن اس دَا عاَدی ہویا ، کَفروناں دے واہتے اِنجےعَمل اوہناں دے مَن کھَچِویں (خوشمنا)کیتے ہوئے نیں
  6,123,تے اِنجے اِی وَستی وَستی(بستی بستی) رَجھ کے بھِیڑے(وڈے مجرم) لوکی ہے نیں اوہ فَساد مَچاندے رہندے ، پَر اوہ اِنج فَساد مَچا کے اَپنا اِی کجَھ پئے گواوَن،سَمجھ ناہ اوہناں نوں اِس گَل دِی
  6,124,گل اَساڈی کول اوہناں دے جَد کوئی اَ پڑے(آوے) آکھن مَنسَاں ناہ جَد تائیں، ساڈے وَل (طرف) وِی اِنج دِی آوے جِکن اَللہ دے پیغمبر وَل آئی،اَللہ بہتر جانے کِس توں اوس رَسالت دَا کَم لینا تے کِنج لینا ،تے اے جُرمی جھَبدے (جلدی ) اَپنی کیتی پاسَن،رَبّوں اِک عَذاب شَدید اوہ تَکسن اَپنی بَد اَندیشی پاروں
  6,125,اِیہہ اَللہ دے اپنے کَم نیں ،رَاہے پانا تے اِسلام لئی دَر(دروازے)دِل دے کھول کِسے تے دینے تے تھَڑکانا (ہٹانا) چاہے،جِس نوں وِی اوہ رَاہوں، ڈاہڈا بھیڑے سینہ اُس دا ، (سینہ تنگ ہونا)جویں اُچائی چڑھدے نوں ساہ چُڑھیا ہووے،الَلہ اِنج عَذابے پائےاوہناں نوں جو مَنّن ناہیں
  6,126,رَب ترے دَا سِدھا رَستہ اِیہوا ہے وے،مَت مَن (نصیحت قبول کرن والے) لوکاں واہتے ،گَلّاں تَفصیلی نیں دَسیاں(واضح کیتاں)
  6,127,اوہناں واہتے،اوہناں دے رَب دے کول اے تھاں اَمن والی تے اوہ اوہناں دَا بیلی(سرپرست) ہوسِی اوہناں دے عَملاں دے پاروں
  6,128,اِک دِن اوہ اَکٹھیاں کَرکے اوہناں سَبھناں تائیں(کہسی )اے شیطانی مَنڈلی کِنّے اِی(کتنے ای) اِنسان تُساں نے اپنے جال پھَسائے تے اِنساناں توں اوہناں دے سَنگی کہسن ،ربَّا کَم اَساں رہے کَڈدے اِک دوجے توں تے مُڑ سَاڈی مُہلت مکی (ختم ہوئی) جیہڑی توں سِی مِتھی(مقرر کیتی) ہوئی سَاڈے واہتے۔رَب آکھے دَا اَگ سَدیوی(اَگ ہمیشہ) وَاس (ٹھکانا)تہاڈا، اَڈ (بچت )اوہناں نوں اَللہ سوچے ہَور جنہاں دے بارے،تیرا رَب حکیم ،عَلیم ایں ، شک ناہ کوئی
  6,129,تے اِنج گھوڑ پھَڑ اک اَسی کروائیے نافرناں نوں اِک دوجے اُتے اوہناں دے کَرتوتاں پاروں
  6,130,اے جِنّی تے اِنسانی ٹولے ،کی تہاڈے تَک تہاڈے وِچوں ناہ پیغمبر آئے میر آکھی کَن تہاڈے پانے واہتے،تے اَج دِی اِس پیشی بارے وِی دبکاندے رہے تہانوں،اوہ آکھن دے اَپنے اُلٹ گواہی،اوہ دُنیا دی رَنگ رَلیاں توں دھوکہ کھَا گئے تے ہُن اپنے اُلٹ گواہی آپوں دیسَن جے اوہ کافَر ہے سَن
  6,131,پیغمبر اِس پاروں گھَلے جے رَب تیرا ناہ ، بَرباد کِسے وِی وَستی نوں کَردا اے دھَکّم دَھکّی تے وَسکیناں(باشندیاں ) نُوں بِن جھونے(بغیر دَسّے)
  6,132,ہَر کِسے دَا اَپنا حِصہ،عَمل مُطابق، رَب ترا ناہ، عَمل کَسے توں ناواقف
  6,133,تیرا رَب غَنی تے رحمت اِی رحمت اے،پر جے چاہے چَک وِی دیوے اوہ تہانوں تے لے آوے تھاں (جگہ)تہاڈی اوہ جِس نوں چاہے جِو یں اوس تہانوں اُٹھایا ،قوم اِک ہَوری وِچوں
  6,134,وَعدہ جِس دَا نال تہاڈے ، اوس نے آکے رہنا،ایس نوں ٹال تُسی ناہ سَکدے
  6,135,کہہ دے لوکو،ٹِل(زور) اَپنا جو لگ سَکدا اے لائی جاؤ میں اپنے َکم لگّا ہویا، پَتہ تہانو ں وِی َلگ جاسِی کِس دِی اُوڑک (انجام)چَنگی،اِیہہ یَقین اے ظالم رہسن بے مُرادے
  6,136,آپوں اِی ناں رَب لئی کَردے حِصہ بیجی پیلی(کھیتاں)وِچوں، ڈَنگراں وِچوں، تے مُڑ کہندے اپنے زعموں (خیال) اِیہہ اَللہ دَا اے اِیہہ( دوجا) اوہناں دَا جو شریک اَساڈے (اپنے متھے ہوئے) تے اوہ اَللہ تیک ناہ اَپڑے(ناہ پہنچے)،حِصہ جو شَریکاں والا، ہاں شَریکاں نُوں مِل جاندا حِصہ اَللہ دَا وِی، کِڈی کانی وَنڈ( بُری تقسیم ) اوہناں دِی
  6,137,تے انجے ای مشرک لوکاں وچوں چوکھے جنہاں واہتے غیر اللہ نے جاتک ماری(بچےقتل کرنا) مَن کھچواں (خوشنما)کیتا ہویا جس توں اوہ برباد ہو جاندے تے دین اوہناں واہتے اےرل گڈ(مشتبہ) ہو جاندا،اللہ چاہندا تے اوہ انج کدے ناہ کردے،چھڈ اوہناں نوں کوڑ اُ سارن جوغا(جھوٹھ بولن لئی)
  6,138,تے اوہ آکھن ، اِیہہ ڈنگر(مویشی) ، اِیہہ کھیتر(کھیت) ٹھاکے (محفوظ)ہوئے نیں،اِیہہ ناہ کھائے اَڈ (سوائے)اوہناں توں ،اَسی جِنہاں نوں کہیے، کُجھ ڈَنگراں دَی کَنڈ دِی ٹھاک اے(سواری حرام اے)،کجُھ تے ذِبح کَرن دے ویلے، اوہ اَللہ دَا نام ناہ لیندے ،اِیہہ بُہتان اوہناں دَا اُس تے، تے اس کوڑ اُساری نوں سِر تے بھُگتن
  6,139,ایبھی کہندے جا (بچہ) اِہناں ڈَنگراں دے ڈِھڈا ں دے وِچ جیہڑے اوہ نِرے مَرداں دے واہتے ،زَالاں(عورتاں )واہتے ٹھاک(حرام) اوہناں دِی، مویا(مریا) جَم سَبھناں دَا سَانجھا، اوہ اَپنی اِیہہ مَتھے لائی وِی بھگتن گے،بے شک اوہ اَللہ حکیم علیم اے
  6,140,گھاٹے وِچ اوہ مُورَکھ جیہڑے بِن اَللہ دے حُکموں قَتل کَریندے جمَے جائے(اولاد نوں) تے اَللہ دے ناں(نام ) تے کوڑ اُساری کَرکے رِزق اَللہ دَا اوہناں واہتے دِتّا ہویا، بَند اوہناں تے کَردے،رَاہوں بے راہے اوہ ہو وَنجے(گئے)، سِدھے رَاہے ہوسَن ناہیں
  6,141,اوہوا اِی اے جِس باغ اُگائے چھَپرے تے اَن چھَپرے،کھجَیاں اَتے گَڈیکاں جھار جنہاں دے قِسم قِسم دے، تے اِنارا، اَنگور اِک وَرگے نالے وَکھ وَکھ وَرگے،ہر اِک دَا پَھل کھاؤ ، جَد اوہ پَھل تے آوے،وَاہڈی(کٹائی) ویلے اَللہ دَا وِی حق چمکاؤ، پَر بے جَا ناہ خَرچو، اَللہ نوں ناہ بے جَا خَرچَن والے بھاوَسن،
  6,142,ڈَنگراں چوں وِی کُجھ لادُو تے کُجُھ اَن لادُو ،اَللہ دے اِس رِزقوں کھاؤ۔پَیر شیطانی پَیراں تے ناہ دَھردے جاؤ(شیطان دی پیروی ناہ کرو) اوہ تہاڈا ویری(دشمن) کھُلّم کھّلّلا
  6,143,کھانے واہتے نے نَر ، ماَدے نیں اَٹھ طَرح دے،دو بھیڈل ،دو بَکرل،پُچھ حَرام اُس کیتے نیں نَر دونویں یا مدنیاں (مادہ)دونویں یاں اوہ جو مدنیاں دوآں پیٹیاں دے وِچ رَکھیا ہویا۔جے سچے اوہ ،ٹُھک دِی کوئی مینوں دَسّو
  6,144,اِنجےدو اُٹھاں(اونٹ) دے اَندر دو ڈَھگلیالاں (گائے)اَندر، پُچھ حَرام اُس کیتے نیں نُر دونویں یا ں مدنیاں (مادہ)دونویں یا ں اوہ جو مدنیاں دوآں پیٹیاں دے وِچ رَکھیا ہویا۔پُچھ تُسی سِی کول اوس ویلےجَدسِی حُکم سُنایا، اوس توں وَدھ ظال م کیہڑا ،کُوڑ اَللہ دے مَتھے لاندا جیہڑا، لوکاں نوں گُمراہ کرن نوں بے تُکیاں اِی،بے شک اللہ نافرناں نوں ناہ رَاہے پائے
  6,145,کہہ دے میرے وَل اُتریوی وَحی وِچ ٹھاک ملی ناہ کوئی مینوں،کھاندل واہتے کھانے والی شے دے بارے ،جے کر اوہ مُردار ناہ ہووے،ناہ رَت وَگی ہوئی(ناہ وگدا خون ہووے) تے خَنزیری ماس (گوشت)ناہ ہووے کیوں جے اس دے وچ کَرا ہت، اِنجے کِسے غیر اَللہ دے ناں(نام)کیتے دی نافَرمانی پاروں ٹھاک اے، تے جے چارہ ہَور ناہ چلّے تے ناہ باغی تے حَد ٹپن والا ہووے اوس دے واہتے رب غفورحیم اے
  6,146,جیہڑے وَل یہودی ہے نیں،ہین حَرام اُوہناں دے اُتے ،نُہواں(ناخن) والے،ڈھگل(بھیڈل) بَکرل چَربی،پیٹھاں دے نال یا اَندراسل(آندرا ) یا ہڈیاں دے نال لگی چھَڈ کے،نافرمانی دِی اوہناں نوں اے سَزا سے سِاڈے وَلوں تے ہےاے گل اَساڈی سچی
  6,147,تے جے اوہ جھُٹھیارن تے کہہ دے بھاویں رَب تہاڈا رحم کَرن وچ کھُلا، پر ناہ مُجرم لوکاں اُتوں ،ہے عذاب اُس دے نیں ٹَلنا
  6,148,مُشرک ایہہ ضرور آکھن دے جے رَب چاہندا ،شِرک اَسی ناہ کردے، ناہ ای سَاڈے وَڈ وَڈیرے(باپ دادا)،ناہ ایں چیز حَرام اَسی ٹھہراندےکوئی، اِنجے اوہناں توں پہلاں دے لوکاں نے وی ناہ گَل گولی(ناہ تسلیم کیتی) تے رہے ِ چَکھ کے اوہ عَذاب ا َساڈا، کہہ جے پَکی گل کوئی کول تہاڈے ہے تے رَکھ دیئو اوہ سَاڈے اَگے،پر تُساں تے ہے ظنّاں(گمان) دی پوشَل(دُم )نَپی(پکڑی)اَٹکل تے اَٹکل دوڑا ؤ (قیاس آرئیاں کردے جاؤ)
  6,149,کہہ دے ہے دلیل خُدا دے کول اِی دِل نوں ٹوہنے والی،جے اے منظور ہوندا اوس نوں ،تے اوہ سَبھناں نوں اِی راہے پاندا
  6,150,کہہ گواہ لے آؤ اَپنے ،دیہن گَواہی اِس دِی ٹھاک اَللہ دِی ہے سِی اِہناں چیزاں بارے،جے گَواہی دے وِی دیوَن،توں گواہی مول ناہ دیویں نال اوہناں دے،تے ناہ اوہناں دِی مَن مَرضی پِچھے لَگیں،جیہڑے کُوڑ(جھوٹھ) کہن آیات اَساڈی تائیں تے چھیکڑ دے منکر تے ہَوراں نوں اوہ برابر رَب دے گِنِ دے
  6,151,"اے محمد (صلی اللہ علیہ وآلہ وسلم) !کہہ آ جاؤو، میں دَسناں واں وَاجب جو تہاڈے اُتے اللہ کیتا،(اوہ ایِناں سِی) کَرو شَریک ناہ اُس دا کوئی،ماپڑیاں(والدین) ) دے نال تَعلق سوہنا رَکھو,قتل کرو ناہ بھُکھوں(بُھکھ توں ) ڈَر کے جمَے جائے(بچے) ساڈے کول اِی رِزق تہاڈا تے اوہناں دَا,بےشَرمی دے کَم کَرو ناہ ،کی ننَگے کی گُجھے (کھُلّے ہوَن یاں چھُپے),اوس بندے نوں ماروں ناہیں ،جس دے بارے ٹھاک خُدا دی،جے کر حق ناہ بَن دا ہووے,ایہہ تہانوں اللہ کہند،ا تاں جے سمجھو"
  6,152,"مال یَتیماں دےنوں سوہنے ڈَھنگ ای وَرتو۔ناہ جد تائیں اوہ بالغ تھیون ،ٹوپا پور ا تول وِی پورا رَکھو ،اَسی کِسے نوں چَک اوہدی توں وَدھ کے بھار چُکائیے ناہیں,گَل کرو تے کَرو نِیاں دِی(انصاف دِی) بھاویں ساک(رشتے دار) ای اَگے ہووے,َللہ دے نال قول نَباہو,ایہہ تہانوں ہے تاکید خُدا دے وَلوں تاں جےمَت تہانوں آوے"
  6,153,میرا سِدھا رستہ ایہوا، اس اُتے اِی چلّو، پَک ڈنڈیاں ناہ مَلّو(دوجی راہ ناہ چلو) اوہ تہانوں سِدھے راہ توں تھَڑکا دیَسن۔رَب تہانوں تاکید ایسے دِی کیتی ،تاں جے تَقوے والے تھِیوو
  6,154,موسیٰ (علیہ السلام) نوں وِی اَسی کتاب عَنایت کیتی، نِعمت پوری کرنے واہتے نیکوکاراں اُتے، ہَر گَل دِی تَفصیل سِی اوس وِچ،اوہ ہَدایت تے رحمت سِی، مَطلب اِیہہ سی لوک اے مَنن ،رَب دے اَگے پیش ضرور اے ہونا
  6,155,اِنجےاِیہہ کتاب اَساں ایں نازل کیتی بَرکت والی، اِس دے پِچھے لَگّو، جھاک خُدا دِی رَکھو(تقویٰ اِختیار کرو) تاں جے رحم تُساں تے ہووے
  6,156,مَت کل آکھو، دو دِھراں دے وَل کتاب اُتریِوی ہے سی ساتھوں پہلاں، اس دے پَڑھن پَڑھاوَن بارے سَانوں کجُھ وِی خَبر نئیں سِی
  6,157,یاں اِیہہ آکھو جے کِتاب اَساڈے وَل وِی آئی ہوندی،اَساں اوہناں توں وَدھ ہدایت پائی ہوندی، سَو ہُن اوہ نتراوَل ا(دلیلِ روشن)،رحمت اَتے ہَدایت بَن کے رَب تہاڈے وَلوں تے بد قسمت اوس توں وَدھ کے کیہڑا ہوسی جو ایہہ اِحکامِ خداوندی ۔جِس جھُوٹھے جاتے، تے کَترایا اوہناں کولوں، تے آیات اَساڈی توں کَتراسن جیہڑے،مِلسی عذاب اوہناں نوں بھِیڑا (بدترین) اِیس کَتراوٹ (رُوگَردانی)پاروں
  6,158,کی اوہ اِیس اُڈیکے لَّگے(منتظر نیں) اوہناں کول فَرِشتہ آوے،یاں نشان اِی کجُھ آجاوَن اُس دے ،رَب ترے دے جَدوں نشان کوئی آ وَنجے(جاوے) تے مَن(ایمان) کِسے دِی اوس ویلے کَم ناہ دیسی جے پہلاں ایمان ناہ ہوسِی ا ُس دا ،یاں اِیمان اَپنے دِی کھَٹی(کمائی) ، اوس چَنگی ناہ کھَٹی ہوسِی،کہہ دے کَرو اُڈیک(انتظار) تُسی وِی ،وِچ اُڈیک اَسی وِی ہے واں
  6,159,دین اَپنے نُوں ٹوٹے ٹوٹے کَرنے والے تے دَھڑیاں وِچ پاٹن والے ترے کجُھ ناہ لَگدے،سَٹ (چھڈ)اَللہ تے گل اوہناں دی ہاں اوہناں نوں توں اوہناں دے کَرتوتاں توں وَاقف کَردے
  6,160,نیک عَمل جس کیتا ہوسِی،اوس دے کھاتے دَس گُنا رَب وَلوں پیسی تے جیہڑا مَند(بدی) لے کے آیا اوس دے نال اونجے دِی ہوسی، پَر ناہ مول وَدھیکی ہوسِی(ظلم کِسےدے نال ناہ ہوسی)
  6,161,اے محمد (صلی اللہ علیہ وآلہ وسلم) کہہ دے بے شک رَب میرے نے مینوں سِدھے راہے پایا، ڈِنگوں خالی دین اوس دِتّا (ٹھیک دین جس وچ کوئی ٹیڑھ نئیں) ابرہم حنیف آلی اُس ملت دِتّی۔اوہ ناہ ہے سِی مُشرک لوکاں وِچوں
  6,162,کہہ نَماز میری،قُربانی میری(تے ساری عبادتاں میری)۔مَوت حیَاتی میری سَب اَللہ دا، جیہڑا رَب اے سَب دا
  6,163,کوئی اِس دا سِیری (شریک) ناہیں۔اَمر (حکم) ہویا ہےمینوں ایہوا ، تے میں سَب توں پہلاں اِس دی مَنّن والا
  6,164,کہہ دے ،کی اَللہ نوں چھَڈ کے ہَور کوئی رَب چاہواں،حالاں اوہ ہر شے دَا رَب اے،تے جو عَمل کِسے دَا ہونا ،اوسے تے بھَار اوس دا پَنڈ(باجھ) کِسے دِی ہَور کِسے پَنڈ چائے(چُکن والے) نے کَد چانی ، تے مُڑ پَرت (واپسی)تہاڈی ہونی، رَب تہاڈے وَل اِی،تے دَس دیسی اوہ تہانوں ،جس بارے سی وَکھرے ٹُردے
  6,165,اوہوا ہے وے جِس نے تہانوں دُنیا دے وِچ چدھڑاہٹ دِتّی،کجُھ نوں کُجھ توں اُچا کیتا، تاں جے اَپنے کیتے بارے ،کَرے تہاڈی اوہ َازمائش، بے شک رَب تیرے دِی پَکڑ تَرِکھی(تیز) ہے وے ، پَر غَفُور رَحیم وِی ہےاوہ
  7,1,الف- لام- میم- صاد
  7,2,ہے کتاب ایہہ نازل کِیتی تیرے اُتّے کیوں دھڑکے دِل تیرا اِس دِی رَاہیں جھُونن(چلن ) اُتّوں ، اِس وِچ مَتّل گَلاں اِی نیں مَنّن والے لوکاں واہتے
  7,3,لوکو پلّے بَنّو (پیروی کرو) رَب تہاڈے وَلّوں آیا وَل تہاڈے،مَنّوں ناہیں سائیں کوئی، اِس دے باجھوں (علاوہ)،گَل تہانوں گَھٹ اِی چیتے رہندی
  7,4,ویکھو کِنّیاں گوٹھاں(بستیا ں) اَساں ویران بَنائیاں جَدوں عَذاب اَساڈا آیا سُتے (راتی) تے جاگے(دِن وچ جَد آرام کَریندے) اوہناں اُتّے
  7,5,"تے مُڑ اوس عَذابی ویلے اوہناں دے مونہوں چوں ایہوا نکِلے :ساڈی نافرنی سَاڈے اَگّے آئی"
  7,6,کَرنی پُچھ اَساں نیں،اوہناں کولوں ،جَنہاں وَل پیغمبر گھَلّے،پیغمبراں توں وِی پُچھ ہوسِی
  7,7,تے مُڑ لوکاں نوں دَسّاں دے جو کجُھ عِلم اَساڈا دَسْدا،اَسی تے اوہلے بیٹھے نئیں سَاں
  7,8,اوس دِہاڑے تول ہونا ایں حَقا سَچا، جِن دَا پَلّہ بھَارا ہوا اوہ مُراداں پاسَن
  7,9,اے پَر ہَولے پَلَّے (ہلکے پلڑے ) وَالے اوہ اِی ہوسَن گھَاٹے دے وِچ اپنے تائیں آپ جِنہاں نے پایا، سَاڈے حُکماں دِی نافَرنی کَرنے توں
  7,10,ایہہ اَسی آں جنہاں ،تہانوں دَھرتی وِچ وَسایا، اِس دے وِچ تُہاڈے وَاہتے ڈَنگ ٹَپانے دے رَاہ کَڈے ، گَھٹ (تھوڑے لوک ای )اِحسان اوہ جانَن والے
  7,11,ایہہ اَسی آں جِنہاں ،تہانوں پیدا کیتا چہرہ مُہرہ دِتَّا، فیر ملَائک نُوں فَرمایا ، آدم دے اَگے سِْیس نَواؤ( سجدہ کرو)،سبَھناں سِیس نَوَائے اَڈ (سوائے) اَبلیسوں اوہ نیئوندَل (سجدہ کرن والے) ٹولے نالوں وَکھرا ہویا
  7,12,رَب نے پچُھیا کیہڑی گَلوں میری آکھی تے وی ہویوں تُوں نیئونوں نابَر(سجدہ کرن توں انکاری )،آکھن لَگّا میں اُچیرا(بہتر) اِیس توں،مینوں توں اَگوں (اَگ توں )خَلقایا تے خاکوں اِیس تائیں(نوں)
  7,13,حُکم ہویا ،دُور ہو جَا اِیتھوں،پھَونڈ (گھمنڈ) اِیہہ تینوں جَچدی ناہ سی ، توں اِیس ٹیں دی نِکل ہَواؤں
  7,14,آکھن لَگّا، مُہلت مَنگا روز قیامت تائیں
  7,15,حُکم ہویا ۔دے دِتِّی
  7,16,آکھن لَگُا تُوں رَاہ بَند مِرے تے کِیتی، اِِس توں کھِج کے ، تیرے سِدھے رَستے اُتّے تھَڑا دَیاں دَا میں اوہناں نُوں
  7,17,اوہناں دے میں اَگوں ،پِچھوں،سَجئیوں (سجے )،کھَبئیوں(کھبے) چَڑھ آواں دَا، تے توں تَکسیں چَوکھے تیرے،اَحسا ناں دَا مُل ناہ پاسَن
  7,18,رَب کہیا، نِکل جَا اِ یتھوں ،مَند (ذلیل) تے رَدْیا (ٹھکرایا) ہویا، اِنساناں چوں جیہڑے تیرے مَتھے لَّگے، دَوزخ بھَرساں نال تہاڈے سَب وَلاں دے
  7,19,اے آدم ؑ وَس (رہ) جَنت اَندر سَنگ (ساتھ) اَپنے سَنگ (ساتھی) دے ، جِتھوں جو کُجھ چاہو کھاؤ ،ہاں ایس رَکھ دے کول ناہ جانا نئیں تے نافرمانے تھِیسو
  7,20,پَر شیطان اوہناں نُوں اَپنی پَٹی لایا(بہکایا) ،تاں جے سَتَّر(شرم گاہیں) اوہناں دے کھَولے ،ہے سَن جیہڑے اوہناں کولوں پہلاں اوہلے(چُھپے ہوئے) آکھن لَگّا اِس شَجر توں رَب تہاڈا اِیس توں روکے ،جے ملائیک ناہ بَن جاؤ یاں اَمَرْہو جاؤ (ہمیشہ دِی زندگی پا جاؤ)
  7,21,قَسماں کھَا کے اوس کہیا سِی میں تہاڈا ہے چَنگ چاہی(سچاخیر خواہ)
  7,22,اِنج اوہناں نوں اوس بَچلایا(دھوکا دے اپَنے ڈھب تے لایا) پَر جَد اوس شَجر نوں چَکھیا، اوہناں اُتے سَتّر(شَرم گاہیں) اوہناں دے کھّلّے، تے اوہ باگی(باغ دے) پَتراں رَاہیں(پتے نال) سَتّر چھپٗاوَن لَّگے، تاں رَب اوہناں نوں جَتلایا، کی تہانوں اِیس شَجر ہَوڑ ہَٹک (قریب جان توںمنع)ناہ کیتی ہے سِی،تہانوں دَسیا ناہ سی، شیطاں تہاڈا دُشمن کھُلّم کھُلا
  7,23,اوہناں مَنَیا(تسلیم کیتا) اَپنے پیراں اَساں کلہاڑی آپوں ماری، جے توں بھُلیں ناہ بھُل اَساڈی (اگر توں درگزر ناہ کرے)، مہر (رحم) کریں ناہ سَاڈے اُتے ،گھَاٹ ای گھَاٹ اَساڈے لیکھیں (ساڈے نصیب وچ تباہی ہوسی)
  7,24,رَب کہیا ہُن اِیتھوں نِکلو،اِک تہاڈے اِکناں دے ہُن ویری تھیسَن دُنیا وِچ ہُن رہن تہاڈا تے چوگا اِک مدت تائیں
  7,25,ہَور کہیا جے اِیتھے اِی ہُن جیئونا ،مَرنا ہوگ(ہوسی) تہاڈا ، تے اِیتھوں اِی ہَوگ اُٹھا لا(ہوسی اُٹھانا)
  7,26,آدم جایو ،(اولادِ آدم) چَج لِباس بَناون لاون دا وِی دِتا اَساں تہانوں،جیہڑا کجَے(چھپائے) سَتّر( قابلِ شرم حصے)تہاڈے،نالے زینت بنے تہاڈی،اُنج لباس چنگیرا(بہترین) سَب توں تَقویٰ ہے وے، ،اِیہہ الٰہی مَتاں (نصیحت )ہے نیں پلَّے بَنّھن واہتے(یاد رَکھن لئی)
  7,27,آدم جائیو،(اولادِ آدم)،َمت شیطان تہانوں کِدھرے،رَستے توں تھَڑ کائے، جویں تہاڈے ماپڑیاں (ماں ،باپ) نوں جنتوں سی کَڈھوایا،لا ہ (اُتار کے) کے اوہ لباس اوہناں دا،بے پردا اِک دوجے اَگے اوہناں نوں کر دِتّا،اوہ تے اوس داٹولہ تہانوں اِنج گھاتے بیٹھا ہویا ویکھے جے آپوں نا ہ نَظری آوے،اَسی اوہناں نوں جیہڑے نیں ایمانوں کَورے(خالی)سَنگی (ساتھی)نیں شیطان بنائے
  7,28,بے حَیایاں کردے ہوئے اوہ اِیہہ کہندے ۔اِنجے وَڈوڈیرے سَاڈے کَردے آئے،اَللہ وَلوں اِی اِیہہ اَمر اَسانوں ہے وے،کہہ دے اَللہ بے حیایاں دا حکم تہانوں دیووے،کیوں جے بے تُکیاں اوہ ،اَللہ دے مَتھے لاندے
  7,29,کہہ دے اَمر مِرے رَب دَا اے ،سِدھے سانویں(راست تے انصاف تے ) رہنا،ہر عبِادت ویلے رَکھنی رَب دے وَل توَجہ سِدھی،اِنج چتَارو(پُکارو) اوس نوں جِویں چتَارن دِل چوں مَنّن والے،جِویں تہاڈی پہل ہوئی سِی،اِنجے پَرت(واپسی)تہاڈی
  7,30,اِک فریق ہدایت پائی ، اِکناں نے گُمراہی ،کیوں جے اوہناں رَب نوں چھڈ کے ،شیطاناں نال یَاری لائی،اِیس بھُلیکھے جے اوہ نیں سِدھ رَاہی
  7,31,آدم جایو ہَر عِبادت ویلے کَپڑے ڈَھب دے پاؤ، پیوو کھاؤ پر ایویں ناہ اُڈاؤ،کیوں جے اللہ نوں ناہ مال ا ُڈاؤ بھاوَن
  7,32,پُچھ حَرام بنَایا کِس نے اس پاوَن توں اَللہ جِس نُوں اَپنے بَندیاں واہتے آپوں آپ پیدا کیتا تے انِجے پاکیزہ کھاوَن ،کہہ دے ایہہ اِس دُنیا دے وِچ وِی ہین حَلال اوہناں دے واہتے جیہڑے ہین ایمان لیائے اَتے نَرول اوہناں دَا اِیہہ حِصہ ہوسَن اَگے چَل کے، اِنجے اَسی ایات اپنی تَفصیلاً دَسدے اوہناں نوں جو سُوجھت والے(علم رکھن والے)
  7,33,کہہ دے رَب مِرے ٹھاکے(حرام کیتے) بے حیَائی دے کَم سَارے ،کی ا ُکڑے(کھلے) کی اوہلے(چھپے)،حَق ماری تے دَھکے شاہی، انجے سِیری رَب دا کَرنا کیوں جے اِس دَا حُکم کَدے ناہ اُس نے دِتّا، ہے حَرام اوہ گَل وِی اَللہ دے سِر پائی ،جِس دِی اللہ وَلوں ہونے دی ناہ کول نشانی
  7,34,ہَر لوکائی دِی اِک مدت ،جَد اوہ مُدت ہو جاندی اےپُوری۔اِک پَل دِی ِوی ڈِھل ہووے ناہ ، پہل ہووے اِی
  7,35,آدم جایو جے رَسُول تہادڈے وِچوں آوَن کول تہاڈے ،تے اوہ آیات میری پاوَن کَن(کان) تہاڈے آکھے لگن تے گَند دھوَن والڑیاں نوں خوف ہوسی ناہ جھورا کوئی(رنج کوئی)
  7,36,ہاں جِنہاں آیات اَساڈی نوں ناہ مَنیا(ناہ تسلیم کیتا) تے ہیکڑ (سرکشی) توں کم لیئوو نیں(کم لِتا) اوہناں بارے،اوہ اَگ وَاس(جہنمی) ہمیشہ واہتے
  7,37,تے اِس نالوں بھِیڑی کس نال ہونی ایں ،جیہڑ ا لائے جھوٹھ اَللہ تے مَتھے ،اوس دَیاں یا ں دَسیاں نوں جھُٹھیارے،اِنج دے لوکا ں نوں اوہناں دَا لِکھیا مل کے رہسی، جَد اوہناں کول آون دے جِند کڈھ (موت دے فرشتے) سَاڈے وَلوں، اوہ پُچھن دے کِتھے ہے اوہ کَل سَددے سِی گے رَب نوں چھَڈ کے،اوہ آکھن دے اوہناں سَنگ تَڑوڑی کیتی (ساتھ چھڈدِتّا) اپنے بارے ایہہ گواہی اوہناں دِی اَپنی اِی ہوسی جے اوہ سَچ مُچ کافَر ہے سَن
  7,38,حُکم ہووے دا، رَلدے جاؤ اَگ دے اَندر سَنگ اوہناں دے جو تُساں توں پہلاں ٹولے ہو گُزرے نیں، جِناّں تے اِنساناں وِچوں جَدوں وی کوئی ٹولی داخل ہوسِی دوجی نوں پھَٹکار کَرے دِی تے جَد سارے کَٹھے ہوسَن، پشلے(پچھلے) کہسن اَگلڑیاں دے بارے،رَبّا ایہوا سَانوں نیں بَدراہوَن والے،اِک عَذاب دُونا اِنہاں نُوں دے اَساڈے نالوں،رَب کہے دَا سَب لئی دُونا(دوگُنا)، اَجے تہانوں اوس ہونی دِی سَار(خبر) ناہ کوئی
  7,39,سَب توںچھیکڑ والی(آخر والی) ٹولی نوں پہلی کہسی ۔کاہدی(کیسی) اَج وَڈِت(فضیلت) تہاڈی سَاڈے اُتے (ساڈے وانگ اِی)اپنا کیتا آپ تُسی وِی بھُگتو
  7,40,جیہڑے وی آیات اَساڈی مَن دے ناہیں،تے آ کڑ (سرکشی )وِچ کنڈ ھ بھَواندے(ناہ مَن دے) اَسماناں دے دَر اوہناں تے کھُلسن ناہیں تے اوہ جنت وِچ ناہ وَڑسِن،جیِتوں (جد تک)ناہ اُوٹھ(اونٹ) سوئی دے نکےو چدوں لَنگھے (گزرے) مُجرم لوکی اَساڈے کولوں اِنج اِی کیتا پاسَن
  7,41,دوزخ ا ِی اوہناں دے تھَلے اُتے ہوسِی،بَدکاراں نے اِنج سَاتھوں (ساڈے کولوں)کیتے پانے
  7,42,تے اوہ جو اِیمان لیائے نالے چنَگے عَمل کَمائے جیہڑے اوہناں دی چَک(استطاعت) توں ناہ وَدھ ہووَن دے اوہ ہووَن دے جَنت وَاسی(جنتی)،اِیس دے وِچ ہمیشہ رہسن،
  7,43,اوہناں دے اَندراں دے بھَارے(کَدُورتاں) سَارے دُور کَراں دیں،وَگدے پانی لاگے ہوسَن تے اوہ کہسن شُکر خدا دا جےسانوں اوس راہے پایا، اَسی ناہ سِدھے پاسے لَگدے۔جے اوہ راہ ناہ پاندا، رَب ساڈے دے مُرسل (پیغمبر) سارے لے کے سَچ اِی سَچ آئے سن،اوہناں نوں خوشخبری مِلسی ،ایہہ اوہ جنت جِس دا وارث کیتا، اَساں تہانوں۔ عَمل تہاڈے تَک(ویکھ) کے
  7,44,جنت وَاسی ،دوزخ وَاسی لوکاں تائیں اِیہہ آکھن دے،رَب اَساڈے، نال اَساڈے وَعدہ جو کیتا سِی ،اوہ سَچ ہو یا، کی تہاڈے نال ہویا وِی، وَعدہ سَچ ہویا ہے وے اوہ آکھن دے آخو(ہاں) ،اوس ویلے اِک نعرہ لانے والا ،نعرہ لاسی، حَد ٹپَالے لوکاں اُتےرَب دِی لعنت
  7,45,یعنی اوہناں اُتے جیہڑے رَب دی راہوں رَہے لوکاں نوں ڈَکدے(روکدے) تے پُٹھے پاسے (غلط راہ تے) لاندے نالے چھیکڑ (آخرت)دے وِی مُنکر
  7,46,دوآں تھاواں دے وِچکارے اِک کند(دیوار) ہووے دِی تے ٹِبیاں(بلندیاں ) تے بیٹھے لوکی، آپ قیافے لا لیون دے ہر کِسے دے بارے، جَنتیاں نوں آکھن دے شالا تُسی سَلامت وَسّو(سلامتی ہووے تُساں تے) آپ اَجے ناہ اِس وِچ بھاویں، ہوئے داخل، پر آسی(امیدوار) تے ہوسَن
  7,47,پِھر کے جَد نگاہ اوہناں دی ،اَگ وَسنیکاں (جَہنمیاں وَل) جاسِی ،بول اُٹھن دے،رَبّا ،ساَنوں حَد ٹَپلاں (ظالماں)دے ناہ سَنگ رَلائیں(نال شامل ناہ کر)
  7,48,اِیہہ اِعرافی کُجھ وَڈیرے بارےلا قیَافہ اِیہہ آکھن دے اَج تہاڈےکِس کَم آیا مال تہاڈا تے اوہ آ کڑ جِس دی ہے سِی
  7,49,کی اِیہہ اوہوا لوک نئیں نیں ،جِنہاں دے بارے قَسماں کھاندے سِی جے، اِہناں اُتے اَللہ رحمت کرنی ناہیں(اونج دے لوکوں نوں ایہہ کہیا جاسی ) آؤ جنت مال تہاڈا،خوف کَرو ناہ، جھور جھُرو ناہ( رنج کرو ناہ)
  7,50,جَنتیاں نوں مُڑ اَگ والے(جہنمی) کُوک مَریسن(پُکارسن) فیض کَرو کجُھ پانی دا ساڈے وِی اُتے یا ں اوس وِچوں جو تہانوں اَللہ دِتّا، اوہ آکھن دے ہین حَرام ایہہ دوواں اِی(دونوں) کَفرونوں اُتے اَللہ وَلوں
  7,51,یعنی اوہ جِنہاں نےاَپنا دین بنایا سِی رَنگ رَلیاں تے جگ جیون تے اوہ بھُلے تے اَج اوہ سَاڈی یَادوں لَتھے جِیویں اوہناں دِی یادوں ،کَل سی، اَج دِی پیشی لَتھی ہوئی تے آیات اَساڈی دَا اِنکار اوہناں کیتا رَکھیا
  7,52,اِہناں کول کتِاب اَساں اوہوا گھَلی ،رَکھ کے بُنیاد وَحی تےجِس دِی، تَفصیلاً ہَر گل دَسی اے جِس دے اَندر، اوہ ہَدایت تے رحمت اے مومن لوکاں واہتے
  7,53,کی اُڈیک اوہناں نوں اِس دِی کِس دِن آکھی پوری ہوندی، اوہ آکھی جَد پوری ہوئی، اِیہوا پہلوں او ہنوں بھُلے ہوئے کہسن ،ساڈے رَب دے مُرسل(پیغمبر) آئے سِی سَچ لے کے،کِدے سَفارش کار کوئی مِل جائے سَانوں یا دُنیا وَل موڑے جائیے، تاں جے کَرئیے جو پہلاں ناہ کیتا، گھاٹے دے وچ اپنے تائیں اِہناں پایا۔اَج دغا اوہناں نوں دِتّا اِس تانے بانے
  7,54,رَب تہاڈا تے اوہ اَللہ،اِیہہ زَمین اَسمان بنائے چھ دِناں وِچ جِس نے ، فیر بَراجا (جلوہ افروز ہویا) اوہ تَخت اُتے،دِن نوں رَات کَجیندی(ڈھک لیند اے) اِس دے پِچھے دِن وِی اَڈیاں چاندا آوے(دوڑدا آوے)،سُورج ،چَن سَتارے سَارے اس دا آکھا منن ہارے(تسلیم کرن والے) اوسے دے ہَتھ اے پیداکرنا واگ منانا، (اوسے دَا اَمر اے) ہر برکت اَللہ دے ہَتھ اے جو رَب سَب دا
  7,55,اَپنے رَب نوں تُسی پُکاروں اُچّا اُچّا بھاویں مَٹھا مَٹھا اوس نوں حَدوں لَنگھن والے بھاوَن ناہیں
  7,56,گڑ بڑ مول کرو ناہ آل دَوال(اِردگِرد) سَوارن پچِھوں(اصلاح ہو چُکن بعد) آس نراس ہر حالت اَندر اُس نوں تُسی چتارو بے شک رحمت رَب دی نیڑے نیکوکاراں دے ہو ندی اے
  7,57,اس دی ذات ہوائیں (ہواواں)گھَلے،جنہاں ،دے خوشخبر ی پلٗے رحمت اس دی دے۔اوہ ہوَن اَگے اَگے،بھارے بَدلاں نوں جَد کِرے کلاوے(نوں جد چُکن)،سُکی موئی ونڈ کِسے وَل گھَلئے (کسے مُردہ سر زمین دی طرف روانہ کرئیے)،اِس وِچوں پانی اَسی وَسا کے،(بارش کرکے) اِس دِی راہیں ہر طرح دے پھَل اُگاندے،اِنج موئیاں(مرَے ہوئیاں ) نُوں اَسی اُٹھاندے تاں جے جاگےاَندر سَوچ تہاڈے
  7,58,تے جیہڑی تھاں چَنگی ہووے اوتھے حُکم الٰہی پاروں وَل(چنگی) اُگائی ہووے(پیداوار ہووے)،جیہڑی تھَاں نَاقص ہووے پیدائش وِی ناقص ہوندی اےاوس تھَاں (جگہ)تے،انج اَسی پَرتا پَرتا کے اَپنیاں گَلاں شُکر کَرن دِی فِطرت والے لوکاں اَگے رَکھئیے
  7,59,نوح نُوں گھَلیا جد اَساں سِی، قوم اوس دی وَل ،اوس اوہناں نُوں سمَجھایا سِی۔لوکو، کَرو عِبادت رَب دی، بِن اُوہدے مَعبود ناہ کوئی ہَور تہاڈا، ڈرناں ، تُسی عَذاب وَڈیرے دے رَگڑے دے وِچ آجاؤ دے
  7,60,قوم اُس دے سِر کڈ بولے،ساَنوں توں تے بُھو نتَلیا (گمراہ) اِی لَگسیں بالکل،
  7,61,اوس کہیا جے بھو نتَیلیا تے میں ناہ اُکّا میری قومے، میں تاں ہاں رَسوُل اوس وَلوں ،جو رَب سَب دَا
  7,62,بھیجاں اَپنے رَب دِیاں ، اَپڑان تہاڈے کول آیا واں،میں دیواں مَت (نصیحت) تہانوں اَللہ وَلوں جو میں جاتا اوہ تُسی ناہ جانا
  7,63,کی اچرج (تعجب )تہانوں لگے،رَب تہادے وَلوں اِک تہاڈے وَرگےوَل اِی کِویں مَت بانی آئی، جھونا دین تہانوں (خبر دار کرے) تا ں جے جھَاک پَوے جے رَب دِی (برائی توں رک جاؤ ،رَب دے خوف توں )تے رحم تُسا ں تے ہووے
  7,64,پَر ناہ اوہناں اُس دِی مَنّی، تاں مُڑ اُس دَا سَنگ سَنگیاں دے بیڑا پاڑ اَساں کَر دِتّا، تے غَرقایا ۔گَل جِنہاں ناہ سَاڈی گولی، قوم اوہ ہے اِی (عقلوں)اَنھے لوکاں دی سِی
  7,65,عاد قَبیلے وَل وِی ہودؑ اوہناں دِا لَگدا گھَلیا، اوس کہیا اے میری قومے، کَر وعبِادت رَب دِی، بِن اوہدے مَعبود ناہ کوئی ہَور تہاڈا، کیوں ناہ اُس دِی جھَاک تہانوں
  7,66,قوم اِس دِی دے، کَفروناں دے سِر کَڈ بولے توں تے کوئی مُورَکھ (بے عقل)جاَپیں شَک اَسانوں اِیبھی یکڑ مار(جھوٹھ مارن والا) کوئی ایں
  7,67,اوس کہیا میں مُورَکھ ناہ لوکائیے(لوکوںمیں بے عقل نئیں) میں تے ہاں اوس وَلوں ،جیہڑا رَب اے سَب دَا میں تہانوں بھیجاں اَپنے رب دِیاں ، اَپڑاوَن تہاڈے کول آیا وَاں
  7,68,ہیرا پھیری کوئی ناہ کَردا ،میں تہانوں مَت ہاں دیندا
  7,69,کی عجیب تہانو ں لگے رَب تہاڈے وَلوں،اِک مَت بانی آوے وَل تہاڈےاِک تہاڈے اپنے وِچ دے بندے رَاہیں، تاں اوہ تہانوں جھونے(خبر دار کرے) ،پر کَروخاں چیتے(یاد کرو) نوح دِی قوموں پچھے وارث جَدوں بنایا ہے سِی، اَساں تہانوں،تے لوکاں وچ ٹوہر تہاڈی اَساں وَدھائی،یاد کَرو اِحسان اللہ دے تاں جے بامُرادے تھِیوو
  7,70,آکھن لگے توں اَساڈے وَل آیا ایں تاں جے اَساں عِبادت کرئیے اَک اَللہ دی تے وَڈیاں دے مَعبوداں نوں چھَڈئیے،دے لے توں ڈَراویں جیہڑے دے سَکدا ایں ،جے سَچیاراں وِچوں ہے ویں
  7,71,اوس کہیا بس باب تہاڈے ،رَب تہاڈے لِکھ دِیّتیاں نیں جھَاڑاں جھنباں تے پئے ایویں نال میرے او جھَگڑے کَردے اوہناں ناواں(ناماں) بارے جیہڑے رَکھے مِتھے آپ تُساں نے یاں تہاڈے وَڈکڑیاں نے،تے اللہ ناہ نازل کیتی ہے دَلیل اوہناں دے بارے،ویکھو اَللہ کی کَردا اے میں نال تہاڈے ویلا اوہ اُڈیکاں(انتظار کراں)
  7,72,تے اُس نوں اَسی بَچایا نال اس دے نال دیاں نُوں اَپنی مہروں (مہربانی کر کے)،اوہناں دِی جَڑ وَڈھ دِتّی جنہاں نے آیات اَساڈی نوں جھُٹھیایا تے اوہ منن والے نئیں سِی لَگدے
  7,73,اِنجے ثَمود کیاں وَل ،صالح ؑاوہناں دَا اِی لَگدا گھَلیا، اوس کہیا میری ر قومے، کَرو عبادت رَب دِی ،ناہ مَعبود تہاڈا کوئی بِن اُس دے ،ہُن جَد رَب تہاڈے وَلوں آپُجی اے اَک نشانی وَل تہاڈے،اِیہہ اَللہ دِی ڈَاچی اوہ نشانی ہے جے اِیس نوں چُگنے ،چرنے دی کھُل دِتُّی رَکھنا، ماڑا ہَتھ ناہ اِیس نوں لانا (کسے بُرے ارادے نال ایس نوں، ناہ چھونا)۔کَدے عذاب کَریڑے دی ،ناہ سَٹ ،وِچ آؤ(اِک دَردناک عذاب تہانوں آلَوے)
  7,74,یاد کَرو عادکیاں توں پچِھے اَسی تہانوں وارث کیتا تے دِتُّی سی مُلکے دی مَلکائی( ملک دی حکومت دِتی)۔پڈھراٹا ںوِچ اوتھے محل اُسارے سِی جے(زمین ہموار کر کے عالی شان محل بنائے)،پربت (پہاڑ)کَٹ کَٹ گھَر بَنائے،یاد کَرو اِحسان خُدا دے تے ناہ پھِرو فسَاد مَچاندے اِیدھر اُودھر
  7,75,قوم اِس دِی دے آکڑ خاناں۔ماڑکیاں چوں(کمزور) مَنّن وَالڑیاں نُوں پُچھیا کی تہانوں کیڑ اے ا(جاندے اوہ)ِ اِس دِی،صاَلح اَپنے رَب دَا مُرسل بَن دَا پھِردا، آکھن لگَے ہے اِیمان اَساٖڈا اِس تے ،اِس دی راہیں جو کجُھ آیا
  7,76,آ کڑخاناں اِیہہ کہیا جے اَسی تے اوس دے نابر(منکر) جِس نُوں تُس مَنّیاں ایں
  7,77,تے ڈاچی دیِ کُھچ (ٹنگ )اوہناں کَپ (کٹ) دِتّی تے رَب اَپنے دِی آ کھی دے آکی ہوئے(مخالف ہوئے)، آکھن لگَے صَالح ،لے آڈَراوے جیہڑے سَانوں دَسدا آیو جےتوں مُرسل لوکاں وِچوں
  7,78,آخر اوہناں نوں تھَر تھَلی نے آ نَپیا (دِل ہلا دین والی آفت نے آپھَڑیا) تے مُونھ پَرنے اوہ اَندراں وِچ ہوئے (اپنے گھَراں وِچ اُلٹے پئے ہوئے سن)
  7,79,صَالح چھَڈ گیا اوہناں نُوں کہندا ہویا،لو کوں میں تہاڈے تائیں رَب اَپنے دِی بھَج (گَل ) اَپڑائی، مَت وِی دِتی(نصیحت وِی کیتی) پر ناہ، وَارا، کھان تہانوں مَتّل بَندے(خیر خواہ بندے)
  7,80,لُوط وِی اِنجے قوم اَپنی نُوں جَد سَمجھایا، کیوں کَردے او بے حیائی ،جو کِسے نے ناہ اَج تائیں کیتی دُنیا اُتے
  7,81,شہوت چائے،رَنّاں چھَڈ کے مَرداں دے وَل ڈُھکو(عورتاں چھڈ کے مَرداں دے نال شہوت کَردے ہو) ہے تُساں بالکل دھو پیتی(تُساں تے حد کر دِتّی)
  7,82,قوم اوہدی نے اِکو پَرتا پرَتایا،(اِک اِی جواب سِی) اِہناں نُوں اَپنے پِنڈوں کَڈے (اہناں نوں اپنی بستی تو کَڈ دیوو)پاک بَڑے اِیہہ بَندے پھِردے
  7,83,تے مُڑ اَساں نَجات دِلائی ایس نوں نالے ایس دے لَڑ لَگیاں نُوں وِی ، زَال (بیوی) اُوہدی نُوں چھَڈکے ،سی اوہ رہکَل(پچھے رہ جان والے )لوکاں وِچوں
  7,84,اوہناں تے پتھرُ وڑ اَساں مُڑ خو ب وَسائی (پتھراں دی بارش کیتی)،تَک لے (ویکھ لے) مجُرم لوکاں دِی ،اے اَنت ہوندی اے(اےاَخیر ہوندی اے)
  7,85,مَدین وَل شُعیب اَسی سِی گھَلیا اوہناں دَا ای لَگدا ، اوس کہیا، اے لوکو کَرو عِبادت رَب دِی ،ناہ مَعبود تہاڈا کوئی اِس دے باجھوں تے اِک تے گل پکی رَب تہاڈے وَلوں آئی وَل تہاڈے،یعنی رکھو سُچامِن تول اَپنا (ناپن دا پیمانہ تے وزن)،ناہ لوکاں دِی چیزاں دے وِچ گھَپل مچاؤ، رَولے ٹھیک ہو جاون تے ناہ گڑ بڑ فیر جگاؤ،خیر تہاڈی ایسے وچ اے جے ایمان تہاڈے اندر
  7,86,تھَڑے ناہ دیوو، رَاہیں اُتے،ناہ دَھمکاؤ، ناہ اَللہ دے رَستے ڈَکّو (روکو) رَب نوںمَنّن وَالڑیاں تے پُٹھے پاسے اوہناں نوں پا دینے واہتے،یَاد کَرو تَعداد تہاڈی جَد تھوڑی سِی ، اَساں تہانوں وَادھے پایا،(بہُتا لیتا)، ایِبھی ویکھو اَنت ہوندا کی گَڑبڑَیاں دا
  7,87,جے ہے اِک دِھر تہاڈے وِچوں اس نوں مَنّن والی جو کجُھ آیا میری راہیں، تے اِک دِھر ناہ مَنّن والی تے فیر اُڈیکو ساَڈے اَندر اَللہ وَلوں جَد نیاں(فیصلہ) ہو جاوے،تے اوہ ہے نیائِیں(فیصلہکرن والا ) سَب توں چَنگا
  7,88,قوم اوس دِی دے آ کڑ خاں اِیہہ گَل آکھی شُعیب اَساں چِک دیساں (کڈ دیساں)تینوں اِپنے پِنڈوں(بستی توں) نالے تیرے سَنگ پَالاں نُوں یاں مُڑساڈے وَاڑے وَڑنا پیسی (ساڈی ملت وچ واپس آنا ہوسِی) اوس کہیا جے دِل ناہ سَاڈا مَنّے(دل ساڈا ناہ تسلیم کرے فیر وی)
  7,89,انج کرئیے ، تے اَللہ بارے کوڑی تانی تنیئے(اَللہ تے جھُوٹھ گھڑن والے ہوئیے )جے اوسے اِی وَاڑے وَڑئیے(اوسے ملت وچ فیر داخل ہوئیے) جِس توں اَللہ آپ بچایا ہے سی سانوں ایہہ سَانوں زیب ناہ دیووے فیر اُودھر نوں مُڑئیے، ایہہ ناہ اَللہ مالک ساڈا ہرگز چاہے ،عِلم اَساڈے رَب دَا ہے وے ہر اِک شے نوں وَلّی کھَلوتا (ہَر شے نوں گھِیرے وچ لِتّا ہوا اے)۔اَساں توَکّل اُس تےکیتا،رَبّا ساڈے تے ایس قوم اَساڈی دے وِچ کَردے توں نَکھیڑا سچّا(بہترین فیصلہ) ،توں ای ایں چَنگائیں نکَھِیڑا کَرنے والا(توں ای بہترین فیصلہ کرن والا اے)
  7,90,قوم اِس دِی دے کَفروناں چوں سِر کڈھیاں اِعلان اِیہہ کیتا،جس کِسے وی راہ شُعیبی مَلّی(شُعیب دی پیروی کیتی) سَمجھو گھَا ٹا کھَادا
  7,91,تے اوہناں نُوں آن بھُہچالے نَپیا (اِک دل ہلا دین والی آفت آپھڑیا )تے اوہ اَپنے اَندراں(گھراں) وچ ا ی مُوندھے ہوگئےـ
  7,92,گَل شُعیب نَبی دی نُوں جھُٹھیارن والے۔انِج ہوئے جیئوں اوہ اوتھے ہوندے اِی ناہ سِی،گَل اوہدی جھُٹھیارن والے گھَاٹا کھَانے وَالے ہوئے
  7,93,اوہناں توں اِک پاسے ،اوہ اِیہہ کہند ا ہویا،لوکو میں اَپڑا (پہنچا) تہاڈے تک دِتّی گَل تُہاڈے رَب دِی نال تہانوں مَت(نصیحت ) وی دِتّی،ہُن جھُراں تے کِکَن جھُراں(افسوس کراں) میں ا َن مَن لوکاں دے حال اُتّے(حق دے منکر لوکا ں دے حال تے)
  7,94,نَبی اَسی جَد کَدی وِی، کِدھرے گھَلّے ،پہلاں اوتھے دے وَسکیناں تائیں مَالی ،جاَنی بَد حَالی وِچ پایا، تاں جے عجز اوہناں وِچ آئے
  7,95,دُکھ اوہناں دے جَد وِی سُکھاں وِچ بدلائے تے اوہ پھَلن پھُلن جد لگے تے آکھن لگے غَمی خُوشی تے سَاڈے وَڈیاں نے وِی سِی ہنڈائی(وڈیاں تے وی آئی) فیر اوہناں نُوں پَکڑ ہوئی ،اَچانک ہوئی اوہناں دے جو چِت ناہ چیتے(اوہناں دے گُمان وِچ ناہ سی)
  7,96,تے جے اوہ نَگریک(بستی والے) اِیمان لیائے ہوندے تے اَللہ دَا جھَاکا رَکھدے،اُوہناں اُتے دَھرتی تے اَسماناں دَی ہَر رحمت دے کھُل جاندے بوہے(دروازے) سَاڈےوَلوں ، پَر اوہ تے انکاری ہوئے تے اوہناں دے کَرتوتاں توں پکڑاَساں اوہناں دِی کیتی
  7,97,تے کی گوٹھاں دے وَسکیناں خوف دِلوں ایہہ کَڈھ چھَڈیا سِی جے اوہناں تے رَاتو ،رات اوہناں دے سُتیاں(سوئے ہوئے)، آ، عذاب اَساڈا جَاسِی
  7,98,یاں نَگریک(بستی والے) اوہ سِی بے فِکرے، اِس توں جے اوہناں تے غَضب اَساڈا دِنّو ،دِنّی (دن دے وقت) آسَکد ا اے جَد اوہ ،رَنگ رَلّیاں دے وِچ ہووَن
  7,99,کی اَللہ دے مَنصوبے تو ں بے چِنتے(بے خوف) سَن،اَللہ دے منصوبے توں بے چِنتے گھَاٹل (نقصان اُٹھاوَن والے) لوکی اِی ہو سَکدے نیں
  7,100,کی ایس وِچو ں مَت (نصیحت)اوہناں نُوں لَبھدی (مل دی )ناہیں۔اَسی جِنہا ں نُوں وَارث کیتا ایس بھوئیں دا ،پہلے وَسکیناں توں پِچھے،جے اَس چاہندے ۔اَسی اوہناں دے پَاپَاں پَاروں تَونِی(سزا دیندے) اِہناں نوُں لا دیندےتے قَلباں تے ٹھَپے لاندے تے اوہ سَمجھَن توں رہ جاندے
  7,101,سِی نَگر اوہ اِنج دے ۔اَسی جَنہاں دے کجُھ قِصّے دَس دِتّے تینوں، اوہناں کول رَسُول اوہناں دے لے کے نَال نَتارے آئے (کھلی نشانیاں)، پَر اوہناں نوں کِنج اوہ مَن دے کَل جِنہاں تے مُنکر ہوئے،اَللہ اِنجے کَفروناں دے دِلاں تے ٹھَپے لاندا
  7,102,چَوکھے اوہناں دے وِچوں گَل دے کچَے، تے ناہ ڈِٹّھا بُہتڑیاں نوں گَل تے پہرہ دیندے
  7,103,فیر اَسی اوہناں دے پِچھے موسٰی گھَلیا،فِرعونے تے اوس دیاں سَرداراں وَلّے،آیات اَپنی دے کے،اوہناں توں اوہ اَوکھے ہوئے تے توں تَک(ویکھ)لے کی اَنجام اوہناں دَا ہویا، جیہڑے رہے سِی گَڑ بَڑ کَردے
  7,104,موسٰی ؑ نے فِرعونے نُوں اِیہہ دَسیا ہے سِی ،میں رَسُول آں جَگ دے رَبس دے وَلّوں،
  7,105,میرے تے اِیہہ لازَم ہے وے اَللہ دے بارے ج و آکھاں ،سَچ آکھاں،میں تہاڈے رَب دے وَلّوں، گَل نَتاڑو (دلیل والی)لے کے آیا تے کَر اِسرائیل کیاں نُوں توں حَوالے میرے
  7,106,اوس(فرعون)کہیا توں لے کے جیہڑی ہیں نتاری ہاری آیا(نشانی لے کے آیا) دَس اَسانوں جے سَچّا ایں
  7,107,اس تے موسٰی عَاصَا سَٹیا، ہوبہو دا ،نَانگ(َاژدھا) لَگیا
  7,108,ہَتھ کَڈیا تے تَکدیاں نُوں اوہ نُورانی َلگیا
  7,109,پَر فِرعونی قوم دے سِر کَڈیاں نے اَگوں اِیہہ کہیا جے،اِیہہ کوئی گُنیا (ماہر)جَادو گَر اے
  7,110,تے ایس دی ایہہ نیت لگے ،ایہہ تہاڈی مل دے (زمین)وِچوں کَڈھ دے اوہ تہانوں، دَسّو کی صَلاح تہاڈی
  7,111,آکھن لگے ٹَالے ٹُولے کولوں تے کَم اَجے تے لئیے دوآں نال ای،تے شہریں چاہو کے گھَلیئے (شہر شہر ہرکارے گھلیئے )
  7,112,جیہڑے گُنیے مَاندریاں (ماہر جادوگراں )نُوں لے آوَن
  7,113,تے فِرعونے کو آپہنچے جاَدوگَر اوہ، آکھن لگَے جے جِت جائیے ،اَجر اَساڈا حَق بَندا اے(چنَگا چَو کھا)
  7,114,اوس ہاں کیتی ،نالے گوڈے مُنڈیاں وِچوں ـ(مُقرب لوکاں وِچوں)کَرنے دِی وِی گَل سُنائی
  7,115,اوہناں کہیا موسٰی بھاویں توں سَٹ پہلاں بھَاویں دَیہہ اَسانوں وَاری ،اُوس کہیا جے وَار تہاڈی پہلی سَٹ دِی
  7,116,تے جد سَٹ اوہناں نے کیتی تے لوکائی (لوکاں) دِی اَکھاں نوں اِنج بَنھ لیئو نیں (انج نظر بندی کیتی) تے اوہ رہ گئے ڈر کے تے خوب اوہناں نے جادو دَسّیا
  7,117,موسٰی نوں اَساں اِشارہ عَاصَا سَٹن دا کر دِتّا،تے اوہناں دے بھُچلاوے(جھوٹھے طلسم )مُونھ اوہنے پائے (نگل گیا)
  7,118,انج ہوئی گَل سَچ دِی اُ چّی،تے بےاَثری اوہناں دِی سَب ،کِیتی ہوئی
  7,119,اِنج اوہناں دِی کَنڈاں لَگیاں (اوہ مغلوب ہوئے) تے اوہ اُلٹے پچی ہوئے (ذَلیل ہوئے)
  7,120,جَادُوگَر اوہ، ہَاراں مَن گئے تے سِجدے وِچ جا ڈِگّے اوہ،
  7,121,اوہ بول اُٹھے کُل عَالم دے رَب نُوں مَنّیا
  7,122,موسٰی دَا ہَارون دَا رَب اے جیہڑا
  7,123,اِس اُتے فرعون کہیا جے مِیتھوں اِذن مِلّن توں پہلاں(میری اجازت توں پہلاں)۔اِنج تہاڈے مُومن تھِینے(ہووَن) توں لَگدا اے، اے اِک چَال تہاڈی ہے سِی ،وِچ نَگر دے چَلّی،تاں جے کَڈھوں وَسکیناں(ملک وچ رہن والیاں) نُوں، پَتہ تہانوں پَر لَگ جَاسِی
  7,124,میں ہَتھ ،پیر تُہاڈے آڈے کَٹّاں تے سولے تے لَٹکا دیساں سَبھناں تائیں(سَاریاں نُوں)
  7,125,اِنج گَل اوہناں پَر تائی اَگوں(جو وِی ہَووے)رَب اپَنے وَل مُڑ آئے آں ہُن اَسی تے
  7,126,توں اَساڈے تے کَوڑ(غُصہ) ایسے دِی اِی کھَاویں ،جےآیات تے اِیمان اَساں لے آندا ہے وے ،جَد ہُن کول اَساڈے آئیاں،رَبّا صَبر اَسانوں دیویں تے دُنیا توں کھَڑیں اَسانوں مُسلم ہونے دِی حَالت وِچ
  7,127,تے فِرعون دے سِر کڈھیاں نے پُچھیا کی موسٰی تے اِس دے سَنگ پَالاں نُوں توں چھُٹی دیسیں، جے لوکائی وِچ مَچاوَن اَفَراتَفری،تینوں چھَڈن ،تیرے مَعبُوداں نُوں چھَڈن ، اوس کہیا میں پُت ماری(بیٹے قتل) اوہناں دی کَرساں تے زَالاں (عَورتاں)نُوں زِندہ رَکھساں،اَسی اوہناں توں زورآور آں
  7,128,موسٰی قوم اَپنی نوں کہیا ،بوہڑ خُدا توں مَنگّو تے دِل وَڈّا رَکھو اِیہہ زَمین خُدا دِی اَپنے بَندیاں وِچوں جِس نُوں چاہے دے وِرا ثَت ا ِس دِی، تے اُوڑک(اخیر) اے مُتقّٗیاں دِی چَنگی
  7,129,آکھن لگے تیرے توں پہلاں وِی سَاڈے باب بَتیھری(بہت) ہوئی ،تیرے آیا وِی تے سَاڈے اوہوا رَولے(مسئلے مسائل)،اوس کہیا اوہ ویلا ہُن آیا کہ رَب تہاڈا جَدوں تہاڈے ویری (دشمن ) بنےّ (ہلاک کرے)،لا دیوے دَا مُلکائی مُلکےدِی اوہ دیسی ہَتھ تہاڈے(زمین تے خلیفہ بنا دیوے دا) تے مُڑ عملاں راہیں پَرکھے اوہ تہانوں
  7,130,تے فِرعون کیا نوں سَالاں بَدّھی،پیٹھا سِی کالاں دِی چَکّی(کئی سال قحط رہیا سی)،پَھل پھُل دَا وِی توڑا دِتّا (پیداوار وِچ کَمی دِتّی)شاید ہوش اوہناں نُوں آوے
  7,131,پَر جَد سَوکھے ڈِنگ آیو نیں اوہناں نوں حَق اَپنا جاتا،تے جَاتو نیں اَوکھا ویلا ،موسٰی تے اِس دے سنَگیاں دے پیراں توں آیا، حالاں اوہناں تے بَدبختی آئی ہے سِی ،اَللہ وَلوں، چَوکھڑیاں(اکژ) دِی عَقلوں ایہہ گل اُچیری(اُچی)
  7,132,رَٹ اوہناں ِدی اِیہوا ہے سی،توں نشانی بھاویں کیہڑی وِی لے آوے تاں جے سانوں توں بھُچلاویں،اَسی ناہ تینوں مَنسَاں
  7,133,تا ں مُڑ مو ت وَبائی اوہناں دے وَل گھلی، مَکڑ، چِچڑ، ڈَڈّو تے رَت(خون) بنے عَذاب اوہناں تے اِک اِک کَر کے، فیر وِی اوہناں آکڑ کیتی ، قوم اِی اوہ سِی ،اَنموڑاں(مُجرماں) دِی
  7,134,جَد کَدے وِی آؤنی (آفت) کوئی اوہناں اُتے آجاندی سِی،آکھن َلگدے کَر اَساڈے حَق وِچ دُعا توں موسٰی،کیوں جے وَعدہ نال تیرے اوس کیتا ہویاِ،جے ساڈے توں، آفت ٹالے،آکھے تیرے لَگ جاوا گے، تے کِر دیساں نال تیرے مُڑ ،اِسرائیل کیاں نوں
  7,135,پَر جَد اوہ عَذاب اوہناں توں کُجھ چِر(وقت لئی) اَسی ٹَلا دِتّاسِی جیہڑا اونج اَٹل سِی، پھِر گئے گَل توں
  7,136,فیر اوہناں نں وِچ دَریا دے غَرق اَساں کَر دِتّا تے انج وَاری لائی(انتقام لِتّا) ،ناہ آیات اَساڈی نوں گولن دے پاروں( ناہ آیات اساڈی مَن دے سِن) تے اوہناں توں بے دِھیانے رہنے پاروں
  7,137,تے اوہناں نُوں ،تھَاں اوہناں دی لے آند سِی ، چَڑھدے توں لالہندے توڑی(مشرق توں مغرب دَا وَارث بَنا دِتّا)۔ کَل ہٹھارو(کمزور) جیہڑے ہے سَن ،برَکت والا اوس علاقے نوں کر دِتّا، تے اِنج رَب ترے َگل اسرائیل کیاں دے حَق وِچ سوہنے طور نَباہی،دِل نوں وَڈّا رَکھن پاروں،تے فِرعون سنَے قوم اپنی دے ، جو کُجھ رہیا ، بَناندا ہے سِی تے سب محل چوبارے اس دے ،مَلیا میٹ بنائے سَارے
  7,138,اسرائیل کیاں دے تائیں دَریاؤں پار پُچایا، جَد اوہ اِک قبیلے انج دے کول جا اَپڑے ،جیہڑے بُت پجاری ہے سَن،آکھن لگے ،اِہناں دے مَعبود جیہا ،معَبود اَساڈے واہتے کَر پیدا، اوس کہیا ،بے سَمجھ تُسی اُو
  7,139,ایہہ جِس پاسے لگَے ہوئے اوہ فاَنی ایں، تے عَمل اوہناں دے بے حَاصل
  7,140,اوس کہیا، اَللہ نُوں چھَڈ کے میں مَعبود تُہاڈے واہتے ہُن ہَور کوئی ڈُھونڈا ں،حالاں اوسے سَب عالم توں وَدھ کے فَضل تُساں تے کیتا
  7,141,جَدوں چھُڈایاں سِی فِرعون کیاں دے کولوں اَساں تہانوں،جِنہاں تہانوں بُرےعَذاباں وِچ پایا سی ،پُت تہاڈے اوہ کوہ (ذبح کر)دیندے،زَالاں (عورتاں ) نُوں زِندہ رَکھدے،ایہہ تہاڈے اُتے اِک ازمائش بھَاری ہے سِی رَب تہاڈے وَلّوں
  7,142,موسٰی نُوں جد اَسی بُلایا ( 30 ) تیہہ رَاتاں واہتے،تے مُڑ دَس دَا ہور اِضافہ کَردے ہوئے چالی(40) دِی مَعیاد مکمل ہوئی اس دے رب دے وَلُوں۔موسٰی نے ہارون بھَرا (بھائی)نُوں ،اَپنے پَچھوں قوم اَپنی دَا ،سِی نِگران بَنایا، تاں جے رَکھے اوہ حالات سَوارے۔تے مَندیا ں(وگاڑپیدا کرن والیاں) دِی راہ ناہ جائے
  7,143,تے جَد موسٰی سَاڈی کارے وَالی (مُقرر )تھاویں آیا ،تے رَب اوس دا اُس دے نال کَلامی ہویا (اوس نال گَل کیتی)، اوس وچ سُدھر جاگی(خواہش پیدا ہوئی)،ربّا اپنے جوگا کر ،جے تینوں تَک لوَاں میں (اے رب مینوں اوہ نظر دے کہ میں تینوں ویکھا)۔رَب کہیا توں جھَال ناہ جھُلسیں(تو برداشت ناہ کر سکسیں)،ہاں تََک(ویکھ) ایس پہاڑی وَلّے، جے اوہ رہ جائے اَپنی تھَاویں(جگہ) تے توں جھَال جُھل جاویں دا،تے جَد اوس دے رَب تَجلّی پائی اوس پہاڑی اُتّے ،اوس نُوں سُرمہ کَر دِتّو سَو (رَیزہ رَیزہ کَر دِتّا)،موسٰی غَش کھَا کے ڈِگّا(گر یا ) ، ہو ش آئی تے بول اُٹھیاسِی ،جے توں تَسبیحاں دے لائق ایں ، میری توبہ ، میں سَب توں وَدھ مَنّن والا
  7,144,رَب کہیا ، اے موسٰی میں تینوں لوکاں وِچوں چُن کے میں وے گَلمے لایا ہے (منتخب کیتا)رَسالَت تینوں دِتّی، تیرے نال کَلامی ہویا، تے ہُن لے جو تینوں دِتّا ۔تے ہو شُکرگَزاراں وِچوں
  7,145,تے اَساں سَن اوہدے واہتےتخَتڑیاں (تختیاں) دے اُتےلِکھیاں ہَر کَم بارے مَتُاں،(نصیحتاں) تے تفصیلاں ہر کَم بارے ،پَکیاں کرَکے (مضبوطی نال) اَسی کہیا ،اِہناں نُوں نَپنا(پھَڑنا) تے قوم اَپنی نُوں وِی کہنا، وَل طرح اِہناں نوں نپَے،میں تہانوں نافَرناں دے وِی ڈیرے (گھر)دِکھلا دیساں تھوڑے چِر نُوں(عنقریب)
  7,146,اوہناں دَا آیات میری نال تَعلق کاہدا۔ جیہڑے ایویں دَھکو دَھکی بَن بَن بہندے نیں جَگ اَندر ،اوہ مول ناہ مَنسَن(ایمان ناہ لیاسن) کُل اچر جان(ساری نشا نیاں) تک (ویکھ) لوَن اوہ بھَاویں،سِدھے رَستے نوں تَک کے وِی اوہ ناہ پھَڑسن (ناہ اختیار کرسن) اُس نوں ، تے جے پُٹھا پاسا تَکسن اوسے نوں راہ اپنی گِن سَن،کیوں جے اوہناں نے آیات اَساڈی توں مونھ موڑی کیتی تے بے دَھیانی وَرتی
  7,147,تے اوہ لوک جِنہاں آیات اَساڈی توں مونھ موڑی کیتی تے رَب دے اَگےپیشی نوں ناہ مَنّن۔اُوگت اوہناں دی سَب کیتی(سارے اعمال ضائع ہوگئے)۔اَپنے عَملاں نالوں وَکھ توقع کی رَکھ سَکدے
  7,148,تے موسٰی دے لوکاں اِس دے جانے پِچھوں،گہنے گالے تے گھَڑیا اِک وَچھا(بچھڑا) بڑھکن والا(نکل دی سی اوس وچوں وچھے دی آواز)،کی ناہ دِسیا(نظر ناہ آیا)سی اوہناں نوں اوہ ناہ بولے نال اوہناں دے،ناہ اوہناں نوں راہے پائے(مُڑ وی )اوس نوں پُجن لَگ پئے (عبادت کرن لگے)تے اوہ ظالم سَن)( اوہناں کَم ماڑا کیتا)
  7,149,تے جَد آخر اوہ وَچھّا اوہناں دِی نَظروں ڈِگّا ،تے مَعلوم اوہناں نوں ہویا جے اوہ بھُلے،بول اُٹھے جے ناہ رَب اَساڈا رحم کرے ہُن ساڈے اُتّے،تے ناہ بھُل اَساڈی بھُلے،ساڈےپَلّے کَکھ ناہ رہسی
  7,150,تے جَد موسٰی قوم اپنی دے وَل واپس آیا،روہے روہے(غصے) وِی ا وہ ہویا تے جھُریا وی(رنج وی ہویا) ، اوس کہیا جے میرے پِچھوں،میری تھَاویں ،کَم تُساں اِیہہ ماڑا کیتا،رَب اَپنے دَا قہر بُلانے دِی سِی اینی سَوڑ (جلدی)تہانوں ،پٹیاں(تختیاں) نوں اوس پاسے دَھریاں(رَکھیا) تے بھائی نوں اوس پَٹیاں توں نَپ کے (وَالاں توں پھَڑ کے) اَپنے وَل دھرونی دِتّی(اپنے وَل کھِچیا)،اوس ہارون کہیا اے ماں جائے،اِہناں لوکاں مینوں کجُھ ناہ جاتا(سَمجھیا)،اِیہہ تے مینوں تھَاں مارن تک جا اَپڑے سَن، ویری(دشمن)لوکاں نُوں ناہ موقع دے توں میرے تے ہَسن دا،تے ناہ گِن توں مینوں حَد ٹَپلاں دے وِچوں
  7,151,موسٰی فیر دُعا اے مَنگی،رَبّا مینوں سنَے(ساتھ) بھَرا(بھائی ) دے بخشیں،سَانوں اَپنی رحمت دے سائے وِچ رَکھیں،توں سَب رحم دکھاوِن والڑیاں توں وَدھ کے رحم دِکھاویں
  7,152,تے وَچھے نُوں پُجن والے ، اَپنے رَب دے غُصے ہَیٹاں اَج آئے ، کَل آ ئے،دُنیا وِچ خَواری تَکسن، کوڑ ا ُساری کَرنے والے(جھُوٹھ گھَڑن والے) اِنجے اَپنی کیتی پاندے
  7,153,پَر اوہ لوک جِنہا ں دے کولوں مَندیائیاں(بُری گَلاں ) تے ہوئیاں، تے مُڑ اوہناں توبہ کیتی تے ایِمان لیائے(اوہناں واہتے) رَب تیرا ہے بَخشنہارا تے رحم دِکھاون والا اَگوں واہتے
  7,154,ٹھَنڈا ہویا جَد موسٰی دَا غُصہ تے اوس لَوحَاں چَائیاں(تختیاں چُکیاں) اوہناں وِچ ہَدایت بھَریاں رحمت بھَریاں تِحریراں سِن اوہناں واہتے رَب توں جیہڑے ڈَرنے والے
  7,155,مُڑ موسٰی نے سَتر بَندے قوم اپَنی چوںچھانٹے ،سَاڈے کارے دی تھاں واہتے(تاں جے سَاڈے مُقرر وقت تے حاضر ہون) تے جَد پَکڑ بھُچالے کیتی (زلزلے نے آپھَڑیا)،موسٰی عرض گُذاری،رَبّا توں چاہندا تے ایس توں پہلاں اِہناں نوں وِی تے ،مینوں وِی ، جانوں لے سَکدا سِی، کی ہلاک اَسانوں توں ہُن کَرنا چاہیں،سَاڈے وِچدے بے عَملاں دے ،عَملاں پاروں،تیرے وَلوں اے ازمائش لَگدی ہے وے جِس نوں چاہیں اس دی راہے بھُلے پا ئیں،جس نوں چاہیں راہے پائیں،توں اِی سَاڈا اے سِر سائیں، بَخش اَسانوں کَر توں رحم اَساڈے اُتے،توں ایں سَب توں وَدھ کے ہے وے بخشنہارا
  7,156,سَاڈے لَیکھیں لِکھ دے(ساڈے نصیب وچ کر دے ) ویل ا وَل اَساڈا ٹپَے(چنگا ویلا ساڈا گزرے) کی اِیتھے کی اوتھے،تیرے وَل اَساں مُونھ کیتا، تے اَللہ فرمایا میں عَذاب اَپڑاواں(دیواں) جِس تَک چاہواں،ہے پر میری رحمت دے گھیرے وچ ہر شے،تے اوہ دونویں سُکھ مقد ر اوہناں دَا میں کَر دیواں دا، جیہڑے جھَاک خُدا دِی رَکھسن۔رَب دے ناں(نام ) دِا دیسن (اللہ دی راہ وچ خرچ کرسن )تے آیات اَساڈی مَنسَن
  7,157,اوہناں دے وِی ،جیہڑے پچِھے اوس پیغمبر دے ٹُرسن،ہے وے نبی تے اُمّی جیہڑا ،تے گل جس دی ہے تورات ،زَبور اَندر وِی، اوہ اوہناں نُوں مَت دیندا اے چنَگے کَم دِی، تے مَندے(بُرے کم) توں ٹَھاکے(روکے) تے پاکیزہ چیزاں کھانے نُوں ناہ ٹَھاکے،ہاں گَندیاں توں ٹَھاکے، بھَار (بوجھ) اوہناں دَا ہَولے (ہلکے)کَردا،نالے گَلوں(گلے توں ) گَلاویں لاہندا (بَندشاں کھولدا )،اوہ جنہاں وِچ پھاتھے(جکڑے )ہوئے اُس تے آکھے لگن والے، اُس دی حامی بھَرنے والے،اُس دَا سَنگ نَباہنے والے، اُس دے اِس چانن(روشنی) دے اندر ٹُرنے والے جیہڑا اِس دے نال آ یا اے،بامُراد اوُڑک (آخیر)نوں ہوسنـ(اوہو افلاح پاسن)
  7,158,اے محمد ؑ لوکاں وچ اِعلان ایہہ کَردے ،میں رَسُول تہاڈے سبھناں وَل آیا ہاں، اَللہ وَلّوں،اِیہہ اَسمان سنَے دَھرتی دے مَلکیت نیں جِس دِی،ناہ مَعبودکوئی بِن اوس دے، اوہ جَوائے (زندگی دیندا اے) اوہو ا مَارے، ایس کر کے اَللہ نوں مَنّوں نالے اِس دے پیغمبر نوں ہے نَبی تے اُمّی جیہڑا،تے اِیمان اَپنا وِی اوس دَا ،اَللہ اُتے ،اوس دِی سَب گھَلاں(ارشادات) اُتے،ویکھو اوس دے پِچھے لگو ،تاں جے پے جاؤ رَاہے،
  7,159,تے موسٰی دِی قوم اَندر وِی لوکی جیہڑے، حَق پاسے لاندے (حق دے مطابق ہدایت کردے)تے حقَے اِی اوہ نِیاں(انصاف) وِی کردے
  7,160,باراں اَساں قبیلے اوہناں دے کر دِتّے ،تے اوہ قوموں قومی ہوئے،قوم اپنی دے واہتے موسٰی ،جَد پانی دا، تَرلا پایا، مَت (صلاح) اَساں اِی دِتّی،ٹُر جا اُوس پہاڑ وَلّے عاصے دے سِر تے،اوتھے بارا ں چَشمے پھٹدے (لبھے)،ہر قبیلے پَن گَھٹ (پانی دا مقام )اَپنا جان لیا سِی،اَساں اوہناں تے بَدلاں دَا سایہ کَر دِتّا تے مَن ۔سَلوَا (قابو و وچ) وَس اوہناں دے،کھاؤ اِہناں پاک پوِتَّر چیزاں وِچوں ،اَساں جِنہاں نُوں پُہنچ تہاڈی وچ کَر دِتّا(نافرمانی کرکے اوہناں) کی نقصان اَساڈا کیتا، اَپنا اِی نُقصان ہویو نیں
  7,161,اوہناں نوں جَد اِک نَگر وِچ رہنے دِی جَد مَت(صلاح) سِی دِتّی،تاں جے مَن مَر ضی دَا اُوتھوں کھَاوو ،ہاں حِطَّہ،کہندے ہوئےشُکرانے وچ سیس نَواندے(متَّھا ٹیک دے ہوئے) وَڈّے پھَاٹک وِچوں جاؤ، اَساں ُتہاتھوں ہَوئیاں بھُلاں ، بھُل جَاواں دے، بَلکہ ہَور اوہناں نوں دیساں، جیہڑے نیکی پہچانن دے
  7,162,اوہناں وچ دے نافرماناں،لفظ اَساڈے دَسّے(کہے )ہوئے بَدلا (تبدیل کر)ِدِتّے، اوہناں دِی نافرمانی دے پاروں اِی،اوہناں وَل عذاب اَساں اَسمانوں گھَلیا
  7,163,دَریالے دِی سروَرتی(دریا دے کنارے دی بستی) دِی وِی پُچھ ، ذَرا توں لوکاں کولوں،سَبت دِہاڑے ہَیرا ،پھیری اوہ کَر جاندے، کیوں جے اوس دِن مچھلیاں دِی کانگ آجاندی سی، چَک سِراں نوں (پانی دی سطح تےاُبھر کے) ،اَگے پچھوں ناہ اوہ آوَن۔اِنج اوہناں نوں ازما ئش وِچ پا دِتّا سِی، کیوں جے اوہ سِی حُکم عَدولے(نافرمان)
  7,164,اوہناں وِچوں اِکنّاں نے (اِک گروہ نے) جَد اِیہہ گَل کیتی،کاہنوں اوہناں نوں پئ ے مَتّاں دیندےہے او،اَج ،کَل وِچ اَللہ ہے بَرباد جِنہاں نُوں کَرنے والا یا کوئی ڈاہڈا ہَور عذاب ہےدیوَن والا ، اوہنا ں کہیا ۔رَب تُہاڈے اَگے ،سَچے تے ہو جَاساَں،تے ممکن ہے خوف خُدا دَا جاگ پَوَے نیں
  7,165,پَر جَد اوہناں گَل ناہ گولی(ہدایت نوں فراموش کر دِتا)، اَساں وَلایا (بچایا) بَدیوں ٹھَاک(رُوکدے) رَہے سِن جیہڑے اوہناں تائیں،تے اِک بڑے خراب عذابے دِی صورت وِچ پَکڑ اوہناں دی کیتی۔حَدّاں ٹپن پاروں
  7,166,تے جَد ٹھَاک اَساڈی نُوں ناہ اُکّا پَلّے بَدحا،تے اَساں کہیا ہُن بے اَبرائے(ذلیل) بندرِیلے اِی ڈَنگ ٹَپاسَو(ہن ذلیل و خوار ہوکے ،باندر بن کے وقت لنگھاسَو)
  7,167,تے رَب اِیبھی جَتلا دِتّا جے، ہُن تا قیامت وَاگ اوہناں دِی اوہناں دے ہَتھ رَکساں جو اِہناں دَا ڈاڈھا ماڑا حال کَرن دے،بے شَک رَب تیرا، ناہ ڈِھل ذَرا وِی لاندا، پھہنٹی چاڑن وَاری(سزا دیندے ویلے) بھاویں اونج غَفور رحیم اے
  7,168,تے اوہناں نُوں پھَاڑی پھَاڑی کَر دِتّا دُنیا دے اُتے،اوہناں دے وِچ چنَگے وِی نیں ، مَندے وِی نیں،اَساں اوہناں نُوں اَوکھے،سَوکھے وَقت لِیا کے اَزمایا سِی، ہو سَکدا اِے موڑا کھَاوَن(پلٹ جان)
  7,169,پِچھوں گَدّی ناخَلفاں نے سَانبھی،اوہ کِتاب اَللہ دے وَارث ہوندے ہوئے،رہے دُنیا اِی جھولی پاندے تے اِیہہ کہندے اوہ بخشیوے جاسَن ،ہور وِی دولت نظر پَوَے تے نَس(دوڑ) کے نَپّن (پھڑن)۔کی کِتاب اِلٰہی دَا اِ یہہ قول اوہناں توں لیا نئیں سِی ،رَب دے کھاتے حَقی سَچی گَل اِی پاؤ ،اِس وِچ لِکھیا آپوں وِی نیں پَڑھیا ہویا،یعنی خوف خُدا دَا رَکھن وَالڑیاں دے واہتے ،چھیکڑ(آخرت) دَا گَھَر چنَگا،کیوں ناہ عَقل تہانوں آوے
  7,170,جیہڑے پَکیاں ہین کِتاب اَللہ دِی پھَڑدے،تے پابند نَمازی ہے نیں،اِنج دے نیکوکاراں دَا ناہ اَجر کَدے وِی ضائع ہوسِی
  7,171,تے جد اَساں پہاڑ اوہناں دے سِر تے چھَتری وَانگ ہلایا اوہ سَمجھے اِیہہ اوہناں دے اُتے ہُن ڈِگّا، ہُن ڈِگّا (اَساں کہیا سی اوتھے)جو کجُھ اَساں تہانوں دِتّا، نپَنا پیڈا کرکے(مضبوطی نال پھَڑنا) تے جو کجُھ اِس دے اَندر اِس دے چیتے رَکھنا(یاد ر؟کھنا) ،ہوسَکدا اے جھاک رہوے جے رب دِی(ہو سکدا اے تُسی غلط کماں تو بچ جاؤ)
  7,172,تے جَد رَب تِرے نیں آدم جایاں(بنی آدم ) دِی سِی پُشتوں اوہناں دی اولاد وَدھائی (کڈھی) تے اوہناں توں عہد لیا سِی تے اوہناں نوں اوس گوا ہ ٹہرایا اِک دوجے دے اُتے،(ایہہ گل پُچھ کے) کی میں واں رَب تہاڈا، آخو(ہاں) کہہ کے اوہناں مَنّیاں(اقرار کیتا) ،ایہہ اِس پاروں سِی جے ،کِدھرے روزِقیامت ،عُذر ناہ ڈَاہو (کرو) سَانوں ، اِس دِی خَبر نئیں سِی
  7,173,یا ں اِیہہ آکھو شِرک اَساڈے پیو دَادا نیں کیتا ہے سِی۔اَسی اوہناں دے جَائے (اوہناں دی نسل)،اوہناں دے بَعد آئے،کی مُڑ تُوں ہَلاک اَسانوں باطَلیاں دِی کَاروں کَرسیں (غلط لوکاں دے کَمَّاں تَوں کَرسیں)
  7,174,اِنج اَسی آں کُھل کے اَپنی ہَر گَل دَسدے ،شاید لوکی مُوڑا کھاوَن(پلٹ آون)
  7,175,اے محمد ؑاِہناں اَگے اونج دے بندے دِی گَل کَر خَاں ،جِس دے کول اَسی لےآئے آیات اپنی، تے کَنّی کَترَاندا ہویا اوہناں کولوں اوس شیطانے د َا لَڑ ا وس پھَڑیا تے گُمراہواں دے سَنگ رَلیا
  7,176,اَس چاہندے تے اِہناں رَاہیں او س نوں اُچّاکر سَکدے ساں،اے پَر اوس دِی جھوک (جھکیا) ہمیشہ مِٹّی وَل سِی، تے اَپنی لَلچاوٹ دے پچِھے ٹُریا،حال اوس دَا اے کُتّے وَرگا، ڈَر کَارو (حملہ کرو) یاں ناہ ڈَر کارو (ناہ حملہ کرو)جیبھ (زبان)اوہ کَّڈی رَکھسی،تے آیات اَساڈی نوں ناہ پلّے بنَھن والی ساری قوم اِی جے َکر ہووے ،گَل اوس تے اِہوا ڈُھکّے(جَچدی اے)،پَر اِیہہ مَتّاں(گلاں) اوہناں دے کَن پاندا ،رہ تُوں ،ہو سَکدا اے،سَوچ اوہناں دے اَندر جاگے
  7,177,اوہناں تَوں وِی لوک اوہ بھیڑے(بُرے) جوناہ آیات آِساڈی نوں جو پلّے بنَھن، اوہ اَپنے نال (ظلم ) دَھکّے کَردے
  7,178,جِس نُوں رَب ہدایت دیوے،اوسے نوں اِی ملے ہدایت،جس نوں اوہ توفیق ناہ دیوے اِس دِی، اوہ گھاٹل اِی ہوندے(ناکام ،نامُراد )
  7,179,جنّا ں تے اِنساناں دے وچوں کِنّے اِی نیں اَساں ، جِنہاں نوں دوزخ واہتے اِی پیدا کیتا،عَقل اوہناں دے کول پَر اوہ اِس توَں کَم ناہ لیندے،لوئیں(اَکھاں) ہے نیں پَر اوہناں توَں کَم ناہ لیندے ،لینے والا،کَن ہے نیں پر سُندے ناہیں،(مَت ذرا وی ناہیں) اوہ ڈَنگر دے ڈَنگر ،بلکہ اوہناں نالوں وی دَو رَتّی وَدھ کے، غَفلت وِچ اوہ ڈُبّے ہوئے،
  7,180,اَللہ اِی ہے چنَگیا ںصِفتاں والا، اوہناں نال چتَارو(پکارو) اُس نُوں،جو اوس دِی صِفتاںوِچ گھَپلے کَردے، کَرو کَنارہ اوہنا ں کولوں،اوہ اَپنے کَرتوتاں دَا پھل پاکے رہسن
  7,181,تے مَخلوق اَساڈی وِچوں اوہ بھی نیں حَق دِی راہ تے جیہڑے لوکاں نوں لاندے نیں،تے لاندے نیں اوہ کَچہری حق دی
  7,182,تے آیات اَساڈی نُوں سَچ جِنہاں ناہ جاتا، اَس اوہناں نُوں ہولی ہولی (کھَڑے والے پاسے )کھَڑساں ایس طرح جے اوہناں نوں اِحساس ناہ ہوسِی،
  7,183,ڈِھل اوہنا ں نوں دیندا جاساں، پر اے چاَل پَکیری (پکی)میری
  7,184,کی سَوچن ناہِ، پَکڑ کِسے جِنّ اوہناں دے ،سَنگی نُوں ناہ کیتی ہوئی،اوہ تاں کھُلم کھُلا ہوڑَن ،ہَٹکن والا(برے اَنجام توں دار کرن والاتے ڈَران والا اے)
  7,185,کی خیال کَدے ناہ ا وہناں اِیدھر کیتا، کَاروبار اِیہہ دَھرتی تے اَسماناے دَا ہے وے ،تے ہر شے جیہڑی اَللہ نے خَلقائی ہوئی، دوجے پاسے اِیبھی مُمکن اوہناں دے ڈَنگ(سانس) پورے ہونے والے ہووَن تے اِس پِچھوں اوہ اِیمان لیاسَن، کیہڑی گَل تے
  7,186,اَللہ جِس نُوں رَاہوں اِیدھر اُودھر کردے کون ہدایت اوہنوں دیوے،اِنج دیا ں نُوں چھَڈ دیندا اے اَللہ۔ اوہناں دِی اَپنی اِی گُمراہی دے وِچ، بھَنبھل بھُوسے کھاوَن واہتے
  7,187,تینوں پُچھدے کَدوں کَدے اوہ ساعت(قیامت) آسِی،کہہ دے اوس دَا عِلم خُدا نُوں،و یلے سِر اوہوا ای ،اوس نوں لے آوے دا، دَھرتی تے اَسماناں واہتے اوس ویلے نے بھَارا ہونا۔تے اوس اُچن چیت (اچانک )تہاڈے تے آجانا،تینوں پُچھدے جِویں توں ایسے کھَوجے لگَّا،مُڑ ایوا اِی کہہ جے اِس دَا عِلم خُدا نُوں ، چوَکھے لوکاں دے پلّے ،اِیہہ گل ناہ پینے والی ہے وے
  7,188,اے محمد ؑ کہہ دے میں تے اَپنے حَق وِچ ناہ وَاہدا(نفع) ناہ گھَاٹا (نقصان)ہے واں کَرنے جوغا(کر سکن والا)،اُس توں ہَٹ کے جو اَللہ دِی مَرضی ہووے،تے جے کر میں غَیب دَا جانَن والا ہوندا ، چنَگا چَوکھا اَپنے واہتے کَٹھا کَردا، تے ناہ اَوکڑ (نقصان) وی ٹَوہ سَکدی مینوں،میں تاں ہوڑَن، ہِٹکن والا ہے واں(خَبردَار کَرن والا آں)،نالے آس دِلاوَن والا ،مَن ٹُریاں نوںـجیہڑے میری گَل مَن دے نیں)
  7,189,اِیہہ اوہوا ہے جِس نے تہانوں اِک اَصلوں پیدا کیتا، تے اوسے دے وِچوں اوس دَا جوڑا بنایا تاں جے اِس دے نال وَسے،نر(مرد) دے ناری(عورت) نُوں کَجّن(ملا پ ) تَوں، بھاَر جیہڑا اوہ اِک چاہ لیندی، لےکے جِس نُوں پھِردِی رہندی،تے جَد اوہ بھَار اوہ بھَارا ہووے ،اِیہہ دُعا اوہ کَر دِی اَللہ اَگے یعنی اَپنے رَب دے اَگے جے کَر جِی(بچہ) نَرویا(اچھا)سَانوں دیویں،تیرا دین(دینا) گِنا دیں(تیرے شُکر گزار ہوواں دے)
  7,190,پَر جَد بال نَرویا (صحیح سالم بچہ)اوہناں نوں رَب دیوے،اِیس دینے وِچ سِیری(شریک) ہَوراں نُوں وِی مَنّن ،اَللہ اِس تَوں بہت اُچیر (بلند و بر تر)جے اوہ محتاج سِیر (شریک))کِسے دَا ہووے
  7,191,کی اوہ گِنّن (کہن )سِیری (شریک)اوہناں نُوں جو ناہ خَلاقائے جوغے (جو کجُھ وِی تَخلیق نئیں کَر سَکدے) تے آپوں خَلقِیوے ہوئے(بلکہ خود تخلیق کیتے گئے نیں)
  7,192,ناہ اَپنے جوغے جو اِمداد کَرن اوہناں دی،اوہ تاں اَپنی وَی ناہ کُجھ سَوارن جوگے(اوہ تے اَپنی مَدد وِی نئیں کَرسَکدے)
  7,193,جے توں اوہناں تائیں سَدّیں (بُلاوے) سِدّھے پاسے(سدھی راہ تے) اوہ ناہ آکھے لَگّن، ہے برابر اوہناں نُوں سَدّنَا تے ناہ سَدّنا(پکُارو یاں ناہ پُکارو)
  7,194,اَللہ تَوں وَکھ ،جِنہاں اَگے تُسی عِرض گُزار ہوندے اوہ مُحتاج تہاڈے وَرگے،اوہناںاَگے عَرضاں کَر کے ویکھ، جے سچے او تاں، اوہ سُنن عَرض تُہاڈی
  7,195,کیہڑی پَیریں(پیراں) اوہ ٹُردے(چَلدے) نیں،کیہڑی ہَتھیں(ہتھ) اوہ کجُھ پھَڑدے(پکڑدے نیں)، کیہڑی اَکھیں(آکھ) تَکدے (ویکھدے)نیں،کیہڑی کِنّیں(کَن) اوہ سُندے نیں،اوہناں نُوں لَلکَر کے کہہ دے،سَد لوَو(بلاؤ) اِیہہ سَارے سِیری(شریک) اَپنے،تے سَارے وِنج چپّے لا لئو(تدبیراں کرلوَو)،ڈِھل د یئو ناہ مینوں اُکّا
  7,196,میرے سِر تے اِیہہ کِتاب اُتارن والا اَللہ ہے وے، تے اوہ نیکوکاراں دے ہَتھ سِر تے رَکھدا(وہ حمایت کردا اے)
  7,197,تُسی خُدا نُوں چھَڈکے عَرض گُذار جِنہاں دے اَگے ہووو،اوہ تُہاڈا کُجھ سوَارن جوگے ناہیں،اوہ تَاں اپَنا وِی ناہ کُجھ سَوارن جوگے
  7,198,مُڑ وی ااہناں نُوں جے سِدّھے پاسے سَدیں (بُلاوے) اوہ ناہ گَل نُوں گَولن(مَنّن)،تینوں لگدا اے اوہ تیرے وَل اِی ویکھ رہے نیں اونج اوہ تیرے وَلّوں بے دِھیاَنے ہوندے
  7,199,پَر ناہ بَنھ تُوں بھُل، کِسے دِی پلّے(درگزر کر)، تے رہ دیندا چنَگیاں مَتَّاں ، ہاں کَنّی کھِسکائی رَکھ(ناہ اُلَجھ) توُں جَاہل لوکاں کولوں
  7,200,جے شیطان کَدے کوئی چَکر تیرے نَال چَلاندا جاپے(تینوں اُکسائے) توُں لے او س توَں اُوٹ(پناہ) اَللہ دِی،اوہ سمیع اے،اوہ عِلیم اے بے َشک
  7,201,خُو ف خُدا دَا رَکھن والے جَدوں کَدے شیطان اوہناں تے چکر پیا چَلاندا جاپے،یَاد خُدا نُوں کَردے،اِنج ہَر گَل اوہناں اَگے نِتر جاندی(اوہناں نوں صاف نظرآ جاندا ،صحیح طریقہ کی اے)
  7,202,چیلے چَانٹے(شیطان دے) جاہل لوکاں نُوں بُرائی دے وَل دَھریکَن (لے جان )تُوں ناہ مَٹھے پیندے(کوئی کَسرنئیں چھَڈدے)
  7,203,لوکاں کولوں جَدوں توُں کوئی نشانی لے جاوے ناہیں، آکھن آپوں گھَڑ(بنا)لینی سِی،کہہ دے میں تاں اوہوا کَردا ، جِس دا مینوں ہے اِشارہ، رَبّوں ہوندا، اِیہہ گَلاں لَو اَکھیاں(بصیر ت دی روشیناں)دِی ہین تہا ڈے رب دے وَلوں،نالے رحمت اَتے ہدایت،مَنّن وَالڑیاں ں دے واہتے
  7,204,جے قرآن پَڑھیندا ہووے جَد وِی کِدھرے، اِس نوں سُنو تَوجہ کَرکے،چُپ ،چَاپ ہَو کے،ہو سَکدا اے رحمت رَب دِی، وَسّے(بارش وانگوں ہووے) آن تُساں تے
  7,205,رَب اَپنے نُوں تُسی چتارو(پُکارو)،اَپنے دِل وِچ زَاری کَردے ، اوس توں ڈَر دے،یا مُڑ ہونٹ ہَلاندے ،ہَولی ہَولی ،فَجری ،شَامیں، یعنی غافل لوکاں وِچوں تھِیوو ناہیں(ہوو ناہ)
  7,206,جیہڑے ہین خُدا دے نِیڑے(نزدیک) اوہ (دُنیا وِی) وَڈیائی دِی پھَنڈوں(بَڑائی دی گھُمنڈتوں)، دُور عبِادت تَوں ناہ ہَوندے،اوس دِیاں تَسبیحاں پَڑھدے ،اُوسے اَگےسجدے کَردے
  8,1,مالِ غَنیمت دے بارے پُچھدے نیں اوہ تینوں،دَسّ اِیہہ دولت اَللہ اَتے رَسُول اوس دے دِی ،ایس کر کے اَللہ کولوں ڈَردے (ایس تےجھگڑو ناہیں)آپس وِچ صُلح صَفائی رَکھو جے مومَن او،اَللہ اَتےرَسُول اوس دے دِی آکھی مَنّو
  8,2,مومن اوہوا دِل جنہاں دے کَمبَن لَگدے ،اَللہ دا ناں (نام)سُن کے،تے آیات الٰہی کوئی جَد اوہناں دے کَنّیں پاوے ،ہوراِیمان وَدھیرا( زیادہ) اوہناں دَا ہو جاوے،اوہ تَوکّل رَب اَپنے تے کَردے
  8,3,قائم کَردے اوہ صَلاتاں تے ساڈے دِتّے چوں دیندے
  8,4,سَچے مومَن اِنج دے ہوندے،رَب دے کول اوہناں دے دَرجے،بھُل کھُنج اوہناں دی رَب دھووے تے عِزت دِی روزی دیوے
  8,5,سِی رَب تیرے ٹھیک سَمجھ کے،تینوں گھَر تَوں باہر آندا،اِک وَنڈ (گروہ) نُوں ایہہ گَل ناہ وَارا کھَادی (اِیہہ گَل پسند ناہ آئی)
  8,6,اوہ ایس ٹھیک قَدم دے بارے ، تیرے نال سَن بحثے لگَّے،(بحث کرن لگے)کیوں جے اوہناں نُوں لَگدا سِی اوہ موتَل پاسے (موت وَل) ظاہرَم ظاہرا اوہ دَھکِیوے جاندے پئے نیں(اوہناں نوں دَھکّا دِتّا جا رہیا اے)
  8,7,اِنجے یاد کَرو جَد اَللہ تُہاڈے نال ایس گَل دَا سِی وَعدہ کیتا، دُونھ دِھراں چوں، اِک مَنّےدِی اِین تہاڈی (اِک تہانوں مِل جاسی)،دِل تُہاڈا اِیہہ کَردا سِی ،اوہ تُہاڈے قابو آوَن جِنہاں دے سِر سینگ ناہ ہووَن (کمزور گروہ)، پَر اَللہ دِی اِیہہ مَرضی سِی ،حَق دِی گَل اُچیری ہووے ،اَپنی آکھی رَاہیں، تے کُفروناں دی جَڑ وَڈّی جائے
  8,8,تے دُدھ دَا دُدھ تے پانی دا پانی اِنج نِترے ، بھَاویں جُرمی نَک مُونھ چَاہڑَن
  8,9,بوہڑن وَاہتے(مَدد لئی) جَد تُساں رَب اَپنے دِی مِنّت کِیتی تے اوس مِنّت مَن دے ہوئے کہہ دِتَّا سِی، پَرے بنا کے اِک ہَزار فَرِشتے گھَلْساں تے اِنج مَدد تُہاڈی کَر ساں
  8,10,ایس تَوں مَطلَب سِی اِیہہ سَاڈا ، سُکھ دَا سَاہ تُہانوں آوے تے ناہ ڈولن دِل تُہاڈے، چیتے رَکھو جِت اُنج آوے رَب دے اِی وَلّوں، بے شَک اَللہ غَلبے وَالا، حِکمت والا
  8,11,نِیندَر جَد تُہاڈے اُتّے ہے سِی سُکھ دِی طَاری کِیتی تے اَسمانوں مینھ وَرسایا تاں جے تھِیوو ، اَندروں باہروں دھوتے ہوئے تے شیطانی وَسوَسیاں توَں وِی پَاک ہووو تے کرئیے مَضبوط تہاڈے قَلباں تائیں ، پَکیاں کرئیے قدماں تائیں
  8,12,جَدوں ملائک نُوں رَب تیرے اِیہہ اَشارہ کیتا ، میں ہاں نال تُہاڈے ، اِیمانی لوکاں دے جا اَندر کھُلواؤ (ثابت قدم رکھو)،میں جھَبدے اِی (ہُنی) کُفروناں نُوں اَندروں اِی یَرکاں دیوا دَا (رُعب پا دیساں)، آکھ دئیو نیں لاہن ( کَٹ دین) اوہناں دے گَاٹے(گَردناں) پُوٹے کَرَن اوہناں نُوں (جوڑ جوڑ تے سَٹ لاوَن)
  8,13,کیوں جے اوہناں اَللہ اَتے رَسُول اوس دے دِی گَل ناہ مَنّی،تے جیہڑا اِنج پُٹھا ٹُریا اوہناں نُوں اَللہ وَلّوں ڈاہڈی اے پَر تاوِیں پیندی
  8,14,اے پُٹھ کَارو ) کَر نی دَا پَھل کھاؤ تے نالے ایبھی چیتے رَکھو،کُفروناں نُوں اَگے چَل کے ہے عذاب اَگیاری مِلنا (اَگ دا عذاب مِلْسی)
  8,15,اے اِیمان لِیَائے لوکو جَدوں کَدے وِی کُفروناں دے نال ہووے ٹَکراؤ تُہاڈا ، کَنڈھ دئیو ناہ ( پِٹِھ ناہ پھِیرو)
  8,16,تے جِس نے وِی کَنڈھ و َکھائی اوس دہاڑے ،غَضب اَللہ دا اوس دے بھاگیں،اَتے ٹھکانا اوس دَا دوزخ تے اوہ ڈاہڈی بھیڑی تھَاں ایں ۔جے اے چاَل بھَرن دِی ہووے یا ں نَس کے اپنے ٹولے رَلنے وَالی ،تَاں گَل وَکھری
  8,17,تُسآں اوہناں نُوں قَتل ناہ کیتا، اَللہ اوہناں نُوں قَتل کیتا ،اے پیغمبر مِٹّی دِی مُٹھ تُوں (دِسن وچ) جَد وَگائی نئیں سِی تُوں وَگائی ، اَللہ نے سِی اوہ وَگائی(سَٹی)۔اَللہ ایس لَڑائی رَاہیں مومَن لوکاں دے جوہر ظاہر کَرنا چاہنداہے سِی تے اِنعام اَپنے وی ،بےشک اَللہ سُننے والا جانَن وا لا
  8,18,ایس فَتح نُوں جھولی پا کے ایبھی سُن لئو، اَللہ وَلّوں کُفروناں دِی ہر گاٹی ہُن پُٹھی پیسی (ہر تدبیر ہُن اُلٹی ہوسِی)
  8,19,تُسی نتارا (فیصلہ) مَنگدے سِی کُفرونو ،اوہ نَتارا ہو چُکیا اے،اَگے توں ہُن کَنّاں نُوں ہَتھ لاؤ اِیہہ تُہاڈے وَاہتے چنَگا،جے فیر تُساں نیں بھَانجی (مخالفت) بھیڑی پائی تے فیر اَسی وِی اِنجے بھَانجی پَرتاوا ں گےتے اِیہہ چوکھ (جمیعیت) تُہاڈی کَم کِسے ناہ آسی اوہ کِنّی وِی ہووے کیوں جے اَللہ تے مومَن دَا سَنگی اے
  8,20,اے اِیمان لِیَائے لوکو آکھے لَگّو اَللہ دےتے اوس دے پیغمبر دے۔مُونھ ناہ پھیرو اس دے وَلّوں، اوس دِیاں سُن کے
  8,21,تے اوہناں دے وانگ ناہ ہوو،جیہڑے مُونھوں کہندے ہوئے گَل تُہاڈی،سِر مَتھے تے ،اوس نوں کَنّاں دے وِچ مَارَن (حالاں اوہ نئیں سُندے)
  8,22,اَللہ دے نزدیک جَنَورَاں(جانوراں) توں وی بھَیڑے اوہ کافر ناہ سُننے ناہ کرنے والے(گونگے تے بہرے) تے عَقل ناہ وَرتن والے
  8,23,تے جے اَللہ نُوں اِیہناں وِچ خَیر نَظرکوئی آؤندی۔اوس اوہناں نوں سُننے جوگَا کَر دینا سِی ،جے اِیہناں نُوں کَر وِی دے اوہ سُننے جوگَا اوہ کنڈ کرسَن کیوں جے اوہ تَاں مُونھ بھَوَآ کے مُڑنے والے(بے رُخی نال مُونھ پھیرن والے)
  8,24,اے اِیمان لیائے لوکو اَللہ اَتے رَسُول ایس دے دی سَدّ (پکار)نوں مَنّو، جَد کَدی اوہ ،تُہانوں اوس کَرنی وَل سَدّے(بُلاوے) جِس دے نال جَوین تُہاڈا (تہانوں زندگی بخشن والی شے) تے اِیہہ چیتے رَکھو ہر بَندے دے تے اوس دِی مَن مرضی دے وِچکار ہوندا اے اَللہ،تے ایس دے وِچ شَک ناہ کوئی اوس دے وَل اُٹھ تہاڈی(اوسےوَل اِی جانا اے)
  8,25,ڈَر جاؤ اوس فتِنے تَوں وِی جِس دے صرف اوہناں اِی ڈَھائے چَڑھنا ناہیں جِنہاں ظُلم تُہاڈے وِچوں ہین کمائے (کَنکَاں نال گھُن وچ پِسدا) چیتے رَکھو اللہ ڈاہڈا پَکڑ کَرن وِچ
  8,26,یَاد کَروں جِس وَقت تُسی سِی آٹے دے وِچ لوُن(نمک) بَرابر تے رہندے سی مُلکےاندر (ملک وچ) یَرکے یَرکے(ڈَرے ،ڈَرے)لوک تُہانوں چا کھڑن دے (چُک لین گے)۔تے اوس ویلے اُوٹ(پناہ) تُہاڈی اوہوا بَنیا۔اوسے دے بوہڑن (مدد)توں ملیا ٹِل (نجات)تُہانوں۔اوسے اِی چنَگا رِزق تُہانوں دِتّا، تاں جے شکر کروتُس اوس دَا
  8,27,اے ایمان لِیَائے لوکو اَللہ تے او س دے رَسُول نُوں ناہ دَا لاؤ (خیانت ناہ کرو) دِیدہ دَانستہ ناہ اَپنی وِسن گَواؤ (لوکاں دی امانتاں وچ وی خیانت ناہ کرو)
  8,28,چیتے رَکھو مال ،اَولاد تُہاڈے واہتے ہین اَزمائش ،اَجر وَڈیرا جے سَمجھو، تَاں اَللہ کول اے
  8,29,"اے ایمان لایئے لوکو جے ڈَرو , دے اَللہ کولوں ، اوہ تُہاڈے اَندر(نُور) اوہ پیدا کَرسِی ،جِس تَوں تُسی نَکھیڑا کَرسو (کی چَنگا کی مَندا) نالے کالَخ (سیاہی )عمَلاں والی دھو دیووے دا ،اوہ تُہاڈے پِشلے(پہلے) کیتے سَب بَخشے دا، بے شَک اَللہ چَوکھے فَضلاں وَالا ہے وے"
  8,30,جَد کَفرُون پئے سَن سَازش کَردے، تَاں جے قَید کَرن اوہ تینوں، قَتل کَرن یاں دیسوں کَڈّن،چَل رہے سَن اوہ پئے چالاں اَپنی تھَانویں،تَوڑ اوہناں دَا اَللہ اَپنی تھَانویں کیتا،کیوں جے اَللہ ہے مَنصوبے سَب توں بہتر کَرنے ولا
  8,31,اِیہناں مَکرے لوکاں اَگے جَد آیات اَساڈی لوکی پَڑھدے نیں،اَگوں کہندے (رہن دیوو) اَس سُن لئیاں نیں،جے اَساڈی مرضی ہووے ،جوڑَن انج دے جوڑ اَسی وی لئیے،اِیہہ پُرانے قِصے اِی تے ، آخَر ہے نیں
  8,32,اِہناں لوکاں یَاد اے تینوں جَد کہیا سِی ،رَبّا جے کَر اِیہہ اِی سَچ اے تیرے وَلّوں آیا ہویا، اَسماناں تَوں سَاڈے اُتے کَر پَتھراں دِی بَارَش، یا ں عَذاب گھَنیرا کوئی ساڈے تے کَر نازل
  8,33,اے پَر اَللہ نئیں سی چاہندا توں اوہناں دے وچ ہوویں تے اوہ عذاب اوہناں تے ڈَھائے، اَللہ نوں منظورناہ ایبھی اوہ عذاب اوہناں تے ڈَھائے جے کجُھ لوکی اوہناں وِچوں بَخشش مَنگدے ہووَن
  8,34,پَر جے اوہ مَسِیت مُبارَک تَوں روکَن تاں کِویں عَذابے جاوَن ناہیں اوہ اِس دے مَتوَلّی ناہیں کیوں جے اِس دے مَتوَلّی تے ہو سَکدے نیں خوف خُدا دَا رَکھن والے،اے پَر چَوکھے لوکاں اُتّے اِیہہ حَقیقَت روشن ناہیں
  8,35,ہے نَماز اوہناں دِی (رَب دے گھَر) اِیہوا، مانگے مارَن،سیٹ وَجاوَن،چَکھوں ہُن عَذاب ایس پاروں جیہڑے کُفر کَماندے رہے او
  8,36,کافر لوکی اَپنی دولت رَبّی رَاہ توَں روکَن دے وِچ لاندے، پَر اوڑک اِیہہ لان(خرچ) اوہناں دے واہتے جھورَا بَنسِی(پچھتاوا ہوسی) کیوں جے کَنڈ(ہار) اوہناں دِی آخر لَگنی،تے اِیہہ کُفَر کمَاوَن والے دوزخ دے وچ دِھکے جاسَن
  8,37,چنَگے مَندے وِچ اِنج نَکھیڑا کَرکے(چھانٹ کے الگ کرساں)،مَندیالاں نُوں اِک دوجے تے اَللہ سَٹ کے ڈھیر اوہناں دے لاندے ہوئے، سَبھناں نُوں دوزخ دے وِچ پاسِی ،تے اوہناں نے گھَاٹا کھَانا
  8,38,کُفروناں نُوں تُوں سَمجھا دے ،ُہن وِی جے اوہ باز آجاوَن،اوہناں دِی سَب پِشلی دھو گَھَتّے دِی،(پہلی گللاں توں دَرگُذر کیتا جاسِی) پَر جے اوہناں اوہوا چالے رَکھے ،ہُوڑ ناہ چھَڈن والےپہلاں وِی تے کیتی پاندے رہے نیں
  8,39,انج دے لوکاں نال نِبڑو اودوں تَوڑی ،جَد تائیں ناہ رَپھڑ مٗکے،تے اَللہ دے دِین دَا ڈَنکا چاروں پاسے وَجے، پَر جے اوہ چھَڈ دےدِسّن(فتنہ ) ، اَللہ اوہناں دے عمَلاں نوں ویکھ رہیا اے
  8,40,تے جے گَل تَوں اوہ پھِر جاوَن، رَب تہاڈا ہے سِر سائیں کِنٗا چنَگا اوہ سِر سائیں،کِنّا چنَگا اوہ سہارا
  8,41,پَر اِیہہ گَل وِی چیتے رَکھو، مال غَنیمت جِنّا ہووے،جو وِی ہووے ، پَنجواں حِصّہ اوس دےوِچوں اَللہ اَتے رَسُول اوس دے دَا، نیڑکیاں دا(رشتے داراں دا)،ماپے مویاں(یتیماں دا)مَسکیناں تے رَاہیاں(مسافراں) دَا اے جے اِیمان تہاڈا ہے وے اَللہ اُتّے نالے اوہناں مَلکوتاں (فرشتیاں) تے اَساں جِنہاں نوں نَازل کیتا اوس نَکھیڑَ نہار دِہاڑے (بَدری جَنگ دے) اپنے بندے دے اِمدادی کَر کے،جَد دو لَشکَر اِک دوجے نال جُٹ(بھِڑ پئے سن) پئے سَن،بے شَک اَللہ ہر کَم اُتے قَادر ہے وے
  8,42,وَادی دے جَد تُسی کِنارے اُرلے ہے سِی(ایس پاسے)،تے اوہ لوکی دُوجے دَندے تے (دوجے پاسے، تے کَروان(قافلہ) تُہاڈے بالُکل تھَلّے ہے سِی،اِک دوجے نال سانویں ہونے (مقابلے)دِی جے پَکی مِتھی ہوندی ہو سَکدا اےویلے سِر (وقت تے)ناہ اوس تھَاں پُہنچ تُہاڈی ہوندی، پر اَللہ دِی اِیہہ مَرضی ہے سی، اَمر اوس دا، رہے پُورا ہو کے۔تے جو دِھر برَباد ہو جاوئے،بَرباد ہووے گَل نترن تے (دلیلِ روشن تے ) ،جِیوے (زندہ رہووے)جیہڑا اوہ بھی جِیوے گل نترن تے،بے شک اَللہ سننے والا ،جانن والا
  8,43,تے جَد اَللہ خوابے اَندر(خواب وچ) تینوں جھَلکی اِنج دِی دِتّی، جے وَیری(دشمن) نیں تھُوڑے کُو ای(گھٹ ای نیں) جے اوہ تینوں چَوکھے کَر کے دَس دیندا تَاں ،تیرے سَنگی یَرکن پاروں(خوف ٹوں ) ایس اَمر وِچ وَکھو وَ کھو سُراں پئے کَڈدے(معاملے تے جھگڑ پیندے)،اے پَرکھیا رَب تُہانوں، اوہ دِلاں دَا پُورا پُورا جانو (واقف) ہے وے
  8,44,تے اِنجے جَد بھِڑنے ویلے اوس دِی حِکمت پاروں وَیری(دُشمن چَوکھے ہوندے ہوئے) تھوڑے نَظر تُہانوں آئے تے اوہناں نوں بے حَقیقت تُس لَگدے سِی،(تھوڑے ہونے پاروں) کیوں جے اَللہ دِی مَرضی سِی ،اَمر اوس دا ، رہے پورا ہوکے،اللہ دے ای وَس ہوندے کَم سارے(سارے معا ملات اللہ وَل ای رجوع کردے نیں)
  8,45,اے اِیمان لِیَائے لوکو ! پڑ(مقابلہ) جَدوں پے جائے کِدھرے ،پیَر پَکیرے رَکھو(ثابت قدم رہوو)، رَب نُوں خُوب چتَارو(یاد کرو)،تاں جے پَھل چَنگیرا کھَاؤ (تاں جے کامیابی نصیب ہووے)
  8,46,اَللہ اَتے رَسوُل اوس دِی آکھی مَنّو(اطاعت کرو)،آپو وِچ ناہ پاَٹو(ناہ جھگڑو)، جے پاٹو دے، تاں یَرکو دے(ڈرو دے) تے نکِلے دِی پھُوک تُہاڈی،ویکھو قائم ہَٹھ اَپنی نُوں رَکھو،اَللہ اوہناں دَا اِی سَاتھی جیہڑے یَرکن ناہیں
  8,47,تے اوہناں دے وانگ ناہ ہونا،جیہڑے پھَنڈا ں کَردے ہوئے اپنے وَسوں(گھروں) وِچوں نکلے لوکاں وِچ دِکھاوے کردے تے لوکاں نوں رَبّی رَاہوں اوہ ڈَکدے سَن، پر اللہ اوہناں دے سَب کَرتوتاں اُتے حَاوی ہے وے
  8,48,جَد شیطان اَعمال اوہناں دے لیپا پَوچی کَر کے دَسّے تے اوہناں دے کَن اِیہہ بھَریا، لوکاں وِچوں اَج تُہاڈے تَوں وَدھ کیہڑا۔ میں تہاڈے آپوں ہے واں سِر دے اُتّے پَر جِس ویلے دُونویں ٹولے اِک دوجے دے سَانویں ہوئے(آمنے سامنے ہوئے)،اوہ کھُری وَٹ نَسیَا(اُلٹے پیری نس گیا) ،اوس کہیا میں تُہاڈا سِیری (ساتھی )ناہیں،جو کُجھ مینوں نَظری آوے تُس ناہ نَظری آوے،میں تاں اَللہ کولوں ڈَرناں ، تےاَللہ دِی پَکڑ اے ڈاہڈی
  8,49,ایہہ ویلا سِی جَدوں مُنافَق تے حاسَد سن کہندے دِین اِہناں دے نے اِہناں نُوں پُٹھےراہے پا دِتا ا ے(اوہ ناہ سمجھن ) اللہ اُتّے جیہڑے وَل تَوَکّل کَردے،اَللہ ہے عَزیز حَکیم اوہناں دے وَاہتے
  8,50,جے تَک سَکدوں تُوں اوہ ویلا جَدوں فَرِشتے کُفروناں دِیاں جاَناں کَڈدےکِنج اوہناں دے اوہ بُتھاڑ(مونھ) سُجاندےہے نیں تے کَنڈاں وِی ، کہندے ہوئے چَکھو اَگن عذاب ہن( اِیتھے)
  8,51,اِیہہ سَب کجھَ اوس پاروں ،جو کَجھ ہَتھ تُہاڈے گھلَدے آئے،کیوں جے اَللہ بَندیاں نال کَریندا ناہیں کَدے وَدھیکی(ظُلم نئیں کَردا)
  8,52,حال اوہناں دَا فَرعون کیاں دے وِرگا تے اوہناں دے وَرگا جو اوہناں توں پہلاں ہوئے،اَللہ دی آگاہیاں دے سِی اوہ انکاری،مُڑ اَللہ اوہناں دے کَرتوتاں دے پاروں ، پَکڑ اوہناں دِی کیتی، بے شَک اَللہ تَکڑا وِی اے ڈاہڈا پَکڑنہار ا وِی اے
  8,53,کیوں جے اَللہ قوم کِسے تے کَردا ہے جے رحمت کوئی،اوس رحمت نوں اُس دے کولوں کھوہ ناہ لیندا جَد تائیں اوہ قوم بَدل کے اَندروں رہے ناہ قابل اِس دے، بے شَک اَللہ سُننے والا حِکمت والا
  8,54,حال اوہناں دَا فِرعون کیاں دے وَرگا تے اوہناں دے ورگا جو اوہناں توں پہلاں ہوئے،اوہناں نے آیات الٰہی نُوں ناہ مَنیا(ناہ تسلیم کیتا) اوہناں دے اِنج دے اِی کَرتُوتاں پاروں ،اَساں ہَلاک اوہناں نُوں کیتا،تے سَارے فِرعونی ٹولے نُوں غرقایا کیوں جے اوہ سَارے اِی سَن پُٹھے پانی رُڑنے والے
  8,55,اَللہ دے نَزدیک اوہ لوکی پِشوآں تَوں وِی لَتھے ہوئے(بدترین مخلوق نیں) کُفر جِنہاں نے اپَنایا تے اِیمان گلَے ناہ لایا
  8,56,اِیہہ لوکی اوہ نیں نال جنہاں دے قول تیرا سِی ہویا ، پَر اوہناں نے ہَر وَاری اِی تھُک کے اَپنا چٹیا، اوہناں نُوں ناہ خوف خُدا دَا
  8,57,اِس کر کے جے بھیڑ کِسے وِچ اوہ ہَتھ آوَن، اِنج اوہناں نَوں کھُلّو(خبر لَوَو) جے اوہناں دے پِشلے وِی ہَتھ کَنّاں نُوں لاوَن تے اِس پھَنڈ نُوں چیتے رَکھن
  8,58,تے جے کَر اِیہہ خَطرہ ہووے اوہ گل اُتوں پھِر جاوَن دے،قول اوہناں دے مار اوہناں دِی بُوتِھی(مونھ) اُتّے بے شَک اَللہ اوہناں نوں چَنگیاندا ناہیں(پسندنئیں کردا ) جیہڑے گَل کَرکے پھِر جاندے
  8,59,کافر لوکی ایس بھُلیکے رہن ناہ ہرگز ،جے اوہ بازی جِت جاوَن دے،اوہ تہانوں کَر سکن ناہ عَاجز اُکّا
  8,60,اوہناں دے نال نِبڑن وا ہتے ،کَرو تَیاری جِنّی وِی کَر سَکدے ہے او،نَفری وَلّوں ،اَسپاں وَلّوں(گھوڑے وَلوں)،تاں جے اِیہہ تیَاری تَک کے اوہناں نوں کَنبِنِی لگ جائے جیہڑے ہین تُہاڈے دُشمن تے اَللہ دے دُشمن بَلکہ اِہناں توں وَکھ اوہ وِی (کَنب کَنب جاوَن)جِنہاں دی نئیں خبَر تُہانوں، پَر اَللہ نُوں خبَر اوہناں دِی،جو کجُھ وِی تُس راہ خُدا وِچ خَرچ کَرو دے اوہ تُہانوں پُورے دَا پُورا مِل جَاسِی، حَق مَاری ناہ اُکّا ہو سی
  8,61,پر جے اوہ صلح کرن وَ ل کّنا کھاون (مائل ہوون)توں وی کَبّا کھا اوہناںوَل ،کر توکل رب دے اُتے ،بے شک اوہ سمیع علیم اے
  8,62,جے اوہ تینون دھوکھا دینے وَل آون،رکھ تسلی ، اُوٹ اللہ دی تیرے واہتے کافی،اہوا ای اے جس نے تینوں تے ایمان لیائے لوکاں نوں تگڑینواں دِتا ،تہاڈے تے ہتھ رکھیا، نالے
  8,63,مہر تہاڈے قلباں دے وچ پائی،اُنج تُسی کُل جگدے لاندے وی، لانے تاں دِل تہاڈے اِک دوجے دے نال ناہ جُڑدے۔اللہ ای اے جس نے تہاڈے وچ ایہہ اُلفت پادِتی اے،اوہ ہر ک کَم کر سکنے والا تے ہر حکمت والا
  8,64,اے پیغمبر اَللہ کافی تیرے وَاہتے تے اوہناں دے وَاہتے جیہڑے مومن لوکاں وِچوں تیرے پِچھے ٹُردے
  8,65,اے پیغمبر کَر آمادہ بھِڑبھَڑن تے(جنگ تے ) مومَن لوکاں تائیں ،ہوون وِیھ(20 ) وِی وِچ ُتہاڈے ،ڈَٹ کَر جے کھِلووَن والے اوہ دو سو ،تے غالب آسَن،سو ہووَن دے تے اوہ ہَزار کُفروناں تے غالب آسَن،کیوں جے قوم اوہ ناہ سَمجھاں دی،
  8,66,اَللہ کَم تُہاڈا ہَولا کَر دِتّا اے، اوہ تُہاڈی کَمزوری نُوں جانے، اِس کَر کے سو صَابر مومَن ،دوسو اُتے غَالب آسَن تے جے اِک ہَزار ہووَن تے اوہ دو ہَزاراں اُتّے اذن اَللہ دِی نال آوَن دے غَالب،بے شَک اَللہ صابر لوکاں دَا اِی سَنگی
  8,67,اے نَبی نُوں زیبے ناہیں اوس دے کول کوئی قیدی ہووے مُلک تے غَلبہ ہون تَوں پہلاں۔ حُب تُہاڈےاَندر دُنیا دی دولت دِی،پَر اَللہ دِی خواہش اِ یہہ وے، چھِیکَڑ جھَولی پَوَے تُہاڈی بے شَک اَللہ غلبے ولا حِکمت والا
  8,68,جے کَر حُکم خُدا دا پَہلاں ہو چُکیاں ناہ ہوندا(بَدری لُٹ دی) ایس تُہاڈی حَرکت اُتّےاِک عَذاب گھَنیرے نے کَرنی سِی پَکڑ تُہاڈی
  8,69,خیر ہویا جو ہویا -ما ل غَنیمت وِچوں جو کجُھ لَگیا ہَتھ تُہاڈے اوس نوں تُسی حَلال طَیَّب گِن کے وَرتَو کھَاؤ، پَر اَللہ دَا خوف دِلاں وِچ رَکھو بے شَک اَللہ بَخشن ہارا رحمت کرنے والا
  8,70,اے پیغمبر کہہ اہناں نُوں جیہڑے قیدی تیرے قبضے جے تُہاڈے قَلبے اَندر اَللہ نے چنگیائی ویکھی اوہ تُہانوں دیوے گا اوس نالوں وَدھ کے ،جو لیا اے اَج تہادے کولوں (فدیہ کرکے) نالے اوہ گناہ تہاڈے وی بخشے دا ،بے شک اوہ غفوررحیم اے
  8,71,پَر جے نال تَیرے اوہ کوئی دَھوکھے بازی کَرنا چاہوَن اَللہ نَال خیَانت اوہناں پہلاں کَر کے وَیکھ لیا اے،اَللہ تینوں اوہناں اُتّے غَالَب کیتا، بے شَک اَللہ آپ عَلیم حَکیم اے
  8,72,جیہڑے لوک اِیمان لِیَائے تے(اس پاروں) ہِجرت کیتی،اَتے جَہاد جِنہاں نے کِیتا جاَنی ، ماَلی رَب دِی راہے ،تے اوہ وَل جِنہاں ،اوہناں نُوں اَپنے کول پَناہ سِی دِتّی ، مَدد اوہناں دِی کِیتی ، اِہوا لوک اِک دوجے دے سَجن ہے نیں، جیہڑے لوک اِیمان لِیَائے پر اِہناں نے ہِجرت ناہ کیتی نال تُہاڈے اوہناں دِی سجَنائی کاہدی جَد تائیں ناہ اوہ دیس اَپنا ناہ چھَڈن،مُڑ اوہ جَد دِین دِی خَاطَر ،مَنگَن مَدد تُہاڈے کولوں،ہے تُہانوں مَدد اوہناں دی کَرنی بَن دِی ، جے مَدد اے خَلاف اوہناں دے ناہ جائے نال جنہا ں دے کوئی عہد تُہاڈا ہووے،چیتے رَکھو جو وِی عَمل تُہاڈے ہے نیں ، اَللہ دِی اَکھ تھَلّے
  8,73,جیہڑے لوکی کافَر ہے نیں اوہ تاں اِک دوجے دے ساتھی۔ تے جے انج تُساں ناہ کیتا، مُلکے اَندر فِتنہ مچ سی (پھیل جاسی ) اَتے فَسَاد گھَنیرا
  8,74,جِیہڑے وَل اِیمان لِیَائے، دیسوں نکِلے، رَب دِی راہ جَہاد جِنہاں نے کیتا تے اوہ لوک بنے سِی جیہڑے اُوٹ اوہناں دِی تے اوہناں دے مَددی ہوئے۔حقَے سچے مومَن اوہوا،مَغفَرت اوہناں نُوں مِلنی، باعِزت روزی وِی اوہناں دے اِی بھَاگھیں
  8,75,اے پر ایس اَزمائش پِچھوں وِی جیہڑے اِیمان لِیَاوَن ،دیس اَپنے نُوں چھَڈن ،رَل کے نال تُہاڈے کَرن جَہاد،اوہ وَل وِی ہین تُہاڈے وِچوں،اَللہ دے فَرمان مُطابق رِشتے دار اِک دوجے اُتے حَق زَیادہ رَکھدے،بے شَک اَللہ نُوں علم ہے وے ہَر اِک شے دَا
  9,1,جیہڑے مُشرک لوکاں نال ،قول تُساں سَنْ کیتے ہوئے،نال اوہناں دے اَج تَوں اَگے،اَللہ اَتے رَسُول اوس دے دا، رہیا ناہ لاگا دَاگا (علان لاتعلقی)
  9,2,چار مہینے کھُل (چھوٹ) اوہناں نُوں تے اِیہہ بھُل دِلاں چوں کَڈّھن جے اَللہ نُوں عاجز اوہ کَر سَکدے ہے نیں، اَللہ اِی نے کَفروناں نُوں کھیہ بَنا کے چھَڈناں(اَللہ اِی منکرین حق نُوں رُسوا کَرن والا اے)
  9,3,اَللہ اَتے رَسول اوس دے دَا اِیہہ اِعلان سُنایا جاسِی سَب لوکاں نُوں وَڈّے حَج تے، جے اَللہ دَا اَتے رَسُول اوس دے دَا ، رہیا ناہ لا گا داگا (نئیں رہ گئی ذمہ داری)کوئی نال اوہناں دے جیہڑے مُشرک، ایس کرکے جے توبہ کَر لَئو ،اِیہہ تُہاڈے حَق وِچ چنَگا تے جے کَر مُونھ موڑی کَر سَو، چیتے رَکھو اَللہ نُوں تُس عَاجز کرَنے وَالے اُکّا ہو نَئیں سَکدے ،کَفْروناں نوں دَس دئیو جے ہے عَذاب اِہناں دے بھاگیں ڈاہڈا اَوکھا کَرنے والا
  9,4,مُشرک لوکاں وِچوں وِی اوہ قول جِنہاں نیں نال تُہاڈے کیتے ہوئے،پہرہ پئے ایس تے دیندے،کِسے تُہاڈے ویری(دشمن) دَا وِی دَھڑا (ساتھ)اوہناں نیں اَج تَک کیتا،اوہناں دے نال گَل نِبَاہو کیتی مدت تائیں،بے شَک اَللہ گَل پالاں نُوں چَنگیاندا اے(وعدہ پورا کرن والیاں نوں پسند کردا ا ے)
  9,5,حُرمت والے جَد مَہینے لنگھ جاوَن(گزر جان) تاں۔ جتِھے وِی مِل جاوَن مُشرک، مَار دَئیو نیں(قتل کرو)،قید کَرو نیں،نَپ لَوَو نیں (پھڑو)،تھَاں تھَا ں تھَڑا دیئو اوہناں نُوں (ہر تھاں تےخبر لین لئی گھات لاؤ) تے جے کر مُشرک باز آجاوَن، پَڑھن نَمازاں نالے دَین زَکاتاں مُڑ اوہناں نُوں کجُھ ناہ آکھو،ہے غَفور رَحیم بے شَک ذَات اَللہ دِی
  9,6,جے کوئی مُشرک کَلّم کَلا وِی لے اُوٹ (پناہ) تُہاڈی آکے،اوس نُوں رَکھو اوٹ اَپنی وِچ ، تاں جے ایس بہانے اس دے کَنّیں پَوَے کلام اِلٰہی مُڑ اوہناں دِی بے چنتی تھَاں اوہناں نوں اَپڑاؤ ،کیوں جے اوہ ہَر گَل تَوں ناہ با خبَر ہوندے نیں
  9,7,مُشرک لوکاں نال بھلَا کَد عِہد، اَللہ دَا اَتے رَسُول اوس دے دَا (سوچو) رہ سَکدا اے، اَڈ (سوائے) اوہناں تُوں نال جنہاں دے قَول تُہاڈا ہویا ہے سِی بَیتُ اللہ دےلاگے،قائم رہن اوہ جد تائیں گَل اَپنی دے اُتّے ، رَہوَو تُسی وِی قائم گَل اَپنی دے اُتّے کیوں جے اَللہ گَل پَالاں نَوں چَنگا گِن دَا
  9,8,اِیہہ مُشرک تَاں اوہ نیں،جے تُسی اوہناں دے قابو آجاؤ،تے اوہناں نے ناہ چیتے کَرنا سکیائی نُوں(ناہ قرابت دا خیال رکھنا) ، گَل ہوئی نُوں،اوہ تُہانوں گَلاں دے نال پَرچاندے نیں(گلاں نال راضی کردے نیں )،ہے دِلاں وِچ کھوٹ اوہناں دے ،تے اوہناں دے وچوں چَوکھے قول اُتوں پھِر جانے وَالے
  9,9,اِیہہ تاں ہے نیں ، اَللہ دے حکُماں نُوں چھَڈ کے ،چھوٹے موٹےنَفعیاں دے وَل بھَجّن وَالے تے لوکاں نُوں رَب دی رَاہوں روکن والے،ڈاہڈے مَندے نیں کَرتُوْت اوہناں دے
  9,10,مومَن لوکاں نال رَوئیے اَپنے وِچ اِیہہ،ناہ گولن (لحاظ رکھن) رِشتے دَاری ناہ اِی گَل دِی پالن ہاری (عہد دِی ذمہ داری)، ہَر حَد اِیہہ ٹَپ جانے والے
  9,11,مُڑ جے اِیہہ باز آجاوَن، پکَے ہون نمَازاں اُتّے،دیھن زَکاتاں(دِلوں بَجانوں) تاں مُڑ اوہ بھَرا (بھائی) تُہاڈے دِینی ہے نیں،اَس اِیہہ گَلاں ،سوجھت والے لوکاں اَگے کھول کے رَکھیے
  9,12,جے پھِر جاوَن عِہد اَپنے تَوں ، پہلاں کَر کے،نالے دِین تُہاڈے بارے کَرن ٹَکوراں(غلط گلاں کَرن)،تے مُڑ ایہناں کُفر دیاں سِر کَڈَّاں دے نال(کفر دے علمبرداراں دے نال)،پَاس جِنہاں نُوں ،گَل دَا ناہیں،کَرو لڑائی ،اوہناں دے باز آوَن تائیں
  9,13,کی اوہناں دے نال ناہ لَڑسَو، کِیتے قول جِنہاں نے بھَنّے(توڑے)،مَتے پَکائے(قصد کیتا) تاں جے پیغمبر نُوں دیس تَوں کَڈئیے، اِیہوا سَن(ایہو ہے سن) جِنہاں نیں پہلاں،وَیراں دِی نِیہہ رَکھی ہے سِی (زیادتی دی ابتدا کیتی )،کی اوہناں دے کولوںڈَرسَو، ڈَرْنَا تے اَللہ تَوں سَوبھے جے اِیمان تُہاڈے اَندر
  9,14,نال اوہناں دے کَرو لَڑائی، رَب تُہاڈے ہَتھوں اوہناں نُوں پائے دَا وِچ عَذابے تے اوہناں دی مِٹِّی منسی (ذلیل خوار کرسی)،اوہنا ں اُتے فَتح تُہانوں دینے دے وِچ کَر سی مَدَد تُہاڈی تے مومَن لوکاں دے سِینے ،ٹھَنڈَاں پَاسی
  9,15,اِیبھی مُمکن رَب اوہناں لوکاں دے اَندر ،وَجْیاَں گَنڈاں نُوں وِی کھولے(دِل دِی جَلن مٹائے) کیوں جے اَللہ جِس وَل چاہے نَظر کَرم دِی کَر سَکدا اے،بے شَک اَللہ عِلماں والا،سوچاں والا
  9,16,کی خیَال تُہاڈا ہے وے، ناہ پَڑچول ( ناہ پُچھ گُچھ) تُہاڈی ہونی حالاں اَللہ چھانٹ اَجے تاں کِیتی ناہیں،کیہڑے لوک جَہاد تُہاڈے وِچوں کَرنے والے ہوسَن،تے اَللہ نُوں اَتے رَسول اِس دے نُوں نالے مومن لوکاں تائیں چھَڈ کے،دُوجَڑیاں نُوں(دوسرے لوکاں نوں) جانی یَار بَنانے والے ،کیہڑے ہوسَن۔اَللہ خوب سَمجھدا ہے وےجو جِکَنْ دے عَمل تُہاڈے
  9,17,مُشرک لوکاں کولوں اِیہہ ناممکن ہے وے ، رَب دے گھَر آباد کَرن اوہ،جَد اوہناں دَا کُفر گَواہی آپ خَلاف اوہناں دے دیندا، اِیہہ لوکی نیں ڈُبے(ضائع ہوئے ) عَمل جِنہاں دے تے اوہنا ں نیں دَائم اَگ دے وِ چ اے رہنا
  9,18,رَب دے گھَر آباد اوہوا اِی رَکھ سَکدے نیں ، اَللہ تے اِیمان جِنہاں دَا نالے چھِیکڑ دِن اُتّے(آخرت اُتے)،ہین نَمازی جیہڑے پکَے، سَدا زَکاتاں دینے والے،تے اَللہ توَں باجھ(سوا) کِسے توں ڈیھلن ناہیں(ناہ ڈرن )،اِنج دے لوکاں اِی ہونا ہے ،ہَدایت پایاں وِچوں
  9,19,کی پَیانا پانی حَج نُوں آیاں تائیں (کی حاجیاں نُوں پانی پلانا)یاں مُڑ سَانبھ خُدا دے گھَر دِی (یاں مسجدِ حرام دی مجاوری)۔رَب دِی تَولے سَانویں کِویں اوہناں دے تُل سَکدی ( کی رب دی نظر وچ برابر ہوسکدے ) اَللہ تے اِیمان جِنہاں دا،نالے چھِیکڑ دِن اُتّے ،ہون نَمازی جیہڑے پکَے نالے دیہن زَکاتاں،رَب دِی رَاہ جَہاد کَریندے،مَندکاراں نُوں(ظالماں نوں ) اَللہ سِدّھے راہ ناہ پائے
  9,20,جیہرے لوک اِیمان لِیَائے ،ہِجرت کیتی،رَب دِی رَاہے ،جانی، مالی ہے جہَاد جِنہاں نے کیتا،رب دے اَگے اوہناں دے ای دَرجے اُچّے،اُوڑک جِتْ(آخری کامیابی ) اوہناں دِی ہونی
  9,21,رَب اوہناں دَا ، دے بَشارت اوہناں تائیں، اوہ رحم اوہناں اُتے کَرسی، اوہناں اُتُے رَاضی ہوکے تے اوہناں نُوں سَدَا بہَار باغ اوہ دیسی
  9,22,اِہناں وِچ اوہ دَائم رہسن، بے شک اللہ دے کول اَجراں دِیاں پَنڈَاں(اللہ دے کول خدمات دا صلہ دَین واہتے بہت کجُھ اے)
  9,23,اے اِیمان لِیَائے لوکو اَپنے پےآں (والد)،بھَراواں نُوں ناہ سَنگی متھو ، جے اِیمانوں چنَگا اوہ کُفرنُوں جانَن، جِس وَل تُہاڈے وِچو ں اوہناں نُوںسَجنایا (رفیق بنایا)،اپنے واہتے ظُلم کَمَایا
  9,24,اِیہہ جتا دے اوہناں تائیں،جے تُہانوں بَاپ تُہاڈے، پُت تُہاڈے،تِیویاں(بیویاں) تے سَنگ ساک تُہاڈے(عزیزو اقارب)،دولت کَٹھی کیتی ہوئے کَاروبا ر جِدے وِچ ڈَر جے مَندوَاڑا( نقصان) آجاسی،کُلّے کوٹھے جیہڑے مَن تہاڈے وَسَن،اَللہ اَتے رَسُول اُس دے تَوں اَللہ دِی راہ جَہاد کَرن توَں اَگے ہے نیں ، تاں اوہ وَقَت اُڈیکو۔اَ مَرْ(فیصلے ) اَپنے نُوں اَللہ لے کے آجائے کیوں جے اللہ نوں ناہ فَاسق لوک پیارے
  9,25,بے شَک اَللہ نیں کِنّیاں اِی تھَاواں اُتّے کیتی اے مَدد تُہاڈی(چیتا ہے جے)چَوکھ(کژت) اَپنی تے پھَنڈ (آ کڑ )تُہاڈے وِچ آئی سِی یوم حُنینے ،تے ایس چَوکھوں سَوَرْ(سنوار) ناہ کُجھ تُہاڈا سَکیا( اِیہہ کژت کم ناہ آئی) ، تنگ تُہاڈے اُتّے دَھرتی ایڈی (اتنی)کھُلی ہوندی ہوئی تے تُس نَسّے کَنڈاں کَر کے(تُسی پِٹھ پھیر کے نَس گئے سَو)
  9,26,نازِل فِیر سَکون اَللہ نے کیتا اپنے پیغمبر تے،مَنن والے لوکاں اُتے،اوہ لشکر اوس گھَلے دِسدے نَئیں سَن اوہ تُہانوں،انِج اَللہ نے وِچ عَذابے کُفروناں نُوں پایا سِی
  9,27,اِیناں کُجھ ہو جانے تے وِی،جِس دے بارے چاہسی، نَظر کَرم دِی اُس تے کَرسِی، بے شَک اوہ غَفور رَحیم اے
  9,28,اے اِیمان لیائے لوکو ہین پَلیت (ناپاک) اِیہہ مُشرک،ایس سَالوں پِچھوں(ایس سال توں بعد) ، بَیْتُ اللہ ،اوہ ناہ آوَن، ایس تے جے تُہانوں بُھکھ دَا خَطرہ ہووے تاں تَسَلّی رَکھو اَللہ جے چاہیا، جھَبدے اوہ تہانوں سَوکھَا کَرسِی(غنی کرسی)بے شَک اوہ عَلیم حَکیم اے
  9,29,تے جیہڑے نیں لوک کِتابی ، چَڑھ اوہناں دے اُتّے جے اَللہ تے چھِیکڑ دِن نُوں ناہ مَنّن اَتے حَرام اوس نُوں ناہ جَانَنْ اَللہ اَتے رَسُول اوس دے نیں ٹھَاک( حرام) ہے وے جِس بارےے کِیتی تے ناہ مَنّن دِین سَچیرا (دِین حق نوں اَپنا دِین نئیں بناندے)،یاں اوہ جَزیہ دَین دے وَل ناہ آوَن ، ہاراں مَن کے۔تے ناہ تھَلّے لَگ کے وَقَت گُزارَن
  9,30,اِیہہ یَہودی کہندے ہے عُزیر اَللہ دَا بیٹا، تے نُصرانی کہندے ہے مَسیح اَللہ دَا بیٹا، اِیہہ اوہناں دِیاں گھَڑیاں ہوئیاں گَلاں ،اوہناں تَوں پہلاں دے کافر جو مُونہوں کَڈدے آئے ،اِیہہ کر دے نیں نَقَل اوہناں دِی،اَللہ دِی مار اوہناں اُتّے ، کیہڑے پُٹھے پاسے پے گئے
  9,31,اپنے پادَریاں نُوں ،اَپنے جو گڑیاں(درویشاں )نُوں، مَریم جائے عیسٰی نُوں وِی ،اَللہ نُوں چھَڈ کے ہے سَب بَنایا ہویا، حالاں اوہناں نُوں اِیہوا اِی حُکم ہویا سِی، کَرو عِبادت اِکّم اِکّے اَللہ دِی، بِن اوس دے مَعبود ناہ کوئی،اوہ ہَر اوس تَوں پاک اے جِس نں تُسی شَریک بَناؤ اوس دَا
  9,32,چاہندے نیں جے پھُکاں دے نَال نُور بھُجَاوَن اِیہہ اَللہ دَا تے مَنظور اَللہ اِیہوا ، چَاہڑےتوَ ڑ اوہ نُور اَپنے نُوں ، کافَر لَکھ ایس تے، نَک چَاہڑَن(بھاویں کافراں نوں کِنا ای ناگوار گزرے)
  9,33,اوہوا ذات اے اللہ جِس نے گھَلیا ہے رَسُول اَپنے نُوں ۔دے کِتاب ہَدایت والی نال دِین سُچیرا(دین ِحق) تاں جے باقی سَب دِیناں تے اِس نُوں غَالب کَر دے، مُشرک لَکھ اس تے نَک چَاہڑَن
  9,34,اے اِیمان لِیَائے لوکو! پَادَرْیاں تے جوگڑیاں چوں بُہتے وَل نیں لوکائی دَا مال ، نحقاً (ناحق) جیہڑے کھاندے تے اَللہ دِی رَاہو ں ڈَکدے تے اوہ لوکی ،سونا چاندی جیہڑا کَٹھا کَردے رہندے ، پر اَللہ دِی راہ وِچ اوس نُوں لاندے ناہیں(خرچ نئیں کردے)، اِک عَذاب اوہناں نوں دَس دے ، اَوکھا کَرنے والا ہوسِی اوہناں وَاہتے
  9,35,اوس دِہاڑے جَد جَہنم دِی اَگ اَندر، اوہنا ں واہتے گَرم کَرن دے،اِس سونے تے اِس چاندی نُوں تے اوہناں دے مَتھے (پیشانی)،پاسے تے کَنڈاں تے ٹھَپّے لگسن(دَسدے ہوئے) اِیہہ سِی کَٹھ جیہڑا ِ جو تُساں نے اپنے واہتے کیتا ہے سِی ، چکَھو ہُن سَوَادْ اوس دَا ،جو رَہے سِی کَٹھا کَردے
  9,36,اَللہ دے نَزدیک مہینے بَاراں رَب دے لیکھے دے وچ، ایہوا نیں اوس دِن تَوں جَد توَں اَسمان ،زمین اوس نے خَلقائےہے سَن اِہناں وچوں چَار مہینے جَنگ بَندی دے، اِیہہ دَستو ر اے پَکا پیڈا،ایس کَرکے اِہناں دے اَندر ظُلم کَرو ناہ اَپنے اُتّے(اِہناں دِی حُرمت نُوں بھُل کے) کَرو لڑائی مُشرک لوکاں نال (جَد اوہ چارمہینے لَنگھ جاون) سارے رَلکے (مل کے )،جِکَن لَڑائی کَرن تُہاڈے نال اوہ رَل کے ،اِیہہ یقین دِلّے وِچ رَکھو، اَللہ سِدھے ٹُرنے والے لوکاں دَا اِی ساتھی ہے وے
  9,37,نَسیِ (حُرمت والےمہینے دَا ا َگےپِچھے کرنا) حَقیت وِچ کُفر وَدھائی ہے وے ، اس دے پاروں کافر لوکی گُمراہی دے وِچ پیندے، کیوں جے اِنج حَلال بناندے (لَڑنے واہتے) اِک وَر ہے(سال) دِن جیہڑے اوہناں نُوں اِی اَگلی وَاری آپ حَرام بَناندے اِس دِی گِنتر(گنتی) پُوری کَرنے واہتے جِس دے بارے ٹھَاک اَللہ دِی، انِج خُدائی ٹھَاک ،اُٹھا ک اوہ کَردے،اَپنے مَندے عمَلاں دے وِچ اوہناں نُوں چنَگیائی لَگدی۔تے اَللہ ناہ کُفروناں نُوں ناہ راہے پاندا
  9,38,اے اِیمان لِیَائے لوکو ! ہو گیا اے کی تُہانوں،رَب دِی راہے جَدوں تُہانوں آکھی دَا اے نِکلن واہتے،زَویں (زمین)تُہاڈے پیَراں نُوں نَپ لیندی،جاپے کی دُنیاوی سُکھ تے رَاضی ہو بیَٹھے او، اُوڑک (آخرت ) دے آراماں بدلے جے سوچو تاں مَال متَاع اِیہہ دُنیا والے،اُوڑک اَگے بےحیثیت نیں
  9,39,جے جَہاد کَرن نُوں پیَر تُساں ناہ پٹے (ناہ اُٹھے)،رَب تُہاڈا تُہانوں ڈاہڈے وَختاں (سزا) اَندرپاسی۔اوہ تہاڈی تَھاویں ٹولے ہور کَسے نُوں گَلمے لاسِی(تہاڈی تھاں کسے ہور گروہ نوں اوہ اُٹھائے دا)کی وَگاڑ سَکو دے اوس دا ،کیوں جے اَللہ ہر کم اُتے قادر ہے وے
  9,40,جے پیغمبر دے ناہ تُس اِمدادی ہو سَو، اَللہ اوس دا اُدوں وِی اِمدادی ہویا ،جَد کَڈیاں کُفروناں ایس نُوں،دونھ دے وِچوں(دو چوں) دُوجا کر کے، تے جَد غار سَن اوہ دَونویں(دونوں) تے اوہ اَپنے سَنگی تائیں کہہ رہیا سِی،گھبرانے دِی لُو ڑ ناہ کوئی، اَللہ نال اَساڈے،اِنجے اَللہ نیں اُس اُتے بے چنتی (سکون قلب)نازل کیتی ہے وے،کِنّی وَاری تے اوہ لشکر گھَل کے، جیہڑے نَظر ناہ آوَن۔ اِنج اوہنے کَفروناں دِی مُونھ کَڈی نُوں کھیہ بنایا(کفروناں دَا بول نِیواں کیتا ا) اَللہ دِی اِی گَل اُچیری (اُچی)رِہنے والی بے شَک اوہ عَزیز حَکیم اے
  9,41,جَنگ نُوں نِکلو ،ہولے بھَارے جو سامان مُیسر آوے اوہوا لے کے،تے اَللہ دِی راہ جَہاد کَرو ہُن مالی ، جانی جے کر سوجھ تُہاڈے اَندر، تاں بھَلیائی ایسے وِچ تُہاڈی ہے وے
  9,42,مال کَرے جے نِیڑے ہوندا تے پَینڈا وِی ہَولا(سفر ہلکا) ہوندا، ٹُردے نال ضَرُّور اِیہہ تیرے، پَر اِیہہ پَینڈا(رستہ)ڈُونگا تَک(کھٹن ویکھ) کے، دِل پئے چھَڈن، ہُن اَللہ دِی قَسماں کھَاسن (کہندے ہوئے)جے ساڈے وِچ آگنس(طاقت )ہوندی نال ضَرورتُہاڈے چَلدے،تے جاناں دے دیندے ، پَر اَللہ نُوں عِلم اے اِس دَا، اِیہہ لوکی نیں جھُوٹھے
  9,43,اَللہ تیری چَنتا ٹالے(اَللہ تینوں معاف کیتا) پَر اے نَبی تُوں اِذن اوہناں نوں کاہے نُوں دِتُی ہے سِی (گھر رہنے دی) جد تائیں ناہ کھَریاں(سچے) تاں کھوٹلیاں(جھوٹھیاں ) دَا ہو نَتارا جاندا
  9,44,تیرے کولوں اوہ اجازت منگسن ناہیں، پئی جَہاد مالی ،جانی کرنے تَوں اوہ بچ جاوَن ، اَللہ تے اِیمان جِنہاں دَا نالے چھِیکڑ والے ے دِن تے ،بے شَک اَللہ نُوںمعلوم ایں کیہڑے لوکی اَندروں باہروں سُچے
  9,45,اِذن (اجازت) تیرے کولوں مَنگن اوہوا آوَن دے،اَللہ نوں تے چھیکڑ والے دِن نُوں جیہڑے مَن دے ناہیں تے شک ہین جِنہاں دے اَندر، تے اپنے شَکاں دے پاروں ،اوہ رہندے نیں ڈولَم ڈولا
  9,46,کجُھ وِی جے ارادہ نِکلن دَا ہوندو نیں ، کجُھ ناہ کجُھ تیَاری اوہناں کَرنی ہے سِی ، پَر اَللہ نُوں اِیہہ ناہ وَارا کھَاندا ہے سِی اوہ لامے(جنگ) نُوں نِکلن ،تے اوہناں نُوں پِچھے رہنے نُوں کہہ دِتّا سنگ رہیلاں(بیٹھے رہن والیاں دے نال)
  9,47,جے اوہ نال تُہاڈے رَل کے لامے جاندے اوہ ُتہاڈے وَخت(مصیبت) وَدھاندے ،اوہناں دی بھَج دَوڑ تُہاڈے وِچ تَیریڑاں(فتنہ) پانے واہتے اِی رہنی سی ، کیوں جے کَنّاں دے کچَے لوک تُہاڈے اَندر ہے سَن،تے اَللہ نُوں سَار(معلوم ) اے سَاری، کیہڑےپُٹھے ٹُرنے والے
  9,48,اِیہہ پہلاں وِی کَر بیٹھے سِی کوشش اِس دِی، تاں جے کوئی فِتنہ جاگے تے حالات اہناں نے تیرے واہتے پُٹھے کَر دِتّے سَن،حق دےجھولے جھُلّے تے اَللہ دَا اَمر اِی جِتیا ،بھَاویں اوہناں نے نَک چاَہڑے
  9,49,اوہناںوِچوں اوبھی ہے سِن،اِذن(رخصت) جِنہاں نے مَنگی ہے سی گھَر رہنے دِی تاں جے اوہ ازمائش وِچوں بچ اِی جاوَن،سَچ تاں اِیہہ وے اوہ اَزمائش وِچ آپوں پھَاتھےتے دوذخ نے گھیر لیا اے کفروناں نُوں
  9,50,جے کوئی سُکھ تیرے تے آوے ،اِہناں نُوں تَکلیف ہوندی اے ،پر جے اوکھ(مصیبت )تیرے تے آوے،اِیہہ کہندے نیں اپنی اَساں بَچاوٹ پہلاں کرلِتّی سی تے اوہ خُوش خُوش کَنڈاں کَردے(اوہ مونھ بھواں کے خوش خوش جاندے)
  9,51,کہہ دے اَللہ وَلوں جو نصیب اَساڈا لکھیا ہویا،ہے اَسانوں اوہوا ملنا، اوہ اَساڈا کَم سَوارَن والاہے وے ،تے اللہ تے ہین تَوَکّل مومَن کَردے
  9,52,کہہ اوہناں نُوں سَاڈے بارے دَو چنَگیائیاں غَازی یاں شَہید ہونے چوں ،اِک ا ُڈیک تُہاڈی، اِیدھر اَسی تہاڈے بارے دو اُڈیکاں لائی بیٹھے ،یاں تے اللہ آپ تُہانوں وِچ عذابے پائے یاں اَساڈی ہَتھیں (ساڈے ہتھ توں)،اپنی تھَاں تُسی اُڈیکو،( انتظار کرو)،اَس وِی ہاں اُڈیکن بارے نال تُہاڈے
  9,53,واضع کردے اِیہہ اِہناں تے ، خرچ کَرو ہُن ہسدے مِتھے(راضی خوشی) یاں کَوڑے مِتھے( کراہٹ نال)،اوہ قَبول ناہ ہوسی کیوں جے قوم تُسی ناہ آکھے لَگّن والی
  9,54,لایا(ِدِتّا مال) ہُن قبَول اوہناں دَا ا ِس پاروں ناہ ہونا، اَللہ دَا انِکار اوہناں نیں کِیتا نال او س دے پیغمبر دَا ، اوہ نمَازاں وَل وی آوَن مَن موئے دے وَانگوں،خَرچ کَریندے چَٹی بھَردے لَگّن
  9,55,مال اولاد اوہناں دِی تَک کے ،رُعب ہَیٹھاں ناہ اُکا آویں،اَللہ اِہناں دی رَاہیں اِی ،اوہناں تائیں ،وِچ عَذابے اِس دُنیاوی جِیون اَندر ہے پانے دِی نِیت رَکھدا تے کَفرونی حَالت وِچ اِی ، جان اوہناں دِی لینا چاہندا
  9,56,اِیہہ اَللہ دِی قَسماں کھَا کے ، لَکھ یَقین دِلاوَن اوہ تُہاڈے وِچوں ، اوہ نال مول (ہرگز) تُہاڈے وِچوں،ایہہ تاں ڈَردے ہُن اِنج کَردے
  9,57,جے کوئی ٹھَاہر(پناہ) ملِے اوہناں نُوں غار کوئی یاں کُھندر(چُھن دی تھاں)،اِیہہ اوہدر نُوں مُونھ کَر جان ، تُڑا کے رَسّے
  9,58,اوبھی اِہناں وِچوں ہے نیں ،صَدقے وَنڈن (تقسیم) بارے جیہڑے، طعَنے تینوں دیندے،پر جے اوہناں نُوں اوہدے وِچوں دِتّا جائے تاں اوہ راضی ،جے کَر ناہ دِتّا جائے اوسے ویلے مُونھ بناندے
  9,59,چنَگا سِی جے رَاضی ہوندے اوس دے اُتّے اَللہ اَتے رَسُول اوس دے نےجو دِتّا سی تے ایہہ کہندے اَللہ بہت اَساڈے واہتے، اَپنے فَضلوں اَللہ ہور دیسی ،پَیغمبر وَ اوس دَا دیسی،اَللہ وَل اِی تَک اَساڈی
  9,60,"اِیہہ خَیرا تاں ہین اَصل وِچ ،تھُڑیاں واہتے(فقیراں محتاجاں واہتے)،مَسکیناں دے واہتے،تے خَیرا تاں وَنڈّن اُتّے لگےہوئے لوکاں واہتے،تے اوہناں دے واہتے دِل جِنہاں دے وَس کَرنے لُو ڑیندے نیں(تالیف قلب مطلوب) نالے بَند ی واناں واہتے(قیدی تے غلام چھڑاون واہتے)قرَضائیاں تےاَللہ دِی رَاہیں واہتے تے مُسافراں واہتے ,اَللہ وَلّوں فرض ہے وے ، بےشک اوہ علیم حکیم اے"
  9,61,تے اوہناں دے وِچوں اوہ بھی جو سَتاندے ہین نَبی نُوں کہندے نیں اوہ کَن اِی َکن اے(کَنّاں داکَّچا اے) کہہ دے ہاں اوہ کَن اِی کَن اے بھَلے تُہاڈے واہتے۔اوہ اَللہ دِی سُن کے سَچ سَمجھدا اے۔تے مومَن لوکا ؐ دِی وِی سُن کے سَچ سَمجھدا اے تے اوہناں دے واہتے رحمت جیہڑے اِس دِی مَن ٹُردے نیں،
  9,62,اِیہہ اِللہ دیاں قَسماں کھاوَن تاں جے راضی کَرن تُہانوں،حالاں اَللہ اَتے رَسول اوس دے نُوں راضی کرنا چوکھا بَندا ہے وے جے (دِلّوں )اوہ مومن ہووَن
  9,63,کی اوہناں نُوں مَعلوم نئیں اَللہ اَتے رَسُول اوس دے دَا جیہڑا ویری(دشمن)دوزخ دی اَگ اوس دے واہتے جِس وِچ اوہ ہَمیشہ رہسی،ایہہ وَڈی رُسوائی ہے وے
  9,64,ڈردے ہین مُنافق ایس توں مَت خَلاف اوہناں دے کوئی سُورت نازَل ہووے جِس تَوں ظاہر تھِیوے جو اوہناں دے اَندر، کہہ دے کھَچاں ماری جاؤ(کلیاں بیھ کے)،پر اَللہ ہُن ، جس دا خوف تہانوں، اُس نوں ظاہر کَرکے رہسی
  9,65,تے جے اوہناں کولوں پُچھیں، اوہ آکھن دے ، اَس تاں ایویں ہے ساں شُغلیں ،گَپّیں لگے،آکھ اوہناں نُوں ، گَپ کھچ واہتے اَللہ اَتے کَلام اوس دا تے پیغمبر اِی اُس دَا لَبھے ہین تُہانوں
  9,66,عُذر گھَڑو ناہ اینویں،بے اِیمان تُسی ہو وَنجے، مُڑ اِیمان لیا کے،جے کر اَسی ُتہاڈے وِچوں کَر معاف اِکنَاں نُوں دئیے ،اِکنَاں تائیں اَسی سزائیں دے کے رہئیے کیوں جے اوہ خَطائی(مجرم)
  9,67,مَرد ہووَن یاں رَنّاں ہووَن اِکّو کُج مُنافق سارے،مَندیائی کَرنے نُوں آکھن تے چَنگیائی وَلّوں ٹھاکن(روکن )تے اوہ مُٹھاں گھُٹ کے رَکھّن (خیر توں ہَتھ روکن ) اوہ اَللہ نُوں بھُل گئے تے اَللہ وِی اوہناں نوں بھُلیا، بے شک نافرمان مُنافق
  9,68,اِیہہ مُنافق مَرد ہووَن یاں رَنّاں ہووَن، اَللہ دَا اہناں دے بارے تے کفروناں بارے دوزخ دی بھا ،دَا اے وعدہ، جِس دے وِچ اوہ ہمیشہ رہسن ، اِیہوا اوہناں واہتے کافی، رَب دِی لَعنت اوہناں اُتّے،ہے عَذاب اوہناں دے واہتے دائم رہنے والا
  9,69,جِکن تُہاڈے تَوں پہلاں دے سِی تُہاڈے نالوں اُتّے،قُوتّ وِچوں ،دولت وِچوں، جِیا جَنت دے وِچوں(دنیا وچوں) ،کھَا ہنڈا کے اپَنے حصے(مزے لُٹ کے) ۔اوہ راہی ہوئے(اوہ گزر گئے)، کھا ، ہَنڈا کے تُساں وی راہی ہونا جویں تُہاتھوں پہلاں ، کھا ، ہَنڈا کے راہی ہوئے،اوہناں بَک بکارے(بحثاں ) کیتے ، تُساں وِی کیتے،اِنج دَیاں دے عِمل کِسے ناہ بنے(کنارے ) لگنے کی ایتھے کی اُوتھے۔تے اوہوا اِی گھاٹل(خَسارے والے)
  9,70,کی اِہناں تائیں اَپڑی ناہیں گَل اوہنا ں د<ی جو اِہنا ں تَوں پہلاں ہوئے،نوح تے عاد ، ثمود کیاں دِی، اِبراہیم کیاں دی، مَدین دی تے اوہناں گوٹھاں دِی (بستیاں دی) ۔اَساں جِنہاں نُوں ہیٹھاں اُتّے کر دِتّا سی(جنہاں بستیاں نوں اُ لٹ دِتا سی) اوہناں کول رَسُول آئے سَن کھُلم کھُلیاں گلَاں لے کے،تے اِنج نال اوہناں دے، اَللہ ظُلم نئیں سی کیتا،ظلم اوہناں نے آپوں اَپنیاں جاناں دے نال کیتا
  9,71,مومن سارے اِک دوجے دے سَنگی(رفیق) ، مَرد ہووَن یاں زَالاں (عورتاں)، ایِہہ چنَگیائی آکھن(نیکی دا حکم دین) ، مَندیائی توں ٹھاکن(بُرائی توں روکن)،قائیم کَرن صَلاتاں ، دَین زکاتاں،آکھے لَگن اِیہہ اَللہ دے نالے اِس دے پیغمبر دے، اِیہو ا وَل(اے لوک ) نیں رَب جِنہاں تے رحمت کَرسی،بے شک اَللہ آپ عزیز حکیم اے
  9,72,اَللہ دَا اے وَعدہ اے مومَن مَرداں ، رَنّاں(عورتاں ) تائیں ،دیسی(عطا کرسی ) اوہناں نُوں اوہ ، وِچ بہشتاں جائیں(رہائش) کول جِنہاں دے وَگدے پانی، دائم اوہناں وِچ اوہ رہسن ،اَبدی باغاں وِچ ٹھکانے، سُتھرے صاف اوہناں دے ہوسَن،سب توَں وَڈی گَل جے ، اَللہ راضی اوہناں اُتے ہوسی ، ایس توں وَدھ کے ہور وَدھیری جِت(کامیابی) ہوندی اے کیہڑی
  9,73,بھِڑ جا (مُقابلہ کر) تُوں کَفروناں تے دو رَنگیاں(منافقاں) دے نال اے پیغمبر، تے کَر سَختی اوہناں اُتے،ہے جہنم ٹھاہڑ (ٹھکانا) اوہناں دِی تے اوہ کِنّی بھیڑی(بدترین) ٹھاہڑ اے
  9,74,اِیہہ اَللہ دِی قَسماں کھا کے کہندے ایسی ویسی گل اَساں نئیں کوئی کیتی، حالاں کلمے کُفر والے اوہ بَک دے رہے نیں تے اسلام لِیاوَن پِچھوں اوہ کافر ہوئے،اَن پکنے اوہ مَنصوبے رہےپکاندے،اوہناں نال ناہ ماڑا کیتا اللہ تے پیغمبر اُس دے،جے اوہناں نُوں اَپنے فَضلوں رَجیا پُجیا کیتا،جے ہُن وی اوہ باز آجاوَن ،اِس وِچ اوہناں دِی بھَلیائی تے جے پُٹھاں موڑا کھاوَن تے اَللہ ڈاہڈا وَختاں(دردناک عذاب ) وچ اوہناں نُوں پاسی اِس دُنیا وِچ ،اُس دُنیا وِچ۔دَھرتی اُتے اوہناں دَا سنگی ناہ اِمدادی ہوسِی
  9,75,اِہناں وِچوں اِی اوبھی نیں،قول جِنہاں اَللہ نال کیتا،جے اَسانوں مال غَنیمت اوہ دے دیو ے(اِس دے وِچوں ) صَدقہ دیساں، نیکوکاراں وِچوں تھِیساں
  9,76,پر جَد اَللہ نے فَضل اوہناں اُتّے کِیتا،اوہناں نے کَنجوسی کیتی سی، اِس بارے گَل توں پھِر گئے، اوہ کَنّی کَتراندے
  9,77,اِس دے پاروں اَللہ نے اوہناں دے اَندراں رَکھ دِتی دو رَنگی(نفاق) جیہڑی رہسی روزِقیامت تائیں کیوں جے اوہناں نے اللہ دے نال کیتے ہوئے وعدے توں کنڈ پھیری،تے اِس پاروں جیہڑےجھُو ٹھ اوہناں نے بولے
  9,78,کی ایہہ کَیڑ (جاندے) نئیں اوہناں نوں ،اَللہ جانے اوہناں دی ہر گھُر گھُر نُوں تے کَجی(چھپی) گَل نُوں،بےشک اَللہ ہے غیباں نُوں جانن والا
  9,79,جیہڑے لوکی کیڑے پاندے(گلاں کردے)،مومن لوکی جَد خوشی خوشی صَدقے دیندے تے اوہناں دی کھَچ مَریندے(مذاق اُڑاندے) جیہڑے وَختاں(مشقت)نال کمائے وِچوں دیوَن، اَللہ اوہناں دِی کھِچ اوہناں وَل (طرف ) پَرتاسی،بھا (نصیب ) اوہناں دے اوس۔عذابے اَوکھا کَرنے والا کَرنا
  9,80,اوہناں واہتے تَوں سفارش کَر بخشش دِی بھاویں ناہ کر(اِک برابر) ستر واری (70 مرتبہ)جےاوہناں دِی کریں سفارش بخشش واہتے،اَللہ بخشش مول ناہ اوہناں تائیں (اللہ اوہناں نوںمعاف ناہ کرسی) کیوں جے اَللہ دے ایس پیغمبر دے اوہ اِنکاری ہوئے تے اللہ ناہ (ایس طرح ) دے بَدعہداں نُوں راہے پاندا
  9,81,ہے سَن خوُش گھَراں وِچ پِچھے رہنے والے، اَللہ دے پیغمبر تَوں پِچھے رہ کے اوہناں ناہ وَارا کھادا۔مالی جانی رَب دِی راہ جہاد کرن اوہ،کہندے سَن اوہ، اِس گَرمی وِچ لام(جہاد) اُتّے ناہ جاؤ، کہہ دے نَار جَہنم والی ڈاہڈی لوہنے والی ہے وے،کاش ایہہ گَل اوہ سَمجھدے
  9,82,اوہناں دے بھَا (نصیب) تھوڑ ا ہَسنا ، چَوکھا رونا جو کَرتوت اوہناں نے کیتے اِس دے بَدلے
  9,83,اِہناں وِچوں رَب کرے، جے کَر تیرا میل کِسے ٹولے نال ہووے،تے اوہ (اگوں ) لامے(جہاد) واہتے تیتھوں لَین اِجازت، کہہ دے میرے نال تہاڈا، لامے جانا ہُن ناممکن ہویا۔ میرے نال کَدے وِی رَل کے ہُن ویری (دشمن ) نال ڈانگو سوٹامُمکن ناہیں،َکل تُہاڈی ہے رَضا سِی نِٹھ بہنے دِی (بیٹھے رہن دی)،ہُن وی پچھے رہ سَن جیہڑے ،اوہناں نال نِٹھ کےبیٹھ
  9,84,اِہناں وِچوں توُں کِسے دَا نَئیں جنازہ پَڑھنا،ناہ کِسے دِی قَبر اُتّے اِی جا کھَلونا، اَللہ اَتے رَسُول اوس دے سَن اوہ اِنکاری تے فاسَق اِی رہ کے موئے(مَرے)
  9,85,مال ،اَولاد اوہناں دِی ،تینوں کیوں دَلیلاں دے وِچ پائے،اَللہ دِی اے مَرضی ہے وے دُنیا وِچ اِہناں تَوں ایں ، اوہناں نوں وَختا ں (سزا) وِچ پائے تے اوہناں نُوں رَکھ کے کافَر مَارے
  9,86,تے جَد سورت نازل ہوندی اے اِس بارے ۔اَللہ تے اِیمان لِیاؤ تے اِس دے پیغمبر دے سَنگ ہو کے لَڑو لڑائی پج آؤندے وِی(صاحبِ حثیت) اوہناں وِچوں لَین اِجازت تیرے کولوں (گھر رہنے دی)تے ایہہ کہندے سَانوں پِچھے رہنے والے لوکاں نال اِی رَکھو
  9,87,اوہ اوس اُتّے راضی ہوئے ، رہندڑیاں(گھر وچ رہن والیاں) دے وانگ اوہ رہوَن پِچھے ،اَللہ نے اِس کَرکے اِی تاں اوہناں دے قَلباں دے اُتّے مُہراں لائیاں اوہ سَمجھن توَں رہ گئے
  9,88,دوجے پاسے پیغمبر تےاوہ وَل جیہڑے نال اِس دے اِیمان لِیائے۔مالی،جانی رہے جہادے لگَے اِہناں لوکاں واہتے اِی بھَلیائیاں تے اِیہوا اِی ہین فلاحواں پان والے
  9,89,اوہناں واہتے ہین بَہشتاں اَللہ نے تَیار کَر رَکھیاں ،کول جِنہاں دے وَگدے پانی ،دَائم اوہناں دے وِچ رہسن، ایدوں وَڈی کی جِت ہونی
  9,90,تَھل وَاساں(صحرئی بدُو)) دے وِچوں وِی تے حیَلے گھَڑنے والے آئے تاں جے اوہناں دَا چھُٹکارا اِی ہو جائے(اجازت مل جائے)،پِچھے بیٹھے رہے سَن اوہوا، اَللہ تے پیغمبر اسِ دے نوںجھُوٹھ جکَھایا(جھوٹھا عہد کیتا)،ایس طرح دے کفروناں نُوں مِل کے رہسی مار دُکھاویں(دردناک سزا)
  9,91,ناہ کوئی دَھکا ہے اِس بارے ، کَمزوراں تے بیماراں اُتّےیاں اوہناں تے کول جِنہاں دےخَرچ کَرن نُوں وَافر ناہیں، پَر اوہ بولن چنَگے کلَمے َاللہ بارے تے اِس دے پیغمبر بارے،نیکوکاراں (معذوراں) تے مُول الاہمہ(اعتراض) ناہ کوئی آوے،اَللہ آپ غَفور رَحیم اے
  9,92,اوہناں تے وِی اِلزام کوئی نا ہ آوے،جیہڑے کول تیرے آجاوَن تاں جے ملِے سَواری کوئی ، تےتوں آکھے نئیں تُہاڈے واہتے میرے کول سَواری تے اِس غم توَں وَسدی اَکھیں (روندیاں اَکھاںنال )جان گھَراں نُوں اوہ کَدے اَج اپنے کولوں خَرچ کَرن دے قابل ہوندے
  9,93,ہاں اِلزام اوہنا ں تے آوے جیہڑے اپڑآوندے ہوئے (مالدار ہوندے ہوئے)تیرے کولوں چھُٹی مَنگن تے اِس گَل نُوں چَنگا جات ا رہن اوہ پچھے سنگ رہیلن زالڑیاں دے(گھَر وِچ پیٹھن والی عورتاں نال شامل ہونا پسندکَرن )اِس توں مُہر اَللہ نے لائی اوہناں دے قَلباں دے اُتّے تے ہوئے اوہ سَمجھوں عاری)
  9,94,انج دے لوکاں پِچھے جانے اُتےگھَڑنے عُذر (ہزار) تُہاڈے اَگے ،کہہ دے عُذر کَرو ناہ اُکّا، گَل تُہاڈی ہُن ناہ کوئی مَنّی جانی، اَللہ نے ہر گَل تُہاڈی دَس دِتّی اے سانوں ،تے ہُن اَللہ تے پیغمبر اوس دَا ،تَکسن جیہڑے عَمل تُہاڈےہوئے،فیر تُہانوں اوس دے اَگے کِیتا جاسی، جیہڑا جانو(جنانن والا) ہر اوہلے (چُھپےکم دا ) ، اَن اوہلےدَا (ظاہر دا)
  9,95,لاموں (جنگ توں) مُڑ کے جد آوو دے کول اوہناں دے اِیہہ َاللہ دیاں قَسماں کھاسن آکے کول تہاڈےتاں جے کِدھرے اوہناں وَلّوں مُونھ ناہ پھیروں۔اِس کَر کے ہُن اوہناں وَلوں مُونھ اِی پھیرو، ایِہہ گَندے نیں تے دوزخ اِی ٹھاہڑ (رہن دی تھاں) اِہناں دِی اَپنے کَرتوتاں دے بدلے
  9,96,اِیہہ قَسماں ہُن ایس تَوں کھاندے ،توں اِہناں تے راضی تھِیویں جے تُوں راضی وِی ہو جاویں اِہناں اُتّے اَللہ راضی مول(ہرگز) ناہ ہوندا بےزبانے (فاسَق)لوکاں اُتُے
  9,97,اِیہہ تَھل واسی (صحراہی بدو)م خُوب پَکیرے (زیادہ سخت نیں) کُفر اُتّے دو رَنگی َاندر تے اَللہ نے جو کُجھ اپَنے پیغمبر تے نازل کیتا اِس دیاں حَداں ناہ گولن وِچ ماہر اے(دِین دی حدود توں ناواقف نیں)،پر اَللہ وِی تے آپ حَکیم عَلیم اے
  9,98,تَھل واساں(صحرئی بدُو)) دے وِچوں اوبھی جیہڑے راہ خُدا دے وِچ دیوَن نُوں اِک چَٹی جانَن،اوہ ایس اُڈیکے(انتظار کردے نیں )، اَند ر گیڑ کِسے تُس آجاؤ(تُسی کِسے چَکر وِچ آجاؤ)۔مَندا گیڑا اوہناں تے آؤنا(حالاں بدی دا چکر اوہنان تے ای مسلط ہونا اے)،بے شک اَللہ آپ سَمیع ، آپ عَلیم اے
  9,99,تے تَھل واساں (صحراہی بدو) دے وِچوں اوبھی اَللہ تے اِیمان جِنہاں دا، نالے چھیکڑ والے دِن تے ،اوہ جو کُجھ وی خرچ کَریندے (راہِ خُدا دے) جانَن اِس نوں اِک ذَریعہ رِب دے نیڑے ہو جانے دَا ،نالے اِنج دُعائیں لینے دَا پیغمبر کولوں، بے شک اوہناں واہتے اِیہہ خَرچاوَٹ(خرچ) ہے وے نیڑے ڈُھکن دَا اِک رَستہ،ایس طریقے اَللہ اپنے رحمت دے گھَر سر پر داخل اوہناں نوں کَر لیسی، بے شک اَللہ بخشنہارا نالے رحمت کرنے والا
  9,100,رب دے کول سَب تَوں اَگے اوہ جنہاں نیں سَب توں پہلاں ہِجرت کیتی تے اوہ جیہڑے اوہناں نُوں جی آیاں نُوں آکھن والے ہے سَن نالے اوبھی جیہڑے اوہناں دے پِچھے لگَے جیئوں (جیسا) لَگن د َا حق ہوندا اے ، اَللہ اوہناں اُتّے راضی تے اوہ راضی اَللہ دے اُتّے،اوہناں واہتے اَللہ ہین بہشت اسارے(باغ مہیاکیتے) کول جنہاں دے وَگدے پانی، دائم اوہناں دے وچ اوہ رہسن، اِیہہ بڑی اِی جِت اوہناں دِی
  9,101,تیرے آسے پاسے جیہڑے تَھل واسی نیں(صحراہی بَدو) اوہ مُنافق، اِنجے ہین مدینے وِچ وِی لوک مُنافق، دو رَنگی دَا رنگ ا ِہناں تے پَکّا چَڑھیا، تینوں کَیڑ(خبر) اوہناں دِی ناہیں سانوں کَیڑ اوہناں دِی واہوا،اَسی عذاب اوہناں نُوں سرپر دیواں گے دو وَاری ،فیر عَذابے ہور وَڈیرے، وِچ اوہ پیَسن
  9,102,اِنج دے کجُھ لوکی اِہناں وِچوں ،جِنہاں مَن لئَے(تسلیم کیتے) مَند اَپنے(قصوراپنے)،چَنگے ،مَندے دِی کِھچڑی نین عَمل اوہناں دے،ہو سَکدا اے اَللہ کَرے کَرم اوہناں تے،بے شک اوہ غَفور ، رَحیم اے
  9,103,اوہناں دے مالاں دے وِچوں صَدقہ لیندے ہوئے پاک پَوِتّر ر ایہہ سَمجھ اوہنا ں نوں کَرسیں اَندروں باہروں،منگ دُعا اوہناں دے حَق وِچ، اوہناں نُوں تَسکین دُعا تیرے تَوں ہوسی،بے شک اللہ سننے والا جانن والا
  9,104,کی اِہناں نُوں عِلم ناہ اِس دَا،اَللہ ای اے اپَنے بندیاں دِی توبہ نوں منن والانالے دِتیاں خیراتا ں نُوں،بے شک اَللہ بڑا اِی توبہ مَّنن والا نالے رحمت کرنے والا
  9,105,اِیہہ سمجھا دے اوہناں تائیں ، عمَلوں دَسو(توبہ کرکے) اَللہ تَکسی(ویکھے دا ) عَمل تہاڈے،نالے اِس دَا پیغمبر وِی تَکسی نالے مومن لوکی تَکسن(ویکھن دے) ،جھب(فیر) تُساں نے اوس دے اَگے پیش ہونا،ہر اوہلے،اَن اوہلے (ہر چھپے تے کھلے عمل)دَا جاننہارا(جانن والا)، دَس دیوے دَا کی سَن عَمل تُہاڈے
  9,106,تے کُجھ اوبھی ہین جِنہاں دے بارے،رَب اِی جانے جو ہونا ایں،اوہ چاہے تے وِچ عذاب اوہناں نوں پائے ،تے جے چاہے توبہ کَرے قبَول اوہناں دِی ،کیوں جے اللہ آپ عَلیم حکیم اے
  9,107,تے اوہ لوک جِنہاں نے مَسجد پائی ہے وے مومن لوکاں وِچ تَریڑاں (نفاق)پانے واہتے،کُفر کھلاوَن ،پھوٹ پواوَن واہتے،اوہناں دَا اڈُا(کمین گاہ) کر کے جیہڑے پہلاں لڑدے رہے نیں نال اَللہ دے تے اُس دے پیغمبر دے وِی،تے اوہ قَسماں کھاندے ہوئے آکھن دے ۔نیت ٹھیک اَساڈی ہے وے، پر اَللہ اے شاہد اِس تے اوہ سَراسَر جھُوٹھے
  9,108,اِس دے وِچ وَڑیں ناہ اُکّ ا(ہرگز اس وچ داخل ناہ ہونا) پہلے تَوں اِی جیہڑی مَسجد تَقوے تے اُسری(قائم ) ہے وےاُس دے وچ کھَلونا جَچدا، اِس دے وِچ اوہ لوکی ہوندے جِنہاں نُوں سُتھرائی نال محبت ہوندی تے اللہ وِی سُتھرائی لوکاں نال مُحبت رَکھدا ہے وے
  9,109,کی اَللہ دے تَقوے نالے اِس نوں راضی رَکھن اُتّے جِس اُساری(قائم ) کیتی ہووے وِی نِیہہ (بنیاد) اپنی وی،اوہ چنگا ، یا اوہ نیہہ اُساری ہووے جس نے ڈھٹھن ہاری کَنّی والے دَندے تے ا وہ (دندا) نال ای اِس دے دوزخ دِی اَگ اَندر ڈِگے،بے شک اَللہ اوہناں ناہ راہے پاندا، جیہڑے لوکی کَم اَن ہونے کَردے
  9,110,ایہہ اُساری (عمارت)ہے اُساری (بنائی)جیہڑی رَڑکن(دل وچ پھا نس ) بَن کے اوہناں دےاَندراں دے وچ دائم رہسی،جد تائیں اوہناں دے اَندرونے ٹوٹے ٹوٹے ناہ ہوجاسن،اَللہ دِی ذات عَلیم حَکیم اے
  9,111,لَئیاں ہین(خرید لَئی اے) اَللہ نے مومن لوکاں کولوں ،جاناں تے اَموالاں بے شک،جنت دے بَدلے، اَللہ دِی راہ لَڑدے اوہ مارَن یاں آپ مَریوَن(شَہید ہووَن)، وِچ توَراتے ،وِچ اَنجیلے وِچ قُرآنے اِیہوا آیا ، اَللہ ہے اپنے اِس وَعدے اُتے قائم،ا للہ دے نالوں کیہڑا قول اَپنے دَا پکّا، اِس ک؟رکے جو وَنج(سَودا) تُساں اَللہ دے نال کیتا ہے وےخُوشی مَناؤ اِس دے اُ تے ، اِیہوا اِی تے جِت وَڈیری (وَڈّی کامیابی) سَب تَوں ہے وے
  9,112,اِیہہ بپاری اوہ نیں جیہڑے عابد، تائب تے تبلیغی، اُس دے اگے جُھکنے والے،سجدے کرنے والے، چَنگیائی دا آکھن والے مَندیائی توں ٹھاکن والے، رَب دِیاں حَدَّاں دے رَکھوالے، خو شخبری دے ایس طرح دے مومن لوکاں تائیں
  9,113,اےنَبی نُوں زیب ناہ دیوے ناہ اِیمان لِیائے لوکاں نُوں زیبے ۔مُشرک لوکاں دے حَق اَندر َبخشش مَنگن بھاویں سَکّے سَاک(رشتے دار) اِی ہووے،اِس تَوں پِچھے جَد اوہناں دے اُتّے واضح ہو چُکیا اے ،جے اِیہہ لوکی اَگ دے واسی
  9,114,باپ اپنے دے واہتے اِبراہم نَبی دَا بخشش واہتے ، رَب نُوں کہنا اُس وَعدے دَاپالن ہے سی جیہڑا سی اِس تَوں کَروایا،تے جد اُس تے روشن ہویا اوہ اَللہ دَا دُشمن ہےوے۔اوہ اُس توں اِک پاسے ہویا، بے شک اِبراہیم حَلیم طَبیعت والا تے سِی نَرم دِلے دَا
  9,115,اَللہ دَا دَستور نئیں اِیہہ ،قوم کِسے نُوں سِدھا رَستہ دَس کے(ہدیت دے کے ) پُٹھے راہے پائے (گمراہی وچ مُبتلا کرے) جَد تَک ناہ اوہناں نُوں ناہ کھُلم کھُلا دسّے، کیہڑی کیہڑی شے توں رہن اوہ بچ کے،بے شک اَللہ نُوں کیَڑ (خبر) ہے وے اِک اِک شے دِی
  9,116,اِیہہ اَسمان زَمین تمَامی، اَللہ دے اِی ہَتھ وَس ہے نیں(قبضے وچ نیں )،اوہ جَوَائے (زندگی دیندا اے) اوہوا مَارے، اَللہ باجھوں (سوا) ہور تہاڈا ناہ کوئی سائیں ، ناہ ِامدادی
  9,117,نَظر کَرم دِی اَللہ کیتی، وَل نبی دے ، تے اوہناں وَل جیہڑے ہِجرت کَرکےآئے تے اَنصاراں دے وَل جیہڑےاَوکھے ویلے اِس دے پِچھے لگَے،اس دے پِچھے جَد اِک ٹولہ دِل تَریڈے کر لینے دے نیڑے ڈُھک پیا سی،فیر نَظر رحمت دی اوس نے ،اوہناں اُتّے کیتی ،کیوں جے اوہ رؤف رَحیم اوہناں دے حَق وِچ
  9,118,اوہناں تِنّاں اُتّے وی اوس نَظر کَرم دِی کِیتی،جِنہاں بارے گَل اَگیرے چَل کے بنے لَگنی ہے سی (جنہان دا فیصلہ ہونا سی)،اِیہہ زَمین جَدوں کھُل ساری(سار ی وسعت دے باوجود)، اوہناں نُوںسَوڑی(تنگ) ہوندی جاپی تے اوہناں جاناں َلگیاں وِچ شَکنجے آئیاں، اِیہہ محسوس اوہناں نے کیتا۔اَللہ کولوں ہَٹ کے کِدھرے جان اوہناں دَا ناہیں،فیر اَس اوہناں اُتّے کیتی نَظر کَرم دِی، تاں جے توبہ تَاب کَرن اوہ، بے شک اللہ رَج کےتوبہ سُننے والا نالے رحمت کرنے والا
  9,119,اے اِ یمان لیائے لوکو ڈَردے رہو خُدا دے کولوں تے سچیاراں دے نال رَہوو
  9,120,اِیہہ مدینے دے وَسنیکاں دے یا جیہڑے آل دَوالے تَھل واسی(بدو)نیں ،جچدا نئیں سی اوہ رسول اَللہ نُوں چھڈ کے پِچھے رہندےیا اوہ جِنداں(زندگیاں) اَپنیاں نُوں اِس دِی جِندوں اَگے گِن دے، اِس َکر کے جے لَگدی ہے وے جیہڑی تیہہ تھکاوٹ تے بھُکھ رَب دے رَستے دے وِچ اوہناں نوں،وغڑ وغڑیاں کَردے جاندے،کفروناں نُوں کَوڑ دِیواندے یاں دُشمن نُوں چَرکا لاندے اِس دے بَدلے اوہناں دے ناں(نام ) لِکھیا جاندا عَمل چَنگیرا، کیوں جے اَللہ ضائع اُکا کَردا نئیں اَجر اوہناں دے جیہڑے چَنگے کَم کَردے نیں
  9,121,اوہ جیہڑا وِی خَرچہ کَردے تھوڑا یاں بُہتا یاں جنِاّ ں وِی پینڈا (فاصلہ)کَردے۔اِس دَا بَدلہ لِکھیا جاندا ، اَللہ چنگا اَجر اوہناں نُوں دیسی اوہناں دے عَملاں دے پاروں
  9,122,اِیہہ تاں مُمکن ناہیں ہے سی ٹُر پیندے مومَن سارے دے سَارے اِی، پر لوکاں دے اَپنے اَپنے قَبیلے وِچوں کیوں ناہ کجُھ نے آکے اَپنی دِینی سوجھ وَدھائی تاں جے واپس اَپنے اَپنے لوکاں وِچ اُوہ ہوڑ ہَٹک (خبردار )کَر دے تے اوہناں نوں (مَندیائیاں تَوں ) ڈَکدے(بُرائیاں تَوں روکدے)
  9,123,اے اِیمان لِیائے لوکو آسے پاسے ہین تہاڈے کافر جیہڑے ، اِنج اوہناں نوں پے جاؤ، جے زِچ ہوجاوَن اوہ تُہاڈے ہتھوں ،تے اِیہہ چیتے رَکھو اَللہ اوہناں دَا جو اُس دِی مَن دے(متقی)
  9,124,تے جَد سورت نازل ہوندی ہے وے کوئی، اوہناں وِچوں اِنج دے وِی نیں جیہڑے آکھن اس دے پاروں کِس دَا ہے اِیمان وَدھیرا ہویا (ایمان وچ اضافہ ہویا )، پر جیہڑے نے مَّنن والا اوہناں دَا اِیمان وَدھیرا ہو جاندا اے تے اوہناں نوں چا ء چَڑھدا اے(اوہ دِلشاد ہوندے نیں )
  9,125,روگ(نَفاق) جِنہاں دے اَندر ہے وے ، اوہناں دَا گَند اِس توَں ہور زیادہ ہوندا تے اوہناں نے کافر ہوندے اِی مَرنا ایں
  9,126,کی اوہناں نو ں دِسدا ناہیں (نظر نئیں آندا)اِک دو وَاری ہر سَال َاندر اوہ اَزمائش دے وِچ پیندے ،مُڑ وِی توبہ اوہ ناہ کَردے تے ناہ مَت مَن دے(نَصیحت قبول کردے)
  9,127,تے جد سورت نازل ہوندی ہے وے کوئی ایہہ اِک دوجے وَلوں (کہندے ہوئے) کی مُنافق پَن اَساڈا کھُلیا ، اِہناں اُتّے فیر اِک پاسے ہو جاندے نیں،پھیرا اوہناں دے قَلباں اَندر اَللہ پایا کیوں جے اوہ تے سوچوں کورے
  9,128,سوچو اِک رَسُول تُہاڈےوَل ،تُہاڈے وِچوں آیا،جیہڑا کُڑھدا ہے اِس اُتُے، تُسی مُصیبت وِچ پوَو ناہ، چاہ تُہا ڈی اس دے اَندر(تُہاڈی فلاح چاہندا اے)،مومَن لوکاں واہتے اوہ رحمت اِی رحمت ، اوہ شَفقت اِی شَفقت
  9,129,اِس تے وِی جے (اے پیغمبر )اوہ مُونھ موڑن،کہہ دے اَللہ کافی ہے وے ،میرے واہتے،باجھ اس دے (اس دے سوا)مَعبود ناہ کوئی،میں توکل اِس تے کَردا،اوہوا مالک عَرش وَڈّے دَا