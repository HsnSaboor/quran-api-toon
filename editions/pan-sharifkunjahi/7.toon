quran[206]{c,v,t}:
  7,1,الف- لام- میم- صاد
  7,2,ہے کتاب ایہہ نازل کِیتی تیرے اُتّے کیوں دھڑکے دِل تیرا اِس دِی رَاہیں جھُونن(چلن ) اُتّوں ، اِس وِچ مَتّل گَلاں اِی نیں مَنّن والے لوکاں واہتے
  7,3,لوکو پلّے بَنّو (پیروی کرو) رَب تہاڈے وَلّوں آیا وَل تہاڈے،مَنّوں ناہیں سائیں کوئی، اِس دے باجھوں (علاوہ)،گَل تہانوں گَھٹ اِی چیتے رہندی
  7,4,ویکھو کِنّیاں گوٹھاں(بستیا ں) اَساں ویران بَنائیاں جَدوں عَذاب اَساڈا آیا سُتے (راتی) تے جاگے(دِن وچ جَد آرام کَریندے) اوہناں اُتّے
  7,5,"تے مُڑ اوس عَذابی ویلے اوہناں دے مونہوں چوں ایہوا نکِلے :ساڈی نافرنی سَاڈے اَگّے آئی"
  7,6,کَرنی پُچھ اَساں نیں،اوہناں کولوں ،جَنہاں وَل پیغمبر گھَلّے،پیغمبراں توں وِی پُچھ ہوسِی
  7,7,تے مُڑ لوکاں نوں دَسّاں دے جو کجُھ عِلم اَساڈا دَسْدا،اَسی تے اوہلے بیٹھے نئیں سَاں
  7,8,اوس دِہاڑے تول ہونا ایں حَقا سَچا، جِن دَا پَلّہ بھَارا ہوا اوہ مُراداں پاسَن
  7,9,اے پَر ہَولے پَلَّے (ہلکے پلڑے ) وَالے اوہ اِی ہوسَن گھَاٹے دے وِچ اپنے تائیں آپ جِنہاں نے پایا، سَاڈے حُکماں دِی نافَرنی کَرنے توں
  7,10,ایہہ اَسی آں جنہاں ،تہانوں دَھرتی وِچ وَسایا، اِس دے وِچ تُہاڈے وَاہتے ڈَنگ ٹَپانے دے رَاہ کَڈے ، گَھٹ (تھوڑے لوک ای )اِحسان اوہ جانَن والے
  7,11,ایہہ اَسی آں جِنہاں ،تہانوں پیدا کیتا چہرہ مُہرہ دِتَّا، فیر ملَائک نُوں فَرمایا ، آدم دے اَگے سِْیس نَواؤ( سجدہ کرو)،سبَھناں سِیس نَوَائے اَڈ (سوائے) اَبلیسوں اوہ نیئوندَل (سجدہ کرن والے) ٹولے نالوں وَکھرا ہویا
  7,12,رَب نے پچُھیا کیہڑی گَلوں میری آکھی تے وی ہویوں تُوں نیئونوں نابَر(سجدہ کرن توں انکاری )،آکھن لَگّا میں اُچیرا(بہتر) اِیس توں،مینوں توں اَگوں (اَگ توں )خَلقایا تے خاکوں اِیس تائیں(نوں)
  7,13,حُکم ہویا ،دُور ہو جَا اِیتھوں،پھَونڈ (گھمنڈ) اِیہہ تینوں جَچدی ناہ سی ، توں اِیس ٹیں دی نِکل ہَواؤں
  7,14,آکھن لَگّا، مُہلت مَنگا روز قیامت تائیں
  7,15,حُکم ہویا ۔دے دِتِّی
  7,16,آکھن لَگُا تُوں رَاہ بَند مِرے تے کِیتی، اِِس توں کھِج کے ، تیرے سِدھے رَستے اُتّے تھَڑا دَیاں دَا میں اوہناں نُوں
  7,17,اوہناں دے میں اَگوں ،پِچھوں،سَجئیوں (سجے )،کھَبئیوں(کھبے) چَڑھ آواں دَا، تے توں تَکسیں چَوکھے تیرے،اَحسا ناں دَا مُل ناہ پاسَن
  7,18,رَب کہیا، نِکل جَا اِ یتھوں ،مَند (ذلیل) تے رَدْیا (ٹھکرایا) ہویا، اِنساناں چوں جیہڑے تیرے مَتھے لَّگے، دَوزخ بھَرساں نال تہاڈے سَب وَلاں دے
  7,19,اے آدم ؑ وَس (رہ) جَنت اَندر سَنگ (ساتھ) اَپنے سَنگ (ساتھی) دے ، جِتھوں جو کُجھ چاہو کھاؤ ،ہاں ایس رَکھ دے کول ناہ جانا نئیں تے نافرمانے تھِیسو
  7,20,پَر شیطان اوہناں نُوں اَپنی پَٹی لایا(بہکایا) ،تاں جے سَتَّر(شرم گاہیں) اوہناں دے کھَولے ،ہے سَن جیہڑے اوہناں کولوں پہلاں اوہلے(چُھپے ہوئے) آکھن لَگّا اِس شَجر توں رَب تہاڈا اِیس توں روکے ،جے ملائیک ناہ بَن جاؤ یاں اَمَرْہو جاؤ (ہمیشہ دِی زندگی پا جاؤ)
  7,21,قَسماں کھَا کے اوس کہیا سِی میں تہاڈا ہے چَنگ چاہی(سچاخیر خواہ)
  7,22,اِنج اوہناں نوں اوس بَچلایا(دھوکا دے اپَنے ڈھب تے لایا) پَر جَد اوس شَجر نوں چَکھیا، اوہناں اُتے سَتّر(شَرم گاہیں) اوہناں دے کھّلّے، تے اوہ باگی(باغ دے) پَتراں رَاہیں(پتے نال) سَتّر چھپٗاوَن لَّگے، تاں رَب اوہناں نوں جَتلایا، کی تہانوں اِیس شَجر ہَوڑ ہَٹک (قریب جان توںمنع)ناہ کیتی ہے سِی،تہانوں دَسیا ناہ سی، شیطاں تہاڈا دُشمن کھُلّم کھُلا
  7,23,اوہناں مَنَیا(تسلیم کیتا) اَپنے پیراں اَساں کلہاڑی آپوں ماری، جے توں بھُلیں ناہ بھُل اَساڈی (اگر توں درگزر ناہ کرے)، مہر (رحم) کریں ناہ سَاڈے اُتے ،گھَاٹ ای گھَاٹ اَساڈے لیکھیں (ساڈے نصیب وچ تباہی ہوسی)
  7,24,رَب کہیا ہُن اِیتھوں نِکلو،اِک تہاڈے اِکناں دے ہُن ویری تھیسَن دُنیا وِچ ہُن رہن تہاڈا تے چوگا اِک مدت تائیں
  7,25,ہَور کہیا جے اِیتھے اِی ہُن جیئونا ،مَرنا ہوگ(ہوسی) تہاڈا ، تے اِیتھوں اِی ہَوگ اُٹھا لا(ہوسی اُٹھانا)
  7,26,آدم جایو ،(اولادِ آدم) چَج لِباس بَناون لاون دا وِی دِتا اَساں تہانوں،جیہڑا کجَے(چھپائے) سَتّر( قابلِ شرم حصے)تہاڈے،نالے زینت بنے تہاڈی،اُنج لباس چنگیرا(بہترین) سَب توں تَقویٰ ہے وے، ،اِیہہ الٰہی مَتاں (نصیحت )ہے نیں پلَّے بَنّھن واہتے(یاد رَکھن لئی)
  7,27,آدم جائیو،(اولادِ آدم)،َمت شیطان تہانوں کِدھرے،رَستے توں تھَڑ کائے، جویں تہاڈے ماپڑیاں (ماں ،باپ) نوں جنتوں سی کَڈھوایا،لا ہ (اُتار کے) کے اوہ لباس اوہناں دا،بے پردا اِک دوجے اَگے اوہناں نوں کر دِتّا،اوہ تے اوس داٹولہ تہانوں اِنج گھاتے بیٹھا ہویا ویکھے جے آپوں نا ہ نَظری آوے،اَسی اوہناں نوں جیہڑے نیں ایمانوں کَورے(خالی)سَنگی (ساتھی)نیں شیطان بنائے
  7,28,بے حَیایاں کردے ہوئے اوہ اِیہہ کہندے ۔اِنجے وَڈوڈیرے سَاڈے کَردے آئے،اَللہ وَلوں اِی اِیہہ اَمر اَسانوں ہے وے،کہہ دے اَللہ بے حیایاں دا حکم تہانوں دیووے،کیوں جے بے تُکیاں اوہ ،اَللہ دے مَتھے لاندے
  7,29,کہہ دے اَمر مِرے رَب دَا اے ،سِدھے سانویں(راست تے انصاف تے ) رہنا،ہر عبِادت ویلے رَکھنی رَب دے وَل توَجہ سِدھی،اِنج چتَارو(پُکارو) اوس نوں جِویں چتَارن دِل چوں مَنّن والے،جِویں تہاڈی پہل ہوئی سِی،اِنجے پَرت(واپسی)تہاڈی
  7,30,اِک فریق ہدایت پائی ، اِکناں نے گُمراہی ،کیوں جے اوہناں رَب نوں چھڈ کے ،شیطاناں نال یَاری لائی،اِیس بھُلیکھے جے اوہ نیں سِدھ رَاہی
  7,31,آدم جایو ہَر عِبادت ویلے کَپڑے ڈَھب دے پاؤ، پیوو کھاؤ پر ایویں ناہ اُڈاؤ،کیوں جے اللہ نوں ناہ مال ا ُڈاؤ بھاوَن
  7,32,پُچھ حَرام بنَایا کِس نے اس پاوَن توں اَللہ جِس نُوں اَپنے بَندیاں واہتے آپوں آپ پیدا کیتا تے انِجے پاکیزہ کھاوَن ،کہہ دے ایہہ اِس دُنیا دے وِچ وِی ہین حَلال اوہناں دے واہتے جیہڑے ہین ایمان لیائے اَتے نَرول اوہناں دَا اِیہہ حِصہ ہوسَن اَگے چَل کے، اِنجے اَسی ایات اپنی تَفصیلاً دَسدے اوہناں نوں جو سُوجھت والے(علم رکھن والے)
  7,33,کہہ دے رَب مِرے ٹھاکے(حرام کیتے) بے حیَائی دے کَم سَارے ،کی ا ُکڑے(کھلے) کی اوہلے(چھپے)،حَق ماری تے دَھکے شاہی، انجے سِیری رَب دا کَرنا کیوں جے اِس دَا حُکم کَدے ناہ اُس نے دِتّا، ہے حَرام اوہ گَل وِی اَللہ دے سِر پائی ،جِس دِی اللہ وَلوں ہونے دی ناہ کول نشانی
  7,34,ہَر لوکائی دِی اِک مدت ،جَد اوہ مُدت ہو جاندی اےپُوری۔اِک پَل دِی ِوی ڈِھل ہووے ناہ ، پہل ہووے اِی
  7,35,آدم جایو جے رَسُول تہادڈے وِچوں آوَن کول تہاڈے ،تے اوہ آیات میری پاوَن کَن(کان) تہاڈے آکھے لگن تے گَند دھوَن والڑیاں نوں خوف ہوسی ناہ جھورا کوئی(رنج کوئی)
  7,36,ہاں جِنہاں آیات اَساڈی نوں ناہ مَنیا(ناہ تسلیم کیتا) تے ہیکڑ (سرکشی) توں کم لیئوو نیں(کم لِتا) اوہناں بارے،اوہ اَگ وَاس(جہنمی) ہمیشہ واہتے
  7,37,تے اِس نالوں بھِیڑی کس نال ہونی ایں ،جیہڑ ا لائے جھوٹھ اَللہ تے مَتھے ،اوس دَیاں یا ں دَسیاں نوں جھُٹھیارے،اِنج دے لوکا ں نوں اوہناں دَا لِکھیا مل کے رہسی، جَد اوہناں کول آون دے جِند کڈھ (موت دے فرشتے) سَاڈے وَلوں، اوہ پُچھن دے کِتھے ہے اوہ کَل سَددے سِی گے رَب نوں چھَڈ کے،اوہ آکھن دے اوہناں سَنگ تَڑوڑی کیتی (ساتھ چھڈدِتّا) اپنے بارے ایہہ گواہی اوہناں دِی اَپنی اِی ہوسی جے اوہ سَچ مُچ کافَر ہے سَن
  7,38,حُکم ہووے دا، رَلدے جاؤ اَگ دے اَندر سَنگ اوہناں دے جو تُساں توں پہلاں ٹولے ہو گُزرے نیں، جِناّں تے اِنساناں وِچوں جَدوں وی کوئی ٹولی داخل ہوسِی دوجی نوں پھَٹکار کَرے دِی تے جَد سارے کَٹھے ہوسَن، پشلے(پچھلے) کہسن اَگلڑیاں دے بارے،رَبّا ایہوا سَانوں نیں بَدراہوَن والے،اِک عَذاب دُونا اِنہاں نُوں دے اَساڈے نالوں،رَب کہے دَا سَب لئی دُونا(دوگُنا)، اَجے تہانوں اوس ہونی دِی سَار(خبر) ناہ کوئی
  7,39,سَب توںچھیکڑ والی(آخر والی) ٹولی نوں پہلی کہسی ۔کاہدی(کیسی) اَج وَڈِت(فضیلت) تہاڈی سَاڈے اُتے (ساڈے وانگ اِی)اپنا کیتا آپ تُسی وِی بھُگتو
  7,40,جیہڑے وی آیات اَساڈی مَن دے ناہیں،تے آ کڑ (سرکشی )وِچ کنڈ ھ بھَواندے(ناہ مَن دے) اَسماناں دے دَر اوہناں تے کھُلسن ناہیں تے اوہ جنت وِچ ناہ وَڑسِن،جیِتوں (جد تک)ناہ اُوٹھ(اونٹ) سوئی دے نکےو چدوں لَنگھے (گزرے) مُجرم لوکی اَساڈے کولوں اِنج اِی کیتا پاسَن
  7,41,دوزخ ا ِی اوہناں دے تھَلے اُتے ہوسِی،بَدکاراں نے اِنج سَاتھوں (ساڈے کولوں)کیتے پانے
  7,42,تے اوہ جو اِیمان لیائے نالے چنَگے عَمل کَمائے جیہڑے اوہناں دی چَک(استطاعت) توں ناہ وَدھ ہووَن دے اوہ ہووَن دے جَنت وَاسی(جنتی)،اِیس دے وِچ ہمیشہ رہسن،
  7,43,اوہناں دے اَندراں دے بھَارے(کَدُورتاں) سَارے دُور کَراں دیں،وَگدے پانی لاگے ہوسَن تے اوہ کہسن شُکر خدا دا جےسانوں اوس راہے پایا، اَسی ناہ سِدھے پاسے لَگدے۔جے اوہ راہ ناہ پاندا، رَب ساڈے دے مُرسل (پیغمبر) سارے لے کے سَچ اِی سَچ آئے سن،اوہناں نوں خوشخبری مِلسی ،ایہہ اوہ جنت جِس دا وارث کیتا، اَساں تہانوں۔ عَمل تہاڈے تَک(ویکھ) کے
  7,44,جنت وَاسی ،دوزخ وَاسی لوکاں تائیں اِیہہ آکھن دے،رَب اَساڈے، نال اَساڈے وَعدہ جو کیتا سِی ،اوہ سَچ ہو یا، کی تہاڈے نال ہویا وِی، وَعدہ سَچ ہویا ہے وے اوہ آکھن دے آخو(ہاں) ،اوس ویلے اِک نعرہ لانے والا ،نعرہ لاسی، حَد ٹپَالے لوکاں اُتےرَب دِی لعنت
  7,45,یعنی اوہناں اُتے جیہڑے رَب دی راہوں رَہے لوکاں نوں ڈَکدے(روکدے) تے پُٹھے پاسے (غلط راہ تے) لاندے نالے چھیکڑ (آخرت)دے وِی مُنکر
  7,46,دوآں تھاواں دے وِچکارے اِک کند(دیوار) ہووے دِی تے ٹِبیاں(بلندیاں ) تے بیٹھے لوکی، آپ قیافے لا لیون دے ہر کِسے دے بارے، جَنتیاں نوں آکھن دے شالا تُسی سَلامت وَسّو(سلامتی ہووے تُساں تے) آپ اَجے ناہ اِس وِچ بھاویں، ہوئے داخل، پر آسی(امیدوار) تے ہوسَن
  7,47,پِھر کے جَد نگاہ اوہناں دی ،اَگ وَسنیکاں (جَہنمیاں وَل) جاسِی ،بول اُٹھن دے،رَبّا ،ساَنوں حَد ٹَپلاں (ظالماں)دے ناہ سَنگ رَلائیں(نال شامل ناہ کر)
  7,48,اِیہہ اِعرافی کُجھ وَڈیرے بارےلا قیَافہ اِیہہ آکھن دے اَج تہاڈےکِس کَم آیا مال تہاڈا تے اوہ آ کڑ جِس دی ہے سِی
  7,49,کی اِیہہ اوہوا لوک نئیں نیں ،جِنہاں دے بارے قَسماں کھاندے سِی جے، اِہناں اُتے اَللہ رحمت کرنی ناہیں(اونج دے لوکوں نوں ایہہ کہیا جاسی ) آؤ جنت مال تہاڈا،خوف کَرو ناہ، جھور جھُرو ناہ( رنج کرو ناہ)
  7,50,جَنتیاں نوں مُڑ اَگ والے(جہنمی) کُوک مَریسن(پُکارسن) فیض کَرو کجُھ پانی دا ساڈے وِی اُتے یا ں اوس وِچوں جو تہانوں اَللہ دِتّا، اوہ آکھن دے ہین حَرام ایہہ دوواں اِی(دونوں) کَفرونوں اُتے اَللہ وَلوں
  7,51,یعنی اوہ جِنہاں نےاَپنا دین بنایا سِی رَنگ رَلیاں تے جگ جیون تے اوہ بھُلے تے اَج اوہ سَاڈی یَادوں لَتھے جِیویں اوہناں دِی یادوں ،کَل سی، اَج دِی پیشی لَتھی ہوئی تے آیات اَساڈی دَا اِنکار اوہناں کیتا رَکھیا
  7,52,اِہناں کول کتِاب اَساں اوہوا گھَلی ،رَکھ کے بُنیاد وَحی تےجِس دِی، تَفصیلاً ہَر گل دَسی اے جِس دے اَندر، اوہ ہَدایت تے رحمت اے مومن لوکاں واہتے
  7,53,کی اُڈیک اوہناں نوں اِس دِی کِس دِن آکھی پوری ہوندی، اوہ آکھی جَد پوری ہوئی، اِیہوا پہلوں او ہنوں بھُلے ہوئے کہسن ،ساڈے رَب دے مُرسل(پیغمبر) آئے سِی سَچ لے کے،کِدے سَفارش کار کوئی مِل جائے سَانوں یا دُنیا وَل موڑے جائیے، تاں جے کَرئیے جو پہلاں ناہ کیتا، گھاٹے دے وچ اپنے تائیں اِہناں پایا۔اَج دغا اوہناں نوں دِتّا اِس تانے بانے
  7,54,رَب تہاڈا تے اوہ اَللہ،اِیہہ زَمین اَسمان بنائے چھ دِناں وِچ جِس نے ، فیر بَراجا (جلوہ افروز ہویا) اوہ تَخت اُتے،دِن نوں رَات کَجیندی(ڈھک لیند اے) اِس دے پِچھے دِن وِی اَڈیاں چاندا آوے(دوڑدا آوے)،سُورج ،چَن سَتارے سَارے اس دا آکھا منن ہارے(تسلیم کرن والے) اوسے دے ہَتھ اے پیداکرنا واگ منانا، (اوسے دَا اَمر اے) ہر برکت اَللہ دے ہَتھ اے جو رَب سَب دا
  7,55,اَپنے رَب نوں تُسی پُکاروں اُچّا اُچّا بھاویں مَٹھا مَٹھا اوس نوں حَدوں لَنگھن والے بھاوَن ناہیں
  7,56,گڑ بڑ مول کرو ناہ آل دَوال(اِردگِرد) سَوارن پچِھوں(اصلاح ہو چُکن بعد) آس نراس ہر حالت اَندر اُس نوں تُسی چتارو بے شک رحمت رَب دی نیڑے نیکوکاراں دے ہو ندی اے
  7,57,اس دی ذات ہوائیں (ہواواں)گھَلے،جنہاں ،دے خوشخبر ی پلٗے رحمت اس دی دے۔اوہ ہوَن اَگے اَگے،بھارے بَدلاں نوں جَد کِرے کلاوے(نوں جد چُکن)،سُکی موئی ونڈ کِسے وَل گھَلئے (کسے مُردہ سر زمین دی طرف روانہ کرئیے)،اِس وِچوں پانی اَسی وَسا کے،(بارش کرکے) اِس دِی راہیں ہر طرح دے پھَل اُگاندے،اِنج موئیاں(مرَے ہوئیاں ) نُوں اَسی اُٹھاندے تاں جے جاگےاَندر سَوچ تہاڈے
  7,58,تے جیہڑی تھاں چَنگی ہووے اوتھے حُکم الٰہی پاروں وَل(چنگی) اُگائی ہووے(پیداوار ہووے)،جیہڑی تھَاں نَاقص ہووے پیدائش وِی ناقص ہوندی اےاوس تھَاں (جگہ)تے،انج اَسی پَرتا پَرتا کے اَپنیاں گَلاں شُکر کَرن دِی فِطرت والے لوکاں اَگے رَکھئیے
  7,59,نوح نُوں گھَلیا جد اَساں سِی، قوم اوس دی وَل ،اوس اوہناں نُوں سمَجھایا سِی۔لوکو، کَرو عِبادت رَب دی، بِن اُوہدے مَعبود ناہ کوئی ہَور تہاڈا، ڈرناں ، تُسی عَذاب وَڈیرے دے رَگڑے دے وِچ آجاؤ دے
  7,60,قوم اُس دے سِر کڈ بولے،ساَنوں توں تے بُھو نتَلیا (گمراہ) اِی لَگسیں بالکل،
  7,61,اوس کہیا جے بھو نتَیلیا تے میں ناہ اُکّا میری قومے، میں تاں ہاں رَسوُل اوس وَلوں ،جو رَب سَب دَا
  7,62,بھیجاں اَپنے رَب دِیاں ، اَپڑان تہاڈے کول آیا واں،میں دیواں مَت (نصیحت) تہانوں اَللہ وَلوں جو میں جاتا اوہ تُسی ناہ جانا
  7,63,کی اچرج (تعجب )تہانوں لگے،رَب تہادے وَلوں اِک تہاڈے وَرگےوَل اِی کِویں مَت بانی آئی، جھونا دین تہانوں (خبر دار کرے) تا ں جے جھَاک پَوے جے رَب دِی (برائی توں رک جاؤ ،رَب دے خوف توں )تے رحم تُسا ں تے ہووے
  7,64,پَر ناہ اوہناں اُس دِی مَنّی، تاں مُڑ اُس دَا سَنگ سَنگیاں دے بیڑا پاڑ اَساں کَر دِتّا، تے غَرقایا ۔گَل جِنہاں ناہ سَاڈی گولی، قوم اوہ ہے اِی (عقلوں)اَنھے لوکاں دی سِی
  7,65,عاد قَبیلے وَل وِی ہودؑ اوہناں دِا لَگدا گھَلیا، اوس کہیا اے میری قومے، کَر وعبِادت رَب دِی، بِن اوہدے مَعبود ناہ کوئی ہَور تہاڈا، کیوں ناہ اُس دِی جھَاک تہانوں
  7,66,قوم اِس دِی دے، کَفروناں دے سِر کَڈ بولے توں تے کوئی مُورَکھ (بے عقل)جاَپیں شَک اَسانوں اِیبھی یکڑ مار(جھوٹھ مارن والا) کوئی ایں
  7,67,اوس کہیا میں مُورَکھ ناہ لوکائیے(لوکوںمیں بے عقل نئیں) میں تے ہاں اوس وَلوں ،جیہڑا رَب اے سَب دَا میں تہانوں بھیجاں اَپنے رب دِیاں ، اَپڑاوَن تہاڈے کول آیا وَاں
  7,68,ہیرا پھیری کوئی ناہ کَردا ،میں تہانوں مَت ہاں دیندا
  7,69,کی عجیب تہانو ں لگے رَب تہاڈے وَلوں،اِک مَت بانی آوے وَل تہاڈےاِک تہاڈے اپنے وِچ دے بندے رَاہیں، تاں اوہ تہانوں جھونے(خبر دار کرے) ،پر کَروخاں چیتے(یاد کرو) نوح دِی قوموں پچھے وارث جَدوں بنایا ہے سِی، اَساں تہانوں،تے لوکاں وچ ٹوہر تہاڈی اَساں وَدھائی،یاد کَرو اِحسان اللہ دے تاں جے بامُرادے تھِیوو
  7,70,آکھن لگے توں اَساڈے وَل آیا ایں تاں جے اَساں عِبادت کرئیے اَک اَللہ دی تے وَڈیاں دے مَعبوداں نوں چھَڈئیے،دے لے توں ڈَراویں جیہڑے دے سَکدا ایں ،جے سَچیاراں وِچوں ہے ویں
  7,71,اوس کہیا بس باب تہاڈے ،رَب تہاڈے لِکھ دِیّتیاں نیں جھَاڑاں جھنباں تے پئے ایویں نال میرے او جھَگڑے کَردے اوہناں ناواں(ناماں) بارے جیہڑے رَکھے مِتھے آپ تُساں نے یاں تہاڈے وَڈکڑیاں نے،تے اللہ ناہ نازل کیتی ہے دَلیل اوہناں دے بارے،ویکھو اَللہ کی کَردا اے میں نال تہاڈے ویلا اوہ اُڈیکاں(انتظار کراں)
  7,72,تے اُس نوں اَسی بَچایا نال اس دے نال دیاں نُوں اَپنی مہروں (مہربانی کر کے)،اوہناں دِی جَڑ وَڈھ دِتّی جنہاں نے آیات اَساڈی نوں جھُٹھیایا تے اوہ منن والے نئیں سِی لَگدے
  7,73,اِنجے ثَمود کیاں وَل ،صالح ؑاوہناں دَا اِی لَگدا گھَلیا، اوس کہیا میری ر قومے، کَرو عبادت رَب دِی ،ناہ مَعبود تہاڈا کوئی بِن اُس دے ،ہُن جَد رَب تہاڈے وَلوں آپُجی اے اَک نشانی وَل تہاڈے،اِیہہ اَللہ دِی ڈَاچی اوہ نشانی ہے جے اِیس نوں چُگنے ،چرنے دی کھُل دِتُّی رَکھنا، ماڑا ہَتھ ناہ اِیس نوں لانا (کسے بُرے ارادے نال ایس نوں، ناہ چھونا)۔کَدے عذاب کَریڑے دی ،ناہ سَٹ ،وِچ آؤ(اِک دَردناک عذاب تہانوں آلَوے)
  7,74,یاد کَرو عادکیاں توں پچِھے اَسی تہانوں وارث کیتا تے دِتُّی سی مُلکے دی مَلکائی( ملک دی حکومت دِتی)۔پڈھراٹا ںوِچ اوتھے محل اُسارے سِی جے(زمین ہموار کر کے عالی شان محل بنائے)،پربت (پہاڑ)کَٹ کَٹ گھَر بَنائے،یاد کَرو اِحسان خُدا دے تے ناہ پھِرو فسَاد مَچاندے اِیدھر اُودھر
  7,75,قوم اِس دِی دے آکڑ خاناں۔ماڑکیاں چوں(کمزور) مَنّن وَالڑیاں نُوں پُچھیا کی تہانوں کیڑ اے ا(جاندے اوہ)ِ اِس دِی،صاَلح اَپنے رَب دَا مُرسل بَن دَا پھِردا، آکھن لگَے ہے اِیمان اَساٖڈا اِس تے ،اِس دی راہیں جو کجُھ آیا
  7,76,آ کڑخاناں اِیہہ کہیا جے اَسی تے اوس دے نابر(منکر) جِس نُوں تُس مَنّیاں ایں
  7,77,تے ڈاچی دیِ کُھچ (ٹنگ )اوہناں کَپ (کٹ) دِتّی تے رَب اَپنے دِی آ کھی دے آکی ہوئے(مخالف ہوئے)، آکھن لگَے صَالح ،لے آڈَراوے جیہڑے سَانوں دَسدا آیو جےتوں مُرسل لوکاں وِچوں
  7,78,آخر اوہناں نوں تھَر تھَلی نے آ نَپیا (دِل ہلا دین والی آفت نے آپھَڑیا) تے مُونھ پَرنے اوہ اَندراں وِچ ہوئے (اپنے گھَراں وِچ اُلٹے پئے ہوئے سن)
  7,79,صَالح چھَڈ گیا اوہناں نُوں کہندا ہویا،لو کوں میں تہاڈے تائیں رَب اَپنے دِی بھَج (گَل ) اَپڑائی، مَت وِی دِتی(نصیحت وِی کیتی) پر ناہ، وَارا، کھان تہانوں مَتّل بَندے(خیر خواہ بندے)
  7,80,لُوط وِی اِنجے قوم اَپنی نُوں جَد سَمجھایا، کیوں کَردے او بے حیائی ،جو کِسے نے ناہ اَج تائیں کیتی دُنیا اُتے
  7,81,شہوت چائے،رَنّاں چھَڈ کے مَرداں دے وَل ڈُھکو(عورتاں چھڈ کے مَرداں دے نال شہوت کَردے ہو) ہے تُساں بالکل دھو پیتی(تُساں تے حد کر دِتّی)
  7,82,قوم اوہدی نے اِکو پَرتا پرَتایا،(اِک اِی جواب سِی) اِہناں نُوں اَپنے پِنڈوں کَڈے (اہناں نوں اپنی بستی تو کَڈ دیوو)پاک بَڑے اِیہہ بَندے پھِردے
  7,83,تے مُڑ اَساں نَجات دِلائی ایس نوں نالے ایس دے لَڑ لَگیاں نُوں وِی ، زَال (بیوی) اُوہدی نُوں چھَڈکے ،سی اوہ رہکَل(پچھے رہ جان والے )لوکاں وِچوں
  7,84,اوہناں تے پتھرُ وڑ اَساں مُڑ خو ب وَسائی (پتھراں دی بارش کیتی)،تَک لے (ویکھ لے) مجُرم لوکاں دِی ،اے اَنت ہوندی اے(اےاَخیر ہوندی اے)
  7,85,مَدین وَل شُعیب اَسی سِی گھَلیا اوہناں دَا ای لَگدا ، اوس کہیا، اے لوکو کَرو عِبادت رَب دِی ،ناہ مَعبود تہاڈا کوئی اِس دے باجھوں تے اِک تے گل پکی رَب تہاڈے وَلوں آئی وَل تہاڈے،یعنی رکھو سُچامِن تول اَپنا (ناپن دا پیمانہ تے وزن)،ناہ لوکاں دِی چیزاں دے وِچ گھَپل مچاؤ، رَولے ٹھیک ہو جاون تے ناہ گڑ بڑ فیر جگاؤ،خیر تہاڈی ایسے وچ اے جے ایمان تہاڈے اندر
  7,86,تھَڑے ناہ دیوو، رَاہیں اُتے،ناہ دَھمکاؤ، ناہ اَللہ دے رَستے ڈَکّو (روکو) رَب نوںمَنّن وَالڑیاں تے پُٹھے پاسے اوہناں نوں پا دینے واہتے،یَاد کَرو تَعداد تہاڈی جَد تھوڑی سِی ، اَساں تہانوں وَادھے پایا،(بہُتا لیتا)، ایِبھی ویکھو اَنت ہوندا کی گَڑبڑَیاں دا
  7,87,جے ہے اِک دِھر تہاڈے وِچوں اس نوں مَنّن والی جو کجُھ آیا میری راہیں، تے اِک دِھر ناہ مَنّن والی تے فیر اُڈیکو ساَڈے اَندر اَللہ وَلوں جَد نیاں(فیصلہ) ہو جاوے،تے اوہ ہے نیائِیں(فیصلہکرن والا ) سَب توں چَنگا
  7,88,قوم اوس دِی دے آ کڑ خاں اِیہہ گَل آکھی شُعیب اَساں چِک دیساں (کڈ دیساں)تینوں اِپنے پِنڈوں(بستی توں) نالے تیرے سَنگ پَالاں نُوں یاں مُڑساڈے وَاڑے وَڑنا پیسی (ساڈی ملت وچ واپس آنا ہوسِی) اوس کہیا جے دِل ناہ سَاڈا مَنّے(دل ساڈا ناہ تسلیم کرے فیر وی)
  7,89,انج کرئیے ، تے اَللہ بارے کوڑی تانی تنیئے(اَللہ تے جھُوٹھ گھڑن والے ہوئیے )جے اوسے اِی وَاڑے وَڑئیے(اوسے ملت وچ فیر داخل ہوئیے) جِس توں اَللہ آپ بچایا ہے سی سانوں ایہہ سَانوں زیب ناہ دیووے فیر اُودھر نوں مُڑئیے، ایہہ ناہ اَللہ مالک ساڈا ہرگز چاہے ،عِلم اَساڈے رَب دَا ہے وے ہر اِک شے نوں وَلّی کھَلوتا (ہَر شے نوں گھِیرے وچ لِتّا ہوا اے)۔اَساں توَکّل اُس تےکیتا،رَبّا ساڈے تے ایس قوم اَساڈی دے وِچ کَردے توں نَکھیڑا سچّا(بہترین فیصلہ) ،توں ای ایں چَنگائیں نکَھِیڑا کَرنے والا(توں ای بہترین فیصلہ کرن والا اے)
  7,90,قوم اِس دِی دے کَفروناں چوں سِر کڈھیاں اِعلان اِیہہ کیتا،جس کِسے وی راہ شُعیبی مَلّی(شُعیب دی پیروی کیتی) سَمجھو گھَا ٹا کھَادا
  7,91,تے اوہناں نُوں آن بھُہچالے نَپیا (اِک دل ہلا دین والی آفت آپھڑیا )تے اوہ اَپنے اَندراں(گھراں) وچ ا ی مُوندھے ہوگئےـ
  7,92,گَل شُعیب نَبی دی نُوں جھُٹھیارن والے۔انِج ہوئے جیئوں اوہ اوتھے ہوندے اِی ناہ سِی،گَل اوہدی جھُٹھیارن والے گھَاٹا کھَانے وَالے ہوئے
  7,93,اوہناں توں اِک پاسے ،اوہ اِیہہ کہند ا ہویا،لوکو میں اَپڑا (پہنچا) تہاڈے تک دِتّی گَل تُہاڈے رَب دِی نال تہانوں مَت(نصیحت ) وی دِتّی،ہُن جھُراں تے کِکَن جھُراں(افسوس کراں) میں ا َن مَن لوکاں دے حال اُتّے(حق دے منکر لوکا ں دے حال تے)
  7,94,نَبی اَسی جَد کَدی وِی، کِدھرے گھَلّے ،پہلاں اوتھے دے وَسکیناں تائیں مَالی ،جاَنی بَد حَالی وِچ پایا، تاں جے عجز اوہناں وِچ آئے
  7,95,دُکھ اوہناں دے جَد وِی سُکھاں وِچ بدلائے تے اوہ پھَلن پھُلن جد لگے تے آکھن لگے غَمی خُوشی تے سَاڈے وَڈیاں نے وِی سِی ہنڈائی(وڈیاں تے وی آئی) فیر اوہناں نُوں پَکڑ ہوئی ،اَچانک ہوئی اوہناں دے جو چِت ناہ چیتے(اوہناں دے گُمان وِچ ناہ سی)
  7,96,تے جے اوہ نَگریک(بستی والے) اِیمان لیائے ہوندے تے اَللہ دَا جھَاکا رَکھدے،اُوہناں اُتے دَھرتی تے اَسماناں دَی ہَر رحمت دے کھُل جاندے بوہے(دروازے) سَاڈےوَلوں ، پَر اوہ تے انکاری ہوئے تے اوہناں دے کَرتوتاں توں پکڑاَساں اوہناں دِی کیتی
  7,97,تے کی گوٹھاں دے وَسکیناں خوف دِلوں ایہہ کَڈھ چھَڈیا سِی جے اوہناں تے رَاتو ،رات اوہناں دے سُتیاں(سوئے ہوئے)، آ، عذاب اَساڈا جَاسِی
  7,98,یاں نَگریک(بستی والے) اوہ سِی بے فِکرے، اِس توں جے اوہناں تے غَضب اَساڈا دِنّو ،دِنّی (دن دے وقت) آسَکد ا اے جَد اوہ ،رَنگ رَلّیاں دے وِچ ہووَن
  7,99,کی اَللہ دے مَنصوبے تو ں بے چِنتے(بے خوف) سَن،اَللہ دے منصوبے توں بے چِنتے گھَاٹل (نقصان اُٹھاوَن والے) لوکی اِی ہو سَکدے نیں
  7,100,کی ایس وِچو ں مَت (نصیحت)اوہناں نُوں لَبھدی (مل دی )ناہیں۔اَسی جِنہا ں نُوں وَارث کیتا ایس بھوئیں دا ،پہلے وَسکیناں توں پِچھے،جے اَس چاہندے ۔اَسی اوہناں دے پَاپَاں پَاروں تَونِی(سزا دیندے) اِہناں نوُں لا دیندےتے قَلباں تے ٹھَپے لاندے تے اوہ سَمجھَن توں رہ جاندے
  7,101,سِی نَگر اوہ اِنج دے ۔اَسی جَنہاں دے کجُھ قِصّے دَس دِتّے تینوں، اوہناں کول رَسُول اوہناں دے لے کے نَال نَتارے آئے (کھلی نشانیاں)، پَر اوہناں نوں کِنج اوہ مَن دے کَل جِنہاں تے مُنکر ہوئے،اَللہ اِنجے کَفروناں دے دِلاں تے ٹھَپے لاندا
  7,102,چَوکھے اوہناں دے وِچوں گَل دے کچَے، تے ناہ ڈِٹّھا بُہتڑیاں نوں گَل تے پہرہ دیندے
  7,103,فیر اَسی اوہناں دے پِچھے موسٰی گھَلیا،فِرعونے تے اوس دیاں سَرداراں وَلّے،آیات اَپنی دے کے،اوہناں توں اوہ اَوکھے ہوئے تے توں تَک(ویکھ)لے کی اَنجام اوہناں دَا ہویا، جیہڑے رہے سِی گَڑ بَڑ کَردے
  7,104,موسٰی ؑ نے فِرعونے نُوں اِیہہ دَسیا ہے سِی ،میں رَسُول آں جَگ دے رَبس دے وَلّوں،
  7,105,میرے تے اِیہہ لازَم ہے وے اَللہ دے بارے ج و آکھاں ،سَچ آکھاں،میں تہاڈے رَب دے وَلّوں، گَل نَتاڑو (دلیل والی)لے کے آیا تے کَر اِسرائیل کیاں نُوں توں حَوالے میرے
  7,106,اوس(فرعون)کہیا توں لے کے جیہڑی ہیں نتاری ہاری آیا(نشانی لے کے آیا) دَس اَسانوں جے سَچّا ایں
  7,107,اس تے موسٰی عَاصَا سَٹیا، ہوبہو دا ،نَانگ(َاژدھا) لَگیا
  7,108,ہَتھ کَڈیا تے تَکدیاں نُوں اوہ نُورانی َلگیا
  7,109,پَر فِرعونی قوم دے سِر کَڈیاں نے اَگوں اِیہہ کہیا جے،اِیہہ کوئی گُنیا (ماہر)جَادو گَر اے
  7,110,تے ایس دی ایہہ نیت لگے ،ایہہ تہاڈی مل دے (زمین)وِچوں کَڈھ دے اوہ تہانوں، دَسّو کی صَلاح تہاڈی
  7,111,آکھن لگے ٹَالے ٹُولے کولوں تے کَم اَجے تے لئیے دوآں نال ای،تے شہریں چاہو کے گھَلیئے (شہر شہر ہرکارے گھلیئے )
  7,112,جیہڑے گُنیے مَاندریاں (ماہر جادوگراں )نُوں لے آوَن
  7,113,تے فِرعونے کو آپہنچے جاَدوگَر اوہ، آکھن لگَے جے جِت جائیے ،اَجر اَساڈا حَق بَندا اے(چنَگا چَو کھا)
  7,114,اوس ہاں کیتی ،نالے گوڈے مُنڈیاں وِچوں ـ(مُقرب لوکاں وِچوں)کَرنے دِی وِی گَل سُنائی
  7,115,اوہناں کہیا موسٰی بھاویں توں سَٹ پہلاں بھَاویں دَیہہ اَسانوں وَاری ،اُوس کہیا جے وَار تہاڈی پہلی سَٹ دِی
  7,116,تے جد سَٹ اوہناں نے کیتی تے لوکائی (لوکاں) دِی اَکھاں نوں اِنج بَنھ لیئو نیں (انج نظر بندی کیتی) تے اوہ رہ گئے ڈر کے تے خوب اوہناں نے جادو دَسّیا
  7,117,موسٰی نوں اَساں اِشارہ عَاصَا سَٹن دا کر دِتّا،تے اوہناں دے بھُچلاوے(جھوٹھے طلسم )مُونھ اوہنے پائے (نگل گیا)
  7,118,انج ہوئی گَل سَچ دِی اُ چّی،تے بےاَثری اوہناں دِی سَب ،کِیتی ہوئی
  7,119,اِنج اوہناں دِی کَنڈاں لَگیاں (اوہ مغلوب ہوئے) تے اوہ اُلٹے پچی ہوئے (ذَلیل ہوئے)
  7,120,جَادُوگَر اوہ، ہَاراں مَن گئے تے سِجدے وِچ جا ڈِگّے اوہ،
  7,121,اوہ بول اُٹھے کُل عَالم دے رَب نُوں مَنّیا
  7,122,موسٰی دَا ہَارون دَا رَب اے جیہڑا
  7,123,اِس اُتے فرعون کہیا جے مِیتھوں اِذن مِلّن توں پہلاں(میری اجازت توں پہلاں)۔اِنج تہاڈے مُومن تھِینے(ہووَن) توں لَگدا اے، اے اِک چَال تہاڈی ہے سِی ،وِچ نَگر دے چَلّی،تاں جے کَڈھوں وَسکیناں(ملک وچ رہن والیاں) نُوں، پَتہ تہانوں پَر لَگ جَاسِی
  7,124,میں ہَتھ ،پیر تُہاڈے آڈے کَٹّاں تے سولے تے لَٹکا دیساں سَبھناں تائیں(سَاریاں نُوں)
  7,125,اِنج گَل اوہناں پَر تائی اَگوں(جو وِی ہَووے)رَب اپَنے وَل مُڑ آئے آں ہُن اَسی تے
  7,126,توں اَساڈے تے کَوڑ(غُصہ) ایسے دِی اِی کھَاویں ،جےآیات تے اِیمان اَساں لے آندا ہے وے ،جَد ہُن کول اَساڈے آئیاں،رَبّا صَبر اَسانوں دیویں تے دُنیا توں کھَڑیں اَسانوں مُسلم ہونے دِی حَالت وِچ
  7,127,تے فِرعون دے سِر کڈھیاں نے پُچھیا کی موسٰی تے اِس دے سَنگ پَالاں نُوں توں چھُٹی دیسیں، جے لوکائی وِچ مَچاوَن اَفَراتَفری،تینوں چھَڈن ،تیرے مَعبُوداں نُوں چھَڈن ، اوس کہیا میں پُت ماری(بیٹے قتل) اوہناں دی کَرساں تے زَالاں (عَورتاں)نُوں زِندہ رَکھساں،اَسی اوہناں توں زورآور آں
  7,128,موسٰی قوم اَپنی نوں کہیا ،بوہڑ خُدا توں مَنگّو تے دِل وَڈّا رَکھو اِیہہ زَمین خُدا دِی اَپنے بَندیاں وِچوں جِس نُوں چاہے دے وِرا ثَت ا ِس دِی، تے اُوڑک(اخیر) اے مُتقّٗیاں دِی چَنگی
  7,129,آکھن لگے تیرے توں پہلاں وِی سَاڈے باب بَتیھری(بہت) ہوئی ،تیرے آیا وِی تے سَاڈے اوہوا رَولے(مسئلے مسائل)،اوس کہیا اوہ ویلا ہُن آیا کہ رَب تہاڈا جَدوں تہاڈے ویری (دشمن ) بنےّ (ہلاک کرے)،لا دیوے دَا مُلکائی مُلکےدِی اوہ دیسی ہَتھ تہاڈے(زمین تے خلیفہ بنا دیوے دا) تے مُڑ عملاں راہیں پَرکھے اوہ تہانوں
  7,130,تے فِرعون کیا نوں سَالاں بَدّھی،پیٹھا سِی کالاں دِی چَکّی(کئی سال قحط رہیا سی)،پَھل پھُل دَا وِی توڑا دِتّا (پیداوار وِچ کَمی دِتّی)شاید ہوش اوہناں نُوں آوے
  7,131,پَر جَد سَوکھے ڈِنگ آیو نیں اوہناں نوں حَق اَپنا جاتا،تے جَاتو نیں اَوکھا ویلا ،موسٰی تے اِس دے سنَگیاں دے پیراں توں آیا، حالاں اوہناں تے بَدبختی آئی ہے سِی ،اَللہ وَلوں، چَوکھڑیاں(اکژ) دِی عَقلوں ایہہ گل اُچیری(اُچی)
  7,132,رَٹ اوہناں ِدی اِیہوا ہے سی،توں نشانی بھاویں کیہڑی وِی لے آوے تاں جے سانوں توں بھُچلاویں،اَسی ناہ تینوں مَنسَاں
  7,133,تا ں مُڑ مو ت وَبائی اوہناں دے وَل گھلی، مَکڑ، چِچڑ، ڈَڈّو تے رَت(خون) بنے عَذاب اوہناں تے اِک اِک کَر کے، فیر وِی اوہناں آکڑ کیتی ، قوم اِی اوہ سِی ،اَنموڑاں(مُجرماں) دِی
  7,134,جَد کَدے وِی آؤنی (آفت) کوئی اوہناں اُتے آجاندی سِی،آکھن َلگدے کَر اَساڈے حَق وِچ دُعا توں موسٰی،کیوں جے وَعدہ نال تیرے اوس کیتا ہویاِ،جے ساڈے توں، آفت ٹالے،آکھے تیرے لَگ جاوا گے، تے کِر دیساں نال تیرے مُڑ ،اِسرائیل کیاں نوں
  7,135,پَر جَد اوہ عَذاب اوہناں توں کُجھ چِر(وقت لئی) اَسی ٹَلا دِتّاسِی جیہڑا اونج اَٹل سِی، پھِر گئے گَل توں
  7,136,فیر اوہناں نں وِچ دَریا دے غَرق اَساں کَر دِتّا تے انج وَاری لائی(انتقام لِتّا) ،ناہ آیات اَساڈی نوں گولن دے پاروں( ناہ آیات اساڈی مَن دے سِن) تے اوہناں توں بے دِھیانے رہنے پاروں
  7,137,تے اوہناں نُوں ،تھَاں اوہناں دی لے آند سِی ، چَڑھدے توں لالہندے توڑی(مشرق توں مغرب دَا وَارث بَنا دِتّا)۔ کَل ہٹھارو(کمزور) جیہڑے ہے سَن ،برَکت والا اوس علاقے نوں کر دِتّا، تے اِنج رَب ترے َگل اسرائیل کیاں دے حَق وِچ سوہنے طور نَباہی،دِل نوں وَڈّا رَکھن پاروں،تے فِرعون سنَے قوم اپنی دے ، جو کُجھ رہیا ، بَناندا ہے سِی تے سب محل چوبارے اس دے ،مَلیا میٹ بنائے سَارے
  7,138,اسرائیل کیاں دے تائیں دَریاؤں پار پُچایا، جَد اوہ اِک قبیلے انج دے کول جا اَپڑے ،جیہڑے بُت پجاری ہے سَن،آکھن لگے ،اِہناں دے مَعبود جیہا ،معَبود اَساڈے واہتے کَر پیدا، اوس کہیا ،بے سَمجھ تُسی اُو
  7,139,ایہہ جِس پاسے لگَے ہوئے اوہ فاَنی ایں، تے عَمل اوہناں دے بے حَاصل
  7,140,اوس کہیا، اَللہ نُوں چھَڈ کے میں مَعبود تُہاڈے واہتے ہُن ہَور کوئی ڈُھونڈا ں،حالاں اوسے سَب عالم توں وَدھ کے فَضل تُساں تے کیتا
  7,141,جَدوں چھُڈایاں سِی فِرعون کیاں دے کولوں اَساں تہانوں،جِنہاں تہانوں بُرےعَذاباں وِچ پایا سی ،پُت تہاڈے اوہ کوہ (ذبح کر)دیندے،زَالاں (عورتاں ) نُوں زِندہ رَکھدے،ایہہ تہاڈے اُتے اِک ازمائش بھَاری ہے سِی رَب تہاڈے وَلّوں
  7,142,موسٰی نُوں جد اَسی بُلایا ( 30 ) تیہہ رَاتاں واہتے،تے مُڑ دَس دَا ہور اِضافہ کَردے ہوئے چالی(40) دِی مَعیاد مکمل ہوئی اس دے رب دے وَلُوں۔موسٰی نے ہارون بھَرا (بھائی)نُوں ،اَپنے پَچھوں قوم اَپنی دَا ،سِی نِگران بَنایا، تاں جے رَکھے اوہ حالات سَوارے۔تے مَندیا ں(وگاڑپیدا کرن والیاں) دِی راہ ناہ جائے
  7,143,تے جَد موسٰی سَاڈی کارے وَالی (مُقرر )تھاویں آیا ،تے رَب اوس دا اُس دے نال کَلامی ہویا (اوس نال گَل کیتی)، اوس وچ سُدھر جاگی(خواہش پیدا ہوئی)،ربّا اپنے جوگا کر ،جے تینوں تَک لوَاں میں (اے رب مینوں اوہ نظر دے کہ میں تینوں ویکھا)۔رَب کہیا توں جھَال ناہ جھُلسیں(تو برداشت ناہ کر سکسیں)،ہاں تََک(ویکھ) ایس پہاڑی وَلّے، جے اوہ رہ جائے اَپنی تھَاویں(جگہ) تے توں جھَال جُھل جاویں دا،تے جَد اوس دے رَب تَجلّی پائی اوس پہاڑی اُتّے ،اوس نُوں سُرمہ کَر دِتّو سَو (رَیزہ رَیزہ کَر دِتّا)،موسٰی غَش کھَا کے ڈِگّا(گر یا ) ، ہو ش آئی تے بول اُٹھیاسِی ،جے توں تَسبیحاں دے لائق ایں ، میری توبہ ، میں سَب توں وَدھ مَنّن والا
  7,144,رَب کہیا ، اے موسٰی میں تینوں لوکاں وِچوں چُن کے میں وے گَلمے لایا ہے (منتخب کیتا)رَسالَت تینوں دِتّی، تیرے نال کَلامی ہویا، تے ہُن لے جو تینوں دِتّا ۔تے ہو شُکرگَزاراں وِچوں
  7,145,تے اَساں سَن اوہدے واہتےتخَتڑیاں (تختیاں) دے اُتےلِکھیاں ہَر کَم بارے مَتُاں،(نصیحتاں) تے تفصیلاں ہر کَم بارے ،پَکیاں کرَکے (مضبوطی نال) اَسی کہیا ،اِہناں نُوں نَپنا(پھَڑنا) تے قوم اَپنی نُوں وِی کہنا، وَل طرح اِہناں نوں نپَے،میں تہانوں نافَرناں دے وِی ڈیرے (گھر)دِکھلا دیساں تھوڑے چِر نُوں(عنقریب)
  7,146,اوہناں دَا آیات میری نال تَعلق کاہدا۔ جیہڑے ایویں دَھکو دَھکی بَن بَن بہندے نیں جَگ اَندر ،اوہ مول ناہ مَنسَن(ایمان ناہ لیاسن) کُل اچر جان(ساری نشا نیاں) تک (ویکھ) لوَن اوہ بھَاویں،سِدھے رَستے نوں تَک کے وِی اوہ ناہ پھَڑسن (ناہ اختیار کرسن) اُس نوں ، تے جے پُٹھا پاسا تَکسن اوسے نوں راہ اپنی گِن سَن،کیوں جے اوہناں نے آیات اَساڈی توں مونھ موڑی کیتی تے بے دَھیانی وَرتی
  7,147,تے اوہ لوک جِنہاں آیات اَساڈی توں مونھ موڑی کیتی تے رَب دے اَگےپیشی نوں ناہ مَنّن۔اُوگت اوہناں دی سَب کیتی(سارے اعمال ضائع ہوگئے)۔اَپنے عَملاں نالوں وَکھ توقع کی رَکھ سَکدے
  7,148,تے موسٰی دے لوکاں اِس دے جانے پِچھوں،گہنے گالے تے گھَڑیا اِک وَچھا(بچھڑا) بڑھکن والا(نکل دی سی اوس وچوں وچھے دی آواز)،کی ناہ دِسیا(نظر ناہ آیا)سی اوہناں نوں اوہ ناہ بولے نال اوہناں دے،ناہ اوہناں نوں راہے پائے(مُڑ وی )اوس نوں پُجن لَگ پئے (عبادت کرن لگے)تے اوہ ظالم سَن)( اوہناں کَم ماڑا کیتا)
  7,149,تے جَد آخر اوہ وَچھّا اوہناں دِی نَظروں ڈِگّا ،تے مَعلوم اوہناں نوں ہویا جے اوہ بھُلے،بول اُٹھے جے ناہ رَب اَساڈا رحم کرے ہُن ساڈے اُتّے،تے ناہ بھُل اَساڈی بھُلے،ساڈےپَلّے کَکھ ناہ رہسی
  7,150,تے جَد موسٰی قوم اپنی دے وَل واپس آیا،روہے روہے(غصے) وِی ا وہ ہویا تے جھُریا وی(رنج وی ہویا) ، اوس کہیا جے میرے پِچھوں،میری تھَاویں ،کَم تُساں اِیہہ ماڑا کیتا،رَب اَپنے دَا قہر بُلانے دِی سِی اینی سَوڑ (جلدی)تہانوں ،پٹیاں(تختیاں) نوں اوس پاسے دَھریاں(رَکھیا) تے بھائی نوں اوس پَٹیاں توں نَپ کے (وَالاں توں پھَڑ کے) اَپنے وَل دھرونی دِتّی(اپنے وَل کھِچیا)،اوس ہارون کہیا اے ماں جائے،اِہناں لوکاں مینوں کجُھ ناہ جاتا(سَمجھیا)،اِیہہ تے مینوں تھَاں مارن تک جا اَپڑے سَن، ویری(دشمن)لوکاں نُوں ناہ موقع دے توں میرے تے ہَسن دا،تے ناہ گِن توں مینوں حَد ٹَپلاں دے وِچوں
  7,151,موسٰی فیر دُعا اے مَنگی،رَبّا مینوں سنَے(ساتھ) بھَرا(بھائی ) دے بخشیں،سَانوں اَپنی رحمت دے سائے وِچ رَکھیں،توں سَب رحم دکھاوِن والڑیاں توں وَدھ کے رحم دِکھاویں
  7,152,تے وَچھے نُوں پُجن والے ، اَپنے رَب دے غُصے ہَیٹاں اَج آئے ، کَل آ ئے،دُنیا وِچ خَواری تَکسن، کوڑ ا ُساری کَرنے والے(جھُوٹھ گھَڑن والے) اِنجے اَپنی کیتی پاندے
  7,153,پَر اوہ لوک جِنہا ں دے کولوں مَندیائیاں(بُری گَلاں ) تے ہوئیاں، تے مُڑ اوہناں توبہ کیتی تے ایِمان لیائے(اوہناں واہتے) رَب تیرا ہے بَخشنہارا تے رحم دِکھاون والا اَگوں واہتے
  7,154,ٹھَنڈا ہویا جَد موسٰی دَا غُصہ تے اوس لَوحَاں چَائیاں(تختیاں چُکیاں) اوہناں وِچ ہَدایت بھَریاں رحمت بھَریاں تِحریراں سِن اوہناں واہتے رَب توں جیہڑے ڈَرنے والے
  7,155,مُڑ موسٰی نے سَتر بَندے قوم اپَنی چوںچھانٹے ،سَاڈے کارے دی تھاں واہتے(تاں جے سَاڈے مُقرر وقت تے حاضر ہون) تے جَد پَکڑ بھُچالے کیتی (زلزلے نے آپھَڑیا)،موسٰی عرض گُذاری،رَبّا توں چاہندا تے ایس توں پہلاں اِہناں نوں وِی تے ،مینوں وِی ، جانوں لے سَکدا سِی، کی ہلاک اَسانوں توں ہُن کَرنا چاہیں،سَاڈے وِچدے بے عَملاں دے ،عَملاں پاروں،تیرے وَلوں اے ازمائش لَگدی ہے وے جِس نوں چاہیں اس دی راہے بھُلے پا ئیں،جس نوں چاہیں راہے پائیں،توں اِی سَاڈا اے سِر سائیں، بَخش اَسانوں کَر توں رحم اَساڈے اُتے،توں ایں سَب توں وَدھ کے ہے وے بخشنہارا
  7,156,سَاڈے لَیکھیں لِکھ دے(ساڈے نصیب وچ کر دے ) ویل ا وَل اَساڈا ٹپَے(چنگا ویلا ساڈا گزرے) کی اِیتھے کی اوتھے،تیرے وَل اَساں مُونھ کیتا، تے اَللہ فرمایا میں عَذاب اَپڑاواں(دیواں) جِس تَک چاہواں،ہے پر میری رحمت دے گھیرے وچ ہر شے،تے اوہ دونویں سُکھ مقد ر اوہناں دَا میں کَر دیواں دا، جیہڑے جھَاک خُدا دِی رَکھسن۔رَب دے ناں(نام ) دِا دیسن (اللہ دی راہ وچ خرچ کرسن )تے آیات اَساڈی مَنسَن
  7,157,اوہناں دے وِی ،جیہڑے پچِھے اوس پیغمبر دے ٹُرسن،ہے وے نبی تے اُمّی جیہڑا ،تے گل جس دی ہے تورات ،زَبور اَندر وِی، اوہ اوہناں نُوں مَت دیندا اے چنَگے کَم دِی، تے مَندے(بُرے کم) توں ٹَھاکے(روکے) تے پاکیزہ چیزاں کھانے نُوں ناہ ٹَھاکے،ہاں گَندیاں توں ٹَھاکے، بھَار (بوجھ) اوہناں دَا ہَولے (ہلکے)کَردا،نالے گَلوں(گلے توں ) گَلاویں لاہندا (بَندشاں کھولدا )،اوہ جنہاں وِچ پھاتھے(جکڑے )ہوئے اُس تے آکھے لگن والے، اُس دی حامی بھَرنے والے،اُس دَا سَنگ نَباہنے والے، اُس دے اِس چانن(روشنی) دے اندر ٹُرنے والے جیہڑا اِس دے نال آ یا اے،بامُراد اوُڑک (آخیر)نوں ہوسنـ(اوہو افلاح پاسن)
  7,158,اے محمد ؑ لوکاں وچ اِعلان ایہہ کَردے ،میں رَسُول تہاڈے سبھناں وَل آیا ہاں، اَللہ وَلّوں،اِیہہ اَسمان سنَے دَھرتی دے مَلکیت نیں جِس دِی،ناہ مَعبودکوئی بِن اوس دے، اوہ جَوائے (زندگی دیندا اے) اوہو ا مَارے، ایس کر کے اَللہ نوں مَنّوں نالے اِس دے پیغمبر نوں ہے نَبی تے اُمّی جیہڑا،تے اِیمان اَپنا وِی اوس دَا ،اَللہ اُتے ،اوس دِی سَب گھَلاں(ارشادات) اُتے،ویکھو اوس دے پِچھے لگو ،تاں جے پے جاؤ رَاہے،
  7,159,تے موسٰی دِی قوم اَندر وِی لوکی جیہڑے، حَق پاسے لاندے (حق دے مطابق ہدایت کردے)تے حقَے اِی اوہ نِیاں(انصاف) وِی کردے
  7,160,باراں اَساں قبیلے اوہناں دے کر دِتّے ،تے اوہ قوموں قومی ہوئے،قوم اپنی دے واہتے موسٰی ،جَد پانی دا، تَرلا پایا، مَت (صلاح) اَساں اِی دِتّی،ٹُر جا اُوس پہاڑ وَلّے عاصے دے سِر تے،اوتھے بارا ں چَشمے پھٹدے (لبھے)،ہر قبیلے پَن گَھٹ (پانی دا مقام )اَپنا جان لیا سِی،اَساں اوہناں تے بَدلاں دَا سایہ کَر دِتّا تے مَن ۔سَلوَا (قابو و وچ) وَس اوہناں دے،کھاؤ اِہناں پاک پوِتَّر چیزاں وِچوں ،اَساں جِنہاں نُوں پُہنچ تہاڈی وچ کَر دِتّا(نافرمانی کرکے اوہناں) کی نقصان اَساڈا کیتا، اَپنا اِی نُقصان ہویو نیں
  7,161,اوہناں نوں جَد اِک نَگر وِچ رہنے دِی جَد مَت(صلاح) سِی دِتّی،تاں جے مَن مَر ضی دَا اُوتھوں کھَاوو ،ہاں حِطَّہ،کہندے ہوئےشُکرانے وچ سیس نَواندے(متَّھا ٹیک دے ہوئے) وَڈّے پھَاٹک وِچوں جاؤ، اَساں ُتہاتھوں ہَوئیاں بھُلاں ، بھُل جَاواں دے، بَلکہ ہَور اوہناں نوں دیساں، جیہڑے نیکی پہچانن دے
  7,162,اوہناں وچ دے نافرماناں،لفظ اَساڈے دَسّے(کہے )ہوئے بَدلا (تبدیل کر)ِدِتّے، اوہناں دِی نافرمانی دے پاروں اِی،اوہناں وَل عذاب اَساں اَسمانوں گھَلیا
  7,163,دَریالے دِی سروَرتی(دریا دے کنارے دی بستی) دِی وِی پُچھ ، ذَرا توں لوکاں کولوں،سَبت دِہاڑے ہَیرا ،پھیری اوہ کَر جاندے، کیوں جے اوس دِن مچھلیاں دِی کانگ آجاندی سی، چَک سِراں نوں (پانی دی سطح تےاُبھر کے) ،اَگے پچھوں ناہ اوہ آوَن۔اِنج اوہناں نوں ازما ئش وِچ پا دِتّا سِی، کیوں جے اوہ سِی حُکم عَدولے(نافرمان)
  7,164,اوہناں وِچوں اِکنّاں نے (اِک گروہ نے) جَد اِیہہ گَل کیتی،کاہنوں اوہناں نوں پئ ے مَتّاں دیندےہے او،اَج ،کَل وِچ اَللہ ہے بَرباد جِنہاں نُوں کَرنے والا یا کوئی ڈاہڈا ہَور عذاب ہےدیوَن والا ، اوہنا ں کہیا ۔رَب تُہاڈے اَگے ،سَچے تے ہو جَاساَں،تے ممکن ہے خوف خُدا دَا جاگ پَوَے نیں
  7,165,پَر جَد اوہناں گَل ناہ گولی(ہدایت نوں فراموش کر دِتا)، اَساں وَلایا (بچایا) بَدیوں ٹھَاک(رُوکدے) رَہے سِن جیہڑے اوہناں تائیں،تے اِک بڑے خراب عذابے دِی صورت وِچ پَکڑ اوہناں دی کیتی۔حَدّاں ٹپن پاروں
  7,166,تے جَد ٹھَاک اَساڈی نُوں ناہ اُکّا پَلّے بَدحا،تے اَساں کہیا ہُن بے اَبرائے(ذلیل) بندرِیلے اِی ڈَنگ ٹَپاسَو(ہن ذلیل و خوار ہوکے ،باندر بن کے وقت لنگھاسَو)
  7,167,تے رَب اِیبھی جَتلا دِتّا جے، ہُن تا قیامت وَاگ اوہناں دِی اوہناں دے ہَتھ رَکساں جو اِہناں دَا ڈاڈھا ماڑا حال کَرن دے،بے شَک رَب تیرا، ناہ ڈِھل ذَرا وِی لاندا، پھہنٹی چاڑن وَاری(سزا دیندے ویلے) بھاویں اونج غَفور رحیم اے
  7,168,تے اوہناں نُوں پھَاڑی پھَاڑی کَر دِتّا دُنیا دے اُتے،اوہناں دے وِچ چنَگے وِی نیں ، مَندے وِی نیں،اَساں اوہناں نُوں اَوکھے،سَوکھے وَقت لِیا کے اَزمایا سِی، ہو سَکدا اِے موڑا کھَاوَن(پلٹ جان)
  7,169,پِچھوں گَدّی ناخَلفاں نے سَانبھی،اوہ کِتاب اَللہ دے وَارث ہوندے ہوئے،رہے دُنیا اِی جھولی پاندے تے اِیہہ کہندے اوہ بخشیوے جاسَن ،ہور وِی دولت نظر پَوَے تے نَس(دوڑ) کے نَپّن (پھڑن)۔کی کِتاب اِلٰہی دَا اِ یہہ قول اوہناں توں لیا نئیں سِی ،رَب دے کھاتے حَقی سَچی گَل اِی پاؤ ،اِس وِچ لِکھیا آپوں وِی نیں پَڑھیا ہویا،یعنی خوف خُدا دَا رَکھن وَالڑیاں دے واہتے ،چھیکڑ(آخرت) دَا گَھَر چنَگا،کیوں ناہ عَقل تہانوں آوے
  7,170,جیہڑے پَکیاں ہین کِتاب اَللہ دِی پھَڑدے،تے پابند نَمازی ہے نیں،اِنج دے نیکوکاراں دَا ناہ اَجر کَدے وِی ضائع ہوسِی
  7,171,تے جد اَساں پہاڑ اوہناں دے سِر تے چھَتری وَانگ ہلایا اوہ سَمجھے اِیہہ اوہناں دے اُتے ہُن ڈِگّا، ہُن ڈِگّا (اَساں کہیا سی اوتھے)جو کجُھ اَساں تہانوں دِتّا، نپَنا پیڈا کرکے(مضبوطی نال پھَڑنا) تے جو کجُھ اِس دے اَندر اِس دے چیتے رَکھنا(یاد ر؟کھنا) ،ہوسَکدا اے جھاک رہوے جے رب دِی(ہو سکدا اے تُسی غلط کماں تو بچ جاؤ)
  7,172,تے جَد رَب تِرے نیں آدم جایاں(بنی آدم ) دِی سِی پُشتوں اوہناں دی اولاد وَدھائی (کڈھی) تے اوہناں توں عہد لیا سِی تے اوہناں نوں اوس گوا ہ ٹہرایا اِک دوجے دے اُتے،(ایہہ گل پُچھ کے) کی میں واں رَب تہاڈا، آخو(ہاں) کہہ کے اوہناں مَنّیاں(اقرار کیتا) ،ایہہ اِس پاروں سِی جے ،کِدھرے روزِقیامت ،عُذر ناہ ڈَاہو (کرو) سَانوں ، اِس دِی خَبر نئیں سِی
  7,173,یا ں اِیہہ آکھو شِرک اَساڈے پیو دَادا نیں کیتا ہے سِی۔اَسی اوہناں دے جَائے (اوہناں دی نسل)،اوہناں دے بَعد آئے،کی مُڑ تُوں ہَلاک اَسانوں باطَلیاں دِی کَاروں کَرسیں (غلط لوکاں دے کَمَّاں تَوں کَرسیں)
  7,174,اِنج اَسی آں کُھل کے اَپنی ہَر گَل دَسدے ،شاید لوکی مُوڑا کھاوَن(پلٹ آون)
  7,175,اے محمد ؑاِہناں اَگے اونج دے بندے دِی گَل کَر خَاں ،جِس دے کول اَسی لےآئے آیات اپنی، تے کَنّی کَترَاندا ہویا اوہناں کولوں اوس شیطانے د َا لَڑ ا وس پھَڑیا تے گُمراہواں دے سَنگ رَلیا
  7,176,اَس چاہندے تے اِہناں رَاہیں او س نوں اُچّاکر سَکدے ساں،اے پَر اوس دِی جھوک (جھکیا) ہمیشہ مِٹّی وَل سِی، تے اَپنی لَلچاوٹ دے پچِھے ٹُریا،حال اوس دَا اے کُتّے وَرگا، ڈَر کَارو (حملہ کرو) یاں ناہ ڈَر کارو (ناہ حملہ کرو)جیبھ (زبان)اوہ کَّڈی رَکھسی،تے آیات اَساڈی نوں ناہ پلّے بنَھن والی ساری قوم اِی جے َکر ہووے ،گَل اوس تے اِہوا ڈُھکّے(جَچدی اے)،پَر اِیہہ مَتّاں(گلاں) اوہناں دے کَن پاندا ،رہ تُوں ،ہو سَکدا اے،سَوچ اوہناں دے اَندر جاگے
  7,177,اوہناں تَوں وِی لوک اوہ بھیڑے(بُرے) جوناہ آیات آِساڈی نوں جو پلّے بنَھن، اوہ اَپنے نال (ظلم ) دَھکّے کَردے
  7,178,جِس نُوں رَب ہدایت دیوے،اوسے نوں اِی ملے ہدایت،جس نوں اوہ توفیق ناہ دیوے اِس دِی، اوہ گھاٹل اِی ہوندے(ناکام ،نامُراد )
  7,179,جنّا ں تے اِنساناں دے وچوں کِنّے اِی نیں اَساں ، جِنہاں نوں دوزخ واہتے اِی پیدا کیتا،عَقل اوہناں دے کول پَر اوہ اِس توَں کَم ناہ لیندے،لوئیں(اَکھاں) ہے نیں پَر اوہناں توَں کَم ناہ لیندے ،لینے والا،کَن ہے نیں پر سُندے ناہیں،(مَت ذرا وی ناہیں) اوہ ڈَنگر دے ڈَنگر ،بلکہ اوہناں نالوں وی دَو رَتّی وَدھ کے، غَفلت وِچ اوہ ڈُبّے ہوئے،
  7,180,اَللہ اِی ہے چنَگیا ںصِفتاں والا، اوہناں نال چتَارو(پکارو) اُس نُوں،جو اوس دِی صِفتاںوِچ گھَپلے کَردے، کَرو کَنارہ اوہنا ں کولوں،اوہ اَپنے کَرتوتاں دَا پھل پاکے رہسن
  7,181,تے مَخلوق اَساڈی وِچوں اوہ بھی نیں حَق دِی راہ تے جیہڑے لوکاں نوں لاندے نیں،تے لاندے نیں اوہ کَچہری حق دی
  7,182,تے آیات اَساڈی نُوں سَچ جِنہاں ناہ جاتا، اَس اوہناں نُوں ہولی ہولی (کھَڑے والے پاسے )کھَڑساں ایس طرح جے اوہناں نوں اِحساس ناہ ہوسِی،
  7,183,ڈِھل اوہنا ں نوں دیندا جاساں، پر اے چاَل پَکیری (پکی)میری
  7,184,کی سَوچن ناہِ، پَکڑ کِسے جِنّ اوہناں دے ،سَنگی نُوں ناہ کیتی ہوئی،اوہ تاں کھُلم کھُلا ہوڑَن ،ہَٹکن والا(برے اَنجام توں دار کرن والاتے ڈَران والا اے)
  7,185,کی خیال کَدے ناہ ا وہناں اِیدھر کیتا، کَاروبار اِیہہ دَھرتی تے اَسماناے دَا ہے وے ،تے ہر شے جیہڑی اَللہ نے خَلقائی ہوئی، دوجے پاسے اِیبھی مُمکن اوہناں دے ڈَنگ(سانس) پورے ہونے والے ہووَن تے اِس پِچھوں اوہ اِیمان لیاسَن، کیہڑی گَل تے
  7,186,اَللہ جِس نُوں رَاہوں اِیدھر اُودھر کردے کون ہدایت اوہنوں دیوے،اِنج دیا ں نُوں چھَڈ دیندا اے اَللہ۔ اوہناں دِی اَپنی اِی گُمراہی دے وِچ، بھَنبھل بھُوسے کھاوَن واہتے
  7,187,تینوں پُچھدے کَدوں کَدے اوہ ساعت(قیامت) آسِی،کہہ دے اوس دَا عِلم خُدا نُوں،و یلے سِر اوہوا ای ،اوس نوں لے آوے دا، دَھرتی تے اَسماناں واہتے اوس ویلے نے بھَارا ہونا۔تے اوس اُچن چیت (اچانک )تہاڈے تے آجانا،تینوں پُچھدے جِویں توں ایسے کھَوجے لگَّا،مُڑ ایوا اِی کہہ جے اِس دَا عِلم خُدا نُوں ، چوَکھے لوکاں دے پلّے ،اِیہہ گل ناہ پینے والی ہے وے
  7,188,اے محمد ؑ کہہ دے میں تے اَپنے حَق وِچ ناہ وَاہدا(نفع) ناہ گھَاٹا (نقصان)ہے واں کَرنے جوغا(کر سکن والا)،اُس توں ہَٹ کے جو اَللہ دِی مَرضی ہووے،تے جے کر میں غَیب دَا جانَن والا ہوندا ، چنَگا چَوکھا اَپنے واہتے کَٹھا کَردا، تے ناہ اَوکڑ (نقصان) وی ٹَوہ سَکدی مینوں،میں تاں ہوڑَن، ہِٹکن والا ہے واں(خَبردَار کَرن والا آں)،نالے آس دِلاوَن والا ،مَن ٹُریاں نوںـجیہڑے میری گَل مَن دے نیں)
  7,189,اِیہہ اوہوا ہے جِس نے تہانوں اِک اَصلوں پیدا کیتا، تے اوسے دے وِچوں اوس دَا جوڑا بنایا تاں جے اِس دے نال وَسے،نر(مرد) دے ناری(عورت) نُوں کَجّن(ملا پ ) تَوں، بھاَر جیہڑا اوہ اِک چاہ لیندی، لےکے جِس نُوں پھِردِی رہندی،تے جَد اوہ بھَار اوہ بھَارا ہووے ،اِیہہ دُعا اوہ کَر دِی اَللہ اَگے یعنی اَپنے رَب دے اَگے جے کَر جِی(بچہ) نَرویا(اچھا)سَانوں دیویں،تیرا دین(دینا) گِنا دیں(تیرے شُکر گزار ہوواں دے)
  7,190,پَر جَد بال نَرویا (صحیح سالم بچہ)اوہناں نوں رَب دیوے،اِیس دینے وِچ سِیری(شریک) ہَوراں نُوں وِی مَنّن ،اَللہ اِس تَوں بہت اُچیر (بلند و بر تر)جے اوہ محتاج سِیر (شریک))کِسے دَا ہووے
  7,191,کی اوہ گِنّن (کہن )سِیری (شریک)اوہناں نُوں جو ناہ خَلاقائے جوغے (جو کجُھ وِی تَخلیق نئیں کَر سَکدے) تے آپوں خَلقِیوے ہوئے(بلکہ خود تخلیق کیتے گئے نیں)
  7,192,ناہ اَپنے جوغے جو اِمداد کَرن اوہناں دی،اوہ تاں اَپنی وَی ناہ کُجھ سَوارن جوگے(اوہ تے اَپنی مَدد وِی نئیں کَرسَکدے)
  7,193,جے توں اوہناں تائیں سَدّیں (بُلاوے) سِدّھے پاسے(سدھی راہ تے) اوہ ناہ آکھے لَگّن، ہے برابر اوہناں نُوں سَدّنَا تے ناہ سَدّنا(پکُارو یاں ناہ پُکارو)
  7,194,اَللہ تَوں وَکھ ،جِنہاں اَگے تُسی عِرض گُزار ہوندے اوہ مُحتاج تہاڈے وَرگے،اوہناںاَگے عَرضاں کَر کے ویکھ، جے سچے او تاں، اوہ سُنن عَرض تُہاڈی
  7,195,کیہڑی پَیریں(پیراں) اوہ ٹُردے(چَلدے) نیں،کیہڑی ہَتھیں(ہتھ) اوہ کجُھ پھَڑدے(پکڑدے نیں)، کیہڑی اَکھیں(آکھ) تَکدے (ویکھدے)نیں،کیہڑی کِنّیں(کَن) اوہ سُندے نیں،اوہناں نُوں لَلکَر کے کہہ دے،سَد لوَو(بلاؤ) اِیہہ سَارے سِیری(شریک) اَپنے،تے سَارے وِنج چپّے لا لئو(تدبیراں کرلوَو)،ڈِھل د یئو ناہ مینوں اُکّا
  7,196,میرے سِر تے اِیہہ کِتاب اُتارن والا اَللہ ہے وے، تے اوہ نیکوکاراں دے ہَتھ سِر تے رَکھدا(وہ حمایت کردا اے)
  7,197,تُسی خُدا نُوں چھَڈکے عَرض گُذار جِنہاں دے اَگے ہووو،اوہ تُہاڈا کُجھ سوَارن جوگے ناہیں،اوہ تَاں اپَنا وِی ناہ کُجھ سَوارن جوگے
  7,198,مُڑ وی ااہناں نُوں جے سِدّھے پاسے سَدیں (بُلاوے) اوہ ناہ گَل نُوں گَولن(مَنّن)،تینوں لگدا اے اوہ تیرے وَل اِی ویکھ رہے نیں اونج اوہ تیرے وَلّوں بے دِھیاَنے ہوندے
  7,199,پَر ناہ بَنھ تُوں بھُل، کِسے دِی پلّے(درگزر کر)، تے رہ دیندا چنَگیاں مَتَّاں ، ہاں کَنّی کھِسکائی رَکھ(ناہ اُلَجھ) توُں جَاہل لوکاں کولوں
  7,200,جے شیطان کَدے کوئی چَکر تیرے نَال چَلاندا جاپے(تینوں اُکسائے) توُں لے او س توَں اُوٹ(پناہ) اَللہ دِی،اوہ سمیع اے،اوہ عِلیم اے بے َشک
  7,201,خُو ف خُدا دَا رَکھن والے جَدوں کَدے شیطان اوہناں تے چکر پیا چَلاندا جاپے،یَاد خُدا نُوں کَردے،اِنج ہَر گَل اوہناں اَگے نِتر جاندی(اوہناں نوں صاف نظرآ جاندا ،صحیح طریقہ کی اے)
  7,202,چیلے چَانٹے(شیطان دے) جاہل لوکاں نُوں بُرائی دے وَل دَھریکَن (لے جان )تُوں ناہ مَٹھے پیندے(کوئی کَسرنئیں چھَڈدے)
  7,203,لوکاں کولوں جَدوں توُں کوئی نشانی لے جاوے ناہیں، آکھن آپوں گھَڑ(بنا)لینی سِی،کہہ دے میں تاں اوہوا کَردا ، جِس دا مینوں ہے اِشارہ، رَبّوں ہوندا، اِیہہ گَلاں لَو اَکھیاں(بصیر ت دی روشیناں)دِی ہین تہا ڈے رب دے وَلوں،نالے رحمت اَتے ہدایت،مَنّن وَالڑیاں ں دے واہتے
  7,204,جے قرآن پَڑھیندا ہووے جَد وِی کِدھرے، اِس نوں سُنو تَوجہ کَرکے،چُپ ،چَاپ ہَو کے،ہو سَکدا اے رحمت رَب دِی، وَسّے(بارش وانگوں ہووے) آن تُساں تے
  7,205,رَب اَپنے نُوں تُسی چتارو(پُکارو)،اَپنے دِل وِچ زَاری کَردے ، اوس توں ڈَر دے،یا مُڑ ہونٹ ہَلاندے ،ہَولی ہَولی ،فَجری ،شَامیں، یعنی غافل لوکاں وِچوں تھِیوو ناہیں(ہوو ناہ)
  7,206,جیہڑے ہین خُدا دے نِیڑے(نزدیک) اوہ (دُنیا وِی) وَڈیائی دِی پھَنڈوں(بَڑائی دی گھُمنڈتوں)، دُور عبِادت تَوں ناہ ہَوندے،اوس دِیاں تَسبیحاں پَڑھدے ،اُوسے اَگےسجدے کَردے