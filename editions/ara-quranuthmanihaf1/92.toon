quran[21]{c,v,t}:
  92,1,واليل اذا يغشى
  92,2,والنهار اذا تجلى
  92,3,وما خلق الذكر والانثى
  92,4,ان سعيكم لشتى
  92,5,فاما من اعطى واتقى
  92,6,وصدق بالحسنى
  92,7,فسنيسره لليسرى
  92,8,واما من بخل واستغنى
  92,9,وكذب بالحسنى
  92,10,فسنيسره للعسرى
  92,11,وما يغني عنه ماله اذا تردى
  92,12,ان علينا للهدى
  92,13,وان لنا للاخرة والاولى
  92,14,فانذرتكم نار ا تلظى
  92,15,لا يصلىها الا الاشقى
  92,16,الذي كذب وتولى
  92,17,وسيجنبها الاتقى
  92,18,الذي يوتي ماله يتزكى
  92,19,وما لاحد عنده من نعمة تجزى
  92,20,الا ابتغاء وجه ربه الاعلى
  92,21,ولسوف يرضى