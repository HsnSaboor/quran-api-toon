quran[19]{c,v,t}:
  82,1,اذا السماء انفطرت
  82,2,واذا الكواكب انتثرت
  82,3,واذا البحار فجرت
  82,4,واذا القبور بعثرت
  82,5,علمت نفس ما قدمت واخرت
  82,6,يايها الانسن ما غرك بربك الكريم
  82,7,الذي خلقك فسوىك فعدلك
  82,8,في اي صورة ما شاء ركبك
  82,9,كلا بل تكذبون بالدين
  82,10,وان عليكم لحفظين
  82,11,كرام ا كتبين
  82,12,يعلمون ما تفعلون
  82,13,ان الابرار لفي نعيم
  82,14,وان الفجار لفي جحيم
  82,15,يصلونها يوم الدين
  82,16,وما هم عنها بغايبين
  82,17,وما ادرىك ما يوم الدين
  82,18,ثم ما ادرىك ما يوم الدين
  82,19,يوم لا تملك نفس لنفس شي ا والامر يوميذ لله