quran[67]{c,v,t}:
  90,1,"Hayır, and içerim bu şehre"
  90,2,Ki sen bu şehre girmektesin
  90,3,Doğurana ve doğurduğuna andolsun ki
  90,4,"Biz insanı birtakım zorluklar, zahmetler ve sıkıntılar içinde yarattık"
  90,5,İnsan hiç kimsenin kendisine güç yetiremeyeceğini mi sanıyor
  90,6,Yığın yığın mal tüketmişimdir diyor
  90,7,Kimsenin kendisini görmediğini mi sanıyor
  90,8,Biz ona iki göz vermedik mi
  90,9,"Bir dil, iki dudak vermedik mi"
  90,10,Biz ona eğri ve doğru iki yol göstermedik mi
  90,11,Fakat o zor geçidi aşmaya girişmedi
  90,12,O zor geçidin ne olduğunu sen bilir misin
  90,13,O geçit bir köle ve esir azad etmektir
  90,14,Yahut açlık gününde doyurmaktır
  90,15,Akraba olan yetimi
  90,16,Hiçbir şeyi olmayan yoksulu
  90,17,Sonra inanıp birbirlerine sabır tavsiye eden ve merhamet tavsiye edenlerden olmak
  90,18,İşte bunlar amel defterleri sağdan verilenlerdir
  90,19,Ayetlerimizi inkar edenler. İşte onlar amel defterleri soldan verilenlerdir
  90,20,Onlar her yönden ateşe kapatılacaklardır
  91,1,Güneşe ve onun ışığına
  91,2,Ardından gelmekte olan Ay´â
  91,3,Onu ortaya koyan gündüze
  91,4,Onu bürüyen geceye
  91,5,Göğe ve onu yapana
  91,6,Yere ve onu yayana
  91,7,Kişiye ve onu şekillendirene
  91,8,Sonra da ona iyilik ve kötülük kabiliyeti verene andolsun ki
  91,9,Kendini arıtan saadete ermiştir
  91,10,Kendini fenalıklara gömen kimse de ziyana uğramıştır
  91,11,Semud kavmi azgınlığı yüzünden Hakkı yalanladı
  91,12,İçinden azgını ileri atılınca
  91,13,"Allah´ın elçisi onlara: ´Allah´ın devesine ve onun su içme hakkına dokunmayın´ dedi"
  91,14,"Onu yalanladılar, deveyi kestiler. Rabbleri de, günahları yüzünden azabı başlarına geçirdi, orayı dümdüz etti"
  91,15,Allah bu işin sonundan korkmaz
  92,1,Örttüğü zaman geceye andolsun
  92,2,Ortaya çıkıp göründüğü zaman gündüze andolsun
  92,3,Erkeği ve dişiyi yaratana andolsun
  92,4,Sizin işiniz çeşit çeşittir
  92,5,Kim verir korunursa
  92,6,ve en güzel sözü doğrularsa
  92,7,Onu en kolay başarıya ulaştırırız
  92,8,"Fakat kim cimrilik eder, kendini zengin görüp kendisini Allah´tan müstağni sayarsa"
  92,9,Ve en güzel sözü de yalanlarsa
  92,10,Biz de onu en zora yöneltiriz
  92,11,Çukura düştüğü zaman malı ona hiçbir fayda sağlamaz
  92,12,Doğru yola iletmek bize aittir
  92,13,Şüphesiz ahiret de dünya da bize aittir
  92,14,Ben sizi alev saçan bir ateşe karşı uyardım
  92,15,Ona ancak bedbaht kimse girer
  92,16,O ki yalanladı ve döndü
  92,17,En çok korkan ondan uzak tutulur
  92,18,"O ki malını Allah rızası için vererek arınır, yücelir"
  92,19,O yaptığı iyiliği birinden karşılık görmek için yapmaz
  92,20,Ancak yüce Rabbinin hoşnutluğunu gözeterek yapar
  92,21,Elbette kendisi de hoşnut olacaktır
  93,1,Kuşluk vaktine andolusun
  93,2,Durgunlaşan geceye andolsun ki
  93,3,Rabbin seni bırakmadı ve sana darılmadı
  93,4,Andolsun senin için ahiret dünyadan daha hayırlıdır
  93,5,Rabbin sana verecek ve sen razı olacaksın
  93,6,O seni yetim bulup barındırmadı mı
  93,7,Şaşırmış bulup da yol göstermedi mi
  93,8,Fakir iken seni zengin etmedi mi
  93,9,Yetime gelince sakın onu üzme
  93,10,Yoksula gelince sakın onu azarlama
  93,11,Yalnızca Rabbinin nimetini anlat