quran[70]{c,v,t}:
  26,111,قَالُوۡ٘ا اَنُؤۡمِنُ لَكَ وَاتَّبَعَكَ الۡاَرۡذَلُوۡنَ ١١١ﶠ
  26,112,قَالَ وَمَا عِلۡمِيۡ بِمَا كَانُوۡا يَعۡمَلُوۡنَ ١١٢ﶔ
  26,113,اِنۡ حِسَابُهُمۡ اِلَّا عَلٰي رَبِّيۡ لَوۡ تَشۡعُرُوۡنَ ١١٣ﶔ
  26,114,وَمَا٘ اَنَا بِطَارِدِ الۡمُؤۡمِنِيۡنَ ١١٤ﶔ
  26,115,اِنۡ اَنَا اِلَّا نَذِيۡرٌ مُّبِيۡنٌ ١١٥ﶠ
  26,116,قَالُوۡا لَئِنۡ لَّمۡ تَنۡتَهِ يٰنُوۡحُ لَتَكُوۡنَنَّ مِنَ الۡمَرۡجُوۡمِيۡنَ ١١٦ﶠ
  26,117,قَالَ رَبِّ اِنَّ قَوۡمِيۡ كَذَّبُوۡنِ ١١٧ﶗ
  26,118,فَافۡتَحۡ بَيۡنِيۡ وَبَيۡنَهُمۡ فَتۡحًا وَّنَجِّنِيۡ وَمَنۡ مَّعِيَ مِنَ الۡمُؤۡمِنِيۡنَ ١١٨
  26,119,فَاَنۡجَيۡنٰهُ وَمَنۡ مَّعَهٗ فِي الۡفُلۡكِ الۡمَشۡحُوۡنِ ١١٩ﶔ
  26,120,ثُمَّ اَغۡرَقۡنَا بَعۡدُ الۡبَاقِيۡنَ ١٢٠ﶠ
  26,121,اِنَّ فِيۡ ذٰلِكَ لَاٰيَةًﵧ وَمَا كَانَ اَكۡثَرُهُمۡ مُّؤۡمِنِيۡنَ ١٢١
  26,122,وَاِنَّ رَبَّكَ لَهُوَ الۡعَزِيۡزُ الرَّحِيۡمُ ١٢٢ﶒ
  26,123,كَذَّبَتۡ عَادُ اِۨلۡمُرۡسَلِيۡنَ ١٢٣ﶗ
  26,124,اِذۡ قَالَ لَهُمۡ اَخُوۡهُمۡ هُوۡدٌ اَلَا تَتَّقُوۡنَ ١٢٤ﶔ
  26,125,اِنِّيۡ لَكُمۡ رَسُوۡلٌ اَمِيۡنٌ ١٢٥ﶫ
  26,126,فَاتَّقُوا اللّٰهَ وَاَطِيۡعُوۡنِ ١٢٦ﶔ
  26,127,وَمَا٘ اَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ اَجۡرٍﵐ اِنۡ اَجۡرِيَ اِلَّا عَلٰي رَبِّ الۡعٰلَمِيۡنَ ١٢٧ﶠ
  26,128,اَتَبۡنُوۡنَ بِكُلِّ رِيۡعٍ اٰيَةً تَعۡبَثُوۡنَ ١٢٨ﶫ
  26,129,وَتَتَّخِذُوۡنَ مَصَانِعَ لَعَلَّكُمۡ تَخۡلُدُوۡنَ ١٢٩ﶔ
  26,130,وَاِذَا بَطَشۡتُمۡ بَطَشۡتُمۡ جَبَّارِيۡنَ ١٣٠ﶔ
  26,131,فَاتَّقُوا اللّٰهَ وَاَطِيۡعُوۡنِ ١٣١ﶔ
  26,132,وَاتَّقُوا الَّذِيۡ٘ اَمَدَّكُمۡ بِمَا تَعۡلَمُوۡنَ ١٣٢ﶔ
  26,133,اَمَدَّكُمۡ بِاَنۡعَامٍ وَّبَنِيۡنَ ١٣٣ﶖ
  26,134,وَجَنّٰتٍ وَّعُيُوۡنٍ ١٣٤ﶔ
  26,135,اِنِّيۡ٘ اَخَافُ عَلَيۡكُمۡ عَذَابَ يَوۡمٍ عَظِيۡمٍ ١٣٥ﶠ
  26,136,قَالُوۡا سَوَآءٌ عَلَيۡنَا٘ اَوَعَظۡتَ اَمۡ لَمۡ تَكُنۡ مِّنَ الۡوٰعِظِيۡنَ ١٣٦ﶫ
  26,137,اِنۡ هٰذَا٘ اِلَّا خُلُقُ الۡاَوَّلِيۡنَ ١٣٧ﶫ
  26,138,وَمَا نَحۡنُ بِمُعَذَّبِيۡنَ ١٣٨ﶔ
  26,139,فَكَذَّبُوۡهُ فَاَهۡلَكۡنٰهُمۡﵧ اِنَّ فِيۡ ذٰلِكَ لَاٰيَةًﵧ وَمَا كَانَ اَكۡثَرُهُمۡ مُّؤۡمِنِيۡنَ ١٣٩
  26,140,وَاِنَّ رَبَّكَ لَهُوَ الۡعَزِيۡزُ الرَّحِيۡمُ ١٤٠ﶒ
  26,141,كَذَّبَتۡ ثَمُوۡدُ الۡمُرۡسَلِيۡنَ ١٤١ﶗ
  26,142,اِذۡ قَالَ لَهُمۡ اَخُوۡهُمۡ صٰلِحٌ اَلَا تَتَّقُوۡنَ ١٤٢ﶔ
  26,143,اِنِّيۡ لَكُمۡ رَسُوۡلٌ اَمِيۡنٌ ١٤٣ﶫ
  26,144,فَاتَّقُوا اللّٰهَ وَاَطِيۡعُوۡنِ ١٤٤ﶔ
  26,145,وَمَا٘ اَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ اَجۡرٍﵐ اِنۡ اَجۡرِيَ اِلَّا عَلٰي رَبِّ الۡعٰلَمِيۡنَ ١٤٥ﶠ
  26,146,اَتُتۡرَكُوۡنَ فِيۡ مَا هٰهُنَا٘ اٰمِنِيۡنَ ١٤٦ﶫ
  26,147,فِيۡ جَنّٰتٍ وَّعُيُوۡنٍ ١٤٧ﶫ
  26,148,وَّزُرُوۡعٍ وَّنَخۡلٍ طَلۡعُهَا هَضِيۡمٌ ١٤٨ﶔ
  26,149,وَتَنۡحِتُوۡنَ مِنَ الۡجِبَالِ بُيُوۡتًا فٰرِهِيۡنَ ١٤٩ﶔ
  26,150,فَاتَّقُوا اللّٰهَ وَاَطِيۡعُوۡنِ ١٥٠ﶔ
  26,151,وَلَا تُطِيۡعُوۡ٘ا اَمۡرَ الۡمُسۡرِفِيۡنَ ١٥١ﶫ
  26,152,الَّذِيۡنَ يُفۡسِدُوۡنَ فِي الۡاَرۡضِ وَلَا يُصۡلِحُوۡنَ ١٥٢
  26,153,قَالُوۡ٘ا اِنَّمَا٘ اَنۡتَ مِنَ الۡمُسَحَّرِيۡنَ ١٥٣ﶔ
  26,154,مَا٘ اَنۡتَ اِلَّا بَشَرٌ مِّثۡلُنَاﵗ فَاۡتِ بِاٰيَةٍ اِنۡ كُنۡتَ مِنَ الصّٰدِقِيۡنَ ١٥٤
  26,155,قَالَ هٰذِهٖ نَاقَةٌ لَّهَا شِرۡبٌ وَّلَكُمۡ شِرۡبُ يَوۡمٍ مَّعۡلُوۡمٍ ١٥٥ﶔ
  26,156,وَلَا تَمَسُّوۡهَا بِسُوۡٓءٍ فَيَاۡخُذَكُمۡ عَذَابُ يَوۡمٍ عَظِيۡمٍ ١٥٦
  26,157,فَعَقَرُوۡهَا فَاَصۡبَحُوۡا نٰدِمِيۡنَ ١٥٧ﶫ
  26,158,فَاَخَذَهُمُ الۡعَذَابُﵧ اِنَّ فِيۡ ذٰلِكَ لَاٰيَةًﵧ وَمَا كَانَ اَكۡثَرُهُمۡ مُّؤۡمِنِيۡنَ ١٥٨
  26,159,وَاِنَّ رَبَّكَ لَهُوَ الۡعَزِيۡزُ الرَّحِيۡمُ ١٥٩ﶒ
  26,160,كَذَّبَتۡ قَوۡمُ لُوۡطِ اِۨلۡمُرۡسَلِيۡنَ ١٦٠ﶗ
  26,161,اِذۡ قَالَ لَهُمۡ اَخُوۡهُمۡ لُوۡطٌ اَلَا تَتَّقُوۡنَ ١٦١ﶔ
  26,162,اِنِّيۡ لَكُمۡ رَسُوۡلٌ اَمِيۡنٌ ١٦٢ﶫ
  26,163,فَاتَّقُوا اللّٰهَ وَاَطِيۡعُوۡنِ ١٦٣ﶔ
  26,164,وَمَا٘ اَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ اَجۡرٍﵐ اِنۡ اَجۡرِيَ اِلَّا عَلٰي رَبِّ الۡعٰلَمِيۡنَ ١٦٤ﶠ
  26,165,اَتَاۡتُوۡنَ الذُّكۡرَانَ مِنَ الۡعٰلَمِيۡنَ ١٦٥ﶫ
  26,166,وَتَذَرُوۡنَ مَا خَلَقَ لَكُمۡ رَبُّكُمۡ مِّنۡ اَزۡوَاجِكُمۡﵧ بَلۡ اَنۡتُمۡ قَوۡمٌ عٰدُوۡنَ ١٦٦
  26,167,قَالُوۡا لَئِنۡ لَّمۡ تَنۡتَهِ يٰلُوۡطُ لَتَكُوۡنَنَّ مِنَ الۡمُخۡرَجِيۡنَ ١٦٧
  26,168,قَالَ اِنِّيۡ لِعَمَلِكُمۡ مِّنَ الۡقَالِيۡنَ ١٦٨ﶠ
  26,169,رَبِّ نَجِّنِيۡ وَاَهۡلِيۡ مِمَّا يَعۡمَلُوۡنَ ١٦٩
  26,170,فَنَجَّيۡنٰهُ وَاَهۡلَهٗ٘ اَجۡمَعِيۡنَ ١٧٠ﶫ
  26,171,اِلَّا عَجُوۡزًا فِي الۡغٰبِرِيۡنَ ١٧١ﶔ
  26,172,ثُمَّ دَمَّرۡنَا الۡاٰخَرِيۡنَ ١٧٢ﶔ
  26,173,وَاَمۡطَرۡنَا عَلَيۡهِمۡ مَّطَرًاﵐ فَسَآءَ مَطَرُ الۡمُنۡذَرِيۡنَ ١٧٣
  26,174,اِنَّ فِيۡ ذٰلِكَ لَاٰيَةًﵧ وَمَا كَانَ اَكۡثَرُهُمۡ مُّؤۡمِنِيۡنَ ١٧٤
  26,175,وَاِنَّ رَبَّكَ لَهُوَ الۡعَزِيۡزُ الرَّحِيۡمُ ١٧٥ﶒ
  26,176,كَذَّبَ اَصۡحٰبُ لۡـَٔيۡكَةِ الۡمُرۡسَلِيۡنَ ١٧٦ﶗ
  26,177,اِذۡ قَالَ لَهُمۡ شُعَيۡبٌ اَلَا تَتَّقُوۡنَ ١٧٧ﶔ
  26,178,اِنِّيۡ لَكُمۡ رَسُوۡلٌ اَمِيۡنٌ ١٧٨ﶫ
  26,179,فَاتَّقُوا اللّٰهَ وَاَطِيۡعُوۡنِ ١٧٩ﶔ
  26,180,وَمَا٘ اَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ اَجۡرٍﵐ اِنۡ اَجۡرِيَ اِلَّا عَلٰي رَبِّ الۡعٰلَمِيۡنَ ١٨٠ﶠ