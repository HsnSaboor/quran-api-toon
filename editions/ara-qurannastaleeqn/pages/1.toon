quran[7]{c,v,t}:
  1,1,بِسۡمِ اللّٰهِ الرَّحۡمٰنِ الرَّحِيۡمِ١
  1,2,اَلۡحَمۡدُ لِلّٰهِ رَبِّ الۡعٰلَمِيۡنَ ٢ﶫ
  1,3,الرَّحۡمٰنِ الرَّحِيۡمِ ٣ﶫ
  1,4,مٰلِكِ يَوۡمِ الدِّيۡنِ ٤ﶠ
  1,5,اِيَّاكَ نَعۡبُدُ وَاِيَّاكَ نَسۡتَعِيۡنُ ٥ﶠ
  1,6,اِهۡدِنَا الصِّرَاطَ الۡمُسۡتَقِيۡمَ ٦ﶫ
  1,7,صِرَاطَ الَّذِيۡنَ اَنۡعَمۡتَ عَلَيۡهِمۡﵿ غَيۡرِ الۡمَغۡضُوۡبِ عَلَيۡهِمۡ وَلَا الضَّآلِّيۡنَ ٧ﶒ