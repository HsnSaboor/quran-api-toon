quran[15]{c,v,t}:
  112,1,قُلۡ هُوَ اللّٰهُ اَحَدٌ ١ﶔ
  112,2,اَللّٰهُ الصَّمَدُ ٢ﶔ
  112,3,لَمۡ يَلِدۡﵿ وَلَمۡ يُوۡلَدۡ ٣ﶫ
  112,4,وَلَمۡ يَكُنۡ لَّهٗ كُفُوًا اَحَدٌ ٤ﶒ
  113,1,قُلۡ اَعُوۡذُ بِرَبِّ الۡفَلَقِ ١ﶫ
  113,2,مِنۡ شَرِّ مَا خَلَقَ ٢ﶫ
  113,3,وَمِنۡ شَرِّ غَاسِقٍ اِذَا وَقَبَ ٣ﶫ
  113,4,وَمِنۡ شَرِّ النَّفّٰثٰتِ فِي الۡعُقَدِ ٤ﶫ
  113,5,وَمِنۡ شَرِّ حَاسِدٍ اِذَا حَسَدَ ٥ﶒ
  114,1,قُلۡ اَعُوۡذُ بِرَبِّ النَّاسِ ١ﶫ
  114,2,مَلِكِ النَّاسِ ٢ﶫ
  114,3,اِلٰهِ النَّاسِ ٣ﶫ
  114,4,مِنۡ شَرِّ الۡوَسۡوَاسِﵿ الۡخَنَّاسِ ٤ﶫ
  114,5,الَّذِيۡ يُوَسۡوِسُ فِيۡ صُدُوۡرِ النَّاسِ ٥ﶫ
  114,6,مِنَ الۡجِنَّةِ وَالنَّاسِ ٦ﶒ