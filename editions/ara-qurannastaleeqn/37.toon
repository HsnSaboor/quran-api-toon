quran[182]{c,v,t}:
  37,1,وَالصّٰٓفّٰتِ صَفًّا ١ﶫ
  37,2,فَالزّٰجِرٰتِ زَجۡرًا ٢ﶫ
  37,3,فَالتّٰلِيٰتِ ذِكۡرًا ٣ﶫ
  37,4,اِنَّ اِلٰهَكُمۡ لَوَاحِدٌ ٤ﶠ
  37,5,رَبُّ السَّمٰوٰتِ وَالۡاَرۡضِ وَمَا بَيۡنَهُمَا وَرَبُّ الۡمَشَارِقِ ٥ﶠ
  37,6,اِنَّا زَيَّنَّا السَّمَآءَ الدُّنۡيَا بِزِيۡنَةِ اِۨلۡكَوَاكِبِ ٦ﶫ
  37,7,وَحِفۡظًا مِّنۡ كُلِّ شَيۡطٰنٍ مَّارِدٍ ٧ﶔ
  37,8,لَا يَسَّمَّعُوۡنَ اِلَي الۡمَلَاِ الۡاَعۡلٰي وَيُقۡذَفُوۡنَ مِنۡ كُلِّ جَانِبٍ ٨ﶾ
  37,9,دُحُوۡرًا وَّلَهُمۡ عَذَابٌ وَّاصِبٌ ٩ﶫ
  37,10,اِلَّا مَنۡ خَطِفَ الۡخَطۡفَةَ فَاَتۡبَعَهٗ شِهَابٌ ثَاقِبٌ ١٠
  37,11,فَاسۡتَفۡتِهِمۡ اَهُمۡ اَشَدُّ خَلۡقًا اَمۡ مَّنۡ خَلَقۡنَاﵧ اِنَّا خَلَقۡنٰهُمۡ مِّنۡ طِيۡنٍ لَّازِبٍ ١١
  37,12,بَلۡ عَجِبۡتَ وَيَسۡخَرُوۡنَ ١٢ﶝ
  37,13,وَاِذَا ذُكِّرُوۡا لَا يَذۡكُرُوۡنَ ١٣ﶝ
  37,14,وَاِذَا رَاَوۡا اٰيَةً يَّسۡتَسۡخِرُوۡنَ ١٤ﶝ
  37,15,وَقَالُوۡ٘ا اِنۡ هٰذَا٘ اِلَّا سِحۡرٌ مُّبِيۡنٌ ١٥ﶗ
  37,16,ءَاِذَا مِتۡنَا وَكُنَّا تُرَابًا وَّعِظَامًا ءَاِنَّا لَمَبۡعُوۡثُوۡنَ ١٦ﶫ
  37,17,اَوَ اٰبَآؤُنَا الۡاَوَّلُوۡنَ ١٧ﶠ
  37,18,قُلۡ نَعَمۡ وَاَنۡتُمۡ دَاخِرُوۡنَ ١٨ﶔ
  37,19,فَاِنَّمَا هِيَ زَجۡرَةٌ وَّاحِدَةٌ فَاِذَا هُمۡ يَنۡظُرُوۡنَ ١٩
  37,20,وَقَالُوۡا يٰوَيۡلَنَا هٰذَا يَوۡمُ الدِّيۡنِ ٢٠
  37,21,هٰذَا يَوۡمُ الۡفَصۡلِ الَّذِيۡ كُنۡتُمۡ بِهٖ تُكَذِّبُوۡنَ ٢١ﶒ
  37,22,اُحۡشُرُوا الَّذِيۡنَ ظَلَمُوۡا وَاَزۡوَاجَهُمۡ وَمَا كَانُوۡا يَعۡبُدُوۡنَ ٢٢ﶫ
  37,23,مِنۡ دُوۡنِ اللّٰهِ فَاهۡدُوۡهُمۡ اِلٰي صِرَاطِ الۡجَحِيۡمِ ٢٣ﶺ
  37,24,وَقِفُوۡهُمۡ اِنَّهُمۡ مَّسۡـُٔوۡلُوۡنَ ٢٤ﶫ
  37,25,مَا لَكُمۡ لَا تَنَاصَرُوۡنَ ٢٥
  37,26,بَلۡ هُمُ الۡيَوۡمَ مُسۡتَسۡلِمُوۡنَ ٢٦
  37,27,وَاَقۡبَلَ بَعۡضُهُمۡ عَلٰي بَعۡضٍ يَّتَسَآءَلُوۡنَ ٢٧
  37,28,قَالُوۡ٘ا اِنَّكُمۡ كُنۡتُمۡ تَاۡتُوۡنَنَا عَنِ الۡيَمِيۡنِ ٢٨
  37,29,قَالُوۡا بَلۡ لَّمۡ تَكُوۡنُوۡا مُؤۡمِنِيۡنَ ٢٩ﶔ
  37,30,وَمَا كَانَ لَنَا عَلَيۡكُمۡ مِّنۡ سُلۡطٰنٍﵐ بَلۡ كُنۡتُمۡ قَوۡمًا طٰغِيۡنَ ٣٠
  37,31,فَحَقَّ عَلَيۡنَا قَوۡلُ رَبِّنَا٘ﵲ اِنَّا لَذَآئِقُوۡنَ ٣١
  37,32,فَاَغۡوَيۡنٰكُمۡ اِنَّا كُنَّا غٰوِيۡنَ ٣٢
  37,33,فَاِنَّهُمۡ يَوۡمَئِذٍ فِي الۡعَذَابِ مُشۡتَرِكُوۡنَ ٣٣
  37,34,اِنَّا كَذٰلِكَ نَفۡعَلُ بِالۡمُجۡرِمِيۡنَ ٣٤
  37,35,اِنَّهُمۡ كَانُوۡ٘ا اِذَا قِيۡلَ لَهُمۡ لَا٘ اِلٰهَ اِلَّا اللّٰهُ يَسۡتَكۡبِرُوۡنَ ٣٥ﶫ
  37,36,وَيَقُوۡلُوۡنَ اَئِنَّا لَتَارِكُوۡ٘ا اٰلِهَتِنَا لِشَاعِرٍ مَّجۡنُوۡنٍ ٣٦ﶠ
  37,37,بَلۡ جَآءَ بِالۡحَقِّ وَصَدَّقَ الۡمُرۡسَلِيۡنَ ٣٧
  37,38,اِنَّكُمۡ لَذَآئِقُوا الۡعَذَابِ الۡاَلِيۡمِ ٣٨ﶔ
  37,39,وَمَا تُجۡزَوۡنَ اِلَّا مَا كُنۡتُمۡ تَعۡمَلُوۡنَ ٣٩ﶫ
  37,40,اِلَّا عِبَادَ اللّٰهِ الۡمُخۡلَصِيۡنَ ٤٠
  37,41,اُولٰٓئِكَ لَهُمۡ رِزۡقٌ مَّعۡلُوۡمٌ ٤١ﶫ
  37,42,فَوَاكِهُﵐ وَهُمۡ مُّكۡرَمُوۡنَ ٤٢ﶫ
  37,43,فِيۡ جَنّٰتِ النَّعِيۡمِ ٤٣ﶫ
  37,44,عَلٰي سُرُرٍ مُّتَقٰبِلِيۡنَ ٤٤
  37,45,يُطَافُ عَلَيۡهِمۡ بِكَاۡسٍ مِّنۡ مَّعِيۡنٍۣ ٤٥ﶫ
  37,46,بَيۡضَآءَ لَذَّةٍ لِّلشّٰرِبِيۡنَ ٤٦ﶔ
  37,47,لَا فِيۡهَا غَوۡلٌ وَّلَا هُمۡ عَنۡهَا يُنۡزَفُوۡنَ ٤٧
  37,48,وَعِنۡدَهُمۡ قٰصِرٰتُ الطَّرۡفِ عِيۡنٌ ٤٨ﶫ
  37,49,كَاَنَّهُنَّ بَيۡضٌ مَّكۡنُوۡنٌ ٤٩
  37,50,فَاَقۡبَلَ بَعۡضُهُمۡ عَلٰي بَعۡضٍ يَّتَسَآءَلُوۡنَ ٥٠
  37,51,قَالَ قَآئِلٌ مِّنۡهُمۡ اِنِّيۡ كَانَ لِيۡ قَرِيۡنٌ ٥١ﶫ
  37,52,يَّقُوۡلُ ءَاِنَّكَ لَمِنَ الۡمُصَدِّقِيۡنَ ٥٢
  37,53,ءَاِذَا مِتۡنَا وَكُنَّا تُرَابًا وَّعِظَامًا ءَاِنَّا لَمَدِيۡنُوۡنَ ٥٣
  37,54,قَالَ هَلۡ اَنۡتُمۡ مُّطَّلِعُوۡنَ ٥٤
  37,55,فَاطَّلَعَ فَرَاٰهُ فِيۡ سَوَآءِ الۡجَحِيۡمِ ٥٥
  37,56,قَالَ تَاللّٰهِ اِنۡ كِدۡتَّ لَتُرۡدِيۡنِ ٥٦ﶫ
  37,57,وَلَوۡلَا نِعۡمَةُ رَبِّيۡ لَكُنۡتُ مِنَ الۡمُحۡضَرِيۡنَ ٥٧
  37,58,اَفَمَا نَحۡنُ بِمَيِّتِيۡنَ ٥٨ﶫ
  37,59,اِلَّا مَوۡتَتَنَا الۡاُوۡلٰي وَمَا نَحۡنُ بِمُعَذَّبِيۡنَ ٥٩
  37,60,اِنَّ هٰذَا لَهُوَ الۡفَوۡزُ الۡعَظِيۡمُ ٦٠
  37,61,لِمِثۡلِ هٰذَا فَلۡيَعۡمَلِ الۡعٰمِلُوۡنَ ٦١
  37,62,اَذٰلِكَ خَيۡرٌ نُّزُلًا اَمۡ شَجَرَةُ الزَّقُّوۡمِ ٦٢
  37,63,اِنَّا جَعَلۡنٰهَا فِتۡنَةً لِّلظّٰلِمِيۡنَ ٦٣
  37,64,اِنَّهَا شَجَرَةٌ تَخۡرُجُ فِيۡ٘ اَصۡلِ الۡجَحِيۡمِ ٦٤ﶫ
  37,65,طَلۡعُهَا كَاَنَّهٗ رُءُوۡسُ الشَّيٰطِيۡنِ ٦٥
  37,66,فَاِنَّهُمۡ لَاٰكِلُوۡنَ مِنۡهَا فَمَالِـُٔوۡنَ مِنۡهَا الۡبُطُوۡنَ ٦٦ﶠ
  37,67,ثُمَّ اِنَّ لَهُمۡ عَلَيۡهَا لَشَوۡبًا مِّنۡ حَمِيۡمٍ ٦٧ﶔ
  37,68,ثُمَّ اِنَّ مَرۡجِعَهُمۡ لَا۠اِلَي الۡجَحِيۡمِ ٦٨
  37,69,اِنَّهُمۡ اَلۡفَوۡا اٰبَآءَهُمۡ ضَآلِّيۡنَ ٦٩ﶫ
  37,70,فَهُمۡ عَلٰ٘ي اٰثٰرِهِمۡ يُهۡرَعُوۡنَ ٧٠
  37,71,وَلَقَدۡ ضَلَّ قَبۡلَهُمۡ اَكۡثَرُ الۡاَوَّلِيۡنَ ٧١ﶫ
  37,72,وَلَقَدۡ اَرۡسَلۡنَا فِيۡهِمۡ مُّنۡذِرِيۡنَ ٧٢
  37,73,فَانۡظُرۡ كَيۡفَ كَانَ عَاقِبَةُ الۡمُنۡذَرِيۡنَ ٧٣ﶫ
  37,74,اِلَّا عِبَادَ اللّٰهِ الۡمُخۡلَصِيۡنَ ٧٤ﶒ
  37,75,وَلَقَدۡ نَادٰىنَا نُوۡحٌ فَلَنِعۡمَ الۡمُجِيۡبُوۡنَ ٧٥ﶛ
  37,76,وَنَجَّيۡنٰهُ وَاَهۡلَهٗ مِنَ الۡكَرۡبِ الۡعَظِيۡمِ ٧٦ﶛ
  37,77,وَجَعَلۡنَا ذُرِّيَّتَهٗ هُمُ الۡبَاقِيۡنَ ٧٧ﶛ
  37,78,وَتَرَكۡنَا عَلَيۡهِ فِي الۡاٰخِرِيۡنَ ٧٨ﶛ
  37,79,سَلٰمٌ عَلٰي نُوۡحٍ فِي الۡعٰلَمِيۡنَ ٧٩
  37,80,اِنَّا كَذٰلِكَ نَجۡزِي الۡمُحۡسِنِيۡنَ ٨٠
  37,81,اِنَّهٗ مِنۡ عِبَادِنَا الۡمُؤۡمِنِيۡنَ ٨١
  37,82,ثُمَّ اَغۡرَقۡنَا الۡاٰخَرِيۡنَ ٨٢
  37,83,وَاِنَّ مِنۡ شِيۡعَتِهٖ لَاِبۡرٰهِيۡمَ ٨٣ﶭ
  37,84,اِذۡ جَآءَ رَبَّهٗ بِقَلۡبٍ سَلِيۡمٍ ٨٤
  37,85,اِذۡ قَالَ لِاَبِيۡهِ وَقَوۡمِهٖ مَاذَا تَعۡبُدُوۡنَ ٨٥ﶔ
  37,86,اَئِفۡكًا اٰلِهَةً دُوۡنَ اللّٰهِ تُرِيۡدُوۡنَ ٨٦ﶠ
  37,87,فَمَا ظَنُّكُمۡ بِرَبِّ الۡعٰلَمِيۡنَ ٨٧
  37,88,فَنَظَرَ نَظۡرَةً فِي النُّجُوۡمِ ٨٨ﶫ
  37,89,فَقَالَ اِنِّيۡ سَقِيۡمٌ ٨٩
  37,90,فَتَوَلَّوۡا عَنۡهُ مُدۡبِرِيۡنَ ٩٠
  37,91,فَرَاغَ اِلٰ٘ي اٰلِهَتِهِمۡ فَقَالَ اَلَا تَاۡكُلُوۡنَ ٩١ﶔ
  37,92,مَا لَكُمۡ لَا تَنۡطِقُوۡنَ ٩٢
  37,93,فَرَاغَ عَلَيۡهِمۡ ضَرۡبًاۣ بِالۡيَمِيۡنِ ٩٣
  37,94,فَاَقۡبَلُوۡ٘ا اِلَيۡهِ يَزِفُّوۡنَ ٩٤
  37,95,قَالَ اَتَعۡبُدُوۡنَ مَا تَنۡحِتُوۡنَ ٩٥ﶫ
  37,96,وَاللّٰهُ خَلَقَكُمۡ وَمَا تَعۡمَلُوۡنَ ٩٦
  37,97,قَالُوا ابۡنُوۡا لَهٗ بُنۡيَانًا فَاَلۡقُوۡهُ فِي الۡجَحِيۡمِ ٩٧
  37,98,فَاَرَادُوۡا بِهٖ كَيۡدًا فَجَعَلۡنٰهُمُ الۡاَسۡفَلِيۡنَ ٩٨
  37,99,وَقَالَ اِنِّيۡ ذَاهِبٌ اِلٰي رَبِّيۡ سَيَهۡدِيۡنِ ٩٩
  37,100,رَبِّ هَبۡ لِيۡ مِنَ الصّٰلِحِيۡنَ ١٠٠
  37,101,فَبَشَّرۡنٰهُ بِغُلٰمٍ حَلِيۡمٍ ١٠١
  37,102,فَلَمَّا بَلَغَ مَعَهُ السَّعۡيَ قَالَ يٰبُنَيَّ اِنِّيۡ٘ اَرٰي فِي الۡمَنَامِ اَنِّيۡ٘ اَذۡبَحُكَ فَانۡظُرۡ مَاذَا تَرٰيﵧ قَالَ يٰ٘اَبَتِ افۡعَلۡ مَا تُؤۡمَرُﵟ سَتَجِدُنِيۡ٘ اِنۡ شَآءَ اللّٰهُ مِنَ الصّٰبِرِيۡنَ ١٠٢
  37,103,فَلَمَّا٘ اَسۡلَمَا وَتَلَّهٗ لِلۡجَبِيۡنِ ١٠٣ﶔ
  37,104,وَنَادَيۡنٰهُ اَنۡ يّٰ٘اِبۡرٰهِيۡمُ ١٠٤ﶫ
  37,105,قَدۡ صَدَّقۡتَ الرُّءۡيَاﵐ اِنَّا كَذٰلِكَ نَجۡزِي الۡمُحۡسِنِيۡنَ ١٠٥
  37,106,اِنَّ هٰذَا لَهُوَ الۡبَلٰٓؤُا الۡمُبِيۡنُ ١٠٦
  37,107,وَفَدَيۡنٰهُ بِذِبۡحٍ عَظِيۡمٍ ١٠٧
  37,108,وَتَرَكۡنَا عَلَيۡهِ فِي الۡاٰخِرِيۡنَ ١٠٨ﶚ
  37,109,سَلٰمٌ عَلٰ٘ي اِبۡرٰهِيۡمَ ١٠٩
  37,110,كَذٰلِكَ نَجۡزِي الۡمُحۡسِنِيۡنَ ١١٠
  37,111,اِنَّهٗ مِنۡ عِبَادِنَا الۡمُؤۡمِنِيۡنَ ١١١
  37,112,وَبَشَّرۡنٰهُ بِاِسۡحٰقَ نَبِيًّا مِّنَ الصّٰلِحِيۡنَ ١١٢
  37,113,وَبٰرَكۡنَا عَلَيۡهِ وَعَلٰ٘ي اِسۡحٰقَﵧ وَمِنۡ ذُرِّيَّتِهِمَا مُحۡسِنٌ وَّظَالِمٌ لِّنَفۡسِهٖ مُبِيۡنٌ ١١٣ﶒ
  37,114,وَلَقَدۡ مَنَنَّا عَلٰي مُوۡسٰي وَهٰرُوۡنَ ١١٤ﶔ
  37,115,وَنَجَّيۡنٰهُمَا وَقَوۡمَهُمَا مِنَ الۡكَرۡبِ الۡعَظِيۡمِ ١١٥ﶔ
  37,116,وَنَصَرۡنٰهُمۡ فَكَانُوۡا هُمُ الۡغٰلِبِيۡنَ ١١٦ﶔ
  37,117,وَاٰتَيۡنٰهُمَا الۡكِتٰبَ الۡمُسۡتَبِيۡنَ ١١٧ﶔ
  37,118,وَهَدَيۡنٰهُمَا الصِّرَاطَ الۡمُسۡتَقِيۡمَ ١١٨ﶔ
  37,119,وَتَرَكۡنَا عَلَيۡهِمَا فِي الۡاٰخِرِيۡنَ ١١٩ﷇ
  37,120,سَلٰمٌ عَلٰي مُوۡسٰي وَهٰرُوۡنَ ١٢٠
  37,121,اِنَّا كَذٰلِكَ نَجۡزِي الۡمُحۡسِنِيۡنَ ١٢١
  37,122,اِنَّهُمَا مِنۡ عِبَادِنَا الۡمُؤۡمِنِيۡنَ ١٢٢
  37,123,وَاِنَّ اِلۡيَاسَ لَمِنَ الۡمُرۡسَلِيۡنَ ١٢٣ﶠ
  37,124,اِذۡ قَالَ لِقَوۡمِهٖ٘ اَلَا تَتَّقُوۡنَ ١٢٤
  37,125,اَتَدۡعُوۡنَ بَعۡلًا وَّتَذَرُوۡنَ اَحۡسَنَ الۡخٰلِقِيۡنَ ١٢٥ﶫ
  37,126,اللّٰهَ رَبَّكُمۡ وَرَبَّ اٰبَآئِكُمُ الۡاَوَّلِيۡنَ ١٢٦
  37,127,فَكَذَّبُوۡهُ فَاِنَّهُمۡ لَمُحۡضَرُوۡنَ ١٢٧ﶫ
  37,128,اِلَّا عِبَادَ اللّٰهِ الۡمُخۡلَصِيۡنَ ١٢٨
  37,129,وَتَرَكۡنَا عَلَيۡهِ فِي الۡاٰخِرِيۡنَ ١٢٩ﶫ
  37,130,سَلٰمٌ عَلٰ٘ي اِلۡ يَاسِيۡنَ ١٣٠
  37,131,اِنَّا كَذٰلِكَ نَجۡزِي الۡمُحۡسِنِيۡنَ ١٣١
  37,132,اِنَّهٗ مِنۡ عِبَادِنَا الۡمُؤۡمِنِيۡنَ ١٣٢
  37,133,وَاِنَّ لُوۡطًا لَّمِنَ الۡمُرۡسَلِيۡنَ ١٣٣ﶠ
  37,134,اِذۡ نَجَّيۡنٰهُ وَاَهۡلَهٗ٘ اَجۡمَعِيۡنَ ١٣٤ﶫ
  37,135,اِلَّا عَجُوۡزًا فِي الۡغٰبِرِيۡنَ ١٣٥
  37,136,ثُمَّ دَمَّرۡنَا الۡاٰخَرِيۡنَ ١٣٦
  37,137,وَاِنَّكُمۡ لَتَمُرُّوۡنَ عَلَيۡهِمۡ مُّصۡبِحِيۡنَ ١٣٧ﶫ
  37,138,وَبِالَّيۡلِﵧ اَفَلَا تَعۡقِلُوۡنَ ١٣٨ﶒ
  37,139,وَاِنَّ يُوۡنُسَ لَمِنَ الۡمُرۡسَلِيۡنَ ١٣٩ﶠ
  37,140,اِذۡ اَبَقَ اِلَي الۡفُلۡكِ الۡمَشۡحُوۡنِ ١٤٠ﶫ
  37,141,فَسَاهَمَ فَكَانَ مِنَ الۡمُدۡحَضِيۡنَ ١٤١ﶔ
  37,142,فَالۡتَقَمَهُ الۡحُوۡتُ وَهُوَ مُلِيۡمٌ ١٤٢
  37,143,فَلَوۡلَا٘ اَنَّهٗ كَانَ مِنَ الۡمُسَبِّحِيۡنَ ١٤٣ﶫ
  37,144,لَلَبِثَ فِيۡ بَطۡنِهٖ٘ اِلٰي يَوۡمِ يُبۡعَثُوۡنَ ١٤٤ﶔ
  37,145,فَنَبَذۡنٰهُ بِالۡعَرَآءِ وَهُوَ سَقِيۡمٌ ١٤٥ﶔ
  37,146,وَاَنۣۡبَتۡنَا عَلَيۡهِ شَجَرَةً مِّنۡ يَّقۡطِيۡنٍ ١٤٦ﶔ
  37,147,وَاَرۡسَلۡنٰهُ اِلٰي مِائَةِ اَلۡفٍ اَوۡ يَزِيۡدُوۡنَ ١٤٧ﶔ
  37,148,فَاٰمَنُوۡا فَمَتَّعۡنٰهُمۡ اِلٰي حِيۡنٍ ١٤٨ﶠ
  37,149,فَاسۡتَفۡتِهِمۡ اَلِرَبِّكَ الۡبَنَاتُ وَلَهُمُ الۡبَنُوۡنَ ١٤٩ﶫ
  37,150,اَمۡ خَلَقۡنَا الۡمَلٰٓئِكَةَ اِنَاثًا وَّهُمۡ شٰهِدُوۡنَ ١٥٠
  37,151,اَلَا٘ اِنَّهُمۡ مِّنۡ اِفۡكِهِمۡ لَيَقُوۡلُوۡنَ ١٥١ﶫ
  37,152,وَلَدَ اللّٰهُﶈ وَاِنَّهُمۡ لَكٰذِبُوۡنَ ١٥٢
  37,153,اَصۡطَفَي الۡبَنَاتِ عَلَي الۡبَنِيۡنَ ١٥٣ﶠ
  37,154,مَا لَكُمۡﵴ كَيۡفَ تَحۡكُمُوۡنَ ١٥٤
  37,155,اَفَلَا تَذَكَّرُوۡنَ ١٥٥ﶔ
  37,156,اَمۡ لَكُمۡ سُلۡطٰنٌ مُّبِيۡنٌ ١٥٦ﶫ
  37,157,فَاۡتُوۡا بِكِتٰبِكُمۡ اِنۡ كُنۡتُمۡ صٰدِقِيۡنَ ١٥٧
  37,158,وَجَعَلُوۡا بَيۡنَهٗ وَبَيۡنَ الۡجِنَّةِ نَسَبًاﵧ وَلَقَدۡ عَلِمَتِ الۡجِنَّةُ اِنَّهُمۡ لَمُحۡضَرُوۡنَ ١٥٨ﶫ
  37,159,سُبۡحٰنَ اللّٰهِ عَمَّا يَصِفُوۡنَ ١٥٩ﶫ
  37,160,اِلَّا عِبَادَ اللّٰهِ الۡمُخۡلَصِيۡنَ ١٦٠
  37,161,فَاِنَّكُمۡ وَمَا تَعۡبُدُوۡنَ ١٦١ﶫ
  37,162,مَا٘ اَنۡتُمۡ عَلَيۡهِ بِفٰتِنِيۡنَ ١٦٢ﶫ
  37,163,اِلَّا مَنۡ هُوَ صَالِ الۡجَحِيۡمِ ١٦٣
  37,164,وَمَا مِنَّا٘ اِلَّا لَهٗ مَقَامٌ مَّعۡلُوۡمٌ ١٦٤ﶫ
  37,165,وَّاِنَّا لَنَحۡنُ الصَّآفُّوۡنَ ١٦٥ﶔ
  37,166,وَاِنَّا لَنَحۡنُ الۡمُسَبِّحُوۡنَ ١٦٦
  37,167,وَاِنۡ كَانُوۡا لَيَقُوۡلُوۡنَ ١٦٧ﶫ
  37,168,لَوۡ اَنَّ عِنۡدَنَا ذِكۡرًا مِّنَ الۡاَوَّلِيۡنَ ١٦٨ﶫ
  37,169,لَكُنَّا عِبَادَ اللّٰهِ الۡمُخۡلَصِيۡنَ ١٦٩
  37,170,فَكَفَرُوۡا بِهٖ فَسَوۡفَ يَعۡلَمُوۡنَ ١٧٠
  37,171,وَلَقَدۡ سَبَقَتۡ كَلِمَتُنَا لِعِبَادِنَا الۡمُرۡسَلِيۡنَ ١٧١ﶗ
  37,172,اِنَّهُمۡ لَهُمُ الۡمَنۡصُوۡرُوۡنَ ١٧٢ﶝ
  37,173,وَاِنَّ جُنۡدَنَا لَهُمُ الۡغٰلِبُوۡنَ ١٧٣
  37,174,فَتَوَلَّ عَنۡهُمۡ حَتّٰي حِيۡنٍ ١٧٤ﶫ
  37,175,وَّاَبۡصِرۡهُمۡ فَسَوۡفَ يُبۡصِرُوۡنَ ١٧٥
  37,176,اَفَبِعَذَابِنَا يَسۡتَعۡجِلُوۡنَ ١٧٦
  37,177,فَاِذَا نَزَلَ بِسَاحَتِهِمۡ فَسَآءَ صَبَاحُ الۡمُنۡذَرِيۡنَ ١٧٧
  37,178,وَتَوَلَّ عَنۡهُمۡ حَتّٰي حِيۡنٍ ١٧٨ﶫ
  37,179,وَّاَبۡصِرۡ فَسَوۡفَ يُبۡصِرُوۡنَ ١٧٩
  37,180,سُبۡحٰنَ رَبِّكَ رَبِّ الۡعِزَّةِ عَمَّا يَصِفُوۡنَ ١٨٠ﶔ
  37,181,وَسَلٰمٌ عَلَي الۡمُرۡسَلِيۡنَ ١٨١ﶔ
  37,182,وَالۡحَمۡدُ لِلّٰهِ رَبِّ الۡعٰلَمِيۡنَ ١٨٢ﶒ