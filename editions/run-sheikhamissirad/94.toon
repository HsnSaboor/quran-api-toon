quran[8]{c,v,t}:
  94,1,Mbega ntitwakwaguriye igikiriza cawe
  94,2,Nukugukurira uburemere bwawe wari ufise
  94,3,Bwavunye umugongo wawe
  94,4,Nukuguhayagiza kukuvurwa kwawe
  94,5,"Rero mu vy’ukuri hamwe n’ingorane, haraboneka agahengwe"
  94,6,"Mu vy’ukuri hamwe n’ingorane, haraboneka agahengwe"
  94,7,"Niwaheza\tgushikiriza\tubutumwa\tbwawe,\tn’ubandaye\tn’amasengesho yawe"
  94,8,Kandi wiyegereze cane ku Muremyi wawe