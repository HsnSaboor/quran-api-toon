quran[18]{c,v,t}:
  36,33,"N’ikimenyetso\tkiri\tkuribo\tn’Isi\tyapfuye,\ttuzoyizura\tnugukura\tmuriyo imbuto bazohora bafungura"
  36,34,"Tugira muriyo imirima hamwe n’ibiti vy’imitende n’imizabibu\thamwe nugu cishamwo amariba muriyo"
  36,35,"Kugira ngo bafungure muri ivyo vyamwa, kandi n’amaboko yabo ntaco yakoze, mbega ntibashima"
  36,36,Hahayagizwa Imana yaremye ikigabo n’ikigore muri vyose muvyo Isi inagisha no mumitima yabo hamwe nivyo batazi
  36,37,"N’ijoro\tn’ikimenyetso\tkuribo\tkuko\tariho\tbakura\tmwo\tumurango, mumwanya bagaca baba mumwijima"
  36,38,"N’izuba\trigenda\tgushika\tkugituro\tcaryo,\tiryo\tn’iteguro\try’uwufise ububasha n’ubumenyi"
  36,39,"N’ukwezi\ttwagupimiye\tibituro\tvyakwo\tkugeza\tnaho\tgusubira\tkuba gutoyi cane nk’igishishwa c’icamwa c’umutende gishaje cane"
  36,40,"Ntazuba rishikira\tUkwezi canke Ijoro ngo rirenge Umutaga, mugabo vyose biguma birerembera munzira zavyo"
  36,41,"N’ibimenyetso\tkuribo\tbimenyesha\tyuko\ttwajanye\tabavyeyi\tbabo mumato yari yuzuye mwo ibintu"
  36,42,Twabaremeye ivyo burira ko bimeze nkivyo bazo kurira ko
  36,43,Nitwa shaka twoshobora kuba somesha nturi kandi ntamufasha azoba arimwo canke uwuzoba rokora
  36,44,Atari kumpuhwe zivuye iwacu hamwe nukuba girira akamaro mukiringo kigufiya
  36,45,"Mugihe babwiwe bati:- nimutinye ibiri imbere yanyu hamwe n’ibiri inyuma yanyu kugira ngo muronke imihezagiro y’Imana"
  36,46,Ntakimenyetso icarico cose kibashikira mubimenyetso vy’Umuremyi wabo atari uko batavyitaho
  36,47,"Mugihe babwiwe bati:- nimutange muvyo Imana yabahaye, bamwe bahakanye Imana yabo y’ukuri baca babwira abemeye Imana yabo y’ukuri bati:- mbega tubarishe ibifungurwa mubo Imana yishakiye wenyene mwebwe ntimurimwo atari mubuzimire buri k’umugaragaro"
  36,48,"Nabo bavuga bati:- iri sango rizoba ryari nimwaba muvugisha ukuri"
  36,49,Ntaco barindira atari ijwi rimwe gusa rizo sokora imitima yabo mugihe bazoba bariko baratongana aba nabariya
  36,50,Kandi ntibazo shobora kuraga muri ico gihe canke ngo bashobore kugaruka ku bantu babo