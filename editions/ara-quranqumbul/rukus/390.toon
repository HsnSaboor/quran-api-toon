quran[44]{c,v,t}:
  37,139,وَإِنَّ يُونُسَ لَمِنَ ٱلۡمُرۡسَلِينَ
  37,140,إِذۡ أَبَقَ إِلَى ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ
  37,141,فَسَاهَمَ فَكَانَ مِنَ ٱلۡمُدۡحَضِينَ
  37,142,فَٱلۡتَقَمَهُ ٱلۡحُوتُ وَهُوَ مُلِيمࣱ‏
  37,143,فَلَوۡلَا أَنَّهُۥ كَانَ مِنَ ٱلۡمُسَبِّحِينَ
  37,144,لَلَبِثَ فِي بَطۡنِهِۦ إِلَىٰ يَوۡمِ يُبۡعَثُونَ
  37,145,۞فَنَبَذۡنَٰهُۥ بِٱلۡعَرَآءِ وَهُوَ سَقِيمࣱ‏
  37,146,وَأَنۢبَتۡنَا عَلَيۡهِۦ شَجَرَةࣰ مِّن يَقۡطِينࣲ‏
  37,147,وَأَرۡسَلۡنَٰهُۥ إِلَىٰ مِاْئَةِ أَلۡفٍ أَوۡ يَزِيدُونَ
  37,148,فَـَٔامَنُواْ فَمَتَّعۡنَٰهُمُۥ إِلَىٰ حِينࣲ‏
  37,149,فَٱسۡتَفۡتِهِمُۥ أَلِرَبِّكَ ٱلۡبَنَاتُ وَلَهُمُ ٱلۡبَنُونَ
  37,150,أَمۡ خَلَقۡنَا ٱلۡمَلَٰٓئِكَةَ إِنَٰثࣰ ا وَهُمُۥ شَٰهِدُونَ
  37,151,أَلَا إِنَّهُمُۥ مِنۡ إِفۡكِهِمُۥ لَيَقُولُونَ
  37,152,وَلَدَ ٱللَّهُ وَإِنَّهُمُۥ لَكَٰذِبُونَ
  37,153,أَصۡطَفَى ٱلۡبَنَاتِ عَلَى ٱلۡبَنِينَ
  37,154,مَا لَكُمُۥ كَيۡفَ تَحۡكُمُونَ
  37,155,أَفَلَا تَذَّكَّرُونَ
  37,156,أَمۡ لَكُمُۥ سُلۡطَٰنࣱ مُّبِينࣱ‏
  37,157,فَأۡتُواْ بِكِتَٰبِكُمُۥ إِن كُنتُمُۥ صَٰدِقِينَ
  37,158,وَجَعَلُواْ بَيۡنَهُۥ وَبَيۡنَ ٱلۡجِنَّةِ نَسَبࣰ اۚ وَلَقَدۡ عَلِمَتِ ٱلۡجِنَّةُ إِنَّهُمُۥ لَمُحۡضَرُونَ
  37,159,سُبۡحَٰنَ ٱللَّهِ عَمَّا يَصِفُونَ
  37,160,إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلِصِينَ
  37,161,فَإِنَّكُمُۥ وَمَا تَعۡبُدُونَ
  37,162,مَا أَنتُمُۥ عَلَيۡهِۦ بِفَٰتِنِينَ
  37,163,إِلَّا مَنۡ هُوَ صَالِ ٱلۡجَحِيمِ
  37,164,وَمَا مِنَّا إِلَّا لَهُۥ مَقَامࣱ مَّعۡلُومࣱ‏
  37,165,وَإِنَّا لَنَحۡنُ ٱلصَّآفُّونَ
  37,166,وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ
  37,167,وَإِن كَانُواْ لَيَقُولُونَ
  37,168,لَوۡ أَنَّ عِندَنَا ذِكۡرࣰ ا مِّنَ ٱلۡأَوَّلِينَ
  37,169,لَكُنَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلِصِينَ
  37,170,فَكَفَرُواْ بِهِۦۖ فَسَوۡفَ يَعۡلَمُونَ
  37,171,وَلَقَدۡ سَبَقَتۡ كَلِمَتُنَا لِعِبَادِنَا ٱلۡمُرۡسَلِينَ
  37,172,إِنَّهُمُۥ لَهُمُ ٱلۡمَنصُورُونَ
  37,173,وَإِنَّ جُندَنَا لَهُمُ ٱلۡغَٰلِبُونَ
  37,174,فَتَوَلَّ عَنۡهُمُۥ حَتَّىٰ حِينࣲ‏
  37,175,وَأَبۡصِرۡهُمُۥ فَسَوۡفَ يُبۡصِرُونَ
  37,176,أَفَبِعَذَابِنَا يَسۡتَعۡجِلُونَ
  37,177,فَإِذَا نَزَلَ بِسَاحَتِهِمُۥ فَسَآءَ صَبَاحُ ٱلۡمُنذَرِينَ
  37,178,وَتَوَلَّ عَنۡهُمُۥ حَتَّىٰ حِينࣲ‏
  37,179,وَأَبۡصِرۡ فَسَوۡفَ يُبۡصِرُونَ
  37,180,سُبۡحَٰنَ رَبِّكَ رَبِّ ٱلۡعِزَّةِ عَمَّا يَصِفُونَ
  37,181,وَسَلَٰمٌ عَلَى ٱلۡمُرۡسَلِينَ
  37,182,وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَٰلَمِينَ