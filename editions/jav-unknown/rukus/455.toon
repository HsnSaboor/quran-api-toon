quran[23]{c,v,t}:
  51,1,Demi angin kang ngumbulake bledhuk kang mabul - mabul
  51,2,Demi mega kang gawa banyu udan
  51,3,Demi perahu kang mlaku ana banyu kelawan gampang
  51,4,Demi Malaikat kang andum rizki lan udan
  51,5,Anggonira padha diprasetyani lan diancam dening Allah mesthi bakal kelakon
  51,6,Pituwase laku hala lan becik mesthi bakal kelakon
  51,7,Demi langit kang ana dalane kanggo mlaku lintang - lintang
  51,8,Anggonira padha bedha - bedha panemu (bab Muhammad lan al-Quran)
  51,9,"Wongkang kena digorohi, hiya sida didohake (saka al-Quran lan Nabi Muhammad)"
  51,10,Wongkang padha goroh mau didohake saka rahmate Allah
  51,11,Wongkang padha kesilep bodho padha lali
  51,12,"Padha takon, \"benjing punapa kalampahanipun Kiamat"
  51,13,Hiya iku dina nalikane (wong kafir) padha disiksa ing neraka
  51,14,"(Lan padha dawuh) iki siksa kang padha sira kesusokake biyen, padha rasakna"
  51,15,Sarupane wongkang bekti ing Allah ana suwarga kang ana bengawane mili
  51,16,"Padha nampani ganjaran paringe Pangeran, dheweke mau sadurunge mlebu suwarga padha nglakoni penggawe becik"
  51,17,Wong Mukmin mau yen bengi anggone turu mung sethithik
  51,18,Lan yen wayah sahur (seprapating wengi kang wekasan) padha nyuwun pangapuraning Allah
  51,19,Bandhane disediakake dadi duweke wong miskin kang jejaluk lan wong melarat
  51,20,Bumi iku panggonan gumelare tondha yekti tumrap wong kang terang susurupane kang mratandani kuasaning Allah
  51,21,Apa sira ora tau deleng kang ana ing awakira
  51,22,Rizkimu lan pituwasing laku kang disediakake marang sira padha ana ing langit
  51,23,"Demi Pangerane bumi lan langit, sabarang kang diprasetiakake marang sira , mesthi, kelakon nyata kaya anggonmu bisa kandha wis tanpa mamang"