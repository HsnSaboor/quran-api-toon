quran[7]{c,v,t}:
  1,1,بِسۡمِ اللّٰهِ الرَّحۡمٰنِ الرَّحِيۡمِ
  1,2,اَلۡحَمۡدُ لِلّٰهِ رَبِّ الۡعٰلَمِيۡنَۙ‏
  1,3,الرَّحۡمٰنِ الرَّحِيۡمِۙ‏
  1,4,مٰلِكِ يَوۡمِ الدِّيۡنِؕ‏
  1,5,اِيَّاكَ نَعۡبُدُ وَاِيَّاكَ نَسۡتَعِيۡنُؕ‏
  1,6,اِهۡدِنَا الصِّرَاطَ الۡمُسۡتَقِيۡمَۙ‏
  1,7,صِرَاطَ الَّذِيۡنَ اَنۡعَمۡتَ عَلَيۡهِمۡ ࣢ۙ غَيۡرِ الۡمَغۡضُوۡبِ عَلَيۡهِمۡ وَلَا الضَّآلِّيۡنَࣖ‏