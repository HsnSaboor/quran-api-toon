quran[78]{c,v,t}:
  55,1,اَلرَّحۡمٰنُۙ‏
  55,2,عَلَّمَ الۡقُرۡاٰنَؕ‏
  55,3,خَلَقَ الۡاِنۡسَانَۙ‏
  55,4,عَلَّمَهُ الۡبَيَانَ
  55,5,اَلشَّمۡسُ وَالۡقَمَرُ بِحُسۡبَانٍۙ‏
  55,6,وَّالنَّجۡمُ وَالشَّجَرُ يَسۡجُدٰنِ
  55,7,وَالسَّمَآءَ رَفَعَهَا وَوَضَعَ الۡمِيۡزَانَۙ‏
  55,8,اَلَّا تَطۡغَوۡا فِي الۡمِيۡزَانِ
  55,9,وَاَقِيۡمُوا الۡوَزۡنَ بِالۡقِسۡطِ وَلَا تُخۡسِرُوا الۡمِيۡزَانَ
  55,10,وَالۡاَرۡضَ وَضَعَهَا لِلۡاَنَامِۙ‏
  55,11,فِيۡهَا فَاكِهَةٌ وَّالنَّخۡلُ ذَاتُ الۡاَكۡمَامِۖ‏
  55,12,وَالۡحَبُّ ذُو الۡعَصۡفِ وَالرَّيۡحَانُۚ‏
  55,13,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,14,خَلَقَ الۡاِنۡسَانَ مِنۡ صَلۡصَالٍ كَالۡفَخَّارِۙ‏
  55,15,وَخَلَقَ الۡجَآنَّ مِنۡ مَّارِجٍ مِّنۡ نَّارٍۚ‏
  55,16,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,17,رَبُّ الۡمَشۡرِقَيۡنِ وَرَبُّ الۡمَغۡرِبَيۡنِۚ‏
  55,18,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,19,مَرَجَ الۡبَحۡرَيۡنِ يَلۡتَقِيٰنِۙ‏
  55,20,بَيۡنَهُمَا بَرۡزَخٌ لَّا يَبۡغِيٰنِۚ‏
  55,21,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,22,يَخۡرُجُ مِنۡهُمَا اللُّؤۡلُؤُ وَالۡمَرۡجَانُۚ‏
  55,23,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,24,وَلَهُ الۡجَوَارِ الۡمُنۡشَاٰتُ فِي الۡبَحۡرِ كَالۡاَعۡلَامِۚ‏
  55,25,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِࣖ‏
  55,26,كُلُّ مَنۡ عَلَيۡهَا فَانٍۚۖ‏
  55,27,وَّيَبۡقٰي وَجۡهُ رَبِّكَ ذُو الۡجَلٰلِ وَالۡاِكۡرَامِۚ‏
  55,28,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,29,يَسۡـَٔلُهٗ مَنۡ فِي السَّمٰوٰتِ وَالۡاَرۡضِؕ كُلَّ يَوۡمٍ هُوَ فِيۡ شَاۡنٍۚ‏
  55,30,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,31,سَنَفۡرُغُ لَكُمۡ اَيُّهَ الثَّقَلٰنِۚ‏
  55,32,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,33,يٰمَعۡشَرَ الۡجِنِّ وَالۡاِنۡسِ اِنِ اسۡتَطَعۡتُمۡ اَنۡ تَنۡفُذُوۡا مِنۡ اَقۡطَارِ السَّمٰوٰتِ وَالۡاَرۡضِ فَانۡفُذُوۡاؕ لَا تَنۡفُذُوۡنَ اِلَّا بِسُلۡطٰنٍۚ‏
  55,34,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,35,يُرۡسَلُ عَلَيۡكُمَا شُوَاظٌ مِّنۡ نَّارٍ ࣢ۙ وَّنُحَاسٌ فَلَا تَنۡتَصِرٰنِۚ‏
  55,36,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,37,فَاِذَا انۡشَقَّتِ السَّمَآءُ فَكَانَتۡ وَرۡدَةً كَالدِّهَانِۚ‏
  55,38,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,39,فَيَوۡمَئِذٍ لَّا يُسۡـَٔلُ عَنۡ ذَنۭۡ بِهٖ٘ اِنۡسٌ وَّلَا جَآنٌّۚ‏
  55,40,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,41,يُعۡرَفُ الۡمُجۡرِمُوۡنَ بِسِيۡمٰهُمۡ فَيُؤۡخَذُ بِالنَّوَاصِيۡ وَالۡاَقۡدَامِۚ‏
  55,42,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,43,هٰذِهٖ جَهَنَّمُ الَّتِيۡ يُكَذِّبُ بِهَا الۡمُجۡرِمُوۡنَۘ‏
  55,44,يَطُوۡفُوۡنَ بَيۡنَهَا وَبَيۡنَ حَمِيۡمٍ اٰنٍۚ‏
  55,45,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِࣖ‏
  55,46,وَلِمَنۡ خَافَ مَقَامَ رَبِّهٖ جَنَّتٰنِۚ‏
  55,47,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۙ‏
  55,48,ذَوَاتَا٘ اَفۡنَانٍۚ‏
  55,49,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,50,فِيۡهِمَا عَيۡنٰنِ تَجۡرِيٰنِۚ‏
  55,51,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,52,فِيۡهِمَا مِنۡ كُلِّ فَاكِهَةٍ زَوۡجٰنِۚ‏
  55,53,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,54,مُتَّكِـِٕيۡنَ عَلٰي فُرُشٍۭ بَطَآئِنُهَا مِنۡ اِسۡتَبۡرَقٍؕ وَجَنَا الۡجَنَّتَيۡنِ دَانٍۚ‏
  55,55,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,56,فِيۡهِنَّ قٰصِرٰتُ الطَّرۡفِۙ لَمۡ يَطۡمِثۡهُنَّ اِنۡسٌ قَبۡلَهُمۡ وَلَا جَآنٌّۚ‏
  55,57,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,58,كَاَنَّهُنَّ الۡيَاقُوۡتُ وَالۡمَرۡجَانُۚ‏
  55,59,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,60,هَلۡ جَزَآءُ الۡاِحۡسَانِ اِلَّا الۡاِحۡسَانُۚ‏
  55,61,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,62,وَمِنۡ دُوۡنِهِمَا جَنَّتٰنِۚ‏
  55,63,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۙ‏
  55,64,مُدۡهَآمَّتٰنِۚ‏
  55,65,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ‏
  55,66,فِيۡهِمَا عَيۡنٰنِ نَضَّاخَتٰنِۚ‏
  55,67,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ‏
  55,68,فِيۡهِمَا فَاكِهَةٌ وَّنَخۡلٌ وَّرُمَّانٌۚ‏
  55,69,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِۚ‏
  55,70,فِيۡهِنَّ خَيۡرٰتٌ حِسَانٌۚ‏
  55,71,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,72,حُوۡرٌ مَّقۡصُوۡرٰتٌ فِي الۡخِيَامِۚ‏
  55,73,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,74,لَمۡ يَطۡمِثۡهُنَّ اِنۡسٌ قَبۡلَهُمۡ وَلَا جَآنٌّۚ‏
  55,75,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,76,مُتَّكِـِٕيۡنَ عَلٰي رَفۡرَفٍ خُضۡرٍ وَّعَبۡقَرِيٍّ حِسَانٍۚ‏
  55,77,فَبِاَيِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ
  55,78,تَبٰرَكَ اسۡمُ رَبِّكَ ذِي الۡجَلٰلِ وَالۡاِكۡرَامِࣖ‏