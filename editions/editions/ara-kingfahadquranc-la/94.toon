quran[8]{c,v,t}:
  94,1,"'alam nwse -ayha alnby- lak sadrak lshraye aldyn, waldaewat 'iilaa allh, walatsaf bmkarm alakhlaq, whttna eank bdhlk himlk aldhy athql zhrk, wjelnak -bma 'aneamna ealayk min almkarm- fi mnzlt rafieat ealy?"
  94,2,"alm nwse -ayha alnby- lak sadrak lshraye aldyn, waldaewat 'iilaa allh, walatsaf bmkarm alakhlaq, whttna eank bdhlk himlk aldhy athql zhrk, wjelnak -bma 'aneamna ealayk min almkarm- fi mnzlt rafieat ealy?"
  94,3,"alm nwse -ayha alnby- lak sadrak lshraye aldyn, waldaewat 'iilaa allh, walatsaf bmkarm alakhlaq, whttna eank bdhlk himlk aldhy athql zhrk, wjelnak -bma 'aneamna ealayk min almkarm- fi mnzlt rafieat ealy?"
  94,4,"alm nwse -ayha alnby- lak sadrak lshraye aldyn, waldaewat 'iilaa allh, walatsaf bmkarm alakhlaq, whttna eank bdhlk himlk aldhy athql zhrk, wjelnak -bma 'aneamna ealayk min almkarm- fi mnzlt rafieat ealy?"
  94,5,"fla ythnk 'adhana aedayk ean nashr alrsalt; fa'iina mae aldyq frjana, 'iina mae aldyq frjana"
  94,6,"fla ythnk 'adhana aedayk ean nashr alrsalt; fa'iina mae aldyq frjana, 'iina mae aldyq frjana"
  94,7,"f'idha faraght min 'umur aldunya washghalha fajidd fi alebadt, wa'iilaa rabik wahdah farghab fima endh"
  94,8,"f'idha faraght min 'umur aldunya washghalha fajidd fi alebadt, wa'iilaa rabik wahdah farghab fima endh"