quran[6]{c,v,t}:
  114,1,"ql -ayha alrrsul-: 'aeudh wa'aetasim birabi alnnas, alqadir wahdah ealaa rdd shari alwaswas"
  114,2,"milik alnaas almutasarif fi kl shuuwnihim, alghny eanhm"
  114,3,'iilh alnaas aldhy la maebud bihaqin suah
  114,4,"min 'adhana alshaytan aladhi yuaswis eind alghuflat, wayakhtafi eind dhakar allh"
  114,5,aldhy ybthth alshara walshukuk fi sudur alnnas
  114,6,min shayatin aljini wal'iins