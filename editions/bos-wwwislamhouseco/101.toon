quran[11]{c,v,t}:
  101,1,Udar zastrašujući
  101,2,Šta je Udar zastrašujući
  101,3,I šta ti znaš šta je Udar zastrašujući
  101,4,Dan taj ljudi će biti kao leptiri raštrkani
  101,5,a planine kao šarena vuna iščupana
  101,6,Onaj čija dobra djela budu teška
  101,7,u ugodnom životu će živjeti
  101,8,a onaj čija dobra djela budu lahka
  101,9,boravište će mu bezdan biti
  101,10,A znaš li ti šta će to biti
  101,11,Vatra užarena