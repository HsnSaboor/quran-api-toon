quran[20]{c,v,t}:
  90,1,"Hayır, Yemin ederim, bu şehre"
  90,2,Sen de bu şehrin insanısın
  90,3,"Anne, baba ve çocuklara"
  90,4,İnsanı dosdoğru/dayanıklı olarak yaratmışızdır
  90,5,Kimsenin kendisine güç yetiremeyeceğini mi sanıyor
  90,6,"Pek çok mal tüketmişimdir, diyor"
  90,7,Kendisini kimsenin görmediğini mi sanıyor
  90,8,Ona iki göz vermedik mi
  90,9,"Bir dil, iki dudak"
  90,10,Ona iki de yol gösterdik
  90,11,O zor geçidi aşamadı
  90,12,Zor geçidin ne olduğunu sana bildiren nedir
  90,13,Köle azat etmektir
  90,14,Veya açlık gününde doyurmaktır
  90,15,Yakınlığı olan bir yetimi
  90,16,Veya sürünen bir düşkünü
  90,17,"Bir de iman edip, sabrı ve merhameti birbirine tavsiye edenlerden olmaktır"
  90,18,İşte sağ tarafın halkı onlardır
  90,19,"Ayetlerimizi inkar edenler, onlar sol taraf halkıdır"
  90,20,Üzerlerinde kapıları kilitlenmiş bir ateş vardır