quran[67]{c,v,t}:
  90,1,"Hayır, Yemin ederim, bu şehre"
  90,2,Sen de bu şehrin insanısın
  90,3,"Anne, baba ve çocuklara"
  90,4,İnsanı dosdoğru/dayanıklı olarak yaratmışızdır
  90,5,Kimsenin kendisine güç yetiremeyeceğini mi sanıyor
  90,6,"Pek çok mal tüketmişimdir, diyor"
  90,7,Kendisini kimsenin görmediğini mi sanıyor
  90,8,Ona iki göz vermedik mi
  90,9,"Bir dil, iki dudak"
  90,10,Ona iki de yol gösterdik
  90,11,O zor geçidi aşamadı
  90,12,Zor geçidin ne olduğunu sana bildiren nedir
  90,13,Köle azat etmektir
  90,14,Veya açlık gününde doyurmaktır
  90,15,Yakınlığı olan bir yetimi
  90,16,Veya sürünen bir düşkünü
  90,17,"Bir de iman edip, sabrı ve merhameti birbirine tavsiye edenlerden olmaktır"
  90,18,İşte sağ tarafın halkı onlardır
  90,19,"Ayetlerimizi inkar edenler, onlar sol taraf halkıdır"
  90,20,Üzerlerinde kapıları kilitlenmiş bir ateş vardır
  91,1,Andolsun Güneş’e ve aydınlığına
  91,2,Onu takip eden Ay’a
  91,3,Onu ortaya koyan gündüze
  91,4,Onu örten geceye
  91,5,Göğe ve onu bina edene
  91,6,Yere ve onu yayana
  91,7,Cana ve onu düzenleyene
  91,8,Sonra da ona kötülüğü ve korunmayı ilham edene
  91,9,Ki onu arındıran kurtuluşa ermiştir
  91,10,Onu kötülüğe gömen ise mahvolmuştur
  91,11,Semud azgınlığı sebebiyle yalanladı
  91,12,En azgınları ileri atılmıştı
  91,13,"Oysa Allah’ın Resûlü, onlara: -Allah’ın devesine ve su hakkına riayet edin! demişti"
  91,14,"O’nu yalanladılar ve deveyi kestiler de Rab’leri suçları sebebiyle onları kırıp geçirdi, yerle bir etti"
  91,15,Bunun sonucundan Allah’ın bir endişesi yoktur
  92,1,Bürüdüğü zaman geceye and olsun
  92,2,Ortaya çıktığı zaman gündüze
  92,3,Erkeği ve dişiyi yaratana
  92,4,Doğrusu sizin çalışmalarınız çeşit çeşittir
  92,5,Kim (malından) verir ve korunursa
  92,6,En güzeli tasdik ederse
  92,7,Biz de ona kolay olması için başarı vereceğiz
  92,8,Kim de cimrilik eder ve kendini ihtiyaçsız görürse
  92,9,En güzeli yalanlarsa
  92,10,Biz de ona zorluğu kolaylaştırırız
  92,11,Baş aşağı düştüğü zaman malı ona bir yarar sağlamaz
  92,12,Doğru yolu göstermek bize düşer
  92,13,Şüphesiz ahiret de dünya da bize aittir
  92,14,"Sizi, alev saçan ateşe karşı uyardım"
  92,15,Ona ancak isyankar olanlar girecektir
  92,16,"Yalanlayan, yüz çeviren"
  92,17,Takva sahibi ondan uzak tutulacaktır
  92,18,Malını veren ve arınan
  92,19,"Hiç kimseden bir karşılık, nimet beklemez"
  92,20,Sadece yüce Rabbi’nin hoşnutluğunu kazanmak için
  92,21,Elbette o da hoşnut olacaktır
  93,1,Andolsun kuşluk vaktine
  93,2,Sükuna erdiği vakit geceye
  93,3,Rabbin seni terk etmedi ve sana darılmadı
  93,4,Gerçekten ahiret/sonuç senin için dünyadan/evvelinden daha hayırlıdır
  93,5,Rabbin sana verecek ve sen de hoşnut olacaksın
  93,6,"Seni yetim bulup, barındırmadı mı"
  93,7,"Seni dalalette bulup, doğru yolu göstermedi mi"
  93,8,"Seni fakir bulup, zengin etmedi mi"
  93,9,Şimdi yetimi hor görme
  93,10,İsteyeni azarlama
  93,11,"Rabbinin nimetini ise, haydi anlat"