quran[10]{c,v,t}:
  75,31,"Tasdik etmemiş, namaz kılmamış"
  75,32,"Fakat, yalanlamış, yüz çevirmiş"
  75,33,Sonra da çalım satarak ailesine gitmişti
  75,34,"Belanı buldun, belanı"
  75,35,Sonra sen buna layıksın
  75,36,İnsan kendisini başı boş bırakacağımızı mı sanar
  75,37,"O, atılan spermden bir damla değil miydi"
  75,38,"Sonra “alaka” olmuş, Allah, onu yaratmış ve düzenlemişti"
  75,39,Ondan erkek ve dişi iki çift yapmıştır
  75,40,Bunu yapanın ölüleri diriltmeye gücü yetmez mi