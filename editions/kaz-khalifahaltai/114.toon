quran[6]{c,v,t}:
  114,1,"(Мұхаммед Ғ.С): «Адамдардың Раббына,»"
  114,2,"«Адамдардың иесіне,»"
  114,3,"«Адамдардың иесіне,»"
  114,4,"«Сыбырлап азғырушының кесірінен,»"
  114,5,«Сондай адамдардың көкейлеріне салатын;»
  114,6,"«Мейлі жыннан,мейлі адамдардан болсын, (бүкіл азғырушылардың кесірінен Аллаға) сиынамын» де"