quran[78]{c,v,t}:
  55,1,ٱلرَّحۡمَٰنُ
  55,2,عَلَّمَ ٱلۡقُرَانَ
  55,3,خَلَقَ ٱلۡإِنسَٰنَ
  55,4,عَلَّمَهُ ٱلۡبَيَانَ
  55,5,ٱلشَّمۡسُ وَٱلۡقَمَرُ بِحُسۡبَانࣲ‏
  55,6,وَٱلنَّجۡمُ وَٱلشَّجَرُ يَسۡجُدَانِ
  55,7,وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلۡمِيزَانَ
  55,8,أَلَّا تَطۡغَوۡاْ فِي ٱلۡمِيزَانِ
  55,9,وَأَقِيمُواْ ٱلۡوَزۡنَ بِٱلۡقِسۡطِ وَلَا تُخۡسِرُواْ ٱلۡمِيزَانَ
  55,10,وَٱلۡأَرۡضَ وَضَعَهَا لِلۡأَنَامِ
  55,11,فِيهَا فَٰكِهَةࣱ وَٱلنَّخۡلُ ذَاتُ ٱلۡأَكۡمَامِ
  55,12,وَٱلۡحَبُّ ذُو ٱلۡعَصۡفِ وَٱلرَّيۡحَانُ
  55,13,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,14,خَلَقَ ٱلۡإِنسَٰنَ مِن صَلۡصَٰلࣲ كَٱلۡفَخَّارِ
  55,15,وَخَلَقَ ٱلۡجَآنَّ مِن مَّارِجࣲ مِّن نَّارࣲ‏
  55,16,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,17,رَبُّ ٱلۡمَشۡرِقَيۡنِ وَرَبُّ ٱلۡمَغۡرِبَيۡنِ
  55,18,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,19,مَرَجَ ٱلۡبَحۡرَيۡنِ يَلۡتَقِيَانِ
  55,20,بَيۡنَهُمَا بَرۡزَخࣱ لَّا يَبۡغِيَانِ
  55,21,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,22,يَخۡرُجُ مِنۡهُمَا ٱللُّؤۡلُؤُ وَٱلۡمَرۡجَانُ
  55,23,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,24,وَلَهُ ٱلۡجَوَارِ ٱلۡمُنشَـَٔاتُ فِي ٱلۡبَحۡرِ كَٱلۡأَعۡلَٰمِ
  55,25,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,26,كُلُّ مَنۡ عَلَيۡهَا فَانࣲ‏
  55,27,وَيَبۡقَىٰ وَجۡهُ رَبِّكَ ذُو ٱلۡجَلَٰلِ وَٱلۡإِكۡرَامِ
  55,28,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,29,يَسۡـَٔلُهُۥ مَن فِي ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۚ كُلَّ يَوۡمٍ هُوَ فِي شَأۡنࣲ‏
  55,30,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,31,سَنَفۡرُغُ لَكُمُۥ أَيُّهَ ٱلثَّقَلَانِ
  55,32,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,33,يَٰمَعۡشَرَ ٱلۡجِنِّ وَٱلۡإِنسِ إِنِ ٱسۡتَطَعۡتُمُۥ أَن تَنفُذُواْ مِنۡ أَقۡطَارِ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ فَٱنفُذُواْۚ لَا تَنفُذُونَ إِلَّا بِسُلۡطَٰنࣲ‏
  55,34,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,35,يُرۡسَلُ عَلَيۡكُمَا شِوَاظࣱ مِّن نَّارࣲ وَنُحَاسࣲ فَلَا تَنتَصِرَانِ
  55,36,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,37,فَإِذَا ٱنشَقَّتِ ٱلسَّمَآءُ فَكَانَتۡ وَرۡدَةࣰ كَٱلدِّهَانِ
  55,38,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,39,فَيَوۡمَئِذࣲ لَّا يُسۡـَٔلُ عَن ذَنۢبِهِۦ إِنسࣱ وَلَا جَآنࣱّ‏
  55,40,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,41,يُعۡرَفُ ٱلۡمُجۡرِمُونَ بِسِيمَٰهُمُۥ فَيُؤۡخَذُ بِٱلنَّوَٰصِي وَٱلۡأَقۡدَامِ
  55,42,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,43,هَٰذِهِۦ جَهَنَّمُ ٱلَّتِي يُكَذِّبُ بِهَا ٱلۡمُجۡرِمُونَ
  55,44,يَطُوفُونَ بَيۡنَهَا وَبَيۡنَ حَمِيمٍ ءَانࣲ‏
  55,45,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,46,وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ
  55,47,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,48,ذَوَاتَا أَفۡنَانࣲ‏
  55,49,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,50,فِيهِمَا عَيۡنَانِ تَجۡرِيَانِ
  55,51,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,52,فِيهِمَا مِن كُلِّ فَٰكِهَةࣲ زَوۡجَانِ
  55,53,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,54,مُتَّكِـِٔينَ عَلَىٰ فُرُشِۭ بَطَآئِنُهَا مِنۡ إِسۡتَبۡرَقࣲۚ وَجَنَى ٱلۡجَنَّتَيۡنِ دَانࣲ‏
  55,55,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,56,فِيهِنَّ قَٰصِرَٰتُ ٱلطَّرۡفِ لَمۡ يَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمُۥ وَلَا جَآنࣱّ‏
  55,57,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,58,كَأَنَّهُنَّ ٱلۡيَاقُوتُ وَٱلۡمَرۡجَانُ
  55,59,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,60,هَلۡ جَزَآءُ ٱلۡإِحۡسَٰنِ إِلَّا ٱلۡإِحۡسَٰنُ
  55,61,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,62,وَمِن دُونِهِمَا جَنَّتَانِ
  55,63,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,64,مُدۡهَآمَّتَانِ
  55,65,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,66,فِيهِمَا عَيۡنَانِ نَضَّاخَتَانِ
  55,67,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,68,فِيهِمَا فَٰكِهَةࣱ وَنَخۡلࣱ وَرُمَّانࣱ‏
  55,69,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,70,فِيهِنَّ خَيۡرَٰتٌ حِسَانࣱ‏
  55,71,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,72,حُورࣱ مَّقۡصُورَٰتࣱ فِي ٱلۡخِيَامِ
  55,73,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,74,لَمۡ يَطۡمِثۡهُنَّ إِنسࣱ قَبۡلَهُمُۥ وَلَا جَآنࣱّ‏
  55,75,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,76,مُتَّكِـِٔينَ عَلَىٰ رَفۡرَفٍ خُضۡرࣲ وَعَبۡقَرِيٍّ حِسَانࣲ‏
  55,77,فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ
  55,78,تَبَٰرَكَ ٱسۡمُ رَبِّكَ ذِي ٱلۡجَلَٰلِ وَٱلۡإِكۡرَامِ