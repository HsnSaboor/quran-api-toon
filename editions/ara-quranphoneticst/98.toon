quran[8]{c,v,t}:
  98,1,Lam Yakuni Al-Ladhīna Kafarū Min 'Ahli Al-Kitābi Wa Al-Mushrikīna Munfakkīna Ĥattá Ta'tiyahumu Al-Bayyinahu
  98,2,Rasūlun Mina Allāhi Yatlū Şuĥufāan Muţahharahan
  98,3,Fīhā Kutubun Qayyimahun
  98,4,Wa Mā Tafarraqa Al-Ladhīna 'Ūtū Al-Kitāba 'Illā Min Ba`di Mā Jā'at/humu Al-Bayyinahu
  98,5,Wa Mā 'Umirū 'Illā Liya`budū Allāha Mukhlişīna Lahu Ad-Dīna Ĥunafā'a Wa Yuqīmū Aş-Şalāata Wa Yu'utū Az-Zakāata Wa Dhalika Dīnu Al-Qayyimahi
  98,6,Inna Al-Ladhīna Kafarū Min 'Ahli Al-Kitābi Wa Al-Mushrikīna Fī Nāri Jahannama Khālidīna Fīhā 'Ūlā'ika Hum Sharru Al-Barīyahi
  98,7,Inna Al-Ladhīna 'Āmanū Wa `Amilū Aş-Şāliĥāti 'Ūlā'ika Hum Khayru Al-Barīyahi
  98,8,Jazā'uuhum `Inda Rabbihim Jannātu `Adnin Tajrī Min Taĥtihā Al-'Anhāru Khālidīna Fīhā 'Abadāan Rađiya Allāhu `Anhum Wa Rađū `Anhu Dhālika Liman Khashiya Rabbahu