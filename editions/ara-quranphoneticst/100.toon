quran[11]{c,v,t}:
  100,1,Wa Al-`Ādiyāti Đabĥāan
  100,2,Fālmūriyāti Qadĥāan
  100,3,Fālmughīrāti Şubĥāan
  100,4,Fa'atharna Bihi Naq`āan
  100,5,Fawasaţna Bihi Jam`āan
  100,6,Inna Al-'Insāna Lirabbihi Lakanūdun
  100,7,Wa 'Innahu `Alá Dhālika Lashahīdun
  100,8,Wa 'Innahu Liĥubbi Al-Khayri Lashadīdun
  100,9,Afalā Ya`lamu 'Idhā Bu`thira Mā Fī Al-Qubūri
  100,10,Wa Ĥuşşila Mā Fī Aş-Şudūri
  100,11,Inna Rabbahum Bihim Yawma'idhin Lakhabīrun