quran[10]{c,v,t}:
  77,41,Inna Al-Muttaqīna Fī Žilālin Wa `Uyūnin
  77,42,Wa Fawākiha Mimmā Yashtahūna
  77,43,Kulū Wa Ashrabū Hanī'āan Bimā Kuntum Ta`malūna
  77,44,Innā Kadhālika Najzī Al-Muĥsinyna
  77,45,Waylun Yawma'idhin Lilmukadhibīna
  77,46,Kulū Wa Tamatta`ū Qalīlāan 'Innakum Mujrimūna
  77,47,Waylun Yawma'idhin Lilmukadhibīna
  77,48,Wa 'Idhā Qīla Lahumu Arka`ū Lā Yarka`ūna
  77,49,Waylun Yawma'idhin Lilmukadhibīna
  77,50,Fabi'ayyi Ĥadīthin Ba`dahu Yu'uminūna