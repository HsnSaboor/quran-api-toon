quran[8]{c,v,t}:
  102,1,Alhākumu At-Takāthuru
  102,2,Ĥattá Zurtumu Al-Maqābira
  102,3,Kallā Sawfa Ta`lamūna
  102,4,Thumma Kallā Sawfa Ta`lamūna
  102,5,Kallā Law Ta`lamūna `Ilma Al-Yaqīni
  102,6,Latarawunna Al-Jaĥīma
  102,7,Thumma Latarawunnahā `Ayna Al-Yaqīni
  102,8,Thumma Latus'alunna Yawma'idhin `Ani An-Na`īmi