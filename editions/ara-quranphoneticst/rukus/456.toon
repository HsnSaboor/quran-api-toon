quran[23]{c,v,t}:
  51,24,Hal 'Atāka Ĥadīthu Đayfi 'Ibrāhīma Al-Mukramīna
  51,25,Idh Dakhalū `Alayhi Faqālū Salāmāan Qāla Salāmun Qawmun Munkarūna
  51,26,Farāgha 'Ilá 'Ahlihi Fajā'a Bi`ijlin Samīnin
  51,27,Faqarrabahu 'Ilayhim Qāla 'Alā Ta'kulūna
  51,28,Fa'awjasa Minhum Khīfatan Qālū Lā Takhaf Wa Basharūhu Bighulāmin `Alīmin
  51,29,Fa'aqbalati Amra'atuhu Fī Şarratin Faşakkat Wajhahā Wa Qālat `Ajūzun `Aqīmun
  51,30,Qālū Kadhāliki Qāla Rabbuki 'Innahu Huwa Al-Ĥakīmu Al-`Alīmu
  51,31,Qāla Famā Khaţbukum 'Ayyuhā Al-Mursalūna
  51,32,Qālū 'Innā 'Ursilnā 'Ilá Qawmin Mujrimīna
  51,33,Linursila `Alayhim Ĥijāratan Min Ţīnin
  51,34,Musawwamatan `Inda Rabbika Lilmusrifīna
  51,35,Fa'akhrajnā Man Kāna Fīhā Mina Al-Mu'uminīna
  51,36,Famā Wajadnā Fīhā Ghayra Baytin Mina Al-Muslimīna
  51,37,Wa Taraknā Fīhā 'Āyatan Lilladhīna Yakhāfūna Al-`Adhāba Al-'Alīma
  51,38,Wa Fī Mūsá 'Idh 'Arsalnāhu 'Ilá Fir`awna Bisulţānin Mubīnin
  51,39,Fatawallá Biruknihi Wa Qāla Sāĥirun 'Aw Majnūnun
  51,40,Fa'akhadhnāhu Wa Junūdahu Fanabadhnāhum Fī Al-Yammi Wa Huwa Mulīmun
  51,41,Wa Fī `Ādin 'Idh 'Arsalnā `Alayhimu Ar-Rīĥa Al-`Aqīma
  51,42,Mā Tadharu Min Shay'in 'Atat `Alayhi 'Illā Ja`alat/hu Kālrramīmi
  51,43,Wa Fī Thamūda 'Idh Qīla Lahum Tamatta`ū Ĥattá Ĥīnin
  51,44,Fa`ataw `An 'Amri Rabbihim Fa'akhadhat/humu Aş-Şā`iqatu Wa Hum Yanžurūna
  51,45,Famā Astaţā`ū Min Qiyāmin Wa Mā Kānū Muntaşirīna
  51,46,Wa Qawma Nūĥin Min Qablu 'Innahum Kānū Qawmāan Fāsiqīna