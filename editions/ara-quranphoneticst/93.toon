quran[11]{c,v,t}:
  93,1,Wa Ađ-Đuĥá
  93,2,Wa Al-Layli 'Idhā Sajá
  93,3,Mā Wadda`aka Rabbuka Wa Mā Qalá
  93,4,Wa Lal'ākhiratu Khayrun Laka Mina Al-'Ūlá
  93,5,Wa Lasawfa Yu`ţīka Rabbuka Fatarđá
  93,6,Alam Yajidka Yatīmāan Fa'āwá
  93,7,Wa Wajadaka Đāllāan Fahadá
  93,8,Wa Wajadaka `Ā'ilāan Fa'aghná
  93,9,Fa'ammā Al-Yatīma Falā Taqhar
  93,10,Wa 'Ammā As-Sā'ila Falā Tanhar
  93,11,Wa 'Ammā Bini`mati Rabbika Faĥaddith