quran[23]{c,v,t}:
  26,184,Wa Attaqū Al-Ladhī Khalaqakum Wa Al-Jibillata Al-'Awwalīna
  26,185,Qālū 'Innamā 'Anta Mina Al-Musaĥĥarīna
  26,186,Wa Mā 'Anta 'Illā Basharun Mithlunā Wa 'In Nažunnuka Lamina Al-Kādhibīna
  26,187,Fa'asqiţ `Alaynā Kisafāan Mina As-Samā'i 'In Kunta Mina Aş-Şādiqīna
  26,188,Qāla Rabbī 'A`lamu Bimā Ta`malūna
  26,189,Fakadhabūhu Fa'akhadhahum `Adhābu Yawmi Až-Žullati 'Innahu Kāna `Adhāba Yawmin `Ažīmin
  26,190,Inna Fī Dhālika La'āyatan Wa Mā Kāna 'Aktharuhum Mu'uminīna
  26,191,Wa 'Inna Rabbaka Lahuwa Al-`Azīzu Ar-Raĥīmu
  26,192,Wa 'Innahu Latanzīlu Rabbi Al-`Ālamīna
  26,193,Nazala Bihi Ar-Rūĥu Al-'Amīnu
  26,194,Alá Qalbika Litakūna Mina Al-Mundhirīna
  26,195,Bilisānin `Arabīyin Mubīnin
  26,196,Wa 'Innahu Lafī Zuburi Al-'Awwalīna
  26,197,Awalam Yakun Lahum 'Āyatan 'An Ya`lamahu `Ulamā'u Banī 'Isrā'īla
  26,198,Wa Law Nazzalnāhu `Alá Ba`đi Al-'A`jamīna
  26,199,Faqara'ahu `Alayhim Mā Kānū Bihi Mu'uminīna
  26,200,Kadhālika Salaknāhu Fī Qulūbi Al-Mujrimīna
  26,201,Lā Yu'uminūna Bihi Ĥattá Yaraw Al-`Adhāba Al-'Alīma
  26,202,Faya'tiyahum Baghtatan Wa Hum Lā Yash`urūna
  26,203,Fayaqūlū Hal Naĥnu Munžarūna
  26,204,Afabi`adhābinā Yasta`jilūna
  26,205,Afara'ayta 'In Matta`nāhum Sinīna
  26,206,Thumma Jā'ahum Mā Kānū Yū`adūna