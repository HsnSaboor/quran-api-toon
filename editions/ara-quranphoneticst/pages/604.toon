quran[15]{c,v,t}:
  112,1,Qul Huwa Allāhu 'Aĥadun
  112,2,Allāhu Aş-Şamadu
  112,3,Lam Yalid Wa Lam Yūlad
  112,4,Walam Yakun Lahu Kufūan 'Aĥadun
  113,1,Qul 'A`ūdhu Birabbi Al-Falaqi
  113,2,Min Sharri Mā Khalaqa
  113,3,Wa Min Sharri Ghāsiqin 'Idhā Waqaba
  113,4,Wa Min Sharri An-Naffāthāti Fī Al-`Uqadi
  113,5,Wa Min Sharri Ĥāsidin 'Idhā Ĥasada
  114,1,Qul 'A`ūdhu Birabbi An-Nāsi
  114,2,Maliki An-Nāsi
  114,3,Ilahi An-Nāsi
  114,4,Min Sharri Al-Waswāsi Al-Khannāsi
  114,5,Al-Ladhī Yuwaswisu Fī Şudūri An-Nāsi
  114,6,Mina Al-Jinnati Wa An-Nāsi