quran[14]{c,v,t}:
  106,1,Li'īlāfi Qurayshin
  106,2,Īlāfihim Riĥlata Ash-Shitā'i Wa Aş-Şayfi
  106,3,Falya`budū Rabba Hādhā Al-Bayti
  106,4,Al-Ladhī 'Aţ`amahum Min Jū`in Wa 'Āmanahum Min Khawfin
  107,1,Ara'ayta Al-Ladhī Yukadhibu Bid-Dīni
  107,2,Fadhālika Al-Ladhī Yadu``u Al-Yatīma
  107,3,Wa Lā Yaĥuđđu `Alá Ţa`āmi Al-Miskīni
  107,4,Fawaylun Lilmuşallīna
  107,5,Al-Ladhīna Hum `An Şalātihim Sāhūna
  107,6,Al-Ladhīna Hum Yurā'ūna
  107,7,Wa Yamna`ūna Al-Mā`ūna
  108,1,Innā 'A`ţaynāka Al-Kawthara
  108,2,Faşalli Lirabbika Wa Anĥar
  108,3,Inna Shāni'aka Huwa Al-'Abtaru