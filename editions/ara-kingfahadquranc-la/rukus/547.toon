quran[5]{c,v,t}:
  105,1,"alm taelam -ayha alrswl- kayf faeal rabuk bi'ashab alfyl: abrht alhbshy wjyshh aladhin 'araduu tadmir alkaebat almbark?"
  105,2,alm yajeal ma dbbarwh min shari fi 'ibtal wtdyye?
  105,3,"wbeth ealayhim tyrana fi jamaeat mttabet, tqdhfhm bihijarat min tin mthjjir"
  105,4,"wbeth ealayhim tyrana fi jamaeat mttabet, tqdhfhm bihijarat min tin mthjjir"
  105,5,fjelhm bih mhtmyn kawraq alzare alyabisat alty akltha albhaym thuma rmt bha