quran[38]{c,v,t}:
  56,1,"'idha qamat alqyamt, lays lqyamha ahd ykdhdhib bh, hi khafidat laeda' allah fi alnar, raafieat lawlyayh fi aljnt"
  56,2,"'idha qamat alqyamt, lays lqyamha ahd ykdhdhib bh, hi khafidat laeda' allah fi alnar, raafieat lawlyayh fi aljnt"
  56,3,"'iidha qamat alqyamt, lays lqyamha ahd ykdhdhib bh, hi khafidat laeda' allah fi alnar, raafieat lawlyayh fi aljnt"
  56,4,"'idha hurrikt al'ard thrykana shdydana, wfuttitt aljibal tftytana dqyqana, fsart ghbarana mttayrana fi aljawi qad dharath alryh"
  56,5,"'idha hurrikt al'ard thrykana shdydana, wfuttitt aljibal tftytana dqyqana, fsart ghbarana mttayrana fi aljawi qad dharath alryh"
  56,6,"'idha hurrikt al'ard thrykana shdydana, wfuttitt aljibal tftytana dqyqana, fsart ghbarana mttayrana fi aljawi qad dharath alryh"
  56,7,wkntm- 'ayuha alkhlq- asnafana thlatht
  56,8,"fashab alymyn, 'ahl almnzlt alealyt, ma 'aezam mkanthm!! wa'ashab alshmal, 'ahl almnzlt aldnyyt, ma 'aswa halhm"
  56,9,"fashab alymyn, 'ahl almnzlt alealyt, ma 'aezam mkanthm!! wa'ashab alshmal, 'ahl almnzlt aldnyyt, ma 'aswa halhm"
  56,10,"walsabqwn 'iilaa alkhayrat fi aldunya hum alsaabiqun 'iilaa aldarajat fi alakhrt, 'uwlayik hum almuqarabun eind allh, yudkhlhm rabihim fi janaat alneym"
  56,11,"walsabqwn 'iilaa alkhayrat fi aldunya hum alsaabiqun 'iilaa aldarajat fi alakhrt, 'uwlayik hum almuqarabun eind allh, yudkhlhm rabihim fi janaat alneym"
  56,12,"walsabqwn 'iilaa alkhayrat fi aldunya hum alsaabiqun 'iilaa aldarajat fi alakhrt, 'uwlayik hum almuqarabun eind allh, yudkhlhm rabihim fi janaat alneym"
  56,13,"ydkhlha jamaeat kathirat min sadar hadhih alamt, wghyrhm min al'umam alakhra, waqalil min akhar hadhih al'umat ealaa surur mnswjt baldhhb, mutakiiyn ealayha yqabl bedhm bedana"
  56,14,"ydkhlha jamaeat kathirat min sadar hadhih alamt, wghyrhm min al'umam alakhra, waqalil min akhar hadhih al'umat ealaa surur mnswjt baldhhb, mutakiiyn ealayha yqabl bedhm bedana"
