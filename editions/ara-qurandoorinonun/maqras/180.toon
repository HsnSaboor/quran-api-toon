quran[62]{c,v,t}:
  37,83,۞وَإِنَّ مِن شِيعَتِهِۦ لَإِبۡرَٰهِيمَ
  37,84,إِذ جَّآءَ رَبَّهُۥ بِقَلۡبٖ سَلِيمٍ
  37,85,إِذۡ قَالَ لِأَبِيهِ وَقَوۡمِهِۦ مَاذَا تَعۡبُدُونَ
  37,86,أَٰى۪فۡكًا ءَالِهَةٗ دُونَ اَ۬للَّهِ تُرِيدُونَ
  37,87,فَمَا ظَنُّكُم بِرَبِّ اِ۬لۡعَٰلَمِينَ
  37,88,فَنَظَرَ نَظۡرَةٗ فِي اِ۬لنُّجُومِ
  37,89,فَقَالَ إِنِّي سَقِيمٞ
  37,90,فَتَوَلَّوۡاْ عَنۡهُ مُدۡبِرِينَ
  37,91,فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمۡ فَقَالَ أَلَا تَأۡكُلُونَ
  37,92,مَا لَكُمۡ لَا تَنطِقُونَ
  37,93,فَرَاغَ عَلَيۡهِمۡ ضَرۡبَۢا بِالۡيَمِينِ
  37,94,فَأَقۡبَلُوٓاْ إِلَيۡهِ يَزِفُّونَ
  37,95,قَالَ أَتَعۡبُدُونَ مَا تَنۡحِتُونَ
  37,96,وَاَللَّهُ خَلَقَكُمۡ وَمَا تَعۡمَلُونَ
  37,97,قَالُواْ اُ۪بۡنُواْ لَهُۥ بُنۡيَٰنٗا فَأَلۡقُوهُ فِي اِ۬لۡجَحِيمِ
  37,98,فَأَرَادُواْ بِهِۦ كَيۡدٗا فَجَعَلۡنَٰهُمُ اُ۬لۡأَسۡفَلِينَ
  37,99,وَقَالَ إِنِّي ذَاهِبٌ إِلَىٰ رَبِّي سَيَهۡدِينِ
  37,100,رَبِّ هَبۡ لِي مِنَ اَ۬لصَّٰلِحِينَ
  37,101,فَبَشَّرۡنَٰهُ بِغُلَٰمٍ حَلِيمٖ
  37,102,فَلَمَّا بَلَغَ مَعَهُ اُ۬لسَّعۡيَ قَالَ يَٰبُنَيِّ إِنِّيَ أَر۪يٰ فِي اِ۬لۡمَنَامِ أَنِّيَ أَذۡبَحُكَ فَاَنظُرۡ مَاذَا تَر۪يٰۚ قَالَ يَٰٓأَبَتِ اِ۪فۡعَلۡ مَا تُؤۡمَرُۖ سَتَجِدُنِيٓ إِن شَآءَ اَ۬للَّهُ مِنَ اَ۬لصَّٰبِرِينَ
  37,103,فَلَمَّآ أَسۡلَمَا وَتَلَّهُۥ لِلۡجَبِينِ
  37,104,وَنَٰدَيۡنَٰهُ أَن يَٰٓإِبۡرَٰهِيمُ
  37,105,قَد صَّدَّقۡتَ اَ۬لرُّءۡيۭآۚ إِنَّا كَذَٰلِكَ نَجۡزِي اِ۬لۡمُحۡسِنِينَ
  37,106,إِنَّ هَٰذَا لَهۡوَ اَ۬لۡبَلَٰٓؤُاْ اُ۬لۡمُبِينُ
  37,107,وَفَدَيۡنَٰهُ بِذِبۡحٍ عَظِيمٖ
  37,108,وَتَرَكۡنَا عَلَيۡهِ فِي اِ۬لۡأٓخِرِينَ
  37,109,سَلَٰمٌ عَلَىٰٓ إِبۡرَٰهِيمَ
  37,110,كَذَٰلِكَ نَجۡزِي اِ۬لۡمُحۡسِنِينَ
  37,111,إِنَّهُۥ مِنۡ عِبَادِنَا اَ۬لۡمُؤۡمِنِينَ
  37,112,وَبَشَّرۡنَٰهُ بِإِسۡحَٰقَ نَبِيّٗا مِّنَ اَ۬لصَّٰلِحِينَ
  37,113,وَبَٰرَكۡنَا عَلَيۡهِ وَعَلَىٰٓ إِسۡحَٰقَۚ وَمِن ذُرِّيَّتِهِمَا مُحۡسِنٞ وَظَالِمٞ لِّنَفۡسِهِۦ مُبِينٞ
  37,114,۞وَلَقَدۡ مَنَنَّا عَلَىٰ مُوسۭيٰ وَهَٰرُونَ
  37,115,وَنَجَّيۡنَٰهُمَا وَقَوۡمَهُمَا مِنَ اَ۬لۡكَرۡبِ اِ۬لۡعَظِيمِ
  37,116,وَنَصَرۡنَٰهُمۡ فَكَانُواْ هُمُ اُ۬لۡغَٰلِبِينَ
  37,117,وَءَاتَيۡنَٰهُمَا اَ۬لۡكِتَٰبَ اَ۬لۡمُسۡتَبِينَ
  37,118,وَهَدَيۡنَٰهُمَا اَ۬لصِّرَٰطَ اَ۬لۡمُسۡتَقِيمَ
  37,119,وَتَرَكۡنَا عَلَيۡهِمَا فِي اِ۬لۡأٓخِرِينَ
  37,120,سَلَٰمٌ عَلَىٰ مُوسۭيٰ وَهَٰرُونَ
  37,121,إِنَّا كَذَٰلِكَ نَجۡزِي اِ۬لۡمُحۡسِنِينَ
  37,122,إِنَّهُمَا مِنۡ عِبَادِنَا اَ۬لۡمُؤۡمِنِينَ
  37,123,وَإِنَّ إِلۡيَاسَ لَمِنَ اَ۬لۡمُرۡسَلِينَ
  37,124,إِذۡ قَالَ لِقَوۡمِهِۦٓ أَلَا تَتَّقُونَ
  37,125,أَتَدۡعُونَ بَعۡلٗا وَتَذَرُونَ أَحۡسَنَ اَ۬لۡخَٰلِقِينَ
  37,126,اَ۬للَّهُ رَبُّكُمۡ وَرَبُّ ءَابَآئِكُمُ اُ۬لۡأَوَّلِينَ
  37,127,فَكَذَّبُوهُ فَإِنَّهُمۡ لَمُحۡضَرُونَ
  37,128,إِلَّا عِبَادَ اَ۬للَّهِ اِ۬لۡمُخۡلِصِينَ
  37,129,وَتَرَكۡنَا عَلَيۡهِ فِي اِ۬لۡأٓخِرِينَ
  37,130,سَلَٰمٌ عَلَىٰٓ إِلۡ يَاسِينَ
  37,131,إِنَّا كَذَٰلِكَ نَجۡزِي اِ۬لۡمُحۡسِنِينَ
  37,132,إِنَّهُۥ مِنۡ عِبَادِنَا اَ۬لۡمُؤۡمِنِينَ
  37,133,وَإِنَّ لُوطٗا لَّمِنَ اَ۬لۡمُرۡسَلِينَ
  37,134,إِذۡ نَجَّيۡنَٰهُ وَأَهۡلَهُۥٓ أَجۡمَعِينَ
  37,135,إِلَّا عَجُوزٗا فِي اِ۬لۡغَٰبِرِينَ
  37,136,ثُمَّ دَمَّرۡنَا اَ۬لۡأٓخَرِينَ
  37,137,وَإِنَّكُمۡ لَتَمُرُّونَ عَلَيۡهِم مُّصۡبِحِينَ
  37,138,وَبِالَّيۡلِۗ أَفَلَا تَعۡقِلُونَ
  37,139,وَإِنَّ يُونُسَ لَمِنَ اَ۬لۡمُرۡسَلِينَ
  37,140,إِذۡ أَبَقَ إِلَى اَ۬لۡفُلۡكِ اِ۬لۡمَشۡحُونِ
  37,141,فَسَاهَمَ فَكَانَ مِنَ اَ۬لۡمُدۡحَضِينَ
  37,142,فَاَلۡتَقَمَهُ اُ۬لۡحُوتُ وَهۡوَ مُلِيمٞ
  37,143,فَلَوۡلَآ أَنَّهُۥ كَانَ مِنَ اَ۬لۡمُسَبِّحِينَ
  37,144,لَلَبِثَ فِي بَطۡنِهِۦٓ إِلَىٰ يَوۡمِ يُبۡعَثُونَ