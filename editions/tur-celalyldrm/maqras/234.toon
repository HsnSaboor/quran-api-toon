quran[71]{c,v,t}:
  80,1,Kendisine o iki gözü kör geldi diye yüzünü ekşitip çevirdi
  80,2,Kendisine o iki gözü kör geldi diye yüzünü ekşitip çevirdi
  80,3,"Ne bilirsin, belki o temizlenecek veya öğüt alacaktı da o öğüt ona fayda verecekti"
  80,4,"Ne bilirsin, belki o temizlenecek veya öğüt alacaktı da o öğüt ona fayda verecekti"
  80,5,"Ama öğüt almaya ihtiyaç duymayanı ise, sen ona yönelip ilgi duyuyorsun"
  80,6,"Ama öğüt almaya ihtiyaç duymayanı ise, sen ona yönelip ilgi duyuyorsun"
  80,7,Onun arınmamasından sana ne
  80,8,(Allah´tan) saygı ile korkarak koşup gelenle ilgilenmeyip kendisinden habersiz (gibi) görünüyorsun
  80,9,(Allah´tan) saygı ile korkarak koşup gelenle ilgilenmeyip kendisinden habersiz (gibi) görünüyorsun
  80,10,(Allah´tan) saygı ile korkarak koşup gelenle ilgilenmeyip kendisinden habersiz (gibi) görünüyorsun
  80,11,"Hayır, hayır; O (Kur´ân) elbette bir öğüttür"
  80,12,Arzu eden Onu hatırlayıp öğüt alır
  80,13,"O, saygı duyulan şerefli tertemiz yüce sahifelerdedir"
  80,14,"O, saygı duyulan şerefli tertemiz yüce sahifelerdedir"
  80,15,İyilik timsâli saygıdeğer kâtiplerin elleriyle (yazılmıştır)
  80,16,İyilik timsâli saygıdeğer kâtiplerin elleriyle (yazılmıştır)
  80,17,Kahrolası (inkarcı azgın) insan ne de nankördür
  80,18,Allah onu hangi şeyden yaratmıştır
  80,19,Nutfe (sperma)dan yaratmış da (en güzel biçimde) takdîr etmiştir
  80,20,"Sonra da (yaşayıp geçinme, anlayıp inanma) yolunu ona kolaylaştırmıştır"
  80,21,Sonra onu öldürüp kabre koymuştur
  80,22,Sonra dilediği zaman onu diriltip kaldırır
  80,23,"Hayır, hayır; insan, Allah´ın buyruğunu (lâyıkıyla) yerine getirmemiştir"
  80,24,"Bir de insan, yiyeceğine bir baksın"
  80,25,"Şüphesiz ki biz suyu döker de dökeriz, (İhtiyaç nisbetinde yağmur yağdırırız)"
  80,26,Sonra yeryüzünü (kabartıp) yarık yarık yaparız
  80,27,"Orada dâne, üzüm, yonca, zeytin, hurma, sık ve büyük ağaçlı bahçeler, meyveler ve çayırlar bitiririz"
  80,28,"Orada dâne, üzüm, yonca, zeytin, hurma, sık ve büyük ağaçlı bahçeler, meyveler ve çayırlar bitiririz"
  80,29,"Orada dâne, üzüm, yonca, zeytin, hurma, sık ve büyük ağaçlı bahçeler, meyveler ve çayırlar bitiririz"
  80,30,"Orada dâne, üzüm, yonca, zeytin, hurma, sık ve büyük ağaçlı bahçeler, meyveler ve çayırlar bitiririz"
  80,31,"Orada dâne, üzüm, yonca, zeytin, hurma, sık ve büyük ağaçlı bahçeler, meyveler ve çayırlar bitiririz"
  80,32,Size ve davarlarınıza yararlı geçimlik olsun diye (bunları lütfederiz)
  80,33,Kulakları sağırlaştıracak o Kıyamet gürültüsü geldiğinde
  80,34,O gün kişi kardeşinden
  80,35,"Anasından, babasından, eşinden ve oğullarından kaçar"
  80,36,"Anasından, babasından, eşinden ve oğullarından kaçar"
  80,37,Onlardan her kişinin (o gün) kendine yetecek derdi ve meşguliyeti vardır
  80,38,Yüzler var ki o gün ışıl ışıl ışıldar
  80,39,Güler ve müjde sevincini duyar
  80,40,Yüzler de var ki o gün üzerleri tozludur; o tozu da bir karanlık sarar
  80,41,Yüzler de var ki o gün üzerleri tozludur; o tozu da bir karanlık sarar
  80,42,"İşte bunlar kâfirler ve tacirler (Allah´ı inkâr edenler, günah işleyip haklara tecâvüz edenler)dir"
  81,1,Güneş kararıp dürüldüğünde
  81,2,Yıldızlar parçalanıp döküldüğünde
  81,3,Dağlar yerinden oynatılıp yürütüldüğünde
  81,4,Gebe olan develer (kendi haline) bırakıldığında
  81,5,Vahşi hayvanlar (korkudan) biraraya toplandığında
  81,6,Denizler birbirine karışıp kaynaştığında (veya ateş haline geldiğinde)
  81,7,"Ruhlar bedenlerle; iyiler iyilerle, kötüler kötülerle birleştiğinde"
  81,8,"Diri diri gömülen veya gömülmeden öldürülüp öylece gömülen kız çocuğuna, hangi suçtan dolayı öldürüldüğü sorulduğunda"
  81,9,"Diri diri gömülen veya gömülmeden öldürülüp öylece gömülen kız çocuğuna, hangi suçtan dolayı öldürüldüğü sorulduğunda"
  81,10,(Amel) sahifeleri açıldığında
  81,11,Gök(teki cisimler) yörüngesinden kaydırılıp dürüldüğünde
  81,12,Cehennem iyice alev alev kızıştırdığında
  81,13,Cennet (mü´minlere) yaklaştırıldığında
  81,14,Herkes neler hazırladığını bilip anlayacak
  81,15,Yemin ederim o (gündüzleyin) sinip gizlenen (yıldız)lara
  81,16,(Geceleyin) ortaya çıkıp gözükenlere
  81,17,Karanlığa gömülen geceye
  81,18,Teneffüs eden (ağarıp nefes nafes belirginleşen) sabaha ki
  81,19,"Muhakkak o (Kur´ân), yüce şerefli, Arş´ın sahibi yanında güçlü ve kudretli bir elçinin sözüdür"
  81,20,"Muhakkak o (Kur´ân), yüce şerefli, Arş´ın sahibi yanında güçlü ve kudretli bir elçinin sözüdür"
  81,21,"O elçi kendisine uyulandır, güvenilirdir"
  81,22,Arkadaşınız (Muhammed) deli ve dengesiz değildir
  81,23,"And olsun ki. O, onu (Muhammed, Melek Cebrail´i) açık ufukta gördü"
  81,24,O (Muhammed) gaybe karşı suç zanlısı veya cimri de değildir
  81,25,Bu (Kur´ân) ilâhî rahmetten kovulmuş bir şeytanın sözü değildir
  81,26,O halde nereye gidiyorsunuz
  81,27,"O, âlemler için ve sizden doğru davranmayı arzu edenler için katıksız bir öğüttür"
  81,28,"O, âlemler için ve sizden doğru davranmayı arzu edenler için katıksız bir öğüttür"
  81,29,Âlemlerin Rabbi Allah dilemedikçe siz dileyemezsiniz