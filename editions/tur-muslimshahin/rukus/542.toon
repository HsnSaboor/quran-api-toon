quran[11]{c,v,t}:
  100,1,"Harıl harıl koşanlara, yemin ederim ki"
  100,2,(nallarıyla) çakarak kıvılcım saçanlara yemin ederim ki
  100,3,"(ansızın) sabah baskını yapanlara, yemin ederim ki"
  100,4,"orada tozu dumana katanlara, yemin ederim ki"
  100,5,derken orada bir topluluğun ta ortasına girenlere yemin ederim ki
  100,6,"insan, Rabbine karşı pek nankördür"
  100,7,Şüphesiz buna kendisi de şahittir
  100,8,"ve o, mal sevgisine de aşırı derecede düşkündür"
  100,9,"(İnsan) düşünmez mi ki, kabirlerde bulunanlar diriltilip dışarı atıldığı zaman"
  100,10,Ve kalplerde gizlenenler ortaya konduğu zaman (hali ne olacak)
  100,11,Şüphesiz Rableri o gün onlardan tamamıyla haberdardır