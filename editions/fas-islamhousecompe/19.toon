quran[98]{c,v,t}:
  19,1,"کهیعص [= کاف. ها. یا. عین. صاد]"
  19,2,"[این] بیان رحمت پروردگارت [نسبت] به بنده‌اش زکریاست"
  19,3,"آنگاه که پروردگارش را به ندایی پنهان [به دعا] خواند"
  19,4,"گفت: «پروردگارا، به راستی که استخوانم سست شده و [موی] سرم از پیری سپید گشته و ای پروردگارم، [هرگز] در دعای تو [از اجابت] بی‌بهره نبوده‌ام"
  19,5,"و من پس از [مرگ] خود از خویشاوندانم [نسبت به حفظِ دین تو] بیمناکم و همسرم [نیز] نازاست؛ پس به لطف خویش [فرزندی به عنوان وارث و] یاور به من عطا فرما"
  19,6,"[پسری که] وارث من و وارث خاندانِ یعقوب باشد؛ و پروردگارا، او را [در علم و دین، انسانی] پسندیده گردان»"
  19,7,"[الله دعایش را اجابت کرد و فرمود:] «ای زکریا، ما تو را به [تولدِ] پسری بشارت می‌دهیم که نامش یحیی است [و] پیش از این، همنامی برایش قرار نداده‌ایم»"
  19,8,"[زکریا] گفت: «پروردگارا، چگونه پسری خواهم داشت در حالی ‌که همسرم نازاست و من [نیز] از شدت پیری، به ناتوانی رسیده‌ام؟»"
  19,9,"[فرشته] گفت: «این گونه است [که تو می‌گویی؛ ولی] پروردگارت فرموده است: \"این [امر،] برای من آسان است و به راستی پیش از این [نیز] تو را آفریدم، در حالی ‌که چیزی نبودی\"»"
  19,10,"[زکریا] گفت: «پروردگارا، نشانه‌ای [بر تحققِ این بشارت] برایم قرار بده». [الله] فرمود: «نشانۀ تو این است که سه شبانه [روز] در حالی‌ که سالم [و تندرست] هستی، با مردم سخن نمی‌گویی»"
  19,11,"او از محراب [= جایگاه عبادتش] به سوی قومش رفت و به آنان اشاره کرد که: «بامداد و شامگاه، [پروردگار را] به پاکی یاد کنید»"
  19,12,"[الله فرمود:] «ای یحیی، کتاب [تورات] را با قوّت [و جدیت] بگیر» و در کودکی به او دانش [و حکمت] دادیم"
  19,13,"و از جانب خویش [به او] محبت و پاکی [از گناهان عطا کردیم] و او پرهیزگار بود"
  19,14,"و نسبت به پدر و مادرش نیکوکار بود و سرکش [و] نافرمان نبود"
  19,15,"و سلام [و امنیتِ الله] بر او باد، روزی‌ که متولد شد و روزی ‌که می‌میرد و روزی ‌که زنده برانگیخته می‌شود"
  19,16,"و در [این] کتاب [= قرآن] از مریم یاد کن، آنگاه ‌که از خانواده‌اش کناره گرفت [و در] ناحیۀ شرقی [از آنان] مستقر شد"
  19,17,"و میان خود و آنها پرده‌اى افكند [تا خلوتگاهِ عبادتش باشد]. آنگاه [ما] روحِ خود [= جبرئیل] را به سویش فرستادیم و به [شكل] انسانی خوش‌اندام بر وی نمایان گشت"
  19,18,"[مریم] گفت: «من از [شرّ] تو، به [الله] رحمان پناه می‌برم. اگر پرهیزگاری [به من آسیب نرسان]»"
  19,19,"[جبرئیل] گفت: «یقیناً من فرستادۀ پروردگارت هستم تا پسرِ پاکیزه‌ای به تو بخشم»"
  19,20,"[مریم] گفت: «چگونه ممکن است پسری داشته باشم؛ حال آنكه دست هیچ انسانی به من نرسیده است و بدكار [نیز] نبوده‌ام؟»"
  19,21,"[جبرئیل] گفت: «[دستور‌] چنین است. پروردگارت فرمود: \"این [کار] بر من آسان است و او را برای مردم نشانه‌ای [از قدرتِ خویش] قرار می‌دهیم و [نیز] رحمتی از سوی ماست؛ و این [شیوۀ تولد،] امری انجام‌یافته [و حتمی] است\"»"
  19,22,"پس [مریم] او [= عیسی] را باردار شد. و با او به جایی دوردست [رفت و از مردم] کناره گرفت"
  19,23,"درد زایمان او را به سمت یک تنۀ‌ نخل کشاند [و او در حالی که درد می‌کشید] گفت: «ای کاش پیش از این می‌مُردم و به کلی از یادها می‌رفتم [تا کسی درباره‌ام خیال باطل نکند]»"
  19,24,"ناگهان از زیر [پای] او، [جبرئیل] ندایش داد که: «غمگین مباش. پروردگارت زیر [پاى‌] تو چشمۀ آبى روان ساخته است"
  19,25,"و تنۀ نخل را به طرف خود تکان بده [تا] خرمای تازه بر تو فرو‌ریزد"
  19,26,"آنگاه [از آن خرما] بخور و [از آب نهر] بنوش و دیدگان را [به ‌این فرزند] روشن دار [و شاد باش]؛ و اگر هر یک از مردم را دیدی [با اشاره] بگو: \"من برای [الله] رحمان روزه[ی سکوت] نذر کرده‌ام و امروز با هیچ انسانی سخن نخواهم گفت\"»"
  19,27,"[مریم] در حالی‌ که او [= عیسی] را برداشته بود نزد قومش آمد. آنان گفتند: «ای مریم، به راستی دروغ بزرگی می‌گویی [که این نوزاد بدون پدر متولد شده است]"
  19,28,"ای خواهر هارون، نه پدرت مرد بدکاری بود و نه مادرت [زن] بدکاره‌ای»"
  19,29,"آنگاه مریم به او [= عیسی] اشاره کرد. آنان گفتند: «چگونه با ‌کودکی در گهواره سخن بگوییم؟»"
  19,30,"[عیسی به سخن آمد و] گفت: «من بندۀ الله هستم. او به من کتاب داده و مرا پیامبر ساخته است"
  19,31,و مرا ـ هر جا که باشم ـ پربرکت نموده و تا زنده‌ هستم مرا به نماز و زکات سفارش کرده است
  19,32,"و نسبت به مادرم نیکوکار [گردانده] و مرا [در برابر پروردگارم] سرکش [و] نافرمان قرار نداده است"
  19,33,و سلام بر من، روزی‌ که متولد شدم و روزی‌ که می‌میرم و روزی‌ که زنده برانگیخته می‌شوم»
  19,34,"این است [حکایت] عیسی پسر مریم؛ [همان] گفتار راستی که [گمراهان] درباره‌اش تردید [و اختلاف] می‌کنند"
  19,35,"[هرگز] سزاوار نیست که الله [برای خویش] فرزندی بگیرد. او [پاک و] منزّه است. [الله] هر گاه کاری را اراده کند، فقط به آن می‌گوید: «موجود شو»؛ آنگاه [بی‌درنگ] موجود می‌شود"
  19,36,"و [عیسی به قومش گفت:] «بی‌تردید، الله پروردگار من و شماست؛ پس او را عبادت کنید [که] راهِ راست همین است»"
  19,37,"آنگاه گروه‌ها[ی مختلفِ قومش] در میان خود دچار اختلاف شدند؛ پس وای بر کسانی که کفر ورزیدند از مشاهدۀ روز بزرگ [قیامت]"
  19,38,"آن روز ‌که نزد ما می‌آیند، چه [خوب] شنوا و بینا هستند! اما امروز [در زندگی دنیا] ستمکاران در گمراهیِ آشکارند"
  19,39,"و [ای پیامبر،] به آنان دربارۀ روز [پشیمانی و] حسرت هشدار بده؛ آنگاه كه کار [داورى] انجام می‌گیرد؛ و [امروز‌] آنان در غفلتند و ایمان نمی‌آورند"
  19,40,"یقیناً ما زمین و هر ‌کس را بر آن است به ارث می‌بریم و [همه] به سوی ما بازگردانده می‌شوند"
  19,41,"و [ای پیامبر،] در این کتاب از ابراهیم یاد کن. بی‌تردید، او پیامبری بسیار راستگو بود"
  19,42,"هنگامی‌ که به پدرش [آزر] گفت: «پدر جان، چرا چیزی را عبادت می‌کنی که نه [دعایت را] می‌شنود و نه [عبادتت را] می‌بیند و نه گزندی را از تو دور می‌سازد؟"
  19,43,"پدر جان، یقیناً از دانش [وحی] چیزی به من رسیده است که [هرگز] به تو نرسیده است؛ پس از من پیروی کن تا تو را به راهی راست هدایت کنم"
  19,44,"پدر جان، از شیطان پیروی نکن [چرا که] بی‌تردید، شیطان نسبت به [الله] رحمان نافرمان بود"
  19,45,"پدر جان، من می‌ترسم که از [جانب الله] رحمان عذابی به تو رسد و [در دوزخ] از دوستان [و همنشینانِ] شیطان باشی»"
  19,46,"[آزر] گفت: «ای ابراهیم، آیا از معبود‌های من رویگردانی؟ اگر [از عقیده‌ات] دست برنداری، قطعاً سنگسارت می‌کنم؛ [برو] و مدت زیادى از من دور شو»"
  19,47,"[ابراهیم] گفت: «سلام [و امنیت از جانب من] بر تو. به زودی از پروردگارم برایت آمرزش خواهم خواست. بی‌تردید، او نسبت به من بسیار مهربان است"
  19,48,"و از شما [کافران] و آنچه به جای الله می‌خوانید کناره‌گیری می‌کنم و پروردگارم را می‌خوانم. امید است كه در خواندنِ پروردگارم [از اجابت] بى‌بهره نباشم»"
  19,49,"هنگامی که از آنان و آنچه به جای الله عبادت می‌کردند کناره‌گیری کرد، [پسرش] اسحاق و [نوه‌اش] یعقوب را به او بخشیدیم و همه [آنان] را پیامبر نمودیم"
  19,50,"و ایشان را از رحمت خویش بهره‌مند ساختیم و [در میان مردم آوازۀ بلند و] نام نیکو برایشان نهادیم"
  19,51,"و در این کتاب، از موسی یاد کن. بی‌تردید، او [برگزیده‌ای] مخلص و فرستاده‌ای پیامبر بود"
  19,52,"و [ما] او [=موسى] را از كناره [كوه] طور و سمت راست [خودش] ندا دادیم و او را مناجات‌کنان [به خویش] نزدیک ساختیم"
  19,53,و از رحمت خود، برادرش هارون را به عنوان پیامبر به وی عطا کردیم
  19,54,و در این کتاب، از اسماعیل یاد کن. بی‌تردید، او راست‌وعده و فرستاده‌ای پیامبر بود
  19,55,"و [همواره] خانواده‌اش را به نماز و زکات فرمان می‌داد و نزد پروردگارش پسندیده بود"
  19,56,و در این کتاب، از ادریس یاد کن. بی‌تردید، او راست‌گفتار پیامبری بود
  19,57,"و [ما] او را به مقامی بلند برکشیدیم"
  19,58,"اینان کسانی از پیامبران هستند که الله نعمت [هدایت] به آنان داد؛ [افرادی] از فرزندان آدم و از كسانى كه همراه نوح [بر كشتى‌] سوار كردیم و از فرزندان ابراهیم و یعقوب و از [جمله] افرادی كه هدایت کردیم و برگزیدیم [و] هر گاه آیات [پرودگار‌] رحمان بر آنان خوانده مى‌شد، سجده‌كنان و گریان به خاک مى‌افتادند"
  19,59,"پس از آنان، جانشینانى گمراه و ناشایست آمدند كه نماز را تباه ساختند [و در آن سهل‌انگارى نمودند] و از هوس‌ها [و شهوات] پیروى كردند؛ و به زودى [کیفرِ] گمراهى [خویش] را خواهند دید"
  19,60,مگر کسی که توبه نمود و ایمان آورد و کاری شایسته کرد، اینان به بهشت داخل می‌شوند و هیچ ستمی بر آنان نمی‌رود
  19,61,"باغ‌هایی جاودان که [الله] رحمان از [عالم] غیب [و نادیده] به بندگانش وعده داده است. یقیناً وعدۀ او آمدنی است"
  19,62,"در آنجا سخن بیهوده‌ای نمی‌شنوند [و گفتارشان] جز سلام [و تحیت نیست]؛ و در آنجا برایشان [هر] صبح و شام روزی‌ [بی‌حساب فراهم] است"
  19,63,"این همان بهشتی است که به هر كس از بندگانمان که [در دنیا] پرهیزگار باشد به میراث می‌دهیم"
  19,64,"و [ای جبرئیل، به محمد بگو:‌] «[ما فرشتگان] جز به فرمان پروردگارت فرود نمی‌آییم. او حاکم بر آینده و گذشته و حالِ ماست؛ و پروردگارت فراموشکار نیست‌"
  19,65,"[همان] پروردگار آسمان‌ها و زمین و آنچه میان آنهاست؛ پس او را عبادت کن و بر عبادتش شکیبا [و پایدار] باش. آیا [همانند و] همنامی برایش می‌شناسی؟»"
  19,66,"و انسان [کافر] می‌گوید: «آیا هنگامی که بمیرم، به راستی مرا زنده [از گور] بیرون خواهند ‌آورد؟»"
  19,67,آیا انسان به یاد نمی‌آورد که ما پیش از این او را آفریدیم، در حالی ‌که هیچ نبود؟
  19,68,"پس سوگند به پروردگارت که یقیناً آنان [= منکران قیامت] را با شیاطین محشور خواهیم کرد؛ سپس همه را به‌زانودرآمده گرداگرد دوزخ حاضر می‌کنیم"
  19,69,"سپس از هر گروهی، کسانی را که در برابر [فرمان الله] رحمان سرکش‌تر بوده‌اند بیرون می‌کشیم"
  19,70,"آنگاه یقیناً ما به [حال] کسانی ‌که برای [درافتادن به] آن [آتش مهیب] سزاوارترند، داناتریم"
  19,71,"و هیچ یک از شما [مردم] نیست، مگر آنکه وارد آن می‌گردد؛ [مؤمنان برای عبور و دیدن، کافران برای ورود و ماندن]. این [امر،] همواره بر پروردگارت حکمی حتمی است"
  19,72,"سپس كسانى را كه پرهیزگاری كرده‌اند [از آتش] نجات مى‌دهیم و ظالمان را به‌زانودرآمده در آن رها مى‌كنیم"
  19,73,"و هنگامی‌ که آیات روشن ما بر آنان تلاوت می‌شود، کسانی ‌که کفر ورزیده‌اند به افرادی‌ که ایمان آورده‌اند می‌گویند: «كدام یک از [ما] دو گروه، جایگاهی بهتر و مجلسی نیکوتر دارد؟»"
  19,74,چه بسیار نسل‌ها را پیش از آنان نابود کردیم که ثروتی بیشتر و ظاهری آراسته‌تر داشتند
  19,75,"[ای پیامبر،] بگو: «هر کس که در گمراهى است، [الله‌] رحمان به او مهلت مى‌دهد [تا گمراهی‌اش بیشتر شود] تا زمانی که وعدۀ الهی را [به چشم خود] ببینند: یا عذاب [دنیا] یا [کیفرِ] قیامت. پس به زودى خواهند دانست که چه کسی جایگاهش بدتر و سپاهش ناتوان‌تر است»"
  19,76,"و [اما] کسانی ‌که راه‌یافته‌اند، الله بر هدایتشان می‌افزاید؛ و نیکی‌های پایدار [= رفتار و گفتار شایسته] در پیشگاه پروردگارت، پاداشی بهتر و سرانجامی نیکوتر دارد"
  19,77,"آیا دیدی آن کسی را که به آیات ما کافر شد و گفت: «قطعاً مال و فرزند [فراوانی در آخرت] به من داده خواهد شد»؟"
  19,78,"آیا او بر غیب آگاهی یافته یا از [الله] رحمان پیمانی گرفته است؟"
  19,79,"[هرگز] چنین نیست؛ گفته‌اش را می‌نویسیم و بر عذابش می‌افزاییم‌"
  19,80,"و آنچه [از اموال و فرزندان] که می‌گوید از او به ارث می‌بریم و [روز قیامت، نیازمند و] تنها نزد ما می‌آید"
  19,81,"و [مشرکان] به جای الله معبودانی برگزیده‌اند تا [یاور و] پشتیبانشان باشند"
  19,82,"چنین نیست؛ [بلکه آن معبودها در قیامت] عبادت آنان را انکار خواهند کرد و دشمنشان خواهند بود"
  19,83,"[ای پیامبر،] آیا ندیدی كه ما شیاطین را بر كافران فرستادیم تا آنان را [با وسوسه‌های خود] تحریک كنند [و از راهِ الله بازدارند]؟"
  19,84,"پس دربارۀ [نابودیِ] آنان شتاب نکن. جز این نیست که ما [روزهای مرگ و فرارسیدنِ عذاب را] به دقت برایشان می‌شماریم"
  19,85,"[یاد كن از‌] روزى كه پرهیزگاران را [با عزت و احترام] به مهمانی [الله] رحمان گِرد می‌آوریم"
  19,86,و مجرمان را تشنه‌کام به سوی جهنم می‌رانیم
  19,87,"آنان هرگز [توان] شفاعت ندارند؛ مگر کسی ‌که [با ایمان و عمل شایسته‌اش،] از [الله] رحمان پیمانی گرفته باشد"
  19,88,"و [مشرکان] گفتند: «[الله] رحمان، فرزندی [برای خویش] برگزیده است»"
  19,89,"به راستی [با این ادعا] چیزی بسیار زشت [به میان] آوردید"
  19,90,"از این [سخن کفرآمیز،] نزدیک است آسمان‌ها از هم بپاشد و زمین بشکافد و کوه‌ها در هم بشکنند و فروریزند"
  19,91,"[چرا] که برای [الله] رحمان فرزندی ادعا کرده‌اند"
  19,92,"و هرگز سزاوار [الله] رحمان نیست که فرزندی برگزیند"
  19,93,"در آسمان‌ها و زمین هیچ كسى نیست، مگر آنكه [در روز قیامت، خاکسار و] بنده‌وار نزد الله رحمان مى‌آید"
  19,94,"یقیناً [الله همۀ] آنان را در شمار آورده و درست برشمرده است"
  19,95,"و همگی‌شان روز قیامت، تنها [و تهیدست] نزد او حاضر می‌شوند"
  19,96,"کسانی‌ که ایمان آورده‌اند و کارهای شایسته کرده‌اند یقیناً [الله] رحمان [در دل‌های بندگانش] محبتی برایشان خواهد نهاد"
  19,97,"[ای پیامبر،] بی‌تردید، ما این [قرآن] را بر زبان تو آسان نمودیم تا پرهیزگاران را با آن بشارت دهی و ستیزه‌گران [سرسخت] را بیم دهی"
  19,98,"و چه بسیار نسل‌های گذشته را پیش از آنان نابود کردیم. آیا [وجود] هیچ‌یک از آنان را احساس می‌کنی یا کمترین صدایی از آنان می‌شنوی؟"