quran[564]{c,v,t}:
  78,1,"[کافران] دربارۀ چه چیزی از یکدیگر سؤال می‌کنند؟"
  78,2,از خبری بزرگ
  78,3,"همان [خبری] که در مورد آن با هم اختلاف دارند"
  78,4,"چنین نیست [که آنها می‌اندیشند]؛ به زودی خواهند دانست"
  78,5,باز هم چنین نیست؛ به زودی خواهند دانست
  78,6,"آیا زمین را بستری [برای آسایش شما] قرار ندادیم؟"
  78,7,"و کوه‌ها را میخ‌ها[ی آن قرار ندادیم؟]"
  78,8,"و شما را جفت [= نر و ماده] آفریدیم"
  78,9,"و خواب شما را [مایۀ] آرامشتان قرار دادیم"
  78,10,"و شب را پوششی [برایتان] قرار دادیم"
  78,11,"و روز را [وسیلۀ] زندگی و [امرارِ معاش] قرار دادیم،"
  78,12,"و بر فراز شما هفت [آسمان] محکم بنا کردیم،"
  78,13,"و [خورشید را] چراغی درخشان [و روشنایی‌بخش] آفریدیم،"
  78,14,و از ابر‌های باران‌زا، آبی فراوان فرو‌فرستادیم
  78,15,تا دانه و گیاه بسیار با آن برویانیم
  78,16,"و باغ‌هایی پردرخت [با آن پرورش دهیم]"
  78,17,"بی‌گمان، روز داورى [میان مخلوقات]، وعده‌گاه [ما با شما] است"
  78,18,"روزی ‌که در «صور» دمیده می‌شود و شما گروه‌گروه [به محشر] می‌آیید؛"
  78,19,و آسمان گشوده می‌شود و به صورت درهای متعدد درمی‌آید؛
  78,20,و کوه‌ها به حرکت درمی‌آید و به صورت سرابی می‌شود؛
  78,21,و بی‌گمان، جهنم کمینگاهی است
  78,22,"[و] محل بازگشتی برای طغیانگران"
  78,23,مدت زمانی بی‌پایان در آنجا می‌مانند
  78,24,"در آنجا نه [چیز] خنکی می‌چشند و نه آشامیدنی [گوارایی خواهند داشت]"
  78,25,"جز آبی سوزان و [مایعی که] چرک و خون [جهنمیان است]"
  78,26,"[این] کیفری است مناسب و درخور [گناهانشان]؛"
  78,27,"همانا آنان از حساب [و کتاب روز قیامت] نمی‌ترسیدند"
  78,28,و آیات ما را به شدت تکذیب کردند؛
  78,29,"و ما همه چیز را [در لوح محفوظ] شمارش و ثبت کرده‌ایم"
  78,30,"پس [کیفرِ اعمال خود را] بچشید که [چیزی] جز عذاب بر شما نمی‌افزاییم"
  78,31,"بی‌گمان، برای پرهیزگاران کامیابی [بزرگی] است"
  78,32,"باغ‌های [میوه] و تاکستان‌ها"
  78,33,و حوریانی نوجوان و هم‌سن و سال
  78,34,"و جام‌هایی لبریز و پیاپی [از شراب پاکیزۀ بهشت]"
  78,35,در آنجا نه سخن بیهوده‌ای می‌شنوند و نه دروغی
  78,36,"[این] پاداش، از جانب پروردگار توست، و عطایی از روی حساب"
  78,37,"[همان] پروردگار آسمان‌ها و زمین و آنچه در میان آنهاست؛ [همان الله] رحمان [که] هیچ‌ کس [در آن روز] یارای سخن گفتن با او را ندارد"
  78,38,"روزی ‌که روح [= جبرئیل] و فرشتگان به صف می‌ایستند، [و] هیچ‌ کس سخن نمی‌گوید، جز کسی ‌که [الله] رحمان به او اجازه داده باشد و [او] سخن درست [و صواب] گوید"
  78,39,"آن [روز]، روزِ حق است [و بدون تردید واقع می‌شود]؛ پس هر کس كه بخواهد، [می‌تواند] راه بازگشتى به سوى پروردگار خود بجوید"
  78,40,"به راستی، ما شما را از عذابی نزدیک بیم دادیم: روزی ‌که انسان آنچه را از قبل با دست‌های خود فرستاده است می‌بیند، و کافر می‌گوید: «ای کاش من خاک بودم [و برای حساب برانگیخته نمی‌شدم»]"
  79,1,"سوگند به فرشتگانی که جان [کافران] را به شدت بیرون می‌کشند"
  79,2,"و سوگند به فرشتگانی که جان [مؤمنان] را به نرمی و آسانی می‌گیرند"
  79,3,"و سوگند به فرشتگانی که [به امرِ الله، از آسمان به سوی زمین و بالعکس] شناورند"
  79,4,"و سوگند به فرشتگانی که [در اجرای اوامر الهی] بر یکدیگر سبقت می‌گیرند"
  79,5,"و سوگند به فرشتگانی [که به امر الهی] کارها را تدبیر می‌کنند"
  79,6,"روزی‌ که [پس از اولین دمیدن در صور] زمین [و کوه‌ها و همه چیز] به لرزه درآید"
  79,7,"[و] در پی آن، [دمیدن دوم حشر] بیاید،"
  79,8,"در آن روز، دل‌هایی سخت مضطرب [و ترسان] هستند"
  79,9,"و چشم‌های آنان [از ترس و شرمساری] فرو افتاده است"
  79,10,"[کافران در دنیا] می‌گفتند: «آیا ما [پس از مرگ، دوباره] به حال اول خود باز‌گردانده می‌شویم؟"
  79,11,"آیا هنگامی‌ که استخوان‌هایی پوسیده شدیم [و به خاک تبدیل گشتیم، باز هم زنده می‌شویم]»؟"
  79,12,"می‌گفتند: «[اگر چنین وعده‌ای درست باشد،] آنگاه آن بازگشتی زیانبار است»"
  79,13,"آن [بازگشت،] تنها [به] یک بانگِ مهیب است [و بس]"
  79,14,"و ناگهان همگی بر عرصۀ زمین [محشر] ظاهر می‌شوند"
  79,15,"[ای پیامبر،] آیا داستان موسی به تو رسیده است؟"
  79,16,"آنگاه که پروردگارش او را در سرزمین مقدس «طُوی» ندا داد [و فرمود]"
  79,17,«به سوی فرعون برو که او طغیان کرده است،
  79,18,"و به او بگو: «آیا می‌خواهی [از کفر و گناه] پاک شوی؟"
  79,19,"و من تو را به سوی پروردگارت هدایت کنم تا [از او] بترسی [و فرمانبردار شوی]؟"
  79,20,"پس [موسی] معجزۀ بزرگ را به او نشان داد"
  79,21,اما او تکذیب و سرکشی کرد
  79,22,"سپس پشت کرد و به کوشش و تلاش [علیه او] پرداخت"
  79,23,"آنگاه [قومش را] جمع کرد و ندا داد"
  79,24,"و گفت: «من پروردگارِ برتر شما هستم»"
  79,25,الله او را به عذاب آخرت و دنیا گرفتار کرد
  79,26,"بی‌گمان، در این [واقعه،] برای هر کس ‌که [از الله] می‌ترسد، عبرتی است"
  79,27,"آیا آفرینش شما [بعد از مرگ] سخت‌تر است یا آسمانی که [الله] آن را بنا کرد؟"
  79,28,سقف آن را بر افراشت و به آن شکل و نظم داد،
  79,29,و شبش را تاریک و روزش را روشن گردانید،
  79,30,و زمین را بعد از آن گسترانید،
  79,31,"و از آن، آب [چشمه‌ها و چاه‌ها و] چراگاهش را بیرون آورد،"
  79,32,"و کوه‌ها را محکم و استوار [بر روی زمین] قرار داد"
  79,33,"[همۀ اینها] برای بهره‌گیری شما و چهارپایانتان است"
  79,34,"هنگامی‌ که [آن] حادثۀ بزرگ [قیامت] فرا رسد،"
  79,35,"در آن روز، انسان [تمام اعمال و] تلاش‌های خود را به یاد می‌آورد"
  79,36,و جهنم برای هر بیننده‌ای آشکار می‌شود
  79,37,"اما آن کس که طغیان [و سرکشی] کرده باشد"
  79,38,"و زندگی دنیا را [بر آخرت] ترجیح داده باشد،"
  79,39,بی‌تردید، جهنم جایگاه اوست
  79,40,"و اما کسی‌ که از ایستادن در حضور پروردگارش بیمناک بوده و نفس را از هوی [و هوس] بازداشته باشد،"
  79,41,قطعاً بهشت جایگاه اوست
  79,42,"[ای پیامبر،] دربارۀ قیامت از تو می‌پرسند که در چه زمانی واقع می‌شود؟"
  79,43,تو را با یادآوری این سخن چه کار است؟
  79,44,"[سرانجام و] منتهای [علمِ] آن، نزد پروردگار توست"
  79,45,"تو فقط بیم‌دهندۀ کسانی هستی که از آن [= قیامت] می‌ترسند"
  79,46,"روزی‌ که [کافران قیامت را] ببینند، [چنین احساس می‌کنند که] گویی [در دنیا] جز یک شامگاه یا بامداد به سر نبرده‌اند"
  80,1,"[پیامبر] چهره در هم کشید و روی برگردانْد"
  80,2,"از اینکه آن نابینا [= عبدالله بن اُمّ مَکتوم] نزدش آمد"
  80,3,"و [ای پیامبر،] تو چه می‌دانی؟ چه بسا او [از گناهانش] پاک ‌شود،"
  80,4,یا پند گیرد و این پند به سودش باشد
  80,5,"اما آن کس که [از ایمان] بی‌نیازی می‌ورزد"
  80,6,تو به او روی می‌آوری؛
  80,7,"در حالی که اگر او خود را [از کفر] پاک نسازد، ایرادی بر تو نیست؛"
  80,8,اما کسی که شتابان به سراغ تو می‌آید
  80,9,"و [از الله] می‌ترسد،"
  80,10,"تو از او غافل می‌شوی [و به دیگران می‌پردازی]"
  80,11,"هرگز چنین نیست؛ بی‌گمان، این [آیات برای] تذکر و یادآوری است"
  80,12,"پس هر کس که بخواهد، [می‌تواند] از آن پند گیرد"
  80,13,"در صحیفه‌های ارجمندی [ثبت] است"
  80,14,"[در جایگاهی] بلندپایه و پاکیزه [از پلیدی]"
  80,15,"در دست سفیران [وحی] است"
  80,16,"[که] بزرگوار و نیکوکارند"
  80,17,"مرگ بر انسان [کافر، که] چقدر ناسپاس است"
  80,18,"[الله] او را از چه چیز آفریده است؟"
  80,19,"او را از نطفۀ [ناچیزی] آفرید، سپس او را موزون ساخت"
  80,20,سپس راه را برایش آسان نمود
  80,21,"آنگاه [پس از پایان عمر،] او را میرانْد و در قبر [پنهان] نمود"
  80,22,"سپس هر گاه بخواهد، او را [زنده می‌کند و] برمی‌انگیزد"
  80,23,"هرگز چنین نیست [که او می‌پندارد]. او هنوز آنچه را که [الله] فرمان داده به جای نیاورده است"
  80,24,"انسان باید به غذای خویش [و آفرینشِ آن] بنگرد"
  80,25,"ما آب فراوان [از آسمان] فروریختیم،"
  80,26,سپس زمین را از هم شکافتیم،
  80,27,"آنگاه دانه‌[های فراون] در آن رویاندیم،"
  80,28,"و انگور و سبزی [خوراکی بسیار]،"
  80,29,و زیتون و نخل،
  80,30,"و باغ‌هایی [انبوه و] پردرخت،"
  80,31,"و [انواع] میوه و علوفه [پدید آوردیم]"
  80,32,"[همۀ اینها] برای بهره‌گیری شما و چهارپایانتان است"
  80,33,"هنگامی ‌که [آن] صدای مهیب [قیامت] فرارسد،"
  80,34,روزی ‌که انسان از برادرش می‌گریزد
  80,35,و از مادرش و از پدرش
  80,36,"و از زنش و پسرانش [نیز می‌گریزد]،"
  80,37,"در آن روز، هر کس را کاری است که او را به خودش سرگرم می‌دارد [و از دیگری بازمی‌دارد]"
  80,38,چهره‌هایی در آن روز، گشاده و روشن است
  80,39,"[به خاطر نعمت و رحمتِ الله] خندان [و] شاد است"
  80,40,و چهره‌هایی در آن روز، غبارآلود است
  80,41,"[و] سیاهی [و تاریکی] آنها را پوشانده است"
  80,42,اینان همان کافرانِ بدکردارند
  81,1,"آنگاه ‌که خورشید درهم پیچیده [و تاریک] گردد،"
  81,2,و آنگاه ‌که ستارگان بی‌فروغ شوند،
  81,3,و آنگاه ‌که کوه‌ها به حرکت درآید،
  81,4,و آنگاه ‌که ماده‌شترانِ باردار رها شوند،
  81,5,"و آنگاه ‌که حیوانات وحشی [در کنار انسان] گرد آورده شوند،"
  81,6,"و آنگاه ‌که دریا‌ها [جوشان و] برافروخته شود،"
  81,7,و آنگاه ‌که هر کس با همسانِ خود قرین گردد،
  81,8,و آنگاه ‌که از دختر زنده‌به‌گورشده پرسیده شود
  81,9,"[که] به کدامین گناه کشته شده است،"
  81,10,"و آنگاه ‌که نامه‌های [اعمال] گشوده شود،"
  81,11,و آنگاه ‌که پرده از روی آسمان برگرفته شود،
  81,12,"و آنگاه ‌که دوزخ، افروخته [و شعله‌ور] گردد،"
  81,13,"و آنگاه ‌که بهشت [برای پرواپیشگان] نزدیک آورده شود"
  81,14,"[در آن هنگام،] هر کس خواهد دانست که چه چیزی [برای آخرت خود] آماده کرده است"
  81,15,"سوگند به ستارگانی که [به جایگاه خود] بازمی‌گردند،"
  81,16,"[شتابان] حرکت می‌کنند [و از نظر] پنهان می‌شوند؛"
  81,17,"و سوگند به شب، هنگامی ‌که [از تاریکی‌اش کاسته شود و] پشت کند؛"
  81,18,و سوگند به صبح، هنگامی که بدمد؛
  81,19,"بی‌تردید، این [قرآن، سخن الله است که ابلاغش به پیامبر، بر عهدۀ] فرستاده‌ای بزرگوار [=جبرئیل] است؛"
  81,20,"[همان فرشته‌ای] که [مقتدر و] نیرومند است و نزد [اللهِ] صاحب‌عرش، مقام والایی دارد؛"
  81,21,"[در ملکوت اعلی و عالم فرشتگان] از او فرمان می‌برند و امین [وحی] است"
  81,22,"[ای مردم،] همنشین شما [= محمد] دیوانه نیست؛"
  81,23,"و بی‌تردید، [محمد]، او [= جبرئیل] را در افق روشن دیده است"
  81,24,"و او بر [ابلاغِ آنچه از طریق] غیب [به وی وحی می‌گردد] بخیل نیست [و همانند کاهنان نیز مزد نمی‌گیرد]"
  81,25,"و این [قرآن] گفتۀ شیطان رانده‌شده نیست"
  81,26,پس به کجا می‌روید؟
  81,27,"این [قرآن] چیزی جز پند و اندرز برای جهانیان نیست"
  81,28,"برای هر یک از شما که بخواهد راه راست [حق را] در پیش گیرد"
  81,29,"و شما [چیزی را] نمی‌خواهید، مگر آنکه پروردگار جهانیان [اراده کند و] بخواهد"
  82,1,آنگاه ‌که آسمان شکافته شود،
  82,2,"آنگاه ‌که ستارگان پراکنده شوند [و فرو ریزند]،"
  82,3,"و آنگاه ‌که دریا‌ها [به هم آمیزند و لبریز و] روان گردند،"
  82,4,"و آنگاه ‌که قبرها [برای براگیختن مردگان] زیر و رو شود،"
  82,5,"[در آن هنگام،] هر کس می‌داند چه چیزهایی را پیشاپیش فرستاده و چه چیزهایی را واپس نهاده [و بر جای گذاشته است]"
  82,6,"ای انسان، چه چیزی تو را [نسبت] به پروردگار بزرگوارت مغرور ساخته است؟"
  82,7,"آن [پروردگاری] که تو را آفرید، سپس به تو سر و سامان داد و آنگاه تو را متعادل و متناسب کرد"
  82,8,"و به هر شکلی [و صورتی] که خواست، تو را ترکیب نمود"
  82,9,"هرگز چنین نیست [که شما گمان می‌کنید]؛ بلکه شما [روز] جزا را تکذیب می‌کنید"
  82,10,"و بی‌گمان، نگهبانانی [از فرشتگان] بر شما گمارده شده‌اند"
  82,11,که نویسندگانی بزرگوارند؛
  82,12,"آنچه را انجام می‌دهید، می‌دانند [و اعمال نیک و بد شما را ثبت می‌کنند]"
  82,13,"مسلماً نیکوکاران در نعمت[های بهشت] هستند"
  82,14,"و یقیناً بدکاران در [آتش] جهنمند"
  82,15,"روز جزا به آن درمی‌آیند [و می‌سوزند]"
  82,16,"و هرگز آنان از آنجا به دور و [در امان] نباشند"
  82,17,و تو چه ‌دانی که روز جزا چیست؟
  82,18,باز تو چه می‌دانی که روز جزا چیست؟
  82,19,"روزی‌که هیچ کس قادر به انجام کاری برای دیگری نیست؛ و در آن روز، حکم [و فرمان،] از آنِ الله است"
  83,1,وای بر کم‌فروشان
  83,2,"[همان] کسانی‌ که چون [برای خود] از مردم پیمانه می‌کنند، حق خود را کامل می‌گیرند،"
  83,3,"و هنگامی ‌که [می‌خواهند] برای آنان پیمانه یا وزن کنند، کم می‌گذارند"
  83,4,"آیا آنها گمان نمی‌کنند که [قیامت فرا می‌رسد و از قبرها] برانگیخته می‌شوند،"
  83,5,در روزی بزرگ؟
  83,6,"[همان] روزی‌ که مردم در پیشگاه پروردگار جهانیان می‌ایستند"
  83,7,"هرگز چنین نیست [که کافران پنداشته‌اند]! به راستی که نامۀ [اعمال] بدکاران در سِجّین است"
  83,8,و تو چه دانی که سِجّین چیست؟
  83,9,"کتابی است که [اعمال بدکاران در آن] نوشته شده است"
  83,10,در آن روز، وای بر تکذیب‌کنندگان
  83,11,"همان کسانی که روز جزا را [انکار و] تکذیب می‌کنند؛"
  83,12,"و جز ستمکارانِ گنهکار، [کسی] آن [روز] را تکذیب نمی‌کند"
  83,13,"هنگامی که آیات ما بر او تلاوت می‌شود، می‌گوید: «[این] افسانه‌های [خیالی] گذشتگان است»"
  83,14,"هرگز چنین نیست [که آنها گمان می‌کنند]؛ بلکه [به سبب] آنچه کرده‌اند، بر دل‌هایشان زنگار بسته است"
  83,15,"هرگز چنین نیست [که آنها می‌پندارند]. بی‌گمان، آنان در آن روز از [دیدار] پروردگار‌شان محرومند"
  83,16,"و [بعد از حساب،] مسلماً وارد دوزخ می‌شوند"
  83,17,"آنگاه به آنان گفته می‌شود: «این [آتش،] همان چیزی است که آن را تکذیب می‌کردید»"
  83,18,"هرگز چنین نیست [که آنها می‌پندارند]؛ بی‌گمان، نامۀ [اعمال] نیکوکاران در «عِلّیین» است"
  83,19,و تو چه دانی که «عِلّیین» چیست؟
  83,20,"کتابی است که [اعمال نیکوکاران در آن] نوشته شده است،"
  83,21,"که مقرّبان [درگاه الهی] بر آن حاضر می‌شوند [و گواهی می‌دهند]"
  83,22,"همانا نیکوکاران در نعمت[های بهشت] هستند"
  83,23,"بر تخت‌ها [تکیه زده و] می‌نگرند"
  83,24,"خرمی و نشاطِ نعمت [بهشت] را در چهره‌هایشان [می بینی و] می‌شناسی"
  83,25,"آنها از شراب نابِ مُهرشده، [نوشانیده و] سیراب می‌شوند"
  83,26,"مُهری که بر آن نهاده شده، از مُشک است، و مشتاقان [رحمت]، در این [شراب و دیگر نعمت‌های بهشتی] باید بر یکدیگر پیشی گیرند"
  83,27,"و آمیزه‌اش از [چشمه] تسنیم است؛"
  83,28,"[همان] چشمه‌ای که مقربان [درگاه الهی] از آن می‌نوشند"
  83,29,"همانا کسانی که جرم و گناه مرتکب شدند، پیوسته [در دنیا] بر کسانی‌ که ایمان آورده بودند می‌خندیدند"
  83,30,"و هر گاه [مؤمنان] از کنار‌شان می‌گذشتند، با چشم و ابرو به هم اشاره می‌کردند [و آنان را به سُخره می‌گرفتند]؛"
  83,31,"و چون به سوی خانوادۀ خود بازمی‌گشتند، [به خاطر تمسخرِ مؤمنان] شادمان و خندان بودند؛"
  83,32,"و هنگامی که مؤمنان را می‌دیدند می‌گفتند: «بی‌گمان، اینان گمراهانند»؛"
  83,33,"در حالی ‌که آنان برای مراقبت [و نگهبانی،] بر مؤمنان فرستاده نشده بودند"
  83,34,ولی امروز کسانی ‌که ایمان آورده‌اند، به کافران می‌خندند
  83,35,"بر تخت‌های [آراسته نشسته و به نعمت‌های الهی که برترین آنها، رؤیت وجه گرامی الله است] می‌نگرند"
  83,36,"آیا کافران [با چشیدن عذاب،] جزای آنچه را که می‌کردند دریافت نموده‌اند؟"
  84,1,آنگاه ‌که آسمان شکافته شود،
  84,2,"و به [فرمان] پروردگارش گوش فرا دهد [و تسلیم شود]؛ و سزاوار است [که چنین کند]،"
  84,3,"و آنگاه ‌که زمین گسترده [و هموار] شود،"
  84,4,و هر چه را درون خود دارد، بیرون ریزد و تهی گردد،
  84,5,"و به [فرمان] پروردگارش گوش دهد [و تسلیم شود]؛ و سزاوار است [که چنین کند]"
  84,6,"ای انسان، بی‌گمان، تو در راه [رسیدن به] پروردگارت سخت تلاش و کوشش می‌کنی؛ پس او را ملاقات خواهی کرد"
  84,7,"و اما کسی ‌که نامۀ [اعمال او] به دست راستش داده شود،"
  84,8,به زودی به حسابی آسان، محاسبه می‌شود
  84,9,و شادمان به سوی خانواده‌اش بازمی‌گردد؛
  84,10,"و اما کسی ‌که نامۀ [اعمال او] از پشت سرش به او داده شود"
  84,11,به زودی نابودیِ خود را خواهد ‌طلبید
  84,12,"و به [آتش] جهنم شعله‌ور در خواهد آمد"
  84,13,"بی‌گمان، او در [دنیا به خاطر گناهانش،] در میان خانوادۀ خود شادمان بود"
  84,14,"او گمان می‌کرد که هرگز [به نزد الله] بازنخواهد گشت"
  84,15,آری؛ همانا پروردگارش از حال وی آگاه بود
  84,16,به شفق سوگند می‌خورم،
  84,17,و سوگند به شب و آنچه را فرو می‌پوشد
  84,18,"و سوگند به ماه چون [فروغش] کامل شود"
  84,19,"که قطعاً مراتب و حالات مختلفی را یکی پس از دیگری [در مسیر زندگی دنیوی] طی خواهید کرد"
  84,20,آنان را چه شده که ایمان نمی‌آورند؟
  84,21,"و [چرا] هنگامی‌ که قرآن بر آنان تلاوت می‌شود سجده نمی‌کنند؟"
  84,22,"بلکه کسانی‌ که کافر شدند، پیوسته [آیات الهی را] تکذیب می‌کنند"
  84,23,و الله به آنچه در دل پنهان می‌دارند، دانا‌تر است
  84,24,"پس [ای پیامبر،] آنان را به عذابی دردناک بشارت ده؛"
  84,25,مگر کسانی که ایمان آورده‌اند و کارهای شایسته انجام داده‌اند، که پاداشی بی‌منّت و پیوسته برایشان است
  85,1,سوگند به آسمان که دارندۀ بُرج‌هاست،
  85,2,"و سوگند به روز موعود [قیامت]،"
  85,3,و سوگند به هر کس که گواهی دهد و به هر کس که مورد گواهی قرار گیرد
  85,4,مرگ بر آدم‌سوزان خندق
  85,5,"[همان آتشِ] افروخته از هیزم‌های بسیار [که مؤمنان را در آن می‌سوزاندند]؛"
  85,6,"هنگامی ‌که بر [کنارۀ] آن نشسته بودند"
  85,7,و آنچه را با مؤمنان انجام می‌دادند، تماشا می‌کردند؛
  85,8,"و هیچ ایرادی از آنان [=مؤمنان] نگرفتند، جز اینکه به الله پیروزمندِ ستوده ایمان آورده بودند"
  85,9,"[همان] ذاتی که فرمانروایی آسمان‌ها و زمین از آنِ اوست؛ و الله بر همه چیز گواه است"
  85,10,"به راستی کسانی که مردان و زنان مؤمن را شکنجه [و آزار] دادند و پس [از انجام آن کار،] توبه نکردند، عذاب جهنم برایشان [مهیّا] است و عذاب آتش [در پیش دارند]"
  85,11,"همانا برای کسانی ‌که ایمان آوردند و کار‌های شایسته کردند، باغ‌هایی [از بهشت] است که جویبارها زیر [درختان] آن جاری است؛ و این است کامیابی بزرگ"
  85,12,"بی‌گمان، [مجازات و] سختگیریِ پروردگارت بسیار شدید است"
  85,13,"در حقیقت، اوست که [آفرینش را] آغاز می‌کند و دوباره [بعد از مرگ] بازمی‌گرداند؛"
  85,14,"و همو آمرزنده [و] دوستدار [مؤمنان] است"
  85,15,"[الله] صاحب‌عرش [و] بلندمرتبه [و شکوهمند] است"
  85,16,"[و] آنچه را بخواهد، انجام می‌دهد"
  85,17,"[ای پیامبر،] آیا داستان لشکر‌یان [حق‌ستیز] به تو رسیده است؟"
  85,18,"[لشکر] فرعون و [قوم] ثمود"
  85,19,"بلکه کسانی ‌که کافر شدند، پیوسته در تکذیب [حق] هستند،"
  85,20,و الله از هر سو بر آنان احاطه دارد
  85,21,"آری، این [آیات، شعر و سحر نیست؛ بلکه] قرآن شکوهمند است"
  85,22,"در لوح محفوظ [از هر گونه تحریف و تبدیل، در امان] است"
  86,1,سوگند به آسمان و سوگند به ستارۀ شبگرد
  86,2,و تو چه می‌دانی که ستارۀ شبگرد چیست؟
  86,3,"[همان] ستارۀ فروزان است"
  86,4,"هیچ کس نیست، مگر اینکه نگهبانی [از فرشتگان] بر او[گماشته شده] است"
  86,5,انسان باید بنگرد که از چه چیز آفریده شده است
  86,6,از یک آب جهنده آفریده شده
  86,7,"که از میان [استخوانِ] پشت [مرد] و سینۀ [زن] بیرون می‌آید"
  86,8,"بی‌گمان، الله بر بازگرداندن او [پس از مرگ] تواناست"
  86,9,"روزی ‌که [تمام] رازها فاش شود،"
  86,10,"[در آن روز،] انسان هیچ توان و یاوری ندارد"
  86,11,سوگند به آسمان پرباران
  86,12,"و سوگند به زمینِ پرشکاف [که گیاهان از آن سر برمی‌آورند]"
  86,13,"[که] بی‌گمان، این قرآن، سخن جداکنندۀ حق از باطل است"
  86,14,"و [سخنِ] هزل و بیهوده نیست"
  86,15,"آنان [= کافران] پیوسته حیله و نیرنگ می‌کنند"
  86,16,"و من [نیز] حیله [و تدبیر] می‌کنم؛"
  86,17,"پس به کافران مهلت بده [و] اندکی رهایشان کن [تا غرق گناه باشند]"
  87,1,نام پروردگار بلند مرتبه‌ات را به پاکی یاد کن
  87,2,"[همان ذاتی] که [انسان را] آفرید و هماهنگ و متعادل ساخت"
  87,3,"و [همان] ذاتی‌ که اندازه‌گیری کرد و [به شایستگی آفرید] و سپس هدایت نمود"
  87,4,"و [آن] ذاتی‌ که چراگاه را [برای تغذیۀ جانداران] رویانید"
  87,5,سپس آن را خشک و سیاه گردانید
  87,6,"ما به زودی [قرآن را] بر تو می‌خوانیم؛ پس تو هرگز [آن را] فراموش نخواهی کرد؛"
  87,7,مگر آنچه را که الله بخواهد؛ همانا او آشکار و نهان را می‌داند
  87,8,"و آسان‌ترین [راه‌] را برایت فراهم مى‌گردانیم"
  87,9,"اگر پند مفید باشد، [مردم را با آیات قرآن] پند ده"
  87,10,"به زودی کسی‌ که [از الله] می‌ترسد، پند می‌پذیرد"
  87,11,"و بدبخت‌ترین [مردم،] از آن دوری می‌گزیند؛"
  87,12,"[همان] کسی‌ که در آتش بزرگ [جهنم] درخواهد آمد،"
  87,13,"و در آن [آتش] نه می‌میرد و نه زنده می‌مانَد"
  87,14,"یقیناً کسی ‌که خود را [از کفرو گناه] پاک کند، رستگار خواهد شد؛"
  87,15,"و [نیز کسی که] نام پروردگارش را یاد کند و نماز بگزارد"
  87,16,"ولی شما [مردم،] زندگی دنیا را [بر آخرت] ترجیح می‌دهید؛"
  87,17,در حالی‌ که آخرت، بهتر و پاینده‌تر است
  87,18,"به راستی این [پندها] در کتاب‌های آسمانی پیشین [نیز] بود؛"
  87,19,کتاب‌های ابراهیم و موسی
  88,1,"[ای پیامبر،] آیا خبرِ قیامت هولناکِ فراگیر به تو رسیده است؟"
  88,2,در آن روز، چهره‌هایی خوار و ذلیل خواهند بود
  88,3,"[در دنیا] پیوسته تلاش کرده [و] خسته شده [و چون در راه حق نبوده، نتیجه‌ای ندیده‌اند]"
  88,4,در آتش سوزان درمی‌آیند،
  88,5,از چشمۀ بسیار داغ به آنها نوشانیده می‌شود
  88,6,غذایی جز خارِ خشک و تلخ ندارند
  88,7,"که نه [آنان را] فربه کند و نه گرسنگی را دفع می‌نماید"
  88,8,در آن روز، چهره‌هایی شاداب و تازه هستند
  88,9,"و از سعی [و تلاش] خود راضیند؛"
  88,10,در بهشت برین هستند
  88,11,در آنجا هیچ سخن بیهوده‌ای نمی‌شنوند
  88,12,"در آن، چشمه[های آب] روان است"
  88,13,"تخت‌های [زیبای] بلند [پایه] در آن است"
  88,14,"و جام‌هایی [که در کنار چشمه‌ها] نهاده شده"
  88,15,"و بالشت‌های [منظم] چیده‌شده،"
  88,16,"و [نیز] فرش‌های گرانبها گسترده شده است"
  88,17,"آیا [کافران] به شتر نمی‌نگرند که چگونه آفریده شده است؟"
  88,18,"و به آسمان [نمی‌نگرند] که چگونه برافراشته شده است؟"
  88,19,"و به کوه‌ها [نمی‌نگرند] که چگونه [محکم بر زمین] نصب شده است؟"
  88,20,"و به زمین [نمی‌نگرند] که چگونه گسترده شده است؟"
  88,21,"[ای پیامبر،] پند بده، که تو فقط پنددهنده‌ای"
  88,22,"تو بر آنان مسلط [و چیره] نیستی [که آنان را بر ایمان‌آوردن وادار کنی]"
  88,23,اما کسی‌ که روی بگردانَد و کافر شود
  88,24,الله او را با بزرگ‌ترین عذاب، مجازات می‌کند
  88,25,همانا بازگشت آنها به سوی ماست
  88,26,"سپس بی‌گمان، حسابشان [نیز] با ماست"
  89,1,"سوگند به سپيده‌دم [صبحگاهان]"
  89,2,"و به شب‌های دهگانه [آغاز ذی‌حجه]"
  89,3,"و به زوج و فرد [اشیاء]"
  89,4,"و سوگند به شب، هنگامی‌ که [حرکت می‌کند و] می‌رود"
  89,5,"آیا در این [چیزها] سوگندی برای صاحب‌خرد نیست [که او را قانع نماید]؟"
  89,6,"[ای پیامبر،] آیا ندیدی که پروردگارت با [قوم] عاد چه کرد؟"
  89,7,"[همان قبیلۀ] اِرَم که دارای [کاخ‌هایی با] ستونهای بلند بودند"
  89,8,که همانند آن در شهرها آفریده نشده بود؟
  89,9,"و [نیز قوم] ثَمود، کسانی که صخره‌های سخت را از [کنار] وادی می‌تراشیدند [و خانه برای خودشان می‌ساختند]؟"
  89,10,"و فرعون، صاحب سپاه [بزرگ و قدرتمند]"
  89,11,"[همان] کسانی که در شهر‌ها طغیان [و سرکشی] کردند"
  89,12,و فسادِ بسیار در آنها به بار آوردند
  89,13,آنگاه پروردگارت تازیانۀ عذاب را بر آنان فرود آورد
  89,14,یقیناً پروردگار تو در کمینگاه است
  89,15,"و اما انسان هنگامی که پروردگارش او را بیازماید و گرامی دارد و به او نعمت بخشد، [مغرور می‌گردد و گمان می‌کند که این امر به خاطر کرامتی است که نزد الله دارد]، پس می‌گوید: «پروردگارم مرا گرامی داشته است»؛"
  89,16,"و اما هنگامی که او را بیازماید و روزی‌اش را بر او تنگ سازد، [دلسرد ‌شده و گمان می‌کند که این امر بدان سبب است که نزد الله، خوار و ذلیل است؛] پس می‌گوید: «پروردگارم مرا خوار کرده است»"
  89,17,"هرگز چنین نیست [که شما می‌پندارید]؛ بلکه شما یتیم را گرامی نمی‌دارید"
  89,18,و یکدیگر را بر اطعام مستمندان ترغیب نمی‌کنید
  89,19,"و میراث را حریصانه می‌خورید [و حق ضعیفان را نمی‌دهید]"
  89,20,"و مال و ثروت [دنیا] را بسیار دوست دارید"
  89,21,"هرگز چنین نیست [که شما گمان می‌کنید]؛ هنگامی ‌که زمین سخت در هم کوبیده شود [و هموار گردد]"
  89,22,"و پروردگارت [برای دادرسی] بیاید و [نیز] فرشتگان صف‌درصف [بایستند]"
  89,23,"و در آن روز جهنم آورده شود، آن روز است که انسان [کافر] پند می‌گیرد [و توبه می‌کند]؛ و [اما] این پند گرفتن، چه سودی برایش دارد؟"
  89,24,"وی می‌گوید: «ای کاش [در دنیا] برای [این] زندگی‌ام [اعمال نیک، از] پیش فرستاده بودم"
  89,25,"در آن روز، هیچ کس همانند عذاب او [= الله] عذاب نمی‌کند،"
  89,26,"و هیچ کس همچون بند کشیدن او [= الله]، کسی را به بند نمی‌کشد"
  89,27,"[اما به مؤمن ندا می‌شود:] «ای روحِ آرام‌یافته،"
  89,28,"به سوی پروردگارت بازگرد، در حالی که تو [از پاداشِ الله] راضی هستی، و او از [اعمال] تو راضی است"
  89,29,"پس در زمرۀ بندگان [خاصّ] من در آی"
  89,30,و به بهشت من وارد شو»
  90,1,"سوگند به این شهر [مکه]"
  90,2,"در حالی که [ای پیامبر!] تو در این شهر ساکنی [و جنگ در این شهر برایت حلال است]"
  90,3,"و سوگند به پدر [= آدم] و فرزندانش"
  90,4,"یقیناً ما انسان را در رنج [و دشواری‌های دنیوی] آفریدیم"
  90,5,"آیا او گمان می‌کند هیچ کس بر [مجازاتِ] وی توانا نیست؟"
  90,6,"می‌گوید: «[به خاطرِ انفاق،] مال زیادی را تباه کرده‌ام»"
  90,7,آیا می‌پندارد که هیچ کس او را ندیده است؟
  90,8,آیا دو چشم برایش قرار ندادیم؟
  90,9,و یک زبان و دو لب؟
  90,10,"و او را به دو راه [خیر و شر] راهنمایی کردیم"
  90,11,"اما به گردنۀ [سخت] قدم نگذاشت [و نیامد]"
  90,12,"و تو چه می‌دانی که آن گردنۀ [سخت] چیست؟"
  90,13,آزاد کردن برده‌ای است
  90,14,"یا اطعام در روز قحطی [و گرسنگی]،"
  90,15,"[خواه] یتیمی از خویشاوندان [باشد]"
  90,16,یا مستمندی خاک نشین؛
  90,17,"به علاوه، از کسانی باشد که ایمان آورده‌اند و یکدیگر را به صبر [بر عبادت و دوری از گناه] و مهربانی [با بندگان] توصیه نموده‌اند"
  90,18,"اینان اهل سعادتند [که نامۀ اعمال آنان به دست راستشان داده می‌شود و اهل بهشتند]"
  90,19,"اما کسانی ‌که به آیات ما کفر ورزیدند، آنان اهل شقاوتند [که نامۀ اعمال به دست چپشان داده می‌شود و به دوزخ می‌روند]"
  90,20,"[از هر سو] آتش سرپوشید‌ه‌ای بر آنان است [که راه فرار ندارند]"
  91,1,"سوگند به خورشید و روشنیِ آن [به هنگام بامداد]،"
  91,2,"و سوگند به ماه، هنگامی که بعد از آن [= خورشید] در‌آید،"
  91,3,"و سوگند به روز، هنگامی‌ که آن [= خورشید] را روشن [و جلوه‌گر] کند،"
  91,4,و سوگند به شب، هنگامی که آن را بپوشانَد،
  91,5,و سوگند به آسمان و به ذاتی که آن را بنا کرد،
  91,6,و سوگند به زمین و به ذاتی که آن را گسترانید،
  91,7,"و سوگند به جانِ [انسان] و ذاتی که آن را [آفرید و] نیکو گردانید،"
  91,8,"سپس نافرمانی و پرهیزگاری‌اش را [به او] الهام کرد"
  91,9,"بی‌تردید، هر کس نفس خود را [از گناهان] پاک کند، رستگار می‌شود"
  91,10,"و هر کس آن را [با گناه] آلوده سازد، یقیناً زیانکار می‌شود"
  91,11,"[قوم] ثمود از روی سرکشی، [پیامبر‌شان را] تکذیب کردند،"
  91,12,"آنگاه که بدکار‌ترین آنان [برای اقدام به جنایت] برخاست"
  91,13,"پیامبر الله [= صالح] به آنان گفت: «ماده‌شترِ الله و [نوبت‌] آب‌خوردنش را [حرمت نهید]»"
  91,14,"[ولی آنان] او را تکذیب کردند و آن [ماده‌شتر] را کشتند؛ پس پروردگار آنان به سبب گناهانشان بر سر‌شان عذاب آورد و همگی آنان را با خاک یکسان کرد"
  91,15,"و [الله] از سرانجام آن [کار،] بیم ندارد"
  92,1,"سوگند به شب، هنگامی ‌که [همه چیز را] بپوشانَد،"
  92,2,و سوگند به روز، هنگامی‌ که آشکار شود،
  92,3,و سوگند به ذاتی که نر و ماده را آفرید،
  92,4,"که یقیناً سعی [و تلاش] شما مختلف [و نیک و بد] است"
  92,5,"و اما کسی‌ که [در راه الله] ببخشد و پرهیزگاری نماید"
  92,6,"و [وعدۀ الله و سخنان] نیک را تصدیق کند،"
  92,7,"به زودی انجام [کار خیر و] آسانی [= اعمال نیکو و انفاق در راه الله] را برایش آسان می‌کنیم"
  92,8,و اما کسی‌که بخل ورزد و بی‌نیازی بجوید،
  92,9,"و [وعدۀ الله و سخنانِ] نیک را تکذیب کند،"
  92,10,"به زودی انجام دشواری [= اعمال شر و پلید] را برایش آسان می‌سازیم [و انجام کار خیر را بر او سخت می‌گردانیم]؛"
  92,11,"و در هنگام [مرگ و] ورود به دوزخ، دارایی او سودی به حالش نخواهد داشت"
  92,12,"مسلماً هدایت [بندگان] بر [عهدۀ] ماست"
  92,13,"و محققاً آخرت و دنیا [نیز] از آنِ ماست"
  92,14,من شما را از آتشی شعله‌ور بیم دادم
  92,15,"که جز بدبخت‌ترین [مردم] در آن نیفتد؛"
  92,16,"[همان] کسی ‌که [آیات ما را] تکذیب کرد و روی گرداند"
  92,17,"و به زودی پرهیزگارترین [مردم] از آن دور نگه داشته می‌شود"
  92,18,"[همان] کسی‌که مال خود را [در راه الله] می‌بخشد تا [از گناه] پاک شود"
  92,19,و هیچ كس را به قصد پاداش‌یافتن نعمت نمى‌بخشد؛
  92,20,"مگر [برای] کسبِ رضا [و خشنودی] پروردگار برترش"
  92,21,"و به راستی که [با پاداشِ الله] راضی خواهد شد"
  93,1,سوگند به آغاز روز،
  93,2,و سوگند به شب، هنگامی‌ که آرام گیرد
  93,3,"[که] پروردگارت تو را وانگذاشته و [بر تو] خشم نگرفته است"
  93,4,و مسلماً آخرت برای تو از دنیا بهتر است
  93,5,"و به زودی پروردگارت به تو [و امت تو آنقدر] عطا خواهد کرد که راضی گردی"
  93,6,آیا تو را یتیم نیافت، و پناه داد؟
  93,7,"و تو را [راه‌نایافته و] سرگشته یافت، و هدایت کرد"
  93,8,و تو را فقیر یافت، و بی‌نیاز نمود
  93,9,"پس [تو نیز] یتیم را میازار،"
  93,10,"و [مستمندِ] نیازخواه را مران [و با او خشونت مکن]،"
  93,11,"و نعمت‌های پروردگارت را بازگو کن [و سپاس گزار]"
  94,1,"[ای پیامبر،] آیا ما سینه‌ات را [برای نزول وحی] برایت نگشودیم؟"
  94,2,"و سنگینی [بارِ گناه و دشواریِ رسالت] را از [دوشِ] تو برنداشتیم؟"
  94,3,"همان [باری] که بر پشتت سنگینی می‌کرد"
  94,4,"و [نام و] آوازۀ تو را بلند ساختیم"
  94,5,"مسلماً با [هر] دشواری، آسانی است"
  94,6,"[آری؛] مسلماً با [هر] دشواری، آسانی است"
  94,7,"پس هنگامی‌ که [از کار و امور دنیا] فارغ شدی، [به عبادت پروردگارت] بکوش"
  94,8,"و به سوی پروردگارت راغب [و مشتاق] شو"
  95,1,سوگند به انجیر و زیتون
  95,2,و سوگند به طورِ سینا
  95,3,"و سوگند به این شهر امن [مکه]"
  95,4,"[که] یقیناً ما انسان را در بهترین صورت [و با فطرت پاک] آفریدیم"
  95,5,"سپس او را [که انحراف یافت،] به پست‌ترین [مراحلِ] پَستی برگرداندیم"
  95,6,"مگر کسانی که ایمان آوردند و کار‌های شایسته انجام دادند؛ که پاداشی پایدار برایشان [در پیش] است"
  95,7,"پس [ای انسان،] چه چیزی بعد [از این همه دلایل روشن،] تو را به تکذیب [روز] جزا وا می‌دارد؟"
  95,8,"آیا الله بهترین داور [و حاکم مطلق] نیست؟"
  96,1,"بخوان به نام پروردگارت که [هستی را] آفرید؛"
  96,2,"[همان پروردگاری که] انسان را از خونِ بسته آفرید"
  96,3,"بخوان و پروردگارت [از همه] بزرگوار‌تر است"
  96,4,"[همان] ذاتی ‌که به وسیلۀ قلم [نوشتن] آموخت"
  96,5,"به انسان آنچه را که نمی‌دانست [به تدریج] آموخت"
  96,6,"چنین نیست [که شما می‌پندارید]؛ حقا که انسان طغیان [و سرکشی] می‌کند"
  96,7,"[بعد] از اینکه خود را بی‌نیاز [و توانگر] ببیند"
  96,8,"یقیناً بازگشت [همه] به سوی پروردگار توست"
  96,9,"[ای پیامبر،] آیا دیده‌ای آن کسی [= ابوجهل] را که [از عبادت الله] باز می‌دارد"
  96,10,"بنده‌ای [= محمد] را هنگامی که [کنار کعبه] نماز می‌خواند"
  96,11,"به من خبر بده اگر این [بنده بازداشته‌شده] بر [راه] هدایت باشد"
  96,12,"یا [مردم را] به پرهیزگاری فرمان دهد، [سزای کسی‌ که چنین بنده‌ای را بیازارد چیست؟]"
  96,13,"به من خبر بده اگر این [شخص سرکش، حق را] تکذیب کند و رویگردان شود [آیا سزاوار عذاب نیست؟]"
  96,14,"آیا نمی‌داند که بی‌تردید، الله [همه اعمالش را] می‌بیند؟"
  96,15,"چنین نیست [که او گمان می‌کند]؛ اگر باز نیاید [و دست از شرارت برندارد،] قطعاً موی پیشانی [او] را به شدّت خواهیم گرفت [و به سوی دوزخ خواهیم کشاند]؛"
  96,16,"موی پیشانیِ [همان] دروغگوی خطاکار را"
  96,17,"پس باید هم‌مجلسانش را [به کمک] بخواند"
  96,18,"ما [نیز] آتشبانان [دوزخ] را فرا خواهیم ‌خواند"
  96,19,"چنین نیست [که او می‌پندارد]؛ هرگز او را اطاعت مکن و سجده کن، و [به الله] تقرّب جوی"
  97,1,"همانا ما آن [قرآن] را در شب قدر نازل کردیم"
  97,2,و تو چه دانی شب قدر چیست؟
  97,3,شب قدر، بهتر از هزار ماه است
  97,4,"فرشتگان و روح [= جبرئیل] در آن [شب،] به فرمان پروردگارشان برای [انجام] هر کاری نازل می‌شوند"
  97,5,"[آن شب] تا طلوع فجر، سلامت [و رحمت] است"
  98,1,"کسانی از اهل کتاب و مشرکان ‌که کافر شدند، [از آیین کفر] دست برنمی‌دارند تا اینکه دلیل روشنی برایشان بیاید"
  98,2,"پیامبری از سوی الله [بیاید] که صحیفه‌های پاک را بخواند"
  98,3,"و نوشته‌هایی استوار [و درست] در آن [صحیفه‌ها] است"
  98,4,"و کسانی‌ که به آنان کتاب داده شد [از جمله یهود و نصاری] پراکنده نشدند [و اختلاف نکردند،] مگر بعد از آنکه دلیل روشن برایشان آمد"
  98,5,"و آنان فرمان نیافتند جز اینکه الله را عبادت کنند در حالی ‌که دین [خود] را برای او خالص گردانند [و از شرک و عبادت معبودان باطل،] به توحید روی آورند؛ و نماز برپا دارند و زکات بپردازند؛ و این است آیین راستین و مستقیم"
  98,6,بی‌گمان، کسانی از اهل کتاب و مشرکان ‌که کافر شدند، جاودانه در آتش جهنم خواهند ماند. آنان بدترینِ آفریدگان هستند
  98,7,همانا کسانی که ایمان آوردند و کارهای شایسته انجام دادند، آنان بهترینِ آفریدگان هستند
  98,8,"پاداش آنان نزد پروردگار‌شان، باغ‌های [بهشت] جاویدان است که جویبارها از زیر [درختان] آن جاری است؛ همیشه در آن خواهند ماند؛ الله از [اعمال] آنها راضی است و آنان [نیز] از [پاداشِ] او راضیند؛ و این [مقام و پاداش،] برای کسی است که از پروردگارش بترسد"
  99,1,هنگامی که زمین با شدید‌ترین تکان‌هایش به لرزه درآید
  99,2,و زمین بار‌های سنگینش را بیرون ریزد
  99,3,"و انسان می‌گوید: «آن [= زمین] را چه شده است؟»"
  99,4,"در آن روز، [زمین] تمام خبرهایش را بازگو می‌کند؛"
  99,5,"زیرا که پروردگارت به او [چنین] وحی [و حکم] کرده است"
  99,6,"در آن روز، مردم گروه‌گروه باز می‌گردند تا [نتیجۀ] اعمالشان به آنان نشان داده شود"
  99,7,"آنگاه هر کس به‌ اندازۀ ذره‌ای کار نیک انجام داده باشد، [پاداشِ] آن را می‌بیند؛"
  99,8,"و هر کس به اندازه ذره‌ای کار بد کرده باشد، [کیفرِ] آن را می‌بیند"
  100,1,"سوگند به اسب‌های دونده که نفس‌زنان [به سوی میدان جهاد] پیش می‌روند"
  100,2,"و سوگند به اسب‌هایی که [با برخورد سُم‌هایشان به سنگ‌ها] جرقۀ [آتش] ایجاد می‌کنند"
  100,3,"باز سوگند به اسب‌هایی که در صبحگاهان [بر دشمن] یورش می‌برند"
  100,4,و در آن هنگام گرد و غبار برمی‌انگیزند
  100,5,"آنگاه در دل [سپاه دشمن] می‌تازند"
  100,6,"یقیناً انسان در برابر [نعمت‌های] پروردگارش بسیار ناسپاس است،"
  100,7,"و بی‌گمان، او [خود] بر این [ناسپاسی] گواه است،"
  100,8,"و همانا او علاقۀ فراوانی به مال [دنیا] دارد"
  100,9,"آیا او نمی‌داند که در آن روز، آنچه در گور‌هاست، [همه زنده و] برانگیخته می‌شوند؟"
  100,10,"و آنچه در سینه‌هاست [همه] آشکار می‌گردد"
  100,11,"یقیناً در آن روز، پروردگارشان کاملاً به [وضع و حال] آنان آگاه است"
  101,1,"[آن] فروکوبنده"
  101,2,"[آن] فروکوبنده چیست؟"
  101,3,"و تو چه ‌دانی که [آن] فروکوبنده چیست؟"
  101,4,"روزی‌ که مردم مانند پروانه‌های پراکنده [حیران و سرگردان] خواهند بود"
  101,5,و کوه‌ها مانند پشم رنگینِ حلاجی‌شده خواهند شد
  101,6,"و اما هر کس که [در آن روز،] کفّۀ میزانش سنگین باشد،"
  101,7,"[در بهشت،] در زندگی رضایت‌بخشی خواهد بود"
  101,8,و اما هر کس که کفّۀ میزانش سبک باشد،
  101,9,"[مسکن و] پناهگاهش «هاویه» است"
  101,10,"و تو چه دانی که آن [هاویه] چیست؟"
  101,11,"آتشی است سوزان [و شعله‌ور]"
  102,1,"زیاده‌خواهی، شما را به خود مشغول [و از یادِ پروردگار غافل] ساخت"
  102,2,"تا [پایانِ] كارتان به گورستان رسید"
  102,3,"هرگز چنین نیست [که شما می‌پندارید]؛ به زودی خواهید دانست"
  102,4,"باز [هم] چنین نیست؛ به زودی خواهید دانست"
  102,5,"چنین نیست [که شما گمان می‌کنید]؛ اگر به دانشِ یقینی [و تردیدناپذیر، حقیقتِ قیامت را] می‌دانستید، [از زیاده‌خواهی و افتخار به اموال و فرزندانتان دست برمی‌داشتید]"
  102,6,سوگند که دوزخ را خواهید دید
  102,7,باز هم سوگند که آن را با چشم یقین خواهید دید؛
  102,8,"آنگاه قطعاً در آن روز، از [تمام] نعمت‌ها بازخواست خواهید شد"
  103,1,سوگند به عصر
  103,2,که انسان در زیان است
  103,3,مگر مؤمنان نیکوکاری که یکدیگر را به حق سفارش نموده‌اند و به شکیبایی توصیه کرده‌اند
  104,1,"وای بر هر غیبت‌کننده [و] عیبجوی‌"
  104,2,"[همان] کسی که مال فراونی گرد می‌آورد و آن را بارها می‌شمارد"
  104,3,گمان می‌کند که مالَش او را جاودانه می‌سازد
  104,4,"هرگز چنین نیست [که او گمان می‌کند]؛ قطعاً در آتشِ درهم‌کوبنده انداخته خواهد شد"
  104,5,"و [ای پیامبر،] تو چه می‌دانی که آتشِ درهم‌کوبنده چیست؟"
  104,6,آتش برافروختۀ الهی است؛
  104,7,"[آتشی] که بر دل‌ها چیره می‌گردد [و می‌سوزانَد]"
  104,8,"بی‌گمان، آن [آتش] بر آنان بسته شده [و از هر سو محاصره‌شان کرده] است"
  104,9,"[افروخته] در ستون‌های بلند است"
  105,1,"[ای پیامبر،] آیا ندیدی پروردگارت با اصحاب فیل چه کرد؟"
  105,2,"آیا [فریب و] نقشۀ آنان را در تباهی قرار نداد؟"
  105,3,"و پرندگانی گروه‌گروه بر [سر] آنان فرستاد"
  105,4,"[که] با سنگ‌گِل [که در منقار و چنگال داشتند] آنان را سنگباران می‌کردند؛"
  105,5,و آنها را همچون کاهِ جویده‌شده ساخت
  106,1,"برای [سپاسگزاری از] همبستگی و اُنس قریش،"
  106,2,"[همان] همبستگی و اُنسِ آنان در سفر‌های زمستانی [به یَمَن] و تابستانی [به شام]؛"
  106,3,باید پروردگارِ خانۀ کعبه را عبادت کنند؛
  106,4,"همان [پروردگاری] که آنان را از گرسنگی [رهانید، به آنان] خوراک داد و از وحشت و ترس ایمن نمود"
  107,1,"[ای پیامبر،] آیا کسی را که [روز] جزا را تکذیب می‌کنند، دیده‌ای؟"
  107,2,"او [همان] کسی است ‌که یتیم را [با خشونت از خود] می‌رانَد"
  107,3,"و [دیگران را] به اطعامِ مسکین تشویق نمی‌کند"
  107,4,پس وای بر نمازگزاران
  107,5,همان کسانی ‌که از نمازشان غافلند
  107,6,کسانی ‌که خودنمایی می‌کنند
  107,7,"و [از امانت دادنِ] وسایل ضروری زندگی دریغ می‌ورزند"
  108,1,"[ای پیامبر،] به راستی که ما خیرِ بی‌نهایت [از جمله رود کوثر در بهشت را] به تو عطا کردیم؛"
  108,2,پس برای پروردگارت نماز بخوان و قربانی کن
  108,3,"بی‌تردید، دشمنت [از همۀ خیرات و برکات و نام و نشان، بی‌بهره و] بُریده است"
  109,1,"[ای پیامبر،] بگو: «ای کافران،"
  109,2,آنچه را که شما عبادت می‌کنید، من عبادت نمی‌کنم،
  109,3,"و [نیز] آنچه را که من عبادت می‌کنم شما عبادت نمی‌کنید"
  109,4,و نه من عبادت‌کننده آنچه شما عبادت کرده‌اید خواهم بود؛
  109,5,و نه شما عبادت‌کننده آنچه من عبادت می‌کنم خواهید بود
  109,6,"[بنابراین] آیین شما [که آن را برای خویش ساخته‌اید] برای خود‌تان باد و آیین من [که الله آن را بر من فرستاده است] برای خودم»"
  110,1,"[ای پیامبر،] هنگامی ‌که یاری الله و پیروزی فرا رسد [و فتح مکه رخ دهد]،"
  110,2,و مردم را ببینی که گروه‌گروه در دین الله داخل می‌شوند
  110,3,پس به ستایش پروردگارت تسبیح گوی و از او آمرزش بخواه؛ همانا او بسیار توبه‌پذیر است
  111,1,بریده باد هر دو دست اَبولَهَب و هلاک باد خودش
  111,2,"مال و ثروتش و آنچه به دست آورده بود، او را بی‌نیاز نساخت [و برایش سودی نبخشید]"
  111,3,به زودی به آتش شعله‌ور درخواهد آمد؛
  111,4,"و همسرش [اُمّ‌جمیل، آن] هیزم‌کش [آتش‌افروز نیز وارد آتش دوزخ می‌شود]"
  111,5,"[در حالی که] طنابی از لیفِ خرما بر گردنش است"
  112,1,"[ای پیامبر] بگو: «او الله یکتا و یگانه است"
  112,2,"الله بی‌نیاز است [و همه نیازمند او هستند]"
  112,3,"نه [فرزندی] زاده و نه [از کسی] زاده شده است"
  112,4,و هیچ کس همانند و همتای او نبوده و نیست»
  113,1,"[ای پیامبر،] بگو: «به پروردگار سپیده‌دم پناه می‌برم،"
  113,2,از شرِ تمام آنچه آفریده است،
  113,3,و از شر تاریکی شب، آنگاه که همه جا را فراگیرد،
  113,4,"و از شر [زنان جادوگر] که با افسون در گره‌ها می‌دمند"
  113,5,"و از شر [هر] حسود، آنگاه که حسد ورزد»"
  114,1,"[ای پیامبر،] بگو: «به پروردگار مردم پناه می‌برم،"
  114,2,فرمانروای مردم،
  114,3,معبود مردم،
  114,4,"از شرِ [شیطانِ] وسوسه‌گر که [به هنگام ذکر الله،] پنهان می‌گردد؛"
  114,5,"همان [وسوسه‌گری] که در دل‌های مردم وسوسه می‌کند؛"
  114,6,"از جنیان [باشد] و [یا از] آدمیان»"