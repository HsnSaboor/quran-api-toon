quran[227]{c,v,t}:
  15,1,"الر [= الف. لام. را]. این آیات كتاب [الهى] و قرآنِ روشنگر است"
  15,2,"چه بسا کافران [هنگام مواجهه با عذاب قیامت] آرزو ‌کنند که کاش مسلمان بودند"
  15,3,"بگذار بخورند و [از لذت‌های دنیا] بهره‌مند شوند و آرزوها[ی مادّی،] سرگرمشان سازد؛ پس به زودی خواهند دانست"
  15,4,"ما [ساکنان] هیچ [شهر و] دیاری را هلاک نکردیم؛ مگر اینکه [مهلت و] اَجلی معیّن داشتند"
  15,5,"هیچ امتى از اَجلِ [مقررِ] خود نه پیشى می‌گیرد و نه [از آن] عقب می‌مانَد"
  15,6,"[کافران] گفتند: «ای کسی‌ که [ادعا می‌کنی] قرآن بر تو نازل شده است، یقیناً تو دیوانه‌ای"
  15,7,"اگر راست می‌گویی، چرا فرشتگان را نزدمان نمی‌آوری [تا دربارۀ پیامبری‌ات گواهی دهند]؟»"
  15,8,"[باید بدانند که‌] ما فرشتگان را به‌حق [و فقط در هنگام عذاب کافران] نازل می‌کنیم؛ و [اگر برای عذابشان نازل شوند] دیگر مهلتی نمی‌یابند"
  15,9,"به راستی که ما خود، قرآن را نازل کردیم و قطعاً خودمان نیز نگهبان آن [از هر گونه تبدیل و تحریفی] هستیم"
  15,10,"[ای پیامبر،] پیش از تو نیز [رسولان خود را] میان گروه‌های پیشین فرستادیم"
  15,11,هیچ پیامبری نزدشان نمی‌آمد، مگر آنکه مسخره‌اش می‌کردند
  15,12,"اینچنین آن [تکذیب و تمسخر] را در دل‌های گناهکاران [= کافران] راه می‌دهیم"
  15,13,"آنان به آن [قرآن] ایمان نمی‌آورند؛ و شیوۀ [الله در مجازات] پیشینیان [نیز چنین] رفته است [كه آنان را با عذابی دردناک هلاک نماید]"
  15,14,"و [حتی] اگر دری از آسمان به روی آنان می‌گشودیم تا پیوسته در آن بالا روند [و شگفتی‌های ملکوت را ببینند]،"
  15,15,"یقیناً باز هم می‌گفتند: «بی‌تردید، ما را چشم‌بندی کرده‌اند؛ بلکه ما گروهی جادو‌شده‌ایم»"
  15,16,و به راستی، ما برجهایی در آسمان قرار داده‌ایم و آن را برای تماشاگران آراسته‌ایم
  15,17,"و آن [= آسمان] را از [ورود و دستبردِ] هر شیطانِ رانده‌شده‌ای حفظ کردیم"
  15,18,"مگر آن کس که دزدانه سخنی [از ملکوتیان] بشنود که [در آن صورت،] شهابی روشن او را دنبال می‌کند [و می‌سوزاند]"
  15,19,"و زمین را گستردیم و کوه‌های استواری در آن افکندیم و از هر گیاه سنجیده [و مناسبی] در آن رویاندیم"
  15,20,و براى شما و کسانی كه روزى‌دهنده آنان نیستید اسباب زندگی در آن قرار دادیم
  15,21,و هیچ چیز نیست، مگر آنکه گنجینه‌هایش نزد ماست و ما آن را جز به ‌اندازه‌ای معیّن فرو نمی‌فرستیم
  15,22,"و بادها را بارورکننده[ی ابرها] فرستادیم، سپس آبی از آسمان‌ها نازل کردیم و شما را با آن سیراب ساختیم؛ در حالى كه شما ذخیره‌كننده‌اش نیستید"
  15,23,"و یقیناً ماییم که زنده می‌کنیم و می‌میرانیم، و ما [بازماندۀ جاوید و] وارث [همۀ جهانیان] هستیم"
  15,24,"و بی‌تردید، [تولد و مرگ] گذشتگان شما را دانسته‌ایم و یقیناً [تولد و مرگ] آیندگان را [نیز به خوبی] می‌دانیم"
  15,25,"و [ای پیامبر،] بی‌گمان، پروردگارت [همۀ] آنان را [در قیامت] محشور می‌کند. به راستی که او حکیم داناست"
  15,26,"و در حقیقت، ما [نخستین] انسان [= آدم] را از گِلِ خشک [بازمانده] از لجنی بدبو آفریدیم‌"
  15,27,و پیش از آن، جن را از آتشی سوزان و بى‌دود آفریدیم
  15,28,"و [یاد کن] از هنگامی که پروردگارت به فرشتگان فرمود: «همانا من بشری را از گِلِ خشک [بازمانده] از لجنی بدبو خواهم آفرید"
  15,29,"پس چون [او را آفریدم و] به او سامان دادم و از روح خویش در وی دمیدم، [به نشانۀ اطاعت از فرمان من، همگی] بر او سجده کنید»"
  15,30,فرشتگان همگی سجده کردند،
  15,31,مگر ابلیس که سرپیچی کرد از اینکه با سجده‌کنندگان باشد
  15,32,"[الله] فرمود: «ای ابلیس، چرا تو با سجده‌کنندگان [همراه] نیستی؟»"
  15,33,"[ابلیس] گفت: «من آن نیستم که برای بشری که او را از گِلِ خشک [بازمانده] از لجنی بدبو آفریده‌ای سجده ‌کنم»"
  15,34,"[الله] فرمود: «از آنجا [= بهشت] بیرون شو [که] بی‌تردید، تو [از بارگاهِ ما] رانده‌شده‌ای"
  15,35,و یقیناً تا روز قیامت بر تو لعنت خواهد بود»
  15,36,"[ابلیس] گفت: «پروردگارا، تا روزی ‌که [مردم] برانگیخته می‌شوند به من مهلت بده [و مرا نمیران]»"
  15,37,"[الله] فرمود: «[برو که] یقیناً تو از مهلت‌یافتگانی،"
  15,38,"تا روزِ آن وقتِ معلوم [که تمام مخلوقات با نفخۀ نخست می‌میرند]»"
  15,39,"[او] گفت: «پروردگارا، به سببِ آنکه مرا گمراه ساختی، [من نیز] در زمین [بدی‌ها را] در نظرشان نیک جلوه می‌دهم و همۀ آنان را به گمراهی می‌کشانم؛"
  15,40,"مگر بندگان خالصِ تو از [میان] آنان، [که هدایتشان کرده‌ای]»"
  15,41,"[الله] فرمود: «این [اخلاص،] راه مستقیمی است [که به من می‌رسد]"
  15,42,"یقیناً تو بر بندگانم تسلطی نداری، مگر [بر آن مشرکان و] گمراهانی که از تو پیروی می‌کنند"
  15,43,و بی‌تردید، دوزخ وعده‌گاه همۀ آنان است
  15,44,"[دوزخ] هفت در دارد [و] برای هر دری، گروهی از آنان تقسیم [و مشخص] شده‌اند»"
  15,45,"یقیناً پرهیزگاران در باغ‌ها[ی بهشت] و در [کنار] چشمه‌ها هستند"
  15,46,"[هنگام ورود به آنان گفته می‌شود:] «به سلامت و ایمنی به آن [باغ‌ها] وارد شوید»"
  15,47,"آنچه از کینه [و حسد که] در دل‌هایشان است برمی‌کنیم؛ برادرانه بر تخت‌ها مقابل یکدیگرند"
  15,48,در آنجا نه رنجى به آنان مى‌رسد و نه از آنجا بیرون رانده مى‌شوند
  15,49,"[ای پیامبر،] به بندگانم خبر بده که من آمرزندۀ مهربانم"
  15,50,و اینکه عذاب من، عذابی دردناک است
  15,51,"و از مهمانان ابراهیم [نیز] به آنان خبر بده"
  15,52,"هنگامی که بر او وارد شدند، سلام گفتند؛ [اما چون دست به غذا نبردند، ابراهیم‌] گفت: «ما از شما هراسانیم»"
  15,53,"آنان گفتند: «نترس؛ ما تو را به پسری دانا مژده می‌دهیم»"
  15,54,"[ابراهیم] گفت: «آیا با اینكه سالخورده شده‌ام مژده[ی تولد فرزند] به من مى‌دهید؟ به چه [دلیل اینچنین] بشارت مى‌دهید؟»"
  15,55,"آنان گفتند: «ما تو را به درستی بشارت دادیم؛ پس ناامید نباش»"
  15,56,"[ابراهیم] گفت: «و جز گمراهان، چه کسی از رحمتِ پروردگارش ناامید می‌گردد؟»"
  15,57,"[آنگاه به فرشتگان] گفت: «اى فرستادگان، كار [و مأموریت دیگر] شما چیست؟»"
  15,58,"آنان گفتند: «در حقیقت، ما به سوی قوم گنهکار [لوط] فرستاده شده‌ایم [تا هلاکشان کنیم]"
  15,59,مگر خانوادۀ لوط که ما یقیناً همۀ آنان را نجات خواهیم داد
  15,60,"جز همسرش که مقدر کرده‌ایم از بازماندگان [در عذاب] باشد»"
  15,61,"هنگامی‌ که فرستادگان [الله به شکل انسان] نزد خاندان لوط آمدند،"
  15,62,"[لوط] گفت: «شما گروهی ناشناس هستید»"
  15,63,"[فرشتگان] گفتند: «بلکه ما همان چیزی را برایت آورده‌ایم كه [این مردم گناهکار] درباره‌اش تردید مى‌كردند [= نزول عذاب]"
  15,64,"و ما برایت [خبرِ حقیقی و] راست آورده‌ایم و قطعاً ما راستگوییم"
  15,65,"پس پاسی از شب [که گذشت] خانواده‌ات را [از این جا] ببر و [خودت] به دنبالشان برو؛ و هیچ‌یک از شما [نباید] پشت سرش را نگاه نکند و به جایی که به شما فرمان می‌دهند بروید»"
  15,66,"و ما او [= لوط] را از این امر آگاه كردیم که صبحگاهان ریشۀ آنان برکنده خواهد شد"
  15,67,"و اهالی شهر، در حالی که [دربارۀ آمدن افراد جدید] با شادی‌ [به یکدیگر] خبر می‌دادند [به سوی خانۀ لوط] آمدند"
  15,68,"[لوط] گفت: «اینها مهمانان من هستند؛ پس مرا رسوا [و شرمندۀ مهمانانم] نکنید،"
  15,69,و از الله بترسید و سرشکسته‌ام نسازید»
  15,70,"[آنان] گفتند: «مگر ما تو را از [میزبانیِ] افراد [بیگانه] نهی نکردیم؟»"
  15,71,"[لوط] گفت: «اگر مى‌خواهید [كارى حلال‌] انجام دهید، اینها دختران [قوم] من هستند؛ [با آنها ازدواج كنید]»"
  15,72,"سوگند به جان تو [ای پیامبر] که آنان در مستیِ خویش سرگشته بودند"
  15,73,"پس هنگام برآمدنِ آفتاب، بانگ [مرگبار] آنان را فراگرفت"
  15,74,"آنگاه آن [سرزمین] را زیر و رو کردیم و سنگ‌گل‌هایی پیاپی بر آنان باریدیم"
  15,75,"به یقین، در این [كیفر،] براى هوشیاران عبرت‌هاست"
  15,76,"و [آثار] آن [شهرهای ویرانه، هنوز] بر سر راه [مسافران] پابرجاست"
  15,77,"یقیناً در این [عذاب،] نشانه‌ای برای [عبرت گرفتنِ] مؤمنان است"
  15,78,"و اصحاب اَیکه [= قوم شعیب] قطعاً ستمکار بودند"
  15,79,"[ما] از آنان انتقام گرفتیم و [شهرهای ویران‌شدۀ] این دو [قوم،] بر سر راه آشکار است"
  15,80,"و بی‌تردید، اهل حِجر [= قوم ثمود] پیامبران را دروغگو انگاشتند"
  15,81,"و [ما معجزات و] نشانه‌های خود را به آنان دادیم، و[لی] از آنها رویگردان شدند"
  15,82,"و از کوه‌ها خانه‌هایی [برای خود] می‌تراشیدند که در امان بمانند"
  15,83,"پس صبحگاهان بانگ [مرگبار] آنان را فراگرفت"
  15,84,"و آنچه [از اموال و خانه‌های محکم] به دست آورده بودند، سودی به حالشان نداشت [و عذاب الهی را دفع نکرد]"
  15,85,"و ما آسمان‌ها و زمین و آنچه را که میان آنهاست جز به‌حق نیافریده‌ایم؛ و قیامت قطعاً آمدنی است؛ پس [ای پیامبر، از کافران‌] به نیکویی گذشت کن.‌"
  15,86,بی‌تردید، پروردگارت همان آفریدگارِ داناست. ‌
  15,87,"و به راستی، ما به تو «سبعُ المثانی» [= سورۀ فاتحه] و قرآن بزرگ را دادیم"
  15,88,"[بنابراین،] هرگز به آنچه [از نعمت‌های دنیوی] که گروه‌هایی از آنان [= کافران] را بهره‌مند کرده‌ایم چشم ندوز و به خاطر [ناسپاسی و شرکِ] آنان اندوهگین نباش و با مؤمنان فروتنی کن"
  15,89,"و بگو: «به راستی که من همان بیم‌دهندۀ آشکارم»"
  15,90,"[و آنان را از عذاب بترسان] همان گونه که [آن را] بر تقسیم‌کنندگان [آیات الهی] فرستادیم؛"
  15,91,"همان کسانی كه قرآن را بخش بخش کردند [و آن را شعر، سحر، کذب، و اساطیر ‌نامیدند]"
  15,92,"سوگند به پروردگارت، قطعاً [در قیامت] از همۀ آنان سؤال خواهیم کرد،"
  15,93,از آنچه می‌کردند
  15,94,"پس [ای پیامبر،] آنچه [را که از سوی الله] دستور یافته‌ای، آشکار کن و از مشرکان روی بگردان‌"
  15,95,"بی‌تردید، ما [شرّ] مسخره‌کنندگان را از تو دور می‌کنیم"
  15,96,"همان کسانی که [برای خود،] با الله، معبود دیگری قرار می‌دهند؛ پس به زودی [نتیجۀ شرکِ خویش را] خواهند دانست"
  15,97,"و [ای پیامبر،] یقیناً ما می‌دانیم که تو از آنچه آنان [= کافران] می‌گویند آزرده‌خاطر می‌گردی"
  15,98,پس به ستایش پروردگارت تسبیح بگو و از سجده‌کنندگان باش
  15,99,و تا هنگامی‌ که مرگت فرامی‌رسد پروردگارت را عبادت کن
  16,1,"[ای کافران، لحظۀ وقوع قیامت و] فرمانِ الله [برای عذابتان] نزدیک شده است؛ پس برای [رسیدنِ] آن شتاب نکنید. او منزّه است و از چیزهایی که با وی شریک می‌سازند برتر است"
  16,2,"[الله] به فرمان خویش فرشتگان را با وحی بر هر ‌یک از بندگانش که بخواهد نازل می‌کند [با این پیام] که: «[ای پیامبران، مردم را از شرک به الله] بیم دهید [و به آنان بگویید که] معبودی [به‌حق] جز من نیست؛ پس [ای مردم،] از من پروا کنید»"
  16,3,"او تعالی آسمان‌ها و زمین را به‌حق [و هدفمند] آفرید [و] از چیزهایی که [با وى‌] شریک مى‌سازند برتر است"
  16,4,"[الله] انسان را از نطفه‌ای آفرید و ناگهان او ستیزه‌گری سرسخت و آشکار شد"
  16,5,"و چهارپایان را برایتان آفرید که در آنها پوشش [گرم] و منافع [دیگری] است و از [گوشت برخی از] آنها می‌خورید"
  16,6,"و در آنها زیبایى [و شكوه‌] برایتان است، آنگاه كه [آنها را شامگاهان] از چَرا بازمى‌آورید و [بامدادان] برای چَرا [به صحرا] مى‌فرستید"
  16,7,"[آنها] بارهاى سنگین شما را [از شهری] به شهرى [دیگر] مى‌بَرند كه [اگر چنین نمی‌کردند،] جز با زحمتی جانکاه نمى‌توانستید به آنجا برسید. به راستی که پروردگارتان دلسوز و مهربان است"
  16,8,"و اسبان و قاطِران و خران را [نیز آفرید] تا بر آنها سوار شوید و [نیز برایتان مایۀ] تجمل [است] و چیزهایی می‌آفریند که نمی‌دانید"
  16,9,"بر الله است که راهِ راست [= اسلام] را [به بند‌گانش بنمایاند] و برخی از آن [راه‌ها] بیراهه است؛ و اگر [الله] می‌خواست، همۀ شما را هدایت می‌کرد"
  16,10,"او همان ذاتی است که آبی از آسمان فروفرستاد که آشامیدنیِ شما از آن است و [گیاه و] درختی كه [چهارپایان خود را] در آن مى‌چرانید [نیز] از آن [آب] است"
  16,11,"[الله] به وسیله آن، كِشت و زیتون و درختان خرما و انگور و همه نوع محصولات [و میوه‌های دیگر] برایتان مى‌رویانَد. به راستی که در اینها براى مردمی که می‌اندیشند نشانه‌اى [از قدرت پروردگار] است"
  16,12,"و شب و روز و خورشید و ماه را به خدمتتان گماشت؛ و ستارگان [نیز] به فرمانش در خدمت [انسان] هستند. بی‌تردید، در این [آفرینش،] برای مردم كه خردورزی می‌کنند نشانه‌ای [از قدرت پروردگار] است"
  16,13,"و آنچه را که در زمین به رنگ‌های گوناگون برایتان آفرید [نیز به خدمت شما گماشت‌]. بى‌تردید، در این [امور،] براى مردمى كه پند مى‌گیرند، نشانه‌اى [از قدرت پروردگار] است"
  16,14,"اوست كه دریا را به خدمتتان گماشت تا از [صیدِ] آن، گوشت تازه بخورید و زیورى [همچون مروارید و مرجان] از آن بیرون مى‌آورید که می‌پوشید؛ و کشتی‌ها را در آن [دریا] مى‌بینى كه [امواج را] مى‌شكافند تا شما از فضل [و بخشش] الله بهره‌مند گردید و باشد كه سپاس گزارید"
  16,15,"و کوه‌های استوار [و محکمی] در زمین درافکند که مبادا شما را بلرزاند و جویبارها و راه‌ها[یی پدید آورد] تا [بدون گم‌شدن،] راه خود را بیابید"
  16,16,"و نشانه‌هایى [برای یافتن مسیرها در طول روز آفرید] و توسط ستاره[ها نیز در شب] راه‌یابی مى‌كنند"
  16,17,"آیا آن ذاتی که می‌آفریند همچون کسی است که [هیچ] نمی‌آفریند؟ آیا پند نمی‌گیرید؟"
  16,18,"اگر [بخواهید] نعمت[های] الله را بشمارید، نمی‌توانید آنها را به شمارش درآورید. بی‌تردید، الله آمرزندۀ مهربان است"
  16,19,"و الله آنچه پنهان می‌کنید و آشکار می‌سازید، [همه را] می‌داند"
  16,20,"و آنهایی را که [مشرکان] به جای الله [به یاری و دعا] می‌خوانند، چیزی را نمی‌آفرینند و خود آفریده می‌شوند"
  16,21,"[این معبود‌ها در حقیقت،] مُرده‌اند نه زنده؛ و خود نمی‌دانند که چه هنگام برانگیخته می‌شوند"
  16,22,"معبود شما، معبودی یگانه است؛ و کسانی‌ که به آخرت ایمان ندارند، دل‌هایشان انکارکننده[ی حق] است و خود متکبرند"
  16,23,"قطعاً الله آنچه را پنهان می‌کنند و آشکار می‌سازند [همه را] می‌داند. بی‌تردید، او متکبران را دوست ندارد"
  16,24,"هنگامی که به آنان گفته می‌شود: «پروردگارتان چه چیزی نازل کرده است؟» می‌گویند: «افسانه‌های [خیالی] پیشینیان»"
  16,25,"[همچنان در کفر می‌مانند] تا روز قیامت، [هم] بارِ گناهان خود را به تمامی بر دوش کشند و [هم بخشی] از بارِ گناهان کسانی را که از روی نادانی [و تقلید] گمراهشان کرده‌اند. هان! چه بد است آنچه بر دوش می‌کشند"
  16,26,"در حقیقت، کسانی که پیش از آنان بودند [نیز] نیرنگ [و بداندیشی] کردند؛ اما فرمان الله دررسید که بنیادشان را از اساس برانداخت و سقف بر سرشان فرو ریخت و از [همان] جایی که گمان نمی‌کردند عذاب دامنگیرشان شد"
  16,27,"سپس روز قیامت، [الله با عذابی دردناک،] آنان را خوار می‌سازد و می‌فرماید: «کجا هستند شریکان من که دربارۀ آنان [با پیامبران و مؤمنان] ستیز می‌کردید؟» کسانی که به آنان علم داده شده است [= علمای ربانی] می‌گویند: «امروز خواری و عذاب، نصیب کافران است»"
  16,28,"[همان] کسانی ‌که فرشتگان [عذاب،] در حالی‌ جانشان را می‌گیرند که [به سبب شرک در دنیا] به خود ستم کرده بودند. [آنان در هنگام مرگ] سرِ تسلیم فرود می‌آورند [و می‌گویند:] «ما هیچ [کارِ] بدی نمی‌کردیم. آری، مسلماً الله به آنچه می‌کردید داناست"
  16,29,"پس، از دروازه‌های دوزخ وارد شوید [که] جاودانه در آن خواهید بود؛ و به راستی، جایگاه گردنکشان چه بد است‌"
  16,30,"و به کسانی‌ که پرهیزگاری کردند گفته می‌شود: «پروردگارتان [بر پیامبر] چه چیز نازل کرده است؟» آنان می‌گویند: «خیر [و نیکوییِ بسیار]». براى كسانى كه در این دنیا نیكى كرده‌اند، [پاداش‌] نیكویى است و قطعاً سراى آخرت بهتر است؛ و به راستی، چه نیكوست سراى پرهیزگاران"
  16,31,"[جایگاهشان،] باغ‌هایی [از بهشت] جاودان است که به آن وارد می‌شوند. از زیر [درختان] آن جویبارها جاری است [و] در آنجا هر چه بخواهند برایشان [فراهم] است. الله پرهیزگاران را اینچنین پاداش می‌دهد"
  16,32,"[همان] كسانى كه فرشتگان در حالى جانشان را مى‌ستانند كه [از آلودگیِ کفر و گناه] پاكند [و به آنان‌] مى‌گویند: «درود بر شما. به [پاداش‌] آنچه می‌کردید [اینک] به بهشت درآیید»"
  16,33,"آیا [کافران] جز این انتظار دارند که فرشتگان [برای قبض روح] به سراغشان بیایند یا فرمان پروردگارت [برای عذابشان] بیاید؟ کسانی ‌که پیش از آنان بودند [نیز] چنین می‌کردند و الله به آنان ستم نکرد؛ بلکه آنان خود به خویشتن ستم می‌کردند"
  16,34,"پس [كیفر] بدی‌هایی كه مرتکب شده بودند گریبانگیرشان شد و آنچه که آن را مسخره مى‌كردند آنان را فروگرفت"
  16,35,"و کسانی‌ که شرک ورزیدند گفتند: «اگر الله مى‌خواست، نه ما و نه پدرانمان چیزى را غیر از او عبادت نمی‌کردیم و چیزى را جز به [خواست و فرمان] او حرام نمى‌كردیم». كسانى كه پیش از آنان بودند نیز چنین کردند؛ پس آیا پیامبران وظیفه‌ای جز رساندن آشكار [وحی] دارند؟"
  16,36,"یقیناً ما در هر امتی، پیامبری را [با این پیام] برانگیختیم که: «الله یکتا را عبادت کنید و از طاغوت [= معبودان غیر الله] دوری کنید». الله برخی از آنان را هدایت كرده است و برخی از آنان نیز سزاوار گمراهى شدند. پس در زمین بگردید و بنگرید که سرانجامِ تكذیب‌كنندگان [آیات الهی] چگونه بوده است"
  16,37,"[ای پیامبر،] هر اندازه بر هدایت آنان مشتاق باشی [سودی ندارد؛ زیرا] الله کسی را که گمراه نماید، هدایت نخواهد کرد و آنان [هیچ] یاوری ندارند"
  16,38,"[مشرکان] با سخت‌ترین سوگندهایشان به الله سوگند خوردند که: «الله کسی را که می‌میرد برنمی‌انگیزد». آری، این [برانگیختنِ مردگان]، وعده‌ای است که به‌حق بر عهدۀ اوست؛ ولی بیشتر مردم نمی‌دانند"
  16,39,"[او مردگان را زنده می‌کند] تا سرانجام [حقیقتِ] آنچه را که در آن اختلاف می‌کنند برایشان روشن سازد و تا کسانی ‌که کفر ورزیدند بدانند که دروغگو بوده‌اند"
  16,40,"سخن ما دربارۀ چیزی که آن را اراده کرده‌ایم فقط این است که به آن می‌گوییم: «موجود شو»، پس بی‌درنگ موجود می‌شود"
  16,41,"و کسانی که در [راه] الله ـ پس از آنكه مورد ستم واقع شدندـ هجرت کردند، قطعاً در دنیا [در سرزمین‌ و] مکانی نیکو آنان را جای می‌دهیم؛ و یقیناً پاداش آخرت بزرگ‌تر است‌. اگر [کسانی که از هجرت امتناع کردند، پاداش این کار را] می‌دانستند، [هرگز از هجرت بازنمی‌ماندند]"
  16,42,"[مهاجران در راه الله،] کسانی‌ [هستند] که شکیبایی نمودند و بر پروردگار‌شان توکل می‌کنند"
  16,43,"و [ای پیامبر،] ما پیش از تو جز مردانی که به آنان وحی می‌کردیم [کسی را به رسالت] نفرستادیم؛ پس [ای مشرکان،] اگر نمی‌دانید، از اهل ذکر [= دانشمندان اهل کتاب] بپرسید"
  16,44,"[آن پیامبران را] با دلایل روشن و کتاب‌ها[ی آسمانی فرستادیم]؛ و [ما این] قرآن را بر تو نازل کردیم تا برای مردم آنچه را که برایشان نازل شده است روشن سازی؛ باشد که [در مفاهیمش] بیندیشند"
  16,45,"آیا کسانی‌ که بداندیشی [و توطئه] کردند، ایمن هستند [از این] که الله [همۀ] آنان را در زمین فروبَرد یا عذاب [الهی] از جایی که نمی‌دانند [به سراغشان] بیاید؟"
  16,46,"یا [آنکه] به هنگام رفت و آمدشان [گریبان] آنان را بگیرد؟ پس آنان مانع [رسیدن عذاب] نیستند"
  16,47,"یا [آنکه عذاب الهی] در حالی که [از آن] می‌ترسند گریبانگیرشان شود؟ پس بی‌تردید، پروردگارتان دلسوزِ مهربان است [که در مجازات شما شتاب نمی‌کند]"
  16,48,"آیا آنان به چیزهایی [همچون درختان و کوه‌ها] که الله آفریده است نمی‌نگرند که [چگونه با حرکت خورشید و ماه] سایه‌هایشان از راست و چپ می‌گسترد و در حالی برای الله سجده می‌کنند که [در برابر عظمتش] خاکسارند؟"
  16,49,"و هر چه در آسمان‌ها و زمین است ـ از جنبندگان و فرشتگان‌ـ [همگی] برای الله سجده می‌آورند و گردنکشی نمی‌کنند"
  16,50,"[فرشتگان] از پروردگار خویش كه [به ذات و غلبه و قدرتش] بالای آنان است مى‌ترسند و آنچه را فرمان داده مى‌شوند انجام می‌دهند"
  16,51,"و الله فرمود: «دو معبود [را براى خود به عبادت] نگیرید. جز این نیست كه [معبود شما] همان الله یکتاست؛ پس تنها از من پروا کنید»"
  16,52,"و آنچه در آسمان‌ها و زمین است، از آنِ اوست و عبادت و فرمانبردارى [نیز] همیشه و پیوسته براى اوست. آیا از غیر الله پروا می‌کنید؟"
  16,53,"و [ای مردم،] هر نعمتی که دارید، از سوی الله است؛ به علاوه، وقتی گزندی به شما می‌رسد، به پیشگاه او ناله و زاری می‌کنید"
  16,54,سپس وقتی آن گزند را از شما برطرف ساخت، گروهی از شما به پروردگارشان شرک می‌ورزند
  16,55,"تا سرانجام به آنچه به آنان داده‌ایم ناسپاسی کنند. پس [چند روزی از نعمت‌های دنیا] برخوردار شوید که به زودی [نتایج کردارتان را] خواهید دانست"
  16,56,"و [مشرکان‌] از آنچه روزی‌شان کرده‌ایم، برای معبودانی که [چیزی] نمی‌دانند سهمی قرار می‌دهند. به الله سوگند که دربارۀ آنچه افترا می‌بستید، قطعاً بازخواست خواهید شد"
  16,57,"و [آنان فرشتگان را] دخترانی برای الله قرار می‌دهند ـ او تعالی منزّه است‌ ـ و آنچه را میل دارند [= پسران] برای خودشان [قرار می‌دهند]"
  16,58,"و هر گاه یکی از آنان را به [تولد] دختری بشارت دهند، در حالی ‌که خشمش را فرومی‌خورد، چهره‌اش [از اندوه] تیره می‌شود"
  16,59,"از بدی [و ناراحتیِ] آنچه به او مژده داده‌اند، از قوم [خویش] پنهان می‌شود [و با خود می‌اندیشد که] آیا او را با سرافکندگی نگه دارد یا در خاک پنهانش کند. هان! چه بد داورى مى‌كنند"
  16,60,"صفت زشت [جهل و کفر] براى كسانى است كه به آخرت ایمان ندارند و صفتِ برتر، از آنِ الله است و او شکست‌ناپذیرِ حكیم است"
  16,61,"و اگر الله مردم را به خاطر ظلمشان بازخواست مى‌كرد، جنبنده‌اى روى زمین باقى نمى‌گذاشت؛ ولی [كیفرِ] آنان را تا زمانی معیّن به تأخیر مى‌اندازد؛ و چون اَجَلشان به سر آید، نه ساعتى [از آن‌] تأخیر می‌كنند و نه پیشى می‌گیرند"
  16,62,"و [مشرکان] آنچه را نمی‌پسندند برای الله قرار می‌دهند و زبانشان [چنین] دروغ مى‌سازد كه [رستگاری و] نیكویی از آنِ آنان است. حقا که آتش نصیبشان است و آنان قطعاً در [دوزخ] رها [و فراموش] می‌شوند"
  16,63,"[ای پیامبر،] سوگند به الله كه به سوى امت‌هایی که پیش از تو بودند [نیز پیامبرانی‌] فرستادیم؛ اما شیطان کارهایشان را برایشان آراست؛ از این رو، امروز [نیز‌ دوست و] کارسازشان همو[= شیطان] است و برایشان عذابى دردناک [در پیش] است"
  16,64,"و [ای پیامبر،] این كتاب را بر تو نازل نكردیم مگر برای اینكه [حقیقتِ] آنچه را که [مردم] در آن اختلاف دارند برایشان بیان كنى و هدایت و رحمتى باشد براى گروهی كه ایمان مى‌آورند"
  16,65,"و الله آبی از آسمان فرو فرستاد و با آن، زمین را پس از خزان و خشکی‌اش زنده كرد. قطعاً در این [امر] براى مردمى كه [سخن حق را] می‌شنوند، نشانه‌ای [از قدرت پروردگار] است"
  16,66,"و [ای مردم،] قطعاً در [آفرینش] چهارپایان عبرتى برای شماست: از آنچه در شكمِ آنهاست، از میان غذاهای هضم‌شده و خون، شیرِ خالصی به شما مى‌نوشانیم كه براى نوشندگان گواراست"
  16,67,"و [نیز] از میوه‌های درختان خرما و انگور، هم شراب [مستی‌آور] و هم روزیِ نیکو [و پاکیزه] به دست می‌آورید. بی‌گمان، در این [امر]، برای کسانی که خرد می‌ورزند، نشانه‌ای [از لطف و قدرتِ پروردگار] است"
  16,68,"پروردگارت به زنبور عسل الهام كرد كه: «از کوه‌ها و درختان و از آنچه [مردم‌] بنا می‌کنند [برای خود] خانه‌هایی برگیر"
  16,69,"آنگاه از [شیرۀ] تمام میوه‌ها [و گل‌ها] بخور و راه‌های پروردگارت را فروتنانه طی کن». از شكم آنها شهدی رنگارنگ بیرون مى‌آید كه شفاى مردم در آن است. به راستى، در این [ویژگی و کار زنبور عسل،] براى مردمى كه می‌اندیشند، نشانه‌ای [از علم و قدرتِ پروردگار] است"
  16,70,"و الله شما را آفریده است سپس جانتان را می‌گیرد؛ و برخی از شما به فروترین [دوران] عمر [= کُهنسالی] می‌رسد چنان که پس از دانستن [بسیاری چیزها، دیگر] چیزی نمی‌داند [و همه را فراموش می‌کند]. بی‌تردید، الله دانای تواناست‌"
  16,71,"و الله برخی از شما را بر برخی [دیگر] در [نعمت و] روزی برتری داده است؛ ولی کسانی ‌که برتری داده شده‌اند، حاضر نیستند از روزی خود به بردگانشان بدهند، تا همگی در آن [نعمت و دارایی] برابر شوند. [اگر خود از شریک بیزارند، چرا برای الله شریک قرار می‌دهند؟] پس آیا [با این شرک‌ورزی،] نعمت الله را انكار مى‌كنند؟"
  16,72,"و الله از [جنس] خودتان همسرانی برای شما قرار داد و از همسرانتان فرزندان و نوادگانی برای شما آفرید و از چیزهای پاكیزه به شما روزى بخشید. پس آیا [باز هم‌] به باطل ایمان می‌آورند و نعمت الله را ناسپاسی می‌کنند؟"
  16,73,"و [مشرکان] به جاى الله چیزهایى را عبادت می‌کنند كه مالک هیچ روزى‌ای در آسمان‌ها و زمین برایشان نیستند و توانایی [هیچ کاری] ندارند"
  16,74,"پس براى الله امثال [و شریک‌ها] قائل نشوید. بی‌تردید، الله مى‌داند و شما نمى‌دانید"
  16,75,"الله مثالی زده است: بردۀ مملوکی که قادر به هیچ کاری نیست و [در مقابل،] کسی که از جانب خویش به او روزیِ نیکویی بخشیده‌ایم و او از همان [نعمت‌های الهی] پنهان و آشکار انفاق می‌کند. آیا این دو برابرند؟ [پس شما مشرکان چگونه مالک مطلق را با معبودهای ناتوان یکسان می‌دانید؟] ستایش مخصوص الله است؛ اما بیشتر آنان [حقِ یگانگی‌اش را] نمی‌دانند"
  16,76,"و الله مَثل [دیگری] زده است: دو مرد را [فرض کنید] که یکی از آنها گنگ است و هیچ کاری از وی برنمی‌آید و سربارِ سرور خود می‌باشد، هر کجا او را می‌فرستد، هیچ خیری به همراه نمی‌آورد [و وظایفش را به درستی انجام نمی‌دهد]؛ آیا او با کسی ‌که به عدالت فرمان می‌دهد و خود بر راهی مستقیم قرار دارد برابر است؟ [پس شما مشرکان چگونه قادر مطلق را با مردگان و بُت‌های بی‌احساسِ ناتوان یکسان می‌دانید؟]"
  16,77,"[علم] غیب آسمان‌ها و زمین، تنها از آنِ الله است و امرِ [برپاییِ] قیامت، جز [به سرعت‌] یک چشم بر هم زدن نیست؛ یا [حتی] سریع‌تر. بی‌تردید، الله بر هر چیزی تواناست"
  16,78,"[ای مردم،] الله شما را از شکمِ مادرانتان خارج نمود در حالی ‌که هیچ چیز نمی‌دانستید؛ و گوش و چشم و دل [= عقل] برایتان پدید آورد [تا قدرت‌های الهی را درک کنید]؛ باشد که سپاس گزارید"
  16,79,"آیا [مشرکان] پرندگان را ندیده‌اند که در فضای آسمان رام شده‌اند [و] کسی جز الله آنها را [در آن حال‌] نگه نمی‌دارد؟ به راستی، در این [امر‌]، براى مردمى كه ایمان دارند، نشانه‌هایى [از قدرت پروردگار] است"
  16,80,"الله از خانه‌هایتان محلِ سکونت [و آرامش] برای شما قرار داد و از پوست چهارپایان [نیز] خانه‌هایی [= خیمه‌هایی] برایتان قرار داد تا روز کوچ کردن‌ سبکبار باشید و روز اقامتتان [نیز برپایی‌اش آسان باشد]؛ و از پشم و کُرک و مو‌هایشان تا مدتی معیّن اثاث [خانه] و اسباب [و وسایل زندگی، برایتان] فراهم کرد"
  16,81,"الله از آنچه [مانند درختان] آفرید، سایه‌هایی برایتان فراهم آورده است و از کوه‌ها [نیز راه‌ها و] پناهگاه‌هایی برایتان قرار داده است و جامه‌هایى برایتان پدید آورده است كه شما را از [سرما] و گرما نگاه می‌دارد و [زِره‌ها و] تن‌پوشهایی كه در جنگ[های]تان از شما محافظت مى‌کند. او اینچنین نعمتش را بر شما تمام مى‌گردانَد؛ باشد که [در برابرِ توحید] تسلیم شوید [و شرک نورزید]"
  16,82,"پس [ای پیامبر،] اگر [مشرکان] روی گرداندند، جز این نیست که وظیفۀ تو [فقط] پیام‌رسانیِ آشکار است"
  16,83,"[آنان] نعمت الله را می‌شناسند؛ اما [باز هم] آن را انکار می‌کنند و بیشتر آنان ناسپاس و کافرند"
  16,84,"و [یاد کن از] روزی‌ که از هر امتی، گواهی [بر آنان] برمی‌انگیزیم؛ آنگاه به کسانی‌ که کفر ورزیدند نه اجازۀ [سخن گفتن] داده می‌شود و نه از آنان خواسته می‌شود که پوزش بخواهند"
  16,85,"و کسانی‌ که ستم کردند، هنگامی ‌که عذاب [آخرت] را می‌بینند؛ نه عذابشان سبک می‌شود و نه مهلت داده می‌شوند"
  16,86,"کسانی كه شرک ورزیدند، وقتی شریكان خود را می‌بینند مى‌گویند: «پروردگارا، اینها بودند آن شریكانى كه ما به جاى تو مى‌خواندیم» و[لى شریكان‌،] سخنِ آنان را [اینگونه] رد مى‌كنند كه: «یقیناً شما دروغگویید»"
  16,87,"در آن روز، در برابرِ الله، سرِ تسلیم می‌افكنند و دروغ‌هایی که [دربارۀ شفاعتِ غیر الله] می‌بافتند همه محو و نابود می‌گردد"
  16,88,"کسانی‌ که کفر ورزیدند و [مردم را] از راهِ الله بازداشتند، به [کیفر] آنکه فساد می‌کردند، عذابی بر عذابشان می‌افزاییم"
  16,89,"و روزی [را یاد کن] که از هر امتی، گواهی از خودشان بر آنان می‌گماریم [تا به کفر و ایمانشان گواهی دهد] و تو را [نیز ای محمد،] بر اینان گواه می‌گیریم؛ و ما این کتاب [= قرآن‌] را بر تو نازل کردیم که روشنگرِ همه چیز است و برای مسلمانان، رهنمود و رحمت و بشارت است.‌"
  16,90,"در حقیقت، الله [شما را] به عدالت و نیکوکاری و بخشش به خویشاوندان فرمان مى‌دهد و از فحشا و زشت‌کاری و سرکشی نهى مى‌كند. او شما را پند مى‌دهد؛ باشد كه پند گیرید"
  16,91,"و چون با الله [یا با مردم] پیمان بستید، به آن وفا كنید؛ و سوگندها[ى خود] را پس از محكم ساختنشان نشكنید، در حالى كه الله را بر [وفاداریِ] خویش گواه قرار داده‌اید. بى‌تردید، الله می‌داند که چه مى‌كنید"
  16,92,"و مانند آن زن [نادانی] نباشید که رشتۀ [پشمی تابیدۀ] خویش را پس از محکم‌بودن از هم باز‌گشود [و گسست؛ پس مبادا] سوگندهاى خود را وسیلۀ فریب یکدیگر قرار دهید [آن هم تنها] به سبب این كه [ثروت و] جمعیت گروهی افزون‌تر از دیگرى است. جز این نیست که الله شما را با این [کار] می‌آزماید و یقیناً روز قیامت، آنچه را که در آن اختلاف می‌کردید، برایتان روشن می‌سازد"
  16,93,"و اگر الله می‌خواست، همۀ شما را یک امت قرار می‌داد؛ ولی [با عدالت خویش] هر کس را که بخواهد گمراه می‌کند و [با فضل خویش] هر کس را که بخواهد هدایت می‌نماید؛ و شما [روز قیامت] قطعاً از آنچه می‌کردید، بازخواست خواهید شد"
  16,94,"و سوگندهایتان را وسیلۀ نیرنگ [و فریبکاری] میان خویش قرار ندهید، تا مبادا [ایمانتان به خطر بیفتد و] گامى پس از استواری‌اش بلغزد و به سزاى آنكه [مردم را] از راه الله بازداشته‌اید، [کیفرِ] ناگواری بچشید و عذابی بزرگ برایتان [در پیش‌] باشد‌"
  16,95,و پیمان الله را به بهای اندک نفروشید. اگر بدانید، یقیناً آنچه نزد الله است، برایتان بهتر است
  16,96,"آنچه نزد شماست، پایان می‌پذیرد و[لی] آنچه نزد الله است، باقی [و جاوید] است؛ و قطعاً به كسانى كه شكیبایى كرده‌اند، اجرشان را بر اساس نیکوترین [طاعت و] كارى كه مى‌كردند خواهیم داد"
  16,97,"هر کس ـ مرد یا زن ـ که کار نیک کند و مؤمن باشد، قطعاً او را [در دنیا] به زندگانی پاک و پسندیده‌ای زنده می‌داریم و [در آخرت نیز] بر اساس نیکوترین [طاعت و] كارى كه مى‌كردند، به آنان پاداش می‌دهیم"
  16,98,"پس [ای مؤمن،] هنگامی ‌که قرآن می‌خوانی، از [شرّ] شیطانِ رانده‌شده [از رحمت الهی]، به الله پناه ببر"
  16,99,"بی‌تردید، او بر کسانی ‌که ایمان آورده‌اند و بر پروردگار‌شان توکل می‌کنند [هیچ] تسلطی ندارد"
  16,100,"تسلط او تنها بر کسانی است که او را [دوست و] کارساز خود گرفته‌اند و [همچنین بر] کسانی ‌که به سبب [اغوای] شیطان، [به الله] شرک می‌ورزند"
  16,101,"و هنگامی که [حكمِ] آیه‌اى را جایگزین آیه‌ای [دیگر] می‌کنیم ـ حال آنكه الله به آنچه نازل مى‌كند داناتر است ـ [کافران] مى‌گویند: «[ای محمد،] جز این نیست كه تو دروغ‌بافی». [چنین نیست؛] بلکه بیشتر آنان [از احکام شرع و حمکت الهی چیزی] نمى‌دانند"
  16,102,"بگو: «روح القُدُس [= جبرئیل] آن را از جانب پروردگارت به‌حق نازل کرده است تا کسانی را که ایمان آورده‌اند ثابت‌قدم گرداند و هدایت و بشارتی برای مسلمانان باشد»"
  16,103,"و یقیناً می‌دانیم که آنان می‌گویند: «حتماً بشری [این آیات را] به او آموزش می‌دهد». [نه، چنین نیست؛ زیرا] زبان كسى كه [این‌] نسبت را به او مى‌دهند غیرعربى است؛ حال آنکه این [قرآن‌،] به زبان عربىِ روشن [و با بلاغت و فصاحت عالی نازل شده] است"
  16,104,"یقیناً کسانی ‌که به آیات الله ایمان نمی‌آورند، الله آنان را هدایت نمی‌کند و عذاب دردناکی برای آنان [در پیش] است"
  16,105,"[محمد صلی الله علیه وسلم دروغگو نیست؛ بلکه] کسانی دروغ می‌بافند که به آیات الله ایمان ندارند و اینان دروغگویان [واقعی] هستند"
  16,106,"هر کس بعد از ایمانش به الله کفر بورزد، [گرفتار عذاب الهی خواهد شد]؛ مگر کسی که [به این کار،] وادار شده باشد و[لی] دلش به ایمان، آرام [و استوار] باشد؛ اما هر کس سینه‌اش را به کفر بگشاید، خشم الله بر آنان است و عذابی سهمگین [در پیش‌] دارند"
  16,107,"این [مجازات،] از آن روست که زندگی دنیا را بر آخرت ترجیح دادند؛ و [نیز] اینکه الله گروه کافران را هدایت نمی‌کند"
  16,108,"اینان کسانی هستند که [بر اثر گناهانشان] الله بر دل‌ها و گوش‌ها و چشمانشان مُهر نهاده است؛ و اینان غافلان [واقعی] هستند"
  16,109,یقیناً آنان در آخرت زیانکارند
  16,110,"سپس پروردگارت نسبت به كسانى كه پس از زجر کشیدن [از آزار مشرکان] هجرت كردند سپس به جهاد برخاستند و شکیبایی نمودند، پس از آن [همه سختی‌ها‌] قطعاً آمرزندۀ مهربان است"
  16,111,"[ای پیامبر، یاد کن از] روزى كه هر كس در حالی [به پیشگاه عدل الهی] مى‌آید که [تنها] از خود دفاع مى‌كند؛ و هر كس در برابر آنچه كرده است، بى‌كم‌وكاست پاداش مى‌گیرد و بر آنان ستم نمى‌رود"
  16,112,"و الله شهری [همچون مکه] را مثال می‌زند که امن و آرام بود [و] روزی‌اش از هر سو به آسانی و فراوانی می‌رسید؛ ولی [مردمانش] نسبت به نعمت‌های الهی ناسپاسی نمودند و آنگاه الله [نیز] به سزاى آنچه مرتکب می‌شدند، طعم گرسنگى و ترس را به [اهالی‌] آن چشانید"
  16,113,"و پیامبری از خودشان به سوی آنان آمد، اما او را دروغگو انگاشتند؛ و در حالی ‌که ستمکار [و مشرک] بودند، عذاب [الهی] آنان را فروگرفت"
  16,114,"پس، از آنچه الله روزی‌تان کرده است حلال [و] پاکیزه بخورید و اگر فقط او را عبادت می‌کنید [و شرک نمی‌ورزید]، بر نعمت الهی شکر گزارید"
  16,115,"جز این نیست که [الله] فقط مُردار و خون و گوشت خوک و آنچه را که [هنگام ذبح،] نامِ غیر الله بر آن برده شده است بر شما حرام کرده است؛ اما هر کس [برای حفظ جانش به خوردن آنها] ناچار شود [و] سركش و زیاده‌خواه نباشد، [بر او گناهی نیست؛ چرا که] بی‌تردید، الله آمرزندۀ مهربان است"
  16,116,"و [ای مشرکان،] با دروغی که بر زبانتان جاری می‌شود نگویید: «این حلال است و آن حرام» تا بر الله دروغ بندید. كسانى كه بر الله دروغ مى‌بندند، هرگز رستگار نمى‌شوند"
  16,117,"[نتیجۀ دنیادوستی‌شان] بهره‌ای اندک است و [در آخرت] عذابى دردناک [در پیش] دارند"
  16,118,"و بر یهود آنچه را پیش‌تر بر تو حكایت کردیم حرام نمودیم و ما به آنان ستم نكردیم؛ بلكه آنها خود [بودند که در نتیجۀ نافرمانی،] به خویشتن ستم مى‌كردند"
  16,119,"با وجود این، پروردگارت نسبت به كسانى كه از روى نادانی گناه كردند و سپس از آن [اشتباهات] توبه نمودند و درستكارى كردند، قطعاً پس از آن، آمرزندۀ مهربان است"
  16,120,"بی‌گمان، ابراهیم پیشوایی فروتن در برابر الله [و] حقگرا بود و [هرگز] در زمرۀ مشرکان نبود"
  16,121,"[او] شکرگزارِ نعمت‌های الله بود. [الله] وی را برگزید و به راه راست هدایت نمود"
  16,122,"[ما] در دنیا به او نیکی عطا کردیم و قطعاً او در آخرت [نیز] از شایستگان است"
  16,123,"سپس [ای پیامبر،] به تو وحی کردیم که از آیین ابراهیم پیروی کن که حقگرا بود و [هرگز] در زمرۀ مشرکان نبود"
  16,124,"[وجوبِ بزرگداشتِ روزهای] شنبه، تنها بر کسانی‌ قرار داده شد که در آن اختلاف کردند؛ و قطعاً پروردگارت روز قیامت، در مورد آنچه اختلاف می‌کردند، میان آنان داوری خواهد کرد"
  16,125,"[ای پیامبر، مردم را] با حکمت و پند نیکو به راه پروردگارت دعوت نما و با روشی که نیکو‌تر است با آنان [بحث و] مناظره کن. بی‌تردید، پروردگارت به [حال] کسی‌ که از راه او گمراه می‌شود دانا‌تر است و او به [حال] هدایت‌یافتگان [نیز] دانا‌تر است"
  16,126,"و اگر [شما مؤمنان] خواستید [دشمنانتان را] مجازات کنید، چنان مجازات کنید که [آنان] شما را مجازات کرده‌اند؛ و اگر [خویشتنداری و‌] شکیبایی کنید، [بدانید که] قطعاً این [کار] برای شکیبایان بهتر است‌"
  16,127,"و [ای پیامبر،] صبر پیشه کن و صبر تو جز به [یاری و] توفیق الله نیست؛ و بر آنان [= کافران] اندوه مخور و از نیرنگی که می‌ورزند دلتنگ مباش‌"
  16,128,بی‌تردید، الله با كسانى است كه پرهیزگاری کردند و كسانى كه نیكوكارند