quran[63]{c,v,t}:
  76,19,و همواره نوجوانانی جاودانه بر گِردشان می‌چرخند که هر گاه آنها را ببینی، گمان می‌کنی مرواریدِ پراکنده هستند
  76,20,"و چون [به هر سَمتی] بنگری، نعمت بسیار و فرمانرواییِ عظیمی آنجا می‌بینی"
  76,21,"بر آنان [= بهشتیان] لباس‌هایی سبزرنگ از دیبای نازک و دیبای ضخیم [پوشانده شده] است، و با دستبند‌هایی از نقره آراسته شده‌اند، و پروردگارشان شراب پاک به آنان می‌نوشانَد"
  76,22,"[و به آنها گفته می‌شود:] «این [نعمت‌ها،] پاداش شماست، و [بدانید که] از سعی و کوشش شما قدردانی شده است»"
  76,23,"[ای پیامبر،] یقیناً ما قرآن را به صورت تدریجی بر تو نازل کردیم؛"
  76,24,پس بر حُکم پروردگارت شکیبا باش و از هیچ یک از گناهکاران و بی‌دینان آنان فرمان مبر
  76,25,و صبح و شام، نامِ پروردگارت را یاد کن
  76,26,"و [نیز] بخشی از شب برایش سجده کن [و نماز بگزار]، و در بخش بلندی از شب، او را تسبیح گوی"
  76,27,"بی‌گمان، اینان [= کافران] دنیای زودگذر را دوست دارند و روز سختی [را که در پیش دارند] پشت سر خود رها می‌کنند [و به آن اهمیت نمی‌دهند]"
  76,28,"ما آنها را آفریدیم و پیوند وجودشان را محکم کردیم، و هر زمان که بخواهیم، جای آنان را به [گروه دیگری] همانندشان می‌دهیم"
  76,29,"بی‌گمان، این یادآوری [و پند] است؛ پس هر ‌کس که بخواهد، راهی به سوی پروردگارش بر‌گزیند"
  76,30,"و تا الله اراده نکند، [شما چیزی را] نخواهید خواست. بی‌گمان، الله دانای حکیم است؛"
  76,31,هر کس را که بخواهد، در رحمت خود وارد می‌کند؛ و عذاب دردناکی برای ستمکاران آماده کرده است
  77,1,سوگند به فرشتگانی که پیاپی فرستاده می‌شوند،
  77,2,و سوگند به فرشتگانی که همچون تندباد می‌روند،
  77,3,"و سوگند به فرشتگانی که [ابرها را] پراکنده می‌کنند،"
  77,4,"و سوگند به فرشتگانی که جداکننده[ی حق از باطل] هستند"
  77,5,"و سوگند به فرشتگانی که وحی [الهی] را [به پیامبران] القا می‌کنند،"
  77,6,برای اتمامِ‌حجت یا برای بیم و هشدار
  77,7,بی‌گمان، آنچه به شما وعده داده می‌شود، واقع خواهد شد؛
  77,8,"آنگاه ‌که ستارگان تیره [و محو] شود"
  77,9,و آنگاه‌ که آسمان شکافته شود،
  77,10,"و آنگاه ‌که کوه‌ها [از جا کنده و] پراکنده شود،"
  77,11,"و آنگاه ‌که برای پیامبران [جهت گواهی دادن در مورد امت‌ها]، وقت تعیین گردد،"
  77,12,"این [امر،] برای چه روزی به تأخیر افتاده است؟"
  77,13,"برای روز جدایی [و داوری]"
  77,14,"و تو چه دانی روز جدایی [و داوری] چیست؟"
  77,15,"در آن روز، [= قیامت] وای بر تکذیب‌کنندگان"
  77,16,"آیا ما پیشینیان [مجرم] را نابود نکردیم؟"
  77,17,سپس دیگران را در پی آنها خواهیم آورد
  77,18,اینچنین با گنهکاران رفتار می‌کنیم
  77,19,در آن روز، وای بر تکذیب‌کنندگان
  77,20,"آیا شما را از آبی پست [و ناچیز] نیافریدیم؟"
  77,21,"سپس آن را در قرارگاهی محفوظ [= رحِم] قرار دادیم"
  77,22,تا زمانی معین
  77,23,"ما [بر این کار] توانا بودیم و چه نیک توانا [و قدرتمند] هستیم"
  77,24,در آن روز، وای بر تکذیب‌کنندگان
  77,25,"آیا زمین را جایگاه [تجمع مردم] قرار ندادیم؟"
  77,26,هم در حال حیات و هم مرگشان؟
  77,27,"و کوه‌های بسیار بلند [و استوار] در آن قرار دادیم و آبی شیرین [و گوارا] به شما نوشاندیم"
  77,28,در آن روز، وای بر تکذیب‌کنندگان
  77,29,"[به آنها گفته می‌شود:] «به سوی همان چیزی بروید که پیوسته آن را تکذیب می‌کردید"
  77,30,"بروید به سوی سایۀ [دودهای آتش] سه‌شاخه،"
  77,31,"نه سایه‌افکن [و خنک] است و نه از [گرمیِ] شعله‌های آتش جلوگیری می‌کند»"
  77,32,"همانا [دوزخ،‌] شراره‌هایی چون كاخى [بلند] مى‌افكنَد"
  77,33,"گویی که آن [شراره‌ها] شتران زردرنگ هستند"
  77,34,در آن روز، وای بر تکذیب‌کنندگان
  77,35,"این [همان] روزی است که سخن نمی‌گویند"
  77,36,و به آنها اجازه داده نمی‌شود تا عذرخواهی کنند
  77,37,در آن روز، وای بر تکذیب‌کنندگان
  77,38,"این [همان] روز جدایی [و داوری] است که شما و گذشتگان را گرد آورده‌ایم"
  77,39,"پس اگر [حیله و] نیرنگی دارید، آن را در حق من به کار گیرید"
  77,40,در آن روز، وای بر تکذیب‌کنندگان
  77,41,"به راستی که [در آن روز،] پرهیزگاران در سایه‌ها و [کنار] چشمه‌ها قرار دارند،"
  77,42,و میوه‌هایی که میل داشته باشند
  77,43,"[به آنها گفته می‌شود:] «به پاداش آنچه می‌کردید، گوارا بخورید و بیاشامید"
  77,44,ما این گونه نیکوکاران را پاداش می‌دهیم»
  77,45,در آن روز، وای بر تکذیب‌کنندگان
  77,46,"«[ای کافران، در این دنیا] اندکی بخورید و بهره گیرید؛ زیرا شما گناهکارید»"
  77,47,در آن روز، وای بر تکذیب‌کنندگان
  77,48,"و هنگامی‌ که به آنها گفته شود: [نماز بگزارید و] رکوع کنید، [نماز نمی‌گزارند و] رکوع نمی‌کنند"
  77,49,در آن روز، وای بر تکذیب‌کنندگان
  77,50,"[وقتی مردم به این قرآن که از جانب پروردگارشان نازل شده است ایمان نمی‌آورند،] پس به کدام سخن دیگری غیر از آن ایمان خواهند آورد؟"