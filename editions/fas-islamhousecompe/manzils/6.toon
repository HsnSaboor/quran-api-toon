quran[842]{c,v,t}:
  37,1,"سوگند به فرشتگان صف‌به‌صف [که برای عبادت پروردگار ایستاده‌اند]"
  37,2,و سوگند به فرشتگانی که ابرها را می‌رانند
  37,3,و سوگند به فرشتگانی که قرآن تلاوت می‌کنند
  37,4,"[که] بی‌تردید، معبود شما یکتاست"
  37,5,"[همان] پروردگار آسمان‌ها و زمین و آنچه میان آنهاست و پروردگار [خورشید در غروب‌گاه‌ها و] طلوع‌گاه‌ها"
  37,6,به راستی که ما آسمان دنیا را با زیورِ ستارگان آراستیم
  37,7,"و [آن را] از [دسترس] هر شیطان سرکشی حفظ کردیم"
  37,8,"[آن شیاطین، هرگز] نمی‌توانند [سخنان فرشتگان] عالم بالا را بشنوند و از هر سو [با شهاب‌های آتشین] تیرباران می‌شوند"
  37,9,"[از ورود آنان، به عالم فرشتگان جلوگیری می‌شود و همواره به] عقب رانده می‌شوند و عذابی جاودان [در پیش] دارند؛"
  37,10,"مگر کسی [از شیاطین] که ناگهان چیزی [از گفتگوی فرشتگان را] برباید که [در این صورت،] شهابی درخشان او را دنبال می‌کند"
  37,11,"پس از آنان [= کافران] بپرس که آیا آفرینش [پیکرهای] آنان سخت‌تر است یا آنچه که ما [از زمین و آسمان‌ها و جهان بیکران] آفریده‌ایم؛ [در حالی که] ما آنها از گِلى [بی‌ارزش و] چسبنده پدید آوردیم"
  37,12,"تو [از انکار آنان] در شگفتی و آنها [نیز سخنانت را دربارۀ قیامت] مسخره می‌کنند"
  37,13,و چون پند داده ‌شوند، نمی‌پذیرند
  37,14,"و چون نشانه‌ای [در مورد راستگویی پیامبر] می‌بینند، [آن را] به تمسخر می‌گیرند"
  37,15,"و می‌گویند: «این [قرآن، چیزی] نیست، مگر جادویی آشکار"
  37,16,آیا هنگامی که مردیم و خاک و استخوان شدیم، برانگیخته خواهیم شد؟
  37,17,"آیا پدران ما [نیز برانگیخته می‌شوند]؟»"
  37,18,"بگو: «آری؛ شما در حالی که خوار هستید [زنده می‌شوید]»"
  37,19,"[وقوع قیامت،] تنها با یک بانگ [سهمناک] است و ناگهان [همه از قبرها بیرون می‌آیند و در انتظار دستور پروردگار، وحشت قیامت را] نظاره می‌کنند"
  37,20,"و می‌گویند: «وای بر ما! این [همان] روز جزاست»"
  37,21,"[گفته می‌شود: «آری،] این همان روز داوری است که آن را انکار می‌کردید»"
  37,22,"[به فرشتگان گفته می‌شود:] «گرد آورید کسانی را که [با شرک به خویش] ستم کرده‌اند با [همفکران و] همانندهایشان و آنچه عبادت می‌کردند"
  37,23,به جاى الله؛ و آنان را به راه دوزخ هدایت کنید
  37,24,"و آنان را نگه دارید که قطعاً [پیش از رفتن به دوزخ] بازخواست خواهند شد»"
  37,25,"[از دوزخیان می‌پرسند:] «چرا [مانند دنیا] از یكدیگر حمایت نمى‌كنید؟»"
  37,26,"بلکه امروز [همگی] تسلیم [امرِ پروردگار] هستند"
  37,27,و سرزنش‌کنان به یکدیگر رو می‌کنند
  37,28,"[و به رهبران و بزرگان خود] می‌گویند: «شما [برای به کفر کشاندنِ ما، با ادعای دین راستین و] از موضع حق به سراغمان می‌آمدید»"
  37,29,"[رهبرانشان] می‌گویند: «[ما مقصر نیستیم؛] بلکه شما خود ایمان نداشتید؛"
  37,30,و ما هیچ تسلطى بر شما نداشتیم؛ بلکه شما خود گروهى سرکش بودید
  37,31,"[اکنون] فرمان مجازاتِ پروردگارمان بر ما محقق شده و به راستی، ما [همگی عذاب دوزخ را] خواهیم چشید"
  37,32,"شما را گمراه نمودیم [چرا که] در حقیقت، خود نیز گمراه بودیم»"
  37,33,"یقیناً آن روز [همۀ آنان] در عذاب شریکند"
  37,34,"بی‌تردید، ما با گناهکاران اینچنین [رفتار] می‌کنیم"
  37,35,"آنان بودند كه وقتی به آنان گفته مى‌شد: «معبودی [به‌حق] جز الله نیست» سرکشی [و تکبر] می‌کردند"
  37,36,"و می‌گفتند: «آیا ما معبودانمان را به خاطر [سخن] شاعری دیوانه رها کنیم؟»"
  37,37,"[چنین نیست] بلکه او حق [= توحید] را آورده و پیامبران [پیشین] را تصدیق کرده است"
  37,38,"شما [کافران] قطعاً عذاب دردناک [دوزخ] را می‌چشید"
  37,39,"و جز [در برابر] آنچه می‌کردید مجازات نمی‌شوید"
  37,40,"[همه عذاب می‌بینند؛] مگر بندگان مخلص الله"
  37,41,"آنان [در پیشگاهِ پروردگار،] روزیِ مشخصی دارند"
  37,42,"[انواع] میوه‌ها [را در اختیار خواهند داشت] و گرامی داشته می‌شوند"
  37,43,"در باغ‌های پرنعمت [بهشت]؛"
  37,44,"در حالی که مقابل یکدیگر بر تخت‌ها [تکیه زده‌اند]؛"
  37,45,"جامی از شراب ناب [و زلال] پیرامونشان می‌گردانند؛"
  37,46,"[شرابی روشن و] سپید که برای نوشندگانش لذت‌بخش است؛"
  37,47,"[شرابی كه خماری و] سردردى در نوشیدنش نیست و از آن مست نمی‌گردند"
  37,48,"و نزدشان زنانی زیباچشم است که تنها [به شوهران خود] نظر دارند [و تنها به آنها عشق می‌ورزند]"
  37,49,"[زنانی که] گویی پردۀ سفید داخلی تخم [پرندگان] هستند که [از دسترس همگان] پنهان مانده‌اند"
  37,50,"[بهشتیان دربارۀ رخدادهای دنیا صحبت می‌کنند و] برخی از آنان پرسش‌کنان رو به برخی دیگر می‌کنند"
  37,51,"یکی از آنان می‌گوید: «من [در دنیا] همنشینی داشتم"
  37,52,"[که پیوسته به من] می‌گفت: آیا تو واقعاً [به قیامت] باور داری؟"
  37,53,"آیا هنگامی که مُردیم و خاک و استخوان شدیم، آیا حقیقتاً [زنده می‌شویم و در قبال کارهایمان مورد محاسبه قرار می‌گیریم و] به ما کیفر می‌دهند؟!»"
  37,54,"[سپس به دوستان بهشتی‌اش] می‌گوید: «آیا [شما نیز همراه من] سر می‌کشید [تا بدانیم او کجاست]؟»"
  37,55,آنگاه خود سر می‌کشد و او را در میان دوزخ مى‌بیند
  37,56,"به وی می‌گوید: «به الله سوگند که نزدیک بود مرا [با وسوسه‌های کفرآمیزت] نابود سازی"
  37,57,"اگر نعمتِ [هدایتِ] پروردگارم نبود، من نیز از حاضرشدگان [در دوزخ] بودم»"
  37,58,"[آنگاه به بهشتیان می‌گوید:] «آیا ما مرگ دیگری نخواهیم داشت"
  37,59,جز مرگ نخستین، و عذاب نمی‌شویم؟
  37,60,به راستی که این همان کامیابی بزرگ است»
  37,61,"اهل عمل، باید براى چنین [پاداشی] بکوشند"
  37,62,"آیا این [نعمت بهشت، کریمانه‌تر و] براى پذیرایى بهتر است یا درختِ زَقّوم [در دوزخ]؟"
  37,63,"بی‌تردید، ما آن درخت را مایۀ آزمایش ستمکاران [مشرک] قرار داده‌ایم [چرا که می‌گویند: «هیچ درختی در آتش نمی‌روید»]"
  37,64,"در حقیقت، آن [مایۀ عذاب،] درختی است که از ژرفای دوزخ می‌روید"
  37,65,"میوه‌اش [چنان بدمنظر است که] گویى سرهاى شیاطین است"
  37,66,"آنان [= دوزخیان] از [میوه‌های تلخ] آن مى‌خورند و شکم‌ها را از آنها انباشته مى‌كنند"
  37,67,"آنگاه بر روی این [غذای ناپاک، به جای نوشیدنی] آمیزه‌ای از آب جوشان دارند"
  37,68,سپس یقیناً باز‌گشتشان به دوزخ است
  37,69,آنان پدران خود را گمراه یافتند؛
  37,70,"و [همچنان] در پیِ آنان می‌شتافتند"
  37,71,و قطعاً قبل از آنان نیز بیشتر پیشینیان گمراه شدند
  37,72,"و بی‌تردید، ما هشدار‌دهندگان [بسیاری] میان آنان فرستادیم"
  37,73,پس بنگر که سرانجامِ هشداریافتگان چگونه بود
  37,74,"[همه گرفتار عذاب شدند] مگر بندگان مخلص الله"
  37,75,"نوح به درگاه ما دعا کرد و [ما] چه نیکو اجابت‌کننده بودیم"
  37,76,"و او و خانواده‌اش را [به همراه مؤمنان] از بلای بزرگ [طوفان] نجات دادیم"
  37,77,"و [پس از طوفان، فقط پیروان مؤمن و] خانوادۀ او را [در زمین] باقی گذاشتیم"
  37,78,"و در میان آیندگان [نام نیک] برایش به جا نهادیم"
  37,79,"سلام [و ستایش] جهانیان بر نوح باد"
  37,80,به راستی، ما نیکوکاران را اینچنین پاداش می‌دهیم
  37,81,بی‌تردید، او از بندگان مؤمن ما بود
  37,82,"آنگاه دیگران را [که در طوفان مانده بودند] غرق کردیم"
  37,83,"و قطعاً ابراهیم از پیروان او [= نوح] بود"
  37,84,"[یاد کن از] هنگامی که وی با دلی پاک [و خالی از شرک] به [درگاه] پروردگارش آمد"
  37,85,"آنگاه که به پدر و قومش گفت: «چه چیزی عبادت می‌کنید؟"
  37,86,آیا به جای الله، این معبودان دروغین را می‌خواهید؟
  37,87,گمانتان دربارۀ پروردگار جهانیان چیست؟»
  37,88,"سپس نگاهی به ستارگان افکند [و اندیشید]"
  37,89,"و گفت: «من بیمارم [و در جشن شرکت نمی‌کنم]»"
  37,90,"پس [مردم] او را ترک کردند و رفتند"
  37,91,"آنگاه پنهانی نزد معبودهایشان رفت و [با تمسخر] گفت: «چیزی نمی‌خورید؟"
  37,92,شما را چه شده است که سخن نمی‌گویید؟»
  37,93,"سپس با دست راست خود ضربه‌ای [محکم] بر آنها وارد آورد [و جز بُت‌ بزرگ، همه را شکست]"
  37,94,قومش شتابان به سوی او آمدند
  37,95,"[ابراهیم] گفت: «آیا چیزی را که خود می‌تراشید عبادت می‌کنید؟"
  37,96,"و حال آنکه الله، [هم] شما و [هم] آنچه را انجام می‌دهید آفریده است»"
  37,97,"[وقتی بُت‌پرستان از پاسخ درماندند،] گفتند: «بنایی [بلند] برایش بسازید و او را در آتش بیفکنید»"
  37,98,"براى [نابودى‌] او نیرنگی خواستند و[لى] ما آنان را پست و [مغلوب‌] ساختیم [و آتش بر ابراهیم سرد و بی‌اثر شد]"
  37,99,"و گفت: «من به سوى [سرزمین دیگرى براى عبادتِ] پروردگارم می‌روم [و هجرت می‌کنم] و او مرا هدایت خواهد كرد"
  37,100,"پروردگارا، [فرزندی] از شایستگان به من عطا کن»"
  37,101,"ما [دعایش را مستجاب کردیم و] او را به تولد پسری بردبار بشارت دادیم"
  37,102,"و چون [اسماعیل] به [سن نوجوانى و] حد تلاش [و همكارى] با او [= ابراهیم] رسید، به وی گفت: پسرم، در خواب [به من وحی می‌شود و] مى‌بینم كه تو را ذبح مى‌كنم. نظرت در این باره چیست؟» [اسماعیل] گفت: «پدرجان، آنچه را به تو امر شده است انجام بده. ان شاء الله مرا [در برابر اجرای این فرمان،] شكیبا خواهی یافت»"
  37,103,"هنگامی که هر دو تسلیم [فرمان پروردگار] شدند و [ابراهیم] او را به پیشانی [بر خاک] نهاد"
  37,104,"به او ندا دادیم که: «ای ابراهیم،"
  37,105,یقیناً که خوابت را تحقق بخشیدی». ما نیکوکاران را اینچنین پاداش می‌دهیم
  37,106,"بی‌تردید، این [خواب،] آزمایشی آشکار بود [و ابراهیم از آن سربلند بیرون آمد]"
  37,107,"و [جان] او را در ازای قربانی بزرگی بازخریدیم"
  37,108,"و در میان آیندگان، [نام نیک] برایش بر جای نهادیم"
  37,109,سلام بر ابراهیم
  37,110,ما نیکوکاران را اینچنین پاداش می‌دهیم
  37,111,بی‌تردید، او از بندگان مؤمن ما بود
  37,112,"و او را به [تولد] اسحاق که پیامبری از شایستگان بود بشارت دادیم"
  37,113,"[ما] به او و اسحاق برکت دادیم؛ و [برخى] از افرادِ دودمانشان نیكوكار بودند و [برخى دیگر] آشكارا نسبت به خویشتن ستمکار بودند"
  37,114,و به راستی، بر موسی و هارون منت نهادیم
  37,115,"و آن دو را همراه قومشان از اندوه بزرگ [= ستم فرعون و خطر غرق شدن در نیل] نجات دادیم"
  37,116,و یاری‌شان کردیم تا پیروز شدند
  37,117,"و به آن دو، کتاب روشنگر [= تورات] دادیم"
  37,118,و آن دو را به راه راست هدایت کردیم
  37,119,"و در میان آیندگان [نام نیک] برایشان بر جای نهادیم"
  37,120,سلام بر موسی و هارون
  37,121,ما نیکوکاران را اینچنین پاداش می‌دهیم
  37,122,بی‌تردید، آن دو از بندگان مؤمن ما بودند
  37,123,"و قطعاً الیاس [نیز] یکی از پیامبران [ما] بود"
  37,124,"[یاد کن از] هنگامی که او به قومش گفت: «آیا [از الله] پروا نمی‌کنید؟"
  37,125,"آیا [نماد یا همان بتِ] «بَعل» را [به عبادت] می‌خوانید و بهترین آفریننده را رها می‌کنید؟"
  37,126,"الله [را ترک می‌کنید] که پروردگار شما و پروردگار پدرانتان است»"
  37,127,"اما او را دروغگو انگاشتند و مسلّماً [برای عذاب] احضار می‌شوند"
  37,128,مگر بندگان مخلص الله
  37,129,"ما در میان آیندگان [نام نیک] برایش بر جای نهادیم"
  37,130,سلام بر الیاس
  37,131,به راستی، ما نیکوکاران را اینچنین پاداش می‌دهیم
  37,132,بی‌تردید، او از بندگان مؤمن ما بود
  37,133,"و قطعاً لوط [نیز] یکی از پیامبران [ما] بود"
  37,134,"[یاد کن از] هنگامی که او و همۀ خانواده‌اش را نجات دادیم"
  37,135,"مگر پیرزنی که از باقی‌ماندگان [در عذاب] بود"
  37,136,سپس دیگران را هلاک کردیم
  37,137,"و شما [در سفر به سرزمین شام] صبحگاهان بر [ویرانه‌های شهرهای] آنان می‌گذرید"
  37,138,"آیا نمی‌اندیشید [و عبرت نمی‌گیرید]؟"
  37,139,"و قطعاً یونس [نیز] یکی از پیامبران [ما] بود"
  37,140,"[یاد کن از] هنگامی که [خشمگین از کفر قومش، بدون اجازۀ پروردگار] به کشتیِ انباشته [از مسافر و بار] گریخت"
  37,141,"[چون کشتی در حال غرق شدن بود، یونس با سرنشینان کشتی برای بیرون انداختنِ برخی افراد] قرعه انداخت و خود از باختگان شد [و او را به دریا انداختند]"
  37,142,"سپس ماهی [بزرگی] او را بلعید؛ در حالى كه [خود را به خاطر ترک وظیفه‌] سرزنش مى‌كرد"
  37,143,"اگر در زمرۀ تسبیح‌گویان [پروردگار] نبود،"
  37,144,"یقیناً تا روزی که [مردم] برانگیخته می‌شوند، در شکم آن [ماهی] باقی می‌ماند"
  37,145,"آنگاه او را در حالی که [ضعیف و] بیمار بود به سرزمینی خشک [و ‌بی‌گیاه] افکندیم"
  37,146,"و بوتۀ کدو بر [سرِ] او رویاندیم [تا از سایه و میوه‌اش بهره گیرد]؛"
  37,147,"و [دوباره] او را به سوی صد هزار نفر یا بیشتر [به رسالت] فرستادیم"
  37,148,"آنان ایمان آوردند و ما نیز آنان را تا مدتی [از نعمت‌های زندگی] بهره‌مند ساختیم"
  37,149,"از آنان [= مشرکان] بپرس آیا دخترها برای پروردگارِ تو و پسرها برای آنهاست؟"
  37,150,آیا ما فرشتگان را دختر آفریدیم و آنان حضور داشتند؟
  37,151,"آگاه باش! آنان از [روی تهمت و] دروغگویی‌ می‌گویند"
  37,152,«الله فرزند دارد» و یقیناً دروغ می‌گویند
  37,153,"آیا [الله] دختران را بر پسران ترجیح داده است؟"
  37,154,شما را چه شده است؟ چگونه حکم می‌کنید؟
  37,155,"آیا [نمی‌اندیشید و] پند نمی‌گیرید؟"
  37,156,"آیا [بر ادعای باطل خویش] دلیل روشنی دارید؟"
  37,157,اگر راستگویید، کتابتان را بیاورید
  37,158,"[مشرکان] بین او [= الله] و فرشتگان، خویشاوندى قائل شده‌اند؛ در حالى كه فرشتگان به یقین می‌دانند كه [مشرکان روز قیامت، براى حسابرسی] احضار می‌شوند"
  37,159,"الله از آنچه [مشرکان] توصیف می‌کنند منزّه است"
  37,160,"[مردم در توصیف پروردگار، سخن گزاف مى‌گویند؛] مگر بندگان مخلص الله"
  37,161,"شما [مشرکان] و آنچه عبادت می‌کنید"
  37,162,"[هرگز] گمراهگر [کسی از دین حق] نیستید؛"
  37,163,"مگر کسی که [به تقدیرِ الهی،] اهل دوزخ باشد"
  37,164,"و [فرشتگان می‌گویند:] «هیچ‌یک از ما نیست، مگر آنکه مقام مشخصی [در پیشگاه الهی] دارد"
  37,165,"ماییم که [برای عبادت و نیایش به درگاه پروردگار] به صف ایستاده‌ایم"
  37,166,"و بی‌تردید، ماییم که تسبیح‌گوی [او] هستیم»"
  37,167,"و [کافران، پیش از بعثت] همواره می‌گفتند"
  37,168,"«اگر کتابی از [کتاب‌های آسمانیِ] پیشینیان نزدمان بود،"
  37,169,یقیناً از بندگان مخلصِ الله می‌شدیم»
  37,170,"اما [هنگامی که پیامبر با قرآن به سویشان آمد، حقانیتِ] آن را انکار کردند؛ به زودی [نتیجۀ انکارشان را] خواهند دانست"
  37,171,"و قطعاً سخن ما دربارۀ بندگان فرستاده‌شده‌مان از پیش صادر شده است [که]"
  37,172,"آنان قطعاً [از جانب ما] یاری‌شده‌اند"
  37,173,و بی‌تردید، لشکر ما پیروزند
  37,174,"پس [ای پیامبر،] تا مدتی از آنان [= مشرکان] روی بگردان"
  37,175,"و آنان را [در هنگام نزول عذاب] بنگر؛ به زودی خود [نیز نتیجۀ کفرشان را] خواهند دید"
  37,176,آیا عذاب ما را به شتاب خواستارند؟
  37,177,"آنگاه كه [عذاب الهی] بر خانه‌هایشان فرود آید، چه بد است بامداد هشداریافتگان"
  37,178,و تا مدتی از آنان روی بگردان،
  37,179,"و آنان را [در هنگام نزول عذاب] بنگر؛ به زودی خود [نیز نتیجۀ کفرشان را] خواهند دید"
  37,180,"پروردگارت ـ پروردگار عزت و قدرت ـ از آنچه [مشرکان به دروغ] توصیف می‌کنند پاک و منزه است"
  37,181,و سلام بر پیامبران
  37,182,"و سپاس [و ستایش] از آنِ الله ـ پروردگار جهانیان ـ است"
  38,1,"ص [= صاد]. سوگند به قرآن پندآموز [که الله هیچ شریکی ندارد]"
  38,2,بلکه کسانی که کفر ورزیدند در سرکشی و ستیزند
  38,3,"چه بسیار نسل‌ها پیش از آنان نابود کردیم که [در هنگام نزول عذاب] فریاد [توبه] برمی‌آوردند؛ و[لی آن زمان، دیگر] وقت [توبه و] رهایی نبود"
  38,4,"و [مشرکان] از اینکه بیم‌دهنده‌اى از میان خودشان به سراغشان آمده است تعجب کردند و گفتند: «این مرد، جادوگرى دروغگوست"
  38,5,"آیا معبودان [مختلف و متعدد] را [تبدیل به] معبودی یگانه کرده است؟ این واقعاً چیز عجیبی است»"
  38,6,"بزرگانشان [= سران قریش] به پا خاستند [و به پیروان خود گفتند]: «بروید و بر [عبادت و حفظ] معبودانتان شکیبا [و پایدار] باشید؛ زیرا این [دعوت به عبادت معبودی یگانه] چیزی است که [برنامه‌ریزی و] خواسته شده است [تا محمد بر شما برتری یابد]"
  38,7,"ما در آیین اخیر [= نصرانیت] نیز چنین [ادعایی دربارۀ توحید] نشنیده‌ایم. این جز دروغ [چیزی] نیست"
  38,8,"آیا از میان [همۀ] ما، قرآن بر او نازل شده است؟» [چنین نیست که می‌گویند؛] بلکه آنان دربارۀ وحی من [بر تو] تردید دارند؛ بلکه هنوز عذاب [الهی] را نچشیده‌اند [که چنین گستاخند]"
  38,9,آیا گنجینه‌های رحمت پروردگار شکست‌ناپذیر بخشنده‌ات نزدشان است؟
  38,10,"یا فرمانروایی آسمان‌ها و زمین و آنچه بین آنهاست از آنِ آنان است؟ [اگر چنین است،] باید با وسایل [و امكانات خود به آسمان] اوج بگیرند [و مانع یا باعث نزول نعمت‌ها گردند]"
  38,11,"[این کافران] لشکری شکست‌خورده از جمله گروه‌ها[و فرقه‌های مخالف پیامبران] هستند"
  38,12,"[پیش از آنان نیز] قوم نوح و عاد و فرعونِ صاحب‌سپاه [نیز پیامبران ما را] دروغگو انگاشتند"
  38,13,"و قوم ثمود و قوم لوط و اصحاب اَیکه [= قوم شعیب] نیز [از] آن گروه‌ها بودند [که به تکذیب پیامبران پرداختند]"
  38,14,"هر یک [از این کافران] پیامبران را دروغگو انگاشتند و كیفر من [در موردشان] تحقق یافت"
  38,15,"اینان [= مشرکان] جز یک بانگ [سهمگین] را انتظار نمی‌کشند؛ [بانگی] که هیچ بازگشتی ندارد"
  38,16,"و [با تمسخر] ‌گفتند: «پروردگارا، پیش از فرارسیدن روز حساب، بهرۀ ما را [از عذاب] به شتاب بده»"
  38,17,"[ای پیامبر،] در برابر گفتارشان شكیبا باش و از بندۀ ما ـ داود توانمند ـ یاد کن [که] بی‌تردید، بسیار توبه‌کار بود"
  38,18,"به راستی، ما کوه‌ها را همراهش به خدمت گماشتیم که [هم‌نوا با او] شامگاهان و بامدادان [پروردگار را] به پاکی می‌ستودند"
  38,19,"و پرندگان را نیز گِردآمده [در آسمان، به خدمت گماشتیم و] همگی به پیروی از وی تسبیح‌گوی بودند"
  38,20,و فرمانروایی‌اش را استوار نمودیم و پیامبری و کلامی فیصله‌بخش به او عطا کردیم
  38,21,"و آیا خبر آن شاکیان به تو رسیده است، آنگاه که [برای دادخواهی نزد داود] از دیوار عبادتگاه [او] بالا رفتند؟"
  38,22,"چون [بدون اطلاع] بر داود وارد شده بودند، از آنان ترسید؛ گفتند: «نترس؛ ما دو نفر شاکی هستیم که یکی بر دیگری ستم کرده است؛ به عدالت در میان ما داوری کن و ستم روا مدار و ما را به راه راست هدایت کن»"
  38,23,"[یکی از آن دو گفت:] «این [مرد،] برادرم است. او نود و نُه میش دارد و من یک میش دارم و [به اصرار] می‌گوید: \"آن [یک میش] را هم به من واگذار\"؛ و در بحث بر من پیروز شده است»"
  38,24,"[داود] گفت: «بی‌تردید، او با خواستنِ میش تو [براى افزودن] به میش‌های خودش، بر تو ستم كرده است؛ و البته بسیاری از شریکان [و همكاران] در حق یكدیگر ستم مى‌كنند، مگر کسانی که ایمان آورده‌اند و کارهای شایسته انجام داده‌اند كه آنها [نیز بسیار] اندکند»؛ و داود [كه بدون توضیح خواستن از طرف دیگر، حكم صادر كرده بود] دریافت كه قطعاً او را امتحان كرده‌ایم؛ بنابر این، از پروردگار خویش آمرزش خواست و سجده‌کنان بر زمین افتاد و [به درگاه الهی] توبه کرد"
  38,25,"آن [اشتباه] را بر او بخشیدیم؛ و به راستی، او نزد ما مقامی والا و [در آخرت] بازگشتی نیکو دارد"
  38,26,"ای داود، ما تو را جانشین [خود] در زمین قرار دادیم؛ پس به حق میان مردم داوری کن و پیرو هوای [نفس] نباش که تو را از راه الله گمراه می‌کند. بی‌تردید، کسانی که از راه الله گمراه می‌شوند، به سزای آنکه روز حساب را فراموش کرده‌اند، عذاب شدیدی [در پیش] دارند"
  38,27,"ما آسمان و زمین و آنچه را که میان آنهاست، بیهوده نیافریده‌ایم. این، گمان کسانی است که کفر ورزیده‌اند. پس وای بر کسانی که کفر ورزیدند از آتش [دوزخ]"
  38,28,آیا کسانی را که ایمان آورده‌اند و کارهای شایسته انجام داده‌اند مانند مفسدان در زمین به حساب می‌آوریم؟ آیا پرهیزگاران را مانند بدکاران به حساب می‌آوریم؟
  38,29,"[ای محمد، این قرآن] کتابی است پربرکت که بر تو نازل کردیم تا [مردم] در آیاتش به دقت بیندیشند و خردمندان پند گیرند"
  38,30,"و سلیمان را به داود عطا کردیم؛ نیکو بنده‌ای بود [و] بی‌تردید، بسیار توبه‌کار بود"
  38,31,"[یاد کن از] هنگامی که عصرگاهان، اسب‌های [اصیل و] تیزرو را بر او عرضه کردند [و این اسب‌ها پیوسته تا غروب خورشید بر او عرضه می‌شد]"
  38,32,"[سلیمان سرگرم تماشای اسب‌ها شد و وقت عبادت گذشت؛] گفت: «به راستی که دوست‌داشتن مال [و تماشای اسب‌ها] مرا از یاد پروردگارم غافل کرد تا [آنکه خورشید] در پرده [مغرب] پنهان گشت"
  38,33,"[بار دیگر] آنها را نزدم بازگردانید». آنگاه [به نشانۀ وقف در راهِ الله] به ساق‌ها و گردن‌ها[ی آن اسب‌ها] دست کشید"
  38,34,"و بی‌تردید، سلیمان را آزمودیم و جسد [نوزاد]ى را [كه ـ بدون گفتن ان‌شاءالله- مشتاقانه در انتظار تولدش بود، مُرده] بر تختش افكندیم [تا دریابد که ادارۀ امور، به دست الله است]؛ سپس [توبه کرد و به درگاه الهی] بازگشت"
  38,35,"گفت: «پروردگارا، مرا بیامرز و حكومتى به من ارزانى دار كه پس از من بى‌نظیر باشد [كه] بی‌تردید، تو بسیار بخشاینده‌ای»"
  38,36,"[ما] باد را در خدمتش گماشتیم که هر کجا اراده می‌کرد به فرمانش به آرامى روانه مى‌شد"
  38,37,"و هر بنّا و غواصی از جنیان را [که می‌خواست، به فرمانش درآوردیم]"
  38,38,"و گروه دیگری [از جنیان] را [که همگی] در غل و زنجیر بودند [تحت سلطه‌اش قرار دادیم]"
  38,39,"[به او گفتیم:] «این عطای ماست؛ بی‌شمار [به هر که می‌خواهی] ببخش یا [از هر کس كه می‌خواهى] بازدار»"
  38,40,"و به راستی، او نزد ما مقامی والا و [در آخرت] بازگشتی نیکو دارد"
  38,41,"[ای پیامبر،] از بندۀ ما ـ ایوب ـ یاد کن؛ آنگاه که پروردگارش را ندا داد که: «شیطان مرا به رنج و درد آورده است»"
  38,42,"[به او فرمان دادیم:] «پایت را بر زمین بکوب [تا چشمه‌ای بجوشد]. این، چشمه‌ساری خنک برای شستشو و آشامیدن است»"
  38,43,"و خانواده‌اش و مانند آنها [= نوادگان] را همراه آنان به وی بخشیدیم تا [نشانۀ] رحمتى از جانب ما و اندرزی براى خردمندان باشد"
  38,44,"و [به او فرمان دادیم:] «دسته‌ای گیاه برگیر و [همسرت را] با آن بزن و سوگندت را [که در هنگام خشم یاد کرده بودی] نشکن. به راستی، ما او را شکیبا یافتیم. نیکو بنده‌ای بود [و] بی‌تردید، بسیار توبه‌کار بود"
  38,45,"و [ای پیامبر،] از بندگان ما ابراهیم و اسحاق و یعقوب یاد کن که [در عبادت] توانمند و [در شناخت حق] بابصیرت بودند"
  38,46,"ما آنان را با خصلتی [ممتاز] ویژه ساختیم که [همانا] یاد آخرت بود"
  38,47,و آنان نزد ما از برگزیدگان و نیکانند
  38,48,"و از اسماعیل و یَسَع و ذوالکِفل یاد کن [که] همگی از نیکانند"
  38,49,"این [قرآن] پندی است و یقیناً پرهیزگاران [در آخرت] بازگشتی نیکو دارند"
  38,50,"باغ‌هایی جاودان که در‌ها[یش] برای آنان گشوده است"
  38,51,"در حالى كه [بر تخت‌ها] تكیه زده‌اند، [از خدمتکارانشان] میوه‌هاى فراوان و نوشیدنی مى‌خواهند"
  38,52,"و زنانی نزدشان است که تنها [به شوهران خود] نظر دارند و [همگی] هم‌سن و سال ‌هستند"
  38,53,این است آنچه براى روز حساب به شما وعده داده مى‌شد
  38,54,"این روزی [و لطف] ماست که پایانی ندارد"
  38,55,"این [پاداش پرهیزگاران] است؛ و بی‌تردید، سرکشان بدترین بازگشتگاه را دارند"
  38,56,"[همان] دوزخ که در آن وارد می‌شوند؛ و چه بد قرارگاهی است"
  38,57,"این [مجازات،] آب جوشان و خونابۀ چرک‌آلودی است که باید آن را بچشند"
  38,58,"و از همين گونه، انواع ديگری [عذاب‌ها را خواهند دید]"
  38,59,"[هنگام ورود دوزخیان به آتش، برخی از آنان به دیگران می‌گویند:] «این گروهی است که همراه شما [به آتش] داخل می‌شوند». [آنان پاسخ مى‌دهند:] «خوشامد بر آنان مباد! به راستی که به آتش درمى‌آیند»"
  38,60,"[آنان به رهبران خود] می‌گویند: «بلکه بر شما خوشامد مباد؛ [زیرا] شما بودید که این [عذاب] را پیش پای ما نهادید. پس [دوزخ] چه بد قرارگاهی است!»"
  38,61,"[آنگاه] می‌گویند: «پروردگارا، هر کس این [عذاب] را برای ما فراهم کرده است، عذابش را در آتش چندین برابر بیفزای»"
  38,62,"[دوزخیان متکبر] می‌گویند: «چرا کسانی را که [در دنیا] از اشرار مى‌پنداشتیم، [در دوزخ] نمى‌بینیم؟"
  38,63,"آیا [در دنیا، بى‌جهت] آنان را به تمسخر می‌گرفتیم یا [اینجا هستند و] چشمان [ما] به آنان نمی‌افتد؟»"
  38,64,"بی‌تردید، این ستیز [و مجادله] اهل آتش، راست است [و قطعاً رخ می‌دهد]"
  38,65,"[ای پیامبر، به کافران] بگو: «من فقط بیم‌دهنده‌ام و معبودی [به‌حق] نیست، مگر الله یگانۀ پیروزمند"
  38,66,"پروردگار آسمان‌ها و زمین و آنچه میان آنهاست، [آن ذاتِ] شکست‌ناپذیرِ آمرزنده»"
  38,67,"[به کافران] بگو: «این [قرآن،] خبرى بزرگ است"
  38,68,"[ولی] شما از آن رویگردانید"
  38,69,"[اگر به من وحى نمى‌شد، هرگز] از عالم بالاتر ـ آنگاه كه [فرشتگان در مورد آفرینشِ بشر] جدال مى‌كردندـ اطلاعى نداشتم"
  38,70,به من وحی نمی‌شود، مگر از آن روى كه من بیم‌دهنده‌اى آشكارم»
  38,71,"[یاد کن از] هنگامی که پروردگارت به فرشتگان گفت: «من بشری از گِل می‌آفرینم"
  38,72,"آنگاه كه او را سامان دادم و از روح خویش در او دمیدم، [به نشانۀ بزرگداشتِ الله] برایش به سجده بیفتید»"
  38,73,"[چون آدم پدید آمد،] فرشتگان همگی سجده کردند"
  38,74,"مگر ابلیس [که] تکبر نمود و کافر شد"
  38,75,"[الله] فرمود: «اى ابلیس، چه چیز مانع تو شد از اینکه در برابر آنچه به دستان خویش آفریده‌ام سجده كنى؟ آیا تکبر ورزیدی یا برتری‌جویی کردی؟»"
  38,76,"او گفت: «من از او برترم: مرا از آتش آفریده‌ای و او را از گِل»"
  38,77,"[الله] فرمود: «از آن [بهشت برین] بیرون شو [که] بی‌تردید، تو [منفور و] رانده‌شده‌ای"
  38,78,"و لعنت من تا روز جزا [= قیامت] بر تو خواهد بود»"
  38,79,"[ابلیس] گفت: «پروردگارا، پس تا روزی که [بندگانت] برانگیخته می‌شوند، به من مهلت بده»"
  38,80,"[الله] فرمود: «مهلت خواهی داشت،"
  38,81,"تا روز [قیامت،] آن وقت معیّن»"
  38,82,"[ابلیس] گفت: «پس به عزت تو سوگند که قطعاً همۀ آنان را گمراه می‌کنم"
  38,83,مگر بندگان مخلصت را از میان آنان»
  38,84,"[الله] فرمود: «[سخنِ من] حق است و حق را مى‌گویم"
  38,85,و یقیناً جهنم را از تو و از هر یک از آنان که از تو پیروی کند ـ از همه ـ انباشته خواهم ساخت»
  38,86,"[ای پیامبر، به مشرکان] بگو: «من [در برابر رسالتم] هیچ پاداشی از شما نمی‌خواهم و فریبکار نیستم [و به دروغ ادعای نبوت نمی‌کنم]»"
  38,87,"این [قرآن] جز پندی برای جهانیان [= انسان و جن] نیست"
  38,88,"و قطعاً پس از چندی [که مرگ به سراغتان آمد] از خبرِ [راستیِ] آن آگاه خواهید شد"
  39,1,نزول این کتاب، از سوی الله شکست‌ناپذیرِ حکیم است
  39,2,این کتاب را به‌حق بر تو نازل کردیم؛ پس الله را با خلوص اعتقاد عبادت کن
  39,3,"آگاه باشید که دین خالص [و خالی از شرک]، از آنِ الله است و افرادى كه غیر الله را [دوست و] كارساز خود انتخاب كرده‌اند [پندارشان این است كه:] «آنها را فقط به این دلیل عبادت می‌کنیم كه ما را به الله نزدیک ‌گردانند [و منزلتمان را بیشتر کنند]. الله در مواردی که با هم اختلاف دارند میان آنان [و موحدانِ راستین] داورى خواهد كرد. بی‌تردید، الله كسى را كه دروغگوی ناسپاس باشد، هدایت نخواهد كرد"
  39,4,"اگر الله مى‌خواست فرزندى برگزیند، از میان آفریدگان خود هرچه مى‌خواست برمى‌گزید. او تعالی [از این نسبت‌ها] منزه است، و اوست الله یگانۀ پیروزمند"
  39,5,"آسمان‌ها و زمین را به‌حق [و با هدف] آفرید. شب را بر روز مى‌گسترانَد و روز را بر شب؛ و خورشید و ماه را در خدمت [شما] گماشت که هر یک تا سرآمدِ معیّنى در حرکت است. آگاه باشید! او شکست‌ناپذیرِ آمرزگار است"
  39,6,"او شما را از یک تن آفرید، آنگاه همسرش را نیز از وی پدید آورد؛ و براى [استفادۀ] شما، هشت نوع از چهارپایان [= نر و مادۀ شتر، گاو، گوسفند و بز] را آفرید. شما را در شكم مادرتان طى مراحل مختلف در نهانگاه‌های سه‌گانه [پردۀ مَشیمه، رحِم و شكم] مى‌آفریند. این است الله، پروردگار شما كه فرمانروایى، خاص اوست. معبودى [به‌حق] جز او نیست؛ پس چگونه [از عبادت الله] به بیراهه می‌روید؟"
  39,7,"اگر ناسپاسی کنید، [بدانید که] الله از شما بی‌نیاز است و هرگز ناسپاسیِ بندگانش را نمی‌پسندد؛ و اگر شکر او را به جای آورید، این کار را برایتان می‌پسندد؛ و هیچ گناهکاری، بارِ گناه دیگری را بر دوش نمی‌کشد؛ بازگشتتان به سوی پروردگارتان است؛ آنگاه او شما را از آنچه انجام می‌دادید، آگاه می‌کند. یقیناً او از رازِ دل‌ها آگاه است"
  39,8,"هر گاه انسان دچار [رنج و] زیانی می‌شود، پروردگارش را [با تضرّع و زاری] می‌خواند و به درگاهش بازمی‌گردد؛ اما هنگامی که نعمتی از جانب خود به وی می‌بخشیم، مشکلی را که قبلاً برایش دعا می‌کرد از یاد می‌بَرد و برای الله [در قدرت،] همتایانی قائل می‌شود تا [دیگران را نیز] از راه او گمراه کند. [ای پیامبر، به چنین کسی] بگو: «چند صباحی با ناسپاسی [از نعمت‌های دنیا] بهره‌مند شو که قطعاً دوزخی خواهی بود»"
  39,9,"آیا [چنین مشرکی بهتر است یا] کسی که در طول شب، در حال سجده و قیام، به عبادت [الله] مشغول است و از [عذاب] آخرت ترسان است و به رحمت پروردگارش امید دارد؟ بگو: «آیا کسانی که [حق بندگی پروردگار را] می‌دانند و کسانی که نمی‌دانند، یکسانند؟ تنها خردمندان پند می‌پذیرند»"
  39,10,"[ای پیامبر،] بگو: «ای بندگان باایمانِ من، از پروردگارتان پروا کنید. افرادى كه نیكویى مى‌كنند، [علاوه بر آخرت، در این دنیا نیز] پاداش نیكو دارند. زمین الله گسترده است [پس اگر براى حفظ عقیدۀ خود دچار مشكل شدید، هجرت كنید]. قطعاً پاداش پایداران، کامل و بى‌دریغ عطا خواهد شد»"
  39,11,"بگو: «من مأمورم با خلوصِ اعتقاد، الله را عبادت کنم،"
  39,12,"و مأمور شده‌ام نخستین كسى [در این امت] باشم كه تسلیم [محض در مقابل پروردگار] است»"
  39,13,"بگو: «اگر در برابر پروردگارم نافرمان باشم، از عذاب روز بزرگ [قیامت] مى‌ترسم»"
  39,14,"[ای پیامبر] بگو: «من الله را با خلوصِ اعتقاد خود عبادت می‌کنم؛"
  39,15,"شما نیز غیر از الله، هر چه را می‌خواهید عبادت کنید». بگو: «زیانكاران [واقعى] كسانى هستند كه [به طمع دنیا] خود و خانواده‌هایشان را در رستاخیز به زیان انداختند. آگاه باشید كه این، همان زیان آشکار است"
  39,16,"بر بالای سر و زیر پایشان طبقاتى از آتش است. این است آنچه الله بندگانش را از آن مى‌ترساند. اى بندگان من، از [نافرمانى] من پروا كنید"
  39,17,"بشارت براى كسانى است كه از عبادت طاغوت [= معبودان غیر الله] اجتناب ورزیدند و [توبه‌کنان] به درگاه الهی بازگشتند؛ پس [ای پیامبر،] [بهشت را] به بندگانم بشارت بده"
  39,18,"[همان] کسانی که سخن[های مختلف] را می‌شنوند و از بهترین آن پیروى مى‌كنند. آنان كسانى هستند كه الله هدایتشان کرده و خردمندند"
  39,19,"آیا كسى را كه فرمان مجازات بر او قطعی شده است [می‌توان هدایت نمود]؟ آیا تو مى‌توانى کسی را كه در آتش است، نجات دهی؟"
  39,20,"اما كسانى كه از [عذاب] پروردگارشان پروا دارند، برای آنان [در بهشت] غرفه‌هایی است که بر فراز آنها غرفه‌های دیگری ساخته شده‌ [و] جویبارها از زیر آنها جاری است. این وعده را الله داده است و الله در وعده خلاف نمی‌کند"
  39,21,"آیا ندیده‌ای كه الله بارانى از آسمان فرستاد و آن را [به صورت] چشمه‌هایى در زمین جاری ساخت؛ آنگاه به وسیلۀ آن، كشتزارى با رنگ‌های گوناگون پدید مى‌آورد؛ سپس پژمرده مى‌گردد و مى‌بینى كه زرد شده است؛ آنگاه آن را خُرد و خاشاک مى‌سازد؟ بی‌تردید، در این [دگرگونی‌ها] پندی براى خردمندان است"
  39,22,"پس آیا كسى كه الله دلش را پذیراى اسلام كرده و از جانب پروردگارش، از نور [هدایت و بصیرت] برخوردار گشته، [همانند سختدلان است]؟ واى بر آنان که در برابرِ ذكر الله سنگدل شده‌اند! آنان در گمراهىِ آشكارند"
  39,23,"الله بهترین سخن را به صورت كتابى نازل كرده كه [برخی از آیاتش‌] همانند یكدیگر و [برخی نیز] مکرر است. كسانى كه از [مجازات] پروردگارشان بیم دارند، [با شنیدن این آیات،] مو بر تنشان راست می‌شود و سپس دل و جانشان با یاد الله آرام می‌گیرد. این هدایتِ الله است كه هر کس را بخواهد، به آن راه می‌نماید؛ و هر کس که الله او را گمراه سازد، هیچ هدایتگری نخواهد داشت"
  39,24,"پس آیا كسی كه در روز قیامت [دستانش بسته است و ناچار‌] با صورتش آن عذاب سخت را دفع مى‌كند، [همچون کسی است که در آسایش بهشت قرار دارد]؟ به ستمکاران [مشرک‌] گفته می‌شود: «[نتیجۀ‌] دستاوردتان را بچشید»"
  39,25,"کسانی که پیش از آنان بودند [نیز آیات الله را] دروغ شمردند و از جایى كه گمان نمى‌كردند، عذاب دامنگیرشان شد"
  39,26,"الله [طعم] رسوایی و خواری را در زندگی دنیا به آنان چشاند؛ و مسلّماً عذاب آخرت بزرگ‌تر [و سخت‌تر] است. اگر مشرکان می‌دانستند [که رفتارشان چه پیامدی دارد، عبرت می‌گرفتند]"
  39,27,"در این قرآن، از هر [گونه] مَثلى براى مردم آورده‌ایم؛ باشد که پند پذیرند"
  39,28,"قرآنى به زبان فصیح عربی و بدون هیچ گونه ابهام و انحراف [نازل كردیم]؛ باشد که [تحت تعلیماتش، از پروردگار یکتا] پروا کنند"
  39,29,"الله [براى مقایسۀ مشرک و موحد،] مردى را مثال می‌زند كه چند شریک دربارۀ [مالکیتِ] او پیوسته با هم اختلاف و مشاجره دارند؛ و در مقابل آن، مردى كه تحت فرمان یک نفر قرار دارد. آیا این دو نفر، [از نظرِ موقعیت] یكسانند؟ ستایش مخصوص الله است؛ ولى بیشتر آنان نمى‌دانند"
  39,30,"[ای پیامبر،] قطعاً تو خواهی مُرد و آنان [نیز] خواهند مُرد"
  39,31,"آنگاه [شما مردم] در روز قیامت، نزد پروردگارتان [دربارۀ مسایل مورد اختلاف،] مجادله خواهید کرد"
  39,32,و كیست ستمكارتر از کسی كه به الله، دروغ نسبت می‌دهد و سخن راستی را كه به وی رسیده است، دروغ می‌شمارد؟ آیا در دوزخ، جایگاهى براى کافران نیست؟
  39,33,"اما کسانی که پیام راستین بیاورند [و دیگران را به پذیرش آن دعوت کنند] و خود نیز آن را تصدیق نمایند، به راستی پرهیزگارند"
  39,34,هر چه بخواهند، نزد پروردگارشان دارند. پاداش نیكوكاران همین است
  39,35,"تا الله، بدترین رفتارشان را از [كارنامۀ] آنان بزداید و بر اساس بهترین اعمالشان، به آنان پاداش دهد"
  39,36,"آیا الله براى دفاع از بنده‌اش كافى نیست؟ اما [مشرکان] تو را از معبودان[باطل]شان مى‌ترسانند؛ و هر کس كه الله او را گمراه کند، هیچ هدایتگری نخواهد داشت"
  39,37,و هر کس که الله او را هدایت کند، هیچ کس او را گمراه نخواهد ساخت. آیا الله شکست‌ناپذیر و انتقام‌گیرنده نیست؟
  39,38,"[ای پیامبر،] اگر از مشرکان بپرسی: «چه کسی آسمان‌ها و زمین را آفریده است؟»، مسلماً می‌گویند: «الله». به آنان بگو: «پس به نظر شما، اگر الله ناخوشی و رنجی برایم بخواهد، آیا آنچه به جاى الله [به نیایش] مى‌خوانید، می‌توانند آسیب او را برطرف کنند؟ یا اگر الله رحمتى براى من بخواهد، آیا مى‌توانند مانع او شوند؟» بگو: [پشتیبانیِ] الله برایم کافی است. اهل توکل، تنها بر او توكل مى‌كنند»"
  39,39,"بگو: «اى قوم من، شما بر روش خود عمل کنید، من نیز [به وظایف خود] عمل مى‌كنم"
  39,40,"به زودى خواهید دانست كه كیست آنكه [در دنیا] گرفتارِ عذاب رسواگر می‌شود و [در آخرت،] عذاب پاینده بر سرش می‌بارد»"
  39,41,"این كتاب آسمانی را براى [هدایت] مردم، به‌حق بر تو نازل كردیم؛ هر کس هدایت شود، به سودِ خود اوست و هر کس گمراه گشت، به زیان خویش گمراه شده است؛ و تو [نگهبان و] کارسازشان نیستى [که آنان را به هدایت اجبار کنی]"
  39,42,"الله جان‌ها را در لحظۀ مرگ مى‌گیرد و [نیز] جان کسی را كه نمرده است، به هنگام خوابش [مى‌گیرد]؛ آنگاه جان‌هایی را كه حكم مرگ بر آنها رانده است، نگه مى‌دارد و جانِ دیگران را تا هنگام معین [مرگ] بازپس می‌فرستد. در این [امر] براى هر کس که بیندیشد، نشانه‌هایى [از قیامت] وجود دارد"
  39,43,"آیا مشرکان غیر از الله، شفیعانی [برای خود از میان معبودان باطلشان] انتخاب کرده‌اند؟ [ای پیامبر، به آنان] بگو: «حتی اگر آنها مالک چیزی نباشند و [چیزی را] درک نکنند [باز هم آنها را به شفاعت می‌طلبید]؟»"
  39,44,"بگو: «تمام شفاعت‌ها، فقط از آنِ الله است. فرمانروایی آسمان‌ها و زمین [نیز] از آن اوست؛ سپس [در روز قیامت، همگی] به پیشگاهِ او بازگردانده می‌شوید»"
  39,45,"هنگامی که الله به یکتایی [و توحید] یاد می‌شود، دل‌های کسانی که به آخرت ایمان ندارند، متنفر [و بیزار] می‌گردد؛ و چون از معبودانی غیر از الله یاد شود، آنگاه است که مشرکان شادمان می‌گردند"
  39,46,"بگو: «بار الها، [ای] آفرینندۀ آسمان‌ها و زمین، ای دانای ‌نهان و آشکار، تو [به تنهایی] میان بندگانت راجع به آنچه [در دنیا] در آن اختلاف می‌ورزیدند داوری خواهی کرد»"
  39,47,"اگر دو برابر آنچه در زمین است، در اختیار ستمکاران [مشرک] باشد، همه را براى نجات خود از سختىِ عذابِ روز قیامت فدا مى‌كنند؛ [ولى پذیرفتنى نیست]؛ و اموری از جانب الله برایشان آشكار مى‌گردد كه تصورش را هم نمى‌كردند"
  39,48,"[در آن روز،] دستاورد زشتشان بر آنان آشكار مى‌شود و عذابى كه مسخره مى‌كردند، دامنگیرشان خواهد شد"
  39,49,"هر گاه انسان دچار [رنج و] زیانی شود، ما را [به نیایش] مى‌خواند؛ و چون از جانب خویش نعمتى به وی ارزانى‌ داریم، می‌گوید: «فقط [لیاقت و] داناییِ‌ خودم موجب این نعمت شده است. [نه،] بلكه این آزمایش [الهی] است؛ ولى بیشتر مردم نمى‌دانند"
  39,50,"پیشینیان آنان نیز همین سخن را گفتند؛ ولى [به هنگام عذاب،] دستاوردشان سودى به حالشان نداشت"
  39,51,"و [عقوبت] دستاورد زشت آنان دامنگیرشان شد. این ستمکاران [مشرک] نیز به عقوبت دستاوردشان گرفتار خواهند شد و [پروردگار متعال را] به تنگ نخواهند آورد"
  39,52,"آیا مشرکان نمی‌دانند که الله [نعمت و] روزی را بر هر کس که بخواهد، گسترده می‌دارد و یا تنگ می‌گرداند؟ بی‌گمان در این امر، نشانه‌هایی [از تدبیر و حکمت الهی] برای مومنان است"
  39,53,"[ای پیامبر،] به بندگانم که [در ارتکاب به شرک و گناه] زیاده‌روی کرده‌اند، بگو: «از رحمت الهی مأیوس نباشید؛ چرا که [اگر توبه کنید،] الله همۀ گناهانتان را می‌بخشد. به راستی که او تعالی بسیار آمرزنده و مهربان است"
  39,54,"پیش از آنکه عذاب به سراغتان بیاید و هیچ کس نتواند یاری‌تان کند، به سوی پروردگار‌تان بازگردید و تسلیم [فرمانِ] او شوید"
  39,55,و پیش از آنكه ناگهان ـ در حالی که غافلید ـ عذاب به سراغتان بیاید، از بهترین دستورهایى كه از جانب پروردگارتان بر شما نازل شده است، پیروى کنید
  39,56,"[هم‌اکنون بر حذر باشید] تا کسی [در روز قیامت] نگوید: «ای دریغ بر من که در حقِ الله کوتاهی نمودم و [مؤمنان را] مسخره می‌کردم!»"
  39,57,"یا [گناه خود را بر گردن تقدیر نیندازد و] نگوید: «اگر الله مرا هدایت کرده بود، قطعاً پرهیزگار بودم»"
  39,58,"یا هنگامی که عذاب را می‌بیند، نگوید: «ای کاش بازگشتی [به دنیا] داشتم تا در زمرۀ نیکوکاران قرار می‌گرفتم»"
  39,59,"[الله می‌فرماید:] «آری، آیات من برایت آمد و تو آنها را دروغ پنداشتی و تکبر نمودی و کفر ورزیدی»"
  39,60,و روز قیامت کسانی را که بر الله دروغ بسته‌اند، سیه‌روی می‌بینی. آیا در دوزخ جایگاهی برای متکبران نیست؟
  39,61,"الله، پرهیزگاران را با درآوردن به مکان کامیابی‌شان، [از عذاب] نجات می‌دهد. [در بهشت،] نه رنجی به آنان می‌رسد و نه اندوهگین می‌شوند"
  39,62,"الله آفریدگار هر چیزی است و او تعالی بر همه چیز [نگهبان و] کارساز است"
  39,63,کلید گنجینه‌های آسمان‌ها و زمین از آنِ اوست؛ و کسانی که به آیات الهی کافر شدند، قطعاً زیانکارند
  39,64,"[ای پیامبر،] بگو: «ای بی‌خبران، آیا به من فرمان می‌دهید که [معبودی] غیر از الله را عبادت کنم؟»"
  39,65,"به تو و پیامبرانِ پیش از تو وحى شده است كه: «اگر شرک بورزى، [پاداشِ] کارهایت قطعاً بر باد خواهد رفت و زیانكار خواهى شد؛"
  39,66,بلکه تنها الله را عبادت کن و سپاسگزار باش»
  39,67,"مشرکان، الله را چنان كه سزاوار اوست، ارج ننهادند؛ حال آنکه در روز قیامت، زمین یكسره در قبضۀ اوست؛ و آسمان‌ها به دست وی درهم‌پیچیده خواهد شد. پاک و منزه است الله؛ و از چیزهایی که با [وی] شریک می‌سازند، برتر است"
  39,68,"[در آستانۀ قیامت،] در «صور» دمیده می‌شود؛ آنگاه هر کس که در آسمان‌ها و در زمین است، مدهوشِ مرگ خواهد شد ـ مگر كسى كه الله بخواهد؛ آنگاه بار دیگر در آن دمیده می‌شود و ناگهان [همه از مرگ] برمی‌خیزند و چشم‌به‌راه [فرمان پروردگار] هستند"
  39,69,"[در روز قیامت،] زمین به نورِ پروردگارش روشن خواهد شد و نامۀ [اعمال] نهاده می‌شود و پیامبران و گواهان را می‌آورند و به حق و عدالت میان مردم داوری می‌شود و هرگز به آنان ستم نخواهد شد"
  39,70,و جزای عملکردِ هر کس، به تمام و کمال داده می‌شود؛ و الله نسبت به اعمالشان دانا‌تر است
  39,71,"کافران گروه‌گروه به سوى دوزخ رانده مى‌شوند. همین كه به آنجا می‌رسند، درهایش [به روی آنان] گشوده می‌گردد و نگهبانانش می‌گویند: «آیا پیامبرانی از میان خود شما به سراغتان نیامدند كه آیات پروردگارتان را برای شما مى‌خواندند و دربارۀ دیدار این روز هشدار مى‌دادند؟» آنان [در پاسخ] مى‌گویند: «آری؛ ولى [ما آنان را انکار كردیم و] فرمان مجازات، سزاى کافران است»"
  39,72,"[به آنان] گفته مى‌شود: «از درهاى دوزخ وارد شوید و جاودانه در آن به سر ‌بَرید؛ و [به راستى] جایگاه متكبران، چه بد [جایگاهى] است!»"
  39,73,"و كسانى كه از پروردگارشان پروا داشتند، گروه‌گروه به سوى بهشت هدایت مى‌شوند؛ همین كه به آنجا می‌رسند ـ در حالی كه درهاى بهشت گشوده شده است ـ [با عزت و احترام وارد می‌شوند] و نگهبانان آنجا می‌گویند: «سلام بر شما. خوش آمدید. [و] برای همیشه [در آن بمانید]»"
  39,74,"بهشتیان مى‌گویند: «ستایش و سپاس مخصوص الله است كه وعدۀ خویش را در مورد ما تحقق بخشید و سرزمین [پهناور بهشت] را به ما میراث داد كه در هر جاى آن بخواهیم، منزل می‌گیریم؛ و [به راستى] پاداش اهل عمل، چه نیكوست!»"
  39,75,"[در آن روز،] فرشتگان را خواهی دید كه پیرامون عرش حلقه زده‌اند و پروردگارشان را به پاکی می‌ستایند؛ و به حق و عدالت میان مردم داورى خواهد شد و گفته مى‌شود: «ستایش و سپاس، مخصوص الله - پروردگار جهانیان- است»"
  40,1,"حم [حا. میم]"
  40,2,"نزول [این] کتاب، از سوی الله شکست‌ناپذیرِ داناست"
  40,3,"[پروردگاری که] آمرزندۀ گناه و توبه‌پذیر، سخت‌کیفر و نعمت‌بخش است؛ هیچ معبودی [به‌حق] جز او نیست و بازگشت [همه] به سوی اوست"
  40,4,"تنها کافران هستند که دربارۀ آیات الهی مجادله مى‌كنند؛ پس مبادا رفت و آمدشان در شهرها [برای تجارت و بهره‌مندی‌شان از نعمت‌های دنیا] تو را بفریبد"
  40,5,"پیش از آنان قوم نوح، و پس از آنان نیز گروه‌های دیگری [همچون قوم عاد و ثمود و لوط نیز پیامبرانشان را] دروغگو شمردند و هر قومی خواست پیامبرش را دستگیر كند [و به قتل برساند]. آنان به باطل مجادله كردند تا به وسیله آن، حق را از میان بردارند؛ من نیز آنان را عذاب کردم؛ [پس بنگرید که] عذابِ من چگونه بود"
  40,6,و فرمان عذابِ پروردگارت درباره کافران اینچنین به تحقق پیوست كه آنان اهل آتشند
  40,7,"فرشتگانى كه عرش را حمل مى‌كنند و فرشتگانى كه گردِ آن حلقه زده‌اند، پروردگارشان را به پاکی می‌ستایند و به او ایمان دارند و [این گونه] براى اهل ایمان آمرزش مى‌خواهند: «پروردگارا، رحمت و دانشت، هر چیزى را فراگرفته است؛ پس كسانى را كه توبه كردند و پیرو راه تو شدند، بیامرز و از عذاب دوزخ دور نگاه دار»"
  40,8,"پروردگارا، آنان و پدران [و مادران] و همسران و فرزندان صالحشان را در باغ‌های جاودان بهشت كه وعده داده‌اى، داخل كن، كه بی‌تردید، تو شکست‌ناپذیر و حکیمی"
  40,9,"[بار الها،] آنان را از [كیفرِ] بدی‌ها حفظ كن؛ و قطعاً هر کس را که در آن روز از [كیفرِ] بدی‌ها نگاه دارى، مشمول رحمتت قرار داده‌اى. این، همان كامیابى بزرگ است»"
  40,10,"[در دوزخ] به کافران ندا مى‌دهند كه: «دشمنى و خشم الله، سخت‌تر از دشمنى و خشم شما نسبت به خودتان است؛ چرا كه به ایمان دعوت مى‌شدید، ولى [با دشمنى نسبت به خود، عقیدۀ توحیدی را] انكار مى‌كردید»"
  40,11,"آنان [در پاسخ] می‌گویند: «پروردگارا، ما را دوبار میراندی و دو بار زنده کردی؛ پس [اکنون که] به گناهان خود اعتراف کردیم، آیا راهی برای خروج [از دوزخ] وجود دارد؟»"
  40,12,"[به آنان گفته می‌شود:] «این [عذاب] به سبب آن است که چون الله به یگانگی خوانده می‌شد، انکار می‌کردید؛ ولی اگر به او شرک آورده می‌شد ایمان می‌آوردید. [اکنون] داوری از آن الله بلندمرتبۀ بزرگ است"
  40,13,"او همان ذاتی است که نشانه‌های [توان و تدبیر] خود را به شما ارائه می‌دهد و [با نزول باران] از آسمان روزى برایتان مى‌فرستد؛ ولى تنها كسانى پند مى‌گیرند كه [خالصانه به درگاه الهی] توبه ‌کنند"
  40,14,"[ای مردم! تنها] الله را با خلوصِ اعتقاد بخوانید؛ هر چند کافران خوششان نیاید"
  40,15,"او دارای درجات رفیع و صاحبِ عرش است؛ و به سوی هر یک از بندگانش كه بخواهد، به فرمان خویش وحى مى‌فرستد تا دربارۀ روز ملاقات [به آنان] هشدار دهد"
  40,16,"روزی كه مردم حاضر و نمایان می‌شوند و چیزی از آنان بر الله پوشیده نخواهد ماند، [الله می‌فرماید:] «امروز فرمانروایی از آنِ کیست؟» [آنگاه خود می‌فرماید:] «از آنِ الله یگانه پیروزمند»"
  40,17,امروز هر کس در برابر آنچه کرده است، پاداش داده می‌شود و هیچ ستمی در میان نیست. بی‌گمان، الله در حسابرسی سریع است
  40,18,"در مورد روز قیامت [که بسیار نزدیک است] به آنان هشدار بده؛ آنگاه كه جان‌ها [از شدت وحشت] به گلوگاه مى‌رسد، در حالى كه سرشار از‌ اندوه شده‌اند. [در آن روز،] ستمگران نه دوستى مهربان دارند و نه شفیعی كه سخنش پذیرفته شود"
  40,19,"[الله] حركات شرورانۀ چشم‌ها و آنچه را که در دل‌های افراد نهفته است، [به خوبی] مى‌داند"
  40,20,"الله به عدالت داوری مى‌كند؛ و معبودانى كه [مشركان] به جاى الله عبادت می‌کنند، هیچ گونه [حق] داوری ندارند. به راستی که الله شنوای بیناست"
  40,21,"آیا مشرکان در زمین نگشته‌اند تا ببینند سرانجامِ کسانی که پیش از آنان بودند، چگونه بوده است؟ آن اقوام گذشته، نیرومندتر از اینها بودند و آثار و بناهای [استوارتر] بیشتری در زمین پدید آوردند؛ اما الله آنان را به [سبب] گناهانشان عذاب کرد، در حالی که در برابرِ [عذاب] الله، هیچ [یار و] مدافعی نداشتند"
  40,22,"این [كیفر] به سبب آن بود كه پیامبرانشان نشانه‌هاى روشن برایشان ارائه مى‌كردند، ولى آنان انكار می‌ورزیدند و الله [نیز] آنان را عذاب کرد. بی‌گمان، او توانمندى سخت‌كیفر است"
  40,23,ما موسى را با معجزاتِ خود و دلیلى قاطع فرستادیم
  40,24,"به سوی فرعون و هامان و قارون؛ ولی [آنان] گفتند: «[او] جادوگری دروغگوست»"
  40,25,"اما هنگامی که موسی، معجزات الهی و دلایل محکم را از جانب ما بر آنان ارائه كرد، [فرعون و یارانش سرکشی کردند و] گفتند: «پسران كسانى را كه به موسى ایمان آورده‌اند، بكشید و زنانشان را [براى کنیزی] زنده نگاه دارید»؛ و[لى] نیرنگ کافران، محكوم به فناست"
  40,26,"فرعون گفت: «بگذارید موسى را بکشم؛ و [چون كسى را ندارد،] ناگزیر است پروردگارش را به یاری بخواند [و من از وی هراسی ندارم]. مى‌ترسم که او دینتان را دگرگون سازد یا در این سرزمین تباهى به بار آورد»"
  40,27,"موسی گفت: «من از [شر] هر متکبری که به روز حساب باور ندارد، به پروردگار خویش و پروردگار شما پناه می‌برم»"
  40,28,"و مرد مؤمنی از خانوادۀ فرعون که ایمانش را پنهان می‌داشت، گفت: «آیا می‌خواهید این مرد را [فقط به این جرم] بکشید که می‌گوید: \"پروردگارم الله است\" و [در تأیید سخنش نیز] دلایل روشنی از سوی پروردگار‌تان برای شما آورده است؟ اگر دروغگو باشد، [گناه] دروغش بر عهدۀ خودِ اوست؛ و اگر راست گفته باشد، [دست‌کم] برخى از عذاب‌هایی كه وعده مى‌دهد، به شما خواهد رسید. بی‌تردید، الله، کسی را که اسرافکار و دروغگوست، هدایت نمی‌کند"
  40,29,"ای قوم من، امروز فرمانروایى در اختیار شماست [و] در این سرزمین سُلطه دارید؛ ولى اگر سختگیرىِ الله دامنگیرمان شود، چه كسى ما را یارى خواهد كرد؟» فرعون گفت: «من فقط آنچه را صلاح می‌دانم می‌گویم و شما را به راه راست هدایت مى‌كنم»"
  40,30,"آن مرد مؤمن گفت: «ای قوم من، می‌ترسم عذابی همچون عذاب اقوام پیشین [که از پیامبرانشان سرپیچی کردند] بر سرتان بیاید؛"
  40,31,"مانند شیوۀ [عذاب] قوم نوح و عاد و ثمود و کسانی که بعد از آنان بودند؛ در حالی که الله ستمی برای بندگانش نمی‌خواهد"
  40,32,و ای قوم من، از روزی بر شما می‌ترسم که مردم به فریاد از یکدیگر یاری‌ می‌خواهند
  40,33,"[همان] روزى كه همگی [از ترس] به عقب بازمى‌گردید و در برابر [مجازاتِ] الله، هیچ محافظى ندارید؛ و هر کس که الله او را گمراه كند، هیچ هدایتگری نخواهد داشت"
  40,34,"پیش از این نیز یوسف با دلایل روشن نزدتان آمد؛ اما شما از آنچه برایتان آورده بود پیوسته در شک بودید، تا زمانی که از دنیا رفت [و بر تردیدتان افزوده شد]؛ آنگاه گفتید: «الله هرگز پس از وی پیامبری را مبعوث نخواهد کرد». الله، اسرافکارِ بدگمان را این‌گونه گمراه می‌سازد"
  40,35,"كسانى كه در مورد آیات الهی ـ بدون اینکه دلیلى داشته باشند ـ به مجادله برمى‌خیزند، [رفتارشان] نزد الله و مؤمنین، سخت ناپسند است. الله این‌گونه بر دل هر متكبرِ خودكامه‌ای مهر [غفلت] مى‌نهد»"
  40,36,"فرعون [به وزیرش] گفت: «ای هامان، بنای بلندی برایم بساز؛ شاید به راه‌هایی برسم؛"
  40,37,"راه‌هایی در‌ آسمان‌ها [که مرا تا عرش الهی ببرد] تا به معبود موسی بنگرم [و از او آگاه شوم]؛ هر چند که من قطعاً او را دروغگو می‌پندارم». این‌گونه، زشتیِ کردارِ فرعون، [در نظرش] آراسته گشت و از راه [حق] بازماند؛ و نیرنگ فرعون، به زیان و تباهی انجامید"
  40,38,"آن مرد مؤمن گفت: «ای قوم من، از من پیروی کنید تا شما را به راه راست هدایت کنم"
  40,39,"ای قوم من، این زندگی دنیا، بهره‌ای [اندک و زودگذر] است؛ و آخرت، سرای جاودان است"
  40,40,هر ‌کس کار بدی مرتکب شود، به تناسبِ آن کیفر خواهد دید؛ و مردان و زنان مؤمن و نیکوکار، به بهشت وارد می‌شوند و در آنجا از نعمتِ بی‌شمار برخوردار خواهند شد
  40,41,"ای قوم من، چه شده كه من شما را به راه نجات دعوت مى‌كنم، و[لى] شما مرا به آتش فرامى‌خوانید؟"
  40,42,"مرا دعوت مى‌كنید كه الله را انكار كنم و چیزى را [در قدرت] با الله شریک گردانم كه هیچ اطلاعى از آن ندارم؛ در حالى كه من شما را به سوى [پروردگار] شکست‌ناپذیر و آمرزگار فرامى‌خوانم"
  40,43,"قطعاً، آنچه مرا به آن دعوت مى‌دهید، در دنیا و آخرت [توان اجابت] دعایى را ندارد؛ و بازگشت ما به پیشگاه الله است، و اسرافكاران [در کفر و گناه،] دوزخى هستند"
  40,44,"به زودى سخنان مرا به یاد خواهید آورد؛ و من كار خود را به الله واگذار مى‌كنم؛ زیرا الله نسبت به [کردارِ] بندگان بیناست»"
  40,45,الله او را از آسیب دسیسۀ آنان حفظ نمود و عذاب سخت، دامنگیر فرعونیان شد
  40,46,"همان آتشی كه [در قبرهایشان] بامداد و شامگاه بر آن عرضه مى‌شوند؛ و روزی که قیامت برپا گردد، [فرمان می‌رسد که:] «فرعونیان را در سخت‌ترین عذاب درآورید»"
  40,47,"آنگاه كه در آتش دوزخ کشمکش [و مجادله] می‌کنند، مردمانِ زیردست به رهبران گمراهگر می‌گویند: «ما پیرو شما بودیم؛ آیا ممكن است بخشى از عذاب آتش را از ما دور کنید؟»"
  40,48,"رهبران گمراهگر می‌گویند: «بی‌تردید، همۀ ما در آتش خواهیم بود. الله میان بندگان [خود] داورى كرده است»"
  40,49,"و كسانى كه در آتشند، به نگهبانان دوزخ مى‌گویند: «از پروردگارتان بخواهید كه برای یک روز، این عذاب را از ما بردارد»"
  40,50,"آنان پاسخ مى‌دهند: «مگر پیامبرانتان نشانه‌هاى روشن بر شما ارائه نكردند؟ دوزخیان مى‌گویند: «بله»؛ و مأموران مى‌گویند: «پس [بى‌نتیجه] درخواست كنید که درخواست کافران، [مردود و] تباه است»"
  40,51,"بی‌گمان، ما پیامبران خویش و اهل ایمان را در زندگى دنیا و روزى كه گواهان [به شهادت] برمی‌خیزند، یارى مى‌كنیم"
  40,52,"روزى كه عذرخواهىِ ستمگران سودى به حالشان نخواهد داشت؛ آنان از رحمت الهی به دورند و دشوارى عذاب آخرت را [در پیش] دارند"
  40,53,"ما [مقام] هدایت به موسی بخشیدیم و بنی‌اسرائیل را وارثان تورات قرار دادیم؛"
  40,54,"[کتابی‌که] برای خردمندان، هدایت و پند است"
  40,55,"پس [ای پیامبر، بر آزارِ مشرکان] شكیبا باش [كه] قطعاً وعدۀ الهی راست است و براى گناهت آمرزش بخواه و پروردگارت را شامگاه و بامداد، به پاکی ستایش کن"
  40,56,"كسانى كه در مورد آیات الهی ـ بدون اینکه دلیلى در اختیارشان باشد ـ به مجادله برمى‌خیزند، در دل‌هایشان [غرور و] تکبری است كه هرگز به آن نخواهند رسید؛ پس [از شرِ آنان] به الله پناه ببر كه به راستی، او شنوای بیناست"
  40,57,"مسلماً آفرینش آسمان‌ها و زمین بزرگ‌تر از آفرینشِ انسان‌هاست؛ [بنابر این برپاییِ قیامت، برای الله دشوار نیست]؛ ولی بیشتر مردم نمی‌دانند"
  40,58,"نابینا و بینا هرگز برابر نیستند، و مؤمنان نیكوكار با بدكاران یكسان نخواهند بود؛ [ولى] عدۀ كمى از شما پند مى‌پذیرید"
  40,59,هیچ تردیدی در این نیست که روز قیامت فرامی‌رسد؛ ولی بیشتر مردم ایمان نمی‌آورند
  40,60,"پروردگارتان فرمود: «مرا به دعا بخوانید، تا [دعای] شما را اجابت کنم. کسانی که از عبادت من سرکشی می‌کنند، به زودی با خواری به جهنم وارد می‌شوند»"
  40,61,"الله است كه شب را برایتان پدید آورد تا در آن آرامش یابید و روز را روشنى‌بخش [قرار داد تا به تلاش پردازید]. به راستى، الله نسبت به مردم [لطف و] بخشش دارد؛ ولى بیشتر مردم سپاس نمی‌گزارند"
  40,62,"این است الله، پروردگار شما [که] آفرینندۀ هر موجودی [است]. هیچ معبودی [به‌حق] جز او نیست؛ پس چگونه [از عبادت او] منحرف می‌شوید؟"
  40,63,"به همین صورت، كسانى كه آیات الهی را انكار مى‌كنند نیز [از حق] منحرف می‌گردند"
  40,64,الله است که زمین را قرارگاه و آسمان را سرپناهتان مقرر داشت و شما را صورتگرى كرد و نیكو صورتگرى كرد و از نعمت‌های پاكیزه به شما روزى داد؛ این است الله، پروردگار شما؛ پس پر برکت و بزرگوار است الله که پروردگار جهانیان است
  40,65,"الله زنده [و پاینده] است و معبودى [به‌حق] جز او نیست؛ پس او را با خلوص اعتقاد بخوانید. ستایش و سپاس مخصوص الله، پروردگار جهانیان است"
  40,66,"[ای پیامبر،] بگو: «من از عبادت افرادى كه شما به جاى الله [به نیایش] مى‌خوانید، نهى شده‌ام؛ زیرا نشانه‌هاى روشنی از جانب پروردگارم به من رسیده است و فرمان یافته‌ام كه [تنها] در برابر پروردگار جهانیان تسلیم باشم»"
  40,67,"او تعالی ذاتی است كه شما را از خاک، و سپس [طى مراحل مختلف] از نطفه و آنگاه خون بسته [= جنین ابتدایى] آفرید؛ سپس شما را [به صورت] كودكى [به دنیا] مى‌آورد، و امكان مى‌دهد تا به حد رشد [و کمال نیرو] برسید؛ سپس [سال‌ها زندگی می‌کنید تا] سالخورده می‌شوید. برخی از شما دچار مرگِ زودرس خواهند شد و [به گروهى دیگر امكان می‌دهد] تا به اجل معیّن برسید؛ باشد که بیندیشید"
  40,68,"او ذاتی است که زنده می‌کند و می‌میرانَد و هنگامی که چیزی را می‌خواهد، تنها به آن می‌گوید: «موجود شو»؛ پس [بی‌درنگ] موجود می‌شود"
  40,69,"آیا ندیدی کسانی که دربارۀ آیات الهی مجادله می‌کنند، چگونه [از راه حق] منحرف می‌گردند؟"
  40,70,"کسانی که كتاب [آسمانى] و پیام پیامبران ما را دروغ شمردند، به زودى [نتیجۀ کردارشان را] خواهند دانست"
  40,71,آنگاه كه غل و زنجیر بر گردنشان قرار گرفته و كشیده می‌شوند
  40,72,"[ابتدا] در آب داغ [و] سپس در آتش دوزخ افروخته مى‌شوند"
  40,73,"سپس به آنان گفته می‌شود: «چیزهایی که شریک [الله] قرار مى‌دادید، کجا هستند؟"
  40,74,"[همان معبودانی که آنها را] به جای الله [عبادت می‌کردید]. آنان گویند: «از [نظر] ما ناپدید شدند؛ گویی ما هرگز پیش از این چیزی را [به عبادت] نمی‌خواندیم». این‌گونه الله کافران را گمراه می‌کند"
  40,75,"این [عذاب] از آن جهت است كه به ناحق در زمین شادمانى و سرمستى مى‌كردید و فخر مى‌فروختید"
  40,76,"[اکنون] از در‌های جهنم وارد شوید و جاودانه در آنجا بمانید. و [به راستى که] جایگاه متكبران چه بد [جایگاهى] است"
  40,77,"[ای پیامبر، بر آزار مشرکان] شکیبا باش که وعدۀ الهی حق است؛ و اگر برخى از مجازات‌هایی را كه به آنان وعده داده‌ایم، [در زندگی] به تو بنماییم یا [پیش از نزول عذاب،] جان تو را بگیریم، در هر حال، به پیشگاه ما بازگردانده مى‌شوند [و راه گریزی از عذاب ندارند]"
  40,78,"پیش از تو نیز پیامبرانی فرستاده‌ایم كه [سرگذشت] برخى از آنان را برایت حكایت كرده‌ایم و [سرگذشت] برخى دیگر را حكایت نكرده‌ایم؛ و هیچ رسولى نمی‌توانست بدون فرمان الهی معجزه‌اى ارائه كند؛ و آنگاه كه فرمان الله [براى پاداش و كیفر] فرارسد، به حق و عدالت داورى خواهد شد و باطل‌اندیشان زیانكار خواهند بود"
  40,79,الله است که چهارپایان را برایتان آفرید تا از برخى براى سوارى و از برخى براى تغذیه استفاده كنید
  40,80,"و سودهای دیگری نیز در آنها برایتان است؛ و [نیز] برای آنکه سوار بر آنها به مقصدی که در دل دارید برسید؛ و بر آنها و بر کشتی‌ها [به هر جا که می‌خواهید] منتقل می‌شوید"
  40,81,"الله نشانه‌های [قدرت و تدبیرِ] خود را به شما نشان می‌دهد؛ پس کدام یک از نشانه‌های الهی را انکار می‌کنید؟"
  40,82,"آیا مشرکان در زمین نگشته‌اند تا ببینند سرانجامِ کسانی که پیش از آنان بودند، چگونه بوده است؟ آن اقوام گذشته، نفراتشان از اینها افزون‌تر بود و آثار و بناهای بیشتری در زمین پدید آورده بودند؛ اما [در هنگام نزول عذاب،] دستاورد آنان سودى به حالشان نداشت"
  40,83,"هنگامى كه پیامبرانشان با نشانه‌هاى روشن به سراغشان آمدند، به دانش و كاردانىِ خود سرمست [و از توحید، رویگردان] شدند و همان عذابى كه آن را مسخره مى‌كردند، دامنگیرشان شد"
  40,84,"هنگامی که عذاب ما را دیدند، گفتند: «تنها به الله ایمان آوردیم و معبودانی را که شریک او قرار داده بودیم، انکار می‌کنیم»"
  40,85,"اما ایمان‌آوردنشان به هنگام مشاهدۀ عذاب، هیچ سودی نداشت. این سنت الهی [که در هنگام عذاب، توبۀ کسی پذیرفته نمی‌گردد، همواره] در مورد بندگانِ الله جارى بوده است؛ و در این هنگام، کافران زیانكار شده‌اند"
  41,1,"حم [حا. میم]"
  41,2,"[این قرآن،] از سوی الله بخشندۀ مهربان نازل شده است"
  41,3,کتابی است که آیاتش به زبان عربی، برای مردمی که می‌دانند، به شیوایی و روشنی بیان شده است
  41,4,"[کتابی] بشارت‌دهنده و بیم‌دهنده است؛ ولی بیشتر مردم رویگردانند و [حقایق را] نمی‌شنوند"
  41,5,"مشرکان گفتند: «دل‌های ما نسبت به آنچه ما را دعوت می‌کنی در پوششی [از بى‌تفاوتى] قرار دارد و در گوش‌هایمان سنگینی است و میان ما و تو فاصله است؛ پس تو به کارِ خود مشغول باش و ما نیز به کارِ خود»"
  41,6,"[ای پیامبر، به آنان] بگو: «من فقط بشرى همچون شما هستم [با این تفاوت] كه به من وحى مى‌شود: «معبودِ شما، معبودى است یگانه؛ پس به او روى آورید و از او آمرزش بخواهید؛ و واى به حال مشركان!»"
  41,7,همان کسانی که زكات نمى‌پردازند و آخرت را انكار مى‌كنند
  41,8,"[ولى] مؤمنانِ نیكوكار پاداشى بى‌پایان دارند"
  41,9,"بگو: آیا به آن [خالقِ توانمندی] كه زمین را در دو روز آفرید، کفر می‌ورزید و همتایانى برایش قائل مى‌شوید؟ این [آفریدگار یکتاست که] پروردگار جهانیان است"
  41,10,او طى چهار روز، کوه‌های استواری بر روى زمین پدید آورد و خیر و بركتِ فراوان در آن نهاد و رزق و روزیِ آن را درست به ‌اندازۀ نیازِ تقاضا‌كنندگان مقدّر نمود
  41,11,"آنگاه به آسمان پرداخت، در حالى كه [هنوز به صورت] دودی بود؛ و به آسمان و زمین گفت: «خواه یا ناخواه، از درِ تسلیم درآیید». آن دو گفتند: «با میل، از درِ تسلیم درآمدیم»"
  41,12,"سپس آن تودۀ گاز را به صورت هفت آسمان، در دو روز آفرید و به هر آسمانى برنامه‌اش را وحى كرد؛ و آسمان دنیا را با چراغ‌هایى [از ستارگان] آراستیم و [آن را از شرِ شیاطین] حفظ نمودیم؛ این است تقدیر [پروردگارِ] شکست‌ناپذیرِ دانا"
  41,13,"[ای پیامبر،] اگر آنان [از پذیرشِ اسلام] روی گرداندند، بگو: «من شما را از صاعقه‌اى مانند صاعقه [هلاکت قوم] عاد و ثمود هشدار مى‌دهم»"
  41,14,"آنگاه كه پیامبران الهی پیاپی به سراغشان می‌آمدند [با این پیام] كه: «جز الله را عبادت نکنید»، آنان [در پاسخ] می‌گفتند: «اگر پروردگارمان مى‌خواست [پیامِ هدایتگری بفرستد،] فرشتگانى نازل مى‌كرد. ما پیامى را كه شما مأمور [ابلاغ] آن هستید باور نمى‌كنیم»"
  41,15,"اما [قوم] عاد به ناحق در زمین تکبر می‌ورزیدند و می‌گفتند: «چه كسى نیرومندتر از ماست؟» آیا نمى‌دانستند الله [آن خالق یکتایی] كه آنان را آفریده، نیرومندتر از آنان است؟ ولى [با لجاجت] آیات ما را انكار مى‌كردند"
  41,16,"سرانجام تندبادى سرد و سخت در روزهایى شوم بر آنان فرستادیم تا عذابِ رسوایى [و خفت] را در زندگى دنیا به آنان بچشانیم؛ ولى عذاب آخرت رسواكننده‌تر است و [از هیچ سو] یارى نخواهند شد"
  41,17,"و اما قوم ثمود را نیز هدایت كردیم؛ ولى آنان كوردلى را به هدایت ترجیح دادند و به [سزاى] دستاوردشان، صاعقۀ عذابِ خفت‌بار، آنان را فراگرفت؛"
  41,18,"و كسانى را كه ایمان آورده و [از گناه و نافرمانی] پروا مى‌كردند، نجات دادیم"
  41,19,"[ای پیامبر، یاد کن از] روزى كه دشمنان الله را به سوى آتشِ دوزخ احضار مى‌كنند و [از پراكندگى] بازمی‌دارند،"
  41,20,تا هنگامی که به دوزخ می‌رسند، گوش و چشم و پوستشان به کارهایی که انجام می‌داده‌اند بر ضدّشان گواهى می‌دهند
  41,21,"آنان به پوست خود می‌گویند: «چرا علیه ما گواهی دادید؟» [در جواب] می‌گویند: «الله [همان خالق توانمندی] كه همه موجودات را گویا كرده، ما را نیز به سخن درآورده است؛ و اوست كه نخستین بار شما را آفرید و [سرانجام، همگی] به پیشگاه او بازگردانده مى‌شوید»"
  41,22,"شما كه [گناهانتان را] پنهان نمى‌كردید، نه از آن بابت بود كه تصور مى‌كردید گوش و چشم‌ و پوستتان علیه شما گواهى نمى‌دهند؛ بلكه گمان می‌کردید الله بر بسیارى از اعمالى كه مى‌كنید، آگاه نیست"
  41,23,"این پندار شما دربارۀ پروردگارتان بود كه موجب هلاكت شما گردید و [سرانجام] زیانكار شدید"
  41,24,"اگر شكیبایى و تحمل كنند [یا نكنند]، آتش جایگاهشان است؛ و اگر طلب رضایت [و آمرزش] كنند، پذیرفته نخواهد شد"
  41,25,"ما همنشینانى [از شیاطین] بر آنان گماشتیم که [کارهای] گذشته و [آرزوهاى] آینده را در نظرشان آراستند؛ و [این‌گونه،] فرمان [عذاب] در مورد آنان تحقق یافت و به عذاب اقوام گمراهی از جن و انس که پیش از آنان بودند گرفتار شدند. بى‌گمان، آنان زیانكار بودند"
  41,26,"کافران [که در برابر حق عاجز گشته بودند] گفتند: «به این قرآن گوش نکنید و در [هنگام تلاوت] آن، جنجال به راه اندازید [و سخنان بیهوده بگویید]؛ باشد که پیروز گردید»"
  41,27,"یقیناً عذاب سختی به کافران می‌چشانیم و آنان را بر اساس [جزای] بدترین کارهایشان کیفر می‌دهیم"
  41,28,"این است سزاى دشمنان الله: آتشی كه در آن سكونتِ جاودان دارند؛ به كیفر آنكه آیات ما را انكار مى‌كردند"
  41,29,"کافران [به هنگام عذاب] می‌گویند: «پروردگارا، [افرادى] از دو گروه جن و انس را كه عامل گمراهى‌مان بودند، به ما نشان بده که لگدمالشان كنیم تا از همه ذلیل‌تر شوند»"
  41,30,"[اما] كسانى كه گفتند: «پروردگار ما الله است» سپس [از عبادت و بندگى غیر او سر باز زدند و بر اعتقاد خود] پایداری کردند، [هنگام فرا رسیدن مرگشان] فرشتگان بر آنان فرود مى‌آیند، [و مى‌گویند:] «نترسید و ‌اندوه نداشته باشید؛ و شما را بشارت باد به بهشتی که به آن وعده داده می‌شدید"
  41,31,ما در زندگى دنیا و آخرت دوستدار شماییم، و در بهشت هرچه دلتان بخواهد و درخواست كنید، در اختیار شماست
  41,32,به عنوان پذیرایى از جانب آمرزگارى مهربان»
  41,33,"کیست خوش‌گفتارتر از آن کس كه به سوى الله دعوت می‌دهد و به شایستگى عمل می‌نماید و می‌گوید: «تسلیم [اوامر الهی] هستم؟»"
  41,34,"[هرگز] نیکی و بدی یکسان نیست. همواره به شیوه‌اى كه بهتر است، پاسخ بده كه در آن صورت، [خواهی دید] همان كسى كه بین تو و او دشمنى بود، همچون دوستى مهربان [و دلسوز] گشته است"
  41,35,"تنها شكیبایان و کسانی كه بهرۀ بزرگی [از ایمان و اخلاق] دارند، به چنین مقامى مى‌رسند"
  41,36,و هر گاه وسوسه‌ای از جانب شیطان تو را فراگرفت، به الله پناه ببر كه یقیناً او شنوای داناست
  41,37,"از نشانه‌هاى [توان و تدبیر] او، شب و روز و خورشید و ماه است. در برابر خورشید و ماه سجده نكنید؛ بلكه اگر تنها او را عبادت می‌کنید، بر الله كه آنها را آفریده است سجده کنید"
  41,38,"و اگر [گروه‌هایی از نیایش او تعالی] تكبر ورزیدند، [فرشتگان و] مقربان درگاه پروردگارت، شب و روز، بدون خستگى او را به پاکی می‌ستایند"
  41,39,"از جمله نشانه‌هاى [قدرت] الهى این است كه زمین خشک و فرسوده را مى‌بینى که چون باران بر آن فرومی‌ریزیم، به جنبش درمی‌آید [و گیاه می‌رویاند] و [گیاهانش] رشد می‌كند؛ آن [پروردگار توانمندی] كه زمین را زنده مى‌كند، مردگان را نیز زنده خواهد كرد. به راستی كه او تعالی بر هر كارى تواناست"
  41,40,"[گفتار و رفتارِ] كسانى كه در مورد آیات ما كجروى [و آن را تحریف] مى‌كنند بر ما پوشیده نخواهند بود. آیا كسی كه به آتش [دوزخ] ‌می‌افتد بهتر است یا کسی كه در روز رستاخیز [از عذاب] ایمن است؟ هر چه مى‌خواهید انجام دهید كه بی‌تردید، الله به آنچه مى‌كنید بیناست"
  41,41,"کسانی كه این قرآن را كه براى [هدایت]شان آمده است، انكار كرده‌اند، [در قیامت عذاب خواهند شد]. این [کلامِ الهی،] كتابى است شكست‌ناپذیر"
  41,42,"سخن باطل، نه از پیش رو و نه از پشت سرش [= از هیچ جهت و از هیچ نظری] به آن راه نمی‌یابد و از جانب [پروردگارِ] حکیمِ ستوده نازل شده است"
  41,43,"[ای پیامبر، کافران] همان [سخنان باطلی] را به تو می‌گویند که به پیامبران پیش از تو نیز می‌گفتند. بى‌گمان، پروردگارت آمرزش و [در عین حال،] كیفرى دردناک دارد"
  41,44,"اگر قرآن را [به زبانِ] غیرعربی نازل كرده بودیم، کافران مى‌گفتند: «چرا آیاتش [عربی نیست و] به روشنی بیان نشده است؟ کتابی غیرعربی و پیامبری عرب؟» [ای پیامبر، به آنان] بگو: «این كتاب، براى مؤمنان مایۀ هدایت و شفاست و کسانی كه ایمان نمی‌آورند، در گوش‌هایشان سنگینى است و قرآن برایشان نامفهوم است؛ [گویى] آنان را از راهى دور صدا می‌زنند»"
  41,45,"ما به موسى كتاب [تورات] دادیم؛ اما در [مورد] آن اختلاف[نظر] پدید آمد؛ و اگر فرمانى از پروردگارت [در موردِ مهلت و آزمایش] از پیش مقرر نشده بود، [بى‌درنگ] میانشان داورى مى‌شد. کافران [نیز] در موردِ قرآن در تردید و بدگمانى‌اند"
  41,46,هر کس کاری شایسته كند، به سود خودِ اوست؛ و هر کس بدى كند، به زیان خویش بد كرده است؛ و پروردگار تو هرگز به بندگان ستم نمی‌کند
  41,47,"آگاهى از [لحظۀ وقوع] قیامت، تنها به الله مربوط است؛ و خروجِ هر میوه‌اى از شكوفه‌اش و باردارى و وضع حملِ هر ماده‌اى، با آگاهىِ اوست؛ و روزی كه [الله] به مشركان ندا مى‌دهد: «افرادى كه [در قدرت،] شریک من تصور مى‌كردید [و به آنان توسل می‌جستید] كجا هستند؟» آنان می‌گویند: «اکنون در برابر تو اعتراف مى‌كنیم كه هیچ یک از ما [بر درستىِ اعتقاد مشرکانۀ خود] گواه نیست»"
  41,48,"آنچه در گذشته [تكیه‌گاه خود] مى‌خواندند، از نظرشان ناپدید می‌شود و درمى‌یابند كه هیچ راه گریزی [از آتش عذاب الهی] نخواهند داشت"
  41,49,"انسان در تمناى خیر، خستگی‌ناپذیر است، و[لى] اگر بدى به او برسد، مأیوس و دلسرد خواهد شد"
  41,50,"و اگر پس از رنجی كه به انسان مى‌رسد، رحمتى از جانب خویش به او برسانیم، [مغرورانه] مى‌گوید: «این حق من است، و گمان نمى‌كنم قیامت برپا شود، و اگر [هم واقع شود و] به سوى پروردگارم بازگردانده شوم، [ثروت و پاداش‌های] نیکویی نزدش خواهم داشت». مسلّماً کافران را از عملكردشان آگاه خواهیم ساخت و عذابى سخت به آنان می‌چشانیم"
  41,51,"هرگاه نعمتی به انسان می‌بخشیم، [با سرمستى] روى مى‌گرداند [و شکر نعمت را به جای نمی‌آورد] و متکبرانه [از حق] دور می‌شود؛ و هنگامى كه رنجی [همچون فقر و بیماری] به سراغش می‌آید، [به درگاه الهی] دعا و درخواست فراوان دارد"
  41,52,"[ای پیامبر، به کافران] بگو: «به من بگویید اگر [قرآن] از جانب الله باشد و شما به آن کافر شوید، کیست گمراه‌تر از کسی كه [با وجود آشکار بودنِ حق،] در ستیزی بى‌پایان [با آن] قرار دارد؟»"
  41,53,"[در این دنیا و در هنگامۀ قیامت،] نشانه‌هاى [توان و تدبیر] خود را در آفاق [جهان] و در [وجود] خودشان به آنان نشان خواهیم داد تا برایشان روشن شود كه قرآن حق است. آیا كافى نیست كه پروردگارت بر هر چیزی گواه است؟"
  41,54,"آگاه باشید كه آنان در مورد دیدار پروردگارشان [در قیامت] تردید دارند! [و] آگاه باشید كه الله بر همه چیز احاطه دارد"
  42,1,"حم [حا. میم]"
  42,2,"عسق [عین. سین. قاف]"
  42,3,الله شکست‌ناپذیر حکیم، بر تو و پیامبران پیش از تو چنین وحى مى‌فرستد
  42,4,هرچه در آسمان‌ها و زمین است متعلق به اوست؛ و او بلندمرتبه و بزرگ است
  42,5,"نزدیک است آسمان‌ها [از شکوه و عظمت الهی] از فراز یکدیگر بشكافند، و فرشتگان، پروردگارشان را با ستایش تقدیس مى‌كنند و براى ساكنان زمین [كه توبه كرده‌اند] آمرزش مى‌طلبند. آگاه باشید كه الله آمرزندۀ مهربان است"
  42,6,"[ای پیامبر،] الله خود مراقبِ [رفتارِ] كسانى است كه غیر او را [دوست و] کارسازِ خود برگزیده‌اند و تو كارگزار [و مسئول رفتار] آنان نیستى"
  42,7,"ما قرآن را این گونه به زبان عربی بر تو وحى كردیم تا اهل مکه و ساكنان اطرافش را بیم دهى و در مورد روز محشر ـ که تردیدی در وقوعش نیست ـ به آنان هشدار دهى. [آن روز،] گروهى بهشتى‌اند و گروهى در آتش سوزان"
  42,8,"اگر الله مى‌خواست، همۀ مردم را امتی واحد [که الله را به یگانگی عبادت کنند] قرار مى‌داد؛ ولى [به انسان اختیار داد؛ او تعالی] هر کس را بخواهد، به رحمت خویش درمی‌آورد؛ و مشرکان هیچ کارساز و یاورى نخواهند داشت"
  42,9,"آیا آنان به جای او کسی [دیگر را به عنوان دوست و] کارساز برگزیده‌اند؟ حال آنكه كارساز [جهانیان] الله است و اوست كه مردگان را زنده مى‌كند و بر هر كارى تواناست"
  42,10,"[بگو: «ای مردم،] هر اختلافى بین شماست، داورى‌اش با الله است. این است الله، پروردگار من؛ بر او توکل كرده‌ام و به پیشگاهش بازمی‌آیم»"
  42,11,"او آفرینندۀ آسمان‌ها و زمین است؛ همسرانى از [جنسِ] خود شما برایتان قرار داد و از چهارپایان نیز جفت آفرید؛ به این صورت، تعداد شما را افزایش مى‌دهد. هیچ چیز همانند الله نیست و همو شنوا و بیناست"
  42,12,"کلید‌ [گنجینه‌های] آسمان‌ها و زمین از آنِ اوست؛ [نعمت و] روزی را بر هر کس که بخواهد، گسترده می‌دارد و یا تنگ می‌گرداند. به راستی که او بر هر چیزی داناست"
  42,13,"از دین همان را براى شما مقرر كرد كه به نوح امر كرده بود؛ و نیز آنچه به تو وحى كردیم و آنچه به ابراهیم و موسى و عیسى امر كردیم؛ اینكه: «دین را برپا نگاه دارید و در مورد آن فرقه‌فرقه نشوید [و اختلاف نورزید]». [پذیرشِ] دعوت تو بر مشركان گران آمده است. الله است كه هر كس را بخواهد [توفیقِ عبادت می‌دهد و] به سوى خویش برمى‌گزیند؛ و هر کس را [که توبه کند و به درگاهش] بازآید، به سوى خویش هدایت خواهد كرد"
  42,14,"هنگامی که دلایل محکمِ نبوتِ پیامبر بر کافران عرضه شد، آنان از روی برترى‌خواهى [و حسادتی] كه بینشان بود، راه تفرقه پیمودند؛ و اگر فرمان پروردگارت [در موردِ مهلت و تأخیرِ عذاب] تا زمانى معین، از پیش مقرر نشده بود، [بی‌درنگ] میانشان داورى مى‌شد؛ و اما پس از کافران [و به دلیل انكار و اختلاف آنان] وارثان كتاب [تورات و انجیل نیز] در مورد قرآن، سخت در تردید و بدگمانى‌ هستند"
  42,15,"[ای پیامبر، مردم را] به سوی این [آیین الهی] دعوت کن و چنان كه فرمان یافته‌اى پایداری كن و از هوس‌های آنان پیروى نكن و بگو: «به همۀ کتاب‌هایی كه الله نازل كرده است ایمان دارم و فرمان یافته‌ام كه در برابر شما به عدالت رفتار كنم. الله پروردگار ما و شماست. [نتیجۀ] اعمال ما براى ماست و [نتیجۀ] اعمال شما براى شما؛ هیچ [دشمنی و] جدالی بین ما و شما نیست. الله همۀ ما را [در قیامت] جمع خواهد كرد و بازگشت [همه] به سوی اوست»"
  42,16,"كسانى كه دربارۀ الله [و دین او] پس از آن كه [دعوت او از سوی مردم منصف] پذيرفته شد، به مجادله مى‌پردازند، حجّتشان نزد پروردگارشان [باطل و] بى‌پایه است؛ خشم [الهی] گریبانگیرشان مى‌شود و عذابى سخت [در پیش] دارند"
  42,17,الله است که قرآن و مقیاس عدالت را به‌حق نازل كرده است؛ و تو چه می‌دانی؟ شاید قیامت نزدیک باشد
  42,18,"كسانى كه قیامت را باور ندارند، [با تمسخر و] به شتاب آن را مى‌خواهند؛ و كسانى كه [به روزِ جزا] باور دارند و مى‌دانند كه حق است، از آن هراسانند. آگاه باشید! کسانی كه در مورد قیامت، جدل و انكار مى‌كنند، در گمراهىِ بى‌پایانى قرار دارند"
  42,19,"الله نسبت به بندگانش باریک‌بین [و مهربان] است؛ به هر کس بخواهد، روزی می‌بخشد؛ و او توانای شکست‌ناپذیر است"
  42,20,"کسی كه كِشت آخرت را بخواهد، به كِشته‌اش بركت مى‌بخشیم؛ و هر کس [تنها] كِشت دنیا را بخواهد، در اختیار او قرار مى‌دهیم؛ و[لى] در آخرت بهره‌اى نخواهد داشت"
  42,21,"آیا [مشرکان] معبودانى دارند كه بدون اجازۀ الله، [قوانین] دینى برایشان مقرر كرده‌اند؟ اگر حُكمِ قطعى [براى مهلت دادن به گناهکاران] در میان نبود، [بى‌درنگ] میانشان داورى مى‌شد؛ و ستمکاران عذابی دردناک [در پیش] دارند"
  42,22,"[در روز قیامت،] ستمکاران را از دستاوردشان هراسان مى‌بینى و [خواهی دید که كیفر آن کارها] دامنگیرشان است؛ ولى مؤمنان نیكوكار در باغ‌های بهشتند؛ هر چه بخواهند، نزد پروردگارشان دارند؛ فضل [و بخششِ] بزرگ همین است"
  42,23,"این همان [فضیلتی] است كه الله به بندگان مؤمن و نیكوكارش بشارت مى‌دهد. [ای پیامبر،] بگو: «در برابر این رسالت، پاداشى از شما نمى‌خواهم؛ جز [رعایتِ دوستی و] محبتِ خویشاوندى؛ و هر کس [در این راستا] اقدام نیكویى كند، بر پاداشش در آن [مورد] مى‌افزاییم. به راستی كه الله آمرزگارى قدرشناس است"
  42,24,"آیا مشرکان مى‌گویند: «[محمد] به الله دروغ نسبت داده است؟» اگر الله بخواهد، بر دل تو مُهر مى‌نهد؛ و[لى] الله باطل را محو مى‌كند و حق را با سخنان [و تمهیداتِ] خویش به كرسى مى‌نشانَد؛ كه او به راز دل‌ها داناست"
  42,25,اوست که توبۀ بندگانش را می‌پذیرد و از بدی‌ها درمى‌گذرد و آنچه مى‌كنید مى‌داند
  42,26,"او [درخواستِ] مؤمنانِ نیكوكار را مى‌پذیرد و از فضلِ خویش بر [پاداش] آنان مى‌افزاید؛ و کافران عذابى سخت [در پیش] دارند"
  42,27,"اگر الله روزىِ [برخى از] بندگانش را گشایش مى‌داد، در زمین ستم و سركشى مى‌كردند؛ ولى به ‌اندازه‌اى كه بخواهد مقرر مى‌دارد؛ زیرا او قطعاً به [حال] بندگانش آگاه و بیناست"
  42,28,"او ذاتی است كه باران را پس از نومیدى [مردم] مى‌فرستد و رحمت خویش را مى‌گسترد؛ و او تعالی كارساز و ستوده است"
  42,29,"از نشانه‌هاى [توان و تدبیر] او، آفرینش آسمان‌ها و زمین و موجودات زنده‌اى است كه در آنها پراكنده كرده است؛ و هر گاه اراده كند، بر جمع‌آورى آنها نیز تواناست"
  42,30,"هر مصیبتی که به شما رسد، به خاطر کارهایی است که انجام داده‌اید؛ و [الله] از بسیاری [از گناهانتان] گذشت می‌کند"
  42,31,"شما هرگز در زمین [و آسمان، الله را] به تنگ نمى‌آورید؛ و در برابر الله هیچ كارساز و یاورى نخواهید داشت"
  42,32,"از نشانه‌های [توان و تدبیرِ] الهی، کشتی‌های کوه‌پیکری است که در دریاها در حرکتند"
  42,33,"اگر الله بخواهد، باد را ساكن مى‌گردانَد تا [کشتی‌ها] بر پهنۀ دریا بى‌حركت بمانند. به راستى در این [امر،] براى هر شكیباى سپاسگزاری، نشانه‌هایى است"
  42,34,"یا [اگر بخواهد، سرنشینانِ] آن کشتی‌ها را به کیفر اعمالشان نابود می‌سازد؛ در حالی که او از بسیاری [از گناهان] ‌گذشت می‌کند"
  42,35,"[تا موجب عبرت باشد] و كسانى كه در مورد آیات ما به مجادله برمى‌خیزند، بدانند كه [اگر عذاب الهی فرارسد،] راه گریزى نخواهند داشت"
  42,36,"[ای مردم،] آنچه به شما داده شده است، نعمت‌های [گذراىِ] زندگى دنیاست؛ و آنچه نزد الله است، براى مؤمنانى كه بر پروردگارشان توکل مى‌كنند، بهتر و پاینده‌تر است"
  42,37,"و [نیز براى] کسانی كه از گناهان بزرگ و بی‌حیایی‌ها اجتناب می‌ورزند و آنگاه كه خشمگین می‌شوند، گذشت مى‌كنند"
  42,38,"و کسانی كه [دعوت] پروردگارشان را پذیرا مى‌شوند و نماز برپا مى‌دارند و كارشان در ميانشان [بر پايه‌] مشورت است و از آنچه روزى‌شان كرده‌ایم، انفاق مى‌كنند"
  42,39,"و کسانی که هر گاه ستمی به آنان برسد، [به دفاع و] انتقام برمی‌خیزند"
  42,40,"و جزای هر بدی، کیفری همانند آن بدی است [نه بیشتر]؛ اما هر کس گذشت کند و کار را به اصلاح [و آشتی] آورَد، پاداشش بر عهدۀ الله است. بی‌گمان، او ستمکاران را دوست ندارد"
  42,41,"البته کسانی كه پس از ستمى كه دیده‌اند، انتقام می‌گیرند، هیچ [بازخواست و] سرزنشی بر آنان نیست"
  42,42,"راه [بازخواست و] سرزنش، تنها بر ستمکارانى گشوده است كه به ناحق در زمین برترى‌جویی مى‌كنند. آنان عذابى دردناک [در پیش] دارند"
  42,43,"اما هر کس شكیبایى و گذشت كند، نشان از قدرت ارادۀ [او] دارد"
  42,44,"هر کس که الله او را گمراه كند، پس از الله هیچ [یاور و] كارسازى نخواهد داشت؛ و [در روز قیامت،] ستمکاران را مى‌بینى كه چون عذاب را مشاهده كنند، مى‌گویند: «آیا راه بازگشتى [به دنیا] هست؟»"
  42,45,"[در آن روز،] ستمگران را مشاهده خواهى كرد كه بر آتش عرضه مى‌شوند؛ و در حالى كه از [شدت] خواری، فروتن شده‌اند، زیرچشمى مى‌نگرند؛ و [در آن حال] مؤمنان مى‌گویند: «زیانكاران [واقعى] كسانى هستند كه [به طمع دنیا] خود و خانواده‌شان را در قیامت به زیان‌انداخته‌اند». آگاه باشید! ستمکاران، گرفتارِ عذابى پایدارند"
  42,46,"و آنان در برابر الله، كارسازى نخواهند داشت كه یارى‌شان كند؛ و هر کس كه الله او را گمراه كند، راهى [براى نجات] نخواهد داشت"
  42,47,"[ای مردم،] پیش از آنكه روزى فرارسد كه بازگشتى از جانب الله ندارد، دعوت پروردگارتان را بپذیرید. در آن روز، نه پناهگاهى خواهید داشت، نه [فرصتی برای] انكار"
  42,48,"[ای پیامبر] اگر [مشرکان از دعوتِ تو] روى می‌گردانند، [توفیق را از خود سلب می‌كنند]. ما تو را نگهبان آنان نفرستادیم و تو وظیفه‌اى جز رساندن [وحی] نداری؛ و چون رحمتى از جانب خود به انسان بچشانیم، به آن سرمست مى‌شود؛ و اگر به سزاى رفتار گذشتۀ خود دچار مصیبتى شود، [به جاى بیدارى، ناسپاسی مى‌کند]. به راستی که انسان بسیار ناسپاس است"
  42,49,"فرمانروایى آسمان‌ها و زمین، از آنِ الله است. او هر چه بخواهد، مى‌آفریند؛ به هر کس که بخواهد، [فرزندِ] دختر مى‌بخشد و به هر کس كه بخواهد، [فرزندِ] پسر"
  42,50,یا پسر و دختر را ـ هر دو ـ با هم می‌دهد؛ و هر کس را که بخواهد، نازا مى‌گرداند كه او دانای تواناست
  42,51,"درخورِ هیچ بشرى نیست كه الله با او سخن بگوید؛ مگر با وحى یا از فراسویِ حجابى یا [اینکه الله] فرشته‌اى بفرستد كه به فرمانش هر چه بخواهد، وحى كند. بی‌تردید، او تعالی بلندمرتبۀ حکیم است"
  42,52,"[ای پیامبر] این‌گونه، قرآن را [توسط جبرئیل و] به فرمان خویش بر تو وحى كردیم. [پیش از آن] تو آگاهى نداشتى كه كتاب و ایمان چیست؛ ولى ما آن را نورى ساختیم كه هر یک از بندگان خویش را كه بخواهیم، به آن هدایت كنیم؛ و مسلّماً تو به راهى راست [= اسلام] هدایت مى‌كنى"
  42,53,"راه الله که آنچه در آسمان‌ها و زمین است از آنِ اوست. آگاه باشید! [همۀ] امور به سوی الله بازمی‌گردد"
  43,1,"حم [حا. میم]"
  43,2,سوگند به کتاب روشنگر
  43,3,ما آن را قرآنى به زبان عربی قرار دادیم، باشد که خردورزى كنید
  43,4,"این كتاب، كه بلندمرتبه و حكمت‌آموز است، در لوح محفوظ نزد ما ثبت شده است [و دستخوش تغییر نخواهد شد]"
  43,5,"آیا به صِرف اینكه شما [مشرکان،] گروهی اسرافکارید [و پیام الهی را انكار مى‌كنید، نزول] قرآن را از شما بازداریم؟"
  43,6,چه بسیار پیامبرانى كه در میان پیشینیان فرستادیم
  43,7,"و[لی] هر پیامبری به سوی آنان می‌آمد، مسخره‌اش می‌کردند"
  43,8,"ما افرادی نیرومند‌تر از مشرکان مکه را هلاک کرده‌ایم؛ و داستان [عبرت‌انگیز] پیشینیان گذشت"
  43,9,"[ای پیامبر] اگر از مشرکان بپرسی: «آسمان‌ها و زمین را چه کسی آفریده است؟»، قطعاً می‌گویند: «[الله] شکست‌ناپذیر دانا»"
  43,10,"همان [پروردگاری] كه زمین را محل آسایش شما قرار داد و راه‌هایی در آن برایتان پدید آورد تا راه یابید"
  43,11,"و همان ذاتی كه باران را از آسمان به مقدار معینى فرستاد؛ آنگاه سرزمین خزان‌زده و خشک را به وسیلۀ آن حیات بخشیدیم؛ شما نیز همین گونه [از گورها] بیرون آورده مى‌شوید"
  43,12,پروردگاری كه تمام مخلوقات را آفرید و از کشتی‌ها و چهارپایان، وسیلۀ سوارى برایتان پدید آورد؛
  43,13,"تا بر پشت آنها قرار گیرید و آنگاه كه بر آنها قرار گرفتید، نعمت پروردگارتان را یاد كنید و بگویید: «پاک و منزه است ذاتی كه این [وسیله] را در خدمت ما گماشت و[گرنه] ما خود توان این کار را نداشتیم؛"
  43,14,و ما به پیشگاهِ پروردگار‌مان بازمی‌گردیم»
  43,15,"مشرکان از میان بندگان الله، سهمى [از فرزند] برایش قرار دادند. به راستى كه انسان آشكارا ناسپاس است"
  43,16,"آیا [می‌پندارید] الله از میان آفریدگانش، دختران را انتخاب كرده و پسران را به شما اختصاص داده است؟"
  43,17,"اما هر گاه به یكى از آنان، همان چیزی را بشارت دهند که براى [الله] رحمان قائل هستند [= تولد دختر]، در حالى كه خشم خود را فرومى‌خورد، چهره‌اش [از اندوه] تیره مى‌گردد"
  43,18,"آیا کسی را که در زیور [و راحتی] پرورش می‌یابد و در [هنگام] جدال [قادر به] تبیین مقصودش نیست [به الله نسبت می‌دهید؟]"
  43,19,"[مشرکان]، فرشتگان را كه بندگانِ [الله] رحمانند، مؤنث پنداشتند. آیا به هنگام آفرینش آنان حضور داشتند؟ سخنانشان ثبت می‌گردد و [در روز قیامت،] بازخواست خواهند شد"
  43,20,"[آنان برای توجیهِ شرکِ خود] می‌گویند: «اگر [الله] رحمان می‌خواست، ما فرشتگان را عبادت نمی‌کردیم». آنان در مورد این [سخن] بى‌اطلاعند [و] جز سخن دروغ نمى‌گویند"
  43,21,آیا پیش از قرآن كتابى به آنان داده‌ایم كه به آن استدلال كنند؟
  43,22,"بلکه می‌گویند: «نیاکانمان نیز همین آیین را داشتند و ما [نیز] راه آنان را دنبال می‌کنیم»"
  43,23,"پیش از تو نیز هر [پیامبرِ] هشداردهنده‌ای را به هر شهری فرستادیم، ثروتمندانِ سرکشِ آن شهر می‌گفتند: «نیاکانمان نیز همین آیین را داشتند و ما [نیز] راه آنان را دنبال می‌کنیم»"
  43,24,"[پیامبر‌شان] می‌گفت: «اگر آیینى هدایت‌بخش‌تر از آنچه نیاکانتان داشتند آورده باشم [باز هم از آنان پیروی می‌کنید]؟» آنان [در پاسخ] می‌گفتند: «[آری،] پیامى را كه مأمور [ابلاغ] آن شده‌اید، انكار مى‌كنیم»"
  43,25,ما نیز از آنان انتقام گرفتیم؛ پس بنگر که سرانجامِ تكذیب‌كنندگان چگونه بود
  43,26,"[یاد کن] هنگامی را ‌که ابراهیم به پدر و قومش گفت: «از آنچه شما عبادت می‌کنید، بیزارم؛"
  43,27,مگر از ذاتی كه مرا آفریده است كه او هدایتم خواهد كرد»
  43,28,"ابراهیم، یكتاپرستى را در میانِ نسل‌های پس از خود، سخنى ماندگار قرار داد؛ باشد که [به پیشگاه الهی] بازگردند"
  43,29,"بلکه اینان [که در مکه آلوده به شرک هستند] و پدرانشان را [از نعمت‌های دنیا] برخوردار كردم تا آنكه حق [= قرآن] و پیامبری روشنگر به سراغشان آمد؛"
  43,30,"و آنگاه كه حق [= قرآن] به سویشان آمد، گفتند: «این جادوست و آن را انكار مى‌كنیم»؛"
  43,31,"و گفتند: «چرا این قرآن بر مردى بزرگ از دو شهرِ [مکه و طائف] نازل نشده است؟»"
  43,32,"آیا آنان رحمت پروردگارت را تقسیم مى‌كنند؟ ماییم كه روزی [و معیشت] آنان را در زندگى دنیا میانشان تقسیم كرده‌ایم و آنان را نسبت به هم، به درجاتى برتری بخشیده‌ایم تا از خدماتِ [متقابلِ] یكدیگر استفاده كنند؛ و رحمت پروردگارت از اموالى كه جمع مى‌كنند بهتر است"
  43,33,"اگر [نگرانى از آن] نبود كه همۀ مردم [در دنیاطلبى و انكار الله] یك گروه ‌شوند، سقف خانۀ كسانى را كه به الله رحمان ایمان ندارند، از نقره قرار مى‌دادیم و نیز پله‌هایى [از نقره در آن می‌نهادیم] كه بتوانند از [طبقاتِ] آن [خانه] بالا روند؛"
  43,34,"و برای خانه‌هایشان در‌هایی [از طلا] می‌گذاشتیم و تخت‌هایی [قرار می‌دادیم] که بر آن تکیه زنند؛"
  43,35,"و تجمل [و زینت‌های] فراوان [برایشان فراهم می‌کردیم] و تمام اینها بهرۀ [ناچیز] زندگی دنیاست؛ و آخرت نزد پروردگارت برای پرهیزگاران است"
  43,36,"هر کس از یاد [الله] رحمان دل بگرداند، شیطانى بر او مى‌گماریم تا [یار و] همنشینش باشد [و همواره او را فریب دهد]"
  43,37,"شیاطین، این گروه را از راه [الله] بازمی‌دارند؛ و[لی] آنان گمان می‌کنند که هدایت‌یافته‌اند"
  43,38,"تا آنگاه كه [در قیامت] نزد ما بیاید، [به شیطانِ همنشینش] می‌گوید: ای كاش میان من و تو، فاصله‌اى به دورى شرق و غرب بود! چه همنشین بدی بودى!»"
  43,39,"[الله می‌فرماید:] «امروز [پشیمانى] سودى به حالتان نخواهد داشت؛ زیرا ستم كرده‌اید و همگی در عذاب شریكید»"
  43,40,"[ای پیامبر،] آیا می‌توانی [پیام خود را] به گوش ناشنوایان برسانى یا نابینایان و گمراهانِ آشكار را [به راه راست] هدایت كنى؟"
  43,41,"پس اگر تو را [پیش از عذاب آنان از دنیا] ببریم، [در هر حال،] از آنان انتقام خواهیم گرفت"
  43,42,"یا عذابى را كه به آنان وعده داده‌ایم، [در دوران زندگی‌ات] به تو نشان خواهیم داد؛ زیرا ما بر آنان اقتدار [کامل] داریم"
  43,43,به آنچه بر تو وحی می‌شود تمسّک بجوی که بی‌گمان، بر راه راست قرار داری
  43,44,"تردیدی نیست که قرآن برای تو و قومت مایۀ اندرز [و سربلندی] است و [روز قیامت، دربارۀ ایمان و عمل به آن] بازخواست خواهید شد"
  43,45,"از پیامبرانی که پیش از تو فرستادیم بپرس که آیا غیر از [الله] رحمان، معبودانی برای عبادت قرار داده‌ایم [مسلّماً چنین نیست]"
  43,46,"ما موسى را با معجزات خویش به سوى فرعون و سران قومش فرستادیم و به آنان گفت: «من فرستادۀ پروردگار جهانیانم»؛"
  43,47,"و هنگامی که آیات [و معجزات] ما را به آنان ارائه كرد، همگی به آنها خندیدند"
  43,48,"هر معجزه‌اى به آنان ارائه دادیم، یكى از دیگرى بزرگ‌تر بود و [چون همه را تكذیب كردند،] آنان را به عذاب گرفتار كردیم؛ باشد که [از کفر] بازگردند"
  43,49,"[پس هنگامی که گوشه‌ای از عذاب الهی را چشیدند،] گفتند: «اى جادوگر! از پروردگارت ـ بنا به عهدى كه با تو دارد ـ بخواه [تا عذاب را از ما دور كند] كه ما [دیگر] راه‌یافته‌ایم»"
  43,50,"اما هنگامی که عذاب را از آنان برداشتیم، پیمان شكستند [و بر کفر اصرار ورزیدند]"
  43,51,"فرعون در میان قوم خود ندا سر داد و گفت: «اى قوم من، آیا فرمانروایىِ مصر در اختیار من نیست و این نهرها از دامنۀ قصرِ من جریان ندارد؟ آیا [قدرت و عظمتم را] نمى‌بینید؟"
  43,52,"من از این مردِ بى‌مقدار که [حتی] نمى‌تواند به روشنى سخن بگوید، شایسته‌ترم"
  43,53,"چرا [به نشانۀ سروَرى،] دستبند‌هاى زرین [از آسمان] بر او افكنده نشده است [تا ثابت شود که پیامبر است]؟ یا چرا فرشتگان همراه او نیامده‌اند؟»"
  43,54,"او [= فرعون] قوم خود را به [بی‌خردی و] سبُكسَرى كشاند و همگی مُطیع او شدند. حقا که آنان [نسبت به اوامر الهی] نافرمان بودند"
  43,55,"پس چون ما را به خشم آوردند، از آنان انتقام گرفتیم و همگی را [در دریا] غرق کردیم"
  43,56,"آنگاه آنان را در شمارِ پیشگامان [کفر و نافرمانی] و عبرتی [برای آیندگان] قرار دادیم"
  43,57,"و هنگامی که [داستانِ تولد] پسر مریم مطرح شد، قومِ تو [که گمان ‌کردند می‌توانند مانند نصاری چند معبود داشته باشند] به ناگاه، شادی و هیاهو به راه‌ انداختند"
  43,58,"و گفتند: «معبودان ما بهترند یا او [= عیسی]؟» آنان این سخن را تنها براى جدال با تو عنوان كردند؛ به راستی که گروهى ستیزه‌جو هستند"
  43,59,"عیسى فقط بنده‌اى است كه نعمت [رسالت] بر او ارزانى داشتیم و او را نمونه‌ای [از قدرت الهی] براى بنی‌اسرائیل قرار دادیم"
  43,60,"اگر مى‌خواستیم، [همۀ شما انسان‌ها را نابود می‌کردیم و] به جای شما، فرشتگانى پدید مى‌آوردیم كه در زمین جانشین [شما] شوند"
  43,61,"قطعاً [نزول] او [= عیسی] نشانه [نزدیکی وقوع] قیامت است؛ پس هرگز در مورد قیامت شک نكنید و پیرو من باشید كه راه راست [به سوی بهشت،] همین است"
  43,62,"[آگاه باشید تا] شیطان شما را [از راه الله] بازندارد؛ چرا كه او دشمن آشكار شماست"
  43,63,"و چون عیسى [معجزات و] نشانه‌هاى روشن به آنان ارائه كرد، گفت: «من حکمت برایتان آورده‌ام تا [به آن راه یابید] و برخى از موارد اختلافتان را روشن كنم؛ پس از الله پروا کنید و مطیع [دستورهای] من باشید"
  43,64,الله پروردگار من و شماست؛ پس او را عبادت کنید که راهِ راست همین است»
  43,65,"آنگاه گروه‌های [مختلف] بنی‌اسرائیل میان خود [دربارۀ عیسی] دچار اختلاف شدند؛ پس وای بر ستمکاران از عذاب روز دردناک"
  43,66,آیا جز این انتظار دارند كه قیامت ـ در حالی که غافلند ـ ناگهان بر آنان فرا رسد؟
  43,67,"دوستان [دنیایى،] در آن روز، دشمن یكدیگرند؛ مگر پرهیزگاران"
  43,68,"[الله به آنان می‌فرماید:] «ای بندگانِ [پرهیزكارِ] من، امروز ترس و ‌اندوهى نخواهید داشت"
  43,69,"همان بندگانى كه به آیات ما ایمان آوردند و تسلیم [فرمانِ ما] بودند"
  43,70,"شما و دیگر مؤمنانی که همچون شما هستند، به بهشت درآیید تا [از نعمت‌های جاودانش بهره‌مند گردید و] شادمان شوید"
  43,71,ظرف‌ها و جام‌های زرین را پیرامونشان مى‌گردانند؛ و هر چه دل‌ها بخواهد و دیده‌ها از آن لذت بَرَد، در آنجا موجود است؛ و شما در بهشت جاودانه‌اید
  43,72,این همان بهشتى است كه در برابر اعمالتان به شما داده‌اند
  43,73,میوه‌هاى فراوانی آنجا در اختیار دارید كه از آنها مى‌خورید
  43,74,بی‌تردید، مجرمان در عذاب دوزخ جاودانند
  43,75,"[در حالى كه عذاب] از آنان كاسته نمی‌شود و در یأس و نومیدی فرورفته‌اند"
  43,76,ما به آنان ستم نكردیم؛ بلکه آنها خود به خویشتن ستم می‌کردند
  43,77,"[دوزخیان، نگهبان آتش را صدا می‌زنند و] فریاد برمی‌آرند: «اى مالک [كاش] پروردگارت كار ما را یكسره كند [و ما را بمیراند]». او می‌گوید: «نه، شما [در این عذاب] ماندگارید»"
  43,78,به راستی ما حق را برای شما آوردیم؛ ولی بیشتر شما از آن کراهت داشتید
  43,79,"بلکه آنان عزمِ [خود را برای توطئه علیه تو] جزم كردند؛ ما نیز ارادۀ محکمی [بر ناکام گذاشتنِ آنان] داریم"
  43,80,"آیا مى‌پندارند كه ما سخنان سِرّى و نجوایشان را نمى‌شنویم؟ آرى، فرشتگان ما در كنارشان [هستند و همه چیز را] ثبت مى‌كنند"
  43,81,"[ای پیامبر، به مشرکان] بگو: «اگر [به فرض محال، الله] رحمان فرزندى داشت، من نخستین عبادت‌کننده [او] بودم»"
  43,82,"[معبود یگانه‌ای كه] پروردگار آسمان‌ها و زمین و عرش است، از توصیفِ [جاهلانه] آنان منزه است"
  43,83,"پس [ای پیامبر،] آنان را [به حال خود] بگذار تا یاوه‌گویی کنند و به بازى سرگرم باشند تا سرانجام، با روز موعود [= قیامت] مواجه شوند [و سزای اعمالشان را ببینند]"
  43,84,او تعالی است که در آسمان و زمین معبود است؛ و او حکیم داناست
  43,85,"پربرکت و بزرگوار است ذاتی که فرمانروایی آسمان‌ها و زمین و آنچه میان آنهاست، از آنِ اوست؛ و آگاهى از [لحظۀ برپایىِ] رستاخیز تنها در اختیار اوست و [همگی] به پیشگاه او بازگردانده مى‌شوید"
  43,86,"كسانی كه [مشركان] به جاى الله [به نیایش] مى‌خوانند، قادر به شفاعت نیستند؛ مگر افرادى كه به [کلمۀ توحید و] حق گواهى مى‌دهند"
  43,87,"و اگر از مشرکان بپرسی چه کسی آنان را آفریده است، مسلّماً می‌گویند: «الله»؛ پس چگونه [از عبادت الله] بازگردانیده می‌شوند"
  43,88,"[شکایت و] سخن پیامبر [این بود:] «پروردگارا، اینان قومی هستند که ایمان نمی‌آورند»"
  43,89,"[ای پیامبر،] از [آزار و اذیت] آنان درگذر و [برای رهایی از شرّشان] بگو: «سلام بر شما»؛ به زودى خواهند دانست [که عذابشان چگونه است]"
  44,1,"حم [حا. میم]"
  44,2,و سوگند به کتاب روشنگر
  44,3,"[که] ما قرآن را در شب مبارک [و فرخندۀ قدر] نازل کردیم [زیرا] که ما [همواره] هشداردهنده بوده‌ایم"
  44,4,"در آن [شب،] هر امر مهمى فیصله مى‌یابد [و تدبیر می‌شود]"
  44,5,"[این‌] كارى است [كه‌] از جانب ما [صورت مى‌گیرد] بى‌گمان، ما فرستنده[ی پیامبران] بوده‌ایم"
  44,6,به عنوان رحمتى از پروردگارت. بی‌تردید، او شنوای داناست
  44,7,"پروردگار آسمان‌ها و زمین و آنچه میان آنهاست. اگر [به این حقیقت] یقین دارید [به الله و پیامبرش ایمان بیاورید]"
  44,8,"هیچ معبودی [به‌حق] جز او نیست؛ زندگی می‌بخشد و می‌میراند؛ پروردگار شما و نیاکان شماست؛"
  44,9,"ولى مشرکان تردید دارند و سرگرم [لذت‌های دنیا] و بازى هستند"
  44,10,"پس [ای پیامبر] منتظر روزی باش که آسمان، دودی آشکار [پدید] آورد"
  44,11,"که [تمام] مردم را فرامی‌گیرد. این عذابی دردناک است"
  44,12,"[آنگاه کافران می‌گویند:] «پروردگارا، [این] عذاب را از ما برطرف کن که ایمان آورده‌ایم»"
  44,13,"چگونه [و از کجا] پند می‌پذیرند در حالی که [پیشتر،] پیامبر روشنگر به سویشان آمده بود؟"
  44,14,"اما از او روی گرداندند و گفتند: «[او] آموزش‌یافته‌ای دیوانه است»"
  44,15,"[براى آزمایش شما] زمانى ‌اندک عذاب را برمى‌داریم؛ و[لى] شما [به کفرِ خویش] بازمى‌گردید"
  44,16,"روزی که سخت بر آنان می‌تازیم. [آری،] ما [از کافران به خاطر کفر و تکذیبشان،] انتقام‌ می‌گیریم"
  44,17,پیش از آنان نیز قوم فرعون را آزمودیم و پیامبری بزرگوار به سویشان آمد
  44,18,"[که به آنان گفت:] «بندگان الله [= بنی‌اسرائیل‌] را به من بسپارید که من پیامبری امین برایتان هستم"
  44,19,"و [نیز] بر الله برتری مجویید که من دلیل روشنی برایتان آورده‌ام؛"
  44,20,و از اینکه سنگسارم کنید به پروردگار خود و پروردگار شما پناه می‌برم
  44,21,"اگر به من ایمان نمی‌آورید، از من کناره بگیرید [و رهایم کنید]»"
  44,22,"آنگاه به درگاه پروردگارش دعا کرد که: «[بار الها،] اینان گروهی تبهکارند»"
  44,23,"[به موسی وحی کردیم که:] «بندگانم را شبانه [از مصر] بیرون ببر؛ زیرا [سپاه فرعون] شما را تعقیب خواهند کرد؛"
  44,24,و دریا را آرام پشت سر بگذار كه آنان سپاهى هستند كه غرق خواهند شد
  44,25,"چه بسیار باغ‌ها و چشمه‌سارها كه رها كردند [و رفتند]،"
  44,26,"و کشتزارها و قصر‌های نیکو [و زیبا]،"
  44,27,"و نعمتی که در آن شادمان [و بهر‌ه‌مند] بودند"
  44,28,"[سرنوشتشان] این گونه [بود] و [تمامى] آن نعمت‌ها را به گروهى دیگر واگذاشتیم"
  44,29,"آسمان و زمین قطرۀ اشکی بر [نابودى] آنان نریخت و مهلتى [برای توبه] نیز نیافتند"
  44,30,بی‌تردید، بنی‌اسرائیل را از عذاب خفت‌بار نجات دادیم؛
  44,31,"از فرعون که [رهبر] سرکشی در زمرۀ اسرافکاران بود"
  44,32,ما با دانشِ خود بنی‌اسرائیل را بر مردم زمانه برترى دادیم،
  44,33,"و نشانه‌هایى [از قدرت خویش] در اختیارشان گذاشتیم كه آزمایشى روشن در آن بود"
  44,34,"این [کافران] مى‌گویند"
  44,35,"«جز مرگِ نخستینِ ما، هیچ [زندگیِ دیگری] نیست و هرگز برانگیخته نخواهیم شد؛"
  44,36,"و اگر راست می‌گویید، نیاکانمان را [زنده کنید و] بیاورید»"
  44,37,"آیا اینان بهترند یا قوم [نیرومندِ] «تُبَّع» و پیشینیان آنها كه چون بزهكار بودند آنان را نابود كردیم؟"
  44,38,ما آسمان‌ها و زمین و آنچه را که میان آنهاست به بازی نیافریده‌ایم؛
  44,39,"آنها را به‌حق [و با هدف] آفریده‌ایم؛ ولى بیشتر آنان نمى‌دانند"
  44,40,"بی‌تردید، روزِ داوری [= قیامت] وعده‌گاه همۀ آنان است"
  44,41,"روزى كه هیچ دوستى براى دوست خود سودمند نیست و [از هیچ سو] یارى نمی‌شوند؛"
  44,42,"مگر كسى كه الله [بر او] رحم كند كه او تعالی شکست‌ناپذیرِ مهربان است"
  44,43,بی‌گمان، درخت زَقّوم،
  44,44,غذای گناهکاران است
  44,45,"[میوه‌اش، به سبب گرمای زیاد،] همچون مسِ گداخته در شکم‌ها می‌جوشد؛"
  44,46,مانند جوششِ آب داغ
  44,47,"[خطاب مى‌رسد:] «آن [ستمکار] را بگیرید و به میان دوزخ درافكنید؛"
  44,48,آنگاه از عذاب آب داغ بر سرش فروریزید»
  44,49,"[در آن حال، به او گفته می‌شود:] «بچش که تو [در میان قوم خود] عزتمند و بزرگواری"
  44,50,"این همان [سرنوشت دردناکی] است که در موردش تردید داشتید»"
  44,51,یقیناً پرهیزگاران در جایگاه امنی هستند؛
  44,52,"در [میان] باغ‌ها و [کنار] چشمه‌سار‌های بهشت"
  44,53,"لباس‌هایی از دیبای نازک و دیبای ضخیم می‌پوشند، در حالى كه رویاروى یكدیگر [به صحبت] نشسته‌اند"
  44,54,"چنین است [وضع آنان]؛ و [نیز] حور العین را به همسری آنان درمی‌آوریم"
  44,55,در آنجا هر میوه‌اى كه اراده کنند، بى دغدغه در اختیارشان است
  44,56,"در بهشت طعم مرگ را نخواهند چشید؛ جز همان مرگ نخستین [در دنیا]؛ و [پروردگار مهربان] آنان را از مجازات دوزخ محفوظ می‌دارد"
  44,57,"[این] بخششی است از [جانب] پروردگارت؛ و این همان کامیابی بزرگ است"
  44,58,"[ای پیامبر،] ما قرآن را به زبان تو روان [و آسان] ساختیم؛ باشد که [مشرکان] پند گیرند"
  44,59,"پس در انتظار [وعده‌های الهی] باش که بی‌گمان، آنان [نیز] منتظر [شکست و مرگ تو] هستند"
  45,1,"حم [حا. میم]"
  45,2,"نزول [این] کتاب از جانب الله شکست‌ناپذیرِ حکیم است"
  45,3,"به راستى كه در آسمان‌ها و زمین، نشانه‌هایى [از قدرت الهى] براى مؤمنان [پدیدار] است"
  45,4,"و [نیز] در آفرینش خودتان و موجودات زنده‌اى كه [در زمین] پراكنده مى‌سازد، نشانه‌هایى [از توان و تدبیر الله] برای اهل یقین [آشکار] است"
  45,5,"و در گردش پیاپى شب و روز و رِزقى كه الله [به صورت باران] از آسمان مى‌فرستد و با آن، زمین را پس از خزان و خشكى‌اش زنده می‌سازد؛ و [نیز] در گردش بادها، نشانه‌هایى [از قدرت پروردگار،] برای خردورزان است"
  45,6,"[ای پیامبر،] اینها آیات و [نشانه‌های] الهی است كه به‌حق بر تو مى‌خوانیم. [به راستی، مشرکان] پس از [سخن] الله و آیاتش، كدام سخن را باور مى‌كنند؟"
  45,7,وای بر هر دروغگوی گنهکاری
  45,8,"[آن کافری] كه آیات الهی را كه بر او خوانده مى‌شود، مى‌شنود؛ ولى متكبرانه بر مخالفت اصرار دارد؛ گویى آنها را نشنیده است؛ پس او را به عذابى دردناک بشارت بده"
  45,9,"[همان کسی که] چون بر گوشه‌اى از آیات ما واقف شود، آن را به سُخره مى‌گیرد. آنان عذابى خفت‌بار [در پیش] دارند"
  45,10,"پیش رویشان دوزخ است؛ و دستاوردشان و [یاوران و] كارسازانى كه به جاى الله برگزیده‌اند، هیچ سودی به حالشان نخواهند داشت؛ و عذابى سهمگین [در پیش] دارند"
  45,11,"این [قرآن، موجبِ] هدایت است؛ و كسانى كه آیات پروردگار‌شان را انكار می‌كنند، عذابی از سخت‌ترین عذاب‌های دردناک [دوزخ را در پیش] دارند"
  45,12,"الله همان ذاتی است كه دریاها را در خدمت شما گماشت تا کشتی‌ها به فرمانش در آن حرکت کنند و [شما بتوانید] از فضل او [روزى] بجویید؛ باشد که شکر به جای آورید"
  45,13,"آنچه را در آسمان‌ها و زمین است، از [رحمت] خویش در خدمت شما گماشت؛ كه در این [امر،] نشانه‌هایی [از لطف و قدرت الهی] برای اندیشمندان است"
  45,14,"[ای پیامبر] به مؤمنان بگو: «از كسانى كه به روزهاى الله [= روزهای پیروزی بر کفر و گرفتن انتقام از مشرکان] امیدى ندارند، درگذرند تا [الله در زمان مشخص، هر] گروهى را در برابر آنچه که انجام داده‌اند سزا دهد»"
  45,15,"هر کس کار شایسته‌ای انجام دهد، به سود خود و هر کس کار بدى كند، به زیان خود كرده است؛ آنگاه [براى محاسبه و جزا] به پیشگاه پروردگارتان بازگردانده مى‌شوید"
  45,16,"به بنی‌اسرائیل، کتاب [تورات و انجیل] و [علمِ] داوری [بین مردم] و نبوت بخشیدیم و از نعمت‌های پاكیزه، روزی‌شان دادیم و آنان را [به موهبت توحید] بر مردم زمانه برترى بخشیدیم؛"
  45,17,"و در امر [بازشناسی حق از باطل]، آیات روشنى در اختیارشان قرار دادیم؛ پس اختلاف نکردند مگر بعد از اینکه علم [و آگاهی] برایشان حاصل شد [و حجت بر آنان اقامه گشت، آنگاه] به سبب برتری‌جویی [و حسادتی] كه بینشان بود، اختلاف ورزیدند؛ قطعاً، پروردگارت روز قیامت دربارۀ آنچه [در دنیا] راجع به آن اختلاف می‌ورزیدند میان آنان داورى خواهد كرد"
  45,18,"آنگاه تو را بر روشی [روشن و كامل] از امر [دین] قرار دادیم؛ پس پیرو همان راه باش و از هوس‌های نادانان پیروى نكن"
  45,19,"آنان در برابر [عذاب] الله هیچ نفعی براى تو ندارند؛ ستمکاران [یاور و] كارساز یكدیگرند؛ و الله كارسازِ پرهیزگاران است"
  45,20,"این [قرآن] مایۀ بصیرت مردم است و هدایت و رحمتی برای اهل یقین است"
  45,21,"آیا كسانى كه مرتكب کارهای ناشایست شدند، پنداشته‌اند كه آنان را مانند کسانی قرار می‌دهیم که ایمان آورده و کارهای نیک انجام داده‌اند، به گونه‌اى كه زندگى و مرگشان [با آنان] یكسان باشد؟ چه بد داوری می‌کنند"
  45,22,"الله آسمان‌ها و زمین را [هدفمند و] به‌حق آفرید تا [همه آزمایش شوند] و جزاى دستاوردهاى همه [بندگان] داده شود؛ بدون آنكه ظلمی به آنان شود"
  45,23,"آیا آن كسی را دیده‌ای كه آگاهانه هواى نفسش را به جاى معبود خود نشانده [و تسلیم آن شده] است؟ الله نیز او را گمراه ساخت و بر گوش و دلش مُهر [غفلت] نهاد و بر دیده‌اش پرده‌اى كشید؛ [اگر الله هدایتش نکند،] پس از الله چه كسى هدایتش خواهد كرد؟ آیا پند نمى‌گیرید؟"
  45,24,"[مشرکان] می‌گویند: «جز زندگى دنیاى ما هیچ [خبرى] نیست؛ زندگى مى‌كنیم و مى‌میریم؛ و این گردشِ روزگار است كه ما را به كامِ مرگ مى‌برد». آنان در مورد این [امر،] ناآگاه هستند و فقط از حدس و گمان پیروی می‌کنند"
  45,25,"و چون آیات روشنگر ما [در مورد قیامت] بر آنان خوانده می‌شود، دلیل [انكار]شان فقط این است كه مى‌گویند: «اگر راست مى‌گویید، نیاکانمان را [زنده کنید و] بازگردانید»"
  45,26,"[ای پیامبر، به آنان] بگو: «الله است كه شما را حیات مى‌بخشد و مرگ مى‌دهد؛ آنگاه شما را در روز قیامت ـ که هیچ تردیدی در [وقوع] آن نیست ـ جمع مى‌كند؛ ولى بیشتر مردم [این حقیقت را] نمى‌دانند»"
  45,27,فرمانروایی آسمان‌ها و زمین از آنِ الله است و روزی که قیامت برپا شود، اهل باطل زیانکار خواهند بود
  45,28,"[در آن روز] هر گروهى را [از وحشت حساب و جزا، خوار و] به‌زانودرآمده مى‌بینى؛ همه را براى [گرفتن] نامۀ اعمالشان فرامی‌خوانند [و به آنان خطاب می‌شود:] «امروز شما در برابر آنچه كرده‌اید، جزا مى‌بینید"
  45,29,"این نامۀ [اعمالِ شما نزد] ماست كه به‌حق بر شما گواهى مى‌دهد. ما [تمام] اعمالی را که انجام می‌دادید [دقیقاً] ثبت مى‌كردیم"
  45,30,مؤمنان نیكوكار را پروردگارشان مشمول رحمت خویش قرار خواهد داد. این همان كامیابى آشكار است»
  45,31,"ولى [به] کافران [خطاب می‌شود:] «مگر نه این بود كه در برابر آیات من كه بر شما عرضه مى‌شد، گردنكشى مى‌كردید و گروهى بزهكار بودید؟"
  45,32,"و چون گفته می‌شد: \"وعدۀ الله حق است و [در وقوع] قیامت هیچ تردیدی نیست\"، می‌گفتید: \"نمی‌دانیم قیامت چیست؛ [آن را] توهّمی بیش نمی‌دانیم و به یقین نرسیده‌ایم\"»"
  45,33,رفتار زشتشان بر آنان آشكار مى‌شود و عذابى كه آن را مسخره مى‌كردند، دامنگیرشان خواهد شد
  45,34,"[به آنان] گفته می‌شود: «امروز شما را [در عذاب دوزخ] رها می‌کنیم؛ چنان كه شما [نیز در دنیا نسبت] به دیدار امروز بی‌اعتنا بودید؛ و جایگاهتان آتش است و هیچ یاورى نخواهید داشت"
  45,35,"این [گرفتارى] از آن روست كه آیات الهی را مسخره می‌کردید و زندگى دنیا فریبتان داده بود». امروز [کافران را] از آتش بیرون نخواهند آورد و از آنان خواسته نمی‌شود که [با توبه و طاعت، پروردگارشان را از خود] خشنود سازند"
  45,36,ستایش مخصوص الله است؛ پروردگار آسمان‌ها و زمین و تمامیِ جهانیان
  45,37,بزرگی در آسمان‌ها و زمین از آنِ اوست؛ و او تعالی شکست‌ناپذیرِ حکیم است
  46,1,"حم [حا. میم]"
  46,2,"نزول [این] کتاب از جانب الله شکست‌ناپذیرِ حکیم است"
  46,3,"آسمان‌ها و زمین و آنچه را که بین آنهاست به‌حق [و هدفمند] و براى مدتى معین آفریده‌ایم؛ و[لى] کافران از آنچه به آنان هشدار داده شده، رویگردانند"
  46,4,"[ای پیامبر، به مشرکان] بگو: «آیا به چیزهایی که به جاى الله [به نیایش] مى‌خوانید توجه كرده‌اید؟ به من نشان دهید چه چیز از [اجزاى] زمین را آفریده‌اند. آیا در [آفرینش] آسمان‌ها شركت داشته‌اند؟ اگر راست مى‌گویید، از کتاب‌های آسمانى پیشین یا بازمانده‌ای از دانش [گذشتگان، دلیل] بیاورید»"
  46,5,"كیست گمراه‌تر از کسی كه به جاى الله، افرادى را به دعا مى‌خواند كه تا روز قیامت به او پاسخ نمى‌دهند و آنان [= معبود‌های باطل، اساساً] از درخواست آنها [= عبادتگزارانشان] بى‌خبرند؟"
  46,6,"و آنگاه که [در قیامت] مردم احضار شوند، آن [معبودان باطل] دشمنانشان خواهند بود و عبادتشان را انکار خواهند کرد"
  46,7,"و چون آیاتِ روشنگر ما بر کافران خوانده می‌شود، آنان در مورد سخن حقى كه به آنها رسیده است می‌گویند: «این جادویى آشكار است»؛"
  46,8,"یا می‌گویند: «[محمد] این [قرآن] را خود جعل كرده [و به الله نسبت داده] است». [ای پیامبر، به آنان] بگو: «اگر من آن را جعل کرده [و به الله نسبت داده] باشم، شما نمی‌توانید در برابر [عذاب و خشم] الله از من دفاع کنید. الله به آنچه شما دربارۀ او [= قرآن، با طعنه] گفتگو می‌کنید، آگاه‌تر است، و به عنوان گواه بین من و شما كافى است؛ و او آمرزگارِ مهربان است»"
  46,9,"بگو: «من پدیده‌اى نوظهور در میان پیامبران نیستم و نمى‌دانم سرنوشت من و شما چه خواهد شد؛ تنها از آنچه به من وحى مى‌شود پیروى مى‌كنم و فقط هشداردهنده‌اى آشكارم»"
  46,10,"بگو: «به من بگویید: اگر قرآن از جانب الله باشد و شما به آن کفر ورزید و شاهدى از بنی‌اسرائیل، به مشابهت آن [با تورات و با تکیه بر آنچه در تورات در مورد آن آمده بر حقانیّت آن] گواهى داده و ایمان آورده باشد و شما در برابرش [انكار و] تكبر ورزید، [آیا گمراه و ستمگر نیستید]؟ بى‌گمان، الله ستمکاران را هدایت نخواهد كرد»"
  46,11,"و کافران به مؤمنان گفتند: «اگر این [قرآن] خوب بود، کسانی [كه بردگان و فقیرانی ناچیزند] در پذیرش آن بر ما سبقت نمى‌گرفتند»؛ و چون به وسیله آن هدایت نیافته‌اند، مى‌گویند: «این [قرآن]، دروغى قدیمی است»"
  46,12,"و [در حالى كه] پیش از آن [= قرآن]، كتاب موسى راهنما و رحمت بود؛ و این [قرآن،] كتابى است كه [تورات را] به زبان [شیوای] عربی تصدیق مى‌كند تا به ستمکاران هشدار دهد و براى نیكوكاران بشارت باشد"
  46,13,"كسانى كه گفتند: «پروردگارِ ما الله است»؛ آنگاه [از بندگىِ غیرِ او سر باز زدند و بر اعتقاد خود] پاى فشردند، ترس و ‌اندوهى نخواهند داشت"
  46,14,آنان اهل بهشتند و جاودانه در آنجا خواهند بود. این، پاداش اعمالی است که انجام ‌داده‌اند
  46,15,"و انسان را به نيكى كردن به پدر و مادرش سفارش كرديم؛ [به ویژه] مادر كه به دشوارى بارِ حمل او را بر عهده دارد و با دشوارى وضع حمل می‌كند؛ و [دوران] باردارى و شیرخوارگى‌اش [مجموعاً] سى ماه است؛ [او پرورش می‌یابد] تا به حد رشد برسد و در چهل سالگى [كه توان جسمی و ذهنی‌اش کامل است] می‌گوید: «پروردگارا، به من توفیق بده تا شکرِ نعمتی را كه به من و پدر و مادرم ارزانى داشته‌اى، به جای آورم و كار شایسته‌اى انجام دهم كه از آن راضی گردى؛ و فرزندانم را شایسته گردان؛ به درگاهت [توبه‌ نموده و] بازگشته‌ام و تسلیم [فرمانت] هستم»"
  46,16,آنان کسانی هستند که ما نیکوترین کارهایشان را می‌پذیریم و از گناهانشان درمی‌گذریم و در زمرۀ اهل بهشتند. این وعدۀ راستی است که به آن نوید داده‌ شده‌اند
  46,17,"و کسی كه به پدر و مادرش گفت: «اف بر شما! چگونه به من وعده مى‌دهید كه [از گور] بیرون آورده خواهم شد؛ در حالى كه نسل‌های فراوانی پیش از من رفتند [و بازنگشتند]؟» پدر و مادرش به درگاه الهی زاری مى‌كنند [که فرزندشان را هدایت کند و به او مى‌گویند:] «واى بر تو! ایمان بیاور كه وعدۀ الهی راست است»؛ [اما] او پاسخ مى‌دهد: «این [وعده‌ها] فقط افسانه‌هاى [خیالی] پیشینیان است»"
  46,18,این افراد، در زمرۀ گروه‌هایی از جن و انس هستند كه پیشتر، فرمان عذاب الهی در موردشان تحقق یافته است. بى‌گمان، آنان زیانكار بودند
  46,19,"هر گروه [بهشتی یا دوزخی]، درجاتى بر حسب اعمالشان دارند [تا حقى ضایع نگردد]؛ و الله اعمالشان را به تمام و کمال کیفر می‌دهد؛ بى آنكه در حقشان ستم شود"
  46,20,"روزى كه کافران بر آتش عرضه مى‌شوند، [به آنان خطاب مى‌شود:] «نعمت‌های پاكیزۀ خود را در زندگی دنیا از بین بردید و از آنها بهره‌مند شدید؛ پس امروز به خاطر برتری‌جوییِ ناحق و انحرافی كه در زمین داشتید، با عذابى خفت‌بار مجازات مى‌شوید»"
  46,21,"[ای پیامبر، سرگذشت هود،] برادر قوم عاد را یاد کن؛ آنگاه كه در سرزمین «احقاف» [= ریگزاری در جنوب شبه جزیرۀ عربستان] قومش را هشدار مى‌داد ـ در حالى كه هشداردهندگان [دیگرى نیز] در گذشته‌هاى دور و نزدیک آمده بودند ـ [و چنین می‌گفت] كه: «تنها الله را عبادت کنید كه من از عذاب روزى بزرگ بر شما مى‌ترسم»"
  46,22,"آنان گفتند: «آیا آمده‌اى كه ما را از [عبادت] معبودانمان بازگردانى؟ اگر راست مى‌گویى، عذابى كه به ما وعده مى‌دهى پیش آور»"
  46,23,"[هود] گفت: «[وقت نزول عذاب را] فقط الله مى‌داند؛ و من پیامى را كه مأمور [ابلاغ] آن شده‌ام به شما مى‌رسانم؛ ولى شما را گروهى نادان مى‌بینم»"
  46,24,"و چون آن [عذاب] را كه به صورت ابرى در جهت [دشت و] دره‌ها[ى حاصلخیز]شان پیش مى‌آمد، مشاهده كردند، [با شادمانی] گفتند: «این ابرى است كه [رحمت] بر ما مى‌بارد»؛ [هود گفت: «نه،] بلكه همان [عذابى] است كه براى رسیدنش شتاب داشتید؛ تندبادى است که عذابى دردناک با خود دارد"
  46,25,"[طوفانی است که] هر چیزى را به فرمان پروردگارش در هم مى‌كوبد»؛ آنگاه چنان [هلاک] شدند كه جز خانه‌هاى [ویران] آنان، اثرى به چشم نمى‌خورد. ما بزهكاران را این گونه كیفر مى‌دهیم"
  46,26,"یقیناً به آنها [= قوم عاد]، چنان امکاناتی داده بودیم كه به شما [اهل مکه، چنان] امکاناتی نداده‌ایم؛ و برای آنان چشم و گوش و دل [نیرومندتر از دیگران] قرار داده بودیم، و[لی] گوش و چشم و دل‌هایشان سودى به حالشان نداشت؛ زیرا آیات الهی را انكار مى‌كردند و [سرانجام،] عذابی كه آن را مسخره مى‌كردند، دامنگیرشان شد"
  46,27,"[بسیارى از مردم] شهرهاى پیرامون شما [مكّیان] را هلاک كردیم؛ و[لى قبلاً] نشانه‌ها [و دلایل توحید] را به شکل‌های مختلف در میان آوردیم؛ باشد که [از کفر و گمراهى] بازگردند"
  46,28,"پس چرا کسانی كه [مشرکان آنان را] براى تقرب [به الله،] معبودان خود گرفتند، [به هنگام بلا] یاری‌شان نكردند؟ بلكه از نظرشان ناپدید شدند؛ و [سرانجامِ] دروغ‌ها و تهمت‌هایشان همین بود"
  46,29,"[ای پیامبر، به یاد آور] هنگامی‌ که گروهى از جن را به سوی تو فرستادیم كه قرآن را بشنوند؛ هنگامی که نزد پیامبر حضور یافتند، [به یكدیگر] گفتند: «خاموش باشید [تا به آیات قرآن گوش فرادهیم] و چون [تلاوتش] به پایان رسید، نزد قوم خود بازگشتند تا به آنان [در مورد عواقبِ سرپیچی از فرمان حق] هشدار دهند"
  46,30,"گفتند: «اى قوم، ما [آیاتِ] كتابى را شنیدیم كه پس از موسى نازل شده است و کتاب‌های [آسمانیِ] پیش از خود را تصدیق می‌کند و به [سوى] حق و راه راست هدایت مى‌نماید"
  46,31,"ای قوم، [سخنان توحیدیِ] این دعوتگر را که به سوی الله فرامی‌خوانَد بپذیرید و به او ایمان آورید تا [الله] برخى از گناهانتان را ببخشد و شما را از عذابى دردناک در امان بدارد"
  46,32,"و هر کس [سخنان] دعوتگری را که به سوی الله فرامی‌خوانَد نپذیرد [و به وی ایمان نیاورد، هرگز الله را] در زمین به تنگ نمى‌آورَد؛ و در برابر الله [یاور و] كارسازى نخواهد داشت. چنین کسانی در گمراهىِ آشكارند»"
  46,33,"آیا مشرکان ندیده‌اند [و نمی‌دانند] الله که آسمان‌ها و زمین را آفرید و از آفرینش آنها درمانده نشد، قادر است مردگان را [نیز] زنده كند؟ آرى، او بر هر كارى تواناست"
  46,34,"روزى كه کافران بر آتش عرضه مى‌شوند، [از آنان پرسیده مى‌شود:] «آیا این آتش حق نیست [و حقیقت ندارد]؟» آنان می‌گویند: «آری؛ سوگند به پروردگارمان [که چنین است]»؛ [آنگاه الله] می‌فرماید: «پس به سزاى آنكه [قیامت را] انكار مى‌کردید، عذاب را بچشید»"
  46,35,"[ای پیامبر،] تو نیز همچون پیامبران اولوالعزم [كه همواره ثابت‌قدم بودند، در برابر آزار و تکذیبِ قومت] شکیبا باش و در مورد [درخواست عذابِ] آنان شتاب نكن. روزى كه [این کافران] عذابِ موعودشان را [در جهان آخرت] ببینند، [کیفرشان چنان طولانی است که] گویى فقط بخشی از روز را [در دنیا] به سر برده‌اند. این قرآن، پیامى [عمومى برای جن و انس] است. آیا جز نافرمانان هلاک مى‌شوند؟"
  47,1,"کسانی که کافر شدند و [مردم را] از راه الله بازمى‌دارند، [الله] اعمال آنان را تباه می‌كند"
  47,2,"و کسانی كه ایمان آورده و کارهای شایسته کرده‌اند و به آنچه بر محمد نازل شده- که آن حق و از جانب پروردگارشان است- ایمان آورده‌اند، [الله نیز]، بدی‌هایشان را می‌زداید و امور [دنیا و دین]شان را سامان می‌بخشد [و اصلاح می‌کند]"
  47,3,"این [پاداش و جزا،] به سبب آن است که کافران پیرو باطل شدند و مؤمنان، پیرو [آیات] حقِ پروردگارشان. الله مَثَل‌های مردم را اینچنین برایشان بیان مى‌كند"
  47,4,"[ای مومنان!] هر گاه با کافران روبرو شدید، آنان را گردن بزنید تا آنكه [بسیاری از آنان را] بکشید؛ آنگاه [اسیران را] محکم به بند كشید؛ سپس یا بر آنان منت گذارید [و بدون هیچ عوضی آزادشان کنید] یا [از آنان] فدیه بگیرید [و رهایشان کنید] تا سنگینى جنگ فروكش كند. این [حکم الهی] است؛ و اگر الله مى‌خواست، خود از آنان انتقام مى‌گرفت؛ ولى [فرمان جنگ داد] تا شما را در برابر یكدیگر آزمایش كند؛ و کسانی كه در راه الله كشته شدند، [الله هرگز] نتیجه تلاششان را تباه نمى‌كند"
  47,5,"الله آنان را [به راه راست] هدایت خواهد كرد و امورشان را سامان خواهد بخشید؛"
  47,6,"و آنان را به بهشتی که [اوصافش را] برایشان بیان کرده است وارد خواهد نمود"
  47,7,"ای کسانی که ایمان آورده‌اید، اگر [دین و پیامبر] الله را یاری کنید، او نیز شما را یاری می‌کند و گام‌هایتان را [ثابت و] استوار می‌دارد"
  47,8,"و بر کافران، نگونساری و هلاکت باد! [الله] اعمالشان را تباه می‌گردانَد؛"
  47,9,"زیرا آنچه را که الله نازل كرده است نپسندیدند؛ [الله] نیز اعمالشان را تباه نمود"
  47,10,"آیا در زمین گشت و گذار نکرده‌اند تا ببینند سرانجامِ کسانی که پیش از آنان بودند، چگونه بوده است؟ الله [خانه‌هایشان را] بر سر‌شان ویران کرد [و آنان را نابود ساخت] و این کافران [نیز کیفری] همانند آن [در پیش] خواهند داشت"
  47,11,"زیرا الله [یاور و] كارسازِ مؤمنان است؛ و[لى] کافران هیچ كارسازى ندارند"
  47,12,"الله مؤمنان نیكوكار را به باغ‌هایی [از بهشت] وارد می‌کند که جویبارها از زیر [درختان] آن جاری است؛ و کافران [تنها در دنیا] بهره‌مند مى‌شوند و همچون چهارپایان مى‌خورند و آتش [دوزخ] جایگاهشان است"
  47,13,"و چه بسیار شهرهایی که ساکنانش از [مردم] شَهرت که تو را از آنجا بیرون کردند، توانمند‌تر بودند؛ ما آنان را نابود کرده‌ایم و هیچ یاوری [در برابر عذاب الهی] نداشتند"
  47,14,آیا كسى كه بر شیوۀ روشنى از جانب پروردگار خویش است، همچون كسانى است كه زشتىِ رفتارشان در نظرشان آراسته شده و از هوس‌های خویش پیروى مى‌كنند؟
  47,15,"توصیف بهشتى كه به پرهیزگاران وعده داده شده، [چنین است كه:] در آن، جویبارهایی از آبی [خالص و زلال] که بو و مزه‌اش تغییر نکرده؛ و جویبارهایی از شیری كه طعمش دگرگون نگشته؛ و جویبارهایی از شرابی كه مایۀ لذتِ نوشندگان است؛ و جویبارهایی از عسل ناب است؛ و همۀ [انواع] میوه‌ها، در آنجا در دسترسشان است و [از همه برتر، از] آمرزشِ پروردگارشان [برخوردارند]. [آیا بهشتیان] همانند ساكنان جاودان دوزخند كه آبی چنان جوشان به آنان می‌نوشانند كه روده‌هایشان را متلاشى می‌كند؟"
  47,16,"[ای پیامبر،] برخی از منافقان به [گفتار] تو گوش فرامى‌دهند اما هنگامی که از نزد تو خارج مى‌شوند، به اهل دانش [با تمسخر] مى‌گویند: «[فهمیدید] لحظاتى پیش چه مى‌گفت؟» الله بر دل‌هایشان مُهر [غفلت] نهاده است و آنان از هوس‌های خویش پیروى كرده‌اند"
  47,17,"الله بر هدایتِ پرهیزگاران مى‌افزاید و پرهیزكاری‌شان [را قوّت] مى‌بخشد"
  47,18,"آیا [کافران] جز این انتظار دارند که قیامت ناگهان بر آنان فرارسد؟ همانا نشانه‌هاى آن آشكار شده است. آنگاه كه قیامت فرارسد پندگرفتنشان چه سودی خواهد داشت؟"
  47,19,"[ای پیامبر،] بدان که معبودی [به‌حق] جز الله نیست؛ و برای گناه خویش و [گناهِ] مردان و زنان مؤمن آمرزش بخواه؛ و [به یاد داشته باش که] الله، محل رفت‌وآمدِ [روزانه] و آرمیدن [شبانۀ] شما را مى‌داند"
  47,20,"مؤمنان می‌گویند: «چرا سوره‌ای [دربارۀ اجازۀ جهاد] نازل نمی‌شود؟»؛ اما هنگامى كه آیات صریحی در مورد جنگ نازل مى‌گردد، [منافقان و] بیماردلان را مى‌بینى كه همچون كسى كه از [سختى] مرگ دستخوش بیهوشى شده باشد به تو مى‌نگرند؛ [مرگ و عذاب الهی] بر آنان شایسته‌تر است"
  47,21,"اطاعت و گفتار شایسته [بهتر است]؛ و چون تصمیم قطعی [جهاد] گرفته شد، اگر [در تعهد خود با] الله صادق باشند، [از نفاق و سرکشی]، برایشان بهتر است"
  47,22,"پس [اى منافقان،‌] آیا [جز این‌] انتظار ‌دارید كه اگر [از قرآن و سنت پیامبرش] روی بگردانید، در زمین تباهى كنید و از خویشاوندانتان ببُرید؟ [چنان‌که در جاهلیت این حالت را داشتید]"
  47,23,"اینان کسانی هستند که الله [با دور ساختن از رحمتِ خویش] لعنتشان کرده است؛ پس [گوشِ دلِ] آنان را کر، و چشم [دلِ] آنان را کور ساخته است"
  47,24,"آیا در قرآن تدبّر نمی‌کنند یا قفل‌ها[ی غفلت] بر دل‌هایشان نهاده شده است؟"
  47,25,"کسانی که پس از روشن شدن [راه] هدایت، به راه پیشینِ خویش بازگشتند [و مرتد شدند،] شیطان [اعمال زشتشان را] برایشان آراسته و آنان را [با آرزوهای دراز] فریب داده است"
  47,26,"این [جهل و گمراهی،] بدان خاطر است که منافقان به مشرکانی که از وحی الهی کراهت داشتند گفتند: «ما در برخی از امور از شما پیروی می‌کنیم»؛ و الله پنهانکاری‌شان را می‌داند"
  47,27,"آنگاه كه فرشتگان الهی بر چهره و پشتشان مى‌زنند و جانشان را مى‌گیرند، [حال این منافقان] چگونه خواهد بود؟"
  47,28,"این [کیفر،] از آن روست که آنان پیرو راهی شدند که الله را به خشم می‌آورَد و از انجام کارهایی که موجب خشنودی الهی می‌شود کراهت داشتند؛ پس [الله نیز نتیجۀ] کارهایشان را تباه ساخت"
  47,29,"آیا بیماردلان [منافق] پنداشته‌اند كه الله هرگز كینه‌هایشان را آشكار نخواهد ساخت؟"
  47,30,"[ای پیامبر،] اگر مى‌خواستیم، آنان را به تو نشان می‌دادیم كه [باطن] آنان را از ظاهرشان بازشناسى؛ و مسلّماً از شیوه سخنشان به خوبى آنان را خواهى شناخت؛ و [بدانید که] الله از کارهایتان آگاه است"
  47,31,"قطعاً [همۀ] شما را آزمایش می‌کنیم تا مجاهدان و شکیبایانتان را بازشناسیم و احوال شما را می‌آزماییم [تا راستگویان مشخص گردند]"
  47,32,"كسانى كه پس از روشن شدن راه هدایت بر آنان، کفر ورزیدند و [مردم را] از راه الله بازداشتند و به مخالفت با پیامبر برخاستند، هرگز زیانى به الله نخواهند رساند؛ و [الله نیز نتیجۀ] اعمالشان را تباه خواهد ساخت"
  47,33,"ای مؤمنان، از الله و پیامبر اطاعت كنید و [با کفر و ریا] اعمال [شایستۀ] خویش را تباه نكنید"
  47,34,"کسانی که کفر ورزیدند و [دیگران را نیز] از راه الله بازداشتند و در حال کفر مردند، الله هرگز آنان را نخواهد آمرزید"
  47,35,"پس [ای مؤمنان، هنگام رویارویی با دشمنان] سستی نورزید و [از ترس جنگ، آنان را] به صلح و آشتی دعوت نکنید؛ در حالى كه شما برترید و الله با شماست و هرگز از [پاداش] اعمالتان نخواهد کاست"
  47,36,"به راستی که زندگی دنیا، بازیچه و سرگرمى است؛ و اگر ایمان بیاورید و پرهیزگاری کنید، [الله] پاداشتان را [بی‌کم‌و‌کاست] خواهد داد؛ و [تمام] اموالتان را نمی‌خواهد [بلکه می‌فرماید که زکاتش را بپردازید]"
  47,37,"اگر [تمام] آن را از شما بخواهد و [بر این دستور] اصرار ‌کند، بخل مى‌ورزید و [این کار،] کینه‌هایتان را آشکار می‌سازد"
  47,38,"آگاه باشید! شما كسانى هستید كه براى انفاق در راه الله دعوت مى‌شوید؛ ولى برخی از شما بخل مى‌ورزند؛ و هر کس بخل بورزد، به زیان خویش بخل ورزیده است؛ و الله بى‌نیاز است و [این شما هستید كه] نیازمندید؛ و اگر [از اسلام به سوی کفر] بازگردید، الله گروهى دیگر را جایگزین شما خواهد كرد كه همچون شما [به بخل مبتلا] نباشند"
  48,1,"[ای پیامبر،] به راستی که ما پیروزىِ آشكارى را [در صلح حدیبیه] برایت مقدر كردیم"
  48,2,تا الله گناهِ گذشته و آینده‌ات را بیامرزد و نعمتش را بر تو تمام گردانَد و تو را به راه راست هدایت نماید؛
  48,3,و الله به پیروزیِ شکست‌ناپذیری یاری‌ات کند
  48,4,"اوست که بر دل‌های مؤمنان آرامش [و ثبات] نازل کرد تا بر ایمانشان بیفزایند؛ و سپاهیان آسمان‌ها و زمین از آنِ الله است؛ و الله دانای حکیم است"
  48,5,"[آری، چنین کرد] تا مردان و زنان مؤمن را به باغ‌هایی [بهشتی] وارد کند که جویبارها از زیر [درختان] آن جاری است؛ جاودانه در آنجا خواهند بود؛ و گناهانشان را بزداید [و بیامرزد]؛ و این نزد الله كامیابى بزرگى [برای مومنان] است؛"
  48,6,"و [نیز به این هدف که] منافقان و مشرکان را ـ اعم از زن و مرد ـ كه نسبت به الله بدگمانند مجازات كند؛ ناگواری [و عذاب الهی] بر آنان باد! الله بر آنان خشم گرفته و آنان را از رحمت خویش دور کرده و دوزخ را برایشان آماده نموده است؛ و [به راستی که دورخ] چه بد جایگاهی است"
  48,7,سپاهیان آسمان‌ها و زمین از آنِ الله است؛ و الله شکست‌ناپذیرِ حکیم است
  48,8,"[ای پیامبر،] ما تو را گواه و مژده‌دهنده و هشدار‌دهنده فرستادیم"
  48,9,"تا [شما مردم] به الله و پیامبرش ایمان بیاورید و [دین] او را یاری کنید و او را بزرگ دارید و بامداد و شامگاه، الله را تسبیح گویید"
  48,10,"بی‌تردید، كسانى كه با تو بیعت مى‌كنند، در حقیقت، با الله بیعت مى‌كنند؛ دست الله بالای دست‌های آنان است. هر کس [پس از بیعت] پیمان‌شكنى كند، به زیان خویش پیمان شكسته است؛ و هر کس به پیمانش [مبنی بر یاری دین الله و پیامبرش] وفا كند، به زودى [الله] پاداش بزرگی به او خواهد داد"
  48,11,"بادیه‌نشینان متخلف [كه از شركت در سفر مکه و صلح حدیبیه خودداری کرده‌اند، براى توجیهِ کارِ خود] خواهند گفت: «[محافظت] اموال و خانواده‌مان ما را گرفتار كرد؛ برایمان آمرزش بخواه». آنان چیزى كه در دل‌هایشان نیست بر زبان مى‌آورند. بگو: «اگر الله اراده كند که به شما زیان یا سودی برسد، كیست كه در مقابل [خواستِ] الله از شما دفاع کند؟ آرى، الله از آنچه مى‌كنید آگاه است»"
  48,12,"[عذرتان این نبود؛] بلكه گمان می‌کردید كه پیامبر و مؤمنان [همراهش، از این سفرِ خطرناک] هرگز نزد خانوادۀ خویش بازنخواهند گشت؛ و این [توهم] در دل‌هایتان آراسته شد و گمانِ بد بردید [که الله دین و پیامبرش را یاری نخواهد کرد؛ پس به خطا رفتید] و هلاک شدید"
  48,13,"هر کس به الله و پیامبرش ایمان نیاورد، [بداند که] ما آتشی سوزان برای کافران آماده کرده‌ایم"
  48,14,فرمانرواییِ آسمان‌ها و زمین از آنِ الله است؛ هر کس را که بخواهد می‌آمرزد و هر کس را که بخواهد عذاب می‌کند؛ و الله آمرزندۀ مهربان است
  48,15,"[ای مؤمنان،] هنگامى كه عازم [خیبر و] گرفتن غنیمت مى‌شوید، متخلفان [از سفر مکه] خواهند گفت: «اجازه دهید ما [نیز] به دنبال شما بیاییم». آنان مى‌خواهند كلام الهی را تغییر دهند. [ای پیامبر،] به آنان بگو: «شما هرگز به دنبال ما نخواهید آمد [زیرا این غنیمت‌ها مخصوص کسانی است که در حدیبیه حضور داشتند و دربارۀ این حُکم،] الله قبلاً چنین فرموده است»؛ آنگاه خواهند گفت: «[نه،] بلكه شما نسبت به ما حسد مى‌ورزید». [هرگز چنین نیست؛] بلكه جز عدۀ كمى [از آنان، اوامر الهی را] درنمى‌یابند"
  48,16,"[ای پیامبر،] به بادیه‌نشینان متخلف بگو: «به زودى به مقابله با گروهى جنگاور فراخوانده خواهید شد که آنان را از پای درآورید، مگر اینكه تسلیم شوند؛ اگر اطاعت كنید، الله پاداش نیكویى به شما خواهد داد؛ و اگر همچون گذشته سرپیچی نمایید، شما را با عذابى دردناک مجازات خواهد كرد»"
  48,17,"بر نابینا و لَنگ و بیمار گناهى نیست [كه در جنگ شركت نكنند]؛ و هر کس از الله و پیامبرش اطاعت كند، [الله] او را به باغ‌هایی [از بهشت] وارد می‌کند كه جویبارها از زیر [درختان] آن جاری است؛ و هر کس را که سرپیچی کند، به عذابى دردناک مجازات خواهد كرد"
  48,18,"الله از مؤمنانى كه در كنار آن درخت [در حدیبیه] با تو بیعت كردند، راضی شد و دانست كه در دلشان چه مى‌گذرد؛ از این روى آرامش [و ثبات] بر آنان فروفرستاد و به پیروزى نزدیک [در خیبر] پاداششان داد؛"
  48,19,"و [همچنین] غنیمت‌های فراوانی که [از خیبر] به دست می‌آورند؛ و الله همواره شکست‌ناپذیر [و] حکیم است"
  48,20,"الله غنیمت‌های فراوانى را به شما وعده داد كه [در فتوحات اسلامی آینده] به آنها دست خواهید یافت؛ این [پیروزى و غنیمت‌های خیبر] را براى شما زودتر فراهم ساخت و دست [تعدی و تجاوز] دشمن [= یهودیان] را از شما کوتاه نمود تا نشانه‌اى [از لطف الهی] برای مومنان باشد و شما را به راهى راست هدایت كند؛"
  48,21,"و [همچنین غنیمت‌های] دیگرى [در انتظار شماست] كه هنوز به آنها دست نیافته‌اید [و] الله بر آنها احاطه دارد [و از آنها آگاه است]. به راستی که الله بر هر كارى تواناست"
  48,22,"اگر کافران به جنگ شما بیایند، [از توکل و صلابت شما] پشت كرده و مى‌گریزند؛ سپس هیچ كارساز و یاورى نخواهند یافت"
  48,23,این سنت الهی است که پیشتر نیز جاری بوده است؛ و هرگز در سنت الهی تغییر و تبدیلی نخواهی یافت‌
  48,24,"اوست که در دل مکه [= در حدیبیه] دست آنان را از شما کوتاه نمود [و مانع از آن شد که شما را به جنگ وادارند]، و پس از پيروزساختنِ شما بر آنان، دست‌های شما را از آنان [بازداشت که آنان را بعد از اسارت، نکشید و آزادشان کنید]؛ و الله همواره به آنچه مى‌كنید بیناست"
  48,25,"آنان كسانى بودند كه کافر شدند و شما را از [ورود به] مسجدالحرام بازداشتند و نیز نگذاشتند قربانی‌هایی که با خود داشتید به قربانگاهش برسد؛ و اگر مردان و زنان مؤمنی [بین مردم مکه] نبودند که [در صورت بروز درگیری، ممکن بود] آنان را ندانسته پایمال کنید و ناخواسته مرتکب گناه شوید، [فرمان حمله به مکه می‌دادیم؛ ولى الله چنین کرد] تا [از اهل مکه] هر کس را که بخواهد، مشمول رحمت خویش قرار دهد؛ و اگر [مؤمنان و کافران در مکه] از یکدیگر جدا بودند، کافرانشان را با عذابى دردناک مجازات مى‌كردیم"
  48,26,"[به یاد آور] آنگاه كه کافران [مکه در حدیبیه] قلباً دستخوش تعصب، [آن هم] تعصب جاهلیت شده بودند، الله آرامش [خاطرى از جانب] خویش بر پیامبرش و بر مؤمنان فروفرستاد و آنان را به اصل [و اساس توحید و] پرهیزگاری [= لا اله الا الله] پایبند ساخت؛ چرا كه [نسبت به مشرکان،] به آن سزاوارتر و شایسته‌تر بودند؛ و الله به هر چیزى داناست"
  48,27,"الله رؤیاى رسولش را به درستی تحقق بخشید كه به خواست الهی، در حالى كه سرهایتان را تراشیده و [یا] موهایتان را كوتاه كرده‌اید، در ایمنی و بدون ترس [از دشمن]، به مسجدالحرام وارد خواهید شد. [الله] چیزهایى را مى‌دانست كه شما نمى‌دانستید؛ و علاوه بر فتح مکه، پیروزى نزدیک [خیبر] را [نیز برایتان] مقرر نمود"
  48,28,"اوست كه پیامبرش را با [کتابِ] هدایت و آیین حق فرستاد تا [حقانیت برتر] آن را بر همۀ ادیان آشکار گردانَد؛ و الله به عنوان گواه كافى است"
  48,29,"محمد رسول الله و [صحابۀ مؤمن و فداکارش، همان] کسانی که همواره با او هستند، در برابر كافران [ستیزه‌جو]، محکم و سختگیرند و با یكدیگر مهربان؛ آنان را در حال رکوع و سجده می‌بینی كه پیوسته فضل و رضایت الله را مى‌جویند؛ نشان [ایمان و پرهیزگاری] آنان در چهره‌هایشان از اثر سجده و عبادت هویداست؛ این وصف آنان در تورات است؛ و توصیفشان در انجیل [نیز] همچون گیاهی‌ است كه جوانه‌اش را برمی‌آورد و آن را نیرو می‌بخشد تا محکم گردد و بر ساقه‌هایش استوار بایستد؛ چنان كه موجب شگفتى كشاورزان شود؛ در نتیجه، [الله] با [تقویت و پیشرفتِ] مؤمنان، کافران را به خشم می‌آورد. الله به مؤمنان نیكوكار [= صحابه و پیروانشان] وعدۀ آمرزش و پاداشى بزرگ داده است"
  49,1,"ای مؤمنان، در برابر الله و پیامبرش [در هیچ كارى‌] پیشى نگیرید؛ و از الله پروا کنید كه الله شنواى داناست"
  49,2,ای مؤمنان، صدایتان را از صداى پیامبر بلندتر نكنید؛ و همچنان كه برخى از شما با برخى دیگر بلند سخن مى‌گویید، با او به صداى بلند سخن نگویید. مبادا بى‌آنكه بدانید، اعمالتان تباه گردد
  49,3,"کسانی که صدای خود را نزد رسول الله پایین می‌آورند، الله دل‌هایشان را برای پرهیزگاری آزموده [و خالص گردانده] است. آمرزش و پاداش بزرگی برایشان [در پیش] است"
  49,4,"[ولى] کسانی كه از پشت اطاق‌ها[ی همسرانت] تو را صدا مى‌زنند، بیشتر آنان بى‌خردند"
  49,5,و اگر صبر مى‌كردند تا خود براى ملاقاتشان خارج شوى، برایشان بهتر بود؛ و الله آمرزگار مهربان است
  49,6,"ای مؤمنان، اگر شخص منحرفى خبرى برایتان آورد، تحقیق كنید تا مبادا ندانسته به گروهى [بی‌گناه] آسیب برسانید و از کردۀ خود پشیمان شوید"
  49,7,"بدانید كه رسول الله میان شماست [و صلاحتان را بهتر می‌داند]؛ اگر در بسیارى از امور از [میل و نظرِ] شما پیروی كند، قطعاً دچار رنج و زحمت می‌شوید؛ ولى الله ایمان را محبوب شما نمود و آن را در دل‌هایتان بیاراست [تا اسلام بیاورید] و کفر و نافرمانى و سرکشی را در نظرتان ناخوشایند گرداند. آنان [كه آراسته به این اوصافند] پویندگانِ راه هدایت و کمالند"
  49,8,"[این عنایات،] به عنوان فضیلت و نعمتى از جانب الله [مقرر شده است]؛ و الله دانای حکیم است"
  49,9,اگر دو گروه از مؤمنان با هم درگیر شدند، میانشان آشتى برقرار كنید؛ و اگر یک گروه بر دیگرى تجاوز كرد، با گروه متجاوز بجنگید تا به فرمان الله بازآید؛ اگر بازگشت، صلحى عادلانه در میان آنان برقرار كنید و به عدالت رفتار نمایید كه الله عادلان را دوست دارد
  49,10,بی‌تردید مؤمنان برادر یكدیگرند؛ پس میان برادران خویش آشتى برقرار كنید و از الله پروا كنید؛ باشد که مورد رحمت قرار گیرید
  49,11,"هرگز نباید گروهى [از شما] گروهی دیگر را مسخره کند؛ چه بسا اینان از آنان بهتر باشند؛ و زنان نیز نباید زنان دیگر را مسخره نمایند؛ چه بسا اینان از آنان برتر باشند؛ و از یكدیگر عیبجویى نكنید؛ و یكدیگر را با لقب‌های [زشت] خطاب نكنید [که این کار، مصداقِ نافرمانی از اوامر الهی است]؛ و بدترین ویژگی [برای یک مسلمان] این است که پس از ایمان‌آوردن، [فِسق و] نافرمانی کند؛ و کسانی كه توبه نكنند، [نسبت به نفس خویش] ستمکارند"
  49,12,"ای مؤمنان، از بسیارى از گمان‌ها بپرهیزید؛ چرا كه برخى از گمان‌ها گناه است؛ و دربارۀ یكدیگر تجسس و غیبت نكنید؛ آیا هیچ یک از شما دوست دارد كه گوشت برادرِ مرده‌اش را بخورد؟ [حتماً] از آن نفرت دارید، [غیبت نیز به همین زشتى است]؛ از الله پروا كنید كه الله توبه‌پذیرِ مهربان است"
  49,13,"ای مردم، ما شما را از [آمیزش] مرد و زنى آفریدیم و به تیره‌ها و قبیله‌های مختلف تقسیم كردیم تا یكدیگر را بازشناسید. بی‌تردید، بزرگوارترین شما نزد الله پرهیزگار‌ترینِ شماست؛ و الله [به آنچه می‌کنید] دانا و آگاه است"
  49,14,"اعراب [بادیه‌نشین، در حضور پیامبر] گفتند: «ایمان آورده‌ایم» [ای پیامبر، به آنان] بگو: «شما ایمان نیاورده‌اید؛ ولى بگویید: \"اسلام آورده‌ایم\"؛ و هنوز ایمان در قلب‌هایتان نفوذ نكرده است. اگر از الله و پیامبرش اطاعت كنید، از [پاداش] اعمال شما ذره‌ای نخواهد كاست. به راستی كه الله آمرزگارى مهربان است»"
  49,15,"مؤمنان [حقیقی] كسانى هستند كه به الله و پیامبرش ایمان آورده‌اند و [لحظه‌ای در ایمانشان] تردید نكردند و با مال و جانشان در راه الله به مبارزه برخاستند؛ اینانند كه [در اعتقاد و عمل] صداقت دارند"
  49,16,"[ای پیامبر، به بادیه‌نشینان] بگو: «آیا می‌خواهید الله را از دین خویش آگاه كنید [که از عمق قلب ایمان آورده‌اید؟!] در حالى كه الله هر چه را که در آسمان‌ها و زمین است مى‌داند؛ و الله به هر چیزى آگاه است»"
  49,17,"آنان بر تو منت مى‌نهند كه اسلام آورده‌اند؛ بگو: «منتِ اسلامِ خویش را بر من نگذارید؛ بلكه اگر [در ابراز ایمان] صداقت دارید، این الله است كه بر شما منت دارد كه شما را به سوى ایمان هدایت نموده است»"
  49,18,بی‌تردید، الله اسرار آسمان‌ها و زمین را مى‌داند و به آنچه مى‌كنید بیناست