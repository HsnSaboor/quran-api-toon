quran[8]{c,v,t}:
  94,1,Mbela Min njaacnaani ma ɓernde ma
  94,2,Min ittan ma bakkatuuji ma
  94,3,Oon nisnuɗo keeci ma
  94,4,Min ɓamtan ma Innde ma
  94,5,Pellet kala satteende na wondi e newaare
  94,6,Pellet satteende kala na wondi e yaajeende
  94,7,Si A hantinii tampu
  94,8,E faade joom Ma reerɗu