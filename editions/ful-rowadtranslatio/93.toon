quran[11]{c,v,t}:
  93,1,E mbeeta
  93,2,Mi woondarii jemma si mbo deeƴi
  93,3,joom Ma accaani Mo O añaani
  93,4,Pellet ko galle laakara ɓuri gadana o
  93,5,Yaama joom Ma okku ma mbeleɗa
  93,6,Mbela O tawaani ma ko a Alyatiime O mool Ma
  93,7,O tawma ko majjuɗo O feewnu ma
  93,8,O taw ma ko a baasɗo O alɗin ma
  93,9,Tawi ko alyatiime woto hoynu mbo
  93,10,Woto furo ñaagatooɗo
  93,11,Tawi ko neema joom ma haal