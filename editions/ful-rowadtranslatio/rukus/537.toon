quran[8]{c,v,t}:
  95,1,Mi woondiri e Tiin e jaytuun
  95,2,E fella Tuur ka Siina
  95,3,E ndi leydi koolii ndi
  95,4,Min tagii aade e mbaadi Й“urndi fortaade e feewde
  95,5,Refti Min ndutti mbo to Й“uri leesЙ—ude
  95,6,"Si wonah Й“een gomЙ—imЙ“e Й“e golli moЖҙЖҙi Й—in, hino woodani Й“e njoЙ“di ndi taЖҙondirtah"
  95,7,Hol fennin ma Гұalawma njobdi caggal Й—uum
  95,8,Mbela Alla wonah Й“urЙ—o nuunЙ—ude e ГұaawooЙ“e Й“e