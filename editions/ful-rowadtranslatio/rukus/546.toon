quran[9]{c,v,t}:
  104,1,Woyli woodanii ño*oowo sanne e juwoowo sanne
  104,2,Oon denndinɗo jawdi o limi ndi
  104,3,Hombo sikka jawdi makko ndi saasnat mbo
  104,4,Alah maɓe mberle e yiite morñatnge
  104,5,Ko honɗum anndin maa ko woni yiite heltoowe
  104,6,Ko yiite Alla huɓɓatnge
  104,7,Ngeen woni yulatnge keeñe
  104,8,Ngeen de ko nge sokaange e dow maɓɓe
  104,9,E nge doosɗe pooɗtiiɗe