quran[75]{c,v,t}:
  87,1,ھەممىدىن ئۈستۈن پەرۋەردىگارىڭنىڭ نامىنى پاك ئېتىقاد قىلغىن
  87,2,ئۇ (پۈتۈن مەخلۇقاتنى) ياراتتى، (ئۇلارنى) بېجىرىم (يەنى چىرايلىق ۋە مۇناسىپ شەكىلدە) قىلدى
  87,3,مەخلۇقاتقا پايدىلىق ئىشلارنى (تەقدىر قىلدى، ئۇلارغا پايدىلىنىش يوللىرىنى) كۆرسەتتى
  87,4,ئوت ـ چۆپلەرنى ئۆستۈرۈپ بەردى
  87,5,ئاندىن ئۇلارنى قارامتۇل قۇرۇق ئوت ـ خەسكە ئايلاندۇردى
  87,6,"(ئى مۇھەممەد!) ساڭا (قۇرئاننى) ئوقۇتىمىز، ئاللاھ (نەسخى) قىلماقچى بولغان نەرسىدىن باشقىنى ئۇنتۇمايسەن. ئاللاھ (بەندىلەرنىڭ) ئاشكارا ۋە يوشۇرۇن (سۆز ـ ھەرىكەتلىرىنى) بىلىپ تۇرىدۇ[6ـ]"
  87,7,"(ئى مۇھەممەد!) ساڭا (قۇرئاننى) ئوقۇتىمىز، ئاللاھ (نەسخى) قىلماقچى بولغان نەرسىدىن باشقىنى ئۇنتۇمايسەن. ئاللاھ (بەندىلەرنىڭ) ئاشكارا ۋە يوشۇرۇن (سۆز ـ ھەرىكەتلىرىنى) بىلىپ تۇرىدۇ[6ـ]"
  87,8,سېنى بىز ئاسان يولغا (يەنى ئىسلام شەرىئىتىگە) مۇۋەپپەق قىلىمىز
  87,9,ۋەز ـ نەسىھەتنىڭ پايدىسى بولىدىغان بولسا، (كىشىلەرگە قۇرئان بىلەن) ۋەز ـ نەسىھەت قىلغىن
  87,10,ئاللاھتىن (قورققان) ئادەم ۋەز ـ نەسىھەتنى قوبۇل قىلىدۇ
  87,11,ئەڭ شەقى ئادەم ۋەز ـ نەسىھەتتىن قاچىدۇ
  87,12,ئۇ كاتتا ئوتقا (يەنى دوزاخقا) كىرىدۇ
  87,13,ئاندىن ئۇ ئوتتا ئۆلمەيدۇ ۋە (ئوبدان) ياشىمايدۇ
  87,14,(كۇفرىدىن ۋە گۇناھتىن) پاك بولغان ئادەم مەقسىتىگە يەتتى
  87,15,ئۇ پەرۋەردىگارىنىڭ نامىنى ياد ئەتتى، ئاندىن ناماز ئوقۇدى
  87,16,سىلەر دۇنيا تىرىكچىلىكىنى ئارتۇق كۆرىسىلەر
  87,17,ئاخىرەت ياخشىدۇر ۋە باقىيدۇر
  87,18,"بۇ (يەنى بۇ سۈرىدىكى ۋەزلەر) شەك ـ شۈبھىسىز بۇرۇنقى كىتابلاردا ـ ئىبراھىم ۋە مۇسالارنىڭ كىتابلىرىدا باردۇر[18ـ]"
  87,19,"بۇ (يەنى بۇ سۈرىدىكى ۋەزلەر) شەك ـ شۈبھىسىز بۇرۇنقى كىتابلاردا ـ ئىبراھىم ۋە مۇسالارنىڭ كىتابلىرىدا باردۇر[18ـ]"
  88,1,(ئى مۇھەممەد!) ساڭا ھەقىقەتەن قىيامەتنىڭ خەۋىرى كەلدى
  88,2,بۇ كۈندە نۇرغۇن ئادەملەر خار بولغۇچىدۇر
  88,3,ئۇلار دۇنيادا گۇناھ قىلغۇچىلاردۇر، (ئاخىرەتتە) جاپا تارتقۇچىلاردۇر
  88,4,ئۇلار ھارارىتى قاتتىق دوزاخقا كىرىدۇ
  88,5,(سۇلىرى) قايناپ تۇرغان بۇلاقتىن سۇغىرىلىدۇ
  88,6,ئۇلار ئۈچۈن زەرىدىن (يەنى بەتبۇي، ئاچچىق تىكەندىن) باشقا يېمەكلىك بولمايدۇ
  88,7,زەرى كىشىنى سەمرىتمەيدۇ، ئاچلىقنى پەسەيتمەيدۇ
  88,8,بۇ كۈندە نۇرغۇن كىشىلەر باركى، ئۇلار نېمەت بىلەن خۇشالدۇر
  88,9,بۇ دۇنيادا قىلغان (سەئيى - ئەمەللىرىدىن) مەمنۇندۇر
  88,10,ئۇلار ئالىي جەننەتتىدۇر
  88,11,ئۇ يەردە يامان سۆز ئاڭلىمايدۇ
  88,12,ئۇ يەردە بۇلاقلار ئېقىپ تۇرىدۇ
  88,13,"ئۇ يەردە ئېگىز تەختلەر، قاتار تىزىلغان قەدەھلەر، رەت ـ رەت قويۇلغان ياستۇقلار، سېلىنغان ئېسىل بىساتلار بار[13ـ]"
  88,14,"ئۇ يەردە ئېگىز تەختلەر، قاتار تىزىلغان قەدەھلەر، رەت ـ رەت قويۇلغان ياستۇقلار، سېلىنغان ئېسىل بىساتلار بار[13ـ]"
  88,15,"ئۇ يەردە ئېگىز تەختلەر، قاتار تىزىلغان قەدەھلەر، رەت ـ رەت قويۇلغان ياستۇقلار، سېلىنغان ئېسىل بىساتلار بار[13ـ]"
  88,16,"ئۇ يەردە ئېگىز تەختلەر، قاتار تىزىلغان قەدەھلەر، رەت ـ رەت قويۇلغان ياستۇقلار، سېلىنغان ئېسىل بىساتلار بار[13ـ]"
  88,17,"ئۇلار قارىمامدۇكى، تۆگىلەر قانداق يارىتىلدى[17]،"
  88,18,"ئاسمان قانداق ئېگىز قىلىندى[18]،"
  88,19,"تاغلار قانداق تۇرغۇزۇلدى[19]،"
  88,20,زېمىن قانداق يېيىتىلدى
  88,21,سەن (ئۇلارغا) ۋەز ـ نەسىھەت قىلغىن، سەن پەقەت (ئۇلارغا) ۋەز ـ نەسىھەت قىلغۇچىسەن
  88,22,سەن ئۇلارغا مۇسەللەت (يەنى ئۇلارنى ئىمانغا مەجبۇرلىغۇچى) ئەمەسسەن
  88,23,"لېكىن كىمكى (ۋەز ـ نەسىھەتتىن) يۈز ئۆرۈپ (ئاللاھنى) ئىنكار قىلىدىكەن[23]،"
  88,24,ئاللاھ ئۇنى قاتتىق ئازابلايدۇ
  88,25,ئۇلار (ئۆلگەندىن كېيىن) ھەقىقەتەن بىزنىڭ دەرگاھىمىزغا قايتىدۇ
  88,26,ئاندىن ئۇلاردىن ھېساب ئېلىشقا بىز مەسئۇلمىز
  89,1,سۈبھى بىلەن،
  89,2,(زۇلھەججىنىڭ دەسلەپكى) ئون كېچىسى بىلەن،
  89,3,قۇربانلىق كۈنى بىلەن، ھارپا كۈنى بىلەن،
  89,4,(كائىناتنىڭ ئاجايىپ ھەرىكىتى بىلەن) ئۆتكەن كېچە بىلەن قەسەمكى، (كاپىرلارغا چوقۇم ئازاب قىلىمىز)
  89,5,ئەقىل ئىگىسىگە بۇنىڭدا (يەنى يۇقىرقى نەرسىلەردە قانائەتلىنەرلىك)قەسەم بارمۇ؟
  89,6,"پەرۋەردىگارىڭنىڭ ئاد ـ كۈچلۈك ئىرەمنى قانداق جازالىغانلىقىنى كۆرمىدىڭمۇ؟[6ـ]"
  89,7,"پەرۋەردىگارىڭنىڭ ئاد ـ كۈچلۈك ئىرەمنى قانداق جازالىغانلىقىنى كۆرمىدىڭمۇ؟[6ـ]"
  89,8,بۇنداق ئادەملەر باشقا شەھەرلەردە يارىتىلمىغان ئىدى
  89,9,شۇنىڭدەك ۋادىقورادا تاشلارنى كېسىپ (ئۆيلەرنى بىنا قىلغان) سەمۇدنى ئاللاھ قانداق جازالىدى
  89,10,شۇنىڭدەك قۇزۇقلار ئىگىسى پىرئەۋننى قانداق جازالىدى
  89,11,ئۇلار شەھەرلەردە (زۇلۇم قىلىشتا) ھەددىدىن ئاشتى
  89,12,ئۇ يەرلەردە بۇزغۇنچىلىقنى كۆپ قىلدى
  89,13,پەرۋەردىگارىڭ ئۇلارغا قاتتىق ئازابنى نازىل قىلدى
  89,14,پەرۋەردىگارىڭ (بەندىلەرنى) ئەلۋەتتە كۆزىتىپ تۇرغۇچىدۇر
  89,15,"پەرۋەردىگارى ئىنساننى سىناپ ئەزىز قىلسا ۋە ئۇنىڭغا نېمەت بەرسە، ئۇ: «پەرۋەردىگارىم مېنى ئەزىز قىلدى» دەيدۇ"
  89,16,"پەرۋەردىگارى ئىنساننى سىناپ رىزقىنى تار قىلسا، ئۇ: «پەرۋەردىگارىم مېنى خار قىلدى» دەيدۇ"
  89,17,ھەرگىز ئۇنداق ئەمەس، سىلەر يېتىمنى ھۆرمەت قىلمايسىلەر
  89,18,بىر ـ بىرىڭلارنى مىسكىنگە ئاش، نان بېرىشكە تەرغىب قىلمايسىلەر
  89,19,مىراسنى (ھالال- ھارام دېمەستىن) ھە دەپ يەيسىلەر
  89,20,مالنى (ھېرىسلىق بىلەن) ناھايىتى دوست تۇتىسىلەر
  89,21,(ئى غاپىللار!) بۇنىڭدىن يېنىڭلار، زېمىن ئارقىمۇئارقا تەۋرىتىلگەن چاغدا
  89,22,پەرۋەردىگارىڭ كەلگەن ۋە پەرىشتىلەر سەپ ـ سەپ بولۇپ كەلگەن چاغدا
  89,23,(گۇناھكارلارنى كۆرۈش ئۈچۈن) جەھەننەم كەلتۈرۈلگەن چاغدا، شۇ كۈندە ئىنسان (يەنى كاپىر) (دۇنيادىكى قىلمىشلىرىنى) ئەسلەيدۇ، (بۇ چاغدا) ئەسلىگەننىڭ ئۇنىڭغا نېمە پايدىسى بولسۇن
  89,24,"ئۇ ئېيتىدۇكى: «كاشكى مەن (دۇنيادىكى) ھايات ۋاقتىمدا ياخشى ئىشلارنى قىلغان بولسامچۇ!»"
  89,25,شۇ كۈندە ھەر ئەھەدى (ئاللاھقا ئاسىيلىق قىلغانلارنى) ئاللاھ جازالىغاندەك جازالىمايدۇ
  89,26,ھەمدە ھېچ ئەھەدى ئاللاھ باغلىغاندەك باغلىمايدۇ
  89,27,ئى ئارام تاپقۇچى جان
  89,28,سەن پەرۋەردىگارىڭدىن مەمنۇن، پەرۋەردىگارىڭ سەندىن رازى بولغان ھالدا، ئۇنىڭ دەرگاھىغا قايتقىن
  89,29,سەن مېنىڭ (ياخشى) بەندىلىرىم قاتارىغا قوشۇلغىن
  89,30,مېنىڭ جەننىتىمگە كىرگىن