quran[82]{c,v,t}:
  100,9,"قەبرىلەردىكى ئۆلۈكلەر (سىرتقا) چىقىرىلغان، دىللاردىكى سىرلار ئاشكارا قىلىنغان چاغدا، ئۇلارنىڭ ھەممە ئەھۋالىدىن پەرۋەردىگارىنىڭ ھەقىقەتەن خەۋەردار ئىكەنلىكىنى (بۇ نادان ئىنسان) بىلمەمدۇ؟[9ـ]"
  100,10,"قەبرىلەردىكى ئۆلۈكلەر (سىرتقا) چىقىرىلغان، دىللاردىكى سىرلار ئاشكارا قىلىنغان چاغدا، ئۇلارنىڭ ھەممە ئەھۋالىدىن پەرۋەردىگارىنىڭ ھەقىقەتەن خەۋەردار ئىكەنلىكىنى (بۇ نادان ئىنسان) بىلمەمدۇ؟[9ـ]"
  100,11,"قەبرىلەردىكى ئۆلۈكلەر (سىرتقا) چىقىرىلغان، دىللاردىكى سىرلار ئاشكارا قىلىنغان چاغدا، ئۇلارنىڭ ھەممە ئەھۋالىدىن پەرۋەردىگارىنىڭ ھەقىقەتەن خەۋەردار ئىكەنلىكىنى (بۇ نادان ئىنسان) بىلمەمدۇ؟[9ـ]"
  101,1,"قىيامەت[1]،"
  101,2,قىيامەت نېمىدۇر
  101,3,قىيامەتنىڭ نېمە ئىكەنلىكىنى قانداق بىلەلەيسەن؟
  101,4,شۇ كۈندە ئىنسانلار تارىلىپ كەتكەن پەرۋانىدەك بولۇپ كېتىدۇ
  101,5,تاغلار ئېتىلغان يۇڭدەك بولۇپ كېتىدۇ
  101,6,"تارازىسى ئېغىر كەلگەن (يەنى ياخشىلىقلىرى يامانلىقلىرىنى بېسىپ چۈشكەن) ئادەمگە كەلسەك، ئۇ كۆڭۈللۈك تۇرمۇشتا (يەنى نازۇنېمەتلىك جەننەتتە) بولىدۇ[6ـ]"
  101,7,"تارازىسى ئېغىر كەلگەن (يەنى ياخشىلىقلىرى يامانلىقلىرىنى بېسىپ چۈشكەن) ئادەمگە كەلسەك، ئۇ كۆڭۈللۈك تۇرمۇشتا (يەنى نازۇنېمەتلىك جەننەتتە) بولىدۇ[6ـ]"
  101,8,"تارازىسى يېنىك كەلگەن (يەنى يامانلىقلىرى ياخشىلىقلىرىنى بېسىپ كەتكەن، يا ياخشىلىقى بولمىغان) ئادەمگە كەلسەك، ئۇنىڭ جايى ھاۋىيە بولىدۇ[8ـ]"
  101,9,"تارازىسى يېنىك كەلگەن (يەنى يامانلىقلىرى ياخشىلىقلىرىنى بېسىپ كەتكەن، يا ياخشىلىقى بولمىغان) ئادەمگە كەلسەك، ئۇنىڭ جايى ھاۋىيە بولىدۇ[8ـ]"
  101,10,ھاۋىيەنىڭ نېمە ئىكەنلىكىنى سەن قانداق بىلەلەيسەن؟
  101,11,ھاۋىيە قىزىق ئوتتۇر
  102,1,"تاكى قەبرىلەرنى زىيارەت قىلغىنىڭلارغا (يەنى قەبرىلەرگە كۆمۈلگىنىڭلارغا) قەدەر، (پۇل ـ مال، بالىلار بىلەن) پەخىرلەنمەك سىلەرنى غەپلەتتە قالدۇردى[1ـ]"
  102,2,"تاكى قەبرىلەرنى زىيارەت قىلغىنىڭلارغا (يەنى قەبرىلەرگە كۆمۈلگىنىڭلارغا) قەدەر، (پۇل ـ مال، بالىلار بىلەن) پەخىرلەنمەك سىلەرنى غەپلەتتە قالدۇردى[1ـ]"
  102,3,راستلا كەلگۈسىدە بىلىسىلەر
  102,4,ئاندىن راستلا كەلگۈسىدە بىلىسىلەر
  102,5,ئەگەر سىلەر راستلا ھەقىقىي بىلسەڭلار (غەپلەتتە قالماڭلار)
  102,6,سىلەر چوقۇم جەھەننەمنى كۆرىسىلەر
  102,7,ئاندىن ئۇنى چوقۇم ئۆز كۆزۈڭلار بىلەن كۆرىسىلەر
  102,8,ئاندىن (دۇنيادا سىلەرگە بېرىلگەن) نېمەتلەردىن سوئال ـ سوراق قىلىنىسىلەر
  103,1,"زامان بىلەن قەسەمكى[1]،"
  103,2,"ئىمان ئېيتقان، ياخشى ئەمەللەرنى قىلغان، بىر ـ بىرىگە ھەقنى تەۋسىيە قىلىشقان، بىر ـ بىرىگە سەۋرنى تەۋسىيە قىلىشقان كىشىلەردىن باشقا ھەممە ئادەم چوقۇم زىيان ئىچىدىدۇر[2 ـ]"
  103,3,"ئىمان ئېيتقان، ياخشى ئەمەللەرنى قىلغان، بىر ـ بىرىگە ھەقنى تەۋسىيە قىلىشقان، بىر ـ بىرىگە سەۋرنى تەۋسىيە قىلىشقان كىشىلەردىن باشقا ھەممە ئادەم چوقۇم زىيان ئىچىدىدۇر[2 ـ]"
  104,1,(كىشىلەرنى) ئەيىبلىگۈچى سۇخەنچىگە ۋاي
  104,2,ئۇ مال توپلىدى ۋە ئۇنى (ياخشىلىق يوللىرىغا سەرپ قىلماي ساقلاش ئۈچۈن) سانىدى
  104,3,ئۇ مېلى ئۆزىنى (دۇنيادا مەڭگۈ قالدۇرىدۇ دەپ ئويلايدۇ)
  104,4,ھەرگىز ئۇنداق ئەمەس، ئۇ چوقۇم ھۇتەمەگە تاشلىنىدۇ
  104,5,ھۇتەمەنىڭ نېمىلىكىنى قانداق بىلەلەيسەن؟
  104,6,"ئۇ، ئاللاھنىڭ ياندۇرغان ئوتىدۇركى، (ئۇنىڭ ئەلىمى) يۈرەكلەرگە يېتىپ بارىدۇ[6ـ]"
  104,7,"ئۇ، ئاللاھنىڭ ياندۇرغان ئوتىدۇركى، (ئۇنىڭ ئەلىمى) يۈرەكلەرگە يېتىپ بارىدۇ[6ـ]"
  104,8,ئۇلار چوقۇم دوزاخقا سولىنىدۇ
  104,9,ئېگىز تۈۋرۈكلەرگە باغلىنىدۇ
  105,1,پەرۋەردىگارىڭنىڭ فىل ئىگىلىرىنى قانداق قىلغانلىقىنى كۆرمىدىڭمۇ؟
  105,2,ئۇ ئۇلارنىڭ ھىيلە ـ مىكرىنى بەربات قىلمىدىمۇ؟
  105,3,ئۇ ئۇلارنىڭ ئۈستىگە توپ ـ توپ قۇشلارنى ئەۋەتتى
  105,4,"قۇشلار ئۇلارغا ساپال تاشلارنى ئېتىپ[4]،"
  105,5,ئۇلارنى چاينىۋېتىلگەن ساماندەك قىلىۋەتتى
  106,1,"قۇرەيش قوغدالغانلىقلىرى ئۈچۈن[1]،"
  106,2,"ئۇلار قىشلىق ۋە يازلىق سەپىرىدە قوغدالغانلىقلىرى ئۈچۈن[2]،"
  106,3,"بۇ ئۆي (يەنى بەيتۇللاھ) نىڭ پەرۋەردىگارىغا ئىبادەت قىلسۇنكى، ئۇ ئۇلارنى ئاچلىقتا ئوزۇقلاندۇردى، ئۇلارنى قورقۇنچتىن ئەمىن قىلدى[3ـ]"
  106,4,"بۇ ئۆي (يەنى بەيتۇللاھ) نىڭ پەرۋەردىگارىغا ئىبادەت قىلسۇنكى، ئۇ ئۇلارنى ئاچلىقتا ئوزۇقلاندۇردى، ئۇلارنى قورقۇنچتىن ئەمىن قىلدى[3ـ]"
  107,1,دىننى ئىنكار قىلغان ئادەمنى كۆردۈڭمۇ؟
  107,2,"ئۇ يېتىمنى دۆشكەلەيدىغان، مىسكىنگە تاماق بېرىشنى تەرغىب قىلمايدىغان ئادەمدۇر[2ـ3]،"
  107,3,"ئۇ يېتىمنى دۆشكەلەيدىغان، مىسكىنگە تاماق بېرىشنى تەرغىب قىلمايدىغان ئادەمدۇر[2ـ3]،"
  107,4,"شۇنداق ناماز ئوقۇغۇچىلارغا ۋايكى، ئۇلار نامازلىرىدىن غەپلەتتىدۇر [4ـ]"
  107,5,"شۇنداق ناماز ئوقۇغۇچىلارغا ۋايكى، ئۇلار نامازلىرىدىن غەپلەتتىدۇر [4ـ]"
  107,6,نامازنى رىيا قىلىدىغانلاردۇر
  107,7,ئۇلار قولقا بەرمەيدۇ
  108,1,بىز ساڭا ھەقىقەتەن نۇرغۇن ياخشىلىقلارنى ئاتا قىلدۇق
  108,2,پەرۋەردىگارىڭ ئۈچۈن ناماز ئوقۇغىن ۋە قۇربانلىق قىلغىن
  108,3,ھەقىقەتەن سېنىڭ دۈشمىنىڭنىڭ نام ـ نىشانى قالمايدۇ
  109,1,(ئى مۇھەممەد! سېنى بۇتلارغا چوقۇنۇشقا ئۈندىگۈچى كۇففارلارغا) ئېيتقىنكى، «ئى كاپىرلار
  109,2,سىلەر چوقۇنۇۋاتقان بۇتلارغا مەن چوقۇنمايمەن
  109,3,سىلەرمۇ مەن ئىبادەت قىلىۋاتقان ئاللاھقا ئىبادەت قىلمايسىلەر
  109,4,سىلەر چوقۇنغان بۇتلارغا مېنىڭ چوقۇنغىنىم يوق
  109,5,سىلەرنىڭمۇ مەن ئىبادەت قىلغان ئاللاھقا ئىبادەت قىلغىنىڭلار يوق
  109,6,سىلەرنىڭ دىنىڭلار ئۆزۈڭلار ئۈچۈن، مېنىڭ دىنىممۇ ئۆزۈم ئۈچۈن»
  110,1,"ئاللاھنىڭ ياردىمى ۋە غەلىبىسى كەلگەن ۋە ئاللاھنىڭ دىنىغا كىشىلەرنىڭ توپ ـ توپ بولۇپ كىرگەنلىكىنى كۆرگىنىڭدە[1ـ2]،"
  110,2,"ئاللاھنىڭ ياردىمى ۋە غەلىبىسى كەلگەن ۋە ئاللاھنىڭ دىنىغا كىشىلەرنىڭ توپ ـ توپ بولۇپ كىرگەنلىكىنى كۆرگىنىڭدە[1ـ2]،"
  110,3,رەببىڭغا تەسبىھ ئېيتقىن، ھەمدى ئېيتقىن ۋە ئۇنىڭدىن مەغپىرەت تىلىگىن. ئاللاھ ھەقىقەتەن تەۋبىنى بەك قوبۇل قىلغۇچىدۇر
  111,1,ئەبۇ لەھەبنىڭ ئىككى قولى قۇرۇپ كەتسۇن! (ئەمەلدە) قۇرۇپ كەتتى
  111,2,ئۇنىڭغا مال ـ مۈلكى ۋە ئېرىشكەن نەرسىلىرى ئەسقاتمىدى
  111,3,ئۇ لاۋۇلداپ تۇرغان ئوتقا (يەنى دوزاخقا) كىرىدۇ
  111,4,ئۇنىڭ ئوتۇن توشۇغۇچى (يەنى سۇخەنچى) خوتۇنىمۇ لاۋۇلداپ تۇرغان ئوتقا كىرىدۇ
  111,5,ئۇنىڭ بوينىدا مەھكەم ئېشىلگەن ئارغامچا بولىدۇ
  112,1,(ئى مۇھەممەد!) ئېيتقىنكى، ئۇ ـ ئاللاھ بىردۇر
  112,2,ھەممە ئاللاھقا موھتاجدۇر
  112,3,ئاللاھ بالا تاپقانمۇ ئەمەس، تۇغۇلغانمۇ ئەمەس
  112,4,ھېچ كىشى ئۇنىڭغا تەڭداش بولالمايدۇ
  113,1,"«مەخلۇقاتنىڭ شەررىدىن، قاراڭغۇلۇقى بىلەن كىرگەن كېچىنىڭ شەررىدىن، تۈگۈنلەرگە دەم سالغۇچى سېھىرگەرلەرنىڭ شەررىدىن، ھەسەتخورنىڭ ھەسەت قىلغان چاغدىكى شەررىدىن سۈبھىنىڭ پەرۋەردىگارى (ئاللاھ) قا سىغىنىپ پاناھ تىلەيمەن» دېگىن[1ـ]"
  113,2,"«مەخلۇقاتنىڭ شەررىدىن، قاراڭغۇلۇقى بىلەن كىرگەن كېچىنىڭ شەررىدىن، تۈگۈنلەرگە دەم سالغۇچى سېھىرگەرلەرنىڭ شەررىدىن، ھەسەتخورنىڭ ھەسەت قىلغان چاغدىكى شەررىدىن سۈبھىنىڭ پەرۋەردىگارى (ئاللاھ) قا سىغىنىپ پاناھ تىلەيمەن» دېگىن[1ـ]"
  113,3,"«مەخلۇقاتنىڭ شەررىدىن، قاراڭغۇلۇقى بىلەن كىرگەن كېچىنىڭ شەررىدىن، تۈگۈنلەرگە دەم سالغۇچى سېھىرگەرلەرنىڭ شەررىدىن، ھەسەتخورنىڭ ھەسەت قىلغان چاغدىكى شەررىدىن سۈبھىنىڭ پەرۋەردىگارى (ئاللاھ) قا سىغىنىپ پاناھ تىلەيمەن» دېگىن[1ـ]"
  113,4,"«مەخلۇقاتنىڭ شەررىدىن، قاراڭغۇلۇقى بىلەن كىرگەن كېچىنىڭ شەررىدىن، تۈگۈنلەرگە دەم سالغۇچى سېھىرگەرلەرنىڭ شەررىدىن، ھەسەتخورنىڭ ھەسەت قىلغان چاغدىكى شەررىدىن سۈبھىنىڭ پەرۋەردىگارى (ئاللاھ) قا سىغىنىپ پاناھ تىلەيمەن» دېگىن[1ـ]"
  113,5,"«مەخلۇقاتنىڭ شەررىدىن، قاراڭغۇلۇقى بىلەن كىرگەن كېچىنىڭ شەررىدىن، تۈگۈنلەرگە دەم سالغۇچى سېھىرگەرلەرنىڭ شەررىدىن، ھەسەتخورنىڭ ھەسەت قىلغان چاغدىكى شەررىدىن سۈبھىنىڭ پەرۋەردىگارى (ئاللاھ) قا سىغىنىپ پاناھ تىلەيمەن» دېگىن[1ـ]"
  114,1,"«ئىنسانلارنىڭ پەرۋەردىگارى، ئىنسانلارنىڭ پادىشاھى، ئىنسانلارنىڭ ئىلاھى (ئاللاھ) قا سىغىنىپ، كىشىلەرنىڭ دىللىرىدا ۋەسۋەسە قىلغۇچى جىنلاردىن ۋە ئىنسانلاردىن بولغان يوشۇرۇن شەيتاننىڭ ۋەسۋەسىسىنىڭ شەررىدىن پاناھ تىلەيمەن» دېگىن[1ـ]"
  114,2,"«ئىنسانلارنىڭ پەرۋەردىگارى، ئىنسانلارنىڭ پادىشاھى، ئىنسانلارنىڭ ئىلاھى (ئاللاھ) قا سىغىنىپ، كىشىلەرنىڭ دىللىرىدا ۋەسۋەسە قىلغۇچى جىنلاردىن ۋە ئىنسانلاردىن بولغان يوشۇرۇن شەيتاننىڭ ۋەسۋەسىسىنىڭ شەررىدىن پاناھ تىلەيمەن» دېگىن[1ـ]"
  114,3,"«ئىنسانلارنىڭ پەرۋەردىگارى، ئىنسانلارنىڭ پادىشاھى، ئىنسانلارنىڭ ئىلاھى (ئاللاھ) قا سىغىنىپ، كىشىلەرنىڭ دىللىرىدا ۋەسۋەسە قىلغۇچى جىنلاردىن ۋە ئىنسانلاردىن بولغان يوشۇرۇن شەيتاننىڭ ۋەسۋەسىسىنىڭ شەررىدىن پاناھ تىلەيمەن» دېگىن[1ـ]"
  114,4,"«ئىنسانلارنىڭ پەرۋەردىگارى، ئىنسانلارنىڭ پادىشاھى، ئىنسانلارنىڭ ئىلاھى (ئاللاھ) قا سىغىنىپ، كىشىلەرنىڭ دىللىرىدا ۋەسۋەسە قىلغۇچى جىنلاردىن ۋە ئىنسانلاردىن بولغان يوشۇرۇن شەيتاننىڭ ۋەسۋەسىسىنىڭ شەررىدىن پاناھ تىلەيمەن» دېگىن[1ـ]"
  114,5,"«ئىنسانلارنىڭ پەرۋەردىگارى، ئىنسانلارنىڭ پادىشاھى، ئىنسانلارنىڭ ئىلاھى (ئاللاھ) قا سىغىنىپ، كىشىلەرنىڭ دىللىرىدا ۋەسۋەسە قىلغۇچى جىنلاردىن ۋە ئىنسانلاردىن بولغان يوشۇرۇن شەيتاننىڭ ۋەسۋەسىسىنىڭ شەررىدىن پاناھ تىلەيمەن» دېگىن[1ـ]"
  114,6,"«ئىنسانلارنىڭ پەرۋەردىگارى، ئىنسانلارنىڭ پادىشاھى، ئىنسانلارنىڭ ئىلاھى (ئاللاھ) قا سىغىنىپ، كىشىلەرنىڭ دىللىرىدا ۋەسۋەسە قىلغۇچى جىنلاردىن ۋە ئىنسانلاردىن بولغان يوشۇرۇن شەيتاننىڭ ۋەسۋەسىسىنىڭ شەررىدىن پاناھ تىلەيمەن» دېگىن[1ـ]"