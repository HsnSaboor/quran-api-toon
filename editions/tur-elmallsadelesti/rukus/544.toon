quran[8]{c,v,t}:
  102,1,O çokluk kuruntusu sizleri oyaladı
  102,2,ta kabirlere kadar gidip ziyaret edişinize kadar
  102,3,"Öyle değil, ileride bileceksiniz"
  102,4,"Sonra yine öyle değil, ileride bileceksiniz"
  102,5,"Öyle değil, kesin olarak bilseniz"
  102,6,"andolsun ki, cehennemi mutlaka göreceksiniz"
  102,7,"Sonra yine andolsun ki, onu yakın gözüyle göreceksiniz"
  102,8,"Sonra andolsun ki, o gün her nimetten sorgulanacaksınız"