quran[8]{c,v,t}:
  94,1,"[اى پیامبر!] آیا سینه‌ات را نگشاده‌ایم؟"
  94,2,"و بار سنگینت را از [دوش] تو برنداشتیم؟"
  94,3,"آن [بار گران] که براى تو کمرشکن بود"
  94,4,"و نام تو را بلند [آوازه] کردیم"
  94,5,"پس [بدان که] با هر سختى، آسانى است"
  94,6,"[آرى!] با هر سختى، آسانى است"
  94,7,"پس هرگاه [از کار] فارغ شدى، [برای کار تازه] بکوش و رنج آن را بر خود هموار کن"
  94,8,و مشتاقانه به سوى پروردگارت روى آور