quran[17]{c,v,t}:
  86,1,Při nebi a HVĚZDĚ NOČNÍ
  86,2,"A co poví ti, co jest hvězda noční"
  86,3,Hvězda pronikavě (zářivá)
  86,4,Zajisté každá duše nad sebou strážce má
  86,5,"Nechť pohlédne jen člověk na to, z čeho stvořen byl"
  86,6,Stvořen byl z vody vystřiklé
  86,7,z prostřed ledví a kostí hrudních vyšlé
  86,8,Pročež jistě (Bůh) moc má; by vrátil jej (k životu)
  86,9,"v den, kdy zkoumána budou tajemství"
  86,10,"a kdy síly míti (člověk) nebude, aniž pomocníka"
  86,11,"Při nebi, jež se otáčí"
  86,12,"při zemi, jež se rozpukává"
  86,13,"(přísám, že Korán) zajisté jest slovo rozhodné"
  86,14,není Jen žertem (míněno)
  86,15,Oni pak kují léčky své —
  86,16,a já též kuji léčky své
  86,17,"Pomalu jednej s nevěrci: poshov jim (ještě) chvilenku"