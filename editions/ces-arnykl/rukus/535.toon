quran[11]{c,v,t}:
  93,1,Při ZÁŘI POLEDNÍ
  93,2,"a noci, když se temní"
  93,3,"Neopustil tě Pán tvůj, aniž tě nenávidí"
  93,4,zajisté pak život budoucí lepším bude pro tebe života pozemského
  93,5,zajisté obdaří té Pán tvůj a budeš spokojen
  93,6,Což neshledal tě sirotkem a dal ti útulek
  93,7,A shledal tě zbloudilým a uvedl tě (na cestu pravou)
  93,8,a shledal tě potřebným a obohatil tě
  93,9,"Pročež, pokud se týče sirotka. neubližuj mu"
  93,10,"a pokud se týče prosícího, neodháněj ho"
  93,11,"a pokud se týče dobrodiní Pána tvého, hovoř o něm"