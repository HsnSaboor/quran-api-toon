quran[11]{c,v,t}:
  101,1,Azeem hadisa
  101,2,Kya hai woh azeem hadisa
  101,3,Tum kya jano ke woh azeem hadisa kya hai
  101,4,woh din jab log bhikre huey parwano ki tarah
  101,5,Aur pahad rang bi rangi dhunki hui oon ke tarah hongey
  101,6,Phir jiske palade bhari hongey
  101,7,Woh dil pasand aish mei hoga
  101,8,Aur jis kay palade halke hongey
  101,9,Uski jaye qarar gehri khayi hogi
  101,10,Aur tumhein kya khabar kay woh kya cheez hai
  101,11,Bhadakti hui Aag