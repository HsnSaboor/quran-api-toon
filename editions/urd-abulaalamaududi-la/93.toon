quran[11]{c,v,t}:
  93,1,Kasam hai rozey roshan ki
  93,2,Aur raat ki jabke woh sukoon ke saath taari ho jaye
  93,3,(Aey nabi) tumharey Rubb ne tumko hargiz nahin chodha aur na woh naraaz hua
  93,4,Aur yaqeenan tumhare liya baad ka daur pehle daur se behtar hai
  93,5,Aur anqareeb tumhra Rubb tumko itna dega ke tum khush ho jaogey
  93,6,Kya usne tumko yateem nahin paya aur phir thikana faraham kiya
  93,7,Aur tumhey nawaqif-e-raah paya aur phir hidayat bakshi
  93,8,Aur tumhein nadaar(in want) paya aur phir maldar kar diya
  93,9,Lihaza yateem par sakhti na karo
  93,10,Aur saayil(maangne waley) ko na jhidko
  93,11,Aur apne Rubb ki niyamt ka izhar karo