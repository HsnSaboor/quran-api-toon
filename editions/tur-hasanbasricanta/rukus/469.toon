quran[38]{c,v,t}:
  56,1,Kıyamet kopduğu zaman
  56,2,(hiçbir nefs) onun vukuunda (Allaha karşı artık) yalancı değildir
  56,3,"O, (kimini) alçaltıcı, (kimini) yükselticidir"
  56,4,O zaman yer bir sarsıntı ile sarsılmışdır
  56,5,dağlar didik didik parçalanmışdır
  56,6,"derken (hepsi de) dağılmış, toz haaline gelmişdir"
  56,7,Siz de (kıyâmetde) üç sınıf olmuşsunuzdur
  56,8,"Sağcılar (a gelince:) O sağcılar ne (mutlu) durlar"
  56,9,"Solcular (a gelince:) O solcular ne (bedbaht) dırlar"
  56,10,"Hayır yarışlarında tâ öne geçib kazananlar (a gelince:) onlar (orada da) öncüdürler"
  56,11,İşte onlar (Allaha) en çok yaklaşdırılmış olanlardır
  56,12,Naıym cennetlerinde (dirler)
  56,13,Bir çok (u) evvelki (ümmet) lerden
  56,14,biraz (ı) da sonrakilerdendir
  56,15,(Onlar) cevherlerle örülmüş tahtlar üzerindedirler
  56,16,Üstlerinde karşı karşıya yaslanan (bahtiyar) lar olacak
  56,17,Ebedî (taze) lige mazhar edilmiş evlâdlar (hizmet için) etraflarında dolanırlar
  56,18,"«Maîn» (kaynağın) dan (dolu) büyük kablarla, ibriklerle ve kadehlerle"
  56,19,(Ki bundan baş ağrısına uğratılmayacaklar) gibi akılları da giderilmez
  56,20,Beğeneceklerinden (türlü) meyve (ler)
  56,21,İştahlanacaklarından kuş et (ler) i ile (etraflarında dolanırlar)
  56,22,(Orada) şahin gözlü huurîler de (vardır)
  56,23,saklı inci timsâlleri gibi
  56,24,(Bunlar mukarreblerin) işledikleri iyi amel (ve hareket) lere bir mükâfat olarak (yapılır)
  56,25,"Onlar orada ne boş bir lâf, ne de günâha sokacak bir şey işitmezler"
  56,26,"Yalınız bir söz (işidirler ki oda) «Selâm, selâm» dir"
  56,27,"Sağcılar: Onlar ne (mutlu) sağcılardır"
  56,28,Dikensiz kiraz
  56,29,meyveleri tıklım tıklım muz ağaç (lar) ı
  56,30,yayılmış (daimî) gölge (ler)
  56,31,dâima akan su (lar)
  56,32,"(hiçbir zaman) kesil (ib tüken) meyen, yasak da edilmeyen birçok (cinsde) meyve (ler) arasında"
  56,33,"(hiçbir zaman) kesil (ib tüken) meyen, yasak da edilmeyen birçok (cinsde) meyve (ler) arasında"
  56,34,ve (kadri) yükseltilmiş döşeklerdedirler
  56,35,"Hakıykat, biz onları yepyeni bir yaratılışla yaratdık da"
  56,36,"kız oğlan kızlar, zevcelerine sevgi ile düşkün, hep bir yaşıt yapdık"
  56,37,"kız oğlan kızlar, zevcelerine sevgi ile düşkün, hep bir yaşıt yapdık"
  56,38,sağcılar için