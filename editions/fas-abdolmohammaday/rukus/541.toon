quran[8]{c,v,t}:
  99,1,آنگاه كه زمين لرزانده شود به سخت‌ترين لرزه‌هايش،
  99,2,و زمين بارهاى سنگينش را بيرون ريزد،
  99,3,و آدمى بگويد كه زمين را چه رسيده است؟
  99,4,در اين روز زمين خبرهاى خويش را حكايت مى‌كند
  99,5,از آنچه پروردگارت به او وحى كرده است
  99,6,در آن روز مردم پراكنده از قبرها بيرون مى‌آيند تا اعمالشان را به آنها بنمايانند
  99,7,پس هر كس به وزن ذره‌اى نيكى كرده باشد آن را مى‌بيند
  99,8,و هر كس به وزن ذره‌اى بدى كرده باشد آن را مى‌بيند