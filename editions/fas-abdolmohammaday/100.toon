quran[11]{c,v,t}:
  100,1,سوگند به اسبان دونده‌اى كه نفس‌نفس مى‌زنند،
  100,2,سوگند به اسبانى كه به سُم از سنگ آتش مى‌جهانند،
  100,3,و سوگند به اسبانى كه بامدادان هجوم آورند،
  100,4,و در آنجا غبار برانگيزند،
  100,5,و در آنجا همه را در ميان گيرند،
  100,6,"كه: آدمى پروردگار خود را سپاس نمى‌گويد،"
  100,7,و او خود بر اين گواه است،
  100,8,او مال را فراوان دوست دارد
  100,9,آيا نمى‌داند كه چون آنچه در گورهاست زنده گردد،
  100,10,و آنچه در دلها نهان است آشكار شود،
  100,11,پروردگارشان در آن روز از حالشان آگاه است؟