quran[40]{c,v,t}:
  77,1,Nditsuba khutsirumungwa kaala
  77,2,Nende tsiwutsanga bwangu
  77,3,Nende tsimitsanga amakhuwa koosi
  77,4,Nende tsiokhwawukhasia nitsikabukhasia
  77,5,Nende khutsiyilanga amachelo
  77,6,"Tsibe\tkhubo\teshichila\tnohomba amekanyilisio"
  77,7,Toto bwene kamulakungwa kaliba
  77,8,Olwe tsing’ining’ini tsilirusibwayo
  77,9,Ne olwe likulu liliatisibwa
  77,10,Ne olwe tsingulu tsilipurusibwa
  77,11,Ne olwa Abarumwa balihebwa ebise biabu
  77,12,Ni inyanga shina yakasilibwa amakhuwa ako
  77,13,Inyanga yokhwaukhania
  77,14,"Ne\tshina\tshikhumanyia\tinyanga yokhwaukhania nishina"
  77,15,Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi
  77,16,Shikhwa sishia abaranjila
  77,17,Mana nikhubalondiakhwo abandi
  77,18,Endio nilwakhukholanga Abandu ababii
  77,19,Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi
  77,20,Shikhwabaloonga okhurulana nende amatsi kalekungwa
  77,21,Mana nikhukara habundu ayenzefu alayi
  77,22,Okhula ibise bikwanile
  77,23,Mana nikhuraho ebise ne nifwe abamanya ebise bikwanile
  77,24,Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi
  77,25,"Shikhwakhola\tliloba\tlibe liokhukhung’asia"
  77,26,Abalamu nende Abafu
  77,27,"Ne nikhuramwo tsingulu tsindambi tsiokhusiila, ne nukhubanywesia amatsi amalayi"
  77,28,Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi
  77,29,Tsie khu shinyasio shiamwakhayanga
  77,30,Tsie mushinikha shiamarafi kataru
  77,31,Sishikalila omulilo nohomba sishikhoonya shosishosi tawe khubwalaba bwomulilo
  77,32,Omulilo oko kusukunanga tsinzesele shinga tsinzu
  77,33,Shinga tsingamia tsianamabuyu
  77,34,"Eshinyasio eshikhongo\tinyanga eyo shiliba khubakhayi"
  77,35,Ino ni inyanga yabalaliboola shiosi shiosi tawe
  77,36,Nohomba shibalifuchililwa okhurusia eshichila tawe
  77,37,Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi
  77,38,"Ino niyo inyanga yobwawukhani, khubakhung’asiye nende abeyimbeli"
  77,39,Ne nimuli nenda liamwakhakhola mukhole
  77,40,Eshinyasio eshikhongo inyanga eyo shiliba khu bakhayi