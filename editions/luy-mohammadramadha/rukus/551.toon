quran[6]{c,v,t}:
  109,1,"Boola: “Enywe Abakhayi"
  109,2,Shelaamanga shiamulaamanga tawe
  109,3,"Nohomba\tenywe\tshimulaamanga Owelaamanga tawe"
  109,4,Nohomba shindililaama shiamulaamanga tawe
  109,5,"Nohomba\tenywe\tshimulaamanga owelaamanga tawe"
  109,6,"Enywe muli nende idini yenyu, nasi endi nende idini yanje.”"