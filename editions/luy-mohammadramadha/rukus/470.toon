quran[36]{c,v,t}:
  56,39,Omukabo omukhongo khubaali imbeli
  56,40,Ne omukabo omukhongo khubaali inyuma
  56,41,"Abandu bomukhono mukhasi , koo ni shina shilinyoola Abandu bomukhono mukhasi"
  56,42,Baliba mumuyeka kwomulilo nende amatsi kayia pia
  56,43,Nende eshinikha shiomwosi omumali ti
  56,44,"Shishili shiokhunyoolamwo\tobunyifu nohombo obwihotselefu tawe"
  56,45,Toto abo bali khale awo bamenyanga shinga benya
  56,46,"Ne\tbaali\tnibakhaila\tkhubionoono ebikhongo"
  56,47,"Ne baboolanga mbu nikhumala khwafwa mana nikhuba liloba nende ebikumba, mbu toto efwe khulilamusibwa"
  56,48,Nohomba bapapa befu bakhale
  56,49,"Boola mbu: “balia abeyimbeli nende inyuma”"
  56,50,“Toto balilamusibwa khubise bieyinyanga yarechekhwa.”
  56,51,Mana toto enywe abakori abakhayi
  56,52,Mulilia toto omusala kwa zaqoom
  56,53,Mulikwitsusia mutsinda tsienyu
  56,54,Ne mana mulinywa amaatsi kayile pia
  56,55,Nemulikanywa shinga ingamia inywetsanga nili nende obuloo
  56,56,Ino niyo isambo yabu inyanga yomurungo
  56,57,Efwe khwabaloonga enywe shichilanga shina nimulasuubila
  56,58,Koo mulolangakhwo amatsi kolwibulo kamwitikhanga
  56,59,"Koo\tnenywe\tmukaloonganga nohomba nefwe abaloonji"
  56,60,Efwe khwabarecheshela lifwa nafu shikhushilungwa tawe
  56,61,Okhukalukhania abaandi balali enywe ne khubalonje enywe ebindi biamulamanyile tawe
  56,62,"Netoto mwamala okhumanya okhulongwa khwa ambeli, neshina shichilanga nimuletsulilaanga"
  56,63,"Ne\tmulolangakhwo\temimela chiamuraakanga"
  56,64,Nenywe muchimesinjia nohomba nefwe khuchimesinjia
  56,65,"Ne nikhwenya nikhuchikhola chiakhaya okhurakhwo shiosi shiosi, mwatong’a nimung’ang’alile"
  56,66,Nimuboola mbu toto efwe khusishile
  56,67,Halali efwe khwimilwe
  56,68,"Koo\tmulolangakhwo\tamaatsi kamunywetsanga"
  56,69,Ni enywe mukeshinjia okhurula mumaleesi nohomba nefwe bakeshiinjia
  56,70,"Nikhwenya nikhukakhola keyichumvi , ne shina shichilanga nimuloopa orio"
  56,71,Mulolangakhwo omulilo kwamwashinjia
  56,72,Nenywe mwaloonga omusaala kwakwo nohomba nefwe baloonga
  56,73,Efwe khwakukhola okhuba eshitsulisio nende kwokhukhoonya balia bali mushitsimi
  56,74,Ne witsoomie elira lia Nyasaye wuwo omukhongo