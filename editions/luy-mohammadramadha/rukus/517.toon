quran[10]{c,v,t}:
  77,41,Toto abaria Nyasaye baliba mubinikha nende tsisebele
  77,42,Nende ebiamo biabachama
  77,43,lie ne munywe mumwikhoyo khukalia kamwakholanga
  77,44,Toto endio nilwakhurunganga abakholi bamalayi
  77,45,Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi
  77,46,"Lie, ne mwikhoye hatiti, toto enywe muli abamayanu"
  77,47,Eshinyasio eshikhongo inyanga eyo shiliba khubakhayi
  77,48,"Ne nobaboolela mbu benamile Nyasaye, shibamwinamila tawe"
  77,49,Eshinyasio eshikhonga inyanga eyo shiliba khubakhayi
  77,50,Mana nimakhuwa shina imbeli wa kano kabasuubilanga