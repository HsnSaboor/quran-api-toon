quran[25]{c,v,t}:
  74,32,Tawe Nditsuba khumwesi
  74,33,Nende khushilo nishiwa
  74,34,Nende khumabwibwi olwabushietsanga
  74,35,Toto omulilo oko nimulala khumakhuwa amakhongo muno
  74,36,Ne amekanyilisio khubandu
  74,37,Kho ulia wenya mwinywe aranjilile nohomba amalilishe
  74,38,"Buli\tOmundu\talinyoola\tamabii kayakhola"
  74,39,halali Abandu bomukhono omusatsa
  74,40,"Baliba\tmwikulu\t(mumikunda) nibarebananga"
  74,41,Amakhuwa ka Abandu betsimbii
  74,42,Ni shina shiachila nimwinjila mumulilo
  74,43,"Baliboola mbu: “ efwe shikhwalamanga tawe"
  74,44,Ne shikhwalisinjia abamanani tawe
  74,45,Nekhwali nikhweibila halala nende balia beyibila mutsimbi
  74,46,Ne khwali na mainji khuyinyanga yomurungo
  74,47,Okhula shinga lifwa liakhuulila
  74,48,Kho okhusabilwa khwomusabi shikhulibakhoonya shiosi shiosi tawe
  74,49,"Mana\tbalibarieena\tabalawulila amekanyilisio kano"
  74,50,Opara mbu tsisishili tsisundusibwe
  74,51,Tsilukhanga Italanyi
  74,52,Mbu buli Omundu mubo yenya ehebwe eshitabu shishie okhurula mwikulu
  74,53,"Shikali kario tawe, halali shibaritsanga Mwikulu tawe"
  74,54,"Shikali kario tawe , toto kano ni ametsulisio"
  74,55,Khu ulia wenya yetsulile
  74,56,"Ne shibakhetsulila tawe okhuula Nyasaye achame, Eshiribwa neshishie. Nobulesheli nobuubwe"