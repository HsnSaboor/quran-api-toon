quran[11]{c,v,t}:
  93,1,Nditsuba khu isenya
  93,2,Nditsuba khushilo olwa shinjilanga
  93,3,"Nyasaye wuwo shiyakhulekha tawe, nohomba shiyakhusinyishila tawe"
  93,4,Ne imbeli itsanga ilaba indayi okhushila ebise biaranjilila
  93,5,Ne Nyasaye wuwo omulesi alakhuwa okhula ochame
  93,6,Shiyakhunyoola noli omufwilwa ya khuwa eshimenyo
  93,7,Ne yakhunyoola niwakora yakhulunjisia
  93,8,"Nenakhunyoola\tnoli\tomumanani nakhuyindiasia"
  93,9,Mana omufwilwa olamuyindushila tawe
  93,10,Naye usaba olamuwusa tawe
  93,11,Ne obwokholo bwa Nyasaye wuwo omulesi obuboole