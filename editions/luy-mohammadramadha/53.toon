quran[62]{c,v,t}:
  53,1,"Nditsuba\tkhu\ting’iningini\tolwa ikhamiukhanga"
  53,2,"Owashienywe\tuno shiyakora tawe nohomba shiyetsukhanila tawe"
  53,3,Ne shaboolanga khubwikombi bubwe tawe
  53,4,Halali ni obufimbuli bwafimbulilungwa
  53,5,Yechesibwa nende Owamani amanji
  53,6,Owakukhanga niyewotselesia
  53,7,Naye ali hekulu muno
  53,8,Mana owitsanga ahambi niyekha
  53,9,Naba hambi shinga akari wemikhono chibili nohambo ahambi muno
  53,10,Mana namufimbulila Omusumba we ubufimbuli
  53,11,"Omwoyo\tshikwaboola\tobubeyi khukakwalolo tawe"
  53,12,Koo mumuyingasinjia khukayalola
  53,13,Mana toto namulola khandi
  53,14,Mushisina shio musaala ( mkunazi) kwo khu malilikha
  53,15,"Ahambi nende omusaala oko, kuliwo omukunda kwamenywamwo"
  53,16,Olwa kwafimbwa omusaala oko nende shiakufiimba
  53,17,Tsimoni shitsiesundukha tawe nohomba shitsiabura eshichelo tawe
  53,18,Toto yalola ebimanyisio ebikhongo bia Nyasaye wuwe Omulesi
  53,19,Koo mwalolakhwo Laata nende Uzza
  53,20,"Nende Manata, owundi wakhataru"
  53,21,Koo nenywe muli nabasiani Naye alinabakhaana
  53,22,Toto okho ni okhukaba okhubi
  53,23,"Ako namerasa kamwakulikha enywe nende basenywe, Nyasaye shiyeshiakhwo shiosi shiosi khumeera ako tawe. balondangasa amaparo nende shie mioyo chiabu chienya, ne toto abulunjifu bwabetsela okhurula khu Nyasaye wabu"
  53,24,Mbu Omundu anyoolanga shia yekombanga
  53,25,Nyasaye sa niye mwene eshialo nende mwikulu
  53,26,"Ne ni Abamalaika benga bali mwikulu, abokhusabila khwabu shikhulikhoonya yesi yesi tawe, halali khuwa Nyasaye achamile namufuchilila"
  53,27,Toto biala balasuubilanga mwikulu tawe balanganga Abamalaika amera keshikhasi
  53,28,"Ne babula shiabamanyile khu ako, balondanga butswa amaparo, ne toto okhuparirisia shikhukhoonyanga shiosi shiosi khubwatoto tawe"
  53,29,"Lekhana nende ulia uhelesia omukongo ametsulisio kefu, ne shiyenya shosi shosi halali obulamu bwokhushialo"
  53,30,"Awo naboolela khubumanyi, toto Nyasaye wuwo niye umanyile muno ulia wakora khunjila ye, naye amanyile muno ulia walunjikha"
  53,31,"Ne nibia Nyasaye biosi bili mwikulu nende mushialo, kho abarunge betsimbi khukabakholanga ne abakhola amalayi abarunge obulayi"
  53,32,"Balia beikalilanga okhukhola ebionono ebikhongo nende akeshifwabi, halali orwonono orutiti titi, Toto Nyasaye wuwo obulesheli bwe nobuunji, Ye abamanyile muno, olwa yabaloonga okhurula khuliloba , nende ngamwali mutsinda tsia banyinenywe, kho muleelole tawe, Ye amanyile muno owamuria"
  53,33,Koo! Walolakhwo ulia ufutariranga
  53,34,Nayinia shitutu mana niyemana
  53,35,"koo akhali nende obumanyi khu kefisile, mana alolanga"
  53,36,Nohomba shiyabolelwakhwo khukali mubitabu bia Musa
  53,37,Nende Ibrahim wosia indache
  53,38,Mbu Omundu shalichinga tsimbi tsiowashie tawe
  53,39,Ne Omundu shalinyoola halali kalia kayakhola
  53,40,Ne toto ebikhole bibie bililolekha
  53,41,Mana alirungwa omurungo kukwe kwosi
  53,42,Ne toto khu Nyasaye wuwo niwo akaliweela
  53,43,Ne toto niye ureranga okhutsekha nende okhulila
  53,44,Naye toto niye owufwisinjia nende ulamusinjia
  53,45,Ne toto ye niye waloonga eshisatsa nende eshikhasi
  53,46,Okhurulana nende imwo yolwibulo nimitswa
  53,47,Netoto mbu kali khuye okhulamusibwa khandi
  53,48,"Naye\tniye\tuyindiasinjia\tnende uhelasinjia"
  53,49,"Naye\tniye\tNyasaye\tOmuleli wetsing’ining’ini tsia (shiira)"
  53,50,Naye niye wasishia A’ad beimbeli
  53,51,Nende Tsamudi shibalekhwa tawe
  53,52,"Nende Abandu ba Nuhu abaliho imbeli, Toto bali ababii muno ebitsimbi po"
  53,53,"Nende tsingongo tsiakalukhanibwa, niye watsikalukhania"
  53,54,Nitsifuunikhwa nende biatsifuunikha
  53,55,Mana nitsimbabaasi shina tsia Nyasaye wuwo tsiokanakananga
  53,56,"Uno ni omwikanyilisi, mubekanyilisi beyimbeli"
  53,57,Inyanga yeyindukho ilihambi
  53,58,Owumao wakhaibuula owulali Nyasaye
  53,59,"Ne\tamakhuwa\tkano nikamwisundushilanga"
  53,60,Ne mutsekhanga ne shimulilanga tawe
  53,61,Nanyu muli mubukoyani
  53,62,Ne musujudile Nyasaye ne mumulaame