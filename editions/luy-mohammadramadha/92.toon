quran[21]{c,v,t}:
  92,1,Nditsuba khu shilo olwashifunikhanga
  92,2,Nende olwe eshiteere shilolekhanga
  92,3,"Nende\tkhuwaloonga\teshisatsa neshikhasi"
  92,4,Toto bwene okhukhalabana khwenyu khukabukhana
  92,5,Ne ulia urusia mana arie Omuloonji
  92,6,Mana nakhola kali amalayi
  92,7,Khwitsa okhumuwanguyisilia kabe amangu
  92,8,"Ne ulia ukhola obwimani, mana abule oluchendo na bashie"
  92,9,Mana nafuukula amalayi
  92,10,Khwitsa okhumuwanguyisilia kabe amasiro
  92,11,Ne omwandu kukwe kulimukhonya shina olwa aliba nasikhanga
  92,12,Toto bwene kali khu efwe okhwechesia obulunjifu
  92,13,Ne toto bwene kali khu efwe ka mutsuli (akhera) nende kokhuranjilila
  92,14,"Kho\tebekanyisilia\tkhumulilo kwakhanga"
  92,15,Shali kwinjilamwo halali ulia Omubii muno
  92,16,Ulia wafuukula mana nafutarira omukongo
  92,17,Ne ulia waria Nyasaye alireebwa ehale ninakwo
  92,18,ulia Urusinjia omwandu kukwe khulwo khwitswenula
  92,19,Ne shikali mbu aliho yesi yesi wamukholela amalayi lano khamurunje
  92,20,Halali nokhukhaaba obulekhule bwa Nyasaye wuwe Omulesi Owoluyali
  92,21,Naye yakhachame