quran[64]{c,v,t}:
  84,1,Olwelikulu liliarukha
  84,2,"Ne olwa liliwulila Nyasaye walio, shingala lialachilwa okhumuwulila"
  84,3,Olwe liloba lilikwalaasibwa
  84,4,Mana liarusia biosi bilimwo liaba likhaya
  84,5,"Ne olwa liliwulila Nyasaye walio, shingala lialachilwa okhumuwulila"
  84,6,"Ewe Omundu! Toto ewe oleeminjia eshinani shishio okhulolana nende Nyasaye wuwo Omulesi, mana Olimunyoola"
  84,7,Ne ulia owulihebwa eshitabu shishie no mukhono kukwe omulunji
  84,8,Kho oyo okhubalwa khukhwe khuliba okhwangu
  84,9,Ne alikalushila Abandu bebe nali nomwikhoyo
  84,10,Ne ulia ulihelesibwa eshitabu shishie namukongo wuwe
  84,11,Kho oyo alisaba okhulala
  84,12,Ne ilinjila mumulilo
  84,13,Toto ye yali mubandu be nali nomwikhoyo
  84,14,Toto ye yaparanga mbu shalikalukha khandi tawe
  84,15,"Kali mbu, toto bwene Nyasaye wuwe Omulesi yamulolanga"
  84,16,Ne nditsuba khubwakhanyu bweliuba nilitsia okhukwa
  84,17,Nende khushilo nende shia shibuusinjia
  84,18,Nende khu Omwesi shingala kukhongoyanga
  84,19,Toto bwene mwitsa okhunina eshisia khu khushisia
  84,20,Bali barie abalasuubilanga
  84,21,Ne nibasoomelwa Ikurani shibasujudanga tawe
  84,22,Halali balia abakhaya bayingananga butswa
  84,23,Ne Nyasaye amanyile kabenya okhukhola
  84,24,Kho basuubisie eshinyasio eshilulu
  84,25,"Halali balia basuubila mana nibakhola amalayi, abo baliba nende umurungo kulawa tawe"
  85,1,Nditsuba khu likulu lie tsing’ining’ini
  85,2,Nende khuinyanga yalakwa
  85,3,Nende khumuloli nende shikholelwa obuloli
  85,4,Basishibwa Abandu bethingoba
  85,5,Omulilo kwe tsikhwi tsinyinji
  85,6,Olwabali nibekhale awo(khumulilo)
  85,7,Nabo nibo abaloli khu kalia kabakholelanga Abasuubili
  85,8,Nabo shibalolakhwo khubo obubii bwosi bwosi tawe habula okhusuubila khwabu khu Nyasaye Owamani Owa oluyali
  85,9,Uli nende obwami bwo mwikulu nende khushialo ne Nyasaye nomuloli wabuli eshindu
  85,10,"Toto balia bakhoba Abasuubili Abasatsa nende Abasuubili Abakhasi mana nibalekanila , balinyoola ishinyasio shiomulilo ne balinyoola eshinyasio eshiokhusambwa"
  85,11,"Toto bwene balia basuubila mana nibakhola amalayi balinyoola emikunda chiburangamwo imialo, ne okho nikho okhubura okhukhongo"
  85,12,Toto bwene eshinyasio shia Nyasaye wuwo neshilulu
  85,13,"Toto ye aranjilisinjia\tkhandi niye ukalusinjia"
  85,14,naye niwobulesheli owobuyanzi muno
  85,15,Oweshifumbi shioluyali
  85,16,uwukholanga muno akayenya
  85,17,Koo! Wawulilakhwo olukano lwabalwani be liyie
  85,18,Aba Firauni nende Thsamudi
  85,19,halali abakhayi bali mukhuyingasia butswa
  85,20,Ne Nyasaye yababotokhana munyuma mwabu
  85,21,Halali ino ni Ikurani yoluyali
  85,22,Ili khulupao lwalindwa
  86,1,Nditsuba khulikulu nende shokhwitsa eshilo
  86,2,Ne nishina eshikhumanyia mbu nishina esho shitsanga eshilo
  86,3,Ing’ining’ini yili nende obulafu obunji
  86,4,Buli shiamundu ali nende umuhenganga
  86,5,Ne Omundu ahenge yalongwa okhurulana nende shina
  86,6,"Yalongwa\tokhurulana\tkhu\tmatsi karulanga nikamitsikha"
  86,7,Karulanga hakarikari mulukongofuma nende omukongo
  86,8,Toto bwene Nyasaye ali nende obunyali bwokhumukalusia
  86,9,Inyanga ya kalia kefisa kalirebwa habulafu
  86,10,Abwene aho shaliba nende amani nohomba Omuhabini tawe
  86,11,"Nditsuba\tkhulikilu\tlili\tnende amakalushilo"
  86,12,Nende liloba liarukhanga
  86,13,"Toto\tbwene\tlino\tnilikhuwa lwokhwawukhasia"
  86,14,Nalio shilili emibayo tawe
  86,15,Toto bwene abo batutanga bututa
  86,16,Na siesi ndamanya obututi bwabu po
  86,17,Mana bahelesie ebise abakhayi- kaala kaala