quran[82]{c,v,t}:
  100,9,Kho koo akorerwe olwa abali mubilindwa balilamusibwa mubafuu
  100,10,Ne kalikhung’asibwa akali mubilifu
  100,11,Toto Nyasaye wabu Omulesi inyanga eyo aliba nende amakhuwa kabu boosi
  101,1,Eshikhong’ondanga
  101,2,Nishina shikhong’ondanga
  101,3,Ne nishiina shilakhumanyia mbu nishina shikhong’ondanga
  101,4,"Inyanga\tyabandu\tbaliba\tshinga tsimburukuru tsisaalanibwe"
  101,5,Ne tsinguli tsiliba shinga ipamba isakhululwe
  101,6,Kho ulia weshichelo shishie shiliba eshisiro
  101,7,Oyo aliba mubulamu buchamisia
  101,8,Ne ulia weshichelo shishie shiliba eshiangu
  101,9,Oyo eshimenyo shishie shiliba mumulilo kwa Hawiya
  101,10,Ne nishina shikhumanyisia mbu nishina esho
  101,11,Ni omulilo omukhongo
  102,1,Okhukonya ebinji khubakoyaniyie
  102,2,Okhula mulile mutsing’ani
  102,3,Shikali kario tawe! Mulitsa okhumanya
  102,4,Mana khandi shikali kario tawe! Mulitsa okhumanya
  102,5,Shikali kario tawe! Mumanyangakhwo amachesi katoto
  102,6,Toto bwene mulilola Jahannam
  102,7,Mana khandi toto bwene muliyilola nende imoni yatoto
  102,8,Mana khandi toto mulirebwa inyanga eyo okhulondokhana nende obwokholo
  103,1,Nditsuba khubise
  103,2,"Toto bwene omundu ali mu khusikha, (abula inganga)"
  103,3,"Halali balia basuubila, mana nibakhola amalayi , nenibaboolanila okhwema khubwatoto, nende okhwifwiila"
  104,1,Eshinyasio eshikhongo shilinyoola buli ulia wokhutiabukha omumoonyi
  104,2,Ulia wabunjelesia omwandu mana nakubala
  104,3,"Aparanga\tmbu\tomwandu\tkukwe kulimutonyia tsinyanga tsiosi"
  104,4,Shikali kario tawe! Ali khwesululwa niyenjisibwa mu Hutwama
  104,5,Ne nishina shilakhwechesia mbu Hutwama nishina
  104,6,Ni omulilo kwa Nyasaye okwawafibwa
  104,7,Ukuninanga khumioyo
  104,8,toto oko baliboyelwamwo
  104,9,Khutsisiilo tsiakololokha
  105,1,Koo shiwalolakhwo shinga Nyasaye wuwo Omulesi yakholaAbandu beyinzofu balia
  105,2,Shiyakhola ebifwanga biabu biabiiya
  105,3,Mana nabarumila amayoni emikanda nemikanda
  105,4,Mana nikabalasila amachina keliloba liomumulilo
  105,5,"Mana\tnabakhola\tshinga\tobunyasi bunyanyanyilwe"
  106,1,Khulwa omunalo kwabakuraish
  106,2,Okhunala khwabu tsinjendo tsieyirotso nende tseshirumbi
  106,3,Khomana balaame Nyasaye wabu Omulesi owe Inzu ino
  106,4,"Ulia Ubaliisinjia balanyoola inzala tawe, mana nabaliinda okhurulana nende oburi"
  107,1,Koo! olutsikhwo ulia ukananga umurungo kwe inyanga ye indukho
  107,2,Ni ulia uluumanga (usindikhanga) Omwana umufwilwa
  107,3,Nohomba shakholangakhwo eshinani shokhulisia umutakha tawe
  107,4,"Oooh, eshinyasio eshikhongo khubalia balaamanga"
  107,5,Balia beyibilisinjia okhulaama khwabu
  107,6,Balia belolosinjia
  107,7,Ne bekalilanga obukhonyi
  108,1,Toto khwakhuhelesia obulayi obunji
  108,2,kho laama ne osinze khulwa Nyasaye wuwo Omulesi
  108,3,toto ulia okhusila niye ulabiyilibwa
  109,1,"Boola: “Enywe Abakhayi"
  109,2,Shelaamanga shiamulaamanga tawe
  109,3,"Nohomba\tenywe\tshimulaamanga Owelaamanga tawe"
  109,4,Nohomba shindililaama shiamulaamanga tawe
  109,5,"Nohomba\tenywe\tshimulaamanga owelaamanga tawe"
  109,6,"Enywe muli nende idini yenyu, nasi endi nende idini yanje.”"
  110,1,Olwa obuhabini bwa Nyasaye nende obwikuli buliitsa
  110,2,Ne nolola Abandu nibenjila mudini ya Nyasaye mumikanda
  110,3,"Awo ofumie oluyali lwa Nyasaye wuwo, ne omusabe eshileshelo, toto bwene niye Omulesheli muno"
  111,1,"Chiasikha emikhono chibili chiaa Abu Lahab, mana nasikha"
  111,2,Omwandu kukwe shikulimukhoonya tawe nohomba ebiayakhalabanila
  111,3,Aliinjila mumulilo kupupuchila
  111,4,Nende Omukhasi wuwe omuchinji wetsikhwi
  111,5,Mwikosi mumwe alirebwamwo omukoye kwaborolwa
  112,1,"Boola mbu: “ye ni Nyasaye mulala yenyene.”"
  112,2,Nyasaye owisikungwa
  112,3,shiyebula nohomba shiyebulwa tawe
  112,4,Ne abulaho ufwanana ninaye kata mulala
  113,1,"Boola : “ndilinda khu Nyasaye Omulesi owa mabwibwi,”"
  113,2,Okhurulana nende obusuku obwa bilia ebiayaloonga
  113,3,Nende obusuku bweshilima shieshilo olwashinjilanga
  113,4,Nende okhurulana khu obusuku bwabalia bafuririranga amafundikho
  113,5,"Nende khu obusuku\tbwa weyishinda olwaba nakhola eshikhalikhali"
  114,1,"Bola: “ndiliinda khu Nyasaye Omuliindi wa Abandu”"
  114,2,Omwami wa Abandu
  114,3,Nyasaye wa Abandu
  114,4,Okhurulana nende obusuku bwo buyendi bwashetani..khefisanga
  114,5,Kharetsanga obuyendi mubilifu bia Abandu
  114,6,Okhurulana mu Majini nende Abandu