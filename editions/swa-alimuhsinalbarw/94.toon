quran[8]{c,v,t}:
  94,1,Hatukukunjulia kifua chako
  94,2,Na tukakuondolea mzigo wako
  94,3,Ulio vunja mgongo wako
  94,4,Na tukakunyanyulia utajo wako
  94,5,Basi kwa hakika pamoja na uzito upo wepesi
  94,6,Hakika pamoja na uzito upo wepesi
  94,7,"Na ukipata faragha, fanya juhudi"
  94,8,Na Mola wako Mlezi ndio mshughulikie