quran[38]{c,v,t}:
  56,1,O gerçek olan kıyamet gerçekleşince neler olacak neler
  56,2,Zaten onun olmasını yalanlayacak hiçbir delil olamaz
  56,3,"O kimini alçaltır, kimini yüceltir"
  56,4,Yer şiddetle sarsıldığı
  56,5,Dağlar darmadağın edilip parçalandığı
  56,6,Uçuşan toz zerreleri haline geldiği zaman
  56,7,Sizler de üç sınıfa ayrılırsınız
  56,8,Ashab-ı yemin ki ne ashab-ı yemin! Ne mutludur onlar
  56,9,Ashab-ı şimal ki ne ashab-ı şimal! Ne bedbahttır onlar
  56,10,"İmanda, fazilette öncüler ki ne öncüler! Onlar herkesi geçerler"
  56,11,İşte onlardır Allah'a en yakın olanlar. Naîm cennetlerindedir onlar
  56,12,İşte onlardır Allah'a en yakın olanlar. Naîm cennetlerindedir onlar
  56,13,"Çoğu önceki ümmetlerden, biraz da sonrakilerden"
  56,14,"Çoğu önceki ümmetlerden, biraz da sonrakilerden"
  56,15,Mücevheratla işlenmiş tahtlara yaslanarak karşılıklı otururlar
  56,16,Mücevheratla işlenmiş tahtlara yaslanarak karşılıklı otururlar
  56,17,"Etraflarında, cennet şarabından dolu testiler, sürahiler, kadehlerle, ebedîliğe ermiş çocuklar dolaşıp hizmet ederler"
  56,18,"Etraflarında, cennet şarabından dolu testiler, sürahiler, kadehlerle, ebedîliğe ermiş çocuklar dolaşıp hizmet ederler"
  56,19,"Bu içkiden ötürü baş ağrısı çekmezler, sarhoş da olmazlar"
  56,20,Bir de... tercih edecekleri meyveler
  56,21,Canlarının istediği kuş etleri
  56,22,Ve gün görmemiş saklı inciler gibi güzel eşler
  56,23,Ve gün görmemiş saklı inciler gibi güzel eşler
  56,24,Bütün bunlar dünyada yaptıkları güzel işlere mükâfat olarak verilecek
  56,25,"Onlar cennette ne boş bir söz, ne de günaha sokan bir laf işitmezler"
  56,26,"İşittikleri söz, hep: “Selâm! selâm!” sesleridir"
  56,27,Ashab-ı yemin ki ne ashab-ı yemin! Ne mutludur onlar
  56,28,Dalbastı kirazlar
  56,29,Dolgun salkımlı muzlar
  56,30,Yayılmış gölgeler
  56,31,Şarıl şarıl akan sular
  56,32,"Tükenmeyen, eksilmeyen, hiçbir surette esirgenmeyen birçok meyveler içindedirler"
  56,33,"Tükenmeyen, eksilmeyen, hiçbir surette esirgenmeyen birçok meyveler içindedirler"
  56,34,"Onlara, pek değerli eşler de verdik. Biz o eşleri, yepyeni bir yaratılışla yaratıp, sûret ve sîretlerini son derece güzelleştirdik"
  56,35,"Onlara, pek değerli eşler de verdik. Biz o eşleri, yepyeni bir yaratılışla yaratıp, sûret ve sîretlerini son derece güzelleştirdik"
  56,36,"Böylece onları, ashab-ı yemin için bakire kızlar, kocalarına âşık yaşıtlar kıldık"
  56,37,"Böylece onları, ashab-ı yemin için bakire kızlar, kocalarına âşık yaşıtlar kıldık"
  56,38,"Böylece onları, ashab-ı yemin için bakire kızlar, kocalarına âşık yaşıtlar kıldık"