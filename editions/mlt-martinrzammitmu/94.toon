quran[8]{c,v,t}:
  94,1,"Jaqaw ma wessajnilekx sidrek (Muħammad, bit-twemmin ti bit-tmexxija t-tajba)"
  94,2,u warrabna minnek it-toqol tiegħek (iera ħfirnielek in- nuqqasijiet tiegħek)
  94,3,litaqqal dahrek
  94,4,u għollejnielek ġieħek
  94,5,Tabilħaqq li mas-saram jiġi l-faraġ
  94,6,"tassew, mas-saram jiġi l-faraġt"
  94,7,"U meta ttemm (it-tixrid tal-kelma), ħabrek (fil-qima ta' Alla)"
  94,8,ugħal Sidek ixxennaq