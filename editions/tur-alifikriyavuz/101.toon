quran[11]{c,v,t}:
  101,1,(Dehşetiyle kalblere çarpacak) o kıyamet
  101,2,Nedir o kıyamet
  101,3,"Ne bildirdi sana, nedir o kıyamet"
  101,4,"O gün insanlar, çırpınıp yayılan kelebekler (pervaneler) gibi olacak"
  101,5,Dağlar da atılmış renkli yünler gibi olacak
  101,6,"İşte o vakit, kimin tartıları (iyilikleri) ağır gelmişse"
  101,7,"Artık o, hoşnud bir hayattadır"
  101,8,Fakat kimin de tartıları (iyilikleri) hafif gelmişse
  101,9,Artık onun yeri Haviye’dir
  101,10,Bildin mi Haviye nedir
  101,11,"O, kızgın bir ateştir"