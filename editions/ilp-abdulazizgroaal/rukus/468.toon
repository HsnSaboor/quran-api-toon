quran[33]{c,v,t}:
  55,46,"Na adun a bagiyan o tao a inikaluk iyan so kapakatindug iyan ko Hadapan o Kadnan Niyan, a dowa a Sorga"
  55,47,"Na anda ko manga Limo o Kadnan niyo, ı Pagongkirun niyo"
  55,48,A romarangiran
  55,49,"Na anda ko manga Limo o Kadnan niyo, 1 Pagongkirun niyo"
  55,50,Katatagowan a dowa oto sa dowa a bowalan a puphamangondas
  55,51,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,52,"Katatagowan a dowa oto sa mbarambarang a Onga, a ndo-dowa soson"
  55,53,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,54,"Gi-i siran shasandasandang ko manga iga-an, a so manga didalum iyan na sotra a ma-Ķapal: Na so Kaphuropowa ko Onga o dowaa Pamomolan na marani"
  55,55,"Na anda ko manga Limo oKadnan niyo, i Pagongkirun niyo"
  55,56,"Katatagowan noto sa (manga bai a) manga thatangka 1i kailai, a da-a miyakabatal kiran a Manosiya ko ona an o manga Karoma iran, antawa-a Jinn"
  55,57,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,58,"Lagid o ba siran Montiya a Ya-akot, go Marjian"
  55,59,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,60,Ba adun a imbalas ko kaphiyapiya a rowar ko kaphiyapiya
  55,61,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,62,Na adun a salakao ro-o pun a dowa Sorga
  55,63,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,64,Miyagado gadong a dowa oto
  55,65,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,66,"Katatagowan a dowa oto sa dowa a bowalan, a mipapantos"
  55,67,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,68,"Katatagowan a dowa oto sa manga Onga, go Qormah, go Dalima"
  55,69,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,70,"Katatagowan noto sa (manga bai a) manga pipiya (i parangai), a manga tataid"
  55,71,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,72,"A manga lalano, a Khigigibonun ko manga lamin"
  55,73,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,74,"Da-a miyakabatal kiran a Manosiya, ko ona-an o manga Karoma iran, antawa-a Jinn"
  55,75,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,76,"Gi-i siran shasandasandang ko manga ontoda, a gadong, go manga paramadali, a manga tatanos"
  55,77,"Na anda ko manga Limo o Kadnan niyo, i Pagongkirun niyo"
  55,78,"Maporo so ngaran o Kadnan Ka, a khiruk ko kabusaran, a go so Kapangalimo"