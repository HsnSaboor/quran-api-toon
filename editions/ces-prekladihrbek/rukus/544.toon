quran[8]{c,v,t}:
  102,1,Vy rádi v rozmnožování jmění soupeříte
  102,2,pokud hroby nenavštívíte
  102,3,Však pozor! Brzy poznáte
  102,4,A znovu pozor! Brzy poznáte
  102,5,Však pozor! Kéž zřetelným poznáním poznáte
  102,6,a věru oheň planoucí uzříte
  102,7,a potom vskutku okem jistým jej spatříte
  102,8,a posléze v ten den na blahobyt tázáni budete