quran[6]{c,v,t}:
  114,1,"Vuga (yewe Muhamadi) uti “Niragije (Allah), Nyagasani w’abantu,”"
  114,2,"“Umwami w’abantu,”"
  114,3,"“Imana y’abantu,”"
  114,4,"“Ngo andinde ububi bwa (shitani) yoshya gukora ibibi, nyuma ikabireka (igihe umuntu yibutse Allah),”"
  114,5,“Yoshya imitima y’abantu gukora ibibi; ”
  114,6,“Yaba (shitani) yo mu majini cyangwa mu bantu.”