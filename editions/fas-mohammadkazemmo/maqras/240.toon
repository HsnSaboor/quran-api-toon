quran[82]{c,v,t}:
  100,9,پس آیا نداند گاهی که انگیخته شود آنچه در گورها است‌
  100,10,و فراهم شود آنچه در سینه‌ها است‌
  100,11,که پروردگار ایشان است بدیشان آگاه‌
  101,1,آن کوبنده‌
  101,2,چیست کوبنده‌
  101,3,و چه دانستت چیست کوبنده‌
  101,4,روزی که شوند مردم چون پروانه‌های پراکنده‌
  101,5,و شوند کوه‌ها مانند پشم زده‌
  101,6,پس اما آنکه سنگین آید سنجشهایش (ترازوهایش)
  101,7,پس او است در زندگی پسندیده‌
  101,8,و اما آنکه سبک گردد ترازوهایش‌
  101,9,پس مادر اوست هاویه‌
  101,10,و ندانستت چیست آن‌
  101,11,آتشی است سوزنده‌
  102,1,بفریفت شما را (سرگرم ساخت) فزونی جستن‌
  102,2,تا رسیدید به گورستان‌
  102,3,نه چنین است زود است بدانید
  102,4,پس نه چنین است زود است بدانید
  102,5,نه چنین است اگر بدانید دانستن یقین‌
  102,6,هر آینه ببینید البته دوزخ را
  102,7,سپس ببینیدش البته عین یقین (یقین نمایان)
  102,8,سپس پرسش شوید همانا در آن روز از نعمتها
  103,1,سوگند به عصر (روزگار بازپسین)
  103,2,که همانا انسان است در زیانکاری‌
  103,3,مگر آنان که ایمان آوردند و کردار شایسته کردند و سفارش کردند به حقّ (به درستی) و سفارش کردند به شکیب‌
  104,1,وای بر هر نکوهشگری عیب‌جوی‌
  104,2,آنکه گردآورد مالی را و شمردش‌
  104,3,پندارد که مالش جاودان داردش‌
  104,4,نه چنین است همانا انداخته شود در حُطَمه‌
  104,5,و ندانستت چیست حُطَمه‌
  104,6,آتش خدای افروخته‌
  104,7,که چیره گردد بر دلها
  104,8,همانا آن است بر ایشان افروخته (یا پوشیده)
  104,9,در ستونهای کشیده‌
  105,1,آیا ندیدی چه کرد پروردگار تو به یاران (یا خداوندان) فیل‌
  105,2,آیا نگردانید نیرنگ آنان را در گم‌گشتگی‌
  105,3,و فرستاد بر ایشان مرغانی گروه گروه‌
  105,4,می‌افکندند بر ایشان (پرتاب می‌کردند) سنگی را از سجّیل‌
  105,5,پس گردانیدشان مانند خوشه (یا برگی) خورده‌شده‌
  106,1,برای جان دادن (یا الفت‌گرفتن) قریش‌
  106,2,الفت ایشان به کوچیدن زمستان و تابستان‌
  106,3,پس باید پرستش کنند پروردگار این خانه را
  106,4,که خورانیدشان پس از گرسنگی و ایمنشان ساخت پس از ترس‌
  107,1,آیا دیدی آن را که تکذیب کند به دین‌
  107,2,پس آن است که می‌راند یتیم را
  107,3,و ترغیب نکند بر خوراک بینوا
  107,4,پس وای بر نمازگزاران‌
  107,5,آنان که از نماز خویشند غفلت‌کنندگان‌
  107,6,آنان که خودنمائی کنند
  107,7,و بازدارند زکات را (یا خیر را)
  108,1,همانا ارزانی داشتیمت کوثر
  108,2,پس نمازگزار برای پروردگار خویش و قربان کن (یا سجود و رکوع کن)
  108,3,همانا بدخواه تو است دنباله‌بریده‌
  109,1,بگو ای گروه کافران‌
  109,2,نپرستم آنچه را پرستید
  109,3,و نه شما پرستندگانید آنچه را پرستم‌
  109,4,و نه منم پرستنده آنچه پرستش کردید
  109,5,و نه شما پرستندگانید آنچه را پرستم‌
  109,6,شما را است دینتان و مرا است دینم‌
  110,1,گاهی که آید یاری خدا و پیروزی‌
  110,2,و بینی مردم را درآیند به دین خدا گروه گروه‌
  110,3,پس تسبیح گوی به سپاس پروردگار خویش و آمرزش خواهش که او است همانا آمرزگار
  111,1,بریده باد دستهای ابی‌لهب و بریده باد
  111,2,بی‌نیاز نکرد از او مالش و آنچه فراهم کرد
  111,3,زود است بچشد آتشی شعله‌ور
  111,4,و زن او بردارنده هیزم‌
  111,5,در گردنش بندی است از لیف خرما
  112,1,بگو او است خدای یکتا
  112,2,خداوند است صمد
  112,3,نه زائید و نه زاده شده‌
  112,4,و نبودش همتا کسی‌
  113,1,بگو پناه برم به پروردگار بامداد (شکاف صبح)
  113,2,از بدی آنچه آفرید
  113,3,و از بدی تاریکی گاهی که فراگیرد (یا فرورود)
  113,4,و از بدی زنان دمنده در گره‌ها
  113,5,و از بدی حسود گاهی که حسد ورزد
  114,1,بگو پناه به پروردگار مردم‌
  114,2,پادشاه مردم‌
  114,3,خدای مردم‌
  114,4,از بدی وسوسه‌کننده نهان شونده‌
  114,5,آنکه وسوسه کند در سینه‌های مردم‌
  114,6,از پریان و مردم‌