quran[856]{c,v,t}:
  26,1,طسم‌
  26,2,این است آیتهای کتاب روشن‌
  26,3,شاید ببازی تو جان خویش را چرا نیستند مؤمنان‌
  26,4,اگر بخواهیم بفرستیم بر ایشان آیتی از آسمان پس بگردد گردنهاشان پیش آن فروتنان‌
  26,5,و نیایدشان یادآوریی از خدای مهربان نوینی مگر آنکه باشند از آن روگردانان‌
  26,6,همانا تکذیب کردند پس زود هست بیایدشان داستانهای آنچه بودند بدان استهزاکنان‌
  26,7,آیا ننگرند بسوی زمین چه فراوان رویانیدیم در آن از هر جفتی گرامی‌
  26,8,در این است هر آینه آیتی و نیستند بیشترشان ایمان‌آرندگان‌
  26,9,و همانا پروردگار تو است عزّتمند مهربان‌
  26,10,هنگامی که خواند پروردگار تو موسی را که برو به نزد گروه ستمگران‌
  26,11,قوم فرعون چرا پرهیزکاری نکنند
  26,12,گفت پروردگارا ترسم تکذیبم کنند
  26,13,و تنگ شود سینه‌ام و روان نگردد زبانم پس بفرست بسوی هارون‌
  26,14,و ایشان را است بر من گناهی و ترسم مرا بکشند
  26,15,گفت نه چنین است بروید شما هر دو به آیتهای ما که مائیم با شما شنوندگان‌
  26,16,پس درآئید بر فرعون و بگوئید مائیم فرستاده پروردگار جهانیان‌
  26,17,که بفرست با ما بنی‌اسرائیل را
  26,18,گفت آیا نپروریدمت نزد ما به نوزادی و ماندی نزد ما از عمر خویش سالیانی‌
  26,19,و کردی کارت را آن را که کردی و بودی از ناسپاسان‌
  26,20,گفت کردمش آن هنگام و بودم من از گمراهان‌
  26,21,پس گریختم از شما گاهی که ترسیدمتان پس بخشید مرا پروردگار من فرمانی و گردانیدم از پیمبران‌
  26,22,و این نعمتی است که منّتش را بر من نهی که بنده گرفتی بنی‌اسرائیل را
  26,23,گفت فرعون و چیست پروردگار جهانیان‌
  26,24,گفت پروردگار آسمانها و زمین و آنچه میان آنها است اگر هستید یقین‌دارندگان‌
  26,25,گفت بدانان که در پیرامونش بودند آیا نمی‌شنوید
  26,26,گفت پروردگار شما و پروردگار پدران شما پیشینیان‌
  26,27,گفت همانا پیمبر شما که فرستاده شده است بسوی شما هر آینه او است دیوانه‌
  26,28,گفت پروردگار خاور و باختر و آنچه میان آنها است اگر هستید خردمندان‌
  26,29,گفت اگر بگرفتی خدائی جز من هر آینه بگردانمت از زندانیان‌
  26,30,گفت و اگر چه بیارمت چیزی آشکار
  26,31,گفت پس بیارش اگر هستی از راستگویان‌
  26,32,پس افکند چوبدست خود را ناگهان آن است اژدری نمایان‌
  26,33,و برآورد دست خود را ناگهان آن است پرتوی برای بینندگان‌
  26,34,گفت بدان گروه که در گردش بودند همانا این است جادوگری دانشمند
  26,35,خواهد برون کند شما را از سرزمین شما به جادوی خویش تا چه فرمان دهید
  26,36,گفتند نگهدار او و برادرش را و بفرست در شهرستانها گردآورندگان‌
  26,37,تا بیارندت بهر جادوگری دانشمند
  26,38,پس گرد آورده شدند جادوگران برای وعده‌گاه روزی شناخته‌
  26,39,و گفته شد به مردم آیا شمائید گردآیندگان‌
  26,40,شاید پیروی کنیم جادوگران را اگر بودند پیروزمندان‌
  26,41,پس هنگامی که آمدند جادوگران گفتند به فرعون آیا ما را است مزدی اگر شدیم پیروزمندان‌
  26,42,گفت آری و همانا شمائید در آن هنگام از نزدیکان‌
  26,43,گفت بدیشان موسی بیفکنید آنچه را شمائید افکنندگان‌
  26,44,پس بیفکندند ریسمانها و چوبهای خود را و گفتند به فَر فرعون مائیم همانا پیروزمندان‌
  26,45,پس افکند موسی چوبدست خویش را ناگهان فروبرد آنچه را به دروغ آوردند
  26,46,پس بیفتادند جادوگران سجده‌کنان‌
  26,47,گفتند ایمان آوردیم به پروردگار جهانیان‌
  26,48,پروردگار موسی و هارون‌
  26,49,گفت ایمان آوردید بدو پیش از آنکه دستورتان دهم همانا او بزرگ شما است که آموخت به شما جادوگری را پس زود است بدانید همانا سخت ببرّم دستها و پایهای شما را از برابر و هر آینه به دارتان کشم همگی‌
  26,50,گفتند نیست باکی مائیم بسوی پروردگار خویش بازگشتگان‌
  26,51,همانا امیدواریم بیامرزد برای ما پروردگار ما گناهان ما را که بودیم نخستین ایمان‌آرندگان‌
  26,52,و وحی کردیم به موسی که شبانه بر بندگانم را همانا شمائید پیروی شدگان‌
  26,53,پس فرستاد فرعون در شهرستانها گردآرندگان‌
  26,54,که اینانند همانا گروهی اندک‌
  26,55,و همانا ایشانند بر ما خشم‌آرندگان‌
  26,56,و هر آینه مائیم همگی بیمناکان‌
  26,57,پس برون راندیمشان از باغها و چشمه‌سارها
  26,58,و گنجها و جایگاهی گرامی‌
  26,59,بدینسان و ارث دادیمش به بنی‌اسرائیل‌
  26,60,پس از پی ایشان بیامدند به هنگام خورشید تابان‌
  26,61,تا گاهی که نمودار شدند (دیدار کردند) دو گروه گفتند یاران موسی که مائیم دریافتگان‌
  26,62,گفت نچنین است همانا با من است پروردگارم زود است رهبریم کند
  26,63,پس وحی کردیم به موسی که بزن چوبدست خود را به دریا پس بشکافت و شد هر دیواری چون کوهی بزرگ‌
  26,64,و جای دادیم در آنجا دگران را
  26,65,و رهانیدیم موسی و آنان را که با او بودند همگی‌
  26,66,سپس به دریا فروبردیم دگران را
  26,67,همانا در این است آیتی و نیستند بیشترشان ایمان آرندگان‌
  26,68,و همانا پروردگار تو است هرآینه عزّتمند مهربان‌
  26,69,و بخوان بر ایشان داستان ابراهیم را
  26,70,هنگامی که گفت به پدر خویش و قومش چه می‌پرستید
  26,71,گفتند می‌پرستیم بتانی را پس می‌باشیم پیرامون آنها گردآمدگان‌
  26,72,گفت آیا می‌شنوند شما را گاهی که می‌خوانید
  26,73,یا سودتان بخشند یا آیان رسانند
  26,74,گفتند بلکه یافتیم پدران خود را چنین می‌کردند
  26,75,گفت آیا دیدید آنچه را بودید می‌پرستیدید
  26,76,شما و پدران شما پیشتران‌
  26,77,که ایشان مرا دشمنند مگر پروردگار جهانیان‌
  26,78,آنکه مرا آفرید پس رهبریم کند
  26,79,و آنکه بخوراندم و بنوشاندم‌
  26,80,و گاهی که بیمار شوم پس او بهبودیم دهد
  26,81,و آنکه بمیراندم سپس زنده سازدم‌
  26,82,و آنکه امیدوارم که بیامرزد برای من گناهم را روز دین‌
  26,83,پروردگارا ارزانی دار مرا حُکمی و برسانم به شایستگان‌
  26,84,و قرار ده برای من زبان راستی در آخران‌
  26,85,و بگردانم از ارث‌برندگان بهشت نعمتها
  26,86,و بیامرز برای پدرم که او بود همانا از گمراهان‌
  26,87,و خوارم نکن روزی که برانگیخته شوند
  26,88,روزی که سود ندهد مال و نه فرزندان‌
  26,89,مگر آنکه بیاید خدا را با دلی درست‌
  26,90,و آماده شد بهشت برای پرهیزکاران‌
  26,91,و پدید آورده شد دوزخ برای گمراهان‌
  26,92,و گفته شد بدیشان کجا بودید می‌پرستیدید
  26,93,جز خدا را آیا یاری کنند شما را یا یاری جویند
  26,94,پس به روی افکنده شدند در آن ایشان و گمراهان‌
  26,95,و سپاه‌های ابلیس همگان‌
  26,96,گفتند و ستیزه می‌کردند در آن‌
  26,97,سوگند به خدا همانا بودیم ما در گمراهی آشکار
  26,98,هنگامی که یکسان داشتیم شما را با پروردگار جهانیان‌
  26,99,و گمراه نکردند ما را مگر گنهکاران‌
  26,100,پس نیست ما را شفاعت‌گرانی‌
  26,101,و نه دوستی مهربان‌
  26,102,کاش ما را بازگشتی بودی تا می‌شدیم از مؤمنان‌
  26,103,همانا در این است آیتی و نیستند بیشتر ایشان ایمان‌آرندگان‌
  26,104,و همانا پروردگار تو او است عزّتمند مهربان‌
  26,105,تکذیب کردند قوم نوح فرستادگان را
  26,106,هنگامی که گفت بدیشان برادرشان نوح چرا پرهیزکاری نکنید
  26,107,همانا منم برای شما فرستاده‌ای امین‌
  26,108,پس بترسید خدا را و مرا فرمان برید
  26,109,و نپرسمتان بر آن مزدی نیست مزد من جز بر پروردگار جهانیان‌
  26,110,پس بترسید خدا را و مرا فرمان برید
  26,111,گفتند آیا ایمان آوریم برایت و پیرویت کردند فرومایگان‌
  26,112,گفت چه دانائی است مرا بدانچه بودند می‌کردند
  26,113,نیست حسابشان جز بر پروردگار من اگر دریابید
  26,114,و نیستم من دورکننده مؤمنان‌
  26,115,نیستم من جز ترساننده آشکار
  26,116,گفتند اگر دست برنداری ای نوح هرآینه بشوی از سنگسارشدگان‌
  26,117,گفت پروردگارا همانا قومم تکذیبم کردند
  26,118,پس بگشای میان من و ایشان گشایشی و برهانم و آنان را که با منند از مؤمنان‌
  26,119,پس رهانیدیمش و آنان که با او بودند در کشتی پرشده‌ای‌
  26,120,سپس غرق کردیم پس از این بازماندگان را
  26,121,همانا در این است آیتی و نیستند بیشترشان مؤمنان‌
  26,122,و همانا پروردگار تو است عزّتمند مهربان‌
  26,123,تکذیب کردند عاد فرستادگان را
  26,124,هنگامی که گفت بدیشان برادرشان هود چرا پرهیزکاری نکنید
  26,125,همانا منم برای شما فرستاده امین‌
  26,126,پس بترسید از خدا و مرا فرمان برید
  26,127,و نپرسمتان بر آن پاداشی نیست مزدم مگر بر پروردگار جهانیان‌
  26,128,آیا بنیاد می‌نهید به هر پشته‌ای نشانی بیهده بازی کنید
  26,129,و برگیرید کوشکهائی شاید شما جاودان مانید
  26,130,و هر گاه خشمگین شوید خشمگین شوید ستمگرانه‌
  26,131,پس بترسید خدا را و مرا فرمان برید
  26,132,و بترسید آن را که یاری کرده است شما را بدانچه می‌دانید
  26,133,کمک کرده است شما را به دامها و فرزندان‌
  26,134,و باغها و چشمه‌سارها
  26,135,همانا می‌ترسم بر شما از عذاب روزی بزرگ‌
  26,136,گفتند یکسان است بر ما چه اندرز دهی یا نباشی از اندرزگویان‌
  26,137,نیست این مگر این خوی پیشینیان‌
  26,138,و نیستیم ما عذاب‌شدگان‌
  26,139,پس تکذیبش کردند پس نابودشان ساختیم همانا در این است آیتی و نیستند بیشترشان مؤمنان‌
  26,140,و همانا پروردگار تو است عزّتمند مهربان‌
  26,141,تکذیب کردند ثمود فرستادگان را
  26,142,هنگامی که گفت بدیشان برادرشان صالح چرا پرهیز نکنید
  26,143,همانا منم برای شما فرستاده امین‌
  26,144,پس پرهیز کنید خدا را و مرا فرمان برید
  26,145,و پرسش نکنم شما را بر آن مزدی نیست مزد من مگر بر پروردگار جهانیان‌
  26,146,آیا رها می‌شوید در آنچه اینجا است آرمیدگان‌
  26,147,در باغها و چشمه‌سارها
  26,148,و کشتزارها و نخلستانهائی که شکوفه آنها است رسیده (یا گوارا)
  26,149,و می‌تراشید از کوه‌ها خانه‌هائی کامرانان‌
  26,150,پس بترسید خدا را و فرمانم برید
  26,151,و اطاعت نکنید از دستور اسراف‌کنندگان‌
  26,152,آنان که تبهکاری کنند در زمین و درست کاری نکنند (اصلاح نکنند)
  26,153,گفتند جز این نیست که توئی از جادوشدگان‌
  26,154,نیستی تو جز بشری همانند ما پس بیاور آیتی اگر هستی از راستگویان‌
  26,155,گفت این است اشتری برای آن آبشخوری و برای شما است آبشخور روزی دانسته‌
  26,156,و نگردید گردش به بدی که بگیرد شما را شکنجه روزی بزرگ‌
  26,157,پس پی کردندش پس بامداد کردند پشیمانان‌
  26,158,پس گرفت ایشان را عذاب همانا در این است آیتی و نیستند بیشترشان ایمان آرندگان‌
  26,159,و همانا پروردگار تو او است عزّتمند مهربان‌
  26,160,تکذیب کردند قوم لوط فرستادگان را
  26,161,گاهی که گفت بدیشان برادرشان لوط چرا پرهیزکاری نکنید
  26,162,همانا منم برای شما فرستاده امین‌
  26,163,پس بترسید خدا را و مرا فرمان برید
  26,164,و نپرسم شما را بر آن پاداشی نیست مزد من مگر بر پروردگار جهانیان‌
  26,165,آیا درآمیزید با نران از جهانیان‌
  26,166,و می‌گذارید آنچه را آفریده است برای شما پروردگار شما از همسران خویش بلکه شمائید گروهی تجاوزگران‌
  26,167,گفتند اگر بس نکنی ای لوط همانا شوی از برون‌راندگان‌
  26,168,گفت همانا منم کار شما را از رهاکنندگان‌
  26,169,پروردگارا برهان مرا و خاندانم را از آنچه می‌کنند
  26,170,پس نجاتش دادیم و خاندانش را همگی‌
  26,171,مگر پیرزنی در گذشتگان‌
  26,172,پس نگونسار کردیم دگران را
  26,173,و باریدیم بر آنان بارانی پس چه زشت است باران بیم‌دادگان‌
  26,174,همانا در این است آیتی و نیستند بیشترشان ایمان‌آرندگان‌
  26,175,و همانا پروردگار تو است عزّتمند مهربان‌
  26,176,تکذیب کردند یاران ایکه فرستادگان را
  26,177,هنگامی که گفت بدیشان شعیب چرا پرهیزکاری نکنید
  26,178,همانا منم شما را فرستاده‌ای امین‌
  26,179,پس بترسید خدا را و فرمانم برید
  26,180,و نپرسم شما را بر آن مزدی نیست مزد من مگر بر پروردگار جهانیان‌
  26,181,تمام دهید پیمانه را و نباشید از کم‌دهندگان‌
  26,182,و بسنجید با سنگ (ترازوی) راست‌
  26,183,و کم ندهید به مردم چیزهای ایشان را و نکوشید در زمین تباه‌کنندگان‌
  26,184,و بترسید آن را که آفرید شما را و آفریدگان پیشینیان‌
  26,185,گفتند جز این نیست که توئی از جادوشدگان‌
  26,186,و نیستی تو مگر بشری مانند ما و همانا پنداریمت از دروغگویان‌
  26,187,پس بیفکن بر ما پاره‌هائی از آسمان اگر هستی از راستگویان‌
  26,188,گفت پروردگار من داناتر است بدانچه می‌کنید
  26,189,پس تکذیبش کردند پس بگرفتشان عذاب روز ظلّه (سایبان) که بوده است آن عذاب روزی بزرگ‌
  26,190,همانا در این است آیتی و نیستند بیشتر ایشان مؤمنان‌
  26,191,و همانا پروردگار تو است عزّتمند مهربان‌
  26,192,و همانا آن است فرودآوردن پروردگار جهانیان‌
  26,193,فرود آوردش روح الأمین‌
  26,194,بر دل تو تا باشی از ترسانندگان‌
  26,195,به زبان عربی آشکار
  26,196,و همانا آن است در کتب پیشینیان‌
  26,197,آیا نیست برای ایشان آیتی که بدانندش دانشمندان بنی‌اسرائیل‌
  26,198,و اگر می‌فرستادیمش بر یکی از گنگ‌زبانان‌
  26,199,پس می‌خواندش بر ایشان نبودند بدان ایمان‌آرندگان‌
  26,200,بدینسان راهش دادیم در دلهای گنهکاران‌
  26,201,که ایمان نیارند بدان تا ببینند عذاب دردناک را
  26,202,که بیایدشان ناگاه و ایشان ندانند
  26,203,پس گویند آیا مائیم مهلت‌دادگان‌
  26,204,آیا به عذاب ما می‌شتابند
  26,205,آیا دیده باشی که اگر کامروا گردانیمشان سالیانی‌
  26,206,پس بیایدشان آنچه وعده داده می‌شوند
  26,207,بی نیاز نکند از ایشان آنچه بودند بهره‌ور می‌شدند
  26,208,و نابود نساختیم شهری را مگر برای آن بود ترسانندگانی‌
  26,209,یادآوردنی است و نیستیم ما ستمکاران‌
  26,210,و فرود نیاوردندش شیاطین‌
  26,211,و نسزد ایشان را و نتوانند
  26,212,همانا ایشانند از شنیدن دورماندگان‌
  26,213,پس نخوان با خدا خدائی دیگر را که باشی از عذاب‌شدگان‌
  26,214,و بترسان خویشاوندان خویش را نزدیکان‌
  26,215,و فرود کن بال خود را برای هر که پیرویت کند از مؤمنان‌
  26,216,پس اگر عصیانت کردند بگو من بیزارم از آنچه می‌کنید
  26,217,و توکّل کن بر خدای عزّتمند مهربان‌
  26,218,آنکه می‌بیندت گاهی که بپا می‌شوی‌
  26,219,و گردش تو را در سجده‌کنندگان‌
  26,220,که او است همانا شنوای دانا
  26,221,آیا آگهیتان دهم که بر که فرود می‌آیند شیاطین‌
  26,222,فرود آیند بر هر دروغ‌پرداز گنهباری‌
  26,223,که فرادهند گوش را و بیشتر ایشانند دروغگویان‌
  26,224,و شاعران و پیروی کنند گمراهان‌
  26,225,آیا نبینی که ایشانند در هر بیغوله‌ای سرگردان‌
  26,226,و آنکه گویند آنچه را نکنند
  26,227,مگر آنان که ایمان آوردند و کردار شایسته کردند و یاد کردند خدا را بسیار و یاری جستند پس از آن که ستم شدند و زود است بدانند آنان که ستم کردند چه بازگشتگاهی بازمی‌گردند
  27,1,طس این است آیتهای قرآن و کتابی آشکار
  27,2,هدایت و بشارتی برای مؤمنان‌
  27,3,آنان که بپا می‌دارند نماز را و می‌دهند زکات را و ایشانند به آخرت یقین دارندگان‌
  27,4,همانا آنان که ایمان نیارند به آخرت آراستیم برای ایشان کارهای ایشان را پس ایشانند سرگردانان‌
  27,5,آنانند که برای ایشان است زشتی عذاب و ایشانند در آخرت زیانمندان‌
  27,6,و همانا تو داده می‌شوی قرآن را از نزد حکیمی دانا
  27,7,هنگامی که گفت موسی به خاندانش که احساس کردم آتشی زود است بیارم شما را از آن خبری یا بیارم شما را اخگری گیرانه شاید گرم شوید
  27,8,پس هنگامی که بیامدش خوانده شد که خجسته باد آنکه در آتش است و آنکه پیرامون آن است و منزّه است خدا پروردگار جهانیان‌
  27,9,ای موسی همانا منم خداوند عزّتمند حکیم‌
  27,10,و بیفکن عصای خویش را پس گاهی که نگریستش می‌جنبد گوئیا ماری زبر و سبکخیز است بازگشت پشت‌کننده و به پشت برنگشت ای موسی نترس همانا نترسد نزد من فرستادگان‌
  27,11,مگر آنکه ستم کند پس جایگزین گرداند خوبی را پس از بدی که منم همانا آمرزنده مهربان‌
  27,12,و فرو بر دستت را در گریبان خود برون آید درخشنده بی‌آزاری در نه آیت بسوی فرعون و قومش که همانا بودند قومی فاسقان‌
  27,13,پس هنگامی که بیامدشان آیتهای ما روشن گفتند این است جادویی آشکار
  27,14,و انکار کردند آنها را حالی که یقین بدانها داشت دلهای ایشان به ستم و سرکشی پس بنگر چگونه بود فرجام تبهکاران‌
  27,15,و همانا ارزانی داشتیم به داود و سلیمان دانشی و گفتند سپاس خدای را که برتری داد ما را بر بسیاری از بندگان او مؤمنان‌
  27,16,و ارث بُرد سلیمان از داود و گفت ای مردم آموخته شدیم سخن مرغان را و داده شدیم از همه چیز همانا این است هر آینه فضلی آشکار
  27,17,و گردآورده شد برای سلیمان سپاه‌هایش از پری و آدمی و مرغان پس ایشانند بازداشت‌شدگان‌
  27,18,تا گاهی که آمدند بر درّه مورچگان گفت مورچه‌ای ای گروه مورچگان درآئید به نشیمنگاه خویش نبادا پایمالتان کنند سلیمان و سپاهیانش و ایشان درنیابند
  27,19,پس لبخندی زد خندان از گفتارش و گفت پروردگارا توفیقم ده که سپاسگزارم نعمتت را که ارزانی داشتی بر من و بر پدر و مادرم و آنکه شایسته‌ای کنم که تو را پسند آید و درآور مرا به رحمت خود در بندگان شایسته خویش‌
  27,20,و جُست مرغان را پس گفت چه شودم نبینم هُدهُد را یا شده است از ناپیدایان‌
  27,21,همانا شکنجه کنمش شکنجه‌ای سخت یا سرش را بُرم یا آنکه بیاردم فرمانی آشکار
  27,22,پس درنگ کرد نه دور گفت فراگرفتم آنچه را فرانگرفتی آن را و آوردمت از سبا داستانی را یقین‌
  27,23,هر آینه یافتم زنی را که پادشاه آنان بود و داده شده بود از همه چیز و بود او را تختی بزرگ‌
  27,24,یافتمش با کسان خود سجده می‌کردند برای خورشید نه خدا و آراسته بود برای ایشان شیطان کردار ایشان را پس بازداشته بودشان از راه پس راه نمی‌برند
  27,25,چرا سجده نکنند برای خداوندی که برون آرد نهانها را در آسمانها و زمین و می‌داند آنچه را نهان کنید و آنچه آشکار سازید
  27,26,خدا که نیست خدائی جز او پروردگار عرش بزرگ‌
  27,27,گفت زود است بنگریم آیا راست گفتی یا بودی از دروغگویان‌
  27,28,ببر نامه مرا این و بیفکنش بسوی آنان پس برگرد از ایشان و بنگر چه پاسخ گویند
  27,29,گفت آن زن ای گروه همانا به سویم افکنده شد نامه‌ای گرامی‌
  27,30,همانا آن از سلیمان است و همانا آن است به نام خداوند بخشنده مهربان‌
  27,31,که برتری نجوئید بر من و بیائید مرا تسلیم‌شوندگان‌
  27,32,گفت آن زن ای گروه دستوری دهیدم در کارم نبوده‌ام برنده کاری تا شما گواهی دهید
  27,33,گفتند مائیم خداوندان توانائی و دارندگان نیروئی سخت و کار با تو است پس بنگر تا چه فرمان دهی‌
  27,34,گفت آن زن همانا شهان هرگاه به کشوری درآیند تباهش کنند و بگردانند مهتران مردمش را کهتران و بدینسان کار کنند
  27,35,و همانا من فرستنده‌ام بسوی ایشان پیشکشی پس نگرانم چه پاسخ آورند فرستادگان‌
  27,36,پس هنگامی که بیامد سلیمان را گفت آیا کمک کنیدم به مال همانا آنچه داد مرا خدا بهتر است از آنچه داد شما را بلکه شما خود را به پیشکش خویشید شادمان‌
  27,37,بازگرد بسوی ایشان که همانا بیاریم ایشان را لشگرهائی که تاب نباشدشان بدانان و همانا برون رانیمشان از آن خوار حالی که ایشانند سرافکندگان‌
  27,38,گفت ای گروه کدامین از شما آوردم تخت آن زن را پیش از آنکه بر من درآیند تسلیم‌شدگان‌
  27,39,گفت دیوی از پریان من آرمت بدان پیش از آنکه از جای خویش خیزی و منم هرآینه بر آن توانائی امین‌
  27,40,گفت آنکه نزدش بود دانشی از کتاب من آرمت بدان پیش از آنکه بازگردد بسوی تو مُژه‌ات پس هنگامی که نگریستش جایگزین نزد خویش گفت این از فضل پروردگارم باشد تا بیازمایدم آیا شکر می‌کنم یا کفران ورزم و آنکه شکر کند جز این نیست که برای خویشتن سپاسگزارد و آنکه کفران کند همانا پروردگار من است بی‌نیازی گرامی‌
  27,41,گفت ناشناس دارید برایش تختش را بنگریم آیا رهبری می‌شود یا می‌باشد از آنان که رهبری نشوند
  27,42,پس گاهی که بیامد آن زن گفته شد آیا چنین است تختت گفت گوئیا این است آن و داده شدیم دانش را پیش از آن و بودیم تسلیم‌شدگان‌
  27,43,و بازداشتش آنچه بود می‌پرستید جز خدا همانا بود او از گروهی کافران‌
  27,44,گفته شد بدو به کاخ اندرآی پس گاهی که نگریستش پنداشتش آبگیری و برهنه ساخت ساقهای خویش را گفت همانا آن است کاخی لغزنده ساخته از بلور گفت آن زن پروردگارا همانا ستم به خود کردم و اسلام آوردم با سلیمان برای خدا پروردگار جهانیان‌
  27,45,و همانا فرستادیم بسوی ثمود برادرشان صالح را که پرستش کنید خدا را ناگهان ایشان دو گروهند ستیزه‌کنان‌
  27,46,گفت ای قوم من چرا می‌شتابید به بدی پیش از خوبی چرا آمرزش نمی‌جوئید از خدا شاید رحم آورده شوید
  27,47,گفتند به فال بد گرفتیم تو و آنان را که با تو هستند گفت همانا فال بد شما نزد خدا است بلکه شمائید گروهی گرفتارشدگان (یا آزمودگان)
  27,48,و بودند در شهر نه تیره که تبهکاری می‌کردند در زمین و اصلاح نمی‌کردند
  27,49,گفتند سوگند یاد کنید به خدا که شبیخون آریم بر او و خاندانش و سپس گوئیم به ولیّ او که ندیدیم (یا گواهی ندادیم) هلاک خویشاوندش را (یا خاندانش را) و هر آینه مائیم راستگویان‌
  27,50,و آوردند نیرنگی و آوردیم نیرنگی و آنان درنیافتند
  27,51,پس بنگر چگونه شد فرجام نیرنگشان که واژگون ساختیم ایشان را با قومشان همگی‌
  27,52,پس اینک خانه‌های آنان فرود آمده بدانچه ستم کردند همانا در این است نشانیی برای گروهی که می‌دانند
  27,53,و نجات دادیم آنان را که ایمان آوردند و پرهیزکاری می‌کردند
  27,54,و لوط را هنگامی که گفت به قوم خود آیا مرتکب فحشا شوید (ناشایست را آورید) و شمائید بینایان‌
  27,55,آیا شما با مردان گردائید به شهوت نه زنان بلکه شمائید گروهی نادانان‌
  27,56,پس نبود پاسخ قومش جز آنکه گفتند برون کنید خاندان لوط را از شهر خویش که ایشانند مردانی پاکیزگی‌جویان‌
  27,57,پس رهانیدیم او و خاندانش را مگر زنش که مقدّر گردانیدیم او را از گذشتگان‌
  27,58,و باریدیم بر آنان بارانی پس چه زشت است باران بیم‌دادگان‌
  27,59,بگو سپاس خدا را و سلام بر بندگان او که برگزیده است آیا خدا بهتر است یا آنچه شرک می‌ورزند
  27,60,یا آنکه آفرید آسمانها و زمین را و فرستاد برای شما از آسمان آبی پس رویانیدیم بدان باغستانی خرّم نرسد شما را که برویانید درختش را آیا خدائی است با خدا بلکه ایشانند قومی کجروان‌
  27,61,یا آنکه گردانید زمین را آرامشگاهی و گردانید میان آن جویهائی و گردانید برای آنها لنگرهایی و گردانید میان دو دریا فاصلی (دیواری) آیا خدائی است با خدا بلکه بیشترشان نمی‌دانند
  27,62,یا آنکه اجابت کند بیچاره را گاهی که خواندش و بگشاید رنج را و بگرداند شما را جانشینان زمین آیا خدائی است با خدا به کمی یادآور شوید
  27,63,یا آنکه هدایت کند شما را در تاریکیهای دشت و دریا و آنکه بفرستد بادها را مژده‌ای پیش روی رحمتش آیا خدائی است با خدا برتر است خدا از آنچه شرک ورزند
  27,64,یا آنکه آغاز کند آفرینش را سپس برگرداندش و آنکه روزیتان دهد از آسمان و زمین آیا خدائی است با خدا بگو بیارید دستاویز خود را اگر هستید راستگویان‌
  27,65,بگو نداند آنکه در آسمان و زمین است نهان را بجز خدا و درنیابند کی (چه هنگام) برانگیخته شوند
  27,66,بلکه رسید دانش ایشان در آخرت بلکه ایشانند در شکّی از آن بلکه ایشانند از آن کوران‌
  27,67,و گفتند آنان که کفر ورزیدند آیا گاهی که شدیم خاک و پدران ما آیا مائیم هر آینه برون‌آوردگان‌
  27,68,همانا وعده داده شدیم این را ما و پدران ما از پیش نیست این جز افسانه‌های پیشینیان‌
  27,69,بگو بگردید در زمین پس بنگرید چگونه بود فرجام گنهکاران‌
  27,70,و اندوهگین نباش بر ایشان و نباش در تنگنائی از آنچه نیرنگ آورند
  27,71,و گویند کی (چه هنگام است) این وعده اگر هستید راستگویان‌
  27,72,بگو امید است نزدیک باشد برای شما پاره‌ای از آنچه شتاب می‌جوئید
  27,73,و همانا پروردگار تو دارای فضلی است بر مردم و لیکن بیشترشان سپاس نگزارند
  27,74,و هر آینه پروردگار تو می‌داند آنچه را نهان کند سینه‌های ایشان و آنچه آشکار کنند
  27,75,و نیست ناپیدائی در آسمان و زمین مگر در کتابی است هویدا
  27,76,همانا این قرآن می‌سُراید بر بنی اسرائیل بیشتر آنچه را ایشانند در آن اختلاف‌کنندگان‌
  27,77,و همانا آن هدایت و رحمتی است برای مؤمنان‌
  27,78,همانا پروردگار تو حکومت می‌کند میان ایشان به حکم خود و او است عزّتمند دانا
  27,79,پس توکّل کن بر خدا که تویی بر حقّ هویدا
  27,80,هرآینه نشنوانی تو مُردگان را و نشنوانی به کران بانگ را گاهی که برگردند پشت‌کنان‌
  27,81,و نیستی تو هدایت‌کننده کوران را از گمراهی خود نشنوانی جز آن را که ایمان آرد به آیتهای ما پس ایشانند تسلیم‌شدگان‌
  27,82,و گاهی که فرود آید بر ایشان سخن برون آریم برای ایشان جنبنده‌ای را از زمین سخن گوید با ایشان که بودند مردم به آیتهای ما یقین نمی‌آوردند
  27,83,و روزی که برانگیزیم از هر امّتی گروهی را از آنان که تکذیب کنند به آیتهای ما پس بازداشت شوند
  27,84,تا گاهی که آیند گوید آیا تکذیب کردید آیتهای مرا و فرانگرفتید آنها را به دانش یا چه بود آنچه می‌کردید
  27,85,و فرود آمد بر ایشان سخن بدانچه ستم کردند پس ایشان سخن نگویند
  27,86,آیا نبینند که ما نهادیم شب را تا آرامش کنند در آن و روز را روشن همانا در این است آیتهائی برای گروهی که ایمان آرند
  27,87,و روزی که دمیده شود در صور پس بمیرند از هراس آنان که در آسمانها و آنان که در زمینند مگر آنکه خواهد خدا و همه بیایندش سرافکندگان‌
  27,88,و بینی کوه‌ها را پنداریشان خشک بر جای خود حالی که می‌گذرند همانند گذشتن ابر ساخت خدائی که درست کرد همه چیز را همانا او آگاه است بدانچه می‌کنید
  27,89,آنکو نکوئی آرد پس او را است بهتر از آن و ایشانند از هراس در آن روز ایمنان‌
  27,90,و آنکه بدی آرد پس بروی افتد چهره‌های آنان در آتش آیا پاداش داده می‌شوید جز آنچه را بودید می‌کردید
  27,91,جز این نیست که فرمان داده شدم که پرستش کنم پروردگار این شهر را آنکه حرامش گردانید و برای او است همه چیز و دستور داده شدم که باشم از اسلام‌آرندگان‌
  27,92,و آنکه بخوانم قرآن را پس آنکه رهبری شود جز این نیست که رهبری شود برای خویشتن و آنکه گمراه شود بگو جز این نیست که منم از ترسانندگان‌
  27,93,و بگو سپاس خدای را زود است بنمایاندتان آیتهای خویش را تا بشناسید آنها را و نیست پروردگار تو ناآگاه از آنچه می‌کنید
  28,1,طسم‌
  28,2,این است آیتهای کتاب هویدا
  28,3,می‌خوانیم بر تو از داستان موسی و فرعون به حقّ برای گروهی که ایمان آرند
  28,4,همانا فرعون برتری جُست در زمین و گردانید مردمش را گروهائی ناتوان می‌گرفت دسته‌ای از آنان را سر می‌برید فرزندان ایشان را و می‌گذارد زنان ایشان را و همانا او بود از تباهکاران‌
  28,5,و خواهیم منّت نهیم بر آنان که ناتوان شمرده شدند در زمین و بگردانیمشان پیشوایانی و بگردانیمشان ارث‌برندگان‌
  28,6,و فرمانروائیشان دهیم در زمین و بنمایانیم فرعون و هامان و سپاه‌های ایشان را از آنان آنچه بودند می‌ترسیدند
  28,7,و وحی کردیم بسوی مادر موسی که شیرش ده تا گاهی که بیمناک شدی بر او بیفکنش در دریا و نترس و نه اندوهگین باش که ما برگرداننده‌ایم او را بسوی تو و گرداننده‌ایم او را از پیمبران‌
  28,8,پس برداشتندش خاندان فرعون تا بشود برای ایشان دشمنی و اندوهی همانا فرعون و هامان و سپاهیان ایشان بودند لغزشکاران‌
  28,9,و گفت زن فرعون روشنی چشمی است برای تو و من مکش او را باشد سودمند افتد ما را یا برگیریمش فرزندی و ایشان درنمی‌یافتند
  28,10,و بامداد کرد دل مادر موسی تهی نزدیک بود فاش سازدش اگر نه بسته بودیم دلش را تا بشود از ایمان‌آرندگان‌
  28,11,و گفت به خواهر خود جستجویش کن پس نگریستش از دور و ایشان نمی‌یافتند
  28,12,و حرام ساختیم بر او شیرخوارگاه‌ها را (پستانها را) از پیش پس گفت آن زن آیا راهنمائی نکنم شما را به خاندانی که پرستاریش کنند برای شما و ایشانند برای او نیک‌خواهان‌
  28,13,پس بازگردانیدیمش بسوی مادرش تا روشن شود چشمش بدو و اندوهگین نشود و تا بداند که وعده خدا است حقّ و لیکن بیشترشان نمی‌دانند
  28,14,و هنگامی که رسید نیروی خود را و استوار شد ارزانی داشتیمش حکم و دانش را و بدینسان پاداش دهیم به نکوکاران‌
  28,15,و در آمد به شهر هنگام غفلتی از مردمش پس یافت در آن دو مرد که کارزار می‌کردند این از دوستانش بود و آن از دشمنانش پس یاری جست از او آنکه از پیروانش بود بر آنکه از دشمنانش بود پس مشتی نواخت بر او موسی که کارش را ساخت گفت این از کار شیطان بود همانا او دشمنی است گمراه‌کننده‌ای آشکار
  28,16,گفت پروردگارا همانا ستم به خود نمودم پس بیامرز مرا پس آمرزید او را که او است آمرزنده مهربان‌
  28,17,گفت پروردگارا بدانچه به من ارزانی داشتی هرگز نشوم پشتیبان گنهکاران‌
  28,18,پس بامداد کرد در شهر هراسانی چشم به راه ناگهان آنی که یاریش کرده بود دیروز به یاریش می‌طلبید گفت بدو موسی توئی همانا گمراهی آشکار
  28,19,پس گاهی که خواست خشم آرد بدانکه او دشمن هر دو بود گفت ای موسی آیا خواهی مرا کشی چنانکه کشتی تنی را دیروز تو همانا نخواهی جز آنکه ستمگری باشی در زمین و نخواهی که باشی از اصلاح‌کنندگان‌
  28,20,و آمد مردی از پایان شهر می‌دوید گفت ای موسی همانا مردم در اندیشه تواند که بکشندت پس برون شو همانا منم تو را از اندرزگویان‌
  28,21,پس برون رفت از آن هراسانی چشم به راه گفت پروردگارا نجاتم ده از گروه ستمگران‌
  28,22,و هنگامی که روی آورد بسوی مدین گفت امید است پروردگار من رهبریم کند به راه راست‌
  28,23,و هنگامی که وارد شد بر آب مدین یافت بر آن گروهی را از مردم که آب می‌دادند و یافت نزدیک ایشان دو زن که بازمی‌داشتند (گوسفندان را از گریختن) گفت چیست کار شما گفتند ما آب ندهیم تا بازآیند شبانان (سیراب کنند) و پدر ما پیری هست فرتوت‌
  28,24,پس سیراب کرد برای ایشان سپس بازگشت بسوی سایه و گفت پروردگارا همانا منم بدانچه فرستی به سویم از خیر نیازمند
  28,25,پس بیامدش یکی از آن دو زن که می‌آمد (که روان بود) بر آزرمی گفت همانا پدرم تو را می‌خواند تا بپردازدت مزد آنچه را آب دادی برای ما پس گاهی که بر او درآمد و خواند بر او داستانها را گفت بیم مدار رها شدی از گروه ستمگران‌
  28,26,گفت یکی از آن دو زن ای پدر مزدورش گیر که بهترین آنان که مزدور گیری نیرومندی است امین‌
  28,27,گفت همانا خواهم که همسر تو گردانم یکی از دخترانم را اینان بر آنکه مزدورم باشی هشت سال و اگر ده سال را به پایان آوردی پس از نزد تو است و نخواهم سختی بر تو آرم زود است بیابی مرا اگر خدا خواهد از شایستگان‌
  28,28,گفت این میان من و تو است که هر یک از دو سرآمد را به پایان آوردم نباشد ستمی بر من و خدا است بر آنچه گوئیم وکیل‌
  28,29,پس گاهی که پایان آورد موسی سرآمد را و روان گشت با خاندان خویش دریافت از کنار طور آتشی را گفت به خاندان خویش درنگ کنید که من آتشی احساس کردم باشد بیارمتان از آن آگهیی یا گیرانه اخگری شاید شما گرم شوید
  28,30,پس گاهی که آمد آن را خوانده شد از کنار راست درّه در سرزمین فرخنده از درخت که‌ای موسی همانا منم خدا پروردگار جهانیان‌
  28,31,و آنکه بیفکن چوبدست خود را تا گاهی که نگریستش می‌جنبد مانند ماری سبک‌خیز برگشت روی گردان و به پشت ننگریست ای موسی بیا و نترس که توئی از ایمن شدگان‌
  28,32,فرو بر دستت را در گریبان خویش تا برون آید تابنده بی‌آزاری و بازگردان بسوی خود بال خود را از بیم پس اینها دو حجّتند از پروردگار تو بسوی فرعون و کسانش که بودند ایشان همانا گروهی نافرمانان‌
  28,33,گفت پروردگارا کشتم از ایشان تنی را و ترسم که بکشندم‌
  28,34,و برادرم هارون او روانتر است از من در زبان پس بفرستش با من کمکی که تصدیقم کند زیرا می‌ترسم که مرا تکذیب کنند
  28,35,گفت زود است استوار سازم بازوی تو را به برادرت و بدهم به شما فرمانروائی تا نرسند به شما به آیتهای ما شما و هر که پیروی کند شما را هستید چیره‌آیندگان‌
  28,36,پس هنگامی که بیامدشان موسی به آیتهای ما تابناک گفتند نیست این جز جادوئی دروغ بسته و نشنیدیم بدان در پدران ما پیشینیان‌
  28,37,و گفت موسی پروردگار من داناتر است بدانکه هدایت آورده است از نزدش و آنکه برای او است پایان آن سرای همانا رستگار نشوند ستمگران‌
  28,38,و گفت فرعون ای قوم ندانم برای شما خدائی جز خویش پس بیفروز برایم ای هامان بر گل پس بساز برایم کوشکی شاید اطّلاع یابم بر خدای موسی و همانا می‌پندارمش من از دروغگویان‌
  28,39,و سرکشی کرد او و لشکرهای او در زمین به ناروا و پنداشتند که ایشان بسوی ما بازگردانیده نمی‌شوند
  28,40,پس گرفتیم او و سپاهش را و افکندیمشان به دریا پس بنگر چگونه بود فرجام ستمگران‌
  28,41,و گردانیدیمشان پیشوایانی که می‌خوانند بسوی آتش و روز قیامت یاری نمی‌شوند
  28,42,و از پی آوردیمشان در این دنیا لعنتی و روز رستاخیز ایشانند از ناشایستگان (زشت‌شدگان)
  28,43,و هرآینه دادیم به موسی کتاب را پس از آنکه نابود ساختیم قرنهای پیشین را بینشهائی برای مردم و راهنمائی و رحمتی شاید ایشان یادآور شوند
  28,44,و نبودی تو در کنار باختری هنگامی که گذراندیم بسوی موسی کار را و نبودی تو از گواهان‌
  28,45,لیکن ما پدید آوردیم قرنهائی پس دراز شد بر ایشان عمر (روزگار) و نبودی تو جایگزین در مردم مدین بخوانی بر ایشان آیتهای ما را و لیکن بودیم ما فرستندگان‌
  28,46,و نبودی تو در کنار طور هنگامی که فراخواندیم و لیکن رحمتی از پروردگارت تا بترسانی گروهی را که نیامدستشان بیم‌دهنده‌ای پیش از تو شاید یادآور شوند
  28,47,و اگر نبود آنکه گاهی که برسدشان پیش آمدی بدانچه پیش فرستاده است دستهای ایشان گویند پروردگارا چرا نفرستادی بسوی ما فرستاده‌ای تا پیروی کنیم آیتهای تو را و باشیم از مؤمنان‌
  28,48,و هنگامی که بیامدشان حقّ از نزد ما گفتند چرا داده نشد مانند آنچه داده شد موسی آیا کفر نورزیدند بدانچه داده شد موسی از پیش گفتند دو جادویند پشتیبان همدیگر و گفتند هرآینه مائیم به هر کدام کافران‌
  28,49,بگو پس بیارید کتابی از نزد خدا راهنماینده‌تر از این دو تا پیرویش کنم اگر هستید راستگویان‌
  28,50,پس اگر نپذیرفتند از تو بدان که همانا پیروی کنند هوسهای خویش را و کیست گمراه‌تر از آنکه پیروی کند هوس خود را بی رهبریی از خدا همانا خدا هدایت نکند گروه ستمکاران را
  28,51,و همانا پیوسته داشتیم برای ایشان گفتار را شاید یادآور شوند
  28,52,آنان که دادیمشان کتاب را پیش از آن ایشانند بدان ایمان‌آرندگان‌
  28,53,و هر گاه خوانده شود بر ایشان گویند ایمان آوردیم بدان همانا آن است حقّ از پروردگار ما همانا بودیم پیش از آن اسلام‌آرندگان‌
  28,54,آنان داده شوند مزد خویش را دوبار بدانچه شکیبائی گزیدند و دور می‌کردند به خوبی بدی را و از آنچه روزیشان دادیم می‌دادند
  28,55,و هر گاه می‌شنیدند بیهده (یاوه) را روی می‌گردانیدند از آن و گفتند ما را است کردار ما و شما را است کردار شما سلام بر شما نخواهیم نادانان را
  28,56,همانا تو رهبری نکنی آن را که دوست داری و لیکن خدا رهبری کند هر که را که خواهد و او است داناتر به راه‌یافتگان‌
  28,57,و گفتند اگر پیروی کنیم هدایت را با تو ربوده شویم از سرزمین خویش آیا فرمانروائیشان ندادیم در حرم امنی که آورده شود به سویش میوه‌های همه چیز روزیی از نزد ما لیکن بیشترشان نمی‌دانند
  28,58,و بسا نابود کردیم شهری را که کامرانی گرفته بود زندگی خویش را پس اینک نشیمنهای آنان که نشیمن نشدند پس از ایشان مگر اندکی و بودیم ما ارث‌برندگان‌
  28,59,و نیست پروردگار تو نابودکننده شهرها تا برانگیزد در مادر آنها پیمبری که خواند بر ایشان آیتهای ما را و نیستیم ما نابودکننده شهرها مگر و مردم آنهایند ستمگران‌
  28,60,و آنچه داده شدید از چیزی پس بهره زندگانی دنیا و زیور آن است و آنچه نزد خدا است بهتر و پایدارتر است آیا بخرد نمی‌یابید
  28,61,آیا آن را که وعده‌ای دادیم وعده نیکی پس او است بدان رسنده مانند آن است که کامیابیش دادیم کامیابی زندگانی دنیا سپس او است روز قیامت از احضارشدگان‌
  28,62,و روزی که خواندشان پس گوید کجایند شریکان من آنان که بودید می‌پنداشتید
  28,63,گفتند آنان که فرود آمده بود بر ایشان سخن پروردگار اینانند که گمراه کردیم گمراهشان کردیم بدانسان که گمراه شدیم بیزاری جستیم به سویت نبودند ما را پرستندگان‌
  28,64,و گفته شد بخوانید شریکان خود را پس خواندند ایشان را پس پاسخ نگفتندشان و دیدند عذاب را اگر بودند هدایت می‌شدند
  28,65,و روزی که خواندشان پس گوید چه چیز پاسخ گفتید به فرستادگان‌
  28,66,پس کور شود بر ایشان آگهیها در آن روز پس از همدیگر نپرسند
  28,67,امّا آنکه توبه کند و ایمان آرد و کردار شایسته کند پس امید است آنکه باشد از رستگاران‌
  28,68,و پروردگارت می‌آفریند هر آنچه خواهد و برگزیند نیستشان اختیاری منزّه و برتر است خدا از آنچه شرک ورزند
  28,69,و پروردگار تو داند آنچه نهان می‌دارد سینه‌های ایشان و آنچه پدیدار کند
  28,70,و او است خدا نیست خدائی جز او برای او است سپاس در آغاز و انجام و برای او است حکم و به سویش بازگردانیده شوید
  28,71,بگو آیا دیده‌اید اگر بگرداند خدا بر شما شب را پیوسته تا روز رستاخیز کدام خدا است جز خدا که بیارد شما را پرتوی آیا نمی‌شنوید
  28,72,بگو آیا دیده‌اید اگر گرداند خدا بر شما روز را همیشگی تا روز قیامت کدام خدا است جز خدا که آوردتان شبی که آرامش گیرید در آن آیا نمی‌بینید
  28,73,و از رحمتش نهاد برای شما شب و روز را تا بیارامید در آن و تا جوئید از فضلش و شاید سپاسگزارید
  28,74,و روزی که بخواندشان پس گوید کجا است شریکانم آنان که بودید می‌پنداشتید
  28,75,و گرفتیم از هر ملّتی گواهی و گفتیم بیارید دستاویز خویش را پس دانستند آنکه حقّ از آن خدا است و گم شد از ایشان آنچه بودند دروغ می‌بستند
  28,76,همانا قارون بود از قوم موسی پس سرکشی کرد بر ایشان و دادیمش از گنجها آنچه کلیدهایش گران می‌آید بر گروه نیرومند هنگامی که گفتند بدو قومش شادمانی نکن که خدا دوست ندارد شادمانان را
  28,77,و بجوی در آنچه خدا به تو داده است خانه آخرت را و فراموش مکن بهره خویش را از دنیا و نکوئی کن چنانکه نکوئی کرد به تو خدا و نجوی تباهی را در زمین همانا خدا دوست ندارد تبهکاران را
  28,78,گفت جز این نیست که داده شدش بر دانشی نزد من آیا نمی‌داند که خدا نابود کرد پیش از او از قرنها آنکه سخت‌تر از او بود در نیرو و بیشتر در گروه و پرسش نشوند از گناهانشان گنهکاران‌
  28,79,پس برون شد بر قومش در زیور خویش گفتند آنان که خواهند زندگانی دنیا را کاش ما را می‌بود مانند آنچه داده شده است قارون همانا او است دارای بهره گران‌
  28,80,و گفتند آنان که داده شدند دانش را وای بر شما پاداش خدا بهتر است برای آنکه ایمان آرد و کردار شایسته کند و داده نشوند آن را مگر شکیبایان‌
  28,81,پس فروبردیم او و خانه او را در زمین و نبود برایش دسته‌ای که یاریش کنند جز خدا و نبود از یاری‌شدگان‌
  28,82,و بامداد کردند آنان که آرزو می‌کردند جای او را دیروز می‌گفتند وای گوئیا خدا می‌گشاید روزی را برای هر که خواهد از بندگانش و تنگ می‌گرداند اگر نه منّت می‌نهاد خدا بر ما هرآینه فرومی‌برد ما را وای گوئیا رستگار نشوند کافران‌
  28,83,اینک خانه آخرت نهیمش برای آنان که نجویند برتریی در زمین و نه تبهکاریی و فرجام است از آنِ پرهیزکاران‌
  28,84,آنکه خوبی را آرد وی را است بهتر از آن و آنکه بدی را آرد پس کیفر نشوند آنان که کردار زشت کنند مگر آنچه را بودند می‌کردند
  28,85,همانا آنکه بایسته داشت بر تو قرآن را بازگرداننده است تو را بسوی بازگشتگاه بگو پروردگارم داناتر است که هدایت را آورده و کیست آنکه او است در گمراهی آشکار
  28,86,و نبودی تو امیدوار بدانکه افکنده شود به سویت کتاب مگر رحمتی از پروردگارت پس نباش البتّه پشتیبانی برای کافران‌
  28,87,و بازندارندت از آیتهای خدا پس از آنکه فرستاده شد به سویت و بخوان بسوی پروردگار خویش و نباش از شرک‌ورزان‌
  28,88,و نخوان با خدا خدای دیگری نیست خدائی جز او هر چیزی نابود است جز رویش او را است حکم و به سویش بازگردانیده شوید
  29,1,الم
  29,2,آیا پنداشتند مردم که رها شوند آنکه گویند ایمان آوردیم و آزموده نگردند
  29,3,و همانا آزمودیم آنان را که پیش از ایشان بودند تا بداند خدا آنان را که راست گفتند و تا بداند دروغگویان را
  29,4,یا گمان دارند آنان که کنند بدیها که بر ما سبقت گیرند زشت است آنچه حکم کنند
  29,5,آنکو امید دارد ملاقات خدا را همانا سرآمد خدا است آینده و او است شنوای دانا
  29,6,و آنکه می‌کوشد جز این نیست که می‌کوشد برای خویشتن همانا خدا بی‌نیاز است از جهانیان‌
  29,7,و آنان که ایمان آوردند و کارهای شایسته کردند همانا بستریم از ایشان بدیهای ایشان را و هر آینه پاداششان دهیم بهتر آن را که بودند می‌کردند
  29,8,و اندرز دادیم انسان را به پدر و مادرش نکوئی‌کردن و اگر کوشیدند با تو که شرک‌ورزی با من آنچه را نیستت بدان دانشی پس فرمانبرداریشان نکن بسوی من است بازگشت شما تا آگهیتان دهم بدانچه بودید می‌کردید
  29,9,و آنان که ایمان آوردند و کردار شایسته کردند هر آینه درآریمشان در شایستگان‌
  29,10,و از مردمند آنان که گویند ایمان آوردیم به خدا پس گاهی که آزرده شود در راه خدا بگرداند آزار مردم را چون عذاب خدا و اگر بیاید یاریی از پروردگارت هر=آینه گویند ما با شما بودیم آیا نیست خدا را داناتر بدانچه هست در سینه‌های جهانیان‌
  29,11,و تا بداند خدا آنان را که ایمان آوردند و تا بداند آنان را که نفاق (دوروئی) ورزیدند
  29,12,و گفتند آنان که کفر ورزیدند بدانان که ایمان آوردند پیروی کنید راه ما را و باید به دوش کشیم گناهان شما را و نیستند حمل‌کنندگان گناهان ایشان به چیزی همانا ایشانند دروغگویان‌
  29,13,و هر آینه به دوش کشند بارهای خود را و بارهایی با بارهای خود و هر آینه پرسش شوند روز قیامت از آنچه بودند دروغ می‌بستند
  29,14,و همانا فرستادیم نوح را بسوی قومش پس ماند در ایشان هزار سال مگر پنجاه سال پس گرفت ایشان را طوفان حالی که بودند ستمگران‌
  29,15,پس رهانیدیمش و یاران کشتی را و گردانیدیمش آیتی برای جهانیان‌
  29,16,و ابراهیم هنگامی که گفت به قوم خود پرستش کنید خدا را و بترسیدش این بهتر است برای شما اگر بدانید
  29,17,جز این نیست که می‌پرستید جز خدا بتانی را و می‌آفرید دروغی را (می‌پردازید) همانا آنان که می‌پرستید جز خدا دارا نیستند برای شما روزیی پس بجوئید نزد خدا روزی را و او را پرستش کنید و شکرش گزارید بسوی او بازگردانیده می‌شوید
  29,18,و اگر تکذیب کنید همانا تکذیب کردند ملّتهائی پیش از شما و نیست بر پیمبر مگر رساندن آشکار
  29,19,آیا نبینند چگونه پدید آرد خدا آفرینش را و سپس بازگرداندش همانا آن است بر خدا آسان‌
  29,20,بگو بگردید در زمین پس بنگرید چگونه آغاز آفرینش کرد سپس خدا پدید آورد پیدایش بازپسین را همانا خدا بر همه چیز است توانا
  29,21,عذاب کند هر که را خواهد و بیامرزد هر که را خواهد و بسوی او بازگردانیده شوید
  29,22,و نیستید شما عاجزکنندگان در زمین و نه در آسمان و نیستتان جز خدا دوست و نه یاوری‌
  29,23,و آنان که کفر ورزیدند به آیتهای خدا و ملاقات او آنان نومیدند از رحمتم و آنان را است عذابی دردناک‌
  29,24,پس نبود پاسخ قومش جز آنکه گفتند بکشیدش یا بسوزانیدش پس رها ساختش خدا از آتش همانا در این است آیتهائی برای قومی که ایمان آرند
  29,25,و گفت جز این نیست که برگرفتید جز خدا بتهایی به دوستی میان خویش در زندگانی دنیا پس روز قیامت کفر ورزد برخی از شما به برخی و لعن کند برخی از شما برخی را و جای شما آتش است و نیست شما را یارانی‌
  29,26,پس ایمان آورد برایش لوط و گفت همانا منم هجرت‌کننده بسوی پروردگار خویش همانا او است عزّتمند حکیم‌
  29,27,و بخشیدیم بدو اسحق و یعقوب را و نهادیم در نژادش پیمبری و کتاب را و دادیم بدو مزدش را در دنیا و همانا او است در آخرت از شایستگان‌
  29,28,و لوط گاهی که گفت به قوم خود آیا می‌آئید (یا آرید) فاحشه (ناشایست) را که پیشی نگرفته است شما را بدان کسی از جهانیان‌
  29,29,آیا شما درآئید بر مردان و ببرید راه را و بیارید در انجمن خویش ناپسند را پس نبود پاسخ قومش جز آنکه گفتند بیاور ما را به عذاب خدا اگر هستی از راستگویان‌
  29,30,گفت پروردگارا یاریم کن بر گروه بدکاران‌
  29,31,و هنگامی که آمدند فرستادگان ما ابراهیم را به مژده گفتند هر آینه نابودکننده‌ایم مردم این شهر را همانا مردمش بودند ستمگران‌
  29,32,گفت همانا در آن است لوط گفتند ما داناتریم بدانکه در آن است هر آینه نجاتش دهیم او و خاندانش را مگر زنش را که بوده است از گذشتگان‌
  29,33,و هنگامی که آمدند فرستادگان ما لوط را به رنج شد از ایشان و تنگ شد بدیشان تاب و توان او گفتند نترس و اندوهگین مباش که مائیم نجات‌دهندگان تو و خاندانت مگر آن تو که او است هر آینه از گذشتگان‌
  29,34,همانا مائیم فرستنده بر مردم این شهر چرکی را از آسمان بدانچه بودند نافرمانی می‌کردند
  29,35,و همانا بازگذاردیم از آن نشانی آشکار برای گروهی که بخرد می‌یابند
  29,36,و بسوی مَدین برادرشان شعیب را پس گفت ای قوم پرستش کنید خدا را و امید دارید روز بازپسین را و نکوشید در زمین تباهکاران‌
  29,37,پس تکذیبش کردند پس بگرفتشان لرزشی که بامداد کردند در خانه خویش مردگان‌
  29,38,و عاد و ثمود و بدرست پدیدار شد برای شما از نشیمنیهای آنان و بیاراست برای ایشان شیطان کردارشان را پس بازداشتشان از راه حالی که بودند بینایان‌
  29,39,و قارون و فرعون و هامان و همانا بیامدشان موسی با نشانیها پس سرکشی ورزیدند در زمین و نبودند پیشی‌گیرندگان‌
  29,40,پس هر کدام را گرفتیم به گناهش پس از ایشان است آنکه فرستادیم بر او سنگ‌ریزه و از ایشان است آنکه بگرفتش خروش و از ایشان است آنکه فروبردیمش در زمین و از ایشان است آنکه غرق کردیم و نبود خدا ستم بر ایشان کند و لیکن بودند خویشتن را ستمکاران‌
  29,41,مثَل آنان که گرفتند جز خدا دوستانی مانند عنکبوت است که برگرفت خانه‌ای و هر آینه سست‌ترین خانه‌ها خانه عنکبوت است اگر بدانند
  29,42,همانا خدا می‌داند آنچه را خوانند جز وی از چیزی و او است عزّتمند حکیم‌
  29,43,و این مثَلها را می‌زنیم برای مردم و بخرد نیابندش جز دانایان‌
  29,44,آفرید خدا آسمانها و زمین را به حقّ همانا در این است آیتی برای مؤمنان‌
  29,45,بخوان آنچه را وحی شد بسویت از کتاب و بپای‌دار نماز را که همانا نماز بازدارد از فحشاء (ناشایست) و منکر (ناپسند) و هر آینه یاد خدا بزرگتر است و خدا داند آنچه را می‌سازید
  29,46,و نستیزید با اهل کتاب مگر بدانچه آن است بهتر مگر آنان که ستم کردند از ایشان و بگوئید ایمان آوردیم بدانچه فرستاده شد بسوی ما و فرستاده شد بسوی شما و خدای ما و خدای شما یکی است و مائیم برای او اسلام‌آرندگان‌
  29,47,و چنین فرستادیم بسویت کتاب را پس آنان که دادیمشان کتاب را ایمان آرند بدان و از ایشان است آنکه ایمان آرد بدان و خیرگی نکنند در آیتهای ما مگر کافران‌
  29,48,و نبودی تو بخوانی پیش از این کتابی و نه بنویسش با دست راست آن هنگام هر آینه شکّ می‌آوردند نادرستان‌
  29,49,بلکه آن آیتهای آشکارائی است در سینه‌های آنان که داده شدند دانش را و برابری نکنند به آیتهای ما مگر ستمکاران‌
  29,50,و گفتند چرا فرستاده نشد بر او آیتهائی از پروردگارش بگو جز این نیست که آیتها نزد خدا است و جز این نیست که منم ترساننده آشکار
  29,51,آیا پس نشد ایشان را که فرستادیم بر تو کتاب را خوانده می‌شود بر ایشان همانا در این است رحمت و یادآوردنی برای گروهی که ایمان آرند
  29,52,بگو بس است خدا میان من و شما گواه داند آنچه را در آسمانها و زمین است و آنان که ایمان آرند به باطل و کفر ورزند به خدا آنانند زیانکاران‌
  29,53,و شتاب خواهند از تو در عذاب و اگر نبود سرآمدی نامبرده هر آینه می‌آمدشان عذاب و همانا بیایدشان ناگهان و ایشان درنیابند
  29,54,شتاب خواهند از تو در عذاب و همانا دوزخ است فراگیرنده به کافران‌
  29,55,روزی که فراگیردشان عذاب از فرازشان و از زیر پایهایشان و گوید بچشید آنچه را بودید می‌کردید
  29,56,ای بندگان من که ایمان آوردید همانا زمین من پهناور است پس مرا پرستش کنید
  29,57,همه کس چشنده مرگ است سپس بسوی ما برگردانیده شوید
  29,58,و آنان که ایمان آرند و کردار شایسته کنند هر آینه جایگاه گردانیمشان از بهشت غرفه‌هائی که روان است زیر آنها جویها جاودانان در آن چه خوب است پاداش عمل‌کنندگان‌
  29,59,آنان که شکیبائی ورزیدند و بر پروردگار خویش توکّل کنند
  29,60,و بسا جنبنده‌ای که برندارد روزی خویش را خدا روزی دهدش و شما را و او است شنوای دانا
  29,61,و اگر پرسیشان که آفرید آسمانها و زمین را و رام کرد مهر و ماه را هر آینه گویند خدا پس کجا به دروغ رانده می‌شوند
  29,62,خدا فراخ گرداند روزی را برای هر که خواهد از بندگان خویش و تنگ گرداند برایش همانا خداوند است به همه چیز دانا
  29,63,و اگر پرسیشان که فرستاد از آسمان آبی تا زنده کرد بدان زمین را پس از مردنش هر آینه گویند خدا بگو سپاس خدای را بلکه بیشترشان بخرد درنمی‌یابند
  29,64,و نیست این زندگانی دنیا جز هوسرانی و بازی و همانا خانه بازپسین است زندگانی اگر بدانند
  29,65,پس گاهی که سوار شوند در کشتی خوانند خدا را پاک‌کنندگان برای او دین را تا گاهی که رهانیدشان بسوی دشت ناگهان ایشان شرک ورزند
  29,66,تا کفر ورزند بدانچه دادیمشان و تا کامیاب شوند پس زود است بدانند
  29,67,آیا نبینند که ما نهادیم حرمی امن و ربوده شوند مردم از پیرامونش آیا به باطل ایمان آرند و به نعمت خدا کفر ورزند
  29,68,و کیست ستمگرتر از آنکه بست بر خدا دروغی یا دروغ پنداشت حقّ را گاهی که آمدش آیا نیست در دوزخ جایگاهی برای کافران‌
  29,69,و آنان که بکوشند در راه ما هر آینه بنمایانیمشان راه‌های خویش را همانا خدا است با نکوکاران‌
  30,1,الم
  30,2,شکست خوردند روم
  30,3,در نزدیکترین سرزمین و ایشان پس از شکستشان زود است پیروز شوند
  30,4,در چند سال برای خدا است کار از پیش و از پس و در آن روز خرسند شوند مؤمنان‌
  30,5,به یاری خدا یاری کند هر که را خواهد و او است عزّتمند مهربان‌
  30,6,وعده خدا است و نشکند خدا وعده خویش را لیکن بیشتر مردم نمی‌دانند
  30,7,می‌دانند روئی (ظاهری) را از زندگانی دنیا و ایشانند از آخرت ناآگهان‌
  30,8,آیا نیندیشیدند پیش خود که نیافریده است خدا آسمانها و زمین و آنچه را میان آنها است جز به حقّ و سرآمدی نامبرده و هر آینه بیشی از مردمند به ملاقات پروردگار خویش کافران‌
  30,9,آیا نمی‌گردند در زمین تا بنگرند چگونه بود فرجام آنان که بودند پیش از ایشان بودند سخت‌تر از ایشان در نیرو و کاویدند زمین را (یا شخم زدند) و آبادان ساختندش بیشتر از آنچه اینان آباد کردندش و بیامدندشان پیمبرانشان به روشنائیها پس نبود خدا ستم کند بر ایشان لیکن بودند خویشتن را ستم می‌کردند
  30,10,پس شد فرجام آنان که بدی کردند آنکه دروغ پنداشتند آیتهای خدا را و بودند بدانها مسخره‌کنان‌
  30,11,خدا آغاز کند آفرینش را پس بازگرداندش و سپس بسویش بازگردانیده شوید
  30,12,و روزی که بپاشود ساعت سراسیمه شوند گنهکاران‌
  30,13,و نبود ایشان را از شریکانشان شفاعت‌کنندگانی و بودند به شریکان خویش کفرورزان‌
  30,14,و روزی که بپاشود ساعت در آن روز پراکنده شوند
  30,15,پس آنان که ایمان آوردند و کردار شایسته کردند ایشانند در چمنزاری شادمان‌
  30,16,و اما آنان که کفر ورزیدند و دروغ پنداشتند آیتهای ما را و رسیدن را به آخرت آنانند در عذاب احضارشدگان‌
  30,17,پس منزّه است (یا منزه شمرید) خدا را هنگامی که شام کنید و هنگامی که بامداد کنید
  30,18,و او را است سپاس در آسمانها و زمین و شامگاهان و گاهی که نیمروز کنید
  30,19,برون آرد زنده را از مرده و برون آرد مرده را از زنده و زنده می‌کند زمین را پس از مردنش و بدینسان برون آورده شوید
  30,20,و از آیتهای او آن است که آفرید شما را از خاکی ناگاه شما بشرید پراکندگان‌
  30,21,و از آیتهای او آن است که آفرید برای شما از خودتان جفتهائی تا بیارامید بدانان و نهاد در میان شما دوستی و مهری را همانا در این است آیتهائی برای گروهی که اندیشه کنند
  30,22,و از آیتهایش آفرینش آسمانها و زمین و گوناگون بودن زبانهای شما و رنگهای شما است همانا در این آیتهائی برای دانایان‌
  30,23,و از آیتهایش خواب شما است در شب و روز و روزی‌جستن شما از فضلش همانا در این است آیتهائی برای گروهی که می‌شنوند
  30,24,و از آیتهایش بنماید به شما برق را بیمی و امیدی و بفرستد از آسمان آبی که زنده سازد بدان زمین را پس از مردنش همانا در این است آیتهائی برای گروهی که بخرد یابند
  30,25,و از آیتهایش آنکه بپا ایستد آسمان و زمین به فرمانش تا گاهی که بخواند شما را خواندنی از زمین ناگاه برون آئید
  30,26,و او را است آنکه در آسمانها و زمین است همگانند برای او فروتنان‌
  30,27,و او است آنکه آغاز کند آفرینش را پس بازگرداندش و آن آسانتر است بر او و برایش مثل برتر است در آسمانها و زمین و او است عزّتمند حکیم‌
  30,28,زده است برای شما مثَلی از خود شما آیا شما را است از آنچه مالک است یمینهای شما شریکانی در آنچه روزیتان دادیم که شمائید در آن یکسان همی‌ترسیدشان همانند ترستان از خویشتن بدینگونه تفصیل دهیم آیتها را برای گروهی که بخرد یابند
  30,29,بلکه پیروی کردند آنان که ستم کردند هوسهای خویش را به نادانی پس که راهنمائی کند آن را که گمراه ساخت خدا و نیست ایشان را یاورانی‌
  30,30,پس راست کن روی خود را بسوی دین یکتاپرست آفرینش خدائی که سرشت مردم را بر آن نیست دگرگون‌شدنی برای آفرینش خدا این است دین استوار و لیکن بیشتر مردم نمی‌دانند
  30,31,زاری‌کنندگان به سویش و بترسیدش و بپای دارید نماز را و نباشید از شرک‌ورزان‌
  30,32,از آنان که پراکنده ساختند دین خود را و گشتند گروه‌هائی هر حزبی است بدانچه نزد خویش است شادمان‌
  30,33,و هر گاه رسد مردم را رنجی خوانند پروردگار خود را زاری کنان بسویش تا آنگاه که چشاندشان از خویش رحمتی ناگهان گروهی از ایشانند به پروردگار خویش شرک‌ورزان‌
  30,34,تا کفر ورزند بدانچه آوردیمشان پس بهره‌مند باشید زود است بدانید
  30,35,یا فرستادیم بر ایشان فرمانی که سخن گوید بدانچه بودند بدان شرک‌ورزان‌
  30,36,و هر گاه چشانیم مردم را رحمتی شادمان شوند بدان و اگر رسدشان بدیی بدانچه پیش فرستاد دستهاشان ناگاه ایشانند نومیدان‌
  30,37,آیا ندیدند که خدا فراخ گرداند روزی را برای هر که خواهد و تنگ سازد همانا در این است آیتهائی برای گروهی که ایمان آرند
  30,38,پس بده به خویشاوندان بهره‌اش را و بینوا و وامانده در راه این نکوتر است برای آنان که خواهانند روی خدا و آنانند رستگاران‌
  30,39,و آنچه آرید از ربایی (سود) که بیفزاید در مالهای مردم پس فزونی نگیرد نزد خدا و آنچه آرید از زکاتی که خواهید بدان روی خدا را پس آنانند فزونی‌گیرندگان‌
  30,40,خدا است آنکه آفرید شما را پس روزیتان داد پس بمیراند شما را و سپس زنده سازدتان آیا هست از شریکان شما آنکه بکند از اینها چیزی را او منزّه و برتر است از آنچه شرک می‌ورزند
  30,41,پدیدار شد تباهی در دشت و دریا بدانچه فراهم کرد دستهای مردم تا چشاندشان پاره‌ای از آنچه کردند شاید بازگردند
  30,42,بگو بگردید در زمین پس بنگرید چگونه بود فرجام آنان که از پیش بودند بیشتر ایشان شرک‌ورزندگان‌
  30,43,پس راست کن روی خود را بسوی دین استوار پیش از آنکه بیاید روزی که نیستش بازگشتی از خدا آن روز شکافته شوند از هم‌
  30,44,هر که کفر ورزد پس بر او است کفرش و هر که کار نکو کند پس برای خویش آماده می‌کنند
  30,45,تا پاداش دهد آنان را که ایمان آوردند و کارهای نکو کردند از فضلش همانا او دوست ندارد کافران را
  30,46,و از آیتهایش آنکه بفرستد بادها را مژده‌دهندگان و تا چشاندتان از رحمتش و تا روان شود کشتی به فرمانش و تا جوئید روزی را از فضلش و شاید سپاسگزارید
  30,47,و هر آینه فرستادیم پیش از تو فرستادگانی بسوی قوم خویش پس بیامدندشان به روشنائیها پس انتقام گرفتیم از آنان که گناه کردند و هست حقّی بر ما یاری کردن مؤمنان‌
  30,48,خدا است آنکه می‌فرستد بادها را پس برانگیزد ابری پس پهن سازدش در آسمان هر گونه خواهد و بگرداندش پاره‌هائی و بینی باران را برون آید از شکافهایش تا گاهی که رساندش به هر که خواهد از بندگان خویش ناگاه ایشانند شادمانی‌کنان‌
  30,49,و اگرچه بودند پیش از آنکه فرستاده شود بر ایشان پیش از آن پژمردگان‌
  30,50,پس بنگر بسوی آثار رحمت خدا چسان زنده سازد زمین را پس از مرگش همانا آن است زنده‌سازنده مردگان و او است بر همه چیز توانا
  30,51,و اگر بفرستیم بادی که نگرندش زردفام همانا آغاز کنند پس از آن کفران‌کنندگان‌
  30,52,هرآینه تو نشنوانی مردگان را و نشنوانی به کران بانگ را گاهی که بازگردند پشت‌کنندگان‌
  30,53,و نیستی تو راهنمای کوران از گمراهیشان نشنوانی مگر آن را که ایمان آورد به آیتهای ما پس آنانند اسلام‌آرندگان‌
  30,54,خدا است آنکه آفرید شما را از سستی پس قرار داد پس از سستی توانائی پس قرار داد پس از نیرومندی سستی و پیری را می‌آفرد هر چه خواهد و او است دانای توانا
  30,55,و روزی که بپا شود ساعت سوگند یاد کنند و همراهیشان کن ماندند جز ساعتی بدینسان بودند به دروغ رانده می‌شدند
  30,56,و گفتند آنان که داده شدند دانش و ایمان را همانا شما درنگ کردید در کتاب خدا تا روز برانگیختن پس این است روز برانگیختن لیکن بودید شما نمی‌دانستید
  30,57,پس آن روز سود ندهد آنان را که ستم کردند بهانه آوردنشان و نه بازخواست شوند
  30,58,و هر آینه زدیم برای مردم در این قرآن از هر مثَلی و اگر بیاریشان آیتی همانا گویند آنان که کفر ورزیدند نیستید شما جز نادرستان‌
  30,59,چنین مُهر نهد خدا بر دلهای آنان که نمی‌دانند
  30,60,پس شکیبا شو که وعده خدا است حقّ و سبکسارت نکنند آنان که نیستند یقین‌دارندگان‌
  31,1,الم‌
  31,2,این است آیتهای کتاب استوار
  31,3,راهنمائی و رحمتی برای نیکوکاران‌
  31,4,آنان که بپای دارند نماز را و دهند زکات را و ایشانند به آخرت یقین‌دارندگان‌
  31,5,آنانند بر هدایتی از پروردگارشان و آنانند رستگاران‌
  31,6,و از مردم است آنکه می‌خرد داستانهای بیهوده (سخنهای هوسناک) را تا گمراه کند از راه خدا به نادانی و بگیرد آنها را به استهزاء آنان را است عذابی خوارکننده‌
  31,7,و گاهی که خوانده شود بر او آیتهای ما پشت کند کبرورزنده چنانکه گوئی نشنیده است آن را گوئی که در گوشهایش است سنگینی پس نویدش ده به عذابی دردناک‌
  31,8,همانا آنان که ایمان آوردند و کارهای شایسته کردند ایشان را است باغستان نعمتها
  31,9,جاودانان در آن وعده خدا به درست و او است عزتمند حکیم‌
  31,10,آفرید آسمانها را بی‌ستونی که بینیدش و افکند در زمین لنگرهائی نبادا کج شود به شما و پراکند در آن از هر جنبنده‌ای و فرستادیم از آسمان آبی پس رویانیدیم در آن از هر جفتی گرامی‌
  31,11,این است آفرینش خدا پس بنمایانیدم چه چیز آفریدند آنان که جز اویند بلکه ستمگرانند در گمراهیی آشکار
  31,12,و همانا دادیم به لقمان حکمت را که سپاسگزار برای خدا و آنکه سپاس گزارد جز این نیست که سپاس گزارد برای خویش و آنکه ناسپاسی ورزد همانا خدا است بی‌نیاز ستوده‌
  31,13,و گاهی که گفت لقمان به فرزند خود و اندرزش همی‌داد ای پسرک من شرک نورز به خدا همانا شرک است ستمی بزرگ‌
  31,14,و اندرز گفتیم انسان را در باره پدر و مادر بارور گشت بدو مادرش سستی ای بر سستی ای و از شیر بازگرفتنش در دو سال که شکرگزار برای من و برای پدر و مادر خویش بسوی من است بازگشت‌
  31,15,و اگر کوشیدند با تو که شرک ورزی با من آنچه را نیستت بدان دانشی پس فرمانبرداریشان نکن و همراهیشان کن در دنیا به خوشی و پیروی کن راه آن را که بازگشت کند بسوی من بسوی من است بازگشت شما پس آگهیتان دهم بدانچه بودید می‌کردید
  31,16,ای پسرک من همانا آن اگر باشد به سنگینی دانه‌ای از خردل پس باشد در سنگی خارا یا در آسمانها یا در زمین بیاردش خدا همانا خدا است بخشنده آگاه‌
  31,17,ای پسرک من بپای دار نماز را و فرمان کن به نیکی و بازدار از بدی و شکیبا شو بر آنچه رسدت همانا این است از عزیمت کارها
  31,18,و دژم نساز روی خود را برای مردم و نرو در زمین خرامان همانا خدا دوست ندارد آن را که خرامانی خودپسند است‌
  31,19,و میانه‌رو باش در روش خویش و فرو کش از آواز خویش همانا ناخوشترین آوازها آواز خران است‌
  31,20,آیا نبینید که خدا رام کرد برای شما آنچه در آسمانها و آنچه در زمین است و فراوان کرد بر شما روزیهای خویش را آشکار و نهان و از مردم است آنکه بستیزد در خدا بی دانشی و نه رهبریی و نه کتابی درخشان‌
  31,21,و اگر گفته شود بدیشان پیروی کنید آنچه را فرستاد خدا گویند بلکه پیروی کنیم آنچه یافتیم پدران خویش را بر آن و اگر چه باشد شیطان بخواندشان بسوی عذاب سوزان‌
  31,22,و آنکه تسلیم کند روی خود را بسوی خدا و او است نکوکار همانا پناه جست به دستاویزی استوار و بسوی خدا است فرجام کارها
  31,23,و آنکه کفر ورزد اندوهگین نسازدت کفرش بسوی ما است بازگشت ایشان تا آگهیشان دهیم بدانچه کردند همانا خدا دانا است به راز سینه‌ها
  31,24,بهره‌مندشان سازیم اندکی و سپس ناگزیرشان سازیم بسوی عذابی انبوه‌
  31,25,و اگر پرسیشان که آفرید آسمانها و زمین را هر آینه گویند خدا بگو سپاس خدا را بلکه بیشتر ایشان نمی‌دانند
  31,26,خدای را است آنچه در آسمانها و زمین است همانا خدا است بی‌نیاز ستوده‌
  31,27,و اگر باشد آنچه در زمین است از درخت قلمهائی و دریا را کمک کند از پس آن هفت دریا پایان نیابد سخنان خدا همانا خدا است عزّتمند حکیم‌
  31,28,نیست آفرینش شما و نه برانگیختن شما مگر چون یک تن همانا خدا است شنوای بینا
  31,29,آیا نبینی خدا فرو می‌برد شب را در روز و فرو می‌برد روز را در شب و رام کرد مهر و ماه را هر کدام روان است بسوی سرآمدی نامبرده و آنکه خدا است به آنچه می‌کنید آگاه‌
  31,30,این بدان است که خدا است حقّ و هر چه خوانند جز او باطل است و آنکه خدا است مهتر بزرگ‌
  31,31,آیا ندیدی کشتی روان است در دریا به نعمت خدا تا بنمایاند شما را از آیتهایش همانا در این است آیتهائی برای هر شکیبائی سپاسگزار
  31,32,و هر گاه فراگیردشان موجی چون توده‌های ابر خوانند خدا را پاک‌دارنده برایش دین را و هنگامی که رهانیدشان بسوی خشکی از ایشان است میانه‌روی و نستیزد با آیتهای ما جز هر پیمان‌شکنی ناسپاس‌
  31,33,ای مردم بترسید پروردگار خود را و بترسید از روزی که بی‌نیاز نگرداند پدری از فرزند خویش و نه فرزندی که بی‌نیاز کند از پدر خود چیزی را همانا وعده خدا است حقّ پس نفریبد شما را زندگانی دنیا و نفریبد شما را به خدا فریبنده (سرگرمی)
  31,34,همانا خدا نزد او است علم ساعت و فرود آورد باران را و داند آنچه را در زهدانها است و نداند کسی چه چیز فراهم می‌آورد فردا و نداند کسی به کدام زمین می‌میرد همانا خدا است دانای آگاه‌
  32,1,الم‌
  32,2,فرود آوردن کتاب نیست شکی در آن از پروردگار جهانیان‌
  32,3,یا گویند دروغ بست آن را بلکه آن است حقّ از پروردگارت تا بترسانی گروهی را که نیامدستشان بیم‌دهنده‌ای پیش از تو شاید ایشان رهبری شوند
  32,4,خدا است آنکه آفرید آسمانها و زمین را و آنچه میان آنها است در شش روز سپس استوار شد بر عرش نیست شما را جز او دوست و نه شفاعتگری پس آیا یادآور نمی‌شوید
  32,5,بپردازد کار را از آسمان بسوی زمین سپس بالا رود بسویش در روزی که اندازه آن هزار سال است از آنچه می‌شمرید
  32,6,این است دانای نهان و هویدا آن عزتمند مهربان‌
  32,7,آنکو نکو کرد هر چیزی آفرینش آن را و آغاز کرد آفرینش انسان را از گل‌
  32,8,پس گردانید نژادش را از چکه‌ای از آبی پست‌
  32,9,سپس آراستش و دمید در آن از روح خویش و گذاشت برای شما گوش و دیدگان و دلها را به کمی سپاس گزارید
  32,10,و گفتند آیا هر گاه گم شدیم در زمین آیا مائیم در آفرینشی نوین بلکه ایشانند به ملاقات پروردگار خویش کافران‌
  32,11,بگو دریابد شما را فرشته مرگ که گمارده شده است بر شما سپس بسوی پروردگار خویش بازگردانیده شوید
  32,12,و اگر بینی هنگامی که گنهکاران سرافکندگانند نزد پروردگارشان پروردگارا دیدیم و شنیدیم پس برگردان ما را تا بکنیم کاری شایسته همانا مائیم یقین‌دارندگان‌
  32,13,و اگر می‌خواستیم هر آینه می‌دادیم به هر کس رهبریش را و لیکن استوار گشت سخن از من که همانا پر سازم دوزخ را از پریان و مردم همگی‌
  32,14,پس بچشید بدانچه فراموش کردید رسیدن را به روزتان این همانا ما فراموشتان کردیم و بچشید عذاب دوزخ را بدانچه بودید می‌کردید
  32,15,جز این نیست که ایمان آرند به آیتهای ما آنان که هر گاه یادآوری شوند بدانها بیفتد سجده‌کنان و تسبیح گویند به سپاس پروردگار خویش و ایشانند کبرناورزندگان‌
  32,16,دوری گزیند پهلوهای ایشان از خوابگاه‌ها خوانند پروردگار خویش را بیمی و امیدی و از آنچه روزیشان دادیم ببخشند
  32,17,پس نمی‌داند کسی چه نهان شده است برای ایشان از روشنی‌چشم پاداشی بدانچه بودند می‌کردند
  32,18,پس آیا آنکه مؤمن است مانند آنی است که نابفرمان است نیستند یکسان‌
  32,19,اما آنان که ایمان آوردند و کردار شایسته کردند پس ایشان را باغستان جایگاه پیشکشی بدانچه بودند می‌کردند
  32,20,و اما آنان که نافرمانی کردند پس جایگاه ایشان است آتش هر گاه خواهند برون آیند از آن بازگردانیده شوند در آن و گفته شود برای ایشان بچشید عذاب آتشی را که بودید بدان تکذیب می‌کردید
  32,21,و همانا بچشانیمشان از شکنجه نزدیک نارسیده به شکنجه بزرگ باشد ایشان بازگردند
  32,22,و کیست ستمگرتر از آنکه یادآوری شود به آیتهای پروردگار خویش پس روی برتابد از آنها همانا مائیم از گنهکاران کین‌کشندگان‌
  32,23,و همانا دادیم به موسی کتاب را پس نباش در شکی از ملاقاتش و گردانیدیمش رهبریی برای بنی‌اسرائیل‌
  32,24,و گردانیدیم از ایشان پیشوایانی که راهنمائی می‌کنند به فرمان ما چنانکه شکیبائی کردند و بودند به آیتهای ما یقین‌دارندگان‌
  32,25,و همانا پروردگارت جدائی افکند میانشان روز رستاخیز در آنچه بودند در آن اختلاف می‌کردند
  32,26,آیا رهبریشان نکرد که بسا نابود ساختیم پیش از ایشان از قرنهائی که روانند در آرامگاه‌های آنان همانا در این است آیتهائی آیا نمی‌شنوند
  32,27,آیا ندیدند که روان می‌سازیم آب را بسوی زمینی خشکزار پس برون آریم بدان کشتی را که می‌خورند از آن دامهای ایشان و ایشان پس آیا نمی‌نگرند
  32,28,و گویند کی است این گشایش (یا پیروزی) اگر هستید راستگویان‌
  32,29,بگو روز پیروزی سود ندهد آنان را که کفر ورزیدند ایمانشان و نه مهلت داده شوند
  32,30,پس روی برتاب از ایشان و منتظر باش که ایشانند منتظران‌
  33,1,ای پیمبر بترس خدا را و فرمانبردار نباش کافران و دورویان را همانا خدا است دانشمند حکیم‌
  33,2,و پیروی کن آنچه وحی شود بسویت از پروردگار خویش همانا خدا است بدانچه می‌کنید آگاه‌
  33,3,و توکل کن بر خدا و بس است خداوند وکیل‌
  33,4,ننهاد خدا برای مردی دودل در اندرونش و نگردانید خدا همسران شما را آنان که ظهار کنید از ایشان مادران شما و نگردانید پسرخواندگان شما را فرزندان شما این گفتار شما است با دهانهای شما و خدا گوید حقّ را و او است هدایت‌کننده به راه‌
  33,5,بخوانید ایشان را برای پدران ایشان آن دادگرانه‌تر است نزد خدا پس اگر ندانستید پدران ایشان را پس برادران شمایند در دین و بندگان شما و نیست بر شما پروائی در آنچه خطا کردید بدان و لیکن آنچه خواست دلهای شما و خدا است آمرزنده مهربان‌
  33,6,پیمبر سزاوارتر است به مؤمنان از خود ایشان و زنان او مادران ایشانند و خویشاوندان برخیشان سزاوارترند به برخی در کتاب خدا از مؤمنان و مهاجران مگر آنکه کنید در باره دوستانتان نکوئی بوده است آن در کتاب نوشته‌
  33,7,و هنگامی که بگرفتیم از پیمبران پیمانشان را و از تو و از نوح و ابراهیم و موسی و عیسی ابن مریم و گرفتیم از ایشان پیمانی گران‌
  33,8,تا بپرسد راستگویان را از راستیشان و آماده کرد برای کافران عذابی دردناک‌
  33,9,ای آنان که ایمان آوردید یاد آرید نعمت خدا را بر خویش گاهی که بیامد شما را لشکرهائی پس فرستادیم بر آنان بادی و لشکرهائی که ندیدید و خدا است بدانچه می‌کنید بینا
  33,10,گاهی که آمدند شما را از فراز شما و از زیر شما و گاهی که گردیدند دیدگان و رسید دلها گلوگاه‌ها را و گمان می‌بردید به خدا گمانها را
  33,11,آنجا (یا آنگاه) آزمایش شدند مؤمنان و لرزیدند لرزشی سخت‌
  33,12,و هنگامی که می‌گفتند مردمان دوروی و آنان که در دلهاشان بیماری است که وعده نداد ما را خدا و پیمبرش مگر فریبی را
  33,13,و هنگامی که گفتند گروهی از ایشان ای مردم یثرب نیست جایگاهی برای شما پس بازگردید و دستوری می‌خواست گروهی از ایشان از پیمبر می‌گفتند همانا خانه‌های ما برهنه است و نیستند آنها برهنه و نخواهند جز گریزی را
  33,14,و اگر ورود شود بر ایشان در آنها از هر سوی سپس درخواست شوند فتنه (جنگ) را هر آینه آرندش و درنگ نکنند بدان مگر اندکی‌
  33,15,و همانا بودند پیمان بستند با خدا از پیش که برنتابند پشتها را و هست پیمان خدا پرسش‌شده‌
  33,16,بگو سود ندهد شما را گریز اگر بگریزید از مرگ یا کشتن و آن هنگام کامیاب نشوید مگر اندکی‌
  33,17,بگو کیست که نگهدارد شما را از خدا اگر خواهد به شما رنجی یا خواهد برای شما رحمتی و نیابید برای خویش جز خدا دوست و نه یاوری را
  33,18,بسا داند خدا بازدارندگان را از جنگ از شما و گویندگان را به برادران خویش بیائید بسوی ما و نیایند نبرد را جز اندکی‌
  33,19,بخل ورزانند بر شما تا گاهی که بیاید ترس بینیشان بنگرند در تو می‌گردد دیدگانشان مانند آنکه فراگرفته باشدش مرگ تا گاهی که برود ترس آزارتان کنند با زبانهائی تیز خوددارانند از نیکی آنان ایمان نیاوردند پس تباه ساخت خدا کردار ایشان را و آن است بر خدا آسان‌
  33,20,پندارند احزاب را نرفتند و اگر بیایند احزاب دوست دارند کاش برون بودند در مردم دشت‌نشین و از دور اخبار شما را می‌پرسیدند و اگر می‌بودند در شما پیکار نمی‌کردند جز اندکی‌
  33,21,همانا شما را است در پیمبر خدا پیرویی نکو برای آن که امید دارد خدا و روز بازپسین را و یاد کند خدا را بسیار
  33,22,و هنگامی که دیدند مؤمنان احزاب را گفتند این است آنچه وعده داد به ما خدا و پیمبرش و راست گفت خدا و پیمبرش و نیفزود ایشان را مگر ایمان و تسلیمی‌
  33,23,از مؤمنانند مردانی که راست گفتند آنچه را با خدا پیمان بر آن بستند پس از ایشان است آنکه گذراند پیمان خویش را و از ایشان است آنان که انتظار کشند و تبدیل نکردند تبدیلی‌
  33,24,تا پاداش دهد خدا راستگویان را به راستیشان و عذاب کند دورویان را اگر خواهد یا توبه پذیرد از ایشان همانا خدا است آمرزنده مهربان‌
  33,25,و بازگردانید خدا آنان را که کفر ورزیدند به خشمشان نرسیدند به خیری و کفایت کرد خدا مؤمنان را از جنگ و خدا است نیرومند عزیز
  33,26,و فرود آورد آنان را که پشتیبانیشان کردند از اهل کتاب از کاخهای ایشان و افکند در دلهای آنان هراس را که گروهی را کشتید و برده گرفتید گروهی را
  33,27,و ارث داد به شما سرزمین ایشان و خانه‌های ایشان و خواسته‌های ایشان را و سرزمینی را که تاخت نیاوردید بر آن و خداست بر همه چیز توانا
  33,28,ای پیمبر بگو به زنان خویشتن اگر خواهان زندگانی دنیا و زیور آنید پس بیائید بهره‌مند سازم شما را و رها سازم شما را رهاکردنی نیکو
  33,29,و اگر خواستار خدا و پیمبرش و خانه آخرت باشید پس خدا آماده کرده است برای نکوکاران از شما پاداشی بزرگ را
  33,30,ای زنان پیمبر هر کس از شما فحشایی (ناشایستی) آشکار آرد افزوده شود برایش شکنجه به دو برابر و همانا آن است بر خدا آسان‌
  33,31,و آنکه فروتنی کند از شما برای خدا و پیمبرش و کرداری شایسته کند دهیمش مزدش را دوبار و آماده کردیم برای او روزیی گرامی را
  33,32,ای زنان پیمبر نیستید شما مانند یکی از زنان اگر می‌ترسید خدا را پس نرمی نشان ندهید در گفتار تا امید بندد آنکه در دلش بیماریی است و بگوئید گفتاری نکو را
  33,33,و بیارمید در خانه‌های خویش و خودنمائی نکنید مانند خودنمائی جاهلیت نخستین (پیکر خود را آشکار نسازید) و بپای دارید نماز را و بدهید زکات را و فرمانبرداری کنید از خدا و پیمبرش جز این نیست که خواهد خدا دور کند از شما چرک (پلیدی) را ای اهل خانه و پاک سازد شما را پاک ساختنی‌
  33,34,و یادآرید آنچه را خوانده می‌شود در خانه‌های شما از آیتهای خدا و حکمت همانا خداوند است تیزبین کارآگاه‌
  33,35,همانا مردان مسلمان و زنان مسلمان و مردان مؤمن و زنان مؤمن و مردان فروتن و زنان فروتن و مردان راستگو و زنان راستگو و مردان شکیبا و زنان شکیبا و مردان نرم‌دل و زنان نرم‌دل و مردان بخشنده و زنان بخشنده و مردان روزه‌دار و زنان روزه‌دار و مردانی که فرجهای خود را نگه دارند و زنان نگهدارنده و مردانی که یاد خدا بسیار کنند و زنان یادکننده آماده کرده است خدا برای ایشان آمرزشی و پاداشی بزرگ را
  33,36,و نرسد مرد مؤمن و نه زن مؤمنی را که هر گاه بگذارند خدا و پیمبرش کاری را آنکه باشد برای ایشان اختیاری در کار خویش و آنکه سر از فرمان خدا و پیمبرش برتابد همانا گمراه شده است گمراهی آشکار
  33,37,و هنگامی که می‌گفتی بدان که نعمت داده بود خدا بدو و نعمت داده بودی تو بدو نگهدار نزد خویش همسر خود را و بترس خدا را و نهان می‌داشتی نزد خود آنچه خدا است آشکارکننده آن و می‌ترسیدی مردم را و خدا سزاوارتر است که بترسیش تا گاهی که بگذرانید زید از آن زن حاجت را همسر تو گردانیدیمش تا نباشد بر مؤمنان سخت‌گیریی در زنان پسرخواندگانشان گاهی که بگذرانند از آنان حاجت را و بوده است کار خدا شدنی‌
  33,38,نیست بر پیمبر پروائی (سخت‌گیریی) در آنچه بایسته داشت خدا برایش شیوه خدا در آنان که گذشتند از پیش و بوده است کار خدا اندازه‌ای گذارده‌
  33,39,آنان که رسانند پیامهای خدا را و ترسندش و نترسند کسی را جز خدا و بس است خدا حساب‌گیرنده‌
  33,40,نیست محمد (صلی اللّه علیه و آله) پدر یکی از مردان شما و لیکن پیمبر خدا و سرآمد پیمبران و بوده است خدا به همه چیز دانا
  33,41,ای آنان که ایمان آوردید یاد کنید خدا را یادکردنی فراوان‌
  33,42,و تسبیحش گویید بامدادان و شامگاهان‌
  33,43,او است آنکه درود (آمرزش) فرستد بر شما او و فرشتگانش تا برون آرد شما را از تاریکیها بسوی روشنائی و بوده است به مؤمنان مهربان‌
  33,44,درودشان روزی که بدو رسند سلام است و آماده کرد برای ایشان پاداشی گرامی را
  33,45,ای پیمبر همانا فرستادیمت گواهی و مژده‌رسانی و بیم‌دهنده‌ای‌
  33,46,و خواننده‌ای بسوی خدا به فرمانش و چراغی درخشان‌
  33,47,و مژده ده به مؤمنان که آنان را است از نزد خدا فضلی بزرگ‌
  33,48,و فرمانبرداری مکن کافران و دورویان را و رها کن آزردن ایشان را و توکّل کن بر خدا و بس است خدا وکیلی‌
  33,49,ای آنان که ایمان آوردید هر گاه کابین بستید بر زنان مؤمنه پس رهاشان ساختید پیش از آنکه بدیشان نزدیکی کنید پس نیست شما را بر ایشان سرآمدی که در انتظارش نشینید پس بهره بدیشان دهید و رهاشان کنید رهائیی نکو
  33,50,ای پیمبر همانا حلال ساختیم برایت همسران تو را آنان که مزد ایشان را پرداختی و آنچه را مالک است یمین تو از آنچه خدا بهره جنگ به تو ارزانی داشت و دختران عمّت را و دختران عمّه‌هایت را و دختران خالت را و دختران خاله‌هایت را که هجرت کردند با تو و زنی مؤمنه را اگر ببخشد خویشتن را به پیمبر اگر خواهد پیمبر که همسر گیردش تنها از آن تو است این و نرسد به مؤمنان همانا دانستیم آنچه را بایسته کردیم بر ایشان در همسرانشان و آنچه دارا است دستهای ایشان تا نباشد بر تو سخت آمدنی و بوده است خدا آمرزنده مهربان‌
  33,51,برانی آن را که خواهی از آن زنان و نزد خویش جای دهی هر که را خواهی از ایشان و هر که را خواهی از آنان که دور کردی پس نیست باکی بر تو این است نزدیکتر بدان که روشن شود دیدگانشان و اندوهگین نشوند و خرسند شوند بدانچه دادیشان همگی ایشان و خدا می‌داند آنچه را در دلهای شما است و خدا است دانای بردبار
  33,52,حلال نیست برایت زنان از این پس و نه آنکه برگزینی به جای آنان همسرانی و هر چند خوش آیدت زیبائی آنان جز آنکه دارا شود دستت و خدا است بر همه چیز نگهبان‌
  33,53,ای آنان که ایمان آوردید درنیائید به خانه‌های پیمبر جز آنکه دستور داده شود به شما بسوی خوراکی نانگرانان بجای آن و لیکن هر گاه خوانده شدید درآئید و هر گاه خوردید پس پراکنده شوید و نه انس‌گیرندگان به سخنی همانا این آزار می‌داد پیمبر را و او شرم می‌داشت از شما و خدا پروا ندارد از حقّ و هر گاه خواستار کالایی باشید از ایشان پس بخواهید از ایشان از پشت پرده (پوششی) این پاکتر است برای دلهای شما و دلهای آنان و نرسد شما را که بیازارید پیمبر خدا را و نه آنکه همسر گیرید زنانش را از پس او هیچگاه همانا آن است نزد خدا گران (بزرگ)
  33,54,اگر آشکار سازید چیزی را یا نهان داریدش همانا خدا است به همه چیز دانا
  33,55,پروائی نیست بر آن زنان در پدران ایشان و نه فرزندان ایشان و نه برادران ایشان و نه برادرزادگان ایشان و نه خواهرزادگان ایشان و نه زنان ایشان و نه آنچه دارا است دستهای ایشان و بترسید ای زنان خدا را که خدا است بر همه چیز گواه‌
  33,56,همانا خدا و فرشتگانش درود (آمرزش) فرستند بر پیمبر ای آنان که ایمان آوردید درود فرستید بر او و سلام کنید سلام کردنی (فرمانش را گردن نهید گردن‌نهادنی)
  33,57,همانا آنان که بیازارند خدا و پیمبرش لعن کرد ایشان را خدا در دنیا و آخرت و آماده کرد برای ایشان عذابی خوارسازنده را
  33,58,و آنان که بیازارند مردان و زنان مؤمن را بجز آنچه فراهم کردند همانا برداشتند تهمتی و گناهی آشکار را
  33,59,ای پیمبر بگو به زنان خویش و دختران خویش و زنان مؤمنین که فروهلند بر خویشتن از روپوششهای خویش این نزدیکتر است بدان که شناخته شوند پس آزار نشوند و خدا است آمرزنده مهربان‌
  33,60,اگر کوتاه نیایند (پس نکنند) دورویان و آنان که در دلهاشان بیماری است و هرزه درآیان در شهر (اراجیف‌گویان) هرآینه بشورانیمت بر آنان تا همسایگیت نکنند در آن مگر اندکی‌
  33,61,لعن شدگان (راندگان) هر کجا یافت شوند دستگیر شوند و سخت کشته شوند کشته‌شدنی‌
  33,62,شیوه خدا در آنان که گذشتند از پیش و هرگز نیابی شیوه خدا را دگرگونی‌
  33,63,پرسندت مردم از ساعت بگو جز این نیست که علم آن نزد خدا است و چه دانی تو (یا چه دانا سازدت) شاید ساعت است نزدیک‌
  33,64,همانا خدا لعن کرد کافران و آماده کرد برای ایشان آتشی سوزان‌
  33,65,جاودانان در آن همیشه نیابند یاری و نه یاوری را
  33,66,روزی که گردش داده شود رویهای ایشان در آتش گویند کاش فرمانبرداری می‌کردیم خدا را و فرمانبرداری می‌کردیم پیمبر را
  33,67,و گفتند پروردگارا همانا فرمان بردیم مهتران خویش و بزرگان خویش را پس گمراه ساختند ما را از راه‌
  33,68,پروردگارا بدیشان دو برابر فرما از عذاب و لعن کن ایشان را لعنی بزرگ‌
  33,69,ای آنان که ایمان آوردید نباشید مانند آنان که آزردند موسی را پس بیزار شمردش خدا از آنچه گفتند و بود نزد خدا آبرومند
  33,70,ای آنان که ایمان آوردید بترسید خدا را و بگوئید گفتاری استوار
  33,71,تا ساز آرد برای شما کارهای شما را و بیامرزد گناهان شما را و آنکه فرمان برد خدا و پیمبرش را همانا رستگار شده است رستگاریی بزرگ‌
  33,72,همانا عرض کردیم سپرده را بر آسمانها و زمین و کوه‌ها پس نیارستند برداشتنش را و بیمناک شدند از آن و برداشتش انسان همانا او بوده است ستمگری نادان‌
  33,73,تا عذاب کند خدا مردان دوروی و زنان دوروی را و مردان مشرک و زنان مشرک را و بازگشت کند خدا بر مردان و زنان مؤمن و بوده است خدا آمرزنده مهربان‌
  34,1,سپاس خدای را که از آنِ وی است آنچه در آسمانها و آنچه در زمین است و او را است سپاس در آخرت و او است حکیم آگاه‌
  34,2,داند آنچه را فرو می‌رود در زمین و آنچه برون آید از آن و آنچه فرود آید از آسمان و آنچه بالا رود در آن و او است مهربان آمرزنده‌
  34,3,و گفتند آنان که کفر ورزیدند نیاید ما را ساعت بگو بلی سوگند به پروردگارم هر آینه بیاید شما را دانای نهان است گم نشود از او سنگینی ذرّه‌ای در آسمانها و نه در زمین و نه کوچکتر از آن و نه بزرگتر مگر در کتابی است آشکار
  34,4,تا پاداش دهد آنان را که ایمان آوردند و کردار شایسته کردند ایشان را است آمرزشی و روزیی گرامی‌
  34,5,و آنان که کوشیدند در آیتهای ما به عجزآرندگان ایشان را است عذابی از پلید دردناک‌
  34,6,و بینند آنان که داده شدند دانش را که آنچه فرستاده شد بسویت از پروردگارت حقّ است و راهنمائی کند بسوی راه خدای عزّتمند ستوده‌
  34,7,و گفتند آنان که کفر ورزیدند آیا ننمایانیم به شما مردی را که آگهیتان دهد هر گاه پراکنده شدید مُنتهای پراکندگی را همانا شمائید در آفرینشی نوین‌
  34,8,آیا دروغی بر خدا بسته است یا بدو دیوانگی است بلکه آنان که باور ندارند بازپسین را در شکنجه و گمراهی دورند
  34,9,آیا ننگرند بدانچه پیش روی ایشان است و آنچه پشت سر ایشان است از آسمان و زمین که اگر خواهیم فروبریمشان در زمین یا افکنیم بر ایشان پاره‌هائی از آسمان همانا در این است آیتی برای هر بنده بازگشت‌کننده‌
  34,10,و همانا دادیم داود را از خویش فضلی ای کوه‌ها تسبیح گوئید با او و مرغان و نرم ساختیم برایش آهن را
  34,11,که بساز زره‌هائی آراسته و اندازه بگذار در زره و بکنید شایسته که همانا منم بدانچه می‌کنید بینا
  34,12,و برای سلیمان باد را پیشینش یک ماه و پسینش یک ماه و روان (ذوب) ساختیم برایش چشمه مس را و از پریان آنان را که کار می‌کردند پیش رویش به دستور پروردگار او و آنکو کجروی می‌کرد از ایشان از فرمان ما می‌چشاندیمش از عذابی سوزان‌
  34,13,می ساختند برایش هر چه می‌خواست از پرستشگاه‌ها و پیکرها و جامه‌هائی همانند آبگیرها (حوضها) و دیگهائی بر جای نشانده (در کوه یا سنگ) بکنید ای خاندان داود شکر را و کم است از بندگان من شکرگزار
  34,14,پس هنگامی که گذراندیم بر او مرگ را رهبریشان نکرد بر مرگش جز جنبنده زمین که می‌خورد چوبدستش را تا گاهی که به روی در افتاد دریافتند پریان که اگر می‌دانستند ناپیدا را نمی‌ماندند در عذابی خوارکننده‌
  34,15,همانا بود سبا را در نشیمنشان آیتی دو باغ از راست و چپ بخورید از روزی پروردگار خویش و سپاس گزارید برایش شهری پاکیزه و پروردگاری آمرزگار
  34,16,پس روی برتافتند پس فرستادیم بر ایشان سیل بیکران را و بدیشان دادیم جای دو باغ ایشان دو باغ دارنده میوه (یا خوراکی) «خمط» و «اثل» و چیزی از درخت سدر اندک‌
  34,17,این را پاداششان دادیم بدانچه کفر ورزیدند و آیا کیفر همی‌دهیم جز به کفرورزنده‌
  34,18,و گذاردیم میان ایشان و میان شهرستانی که برکت نهاده بودیم در آنها شهرهائی پدیدار و مقرّر کردیم در آنها راه‌پیمودن را بروید در آنها شبهائی و روزهائی ایمن‌شدگان‌
  34,19,پس گفتند پروردگارا دوری افکن میان سفرهای ما و ستم کردند خویش را پس گردانیدیمشان داستانهائی و پریشان (پراکنده) ساختیمشان مُنتهای پریشانی را همانا در این است آیتهائی برای هر شکیبائی سپاسگزار
  34,20,و همانا راست آورد بر ایشان ابلیس پندار خویش را پس پیرویش کردند مگر گروهی از مؤمنان‌
  34,21,و نیستش بر ایشان فرمانروائیی مگر تا بشناسیم آن را که ایمان آورد به آخرت از آنکه او است در شکی از آن و پروردگار تو است بر همه چیز نگهبان‌
  34,22,بگو بخوانید آنان را که پنداشتید جز خدا دارا نیستند سنگینی ذرّه در آسمانها و نه در زمین و نیستشان در آنها شرکتی و نیست او را از ایشان پشتیبانی‌
  34,23,و سود ندهد شفاعت نزد او جز برای آنکه دستور دهدش تا گاهی که گرفته شود طپیدن هراس از دلهای ایشان گویند چه گفت پروردگار شما گویند حقّ را و او است برتر بزرگوار
  34,24,بگو که روزیتان دهد از آسمانها و زمین بگو خدا و ما یا شمائیم هر آینه بر هدایتی یا در گمراهی آشکار
  34,25,بگو پرسش نشوید از آنچه ما کردیم و نه پرسش شویم از آنچه شما کنید
  34,26,بگو گردآورد میان ما پروردگار ما سپس بگشاید میان ما به حقّ و او است گشاینده دانا
  34,27,بگو بنمایانیدیم آنان را که پیوستش کردید شریکانی نه چنین است بلکه او است خداوند عزّتمند حکیم‌
  34,28,و نفرستادیم تو را مگر برای همه مردم مژده‌دهنده و ترساننده و لیکن بیشتر مردم نمی‌دانند
  34,29,و گویند چه هنگام است این وعده اگر هستید راستگویان‌
  34,30,بگو شما را است وعده‌گاه روزی که نه دیر کنید از آن ساعتی و نه پیشی گیرید
  34,31,و گفتند آنان که کفر ورزیدند هرگز ایمان نیاریم بدین قرآن و نه بدانچه پیش روی آن است و کاش می‌دیدی گاهی که ستمگران بازداشت شدگانند نزد پروردگار خویش برگردانند برخی از ایشان به برخی گفتار را گویند آنان که ناتوان شمرده شدند بدانان که برتری جستند اگر نبودید شما هرآینه می‌بودیم ما مؤمنان‌
  34,32,گفتند آنان که برتری جستند بدانان که ناتوان شمرده شدند آیا ما بازداشتیم شما را از رهبری پس از آنکه بیامد شما را بلکه بودید شما گنهکاران‌
  34,33,و گفتند آنان که ناتوان شمرده شدند بدانان که کبر ورزیدند بلکه نیرنگ شب و روز بود هنگامی که فرمان می‌دادید ما را که کفر ورزیم به خدا و قرار دهیم برایش همتایانی و نهان داشتند پشیمانی را گاهی که دیدند عذاب را و نهادیم زنجیرها را در گردنهای آنان که کفر ورزیدند آیا پاداش داده شوند جز آنچه را بودند می‌کردند
  34,34,و نفرستادیم در شهری ترساننده‌ای مگر گفتند هوسرانان آنکه مائیم بدانچه فرستاده شدید بدان کافران‌
  34,35,و گفتند ما بیشتریم در مالها و فرزندان و نیستیم ما عذاب‌شدگان‌
  34,36,بگو هر آینه پروردگار من فراخ گرداند روزی را برای هر که خواهد و تنگ کند و لیکن بیشتر مردم نمی‌دانند
  34,37,و نیستند مالهای شما و نه فرزندان شما که نزدیک گردانند شما را نزد ما جایگاهی نزدیک مگر آنکه ایمان آورد و کردار شایسته کرد که آنان را است پاداش دو برابر بدانچه کردند و آنانند در کاخها آرمیدگان‌
  34,38,و آنان که می‌کوشند در آیتهای ما به عجزآرندگان آنانند در عذاب احضارشدگان‌
  34,39,بگو هر آینه پروردگار من گشایش دهد روزی را برای هر که خواهد از بندگان خویش و تنگ گرداند بر او و آنچه دهید از چیزی پس او جانشین (عوض) آردش و او است بهترین روزی‌دهندگان‌
  34,40,و روزی که گرد آردشان همگی سپس گوید به فرشتگان آیا اینان بودند شما را می‌پرستیدند
  34,41,گفتند منزهی تو توئی دوست ما نه آنان بلکه بودند می‌پرستیدند پریان را بیشتر ایشانند بدانان گروندگان‌
  34,42,پس امروز دارا نیست برخی از شما برای برخی سود و نه زیانی و گوئیم بدانان که ستم کردند بچشید عذاب آتشی را که بودید آن را دروغ می‌پنداشتید
  34,43,و گاهی که خوانده شود بر ایشان آیتهای ما روشن گویند نیست این جز مردی که خواهد بازدارد شما را از آنچه بودند می‌پرستیدند پدران شما و گفتند نیست این جز دروغی پرداخته و گفتند آنان که کفر ورزیدند به حقّ گاهی که آمدشان نیست این جز جادوئی آشکار
  34,44,و ندادیمشان کتابهائی که آنها را درس خوانند و نفرستادیم بسوی ایشان پیش از تو ترساننده‌ای‌
  34,45,و تکذیب کردند آنان که پیش از ایشان بودند و نرسیدند ده یک آنچه بدیشان دادیم و تکذیب کردند فرستادگانم را پس چسان است کین‌کشیدن من‌
  34,46,بگو همانا اندرز دهم شما را به یکی که بپای ایستید برای خدا دو دو و یک یک سپس بیندیشید که نیست بر یار شما دیوانگیی نیست او جز ترساننده برای شما پیش روی عذابی سخت‌
  34,47,بگو هر چه خواهم از شما از مزدی پس از آن شما است نیست مزدم جز بر خدا و او است بر همه چیز گواه‌
  34,48,بگو همانا پروردگار من بیفکند حقّ را او است دانای نهانها
  34,49,بگو بیامد حقّ نه آغاز کند باطل و نه بازگرداند
  34,50,بگو اگر گمراه شوم همانا گمراه شوم بر خود و اگر هدایت یابم پس بدان چیز است که وحی فرستد به سویم پروردگارم همانا او است شنوای نزدیک‌
  34,51,و کاش میدیدی گاهی را که هراسان شوند پس نیست گریزی (دررفتنی) و دستگیر شدند از جایگاهی نزدیک‌
  34,52,و گفتند ایمان آوردیم بدان و کجا است ایشان را سودمندشان از جایگاهی دور
  34,53,حالی که کفر ورزیدند بدان از پیش و می‌افکنند به ناپیدا از جایگاهی دور
  34,54,و جدائی افکنده شد میان ایشان و میان آنچه هوس کردند بدانسان که شد به پیروانشان از پیش که ایشان بودند در شکی شک‌آورنده‌
  35,1,سپاس خدا را آفریننده آسمانها و زمین گرداننده فرشتگان فرستادگانی دارندگان بالهائی دوتا و سه‌تا و چهارتا بیفزاید در آفرینش آنچه خواهد همانا خدا است بر همه چیز توانا
  35,2,آنچه بگشاید خدا برای مردم از رحمت نیستش بازدارنده و آنچه بازدارد نیستش رهاکننده‌ای پس از او و او است عزتمند حکیم‌
  35,3,ای مردم یاد آرید نعمت خدا را بر شما آیا هست آفریننده‌ای جز خدا که روزی دهد شما را از آسمان و زمین نیست خدائی جز او پس کجا به دروغ رانده می‌شوید
  35,4,و اگر تکذیبت کنند همانا تکذیب شدند فرستادگانی پیش از تو و بسوی خدا بازگردانیده شوند کارها
  35,5,ای مردم همانا وعده خدا است حقّ پس نفریبد شما را زندگانی دنیا و فریب ندهد شما را به خدا فریب‌دهنده‌
  35,6,همانا شیطان شما را است دشمنی پس برگیریدش دشمن جز این نیست که می‌خواند دسته خویش را تا شوند از یاران آتش سوزان‌
  35,7,آنان که کفر ورزیدند برای ایشان است شکنجه‌ای سخت و آنان که ایمان آوردند و کردار شایسته کردند ایشان را است آمرزشی و مزدی بزرگ‌
  35,8,آیا کسی که آراسته شود برایش بدی کارش پس آن را نکو بیند همانا خدا گمراه سازد هر که را خواهد و هدایت کند هر که را خواهد پس نرود جانت اندوه‌هائی (دریغهایی) بر ایشان همانا خدا دانا است بدانچه می‌سازند
  35,9,و خدا است آنکه فرستاد بادها را پس برانگیزند ابری پس راندیمش بسوی شهری مرده پس زنده سازیم بدان زمین را پس از مرگش چنین است برانگیختن (یا گردآوردن)
  35,10,آنکو عزت جوید پس برای خدا است عزت همگی بسویش بالا رود سخنان پاک و کردار نیک را او بالا برد و آنان که نیرنگهای زشت آرند ایشان را است عذابی سخت و نیرنگ آنان است تباه و نابود
  35,11,و خدا بیافرید شما را از خاکی پس از چکه آبی سپس گردانید شما را جفتهائی و بارور نگردد ماده‌ای و نه بنهد بارش را جز با علم او و سالمند نشود سالمندی و نه کاسته شود از سالش مگر در کتابی است همانا آن است بر خدا آسان‌
  35,12,و یکسان نیستند دو دریا این خوشکام شیرین که گوارا است نوشابه آن و آن نمکی شور (یا تلخ) و از هر یک خورید ماهیی تازه و برون آرید زیوری که پوشیدش و بینی کشتیها را در آن رونده تا بجوئید از فضلش و شاید سپاسگزارید
  35,13,فروبرد شب را در روز و فروبرد روز را در شب و رام گرداند مهر و ماه را هر کدام روانند تا سرآمدی نامبرده این است پروردگار شما وی را است پادشاهی و آنان که خوانید جز او دارا نیستند پوست هسته خرمائی‌
  35,14,اگر بخوانیدشان نشنوند بانگ شما را و اگر می‌شنیدند پاسخ نمی‌گفتندتان و روز قیامت کفران ورزند به شرک‌ورزی شما و آگاه نسازدت همانند کاردان‌
  35,15,ای مردم شمائید نیازمندان به خدا و خدا است بی‌نیاز ستوده‌
  35,16,اگر خواهد ببرد شما را و بیارد آفرینشی نوین‌
  35,17,و نیست آن بر خدا گران‌
  35,18,و برندارد گنهباری بار دیگری را و اگر بخواند گرانباری بسوی بارش برداشته نشود از او چیزی و اگر چه باشد خویشاوند جز این نیست که بیم دهی آنان را که می‌پرستند پروردگار خویش را به نهان و بپای دارند نماز را و آنکه پاکی جوید جز این نیست که برای خویش پاکی جوید و بسوی خداست بازگشت‌
  35,19,یکسان نیستند کور و بینا
  35,20,و نه تاریکیها و نه روشنائی‌
  35,21,و نه سایه و نه سوزش گرما
  35,22,و یکسان نیستند زندگان و نه مردگان همانا خدا می‌شنواند هر که را خواهد و نیستی تو شنواننده آنان که در گورستانند
  35,23,نیستی تو جز بیم‌دهنده‌
  35,24,همانا فرستادیمت به حقّ نویددهنده و ترساننده و نیست ملتی جز آنکه بگذشت در آن ترساننده‌ای‌
  35,25,و اگر تکذیب کنند همانا تکذیب کردند آنان که پیش از ایشان بودند بیامدندشان پیمبرانشان به نشانیها و به کتابها و به نامه درخشان‌
  35,26,سپس برگرفتیم آنان را که کفر ورزیدند پس چگونه بود کیفرم‌
  35,27,آیا ندیدی که خدا فرستاد از آسمان آبی پس برون آوردیم بدان میوه‌هائی به رنگهای گوناگون و از کوه‌ها راه‌هائی سفید و سرخ رنگارنگ و سیاه‌هائی تار
  35,28,و از مردم و جنبندگان و دامها به رنگهای گوناگون بدینسان جز این نیست که می‌ترسند خدا را از بندگانش دانشمندان همانا خدا است عزتمند آمرزگار
  35,29,آنان که خوانند کتاب خدا را و بپای دارند نماز را و دهند از آنچه روزیشان دادیم نهان و آشکارا امید دارند سوداگریی را که هرگز تباه نگردد
  35,30,تا بپردازد بدیشان پاداش ایشان را تمامی و بیفزایدشان از فضل خویش و او است آمرزنده سپاسگزار
  35,31,و آنچه وحی فرستادیم بسوی تو از کتاب آن است حقّ تصدیق‌کننده آنچه پیش روی آن است همانا خداوند است به بندگان خویش آگهی بینا
  35,32,سپس ارث دادیم کتاب را بدانان که برگزیدیم از بندگان خویش پس از ایشان است ستم‌کننده بر جان خود و از ایشان است میانه‌روی و از ایشان است سبقت‌گیرنده به خوبیها به دستور خدا این است آن فضل بزرگ‌
  35,33,بهشتهای جاودان در آنها درآیند آراسته شوند در آنها با زیورهائی از زر و دستبرنجهای زرین و مروارید و پوشاک ایشان در آن است حریر (ابریشم)
  35,34,و گفتند سپاس خدای را که برد از ما اندوه را همانا پروردگار ما است آمرزنده سپاسگزار
  35,35,آنکو جایگزین ساخت ما را در سرای آرمیدن از فضل خویش نرسد ما را در آن خستگی و نه ما را رسد در آن رنجی‌
  35,36,و آنان که کفر ورزیدند ایشان را است آتش دوزخ نه گذرانیده شود بر ایشان تا بمیرند و نه کاسته شود از ایشان از عذابش بدینسان پاداش دهیم به هر ناسپاسی‌
  35,37,و ایشان می‌نالند در آن پروردگارا برون آر ما را تا بکنیم کرداری شایسته جز آنچه بودیم می‌کردیم آیا عمر ندادیم شما را آنچه یادآور شود در آن آنکه یادآور شود و بیامد شما را ترساننده‌ای پس بچشید که نیست ستمگران را یاوری‌
  35,38,همانا خدا است داننده نهان آسمانها و زمین همانا او است دانا بدانچه در سینه‌ها است‌
  35,39,او است آنکه گردانید شما را جانشینانی در زمین پس آنکو کفر ورزد بر او است کفرش و نیفزاید کافران را کفرشان نزد پروردگارشان مگر خشمی و نیفزاید کافران را کفرشان مگر زیانی‌
  35,40,بگو آیا دیدید شریکان خویش را که خوانید جز خدا بنمایانیدم چه چیز آفریدند از زمین یا آنان را است شرکتی در آسمانها یا دادیم بدیشان کتابی پس ایشانند بر روشنائی (یا نشانی) از آن بلکه وعده نمی‌دهند ستمگران برخی از ایشان برخی را جز فریب‌
  35,41,همانا خدا نگهدارد آسمانها و زمین را از آنکه بیفتند و اگر بیفتند نگه ندارد آنها را کسی پس از او همانا او است بردبار آمرزگار
  35,42,و سوگند یاد کردند به خدا سخت‌ترین سوگندان خویش را که اگر بیایدشان ترساننده‌ای هر آینه باشند راه یابنده‌تر از یکی از امتها پس هنگامی که بیامدشان ترساننده‌ای نیفزود ایشان را جز رمیدنی (نفرتی)
  35,43,برتری‌جستنی در زمین و نیرنگ زشت و فرود نیاید نیرنگ زشت جز به اهلش پس آیا جز شیوه پیشینیان را منتظرند که هرگز نیابی شیوه خدا را دگرگونی و نه هرگز یابی شیوه خدا را بازگشتنی‌
  35,44,آیا نگشتند در زمین تا بنگرند چگونه بود فرجام آنان که پیش از ایشان بودند بودند سخت‌تر از ایشان در نیرو و نبود خدا به عجزآرنده او چیزی در آسمانها و نه در زمین همانا او است دانای توانا
  35,45,و اگر بگیرد خدا مردم را بدانچه فراهم کردند نگذارد بر پشت آن جنبنده‌ای لیکن پس اندازدشان تا سرآمدی نامبرده پس گاهی که بیاید سرآمدشان همانا خدا است به بندگان خویش بینا
  36,1,یس‌
  36,2,سوگند به قرآن استوار
  36,3,که توئی همانا از فرستادگان‌
  36,4,بر راهی راست‌
  36,5,فرستادن خداوند عزیز مهربان‌
  36,6,تا بیم دهی قومی را که بیم‌داده نشدند پدران ایشان پس آنانند ناآگاهان‌
  36,7,همانا راست آمد (یا فرود آمد) سخن بر بیشتر ایشان پس ایشان ایمان نمی‌آرند
  36,8,همانا نهادیم در گردنهای ایشان زنجیرهائی پس دستهایشان بسوی چانه‌ها است پس ایشانند لگام زدگان (سر به بالا نگاه‌داشتگان)
  36,9,و گذاردیم پیش روی ایشان سدی و از پشت سرشان سدی پس پوشانیدمشان پس ایشان نبینند
  36,10,و یکسان است بر ایشان چه بترسانیشان یا نترسانیشان ایمان نیارند
  36,11,جز این نیست که می‌ترسانی آن را که پیروی ذکر کند و بترسد خدای مهربان را به نهان پس مژده ده او را به آمرزشی و مزدی گرامی‌
  36,12,همانا ما زنده کنیم مردگان را و نویسیم آنچه پیش فرستادند و آثار ایشان را و هر چیزی را فراهم کردیم در پیشوائی آشکار
  36,13,و بزن برای ایشان مثل یاران شهر را هنگامی که آمدندش فرستادگان‌
  36,14,هنگامی که فرستادیم بسوی آنان دو تن پس تکذیبشان کردند پس تقویت کردیم آنان را به سیمینی پس گفتند همانا مائیم بسوی شما فرستادگان‌
  36,15,گفتند نیستید شما جز مردمی مانند ما و نفرستاده است خدای مهربان چیزی را و نیستید شما جز دروغگویان‌
  36,16,گفتند پروردگار ما داند که مائیم بسوی شما هر آینه فرستادگان‌
  36,17,و نیست بر ما جز رساندن آشکار
  36,18,گفتند همانا به فال بد گرفتیم شما را اگر کوتاه نیائید هر آینه سنگسارتان کنیم و البتّه رسد شما را از ما شکنجه دردناک‌
  36,19,گفتند فال بد شما همراه شما است آیا اگر که یادآوری شوید بلکه شمائید گروهی فزونی‌جویان‌
  36,20,و آمد از دورترین جای شهر مردی می‌دوید گفت ای قوم من پیروی کنید فرستادگان را
  36,21,پیروی کنید آنان را که نخواهند از شما مزدی و ایشانند راه‌یافتگان‌
  36,22,و چه شود مرا که نپرستم آن را که بیافریدم و بسوی او بازگردانیده شوید
  36,23,آیا برگیرم جز او خدایانی که اگر خواهدم خدای مهربان به رنجی بی‌نیاز نگرداندم شفاعت ایشان به چیزی و نه رها سازندم‌
  36,24,همانا منم آن هنگام در گمراهیی آشکار
  36,25,همانا ایمان آوردم به پروردگار شما پس مرا بشنوید
  36,26,گفته شد به بهشت درآی گفت ای کاش قومم می‌دانستند
  36,27,که آمرزید مرا پروردگار من و گردانید مرا از گرامی‌داشتگان‌
  36,28,و نفرستادیم بر قومش پس از او لشکری از آسمان و نبودیم فرستندگان‌
  36,29,نبود آن جز یک خروش که ناگهان ایشانند مُردگان‌
  36,30,افسوس بر بندگان که نیایدشان پیمبری جز آنکه هستند بدو استهزاکنندگان‌
  36,31,آیا ندیدند بسا نابود کردیم پیش از ایشان از قرنها که آنان بسوی ایشان بازنگردند
  36,32,و هر آینه همگانند با هم به نزد ما احضارشدگان‌
  36,33,و آیتی برای ایشان زمین مرده است که زنده کردیمش و برون آوردیم از آن دانه‌ای که از آن می‌خورند
  36,34,و نهادیم در آن باغهائی از خرمابنها و انگورها و بشکافتیم در آن از چشمه‌ها
  36,35,تا خورند از میوه آن و آنچه ساختش دستهای ایشان پس آیا سپاس نگزارند
  36,36,منزّه است آنکه آفرید جفتها را همگی از آنچه می‌رویاند زمین و از خود ایشان و از آنچه نمی‌دانند
  36,37,و آیتی برای ایشان شب است که برکنیم از آن روز را ناگاه ایشانند به تاریکی‌شدگان‌
  36,38,و خورشید روان است سوی آرامگاهی برایش این است اندازه‌نهادن (یا مقرّر داشتن) عزّتمند دانا
  36,39,و ماه را گردانیدیم منزلهائی تا بازگشت چون شاخه خرمای کهن (خشکیده)
  36,40,نه مهر را سزد که به ماه رسد و نه شب است پیشی‌گیرنده بر روز و هر کدامند در گردونه‌ای شناوران‌
  36,41,و آیتی است برای ایشان آنکه ما سوار کردیم نژاد ایشان را در کشتی انباشته‌
  36,42,و آفریدیم برای ایشان از نمونه چه را سوار شوند
  36,43,و اگر خواهیم غرقشان سازیم تا به فریادرسی ایشان را باشد و نه رهانیده شوند
  36,44,جز رحمتی از ما و کامیابی تا زمانی‌
  36,45,و گاهی که گفته شود بدیشان بترسید آنچه را پیش روی شما و آنچه پشت سر شما است شاید رحم شوید
  36,46,و نمی‌آیدشان آیتی از آیتهای پروردگارشان مگر هستند از آن روی‌گردانان‌
  36,47,و گاهی که گفته شود بدیشان دهید از آنچه روزیتان داده است خدا گویند آنان که کفر ورزیدند بدانان که ایمان آوردند آیا خورانیم آن را که اگر می‌خواست خدا می‌خورانیدش نیستید شما مگر در گمراهیی آشکار
  36,48,و گویند چه هنگام است این وعده اگر هستید راستگویان‌
  36,49,ننگرند (چشم به راه نیستند) جز یک خروش را که بگیردشان حالی که ایشانند با هم ستیزه‌کنان‌
  36,50,پس نتوانند وصیّت گذاردنی و نه بسوی خاندان خویش بازگردند (یا سخن گویند)
  36,51,و دمیده شد در صور که ناگاه ایشانند از گورها بسوی پروردگار خویش شتابندگان‌
  36,52,گویند وای بر ما که برانگیخت ما را از خوابگاه ما این است آنچه وعده داد خداوند مهربان و راست گفتند فرستادگان‌
  36,53,نبود آن جز یک خروش که ناگهان ایشانند همگان با هم نزد ما احضارشدگان‌
  36,54,پس امروز نه ستم شود به کسی چیزی و نه پاداش داده شوید جز آنچه بودید می‌کردید
  36,55,همانا یاران بهشت امروز دست بکار کامرانند
  36,56,آنان و همسرانشان در سایه‌هائی بر اریکه‌هایند تکیه‌کنندگان‌
  36,57,آنان را است در آن میوه و آنان را است در آن هر چه می‌خواهند
  36,58,سلامی است گفتاری از پروردگار مهربان‌
  36,59,و جدا شوید امروز ای گنهکاران‌
  36,60,آیا اندرز ندادم شما را ای بنی‌آدم که نپرستید شیطان را که او شما را است دشمنی آشکار
  36,61,و آنکه مرا پرستید این است راهی راست‌
  36,62,و هر آینه گمراه ساخت از شما گروهی بسیار را آیا نبودید بخرد یابید
  36,63,این است دوزخی که بودید وعده داده می‌شدید
  36,64,بچشیدش امروز بدانچه بودید ناسپاسی می‌کردید
  36,65,امروز مُهر نهیم بر دهانهای ایشان و سخن گویند با ما دستهای ایشان و گواهی دهند پاهای ایشان بدانچه بودند فراهم می‌کردند
  36,66,و اگر می‌خواستیم می‌گرفتیم دیدگان ایشان را پس سبقت گرفتند بسوی راه ولی کجا بینند
  36,67,و اگر می‌خواستیم هر آینه مسخ می‌کردیم ایشان را (پیکری دیگر می‌آوردیمشان) با فرمانروائیشان پس نتوانند رفتن را و نه بازگردند
  36,68,و هر که را سالمند گردانیم بکاهیمش در آفرینش آیا بخرد نیابند
  36,69,و نیاموختیم بدو شعر را و نه سزدش نیست آن جز یادآوری و قرآنی آشکار
  36,70,تا بترساند آن را که زنده است و فرود آید سخن بر کافران‌
  36,71,آیا ندیدند که ما آفریدیم برای ایشان از آنچه ساخت دستهای ما چهارپایانی پس ایشانند آنها را دارندگان‌
  36,72,و رام کردیم آنها را برای ایشان پس از آنها است سواری ایشان و از آنها می‌خورند
  36,73,و برای ایشان است در آنها سودهائی و آبشخورها (نوشابه‌هائی) پس آیا سپاسی نگزارند
  36,74,و بگرفتند جز خدا خدایانی شاید یاری شوند
  36,75,نتوانندشان یاری کردن و ایشانند آنان را لشکری فراخواندگان (احضارشدگان)
  36,76,پس اندوهگین نسازدت سخن ایشان همانا دانیم آنچه را نهان دارند و آنچه پدیدار کنند
  36,77,آیا ندیده است انسان که ما آفریدیمش از چکّه آبی پس ناگهان او است دشمنی یا ستیزه‌جوئی (آشکار)
  36,78,و بزد برای ما مثَلی و فراموش کرد آفرینش خود را گفت کیست که زنده کند استخوانها را حالی که آنهایند خاکی پوسیده‌
  36,79,بگو زنده کند آنها را آنکه پدید آورد یا بیافرید آنها را نخستین بار و او است به هر آفرینشی دانا
  36,80,آنکه نهاد برای شما از درخت سبز آتشی که ناگهان شمائید از آن فروزندگان‌
  36,81,آیا نیست آنکه آفرید آسمانها و زمین را توانا بر آنکه بیافرد مانند ایشان را بلی و او است آفریننده دانا
  36,82,جز این نیست کار او گاهی که چیزی خواهد که بدو گوید بشو پس بشود
  36,83,پس منزّه است آنکه به دستش پادشاهیهای همه چیز است و بسوی او بازگردانیده شوید