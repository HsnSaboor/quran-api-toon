quran[564]{c,v,t}:
  78,1,از چه چیزند پرسش‌کنان‌
  78,2,از داستان (آگهی) بزرگ‌
  78,3,آنکه آنانند در آن اختلاف‌کنان‌
  78,4,نه چنین است زود است بدانند
  78,5,پس نه چنین است زود است بدانند
  78,6,آیا نگردانیدیم زمین را آرامگاهی‌
  78,7,و کوه‌ها را میخهائی‌
  78,8,و آفریدیم شما را جفتهائی‌
  78,9,و گردانیدیم خواب شما را بیهشی (یا آسایشی)
  78,10,و گردانیدیم شب را پوشاکی‌
  78,11,و گردانیدیم روز را روزی‌گهی‌
  78,12,و بنیاد نهادیم فراز شما هفتگانه‌ای استوار
  78,13,و نهادیم چراغی درخشان‌
  78,14,و فرستادیم از فشرده‌ها آبی ریزان‌
  78,15,تا برون آریم بدان دانه و رستنی‌
  78,16,و باغستانی پیچاپیچ‌
  78,17,همانا روز جداشدن است وعده‌گاهی‌
  78,18,روزی که دمیده شود در صور پس آیند گروه‌هائی‌
  78,19,و گشوده شود آسمان پس بگردد درهائی‌
  78,20,و رانده شوند کوه‌ها پس شوند سرابی‌
  78,21,همانا دوزخ است کمینگاهی‌
  78,22,برای سرکشان بازگشتگاهی‌
  78,23,ماندگانند در آن سالهائی‌
  78,24,نچشند در آن خنکی و نه نوشابه‌ای‌
  78,25,مگر آبی جوشان و چرکی‌
  78,26,کیفری برابر
  78,27,که بودند ایشان امید نداشتند حسابی‌
  78,28,و تکذیب کردند آیتهای ما را تکذیبی‌
  78,29,و هر چیزی را فراآوردیم در نامه‌ای‌
  78,30,پس بچشید که هرگز نیفزائیم شما را جز عذابی‌
  78,31,همانا برای پرهیزکاران است برخوردارگاهی‌
  78,32,باغچه‌هائی و تاکهائی‌
  78,33,و آنان پستان برآمده همسالانی‌
  78,34,و جامی لبریز
  78,35,نشنوند در آن یاوه و نه تکذیبی‌
  78,36,پاداشی از پروردگارت بخششی به شمار
  78,37,پروردگار آسمانها و زمین و آنچه میان آنها است خداوند مهربان که دارا نیستند از او خطابی (سخن‌گفتنی)
  78,38,روزی که بپای ایستند روح و فرشتگان به صفی سخن نگویند جز آنکو دستوری دهدش خداوند مهربان و گوید درستی‌
  78,39,آن است روز حقّ تا هر که خواهد برگیرد بسوی پروردگار خویش بازگشتگاهی‌
  78,40,همانا بیم دادیم شما را از عذابی نزدیک روزی که بنگرد مرد آنچه را پیش فرستاده است دو دستش و گوید کافر کاش می‌بودم خاکی‌
  79,1,سوگند به برکنندگان به قوّت‌
  79,2,و به کشندگان کشیدنی (یا جهندگاه جهشی)
  79,3,و به شناوری‌کنان شناوریی‌
  79,4,پس پیشی‌گیرندگان پیشی‌گرفتنی‌
  79,5,پس کارپردازان کاری‌
  79,6,روزی که بلرزد لرزنده‌
  79,7,از پیش آید پی درآینده‌
  79,8,دلهائی است در آن روز هراسان‌
  79,9,دیدگان آنها است سرافکنده‌
  79,10,گویند آیا مائیم بازگردانیده در گور (یا در حال نخستین)
  79,11,آیا گاهی که گردیدیم استخوانهائی پوسیده‌
  79,12,گویند آن است آن هنگام بازگشتی زیانمند
  79,13,پس جز این نیست که خروشی است یگانه‌
  79,14,ناگهان ایشانند به روی زمین‌
  79,15,آیا بیامدت داستان موسی‌
  79,16,گاهی که بانگ دادش پروردگارش بر درّه مقدّس طوی‌
  79,17,برو بسوی فرعون که او سرکشی کرد
  79,18,پس بگو آیا تو را است بسوی آنکه پاکی جوئی‌
  79,19,و رهبریت کنم بسوی پروردگارت پس بترسی‌
  79,20,پس نمایاندش آیت بزرگ را
  79,21,پس تکذیب کرد و سرپیچید
  79,22,سپس پشت کرد می‌دوید
  79,23,پس گردآورد پس برخواند
  79,24,پس گفت منم پروردگار بزرگتر شما
  79,25,پس گرفتش خدا به کیفر انجام و آغاز
  79,26,همانا در این است عبرتی برای آنکه بترسد
  79,27,آیا شما سخت‌ترید در آفرینش یا آسمان که ساختش‌
  79,28,برافراشت پوشش را پس بیاراستش‌
  79,29,و تاریک ساخت شبش را و برآورد روزش‌
  79,30,و زمین را از آن پس گسترانیدش‌
  79,31,برون آورد از آن آبش را و چراگاهش‌
  79,32,و کوه‌ها را لنگر گردانیدش‌
  79,33,بهره‌مندیی برای شما و برای دامهای شما
  79,34,پس گاهی که آید فرودآینده‌ای بزرگتر
  79,35,روزی که یاد آورد انسان آنچه را کوشیده است‌
  79,36,و آشکار گردد دوزخ برای هر که بیند
  79,37,پس اما آنکه سرپیچید
  79,38,و زندگانی دنیا را برگزید
  79,39,همانا دوزخ است جایگاهش‌
  79,40,و امّا آنکه بترسد جایگاه پروردگار خویش را و بازدارد خویشتن را از هوسها
  79,41,همانا بهشت است جایگاهش‌
  79,42,پرسندت از ساعت کی است لنگرگاهش‌
  79,43,در چیستی تو از یادآوردنش‌
  79,44,بسوی پروردگار تو است پایانش‌
  79,45,جز این نیست که توئی ترساننده آنکه بترسدش‌
  79,46,گوئیا ایشان روزی که بینندش نماندند جز شبی یا روزش‌
  80,1,روی درهم کشید و پشت کرد
  80,2,که آمدش کور
  80,3,و چه دانستت شاید او پاکی جوید
  80,4,یا یادآور شود پس سود دهدش یادآوردن‌
  80,5,اما آنکه بی‌نیازی جست‌
  80,6,پس تواش پذیرفتی‌
  80,7,و نیست بر تو که او پاکی نجوید
  80,8,و اما آنکه بیامدت می‌دوید
  80,9,و او می‌ترسید
  80,10,پس تو از او سرگرمی جستی‌
  80,11,نه چنین است همانا آن است یادآوریی‌
  80,12,که هر که خواهد یاد آوردش‌
  80,13,در نامه‌هایی گرامی‌
  80,14,برافراشته پاک‌شده‌
  80,15,به دستهای پیام‌آورانی‌
  80,16,گرامیانی نیکانی‌
  80,17,کشته باد انسان چه ناسپاس است‌
  80,18,از چه چیز آفریدش‌
  80,19,از نطفه بیافریدش پس مقدّر داشتش (اندازه نهادش)
  80,20,سپس راه را آماده ساختش‌
  80,21,پس میرانیدش و به گور بردش‌
  80,22,سپس هر گاه خواست برون آردش‌
  80,23,نه چنین است هنوز نگذارد آنچه فرمودش‌
  80,24,پس بنگرد انسان بسوی خوراکش‌
  80,25,که ریختیم ما آب را ریزشی‌
  80,26,پس شکافتیم زمین را شکافتنی‌
  80,27,پس رویانیدیم در آن دانه‌
  80,28,و انگوری و خرمائی‌
  80,29,و زیتونی و خرمابنی‌
  80,30,و باغچه‌هائی پیچیده‌
  80,31,و میوه‌ای و چمنی‌
  80,32,بهره‌ای برای شما و برای دامهای شما
  80,33,پس گاهی که آید خروش کرسازنده‌
  80,34,روزی که گریزد مرد از برادرش‌
  80,35,و مادرش و پدرش‌
  80,36,و همسرش و فرزندانش‌
  80,37,هر مردی از ایشان را است در آن روز کاری که به خود واداردش‌
  80,38,چهره‌هایی است در آن روز گشوده‌
  80,39,خندان شادان‌
  80,40,و چهره‌هایی در آن روز بر آنها است گردی‌
  80,41,دستخوش سازدش پریشانی‌
  80,42,آنانند کافران پرده‌دران‌
  81,1,گاهی که خورشید بی‌فروغ گردد
  81,2,و گاهی که ستارگان تیره شوند
  81,3,و گاهی که کوه‌ها رانده شوند
  81,4,و گاهی که اشتران آبستن (یا آبستنان) رها کرده شوند
  81,5,و گاهی که وحشیان گردآورده شوند
  81,6,و گاهی که دریاها به هم آمیخته شوند
  81,7,و گاهی که نفوس جفت کرده شوند
  81,8,و گاهی که گورشده پرسیده شود
  81,9,به کدام گناه کشته شد
  81,10,و گاهی که نامه‌ها گشوده شود
  81,11,و گاهی که آسمان برکنده شود
  81,12,و گاهی که دوزخ افروخته شود
  81,13,و گاهی که بهشت آماده (یا نزدیک) شود
  81,14,بداند هر کسی آنچه احضار کرده است‌
  81,15,پس سوگند نیارم به فروروندگان‌
  81,16,روندگان نهان‌شدگان‌
  81,17,و شب‌گاهی که تیرگیش پشت کند
  81,18,و بامدادگاهی که بدرخشد
  81,19,که آن است همانا گفتار فرستاده گرامی‌
  81,20,توانگری نزد خداوند عرش ارجمند (یا سخن روائی)
  81,21,فرمانروائی آنجا امینی‌
  81,22,و نیست یار شما دیوانه‌
  81,23,و هر آینه بدیدش در اُفقی آشکار
  81,24,و نیست او بر ناپیدا بخیل‌
  81,25,و نیست آن سخن شیطان رانده‌شده‌
  81,26,پس کجا می‌روید
  81,27,نیست آن جز یادآوریی برای جهانیان‌
  81,28,برای آنکه خواهد از شما که راستی گزیند (یا پایداری کند)
  81,29,و نخواهید جز آنکه بخواهد خدا پروردگار جهانیان‌
  82,1,گاهی که آسمان بشکافد
  82,2,و گاهی که ستارگان بپاشد (یا بریزد)
  82,3,و گاهی که دریاها شکافته شود
  82,4,و گاهی که گورها برانگیخته شود
  82,5,داند کسی چه پیش فرستاده است و چه پس آورده است‌
  82,6,ای انسان چه چیزت فریفت (یا چه فریفته تو را) به پروردگار کریمت‌
  82,7,آنکه آفریدت پس راست آوردت پس معتدلت ساخت‌
  82,8,به هر پیکری که خواست تو را پرداخت‌
  82,9,نه چنین است بلکه تکذیب کنید به دین‌
  82,10,و همانا بر شما است نگهبانانی‌
  82,11,گرامیانی نویسندگانی‌
  82,12,دانند آنچه کنید
  82,13,همانا نیکانند در نعمتها
  82,14,و همانا گنهکارانند در دوزخ‌
  82,15,چشندش روز دین‌
  82,16,و نیستند ایشان از آن ناپدیدان‌
  82,17,و ندانی تو چیست روز دین‌
  82,18,پس ندانی تو چیست روز دین‌
  82,19,روزی که دارا نیست کسی برای کسی چیزی و کار در آن روز خدا را است‌
  83,1,وای بر کم‌فروشان‌
  83,2,آنان که هر گاه پیمایند بر مردم تمام بردارند
  83,3,و هر گاه پیمایندشان یا سنجندشان کم دهند
  83,4,آیا نپندارند که ایشان برانگیختگانند
  83,5,برای روزی بزرگ‌
  83,6,روزی که بپای خیزند مردم برای پروردگار جهانیان‌
  83,7,نه چنین است همانا نامه گنهکاران است در سِجّین‌
  83,8,و چه دانستت چیست سِجّین‌
  83,9,نامه‌ای است نوشته‌
  83,10,وای در آن روز بر تکذیب‌کنندگان‌
  83,11,آنان که تکذیب کنند به روز دین‌
  83,12,و تکذیب نکند بدان جز هر تجاوزگری گنهکار
  83,13,که هر گاه خوانده شود بر او آیتهای ما گوید این است افسانه‌های پیشینیان‌
  83,14,نه چنین است بلکه چیره گشت بر دلهای آنها بودند فراهم می‌کردند
  83,15,نه چنین است همانا ایشانند از پروردگارشان آن روز راندگان‌
  83,16,سپس ایشانند همانا چشندگان دوزخ‌
  83,17,پس گفته شود این است آنچه بودید بدان تکذیب می‌کردید
  83,18,نه چنین است همانا نامه نیکان است در علّیّین‌
  83,19,و چه دانستت چیست علّیّون‌
  83,20,نامه نوشته‌
  83,21,که گواهیش دهند نزدیکان‌
  83,22,همانا نیکانند در نعمتها
  83,23,بر بالشها (یا تختها) نگران‌
  83,24,بشناسی در چهره‌شان خرمی نعمتها
  83,25,نوشاینده شوند از جامی مُهرزده‌
  83,26,مُهر آن است مشک و بدین پس باید بگروند گروندگان‌
  83,27,و آمیزش آن است از تَسنیم‌
  83,28,چشمه‌ای که نوشند از آن نزدیکان‌
  83,29,همانا آنان که گنهکاراند بودند بر آنان که ایمان آوردند خنده‌زنان‌
  83,30,و هر گاه می‌گذشتند بر آنان به چشم طعن و استهزاء بنگرند
  83,31,و هر گاه بازمی‌گشتند بسوی خاندان خویش بازمی‌گشتند لبخندزنان‌
  83,32,و هر گاه می‌دیدندشان می‌گفتند همانا اینانند گمراهان‌
  83,33,و فرستاده نبودند بر ایشان نگهبانان‌
  83,34,پس امروز آنان که ایمان آوردند به کافرانند خنده‌زنان‌
  83,35,بر بالشهایند نگران‌
  83,36,آیا پاداش داده شدند کفّار آنچه را بودند می‌کردند
  84,1,گاهی که آسمان بشکافت‌
  84,2,و فرمان برد برای پروردگار خویش و سزاوار شد
  84,3,و گاهی که زمین کشیده (پهن) شد
  84,4,و افکند آنچه در آن است و تهی شد
  84,5,و فرمان برد پروردگار خویش را و سزاوار شد
  84,6,ای انسان همانا توئی رنج‌برنده بسوی پروردگار خویش رنجی را پس رسنده‌ای بدان‌
  84,7,امّا آنکه داده شود نامه خویش را به راستش‌
  84,8,پس زود است حساب شود حسابی آسان‌
  84,9,و بازگردد بسوی خاندان خویش شادان‌
  84,10,و اما آنکه داده شود نامه خویش را از پشت سرش‌
  84,11,پس زود است بخواند مرگ را
  84,12,و بچشد آتش را
  84,13,که بود او همانا در خاندان خود شادان‌
  84,14,او همانا پنداشت که هرگز بازنگردد
  84,15,بلکه پروردگار او است بدو بینا
  84,16,پس سوگند نیارم به خورگاه (شفق)
  84,17,و به شب و آنچه فراگیرد
  84,18,و به ماه گاهی که تمام شود
  84,19,که هر آینه سوار گردید پشتی بر پشتی (طبقه‌ای پس از طبقه‌ای)
  84,20,پس چه شودشان که ایمان نیارند
  84,21,و گاهی که خوانده شود بر ایشان قرآن سجده نکنند
  84,22,بلکه آنان که کفر ورزیدند تکذیب کنند
  84,23,و خدا دانا است بدانچه در خویشتن نهان دارند
  84,24,پس مژده ده ایشان را به عذابی دردناک‌
  84,25,مگر آنان که ایمان آوردند و کردار شایسته کردند که ایشان را است مزدی بی‌پایان (یا بی‌منّت)
  85,1,سوگند به آسمان دارنده برجها
  85,2,و به روز وعده‌شده‌
  85,3,و به گواه و گواهی‌شده‌
  85,4,کشته شوند یاران حفره‌ها
  85,5,آن آتش فروزان (یا دارنده) سوخت‌
  85,6,گاهی که ایشانند بر آن نشستگان‌
  85,7,و آنانند بر آنچه به مؤمنان کنند گواهان‌
  85,8,و خشم نگرفتند بر ایشان جز از آن رو که ایمان آوردند به خدای عزّتمند ستوده‌
  85,9,آنکه وی را است پادشاهی آسمانها و زمین و خدا است بر همه چیز گواه‌
