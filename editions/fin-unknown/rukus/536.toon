quran[8]{c,v,t}:
  94,1,Emmekö Me ole avartanut rintaasi
  94,2,Emmekö ole sinulta ottanut pois kuormasi
  94,3,joka raskaana painoi hartioillasi
  94,4,ja korottanut sinun arvoasi
  94,5,"Totisesti, helpotus seuraa vastuksia"
  94,6,ja vastoinkäymistä seuraa huojennus
  94,7,"Kun siis olet vapaa työstä, rukoile ahkerasti"
  94,8,ja palvele Herraasi koko sydämestäsi