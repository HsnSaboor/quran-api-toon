quran[6]{c,v,t}:
  109,1,"Vuga (yewe Muhamadi) uti \"Yemwe bahakanyi"
  109,2,Sinsenga ibyo musenga
  109,3,Kandi na mwe ntimusenga uwo nsenga
  109,4,Ndetse nanjye sinzigera nsenga ibyo musenga
  109,5,Kandi namwe ntimuzigera musenga uwo nsenga
  109,6,"Mufite idini ryanyu, nanjye nkagira idini ryanjye"