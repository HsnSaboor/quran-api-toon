quran[21]{c,v,t}:
  92,1,(Ааламдарды караңгылыгы менен) каптаган түнгө ант
  92,2,(Жарыгы менен) көрүнгөн күндүзгө ант
  92,3,Жана эркек менен ургаачыны жараткан Затка ант
  92,4,"Албетте (о, инсандар) силердин аракетиңер ар кандай"
  92,5,Ким (садака) берсе жана такыба кылса
  92,6,жана жакшылыкты (Исламды) тастыктаса —
  92,7,Биз ага жакшылыкты (бактылуу жашоону) жеңил кылабыз
  92,8,"Ал эми, ким (байлыгын Аллаһ жолуна сарп кылуудан) сараңдык кылса жана (Аллаһ бере турган соопту) “керек эмес” десе"
  92,9,Жана ыйманды жалган десе
  92,10,Биз ага түйшүктүү жолго түшүүнү жеңил кылабыз
  92,11,(Тозокко) оңкосунан сайылган убакта (кызганган) мал-мүлкү ага пайда бербей калат
  92,12,"Албетте, (адамдарды) Туура Жолго баштоо Бизге гана таандык иш"
  92,13,"Аныгында, Акырет (жашоосу) да, Дүйнө (жашоосу) да Биздин ыктыярыбызда"
  92,14,Мен силерди алоолонгон оттон эскерттим
  92,15,Ал отко шору каткан адам гана кирет
  92,16,Ал (Исламды) жалган деп (чындыктан) жүз бурган
  92,17,Андан (тозоктон) такыбаа киши ыраак болот
  92,18,"Ал мал-мүлкүн (Аллаһ жолунда) берип, (өзүн сараңдыктан) тазалаган киши"
  92,19,Ал адамда эч ким үчүн (ордуна) сыйлык кайтарыла турган жакшылык жок
  92,20,(Анын бардык жакшылыктары) эң жогорку Раббисинин ыраазычылыгы үчүн гана (жасалат)
  92,21,Жакында (Аллаһ аны чоң сыйлык менен сыйлайт. Ошондо ал дагы Раббисинен) ыраазы болот