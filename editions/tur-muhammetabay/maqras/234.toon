quran[71]{c,v,t}:
  80,1,abese vetevellâ
  80,2,en câehü-l'a`mâ
  80,3,vemâ yüdrîke le`allehû yezzekkâ
  80,4,ev yeẕẕekkeru fetenfe`ahü-ẕẕikrâ
  80,5,emmâ meni-stagnâ
  80,6,feente lehû teṣaddâ
  80,7,vemâ `aleyke ellâ yezzekkâ
  80,8,veemmâ men câeke yes`â
  80,9,vehüve yaḫşâ
  80,10,feente `anhü telehhâ
  80,11,kellâ innehâ teẕkirah
  80,12,femen şâe ẕekerah
  80,13,fî ṣuḥufim mükerrameh
  80,14,merfû`atim müṭahherah
  80,15,bieydî seferah
  80,16,kirâmim berarah
  80,17,ḳutile-l'insânü mâ ekferah
  80,18,min eyyi şey'in ḫaleḳah
  80,19,min nuṭfeh. ḫaleḳahû feḳadderah
  80,20,ŝümme-ssebîle yesserah
  80,21,ŝümme emâtehû feaḳberah
  80,22,ŝümme iẕâ şâe enşerah
  80,23,kellâ lemmâ yaḳḍi mâ emerah
  80,24,felyenżuri-l'insânü ilâ ṭa`âmih
  80,25,ennâ ṣabebne-lmâe ṣabbâ
  80,26,ŝümme şaḳaḳne-l'arḍa şeḳḳâ
  80,27,feembetnâ fîhâ ḥabbâ
  80,28,ve`inebev veḳaḍbâ
  80,29,vezeytûnev venaḫlâ
  80,30,veḥadâiḳa gulbâ
  80,31,vefâkihetev veebbâ
  80,32,metâ`al leküm velien`âmiküm
  80,33,feiẕâ câeti-ṣṣâḫḫah
  80,34,yevme yefirru-lmerü min eḫîh
  80,35,veümmihî veebîh
  80,36,veṣâḥibetihî vebenîh
  80,37,likülli-mriim minhüm yevmeiẕin şe'nüy yugnîh
  80,38,vucûhüy yevmeiẕim müsfirah
  80,39,ḍâḥiketüm müstebşirah
  80,40,vevucûhüy yevmeiẕin `aleyhâ gaberah
  80,41,terheḳuhâ ḳaterah
  80,42,ülâike hümü-lkeferatü-lfecerah
  81,1,iẕe-şşemsü küvvirat
  81,2,veiẕe-nnücûmü-nkederat
  81,3,veiẕe-lcibâlü süyyirat
  81,4,veiẕe-l`işâru `uṭṭilet
  81,5,veiẕe-lvuḥûşü ḥuşirat
  81,6,veiẕe-lbiḥâru süccirat
  81,7,veiẕe-nnüfûsü züvvicet
  81,8,veiẕe-lmev'ûdetü süilet
  81,9,bieyyi ẕembin ḳutilet
  81,10,veiẕe-ṣṣuḥufü nüşirat
  81,11,veiẕe-ssemâü küşiṭat
  81,12,veiẕe-lceḥîmü sü``irat
  81,13,veiẕe-lcennetü üzlifet
  81,14,alimet nefsüm mâ aḥḍarat
  81,15,felâ uḳsimü bilḫunnes
  81,16,elcevâri-lkünnes
  81,17,velleyli iẕâ `as`as
  81,18,veṣṣubḥi iẕâ teneffes
  81,19,innehû leḳavlü rasûlin kerîm
  81,20,ẕî ḳuvvetin `inde ẕi-l`arşi mekîn
  81,21,müṭâ`in ŝemme emîn
  81,22,vemâ ṣâḥibüküm bimecnûn
  81,23,veleḳad raâhü bil'üfüḳi-lmübîn
  81,24,vemâ hüve `ale-lgaybi biḍanîn
  81,25,vemâ hüve biḳavli şeyṭânir racîm
  81,26,feeyne teẕhebûn
  81,27,in hüve illâ ẕikrul lil`âlemîn
  81,28,limen şâe minküm ey yesteḳîm
  81,29,vemâ teşâûne illâ ey yeşâe-llâhü rabbü-l`âlemîn