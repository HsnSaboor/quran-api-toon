quran[30]{c,v,t}:
  75,1,lâ uḳsimü biyevmi-lḳiyâmeh
  75,2,velâ uḳsimü binnefsi-llevvâmeh
  75,3,eyaḥsebü-l'insânü ellen necme`a `iżâmeh
  75,4,belâ ḳâdirîne `alâ en nüsevviye benâneh
  75,5,bel yürîdü-l'insânü liyefcüra emâmeh
  75,6,yes'elü eyyâne yevmü-lḳiyâmeh
  75,7,feiẕâ beriḳa-lbeṣar
  75,8,veḫasefe-lḳamer
  75,9,vecümi`a-şşemsü velḳamer
  75,10,yeḳûlü-l'insânü yevmeiẕin eyne-lmeferr
  75,11,kellâ lâ vezer
  75,12,ilâ rabbike yevmeiẕin-lmüsteḳarr
  75,13,yünebbeü-l'insânü yevmeiẕim bimâ ḳaddeme veeḫḫar
  75,14,beli-l'insânü `alâ nefsihî beṣîrah
  75,15,velev elḳâ me`âẕîrah
  75,16,lâ tüḥarrik bihî lisâneke lita`cele bih
  75,17,inne `aleynâ cem`ahû veḳur'âneh
  75,18,feiẕâ ḳara'nâhü fettebi` ḳur'âneh
  75,19,ŝümme inne `aleynâ beyâneh
  75,20,kellâ bel tüḥibbûne-l`âcileh
  75,21,veteẕerûne-l'âḫirah
  75,22,vucûhüy yevmeiẕin nâḍirah
  75,23,ilâ rabbihâ nâżirah
  75,24,vevucûhüy yevmeiẕim bâsirah
  75,25,teżunnü ey yüf`ale bihâ fâḳirah
  75,26,kellâ iẕâ belegati-tterâḳiy
  75,27,veḳîle men râḳ
  75,28,veżanne ennehü-lfirâḳ
  75,29,velteffeti-ssâḳu bissâḳ
  75,30,ilâ rabbike yevmeiẕin-lmesâḳ