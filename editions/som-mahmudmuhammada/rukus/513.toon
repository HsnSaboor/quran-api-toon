quran[10]{c,v,t}:
  75,31,Mase Rumaynin Gaalku Xaqa mana tukannin
  75,32,Laakiin wuu Beeniyay wuuna Jeedsaday
  75,33,Wuxuuna aaday Ehelkiisii isagoo kibirsan
  75,34,Halaag Buuse Mutaa
  75,35,Haddana Halaagbuu Mutaa
  75,36,Ma wuxuu u maleeyay Dadku in looga tagi Bilaash (Dan la'aan)
  75,37,Miyuusan ahayn Dhibic mani ah oo la Dhibciyo
  75,38,Markaas Noqoto xinjir oo Eebe Abuuro Ekeeyana
  75,39,Kana yeelo Labadii Nooc lab iyo Dhaddig
  75,40,Eebaha Saas kara miyuusan Awoodin inuu soo Nooleeyo wixii Dhintay