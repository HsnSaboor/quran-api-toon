quran[8]{c,v,t}:
  94,1,Biso te nde tofungolaki yo motema
  94,2,Mpe tokitisaki mokumba nayo
  94,3,Mokumba moye mozalaki kobuka mokongo nayo
  94,4,Mpe totombolaki lokumu nayo
  94,5,"Ya soló, mpasi ezalaka péne ya esengo"
  94,6,"Ya solo, mpasi ezalaka péne ya esengo"
  94,7,Soki osilisi misala telema тропа kosambela
  94,8,Mpe pona Nkolo nayo zala na elikya