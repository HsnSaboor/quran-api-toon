quran[19]{c,v,t}:
  96,1,اقرا باسم ربك الذي خلق
  96,2,"خلق الانسن من علق (علق: قطعة دم غليظ)"
  96,3,اقرا وربك الاكرم
  96,4,الذي علم بالقلم
  96,5,علم الانسن ما لم يعلم
  96,6,"كلا ان الانسن ليطغى (كلا: حقا, ليطغى: ليتجاوز الحد في العصيان، والكبر)"
  96,7,"ان رءاه استغنى (ان راه استغنى: بسبب ان راى نفسه مستغنيا بماله)"
  96,8,"ان الى ربك الرجعى (الرجعى: الرجوع، والمصير)"
  96,9,"ارءيت الذي ينهى (ارايت: الا تعجب)"
  96,10,عبدا اذا صلى
  96,11,ارءيت ان كان على الهدى
  96,12,او امر بالتقوى
  96,13,"ارءيت ان كذب وتولى (وتولى: اعرض عن الايمان)"
  96,14,الم يعلم بان الله يرى
  96,15,"كلا لين لم ينته لنسفعا بالناصية (لنسفعا: لناخذنه اخذا عنيفا فنطرحه في النار, بالناصية: بمقدم راسه)"
  96,16,"ناصية كذبة خاطية (خاطية: اثمة)"
  96,17,"فليدع ناديه (فليدع: فليحضر، وليناد, ناديه: اهل مجلسه من قومه، وعشيرته)"
  96,18,"سندع الزبانية (الزبانية: ملايكة العذاب)"
  96,19,"كلا لا تطعه واسجد واقترب۩ (كلا: ليس الامر على ما يظن ابو جهل, واقترب: ادن منه بالطاعة)"