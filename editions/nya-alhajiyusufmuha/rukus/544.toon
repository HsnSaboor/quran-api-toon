quran[8]{c,v,t}:
  102,1,Mpikisano wosonkhanitsa chuma cha padziko wakutangwanikitsani inu
  102,2,Mpaka pamene inu mulowa m’manda
  102,3,Iyayi! Inu mudzadziwa
  102,4,"Kachiwiri, Iyayi! Inu mudzadziwa"
  102,5,Iyayi! Inu mukanadziwa kwenikweni
  102,6,Ndithudi inu mudzaona moto woyaka
  102,7,Kachiwiri inu mudzauona ndi maso anu
  102,8,Ndipo patsiku limeneli inu mudzafunsidwa za chisangalalo chimene munali kuchita