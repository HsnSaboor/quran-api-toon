quran[6]{c,v,t}:
  109,1,"Nena: oh! Inu anthu osakhulupirira"
  109,2,Ine sindipembedza chimene inu mupembedza
  109,3,Ndiponso inu simudzapembedza chimene ine ndipembedza
  109,4,Ndipo ine sindidzapembedza chimene inu muli kuchipembedza
  109,5,Ndipo inu simudzapembedza chimene ine ndimapembedza
  109,6,Kwa inu chipembedzo chanu ndipo kwa ine chipembedzo changa