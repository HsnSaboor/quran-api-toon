quran[11]{c,v,t}:
  93,1,Ndifunga ngesandulela semini
  93,2,Nangobusuku xa bufiphala (buzolile)
  93,3,"INkosi\tyakho\t(Muhammad)\tAyikushiyanga,\t(futhi) Ayikuchasanga"
  93,4,Inene uBomi oBuzayo bobona bulungileyo kunobu (bomi balo mhlaba)
  93,5,Yaye inene iNkosi yakho Iya kukunika (konke okulungileyo) ukuze wena waneliseke
  93,6,"Yayingakufumananga uyinkedama na, Yakunika ukhuseleko"
  93,7,"Yakufumana kananjalo ulahlekile, Yakukhokela"
  93,8,Yakufumana ulihlwempu Yakwenza isityebi
  93,9,Ngoko ke ungayiphathi kakubi inkedama
  93,10,Ungaligxothi nengqiba
  93,11,Uvakalise uBabalo lweNkosi yakho