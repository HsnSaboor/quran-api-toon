quran[10]{c,v,t}:
  77,41,"Inene\tabanyulu\tbaya\tkuba\tphakathi\tkwemithunzi nemithombo"
  77,42,Neziqhamo (zohlobo) abalufunayo
  77,43,"(Kuya kuthiwa kubo): “Yidlani nisele nanele ngenxa yoko nakwenzayo.”"
  77,44,Inene Thina sibavuza kajalo ke abenzi bokulungileyo
  77,45,Yeha ngaloo Mini kubaphiki
  77,46,"(Hini na nina bangakholwayo), yibani nisitya nizonwabise okwethutyana inene nina ningaboni"
  77,47,Yeha ngaloo Mini kubaphiki
  77,48,"Ukanti xa kusithiwa kubo: Gobani amadolo (phambi koAllâh)”, abagobi bona"
  77,49,Yeha ngaloo Mini kubaphiki
  77,50,Yiyiphi ke enye intetho emva (kwe’Kur’ân) abaya kukholwa kuyo