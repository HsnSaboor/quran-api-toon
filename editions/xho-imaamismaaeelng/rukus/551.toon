quran[6]{c,v,t}:
  109,1,"Yithi: Hini na nina bangakholwayo"
  109,2,Andikunquli oko nina nikunqulayo
  109,3,Nibe nani anikunquli oko mna ndikunqulayo
  109,4,Kanti nam andiyi kukunqula oko nina nikunqulayo
  109,5,Ukanti nani aniyi kukunqula oko mna ndikunqulayo
  109,6,Nina ninenkolo yenu nam ndinenkolo yam