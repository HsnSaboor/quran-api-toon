quran[78]{c,v,t}:
  55,1,“(Allah) Wachifundo chochuluka
  55,2,“Waphunzitsa Qur’an
  55,3,“Adalenga munthu
  55,4,“Adamphunzitsa kuyankhula
  55,5,“Dzuwa ndi mwezi zikuyenda mwachiwerengero
  55,6,"“Zomera zopanda tsinde ndi mitengo, zikulambira (Allah pachilichonse chimene wafuna mwa izo)"
  55,7,“Ndipo thambo adalitukula kumwamba ndipo adakhazikitsa sikelo (ya chilungamo)
  55,8,“Kuti musapyole malire ndi kuchita chinyengo poyesa
  55,9,“Choncho yesani sikelo mwachilungamo ndipo musapungule muyeso
  55,10,“Ndipo nthaka adaiyala (ndi kuikonza) kuti ikhale ya zolengedwa
  55,11,“M’menemo muli zipatso ndi mitengo ya kanjedza yokhala ndi mapava (a zipatso)
  55,12,"“Ndi mbewu zamakoko (kuti chikhale chakudya cha inu ndi ziweto zanu), ndipo mulinso m’menemo mmera wafungo labwino"
  55,13,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,14,“Adalenga munthu kuchokera ku dongo lolira monga ziwiya zadongo
  55,15,“Ndipo adalenga ziwanda kuchokera ku malawi a moto (wopanda utsi)
  55,16,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,17,“Mbuye wa kuvuma kuwiri ndiponso Mbuye wa kuzambwe kuwiri
  55,18,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,19,"“Adaika nyanja ziwiri zokumana (yamadzi amchere, ndi yamadzi ozizira)"
  55,20,"“Pakati pake pali chitsekerezo, sizilowana"
  55,21,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,22,“M’menemo mumatuluka ngale zing’onozing’ono ndi ngale zikuluzikulu
  55,23,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,24,"“Ndipo (Iye) ali nazo zombo (zimene zapangidwa ndi manja anu), zoyenda panyanja, zazikuluzikulu ngati mapiri"
  55,25,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,26,“Zonse zili pamenepo (pa dziko) nzakutha
  55,27,“Ndipo idzatsala nkhope ya Mbuye wako yaulemelero ndi mtendere
  55,28,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,29,"“(Onse) akumwamba ndi pansi akupempha Iye (zofuna zawo)! Tsiku lililonse Iye ali ndi zochita (monga kupatsa uyu ulemelero, ndi kutsitsa uyu)"
  55,30,"“(Inu zolengedwa zamitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,31,"“Posachedwapa (patsiku la chiweruziro), tidzaikapo mtima pa chiwerengero chanu (cha zochita zanu) inu anthu ndi ziwanda"
  55,32,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,33,"“E inu ziwanda ndi anthu! Ngati mungathe kutuluka m’mphepete mwa thambo ndi nthaka (pothawa Allah), tulukani! Simungathe kutuluka pokhapokha ndi mphamvu. (Koma inu simungathe kutero)"
  55,34,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,35,“Mudzathiridwa malawi a moto ndi mtovu wa moto wosungunuka ndipo simungathe kupulumuka (ku chilango chimenechi)
  55,36,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,37,“(Kumbuka) pamene thambo lidzang’ambika ndi kukhala lofiira ngati chikopa chofiira (kapena ngati mafuta oyaka)
  55,38,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,39,"“Ndipo patsikulo munthu ndi chiwanda, sadzafunsidwa (aliyense) za tchimo lake"
  55,40,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,41,“Adzadziwika oipa (pakati pa anthu ndi ziwanda) ndi zizindikiro zawo (zowazindikiritsa). Ndipo adzagwidwa maliombo awo ndi mapazi awo (ndi kuponyedwa ku Jahena)
  55,42,"“((Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,43,"“(Kudzanenedwa mowadandaulitsa): Iyi ndi Jahannam yomwe adali kuitsutsa oipa"
  55,44,"“Adzakhala akuyenda pakati pa moto ndi pakati pa madzi owira, otentha kwambiri"
  55,45,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,46,"“Koma amene waopa kuti adzaimitsidwa kwa Mbuye wake (pa nthawi ya chiweruziro), adzalandira minda iwiri (yaikulu yamtendere)"
  55,47,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,48,“(Minda ya mitengo) yanthambi zofwanthamuka
  55,49,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,50,"“M’menemo muli akasupe awiri, omwe akuyenda"
  55,51,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,52,"“M’menemo muli zipatso za mtundu uliwonse, mitundu iwiri iwiri"
  55,53,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,54,"“Atatsamira pa zoyala, mkati mwake mosokelera veleveti wochindikala; ndipo zipatso zam’minda iwiriyi nzapafupi (kuzithyola)"
  55,55,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,56,"“M’mindamo muli akazi oyang’ana amuna awo okha basi, (mawuthu) omwe sadakhalepo malo amodzi ndi munthu kapena chiwanda asadakumane ndi iwo"
  55,57,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,58,“Kukongola kwake (akaziwo) kuli ngati ngale zikuluzikulu ndi zing’onozing’ono
  55,59,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,60,“Malipiro a ntchito zabwino ndikulandira zabwino basi
  55,61,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,62,“Ndipo kuonjezera paminda iwiri (ija) palinso minda ina iwiri
  55,63,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,64,"“Yobiriwira, kwambiri"
  55,65,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,66,“M’menemo muli akasupe awiri ofwamphuka madzi mwaphamvu
  55,67,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,68,"“Mmenemo muli zipatso, mitengo yakanjedza ndi yamikangaza"
  55,69,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,70,"“M’menemo muli akazi amakhalidwe abwino, owala nkhope"
  55,71,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,72,"“Okongola maso, achikhalire m’mahema (m’matenti) awo"
  55,73,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,74,“Amene sadakhalepo malo amodzi ndi munthu kapena chiwanda asadakumane ndi iwo
  55,75,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,76,"“Uku atatsamira misamiro yawofuwofu yokutidwa ndi zobiriwira; ndi zoyala zokongola, zakapangidwe kabwino"
  55,77,"“(Inu zolengedwa za mitundu iwiri, anthu ndi ziwanda), kodi ndi mtendere uti wa Mbuye wanu umene mukuukana (kuti si Wake)"
  55,78,“Latukuka ndi kudalitsika dzina la Mbuye wako Mwini ulemelero ndi ufulu