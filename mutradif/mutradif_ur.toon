mutradif[3006]{id,mid,a,w,d,s,hw,aw,ay,ta}:
1,1,"آ","اَسْکَنَ","«اَسْکَنَ» اس کا معنی ہے کسی ایک مقام سے دوسرے مقام پر لے جا کر آباد کرنا ۔\nمثلاً : قرآن کریم میں حضرت ابراہیمؑ کے تذکرے کو یوں بیان فرمایا ہے:\n«رَبَّنَآ اِنِّىْٓ اَسْكَنْتُ مِنْ ذُرِّيَّتِيْ بِوَادٍ غَيْرِ ذِيْ زَرْعٍ» (37 / 14)\nترجمہ : اے ہمارے پروردگار ! میں نے اپنی اولاد کو ایسی وادی  میں لا بسایا ہے جہاں کوئی کھیتی نہیں ۔","«اَسْکَنَ» کسی دوسرے مقام پر آباد کرنے کیلئے استعمال ہوتا ہے  ۔","آباد","اسکن","2:35-2:128-7:19-7:161-17:104-23:18-65:6",7
2,1,"آ","اٰوٰی","«اٰوٰی» اس کا معنی ہے کسی کو اپنے ہاں رہائش کے لیے جگہ دینا ، پناہ دینا ۔ اس کا  اصل  لفظ «اَوَی» ہے جس کے معنی ہیں  کسی کے ساتھ مل جانا اور جڑ جانا (مف) تاکہ کسی خطرہ وغیرہ سے پناہ حاصل ہو جائے ۔\nجیسا کہ قرآن کریم میں اصحاب کہف کا قصّہ بیان کیا گیا ہے کہ وہ مشرک حکومت کے ڈرسے پہاڑ کی ایک کھوہ (یعنی غار) میں جا بیٹھے تھے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِذْ اَوَى الْفِتْيَةُ اِلَى الْكَهْفِ» (10 / 18)\nترجمہ : جب اُن نوجوانوں نے غار میں پناہ پکڑی ۔\nاوراسی طرح جب نوح علیہ السلام نے اپنے کافر بیٹے کو ایمان لانے اور کشتی میں سوار ہونے کو کہا تاکہ وہ طوفان سے ہلاک ہونے سے بچ جائے تواُن کے بیٹے نے جو کہا:\nاُسکو قرآن نے یوں بیان کیا ہے :\n«سَاٰوِيْٓ اِلٰي جَبَلٍ يَّعْصِمُنِيْ مِنَ الْمَاۗءِ»  (43 / 11)\nترجمہ : میں ابھی پہاڑکی پناہ لے لوں  گا وہ مجھے پانی سے بچا لے گا ۔\nاور باب (افعال ) میں اِیواء کا معنی خاص طور پرکسی کو اپنے ہاں جگہ دینا اورٹھہرانا ہے۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ الَّذِيْنَ اٰمَنُوْا وَهَاجَرُوْا وَجٰهَدُوْا بِاَمْوَالِهِمْ وَاَنْفُسِهِمْ فِيْ سَبِيْلِ اللّٰهِ وَالَّذِيْنَ اٰوَوْا وَّنَــصَرُوْٓا اُولٰۗىِٕكَ بَعْضُهُمْ اَوْلِيَاۗءُ بَعْضٍ» (72 / 8)\nترجمہ : جو لوگ ایمان لائے اور وطن سے ہجرت کر گئے اور خدا کی راہ میں اپنے مال اور جان سے لڑے اور جنہوں نے ہجرت کرنے والوں کو جگہ دی اور مدد کی وہ آپس میں ایک دوسرے کے رفیق ہیں ۔\n","«اٰوٰی» کسی خطرے سے بچنے کے لئے  کسی محفوظ جگہ پر پناہ  لینے کے لئے استعمال ہوتا ہے ۔","آباد","اوی","8:72-11:43-11:80-12:69-12:99-18:10-18:63-23:50-28:45-32:19",10
3,1,"آ","بَوَّا","«بَوَّا» اس کا معنی ہے کسی کواُس کی طبیعت اور پسند کے موافق جگہ پر آباد کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَقَدْ بَوَّاْنَا بَنِيْٓ اِسْرَاۗءِيْلَ مُبَوَّاَ صِدْقٍ وَّرَزَقْنٰھُمْ مِّنَ الطَّيِّبٰتِ» (93 / 10)\nترجمہ : اور ہم نے بنی اسرائیل کو رہنے کے لیے عمدہ جگہ دی اور کھانے کو پاکیزہ چیزیں عطا کیں ۔","« بَوَّا» مناسب ماحول میں آباد کرنے  کیلئے استعمال ہوتا ہے ۔","آباد","بوا","7:74-10:93-22:26",3
4,1,"آ","تَبَوَّا","«تَبَوَّا» کی اصل (بوء) ہے ۔ اس کے مفہوم میں دو باتیں پائی جاتی ہیں :\n(1) رُجُوْع اِلَی الشَیٔ  (2) اور برابر سرابر ہونا (م ۔ ل) اور اس لفظ کا استعمال اُس وقت ہوتا ہے جب کسی رہائشی مقام کی آب و ہوا اور ماحول رہنے والے کی طبیعت کے موافق اور سازگار ہو (مف) یا کوئی شخص جس مقصد کے لیے کسی رہائشی جگہ کا انتخاب کرتا ہے وہ اُس کے لیے موافق اور سازگار ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَكَذٰلِكَ مَكَّنَّا لِيُوْسُفَ فِي الْاَرْضِ ۚ يَتَبَوَّاُ مِنْهَا حَيْثُ يَشَاۗءُ» (56 / 12)\nترجمہ : اور اسی طرح ہم نے یوسف ؑ کو ملک (مصر) میں اقتدار بخشا ، وہ جہاں چاہتے رہائش اختیار کر لیتے ۔\nاور اسی طرح قرآن کریم میں اللہ تعالیٰ حضوراکرم ﷺ کو مخاطب کر کے فرماتے ہیں :\n«وَاِذْ غَدَوْتَ مِنْ اَھْلِكَ تُبَوِّئُ الْمُؤْمِنِيْنَ مَقَاعِدَ لِلْقِتَالِ» (121 / 3)\nترجمہ : اور جب آپ صبح کو اپنے گھر سے روانہ ہو کر ایمان والوں کو لڑائی کے لیے مورچوں پر ( موقع بہ موقع ) متعین کر رہے تھے ۔\n اِس کا مطلب یہ ہے کہ آپ جنگ کے موقع ومحل کے لحاظ سے ہر ایک کو مخصوص مقامات پر متعین فرماتے تھے ۔","« تَبَوَّا» موافق اور سازگار ماحول میں آباد ہونے کیلئے استعمال ہوتا ہے۔","آباد","تبوا","10:87-12:56-39:74-41:24-59:9",5
5,1,"آ","ثوٰی","«ثَوَی» بمعنی دفن کیا جانا ۔ کسی جگہ ٹھہرنا ، آباد ہونا ۔\n«ثَوَی الرَّجُل» : آدمی کا مرنا (منجد) (لغتِ اضداد)  اور بمعنی  کسی جگہ کو مستقل طور پر رہائش گاہ بنا لینا (مف) آباء واجداد کے زمانے سے کسی ایک مقام پر ہی رہائش اختیار کیے رکھنا ۔\nمثلاً : قرآن کریم میں اللہ تعالیٰ نے حضور اکرم ﷺ کو ارشاد فرمایا ہے :\n«وَمَا كُنْتَ ثَاوِيًا فِيْٓ اَهْلِ مَدْيَنَ تَتْلُوْا عَلَيْهِمْ اٰيٰتِنَا» (45 / 28)\nترجمہ : اور آپؐ تو مدین میں رہنے والوں میں سے نہ تھے کہ انہیں ہماری آیتیں پڑھ پڑھ کر سناتے ۔\nنوٹ : (لغت اضداد ایسے الفاظ کو کہتے ہیں جن کے  دو الگ الگ معنیٰ ہوں اور وہ معنیٰ ایک دوسرے کے مخالف اور متضاد ہوں)","«ثوَی» باپ دادا کی سرزمین پر ہی آباد رہنے کے لئے  استعمال ہوتا ہے۔","آباد","ثوی","3:151-16:29-29:68-39:3239:60-39:72-40:76-41:24-47:12",9
6,1,"آ","حَضَرَ ، بَدَا","«حَضَرَ»  کسی شہر میں مقیم ہونا ۔ شہری رہائش اختیار کرنے کے لیے استعمال ہوتا ہے اور «بَدَا» کسی دیہات یا جنگل میں رہنے کے لیے استعمال ہوتا ہے۔ «حَضْرٌ» کی ضد «بَدْوٌ» ہے ۔ (م ل) «بَدَا ، یَبْدُوْا،  بَدَاوَۃٌ» کے معنی کسی گاؤں یا دُوردرازعلاقے کا باشندہ ہونا ۔ «بَدَا» کے لغوی معنیٰ  (ظاہر ہونا) بھی ہے اور اس سے ایسا مقام ِرہائش مراد ہے جہاں بلند اوراونچی عمارتیں نہ ہونے کی وجہ سے سب کچھ نمایاں اور صاف طور پر نظرآتا ہے (مف) اور اسی سے «بَادِیَۃٌ» بمعنی صحرا ، اور«بَادِیٌ» بمعنی صحرانشین اور«بَدَوِیٌّ» بمعنی دیہاتی کے الفاظ  نکلے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«ذٰلِكَ لِمَنْ لَّمْ يَكُنْ اَھْلُهٗ حَاضِرِي الْمَسْجِدِ الْحَرَامِ» (2 / 196)\nترجمہ : یہ حکم اس شخص کے لیے ہے جس کے اہل وعیال مکہ میں نہ رہتے ہوں ۔‘‘\nاسی طرح قرآن کریم میں حضرت یوسف علیہ السلام اللہ تعالیٰ کے احسانات کا تذکرہ اِن الفاظ کے ساتھ کرتے ہیں :\n«وَقَدْ اَحْسَنَ بِيْٓ اِذْ اَخْرَجَنِيْ مِنَ السِّجْنِ وَجَاۗءَ بِكُمْ مِّنَ الْبَدْوِ» (100 / 12)\nترجمہ : اور اُس ( اللہ ) نے مجھ پر بہت سے احسان کیے ہیں جبکہ مجھے جیل خانہ سے نکالا اور آپ ( سب گھر والوں ) کو گاؤں سے یہاں سے لایا ۔","«حَضَرَ» کسی شہر میں رہائش اختیار کرنےلیے استعمال ہوتا ہے۔\nاور«بَدَا» کسی دیہات یا جنگل میں رہنے کے لیے استعمال ہوتا ہے۔\n","آباد","حضر ، بدا","2:196-12:100",2
7,1,"آ","خَلَدَ","«خَلَدَ» کسی جگہ پر ایک لمبے عرصہ تک رہنا جہاں کوئی تغیر(یعنی تبدیلی) اور فساد واقع  نہ ہو (مف)\nمثلاً : قرآن کریم میں اللہ تعالیٰ اہل جنت کو مخاطب کرکے فرماتے ہیں:\n«وَلَھُمْ فِيْهَآ اَزْوَاجٌ مُّطَهَّرَةٌ وَّھُمْ فِيْهَا خٰلِدُوْنَ» (25 / 2)\nترجمہ : اور وہاں اُن کے لیے پاک بیویاں ہوں گی اور وہ اس ( جنت ) میں ہمیشہ رہیں گے ۔","«خَلَدَ» طویل عرصہ تک کسی ایسی  جگہ رہائش اختیار کیے رکھنا جہاں کوئی تبدیلی اور فساد نہ ہو۔ ","آباد","خلد","2:25-2:39-2:81-2:82-2:162-2:217-2:257-2:275-3:15-3:88-3:107-3:116-3:136-3:198-4:13-4:14-4:57-4:93-4:122-4:169-5:80-5:85-5:119-6:128-7:20-7:36-7:42-9:17-9:22-9:63-9:68-9:72-9:89-9:100-10:26-10:27-10:52-11:23-11:107-11:108-13:5-14:23-16:29-18:108-20:76-20:101-20:120-21:8-21:34-21:99-21:102-23:11-23:103-25:15-25:16-25:69-25:76-26:129-29:58-31:9-32:14-33:65-39:72-39:73-40:76-41:28-43:71-43:74-46:14-47:15-48:5-56:17-57:12-58:17-58:22-59:17-64:9-64:10-65:11-72:23-76:19-98:6-98:8-104:3",84
8,1,"آ","سَکَنَ","«سَکَنَ» سکون کا لفظ اضطرار (بے چینی) اور حرکت کی ضد ہے لہٰذا آباد ہونا کے مفہوم میں جب «سَکَنَ» کا استعمال ہو گا تو اس کے معنی ہوں گے ’’ کسی دوسرے مقام سے آکر رہائش پذیر ہونا .\nمثلاً :قرآن کریم میں ہے :\n«يٰٓاٰدَمُ اسْكُنْ اَنْتَ وَزَوْجُكَ الْجَنَّةَ» (35 / 2)\nترجمہ : اے آدمؑ ! تم اور تمہاری بیوی جنّت میں آباد ہو جاؤ ۔\nتو اس کا مطلب یہ ہوا  کہ ان کی پیدائش جنت کے علاوہ کسی دوسرے مقام پر ہوئی تھی ۔\nاسی طرح جب  حضرت ابراہیمؑ نے حضرت ہاجرہ اور اسمٰعیلؑ کو  مکہ  میں لا بسایا تو فرمایا :\n«رَبَّنَآ اِنِّىْٓ اَسْكَنْتُ مِنْ ذُرِّيَّتِيْ» (37 / 14)\nترجمہ : اے ہمارے پروردگار ! میں نے اپنی اولاد لا بسائی ہے ۔","«سَکَنَ» کسی دوسرے مقام سے آ کر آباد ہونے کیلئے استعمال ہوتا ہے ۔","آباد","سکن","2:35-6:13-7:19-7:161-14:14-14:37-14:45-16:80-17:104-23:18-28:58-34:15-42:33-65:6",14
9,1,"آ","عَاشَرَ","«عَاشَرَ» اس  کی اصل (عَشَرَ) ہے ۔ جس کے دو بنیادی معنی ہیں ۔\nپہلا معنیٰ «عَشَرَ» دس کے عدد کو کہتے ہیں ؛ دوسرا معنی مخالطت اور مداخلت (م ل) یعنی آپس میں مِل جُل کر رہنا ۔ اور دخل اندازی کرنا ۔ اسی سے لفظ «عَشِیْرَۃٌ» نکلا  ہے جس کے معنی قبیلہ کے ہیں اور«عَاشَرَ» کے معنی ایک کنبہ  خاندان کا ایک ساتھ مِل جُل کر رہنا ۔\nمثلاً : قرآن کریم میں ایسے مردوں کو جنہیں اپنی بیویوں پر کچھ شکایات ہوں حکم دیا گیا ہے کہ :\n«وَعَاشِرُوْھُنَّ بِالْمَعْرُوْفِ»  (19 / 4)\nترجمہ : اور اُن عورتوں کے ساتھ اچھی طرح رہو سہو ۔","«عَاشَرَ» اپنے خاندان کے ساتھ مل جل کر رہنے کے لیے استعمال ہوتا ہے ۔","آباد","عاشر","4:19",1
10,1,"آ","عَمَرَ","«عَمَرَ» کا لفظ مکان بنانے ، رونق بڑھانے اور بنجر اور بے آباد زمین کو آباد کرنے کے معنی میں آتا ہے اور ابن الفارس کے نزدیک اس کے مفہوم میں بقاء (یعنی ہمیشگی) اور طویل مدّت بھی شامل ہے (م ۔ ل) اورعمر وہ مدّت ہے جب تک رُوح جسم کے ساتھ آباد رہے ۔\n«عَمَرَ» اسکی ضد «خَرَبَ» ہے جس کے معنی  ہیں مکانوں یا کھیتوں کو برباد کرنا ، اُجاڑنا اور بے آباد کرنا اور بے رونق بنانا  ۔ مثلاً : حضور اکرم ﷺ نے قرب قیامت کی جوعلامات بتلائیں ہیں ان میں ایک یہ بھی ہے : «مَسَاجِدُھَا عَامِرَۃٌ وَّھِیَ خَرَابٌ مِّنَ الْھُدٰی»\nیعنی اس وقت مسجدیں آباد تو ہوں گی مگر ہدایت کے لحاظ سے اجڑی  ہوئی ہوں گی ۔\nاور مثلاً : قرآن کریم میں ہے :\n«اِنَّمَا يَعْمُرُ مَسٰجِدَ اللّٰهِ مَنْ اٰمَنَ بِاللّٰهِ وَالْيَوْمِ الْاٰخِرِ» (9 / 18)\nترجمہ : اللہ کی مسجدوں کو تو وہی لوگ آباد کرتے ہیں جو اللہ پر اور قیامت کے دن پر ایمان لاتے ہیں ۔\nاسی طرح ایک دوسرے جگہ پر ارشاد باری تعالیٰ ہے :\n«كَانُوْٓا اَشَدَّ مِنْهُمْ قُوَّةً وَّاَثَارُوا الْاَرْضَ وَعَمَرُوْهَآ اَكْثَرَ مِمَّا عَمَرُوْهَا»  (9 / 30)\nترجمہ : وہ  (یعنی اِن سے پہلی قومیں ) اِن سے زور اور طاقت میں کہیں زیادہ تھیں ، اُنہوں نے زمین کو جوتا اور اُس کو اِس سے زیادہ آباد کیا تھا جتنا اِنہوں نے آباد کیا ہے ۔","«عَمَرَ» زمین آباد کرنے ، مکان تعمیر اور آباد کرنے اور رونق بڑھانے کے کیلئے استعمال ہوتا ہے ۔","آباد","عمر","9:17-9:18-11:61-28:45-30:9",5
11,1,"آ","غَنِیَ بِالْمَکَانِ","«غَنِیَ بِالْمَکَانِ» اس کا معنی ہے کسی مقام پر طویل مدّت تک آرام و اطمینان سے رہنا ۔ گویا وہ دوسری جگہوں سے بے نیاز ہے ( مف )\nمثلاً : قرآن کریم میں  ہے :\n«الَّذِيْنَ كَذَّبُوْا شُعَيْبًا كَاَنْ لَّمْ يَغْنَوْا فِيْهَا»  (92 / 7)\nترجمہ : جنہوں نے شعیب ( علیہ السلام ) کی تکذیب کی ایسے برباد ہوئے کہ گویا وہ ان میں کبھی آباد ہی نہ ہوئے تھے ۔","«غَنِیَ» طویل مدت تک آرام و اطمینان سے رہنے کیلئے استعمال ہوتا ہے۔","آباد","غنی بالمکان","7:92-11:68-11:95",3
12,2,"آ","یَوْمُ الْاٰخِرَ","«یَوْمُ الْاٰخِرَ» یوم سے مراد اس دنیا کا عام  دن نہیں جو 24 گھنٹے کا ہوتا ہے یا جو رات کے مقابلہ میں کہا جاتا ہے جیسے دن اور رات ۔\nبلکہ اس سے آخرت کی زندگی کا طویل اور نا ختم ہونے والا دور مراد ہے ۔\nمثلاً :  قرآن کریم میں ہے :\n«اِنَّ رَبَّکُمُ اللّٰہُ الَّذِیۡ خَلَقَ السَّمٰوٰتِ وَ الۡاَرۡضَ فِیۡ سِتَّۃِ اَیَّامٍ»  (54 / 7)\nترجمہ : بے شک تمہارا پروردگار وہ اللہ ہے جس نے آسمانوں اور زمین کو چھ دنوں میں پیدا کیا ۔‘‘ اور یہ تو واضح ہے ۔ زمین اور آسمانوں کی پیدائش سے پہلے موجودہ دن ، جو سورج کے وجود سے پیدا ہوتا ہے ، کا تصوّر بھی نہیں کیا جاسکتا ۔","«یَوْمُ الْاٰخِرَ» اس سے مراد قیامت کا دن ہے جس دن لوگوں کو حساب وکتاب اور جزاء وسزا کے لئے اٹھایا جائے گا ۔","آخرت","یوم الاخر","2:8-2:62-2:126-2:177-2:228-2:232-2:264-3:114-4:38-4:39-4:59-4:136-4:162-5:69-9:18-9:19-9:29-9:44-9:45-9:99-24:2-29:36-33:21-58:22-60:6-65:2",26
13,2,"آ","یَوْمُ الْبَعْثِ","«اَلْیَوْمُ الْبَعْثِ» البعث  سے مراد قبروں سے زندہ ہوکر کسی خاص مقصد کے لیے اُٹھ کھڑے ہونا ہے ، چونکہ آخرت کے اس طویل دورکا آغاز اسی «بَعَث» سے ہوگا لہٰذا اسے «یَوْمُ الْبَعْث» بھی کہا گیا ہے ۔\nمثلاً :  قرآن کریم میں ہے :\n«لَقَدۡ لَبِثۡتُمۡ  فِیۡ کِتٰبِ اللّٰہِ  اِلٰی یَوۡمِ الۡبَعۡثِ» (56 / 3)\nترجمہ : بے شک تم اللہ کی کتاب کے مطابق«یَوْمُ الْبَعْث» تک قبروں میں ٹھہرے رہے ۔","«یَوْمُ الْبَعْثِ» وہ دن  جس دن مردوں کو دوبارہ زندہ کیا جائے گا ، مراد قیامت کا دن ہے۔","آخرت","الیوم البعث","30:56",1
14,2,"آ","آخِرَۃ","«آخِرَۃ» کا معنی «دَارُالْبَقَا» (ہمیشہ رہنے کی جگہ  ہے) ۔ ( م ، م ۔ منجد ) یعنی مرنے کے بعد بدن اور روح کو ملا کرانسان کو دوبارہ زندہ کیا جائے گا اور اس کو ایک دائمی یعنی ہمیشہ ہمیشہ کی زندگی دی جائے گی جس میں کبھی موت نہ ہوگی ، اور نیک اور بدکار لوگوں کو اپنے اپنے اعمال کے بدلہ میں جنت یا دوزخ میں داخل کیا جائے گا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ بِالۡاٰخِرَۃِ ھُمۡ یُوۡقِنُوۡنَ» (4 / 2)\nترجمہ : اور ( ایماندار لوگ ) آخرت پر یقین رکھتے ہیں ۔\nیہاں آخرت سے مراد اسی قسم کی زندگی ہے ۔ اس لحاظ سے آخرت کی ضد قرآن کریم میں (عَاجِلَۃ ، دنیا ، اَدْنیٰ ، اُوْلٰی) سب استعمال کی گئی ہے ۔","«آخِرَۃ» عرف عام میں  قیامت کے دن کے لئے استعمال ہوتا ہے ،جس دن  تمام انسانوں کو دوبارہ زندہ کیا جائے گا اور انکے اعمال کے مطابق انکا فیصلہ کرکے انکو ہمیشہ ہمیشہ کی زندگی دی جائے گی۔","آخرت","آخرۃ","2:4-2:86-2:102-2:114-2:130-2:200-2:201-2:217-2:220-3:22-3:45-3:56-3:72-3:77-3:85-3:145-3:148-3:152-3:176-4:74-4:77-4:134-5:5-5:33-5:41-6:92-6:113-6:150-7:45-7:147-7:156-8:67-9:38-9:69-9:74-10:64-11:16-11:19-11:22-11:103-12:37-12:57-12:101-13:26-13:34-14:3-14:27-16:22-16:41-16:60-16:107-16:109-16:122-17:7-17:10-17:19-17:21-17:45-17:72-17:104-20:127-22:11-22:15-23:33-23:74-24:14-24:19-24:23-27:3-27:4-27:5-27:66-28:70-29:20-29:27-30:7-30:16-31:4-33:57-34:1-34:8-34:21-38:7-39:9-39:26-39:45-40:39-40:43-41:7-41:16-41:31-42:20-43:35-53:25-53:27-57:20-59:3-60:13-68:33-74:53-75:21-79:25-87:17-92:13-93:4",105
15,2,"آ","دَارُالْاٰخِرَۃ","«دَارُالْاٰخِرَۃ» دار کا معنی ہے رہائش گاہ یعنی گھر اور دار کی ( جمع دیار ، اور دُور ہے ) اور اسکا  مفہوم بہت وسیع  ہے ۔ جیسے  دار بمعنی گھر ، حویلی ، علاقہ ، وطن ، ملک ، حتیٰ کہ یہ پوری دنیا بھی انسانوں کی رہائش گاہ ہونے کے لحاظ سے دارالدنیا ہے اور اس کی ضد دارالاخرت ہے ۔ البتہ آخرت کی  زندگی میں ہر شخص کو اسکے اعمال کے مطابق داریعنی رہائش گاہ  دی جائے گا ۔\nمثلاً : نیک لوگوں کے بارے میں ارشاد باری تعالیٰ ہے :\n«وَلَنِعۡمَ  دَارُ الۡمُتَّقِیۡنَ» (30 / 16)\nترجمہ : پرہیزگاروں کے لیے دار ( جنّت ) کیسا اچھا ٹھکانہ ہے ۔\nاسی طرح  کافروں کے لیے  ارشاد باری تعالیٰ ہے :\n«اَلَمۡ تَرَ اِلَى الَّذِيۡنَ بَدَّلُوۡا نِعۡمَتَ اللّٰهِ كُفۡرًا وَّاَحَلُّوۡا قَوۡمَهُمۡ دَارَ الۡبَوَارِۙ‏ - جَهَـنَّمَ​ۚ يَصۡلَوۡنَهَا​ؕ وَبِئۡسَ الۡقَرَارُ‏» (29 - 28 / 14)\nترجمہ : نہوں نے اللہ کی نعمت کو کفر سے بدل ڈالا ، اور اپنی قوم کو تباہی کے گھر میں لا اتار ۔ جس کا نام جہنم ہے وہ اس میں جلیں گے ، اور وہ بہت برا ٹھکانا ہے ۔\n (بُرا گھر اور برا ٹھکانہ) دونوں سے مراد دوزخ ہے ۔","«دَارُالْاٰخِرَۃ»  سے مراد وہ گھر ہے جس کا فیصلہ روز قیامت  انسان کے اچھے یا بُرے اعمال  کے نتیجہ میں  کیا جائے گا اور وہ اس میں ہمیشہ رہے گا ۔","آخرت","دارالاخرۃ","2:94-6:32-7:169-12:109-16:30-28:77-28:83-29:64-33:29",9
16,2,"آ","دَارُالْاٰخِرَۃ","«دَارُالْقَرَار» قرار بمعنی کسی جگہ جم کررہنا ہے ۔ چونکہ آخرت کی زندگی ابدی (نا ختم ہونے والی) اور دائمی (ہمیشہ رہنے والی ہوگی) اس لحاظ سے اُسے دارالقرار کہا گیا ہے ۔ تاہم دارالقرار کالفظ اچھے معنوں میں استعمال ہوتا ہے اور دارالقرار سے مراد نیک لوگوں کا ٹھکانا یعنی جنت ہوگا ۔\nاور  کافروں کی ہمیشہ اور نا ختم ہونے والی زندگی  کے لیے  قرآن کریم  نے (سورہ نمبر  14/ آیت نمبر29 )  میں « بِئْسَ الْقَرَار» کے الفاظ استعمال کیے ہیں ۔ ( مراد دوزخ ہے )\nیوم سے مراد اس دنیا کا عام  دن نہیں جو 24   گھنٹے کا ہوتا ہے یا جو رات کے مقابلہ میں کہا جاتا ہے جیسے دن اور رات ۔\nبلکہ اس سے آخرت کی زندگی کا طویل اور نا ختم ہونے والا دَور مراد ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ رَبَّکُمُ اللّٰہُ الَّذِیۡ خَلَقَ السَّمٰوٰتِ وَ الۡاَرۡضَ فِیۡ سِتَّۃِ اَیَّامٍ» (54 / 7)\nترجمہ : بے شک تمہارا پروردگار وہ اللہ ہے جس نے آسمانوں اور زمین کو چھ دنوں میں پیدا کیا ۔‘‘ اور یہ تو واضح ہے ۔ زمین اور آسمانوں کی پیدائش سے پہلے موجودہ دن ، جو سورج کے وجود سے پیدا ہوتا ہے ، کا تصوّر بھی نہیں کیا جاسکتا ۔","«دَارُالْقَرَار» سے مراد وہ اچھا ٹھکانہ ہے جو ایمان والوں کو اللہ تعالیٰ اُن کے نیک اعمال کے بدلے میں عطاء فرمائے گا ، یعنی جنت ۔","آخرت","دارالقرار","40:39",1
17,3,"ا","اٰدَمَ","«اٰدَمَ» کا اصل لفظ «اَدَمْ» ہے جس کے بنیادی معنی ’’ مُوافَقَت اور مُلَا ئِمَت ‘‘ یعنی طبیعت اور مزاج کا ایک جیسا ہونا ہے (م-ل) اور «اَدَام» ہر موافق اور ملائم چیز کو کہتے ہیں (منجد) اور اس پر دلیل حضور اکرم ﷺ کا وہ ارشاد ہے جو آپ ﷺ نے حضرت مغیرہ بن شعبہ رضی اللہ عنہ کو ایک عورت کو پیغامِ نکاح کے سلسلہ میں ارشاد فرمایا تھا :\n«لَوْ نَظَرْتَ إِلَيْهَا فَإِنَّهُ أَحْرَى أَنْ يُؤْدَمَ بَيْنَكُمَا» یعنی’’ اگر تو اسے (یعنی اپنی منگیتر کو) ایک نظر دیکھ لے تو اس سے تمہارے درمیان الفت اورخوشگواری پیدا ہونے کا زیادہ امکان ہے ‘‘(سنن  نسائی ؛ حدیث نمبر : 3237)\nاس دلیل کےعلاوہ اور بھی کئی دلیلیں بیان کی جاتی ہیں لیکن صحیح دلیل یہی مذکورہ دلیل ہے کیونکہ اس کی تائید حدیث سے بھی ہوجاتی ہے ۔\nآدم : ابوالبشر حضرت آدم علیہ السلام کا نام ہے لیکن آدم ؑ کی اولاد کے لئے بھی استعمال ہوسکتا ہے (منجد) لہذا بنی آدم کہا جائے تو اس سے تمام نوعِ انسانی مراد ہوتی ہے ۔\nاور آدم یا بنی آدم کا استعمال جہاں کہیں بھی قرآن کریم میں مذکور ہے وہ انسان کی تاریخ سے تعلق رکھتا ہے ۔\nمثلاً : آدم کی مٹی سے پیدائش ، فرشتوں کا آدمؑ کو سجدہ کرنا، اور انسان کا اشرف المخلوقات ہونا ، اور عہد  اَلَسَتْ (یعنی وہ وعدہ جو اللہ نے آدم اور اولاد آدم سےعالم ارواح میں لیا تھا) اور شیطان کا آدم اور بنی آدم کو گمراہ کرنا اور اُس کا خدا سے مکالمہ وغیرہ وغیرہ ۔","«اٰدَمَ» عرف عام میں سب سے پہلے انسان حضرت آدم علیہ سلام کو کہاجاتا ہے ،البتہ لفظ  (اَدَمْ)  ہم مزاج اور ہم طبیعت کے معنیٰ میں بھی استعمال ہوتا ہے ۔","انسان","ادم","2:31-2:33-2:34-2:35-2:37-3:33-3:59-5:27-7:11-7:19-7:26-7:27-7:31-7:35-7:172-17:61-17:70-18:50-19:58-20:115-20:116-20:117-20:120-20:121-36:60",25
18,3,"ا","اِنْس","«اِنْس»  جمع اسکی «اُنَاس» ہے  انسانوں کے ایسے گروہ یا جماعت  کو کہا جاتا ہے جو قبیلہ ، خاندان یا کسی دوسری وجہ سے ایک دوسرے سے مختلف ہوں :\nمثلاً : قرآن کریم میں ہے :\n«قَدۡ عَلِمَ کُلُّ اُنَاسٍ مَّشۡرَبَہُمۡ» (60 / 2)\n ترجمہ : ہر گروہ نے اپنا اپنا گھاٹ ( پینے کی جگہ ) پہچان لیا ۔\nاور (اَنَاسِیَّ) انسانوں کے ایک بہت بڑے گروہ کو کہا جاتا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«خَلَقۡنَاۤ اَنۡعَامًا وَّ اَنَاسِیَّ  کَثِیۡرًا» (49 / 25)\nترجمہ : ہم نے چوپائے اور بے شمار انسان پیدا کیے ۔","«اِنْس» جب انسان کے معاشرتی پہلو  (یعنی رہن سہن ) کا تذکرہ  کرنا  ہو تو اِنس اور اس  سے نکلے ہوئے الفاظ استعمال کئے جاتے ہیں، اور جب تاریخی پہلو کو ذکرنا ہو تو آدم اور بنی آدم استعمال کیا جاتا ہے ،  اور جب اُس کے طبعی اور فطری  پہلو کا ذکر کرنا ہو تو بشر کا لفظ استعمال ہوتا ہے ۔","انسان","انس","6:112-6:128-6:130-7:38-7:179-27:17-41:25-41:29-46:18-51:56-55:33-55:39-55:56-55:74-72:5-72:6",16
19,3,"ا","بَشَرَ","«بَشَرَ» کے  بنیادی معنی ہیں کسی چیز کا اپنے حسن و جمال کے ساتھ ظاہر ہونا (م ل) جبکہ اُنس کے معنی صرف ظاہر ہونے کے ہیں ۔\nاور «اَلْبَشَرَۃَ» انسان کی جلد کی اُوپر کی سطح کو کہتے ہیں ۔\nمثلاً :  قرآن کریم میں ہے :\n«لَوَّاحَۃٌ  لِّلۡبَشَرِ»  (29 / 74)\nترجمہ : دوزخ کی آگ جلد کو جھلس کر سیاہ کردے گی ۔\nاوراس کی جمع « بَشَرٌ» اور«اَبْشَارٌ» ہے اور انسان کو بشر اس لیے کہا جاتا ہے کہ اس کی جلد دوسرے حیوانات کے مقابلہ میں اُون ، رُوان اور بالوں وغیرہ سے بہت حد تک پاک صاف ہوتی اور صاف دکھائی دیتی ہے ۔ (مف)\nبشر کا لفظ واحد ، جمع ، مذکر ، مؤنث سب کے لیے استعمال ہوتا ہے ۔ البتہ اگر دو انسانوں کے لئے استعمال ہوگا تو«بَشَرَیْن» بولا جائے گا ۔\nمثلاً :  قرآن کریم میں ہے :\n«اَنُؤۡمِنُ لِبَشَرَیۡنِ مِثۡلِنَا» (47 / 23)\nترجمہ :  کیا ہم اپنے ہی جیسے دو آدمیوں پر ایمان لے آئیں؟\nاور بشر کا لفظ اس وقت استعمال ہوتا ہے جب انسان کے طبعی اور مادی پہلو ، اوراس کی جسمانی بناوٹ ، فطری ضروریات اور کمزوریوں کا ذکر کرنا مقصود ہو ۔ جیسا کہ اوپر ذکر کی گئی آیت سے واضح ہورہا ہے ۔\nاور بشر کے مقابلہ میں «مَلَک» (یعنی فرشتہ) کا لفظ ہے جو مادی پہلو ، یعنی ظاہری جسمانی اور فطری ضروریات سے پاک ہوتا ہے ۔ کفّار کا ہمیشہ یہی اعتراض رہا کہ ہم اپنے ہی جیسے ایک بشر جو ہماری طرح ہی پیدا ہوتا اور مرتا ہے ، کھاتا پیتا ، بازاروں میں چلتا پھرتا اور اپنی حاجات ہماری طرح ہی پوری کرتا ہے ۔ تو اس کو ہم پر ایسی کون سی ترجیح حاصل  ہے کہ اس پر ایمان لایا جائے ۔ ہاں اگرکوئی فرشتہ ہوتا ، جو ان حوائج  اورضروریات سے پاک ہوتا توکوئی بات بھی تھی ۔\nدرج ذیل آیات میں خدا تعالیٰ نے اسی اعتراض کا جواب دیا ہے :\n«وَ مَا مَنَعَ النَّاسَ اَنۡ یُّؤۡمِنُوۡۤا اِذۡ جَآءَہُمُ الۡہُدٰۤی اِلَّاۤ  اَنۡ قَالُوۡۤا اَبَعَثَ اللّٰہُ بَشَرًارَّسُوۡلًا .قُلۡ لَّوۡ کَانَ فِی الۡاَرۡضِ مَلٰٓئِکَۃٌ یَّمۡشُوۡنَ مُطۡمَئِنِّیۡنَ لَنَزَّلۡنَا عَلَیۡہِمۡ مِّنَ  السَّمَآءِ  مَلَکًا  رَّسُوۡلًا»\n(95 - 94 / 17)\nترجمہ : اور جب لوگوں کے پاس ہدایت آگئی تو ان کو ایمان لانے سے اس کے سوا کوئی چیز مانع نہ ہوئی کہ کہنے لگے کہ کیا خدا نے آدمی کو پیغمبر بناکے بھیجا ہے ۔ آپ کہہ دیجیے کہ اگر فرشتے زمین میں آباد ہوتے جو چلتے پھرتے اور آرام کرتے تو ہم ان کے پاس آسمان سے فرشتہ ہی پیغمبر بنا کر بھیجتے ۔","«بَشَرَ» عرف عام میں انسان کو کہا جاتا ہے، البتہ انسان کی جلد کی اوپر کی سطح کے لئے بھی استعمال ہوتا ہے ۔","انسان","بشر","3:47-3:79-5:18-6:91-11:27-12:31-14:10-14:11-15:28-15:33-16:103-17:93-17:94-18:110-19:17-19:20-19:26-21:3-21:34-22:72-23:24-23:33-23:34-23:47-25:54-26:154-26:186-30:20-36:15-38:71-41:6-42:51-54:24-64:6-74:25-74:29-74:31-74:36",38
20,4,"آ","اِرْتَفَقَ","«اِرْتَفَقَ» اس کا اصل لفظ «رَفَقَ» ہے ۔ بدمزاج اور سختی سے پاک باہمی موافقت ، رضامندی ، اتفاق ، اتحاد ، دوستی اور قرب کو رفق کہتے ہیں ۔ اس کے بعد جو چیز  راحت اور رضامندی  کا سبب بنے اسے رفق کہا جاتا ہے ۔ اسی لحاظ سے «مِرْفَق» کہنی کو بھی کہتے ہیں کہ اس سے ٹیک لگائی جاتی ہے اور انسان آرام محسوس کرتا ہے اور«مِرفَقَہ» چھوٹے تکیہ کو  کہتے ہیں اور «اِرْ تِفَاق» ایسی رفاقت کو کہتے ہیں جو راحت اور موافقت کا سبب ہو اور«مَرْتَفَق» ایسی جگہ کو کہتے ہیں جہاں آرام بھی میسر ہو اورکوئی چیز آرام میں  خلل پیدا نا کرے ۔\nمثلاً : قرآن کریم میں ہے :\n«نِعۡمَ الثَّوَابُ ؕ وَ حَسُنَتۡ  مُرۡتَفَقًا»(29 / 18)\nترجمہ : ( وہ جنت کیا ہی ) خوب بدلہ ہے اور ( کیا ) اچھی آرام گاہ ہے ۔","«اِرْتَفَقَ» ایسے آرام کے لیے استعمال ہوتا ہے جس میں کوئی دوسری چیز حائل یا خلل انداز نہ ہو ۔","آرام","ارتفق","18:29-18:31",2
21,4,"آ","سَبَتَ","«سَبَتَ» اس کے بنیادی معنیٰ راحت اور سکون ہے (م ۔ ل) یعنی ایسا آرام جس کے بعد راحت و سکون بھی حاصل ہو (مف)\nمثلاً :  قرآن کریم میں ہے :\n«وَّجَعَلۡنَا نَوۡمَکُمۡ سُبَاتًا» (9 / 78)\nترجمہ : اور ہم نے نیند کو تمہارے لیے ( موجبِ ) آرام بنایا ۔\nاور میڈیکل سائنس کی تحقیق یہ ہے کہ دن بھر کام کرنے سے جسم کے جو خلیے ختم ہوجاتے ہیں نیند کی حالت میں ان کی کمی پوری ہوجاتی ہے یہی وجہ ہے کہ پوری نیند لینے کے بعد انسان جب بیدار ہوتا ہے تو تازہ دم اور مسرُور ہوتا ہے اور یہی «سَبَتَ» کا مفہوم ہے ۔","«سَبَتَ» ایسا آرام جس  کے بعد  انسان راحت  محسوس کرے ۔","آرام","سبت","25:47-78:9",2
22,4,"آ","سَکَنَ","«سَکَنَ» حرکت اور اضطراب یعنی بے چینی  کے بعد ٹھہراؤ کو سکون کہتے ہیں (م ل) اور سکون کا لفظ ظاہری اور باطنی دونوں معنی کے لئے استعمال ہوتا ہے  جیسے جسمانی تھکاوٹ کے بعد آرام کرنے کے لیے ۔\n مثلاً : قرآن کریم میں ہے :\n«مَنۡ اِلٰہٌ غَیۡرُاللّٰہِ یَاۡتِیۡکُمۡ بِلَیۡلٍ تَسۡکُنُوۡنَ فِیۡہِ» (73 / 28)\nترجمہ : اللہ کے سوا اور کون معبود ہے جو رات لاسکے ۔ جس میں تم آرام کرتے ہو ۔\nاور ذہنی فکروں سے سکون حاصل کرنے کے لیے بھی استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ صَلِّ عَلَیۡہِمۡ ؕ اِنَّ صَلٰوتَکَ سَکَنٌ لَّہُمۡ» (103 / 9)\nترجمہ : اور اُن کے حق میں دعائے خیر کرو کیونکہ تمہاری دعا اُن کے لیے موجب تسکین ہے ۔","«سَکَنَ» جسمانی اور ذہنی آرام کے لیے استعمال ہوتا ہے ۔ ","آرام","سکن","6:13-6:96-7:189-9:103-10:67-16:80-23:18-27:86-28:72-28:73-30:21-40:61-42:33",13
23,5,"آ","اَمَل","«اَمَل» ایسی خواہش اور امید کو کہتے ہیں جس کا پورا ہونا ممکن تو ہو  لیکن مشکل ہوچنانچہ ابن فارس نے اس کے معنیٰ «اَلتَّثَبُّت وَالْاِنْتِظَار» کیا ہے ۔ (م-ل) یعنی کسی آرزو کی آس لگائے رکھنا اور اس کی تکمیل کا منتظر رہنا ، زندگی کی بہاریں دیکھنے کا خواہش مند رہنا جیسے کسی شاعر نے اپنے دوست سے وفا کی آرزو میں یہ مصرع کہہ دیا جو «اَمَل» کے مفہوم کی صحیح ترجمانی کرتا ہے : وفا فریب ہے طولِ امل ہے ، کچھ بھی نہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«ذَرۡہُمۡ یَاۡکُلُوۡاوَ یَتَمَتَّعُوۡا وَ یُلۡہِہِمُ الۡاَمَلُ  فَسَوۡفَ  یَعۡلَمُوۡنَ» (3 / 15)\nترجمہ : ( اے پیغمبرؐ ! ) اُن کو اُن کے حال پر رہنے دو کہ کھا لیں اور فائدے اٹھالیں اور ( طول ) امل ان کو ( دنیا میں ) مشغول کیے رہے ، عنقریب اُن کو ( اس کا انجام ) معلوم ہوجائے گا ۔","«اَمَل» بظاہر غیر متوقع اور دیر سے  پوری ہونے والی آرزو ۔","آرزو","امل","15:3-18:46-47:25",3
24,5,"آ","اُمْنِیَّۃ","«اُمْنِیَّۃ» ایسی آرزو جس کی کوئی مضبوط بنیاد موجود نہ ہو ۔ حسن ظن و گمان پرکوئی خیال باندھنا پھر اس کی آرزو رکھنا (مف) گویا یہ لفظ باطل اور جھوٹی خواہشات اور توقعات لگانے کے لیے آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ قَالُوۡا لَنۡ یَّدۡخُلَ الۡجَنَّۃَ اِلَّا مَنۡ کَانَ ہُوۡدًا اَوۡ نَصٰرٰی ؕ تِلۡکَ اَمَانِیُّہُمۡ  ؕ قُلۡ ہَاتُوۡا بُرۡہَانَکُمۡ  اِنۡ کُنۡتُمۡ صٰدِقِیۡنَ» (111 / 2)\nترجمہ : اور ( یہودی اور عیسائی ) کہتے ہیں کہ یہودیوں اور عیسائیوں کے سوا کوئی بہشت میں نہیں جائے گا ۔ یہ ان لوگوں کے خیالاتِ باطل ہیں ۔ ( اے پیغمبرؐ ! ) ان سے کہہ دیجیے ، اگر سچے ہو تو دلیل پیش کرو ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَمِنۡہُمۡ اُمِّیُّوۡنَ لَا یَعۡلَمُوۡنَ الۡکِتٰبَ اِلَّاۤ اَمَانِیَّ وَ اِنۡ ہُمۡ  اِلَّا یَظُنُّوۡنَ» (78 / 2)\nترجمہ : اور ان میں سے بعض اَن پڑھ ہیں کہ اپنے خیالاتِ باطل کے سوا ( خدا کی ) کتابوں سے واقف ہی نہیں اور وہ صرف ظن سے کام لیتے ہیں ۔\nبعض علماء نے  اس آیت میں امانی سے مراد وہ روایات لی ہیں جو انہوں نے اپنی طرف سے دین میں شامل کرلی تھیں یا تحریف کرلی تھی اور مجاہد نے «اِلَّا اَمَانِیَّ» کے معنی «اِلَّا کَذِبًا» یعنی جھوٹ کیا ہے اور بعض نے «اَمَانِیّ» سے مراد بغیرسوچے سمجھے تلاوت کرنا لیا ہے (مف) جیساکہ اس خیال کی تائید بعض دوسری آیات بھی کرتی ہیں اور«تَمَنّٰی» بمعنی جھوٹی بات کرنا «تَمَنِیَ الرَّجُلْ» بمعنی اس نے جھوٹ بولا ۔ (م-ق)\nمثلاً :  قرآن کریم میں ہے :\n«اَمْ لِلْاِنْسَانِ مَا تَمَنّٰى٘ۖ» (24 / 53)\nترجمہ : کیا انسان جس چیز کی آرزو کرتا ہے وہ اسے ضرور ملتی ہے؟ ","«اُمْنِیَّۃ» جھوٹی  اور بے بنیاد آرزو  کے لئے استعمال ہوتا ہے  ( اور جس آرزو کی بنیاد موجود ہو وہ « رَجَاء » ہے) ۔","آرزو","امنیۃ","2:78-2:111-4:123-57:14",4
25,5,"آ","وَدّ","«وَدّ» اس کے بنیادی معنی میں دو باتیں پائی جاتی ہیں : (1) کسی چیز سے محبت کرنا (2) اس کے حصول کی آرزو کرنا  پھر یہ لفظ کبھی دونوں معنوں میں استعمال ہوتا ہے کبھی کسی ایک معنی میں ۔\nمثلاً :  قرآن کریم میں ہے :\n«رُبَمَا یَوَدُّ الَّذِیۡنَ کَفَرُوۡا لَوۡ کَانُوۡا مُسۡلِمِیۡنَ» (2 / 15)\nترجمہ : کسی وقت کافر لوگ آرزو کریں گے کہ اے کاش وہ مسلمان ہوتے ۔\nاس آیت میں دونوں باتیں پائی جاتی ہیں ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«اِنَّ الَّذِیۡنَ اٰمَنُوۡا وَ عَمِلُوا الصّٰلِحٰتِ سَیَجۡعَلُ  لَہُمُ  الرَّحۡمٰنُ  وُدًّا» (96 / 19)\nترجمہ : اور جو لوگ ایمان لائے اور عمل نیک کیے خدا ان کی محبت ( مخلوقات کے دل میں ) ڈال دے گا ۔\nاس آیت میں صرف پہلا مفہوم پایا جاتا ہے ۔\nنیز دیکھئے ’’ خواہش  ۔","«وَدّ» کسی بھی چیز کی محبت اور آرزو کو کہتے ہیں ۔ ","آرزو","ود","2:96-2:105-2:109-2:266-3:30-3:69-3:118-4:42-4:73-4:89-4:102-5:82-11:90-15:2-19:96-29:25-30:21-33:20-42:23-60:1-60:2-60:7-68:9-70:11-85:14",25
26,6,"آ","بَرْزَخ","«بَرْزَخ» دو چیزوں کے درمیان کسی حائل چیز کو کہتے ہیں جبکہ ان دونوں چیزوں کے درمیان کافی وسعت ہو تو یہ حائل چیز برزخ ہے ۔ (م-ل) جیسے دنیا اور آخرت کے درمیان یا مرنے سے لے کر قیامت تک کا درمیانی وقفہ برزخ کہلاتا ہے ۔ لیکن ابن الفارس نے جو کافی وسعت کی قید لگائی ہے یہ صحیح نہیں کیونکہ قرآن کریم اس کی تائید نہیں کرتا ۔\nمثلاً : قرآن کریم میں ہے :\n«مَرَجَ الۡبَحۡرَیۡنِ یَلۡتَقِیٰنِ ، بَیۡنَہُمَا بَرۡزَخٌ  لَّا  یَبۡغِیٰنِ» (20 / 55)\nترجمہ : اُس نے دو دریا رواں کیے جو آپس میں ملتے ہیں ۔ دونوں میں ایک آڑ ہے کہ ( اس سے ) تجاوز نہیں کرسکتے ۔\nالبتہ اگر ’’ کافی کھلی جگہ ‘‘ کے بجائے کافی فرق  کہا جا ئے تو زیادہ بہتر ہے ۔\nبرزخ دراصل دو چیزوں کے درمیان ایک تیسری چیز ہوتی ہے جو آڑ کا کام بھی دیتی ہے مگر اس تیسری چیز یعنی برزخ میں دونوں چیزوں کی خاصیت بھی موجود ہوتی ہے چاہے ایک چیز کی خاصیت دوسری سے زیادہ ہو یا برابر ہو ۔ عالمِ برزخ کی بھی یہی صورت ہے کہ مومن کے لیے اس کی قبرراحت وسکون کی جگہ ہوتی ہے  اور کافر کے لیے یہی قبرعذاب اور تکلیف کی جگہ ، لیکن یہ راحت یا عذاب اخروی راحت یا عذاب سے کم تر درجہ کا ہوتا ہے ۔\nاور دو دریاؤں کا درمیانی برزخ یوں ہوتا ہے کہ سمندر میں ایک گرم رَو چل رہی ہے دوسری سرد رَو ہے تو اس برزخ کا پانی معتدل یعنی درمیانہ ہوگا ۔ اسی طرح اگرایک طرف میٹھا پانی ہو اور دوسری طرف کڑوا اور کھاری تو اس برزخ کا پانی درمیانی کیفیت کا حامل ہوگا ۔","«بَرْزَخ» دو چیزوں کے درمیان ایک تیسری چیز کو کہتے ہیں جس میں دونوں کی خصوصیات  برابر سرابر یا تھوڑی بہت پائی جائیں اور رکاوٹ  کا کام دے ۔","آڑ","برزخ","23:100-25:53-55:20",3
27,6,"آ","حِجْر","«حِجْر» حجارۃ کا عام معنی پتھر ہے جو سخت اور ٹھوس ہے ۔ پھر حجر ہراس چیزکو کہتے ہیں جو سخت بھی ہواورایسی آڑ یا روک کا کام دے جو کسی چیزکودوسری چیزوں سے الگ کرسکے ۔ (مف) ابنِ فارس کے نزدیک اس کا مفہوم یہ ہے : «اَلْمُنِعَ وَالْاِحَاطَۃُ عَلَی الشَّیْء» ۔ (م-ل)  (یعنی کسی چیز کی ممانعت اور احاطہ)\n گاؤں کی حفاظت کے لیے گاؤں کے گرد حصار کھینچ لینا ، پتھروں سے احاطہ کرنا ، کوٹ یا حویلی سے احاطہ کرنا ۔ یہ سب کچھ حجر کے مفہوم میں شامل ہے ،\nمثلاً : قرآن کریم میں ہے :\n«یَوۡمَ یَرَوۡنَ الۡمَلٰٓئِکَۃَ  لَا بُشۡرٰی یَوۡمَئِذٍ لِّلۡمُجۡرِمِیۡنَ وَ یَقُوۡلُوۡنَ حِجۡرًا مَّحۡجُوۡرًا» (22 / 25)\nترجمہ : جس دن وہ ( گنہگار) فرشتوں کو دیکھیں گے اس دن گنہگاروں کے لیے کوئی خوشی کی بات نہیں ہو گی اور کہیں گے ( خدا کرے ) تم روک لیے اور بند کر دیے جاؤ ۔ ( جالندھریؒ ) اور تفسیر عثمانی نے ترجمہ کیا ہے ( روک دی جاوے کوئی آڑ )\n«حِجْرًا مَّحجُوْرًا» کا لفظ اہل عرب کسی دشمن یا آفت کے نازل ہونے  کے وقت محاورتاً استعمال کرتے تھے جیسے ہم کہتے ہیں ’’ اس سے خدا کی پناہ ‘‘ ۔ تو سننے والا اس کو عموماً کوئی تکلیف نہ پہنچاتا ۔ پھر حجر کا لفظ ایسی عقل کے لیے بھی استعمال ہوتا ہے جو غلط اور باطل نظریات اور بیہودہ باتوں کو قبول کرنے سے انکار کر دے ۔ گویا ایسی محتاط عقل کو بھی جو اپنا  بچاؤ سوچ لے حجر کہتے ہیں ،\nمثلاً :  قرآن کریم میں ہے :\n« ہَلۡ فِیۡ ذٰلِکَ قَسَمٌ  لِّذِیۡ حِجۡرٍ» (5 / 89)\nترجمہ :بیشک یہ چیزیں عقلمندوں کے نزدیک قسم کھانے لے لائق ہیں ۔\nپھر حجر کا لفظ ممنوع ، ناجائز اور حرام چیز کے لیے بھی استعمال ہوتا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«وَ قَالُوۡا ہٰذِہٖۤ  اَنۡعَامٌ  وَّ حَرۡثٌ حِجۡرٌ ٭ۖ لَّا یَطۡعَمُہَاۤ اِلَّا مَنۡ نَّشَآءُ بِزَعۡمِہِمۡ» (138 / 6)\nترجمہ : اور وہ اپنے خیال سے یہ بھی کہتے ہیں کہ یہ جانور اور کھیتی منع ہے اسے اس شخص کے سوا جسے ہم چاہتے ہیں کوئی نہ کھائے ۔","«حِجْر» ایسی روک کے لئے استعمال ہوتا ہے  جو کسی چیز کو دوسری چیزوں سے محفوظ رکھے ۔","آڑ","حجر","6:138-25:22-25:53",3
28,6,"آ","حجز","«حَجَزَ» کہتے ہیں دو چیزوں کے درمیان ایک تیسری چیز کو جو دونوں کے درمیان حائل ہو جائے اورحاجز کے معنی اوٹ اور پردہ  کے بھی ہیں\nمثلاً :  قرآن کریم میں ہے :\n«وَ جَعَلَ بَیۡنَ الۡبَحۡرَیۡنِ حَاجِزًا» (61 / 27)\nترجمہ : اور دو دریاؤں کے درمیان اوٹ ( کس نے ) بنائی ؟\nپھر حاجز کا لفظ درمیان میں حائل ہو کر کسی ایک چیز کو روک لینے یا دوسری کو بچا لینے کے معنی میں بھی آتا ہے ۔\n«فَمَا مِنۡکُمۡ  مِّنۡ اَحَدٍ عَنۡہُ حٰجِزِیۡنَ» (47 / 69)\nترجمہ : پھر تم میں سے کوئی ( ہمیں ) اس سے روکنے والا نہ ہوتا ( جالندھریؒ )\nتفسیر عثمانی نے اسکا ترجمہ کیا ہے : پھر تم میں سے کوئی ایسا نہیں جو اس سے بچا لے ۔","«حَجَزَ» دو چیزوں کے درمیان ایسی روک جو ایک چیز کو دوسری چیز سے محفوظ اور بچائے رکھے ۔","آڑ","حجز","27:61-69:47",2
29,6,"آ","حَدّ","«حَدّ» کسی بھی چیز کی انتہا اور آخری کنارا جو اسے دوسری چیزوں سے الگ کر دے (م ر) گویا اس کے بنیادی معنی میں روک اور کنارے کا مفہوم پایا جاتا ہے ۔ لہذا  «حَدّ» کوئی تیسری چیز نہیں ہوتی یہ ایک ہی چیز کا آخری کنارا ہے جو اُسے دوسری چیزوں سے ملنے نہیں دیتا (مف) ہمارے ہاں عام طور پر حدُود اربعہ کا لفظ استعمال کیا جاتا ہے  ہے جو اس مفہوم کی وضاحت کرتا ہے ۔\nمثلاً :  قرآن کریم میں ہے :\n«وَ مَنۡ یَّعۡصِ اللّٰہَ  وَ رَسُوۡلَہٗ وَ یَتَعَدَّ حُدُوۡدَہٗ یُدۡخِلۡہُ نَارًا خَالِدًا فِیۡہَا» (14 / 4)\nترجمہ : اور جو کوئی خدا اور اس کے رسول کی نافرمانی کرے اور اس کی حدوں ( آخری انتہا ) سے آگے نکل جائے تو خدا اُسے دوزخ میں ڈالے گا جہاں وہ ہمیشہ رہے گا ۔\n نیز دیکھئے ’’ پردہ ‘‘ اور ’’ دیوار ‘‘ ۔","«حَدّ» کسی بھی چیز کی انتہا اور آخری کنارے کو کہتے ہیں جو اسے دوسری چیزوں سے ملنے سے روک دے ۔","آڑ","حد","2:187-2:229-2:230-4:13-4:14-9:97-9:112-58:4-65:1",9
30,7,"آ","تَسْرِیْحُ","«تَسْرِيْحُ» یہ لفظ «سَرَح» سے نکلا ہے ۔ جس کے معنی ہیں مویشی (جانوروں) کو چرنے کے لیے لے جانا اور «اَسْرَحَ» بمعنی اونٹ یا مویشیوں کو چرنے کے لیے بھیجنا (منجد) بعد میں اس کا اطلاق مویشیوں کو چراگاہوں میں کھلا چھوڑ دینے پر ہونے لگا (م ر)\nمثلاً : قرآن کریم میں ہے :\n«وَ لَکُمۡ فِیۡہَا جَمَالٌ حِیۡنَ تُرِیۡحُوۡنَ وَ حِیۡنَ  تَسۡرَحُوۡنَ» (6 / 16)\nترجمہ : اور شام کو جب ان مویشیوں کو ( جنگل سے ) لاتے ہو اور صبح کو جب ( جنگل ) چرانے لے جاتے ہو تو ان سے تمہاری عزت و شان ہے ۔\nگویا «تَسْرِيْحُ» کا بنیادی معنی رخصت میں سہولت کو ملحوظ رکھنا ہوتا ہے اور اس میں بندھن کی گرفت ایسی مضبوط نہیں ہوتی جیسی طلاق کے مفہوم میں پائی جاتی ہے ۔ نیز«تَسْرِيْحُ» کا لفظ عام ہے جبکہ طلاق کا لفظ قریباً عورت ہی سے مختص ہو کر رہ گیا ہے ۔ البتہ یہ تسریح اگرعورت سے متعلق ہو جیسے «تَسْرِيْحُ الْمَرَاۃ» تو پھر اس کے معنی عورت کو طلاق دے کررخصت میں آسانی ملحوظ رکھنا  ہوں گے ۔ (م ر)\nمثلاً : قرآن کریم میں ہے :\n«اَلطَّلَاقُ مَرَّتٰنِ۪ فَاِمۡسَاکٌۢ بِمَعۡرُوۡفٍ اَوۡ تَسۡرِیۡحٌۢ بِاِحۡسَانٍ» (229 / 2)\nترجمہ : طلاق ( صرف ) دو بار ہے ۔ پھر یا تو بطریق حسنہ نکاح میں رہنے دیا جائے یا انہیں بھلائی سے رخصت کر دیا جائے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«یٰۤاَیُّہَا النَّبِیُّ  قُلۡ  لِّاَزۡوَاجِکَ اِنۡ  کُنۡـتُنَّ تُرِدۡنَ الۡحَیٰوۃَ  الدُّنۡیَا وَ زِیۡنَتَہَا فَتَعَالَیۡنَ اُمَتِّعۡکُنَّ وَ اُسَرِّحۡکُنَّ سَرَاحًا جَمِیۡلًا»  (28 / 33)\nترجمہ : اے نبی ﷺ ! آپ اپنی بیویوں سے کہہ دیجیے اگر تم دنیا کی زندگی اور اس کی زینت و آرائش کی خواستگار ہو تو آؤ میں تمہیں کچھ مال دوں اور اچھی طرح سے رخصت کر دوں ! ","«تَسْرِيْحُ» اور «اَلطَّلَاق» یہ دونوں لفظ عورت کی جدائی یا عام مفہوم میں ’’ طلاق ‘‘ کے لیے استعمال ہوتے ہیں ۔ «اَلطَّلَاق» میں  تخلیہ یعنی تنہا چھوڑ دینا  ضروری  شرط ہے اور ارسال یعنی  اپنے گھر سے کسی دوسری جگہ بھیج دینا  جزوی شرط ہے ۔ جبکہ «تَسْرِيْحُ» میں لازمی جز  ارسال یعنی بیوی کو اپنے گھر سے رخصت  کردینا  ہے اور وہ بھی آسانی اور سہولت کو مدنظر رکھتے ہوئے ۔","آزاد","تسریح","2:229-16:6-33:28-33:49",4
31,7,"آ","تَحْرِیْرًا","«تَحْرِیْرًا» اسکی اصل «حُرّ» ہے اور اس کے مادہ میں دو باتیں پائی جاتی ہیں (1) آزاد ہونا (2) عیب و نقص سے پاک ہونا (م ل) «حُرّ» کی ضد «عَبْد» بمعنی غلام ہے ۔ اور «حَرَّرَ ، تَحْرِیْرًا» کے معنی غلام کو آزاد کرنا گویا یہ لفظ صرف غلام کو آزاد کرنے کے لیے مخصوص ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَنۡ قَتَلَ مُؤۡمِنًا خَطَئًا فَتَحۡرِیۡرُ رَقَبَۃٍ مُّؤۡمِنَۃٍ وَّ دِیَۃٌ مُّسَلَّمَۃٌ اِلٰۤی اَہۡلِہٖۤ» (92 / 4)\nترجمہ : اور جو بھول کر بھی مومن کو مار ڈالے تو ( ایک تو ) ایک مسلمان غلام آزاد کرے اور ( دوسرے ) مقتول کے وارثوں کو خون بہا بھی دے ۔ ","«تَحْرِیْرًا» کا لفظ صرف غلام کو آزاد کرنے کے لیے مخصوص ہے ۔","آزاد","تحریر","4:92-5:89-58:3",3
32,7,"آ","حُرّ","«حُرّ» بمعنی آزاد (اس کی  ضد عبد یعنی غلام ہے ) یعنی ایسا شخص جو کسی کا غلام نہ ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلۡحُرُّ بِالۡحُرِّ وَ الۡعَبۡدُ بِالۡعَبۡدِ وَ الۡاُنۡثٰی بِالۡاُنۡثٰی» (178 / 2)\nترجمہ : آزاد کے بدلے آزاد مارا جائے ، غلام کے بدلے غلام اور عورت کے بدلے عورت ۔","«حُرّ» غلام  کے مقابلہ میں آزاد ۔","آزاد","حر","2:178-3:35",2
33,7,"آ","سُدٰی","«سُدٰی النَّاقَۃ» بمعنی اونٹنی نے اپنی چال میں فراخ قدم رکھا اور ساٰدی اس اونٹنی کو کہتے ہیں جواپنی چال میں کھلے کھلے قدم رکھے (منجد) اور «سُدٰی» بمعنی شتر بے مہار جس پر کوئی پابندی نہ ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَیَحۡسَبُ  الۡاِنۡسَانُ اَنۡ یُّتۡرَکَ سُدًی»  (36 / 75)\nترجمہ : کیا انسان خیال کرتا ہے کہ چھوٹا رہے گا بے قید ( عثمانی ) ","«سُدٰی» شتر بے مہار جس پر کوئی پابندی نہ ہو۔","آزاد","سدی","75:36",1
34,7,"آ","طَلَاق","«اَلطَّلَاق» اس کے مادہ اصل ’’ طلق ‘‘ میں دو باتیں پائی جاتی ہیں (1) تخلیہ یعنی تنہائی (2) ارسال یعنی بھیجنا (م ل)  اس کا معنی ہے گویا کسی ذی حیات کو ، جو اپنے کنٹرول اور نگہداشت میں ہو ، اس سے کنٹرول اٹھا لینا اور اپنے ہاں سے روانہ کر دینا اور اس لفظ کا استعمال بالعموم اپنی بیوی کو نکاح کے بندھن سے آزاد کرنے اور رخصت کرنے کے لیے استعمال ہوتا ہے ۔ تاہم یہ ضروری نہیں کہ دونوں باتیں ایک ساتھ ہی پائی جائیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلطَّلَاقُ مَرَّتٰنِ» (229 / 2)\n ترجمہ : طلاق دو بار ہے ۔\nاب یہ تو ظاہر ہے کہ ایک یا دو مرتبہ کی طلاق میں تخلیہ تو پایا جاتا ہے لیکن رخصتی نہیں ہے ۔\nاسی طرح قیدی کو آزاد کرنے کے لیے بھی طلاق کا لفظ استعمال ہوتا ہے ( گو کہ قرآن کریم میں اس کی مثال موجود نہیں ) تو یہاں بھی تخلیہ یا اپنے حق سے دستبرداری کی شرط موجود ہے لیکن ارسال یعنی رخصت کرنے  کی نہ ضرورت ہے نہ شرط ۔ جس کا مطلب یہ ہے کہ طلاق میں اصل شرط تخلیہ یعنی تنہائی  ہے ۔ اور ارسال یعنی رخصت کی شرط بعض اوقات جیسے تیسری مرتبہ کی طلاق میں یہ شرط لازمی ہے اور بعض اوقات معدوم ہوتی ہے جیسے پہلی یا دوسری بار کی طلاق میں ۔","«اَلطَّلَاق» اور «تَسْرِيْحُ» دونوں لفظ عورت کی جدائی یا عام مفہوم میں ’’ طلاق ‘‘ کے لیے استعمال ہوتے ہیں ۔ «الطلاق» میں تخلیہ ضروری اور ارسال یعنی رخصت کرنا جزوی شرط ہے جبکہ «تَسْرِیْح» میں لازمی جز ارسال یعنی رخصت کرنا ہے اور وہ بھی آسانی اور سہولت کو مدنظر رکھتے ہوئے ۔","آزاد","طلاق","2:227-2:229",2
35,7,"آ","مُحِصَن","«حَصَن»  کے معنی قلعہ یا پناہ گاہ کے ہیں اورابن الفارس کے نزدیک اس میں تین باتیں پائی جاتی ہیں ۔ حفاظت ، احاطہ اور پناہ ۔ اور احصان میں بھی بنیادی طور پرانہی باتوں کا تصور پایا جاتا ہے ۔ احصان بھی دو قسم پر ہے ایک یہ کہ آزادی اوراس کا شرف غلامی کے مقابلے میں بذاتِ خود ایک قلعہ کا کام دیتا ہے ۔ دوسرے نکاح بھی فحاشی سے بچنے اور عفت و عصمت کو محفوظ رکھنے کے لیے قلعہ کا کام دیتا ہے ۔ قرآن کریم میں یہ لفظ ان دونوں معنوں میں استعمال ہوا ہے ۔ محصن یا محصنات اگرعفیف یا عفیفہ کہ معنی میں ہو تو ص کو زبر اور زیر دونوں کے ساتھ پڑھ سکتے ہیں اوراگر حُرِّمَتْ کے بعد یہ لفظ آئے تو ص پر زبر ہی پڑھا جائے گا اوراس کا معنیٰ صرف شادی شدہ ہو گا (مف) لونڈی اور غلام کے مقابلہ میں آزاد مرد اورعورت اپنی عصمت کی حفاظت کرنے میں بہت حد تک آزاد ہیں ۔ ایک تو لونڈی غلام کو کام کاج کے لیے باہر جانا پڑتا ہے اور وہ معاشرہ میں کمتر درجہ رکھنے کے باعث فحاشی کے زیادہ مرتکب یا شکار ہو جاتے تھے ۔ دوسرے اس وقت کا یہ دستور بھی تھا کہ مالک محض لالچ کی خاطر اپنی لونڈی سے پیشہ کرواتے تھے ۔ چنانچہ اللہ تعالیٰ نے اس مکروہ کاروبار سے سختی سے منع فرما دیا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تُکۡرِہُوۡا فَتَیٰتِکُمۡ عَلَی الۡبِغَآءِ  اِنۡ  اَرَدۡنَ تَحَصُّنًا لِّتَبۡتَغُوۡا عَرَضَ الۡحَیٰوۃِ  الدُّنۡیَا» (33 / 24)\nترجمہ : اور اپنی لونڈیوں کو اگر وہ پاکدامن رہنا چاہیں تو محض دنیوی فائدہ حاصل کرنے کے لیے بدکاری پر مجبور نہ کرو ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَمَنۡ لَّمۡ یَسۡتَطِعۡ مِنۡکُمۡ طَوۡلًا اَنۡ یَّنۡکِحَ الۡمُحۡصَنٰتِ الۡمُؤۡمِنٰتِ فَمِنۡ مَّا مَلَکَتۡ اَیۡمَانُکُمۡ مِّنۡ فَتَیٰتِکُمُ الۡمُؤۡمِنٰتِ»  (25 / 4)\nترجمہ : اور جو شخص تم میں سے آزاد عورتوں سے نکاح کرنے کا مقدور (طاقت) نہ رکھے تو مومن لونڈیوں ہی سے جو تمہارے قبضہ میں آ گئی ہوں نکاح کر لے ۔\nاس آیت میں «مُحْصَنٰت» کا لفظ آزاد اور کنواری عورتوں کے لیے استعمال ہوا ہے ۔ شادی شدہ عورتوں کو اپنی عصمت کی حفاظت کے اور بھی زیادہ مواقع میسرہوتے ہیں ۔ نکاح کے بعد شہوت کی تسکین اور مرد کی غیرت عورت کو فحاشی سے بچانے کے لیے مضبوط قلعہ کا کام دیتی ہے ۔ درج ذیل آیت میں «مُحْصَنٰت» کا لفظ صرف شادی شدہ عورت کا مفہوم واضح کر رہا ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَّالۡمُحۡصَنٰتُ مِنَ النِّسَآءِ  اِلَّا مَا مَلَکَتۡ اَیۡمَانُکُمۡ» (24 / 4)\nترجمہ : اور شوہر والی عورتیں بھی ( تم پر حرام ہیں ) مگر وہ لونڈیاں جو تمہارے قبضہ میں آ جائیں ۔\nگویا «اِحْصَان» کا لفظ اپنی عصمت و عفت کی حفاظت میں آزاد ہونے کے مفہوم کو ظاہر کرتا ہے ۔","«مُحْصِن» اپنی عصمت و عزت کی حفاظت کرنے میں آزاد اور خودمختار ۔","آزاد","محصن","4:24-4:25-5:5-24:4-24:23",5
36,8,"آ","اِمْتَحَنَ","«اِمْتَحَان» امتحان ایسی آزمائش کو کہتے ہیں جو سختی کے بجائے نرمی سے کی جائے اور اس میں گنجائش اور وسعت کا پہلو بھی شامل ہو (م ر) اور بسا اوقات اس آزمائش سے پہلے امتحان دینے والے کو زیر تعلیم و تربیت بھی رکھا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَاالَّذِیۡنَ اٰمَنُوۡۤا اِذَا جَآءَکُمُ الۡمُؤۡمِنٰتُ مُہٰجِرٰتٍ فَامۡتَحِنُوۡہُنَّ ؕ اَللّٰہُ  اَعۡلَمُ  بِاِیۡمَانِہِنَّ ۚ فَاِنۡ عَلِمۡتُمُوۡہُنَّ  مُؤۡمِنٰتٍ فَلَا تَرۡجِعُوۡہُنَّ  اِلَی  الۡکُفَّارِ» (10 / 60)\nترجمہ : اے ایمان والو ! جب تمہارے پاس مومن عورتیں وطن چھوڑ کر آئیں تو ان کی آزمائش کر لو ۔ ( اور ) خدا تو ان کے ایمان کو خوب جانتا ہے ۔ سو اگر تمہیں معلوم ہو کہ مومن ہیں تو ان کو کفار کے پاس واپس نہ بھیجو ۔","«اِمْتَحَان» ایسی آزمائش جس میں سختی کے بجائے نرمی ہو اور اِس میں سابقہ تعلیم و تربیت کی آزمائش ہوتی ہے ۔","آزمائش","امتحن","49:3-60:10",2
37,8,"آ","بَلٰی","«یَبٰلَو ، بَلَاءً» ایسی آزمائش ہے جس میں سختی اور شدت پائی جائے صاحب مُنْتَہَی الْاَرَب اس کے معنی سختی  بتلاتے ہیں (م ر) اور یہ آزمائش خیر و شر دونوں صورتوں میں ہو سکتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَبَلَوۡنٰہُمۡ بِالۡحَسَنٰتِ وَ السَّیِّاٰتِ لَعَلَّہُمۡ یَرۡجِعُوۡنَ»  (168 / 7)\nترجمہ : اور ہم آسائشوں اور تکلیفوں ( دونوں طرح ) سے ان کی آزمائش کرتے رہے تاکہ وہ ( ہماری طرف ) رجوع کریں ۔\nتاہم آزمائش چونکہ تکلیف دہ ہوتی ہے اس لیے شر کے پہلو میں استعمال زیادہ ہوتا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«وَلَنَبۡلُوَنَّکُمۡ بِشَیۡءٍ مِّنَ الۡخَوۡفِ وَ الۡجُوۡعِ وَ نَقۡصٍ مِّنَ الۡاَمۡوَالِ وَ الۡاَنۡفُسِ وَ الثَّمَرٰتِ ؕ وَ بَشِّرِ الصّٰبِرِیۡنَ»  (155 / 2)\nترجمہ : اور ہم کسی قدر خوف بھوک اور مال ، جانوں اور میووں کے نقصان سے تمہاری آزمائش کریں گے اور صبر کرنے والوں کو ( خدا کی خوشنودی کی ) بشارت سنا دو ۔\nاور«اِبْتَلیٰ» کے معنی کسی چیز کو الٹ پلٹ کرنا یا حالات کو  زیر و زبر کر کے جانچنا ہوتا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«اِنَّا خَلَقۡنَا الۡاِنۡسَانَ مِنۡ نُّطۡفَۃٍ  اَمۡشَاجٍ ٭ۖ  نَّبۡتَلِیۡہِ» (3 / 76)\nترجمہ : ہم نے انسان کو مخلوط نطفہ سے پیدا کیا جسے ہم الٹتے پلٹتے رہے ۔\nپھر«اِبْتَلَاء» عموماً کسی اتفاقی حادثہ سے ہوتا ہے ۔ ایسا واقعہ سے جسے دوسرے لوگ بھی دیکھ سکیں ۔ (مف)\n دیکھیے درج ذیل آیت :\n«وَاِذِ ابۡتَلٰۤی اِبۡرٰہٖمَ رَبُّہٗ بِکَلِمٰتٍ فَاَتَمَّہُنَّ» (124 / 2)\nترجمہ : اور جب حضرت ابراہیم علیہ السلام کی اس کے پروردگار نے چند باتوں میں آزمائش کی تو وہ ان میں پورے اترے ۔\nاور ظاہر ہے کہ یہ باتیں ترک وطن ، اولاد کو جنگل بیابان میں بے آسرا چھوڑ دینا ، بیٹے کی قربانی پر تیار ہو جانا ,یا آگ میں داخل ہو جانا وغیرہ تھے ، جنھیں دوسرے سب لوگ دیکھ سکتے تھے ۔","«بَلَاء» اور «اِبْتَلَاء» یہ آزمائش سخت قسم کی ہوتی ہے اور بالعموم ایسے واقعات سے ہوتی جسے دوسرے بھی دیکھ سکیں یعنی حوادث سے ہوتی ہے ۔","آزمائش","بلی","2:49-2:124-2:155-2:249-3:152-3:154-3:186-4:6-5:48-5:94-6:165-7:141-7:163-7:168-8:17-10:30-11:7-14:6-16:92-18:7-21:35-23:30-27:40-33:11-37:106-44:33-47:4-47:31-67:2-68:17-76:2-89:15-89:16",33
38,8,"آ","فَتَنَ","«فَتَنَ» کے معنی سونا چاندی کو کٹھیالی میں ڈال کر تپانا گلانا اور کھوٹ معلوم کرنا ہے ( منجد ) «اِبْتَلَاء» کی طرح اس آزمائش میں بھی سختی پائی جاتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یَوۡمَ ہُمۡ عَلَی النَّارِ یُفۡتَنُوۡنَ» (13 / 51)\nترجمہ : وہ اس دن آگ پر تپائے جائیں گے ۔\nاور «فِتْنَۃ» کا لفظ اکثر برے مفہوم میں استعمال ہوتا ہے ۔ فتنہ کے معنی آزمائش ، دکھ ، رنج ، رسوائی ، دیوانگی ، عبرت ، عذاب ، مرض ، ان تمام معنوں میں استعمال ہوتا ہے (منجد) اسی طرح «فَتَّان» کے معنی شر انگیز انسان ، چور ، شیطان ہیں ۔ (منجد) جبکہ ابتلاء میں انسان کی آزمائش ذاتی برائی اور خباثت کے سبب سے نہیں آتی ۔ دور ابتلاء اور دور فتن میں جو فرق ہے وہ بالکل واضح ہے ۔ ابتلاء میں برا پہلو عموماً قدرتی حوادث سے متعلق ہوتا ہے ‘ جبکہ فتنہ میں برا پہلو بسا اوقات انسان کا اپنا پیدا کردہ ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِلَّا تَفۡعَلُوۡہُ تَکُنۡ فِتۡنَۃٌ فِی الۡاَرۡضِ وَ فَسَادٌ کَبِیۡرٌ» (73 / 8)\nترجمہ : مسلمانو ! اگر تم ایسا نہ کرو گے تو ملک میں فتنہ بپا ہو جائے گا اور بڑا فساد مچے گا ۔\nابتلاء اور فتنہ میں فرق یہ ہے کہ فتنہ میں عام طور پر آزمائش ایسی چیزوں سے ہوتی ہے جن سے انسان محبت کرتا ہے اور ان سے اس کا دلی لگاؤ ہوتا ہے ۔ (م ر)\nمثلاً : قرآن کریم میں ہے :\n«وَاعۡلَمُوۡۤا اَنَّمَاۤ اَمۡوَالُکُمۡ  وَ اَوۡلَادُکُمۡ  فِتۡنَۃٌ» (28 / 8)\nترجمہ : اور جان رکھو کہ تمہارے مال اور اولاد بہت بڑی آزمائش ہیں ۔\nاسی پر قوی دلیل ہے ۔ سورۂ بقرہ میں ہاروت اور ماروت کا ذکر کرتے ہوئے فرمایا :\n«وَ مَا یُعَلِّمٰنِ مِنۡ اَحَدٍ حَتّٰی یَقُوۡلَاۤ اِنَّمَا نَحۡنُ فِتۡنَۃٌ فَلَا تَکۡفُرۡ» (102 / 2)\nترجمہ : وہ دونوں اس وقت تک کسی کو جادو نہ سکھاتے تھے جب تک یہ نہ کہہ دیتے کہ ہم تو ( ذریعہ ) آزمائش ہیں تم کفر میں نہ پڑو ۔\nاور یہ کفر جادو کی طلب تھی جس کی ہوس میں وہ لوگ گرفتار تھے ۔ اسی ہوس کو فتنہ سے تعبیر کیا گیا ۔\nنوٹ : (کٹھیالی چان٘دی سونا وغیرہ پگلا نے کے لیے مٹّی کا بنا ہوا پیالہ نما برتن)","«فَتَنَ» بمعنی آزمائش اور یہ بالعموم ایسی چیزوں سے ہوتی ہے جن سے انسانوں کا دلی لگاؤ ہوتاہے ۔ ","آزمائش","فتن","2:102-2:191-2:193-2:217-3:7-4:91-4:101-5:41-5:49-5:71-6:53-7:27-7:155-8:25-8:28-8:39-8:73-9:47-9:48-9:49-9:126-10:83-10:85-16:110-17:60-17:73-20:40-20:85-20:90-20:131-21:35-21:111-22:11-22:53-24:63-25:20-27:47-29:2-29:3-29:10-33:14-37:63-38:24-38:34-39:49-44:17-51:14-54:27-57:14-60:5-64:15-72:17-74:31-85:10",54
39,9,"آ","ھَیِّن","«ھَیِّنٌ» اس کا مادہ «ھون» ہے ۔ جس میں آسانی کے علاوہ نرمی کا پہلو بھی شامل ہے (م ر) بشرطیکہ اس نرمی میں اہانت اور بے عزّتی نہ ہو ۔ بلکہ نرمی کے ساتھ ساتھ سکینت اور وقار شامل ہو اور یہ صفت قابل تعریف ہے  ۔\nمثلاً : قرآن کریم میں ہے :\n«وَعِبَادُ  الرَّحۡمٰنِ الَّذِیۡنَ  یَمۡشُوۡنَ عَلَی الۡاَرۡضِ ہَوۡنًا»  (25/63)\nترجمہ : اور خدا کے بندے تو وہ ہیں جو زمین پر متواضع ہو کر چلتے ہیں ۔\nاور اگر یہ نرمی کسی کو کمتر کر دے تو یہ ذلت اور رسوائی کی بات ہوتی ہے اور یہ مذموم فعل ہے اور اس کے لیے «ھُوْن» کا لفظ استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَالۡیَوۡمَ تُجۡزَوۡنَ عَذَابَ الۡہُوۡنِ» (20 / 46)\nترجمہ : سو آج تم کو ذلت کا عذاب ہے ۔\nلہذا «ھَیِّنٌ» ایسا کام ہے جو کرنے والے کی طاقت اور قدرت کے مقابلہ میں بالکل ہیچ (ہلکا) ہو کیونکہ اس کے مادہ کے مفہوم میں عاجزی کے ساتھ ساتھ کمتری و ذلت کا پہلو بھی شامل ہے ۔ یعنی بالکل معمولی اور حقیر بات ۔\nچناچہ سورۂ مریم میں ہے کہ جب فرشتے نے حضرت مریم کو بن باپ بیٹے کی پیدائش کی اطلاع دی تو وہ حیران ہو کر بولیں جسے قرآن کریم نے یوں بیان کیا ہے:\n«اَنّٰی یَکُوۡنُ لِیۡ غُلٰمٌ وَّ لَمۡ یَمۡسَسۡنِیۡ  بَشَرٌ وَّ لَمۡ اَکُ بَغِیًّا ، قَالَ کَذٰلِکِ ۚ قَالَ رَبُّکِ ہُوَعَلَیَّ ہَیِّنٌ» (21 - 20 / 19)\nترجمہ : یہ کیسے ممکن ہے کہ میرے ہاں لڑکا پیدا ہو جبکہ مجھے نہ کسی آدمی نے چھوا ہے اور نہ ہی میں بدکار ہوں ۔ فرشتے نے کہا : یونہی ہو گا ۔ تمہارے پروردگار نے فرمایا : یہ چیز میرے لیے بہت آسان ہے ۔","«ھَیِّنٌ» وہ بات یا کام جو غافل کی قوت و قدرت کے مقابلہ میں بہت کم درجہ کا ہو ۔","آسان","ھین","19:9-19:21",2
40,9,"آ","يَسِيرٌ","«يَسِيرٌ» اس کے مادہ اصل «یُسْر» میں آسانی اور ہلکا ہونا داخل ہے ( م ل ) اور «یَسِیْر» وہ کام ہے جو آسانی اور سہولت کے ساتھ سرانجام پا جائے ۔ اسکی ضد «عُسَیْر» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَنۡ یَّفۡعَلۡ ذٰلِکَ عُدۡوَانًا وَّ ظُلۡمًا فَسَوۡفَ نُصۡلِیۡہِ نَارًا ؕ وَ کَانَ ذٰلِکَ عَلَی اللّٰہِ  یَسِیۡرًا»  (4/30)\nترجمہ : اور جو تعدّی اور ظلم سے ایسا کرے گا ہم اس کو عنقریب جہنم میں داخل کریں گے اور یہ بات اللہ کے لیے آسان ہے ۔","«يَسِيرٌ» بمعنی آسانی ، وہ کام ہے جو آسانی اور سہولت کے ساتھ سرانجام پا جائے ۔","آسان","یسیر","4:30-4:169-12:65-22:70-29:19-33:19-33:30-35:11-50:44-57:22-64:7-74:10-84:8",13
41,10,"آ","سَمَاء","«سَمَاء» اور «سَمُوْء» بنیادی معنی بلندی کے ہیں لیکن اس بلندی کی کوئی حد مقرر نہیں ۔ صاحب فِقْہُ الُغَۃ نے سماء کی تعریف یہ کی ہے : ہر وہ چیز جو ہمارے اوپر ہو اور ہم پر سایہ ڈالنے والی ہو سماء ہے ۔ (ف ل)\nمثلاً : قرآن کریم میں ہے :\n«وَّ اَنۡزَلَ مِنَ السَّمَآءِ مَآءً»  (2/22)\nترجمہ :’’ اور اس اللہ نے آسمان سے پانی اتارا ( مینہ برسایا )\nیہاں سماء سے مراد بادل ہیں جو سطح زمین سے عموماً میل ڈیڑھ میل کی بلندی پر اڑتے پھرتے ہیں ۔ اس معمولی سی بلندی کے لیے بھی سماء کا لفظ استعمال ہوا ہے اور ایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«اِنَّا زَیَّنَّا السَّمَآءَ  الدُّنۡیَا بِزِیۡنَۃِۣ الۡکَوَاکِبِ» (37/6)\nترجمہ :  بیشک ہم نے آسمان دنیا کو ستاروں کی زینت سے مزین کیا ۔\nیہاں اتنی زیادہ بلندی مراد ہے جتنی دوری پر ستارے چمکتے ہیں خواہ وہ لاکھوں میلوں کی بلندی پر ہوں جیسے چاند یا کروڑوں میلوں پر جیسے سورج یا ارب ہا ارب  میل کی بلندی جیسے العقرب وغیرہ ۔\n«سَمَاء» کا لفظ اسمائے نسبیہ میں سے ہے اوراس کی ضد ’’ ارض ‘‘ ہے ۔ یعنی ہر چیز اپنے ماتحت یعنی جونیچے ہیں ان کے لحاظ «سَمَاء» ہے اور وہی چیز اپنے مافوق یعنی جو اوپر ہے اس کے لحاظ سے «اَرْض» بھی ہے (مف) گویا ایک ایسی چیز جو اپنے ماتحت کے لحاظ سے «سَمَاء» ہے اور وہی اپنے مافوق کے لحاظ سے ارض ہے ۔\n مثلاً : قرآن کریم میں ہے :\n«اَللّٰہُ  الَّذِیۡ خَلَقَ سَبۡعَ  سَمٰوٰتٍ وَّ مِنَ الۡاَرۡضِ مِثۡلَہُنَّ» (65 / 12)\nترجمہ :  خدا ہی تو ہے جس نے سات آسمان اور ویسی ہی زمینیں پیدا کیں ۔\nاس آیت میں یہی معنی پائے جاتے ہیں ۔\nپھر جس طرح سماء بلندی کے معنی میں استعمال ہوتا ہے ۔ ’’ اَرْض ‘‘ بھی پستی کے معنوں میں استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لَوۡ شِئۡنَا لَرَفَعۡنٰہُ بِہَا وَ لٰکِنَّہٗۤ اَخۡلَدَ اِلَی الۡاَرۡضِ وَ اتَّبَعَ ہَوٰىہُ»  (7/176)\nترجمہ : اور اگر ہم چاہتے تو ان آیتوں سے اس کے ( درجے ) بلند کر دیتے ۔ مگر وہ تو پستی کی طرف مائل ہو گیا ۔ اور اپنی خواہش کے پیچھے چل پڑا ۔","«سَمَاء» اس کے بنیادی معنی بلندی کے ہیں لیکن اس بلندی کی کوئی حد مقرر نہیں ۔","آسمان","سماء","2:19-2:22-2:29-2:33-2:59-2:107-2:116-2:117-2:144-2:164-2:255-2:284-3:5-3:29-3:83-3:109-3:129-3:133-3:180-3:189-3:190-3:191-4:126-4:131-4:132-4:153-4:170-4:171-5:17-5:18-5:40-5:97-5:112-5:114-5:120-6:1-6:3-6:6-6:12-6:14-6:35-6:73-6:75-6:79-6:99-6:101-6:125-7:40-7:54-7:96-7:158-7:162-7:185-7:187-8:11-8:32-9:36-9:116-10:3-10:6-10:18-10:24-10:31-10:55-10:61-10:66-10:68-10:101-11:7-11:44-11:52-11:107-11:108-11:123-12:101-12:105-13:2-13:15-13:16-13:17-14:2-14:10-14:19-14:24-14:32-14:38-14:48-15:14-15:16-15:22-15:85-16:3-16:10-16:49-16:52-16:65-16:73-16:77-16:79-17:44-17:55-17:92-17:93-17:95-17:99-17:102-18:14-18:26-18:40-18:45-18:51-19:65-19:90-19:93-20:4-20:6-20:53-21:4-21:16-21:19-21:30-21:32-21:56-21:104-22:15-22:18-22:31-22:63-22:64-22:65-22:70-23:18-23:71-23:86-24:35-24:41-24:42-24:43-24:64-25:2-25:6-25:25-25:48-25:59-25:61-26:4-26:24-26:187-27:25-27:60-27:64-27:65-27:75-27:87-29:22-29:34-29:44-29:52-29:61-29:63-30:8-30:18-30:22-30:24-30:25-30:26-30:27-30:48-31:10-31:16-31:20-31:25-31:26-32:4-32:5-33:72-34:1-34:2-34:3-34:9-34:22-34:24-35:1-35:3-35:27-35:38-35:40-35:41-35:44-36:28-36:81-37:5-37:6-38:10-38:27-38:66-39:5-39:21-39:38-39:44-39:46-39:63-39:67-39:68-40:13-40:37-40:57-40:64-41:11-41:12-42:4-42:5-42:11-42:12-42:29-42:49-42:53-43:9-43:11-43:82-43:84-43:85-44:7-44:10-44:29-44:38-45:3-45:5-45:13-45:22-45:27-45:36-45:37-46:3-46:4-46:33-48:4-48:7-48:14-49:16-49:18-50:6-50:9-50:38-51:7-51:22-51:23-51:47-52:9-52:36-52:44-53:26-53:31-54:11-55:7-55:29-55:33-55:37-57:1-57:2-57:4-57:5-57:10-57:21-58:7-59:1-59:24-61:1-62:1-63:7-64:1-64:3-64:4-65:12-67:3-67:5-67:16-67:17-69:16-70:8-71:11-71:15-72:8-73:18-77:9-78:19-78:37-79:27-81:11-82:1-84:1-85:1-85:9-86:1-86:11-88:18-91:5",297
42,10,"آ","فَلَک","«فَلَک» کا معنی عموماً آسمان ہی کیا جاتا ہے ۔ مگر حقیقتاً فضا میں سیاروں کے مدار یا اجرام فلکی کے گھومنے کے راستوں کو فلک کہتے ہیں ( م ر ۔ م ل ۔ مف )\nمثلاً : قرآن کریم میں ہے :\n«وَ ہُوَ الَّذِیۡ خَلَقَ الَّیۡلَ وَ النَّہَارَ وَ الشَّمۡسَ وَ الۡقَمَرَ ؕ کُلٌّ فِیۡ  فَلَکٍ یَّسۡبَحُوۡنَ»  (21/33)\nترجمہ : اور وہی تو ہے جس نے رات اور دن اورسورج اور چاند کو بنایا یہ سب ( یعنی سورج ، چاند اور سیارے ) آسمان میں ( اس طرح چلتے ہیں گویا ) تیر رہے ہیں ۔\nاور ان راستوں کو «فَلَک» کہنے کی توجیہ یہ ہے کہ سیارے فضا میں پورے دائرہ کی شکل میں نہیں گھومتے بلکہ بعض قوانین حرکت کے تحت بیضوی شکل اختیار کر جاتے ہیں ۔ پھر ان کے کشتی نما ہونے کی وجہ سے انہیں «فَلَک» کہا گیا ہے ۔ ایسی کشتی کو عربی میں «فُلْک» کہتے ہیں ۔","«فَلَک» فلک سے مراد سیاروں کے مدار (راستے) ہیں ۔","آسمان","فلک","21:33-36:40",2
43,11,"آ","اِعْتَرٰی","«اِعْتَرٰی» بمعنی ننگا ہونا اور «اَعْرٰی» بمعنی کسی کے کپڑے اتار کر اسے ننگا کر دینا اور«اَعْرٰی فُلَانًا صَدِیْقَہ» بمعنی کسی شخص کا اپنے دوست کی مدد نہ کرنا اور اسے چھوڑ کر دور ہو جانا اور«عُرِیَ» بمعنی بخار کی سردی لگنا اور خوف سے کپکپانا اور «عُرْوًا» بمعنی بخار کی سردی (منجد) اور«اِعْتَرٰی» بمعنی کسی کو اس قسم کے عارضہ سے دوچار کر دینا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنۡ نَّقُوۡلُ  اِلَّا اعۡتَرٰىکَ بَعۡضُ اٰلِہَتِنَا بِسُوۡٓءٍ» (11/54)\nترجمہ : ( قوم ہود نے کہا ) ہم تو یہ کہتے ہیں کہ ہمارے کسی معبود نے تمہیں آسیب پہنچا ( کر دیوانہ کر ) دیا ہے ۔","«اِعْتَرٰی» کسی کو جسمانی بیماری میں مبتلا کردینے کے لئے استعمال ہوتا ہے ۔","آسیب","اعتری","11:54",1
44,11,"آ","تَخَبَّطَ","«خَبَطَ» بمعنی کسی کو مار مار کر بدحواس کر دینا ( مف ) اور مخبوط بمعنی فاتر العقل ، یعنی ایسا شخص جس کی عقل ٹھیک کام نہ کرتی ہو ۔ اہل عرب کے خیال کے مطابق یہ کام جنوں اور شیطانوں سے متعلق تھا ۔ جیسے کہ وہ دیوانہ کو بھی مجنون کہتے تھے ۔ یعنی جس کو جن پڑ گئے ہوں اور اس نے اسے دیوانہ بنا دیا ہو ۔ مجنون اور مخبوط میں فرق صرف یہ تھا کہ جو شخص فتور عقل کے عارضہ سے بیمار ہوتا اسے مجنون کہہ دیتے تھے اور جسے وقتی اور عارضی طور پر یہ مرض لاحق ہوتا اسے مخبوط کہہ دیتے تھے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَّذِیۡنَ یَاۡکُلُوۡنَ الرِّبٰوا لَا یَقُوۡمُوۡنَ اِلَّا کَمَا یَقُوۡمُ الَّذِیۡ یَتَخَبَّطُہُ الشَّیۡطٰنُ مِنَ الۡمَسِّ» (2/275)\nترجمہ : جو لوگ سود کھاتے ہیں وہ ( قبروں سے ) اس طرح ( بدحواس ہو کر ) اٹھیں گے ۔ جیسے کسی کو جن نے لپٹ کر دیوانہ بنا دیا ہو ۔","«تَخَبَّطَ» عارضہ (بیماری) کا تعلق اگرعقل سے ہو تو «تَخَبَّطَ» کہلاتا ہے۔\nاوراگرعارضہ (بیماری) کا تعلق جسم سے ہوتو«اعترٰی» کا لفظ استعمال ہو گا ۔","آسیب","تخبط","2:275",1
45,12,"آ","اَطْفَأَ","«طَفَاْ» بمعنی آگ کا بالکل بجھ جانا ، سرد پڑ جانا اور «اَطْفَاْ» آگ کو بجھا دینا ۔ پھونک مار کر چراغ کو گل کر دینا (مف منجد) پھر اس لفظ کا استعمال مادی اور معنوی دونوں صورتوں میں ہوتا ہے ۔ جیسے «اَطْفَأَ الْفِتْنَۃَ اَوِالْحَرْب» ۔ بمعنی فتنہ کو یا لڑائی کو بجھا دیا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«یُرِیۡدُوۡنَ  اَنۡ یُّطۡفِئُوۡا نُوۡرَ اللّٰہِ بِاَفۡوَاہِہِمۡ» (9/32)\nترجمہ : کافر چاہتے ہیں کہ اللہ کے نور کو اپنے مونہوں سے پھونک مار کر بجھا دیں ۔","«طَفَا» آگ کا بالکل بجھ جانا ۔","آگ","اطفا","5:64-9:32-61:8",3
46,12,"آ","اَوْرٰی ( وری )","«وَرٰی یَرِیْ» کے معنی آگ کا شعلہ برامد ہونا ہے ۔ وری الزند محاورہ ہے یعنی چقماق سے آگ کا شعلہ نکالنا (مف) اور (ف ل 288)\nمثلاً : قرآن کریم میں ہے :\n«فَالۡمُوۡرِیٰتِ قَدۡحًا» ( 2/ 100)\nترجمہ :’’ پھر (ان گھوڑوں کی قسم) جو پتھر پر نعل مار کر آگ نکالتے ہیں ۔\nاس آیت میں «قدَحَ» سے مراد پتھر پر نعل مارنا (کہ اس سے شعلہ پیدا ہوجائے) اور «آری» سے مراد شعلہ پیدا ہونا ہے ۔ بعد ازاں لفظ «اَوْرٰی» آگ جلانے کے معنوں میں عام استعمال ہونے لگا ۔ خواہ وہ نباتاتی ایندھن سے ہو یا کسی دوسری چیز سے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَفَرَءَیۡتُمُ النَّارَ الَّتِیۡ تُوۡرُوۡنَ ۔ ءَاَنۡتُمۡ اَنۡشَاۡتُمۡ شَجَرَتَہَاۤ  اَمۡ نَحۡنُ الۡمُنۡشِئُوۡنَ» (72-71/56)\nترجمہ : بھلا دیکھو جو آگ تم ( درخت سے ) نکالتے ہو کیا تم نے اس درخت کو پیدا کیا ہے یا ہم پیدا کرتے ہیں ؟","«اَوْرٰی» شعلہ پیدا کرنا ۔","آگ","اوری ( وری )","56:71-100:2",2
47,12,"آ","اَوْقَدَ","«وَقَدَ» بمعنی آگ کا بھڑک اٹھنا (منجد) ابن فارس نے اس کے معنی «کَلِمَۃٌ تَدُلُّ عَلیٰ اِشْتِعَالِ النَّار» بیان کیے ہیں ( م ل )\nاور«اَوْقَدَ» آگ جلانے کے معنی میں آتا ہے جبکہ اس میں شعلے پیدا ہونے لگیں ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَوۡقِدۡ لِیۡ یٰہَامٰنُ عَلَی الطِّیۡنِ فَاجۡعَلۡ  لِّیۡ صَرۡحًا» (38/ 28 )\nترجمہ : ( فرعون نے کہا ) اے ہامان ! میرے لیے گارے کو آگ لگا ( کر اینٹیں پکا ) دو پھر ایک اونچا محل بنا دو ۔\n«اَوْقَدَ» : کا استعمال معنوی طور پر بھی استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«کُلَّمَاۤ اَوۡقَدُوۡا  نَارًا لِّلۡحَرۡبِ اَطۡفَاَہَا اللّٰہُ» ( 64/ 5)\nترجمہ : جب کبھی یہ ( یہود ) لڑائی کے لیے آگ لگاتے ہیں تو خدا اسے بجھا دیتا ہے ۔\nاور «اِسْتَوْقَدَ» کے معنی ایندھن وغیرہ اکٹھا کر کے بہ تکلف آگ یا چراغ روشن کرنے کے ہیں (مف)\nمثلاً : قرآن کریم میں ہے :\n«مَثَلُہُمۡ کَمَثَلِ الَّذِی اسۡتَوۡقَدَ نَارًا ۚ  فَلَمَّاۤ اَضَآءَتۡ مَا حَوۡلَہٗ ذَہَبَ اللّٰہُ بِنُوۡرِہِمۡ» ( 17/2)\nترجمہ : ان ( منافقین ) کی مثال اس شخص کی سی ہے جس نے ( شب تاریک مین ) آگ جلائی ۔ جب آگ نے اردگرد کی چیزیں روشن کیں تو اللہ نے ان لوگوں کی روشنی زائل کر دی ۔","«اَوْقَدَ» ایندھن سے آگ جلانا ۔","آگ","اوقد","2:17-5:64-24:35-28:38-36:80-104:6",6
48,12,"آ","تَلَظّٰی","«لَظٰی» میں ایسی آگ جو بھڑک رہی ہو مگر اس میں شعلہ نہ ہو ( ف ل 56 ) اور «لَظَّی النَّار» بمعنی آگ بھڑکانا اور «تَلَظّٰی» بمعنی آگ کا بھڑک اٹھنا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَنۡذَرۡتُکُمۡ  نَارًا تَلَظّٰی» ( 14/ 92 )\nترجمہ : پھر میں نے تم کو بھڑکتی آگ سے متنبہ کر دیا ۔","«تَلَظّٰی» جب آگ میں بھڑک ہی بھڑک ہو ، شعلہ نہ ہو ۔","آگ","تلظی","70:15-92:14",2
49,12,"آ","جِذْوَۃٌ","«جِذْوَۃٌ» ایسا انگارہ جس پر راکھ آگئی ہو اور چمک ختم ہو گئی ہو۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«اِنِّیۡۤ  اٰنَسۡتُ نَارًا لَّعَلِّیۡۤ  اٰتِیۡکُمۡ مِّنۡہَا بِخَبَرٍ اَوۡ جَذۡوَۃٍ مِّنَ النَّارِ» ( 29/ 28 )\nترجمہ : مجھے آگ نظر آئی ہے ۔ شاید میں وہاں سے ( رستے کا ) کچھ پتہ لاؤں یا آگ کا انگارہ لے آؤں ۔","«جِذْوَۃٌ» ایسا انگارہ جس پر راکھ آگئی ہو اور چمک ختم ہو گئی ہو ۔","آگ","جذوۃ","28:29",1
50,12,"آ","حَرَّقَ","«حَرَقَ» اور «حَرَّقَ بِالنَّار» آگ کا جلا ڈالنا اور «اِحْتَرَقَ» بمعنی اس چیز کا جل کر راکھ ہو جانا ہے ( مف ) ( یہ گویا آخری درجہ ہوا )\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡاحَرِّقُوۡہُ وَانۡصُرُوۡۤا اٰلِہَتَکُمۡ اِنۡ کُنۡتُمۡ فٰعِلِیۡنَ» ( 68/ 21 )\nترجمہ : ( تب وہ مشرک کہنے لگے ۔ اگر تمہیں ( ابراہیم ؑ سے اپنے معبودوں کا ( انتقام لینا اور ) کچھ کرنا ہے تو ابراہیم ؑ کو جلا ڈالو اور اپنے معبودوں کی مدد کرو ۔\nایک دوسرے مقام پرارشاد باری تعالیٰ ہے :\n«فَاَصَابَہَاۤ اِعۡصَارٌ فِیۡہِ نَارٌ فَاحۡتَرَقَتۡ» ( سورہ نمبر2/ آیت نمبر266 )\nترجمہ : تو ( ناگہاں ) اس باغ پر آگ کا بھرا ہوا بگولا چلے اور وہ جل (کر راکھ کا ڈھیر ہو ) جائے ۔","«حَرَّقَ» آگ کا کسی چیز کو جلا کر راکھ کردینا ۔","آگ","حرق","20:97-21:68-29:24",3
51,12,"آ","خَبَا","«خَبَا» بمعنی آگ کا شعلہ افسردہ ہو جانا اورکوئلہ یا انگارہ پرراکھ کا پردہ چڑھ جانا ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«کُلَّمَا خَبَتۡ زِدۡنٰہُمۡ سَعِیۡرًا» ( 97/17 )\nترجمہ : ’’ جب اس کی آگ بجھنے کو ہو گی تو ہم اس کو اور بھڑکا دیں گے ۔","«خَبَا» شعلہ کا ختم ہونا اور انگارہ پر راکھ کا پردہ آ جانا ۔ یہ درمیانی صورت ہے ۔","آگ","خبا","17:97",1
52,12,"آ","خَمَدَ","«خَمَدَ» آگ کے مدہم پڑ جانے کو کہتے ہیں جس سے شعلہ ختم ہو چکا ہو مگر انگارہ نہ بجھا ہو ۔ اور«خَمِدَتِ الْحُمّٰی» کے معنی بخار کا زور ٹوٹ جانا اور «خُمُوْد» کوئلہ کے معنی میں بھی آتا ہے اور بطور کنایۃ موت کے معنی میں بھی استعمال ہوتاہے (مف ۔ م ۔ ق)\nمثلاً : قرآن کریم میں ہے :\n«اِنۡ کَانَتۡ  اِلَّا صَیۡحَۃً وَّاحِدَۃً  فَاِذَا ہُمۡ خٰمِدُوۡنَ» ( 36/ 29\nترجمہ : تو وہ صرف ایک چنگھاڑ تھی سو وہ ( اس سے ) ناگہاں بجھ کر رہ گئے ۔ ( یا مر گئے ) ","«خَمَدَ» آگ کا شعلہ ختم ہونا ۔","آگ","خمد","21:15-36:29",2
53,12,"آ","سَجَّرَ","«سَجَّرَ» میں کسی چیز کے بھرے ہوئے ہونے اور اس میں مخالطت یا تلاطم کا مفہوم پایا جاتا ہے ( م ل ) «سَجَّرَ الْتَّنُّوْر» کے معنی تنور کو ایندھن سے بھر کر گرم کرنا (منجد) تاکہ آگ پوری شدت سے بھڑک سکے ۔ نیز «سَجْر» بادل کی گرج اور چمک کی آواز کو بھی کہتے ہیں (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَ الۡبَحۡرِالۡمَسۡجُوۡرِ» ( 52/6 )\nترجمہ : اور بھڑکائے ہوئے سمندر کی ۔\nاس سے مراد ہے کہ سمندر بھرا ہوا بھی ہو اور جوش تلاطم سے ابل بھی رہا ہو «سَجُوْر» اس ایندھن کو کہتے ہیں جس سے تنور گرم کیا جائے (منجد) گویا ہر وہ چیز جو آگ میں شدت پیدا کرنے کے لیے تنور میں جھونک دی جائے «سَجُوْر» ہے۔\nمثلاً : قرآن کریم میں ہے :\n«فِی الۡحَمِیۡمِ ۬ ۙ ثُمَّ  فِی النَّارِ  یُسۡجَرُوۡنَ» ( سورہ نمبر40/ آیت نمبر72 )\nترجمہ : یہ ( کافر لوگ ) پہلے کھولتے پانی میں پھر آگ میں جھونک دیے جائیں گے ۔\nنوٹ : (مخالطت : بمعنی میل جول ، دوستی ، اختلاط ، میل ملاپ)\nنوٹ : (تلاطم  : شدت سے موجوں کا اٹھنا اور آپس میں ٹکرانا، پانی کے تھپیڑے، طوفان)","«سَجَّرَ» آگ کی بھڑک میں شدت پیدا کرنا ۔","آگ","سجر","40:72-81:6",2
54,12,"آ","سعّر ۔ سَعَرَ","«سَعَّرَ» کا معنٰی آگ کا جلنا بھڑکنا اور بلند ہونا ہے ۔ (م ل) گویا یہ «وَقَدَ» سے اگلا درجہ ہے اور«سَقَرَ» بمعنی آگ کو خوب بھڑکانا (منجد) اور «سَعِیْر» بمعنی بھڑکتی ہوئی آگ ۔ مثلاً : قرآن کریم میں ہے :\n«وَاِذَاالۡجَحِیۡمُ سُعِّرَتۡ» (81/ 12)\nترجمہ : اور جب دوزخ کی آگ بھڑکائی جائے گی ۔","«سَعَّرَ» آگ کا بھڑکانا ۔","آگ","سعر ۔ سعر","81:12",1
55,12,"آ","شِھَابٌ","«شِھَابٌ» ایسے انگارہ کو کہتے ہیں جس میں چمک اور شعلہ موجود ہو ، خواہ وہ آگ کا انگارہ ہو یا فضا میں پایا جائے (مف) اور اس کی جمع «شُہُب» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّاَنَّا لَمَسۡنَا السَّمَآءَ فَوَجَدۡنٰہَا مُلِئَتۡ حَرَسًا شَدِیۡدًا وَّشُہُبًا» ( 8/72 )\nترجمہ : ( جنوں نے کہا ) اور یہ کہ ہم نے آسمان کو ٹٹولا اور اس کو مضبوط چوکیداروں اور انگاروں سے بھرا ہوا پایا ۔","«شِھَابٌ» شعلہ والا چمکتا ہوا انگارہ ۔","آگ","شھاب","15:18-27:7-37:10-72:8-72:9",5
56,12,"آ","شَوٰی ( یشوی )","«شَوٰی» آگ میں گوشت کو بھوننا اور بھنے ہوئے گوشت کو کہتے ہیں (منجد)  یہ تیسرا درجہ ہوا۔\nمثلاً : قرآن کریم میں ہے :\n«وَ اِنۡ یَّسۡتَغِیۡثُوۡا یُغَاثُوۡا بِمَآءٍ کَالۡمُہۡلِ یَشۡوِی الۡوُجُوۡہَ» ( 18/29 )\nترجمہ : اور اگر فریاد کریں گے تو ایسے کھولتے پانی سے ان کی دادرسی کی جائے گی جو پگھلے ہوئے تانبے کی طرح گرم ہو گا اور چہروں کو بھون ڈالے گا ۔","«شَوٰی» آگ میں بھنے ہوئے گوشت  کے لئے استعمال ہوتا ہے ۔","آگ","شوی ( یشوی )","18:29-70:16",2
57,12,"آ","صَھَرَ","«صَھَرَ» بمعنی چربی وغیرہ کو گرم کر کے پگھلانا اور «صَھَارَۃ» بمعنی پگھلائی ہوئی چیز ۔ چربی کا ٹکڑا ، ہڈی کا گودا اور «صَھُوْر» بمعنی پگھلانے والا ، گوشت بھوننے والا (مف منجد) گویا «صَھَرَ» میں اتنی حرارت درکار ہے کہ جو پگھلنے والی اشیاء بالخصوص چربی کے پگھلانے کے لیے اور گوشت کے گلنے کے لیے درکار ہوتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یُصَبُّ مِنۡ فَوۡقِ رُءُوۡسِہِمُ الۡحَمِیۡمُ ۔ یُصۡہَرُ  بِہٖ  مَا فِیۡ  بُطُوۡنِہِمۡ  وَ الۡجُلُوۡدُ» ( 22/19،20 )\nترجمہ : اور ان کے سروں کے اوپر سے جلتا ہوا پانی ڈالا جائے گا ۔ اس سے ان کے پیٹ کی اندر کی چیزیں اور کھالیں گل جائیں گی ۔","«صَھَرَ» اتنی حرارت والی آگ جو گوشت کو بھون دے اور چربی کو پگلا دے ۔","آگ","صھر","22:20",1
58,12,"آ","قَبَسٌ","«قَبَسٌ» مانگا ہوا آگ کا انگارہ یا شعلہ ۔ تفصیل آگ جلانا میں دیکھیے ۔","«قَبَسٌ» مانگا ہوا آگ کا انگارہ یا شعلہ ۔","آگ","قبس","20:10-27:7",2
59,12,"آ","قَبَسَ","«قَبَسَ» بمعنی آگ کی چنگاری جو شعلہ سے لی جائے (مف) اور بمعنی آگ کو بصورت شعلہ لینا اور«قَبَس» بمعنی آگ کا وہ شعلہ جو بڑی آگ سے لیا جائے ۔\nاور «قَابِس» بمعنی آگ کا طالب اور«قَبَسَہُ النَّار» بمعنی کسی کے لیے آگ لانا اور «اَقْبَسَ فُلَانًا» بمعنی کسی کو آگ دینا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«اِنِّیۡۤ اٰنَسۡتُ نَارًا لَّعَلِّیۡۤ  اٰتِیۡکُمۡ مِّنۡہَا بِقَبَسٍ  اَوۡ  اَجِدُ  عَلَی النَّارِ  ہُدًی» ( 20/10 )\nترجمہ : میں نے آگ دیکھی ہے شاید اس میں سے تمہارے پاس انگاری لاؤں یا آگ جلانے والوں سے رستہ معلوم کر سکوں ۔\nاس آیت میں «قَبَس» کا لفظ «جَذْوَۃٌ مِنَ النَّار» کے بدلہ آیا ہے اور مانگی ہوئی آگ کے لیے بھی ۔\nپھر «قَبَسَ» کا لفظ آگ کے علاوہ آگ سے آگ جلانے ، بڑی روشنی سے روشنی حاصل کرنے اور بڑے علم والے سے علم حاصل کرنے کے معنوں میں بھی آتا ہے ۔ «قَبَسَ الْعِلْم» بمعنی علم حاصل کرنا ۔ علم سے فائدہ اٹھانا اور «اِقْتَبَسَ مِنْہُ النَّارَ وَالنُّور وَالْعِلْم» بمعنی کسی سے آگ ، روشنی یا علم حاصل کرنا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«لِلَّذِیۡنَ اٰمَنُوا انۡظُرُوۡنَا نَقۡتَبِسۡ مِنۡ نُّوۡرِکُمۡ» ( 57/13 )\nترجمہ : ہماری طرف نظر ( شفقت ) کیجیے کہ ہم بھی تمہارے نور سے روشنی حاصل کریں ۔\nاور ہمارے ہاں جو اقتباس کا لفظ مستعمل ہے تو اس کا معنی کسی کی علمی تحریر یا کتاب سے کوئی حصہ یا ٹکڑا لینا اور اس کو پیش کرنا ہے ۔","«قَبَسَ» آگ سے آگ جلانا ۔","آگ","قبس","20:10-27:7",2
60,12,"آ","قَدَحَ","«زَنَّدَ» بمعنی چقماق کاآگ نکالنا (منجد) گویا «قَدَحَ» کا لفظ صرف آگ نکالنے کی کوشش اور ارادہ تک محدود ہے ۔","«قَدَحَ» آگ جلانے کی ابتدائی کوشش ۔ ","آگ","قدح","100:2",1
61,12,"آ","لَفَحَ","«لَفَحَ» کے معنی آگ یا گرم ہوا کا چہرے یا جلد کو جھلس دینا (مف ۔ منجد) ہے ۔ جس سے حلیہ بگڑ جائے گویا یہ دوسرا درجہ ہوا ۔\nمثلاً : قرآن کریم میں ہے :\n«تَلۡفَحُ وُجُوۡہَہُمُ النَّارُ وَ ہُمۡ فِیۡہَا کٰلِحُوۡنَ» ( 23/104 )\nترجمہ : جہنم کی آگ ان کے چہرے جھلس دے گی اور وہ اس میں بدشکل بنے ہوئے ہوں گے ۔","«لَفَحَ» آگ یا  گرم  ہوا  کا چہرے یا جلد کو جھلسا دینا جس سے حلیہ بگڑ جائے ۔ ","آگ","لفح","23:104",1
62,12,"آ","لَوَّحَ","«لَاحَ» سے مراد فقط جلد کا سیاہی مائل رنگت میں تبدیل ہونا ہے ۔ خواہ یہ آگ سے ہو یا حرارت سے ، دھوپ سے ہو یا پیاس یا سفر سے ( منجد ) یعنی آگ یا حرارت کا کسی کو اس طرح چھونا کہ اس سے رنگت سیاہی مائل ہو جائے اور «لَوَّحَ» کے معنی آگ سے کسی چیز کو گرم کرنا ہے ( منجد )\nمثلاً : قرآن کریم میں ہے :\n«لَوَّاحَۃٌ  لِّلۡبَشَرِ» ( 74/29 )\nترجمہ : ( دوزخ کی آگ ) جلد کو ( جھلس کر ) سیاہ کر دے گی ۔","«لَوَّحَ» آگ کی حرارت یا سورج کی تپش سے جلد کا سیاہ ہوجانا ۔","آگ","لوح","74:29",1
63,12,"آ","نَارٌ","«نَارٌ» کا لفظ عام ہے ۔ آگ چاہے بھڑک رہی ہو ‘ تیزی میں ہو یا بجھنے والی ہو ، اس میں شعلہ ہو یا نہ ہو سب پر لفظ نار کا اطلاق ہوتا ہے جبکہ «لظٰی» ایسی شدید گرم اور بھڑکنے والی آگ کو کہتے ہیں جس میں شعلہ نہ ہو ( الخالص من اللہب ف ل 56 )\nمثلاً : قرآن کریم میں ہے :\n«کَلَّا ؕ اِنَّہَا  لَظٰی ۔ نَزَّاعَۃً   لِّلشَّوٰی» ( 70 / 15 ، 16 )\nترجمہ : وہ ( دوزخ ) بھڑکتی ہوئی آگ ہے ، کھال ادھیڑ دینے والی ۔","«نَارٌ» ہر قسم کی آگ کے لئے استعمال ہوتا ہے ۔","آگ","نار","2:17-2:24-2:39-2:80-2:81-2:126-2:167-2:174-2:175-2:201-2:217-2:221-2:257-2:266-2:275-3:10-3:16-3:24-3:103-3:116-3:131-3:151-3:183-3:185-3:191-3:192-4:10-4:14-4:30-4:56-4:145-5:29-5:37-5:64-5:72-6:27-6:128-7:12-7:36-7:38-7:44-7:47-7:50-8:14-9:17-9:35-9:63-9:68-9:81-9:109-10:8-10:27-11:16-11:17-11:98-11:106-11:113-13:5-13:17-13:35-14:30-14:50-15:27-16:62-18:29-18:53-18:96-20:10-21:39-21:69-22:19-22:72-23:104-24:35-24:57-27:7-27:8-27:90-28:29-28:41-29:24-29:25-32:20-33:66-34:42-35:36-36:80-38:27-38:59-38:61-38:64-38:76-39:8-39:16-39:19-40:6-40:41-40:43-40:46-40:47-40:49-40:72-41:19-41:24-41:28-41:40-45:34-46:20-46:34-47:12-47:15-51:13-52:13-52:14-54:48-55:15-55:35-56:71-57:15-58:17-59:3-59:17-59:20-64:10-66:6-66:10-71:25-72:23-74:31-85:5-87:12-88:4-90:20-92:14-98:6-101:11-104:6-111:3",138
64,12,"آ","نَضِجَ","«نَضِجَ» شدت حرارت سے گوشت کا گل جانا ( مف ) اس طرح کہ اس کے اجزاء الگ ہونے لگیں ۔ ( یہ چوتھا درجہ ہوا )\nمثلاً : قرآن کریم میں ہے :\n«سَوۡفَ نُصۡلِیۡہِمۡ نَارًا ؕ کُلَّمَا نَضِجَتۡ جُلُوۡدُہُمۡ بَدَّلۡنٰہُمۡ جُلُوۡدًا غَیۡرَہَا» ( 4/56 )\nترجمہ : ہم عنقریب انہیں آگ میں داخل کریں گے ۔ جب ان کی کھالیں گل اور جل جائیں گی تو ہم اور کھالیں بدل دیں گے ۔","« نَضِجَ» صرف آگ کی تپش سے گوشت کا گل جانا ۔","آگ","نضج","4:56",1
65,13,"آ","اَدرٰی ( دری )","«اَدرٰی» بمعنی کسی حیلہ یا تدبیر یا کسی اور چیز کے ذریعہ سے کسی چیز کا علم حاصل ہونا ( مف ) «دَرِی» سے مصدر ہے «دِرَایَۃٌ» جو بکثرت مستعمل ہے ۔ «اَدْرٰی» اس فعل سے متعدی ہے اس پر ہمیشہ «لَا ، مَا» یا «اِنْ» نافیہ ، یا «مَا» استفہامیہ داخل ہوتا ہے ۔\nمثلاً : ارشاد باری تعالی ہے :\n«وَ مَاۤ  اَدۡرٰىکَ مَا ہِیَہۡ نَارٌ حَامِیَۃٌ» ( 101/10،11 )\nترجمہ : اور تم کیا سمجھے کہ وہ کیا چیز ہے ؟ ( وہ ) دہکتی ہوئی آگ ہے ۔\nمزید مثالیں ’’ جاننا ‘‘ میں دیکھیے ۔\nنوٹ : ( مصدر: بمعنی  صادر ہونے یعنی نکلنے یا شروع ہونے کی جگہ، منبع، اصل، بنیاد، چشمہ، جڑ ۔ مصدر : ایسا اسم ہے جس سے دوسرے فعل بن سکتے ہیں لیکن وہ خود کسی فعل سے نہیں بنتا۔)","«اَدرٰی» کسی حیلہ اور تدبیر سے بات سمجھانا ۔","آگاہ","ادری ( دری )","10:16-10:90-21:109-21:111-46:9-69:3-69:26-72:25-74:27-77:14-82:17-82:18-83:8-83:19-86:2-90:12-97:2-101:3-101:10-104:5",20
66,13,"آ","اَشْعَرْ","«اَشْعَرْ» خبر دینے کے لئے استعمال ہوتا ہے۔\nمثلاً : قرآن کریم میں ہے :\n«فَابۡعَثُوۡۤا اَحَدَکُمۡ بِوَرِقِکُمۡ ہٰذِہٖۤ  اِلَی الۡمَدِیۡنَۃِ فَلۡیَنۡظُرۡ اَیُّہَاۤ اَزۡکٰی طَعَامًا فَلۡیَاۡتِکُمۡ بِرِزۡقٍ مِّنۡہُ  وَ لۡـیَؔ‍‍‍تَلَطَّفۡ وَ لَا یُشۡعِرَنَّ بِکُمۡ اَحَدًا» ( 18/19 )\nترجمہ : ( اصحاب کہف طویل مدت کے بعد بیدار ہوئے اور آپس میں گفتگو کرنے لگے ) کہ اپنے میں سے کسی کو یہ روپیہ دے کر شہر بھیجو وہ دیکھے کہ نفیس کھانا کونسا ہے تو اس میں سے کھانا لے آئے اور ( قول و فعل میں ) نرمی اختیار کرے اور تمہارا حال کسی کو نہ بتلائے ( تمہارے حال سے کسی کو آگاہ نہ ہونے دے )","«اَشْعَرْ» خبر دینے کے لئے استعمال ہوتا ہے ۔","آگاہ","اشعر","6:109-18:19",2
67,13,"آ","اَطْلَعَ","«طَلَعَ» کے بنیادی معنی نمودار ہونا اور سامنے آنا ہے ( م ل ) اور «طَلَعَ الْکَوَاکِب» بمعنی سیاروں سورج ، چاند وغیرہ کا طلوع ہونا ہے اور «اَطْلَع» کے معنی کسی کو حقیقت حال سے واقف کرنا ( منجد )\nمثلاً : قرآن کریم میں ہے :\n«وَ مَا کَانَ اللّٰہُ لِیُطۡلِعَکُمۡ عَلَی الۡغَیۡبِ وَ لٰکِنَّ اللّٰہَ یَجۡتَبِیۡ مِنۡ رُّسُلِہٖ مَنۡ یَّشَآءُ» ( 3/179 )\nترجمہ : اور یہ ممکن نہیں کہ اللہ تم کو غیب کی باتوں سے مطلع کرے البتہ خدا اپنے پیغمبروں میں سے جسے چاہتا ہے انتخاب کر لیتا ہے ۔","«اَطْلَع» کسی چیز کی حقیقت سے واقف کرنا ۔","آگاہ","اطلع","3:179-5:13-19:78",3
68,13,"آ","اَظْھَرَ","«اَظْھَرَ» چھپی ہوئی خبر کو ظاہر کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«عٰلِمُ الۡغَیۡبِ فَلَا یُظۡہِرُ عَلٰی غَیۡبِہٖۤ اَحَدًا» ( 72/26 ) ’’\nترجمہ :( وہی اللہ ) غیب ( کی باتوں کو ) جاننے والا ہے اور پھر اپنے غیب کو کسی پر ظاہر نہیں کرتا ۔","«اَظْھَرَ» چھپی ہوئی خبر کو ظاہر کرنا ۔","آگاہ","اظھر","66:3-72:26",2
69,13,"آ","اَنْبَا  ،  نَبَّاَ","«نَبَّاَ» کے بنیادی معنی ایک جگہ سے دوسری جگہ آنا ہے اور «سَیْلٌ نَابیٌء» ایسے سیلاب کو کہتے ہیں جو ایک شہر سے دوسرے شہر تک جا پہنچے ( م ل ) پھر اسی بناء پر نبا کا لفظ خبر کے معنوں میں استعمال ہونے لگا ۔ صاحب  مُنْتَہَی الْاَرَب نے «اَنْبَا» کے معنی خبر دینا اور آگاہ کرنا لکھے ہیں ( م ل ) ۔ خبر اور نبا کا فرق یہ ہے ۔ خبر عام ہے اور نبا کسی خاص واقعہ کی خبر کو کہتے ہیں جو سننے والے کے لیے مفید بھی ہو ۔ علاوہ ازیں نبا کا تعلق ماضی ، حال ، مستقبل حتی کہ مابعد الطبیعات یعنی مرنے کے بعد اور دوبارہ زندگی کی خبروں سے بھی ہوتا ہے جبکہ خبر کا دائرہ صرف ماضی اور حال تک محدود ہوتا ہے ۔ گویا اہمیت ، افادیت اور زمانہ کی وسعت تین چیزیں «نَبَّاَ» کو عام خبر سے ممتاز کرتی ہیں ۔ «نَبَّاَ» میں چونکہ مستقبل کی خبر یا پیشین گوئی بھی شامل ہے اسی بناء پر کافر انبیاء کو کاہن بھی کہتے رہے ہیں ۔ امام راغب نے نبا کی تعریف میں یہ بھی لکھا ہے کہ اس میں جھوٹ کا احتمال نہ ہو اور اس سے علم یا مفید ظن حاصل ہو جیسا کہ وحی الہی سے اور خبر متواتر وغیرہ سے حاصل ہوتا ہے لیکن ہمارے خیال میں یہ قید درست نہیں ۔ کیونکہ ارشاد باری تعالیٰ ہے :\n«یٰۤاَیُّہَا  الَّذِیۡنَ اٰمَنُوۡۤا  اِنۡ جَآءَکُمۡ فَاسِقٌۢ بِنَبَاٍ فَتَبَیَّنُوۡۤا» ( 49/6 )\nترجمہ : اے ایمان والو اگر تمہارے پاس کوئی خبر لے کر آئے تو اس کی تحقیق کر لیا کرو ۔\nاور یہ تو ظاہر ہے کہ فاسق کی نبا میں کذب کا احتمال موجود ہے جبھی تو اللہ تعالیٰ نے تحقیق کا حکم دیا ہے ۔ اسی طرح ہد ہد پرندہ نے حضرت سلیمان ؑ کو جو خبر ( نبا ) دی تھی اس سے انہیں بھی علم یا مفید ظن حاصل نہیں ہوا تھا ( نیز دیکھیے خبر دینا )","«نَبَّاَ» اور «اَنْبَاَ» کسی اہم واقعہ کی خبر دینا اور اس پر متنبہ کرنا جبکہ اسکا تعلق خبر پانے والی کی ذات سے ہو خواہ یہ خبر ماضی سے متعلق ہو یا حال سے یا مستقبل سے ۔","آگاہ","انبا ، نبا","2:31-2:33-3:15-3:44-3:49-5:14-5:27-5:48-5:60-5:105-6:5-6:34-6:60-6:67-6:105-6:108-6:143-6:159-6:164-7:101-7:175-9:64-9:70-9:94-9:105-10:18-10:23-10:53-10:71-11:49-11:100-11:120-12:15-12:36-12:37-12:45-12:102-13:33-14:9-15:49-15:51-18:13-18:78-18:103-20:99-22:72-24:64-26:6-26:69-26:221-27:22-28:3-28:66-29:8-31:15-31:23-33:20-34:7-35:14-38:21-38:67-38:88-39:7-41:50-49:6-53:36-54:4-54:28-58:6-58:7-62:8-64:5-64:7-66:3-75:13-78:2",76
70,13,"آ","حَدَّثَ","«حَدَّثَ» بمعنی کسی امر کا وقوع پذیر ہونا ۔ نیا ہونا یا نئی چیز یا بات کا پیدا ہونا ہے ( منجد ) اور ابن الفارس کے مطابق «کَوْن الشَّیْء لَمْ یَکُنْ» ۔ پس ایسی چیز کا پیدا ہونا یا وجود میں آنا جو پہلے نہ تھی ( م ل ) اور «حَدَّثَ» کے معنی کسی کو ایسی بات بتلانا جو وہ پہلے نہ جانتا ہو یا کم از کم بتلانے والا ایسا ہی گمان کرتا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ اِذَا لَقُوا الَّذِیۡنَ اٰمَنُوۡا قَالُوۡۤا اٰمَنَّا  ۚ ۖ  وَ اِذَا خَلَا بَعۡضُہُمۡ  اِلٰی بَعۡضٍ قَالُوۡۤا اَتُحَدِّثُوۡنَہُمۡ بِمَا فَتَحَ اللّٰہُ عَلَیۡکُمۡ لِیُحَآجُّوۡکُمۡ بِہٖ عِنۡدَ رَبِّکُمۡ» ( 2/76 )\nترجمہ : اور یہ ( یہود ) جب مومنوں سے ملتے ہیں تو کہتے ہیں ہم ایمان لے آئے اور جس وقت علیحدگی میں ایک دوسرے سے ملتے ہیں تو کہتے ہیں جو بات خدا نے تم پر ظاہر فرمائی ہے وہ تم ان کو اس لیے بتلاتے ہو کہ ( قیامت کے دن ) اس کے حوالے سے تمہارے پروردگار کے سامنے تم پر الزام دیں ۔","«حَدَّثَ» کوئی نئی بات بتلانا ۔","آگاہ","حدث","2:76-18:70-20:113-21:2-26:5-65:1-93:11-99:4",8
71,13,"آ","خَبَرَ","«خَبَرَ» کسی چیز کی حقیقت و ماہیت سے واقف اور باخبر ہونا اور اس کے دوسرے معنیٰ «خبرالشیٔ» کسی چیز کو تجربہ سے جان لینا ۔ تجربہ کرنا ۔ آزمانا ( منجد ) ان سے واضح ہے کہ علم کے مقابلہ میں خبر میں واقفیت واضح تر ہوتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ اللّٰہَ  خَبِیۡرٌۢ   بِمَا تَعۡمَلُوۡنَ» ( 59/18 )\nترجمہ : بیشک خدا تمہارے سب اعمال سے خبردار ہے ۔","«خَبُرَ» جب علم کے ساتھ اس کی جانچ بھی ہو چکی ہو ۔ تب استعمال ہوتا ہے ۔","آگاہ","خبر","2:234-2:271-3:153-3:180-4:35-4:94-4:128-4:135-5:8-6:18-6:73-6:103-9:16-11:1-11:111-17:17-17:30-17:96-18:68-18:91-22:63-24:30-24:53-25:58-25:59-27:7-27:88-28:29-31:16-31:29-31:34-33:2-33:34-34:1-35:14-35:31-42:27-48:11-49:13-57:10-58:3-58:11-58:13-59:18-63:11-64:8-66:3-67:14-100:11",49
72,13,"آ","دَلَّ","«دَلَّ» بمعنی راہنمائی کرنا ، رستہ دکھانا ، کسی چیز کا پتہ بتلانا اور دلالت بمعنی جس کے ذریعہ کسی چیز کی معرفت پہچان حاصل ہو جیسے الفاظ کا معانی پر دلالت کرنا ۔ یا جیسے کوئی چیز حرکت کرنے لگے تو انسان سمجھ لیتا ہے کہ یہ چیز کوئی زندہ جانور ہے گویا اس کی حرکت جاندار کی زندگی پر دلالت کرتی ہے ( مف ) اور «دَلَّ» کا لفظ مادی اور معنوی دونوں طرح استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِذۡ تَمۡشِیۡۤ اُخۡتُکَ فَتَقُوۡلُ ہَلۡ اَدُلُّکُمۡ  عَلٰی مَنۡ  یَّکۡفُلُہٗ» ( 20/40 )\nترجمہ : اور ( اے موسیٰ ) تیری بہن ( فرعون کے ہاں ) گئی اور کہنے لگی کیا میں تمہیں ایسے شخص کا پتہ بتلاؤں جو اس کی کفالت کرے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«یٰۤاَیُّہَا  الَّذِیۡنَ  اٰمَنُوۡا ہَلۡ اَدُلُّکُمۡ عَلٰی تِجَارَۃٍ  تُنۡجِیۡکُمۡ مِّنۡ عَذَابٍ اَلِیۡمٍ» ( 61/10 )\nترجمہ : اے ایمان والو ! کیا میں تمہیں ایسی تجارت نہ بتلاؤں جو تمہیں دردناک عذاب سے نجات دے ۔","«دَلَّ» راہ نمائی کرنا ۔ کسی چیز سے دوسری کا پتہ بتلانا یا راہ سمجھانا ۔","آگاہ","دل","20:40-20:120-28:12-34:7-61:10",5
73,13,"آ","شَعَرَ","«شَعْر» بال کو کہتے ہیں لہذا «شَعَرَ» کے معنی بال کی طرح باریک علم حاصل کرنا ہے ( مف ) کسی معاملہ کی باریکی اورنزاکت کو سمجھ لینا یا حالات و واقعات سے نتیجہ اخذ کرنا اور معاملہ کی تہ تک پہنچ جانے کو «شَعْر» کہتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَاۤ اِنَّہُمۡ ہُمُ الۡمُفۡسِدُوۡنَ وَ لٰکِنۡ لَّا یَشۡعُرُوۡنَ» ( 2/12 )\nترجمہ : دیکھو یہ منافقین بلاشبہ خود مفسد ہیں لیکن انہیں سمجھ نہیں آتی ۔","«شَعَرَ» کسی معاملہ کی باریکی اور نزاکت کو سمجھ کرمعاملہ کی تہ تک پہنچ جانا ۔ ","آگاہ","شعر","2:9-2:12-2:154-3:69-6:26-6:109-6:123-7:95-12:15-12:107-16:21-16:26-16:45-18:19-23:56-26:113-26:202-27:18-27:50-27:65-28:9-28:11-29:53-39:25-39:55-43:66-49:2",27
74,13,"آ","ظَھَرَ","«ظَھَرَ» اس کے بنیادی معنی دو ہیں (1) «قُوَّۃ» (2) عیاں ہونا ( م ل ) یہاں دوسرے مفہوم سے تعلق ہے جس کی ضد بطن ہے تو «ظَھَرَ» سے مراد ایسا علم ہے جو بالکل ظاہری حالات و واقعات سے حاصل ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَوِ الطِّفۡلِ الَّذِیۡنَ لَمۡ  یَظۡہَرُوۡا عَلٰی عَوۡرٰتِ النِّسَآءِ» ( 24/31 )\nترجمہ : یا ایسے لڑکوں سے ( عورتوں کو پردہ کی ضرورت نہیں ) جو ابھی عورتوں کے پردے کی چیزوں سے واقف نہ ہوئے ہوں ۔","«ظَھَرَ» اس سے مراد ایسا علم ہے جو بالکل ظاہری حالات و واقعات سے حاصل ہو ۔","آگاہ","ظھر","2:85-6:120-6:151-7:33-9:8-9:33-9:48-13:33-18:20-18:22-18:97-24:31-30:7-30:18-30:41-31:20-34:18-40:26-40:29-43:33-48:28-57:3-57:13-61:9-61:14-66:3-72:26",27
75,13,"آ","عَثَرَ","«عَثَرَ» ایسی بات کی واقفیت جو بغیر ارادہ کے باتوں باتوں میں حاصل ہو جائے ( مف )\nمثلاً : قرآن کریم میں ہے :\n«فَاِنۡ عُثِرَ عَلٰۤی اَنَّہُمَا اسۡتَحَقَّاۤ اِثۡمًا» ( 5/107 )\nترجمہ : پھر اگر معلوم ہو جائے کہ ان دونوں نے (جھوٹ بول کر) گناہ حاصل کیا ہے ۔","«عَثَرَ» باتوں باتوں میں بغیرارادہ کے کسی چیز کا علم ہوجانا ۔ ","آگاہ","عثر","5:107-18:21",2
76,13,"آ","عَرَّفَ","«عَرَفَ» کے معنی کسی چیز کے علامات و آثار پر غور و فکر کر کے اس کا ادراک کر لینا یا پہچاننا (مف) اور ظاہر ہے کہ پہچاننے میں انسان بعض دفعہ غلطی بھی کر سکتا ہے لہذا معرفت یا عرفان کا درجہ علم سے کمتر ہے اور عرفان کی ضد انکار ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَعَرَفَہُمۡ  وَ ہُمۡ  لَہٗ  مُنۡکِرُوۡنَ» ( 12/58 )\nترجمہ : یوسف ؑ نے تو انہیں ( اپنے بھائیوں کو ) پہچان لیا لیکن وہ آپؑ کو نہ پہچان سکے ۔\nپھر«عَرَفَ» کے معنی خوشبو لگانا اور «عَرَّفَ» کے معنی خوشبو سے معطر کرنا اور خوشبو چھوڑ دینا بھی ہے ۔ (مف ۔ منجد) جبکہ «عَرَّفَ» کا عام مفہوم واقف کرانا ، تعارف کرانا یا مطلع کرنا ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یُدۡخِلُہُمُ  الۡجَنَّۃَ  عَرَّفَہَا  لَہُمۡ» ( 47/6 )\nترجمہ : اور ان کو بہشت میں داخل کرے گا جس سے ان کو آشنا کر رکھا ہے ۔\nاور امام راغب نے اسکا ترجمہ یوں کیا ہے : اور اللہ تعالیٰ نے ان کے لیے جنت کو خوشبو سے بسا دیا ہے ( مف )","«عَرَّفَ» علامات اور نشانات سے بات سمجھانا ۔","آگاہ","عرف","2:89-2:146-2:273-5:83-6:20-7:46-7:48-12:58-12:62-16:83-22:72-23:69-27:93-33:59-47:6-47:30-55:41-66:3-83:24",19
77,13,"آ","عَلِمَ","«عَلِمَ» کسی چیز کی حقیقت کے متعلق واقفیت اگر یقین کی حد تک پہنچ جائے تو یہ واقفیت علم کہلائے گی اور اس کی ضد «جَھْل» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لَقَدۡ عَلِمُوۡا لَمَنِ اشۡتَرٰىہُ مَا لَہٗ فِی الۡاٰخِرَۃِ مِنۡ خَلَاقٍ» ( 2/102 )\nترجمہ : اور وہ جان گئے تھے کہ جو شخص ایسی چیزیں ( یعنی سحر اور منتر وغیرہ ) کا خریدار ہو گا ۔ اس کا آخرت میں کچھ حصہ نہیں ۔","«عَلِمَ» کسی چیز کی حقیقت کے متعلق یقین حاصل ہونا ۔","آگاہ","علم","2:60-2:65-2:102-2:187-2:235-7:160-8:23-8:66-12:21-12:37-24:41-45:9-48:18-48:27-50:4-56:62-60:10-73:20-81:14-82:5",20
78,13,"آ","عَلَّمَ","«عَلَّمَ» کسی کو علم سکھانے کے معنی میں استعمال ہوتا ہے۔\nمثلاً : قرآن کریم میں ہے :\n«قُلۡ اَتُعَلِّمُوۡنَ اللّٰہَ بِدِیۡنِکُمۡ» ( 49/16 )\nترجمہ : اے پیغمبر ﷺ ! آپ ان سے کہہ دیجئے کیا تم اللہ کو اپنی دین داری جتلاتے ہو ۔\nان کے علاوہ اس مفہوم میں «اَدْرٰی ، حَدَّثَ ، عَرَّفَ» اور «اطلع ، اَنْبَاَ» یا «نَبَّا» ( نبی ) اور «دَلَّ» کے الفاظ بھی استعمال ہوئے ہیں ۔","«عَلَّمَ» کسی کو علم سکھانے کے معنی میں استعمال ہوتا ہے ۔","آگاہ","علم","49:16",1
79,14,"آ","اَسْلَفَ","«سَلَفَ» کے معنی کسی چیز یا کام کا گزر جانا (م ۔ ا) مثلاً : احکام شریعت میں بیع سلف اس بیع کو کہتے ہیں  جس میں قیمت پیشگی ادا کر دی جاتی ہے اور اسلاف گزشتہ دور میں گزری ہوئی نسلوں کو کہتے ہیں ۔ گزشتہ آباؤاجداد (منجد)\nمثلاً : قرآن کریم میں ہے :\n«اِلَّا مَا قَدۡ سَلَفَ» ( 4/23 )\nترجمہ : مگر جو ہو چکا سو ہو چکا ۔\nپھر «سَلَفَ» کے دوسرے معنی ’’ آگے بڑھنا ‘‘ کے بھی آتے ہیں (م ل ، منجد) «سَلِیْف» کے معنی آگے ہونے والا ، آگے چلنے والا ۔ «اَسْلَاف» بمعنی جماعت متقدمین (منجد) اور «اَسْلَفَ» کے معنی زمانہ ماضی میں کیا ہوا کوئی کام ۔\nمثلاً : قرآن کریم میں ہے :\n«ہُنَالِکَ تَبۡلُوۡا کُلُّ نَفۡسٍ مَّاۤ  اَسۡلَفَتۡ» ( 10/30 )\nترجمہ : (1) وہاں ہر شخص اپنے اعمال کی جو اس نے آگے بھیجے ہوں گے آزمائش کر لے گا ۔\nترجمہ : (2) وہاں جانچ لے گا ہر کوئی جو اس نے پہلے کیا تھا ( عثمانیؒ )","«اَسْلَفَ» کسی کام کا گزر جانا عام طور پر سلف یعنی گزرے ہوئے آبا واجداد کے لئے بھی استعمال ہوتا ہے ۔","آگے","اسلف","2:275-4:22-4:23-5:95-8:38-10:30-43:56-69:24",8
80,14,"آ","اَقْبَلَ","«اِقْبَال» اور «اِسْتِقْبَال» دونوں کے معنی کسی کے روبرو اور اس کی طرف متوجہ ہو جانے اور آگے بڑھنے کے ہیں ( مف ) یعنی کسی کی جانب آگے بڑھنا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَقۡبَلَ بَعۡضُہُمۡ عَلٰی بَعۡضٍ یَّتَلَاوَمُوۡنَ» ( 68/30 )\nترجمہ : پھر لگے ایک دوسرے کو رُو در رُو ملامت کرنے ۔ ( جالندھری )\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«فَلَمَّا رَاَوۡہُ عَارِضًا مُّسۡتَقۡبِلَ اَوۡدِیَتِہِمۡ ۙ قَالُوۡا ہٰذَا عَارِضٌ مُّمۡطِرُنَا» ( 46/24 )\nترجمہ : پھر جب انہوں نے اس ( عذاب ) کو دیکھا کہ بادل ( کی صورت میں ) ان کے میدانوں کی طرف بڑھ رہا ہے تو کہنے لگے یہ تو بادل ہے جو ہم پر برس کر رہے گا ۔","«اَقْبَلَ» کسی کے رو برو اور متوجہ ہونے کے معنی میں استعمال ہوتا ہے۔","آگے","اقبل","12:71-28:31-37:27-37:50-37:94-51:29-52:25-68:30",8
81,14,"آ","بَیْنَ یَدَیْ ، بَیْنَ اَیْدِیْ","«بَیْنَ یَدَیْ ، بَیْنَ اَیْدِیْ» (اسکے لفظی معنی ہیں ہاتھوں کے درمیان) مگر اشارۃً اور محاورتاً آگے یا سامنے ۔ اور ضد اسکی «خَلَف» ہے ۔ اس کا استعمال ظرف زمان اور مکان (یعنی جگہ اور وقت دونوں طرح استعمال ہوتا ہے ۔ ظرف زمانی کی صورت میں اس کا معنی اس وقت کے موجود لوگ یا اس دور کے لوگ ہو گا لیکن عام طور پر اس کا معنی اگلے کر لیا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَجَعَلۡنٰہَا نَکَالًا لِّمَا بَیۡنَ یَدَیۡہَا وَ مَا خَلۡفَہَا» ( 2/66 )\nترجمہ : تو ہم نے اس قصے کو اس وقت کے لوگوں کے لیے اور بعد میں آنے والوں کے لیے عبرت بنا دیا ۔\nاور مکانی کی صورت میں اس کا معنی آگے یا آگے آگے ہو گا ۔\nمثلاً : قرآن کریم میں ہے :\n«لَہٗ مُعَقِّبٰتٌ مِّنۡۢ بَیۡنِ یَدَیۡہِ وَ مِنۡ خَلۡفِہٖ  یَحۡفَظُوۡنَہٗ  مِنۡ اَمۡرِ اللّٰہِ» ( 13/11 )\nترجمہ : اس کے آگے اور پیچھے خدا کے چوکیدار ہیں جو خدا کے حکم سے اس کی حفاظت کرتے ہیں ۔","«بَیْنَ یَدَیْ ، بَیْنَ اَیْدِیْ» عام طور پر ان الفاظ کا استعمال زمانے اور وقت کو بیان کر نے کے لئے کیا جاتا ہے ۔","آگے","بین یدی ،  بین ایدی","2:66-2:97-2:255-3:3-3:50-5:46-5:48-6:92-7:17-7:57-10:37-12:111-13:11-19:64-20:110-21:28-22:76-25:48-27:63-34:9-34:12-34:31-34:46-35:31-36:9-36:45-41:14-41:25-41:42-46:21-46:30-49:1-57:12-58:12-58:13-61:6-66:8-72:27",38
82,14,"آ","سَبَقَ","«سَبَقَ» کے معنی آگے بڑھنا ، پیش پیش ہونا ، سبقت کرنا ۔ «السَّبْقُ» ایسی شرط جو آگے نکل جانے پر رکھی جاتی ہے اور سابق بمعنی دوڑ سے جیتنے والا گھوڑا اور «سَبَّقَ» کے معنی شرط لینا دینا ہوتا ہے (منجد) گویا «سبق» میں مقابلۃ میں آگے نکل جانے کا مفہوم پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«رَبَّنَا اغۡفِرۡ لَنَا وَ لِاِخۡوَانِنَا الَّذِیۡنَ سَبَقُوۡنَا بِالۡاِیۡمَانِ» ( 59/10 )\nترجمہ : اے ہمارے پروردگار ! ہمارے اور ہمارے ان بھائیوں کے جو ہم سے پہلے ایمان لائے ہیں ( سب کے گناہ ) معاف فرما ۔\nاور «اِسْتَبَقَ» کے معنی جلد آگے بڑھنے کی کوشش کرنا (منجد) یا آگے بڑھنے کے لیے دوڑ لگانا  کے آتے ہیں ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ اسۡتَبَقَا الۡبَابَ وَ قَدَّتۡ قَمِیۡصَہٗ مِنۡ دُبُرٍ» ( 12/25 )\nترجمہ : اور دونوں دروازے کی طرف بھاگے ( آگے یوسف پیچھے زلیخا ) اور عورت نے اس کا کرتہ پیچھے سے ( پکڑ کر جو کھینچا تو ) پھاڑ ڈالا ۔","«سَبَقَ» اس میں مقابلہ میں دوسروں سے آگے بڑھنے کا مفہوم پایاجاتا ہے ۔","آگے","سبق","7:80-8:59-8:68-10:19-11:40-11:110-15:5-20:99-20:199-21:27-21:101-23:27-23:43-29:4-29:28-37:171-41:45-42:14-46:11-59:10-79:4",21
83,14,"آ","قُبُل","«قُبْل» بمعنی ہر چیز کا آگے کا حصہ جو پہلے نظر آئے ۔ اور اسکی  ضد «دُبُر» اور «دُبْر»  ہے  (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَلَوۡ اَنَّنَا نَزَّلۡنَاۤ  اِلَیۡہِمُ الۡمَلٰٓئِکَۃَ وَ کَلَّمَہُمُ الۡمَوۡتٰی وَ حَشَرۡنَا عَلَیۡہِمۡ کُلَّ شَیۡءٍ قُبُلًا مَّا کَانُوۡا لِیُؤۡمِنُوۡۤا» ( 6/111 )\nترجمہ : ار ہم ان پر فرشتے بھی اتار دیتے اور مردے بھی ان سے گفتگو کرنے لگتے اور ہم سب چیزوں کو ان کے سامنے لا موجود بھی کر دیتے تو بھی یہ ایمان نہ لاتے ۔\nاور«قِبَل» کے معنی طاقت اور قدرت کے بھی ہیں (منجد) اور«قِبَل» کسی ایسی چیز کے سامنے آنے کو کہتے ہیں جس کے مقابلہ کی طاقت اور سکت نہ ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«بَاطِنُہٗ فِیۡہِ الرَّحۡمَۃُ وَ ظَاہِرُہٗ مِنۡ قِبَلِہِ الۡعَذَابُ» ( 57/13 )\nترجمہ : اس دیوار کی اندرونی جانب رحمت ہے اور بیرونی جانب سامنے عذاب ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«اَوۡ تَاۡتِیَ بِاللّٰہِ  وَ الۡمَلٰٓئِکَۃِ  قَبِیۡلًا» ( 17/92 )\nترجمہ : یا تم اللہ تعالیٰ اور فرشتوں کو ہمارے سامنے لے آؤ ۔","«قُبُل» کے معنی میں دو چیزوں کا آمنے سامنے یا آگے اور سامنے ہونا ۔ یا رُو برُو ہونا ضروری ہے جبکہ «بَیْنَ یَدَی» چاہے زمانے کے اعتبار سے ہو یا مکان کے اعتبار سے ہو چیزوں کا آمنے سامنے ہونا ضروری نہیں ہوتا ۔","آگے","قبل","6:111-12:26-18:55-27:37-28:31-46:24-51:29-57:13",8
84,14,"آ","قَدِمَ","«قَدَمَ» کے معنی آگے چلنا ، قدموں پر چلنا اور کسی کے آگے چلنا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«یَقۡدُمُ  قَوۡمَہٗ یَوۡمَ الۡقِیٰمَۃِ فَاَوۡرَدَہُمُ النَّارَ» ( 11/98 )\nترجمہ : ( فرعون ) قیامت کے دن اپنی قوم کے آگے چلے گا اور ان کو دوزخ میں جا اتارے گا ۔\nاور «اِسْتَقْدَمَ» آگے بڑھنے کا ارادہ رکھنا (مف) اوراس کی ضد «اِسْتَاخَرَ» ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«اِذَا جَآءَ اَجَلُہُمۡ فَلَا یَسۡتَاۡخِرُوۡنَ سَاعَۃً وَّ لَا  یَسۡتَقۡدِمُوۡنَ» ( 10/49 )\nترجمہ : جب وہ وقت آ جاتا ہے تو ایک گھڑی بھی دیر نہیں کر سکتے اور نہ جلدی کر سکتے ہیں ۔","«قَدَمَ» میں صرف آگے چلنے یا آگے بڑھنے اور«سَبَقَ» میں دوسروں سے مقابلۃ میں آگے بڑھنے اور «اَقْبَلَ» میں کسی شخص یا کسی چیز کی طرف منہ کرنے اور آگے بڑھنے کا مفہوم پایا جاتا ہے ۔","آگے","قدم","7:34-10:2-10:49-11:98-15:24-16:61-25:23-34:30-38:60-38:61-49:1-58:12-58:13-74:37",14
85,14,"آ","قَدَّمَ","«قَدَّمَ» کے معنی کوئی کام وقت ضرورت سے پہلے کرنا اور اس کی ضد «اَخَّرَ» یعنی کسی کام کو مناسب وقت پر نہ کرنا اور پیچھے ڈال دینا ہے (مف) اور یہ مناسب وقت موت ہے یعنی موت سے پہلے اپنی زندگی میں جو اعمال انسان نے کیے ہیں وہ گویا سب اس نے اپنی اخروی زندگی کے لیے آگے بھیجے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لَنۡ یَّتَمَنَّوۡہُ اَبَدًۢا بِمَا قَدَّمَتۡ اَیۡدِیۡہِمۡ» ( 2/95 )\nترجمہ : اور ان اعمال کی وجہ سے جو ان کے ہاتھ آگے بھیج چکے ہیں یہ یہود کبھی موت کی آرزو نہ کریں گے ۔\nپھر کسی شخص کو کوئی کام کرنے سے پہلے اس کے نتائج سے آگاہ کرنے کے لیے بھی «قَدَّمَ» کا لفظ آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَ  لَا تَخۡتَصِمُوۡا لَدَیَّ وَ قَدۡ قَدَّمۡتُ اِلَیۡکُمۡ  بِالۡوَعِیۡدِ» ( 50/28 )\nترجمہ :’’ اللہ تعالیٰ ( اہل دوزخ سے قیامت کے دن ) فرمائے گا بحث ومباحثہ نہ کرو ۔ ہم تمہارے پاس پہلے ہی ( عذاب کی ) وعید بھیج چکے تھے ۔\nاور«اَسْلَفَ» میں وہی فرق ہے جو «اِرْتَفَاع» اور «عَمَق» میں ہے اگر نیچے کے کنارے پر ہوں تو اسی فاصلہ کو بلندی کہتے ہیں اور اوپر کے کنارے پر کھڑے ہوں تو وہی فاصلہ عمق یا گہرائی کہلاتا ہے ۔ وہی بات یا کام جو «قَدَّمَ» کا مفہوم ہے موقع کے لحاظ سے وہی اسلف بن جاتا ہے ۔ جیسے قیامت کے دن اللہ تعالیٰ مومنوں سے فرمائیں گے :«کُلُوۡا وَ اشۡرَبُوۡا ہَنِیۡٓـئًۢا بِمَاۤ  اَسۡلَفۡتُمۡ فِی الۡاَیَّامِ الۡخَالِیَۃِ» ( 69/24 )\nترجمہ : جو ( عمل ) تو ایام گزشتہ میں آگے بھیج چکے ہو اس کے صلے میں مزے سے کھاؤ پیو ۔\nاب اگر یہی مفہوم زمانہ حال میں ادا کرنا ہو تو «بِمَا قَدَّمَتْ اَیْدِیْکُمْ» سے ادا ہو گا ۔","«قَدَّمَ» کے معنی کوئی کام وقت ضرورت سے پہلے کرنا.","آگے","قدم","2:95-2:110-2:223-3:182-4:62-5:80-8:51-18:57-22:10-26:76-28:47-30:36-36:12-42:48-48:2-50:28-59:18-62:7-73:20-75:13-78:40-82:5-89:24",23
86,15,"ج","اَسْلِحَۃ","«اَسْلِحَۃْ»  جمع ہے «سَلَاح» کی اوروہ ہرچیزسلاح ہے جس سے جنگ لڑی جا سکے (م ل) گویا یہ لفظ جنگی ہتھیاروں کے لیے خاص ہے خواہ وہ چاقواورنیزہ اور تلوار ہو یا رائفل اورمیزائل ۔\nمثلاً : قرآن کریم میں ہے :\n«وَدَّ الَّذِیۡنَ کَفَرُوۡا لَوۡ تَغۡفُلُوۡنَ عَنۡ اَسۡلِحَتِکُمۡ وَ اَمۡتِعَتِکُمۡ» ( 4/102 )\nترجمہ : کافر لوگ تو یہ آرزو کرتے ہیں کہ تم اپنے ہتھیاروں اور سامان سے غافل ہو جاؤ ۔","«اَسْلِحَۃْ» ہر قسم کا جنگی سامان ۔ جنگی سامان کے لیے مخصوص لفظ ہے ۔","جنگ","اسلحۃ","4:102",1
87,15,"ج","اَوْزَار","«اَوْزَار» جمع ہے «وِزْر» کی جس کے معنی بوجھ ، ہتھیار اور آلہ کے ہیں  اور جب «وِزْرُالْحَرْب» کا استعمال ہو تو یہ جنگی آلات سے مخصوص ہو جاتا ہے ۔ (مف)\nتاہم صرف لفظ «وِرْز» سے بھی جنگی ہتھیار مراد لیا جاتا ہے «وَکَذَا اَلْوِزْر : اَلسَّلَاحُ وَالْجَمْعُ اَوْزَار ۔ م ل )»\nمثلاً : قرآن کریم میں ہے :\n«حَتّٰی تَضَعَ الۡحَرۡبُ اَوۡزَارَہَا» ( 47/4 )\nترجمہ : یہاں تک کہ لڑائی (فریق مقابل) اپنے ہتھیار ڈال دے ۔","«اَوْزَار» بمعنی ہتھیار ۔ اگر جنگ کی طرف نسبت ہو تو آلاتِ جنگ ہیں ورنہ نہیں ۔","جنگ","اوزار","6:31-6:164-16:25-17:15-20:87-20:100-35:18-39:7-47:4-53:38-94:2",11
88,15,"ج","حِذْر","«حِذْر» کے اصلی معنی بچاؤ کرنا ، محتاط اور چوکنا رہنے کے ہیں (م ل) یہ لفظ عام ہے ۔ اگر جنگ کے سلسلہ میں استعمال ہو تو اس کا مطلب دفاعی سامان جنگ ہو گا ۔ اس سے جہاں بچاؤ کی جگہ مراد لی جا سکتی ہے جیسے مورچے وغیرہ ، بعینہ اسی طرح ڈھال سے لے کر ریڈار تک بھی مراد لیے جا سکتے ہیں ۔ یعنی ہر وہ چیز اور ہر وہ تدبیر جس سے بچاؤ اور مدافعت کی جا سکے وہ «حِذْر» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا جُنَاحَ عَلَیۡکُمۡ اِنۡ کَانَ بِکُمۡ اَذًی مِّنۡ مَّطَرٍاَوۡ کُنۡتُمۡ مَّرۡضٰۤی اَنۡ تَضَعُوۡۤا اَسۡلِحَتَکُمۡ ۚ وَ خُذُوۡاحِذۡرَکُمۡ» ( 4/102 )\nترجمہ : اورتم پرکچھ گناہ نہیں اگرتم کو تکلیف ہو مینہ سے یا تم بیمار ہو کہ اتاررکھواپنے ہتھیار ۔ اور ساتھ لے لو اپنا بچاؤ ۔ ( عثمانیؒ )\nاس میں «خُذُوْا» کا لفظ اس بات پر دلالت کرتا ہے کہ یہاں «حِذْر» سے مراد صرف ہوشیار رہنا نہیں (جیسا کہ فتح محمد صاحب نے لکھا ہے) بلکہ دفاعی سامان ہر حالت میں اپنے ساتھ رکھنا چاہیے ۔ ایسا نہ ہو کہ دشمن نہتا دیکھ کر اس سے فائدہ اٹھانے کی کوشش کرے ۔","«حِذْر» اگر جنگ کے سلسلہ میں استعمال ہو تو اس کا مطلب دفاعی سامان جنگ ہو گا ۔","جنگ","حذر","2:19-2:235-2:243-3:28-3:30-4:71-4:102-5:41-5:49-5:92-9:64-9:122-24:63-28:6-39:9-63:4-64:14",17
89,15,"ج","شَوْکَۃ","«شَوْک» بمعنی کانٹا (معہ) «درمثَاکَ» بمعنی کانتا چبھونا اور «شَوْکَۃ» بمعنی ایک کانٹا اور جمع اسکی «اَشْوَاک» ہے ۔ بچھو کا ڈنگ ۔ ہتھیار ، تیزی ، قوت ، لڑائی ، دبدبہ اور «ذُوْشَوْکَۃ» بمعنی باہتھیار ۔ مسلح اور «شَوْک» سے یہ بھی ظاہر ہوتا ہے کہ اس سے جارحانہ ہتھیار مراد ہیں جن سے حملہ کیا جا سکے ۔ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَ تَوَدُّوۡنَ اَنَّ غَیۡرَ ذَاتِ الشَّوۡکَۃِ تَکُوۡنُ لَکُمۡ» ( 8/7 )\nترجمہ : اور تم چاہتے تھے کہ جو قافلہ بے ہتھیار ہے وہ تمہارے ہاتھ آ جائے ۔","«شَوْکَۃ» جارحانہ لڑائی کے ہتھیار ۔","جنگ","شوکۃ","8:7",1
90,16,"آ","اَتٰی","«اَتٰی» کسی دوسرے کام کے نتیجہ میں آنے کو یا بسہولت آنے کو کہتے ہیں جیسے دودھ بلونے سے اوپر مکھن آ جاتا ہے تو اس مکھن کو «اَتُوَّۃٌ» کہتے ہیں اور «اٰتِیّ» سیلاب کو  کہتے ہیں ۔ (مف فِل)\n«جَاءَ» اور «اَتٰی» میں دوسرا فرق یہ ہے کہ «اَتٰی» میں بخلاف «جَاءَ» کے  یہ ضروری نہیں ہوتا کہ اصل میں آنے کا عمل واقعہ ہو چکا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَتٰۤی اَمۡرُ اللّٰہِ فَلَا تَسۡتَعۡجِلُوۡہُ» ( 16/1 )\nترجمہ :  خدا کا حکم ( یعنی عذاب گویا ) آ ہی پہنچا تو ( کافرو ) اس کے لیے جلدی مت کرو ۔\nاس آیت میں امر سے مراد قیامت اور جزاء و سزا کا عمل ہے جو ابھی واقع ہونے والا ہے ۔","«اَتٰی» کسی دوسرے کام کے نتیجہ میں آنے کو یا بسہولت آنے کو کہتے ہیں ۔","آنا","اتی","2:38-2:85-2:118-2:189-2:210-2:214-2:222-2:223-2:248-2:254-2:260-3:125-4:15-4:16-4:19-4:25-4:102-5:41-6:4-6:5-6:34-6:40-6:47-6:130-6:134-6:158-7:17-7:35-7:53-7:80-7:81-7:97-7:98-7:106-7:129-7:138-7:163-7:187-9:54-9:70-9:92-10:24-10:50-11:8-11:76-11:39-11:93-11:105-12:37-12:48-12:49-12:93-12:107-13:31-13:41-14:9-14:17-14:31-14:44-15:11-15:85-15:99-16:1-16:26-16:33-16:45-16:111-16:112-18:19-18:55-18:77-19:38-19:43-19:61-19:93-19:95-20:9-20:11-20:15-20:47-20:60-20:69-20:74-20:75-20:123-20:126-20:133-21:2-21:3-21:40-21:44-22:7-22:27-22:55-23:68-24:49-25:40-26:5-26:6-26:16-26:89-26:154-26:165-26:202-27:18-27:31-27:38-27:54-27:55-27:87-27:92-28:30-28:46-29:5-29:28-29:29-29:53-30:43-32:3-33:14-33:18-33:20-33:30-34:3-36:30-36:46-37:28-38:21-39:25-39:40-39:54-39:55-39:71-40:22-40:35-40:50-40:56-40:59-41:11-41:40-41:42-42:47-43:7-43:66-47:18-51:24-51:42-51:52-59:2-60:12-61:6-63:10-64:5-64:6-65:1-67:8-71:1-74:47-76:1-78:18-79:15-85:17-88:1-98:1",164
91,16,"آ","تَعَال","«عَلَو» بمعنی بلندی اور«تَعَال» بمعنی کسی کو بلند جگہ یا بلند مقصد کی طرف بلانا (مف) کسی کو تعظیم سے بلانے کے لیے استعمال ہوتا ہے اور صرف امر حاضر کے صیغے استعمال ہوتے ہیں :\nمثلاً : قرآن کریم میں ہے :\n«قُلۡ یٰۤاَہۡلَ الۡکِتٰبِ تَعَالَوۡا اِلٰی کَلِمَۃٍ سَوَآءٍۢ  بَیۡنَنَا وَ بَیۡنَکُمۡ اَلَّا نَعۡبُدَ اِلَّا اللّٰہَ» ( 3/64 )\nترجمہ : (اے پیغمبر) آپ کہہ دیجیے کہ اے اہل کتاب ! جو بات ہمارے اور تمہارے درمیان یکساں ( مسلّم ) ہے ۔ اس کی طرف آؤ وہ یہ کہ ہم خدا کے سوا کسی کی عبادت نہ کریں ۔","«تَعَال» کسی بلند مقصد کے لیے یا تعظیم سے بلانے کے لیے استعمال ہوتا ہے ۔","آنا","تعال","3:61-3:64-3:167-4:61-5:104-6:151-33:28-63:5",8
92,16,"آ","جَاءَ","«جَاءَ» آنا کے لیے عام لفظ  ہے ۔ تاہم اس کے لیے یہ ضروری ہے کہ آنے کا عمل فی الواقعہ ہو چکاہو (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ جَآءُوۡۤ  اَبَاہُمۡ  عِشَآءً  یَّبۡکُوۡنَ» ( 12/16 )\nترجمہ : اور وہ ( یوسف ؑ کے بھائی ) رات کو روتے روتے اپنے باپ کے پاس آئے ۔","«جَاءَ» بمعنی آنا اس کے لیے یہ ضروری ہے کہ آنے کا عمل فی الواقعہ ہو چکا ہو ۔","آنا","جاء","2:87-2:89-2:92-2:101-2:120-2:145-2:209-2:211-2:213-2:253-2:275-3:19-3:61-3:81-3:86-3:105-3:183-3:184-4:43-4:62-4:64-4:83-4:90-4:153-4:170-4:174-5:6-5:15-5:19-5:32-5:42-5:48-5:61-5:70-5:84-6:5-6:25-6:31-6:34-6:43-6:54-6:61-6:104-6:109-6:124-6:157-6:160-7:4-7:5-7:34-7:37-7:43-7:53-7:63-7:69-7:73-7:85-7:101-7:113-7:116-7:126-7:131-7:143-8:19-9:48-9:90-9:128-10:13-10:22-10:47-10:49-10:57-10:74-10:76-10:77-10:80-10:93-10:94-10:97-10:108-11:12-11:40-11:58-11:66-11:69-11:74-11:76-11:77-11:78-11:82-11:94-11:101-11:120-12:16-12:19-12:50-12:58-12:96-13:37-14:9-15:61-15:67-16:61-16:113-17:5-17:7-17:81-17:94-17:101-17:104-18:55-18:98-19:43-20:72-23:27-23:44-23:68-23:70-23:99-24:39-25:29-26:41-26:206-27:28-27:13-27:36-27:42-27:84-27:89-27:90-28:20-28:25-28:36-28:37-28:48-28:84-28:85-29:10-29:31-29:33-29:39-29:53-29:68-30:9-30:47-33:9-33:10-33:19-34:32-34:43-34:49-35:25-35:37-35:42-35:45-36:13-36:20-37:37-37:84-38:4-39:32-39:33-39:59-39:71-39:73-40:25-40:28-40:29-40:34-40:66-40:78-40:83-41:14-41:20-41:41-42:14-43:29-43:30-43:38-43:47-43:53-43:63-44:13-44:17-45:17-46:7-47:18-49:6-50:2-50:5-50:19-50:21-50:33-51:26-53:23-54:4-54:41-57:14-58:8-59:10-60:1-60:10-60:12-61:6-63:1-63:11-67:9-69:9-71:4-79:34-80:2-80:8-80:33-89:22-98:4-110:1",216
93,16,"آ","ھَلُمَّ","«ھَلُمَّ» اسماء الافعال سے ہے بمعنی پکار یعنی کسی کو پکار پکار کر بلانا (م ل) یہ لفظ بہت کم استعمال ہوتا ہے ۔\n مثلاً : قرآن کریم میں ہے :\n«قَدۡ یَعۡلَمُ اللّٰہُ  الۡمُعَوِّقِیۡنَ مِنۡکُمۡ وَ الۡقَآئِلِیۡنَ لِاِخۡوَانِہِمۡ ہَلُمَّ   اِلَیۡنَا» ( 33/18 )\nترجمہ : خدا تم میں سے ان لوگوں کو بھی جانتا ہے جو ( لوگوں کو جنگ میں شامل ہونے سے ) منع کرتے ہیں اور اپنے بھائیوں سے کہتے ہیں کہ ہمارے پاس چلے آؤ ۔\nنوٹ : (اسماء افعال : وہ اسماء جن میں فعل کے معنی پائے جائیں لیکن وہ فعل کی علامات کو قبول نہ کریں)","«ھَلُمّ» پکار پکار کر بار بار کہنے کے لیے استعمال ہوتا ہے ۔","آنا","ھلم","6:150-33:18",2
94,16,"آ","ھَیْتَ","«ھَیْت» یہ لفظ دراصل «اَتٰی» کے صیغہ امر حاضر کے طورپراستعمال ہوتا ہے اور اس کے صیغے ضمائر منفصل سے تبدیل ہوتے ہیں ۔ مثلاً «ھَیْتَ لَکَ ھَیْتَ لَکُمَا ، ھَیْتَ لَکُمْ ۔ وَ۔ وَقِس عَلیٰ ھٰذَا» ۔ ابن فارس کے نزدیک «ھَیْتَ» اصل میں ’’ چیخنے ‘‘ پر دلالت کرتا ہے «کَلِمَۃٌ تُدَلٌ عَلَی الصَّیْحَۃِ» بعض نے اس کے معنی یہاں آنے ، ادھر آنے اور جلدی آنے کے بھی لکھے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ غَلَّقَتِ الۡاَبۡوَابَ وَ قَالَتۡ ہَیۡتَ لَکَ» ( 12/23 )\nترجمہ : وہ عورت ( زلیخا ) دروازے بند کر کے کہنے لگی ( یوسف ) جلدی آؤ ۔","«ھَیْت» کسی کو چیخ کر اپنے پاس بلانے کے لیے استعمال ہوتا ہے ۔","آنا","ھیت","12:23",1
95,17,"آ","بَصَر","«بَصَر» میں ظاہری آنکھ کے علاوہ قلبی رؤیت کا بھی لحاظ ہوتا ہے (مف) علاوہ ازیں «بَصَرَ» کا اطلاق ظاہری آنکھ کےعمل یعنی دیکھنے اور نگاہ پراورپھراس دیکھی ہوئی چیزپرغورکرنے کے معنوں میں بھی ہوتا ہے ۔ اس کی مثالیں ملاحظہ فرمائیے :\nمثال (1) ارشاد باری تعالیٰ ہے :\n«الۡحَقُّ فَاِذَا ہِیَ شَاخِصَۃٌ  اَبۡصَارُ الَّذِیۡنَ کَفَرُوۡا» ( 21/97 )\nترجمہ : اور قیامت کا سچا وعدہ قریب آ جائے تو ناگاہ کافروں کی آنکھیں کھلی کی کھلی رہ جائیں ۔\nمثال (2) نگاہ کے لیے : ارشاد باری تعالیٰ ہے :\n«فَکَشَفۡنَا عَنۡکَ غِطَآءَکَ فَبَصَرُکَ الۡیَوۡمَ حَدِیۡدٌ» ( 50/22 )\nترجمہ : اب ہم نے تجھ پر سے پردہ اٹھا دیا تو آج تیری نگاہ بہت تیز ہے ۔\nمثال (3) قلبی رؤیت کے لیے : ارشاد باری تعالیٰ ہے :\n«وَعَلٰۤی اَبۡصَارِہِمۡ غِشَاوَۃٌ» ( 2/7 )\nترجمہ : اور ان کی آنکھوں پر پردہ پڑا ہے ۔\nبصر سے مصدر بصارۃ بھی ہے اور بصیرت بھی ۔ بصارت کا اطلاق ظاہری نگاہ پر ہوتا ہے ۔ ضعف بصارت سے اسی ظاہری نظر کی کمزوری مراد ہوتی ہے اوربصیرت سے مراد قلبی نگاہ ہے ۔ کسی شاعر نے بصیرت اور بصارت کے فرق کو یوں واضح کیا ہے ۔ع\nدلِ بینا بھی کر خدا سے طلب\nآنکھ کا نور دل کا نور نہیں !\nنوٹ : ( مصدر: بمعنی  صادر ہونے یعنی نکلنے یا شروع ہونے کی جگہ، منبع، اصل، بنیاد، چشمہ، جڑ ۔ مصدر : ایسا اسم ہے جس سے دوسرے فعل بن سکتے ہیں لیکن وہ خود کسی فعل سے نہیں بنتا۔)","«بَصَر» میں ظاہری آنکھ کے علاوہ قلبی رؤیت کا بھی لحاظ ہوتا ہے ۔","آنکھ","بصر","2:7-2:17-2:20-3:13-6:46-6:103-6:104-6:110-7:47-7:179-7:195-7:198-7:201-10:31-10:43-10:67-11:20-14:42-15:15-16:77-16:78-16:108-17:12-17:36-17:59-18:26-19:38-19:42-20:96-21:3-21:97-22:46-23:78-24:30-24:31-24:37-24:43-24:44-27:13-27:54-27:86-28:11-28:72-29:38-32:9-32:12-32:27-33:10-36:9-36:66-37:175-37:179-38:45-38:63-40:61-41:20-41:22-43:51-45:23-46:26-47:23-50:8-50:22-51:21-52:15-53:17-54:7-54:50-56:85-59:2-67:3-67:4-67:23-68:5-68:43-68:51-69:38-69:39-70:11-70:44-75:7-79:9",82
96,17,"آ","حُوْر","«حَورَتِ الْعَیْن» یعنی آنکھ کی سفیدی بہت سفیداورسیاہی خوب سیاہ ہوگئی ۔ اور جس قدرآنکھ کی سفیدی میں سفیدی اور پتلی کی سیاہی میں سیاہی زیادہ ہو\n اسی قدر خوبصورتی میں اضافہ ہو جاتا ہے ۔«اَحْوَرْ» اور«حَوْرَاء» اس مرد اورعورت کو کہتے ہیں جو اسی صفت سے موصوف ہواوران دونوں کی جمع «حُوْر» آتی ہے (مف ۔ م ق)\n مثلاً : قرآن کریم میں ہے :\n«حُوۡرٌ مَّقۡصُوۡرٰتٌ فِی  الۡخِیَامِ» ( 55/72 )\nترجمہ : ( جنت میں ) حوریں ہوں گی خیموں میں رکی رہنے والی ۔\nایک دوسرے مقام پرآنکھ کی ان دونوں صفات کا اکٹھا بھی ذکر آیا ہے :\nارشاد باری تعالیٰ ہے :\n«وَ حُوۡرٌ عِیۡنٌ کَاَمۡثَالِ اللُّؤۡلُوءِ  الۡمَکۡنُوۡنِ» ( 56/22،23 )\nترجمہ : اور بڑی بڑی آنکھوں والی سیاہ چشم عورتیں ایسی ہیں جیسے کہ حفاظت سے چھپائے دھرے موتی ۔","«حُوْر» سفید اور سیا آنکھ کے لیے استعمال ہوتا ہے عرف عام میں جنت کی عورت کو کہتے ہیں۔","آنکھ","حور","44:54-52:20-55:72-56:22",4
97,17,"آ","عَیْن","«عَیْن» مشہوعضو انسانی جس سے دیکھتے ہیں اور بمعنی چشمہ کہ ان دونوں میں کئی لحاظ سے مناسبت ہے ۔ «عَیْن» جمع اسکی «اَعْیُن اور عُیُوْن») ہے  لیکن قرآن میں عین (آنکھ) کی جمع اکثر «اَعْیُن» آئی ہے ۔ اور عین بمعنی (چشمہ) کی جمع «عُیُوْن» آئی ہے ۔ لفظ «عَیْن» کا اطلاق محض ظاہری آنکھ پر ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَالۡعَیۡنَ بِالۡعَیۡنِ» ( 5/45 )\nترجمہ :’’ آنکھ کے عوض آنکھ (قصاص ہے) اور صفات کے لحاظ سے «عَیْن» کی دو اور قسمیں قرآن میں مذکور ہیں ۔\n«عِیْن» اور «حُوْر» آنکھوں کی صفات ہیں «عِین» موٹی موٹی آنکھوں والی اور «حُوْر» نہایت سفید اور پُتلی نہایت سیاہ رنگ کی آنکھوں والی ۔ «بَصَر» کا لفظ ظاہری عضو کے علاوہ آنکھ کے عمل یعنی نگاہ اور پھر اس دیکھی ہوئی چیز پر غور کرنے کے معنوں میں آتا ہے ۔","«عَیْن» کا لفظ دیکھنے کے ظاہری عضو آنکھ کے لیے استعمال ہوتا ہے ۔ ","آنکھ","عین","3:13-5:45-5:83-7:116-7:179-7:195-8:44-9:92-11:31-11:37-12:84-15:88-18:28-18:86-18:101-19:26-20:39-20:40-20:131-21:61-23:27-25:74-28:9-28:13-32:17-33:19-33:51-36:66-40:19-43:71-52:48-54:14-54:37-90:8-102:7",35
98,17,"آ","عِیْن","«عِیْن» بمعنی موٹی موٹی یا بڑی بڑی آنکھوں والی ۔ «اَعْیَن» اس مرد کو کہا جاتا ہے جس کی آنکھیں موٹی اور خوبصورت ہوں اور «عَیْنَاء» ایسی ہی عورت کو اور «اَعْیَن» اور «عَیْنَاء» دونوں کی جمع «عِیْنٌ» آتی ہے ۔ وحشی گائے کی آنکھیں بھی چونکہ موٹی موٹی اور خوبصورت ہوتی ہیں لہذا اسے بھی «اَعْیَن» اور«عَیْنَاء» کہا جاتا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ عِنۡدَہُمۡ  قٰصِرٰتُ الطَّرۡفِ عِیۡنٌ» ( 37/48 )\nترجمہ : اور ان ( جنتیوں ) کے پاس عورتیں ہوں گی نگاہیں نیچی رکھنے والی اور بڑی بڑی آنکھوں والی ۔","«عِین» موٹی موٹی آنکھوں والی ۔","آنکھ","عین","37:48-44:54-52:20-56:22",4
99,18,"آ","تَاہَ","«تَاہَ» بمعنی حیران و پریشان پھرنا ۔ گمراہی کی حالت میں ادھر ادھر بھٹکتے پھرنا ۔ (مف) اور ابن فارس کے نزدیک «جِنْسٌ مِّنَ الْحَیْرَۃ» یعنی یہ حیرانگی کی ایک خاص قسم ہے اور «اَتِیَہ» کے معنی ایسا چٹیل میدان جس میں چلنے والا بھٹک جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاِنَّہَا مُحَرَّمَۃٌ عَلَیۡہِمۡ اَرۡبَعِیۡنَ سَنَۃً ۚ یَتِیۡہُوۡنَ فِی الۡاَرۡضِ» ( 5/26 )\nترجمہ : خدا نے فرمایا کہ وہ ملک ان ( بنی اسرائیل ) پر چالیس برس تک کیلئے حرام کر دیا گیا اور یہ جنگل کی زمین میں سرگرداں پھرتے رہیں گے ۔","«تَاہَ» حیرانگی اور پریشانی کی حالت میں گمراہی کے رستوں پر سرگرداں پھرنے کے لیے استعمال ہوتا ہے ۔","آوارہ ","تاہ","5:26",1
100,18,"آ","ھَامَ","«ھَامَ» بمعنی مجنونی کیفیت سے پھرنا ۔ عاشق قسم کے لوگوں کی آوارگی (مف) صاحبِ منجد اس کے معنی محبت کرنا اورآوارہ پھرنا لکھتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَالشُّعَرَآءُ  یَتَّبِعُہُمُ  الۡغَاوٗنَ ۔ اَلَمۡ تَرَاَنَّہُمۡ فِیۡ کُلِّ وَادٍ یَّہِیۡمُوۡنَ» ( 26/224 )\nترجمہ : اور شاعروں کی پیروی گمراہ لوگ کیا کرتے ہیں ۔ کیا تم نے نہیں دیکھا کہ وہ ہر وادی میں سر مارتے پھرتے ہیں ۔","«ھَامَ» عشق و محبت کی آوارگی کے لیے استعمال ہوتا ہے ۔","آوارہ ","ھام","26:225",1
101,19,"آ","تَصْدِیَۃ","( صَدِیَ ) دونوں ہاتھوں سے تالیاں بجانا (م ل) اوراس میں تمام ساز و مضراب یعنی سامان موسیقی شامل ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَا کَانَ صَلَاتُہُمۡ عِنۡدَ الۡبَیۡتِ اِلَّا مُکَآءً وَّ تَصۡدِیَۃً» ( 8/35 )\nترجمہ : اور ان لوگوں کی نماز خانہ کعبہ کے پاس سیٹیاں بجانا اور تالیاں بجانے کے سوا کچھ نہ تھی ۔","«تَصْدِیَۃ» تالی کی طرح کی ایک آواز کوکہتے ہیں ۔","آواز","تصدیۃ","8:35",1
102,19,"آ","تَغَیُّظ","«تَغَیُّظ» بمعنی جوش اورغصہ میں جھنجھلاہٹ اورچڑچڑا پن (منجد) مجازاً جہنم کی آگ میں تیزی اور جوش کی وجہ سے پیدا ہونے والی آوازیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اِذَارَاَتۡہُمۡ مِّنۡ مَّکَانٍۭ بَعِیۡدٍ سَمِعُوۡا لَہَا تَغَیُّظًا وَّ زَفِیۡرًا» ( 25/12 )\nترجمہ : جب وہ ( دوزخ ) اُن کو دور سے دیکھے گی ( تو غضبناک ہو رہی ہو گی اور یہ ) اس کے جوش ( غضب ) اور چیخنے چلانے کو سنیں گے ۔","«تَغَیُّظ» غیظ و غضب میں جھنجھلاہٹ چڑچڑا پن کے لیے استعمال ہوتا ہے ۔","آواز","تغیظ","3:119-3:134-9:15-9:120-22:15-25:12-33:25-48:29-67:8",9
103,19,"آ","حَسِیْس","«حَسِیْس» قدموں کی آہٹ ، چاپ ۔ ہلکی  سی آواز (منجد) آگ بھڑکنے کی آواز (ف ل 2 ، 3)\nمثلاً : قرآن کریم میں ہے :\n«لَا یَسۡمَعُوۡنَ حَسِیۡسَہَا ۚ وَ ہُمۡ  فِیۡ مَا اشۡتَہَتۡ اَنۡفُسُہُمۡ  خٰلِدُوۡنَ» ( 21/102 )\nترجمہ : نہیں سنیں گے اس کی آہٹ اور وہ اپنے جی کے مزوں میں سدا رہیں گے ۔ (عثمانیؒ)","«حَسِیْس» قدموں کی آہٹ کی طرح ہلکی سی آواز کے لیے استعمال ہوتا ہے ۔","آواز","حسیس","21:102",1
104,19,"آ","خُوَار","«خُوَار» بیل ۔ گائے یا بچھڑے کی آواز (ف ل 193)\nمثلاً : قرآن کریم میں ہے :\n«وَ اتَّخَذَ قَوۡمُ  مُوۡسٰی مِنۡۢ بَعۡدِہٖ مِنۡ حُلِیِّہِمۡ عِجۡلًا جَسَدًا لَّہٗ خُوَارٌ» ( 7/148 )\nترجمہ : اور قومِ موسیٰ نے موسیٰؑ کے بعد اپنے زیور کا ایک بچھڑا بنا لیا وہ ایک جسم تھا جس میں سے بیل کی آواز نکلتی تھی ۔","«خُوَار» بچھڑے کی آواز کے لئے استعمال ہوتا ہے ۔","آواز","خوار","7:48-20:88",2
105,19,"آ","رِكْزًا","«رِکْز» ہلکی اور دھیمی آواز (ف ل 193) اور بعض کے نزدیک بھنک ۔ مکھی کی بھنبھناہٹ ۔\nمثلاً : قرآن کریم میں ہے :\n«وَکَمۡ اَہۡلَکۡنَا قَبۡلَہُمۡ مِّنۡ قَرۡنٍ ؕ ہَلۡ تُحِسُّ مِنۡہُمۡ مِّنۡ  اَحَدٍ اَوۡ تَسۡمَعُ لَہُمۡ رِکۡزًا» ( 19/98 )\nترجمہ : اور ہم نے ان سے پہلے بہت سے گروہوں کو ہلاک کر دیا ہے ۔ بھلا تم ان میں سے کسی کو دیکھتے ہو یا کہیں ان کی بھنک سنتے ہو ۔","«رِكْزًا» مکھی بھنبھناہٹ جیسی ہلکی آواز کے لیے استعمال ہوتا ہے ۔","آواز","رکز","19:98",1
106,19,"آ","زَفِیْرٌ","«زَفَرَ» بمعنی لمبا سانس باہر نکالنا اور «زَفِیْر» اس آواز کو کہتے ہیں جب گدھا رینگنا شروع کرتا ہے تواُسکی جو ابتدائی آواز ہوتی ہے جوآہستہ آہستہ اونچی ہونا شروع ہو جاتی ہے اسے زفیر کہتے ہیں ۔ ( ف ل 34 )\n","«زَفِیْر» گدھے کے رینگنے کی ابتدائی آوازکو کہتے ہیں ۔","آواز","زفیر","11:106-21:100-25:12",3
107,19,"آ","شَھِیْق","«شَھِیْق» اُس آواز کو کہتے ہیں جب گدھا رینگنا ختم کرنے لگے تواونچی آواز سے جب آواز کم ہونا شروع ہوتی ہے اسے «شَھِیْق» کہتے ہیں (ف ل 34) زفیراورشھیق یہ دونوں ایک دوسرے کی ضد ہیں (م ل)\nمثلاً :  قرآن کریم میں ہے :\n«فَاَمَّا الَّذِیۡنَ شَقُوۡا فَفِی النَّارِ لَہُمۡ فِیۡہَا زَفِیۡرٌ  وَّ شَہِیۡقٌ» ( 11/106 )\nترجمہ : تو جو بدبخت ہیں وہ دوزخ میں ڈال دیے جائیں گے اس میں ان کے لیے زفیر اور شہیق جیسی آوازیں ہوں گی ۔\nیہ آوازیں یا تو جہنم کی آگ سے پیدا ہوں گی جو انہیں سننا پڑیں گی یا گرمی اور پیاس کی شدت کی وجہ سے خود اُن کے اندر سے منہ کے راستہ ایسی آوازیں نکلیں گی ۔","«شَھِیْق» گدھے کے رینگنے کی انتہا ئی آواز کو کہتے ہیں ۔","آواز","شھیق","11:106-67:7",2
108,19,"آ","صَاخّۃ","«صَاخَّۃ» ایسی کرخت آواز جو کانوں کو بہرا کر دے (م ۔ ل) کان پھوڑنے والی آواز ۔ سخت قسم کا شور و غل ۔\nمثلاً :  قرآن کریم میں ہے :\n«فَاِذَا جَآءَتِ الصَّآخَّۃُ» ( 80/33 )\nترجمہ : پھر جب آئے وہ کان پھوڑنے والی ۔ ( عثمانیؒ )","«صَاخَّۃ» کان پھوڑنے والی کرخت اور بلند آواز کے لیے استعمال ہوتا ہے ۔","آواز","صاخۃ","80:33",1
109,19,"آ","صَدَّ","«یَصِدُّ صَدِیْدًا» کسی انسان کے گرنے کے وقت کی چیخ و پکار اور کراہنے کی آواز (ف ل 192) لیکن یہ لفظ قرآن میں محض چیخنے چلانے کے معنوں میں آیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لَمَّا ضُرِبَ ابۡنُ مَرۡیَمَ  مَثَلًا  اِذَا قَوۡمُکَ مِنۡہُ  یَصِدُّوۡنَ» ( 43/57 )\nترجمہ : اور جب مریم کے بیٹے ( عیسیٰ کا ) حال بیان کیا گیا تو تمہاری قوم کے لوگ اس سے چلا اٹھتے ہیں ۔","«صَدَّ» چیخنا چلانا یا کراہنا  کے لئے استعمال ہوتا ہے ۔","آواز","صد","15:94-43:57",2
110,19,"آ","صَرَخَ","«صَرَخَ» مصیبت اور گھبراہٹ میں چلانے کی آواز ۔ فریاد (ف ل)\nمثلاً : قرآن کریم میں ہے :\n«وَہُمۡ یَصۡطَرِخُوۡنَ فِیۡہَا ۚ رَبَّنَاۤ اَخۡرِجۡنَا نَعۡمَلۡ صَالِحًا غَیۡرَ الَّذِیۡ کُنَّا نَعۡمَلُ» ( 35/37 )\nترجمہ : وہ اس دوزخ میں چلائیں گے اور ( کہیں گے ) اے پروردگار ہم کو نکال لے ۔ تب ہم نیک عمل کیا کریں گے نہ وہ جو ( پہلے ) کرتے تھے ۔","«صَرَخَ» فریاد کی صورت میں چلانے کی آواز  کے لیے استعمال ہوتا ہے ۔","آواز","صرخ","14:22-28:18-35:37",3
111,19,"آ","صَلصَال","«صَلصَال» خشک اور پختہ مٹی سے بنے ہوئے برتنوں کے آپس میں ٹکرانے کی آواز ۔ اصل میں یہ «صَلَّال» تھا ۔ ایک لام ص سے بدل گیا ۔ (مف) «اَلصَّلَالُ مِنَ الطِّیْن» ۔ خشک کھنکھنی مٹی جو لوہے کی طرح بجے (منجد) «صَلَّ الْمِسْمَارُ» ۔ یعنی وہ آواز جو کسی چیز میں میخ یا کیل ٹھونکنے سے پیدا ہو (مف)\n مثلاً :  قرآن کریم میں ہے :\n«وَ لَقَدۡ خَلَقۡنَا الۡاِنۡسَانَ مِنۡ صَلۡصَالٍ مِّنۡ حَمَاٍ مَّسۡنُوۡنٍ» ( 15/26 )\nترجمہ : اور ہم نے انسان کو کھنکھناتے سڑے ہوئے گارے سے پیدا کیا ہے ۔","«صَلْصَال» مٹی کے  برتنوں کے آپس میں ٹکرانے کی آواز  کے لیے استعمال ہوتا ہے ۔","آواز","صلصال","15:26-15:28-15:33-55:14",4
112,19,"آ","صَوْت","«صَوْت» یہ لفظ عربی میں ہر قسم کی آواز کے لیے استعمال ہوتا ہے ۔  چاہے وہ بولنے سے پیدا ہو یا چیزوں کے ٹکرانے سے ۔ صوت کی ایک تعریف یہ بھی  کی گئی ہے  ’’ منہ سے نکلی ہوئی  چیزاگر الفاظ اور حروف پر مشتمل نہ ہو تو وہ صوت ہے  مگر یہ تعریف قابل اعتبار نہیں ۔ (محیط)\nمثلاً :  قرآن کریم میں ہے :\n«یٰۤاَیُّہَا  الَّذِیۡنَ اٰمَنُوۡا لَا تَرۡفَعُوۡۤا اَصۡوَاتَکُمۡ  فَوۡقَ صَوۡتِ النَّبِیِّ» ( 49/2 )\nترجمہ : اے ایمان والو ! نبی کی آواز سے اپنی آواز بلند نہ کرو ۔\nاور ظاہر ہے کہ صحابہؓ کا حضور اکرم ﷺ سے بامعنی کلام ہوتا تھا ۔ بے معنی آوازیں نہ ہوتی تھیں ۔\nالبتہ ابن فارس نے صوت کی جامع تعریف کی ہے ۔ وہ کہتے ہیں «کُلُّ مَا وَتَرَفِیْ اُذُنِ سَامَعٍ» ۔ (م ل)  ہر وہ کچھ جو سننے والے کے کان سے ٹکرائے وہ آواز ہے ۔\nقرآن کریم میں کچھ تو جانداروں کی آوازیں مذکور ہیں اور کچھ بے جان چیزوں کی ۔ ہم اسی ترتیب سے انہیں بیان کریں گے ۔\nجانداروں کی آوازیں : «صَد ، صَرَخ ، ھَمَس ، حَسِیْس ، مُکَاء ( مَکُو ) تَصْدِیَۃ ، ضَبَح ، خُوَار ، زَفِیْر ، شَھِیْق ، لَھَث»","«صَوْت» ہر قسم کی آواز کے لیے استعمال ہوتا ہے چاہے  ہلکی ہو یا بلند ۔ جاندار کی ہو  یا بے جان کی ہو ، بے معنی ہو یا با معنی ہو ۔","آواز","صوت","17:64-31:19-49:2",3
113,19,"آ","صَیْحَۃً","«صَیْحَۃً» آواز پھاڑ پھاڑ کر چلانا ۔ صور پھونکنے کی آواز (مف) ایسی آواز جس سے دل دہل جائیں گرج دار آواز ۔ دھماکہ ۔ یعنی جب کسی بھی آواز میں شدت پیدا ہو جائے ۔ ہر بے معنی اور بلند آواز کو «صَیْحَۃ» کہتے ہیں (فق ل 26)\nمثلاً :  قرآن کریم میں ہے :\n«فَاَخَذَتۡہُمُ الصَّیۡحَۃُ  مُشۡرِقِیۡنَ . فَجَعَلۡنَا عَالِیَہَا سَافِلَہَا» ( 15/73،74 )\nترجمہ : سو ان کو سورج نکلتے نکلتے چنگھاڑ نے آ پکڑا اور ہم نے اس ( شہر ) کو ( الٹ کر ) اس کے اوپر کے حصے کو نچلا بنا دیا ۔","«صَیْحَۃً» بلند اور بے معنی آوازکے لیے استعمال ہوتا ہے ۔","آواز","صیحۃً","11:67-11:94-15:73-15:83-23:41-29:40-36:29-36:49-36:53-38:15-50:42-54:31-63:4",13
114,19,"آ","ضَبَحَ","«ضَبَحَ» گھوڑے کے تیز دوڑنے کی وجہ سے اس کے ہانپنے کی آواز (ف ل 199)\nمثلاً : قرآن کریم میں ہے :\n«وَالۡعٰدِیٰتِ ضَبۡحًا» ( 100/1 )\nترجمہ : ان سرپٹ دوڑنےوالے گھوڑوں کی قسم جو ہانپ اٹھتے ہیں ۔","«ضَبَحَ» دوڑتے وقت ہانپنے کی آواز کو کہتے ہیں ۔","آواز","ضبح","100:1",1
115,19,"آ","غَلْی","«غَلْی» ہنڈیا کے ابلنے اور جوش مارنے کی آواز ۔ کھولنے کی آواز ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«کَالۡمُہۡلِ یَغۡلِیۡ  فِی الۡبُطُوۡنِ . کَغَلۡیِ  الۡحَمِیۡمِ» ( 44/45،46 )\nترجمہ : جیسے پگھلا ہوا تانبا ، پیٹوں میں ( اس طرح ) کھولے گا جس طرح گرم پانی کھولتا ہے ۔","«غَلْی» ہنڈیا کے ابلنے کی آواز کے لیے استعمال ہوتا ہے ۔","آواز","غلی","44:45-:44:46",3
116,19,"آ","قارِعۃ","«قَرَعَ» کے معنی ایک چیز کو دوسری چیز پر مارنا ( مف ) اور «قَررَعَ الْبَابَ» بمعنی دروازہ کھٹکھٹانا ( منجد ) یعنی جب اس کے ایک پٹ کو دوسرے پٹ سے ٹکرا کر یا  ہاتھ مار کر یا کسی اور چیز سے آواز پیدا کی جائے ۔ قیامت کو اللہ تعالیٰ نے «قَارِعَۃ» کہا ہے کہ اس وقت چیزوں کے ایک دوسرے سے ٹکرا نے سے آوازیں پیدا ہوں گی ۔ مثلاً : قرآن کریم میں ہے :\n«اَلۡقَارِعَۃُ مَا الۡقَارِعَۃُ» ( 101/1،2)\nترجمہ : کھڑکھڑ ڈالنے والی ۔ کیا ہے وہ کھڑکھڑ ڈالنے والی ۔","«قَارِعَۃ» کھڑکھڑانے کی آواز ۔","آواز","قارعۃ","13:31-69:4-101:1-101:2-101:3",5
117,19,"آ","لَھَثَ","«لَھَثَ» کتے کے ہانپنے کی آواز جس کی وجہ گرمی یا پیاس کی شدت ہوتی ہے اور وہ زبان باہر نکال کر ہانپنے یا بھونکنے لگتا ہے ۔ (مف ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَمَثَلُہٗ  کَمَثَلِ الۡکَلۡبِ ۚ اِنۡ  تَحۡمِلۡ عَلَیۡہِ یَلۡہَثۡ اَوۡ تَتۡرُکۡہُ یَلۡہَثۡ» ( 7/176 )\nترجمہ : اس شخص کی مثال کتے کی سی ہے کہ اگر اس پر بوجھ لاد دو تو بھی ہانپے اوراگرچھوڑ دوتوبھی ہانپے ۔\nبے جان چیزوں کی آوازیں  کے لئے بھی استعمال ہوتا ہے :","«لَھَثَ» گرمی یا پیاس کی شدت  وجہ سے کتے کے ہانپنے یا  بھونکنے کی آواز  کو کہتے ہیں ۔","آواز","لھث","7:176",1
118,19,"آ","مُکَآءً","«مُکَآءً» منہ سے سیٹی بجانا (منجد) اور اس میں موسیقی کے تمام سُر تال شامل ہیں ۔","«مُکَآءً» منہ سے سیٹی کی سی آواز نکالنے کے لیے استعمال ہوتا ہے ۔","آواز","مکآءً","8:35",1
119,19,"آ","ھَدّ","«ھَدّ» کسی عمارت یا دیوار یا ستون وغیرہ کے گرنے کی آواز جیسے دھڑام کی آواز ۔ ( ف ل 194 )\nمثلاً : قرآن کریم میں ہے :\n«تَکَادُ السَّمٰوٰتُ یَتَفَطَّرۡنَ مِنۡہُ وَ تَنۡشَقُّ الۡاَرۡضُ وَ تَخِرُّ الۡجِبَالُ ہَدًّا» ( 19/90 )\nترجمہ : قریب ہے کہ اس ( افتراء ) سے آسمان پھٹ پڑیں اور زمین شق ہو جائے اور پہاڑ ڈھے کر گر پڑیں ۔","«ھَدّ» کسی عمارت یا دیوار یا ستون وغیرہ کے گرنے کی آواز کے لیے استعمال ہوتا ہے ۔","آواز","ھد","19:90",1
120,19,"آ","ھَمْس","«ھَمْس» انسان کی کسی بھی حرکت کی آواز (ف ل 193) کھسر پھسر یا کانا پھوسی کی آواز  کے لیے استعمال ہوتا ہے (منجد) «اَلصَّوْتُ الْخَفِیِّ وَاَحَسّ» (م ل) گویا اس سے مراد انسان کی کوئی بھی دھیمی اور قابل محسوس آواز ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ خَشَعَتِ الۡاَصۡوَاتُ لِلرَّحۡمٰنِ فَلَا تَسۡمَعُ   اِلَّا ہَمۡسًا» ( 20/108 )\nترجمہ : اور خدا کے سامنے سب آوازیں دب جائیں گی اور تم آواز خفی کے سوا کوئی آواز نہ سن سکو گے ۔","«ھَمْس» انسان کی کسی بھی حرکت کی ہلکی سی آواز  کو کہا جاتا ہے ۔","آواز","ھمس","20:108",1
121,20,"آ","اِسْتِدْراج","«دَرَجَۃ» سیڑھی کے زینہ کو کہتے ہیں جبکہ اوپر کی طرف  چڑھا جائے اور «ااِسْتِدْراج» کے معنی آہستہ آہستہ اور درجہ بدرجہ ایک چیز کو دوسری چیز کے قریب کرنے کے ہیں (مف) تاکہ اسے کچھ معلوم نہ ہو سکے ۔ گویا «ااِسْتِدْراج»  میں تدریج یعنی درجہ بدرجہ اور آہستگی ان باتوں کی رعایت ضروری ہوتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ الَّذِیۡنَ کَذَّبُوۡا بِاٰیٰتِنَا سَنَسۡتَدۡرِجُہُمۡ مِّنۡ حَیۡثُ لَا  یَعۡلَمُوۡنَ» ( 7/182 )\nترجمہ : اور جن لوگوں نے ہماری آیتوں کو جھٹلایا ان کو بتدریج اس طرح پکڑیں گے کہ انہیں معلوم ہی نہ ہو گا (جالندھری) ۔ ہم ان کو آہستہ آہستہ پکڑیں گے ۔ (عثمانی)","«ااِسْتِدْراج» درجہ بدرجہ اور آہستگی سے کسی دوسری چیز کے قریب ہونا ۔"," آہستہ","استدراج","7:182-68:44",2
122,20,"آ","دَلّٰی ۔ دَلْوٌ","«دَلّٰی ۔ دَلْوٌ» کے معنی ایسا ڈول ہے جو پانی سے خالی ہو اور «اَدْلیٰ» کے معنی خالی ڈول کو پانی سے بھرنے کے لیے کنویں میں لٹکانا ہے جو آہستہ آہستہ پانی تک پہنچ جاتا ہے اور «دَلّٰی» کے معنی آہستہ آہستہ کسی کام کو سرانجام دینے اور مقصد تک پہنچنے کے ہیں ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«فَدَلّٰىہُمَا بِغُرُوۡرٍ» ( 7/22 )\nترجمہ : غرض (شیطان مردود نے) ان دونوں (آدم و حوا) کو دھوکا دے کر (معصیت کی طرف) کھینچ ہی لیا ۔ (جالندھریؒ)\nمائل کر لیا اُن کو فریب سے (عثمانیؒ)","«دَلّٰی» رفتہ رفتہ اور آہستگی سے اپنا مقصد حاصل کرنے کے لیے استعمال ہوتا ہے ۔"," آہستہ","دلی ۔ دلو","7:22-:12:19",3
123,20,"آ","رُخَاءً","«رُخَاءً» اتنی نرم اور آہستہ آہستہ چلنے والی ہوا جو کسی چیز کو نہ ہلا سکے (منجد) ہوا کا نرمی سے دھیرے دھیرے چلنا ( ف ل 46 )\nمثلاً :  قرآن کریم میں ہے :\n«فَسَخَّرۡنَا لَہُ  الرِّیۡحَ تَجۡرِیۡ بِاَمۡرِہٖ رُخَآءً  حَیۡثُ  اَصَابَ» ( 38/36 )\nترجمہ : پھر ہم نے ہوا کو ان کے زیرِ فرمان کر دیا کہ جہاں وہ پہنچنا چاہتے ان کے حکم سے نرم نرم چلنے لگتی ۔","«رُخَاءً» ہوا کا اتنا آہستہ اور نرمی سے چلنا کہ وہ ہوا کسی چیز کو ہلا نہ سکے ۔"," آہستہ","رخاءً","38:36",1
124,20,"آ","رُوَیدا","«رُوَیْدا» نکلا ہے «اَلرَّوْد» سے اور «اَرْوَدُ» کا اصل لفظ  «مُصَغَّر»  ہے بمعنی چھوٹا کرنا ۔  «اِمْشِ عَلَی الرَّوْد» آہستہ چلو ۔ اور «سَارُوْا سَیْرًا رُوَیْدًا» ۔ وہ نرمی سے اور آہستہ آہستہ چلے اور «اَرْوَدُ» بمعنی اپنے کام میں آہستگی کرنے والا ۔ نیز کہتے ہیں «اَلدَّھْرُ اَوْرَدُ ذُوْ غِیَرٍ» یعنی زمانہ چپکے چپکے کام کرتا رہتا ہے ۔ پتہ نہیں لگنے دیتا ۔ نیز کہتے ہیں «رُوَیْدَ زَیْدًا» ۔ زید کو مہلت دو (منجد) گویا «رُوَیْد» کا مفہوم آہستہ آہستہ اور چپکے چپکے رسی دراز کرتے جانا یا تھوڑی تھوڑی مہلت دیتے جانا ہے ۔\nمثلاً :  قرآن کریم میں ہے :\n«فَمَہِّلِ الۡکٰفِرِیۡنَ  اَمۡہِلۡہُمۡ رُوَیۡدًا» ( 86/17 )\nترجمہ : تو تم کافروں کو مہلت دو ۔ بس چند روز ہی مہلت دو ۔","«رُوَیْدَا» کسی کی رسی آہستہ آہستہ چھوڑتے جانا تاکہ وہ اپنے انجام کو پہنچ جائے ۔"," آہستہ","رویدا","86:17",1
125,20,"آ","عُرْفًا","«عُرْفًا» دھیمی دھیمی چلنے والی سکون اور راحت بخش ہوا ۔ «العرْف» بمعنی بُو ۔ اکثر اس کا استعمال خوشبو کے لیے ہوتا ہے ۔ (منجد) اورایسی ہوائیں جوعموماً دھیمی رفتار سے چلتی ہیں ۔ نسیمِ سحر ۔\nمثلاً :  قرآن کریم میں ہے :\n«وَ الۡمُرۡسَلٰتِ  عُرۡفًا» ( 77/1 )\nترجمہ : قسم ہے چلتی ہواؤں کی ، دل کو خوش آتی ( عثمانیؒ )","«عُرْفًا» ہوا کا آہستگی کے ساتھ چلنا جبکہ اس میں راحت اور سکون  بھی شامل ہو ۔"," آہستہ","عرفًا","77:1",1
126,20,"آ","یُسْر","«یُسْر» بمعنی آسانی اور سہولت اور اس کی ضد «عُسْر» ہے  بمعنی تنگی ۔ اور «یُسْرًا» کا لفظ اس حالت کو بھی ظاہر کرتا ہے جب کوئی کام آسانی اور سہولت کے ساتھ بلاتکلف سرانجام دیدیا جائے اور اس میں کسی قسم کا جھول واقع نہ ہو ۔\nمثلاً :  قرآن کریم میں ہے :\n«فَالۡجٰرِیٰتِ  یُسۡرًا» ( 51/3 )\nترجمہ : پھر ( قسم ہے ان ہواؤں کی جو ) آہستہ آہستہ چلتی ہیں (جالندھری) ۔ پھر کشتیاں آسانی سے چلنے والیاں (عثمانیؒ)\nتو یہاں «یُسْر» سے مراد رفتار کی کمی نہیں بلکہ اس سے یہ مراد ہے کہ تیز رفتاری سے چلنے کے باوجود ان میں کوئی ہچکولہ ، جھول ، ڈھلک یا آواز پیدا نہیں ہوتی تو ایسا معلوم ہوتا ہے کہ وہ آہستہ اور نرمی سے چل رہی ہیں ۔","«یُسْرًا» بلاتکلف اور سہولت کے ساتھ  کسی کام کو بغیر کسی مزاحمت کے سرانجام دینا ۔"," آہستہ","یسر","2:185-2:280-18:88-19:97-20:26-44:58-51:3-54:17-54:22-54:32-54:40-65:4-65:7-80:20-87:8-92:7-92:10-94:5-94:6",19
127,21,"ا","غَلْی","«غَلَا» کے بنیادی معنی اپنی حد سے تجاوز کرنا اور اوپراٹھنا ہے اور اسی سے «غَلَا الْقِدْر» بمعنی ہانڈی کا جوش مارنا اور«غَلَا السَّعْر» بمعنی قیمتوں  کا بلند ہو جانا ہے ۔ (م ل)\nمثلاً : قرآن کریم میں ہے :\n«کَالۡمُہۡلِ  ۚ ۛ یَغۡلِیۡ  فِی الۡبُطُوۡنِ کَغَلۡیِ  الۡحَمِیۡمِ» ( 44/45،46 )\nترجمہ : جیسے پگھلا ہوا تانبا ، پیٹوں میں اس طرح کھولے گا جیسے گرم پانی کھولتا ہے ۔","«غَلْی» گرمی کی وجہ سے کسی رکاوٹ والی چیز کا جوش مارنا اور اپنی اصل سطح سے بلند  ہوجانا ۔","اُبلنا","غلی","44:45-44:46",2
128,21,"ا","فَارَ","«فَارَ» کا لفظ ہانڈی کے جوش مارنے ، چشمہ سے پانی ابلنے کے لیے اور آگ کے جوش مارنے کے لیے بھی استعمال ہوتا ہے مگر یہ لفظ اس صورت میں استعمال ہو گا جبکہ اُبال جلد جلد اٹھ رہا ہو کیونکہ «اَلْفَوْر» کے معنی بہت جلدی کے ہیں ۔ کہا جاتا ہے «رَجَعَ مِنْ فَوْرَہٗ» وہ بلا  تاخیر بہت جلد جلد واپس ہوا ۔ (منجد) اور لفظ فوارہ بھی اسی سے  نکلا ہے ۔ جس میں پانی میں تسلسل قائم رہتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«حَتّٰۤی اِذَا جَآءَ اَمۡرُنَا وَ فَارَ التَّنُّوۡرُ» ( 11/40 )\nترجمہ : یہاں تک کہ ہمارا حکم آ پہنچا اور تنور جوش مارنے لگا ۔","«فَارَ» کسی چیز میں شدت اور جلدی کی وجہ سے اس کے اُبال میں تسلسل قائم رہنا ۔","اُبلنا","فار","11:40-23:27",2
129,21,"ا","نَضَخَ","«نَضَخَ» پانی کا چشمہ سے زور سے پھوٹنا (منجد) مگر «نَضَخَ» میں جوش مارنے کی وجہ پانی کی کثرت اوردباؤ ہوتی ہے نہ کہ حرارت اور «نَضَّاخ» موسلا دھار بارش کو بھی کہتے ہیں ۔ (منجد) اور «عَیْنٌ نَضَّاخَۃٌ» وہ چشمہ ہے جو کثرت آب کی وجہ سے جوش مار رہا ہو ۔ (م ل)\nمثلاً : قرآن کریم میں ہے :\n«فِیۡہِمَا عَیۡنٰنِ نَضَّاخَتٰنِ» ( 55/66 )\nترجمہ : ان دونوں باغوں میں دو چشمے ابل رہے ہیں ۔","«نَضَخَ» پانی کی کثرت اوردباؤ کی وجہ سے پانی کا جوش مارنا ۔","اُبلنا","نضخ","55:66",1
130,22,"ا","اَزَّ","«اَزَّ» کسی کو برے کام پر اس طرح  اُکسانا ، اُبھارنا کہ اسے احساس بھی نہ ہو ۔اور کسی کو اپنی جگہ سے اکھاڑ دینا ( م ل ) «اَزِیْز» ہانڈی کے جوش کی آواز کو بھی کہتے ہیں ۔ اس لفظ کا استعمال عموماً برے مفہوم میں ہوتا ہے ۔\nمثلاً :  قرآن کریم میں ہے :\n«اَلَمۡ تَرَ اَنَّـاۤ اَرۡسَلۡنَا الشَّیٰطِیۡنَ عَلَی الۡکٰفِرِیۡنَ تَؤُزُّہُمۡ  اَزًّا» ( 19/83 )\nترجمہ :  کیا تم نے نہیں دیکھا کہ ہم نے شیطانوں کو کافروں پر چھوڑ رکھا ہے کہ وہ ان کو پرانگیختہ کرتے رہتے ہیں ۔","«اَزَّ» کسی کو برے کام پر اس طرح  اُکسانا ، اُبھارنا کہ اسے احساس بھی نہ ہو ۔","اُبھار","از","2:36-19:83",2
131,22,"ا","اَمْت","«اَمْت» اسکی ضد «عِوَجْ» ہے (بمعنی پستی) اور«عِوَجْ» اور «اَمْت» بمعنی نشیب و فراز اور «اَمْت» بمعنی چھوٹا ٹیلہ ۔ ٹبہ بلند مقام (منجد) یعنی ایسی بلندی اور پھیلاؤ جس میں کوئی ترتیب نہ ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«لَّا تَرٰی  فِیۡہَا عِوَجًا وَّ لَاۤ اَمۡتًا» ( 20/107 )\nترجمہ : جس میں نہ تم کجی ( پستی ) دیکھو گے نہ ٹیلا ( اور بلندی ) ۔","«اَمْت» ایسے چھوٹے ٹیلے کو کہتے ہیں جس کی بلندی اور پھیلاؤ میں کوئی ترتیب نہ ہو۔","اُبھار","امت","20:107",1
132,22,"ا","جَرَمَ","«جَرَمَ» (مصدر ہے) گناہ اور قصور کو کہتے ہیں اور جب یہ فعل ہو تو اس کے معنی کسی کو بڑے جانکاہ یعنی جان گھٹانے یا تکلیف دہ کام پراکسانا اشتعال دلانا ہوگا ۔ لغت اس معنی کی تائید نہیں کرتی لیکن تراجم مثلاً جالندھریؒ ، عثمانیؒ اور تفہیم القرآن سب ہمارے بیان کردہ معنی کی تائید کرتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لَا  یَجۡرِمَنَّکُمۡ شَنَاٰنُ قَوۡمٍ عَلٰۤی اَلَّا تَعۡدِلُوۡا» ( 5/8 )\nترجمہ : اور لوگوں کی دشمنی تمہیں اس بات پر آمادہ نہ کرے کہ انصاف چھوڑ دو ۔\nنوٹ : ( مصدر: بمعنی  صادر ہونے یعنی نکلنے یا شروع ہونے کی جگہ، منبع، اصل، بنیاد، چشمہ، جڑ ۔ مصدر : ایسا اسم ہے جس سے دوسرے فعل بن سکتے ہیں لیکن وہ خود کسی فعل سے نہیں بنتا۔)","«جَرَمَ» گناہ کے کاموں پر ابھارنے اور اشتعال دلانے کے لیے استعمال ہوتا ہے ۔","اُبھار","جرم","5:2-5:8-40:43",3
133,22,"ا","حَدَب","«حَدَبَ الرَّجُل» بمعنی آدمی کا کُبڑا ہونا اور «حَدَب» بمعنی کُبڑا پن اور مجازاً اس بلند اور سخت زمین کو بھی کہتے ہیں جو اس شکل کی ہو ۔ ٹیلہ جو پھیلاؤ میں زیادہ اور بلندی میں کم ہو اور یہ اُبھار یا ڈھلان  کُبڑا پن کی طرح ہو ۔ «مُحَدَّب ضد مُجَوَّف» ایسے شیشے جو دور اور نزدیک کی نظر کی کمزوری کے لیے استعمال کیے جاتے ہیں اور «مُحَدَّب» شیشہ کو عدسہ بھی کہتے ہیں کیونکہ یہ شیشہ مسور کے دانے کی طرح دونوں طرف ابھرا ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«حَتّٰۤی  اِذَا  فُتِحَتۡ یَاۡجُوۡجُ وَ مَاۡجُوۡجُ وَ ہُمۡ  مِّنۡ  کُلِّ  حَدَبٍ  یَّنۡسِلُوۡنَ» ( 21/96 )\nترجمہ : یہاں تک کہ یاجوج اور ماجوج کھول دیے جائیں اور وہ ہر بلندی سے دوڑتے آ رہے ہوں ۔","«حَدَب» کُبڑے آدمی کے لیے استعمال ہوتا ہے ، اور ایسے ٹیلے کو بھی کہتے ہیں جس کی بلندی کم اور پھیلاؤ زیادہ ہو ۔","اُبھار","حدب","21:96",1
134,22,"ا","حَرَضَ","«حَرَضَ» کے معنی سخت بیمار ہونا ، لاغر ہونا اورمرنے کے قریب ہوجانا ہے ( م ۔ ل ، م ق )\nمثلاً :  قرآن کریم میں ہے :\n«قَالُوۡا تَاللّٰہِ تَفۡتَؤُا تَذۡکُرُ  یُوۡسُفَ حَتّٰی تَکُوۡنَ حَرَضًا اَوۡ تَکُوۡنَ مِنَ الۡہٰلِکِیۡنَ» ( 12/85 )\nترجمہ : ( یعقوب ؑ کے بیٹے اپنے باپ سے ) کہنے لگے کہ واللہ اگر آپ یوسف کو اسی طرح یاد کرتے رہیں گے تو یا تو بیمار ہو جائیں گے یا جان ہی دے دیں گے ۔\nاور «حَرَضَ» ایسی بات پر ترغیب دینا جس کا نہ کرنا ہلاکت و تباہی کا سبب ہو ۔ (م ل) یعنی کسی ایسے کام پر ابھارنا ، یا اشتیاق پیدا کرنا کہ اگر وہ نہ کیا جائے تو ہلاکت و تباہی کا موجب ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا النَّبِیُّ حَرِّضِ الۡمُؤۡمِنِیۡنَ عَلَی الۡقِتَالِ ؕ اِنۡ یَّکُنۡ مِّنۡکُمۡ عِشۡرُوۡنَ صٰبِرُوۡنَ یَغۡلِبُوۡا مِائَتَیۡنِ» ( 8/65 )\nترجمہ : اے نبی ﷺ ! مسلمانوں کو جہاد کی ترغیب دو ۔ اگر تم میں بیس آدمی ثابت قدم رہنے والے ہوں گے تو دو سو کافروں پر غالب رہیں گے ۔\n","«حَرَضَ» کے معنی سخت بیمار ہونا ، لاغر ہونا اورمرنے کے قریب ہوجانا ہے ۔","اُبھار","حرض","4:84-8:65-12:85",3
135,22,"ا","حَضَّ ۔ حَثَّ","«حَضَّ ۔ حَثَّ» کسی کو کسی کام پر ابھار کر کام کی رفتار تیز کرنا ۔ اچھے کام کی ترغیب دینا ۔ اصل میں «حَضَّ» اور «حَثَّ» دونوں الفاظ ابھارنے کے لیے استعمال ہوتے ہیں ۔ حَثَّ کا لفظ کسی (سواری وغیرہ) کو چلانے اور ہانکنے کے لیے آتا ہے اور «حَضَّ» باقی سب کاموں میں اس کا استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یُغۡشِی الَّیۡلَ النَّہَارَ یَطۡلُبُہٗ حَثِیۡثًا» ( 7/54 )\nترجمہ : وہی رات کو دن کا لباس پہناتا ہے ۔ کہ وہ اس کے پیچھے دوڑتا چلا آتا ہے ۔\nاور «حَضَّ» دوسری باتوں پر ابھارنے یا ترغیب دینے کے لیے آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَرَءَیۡتَ  الَّذِیۡ یُکَذِّبُ بِالدِّیۡنِ فَذٰلِکَ الَّذِیۡ یَدُعُّ  الۡیَتِیۡمَ وَ لَا یَحُضُّ عَلٰی طَعَامِ الۡمِسۡکِیۡنِ» ( 107/1،2،3 )\nترجمہ : بھلا تم نے اس شخص کو دیکھا جو روز جزا کو جھٹلاتا ہے ۔ یہ وہی ( بدبخت ) ہے جو یتیم کو دھکے دیتا ہے اور فقیر کو کھانا کھلانے کے لیے ( لوگوں کو ) ترغیب نہیں دیتا ۔"," «حَضَّ» سواری کے سوا باقی اچھے کاموں کی ترغیب کے لیے  کے لیے استعمال ہوتا ہے ۔\n«حَثَّ» سواری وغیرہ کی رفتار تیز کرنے کے لیے  کے لیے استعمال ہوتا ہے ۔","اُبھار","حض ۔ حث","7:54-18:56-69:34-107:3",4
136,22,"ا","سَمْک","«سَمْک» بمعنی بلند کرنا ۔ موٹا کرنا اور «سَمْک» بمعنی چھت یا چھت کی موٹائی  کے لئے بھی  استعمال ہوتا ہے  ۔ نیز ہر اونچی اور موٹی چیز کا قد و قامت (منجد) اور «سَنَامٌ سَامِکٌ» بمعنی اونٹ کا اونچا کوہان ۔ (م ق)\nمثلاً :  قرآن کریم میں ہے :\n«ءَاَنۡتُمۡ اَشَدُّ خَلۡقًا  اَمِ  السَّمَآءُ ؕ بَنٰہَا رَفَعَ سَمۡکَہَا فَسَوّٰىہَا» ( 79/27،28 )\nترجمہ : کیا تمہارا بنانا مشکل ہے یا آسمان کا ۔ اللہ نے آسمان کو بنایا ۔ پھر اونچا کیا اس کا ابھار ، پھر اسے برابر کیا (عثمانیؒ)","«سَمْک» کسی چیز کو موٹا کرنا اور بلند کرنا جیسے چھت کی اونچائی اور موٹائی ۔","اُبھار","سمک","79:28",1
137,22,"ا","کَعَبْ","«کَعَبْ» بمعنی ٹخنہ ۔ ہر وہ ابھار جو ٹخنہ کی طرح ہواس پر بھی کعب کا اطلاق ہوتا ہے ۔ «کَعَبَتِ الْجَارِیَۃ» بمعنی لڑکی کے پستان ابھرے اور بڑے ہوئے ۔ «کُعَب» بمعنی عورت کے ابھرے ہوئے پستان اور «کاعِب» اس عورت کو کہتے ہیں جس کے پستان اُٹھے ہوئے ہوں ۔ جمع اسکی  «کَوَاعِب» ہے  بمعنی نوجوان عورتیں (مف منجد)\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ  لِلۡمُتَّقِیۡنَ مَفَازًا حَدَآئِقَ وَ  اَعۡنَابًا وَّکَوَاعِبَ  اَتۡرَابًا» ( 78/31،32،33 )\nترجمہ : بیشک پرہیزگاروں کے لیے کامیابی ہے (یعنی) باغ اور انگور اور نوجوان ہم عمر عورتیں ۔\nاگرابھار کا پھیلاؤ اور بلندی تقریبًا برابر ہوں تو یہ «کَعَب» اور «نَجَد» ہے صرف کمیت یعنی مقدار کا فرق ہے ۔ اگر پھیلاؤ زیادہ اور بلندی کم ہو تو یہ «حَدْب» ہے اوراگر پھیلاؤ کم اور اونچائی زیادہ ہو تو یہ «سَمک» ہے اور اگر بلندی اور پھیلاؤ میں کوئی ترتیب اور تناسب نہ ہو تو یہ «اَمْت» ہے ۔","«کَعَبْ» ابھری ہوئی ہڈی کو کہتے ہیں ۔ قرآن کریم میں یہ لفظ ٹخنے کے لیے اور ابھرے ہوئے سینے والی  حور کے لئے استعمال ہوا ہے ۔","اُبھار","کعب","78:33",1
138,22,"ا","نَجْد","«نَجْد» سخت اوراونچی زمین جس میں درخت وغیرہ نہ ہوں کعب کی طرح بلند اور بڑا ٹیلہ ۔ اور بمعنی چھوٹا پہاڑ اور بمعنی گھاٹی اوراس پرچڑھنے اوراترنے کا راستہ  کے لیے بھی استعمال ہوتا ہے ۔ نیزعورت کے پستان کے معنی بھی پائے جاتے ہیں (منجد ۔ م ق) اور «نَجْدَیْن» کا لفظ محاورتاً عورت کے دو پستانوں ، صدق و کذب اور خوبصورت  و  بد صورت  کے تقابل کے لیے بھی استعمال ہوتا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ ہَدَیۡنٰہُ  النَّجۡدَیۡنِ . فَلَا  اقۡتَحَمَ الۡعَقَبَۃَ» ( 90/10،11 )\nترجمہ : اور انسان کو (خیر و شر) کے دونوں راستے بھی دکھا دیے مگر وہ گھاٹی پر سے ہو کر نہ گزرا ۔\nاس میں «نَجْدَیْن» سے بعض مفسرین دونوں پستان مراد لیتے ہیں جنکی طرف بچہ پیدا ہوتے ہی فطری طور پر لپکتا ہے اور پرورش پاتا ہے ۔","«نَجْد» ایسی زمین کے لئے استعمال ہوتا ہے جو سخت اور اونچی  ہو اور اس میں کوئی درخت وغیرہ نہ ہوں ۔","اُبھار","نجد","90:10",1
139,23,"ا","اَحَلَّ","«اَحَلَّ» کسی دوسرے کو کسی مقام پر اتارنا ۔ اور یہ اترنے والے کے کسی عمل کے نتیجہ پر ہوتا ہے ۔ اور خیر و شر دونوں صورتوں میں آتا ہے ۔\nمثلاً : خیر کے لیے  قرآن کریم میں ہے :\n«وَ قَالُوا الۡحَمۡدُ لِلّٰہِ الَّذِیۡۤ  اَذۡہَبَ عَنَّا الۡحَزَنَ ؕ اِنَّ  رَبَّنَا لَغَفُوۡرٌ  شَکُوۡرٌ ۔ الَّذِیۡۤ  اَحَلَّنَا  دَارَ الۡمُقَامَۃِ  مِنۡ فَضۡلِہٖ» ( 35/34،35 )\nترجمہ : وہ کہیں گے ، خدا کا شکر ہے کہ جس نے ہم سے غم دور کیا ۔ بے شک ہمارا پروردگار بخشنے والا قدردان ہے ۔ جس نے ہم کو اپنے فضل سے ہمیشہ کے لیے اپنے گھر میں اتارا ۔\nاور شر کے لیے قرآن کریم میں ہے  :\n«اَلَمۡ تَرَ اِلَی الَّذِیۡنَ بَدَّلُوۡا نِعۡمَتَ اللّٰہِ کُفۡرًا وَّاَحَلُّوۡا قَوۡمَہُمۡ دَارَالۡبَوَارِ» ( 14/28 )\nترجمہ : کیا تم نے ان لوگوں کو نہیں دیکھا جنہوں نے خدا کے احسان کو ناشکری سے بدل دیا اور اپنی قوم کو تباہی کے گھر میں جا اتارا ۔","«اَحَلَّ» میں اتارنے کا عمل اترنے والے کے کسی اچھے یا برے  کام کے نتیجے میں ہوتا ہے ۔","اتارنا ","احل","14:28-35:35",2
140,23,"ا","اَنْزَلَ ، نَزَّل","«اَنْزَلَ ، نَزَّل» بعض علماء کا خیال ہے کہ «اَنْزَلَ» کا لفظ بلندی سے  کسی چیز کو ایک ہی بار میں مکمل اتارنے کیلئے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّاۤ  اَنۡزَلۡنٰہُ  فِیۡ  لَیۡلَۃِ  الۡقَدۡرِ» ( 97/1 )\nترجمہ : ہم نے قرآن کریم کو لیلۃ القدر میں اتارا ۔\nاور یہ تو ظاہر ہے کہ قرآن کریم ایک ساتھ مکمل نازل نہیں ہوا بلکہ تھوڑا تھوڑا کر کے ہوا ہے ۔ اس کی تشریح  یہ ہے کہ قرآن کریم لیلۃ القدرکی رات کو آسمان دنیا پر  توایک ساتھ مکمل نازل ہو گیا تھا ۔ بعد میں حسبِ موقع و ضرورت بذریعہ وحی  تھوڑا تھوڑا نازل ہوتا رہا ۔ دوسری تشریح  یہ ہے جسے ( فتح محمد صاحبؒ ) نے اس آیت کے ترجمہ میں بیان کیا ہے ۔\nترجمہ : ہم نے اس ( قرآن ) کو شب قدر میں نازل (کرنا شروع ) کیا ۔‘‘ اور تنزیل سے مراد کسی چیز کو وقتاً فوقتاً  تھوڑا تھوڑا یا حسبِ ضرورت اتارنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«تَبٰرَکَ الَّذِیۡ نَزَّلَ الۡفُرۡقَانَ عَلٰی عَبۡدِہٖ» ( 25/1 )\nترجمہ : وہ خدائے عزوجل بہت ہی بابرکت ہے جس نے اپنے بندے پر قرآن نازل فرمایا ۔\nچنانچہ امام راغب  کابھی یہی خیال ہے فرماتے ہیں ۔ ’’ ان دونوں میں معنوی فرق یہ ہے کہ تنزیل کے معنی ایک چیز کو وقتاً فوقتاً  تھوڑا تھوڑا اورالگ الگ کرکے نازل کرنے کے ہوتے ہیں اور انزال کا لفظ عام ہے جو ایک ہی دفعہ مکمل طور پر کسی چیز کو نازل کرنے پر بھی بولا جاتا ہے (مف) گویا امام موصوف کے نزدیک تنزیل کا لفظ تدریج کے لیے اور انزال کا تدریج اور یکبارگی اتارنے دونوں کیلئے آتا ہے لیکن قرآن اس کی تائید نہیں کرتا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ قَالَ الَّذِیۡنَ کَفَرُوۡا لَوۡ لَا نُزِّلَ عَلَیۡہِ الۡقُرۡاٰنُ جُمۡلَۃً  وَّاحِدَۃً» ( 25/33 )\nترجمہ : اور کافر کہتے ہیں کہ اس پر قرآن یکبارگی کیوں نہیں اتارا گیا ؟\nیہاں یکبارگی کے ساتھ «تنزیل» کا لفظ استعمال ہوا ہے ۔\nاور حقیقت یہ ہے کہ دونوں لفظ اس قدر قریب المعنیٰ ہیں کہ ایک کی جگہ دوسرا بلاتکلف استعمال ہو سکتا ہے صرف الفاظ کی بندش اور جملہ کی وضاحت کے لحاظ سے کوئی بھی ایک لفظ قرآن کریم نے استعمال کر لیا ہے ۔","«اِنْزَال» اور «تَنْزِیْل»  کسی چیز کو نیچے اتارنے کے لیےاستعمال ہوتے  ہیں ، انزال ایک بار میں ہی مکمل اتارنا ، اور تنزیل محض اتارنے کے لیے چاہے ایک بار ہو یا تھوڑا تھوڑا  ۔","اتارنا ","انزل ، نزل","2:4-2:22-2:23-2:41-2:57-2:59-2:90-2:91-2:97-2:99-2:102-2:105-2:136-2:159-2:164-2:170-2:174-2:176-2:185-2:213-2:231-2:285-3:3-3:4-3:7-3:53-3:65-3:72-3:84-3:93-3:124-3:151-3:154-3:199-4:47-4:60-4:61-4:105-4:113-4:136-4:140-4:153-4:162-4:166-4:174-5:44-5:45-5:47-5:48-5:49-5:59-5:64-5:66-5:67-5:68-5:81-5:83-5:101-5:104-5:112-5:114-5:115-6:7-6:8-6:37-6:81-6:91-6:92-6:93-6:99-6:111-6:114-6:155-6:156-6:157-7:2-7:3-7:26-7:33-7:57-7:71-7:157-7:160-7:196-8:11-8:41-9:26-9:40-9:64-9:86-9:97-9:124-9:127-10:20-10:24-10:59-10:94-11:12-11:14-12:2-12:40-13:1-13:7-13:17-13:19-13:27-13:36-13:37-14:1-14:32-15:6-15:8-15:9-15:21-15:22-15:90-16:2-16:10-16:24-16:30-16:44-16:64-16:65-16:89-16:101-16:102-17:82-17:93-17:95-17:102-17:105-17:106-18:1-18:45-19:64-20:2-20:53-20:80-20:113-21:10-21:50-22:5-22:16-22:63-22:71-23:18-23:24-23:29-24:1-24:34-24:43-24:46-25:1-25:6-25:7-25:21-25:25-25:32-25:48-26:4-26:198-27:60-28:24-28:87-29:34-29:46-29:47-29:50-29:51-29:63-30:24-30:35-30:49-31:10-31:21-31:34-33:26-34:6-35:27-36:15-36:28-38:8-38:29-39:2-39:6-39:21-39:23-39:41-39:55-40:13-41:14-41:39-42:15-42:17-42:27-42:28-43:11-43:31-44:3-45:5-46:30-47:2-47:9-47:20-47:26-48:4-48:18-48:26-50:9-53:23-56:69-57:9-57:25-58:5-59:21-64:8-65:5-65:10-67:9-76:23-78:14-97:1",222
141,23,"ا","حَلَّ","«حَلَّ» کے بنیادی معنی ’’ گِرہ کھولنا ‘‘ ہے اور اس کی ضد «عَقَدَ» یعنی گِرہ باندھنا ہے ۔ «اَرْبابِ حَلّ وَ عَقْد» عام فہم لفظ ہے بمعنی صاحبانِ بست و کشاد ۔ یعنی سامان باندھنے اور کھولنے کی یہ کیفیت ہوتی ہے کہ مسافر سامان باندھ کر سفر پر جاتا ہے اور جہاں ٹہرنا ہوتا ہے تو سامان کھول دیتا ہے ۔ لہذا «حَلَّ» کا لفظ ٹہرنے اور اترنے کے مفہوم میں بھی استعمال ہونے لگا (م ل) اور جس طرح مسافر کسی جگہ  ٹہر کر سامان کھولتا ہے اسی طرح «حَلَّ» کا لفظ کسی کام کے نتیجہ کے طور پر بھی آتا ہے ۔ کہا جاتا ہے «مَنْ جَرَّبَ الْمُجَرَّبَ حَلَّتْ بِہٖ النَّدَامَۃ» یعنی جو آزمائے ہوئے کو آزمائے اس پر ندامت اترتی ہے ۔\nمثلاً :  قرآن کریم میں ہے :\n«مَنۡ یَّاۡتِیۡہِ عَذَابٌ یُّخۡزِیۡہِ وَ یَحِلُّ عَلَیۡہِ عَذَابٌ مُّقِیۡمٌ» ( 39/40 )\nترجمہ : کس پر آتا ہے جو اسے رسوا کرے گا اور کس پر ہمیشہ کا عذاب نازل ہوتا ہے ؟","«حَلَّ» کسی مقام پر اترنے اور قیام کرنے کے لیےاستعمال ہوتا ہے ۔","اتارنا ","حل","11:39-14:28-20:27-20:81-20:86-35:35-39:40-90:2",8
142,23,"ا","خَلَعَ","«خَلَعَ» کے بنیادی معنی کسی ایسی چیز کوعلیحدہ کرنا ہے جو پہلے اس میں شامل ہو ۔ (م ل) لفظ خُلع میں بھی یہی مفہوم پایا جاتا ہے کہ عورت زرِ بدل دے کر خاوند سے علیحدہ ہو جاتی ہے اور طلاق واقع ہو جاتی ہے ۔\nقرآن کریم میں یہ لفظ پاؤں سے جوتے تک کو علیحدہ کرنے (اتارنے) کے لیے استعمال ہوا ہے ۔\nمثلاً :قرآن کریم میں ہے :\n«اِنِّیۡۤ  اَنَا رَبُّکَ فَاخۡلَعۡ نَعۡلَیۡکَ ۚ اِنَّکَ بِالۡوَادِ الۡمُقَدَّسِ طُوًی» ( 20/12 )\nترجمہ : (اے موسیؑ) میں تمہارا پروردگار ہوں تو اپنی جوتیاں اتار دو ۔ تم یہاں پاک میدان یعنی طوٰی میں ہو ۔\nاور خلع میں یہ عجیب نسبت ہے کہ قدیم تہذیبوں میں عورت کو پاؤں کے جوتے سے تعبیر کیا جاتا تھا ۔","«خَلَعَ» کسی ایسی چیز کوعلیحدہ کرنے کے لئے استعمال ہوتا ہے جو پہلے اس میں شامل تھی ۔","اتارنا ","خلع","20:12",1
143,23,"ا","نَزَلَ","«نَزَلَ» اسکا معروف معنی اترنا  ہے ۔ بلندی سے کسی چیز کا نیچے کی طرف آنا (مف) اور اس لفظ کا استعمال عام ہے ۔ «نُزُوْل» اسکی ضد «صَعُوْد» بھی ہے اور «عُرُوْج» بھی ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ مَا یَنۡزِلُ مِنَ السَّمَآءِ وَمَا یَعۡرُجُ فِیۡہَا» ( 57/4 )\nترجمہ : اور جو چیز آسمان سے اترتی اور جو اس کی طرف چڑھتی ہے ۔\nاور «تَنَزَّلَ بِہٖ» بھی «نَزَلَ بِہٖ» کا ہم معنی ہے ۔ اور فرشتوں اور احکامات الہی کے نزول کے لیے یہ دونوں الفاظ استعمال ہوتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«نَزَلَ بِہِ الرُّوۡحُ  الۡاَمِیۡنُ» ( 26/193 )\nترجمہ : اِسے امانت دار فرشتہ لے کر اترا ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n« تَنَزَّلُ الۡمَلٰٓئِکَۃُ وَ الرُّوۡحُ  فِیۡہَا بِاِذۡنِ رَبِّہِمۡ ۚ مِنۡ  کُلِّ  اَمۡرٍ» ( 97/4 )\nترجمہ : اس رات میں روح (الامین) اور فرشتے ہرکام کے (انتظام کے) لیے اپنے پروردگار کے حکم سے اترتے ہیں ۔\nلیکن شیطانی اِلقاء کے لیے صرف «تَنَزَّلَ بِہٖ» ہی آئے گا (مف)\nمثلاً : قرآن کریم میں ہے :\n«ہَلۡ اُنَبِّئُکُمۡ عَلٰی مَنۡ تَنَزَّلُ الشَّیٰطِیۡنُ تَنَزَّلُ عَلٰی کُلِّ اَفَّاکٍ اَثِیۡمٍ» ( 26/221،222 )\nترجمہ : میں تمہیں بتاؤں کہ شیطان کس پر اترتے ہیں ؟ وہ ہر جھوٹے گنہگار پر اترتے ہیں ۔","«نَزَلَ» کا لفظ عام ہے ۔ «تَنَزُّل» وحی و احکامات الہی اور شیطانی القاء وغیرہ کے  لئے استعمال ہوتا ہے ۔","اتارنا ","نزل","17:105-26:193-26:210-26:221-26:222-34:2-37:177-41:30-57:4-57:16-65:12-97:4",12
144,23,"ا","ھَبَطَ","«ھَبَطَ» کسی چیز کاغصہ اورمجبوری کی حالت میں نیچے اترآنا یا گرنا یا نکلنا جیسے پتھر بلندی گرتا ہے (مف) بے اختیارہوکرنکلنا، اپنے مرتبہ سے کمترہونا اور بلندی سے پستی کی طرف جانا ، سب اس مفہوم میں شامل ہے ۔ اب ان کی مثالیں ملاحظہ فرما لیجئے :\n(1) کسی سواری سے نیچے اترنا کے لیے :\nارشاد باری تعالیٰ ہے :\n«قِیۡلَ یٰنُوۡحُ اہۡبِطۡ بِسَلٰمٍ مِّنَّا وَ بَرَکٰتٍ عَلَیۡکَ» ( 11/48 )\nترجمہ : حکم ہوا کہ نوح ! ہماری طرف سے سلامتی اور برکتوں کے ساتھ جو تم پر ( نازل کی گئی ہیں ) اتر آؤ ۔\n(2) کسی چیز کا بےچینی اور خوف سے نیچے اترنا :\nارشاد باری تعالیٰ ہے :\n«وَ اِنَّ مِنۡہَا لَمَا یَہۡبِطُ مِنۡ خَشۡیَۃِ اللّٰہِ» ( 2/74 )\nترجمہ : اور ( پتھروں میں سے ) کچھ ایسے ہیں کہ خدا کے خوف سے گر پڑتے ہیں ۔\n(3) مرتبہ سے کمتر ، یا حقیر) ہو کر نکلنے کے لیے :\nارشاد باری تعالیٰ ہے :\n«فَاَزَلَّہُمَا الشَّیۡطٰنُ عَنۡہَا فَاَخۡرَجَہُمَا مِمَّا کَانَا فِیۡہِ ۪ وَ قُلۡنَا اہۡبِطُوۡا بَعۡضُکُمۡ لِبَعۡضٍ عَدُوٌّ» ( 2/36 )\nترجمہ : پھر شیطان نے ان دونوں ( آدم و حوا ) کو وہاں سے پھسلا دیا اور جس ( عیش و نشاط ) میں تھے ۔ اس سے ان کو نکلوا دیا ۔ تب ہم نے حکم دیا کہ یہاں سے نکل جاؤ تم ایک دوسرے کے دشمن ہو ۔\nاس مفہوم کو ایک شاعر نے ان الفاط میں ادا کیا ہے :\nنکلنا خلد سے آدم کا سنتے آئے ہیں لیکن\nبہت بے آبرو ہو کر تیرے کوچہ سے ہم نکلے !","«ھَبَطَ» کسی جگہ سے غصہ اور بے بسی کی حالت میں اترنے ، گرنے یا نکلنے کے لیے استعمال ہوتا ہے ۔","اتارنا ","ھبط","2:36-2:38-2:61-2:74-7:13-7:24-11:48-20:123",8
145,23,"ا","وَضَعَ","«وَضَعَ» کے بنیادی معنی نیچے رکھ دینا کے ہیں (مف) لفظ وضع حمل اور بوجھ اتارنے کے معنی میں بھی استعمال ہوتا ہے اور حمل میں بوجھ ہی اتارا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ وَضَعۡنَا عَنۡکَ وِزۡرَکَ الَّذِیۡۤ اَنۡقَضَ ظَہۡرَکَ» ( 94/2،3 )\nترجمہ : اور ہم نے آپ سے وہ بوجھ اتار دیا جو آپ کی کمر توڑ رہا تھا ۔\nپھر یہ لفظ اتارنے کے لیے عام ہونے لگا ۔\nمثلاً : قرآن کریم میں ہے :\n«حِیۡنَ تَضَعُوۡنَ ثِیَابَکُمۡ مِّنَ الظَّہِیۡرَۃِ» ( 24/58 )\nترجمہ : اور جب تم دوپہر کو اپنے کپڑے اتارتے ہو ۔","«وَضَعَ» کسی چیز کو اتار کر نیچے رکھنے کے لیے استعمال ہوتا ہے ۔","اتارنا ","وضع","3:36-18:49-39:69-46:15-55:7-55:10-94:2",7
146,24,"ت","اِخْتَالَ","«خَیْل» ابن فارس کے نزدیک «خَیْل» کے معنی «یَدُلُّ عَلیٰ حَرَکَۃِ فِی تَلَوُّنٍ» ( م ۔ ل ) یعنی وہ حرکت جو ہر آن ہر گھڑی نیا رنگ بدلتی ہے ۔ «تَخَیُّلْ» کے معنی  کسی چیز کا تصور کرنا ، تکبر کرنا اور «اِخْتَال» بمعنی اکڑ کر چلنا اور تکبر کی چال چلنا ۔ (منجد) گویا ایسے شخص کا دماغ عام آدمیوں سے اونچی سطح پر ہوتا ہے اور یہ «مَرَحَ» سے اگلا درجہ ہے ۔","«اِخْتَالَ» متکبرانہ چال چلنا اور دوسروں کو حقیر سمجھنا ۔","تکبر","اختال","4:36-31:18-57:23",3
147,24,"ت","اَشَرَ : اَشِرٌ","«اَشَرَ» ایسے خود پسند  شخص کو کہتے ہیں جو خود اپنی بڑائیاں کرتا ہو اور زبان سے ڈھینگیں مارتا ہو ۔ امام راغب «اَلْاَشَر» کے معنی بہت زیادہ اترانا بتلاتے ہیں (مف) گویا یہ «مَرَحَ» اور «اِخْتَال» سے بھی اگلا درجہ ہے ۔\nمثلاً :قرآن کریم میں ہے :\n«سَیَعۡلَمُوۡنَ غَدًا مَّنِ الۡکَذَّابُ الۡاَشِرُ» ( 54/26 )\nترجمہ : ان کو کل ہی معلوم ہو جائے گا کہ کون جھوٹا خود پسند ہے ۔","«اَشَرَ» خود پسند اور  ڈھینگیں مارنے والے شخص کے لئے استعمال ہوتا ہے ۔","تکبر","اشر : اشر","54:25-54:26",2
148,24,"ت","بَطَرَ","«بَطَرَ» نعمتوں کی فراوانی کی وجہ سے بہک جانا اور بقول امام راغب «بَطَر» ایک دہشت ہے جو خوشحالی کے غلط استعمال ، حق نعمت میں کوتاہی اور نعمت کے غلط استعمال سے انسان کو لاحق ہوتی ہے ۔ (مف) اور ابن فارس کے نزدیک «بَطَر» کے اصل معنی پھاڑنا کے ہیں ۔ یعنی جیسے نعمت کی فراوانی نے کسی کے دیدے پھاڑ دیے ہوں اور وہ کسی کو خاطر میں نہیں لاتا گویا «بَطَر» کے مفہوم میں بھی نعمت کی فراوانی اور نا شکری اورغلط استعمال موجود ہے اور یہ «فَرِحَ» سے اگلا درجہ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ کَمۡ  اَہۡلَکۡنَا مِنۡ قَرۡیَۃٍۭ  بَطِرَتۡ مَعِیۡشَتَہَا» ( 28/58 )\nترجمہ : اور ہم نے بہت سی بستیوں کو ہلاک کر ڈالا جو اپنی فراخیٔ معیشت پر اترا رہے تھے ۔","«بَطَرَ» اللہ کی نعمت کی ناشکری کرنا اور ان کا غلط استعمال کرنا ۔","تکبر","بطر","8:47-28:58",2
149,24,"ت","تَکَبَّرَ","«تَکَبَّرَ» یہ فخر کا سب سے آخری درجہ ہے جس میں انسان عُجب یعنی غرور، تکبر، گھمنڈ ، خود بینی ، خود پسندی کا شکار ہوجاتا ہے اور خود کو دوسروں سے بہتر اورغلطی سے پاک سمجھتا ہے ۔ اور خود پسندی کی اس حد تک پہنچ جاتا ہے کہ دوسروں کو حقیر سمجھنے لگتا ہے اور حق بات کو قبول کرنے سے انکار کر دیتا ہے جیسا کہ حدیث میں مروی ہے : «الْكِبَرُ بَطَرُ الْحَقِّ وَغَمْطُ النَّاس» ( الادب المفرد للبخاری ) ترجمہ : ’’ تکبر یہ ہے کہ تو حق بات ٹھکرائے اور لوگوں کو حقیر سمجھے ۔\nمثلاً :قرآن کریم میں ہے :\n«قَالَ فَاہۡبِطۡ مِنۡہَا فَمَا یَکُوۡنُ لَکَ اَنۡ تَتَکَبَّرَ فِیۡہَا» ( 7/13 )\nترجمہ : اللہ تعالیٰ نے شیطان سے فرمایا تو جنت سے نکل جا تجھے شایاں نہیہں کہ تو یہاں غرور کرے ۔","«تَکَبَّرَ» گھمنڈ کا آخری درجہ حق بات کو رد کر دینا اور لوگوں کو حقیر سمجھنا ۔","تکبر","تکبر","2:34-2:87-2:185-4:172-4:173-5:82-6:93-7:13-6:36-7:40-7:48-7:75-7:76-7:88-7:133-7:146-7:206-10:75-14:21-16:22-16:23-16:29-16:49-21:19-22:37-23:46-23:67-25:21-28:39-29:39-31:7-32:15-34:31-34:32-34:33-37:35-38:74-38:75-39:59-39:60-39:72-40:27-40:35-40:47-40:48-40:60-40:76-41:15-41:38-45:8-45:31-46:10-46:20-59:23-63:5-71:7-74:23",57
150,24,"ت","تَمَطّٰی","«مُطَوَّ» بمعنی چلنے میں گھمنڈ ،تکبر ،غرور  سے بازو پھیلانا ، بے نیازی کا اظہار کرنا ۔ بازو پھیلا کر گھمنڈ سے تیز تیز چلنا (ف ل 178)\nمثلاً :قرآن کریم میں ہے :\n«فَلَا صَدَّقَ وَلَا صَلّٰی وَ لٰکِنۡ کَذَّبَ وَتَوَلّٰی ثُمَّ ذَہَبَ اِلٰۤی اَہۡلِہٖ یَتَمَطّٰی» ( 75/31،32،33 )\nترجمہ : تو اس ( عاقبت نا اندیش نے ) نہ تو ( کلامِ خدا کی ) تصدیق کی اور نہ نماز پڑھی بلکہ جھٹلایا اور منہ پھیر لیا ۔ پھر اپنے گھر والوں کے پاس اکڑتا ہوا چل دیا ۔","«تَمَطّٰی» گھمنڈ اور تکبر کی وجہ سے بازو پھیلا کر تیز تیز چلنا ۔","تکبر","تمطی","75:33",1
151,24,"ت","فَخَرَ","«فَخَرَ» شیخی بگھارنا یعنی اپنی بڑائی کرنا اورایسی خوبی بیان کرنا جوموجود ہی نا ہو ۔ مثلاً حسب و نسب پر اترانا یا وراثت کے مال و دولت پرشیخی بکھارنا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تُصَعِّرۡخَدَّکَ لِلنَّاسِ وَلَا تَمۡشِ فِی الۡاَرۡضِ مَرَحًا ؕ اِنَّ اللّٰہَ لَا یُحِبُّ کُلَّ مُخۡتَالٍ فَخُوۡرٍ» ( 21/18 )\nترجمہ : اور ( ازراہِ غرور ) لوگوں سے گال نہ پھلانا اور زمین میں اکڑ کر نہ چلنا کہ خدا کسی اترانے والے خود پسند کو پسند نہیں کرتا ۔\nاس آیت میں اللہ تعالیٰ نے «مَرَحَ ، اِخْتَال» اور «فَخَرَ» تینوں مذموم یعنی بری صفات کا بالترتیب ذکر فرما دیا ہے ۔","«فَخَرَ» ایسی باتوں پر اترانا جو خود میں موجود ہی نہ ہو ۔","تکبر","فخر","4:36-11:10-31:18-57:23",4
152,24,"ت","فَرِحَ","«فَرِحَ» کا استعمال دو طرح سے ہوتا ہے ۔ «فَرِحَ الْقَلْب اور فَرِحَ النَّفْس»\n«فَرِحَ الْقَلْب» سے مراد کسی نعمت پر تہ دل سے شکر گزار ہونا ہے اور یہ اچھی صفت ہے ۔\nمثلاً :قرآن کریم میں ہے :\n«قُلۡ بِفَضۡلِ اللّٰہِ وَ بِرَحۡمَتِہٖ فَبِذٰلِکَ فَلۡیَفۡرَحُوۡا ؕ ہُوَخَیۡرٌمِّمَّا یَجۡمَعُوۡنَ» ( 10/58 )\nترجمہ : آپ کہہ دیجئے کہ ( کتاب ) خدا کے فضل اور اس کی مہربانی سے ( نازل ہوئی ہے ) تو چاہیے کہ لوگ اس سے خوش ہوں اور یہ اس سے کہیں بہتر ہے جو وہ جمع کرتے ہیں ۔\nاور «فَرِحَ النَّفْس» یہ بری صفت ہے ۔ یعنی خدا کی نعمتوں کا شکریہ ادا کرنے کی بجائے اترانے لگنا اور پھولا نہ سمانا اور خوشیاں منانا ۔\nمثلاً :قرآن کریم میں ہے :\n«اِذۡ  قَالَ لَہٗ قَوۡمُہٗ لَا تَفۡرَحۡ اِنَّ اللّٰہَ لَا یُحِبُّ الۡفَرِحِیۡنَ» ( 28/76 )\nترجمہ : جب اس ( قارون ) کی قوم نے اسے کہا : اترائیے مت ۔ خدا اترانے والوں کو پسند نہیں کرتا ۔","«فَرِحَ» خوشیاں منانا ۔ اللہ کی نعمتوں کا شکر ادا کرنے کے لئے بھی استعمال ہوتا ہے اور نا شکری کرکے ان پر اترانے کے لئے بھی استعمال ہوتا ہے ۔","تکبر","فرح","3:120-3:170-3:188-6:44-9:50-9:81-10:22-10:58-11:10-13:26-13:36-23:53-27:36-28:76-30:4-30:32-30:36-40:75-40:83-42:48-57:23",21
153,24,"ت","فَرِہَ","«فَرِہَ» بمعنی خوش ہونا ۔ اکڑنا اور «فَرِہَ» بمعنی ماہر ہونا ۔ تجربہ کار  ہونا ۔ خوش ہونا ۔ ہلکا  ہونا اور «فَارِہٌ» بمعنی چست و چالاک ۔ جس کی مہارت ظاہر ہو ( منجد ) گویا «فَرِہَ» اپنے ہنر اور فن کے کمال پر خوش ہونے ، اترانے اور فخر کرنے کے لیے آتا ہے ۔\nمثلاً :قرآن کریم میں ہے :\n«وَ تَنۡحِتُوۡنَ مِنَ الۡجِبَالِ بُیُوۡتًا فٰرِہِیۡنَ» ( 26/149 )\nترجمہ : اور تکلف سے پہاڑوں میں تراش تراش کر گھر بناتے ہو ۔ ( جالندھریؒ ) ۔ فخریہ عمارتیں بناتے ہو ( مودودیؒ )","«فَرِہَ» اپنے فن کی مہارت پر اترانے کے لئے استعمال ہوتا ہے ۔","تکبر","فرہ","26:149",1
154,24,"ت","مَرَحَ","«مَرَحَ» کے معنی  خوشی سے جھومنے لگنا «شِدّۃُ الْفَرْحِ» (ف ل 170 ) ناز و ادا سے اکڑ اکڑ کرچلنا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لَا تَمۡشِ فِی الۡاَرۡضِ مَرَحًا ۚ اِنَّکَ  لَنۡ تَخۡرِقَ الۡاَرۡضَ وَ لَنۡ تَبۡلُغَ الۡجِبَالَ طُوۡلًا» ( 17/37 )\nترجمہ : اور زمین میں اکڑ اکڑ کر (اور تن کر) مت چل کہ تو نہ تو زمین کو پھاڑ سکے گا اور نہ ہی لمبا ہو کر پہاڑوں (کی چوٹی) تک پہنچ جائے گا ۔","«مَرَحَ» خوشی سے جھومنا اور ناز و ادا سے اکڑ اکڑ کر چلنا ۔ ","تکبر","مرح","17:37-31:18-40:75",3
155,25,"م","اِخْتَلَقَ","«خَلَقَ» بمعنی کوئی چیز پیدا کرنا جس کا مواد کچھ نہ کچھ پہلے موجود ہو اور اختلاق کے معنی ایسی بات جس میں کچھ تھوڑی بہت حقیقت بھی ہو تو اس میں جھوٹ سچ ملا کر اس کو ہموار ، چکنا اور ملائم بنانا (م ل) بناوٹی اور اپنی طرف سے بنائی ہوئی بات ۔ «اِخْتِرَاع» یہ لفظ جھوٹی بات کے لئے خاص ہے جسے اس طرح بیان کیا گیا ہو کہ وہ سچ معلوم ہو ۔ (فق ل 112)\nمثلاً : قرآن کریم میں ہے :\n«مَا سَمِعۡنَا بِہٰذَا فِی الۡمِلَّۃِ  الۡاٰخِرَۃِ  ۚ ۖ اِنۡ ہٰذَاۤ اِلَّا اخۡتِلَاقٌ» ( 38/7 )\nترجمہ : ( کافروں نے کہا ) ہم نے یہ بات پچھلے مذہب میں کبھی سنی ہی نہیں ۔ یہ تو بالکل بنائی ہوئی بات ہے ۔","«اِخْتَلَقَ» ایسی بات جس میں تھوڑی بہت حقیقت ہو باقی سب افسانہ ہو ایسی جھوٹی بات جو سچی معلوم ہو ۔","من گھڑت","اختلق","38:7",1
156,25,"م","اِفْتَرَاء","«اِفْتَرَاء» اس کا اصل لفظ «فَرِیَ» ہے ۔ «فَرِیَ» کے معنی جھوٹ بات کرنا اور بگاڑ پیدا کرنا ہے (م ۔ ا) ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَتَتۡ بِہٖ قَوۡمَہَا تَحۡمِلُہٗ ؕ قَالُوۡا یٰمَرۡیَمُ لَقَدۡ جِئۡتِ شَیۡئًا فَرِیًّا» ( 19/27 )\nترجمہ : پھر (مریمؑ) لائی اس کو اپنے لوگوں کے پاس گود میں تو وہ اسے کہنے لگے اے مریمؑ ! تو لائی یہ چیز طوفان کی (عثمانیؒ)\nاس آیت سے یہ مراد ہے کہ مر یم تو نے یہ کیا غضب کر دیا اور فساد بپا کر دیا ہے ۔\nاور «اِفْترٰی» ایسے جھوٹ یا الزام کو کہتے ہیں جو فساد اور بگاڑ کی خاطر سوچ سمجھ کر بنایا جائے ، بہتان لگانا ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ کَادُوۡا لَیَفۡتِنُوۡنَکَ عَنِ الَّذِیۡۤ اَوۡحَیۡنَاۤ اِلَیۡکَ لِتَفۡتَرِیَ عَلَیۡنَا غَیۡرَہٗ» ( 17/73 )\nترجمہ : اور اے پیغمبر ! جو وحی ہم نے تمہارے طرف بھیجی ہے ، قریب تھا یہ (کافر) لوگ تم کو اس سے بچلا دیں تاکہ تم اس کے سوا دوسری باتیں ہماری نسبت بنا لو ۔","«اِفْتَرَاء» فساد اور بگاڑ پیدا کرنے کی نیت سے جھوٹ بولنا ۔","من گھڑت","افتراء","3:24-3:94-4:48-4:50-5:103-6:21-6:24-6:93-6:112-6:137-6:138-6:140-6:144-7:37-7:53-7:89-7:152-10:17-10:30-10:37-10:38-10:59-10:60-10:69-11:13-11:18-11:21-11:35-11:50-12:111-16:56-16:87-16:101-16:105-16:116-17:73-18:15-20:61-21:5-23:38-25:4-28:36-28:75-29:13-29:68-32:3-34:8-34:43-42:24-46:8-46:28-60:12-61:7",53
157,25,"م","تَقَوَّل","«تَقَوَّل» قول سے ہے منہ سے نکلی ہوئی ہر بات کو قول کہتے ہیں ۔ اور بعض دفعہ قول کا اطلاق ایسی بات پر بھی ہوتا ہے جو ابھی دل میں ہی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یَقُوۡلُوۡنَ فِیۡۤ اَنۡفُسِہِمۡ لَوۡلَا یُعَذِّبُنَا اللّٰہُ» ( 58/8 )\nترجمہ : اور اپنے دل میں کہتے ہیں کہ ( اگر یہ واقعی پیغمبر ہیں تو ) جو کچھ ہم کہتے ہیں خدا ہمیں اس کی سزا کیوں نہیں دیتا ؟\nاور «تَقَوَّل» کے معنی جھوٹی بات کو بیان کرنا اور پھر اسے کسی دوسرے کے سر تھوپ دینا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَ لَوۡ تَقَوَّلَ عَلَیۡنَا بَعۡضَ الۡاَقَاوِیۡلِ . لَاَخَذۡنَا مِنۡہُ بِالۡیَمِیۡنِ ثُمَّ لَقَطَعۡنَا مِنۡہُ الۡوَتِیۡنَ» ( 69/44،45،46 )\nترجمہ : اگر یہ پیغمبر ہماری نسبت کوئی بات جھوٹ بنا لاتے تو ہم ان کا داہنا ہاتھ پکڑ لیتے پھر ان کی رگ گردن کاٹ ڈالتے ۔","«تَقَوَّل» خود سے جھوٹی  بات بنانا اور پھر اسے کسی دوسرے پر تھوپ دینا ۔","من گھڑت","تقول","2:80-2:104-2:140-2:154-2:169-6:93-6:156-6:157-7:28-7:33-7:172-7:173-10:68-10:77-16:116-17:40-20:94-24:15-39:56-39:57-39:58-52:33-61:2-61:3-69:44-72:5",26
158,25,"م","خَرَصَ","«خَرَصَ» صرف گمان و خیال اور اندازے سے کام لینا ۔ «خَرَصَ النَّخْلَۃَ» سے مراد یہ ہے کہ محض گمان سے اندازہ لگانا کہ اس کھجور کے درخت پرکتنا پھل ہوگا اور «خَرَّاص» اس شخص کو کہتے ہیں جو اکثر کاموں میں محض اندازہ اور گمان سے کام لیتا ہو ۔ (منجد) ایسا آدمی عموماً جھوٹا اور ناقابل اعتماد ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قُتِلَ الۡخَرّٰصُوۡنَ» ( 51/10،11،12 )\nترجمہ : اٹکل دوڑانے والے ہلاک ہوں ، جو بے خبری میں پھولے ہوئے ہیں ۔ پوچھتے ہیں کہ جزا کا دن کب ہو گا ؟","«خَرَصَ» صرف گمان اور اندازے سے کام لینا جس میں حقیقت کو دخل نہ ہو ۔","من گھڑت","خرص","6:116-6:148-10:66-43:20",4
159,26,"ب","اَثَارَ","«ثَوْر ، ثَار» کے معنی کسی چیز کا اوپر اٹھنا ہیں (م ل) اور «اَثَارَ» کا لفظ اوپر اٹھانے کے لیے آتا ہے ۔ اگر  یہ لفظ  زمین کے لئے استعمال ہوتو اس کے معنی ہل چلانا ہوتا ہے کہ اس سے زمین کو اوپر اٹھاتے ہیں ۔ اور عام طور پر اس لفظ کا استعمال ہواؤں اور دریاؤں کو اوپر اٹھانے کے لیے ہوتا ہے ۔\nمثلاً :قرآن کریم میں ہے :\n«اَللّٰہُ  الَّذِیۡ یُرۡسِلُ الرِّیٰحَ فَتُثِیۡرُ  سَحَابًا فَیَبۡسُطُہٗ فِی السَّمَآءِ کَیۡفَ یَشَآءُ وَ یَجۡعَلُہٗ کِسَفًا» ( 30/48 )\nترجمہ : خدا ہی تو ہے جو ہواؤں کو چلاتا ہے تو وہ بادلوں کو اٹھاتی ہیں ، پھر خدا اس کو جس طرح چاہتا ہے آسمان میں پھیلا دیتا ہے اور تہ بتہ کر دیتا ہے ۔","«اَثَار» ہواؤں کا بادلوں کو اٹھانا ۔","بوجھ","اثار","30:48-35:9",2
160,26,"ب","اَقَلَّ","«اَقَلَّ» بنیادی طور پر دو معنوں میں استعمال ہوتا ہے ۔ (1) کم ہونا (2) بلند ہونا اور «اَقَلَّ» بمعنی کسی چیز کو اٹھانا اور بلند کرنا (منجد) اور «اَقَلَّ ، اَثَارَ» سے زیادہ قوی   اور بہتر ہے ۔ یعنی ہواؤں کا بارش سے لدے ہوئے بوجھل بادلوں کو معمولی اور حقیر چیز سمجھ کر اٹھائے پھرنا (مف) چنانچہ درج ذیل آیت بھی اس بات کی وضاحت کر رہی ہے :\nمثلاً :قرآن کریم میں ہے :\n«وَہُوَالَّذِیۡ یُرۡسِلُ الرِّیٰحَ بُشۡرًۢا بَیۡنَ یَدَیۡ رَحۡمَتِہٖ ؕ حَتّٰۤی اِذَاۤ اَقَلَّتۡ سَحَابًا ثِقَالًا سُقۡنٰہُ لِبَلَدٍ مَّیِّتٍ» ( 7/57 )\nترجمہ : اور وہی تو ہے جو اپنی رحمت ( یعنی مینہ ) سے پہلے ہواؤں کو خوشخبری بنا کر بھیجتا ہے ۔ یہاں تک کہ جب وہ بھاری بھاری بادلوں کو اٹھا لاتی ہے تو ہم اس کو ایک مری ہوئی بستی کی طرف ہانک دیتے ہیں ۔","«اَقَلَّ» ہواؤں کا بادلوں کے بوجھ کو معمولی اور ہلکا سمجھ کر اٹھالینا ۔","بوجھ","اقل","7:57-9:38",2
161,26,"ب","اِلْتَقَطَ","«لَقَطَ» کے معنی زمین سے کسی چیز کا اٹھانا اور لُقْطَۃ اس چیز کو کہتے ہیں جو زمین پرگری پڑی ہو اور اس کا مالک معلوم نہ ہو (منجد) اسی سے «اِلْتَقَطَ» نکلا ہے جس کے معنی ہیں زمین سے کسی ایسی گری پڑی چیز کا اٹھانا جس کے مالک کا علم نہ ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَ قَآئِلٌ مِّنۡہُمۡ لَا تَقۡتُلُوۡا یُوۡسُفَ وَاَلۡقُوۡہُ فِیۡ غَیٰبَتِ الۡجُبِّ یَلۡتَقِطۡہُ بَعۡضُ السَّیَّارَۃِ» ( 12/10 )\nترجمہ : ( یوسف ؑ کے بھائیوں میں سے ) ایک کہنے والے نے کہا کہ یوسف کو جان سے نہ مارو ۔ کسی گہرے کنویں میں ڈال دو ۔ کوئی راہ گیر اسے اٹھا لے جائے گا ۔","«اِلْتَقَطَ» کسی گری پڑی چیز کو اٹھانے کے لیے استعمال ہوتا ہے ۔","بوجھ","التقط","12:10-28:8",2
162,26,"ب","اَنْشَرَ","«نَشَرَ» کے بنیادی معنی پھیلانا ہیں اور اس کی ضد «طَوَی» یعنی لپیٹنا ہے ۔ «نَشَرْتُ الْکِتَابَ» یعنی میں نے کتاب کو کھولا یا پھیلایا اور «طَوَیْتُہ» کے معنی کتاب کو لپیٹ دیا یا بند کر دیا (م ل)\nمثلاً :قرآن کریم میں ہے :\n«وَاِذَا الصُّحُفُ نُشِرَتۡ» ( 81/10 )\nترجمہ : اور جب اعمال کے دفتر کھولے جائیں گے ۔\nاور «نَشِرَ الْمَیِّتُ نشُوْرًا»  یعنی میت کا دوبارہ زندہ ہونا (مف) اور «وَاِلَیْہِ النُّشُوْر» کے معنی ہیں اللہ کے پاس ہی قبروں سے نکل کر جانا ہے ۔ اس میں زندہ ہونا ، اٹھنا اور پھیلنا سب معنی پائے جاتے ہیں ۔ اسی سے «اَنْشَرَ» فعل متعدی  ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ  اَمَاتَہٗ  فَاَقۡبَرَہٗ ثُمَّ  اِذَا شَآءَ  اَنۡشَرَہٗ» ( 80/21،22 )\nترجمہ : پھر اللہ نے انسان کو موت دی پھر اسے قبر میں دفن کرایا پھر جب چاہے گا اسے اٹھا کھڑا کرے گا ۔\nنوٹ : (فعل متعدی : اس فعل کو کہتے ہیں جس کو پورا کرنے کے لیے فاعل کے علاوہ مفعول کی بھی ضرورت ہو)","«اَنْشَرَ» روز قیامت مُردوں کو قبروں سے اٹھا کر پھیلانے کے معنی میں استعمال ہوتا ہے ۔ ","بوجھ","انشر","18:16-21:21-42:28-43:11-44:35-74:52-77:3-80:22-81:10-94:1",10
163,26,"ب","اَنْشَزَ","«نَشَزَ» کے بنیادی معنی بلندی ، اٹھان ، ابھار کے ہیں ۔ خصوصًا جب کسی چیز میں یہ اٹھان حرکت  اور ہیجان ، جوش ، تیزی اور شدت کا سبب  ہو ۔ (غ ق) «نَشْزَ الرَّجُل» کا معنی بیٹھے ہوئے آدمی کا اٹھ کھڑا ہونا ہے (منجد) اسی سے «اَنْشَزَ» فعل متعدی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ انۡظُرۡاِلٰی حِمَارِکَ وَ لِنَجۡعَلَکَ اٰیَۃً لِّلنَّاسِ وَ انۡظُرۡاِلَی الۡعِظَامِ کَیۡفَ نُنۡشِزُہَا ثُمَّ نَکۡسُوۡہَا لَحۡمًا» ( 2/259 )\nترجمہ : اور اپنے (ہمراہ) گدھے کو دیکھو اور ہم نے تجھے لوگوں کے واسطے نمونہ بنانا چاہا اور ہڈیوں کی طرف بھی دیکھو ، ہم انہیں کس طرح ابھار کر جوڑ دیتے ہیں ۔ پھر ان پر گوشت پوست چڑھاتے ہیں ۔ (عثمانیؒ)\nیہاں «اَنْشَزَ» استعمال کرنے کا یہ معنی ہے کہ ان ہڈیوں میں حرکت اور ہیجان پیدا ہوا ۔ وہ آپس میں جڑنے لگیں اور گدھے کا  ڈہانچہ بن کرکھڑا ہوگیا ۔\nنوٹ : (فعل متعدی : اس فعل کو کہتے ہیں جس کو پورا کرنے کے لیے فاعل کے علاوہ مفعول کی بھی ضرورت ہو)","«اَنْشَزَ» کسی چیز میں حرکت پیدا کر کے اٹھانے کے لیے استعمال ہوتا ہے ۔","بوجھ","انشز","2:259-58:11",2
164,26,"ب","بَعَثَ","«بَعَثَ» بنیادی طور پر اس میں دو معنی پائے جاتے ہیں (1) ابھارنا (2) کسی کو  تنہا روانہ کرنا (منجد) کبھی تو بیک وقت یہ لفظ دونوں معنوں میں کبھی الگ الگ کسی ایک معنیٰ میں استعمال ہوتا ہے ، کہا جاتا ہے «بَعَثْتُ الْبَعِیْر» جس کے معنی ہیں اونٹ کو اٹھانا اور آزاد کر دینا ۔ اس وقت ہمارے زیرِ بحث اس کے پہلے معنی ہیں ۔ اگر اس لفظ کا استعمال مُردوں سے متعلق ہو تو بھی اس میں دونوں معنی پائے جاتے ہیں ۔ یعنی مردوں کو زندہ کر کے اٹھانا اور میدان حشر کی طرف چلانا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّاَنَّ السَّاعَۃَ اٰتِیَۃٌ لَّارَیۡبَ فِیۡہَا ۙ وَاَنَّ اللّٰہَ یَبۡعَثُ مَنۡ فِی الۡقُبُوۡرِ» ( 22/7 )\nترجمہ : اور قیامت یقینا آنے والی ہے اس میں کوئی شک و شبہ نہیں اور اللہ تعالیٰ ضرور ان لوگوں کو زندہ کرکے اٹھائے گا جو قبروں میں پڑے ہیں ۔\nپھر یہ لفظ نیند سے اٹھانے کے لیے بھی (یعنی صرف پہلے معنیٰ میں) استعمال ہوا ہے ۔ کیونکہ نیند بھی ایک ہلکی قسم کی موت ہی ہوتی ہے ۔\nمثلاً  : قرآن کریم میں ہے :\n«وَکَذٰلِکَ بَعَثۡنٰہُمۡ لِیَتَسَآءَلُوۡا بَیۡنَہُمۡ» ( 18/19 )\nترجمہ : اوراسی طرح ہم نے ان ( اصحاب کہف کو نیند سے ) اٹھایا تاکہ آپس میں ایک دوسرے سے دریافت کریں ۔","«بَعَثَ» روزِ قیامت مُردوں کو زندہ کرکے اٹھانے کے لیے استعمال ہوتا ہے ۔ ","بوجھ","بعث","2:56-2:259-6:36-6:60-7:14-15:36-16:21-16:38-18:12-18:19-19:15-19:33-22:5-22:7-23:16-23:100-26:87-27:65-30:56-31:28-36:52-37:144-38:79-58:6-58:18-64:7-72:7",27
165,26,"ب","حَمَلَ","«حَمَلَ» بوجھ اٹھانے کے لیے استعمال ہوتا ہے اور اس کا استعمال عام ہے اور مادی (یعنی کوئی چیز مثلاً سامان وغیرہ اٹھانا) اور معنوی (مثلاً گناہ کا بوجھ اٹھانا) دونوں  معنوں میں استعمال ہوتا ہے ۔\n(1) مادی بوجھ اٹھانے کے لیے خواہ یہ ظاہری ہو یا باطنی جیسے عورت کا اپنے پیٹ میں بچہ کا بوجھ اٹھانا یا درخت کا اپنے پھل یا بادل کا اپنے پانی کا بوجھ اٹھانا ۔ غرض یہ لفظ ہر طرح استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَلَمَّا تَغَشّٰہَا حَمَلَتۡ حَمۡلًا خَفِیۡفًا فَمَرَّتۡ بِہٖ» ( 7/189 )\nترجمہ : جب مرد عورت کے پاس جاتا ہے تو اسے ہلکا سا حمل ہو جاتا ہے اور وہ اس کے ساتھ چلتی پھرتی ہے ۔\n(2) معنوی بوجھ اٹھانے کے لیے : مثلاً : ارشاد باری تعالیٰ ہے :\n«وَعَنَتِ الۡوُجُوۡہُ لِلۡحَیِّ الۡقَیُّوۡمِ ؕ وَ قَدۡ خَابَ مَنۡ حَمَلَ ظُلۡمًا» ( 20/111 )\nترجمہ : اور اس زندہ و قائم کے روبرو منہ نیچے ہو جائیں گے اور جس نے ظلم کا بوجھ اٹھایا وہ نامراد رہا ۔\nاور «حَمَلَ عَلیٰ» بمعنی کسی پر بوجھ لادنا اور «حَمَّلَ» بوجھ اٹھوانے کے معنوں میں آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تَحۡمِلۡ عَلَیۡنَاۤ اِصۡرًا» ( 2/286 )\nترجمہ : اور ہم پر بوجھ نہ ڈال ۔","«حَمَلَ» بوجھ اٹھانے کے لیے استعمال ہوتا ہے خواہ مادی ہو یا معنوی ۔ عام ہے ۔","بوجھ","حمل","2:248-2:286-6:31-6:146-7:176-7:189-9:92-11:40-12:36-12:72-13:8-16:7-16:25-17:3-17:70-19:22-19:27-19:58-20:87-20:100-20:101-20:111-22:2-23:22-24:54-29:12-29:13-29:60-31:14-33:72-35:11-35:18-36:41-40:7-40:80-41:47-46:15-54:13-62:5-65:4-65:6-69:11-69:14-69:17",44
166,26,"ب","لَقَحَ","«لَقَحَ» یہ لفظ باطنی (یعنی نظر نہ آنے والا) بوجھ اٹھانے کے لئے خاص ہے «لَقَحَۃُ النَّاقَۃ» بمعنی اونٹنی حاملہ ہو گئی (مف) پھر یہ لفظ ان ہواؤں سے بھی متعلق ہے جو نر درخت سے نطفہ لے جا کر مادہ درخت میں ڈال دیتی ہیں یا وہ ہوائیں جو بارش کا بوجھ اٹھائے پھرتی ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاَرۡسَلۡنَا الرِّیٰحَ لَوَاقِحَ فَاَنۡزَلۡنَا مِنَ السَّمَآءِ مَآءً» ( 15/22 )\nترجمہ : اور ہم بادلوں کے پانی کا بوجھ اٹھانے والی ہوائیں بھیجتے ہیں ۔ پھر ہم ہی آسمان سے مینہ برساتے ہیں ۔","«لَقَحَ» یہ لفظ باطنی  (یعنی نظر نہ آنے والا ) بوجھ اٹھانے کے لئے  خاص ہے ۔","بوجھ","لقح","15:22",1
167,26,"ب","نَاءَ","( یَنَوء ) کے معنی سخت محنت کرنا اور مشقت سے بوجھ اٹھانا (م ۔ ن) زیادہ بوجھ ہونے کی وجہ سے مشکل سے اٹھانا (م ۔ ا)\nمثلاً : قرآن کریم میں ہے :\n«وَاٰتَیۡنٰہُ مِنَ الۡکُنُوۡزِ مَاۤ اِنَّ مَفَاتِحَہٗ لَتَنُوۡٓاُ بِالۡعُصۡبَۃِ اُولِی الۡقُوَّۃِ» ( 28/76 )\nترجمہ : اور ہم نے اسے اتنے خزانے دیے تھے کہ اس کی چابیاں طاقتور لوگوں کی ایک جماعت سے بھی مشکل سے اٹھتی تھیں ۔ ","«نَاءَ» زیادہ بوجھ جو مشقت کے ساتھ  اٹھایا جا سکے ۔ بوجھ کو بہ مشقت اٹھانا ۔","بوجھ","ناء","28:76",1
168,26,"ب","وَزَرَ","«وَزَرَ» جب کوئی شخص اپنا کپڑا پھیلا کراس میں اپنا بوجھ رکھ کر اٹھاتا اور چل دیتا ہے تو یہی «وَزَرَ» کا صحیح مفہوم ہے ۔ اسی لیے «ذَنْب» یعنی گناہ کو «وِزْر» کہتے ہیں ۔ یعنی وہ شخص اپنے کیے ہوئے گناہ کا بوجھ اٹھا لیتا ہے ۔ (م ل) گویا «وَزَرَ» کا استعمال عموماً گناہوں کا بار اٹھانے کے لیے آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ ہُمۡ یَحۡمِلُوۡنَ اَوۡزَارَہُمۡ عَلٰی ظُہُوۡرِہِمۡ ؕ اَلَا سَآءَ مَا یَزِرُوۡنَ» ( 6/31 )\nترجمہ : اور وہ اپنے ( گناہوں کے ) بوجھ اپنی پشتوں پر اٹھائے ہوئے ہوں گے ۔ دیکھو جو بوجھ یہ اٹھائیں گے کیسا برا ہے ۔","«وَزَرَ» عام طور پر گناہ کا بوجھ اٹھانے کیلئے استعمال ہوتا ہے ۔","بوجھ","وزر","6:31-6:164-16:25-17:15-20:87-20:100-35:18-39:7-53:38-94:2",10
169,27,"ا","اِنْبَعَثَ","«بَعَثَ» کے معنی  ہیں کام کے لیے اٹھنا «باب اِنْفِعَال» میں ہونے کی وجہ سے اس کے معنی کسی شخص کا خود اٹھنا اور کسی اہم مقصد کی تکمیل کے لیے تنہا روانہ ہوجانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«کَذَّبَتۡ ثَمُوۡدُ بِطَغۡوٰىہَاۤ اِذِ انۡۢبَعَثَ اَشۡقٰہَا» ( 91/11،12 )\nترجمہ : ( قوم ) ثمود نے اپنی سرکشی کے سبب پیغمبر کو جھٹلایا ۔ جب ان میں ایک نہایت بدبخت اٹھا ۔","«اِنْبَعَثَ» کسی کا تنہا اٹھ کرکسی مقصد کے لیے روانہ ہو جانا ۔","اٹھنا","انبعث","91:12",1
170,27,"ا","قَامَ","«قَامَ» بیٹھے ہوئے یا لیٹے ہوئے آدمی کا اٹھ کھڑا ہونا یا چلتے چلتے کھڑے ہوجانا سب کے لیے آتا ہے ۔ گویا کھڑے ہونے کے لیے بالعموم استعمال ہوتا ہے ۔ اب مثالیں دیکھئے :\n(1) مثلاً : قرآن کریم میں ہے :\n«الَّذِیۡنَ یَذۡکُرُوۡنَ اللّٰہَ قِیٰمًا وَّقُعُوۡدًا» ( 3/191 )\nترجمہ : وہ لوگ جو کھڑے اور بیٹھے خدا کو یاد کرتے ہیں ۔\n(2)  مثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الۡمُدَّثِّرُ قُمۡ فَاَنۡذِرۡ» ( 74/1،2 )\nترجمہ : اے ( محمد ﷺ ) ! جو کپڑا لپیٹے پڑے ہو اٹھو اور ہدایت کرو ۔\n(3) مثلاً : قرآن کریم میں ہے :\n«کُلَّمَاۤ اَضَآءَ لَہُمۡ مَّشَوۡا فِیۡہِ٭ۙ وَاِذَاۤ اَظۡلَمَ عَلَیۡہِمۡ قَامُوۡا» ( 2/20 )\nترجمہ : جب بجلی (چمکتی اور) ان پر روشنی ڈالتی ہے تو اس میں چل پڑتے ہیں اور جب اندھیرا ہو جاتا ہے تو کھڑے کے کھڑے رہ جاتے ہیں ۔","«قَامَ» کسی بھی حالت کے بعد کھڑا ہونا ۔ عام ہے ۔","اٹھنا","قام","2:20-3:191-4:5-4:102-4:103-4:142-5:6-5:97-9:84-9:108-18:14-18:77-25:64-36:8-39:68-51:45-72:19-73:2-74:2",19
171,27,"ا","نَشَرَ","«نَشَرَ» یہ دو معنوں میں استعمال ہوتا ہے (1) مُردوں کا قبروں سے اٹھ کر پھیل جانا «کَمَا مَرَّ» (2) اٹھ کر نکل کھرا ہونا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّلَا یَمۡلِکُوۡنَ مَوۡتًا وَّلَا حَیٰوۃً وَّلَا نُشُوۡرًا» ( 25/3 )\nترجمہ : نہ مرنا ان کے اختیار میں ہے اور نہ جینا اور نہ (مر کر) اٹھ کھڑے ہونا ۔\nایک  دوسرے مقام پر ارشاد باری تعالیٰ ہے ۔\n«ہُوَالَّذِیۡ جَعَلَ لَکُمُ الَّیۡلَ لِبَاسًا وَّالنَّوۡمَ سُبَاتًا وَّ جَعَلَ النَّہَارَنُشُوۡرًا» ( 25/47 )\nترجمہ : اور وہی تو ہے جس نے رات کو تمہارے لیے پردہ اور نیند کو آرام بنایا اور دن کو اٹھ کھڑے ہونے کا وقت ٹھہرایا ۔","«نَشَرَ» اٹھنا اور پھیل جانا  کے معنی میں استعمال ہوتا ہے ۔","اٹھنا","نشر","25:3-25:40-25:47-35:19-67:15",5
172,27,"ا","نَشَزَ","«نَشَزَ» کسی تحریک یا حرکت کی وجہ سے اٹھنا ۔ «کَمَا مَرَّ»\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ  اٰمَنُوۡۤا  اِذَا  قِیۡلَ  لَکُمۡ تَفَسَّحُوۡا فِی  الۡمَجٰلِسِ فَافۡسَحُوۡا یَفۡسَحِ اللّٰہُ  لَکُمۡ ۚ وَ  اِذَا قِیۡلَ انۡشُزُوۡا فَانۡشُزُوۡا» ( 58/11 )\n ترجمہ : اے ایمان والو ! جب تمہیں مجالس میں کھل کر بیٹھنے کو کہا جائے تو کھل کر بیٹھو ۔ خدا تم کو کشادگی بخشے گا اور جب کہا جائے کہ اٹھ کھڑے ہو تو اٹھ کھڑے ہوا کرو ۔","«نَشَزَ» کسی تحریک (حرکت) کی بنا پر اٹھ جانے کے لیے استعمال ہوتا ہے ۔","اٹھنا","نشز","2:259-58:11",2
173,28,"ا","اِستأذَنَ","«اَذِنَ» بمعنی اجازت یا منظوری «اِسْتأذَنَ» بمعنی منظوری حاصل کرنا یا کسی کام کے لیے اجازت چاہنا اور «اِسْتَأذَنَ عَلَیْہِ» بمعنی اندر آنے کی اجازت طلب کرنا ۔ (منجد)\nمثلاً :قرآن کریم میں ہے :\n«لَا یَسۡتَاۡذِنُکَ الَّذِیۡنَ یُؤۡمِنُوۡنَ بِاللّٰہِ وَالۡیَوۡمِ الۡاٰخِرِاَنۡ یُّجَاہِدُوۡا بِاَمۡوَالِہِمۡ وَاَنۡفُسِہِمۡ» ( 9/44 )\n ترجمہ : جو لوگ خدا اور آخرت پر ایمان رکھتے ہیں ۔ وہ تو آپ سے اجازت نہیں چاہتے کہ پیچھے رہ جائیں ۔ بلکہ چاہتے ہیں کہ اپنے مال اور جان سے جہاد کریں ۔","«اِستأذَنَ» کسی کام کی اجازت یا منظوری طلب کرنا ۔","اجازت","استاذن","9:44-9:45-9:83-9:86-9:93-24:58-24:59-24:62-33:13",9
174,28,"ا","اِسْتَانَسَ","«اٰنَسَ» بمعنی کسی چیز کو دیکھنا اور اس کو جاننا ۔ «اٰنس الصوت» بمعنی آواز سن لینا ۔ «اٰنس النار» ۔ بمعنی آگ دیکھنا ۔ اسی سے «اِسْتَانَسَ»نکلا  ہے ۔ بمعنی انسیت ،رغبت پیدا کرنا ۔ اپنے کسی قول و فعل کے ذریعے دوسرے کو اپنے سے متعارف کرنا ۔ مثلاً کوئی شخص دروازے پر کھڑا ہو کر صاحب خانہ کو آواز دیتا ہے یا کھانستا ہے تو اس آواز یا کھانسنے کے عمل سے صاحب خانہ کو معلوم ہو جاتا ہے کہ دروازے پر فلاں شخص ہے ۔ تو «اِسْتَاْنَسَ» کا مفہوم پورا ہو گیا ۔ مثلاً :قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡا لَا تَدۡخُلُوۡا بُیُوۡتًا غَیۡرَ  بُیُوۡتِکُمۡ  حَتّٰی تَسۡتَاۡنِسُوۡا وَ تُسَلِّمُوۡا عَلٰۤی اَہۡلِہَا» ( 24/27 ) ترجمہ :  ’’ اے ایمان والو ! اپنے گھروں کے سوا دوسرے ( لوگوں کے ) گھروں میں گھر والوں سے اجازت لیے اور ان کو سلام کیے بغیر نہ داخل ہوا کرو ۔","«اِسْتَانَسَ» اپنے کسی قول و فعل سے دوسرے کو متعارف کروانا ۔\nاور اجازت دینا کے لیے صرف «اَذِنَ» آیا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«عَفَا اللّٰہُ عَنۡکَ ۚ لِمَ اَذِنۡتَ لَہُمۡ» ( 9/43 )\nترجمہ : ( اے پیغمبر ﷺ ) خدا آپؐ کو معاف کرے ۔ آپ نے ان ( منافقوں کو جہاد پر نہ جانے کی ) کیوں اجازت دی ۔","اجازت","استانس","24:27",1
175,29,"ا","اَعْرَاب","«اَعْرَاب» گنوار ان پڑھ ، دیہاتی ، جنگلی ، جنگل میں رہنے والے ، غیر مہذّب ، جنھیں گفتگو یا جنہیں زندگی گزارنے کا طریقہ اور سلیقہ اورتمیز ہی نہ ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلۡاَعۡرَابُ اَشَدُّ کُفۡرًا وَّنِفَاقًا وَّاَجۡدَرُاَلَّا یَعۡلَمُوۡاحُدُوۡدَ مَاۤ اَنۡزَلَ اللّٰہُ عَلٰی رَسُوۡلِہٖ» ( 9/97 )\n ترجمہ : گنوار کفر و نفاق میں بہت سخت ہیں ۔ اور اسی لائق ہیں کہ وہ ان احکام کو جو اللہ نے اپنے رسول پر نازل فرمائے ہیں جان ہی نہ سکیں ۔","«اَعْرَاب» بدتمیز لوگ جنھیں آداب گفتگو کا سلیقہ ہی نہ ہو ۔","اُجڈ","اعراب","9:90-9:97-9:98-9:99-9:101-9:120-33:20-48:11-48:16-49:14",10
176,29,"ا","عُتُلّ","«عَتَلَ» بمعنی سختی  کے ساتھ  کسی کو اس کے سر کے بالوں سے پکڑ کر کھینچنا اور گھسیٹنا (مف) «عَتَلَہٗٓ اِلَی السِّجْن» بمعنی اسے گھسیٹ کر قید خانہ میں ڈال دیا ۔ (م ۔ ق)\nمثلاً : قرآن کریم میں ہے :\n«خُذُوۡہُ فَاعۡتِلُوۡہُ  اِلٰی سَوَآءِ الۡجَحِیۡمِ» ( 44/47 )\n ترجمہ : اسے پکڑ لو اور کھینچ کر دوزخ کے بیچوں بیچ لے جاؤ ۔\nاور «عُتُلّ» بمعنی سخت اور اکھڑ مزاج آدمی  (م ۔ ق) سخت گیر (مف)\nمثلاً : قرآن کریم میں ہے :\n«عُتُلٍّۭ بَعۡدَ ذٰلِکَ  زَنِیۡمٍ» ( 68/13 )\nترجمہ : سخت خو اور اس کے علاوہ بد ذات ہے ۔","«عُتُلّ» سخت مزاج اور سخت گیر انسان لئے استعمال ہوتا ہے ۔","اُجڈ","عتل","44:47-68:13",2
177,29,"ا","فَظّ","«فَظّ» بمعنی سخت مزاج ہونا ، بد خلق ہونا ۔ اور «فَظُّ» اکھڑ، بدمزاج اور سخت کلام آدمی ، زبان کا کڑوا ۔ اور اسکی ضِد «لَیْن» ہے یعنی زبان اور مزاج کا نرم ہونا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَبِمَا رَحۡمَۃٍ مِّنَ اللّٰہِ لِنۡتَ لَہُمۡ ۚ وَلَوۡ کُنۡتَ فَظًّا غَلِیۡظَ الۡقَلۡبِ لَانۡفَضُّوۡا مِنۡ حَوۡلِکَ» ( 3/159 )\nترجمہ : اے پیغمبر ﷺ ! یہ اللہ کی بڑی رحمت ہے کہ آپ ان لوگوں کے لیے بڑے نرم مزاج واقع ہوئے ہو، ورنہ اگر آپ تند خو ہوتے تو یہ سب آپ کے پاس سے دور ہوجاتے۔ ","«فَظّ» بدمزاج اور گفتگو میں گالی گلوچ استعمال کرنے والا ۔","اُجڈ","فظ","3:159",1
179,30,"ا","بَغْتَۃً","«بَغْتَۃً» بمعنی اچانک کسی چیز کا یوں ظہور ہوجانا کہ اس کے ظہور کا گمان بھی نہ ہو (مف) «بَغْتَۃً» اور «اِذْ» یا «اِذَا» کا فرق یہ ہے کہ «اِذَا» میں بعد میں پیش آنے والے واقعہ کا پہلے واقعہ سے کچھ نہ کچھ تعلق یا نسبت ہوتی ہے ، جبکہ «بَغْتَۃً» میں صرف کسی اچانک یا ناگہانی واقعہ کا ذکر ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَخَذۡنٰہُمۡ  بَغۡتَۃً وَّ ہُمۡ لَا یَشۡعُرُوۡنَ» ( 7/95 )\nترجمہ :  پھر ہم نے ان کو اچانک پکڑلیا اور ( ایسا ہوجانا ) ان کے وہم وگمان میں بھی نہ تھا ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«حَتّٰۤی  اِذَا جَآءَتۡہُمُ السَّاعَۃُ  بَغۡتَۃً  قَالُوۡا یٰحَسۡرَتَنَا عَلٰی مَا فَرَّطۡنَا فِیۡہَا» ( 6/31 )\nترجمہ :  یہاں تک کہ جب آجائے گا ان پر وہ وقت اچانک تو وہ کہیں گے ہائے افسوس ہماری اس کوتاہی پر جو اس (قیامت) کے بارے میں ہم سے ہوئی ۔","«بَغْتَۃً» کسی ایسی چیز کا اچانک ظہورہوجانا جس کے ظہور کا گمان بھی نہ ہو ۔","اچانک","بغتۃً","6:31-6:44-6:47-7:95-7:187-12:107-21:40-22:55-26:202-29:53-39:55-43:66-47:18",13
180,31,"ا","نِعْمَ","«نِعْمَ» کلمہ تحسین (یعنی تعریفی کلمہ)  ہے جو ہر قسم کی مدح ، تعریف کے لیے استعمال ہوتا ہے (مف) اوراس کے معنی ہیں ۔ واہ واہ کیا خوب ۔ کسی اچھی چیز پر خوش ہو کر بولا جاتا ہے ۔ ابن فارس کے نزدیک اس کی اصل جھکاؤ اور میلان ہے (م ل) یعنی جس چیز کو دیکھ کر طبیعت ادھر مائل اور راغب ہو تو «نِعْم» کہتے ہیں اور اس کی ضد «بِئْسَ» ہے جو کلمہ ذم (یعنی برائی اور تنقید) ہے اور مذمت کے لیے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لَنِعۡمَ  دَارُ الۡمُتَّقِیۡنَ» ( 16/30 )\nترجمہ : اور پرہیزگاروں کا گھر کیا خوب ہے ۔","«نِعْمَ» کلمہ تحسین (یعنی تعریفی کلمہ) ہے جو کسی اچھی بات پر تعریف کے طور پر کہا جاتا ہے ۔","اچھا","نعم","2:271-3:136-3:173-4:58-8:40-13:24-16:30-18:31-22:78-29:58-37:75-38:30-38:44-39:74-51:48-77:23",16
181,31,"ا","خَیْر","«خَیْر» ہر وہ چیز جو سب کو مرغوب ہو ۔ مثلاً عدل ، عقل اور مال و دولت کو بھی خیر کہتے ہیں (م ۔ ا) اس کی ضد «شَر» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنَّہٗ  لِحُبِّ الۡخَیۡرِلَشَدِیۡدٌ» ( 100/8 )\nترجمہ : اور وہ انسان تو مال و دولت سے سخت محبت کرنے والا ہے ۔\nیعنی خیر سے مراد ہر بھلی بات یا نیک کام ہوتا ہے اور اس کی جمع خیرات ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یُؤۡمِنُوۡنَ بِاللّٰہِ وَ الۡیَوۡمِ الۡاٰخِرِ وَ یَاۡمُرُوۡنَ بِالۡمَعۡرُوۡفِ وَ یَنۡہَوۡنَ عَنِ الۡمُنۡکَرِ وَ یُسَارِعُوۡنَ فِی الۡخَیۡرٰتِ» ( 3/114 )\nترجمہ : وہ خدا اور روز آخرت پر ایمان رکھتے ہیں اور اچھے کام کرنے کو کہتے ہیں اور بری باتوں سے منع کرتے ہیں اور نیک کاموں پر لپکتے ہیں ۔\nخیر کا لفظ صرف بھلی بات یا بھلے کام پر ہی استعمال نہیں ہوتا بلکہ بھلے آدمیوں یا چیزوں پر بھی ہوتا ہے اور ایمان کے لیے بھی ۔ اس صورت میں خیر کی  جمع اخیار آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّہُمۡ عِنۡدَنَا لَمِنَ الۡمُصۡطَفَیۡنَ الۡاَخۡیَارِ» ( 38/47 )\n ترجمہ : وہ ہمارے نزدیک منتخب اور نیک لوگوں میں سے تھے ۔\nگویا خیر کا لفظ کسی بھلی بات یا کام یا آدمی کے لیے استعمال ہوتا ہے اور «نِعْمَ» کسی بھلی چیز کو دیکھ کر خوش ہونے پر بولا جاتا ہے ۔\nدرج ذیل آیت اس بات کی وضاحت کر رہی ہے :\n«وَ لَدَارُ الۡاٰخِرَۃِ خَیۡرٌ ؕ وَ لَنِعۡمَ  دَارُ الۡمُتَّقِیۡنَ» ( 16/30 )\nترجمہ : آخرت کا گھر تو بہت ہی اچھا ہے ۔ اور پرہیزگاروں کا گھر کیا ہی خوب ہے ۔","«خَیْر» ہر بھلی بات ، کام یا بھلے آدمی کے لیے استعمال ہوتا ہے ۔","اچھا","خیر","2:54-2:61-2:103-2:105-2:106-2:110-2:148-2:158-2:180-2:184-2:197-2:215-2:216-2:220-2:221-2:263-2:269-2:271-2:272-2:273-2:280-3:15-3:26-3:30-3:54-3:104-3:110-3:114-3:115-3:150-3:157-3:178-3:180-3:198-4:19-4:25-4:46-4:59-4:66-4:77-4:114-4:127-4:128-4:149-4:170-4:171-5:48-5:114-6:17-6:32-6:57-6:158-7:12-7:26-7:85-7:87-7:89-7:155-7:169-7:188-8:19-8:23-8:30-8:70-9:3-9:41-9:61-9:74-9:88-9:109-10:11-10:58-10:107-10:109-11:31-11:84-11:86-12:39-12:57-12:59-12:64-12:80-12:109-16:30-16:76-16:95-16:126-17:11-17:35-18:36-18:40-18:44-18:46-18:81-18:95-19:73-19:76-20:73-20:131-21:35-21:73-21:89-21:90-22:11-22:30-22:36-22:58-22:77-23:29-23:56-23:61-23:72-23:109-23:118-24:11-24:12-24:27-24:33-24:60-25:10-25:15-25:24-27:36-27:59-27:89-28:24-28:26-28:60-28:80-28:84-29:16-30:38-33:19-33:25-34:39-35:32-37:62-38:32-38:76-41:40-41:49-42:36-43:32-43:52-43:58-44:37-46:11-47:21-49:5-49:11-50:25-54:43-55:70-58:12-61:11-62:9-62:11-64:16-66:5-68:12-68:32-70:21-70:41-73:20-87:17-93:4-97:3-98:7-99:7-100:8",170
182,31,"ا","حَسُنَ","«حَسُنَ» بمعنی خوش کن اور پسندیدہ چیز (مف) اور اس کی ضد «سَاءَ» ہے پھر یہ لفظ ظاہری خوبصورتی اور چہرے کے نکھار کے لیے بھی استعمال ہوتاہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فِیۡہِنَّ خَیۡرٰتٌ حِسَانٌ» ( 55/70 )\nترجمہ : ان (جنت کے باغوں میں) نیک سیرت اور خوبصورت عورتیں ہیں ۔\nاس صورت میں اس کی ضد «قَبُحَ» ہے ۔  اسکے علاوہ  یہ لفظ اخلاق کی عمدگی کو ظاہر کرنے کے لیے بھی معنوی طور پر استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَحَسُنَ اُولٰٓئِکَ رَفِیۡقًا» ( 4/69 )\nترجمہ : اور ان لوگوں کی رفاقت کیا ہی خوب ہے ۔","«حَسُنَ» خوش کن اور پسندیدہ بات ظاہری و معنوی خوبصورتی اور اچھائی کے لیےاستعمال ہوتا ہے ۔","اچھا","حسن","2:83-2:138-2:245-3:14-3:37-3:148-3:195-4:59-4:69-4:95-5:12-6:152-6:160-7:137-7:180-8:17-9:107-10:26-11:3-11:88-13:18-13:29-16:62-16:67-16:75-17:110-18:2-18:31-18:86-18:88-20:8-20:86-21:101-22:58-25:76-27:11-28:61-29:8-33:52-35:8-38:25-38:40-38:49-41:50-42:23-48:16-53:31-55:70-55:76-57:10-57:11-57:18-59:24-64:17-73:20-92:6-92:9",57
183,31,"ا","اَمْثَل ، مُثْلیٰ","«مَثَلَ» کے معنی تصویر کا آنکھوں کے سامنے ہونا (مف) اور «اَمْثَل» کے معنی مثالی ، بینظیر ، آئیڈیل ۔ بہترین (م ۔ ا)\nمثلاً : قرآن کریم میں ہے :\n«اِذۡ یَقُوۡلُ اَمۡثَلُہُمۡ طَرِیۡقَۃً» ( 20/104 )\nترجمہ : اس وقت سب سے اچھی راہ والا ( یعنی عاقل و ہوشمند ) کہے گا ( جالندھری )\nاور «مُثْلیٰ ، اَمْثَلُ» سے مونث ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یَذۡہَبَا بِطَرِیۡقَتِکُمُ  الۡمُثۡلٰی» ( 20/63 )\nترجمہ : اور تمہارے مثالی طریق زندگی کا خاتمہ کر دیں ۔","«اَمْثَل ، مُثْلیٰ» بمعنی مثالی ، بہترین ، آئیڈیل جو قابلِ تقلید ہو ۔","اچھا","امثل ، مثلی","20:63-20:104",2
184,31,"ا","جَمِیْلٌ","«جَمِیْلٌ» اسکا اصل لفظ  جمال ہے جس کے معنی ظاہری خوبی ، شان  و شوکت، ٹھاٹھ  باٹھ  اور خوبصورتی ہے (فق 217)\nمثلاً : قرآن کریم میں ہے :\n«وَ لَکُمۡ فِیۡہَا جَمَالٌ» ( 16/6 )\nترجمہ : اور تمہارے لیے اس میں شان ہے ۔\nاور «اَجْمَلَ فِی الْعَمَل» کے معنی کسی کام  کو بہتر طریقے سے سرانجام دینا ہے (م ۔ ق) اور جمیل کا لفظ بہتر راستہ اختیار کرنے کے لیے آتا ہے ۔ جیسے یعقوبؑ نے اپنے بیٹوں سے فرمایا :\n«بَلۡ سَوَّلَتۡ لَکُمۡ اَنۡفُسُکُمۡ اَمۡرًا ؕ فَصَبۡرٌ  جَمِیۡلٌ» ( 12/18 )\n ترجمہ : تم یہ بات اپنے دل سے بنا لائے ہو ۔ سو اب صبر ہی اچھا ہے ۔\nاور قرآن کریم میں ہے جب رسول اللہ ﷺ نے اپنی بیویوں سے فرمایا :\n«اِنۡ  کُنۡـتُنَّ تُرِدۡنَ  الۡحَیٰوۃَ  الدُّنۡیَا وَ زِیۡنَتَہَا فَتَعَالَیۡنَ اُمَتِّعۡکُنَّ وَ اُسَرِّحۡکُنَّ سَرَاحًا جَمِیۡلًا» ( 33/28 )\nترجمہ : اگر تم دنیا کی زندگی اوراس کی زینت و آرائش کی خواستگار ہو تو آؤ میں تمہیں کچھ مال دوں اور اچھی طرح سے رخصت کر دوں ۔\nبعد میں یہ لفظ چہرہ کی خوبصورتی میں بھی استعمال ہونے لگا ۔ لیکن اس کی مثال قرآن میں نہیں ہے ۔","«جَمِیْلٌ» کسی بھی انسان کے اچھے کام ، اچھے  اخلاق   کے لیے آتا ہے ۔عرف عام میں یہ لفظ  ظاہری خوبصورتی  کے لئے بھی  استعمال ہوتا ہے ۔","اچھا","جمیل","12:18-12:83-15:85-16:6-33:28-33:49-70:5-73:10",8
185,32,"ا","نَکِرَ","«نَکِرَ» بمعنی کسی بات سے ناواقف ہونا «نَکْرَۃ» اسکی ضد «مَعْرفَۃ» ہے ۔ اور «اَنْکَرَ» بمعنی انکار کرنا ۔ کسی سے ناواقف ہونا اور «تَنَاکَر» بمعنی جان بوجھ کر ایک دوسرے سے ناواقف بننا اور اجنبیوں جیسا سلوک کرنا اور «نُکْر» ۔ برا کام ۔ سخت کام (منجد) اور«مَنْکِر» بمعنی برا کام ۔ بری بات ۔ ناگوار چیز ۔ گویا «نَکَرَ» میں اجنبیت اور ناگواری دو باتیں پائی جاتی ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«فَلَمَّا رَاٰۤ اَیۡدِیَہُمۡ لَا تَصِلُ اِلَیۡہِ نَکِرَہُمۡ وَاَوۡجَسَ مِنۡہُمۡ خِیۡفَۃً» ( 11/70 )\nترجمہ : پھر جب حضرت ابراہیمؑ نے دیکھا کہ ان (فرشتوں کے) ہاتھ کھانے کی طرف نہیں جاتے تو ان کو اجنبی سمجھ کر دل میں خوف کیا ۔","«نَکِرَ» اجنبیت کے ساتھ اگر ناگواری شامل ہو تو «نَکِرَ» اور اگر خوشگواری شامل ہو تو «عَجَبَ» اور جب ناگواری یا خوشگواری کچھ نہ ہو تو «جُنُب» آتا ہے ۔","اجنبی","نکر","11:70-18:74-18:87-27:41-31:19-54:6-65:8",7
186,32,"ا","عَجَبَ ۔ عَجَبٌ","«عَجَبَ ۔ عَجَبٌ» ایسی حیرت کو کہتے ہیں جس کی وجہ معلوم نہ ہو (مف) نیز«عَجَبَ» بمعنی پسند کرنا اور «اَعْجَبَ» بمعنی کسی ایسی چیز کا خوشگوار محسوس ہونا جس کی امید نہ ہو یا اس کا سبب معلوم نہ ہو ۔ اور کبھی یہ لفظ صرف خوشگوار کے معنوں میں بھی آتا ہے ۔ گویا «عَجَبَ» میں بھی دو باتیں پائی جاتی ہیں ۔ اجنبیت اور خوشگواری ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡۤا اَتَعۡجَبِیۡنَ مِنۡ اَمۡرِ اللّٰہِ رَحۡمَتُ اللّٰہِ وَ بَرَکٰتُہٗ عَلَیۡکُمۡ اَہۡلَ الۡبَیۡتِ» ( 11/73 )\nترجمہ : فرشتے ( حضرت ابراہیم ؑ کی بیوی سے ) کہنے لگے کیا تم خدا کی قدرت سے تعجب کرتی ہو ۔ اے اہل بیت ! تم پر خدا کی رحمت اور اس کی برکتیں ہوں ۔","«عَجَبَ ۔ عَجَبٌ» ایسی حیرت کو کہتے ہیں جس کی وجہ معلوم نہ ہو ۔","اجنبی","عجب ۔ عجب","2:204-2:221-5:100-7:63-7:69-9:25-9:55-9:85-10:2-11:73-13:5-18:9-18:63-33:52-37:12-38:4-48:29-50:2-53:59-57:20-63:4-72:1",22
187,32,"ا","جُنُب","«جَنْب» بمعنی پہلو ۔ کروٹ اور«جُنُب» بمعنی اجنبی بھی اور ناپاک بھی اور «جُنُب» کا لفظ  ایک ، دو ، اور  جمع یعنی سب کے لئے اورمرد و عورت سب کے لیے یکساں استعمال ہوتا ہے ۔ (منجد) یہ لفظ قرآن میں ان دونوں معنوں میں آیا ہے ۔ جب یہ اجنبی کے معنوں میں آئے تو اس میں ناگواری یا خوشگواری کا کچھ تعلق نہیں ہوتا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَالۡجَارِ ذِی الۡقُرۡبٰی وَ الۡجَارِ الۡجُنُبِ وَ الصَّاحِبِ بِالۡجَنۡۢبِ» ( 4/36 )\nترجمہ : اور رشتہ دار ہمسایوں ، اجنبی ہمسایوں اور رفقائے پہلو ( پاس بیٹھنے والوں ) سے اچھا سلوک کرو ۔\nاور«جَنَبَ» بمعنی ایک طرف ہو جانا اور دور ہونا اور جنبی  یعنی ناپاک شخص کو بھی چونکہ نماز اور مسجد وغیرہ سے ایک طرف یا علیحدہ رہنے کا حکم ہے ۔ اسی نسبت سے اسے جنبی یا جُنُب کہا جاتا ہے ۔\n مثلاً :قرآن کریم میں ہے :\n«وَلَا جُنُبًا اِلَّا عَابِرِیۡ سَبِیۡلٍ حَتّٰی تَغۡتَسِلُوۡا» ( 4/43 )\nترجمہ : اور جُنبی بھی ( نماز کے قریب نہ جائے ) جب تک نہا نہ لے ۔ مگر جو راہ چلتا مسافر ہو ۔","«جُنُب» اس میں دو معنی پائے جاتے ہیں پہلا معنی یہ اجنبی شخص کے لئے بھی استعمال ہوتا ہے ، دوسرا معنی یہ ناپاک شخص کے لئے بھی  استعمال ہوتا ہے ۔","اجنبی","جنب","4:36-4:43-5:6-10:12-28:11-39:56-87:11-92:17",8
188,33,"ا","فَضْل","«فَضَّلَ» بمعنی کسی اچھی چیز کا اقتصاد اوردرمیانی درجہ سے زیادہ ہونا (مف) اور«فُضُوْل» یعنی ضرورت سے زیادہ چیز ۔ نیز وہ مال غنیمت جو تقسیم کے بعد بچ   جائے  ۔ اور «فَضُوْل» بہت فضل کرنے والا اور «فَضْل» بمعنی احسان ۔ زیادتی (منجد) اور «فَضَّل» بمعنی کسی کو فضیلت یا بڑائی دینا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تَنۡسَوُا الۡفَضۡلَ بَیۡنَکُمۡ» ( 2/237 )\nترجمہ : اور آپس میں احسان کرنا نہ بھولو ۔ (عثمانیؒ)\nاور «فَضَّلَ» بمعنی کسی کو اس کے اصل حق سے ازراہِ مہربانی کچھ زیادہ دینا ۔\nمثلاً : قرآن کریم میں ہے :\n«تِلۡکَ الرُّسُلُ  فَضَّلۡنَا بَعۡضَہُمۡ عَلٰی بَعۡضٍ» ( 2/253 )\nترجمہ : یہ پیغمبر ہیں ( جو ہم وقتًا فوقتًا بھیجتے رہے ) ہم نے ان میں سے بعض کو بعض پر فضیلت دی ۔","«فَضَّلَ» ازراہِ مہربانی کسی کو اس کی حیثیت سے کچھ زیادہ  دیدینا ۔","احسان","فضل","2:47-2:64-2:90-2:105-2:122-2:198-2:237-2:243-2:251-2:253-2:268-3:73-3:74-3:152-3:170-3:171-3:174-3:180-4:32-4:34-4:37-4:54-4:70-4:73-4:83-4:95-4:113-4:173-4:175-5:2-5:54-6:86-7:39-7:140-8:29-9:28-9:59-9:74-9:75-9:76-10:58-10:60-10:107-11:3-11:27-12:38-13:4-16:14-16:71-17:12-17:21-17:48-17:55-17:66-17:70-17:87-23:24-24:10-24:14-24:20-24:21-24:22-24:32-24:33-24:38-27:15-27:16-27:40-27:73-28:73-30:23-30:45-30:46-33:47-34:10-35:12-35:30-35:32-35:35-40:61-42:22-42:26-44:57-45:12-45:16-48:29-49:8-57:21-57:29-59:8-62:4-62:10-73:20",93
190,33,"ا","اَنْعَمَ","«اَلنَّعْمَۃ» انسان کی اچھی حالت کو کہتے ہیں اور نعمت ہر وہ چیز ہے جو انسان کی کسی  ضرورت کو پورا کردے اور اس کی خوشحالی کا باعث بن سکے اور یہ لفظ جنس کے لیے ہے خواہ نعمت تھوڑی ہو یا زیادہ اور نعمت اور انعام کا لفظ انسان کے ساتھ مخصوص ہے ۔ «اَنْعَمَ» کے معنی احسان ، نیکی یا بھلائی کرنا ہے ۔ لیکن «اَنْعَمَ عَلیٰ فَرَسِہ» کبھی نہ آئے گا (م ۔ ق) نیز یہ لفظ اپنی ذات کے لیے بھی استعمال نہیں ہوتا ۔ (فق ۔ ل 158)\nمثلاً : قرآن کریم میں ہے :\n«اِذۡ تَقُوۡلُ لِلَّذِیۡۤ  اَنۡعَمَ اللّٰہُ عَلَیۡہِ وَاَنۡعَمۡتَ عَلَیۡہِ اَمۡسِکۡ عَلَیۡکَ زَوۡجَکَ» ( 33/37 )\nترجمہ : جب تم اس شخص سے ، جس ( زید بن حارثہ ) پر خدا نے بھی احسان کیا اور تم نے بھی احسان کیا ۔ یہ کہتے ہیں کہ اپنی بیوی کو اپنے پاس رہنے دو ۔ ( طلاق نہ دو )","«اَنْعَمَ» کسی انسان پر سوائے اپنی ذات کے احسان کرنے کے لیے استعمال ہوتا ہے ۔","احسان","انعم","1:6-2:40-2:47-2:122-2:150-2:211-2:231-3:103-3:171-3:174-4:69-4:72-5:3-5:6-5:7-5:11-5:20-5:23-5:110-8:53-11:10-12:6-14:6-14:28-14:34-16:18-16:53-16:71-16:72-16:81-16:83-16:112-16:114-16:121-17:83-19:58-26:22-27:19-28:17-29:67-31:20-31:31-33:9-33:37-35:3-37:57-39:8-39:49-41:51-43:13-43:59-44:27-46:15-48:2-49:8-52:29-54:35-68:2-68:49-73:11-89:15-92:19-93:11",63
191,33,"ا","اَحْسَنَ","«اَحْسَنَ» احسان کا معنی ہر نیک اور اچھا کام ہے خواہ اس کا تعلق اپنی ذات سے ہو ، یا کسی دوسرے سے (فق ل 158) ۔ حدیث جبریلؑ میں ہے کہ جبریلؑ نے آپ سے پوچھا کہ احسان کیا ہے ؟ تو آپ ﷺ نے فرمایا :’’ احسان یہ ہے کہ تو خدا کی یوں عبادت کرے گویا تو اسے دیکھ رہا ہے اور اگر یہ ممکن نہ ہو تو کم از کم یہ ضرور سمجھنا چاہئے کہ خدا تجھے دیکھ رہا ہے ۔‘‘ احسان کا لفظ چھوٹے سے چھوٹے اور بڑے سے بڑے ہر بھلائی کے کام پر بولا جاتا ہے ۔ جیسے حضرت یوسفؑ نے اللہ تعالیٰ کا شکر ادا کرتے ہوئے فرمایا :\n«وَ قَدۡ اَحۡسَنَ  بِیۡۤ اِذۡ اَخۡرَجَنِیۡ مِنَ السِّجۡنِ وَ جَآءَ بِکُمۡ مِّنَ الۡبَدۡوِ» ( 12/100 )\nترجمہ : اور اس نے مجھ پر احسان فرمایا کہ مجھ کو جیل خانہ سے نکالا اور تم سب کو گاؤں سے یہاں لے آیا ۔","«اَحْسَنَ» ہر نیک اور اچھا کام کے لیے استعمال ہوتا ہے خواہ اس کا تعلق اپنی ذات سے ہو ، یا کسی دوسرے کی ذات سےہو۔","احسان","احسن","2:83-2:178-2:195-2:229-3:172-4:36-4:59-4:62-4:86-4:125-5:50-5:93-6:151-6:152-6:154-7:145-9:100-9:121-10:26-11:7-12:3-12:23-12:100-16:30-16:90-16:96-16:97-16:125-17:7-17:23-17:34-17:35-17:53-18:7-18:30-19:73-19:74-23:14-23:96-24:38-25:24-25:33-28:77-29:7-29:46-32:7-37:125-39:10-39:18-39:23-39:35-39:55-40:64-41:33-41:34-46:15-46:16-53:31-55:60-64:3-65:11-67:2-95:4",63
192,34,"ا","خِیَرَۃ","«خَیْر» یعنی اچھا اور بہتر اور «خِیَرَۃ» اور «اِخْتَار» یعنی دو یا زیادہ چیزوں میں سے کسی اچھی چیز کو پسند کر لینا ، چن لینا یا اختیار کرنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَا کَانَ لِمُؤۡمِنٍ وَّلَا مُؤۡمِنَۃٍ اِذَا قَضَی اللّٰہُ وَرَسُوۡلُہٗۤ اَمۡرًا اَنۡ یَّکُوۡنَ لَہُمُ الۡخِیَرَۃُ مِنۡ اَمۡرِہِمۡ» ( 33/36 )\nترجمہ : کسی مومن مرد یا مومن عورت کا یہ حق نہیں ہے کہ جب اللہ اور اس کا رسول کسی بات کا فیصلہ کر دیں تو ان کا اپنا کچھ اختیار باقی رہ جائے ۔","«خِیَرَۃ» دو یااس سے زیادہ چیزوں میں سے کسی ایک کا انتخاب کر لینے کا اختیار ۔","اختیار","خیرۃ","28:68-33:36",2
193,34,"ا","مَلْک","«مِلْک» ہراس چیز کو کہتے ہیں جو کسی کے قبضہ میں ہو اور کسی دوسرے کا اس میں تصرف کرنے کا اختیار نہ ہو اور«مَلْک» اور «مِلْک» دونوں اس لحاظ سے ہم معنی ہیں (مف) یعنی «مَلْک» ایسی چیز میں اختیار کو کہتے ہیں جو اپنی ملکیت اور قبضہ میں ہو ( اور «مَلِک» بادشاہ کو کہتے ہیں کہ پبلک اس کے قبضہ اور تصرف میں ہوتی ہے اور وہ اس کا منتظم ہوتا ہے)\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا مَاۤ اَخۡلَفۡنَا مَوۡعِدَکَ بِمَلۡکِنَا» ( 20/87 )\nترجمہ : ( بنو اسرائیل نے حضرت موسیٰ ؑ سے ) کہا ہم نے اپنے اختیار سے تم سے وعدہ خلاف نہیں کیا ۔\nیعنی سامری فریب سے ہم سے زیورات لے کر اور بچھڑا بنا کر کچھ اس طرح ہم پر مسلط ہو گیا تھا کہ ہمیں اپنی مرضی سے اپنی چیزوں میں بھی تصرف کرنے کا اختیار ہی نہ رہا ۔","«مَلْک» کسی چیز میں تصرف کرنے کا اختیارہونا ۔","اختیار","ملک","2:246-2:247-4:3-4:24-4:25-4:36-5:17-5:25-5:41-5:76-7:188-10:31-10:49-12:43-12:50-12:54-12:72-12:76-13:16-16:71-16:73-17:56-17:100-18:79-19:87-20:87-20:89-20:114-23:6-23:88-23:116-24:31-24:33-24:58-24:61-25:3-29:17-30:28-33:50-33:52-33:55-34:22-34:42-35:13-39:43-43:86-46:8-48:11-59:23-60:4-62:1-70:30-72:21-78:37-82:19-114:2",56
194,34,"ا","وَلَایۃ","«وَلَایَۃ» اگر واؤ کے زَبر کے ساتھ ہو تو اس کا معنی ہوگا کسی کام کا متولی ہونا اور «وِلَایَۃ» اگر واؤ کے  زِیر کے ساتھ ہو تو اسکے معنی ہوگا ملک ، سلطنت یا  بادشاہی ۔(مف) اور «اَلْوَلَاء» بمعنی وہ میراث جو اپنے آزاد کردہ غلام سے حاصل ہو (مف) اور «وَلَایَۃ» کا لفظ قرآن میں وراثت کے معنوں میں بھی استعمال ہوا ہے ۔ مہاجرین اولین اور انصار میں جب مواخات (بھائی چارگی ) کا سلسلہ قائم ہوا تو وہ ایک دوسرے کے وارث بھی ہوتے تھے ۔ لیکن بعد میں یہ احکام ختم کر دیے گئے اور حقیقی وارثوں کو ہی اصل وارث قرار دیا گیا ۔ ( دیکھئے سورہ انفال 72 تا 75 ) نیز قرآن میں«مَوْلیٰ اور مَوَالِی )» وارث کے معنوں میں استعمال ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ لِکُلٍّ جَعَلۡنَا مَوَالِیَ  مِمَّا تَرَکَ الۡوَالِدٰنِ وَ الۡاَقۡرَبُوۡنَ» ( 4/33 )\nترجمہ : اور ایسے مال کے لیے جس کو والدین اور رشتہ دار لوگ چھوڑ کر مریں ہم نے ہرایک کے لیے وارث مقرر کر دیے ہیں ۔\nگویا «وَلَایَۃ» کا لفظ «مَلْک» سے بہت زیادہ وسیع مفہوم میں استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ہُنَالِکَ الۡوَلَایَۃُ لِلّٰہِ الۡحَقِّ» ( 18/44 )\nترجمہ : یہاں (سے ثابت ہوا کہ) حکومت سب خدائے برحق کی ہے ( جالندھری )","«وَلَایَۃ» کسی چیز کے تمام اختیارات کا کسی شخص کے قبضہ میں ہونا ۔","اختیار","ولایۃ","4:33-18:44-19:5",3
195,34,"ا","اَمْکَنَ","«اَمْکَنَ» اور «مَکَّنَ» دونوں کے معنی کسی کو کسی جگہ پر قدرت دینا ۔ اختیار دینا اور قادر بنانا ہے  (منجد) اور اسی سے مکان بھی ہے  یعنی کسی چیز کے رکھنے  یا رہنے کی  جگہ ۔ اور «اَمْکَنَ الْاَمْر» بمعنی کسی کام کو ممکن اور آسان بنانا ہے ۔ (منجد) گویا «اَمْکَنَ» میں اختیار کے ساتھ جگہ یا مقام کا مفہوم پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ یُّرِیۡدُوۡا خِیَانَتَکَ فَقَدۡ خَانُوا اللّٰہَ مِنۡ قَبۡلُ فَاَمۡکَنَ مِنۡہُمۡ» ( 8/71 )\nترجمہ : اگر یہ لوگ تم سے دغا کرنا چاہیں گے تو یہ پہلے ہی خدا سے دغا کر چکے ہیں ۔ تو اللہ نے ان کو ( تمہارے ) قبضے میں کر دیا ( جالندھری ) ۔ تو اس نے ان کو پکڑوا دیا ۔ ( عثمانیؒ )","«اَمْکَنَ» جب اختیار میں مقام یا جگہ کا تصور بھی موجود ہو ۔","اختیار","امکن","8:71",1
196,34,"ا","اِسْتَحَبَّ","«حُبّ» بمعنی محبت اور «اِسْتَحَبَّ» بمعنی ایسی چیز کو اختیار کرنا جسے اختیار کرنے کو انسان کا جی بھی چاہتا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡا لَا تَتَّخِذُوۡۤا اٰبَآءَکُمۡ وَ اِخۡوَانَکُمۡ اَوۡلِیَآءَ اِنِ اسۡتَحَبُّوا الۡکُفۡرَ عَلَی الۡاِیۡمَانِ» ( 9/23 )\nترجمہ : اے ایمان والو ! اگر تمہارے ماں باپ اور بہن بھائی ایمان کے مقابلہ میں کفر کو اختیار کریں تو ان سے دوستی نہ رکھو ۔"," «اِسْتَحَبَّ» دو یا زیادہ چیزوں میں سے ایسی چیز کو اختیار کرنا جو جی کو بھا جائے ۔ ","اختیار","استحب","9:23-14:3-16:107-41:17",4
197,34,"ا","تَحَرّٰی","«حَرْوٌ ، اَحْرٰی» بمعنی لائق تر (م ق) اور «تَحَرّٰی» زیادہ مناسب و لائق کو طلب کرنا ۔ دو چیزوں میں سے زیادہ بہتر کو طلب کرنا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَمَنۡ اَسۡلَمَ فَاُولٰٓئِکَ تَحَرَّوۡا رَشَدًا» ( 72/14 )\nترجمہ : اور جو فرمانبردار بن گیا تو ایسے ہی لوگوں نے بھلائی کا راستہ اختیار کیا ۔","«تَحَرّٰی» دو چیزوں میں سے زیادہ  لائق اور بہتر کو اختیار کرنا اور طلب کرنا ۔ ","اختیار","تحری","72:14",1
198,35,"ق","قرض","«قَرَضَ» بمعنی قرض یعنی ایسا ادھار جو انسان اپنی ضروریات کو پورا کرنے کے لیے کسی دوسرے سے شخص سے لیتا ہے ۔ اور امام راغب کے مطابق وہ مال جو اس کی ضرورت پوری کرنے کے لیے دیا جائے اس شرط پر کہ وہ واپس مل جائے گا ۔ (مف) اور صاحبِ مُنْتَہَی الْاَرَبْ اس پر اِس شرط کا بھی اضافہ کرتے ہیں کہ ایسا ادھار جس کی ادائیگی کے لیے مدت مقرر نہ کی گئی ہو ۔ (م ۔ ا)\n کیونکہ قرض کا لفظ جہاں کہیں قرآن کریم میں استعمال ہوا ہے ۔ اکثر اس کے ساتھ «حَسَنَا» کا لفظ بھی آیا ہے اور قرض حسنہ کی ایک شرط یہ بھی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ کَانَ ذُوۡعُسۡرَۃٍ فَنَظِرَۃٌ اِلٰی مَیۡسَرَۃٍ» ( 2/280 )\nترجمہ : اور اگر مقروض تنگ دست ہو تو فراخی حاصل ہونے تک اسے مہلت دو ۔\nاور ایسے قرض کو اللہ تعالیٰ قرض حسنہ فرماتے ہیں اور خود قرض لینے سے منسوب فرماتے ہیں حالانکہ یہ توضرورت مند لوگوں کو ہی دیا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«مَنۡ ذَا الَّذِیۡ یُقۡرِضُ اللّٰہَ  قَرۡضًا حَسَنًا فَیُضٰعِفَہٗ لَہٗ وَ لَہٗۤ اَجۡرٌ کَرِیۡمٌ» ( 57/11 )\nترجمہ : کون ہے جو اللہ کو اچھا قرض دے تو وہ اس کو اس سے دگنا ادا کرے اور اس کے لیے عزت کا صلہ ( یعنی جنت ) ہے ۔\nاس لحاظ سے ہر قرض دَین تو ہوتا ہے ۔ لیکن ہر دَین قرض نہیں ہوتا ۔ ( فق ل 140 )","«قَرَضَ» وہ رقم جو ذاتی ضروریات کے لیے ایک متعین مدت پر واپس کرنے کی شرط پر لی جاتی ہے ۔ اور  قرض حسنہ  میں مدت معین نہیں ہوتی ۔\n","قرض","قرض","2:245-2:282-4:11-4:12-5:12-57:11-57:18-64:17-73:20",9
199,35,"ق","دین","«دَیْن» ا گر قرض میں مدت مقرر ہو تو یہ دَین کہلاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡۤا اِذَا تَدَایَنۡتُمۡ بِدَیۡنٍ اِلٰۤی اَجَلٍ مُّسَمًّی فَاکۡتُبُوۡہُ» ( 2/282 )\nترجمہ : اے ایمان والو ! جب تم آپس میں کبھی لین دین کے لیے قرض کا معاملہ کرنے لگو تو اس کو لکھ لیا کرو ۔\nاور «دَیْن» سے مراد لین دین کی تمام تر ذمہ داریاں ہوتی ہیں گویا یہ لفظ قرض سے عام ہے یہ تجارتی اغراض کے تحت بھی لیا جا سکتا ہے اور ذاتی ضرورتوں کے لیے بھی اس کی مثال یوں سمجھئے کہ ایک آدمی نے لوگوں کو پانچ ہزار روپے ادا کرنے ہیں اور ساتھ ہی آٹھ ہزار لینے بھی ہیں تو وہ مدیون تو ضرور ہے لیکن مقروض نہیں ہے ۔ اور اگر اس نے آٹھ ہزار ادا کرنے ہیں اور پانچ ہزار لینا ہیں تو وہ مدیون بھی ہے اور مقروض بھی ۔ اور اگر کسی شخص نے ذاتی ضروریات کے لیے قرض کسی مقررہ مدت پر لیا ہے تو اس نے مقررہ وقت پر قرض کی ادائیگی کی ذمہ داری قبول کر لی ہے تو یہ قرض نہیں بلکہ دَین ہے ۔","«دَیْن» ا گر قرض میں مدت مقرر ہو تو یہ دَین کہلاتا ہے ۔","قرض","دین","2:245-2:282-4:11-4:12-5:12-57:11-57:18-64:17-73:20",9
200,36,"ا","اَرَادَ","«رَوْد» بمعنی کسی چیز کی تلاش میں آنا جانا (م ۔ ا) اور «اَرَادَ» بمعنی کسی بات یا کام کے کرنے کا دل میں خیال آنا (مف) اور اسے چاہنا اور اسکی ضد «کَرِہَ» (فق ل 103)\nمثلاً : قرآن کریم میں ہے :\n«اِنَّمَاۤ اَمۡرُہٗۤ اِذَاۤ اَرَادَ شَیۡئًا اَنۡ یَّقُوۡلَ لَہٗ کُنۡ فَیَکُوۡنُ» ( 36/82 )\nترجمہ : اس کی شان یہ ہے کہ جب وہ کسی چیز کا ارادہ کرتا ہے تو وہ اس سے فرما دیتا ہے کہ ہو جا تو وہ ہو جاتی ہے ۔","«اَرَادَ» دل میں کسی بات کا خیال آنا جانا ۔","ارادہ","اراد","2:26-2:228-2:233-5:17-9:46-12:25-13:11-17:19-17:103-18:82-21:70-22:22-25:62-28:19-32:20-33:17-33:50-36:82-37:98-39:4-39:38-48:11-72:10-74:31",24
201,36,"ا","ھَمَّ","«ھَمَّ» جب کوئی ارادہ کچھ وقت دل میں رہےاورانسان اس کوعملی جامہ پہنانے کے لیے غور و فکر اور سوچ و بچار کرتا رہے تو اسے «ھَمَّ» سے تعبیرکیا جائے گا (مف) مثلاً : قرآن کریم میں ہے :\n«اَلَا تُقَاتِلُوۡنَ قَوۡمًا نَّکَثُوۡۤا اَیۡمَانَہُمۡ وَ ہَمُّوۡا بِاِخۡرَاجِ الرَّسُوۡلِ» ( 9/13 )\nترجمہ : بھلا تم اس قوم سے کیوں نہ لڑو جنھوں نے اپنی قسموں کو توڑا اور رسول کو نکالنے کی فکر میں رہے ۔ (عثمانیؒ)","«ھَمَّ» دل میں پیدا ہونے والے ارادے میں سوچ بچار کرنا ۔","ارادہ","ھم","9:13-9:74",2
202,36,"ا","عَزَمَ","«عَزَمَ» اپنے ارادے پر سوچ بچار کے بعد ایک قطعی فیصلہ کر لیا جائے تو اسے «عَزَمَ» کہتے ہیں ۔ ابن الفارس کے الفاظ میں «یَدُلُّ عَلَی الْعَزِیْمَۃِ وَالْقََطْعِ» (م ۔ ل) یعنی پختہ ارادہ بنا لینا پھر اس کو پورا کرنے کی ٹھان لینا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَشَاوِرۡہُمۡ فِی الۡاَمۡرِ ۚ فَاِذَا عَزَمۡتَ فَتَوَکَّلۡ عَلَی اللّٰہِ» (3/159 )\nترجمہ : اور ( اے نبی ) اپنے معاملہ میں ( صحابہ سے ) مشورہ کر لیا کرو ۔ پھر جب کسی کام کا عزم کر لو تو اللہ پر بھروسہ رکھو ۔","«عَزَمَ» سوچ بچار کے بعد پختہ ارادہ بنا لینا ۔","ارادہ","عزم","2:227-2:235-3:159-3:186-20:115-31:17-42:43-46:35-47:21",9
203,36,"ا","اَبْرَمَ","«بَرَمَ» بمعنی دو رسیوں کو ملا کر بٹنا اور «اَبْرَمَ» بمعنی کسی کام یا معاملہ یا چیز کو مضبوط بنانا  (م ل ۔ م ا) اوراس کی ضد «نَقَصَ» ہے  اور «اَبْرَام» بمعنی کسی عزم کو عملی جامہ پہنانے کے لیے تدابیر اختیار کرنا ، منصوبہ بندی کرنا اور اسے آخری شکل دینا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَمۡ اَبۡرَمُوۡۤا اَمۡرًا فَاِنَّا مُبۡرِمُوۡنَ» ( 43/79 )\nترجمہ : کیا انہوں نے کوئی بات ٹھہرا رکھی ہے تو ہم بھی ٹھہرانے والے ہیں !\nاس آیت میں اس بات کی طرف اشارہ ہے جو کفارِ مکہ نے رسول اکرم کو قتل کرنے کا منصوبہ بنایا تھا ۔ اور اللہ کا یہ منصوبہ تھا کہ وہ اپنے رسول کو ان سے بچا لے گا ۔","«اَبْرَمَ» عزم اور ارادے کو پورا کرنے  کی منصوبہ بندی کرنا ۔","ارادہ","ابرم","43:79",1
204,36,"ا","اَمَّ","«اَمَّ» بمعنی کسی راستے یا سفر کا ارادہ کرنا (م ۔ ا) اور امام راغب کے نزدیک ’’ سیدھا مقصد کی جانب متوجہ ہونا اور کسی طرف مائل نہ ہونا ‘‘  ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡا لَا تُحِلُّوۡا شَعَآئِرَ اللّٰہِ وَلَا الشَّہۡرَ الۡحَرَامَ وَلَا الۡہَدۡیَ وَلَا الۡقَلَآئِدَ وَلَاۤ آٰمِّیۡنَ الۡبَیۡتَ الۡحَرَامَ» ( 5/2 )\nترجمہ : اے ایمان والو خدا کے نام کی چیزوں کی بے حرمتی نہ کرنا اور نہ ادب کے مہینے کی اور نہ قربانی کے جانوروں کی اور نہ ان جانوروں کی جن کے گلے میں پٹے بندھے ہوں اور نہ اُن لوگوں کی جو عزت کے گھر ( بیت اللہ ) کو جا رہے ہوں ۔","«اَمَّ» اِدھراُدھر توجہ کیے بغیر سیدھا اپنی منزلِ مقصود  کا ارادہ کرنا ۔","ارادہ","ام","5:2",1
205,36,"ا","تَیَمَّمْ","«تَیَمَّمْ» صاحب منتہی الارب کے نزدیک یہ لفظ دراصل «تَاَمَّمَ» تھا جو «اَمَّ» سےنکلا ہے اور ابن الفارس اسکی کی اصل «تَمْ» قرار دیتے ہیں یعنی جان بوجھ کر یا غلطی سے  کوئی کام کرنا (م ل) گویا یہ لفظ ایسےکاموں کے لئے استعمال ہوتا ہے جہاں سوچ و فکر اور مشورہ کی ضرورت نہیں ہوتی بلکہ احکام شریعت کی تعمیل کا ارادہ کرنا مراد ہوتا ہے ۔ قرآن کریم میں  یہ لفظ دو دفعہ استعمال ہوا ہے ۔ ایک دفعہ امر (حکم) کے لیے اوردوسری دفعہ نہی (منع کرنے) کے لیے ۔\nمثلاً : قرآن کریم میں ہے :\n(1) «فَلَمۡ تَجِدُوۡا مَآءً فَتَیَمَّمُوۡا صَعِیۡدًا طَیِّبًا» ( 4/43 )\nترجمہ : پھر تم کو پانی نہ ملے تو پاک مٹی سے تیمم کرلو ۔ (تقی عثمانی)\n اور تمہیں پانی نہ ملے تو پاک مٹی کا قصد کرو (جونا گڑھی)\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n(2) «وَلَا تَیَمَّمُوا الۡخَبِیۡثَ مِنۡہُ تُنۡفِقُوۡنَ وَلَسۡتُمۡ بِاٰخِذِیۡہِ اِلَّاۤ اَنۡ تُغۡمِضُوۡا فِیۡہِ» ( 2/267 )\nترجمہ : اور جو کچھ تم ( راہ خدا میں ) خرچ کرو تو اس میں کسی بری اور ناپاک چیز دینے کا قصد نہ کرنا کہ اگر وہ چیز تمہیں دی جائے تو خود بھی لینا گوارا نہ کرو الّا یہ کہ چشم پوشی کر جاؤ ۔","«تَیَمَّمْ» کسی شرعی حکم کی تعمیل کا ارادہ کرنا ۔","ارادہ","تیمم","2:267-4:43-5:6",3
206,36,"ا","تَحَرّی","«حَرَّی» بمعنی سزاوار اور «تَحَرّٰی» بمعنی راہ صواب ترین جُستَن (م ۔ ا) یعنی بہترین راہ کی تلاش کرنا اور بمعنی ’’ زیادہ مناسب اور لائق کو طلب کرنا ۔ دو چیزوں میں سے زیادہ بہتر کو طلب کرنا ۔‘‘ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَمَنۡ اَسۡلَمَ فَاُولٰٓئِکَ تَحَرَّوۡا رَشَدًا» ( 72/14 )\nترجمہ : تو جو فرمانبردار ہوئے انہوں نے فیصلہ کر لیا اچھی راہ کا ۔ (عثمانیؒ)","«تَحَرَّی» بہترین راستہ کا ارادہ کرنا ۔","ارادہ","تحری","72:14",1
207,37,"ا","اَصَرَّ","«صَرَّ» بمعنی باندھنا اور «صُرَّہ» اس تھیلی کو کہتے ہیں جس میں نقدی رقم رکھ کر باندھ دی جاتی ہے اور «اَصَرَّ» بمعنی گناہ یا بری بات پر سختی سے جم جانا اور اس سے باز نہ آنا ۔ (مف) یہ لفظ زیادہ تر گناہ کے لیے آتا ہے (م ۔ ق)\nمثلاً : قرآن کریم میں ہے :\n«وَکَانُوۡا یُصِرُّوۡنَ عَلَی الۡحِنۡثِ الۡعَظِیۡمِ» ( 56/46 )\nترجمہ : اور وہ لوگ بڑے گناہ ( شرک ) پر اڑے ہوئے تھے ۔","«اَصَرّ» کسی برے کام پر اَڑ جانا یا اڑے رہنا ۔","اَڑنا","اصر","3:135-45:8-56:46",3
208,37,"ا","مَرَدَ","«مَرَدَ» کے بنیادی معنی کسی چیزکا ایسی چیز سے خالی ہونا جواسمیں ہونا چاہئے «اَمْرَدُ» بمعنی ایسا درخت ہے جس کے پتے نہ ہوں اور وہ نوجوان جس کی یا تو ابھی داڑھی نہ آئی ہو یا ویسے ہی بے ریش ہو اور «مَارَدْ» جنوں یا انسانوں میں سے ایسے شیطان کو کہا جاتا ہے جو ہر قسم کی خیر سے عاری ہوں ۔ پھر یہ لفظ کسی بری بات پر اڑ کر خیر سے خالی رہنے کے لیے استعمال ہونے لگا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ مِمَّنۡ حَوۡلَکُمۡ مِّنَ الۡاَعۡرَابِ مُنٰفِقُوۡنَ  ؕ ۛوَ مِنۡ اَہۡلِ الۡمَدِیۡنَۃِ ۛ ؔ مَرَدُوۡا عَلَی النِّفَاقِ» ( 9/101 )\nترجمہ : اور تمہارے گردونواح کے بعض دیہاتی منافق ہیں اور بعض مدینہ والے بھی جو اپنے نفاق پر اڑے ہوئے ہیں ۔","«مَرَدَ» کسی چیز کا ایسی چیز سے خالی ہونا جو اسمیں ہونا چاہئے ۔","اَڑنا","مرد","9:101",1
209,37,"ا","لَجَّ","«لَجَّ» بمعنی ضد کی وجہ سے جھگڑنا ۔ دشمنی میں مداومت کرنا یعنی دشمنی پالنا (منجد) اور «لَجَّۃً» بمعنی پانی کی گہرائی اور«بَحْرٍ لُّجِیِّ» بمعنی گہرا سمندر اور «اِلْتَجَّ الْبَحْر» بمعنی سمندر کا ہیجان یا طوفان میں آنا اور متلاطم ہونا (منجد) گویا «لَجَّ» کے معنی کسی برے کام میں دور دراز تک چلے جانے کا مفہوم پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَوۡ رَحِمۡنٰہُمۡ وَکَشَفۡنَا مَا بِہِمۡ مِّنۡ ضُرٍّلَّلَجُّوۡا فِیۡ طُغۡیَانِہِمۡ یَعۡمَہُوۡنَ» ( 23/75 )\nترجمہ : اور اگر ہم ان پر رحم کریں اور جو تکلیفیں ان کو پہنچ رہی ہیں وہ دور کر دیں تو اپنی سرکشی پر اڑے رہیں (اور) بھٹکتے پھریں ۔","«لَجَّ» دشمنی پالنا اور دشمنی میں بہت آگے تک نکل جانا ۔","اَڑنا","لج","23:75-67:21",2
210,38,"ا","اَذْرٰی","«ذِرَءُ» بمعنی  کلام کا ٹکڑا (یعنی ادھوری بات ) اور «ذَرَاَتِ الرِّیْح» بمعنی ہوا نے ٹکڑے ٹکڑے چیزوں کو اٹھایا اوردورلے گئی (م ۔ ل) اور «اَذْرٰی» بمعنی ہوا کا ہلکی پھلکی چیزوں کو بکھیرکراڑانا ۔ ابن الفارس کے نزدیک «ذَرْوُ» سے مراد ایسی چیزوں کا ہوا میں اڑنا ہے جو بعد میں الگ الگ ہو کر نیچے گر پڑیں (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«فَاخۡتَلَطَ بِہٖ نَبَاتُ الۡاَرۡضِ فَاَصۡبَحَ ہَشِیۡمًا تَذۡرُوۡہُ  الرِّیٰحُ» ( 18/45 )\nترجمہ : تو اس سے زمین کا سبزہ خوب گھنا ہوگیا ، پھر وہ ایسا ریزہ ریزہ ہوا کہ اسے ہوائیں اڑا لے جاتی ہیں ۔","«ذَرْوُ» چھوٹی چھوٹی چیزوں کو ہوا میں اڑانے کے لیے استعمال ہوتا ہے ۔","اُڑنا","اذری","18:45-51:1",2
211,38,"ا","نَسَفَ","«نَسَفَ الْحَبَّ» غلہ کو چھاج سے پھٹکنا اور «مِنْسَف» چھاج اور چھلنی وغیرہ جس سے غلہ صاف کیا جائے اور «نَسَفَ الرِّیْح» بمعنی ہوا کا کسی چیز کو جڑ سے اکھاڑ کر پھینک دینا (مف منجد) اور بمعنی پہاڑ وغیرہ کو کوٹنا اور اسے ہوا میں اڑا دینا (م ۔ ا)\nمثلاً : قرآن کریم میں ہے :\n«وَ یَسۡئَلُوۡنَکَ عَنِ الۡجِبَالِ فَقُلۡ یَنۡسِفُہَا رَبِّیۡ  نَسۡفًا» ( 20/105 )\nترجمہ : اور تم سے پہاڑوں کے بارے میں پوچھتے ہیں ، کہہ دو کہ خدا اُن کو اڑا کر بکھیر دے گا ۔","«نَسَفَ» کسی چیز کو ملیا میٹ کر دینا ۔","اُڑنا","نسف","20:97-20:105-77:10",3
212,38,"ا","طَارَ ، اِسْتَطَار","«اَلطَّائِر» ہر پر دار جانور کو کہتے ہیں جو فضا میں حرکت کرتا ہے اور «طَارَ یَطِیْر» بمعنی پرندہ کا اڑنا اور «طَیْر» جمع ہے «طَائِر» کی ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا طٰٓئِرٍ یَّطِیۡرُبِجَنَاحَیۡہِ» ( 6/38 )\nترجمہ : اور نہ ہی کوئی پرندہ جو اپنے دونوں پروں سے اڑتا ہے ۔\nاور «غُبَارٌ مُّسْتَطَارٌ» بمعنی ہوا میں اڑ کر منتشر ہو جانے والا غبار (مف) یعنی «اِسْتَطَار» کے معنی کسی چیز کا ہوا یا فضا میں اڑ کر منتشر ہو جانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یَخَافُوۡنَ یَوۡمًا کَانَ شَرُّہٗ مُسۡتَطِیۡرًا» ( 76/7 )\nترجمہ : اور وہ لوگ ڈرتے ہیں اس دن سے جس کی برائی ہے پھیلی ہوئی ۔ (عثمانیؒ)","«طَارَ» ہوا میں اُڑنے والے پرندے کے لئے استعمال ہوتا ہے ۔","اُڑنا","طار ، استطار","6:38-76:7",2
213,39,"ا","اَشَارَ","«اَشَارَ» بمعنی منہ کھولے بغیر ہاتھ کی حرکت سے کسی کو کوئی بات سمجھانا ( ف ل ، 174 )\nمثلاً : قرآن کریم میں ہے :\n«فَاَشَارَتۡ اِلَیۡہِ ؕ قَالُوۡا کَیۡفَ نُکَلِّمُ مَنۡ کَانَ فِی الۡمَہۡدِ صَبِیًّا» ( 19/29 )\nترجمہ : تو مریمؑ نے بچے کی طرف اشارہ کر دیا ۔ وہ کہنے لگے ہم اس سے کہ ابھی گود کا بچہ ہے کیسے بات کریں ؟","«اَشَارَ» ہاتھ کی حرکت سے اشارہ کرنے کے لیے استعمال ہوتا ہے ۔","اشارہ","اشار","19:29",1
214,39,"ا","رَمَزَ","«رَمَزَ» ہونٹ سے اشارہ کرنے یا ہلکی سی آواز نکالنے کو کہتے ہیں (ف ل 174) اور ہر وہ کلام جو اشارہ کی طرح کا ہو وہ رمز ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَ اٰیَتُکَ اَلَّا تُکَلِّمَ النَّاسَ ثَلٰثَۃَ اَیَّامٍ اِلَّا رَمۡزًا» ( 3/41 )\nترجمہ : اللہ تعالیٰ نے فرمایا : تمہارے لیے نشانی یہ ہے کہ تم لوگوں سے تین دن اشارے کے سوا بات نہ کر سکو گے ۔","«رَمَزَ» ہونٹوں یا آنکھوں سے اشارہ کرنے کے لیے استعمال ہوتا ہے ۔","اشارہ","رمز","3:41",1
215,39,"ا","تَغَامَز","«غَمْزُ» یعنی پلکوں اور ابروؤں سے بات سمجھانا (ف ل 174) اور ابن الفارس کے بقول کسی جانور کو کوئی چیز چبھونا تاکہ چل پڑے (م ل ۔ منجد) اور «تَغَامَز» بمعنی کسی کی عیب جوئی کرنے کے لیے ابرو سے اشارہ کرنا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاِذَا مَرُّوۡا بِہِمۡ یَتَغَامَزُوۡنَ» ( 83/30 )\nترجمہ : اور جب ان کے پاس سے گزرتے تو حقارت سے اشارے کرتے ۔","«غَمْزُ» پلکوں اور ابرو کے اشارے سے بات سمجھانا ۔","اشارہ","تغامز","83:30",1
216,39,"ا","عَرَّض","«عَرَضَ» بمعنی پیش کرنا اور «عَرَّضَ» بمعنی اشارہ اور کنایۃ میں بات کرنا اور امام راغب کے نزدیک تعریض کے معنیٰ پہلو دار بات  کرنا (یعنی ایسی بات جس کے مختلف معنی نکلتے ہوں ) جو سچ اور جھوٹ اور ظاہر و باطن دونوں پر محمول ہو سکتی ہو (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَلَا جُنَاحَ عَلَیۡکُمۡ فِیۡمَا عَرَّضۡتُمۡ بِہٖ مِنۡ خِطۡبَۃِ النِّسَآءِ» ( 2/235 )\nترجمہ : اور ( عدت کے دوران ) اگر تم کنایہ کی باتوں میں عورتوں کو نکاح کا پیغام بھیجو تو تم پر کچھ گناہ نہیں ۔","«عَرَّضَ» میں اشارہ کرنا مقصود نہیں بلکہ اشارہ کنایہ سے بات سمجھانا مقصود ہوتا ہے ۔","اشارہ","عرض","2:235",1
217,40,"ا","تَبِعَ","«تَبِعَ» بمعنی کسی کے پیچھے لگنا یا اس کے نقش قدم پر چلنا (مف) اور یہ ظاہری اور باطنی دونوں طرح استعمال ہوتا ہے ۔ باطنی طور پر جیسے دین کی  ہدایت کی    پیروی کرنا  یا کسی شخص کے عادات و اطوار کی پیروی کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَمَنۡ تَبِعَ ہُدَایَ فَلَا خَوۡفٌ عَلَیۡہِمۡ وَلَا ہُمۡ یَحۡزَنُوۡنَ» ( 2/38 )\nترجمہ : جس نے میری ہدایت کی پیروی کی ان کو نہ کچھ خوف ہو گا اور نہ وہ غمناک ہوں گے ۔\nاور ظاہری طور پر کسی شخص کے پیچھے پیچھے چلنے کے لیے «اَتْبَعَ» آتا ہے ۔\nمثلاً :قرآن کریم میں ہے :\n«فَاَتۡبَعَہُمۡ فِرۡعَوۡنُ بِجُنُوۡدِہٖ» ( 20/78 )\nترجمہ : پھر پیچھا کیا فرعون نے اپنے لشکروں کو لے کر ( عثمانیؒ )","«تَبِعَ» بمعنی کسی کے پیچھے لگنا یا اس کے نقش قدم پر چلنا اور یہ ظاہری اور باطنی دونوں طرح استعمال ہوتا ہے ۔","اطاعت","تبع","2:38-2:102-2:120-2:143-2:145-2:166-2:167-2:168-2:170-2:208-2:262-2:263-3:7-3:20-3:31-3:53-3:55-3:68-3:73-3:95-3:162-3:167-3:174-4:27-4:83-4:115-4:125-4:135-5:16-5:48-5:49-5:77-6:50-6:56-6:106-6:116-6:142-6:148-6:150-6:153-6:155-7:3-7:18-7:90-7:142-7:157-7:158-7:175-7:176-7:193-7:203-8:64-9:42-9:100-9:117-10:15-10:35-10:36-10:66-10:89-10:90-10:109-11:27-11:59-11:60-11:97-11:99-11:116-12:38-12:108-13:37-14:21-14:36-14:44-15:18-15:42-15:65-16:123-17:47-17:63-18:28-18:66-18:70-18:85-18:89-18:92-19:43-19:59-20:16-20:47-20:78-20:90-20:93-20:108-20:123-20:134-22:3-23:44-23:71-24:21-25:8-26:40-26:52-26:60-26:111-26:215-26:224-28:35-28:42-28:47-28:49-28:50-28:57-29:12-30:29-31:15-31:21-33:2-34:20-36:11-36:20-36:21-37:10-38:26-38:85-39:18-39:55-40:7-40:38-40:47-42:15-43:61-44:23-45:18-46:9-47:3-47:14-47:16-47:28-48:15-52:21-53:23-53:28-54:3-54:24-57:27-71:21-75:18-77:17-79:7",150
218,40,"ا","اِقْتِدَا","«اِقْتِدَا» بمعنی کسی کی پیروی کرنا اور اس  کے جیسا کام کرنا اور «اَقْدٰی» کے معنی نیکی اور دین کے راستہ میں کسی کی پیروی کرنا ہے (منجد) جیسا کہ مقتدی نماز کی حالت میں امام کی اقتداء کرتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اُولٰٓئِکَ الَّذِیۡنَ ہَدَی اللّٰہُ  فَبِہُدٰىہُمُ اقۡتَدِہۡ» ( 6/90 )\nترجمہ : یہ وہ لوگ ہیں جن کو خدا نے ہدایت دی تھی تو تم انکی ہدایت کی پیروی کرو ۔\nاور اقتداء کا لفظ برے مفہوم میں بھی استعمال ہو سکتا ہے ۔ «قُدْوَۃ» دراصل انسان کی اس حالت کو کہتے ہیں جب وہ کسی دوسرے کا  تابع  ہو (مف) اور «قُدْوَۃ» ، مقتدا ، رہنما اور پیشوا کے معنی میں بھی آتا ہے ۔\nمثلاً : قرآن کریم میں ہے ۔\n«اِنَّا وَجَدۡنَاۤ اٰبَآءَنَاعَلٰۤی اُمَّۃٍ وَّ اِنَّاعَلٰۤی اٰثٰرِہِمۡ مُّقۡتَدُوۡنَ» ( 43/23 )\nترجمہ : ہم نے اپنے باپ دادا کو ایک راہ پر پایا اور ہم ان ہی کے قدم بقدم چل رہے ہیں ۔","«اِقْتِدَا» بمعنی کسی کے پیچھے چلنا اور اس کے جیسا کام کرنا ۔","اطاعت","اقتدا","6:90-43:23",2
219,40,"ا","اُسْوَۃٌ ، قُدْوَۃٌ","«اُسْوَۃٌ» اور «قُدْوَۃٌ» ان دونوں کے معنیٰ قریب قریب ہیں ۔ بطور نمونہ یا قابل اتباع  حالت کے لیے آتے ہیں فرق صرف یہ ہے کہ «اُسْوَۃٌ» میں مواساۃ یعنی آپس میں ہمدردی اور غمساری کا پہلو بھی پایا جاتا ہے ۔ گویا اسوہ ایسا نمونہ ہے جس سے تسلی بھی ہو سکے اور «اٰسِیْ» مرہم پٹی کرنے والے ، طبیب اور صلح جو (یعنی صلح) کرنے والے  کو کہتے ہیں (مف ۔ م ل منجد) گویا «اُسْوَۃٌ» کا لفظ «قُدْوَۃٌ» سے زیادہ  فصیح  و ابلغ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«لَقَدۡ کَانَ لَکُمۡ  فِیۡ رَسُوۡلِ اللّٰہِ  اُسۡوَۃٌ حَسَنَۃٌ» ( 33/21 )\nترجمہ : حقیقت یہ ہے کہ تمہارے لیے رسول اللہ کی ذات میں ایک بہترین نمونہ ہے ۔ (تقی عثمانی)\nتم کو پیغمبر خدا کی پیروی (کرنی) بہتر ہے  (جالندھری)","«اُسْوَۃٌ» جذبہِ ہمدردی کے ساتھ  کسی مثالی کردار کی اتباع کرنا ۔","اطاعت","اسوۃ ، قدوۃ","33:21-60:4-60:6",3
220,40,"ا","اَطَاعَ","«طَوْعَ» بمعنی دل کی خوشی اور رضامندی اور اسکی ضد «کَرْہٌ» ہے  بمعنی کراہت ، نفرت ، ناپسندیدگی ۔ اور «اَطَاعَ» سے مراد ایسی فرمانبرداری ہے جو دل کی خوشی سے سرانجام دی جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَقَالَ لَہَا وَ لِلۡاَرۡضِ ائۡتِیَا طَوۡعًا اَوۡ کَرۡہًا ؕ قَالَتَاۤ اَتَیۡنَا طَآئِعِیۡنَ» ( 41/11 )\nترجمہ : اللہ تعالیٰ نے آسمان سے اور زمین سے کہا کہ آؤ خواہ خوشی سے یا ناخوشی سے ۔ انہوں نے کہا کہ ہم خوشی سے آتے ہیں ۔","«اَطَاعَ» دل کی خوشی کے ساتھ کسی کا حکم بجا لانا ۔","اطاعت","اطاع","2:184-3:83-3:168-4:64-4:80-4:81-13:15-24:53-40:18-41:11-43:54-47:21-81:21",13
221,40,"ا","اِسْتَجَابَ","«اِسْتَجَابَ» بمعنی جواب دینا ۔ بات ماننا ۔ فرمانبرداری کرنا ۔ حکم مان لینا ان تمام معنوں میں استعمال ہوتا ہے ۔ اطاعت اور استجابت میں فرق یہ ہے کہ اطاعت صرف بڑے کی کی جاتی ہے جبکہ استجابت چھوٹا بھی بڑے کی کر سکتا ہے اگر اس کی نسبت اللہ کی طرف ہو تو اس کا معنی اللہ کے بندے کی دعا کو قبول کر لینا ہے اور اگر اس کی نسبت بندے کی طرف ہو تو اس کا معنی بندے کا اللہ کا حکم مان لینا ہے (فق ل 184)\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوا اسۡتَجِیۡبُوۡا لِلّٰہِ وَ لِلرَّسُوۡلِ» ( 8/24 )\nترجمہ : اے ایمان والو ! اللہ اور اس کے رسول کا حکم قبول کرو ۔","«اِسْتَجَابَ» حکم قبول کرنا اور اس پر عمل کرنا ، بات مان لینا اور یہ بڑے سے بھی ممکن ہے ۔","اطاعت","استجاب","2:186-3:172-3:195-6:36-7:194-8:9-8:24-11:14-12:34-13:14-13:18-17:52-28:50-28:64-35:14-42:16-42:26-42:38-42:47-46:5",20
222,40,"ا","اَسْلَمَ","«السَّلْم» بمعنی صحت و عافیت (م ل) اور بمعنی ظاہری اور باطنی آفات سے محفوظ ہونا (مف) اور «اَسْلَمَ» بمعنی اطاعت اختیار کرنا اور خدا کے احکام اور اس کی رضا کے سامنے سر تسلیم خم کر دینا تاکہ اخروی عذاب سے امن اور عافیت حاصل ہو ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«اِذۡ قَالَ لَہٗ رَبُّہٗۤ  اَسۡلِمۡ ۙ قَالَ اَسۡلَمۡتُ لِرَبِّ الۡعٰلَمِیۡنَ» ( 2/131 )\nترجمہ : جب حضرت ابراہیم ؑ کے پروردگار نے ان سے فرمایا کہ اسلام لے آؤ تو انہوں نے عرض کی کہ میں رب العالمین کے سامنے سر اطاعت خم کرتا ہوں ۔","«اَسْلَمَ» کسی کی رضا کے سامنے سر تسلیم خم کر دینا ۔","اطاعت","اسلم","2:112-2:131-3:20-3:83-4:65-4:125-5:44-6:14-6:71-22:34-27:44-37:103-39:54-40:66-49:14-49:17-72:14",17
223,40,"ا","قَنَتَ","«قَنَتَ» بمعنی تمام و کمال خاموشی سے نماز میں کھڑا ہونا اور اللہ تعالیٰ کے آگے خشوع و خضوع کرنا (منجد) اور امام راغب کے نزدیک ’’ عبادت میں ہمہ تن مصروف ہونا اور غیر سے توجہ ہٹانا ‘‘ ہے (مف) گویا قنوت ایسی اطاعت ہے جو پورے خشوع و خضوع اور اور توجہ سے بجا لائی جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ مَنۡ یَّقۡنُتۡ مِنۡکُنَّ لِلّٰہِ وَ رَسُوۡلِہٖ وَ تَعۡمَلۡ صَالِحًا نُّؤۡتِہَاۤ اَجۡرَہَا مَرَّتَیۡنِ» ( 33/31 )\nترجمہ : اور (اے نبی کی بیویو) جو تم میں سے اللہ اور اس کے رسول کی فرمانبردار رہے گی اور بھلے کام کرے گی اس کو ہم دگنا ثواب دیں گے !","«قَنَتَ» عبادات میں ایسی اطاعت جس میں عاجزی و انکساری  بھی ہو ۔","اطاعت","قنت","3:43-33:31",2
224,40,"ا","ذَعَنَ","«ذَعَنَ» بمعنی مطیع و  فرماں بردار ہونا اور اشاروں پر چلنا اور «مِذْعَان» بمعنی آسانی سے فرمانبردار ہو جانے والا (منجد) اور «نَاقَۃٌ مِّذْعَانٌ» سوار کی تابع اور فرمانبردار اونٹنی کو کہتے ہیں (مف) گویا «ذَعَنَ» میں اطاعت کے ساتھ عاجزی اور ذلت کا پہلو بھی پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ اِنۡ یَّکُنۡ  لَّہُمُ الۡحَقُّ یَاۡتُوۡۤا اِلَیۡہِ مُذۡعِنِیۡنَ» ( 24/49 )\nترجمہ : اور اگرحق ان کو پہنچتا ہو تو اس کی طرف مطیع ہو کر چلے آتے ہیں ۔\nبعض مفسرین نے «مُذْعِنِیْن» کا ترجمہ «مُطِیْعِیْن و سَارِعِیْن» کیا ہے ۔ یعنی اگر معاملہ ان کے حق میں جاتا ہو تو اسے قبول کرنے کو دوڑتے آتے ہیں ( فق ل 209 )","«ذَعَنَ» اپنے مفاد کی خاطرکسی کی اطاعت کرنا ۔","اطاعت","ذعن","24:49",1
225,41,"ا","قَصْد","«قَصْد» اور «اِقْتِصَاد» کے معنی افراط اور تفریط سے بچتے ہوئے درمیانی راہ کو اختیار کرنے کے ہیں ۔ فرق صرف یہ ہے کہ «اِقْتِصَاد» کا استعمال عمومًا خرچ اخراجات سے متعلق ہے جبکہ قصد کا لفظ عام ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ اقۡصِدۡ فِیۡ  مَشۡیِکَ» ( 31/19)\nترجمہ : اپنی چال میں اعتدال کو ملحوظ رکھو ۔\nاور «قَصْدُ السَّبِیْل» سے مراد افراط و تفریط سے بچتے ہوئے درمیانی اور اعتدال کی راہ اختیار کرنا ہے اور یہی ایک راستہ سیدھا ہو سکتا ہے ۔ جبکہ باقی سب راستے افراط یا تفریط کی طرف مائل یا ٹیڑھے ہی ہوں گے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَعَلَی اللّٰہِ قَصۡدُ السَّبِیۡلِ وَ مِنۡہَا جَآئِرٌ» ( 16/9 )\nترجمہ : اور اللہ پر پہنچتی ہے سیدھی راہ ( عثمانی ) اور اس کے علاوہ سب راہیں ٹیڑھی ہیں ۔\nنوٹ : (افراط و تفریط : کممی بیشی ، غیر معتدل حالت ، کم و بیش ، تھوڑا بہت ۔\nافراط : اِفراط کے معنی ہیں : حد سے تجاوز کرنا، کسی کے مقام کو بیان کرنے میں مبالغہ کرنا‘‘۔ اس کو قرآنِ کریم نے 'غُلُوّ‘‘ سے تعبیر کیا ہے اور عربی میں اسے 'تَطرُّف‘‘ (Excessiveness) بھی کہتے ہیں۔\nتفریط : کے معنی ہیں: کسی کے مقام میں کمی کرنا اور اُسے اس کے مرتبے سے گرا دینا ۔","«قَصْد» کسی عمل میں افراط و تفریط سے بچ کر اعتدال کی راہ اختیار کرنا  ۔","اعتدال","قصد","9:42-16:9-31:19",3
226,41,"ا","وَسْط","«وَسْط» ایک ہی چیز کا درمیان یا دو یا دو سے زیادہ چیزوں کی درمیانی چیز ۔ گویا کہ یہ لفظ قصد سے زیادہ قوی ہے اور «وَسَطَ» بمعنی ہر ایک معاملہ میں درمیانی اور اعتدال کی راہ اختیار کرنے والا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ کَذٰلِکَ جَعَلۡنٰکُمۡ اُمَّۃً وَّسَطًا لِّتَکُوۡنُوۡا شُہَدَآءَ عَلَی النَّاسِ» ( 2/143 )\nترجمہ : اور اسی طرح ہم نے تم کو امت معتدل بنایا ہے تاکہ تم لوگوں پر گواہ ہو ۔","«وَسْط» کسی ایک ہی چیز کا درمیان یا دو یا دو سے زیادہ چیزوں کی درمیانی چیز کے لیے استعمال ہوتا ہے ۔","اعتدال","وسط","2:143-2:238",2
227,41,"ا","تَقْوِیْم","«تَقْوِیْم» کا تعلق ایک ہی چیز سے ہوتا ہے کہ اس میں افراط و تفریط کے جملہ پہلوؤں کو دور کر دیا جائے ۔ اور وہ متوازن ، متناسب اور معتدل بن جائے ۔ اس میں کوئی جھول ، ڈھلک اور ٹیڑھ نہ رہے ( فق ل 174 ) «قَوْمُ الشَّیءِ» بمعنی کسی چیز کی تعیین و تعدیل کرنا اسی سے «تَقْوِیْمُ الْبَدَان» بنایا گیا ہے کیونکہ اس میں شہروں کے طول و عرض کو بیان کیا جاتا ہے اور «قَوَّمَ دَرْأَہٗ» بمعنی ٹیڑھے پن کو سیدھا کرنا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«لَقَدۡ خَلَقۡنَا الۡاِنۡسَانَ فِیۡۤ  اَحۡسَنِ تَقۡوِیۡمٍ» ( 95/4 )\nترجمہ : بیشک ہم نے انسان کو بہترین اندازے پر پیدا کیا ہے ۔","«تَقْوِیْم» ایک ہی چیز میں ہر پہلو سے اعتدال کو ملحوظ رکھنا ۔","اعتدال","تقویم","95:4",1
228,42,"ا","طَائر","«طَائِر» بمعنی پرندہ «طَیْر» اور «تَطَیَّرْ» اور «اطَّیَّرَ» بمعنی پرندہ سے شگون لینا اورپھر یہ لفظ برے مفہوم میں بھی استعمال ہونے لگا ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا طَآئِرُکُمۡ مَّعَکُمۡ» ( 36/19 )\nترجمہ : وہ کہنے لگے تمہاری نحوست تمہارے اپنے ہی ساتھ ہے ۔\nاور جب انسان کوئی عمل کرلیتا ہے تو اس پر اسے کوئی اختیار نہیں رہتا ۔ گویا وہ اس کے ہاتھوں سے یوں اڑ گیا جیسے پرندہ اڑ جاتا ہے ۔ اس پہلو سے انسان کے اعمال کو بھی طائر سے تعبیر کیا گیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ کُلَّ  اِنۡسَانٍ اَلۡزَمۡنٰہُ طٰٓئِرَہٗ  فِیۡ عُنُقِہٖ» ( 17/13)\nترجمہ : اور ہر انسان کا نامہ اعمال اس کے گلے میں لٹکا دیا ہے ۔","«طَائِر» بمعنی پرندہ ۔ انسان کے اعمال کو بھی طائر سے تعبیر کیا گیا ہے اور جب انسان کوئی عمل کر لیتا ہے تو اسکے بعد اس پراسے کوئی اختیار نہیں رہتا ۔ گویا وہ اس کے ہاتھوں سے یوں اڑ گیا جیسے پرندہ اڑ جاتا ہے ۔","اعمال","طائر","6:38-7:131-17:13-27:47-36:19",5
229,42,"ا","کتاب","«کَتَب» بمعنی لکھنا اور ہر قسم کی تحریر چھوٹی ہو یا بڑی  خط ہو یا اخبار کوئی موٹی کتاب سب پر اس لفظ کا اطلاق ہوتا ہے ۔ اور انسان کے اعمال بھی ساتھ ہی ساتھ کرامًا کاتبین تحریر کرتے جا رہے ہیں ۔ لہذا اعمال نامہ کو اس لحاظ سے تحریر کہا گیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ نُخۡرِجُ لَہٗ یَوۡمَ الۡقِیٰمَۃِ کِتٰبًا  یَّلۡقٰىہُ  مَنۡشُوۡرًا» ( 17/13)\nترجمہ : اور ہم وہ کتاب اسے قیامت کے دن نکال دکھائیں گے جسے وہ کھلا ہوا دیکھے گا ۔","«کِتَاب» ہر لکھے یا چھپے ہوئے اورراق کے مجموعہ کو کتاب کہا جاتا ہے ۔ ","اعمال","کتاب","2:2-2:44-2:53-2:78-2:79-2:85-2:87-2:89-2:101-2:105-2:109-2:113-2:121-2:129-2:144-2:145-2:146-2:151-2:159-2:174-2:176-2:177-2:213-2:231-2:235-3:3-3:7-3:19-3:20-3:23-3:48-3:64-3:65-3:69-3:70-3:71-3:72-3:75-3:78-3:79-3:81-3:98-3:99-3:100-3:110-3:113-3:119-3:145-3:164-3:184-3:186-3:187-3:199-4:24-4:44-4:47-4:51-4:54-4:103-4:105-4:113-4:123-4:127-4:131-4:136-4:140-4:153-4:159-4:171-5:5-5:15-5:19-5:44-5:48-5:57-5:59-5:65-5:68-5:77-5:110-6:7-6:20-6:38-6:59-6:89-6:91-6:92-6:114-6:154-6:155-6:156-6:157-7:2-7:37-7:52-7:169-7:170-7:196-8:68-8:75-9:29-9:36-10:1-10:37-10:61-10:94-11:1-11:6-11:17-11:110-12:1-13:1-13:36-13:38-13:39-13:43-14:1-15:1-15:4-16:64-16:89-17:2-17:4-17:13-17:14-17:58-17:71-17:93-18:1-18:27-18:49-19:12-19:16-19:30-19:41-19:51-19:54-19:56-20:52-21:10-22:8-22:70-23:49-23:62-24:33-25:35-26:2-27:1-27:28-27:29-27:40-27:75-28:2-28:43-28:49-28:52-28:86-29:27-29:45-29:46-29:47-29:48-29:51-30:56-31:2-31:20-32:2-32:23-33:6-33:26-34:3-35:11-35:25-35:29-35:31-35:32-35:40-37:117-37:157-38:29-39:1-39:2-39:23-39:41-39:69-40:2-40:53-40:70-41:3-41:41-41:45-42:14-42:15-42:17-42:52-43:2-43:4-43:21-44:2-45:2-45:16-45:28-45:29-46:2-46:4-46:12-46:30-50:4-52:2-56:78-57:16-57:22-57:25-57:26-57:29-59:2-59:11-62:2-68:37-69:19-69:25-74:31-78:29-83:7-83:9-83:18-83:20-84:7-84:10-98:1-98:4-98:6",232
230,42,"ا","قِطّ","«قِطّ» بمعنی حساب کا رجسٹر ۔ حکم نامہ ۔ محاسبہ کی تحریر ۔ احکام (منجد ۔ مف) اعمال نامہ کو اس لحاظ سے قرآن میں قِطّ کہا گیا ہے کہ یہی تحریر انسان کے محاسبہ کی بنیاد ہو گی ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ قَالُوۡا رَبَّنَا عَجِّلۡ  لَّنَا قِطَّنَا قَبۡلَ یَوۡمِ  الۡحِسَابِ» ( 38/16 )\nترجمہ : اور کہتے ہیں کہ : اے ہمارے پروردگار ! ہمار احصہ ہمیں روز حساب سے پہلے ہی جلدی دیدے ۔ ","«قِطّ» وہ رجسٹر جس میں حساب کتاب لکھا جاتا ہو ۔","اعمال","قط","38:16",1
231,42,"ا","صُحُف","«صُحُف» (واحد صیغہ) بمعنی پھیلی ہوئی چیز اور ہر وہ چیز جس پر کچھ لکھا جاتا ہے (مف) صحیفہ بمعنی لکھا ہوا کاغذ ۔ ورق اور «صِحَافَۃ» بمعنی اخبار نویسی اور «اَصْحَفَ» بمعنی صحیفوں یا لکھے ہوئے اوراق کو کتاب کی صورت میں جمع کرنا اور «مُصْحَف» بمعنی کتاب  اور جمع اسکی  «مَصَاحِف»  ہے (منجد) اور اعمال نامہ کو اس پہلو سے صحیفہ کہا گیا ہے کہ یہ بڑے بڑے پھیلے ہوئے صفحات کی صورت میں ہو گا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِذَا الصُّحُفُ نُشِرَتۡ» ( 81/10 )\nترجمہ : اور جب ( عملوں کے ) دفتر کھولے جائیں گے ۔","«صُحُف» لکھے ہوئے کاغذوں کو کتابی شکل میں جمع کرنا ۔","اعمال","صحف","20:133-53:36-74:52-80:13-81:10-87:18-87:19-98:2",8
232,43,"ا","وَیْلَ","«وَیْلَ» کلمۂ وعید ہے جو اپنی اصل کے لحاظ سے بد دعا کے طور پر استعمال ہوتا ہے اور «وَیْلُ» (اسم) بمعنی شر و برائی کا نزول ۔ ہلاکت ، بہت سخت مصیبت (منجد) اور «تَوَایَل» بمعنی ایک دوسرے کو بددعا دینا (منجد) «وَیْل» کا لفظ برے معنوں میں استعمال ہوتا ہے اور حسرت کے موقع پر بولا جاتا ہے (م ۔ ر) اور جب انسان کسی مصیبت یا پریشانی میں گرفتار ہو تو اس کلمہ سے افسوس کا اظہار کرتا ہے ۔ اب اس کی مثالیں دیکھئے :\n(1) مصیبت کے وقت مثال : ارشاد باری تعالیٰ ہے :\n«قَالُوۡا یٰوَیۡلَنَا مَنۡۢ بَعَثَنَا مِنۡ مَّرۡقَدِنَا» ( 36/52 )\nترجمہ : کہیں گے ۔ اے ہائے ! ہمیں ہماری خوابگاہوں سے کس نے جگا دیا ؟\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَیۡلٌ  یَّوۡمَئِذٍ  لِّلۡمُکَذِّبِیۡنَ» ( 77/15 )\nترجمہ : اس دن جھٹلانے والوں کے لیے خرابی ہے ۔\n(2) پریشانی کے وقت مثال : ارشاد باری تعالیٰ ہے :\n«فَبَعَثَ اللّٰہُ غُرَابًا یَّبۡحَثُ فِی الۡاَرۡضِ لِیُرِیَہٗ کَیۡفَ یُوَارِیۡ سَوۡءَۃَ اَخِیۡہِ ؕ قَالَ یٰوَیۡلَتٰۤی اَعَجَزۡتُ اَنۡ  اَکُوۡنَ مِثۡلَ  ہٰذَا الۡغُرَابِ» ( 5/31 )\nترجمہ : اب خدا نے ایک کوّا بھیجا جو زمین کریدنے لگا ، تاکہ اسے دکھائے کہ اپنے بھائی کی لاش کو کیسے چھپائے ، کہنے لگا ہائے افسوس ! مجھ سے اتنا بھی نہ ہو سکا کہ اس کوّے کے برابر ہوتا ۔","«وَیْلَ» یہ اظہارِ افسوس کا کلمہ ہے جو کسی پریشانی اور مصیبت میں انسان کے منہ سے نکل جاتا ہے ۔","افسوس","ویل","2:79-5:31-11:72-14:2-18:49-19:37-20:61-21:14-21:18-21:46-21:97-25:28-28:80-36:52-37:20-38:27-39:22-41:6-43:65-45:7-46:17-51:60-52:11-68:31-77:15-77:19-77:24-77:28-77:34-77:37-77:40-77:45-77:47-77:49-83:1-83:10-104:1-107:4",38
233,43,"ا","لَیْتَ","«لَیْتَ» حرف تمنّی مشبہ بالفعل ہے اور گزشتہ کوتاہی پر اظہار افسوس کے لیے آتا ہے (مف) بمعنی اے کاش کہ ، کاش کہ ۔ افسوس ۔ اور ایسی آرزو کے لیے آتا ہے جس کا پورا ہونا ناممکن ہو ۔ جیسے «لَیْتَ الشَّبَابُ عَائِدًا» ۔ کاش جوانی لوٹ آتی ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یَقُوۡلُ الۡکٰفِرُ یٰلَیۡتَنِیۡ  کُنۡتُ تُرٰبًا» ( 78/40 )\nترجمہ : اور (قیامت کے دن) کافر کہے گا ۔ اے کاش ! میں مٹی ہو چکا ہوتا ۔\nنوٹ : (حروف مشبہ بالفعل : وہ حروف جو فعل کے مشابہ ہیں اور وہ چھ حروف ہیں : «إِنَّ، أَنَّ، کَأَنَّ، لٰـکِنَّ، لَیْتَ، لَعَلَّ»\nحرف تمنّی : وہ لفظ جس میں تمنا کا اظہار پایا جائے ۔","«لَیْتَ» حرفِ تمنی ہے اور گزشتہ کوتاہی پر اظہار افسوس کے لیے آتا ہے ۔","افسوس","لیت","4:73-6:27-18:42-19:23-25:27-25:28-28:79-33:66-36:26-43:38-69:25-69:27-78:40-89:24",14
234,43,"ا","اَسَفٰی","«اَسَفَ» افسوس اورغم کے ملے جلے جذبات کو کہتے ہیں ۔ غصہ جب کسی کمزور شخص پر آئے تو وہ غیظ و غضب کی شکل اختیار کرتا ہے اور جب اپنے سے طاقتور پر غصہ آئے تو وہ تنگ دل ہو کر غم اور افسوس بن جاتا ہے (مف فل 170)\nمثلاً : قرآن کریم میں ہے :\n«وَ قَالَ یٰۤاَسَفٰی عَلٰی یُوۡسُفَ وَ ابۡیَضَّتۡ عَیۡنٰہُ مِنَ الۡحُزۡنِ فَہُوَ کَظِیۡمٌ» ( 12/84 )\nترجمہ : اور (یعقوبؑ) نے کہا ہائے افسوس ! یوسف (ہائے افسوس) اور غم سے ان کی آنکھیں سفید ہو گئیں اور اس کا دل غم سے بھرا ہوا تھا ۔","«اَسَفَ» ایسے افسوس اورغم کو کہتے ہیں جہاں انسان کا بس نہ چل سکتا ہو ۔","افسوس","اسفی","7:150-12:84-18:6-20:86-43:55",5
235,43,"ا","آسٰی","«اَسٰی» بمعنیٰ کوئی موقعہ جو اپنی غفلت یا کوتاہی کی وجہ سے ہاتھ سے نکل جائے اس پرافسوس اورغم کا اظہار کرنا (ف ل 170)\nمثلاً : قرآن کریم میں ہے :\n«لِّکَیۡلَا تَاۡسَوۡا عَلٰی مَا فَاتَکُمۡ وَلَا تَفۡرَحُوۡا بِمَاۤ اٰتٰىکُمۡ» ( 57/23 )\nترجمہ : تاکہ جو کچھ تم سے فوت ہو گیا اس کا غم نہ کھایا کرو اور جو تم کو اس نے دیا ہو اس پر اترایا نہ کرو ۔","«اَسٰی» کوئی اچھا موقعہ اپنی کوتاہی سے کھو دینا ، اورپھر اس پر افسوس کرنا ۔","افسوس","آسی","7:93-57:23",2
236,44,"ا","مَکَّنَ","«مَکَّنَ» بمعنی قدرت دینا ، اختیار دینا ، قادر بنانا (منجد) جگہ اور منزلت پانا ۔ اپنے پاؤں پر قائم ہونا اور کسی چیز پر قادر ہونا (م ۔ ر) یعنی کسی کو اقتدار بخشنا اور حکومت عطا کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَّذِیۡنَ اِنۡ مَّکَّنّٰہُمۡ فِی الۡاَرۡضِ اَقَامُوا الصَّلٰوۃَ وَ اٰتَوُاالزَّکٰوۃَ وَاَمَرُوۡا بِالۡمَعۡرُوۡفِ وَ نَہَوۡا عَنِ الۡمُنۡکَرِ» ( 22/41 )\nترجمہ : یہ ایسے لوگ ہیں کہ اگر ہم انہیں زمین میں اقتدار بخشیں تو وہ نماز قائم کریں ، اور زکوٰۃ ادا کریں ، اور لوگوں کو نیکی کی تاکید کریں ، اور برائی سے روکیں ۔","«مَکَّنَ» عام طور پر کسی کو اقتدار ، اختیار اور حکومت دینے کے لیے استعمال ہوتا ہے ۔","اقتدار","مکن","6:6-7:10-8:71-12:21-12:56-18:84-18:95-22:41-24:55-28:6-28:57-46:26",12
237,44,"ا","اِسْتَخْلَفَ","«اِسْتَخْلَفَ» بمعنی کسی کو جانشین یا قائم مقام بنانا (منجد ۔ م ۔ ر) اور «خَلَفَ» بمعنی پیچھے آنا یا کسی کا جانشین ہونا ۔\nمثلاً : قرآن کریم میں ہے\n«وَعَدَ اللّٰہُ الَّذِیۡنَ اٰمَنُوۡا مِنۡکُمۡ وَعَمِلُوا الصّٰلِحٰتِ لَیَسۡتَخۡلِفَنَّہُمۡ فِی الۡاَرۡضِ» ( 24/55 )\nترجمہ : جو لوگ تم سے بھی ایمان لائے اور نیک کام کرتے رہے ان سے خدا کا وعدہ ہے کہ ان کو ملک کا حاکم بنا دے گا ۔\nگویا «اِسْتِخْلَاف» کا لفظ اس بات پر بھی دلالت کرتا ہے کہ موجود اقتدار برے آدمیوں کے ہاتھ میں ہے اور جو لوگ اللہ پر ایمان لائیں اور اچھے کام کریں تو اللہ تعالیٰ یہ موجودہ حکومت بدل کر اقتدار ان کے حوالے کر دے گا ۔","«اِسْتَخْلَفَ» بمعنی کسی کو جانشین یا قائم مقام بنانا ۔ ","اقتدار","استخلف","6:133-7:129-11:57-24:55-57:7",5
238,45,"ا","اَقْرَرَ","«اِقْرَار» اس کا اصل مادہ «قَرَار» ہے بمعنی کسی جگہ جم کر ٹھہرنا ۔ قرار پکڑنا اور «اَقْرَرَ» کے معنی کسی بات پر ثابت و قائم ہو جانا (م ۔ ر) اور اقرار عمومًا کسی معاملہ یا وعدہ سے متعلق ہوتا ہے جو زمانۂ مستقبل سے تعلق رکھتا ہو یعنی کسی وعدہ پر ثابت قدم اور قائم رہنا ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَ ءَاَقۡرَرۡتُمۡ وَ اَخَذۡتُمۡ عَلٰی ذٰلِکُمۡ اِصۡرِیۡ ؕ قَالُوۡۤا اَقۡرَرۡنَا ؕ قَالَ فَاشۡہَدُوۡا وَ اَنَا مَعَکُمۡ مِّنَ الشّٰہِدِیۡنَ» ( 3/81 )\nترجمہ : اللہ نے ( انبیاء سے عہد لینے کے بعد ) پوچھا کیا تم نے اقرار کیا اور اس اقرار پر میرا ذمہ لیا ( یعنی مجھے ضامن ٹھہرایا ) انہوں نے کہا ۔ ہاں ! ہم نے اقرار کر لیا ( خدا نے ) فرمایا کہ تم ( اس عہد و پیمان کے ) گواہ رہو اور میں بھی تمہارے ساتھ گواہ ہوں ۔","«اِقْرَار» کے معنی کسی بات پر ثابت و قائم ہو جانا ، کسی عہد و پیمان پر قائم ہونا ۔","اقرار","اقرر","2:84-3:81",2
239,45,"ا","اِعْتَرَفَ","«عَرَفَ» کے معنی کسی کو پہچان لینا اور «اَعْتَرَفَ» بمعنی اپنے جرم کا اقرار کر لینا اور ذلیل و خوار ہونا (م ۔ ر) گویا مجرم جو اپنے جرم سے بہرحال پہلے ہی واقف اور شناسا ہوتا ہے ۔ جب خود اس کا اقرار کر لے تو یہ اعتراف کہلاتا ہے اور اس جرم کا تعلق زمانہ ماضی سے ہوتا ہے جس کا اس نے اقرار کیا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاعۡتَرَفُوۡا بِذَنۡۢبِہِمۡ ۚ فَسُحۡقًا  لِّاَصۡحٰبِ السَّعِیۡرِ» ( 67/11 )\nترجمہ : تو ( گنہگار قیامت کو ) اپنے گناہوں کا اقرار کر لیں گے ۔ سو اہل جہنم کے لیے ( خدا کی رحمت سے ) دوری ہے ۔","«اِعْتَرَفَ» اپنے جرم کا اقرار کرنا جو زمانۂ ماضی میں ہو چکا ہو ۔","اقرار","اعترف","9:102-40:11-67:11",3
240,45,"ا","شَھِدَ","«شَھِدَ» بمعنی گواہی شہادت ۔ اور یہ شہادت دو قسم کی ہوتی ہے ۔ ایک عینی شہادت یعنی ایسی حقیقت جس کا انسان کو کلی طور پر یقین ہو اور وہ کا قاضی کے سامنے اسکی گواہی دیدے ۔\nدوسری قلبی شہادت جیسے کلمۂ شہادت ۔ جسکی ہر مسلمان گواہی دیتا ہے  حالانکہ انہوں نے اللہ کو دیکھا نہیں اور صحابہ ؓ کے علاوہ دوسرے مسلمانوں نے رسول اللہ کو بھی نہیں دیکھا ۔ پھر جب یہی قلبی شہادت اپنی ذات سے متعلق ہو تو اس کا معنی ’’ اقرار کرنا ‘‘ ہو گا ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا شَہِدۡنَا عَلٰۤی اَنۡفُسِنَا وَ غَرَّتۡہُمُ الۡحَیٰوۃُ الدُّنۡیَا» ( 6/130 )\nترجمہ : وہ کہیں گے پروردگار ! ہمیں اپنے گناہوں کا اقرار ہے اور ان لوگوں کو دنیا کی زندگی نے دھوکا میں ڈال رکھا تھا ۔","«شَھِدَ» بمعنی گواہی شہادت ایسی بات کا اقرار جس کا تعلق اپنی ذات سے ہو ۔","اقرار","شھد","2:23-2:84-2:133-2:143-2:185-2:204-2:282-3:18-3:52-3:64-3:70-3:81-3:86-3:99-3:140-4:6-4:15-4:69-4:135-4:166-5:8-5:44-5:111-6:19-6:130-6:144-6:150-7:37-7:172-9:107-11:54-12:26-12:81-18:51-19:37-21:61-22:28-22:78-24:2-24:4-24:6-24:8-24:13-24:24-25:72-27:32-27:49-36:65-39:69-41:20-41:21-41:22-43:19-43:86-46:10-57:19-59:11-63:1-65:2-83:21",60
241,46,"ا","اَحَد","«اَحَد» بمعنی لاثانی ۔ بے نظیر (منجد) اس لحاظ سے اس لفظ کا اطلاق صرف ذات باری تعالیٰ پر ہوتا ہے ۔ غیر باری تعالیٰ کے لیے «وَاحِد» کا لفظ استعمال ہوتا ہے (مف م ر) لیکن دو موقعوں پر «اَحَد» کا لفظ واحد کا رادف (بعد میں آنے والا) ہو کر آتا ہے ۔ (1) اسمائے عدد اور ان کی ترکیب میں جیسے «اَحَدَ عَشَرَ ، اَحَدَھُمَ ، اَحَدٌ مِّنْکُم ، اَحَدُکُم ، یَوَمُ الْاَحَد» وغیرہ (2) نفی کی صورت میں صرف ذوی العقول کے لیے آتا ہے ۔ جیسے «لَیْسَ فِی الدَّارِاَحَدٌ» ( گھر میں کوئی بھی نہیں ہے )\nمثلاً : قرآن کریم میں ہے :\n«فَمَا مِنۡکُمۡ  مِّنۡ اَحَدٍ عَنۡہُ حٰجِزِیۡنَ» ( 69/47 )\nترجمہ : پھر تم میں سے کوئی بھی ہم کو روکنے والا نہ ہو گا ۔\nاور واحد کا لفظ عام ہے ۔ اور اللہ تعالیٰ اور اسکے علاوہ سب کے لیے یکساں مستعمل ہے اور اللہ تعالیٰ کا ایک نام ہے جس کے معنی ایک کے ہیں ۔ جیسے «ھُوَ اللہُ الْوَاحِدُ الْقَھَّارُ» لیکن جب ہم  «قُلۡ ہُوَ اللّٰہُ اَحَدٌ» ( 112/1 )\nترجمہ : کہو کہ وہ ( ذات پاک جس کا نام ) اللہ ( ہے ) ایک ہے ۔\nکہتے ہیں تو اس کا مطلب یہ ہے کہ وہ یکتا ، بے نظیر اور لاثانی ہے ۔ اور ان کے معنوں میں یہ لفظ ذات باری تعالیٰ کے لیے خاص ہے ۔","«اَحَد» لاثانی بے مثل ، ان معنوں میں اللہ تعالیٰ کے لیے یا ایسی مخلوق کے لیے جس کی مثال نہ ہو استعمال ہوتا ہے ۔","اکیلا","احد","2:96-2:102-2:136-2:180-2:266-2:285-3:73-3:84-3:91-3:153-4:18-4:43-4:152-5:6-5:20-5:27-5:106-5:115-6:61-7:80-9:4-9:6-9:84-9:127-11:81-12:4-12:36-12:41-12:78-15:65-16:58-16:76-17:23-18:19-18:22-18:26-18:32-18:38-18:42-18:47-18:49-18:110-19:26-19:98-23:99-24:6-24:21-24:28-29:28-33:32-33:39-33:40-35:41-38:35-43:17-49:12-59:11-63:10-69:47-72:2-72:7-72:18-72:20-72:22-72:26-89:25-89:26-90:5-90:7-92:19-112:1-112:4",72
242,46,"ا","وَحِیْد","«وَاحِد» اور «وَحِیْد» جو چیز خلقت میں سے اکیلی اور یکتا ہو اور اس کی مثل نہ ہو اس کے لیے یہ  دونوں الفاظ استعمال ہوتے ہیں ۔ جیسے «اَلشَّمْسُ وَاحِدَۃٌ» ( سورج ایک ہی ہے ) ۔ یا «فُلَانٌ وَاحِدُ عَصْرِہٖ» ( فلاں شخص اکیلا روزگار ہے ) اور لفظ «وَحِیْد» انہیں معنوں میں آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ذَرۡنِیۡ وَ مَنۡ خَلَقۡتُ وَحِیۡدًا» ( 74/11 )\nترجمہ : ہمیں اس شخص سے سمجھ لینے دو جس کو ہم نے اکیلا پیدا کیا ۔\nیہ آیت ولید بن مغیرہ سے متعلق ہے جو اس وقت اولاد اور جاہ و چشم میں اپنا ثانی نہ رکھتا تھا ۔","«وَحِیْد» لاثانی بے مثل ، ان معنوں میں مخلوقات کے لیے استعمال ہوتا ہے ۔","اکیلا","وحید","74:11",1
243,46,"ا","فَرْد","«فَرَدَ» بمعنی اکیلا ۔ طاق ۔ ایک تلوے کی جوتی ۔ کہا جاتا ہے ۔ «ھٰذَا شَیْءٌ فَرْدٌ» بمعنی یہ منفرد چیز ہے ۔ (منجد) اور فرد ایسی چیز کو کہتے ہیں جس کے ساتھ دوسری نہ ملائی گئی ہو یہ لفظ وتر (طاق : جفت کی ضد) سے عام ہے اور واحد سے خاص (مف) اس کی جمع افراد ہے جس کے معنی ہیں سب الگ الگ ۔\nمثلاً : قرآن کریم میں ہے :\n«وَزَکَرِیَّاۤ اِذۡ نَادٰی رَبَّہٗ رَبِّ لَا تَذَرۡنِیۡ فَرۡدًا وَّاَنۡتَ خَیۡرُالۡوٰرِثِیۡنَ» ( 21/89 )\nترجمہ : اور زکریا ( کو یاد کرو ) جب انہوں نے اپنے پروردگار کو پکارا کہ پروردگار ! مجھے اکیلا نہ چھوڑ اور تو سب سے بہتر وارث ہے ۔","«فَرَدَ» اکیلا فردِ واحد کے لیے استعمال ہوتا ہے ۔","اکیلا","فرد","19:80-19:95-21:89",3
244,46,"ا","فُرَادٰی","«فرٰادٰی» جمع ہے «اَلْفُرْدَۃُ» کی  جس کے معنی ہیں ، تنہا جانے والا ۔ کہا جاتا ہے «جَاءُوْا فُرَادٰی» وہ سب اکیلے اکیلے آئے ۔ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَلَقَدۡ جِئۡتُمُوۡنَا فُرَادٰی کَمَا خَلَقۡنٰکُمۡ  اَوَّلَ مَرَّۃٍ» ( 6/94 )\nترجمہ : اور جیسا ہم نے تم کو پہلی دفعہ پیدا کیا تھا ایسا ہی آج اکیلے اکیلے ہمارے پاس آئے ۔","«فرٰادٰی» ایک ایک کر کے جانے والے کو کہتے ہیں ۔ ","اکیلا","فرادی","6:94-34:46",2
245,47,"ا","اِجْتَثَّ","«جَثّ» بمعنی جڑ سے اکھاڑنا ۔ بیخ کنی کرنا اور «مَجَثَّہ» اس کھرپی کو کہتے ہیں جس سے گھاس وغیرہ کریدی جاتی ہے (منجد) اور«جَثِیْثَۃ» اس کھجور کے پودے کو کہتے ہیں جو اکھاڑ کر دوسری جگہ لگایا گیا ہو ۔ (مف) اور «اِجْتَثَّ» بھی انہی معنوں میں مستعمل ہے ۔ «جَثَّ» کا لفظ گھاس پھوس اور چھوٹے پودوں کی بیخ کنی کے لیے آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَثَلُ کَلِمَۃٍ خَبِیۡثَۃٍ کَشَجَرَۃٍ خَبِیۡثَۃِۣ اجۡتُثَّتۡ مِنۡ فَوۡقِ الۡاَرۡضِ مَا لَہَا مِنۡ قَرَارٍ» ( 14/26 )\nترجمہ : اور ناپاک بات کی مثال ناپاک درخت کی سی ہے ( نہ جڑ مستحکم ، نہ شاخیں بلند ) زمین کے اوپر ہی سے اکھیڑ کر پھینک دیا جائے اس کو ذرا بھی قرار ( و ثبات ) نہیں ۔\nنوٹ : (بیخ کنی : یعنی کسی چیز کو نیست و نابود کرنا ، تخریب کرنا ۔ جڑ سے اُکھاڑنا ۔ جڑ کھودنا ۔ قطع نسل کرنا ۔ ستیاناس کرنا)","«جَثَّ» چھوٹے پودوں اور گھاس پھوس کی بیخ کنی (یعنی اکھاڑنے) کے لیے استعمال ہوتا ہے۔ ","اکھاڑنا","اجتث","14:26",1
246,47,"ا","اِنْقَعَر","«قَعَرَ» کا معنی کسی چیز کی گہرائی اور اندرونی سطح کا نچلا حصہ ہے اور «اَقْعَرَ الْبِئْر» کے معنی کنویں کو گہرا کھودنا اور «اَقْعَرَ الشَّجر» کے معنی کسی درخت کو جڑ سے اکھاڑ دینا ہے ۔ ابن الفارس کے مطابق کسی ایسی چیز کی جڑیں اکھاڑنا جو زمین میں نیچے تک چلی گئی ہوں (م ل) اور صاحب مُنْتَہَی الْاَرَب اس کے معنی کرتے ہیں کہ ! درخت کو جڑ سے اکھاڑنے کے بعد پھر اسے زمین پر پھینک دینا (م ۔ ا)\nگویا «اَقْعَرَ» کا لفظ ایسے بڑے بڑے درختوں کی بیخ کنی کے لیے استعمال ہوتا ہے جن کی جڑیں زمین میں دور تک گہرائی میں چلی گئی ہوں اور «اِنْقَعَر» جب اس کام کا  وارد ہونا یا ظاہر ہونا اس چیز پر ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«تَنۡزِعُ  النَّاسَ ۙ کَاَنَّہُمۡ  اَعۡجَازُ نَخۡلٍ مُّنۡقَعِرٍ» ( 54/20 )\nترجمہ : وہ ( باد صرصر ) لوگوں کو یوں اکھیڑے ڈالتی تھی گویا اکھڑی ہوئی کھجوروں کی جڑیں ہیں ۔\nنوٹ : (بیخ کنی : یعنی کسی چیز کو نیست و نابود کرنا ، تخریب کرنا ۔ جڑ سے اُکھاڑنا ۔ جڑ کھودنا ۔ قطع نسل کرنا ۔ ستیاناس کرنا)","«اِنْقَعَرَ» بڑے بڑے درختوں  کی بیخ کنی (اکھاڑنے) کیلئے استعمال ہوتا ہے، جن کی جڑیں کافی گہرائی تک ہوں ۔","اکھاڑنا","انقعر","54:20",1
247,48,"ا","جَمَعَ","«جَمَعَ» کا لفظ ایک ہی چیز کے مختلف اجزاء کو ، یا مختلف چیزوں کو اکٹھا کرنے کے لیے آتا ہے ۔ یہ چیزیں خواہ جاندار ہوں یا بے جان ۔\nمثلاً : جاندار اشیاء کے لیے : ارشاد باری تعالیٰ ہے :\n«اَلَّذِیۡنَ  قَالَ لَہُمُ النَّاسُ  اِنَّ النَّاسَ قَدۡ جَمَعُوۡا لَکُمۡ» ( 3/173 )\nترجمہ : جب ان لوگوں نے آ کر بیان کیا کہ کفار نے تمہارے ( مقابلے کے ) لیے ( لشکر کثیر ) جمع کیا ہے ۔\nاور بے جان چیزوں کے لیے : ارشاد باری تعالیٰ ہے :\n«الَّذِیۡ جَمَعَ  مَالًا  وَّ عَدَّدَہٗ» ( 104/2 )\nترجمہ : جس نے مال جمع کیا پھر گنتا رہا ۔\nپھر جمع کا لفظ ظاہری چیزوں کو اکٹھا کرنے کے لیے آتا ہے ۔ معنوی طور پر بھی استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَتَوَلّٰی فِرۡعَوۡنُ فَجَمَعَ  کَیۡدَہٗ  ثُمَّ  اَتٰی» ( 20/60 )\nترجمہ : پھر لوٹ گیا فرعون پھر جمع کیے اپنے سارے داؤ پھر آیا ۔ ( عثمانیؒ )","«جَمَعَ» جمع کا لفظ عام ہے ۔ جمع کا لفظ ایک ہی چیز کے مختلف اجزاء کو یا مختلف چیزوں کو اکٹھا کرنے کے لیے استعمال ہوتا ہے ۔","اکٹھا ","جمع","2:29-2:38-2:148-2:161-2:165-3:25-3:87-3:103-3:155-3:157-3:166-3:173-4:23-4:71-4:87-4:139-4:140-4:172-5:17-5:32-5:36-5:48-5:105-5:109-6:12-6:22-6:35-6:128-6:149-7:18-7:38-7:48-7:124-7:158-8:37-8:41-8:63-10:4-10:28-10:58-10:65-10:99-11:55-11:119-12:15-12:83-12:93-13:18-13:31-13:42-14:8-14:21-15:30-15:39-15:43-15:59-15:92-16:9-17:103-18:60-18:61-18:99-20:60-20:64-20:123-21:77-24:31-24:61-26:38-26:49-26:56-26:61-26:65-26:95-26:170-27:51-28:78-32:13-34:26-34:40-35:10-36:32-36:53-37:134-38:73-38:82-38:85-39:44-39:47-39:53-39:67-42:7-42:15-42:29-43:32-43:55-44:40-45:13-45:26-54:44-54:45-58:6-58:18-59:14-64:9-70:14-70:18-75:3-75:9-75:17-77:38-100:5-104:2",113
248,48,"ا","اِجْتَمَعَ","«اِجْتَمَعَ» کا لفظ صرف ذوی العقول کے اکٹھا ہونے کے استعمال ہوتا ہے ۔ خواہ وہ ایک ہی جنس سے تعلق رکھتے ہوں یا مختلف ہوں ۔\nمثلاً : قرآن کریم میں ہے :\n«قُلۡ لَّئِنِ اجۡتَمَعَتِ الۡاِنۡسُ وَ الۡجِنُّ عَلٰۤی اَنۡ یَّاۡتُوۡا بِمِثۡلِ ہٰذَا الۡقُرۡاٰنِ لَا یَاۡتُوۡنَ بِمِثۡلِہٖ» ( 17/88 )\nترجمہ : کہہ دو کہ اگر تمام انسان اور جن اس بات پر مجتمع ہوں کہ اس قرآن جیسا بنا لائیں تو نہ لا سکیں گے ۔","«اِجْتَمَعَ» صرف جانداروں کو اکٹھا کرنے کیلئے استعمال ہوتا ہے ۔","اکٹھا ","اجتمع","17:88-22:73-26:39",3
249,48,"ا","حَشَرَ","«حَشَرَ» کا لفظ جانداروں کے لیے آتا ہے یعنی لوگوں کو ان کے ٹھکانوں سے کسی ایک مقام کی طرف لے جانا (مف) اورابن الفارس بھی اس معنی ک تائید کرتے ہیں ۔ لکھتے ہیں «اَلْحَشْرُ الْجَمْعُ مَعَ سَوْق» (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«فَحَشَرَ فَنَادٰی فَقَالَ اَنَا رَبُّکُمُ الۡاَعۡلٰی» ( 79/23،24 )\nترجمہ : تو فرعون نے ( لوگوں کو ) اکٹھا کیا اور پکارا ۔ کہنے لگا تمہارا سب سے بڑا مالک تو میں ہوں ۔\nپھر یہ لفظ کبھی صرف «بَعَثَ» یا «اَنْبِعَاث» کے معنوں میں بھی استعمال ہوتا ہے (م ۔ ل) یعنی مردہ کو زندہ کرنا) یا کسی خاص مقصد کے لیے لے جانا ۔ «بَعَثَ» کے معنوں میں درج ذیل مثال دیکھئے :\nمثلاً : ارشاد باری تعالیٰ ہے :\n«قَالَ رَبِّ  لِمَ حَشَرۡتَنِیۡۤ  اَعۡمٰی وَ قَدۡ کُنۡتُ  بَصِیۡرًا» ( 20/125 )\nترجمہ : وہ کہے گا کہ میرے پروردگار ! تو نے مجھے اندھا کر کے کیوں ( قبر سے ) اٹھایا ۔ میں تو دیکھتا بھالتا تھا ۔\nاور کبھی اس لفظ کے استعمال میں «تَجَمَّع ، سُوْق» اور «بَعَث» سب معنی پائے جاتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یَوۡمَ نُسَیِّرُ الۡجِبَالَ وَ تَرَی الۡاَرۡضَ بَارِزَۃً ۙ وَّ حَشَرۡنٰہُمۡ  فَلَمۡ  نُغَادِرۡ  مِنۡہُمۡ اَحَدًا» ( 18/47 )\nترجمہ : اور جس دن ہم پہاڑوں کو چلائیں گے اور تم زمین کو صاف میدان دیکھو گے اور ان لوگوں کو ہم جمع کر لیں گے تو ان میں سے کسی کو بھی نہیں چھوڑیں گے ۔","«حَشَرَ» بمعنی اجتماع، ہجوم، بھیڑ جانداروں کوان کے ٹھکانے سے اٹھا کر ایک جگہ جمع کرنے کے لیے استعمال ہوتا ہے۔","اکٹھا ","حشر","2:203-3:12-3:158-4:172-5:96-6:22-6:38-6:51-6:72-6:111-6:128-8:24-8:36-10:28-10:45-15:25-17:97-18:47-19:68-19:85-20:59-20:102-20:124-20:125-23:79-25:17-25:34-27:17-27:83-34:40-37:22-41:19-46:6-50:44-58:9-59:2-67:24-79:23-81:5",39
250,48,"ا","اِدَّخَرَ","«اِدَّخَرَ» اس کا اصل مادہ «ذَخَر» ہے جس کے معنی ہیں مستقبل کی ضرورت کے لیے اشیاء خوردنی یعنی کھانے پینے کی چیزیں سٹاک کر لینا ۔ ذخیرہ کرنا (مف) اور یہ ذخیرہ انسانوں کے علاوہ دوسرے بھی کئی جاندار کرتے ہیں ۔ ابن فارس اس کے معنی میں دو بنیادی باتیں لکھتے ہیں اکٹھا کرنا اور اسے محفوظ کرنا (م ۔ ل) اور «اِدَّخَرَ» بھی اسی معنی میں آتا ہے اور جمع شدہ چیز کو «ذخر» اور «ذخیرہ» کہتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ اُنَبِّئُکُمۡ بِمَا تَاۡکُلُوۡنَ وَمَا تَدَّخِرُوۡنَ ۙ فِیۡ بُیُوۡتِکُمۡ» ( 3/49 )\nترجمہ : ( عیسیٰ ؑ نے کہا ) اور جو کچھ تم کھا کر آتے ہو اور جو اپنے گھروں میں جمع رکھتے ہو سب تم کو بتا دیتا ہوں ۔","«اِدَّخَرَ» مستقبل کے لیے ضرورت کی چیزوں کو جمع کرنے کے لیے استعمال ہوتا ہے ۔","اکٹھا ","ادخر","3:49",1
251,48,"ا","خَزَنَ","ذخیرہ کا لفظ عمومًا اشیاء خوردنی کو جمع کرنے کے لیے استعمال ہوتا ہے ۔ لیکن «خَزَنَ» کا لفظ اس سے عام ہے ۔ یہ اکثر مال و دولت کے جمع کرنے کے لیے آتا ہے جسے «خَزَنْتُ الدَّرَاھِمَ» لیکن اس میں بنیادی مفہوم اکٹھا کرنے سے زیادہ حفاظت کرنا ہے ۔ کہا جاتا ہے ، «خَزَنْتُ السِّرَّ» ( میں نے بھید کو محفوظ رکھا ) (م ۔ ل) اور جو شخص اس جمع شدہ چیز یا مال کا محافظ ہو ۔ اسے «خَازِنْ» کہتے ہیں اور اس کی جمع «خَزَنَۃُ» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«کُلَّمَاۤ  اُلۡقِیَ فِیۡہَا  فَوۡجٌ سَاَلَہُمۡ خَزَنَتُہَاۤ  اَلَمۡ یَاۡتِکُمۡ  نَذِیۡرٌ » ( 67/8 )\nترجمہ : جب اس ( دوزخ ) میں کوئی جماعت ڈالی جائے گی تو دوزخ کے خازن ( محافظ داروغہ ) ان سے پوچھیں گے تمہارے پاس کوئی ڈرانے والا نہیں آیا تھا ؟\nاور جہاں کوئی چیز جمع کی جائے اس جگہ کو «خِزَانَہ» اور «خَزِیْنَہ» کہتے ہیں اور اس کی جمع «خَزَائِن» ہے ۔ آیت مندرجہ میں جمع شدہ چیز گنہگار لوگ ، دوزخ خِزانہ اور داروغہ یا اس کا محافظ یعنی خازن ہیں ۔","«خَزَنَ» جمع شدہ چیزوں کی حفاظت کرنے  کے لیے  استعمال ہوتا ہے ۔","اکٹھا ","خزن","6:50-11:31-12:55-15:21-15:22-17:100-38:9-39:71-39:73-40:49-52:37-63:7-67:8",13
252,48,"ا","وَسَقَ ۔ اِتسَقَ","«وَسَقَ» کے معنی چیزوں کو جمع کرنا اور اٹھانا ہے  (منجد ۔ م ل)  اور «اَوْسَقَ» بمعنی جانور پر بوجھ لادنا اور «وَسَقْتُ الشَّیْءَ» کسی چیز کے متفرق اجزاء کو جمع کرنا اور «اِتَّسَقَ» کے معنی یہ ہیں کہ اس چیز کے سب اجزاء جمع ہو گئے اور وہ مکمل ہو گئی ۔ (ف)\nمثلاً : قرآن کریم میں ہے :\n«وَ الَّیۡلِ وَ مَا وَسَقَ وَ الۡقَمَرِ اِذَا اتَّسَقَ» ( 84/17،18 )\nترجمہ : اور قسم ہے رات کی اور جن چیزوں کو وہ اکٹھا کر لیتی ہے اور چاند کی جب کامل ہو جائے ۔","«وَسَقَ» ایک ہی چیز سے متعلقہ اجزاء کو اکٹھا کرنےکے لیے  استعمال ہوتا ہے ۔","اکٹھا ","وسق ۔ اتسق","84:17-84:18",2
253,48,"ا","کَفَتَ","«کَفَتَ» بمعنی کسی چیز کو جمع کر کے اسے اپنے قبضہ میں لے لینا (مف) سنبھال لینا ۔ سمیٹ لینا اور «کَفِیْت» بمعنی توشہ دان جس میں خوراک اور سامان خوراک کو سنبھال کر رکھتے ہیں ۔ مثلاً : «اَللّٰھُمَّ اکْفِہٖ» ۔ یا اللہ اسے سنبھال لے  (منجد)\nمثلاً : قرآن کریم میں ہے :\n«اَلَمۡ نَجۡعَلِ الۡاَرۡضَ  کِفَاتًا اَحۡیَآءً وَّاَمۡوَاتًا» ( 77/25،26 )\nترجمہ : کیا ہم نے زمین کو سمیٹنے والی نہیں بنایا ( یعنی ) زندوں کو اور مردوں کو ۔","«کَفَتَ» بمعنی جمع کرنا اور قبضہ میں لینا ، سمیٹ لینا ۔","اکٹھا ","کفت","77:25",1
254,48,"ا","لَمَّ","«لَمَّ» بمعنی کسی چیز کو جمع کرنا اور اس کو سنوارنا یا اس کو ٹھیک کرنا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَتَاۡکُلُوۡنَ التُّرَاثَ اَکۡلًا لَّمًّا» ( 89/19 )\nترجمہ : اور تم میراث کے مال کو سمیٹ کر کھاتے ہو ۔","«لَمَّ» جمع کرنا اور اس کی اصلاح کرنا  یعنی ٹھیک کرنا ۔","اکٹھا ","لم","89:19",1
255,48,"ا","حَصَّلَ ۔ التحصیل","«حَصَّلَ» بمعنی چھلکے سے گودا اور مغز کو نکالنا (مف) گویا «حَصَّلَ» کے معنی میں دو باتیں پائی جاتی ہیں (1) نکالنا (2) جمع کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَحُصِّلَ مَا فِی الصُّدُوۡرِ» ( 100/10 )\nترجمہ : اور سینوں کی پوشیدہ باتیں ظاہر کر دی جائیں گی ۔\nاس کے معنی یہ ہوں گے کہ جو بھید سینوں میں ہوں گے وہ نکال کر اس طرح جمع کر دیے جائیں گے جس طرح کہ چھلکے سے مغز الگ کر لیا جاتا ہے (مف) ","«حَصَّلَ» نکالنا اور جمع کرنا ۔","اکٹھا ","حصل ۔ التحصیل","100:10",1
256,48,"ا","مثابۃ","«مَثابَۃ» ثوب سے ہے اور ثوب کے اصل معنیٰ کسی چیز کا اپنی اصل حالت کی طرف لوٹ آنا ہے ۔ کہتے ہیں «ثَابَ فُلَانٌالیٰ دَارَہ» ۔ یعنی فلاں شخص اپنے گھر کی طرف لوٹ آیا اور «مَثابَۃ» اس جگہ کو کہا جاتا ہے جو کنویں کے منہ پر پانی پلانے کے لیے بنائی جاتی ہے (مف) چونکہ لوگ پانی پینے اور لے جانے کے لیے ایسی جگہ پر بار بار لوٹ کر آتے اور جمع ہوتے تھے ۔ لہذا اسے «مَثابَۃ» کہا جاتا ہے ۔ اسی نسبت سے اللہ تعالیٰ نے بیت اللہ شریف کو «مَثابَۃ» کہا ہے  یہاں لوگ آ کر بار بار اپنی روحانی پیاس بجھاتے اور جمع ہوتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ اِذۡ جَعَلۡنَا الۡبَیۡتَ مَثَابَۃً لِّلنَّاسِ وَ اَمۡنًا» ( 2/125 )\nترجمہ : اور جب ہم نے خانہ کعبہ کو لوگوں کے جمع ہونے اور امن پانے کی جگہ مقرر کیا ۔","«مَثَابَۃ» میں جمع ہونا کا معنیٰ کنایۃً و اشارۃً پایا جاتا ہے ۔ اصل معنیٰ بار بار آتے رہنا ہے ۔","اکٹھا ","مثابۃ","2:125",1
257,49,"ا","اِنْ","«اِنْ» حرفِ شرط ہے ۔ مستقبل کے لیے آتا ہے ۔ اس کا پہلا جملہ شرطیہ ہمیشہ فعل ہوتا ہے اور دوسرے جملہ (جزا) پر داخل ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنۡ تُعَذِّبۡہُمۡ فَاِنَّہُمۡ عِبَادُکَ» ( 5/118 )\nترجمہ : اگر تو انہیں عذاب دے تو وہ تیرے بندے ہیں ۔","«اِنْ» اس کو عربی گرامر میں حرفِ شرط  کہتے ہیں ۔ مستقبل کے لیے استعمال ہوتا ہے ۔","اگر","ان","2:23-2:24-2:31-2:70-2:78-2:85-2:91-2:93-2:94-2:11-2:137-2:143-2:172-2:180-2:184-2:191-2:192-2:193-2:196-2:198-2:209-2:217-2:220-2:226-2:227-2:228-2:229-2:230-2:233-2:236-2:237-2:239-2:240-2:246-2:248-2:265-2:271-2:278-2:279-2:280-2:282-2:283-2:284-2:286-3:20-3:29-3:31-3:32-3:49-3:63-3:64-3:75-3:93-3:100-3:111-3:118-3:120-3:125-3:139-3:140-3:144-3:149-3:160-3:164-3:168-3:175-3:179-3:183-3:184-3:186-4:3-4:4-4:6-4:11-4:12-4:15-4:16-4:19-4:20-4:23-4:25-4:31-4:34-4:35-4:40-4:43-4:59-4:62-4:72-4:78-4:89-4:90-4:91-4:92-4:101-4:102-4:104-4:117-4:128-4:129-4:130-4:131-4:133-4:135-4:141-4:147-4:149-4:159-4:170-4:176-5:6-5:17-5:22-5:23-5:41-5:42-5:49-5:57-5:67-5:73-5:92-5:101-5:106-5:107-5:110-5:112-5:116-5:118-6:7-6:15-6:17-6:25-6:26-6:29-6:35-6:40-6:41-6:46-6:47-6:50-6:57-6:70-6:81-6:89-6:90-6:116-6:118-6:121-6:133-6:139-6:143-6:147-6:148-6:150-6:156-7:23-7:70-7:77-7:85-7:87-7:89-7:102-7:106-7:113-7:131-7:143-7:146-7:155-7:169-7:176-7:184-7:188-7:193-7:194-7:198-8:1-8:19-8:29-8:31-8:32-8:34-8:38-8:39-8:40-8:41-8:61-8:62-8:65-8:66-8:70-8:71-8:72-9:3-9:5-9:6-9:8-9:11-9:12-9:13-9:23-9:24-9:28-9:41-9:50-9:58-9:62-9:66-9:74-9:80-9:83-9:96-9:107-9:129-10:15-10:29-10:38-10:41-10:48-10:50-10:66-10:68-10:71-10:72-10:84-10:94-10:104-10:106-10:107-11:3-11:7-11:13-11:28-11:29-11:30-11:32-11:33-11:34-11:35-11:38-11:50-11:51-11:54-11:57-11:63-11:86-11:88-12:3-12:10-12:26-12:27-12:31-12:40-12:43-12:60-12:67-12:74-12:77-12:91-12:99-12:104-13:5-13:40-14:8-14:10-14:11-14:19-14:34-14:46-15:7-15:21-15:71-15:78-16:18-16:37-16:43-16:82-16:95-16:114-16:126-17:7-17:8-17:25-17:44-17:47-17:52-17:54-17:58-17:73-17:76-17:108-18:5-18:6-18:20-18:29-18:39-18:57-18:69-18:70-18:76-19:18-19:71-19:93-20:7-20:63-20:103-20:104-21:7-21:17-21:34-21:36-21:38-21:47-21:63-21:68-21:109-21:111-22:5-22:11-22:41-22:42-22:68-22:73-23:25-23:30-23:37-23:38-23:83-23:84-23:88-23:107-23:114-24:2-24:7-24:9-24:17-24:28-24:32-24:33-24:49-24:54-25:4-25:8-25:10-25:41-25:42-25:44-26:4-26:24-26:28-26:31-26:40-26:41-26:97-26:109-26:113-26:115-26:127-26:137-26:145-26:154-26:164-26:180-26:186-26:187-26:205-26:216-27:64-27:68-27:71-27:81-28:10-28:19-28:27-28:49-28:50-28:57-28:71-28:72-29:8-29:16-29:18-29:29-30:36-30:49-30:53-30:58-31:15-31:16-32:28-33:5-33:13-33:16-33:17-33:20-33:24-33:28-33:29-33:32-33:50-33:54-34:9-34:29-34:43-34:46-34:47-34:50-35:4-35:14-35:16-35:18-35:23-35:24-35:25-35:40-35:41-36:15-36:23-36:29-36:32-36:43-36:47-36:48-36:53-36:69-37:15-37:56-37:102-37:157-37:167-38:7-38:14-38:70-38:87-39:7-39:13-39:38-39:56-40:12-40:28-40:29-40:56-41:13-41:24-41:37-41:38-41:49-41:52-42:24-42:33-42:48-43:20-43:35-43:59-43:81-44:7-44:21-44:35-44:36-45:24-45:25-45:32-46:4-46:8-46:9-46:10-46:22-46:26-47:7-47:22-47:36-47:37-47:38-48:11-48:16-48:27-49:6-49:9-49:14-49:17-52:34-52:44-53:4-53:23-53:28-54:2-55:33-56:86-56:87-56:88-56:90-56:92-57:8-58:2-58:12-59:11-60:1-60:2-60:10-60:11-61:11-62:2-62:6-62:9-63:4-64:12-64:14-64:17-65:4-65:6-66:4-66:5-67:9-67:20-67:21-67:25-67:28-67:30-68:22-68:41-68:51-71:27-72:25-73:17-74:24-74:25-77:39-81:27-86:4-87:9-96:11-96:13",531
258,49,"ا","اِمَّا","« اِنْ ۔ مَا » جب حرف شرط کے طور پر آتا ہے تو اس میں صرف «اِنْ» ہی معنیٰ دیتا ہے ۔ «مَا» حرفِ زیادت اور صرف تحسین کلام یعنی کلام کی خوبصورتی کے لیے آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِمَّا یَبۡلُغَنَّ عِنۡدَکَ الۡکِبَرَ اَحَدُہُمَاۤ» ( 17/23 )\nترجمہ : اگر ان دونوں میں سے کوئی ایک تمہارے سامنے بڑھاپے کو پہنچ جائے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«فَاِمَّا تَرَیِنَّ مِنَ الۡبَشَرِ اَحَدًا» ( 19/26 )\nترجمہ : تو ( اے مریم ! ) اگر تم کسی آدمی کو دیکھو ۔","«اِمَّا» عربی گرامر میں  جب «اِمَّا» اگر کے معنوں میں آئے تو اس میں «مَا» حرف زیادت ہے جو صرف تعریف  کے لیے آتا ہے ۔","اگر","اما","2:38-6:68-7:35-7:115-7:200-8:57-8:58-9:106-10:46-17:23-17:28-18:86-19:26-19:75-20:65-20:123-23:93-40:77-41:36-43:41-47:4-76:3",22
259,49,"ا","لَوْ","«لَوْ» حرف شرط ہے مگر اس میں جزا کا جملہ ہمیشہ شرط سے مقید ہوتا ہے (یعنی کسی کام کے بدلے کے لئے کوئی شرط لگائی جاتی ہے) اوراس کی جزا پر (لام مفتوحہ) داخل ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«لَوۡ کَانَ عَرَضًا قَرِیۡبًا وَّ سَفَرًا قَاصِدًا لَّاتَّبَعُوۡکَ» ( 9/42 )\nترجمہ : اگر مال غنیمت قریب ہوتا اور سفر بھی چھوٹا ہوتا تو (اے نبی (صلی اللہ علیہ وآلہ وسلم) یہ آپ کی پیروی کرتے ۔\nاور اگر «لَوْ» سے پہلے «وَ» داخل ہو جیسے «وَلَو» تو یہ ’’ اگرچہ ‘‘ کا معنی دے گا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَیۡنَ مَا تَکُوۡنُوۡا یُدۡرِکۡکُّمُ الۡمَوۡتُ وَ لَوۡ کُنۡتُمۡ  فِیۡ  بُرُوۡجٍ مُّشَیَّدَۃٍ» ( 4/78 )\nترجمہ : جہاں کہیں بھی تم ہو موت تمہیں آپکڑے گی اگرچہ تم مضبوط قلعوں میں ہو ۔\nاور «لَوْ» کے بعد «لَا» کا اضافہ کرنے سے ’’ اگر نہ ‘‘ کے معنی پیدا ہوتے ہیں ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«لَوۡ لَاۤ اَنۡتُمۡ لَکُنَّا مُؤۡمِنِیۡنَ» ( 34/31 )\nترجمہ : اگر تم نہ ہوتے تو ہم ضرور مومن ہوتے ۔","«لَوْ» میں جزا شرط سے مقید ہوتی ہے ،(یعنی کسی کام کے بدلے کے لئے کوئی شرط لگائی جائے)","اگر","لو","2:20-2:64-2:96-2:102-2:103-2:109-2:251-2:165-2:167-2:220-2:221-2:253-3:30-3:69-3:91-3:110-3:154-3:156-3:159-3:167-3:168-4:9-4:39-4:42-4:46-4:64-4:66-4:78-4:82-4:83-4:89-4:90-4:102-4:113-4:129-4:135-5:36-5:48-5:65-5:66-5:81-5:100-5:106-6:7-6:8-6:9-6:27-6:28-6:30-6:35-6:58-6:88-6:93-6:107-6:111-6:112-6:137-6:148-6:149-6:152-6:157-7:43-7:96-7:100-7:155-7:176-7:188-8:8-8:19-8:23-8:31-8:42-8:43-8:50-8:63-8:68-9:32-9:33-9:42-9:46-9:47-9:57-9:59-9:81-9:113-10:11-10:16-10:19-10:42-10:43-10:54-10:82-10:97-10:99-11:80-11:91-11:110-11:118-12:17-12:24-12:94-12:103-13:18-13:31-14:21-15:2-15:7-15:14-16:9-16:35-16:41-16:61-16:93-17:42-17:74-17:88-17:95-17:100-18:18-18:58-18:77-18:109-20:129-20:134-21:17-21:22-21:39-21:99-22:40-22:73-23:24-23:71-23:75-23:114-24:10-24:14-24:20-24:21-24:35-25:42-25:45-25:51-25:77-26:102-26:113-26:198-28:10-28:47-28:64-28:82-29:41-29:53-29:64-31:27-32:12-32:13-33:14-33:20-33:52-34:14-34:31-34:51-35:14-35:18-35:45-36:47-36:66-36:67-37:57-37:143-37:168-39:4-39:26-39:47-39:57-39:58-40:14-41:14-41:44-41:45-42:8-42:14-42:21-42:27-43:20-43:33-43:60-46:11-47:4-47:21-47:30-48:22-48:25-49:5-49:7-56:65-56:70-56:76-58:22-59:3-59:9-59:21-60:2-61:8-61:9-67:10-68:9-68:33-68:49-69:44-70:11-71:4-75:15-102:5",214
260,50,"ا","اَرْکَسَ","«اَرْکَسَ» کے معنی کسی چیز کو اس کے سر پر الٹا کر دینا (یعنی سر نیچے اور ٹانگیں اوپر) یا اس کے پہلے سرے کو پچھلے سرے سے الٹا کر ملا دینا (م ۔ ل) تہ و بالا کر دینا ۔ کہتے ہیں «اَرْکَسَ الثَّوبُ فِی الصَّبْغِ» بمعنی الٹا کر رنگ میں کپڑا ڈبویا (م ۔ ق)\nمثلاً : قرآن کریم میں ہے :\n«وَ اللّٰہُ اَرۡکَسَہُمۡ بِمَا کَسَبُوۡا» ( 4/88 )\n ترجمہ : خدا نے ان ( منافقین ) کو ان کے کرتوتوں کے سبب اوندھا کر دیا ۔","«اَرْکَسَ» کے معنی کسی چیز کو اس کے سر پر الٹا کر دینا (یعنی سر نیچے ہوں اور ٹانگیں اوپر)","الٹ","ارکس","4:88-4:91",2
261,50,"ا","اِئْتَفَکَ","«اَفَکَ» کے معنی کسی کو صحیح رخ سے موڑ دینا (م ۔ ل) اور اگر کسی صحیح رخ کے علاوہ کسی دوسرے رخ پر پٹخ دیا جائے تو اسے «اِئْتَفَکَ» کہتے ہیں (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ الۡمُؤۡتَفِکَۃَ  اَہۡوٰی» ( 53/53 )\nترجمہ : اور (اُسی نے) الٹی ہوئی بستیوں کو پٹخ دیا ۔","«اِئْتَفَکَ» صحیح رخ کے علاوہ دوسرے رخ پر پٹخ دینا ۔","الٹ","ائتفک","9:70-53:53-69:9",3
262,50,"ا","جَثَمَ","«جَثَمَ» پرندے کا سینہ کے بل زمین پر بیٹھنا اور پھر اس سے چمٹ جانا ( فل 186 ) کنایۃً کسی شخص کا سینہ کے بل زمین پر لیٹنا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَخَذَتۡہُمُ الرَّجۡفَۃُ فَاَصۡبَحُوۡا فِیۡ  دَارِہِمۡ  جٰثِمِیۡنَ» ( 7/78 )\nترجمہ : تو ان کو بھونچال نے آ پکڑا اور وہ اپنے گھروں میں اوندھے پڑے رہ گئے ۔","«جَثَمَ» سینہ کے بل گرنا یا چمٹنا ۔","الٹ","جثم","7:78-7:91-11:67-11:94-29:37",5
263,50,"ا","کَبَّ","«کَبَّ الْاِنَاءَ» کے معنی برتن کو الٹا کر کے رکھ دینے کے ہیں (منجد) اور «کَبَّ فُلَانًا» کے معنی کسی کو منہ کے بل گرا دینا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ مَنۡ جَآءَ بِالسَّیِّئَۃِ  فَکُبَّتۡ وُجُوۡہُہُمۡ  فِی النَّارِ» ( 27/90 )\nترجمہ : اور جو کوئی برائی لے کر آئے گا تو ایسے لوگ اوندھے منہ دوزخ میں ڈال دیے جائیں گے ۔","«کَبَّ» اوندھے منہ گرانا ۔","الٹ","کب","26:94-27:90-67:22",3
264,50,"ا","کَبْکَبَ","«کَبْکَبَ» میں تکرار لفظی ہے جو اس کے معانی میں بھی شدت پیدا کر رہا ہے  بمعنی کسی چیز کو اوپر سے لڑھکا کر گڑھے میں پھینک دینا ۔ (مف ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَکُبۡکِبُوۡا فِیۡہَا  ہُمۡ  وَ الۡغَاوٗنَ» ( 26/94 )\nترجمہ : تو وہ اور گمراہ ( یعنی بت اور بت پرست ) اوندھے منہ دوزخ میں ڈال دیے جائیں گے ۔","«کَبْکَبَ» لڑھکا کر اوندھے منہ گڑھے میں گرا دینا ۔","الٹ","کبکب","26:94",1
265,50,"ا","قَلَّب","«تَقْلِیْبُ الشَّیء» بمعنی کسی چیز کو پھیرنے اور ایک حالت سے دوسری حالت میں لوٹانے کے ہیں اور «قَلّب الثَّوْب» بمعنی کپڑے کو الٹنا «قلّب» کا استعمال مادی اور معنوی دونوں طرح ہوتا ہے ۔\nمادی معنی میں استعمال کی مثال :\nارشاد باری تعالیٰ ہے :\n«یَوۡمَ تُقَلَّبُ وُجُوۡہُہُمۡ فِی النَّارِ» ( 33/66 )\nترجمہ : جس دن اُن کے منہ آگ میں الٹائے جائیں گے ۔\nمعنوی معنی میں استعمال کی مثال :\nارشاد باری تعالیٰ ہے :\n«لَقَدِ ابۡتَغَوُا الۡفِتۡنَۃَ  مِنۡ  قَبۡلُ وَ قَلَّبُوۡا لَکَ الۡاُمُوۡرَ حَتّٰی جَآءَ الۡحَقُّ» ( 9/48 )\nترجمہ : یہ پہلے بھی طالب فساد رہے ہیں اور بہت سی باتوں میں تمہارے لیے الٹ پھیر کرتے رہتے ہیں یہاں تک کہ حق آ پہنچا ۔","«قَلّب» کسی چیز کی حالت یا معاملہ کو الٹ دینا یا الٹ پلٹ کر دینا ۔","الٹ","قلب","2:143-2:144-3:127-3:144-3:149-3:174-5:21-6:110-7:119-7:125-9:48-9:95-12:62-18:18-18:36-22:11-24:37-24:44-26:50-26:227-29:21-33:66-43:14-48:12-67:4-83:31-84:9",27
266,50,"ا","نَکَسَ ، نَکَّسَ","«نَکَسَ» بمعنی الٹا کرنا اور «نَکَسَ رَأْسَہٗ» بمعنی ذلت یا ندامت سے سر جھکا دینا ( یہ محاورتًا استعمال ہوتا ہے اور «نَکِسَ الْمَرِیْض» مریض کا دوبارہ بیمار پڑنا اور «اَلنُّکَاس» بمعنی بیماری کا دوبارہ لوٹ کر آنا اور گِر کر نہ سنبھلنا ۔ پھر دوبارہ پہلے سے زیادہ زور سے گرنا اور «اَلنََکَس» بمعنی بہت بوڑھے لوگ اور«نَکَّسَ» بمعنی الٹ پلٹ کرنا ۔ «اِنْتَکَسَ» بمعنی سر کے بل گرنا ۔ دوبارہ بیمار پڑنا ۔ (منجد مف)\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ  نُکِسُوۡا عَلٰی  رُءُوۡسِہِمۡ» ( 21/65 )\nترجمہ : پھر شرمندہ ہو کر سر نیچا کر لیا ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَ مَنۡ نُّعَمِّرۡہُ  نُنَکِّسۡہُ  فِی الۡخَلۡقِ» ( 36/68 )\nترجمہ : اور جسے ہم بوڑھا کرتے ہیں اسے پیدائشی حالت کی طرف پھر الٹ دیتے ہیں ۔","«نَکَسَ» کا معنی سر کے بل الٹا کرنا ہے یعنی سر نیچے اور پاؤں اوپر کردینا  یہ کسی بھی شخص کی بدترین حالت ہے۔\nاور« نَکَّسَ » بمعنی الٹ پلٹ کرنا ۔","الٹ","نکس ، نکس","21:65-36:68",2
267,51,"ا","فَرَقَ","«فَرَقَ» بمعنی کسی چیز کو پھاڑ کر الگ الگ کر دینا ۔ (مف) پھر اس الگ شدہ چیز کو «فِرْق» کہتے ہیں اور اگر وہ الگ چیزیں انسانوں کا گروہ ہو تو اسے فرقہ کہتے ہیں ۔ مثلاً : قرآن کریم میں ہے :\n«وَ اِذۡ فَرَقۡنَا بِکُمُ الۡبَحۡرَ» ( 2/50 )\nترجمہ : اور جب ہم نے تمہارے لیے دریا کو پھاڑ کر الگ کر دیا ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«فَانۡفَلَقَ فَکَانَ کُلُّ فِرۡقٍ  کَالطَّوۡدِ  الۡعَظِیۡمِ» ( 26/63 )\nترجمہ : تو دریا پھٹ گیا اور ہر ایک ٹکڑا ( یوں ) ہو گیا گویا بڑا پہاڑ ( ہے ) ۔\nپھر «فَرَقَ» کا استعمال معنوی طور پر بھی ہوتا ہے ۔ یعنی دو قسم کی چیزیں جو بظاہر ایک ہی نظر آتی ہوں مگر حقیقتًا الگ الگ ہوں تو ان کو الگ کرنے کے معنی میں استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَ رَبِّ اِنِّیۡ  لَاۤ  اَمۡلِکُ اِلَّا نَفۡسِیۡ وَ اَخِیۡ فَافۡرُقۡ بَیۡنَنَا وَ بَیۡنَ الۡقَوۡمِ الۡفٰسِقِیۡنَ» ( 5/25 )\nترجمہ : موسیٰ ؑ نے ( خدا سے ) التجا کی پروردگار ! میں اپنے اور اپنے بھائی کے سوا کسی پر اختیار نہیں رکھتا تو ہم میں اور ان نافرمان لوگوں میں جدائی ڈال دے ۔\nاور «فَرَّقَ» بمعنی کسی جماعت سے الگ ہونا ، علیحدہ فرقہ بنا لینا ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ الَّذِیۡنَ فَرَّقُوۡا دِیۡنَہُمۡ  وَ کَانُوۡا  شِیَعًا» ( 6/159 )\nترجمہ : جن لوگوں نے اپنے دین میں ( بہت سے ) رستے نکالے اور کئی کئی فرقے ہو گئے ۔ ( جالندھریؒ )","«فَرَقَ» کسی چیز کو پھاڑ کر الگ الگ کر دینا ۔","الگ","فرق","2:50-2:53-2:102-2:136-2:185-2:285-3:4-3:84-3:103-3:105-4:130-4:150-4:152-5:25-6:153-6:159-8:29-8:41-12:39-12:67-17:106-20:94-21:48-25:1-26:63-30:14-30:32-42:13-42:14-44:4-77:4-98:4",32
268,51,"ا","فَتَقَ","«فَتَقَ» کے معنی کسی چیز میں بڑا سا شگاف ڈال کر اسے کھول دینا ہے ۔ جیسے نافۂ مشک (ہرن کی وہ تھیلی  کی جس میں مشک رہتا ہے) اسکو کھولا جاتا ہے (م ر ) یا دو ملی ہوئی چیزوں کو الگ الگ کرنا اور اس کی ضد «رَتَقَ» ہے بمعنی کسی چیز کا گڈمڈ اور جڑی ہوئی ہونا (مف)\nمثلاً : قرآن کریم میں ہے :\n«اَنَّ السَّمٰوٰتِ وَ الۡاَرۡضَ کَانَتَا رَتۡقًا فَفَتَقۡنٰہُمَا» ( 21/30 )\nترجمہ : آسمان اور زمین دونوں ملے ہوئے تھے تو ہم نے ان کو جدا جدا کر دیا ۔","«فَتَقَ» کسی چیز کو پھاڑ کر کھول دینا ۔ یا ملی ہوئی چیزوں کو الگ کردینا ۔","الگ","فتق","21:30",1
269,51,"ا","عَزَلَ","«عَزَلَ» کسی کو اس کے اصل کام یا مقصد سے علیحدہ کر دینا ۔ بیکار کر دینا ۔ ایک جانب لگا دینا (م ر ۔ منجد) معزول بھی اسی سے ہے اس شخص کو کہتے ہیں جو کام سے علیحدہ کر دیا گیا ہو ۔ اور «عُزْلَت» گوشۂ تنہائی کے معنوں میں آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ مَنِ ابۡتَغَیۡتَ مِمَّنۡ عَزَلۡتَ فَلَا جُنَاحَ عَلَیۡکَ» ( 33/51 )\nترجمہ : اور جس ( بیوی ) کو تم نے علیحدہ کر دیا ہو اگر اس کو پھر اپنے پاس طلب کر لو تو تم پر کچھ گناہ نہیں ۔","«عَزَلَ» کسی کو اس کے کام سے الگ کردینا ۔ ","الگ","عزل","11:42-33:51",2
270,51,"ا","جَنَبَ","«جَنَبَ» کے بنیادی معنی دو ہیں (1) پہلو (2) دور ہونا اور «جَنَبَ» کے معنی کسی کو کسی آفت یا مصیبت سے دور رکھ کر بچا لینا (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«وَاِذۡ قَالَ اِبۡرٰہِیۡمُ رَبِّ اجۡعَلۡ ہٰذَا الۡبَلَدَ اٰمِنًا وَّاجۡنُبۡنِیۡ وَ بَنِیَّ اَنۡ نَّعۡبُدَ الۡاَصۡنَامَ» ( 14/35 )\nترجمہ : اور جب ابراہیم ؑ نے دعا کی کہ میرے پروردگار ! اس شہر مکہ کو امن کی جگہ بنا دے اور مجھے اور میری اولاد کو اس بات سے کہ بتوں کی پرستش کرنے لگیں بچائے رکھ ۔","«جَنَبَ» کسی کو الگ کر کے کسی مصیبت سے دور رکھنا ۔","الگ","جنب","14:35-87:11-92:17",3
271,51,"ا","مَازَ","«مَازَ» کسی چیز کو دوسری سے کسی فوقیت اور ترجیح کی بناء پر الگ کرنا اور «مَا زَالشَّیء» بمعنی چیز کو دوسری چیزوں پر ترجیح دینا ۔ فوقیت دینا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«مَا کَانَ اللّٰہُ لِیَذَرَ الۡمُؤۡمِنِیۡنَ عَلٰی مَاۤ اَنۡتُمۡ عَلَیۡہِ حَتّٰی یَمِیۡزَ الۡخَبِیۡثَ مِنَ الطَّیِّبِ» ( 3/179 )\nترجمہ : ( لوگو ! ) جب تک خدا ناپاک کو پاک سے الگ نہ کر دے گا مومنوں کو اس حال میں جس میں تم ہو ہرگز نہیں رہنے دے گا ۔","«مَازَ» کسی چیز کو دوسری سے فوقیت اور ترجیح کی بنا پر الگ کرنا ۔","الگ","ماز","3:179-8:37",2
272,51,"ا","زَیَّلَ","«زیَّلَ» بمعنی کسی چیز کو اس کے اصل مقام سے ہٹاکر دوسروں سے الگ کر دینا ۔ «زَالَ عَنْ مَکَانِہٖ» کسی چیز کو اسکی جگہ سے ہٹانا اور «زَیَّل» بمعنی کسی کو اس کی جگہ سے ہٹا دینا یا متفرق کرنا (منجد) ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یَوۡمَ نَحۡشُرُہُمۡ جَمِیۡعًا ثُمَّ نَقُوۡلُ لِلَّذِیۡنَ اَشۡرَکُوۡا مَکَانَکُمۡ اَنۡتُمۡ وَ شُرَکَآؤُکُمۡ ۚ فَزَیَّلۡنَا بَیۡنَہُمۡ» ( 10/28 )\nترجمہ : اور جس دن ہم ان سب کو جمع کریں گے پھر مشرکوں سے کہیں گے کہ تم اور تمہارے شریک اپنی اپنی جگہ ٹھہرے رہو پھر ہم ان میں جدائی ڈال دیں گے ۔","«زیَّلَ» کسی کو ایک جگہ سے سرکا کر یا ہٹا کر دوسروں سے الگ کر دینا ۔","الگ","زیل","10:28",1
273,51,"ا","تَفَرَّقَ","«تَفَرَّقَ» ضد ہے «تَجَمُّع» کی  ۔ یعنی الگ الگ اور متفرق ہو جانا ۔ پھٹ کر علیحدہ علیحدہ ہو جانا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَ اعۡتَصِمُوۡا بِحَبۡلِ اللّٰہِ جَمِیۡعًا وَّ لَا تَفَرَّقُوۡا» ( 3/103 )\nترجمہ : اور سب مل کر خدا کی ( ہدایت کی ) رسی کو مضبوط پکڑے رہنا اور متفرق نہ ہونا ۔","«تَفَرَّقَ» جماعت سے الگ اور متفرق ہو جانا ۔","الگ","تفرق","3:103-3:105-4:130-6:153-12:39-12:67-30:14-42:13-42:14-98:4",10
274,51,"ا","اِعْتَزَلَ","«اِعْتَزَل» کسی چیز سے کنارہ کش ہو جانا خواہ کسی کام سے یا عقیدہ سے ۔ یعنی خواہ یہ کنارہ کشی ظاہری ہو یا معنوی سب صورتوں میں «اِعْتَزَلَ» استعمال ہوتا ہے ۔\n اب ان کی مثالیں دیکھئے :\nاعتقادات سے یعنی معنوی کنارہ کشی کی مثال :\nارشاد باری تعالیٰ ہے :\n«وَاِنۡ لَّمۡ تُؤۡمِنُوۡا لِیۡ فَاعۡتَزِلُوۡنِ» ( 44/21 )\nترجمہ : اگر تم مجھ پر ایمان نہیں لاتے تو مجھ سے الگ ہو جاؤ ۔\nکسی کام سے یعنی ظاہری کنارہ کشی کی مثال :\nارشاد باری تعالیٰ ہے :\n«فَاعۡتَزِلُوا النِّسَآءَ فِی الۡمَحِیۡضِ» ( 2/222 )\nترجمہ : سو ایام حیض میں عورتوں سے کنارہ کش رہو ۔","«اِعْتَزَل» کسی کام سے یا عقیدہ سے یا انسانوں سے کنارہ کشی اختیار کر لینا ۔","الگ","اعتزل","2:222-4:90-4:91-18:16-19:48-19:49-44:21",7
275,51,"ا","تَجَنَّبَ","«تَجَنَّبَ» ایک طرف ہو کر دور رہنا ۔ پہلو تہی کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«سَیَذَّکَّرُ مَنۡ یَّخۡشٰی وَ  یَتَجَنَّبُہَا الۡاَشۡقَی» ( 87/10،11 )\nترجمہ : جو خوف رکھتا ہے وہ تو نصیحت پکڑے گا اور ( بے خوف ) بدبخت پہلو تہی کرے گا ۔","«تَجَنَّبَ» کسی چیز سے الگ ہو کر دور چلے جانا تاکہ مصیبت سے نجات مل جائے ۔","الگ","تجنب","87:11",1
276,51,"ا","اِمْتَازَ","«اِمْتَازَ» کسی فضیلت اور ترجیح کی بنیاد پر اچھی چیز کا بری سے یا بری چیز کا اچھی سے الگ ہو جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَامۡتَازُوا الۡیَوۡمَ اَیُّہَا الۡمُجۡرِمُوۡنَ» ( 36/59 )\nترجمہ : اور گنہگارو ! تم آج الگ ہو جاؤ ۔\nاس کے علاوہ درج ذیل الفاظ بھی الگ ہونا کے معنوں میں استعمال ہوتے ہیں ۔\n«خَلَا ، خَلَو ، خَلَصَ ، فَصَلَ ، اِنْتَبَذَ ، نَبَذَ ، تَزَیَّلَ ، زَیَّلَ ، اور تَجَافٰی ، جَفَو»","«اِمْتَازَ» کسی خصوصیت کی بناء پر دوسروں سے الگ ہونا ۔","الگ","امتاز","36:59",1
277,51,"ا","خَلَا","« خَلَاء ، یَخْلُو» خالی جگہ کو کہتے ہیں جہاں عمارت اور مکان وغیرہ کچھ نہ ہو ۔ یہ لفظ زمان و مکان دونوں کے لیے استعمال ہوتا ہے ۔ جیسے «خَلَا الزَّمَان» کے معنی زمانہ گزر گیا اور ظرف مکانی کے لحاظ سے «خَلَا الرَّجُل» کے معنی کسی کے ساتھ علیحدگی (خلوت) میں ملاقات کرنا ہو گا (مف منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَاِذَا خَلَوۡا اِلٰی شَیٰطِیۡنِہِمۡ ۙ قَالُوۡۤا اِنَّا مَعَکُمۡ» ( 2/14 )\nترجمہ : اور جب تنہا ہوتے ہیں اپنے شیطانوں کے پاس تو کہتے ہیں ۔ بے شک ہم تمہارے ساتھ ہیں ( عثمانیؒ )","«خَلَا» تنہائی میں ملنے کے لیے علیحدہ ہونا ۔","الگ","خلا","2:14-2:76-2:214-3:119-10:102-24:34-33:38-33:62-35:24",9
278,51,"ا","خَلَصَ","«خَلَصَ» کسی چیز کوملاوٹ سے پاک کرنا اوراس سے ملاوٹ علیحدہ کرنا اور اس کی ضد «خَلَطَ» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَلَمَّا اسۡتَیۡئَسُوۡا مِنۡہُ خَلَصُوۡا نَجِیًّا» ( 12/80 )\nترجمہ : جب یہ اس سے مایوس ہوگئے تو تنہائی میں بیٹھ کر مشورہ کرنے لگے ۔\nیعنی آپس میں مشورہ کرنے کے لیے دوسرے لوگوں سے الگ ہو کر کہیں جا بیٹھے ۔","«خَلَصَ» ملاوٹ  کا اصل چیز سے الگ ہونا اور خالص باقی رہ جانا ۔","الگ","خلص","2:139-4:146-7:29-10:22-12:24-12:54-12:80-15:40-19:51-29:65-31:32-37:40-37:74-37:128-37:160-37:169-38:46-38:83-39:2-39:11-39:14-40:14-40:65-98:5",24
279,51,"ا","فَصَلَ","«فَصَلَ» دو چیزوں کا یوں علیحدہ ہونا کہ ان میں فاصلہ ہو جائے (مف) کسی مقام سے روانہ ہو جانا :\nمثلاً : قرآن کریم میں ہے :\n«فَلَمَّا فَصَلَ طَالُوۡتُ بِالۡجُنُوۡدِ  ۙ قَالَ  اِنَّ اللّٰہَ مُبۡتَلِیۡکُمۡ بِنَہَرٍ» ( 2/249 )\nترجمہ : غرض جب طالوت فوجیں لے کر روانہ ہوا تو اس نے ( ان سے ) کہا کہ خدا ایک نہر سے تمہاری آزمائش کرنے والا ہے ۔","«فَصَلَ» دو چیزوں کو ایک دوسرے سے  اس طرح علحیدہ  کرنا کہ ان کے درمیان فاصلہ پیدا ہوجائے ۔","الگ","فصل","2:249-6:65-6:97-6:98-6:114-6:119-6:126-7:32-7:52-7:133-7:174-9:11-10:5-10:24-11:1-12:94-17:12-30:28-41:3-41:44",20
280,51,"ا","اِنْتَبَذَ","«نَبَذَ» کے معنی کسی چیز کو ناقابل التفات ( یعنی فراموش کردیئے جانے کے قابل چیز جو التفات و توجہ کے قابل نہ ہو) سمجھ کر پھینک دینا (مف) اور «اِنتَبَذَ» کے معنی خود احساس کمتری میں مبتلا ہو کر دوسروں سے علیحدہ ہو جانے کے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاذۡکُرۡ فِی الۡکِتٰبِ مَرۡیَمَ ۘ اِذِ انۡتَبَذَتۡ مِنۡ اَہۡلِہَا مَکَانًا شَرۡقِیًّا» ( 19/16 )\nترجمہ : اور کتاب ( قرآن ) میں مریم کا بھی تذکرہ کرو ۔ جب وہ اپنے لوگوں سے الگ ہو کر مشرق کی طرف چلی گئیں ۔\nاس مقام پر حضرت مریم کے لیے «اِنتَبَذَ» کا لفظ اس لیے استعمال ہوا ہے کہ وہ حضرت عیسیٰ ؑ کے حمل کی وجہ سے لوگوں کے اعتراضات اور لعنت ملامت سے بچنے کے لیے لوگوں سے علیحدہ ہو کرتنہائی میں چلی گئی تھیں ۔","«اِنْتَبَذَ» احساسِ کمتری کی وجہ سے دوسروں سے الگ ہونا ۔","الگ","انتبذ","19:16-19:22",2
281,51,"ا","تَزَیَّل","«زَالَ»  کے معنی چیز کو اس کی جگہ سے ہٹا دینا (مف) اسی نسبت سے «تَزَیَّلَ» کے معنی کسی چیز کا اپنی جگہ چھوڑ کرادھرادھر ہو جانا ۔ ہٹ کر پرے ہو جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«لَوۡ تَزَیَّلُوۡا لَعَذَّبۡنَا الَّذِیۡنَ کَفَرُوۡا مِنۡہُمۡ عَذَابًا اَلِیۡمًا» ( 48/25 )\nترجمہ : اور اگر وہ الگ ہو جاتے تو جو ان میں کافر تھے ہم ان کو دکھ دینے والا عذاب دیتے ۔","«تَزَیَّلَ» اپنی جگہ چھوڑ دینا اور ہٹ کر علیحدہ ہونا ۔","الگ","تزیل","48:25",1
282,51,"ا","تَجَافٰی","«جَفْوَۃٌ» اور «جَفَاءٌ» کے معنی ظلم اور «جَفَا یَجْفُوا» کے معنی ایک جگہ قرار نہ پکڑنا ہے (منجد) اور اسی نسبت سے «تَجَافٰی» کا معنی بیقراری کی وجہ سے اپنی جگہ بدلنا یا اس جگہ سے الگ رہنا ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«تَتَجَافٰی جُنُوۡبُہُمۡ عَنِ الۡمَضَاجِعِ یَدۡعُوۡنَ رَبَّہُمۡ خَوۡفًا وَّ طَمَعًا» ( 32/16 )\nترجمہ : اُن کے پہلو بچھونوں سے الگ رہتے ہیں ( اور ) وہ اپنے پروردگار کو خوف اور امید سے پکارتے ہیں ۔","«تَجَافٰی» بیقراری کی وجہ سے کسی چیز سے الگ ہونا ۔","الگ","تجافی","32:16",1
283,52,"ا","اَمَلَ","«اَمَلَ» کی بحث ’’ آرزو ‘‘ میں گزر چکی ہے اور اس کے معنی ایسی آرزو اور امید کے ہیں جو بظاہرغیرمتوقع اور دیر سے وقوع بذیر ہونے والی ہو ۔ گویا «اَمَل» میں مدت اور انتظار کا تصور بھی پایا جاتا ہے ۔ اس لحاظ سے یہ امید لگائے رکھنے کے معنی میں آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ الۡبٰقِیٰتُ الصّٰلِحٰتُ خَیۡرٌ عِنۡدَ رَبِّکَ ثَوَابًا وَّخَیۡرٌاَمَلًا» ( 18/46 )\nترجمہ : اور نیکیاں جو باقی رہنے والی ہیں وہ ثواب کے لحاظ سے تمہارے پروردگار کے ہاں بہت اچھی اور امید لگانے کے لحاظ سے بہت بہتر ہیں ۔","«اَمَلَ» دیر سے پوری ہونے والی اور بظاہر غیر متوقع امید کے لیے استعمال ہوتا ہے ۔","امید","امل","15:3-18:46-47:25",3
284,52,"ا","اَمْنٰی","«اَمْنِیَۃ» بمعنی جھوٹی اور باطل آرزو اور «اَمَانِی» اس کی جمع ہے ۔ یہ بحث بھی ’’ آرزو کرنا ‘‘ میں گزر چکی اور «اَمْنٰی» کا لفظ کسی کو ایسی ہی باطل اور جھوٹی امید دلانے کے معنوں میں آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّ لَاُضِلَّنَّہُمۡ وَ لَاُمَنِّیَنَّہُمۡ» ( 4/119 )\nترجمہ : ( شیطان نے کہا ) اور ان ( انسانوں ) کو ضرور گمراہ کرتا اور امیدیں لگاتا رہوں گا ۔","«اَمْنٰی» جھوٹی امیدیں دلانے کے لیے استعمال ہوتا ہے ۔","امید","امنی","4:119-22:52",2
285,52,"ا","رجا","«رَجُو رَجَا» کے دو بنیادی معنی ہیں (1) کنارہ (2) امید لگانا (م ۔ ل) یہاں دوسرے معنیٰ سے غرض ہے اور اس میں بھی «اَمَلَ» کی طرح مدت اور انتظار کا تصور پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاٰخَرُوۡنَ مُرۡجَوۡنَ لِاَمۡرِ اللّٰہِ» ( 9/106 )\nترجمہ : اور کچھ اور لوگ ہیں جن کا معاملہ اللہ کا حکم آنے تک ملتوی ہے\nالبتہ «رَجَاء» ایسی امید کو کہتے ہیں جس کے پورا ہونے کا ظن غالب ہوتا ہے ( اور اس کی ضد یاس ہے ) ۔\nمثلاً : قرآن کریم میں ہے\n«وَلَا تَہِنُوۡا فِی ابۡتِغَآءِ الۡقَوۡمِ ؕ اِنۡ تَکُوۡنُوۡا تَاۡلَمُوۡنَ فَاِنَّہُمۡ یَاۡلَمُوۡنَ کَمَا تَاۡلَمُوۡنَ ۚ وَ تَرۡجُوۡنَ مِنَ اللّٰہِ مَا لَا یَرۡجُوۡنَ» ( 4/104 )\nترجمہ : اور کفار کے پیچھا کرنے میں سستی نہ کرنا ۔ اگر تم بے آرام ہوتے ہو تو جس طرح تم بے آرام ہوتے ہو ۔ اسی طرح وہ بھی بے آرام ہوتے ہیں اور تم خدا سے ایسی ایسی امیدیں بھی رکھتے ہو جو وہ نہیں رکھتے ۔","«رَجَا» ایسی امید کے لیے آتا ہے جس کے  پورا ہونے کا ظن غالب ہو خواہ دیر سے ہو ۔","امید","رجا","2:218-4:104-9:106-10:7-10:11-10:15-11:62-17:28-17:57-18:110-24:60-25:21-25:40-28:86-29:5-29:36-33:21-35:29-39:9-45:14-60:6-71:13-78:27",23
286,53,"ا","حَوَایَا","«حَوَایَا» جمع ہے «حَوِیَّۃ» کی مراد سانپ کی طرح کنڈلی مارنے والی انتڑیاں ہیں «حَیَّۃٌ» سانپ کو کہتے ہیں «تَحْوِی الْحَیّۃ» سانپ کے کنڈلی مارنے کو اور «حَاوِی» ۔ سانپ کا منتر پڑھنے والے کو کہا جاتا ہے (منجد) اور یہ وہ  آنت یا انتڑی ہے جو کنڈلی مارتے ہوئے مقعد یعنی پیچھے تک چلی جاتی ہے ۔ (م ۔ ر)\nمثلاً : قرآن کریم میں ہے :\n«حَرَّمۡنَا عَلَیۡہِمۡ شُحُوۡمَہُمَاۤ اِلَّا مَا حَمَلَتۡ ظُہُوۡرُہُمَاۤ اَوِالۡحَوَایَاۤ اَوۡمَا اخۡتَلَطَ بِعَظۡمٍ» ( 6/146 )\nترجمہ : اور ہم نے ان ( یہودیوں ) پر ان دونوں ( گائے اور بکری ) کی چربی حرام کر دی تھی سوائے اس کے جو ان کی پیٹھ پر لگی ہو یا انتڑیوں کی یا جو ہڈی کے ساتھ مل گئی ہو ۔","«حَوَایَا» ان  انتڑیوں کے لئے استعمال ہوتا ہے  جو  سانپ کی  کنڈلی کی طرح  نظر آئے ۔","انتڑیاں","حوایا","6:146",1
287,53,"ا","اَمْعَآء","«اَمْعَآء» جمع ہے «معْیٌ» کی  یہ لفظ عام ہے جو ہر قسم کی چھوٹی بڑی انتڑیوں کے لیے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَسُقُوۡا مَآءً حَمِیۡمًا فَقَطَّعَ اَمۡعَآءَہُمۡ» ( 47/15 )\nترجمہ : اور انہیں کھولتا ہوا پانی پلایا جائے گا جو ان کی انتڑیوں کو ٹکڑے ٹکڑے کر دے گا ۔","«اَمْعَآء» ہر قسم کی چھوٹی بڑی انتڑیوں کے لیے استعمال ہوتا ہے۔","انتڑیاں","امعآء","47:15",1
288,54,"ا","اِنْتَظَرَ","«نَظَرَ» دو کے بنیادی معنی ہیں ۔ (1) معائنہ یعنی آنکھوں سے کوئی چیز دیکھنا اور (2) «تَاَمَّلِ الشَّیْء» کسی چیز کے لیے انتظار اور مہلت (م ل) یہاں دوسرے معنی سے غرض ہے ۔ قرآن کریم میں «نَظِرَۃٌ» اسی معنی میں آیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ کَانَ ذُوۡ عُسۡرَۃٍ فَنَظِرَۃٌ اِلٰی مَیۡسَرَۃٍ» ( 2/280 )\nترجمہ : اور اگر مقروض تنگ دست ہو تو فراخی حاصل ہونے تک اسے مہلت دو ۔\nاور «اِنْتَظَرَ» کسی امید کے پورا ہونے کا وقت گزارنا اور یہ لفظ انتظار کے لیے عام ہے اور اس لحاظ سے «نَظَرَۃ» اور «اِنْتِظَار» قریب المعنیٰ ہیں ۔ اور انتظار خیر و شر ۔ اور شک اور یقین دونوں صورتوں میں استعمال ہوتا ہے ۔ ( فق ل 58 )\nمثلاً : قرآن کریم میں ہے :\n«وَ قُلۡ لِّلَّذِیۡنَ لَا یُؤۡمِنُوۡنَ اعۡمَلُوۡاعَلٰی مَکَانَتِکُمۡ ؕ اِنَّا عٰمِلُوۡنَ وَانۡتَظِرُوۡا ۚ اِنَّا مُنۡتَظِرُوۡنَ» ( 11/121،122 )\nترجمہ : اور جو لوگ ایمان نہیں لائے ان سے کہہ دو کہ تم اپنی جگہ عمل کیے جاؤ ہم ( اپنی جگہ عمل کیے جاتے ہیں ۔ اور نتیجہ اعمال کا ) تم بھی انتظار کرو ۔ ہم بھی انتظار کرتے ہیں ۔","«اِنْتِظَار» کسی امید کے  پورا ہونے  تک کا وقت  گزارنا اور یہ لفظ عام ہے ۔ خیر و شر میں اور شک و یقین دونوں صورتوں میں استعمال ہوتا ہے ۔","انتظار","انتظر","6:158-7:71-10:20-10:102-11:122-32:30-33:23",7
289,54,"ا","اِرْتَقَبَ","«رَقَبَۃٌ» گردن کو کہتے ہیں اور «رَقَبَ» کسی کی گردن پر نظر رکھنے یا اس کی نگرانی کرنے کے لیے استعمال ہوتا ہے (مف) اور «رِقْبَۃٌ» کے معنی احتیاط ۔ نگہبانی ، بچاؤ اور خوف ہے (منجد) لہذا «اِرْتَقَبَ» سے مراد ایسا انتظار ہے جس میں انسان چوکس اور چوکنا رہے ۔ دوسرے کی حرکات و سکنات کا خیال رکھے اور اپنے بچاؤ کا بھی ۔\nمثلاً : قرآن کریم میں ہے :\n«سَوۡفَ تَعۡلَمُوۡنَ ۙ مَنۡ یَّاۡتِیۡہِ عَذَابٌ یُّخۡزِیۡہِ  وَ مَنۡ ہُوَ کَاذِبٌ ؕ وَ ارۡتَقِبُوۡۤا  اِنِّیۡ  مَعَکُمۡ  رَقِیۡبٌ» ( 11/93 )\nترجمہ : تم کو عنقریب معلوم ہو جائے گا کہ رسوا کرنے والا عذاب کس پر آتا ہے اور جھوٹا کون ہے ! اور تم بھی انتظار کرو میں بھی تمہارے ساتھ انتظار کرتا ہوں ۔","«تَرَقُّب» انتظار کرنا اور چوکس رہنا ۔ کڑی نظر رکھنا ۔ عمومًا برائی کے وقت انتظار کے لیے آتا ہے ۔","انتظار","ارتقب","4:1-5:117-11:93-28:18-28:21-44:10-44:59-50:18-54:27",9
290,54,"ا","تَرَبُّص","«رَبَصَ» اور «تَرَبُّص» ایک ہی معنی میں استعمال ہوتے ہیں اور یہ انتظار یا تو کسی معینہ مدت کے لیے ہوتا ہے یا کسی ایسے کام کے ہونے یا زائل ہونے کا جس کی توقع ہو (مف) ۔ مثلاً اشیائے تجارت کی گرانی اور قیمت کی کمی کا انتظارکرنا ۔ «تَرَبُّص بِسِلْعَۃٍ» کا معنی ہے مال کی گرانی کا انتظار کرنا (منجد)\nاسی طرح عورت کے لیے اپنی عدت پوری کرنے کا انتظارکرنا «تَرَبُّص» کہلائے گا اور بمعنی زیادہ فائدہ حاصل کرنے کے لیے انتظار کرنا ۔ ( فق ل 59 )\nمثلاً : قرآن کریم میں ہے :\n«قُلۡ ہَلۡ تَرَبَّصُوۡنَ بِنَاۤ اِلَّاۤ اِحۡدَی الۡحُسۡنَیَیۡنِ ؕ وَنَحۡنُ نَتَرَبَّصُ بِکُمۡ اَنۡ یُّصِیۡبَکُمُ اللّٰہُ بِعَذَابٍ مِّنۡ عِنۡدِہٖۤ اَوۡبِاَیۡدِیۡنَا ۫ ۖفَتَرَبَّصُوۡۤا اِنَّا مَعَکُمۡ مُّتَرَبِّصُوۡنَ» ( 9/52 )\nترجمہ : کہہ دو کہ تم ہمارے حق میں دو بھلائیوں میں سے ایک کے منتظر ہو اور ہم تمہارے حق میں اس بات کے منتظر ہیں کہ خدا ( یا تو ) خود اپنے پاس سے تم پر کوئی عذاب نازل کرے اور یا ہمارے ہاتھوں سے تو تم بھی انتظار کرو ۔ ہم بھی تمہارے ساتھ انتظار کرتے ہیں ۔","«تَرَبُّص» زیادہ فائدہ حاصل کرنے کی مدّت یا معیّنہ مدّت کا انتظار ۔","انتظار","تربص","2:226-2:228-2:234-4:141-9:24-9:52-9:98-20:135-23:25-52:30-52:31-57:14",12
291,55,"ا","منتھیٰ","«اَلنَّھِی» کے معنی روکنا اور «اِنْتَھٰی» رک جانا کے معنوں میں آتا ہے ۔ «اَلْنِھَاءِ وَالنَّھَایَۃ» ۔ کسی چیز کی غایت اور آخر (منجد) اور «نَھَایَۃُ الدَّار» گھر کی چار دیواری کو کہتے ہیں (م ق) اور «مُنْتَھٰی» اسم ظرف ہے ۔ زمانہ یا جگہ کے لحاظ سے کوئی چیز جہاں تک پہنچ کر رک جائے وہ اس کی آخری حد یا «مُنْتَھٰی» یا انجام ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ  یُجۡزٰىہُ  الۡجَزَآءَ  الۡاَوۡفٰی وَ اَنَّ  اِلٰی رَبِّکَ الۡمُنۡتَہٰی» ( 53/41،42 )\nترجمہ : پھر اس کو اس کا پورا پورا بدلہ دیا جائے گا اور یہ کہ آخر تمہارے پروردگار ہی پاس پہنچنا ہے ۔","«مُنْتَھیٰ» کسی کام کا انجام جہاں جا کر وہ ختم ہوتا ہے ، یہ عام ہے ۔","انجام","منتھی","2:192-2:193-2:275-4:171-5:73-5:91-8:19-8:38-8:39-9:12-19:46-26:116-26:167-33:60-36:18-53:14-53:42-59:7-79:44-96:15",20
292,55,"ا","صَارَ","«صَیْر» کے معنی میں دو باتیں بنیادی ہیں (1) رجوع اور (2) انجام (م ۔ ل) اور «َصْیرُالْاَمْر» سے مراد کسی کام کا آخری حصہ یا اس کی انتہا ہے ۔ جب کسی شخص کا کوئی کام اختتام پذیر ہو تو کہتے ہیں «فُلَانٌ عَلیٰ صَیْرِ الْاَمْرِ» (منجد) پھر «صَارَ» کے معنی ایک حالت سے دوسری حالت میں منتقل ہونا بھی ہیں (منجد) گویا «صَارَ» کا لفظ کام کی نوعیت سے بھی تعلق رکھتا ہے ۔ ایک کام جس طریقہ اور ڈھنگ سے ہو رہا ہے وہ کوئی اور رخ تو اختیار نہیں کرے گا اور جس انداز میں وہ جا کر ختم ہو گا اس آخری کیفیت کا نام «صَیْر» ہے اور «مَصِیْر» اس جگہ کو کہتے ہیں جہاں کوئی چیز نقل و حرکت کے بعد پہنچ کر ختم ہو جاتی ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«اَلَاۤ  اِلَی اللّٰہِ  تَصِیۡرُ الۡاُمُوۡرُ» ( 42/53 )\nترجمہ :  یاد رکھو کہ سارے معاملات آخر کار اللہ ہی کی طرف لوٹیں گے ۔","«صَیْر» کسی کام کا انجام اور اس کے ختم ہونے کا رخ اور طور طریقہ ۔","انجام","صار","2:126-2:285-3:28-3:162-4:97-4:115-5:18-8:16-9:73-14:30-22:48-22:72-24:42-24:57-25:15-31:14-35:18-40:3-42:15-42:53-48:6-50:43-57:15-58:8-60:4-64:3-64:10-66:9-67:6",29
293,55,"ا","عَاقِبَۃ","«عَقَبَ» بمعنی ایڑی اور «عَقَّبْ» کے معنی کسی کے پیچھے چلنا اور پیچھے آنا اور «عَاقِبَۃ» ہر چیز کا آخر ، یا کسی کام کا انجام ہے (منجد) پھر عقب کے مفہوم میں شدت اور تکلیف بھی پائی جاتی ہے «عَاقَبَہٗ» کے معنی کسی کو اس کے عمل کے بدلہ میں پکڑنا بھی ہے اور «عِقَاب» کا لفظ عمومًا کسی برے کام کے بدلہ کے لیے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَجٰدَلُوۡا بِالۡبَاطِلِ لِیُدۡحِضُوۡا بِہِ الۡحَقَّ فَاَخَذۡتُہُمۡ ۟ فَکَیۡفَ کَانَ عِقَابِ» ( 40/5 )\nترجمہ : اور بیہودہ ( شبہات سے ) جھگڑتے رہے تاکہ اس سے حق کو زائل کر دیں تو میں نے ان کو پکڑ لیا ۔ سو ( دیکھ لو ) میرا عذاب کیسا ہوا ؟\nگویا «عَاقِبَۃ» کے لفظ کا اطلاق محض کسی کام کے انجام پر نہیں ہوتا بلکہ اس کام کے بدلہ پر بھی ہوتا ہے ۔\nمثلاً : خیر کے لیے ارشاد باری تعالیٰ ہے :\n«اِنَّ الۡاَرۡضَ لِلّٰہِ ۟ ۙ یُوۡرِثُہَا مَنۡ یَّشَآءُ مِنۡ عِبَادِہٖ ؕ وَ الۡعَاقِبَۃُ  لِلۡمُتَّقِیۡنَ» ( 7/128 )\nترجمہ : زمین تو خدا کی ہے ۔ وہ اپنے بندوں میں سے جسے چاہتا ہے اس کا مالک بنا دیتا ہے اور آخر بھلا تو ڈرنے والوں کا ہے ۔\nاور شر کے لیے ارشاد باری تعالیٰ ہے :\n«قَدۡ خَلَتۡ مِنۡ قَبۡلِکُمۡ سُنَنٌ ۙ فَسِیۡرُوۡا فِی الۡاَرۡضِ فَانۡظُرُوۡا کَیۡفَ کَانَ عَاقِبَۃُ الۡمُکَذِّبِیۡنَ»\nترجمہ : تم سے پہلے بھی بہت سے واقعات گزر چکے ہیں تو تم زمین میں سیر کر کے دیکھ لو کہ جھٹلانے والوں کا کیسا انجام ہوا ؟","«عَاقِبَۃ» کسی کام کے انجام اور اس کے بدلہ کے لیے استعمال ہوتا ہے ۔","انجام","عاقبۃ","3:137-6:11-6:135-7:84-7:86-7:103-7:128-10:39-10:73-11:49-12:109-16:36-20:132-22:41-27:14-27:51-27:69-28:37-28:40-28:83-30:9-30:10-30:42-31:22-35:44-37:73-40:21-40:82-43:25-47:10-59:17-65:9",32
294,56,"ا","خَرَصَ","«خَرَصَ» کے معنی محض گمان اور اندازے سے کام لینا «خَرَصَ النَّخْلَۃ» سے یہ مراد ہے کہ محض اٹکل سے اندازہ کرنا کہ اس کھجور کے درخت پر کتنا پھل ہو گا اور «خَرَّاص» ایسا تخمینہ (اندازہ) لگانے والے آدمی کو کہتے ہیں (منجد) اور «خَرَّاص» بمعنی کذاب (بہت جھوٹا آدمی) بھی مستعمل ہے کیونکہ ایسا آدمی بغیر علم اور حقیقت کے بات کرتا ہے اور یہی بات جھوٹ کی بنیاد ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنۡ تَتَّبِعُوۡنَ اِلَّا الظَّنَّ وَ اِنۡ اَنۡتُمۡ اِلَّا تَخۡرُصُوۡنَ» ( 6/148 )\nترجمہ : تم محض خیال کے پیچھے لگتے اور اٹکل کے پیچھے چلتے ہو ۔","«خَرَصَ» ایسا اندازہ جس کی بنیاد علم و حقیقت کی بجائے گمان اور اندازے پر ہو ۔ اور یہ ناقابلِ اعتماد ہوتا ہے ۔","اندازہ ","خرص","6:116-6:148-10:66-43:20",4
295,56,"ا","قَدَّرَ","«قَدَرَ» کے معنی کسی معاملہ کی تدبیر کرنا ، کسی چیز کو تیار کرنا اور اس کی دیکھ بھال کرنا ہے (منجد) اور «قَدَرْ» سے مراد وہ قوانین فطرت ہیں جن کے تحت کوئی چیز وجود میں آتی اور ترتیب پاتی ہے (مف) اور یہ صفت اللہ تعالیٰ سے خاص ہے اور صرف اچھے معنوں میں آتا ہے ( فق ل 157 )\nمثلاً : قرآن کریم میں ہے :\n«اِنَّا کُلَّ شَیۡءٍ خَلَقۡنٰہُ بِقَدَرٍ» ( 54/49 )\nترجمہ : ہم نے ہر چیز اندازہ مقررہ کے ساتھ پیدا کی ہے ۔\nاور «قَدَّرَ» کے کسی چیز کو اس مخصوص طرز پر بنانا اور تربیت کرنا ہے جیسا کہ حکمت کا تقاضا ہو ، اور یہ لفظ عام ہے اور یہ اندازہ اچھا بھی ہو سکتا ہے اور برا بھی ( فق ل 157 ) جیسا کہ یہ بات عقیدہ میں شامل ہے ۔ «وَالْقَدْرِ خَیْرِہٖ وَشَرِّہٖ مِنَ اللہِ تَعَالیٰ» ۔\nمثلاً : قرآن کریم میں ہے :\n«ہُوَ الَّذِیۡ جَعَلَ الشَّمۡسَ ضِیَآءً وَّ الۡقَمَرَ نُوۡرًا وَّ قَدَّرَہٗ  مَنَازِلَ  لِتَعۡلَمُوۡا عَدَدَ السِّنِیۡنَ وَ الۡحِسَابَ» ( 10/5 )\nترجمہ :’’ وہی تو ہے جس نے سورج کو روشن اور چاند کو منور بنایا اور چاند کی منزلیں مقرر کیں تاکہ تم برسوں کا شمار اور ( کاموں کا ) حساب معلوم کرو ۔","«قَدَّرَ» وہ قوانینِ فطرت ہیں جو اللہ تعالیٰ نے اپنے علم و حکمت سے مقرر کر رکھے ہیں اور یہ مستحکم الدلائل ہوتے ہیں ۔ اور «قَدَّرَ» ایسے قوانین پر مبنی اندازہ کو کہتے ہیں ۔","اندازہ ","قدر","13:26-17:30-28:82-29:62-30:37-34:36-34:39-39:52-42:12-65:7-89:16",11
296,57,"ا","خلال","«خَلَال» دو ایسی چیزوں کے اندر کوئی جگہ جن کا آپس میں تعلق ہو «خِلَال» دانتوں کی درمیانی جگہ کو صاف کرنے کے تنکی کو بھی کہتے ہیں اور اس جگہ کے صاف کرنے کو بھی ۔ ایسے ہی ہاتھ کی انگلیوں اور داڑھی کے بالوں میں وضو کرتے وقت پانی سے خلال کیا جاتا ہے ۔\nمثلاً : منافقین کے بارے میں ارشاد باری ہے :\n«لَوۡ خَرَجُوۡا فِیۡکُمۡ مَّا زَادُوۡکُمۡ  اِلَّا خَبَالًا وَّ لَا۠اَوۡضَعُوۡا خِلٰلَکُمۡ یَبۡغُوۡنَکُمُ الۡفِتۡنَۃَ» ( 9/47 )\nترجمہ :’’ اگر وہ تم میں شامل ہو کر نکل بھی کھڑے ہوتے تو تم میں فساد ڈلوانے کی خاطر تمہارے ہی اندر گھوڑے دوڑاتے ۔","«خَلَال» دو ایسی چیزوں کے بیچ کی کشادگی جن کا آپس میں تعلق ہو ۔ مثلاً دانتوں  کا درمیانی فاصلہ ۔","اندر","خلال","9:47-14:31-17:5-17:91-18:33-24:43-27:61-30:48",8
297,57,"ا","باطن","«بَاطِن» بطن پیٹ اور ہر چیز کے اندرونی حصہ کو کہتے ہیں اور «بَاطِن» صرف کسی چیز کے اندرونی حصہ ، اندرونی جانب یا اندر کو کہا جاتا ہے (منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَضُرِبَ بَیۡنَہُمۡ بِسُوۡرٍ لَّہٗ  بَابٌ ؕ بَاطِنُہٗ  فِیۡہِ الرَّحۡمَۃُ وَ ظَاہِرُہٗ  مِنۡ  قِبَلِہِ  الۡعَذَابُ» ( 57/13 )\nترجمہ : سو ان کے درمیان ایک دیوار کھڑی کر دی جائے گی جس کا ایک دروازہ ہو گا ۔ اس کے اندر ( کی طرف ) تو رحمت ہو گی اور باہر کی طرف عذاب ہو گا ۔\nبطائن : «بَطَانَۃ» کی جمع ہے اور «بَطَانَۃ» لباس کے اندر کی طرف لگے ہوئے کپڑے یا استر کو بھی کہتے ہیں اور بھید کو بھی (منجد) نیز رازدار دوست کو بھی ۔\nمثلاً : قرآن کریم میں ہے :\n«مُتَّکِئِیۡنَ عَلٰی فُرُشٍۭ بَطَآئِنُہَا مِنۡ اِسۡتَبۡرَقٍ» ( 55/54 )\nترجمہ : ( اہل جنت ) ایسے بچھونوں سے تکیہ لگائے ہوں گے جن کے استر اطلس کے ہوں گے ۔","«بَاطِن» کسی چیز کا اندر یا اسکا اندرونی حصہ  ۔","اندر","باطن","3:35-6:120-6:151-7:33-24:45-31:20-37:144-57:3-57:13",9
298,57,"ا","جَوْف","«جَوِفَ» بمعنی کھوکھلا ہونا اور «جَوَّف» بمعنی کھوکھلا کرنا ۔ «جَوْف» پیٹ یا اندرونی حصہ کو کہتے ہیں اور «جَوفَ الْبَیْت» مکان کے اندرونی حصہ کو اور «مُجَّوَف» کھوکھلی چیز کو (منجد) گویا «جَوِفَ» میں جہاں اندر یا اندرونی حصہ کا تصور پایا جاتا ہے وہاں ساتھ ہی ساتھ کھوکھلا پن وسعت یا خلا کا تصور بھی پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«مَا جَعَلَ اللّٰہُ  لِرَجُلٍ مِّنۡ قَلۡبَیۡنِ فِیۡ جَوۡفِہٖ» ( 33/4 )\nترجمہ : اللہ تعالیٰ نے کسی آدمی کے اندر دو دل نہیں بنائے ۔","«جَوْف» کسی چیز کا اندرونی خلا ۔","اندر","جوف","33:4",1
299,58,"ا","اَعْمٰی","«اَعْمٰی» بمعنی اندھا نابینا جو دیکھنے سے محروم ہو ۔ آنکھوں کا اندھا ۔ ( فل 39 )\nمثلاً : قرآن کریم میں ہے :\n«ہَلۡ یَسۡتَوِی الۡاَعۡمٰی وَ الۡبَصِیۡرُ» ( 13/16 )\nترجمہ : کیا بینا اور نابینا برابر ہیں ؟\nگو اس لفظ کا اطلاق عمومًا ظاہری آنکھوں کے اندھے پن پر ہوتا ہے لیکن گاہے گاہے دل کے اندھے پن پر بھی ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَاۤ اَنۡتَ بِہٰدِی الۡعُمۡیِ عَنۡ ضَلٰلَتِہِمۡ» ( 27/81 )\nترجمہ : اور آپ ان اندھوں کو گمراہی سے ( نکال کر ) راستہ نہیں دکھا سکتے ۔","«اَعْمٰی» بمعنی اندھا  ۔","اندھا","اعمی","2:18-2:171-6:50-6:104-7:64-10:43-11:24-11:28-13:16-13:19-17:72-17:97-20:124-20:125-22:46-24:61-25:73-27:81-28:66-30:53-35:19-40:58-41:17-41:44-43:40-47:23-48:17-80:20",28
300,58,"ا","اَکْمَہَ","«اَکْمَہَ» ایسا شخص جو پیدائشی اندھا ہو (م ل ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَ تُبۡرِیُٔ الۡاَکۡمَہَ وَ الۡاَبۡرَصَ بِاِذۡنِیۡ»\nترجمہ : اور ( اے عیسیٰ ؑ ) تم میرے حکم سے مادرزاد اندھے اور سفید داغ والے کو ٹھیک کر دیتے تھے ۔","«اَکْمَہَ» پیدائشی اندھے کے لیے استعمال ہوتا ہے ۔","اندھا","اکمہ","3:49-5:110",2
301,58,"ا","عَمِہَ","«عَمْہٌ» بمعنی فقدان بصیرت یعنی بصیرت کا نہ ہونا (منجد) اور بمعنی دل کا اندھا پن ( م ق ) اور بمعنی حیران ہونا  ۔ گمراہی میں بھٹکنا ( منجد ) اور بمعنی حیرانگی کی وجہ سے تردُّد  شک و شبہ میں پڑنا (مف)\nمثلاً : قرآن کریم میں ہے :\n«اَللّٰہُ یَسۡتَہۡزِئُ بِہِمۡ وَ یَمُدُّہُمۡ فِیۡ طُغۡیَانِہِمۡ یَعۡمَہُوۡنَ» ( 2/15 )\nترجمہ : اللہ اُن سے مذاق کرتا ہے اور انہیں مہلت دیے جاتا ہے کہ سرکشی میں پڑے بھٹک رہے ہیں ۔ (جالندھری) ۔ اپنی سرکشی اور حالت یہ ہے کہ دل کے اندھے ہیں ۔ ( عثمانی )","«عَمْہٌ» دل کی آنکھوں کا اندھا ہوجا نا ، جانتے بوجھتے حق کو تسلیم نا کرنا ۔","اندھا","عمہ","2:15-6:110-7:186-10:11-15:72-23:75-27:4",7
302,59,"ا","قِسْط","«قِسْط» کے معنی کسی کو اس کا حق پورا پورا ادا کر دینا یعنی اس کے بنیادی معنی ظلم سے بچنے کے ہیں ۔ (مف) اس لحاظ سے اس کا معنی انصاف کرنا کر لیا جاتا ہے ۔ اور اس کا اطلاق ظاہری امور میں انصاف کرنے پر ہوتا ہے ۔ اسی لیے ترازو اور وزن کرنے کے پیمانے کو بھی «قِسْط» کہتے ہیں ( فق ل 194 )\nمثلاً : قرآن کریم میں ہے :\n«وَاَقِیۡمُوا الۡوَزۡنَ بِالۡقِسۡطِ وَلَا تُخۡسِرُواالۡمِیۡزَانَ» ( 55/9 )\nترجمہ : اور انصاف کے ساتھ ٹھیک تولو اور تول کم مت کرو ۔\nپھر «قِسْط» کا لفظ لغت ذوی الاضداد سے ہے ۔ اگر «قَسَطَ یَقْسُطُ» ہو تو اس کے معنی اوپر بیان ہوئے ہیں اور «قَسَطَ یَقْسِطُ» ہو تو اس کے معنی کسی کا حق دبانے ، حق کے خلاف کرنے اور حق سے تجاوز کرنا ہوں گے ۔ (مف) ۔ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَاَمَّا الۡقٰسِطُوۡنَ فَکَانُوۡا لِجَہَنَّمَ حَطَبًا» ( 72/15 )\nترجمہ : اور وہ جو بے انصاف ( ظالم ) ہوئے وہ جہنم کا ایندھن بنے ( عثمانیؒ )\nپھر کسی کے حق کی ادائیگی خواہ ایک مشت ہو یا کئی حصوں میں ۔ اس کے لیے بھی «قِسْط» اور «اَقْسَاط» کے الفاظ استعمال ہوتے ہیں ۔ گویا لفظ «قِسْط» کا استعمال حق کی ادائیگی کل اور جزو دونوں پر ہوتا ہے ۔ لیکن ان معنوں میں اس کا استعمال قرآن کریم میں نہیں ہے ۔ البتہ باب افعال ہو تو انصاف کرنے ہی کے معنوں میں آئے گا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ اَقۡسِطُوۡا ؕ اِنَّ اللّٰہَ یُحِبُّ الۡمُقۡسِطِیۡنَ» ( 49/9 )\nترجمہ : اور انصاف کرو کہ اللہ انصاف کرنے والوں کو پسند کرتا ہے ۔\nنوٹ : (لغت اضداد ایسے الفاظ کو کہتے ہیں جن کے  دو الگ الگ معنیٰ ہوں اور وہ معنیٰ ایک دوسرے کے مخالف اور متضاد ہوں)","«قِسْط» کا لفظ دوسرے کو اس کا پورا پورا حق ادا کرنے کے لیے استعمال ہوتا ہے ، چاہے وہ ایک ساتھ ہو یا قسطوں میں ۔ ","انصاف","قسط","2:282-3:18-3:21-4:3-4:127-4:135-5:8-5:42-6:152-7:29-10:4-10:47-10:54-11:85-17:35-21:47-26:182-33:5-49:9-55:9-57:25-60:8-72:14-72:15",24
303,59,"ا","عدل","«عَدْل» میں دو بنیادی معنی پائے جاتے ہیں (1) توازن و تناسب کو قائم رکھنا (2) دوسرے کو اس کا حق غیر جانبدارانہ طریقہ سے دینا (ف ۔ ق) اور یہ روایت کہ «بالعدل قامت السموت والارض» ۔ یعنی زمین و آسمان عدل کے سہارے قائم ہیں ۔ تو اس کا مطلب یہ ہے کہ کائنات کے سیاروں میں اس قدر توازن و تناسب اور ہم آہنگی ہے ۔ کہ اگر ان کی کشش اور حرکت میں ذرا بھی کمی بیشی ہو جائے تو زمین و آسمان ایک دوسرے سے ٹکرا کر کائنات فورًا فنا ہو جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«الَّذِیۡ خَلَقَکَ فَسَوّٰىکَ فَعَدَلَکَ» ( 82/7 )\nترجمہ : جس نے تجھے پیدا کیا اور ( تیرے اعضا ) کو ٹھیک کیا اور ( تیری قامت کو ) معتدل رکھا ۔\nیہ آیت پہلے معنٰی میں استعمال ہوئی ہے اور عدل کا تعلق ظاہری اور باطنی امور سب پر ہوتا ہے ( فق ل 194 )\nپھر یہ لفظ اسی لحاظ سے برابری اور عوض یا بدلہ کے معنی میں بھی استعمال ہوتا ہے ۔\nدو چیزوں کا آپس میں برابر ہونا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَوۡ کَفَّارَۃٌ  طَعَامُ مَسٰکِیۡنَ اَوۡ عَدۡلُ ذٰلِکَ صِیَامًا لِّیَذُوۡقَ وَبَالَ اَمۡرِہٖ» ( 5/95 )\nترجمہ : یا کفارہ ( دے اور وہ ) مسکینوں کو کھانا کھلانا ( ہے ) یا اس کے برابر روزے رکھے تاکہ اپنے کام کی سزا ( کا مزہ ) چکھے ۔\nعوض ، بدلہ ، معاوضہ :\nمثلاً : قرآن کریم میں ہے :\n«وَّلَا یُقۡبَلُ مِنۡہَا شَفَاعَۃٌ وَّلَا یُؤۡخَذُ مِنۡہَا عَدۡلٌ» ( 2/48 )\nترجمہ : نہ کسی کی سفارش قبول کی جائے اور نہ کسی سے کسی طرح کا بدلہ قبول کیا جائے ۔\nاور عدل کا دوسرا مفہوم یعنی دوسرے کا حق دینا ہی ہمارے زیرِ بحث ہے جو انصاف کا مفہوم ادا کرتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِعۡدِلُوۡا ۟ ہُوَ  اَقۡرَبُ لِلتَّقۡوٰی» ( 5/8 )\nترجمہ : انصاف کیا کرو ، یہی بات تقوی سے قریب تر ہے ۔\nپھر ان معنوں میں بھی «عدل» کا لفظ ذوی الاضداد سے ہے ۔ اگر «عَدِلَ یَعْدِلُ» کے باب سے آئے تو اس کے معنی ظلم کرنا یا ناانصافی کرنے کے ہوتے ہیں (منجد)\nمثلاً : قرآن کریم میں ہے :\n«اَلۡحَمۡدُ لِلّٰہِ الَّذِیۡ خَلَقَ السَّمٰوٰتِ وَالۡاَرۡضَ وَ جَعَلَ الظُّلُمٰتِ وَالنُّوۡرَ  ؕ ثُمَّ  الَّذِیۡنَ کَفَرُوۡا بِرَبِّہِمۡ یَعۡدِلُوۡنَ» ( 6/1 )\nترجمہ : تمام تعریفیں اللہ ہی کے لائق ہیں جس نے آسمانوں کو اور زمین کو پیدا کیا اور تاریکیوں اور نور کو بنایا پھر بھی کافر لوگ ( غیر اللہ کو ) اپنے رب کے برابر قرار دیتے ہیں ۔\nلفظ عدل چونکہ وسیع مفہوم رکھتا ہے لہذا یہاں «یَعْدِلُوْن» کا ترجمہ خدا کی مثل اور نظیر قرار دیتے ہیں بھی کر لیا جاتا ہے ۔\nنوٹ : (لغت اضداد ایسے الفاظ کو کہتے ہیں جن کے  دو الگ الگ معنیٰ ہوں اور وہ معنیٰ ایک دوسرے کے مخالف اور متضاد ہوں)\n","«عَدْل» دوسرے کو اس کا پورا پورا حق یا اس کی مالیت کے برابر اس کا عوض دینا اس کا استعمال ظاہری اور باطنی امور میں عام ہے ۔","انصاف","عدل","2:48-2:123-2:282-4:3-4:58-4:129-4:135-5:8-5:95-5:106-6:1-6:70-6:115-6:150-6:152-7:159-7:181-16:76-16:90-27:60-42:15-49:9-65:2-82:7",24
304,60,"ا","اَبٰی","«اَبٰی» بمعنی کسی بات کو تسلیم نہ کرنا ، سختی سے منع کرنا ۔ (مف)  نافرمانی ، قبول نہ کرنا ، اَڑ جانا (م ۔ ر) اور «اَبٰی» کے معنی کسی چیز کو مکروہ یعنی ناپسندیدہ  سمجنا ، ناپسند کرنا ۔ کسی چیز سے ناخوش ہونا بھی ہے ۔ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَاِذۡ قُلۡنَا لِلۡمَلٰٓئِکَۃِ اسۡجُدُوۡا لِاٰدَمَ فَسَجَدُوۡۤا اِلَّاۤ اِبۡلِیۡسَ ؕ اَبٰی وَ اسۡتَکۡبَرَ ٭۫ وَکَانَ مِنَ الۡکٰفِرِیۡنَ» ( 2/34 )\nترجمہ : اور جب ہم نے فرشتوں کو حکم دیا کہ آدم کے آگے سجدہ کرو ۔ تو وہ سب سجدے میں گر پڑے مگر شیطان نے انکار کیا اور غرور میں آ کر کافر بن گیا ۔","«اَبٰی» کسی بات کو قبول کرنے سے انکار کرنا ۔ اڑ جانا ۔ نہ ماننا ۔ تسلیم نہ کرنا ۔","انکار","ابی","2:34-9:8-9:32-15:31-17:89-17:99-20:56-20:116-25:50",9
305,60,"ا","اَنْکَر","«نَکَرَ» کے معنی کسی چیز کو نہ پہچاننا ، کسی چیز یا بات سے اجنبی ہونا (م ر) ایسی بات جسے انسانوں کا دل قبول نہ کرے اور جو اچنبھا اورعجیب لگے ۔ خواہ وہ بوجہ جہالت نہ سمجھ سکے ۔ (مف) اور اس کی ضد «عَرَفَ» ہے ۔ بمعنی کسی چیز کو پہچان لینا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَجَآءَ اِخۡوَۃُ یُوۡسُفَ فَدَخَلُوۡا عَلَیۡہِ فَعَرَفَہُمۡ وَہُمۡ لَہٗ مُنۡکِرُوۡنَ» ( 12/58 )\nترجمہ : اور یوسف کے بھائی آئے اور یوسف کے پاس گئے ۔ تو اس نے ان کو پہچان لیا ۔ اور وہ یوسف کو نہ پہچان سکے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَہٰذَا ذِکۡرٌ مُّبٰرَکٌ اَنۡزَلۡنٰہُ ؕ اَفَاَنۡتُمۡ لَہٗ مُنۡکِرُوۡنَ» ( 21/50 )\nترجمہ : اور یہ مبارک نصیحت ہے جسے ہم نے نازل فرمایا ہے ، تو کیا تم اس سے انکار کرتے ہو ؟","«اَنْکَرَ» کسی چیز کو نہ پہچاننے کی وجہ سے انکار کرنا ۔","انکار","انکر","12:58-13:36-16:22-16:83-21:50-23:69-40:81",7
306,60,"ا","جَحَدَ","«جَحَدَ» بمعنی کسی بات کا علم ہو جانے کے بعد جان بوجھ کر انکار کر دینا (م ۔ ر) ایسی بات کا زبان سے انکار کرنا جسے دل صحیح تسلیم کرتا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَجَحَدُوۡا بِہَا وَ اسۡتَیۡقَنَتۡہَاۤ اَنۡفُسُہُمۡ ظُلۡمًا وَّعُلُوًّا» ( 27/14 )\nترجمہ : اور انہوں نے بے انصافی اور غرور سے ان ( معجزات سے ) انکار کیا حالانکہ ان کے دل ان کو مان چکے تھے ۔","«جَحَدَ» ایسی بات سے انکار کرناجس کا دل میں یقین ہو ۔","انکار","جحد","6:33-7:51-11:59-16:71-27:14-29:47-29:49-31:32-40:63-41:15-41:28-46:26",12
307,60,"ا","کَفَرَ","«کَفَرَ» حق کو نہ پہچاننا (م ۔ ر) اور اس کے بنیادی معنیٰ کسی چیز کو چھپانے اور اس پر پردہ دالنے کے ہیں اور کسان کو بھی کافر کہا جاتا ہے (منجد) کیونکہ وہ زمین میں دانہ کو چھپا دیتا ہے ۔ اور ان معنوں میں بھی یہ لفظ قرآن کریم میں استعمال ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«کَمَثَلِ غَیۡثٍ اَعۡجَبَ الۡکُفَّارَ نَبَاتُہٗ» ( 57/20 )\nترجمہ : جیسے بارش ( کہ اس سے کھیتی اگتی اور ) کسانوں کو کھیتی بھلی لگتی ہے ۔\nاور کفر کی ضد ایمان ہے اور اسے کفر اس لیے کہا جاتا ہے کہ اس سے ایمان پر پردہ پوشی کی جاتی ہے (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«قَالَ لَہٗ صَاحِبُہٗ وَ ہُوَیُحَاوِرُہٗۤ اَکَفَرۡتَ بِالَّذِیۡ خَلَقَکَ مِنۡ تُرَابٍ» ( 18/37 )\nترجمہ : تو اس کا دوست جو اس سے گفتگو کر رہا تھا کہنے لگا : کیا تو منکر ہو گیا ہے اس سے جس نے پیدا کیا تجھے مٹی سے ۔ ( عثمانیؒ )\nاور «کَفَرَ» بمعنی احسان فراموشی بھی ہوتا ہے ۔ اس معنیٰ میں اس کی ضد «شَکَرَ» ہے ( 14/7 )","«کَفَرَ» حق بات پر پردہ ڈالتے ہوئے انکار کر دینا ۔","انکار","کفر","2:6-2:26-2:28-2:39-2:61-2:85-2:88-2:89-2:90-2:91-2:93-2:99-2:102-2:105-2:108-2:121-2:126-2:152-2:161-2:171-2:212-2:217-2:253-2:256-2:257-2:258-3:4-3:10-3:12-3:19-3:21-3:52-3:55-3:56-3:70-3:72-3:80-3:86-3:90-3:91-3:97-3:98-3:101-3:106-3:112-3:115-3:116-3:127-3:149-3:151-3:156-3:167-3:176-3:177-3:178-3:196-4:42-4:46-4:51-4:56-4:60-4:76-4:84-4:89-4:101-4:102-4:131-4:136-4:137-4:140-4:150-4:155-4:156-4:167-4:168-4:170-5:3-5:5-5:10-5:12-5:17-5:36-5:41-5:61-5:64-5:68-5:72-5:73-5:78-5:80-5:86-5:103-5:110-5:115-6:1-6:7-6:25-6:30-6:70-6:89-7:66-7:90-8:12-8:15-8:30-8:35-8:36-8:38-8:50-8:52-8:55-8:59-8:65-8:73-9:3-9:12-9:17-9:23-9:26-9:30-9:37-9:40-9:54-9:66-9:74-9:80-9:84-9:90-9:97-9:107-10:4-10:70-11:7-11:17-11:27-11:60-11:68-13:5-13:7-13:27-13:30-13:31-13:32-13:33-13:43-14:7-14:8-14:9-14:13-14:18-14:22-14:28-15:2-16:39-16:55-16:72-16:84-16:88-16:106-16:112-17:69-17:98-18:29-18:37-18:56-18:80-18:102-18:105-18:106-19:37-19:73-19:77-19:82-21:30-21:36-21:39-21:94-21:97-22:19-22:25-22:55-22:57-22:72-23:24-23:33-24:39-24:55-24:57-25:4-25:32-27:40-27:67-28:48-29:12-29:23-29:25-29:52-29:66-29:67-30:16-30:34-30:44-30:51-30:58-31:12-31:23-32:29-33:25-34:3-34:7-34:17-34:31-34:33-34:43-34:53-35:7-35:14-35:26-35:36-35:39-36:47-36:64-37:170-38:2-38:27-39:7-39:8-39:63-39:71-40:4-40:6-40:10-40:12-40:22-40:42-40:84-41:9-41:26-41:27-41:29-41:41-41:50-41:52-43:33-45:11-45:31-46:3-46:7-46:10-46:11-46:20-46:34-47:1-47:3-47:4-47:8-47:12-47:32-47:34-48:22-48:25-48:26-49:7-51:60-52:42-54:14-57:15-57:19-59:2-59:11-59:16-60:1-60:2-60:4-60:5-61:14-63:3-64:5-64:6-64:7-64:10-66:7-66:10-67:6-67:27-68:51-70:36-73:17-74:31-80:17-80:42-84:22-85:19-88:23-90:19-98:1-98:6",297
308,61,"ا","اَصَابِع","«اَصَابِع» جمع ہے «اَصْبِع» کی ۔ انگلی کے ناخن والے پور کو کہتے ہیں ۔ خم اور جوڑ کا مجموعہ ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«یَجۡعَلُوۡنَ اَصَابِعَہُمۡ فِیۡۤ اٰذَانِہِمۡ» ( 2/19 )\nترجمہ : وہ اپنی انگلیاں اپنے کانوں میں ڈال لیتے ہیں ۔\nاور صرف پوروں کے لیے «بَنَان» کا لفظ آیا ہے جس کا واحد «بَنَانَۃ» ہے .\nمثلاً : قرآن کریم میں ہے :\n«بَلٰی قٰدِرِیۡنَ عَلٰۤی اَنۡ نُّسَوِّیَ بَنَانَہٗ» ( 75/4 )\nترجمہ : کیوں نہیں ، اور ہم اس بات پر قادر ہیں کہ اس کی پور پور درست کر دیں ۔","«اَصَابِع» انگلی کے پوروں کے لئے استعمال ہوتا ہے ۔","انگلیاں","اصابع","2:19-71:7",2
309,61,"ا","اَنَامِل","«اَنَامِل» جمع ہے «اَنْمَلَۃٌ» کی  ۔ انگلی کا بالائی حصہ اور اس کی اطراف کو کہتے ہیں (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاِذَا خَلَوۡاعَضُّوۡاعَلَیۡکُمُ الۡاَنَامِلَ مِنَ الۡغَیۡظِ» ( 3/119 )\nترجمہ : اور جب علیحدہ ہوتے ہیں تو تم پر غصے کے سبب انگلیاں کاٹ کاٹ کھاتے ہیں ۔","«اَنَامِل» انگلیوں کے سرے کو کہتے ہیں جن پر ناخن ہوتے ہیں ۔","انگلیاں","انامل","3:119",1
310,62,"ا","استغشٰی","«غَشِی» کے معنی کسی چیز کا دوسری چیز کو ڈھانپ لینا ۔ اور یہ لفظ اوپر سے ڈھانک لینے یا پردہ ڈالنے کے معنی میں آتا ہے (م ل)\nاور «اِسْتَغْشٰی» کے معنی اپنے اوپر کوئی کپڑا اوڑھ لینا اور «غَوَاش» ہر اوڑھنے والی چیز کو کہتے ہیں ۔ ( 7/41 )\nمثلاً : قرآن کریم میں ہے :\n«اَلَاحِیۡنَ یَسۡتَغۡشُوۡنَ ثِیَابَہُمۡ ۙ یَعۡلَمُ مَا یُسِرُّوۡنَ وَ مَا یُعۡلِنُوۡنَ» ( 11/5 )\nترجمہ : سن رکھو ! جس وقت وہ اوڑھتے ہیں اپنے کپڑے جانتا ہے جو کچھ چھپاتے ہیں اور جو ظاہر کرتے ہیں ۔ ( عثمانیؒ )\nاور یہ لفظ جس طرح ظاہری طور پر استعمال ہوتا ہے معنوی لحاظ سے بھی ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنِّیۡ کُلَّمَا دَعَوۡتُہُمۡ  لِتَغۡفِرَلَہُمۡ جَعَلُوۡۤا اَصَابِعَہُمۡ فِیۡۤ اٰذَانِہِمۡ وَاسۡتَغۡشَوۡا ثِیَابَہُمۡ وَاَصَرُّوۡا وَاسۡتَکۡبَرُوا اسۡتِکۡبَارًا» ( 71/7 )\nترجمہ : ( نوح ؑ نے کہا ) اور جب میں نے ان کو بلایا کہ ( توبہ کریں اور ) تو ان کو معاف فرمائے تو انہوں نے اپنے کانوں میں انگلیاں دے لیں اور کپڑے اوڑھ لیے اور اَڑ گئے اور اکڑ بیٹھے ۔","«اِسْتَغْشٰی» کے معنی اپنے اوپر کوئی کپڑا اوڑھ لینا یا لپیٹ لینا ۔","اوڑھنا","استغشی","3:154-7:54-7:189-8:11-10:27-11:5-13:3-14:50-20:78-24:40-29:55-31:32-33:19-36:9-44:11-47:20-53:16-53:54-71:7-91:4-92:1",21
311,62,"ا","اِدَّثَرَ","«اَلدِّثَار» اس گرم چادر یا کمبل کو کہتے ہیں جسے عام لباس کے اوپر اوڑھا جاتا ہے یا سونے والا اوڑھ کر سوتا ہے (منجد) اور ہر وہ کپڑا جو بدن سے ملا ہوا ہو ، اسے «شَعَار» اور جو کپڑا «شَعَار» سے ملا ہوا ہو اسے «دِثَار» کہتے ہیں ( ف ۔ ل 19 ) اور «اِدَّثَّرَ» بمعنی چادر یا کمبل عام لباس کے اوپر اوڑھ لینا ۔ اور «دُثْورُالْقَلْب» بمعنی کسی کی یاد دل سے مٹ جانا اور «دَاثِر» بمعنی ہلاک اور غافل (م ۔ ر) گویا «اِدَّثَر» سے مراد کپڑا اوڑھ کر غفلت کی نیند سونا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الۡمُدَّثِّرُ قُمۡ فَاَنۡذِرۡ» ( 74/1،2 )\nترجمہ : اے ( محمد ﷺ ) جو کپڑا لپیٹے پڑے ہو ۔ اٹھو اور ہدایت کرو ۔","«اِدَّثَر» کپڑا اوڑھ کر غفلت کی نیند سونا یا گہری نیند لینے کی نیت سے کپڑا لپیٹنا ۔","اوڑھنا","ادثر","74:1",1
312,62,"ا","اِزَّمَّل","«زَمَّل» بمعنی کپڑے میں لپٹنا ۔ کپڑے میں اپنے آپ کو چھپانا اور «مُزَّمَّل» بمعنی کپڑوں میں لپٹا ہوا اور «اِزْمَلّ» اور «زُمَیْل» بمعنی کمزور ۔ بزدل ، ڈرپوک (منجد) اور «زُمَّل» بمعنی ضعیف ،خوف زدہ اور بد دل (م ۔ ر) گویا «مُزَمِّل» اس کپڑا اوڑھنے والے کو کہتے ہیں جو کسی کمزوری ، ڈر یا بد دلی کی وجہ سے کپڑا اوڑھ کر لیٹ جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الۡمُزَّمِّلُ قُمِ  الَّیۡلَ   اِلَّا  قَلِیۡلًا» ( 73/1 )\nترجمہ : اے ( محمد ﷺ ) جو کپڑے میں لپٹ رہے ہو ۔ رات کو قیام کیا کرو مگر تھوڑی سی رات ۔","«اِزَّمّل» کسی ڈر ، کمزوری یا بد دلی کی وجہ سے کپڑا اوڑھ کر اپنے آپ کو چھپانا ۔","اوڑھنا","ازمل","73:1",1
313,63,"ا","اَوْلَاد","«اَوْلَاد» جمع ہے «وُلِد» کی بمعنی جنا ہوا بچہ اور«اَوْلَاد» کا اطلاق عمومًا بیٹے بیٹیاں ، پوتے ، پوتیاں اور نیچے تک ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یُوۡصِیۡکُمُ اللّٰہُ فِیۡۤ اَوۡلَادِکُمۡ لِلذَّکَرِ مِثۡلُ حَظِّ الۡاُنۡثَیَیۡنِ» ( 4/11 )\nترجمہ : خدا تمہاری اولاد کے بارے میں ارشاد فرمایا ہے کہ ایک لڑکے کا حصہ دو لڑکیوں کے برابر ہے ۔","«اَوْلَاد» بیٹے بیٹیاں ، پوتے پوتیاں اور آگے تک ۔","اولاد","اولاد","2:233-3:10-3:116-4:11-6:137-6:140-6:151-8:28-9:55-9:69-9:85-17:31-17:64-34:35-34:37-57:20-58:17-60:3-60:12-63:9-64:14-64:15",22
314,63,"ا","اَسْبَاط","«سِبْط» کے معنی اولاد کی اولاد کے ہیں ( یعنی دوسری نسل ) مگر یہ لفظ زیادہ تر نواسوں کے لیے مخصوص ہے ۔ جس طرح پوتے کے لیے «حَفِیْد» یا «حَفْدَۃ» ہے (منجد) اور«اَسْبَاط» کے معنی لڑکیوں کی اولاد یعنی نواسے نواسی اور پھر آگے تک ۔ نیز اسباط عمومًا حضرت اسحاق علیہ السلام کی اولاد کے لیے استعمال ہوتا ہے (مف ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«اَمۡ تَقُوۡلُوۡنَ اِنَّ اِبۡرٰہٖمَ وَاِسۡمٰعِیۡلَ وَ اِسۡحٰقَ وَ یَعۡقُوۡبَ وَالۡاَسۡبَاطَ کَانُوۡا ہُوۡدًا اَوۡ نَصٰرٰی» ( 2/140 )\nترجمہ : ( اے یہود و نصاریٰ ) کیا تم اس بات کے قائل ہو کہ ابراہیم اور اسماعیل اور اسحاق اور یعقوب اور ان کی اولاد یہودی یا عیسائی تھے ۔","«اَسْبَاط» نواسے ، نواسیاں اور آگے تک ۔","اولاد","اسباط","2:136-2:140-3:84-4:163-7:160",5
315,63,"ا","ذُرِیَّۃ","بعض اہل لغت اسے «ذُرّ» سے مشتق یعنی نکلا ہوا قرار دیتے ہیں جس کے معنی ہیں چھوٹی چیونٹیاں (منجد) اور «ذُرَّۃ» اس کا واحد ہے اور «ذُرِّیَۃ» چھوٹی اولاد کو کہتے ہیں (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاَصَابَہُ الۡکِبَرُ وَلَہٗ ذُرِّیَّۃٌ ضُعَفَآءُ» ( 2/266 )\nترجمہ : اور اس کو بڑھاپا آ پکڑے اور اس کے ننھے ننھے بچے بھی ہوں ۔\nپھر اس لفظ کا اطلاق سب اولاد پر ہونے لگا اور بعض اسے «ذَرَاَ» سے مشتق یعنی نکلا ہوا قرار دیتے ہیں ۔ «ذَرَأَ الْاَرْض» کے معنی زمین میں کچھ بونا (منجد) اورابن فارس کے نزدیک ہر وہ چیز جو بوئی اور کھیتی کی جا سکے (م ل) اور یہ لفظ اولاد سے عام ہے ۔ اس میں بیٹے ، بیٹیاں ، پوتے ، پوتیاں ، نواسے ، نواسیاں سب شامل ہیں ۔ (ف ل 206)\nمثلاً : قرآن کریم میں ہے :\n«قَالَ اِنِّیۡ جَاعِلُکَ لِلنَّاسِ اِمَامًا  ؕ قَالَ وَمِنۡ ذُرِّیَّتِیۡ  ؕ قَالَ لَا یَنَالُ عَہۡدِی الظّٰلِمِیۡنَ» ( 2/124 )\nترجمہ : اللہ تعالیٰ نے ابراہیم ؑ سے فرمایا ۔ میں تم کو لوگوں کا پیشوا بناؤں گا ۔ انہوں نے کہا کہ ( پروردگار ) میری اولاد میں سے بھی ( پیشوا بنائیو ) خدا نے فرمایا ہمارا اقرار ظالموں کے لیے نہیں ہوا کرتا ۔\n","«ذُرِیَّۃ» اس میں پوتے نواسے سب شامل ہیں سب کے لئے استعمال ہوتا ہے ۔","اولاد","ذریۃ","2:124-2:128-2:266-3:34-3:36-3:38-4:9-6:84-6:87-6:133-7:172-7:173-10:83-13:23-13:38-14:37-14:40-17:3-17:62-18:50-19:58-25:74-29:27-36:41-37:77-37:113-40:8-46:15-52:21-57:26",30
316,63,"ا","عَقِب","«عَقَب» بمعنی ایڑی ۔ بیٹا ۔ پوتا اور «عَقَّبَ» کے معنی پیچھے چلنا اور «اَعْقَبَ» کے معنی جانشین ہونا ہے (منجد) اور «عَقِبَ» کا اطلاق انسان کے مرنے کے بعد اپنے پیچھے چھوڑی ہوئی اولاد پر ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَجَعَلَہَا کَلِمَۃًۢ  بَاقِیَۃً فِیۡ عَقِبِہٖ» ( 43/28 )\nترجمہ : اور ( حضرت ابراہیم ؑ ) یہی بات اپنی اولاد میں پیچھے چھوڑ گئے ۔","«عَقِب» مرنے کے بعد کسی کی اولاد کو عِقب کہہ سکتے ہیں  مگر اُس کی زندگی میں نہیں ۔","اولاد","عقب","43:28",1
317,63,"ا","نَسْل","«نَسَلَ» کے لغوی معنی تیز دوڑنا یا بلندی سے پستی کی طرف دوڑنا کے ہیں (منجد)\nمثلاً : قرآن کریم میں ہے :\n«حَتّٰۤی اِذَا فُتِحَتۡ یَاۡجُوۡجُ وَمَاۡجُوۡجُ وَہُمۡ مِّنۡ کُلِّ حَدَبٍ یَّنۡسِلُوۡنَ» ( 21/96 )\nترجمہ : یہاں تک کہ یاجوج اور ماجوج کھول دیے جائیں اور وہ ہر بلندی سے دوڑ رہے ہوں ۔\nاور اس کا دوسرا معنی کسی جاندار کے جسم سے کوئی چیز جدا ہونا ہے اور «نُسَالَہ» داڑھی سے گرے ہوئے بالوں کو کہتے ہیں یا پرندوں کے ان پروں کو جو جھڑ کر گر جاتے ہیں اور چونکہ اولاد بھی ماں باپ کے جسم کا حصہ ہوتا ہے جو ان سے جدا ہوتی ہے  لہذا اولاد کو نسل سے تعبیر کرتے ہیں (مف) ابن الفارس نے بھی یہی دو معنے بیان کیے ہیں (م ل)\n«نَسْل» سے مراد کسی مخصوص انسان کی تمام تر پشتیں ہوتی ہیں ۔ گویا یہ لفظ اولاد اور «ذُرِّیَّت» وغیرہ سب سے عام ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ بَدَاَ خَلۡقَ الۡاِنۡسَانِ مِنۡ طِیۡنٍ ثُمَّ جَعَلَ نَسۡلَہٗ  مِنۡ سُلٰلَۃٍ مِّنۡ مَّآءٍ مَّہِیۡنٍ» ( 32/7،8 )\nترجمہ : اور انسان کی پیدائش کو مٹی سے شروع کیا ۔ پھر اس کی نسل خلاصے ( یعنی ) حقیر پانی سے پیدا کی ۔","«نَسْل» کسی شخص کی تمام نچلی پشتیں اس کی نسل  کہلاتی ہے ۔","اولاد","نسل","2:205-32:8",2
318,63,"ا","حَفْدَۃ","«حَفَدَ» بمعنی کام کرنے میں پھرتی دکھانا (مف ۔ منجد) دعائے قنوت کے الفاظ «وَاِلَیْکَ نَسْعٰی وَنَحْفِدُ» سے یہی مراد ہے اور «حَافِد» بمعنی «تَبَرَّعًا» تیزی کے ساتھ خدمت بجا لانے والا خواہ یہ اجنبی ہو یا رشتہ دار (مف) اور «حَافِد» اور «حَفِیْد» دونوں کے معنی پوتا بھی ہیں (مف منجد) اور «حَافِدْ» کی جمع «حَفْدَۃ» ہے ۔ امام راغب کے نزدیک «حَفْدَۃ» کا اطلاق سسر اور اولاد ، دونوں طرف کے رشتہ داروں پر ہوتا ہے «اُنَاث» اس میں شامل نہیں۔\nمثلاً : قرآن کریم میں ہے :\n«وَّجَعَلَ لَکُمۡ مِّنۡ اَزۡوَاجِکُمۡ بَنِیۡنَ وَ حَفَدَۃً» ( 16/72 )\nترجمہ : اور تمہارے لیے تمہاری بیویوں سے بیٹے اور پوتے پیدا کیے ۔","«حَفْدَۃ» کا اطلاق سسر اور اولاد ، دونوں طرف کے رشتہ داروں پر ہوتا ہے ۔","اولاد","حفدۃ","16:72",1
319,63,"ا","آل ، اَھْل","«اَھْل» اور «آل» بعض اہل لغت کے نزدیک یہ دونوں لفظ ہم معنی ہیں اور رشتہ دار یا خاندان کے معنوں میں آتے ہیں ۔ مگر ان دونوں لفظوں میں کئی فرق ہیں مثلاً :\n«اَھْل» کا دائرہ اس لحاظ سے محدود ہے کہ اس میں صرف گھر والے یعنی بیوی بچے شامل ہوتے ہیں جبکہ آل میں ذہنی ہم آہنگی رکھنے والے بھی شامل ہوتے ہیں ۔ مثلاً :«اَھْل» فرعون سے صرف اس کے گھر والے اور «اٰل فرعون» سے گھر والوں کے علاوہ اس کے اہل کار اور اس سے متفق تمام لوگ شامل ہیں ۔ اسی طرح اٰل النبی ﷺ میں آنحضرت ﷺ کے رشتہ داروں کے علاوہ امت کے وہ لوگ بھی شامل ہیں ، جنھیں علم و معرفت کے لحاظ سے آپ سے خصوصی تعلق ہو ۔\nاور «اَھْل» کا دائرہ «اٰل» سے اس لحاظ سے وسیع ہے کہ اس نسبت غیر ذوی العقول کی طرف بھی ہوسکتی ہے ۔ مثلاً «اَھْلُ الْبَلَد» ( شہر والے ) یا اہل الارض تو کہا جا سکتا ہے مگر آل البد یا آل الارض نہیں کہہ سکتے اسی طرح اہلِ المدینہ ، اہلِ الذِّکر ، اہلِ الکتاب اور اہل النار کی بھی صورت ہے ۔\n«اٰل» کی نسبت صرف کسی معروف ہستی کی طرف ہوتی ہے ۔ مثلاً : آل ابراہیم  یا آل عمران تو کہہ سکتے ہیں مگر آل الخیاط نہیں کہہ سکتے ۔ ہاں اہل الخیاط کہہ سکتے ہیں ۔ اس صورت میں ’’ درزی کے گھر والے ‘‘ اس کا معنی ہو گا ۔","«اَھْل» گھر والے ۔ بیوی سمیت ۔ اولاد اور اہل خاندان ۔\n«آل» دیگر رشتہ دار","اولاد","آل ، اھل","2:49-2:50-2:248-3:11-3:33-4:54-7:130-7:141-8:52-8:54-12:6-14:6-15:59-15:61-19:6-27:56-28:8-34:13-40:28-40:45-40:46-54:34-54:41-2:105-2:109-3:69-3:72-3:75-3:110-3:113-3:199-4:123-4:153-4:159-5:47-5:65-7:96-7:97-7:98-9:101-11:73-12:109-15:67-16:43-18:77-20:40-21:7-28:12-28:45-29:31-29:34-29:46-33:26-33:33-38:64-57:29-59:2-59:7-59:11-74:56-98:1-98:6",62
320,64,"ا","صَوْف","«صَوْفَ» بھیڑ اور مینڈھے وغیرہ کے جسم سے اتاری ہوئی اُون کو کہتے ہیں ۔ (ف ل 30)\nمثلاً : قرآن کریم میں ہے :\n«وَمِنۡ اَصۡوَافِہَا وَاَوۡبَارِہَا وَاَشۡعَارِہَاۤ اَثَاثًا وَّمَتَاعًا اِلٰی حِیۡنٍ» ( 16/80 )\nترجمہ :’’ اور ان ( جانوروں ) کی اون ، پشم اور بالوں سے تم اسباب اور برتنے کی چیزیں ( بناتے ہو جو ) مدت تک ( کام دیتی ہیں ) ۔","«صَوْفَ» بھیڑ اور مینڈھے وغیرہ کے جسم سے اتاری ہوئی اُون کو کہتے ہیں ۔","اُون","صوف","16:80",1
321,64,"ا","عِھْن","«عِھْن» مختلف رنگوں میں رنگی ہوئی اُون کو کہتے ہیں۔\nمثلاً : قرآن کریم میں ہے :\n«یَوۡمَ تَکُوۡنُ السَّمَآءُ کَالۡمُہۡلِ وَ تَکُوۡنُ الۡجِبَالُ کَالۡعِہۡنِ» ( 70/8،9 )\nترجمہ : جس دن آسمان ایسا ہو جائے گا جیسا پگھلا ہوا تانبا اور پہاڑ جیسے رنگی ہوئی اون ۔","«عِھْن» مختلف رنگوں میں رنگی ہوئی اُون کو کہتے ہیں۔","اُون","عھن","70:9-101:5",2
322,65,"ا","اِبِل","«اِبِل» اسم جنس ہر قسم کے اونٹ اور نر اور مادہ کے لیے استعمال ہوتا ہے اس کا تثنیہ اور جمع نہیں آتا اور اس لفظ سے اونٹو کا گلہ بھی مراد لیا جاتا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«اَفَلَا یَنۡظُرُوۡنَ  اِلَی الۡاِبِلِ کَیۡفَ خُلِقَتۡ» ( 88/17 )\nترجمہ : یہ لوگ اونٹوں کی طرف نہیں دیکھتے کہ کیسے عجیب پیدا کیے ہیں ۔","«اِبِل» اسم جنس ہر قسم کے اونٹ اور نر اور مادہ کے لیے استعمال ہوتا ہے ۔","اُونٹ","ابل","6:144-88:17",2
323,65,"ا","بَعِیْر","«بَعِیْر» نوجوان اور طاقتور اونٹ ، اسم جنس ہے جب اونٹ چار سال کا بار برداری کے قابل ہو جائے تو اسے«بَعِیْر» کہتے ہیں اور یہ لفظ نر و مادہ سب کے لیے استعمال ہوتا ہے  ۔ (مف فل 27)\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا نَفۡقِدُ صُوَاعَ الۡمَلِکِ وَلِمَنۡ جَآءَ بِہٖ حِمۡلُ بَعِیۡرٍوَّاَنَا بِہٖ زَعِیۡمٌ» ( 12/72 )\nترجمہ : وہ بولے کہ بادشاہ کے ( پینے کا ) گلاس ہمیں مل نہیں رہا اور جو شخص اس کو لے آئے اس کے لیے ایک بارِ شتر ( انعام ) اور میں اس کا ضامن ہوں ۔","«بَعِیْر» جب اونٹ چار سال کا بار برداری کے قابل ہو جائے تو اسے«بَعِیْر» کہتے ہیں ۔","اُونٹ","بعیر","12:65-12:72",2
324,65,"ا","جَمَل","«جَمَل» پانچ سال سے زائد عمر کا نر اونٹ ۔ خوبصورت اونٹ ۔ ( ف ل 27 ) اس کی جمع «جِمَالَۃٌ» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّہَا تَرۡمِیۡ  بِشَرَرٍ کَالۡقَصۡرِ کَاَنَّہٗ جِمٰلَتٌ صُفۡرٌ» ( 77/32،33 )\nترجمہ : اس سے آگ کی اتنی بڑی بڑی چنگاریاں اڑتی ہیں جیسے جمل گو یا زرد رنگ کے اونٹ ہیں ۔","«جَمَل» پانچ سال سے زائد عمر کا نر اونٹ ۔ خوبصورت اونٹ ۔","اُونٹ","جمل","7:40-77:33",2
325,65,"ا","ھِیْم","«ھَام» دو معنی میں استعمال ہوتا ہے (1) عاشقانہ اور مجنونانہ کیفیت سے آوارہ پھرنا اور (2) سخت پیاسا ہونا ۔ یہاں دوسرا معنی زیرِ بحث ہے اور «ھَیَام» اونٹوں کی ایک بیماری ہے جس میں اسے اتنی پیاس لگتی ہے کہ وہ سیر نہیں ہوتا (منجد) اور «ھِیْم» ایسے اونٹ کو کہتے ہیں جو سخت پیاسا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«فَشٰرِبُوۡنَ عَلَیۡہِ مِنَ الۡحَمِیۡمِ فَشٰرِبُوۡنَ شُرۡبَ الۡہِیۡمِ» ( 56/54،55 )\nترجمہ : اور اس پر کھولتا ہوا پانی پیو گے اور پیو گے بھی تو اس طرح جیسے پیاسے اونٹ پیتے ہیں ۔","«ھِیْم» سخت پیاسا اونٹ ۔","اُونٹ","ھیم","56:55",1
326,65,"ا","رِکَاب","«رَکَب» کے معنی سوار ہونا اور «رِکاب» کسی سوار کے سوار ہونے کے وقت پاؤں رکھنے کی جگہ کو کہتے ہیں ۔ ( ہمارے ہاں «رکاب» انہی معنوں میں مستعمل ہے ) پھر یہ لفظ ہر سوار اور سواری کے لیے استعمال ہونے لگا ۔ (منجد) عرف عام میں راکب کا لفظ صرف شتر سوار (یعنی اون٘ٹ پر سواری کرنے والے) کے لیے مخصوص ہے اور اس کی جمع «رُکْبَان ، رَکَب» اور «رُکُوْب» آتی ہے (مف) اور «رِکَاب» کا لفظ اونٹوں کے گلہ پر بھی بولا جاتا ہے ۔ جس طرح خیل کا لفظ گھوڑوں کے گلہ پر بولا جاتا ہے ۔ مثلاً : قرآن کریم میں ہے :\n«فَمَاۤ اَوۡجَفۡتُمۡ عَلَیۡہِ مِنۡ خَیۡلٍ وَّ لَا رِکَابٍ» ( 59/6 )\nترجمہ : اس کے لیے نہ تم نے گھوڑے دوڑائے اور نہ اونٹ ۔","«رِکَاب» کسی سوار کے سوار ہونے کے وقت پاؤں رکھنے کی جگہ کو کہتے ہیں ۔","اُونٹ","رکاب","11:41-11:42-16:8-18:71-29:65-36:42-40:79-43:12-59:6-84:19",10
327,65,"ا","ضَامِر","«ضَمَرَ» بمعنی ہموار شکم (یعنی پتلا دبلا)  خوبصورت جسم والا ۔ اور «ضَامِر» ہر وہ سواری ( گھوڑا یا اونٹ ) ہے جو ورزش اور کسرت کی وجہ سے تُند جسم ہو ، نہ کہ خوراک کی کمی کی وجہ سے  ، اور «مِضْمَار» اس جگہ کو کہتے ہیں جہاں ان جانوروں کو ورزش اور کسرت کی مشق کرائی جاتی ہے ۔ (م ۔ ر) گویا «ضَامِر» بمعنی  دُبلے اور لمبے  بدن والے سبک رفتار گھوڑے یا اونٹ خواہ نر ہو یا مادہ کو کہتے ہیں اور عرب میں چونکہ اونٹ کی سواری عام ہے اس لیے اس کا اطلاق بیشتر اس قسم کے اونٹ پر ہی ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاَذِّنۡ فِی النَّاسِ بِالۡحَجِّ یَاۡتُوۡکَ رِجَالًا وَّعَلٰی کُلِّ ضَامِرٍ یَّاۡتِیۡنَ مِنۡ کُلِّ فَجٍّ عَمِیۡقٍ» ( 22/27 )\nترجمہ : اور لوگوں میں حج کے لیے ندا کر دو کہ تمہاری طرف پیدل اور دبلے پتلے اونٹوں پر جو ( دور دراز ) رستوں سے چلے آتے ہوں ( سوار ہو کر ) چلے آئیں ۔","«ضَامِر» دبلا پتلا تیز رفتاراونٹ نر ہو یا مادہ دونوں کے لیے استعمال ہوتا ہے ۔","اُونٹ","ضامر","22:27",1
328,65,"ا","بُدْنَ","«بُدْنَ» جمع ہے «بَدَنَۃٌ» کی  قربانی کے اُن اونٹوں کو کہتے ہیں جو حرم کعبہ میں لے جا کر ذبح کیے جائیں ۔ (م ۔ ر) یا جو مکہ معظمہ لے جا کر ذبح کیے جائیں (منجد ۔ مف) اور «بَدَنَۃ» بدن کی مناسبت سے ان دونوں جانوروں کے موٹا اور فربہ ہونے کی وجہ سے کہا جاتا ہے ۔ اور عرف عام میں اس سے صرف قربانی کا اونٹ مراد ہے جو مکہ لے جا کر ذبح کیا جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ الۡبُدۡنَ جَعَلۡنٰہَا لَکُمۡ مِّنۡ  شَعَآئِرِ اللّٰہِ» ( 22/36 )\nترجمہ : اور قربانی کے اونٹوں کو بھی ہم نے تمہارے لیے شعائر خدا مقرر کیا ہے ۔\nاور «شَعَآئِرِ اللّٰہ» سے مراد وہ ادب کی چیزیں ہیں جو اللہ کے نام نامزد کی جاتی ہیں ۔","«بُدْنَ» قربانی کے اونٹ جو حرم کعبہ میں لے جا کر ذبح کیے جائیں ۔","اُونٹ","بدن","22:36",1
329,65,"ا","نَاقَۃ","«نَوْق» اس اونٹنی کو کہتے ہیں جو  یعنی مباشرت کے قابل ہو چکی ہو ( ف ۔ ل 17 )\nمثلاً : قرآن کریم میں ہے :\n«وَیٰقَوۡمِ ہٰذِہٖ نَاقَۃُ اللّٰہِ لَکُمۡ اٰیَۃً» ( 11/64 )\nترجمہ : اور ( صالح ) نے کہا ۔ اے قوم ! یہ خدا کی اونٹنی تمہارے لیے ایک نشانی ہے ۔","«نَاقَۃ» ایسی اونٹنی جو مباشرت کے قابل ہو چکی ہو ۔","اُونٹ","ناقۃ","7:73-7:77-11:64-17:59-26:155-54:27-91:13",7
330,65,"ا","عِشَار","«عِشَار» جمع ہے «عَشْرَاءَ» کی اور «عَشَرَ» بمعنی دس ۔ «عَشْرَاء» ایسی اونٹنی کو کہتے ہیں جسے حاملہ ہوئے دس ماہ گزر چکے ہوں (م ۔ ر) اور ایسی اونٹنی بہت پیاری سمجھی جاتی تھی کہ اب بہت جلد بچہ دینے والی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِذَا الۡعِشَارُعُطِّلَتۡ» ( 81/4 )\nترجمہ : اور جب دس ماہ کی حاملہ اونٹنیاں چھوڑ دی جائیں ۔\n( یعنی ایسی پیاری چیزوں کو سنبھالنے کا کسی کو ہوش نہ ہو گا ) ۔","«عِشَار» دس ماہ کی حاملہ اونٹنیاں ۔","اُونٹ","عشار","34:45-81:4",2
331,65,"ا","بُحَیْرَۃ","جب کوئی اونٹنی یا بکری جب دس بچے جَن چکتی تو اسے اہل عرب بتوں کی قربانی کے لیے وقف کر دیتے اور علامت کے لیے اس کے کان چِیر دیتے اور اسے آزاد کھلا چھوڑ دیتے اور اس کا کوئی دودھ بھی نہیں نکال سکتا تھا اور اس کے مرنے پر اس کا گوشت مردوں کے لیے حلال لیکن عورتوں پر حرام سمجھا جاتا تھا ۔","«بَحِیْرَۃ ، سَائِبَۃ ، وَصِیْلَۃ اور حَام» زمانہ جاہلیت میں مختلف شرطوں کے تحت بتوں کی نذر و نیاز اور قربانی کے جانوروں کو کہا جاتا تھا ۔","اُونٹ","بحیرۃ","5:103",1
332,65,"ا","سآئبۃ","«سَآئِبَۃ» ان جانوروں کو کہتے تھے جنہیں زمانہ جاہلیت میں لوگ اپنے معبود باطل کے نام پر چھوڑ دیتے تھے اور سواری اور بوجھ سے آزاد کر دیتے تھے ۔","«سَآئِبَۃ» ان جانوروں کو کہتے تھے جنہیں زمانہ جاہلیت میں لوگ اپنے معبود باطل کے نام پر چھوڑ دیتے تھے اور سواری اور بوجھ سے آزاد کر دیتے تھے ۔","اُونٹ","سآئبۃ","5:103",1
333,65,"ا","وَصِیْلۃ","«وَصِیْلۃ» اس جوان اونٹنی کو کہتے تھے جو پہلی مرتبہ مادہ بچہ جنتی اور پھر دوسری مرتبہ بھی مادہ ہی جنتی، اسے بھی وہ بتوں کے نام پر چھوڑ دیتے تھے لیکن اسی صورت میں جبکہ وہ برابر دو مرتبہ مادہ بچہ جنتی اور اس درمیان میں کوئی نر بچہ نہ ہوتا ۔","«وَصِیْلۃ» (وہ اونٹنی جس نے مسلسل مادہ بچے پیدا کئے اور کوئی نر پیدا نہ کیا ہو)","اُونٹ","وصیلۃ","5:103",1
334,65,"ا","حَام","«حَام» وہ نراونٹ جس کے نطفہ سے دس بچے پیدا ہوئے ہوں اور جب وہ اتنی صحبتیں کر چکتا تو اس کو بھی بتوں کے نام پر چھوڑ دیتے نہ سواری کرتے اور نہ ہی بوجھ لادتے ۔\nاب ایسی قربانیوں کے متعلق ارشاد باری ملاحظہ فرمائیے :\n«مَا جَعَلَ اللّٰہُ مِنۡۢ بَحِیۡرَۃٍ  وَّ لَا سَآئِبَۃٍ  وَّ لَا وَصِیۡلَۃٍ وَّ لَا حَامٍ ۙ وَّ لٰکِنَّ الَّذِیۡنَ کَفَرُوۡا یَفۡتَرُوۡنَ عَلَی اللّٰہِ الۡکَذِبَ» ( 5/103 )\nترجمہ : اللہ نے نہ بحیرہ کچھ چیز بنایا ہے نہ سائبہ ، نہ وصیلہ اور نہ حام ۔ بلکہ کافر خدا پر جھوٹ افترا کرتے ہیں ۔\nکافروں نے یہ نام تو خود مقرر کر رکھے تھے اور کہتے تھے کہ یہ شریعت ابراہیمیؑ کے حکم ہیں اور ان سے تقرب الی اللہ حاصل ہوتا ہے ۔","«حَام» ایسا اونٹ جس کے نطفہ سے کم از کم دس بچے پیدا ہو چکے ہوں ۔ ","اُونٹ","حام","5:103",1
335,66,"ا","نُعَاس","«نَعَس» یہ نیند کی ابتدائی کیفیت ہے بمعنی غنودگی ( ف ل 34 ) ۔ جب نیند کی وجہ سے حواس سست پڑ جائیں اور آنکھوں پر اس کا اثر نمایاں ہونے لگے تو اسے «نُعَاس» کہتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اِذۡ یُغَشِّیۡکُمُ النُّعَاسَ اَمَنَۃً مِّنۡہُ» ( 8/11 )\nترجمہ : جب اللہ نے تمہاری تسکین کے لیے اپنی طرف سے تمہیں نیند ( کی چادر ) اوڑھا دی ۔","«نُعَاس» غنودگی نیند کی ابتدائی کیفیت کو کہتے ہیں ۔","اُونگھ","نعاس","3:154-8:11",2
336,66,"ا","سِنَۃٌ","«سِنَۃٌ» بمعنی غنودگی ۔ ایسی غنودگی جس سے سر میں گرانی محسوس ہونے لگے اور سر جھکنے لگے ۔ غنودگی کا اگلا درجہ ۔ غنودگی اور نیند کی درمیانی کیفیت (ف ل 161)\nمثلاً : قرآن کریم میں ہے :\n«اَللّٰہُ لَاۤ اِلٰہَ اِلَّا ہُوَۚ اَلۡحَیُّ الۡقَیُّوۡمُ ۬ ۚ لَا تَاۡخُذُہٗ سِنَۃٌ وَّلَا نَوۡمٌ» ( 2/255 )\nترجمہ : اللہ کے سوا کوئی عبادت کے لائق نہیں ۔  ہمیشہ زندہ رہنے والا ، اسے نہ اونگھ آتی ہے نہ نیند ۔","«سِنَۃٌ» اونگھ ایسی غنودگی جس سے سر میں گرانی محسوس ہونے لگے اور سر جھکنے لگے ۔","اُونگھ","سنۃ","2:255-33:19",2
337,67,"ا","حَطَبَ","«حَطَبَ» نباتاتی ایندھن ۔ ناکارہ صرف جلانے کے قابل لکڑی ، جھاڑ جھنکار ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّامۡرَاَتُہٗ ؕ حَمَّالَۃَ الۡحَطَبِ» ( 111/4 )\nترجمہ : اور اس ( ابولہب ) کی جورو بھی ایندھن سر پر اٹھائے پھرتی ہے ۔\nاور جو لکڑی کارآمد ہو اسے «خَشَب» کہا جاتا ہے ۔","«حَطَبَ» نباتاتی ایندھن ، ناکارہ لکڑیاں ، جو صرف جلانے کے قابل ہو ۔","ایندھن","حطب","72:15-111:4",2
338,67,"ا","حَصَب","«حَصَب» کے معنی پتھر ۔ چھوٹی پتھریاں ۔ کنکر وغیرہ اور «حَاصِبْ» اس تند و تیز ہوا کو کہتے ہیں جو کنکروں اور چھوٹے پتھروں کو اٹھائے پھرتی ہے ( منجد ) چنانچہ یہ لفظ قرآن کریم میں پتھروں کی بارش کے معنی میں استعمال ہوا ہے ( 67/17 ) اور «حَصَب» کے معنی ایندھن بھی ہے ( منجد ) اور اس سے مراد جماداتی ایندھن ہے ۔ مثلاً گندھک ۔ پوٹاش اور دوسرے آتش گیر مادے ۔ اور پتھر وغیرہ غرضیکہ ہر وہ چیز جو آگ کو بھڑکا دے وہ «حَصَب» ہے ( ف ل 16 )\nمثلاً : قرآن کریم میں ہے :\n«اِنَّکُمۡ وَ مَا تَعۡبُدُوۡنَ مِنۡ دُوۡنِ اللّٰہِ حَصَبُ جَہَنَّمَ» ( 21/98 )\nترجمہ : کافرو اس روز تم اور جن کی تم خدا کے سوا عبادت کرتے ہو دوزخ کا ایندھن ہوں گے ۔","«حَصَب» جماداتی اور معدنیاتی ایندھن ۔ مثلاً گندھک ۔ پوٹاش اور دوسرے آتش گیر مادے ۔ ","ایندھن","حصب","17:68-21:98-29:40-54:34-67:17",5
339,67,"ا","وَقُوْد","«وَقَدَ» بمعنی آگ روشن کرنا اور «وَقُوْد» ہر وہ ایندھن ہے جو شعلہ پیدا کر کے جلے (ف ل 31) خواہ وہ لکڑیاں ہوں یا پتھر یا انسان ۔ بعض دفعہ آگ کی تیزی اس انتہا کو پہنچ جاتی ہے کہ پانی بھی اسے بجھانے کی بجائے اس کے مزید بھڑکنے کا سبب بن جاتا ہے ۔ تو اس صورت میں پانی بھی وقود میں شامل ہو گا ۔ کوئی بھی ایندھن کی قسم ہو جب وہ جل رہا ہو تو اس وقت «وَقُود» کہلائے گا پہلے نہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاتَّقُوا النَّارَ الَّتِیۡ وَقُوۡدُہَا النَّاسُ وَ الۡحِجَارَۃُ» ( 2/24 )\nترجمہ : تو اُس آگ سے ڈرو جس کا ایندھن آدمی اور پتھر ہوں گے ۔","«وَقُوْد» جلتے ہوئے ایندھن کو خواہ کسی قسم کا ہو «وُقود» کہتے ہیں ۔","ایندھن","وقود","2:24-3:10-66:6-85:5",4
340,69,"ب","وَالِدٌ","«وَالِدٌ» کا لفظ صرف باپ کیلئے استعمال ہوتا ہے ۔ اسی طرح والدہ کا لفظ صرف اس عورت کے لیے جس نے بچہ جنا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«لَّا یَجۡزِیۡ وَالِدٌ عَنۡ وَّلَدِہٖ وَلَا مَوۡلُوۡدٌ ہُوَجَازٍعَنۡ وَّالِدِہٖ شَیۡئًا» ( 31/33 )\nترجمہ : نہ تو باپ اپنے بیٹے کے کچھ کام آئے گا اور نہ بیٹا باپ کے کچھ کام آ سکے گا ۔\nاور ماں باپ دونوں کے لیے والدین کا لفظ آئے گا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَنِ اشۡکُرۡ لِیۡ وَ لِوَالِدَیۡکَ» ( 31/14 )\nترجمہ : میرا بھی شکریہ ادا کرتا رہ اور اپنے ماں باپ کا بھی ۔","«وَالِدٌ» کا لفظ صرف باپ کیلئے استعمال ہوتا ہے ۔","باپ","والد","2:83-2:180-2:215-2:233-4:7-4:33-4:36-4:135-5:110-6:151-14:41-17:23-19:14-19:32-27:19-29:8-31:14-31:33-46:15-46:17-71:28-90:3",22
341,69,"ب","اَبْ","«اَبْ» کا لفظ بہت وسیع مفہوم میں استعمال ہوتا ہے ۔ یہ لفظ باپ ، دادا ، پردادا اور اوپر کی سب پشتوں کے لیے استعمال ہوتا ہے ۔ اور ماں باپ کے لیے حسب موقع «اَبْوَیْن» یا «اَبْوَان» آتا ہے ۔\nاب ان کی مثالیں دیکھئے :\n(1) صرف ماں باپ کے لیے :\n(ارشاد باری تعالیٰ ہے )\n«وَ اَمَّا الۡغُلٰمُ فَکَانَ اَبَوٰہُ  مُؤۡمِنَیۡنِ» ( 18/80 )\nترجمہ : اور وہ جو لڑکا تھا ، اس کے ماں باپ دونوں مومن تھے ۔\n(2) کئی پشتوں کے لیے :\n(ارشاد باری تعالیٰ ہے )\n«مَّا سَمِعۡنَا بِہٰذَا فِیۡۤ  اٰبَآئِنَا  الۡاَوَّلِیۡنَ» ( 23/24 )\nترجمہ : ہم نے اپنے باپ دادا میں تو یہ بات کبھی نہیں سنی ۔\nاور یہ پشتیں بہت زیادہ بھی ہو سکتی ہیں ۔\nجیسے (ارشاد باری تعالیٰ ہے )\n«مِلَّۃَ اَبِیۡکُمۡ اِبۡرٰہِیۡمَ ؕ ہُوَ سَمّٰىکُمُ الۡمُسۡلِمِیۡنَ» ( 22/78 )\n ترجمہ : اور ( تمہارے لیے ) تمہارے باپ ابراہیم ؑ کا نظامِ دین ( پسند کیا ) اور تمہارا نام مسلمان رکھا ۔\nواضح رہے کہ حضور اکرم ﷺ اور حضرت ابراہیم ؑ میں قریبًا 62 پشتوں کا فاصلہ تھا ۔ حتیٰ کہ حضرت آدم کے لیے بھی جو نوع انسان کے جدّ اعلیٰ ہیں «اَب» کے لفظ کا اطلاق ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰبَنِیۡۤ اٰدَمَ لَا یَفۡتِنَنَّکُمُ الشَّیۡطٰنُ کَمَاۤ اَخۡرَجَ اَبَوَیۡکُمۡ مِّنَ الۡجَنَّۃِ» ( 7/27 )\n ترجمہ : اے بنی آدم ! دیکھنا کہیں شیطان تمہیں بہکا نہ دے جس طرح تمہارے ماں باپ کو ( بہکا کر ) جنت سے نکلوا دیا ۔\n«اَب» اصل میں «اَبَوَ» ہے اور یہ کسی کی تربیت اور خوراک کی فراہمی پر دلالت کرتا ہے (م ل) اس لیے بیٹا اگر باپ سے مخاطب ہو تو عمومًا «اَبّ» کا لفظ ہی استعمال ہو گا جیسے : حضرت یوسفؑ اپنے باپ سے یوں گویا ہوئے :\nارشاد باری تعالیٰ ہے\n«یٰۤاَبَتِ ہٰذَا تَاۡوِیۡلُ رُءۡیَایَ مِنۡ قَبۡلُ» ( 12/100 )\nترجمہ : ابا جان ! یہ میرے اس خواب کی تعبیر ہے جو میں نے پہلے بچپن میں دیکھا تھا ۔\nپھر«اَب» کا لفظ بعض دفعہ کسی خاص صفت کی وجہ سے بھی استعمال ہوتا ہے جیسے میزبان کو «اَبُوالْاضِیَاف» اور جنگجو کو «اَبُوالْحَرَب» کہہ دیتے ہیں ۔ قرآن کریم میں «ابولھب» کا لفظ اسی صفت کی وجہ سے استعمال ہوا ہے کہ اس کا رنگ شعلہ کی طرح دمکتا تھا ۔ اسی طرح کسی چیز سے نسبت اور پیار کی وجہ سے کنیت رکھ لیتے ہیں جیسے ابوہریرہ اور ابوتراب وغیرہ ۔","«اَبْ» یہ لفظ باپ دادا ، پردادا اور اوپر کی سب پشتوں کے لیے استعمال ہوتا ہے ۔ ","باپ","اب","2:133-2:170-2:200-4:11-4:22-5:104-6:74-6:87-6:91-6:148-7:27-7:28-7:70-7:71-7:95-7:173-9:23-9:24-9:114-10:78-11:62-11:87-11:109-12:4-12:6-12:8-12:9-12:11-12:16-12:17-12:38-12:40-12:59-12:61-12:63-12:65-12:68-12:78-12:80-12:81-12:93-12:94-12:97-12:99-12:100-13:23-14:10-16:35-18:5-18:80-18:82-19:28-19:42-19:43-19:44-19:45-21:44-21:52-21:53-21:54-22:78-23:24-23:68-23:83-24:31-24:61-25:18-26:26-26:70-26:74-26:76-26:86-27:67-27:68-28:23-28:25-28:26-28:36-31:21-33:5-33:40-33:55-34:43-36:6-37:17-37:69-37:85-37:102-37:126-40:8-43:22-43:23-43:24-43:26-43:29-44:8-44:36-45:25-53:23-56:48-58:22-60:4-80:35-111:1",104
342,70,"ب","تَبَارَک ۔ مُبَارَک","«مُبَارَک» برکت کے معنی میں کسی چیز میں خیر الہی کا ثابت ہونا (مف) یعنی جو کام کیا جائے اس میں متوقع زیادہ سے زیادہ فائدہ ہو جانا برکت ہے بشرطیکہ یہ کام یا توقع خیر کا پہلو رکھتی ہو اور «بَرْکَۃْ» بمعنی بڑھاؤ ۔ زیادتی (منجد) اور جس چیز میں یہ خیر کا پہلو بارآور ثابت ہو وہ مبارک ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَہٰذَا ذِکۡرٌمُّبٰرَکٌ اَنۡزَلۡنٰہُ» ( 21/50 )\nترجمہ : اور یہ مبارک ذکر ہے جسے ہم نے نازل فرمایا ہے ۔\nاور تبارک بمعنی نیک فال یا نیک شگون لینا (منجد) لیکن یہ لفظ عمومًا اللہ تعالیٰ کے ساتھ مخصوص ہے اور ان خیر کے کاموں کے لیے آتا ہے جو صرف اللہ تعالیٰ سے مختص ہیں ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«تَبٰرَکَ الَّذِیۡ نَزَّلَ الۡفُرۡقَانَ ( 25/1 )\n فَتَبٰرَکَ اللّٰہُ  رَبُّ الۡعٰلَمِیۡنَ ( 40/64 )\n فَتَبٰرَکَ اللّٰہُ  اَحۡسَنُ  الۡخٰلِقِیۡنَ ( 23/14 )\n تَبٰرَکَ الَّذِیۡ جَعَلَ فِی السَّمَآءِ  بُرُوۡجًا ( 25/61 )\n تَبٰرَکَ الَّذِیۡ  بِیَدِہِ  الۡمُلۡکُ ( 67/1 )» وغیرہ ۔","«مُبارک» ہروہ چیز جس میں خیر اور بھلائی کا پہلو ہو اور نتیجہ خیز ثابت ہو ۔\n«تبارک» اللہ تعالیٰ کی ذات بابرکت ہے ۔","بابرکت","تبارک ۔ مبرک","3:96-6:92-6:155-7:54-7:96-7:137-11:48-11:73-17:1-19:31-21:50-21:71-21:81-23:14-23:29-24:35-24:61-25:1-25:10-25:61-28:30-34:18-37:113-38:29-40:64-41:10-43:85-44:3-50:9-55:78-67:1",31
343,70,"ب","اَیْمَن","«یَمِیْن» بمعنی دایاں ہاتھ اور دائیں طرف اور «اَصْحٰبُ الْیَمِیْن» بمعنی دائیں ہاتھ یا دائیں جانب والے بھی اور اصحاب خیر و برکت بھی (مف) ہے ۔ اور «یَمَنَ یَیْمَنُ» بمعنی بابرکت ہونا خوش قسمت ہونا ۔ «تَیَمُّن» بمعنی برکت لینا ۔ نیک فال لینا اور «مَیْمُون» بمعنی مبارک  ہے (منجد) اور امام راغب کے نزدیک «مَیْمُون» بمعنی سعادت مند ہے ۔ (مف) گویا جس طرح سعادت فطرت میں ودیعت ہوتی ہے اسی طرح «اَیْمَن» وہ چیز ہے جس کی فطرت میں برکت ودیعت کی گئی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«فَلَمَّاۤ اَتٰىہَا نُوۡدِیَ مِنۡ شَاطِیَٔ الۡوَادِ الۡاَیۡمَنِ» ( 28/30 )\nترجمہ : پھر جب موسیٰ ؑ وہاں پہنچے تو بابرکت میدان کے کنارے سے آواز آئی ۔","«اَیْمَن» ایسی خیر و برکت جو فطری طور پرموجود ہو ۔ سعادت ۔","بابرکت","ایمن","19:52-20:80-28:30-56:8-90:18",5
344,70,"ب","طیّب ، طوبٰی","«طَابَ» بمعنی کسی چیز کا دل کو اچھا لگنا اور «طَیَّب» بمعنی پاکیزہ اور حلال چیز اور «طِیْب» بمعنی خوشبو ۔ اور «بَلْدَۃٌ طَیِّبَۃٌ» بمعنی امن اور برکتوں والا شہر (منجد) نیز «اَلْبَلَدُ الطَّیِّبُ» بمعنی بابرکت یا زرخیز زمین (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَالۡبَلَدُ الطَّیِّبُ یَخۡرُجُ نَبَاتُہٗ بِاِذۡنِ رَبِّہٖ» ( 7/58 )\nترجمہ : اور زرخیز زمین سے سبزہ بھی پروردگار کے حکم سے نفیس ہی نکلتا ہے ۔\nاور «طُوْبٰی» بمعنی رشک ۔ سعادت ۔ خیر ۔ بہتری ( منجد ) گویا «طُوْبٰی» سے ایسی خیر و برکت مراد ہے جو من کو بھی بھاتی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَّذِیۡنَ اٰمَنُوۡا وَعَمِلُوا الصّٰلِحٰتِ طُوۡبٰی لَہُمۡ وَحُسۡنُ مَاٰبٍ» ( 13/29 )\nترجمہ : جو لوگ ایمان لائے اور نیک عمل کیے ان کے لیے ہی خوشحالی اور عمدہ ٹھکانا ہے ۔","«طُوبی» ایسی خوشحالی اور خیر و برکت جو دل کو لبھاتی ہو ۔","بابرکت","طیب ، طوبی","2:57-2:168-2:172-2:267-3:38-3:179-4:2-4:43-4:160-5:4-5:5-5:6-5:87-5:88-5:100-7:32-7:58-7:157-7:160-8:26-8:37-8:69-9:72-10:22-10:93-13:29-14:24-16:32-16:72-16:97-16:114-17:70-20:81-22:24-23:51-24:26-24:61-34:15-35:10-40:64-45:16-46:20-61:12",43
345,71,"ب","قَوْل","«قَوْل» اس کی جمع «اَقْوَال» اور جمع «اَلْجَمْعُ اَقَاوِیْل» ہے ۔ عمومًا یہ سمجھا جاتا ہے کہ ہر وہ بات جو زبان سے ادا کی جائے وہ قول ہے خواہ وہ بے معنی ہو یا با معنی ۔ لیکن قرآن کریم میں یہ لفظ تین صورتوں میں استعمال ہوا ہے ۔ (1) منہ سے نکلی ہوئی بات کے لیے استعمال ہوتاہے  (2) ایسی بات جو منہ سے نہ نکلی ہو بلکہ ابھی دل میں ہی ہو اور (3) کسی نظریہ کے لیے بھی استعمال ہوتاہے ۔ مثالیں :\n(1) منہ سے نکلی ہوئی بات کے لیے ارشاد باری تعالیٰ ہے :\n«قَالَ قَآئِلٌ مِّنۡہُمۡ کَمۡ لَبِثۡتُمۡ» ( 18/19 )\nترجمہ : ایک کہنے والے نے کہا کہ تم ( یہاں ) کتنی مدت رہے ؟\n(2) دل میں بات کے لیے ارشاد باری تعالیٰ ہے :\n«وَیَقُوۡلُوۡنَ فِیۡۤ اَنۡفُسِہِمۡ لَوۡلَا یُعَذِّبُنَا اللّٰہُ» ( 58/8 )\nترجمہ : اور وہ اپنے دل میں کہتے ہیں کہ اگر یہ واقعی سچ ہے  تو خدا ہمیں سزا کیوں نہیں دیتا ؟\n(3) کسی نظریہ کے لیے ارشاد باری تعالیٰ ہے :\n«ذٰلِکَ عِیۡسَی ابۡنُ مَرۡیَمَ ۚ قَوۡلَ الۡحَقِّ الَّذِیۡ  فِیۡہِ  یَمۡتَرُوۡنَ» ( 19/34 )\nترجمہ : یہ مریمؑ کے بیٹے عیسیٰؑ ہیں ( اور یہ ) سچی بات ہے جس میں لوگ شک کرتے ہیں ۔","«قَوْل» کوئی بھی بات چاہے بے معنی ہو یا بامعنی ۔ خواہ دل میں ہو یا نظریاتی ہو ۔","بات","قول","2:8-2:26-2:58-2:59-2:68-2:69-2:71-2:79-2:80-2:83-2:102-2:104-2:113-2:117-2:118-2:136-2:140-2:142-2:154-2:169-2:200-2:201-2:204-2:214-2:235-2:263-3:7-3:16-3:47-3:64-3:75-3:78-3:79-3:124-3:147-3:154-3:167-3:181-4:5-4:8-4:9-4:43-4:46-4:51-4:63-4:73-4:75-4:78-4:81-4:94-4:108-4:148-4:150-4:155-4:156-4:157-4:171-5:19-5:41-5:52-5:53-5:63-5:73-5:83-5:109-5:116-6:22-6:25-6:33-6:50-6:53-6:73-6:93-6:105-6:112-6:148-6:156-6:157-7:28-7:33-7:53-7:105-7:161-7:162-7:169-7:172-7:173-7:205-8:49-9:30-9:40-9:49-9:50-9:61-9:65-9:124-10:18-10:20-10:28-10:31-10:38-10:48-10:65-10:68-10:77-11:7-11:8-11:10-11:12-11:13-11:18-11:31-11:35-11:40-11:53-11:54-11:91-12:66-12:81-13:5-13:7-13:10-13:27-13:33-13:43-14:27-14:44-15:97-16:27-16:32-16:40-16:86-16:103-16:116-17:16-17:23-17:28-17:40-17:42-17:43-17:47-17:51-17:53-17:108-18:5-18:22-18:23-18:42-18:49-18:52-18:88-18:93-19:26-19:34-19:35-19:66-19:79-19:80-20:7-20:28-20:40-20:44-20:47-20:89-20:94-20:97-20:104-20:109-20:130-21:4-21:27-21:38-21:46-21:110-22:24-22:30-22:40-23:27-23:68-23:70-23:85-23:87-23:89-23:109-24:15-24:26-24:47-24:51-25:17-25:19-25:22-25:27-25:65-25:74-26:16-26:203-26:226-27:19-27:49-27:71-27:82-27:85-28:28-28:47-28:51-28:62-28:63-28:65-28:74-28:82-29:2-29:10-29:46-29:55-29:61-29:63-30:58-31:25-32:3-32:13-32:28-33:4-33:12-33:13-33:32-33:37-33:66-33:70-34:29-34:31-34:40-34:42-36:7-36:48-36:58-36:70-36:76-36:82-37:31-37:36-37:52-37:151-37:167-38:17-38:84-39:18-39:38-39:56-39:57-39:58-40:28-40:44-40:47-40:68-41:25-41:33-41:50-42:24-42:44-43:9-43:13-43:87-44:34-46:8-46:11-46:17-46:18-47:20-47:21-47:30-48:11-48:15-49:2-49:14-50:18-50:29-50:30-52:33-50:39-50:45-51:8-52:30-52:33-52:44-54:2-54:8-54:44-56:47-57:13-58:1-58:2-58:8-59:10-59:11-60:4-61:2-61:3-63:4-63:7-63:8-63:10-66:8-67:13-67:25-68:51-69:19-69:25-69:40-69:41-69:42-69:44-72:4-72:5-73:5-73:10-74:25-74:31-75:10-78:40-79:10-81:19-81:25-86:13-89:15-89:16-89:24-90:6",327
346,71,"ب","حَدِیْث","«حَدَثَ» بمعنی کسی چیز کا ظہور میں آنا ۔ کسی امر کا واقعہ ہونا ۔ نئی چیز یا بات کا پیدا ہونا ۔ (منجد) اور اس کی ضد «عَدَمَ» ہے ۔ ابن فارس کے الفاظ میں ایسی چیز کا پیدا ہونا جو پہلے نہ تھی (م ل) اور حدیث سے مراد وہ نئی بات یا نظریہ ہے جس کا تعلق عام لوگوں سے ہو اور پہلے اکثر لوگ اس سے نا واقف ہوں ۔\nمثلاً : قرآن کریم میں ہے :\n«لَا تَدۡرِیۡ لَعَلَّ اللّٰہَ یُحۡدِثُ بَعۡدَ ذٰلِکَ اَمۡرًا» ( 65/1 )\nترجمہ : تجھے کیا معلوم شاید اللہ پیدا کر دے اس طلاق کے بعد نئی صورت ( عثمانی )\nنیز ارشاد باری تعالیٰ ہے :\n«اَللّٰہُ نَزَّلَ اَحۡسَنَ الۡحَدِیۡثِ» ( 39/23 )\nترجمہ : خدا نے نہایت ہی اچھی باتیں نازل فرمائی ہیں ۔\nیہاں حدیث سے مراد قرآن کریم ہے اور ظاہر ہے کہ اس دور کے لوگوں کے نظریات اور خیالات کے مطابق یہ ایک نئی چیز تھی ۔ پھر حدیث کے لفظ کا اطلاق جس طرح نئی چیز کے لیے ہوتا ہے ، اسی طرح کسی ایسی پرانی بات یا واقعہ کے لیے بھی ہوتا ہے جو عام طور پر لوگوں کے ذہن سے اتر چکی ہو ۔ ایسی صورت میں اس کا مفہوم بھولی بسری بات یا کہانی ہو گا ۔\nمثلاً : قرآن کریم میں ہے :\n«کُلَّمَا جَآءَ اُمَّۃً  رَّسُوۡلُہَا کَذَّبُوۡہُ  فَاَتۡبَعۡنَا بَعۡضَہُمۡ بَعۡضًا وَّ جَعَلۡنٰہُمۡ اَحَادِیۡثَ» ( 23/44 )\nترجمہ : جب کبھی کسی امت کے پاس اس کا رسول آتا تو اسے جھٹلا دیتے ۔ تو ہم بھی بعض کو بعض کے پیچھے ( ہلاک کرتے اور اُن پر عذاب ) لاتے رہے اور ان کے فسانے بناتے رہے ۔","«حَدِیْث» نئی بات ۔ ایسی بات جس سے عام لوگ نا واقف ہوں ۔","بات","حدیث","4:42-4:78-4:87-4:140-6:68-7:185-12:6-12:21-12:101-12:111-18:6-20:9-23:44-31:6-33:53-34:19-39:23-45:6-51:24-52:34-53:59-56:81-66:3-68:44-77:50-79:15-85:17-88:1",28
347,71,"ب","کَلِمَۃُ","«کَلِمَۃُ» کا لغوی معنیٰ ’’ بامعنی بات ‘‘ ایسی بات جو کانوں سے سنی جا سکے اور اس کا مفہوم سمجھ میں آ سکے ۔ ابن فارس کے اپنے الفاظ میں «نُطْقُ یُفْھَمُ» (م ۔ ل) ہے ۔ مثلاً : قرآن کریم میں ہے :\n«اِنَّہَا کَلِمَۃٌ ہُوَ قَآئِلُہَا» ( 23/100 )\nترجمہ : وہ تو ایک بات ہو گی جو کہنے والا کہہ دے گا ۔\nلیکن جب لفظ «کلمۃ» کی نسبت ذات باری تعالیٰ کی طرف ہو تو اس کے معنی عجائباتِ قدرت ، قوانینِ فطرت اور اللہ تعالیٰ کے تخلیقی کارنامے مراد ہوتے ہیں (تفہیم القرآن) مثلاً : قرآن کریم میں ہے :\n«قُلۡ لَّوۡ کَانَ الۡبَحۡرُ مِدَادًا لِّکَلِمٰتِ رَبِّیۡ لَنَفِدَ الۡبَحۡرُقَبۡلَ اَنۡ تَنۡفَدَ کَلِمٰتُ رَبِّیۡ وَ لَوۡجِئۡنَا بِمِثۡلِہٖ مَدَدًا» ( 18/109 )\nترجمہ : کہہ دو اگر سمندر میرے پروردگار کی باتوں کے ( لکھنے کے ) لیے سیاہی ہو تو قبل اس کے کہ میرے پروردگار کی باتیں تمام ہوں سمندر ختم ہو جائے ۔ اگرچہ ہم ویسا ہی اور اس کی مدد کو لائیں ۔\nاور جب کلمہ کی نسبت خدا تعالیٰ سے انسان کی طرف ہو تو اس سے مراد احکام و فرامین الہی ہوتے ہیں :\nمثلاً : قرآن کریم میں ہے :\n«اَفَمَنۡ حَقَّ عَلَیۡہِ کَلِمَۃُ الۡعَذَابِ ؕ اَفَاَنۡتَ تُنۡقِذُ مَنۡ فِی النَّارِ» ( 39/19 )\nترجمہ : بھلا جس شخص پر عذاب کی بات ثابت ہو چکی ہے تو کیا آپ اسے جو دوزخ میں ہے چھڑا سکتے ہیں ۔","«کَلِمَۃُ» صرف با معنی بات ۔ خدا کے احکام اور عجائباتِ قدرت وغیرہ ۔","بات","کلمۃ","2:37-2:75-2:124-3:39-3:45-3:64-4:46-4:171-5:13-5:41-6:34-6:115-7:137-7:144-7:158-8:7-9:6-9:40-9:74-10:19-10:33-10:64-10:82-10:96-11:110-11:119-14:24-14:26-18:5-18:27-18:109-20:129-23:100-31:27-35:10-37:171-39:19-39:71-40:6-41:45-42:14-42:21-42:24-43:28-48:15-48:26-66:12",47
348,71,"ب","کَلَّمَ","«کَلَّمَ» بمعنی ہم کلام ہونا ۔ بات چیت کرنا ، گفتگو کرنا (منجد) یہ عمومًا مختصر سی بات چیت کے لیے یا ایسی باتوں کے لیے استعمال ہوتا ہے جن کا جواب بات سن کر فوری طور پر دیا جا سکے ۔ پھر«کَلَّمَ» میں یہ بھی ضروری نہیں ہوتا کہ بات چیت دو طرفہ ہو ۔ کبھی یہ یک طرفہ بھی ہو سکتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا یُکَلِّمُہُمُ اللّٰہُ وَلَا یَنۡظُرُ اِلَیۡہِمۡ یَوۡمَ الۡقِیٰمَۃِ» ( 3/77 )\nترجمہ : اور اللہ تعالیٰ قیامت کے روز نہ تو اُن سے کلام کرے گا نہ ہی ان کی طرف دیکھے گا ۔","«کَلَّمَ» گفتگو کے لیے عام لفظ ۔ عمومًا مختصر اور فوری گفتگو کے لیے استعمال ہوتا ہے ۔","بات","کلم","2:118-2:174-2:253-3:41-3:46-3:77-4:164-5:110-6:111-7:143-7:148-11:105-12:54-13:31-19:10-19:26-19:29-23:108-24:16-27:82-30:35-36:65-42:51-78:38",24
349,71,"ب","حَاوَرَ","ابن فارس کہتے ہیں کہ «حَوْراً»  میں بنیادی طور پر دو باتیں پائی جاتی ہیں (1) بات سے رجوع کرنا اور (2) ایک چیز ایک کی طرف اور پھر دوسرے کی طرف لوٹائی جائے (م ل) اور صاحبِ منجد «حَارَ» کے معنی واپس ہونا نیز متحیر (حیران) ہونا لکھتے ہیں ۔ گویا «حَاوَرَ» سے مراد ایسی گفتگو ہے جو بطور سوال جواب ہو ۔ اور کسی بات کا جواب سننے والے کو سوچ سمجھ کر دینا پڑے ۔ ایسی گفتگو عمومًا طویل ہوتی ہے ۔ اسی سے لفظ محاورہ نکلا ہے ۔ جس سے یہ مراد ہے کہ وہ بات سوچ سمجھ کر کہی گئی ہو اور زبان زد یعنی عام ، مشہور اور سمجھ میں آنے والی بھی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَ لَہٗ صَاحِبُہٗ وَ ہُوَ یُحَاوِرُہٗۤ اَکَفَرۡتَ بِالَّذِیۡ خَلَقَکَ مِنۡ تُرَابٍ ثُمَّ مِنۡ نُّطۡفَۃٍ ثُمَّ سَوّٰىکَ رَجُلًا» ( 18/37 )\nترجمہ : تو اس کا دوست جو اس سے گفتگو کر رہا تھا ، کہے گا کہ کیا تم اس ( خدا ) سے کفر کرتے ہو جس نے تمہیں مٹی سے پیدا کیا ، پھر نطفے سے پھر تمہیں پورا مرد بنایا ۔","«حَاوَرَ» سوال و جواب کے طرز پر گفتگو جو سوچ سمجھ کر کی جائے اور طویل ہو ۔","بات","حاور","18:34-18:37-58:1",3
350,71,"ب","خَاطَب","«خَاطَبَ» بھی گفتگو کرنے کے معنوں میں آتا ہے (منجد) اور خطبہ وعظ و تقریر کو کہتے ہیں جو عمومًا یکطرفہ ہوتی ہے ۔ خطیب بمعنی خطبہ دینے والا ، وضاحت سے بات کہنے والا (م ق) اور کبھی ایسا بھی ہوتا ہے کہ سننے والا مختصر سا جواب دے کر خطاب کرنے والے کو چپ کرا دیتا ہے ۔\nچنانچہ قرآن کریم میں اللہ تعالیٰ حضرت نوحؑ سے ارشاد فرماتے ہیں :\n«وَاصۡنَعِ الۡفُلۡکَ بِاَعۡیُنِنَا وَ وَحۡیِنَا وَ لَا تُخَاطِبۡنِیۡ فِی الَّذِیۡنَ ظَلَمُوۡا» ( 11/37 )\nترجمہ : اور ایک کشتی ہمارے حکم سے ہمارے روبرو بناؤ اور جو لوگ ظالم ہیں ان کے بارے میں ہم سے کچھ نہ کہنا ۔\nدوسری جگہ اللہ تعالیٰ نے اپنے بندوں کی صفات بیان کرتے ہوئے فرمایا :\n«وَّاِذَا خَاطَبَہُمُ الۡجٰہِلُوۡنَ  قَالُوۡا سَلٰمًا» ( 25/63 )\nترجمہ : اور جب جاہل لوگ ان سے ( جاہلانہ ) خطاب کرتے ہیں تو وہ سلامتی کی بات کہتے ہیں ۔","«خَاطَبَ» یہ عمومًا یکطرفہ بات ہوتی ہے ۔ یا جس کا جواب مخاطب دینا پسند کرے یا ضروری سمجھے تو دیدے ۔","بات","خاطب","11:37-23:27-25:63",3
351,72,"ب","سُلْطَان","«سُلْطَان» کا لفظ تین معنوں میں آتا ہے .\n(1) بمعنی دلیل جو سند یا دستاویز کی حیثیت رکھتی ہو ۔ اتھارٹی ۔ ان معنوں میں یہ لفظ قرآن کریم میں اکثر آیا ہے ۔\n(2) سلطنت یا بادشاہی ۔ اس معنی میں صرف ایک مقام پر آیا ہے .\n(3) بمعنی بادشاہ جمع اسکی سلاطین ہے  ان معنوں میں یہ لفظ قرآن میں نہیں آیا اور سلطان کا معنیٰ بادشاہ لغت کے اعتبار سے نہیں ہے بلکہ یہ کنائی معنیٰ ہے ۔\nجب یہ لفظ سلطنت یا بادشاہی کے معنوں میں آئے تو اس سے مراد وہ علاقہ ہے جو کسی شخص یا ادارہ یا بادشاہ کے زیرِ نگیں ہو اور اس پر اس کا تسلط ہو ۔\nمثلاً : قرآن کریم میں ہے کہ کافر قیامت کے دن کہے گا :\n«مَاۤ اَغۡنٰی عَنِّیۡ مَالِیَہۡ ہَلَکَ عَنِّیۡ سُلۡطٰنِیَہۡ» ( 69/28،29 )\nترجمہ : آج میرا مال میرے کچھ بھی کام نہ آیا ( ہائے ) میری سلطنت بھی میرے پاس نہ رہی ۔","«سُلْطَان» جب اقتدار اور شان و شوکت کا اظہار مقصود ہو تو «سُلْطَان» اور جب رقبہ کی وسعت کا اظہار مقصود ہو تو «مُلْک» کا لفظ  استعمال ہوتا ہے ۔","بادشاہی","سلطان","3:151-4:90-4:91-4:144-4:153-6:81-7:33-7:71-10:68-11:96-12:40-14:10-14:11-14:22-15:42-16:99-16:100-17:33-17:65-17:80-18:15-22:71-23:45-27:21-28:35-30:35-34:21-37:30-37:156-40:23-40:35-40:56-44:19-51:38-52:38-53:23-55:33-59:6-69:29",39
352,72,"ب","مُلْک","«مُلک» کا لفظ سلطنت سے زیادہ وسیع مفہوم رکھتا ہے ۔ زمین کا کوئی خاص علاقہ جو چند ایک قدرتی حدود سے محدود ہو وہ بھی ملک ہے اور تمام روئے زمین بھی ملک ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قُلِ اللّٰہُمَّ مٰلِکَ الۡمُلۡکِ تُؤۡتِی الۡمُلۡکَ مَنۡ تَشَآءُ وَ تَنۡزِعُ الۡمُلۡکَ مِمَّنۡ تَشَآءُ» ( 3/26 )\nترجمہ : آپ کہہ دیجئے اے اللہ! اے تمام جہان کے مالک! تو جسے چاہے بادشاہی دے جس سے چاہے سلطنت چھین لے  ۔\nاس آیت میں پہلا ملک تمام روئے زمین کے معنوں میں اور دوسرا ایک مخصوص رقبہ کے معنوں میں آیا ہے ۔\nاور «مُلک» کے معنی ملکیت ، بادشاہی اور قبضہ اور «مَلِک» کے معنی بادشاہ ، اور ان دونوں کی جمع «اَملَاک» اور «مُلُوک» آتی ہے (منجد) اور «مَلَکُوْت» کا لفظ «مُلک» سے بھی زیادہ وسیع مفہوم میں آتا ہے ۔ یعنی زمین و آسمان یا کائنات کی بادشاہی ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاتَّبَعُوۡا مَا تَتۡلُوا الشَّیٰطِیۡنُ عَلٰی مُلۡکِ سُلَیۡمٰنَ» ( 2/102 )\nترجمہ : ا ور اس چیز کے پیچھے لگ گئے جسے شیاطین ( حضرت ) سلیمان کی حکومت میں پڑھتے تھے ۔\n«فَسُبۡحٰنَ الَّذِیۡ بِیَدِہٖ مَلَکُوۡتُ کُلِّ شَیۡءٍ وَّ اِلَیۡہِ  تُرۡجَعُوۡنَ» ( 36/83 )\nترجمہ :’’ وہ ( ذات ) پاک ہے جس کے ہاتھ میں ہر چیز کی بادشاہت ہے ۔ اور اس کی طرف تم کو لوٹ کر جانا ہے ۔","«مُلک» زمین کا کوئی خاص علاقہ  جس کے باڈر اور حدود مقرر ہوں ، اور تمام روئے زمین کے لئے بھی استعمال ہوتا ہے ۔","بادشاہی","ملک","2:102-2:107-2:247-2:248-2:251-2:258-3:26-3:189-4:53-4:54-5:17-5:18-5:40-5:120-6:73-6:75-7:158-7:185-9:116-12:101-17:111-20:120-22:56-23:88-24:42-25:2-25:26-27:23-35:13-36:83-38:10-38:20-38:35-39:6-39:44-40:16-40:29-42:49-43:51-43:85-45:27-48:14-57:2-57:5-64:1-67:1-76:20-85:9",48
353,73,"ب","سحاب","«سَحَبْ» بمعنی گھسیٹنا اور کھینچنا بادل کے لیے اس کا استعمال عام ہے ( ف ۔ ل 454 ) ہر قسم کے بادل کو «سَحَاب» کہہ دیتے ہیں تاہم اس لفظ کا اطلاق اس بادل پر ہوتا ہے جسے ہوائیں اٹھا کر آسمان پر پھیلا دیتی ہیں ۔ گویا یہ ہر بادل کی ابتدائی شکل ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاللّٰہُ الَّذِیۡۤ اَرۡسَلَ الرِّیٰحَ فَتُثِیۡرُ سَحَابًا» ( 35/9 )\nترجمہ : اور خدا ہی تو ہے جو ہوائیں چلاتا ہے اور وہ بادل کو ابھارتی ہیں ۔","«سَحَاب» عرف عام میں بادل کے لیے استعمال ہوتا ہے ۔ ","بادل","سحاب","2:164-7:57-13:12-24:40-24:43-27:88-30:48-35:9-52:44",9
354,73,"ب","غَمَام","«غَمَّ» بمعنی ڈھانک لینا (منجد) اور «غَمَام» وہ بادل ہے جو تہہ بہ تہہ ہو کر گاڑھا ہو جائے اور سورج کی روشنی کو زمین تک آنے سے روک دے ۔ (ف ل 254) یعنی زمین پر سایہ فگن ہو جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ ظَلَّلۡنَا عَلَیۡکُمُ الۡغَمَامَ وَ اَنۡزَلۡنَا عَلَیۡکُمُ الۡمَنَّ وَ السَّلۡوٰی» ( 2/57 )\nترجمہ : اور ہم نے بادل کا تم پر سایہ کیے رکھا اور تمہارے لیے من و سلوٰی اتارتے رہے ۔","«غَمَام» جب بادل گاڑھا ہو جائے اور سایہ دار ہو جائے تو اسے غمام کہتے ہیں ۔","بادل","غمام","2:57-2:210-7:160-25:25",4
355,73,"ب","عَارِض","پھر جب گاڑھے اور پھیلے ہوئے بادل سے بوندا باندی بھی شروع ہو جائے تو وہ «عَارِض» کہلاتا ہے ( ف ل 254 )\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا ہٰذَا عَارِضٌ مُّمۡطِرُنَا ؕ بَلۡ ہُوَمَا اسۡتَعۡجَلۡتُمۡ بِہٖ ؕ رِیۡحٌ  فِیۡہَا عَذَابٌ اَلِیۡمٌ» ( 46/24 )\nترجمہ : کہنے لگے یہ بادل تو ہم پر برس کر رہے گا ( نہیں ) بلکہ یہ وہ چیز ہے جس کی تم جلدی کرتے تھے ۔ یعنی آندھی جس میں درد دینے والا عذاب ہے ۔","«عَارِض» ایسا بادل جس میں بوندا باندی کی ابتداء ہو چکی ہو ۔","بادل","عارض","46:24",1
356,73,"ب","مُعْصِرٰت","«عَصَرَ» کے معنی کپڑے کو نچوڑنا اور ( پھلوں وغیرہ سے رس ) نچوڑنا ۔ نیز عصر نکالے ہوئے رس کو بھی کہتے ہیں (م ل ) اور «اَعْصَرَ الْقَوْم» بمعنی قوم پر بارش برسانا (منجد) اور «مُعْصِرَات» جمع ہے «مُعْصِرَۃٌ» کی یعنی ایسے بادل جو پانی سے لدے ہوئے اور برسنے والے ہوں ، نچڑنے والے بادل ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّاَنۡزَلۡنَا مِنَ الۡمُعۡصِرٰتِ مَآءً  ثَجَّاجًا» ( 78/14 )\nترجمہ : اور ہم نے نچڑتے بادلوں سے موسلا دھار مینہ برسایا ۔","«مُعْصِرٰت» پانی سے بھرپور بادل ۔","بادل","معصرت","78:14",1
357,73,"ب","مُزْن","«مَزَنَ» بمعنی مشکیزہ (یعنی پانی کے برتن) کو پانی وغیرہ سے  بھرنا اور «اِبْنُ الْمُزْنَۃ» ۔ بادلوں میں سے نمودار ہونے والے چاند کو کہتے ہیں (مف) اور «مَزن» سفید اور چمکدار بادلوں کو کہتے ہیں ( مف ۔ فل 255 ) اور «حَبُّ الْمُزْن» اولے کو  کہتے ہیں (منجد) اور «مُزْن» بارش والے بادل کو  کہتے ہیں (منجد)\nمثلاً : قرآن کریم میں ہے :\n«ءَاَنۡتُمۡ اَنۡزَلۡتُمُوۡہُ مِنَ الۡمُزۡنِ اَمۡ نَحۡنُ الۡمُنۡزِلُوۡنَ» ( 56/69 )\nترجمہ :’’ کیا تم نے اس ( پانی ) کو بادل سے نازل کیا ہے یا ہم نازل کرتے ہیں ؟","«مُزْن» سفید چمکدار بادل ۔","بادل","مزن","56:69",1
358,73,"ب","صَیِّب","«صَیِّب» سخت گرج دار بادل ( فل 255 ) جبکہ صاحب منتہی الارب اس سے زور دار بارش مراد لیتے ہیں (م ۔ ل) صاحب منجد کے نزدیک کوئی سا بھی بارش والا بادل «صَیِّب» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَوۡ کَصَیِّبٍ مِّنَ السَّمَآءِ فِیۡہِ ظُلُمٰتٌ وَّ رَعۡدٌ وَّ بَرۡقٌ» ( 2/19 )\nترجمہ : یا اس بارش کی مانند جس میں اندھیرے بھی ہیں ، گرج بھی اور چمک بھی ۔","«صَیِّب» سخت گرج دار بادل کو کہتے ہیں ۔","بادل","صیب","2:19",1
359,74,"ب","مَرَّۃ","«مَرَّ» بمعنی کسی مقام کے پاس سے گزرنا (مف) اور نیز وقت کا گزرنا ۔ اور اس لحاظ سے اس کا معنی ہو گا ایک بار گزرنا یا کوئی کام کرنا ۔ اس کی تثنیہ «مَرَّتَان» یا «مَرَّتَیْن» اور جمع «مرّات» اور «مَرَارًا» (بمعنی کئی بار) آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَوَلَا یَرَوۡنَ اَنَّہُمۡ یُفۡتَنُوۡنَ فِیۡ کُلِّ عَامٍ مَّرَّۃً اَوۡ مَرَّتَیۡنِ» ( 9/126 )\nترجمہ : اور کیا ان کو نہیں دکھلائی دیتا کہ یہ لوگ ہر سال ایک بار یا دو بار کسی نہ کسی آفت میں پھنستے رہتے ہیں ۔","«مَرَّۃ» بار ، دفعہ یا مرتبہ کے لیے عام لفظ  ہے ۔","بار ","مرۃ","6:94-6:110-8:56-9:13-9:80-9:83-9:126-17:7-17:51-18:48-20:37-36:79-41:21",13
360,74,"ب","کَرَّۃً","«کَرَّ ، کَرَارًا» بمعنی ( دشمن پر ) حملہ کرنا ۔ ٹوٹ پڑنا ۔ اسی سے لفظ «کَرّار» مشہور ہے اور کرّوفرّ اس جنگی چال کو کہتے ہیں جو عرب میں ایک دور میں مشہور تھی ۔ یعنی حملہ کرنا اور یکدم پسپا ہو کر ازسرِ نو دوبارہ ٹوٹ پڑنا اور «کَرّ ۔ تکرارًا» بمعنی کسی کام کو پہلے کی طرح بار بار کرنا (منجد) اور یہی زیرِ بحث ہے ۔ یعنی کسی کام کو بالکل اسی طرح کرنا جیسے پہلے کیا تھا ، ایک بار پھر کرنا ۔ اور ابن الفارس کے الفاظ میں «رُجُوْع اِلَی الشَّی بَعْدَ مَرَّۃَ الْاُوْلٰی» (م ل) بمعنی دوبارہ پہلے ہی جیسا کام کرنا (فق ل) اور «کَرَّۃً» بمعنی لڑائی میں ایک بار کا حملہ بھی اور کسی کام کو دوبارہ کرنا بھی ان دونوں معنوں میں استعمال ہوتا ہے۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ رَدَدۡنَا لَکُمُ الۡکَرَّۃَ عَلَیۡہِمۡ» ( 17/6 )\nترجمہ : پھر ہم نے دوسری بار تم کو ان پر غلبہ دیا ۔\nاس آیت میں «کَرَّۃَ» کا لفظ دونوں مفہوم ادا کر رہا ہے اور «عَلیٰ» کا صلہ غلبہ کو ظاہر کر رہا ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«ثُمَّ ارۡجِعِ الۡبَصَرَکَرَّتَیۡنِ یَنۡقَلِبۡ اِلَیۡکَ الۡبَصَرُ خَاسِئًا وَّ ہُوَ حَسِیۡرٌ» ( 67/4 )\nترجمہ : پھر دوبارہ ( سہ بارہ ) نظر کرو تو نگاہ ( ہر بار ) تیرے پاس ناکام اور تھک کر لوٹ آئے گی ۔\nجب کوئی شاعر اپنا کلام سناتا ہے تو کسی اچھے شعر پر حاضرین میں سے کوئی مکرّر کا نعرہ لگاتا ہے جس کا مطلب یہ ہوتا ہے کہ اس شعر کو دوبارہ سہ بارہ پڑھ کر سناؤ ۔ یہی «کَرَّۃ» کا مفہوم ہے اور ابو ہلال عسکری کے نزدیک دوسری بار کرنے یا دہرانے کے لیے اعادہ اور دوبار سے زیادہ کرنے کے لیے «کرّر» آتا ہے (فق ۔ ل 27)","«کَرَّۃ» بمعنی ایک بار پھر ، ایک ہی کام کودو بار سے زیادہ کرنا یا بار بار کرنے کے لیے استعمال ہوتا ہے ۔","بار ","کرۃً","2:167-17:6-26:102-39:58-67:4-79:12",6
361,74,"ب","تَارَۃً","«تَارَۃً» اسے بعض اہل لغت «تَوْر» کے تحت لائے ہیں اور بعض «تَار» کے تحت ۔ اور اس کا معنی ہے «اِعَادَۃً بَعْدَ مَرَّۃٍ» (م ۔ ق) اور بمعنی وقت اور یکبار (م ۔ ر) یعنی کبھی کسی وقت ایک بار پھر وہ کام کرنا «فَعَلْتُ تَارَۃً ھَذَا اَو تَارَۃً ذَاکَ» یعنی میں نے کبھی تو یہ کام کیا اور کبھی وہ (منجد) گویا «تَارَۃً» ایسے کام کا اعادہ ہے جو کبھی کسی زمانہ میں پہلے کیا تھا ۔\nمثلاً : قرآن کریم میں ہے :\n«مِنۡہَا خَلَقۡنٰکُمۡ وَ فِیۡہَا نُعِیۡدُکُمۡ وَمِنۡہَا نُخۡرِجُکُمۡ تَارَۃً اُخۡرٰی» ( 20/55 )\nترجمہ : اس ( زمین ) سے ہم نے تم کو پیدا کیا اور اسی میں تمہیں لوٹائیں گے اور اسی سے دوسری مرتبہ نکالیں گے ۔","«تَارَۃً» یعنی کبھی کسی وقت ایک بار پھر وہ کام کرنا جو پہلے بھی کرچکاہو ۔","بار ","تارۃً","17:69-20:55",2
362,75,"ب","مَطَر","«مَطَر» بارش کے لیے عام لفظ ہے ۔ بارش فائدہ مند ہو یا نقصان دہ ۔ پانی برسے یا کوئی اور چیز سب کے لیے «مَطَر» کا لفظ استعمال ہو سکتا ہے اور «اَمْطَرَ» بمعنی بارش برسانا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاَمۡطَرۡنَا عَلَیۡہِمۡ مَّطَرًا ۚ فَسَآءَ مَطَرُالۡمُنۡذَرِیۡنَ» ( 26/173 )\nترجمہ : اور ان پر ایک زبردست بارش برسا دی ۔ غرض بہت بری بارش تھی جو ان پر برسی جنہیں پہلے سے ڈرا دیا گیا تھا ۔","«مَطَر» ہر طرح کی بارش کے لیے  استعمال ہوتا ہے۔ اسم جنس ہے ۔","بارش","مطر","4:102--7:84-8:32-11:82-15:74-25:40-26:173-27:58-46:24",9
363,75,"ب","مَآءَ","«مَآءَ» لفظی معنی پانی ہے «مِیَاہ» مجازًا بارش کے لیے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّاَنۡزَلَ مِنَ السَّمَآءِ مَآءً فَاَخۡرَجَ بِہٖ مِنَ الثَّمَرٰتِ رِزۡقًا لَّکُمۡ» ( 2/22 )\nترجمہ : اور آسمان سے بارش برسا کر تمہارے کھانے کے لیے انواع و اقسام کے میوے پیدا کیے ۔","«مَآءَ» بمعنی پانی ، مجازًا بارش کے لیے استعمال ہوتا ہے ۔","بارش","مآء","2:22-2:164-4:43-5:6-6:99-8:11-13:17-14:16-14:32-15:22-16:10-16:65-20:53-22:63-23:18-24:39-24:45-25:48-27:60-28:23-29:63-30:24-31:10-32:8-35:27-39:21-43:11-47:15-50:9-72:16-77:20-77:27-78:14-86:6",34
364,75,"ب","طَلّ","«طَلّ» بالکل ہلکی اور کمزور سی بارش (ف ل 256 ۔ م ل) شبنم اور پھوہار دونوں کے لیے «طَلّ» کا لفظ استعمال ہوتا ہے (ف ۔ م)\nمثلاً : قرآن کریم میں ہے :\n«فَاِنۡ لَّمۡ یُصِبۡہَا وَابِلٌ فَطَلٌّ» ( 2/265 )\nترجمہ : پھر اگر ( اس باغ پر ) بارش نہ پڑے تو پھر پھوہار بھی کافی ہے ۔","«طَلّ» شبنم ۔ یا پھوہار ","بارش","طل","2:265",1
365,75,"ب","وَدْق","«وَدْق» جو بارش لگاتار ہوتی رہے اسے «وَدْق» کہتے ہیں (ف ل 258) ایسی بارش عمومًا آہستہ آہستہ اور بہت دیر تک جاری رہتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ یَجۡعَلُہٗ  رُکَامًا فَتَرَی الۡوَدۡقَ یَخۡرُجُ مِنۡ خِلٰلِہٖ» ( 24/43 )\nترجمہ : پھر انہیں تہ بر تہ کردیتا ہے تو تم دیکھتے ہو کہ بارش ان کے درمیان میں سے برستی ہے ۔","«وَدْق» دھیمی اور لگاتار بارش ۔","بارش","ودق","24:43-30:48",2
366,75,"ب","غَیْث","«غَیْث» وہ بارش جو ضرورت کے وقت ہو اور ضرورت کے مطابق ہو وہ «غَیْث» ہے (ف ل 258 ۔ م ل)\nمثلاً : قرآن کریم میں ہے :\n«کَمَثَلِ غَیۡثٍ اَعۡجَبَ الۡکُفَّارَ نَبَاتُہٗ» ( 57/20 )\nترجمہ : جیسے بارش کہ اس سے کھیتی اگتی اور کسانوں کو بھلی لگتی ہے ۔","«غَیْث» ایسی بارش جو ضرورت کے وقت ہو اور ضرورت کے مطابق ہو ۔","بارش","غیث","31:34-42:28-57:20",3
367,75,"ب","مِدْرَارًا","«الدَّرّ» دودھ اور دودھ کی فراوانی کو کہتے ہیں اور «دَرُوْر» بہت زیادہ دودھ دینے والی اونٹنی کو کہتے ہیں ۔ اسی سے «مِدْرَارًا» نکلا ہے ۔ «عَیْنٌ مِدْرَارٌ» کے معنی بہت آنسو بہانے والی آنکھ اور «مِدْرَار» کے معنی بہت برسنے والی بارش ہے (منجد) اور «مِدْرَار» وہ بارش ہے جس میں پانی کی فراوانی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یٰقَوۡمِ اسۡتَغۡفِرُوۡا رَبَّکُمۡ ثُمَّ تُوۡبُوۡۤا اِلَیۡہِ یُرۡسِلِ السَّمَآءَ عَلَیۡکُمۡ مِّدۡرَارًا» ( 11/52 )\nترجمہ : اور اے قوم ! اپنے پروردگار سے بخشش مانگو پھر اس کے آگے توبہ کرو ۔ وہ تم آسمان سے موسلا دھار مینہ برسائے گا ۔","«مِدْرَار» بہت زیادہ برسنے والی بارش کو کہتے ہیں ۔","بارش","مدرارًا","6:6-11:52-71:11",3
368,75,"ب","غَدَق","«غَدَق» ابن الفارس کے مطابق «غَدَق» وہ بارش ہے جس میں پانی کی فراوانی بھی ہو اورفائدہ مند بھی ہو (م ل) اور «غَدَقَۃٌ» بمعنی شیریں چشمہ اور «غَدَقَ الْمَکَان» بمعنی جگہ کا بارش سے تر ہو جانا ۔ سرسبز ہو جانا اور «غَدِق» بمعنی سرسبز جگہ (منجد) گویا «غَدَق» ایسی بارش کو کہتے ہیں جو سرسبزی کا باعث ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّاَنۡ لَّوِ اسۡتَقَامُوۡاعَلَی الطَّرِیۡقَۃِ لَاَسۡقَیۡنٰہُمۡ مَّآءً غَدَقًا» ( 72/16 )\nترجمہ : اور اگر یہ لوگ سیدھے رستے پر رہتے تو ہم ان کے پینے کو بہت سا پانی دیتے ۔","«غَدَق» ایسی بارش جس میں پانی وافر ہو اور وہ فائدہ مند بھی ہو ۔ یعنی سبزہ اگانے کا باعث بنے ۔","بارش","غدق","72:16",1
369,75,"ب","صَیِّب","«صَیِّب» ایسی زور دار بارش کوکہتے ہیں جس میں بادل بھی خوب گرج رہے ہوں اور بجلی بھی چمک رہی ہو (ف ل 255 ۔ م ر) اور ابن الفارس کے نزدیک ایسی بارش جو جم کر برسے (م ل) ایسی بارش کو پنجابی میں پھانڈا کہتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اَوۡ کَصَیِّبٍ مِّنَ السَّمَآءِ فِیۡہِ ظُلُمٰتٌ وَّ رَعۡدٌ وَّ بَرۡقٌ» ( 2/19 )\nترجمہ : یا اس بارش کی مانند جس میں اندھیرے بھی ہوں گرج بھی اور چمک بھی ۔","«صَیِّب» زور دار بڑے بڑے قطروں والی بارش ۔","بارش","صیب","2:19",1
370,75,"ب","وَابِل","«وَبَل» کے معنی (مویشی وغیرہ کو) لاٹھی سے لگاتار مارنا (منجد) اس کے معنی میں شدّت اوربوجھ پایا جاتا ہے ۔ ابن فارس کہتے ہیں کہ «وَبَل» کسی چیز میں شدت اور کثرت کے معنی دیتا ہے اور «وَابِل» سے مراد شدید قسم کی بارش ہے (م ل) گویا «وَابِل» وہ بارش ہے جو پانی کی کثرت اور اپنی شدت اور تیزی کی وجہ سے خس و خاشاک (یعنی گھاس پُھوس، تِنکے، کوڑا کرکٹ)  بہا لے جائے اور یہ بارش کا آخری درجہ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَمَثَلُہٗ کَمَثَلِ صَفۡوَانٍ عَلَیۡہِ تُرَابٌ فَاَصَابَہٗ وَابِلٌ فَتَرَکَہٗ صَلۡدًا» ( 2/264 )\nترجمہ : اس کی مثال اس چٹان کی سی ہے جس پر تھوڑی سی مٹی پڑی ہو اور اس پر زور کی بارش برس کر اسے صاف کر ڈالے ۔","«وَابِل» ایسی شدید بارش جو خس و خاشاک (یعنی گھاس پُھوس، تِنکے، کوڑا کرکٹ) بہا لے جائے ۔","بارش","وابل","2:264-2:265",2
371,76,"ب","اِنْتَھٰی","«اَلنَّھْی» کے معنی روکنا اور «اِنْتَھٰی» باز آ جانا یا رکنے کے معنی میں آتا ہے اور «النِّھَاءُ وَالنِّھَایَۃُ» کسی چیز کا انجام ، انتہا ، اور آخری حد کو کہتے ہیں (منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَقَاتِلُوۡۤا اَئِمَّۃَ الۡکُفۡرِ ۙ اِنَّہُمۡ لَاۤ اَیۡمَانَ لَہُمۡ لَعَلَّہُمۡ  یَنۡتَہُوۡنَ» ( 9/12 )\nترجمہ : تو ان کفر کے پیشواؤں سے جنگ کرو کیونکہ یہ بے ایمان لوگ ہیں اور ان کی قسموں کا کچھ اعتبار نہیں ۔ عجیب نہیں کہ ( اپنی حرکات سے ) باز آ جائیں ۔ ","«انتھی» میں کسی کام سے  باز رہنے کا عمل بہت حد تک اختیاری ہوتا ہے جبکہ «اِنْفَکَّ» میں یہ عمل اضطراری (مجبوری ، بے بسی) کی صورت میں ہوتا ہے ۔","باز","انتھی","2:192-2:193-2:275-4:171-5:73-5:91-8:19-8:38-8:39-9:12-19:46-26:116-26:167-33:60-36:18-53:14-53:42-59:7-96:15",19
372,76,"ب","اِنَّفَکَ","«فَکّ» کے معنی ہیں کسی کو کسی بندھن سے آزاد کروادینا «فَکُ الْاَسِیْر» بمعنی قیدی کو چھڑانا اور «اِنْفِکَاک» کے معنی خود جدا ہونا ، کھلنا ۔ «اِنْفِکَاکُ الْعَبْد» کے معنی غلام کا آزاد ہونا ہے ۔ نیز «اِنْفَکَّ الْعَظْمُ» کے معنی کمزوری کی وجہ سے کاندھے کا اپنی جگہ سے ہٹ جانا (منجد ۔ مف) جس کا مطلب یہ ہے کہ «اِنْفِکَاک» میں باز رہنا اضطراری (یعنی زبر دستی) ہوتا ہے یعنی جس جگہ چمٹے ہوئے تھے اس جگہ سے (زبر دستی)  الگ ہونا ۔\nمثلاً : قرآن کریم میں ہے :\n«لَمۡ یَکُنِ الَّذِیۡنَ کَفَرُوۡا مِنۡ اَہۡلِ الۡکِتٰبِ وَالۡمُشۡرِکِیۡنَ مُنۡفَکِّیۡنَ حَتّٰی تَاۡتِیَہُمُ الۡبَیِّنَۃُ» ( 98/1 )\nترجمہ : جو لوگ کافر ہیں یعنی اہل کتاب اور مشرک وہ ( کفر سے ) باز رہنے والے نہ تھے ۔ جب تک کہ ان کے پاس کھلی دلیل نہ آتی ۔\nاور یہ کھلی دلیل حضور اکرم ﷺ کی بعثت اور غلبہ اسلام تھا جس نے انہیں کفر و شرک سے باز رہنے پر مجبور کر دیا ۔","«اِنَّفَکَ» کسی کو کسی بندھن سے آزاد کروادینا یا کسی کو کسی کام سے زبردستی روک دینا ۔","باز","انفک","98:1",1
373,77,"ب","جَنَاح","«جَنَاح» بمعنی پرندے کا پَر یا بازو ۔ تثنیہ «جَنَاحَیْن» پھر کنایۃً کسی چیز کے دو پہلوؤں کو بھی «جَنَاحَیْن» کہہ دیتے ہیں ۔ «جَنَاحَا الْعَسْکَر» بمعنی شکرے کے دونوں بازو یا جانب اسی طرح انسان کے دونوں بازؤں پر بھی اس لفظ کا اطلاق ہوتا ہے گویا «جَنَاحَ» کا لفظ دائیں یا بائیں جانب یا پہلو یا بازو سب جگہ استعمال ہوتا ہے اور بازو سے مراد کندھے سے لے کر انگلیوں کے آخر تک کا حصہ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّ اضۡمُمۡ  اِلَیۡکَ جَنَاحَکَ مِنَ الرَّہۡبِ» ( 28/32 )\nترجمہ : اور خوف سے بچنے کے لیے اپنے بازو کو اپنی طرف سکیڑ لو ۔","«جَنَاح» کندھے سے انگلی کے سرے تک جَنَاح  کہلاتا ہے ۔","بازو","جناح","6:38-15:88-17:24-20:22-26:215-28:32",6
374,77,"ب","عَضُد","«عَضُدُ» سے مراد کہنی سے لے کر کندھے تک کا حصہ ہے (مف) اور«عَضدْتُہٗ» بمعنی میں نے اسے بازو پر مارا ۔ نیز اس کے معنی میں نے اس کا بازو پکڑا اور سہارا دیا بھی ہیں ۔ لہذا یہ لفظ «یَدْ» کی طرح بطور استعارہ مددگار کے معنوں میں بھی آتا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ مَا کُنۡتُ مُتَّخِذَ الۡمُضِلِّیۡنَ عَضُدًا» ( 18/51 )\nترجمہ : اور میں ایسا نہ تھا کہ گمراہ کرنے والوں کو مددگار بناتا ۔","«عَضُدُ» بازو، کاندھے اورکہنی کے درمیانی  حصہ کو کہتے ہیں ۔","بازو","عضد","18:51-28:35",2
375,77,"ب","ذِرَاع","«ذِرَاع» بمعنی کہنی سے لے کر درمیانی انگلی کے آخر تک کا حصہ اور اس کا ترجمہ عمومًا ’’ ہاتھ ‘‘ ہی لیا جاتا ہے ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ کَلۡبُہُمۡ بَاسِطٌ ذِرَاعَیۡہِ  بِالۡوَصِیۡدِ» ( 18/18 )\nترجمہ : اور اُن کا کتا چوکھٹ پر دونوں ہاتھ پھیلائے ہوئے تھا ۔\nپھر «ذِرَاع» سے مراد پیمائش میں اتنی لمبائی بھی لی جاتی ہے جتنی کہنی سے لے کر درمیانی انگلی کے آخر تک ہوتی ہے اس لمبائی کو ہاتھ کہتے ہیں ۔ چونکہ انسان کا قد و قامت مختلف ادوار میں مختلف رہا ہے ۔ لہذا اس پیمائش کی مقدار بھی مختلف رہی ہے ۔ صاحب منجد نے 50 سے 70 سنٹی میٹر بتلائی ہے یعنی تقریبًا 20 انچ سے 28 انچ تک ۔ بعض مترجمین نے اس کا ترجمہ گز بھی کیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ  فِیۡ سِلۡسِلَۃٍ  ذَرۡعُہَا سَبۡعُوۡنَ  ذِرَاعًا  فَاسۡلُکُوۡہُ» ( 69/32 )\nترجمہ : پھر ایک زنجیر سے جس کی پیمائش ستر ہاتھ ہے اسے جکڑ دو ۔","«ذِرَاع» کہنی سے لے کر درمیانی انگلی کے آخر ی حصہ  تک کو کہتے ہیں ۔","بازو","ذراع","18:51-28:35",2
376,78,"ب","جَنَّۃ","«جَنَّۃ» نکلا ہے «جَنَّ» سے جس کے معنی ہیں کسی چیز کو حواس سے پوشیدہ کرنا اور چھپانا اور «جَنّۃٌ» ایسے باغ کو کہتے ہیں جس کی زمین درختوں اور سبزہ کی وجہ سے نظر نہ آئے (مف) صاحب منجد کے نزدیک «جَنَّۃٌ» درختوں سے ہرا بھرا باغ ہے خواہ وہ ارضی ہو یا سماوی ۔\nمثلاً : قرآن کریم میں ہے :\n«کَمَثَلِ جَنَّۃٍۭ بِرَبۡوَۃٍ اَصَابَہَا وَابِلٌ فَاٰتَتۡ اُکُلَہَا ضِعۡفَیۡنِ» ( 2/265 )\nترجمہ : ( ان کی مثال ) ایک باغ کی سی ہے جو اونچی جگہ پر واقع ہو ( جب ) اس پر زور کی بارش پڑے تو دگنا پھل لائے ۔","«جَنَّۃ» ایسے باغ کو کہتے ہیں جس کی زمین درختوں اور سبزہ کی وجہ سے نظر نہ آئے ۔","باغ","جنۃ","2:25-2:35-2:82-2:111-2:214-2:221-2:265-2:266-3:15-3:133-3:136-3:142-3:185-3:195-3:198-4:13-4:57-4:122-4:124-5:12-5:65-5:72-5:85-5:119-6:99-6:141-7:19-7:22-7:27-7:40-7:42-7:43-7:44-7:46-7:49-7:50-9:21-9:72-9:89-9:100-9:111-10:9-10:26-11:23-11:108-13:4-13:23-13:35-14:23-15:45-16:31-16:32-17:91-18:31-18:32-18:33-18:35-18:39-18:40-18:107-19:60-19:61-19:63-20:76-20:117-20:121-22:14-22:23-22:56-23:19-25:8-25:10-25:15-25:24-26:57-26:85-26:90-26:134-26:147-29:58-31:8-32:19-34:15-34:16-35:33-36:26-36:34-36:55-37:43-38:50-39:73-39:74-40:8-40:40-41:30-42:7-42:22-43:70-43:72-44:25-44:52-46:14-46:16-47:6-47:12-47:15-48:5-48:17-50:9-50:31-51:15-52:17-53:15-54:54-55:46-55:54-55:62-56:12-56:89-57:12-57:21-58:22-59:20-61:12-64:9-65:11-66:8-66:11-68:17-68:34-69:22-70:35-70:38-71:12-74:40-76:12-78:16-79:41-81:13-85:11-88:10-89:30-98:8",143
377,78,"ب","حَدَآئِق","«حَدَآئِق» جمع ہے «حَدِیْقَۃ» کی اور «حَدِیْقَۃ» نکلا ہے «حَدَقَ» سے اور «حَدَقَ» کے معنی ہیں کسی کو چاروں طرف سے گھیر لینا ۔ لہذا «حَدِیْقَۃ» ایسے باغ یا باغیچہ کو کہتے ہیں جس کے گرد حفاظت کے لیے چار دیواری بنا دی گئی ہو (منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَاَنۡۢبَتۡنَا بِہٖ حَدَآئِقَ ذَاتَ بَہۡجَۃٍ» ( 27/60 )\nترجمہ : پھر ہم نے اس بارش سے سرسبز باغ اگائے ۔","«حَدَآئِق» ایسے باغات یا باغیچوں کو کہتے ہیں جس کے ارد گرد حفاظت کے لیے چار دیواری بنا دی گئی ہو ۔","باغ","حدآئق","27:60-78:32-80:30",3
378,78,"ب","رَوْضَۃ","«رَوْضَۃ» کی جمع «رَوْضَات» ہے اور «رَوْض» کا لفظ وسعت اور فراخی پر دلالت کرتا ہے (م ۔ ل) اور «رَوَّضَ الْمَطْرُالْاَرْضَ» کے معنی بارش کا زمین کو باغ و بہار بنا دینا ہے اور «رَوْضَۃ» پُر بہار کیاری کو بھی کہتے ہیں (منجد) گویا «رَوْضَہ» کسی باغ کے اندر وہ حصہ یا مقام ہوتا ہے جو بڑا پُر بہار ہو اور ایسی جگہ پر ہی عمومًا بالاخانے یا بارہ دری وغیرہ بنائی جاتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَمَّا الَّذِیۡنَ اٰمَنُوۡا وَعَمِلُوا الصّٰلِحٰتِ فَہُمۡ فِیۡ رَوۡضَۃٍ یُّحۡبَرُوۡنَ» ( 30/15 )\nترجمہ : تو جو لوگ ایمان لائے اور نیک عمل کرتے رہے وہ ( بہشت کے ) باغ میں آؤ بھگت کیے جائیں گے ۔","«رَوْضَۃ» کسی باغ کے اندر کے اُس حصے یا مقام کو کہتے ہیں جو بڑا پُربہار ہو ۔ اور ایسی جگہ پر ہی عمومًا بالاخانے یا بارہ دری وغیرہ بنائی جاتی ہے ۔","باغ","روضۃ","30:15-42:22",2
379,79,"ب","اَبْقٰی","«بَقٰی» کے معنی کسی چیز کا باقی اور ہمیشہ رہنا ہے (م ۔ ل) اور اس کی ضد «فَنٰی» اور «ھَلَکَ» ہے ۔ یعنی کسی چیز کا نیست و نابود ہو جانا اور «اَبْقٰی» کے معنی کسی چیز کو برقرار اور باقی رکھنے کے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاَنَّہٗۤ اَہۡلَکَ عَادَۨا الۡاُوۡلٰیوَاَنَّہٗۤ اَہۡلَکَ عَادَۨا الۡاُوۡلٰی وَثَمُوۡدَا۠ فَمَاۤ اَبۡقٰی» ( 53/50،51 )\nترجمہ : اور اسی نے پہلے قوم عاد کو ہلاک کیا ہے ، اور ثمود کو بھی غرض کسی کو باقی نہ چھوڑا ۔","«اَبْقٰی» کسی چیز کے وجود کو برقرار اور باقی رکھنا ۔","باقی","ابقی","2:248-2:278-11:86-11:116-20:71-20:73-20:127-20:131-28:60-42:36-53:51-55:27-74:28-87:17",14
380,79,"ب","اَثْبَتَ","«ثَبَتَ» کے معنی کسی چیز کا اپنی حالت پر برقرار رہنا اور اس کی ضد «زَالَ» ہے یعنی کسی چیز کا اپنی جگہ سے اِدھر اُدھر ہٹ جانا اور «اَثْبَتَ» کے معنی کسی چیز کو اس کی اصلی حالت پر برقرار اور جمائے رکھنا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«یَمۡحُوا اللّٰہُ مَا یَشَآءُ وَ یُثۡبِتُ» ( 13/39 )\nترجمہ : اللہ جس کو چاہتا ہے مٹا دیتا ہے اور جس کو چاہتا ہے باقی رکھتا ہے ( عثمانیؒ )","«اَثْبَتَ» کسی چیز کو اپنی حالت پر باقی اور برقرار رکھنا ۔","باقی","اثبت","2:250-3:147-8:11-8:12-8:45-11:120-13:39-14:27-16:102-17:74-25:32-47:7",12
381,79,"ب","غَادَر","«غَدَرَ» کے معنی عہد کو توڑنا اور وعدہ خلافی کرنا ہے (م ۔ ل) نیز اس کے معنی پیچھے چھوڑ دینا بھی ہے (م ۔ ر) اور «غَادَرَ» کے معنی حساب کتاب کرنے کے وقت کوئی چیز ارادۃً پیچھے چھوڑنا یا شمار نہ کرنا کے ہیں (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَیَقُوۡلُوۡنَ یٰوَیۡلَتَنَا مَالِ ہٰذَا الۡکِتٰبِ لَا یُغَادِرُ صَغِیۡرَۃً وَّ لَا کَبِیۡرَۃً  اِلَّاۤ اَحۡصٰہَا» ( 18/49 )\nترجمہ : اور کہیں گے ہائے شامت یہ کیسی کتاب ہے کہ نہ چھوٹی بات کو چھوڑتی ہے اور نہ بڑی کو ۔ مگر اسے لکھ رکھا ہے ۔","«غَادَرَ» بہت چیزوں میں سے کسی ایک کو باقی چھوڑنا ۔","باقی","غادر","18:47-18:49",2
382,80,"ب","شَعْر","«شَعْر» انسان سمیت تمام جانداروں کے بال ۔ یہ لفظ عام ہے اور اس کی جمع اشعار ہے ۔ ( ف ل 98 )","«شَعْر» انسان سمیت تمام جانداروں کے بال کو کہتے ہیں ۔","بال","شعر","16:80",1
383,80,"ب","وَبْر","«وَبْر» اونٹ اور پرندوں کے بال اور رواں ۔ اسکی جمع «اَوْبَار» ( ف ل 98 )","«وَبْر» اونٹ اور پرندوں کے بال کو کہتے ہیں ۔","بال","وبر","16:80",1
384,80,"ب","صُوْف","«صُوْف» بھیڑ بکری وغیرہ کے بال اور اون کے لئے استعمال ہوتا ہے۔ اسکی جمع «اَصْوَاف» ہے ( ف ل 98 )\nمثلاً : قرآن کریم میں ہے :\n«وَمِنۡ اَصۡوَافِہَا وَاَوۡبَارِہَا وَاَشۡعَارِہَاۤ اَثَاثًا وَّمَتَاعًا اِلٰی حِیۡنٍ» ( 16/80 )\nترجمہ : اور ان کے اون ، ان کے رویں اور ان کے بالوں سے گھریلو سامان اور ایسی چیزیں پیدا کیں جو ایک مدت تک تمہیں فائدہ پہنچاتی ہیں ۔","«صُوْف» بھیڑ بکری وغیرہ کے بال اور اون کے لئے استعمال ہوتا ہے ۔","بال","صوف","16:80",1
385,81,"ب","عَاقِر","«عَاقِر» کے اصل مادہ «عَقَر» میں گھاؤ زخم لگانے کا مفہوم پایا جاتا ہے (م ل) «اَلْکَلْبُ الْعَقُوْر» کاٹنے والے کتے کو کہتے ہیں اور «عَقَرَ النَّخلَۃ» کے معنی کھجور کے درخت کو جڑ سے کاٹ دینا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَکَذَّبُوۡہُ  فَعَقَرُوۡہَا» ( 91/14 )\nترجمہ : تو انہوں نے پیغمبر ؑ کو جھٹلایا اور اونٹی کی کونچیں کاٹ دیں ۔\nپھر «اَلْعَقْر» کسی کے آخری بچہ کو بھی کہتے ہیں جس کے بعد کوئی اولاد نہ ہو (مف) گویا «عَاقِر» کا لفظ ایسی عورت کے لیے مستعمل ہے جس کی پہلے اولاد ہوتی رہی ہو بعد میں رحم (بچہ دانی) میں زخم یا حیض کی بندش یا کسی دوسرے وجہ سے اس کے ہاں اولاد ہونا بند ہو گئی ہو ۔ نیز یہ لفظ عورت و مرد دونوں کے لیے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنِّیۡ خِفۡتُ الۡمَوَالِیَ مِنۡ وَّرَآءِیۡ وَ کَانَتِ امۡرَاَتِیۡ عَاقِرًا فَہَبۡ لِیۡ مِنۡ لَّدُنۡکَ  وَلِیًّا» ( 19/5 )\nترجمہ : ( حضرت زکریا ؑ نے خدا سے التجا کی ) اور میں اپنے بعد اپنے بھائی بندوں سے ڈرتا ہوں ۔ اور میری بیوی بانجھ ہے تو مجھے اپنے پاس سے ایک وارث عطا فرما ۔","«عَاقِر» ایسی عورت کو کہتے ہیں جس سے پہلے اولاد ہوتی رہی  ہو بعد میں بند ہو چکی ہو ۔","بانجھ","عاقر","3:40-19:5-19:8",3
386,81,"ب","عَقِیْم","«عَقِیْم» بھی «عَاقِر» کی طرح مذکر و مؤنث دونوں کے لیے مستعمل ہے ۔ «عَقِیْم» ریت کے تودۂ یا زمین کے ایسے ٹکڑے کو بھی کہتے ہیں جو بنجر ہو (م ۔ ر) اور «رِیْحٌ عَقِیْمٌ» ایسی ہوا کو کہتے ہیں جو خیر سے خالی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَفِیْ عَادٍ اِذْ اَرْسَلْنَا عَلَیْهِمُ الرِّیْحَ الْعَقِیْمَۚ» ( 51/41 )\nترجمہ : اسی طرح عادیوں میں بھی ( ہماری طرف سے تنبیہ ہے ) جب کہ ہم نے ان پر خیر و برکت سے خالی آندھی بھیجی ۔\nاور «عَقِیْم» وہ شخص ہے جس کے مادہ تولید موجود ہی نہ ہو یا اس کے سیل مردہ ہوں (عام لفظوں میں ایسا مرد جس میں بچہ پیدا کرنے کی صلاحیت نہ ہو) اسی طرح «عَقِیْم» ایسی عورت کو کہتے ہیں جو مرد کا مادہ سرے سے قبول نہ کرے (م ۔ ر) گویا «عَقِیْم» وہ مرد یا عورت ہے جس کے ہاں سرے سے کوئی اولاد نہ ہوئی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَوۡ یُزَوِّجُہُمۡ ذُکۡرَانًا وَّاِنَاثًا ۚ وَیَجۡعَلُ مَنۡ یَّشَآءُ عَقِیۡمًا» ( 42/50 )\nترجمہ : یا ان کو بیٹے اور بیٹیاں دونوں عطا فرماتا ہے اور جسے چاہتا ہے بانجھ بنا دیتا ہے ۔","«عَقِیْم» وہ عورت جس کو بچّہ پیدا نہ ہوتا ہو، اور وہ مرد جس کے نطفے سے حمل نہ  ٹہرے ، بانجھ (عورت اور مرد دونوں ) کے لئے استعمال ہوتا ہے ۔","بانجھ","عقیم","22:55-42:50-51:29-51:41",4
387,82,"ب","رَبَطَ","«رَبَطَ» مضبوط باندھنا اور «مِرْبَطُ» جانوروں کو باندھنے کی رسی وغیرہ «مَرْبَطُ» چوپاؤں کو باندھنے کی جگہ اور «رَبَّاط» بمعنی تانت کو باندھنے والا اور «رَبَیْطَہ» بمعنی بندھے ہوئے جانور اور «رَبَطَ اللہُ عَلیٰ قَلْبِہٖ» محاورہ ہے ۔ اللہ تعالیٰ نے اس کے دل کو باندھ دیا یعنی اس کے دل کو قوت بخشی اور صبرعطا فرمایا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«اِنۡ کَادَتۡ لَتُبۡدِیۡ بِہٖ لَوۡلَاۤ اَنۡ رَّبَطۡنَا عَلٰی قَلۡبِہَا» ( 28/10 )\nترجمہ : اگر ہم اس ( موسیٰ کی ماں کے ) دل کو گرما نہ دیتے ، تو قریب تھا کہ وہ اس بات کو ظاہر کر دے ۔","«رَبَطَ» کسی چیز کو رسی سے باندھنا اور «رَبَطَ اللہُ عَلیٰ قَلْبِہٖ» اللہ کا کسی کے دل کو مضبوط کر کے صبرعطا فرمانا ۔","باندھنا","ربط","8:11-18:14-28:10",3
388,82,"ب","شَدَّ","«شَدَّ الشَّیْء» بمعنی کسی چیز کو باندھنا ، مضبوط کرنا ۔ مضبوط باندھنا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«حَتّٰۤی اِذَاۤ  اَثۡخَنۡتُمُوۡہُمۡ فَشُدُّواالۡوَثَاقَ» ( 47/4 )\nترجمہ : پھر جب ان کو خوب قتل کر چکو تو انہیں مضبوط باندھ کر قید کر لو ۔","«شَدّ» باندھ کرخوب مضبوط کرنا ۔ ","باندھنا","شد","10:88-20:31-28:35-38:20-47:4-66:6-76:28-78:12",8
389,82,"ب","غُلّ","«غُلّ» اس کی جمع «اَغْلَال» ہے  ہر وہ چیز جس سے کسی بھی عضو کو جکڑ کر اس کے وسط میں باندھ دیا جائے اور بمعنی طوق  اور کنایۃً «مَغْلُولُ الْیَد» بخیل شخص کو کہتے ہیں یعنی اس شخص کے ہاتھ خرچ کرنے سے بندھے ہوئے ہوتے ہیں (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَقَالَتِ الۡیَہُوۡدُ یَدُ اللّٰہِ مَغۡلُوۡلَۃٌ ؕ غُلَّتۡ اَیۡدِیۡہِمۡ وَ لُعِنُوۡا بِمَا قَالُوۡا ۘ بَلۡ یَدٰہُ مَبۡسُوۡطَتٰنِ ۙ یُنۡفِقُ کَیۡفَ یَشَآءُ» ( 5/64 )\nترجمہ : اور یہود کہتے ہیں کہ خدا کا ہاتھ ( گردن سے ) بندھا ہوا ہے ( یعنی اللہ بخیل ہے ) انھیں کے ہاتھ باندھیں جائیں اور ایسا کہنے کے سبب ان پر لعنت ہو بلکہ اس کے دونوں ہاتھ کھلے ہیں وہ جس طرح چاہتا ہے خرچ کرتا ہے ۔","«غُلّ» بخیل شخص کو کہتے ہیں ۔ یعنی اس شخص کے ہاتھ خرچ کرنے سے بندھے ہوئے ہوتے ہیں ۔","باندھنا","غل","5:64-12:23-17:29",3
390,83,"ب","صَنَم","«صَنَم» کی جمع «اَصْنَام» ہے بمعنی چاندی ، پیتل یا لکڑی کے خود تراشیدہ بت اور مورتیاں وغیرہ جو قابلِ انتقال اور خرید و فروخت ہوتے ہیں ۔ (مف م ل)\n«صَنَّاعَۃُ الْاَصْنَام» بت فروشی کے فن اور پیشہ کو کہتے ہیں ۔ حضرت ابراہیم ؑ کا باپ آزر یہی کاروبار کرتا تھا ۔ اور حضرت ابراہیم ؑ اپنے رب سے یو دعا کرتے ہیں :\nمثلاً : قرآن کریم میں ہے :\n«وَّاجۡنُبۡنِیۡ وَ بَنِیَّ اَنۡ نَّعۡبُدَ الۡاَصۡنَامَ» ( 14/35 )\nترجمہ : اور ( اے پروردگار ) مجھے اور میری اولاد کو بتوں کی پرستش سے بچائے رکھنا ۔","«صَنَم» چاندی ، پیتل یا لکڑی کو تراش کر بنائے گئے بُت اور مورتیاں ۔","بت","صنم","6:74-7:138-14:35-21:57-26:71",5
391,83,"ب","نُصُب","«نَصَبَ الشَّیْء» کے معنی کسی کو سیدھے رخ کھڑا کر دینا اور زمین میں گاڑ دینا اور «نَصِیْبٌ» وہ پتھر ہے جوراستہ بتانے کے لیے گاڑا جاتا ہے (مف) اور«نَصِیْب» پتھر یا لوہے وغیرہ کے اس مجسمے کو بھی کہتے ہیں جو کسی جگہ بغرض عبادت نصب کر دیا گیا ہو یہ مجسمے عمومًا نبیوں ، ولیوں ، اور پیروں یا بادشاہوں کے ہوتے ہیں ۔ اور ایسے مقامات جہاں یہ مجسمے نصب ہوں انہیں تھان کہا جاتا ہے ۔ اور اس کی جمع «نُصُب» اور «اَنْصَاب» آئی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَا ذُبِحَ عَلَی النُّصُبِ وَ اَنۡ تَسۡتَقۡسِمُوۡا بِالۡاَزۡلَامِ» ( 5/3 )\nترجمہ : اور وہ جانور بھی جو تھان پر ذبح کیا جائیں اور یہ بھی پانسوں کے تیروں سے قیمت معلوم کرو ۔ ( یہ سب کچھ تم پرحرام کیا گیا ہے )","«نَصَب» زمین میں گاڑے ہوئے مجسمے ۔","بت","نصب","5:3-70:43-88:19",3
392,83,"ب","وَثْن","«وَثْن» اسکی جمع «اَوْثَان» ہے بمعنی اپنی جگہ ثابت و قائم رہنے والے بُت یہ بت تراشیدہ اور نصب کردہ نہیں ہوتے ۔ بلکہ بعض مخصوص مقامات پتھروں ، درختوں ، ستاروں یا دریاؤں وغیرہ میں خدا کی صفات کا عقیدہ رکھ کر ان کی عبادت شروع کر دی جاتی ہے «اَلْوَثَنِیٌّ» بت پرست کو اور «اَلْوَثَنِیَّۃ» بت پرستی کو کہتے ہیں (منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَاجۡتَنِبُواالرِّجۡسَ مِنَ الۡاَوۡثَانِ وَاجۡتَنِبُوۡا قَوۡلَ الزُّوۡرِ» ( 22/30 )\nترجمہ : تو بتوں کی پلیدی سے بچو اور جھوٹی بات سے پرہیز کرو ۔","«وَثْن» بعض مخصوص مقامات پتھروں ، درختوں ، ستاروں یا دریاؤں وغیرہ میں خدا کی صفات کا عقیدہ رکھ کر ان کی عبادت شروع  کردینا ۔","بت","وثن","22:30-29:17-29:25",3
393,83,"ب","جِبْت","«جِبْت» بمعنی بت ، کاہن ، فال گری ، اور ہر وہ چیز جس میں خیر نہ ہو۔ مثلاً جادو ٹونہ (م ۔ ر) یہ لفظ دراصل  توہمات ، وسوسے اور خرافات کے لیے جامع لفظ ہے ۔ جس میں جادو ، ٹونے ٹوٹکے ، جنتر منتر ، سیاروں کی تاثیرات ،  تعویذ گنڈے ، نقش وغیرہ سب کچھ شامل ہے ۔","«جِبْت» بمعنی بت ، کاہن ، فال گری ، اور ہر وہ چیز جس میں خیر نہ ہو۔ مثلاً جادو ٹونہ ۔","بت","جبت","4:51",1
394,83,"ب","طَاغُوْت","«طَاغُوْت» بمعنی ’’ لات ، عزّٰی ، جادوگر ، کاہن ، باطل ، بت اور غیراللہ کی پرستش اور سرکش ‘‘ (م ۔ ر) گویا طاغوت سے مراد وہ تمام باطل اور سرکش نظام یا قوت ہے جو اللہ کے مقابلہ میں اس کے احکام کی اطاعت پر مائل ہوں اور انہیں تسلیم کرلیا جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَمۡ تَرَ اِلَی الَّذِیۡنَ اُوۡتُوۡا نَصِیۡبًا مِّنَ الۡکِتٰبِ یُؤۡمِنُوۡنَ بِالۡجِبۡتِ وَالطَّاغُوۡتِ» ( 4/51 )\nترجمہ : کیا آپ نے انہیں نہیں دیکھا جنہیں کتاب کا کچھ حصّہ مِلا ہے؟ جو بُت کا اور باطل معبود کا اعتقاد رکھتے ہیں ۔","«طَاغُوْت» طاغوت سے مراد وہ تمام باطل اور سرکش نظام یا قوت ہے جو اللہ کے مقابلہ میں اس کے احکام کی اطاعت پر مائل ہوں اور انہیں تسلیم کرلیا جائے ۔","بت","طاغوت","2:256-2:257-4:51-4:60-4:76-5:60-16:36-37:30-38:55-39:17-51:53-52:32-68:31-69:5-78:22",15
395,84,"ب","بَرْق","«بَرْق» چمکنے والی یا کوندنے والی بجلی کو کہتے ہیں جو آنکھوں کو خیرہ  چکاچوند کر دیتی ہے اور «بَرِقَ الْبَصَرُ» بمعنی آنکھوں کا چندھیانا ۔\nمثلاً : قرآن کریم میں ہے :\n«یَکَادُ الۡبَرۡقُ یَخۡطَفُ اَبۡصَارَہُمۡ» ( 2/20 )\nترجمہ : قریب ہے کہ بجلی ( کی چمک ) ان کی آنکھوں ( کی بصارت ) کو اچک لے جائے ۔","«بَرْق» چمکنے والی یا کوندنے والی بجلی کو کہتے ہیں ۔","بجلی","برق","2:19-2:20-13:12-24:43-30:24-75:7",6
396,84,"ب","رَعْد","«رَعْد» کڑکنے اور گرجنے والی بجلی ۔ نیز ایسے بادل کو بھی کہتے ہیں جس میں کڑک اور گرج ہو (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ یُسَبِّحُ الرَّعۡدُ بِحَمۡدِہٖ وَالۡمَلٰٓئِکَۃُ مِنۡ خِیۡفَتِہٖ» ( 13/13 )\nترجمہ : اور رعد اور فرشتے سب اس کے خوف سے اس کی تسبیح و تمحید کرتے رہتے ہیں ۔","«رَعْد» کڑکنے اور گرجنے والی بجلی کو کہتے ہیں ۔","بجلی","رعد","2:19-13:13",2
397,84,"ب","صَاعِقَۃ","«صَاعِقَۃ» آسمان سے گرنے والی کڑک دار بجلی جو جلا کر بھسم کر دے ۔ لہذا اس کا معنی عذاب الہی یا موت بھی کر لیا جاتا ہے ۔\n اور امام راغب کہتے ہیں کہ اس سے مراد ایسا خوفناک دھماکہ ہے جو اجسام علوی سے متعلق ہو اور اس کے مقابل لفظ صَقَعَ ہے جو اجسام ارضی سے مخصوص ہے اور معنیٰ دونوں کا ایک ہی ہے ۔ (مف) اور صاحب منتہی الادب اس کے معنی آسمان سے شدید کڑک کے ساتھ آگ پھینکنا ، یا ایسی سخت آواز جسے سن کر بیہوش ہو جائے بتلاتے ہیں (م ۔ ر) اس صورت میں «صَاعِقَۃ ، رَعْد» ہی کی انتہائی صورت ہے ۔ اور «صَاعِقَۃ» کی جمع «صَوَاعِق» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَیُرۡسِلُ الصَّوَاعِقَ فَیُصِیۡبُ بِہَا مَنۡ یَّشَآءُ» ( 13/13 )\nترجمہ : اور وہی بجلیاں بھیجتا ہے ۔ پھر جس پر چاہتا ہے گرا بھی دیتا ہے ۔\nنوٹ : (اجسام علوی یعنی وہ عمل جو فرشتوں یا اسمائے الہیٰ کے ذریعے کیا جائے)","«صَاعِقَۃ» آسمان سے گرنے والی کڑک دار بجلی جو جلا کر بھسم کر دے ۔","بجلی","صاعقۃ","2:19-2:55-4:153-13:13-41:13-41:17-51:44",7
398,85,"ب","وَقٰی","«وَقٰی» کسی برے کام کی سزا سے ڈرا کر اس برے کام اور اسکی سزا سے بچانا ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡا قُوۡۤا اَنۡفُسَکُمۡ وَاَہۡلِیۡکُمۡ نَارًا» ( 66/6 )\nترجمہ : مومنو ! اپنے آپ کو اپنے اہل و عیال کو آتشِ جہنم سے بچاؤ ۔","«وَقٰی» کسی برے کام کی سزا سے ڈرا کر اس برے کام اور اسکی سزا سے بچانا ۔","بچانا","وقی","66:6",1
399,85,"ب","مَنَعَ","«مَنَعَ» کے معنی روکنا اور اس کی ضد «اَلْاِعْطَاء» یعنی کسی کو کچھ دے دینا ہے (م ۔ ل) روک کھڑی کر دینا یا رکاوٹ بن کر کسی مصیبت یا آفت سے بچانے کے معنی میں بھی آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَظَنُّوۡۤا اَنَّہُمۡ مَّانِعَتُہُمۡ حُصُوۡنُہُمۡ مِّنَ اللّٰہِ» ( 59/2 )\nترجمہ : اور وہ لوگ یہ سمجھے ہوئے تھے کہ ان کے قلعے اُن کو خدا ( کے عذاب ) سے بچا لیں گے ۔","«مَنَعَ» کسی چیز کی روک بن کر مصیبت سے  بچانا ۔","بچانا","منع","2:114-4:141-7:12-9:54-12:63-17:59-17:94-18:55-20:92-21:43-38:75-59:2-107:7",13
400,85,"ب","حَجَزَ","«حَجَز» اصل میں دو چیزوں کے درمیان ایک تیسری چیز ہوتی ہے اور وہ درمیان میں حائل ہو کرآڑ کا کام دیتی ہے (م ۔ ل) اور «حَجَز» بمعنی آڑ بن کر ایک چیز کو دوسری سے بچا لینا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَمَا مِنۡکُمۡ  مِّنۡ اَحَدٍ عَنۡہُ حٰجِزِیۡنَ» ( 69/47 )\nترجمہ : پھر تم میں سے کوئی ایسا نہیں جو اسے اس سے بچا لے ( عثمانیؒ )","«حَجَز» کسی تیسری چیز کا حائل ہو کر بچانا ۔","بچانا","حجز","27:61-69:47",2
401,85,"ب","اَحْصَنَ","«حَصَنَ» کے معنی قلعہ یا پناہ گاہ کے ہیں ۔ ابن الفارس کے نزدیک اس کے معنیٰ میں تین باتیں بنیادی طور پر پائی جاتی ہیں (1) حفاظت (2) احاطہ (3) پناہ (م ل) لہذا «اَحْصَنَ» میں بھی یہی باتیں پائی جائیں گی ۔ یعنی روکنا ۔ بچانا اور پوری طرح نگہداشت کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَرۡیَمَ  ابۡنَتَ عِمۡرٰنَ الَّتِیۡۤ اَحۡصَنَتۡ فَرۡجَہَا» ( 66/12 )\nترجمہ : اور عمران کی بیٹی مریم کی جنھوں نے اپنی شرم گاہ کو محفوظ رکھا ۔","«اَحْصَنَ» نگہداشت اور حفاظت کر کے خود کو بچانا ۔","بچانا","احصن","4:24-4:25-5:5-21:91-24:4-24:23-59:14-66:12",8
402,85,"ب","جَنَبَ","«جَنَب» کے دو بنیادی معنی ہیں (1) پہلو (2) دور کر دینا (م ل) اور «جَنَبَ» کے معنی کسی کو دور کرکے علیحدہ لے جا کر کسی مصیبت یا آفت سے بچا لینا ۔\nمثلاً : حضرت ابراہیم ؑ نے اپنے پروردگار کے حضور یوں دعا فرمائی :\n«وَّاجۡنُبۡنِیۡ وَ بَنِیَّ اَنۡ نَّعۡبُدَ الۡاَصۡنَامَ» ( 14/35 )\nترجمہ : اور مجھے اور میری اولاد کو اس بات سے کہ بتوں کی پرستش کرنے لگیں بچائے رکھ ۔","«جَنَب» کسی کو دور کر کے علیحدہ لے جا کر کسی مصیبت یا آفت سے بچا لینا ۔","بچانا","جنب","14:35-87:11-92:17",3
403,85,"ب","عَصَم","«عَصَم» کسی چیز کو اپنے پاس روک کر یا اپنی حفاظت میں لے کر اسے کسی ایسی آفت سے بچانا جس میں وہ جا پڑنے والا ہو ۔ (م ۔ ل) ابن فارس کے اپنے الفاظ میں «ع ۔ ص ۔ م» «کَلِمَۃٌ تَدُلُّ عَلَی الْاِمْسَاکِ وَالْمَنْعِ وَالْ مُلَازِمَۃِ مِنْ سُوْٓءِ مَا یَقَعُ فِیْہِ» (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَاالرَّسُوۡلُ بَلِّغۡ  مَاۤ اُنۡزِلَ اِلَیۡکَ مِنۡ رَّبِّکَ ؕ وَاِنۡ لَّمۡ تَفۡعَلۡ فَمَا بَلَّغۡتَ رِسَالَتَہٗ ؕ وَاللّٰہُ یَعۡصِمُکَ مِنَ النَّاسِ» ( 5/67 )\nترجمہ : اے پیغمبر ﷺ ! جو ارشادات خدا کی طرف سے تم پر نازل ہوئے ہیں سب لوگوں کو پہنچا دو ۔ اگر ایسا نہ کیا تو تم خدا کا پیغام پہنچانے میں قاصر رہے اور خدا تم کو لوگوں سے بچائے رکھے گا ۔\nقرآن کریم میں ایک دوسرے مقام پر حضرت نوح ؑ کا بیٹا حضرت نوح ؑ کو یوں جواب دیتا ہے :\n«سَاٰوِیۡۤ  اِلٰی جَبَلٍ یَّعۡصِمُنِیۡ  مِنَ الۡمَآءِ» ( 11/43 )\nترجمہ : میں ابھی پہاڑ سے جا لگوں گا ۔ وہ مجھے ( طوفان کے ) پانی سے بچا لے گا ۔","«عَصَم» کسی مصیبت اور خطرہ سے کسی دوسرے کو اپنی حفاظت میں لے کر بچانا ۔","بچانا","عصم","5:67-11:43-12:32-33:17",4
404,85,"ب","اِتَّقٰی","«اِتَّقٰی اور تَقْوٰی» کسی برے کام کی سزا سے بچنے کے لیے برے کام اور اس کی سزا سے بچنا ، پرہیزگاری اختیار کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«خُذُوۡا مَاۤ اٰتَیۡنٰکُمۡ بِقُوَّۃٍ وَّ اذۡکُرُوۡا مَا فِیۡہِ لَعَلَّکُمۡ تَتَّقُوۡنَ» ( 2/63 )\nترجمہ : جو کتاب ہم نے تم کو دی ہے اس کو زور سے پکڑے رہو اور جو اس میں ( لکھا ) ہے اسے یاد رکھو تاکہ تم ( عذاب سے ) بچ سکو ۔","«اِتَّقٰی اور تَقْوٰی» برے کاموں کی  سزا سے ڈر کر ان برے کاموں سے بچنا ۔","بچانا","اتقی","2:2-2:21-2:24-2:41-2:48-2:63-2:66-2:103-2:123-2:177-2:179-2:180-2:183-2:187-2:189-2:194-2:196-2:197-2:203-2:206-2:212-2:223-2:224-2:231-2:233-2:237-2:241-2:278-2:281-2:282-2:283-3:15-3:28-3:50-3:76-3:102-3:115-3:120-3:123-3:125-3:130-3:131-3:133-3:138-3:172-3:179-3:186-3:198-3:200-4:1-4:9-4:77-4:128-4:129-4:131-5:2-5:4-5:7-5:8-5:11-5:27-5:35-5:46-5:57-5:65-5:88-5:93-5:96-5:100-5:108-5:112-6:32-6:51-6:69-6:72-6:153-6:155-7:26-7:35-7:63-7:65-7:96-7:128-7:156-7:164-7:169-7:171-7:201-8:1-8:25-8:29-8:34-8:56-8:69-9:4-9:7-9:36-9:44-9:108-9:109-9:115-9:119-9:123-10:6-10:31-10:63-11:49-11:78-12:57-12:90-12:109-13:35-15:45-15:69-16:2-16:30-16:31-16:52-16:81-16:128-19:13-19:18-19:63-19:72-19:85-19:97-20:113-20:132-21:48-22:1-22:32-22:37-23:23-23:32-23:52-23:87-24:34-24:52-25:15-25:74-26:11-26:90-26:106-26:108-26:110-26:124-26:126-26:131-26:132-26:142-26:144-26:150-26:161-26:163-26:177-26:179-26:184-27:53-28:83-29:16-30:31-31:33-33:1-33:32-33:37-33:55-33:70-36:45-37:124-38:28-38:49-39:10-39:16-39:20-39:24-39:28-39:33-39:57-39:61-39:73-40:9-41:18-43:35-43:63-43:67-44:51-45:19-47:15-47:17-47:36-48:26-49:1-49:3-49:10-49:12-49:13-50:31-51:15-52:17-53:32-54:54-57:28-58:9-59:7-59:18-60:11-64:16-65:1-65:2-65:4-65:5-65:10-68:34-69:48-71:3-73:17-74:56-77:41-78:31-91:8-92:5-92:17-96:12",223
405,85,"ب","تَحَصَّنَ","«تَحَصَّنَ» کسی چیز کی نگہداشت اور حفاظت کر کے اسے بچانا ۔ یہ لفظ عمومًا اپنی عفت کی حفاظت کے لیے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تُکۡرِہُوۡا فَتَیٰتِکُمۡ عَلَی الۡبِغَآءِ اِنۡ اَرَدۡنَ تَحَصُّنًا لِّتَبۡتَغُوۡا عَرَضَ الۡحَیٰوۃِ الدُّنۡیَا» ( 24/33 )\nترجمہ : اور اپنی لونڈیوں کو اگر وہ پاکدامن رہنا چاہیں تو ( بے شرمی سے ) دنیاوی زندگی کے فوائد حاصل کرنے کے لیے بدکاری پر مجبور نہ کرنا ۔","«تَحَصَّنَ» کسی چیز کی نگہداشت اور حفاظت کر کے اسے بچانا ۔","بچانا","تحصن","12:48-21:80-24:33",3
406,85,"ب","اِجْتَنَبَ","«اِجْتَنَبَ» کسی چیز یا کام سے دور رہ کر بچنا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاجۡتَنِبُوا الرِّجۡسَ مِنَ الۡاَوۡثَانِ وَاجۡتَنِبُوۡا قَوۡلَ الزُّوۡرِ» ( 22/30 )\nترجمہ : تو بتوں کی پلیدی سے بچو اور جھوٹی بات سے پرہیز کرو ۔","«اِجْتَنَبَ» کسی چیز یا کام سے دور رہ کر بچنا ۔","بچانا","اجتنب","4:31-5:90-16:36-22:30-39:17-42:37-49:12-53:32",8
407,85,"ب","اِسْتَعْصَمَ","«اِسْتَعْصَمَ» کسی گناہ یا نقصان سے بچنا اور حفاظت کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«ولَقَدۡ رَاوَدۡتُّہٗ عَنۡ نَّفۡسِہٖ فَاسۡتَعۡصَمَ» ( 12/32 )\nترجمہ : ( زلیخا کہنے لگی ) بیشک میں نے اسے ( یوسف ؑ کو ) اپنی طرف مائل کرنا چاہا مگر یہ بچا رہا ۔\nمندرجہ بالا آیت میں ذکر کیے گئے الفاظ کےعلاوہ «حَذَرَ» اور «تَعَفُّف» بھی بچنے کے معنیٰ میں قرآن کریم میں استعمال ہوئے ہیں :","«اِسْتَعْصَمَ» کسی گناہ یا نقصان سے بچنا اور حفاظت کرنا ۔","بچانا","استعصم","12:32",1
408,85,"ب","حَذَرَ","«حَذَرَ» کسی متوقع خطرہ سے بچاؤ کی خاطر چوکنا اور ہوشیار رہنا (مف ۔ م ل)\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَاالَّذِیۡنَ اٰمَنُوۡۤا اِنَّ مِنۡ اَزۡوَاجِکُمۡ وَاَوۡلَادِکُمۡ عَدُوًّا لَّکُمۡ فَاحۡذَرُوۡہُمۡ» ( 64/14 )\nترجمہ : اے ایمان والو ! تمہاری عورتوں اور اولاد میں سے بعض تمہارے دشمن ( بھی ) ہیں ۔ سو ان سے بچتے رہو ۔","«حَذَرَ» آنے والے خطرہ سے ہوشیار رہنا اور بچنا ۔","بچانا","حذر","2:19-2:235-2:243-3:28-3:30-4:71-4:102-5:41-5:49-5:92-9:64-9:122-24:63-28:6-39:9-63:4-64:14",17
409,85,"ب","تَعَفُّف","«عَفَّ» کے معنی حرام  یا ناپسندیدہ  کام سے رکنا ۔ پاکدامن رہنا اور «تَعَفُّفَ» حرام کاموں سے  بچنا اور پاکدامن رہنا ۔ (منجد ۔ م ر)\nمثلاً : قرآن کریم میں ہے :\n«یَحۡسَبُہُمُ الۡجَاہِلُ اَغۡنِیَآءَ مِنَ التَّعَفُّفِ ۚ تَعۡرِفُہُمۡ بِسِیۡمٰہُمۡ ۚ لَا یَسۡئَلُوۡنَ النَّاسَ اِلۡحَافًا» ( 2/273 )\nترجمہ : ان کے سوال نہ کرنے کی وجہ سے ناواقف لوگ انہیں خوشحال سمجھتے ہیں۔ آپ ان کے چہروں سے ان کی کیفیت پہچان سکتے ہیں ۔","«تَعَفُّفَ» حرام کاموں سے  بچنا اور پاکدامن رہنا ۔","بچانا","تعفف","2:273-4:6-24:33-24:60",4
410,86,"ل","اَجِنَّۃ","«اَجِنَّہ» جمع ہے «جَنِیْن» کی ، وہ بچہ جو ماں کے پیٹ میں ہو اسے «جَنِیْن» کہا جاتا ہے ۔  اور«جَنَّ» بمعنی کسی چیز کو ڈھانپ لینا اور پوشیدہ کرنا (فل 90)\nمثلاً : قرآن کریم میں ہے :\n«وَاِذۡ اَنۡتُمۡ اَجِنَّۃٌ فِیۡ بُطُوۡنِ اُمَّہٰتِکُمۡ» ( 53/32 )\nترجمہ : اور جب تم اپنی ماؤں کے پیٹ میں بچے تھے ۔","«اَجِنَّہ» جمع ہے «جَنِیْن» کی  وہ بچہ جو ماں کے پیٹ میں ہو اسے «جَنِیْن» کہا جاتا ہے ۔","لڑکا","اجنۃ","53:32",1
411,86,"ل","وَلِیْدًا","«وَلَدُ» کا لغوی مفہوم نوزائیدہ بچہ ہے  پھر اس لفظ کا اطلاق چھوٹی عمر کے بچوں پر ہونے لگا (مف ۔ فل 190)\nمثلاً : قرآن کریم میں ہے :\n«قَالَ اَلَمۡ نُرَبِّکَ فِیۡنَا وَلِیۡدًا وَّلَبِثۡتَ فِیۡنَا مِنۡ عُمُرِکَ سِنِیۡنَ» ( 26/18 )\nترجمہ : ( فرعون نے موسیٰ ؑ سے ) کہا  کیا ہم نے تم کو کہ تم ابھی بچے تھے پرورش نہیں کیا اور تم نے برسوں ہمارے ہاں عمر بسر ( نہیں ) کی ؟\nاور«وَلَدُ» اور «مَوْلُود» کا تعلق صرف بچہ یا اس کی عمر سے نہیں بلکہ «وَلَدُ» کے مقابلہ میں اس کے (پیدا ہونے ) کے فعل سے بھی ہے وہ خواہ چھوٹی عمر کا ہو یا جوان ہو یا بوڑھا ، اپنے والد کے مقابلے میں «وَلَدُ» اور مولود ہی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا النَّاسُ اتَّقُوۡا رَبَّکُمۡ وَاخۡشَوۡا یَوۡمًا لَّا یَجۡزِیۡ وَالِدٌ عَنۡ وَّلَدِہٖ ۫ وَ لَا مَوۡلُوۡدٌ ہُوَجَازٍعَنۡ وَّالِدِہٖ شَیۡئًا» ( 31/33 )\n ترجمہ : لوگو ! اپنے پروردگار سے ڈرو اور اس دن کا خوف کرو کہ نہ تو باپ اپنے بیٹے کے کچھ کام آئے اور نہ بیٹا باپ کے کچھ کام آ سکے ۔\nاس لحاظ سے «وَلِیْدٌ ، مَوْلُوْدٌ ، وَلَدٌ» یعنی ’’ نوزائیدہ بچہ ‘‘ یا دودھ پیتے بچے کے معنوں میں بھی آ جاتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«لَا تُضَآرَّ وَالِدَۃٌۢ بِوَلَدِہَا وَلَا مَوۡلُوۡدٌ لَّہٗ بِوَلَدِہٖ» ( 2/233 )\n ترجمہ : نہ تو ماں کو اس کے بچے کے سبب ( دودھ پلانے کے معاملہ میں ) نقصان پہنچایا جائے ۔ اور نہ باپ کو اس کی اولاد کی وجہ سے !\nاور «وَلَدُ» کے لفظ کا تعلق عمر سے ہو تو اس کا اطلاق عمومًا آٹھ دس سال کے نوخیز بچوں پر ہوتا ہے جو چھوٹے موٹے کام کرنے اور خدمت کرنے کے قابل ہو جائیں اور اس کی جمع «وِلْدَان» آتی ہے ۔ مذکر و مونث دونوں کے لیے استعمال ہوتا ہے ( فل 93 )\n جیسا کہ قرآن کریم میں ارشاد باری تعالیٰ ہے :\n«وَیَطُوۡفُ عَلَیۡہِمۡ وِلۡدَانٌ مُّخَلَّدُوۡنَ ۚ اِذَا رَاَیۡتَہُمۡ حَسِبۡتَہُمۡ لُؤۡلُؤًا مَّنۡثُوۡرًا» ( 76/19 )\n ترجمہ : اور ان ( جنتی لوگوں ) کے پاس لڑکے آتے جاتے ہوں گے جو ہمیشہ ایک ہی حالت پر رہیں گے ۔ جب تم ان پر نگاہ ڈالو تو خیال کرو کہ بکھرے ہوئے موتی ہیں ۔","«وَلَدُ» آٹھ دس سال کی عمر تک کا بچہ ( والد کی طرف نسبت کے لحاظ سے ہرعمر کے آدمی کو بھی کہا جاتا ہے) ۔","لڑکا","ولیدًا","2:116-2:233-3:47-4:11-4:12-4:75-4:98-4:127-4:171-4:176-6:101-10:68-12:21-17:111-18:4-18:39-19:35-19:77-19:88-19:91-19:92-21:26-23:91-25:2-26:18-28:9-31:33-37:152-39:4-43:81-56:17-71:21-72:3-73:17-76:19-90:3-112:3",37
412,86,"ل","طِفْل","«طَفِلَ» کے معنی نرم و نازک ہونا اور «طَفْلَۃٌ» گداز بدن عورت کو کہتے ہیں ۔ اس لحاظ سے جب تک بچہ نرم و نازک رہے وہ «طِفْل» ہے (مف) تاہم اس سے ایسے بچے مراد ہوتے ہیں جو ابھی بالغ نہ ہوئے ہوں ۔ اوراسکی جمع اطفال ہے :\nمثلاً : قرآن کریم میں ہے :\n«وَاِذَا بَلَغَ الۡاَطۡفَالُ مِنۡکُمُ الۡحُلُمَ فَلۡیَسۡتَاۡذِنُوۡا کَمَا اسۡتَاۡذَنَ الَّذِیۡنَ مِنۡ قَبۡلِہِمۡ» ( 24/59 )\nترجمہ : اور جب تمہارے لڑکے بالغ ہو جائیں تو انکو بھی اس طرح اجازت لینی چاہیے جس طرح ان سے اگلے ( یعنی بڑے آدمی ) اجازت حاصل کرتے رہے ہیں ۔\nاس آیت سے یہ واضح ہے کہ بلوغت کے بعد طفل بچہ کی حد سے نکل کر بڑے کی حد میں داخل ہو جاتا ہے ۔","«طِفْل» نابالغ بچہ ۔","لڑکا","طفل","22:5-24:31-24:59-40:67",4
413,86,"ل","صَبِیٌّ","«صَبِیٌّ» وہ بچہ ہے جو ابھی نادانی اور کھیل کود کی عمر میں ہو (م ۔ ر) اوراس لفظ کا تعلق عمر سے زیادہ بچپنے کی عادات سے ہوتا ہے ۔ اگر لڑکا بالغ ہونے کے بعد بھی نادان اور کھیل کود میں مبتلا ہو تو وہ «صَبِیٌّ» ہی ہے ۔ «صَبِیٌّ» بمعنی بچگانہ عادات اور حرکات و سکنات والا بچہ ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰیَحۡیٰی خُذِ الۡکِتٰبَ بِقُوَّۃٍ ؕ وَاٰتَیۡنٰہُ الۡحُکۡمَ صَبِیًّا» ( 19/12 )\nترجمہ : اے یحیی ؑ ! ( ہماری ) کتاب کو زور سے پکڑے رہو اور ہم نے ان کو لڑکپن ہی میں دانائی عطا فرمائی تھی ( یعنی جس عمر میں دوسرے بچے کھیل کود میں مصروف ہوتے ہیں )","«صَبِیٌّ» بچپنے کی عادات اور کھیل کود میں رہنے والا نادان بچہ ۔","لڑکا","صبی","19:12-19:29",2
414,86,"ل","غُلَامٌ","«غُلَامٌ» وہ بچہ جس میں جنسی خواہشات بیدار ہو چکی ہوں (م ۔ ل) یعنی بالغ ہو چکا ہو ۔ نوجوان ۔ اور «اِغْتَلَمَ الْفَحْلُ غُلْمَۃً» یعنی کسی نر میں جماع کی خواہش کاغلبہ پیدا ہونے کو کہتے ہیں ۔ اور «غَلِیْم» نوجوان کو اور «اِغلَام» مشت زنی کرنے کو ۔ «غُلَام» کی جمع «غِلْمَۃٌ» اور «غِلْمَانٌ» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَیَطُوۡفُ عَلَیۡہِمۡ غِلۡمَانٌ لَّہُمۡ کَاَنَّہُمۡ لُؤۡلُؤٌ مَّکۡنُوۡنٌ» ( 52/24 )\nترجمہ : اور نوجوان خدمت گار ( جو ایسے ہوں گے ) جیسے چھپائے ہوئے موتی ، اُن کے آس پاس پھریں گے ۔","«غُلَامٌ» وہ بچہ جو بالغ ہو چکا ہو ۔","لڑکا","غلم","3:40-12:19-15:53-18:74-18:80-18:82-19:7-19:8-19:19-19:20-37:101-51:28-52:24",13
415,87,"ب","دَحٰی ، طَحٰی","«دَحٰی اور طَحٰی» یہ دونوں لفظ دراصل ایک ہی معنی میں استعمال ہوتے ہیں ۔ صرف تلفظ کا فرق ہے ۔ (مف) یعنی مختلف علاقوں کی لغت ہے ۔ قرآن کریم میں یہ دونوں الفاظ صرف ایک ایک بار ہی استعمال ہوئے ہیں اور ایک ہی معنی میں آئے ہیں ۔ کہتے ہیں «دَحَی الْمَطَرُ الْحَصٰی» ۔ بارش کنکریوں کو دور دور تک بہا لے گئی اور «دَحَی الرَّجُل» کے معنی اس شخص نے ملک بھر میں ( یعنی دور دراز تک ) سفر کیا ۔ تو «دَحٰی» اور «طَحٰی» کے معنی دور تک لے جا کر بچھانا یا پھیلانا کے ہیں ۔ قرآن کریم میں «طَحٰی» کی مثال :\n(1) «وَ السَّمَآءِ وَ مَا بَنٰہَا وَ الۡاَرۡضِ وَ مَا طَحٰہَا» ( 91/5،6 )\nترجمہ : اور آسمان کی اور اس ذات کی قسم جس نے اسے بنایا اور زمین کی اور اس کی جس نے اسے پھیلایا ۔\nاسی طرح قرآن کریم میں «دَحٰی» کی مثال :\n(2) «وَالۡاَرۡضَ بَعۡدَ ذٰلِکَ دَحٰىہَا» ( 79/30 )\nترجمہ : اور اس کے بعد زمین کو پھیلا دیا ۔\nاور جدید تحقیق یہ ہے کہ «دَحٰی» کے مفہوم میں گولائی کا تصور پایا جاتا ہے ۔ «اُدْحِیَّۃُ» بمعنی ریت میں شتر مرغ کے انڈے دینے کی جگہ (منجد) اور «اُدْحِیُ النَّعَام» بمعنی ریت میں شتر مرغ کے انڈے دینے کی جگہ (مف) اور «دَحْوَۃ» شتر مرغ کے انڈے کو کہتے ہیں ۔ اور لفظ «دَحٰی» سے زمین کا گول ہونا ثابت کیا جاتا ہے ۔","«دَحٰی اور طَحٰی» کسی چیز کو اپنی جگہ سے دور تک لے جا کر پھیلا دینا ۔","بچھانا","دحی ، طحی","79:30-91:6",2
416,87,"ب","سَطَحَ","«سَطَحَ» کے بنیادی معنیٰ  پھیلانا اور پھر ہموار کرنا ہیں ۔ «سَطَحَ الْبَیْتَ» گھر کی چھت کو ہموار کرنا اور «مَسْطَحْ» ہموار کرنے کے اوزار کو کہتے ہیں ۔ مکان کے اوپر کے حصہ اور چھت کو سطح کہتے ہیں ۔ (منجد) امام راغب کے الفاظ میں «اَلسَّطْحُ اَعْلَی الْبَیْتِ جُعِلَ سَوِیًّا» (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاِلَی الۡاَرۡضِ کَیۡفَ سُطِحَتۡ» ( 88/20 )\nترجمہ : اور ( کیا وہ نہیں دیکھتے ) زمین کی طرف کہ کس طرح بچھائی گئی ( یعنی اس کا اوپر کا حصہ ہموار بنایا گیا )","«سَطَحَ» پھیلانا یا بچھانا اور پھر اسے ہموار کرنا ۔","بچھانا","سطح","88:20",1
417,87,"ب","فَرَشَ","«فَرَشَ» بمعنی کپڑا وغیرہ بچھانا ، بستر لگانا ، اور ہر وہ چیز جو بچھائی جائے اسے «فرش» اور «فِراش» ( بعمنی بچھونا ) کہتے ہیں (مف) فرش کے بنیادی معنیٰ کسی چیزکو پھیلانا  وسیع اور کشادہ کرنا ہے (م ۔ ل) یعنی کسی چیز کو پورے کا پورا پھیلا دینا اور «فَرَشَ الدَّار» بمعنی فرش لگانا ۔ اینٹ اور پتھر بچھانا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«الَّذِیۡ جَعَلَ لَکُمُ الۡاَرۡضَ فِرَاشًا وَّالسَّمَآءَ بِنَآءً» ( 2/22 )\nترجمہ : جس نے تمہارے لیے زمین کو بچھونا اور آسمان کو چھت بنایا ۔","«فَرَشَ» کسی چیز کو پورے کا پورا پھیلانا یا بچھا دینا اور ہموار کرنا ۔","بچھانا","فرش","2:22-6:142-51:48-55:54-56:34",5
418,87,"ب","مَھَدَ","صاحب منجد کے نزدیک جس طرح چھت کو پھیلانے اور ہموار کرنے کے لیے «سَطَحَ» کا لفظ آتا ہے اسی طرح زمین کو ہموار کرنے کے لیے «مَھَدَ» استعمال ہوتا ہے (منجد) لیکن «مَھْد» ماں کی گود کو بھی کہتے ہیں جس میں تربیت کا پہلو بھی شامل ہے ۔ اور «مَھَدَ الْاَرْض» کے معنی یہ ہوں گے کہ زمین کو اس طرح پھیلانا کہ اس میں رہنے والوں کو وسائل رزق بھی مناسب طور پر مہیا ہوں ۔ اور قرآن کریم سے اس بات کی تائید ہوتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّمَہَّدۡتُّ لَہٗ  تَمۡہِیۡدًا ثُمَّ  یَطۡمَعُ اَنۡ اَزِیۡدَ» ( 74/14،15 )\nترجمہ : اور میں نے اس کے لیے ہر طرح کے سامان میں وسعت دی ۔ ابھی خواہش رکھتا ہے کہ اور زیادہ دوں !\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَالۡاَرۡضَ فَرَشۡنٰہَا فَنِعۡمَ الۡمٰہِدُوۡنَ» ( 51/48 )\nترجمہ : اور زمین کو ہم ہی نے بچھایا تو ( دیکھو ) ہم کیا خوب بچھانے والے ہیں ۔\nاس آیت سے یہ بھی ثابت ہوتا ہے کہ «مَھَدَ» میں «فَرَشَ» سے زیادہ وسعت ہے ۔ یعنی ضرورت سے زیادہ متعلقہ سامان کی تیاری ۔","«مَھَدَ» بچھانے کے ساتھ اس میں سامانِ تربیت بھی فراہم کرنا ۔","بچھانا","مھد","3:46-5:110-19:29-20:53-30:44-43:10-74:14",7
419,88,"ب","مِھَاد","«مَھَدَ» کا معنی بچھانا اور اس میں سامان تربیت مہیا کرنا ہے ۔ جیسا کہ اوپر تفصیل گزر چکی ہے ۔ زمین کو اللہ تعالیٰ نے اس لحاظ سے «مِھَاد» فرمایا ہے کہ اس میں یہ دونوں باتیں پائی جاتی ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَمۡ  نَجۡعَلِ الۡاَرۡضَ مِہٰدًا» ( 78/6 )\nترجمہ : کیا ہم نے زمین کو بچھونا نہیں بنایا ؟","«مِھَاد» کنایۃً و اشارتاً زمین کو کہتے ہیں کہ وہ تمام جانوروں کے سامان تربیت کے علاوہ آرامگاہ یعنی بستر کا کام دیتی ہے ۔","بچھونا","مھاد","2:206-3:12-3:197-7:41-13:18-38:56-78:6",7
420,88,"ب","فِرَاش","«فَرَشَ» بمعنی بچھانا اور ہموار کرنا ۔ «اَلْفَرَش» اپنے اصل معنی کے لحاظ سے کپڑا بچھانے کے معنوں میں آتا ہے (مف) تاہم فرش اینٹ یا پتھر کا فرش لگوانے کے معنوں میں بھی آتا ہے جیسے «فَرَشَ الرَّجُلُ» کے معنی بچھونا بچھانا بھی ہے اور فرش بنوانا بھی (منجد) اور «فِرَاش» بچھونا یا بستر کو کہتے ہیں اور کنایۃً فراش میاں بیوی میں سے ہر ایک پر بولا جاتا ہے (مف) جیسے آنحضرت ﷺ نے فرمایا : «اَلْوَلَدُ لِلْفِرَاشِ» اور «لِلْعَاھِرِ الْحَجَر» ( لڑکا خاوند کا ہے اور زانی کے لیے رجم ہے ) قرآن کریم نے اس لفظ کو زمین کے معنوں میں بھی استعمال کیا ہے ۔ اور بچھونا یعنی بستر کے معنوں میں بھی ۔ اوراسکی جمع « فُرُشٍ» ہے\nمثلاً : قرآن کریم میں ہے :\n«مُتَّکِئِیۡنَ عَلٰی فُرُشٍۭ بَطَآئِنُہَا مِنۡ اِسۡتَبۡرَقٍ» ( 55/54 )\nترجمہ : جنتی ایسے فرشوں پر تکیہ لگائے ہوئے ہونگے جن کے استر د بیز ریشم کے ہونگے ۔","«فِرَاش» عام طور پر بستر یا بچھونا کے لیے استعمال ہوتا ہے ۔","بچھونا","فراش","2:22-6:142-51:48-55:54-56:34",5
421,88,"ب","مَضَاجِع","«مَضْجَعُ» کی جمع «مَضَاجِع» ہے ۔ «ضَجَعَ» بمعنی پہلو یا کروٹ کے بل لیٹنا ، سستانا یا آرام کرنا ۔ خواہ اونگھ یا نیند آ جائے یا نہ آئے ۔ نیم خوابی حالت (م ۔ ق) اور «اَضْجَعَہٗ» بمعنی اس نے سلا دیا (منجد) اور «مَضْجَعُ » بمعنی بستر یا بچھونا جس پر آرام کیا یا سویا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«تَتَجَافٰی جُنُوۡبُہُمۡ عَنِ الۡمَضَاجِعِ یَدۡعُوۡنَ رَبَّہُمۡ خَوۡفًا وَّ طَمَعًا» ( 32/16 )\nترجمہ : ان کے پہلو بستروں سے الگ رہتے ہیں اور وہ اپنے پروردگار کو خوف و امید سے پکارتے ہیں ۔","«مَضْجَعُ» ہر ایسی چیز جس کے ساتھ انسان ٹیک لگا کر سستا سکے یا سو سکے ۔ خواہ چارپائی اور بستر ہو یا کوئی اور چیز ۔","بچھونا","مضاجع","3:154-4:34-32:16",3
422,89,"ب","بَخِلَ","«بَخِلَ» اپنے جمع شدہ مال میں سے ایسی جگہ بھی خرچ نہ کرنا جہاں خرچ کرنا چاہیے ۔ (مف) بخل دو قسم کا ہوتا ہے (1) کسی دوسرے کے حقوق کی ادائیگی میں یا انفاق فی سبیل اللہ یعنی اللہ کے راہ میں بخل کرنا (2) اپنی جائز ضروریات پر بھی خرچ نہ کرنا ۔ یہ دونوں قسم کا بخل مذموم یعنی برا اور ناپسندیدہ کام ہے ۔ اور یہ لفظ عام ہے جو ہر طرح کے بخل پر استعمال ہو سکتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«الَّذِیۡنَ یَبۡخَلُوۡنَ وَ یَاۡمُرُوۡنَ النَّاسَ بِالۡبُخۡلِ وَیَکۡتُمُوۡنَ مَاۤ اٰتٰہُمُ اللّٰہُ مِنۡ فَضۡلِہٖ ؕ وَاَعۡتَدۡنَا لِلۡکٰفِرِیۡنَ عَذَابًا مُّہِیۡنًا» ( 4/37 )\nترجمہ : جو خود بھی بخل کریں اور دوسروں کو بھی بخل سکھائیں اور جو ( مال ) خدا نے ان کو اپنے فضل سے عطا فرمایا ہے اسے چھپا چھپا کر رکھیں ۔ اور ہم نے ایسے ناشکروں کے لیے ذلت کا عذاب تیار کر رکھا ہے ۔","«بَخِلَ» اپنے جمع شدہ مال میں سے ایسی جگہ بھی خرچ نہ کرنا جہاں خرچ کرنا چاہیے ۔","بخل","بخل","3:180-4:37-9:76-47:37-47:38-57:24-92:8",7
423,89,"ب","اَمْسَکَ","«اَمْسَکَ» کے معنی جو کچھ پاس ہو اسے ہاتھ سے نکلنے نہ دینا اور تھامے رکھنا ۔ یا کسی چیز سے چمٹ جانا اور اس کی حفاظت کرنا (مف) ۔ اور «اِمْسَاک» کے معنی بخل اور «مُمْسِک» کے بمعنی بخیل بھی آتے ہیں ( م ۔ ل )\nمثلاً : قرآن کریم میں ہے :\n«قُلۡ لَّوۡ اَنۡتُمۡ تَمۡلِکُوۡنَ خَزَآئِنَ رَحۡمَۃِ رَبِّیۡۤ اِذًالَّاَمۡسَکۡتُمۡ خَشۡیَۃَ الۡاِنۡفَاقِ» ( 17/100 )\nترجمہ : کہہ دو کہ اگر میرے رب کی رحمت کے خزانے تمہارے ہاتھ میں ہوتے تو تم خرچ ہو جانے کے خوف سے ان کو روکے رکھتے ۔","«اَمْسَکَ» جو کچھ بھی اپنے پاس ہو اسے روکے رکھنا ، بخل کے معنی میں بھی استعمال ہوتا ہے ۔","بخل","امسک","2:231-2:256-4:15-5:4-7:170-16:59-16:79-17:100-22:65-31:22-33:37-35:2-35:41-38:39-39:38-39:42-43:21-43:43-60:10-65:2-67:19-67:21",22
424,89,"ب","اَوْعٰی","«اَلْاِیْعَاء» کے معنی کسی چیز ( مال وغیرہ ) کو تھیلی میں سنبھال کر اوپر سے منہ بند کر دینا (مف) صاحب منجد کے نذدیک یہ تینوں معنوں میں استعمال ہوتا ہے (1) کسی چیز کو یاد رکھنا (2) جمع کرنا اور (3) بخل کرنا (منجد) اور ابن الفارس کے نزدیک اس کا بنیادی معنیٰ صرف منہ بند کرنا ہے (م ۔ ل) اور «وِعَاء» ہر ایسے سامان کو کہتے ہیں جس کا منہ بند کر دیا جائے یا مقفّل کر دیا جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«تَدۡعُوۡا مَنۡ اَدۡبَرَوَ تَوَلّٰی وَ جَمَعَ فَاَوۡعٰی» (70/17،18 )\nترجمہ : ان لوگوں کو ( دوزخ ) اپنی طرف بلائے گی جنھوں نے ( دین حق سے ) اعراض کیا اور منہ پھیر لیا اور مال جمع کیا اور بند رکھا ۔\nاور «اُذُنٌ وَّاعِیَۃٌ» ( 69/12 ) بمعنی کسی بات کو دھیان سے سننے اور یاد رکھنے والے کان اور مراد اس سے ایسے آدمی ہیں جو کسی بات کو خوب غور سے سنیں پھر اس کو خوب یاد رکھیں اور اس بات کے الفاظ یا مفہوم میں کسی قسم کی کمی بیشی نہ ہونے دیں ۔ جیسا کہ رسول اللہ نے اپنے مشہور خطبہ حجۃ الوداع میں ، جو آپ نے اونٹنی پر سوار ہو منیٰ کے مقام پر دیا تھا ، فرمایا :\nنَضَّرَ اللہُ عَبْدًا سَمِعَ مَقَالَتِیْ فَوَعَاھَا ثُمَّ اَدَّاھَا وَبَلَّغَھَا ۔ ( ترمذی )\nترجمہ : اللہ تعالیٰ اس بندے کو خوشحال رکھے جس نے میری احادیث کو سنا ۔ پھر ان کو یاد رکھا پھر دوسروں تک پہنچا دیا ۔\nگویا «وعٰی» کا لفظ صرف اموال کے لیے نہیں بلکہ ہر قابل حفاظت چیز کے لیے عام  ہے ۔","«اَوْعٰی» سنبھالنا اور کمی نہ ہونے دینا ، ہر قابلِ حفاظت چیز کے لیے استعمال ہوتا ہے ۔","بخل","اوعی","69:12-70:18",2
425,89,"ب","اَکْدٰی","«کُدْیَۃٌ» سخت زمین کو کہتے ہیں ۔ اور «حَفَرَ فَاَکْدٰی» کے معنی ہیں وہ گڑھا کھودتے کھودتے سخت زمین تک جا پہنچا ( مف ۔ فل 262 ) اور جب نسبت مال خرچ کرنے کی طرف ہو تو «اَکْدٰی» کے معنی ہوگا تھوڑا سا خرچ کر کے ہاتھ روک لینا ۔ یا خرچ کرنے کا ارادہ کر کے پھر رک جانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَفَرَءَیۡتَ الَّذِیۡ تَوَلّٰی وَاَعۡطٰی قَلِیۡلًا وَّاَکۡدٰی» ( 53/33،34 )\nترجمہ : بھلا تم نے اس شخص کو دیکھا جس نے منہ پھیر لیا اور تھوڑا سا دیا پھر ہاتھ روک لیا ۔","«اَکْدٰی» تھوڑا سا خرچ کرنے کے بعد رک جانا یا ارادہ کر کے پورا نہ کرنا ۔","بخل","اکدی","7:58-53:34",2
426,89,"ب","اَقْتَرَ","«قَتَرَ» کے معنی بہت کم خرچ کرنا ہے ۔ (مف) اور «اِقْتَار» ، اسراف کی ضد ہے ۔ یعنی اپنی جائز ضروریات پر بھی ضرورت سے کم خرچ کرنا اور کنجوسی کرنا ۔ صاحب منتہی الارب کے نزدیک اس کے معنی ’’ وہ شخص جس نے اپنے اہل و عیال پر نفقہ تنگ کر رکھا ہو ۔ (م ۔ ر) اللہ تعالیٰ اپنے بندوں کی صفات بیان کرتے ہوئے فرماتے ہیں :\nارشاد باری تعالیٰ ہے :\n«وَالَّذِیۡنَ اِذَاۤ اَنۡفَقُوۡا لَمۡ یُسۡرِفُوۡاوَلَمۡ یَقۡتُرُوۡا وَکَانَ بَیۡنَ ذٰلِکَ قَوَامًا» ( 25/67 )\nترجمہ : اور وہ کہ جب خرچ کرتے ہیں تو نہ بیجا اڑاتے ہیں اور نہ کنجوسی کرتے ہیں بلکہ اعتدال کے ساتھ نہ ضرورت سے زیادہ نہ کم ۔","«اَقْتَرَ» اپنے اہل و عیال کے نان و نفقہ میں بخل کرنا یا اپنی ذات پر خرچ کرنے میں بھی کنجوسی کرنا ۔","بخل","اقتر","2:236-25:67",2
427,89,"ب","ضَنَّ","«ضَنَّ» کسی پسندیدہ اور مرغوب چیز کے دینے میں بخل کرنا ۔ (مف) اور «اَلضَّنَائِن» وہ چیزیں ہیں جن کی نفاست کی وجہ سے بخل کیا جائے (منجد) جیسے کوئی حکیم اپنے مجرب نسخے بتانے میں بخل کرتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ مَا ہُوَ عَلَی الۡغَیۡبِ بِضَنِیۡنٍ» ( 81/24 )\nترجمہ : اور وہ ( حضور اکرم ﷺ ) پوشیدہ باتوں ( کے ظاہر کرنے ) میں بخیل نہیں ۔","«ضَنَّ» کسی پسندیدہ اور مرغوب چیز کے دینے میں بخل کرنا ۔","بخل","ضن","20:124-81:24",2
428,89,"ب","شُحَّ","«شُحَّ» کے معنی بخل کرنا ۔ حرص و لالچ کرنا (منجد) جب بخل اور حرص دونوں چیزیں جمع ہو جائیں تو اسے «شُحَّ» کہتے ہیں ( فل 33 ، م ل ) اور اسی کا دوسرا نام شدت حرص ہے ۔ بمعنی ہر وقت مال و دولت سمیٹنے کی فکر میں رہنا اور خرچ کرنے میں بخل کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ مَنۡ یُّوۡقَ شُحَّ نَفۡسِہٖ  فَاُولٰٓئِکَ ہُمُ  الۡمُفۡلِحُوۡنَ» ( 59/9 )\nترجمہ : اور جو شخص حرص نفس سے بچا لیا گیا تو ایسے ہی لوگ مراد پانے والے ہیں ۔\nاور «شَحِیْحٌ» کے معنی بخیل اور حریص آدمی اور اس کی جمع «شِحَاحٌ» اور «اَشِحَّۃٌ» آتی ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«فَاِذَا ذَہَبَ الۡخَوۡفُ سَلَقُوۡکُمۡ بِاَلۡسِنَۃٍ حِدَادٍ  اَشِحَّۃً عَلَی الۡخَیۡرِ» ( 33/19 )\nترجمہ : پھر جب خوف جاتا رہے تو تیز زبانوں کے ساتھ تمہارے بارے میں زبان درازی کریں اور مال میں بخل کریں ( جالندھریؒ ) ڈھکے پڑتے ہیں مال پر ( عثمانیؒ )","«شُحَّ» جب بخل اور حرص دونوں چیزیں جمع ہو جائیں تو اسے «شُحَّ» کہتے ہیں ۔","بخل","شح","4:128-33:19-59:9-64:16",4
429,89,"ب","غُلَّ","«غُلٌّ» کے بنیادی معنی اس طرح کی خیانت ہے کہ اپنے زیرِ تصّرف کوئی چیز جو اپنی ملکیت نہ ہو اٹھا کر چپکے سے اپنے سامان میں رکھ لی جائے جیسے غنیمت کے مشترکہ مال سے کوئی چیز اٹھا کر اپنی ملکیت میں کر لینا ۔ اور «غُلٌّ» بمعنی طوق ہتھکڑی یا بیڑی یعنی ہر وہ چیز جس سے کسی کے اعضاء کو جکڑ کر درمیان میں باندھ دیا جاتا ہے اور اس کی جمع اغلال ہے ۔ اسی نسبت سے کنایۃً «مَغْلُولُ الْیَد» کنجوس شخص کو بھی کہہ دیتے ہیں جس کے ہاتھ بندھے ہوئے ہوں اور وہ کچھ خرچ نہیں کر سکتا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَقَالَتِ الۡیَہُوۡدُ یَدُ اللّٰہِ مَغۡلُوۡلَۃٌ ؕ غُلَّتۡ اَیۡدِیۡہِمۡ» ( 5/64 )\nترجمہ : اور یہودی کہتے ہیں کہ : اللہ کے ہاتھ بندے ہوئے ہیں ہاتھ تو خود ان کے بندھے ہوئے ہیں ۔","«غُلٌّ» قیدی یا مجرم کے ہاتھ کی بیڑی یا گلے میں پڑا ہوا لوہے کا طوق اور عربی محاورہ ہے «مَغْلُولُ الْیَد» بخیل اور کنجوس آدمی کو کہتے ہیں جودوسروں کو کچھ نہ دے ۔","بخل","غل","3:161-5:64-17:29",3
430,90,"ب","شِقْوَۃ","«شِقْوَۃ» اور «شِقَاوَۃ» دونوں کے معنی بدبختی ہے  اور اسکی ضد «سَعَادَۃ»  ہے اور جس طرح «سَعَادَۃ» امور اضافیہ (یعنی اضافی خصوصیات) میں سے ہے ۔ اسی طرح «شِقَاوَۃ» اور «شِقْوَۃ» بھی امور اضافیہ میں سے ہے اور «شَقِی» وہ شخص ہے جو فطرتًا ہی بدبخت یا بد نصیب ہو (مف)\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا رَبَّنَا غَلَبَتۡ عَلَیۡنَا شِقۡوَتُنَا وَ کُنَّا قَوۡمًا ضَآلِّیۡنَ» ( 23/106 )\nترجمہ : کافر کہیں گے اے ہمارے پروردگار ! ہماری بدبختی ہم پرغالب آ گئی اور ہم رستے سے بھٹک گئے ۔","«شِقْوَۃ» ایسا شخص جو فطرتًا ہی بدبخت یا بدنصیب ہو اور بدبختی اسکا حقِ مقدرہو ۔","بدبختی","شقوۃ","11:105-11:106-19:4-19:32-19:48-23:106-87:11-91:12-92:15",9
431,90,"ب","نَحُوْسَۃ","«نُحَاس» کے معنی تانبہ بھی ہے اور آگ کی ایسی لپٹ بھی جس کا رنگ تانبے جیسا ہو ۔ اور «نَحَسَ» کے معنی آسمان کا سرخ ہو کر تانبے کی رنگت جیسا ہو جانا ہے اور یہ نحوست کے لیے ضرب المثل ہے ۔ اور «نَحُسَ» اور «نَحُوْسَۃ» بمعنی سختی اور بدبختی کا زمانہ ۔ «نَحَس» کی ضد «سَعْد» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَرۡسَلۡنَا عَلَیۡہِمۡ رِیۡحًا صَرۡصَرًا فِیۡۤ اَیَّامٍ نَّحِسَاتٍ» ( 41/16 )\nترجمہ : ہم نے ان پر نحوست کے دنوں میں زور کی ٹھنڈی ہوا چلائی ۔","«نَحُوْسَۃ» بمعنی بدبختی اورسختی کا زمانہ ۔","بدبختی","نحوسۃ","41:16-54:19",2
432,90,"ب","طآئر","«طَارَ» بمعنی پرندہ وغیرہ کا ہوا میں اڑنا اور «طَائِر» کی جمع «طَیْر» ہے  بمعنی پرندہ ۔ چونکہ پرندوں سے فال لینے کا رواج عام تھا ۔ لہذا «طَائِر» کا لفظ فال یا شگون لینے کے معنوں میں بھی استعمال ہونے لگا ۔ اس لفظ کا استعمال عمومًا برے معنوں میں ہوتا ہے ۔ «اِطَّیَّرَ» اور «تَطَیَّرَ» کے معنی بد فالی یا برا شگون لینا ہے اور اسکی ضد «تَیَمَّنَ» اور «تَبَرَّک» آتی ہے گویا «طَائِر» کا اصل معنی بدبختی نہیں بلکہ بدبختی کی فال لینا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡۤا اِنَّا تَطَیَّرۡنَا بِکُمۡ» ( 36/18 )\nترجمہ : کافروں نے رسولوں سے کہا کہ ہم تمہیں نامبارک سمجھتے ہیں ۔\nتو ان پیغمبروں نے یہ جواب دیا کہ :\n«قَالُوۡا طَآئِرُکُمۡ مَّعَکُمۡ» ( 36/19 )\nترجمہ : پیغمبر کہنے لگے کہ تمہاری بدبختی تو تمہارے ساتھ ہے ۔","«طَائِر» کسی کے متعلق بدبختی کی فال لینا ۔ یا  بدشگونی کرنا ۔","بدبختی","طآئر","2:260-3:49-5:110-6:38-7:131-12:36-12:41-16:79-17:13-21:79-22:31-24:41-27:16-27:17-27:20-27:47-34:10-36:18-36:19-38:19-56:21-67:19-105:3",23
433,90,"ب","شَئُوْم","«الشَّأمَۃَ الْمَشْئَمَۃ» بمعنی نحوست ۔ بے برکتی اور بایاں پہلو (یعنی بائیں طرف) (منجد) اور بایاں پہلو بھی نحوست کی علامت سمجھی جاتی ہے ۔ اور شامت دراصل ایسی بدشگونی کو کہتے ہیں جو اپنے اعمال کے نتیجہ میں متوقع ہو ۔ شامتِ اعمال مشہور لفظ ہے اور «تَشَاءُم» بمعنی بری فال لینا  اور اسکی ضد «تَیَمُّن» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ کَانَ مِنَ الَّذِیۡنَ اٰمَنُوۡا وَتَوَاصَوۡا بِالصَّبۡرِ وَتَوَاصَوۡا بِالۡمَرۡحَمَۃِ اُولٰٓئِکَ اَصۡحٰبُ الۡمَیۡمَنَۃِ وَالَّذِیۡنَ کَفَرُوۡا بِاٰیٰتِنَا ہُمۡ اَصۡحٰبُ الۡمَشۡئَمَۃِ» ( 90/17،18،19 )\nترجمہ : پھر ان لوگوں میں داخل ہوا جو ایمان لائے اور صبر کی تلقین اور لوگوں پر شفقت کرنے کی وصیت کرتے رہے یہی لوگ صاحب سعادت ہیں اور جنھوں نے ہماری آیتوں کو نہ مانا ، یہی لوگ بدبخت ہیں ۔","«شَئُوْم ۔ شَامَۃ» ایسی بدبختی جو اپنے اعمال کے نتیجہ میں متوقع ہو ۔","بدبختی","شئوم","56:9-90:19",2
434,90,"ب","حُسُوْم","«اَلْحَسَمَ»  بمعنی چیز کو کاٹنا اور اس کے نام و نشان تک کو مٹا دینا اور زائل کر دینا ۔ اور «حُسَام» بمعنی تلوار ۔ پھر «حُسُومُ » ایسی نحوست یا عذاب کو بھی کہتے ہیں کہ انسان کا نام و نشان تک مٹا ڈالے (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاَمَّا عَادٌ فَاُہۡلِکُوۡا بِرِیۡحٍ صَرۡصَرٍعَاتِیَۃٍ سَخَّرَہَا عَلَیۡہِمۡ سَبۡعَ لَیَالٍ وَّثَمٰنِیَۃَ اَیَّامٍ ۙ حُسُوۡمًا ۙ فَتَرَی الۡقَوۡمَ فِیۡہَا صَرۡعٰی ۙ کَاَنَّہُمۡ اَعۡجَازُنَخۡلٍ خَاوِیَۃٍ» ( 69/6،7 )\nترجمہ : رہے عاد تو ان کا نہایت تیز آندھی سے ستیا ناس کر دیا گیا َ خدا نے اس ہوا کو سات دن اور آٹھ راتیں لگاتار چلائے رکھا ۔ تو تو دیکھے انہیں بچھڑے ہوئے ، گویا وہ ہیں کھجوروں کی کھوکھلی جڑیں ۔","«حُسُوْم» ایسی بدبختی جو ملیا میٹ کر دے ۔","بدبختی","حسوم","69:7",1
435,91,"ب","لَعَنَ","«لَعَنَ» بمعنی کسی کو ناراضگی کی بناء پر اپنے سے دور کرنا اور دھتکارنا ہے ۔ اور جب اس کی نسبت اللہ تعالیٰ کی طرف ہو تو اس کا مطلب اللہ کی رحمت اور توفیق سے دور ہونا ہے (مف) اور نیز بمعنی گالی دینا نیکی سے دور کرنا اور دھتکارنا (منجد) اور لعنت بد دعا کے لیے عام اور جامع لفظ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«لُعِنَ الَّذِیۡنَ کَفَرُوۡا مِنۡۢ بَنِیۡۤ اِسۡرَآءِیۡلَ عَلٰی لِسَانِ دَاوٗدَ وَعِیۡسَی ابۡنِ مَرۡیَمَ» ( 5/78 )\nترجمہ : جو لوگ بنی اسرائیل سے کافر ہوئے ان پر داؤد اور عیسیٰ بن مریم علیہم السلام کی زبان سے لعنت کی گئی ۔","«لَعَنَ» خدا کی رحمت اور توفیق سے دوری کی بد دعا ۔","بددعا ","لعن","2:88-2:89-2:159-2:161-3:61-3:87-4:46-4:47-4:52-4:93-4:118-5:13-5:60-5:64-5:78-7:38-7:44-9:68-11:18-11:60-11:99-13:25-15:35-24:7-24:23-28:42-29:25-33:57-33:64-33:68-38:78-40:52-47:23-48:6",34
436,91,"ب","بَعِدَ ، بَعُدًا","«بُعْدًا» بمعنی دور ہونا ، ہلاک ہونا ، مرنا ۔ اور «بُعْدًا» بد دعا کا کلمہ ہے یعنی اللہ اس کو ہلاک کرے یا اپنی رحمت سے دور کرے (منجد)\nمثلاً : قرآن کریم میں ہے :\n«اَلَا بُعۡدًا لِّمَدۡیَنَ کَمَا بَعِدَتۡ ثَمُوۡدُ» ( 11/95 )\nترجمہ : سن رکھو کہ مدین پر بھی ( ویسی ہی ) پھٹکار ہے ۔ جیسے ثمود پر تھی ۔","«بَعِدَ» رحمت سے دوری اور ہلاکت کی بد دعا ۔","بددعا ","بعد ، بعدًا","9:42-11:44-11:60-11:68-11:95-21:101-23:41-23:44-43:38",9
437,91,"ب","سُحْقًا","«سَحَقَ» بمعنی دوا وغیرہ کو پیسنا ہے ۔ اور «اَسْحَقَ الثَّوْب» بمعنی کپڑے کا پرانا ہونا اور «اَسْحَقَہُ اللہ» کے معنی اللہ اسے ہلاک کرے (مف) نیز «سَحِقَ سُحْقًا» بمعنی دور ہونا اور «اِسْتَحَقَ» بمعنی دور کرنا (منجد) گویا یہ بھی بد دعا کا کلمہ ہے اور اس کا معنی بھلائی سے دوری ہے مگر اس میں «بُعْدًا» سے زیادہ شدت پائی جاتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاعۡتَرَفُوۡا بِذَنۡۢبِہِمۡ ۚ فَسُحۡقًا لِّاَصۡحٰبِ السَّعِیۡرِ» ( 67/11 )\nترجمہ : پس وہ اپنے گناہوں کا اقرار کر لیں گے ۔ سو دوزخیوں کے لیے ( خدا کی رحمت سے ) دوری ہے ( جالندھریؒ )","«سُحْقًا» بددعا کے لیے استعمال ہوتا ہے ۔ اس کے مفہوم میں «بُعْدًا» سے زیادہ شدت پائی جاتی ہے ۔","بددعا ","سحقًا","67:11",1
438,91,"ب","اِبْتَھَل","«اَبْھَلْتُ فُلَانًا» محاورۃً استعمال ہوتا ہے اور اس کا معنیٰ ہے کسی کو اس کی رائے اور ارادہ میں آزاد چھوڑ دینا اور «الْبَھْلُ وَالْاِبَتِھَالُ فِی الدُّعَاءِ» کے معنی دعا میں پوری آزادی اور عاجزی سے دعا کرنا (مف) پھر چونکہ آیت مباہلہ میں اللہ کی لعنت کا ذکر ہے ۔ اس لیے مباہلہ کا لفظ ایک دوسرے پر لعنت بھیجنے کے معنوں میں مشہور ہوگیا گویا اس کا استعمال بھی برے مفہوم میں ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ نَبۡتَہِلۡ فَنَجۡعَلۡ لَّعۡنَتَ اللّٰہِ عَلَی الۡکٰذِبِیۡنَ» ( 3/61 )\nترجمہ : پھر ہم دونوں فریق خدا سے دعا و التجا کریں اور جھوٹوں پر خدا کی لعنت بھیجیں ۔","«اِبْتِھَال» فریقین کا ایک دوسرے پر لعنت کے لیے مکمل آزادی سے دعا و التجا کرنا ۔","بددعا ","ابتھل","3:61",1
439,92,"ب","مَسَخَ","«مَسَخَ» بمعنی شکل و صورت کو بگاڑ دینا اور خراب کر دینا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَلَوۡ نَشَآءُ لَمَسَخۡنٰہُمۡ عَلٰی مَکَانَتِہِمۡ فَمَا اسۡتَطَاعُوۡا مُضِیًّا وَّلَا یَرۡجِعُوۡنَ» ( 36/67 )\nترجمہ : اگر ہم چاہیں تو ان کی جگہ پر ان کی صورتیں بدل دیں ۔ پھر وہاں سے نہ آگے جا سکیں اور نہ پیچھے لوٹ سکیں ۔","«مَسَخَ» اچھی شکل و صورت کو بگاڑنے اور بری بنانے کے لیے استعمال ہوتا ہے ۔","بدصورت","مسخ","36:67",1
440,92,"ب","کَلَحَ","«کَلَحَۃ» بمعنی منہ اور اس کے آس پاس کا حصہ اور «كَالِحُ» وہ شخص جس کے ہونٹ آپس میں ملیں نہیں بلکہ کھلے رہتے ہوں اور «کَلَحَ ، کَلَّحَ» بمعنی تیوری چڑھا ہوا ہونا (یعنی ناک منہ چڑھانا) اور «اِکْلَوَّحَ» بمعنی تیوری چڑھانے میں دانت نکالنا (منجد) اور صاحب فِقْہُ اللُّغَۃ کے نزدیک یہ تیوری چڑھانے کا انتہائی درجہ ہے ( دیکھئے تیوری چڑھانا ) جس میں انسان کا حلیہ بگڑ جاتا ہے اور دانت نکلے ہونے کی وجہ سے بڑا بد صورت دکھائی دیتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«تَلۡفَحُ وُجُوۡہَہُمُ النَّارُ وَہُمۡ فِیۡہَا کٰلِحُوۡنَ» ( 23/104 )\nترجمہ : آگ ان کے چہروں کو جھلس دے گی اور وہ اس ( دوزخ ) میں بدشکل ہو رہے ہوں گے ۔","«کَلَحَ» کسی عارضہ ، تکلیف یا جذبات کی وجہ سے عارضی طور پر شکل کے خراب ہونے کے لیے استعمال ہوتا ہے ۔","بدصورت","کلح","23:104",1
441,92,"ب","قَبُحَ","«قَبُحَ» بمعنی بد صورت ہونا ۔ بدنما ہونا اور «قَبِیْح» بمعنی برا ، بدنما ، بدشکل اور «قَبُحَ» کا لفظ معنوی طور پر بھی استعمال ہوتا ہے بمعنی قول یا فعل یا شکل کا برا ہونا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَیَوۡمَ الۡقِیٰمَۃِ ہُمۡ مِّنَ الۡمَقۡبُوۡحِیۡنَ» ( 28/42 )\nترجمہ : اور وہ قیامت کے روز بھی بد حالوں سے ہوں گے ۔\nاس آیت میں «مَقْبُوحِیْن» دونوں معنی دے رہا ہے ۔","«قَبُحَ» پیدائشی طور پر بری شکل و صورت ہونا اور بری صفات کے لیے بھی استعمال ہوتا ہے ۔","بدصورت","قبح","28:42",1
442,93,"ب","زِنَا","«زِنَا» معروف لفظ ہے ۔ یعنی کسی مرد کا غیرعورت سے یا عورت کا اپنے مرد کے علاوہ کسی دوسرے سے بدفعلی کرنا زنا کہلاتا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تَقۡرَبُوا الزِّنٰۤی اِنَّہٗ کَانَ فَاحِشَۃً ؕ وَسَآءَ سَبِیۡلًا» ( 17/32 )\nترجمہ : اور زنا کے پاس بھی نہ جانا کہ وہ بے حیائی اور بری راہ ہے ۔","«زِنَا» معروف لفظ ہے ۔ غیر مرد اور غیر عورت کا آپس میں بدفعلی کرنا ۔","بدکاری","زنا","17:32-24:2-24:3",3
443,93,"ب","بِغَاء","«بَغِیَ» کے معنی حد سے تجاوز کرنا ۔ نافرمانی کرنا ، زیادتی و ظلم کرنا ہیں اور «بَاغَتِ الْاَمَۃُ بِغَآءً» کے معنی لونڈی کا زنا کرنا ہے اور «بَغِیّ» کے معنی زنا کار فاحشہ عورت کے ہیں (منجد) یعنی «بِغَاء» کا لفظ یا تو لونڈی کے زنا کرنے سے مخصوص ہے یا پھر پیشہ ور بدکار عورت یعنی کنجری کے لیے خاص ہے جو لوگوں میں زانیہ مشہور ہو چکی ہو ۔ قرآن ان دونوں معنوں کی تائید کرتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تُکۡرِہُوۡا فَتَیٰتِکُمۡ عَلَی الۡبِغَآءِ» ( 24/33 )\nترجمہ : اور اپنی لونڈیوں کو بدکاری پر مجبور نہ کرنا ۔\nقرآن کریم کے ایک دوسرے مقام پر یہود حضرت مریم ؑ کو مخاطب کرتے ہوئے کہتے ہیں :\n«یٰۤاُخۡتَ ہٰرُوۡنَ مَا کَانَ  اَبُوۡکِ امۡرَ اَ سَوۡءٍ وَّ مَا  کَانَتۡ  اُمُّکِ  بَغِیًّا» ( 19/28 )\nترجمہ : اے ہارون کی بہن ، نہ تو تیرا باپ ہی بد اطوار آدمی تھا اور نہ تیری ماں ہی بدکار تھی ۔","«بِغَاء» لونڈی کا بدکاری کرنا یا پیشہ ورعورت کا زنا کو پیشہ بنانا ۔","بدکاری","بغاء","2:90-2:213-3:19-6:146-7:33-10:23-10:90-16:90-19:20-19:28-22:60-24:33-38:24-42:14-42:39-45:17-49:9-55:20",18
444,93,"ب","سَافَحَ","«سَفَحَ» کے معنی خون یا پانی بہانا اور «سَافَحَ» کے معنی زنا کرنا ہیں (منجد) اور ابن الفارس کے الفاظ میں «صَبَّ الْمَاء بِلَا عَقْدِ نِکَاحٍ» یعنی عقد نکاح کے بغیر زنا کرنا ۔ گویا زنا اور «سَافَحَ» میں فرق یہ ہے کہ اس میں تکرار پایا جاتا ہے ۔ اور قرآن کریم نے «مُحْصِنِیْن» کے مقابلے میں «مُسَافِحِیْن» کا لفظ استعمال کر کے اس کی تائید کر دی ہے ۔ تو «سَافَحَ» کے معنی ہماری زبان میں ’’ بطور داشتہ رکھنا ‘‘ ہیں (یعنی ایسی عورت جس کے ساتھ بغیر نکاح کے جنسی تعلق قائم کر لیا جائے ) اور «مُسَافِح» بمعنی ایسی عورت اور مرد ہیں ۔ جن کے آپس میں علانیہ تعلقات قائم ہوں ۔ آشنا کا لفظ بھی آج کل اسی معنی میں استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَانۡکِحُوۡہُنَّ بِاِذۡنِ اَہۡلِہِنَّ وَ اٰتُوۡہُنَّ اُجُوۡرَہُنَّ بِالۡمَعۡرُوۡفِ مُحۡصَنٰتٍ غَیۡرَ مُسٰفِحٰتٍ وَّ لَا مُتَّخِذٰتِ اَخۡدَانٍ» ( 4/25 )\nترجمہ : تو ان کے ساتھ ان کے مالکوں سے اجازت حاصل کر کے نکاح کر لو ۔ اور دستور کے مطابق ان کا مہر بھی ادا کرو ۔ بشرطیکہ عفیفہ ہوں نہ ایسی کہ کھلم کھلا بدکاری کریں اور نہ در پردہ دوستی کرنا چاہیں ۔","«سَافَحَ» غیر مرد اور غیرعورت کا بدکاری کے تعلقات اعلانیہ طور پر رکھنا ۔","بدکاری","سافح","4:24-4:25-5:5",3
445,93,"ب","فَاحِشَۃ","«فَحَشَ» کے معنی ہر وہ قول یا فعل ہے جو قباحت (خرابی) اور برائی میں حد سے بڑھا ہوا ہو (مف م ل) اور فاحشہ سے مراد ایسے اقوال و افعال ہیں جو زنا کے قریب لے جاتے ہیں یعنی بے حیائی کے کام اور باتیں اور ان معنوں میں یہ لفظ قرآن کریم میں بارہا استعمال ہوا ہے اور زنا کے لیے «فَاحِشَۃٍ مُبَیِّنَۃ» کا لفظ استعمال ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تَعۡضُلُوۡہُنَّ لِتَذۡہَبُوۡا بِبَعۡضِ مَاۤ اٰتَیۡتُمُوۡہُنَّ اِلَّاۤ اَنۡ یَّاۡتِیۡنَ بِفَاحِشَۃٍ مُّبَیِّنَۃٍ» ( 4/19 )\nترجمہ : اور اس نیت سے کہ جو کچھ تم نے ان کو دیا ہے اس میں سے کچھ لے لو انہیں ( گھروں میں ) مت روکنا مگر یہ کہ وہ کھلے طور پر بدکاری کی مرتکب ہوں ۔\nاور فاحشہ کا لفظ ایسی بدکاری کے لیے استعمال ہوتا ہے جسکا ثبوت ابھی موجود نہ ہو۔\nمثلاً : قرآن کریم میں ہے :\n«وَالّٰتِیۡ یَاۡتِیۡنَ الۡفَاحِشَۃَ مِنۡ نِّسَآئِکُمۡ فَاسۡتَشۡہِدُوۡا عَلَیۡہِنَّ اَرۡبَعَۃً مِّنۡکُمۡ» ( 4/15 )\nترجمہ : مسلمانو ! تمہاری عورتوں میں سے جو بدکاری کا ارتکاب کر بیٹھیں ان پر اپنے لوگوں میں سے چار شخصوں کی شہادت لو ۔","«فَاحِشَۃ» زنا کے قریب لے جانے والے کاموں اور باتوں  کے لیے استعمال ہوتا ہے ۔ یا اُس زنا کے الزام کے لیے آتا ہے جو ثبوت کا محتاج ہو ۔","بدکاری","فاحشۃ","2:169-2:268-3:135-4:15-4:19-4:22-4:25-6:151-7:28-7:33-7:80-12:24-16:90-17:32-24:19-24:21-27:54-29:28-29:45-33:30-42:37-53:32-65:1",23
446,94,"ب","بَدَّل","«بَدَلَ» معروف لفظ ہے ۔ یعنی ایک چیز کے عوض کوئی چیز اور «بدَّل» سے مراد کسی چیز کے بدلے دوسری چیز لے آنا (مف) گویا مقصود پہلی چیز تھی مگراس کی جگہ کوئی دوسری چیزآگئی ۔","«بَدَّلَ» ایک چیز کو ختم  کرکے اس کی جگہ دوسری چیزلانا ۔","بدل","بدل","2:59-2:61-2:108-2:181-2:211-4:2-4:56-6:34-6:115-7:95-7:162-9:39-10:15-14:28-14:48-16:101-18:27-18:81-24:55-25:70-27:11-33:23-33:52-34:16-40:26-47:38-48:15-50:29-56:61-66:5-68:32-70:41-76:28",33
447,94,"ب","حَوَّلَ","«حَوَّل» کے معنی کسی چیز کو اصلی جگہ سے ہٹا کر کسی دوسری جگہ رکھ دینا ۔ اور ابن فارس کے نزدیک اسکا معنی «تَحَرُّک فَی دَوْر» یعنی چکر میں حرکت کرنا ہے ۔(م ل) اور کسی چیز کے اردگرد (یعنی اطراف) کو اس کا «حَوْل» کہتے ہیں ۔ گویا «حَوَّل» میں کوئی چیز مقصود نہیں ہوتی بلکہ وہ اپنے اصل مقام سے ہٹ جاتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَہَلۡ یَنۡظُرُوۡنَ اِلَّا سُنَّتَ الۡاَوَّلِیۡنَ ۚ فَلَنۡ تَجِدَ لِسُنَّتِ اللّٰہِ تَبۡدِیۡلًا  ۚ وَ لَنۡ تَجِدَ لِسُنَّتِ اللّٰہِ تَحۡوِیۡلًا» ( 35/43 )\nترجمہ : یہ اگلے لوگوں کی روش کےسوا کسی اور چیز کے منتظر نہیں سو تم خدا کے دستور میں نہ تو تبدیلی پاؤ گے نہ اُسے ٹلتا پاؤ گے ( عثمانیؒ )\nاور خدا کا دستور یہ ہے کہ مجرم قوموں کو ہلاک کر دیا جاتا ہے ۔ آیت بالا میں خدا کے دستور میں ’’ تبدیل ‘‘ کا مطلب یہ ہے کہ یہ کبھی نہیں ہو سکتا ۔ مجرم قوم پر سزا کی بجائے انعامات ہونے لگیں اور ’’ تحویل ‘‘ کا مطلب یہ ہے کہ جرم تو کسی کا ہو اور اس کی سزا دوسرے کو ملے ۔","«حَوَّل» کے معنی کسی چیز کو اصلی جگہ سے ہٹا کر کسی دوسری جگہ رکھ دینا ۔","بدل","حول","3:159-6:92-9:101-9:120-17:1-17:56-17:77-19:68-26:25-26:34-27:8-29:67-35:43-39:75-40:7-42:7-46:27",17
448,94,"ب","غَیَّرَ","«غَیْر» کے معنی سوا ۔ کوئی دوسرا اور «غیَّرَ» سے مراد حالت کی تبدیلی ہے ۔ «غَیَّرَ» میں کوئی چیز نہ مقصود ہوتی ہے اور نہ اپنی جگہ سے ٹلتی ہے بلکہ اس حالت یا صورت میں تبدیلی واقع ہوتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ اللّٰہَ لَا یُغَیِّرُ مَا بِقَوۡمٍ حَتّٰی یُغَیِّرُوۡا مَا بِاَنۡفُسِہِمۡ» ( 13/11 )\nترجمہ : یقین جانو کہ اللہ کسی قوم کی حالت اس وقت تک نہیں بدلتا جب تک وہ خود اپنے حالات میں تبدیلی نہ لے آئے ۔\nاور اسی آیت کا ترجمہ کسی شاعر نے یوں کیا ہے :\n’’ خدا نے آج تک اس قوم کی حالت نہیں بدلی\nنہ ہو جس کو خیال آپ اپنی حالت کے بدلنے کا ‘‘\nایک دوسرے مقام پر شیطان اللہ تعالیٰ کو یوں جواب دیتا ہے :\n«وَّ لَاُضِلَّنَّہُمۡ وَ لَاُمَنِّیَنَّہُمۡ وَ لَاٰمُرَنَّہُمۡ فَلَیُبَتِّکُنَّ اٰذَانَ الۡاَنۡعَامِ وَ لَاٰمُرَنَّہُمۡ فَلَیُغَیِّرُنَّ خَلۡقَ اللّٰہِ» ( 4/119 )\nترجمہ : اور میں ( بنی آدم کو ) گمراہ کرتا اور امیدیں دلاتا رہوں گا اور یہ سکھاتا رہوں گا کہ جانوروں کے کان چیرتے رہیں اور ( یہ بھی ) کہتا رہوں گا کہ وہ خدا کی بنی ہوئی صورتوں کو بدلتے رہیں ۔","«تَغْیِیْر» کسی چیز کی حالت یا صورت میں تبدیلی لانا ۔","بدل","غیر","4:119-8:53-13:11-47:15",4
449,94,"ب","حَرّف","«حَرَف» کے بنیادی معنی کسی چیز کے کنارا کے ہیں اور «حَرَّفَ» کے معنی اس کنارہ کو موڑ دینا ( مف ۔ م ل ) اور حرف کی جمع حروف اور «حُرُوْفُ الْکَلَام» سے مراد حروف تہجی ہیں ۔ اور «تَحْرِیْفُ الْکَلَم» یہ ہے کہ عبارت کے کچھ الفاظ کو سیاق و سباق (یعنی آگے پِیچھے کی عبارت) کا خیال نہ رکھ کر اصل مقام کے بجائے دوسرے مقام پر لگا دینا جس سے کوئی دوسرا مطلب حاصل کیا جا سکے اور اگر کچھ لفظوں کی بجائے دوسرے لفظ داخل کر دیے جائیں تو یہ ’’ تبدیلی ‘‘ ہو گی اور یہود یہ دونوں کام کر لیا کرتے تھے\nمثلاً : قرآن کریم میں ہے :\n«فَبِمَا نَقۡضِہِمۡ مِّیۡثَاقَہُمۡ لَعَنّٰہُمۡ وَ جَعَلۡنَا قُلُوۡبَہُمۡ قٰسِیَۃً ۚ یُحَرِّفُوۡنَ الۡکَلِمَ عَنۡ مَّوَاضِعِہٖ» ( 5/13 )\nترجمہ : تو ان لوگوں کے عہد توڑنے کے سبب ہم نے ان پر لعنت کی اور ان کے دلوں کو سخت کر دیا ۔ یہ لوگ کلمات ( کتاب ) کو اپنے مقامات سے بدل دیتے ہیں ۔\nاور «تَحَرَّفَ» بمعنی کنارا یا پہلو بدلنا اور «تَحَرَّفَ عَنْہُ» بمعنی کسی سے مائل ہو کر ایک طرف ہو جانا ( منجد )\nمثلاً : قرآن کریم میں ہے :\n«وَمَنۡ یُّوَلِّہِمۡ یَوۡمَئِذٍ دُبُرَہٗۤ  اِلَّا مُتَحَرِّفًا لِّقِتَالٍ» ( 8/16 )\nترجمہ : اور جو کوئی بھی ان سے اس دن اپنی پیٹھ پھیرے گا سوائے اس کے کہ وہ کوئی داؤ لگا رہا ہو جنگ کے لیے ۔","«تَحْرِیْف» کسی مسلسل عبارت یا تحریر میں یا اس کے مفہوم میں کوئی تبدیلی کرنا ۔","بدل","حرف","2:75-4:46-5:13-5:41-8:16-22:11",6
450,94,"ب","نَکَّرَ","«نَکَّرَ» میں دو باتیں بنیادی طور پر پائی جاتی ہیں (1) اجنبیت اور (2) ناگواری ۔ تنکیر کی ضد تعریف ہے اور منکر کی معروف ۔ تنکیر بمعنی کسی کو نہ پہچاننا اور تعریف بمعنی کسی کو پہچاننا ۔ اسم نکرہ اور اسم معرفہ مشہور الفاظ ہیں ۔ اور منکر بمعنی برے کام اور معروف بمعنی بھلے کام اور «نَکَّرَ» کے معنی اسم نکرہ بنانا بھی ہے (منجد) اور کسی چیز کی ہیئت کو اس طرح بدل دینا کہ وہ عجیب معلوم ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَ نَـکِّرُوۡا لَہَا عَرۡشَہَا» ( 27/41 )\nترجمہ : سلیمان ؑ نے کہا اس ( بلقیس ) کے لیے اس کے تخت کا روپ بدل دو ۔","«نَکَّرَ» روپ بدل دینا ۔","بدل","نکر","27:41-",1
451,94,"ب","دَاوَل","«اَلدَّوْلَۃ وَالدُّوْلَۃ» بمعنی گردش کرنا اور «دَالَ» کی ضد «دَارَ» ہے ۔ «دَوْر» اور «دَائِرَۃ» کا لفظ تنگ دستی ، بدحالی اور گردش ایام کے لیے آتا ہے ۔ اور «دَوْلَۃُ» برے دنوں سے خوشحالی کے ایام کی طرف پھرنے کو کہتے ہیں ۔ اور «دَاوَل» بمعنی خوشحالی کے دنوں کا ادل بدل کرنا یا پھیر پھیر کر لانا (مف منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَ تِلۡکَ الۡاَیَّامُ نُدَاوِلُہَا بَیۡنَ النَّاسِ» ( 3/140 )\nترجمہ : اور یہ دن ہیں کہ ہم ان کو لوگوں میں ادلتے بدلتے رہتے ہیں ۔","«دَاوَل» ادل بدل کرنا اور بہتر حالت کی طرف لانا ۔","بدل","داول","3:140",1
452,95,"ب","بَدَلَ","«بَدَلَ» بمعنی ایک چیز کے بجائے دوسری چیز لانا (مف) اور یہ کم بھی ہو سکتا ہے زیادہ بھی ، اچھا بھی اور برا بھی ، اس جیسا بھی اور اس کے علاوہ بھی ۔ گویا بدلہ کے لیے یہ لفظ عام ہے ۔ ہم یہاں صرف دو مثالوں پر اکتفا کرتے ہیں :\n(1) مثلاً : قرآن کریم میں ہے :\n«اَفَتَتَّخِذُوۡنَہٗ وَذُرِّیَّتَہٗۤ اَوۡلِیَآءَ مِنۡ دُوۡنِیۡ وَہُمۡ لَکُمۡ عَدُوٌّ ؕ بِئۡسَ لِلظّٰلِمِیۡنَ بَدَلًا» ( 18/50 )\nترجمہ : کیا تم شیطان اور اس کی اولاد کو میرے سوا دوست بناتے ہو ۔ حالانکہ وہ تمہارے دشمن ہیں ۔ اور ( شیطان کی دوستی ) ظالموں کے لیے ( خدا کی دوستی کا ) برا بدل ہے ۔ ( جالندھری )\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n(2) «اِلَّا مَنۡ تَابَ وَاٰمَنَ وَعَمِلَ عَمَلًا صَالِحًا فَاُولٰٓئِکَ یُبَدِّلُ اللّٰہُ سَیِّاٰتِہِمۡ حَسَنٰتٍ» ( 25/70 )\nترجمہ : مگر جس نے توبہ کی اور ایمان لایا اور اچھے کام کیے تو ایسے لوگوں کے گناہوں کو خدا نیکیوں سے بدل دے گا ۔","«بَدَلَ» بدلہ کے لیے عام لفظ  ہے ، کم ہو یا زیادہ ، اچھا ہو یا برا ۔","بدلہ","بدل","18:50-24:55-25:70-33:52-66:5-68:32",6
454,95,"ب","عَدْل","«عَدْل» اصل چیز کے متوازن برابر اور متناسب بدلہ  جبکہ یہ بدلہ اصل چیز کے متوازن اور متناسب ہو ۔ ( تفصیل ’’ انصاف کرنا ‘‘ میں دیکھیے )\nمثلاً : قرآن کریم میں ہے :\n«وَّلَا یُقۡبَلُ مِنۡہَا شَفَاعَۃٌ وَّلَا یُؤۡخَذُ مِنۡہَا عَدۡلٌ» ( 2/48 )\nترجمہ : نہ کسی کی سفارش قبول کی جائے اور نہ کسی سے کسی کا بدلہ قبول کیا جائے ۔","«عَدْل» اصل چیز کے متوازن برابر اور متناسب بدلہ ۔","بدلہ","عدل","2:48-2:123-2:282-4:3-4:58-4:129-4:135-5:8-5:95-5:106-6:1-6:70-6:115-6:150-6:152-7:159-7:181-16:76-16:90-27:60-42:15-49:9-65:2-82:7",24
455,95,"ب","اَجْر","«اَجْر» اور «اُجْرَۃ» وہ بدلہ ہے جو پہلے عہد و پیمان سے متعین (طے) ہو چکا ہو یا بوقت ضرورت «آجِر» (بدلہ دینے والا) بدلہ کا اعلان کرے اور «اَجِیْر» (جس کو بدلہ دیا جائے) اس کو قبول کر کے کام شروع کر دے ۔ یہ کام کا بدلہ ہے ۔ اور یہ عمومًا نفع مند بدلہ کے لیے بولا جاتا ہے ۔ اجر کا لفظ دینی اور دنیوی دونوں طرح کے بدلہ کے لیے آتا ہے ۔ لیکن اجرت کا لفظ عمومًا دنیاوی بدلہ پر بولا جاتا ہے ۔ اور «اٰجِرْ» کام لینے والے کو اور «اَجِیْر» کام دینے والے ، خدمتگار یا اجرت وصول کرنے والے کو کہتے ہیں (مف) اور «اِسْتَاْجَرَ» بمعنی کسی کو مزدور یا نوکر رکھنا ، اجر کا استعمال دینی ، دنیاوی دونوں صورتوں میں قرآن کریم میں مذکور ہے ۔\nمثال (1) : قرآن کریم میں ہے :\n«وَلَاَجۡرُ الۡاٰخِرَۃِ خَیۡرٌ لِّلَّذِیۡنَ اٰمَنُوۡا وَکَانُوۡا یَتَّقُوۡنَ» ( 12/57 )\nترجمہ : اور جو لوگ ایمان لائے اور ڈرتے رہے ، ان کے لیے آخرت کا اجر بہت بہتر ہے ۔\nمثال (2)  : قرآن کریم میں ہے :\n«قَالَ اِنِّیۡۤ  اُرِیۡدُ اَنۡ اُنۡکِحَکَ اِحۡدَی ابۡنَتَیَّ ہٰتَیۡنِ عَلٰۤی اَنۡ تَاۡجُرَنِیۡ ثَمٰنِیَ حِجَجٍ» ( 28/27 )\nترجمہ : انہوں نے ( موسیٰ ؑ ) سے کہا کہ میں چاہتا ہوں اپنی ان دو بیٹیوں میں سے ایک کو تم سے بیاہ دوں ۔ اس ( عہد ) پر کہ تم آٹھ برس میری خدمت کرو ۔","«اَجْر» طے شدہ بدلہ ۔ خدمت کا  معاوضہ ۔","بدلہ","اجر","2:62-2:112-2:262-2:274-2:277-3:136-3:171-3:172-3:179-3:199-4:40-4:67-4:74-4:95-4:100-4:114-4:146-4:162-5:9-6:90-7:113-7:170-8:28-9:22-9:120-10:72-11:11-11:29-11:51-11:115-12:56-12:57-12:90-12:104-16:41-16:96-16:97-17:9-18:2-18:30-18:77-25:57-26:41-26:109-26:127-26:145-26:164-26:180-28:25-28:26-28:27-28:54-29:27-29:58-33:29-33:31-33:35-33:44-34:47-35:7-36:11-36:21-38:86-39:10-39:35-39:74-41:8-42:23-42:40-48:10-48:16-48:29-49:3-52:40-57:7-57:11-57:18-57:19-57:27-64:15-65:5-67:12-68:3-68:46-73:20-84:25-95:6",87
456,95,"ب","جَزَاء","«جَزَا» کے معنی کافی ہونا اور کفایت کرنا (م ۔ ل) اور جزاء وہ بدلہ ہے کہ جو کام کی نسبت سے کسی صورت کم نہ ہو خواہ وہ کام اور اس کا بدلہ اچھا ہو یا برا ۔ اور اس میں عہد و پیمان اور تعین بھی شرط نہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ مَا تُجۡزَوۡنَ  اِلَّا مَا کُنۡتُمۡ تَعۡمَلُوۡنَ» ( 37/39 )\nترجمہ : اور تم کو ویسا ہی بدلہ ملے گا جیسے تم کام کرتے رہے ۔","«جَزَا» وہ بدلہ جو کسی صورت کم نہ ہو  بلکہ پورا پورا ہو ۔","بدلہ","جزاء","2:85-2:191-3:87-3:136-4:93-5:29-5:33-5:38-5:85-5:95-9:26-9:82-9:95-10:27-12:25-12:74-12:75-17:63-17:98-18:88-18:106-20:76-25:15-32:17-34:37-39:34-41:28-42:40-46:14-53:41-54:14-55:60-56:24-59:17-76:9-76:12-76:22-78:26-78:36-98:8",40
457,95,"ب","ثَوَاب","«ثَوَاب» کے بنیادی معنی دوبارہ آنا اور واپس آنا کے ہیں اور «یَثُوْبُ اِلَیْہِ النَّاس» کے معنی جس شخص کے پاس لوگ بکثرت آتے جاتے ہوں ۔ قرآن میں یہ لفظ ان معنوں میں بھی استعمال ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِذۡ جَعَلۡنَا الۡبَیۡتَ مَثَابَۃً لِّلنَّاسِ وَ اَمۡنًا» ( 2/125 )\nترجمہ : اور جب ہم نے خانہ کعبہ کو لوگوں کے جمع ہونے اور امن پانے کی جگہ مقرر کیا ۔\nعلیٰ ہذا القیاس انسان کو اس کے اعمال کا جو بدلہ لوٹتا ہے ۔ اسے ثواب کہا جاتا ہے (مف) گو اس کا استعمال خیر و شر دونوں طرح ہو سکتا ہے ۔ تاہم عمومًا اچھے اعمال کے اچھے بدلہ کے لیے آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاٰتٰىہُمُ اللّٰہُ ثَوَابَ الدُّنۡیَا وَ حُسۡنَ ثَوَابِ الۡاٰخِرَۃِ» ( 3/148 )\nترجمہ : تو خدا نے ان کو دنیا میں بھی بدلہ دیا اور آخرت میں بھی بہت اچھا بدلہ دے گا ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«ہَلۡ  ثُوِّبَ الۡکُفَّارُ  مَا کَانُوۡا یَفۡعَلُوۡنَ» ( 83/36 )\nترجمہ : تو کافروں کو ان کے اعمال کا پورا پورا بدلہ مل گیا ۔\nاس آیت میں بطور طنز ثواب کا لفظ استعمال ہوا ہے ۔","«ثَوَاب» بمعنی اچھے کام کا اچھا بدلہ ۔","بدلہ","ثواب","2:103-2:125-3:145-3:148-3:153-3:195-4:134-5:60-5:85-18:31-18:44-18:46-19:76-28:80-48:18-83:36",16
458,95,"ب","عِقَاب","«عِقََاب» کا لفظ برے کام کے برے بدلہ کے لیے آتا ہے ( تفصیل ’’ انجام ‘‘ میں دیکھیے ) یعنی سزا یا عذاب کے معنوں میں آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاتَّقُوا اللّٰہَ وَاعۡلَمُوۡۤا اَنَّ اللّٰہَ شَدِیۡدُ الۡعِقَابِ» ( 2/196 )\nترجمہ : اور اللہ سے ڈرتے رہو اور جان رکھو کہ اللہ سخت عذاب دینے والا ہے ۔","«عِقََاب» بمعنی برے کام کا برا بدلہ ۔","بدلہ","عقاب","2:196-2:211-3:11-5:2-5:98-6:165-7:167-8:13-8:25-8:48-8:52-13:6-13:32-38:14-40:3-40:5-40:22-41:43-59:4-59:7",20
459,95,"ب","کَفَّارَۃٌ","«کَفَرَ» بمعنی چھپانا ( تفصیل ’’ انکار کرنا ‘‘ میں دیکھئے ) اور «تَکْفِیْر» بمعنی گناہ کو چھپانا اور «کَفَّارَۃٌ» کے معنی وہ نیکی جو گناہ کے بدلے میں کی جائے اور اس سلسلہ میں جو صدقہ یا روزہ رکھا جائے وہ «کَفَّارَۃ» کہلاتا ہے ۔","«کَفَّارَۃ» وہ نیکی جو گناہ کے بدلے میں بطور کفارہ کی جائے ۔","بدلہ","کفارۃ","5:45-5:89-5:95",3
460,95,"ب","وَبَال","«وَبَل» کے بنیادی معنی میں «شِدَّۃ» اور «ثَقَل» کا مفہوم پایا جاتا ہے (مف ۔ منجد) اور اس کے معنی لاٹھی سے مارتے جانا ہے ۔ اور وبال کا لفظ کسی برے کام کی سخت سزا کے لیے استعمال ہوتا ہے ۔ یہ سزا خواہ دنیا میں ملے یا آخرت میں ۔ لیکن اکثر دنیاوی گرفت یا مکافاتِ عمل کی صورت میں ملتا ہے ۔ اب مثالیں ملاحظہ فرمائیے :\nمثال (1) وبال بصورت کفارہ :\nارشاد باری تعالیٰ ہے :\n«اَوۡ کَفَّارَۃٌ  طَعَامُ مَسٰکِیۡنَ اَوۡ عَدۡلُ ذٰلِکَ صِیَامًا لِّیَذُوۡقَ وَبَالَ اَمۡرِہٖ» ( 5/95 )\nترجمہ : یا کفارہ ( دے اور وہ ) مسکینوں کو کھانا کھلانا ہے یا اس کے برابر روزے رکھے تاکہ اپنے کام کی سزا ( کا مزہ ) چکھے ۔\nمثال (2) ارشاد باری تعالیٰ ہے :\n«کَمَثَلِ الَّذِیۡنَ مِنۡ قَبۡلِہِمۡ قَرِیۡبًا ذَاقُوۡا وَبَالَ اَمۡرِہِمۡ ۚ وَلَہُمۡ عَذَابٌ اَلِیۡمٌ» ( 59/15 )\nترجمہ : ان کا حال ان لوگوں کا سا ہے جو ان سے کچھ ہی پیشتر اپنے کاموں کی سزا کا مزہ چکھ چکے ہیں ۔ اور ( ابھی ) ان کے لیے دکھ دینے والا عذاب تیار ہے ۔","«وَبَال» مکافات عمل کی صورت میں سخت گرفت اور سزا ۔","بدلہ","وبال","5:95-59:15-64:5-65:9",4
461,95,"ب","قِصَاص","«قِصَاص» کے معنی ہے کسی فعل کا بدلہ دینا  (منجد) اور قصاص بالعموم انسانی خون اور اس کے اعضا و جوارح سے تعلق رکھتا ہے ۔ جس کی مثال اسی عنوان میں ب کے تحت گزر چکی ، تاہم یہ ضروری نہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلشَّہۡرُالۡحَرَامُ بِالشَّہۡرِالۡحَرَامِ وَالۡحُرُمٰتُ قِصَاصٌ» ( 2/194 )\nترجمہ : ادب کا مہینہ ادب کے مہینے کا مقابل ہے اور ادب کی چیزیں ایک دوسرے کا بدلہ ہیں ۔","«قِصَاص» قتل ناحق اور اعضا و جوارح کا بدلہ ۔","بدلہ","قصاص","2:178-2:179-2:194-5:45",4
462,95,"ب","فِدْیَۃٌ","«فِدْیَۃ» کے معنی کسی کی طرف سے کچھ مال وغیرہ دے کر اسے کسی مصیبت سے بچا لینا ہے (مف) صاحب منجد کے نزدیک مال وغیرہ دے کر قید سے چھڑانا ہے ۔ اور یہ رقم جو بطور معاوضہ دی جائے «فِدْیَۃ» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ یَّاۡتُوۡکُمۡ اُسٰرٰی تُفٰدُوۡہُمۡ وَہُوَ مُحَرَّمٌ عَلَیۡکُمۡ اِخۡرَاجُہُمۡ» ( 2/85 )\nترجمہ : اور اگر وہ تمہارے پاس قیدی ہو کر آئیں تو بدلہ دے کر ان کو چھڑا بھی لیتے ہو ۔ حالانکہ ان کا نکال دینا ہی تم پر حرام تھا ۔","«فِدْیَۃ» کسی کو مصیبت یا قید سے چھڑانے  کے لئے کوئی رقم ادا کرنا ۔","بدلہ","فدیۃ","2:85-2:184-2:196-2:229-3:91-4:92-5:36-10:54-13:18-37:107-39:47-47:4-57:15-70:11",14
463,95,"ب","دِیَۃٌ","«( وَدِی ) وَدَی یَدِیْ وَدْیًا وَدِیَۃً» بمعنی قاتل یا اس کے لواحقین کا مقتول کے لواحقین کو خون بہا ادا کرنا ۔ «اَوْدٰی» بمعنی کسی کا ناجائز خون بہانا اور «دِیَۃٌ» وہ مال ہے جو مقتول کی جان کے عوض قاتل یا اس کے ورثاء کی طرف سے دیا جاتا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ مَنۡ قَتَلَ مُؤۡمِنًا خَطَئًا فَتَحۡرِیۡرُ رَقَبَۃٍ مُّؤۡمِنَۃٍ وَّ دِیَۃٌ مُّسَلَّمَۃٌ اِلٰۤی اَہۡلِہٖۤ اِلَّاۤ اَنۡ یَّصَّدَّقُوۡا» ( 4/92 )\nترجمہ : اور جو بھول کر بھی مومن کو ماڑ ڈالے تو ( ایک تو ) ایک مسلمان آزاد کرے اور ( دوسرے ) مقتول کے وارثوں کو خون بہا دے ۔ الّا یہ کہ وہ معاف کر دیں ۔","«دِیَۃٌ» قاتل یا اس کے لواحقین کا مقتول کے لواحقین کو خون بہا دینا ۔","بدلہ","دیۃ","4:92",1
464,95,"ب","جَزٰی ۔ ثَوَّبَ","جَزٰی کا بیان ’’ بدلہ ‘‘ (جزاء) اور «اَثَاب» اور «ثَوَّبَ» کا بھی ’’ بدلہ ‘‘ میں گزر چکا ہے ۔","«جَزَا» کسی کام کا پورا پورا بدلہ دینا ۔\nاور«ثَوَّبَ» عموماً اچھے کام کے اچھے بدلے کے لئے استعمال ہوتا ہے ۔","بدلہ","جزی ۔ ثوب","3:153-5:85-6:160-20:15-28:84-40:17-40:40-45:22-48:18-92:19",10
465,95,"ب","عَذَّبَ","«عَذُبَ» بمعنی سخت پیاس کی وجہ سے کھانا چھوڑ دینا اور «عَذْب» کے معنی میٹھا اور خوشگوار مشروب یا کھانا اور «مَاءٌ عَذْبٌ» کے معنی ٹھنڈا اور خوشگوار پانی اور «اَعْذَبْ» بمعنی میٹھے پانی پر پہنچنا (مف منجد) لیکن یہ لفظ «باب تفعیل» میں جا کر اپنے بنیادی معنی چھوڑ دیتا ہے اور «عَذَّبَ» بمعنی سخت تکلیف یا سزا دینا یا عذاب دینا ہے ۔ ابوہلال اس کی تعریف «اَلْاَ لَمَ الْمُسْتَقِرّ» ( یعنی ثابت و برقرار رہنے والا دکھ ) سے کرتے ہیں ۔ ( فق ل 198 )\nمثلاً : قرآن کریم میں ہے :\n«وَمَا کُنَّا مُعَذِّبِیۡنَ حَتّٰی نَبۡعَثَ رَسُوۡلًا» ( 17/15 )\nترجمہ : اور جب تک ہم پیغمبر نہ بھیج لیں ، عذاب نہیں دیا کرتے ۔","«عَذَّبَ» سخت سزا کے لیے استعمال ہوتا ہے ۔","بدلہ","عذب","2:284-3:56-3:128-3:129-4:173-5:18-5:40-5:115-5:118-7:164-8:33-8:34-9:14-9:26-9:39-9:55-9:66-9:74-9:85-9:101-9:106-17:15-17:54-17:58-18:86-18:87-20:47-26:138-26:213-27:21-29:21-33:24-33:73-34:35-37:59-48:6-48:14-48:16-48:17-48:25-58:8-59:3-65:8-88:24-89:25",45
466,95,"ب","دَانَ","«اَلدَّیْن» کا لفظ بڑے وسیع مفہوم میں استعمال ہوتا ہے ۔ مختصرًا اس کے چار معانی ہیں ۔ (1) مکمل حاکمیت (2) مکمل عبودیت اور بندگی ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَا لِلّٰہِ الدِّیۡنُ الۡخَالِصُ» ( 39/3 )\nترجمہ : خبردار اللہ تعالیٰ ہی کے لیےٴ خالص عبادت کرنا ہے\nاس آیت میں حاکمیت اور عبودیت یہ دونوں مفہوم پائے جاتے ہیں\nتیسرا معنی قانون جزا و سزا ۔ اور چوتھا معنی اس قانون  کے مطابق اچھے اور برے اعمال کی جزا اور سزا دینا ۔\nمثلاً : قرآن کریم میں ہے :\n«مٰلک یومِ الدین» ( 1/3 )\nترجمہ : روزِ جزا و سزا کا مالک ہے\nاس آیت میں تیسرا اور چوتھا مفہوم پایا جاتا ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«فَلَوۡ لَاۤ اِنۡ  کُنۡتُمۡ غَیۡرَ مَدِیۡنِیۡنَ تَرۡجِعُوۡنَہَاۤ اِنۡ  کُنۡتُمۡ صٰدِقِیۡنَ» ( 56/86،87 )\nترجمہ : پھر اگر تم بدلہ دیے جانے سے آزاد ہو تو تو روح کو ( جب نکل رہی ہوتی ہے ) لوٹا کیوں نہیں لیتے ۔ اگر تم سچے ہو ۔","«دَانَ» جزا و سزا میں حاکم و محکوم کے پہلو کو اجاگر کرنے کے لیے آتا ہے ۔","بدلہ","دان","1:3-2:132-2:193-2:217-2:256-3:19-3:24-3:73-3:83-3:85-4:46-4:125-4:146-4:171-5:3-5:54-5:57-5:77-6:70-6:137-6:159-6:161-7:29-7:51-8:39-8:49-8:72-9:11-9:12-9:29-9:33-9:36-9:122-10:22-10:104-10:105-12:40-12:76-15:35-16:52-22:78-24:2-24:25-24:55-26:82-29:65-30:30-30:32-30:43-31:32-33:5-37:20-37:53-38:78-39:2-39:3-39:11-39:14-40:14-40:26-40:65-42:13-42:21-48:28-49:16-51:6-51:12-56:56-56:86-60:8-60:9-61:9-70:26-74:46-82:9-82:15-82:17-82:18-83:11-95:7-98:5-107:1-109:6-110:2",84
467,95,"ب","عَاقَبَ","«عَقَب» کے معنی ایڑی اور پیچھے اور «عَقَبَ» کے معنی پیچھے لگنا اور «عَاقِب» کے معنی کسی کے پیچھے لگ کر اس کا مواخذہ کرنا اور سزا دینا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَ اِنۡ عَاقَبۡتُمۡ فَعَاقِبُوۡا بِمِثۡلِ مَا عُوۡقِبۡتُمۡ بِہٖ» ( 16/126 )\nترجمہ : اور اگر بدلہ لو تو اسی قدر بدلہ لو جس قدر تم کو تکلیف پہنچائی جائے ۔","«عَاقَبَ» کسی کے پیچھے لگ کر اس کے کیے کا بدلہ لینا ۔","بدلہ","عاقب","16:126-22:60-11:60",3
468,95,"ب","اِنْتَقَمَ","«نَقَمَ» کے معنی کسی چیز کو برا سمجھنا اور اس میں عیب دھرنا ہے (مف ۔ م ل)\nمثلاً : قرآن کریم میں ہے :\n«وَ مَا نَقَمُوۡا مِنۡہُمۡ  اِلَّاۤ  اَنۡ یُّؤۡمِنُوۡا بِاللّٰہِ الۡعَزِیۡزِالۡحَمِیۡدِ» ( 85/8 )\nترجمہ : ان کو مومنوں کی یہی بات بری لگتی تھی کہ وہ خدا پر ایمان لائے ہوئے تھے ۔\nاور «اِنْتَقَام» کسی کو اس کے برے اعمال پر غضبناک ہو کر سزا دینا یا بدلہ لینا یا نعمت کا چھین لینا ۔ اور ابوبلال عسکری کے نزدیک انتقام کی ضد انعام ہے اور انتقام کا معنی انعام کا سلب  کر لینا (چھین لینا) ہے ( فق ل 199 )\nمثلاً : قرآن کریم میں ہے :\n«وَمَنۡ اَظۡلَمُ مِمَّنۡ ذُکِّرَ بِاٰیٰتِ رَبِّہٖ ثُمَّ اَعۡرَضَ عَنۡہَا ؕ اِنَّا مِنَ الۡمُجۡرِمِیۡنَ مُنۡتَقِمُوۡنَ» ( 32/22 )\nترجمہ : اور اس شخص سے بڑھ کر ظالم کون جس کو اس کے پروردگار کی آیتوں سے نصیحت کی جائے تو وہ ان سے منہ پھیرے ، ہم گنہگاروں سے ضرور بدلہ لینے والے ہیں ۔","«اِنْتَقَمَ» بمعنی بدلہ لینا ، سزا دینا ۔ ","بدلہ","انتقم","3:4-5:95-7:136-14:47-15:79-30:47-32:22-39:37-43:25-43:41-43:55-44:16",12
469,95,"ب","اِنْتَصَرَ","«نَصَرَ» کے معنی ظلم اور زیادتی دور کرنے کے لیے کسی کی مدد کرنا (محیط) اور «اِنْتَصَرَ» کے معنی کسی پر ظلم و زیادتی اور دفع مضرت (نقصان سے بچانے) کے لیے بدلہ لینا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَالَّذِیۡنَ اِذَاۤ اَصَابَہُمُ الۡبَغۡیُ ہُمۡ یَنۡتَصِرُوۡنَ» ( 42/39 )\nترجمہ : اور جب ان پر ظلم ( و زیادتی ) ہو تو وہ صرف بدلہ لے لیتے ہیں ۔\nایک دوسرے مقام پر حضرت نوح ؑ اپنے پروردگار سے فریاد کرتے ہیں :\n«فَدَعَا رَبَّہٗۤ  اَنِّیۡ  مَغۡلُوۡبٌ  فَانۡتَصِرۡ» ( 54/10 )\nترجمہ : تو اس نے اپنے پروردگار سے دعا کی کہ میں ( ان کے مقابلے میں ) کمزور ہوں تو ان سے بدلہ لے ۔","«اِنْتَصَار» کسی ظلم و زیادتی کا بدلہ لینا َ خواہ مظلوم خود لے یا اس کی مدد کرتے ہوئے کوئی دوسرا بدلہ لے ۔","بدلہ","انتصر","18:43-26:93-26:227-28:81-42:39-42:41-47:4-51:45-54:10-54:44-55:35",11
470,96,"ب","نَزَفَ","«نَزَفَ» بمعنی کسی چیز کا بتدریج آہستہ آہستہ اور درجہ بدرجہ ختم ہو جانا ۔ «نَزَفَ الْمَاءَ الْبِئْرَ» بمعنی آہستہ آہستہ کنویں سے سارا پانی کھینچ لینا اور«نُزِفَ الْمَآء» بمعنی آہستہ آہستہ پانی کا ختم ہو جانا ۔ اسی طرح «نُزِفَ دَمْعَہٗ» بمعنی اس کی آنکھوں سے آنسو بہہ بہہ کر ختم ہو گئے یا خشک ہو گئے ۔ اور «نُزِفَ الرَّجُلُ» کسی شخص کی عقل کا آہستہ آہستہ  درجہ بدرجہ ختم ہو جانا یا بدمست ہونا ہے اس کی وجہ خواہ کچھ بھی ہو ۔ (مف منجد)\nمثلاً : قرآن کریم میں ہے :\n«لَّا یُصَدَّعُوۡنَ عَنۡہَا وَلَا یُنۡزِفُوۡنَ» ( 56/19 )\nترجمہ : اس سے نہ تو اس کے سر میں درد ہو گا اور نہ بکواس کریں ( عثمانیؒ )","«نَزَفَ» کسی شخص کی عقل کا بتدریج آہستہ آہستہ اور درجہ بدرجہ ختم ہو جانا یا بدمست ہونا ہے ۔","بدمست","نزف","37:47-56:19",2
471,96,"ب","غَالَ","«غَوْل» بمعنی مختلف شکلیں اختیار کرنے والا جنّ اور جادوگر ۔ چھلاوہ ، چڑیل (مف ۔ منجد) اور «اَلْغَوْل» بمعنی مدہوشی ۔ سر درد ۔ (منجد) اور «غَالَ» بمعنی کسی کو یوں ہلاک کر دینا کہ اس کا پتہ بھی نہ چل سکے (مف) گویا «غَوْل» سے ایسی مدہوشی اور بدمستی مراد ہے جس کی وجہ معلوم نہ ہو سکے ۔\nمثلاً : قرآن کریم میں ہے :\n«لَا فِیۡہَا غَوۡلٌ وَّ لَا ہُمۡ عَنۡہَا یُنۡزَفُوۡنَ» ( 37/47 )\nترجمہ : نہ اس سے عقلیں ضائع ہوں اور نہ بکواس کریں ( عثمانیؒ )","«غَوْل» ایسی مدہوشی اور بدمستی مراد ہے جس کی وجہ معلوم نہ ہو سکے ۔","بدمست","غال","37:47",1
472,96,"ب","سَکَرَ","«سُکَر» کا استعمال عمومًا شراب کی وجہ سے مستی اور عقل ضائع ہو جانے پر ہوتا ہے اور «سَکَر» بمعنی ہر نشہ آور چیز ہے ۔ یعنی جب کسی بھی چیز کی مستی ، خواہ غلبۂ عشق ہو یا موت کی سختی کی وجہ سے عقل زائل ہو جائے تو «سکّر» کا استعمال ہو گا ۔ «سَکْرَاتُ الْمَوْت» مشہور لفظ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡا لَا تَقۡرَبُوا الصَّلٰوۃَ وَاَنۡتُمۡ سُکٰرٰی» ( 4/43 )\nترجمہ : اے ایمان والو ! جب تک تم نشہ کی حالت میں ہو تو نماز کے قریب مت جاؤ ۔","«سَکَرَ» ایسی بدمستی جس کی وجہ شراب ہو ۔ تاہم یہ لفظ غلبہ عشق یا دہشت کے موقعہ پر بھی استعمال ہوتا ہے ۔","بدمست","سکر","4:43-15:15-15:72-16:67-22:2-50:19",6
473,97,"ب","بِئْسَ","«بِئْسَ» بمعنی برا ، کلمہ ذم یعنی کلمہ مذمت ، فعل ماضی جامد ہے ۔ کسی ناگوار کام یا بری بات کی مذمت کے لیے استعمال ہوتا ہے ۔ (منجد) اور اس کی ضد «نِعْمَ» ہے ۔ یعنی اچھا ، واہ واہ ، کیا خوب ، جو ہر قسم کی مدح کے لیے استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَحَسۡبُہٗ جَہَنَّمُ ؕ وَ لَبِئۡسَ الۡمِہَادُ» ( 2/206 )\nترجمہ : سو ایسے کو جہنم سزاوار ہے اور وہ بہت برا ٹھکانا ہے !\nنوٹ :  (فعلِ جامد : وہ فعل ہے جو فقط ایک صیغہ میں باقی رہے اور اس کی تصریف نہ ہوتی ہو، اس کو فعل جامد کہتے ہیں، مثلا «نِعۡم» «عسی» وغیرہ)","«بِئْسَ» کسی ناگوار کام یا بری بات کی مذمت کے لیے استعمال ہوتا ہے ۔"," برائی","بئس","2:90-2:93-2:102-2:126-2:206-3:12-3:151-3:162-3:187-3:197-5:62-5:63-5:79-5:80-7:150-8:16-9:73-11:98-11:99-13:18-14:29-16:29-18:29-18:50-22:13-22:72-24:57-38:56-38:60-39:72-40:76-43:38-49:11-57:15-58:8-62:5-64:10-66:9-67:6",39
474,97,"ب","شَرّ","«شَرّ» ہر وہ چیز جس سے ہر کوئی کراہت کرے یا اس سے نقصان پہنچے اور اس کی ضد «خَیْر» ہے یعنی سب کے لیے مرغوب اور پسندیدہ ہو (مف) اور شر کا لفظ برا ، برائی اور تکلیف سب معنوں میں استعمال ہوتا ہے ۔ اور شرارہ آگ کی چنگاری کو کہتے ہیں جس کی جمع شرر ہے ۔\nاور شرارت ہر وہ در پردہ فعل ہے جس سے کسی کو نقصان پہنچایا جا سکے ۔ اور برے آدمی کو شریر کہتے ہیں اور اس کی جمع «اَشْرَار» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ عَسٰۤی اَنۡ تَکۡرَہُوۡا شَیۡئًا وَّ ہُوَ خَیۡرٌ لَّکُمۡ ۚ وَ عَسٰۤی اَنۡ تُحِبُّوۡا شَیۡئًا وَّ ہُوَ شَرٌّ لَّکُمۡ» ( 2/216 )\nترجمہ : اور عجب نہیں کہ ایک چیز تم کو بری لگے اور وہ تمہارے حق میں بھلی ہو ۔ اور عجب نہیں کہ ایک چیز تم کو بھلی لگے اور وہ تمہارے لیے مضر ہو ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَ قَالُوۡا مَا لَنَا لَا نَرٰی رِجَالًا کُنَّا نَعُدُّہُمۡ مِّنَ الۡاَشۡرَارِ» ( 38/62 )\nترجمہ : اور ( اہل دوزخ ) کہیں گے کیا سبب ہے کہ ہم ( یہاں ) ان شخصوں کو نہیں دیکھتے جنھیں ہم بروں میں شمار کرتے تھے ۔","«شَرّ» شر کا لفظ  برا ، برائی اور تکلیف سب معنوں میں استعمال ہوتا ہے ۔ ہر وہ چیز جس سے ہر کوئی کراہت کرے یا اس سے نقصان پہنچے ۔"," برائی","شر","2:216-3:180-5:60-8:22-8:55-10:11-12:77-17:11-17:83-19:75-21:35-22:72-24:11-25:34-38:55-38:62-41:49-41:51-70:20-72:10-76:7-76:11-98:6-99:8-113:2-113:3-113:4-113:5-114:4",29
475,97,"ب","سَاءَ","«سَاءَ» بمعنی قبیح ہونا (منجد) بد صورت یا ناگوار ہونا ، جو ظاہری بد صورتی اور معنوی خرابی دونوں کے لیے آتا ہے ۔ اور اس کی ضد «حَسُنَ» ہے ۔ اسی طرح «سَیِّئَات» بمعنی برا کام اس کی ضد «حَسَنَات» آتی ہے ، «سَاءَ» سے صرف ماضی اور مضارع (مستقبل) کے صیغے آتے ہیں ۔\n(1) معنوی برائی کے لیے :\nمثلاً : قرآن کریم میں ہے :\n«وَ ہُمۡ یَحۡمِلُوۡنَ اَوۡزَارَہُمۡ عَلٰی ظُہُوۡرِہِمۡ ؕ اَلَا سَآءَ  مَا یَزِرُوۡنَ» ( 6/31 )\nترجمہ : اور وہ ( اپنے اعمال کے ) بوجھ اپنی پیٹھوں پر اٹھائے ہوئے ہوں گے ۔ دیکھو جو بوجھ اٹھا رہے ہیں ۔ بہت برا ہے ۔\n(2) ظاہری بد صورتی کے لیے :\nمثلاً : ارشاد باری تعالیٰ ہے :\n«فَلَمَّا رَاَوۡہُ   زُلۡفَۃً  سِیۡٓئَتۡ وُجُوۡہُ الَّذِیۡنَ کَفَرُوۡا» ( 67/27 )\nترجمہ : سو جب وہ دیکھ لیں گے کہ وہ ( وعدہ ) قریب آ گیا تو کافروں کے منہ برے ہو جائیں گے ۔\nاور «سَآءَ» سے فعل متعدی «اَسَآءَ» کے معنی خراب کرنا اور بگاڑنا ، برا بنا دینا کے ہیں ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«فَاِذَا جَآءَ وَعۡدُ الۡاٰخِرَۃِ  لِیَسُوۡٓءٗا  وُجُوۡہَکُمۡ» ( 17/7 )\nترجمہ : پھر جب دوسرے وعدے کا وقت آیا تو ( ہم نے پھر اپنے بندے بھیجے ) تاکہ تمہارے چہروں کو بگاڑ دیں ۔\nاور «سَوْء» بمعنی برا ، بری ، برائی جو کسی چیز کے اندر ہو ۔ «اِمْرَأَسَوْءٍ» بمعنی بدکار آدمی ۔ اور «سُوْءٓ» بمعنی عیب برا کام اور برائی کے معنوں میں آتے ہیں ۔ اور «مُسِیْء» بمعنی برے کام کرنے والا بدکار ۔ بدکردار ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«وَ الَّذِیۡنَ  اٰمَنُوۡا وَ عَمِلُوا الصّٰلِحٰتِ وَ لَا الۡمُسِیۡٓءُ» ( 40/58 )\nترجمہ : اور نہ وہ لوگ جو ایمان لائے اور نیک کام کیے اور بدکار ( برابر ہو سکتے ہیں ) ۔","«سَاءَ» بد صورت یا ناگوار ہونا ، جو ظاہری اور معنوی بد صورتی دونوں کے لیے آتا ہے ۔ اور اس کی ضد «حَسُنَ» ہے ۔"," برائی","ساء","2:49-2:81-2:169-2:271-3:30-3:120-3:174-3:193-3:195-4:17-4:18-4:22-4:31-4:38-4:78-4:79-4:85-4:97-4:110-4:115-4:123-4:148-4:149-5:12-5:65-5:66-6:31-6:54-6:136-6:157-6:160-7:73-7:95-7:131-7:141-7:153-7:165-7:167-7:168-7:177-7:188-8:29-9:9-9:37-9:98-9:102-10:27-11:10-11:54-11:64-11:78-11:114-12:24-12:25-12:51-12:53-13:6-13:11-13:18-13:21-13:22-13:25-14:6-16:25-16:27-16:28-16:34-16:45-16:59-16:60-16:94-16:119-17:7-17:32-17:38-18:29-19:28-20:22-20:101-21:74-21:77-23:96-25:40-25:66-25:70-26:156-26:173-27:5-27:11-27:12-27:46-27:58-27:62-27:90-28:32-28:54-28:84-29:4-29:7-30:10-30:36-33:17-35:8-35:10-35:43-37:177-39:24-39:47-39:48-39:51-39:61-40:9-40:37-40:40-40:45-40:52-40:58-41:34-41:46-42:25-42:40-42:48-45:15-45:21-45:33-46:16-47:2-47:14-48:5-48:6-48:12-53:31-58:15-60:2-63:2-64:9-65:5-66:8-67:27",139
476,97,"ب","قَبَحَ","«قَبَحَ» بمعنی قول یا فعل یا شکل کا برا ہونا اور قبیح بمعنی برا ۔ بدنما (منجد) یہ لفظ عمومًا ظاہری حالت کی برائی کے لیے آتا ہے اور «قَبِیْح» بمعنی بد حال (مف) بمعنی بد صورت یا بد نما ہونا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَاَتۡبَعۡنٰہُمۡ فِیۡ ہٰذِہِ الدُّنۡیَا لَعۡنَۃً ۚ وَ یَوۡمَ الۡقِیٰمَۃِ ہُمۡ مِّنَ الۡمَقۡبُوۡحِیۡنَ» ( 28/42 )\nترجمہ : اور ہم نے اس دنیا میں بھی ان کے پیچھے لعنت لگا دی اور قیامت کے دن بھی وہ بد حالوں میں سے ہوں گے ۔","«قَبَحَ» بد حال یا بد صورت ہونا ۔ قول ، فعل اور شکل کی برائی کے لیے آتا ہے ۔ عمومًا ظاہری طور پر استعمال ہوتا ہے ۔"," برائی","قبح","28:42",1
477,97,"ب","ذَمَّ","«ذَمَّ» بمعنی برائی کرنا ۔ عیب نکالنا ۔ «اَذَمَّ» بمعنی حقیر جاننا اور «تَذَمَّمَ» بمعنی کسی سے خود بچنا اور اسے اپنے لیے شرم و عار سمجھنا (منجد) اور «ذِمَام» بمعنی حرمت وعزت اور «ذَمَّمَہٗ» یعنی اس نے اس کی خوب بے عزتی کی ۔ (م ۔ ق) گویا «ذَمَّ» کا لفظ ایسے کام پر عیب جوئی یا بے عزتی کرنے کے لیے آتا ہے جس کا کرنا کرنے والے کے لیے باعث شرم و عار ہو اور اسکی ضد «مَدَحَ» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ جَعَلۡنَا لَہٗ جَہَنَّمَ ۚ یَصۡلٰىہَا مَذۡمُوۡمًا مَّدۡحُوۡرًا» ( 17/18 )\nترجمہ : پھر اس کے لیے ہم نے جہنم رکھ چھوڑی ہے جس میں وہ ذلیل و خوار ہو کر داخل ہوگا ۔","«ذَمَّ» کسی کے عیب بیان کر کے اس  کی بے عزتی کرنا ۔"," برائی","ذم","17:18-17:22-68:49",3
478,97,"ب","عَتَبَ","«عَتَبَ» بمعنی سرزنش کرنا ، خفگی کرنا ۔ ( یہ لفظ لغت اضداد سے ہے ۔ ) «عَاتِب» کے معنی ملامت کرنا اور غصہ کرنا بھی ہے اور ناز سے خطاب کرنا بھی ۔ اور «اَعْتَبَ» کے معنی سبب ناراضگی کو دور کرنا اور «اِسْتَعْبَبَ» کسی کو راضی کر لینا اور روٹھے ہوئے کو منا لینا (منجد) گویا «عِتَاب» ایسی میٹھی میٹھی ڈانٹ اور ملامت کو کہتے ہیں جس کا مقصد بالآخر رضا مند ہونا اور مان جانا ہو ۔ اور عتاب کا استعمال دوستی اور ہمدردی کے تعلقات ضائع کرنے پر بھی ہوتا ہے ( فق ل 39 )\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ یَّسۡتَعۡتِبُوۡا فَمَا ہُمۡ مِّنَ الۡمُعۡتَبِیۡنَ» ( 41/24 )\nترجمہ : اگر وہ منانا چاہیں تو ان سے رضا مندی نہ ہو گی ۔\nنوٹ : (لغت اضداد ایسے الفاظ کو کہتے ہیں جن کے  دو الگ الگ معنیٰ ہوں اور وہ معنیٰ ایک دوسرے کے مخالف اور متضاد ہوں)","«عَتَبَ» ناراضگی دور کرنے کے لیے میٹھے انداز میں خفگی کا اظہار کرنا ۔"," برائی","عتب","16:84-30:57-41:24-45:35",4
479,97,"ب","لَامَ","«لَامَ» بمعنی کسی کام کو برا سمجھ کر اس کام  کے کرنے والے کو برا بھلا کہنا (مف) خواہ یہ فعل بذات خود برا نہ ہو اور بمعنی انسان کے کسی فعل کے نتیجہ پر اسے تنبیہ کرنا ( فق ل 39 )\nمثلاً : قرآن کریم میں ہے :\n«یُجَاہِدُوۡنَ فِیۡ سَبِیۡلِ اللّٰہِ وَلَا یَخَافُوۡنَ لَوۡمَۃَ لَآئِمٍ» ( 5/54 )\nترجمہ : اللہ کی راہ میں جہاد کریں اور کسی ملامت کرنے والے کی ملامت سے نہ ڈریں ۔","«لَامَ» کسی کو اس کے کسی فعل پر برا بھلا کہنا ۔ اس کے کام کے نتیجہ پر تنبیہ کرنا ۔"," برائی","لام","5:54-14:22-17:29-17:39-23:6-37:142-51:40-51:54-68:30-70:30-75:2",11
480,97,"ب","سَبَّ","«سَبّب» بمعنی مغلظات بکنا اور فحش گالیاں دینا (مف) اور «سَبَّبَ» بمعنی بہت زیادہ گالی دینا ۔ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«لَا تَسُبُّوا الَّذِیۡنَ یَدۡعُوۡنَ مِنۡ دُوۡنِ اللّٰہِ فَیَسُبُّوا اللّٰہَ عَدۡوًۢا بِغَیۡرِعِلۡمٍ» ( 6/108 )\nترجمہ : جو لوگ اللہ کے سوا دوسروں کو پکارتے یا پرستش کرتے ہیں انہیں گالی نہ دو ۔ ورنہ وہ ازراہِ نادانی ضد میں آ کر اللہ تعالیٰ کو برا بھلا کہنے لگیں گے ۔","«سَبّب» گالی اور فحش مغلظات بکنا ۔"," برائی","سب","6:108",1
481,97,"ب","ثَرَّبَ","«ثَرَّبَ» کسی کے برے کام پر اسے سرزنش اور  ڈانٹ ڈپٹ کرنا (مف)\nمثلاً : قرآن کریم میں ہے :\n«لَا تَثۡرِیۡبَ عَلَیۡکُمُ الۡیَوۡمَ ؕ یَغۡفِرُ اللّٰہُ لَکُمۡ» ( 12/92 )\nترجمہ : ( حضرت یوسف ؑ نے اپنے بھائیوں سے کہا ) آج تم پر کوئی سرزنش نہیں ۔ اللہ بھی تمہیں معاف کرے ۔","«ثَرَّبَ» کسی کے برے کام پراسے ملامت  کرنا اور ڈانٹ ڈپٹ بھی کرنا ۔"," برائی","ثرب","12:92",1
482,97,"ب","نُکُر","«نُکُر» میں بنیادی طور پر دو باتیں پائی جاتی ہیں ۔ (1) اجنبیت (2) ناگواری ۔ اور «اَنْکَرَ» کے معنی انکار کرنا بھی ہے اور اچنبھا یعنی (تعجب کی بات) سمجھنا بھی اور «مُنْکَر» کے معنی ہر وہ بات جو عام معاشرہ کی نگاہوں میں ناپسندیدہ ہو یا جسے شریعت نے ناپسندیدہ قرار دیا ہو ۔ اور «نُکُر» بمعنی ایسی بری بات جو ہر ایک کو ناگوار ہو اور بری لگے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَتَوَلَّ عَنۡہُمۡ ۘ یَوۡمَ یَدۡعُ الدَّاعِ اِلٰی شَیۡءٍ نُّکُرٍ» ( 54/6 )\nترجمہ : تو تم ان ( کافروں سے ) منہ پھیر لو اس دن تک جب بلانے والا ایک ناپسندیدہ بات کی طرف بلائے گا ۔","«نُکُر» ہر وہ بات جو عام لوگوں کی نظروں میں ناگوار ہو اورناپسندیدہ  ہو ۔"," برائی","نکر","11:70-18:74-18:87-27:41-31:19-54:6-65:8",7
483,97,"ب","نَقَمَ ، نَقِمَ","«نَقَمَ» بمعنی کسی چیز کو برا سمجھنا (مف) اور بمعنی مکروہ سمجھنا ، عیب لگانا ، ملامت کرنا ، سزا دینا (منجد) گویا «نِقْمَۃ» ایسی ناگوار بات کو کہتے ہیں کہ کسی کو بری لگے ، کسی کو نہ لگے ۔ خواہ یہ بات فی الواقعہ ناگوار ہو یا نہ ہو ۔ پھر وہ اس کے انتقام پر بھی اتر آئے اور «نقمۃ» بمعنی سزا ، عذاب یا بدلہ بھی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَا نَقَمُوۡا مِنۡہُمۡ اِلَّاۤ اَنۡ یُّؤۡمِنُوۡا بِاللّٰہِ الۡعَزِیۡزِالۡحَمِیۡدِ» (85/8)\nترجمہ :( اور ان کافروں کو مومنوں کی صرف یہ بات بری لگتی تھی کہ وہ خدائے غالب و قابلِ ستائش پر ایمان لائے تھے !","«نَقَمَ» ایسی بات جو کسی خاص شخص کو بری لگے اور وہ اسے برداشت نہ کر سکے ۔ اگرچہ اصل میں وہ بات بری بھی نہ ہو ۔"," برائی","نقم ، نقم","5:59-7:126-9:74-85:8",4
484,98,"ب","عَدْل","«عَدْل» ایسی چیزوں میں برابری کو کہتے ہیں جن کا تعلق ناپ تول یا وزن سے ہو یا جن کا ادراک حواس ظاہری سے ہو سکے (مف) انہی حواس ظاہرہ کی بنا پر ہی عدل کو انصاف بھی کہا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَوۡعَدۡلُ ذٰلِکَ صِیَامًا لِّیَذُوۡقَ وَبَالَ اَمۡرِہٖ» ( 5/95 )\nترجمہ : یا اس کے  برابر روزے رکھے تاکہ وہ اپنے کرتوت کا مزہ چکھے ۔","«عَدْل» ایسی چیزوں میں برابری کو کہتے ہیں جن کا تعلق ناپ تول یا وزن سے ہو یا جن کا ادراک حواس ظاہری سے ہو سکے ۔","برابر","عدل","2:48-2:123-2:282-4:3-4:58-4:129-4:135-5:8-5:95-5:106-6:1-6:70-6:115-6:150-6:152-7:159-7:181-16:76-16:90-27:60-42:15-49:9-65:2-82:7",24
485,98,"ب","سَوَاء ، اَسْتَوٰی","«سَوَاء ، اَسْتَوٰی»  حالت اور مقدار کی برابری کے لیے آتا ہے ( مف ۔ فق ل 128 )\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ الَّذِیۡنَ کَفَرُوۡا سَوَآءٌ عَلَیۡہِمۡ ءَاَنۡذَرۡتَہُمۡ اَمۡ لَمۡ تُنۡذِرۡہُمۡ» ( 2/6 )\nترجمہ : جو لوگ کافر ہیں انہیں تم نصیحت کرو یا نہ کرو ان کے لیے برابر ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«ہَلۡ یَسۡتَوِی الۡاَعۡمٰی وَ الۡبَصِیۡرُ ۬ ۙ اَمۡ ہَلۡ تَسۡتَوِی الظُّلُمٰتُ وَ النُّوۡرُ» ( 13/16 )\nترجمہ : کیا بینا اور نابینا برابر ہو سکتے ہیں یا کیا اندھیرا اور روشنی برابر ہو سکتی ہے ۔\nاور «اِسْتَوٰی عَلٰی» کا معنی کسی سواری پر جم کر بیٹھنا ہے ۔\nاور مقدار یا حالت کو برابر کرنے کے لیے «سَوّٰی» کا لفظ آتا ہے ۔ درج ذیل آیت میں یہ دونوں الفاظ اکٹھے آ گئے ہیں ۔\n«الَّذِیۡ خَلَقَکَ فَسَوّٰىکَ فَعَدَلَکَ» ( 82/7 )\nترجمہ : وہ ذات جس نے تجھے پیدا کیا ۔ پھر ( تیری حالت کو ) درست کیا پھر تجھے برابر ( متناسب و متوازن ) کیا ۔\nاور «سَوّٰی» کا لفظ بھی وسیع المفہوم ہے ۔ جس میں پورا کرنا ۔ برابر کرنا ۔ درست اور ٹھیک ٹھاک کرنا ۔ سب کچھ آ جاتا ہے ۔","«سَوَاء ، اَسْتَوٰی» کسی بھی چیز کی حالت یا مقدار کے برابر سرابر ہونے کے لیے استعمال ہوتا ہے ۔","برابر","سواء ، استوی","2:6-2:29-2:108-3:64-3:113-4:89-4:95-5:12-5:60-5:77-5:100-6:50-7:193-8:58-9:19-11:24-13:10-13:16-14:21-16:71-16:75-16:76-18:37-21:109-22:25-26:136-28:22-30:28-32:9-32:18-35:12-35:19-35:22-36:10-37:55-38:22-39:9-39:29-40:58-41:10-41:34-44:47-45:21-48:29-52:16-53:3-57:10-59:20-60:1-63:6-79:28-82:7-91:7-91:14",54
486,99,"ب","ضَلّ","«ضَلَّ» کے معنی کسی چیز کا ضائع ہو کر دوسرے کے حق میں چلے جانا ہے (م ۔ ل) یعنی اپنے وجود کو ختم کر کے یا ملیامیٹ کر کے کسی دوسرے وجود میں مدغم ہو جانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَقَالُوۡۤاءَ اِذَا ضَلَلۡنَا فِی الۡاَرۡضِ ءَ اِنَّا لَفِیۡ خَلۡقٍ جَدِیۡدٍ» ( 32/10 )\nترجمہ : اور کافر کہنے لگے کہ جب ہم زمین میں رَل مل جائیں گے تو کیا ازسرِ نو پیدا ہوں گے ؟\nپھر بعض دفعہ یہ لفظ صرف کسی چیز کے وجود کے ختم ہو جانے یا ضائع و برباد ہونے کے معنوں میں بھی آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا ضَلُّوۡا عَنَّا وَ شَہِدُوۡا عَلٰۤی اَنۡفُسِہِمۡ اَنَّہُمۡ  کَانُوۡا کٰفِرِیۡنَ» ( 7/37 )\nترجمہ : وہ کافر کہیں گے ( معلوم نہیں ) کہ وہ ہمارے شریک ہم سے کہاں غائب ہو گئے ۔ اور اقرار کریں گے کہ بیشک وہ کافر تھے ۔\nاور «ضَلَّ» کا لفظ اگرچہ عام ہے جیسا کہ مندرجہ بالا مثالوں سے ظاہر ہے ۔ تاہم اس کا اطلاق عمومًا راستہ کھو دینے پر ہوتا ہے اور «ضَلَّ» بمعنی راہ گم کر دینا اور صحیح راہ کا پتہ نہ چل سکنا اور اس کی تلاش میں پھرنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ وَجَدَکَ ضَآلًّا فَہَدٰی» ( 93/7 )\nترجمہ : اور اللہ نے تجھے بھٹکتا پایا تو راہ سجھائی ( عثمانیؒ )\nاور «اَضَلَّ» کا معنی عمومًا کسی دوسرے کو راستہ سے بہکا دینا ، بھٹکا دینا ۔ اور بہکا کر غلط راستے پر ڈال دینا ہے ۔ تاہم یہ لفظ برباد کرنے یا ضائع کرنے کے معنوں میں بھی آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَّذِیۡنَ  کَفَرُوۡا وَ صَدُّوۡا عَنۡ سَبِیۡلِ اللّٰہِ  اَضَلَّ  اَعۡمَالَہُمۡ» ( 47/1 )\nترجمہ : جن لوگوں نے کفر کیا اور ( دوسروں کو ) خدا کی راہ سے روکا خدا نے ان کے اعمال برباد کر دیے ۔\nاسی طرح ایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«ذٰلِکَ بِاَنَّہُمۡ کَرِہُوۡا مَاۤ  اَنۡزَلَ اللّٰہُ فَاَحۡبَطَ اَعۡمَالَہُمۡ» ( 47/9 )\nترجمہ : یہ اس لیے کہ اللہ نے جو کچھ نازل فرمایا ، انہوں نے اس کو ناپسند کیا تو اللہ نے ان کے اعمال برباد کر دیے ۔","«ضَلَّ» کسی چیز کا ضائع ہو کر دوسرے کے حق میں چلے جانا اور اپنا وجود کھو دینا ۔","برباد","ضل","1:7-2:16-2:26-2:108-2:175-2:198-2:282-3:69-3:90-3:164-4:44-4:60-4:88-4:113-4:116-4:119-4:136-4:143-4:167-4:176-5:12-5:60-5:77-5:105-6:24-6:39-6:56-6:74-6:77-6:94-6:116-6:117-6:119-6:125-6:140-6:144-7:30-7:37-7:38-7:53-7:60-7:61-7:149-7:155-7:178-7:179-7:186-9:37-9:115-10:30-10:32-10:88-10:108-11:21-12:8-12:30-12:95-13:14-13:27-13:33-14:3-14:18-14:27-14:30-14:36-15:56-16:25-16:36-16:37-16:87-16:93-16:125-17:15-17:67-17:72-17:97-18:17-18:51-18:104-19:38-19:75-20:52-20:79-20:85-20:92-20:123-21:54-22:4-22:9-22:12-23:106-25:17-25:29-25:34-25:42-25:44-26:20-26:86-26:97-26:99-27:81-27:92-28:15-28:50-28:75-28:85-30:29-30:53-31:6-31:11-32:10-33:36-33:67-34:8-34:24-34:50-35:8-36:24-36:47-36:62-37:69-37:71-38:26-39:8-39:22-39:23-39:36-39:37-39:41-40:25-40:33-40:34-40:50-40:74-41:29-41:48-41:52-42:18-42:44-42:46-43:40-45:23-46:5-46:28-46:32-50:27-53:2-53:30-54:24-54:47-56:51-56:92-60:1-62:2-67:9-67:29-68:7-68:26-71:24-71:27-74:31-83:32-93:7",163
487,99,"ب","حَبِطَ","«حَبِطَ» بمعنی ضائع ہونا ، برباد ہونا ، عمل بیکار ہونا ، خراب ہونا اور «حَبَِطَ دَمُّ الْقَتِیْل» بمعنی مقتول کا خون رائیگاں جانا (منجد) یعنی کسی عمل کا بعض دوسرے اسباب کی وجہ سے نتیجہ خیز ثابت نہ ہونا ۔ اچھے اعمال کا برے اعمال کی وجہ سے ضائع ہوجانا ( اور اگر برے اعمال اچھے اعمال کی وجہ سے ختم ہو جائیں تو اس کا نام تکفیر ہے ) فق ل 196 )\nمثلاً : قرآن کریم میں ہے :\n«وَ لَوۡ اَشۡرَکُوۡا لَحَبِطَ عَنۡہُمۡ  مَّا کَانُوۡا یَعۡمَلُوۡنَ» ( 6/88 )\nترجمہ : اور اگر وہ لوگ شرک کرتے تو جو عمل وہ کرتے سب ضائع ہو جاتے ۔\nاور «اَحْبَطَ» بمعنی بے فائدہ بنا دینا یا برباد اور ضائع کر دینا ہے ۔\nمثلاً : قرآن کریم میں ہے :\nذٰلِکَ بِاَنَّہُمۡ کَرِہُوۡا مَاۤ  اَنۡزَلَ اللّٰہُ فَاَحۡبَطَ اَعۡمَالَہُمۡ ( 47/9 )\nترجمہ : یہ اس لیے کہ اللہ نے جو کچھ نازل فرمایا ، انہوں نے اس کو ناپسند کیا تو اللہ نے ان کے اعمال برباد کر دیے ۔","«حَبِطَ» یعنی کسی عمل کا بعض دوسرے اسباب کی وجہ سے نتیجہ خیز ثابت نہ ہونا ۔ اچھے اعمال کا برے اعمال کی وجہ سے ضائع ہوجانا ۔","برباد","حبط","2:217-3:22-5:5-5:53-6:88-7:147-9:17-9:69-11:16-18:105-33:19-39:65-47:9-47:28-47:32-49:2",16
488,99,"ب","بَطَلَ","«بَطَلَ» یعنی ناحق اور بے اصل کام کو «بَاطِل» کہتے ہیں ۔ باطل کی ضد حق ہے ۔ تحقیق کے بعد جس چیز میں ثبات اور پائیداری نظر نہ آئے وہ باطل ہے (مف)  اور «بَطَلَ» بمعنی کسی چیز کا بے نتیجہ اور بے اثر ہونے کی وجہ سے ضائع ہونا ہے ۔ جیسے بد پرہیزی علاج کے فائدہ کو بے اثر کر دیتی ہے یا علاج بیماری کے اثرات کو دور کر کے ختم کر دیتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَوَقَعَ الۡحَقُّ وَ بَطَلَ مَا کَانُوۡا یَعۡمَلُوۡنَ» ( 7/118 )\nترجمہ : پھر حق ثابت ہو گیا تو جو کچھ فرعونی کرتے تھے وہ باطل ہو گیا ۔\nاور «اَبْطَلَ» بمعنی کسی کام کو بے اثر اور بے نتیجہ بنا دینا جس کی وجہ کوئی دوسرا اس کے مخالف عمل ہوتا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«لَا تُبۡطِلُوۡا صَدَقٰتِکُمۡ بِالۡمَنِّ وَالۡاَذٰی» ( 2/264 )\nترجمہ : اپنے صدقات کو احسان جتلا کر اور تکلیف دے کر ضائع نہ کرو ۔","«بَطَلَ» کسی عمل کے مخالف کوئی ایسا عمل جو پہلے عمل کو بے کار کر دے ۔","برباد","بطل","2:264-7:118-7:173-8:8-10:81-29:48-30:58-40:78-45:27-47:33",10
489,99,"ب","اَضَاعَ","«اَضَاعَ» بمعنی تلف کرنا ، ہلاک کرنا ، برباد کرنا ، خواہ یہ کسی بھی وجہ سے ہوعام ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَخَلَفَ مِنۡۢ بَعۡدِہِمۡ خَلۡفٌ اَضَاعُوا الصَّلٰوۃَ وَ اتَّبَعُوا الشَّہَوٰتِ فَسَوۡفَ یَلۡقَوۡنَ  غَیًّا» ( 19/59 )\nترجمہ : پھر ان کے بعد چند ناخلف ان کے جانشین ہوئے جنھوں نے نماز کو ضائع کیا اور خواہشات کے پیچھے لگ گئے ۔ سو عنقریب ان کو گمراہی کی سزا ملے گی ۔","«اَضَاعَ» کسی بھی وجہ سے کوئی چیز برباد کر دینا ۔","برباد","اضاع","19:59",1
490,100,"ب","حَلُمَ","«حَلُمَ» بمعنی بردبار ہونا ، حوصلہ والا ہونا ، یہ ایک مستقل صف ہے جو ہر وقت حلیم انسان کے اندر موجود رہتی ہے ۔ یعنی جب وہ کوئی ناگوار بات سنے یا اسے کوئی صدمہ پیش آئے یا کوئی بے عزتی کرے یا کوئی بڑی خوش کن بات سنے تو اس کی طبیعت میں اتار چڑھاؤ پیدا نہ ہو یا اگر ہو تو معمولی قسم کا ہو اور علیٰ حالہٖ یعنی جوں کا توں برقرار رہے ۔ اور یہ بڑی محمود (یعنی قابل تعریف) صفت ہے اور ابوہلال اس کا معنی «اِمھَال بِتَخِیْرِ الْعِقَابِ الْمُسْتَحَقٌ ( فق ل 165 )» یعنی کسی مستحقِ سزا کو سزا میں تاخیر کر کے مہلت دینا ہے (فق ۔ ل )\nمثلاً : قرآن کریم میں ہے :\n«فَبَشَّرۡنٰہُ  بِغُلٰمٍ  حَلِیۡمٍ» ( 37/101 )\nترجمہ : ہم نے ابراہیم ؑ کو ایک صاحبِ حوصلہ لڑکے کی خوشخبری دی ۔","«حَلُمَ» غم و غصہ کے موقع پر طبیعت کا اعتدال پر رہنا اور کسی مستحقِ سزا کو سزا دینے میں تاخیر کرنا اور اور مہلت دینا ۔","برداشت","حلم","2:225-2:235-2:263-3:155-4:12-5:101-9:114-11:75-11:87-17:44-22:59-33:51-35:41-37:101-64:17",15
491,100,"ب","صَبَرَ","«اَلصَّبْر» کے لغوی معنی ہیں کسی کو تنگی کی حالت میں روکنا (مف) اور رسول اللہ ﷺ نے «اَلصَّبْر» کی یوں تعریف فرمائی کہ «اَلصَّبْرُ عِتْدَ الصَّدْمَۃِ الْاُوْلی» ( بخاری ) یعنی کسی صدمہ ، مصیبت یا ناگوار حادثہ کے پڑنے پر فورًا اپنے نفس کو گریہ و زاری اور بیقراری سے روکنا اور اسے برداشت کر جانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَالصّٰبِرِیۡنَ فِی الۡبَاۡسَآءِ وَالضَّرَّآءِ وَحِیۡنَ الۡبَاۡسِ» ( 2/177 )\nترجمہ : اور وہ لوگ جو سختی ، دکھ اور جنگ کے وقت صبر کرنے والے ہیں ۔","«صَبْرَ» ہر قسم کی سختی صدمہ اور مصیبت کے وقت بے قراری سے پرہیز اور اسے برداشت کر جانا ۔","برداشت","صبر","2:45-2:61-2:153-2:175-2:250-3:120-3:125-3:186-3:200-4:25-6:34-7:87-7:126-7:128-7:137-8:46-10:109-11:11-11:49-11:115-12:18-12:83-12:90-13:22-13:24-14:12-14:21-16:42-16:96-16:110-16:126-16:127-18:28-18:67-18:68-18:72-18:75-18:78-18:82-20:130-23:111-25:20-25:42-25:75-28:54-29:59-30:60-31:17-32:24-38:6-38:17-40:55-40:77-41:24-41:35-42:43-46:35-49:5-50:39-52:16-52:48-68:48-70:5-73:10-74:7-76:12-76:24-90:17-103:3",69
492,100,"ب","کَظَمَ","«کَظْم» سانس کی نالی کو کہتے ہیں اور «کَظَمَ السِّقَاء» بمعنی مشک کو پانی سے لبالب بھر کر اس کا منہ بند کر دینا (مف) اور «کَظِیْم» اور «مَکْظُوْم» اس شخص کو کہتے ہیں جو غم یا غصہ سے سانس کی نالی تک بھرا ہوا ہو ۔ مگر اس کا اظہار نہ کرے اور نہ کرنے دیا جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَابۡیَضَّتۡ عَیۡنٰہُ مِنَ الۡحُزۡنِ فَہُوَ کَظِیۡمٌ» ( 12/84 )\nترجمہ : اور یعقوب کی دونوں آنکھیں غم کی وجہ سے سفید ہو گئیں اور وہ غم سے ( لبالب ) بھرے ہوئے تھے ۔\nایک دوسرے مقام پر حضرت یونس ؑ کے متعلق ارشاد باری تعالیٰ ہے :\n«اِذۡ نَادٰی وَہُوَ مَکۡظُوۡمٌ» ( 68/48 )\nترجمہ : جب انہوں نے پکارا اور وہ غم و غصہ سے بھرے ہوئے تھے ۔\nایک تیسرے مقام پر مومنوں کی صفات بیان کرتے ہوئے فرمایا :\n«وَالۡکٰظِمِیۡنَ الۡغَیۡظَ وَ الۡعَافِیۡنَ عَنِ النَّاسِ» ( 3/134 )\nترجمہ : اور وہ غصہ کو دبا جانے والے اور لوگوں کو معاف کرنے والے ہیں ۔","«کَظَمَ» غم اور غصہ خواہ کتنا ہی زیادہ ہو ، دبائے رکھنا اور اس کا اظہار نہ ہونے دینا ۔","برداشت","کظم","3:134-12:84-16:58-40:18-43:17-68:48",6
493,101,"ب","کَبِیْر ، اَکْبَرْ","«كَبِيْر ، اَکْبَرْ» میں بنیادی طور پر محض بڑائی کے معنی پائے جاتے ہیں کبیر کے ضد صغیر اور اکبر کی اصغر ہے اور یہ اسمائے اضافیہ یہ سے ہے بمعنی ہر چیز اپنے سے چھوٹی کے مقابلے میں کبیر ہے اور وہی چیز اپنے سے بڑے کے مقابلے میں سب صغیر ہے اور کبیر کا لفظ بنیادی طور پر اجسام کے لئے استعمال ہوتا ہے خواہ وہ چیز عمر میں بڑی ہو یا جسامت میں یا کسی اور دوسری صفت ظاہری میں ۔\nمثلاً : عمر میں بڑائی کے لیے :\nارشاد باری تعالیٰ ہے :\n«قَالَ کَبِیۡرُہُمۡ اَلَمۡ تَعۡلَمُوۡۤا اَنَّ اَبَاکُمۡ قَدۡ اَخَذَ عَلَیۡکُمۡ  مَّوۡثِقًا مِّنَ اللّٰہِ» ( 12/80 )\nترجمہ : ان ( یوسف ؑ کے بھائیوں ) میں سے بڑے نے کہا کیا تم نہیں جانتے کہ تمہارے والد نے تم سے خدا کا عہد لیا ہے ۔\nاور جسامت میں بڑائی کے لیے :\nارشاد باری تعالیٰ ہے :\n«فَجَعَلَہُمۡ جُذٰذًا اِلَّا کَبِیۡرًا لَّہُمۡ» ( 21/58 )\nترجمہ : پھر حضرت ابراہیم ؑ نے ان ( بتوں ) کو توڑ کر ریزہ ریزہ کر دیا ۔ مگر بڑے بت کو ( نہ توڑا ) ۔\nلیکن بعد میں لفظ کبیر اور اکبر کا استعمال معنوی طور پر بھی ہونے لگا ۔\nمثلاً : قرآن کریم میں ہے :\n«یَسۡئَلُوۡنَکَ عَنِ الۡخَمۡرِوَالۡمَیۡسِرِؕ قُلۡ فِیۡہِمَاۤ اِثۡمٌ کَبِیۡرٌ وَّمَنَافِعُ لِلنَّاسِ ۫ وَ اِثۡمُہُمَاۤ اَکۡبَرُ مِنۡ نَّفۡعِہِمَا» ( 2/219 )\nترجمہ : اے پیغمبر ! لوگ آپ سے شراب اور جوئے کا حکم دریافت کرتے ہیں ۔ کہہ دیجئے کہ ان میں نقصان بڑے ہیں اور لوگوں کے لیے کچھ فائدے بھی ہیں مگر ان کے نقصان فائدوں سے کہیں زیادہ بڑے ہیں ۔\n«کَبِیْر» کی جمع «کُبَرَاء» آتی ہے اور «اَکْبَر» اسم تفصیل ہے بمعنی بہت بڑا یا سب سے بڑا ۔ دونوں معنوں میں استعمال ہوتا ہے اور اس کی جمع اکابر آتی ہے ۔","«کَبِیْر» بڑائی کے لیے عام لفظ ہے  عمومًا اجسام اور ظاہری صفات میں بڑائی کے لیے استعمال ہوتا ہے ۔","بزرگ ","کبیر ، اکبر","2:185-2:217-2:219-2:282-3:118-4:2-4:34-4:153-6:19-6:78-6:123-8:73-9:3-9:72-9:121-10:61-11:3-11:11-12:31-12:78-12:80-13:9-16:41-17:4-17:9-17:21-17:31-17:43-17:60-17:87-17:111-18:49-20:71-21:58-21:63-21:103-22:37-22:62-25:19-25:21-25:52-26:49-28:23-29:45-31:30-32:21-33:47-33:67-33:68-34:3-34:23-35:7-35:32-39:26-40:10-40:12-40:56-40:57-42:22-43:48-54:53-57:7-67:9-67:12-68:33-76:20-85:11-88:24",68
494,101,"ب","عَظِیْم","«عَظِیْم» کی ضد «حَقِیْر» ہے اور «اَعْظَمَ ، عَظْمٌ» کے بنیادی معنی میں بڑائی کے علاوہ قوت اور شدت کا مفہوم بھی پایا جاتا ہے ۔ اور یہ معنوی صفات کہیں سب اکٹھی اور کہیں فردًا فردًا پائی جاتی ہیں ۔ اور ہڈی کو بھی اس کی قوت اور شدت کی وجہ سے «عَظْمٌ» کہتے ہیں ۔ (م ل) «عَظْم» اور «عَظِیْم» دونوں کی جمع «عِظَام» آتی ہے ۔ «عَظِیْم» کا لفظ بھی اجسام  و اعیان (یعنی بڑاشخص یا بڑامرتبہ) دونوں صورتوں میں استعمال ہوتا ہے ۔ (مف) اور «اَعْظَمَ» اسم تفصیل ہے بمعنی بہت بڑا اور بزرگ یا سب سے بڑا اور بزرگ ۔ اب مثالیں دیکھیے :\nمثلاً : قرآن کریم میں ہے :\n(1) «وَّ لَہُمۡ عَذَابٌ عَظِیۡمٌ» ( 2/7 )\nترجمہ : اور ان کافروں کے لیے بڑا عذاب ہے ۔\n(2) «فَسَبِّحۡ  بِاسۡمِ  رَبِّکَ الۡعَظِیۡمِ» ( 56/96 )\nترجمہ : تو آپ اپنے پروردگار بزرگ کے نام کی تسبیح کرتے رہتے ۔\nایک قوم میں «کَبِیْر» اور «اَکْبَر» بہت سے لوگ ہو سکتے ہیں لیکن «عَظِیْم» ایک ہی ہوتا ہے ۔ ( فق ل 150 )","«عَظِیْم» جس میں بڑائی کے علاوہ قوت اور شدت پائی جائے ۔ جس طرح حقیر اصغر سے کم تر ہے اسی طرح عظیم ، اکبر سے اوپر ہے ۔","بزرگ ","عظیم","2:7-2:49-2:105-2:114-2:255-3:74-3:105-3:172-3:174-3:176-3:179-4:13-4:27-4:40-4:48-4:54-4:67-4:73-4:74-4:93-4:95-4:113-4:114-4:146-4:156-4:162-5:9-5:33-5:41-5:119-6:15-7:59-7:116-7:141-8:28-8:29-8:68-9:20-9:22-9:63-9:72-9:89-9:100-9:101-9:111-9:129-10:15-10:64-12:28-14:6-15:87-16:94-16:106-17:40-19:37-21:76-22:1-23:86-24:11-24:14-24:15-24:16-24:23-26:63-26:135-26:156-26:189-27:23-27:26-28:79-31:13-33:29-33:35-33:53-33:71-37:60-37:76-37:107-37:115-38:67-39:13-40:9-41:35-42:4-43:31-44:57-45:10-46:21-48:5-48:10-48:29-49:3-56:46-56:74-56:76-56:96-57:10-57:12-57:21-57:29-61:12-62:4-64:9-64:15-68:4-69:33-69:52-73:20-78:2-83:5",110
495,101,"ب","ذُوالْجَلَال","«جَلَال» قدر و منزلت میں بڑائی کو کہتے ہیں ۔ «ذُوْالْجَلَال» بمعنی «عَظِیمُ الْمَرْتَبَت» یعنی بڑے رتبے والا ، اور «جَلِیْل» کے معنی بڑی بڑی عظیم الشان اشیاء کو پیدا کرنے والا ہے (مف) اور بمعنی اپنے عظیم الشان کاموں کی وجہ سے مستحق تعریف ذات ( فق ل 150 )\nمثلاً : قرآن کریم میں ہے :\n«تَبٰرَکَ اسۡمُ رَبِّکَ ذِی الۡجَلٰلِ وَالۡاِکۡرَامِ» ( 55/78 )\nترجمہ : بڑی برکت ہے  تیرے رب کے نام کو ، جو بڑائی والا اور عظمت والا ہے ۔ ( عثمانیؒ )","«ذُوالْجَلَال» قدر و منزلت میں بڑائی کو کہتے ہیں صرف اللہ تعالیٰ  کی ذات مبارک کےلئے مخصوص ہے ۔","بزرگ ","ذوالجلال","55:27-55:78",2
496,101,"ب","مَجِیْد","«مَجِیْد» کے معنی شان و شوکت میں بڑا وسیع الشان ہونے کے ہیں (مف) ۔ اور ابن الفارس کے نزدیک : وہ جو کرم و عزت و شرافت میں انتہائی حد کو پہنچا ہوا ہو (م ۔ ل) اور «مَجِیْد» بمعنی وہ جو لوگوں کی نظروں میں بڑا ہو (م ق) ۔\nمثلاً : قرآن کریم میں ہے :\n«وَہُوَالۡغَفُوۡرُ الۡوَدُوۡدُ ذُوالۡعَرۡشِ الۡمَجِیۡدُ» ( 85/14،15 )\nترجمہ : اور وہ بخشنے والا اور محبت کرنے والا ہے ۔ عرش کا مالک ، بڑی شان والا ۔","«مَجِیْد» وہ ذات جو شان و شوکت، کرم و عزت و شرافت میں انتہائی حد کو پہنچی ہوئی ہو ۔","بزرگ ","مجید","11:73-50:1-85:15-85:21",4
497,101,"ب","کِبَر","«كِبْرُ» عمومًا عمر میں بڑائی کے لیے آتا ہے ۔ بمعنی بڑھاپا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاَصَابَہُ الۡکِبَرُ وَلَہٗ ذُرِّیَّۃٌ ضُعَفَآءُ» ( 2/266 )\nترجمہ :’’ اور اسے بڑھاپا آ پہنچے اور اس کے ننھے ننھے بچے ہوں ۔\nنیز «کِبر» بمعنی عظمت ، شان بڑائی ، تکبراور اپنی شان کی بڑائی کا اظہار تکبر ہے ۔ یہ صفت اللہ تعالیٰ کے لیے لائق اور خاص ہے ۔ باقی سب کے لیے مذموم یعنی بری ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنۡ فِیۡ صُدُوۡرِہِمۡ  اِلَّا کِبۡرٌ» ( 40/56 )\nترجمہ : ان کے دلوں میں بڑائی اور تکبر کے سوا کچھ نہیں ۔","«كِبْرُ» عمر میں بڑائی کے لیے یا اپنی شان کے اظہار کے لیے  استعمال ہوتا ہے ۔","بزرگ ","کبر","2:266-3:40-4:6-10:78-14:39-15:54-17:23-19:8-45:37-74:3",10
498,101,"ب","جَلَال","«جَلَالْ» قدر و منزلت میں بڑائی ۔ عظمت کی آخری حد جس کے بعد اور کوئی مرتبہ نہ ہو ۔ اور «ذُوالجلال» کا لفظ صرف اللہ تعالیٰ سے مخصوص ہے ۔ جبکہ «جَلِیْل» دوسری اشیاء بھی ہو سکتی ہیں ۔ اور «جَلِیْل» ہر وہ چیز ہے جو ہر بات میں بڑی ہو اور مضبوط ہو ۔ عظیم الشان (مف)\nمثلاً : قرآن کریم میں ہے :\n«تَبٰرَکَ اسۡمُ رَبِّکَ ذِی الۡجَلٰلِ وَالۡاِکۡرَامِ» ( 55/78 )\nترجمہ : تمہارے پروردگار کا نام بڑا بابرکت ہے جو صاحبِ جلال و عظمت ہے ۔","«جَلَالْ» قدر و منزلت میں بڑائی کی آخری حد ۔","بزرگ ","جلال","55:27-55:78",2
499,101,"ب","جَدّ","«جَدّ» بمعنی فیض الہی اور بمعنی بخت و نصیب «جُدِدْتُ» بمعنی میں خوش قسمت اور صاحبِ نصیب ہو گیا ۔ اور «جَدَّ» بمعنی دنیاوی مال و جاہ سے کسی کو نوازنا نیز «جَدّ» بمعنی آبائی نسب (مف) «جَدّ» بمعنی دادا نانا  جمع «اَجْدَاد» اور بمعنی خوش قسمتی ۔ بزرگی ۔ عظمت دولت ۔ رزق اور «فُلَانٌ ذُوْجَدٍّ» بمعنی وہ شخص بڑا صاحبِ نصیب ہے (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَّاَنَّہٗ تَعٰلٰی جَدُّ رَبِّنَا مَا اتَّخَذَ صَاحِبَۃً وَّلَا وَلَدًا» ( 72/3 )\nترجمہ : اور ہمارے پروردگار کی شان بہت بڑی ہے جس کی نہ بیوی ہے اور نہ اولاد ۔","«جَدّ» فیضان الہی کہ وہ دوسروں کو بھی بزرگی عطا کرتا ہے ۔","بزرگ ","جد","72:3",1
500,102,"ب","زَادَ ، اِزْدَادَ","«زَادَ» کی ضد «نَقَص» ہے بمعنی بڑھنا اور بڑھانا ۔ دونوں افعال لازم و معتدی دونوں طرح آتے ہیں (مف ۔ منجد) یہ بڑھنے اور بڑھانے کے لیے عام لفظ ہے جو عمومًا مقدار اور صفات میں اضافہ کے لیے استعمال ہوتا ہے اور «اَلزَّیَادَۃ» بمعنی وہ اضافہ ہے جو کسی چیز کے پورا ہونے کے بعد بڑھایا جائے (مف) اب ان کی مثالیں دیکھیے :\nمثلاً : قرآن کریم میں ہے :\n«وَ زَادَہٗ بَسۡطَۃً فِی الۡعِلۡمِ وَ الۡجِسۡمِ» ( 2/247 )\nترجمہ : اور اللہ نے اس ( طالوت ) کو علم اور جسم میں زیادہ کشائش بخشی تھی ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ مَا تَغِیۡضُ الۡاَرۡحَامُ وَ  مَا تَزۡدَادُ» ( 13/8 )\nترجمہ : اور ( اللہ جانتا ہے ) پیٹ جو سکڑتے اور بڑھتے ہیں ۔","«زَادَ» کسی چیز کے پورا ہونے کے بعد مقدار اور صفات میں اضافہ کے لیے  استعمال ہوتا ہے ۔","بڑھنا","زاد ، ازداد","2:10-2:197-2:247-3:173-7:69-8:2-9:47-9:124-9:125-11:101-25:60-33:22-35:42-47:17-72:6",15
501,102,"ب","کَثُرَ ، کَثَّرَ","«کَثُر» اسکی ضد «قلّ» ہے بمعنی تعداد اور مقدار میں زیادہ ہونا ۔ تعداد کے لیے :\nمثلاً : قرآن کریم میں ہے :\n«وَدَّ کَثِیۡرٌ مِّنۡ اَہۡلِ الۡکِتٰبِ» ( 2/109 )\n ترجمہ : اہل کتاب میں سے اکثر یہ چاہتے ہیں ۔\nاور مقدار کے لیے  ارشاد باری تعالیٰ ہے :\n«مِمَّا قَلَّ مِنۡہُ اَوۡ کَثُرَ ؕ نَصِیۡبًا مَّفۡرُوۡضًا» ( 4/7 )\n ترجمہ : اس ( ترکہ ) سے ، خواہ یہ تھوڑا ہو یا زیادہ ، حصے مقرر شدہ ہیں ۔\nاور «کَثّر»  عمومًا تعداد میں اضافہ کے لیے آتا ہے ۔\n مثلاً : قرآن کریم میں ہے :\n«وَاذۡکُرُوۡۤا اِذۡ کُنۡتُمۡ قَلِیۡلًا فَکَثَّرَکُمۡ» ( 7/86 )\nترجمہ : اور ( اس وقت کو ) یاد کرو جب تم تھوڑے تھے تو اللہ نے تمہیں بڑھا دیا ۔\nاور «اَکْثَرَ» عمومًا مقدار میں اضافہ کے لیے آتا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«فَاَکۡثَرُوۡا فِیۡہَا الۡفَسَادَ» ( 89/12 )\nترجمہ : تو انہوں نے اس ( زمین ) میں زیادہ فساد برپاہ کر دیا ۔","«کَثُرَ» تعداد اور مقدار میں اضافہ کے لیے استعمال ہوتا ہے ۔","بڑھنا","کثر ، کثر","2:100-2:243-3:110-4:7-4:12-5:59-5:100-5:103-6:37-6:111-6:116-6:128-7:17-7:86-7:102-7:131-7:187-7:188-8:19-8:34-9:8-9:25-9:69-10:36-10:55-10:60-11:17-11:32-12:21-12:38-12:40-12:68-12:103-12:106-13:1-16:38-16:75-16:83-16:101-17:6-17:89-18:34-18:54-21:24-23:70-25:44-25:50-26:8-26:67-26:103-26:121-26:139-26:158-26:174-26:190-26:223-27:61-27:73-27:76-28:13-28:57-28:78-29:63-30:6-30:9-30:30-30:42-31:25-34:28-34:35-34:36-34:41-36:7-37:71-39:29-39:49-40:57-40:59-40:61-40:82-41:4-43:78-44:39-45:26-49:4-52:47-58:7-74:6-89:12",89
502,102,"ب","ضَاعَفَ","«ضِعْفٌ» بمعنی دو گنا اسکی ضد «نِصْف» ہے  «ضَعَفَ الشَّيء» بمعنی کسی چیز کے جیسا اتنا ہی اور (مف) خواہ یہ اضافہ مقدار میں ہو یا تعداد میں ۔ اور «ضَعَّف» بمعنی دگنا کرنا اور «ضَاعَفَ» میں زیادہ مبالغہ پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاللّٰہُ یُضٰعِفُ لِمَنۡ یَّشَآءُ ؕ وَاللّٰہُ وَاسِعٌ عَلِیۡمٌ» ( 2/261 )\nترجمہ : اور اللہ جس کے لیے چاہتا ہے اس سے بھی بڑھا دیتا ہے اور اللہ فراخی والا اور جاننے والا ہے ۔","«ضَاعَفَ» دگنا یا اس سے بھی زیادہ کرنے کے لیے استعمال ہوتا ہے ۔","بڑھنا","ضاعف","2:245-2:261-3:130-4:40-11:20-25:69-33:30-57:11-57:18-64:17",10
503,102,"ب","عَفَا","«عَفَا» کا عام معنی معاف کرنا ہے تاہم اس کا لغوی معنی یہ بھی ہے کہ کسی چیز کو اس کے حال پر چھوڑ دیا جائے تاکہ وہ بڑھ جائے ۔ «عَفَا اَلْشَعْر» بمعنی بالوں کو چھوڑ دینا تاکہ وہ بڑھ جائیں اور لمبے ہو جائیں ۔ ارشاد نبوی ﷺ ہے : «قَصُّوا الشَّوَارِبَ وَاعْفُوا اللُّحْیٰ» یعنی مونچھوں کو کترو اور داڑھیاں بڑھاؤ ۔ اور یہ لفظ لازم و متعدی دونوں طرح استعمال ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ بَدَّلۡنَا مَکَانَ السَّیِّئَۃِ الۡحَسَنَۃَ حَتّٰی عَفَوۡا» ( 7/95 )\nترجمہ : پھر ہم نے تکلیف کو آسودگی (خوشحالی) سے بدل دیا حتیٰ کہ وہ ( مال و اولاد میں ) بڑھ گئے ۔\nاور «عَفْو» بڑھی ہوئی اور ضرورت سے زائد چیز کو بھی کہتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَیَسۡئَلُوۡنَکَ مَا ذَا یُنۡفِقُوۡنَ ۬ ؕ قُلِ الۡعَفۡوَ»\nترجمہ : ( لوگ آپ سے پوچھتے ہیں کہ ( راہ خدا میں ) کیا خرچ کریں تو کہہ دو جو ضرورت سے زائد بچ رہے ۔","«عَفَا» کسی چیز کو اس کے حال پر چھوڑ دیا جائے تاکہ وہ بڑھ جائے ۔","بڑھنا","عفا","2:219-7:95",2
504,102,"ب","تَطَوُّع","«طَوْع» بمعنی دل کی خوشی سے تابعدار ہونا ہے (مف) اور «تَطَوُّع» کے اصل معنی تو بہ تکلف حکم بجا لانا ہے ۔ مگر عرف عام میں وہ نیکی کے کام اور عبادات ہیں جو فرائض کے علاوہ اپنے شوق سے سرانجام دی جائیں ۔ مثلاً نفلی نماز و صدقات وغیرہ ۔\nمثلاً : قرآن کریم میں ہے :\n«وَعَلَی الَّذِیۡنَ یُطِیۡقُوۡنَہٗ فِدۡیَۃٌ طَعَامُ مِسۡکِیۡنٍ ؕ فَمَنۡ تَطَوَّعَ خَیۡرًا فَہُوَ خَیۡرٌ لَّہٗ» ( 2/184 )\nترجمہ : اور جو شخص روزہ کی طاقت نہ رکھے تو اس کے بدلے ایک مسکین کو کھانا کھلائے ۔ پھر جو کوئی اپنے شوق سے نیکی میں اضافہ کرے تو یہ اس کے لیے بہتر ہے ۔","«تَطَوُّع» اپنی مرضی سے کوئی نیک عمل کرنا یا صدقہ وغیرہ دینا ۔","بڑھنا","تطوع","2:158-2:184-3:83-9:53-9:79-13:15-41:11",7
505,102,"ب","نَافِلَۃً","«نَفْل» واجب پر زیادتی کو کہتے ہیں (مف) اور «اَنْفَال» اموال غنیمت کو ۔ «نَفْل» اور «تَطَوُّع» میں فرق یہ ہے کہ  «تَطَوُّع» میں دل کی خوشی اور شوق بھی ضروری ہوتا مثلاً : قرآن کریم میں ہے :\n«وَمِنَ الَّیۡلِ فَتَہَجَّدۡ بِہٖ نَافِلَۃً لَّکَ» ( 17/79 )\nترجمہ : اور رات کو بیدار ہو کر نماز تہجد ادا کرو ۔ یہ تمہارے لیے زیادتی ہے ۔","«نَافِلَۃً» نفلی عبادات مثلاً : صدقہ خیرت ، تہجد نماز نفلی روزے وغیرہ ۔","بڑھنا","نافلۃً","8:1-17:79-21:72",3
506,102,"ب","اَرْبٰی","«رِبَا الْمَال» بمعنی مال کا زیادہ ہونا ۔ اور «رِبٰو» بمعنی سود ۔ اصل مال پر بلا محنت زائد اضافہ ۔ «رِبَا الْفَرْس» بمعنی گھوڑے کا سانس پھول جانا اور «رِبَا الْوَلْد» بمعنی بچے کا نشوونما پا کر پڑھنا ہے اور «اَرْبٰی» بمعنی کسی چیز کی تربیت کرنا یا پال پوس کر بڑھانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یَمۡحَقُ اللّٰہُ الرِّبٰوا وَیُرۡبِی الصَّدَقٰتِ» ( 2/276 )\nترجمہ : اللہ تعالیٰ سود کو مٹاتا اور صدقات کو بڑھاتا ہے ۔","«اَرْبٰی» بمعنی کسی چیز کی تربیت کرنا یا پال پوس کر بڑھانا ۔","بڑھنا","اربی","2:275-2:276-2:278-3:130-4:161-30:39",6
507,103,"ب","قَرْیَۃ","«قَرْیَۃ» ہر وہ جگہ جہاں لوگ جمع ہو کر آباد ہو جائیں «قَرْیَۃ» کہلاتا ہے خواہ یہ چھوٹی سی بستی ہو ، گاؤں ہو ، قصبہ ہو یا شہر اور اسکی جمع «قُریٰ» ہے ۔\nاور «اُمُّ الْقُرٰی» بمعنی مرکزی بستی یا شہر ۔ شہر مکہ کو بھی «اُمُّ الْقُرٰی» کہا گیا ہے اور «قَرْیَۃ» سے مراد بستی بھی ہے اور بستی والے بھی یا وہاں کے رہائشی (مف) مثلاً : قرآن کریم میں ہے :\n«وَسۡئَلِ الۡقَرۡیَۃَ الَّتِیۡ کُنَّا فِیۡہَا» ( 12/82 )\nترجمہ : اور جس بستی میں ہم ٹھہرے تھے اس ( کے رہنے والوں ) سے پوچھ لیجیے ۔","«قَرْیَۃ» بستی ( گاؤں یا شہر ) اور اس کے باشندے ہر وہ جگہ جہاں لوگ جمع ہو کر آباد ہو جائیں ۔","بستی","قریۃ","2:58-2:259-4:75-6:123-7:4-7:82-7:88-7:94-7:161-7:163-10:98-12:82-15:4-16:112-17:16-17:58-18:77-21:6-21:11-21:74-21:95-22:45-22:48-25:40-25:51-26:208-27:34-27:56-28:58-29:31-29:34-34:34-36:13-43:23-43:31-47:13-65:8",37
508,103,"ب","بَدْوُ","«بَدْوُ» بمعنی گاؤں ۔ دیہات یا دور افتادہ جگہ ۔ «بَدَا» بمعنی ظاہر ہونا اور «بَدْوُ» سے ایسی جگہ مراد ہے جہاں بلند عمارتیں نہ ہونے کی وجہ سے سب کچھ نمایاں طور پر نظر آتا ہو (مف) اسی سے «بَادِیَۃٌ» بمعنی صحرا ، «بَادِیٌ» بمعنی صحرا نشین اور «بَدَوِیٌّ» بمعنی دیہاتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَقَدۡ اَحۡسَنَ بِیۡۤ اِذۡ اَخۡرَجَنِیۡ مِنَ السِّجۡنِ وَجَآءَ بِکُمۡ مِّنَ الۡبَدۡوِ» ( 12/100 )\nترجمہ : اور اس ( اللہ ) نے مجھ پر احسان کیا کہ مجھے جیل سے نکالا اور آپ کو گاؤں سے یہاں لایا ۔","«بَدْوُ» دیہات ، گاؤں ایسی جگہ مراد ہے جہاں بلند عمارتیں نہ ہونے کی وجہ سے سب کچھ نمایاں طور پر نظر آتا ہو ۔","بستی","بدو","12:100",1
509,103,"ب","اَعْرَابُ","«عَرَبِیٌّ» بمعنی ملک عرب کا باشندہ اور «اَعْرَابِی» بمعنی عرب کا دیہاتی ۔ ملک عرب کے دیہات میں رہنے والا اور اسکی جمع «اَعْرَاب» ہے بمعنی بادیہ نشین ۔ پھر چونکہ دیہات کے رہنے والے عمومًا جاہل اور گنوار ہوتے ہیں لہذا اعراب کا لفظ گنوار کے معنوں میں بھی مستعمل ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمِنَ الۡاَعۡرَابِ مَنۡ یَّتَّخِذُ مَا یُنۡفِقُ مَغۡرَمًا» ( 9/98 )\nترجمہ : اور بعض دیہاتی ( گنوار) ایسے ہیں جو کچھ خرچ کرتے ہیں اسے تاوان سمجھتے ہیں ۔","«أَعْرَابُ» دیہات کے رہنے والے عربی باشندے ۔","بستی","اعراب","9:90-9:97-9:98-9:99-9:101-9:120-33:20-48:11-48:16-49:14",10
510,104,"ب","غَنَم","«غَنَم» کے معنی اصل میں ایسا مال ہاتھ لگنا ہے جو پہلے کسی کی ملکیت نہ ہو (م ۔ ل) پھر یہ لفظ ایسی بکریوں کے ریوڑ پر استعمال ہونے لگا جو کہیں سے ہاتھ لگ جائیں ۔ بعد میں اس لفظ کا اطلاق اس مال پر بھی ہونے لگا ۔ جو لڑائی کے بعد دشمن سے حاصل ہو (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاعۡلَمُوۡۤا اَنَّمَا غَنِمۡتُمۡ مِّنۡ شَیۡءٍ» ( 8/41 )\nترجمہ : اور جان رکھو کہ جو چیز تم ( کفار سے ) لوٹ کر لاؤ ۔\nپھر اس لفظ کا استعمال عام بکریوں کے ریوڑ سے بھی مخصوص ہو گیا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَدَاوٗدَ وَ سُلَیۡمٰنَ اِذۡ یَحۡکُمٰنِ فِی الۡحَرۡثِ اِذۡ نَفَشَتۡ فِیۡہِ غَنَمُ الۡقَوۡمِ» ( 21/78 )\nترجمہ : اور داؤد اور سلیمان ( کا حال بھی سن لو کہ ) جب وہ ایک کھیتی کا مقدمہ فیصلہ کرنے لگے جس میں کچھ لوگوں کی بکریاں رات کو چر گئی ( اور اسے روند ) گئی تھیں ۔","«غَنَم» صرف بکریوں کے ریوڑ کے لیے استعمال ہوتا ہے ۔","بکری","غنم","6:146-8:41-20:18-21:78",4
511,104,"ب","مَعَزَ","«مَعَزَ» بکریوں کو بھیڑوں سے الگ کرنے کے معنی میں استعمال ہوتا ہے۔ بکریاں اسم جنس ہیں ۔ بکری ، بکرا سب کے لیے یکساں ہے اور اس کا واحد «مَاعِز» ہے ۔ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«مِنَ الضَّاۡنِ اثۡنَیۡنِ وَمِنَ الۡمَعۡزِاثۡنَیۡنِ» ( 6/143 )\nترجمہ : بھیڑوں میں سے دو ( دو ) اور بکریوں میں سے دو ( دو ) ۔","«مَعَزَ» بکریوں کو بھیڑوں سے الگ کرنے کے معنی میں استعمال ہوتا ہے ۔","بکری","معز","6:143",1
512,105,"ب","اِنْبَثَّ","«بَثَّ» کے معنی منتشر کرنا اور دور دور تک پھیلا دینا ہے (م ۔ ر) اور «اِنْبَثَّ» کے معنی کسی چیز کا متفرق ہو کر سب اطراف میں دور تک پھیل جانا ہے ۔ اور اس میں پھیلنے والی چیز کے ارادہ کا کچھ دخل نہیں ہوتا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّ  بُسَّتِ الۡجِبَالُ  بَسًّا فَکَانَتۡ ہَبَآءً  مُّنۡۢبَثًّا» ( 56/5،6 )\nترجمہ : اور پہاڑ ٹوٹ کر ریزہ ریزہ ہو جائیں ۔ پھر غبار ہو کر اڑنے لگیں ۔","«اِنْبَثَّ» متفرق ہونا اور دور دورتک پھیل جانا ۔ (اسمیں ارادے کا دخل نہیں ہوتا )","بکھرنا","انبث","56:6",1
513,105,"ب","اِنْتَشَرَ","«نشر» کے معنی پھیلانا اور مشہور کرنا (م ۔ ر) اور «اِنْتَشَر» کے معنی کسی مجمع یا جلوس وغیرہ سے لوگوں کا اٹھ کر چلے جانا اور اپنی اپنی راہ لے لینا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاِذَا قُضِیَتِ الصَّلٰوۃُ فَانۡتَشِرُوۡا فِی الۡاَرۡضِ وَابۡتَغُوۡا مِنۡ فَضۡلِ اللّٰہِ» ( 62/10 )\nترجمہ : پھر جب نماز ( جمعہ ) ہو چکے تو اپنی اپنی راہ لو ۔ اور خدا کا فضل ( معاش ) تلاش کرو ۔","«اِنْتَشَرَ» مجمع کا متفرق ہونا اور اپنی اپنی راہ لینا ۔ ( اپنے ارادہ سے )","بکھرنا","انتشر","30:20-33:53-54:7-62:10",4
514,105,"ب","اِنْفَضَّ","«فَضَّ» کے معنی کسی چیز کو اس طرح توڑنا کہ وہ الگ الگ ہو جائے اور «اِنْفِضَاض» بمعنی شیشہ وغیرہ کے ٹکڑے ٹکڑے ٹوٹ ٹوٹ کر الگ الگ ہوتے جانا (م ۔ ر) گویا «اِنْفَضَّ» کے معنی کسی چیز کے سب کے سب اجزاء کامنتشر ہوجانا اور بکھرجا نا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِذَا رَاَوۡا تِجَارَۃً اَوۡ لَہۡوَۨا انۡفَضُّوۡۤا اِلَیۡہَا وَتَرَکُوۡکَ قَآئِمًا» ( 62/11 )\nترجمہ : اور جب یہ لوگ سودا بکتا یا تماشا ہوتا دیکھتے ہیں تو ادھر بھاگ جاتے ہیں اور تمہیں ( کھڑے کا ) کھڑا چھوڑ جاتے ہیں ۔","«اِنْفَضَّ» کسی چیز کے پورے اجزاء کا آہستہ آہستہ منتشر ہوجانا اور بکھر جانا ۔","بکھرنا","انفض","3:159-62:11-63:7",3
515,105,"ب","اِنْتَثَرَ","«نَثَرَ» ہر اس چیز کو کہتے ہیں جو کسی چیز سے جھڑ کر الگ ہوجائے ، بکھر جائے  ۔ اور «اِنْتِشَار» ناک جھاڑنے کو کہتے ہیں ۔ (م ر) ابن فارس «نَثَر» کے معنی کسی متفرق چیز کو نیچے ڈال دینا لکھتے ہیں ۔ ان کے اپنے الفاظ میں «کلمۃ تَدُلُّ عَلیٰ اِلْقَاءِ شَیْءٍ مُّتَفَرِّقٍ (م ۔ ل)» اور «نَثَر» غیر منظوم عبارت کو بھی کہتے ہیں (یعنی جس عبارت میں ترتیب اور نظم نہ ہو)  ۔ نیز «اِنْتَثَر» صرف غیر جاندار کے لیے آتا ہے :\nمثلاً : قرآن کریم میں ہے :\n«اِذَا السَّمَآءُ انۡفَطَرَتۡ وَاِذَا الۡکَوَاکِبُ انۡتَثَرَتۡ» ( 82/1،2 )\nترجمہ : جب آسمان پھٹ جائے گا اور تارے جھڑ جائیں گے ۔","«اِنْتَثَرَ» الگ ہونا اور گر پڑنا ( غیر جاندار چیزوں کے لیے آتا ہے )","بکھرنا","انتثر","82:2",1
516,105,"ب","اِسْتَطَارَ","«طَارَ» بمعنی کسی پردار جانور یا چیز کا ہوا میں اڑنا اور «طَائِرُ» بمعنی پرندہ ہے اور اسکی جمع «طَيْرٌ» اور « اِسْتَطَار» بمعنی کسی چیز کا ہوا میں بلند ہو کر پھیلنا اور بکھر جانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یُوۡفُوۡنَ بِالنَّذۡرِ وَیَخَافُوۡنَ یَوۡمًا کَانَ شَرُّہٗ  مُسۡتَطِیۡرًا» ( 76/7 )\nترجمہ : وہ لوگ نذریں پوری کرتے ہیں اور اس دن سے جس کی سختی پھیل رہی ہو گی خوف رکھتے ہیں ۔","«اِسْتَطَارَ» کسی چیز کا فضا میں بکھر کر پھیل جانا ۔","بکھرنا","استطار","76:7",1
517,106,"ب","رَفَعَ","«رَفَعَ» کے معنی بلند کرنا ۔ اور اگر یہ فعل زمین سے کوئی چیز اٹھانے اور بلند کرنے سے متعلق ہو تو اس کی ضد «وَضَعَ» آتی ہے ۔ اور اگر آواز کو بلند کرنے سے متعلق ہو تو اس کی ضد «خَفَضَ» آتی ہے ۔\nمثلاً : کسی چیز کو بلند کرنے کے لیے قرآن کریم میں ہے :\n«وَاِذۡ یَرۡفَعُ  اِبۡرٰہٖمُ  الۡقَوَاعِدَ مِنَ الۡبَیۡتِ وَ اِسۡمٰعِیۡلُ» ( 2/127 )\nترجمہ : اور جب ابراہیم ؑ اور اسماعیل ؑ بیت اللہ کی بنیادیں اونچی کر رہے تھے ۔\nاور آواز بلند کرنے کے لیے قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡا لَا تَرۡفَعُوۡۤا اَصۡوَاتَکُمۡ  فَوۡقَ صَوۡتِ النَّبِیِّ» ( 49/2 )\nترجمہ : اے اہل ایمان ! اپنی آوازیں پیغمبر کی آواز سے اونچی نہ کرو ۔","«رَفَعَ» کسی چیز کو زمین سے بلند کرنا ، اونچا کرنا ۔","بلند","رفع","2:63-2:93-2:127-2:253-4:154-4:158-6:83-6:165-7:176-12:76-12:100-13:2-19:57-24:36-35:10-43:32-49:2-55:7-58:11-79:28-88:18-94:4",22
518,106,"ب","اَنْشَأ","«نَشَو» بمعنی کسی چیز کا اٹھنا اور بلند ہونا (م ل) نیز اس کے معنی کسی کی تربیت کر کے اسے پروان چڑھانا بھی ہے (مف) اور «نَشَاۃ» اٹھان کے معنی میں استعمال ہوتا ہے ۔ یہاں اس لفظ کے بلند ہونے کا پہلو زیر بحث ہے ۔ اور «اَنْشَأ» بمعنی کسی چیز کو پیدا کرنا ، اٹھانا اور پروان چڑھانا ۔\nمثلاً : قرآن کریم میں ہے :\n«ہُوَالَّذِیۡ یُرِیۡکُمُ  الۡبَرۡقَ خَوۡفًا وَّطَمَعًا وَّ یُنۡشِئُ السَّحَابَ الثِّقَالَ» ( 13/12 )\nترجمہ : وہی تو ہے جو تم کو ڈرانے اور امید دلانے کے لیے بجلی دکھاتا اور بھاری بھاری بادل پیدا کرتا ہے ۔ ( جالندھریؒ ) اٹھاتا ہے ( عثمانیؒ ) ۔","«اَنْشَأ» کسی چیز کو پیدا کرنا ۔ تربیت دینا اور اوپر اٹھانا ۔","بلند","انشأ","2:259-6:6-6:83-6:98-6:133-6:141-11:61-13:12-21:11-21:21-23:14-23:19-23:31-23:42-23:78-25:3-25:40-25:47-28:45-29:20-35:9-36:79-43:11-43:18-44:35-53:32-53:47-55:24-56:35-56:61-56:62-56:72-67:15-67:23-88:22-",35
519,106,"ب","عَلَا","«عَلَا» بمعنی بلند ہونا اور اس کی ضد «سَفَلَ» ہے ۔ یہ لفظ اجسام واعیان (یعنی مرتبہ) دونوں جگہ استعمال ہوتا ہے ۔ یعنی جگہ اور کسی جسم کی بلندی کے لیے بھی اور مرتبہ کی بلندی کے لیے بھی استعمال ہوتاہے ۔ نیز یہ لفظ مذموم (بری تعریف) اور محمود (اچھی تعریف) دونوں صورتوں میں استعمال ہوتا ہے ۔ اب مثالیں ملاحظہ فرمائیے :\n(1) جگہ کی بلندی کے لیے  قرآن کریم میں ہے :\n«وَّرَفَعۡنٰہُ مَکَانًا عَلِیًّا» ( 19/57 )\nترجمہ : اور ہم نے ان ( ادریس ؑ ) کو اونچی جگہ اٹھا لیا تھا ۔ ( جالندھریؒ ) اور اٹھا لیا اس کو ایک اونچے مکان ( عثمانیؒ )\n(2) مرتبہ کی بلندی کے لیے قرآن کریم میں ہے :\n«وَجَعَلۡنَا لَہُمۡ لِسَانَ صِدۡقٍ عَلِیًّا» ( 19/50 )\nترجمہ : اور ہم نے ان ( انبیاء ؑ ) کا ذکرِ جمیل بلند کیا ۔ ( جالندھریؒ ) اور کہا ان کے واسطے سچا بول اونچا ۔ ( عثمانیؒ )\n(3) مذموم صورت کی مثال : قرآن کریم میں ہے :\n«اِنَّ فِرۡعَوۡنَ عَلَا فِی الۡاَرۡضِ» ( 28/4 )\nترجمہ : بیشک فرعون نے ملک میں سر اٹھا رکھا تھا ۔","«عَلَا» کا استعمال عام ہے لیکن بلند درختوں اور خصوصًا کھجور کے درخت کی بلندی کے لیے استعمال ہوتا ہے ۔","بلند","علا","4:34-9:40-19:50-19:57-23:91-28:4",6
520,106,"ب","بَسَقَ","«بَسَقَ» صرف بلند و بالا درختوں اور خصوصًا کھجور کے بلند ہونے کے لیے استعمال ہوتا ہے ۔ (ف ل 43)\nمثلاً : قرآن کریم میں ہے :\n«وَالنَّخۡلَ بٰسِقٰتٍ لَّہَا طَلۡعٌ نَّضِیۡدٌ» ( 50/10 )\nترجمہ : اور بلند کھجوریں جن پر تہ بر تہ خوشے لگے ہیں ۔","«بَسَقَ» لفظی معنی بلند ہونا ، بلند و بالا درختوں اور خصوصًا کھجور کے درخت کے  بلند ہونے کے لیے استعمال ہوتا ہے ۔ ","بلند","بسق","50:10",1
521,106,"ب","شَمَخٌ","«شَمَخٌ» کا لفظ کسی چیز کے  بڑا اور بلند ہونے پر دلالت کرتا ہے (م ل) پہاڑوں اور بلند و بالا عمارتوں کی بلندی کے لیے استعمال ہوتا ہے (ف ل 43) فلک بوس بلندی ۔ مثلاً : قرآن کریم میں ہے :\n«وَّجَعَلۡنَا فِیۡہَا رَوَاسِیَ شٰمِخٰتٍ» ( 77/27 )\nترجمہ : اور ہم نے اس ( زمین ) پر اونچے اونچے پہاڑ رکھ دیے ۔","«شَمَخٌ» پہاڑوں اور بلند و بالا عمارتوں کی بلندی کے لیے استعمال ہوتا ہے ۔","بلند","شمخ","77:27",1
522,107,"ب","جَعَلَ","«جَعَلَ» بنانے کے لیے «جَعَلَ» کا استعمال عام ہے ۔ خواہ اس کام کا تعلق ایجاد اور تخلیق سے ہو یا محض ترتیب وغیرہ سے ۔\nمثلاً : قرآن کریم میں ہے :\n«الَّذِیۡ جَعَلَ لَکُمُ الۡاَرۡضَ فِرَاشًا وَّ السَّمَآءَ بِنَآءً» ( 2/22 )\nترجمہ : جس نے تمہارے لیے زمین کو بچھونا اور آسمان کو چھت بنایا ۔","«جَعَلَ» اسکے معنی بنانے کے ہیں مگر اس کا استعمال عام ہے خواہ اس کام کا تعلق ایجاد اور تخلیق سے ہو یا محض ترتیب وغیرہ  دینے سے ۔","بنانا","جعل","2:19-2:22-2:30-2:66-2:125-126-2:128-2:143-2:224-2:259-2:260-3:41-3:61-3:126-3:156-3:176-4:5-4:15-4:19-4:33-4:75-4:90-4:91-4:141-4:144-5:6-5:13-5:20-5:48-5:60-5:97-5:103-6:1-6:6-6:9-6:25-6:39-6:91-6:96-6:97-6:100-6:107-6:112-6:122-6:123-6:124-6:125-6:136-6:165-7:10-7:27-7:47-7:69-7:74-7:138-7:143-7:150-7:189-7:190-8:10-8:29-8:37-9:19-9:40-10:5-10:14-10:24-10:59-10:67-10:73-10:85-10:87-10:100-11:82-11:118-12:15-12:55-12:62-12:70-12:100-13:3-13:16-13:33-13:38-14:30-14:35-14:37-14:40-15:16-15:20-15:74-15:91-15:96-16:56-16:57-16:62-16:72-16:78-16:80-16:81-16:91-16:93-16:124-17:2-17:6-17:8-17:12-17:18-17:22-17:29-17:33-17:39-17:45-17:46-17:60-17:80-17:99-18:1-18:7-18:32-18:48-18:52-18:57-18:59-18:90-18:94-18:95-18:96-18:98-19:6-19:7-19:10-19:21-19:24-19:30-19:31-19:32-19:49-19:50-19:96-20:29-20:53-20:58-21:8-21:15-21:30-21:31-21:32-21:34-21:58-21:70-21:72-21:73-21:91-22:25-22:34-22:36-22:53-22:67-22:78-23:13-23:41-23:44-23:50-23:94-24:40-24:43-24:63-25:10-25:20-25:23-25:31-25:35-25:37-25:45-25:47-25:53-25:54-25:61-25:62-25:74-26:21-26:29-26:84-26:85-27:34-27:61-27:62-27:86-28:4-28:5-28:35-28:38-28:41-28:71-28:72-28:73-28:83-29:10-29:15-29:27-29:67-30:21-30:48-30:54-32:8-32:9-32:23-32:24-33:4-34:18-34:19-34:33-35:11-35:39-36:8-36:9-36:27-36:34-36:80-37:63-37:77-37:98-37:158-38:5-38:26-38:28-39:6-39:8-39:21-40:61-40:64-40:79-41:9-41:10-41:29-41:44-42:8-42:11-42:50-42:52-43:3-43:10-43:12-43:15-43:19-43:28-43:33-43:45-43:56-43:59-43:60-45:18-45:21-45:23-46:26-48:26-48:27-49:13-50:26-51:42-51:51-56:36-56:65-56:70-56:73-56:82-57:7-57:26-57:27-57:28-59:10-60:5-60:7-65:2-65:3-65:4-65:7-67:5-67:15-67:23-68:35-68:50-69:12-71:7-71:12-71:16-71:19-72:25-73:17-74:12-74:31-75:39-76:2-77:21-77:25-77:27-78:6-78:9-78:10-78:11-78:13-87:5-90:8-105:2-105:5",305
523,107,"ب","بَنٰی","«بَنٰی» بمعنی عمارت وغیرہ بنانا ۔ اور «بُنْیَان» بمعنی عمارت ، دیوار یا کوئی تعمیر (مف) اور ابن فارس کے نزدیک «بَنَاءَ الشَّیْ بِضَمٍّ بَعْضَہٗ اِلیٰ بَعْضٍ» (م ۔ ل) ( یعنی کسی چیز کو اس طرح بنانا کہ اس کا ایک حصہ دوسرے میں ضم ہو جائے )\nمثلاً : قرآن کریم میں ہے :\n«وَالسَّمَآءَ  بَنَیۡنٰہَا بِاَیۡىدٍ وَّ اِنَّا لَمُوۡسِعُوۡنَ» ( 51/47 )\nترجمہ : اور آسمان کو ہم نے بنایا اپنے ہاتھوں سے اور ہم (اس کو) توسیع دینے والے ہیں ۔","«بَنٰی» بمعنی عمارت وغیرہ بنانا ۔","بنانا","بنی","9:109-9:110-16:26-18:21-37:97-40:36-50:6-51:47-61:4-78:12",10
524,107,"ب","صَنَعَ","«صَنَعَ» کوئی چیز فنی مہارت کے ساتھ خوبصورت بنانا (مف) اور «صَنَّاع» ماہر کاریگر یا فنکار کو کہتے ہیں اور «اِصْطَنَعَ» کے معنی کسی کام کو فنی مہارت اور خاص توجہ سے بنانا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَاصۡنَعِ الۡفُلۡکَ بِاَعۡیُنِنَا وَ وَحۡیِنَا» ( 11/37 )\nترجمہ : اور اے نوح ؑ ! ہمارے روبرو اور ہماری ہدایت کے مطابق کشتی بناؤ ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَاصۡطَنَعۡتُکَ لِنَفۡسِیۡ» ( 20/41 )\nترجمہ : اور ( اے موسیٰ ؑ ! ) بنایا میں نے تجھ کو خاص اپنے لیے ۔","«صَنَعَ» کسی چیز کو فنی مہارت سے بنانا ۔","بنانا","صنع","5:14-5:63-7:137-11:16-11:37-11:38-13:31-16:112-18:104-20:39-20:41-20:69-21:80-23:27-24:30-27:88-29:45-35:8",18
525,107,"ب","اِتَّخَذَ","«اَخَذَ» بمعنی پکڑنا ، لینا ، کسی چیز کو حاصل کرنا ۔ احاطہ میں لینا اور «اِتَّخَذَ» دو مفعولوں کی طرف متعدی ہو کر «جَعَلَ» کے جاری مجرمیں ہوتا ہے ۔ (مف) اس میں نہ ترتیب کو کچھ دخل ہوتا ہے نہ تخلیق کو ۔ اور اس میں استمرارتسلسل (یعنی  لگاتار جاری رہنے کا عمل)  پایا جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَقَالَ الَّذِی اشۡتَرٰىہُ مِنۡ مِّصۡرَ لِامۡرَاَتِہٖۤ اَکۡرِمِیۡ مَثۡوٰىہُ عَسٰۤی اَنۡ یَّنۡفَعَنَاۤ  اَوۡنَتَّخِذَہٗ وَلَدًا» ( 12/21 )\nترجمہ : اور مصر میں جس شخص نے یوسف ؑ کو خریدا ، اپنی بیوی سے کہنے لگا اس کو عزت و اکرام سے رکھو کچھ عجب نہیں کہ یہ ہمیں فائدہ پہنچائے یا ہم اسے اپنا بیٹا بنا لیں ۔","«اِتَّخَذَ» دو مفعولوں کی طرف متعدی ہو کر بنانے کے معنی دیتا ہے اور اس میں استمرار (یعنی  لگاتار جاری رہنے کا عمل) پایا جاتا ہے ۔ ","بنانا","اتخذ","2:51-2:67-2:80-2:92-2:116-2:125-2:165-2:231-3:28-3:64-3:80-3:118-3:140-4:25-4:89-4:119-4:125-4:139-4:144-4:150-4:153-5:5-5:51-5:57-5:58-5:81-5:116-6:14-6:70-6:74-7:30-7:51-7:74-7:146-7:148-7:152-9:16-9:23-9:31-9:98-9:99-9:107-10:68-11:92-12:21-13:16-16:51-16:67-16:68-16:92-16:94-17:2-17:40-17:73-17:111-18:4-18:15-18:21-18:50-18:51-18:56-18:61-18:63-18:86-18:102-18:106-19:17-19:35-19:81-18:88-19:92-21:17-21:21-21:24-21:26-21:36-23:91-23:110-25:2-25:3-25:18-25:27-25:28-25:30-25:41-25:43-25:57-26:29-26:129-28:9-29:25-29:41-31:6-35:6-36:23-36:74-38:63-39:3-39:4-39:43-42:6-42:9-43:16-43:32-45:9-45:10-45:23-45:35-46:28-58:16-60:1-63:2-72:3-73:9-73:19-76:29-78:39",117
526,108,"ب","غَلَّقَ","«غَلَقَ» بمعنی بند کر دینا اور اس کی ضد «فَکَّ» بمعنی رہا کرانا یا چھڑانا ہے (م ۔ ل) اور «غَلْق» بمعنی قفل یا تالا کے ہیں (منجد) اور «غَلَّقَ الْبَاب» کے معنی دروازہ کو مضبوطی سے بند کرنا ، کنڈی وغیرہ لگانا یا مقفل کرنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَغَلَّقَتِ الۡاَبۡوَابَ وَ قَالَتۡ ہَیۡتَ لَکَ» ( 12/23 )\nترجمہ : اور اس عورت ( زلیخا ) نے دروازے بند کر لیے اور کہنے لگی یوسف جلدی آؤ ۔","«غَلَّقَ» دروازہ وغیرہ بند کرنے کے لیے استعمال ہوتا ہے ۔","بند","غلق","12:23",1
527,108,"ب","وَصَدَ","«وَصَدَ» اس طرح بند کرنے کو کہتے ہیں کہ بند شدہ چیز سے کچھ باہر نہ نکل سکے ۔ ابن فارس کے الفاظ «اَلْوَصْدُ خَتْمُ شَیْءٍ اِلیٰ شَیْءٍ ( م ل )» اور «اَوْصَدْتُ الْقِدْرَ» کے معنی ہانڈی پرڈھکنا دینا تاکہ بھاپ نہ نکل سکے ۔ (م ۔ ر) اور «اَوْصَدْتُ الْبَابَ»  دروازہ بند کرنا ۔ لیکن اس کا اطلاق اس وقت ہو گا جب کوئی دوسری کھڑکی یا دروازہ یا روشندان وغیرہ کھلا نہ ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«عَلَیۡہِمۡ نَارٌمُّؤۡصَدَۃٌ» ( 90/20 )\nترجمہ : یہ لوگ آگ میں بند کر دیے جائیں گے ۔","«وَصَدَ» کسی چیز کو یوں بند کرنا کہ کوئی چیز باہر نہ نکل سکے ۔","بند","وصد","2:217-4:167-13:33-16:88-27:43-40:37-47:1-47:32-47:34-48:25",10
528,108,"ب","قَصَرَ","«قَصَرَ» بنیادی طور پر دو معنوں میں استعمال ہوتا ہے ۔ (1) کسی چیز کا اپنی انتہا اور ہدف تک نہ پہنچنا (2) «حَبَسَ» یعنی بند ہونا (م ۔ ل) ۔ یہاں دوسرا معنی زیر بحث ہے ۔ کہتے ہیں «قَصَرَ فِی بَیْتِہٖ» اپنے گھر میں محبوس یا بند ہو گیا ۔\nمثلاً : قرآن کریم میں ہے :\n«حُوۡرٌ مَّقۡصُوۡرٰتٌ فِی الۡخِیَامِ» ( 55/72 )\nترجمہ : حوریں ہیں رکی رہنے والی خیموں میں ( عثمانیؒ )","«قَصَرَ» کسی جگہ بند ہونے کے معنوں میں  استعمال ہوتا ہے۔","بند","قصر","7:74-22:45-25:10-55:72-77:32",5
529,108,"ب","قَبَضَ","«قَبَضَ» کے معنی کسی چیز کو مٹھی میں بند کرنا اور «قَبَضَۃٌ» مٹھی کو کہتے ہیں (مف) لہذا «قَبَضَ» ، سکڑنا ، کم کرنا ، تنگ کرنا اور بند کرنا سب معنوں میں مستعمل ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یَاۡمُرُوۡنَ بِالۡمُنۡکَرِ وَیَنۡہَوۡنَ عَنِ الۡمَعۡرُوۡفِ وَیَقۡبِضُوۡنَ اَیۡدِیَہُمۡ» ( 9/67 )\nترجمہ : ( منافق ) برے کام کرنے کو کہتے اور نیک کاموں سے منع کرتے ۔ اور ( خرچ کرنے سے ) ہاتھ بند کیے رہتے ہیں ۔","«قَبَضَ» کسی چیز کو مٹھی میں بند کرنا اور اپنے قبضہ میں لے لینا ۔","بند","قبض","2:245-9:67-20:96-25:46-39:67-67:19",6
530,109,"ب","حَبَکَ","«حَبَّاک» بمعنی جولاہا ( کپڑا بننے والا) اور «حَبَکَ الثَّوْبَ» بمعنی اس نے کپڑا بُنا ( م ۔ ق ) اور «حَبَکَ حَابِکَ الثَّوْب» بمعنی جولاہے کا کپڑے کو کاریگری سے بننا ۔ عمدہ بننا (منجد) اور «حَبَک» بمعنی راستہ بھی ہے اور اسکی جمع «حُبُک» ہے (مف ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَالسَّمَآءِ ذَاتِ الۡحُبُکِ» ( 51/7 )\nترجمہ : اور قسم ہے جالی دار آسمان کی۔\n( یعنی آسمان پر ستاروں کا جال بچھا ہوا ہے ) ( عثمانیؒ )\n اور آسمان کی قسم جس میں رستے ہیں ( جالندھریؒ )","«حَبَکَ» کسی چیز کو بُننے کے معنی میں استعمال ہوتا ہے  جیسے کپڑا وغیرہ بُننا ۔","بُننا","حبک","51:7",1
531,109,"ب","وَضَنَ","«وَضَنَ» کے اصل معنی زرہ بانی (یعنی کپڑے پر سونے کے تار کا کام کرنا) کے ہیں ۔ اور اِسْتَعَارَۃً  کسی چیز کو مضبوطی کے ساتھ بننے پر بولا جاتا ہے (مف) اور «مَوضُون» بمعنی باریک بنی ہوئی ۔ یا سونے چاندی سے بنی ہوئی چیز (منجد)\nمثلاً : قرآن کریم میں ہے :\n«عَلٰی سُرُرٍ مَّوۡضُوۡنَۃٍ مُّتَّکِئِیۡنَ عَلَیۡہَا مُتَقٰبِلِیۡنَ» ( 56/15،16 )\nترجمہ : ( لعل و یاقوت وغیرہ سے ) جڑے ہوئے تختوں پر آمنے سامنے تکیہ لگائے ہوں گے ۔","«وَضَنَ» کسی چیز کو مضبوطی کے ساتھ بُننے کے لئے بولا جاتا ہے ۔","بُننا","وضن","56:15",1
532,110,"ب","ثَقَلَ","«ثَقَلَ» مسافر کا سامان ، بوجھ ، وزن وغیرہ (منجد) اور یہ عمومًا مادی اور حِسّی بوجھ کے لیے استعمال ہوتا ہے ۔ اور «ثَقِیْل» کی ضد خفیف ہے ۔ بمعنی وزن میں ہلکا ۔ مثلاً : قرآن کریم میں ہے :\n«اِنۡفِرُوۡا خِفَافًا وَّ ثِقَالًا» ( 9/41 )\nترجمہ : نکل کھڑے ہو جاؤ ہلکے پھلکے ہو تو بھی اور بھاری بھرکم ہو تو بھی  ۔\nاور «ثَقَل» کی جمع «اَثقَال» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَتَحۡمِلُ اَثۡقَالَکُمۡ اِلٰی بَلَدٍ لَّمۡ تَکُوۡنُوۡا بٰلِغِیۡہِ اِلَّا بِشِقِّ الۡاَنۡفُسِ» ( 16/7 )\nترجمہ : اور یہ تمہارے بوجھ لاد کر ایسے شہر تک لے جاتے ہیں جہاں تم جان جوکھوں میں ڈالے بغیر نہیں پہنچ سکتے تھے۔ حقیقت یہ ہے تمہارا پروردگار بہت شفیق، بڑا مہربان ہے۔\nاور «ثَقِیْل» بمعنی وزنی اور بوجھل اشیاء  اس کا استعمال کبھی کبھی معنوی طور پر بھی ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّا سَنُلۡقِیۡ عَلَیۡکَ قَوۡلًا ثَقِیۡلًا» ( 73/5 )\nترجمہ : ہم عنقریب آپ ﷺ پر ایک بھاری فرمان نازل کریں گے ۔\nیہاں «ثَقِیْل» سے مراد ایسی بات ، کلام یا فرمان ہے جو طبیعت کو بہت بوجھل محسوس ہو اور اس پرعمل پیرا ہونا بڑی ہمت کا کام ہو ۔","«ثَقَلَ» عمومًا مسافر کے سامان اور دوسری وزنی چیزوں کے لیے استعمال ہوتا ہے ۔","بوجھ","ثقل","4:40-7:8-7:57-7:187-7:189-9:41-10:61-13:12-16:7-21:47-23:102-29:13-31:16-34:3-34:22-35:18-52:40-55:31-68:46-73:5-76:27-99:2-99:7-99:8-101:6",25
533,110,"ب","حَمْل","«حَمَلَ» بوجھ اٹھانے اور بوجھ لادنے کو کہتے ہیں ۔ اور «حَمْل» ایسے بوجھ کو کہتے ہیں جو کوئی چیز باطن اپنے اندر اٹھائے ہوئے ہو ۔ جیسے پیٹ میں بچہ ، درخت کا پھل یا بادل میں پانی (مف)\nمثلاً : قرآن کریم میں ہے :\n«فَلَمَّا تَغَشّٰہَا حَمَلَتۡ حَمۡلًا خَفِیۡفًا فَمَرَّتۡ بِہٖ» ( 7/189 )\nترجمہ : جب مرد عورت کے پاس جاتا ہے تو اسے ہلکا سا حمل ہو جاتا ہے  اور وہ اس کے ساتھ چلتی پھرتی ہے ۔\nاور «حِمْل» اس بوجھ کو کہتے ہیں جو حسی طور پر کسی کی پیٹھ پر لاد دیا جائے ( مف ) لیکن صاحب منتہی الارب کے نزدیک «حِمْل» کے معنی بارِسر یا بارِ پشت ہے ( م ر ) یعنی اٹھانے والا جتنا زیادہ سے زیادہ بوجھ اٹھا سکتا ہو وہی اس کے لیے حِمْل ہے ۔ اور یہ تعریف زیادہ صحیح معلوم ہوتی ہے ۔ اور قرآن کریم سے اس مفہوم کی تائید بھی ہوتی ہے :\n«قَالُوۡا نَفۡقِدُ صُوَاعَ الۡمَلِکِ وَلِمَنۡ جَآءَ بِہٖ حِمۡلُ بَعِیۡرٍ وَّاَنَا بِہٖ زَعِیۡمٌ» ( 12/72 )\nترجمہ : انہوں نے کہا کہ : ہمیں بادشاہ کا پیمانہ نہیں مل رہا اور جو شخص اسے لاکر دے گا ، اس کو ایک اونٹ کا بوجھ ( انعام میں ) ملے گا ، اور میں اس ( انعام کے دلوانے ) کی ذمہ داری لیتا ہوں ۔","«حَمْل» ایسے بوجھ کو کہتے ہیں جو بوجھ اٹھانے والا بوجھ اپنے اندر اٹھائے ہوئے ہو ۔ جیسے  پیٹ میں بچہ ، درخت کا پھل یا بادل میں پانی۔","بوجھ","حمل","2:248-2:286-6:31-6:146-7:189-9:92-11:40-12:36-12:72-13:8-16:7-16:25-17:3-17:70-19:22-19:27-19:58-20:87-20:100-20:101-20:111-22:2-23:22-24:54-29:12-29:13-29:60-31:14-33:72-35:11-35:18-36:41-40:7-40:80-41:47-46:15-54:13-62:5-65:4-65:6-69:11-69:14-69:17",43
534,110,"ب","وَقْر","بوجھ کے لیے «وَقْر» کا استعمال معنوی طور پر ہوتا ہے ۔ کہتے ہیں «فِیْ صَدْرِہٖ وَقْرٌ» اس کے دل میں (کینہ) کا بوجھ ہے ۔‘‘ (منجد) اسی طرح «فِیْ اُذُنِہٖ وَقْرٌ» ’’ اس کے کان میں بوجھ ہے ‘‘ یعنی اسے ثقل سماعت یا بہرا پن کا عارضہ ہے اور اونچا سنتا ہے ۔ بعض لوگ «وَقْر» کا معنی کانوں کا میل بھی کرتے ہیں مگر پہلا معنی زیادہ ابلغ ہے ۔ اور کانوں کا میل اسے محدود کر دیتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَّجَعَلۡنَا عَلٰی قُلُوۡبِہِمۡ اَکِنَّۃً اَنۡ یَّفۡقَہُوۡہُ وَفِیۡۤ اٰذَانِہِمۡ وَقۡرًا» ( 17/46 )\nترجمہ : اور ان کے دلوں پر ہم نے پردے ڈال دیئے ہیں کہ وہ اسے سمجھیں اور ان کے کانوں میں بوجھ ۔\nاور «وِقْر» کا لفظ اس معنوی بوجھ کی اس زیادہ سے زیادہ مقدار کو کہتے ہیں جو اٹھانے والے کی استطاعت اور طاقت کے مطابق ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«وَالذّٰرِیٰتِ ذَرۡوًا فَالۡحٰمِلٰتِ  وِقۡرًا» ( 51/1،2 )\nترجمہ :’’ بکھیرنے والی ہواؤں کی قسم جو اڑا کر بکھیر دیتی ہیں ۔ پھر ان ہواؤں کی ( جو پانی کا ) بوجھ اٹھاتی ہیں ۔","«وَقْر» عمومًا معنوی بوجھ کے لیے آتا ہے ۔\nاور «وِقر» اٹھانے والے کی طاقت کے مطابق زیادہ سے زیادہ معنوی بوجھ ۔","بوجھ","وقر","6:25-17:46-18:57-31:7-41:5-41:44-51:2",7
535,110,"ب","وِزْر","«وِزْر»ابن فارس لکھتے ہیں کہ کوئی شخص جب اپنا کپڑا پھیلا کر اس میں اپنا بوجھ رکھ کر اور اٹھا کر چل دیتا ہے تو یہ «وِزْر» ہے ۔ اور اسی لیے «اَلْذَنْبُ» ( گناہ ) کو «وِزْر» (بوجھ) کہتے ہیں ۔ یعنی اپنے کیے ہوئے عمل کا بوجھ ۔ اور ایسے ہی «وِزْر» اسلحہ کو بھی کہتے ہیں اور اسکی جمع  «اَوْزَار» ہے (م ۔ ل) اور «اَوْزَرَ اِیْزَارًا» کے معنی چھپانا ، لے جانا اور پناہ دینا وغیرہ بھی آئے ہیں (منجد) اور اسی طرح «وَزَرُ» کے معنی کسی پہاڑ میں جائے پناہ کے بھی آئے ہیں (مف) اور «وِزْر» کا استعمال اکثر گناہوں کے بارِگراں کے لیے ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَہُمۡ یَحۡمِلُوۡنَ اَوۡزَارَہُمۡ عَلٰی ظُہُوۡرِہِمۡ ؕ اَلَا سَآءَ مَا یَزِرُوۡنَ» ( 6/31 )\nترجمہ : اور وہ اپنے ( اعمال کے ) بوجھ اپنی پیٹھوں پر اٹھائے ہوئے ہوں گے ۔ دیکھو جو بوجھ یہ اٹھا رہے ہیں بہت برا ہے ۔","«وِزْر» عمومًا گناہوں کے بوجھ کے  لیے بولا جاتا ہے ۔","بوجھ","وزر","6:31-6:164-16:25-17:15-20:87-20:100-35:18-39:7-53:38-94:2",10
536,110,"ب","اِصْر","«اَلْاِصْر» کے دو معنی ہیں  (1) گرہ لگانا اور (2) کسی چیز کو زبردستی روک لینا (مف ۔ م ل) اس لحاظ سے اپنے عہد و پیمان کی پابندی اور شرعی احکام کی تعمیل کی ذمہ داری کا بوجھ «اِصْر» ہے اور ابن فارس کے نزدیک ہر عقد ، عہد اور قرابت «اِصْر» ہے (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«رَبَّنَا وَلَا  تَحۡمِلۡ عَلَیۡنَاۤ اِصۡرًا کَمَا حَمَلۡتَہٗ عَلَی الَّذِیۡنَ مِنۡ قَبۡلِنَا» ( 2/286 )\nترجمہ : اے پروردگار ! ہم پر ایسا بوجھ نہ ڈالنا جیسا تو نے ہم سے پہلے لوگوں پر ڈالا تھا ۔\nپھر «اِصْر» کا اطلاق راہ حق کو اختیار کرنے میں ان رکاوٹوں پر بھی ہوتا ہے جو کسی معاشرہ کے رسم و رواج کی وجہ سے پیش آئی ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَیَضَعُ عَنۡہُمۡ اِصۡرَہُمۡ وَ الۡاَغۡلٰلَ الَّتِیۡ کَانَتۡ عَلَیۡہِمۡ» ( 7/157 )\nترجمہ : ر ان سے اتاردیں گے ان کے بوجھ اور طوق جو ان (کی گردنوں) پر پڑے ہوں گے ۔","«اِصْر» بمعنی عہد و پیمان ، شرعی احکام کی ذمہ داریاں یا رسم و رواج کی جکڑ بندیاں ۔","بوجھ","اصر","2:286-3:81-7:157",3
537,110,"ب","کَلٌّ","«کَلٌّ» بمعنی محتاج ، عیال ، یتیم ، درماندہ ، عاجز اور بوجھ کے ہیں ۔ (منجد م ۔ ر ۔ م ل) اور «کَلّ» سے مراد تربیت کی ذمہ داری یا نان و نفقہ کا بوجھ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَحَدُہُمَاۤ اَبۡکَمُ لَا یَقۡدِرُعَلٰی شَیۡءٍ وَّہُوَ کَلٌّ عَلٰی مَوۡلٰىہُ ۙ اَیۡنَمَا یُوَجِّہۡہُّ لَایَاۡتِ بِخَیۡرٍ» ( 16/76 )\nترجمہ : ان دونوں میں سے ایک گونگا ہے ( بے اختیار و ناتواں ) کہ کسی چیز پر قدرت نہیں رکھتا اور اپنے مالک پر بوجھ بنا ہوا ہے ۔ وہ جہاں اسے بھیجتا ہے  بھلائی نہیں لاتا ۔","«کَلٌّ» کسی بے اختیار اور ناتواں یتیم  کی تربیت کا بوجھ  اٹھانے کے لیے آتا ہے ۔","بوجھ","کل","16:76",1
538,110,"ب","وَزْن ، مَوَازِیْن","«مَوَازِیْن» بمعنی ترازو جس سے کسی چیز کو تولا اور وزن کیاجاتاہے ۔ اور «وَزْن» وہ بوجھ جو ترازو کے کسی پلڑے میں تلنے کے لیے رکھا جائے ۔ اور میزان بمعنی ترازو بھی اور مقدارِ وزن بھی اور اسکی جمع «مَوَازِیْن» (مف ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَاَمَّا مَنۡ  ثَقُلَتۡ مَوَازِیۡنُہٗ فَہُوَ فِیۡ عِیۡشَۃٍ رَّاضِیَۃٍ» ( 101/6،7 )\nترجمہ : تو جس کے اعمال کے وزن بھاری نکلیں گے وہ دل پسند عیش میں ہو گا ۔","«وَزْن ، مَوَازِیْن» وہ بوجھ  جو وزن کرنے کے لیے ترازو میں رکھ دیا جائے ۔","بوجھ","وزن ، موازین","7:8-7:9-17:35-18:105-21:47-23:102-23:103-26:182-55:9-83:3-101:6-101:8",12
539,111,"ب","ثَقُلَ","«ثَقُلَ» بمعنی تول میں کسی چیز کا بھاری ہونا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَمَّا مَنۡ  ثَقُلَتۡ مَوَازِیۡنُہٗ فَہُوَ فِیۡ عِیۡشَۃٍ رَّاضِیَۃٍ» ( 101/6،7 )\nترجمہ : تو جس کے اعمال کے وزن بھاری نکلیں گے وہ دل پسند عیش میں ہو گا ۔","«ثَقُلَ» بمعنی تول میں کسی چیز کا بھاری ہوجانا ۔","بوجھل","ثقل","7:8-7:57-7:187-7:189-9:41-13:12-16:7-23:102-29:13-35:18-52:40-68:46-73:5-76:27-99:2-101:6",16
540,111,"ب","کَسَلَ","«کَسَلَ» سستی کی وجہ سے طبیعت کا بوجھل اور بھاری ہونا اور «اَلْکَسْل» بمعنی ایسے معاملہ میں گرانباری (بھاری بوجھ) ظاہر کرنا جس میں گرانباری مناسب نہ ہو (مف) ۔ مثلاً : منافقین کے بارے میں ارشاد باری تعالیٰ ہے :\n«وَلَا یَاۡتُوۡنَ الصَّلٰوۃَ  اِلَّا وَ ہُمۡ کُسَالٰی» ( 9/54 )\nترجمہ : اور وہ نماز کو آتے ہیں تو سست اور کاہل ہو کر ۔","«کَسَلَ» سستی کی وجہ سے طبیعت کا بوجھل ہونا ۔","بوجھل","کسل","4:142-9:54",2
541,111,"ب","اٰد","«اٰدَ» بمعنی بوجھ یا محنت و مشقت کی زیادتی کی وجہ سے طبیعت کا بوجھل ہونا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَلَا یَئُوۡدُہٗ حِفۡظُہُمَا ۚ وَ ہُوَالۡعَلِیُّ الۡعَظِیۡمُ» ( 2/255 )\nترجمہ : اور زمین و آسمان کی حفاظت اللہ تعالیٰ کو گرانبار نہیں کرتی ۔","«اٰدَ» محنت و مشقت کی زیادتی کی وجہ سے طبیعت کا بوجھل ہونا ۔","بوجھل","اد","2:255",1
542,111,"ب","کَبُر ، کَبِیْرَۃٌ","«کَبُرَ» کسی کام کو مشکل اور بھاری سمجھنے کی وجہ سے طبیعت کا گراں بار (بوجھل) ہونا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ کَانَ کَبُرَ عَلَیۡکَ اِعۡرَاضُہُمۡ» ( 6/35 )\nترجمہ : اور اگر ان (کافروں) کی بےتوجہی آپ پر گراں گزرتی ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«وَاسۡتَعِیۡنُوۡا بِالصَّبۡرِ وَالصَّلٰوۃِ ؕ وَاِنَّہَا لَکَبِیۡرَۃٌ اِلَّا عَلَی الۡخٰشِعِیۡنَ» ( 2/45 )\nترجمہ : اور مدد حاصل کرو صبر سے اور نماز سے۔ اور یقینایہ بہت بھاری شے ہے مگر ان عاجزوں پر (بھاری نہیں ہے)۔ ","«کَبُرَ» کسی کام کو مشکل اور بھاری سمجھنے کی وجہ سے طبیعت کا بوجھل ہونا ۔","بوجھل","کبر ، کبیرۃ","2:45-2:143-10:71-17:51-18:5-20:23-24:11-40:35-42:13-44:16-53:18-61:3-74:35-79:20-79:34-87:12",16
543,112,"ب","شَیْخ","«شَیْخ» بمعنی بزرگ ۔ خواہ عمر کے لحاظ سے بڑا ہو ، یا علم فضیلت اور مرتبہ میں بلند مقام رکھتا ہو ۔ (منجد) شیخ دراصل تکریم کا لفظ ہے ۔ «شَیْخُ الْمِرْأَۃ» عورت کے خاوند کو بھی کہہ دیتے ہیں خواہ وہ چھوٹی عمر کا ہو ۔ تاہم قرآن کریم سے یہ لفظ عمر کے لحاظ سے بوڑھا کے معنی میں ہی استعمال ہوا ہے (ج ۔ شیوخ)\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ لِتَبۡلُغُوۡۤا اَشُدَّکُمۡ ثُمَّ لِتَکُوۡنُوۡا شُیُوۡخًا» ( 40/67 )\nترجمہ : پھر تم اپنی جوانی کو پہنچتے ہو ۔ پھر بوڑھے ہو جاتے ہو ۔","«شَیْخ» بمعنی (بوڑھا) عام طور پر بوڑھے شخص کے لیے استعمال ہوتاہے ۔ نیز عزت و شرف اور علم والے کو بھی شیخ کہہ دیتے ہیں ۔","بوڑھا","شیخ","11:72-12:78-28:23-40:67",4
544,112,"ب","شِیْب","«شَابَ» بمعنی سفید بالوں والا ہونا ۔ کہتے ہیں «شَابَتْ رُءُوْسُ الْاٰکَام» یعنی ٹیلوں کی چوٹیاں برف سے سفید ہو گئیں ۔ اور «اَشْیَب» کے معنی سفید سروالا ۔ «شِیْب» اسی کی جمع ہے ۔ (منجد) اور «شَیْب» بمعنی بڑھاپا (مف) صاحب فقہ اللغۃ اسے جوانی اور بڑھاپے کا درمیانی حصۃ قرار دیتے ہیں اور 30 سے 40 سال تک عمر بتلاتے ہیں (ف ۔ ل 91) بہرحال «شِیْب» وہی ہو سکتا ہے جس کے بال سفید ہونا شروع ہو چکے ہوں ۔\nمثلاً : قرآن کریم میں ہے :\n«فَکَیۡفَ تَتَّقُوۡنَ اِنۡ کَفَرۡتُمۡ یَوۡمًا یَّجۡعَلُ الۡوِلۡدَانَ شِیۡبَۨا» ( 73/17 )\nترجمہ : تم اگر کافر رہے تو اس دن کیسے پناہ پاؤ گے جو دن بچوں کو بوڑھا کر دے گا ۔","«شِیْب» ایسا شخص جس کے بال سفید ہونا شروع ہو چکے ہوں ۔","بوڑھا","شیب","19:4-30:54-73:17",3
545,112,"ب","کَھَل","«کَھَل» بمعنی ادھیڑ عمر کا ہونا اور «کَھْل» 30 سال سے 50 سال کی عمر والے کو کہتے ہیں اور «کَاھَلَ الرَّجُل» سے مراد آدمی کا شادی کرنا ہے (منجد) جبکہ صاحب صَاحِب فِقْہُ الْلُغَۃ  کے مطابق چالیس سے ساٹھ سال کی درمیانی عمر کے لیے بولا جاتا ہے  (ف ل 9) ان کے اپنے الفاظ میں «ثُمَّ مَا دَامَ بَیْنَ الثَّلَاثِیْنَ وَالْاَرْبَعْیِنَ فَھُو شَابٌ ۔ ثُمَّ ھُوَ کَھْلٌ : اِلیٰ اَنْ یَسْتَوْفَی السِّتِّیْنَ» ۔\n مثلاً : قرآن کریم میں ہے :\n«وَ یُکَلِّمُ النَّاسَ فِی الۡمَہۡدِ وَ کَہۡلًا» ( 3/46 )\nترجمہ : اور وہ ( مسیح ابن مریم ) ماں کی گود میں اور بڑی عمر کا ہو کر ( دونوں حالتوں میں ) لوگوں سے ( یکساں ) گفتگو کرے گا ۔","«کَھَل» چالیس سے ساٹھ سال کی درمیانی عمر کے لیے بولا جاتا ہے ۔","بوڑھا","کھل","3:46-5:110",2
546,112,"ب","عَجُوْز","«عَجُوْز» صرف مؤنث کے لیے آتا ہے ۔ بمعنی بوڑھی عورت جس کی اولاد ہونا بند ہو چکی ہو ۔ اور «عَجُزَۃ» کسی کے آخری بچہ کو کہتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَتۡ یٰوَیۡلَتٰۤیءَ اَلِدُ وَ اَنَا عَجُوۡزٌ وَّ ہٰذَا بَعۡلِیۡ  شَیۡخًا» ( 11/72 )\nترجمہ : اس نے کہا اے ہے میرے بچہ ہو گا ۔ میں تو بڑھیا ہوں اور یہ میرے میاں بھی بوڑھے ہیں ۔","«عَجُوْز» بوڑھی عورت کو کہتے ہیں ( یہ صرف مؤنث کیلئے استعمال ہوتا ہے )","بوڑھا","عجوز","11:72-26:171-37:135-51:29",4
547,112,"ب","مُعَمَّر","«مُعَمَّر» بمعنی عمر رسیدہ کافی عمر تک زندگی پانے والا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَا یُعَمَّرُ مِنۡ مُّعَمَّرٍ وَّلَا یُنۡقَصُ مِنۡ عُمُرِہٖۤ اِلَّا فِیۡ کِتٰبٍ» ( 35/11)\nترجمہ : اور نہ کسی بڑی عمر والے کو عمر زیادہ دی جاتی ہے اور نہ اس کی عمر کم کی جاتی ہے مگر ( سب کچھ ) کتاب میں ( لکھا ہوا ) ہے ۔","«مُعَمَّر» ساٹھ  سال کی عمر کے بعد تک زندہ رہنے والا ۔","بوڑھا","معمر","2:96-10:16-15:72-16:70-21:44-22:5-26:18-28:45-35:11-35:37-36:68",11
548,112,"ب","عَوَان ، فَارِض","«عَانَ» بمعنی ادھیڑ عمر والا ہونا ۔ انسان ، حیوان ، عورت ، مرد سب کے لیے آتا ہے ۔ اور «عَوَان» بمعنی ادھیڑ عمر (منجد) اور «فَارِض» عمر رسیدہ گائے یا بیل اور اس کی ضد «بِکْر» ہے ۔ یعنی بچھڑا جو ابھی جوان نہ ہوا ہو ۔ (مف) نیز بمعنی کنواری لڑکی (منجد)\nمثلاً : قرآن کریم میں ہے :\n«قَالَ اِنَّہٗ یَقُوۡلُ اِنَّہَا بَقَرَۃٌ لَّا فَارِضٌ وَّلَا بِکۡرٌ  ؕ عَوَانٌۢ بَیۡنَ ذٰلِکَ» ( 2/68 )\nترجمہ : موسیٰ ؑ نے کہا ، تمہارا پروردگار کہتا ہے کہ وہ بیل نہ تو بوڑھا ہو اور نہ بچھڑا بلکہ ان کے درمیان ( یعنی ادھیڑ عمر ) ہو ۔","«عَوَان» ادھیڑ عمر ۔ انسان حیوان ، مرد عورت  سب کے لیے استعمال ہوتا ہے ۔\n«فَارِض» عمر رسیدہ گائے یا بیل کے لیے مخصوص لفظ ۔","بوڑھا","عوان ، فارض","2:68",1
549,113,"ب","بَلَیَ","«بَلِیَ» کسی قابلِ استعمال چیز کا پرانا ہو جانے کی وجہ سے کمزور پڑ جانا ۔ «بَلَی الثَّوْب» : کپڑا پرانا ہو گیا (مف) پنجابی میں ہنڈ جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَوَسۡوَسَ اِلَیۡہِ الشَّیۡطٰنُ قَالَ یٰۤـاٰدَمُ ہَلۡ اَدُلُّکَ عَلٰی شَجَرَۃِ الۡخُلۡدِ وَ مُلۡکٍ لَّا یَبۡلٰی» ( 20/120 )\nترجمہ : تو وسوسہ ڈالا اس کے ذہن میں شیطان نے اس نے کہا : اے آدم ؑ ! کیا میں بتاؤں تجھے ہمیشہ رہنے والے درخت اور ایسی بادشاہی کے بارے میں جو کبھی پرانی نہ ہو ۔","«بَلِیَ» کسی چیز کا بوسیدہ اور پرانا ہوجانا ۔","بوسیدہ","بلی","20:120",1
550,113,"ب","وَھِیَ","«وَھِیَ» کسی چیز کے جوڑ ڈھیلے پڑ جانا (م ل) «وَھْیَ الثَّوْبَ وَالْحَبْل» ، کپڑے یا رسی کابوسدگی کی وجہ سے پھٹنے لگنا ( ف ل 39 ) یا چمڑے کا بوسیدگی کی وجہ سے پھٹ جانا (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«وَانۡشَقَّتِ السَّمَآءُ فَہِیَ یَوۡمَئِذٍ وَّاہِیَۃٌ» ( 69/16 )\nترجمہ : اور آسمان پھٹ جائے گا وہ تو اس دن کمزور ( اور بوسیدہ ہو گا ) ","«وَھِیَ» کسی چیز کے جوڑ ڈھیلے پڑ جانا ۔","بوسیدہ","وھی","69:16",1
551,113,"ب","رَمَّ","«رَمَّ» بمعنی قابلِ مرمت ہونا (بوجہ بوسیدگی) اور «رَمَّ الْحَبْل» بمعنی رسی کا ٹوٹ جانا ۔ اور «رَمَّ الْعَظْم» ۔ ہڈی کا بوسیدہ ہو جانا اور «رِمَّۃ» پرانی ہڈی کو کہتے ہیں جو بوسیدہ اور بھربھری ہو چکی ہو ( فل 54 ) یا پھر پرانی رسی کے ٹکڑے کو جو علیحدہ ہو گیا ہو (منجد)\nمثلاً : قرآن کریم میں ہے :\n«مَا تَذَرُ مِنۡ شَیۡءٍ اَتَتۡ عَلَیۡہِ اِلَّا جَعَلَتۡہُ کَالرَّمِیۡمِ» ( 51/42 )\nترجمہ : وہ ( نا مبارک ہَوا ) جس چیز پر چلتی اس کو ریزہ ریزہ کیے بغیر نہ چھوڑتی ۔","«رَمّ» بوسیدگی کی وجہ سے ٹکڑے الگ ہونے لگنا ۔","بوسیدہ","رم","36:78-51:42",2
552,113,"ب","رَفَتَ","«رَفَتَ» بمعنی توڑنا ۔ کوٹنا اور «رَفَتَ الْعَظْم» بمعنی ہڈی کا چورا چورا ہونا ۔ اور «اَلْرَفَات» بمعنی ہر ٹوٹی ہوئی چیز ۔ بوسیدہ (منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَقَالُوۡۤاءَ اِذَا کُنَّا عِظَامًا وَّرُفَاتًاءَ اِنَّا لَمَبۡعُوۡثُوۡنَ خَلۡقًا جَدِیۡدًا» ( 17/49 )\nترجمہ : اور کہتے ہیں کہ جب ہم ( مر کر بوسیدہ ) ہڈیاں اور چورا چورا ہو جائیں گے تو کیا ازسر نو اٹھائے جائیں گے ؟","«رَفَتَ» بوسیدگی کی وجہ سے ریزہ ریزہ ہو جانا ۔","بوسیدہ","رفت","17:49-17:98",2
553,113,"ب","نَخِرَ","«نَخِرَ» کے معنی بوسیدہ ہونا اور ریزہ ہونا ہے (منجد) «نَخِرَۃٌ» بمعنی ہڈی کا بوسیدہ ہو کر اندر سے کھوکھری یا خالی ہو جانا یا اس میں سوراخ ہو جانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یَقُوۡلُوۡنَ ءَاِنَّا لَمَرۡدُوۡدُوۡنَ فِی الۡحَافِرَۃِ ءَ اِذَا کُنَّا عِظَامًا نَّخِرَۃً» ( 79/10،11 )\nترجمہ : ( کافر ) کہتے ہیں کیا ہم الٹے پاؤں پھر لوٹیں گے ؟ بھلا جب ہم کھوکھلی ہڈیاں ہو جائیں گے ( تو پھر زندہ کیے جائیں گے ) ۔","«نَخِرَ» ( ہڈی کا ) بوسیدگی کی وجہ سے اندر سے کھوکھلی ہو جانا ۔","بوسیدہ","نخر","79:11",1
554,114,"ب","لَفَظَ ، لَفِظَ","«لَفَظَ» کے معنی ( منہ سے ) پھینکنا اور «لُفَاظَۃٌ» منہ سے پھینکی ہوئی چیز یا دسترخوان سے جھاڑی ہوئی چیز کو کہتے ہیں اور لفظ بمعنی منہ سے بولا جانے والا کلمہ اور لفظ کی جمع الفاظ ہے (منجد) اور «لَافِظ» چکی کو کہتے ہیں کہ وہ آٹا باہر پھینکتی جاتی ہے (م ۔ ق) اور لفظ بمعنی کسی بات کا زبان سے ادا ہونا خواہ وہ ایک آدھ لفظ ہی ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«مَا یَلۡفِظُ مِنۡ  قَوۡلٍ اِلَّا لَدَیۡہِ رَقِیۡبٌ عَتِیۡدٌ» ( 50/18 )\nترجمہ : کوئی بات اس کی زبان پر نہیں آتی مگر ایک نگہبان اس کے پاس تیار رہتا ہے ۔","«لَفَظَ» جو کچھ منہ سے کہے وہ لفظ  کہلاتا ہے ۔ ","بولنا","لفظ ، لفظ","50:18",1
555,114,"ب","نَطَقَ","«نَطَقَ» ایسی بات کہنا جس کے معنی سمجھ میں آ سکیں ۔ «اَلْمَالُ النَّاطِقُ وَالصَّامِت» بولنے والے مال سے مراد حیوان ہیں ، اور چپ رہنے والے مال سے مراد سونا چاندی ہے ۔ اور چونکہ حیوان بھی ناطق (بولنے والے) ہیں اور وہ ایک دوسرے کی بولی سمجھ لیتے ہیں ۔ اور «مَنْطِقَ الطَّیْر» بمعنی جانوروں کی بولی ۔ لیکن یہ لفظ بالذات صرف انسان کے متعلق بولا جاتا ہے ۔ اور اہل منطق صرف انسان کو ہی حیوان ناطق (بولنے والا) کہتے ہیں اور «نُطْقٌ» سے قوت گویائی مراد لیتے ہیں ( سب سے پہلے ارسطو نے انسان کو حیوان ناطق کہا تھا ۔ مگر لغوی لحاظ سے یہ لفظ ذوی العقول کے لیے استعمال ہو سکتا ہے ) ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَا یَنۡطِقُ عَنِ الۡہَوٰی اِنۡ ہُوَاِلَّا وَحۡیٌ یُّوۡحٰی» ( 53/3،4 )\nترجمہ : اور ( محمد ﷺ ) خواہش نفس سے منہ سے بات نہیں نکالتے یہ ( قرآن تو ) حکم خدا ہے جو ان کی طرف وحی کیا جاتا ہے ۔\nاور جو حضرت سلیمان ؑ کے متعلق قرآن کریم میں آیا ہے کہ :\nمثلاً : ارشاد باری تعالیٰ ہے :\n«یٰۤاَیُّہَا النَّاسُ عُلِّمۡنَا مَنۡطِقَ الطَّیۡرِ» ( 27/16 )\nترجمہ : اے لوگو ! ہمیں خدا کی طرف سے پرندوں کی بولی سکھائی گئی ہے ۔\nتو یہاں «نَطَقَ» کا لفظ حضرت سلیمان ؑ کے سمجھ لینے کی نسبت سے آیا ہے اور پرندوں کے بولنے کی نسبت سے ۔\nپھر جس طرح «نَطَقَ» ظاہری ہے اور اس سے مراد قابلِ فہم بات ہے اسی طرح «نَطَقَ» باطنی بھی ہے جس سے مراد فہم و ادراک یا زبانِ حال ہوتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ہٰذَا کِتٰبُنَا یَنۡطِقُ عَلَیۡکُمۡ  بِالۡحَقِّ ؕ اِنَّا کُنَّا نَسۡتَنۡسِخُ مَا کُنۡتُمۡ تَعۡمَلُوۡنَ» ( 45/29 )\nترجمہ : یہ ہماری کتاب تمہارے بارے میں سچ سچ بول دے گی جو کچھ تم کیا کرتے تھے ، ہم لکھواتے جاتے تھے ۔","«نَطَقَ» قابلِ فہم بات کہنا یعنی ایسی بات کہنا جس کے معنی سمجھ میں آسکیں ۔","بولنا","نطق","21:63-21:65-23:62-27:16-27:85-37:92-41:21-45:29-51:23-53:3-77:35",11
556,114,"ب","فَصَحَ","«فَصُحَ» کے معنی کسی چیز کو آمیزش سے پاک و صاف کرنا ۔ اور «فَصَحَ اللَّبَن» کے معنی دودھ کے اوپر سے جھاگ اتار کر دودھ کو صاف کر لینا ہے ۔ اور «فَصَحَ الرَّجُل» اسی سے مستعار (یعنی لیا گیا) ہے جس کے معنی کسی شخص کا خوش گفتار ہونا اور اس کے کلام کا فضول اوربیکار بات سے پاک صاف ہونا ۔ اور موزوں تر الفاظ کا استعمال کرنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاَخِیۡ ہٰرُوۡنُ ہُوَاَفۡصَحُ مِنِّیۡ لِسَانًا فَاَرۡسِلۡہُ  مَعِیَ رِدۡاً یُّصَدِّقُنِیۡۤ»\nترجمہ : ( موسیٰ ؑ نے کہا ) میرے بھائی ہارون کی زبان مجھ سے زیادہ فصیح ہے تو ( اے اللہ ) اسے میرے ساتھ مددگار بنا کر بھیج کہ میری تصدیق کرے ۔","«فَصُحَ» خوش گفتار ہونا لگی لپٹی  سے پاک  صاف بات کرنا ۔","بولنا","فصح","28:34",1
557,114,"ب","اَعْرَبَ ۔ اَعْجَمَ","«اَلْاِعْرَاب» بمعنی کسی بات کو واضح کر دینا ۔ اور «اَعْرَبَ عَنْ نَفْسِہٖ» بمعنی اس نے بات کو وضاحت سے بیان کر دیا ۔ «اَلْعَرَبِیُّ» بمعنی وضاحت سے بیان کرنے والا بھی ہے اور واضح اور فصیح کلام بھی (مف)\nمثلاً : قرآن کریم میں ہے :\n«اِنَّاۤ اَنۡزَلۡنٰہُ  قُرۡءٰنًا عَرَبِیًّا» ( 12/2 )\nترجمہ : ہم نے اس قرآن کو واضح اور فصیح زبان میں نازل کیا ہے ۔\nاور «اَلْعُجَمَۃ» کے معنی ابہام اور اِخفا کے ہیں اور «اَلْاَعْجَمُ» اس شخص کو کہتے ہیں جس کی زبان فصیح نہ ہو خواہ وہ زبان عربی ہی کیوں نہ ہو ۔ اہل عرب اپنے آپ کو فصیح زبان کے مالک اور دوسروں کو غیر فصیح تصور کرتے تھے اور تمام غیر عرب کو «اَلْعَجْم» کہتے تھے ۔ «اَلْعَجَمِیُّ» اسی طرف منسوب ہے ۔ اور چوپایوں کو بھی «عَجْمَاء» کہتے ہیں کہ وہ (اپنے دل کی بات) کو ٹھیک طور پر ادا نہیں کر سکتے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَوۡ جَعَلۡنٰہُ قُرۡاٰنًا اَعۡجَمِیًّا لَّقَالُوۡا لَوۡلَا فُصِّلَتۡ اٰیٰتُہٗ ؕ ءَؔاَعۡجَمِیٌّ وَّعَرَبِیٌّ» ( 41/44 )\nترجمہ : اور اگر ہم قرآن کو غیر عربی زبان میں نازل کرتے تو یہ لوگ کہتے کہ اس کی آیتیں ( ہماری زبان میں ) کیوں کھول کر بیان نہیں کی گئیں ۔","«اَعْرَب» وضاحت سے بات کرنا ۔\n«اَعْجَمَ»غیر واضح اورمبہم یعنی گول مول بات کرنا ۔","بولنا","اعرب ۔ اعجم","12:2-13:37-16:103-20:113-26:195-26:198-39:28-41:3-41:44-42:7-43:3-46:12",12
558,114,"ب","تَکَلَّمَ","«کَلَّمَ» بمعنی کلام کرنا یا بات کرنا اور «تَکَلَّم» بمعنی بولنا یا بات کو منہ پر لانا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«لَّا یَتَکَلَّمُوۡنَ اِلَّا مَنۡ اَذِنَ لَہُ الرَّحۡمٰنُ» ( 78/38 )\nترجمہ : کوئی شخص بول نہ سکے گا مگر جسے اللہ تعالیٰ اجازت بخشے گا ۔","«تَکَلَّمَ» کسی با معنی بات کوزبان پرلانا ، جسے دوسرا سن رہا ہو ۔","بولنا","تکلم","3:41-5:110-11:105-19:10-23:108-24:16-27:82-30:35-36:65-78:38",10
559,114,"ب","لَحِنَ","«لَحِنَ» بمعنی عام مستعمل طریقہ اور اسلوب سے پھیر دینا اور «لحن القول» بمعنی مروجہ طرزِ بیان یا اندازِ گفتگو سے ہٹ کر کوئی دوسرا طریقہ استعمال کرنا اور «اَلْحَنُ» فصیح کلام کو بھی کہتے ہیں (م ۔ ق) اور زبان آور اور فصیح شخص کو بھی (مف) اور «لَحَّنَ» بمعنی سریلی آواز سے پڑھنا  ۔ لحنِ داودی مشہور ہے ۔ تاہم «لَحَن» کا اصلی معنیٰ لہجہ کی تبدیلی ہے  کہ اس سے ایک ہی فقرہ کبھی مثبت کبھی منفی اور کبھی استفہامیہ بن جاتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَتَعۡرِفَنَّہُمۡ  فِیۡ لَحۡنِ الۡقَوۡلِ» ( 47/30 )\nترجمہ :’’ اور تم انہیں اندازِ گفتگو ہی سے پہچان لو گے ۔","«لَحِنَ» عام روش سے ہٹ کر کوئی دوسرا اندازِ گفتگو اختیار کرنا ۔","بولنا","لحن","47:30",1
560,115,"ب","اَسَالَ","«سَالَ» کے معنی ( مائع اشیاء کا ) بہنا یا بہہ نکلنا اور «سَیل» کے معنی بہنے والا پانی ، سیلاب اور «سَیَّال» بمعنی زور سے بہنے والا (منجد) نیز ہر بہنے والی چیز کو «سَیَّال» کہتے ہیں ۔ اور «اَسَالَ» کے معنی کسی ( بہنے والی یا مائع چیز ) کو بہا دینا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاَسَلۡنَا لَہٗ عَیۡنَ الۡقِطۡرِ» ( 34/12 )\nترجمہ : اور اس ( داؤد ؑ ) کے لیے ہم نے تانبے کا چشمہ بہا دیا تھا ۔","«اَسَالَ» کسی بھی بہنے والی چیز کو بہانا ۔","بہنا","اسال","13:17-34:12-34:16",3
561,115,"ب","اَفَاض","«فَاضَ ، فَیْض» کے معنی کسی چیز کا بسہولت جاری ہو جانا یا پانی کا کسی جگہ سے اچھل کر بہہ نکلنا کہتے ہیں (م ۔ ل - مف) ۔ «اَفَاضَ السَّیْل» پانی کا کثرت سے ہونا اور وادی کے کناروں سے بہہ نکلنا اور «فَاضَتْ عَیْنٰہُ» یعنی اس کی آنکھوں سے آنسو جاری ہو گئے اور «اَفَاضَ» کے معنی ( پانی وغیرہ کا ) بسہولت بہانا ۔ «اَفَاضَ اِنَاہُ» اس نے اپنا برتن لبالب بھرا کہ پانی اوپر سے نیچے گرنے لگا گویا اس کا اصل معنی ( OVER FLOW ) ہونا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَنَادٰۤی اَصۡحٰبُ النَّارِ اَصۡحٰبَ الۡجَنَّۃِ اَنۡ اَفِیۡضُوۡا عَلَیۡنَا مِنَ الۡمَآءِ» ( 7/50 )\nترجمہ :’’ اور دوزخی بہشتوں سے ( گڑگڑا کر ) کہیں گے کہ کسی قدر زائد پانی ہم پر بھی بہا دو ۔","«فَاضَ» کسی بہنے والی چیز کا کنارے  سے بہنے لگنا ۔","بہنا","افاض","5:83-7:50-9:92",3
562,115,"ب","سَکَبَ","«سَکَبَ» کے معنی ( پانی وغیرہ کا ) گرانا اور بہانا ہے ۔ اور «اَلسَّکْب» لگاتار بارش کو یا موٹے موٹے قطروں والی بارش کو کہتے ہیں ۔  (م ۔ ر -  منجد)  جس کا پانی بہہ نکلے ۔ اور «اَلْاُسْکُوْب» بمعنی لگاتار جھڑی (منجد) گویا «سَکَبَ» میں پانی وغیرہ کے گرنے یا بہنے کے ساتھ تسلسل یا دوام کا تصور بھی پایا جاتا ہے ۔ اور «مَآءٍ مَّسْکُوْبٍ» بمعنی بہنے والا پانی\nمثلاً : قرآن کریم میں ہے :\n«وَّظِلٍّ مَّمۡدُوۡدٍ وَّمَآءٍ مَّسۡکُوۡبٍ» ( 56/31 )\nترجمہ : اور سایہ لمبا اور پانی بہتا ہوا ۔ ( عثمانیؒ )","«سَکَبَ» کسی بہنے والی چیز کو اتنی مقدارمیں گرانا کہ بہہ  پڑے ۔","بہنا","سکب","56:31",1
563,115,"ب","سَفَکَ","«سَفَکَ» بمعنی خون یا پانی بہانا ۔ لیکن اس کا اطلاق زیادہ تر خون بہانے پر ہوتا ہے ۔ اور «سفّاک» خونریز انسان کو کہتے ہیں (م ۔ ر)\nمثلاً : قرآن کریم میں ہے :\n«وَاِذۡ اَخَذۡنَا مِیۡثَاقَکُمۡ لَا تَسۡفِکُوۡنَ دِمَآءَکُمۡ» ( 2/84 )\nترجمہ :’’ اور جب ہم نے تم سے عہد لیا کہ آپس میں کشت و خون نہ کرو گے ۔","«سَفَکَ» خون بہانے کے لیے عام استعمال ہے ۔","بہنا","سفک","2:30-2:84",2
564,115,"ب","سَفَحَ","«سَفَحَ» کے معنی بھی لغوی لحاظ سے خون یا پانی بہانے کے ہیں (مف) اور بمعنی کسی بہنے والی چیز کا سرعت سے بہنا اور جاری ہونا ( فق ل 257 ) قرآن کریم میں «دَمًا مَّسْفُوْحًا» بہتا ہوا خون کے معنوں میں آیا ہے ۔ تاہم اس لفظ کا عمومًا استعمال منی یا پانی ناجائز طور پر بہانے یا بدکاری کرنے کے لیے ہوتا ہے : «مُسَافِحٌ» کے معنی بدکار مرد اور «مُسَافِحَۃ» بمعنی بدکار عورت ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاُحِلَّ لَکُمۡ مَّا وَرَآءَ ذٰلِکُمۡ اَنۡ تَبۡتَغُوۡا بِاَمۡوَالِکُمۡ مُّحۡصِنِیۡنَ غَیۡرَ مُسٰفِحِیۡنَ» ( 4/24 )\nترجمہ : اور ان ( محرمات ) کے علاوہ اور سب عورتیں تم پر حلال ہیں ۔ اس طرح مال خرچ کر کے ان سے نکاح کر لو ( بشرطیکہ ) نکاح سے مقصود عفت قائم رکھنا ہو نہ کہ شہوت رانی ۔","«سَفَحَ» کسی بہنے والی چیز کا تیزی سے بہنا ۔","بہنا","سفح","4:24-4:25-5:5",3
565,115,"ب","فَجَرَ","«فَجَرَ» کے اصل معنی کسی چیز کو وسیع طور پر پھاڑنے کے ہیں (مف) بہنے والی چیزوں کے متعلق اس کا استعمال وسعت پر دلالت کرتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَقَالُوۡا لَنۡ نُّؤۡمِنَ لَکَ حَتّٰی تَفۡجُرَ لَنَا مِنَ الۡاَرۡضِ یَنۡۢبُوۡعًا»\nترجمہ : ( اور کافر کہنے لگے ہم تجھ پر ہرگز ایمان نہ لائیں گے تا آنکہ تم ہمارے لیے زمین سے چشمہ نہ بہا دو ۔\nبہنا کے لیے «سَالَ» اور «فَاضَ» اوپر گزر چکے ہیں ۔\n اب ان کی مثالیں دیکھیے ۔\n(1) «سَالَ» کی مثال مثلاً : قرآن کریم میں ہے :\n«اَنۡزَلَ مِنَ السَّمَآءِ مَآءً فَسَالَتۡ اَوۡدِیَۃٌۢ بِقَدَرِہَا» (13/17)\n ترجمہ : اسی نے آسمان سے پانی برسایا پھر اپنی اپنی وسعت کے مطابق نالے بہہ نکلے  ۔\n(2) «فَاضَ» کی مثال مثلاً : قرآن کریم میں ہے :\n«وَاِذَا سَمِعُوۡا مَاۤ اُنۡزِلَ اِلَی الرَّسُوۡلِ تَرٰۤی اَعۡیُنَہُمۡ تَفِیۡضُ مِنَ الدَّمۡعِ مِمَّا عَرَفُوۡا مِنَ الۡحَقِّ» ( 5/83 )\nترجمہ : اور جب اس کتاب کو سنتے ہیں جو پیغمبر ( محمد ﷺ ) پر نازل ہوئی تو تم دیکھتے ہو کہ ان کی آنکھوں سے آنسو جاری ہو جاتے ہیں اس لیے کہ انہوں نے حق بات پہچان لی ۔","«فَجَرَ» کسی چیز کا وسیع وعریض رقبہ پر بہنا ۔","بہنا","فجر","2:60-2:74-17:90-17:91-18:33-36:34-54:12-76:6-82:3",9
566,115,"ب","جَرٰی","«جَرْیًا وَجِرْیَانًا» اپنی اصل کے لحاظ سے یہ لفظ پانی اور اسی طرح کی سیّال چیزوں کے بہنے اور بہتے جانے کے لیے استعمال ہوتا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«فِیۡہَا عَیۡنٌ جَارِیَۃٌ» ( 88/12 )\nترجمہ : اس ( جنت ) میں چشمہ ہے بہتا ہوا ۔\nپھر یہ لفظ ہر اس چیز کے لیے استعمال ہونے لگا جو دور تک یا دیر تک بہتی اور چلتی رہتی ہیں ۔ گویا ظرف زمانی اور مکانی دونوں صورتوں میں اس کا استعمال عام ہو گیا ۔ جیسے ہواؤں یا چاند اور سورج کے چلنے اور چلتے رہنے کے لیے اس کا استعمال قرآنِ کریم میں موجود ہے ۔ پھر اس کا استعمال معنوی طور پر بھی ہوتا ہے ۔ جیسے سنتِ جاریہ مشہور لفظ ہے ۔","«جَرٰی» کسی چیز کا دور تک یا دیر تک بہتے یا چلتے جانا ہے ۔","بہنا","جری","2:25-2:164-2:266-3:15-3:136-3:195-3:198-4:13-4:57-4:122-5:12-5:85-5:119-6:6-7:43-9:72-9:89-9:100-10:9-10:22-11:42-13:2-13:35-14:23-14:32-16:31-18:31-20:76-21:81-22:14-22:23-22:65-25:10-29:58-30:46-31:29-31:31-35:13-36:38-38:36-39:5-39:20-43:51-45:12-47:12-48:5-48:17-51:3-54:14-55:50-57:12-58:22-61:12-64:9-65:11-66:8-69:11-85:11-88:12-98:8",60
567,116,"ب","العُذْر","«اَلْعُذْر» بمعنی کسی الزام کو دور کرنے کے لیے کوئی وجہ پیش کرنا ہے ۔ امام راغب کے نزدیک ایسی کوشش جس سے انسان اپنے گناہوں کو مٹا دینا چاہے اور «عَذَرَ» کے معنی عذر قبول کرنا ، «عَذَّرَ» کے معنی چھوٹا بہانہ یا کوئی جھوٹ موٹ وجہ بیان کرنا اور «اِعْتَذَرَ» بمعنی عذر پیش کرنا ہے ۔ اب اس عذر کی بھی تین قسمیں ہیں : پہلی قسم «فِتْنَۃٌ» ہے ۔","«العُذْر» کسی الزام کو دور کرنے کے لیے کوئی وجہ پیش کرنا اور«مَعْذِرَۃٌ» جھوٹا بہانہ بنانے کے لیے استعمال ہوتا ہے۔ ","بہانہ","العذر","7:164-9:90-18:76-30:57-40:52-77:6",6
568,116,"ب","فِتْنَۃٌ","«فِتْنَۃٌ» یہ ہے کہ انسان جھوٹ سے کام لے کر اس الزام یا گناہ ہی سے انکار کر دے ۔ اس کے لیے قرآن نے «فِتْنَۃٌ» کا لفظ استعمال کیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ لَمۡ تَکُنۡ فِتۡنَتُہُمۡ اِلَّاۤ اَنۡ قَالُوۡا وَاللّٰہِ رَبِّنَا مَا کُنَّا مُشۡرِکِیۡنَ» ( 6/23 )\nترجمہ : پھر ان کے شرک کا انجام اس کے سوا اور کچھ بھی نہ ہوگا کہ وہ یوں کہیں گے کہ قسم اللہ کی اپنے پروردگار کی ہم مشرک نہ تھے ۔\n لفظ فتنہ کسی کا امتحان لینے  جانچنے  اور پرکھنے کے لئے بھی استعمال ہوتا ہے ۔    ","«فِتْنَۃٌ» انسان جھوٹ سے کام لے کراس الزام یا گناہ ہی سے انکار کر دے ۔","بہانہ","فتنۃ","6:23",1
569,116,"ب","عُذْر","«عُذْر» انسان کوئی غلط وجہ یا جھوٹا بہانہ پیش کر کے اپنے آپ کو بری الذمہ ثابت کرنے کی کوشش کرے ۔ اس لیے قرآن نے «عَذَّرَ» کا لفظ استعمال کیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ جَآءَ الۡمُعَذِّرُوۡنَ مِنَ الۡاَعۡرَابِ لِیُؤۡذَنَ لَہُمۡ» ( 9/90 )\nترجمہ : اور صحرا نشینوں سے کچھ لوگ عذر بناتے ہوئے تمہارے پاس آئے کہ انہیں ( جہاد پر نہ جانے کی ) اجازت دی جائے ۔\nاوریہ بھی ممکن ہے کہ اصل میں وہ عذر درست اور معقول ہو ۔ اس کے لیے قرآن کریم میں «عُذْر» اور «مَعْذِرَۃٌ» کے الفاظ  آئے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِذۡ قَالَتۡ اُمَّۃٌ مِّنۡہُمۡ لِمَ تَعِظُوۡنَ قَوۡمَۨا ۙ اللّٰہُ مُہۡلِکُہُمۡ اَوۡ مُعَذِّبُہُمۡ عَذَابًا شَدِیۡدًا ؕ قَالُوۡا مَعۡذِرَۃً اِلٰی رَبِّکُمۡ  وَلَعَلَّہُمۡ یَتَّقُوۡنَ» ( 7/164 )\nترجمہ : اور جب ان میں سے ایک جماعت نے کہا کہ تم ایسے لوگوں کو کیوں نصیحت کرتے ہو جنھیں خدا ہلاک کرنے والا یا سخت عذاب دینے والا ہے ۔ تو انہوں نے کہا کہ تمہارے پروردگار کے سامنے معذرت پیش کر سکیں اور عجب نہیں کہ وہ پرہیزگاری اختیار کریں ۔","«عُذْر» کسی کام کو نہ کرنے پرکوئی بہانہ پیش کرنا چاہے وہ بہانہ جھوٹا ہو یا سچا ۔","بہانہ","عذر","7:164-9:90-18:76-30:57-40:52-77:6",6
570,117,"ب","بُھْتَان","«بَھَتَ» کے معنی حیران اور متحیر ہونا (مف) یا حیرانی کی وجہ سے خاموش اور دم بخود ہو جانا ہے (منجد) اور «بُھْتَان» ایسی بات کو کہتے ہیں جسے سن کر لوگ ہوش کھو دیں اور حیران و ششدر رہ جائیں اور انہیں یقین نہ آئے کہ یہ بات ممکن العمل ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَلَوۡلَاۤ اِذۡ سَمِعۡتُمُوۡہُ قُلۡتُمۡ مَّا یَکُوۡنُ لَنَاۤ اَنۡ نَّتَکَلَّمَ بِہٰذَا ٭ۖ سُبۡحٰنَکَ ہٰذَا بُہۡتَانٌ عَظِیۡمٌ» ( 24/16 )\nترجمہ : اور جب تم نے اسے سنا تھا تو کیوں نہ کہہ دیا کہ ہمیں شایانِ شان نہیں کہ ایسی بات زبان پر لائیں ( پروردگار ) تو پاک ہے یہ تو ( بہت ) بڑا بہتان ہے ۔","«بُھْتَان» ایسا الزام جو لوگوں کو ورطۂ حیرت میں ڈال دے ۔","بہتان","بھتان","2:258-4:20-4:112-4:156-21:40-24:16-33:58-60:12",8
571,117,"ب","اِفْک","«اَفَکَ» کے معنی کسی چیز کو اس کے صحیح رخ سے موڑ دینا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡۤا اَجِئۡتَنَا لِتَاۡفِکَنَا عَنۡ اٰلِہَتِنَا» ( 46/22 )\nترجمہ : وہ ( قوم عاد ) کہنے لگے کیا تم ہمارے پاس اس لیے آئے ہو کہ ہم کو ہمارے معبودوں سے پھیر دو ۔\nاسی طرح حق سے باطل کی طرف یا سچ سے جھوٹ کی طرف یا اچھے کاموں سے برے کاموں کی طرف پھرنے کو «اِفْک» کہتے ہیں ۔ اور اسی لحاظ سے من گھڑت اور جھوٹی بات اور الزام کو بھی «اِفْک» کہتے ہیں ۔ اور «اَفَّاک» بمعنی جھوٹی اور من گھڑت باتیں گھڑنے والے اور الزام تراشی کرنے والے کو کہتے ہیں ۔ اور ابوہلال عسکری کے نزدیک «اِفْک» ایسا جھوٹ ہے جس کا تعلق «فَاحِشَ اَلْقُبْح» سے ہو ۔\nمثلاً : قرآن کریم میں ہے\n«لَوۡلَاۤ اِذۡ سَمِعۡتُمُوۡہُ ظَنَّ الۡمُؤۡمِنُوۡنَ وَالۡمُؤۡمِنٰتُ بِاَنۡفُسِہِمۡ خَیۡرًا ۙ وَّقَالُوۡا ہٰذَاۤ اِفۡکٌ مُّبِیۡنٌ» ( 24/12 )\nترجمہ : جب تم نے وہ بات سنی تھی تو مومن مردوں اور عورتوں نے کیوں اپنے دلوں میں نیک گمان نہ کیا اور ( کیوں نہ ) کہا کہ صریح طوفان ہے ۔\nگویا «اِفْک» کا واقعہ اس لحاظ سے کہ وہ بے بنیاد باتوں پر استوار تھا اور اس لحاظ سے کہ وہ اتنا بڑا جھوٹ تھا کہ عقلِ سلیم دنگ رہ جائے کہ یہ بہتان تھا ۔","«اِفْک» بے بنیاد الزامات اصل بات کو توڑ موڑ کر بنایا ہوا قصہ ۔","بہتان","افک","7:17-24:11-24:12-25:4-26:45-29:17-34:43-37:151-46:11-46:22-46:28-51:9",12
572,117,"ب","اِفْتَرٰی","«فَرِيْ» کے معنی چمڑے کو سینے اور درست کرنے کے لیے کاٹنے کے ہیں اور «اِفْتِرَاء» کے معنی اُسے خراب کرنے کے لیے کاٹنے کے ہیں (مف) اور «فَرَیَ یَفْرِیُ» بمعنی طوفان جوڑنا (منجد) اور «اِفْتَرٰی» کا لفظ اصلاح و فساد دونوں کے لیے آتا ہے ۔ لیکن اس کا زیادہ تر استعمال فساد ہی کے معنوں میں ہوتا ہے (مف) قرآن پاک میں یہ لفظ جھوٹ ، شرک اور ظلم کے موقعوں پر استعمال کیا گیا ہے ۔ اور «اِفْتِرَآءً» سے مراد عمومًا وہ بناوٹی عقائد ہیں جو خود تراش کر خدا تعالیٰ کی طرف منسوب کر دیے جاتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَنۡ اَظۡلَمُ مِمَّنِ افۡتَرٰی عَلَی اللّٰہِ کَذِبًا» ( 6/93 )\nترجمہ : اور اس شخص سے بڑھ کر کون ظالم ہو گا جو اللہ پر بہتان باندھے ۔\nاور «فَرِیًّا» کا معنی کسی کے ذمہ بہتان اور جھوٹی بات لگا دینا (منجد)\nمثلاً : ارشاد باری تعالیٰ ہے :\n«قَالُوۡا یٰمَرۡیَمُ لَقَدۡ جِئۡتِ  شَیۡئًا فَرِیًّا» ( 19/27 )\nترجمہ : وہ کہنے لگے مریم ! یہ تو تم نے بہت بڑا پاپ کیا ۔ ( تفہہیم القرآن )","«اِفْتِرَاء» جھوٹا عقیدہ گڑھنا اور اسکی نسبت اللہ کی طرف کرنا یا ایسا عقیدہ  جو اصلاح کی بجائے بگاڑ پیدا کردے ۔","بہتان","افتری","3:24-3:94-4:48-4:50-5:103-6:21-6:24-6:93-6:112-6:137-6:138-6:140-6:144-7:37-7:53-7:89-7:152-10:17-10:30-10:37-10:38-10:59-10:60-10:69-11:13-11:18-11:21-11:35-11:50-12:111-16:56-16:87-16:101-16:105-16:116-17:73-18:15-19:27-20:61-21:5-23:38-25:4-28:36-28:75-29:13-29:68-32:3-34:8-34:43-42:24-46:8-46:28-60:12-61:7",54
573,118,"ب","ضَلَّ","«ضَلّ» کے معنی کسی چیز کا ضائع ہو کر کسی دوسرے کے حق میں چلا جانا ہے (م ۔ ل) یعنی جس مقصد کے لیے کوئی کام کیا جائے وہ نتیجہ برآمد نہ ہونا  یا راہِ راست سے ہٹ جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَّذِیۡنَ ضَلَّ سَعۡیُہُمۡ فِی الۡحَیٰوۃِ  الدُّنۡیَا وَ ہُمۡ یَحۡسَبُوۡنَ اَنَّہُمۡ یُحۡسِنُوۡنَ صُنۡعًا» ( 18/104 )\nترجمہ : وہ لوگ جن کی کوشش دنیا میں برباد ہو گئی اور وہ یہ سمجھے ہوئے ہیں کہ وہ اچھے کام کر رہے ہیں ۔\nنیز ارشاد باری تعالیٰ ہے :\n«اَلَمۡ یَجۡعَلۡ کَیۡدَہُمۡ فِیۡ  تَضۡلِیۡلٍ» ( 105/2 )\nترجمہ : کیا انکا داؤ غلط نہیں گیا ۔ یعنی ان کی تدبیر رائیگاں ہو گئی ۔\nاور یہ بے راہروی قصدًا (یعنی جان بوجھ) کر بھی ہو سکتی ہے اور اضطرارًا (مجبوری) سے بھی ۔ اگر اضطرارًا یعنی ترکِ ضبط (یاد نہ رہنے کی) وجہ سے ہو تو اس کے معنی بھولنا ہوں گے یعنی کسی بات یا واقعہ یا اس کا کچھ حصہ بھول جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاِنۡ لَّمۡ یَکُوۡنَا رَجُلَیۡنِ فَرَجُلٌ وَّامۡرَاَتٰنِ مِمَّنۡ تَرۡضَوۡنَ مِنَ الشُّہَدَآءِ اَنۡ تَضِلَّ اِحۡدٰىہُمَا فَتُذَکِّرَ اِحۡدٰىہُمَا الۡاُخۡرٰی» ( 2/282 )\nترجمہ : اور اگر دو مرد نہ ہوں تو ایک مرد اور دو عورتیں جن کو تم گواہ پسند کرو کہ اگر ان میں سے ایک بھول جائے تو دوسری اسے یاد دلا دے ۔\nاس لحاظ سے «ضَلَال» یا «ضَلَالَۃٌ» کی ضد حق بھی ہو سکتی ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«فَمَا ذَا بَعۡدَ الۡحَقِّ  اِلَّا الضَّلٰلُ» ( 10/32 )\nترجمہ : اور حق بات ظاہر ہونے کے بعد گمراہی کے سوا ہے ہی کیا ؟\nاور اسکی ضد ہدایت بھی ہوسکتی ہے ۔\n مثلاً : ارشاد باری تعالیٰ ہے :\n«وَ وَجَدَکَ ضَآلًّا فَہَدٰی» ( 93/7 )\nترجمہ : اور ( آپ کو ) رستے سے ناواقف دیکھا تو سیدھا رستہ دکھایا ۔","«ضَلّ» غلطی سے یا جان بوجھ کر راہ راست سے ہٹ جانا ۔","بہکنا","ضل","1:7-2:16-2:26-2:108-2:175-2:198-2:282-3:69-3:90-3:164-4:44-4:60-4:88-4:113-4:116-4:119-4:136-4:143-4:167-4:176-5:12-5:60-5:77-5:105-6:24-6:39-6:56-6:74-6:77-6:94-6:116-6:117-6:119-6:125-6:140-6:144-7:30-7:37-7:38-7:53-7:60-7:61-7:149-7:155-7:178-7:179-7:186-9:37-9:115-10:30-10:32-10:88-10:108-11:21-12:8-12:30-12:95-13:14-13:27-13:33-14:3-14:18-14:27-14:30-14:36-15:56-16:25-16:36-16:37-16:87-16:93-16:125-17:15-17:67-17:72-17:97-18:17-18:51-18:104-19:38-19:75-20:52-20:79-20:85-20:92-20:123-21:54-22:4-22:9-22:12-23:106-25:17-25:29-25:34-25:42-25:44-26:20-26:86-26:97-26:99-27:81-27:92-28:15-28:50-28:75-28:85-30:29-30:53-31:6-31:11-32:10-33:36-33:67-34:8-34:24-34:50-35:8-36:24-36:47-36:62-37:69-37:71-38:26-39:8-39:22-39:23-39:36-39:37-39:41-40:25-40:33-40:34-40:50-40:74-41:29-41:48-41:52-42:18-42:44-42:46-43:40-45:23-46:5-46:28-46:32-50:27-53:2-53:30-54:24-54:47-56:51-56:92-60:1-62:2-67:9-67:29-68:7-68:26-71:24-71:27-74:31-83:32-93:7",163
574,118,"ب","غَوٰی","«غَوٰی» کے معنی کسی کام میں لاعلمی کی بناء پر غلط کام میں پھنس جانا (م ۔ ر) اور پھر راہِ راست سے ناامید ہو جانا ہے (م ۔ ر) اور اس کا استعمال صرف دینی معاملات میں ہوتا ہے ۔ ( فق ل 177 )\nمثلاً : قرآن کریم میں ہے :\n«وَعَصٰۤی اٰدَمُ رَبَّہٗ فَغَوٰی» ( 20/121 )\nترجمہ : اور ( اس طرح ) آدم نے اپنے رب کا کہا ٹالا ، اور بھٹک گئے  ۔\n«اورغیّ» کی ضد «رُشْد» ہے ۔ بمعنی سیدھی راہ پر گامزن ہو جانا اور نیک چلن اختیار کرنا ۔ اور رشید بمعنی ہدایت یافتہ ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«قَدۡ تَّبَیَّنَ الرُّشۡدُ مِنَ الۡغَیِّ» ( 2/256 )\nترجمہ : ہدایت صاف طور پر ظاہر ( اور ) گمراہی سے الگ ہو چکی ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«مَا ضَلَّ صَاحِبُکُمۡ وَمَا غَوٰی» ( 53/2 )\nترجمہ : تمہارے رفیق ( محمد ﷺ ) نہ رستہ بھولے ہیں نہ بھٹکے ہیں ۔","«غَوٰی» لاعلمی کی  وجہ سے کسی غلط کام میں پھنس جانا ۔","بہکنا","غوی","2:256-7:16-7:146-7:202-11:34-15:39-19:59-20:121-28:18-28:63-37:32-38:82-53:2",13
575,118,"ب","تَاہَ","«تَاہَ ، تِیْہ ، تِیْھَاء» ایسے چٹیل میدان کو کہتے ہیں جس میں چلنے والا بھٹک جائے ۔ اور «تَاہَ» کے معنی حواس باختہ ہو کر حیران پریشان پھرنا ہے (منجد)\nمثلاً : قرآن کریم میں ہے :\n«قَالَ فَاِنَّہَا مُحَرَّمَۃٌ عَلَیۡہِمۡ اَرۡبَعِیۡنَ سَنَۃً ۚ یَتِیۡہُوۡنَ فِی الۡاَرۡضِ» ( 5/26 )\nترجمہ : خدا نے فرمایا کہ وہ ملک انکے لیے چالیس برس تک کے لیے حرام کر دیا گیا ( کہ وہاں جانے نہ پائیں گے اور جنگل کی ) زمین میں سرگرداں پھرتے رہیں گے ۔","«تَاہَ» ایسے چٹیل میدان کو کہتے ہیں جس میں چلنے والا بھٹک جائے ۔","بہکنا","تاہ","5:26",1
576,119,"ب","فَرَّ","«فَرَّ» بمعنی بھاگنا عمومًا ملزم کے لیے آتا ہے یا کسی قسم کے خوف و خطر سے بھاگنے کے لیے ۔ «فَرَّمِنَ الْحَرْبِ فِرَارًا» کے معنی میدان جنگ کا چھوڑ دینا یا لڑائی سے فرار ہو جانا اور «مَفَرّ» ایسی جگہ کو کہتے ہیں جہاں بھاگ کر پناہ لی جا سکے ۔ اور مفرور وہ ملزم جو بھاگ جائے ۔\nمثلاً : قرآن کریم میں ہے :\n«قُلۡ لَّنۡ یَّنۡفَعَکُمُ الۡفِرَارُ اِنۡ فَرَرۡتُمۡ مِّنَ الۡمَوۡتِ اَوِالۡقَتۡلِ وَاِذًا لَّا تُمَتَّعُوۡنَ اِلَّا قَلِیۡلًا» ( 33/16 )\nترجمہ : تم کہہ دو کہ اگر موت یا قتل ہو جانے سے بھاگتے ہو تو بھاگنا تم کو فائدہ نہیں دے گا اور اس وقت تم بہت ہی کم فائدہ اٹھاؤ گے ۔\nنیز یہ لفظ مقابلۃً تیز دوڑنے کے معنی میں بھی آتا ہے ۔ «اَلْفَرَّار» تیز دوڑنے والے کو کہتے ہیں ۔ اور «مَفَرٌ مِّنَ الْخَیْل» اُس تیز دوڑنے والے گھوڑے کو کہتے ہیں جو بھاگتے وقت کام میں آئے (منجد) یہ لفظ ان معنوں میں بھی قرآن کریم میں استعمال ہوا ہے ۔\nارشاد باری تعالیٰ ہے :\n«فَفِرُّوۡۤا اِلَی اللّٰہِ ؕ اِنِّیۡ لَکُمۡ  مِّنۡہُ نَذِیۡرٌ مُّبِیۡنٌ» ( 51/50 )\nترجمہ : تو تم لوگ خدا کی طرف بھاگ چلو ۔ میں اس کی طرف سے تم کو صریح طور پر ڈرانے والا ہوں ۔\nاس آیت میں مندرجہ بالا دونوں مفہوم پائے جاتے ہیں ۔","«فَرَّ» کسی ملزم کا بھاگنا ۔","بھاگنا","فر","18:18-26:21-33:13-33:16-51:50-62:8-71:6-74:51-75:10-80:34",10
577,119,"ب","اَبَق","«اَبَق» کا لفظ غلام کا اپنے مالک کے ہاں سے بھاگ جانے کے لیے مخصوص ہے (مف ۔ منجد) خصوصًا جب اسے اپنے مالک کی طرف سے کوئی خطرہ بھی نہ ہو (ف ۔ ل 31) نیز اس لفظ کا استعمال اپنی ذمہ داریوں سے فرار کی راہ اختیار کرنے پر بھی ہوتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَاِنَّ یُوۡنُسَ لَمِنَ الۡمُرۡسَلِیۡنَ اِذۡاَبَقَ اِلَی الۡفُلۡکِ الۡمَشۡحُوۡنِ» ( 37/140 )\nترجمہ : اور یونس ؑ بھی پیغمبروں میں سے تھے جب بھاگ کر بھری ہوئی کشتی میں پہنچے ۔\nاس آیت میں «اَبَقَ» کا لفظ یہ سب معنی دے رہا ہے ۔","«اَبَق» غلام کا آقا کے پاس سے بھاگنا یا ذمہ داریوں سے بھاگنا ۔","بھاگنا","ابق","37:140",1
578,119,"ب","زَھَقَ","«زَھَقَ» کے معنی شکست کھا کر بھاگ کھڑے ہونا ہے (م ۔ ر) «زَھَقَتْ نَفْسُہٗ» بمعنی اس کی روح نکل گئی ۔ یہ لفظ لغت اضداد سے ہے  ۔ «زَاهِقُ» بمعنی بہت موٹا جانور بھی اور بہت دُبلا اور کمزور بھی (منجد) لہذا «اَزْھَقَ» سے مراد کسی چیز کا شکست کھا کر یا کمزور اور مضمحل ہو کر نکل بھاگنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَقُلۡ جَآءَ الۡحَقُّ وَ زَہَقَ الۡبَاطِلُ ؕ اِنَّ الۡبَاطِلَ کَانَ زَہُوۡقًا» ( 17/81 )\nترجمہ : اور کہہ دو کہ حق آ گیا اور باطل نابود ہو گیا ۔ بے شک باطل نابود ہونے والا ہے ۔ ( جالندھریؒ )\nاور کہہ دو کہ آیا سچ اور نکل بھاگا جھوٹ ۔ بیشک جھوٹ ہے نکل بھاگنے والا ۔ ( عثمانیؒ )\nنوٹ : (لغت اضداد ایسے الفاظ کو کہتے ہیں جن کے  دو الگ الگ معنیٰ ہوں اور وہ معنیٰ ایک دوسرے کے مخالف اور متضاد ہوں)","«زَھَقَ» کمزور اور شکست کھا کر بھاگ کھڑے ہونا ۔","بھاگنا","زھق","17:81",1
579,119,"ب","ھَرْبَ","«ھَرْبَ» کسی کا خود پکڑے جانے کے خطرہ کی وجہ سے بھاگنا ( ف ل 31 ) جیسے چور کا چوری کرتے وقت اطلاع ہونے پر بھاگ کھڑا ہونا یا مال چوری کرکے لے جانا اور «تَھْرِیْب» ٹیکس بچانے اور «مُھَرِّبْ» اسمگلرنگ کے معنی میں استعمال ہوتا ہے (قاموس الجدید)\nمثلاً : قرآن کریم میں ہے :\n«وَّاَنَّا ظَنَنَّاۤ اَنۡ لَّنۡ نُّعۡجِزَاللّٰہَ فِی الۡاَرۡضِ وَلَنۡ نُّعۡجِزَہٗ ہَرَبًا» ( 72/12 )\nترجمہ : اور یہ کہ ہم نے یقین کر لیا ہے کہ ہم زمین میں ( خواہ کہیں ہوں ) خدا کو ہرا نہیں سکتے اور نہ بھاگ کر اس کو تھکا سکتے ہیں ۔","«ھَرْبَ» مجرم کا جرم کرنے کے دوران اس طرح بھاگنا کہ پکڑا نہ جائے ۔","بھاگنا","ھرب","72:12",1
580,119,"ب","اِسْتَنْفَرَ","«نَفَرَ» کے معنی جنگ وغیرہ کے لیے نکلنا ، اور «اِسْتَنْفَرَ» کے معنی کسی چیز سے بدک کر بھاگنے کو کہتے ہیں (مف)\nمثلاً : قرآن کریم میں ہے :\n«کَاَنَّہُمۡ حُمُرٌ مُّسۡتَنۡفِرَۃٌ فَرَّتۡ مِنۡ قَسۡوَرَۃٍ» ( 74/50،51 )\nترجمہ : گویا گدھے ہیں کہ بدک جاتے ہیں جو شیر سے ڈر کر بھاگ کھڑے ہوتے ہیں ۔","«اِسْتَنْفَرَ» بدک کر بھاگنا ۔ ","بھاگنا","استنفر","4:71-9:38-9:39-9:41-9:81-9:122-74:50",7
581,119,"ب","شَرَّدَ الْبَعِیْر","«شَرَّدَ الْبَعِیْر»  بمعنی اونٹ بدک کر بھاگ کھڑا ہوا ۔ اور «شَرَّدَ» بمعنی ایسا کام کرنا کہ پھر دوسرے اس جیسا کام نہ کریں (مف) اور بمعنی دھتکارنا ڈرانا بھگانا (منجد) گویا اس کا معنی کسی کے ساتھ عبرتناک سلوک کر کے دوسروں کو بھگا دینا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاِمَّا تَثۡقَفَنَّہُمۡ فِی الۡحَرۡبِ فَشَرِّدۡ بِہِمۡ مَّنۡ خَلۡفَہُمۡ لَعَلَّہُمۡ یَذَّکَّرُوۡنَ» ( 8/57 )\nترجمہ : اگر تم ان کو لڑائی میں پاؤ تو انہیں ایسی سزا دو کہ جو لوگ ان کے پس پشت ہوں وہ ان کو دیکھ کر بھاگ کھڑے ہوں ۔","«شَرَّدَ الْبَعِیْر» ایسی عبرتناک سزا جس سے دوسرے بھاگ کھڑے ہوں ۔","بھاگنا","شرد البعیر","8:57",1
582,120,"ب","اِخوَۃٌ","«اِخوَۃٌ» بمعنی بھائی بھائی ۔ نسبی تعلق کے لیے استعمال ہوتا ہے (منجد ۔ مف) اور اس میں سب بہن بھائی شامل ہوتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاِنۡ کَانَ لَہٗۤ  اِخۡوَۃٌ» ( 4/11 )\nترجمہ : اگر میت کے بھائی بھی ہوں ۔\nاس آیت میں «اِخْوَۃٌ» کا لفظ بہن بھائی دونوں کے لیے ہے ۔ (مف)","«اِخوَۃٌ» بھائی اور بہن  دونو کے لئے استعمال ہوتا ہے ۔","بھائی","اخوۃ","4:11-4:23-4:176-12:5-12:7-12:8-12:58-12:69-12:100-20:42-24:31-24:61-33:55-49:10",14
583,120,"ب","اِخْوَانٌ","«اِخْوَانٌ» کا لفظ بلحاظ صداقت دوستی اور بھائی کے معنی دیتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یَقُوۡلُوۡنَ رَبَّنَا اغۡفِرۡ لَنَا وَلِاِخۡوَانِنَا الَّذِیۡنَ سَبَقُوۡنَا بِالۡاِیۡمَانِ» ( 59/10 )\nترجمہ : دعا کرتے ہیں کہ پروردگار ! ہمارے اور ہمارے بھائیوں کے جو ہم سے پہلے ایمان لائے ہیں  گناہ معاف فرما ۔\nاور ارشاد باری تعالیٰ ہے :\n«اِنَّمَا الۡمُؤۡمِنُوۡنَ اِخۡوَۃٌ» ( 49/10 )\nترجمہ : مومن تو آپس میں بھائی بھائی ہیں ۔\nاس آیت میں اس بات کی طرف اشارہ ہے کہ مومنوں کو محض صداقت اور دوستی کا تعلق ہی نہ سمجھنا چاہیے بلکہ ایک دوسرے کو نسبی برادری کی طرح  سمجھنا چاہیے ۔","«اِخْوَانٌ» بھائی بندی برادرانہ تعلق اور دوستی  کے لئے استعمال ہوتا ہے ۔","بھائی","اخوان","2:220-3:103-3:156-3:168-6:87-7:202-9:11-9:23-9:24-15:47-17:27-26:106-26:124-26:142-26:161-33:5-33:18-50:13-58:22-59:10-59:11",21
584,121,"ب","مَلَاَ","«مَلَاَ الاِنَاءَ» کے معنی کسی برتن کو بھر دینا اور «مِلْءُ» کسی چیز کی وہ مقدار ہے جس سے کوئی برتن بھر جائے (م ل ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«فَلَنۡ یُّقۡبَلَ مِنۡ اَحَدِہِمۡ مِّلۡءُ الۡاَرۡضِ ذَہَبًا وَّلَوِ افۡتَدٰی بِہٖ» ( 3/91 )\nترجمہ : ( کافر اگر نجات حاصل کرنے کے لیے ) بدلے میں زمین بھر سونا دیں ۔ تو بھی ہرگز قبول نہیں کیا جائے گا ۔\nاور «اِمْتَلَأَ» بمعنی کسی چیز کا بھر جانا ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«یَوۡمَ نَقُوۡلُ لِجَہَنَّمَ ہَلِ امۡتَلَاۡتِ وَ تَقُوۡلُ ہَلۡ مِنۡ مَّزِیۡدٍ» ( 50/30 )\nترجمہ : اس دن ہم جہنم سے کہیں گے کیا تو بھر گئی ؟ اور وہ کہے گی کچھ اور بھی ہے ؟","«مَلَاَ» کسی برتن کو بھر دینا ۔","بھرنا","ملا","3:91-7:18-11:119-32:13-38:85-50:30",6
585,121,"ب","دَھَقَ","«دَھَقَ» پیالہ کے کسی مشروب سے بھر جانے کے لیے استعمال ہوتا ہے ( ف ل 65 )\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ لِلۡمُتَّقِیۡنَ مَفَازًا ، حَدَآئِقَ وَ اَعۡنَابًا ، وَّکَوَاعِبَ اَتۡرَابًا ، وَّ کَاۡسًا دِہَاقًا» ( 78/31،32،33،34 )\nترجمہ : بے شک پرہیزگاروں کے لیے کامیابی ہے ( یعنی ) باغ اور انگور اور ہم عمر نوجوان عورتیں اور چھلکتے ہوئے جام ۔","«دَھَقَ» پیالہ کا کسی مشروب سے بھر جانا ۔ ","بھرنا","دھق","78:34",1
586,121,"ب","شَحْنُ","«شَحْنُ» کشتی یا جہاز کو سوار اور سامان لاد کر بھرنا (ف ل 69)\nمثلاً : قرآن کریم میں ہے :\n«اِذۡ اَبَقَ اِلَی الۡفُلۡکِ الۡمَشۡحُوۡنِ» ( 37/140 )\nترجمہ : جب وہ ( یونس ؑ ) بھاگ کر بھری ہوئی کشتی میں پہنچے ۔","«شَحْنُ» مال بردار جہاز کے لئے استعمال ہوتا ہے ۔","بھرنا","شحن","26:119-36:41-37:140",3
587,122,"ب","جُوْع","«جُوْع» بمعنی کھانے کی طلب پیدا ہونا اور یہ بھوک کا ابتدائی درجہ ہے ( ف ل 161 ) اور اس کی ضد «شَبَعَ» ( کھا کر سیر ہو جانا ) ہے ۔ (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«الَّذِیۡۤ اَطۡعَمَہُمۡ مِّنۡ جُوۡعٍ ۬ ۙ وَّاٰمَنَہُمۡ مِّنۡ خَوۡفٍ» ( 106/4 )\nترجمہ : جس نے ان کو بھوک میں کھانا کھلایا اور اسے امن بخشا ۔","«جُوْع» وہ حالت جب انسان کو کھانے کی طلب ہو یعنی حالت بھوک ۔","بھوک","جوع","2:155-16:112-20:118-88:7-106:4",5
588,122,"ب","مَسْغَبَۃ","«سَغَبَ» بمعنی بھوکا ہونا اور «اَسْغَبَ» بمعنی قوم کا قحط سالی میں مبتلا ہونا اور «سَغَابُ» بھوک کو کہتے ہیں ۔ اور یہ بھوک کا دوسرا درجہ ہے ( ف ۔ ل 161 )\nمثلاً : قرآن کریم میں ہے :\n«اَوۡ اِطۡعٰمٌ فِیۡ یَوۡمٍ ذِیۡ مَسۡغَبَۃٍ» ( 90/14 )\nترجمہ : یا بھوک والے دنوں میں کھانا کھلانا ۔","«مَسْغَبَۃ» قحط سالی کا دور ۔","بھوک","مسغبۃ","90:14",1
589,122,"ب","مَخْمَصَۃ","«خَمَصَہُ الْجُوْع» بمعنی بھوک کا کسی کو دبلے پیٹ والا کر دینا اور «مَخْمَصَۃ» بمعنی پیٹ کا کھانے سے خالی ہونا ہے ۔ (منجد) خوراک کی کمی اور محنت کی زیادتی کی وجہ سے لاغر و کمزور ہونا اور پیٹ کا پچک جانا (ر ۔ ل) ۔ اور یہ بھوک کا تیسرا درجہ ہے ( فل 161 )\nمثلاً : قرآن کریم میں ہے :\n«فَمَنِ اضۡطُرَّ فِیۡ مَخۡمَصَۃٍ غَیۡرَ مُتَجَانِفٍ لِّاِثۡمٍ ۙ فَاِنَّ اللّٰہَ غَفُوۡرٌرَّحِیۡمٌ» ( 5/3 )\nترجمہ : ہاں جو شخص بھوک میں ناچار ہو جائے ( بشرطیکہ ) گناہ کی طرف مائل نہ ہو ۔ تو خدا بخشنے والا مہربان ہے ۔","«مَخْمَصَۃ» خوراک کی کمی کی وجہ سے دبلے پیٹ والا ہونا ۔","بھوک","مخمصۃ","5:3-9:120",2
590,122,"ب","خَصَاصَۃ","«خَصَّ» بمعنی محتاج و مفلس ہونا اور «خَصَاصَۃً» مصدر ہے اور «خُصَاصَۃ» تھوڑا اور قلیل کے معنوں میں آتا ہے (منجد) یعنی مفلسی اور احتیاج کی وجہ سے فاقہ کشی کی نوبت کو پہنچ جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَ یُؤۡثِرُوۡنَ عَلٰۤی اَنۡفُسِہِمۡ وَلَوۡ کَانَ بِہِمۡ خَصَاصَۃٌ» ( 59/9 )\nترجمہ : اور ان کو اپنے آپ پر ترجیح دیتے ہیں ، چاہے ان پر تنگ دستی کی حالت گذر رہی ہو ۔","«خَصَاصَۃ» مفلسی اور محتاجی کی وجہ سے فاقہ کشی کی نوبت آنا ۔","بھوک","خصاصۃ","59:9",1
591,123,"ب","نَسِیَ","«نَسِیَ» بھولنا کے لیے یہ لفظ عام ہے خواہ اس کی وجہ غفلت ہو یا ترک ضبط  یا کوئی اور (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَ ضَرَبَ لَنَا مَثَلًا وَّ نَسِیَ خَلۡقَہٗ» ( 36/78 )\nترجمہ : اور ( انسان ) ہمارے بارے میں مثالیں بیان کرنے لگا اور پیدائش کو بھول گیا ۔\nاور «اَنْسٰی» بمعنی کسی دوسرے کو کوئی بات بھلا دینا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَاَنۡسٰہُ الشَّیۡطٰنُ ذِکۡرَ رَبِّہٖ» ( 12/42 )\nترجمہ : لیکن شیطان نے اسے اپنے آقا سے ( یوسف ؑ کا ) ذکر کرنا بھلا دیا ۔","«نَسِیَ» بمعنی بھولنا عام استعمال ہوتا ہے ، وجہ خواہ کچھ بھی ہو ۔","بھولنا","نسی","2:106-2:286-6:68-7:51-9:67-12:42-18:24-18:57-18:61-18:63-18:73-19:23-19:64-20:52-20:88-20:115-20:126-32:14-36:78-39:8-45:34-58:19-59:19-87:6",24
592,123,"ب","سَھَا ( سَھْوًا )","«سَھَا» بمعنی غفلت کی وجہ سے کسی کام سے توجہ ہٹ جانا ۔ توجہ کا اصل کام سے ہٹ کر دوسری طرف پھر جانا اور «سَاھِی» بمعنی غافل اور فراموش کار (یاد نہ رکھنا) (م ۔ ر) سجدہ سہو مشہور لفظ ہے ۔ یعنی کام اور کوئی کرنا تھا مگر بھول کرکوئی اور کام کر دیا ۔\nمثلاً : قرآن کریم میں ہے :\n«الَّذِیۡنَ ہُمۡ فِیۡ غَمۡرَۃٍ سَاہُوۡنَ» ( 51/11 )\nترجمہ : جو بے خبری میں بھولے ہوئے ہیں ۔","«سَھَا» بمعنی غفلت کی وجہ سے بھولنا ۔ توجہ کا دوسری طرف پھر جانا اور اصل کام کی بجائے کوئی دوسرا کام کرنا ۔","بھولنا","سھا ( سھوًا )","51:11-107:5",2
593,123,"ب","ضَلَّ","«ضَلّ» ترکِ ضبط (یاد نہ رکھنے) کی وجہ سے کوئی بات یا واقعہ یا اس کا کچھ حصہ بھول جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَنۡ تَضِلَّ اِحۡدٰىہُمَا فَتُذَکِّرَ اِحۡدٰىہُمَا الۡاُخۡرٰی» ( 2/282 )\nترجمہ : اگر ان دونوں ( عورتوں ) میں سے ایک بھول جائے تو دوسری اسے یاد دلا دے ۔","«ضَلّ» بمعنی ترکِ ضبط (یاد نہ رکھنے) کی وجہ سے بھولنا ۔","بھولنا","ضل","1:7-2:16-2:26-2:108-2:175-2:198-2:282-3:69-3:90-3:164-4:44-4:60-4:88-4:113-4:116-4:119-4:136-4:143-4:167-4:176-5:12-5:60-5:77-5:105-6:24-6:39-6:56-6:74-6:77-6:94-6:116-6:117-6:119-6:125-6:140-6:144-7:30-7:37-7:38-7:53-7:60-7:61-7:149-7:155-7:178-7:179-7:186-9:37-9:115-10:30-10:32-10:88-10:108-11:21-12:8-12:30-12:95-13:14-13:27-13:33-14:3-14:18-14:27-14:30-14:36-15:56-16:25-16:36-16:37-16:87-16:93-16:125-17:15-17:67-17:72-17:97-18:17-18:51-18:104-19:38-19:75-20:52-20:79-20:85-20:92-20:123-21:54-22:4-22:9-22:12-23:106-25:17-25:29-25:34-25:42-25:44-26:20-26:86-26:97-26:99-27:81-27:92-28:15-28:50-28:75-28:85-30:29-30:53-31:6-31:11-32:10-33:36-33:67-34:8-34:24-34:50-35:8-36:24-36:47-36:62-37:69-37:71-38:26-39:8-39:22-39:23-39:36-39:37-39:41-40:25-40:33-40:34-40:50-40:74-41:29-41:48-41:52-42:18-42:44-42:46-43:40-45:23-46:5-46:28-46:32-50:27-53:2-53:30-54:24-54:47-56:51-56:92-60:1-62:2-67:9-67:29-68:7-68:26-71:24-71:27-74:31-83:32-93:7",163
594,123,"ب","ذَھَل","«ذَھَلَ ، ذَھُوْلًا» جب بھولنے کا سبب دہشت ہو یا ایسی مشغولیت جو غم اور پریشانی کا باعث ہو تو اسے «ذَھُوْل» کہتے ہیں (مف) «ذَھَلَ ، ذَھُوْلًا» کے معنی غافل ہونا ، بھول جانا اور «ذَھِلَ ذَھُوْلًا» کے معنی ہکا بکا ہونا ۔ حیران ہوجانا (منجد)\nمثلاً : قرآن کریم میں ہے :\n«یَوۡمَ تَرَوۡنَہَا تَذۡہَلُ کُلُّ مُرۡضِعَۃٍ عَمَّاۤ اَرۡضَعَتۡ وَتَضَعُ کُلُّ ذَاتِ حَمۡلٍ حَمۡلَہَا وَ تَرَی النَّاسَ سُکٰرٰی وَ مَا ہُمۡ بِسُکٰرٰی» ( 22/2 )\nترجمہ : جس دن تو اس ( زلزلہ قیامت کو دیکھے گا تمام دودھ پلانے والی عورتیں اپنے بچوں کو بھول جائیں گی اور تمام حمل والیوں کے حمل گر پڑیں گے اور تو لوگوں کو متوالا دیکھے گا مگر وہ متوالے نہیں ہوں گے ۔","«ذَھَل» بمعنی دہشت اور پریشانی کی وجہ سے بھولنا ۔","بھولنا","ذھل","22:2",1
595,124,"ب","شَوٰی","«شَوٰی» بمعنی گوشت وغیرہ کو آگ میں بھوننا (مف منجد)\nمثلاً : قرآن کریم میں ہے :\n«وَاِنۡ یَّسۡتَغِیۡثُوۡا یُغَاثُوۡا بِمَآءٍ کَالۡمُہۡلِ یَشۡوِی الۡوُجُوۡہَ» ( 18/29 )\nترجمہ : اور اگر وہ فریاد کریں گے تو پگھلے ہوئے تانبے کی طرح کھولتے پانی سے ان کی داد رسی کی جائے گی جو اُن کے چہروں کو بھون ڈالے گا ۔","«شَوٰی» بمعنی آگ پر گوشت وغیرہ کو بھوننا اور پکانا ۔","بھوننا","شوی","18:29-70:16",2
596,124,"ب","حَنَذَ","«اَلْحَنَذَۃٌ» بمعنی سخت حرارت اور «حَنِیْذ» بمعنی گرم پانی بھی اور بھونا ہوا گوشت بھی ۔ اور «حَنَذَتْہُ الشَّمْس» یعنی سورج کا کسی کو جھلس دینا ۔ (منجد) «حَنَذَ» کے اصل معنی کسی بھی ذریعہ حرارت سے  چپچپاہٹ اور رطوبت (یعنی نمی اور تری)  کو خارج کرنا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«فَمَا لَبِثَ اَنۡ جَآءَ بِعِجۡلٍ حَنِیۡذٍ» ( 11/69 )\nترجمہ : ابھی کچھ وقفہ نہیں گزرا تھا کہ ( ابراہیم ؑ ) ایک بھنا ہوا بچھڑا لے آئے ۔","«حَنَذَ» بمعنی سخت حرارت ۔","بھوننا","حنذ","11:69",1
597,125,"ب","اَرْسَلَ","«اَرْسَلَ» کسی کو پیغام ، چٹھی (خط) یا حکم دے کر بھیجنا ہے ۔ (منجد) اور «رَسُول» بمعنی پیغمبر یا پیغام پہنچانے والا ہے جو انسانوں میں سے بھی ہیں اورفرشتوں سے بھی ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡۤا اَرۡجِہۡ وَاَخَاہُ وَاَرۡسِلۡ فِی الۡمَدَآئِنِ حٰشِرِیۡنَ» ( 7/111 )\nترجمہ : فرعون کے درباریوں نے اس سے کہا کہ فی الحال موسیٰ ؑ اور اس کے بھائی کے معاملے کو موقوف رکھیے اور شہروں میں ہرکارے روانہ کر دیجیے ۔","«اَرْسَلَ» بمعنی کسی کو پیغام دے کر بھیجنا ۔","بھیجنا","ارسل","2:119-2:151-4:64-4:79-4:80-5:70-6:6-6:42-6:48-6:61-7:6-7:57-7:59-7:75-7:87-7:94-7:105-7:111-7:133-7:134-7:162-9:33-11:25-11:52-11:57-11:70-11:96-12:12-12:19-12:31-12:45-12:63-12:66-12:109-13:13-13:30-13:38-14:4-14:5-14:9-15:10-15:22-15:58-16:43-16:63-17:54-17:59-17:68-17:69-17:77-17:105-18:40-18:56-19:17-19:83-20:47-20:134-21:5-21:7-21:25-21:107-22:52-23:23-23:32-23:44-23:45-25:20-25:48-25:56-26:13-26:17-26:27-26:53-27:35-27:45-27:63-28:34-28:47-29:14-29:40-30:46-30:47-30:48-30:51-33:9-33:45-34:16-34:28-34:34-34:44-35:2-35:9-35:24-36:14-36:16-37:72-37:147-39:42-40:23-40:70-40:78-41:14-41:16-42:48-42:51-43:6-43:23-43:24-43:45-43:46-46:23-48:8-48:28-51:32-51:33-51:38-51:41-54:19-54:27-54:31-54:34-55:35-57:25-57:26-61:9-67:17-71:1-71:11-73:15-83:33-105:3",131
598,125,"ب","بَعَثَ","«بَعَثَ» بنیادی طور پر اس کے دو معنی ہیں (1) ابھارنا ، اٹھانا اور (2) تنہا روانہ کرنا ۔ پھر کبھی اس سے ایک ہی مفہوم لیا جاتا ہے ۔ مثلاً «بَعَثْتُ الْبَعِیْر» میں نے اونٹ کو اٹھا کر آزاد چھوڑ دیا ۔ اور جب یہ روانہ کرنا کے معنی میں ہو تو اس کا مطلب کسی مقصد یا مہم کی تکمیل کے لیے روانہ کرنا ہو گا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَبَعَثَ اللّٰہُ غُرَابًا یَّبۡحَثُ فِی الۡاَرۡضِ» ( 5/31 )\nترجمہ : اور خدا نے ایک کوّا بھیجا جو زمین کو کریدنے لگا ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«ہُوَالَّذِیۡ بَعَثَ فِی الۡاُمِّیّٖنَ رَسُوۡلًا مِّنۡہُمۡ یَتۡلُوۡاعَلَیۡہِمۡ اٰیٰتِہٖ وَیُزَکِّیۡہِمۡ» ( 62/2 )\nترجمہ : وہی تو ہے جس نے ان پڑھوں میں سے ایک رسول بھیجا جو اُن پر اللہ کی آیات پڑھتا اور اُن کو پاک کرتا ہے ۔","«بَعَثَ» بمعنی کسی کو کسی مقصد کی تکمیل کے لیے تنہا روانہ کرنا ۔","بھیجنا","بعث","2:56-2:129-2:213-2:246-2:247-2:259-3:164-4:35-5:12-5:31-6:36-6:60-6:65-7:14-7:103-7:167-10:74-10:75-15:36-16:21-16:36-16:38-16:84-16:89-17:5-17:15-17:79-17:94-18:12-18:19-19:15-19:33-22:5-22:7-23:16-23:100-25:41-25:51-26:36-26:87-27:65-28:59-30:56-31:28-36:52-37:144-38:79-40:34-58:6-58:18-62:2-64:7-72:7-91:12",54
599,126,"ب","وَصَفَ","«وَصَفَ» کے معنی کسی کا حلیہ بیان کرنا (م ۔ ل) کسی چیز کا حلیہ اورتعریف بیان کرنا خواہ وہ صحیح ہو یا غلط ، منظر کشی کرنا ۔ (مف)\nمثلاً : قرآن کریم میں ہے :\n«قَالَ بَلۡ سَوَّلَتۡ لَکُمۡ اَنۡفُسُکُمۡ اَمۡرًا ؕ فَصَبۡرٌ جَمِیۡلٌ ؕ وَاللّٰہُ الۡمُسۡتَعَانُ عَلٰی مَا تَصِفُوۡنَ» ( 12/18 )\nترجمہ : یعقوب ؑ نے کہا ( یوں نہیں ہے ) بلکہ تم اپنے دل سے یہ بات بنا لائے ہو ۔ اچھا صبر ہی خوب ہے اور جو تم بیان کرتے ہو ، اس کے بارے میں خدا ہی سے مدد مطلوب ہے ۔","«وَصَفَ» بمعنی کسی چیز کا حلیہ بیان کرنا ۔","بیان","وصف","6:100-6:139-12:18-12:77-16:62-16:116-21:18-21:22-21:112-23:91-23:96-37:159-37:180-43:82",14
600,126,"ب","قَصَّ","«قَصَّ» کے معنی کسی کے نشانِ قدم پر چلنا ہے (مف)\nمثلاً : قرآن کریم میں ہے ::\n«فَارۡتَدَّا عَلٰۤی اٰثَارِہِمَا قَصَصًا» ( 18/64 )\nترجمہ : تو وہ دونوں اپنے پاؤں کے نشان دیکھتے دیکھتے لوٹ گئے ۔\nاسی سے «قَصَّ» بمعنی بتدریج یعنی درجہ بدرجہ  اتباع کرتے جانا ہے (منجد) یعنی ایسی بات یا واقعہ بیان کرنا جو لوگوں میں نسلًا بعد نسل بیان ہوتا چلا آ رہا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«نَحۡنُ نَقُصُّ عَلَیۡکَ اَحۡسَنَ الۡقَصَصِ بِمَاۤ اَوۡحَیۡنَاۤ اِلَیۡکَ ہٰذَا الۡقُرۡاٰنَ» ( 12/3 )\nترجمہ : ( اے پیغمبر ﷺ ) ہم اس قرآن کے ذریعے جو ہم نے تمہاری طرف وحی کیا ہے تمہیں ایک نہایت اچھا قصہ بیان کرتے ہیں ۔\nپھر اس لفظ کا اطلاق عام واقعہ اور قصہ کو بیان کرنے پر بھی ہونے لگا ۔\nمثلاً : قرآن کریم میں ہے :\n«فَلَمَّا جَآءَہٗ وَقَصَّ عَلَیۡہِ الۡقَصَصَ ۙ قَالَ لَا تَخَفۡ ٝ۟ نَجَوۡتَ مِنَ الۡقَوۡمِ الظّٰلِمِیۡنَ» ( 28/25 )\nترجمہ : جب موسیٰ ؑ شعیب ؑ کے پاس آئے اور ان سے اپنے واقعات بیان کیے تو انہوں نے کہا کہ کچھ خوف نہ کرو تم ظالم لوگوں سے بچ آئے ہو ۔","«قَصَّ» بمعنی کوئی قصہ یا ماجرا بیان کرنا ۔","بیان","قص","3:62-4:164-6:57-6:130-7:7-7:35-7:101-7:176-11:100-11:120-12:3-12:5-12:111-16:118-18:13-18:64-20:99-27:76-28:25-40:78",20
601,126,"ب","ضَرَبَ","«مَثَلًا» کسی بات کو اس طرح بیان کرنا کہ اس سے کوئی دوسری بات سمجھ میں آ جائے ۔ (مف) کہاوت یا مثال بیان کرنا ۔ «ضَرْبُ الْمِثْل» مشہور لفظ ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ اللّٰہَ لَا یَسۡتَحۡیٖۤ اَنۡ یَّضۡرِبَ مَثَلًا مَّا بَعُوۡضَۃً فَمَا فَوۡقَہَا» ( 2/26 )\nترجمہ : الله اس بات سے عار نہیں کرتا کہ مچھر یا اس سے بڑھ کر کسی چیز (مثلاً مکھی مکڑی وغیرہ) کی مثال بیان فرمائے ۔","«ضَرَبَ ، مَثَلًا » بمعنی مثال یا کہاوت بیان کرنا ۔","بیان","ضرب","2:26-13:17-14:24-14:25-14:45-16:74-16:75-16:76-16:112-17:48-18:32-18:45-22:73-24:35-25:9-25:39-29:43-30:28-30:58-36:13-36:78-39:27-39:29-43:17-43:57-43:58-47:3-59:21-66:10-66:11",30
602,126,"ب","حَدَّثَ","«حَدَثَ» کے معنی کسی ایسی چیز کا وجود میں آنا ہے جو پہلے موجود نہ تھی (م ۔ ل) اور «حَدَّثَ» کے معنی ایسی بات یا خبر بتلانا جس سے عام لوگ بے خبر ہوں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَقَالَ الۡاِنۡسَانُ مَا لَہَا ، یَوۡمَئِذٍ تُحَدِّثُ اَخۡبَارَہَا» ( 99/3،4 )\nترجمہ : اور انسان کہے گا کہ اس زمین کو کیا ہوا ہے ؟ اس روز وہ اپنی خبریں بیان کر دے گی ۔","«حَدَّثَ» بمعنی ایسی چیز بتانا جس سے عام لوگ بے خبر ہوں ۔","بیان","حدث","2:76-18:70-20:113-21:2-26:5-65:1-93:11-99:4",8
603,126,"ب","بَیّن","«بَیَّنَ» بیان کرنے کے معنی میں استعمال ہوتاہے بمعنی فصیح گفتگو (منجد) اور «بَیِِّنَۃ» کے معنی دلیل اور ثبوت کے ہیں ۔ اور «بَیَّنَ» سے مراد کسی بات کو دلائل سے پیش کرنا ہے ۔ ابن الفارس کے نزدیک «بَیَّنْ» میں تین باتیں بنیادی طور پر پائی جاتی ہیں ۔ (1) افتراق (2) بُعد اور (3) وُضوح ۔ یعنی کسی چیز کا دوسری سے جدا اور واضح ہونا (م ۔ ل)\nمثلاً : قرآن کریم میں ہے :\n«کَذٰلِکَ یُبَیِّنُ اللّٰہُ اٰیٰتِہٖ لِلنَّاسِ لَعَلَّہُمۡ یَتَّقُوۡنَ» ( 2/187 )\nترجمہ : اسی طرح بیان فرماتا ہے اللہ اپنی آیتیں لوگوں کے واسطے تاکہ وہ بچتے رہیں ۔ ( عثمانیؒ )\nاور «تَبَیَّنَ» واضح ہونا ۔ جدا ہونا کے معنوں میں آتا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«قَدۡ تَّبَیَّنَ الرُّشۡدُ مِنَ الۡغَیِّ» ( 2/256 )\nترجمہ : ہدایت صاف طور پر گمراہی سے الگ ہو چکی ہے ۔","«بَیَّنَ» بمعنی بات کو دلائل کے ساتھ بیان کرنا ۔","بیان","بین","2:68-2:69-2:70-2:118-2:159-2:160-2:187-2:219-2:221-2:230-2:242-2:266-3:103-3:118-3:187-4:26-4:176-5:15-5:19-5:75-5:89-6:105-9:115-14:4-16:39-16:44-16:64-16:92-18:15-22:5-24:18-24:58-24:59-24:61-43:63-57:17",36
604,126,"ب","صَرَّف","«صَرَّفَ» بمعنی کسی چیز کو ایک حالت سے دوسری حالت میں پھیر دینا اور «صَرَّفَ» بمعنی بات کو لوٹا لوٹا کر بیان کرنا ہے (مف) یعنی کسی معاملہ کو سمجھانے کے لیے اسے مختلف انداز سے بیان کرنا اور اس کے مختلف پہلوؤں پر روشنی ڈالنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اُنۡظُرۡ کَیۡفَ نُصَرِّفُ الۡاٰیٰتِ لَعَلَّہُمۡ یَفۡقَہُوۡنَ» ( 6/65 )\nترجمہ : دیکھو ہم اپنی آیتوں کو کس کس طرح بیان کرتے ہیں تاکہ یہ لوگ سمجھ سکیں ۔","«صَرَّفَ» بمعنی کسی بات کے مختلف پہلوؤں پر روشنی ڈالنا ۔","بیان","صرف","3:152-6:16-6:46-6:65-6:105-7:47-7:58-7:146-9:127-10:32-12:24-12:33-12:34-17:41-17:89-18:53-18:54-20:113-24:43-25:19-25:50-25:65-39:6-40:69-46:27-46:29",26
605,126,"ب","فَصَلَ","«فَصَلَ» کے معنی ایک چیز کا دوسری سے اس طرح الگ ہونا کہ ان کے درمیان فاصلہ ہو جائے اور «فَصَّلَ» کے معنی کسی معاملہ کو الگ الگ کر کے اور ترتیب وار کر کے بیان کرنا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«وَکُلَّ شَیۡءٍ فَصَّلۡنٰہُ تَفۡصِیۡلًا» ( 17/12 )\nترجمہ : اور ہم نے ہر چیز کی ( بخوبی ) تفصیل بیان کر دی ہے ۔","«فَصَلَ» بمعنی کوئی بات ترتیب وار اور الگ الگ کر کے بیان کرنا ۔","بیان","فصل","2:249-6:55-6:97-6:98-6:114-6:119-6:126-7:32-7:52-7:133-7:174-9:11-10:5-10:24-11:1-12:94-13:2-17:12-22:17-30:28-32:25-37:21-38:20-41:3-41:44-42:21-44:40-60:3-77:13-77:14-77:38-78:17-86:13",33
606,126,"ب","فَسَّرَ","«اَلْفَسَر» کے معنی کسی چیز کی معنوی صفت بیان کرنا (مف) نیز «فَسَرَ» بمعنی مراد بتلانا اور وضاحت کرنا ہے ۔ اور «فَسَّرَ» کسی چیز سے پردہ ہٹانا ہے (م ۔ ل ۔ منجد) اور یہ عمومًا دو الفاظ سے کیا جاتا ہے ۔1 لفظ «اَیْ» سے مبہم (یعنی وہ بات جس کا مطلب صاف نہ ہو اور سمجھ میں نہ ٰآئے) کی وضاحت کی جاتی ہے اور لفظ «اَوْ» سے معنی اور مراد کی وضاحت کی جاتی ہے ۔ اور بمعنی جملہ کے ایک ایک لفظ کو کھول کر بیان کرنا اور تنزیل کا لحاظ رکھنا ( فق ل 43 )\nمثلاً : قرآن کریم میں ہے :\n«وَلَا یَاۡتُوۡنَکَ بِمَثَلٍ اِلَّا جِئۡنٰکَ بِالۡحَقِّ وَاَحۡسَنَ  تَفۡسِیۡرًا» ( 25/33 )\nترجمہ : اور جب کبھی یہ لوگ تمہارے پاس کوئی انوکھی بات لے کر آتے ہیں ، ہم تمہیں ( اس کا ) ٹھیک ٹھیک ) جواب اور زیادہ وضاحت کے ساتھ عطا کردیتے ہیں ۔","«فَسَّرَ» مبہم اور مشکل مقامات کی وضاحت کرنا ۔","بیان","فسر","25:33",1
607,127,"ب","وَلَدُ","«وَلَدُ» ہر وہ بچہ جسے ماں نے جنا وہ «وَلَدُ ، وَلِیْد ، مَوْلُوْد» کہلاتا ہے ۔ یہ تینوں الفاظ مذکر و مؤنث دونوں طرح استعمال ہوتے ہیں ۔ لغوی لحاظ سے «وَلِیْد» کی مؤنث «وَلِیْدَۃ» آتی ہے ۔ لیکن قرآن میں «وَلِیْدَۃ» کا لفظ نہیں آیا ۔ ان تینوں الفاظ میں اگر کچھ فرق ہے تو یہ کہ «وَلَدُ» کا لفظ ہر عمر والے کے لیے استعمال ہوتا ہے ۔ ایک بوڑھا آدمی بھی اپنے باپ یا ماں کا ویسے ہی «وَلَدُ» ہے ۔ جیسے پیدا ہوتے وقت تھا ۔ اور «وَلِیْد» کا لفظ پیدائش سے لے کر بلوغت سے پہلے تک کے لیے آتا ہے ۔\nمثلاً : قرآن میں ہے کہ فرعون نے موسیٰ ؑ کو مخاطب کر کے کہا :\n«اَلَمۡ نُرَبِّکَ فِیۡنَا وَلِیۡدًا» ( 26/18 )\nترجمہ : کیا ہم نے تمہیں بچپنے میں پالا نہ تھا ۔\nاور مَوْلُوْد کی نسبت بالعموم باپ کی طرف ہوتی ہے ۔ ماں کی طرف کم ہی ہوتی ہے ۔ اور «مولود» بیٹا کے معنوں میں آتا ہے  اس کا اطلاق بھی عمومًا چھوٹے بچہ پر ہوتا ہے (منجد) تاہم بڑے پر بھی ہو سکتا ہے ۔\n جیسا کہ ارشاد باری تعالی ہے :\n«وَلَا مَوۡلُوۡدٌ ہُوَ جَازٍعَنۡ وَّالِدِہٖ شَیۡئًا» ( 31/33 )\nترجمہ : اور نہ بیٹا اپنے باپ کے کچھ کام آ سکے گا ۔","«وَلَدُ» لفظی معنی لڑکا ۔","بیٹا","ولد","2:116-2:233-3:47-4:11-4:12-4:75-4:98-4:127-4:171-4:176-6:101-10:68-12:21-17:111-18:4-18:39-19:15-19:33-19:35-19:77-19:88-19:91-19:92-21:26-23:91-25:2-26:18-28:9-31:33-37:152-39:4-43:81-56:17-58:2-71:21-72:3-73:17-76:19-90:3-112:3",40
608,127,"ب","اِبْن ، بِنْت","«اِبْن» بمعنی بیٹا اور اسکی جمع «اَبْنَاء» ہے اور «بَنُوْن» اسکی تصغیر «بَنِی» ہے ۔ اور «بِنْت» بمعنی بیٹی اسکی جمع «بَنَات» ہے  «اَبّ» اور «اُمّ» کی طرح یہ الفاظ بھی صرف سگی اولاد کے معنی میں استعمال نہیں ہوتے بلکہ ان کا دائرہ وسیع ہوتا جاتا ہے ۔ مثلاً بنی آدم ، بَنُو اسماعیل وغیرہ اور قبائل کے تو نام ہی جَدّ امجد کے نام پر چلتے ہیں ۔\n«وَلَد» اور «اِبْن» میں دوسرا بڑا فرق یہ ہے کہ «اِبْن» اور «بِنْت» کے الفاظ نسب اور رشتہ کو ظاہر کرنے کے لیے آتے ہیں ۔ جیسے عیسیٰ بن مریم ، مریم بنت عمران ۔ «بِنِیْ اِخْوَانِہِنَّ» اور «بَنَاتُ الْاَخِ» وغیرہ ۔ جبکہ «وَلَد» کے الفاظ نسب اور رشتہ کو ظاہر کرنے کے لیے استعمال نہیں ہوتے ۔\nاور تیسرا فرق یہ ہے کہ «اِبْن» اور «بِنْت» کے الفاظ کنیت کے طور پر بھی استعمال ہوتے ہیں ۔ اور کنیت میں «اَبُو» اور «اُمّ» بھی شامل ہو جاتے ہیں ۔ اس صورت میں ایک ادنیٰ سی مشابہت یا تعلق ہی کافی سمجھا جاتا ہے ۔ مثلاً «اَبُوتُرَاب ، ابوھریرہ ، اُمُّ الْخَبَائِث» اور ( شراب ) «اُمُّ الْاَمَرَاض» ( قبض ) اسی طرح «اِبْنُ الْوَقْت ۔ اِبْنُ السَّبِیْل ۔ اِبْنُ الْاَدْھَم ، بِنْتُ الْکَرَم» ( انگور ) اور «بنَاَتُ النَّعَش» ( کہکشاں ) وغیرہ استعمال ہوتے ہیں ۔ «وَلَد» اور اس کے مشتقات کنیت کے لیے بھی استعمال نہیں ہوتے ۔","«اِبْن» بمعنی بیٹا اور« بِنْت» بمعنی بیٹی ۔","بیٹا","ابن ، بنت","2:40-2:47-2:49-2:83-2:87-2:122-2:132-2:133-2:146-2:177-2:211-2:215-2:246-2:253-3:14-3:45-3:49-3:61-3:93-4:11-4:23-4:36-4:157-4:171-5:12-5:17-5:18-5:27-5:32-5:46-5:70-5:72-5:75-5:78-5:110-5:112-5:114-5:116-6:20-6:100-7:26-7:27-7:31-7:35-7:105-7:127-7:134-7:137-7:138-7:141-7:150-7:172-8:41-9:24-9:30-9:31-9:60-10:90-10:93-11:42-11:45-11:78-11:79-12:5-12:67-12:81-12:87-14:6-14:35-15:71-16:57-16:72-17:2-17:4-17:6-17:26-17:40-17:70-17:101-17:104-18:46-19:34-20:47-20:80-20:94-21:91-23:50-23:55-24:31-26:17-26:22-26:59-26:88-26:133-26:197-27:76-28:4-28:27-30:38-31:13-31:16-31:17-32:23-33:4-33:7-33:50-33:55-33:59-36:60-37:102-37:149-37:153-40:53-43:16-43:57-43:59-44:30-45:16-46:10-52:39-57:27-58:22-59:7-61:6-61:14-66:12-68:14-70:11-71:12-74:13-80:36",131
609,128,"ب","جَلَسَ","«جَلَسَ» بیٹھ جانے کے معنوں میں اس کا استعال عام ہے ۔ خواہ کوئی لیٹنے کی حالت سے اٹھ کر بیٹھ جائے یا کہیں سے آ کر یا کھڑے ہونے کے بعد بیٹھ جائے اور اسکی ضد «قَامَ» ہے اور «جَلْسٌ» بمعنی بلند اور سخت زمین اور «جَلَسَ» بمعنی کسی سخت جگہ پر اپنی مقعد (یعنی تشریف) رکھنا اور بیٹھنے کی جگہ کو «مَجْلِس» کہا جاتا ہے ۔ اور ان لوگوں کو بھی جو اکٹھے بیٹھے ہوں «مَجْلِس»  کہا جاتا ہے اور اسکی جمع «مَجَالِس» ہے اور «جَلْسَہ» اسم مرّہ ہے ، بمعنی ایک بار بیٹھنا یا بیٹھنے کی حالت ۔(مف ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡۤا اِذَا قِیۡلَ لَکُمۡ تَفَسَّحُوۡا فِی الۡمَجٰلِسِ فَافۡسَحُوۡا یَفۡسَحِ اللّٰہُ لَکُمۡ» ( 58/11 )\nترجمہ : اے ایمان والو ! جب تم سے کہا جائے کہ مجالس میں کھل کر بیٹھو تو کھل بیٹھا کرو اللہ تم کو کشادگی بخشے گا ۔","«جَلَسَ» لیٹنے ، کھڑے ہونے یا چلنے کے بعد غرضیکہ کسی بھی حرکت کے بعد بیٹھ جانا ۔","بیٹھنا","جلس","58:11",1
610,128,"ب","قَعَدَ","«قَعَدَ» کئی معنوں میں استعمال ہوتا ہے ۔ مثلاً (1) کھڑا ہونے کی حالت سے بیٹھ جانا اور «قَعْدَۃ» اسم مرہ ہے ۔ بمعنی ایک بار بیٹھنا جیسا کہ دو سجدوں کے درمیان بیٹھتے ہیں ۔ (م ۔ ق)\nمثلاً : قرآن کریم میں ہے :\n«فَلَا تَقۡعُدۡ بَعۡدَ الذِّکۡرٰی مَعَ الۡقَوۡمِ الظّٰلِمِیۡنَ» ( 6/68 )\nترجمہ : یاد آنے کے بعد ظالم لوگوں کے ساتھ مت بیٹھو ۔\n(2) بمعنی بیٹھے رہنا  کوئی کام نہ کرنا ۔ اصل کام سے اعراض کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَجَآءَ الۡمُعَذِّرُوۡنَ مِنَ الۡاَعۡرَابِ لِیُؤۡذَنَ لَہُمۡ وَقَعَدَ الَّذِیۡنَ کَذَبُوا اللّٰہَ وَرَسُوۡلَہٗ» ( 9/90 )\nترجمہ : اور صحرا نشینوں میں سے بھی کچھ لوگ عذر کرتے ہوئے تمہارے پاس آئے کہ ان کو بھی اجازت دے دی جائے اور جنھوں نے خدا اور رسولؐ سے جھوٹ بولا وہ ( گھر میں ) بیٹھے رہے ۔\n(3) بمعنی کھڑا ہونا «قَعَدَ» لغت ذوی الاضداد سے ہے ۔ اور «قَعُوْدًا» کے معنی بیٹھے ہوئے بھی اور کھڑے ہوئے بھی ۔ اسی طرح «مَقْعَد» بمعنی بیٹھک بھی اور مقام بھی (م ۔ ر ۔ منجد)\n مثلاً : قرآن کریم میں ہے :\n«فِیۡ مَقۡعَدِ صِدۡقٍ عِنۡدَ مَلِیۡکٍ مُّقۡتَدِرٍ» ( 54/55 )\n ترجمہ : جو پرہیزگار ہیں وہ باغوں اور نہروں میں ہوں گے ( یعنی ) پاک مقام میں ( سچی بیٹھک میں ) عثمانیؒ ) ہر طرح کی قدرت رکھنے والے بادشاہ کی بارگاہ میں ۔\n(4) پھر جس طرح «قَعَدَ» بیٹھ رہنے یا کام نہ کرنے کے معنوں میں آتا ہے ۔ کسی کام کے لیے تیار ہو بیٹھنے کے معنوں میں بھی آتا ہے ۔ جیسے «قَعَدَ لِلْحَرْبِ» بمعنی لڑائی کے لیے تیار ہو بیٹھا ( م ۔ ق )\n مثلاً : قرآن کریم میں ہے :\n«فَاقۡتُلُواالۡمُشۡرِکِیۡنَ حَیۡثُ وَجَدۡتُّمُوۡہُمۡ وَخُذُوۡہُمۡ وَاحۡصُرُوۡہُمۡ وَاقۡعُدُوۡا لَہُمۡ کُلَّ مَرۡصَدٍ» ( 9/5 )\n ترجمہ : مشرکوں کو جہاں پاؤ قتل کر دو ۔ انہیں پکڑ لو اور گھیر لو ۔ اور ہر گھات کی جگہ ان کی تاک میں بیٹھے رہو ۔\nاور «قَعِیْدَہ» اس عورت کو کہتے ہیں جو گھر کی نگہبان اور محافظ ہو اور گھر میں ہی رہے اور اسکی جمع (قواعد) ہے۔\n مثلاً : قرآن کریم میں ہے :\n«وَالۡقَوَاعِدُ مِنَ النِّسَآءِ الّٰتِیۡ لَا یَرۡجُوۡنَ نِکَاحًا» ( 24/60 )\n ترجمہ : اور گھر میں بیٹھ رہنے والی عورتیں جنھیں نکاح کی امید نہ رہی ہو ۔\nنوٹ : (لغت اضداد ایسے الفاظ کو کہتے ہیں جن کے  دو الگ الگ معنیٰ ہوں اور وہ معنیٰ ایک دوسرے کے مخالف اور متضاد ہوں)\n","«قَعَدَ» بمعنی بیٹھنا ۔","بیٹھنا","قعد","2:127-3:168-3:191-4:103-4:140-6:68-7:16-7:86-9:5-9:46-9:81-9:83-9:90-16:26-17:22-17:29-24:60-54:55-72:9-85:6",20
611,128,"ب","جَثَا یَجْثُوْا جَثْوًا ، جَثٰی یَجْثِیْ جَثِیًّا","«جَثَمَ» بمعنی زانوں کے بل بیٹھنا (مف) یا دو زانوں ہو کر بیٹھنا ۔\nمثلاً : قرآن کریم میں ہے :\n«وَتَرٰی کُلَّ اُمَّۃٍ جَاثِیَۃً» ( 45/28 )\nترجمہ :  اور تم ہر فرقے کو گھٹنوں کے بل بیٹھا دیکھو گے ۔","«جَثَمَ»  بمعنی زانو کے بل بیٹھنا ۔","بیٹھنا","جثا یجثوا جثوًا ، جثی یجثی جثیًا","7:78-7:91-11:67-11:94-19:68-19:72-29:37-45:28",8
612,129,"ب","سَقِیْم","«سَقِمَ» بمعنی بیماری ، روگ وغیرہ اور غیر درست کلام ( یعنی غلط بات) کو بھی کہتے ہیں (منجد) «سَقِمَ» کا لفظ جسمانی بیماری کےلئے خاص ہے (مف) اور صاحب فِقْہُ الْلُغَۃ کے نزدیک بیماری کا پہلا درجہ علالت ہے جبکہ مریض کی طبیعت معمولی خراب ہو تو اسے علیل کہتے ہیں اور طبیعت مزید بگڑنے پر اسے «سَقِیْم» کہیں گے اور جب زیادہ بیمار ہو جائے تو وہ مریض کہلاتا ہے ( فل 123 )\nمثلاً : قرآن کریم میں ہے :\n«فَنَظَرَ نَظۡرَۃً فِی النُّجُوۡمِ ، فَقَالَ اِنِّیۡ سَقِیۡمٌ» ( 37/88،89 )\nترجمہ : پھر ابراہیم ؑ نے ستاروں کی طرف ایک نظر کی اور کہا کہ میں تو بیمار ہوں ۔","«سَقِیْم» صرف جسمانی عوارض اور معمولی بیمار کے لیے استعمال ہوتا ہے ۔","بیمار","سقیم","37:89-37:145",2
613,129,"ب","مَرِیْض","«مَرِیْض» بیماری کے لحاظ سے «سَقِیْمٌ» سے اگلا درجہ ہے ۔ اور «مَرَضُ الْمَوْت» ایسی بیماری کو کہتے ہیں جو جان لیوا ثابت ہو ۔ اور «مرض» کا لفظ جسمانی اور قلبی  دونوں کے لیے آیا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«فِیۡ قُلُوۡبِہِمۡ مَّرَضٌ ۙ فَزَادَہُمُ اللّٰہُ مَرَضًا» ( 2/10 )\nترجمہ : اُن کے دلوں میں ( کفر کا ) مرض تھا ۔ خدا نے ان کا مرض اور زیادہ کر دیا ۔\nاور قلبی امراض سے مراد اخلاق رذیلہ مثلاً بزدلی ، بخل ، نفاق ، کفر وغیرہ ہیں ۔\nاور «مَرِیْض» کی جمع «مَرْضٰی» اور اس کی جمع «اَمْرَاض» آتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«لَیۡسَ عَلَی الضُّعَفَآءِ وَلَا عَلَی الۡمَرۡضٰی وَلَاعَلَی الَّذِیۡنَ لَا یَجِدُوۡنَ مَا یُنۡفِقُوۡنَ حَرَجٌ» ( 9/91 )\nترجمہ : نہ تو ضعیفوں پر کچھ گناہ ہے اور نہ بیماروں پر اور نہ اُن پر جن کے پاس خرچ کرنے کو کچھ موجود نہیں کہ وہ شریک جہاد ہوں ۔","«مَرِیْض» جسمانی ، قلبی ، معمولی یا سخت ہر طرح کے بیمار کے لیے استعمال ہوتا ہے ۔ ","بیمار","مریض","2:10-2:184-2:185-2:196-4:43-4:102-5:6-5:52-8:49-9:91-9:125-22:53-24:50-24:61-26:80-33:12-33:32-33:60-47:20-47:29-48:17-73:20-74:31",23
614,129,"ب","حَرَضَ","«حَرَضَ» بمعنی بڑی بیماری میں مبتلا ہو کر لاغر و ناتوان ہونا اور «اَحْرَضَہُ الْمَرَضَ اَوِ الْحُزْن» بمعنی اس بیمار کو بیماری یا غم نے گھلا دیا (منجد) اور «حَرَضَ» بمعنی سخت لاغر ہو کر موت کے قریب پہنچ جانا ۔ ( م ۔ ق )\nمثلاً : قرآن کریم میں ہے :\n«قَالُوۡا تَاللّٰہِ تَفۡتَؤُا تَذۡکُرُ  یُوۡسُفَ حَتّٰی تَکُوۡنَ حَرَضًا اَوۡ تَکُوۡنَ مِنَ الۡہٰلِکِیۡنَ» ( 12/85 )\nترجمہ : بیٹے کہنے لگے کہ واللہ اگر آپ یوسف ؑ کو اسی طرح یاد کرتے رہیں گے تو یا تو سخت بیمار پڑ جائیں گے یا جان ہی دے دیں گے ۔","«حَرَضَ» وہ مریض جو لاغر و ناتواں اور مرنے کے قریب ہو ۔","بیمار","حرض","12:85",1
615,130,"ب","زَوْج","«زَوْج» بمعنی جوڑا ۔ پھر جوڑا میں سے ہر کوئی ایک دوسرے کا «زَوْج» ہے ۔ میاں بیوی کا «زَوْج» ہے اور بیوی میاں کی «زَوْج» ۔\nمثلاً :عورت کے لیے قرآن کریم میں ہے :\n«وَ قُلۡنَا یٰۤاٰدَمُ اسۡکُنۡ اَنۡتَ وَ زَوۡجُکَ الۡجَنَّۃَ» ( 2/35 )\nترجمہ : اور ہم نے کہا اے آدم ! تم اور تمہاری بیوی ( دونوں ) جنت میں رہو ۔\nاور مرد کے لیے  قرآن کریم میں ہے :\n«قَدۡ سَمِعَ  اللّٰہُ  قَوۡلَ  الَّتِیۡ تُجَادِلُکَ فِیۡ زَوۡجِہَا» ( 58/1 )\nترجمہ : اے پیغمبر ! جو عورت تم سے اپنے شوہر کے بارے بحث و جدال کر رہی تھی خدا نے اس کی التجا سن لی ۔\nاور دونوں مل کر بھی زوج ہی رہتے ہیں ۔","«زَوْج» یہ لفظ عربی زبان میں  بیوی کے لیے استعمال ہوتا ہے ۔","بیوی","زوج","2:25-2:35-2:102-2:230-2:232-2:234-2:240-3:15-4:1-4:12-4:20-4:57-6:139-6:143-7:19-7:189-9:24-11:40-13:3-13:23-13:38-15:88-16:72-20:53-20:117-20:131-21:90-22:5-23:6-23:27-24:6-25:74-26:7-26:166-30:21-31:10-33:4-33:6-33:28-33:37-33:50-33:52-33:53-33:59-35:11-36:36-36:56-37:22-38:58-39:6-40:8-42:11-42:50-43:12-43:70-44:54-50:7-51:49-52:20-53:45-55:52-56:7-58:1-60:11-64:14-66:1-66:3-66:5-70:30-75:39-78:8-81:7",72
616,130,"ب","حَلَائِل","«حَلَائِل» کی جمع «حَلِیْلَہ» ہے ۔ بمعنی «حَلَال» منکوحہ عورت یا بیوی ۔ اور «حَلِیْلَۃٌ حَلِیْل» کی مؤنث ہے ۔ مرد کے لیے بیوی «حَلِیْلَۃٌ» ہے اور بیوی کے لیے مرد «حَلِیْل» ہے ۔ «حَلِیْل» اور «حَلِیْلَۃٌ» دونوں کی جمع «حَلَائِل» ہے (منجد) «حَلِیْل» کی مثال قرآن میں نہیں ہے اور «حَلِیْلَۃٌ» کی مثال یہ ہے :\nارشاد باری تعالیٰ ہے :\n«وَ حَلَآئِلُ اَبۡنَآئِکُمُ الَّذِیۡنَ مِنۡ اَصۡلَابِکُمۡ» ( 4/23 )\nترجمہ : اور تمہارے صلبی (سگے) بیٹوں کی بیویاں بھی تم پر حرام ہیں ۔","«حَلَائِل» بمعنی وہ عورت جو آپ کے نکاح میں ہو ۔","بیوی","حلائل","4:23",1
617,130,"ب","اِمْرَاَۃٌ","«اِمْرَاَۃٌ» عام عورت کو کہتے ہیں اور یہ لفظ بیوی کے لیے بھی استعمال ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«ضَرَبَ اللّٰہُ مَثَلًا  لِّلَّذِیۡنَ کَفَرُوا امۡرَاَتَ نُوۡحٍ وَّامۡرَاَتَ لُوۡطٍ» ( 66/10 )\nترجمہ : اللہ نے کافروں کے لیے نوح کی بیوی اور لوط کی بیوی کی مثال بیان فرمائی ہے ۔","«اِمْرَاَۃٌ» عام عورت کو کہتے ہیں اور یہ لفظ بیوی کے لیے بھی استعمال ہوتا ہے ۔","بیوی","امراۃ","2:282-3:35-3:40-4:12-4:128-7:83-11:71-11:81-12:21-12:30-12:51-15:60-19:5-19:8-27:23-27:57-28:9-28:23-29:32-29:33-33:50-51:29-66:10-66:11-111:4",25
618,130,"ب","نِسَاءٌ","«اِمْرَأَۃٌ» کی جمع غیر سالم ہے بمعنی عام عورتیں ۔ یہ لفظ بھی بیویوں کے لیے استعمال ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰنِسَآءَ النَّبِیِّ لَسۡتُنَّ کَاَحَدٍ مِّنَ النِّسَآءِ» ( 33/32 )\nترجمہ : اے نبی کی بیویو ! تم عام عورتوں کی طرح نہیں ہو ۔","«نِسَاءٌ» عورت کو کہتے ہیں اور یہ لفظ بیوی کے لیے بھی استعمال ہوتا ہے ۔","بیوی","نساء","2:49-2:187-2:222-2:223-2:226-2:231-2:232-2:235-2:236-3:14-3:42-3:61-4:1-4:3-4:4-4:7-4:11-4:15-4:19-4:22-4:23-4:24-4:32-4:34-4:43-4:75-4:98-4:127-4:129-4:176-5:6-7:81-7:127-7:141-14:6-24:31-24:60-27:55-28:4-33:30-33:32-33:52-33:55-33:59-40:25-48:25-49:11-58:2-58:3-65:1-65:4",51
619,130,"ب","صَاحِبَۃ","«صَاحِب» بمعنی ساتھی اور دوست ۔ اور اس سے مؤنث «صَاحِبَۃ» ہے جو بیوی کے معنوں میں استعمال ہوا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یَوۡمَ یَفِرُّالۡمَرۡءُ مِنۡ اَخِیۡہِ ، وَاُمِّہٖ وَاَبِیۡہِ ، وَصَاحِبَتِہٖ وَ بَنِیۡہِ» ( 80/34،35،36 )\nترجمہ : اس دن آدمی اپنے بھائی سے ، اپنی ماں سے ، اپنے باپ سے ، اپنی بیوی سے اور اپنے بیٹے سے دور بھاگے گا ۔","«صَاحِبَۃ» کسی عورت کو احتراماً پکارنے کے لئے استعمال ہوتا ہے مثلاً : نانی صاحبہ اور بیوی کے لئے بھی بولا جاتا ہے ۔","بیوی","صاحبۃ","6:101-70:12-72:3-80:36",4
620,130,"ب","اَھْل","«اَھْلَ الرَّجُل» کسی شخص کے ہم نسب لوگ یا وہ جو ایک ہی گھر میں رہتے ہوں ۔ پھر اس لفظ کا استعمال آدمی کے قریبی رشتہ داروں پر بھی ہوتا ہے ۔ اور کبھی «اَھْلَ الرَّجُل» سے مراد بیوی ہوتی ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«قَالَتۡ مَا جَزَآءُ مَنۡ اَرَادَ بِاَہۡلِکَ سُوۡٓءً» ( 12/25 )\nترجمہ : ( زلیخا ) نے اپنے خاوند سے کہا بھلا جو شخص تمہاری بیوی کے ساتھ برائی کا ارادہ کرے ، اس کی کیا سزا ہو ؟","«اَھْل» کسی شخص کے ہم نسب لوگ یا وہ لوگ جو ایک ہی جگہ  رہتے ہوں اور «اَھْلَ الرَّجُل» سے مراد بیوی بھی  ہوتی ہے ۔","بیوی","اھل","12:25",1
622,131,"ن","ظَلَمَ","«ظَلَمَ» بنیادی طور پر دو طرح استعمال ہوتا ہے (1) کسی چیز کو ناجائز طریقہ سے اس کے اصل مقام کے علاوہ کسی دوسری جگہ رکھنا اور (2) بمعنی تاریکی جو روشنی اور نور کی ضد ہے ۔ اور «ظُلْمَتْ» بمعنی تاریکی اور اسکی جمع «ظُلُمٰت» اور جمع «اَلْجَمْعُ ظَّلَام» آتی ہے ( م ۔ ل )\nاور پہلے معنوں میں ظلم کی ضد عدل ہے ۔ اور ہر بے انصافی کی بات ، خواہ وہ حقوق اللہ سے تعلق رکھتی ہو یا حقوق العباد سے ، وہ ظلم ہے ۔ اور اس لفظ کا استعمال عام ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«یٰبُنَیَّ لَا تُشۡرِکۡ بِاللّٰہِ   ؕ ؔاِنَّ الشِّرۡکَ لَظُلۡمٌ  عَظِیۡمٌ» ( 31/13 )\nترجمہ : اے میرے بیٹے ! خدا کے ساتھ شرک نہ کرنا ۔ شرک تو بڑا ( بھاری ) ظلم ہے ۔\nایک دوسرے مقام پر ارشاد باری تعالیٰ ہے :\n«لَا یُحِبُّ اللّٰہُ  الۡجَہۡرَ  بِالسُّوۡٓءِ مِنَ الۡقَوۡلِ اِلَّا مَنۡ ظُلِمَ» ( 4/148 )\nترجمہ : اللہ اس بات کو پسند نہیں کرتا کہ کوئی کسی کو علانیہ برا کہے مگر وہ جو مظلوم ہو ۔","«ظَلَمَ» ہر بے انصافی کی بات خواہ اس کا تعلق حقوق اللہ سے ہو یاحقوق العباد سے ۔","نا انصافی","ظلم","2:54-2:57-2:59-2:150-2:165-2:231-2:272-2:279-2:281-3:25-3:108-3:117-3:135-3:161-4:10-4:30-4:40-4:49-4:64-4:77-4:110-4:124-4:148-4:153-4:160-4:168-5:39-6:21-6:45-6:82-6:93-6:131-6:144-6:157-6:160-7:9-7:23-7:37-7:103-7:160-7:162-7:165-7:177-8:25-8:60-9:36-9:70-10:13-10:17-10:44-10:47-10:52-10:54-11:18-11:37-11:67-11:94-11:101-11:113-11:116-11:117-13:6-14:44-14:45-16:33-16:41-16:61-16:85-16:111-16:118-17:59-17:71-18:15-18:33-18:49-18:57-18:59-18:87-19:60-20:111-20:112-21:3-21:47-22:25-22:39-23:27-23:62-25:4-25:19-26:227-27:11-27:14-27:44-27:52-27:85-28:16-29:40-29:46-29:68-30:9-30:29-30:57-31:13-32:22-34:19-34:42-36:54-37:22-38:24-39:32-39:47-39:51-39:69-40:17-40:31-42:41-42:42-43:39-43:65-43:76-45:22-46:12-46:19-51:59-52:47-53:52-61:7-65:1",128
623,131,"ن","حَافَ","«حَافَ» کا بنیادی معنی «اَلْمَیْل» یا کسی جانب جھکاؤ ہے (م ۔ ل ) یعنی فیصلہ کرتے وقت ایک جانب جھک جانا اور انصاف نہ کرنا (مف) پھر «حَافَ» کے معنی کسی چیز کو اطراف سے گھٹانا اور کم کرنے کے بھی آتے ہیں (منجد)\nمثلاً : قرآن کریم میں ہے :\n«اَمۡ یَخَافُوۡنَ اَنۡ یَّحِیۡفَ اللّٰہُ عَلَیۡہِمۡ وَ رَسُوۡلُہٗ» ( 24/50 )\nترجمہ : یا ان کو یہ خوف ہے کہ خدا اور اُس کا رسول اُن کے حق میں بے انصافی کریں گے ۔","«حَافَ» دوسرے کے حق کی ادائیگی میں جانبداری کرنا اور کم دینا ۔","نا انصافی","حاف","24:50",1
624,131,"ن","عَالَ","«عَالَ» بمعنی ظلم کرنا ۔ سیدھی راہ سے ہٹنا (منجد) اور «اَلْعَوْل» ہر ایسی چیز یا کام کے متعلق استعمال ہوتا ہے جو انسان کو بوجھل کر دے اور وہ اس کے بوجھ تلے دب جائے ۔ گویا اس کے معنی حق استحقاق یعنی اپنے حق سے ناجائز طور پر زیادہ لے کر بے انصافی کرنا ہے (مف)\nمثلاً : قرآن کریم میں ہے :\n«فَاِنۡ خِفۡتُمۡ اَلَّا تَعۡدِلُوۡا فَوَاحِدَۃً اَوۡ مَا مَلَکَتۡ اَیۡمَانُکُمۡ ؕ ذٰلِکَ اَدۡنٰۤی اَلَّا تَعُوۡلُوۡا» ( 4/3 )\nترجمہ : اور اگر تمہیں اس بات کا اندیشہ ہو کہ سب عورتوں سے یکساں سلوک نہ کر سکو گے تو ایک عورت ( کافی ہے ) یا لونڈی جس کے تم مالک ہو ۔ اس سے تم بے انصافی سے بچ جاؤ گے ۔","«عَالَ» ایسی بے انصافی کرنا جس میں دوسرے کا حق بھی تلف ہو اور جس کا حق دبایا گیا ہے اس پرگراں بھی گزرے ۔","نا انصافی","عال","4:3",1
625,131,"ن","ضَازَ","«ضَازَ» بمعنی ظلم کرنا ۔ حق کم دینا ۔ «ضَیْز» بمعنی کجی  ٹیڑھا پن اور «قِسْمَۃٌ ضِیْزٰی» بمعنی ناقص اور ظالمانہ تقسیم (منجد) یعنی اپنے اور دوسروں کے حقوق متعین کرتے وقت تمام انصاف کے تقاضوں کو بالائے طاق رکھ دینا ، دھاندلی کرنا ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلَکُمُ الذَّکَرُ وَلَہُ الۡاُنۡثٰی ، تِلۡکَ اِذًا قِسۡمَۃٌ ضِیۡزٰی» ( 53/21،22 )\nترجمہ : ( مشرکو ! ) تمہارے لیے تو بیٹے ہوں اور خدا کے لیے بیٹیاں ۔ یہ تو بڑی دھاندلی کی تقسیم ہوئی ( تفہیم القرآن )","«ضَازَ» حقوق کے تعین میں انتہائی بے ضابطگی کرنا ۔","نا انصافی","ضاز","53:22",1
626,132,"ب","رَغِبَ عَنْ","«رَغِبَ» بمعنی کسی چیز کی طرف رغبت یا خواہش رکھنا اور اگر اس کا صلہ «عَن» سے ہو تو اس سے بے رغبتی کے معنی پیدا ہو جاتے ہیں ۔\nمثلاً : قرآن کریم میں ہے :\n«وَمَنۡ یَّرۡغَبُ عَنۡ مِّلَّۃِ اِبۡرٰہٖمَ اِلَّا مَنۡ سَفِہَ نَفۡسَہٗ» ( 2/130 )\nترجمہ : اور ابراہیم کے دین سے کون روگردانی کر سکتا ہے الا یہ کہ وہ اپنے آپ کو بُدّھو بنا لے ۔","«رغِب َعَنْ» بے رغبتی کے لیے عام لفظ  ہے ۔","بے رغبتی","رغب عن","2:130",1
627,132,"ب","حَصُور","«حَصَرَ» بمعنی تنگ کر کے گھیر لینا اور «حَصِر» بمعنی تنگ ہونا اور رکنا ۔ اور «حَصُوْر» اس شخص کو کہتے ہیں جو عورتوں کی طرف سے رکا رہے اور ان سے رغبت نہ رکھتا ہو ۔\nمثلاً : قرآن کریم میں ہے :\n«اَنَّ اللّٰہَ یُبَشِّرُکَ بِیَحۡیٰی مُصَدِّقًۢا بِکَلِمَۃٍ مِّنَ اللّٰہِ وَ سَیِّدًا وَّ حَصُوۡرًا وَّ نَبِیًّا مِّنَ الصّٰلِحِیۡنَ» ( 3/39 )\nترجمہ : بے شک اللہ تجھے ( اے زکریا ؑ ) یحیی کی بشارت دیتا ہے جو اللہ کے کلمہ ( عیسیٰ ؑ ) کی تصدیق کرے گا اور سردار ہو گا اور عورتوں سے رغبت نہ رکھنے والا اور پیغمبر نیکوکاروں سے ہو گا ۔","«حَصُور» بمعنی وہ شخص جو عورتوں کی طرف سے بے رغبت ہو ۔","بے رغبتی","حصور","3:39",1
628,132,"ب","زَاھِدٌ","«زَھَدَ» بمعنی بے غرض ہونا چھوڑ دینا ۔ اور «زَھِیْد» بمعنی حقیر چیز اور «زَاھِدٌ فِیْ الشَّیْء» بمعنی کسی چیز سے بے رغبتی کرنے والا یا حقیر سی چیز پر راضی ہو جانے والا (مف)\nمثلاً : قرآن کریم میں ہے :\n«وَشَرَوۡہُ بِثَمَنٍۭ بَخۡسٍ دَرَاہِمَ مَعۡدُوۡدَۃٍ ۚ وَکَانُوۡا فِیۡہِ مِنَ الزَّاہِدِیۡنَ» ( 12/20 )\nترجمہ : اور یوسف کے بھائیوں نے یوسف ؑ کو تھوڑی سی قیمت یعنی چند ٹکوں میں بیچ ڈالا اور انہیں اس بارے میں کچھ رغبت بھی نہ تھی ۔","«زَھَدَ» کسی چیز کو حقیر اور معمولی سمجھ کر اس سے بے رغبتی کرنے والا یا دلچسپی نہ لینے والا ۔","بے رغبتی","زاھد","12:20",1
629,133,"ب","تَبَرّأَ","«بَرِأَ» کے معنی ہیں کسی مکروہ یا تکلیف دہ چیز سے نجات حاصل کرنا (مف) «بَرِءتُ مِنَ الْمَرَضِ» یعنی میں تندرست ہوا ۔ اور «اَبْرِأُ الْمَرِیْض» ۔ یعنی مریض کو شفا دینا ( منجد )\nمثلاً : قرآن کریم میں ہے :\n«وَاُبۡرِئُ الۡاَکۡمَہَ وَالۡاَبۡرَصَ وَاُحۡیِ الۡمَوۡتٰی بِاِذۡنِ اللّٰہِ» ( 3/49 )\nترجمہ : اور میں خدا کے حکم سے اندھے اور برص والے کو تندرست کر دیتا ہوں اور مردے میں جان ڈال دیتا ہوں ۔\nاور «بَرَاءَۃ» بمعنی بیزاری ، قطع تعلق ۔ بائیکاٹ ۔ فق ل 113 ۔\nمثلاً : قرآن کریم میں ہے :\n«بَرَآءَۃٌ مِّنَ اللّٰہِ وَرَسُوۡلِہٖۤ» ( 9/1 )\nترجمہ : اللہ اور اس کے رسول کی طرف سے بیزاری کا اعلان ہے ۔\nاور «بَرَّأَ» کے معنی کسی کو کسی مکروہ یا تکلیف دہ بات سے نجات دینا ۔ بَری کرنا یا الزام اور تہمت وغیرہ سے دور کرنا ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«وَمَاۤ اُبَرِّئُ نَفۡسِیۡ ۚ اِنَّ النَّفۡسَ لَاَمَّارَۃٌۢ بِالسُّوۡٓءِ» ( 12/53 )\nترجمہ : اور میں اپنے تئیں پاک صاف نہیں کہتا ۔ کیونکہ نفس ( امارہ انسان کو ) برائی ہی سکھلاتا رہتا ہے ۔\nاور «تَبَرَّاَ» کے معنی مکروہ یا تکلیف دہ بات سے خود بیزار ہو جانا ۔\nمثلاً : قرآن کریم میں ہے :\n«اِذۡ تَبَرَّاَ الَّذِیۡنَ اتُّبِعُوۡا مِنَ الَّذِیۡنَ اتَّبَعُوۡا وَرَاَوُاالۡعَذَابَ وَتَقَطَّعَتۡ بِہِمُ الۡاَسۡبَابُ» ( 2/166 )\nترجمہ : اس دن ( کفر کے ) پیشوا اپنے پیروؤں سے بیزاری ظاہر کریں گے اور ( دونوں عذاب الہی ) دیکھ لیں گے اور ان کے آپس میں تعلقات منقطع ہو جائیں گے ۔","«تَبَرّا» کسی تکلیف دینے والی چیز سے یا بات سے بیزار ہونا ۔","بیزار","تبرأ","2:166-2:167-6:19-6:78-8:48-9:1-9:3-9:114-10:41-11:35-11:54-12:53-26:216-28:63-33:69-43:26-54:43-59:16-60:4",19
630,133,"ب","قَلٰی","«قلٰی» کسی سے ناراضگی کی بناء پر بیزار ہونا ۔ صَاحِبِ فِقْہُ الْلُغَۃ «قَلٰی» کو عداوت کے باب میں دوسرے درجہ پر لائے ہیں ۔ یعنی بُغْض کے بعد «قلٰی» کا درجہ ہے (ف ۔ ل 166)\nمثلاً : قرآن کریم میں ہے :\n«مَا وَدَّعَکَ رَبُّکَ وَ مَا قَلٰی» ( 93/3 )\n ترجمہ : ( اے محمد ﷺ ) تمہارے پروردگار نے نہ تو تم کو چھوڑا اور نہ ( ہی تم سے ) ناراض ہوا ۔ ( جالندھری )\nترجمہ :  نہ رخصت کر دیا تجھ کو تیرے رب نے اور نہ بیزار ہوا ( عثمانیؒ )","«قلٰی» کسی سے ناراضگی کی بناء پر اس سے بیزار ہونا ۔","بیزار","قلی","93:3",1
631,133,"ب","مَقْت","«مَقْت» کسی قبیح فعل کے ارتکاب پر سخت ناراض ہونا اور بیزار ہو جانا ۔ اور یہ «قَلٰی» کا اگلا درجہ ہے ( ف ل 166 )\nمثلاً : قرآن کریم میں ہے :\n«وَلَا تَنۡکِحُوۡا مَا نَکَحَ اٰبَآؤُکُمۡ مِّنَ النِّسَآءِ اِلَّا مَا قَدۡ سَلَفَ ؕ اِنَّہٗ کَانَ فَاحِشَۃً وَّ مَقۡتًا ؕ وَسَآءَ سَبِیۡلًا» ( 4/22 )\nترجمہ : اور جن عورتوں سے تمہارے باپوں نے نکاح کیا ہو اُن سے نکاح نہ کرنا مگر ( جاہلیت میں ) جو ہو چکا ( سو ہو چکا ) یہ نہایت ہی بے حیائی اور ناخوشی کی بات تھی اور بہت برا دستور تھا ۔ ( جالندھریؒ )","«مَقْت» کسی قبیح ( برے) فعل پر سخت ناپسندیدگی اور بیزاری ۔ ","بیزار","مقت","4:22-35:39-40:10-40:35-61:3",5
632,134,"ب","اِنَّ ، اَنَّ","«اِنَّ ، اَنَّ» یہ دونوں الفاظ اسم پر داخل ہوتے ہیں ۔ «اِنّ» کلام کے شروع میں آتا ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ اللّٰہَ عَلٰی کُلِّ شَیۡءٍ قَدِیۡرٌ » ( 2/20 )\nترجمہ :’’ بلاشہ اللہ ہر چیز پر قادر ہے ) لیکن «اَنَّ» درمیان میں آتا ہے ۔\n مثلاً : قرآن کریم میں ہے :\n«اَعۡلَمُ  اَنَّ اللّٰہَ  عَلٰی کُلِّ شَیۡءٍ قَدِیۡرٌ» ( 2/259 )\nترجمہ : میں جانتا ہوں کہ اللہ ہر چیز پر قادر ہے ۔\nیہ بات یاد رکھنا ضروری ہے کہ «قَالَ» اور اس کے مشتقات کے بعد درمیان کلام میں بھی «اِنَّ» ہی آئے گا ۔\n مثلاً : قرآن کریم میں ہے :\n«قَالَ اِنَّہٗ یَقُوۡلُ اِنَّہَا بَقَرَۃٌ» ( 2/68 )\nترجمہ : موسیٰ ؑ نے کہا کہ بلاشبہ تمہارا پروردگار کہتا ہے کہ وہ ایک گائے ہے ۔\n«عَلِمَ» اور «شَھِدَ» کے بعد درمیان کلام میں گرائمر کے لحاظ سے «اَنَّ» ہی آنا چاہیے ۔ ( جیسا کہ اوپر مثال بھی دی گئی ہے ) لیکن ایک مقام پر قرآن میں «عَلِمَ» اور «شَھِدَ» کے بعد بھی «اِنَّ» استعمال ہوا ہے ۔\nمثلاً : ارشاد باری تعالیٰ ہے :\n«وَاللّٰہُ یَعۡلَمُ  اِنَّکَ لَرَسُوۡلُہٗ ؕ وَاللّٰہُ یَشۡہَدُ اِنَّ الۡمُنٰفِقِیۡنَ لَکٰذِبُوۡنَ» ( 63/1 )\nترجمہ : اور اللہ جانتا ہے کہ آپؐ اس کے رسول ہیں ۔ اور اللہ ( یہ بھی ) گواہی دیتا ہے کہ منافق جھوٹے ہیں ۔","«اِنَّ ، اَنَّ» یہ دونوں تاکید اور تحقیق کیلئے آتے ہیں اِنَّ کلام کے شروع میں آتا ہے اور«اَنَّ» درمیان میں آتا ہے ۔","بیشک","ان ، ان","2:6-2:12-2:13-2:14-2:20-2:25-2:26-2:30-2:32-2:33-2:37-2:45-2:46-2:47-2:54-2:61-2:62-2:67-2:68-2:69-2:70-2:71-2:74-2:77-2:97-2:98-2:103-2:106-2:107-2:109-2:110-2:115-2:119-2:120-2:122-2:124-2:127-2:128-2:129-2:130-2:132-2:140-2:143-2:144-2:145-2:146-2:148-2:149-2:153-2:156-2:158-2:159-2:161-2:164-2:165-2:167-2:168-2:173-2:174-2:176-2:181-2:182-2:186-2:187-2:190-2:192-2:194-2:195-2:196-2:197-2:199-2:203-2:208-2:209-2:211-2:214-2:215-2:218-2:220-2:222-2:223-2:226-2:227-2:231-2:233-2:235-2:237-2:243-2:244-2:247-2:248-2:249-2:252-2:258-2:259-2:260-2:267-2:270-2:273-2:275-2:277-2:282-2:283-3:4-3:5-3:8-3:9-3:10-3:13-3:16-3:18-3:19-3:21-3:24-3:26-3:30-3:32-3:33-3:35-3:36-3:37-3:38-3:39-3:42-3:45-3:49-3:51-3:52-3:55-3:59-3:62-