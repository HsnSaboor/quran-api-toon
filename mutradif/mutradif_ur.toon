      "d": "«غَمَّ» کا بنیادی معنی ڈھانکنا اور چھپانا ہے ۔ «غُمّٰی» بمعنی غبار اور تاریکی اور «غَمَام» بمعنی بادل جو سورج کی روشنی کو ڈھانپ لیتا ہے ۔ اور «غم» بمعنی بے چینی ۔ دُکھ ، تکلیف (مف ۔ منجد)\nمثلاً : قرآن کریم میں ہے :\n«ثُمَّ اَنۡزَلَ عَلَیۡکُمۡ مِّنۡۢ بَعۡدِ الۡغَمِّ اَمَنَۃً نُّعَاسًا یَّغۡشٰی طَآئِفَۃً مِّنۡکُمۡ» ( 3/154 )\nترجمہ : پھر اللہ تعالیٰ نے غم ورنج کے بعد تم پر تسلی نازل فرمائی ( یعنی ) نیند کہ تم میں سے ایک جماعت پر طاری ہو گئی ۔"
    },
    {
      "id": 3329,
      "a": "د",
      "h": "دکھ - رنج",
      "hw": "دکھ",
      "s": "«رنج» دکھ کا اصل معنی ہے جو انسان کے دل پر اور عقل پر زور دار اثر ڈالتا ہے۔",
      "d": "«رنج» اس کا معنی ہے کہ کسی کے دل پر اور عقل پر بڑا دکھ اور پریشانی پیدا کرنا، جو انسان کو اپنے خود سے دور کر دے۔ یہ الفاظ میں ہی نہیں بلکہ عقل اور دل کے اندر بھی کام کرتا ہے۔ یہ دکھ اور پریشانی کا ایک مخصوص قسم ہے جو کسی کے ذہن اور دل میں گہرائی سے پیدا ہوتی ہے۔ مثلاً : قرآن کریم میں ہے: «وَلَمْ يَكُن لِّلَّذِينَ كَفَرُوا مِنْ أَهْلِ الْكِتَابِ وَالْمُؤْمِنِينَ حَبٌّ حَتَّى تَأْتِيَهُمُ الْبَيِّنَةُ مِن رَّبِّكَ فَقَدْ كَانَ فِي أَهْلِ الْكِتَابِ مِن قَبْلِهَا حَبٌّ وَإِنَّهُمْ لَمْ يَكُونُوا مُحَرَّكِينَ مِنْ أَهْلِ الْكِتَابِ وَالْمُؤْمِنِينَ حَبٌّ حَتَّى تَأْتِيَهُمُ الْبَيِّنَةُ مِن رَّبِّكَ» (البقرة/۲۰۷) ترجمہ : «اور اللہ تعالی نے جو اہلِ کتاب اور مؤمنین کے درمیان دکھ کا احساس پیدا کیا ہے، جب تک کہ آپ کے رب کی واضح بات آئے، تو پہلے اس وقت تک اہلِ کتاب اور مؤمنین میں ایسا دکھ کا احساس نہ تھا، جب تک کہ آپ کے رب کی واضح بات نہ آئے۔»"
    }
  ],
  "726": [
    {
      "id": 3330,
      "a": "ب",
      "h": "بےچینی - بےچینی",
      "hw": "بےچینی",
      "s": "«بےچینی» اس معنی کو دکھاتی ہے کہ کسی کام کو بے پاس اور بے ذوقی سے کرنا جو اصل مفہوم سے دور ہو۔",
      "d": "«بےچینی» کا اردو میں معنی ہے کہ کسی کام کو بے پاس، بے ذوقی، اور بے توجہی سے کرنا۔ اس کا عربی ریٹ کلمہ بیچینی (بَيْچِینِی) ہے جو اصل میں کسی کام کو بے توجہی سے کرنے کا الفاظ ہے۔ اس کا اصل مطلب ہے کہ کسی کام کو بے سرگرمی، بے ذوقی، اور بے پاسی سے کرنا۔ اس سے مختلف ہے کہ بےچینی میں بے توجہی اور بے ذوقی کا مطلب ہوتا ہے، جبکہ دوسرے الفاظ جیسا کہ \"بے دلی\" یا \"بے احساس\" میں بے احساسی کا مطلب ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n\n«وَلَوْلَا دَعَوَتُهُمْ لَقَدْ كُنتُمْ مِّنَ الْمُحْسِنِينَ» (البقرة / ۲۱۷)\nترجمہ : «اور اگر آپ نے ان کی دعا نہ کی ہوتی تو آپ اصل میں محسنوں میں سے تھے۔»"
    },
    {
      "id": 3331,
      "a": "ب",
      "h": "بےچینی - اضطراب",
      "hw": "بےچینی",
      "s": "«اضطراب» بےچینی کا مطلب ہے کہ کوئی چیز کھڑی ہو کر چلنا آسان نہ ہو، جیسے گھڑی کا سر دھوپ میں کھڑی ہو کر پھیل جائے۔",
      "d": "«اضطراب» کا اصل لغتی معنی ہے کہ کچھ چیز کھڑی ہو کر چلنا آسان نہ ہو، جیسے گھڑی کا سر دھوپ میں کھڑی ہو کر پھیل جائے۔ اس کا ریشه اردو کے اصطلاحات میں \"اُضْطِرَاب\" سے ہے جو کہ کسی چیز کو کھڑی کرنا یا اسے دھوپ میں پھیلانا ہے۔ اس کے مقابلے میں \"بےچینی\" کا مطلب ہے کہ کوئی چیز کھڑی ہو کر چلنا آسان نہ ہو، جیسے گھڑی کا سر دھوپ میں کھڑی ہو کر پھیل جائے۔ اس کا معنی ہے کہ کچھ چیز کھڑی ہو کر چلنا آسان نہ ہو، جیسے گھڑی کا سر دھوپ میں کھڑی ہو کر پھیل جائے۔\n\nمثلاً : قرآن کریم میں ہے:\n«وَاللَّذِينَ جَاءُوا مِن بَعْدِهِمْ يَقُولُونَ رَبَّنَا غَفِرْ لَنَا وَلِإِخْوَانِنَا الَّذِينَ سَبَقُوا بِالْإِيمَانِ وَلَا نَجْعَلْ فِي قُلُوبِنَا غِلًّا لِلْمُؤْمِنِينَ وَرَبَّنَا إِنَّكَ رَءُوفٌ رَحِيمٌ» (آل عمران / 194)\nترجمہ : «اور جن لوگوں نے بعد میں آئے انہوں نے کہا کہ، «ہے اے ہمارا رب! ہمیں اور ہمارے بھائیوں کو جو پہلے ایمان لایا، اور ہماری قلب میں مُؤْمِنین کے لئے غُلّت نہ ڈالو، اور ہے اے ہمارا رب! تو اللہ ہے، جو رَءُوف و رَحِیم ہے۔»"
    },
    {
      "id": 3332,
      "a": "ب",
      "h": "بےچینی - بےقراری",
      "hw": "بےچینی",
      "s": "«بےقراری» کا معنی ہے نامعلوم اور غیر محفوظ جگہ پر رہنا، جو بےچینی کے مفہوم کو ظاہر کرتا ہے۔",
      "d": "«بےقراری» کا عربی اصل ہے بے-قراری جس کا مطلب ہے نامعلوم، غیر محفوظ، اور نامعلوم جگہ پر رہنا۔ یہ لفظ اصل میں ہر قسم کی ناامیدی اور عدم استحکام کا اشارہ دیتا ہے، جو بےچینی کے سلسلے میں انسان کی حالت کو واضح کرتا ہے۔ اس کے مقابلے میں «بےچینی» کا مطلب ہوتا ہے کہ کسی چیز کو نامعلوم اور غیر محفوظ جگہ پر رکھنا، جو بےقراری کا وضاحتی معنی ہے۔ اس کا مترادف «بےثباتی» یا «بےرویائی» ہوتا ہے، لیکن «بےقراری» کا خاص معنی ہے کہ کسی چیز کو نامعلوم جگہ پر رکھنا جو بےچینی کی صفت ہوتی ہے۔\n\nمثلاً : قرآن کریم میں ہے:\n«وَالَّذِينَ جَاءُوا مِن بَعْدِهِمْ يَقُولُونَ رَبَّنَا أَنْزِلْ لَنَا مِنْ فَوْقِنَا ظَهْرًا مِّنْ سَاقَطٍ وَرَحْمَةً مِّنْ عِندِكَ وَلِيَكُونَ لَنَا آمِنًا مِّنْ لَّدُنْهُ وَلَوْ أَنَّهُمْ كَانُوا يَعْلَمُونَ» (البقرۃ ۲:۲۴۷)\nترجمہ : «اور جن لوگوں نے بعد میں آئے، وہ کہتے ہیں: «ہے رب، ہمیں آسمان سے نیچے ساقط ہوئی بارش کو اور تیرا رحمت کو انداز کر، تاکہ ہمیں تیرے پاس سے امن حاصل ہو جائے۔ اگر وہ لوگ جانتے تو وہ کیا کرتے؟»"
    }
  ],
