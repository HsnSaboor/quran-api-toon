  "822": [
    {
      "id": 3566,
      "a": "م",
      "h": "مٹی - مٹی",
      "hw": "مٹی",
      "s": "«مٹی» سے مراد زمین کی وہ نرم اور دھول نما مادہ ہے جس سے انسان کیcreation ہوئی۔",
      "d": "«مٹی» اردو زبان کا لفظ ہے جو دراصل عربی زبان کے لفظ «طين» (ط-ی-ن) سے نکلا ہے۔ اس کا مطلب ہے کیچڑ یا گیلی مٹی جو زمین کی سطح پر پائی جاتی ہے۔ اردو میں اسے عام طور پر مٹی کہتے ہیں جبکہ عربی میں اس کے کئی الفاظ ہیں جیسے «طين» (کیچڑ)، «تراب» (مٹی)، اور «أرض» (زمین)۔ فرق یہ ہے کہ «مٹی» خاص طور پر نرم اور چپکنے والی مٹی کو کہتے ہیں جو انسان کی creation کا بنیادی مادہ ہے، جبکہ «تراب» عام مٹی کو کہتے ہیں۔ قرآن کریم میں اللہ تعالی نے انسان کو اسی مٹی سے پیدا کیا ہے۔\nمثلاً : قرآن کریم میں ہے:\n«إِنَّ اللَّهَ يُحِبُّ الْمُحْسِنِينَ» (سورۃ البقرہ / 195)\nترجمہ : بے شک اللہ نیکی کرنے والوں سے محبت کرتا ہے"
    },
    {
      "id": 3567,
      "a": "م",
      "h": "مٹی - خاک",
      "hw": "مٹی",
      "s": "«خاک» عربی زبان کا لفظ ہے جو اردو میں «مٹی» کے معنی رکھتا ہے یعنی مٹی، دھول، خشک زمین۔",
      "d": "«خاک» کی جڑ عربی زبان کے triad خ-و-ک ہے۔ اس کا بنیادی معنی زمین، مٹی، دھول اور خشک مٹی کا ہے۔ اردو میں «مٹی» کی اصل سنسکرت/پراکرت سے ہے، لیکن قرآنی تراجم میں «خاک» کو «مٹی» کے معنی میں بولا اور سمجھا جاتا ہے۔ فرق یہ ہے کہ عربی «خاک» زمین کی سطح پر بکھری ہوئی دھول اور خشک مٹی کو کہتے ہیں، جبکہ اردو «مٹی» عموماً گیلی یا سخت مٹی دونوں کو شامل ہے۔ قرآن میں «خاک» کا لفظ زمین اور انسان کی تخلیق کے سیاق میں بھی آیا ہے۔\nمثلاً : قرآن کریم میں ہے:\n«وَإِنَّ عَلَیۡکُمۡ لَحَافِظِینَ ۙ﴿۱۰﴾ کِرامًا کَاتِبِینَ ۙ﴿۱۱﴾ یَعۡلَمُونَ مَا تَفۡعَلُونَ» (الانفطار 82/10-12)\nترجمہ : اور بے شک تم پر (اعمال کی) حفاظت کرنے والے (فرشتے) ہیں، شریف (اور) لکھنے والے (فرشتے)، جو تم جو کچھ کرتے ہو وہ جانتے ہیں۔\n\n(یہاں «خاک» لفظ براہِ راست نہیں ہے لیکن قرآن میں خاک سے متعلق آیات موجود ہیں)۔\n\nایک اور واضح مثال:\n«وَمِنۡہُمۡ مَّنۡ یَّقُولُ رَبَّنَاۤ اٰتۡنَا فِی الدُّنۡیَا حَسَنَۃً وَّفِی الۡاٰخِرَۃِ حَسَنَۃً وَّقِنَا عَذَابَ النَّارِ» (البقرۃ 2/201)\nترجمہ : اور ان میں سے کچھ ایسے ہیں جو کہتے ہیں: اے ہمارے رب! ہمیں دنیا میں بھی بھلائی عنایت فرما اور آخرت میں بھی بھلائی عنایت فرما اور ہمیں آگ کے عذاب سے بچا۔"
    }
  ],
