      "hw": "صبر",
      "s": "«تحمل» صبر کے مفہوم میں بوجھ اٹھانے کی استعداد اور مشقت کو برداشت کرنے کی خاص کیفیت کو نمایاں کرتا ہے۔",
      "d": "«تحمل» اس کا معنی ہے کسی تکلیف، ذمہ داری یا مشکل کو شعوری طور پر اپنے اوپر لینا اور اسے ثابت قدمی کے ساتھ برداشت کرنا۔ یہ لفظ 'ح-م-ل' کے مادے سے نکلا ہے جس کا بنیادی مفہوم 'اٹھانا' یا 'لادنا' ہے۔ دوسرے الفاظ جیسے 'صبْر' (برداشت) یا 'ثبات' (استقامت) کے مقابلے میں تحمل میں فعال رضامندی اور بوجھ کے انتخاب کا پہلو غالب ہے۔ مثلاً : قرآن کریم میں ہے: «رَبَّنَا وَلَا تُحَمِّلْنَا مَا لَا طَاقَةَ لَنَا بِهِ» (البقرہ 2/286) ترجمہ : اے ہمارے رب! ہم پر ایسا بوجھ نہ ڈال جس کی ہم میں طاقت نہ ہو۔"
    },
    {
      "id": 3317,
      "a": "ص",
      "h": "صبر - برداشت",
      "hw": "صبر",
      "s": "«برداشت» صبر کے تناظر میں مشکلات کو پُرسکونی اور استقلال کے ساتھ جھیلنے کی خاصیت کو ظاہر کرتا ہے۔",
      "d": "«برداشت» اس کا معنی ہے کسی تکلیف یا آزمائش کو بغیر شکوہ کے دلیری اور ضبط کے ساتھ سہنا۔ یہ لفظ ’برد‘ (ٹھنڈک) کے مادے سے نکلا ہے جو صبر کے عمل میں جذبات کو ٹھنڈا رکھنے کی طرف اشارہ کرتا ہے۔ دوسرے الفاظ جیسے ’تحمل‘ (برداشت کرنا) کے برعکس، ’برداشت‘ میں مصیبت کو قبول کرنے کے ساتھ ساتھ اس پر عمل کی مضبوطی بھی شامل ہے۔ مثلاً : قرآن کریم میں ہے: «وَاسْتَعِينُوا بِالصَّبْرِ وَالصَّلَاةِ» (2 / 153) ترجمہ : اور صبر اور نماز کے ذریعے مدد طلب کرو۔"
    }
  ],
  "722": [
    {
      "id": 3318,
      "a": "غ",
      "h": "غلطی - غلطی",
      "hw": "غلطی",
      "s": "«غلطی» سے مراد کسی کام میں بھول، چوک یا راستے سے انحراف کی صورت میں سرزد ہونے والی خطا ہے جو عموماً غیر ارادی یا غفلت کے سبب ہوتی ہے۔",
      "d": "«غلطی» اس کا معنی ہے کسی کام میں نادانستہ یا غیر محتاط رویے کے باعث حق سے تجاوز کرنا۔ لغوی اعتبار سے یہ عربی ثلاثی مجرد 'غ ل ط' سے ماخوذ ہے جس میں 'گمراہی'، 'بھٹکنا' یا 'حقائق کو ٹیڑھا کرنے' کا مفہوم پایا جاتا ہے۔ یہ لفظ 'خطأ' (نادانستہ غلطی) سے اس لحاظ سے مختلف ہے کہ 'غلطی' میں زیادہ تر شعوری غفلت یا دلیل کو نظرانداز کرنے کا پہلو شامل ہوتا ہے۔ مثلاً : قرآن کریم میں ہے: «وَمَا مَنَعَ النَّاسَ أَن يُؤْمِنُوا إِذْ جَاءَهُمُ الْهُدَىٰ إِلَّا أَن قَالُوا أَبَعَثَ اللَّهُ بَشَرًا رَّسُولًا» (18/55) ترجمہ : اور لوگوں کو ایمان لانے سے صرف اس بات نے روکا کہ جب ان کے پاس ہدایت آئی تو وہ کہنے لگے کیا اللہ نے انسان ہی کو رسول بنا کر بھیجا؟ (یہاں 'مَّغَالِطَةً' کی بنیاد پر غلط استدلال کی طرف اشارہ ہے)۔"
    },
    {
      "id": 3320,
      "a": "غ",
      "h": "غلطی - لغزش",
      "hw": "غلطی",
      "s": "«لغزش» کا معنی ہے غلطی کا اظہار جو بے قصد یا بے خبرگی سے ہوتی ہے",
      "d": "«لغزش» اس کا معنی ہے غلطی کا اظہار جو بے قصد یا بے خبرگی سے ہوتی ہے۔ اس کا عربی ریز وہ ہے جو ہر چیز کو ہدایت دینے والی ہوتی ہے، اور اس کا معنی ہے \"ہدایت کے خلاف\"۔ یہ الفاظ بھی ہیں: \"غلطی\"، \"افسوس\"، \"خطا\"۔ لغزش کا اصل معنی ہے ہدایت کے خلاف ہونا، جب کہ غلطی کا معنی ہے صحیح سے دور ہونا۔ مثلاً : قرآن کریم میں ہے:\n«وَلَا تَقُولُوا لِمَنْ يَمُوتُ فِي مَلْكِهِ أَنَّهُ مَوْتٌ إِلَّا أَنْ تَقُولُوا لَهُ لَعَلَّ اللَّهَ لِيَجْعَلَ لَكُمْ خَيْرًا فِي مَلَكِهِ وَلَعَلَّهُ يَمُوتُ فِي مَلْكِهِ وَأَنْتُمْ تَعْمَلُونَ» (سورة النمل، آیت 84)\nترجمہ : اسے نہ کہہو کہ وہ مر گیا ہے، بلکہ کہہو کہ شاید اللہ تمہارے ملک میں اچھا ہو سکتا ہے، اور شاید وہ اپنے ملک میں موت کرے گا، جبکہ تم لوگ عمل کرتے ہو۔"
    }
  ],
  "723": [
    {
      "id": 3321,
      "a": "ا",
      "h": "افسوس - افسوس",
      "hw": "افسوس",
      "s": "«افسوس» غم یا پچھتاوا کا اظہار ہے جو کسی ناگزیر نقصان یا موقع کے ضیاع پر شدید دکھ کو ظاہر کرتا ہے۔",
      "d": "«افسوس» اس کا معنی ہے کسی ناقابل تلافی نقصان، ناکامی، یا موقع کھونے پر دل میں اٹھنے والا شدید غم یا پشیمانی۔ یہ لفظ عربی میں فارسی سے وارد ہوا ہے اور قرآنی عربی میں اس کے قریبی مترادف «حَسْرَة» (ح س ر) کا استعمال ہوا ہے جو اسی جذبے کو بیان کرتا ہے۔ «افسوس» عام پشیمانی («نَدم») سے مختلف ہے، کیونکہ یہ مستقبل کی توقعات کے بجائے ماضی کے irreversible نقصان پر مرکوز ہوتا ہے۔ مثلاً : قرآن کریم میں ہے: «يَا حَسْرَةً عَلَى الْعِبَادِ» (36 / 30) ترجمہ : اے بندوں پر افسوس! (کہ انہوں نے حق کو کیسے نظرانداز کیا)۔"
    },
    {
      "id": 3322,
      "a": "ا",
      "h": "افسوس - حسرت",
      "hw": "افسوس",
      "s": "«حسرت» کا مفہوم افسوس کی شدت، دیرپا پچھتاوا اور موقع گزر جانے کے بعد حاصل ہونے والے احساس کو بیان کرتا ہے۔",
      "d": "«حسرت» اس کا معنی ہے کسی ناقابل تلافی نقصان، موقع کے ضیاع، یا ماضی کے اعمال پر شدید پشیمانی کا گہرا احساس۔ یہ لفظ عربی مصدر «ح-س-ر» سے ماخوذ ہے جو 'نقصان' یا 'کمی' کو ظاہر کرتا ہے۔ دیگر مترادفات جیسے 'ندامت' یا 'غم' کے برعکس، حسرت میں مستقبل کی بے چینی اور گزرے ہوئے لمحات کی غیر قابل واپسی کی کیفیت شامل ہوتی ہے۔ مثلاً : قرآن کریم میں ہے: «يَقُولُ يَا لَيْتَنِي قَدَّمْتُ لِحَيَاتِي» (۸۹ / ۲۴) ترجمہ : وہ کہے گا کہ اے کاش! میں نے اپنی زندگی کے لیے پہلے ہی کچھ بھیج دیا ہوتا۔"
    },
    {
      "id": 3323,
      "a": "ا",
      "h": "افسوس - ملال",
      "hw": "افسوس",
      "s": "«ملال» افسوس کی ایک گہری اور دیرپا کیفیت کو بیان کرتا ہے جو کسی ناکامی یا ماضی کے اعمال پر پشیمانی کے احساس سے متعلق ہوتی ہے۔",
      "d": "«ملال» اس کا معنی ہے کسی کام کے نتیجے میں پیدا ہونے والا شدید افسوس یا پچھتاوا جو دل میں گہرائی تک اثر کرے۔ یہ لفظ عام افسوس (جیسے حزن یا غم) سے مختلف ہے، کیونکہ یہ بار بار ذہن میں آنے والی پشیمانی اور روحانی تھکن کو ظاہر کرتا ہے۔ اس کی لغوی اصل 'م ل ل' ہے جو تکرار یا تھکن کے معنی دیتا ہے۔ مثلاً : قرآن کریم میں ہے: «رُّبَمَا يَوَدُّ الَّذِينَ كَفَرُوا لَوْ كَانُوا مُسْلِمِينَ» (15 / 2) ترجمہ : کبھی ایسا ہوگا کہ کافر آرزو کریں گے کہ کاش وہ مسلمان ہوتے۔"
    }
  ],
  "724": [
    {
      "id": 3324,
      "a": "خ",
      "h": "خوشی - خوشی",
      "hw": "خوشی",
      "s": "«خوشی» قرآن میں اس سے مراد قلبی مسرت، اطمینان اور اللہ کی نعمتوں پر شکرگزاری کا جذبہ ہے جو عارضی دنیاوی لذتوں سے بالاتر ہوتی ہے۔",
      "d": "«خوشی» اس کا معنی ہے داخلی سکون، مثبت جذبات اور ربانی انعامات کے ادراک پر پیدا ہونے والی کیفیت۔ عربی میں اس کے قریبی مترادفات جیسے 'فرح' (عارضی خوشی/غرور) اور 'سرور' (دلی تسکین) سے یہ لفظ روحانی پاکیزگی اور پائیدار اطمینان کے تناظر میں ممتاز ہے۔ مثلاً : قرآن کریم میں ہے: «قُلْ بِفَضْلِ اللَّهِ وَبِرَحْمَتِهِ فَبِذَٰلِكَ فَلْيَفْرَحُوا هُوَ خَيْرٌ مِّمَّا يَجْمَعُونَ» (10/58) ترجمہ : کہہ دیجیے کہ اللہ کے فضل اور اس کی رحمت کے ساتھ، پس اسی پر چاہیے کہ خوشی کریں، یہ ان سب چیزوں سے بہتر ہے جو وہ جمع کرتے ہیں۔"
    },
    {
      "id": 3325,
      "a": "خ",
      "h": "خوشی - مسرت",
      "hw": "خوشی",
      "s": "«مسرت» کا مفہوم گہری اندرونی خوشی اور قلبی مسرت ہے جو دیرپا اور پاکیزہ ہوتی ہے۔",
      "d": "«مسرت» اس کا معنی ہے گہری اور پوشیدہ خوشی جو دل میں محسوس ہوتی ہے، یہ لفظ 'س ر ر' کی بنیاد پر ہے جو اندرونی تسکین اور پاکیزہ مسرت کو ظاہر کرتا ہے۔ دوسرے الفاظ جیسے 'فرح' عارضی یا ظاہری خوشی کو بیان کرتے ہیں جبکہ 'مسرت' میں گہرائی اور پائیداری پائی جاتی ہے۔ مثلاً : قرآن کریم میں ہے: «فَوَقَاهُمُ اللَّهُ شَرَّ ذَٰلِكَ الْيَوْمِ وَلَقَّاهُمْ نَضْرَةً وَسُرُورًا» (76 / 11) ترجمہ : پس اللہ نے انہیں اس دن کی برائی سے بچا لیا اور انہیں تروتازگی اور خوشی عطا کی۔"
    },
    {
      "id": 3326,
      "a": "خ",
      "h": "خوشی - شادمانی",
      "hw": "خوشی",
      "s": "«شادمانی» خوشی کا اصل مطلب ہے جو انسان کے دل کی خوشحالی اور آرام کو ظاہر کرتا ہے۔",
      "d": "«شادمانی» کا عربی اصل ریز کی طرح ہے جو دل کی خوشحالی، آرام اور فرح کو دکھاتا ہے۔ یہ الفاظ کے ساتھ مل کر خوشی کا مطلب دیتا ہے۔ جب کسی شخص کے دل میں خوشی کا احساس ہوتا ہے تو وہ شادمان ہوتا ہے۔ اس کا مترادف کچھ اور الفاظ ہیں جیسا کہ فرح، سرور، بہتری، اور مسرت۔ لیکن «شادمانی» میں اصل مطلب ہے دل کی خوشحالی اور آرام جو کہ دل کی حالت کو ظاہر کرتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَاللَّذِينَ جَاءُوا مِن بَعْدِهِمْ يَقُولُونَ رَبَّنَا اغْفِرْ لَنَا وَلِإِخْوَانِنَا الَّذِينَ سَبَقُوا بِالْإِيمَانِ وَلَا نَجْعَلْ فِي قُلُوبِنَا غِلًّا لِّلَّذِينَ آمَنُوا رَبَّنَا إِنَّكَ رَءُوفٌ رَّحِيمٌ» (الحجرات / ۱۳)\nترجمہ : «اور جو لوگ بعد میں آئے، وہ کہتے ہیں کہ «ہے رب! ہمیں اور ہمارے بھائیوں کو جو پہلے ایمان لائے، غفران دے دے۔ اور ہم کے دلوں میں ان لوگوں کے لئے غُرور نہ کرو جو ایمان لائے۔ ہے رب! تیری مہربانی اور رحمت کا مالک ہے۔»"
    }
  ],
  "725": [
