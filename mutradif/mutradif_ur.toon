      "hw": "وضو",
      "s": "«يمم» کا استعمال وضو کے متبادل کے طور پر مٹی سے طہارت کا قصد کرنے کے لیے ہوتا ہے۔",
      "d": "«يمم» اس کا لغوی معنی قصد کرنا، ارادہ کرنا، یا کسی چیز کا رخ کرنا ہے۔ اسلامی شریعت کی اصطلاح میں، اور خاص طور پر وضو کے سیاق و سباق میں، «يمم» سے مراد پانی کی عدم دستیابی، یا اس کے استعمال سے کسی شرعی عذر (مثلاً بیماری) کی صورت میں پاک مٹی کے ذریعے طہارت حاصل کرنے کا ارادہ اور عمل ہے۔ یہ وضو (اور غسل) کا شرعی متبادل ہے، جسے تیمم کہتے ہیں۔ اس کا خاص نکتہ (nuance) یہ ہے کہ یہ پانی کی جگہ مٹی سے طہارت کا قصد اور عمل ہے، نہ کہ بذاتِ خود پانی سے وضو کرنا۔ اللہ تعالیٰ نے مسلمانوں پر آسانی کے لیے یہ رخصت عطا فرمائی ہے تاکہ وہ ہر حال میں پاکیزگی حاصل کر سکیں۔\nمثلاً : قرآن کریم میں ہے:\n«يَا أَيُّهَا الَّذِينَ آمَنُوا إِذَا قُمْتُمْ إِلَى الصَّلَاةِ فَاغْسِلُوا وُجُوهَكُمْ وَأَيْدِيَكُمْ إِلَى الْمَرَافِقِ وَامْسَحُوا بِرُءُوسِكُمْ وَأَرْجُلَكُمْ إِلَى الْكَعْبَيْنِ ۚ وَإِن كُنتُمْ جُنُبًا فَاطَّهَّرُوا ۚ وَإِن كُنتُم مَّرْضَىٰ أَوْ عَلَىٰ سَفَرٍ أَوْ جَاءَ أَحَدٌ مِّنكُم مِّنَ الْغَائِطِ أَوْ لَامَسْتُمُ النِّسَاءَ فَلَمْ تَجِدُوا مَاءً فَتَيَمَّمُوا صَعِيدًا طَيِّبًا فَامْسَحُوا بِوُجُوهِكُمْ وَأَيْدِيكُم مِّنْهُ ۚ مَا يُرِيدُ اللَّهُ لِيَجْعَلَ عَلَيْكُم مِّنْ حَرَجٍ وَلَٰكِن يُرِيدُ لِيُطَهِّرَكُمْ وَلِيُتِمَّ نِعْمَتَهُ عَلَيْكُمْ لَعَلَّكُمْ تَشْكُرُونَ» (5 / 6)\nترجمہ : اے ایمان والو! جب تم نماز کے لیے کھڑے ہونے کا ارادہ کرو تو اپنے چہروں کو اور کہنیوں تک اپنے ہاتھوں کو دھو لو اور اپنے سروں کا مسح کرو اور ٹخنوں تک اپنے پاؤں (بھی دھو لو)۔ اور اگر تم جنبی ہو تو خوب پاک ہو جاؤ (غسل کر لو)۔ اور اگر تم بیمار ہو یا سفر میں ہو یا تم میں سے کوئی رفع حاجت کر کے آیا ہو یا تم نے عورتوں کو چھوا ہو اور تمہیں پانی نہ ملے تو پاک مٹی سے تیمم کرو، پس اپنے چہروں اور ہاتھوں کا اس سے مسح کرو۔ اللہ تم پر کوئی تنگی نہیں کرنا چاہتا، بلکہ تمہیں پاک کرنا چاہتا ہے اور تم پر اپنی نعمت تمام کرنا چاہتا ہے تاکہ تم شکر گزار بنو۔"
    },
    {
      "id": 3024,
      "a": "و",
      "h": "وضو - وضو",
      "hw": "وضو",
      "s": "«يدي» وضو کے تناظر میں جسم کے اس حصے (ہاتھ) کو بیان کرتا ہے جسے طہارت کے لیے کہنیوں تک دھونا ضروری ہے۔",
      "d": "«يدي» اس کا معنی ہے 'ہاتھ'۔ وضو کے تناظر میں، یہ لفظ اس جسمانی عضو (ہاتھ) کی نشاندہی کرتا ہے جسے طہارت کے عمل میں کہنیوں تک دھونا فرض ہے۔ اس کا مفہوم کسی حرکت یا فعل سے زیادہ، اس عضو کی ذات سے متعلق ہے جو ایک شرعی حکم کی تکمیل کا حصہ ہے۔\nمثلاً : قرآن کریم میں ہے:\n«يَا أَيُّهَا الَّذِينَ آمَنُوا إِذَا قُمْتُمْ إِلَى الصَّلَاةِ فَاغْسِلُوا وُجُوهَكُمْ وَأَيْدِيَكُمْ إِلَى الْمَرَافِقِ وَامْسَحُوا بِرُءُوسِكُمْ وَأَرْجُلَكُمْ إِلَى الْكَعْبَيْنِ ۚ» (5 / 6)\nترجمہ : اے ایمان والو! جب تم نماز کے لیے اٹھو تو اپنے چہروں کو اور اپنے ہاتھوں کو کہنیوں تک دھو لو اور اپنے سروں کا مسح کرو اور اپنے پاؤں کو ٹخنوں تک دھو لو۔"
    },
    {
      "id": 3025,
      "a": "و",
      "h": "وضو - وضو",
      "hw": "وضو",
      "s": "«نسو» اس بھول جانے یا چھوڑ دینے کی کیفیت کو بیان کرتا ہے جس کے نتیجے میں وضو کے اجزاء یا شرائط میں سے کوئی چیز غیر ارادی طور پر رہ جائے اور وضو نامکمل رہ جائے۔",
      "d": "«نسو» اس کا معنی ہے بھول جانا، نظر انداز کر دینا، ترک کر دینا یا چھوڑ دینا۔ وضو کے تناظر میں، یہ لفظ اس کیفیت کو بیان کرتا ہے جب کوئی شخص وضو کے فرائض یا سنتوں میں سے کسی چیز کو غیر ارادی طور پر بھول جائے یا اسے ادا کرنا چھوڑ دے، جس سے وضو کی صحت متاثر ہو سکتی ہے۔ یہ انسانی کمزوری اور غفلت کی طرف اشارہ کرتا ہے کہ عبادات میں بھی انسان سے سہو ہو سکتا ہے، لہٰذا ایسے بھول جانے کی صورت میں وضو کا اعادہ یا اس جزء کو مکمل کرنا ضروری ہو جاتا ہے۔\nمثلاً : قرآن کریم میں ہے:\n«فَلَمَّا بَلَغَا مَجْمَعَ بَيْنِهِمَا نَسِيَا حُوتَهُمَا فَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ سَرَبًا» (18 / 61)\nترجمہ : پھر جب وہ دونوں (اس جگہ) پہنچے جہاں دو دریا ملتے تھے، تو وہ اپنی مچھلی بھول گئے، چنانچہ اس نے (زندگی پا کر) سمندر میں اپنا راستہ بنا لیا سرنگ کی طرح۔"
    },
    {
      "id": 3026,
      "a": "و",
      "h": "وضو - وضو",
      "hw": "وضو",
      "s": "«مرض» کا وضو کے تصور سے براہ راست کوئی لسانی یا شرعی تعلق نہیں ہے، کیونکہ وضو کا تعلق \"وضأ\" سے ہے جبکہ \"مرض\" بیماری کے معنی میں آتا ہے۔",
      "d": "«مرض» اس کا معنی ہے بیماری، علت یا نقص۔ یہ لفظ وضو (طہارت کے ایک مخصوص عمل) کے شرعی یا لغوی معنی سے قطعاً متعلق نہیں ہے، کیونکہ وضو کا لفظ عربی کے مادہ \"و-ض-أ\" سے ماخوذ ہے جس کا بنیادی مطلب پاکیزگی، صفائی اور چمک دمک ہے۔ اس کے برعکس، \"مرض\" کا تعلق جسمانی یا روحانی صحت کی خرابی اور بیماری سے ہے۔ لہٰذا، وضو کے باب میں اس لفظ کا استعمال نہ تو عربی زبان کے اعتبار سے درست ہے اور نہ ہی اسلامی شریعت کے تناظر میں کوئی بنیاد رکھتا ہے۔\n\nمثلاً : قرآن کریم میں ہے:\n«فِي قُلُوبِهِم مَّرَضٌ فَزَادَهُمُ اللَّهُ مَرَضًا ۖ وَلَهُمْ عَذَابٌ أَلِيمٌ بِمَا كَانُوا يَكْذِبُونَ» (2 / 10)\nترجمہ : ان کے دلوں میں (نفاق کی) بیماری ہے، سو اللہ نے ان کی بیماری اور بڑھا دی، اور ان کے لیے دردناک عذاب ہے اس جھوٹ کے بدلے جو وہ بولتے تھے۔"
    }
  ],
