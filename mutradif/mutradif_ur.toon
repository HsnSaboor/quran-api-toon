      "hw": "غم",
      "s": "«ملال» غم کے تناظر میں کسی چیز کے نہ ہونے یا کھو جانے پر پچھتاوے اور افسوس کے گہرے احساس کو ظاہر کرتا ہے۔",
      "d": "«ملال» اس کا معنی ہے کسی نقصان، محرومی، یا ندامت کے باعث دل میں پیدا ہونے والا دکھ اور پشیمانی کا وہ کیفیتی احساس جو تسلی نہ پانے کی صورت میں گہرے رَس تک جا بیٹھتا ہے۔ یہ لفظ عام غم (حزن) سے اس لحاظ سے مختلف ہے کہ اِس میں ناامیدی اور ماضی کے بارے میں اَلمیلی سوچ کا عنصر غالب ہوتا ہے۔ مثلاً : قرآن کریم میں ہے: «رُبَمَا يَوَدُّ الَّذِينَ كَفَرُوا لَوْ كَانُوا مُسْلِمِينَ» (15 / 2) ترجمہ : کبھی ایسا ہوگا کہ کافر آرزو کریں گے کہ کاش وہ مسلمان ہوتے۔ یہاں ’يَوَدُّ‘ (آرزو کرنا) کے ذریعے کفار کے اُس اَلمیلی حسرت کو بیان کیا گیا ہے جو ’ملال‘ کے مفہوم سے ہم آہنگ ہے۔"
    },
    {
      "id": 3280,
      "a": "غ",
      "h": "غم - رنج",
      "hw": "غم",
      "s": "«رنج» احساس کمزوری، پیچیدگی اور ناامیدی سے جڑا ہوا ہے جو دل کو بھیڑ کے جیسا کھول دیتا ہے۔",
      "d": "«رنج» کا اصل ریز ریکھا ہے جو کہ احساس کمزوری، پیچیدگی اور ناامیدی سے جڑا ہوا ہے۔ یہ الفاظ کہیں زیادہ احساسی اور انسانی خصوصیات کو ظاہر کرتے ہیں۔ اس کے مقابلے میں «غم» احساس کے حالت کا ذکر کرتا ہے جو کہ خاص طور پر انسانی ذہن کے ذریعے سے آتا ہے۔ «رنج» ایک خاص نوعیت کا احساس ہے جو کہ ہر وقت انسان کے دل میں موجود ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَاللَّذِينَ جَاءُوا مِن بَعْدِهِمْ لَيَكُونَنَّ فِي تَرَدُّدٍ مِنْهُمْ» (۳۹/۲۶)\nترجمہ : «اور جو لوگ بعد میں آئے گئے، وہ میں اس کے بارے میں تردید میں ہوں گے۔»"
    },
    {
      "id": 3281,
      "a": "غ",
      "h": "غم - افسوس",
      "hw": "غم",
      "s": "«افسوس» غم کے اظہار میں خاص طور پر ناکامی، نقصان اور دل کی دردناک حالت کو ظاہر کرتا ہے۔",
      "d": "«افسوس» اس کا معنی ہے ناکامی، نقصان، خرابی، اور انسان کے دل میں جو بڑھی ہوئی دل کی درد کو ظاہر کرتا ہے۔ یہ الفاظ ایک دوسرے سے مختلف ہیں کہ «غم» عام طور پر احساس کی حالت ہوتا ہے، جبکہ «افسوس» خاص طور پر ناکامی یا خرابی کی وجہ سے دل کی درد کو ظاہر کرتا ہے۔ اس کا ریٹ میں آغاز افسوس (أَفْسُوس) ہے جو ایک کلمہ ہے جو گہرا احساس کی حالت کو ظاہر کرتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«أَفْسُوسَ عَلَى الْقَوْمِ الْمُؤْمِنِينَ إِذَا مَرُّوا بِهِمْ وَلَمْ يَجِدُوا فِيهِمْ مِنْ أَهْلِهِمْ أَحَدًا» (الأنفال / ۲۷)\nترجمہ : \"ایسے لوگوں پر افسوس ہے جنہوں نے اپنے مominوں کو دیکھا، لیکن ان میں سے کوئی بھی اپنے خاندان کا عضو نہیں مل سکا۔\""
    }
  ],
  "712": [
    {
      "id": 3282,
      "a": "غ",
      "h": "غصہ - غصہ",
      "hw": "غصہ",
      "s": "«غصہ» اس کا معنی ہے جب کوئی شخص خود کو بڑا سمجھ کر دوسروں کو نظر انداز کرتا ہو، اور اپنے متعلقہ حقیقت کو بھی نظر انداز کرتا ہو۔",
      "d": "«غصہ» کا عربی روت ہے غ-ص-ہ، جو اصل میں ایک چھوٹی سی چیز کو بڑا کرنے کا معنی رکھتا ہے۔ اس کا لفظی معنی ہے 'بڑا کرنا' یا 'بڑا سمجھنا'۔ یہ کلمہ انسان کے ذہن میں موجود ایک بڑی سوچ کو ظاہر کرتا ہے جو اسے دوسروں کو نظر انداز کرنے اور خود کو بڑا سمجھنے کی طرف لے جاتی ہے۔ اس کا مترادف «تعصب» یا «غرور» ہے، لیکن «غصہ» کا خاص معنی ہے کہ انسان خود کو بڑا سمجھ کر دوسرے لوگوں کو نظر انداز کرتا ہے، اور اپنے حقیقت کو بھی نظر انداز کرتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلَقَدْ أَرْسَلْنَا مُوسَىٰ بِآيَاتِنَا وَسُلْطَانٍ مُّبِينٍ\nإِلَىٰ فِرْعَوْنَ وَمَلَأِهِۦ فَقَالُوآ إِنَّا نَحْنُ كَانَ الْمُؤْتَمِرُونَ\nقَالَ يَا فِرْعَوْنُ إِنِّي لَكَ الْمُنْذِرُ الْمُبِينُ\nلَقَدْ جَاءَكَ الْحَقُّ مِنْ رَّبِّكَ فَأَمَّا يَكُونَ لَكَ أَنْ تَكُونَ فِي الْمُحْتَشِمِينَ\nفَإِنَّهُ لَمَّا يَغْصُو فِي الْمُحْتَشِمِينَ\nوَإِنَّهُ لَمَّا يَغْصُو فِي الْمُحْتَشِمِينَ\nفَلَوْلَا أَنْ يَكُونَ فِي الْمُحْتَشِمِينَ» (طه 20:13-20)\nترجمہ : فرمایا گیا ہے کہ موسیٰ کو اپنی آیات اور واضح سلطنت کے ساتھ فرعون اور اس کے ملک کے سرداروں کو بھیجا گیا تھا۔ انہوں نے کہا کہ ہمیں یہ بات پتہ چلتی ہے کہ ہمیں ایسا کرنا ہے۔ فرمایا گیا کہ فرعون کو میرا ہدایت دینے والا اور واضح سلطنت والا ہوں۔ ہاں، تمہارے رب کی طرف سے حق کا اعلان ہوا ہے، لیکن اگر تم خود کو بڑا سمجھ کر دوسرے لوگوں کو نظر انداز کرتے ہو تو، یہ تو ایک گمراہی ہے۔ اسی طرح جب وہ غصہ کر کے دوسرے لوگوں کو نظر انداز کرتا ہے تو، اس کا نتیجہ ہوتا ہے کہ وہ اپنے حقیقت کو بھی نظر انداز کرتا ہے۔"
    },
    {
      "id": 3283,
      "a": "غ",
      "h": "غصہ - غضب",
      "hw": "غصہ",
      "s": "«غَضَبٌ» جب انسان غصہ سے بپھر کر انتقام پر اتر آئے خواہ چھوٹا ہو یا بڑا  اس کا تعلق اپنی ذات سے نہیں ہوتا بلکہ دوسرے کی ذات سے ہوتا ہے ۔",
      "d": "«غَضَبٌ»  صَاحِبِ فِقْہُ الْلُغَۃ کے نزدیک یہ لفظ عام ہے جو ہر طرح کے غصہ پر بولا جاتا ہے ۔ ( ف ل 169 ) لیکن یہ تعریف صحیح معلوم نہیں ہوتی ۔ رسول اکرم ﷺ نے جو غضب کی تعریف فرمائی وہ یوں ہے :\n«اِتَّقُوْا مِنْ الْغَضَبِ فَاِنَّہٗ جُمْرَۃٌ تُوْقَدُ فِیْ قَلْبِ ابْنِ اٰدَمَ اَلَمْ تَرَوْا اِلَی انْتِفَاخِ اَوْدَاجِہٖ وَجُمْرَۃِ عَیْنَیْہِ»\nترجمہ : غضب سے بچو کہ وہ آگ کی چنگاری ہے جو ابن آدم کے دل میں جلتی ہے ۔ تم دیکھتے نہیں کہ ایسے شخص کی رگیں پھول جاتی ہیں اور آنکھیں سرخ ہو جاتی ہیں ۔\nاور ظاہر ہے کہ یہ کیفیت اس وقت واقع ہوتی ہے جب انسان پر غصہ حاوی  ہوجائے اور وہ انتقام پر اتر آتا ہے ۔ اور اِبْنُ الْفَارِسْ نے اس کے معنیٰ «اَشَدّْ السَّخَط» بمعنی انتہائی ناراضگی کیا ہے  ( م ل ) ۔ اور صاحبِ مُنْجِد  نے «غَضِبَ» کے معنی بغض رکھنا ۔ غضبناک ہونا لکھا ہے (منجد) اور بمعنی «اِرَادَۃُ الضَّرْر لِلْمَغْضُوْبِ عَلَیْہِ ۔» اور «غَضْب» ہمیشہ دوسرے پر آتا ہے یعنی چھوٹے کا بڑے پر بھی ہو سکتا ہے اور بڑے کا چھوٹے پر بھی ( فق ل 106 )\nمثلاً : قرآن کریم میں ہے :\n«وَ مَنۡ یَّحۡلِلۡ عَلَیۡہِ غَضَبِیۡ فَقَدۡ ہَوٰی» ( 20/81 )\nترجمہ : اور جس شخص پر میرا غصہ نازل ہوا وہ ہلاک ہو گیا ۔"
    },
    {
      "id": 3284,
      "a": "غ",
      "h": "غصہ - قہر",
      "hw": "غصہ",
      "s": "«قہر» اس کا معنی ہے غصہ کا ایک خاص نکاتی اور بے رحمانہ جذبہ جو دل کو پھٹنے کی طرف لے جاتا ہے۔",
      "d": "«قہر» اس کا معنی ہے غصہ کا ایک خاص نکاتی اور بے رحمانہ جذبہ جو دل کو پھٹنے کی طرف لے جاتا ہے۔ یہ الفاظ کے ریڑ کے ساتھ ہوتا ہے، جو انسان کے دل کو پھٹنے اور دیگر کی طرف سے دوسروں کو کھولنا ہے۔ قہر اور غصہ دونوں میں فرق ہے، غصہ عام طور پر احساس کے ساتھ ہوتا ہے، جبکہ قہر ایک اضافی دباؤ اور ایک قسم کی بے رحمی کا اظہار ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَإِذْ أَخَذَ اللَّهُ مِيثَاقَ الَّذِينَ أَتَوْا مِن قَبْلِكَ لِيَقُولَنَّ الَّذِينَ أَحْسَنُوا وَالَّذِينَ قَدْ أَخْلَفُوا مِنْهُمْ أَنَّ اللَّهَ لَمْ يَكُنْ بِهِمْ عَلِيمًا» (الأنعام / 150)\nترجمہ : \"اور جب اللہ نے پہلے کے اقوام سے اپنے میثاق لیا تھا کہ وہ اپنے لوگوں کو بھی اپنی قوت اور مدد کی خاطر دیکھیں گے، تو اس کے بعد وہ لوگوں نے اسے کہا کہ اللہ نے ان کے بارے میں علم نہیں رکھا۔\""
    },
    {
      "id": 3285,
      "a": "غ",
      "h": "غصہ - طیش",
      "hw": "غصہ",
      "s": "«طیش» اس کا معنی ہے غصہ کا ایک خاص نکتہ جو بے قاعدگی، بے حوصلگی اور دل کی خرابی کو ظاہر کرتا ہے۔",
      "d": "«طیش» اردو زبان میں غصہ، پھنسن، اور بے قاعدگی کا معنی رکھتا ہے۔ اس کا عربی اصل طیش ہے جو اصل میں سوزی، دل کی خرابی اور احساس کی بے قاعدگی کو ظاہر کرتا ہے۔ اس کے مقابلے میں «غضب» عام طور پر احساس کی ایک تیز اور فوری بارش ہوتی ہے، جبکہ «طیش» احساس کی ایک مسلسل، غیر منتظم اور دل کی خرابی کی صورت میں ظاہر ہوتی ہے۔ «طیش» میں احساس کی مرضی، بے حوصلگی اور دل کی خرابی کا مطلب ہوتا ہے جو انسان کی احساسات کو بے قاعدہ اور غلط بنا دیتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَإِذَا مَسَّكَ اللَّهُ الْقَلْبَ فَلَا مُفَرِّضٍ لَّهُ وَإِذَا مَسَّكَ الْغَضَبَ فَلَا مُعَلِّقٍ لَّهُ» (الأنعام 6/103)\nترجمہ : «اور جب اللہ نے دل کو متاثر کیا تو اس کا کوئی بھی محفوظ نہیں رہتا اور جب غصہ نے اسے متاثر کیا تو اس کا کوئی بھی معلق نہیں رہتا۔»"
    }
  ],
  "713": [
