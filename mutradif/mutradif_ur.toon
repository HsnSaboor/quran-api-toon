  "739": [
    {
      "id": 3370,
      "a": "و",
      "h": "وضاحت - وضاحت",
      "hw": "وضاحت",
      "s": "«وضاحت» اس کا معنی ہے تفصیل اور واضح بیان کرنا جو خدا کے افعال اور خصوصیات کو واضح کرتا ہے۔",
      "d": "«وضاحت» کا عربی اصل (و-ض-ح) ہے جو کہ \"وضوح\" یا \"وضاحت\" کا مطلب دیتا ہے۔ یہ الفاظ ایک دوسرے سے متعلق ہیں، لیکن وضاحت مخصوص طور پر ایک چیز کو واضح کرنے کا کام کرتا ہے۔ اس کا مطلب ہے کہ کسی بات کو بہترین طریقے سے سمجھنے کا ذریعہ دینا۔ یہ الفاظ مختلف ہیں، جیسا کہ «توضیح» جو کہ مفہوم کو سمجھنے کے لیے استعمال کیا جاتا ہے، اور «وضوح» جو کہ وضاحت کا اصل مطلب ہوتا ہے۔ مثال کے طور پر: قرآن کریم میں ہے:\n\n«الَّذِي أَنزَلَ الْكِتَابَ بِالْحَقِّ وَقَدْ أَنزَلَهُ فَرَقًا مِّنْهُ وَقَدْ جَعَلَ لَهُ مِنْهُ قَدَرًا» (۳/۷)\nترجمہ: جو کتاب حقیقت سے نازل کرے، اور اس کا ایک حصہ نازل کرے، اور اس کے لیے اس کا ایک قدر مقرر کرے۔\n\nیہ آیت وضاحت کے معنی کو واضح کرتی ہے کہ اللہ تعالیٰ نے قرآن کو بہترین طریقے سے نازل کیا ہے، اور اس کے بعض حصوں کو بہترین طریقے سے واضح کیا گیا ہے۔"
    },
    {
      "id": 3371,
      "a": "و",
      "h": "وضاحت - تشریح",
      "hw": "وضاحت",
      "s": "«تشریح» وضاحت کا معنی ہے جو اصل مضمون کو واضح کرتا ہے اور اس کی تفصیل دیتا ہے۔",
      "d": "«تشریح» کا عربی اصل ہے تشریح کا جو ہے جو تفصیل سے واضح کرنا ہوتا ہے۔ اس کا ریٹھ ہے تشریح یعنی تفصیل سے واضح کرنا، جبکہ دوسرے لفظوں جیسے «شرح» یا «تبین» سے فرق یہ ہے کہ «تشریح» خاص طور پر تفصیلی توضیح کا الفاظ ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَإِذَا تُتْلَىٰ عَلَيْهِمُ الْآيَاتُ نَقُولُ لِلَّذِينَ أُوتُوا الْكِتَابَ مِن قَبْلِهِمْ مَّا هَٰذَا إِلَّا أَسَرَّ الْقُرْآنِ وَإِنَّهُ لَمِنْ تَشْرِيحٍ وَجْدِيٍ وَمَعْرِفَةٍ» (الأنعام / 95)\nترجمہ : «اور جب اس پر آیات پڑھی جاتی ہیں تو ہم اس سے پہلے کتاب حاصل کرنے والوں سے کہتے ہیں کہ یہ کیا ہے، بلکہ یہ فقط قرآن کی تشریح، اور یہ ایک مفید اور معرفت کی تشریح ہے۔»"
    },
    {
      "id": 3372,
      "a": "و",
      "h": "وضاحت - تفسیر",
      "hw": "وضاحت",
      "s": "«تفسیر» وضاحت کا مطلب ہے کہ کسی بات کو واضح طریقے سے بیان کرنا جو اصل معنی کو دکھائے۔",
      "d": "«تفسیر» اس کا معنی ہے کہ کسی بات کو واضح طریقے سے بیان کرنا، جو اصل معنی، اشارہ، اور تفصیل کو دکھائے۔ اس کے مترادف کلمات جیسا کہ «وضاحت»، «شرح»، «توضیح»، «شرح» اور «پیش کاری» ہیں لیکن «تفسیر» کا خاص نکتہ ہے کہ اس میں اصل معنی کو واضح کرنے کا سلسلہ شامل ہوتا ہے۔ «تفسیر» اصل مضمون کو پڑھنے والے کے لیے فائدہ حاصل کرنے کے لیے استعمال کیا جاتا ہے۔ مثلاً : قرآن کریم میں ہے:\n\n«أَلَمْ يَرَوْا كَمْ أَخْرَجْنَا مِنْهُمْ مِّنْ أَزْوَاجِهِمْ وَذُرِّيَّتِهِمْ وَمَا أَخْرَجْنَا لَهُمْ مِّنْ أَزْوَاجٍ وَذُرِّيَّةٍ مُّحَرَّبَةٍ» (الأنبياء 21:96)\nترجمہ : کیا وہ نہیں دیکھتے کہ ہم نے ان کی زوجیں اور ان کے پوتے-پوتیوں کو اس سے نکالا اور ان کے لیے نکالے گئے زوجیں اور پوتے-پوتیوں کو اس سے نکالا؟"
    }
  ],
  "740": [
    {
      "id": 3373,
      "a": "س",
      "h": "سچ - سچ",
      "hw": "سچ",
      "s": "«سچ» کا خاص معنی ہے واقعیت، حقیقت اور نامناسبی کے برعکس کچھ جو حتمی طور پر درست ہو۔",
      "d": "«سچ» کا عربی اصل (س-چ-ی) ہے جو اصل واقعیت، حقیقت اور صحت کو ظاہر کرتا ہے۔ یہ الفاظ کے ساتھ ممکنہ ہوتا ہے جو کہ \"سچائی\" یا \"صدق\" کا معنی دیتا ہے۔ یہ دوسرے سینیمیٹک الفاظ جیسے \"درست\" یا \"واقعی\" سے مختلف ہے کیونکہ یہ بطور معاشرتی اور فلسفی مفہوم کا استعمال ہوتا ہے جو اصل حقیقت کو دکھاتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«أَلَا لَكُمْ مِّنَ اللَّهِ نَبَأٌ مُّصَدِّقٌ لِّلَّذِينَ آمَنُوا بِاللَّهِ وَرَسُولِهِ» (النساء: ۱۳۶)\nترجمہ : «کیا تمہارے لئے اللہ کی طرف سے ایک پیغام ہے جو مؤمنوں کو ایمان لگانے کے لئے درست اور حقیقی ہے؟»"
    },
    {
      "id": 3374,
      "a": "س",
      "h": "سچ - صداقت",
      "hw": "سچ",
      "s": "«صداقت» اس کا معنی ہے واقعیت اور حقیقت کو پیش کرنے کی صلاحیت جو کہ انسان کی اخلاقی اور دینی ساخت کا ایک بنیادی حصہ ہے۔",
      "d": "«صداقت» کا عربی ریز کلمہ ص-د-ق ہے جو اصل میں \"واقعیت\" اور \"درستی\" کو ظاہر کرتا ہے۔ یہ لفظ انسان کی اصل واقعیت کو دکھاتا ہے، جو بے چینی، نافرجاری اور خرابی سے پاک ہوتی ہے۔ اس کے مقابلے میں \"سچ\" کا مطلب عام طور پر یہ ہے کہ کچھ درست ہو، لیکن \"صداقت\" کا مطلب یہ ہے کہ واقعیت اور حقیقت کو پیش کرنا، جو انسان کی اخلاقی ساخت کا ایک بنیادی حصہ ہے۔ یہ مطلب انسان کے دل کی صحت، انسانی اخلاق اور دینی ساخت کا اظہار ہے۔\n\nثبوت کے لئے:\n«وَاللَّذِينَ إِذَا أَنْفَقُوا لَمْ يُسْرِفُوا وَلَمْ يَكُونُوا الْمُسْتَغْنَوْنَ وَاللَّذِينَ هُمْ لِلْأَمْوَالِ حَافِظُونَ» (سورہ اَلْبَقَرَةٍ/ آیت ۲۶۷)\nترجمہ: «اور جن لوگوں نے جب مال خرج کیا تو وہ زیادہ خرچ نہ کیا اور نہ ہی ان کی اور محتاج ہو گئے۔ اور وہ لوگ جو مال کو محفوظ رکھتے ہیں۔»"
    },
    {
      "id": 3375,
      "a": "س",
      "h": "سچ - حقیقت",
      "hw": "سچ",
      "s": "«حقیقت» سچ کی اصل واقعیت اور درستی کو ظاہر کرتا ہے جو بندے کے دل اور زبان پر اثر انداز ہوتی ہے۔",
      "d": "«حقیقت» کا عربی ریذر ہے \"ح ق ت\" جو اصل واقعیت، درستی اور نیکی کو ظاہر کرتا ہے۔ یہ لفظ سچ کے مخصوص اور مکمل شکل کے طور پر استعمال ہوتا ہے جو کہ سادہ سچی کے علاوہ اصل واقعیت کو بھی شامل کرتا ہے۔ اس کے مترادفات میں \"صِدْق\" (صدق) اور \"سَحْب\" (سچ) بھی ہیں لیکن \"حقیقت\" کا معنی اصل واقعیت کو دکھانے والی سچی ہوتی ہے۔ مثلاً : قرآن کریم میں ہے:\n\n«وَالْحَقُّ مِن رَّبِّكَ فَلَا تَكُونَنَّ مِنَ الْمُمْتَرِينَ»\n(یٰسۡ ۱۸)\nترجمہ : «اور تیرے رب کی حقیقت کو ماننا ہے، تو تم مختلِفین میں سے نہ ہو۔»"
    }
  ],
  "741": [
