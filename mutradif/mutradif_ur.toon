      "h": "دشمن - مخالف",
      "hw": "دشمن",
      "s": "«مخالف» دشمن کے مفہوم میں ایسے شخص کو کہتے ہیں جو خدا کے حکم سے مخالف ہو اور اپنی خواہشات کے مطابق عمل کرتا ہو۔",
      "d": "«مخالف» اس کا معنی ہے ایسا شخص جو خدا کے حکم سے مخالف ہو، اپنی خواہشات اور نہایت سے خلاف عمل کرتا ہو، اور اپنی فطرت کے مطابق بے قربانی اور بے رحمی سے دوسروں کو نقصان پہنچاتا ہو۔ اس کے مترادف الفاظ میں 'عدو'، 'خصیم' اور 'شیطان' شامل ہیں لیکن «مخالف» میں خدا کے حکم سے مخالفت کا خاص معنی شامل ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلَمْ يَكُن لِّلْمُؤْمِنِينَ أَن يَخْرُجُوا كُلَّهُمْ وَلَكِن يَخْرُجُ مِن كُلِّ قَوْمٍ مِّنْهُمْ مُّسَارِيَةٌ لِّيَتَبَعُوا الْحَدِيثَ وَلَيْسَ بِهِمْ بَأْسٌ» (النساء: 79)\nترجمہ : \"مسلمانوں کو سب کو ایک ساتھ نہیں نکالنا چاہیے، بلکہ ہر قوم سے ایک یا دو افراد کو بھیجنے کی ضرورت ہے تاکہ وہ حکم اور آئینوں کو سمجھیں اور ان کے ساتھ مطابقت رکھیں۔\""
    },
    {
      "id": 3454,
      "a": "د",
      "h": "دشمن - عدو",
      "hw": "دشمن",
      "s": "«عَدُوّ» بمعنی  دشمن ۔",
      "d": "«عَدُوّ» اسکی جمع «اَعْدَاء» ہے ۔ ایسا دشمن جو بدخواہ  کینہ پرور ہو ۔ برائی اور نقصان کی بات سوچنے والا اور تکلیف پر خوش ہونے والا ۔ اور اس کی ضد «صِدِّیْق» ہے ( ف ۔ ل 168 )\nمثلاً : قرآن کریم میں ہے :\n«اِنَّ الشَّیۡطٰنَ لَکُمَا عَدُوٌّ مُّبِیۡنٌ» ( 7/22 )\nترجمہ : بیشک شیطان تم دونوں ( آدم و حوا ) کا کھلا دشمن ہے ! ۔\nاور «عَدَاوَۃٌ» بمعنی دشمنی اور بد خواہی ۔ اور یہ دشمنی کا پہلا درجہ ہے ۔ ( ف ۔ ل 169 ) اور بمعنی کسی کی مدد سے ہٹ جانا اسکی  ضد ولایت ہے ۔ ( فق ل 106 )"
    }
  ],
  "772": [
    {
      "id": 3455,
      "a": "ب",
      "h": "بادشاہ - بادشاہ",
      "hw": "بادشاہ",
      "s": "«بادشاہ» اس کا معنی ہے حکمران، ملکیت کا اعلیٰ مالک، جو اپنی ملکیت کے ذریعے اور قوت کے ساتھ سلطنت کا حکمران ہوتا ہے۔",
      "d": "«بادشاہ» کا عربی اصل (ب-د-ش-ا) ہے جو اصل میں \"بادشاہی\" کا عمل ہے جو ایک سلطنتی حکمران کو دکھاتا ہے۔ اس کا مطلب ہے کہ وہ جو شخص اپنی ملکیت کی حفاظت کرتا ہے اور اپنی قوت کے ذریعے سلطنت کا حکمران ہوتا ہے۔ اس کے مقابلے میں \"ملک\" اور \"سلطان\" کا مطلب بھی مشابہ ہوتا ہے لیکن «بادشاہ» کا مطلب سلطنت کا اعلیٰ حکمران ہوتا ہے جو اپنی قوت اور ملکیت کے ذریعے سلطنت کا حکمران ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَإِذْ قَالَ فِرْعَوْنُ لِمَنْ أَنْزَلَ الْكِتَابَ مِنْ بَعْدِهِ قَدْ جَاءَكُمْ رَسُولٌ مِّنْ لَدُنِّي بِالْحَقِّ فَأَكْفُوا بِهِ فَأَنْتُمْ لَمْ تَكُونُوا مُؤْمِنِينَ» (طه / 43)\nترجمہ : فرعون نے اس سے کہا کہ تمہارے بعد کتاب کو جو انزل کیا گیا ہے، وہ تمہارے پاس ایک راستہ آیا ہے جو مجھے سے حق کے ساتھ آیا ہے، لہذا اس کو روک دو، کیونکہ تم نے اس کو نہیں مانگا۔"
    },
    {
      "id": 3457,
      "a": "ب",
      "h": "بادشاہ - شاہ",
      "hw": "بادشاہ",
      "s": "«شاہ» بادشاہ کی حکمرانی اور عرشی سلطنت کے نمائندہ ہے جو خدا کی اذن پر قائم ہوتا ہے۔",
      "d": "«شاہ» اس کا معنی ہے جو سلطنت کے مالک ہوتا ہے، جو عرشی قوت اور حکمرانی کا نمائندہ ہوتا ہے، جو خدا کی اذن پر حکومت کرتا ہے۔ اس کی اصل ریذریت شاہ (شہ) سے ہے جو حکمرانی اور سلطنت کو دکھاتا ہے۔ یہ الفاظ کے مطابق دوسرے اصطلاحات جیسے «ملک» یا «سلطان» سے مختلف ہیں کیونکہ «شاہ» مخصوص طور پر خدا کی اذن پر حکومت کرنے والے حکمران کو دکھاتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«أَلَمْ يَرَوْا كَمْ أَخْرَجْنَا مِنَ الْأَرْضِ جُزْءًا مِّنْهَا وَأَنْبَتْنَاهُ فَأَخْرَجْنَاهُ كَمْ لَمْ يَكُونُوا مُنْبَتِيْهِ» (الأنعام/ ١٤)\nترجمہ : کیا وہ نہیں دیکھتے کہ ہم نے زمین سے ایک حصہ نکالا اور اسے پھولنا پڑا، اور جب ہم نے اسے پھولایا تو اسے پھولنے کے بعد چھوڑ دیا؟"
    }
  ],
  "773": [
    {
      "id": 3459,
      "a": "و",
      "h": "وزیر - مشیر",
      "hw": "وزیر",
      "s": "«مشیر» کا معنی وزیر کے علاوہ ایک ایسا شخص جو سلطان یا حکمران کے پاس خبریں لے کر آتا ہو اور اس کے ساتھ ساتھ سرکاری کاموں میں مدد کرتا ہو۔",
      "d": "«مشیر» کا عربی اصل (Root) مشیر ہے جو اصل میں چیز کو سمجھنے والی چیز یا ایسی چیز جو سمجھوتہ کر دی جائے۔ اس کے علاوہ وزیر کا معنی بھی ہوتا ہے، جو سلطان یا حکمران کے پاس کام کرنے والا شخص ہوتا ہے۔ یہ الفاظ مختلف اصطلاحیں ہیں، مثلاً \"وزیر\" سلطنتی حکومت کے ایک اہم افسر کے طور پر استعمال ہوتا ہے، جبکہ \"مشیر\" کا مطلب ہے کہ ایک شخص جو خبریں لے کر آتا ہو، یا ایسی چیز جو کسی کو سمجھا دے۔ قرآن کریم میں ہے:\n«وَلَقَدْ أَرْسَلْنَا مُوسَىٰ إِلَىٰ فِرْعَوْنَ بِسُلْطَانٍ فَلَمَّا جَاءَهُۥ سُلْطَانُهُۥ قَالَ لَهُۥ مُوسَىٰٓ إِنِّي عَبْدُ اللَّهِ الَّذِي آتَىٰ بِالْحَقِّ وَأَنَا مِنَ الْمُرْسَلِينَ» (طه/23)\nترجمہ : موسیٰ کو فرعون کے پاس سلطنت کے ساتھ بھیجا گیا تھا، اور جب وہ سلطان کو دیکھا تو نے فرمایا کہ میں اللہ کا بندہ ہوں جو حق کے ساتھ آیا ہے اور میں مرسالین میں سے ہوں۔"
    }
  ],
  "774": [
    {
      "id": 3460,
      "a": "ا",
      "h": "استاد - استاد",
      "hw": "استاد",
      "s": "«استاد» اس کا معنی ہے جو علم و دین کی تعلیم دیتا ہو، اور اس کا اصل مطلب عالم و مدرس ہوتا ہے۔",
      "d": "«استاد» کا عربی اصل ریزی کے ساتھ ہے جو متعلقہ علم کا مالک ہوتا ہے، اور اس کا معنی ہے علم و دین کا معلم یا مدرس۔ یہ الفاظ میں سے ایک خاص طور پر دینی تعلیم کے لیے استعمال ہوتا ہے، جبکہ دوسرے الفاظ جیسے «معلم» یا «پڑھاوا» عام طور پر تعلیمی معاونت کے لیے استعمال ہوتے ہیں۔ اس کا خاص نشانہ دینی علوم، نبوت، اور اخلاقی تعلیم ہوتا ہے۔ مثال کے طور پر:\n\n«استاد» اس کا معنی ہے جو علم و دین کی تعلیم دیتا ہو، اور اس کا اصل مطلب عالم و مدرس ہوتا ہے۔\n\nمثلاً : قرآن کریم میں ہے:\n«وَلَقَدْ أَرْسَلْنَا مِن قَبْلِكَ فِي أُمَمٍ مِّن قَبْلِكَ نَبِيَّينَا وَأَرْسَلْنَاهُم بِالْبَيِّنَاتِ وَأَنْزَلْنَا مَعَهُمُ الْكِتَابَ وَزَنَّا فِيهِ الْمِيزَانَ» (الحديد / 25)\nترجمہ : «ہم نے پہلے تم سے بھی امتیں بھیجیں گے جن کے سامنے ہم نے نبیوں کو بھیجا، اور انہیں بیانات کے ساتھ اور ان کے ساتھ کتاب بھی بھیجا، اور ان کے ساتھ وزن بھی انداز کیا۔»"
    },
    {
      "id": 3461,
      "a": "ا",
      "h": "استاد - معلم",
      "hw": "استاد",
      "s": "«معلم» اس کا معنی ہے جو علم و دانش کا پرواز کرتا ہو، اور اپنے طالب علموں کو سکھاتا ہو۔",
      "d": "«معلم» کا عربی اصل مفرد حرف «مَعْلَم» سے ہے جو «مَعْلَمَة» کے ذریعے علم و دانش کی آواز کو بیان کرتا ہے۔ اس کا لفظی معنی ہے \"جو دانش کا نمائندہ ہو\" یا \"جو علم کا پرواز کرتا ہو\"۔ اس کا مطلب عام طور پر انسان ہوتا ہے جو دانش اور علم کا نمائندہ ہو، جو دوسروں کو سکھاتا ہو۔ اس کے مقابلے میں \"استاد\" اور \"مدرس\" کا مطلب بھی مشابہ ہوتا ہے، لیکن \"معلم\" کا مطلب خاص طور پر دانش کا نمائندہ ہونا ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَإِذْ قَالَ مُوسَىٰ لِقَوْمِهِ يَا قَوْمِ إِنَّكُمْ أَظْلَمُ مِنَ الْأَرْضِ فَاسْتَغْفِرُوا رَبَّكُمْ ثُمَّ تُوبُوا إِلَيْهِ فَإِنَّ رَبَّكُمْ رَحِيمٌ رَّحِيمٌ» (۷ / ۵۴)\nترجمہ : \"اور جب موسیٰ نے اپنے قوم کو کہا کہ، \"ای قوم! تم نے زمین کی طرح ظلم کیا ہے، تو اپنے رب کی مغفرت مانگو، پھر اس کی طرف توبہ کرو، کیونکہ تمہارا رب مہربان اور دانش مند ہے۔\""
    },
    {
      "id": 3462,
      "a": "ا",
      "h": "استاد - مدرس",
      "hw": "استاد",
      "s": "«مدرس» اس کا معنی ہے پڑھائی کرنے والے، حکمت کا پرورش دینے والے اور علم کو سمجھانے والے استاد کا نام ہے جو قرآن میں اپنی حکمت اور علم کے ذریعے مسلمانوں کو رہنمائی دیتا ہے۔",
      "d": "«مدرس» اس کا معنی ہے پڑھائی کرنے والے، حکمت کا پرورش دینے والے اور علم کو سمجھانے والے استاد کا نام ہے۔ اس کا اردو میں معنی استاد، معلم، اور حکمت کا پرورش دینے والے ہوتا ہے۔ اس کی آرบی زبان میں اصل رٹ ہے مدرس (د-ر-س) جو اردو میں پڑھنا، سمجھانا، اور حکمت دینا کا عمل ہوتا ہے۔ اس کا مطلب ہے علم کا پرورش دینا، اور علم کو پڑھانا۔ یہ الفاظ مختلف اصطلاحات ہیں، لیکن مدرس کا مطلب عام طور پر علم کا پرورش دینا ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَإِذْ أَرْسَلْنَا مِنْهُمْ رَسُولًا مِّنْهُمْ يَتْلُو عَلَيْهِمْ آيَاتِنَا وَيُزَكِّيهِمْ وَيُعَلِّمُهُمُ الْكِتَابَ وَالحِكْمَةَ» (۲/۱۲۹)\nترجمہ : «اور جب ہم نے ان میں سے ایک ایسے رسول کو بھیجا کہ وہ ان پر اپنی آیات پڑھے، ان کو پاک کرے، اور انہیں کتاب اور حکمت سکھائے۔»"
    }
  ],
