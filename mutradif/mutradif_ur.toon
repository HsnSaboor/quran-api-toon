      "s": "«مشورہ» اس کا معنی ہے سیاست و حکمت کے ساتھ مشورہ کرنا جو انسان کی حکمت اور تعلیم کی ضرورت پر مبنی ہوتی ہے۔",
      "d": "«مشورہ» کا عربی اصل (م-ش-و-ر) ہے جو ایک مخصوص کلمہ ہے جو حکمت، مشورہ اور انسانی تعلیم کے متعلق ہے۔ اس کا معنی ہے سیاست و حکمت کے ساتھ مشورہ کرنا، جو انسان کی حکمت اور تعلیم کی ضرورت پر مبنی ہوتی ہے۔ اس کے مقابلے میں دوسرے مترادف کلمات جیسے 'مکالمہ' یا 'تشریح' کا مطلب مختلف ہوتا ہے، جو صرف بات چیت یا تشریح کا مطلب رکھتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلَا تُكَلِّمُوا الَّذِينَ يَدْعُونَ رَبَّهُم بِالْغَدَاةِ وَعَشِيًا يُرِیدُونَ وَجْهَ رَبِّهِمْ» (۳۰ / ۴۳)\nترجمہ : جو لوگ اپنے رب کو صبح اور شام کے وقت دعا کرتے ہیں، اور ان کا مقصد ہے کہ ان کے رب کا وجوہ دیکھیں۔"
    },
    {
      "id": 3362,
      "a": "م",
      "h": "مشورہ - رائے",
      "hw": "مشورہ",
      "s": "«رائے» کا معنی ہے مصیبہ، خیال، اور مشورہ کا اصل معنی ایک متعلقہ مسئلہ پر متعلقہ شخص کی فکر اور نظریات کو سمجھنا۔",
      "d": "«رائے» کا عربی اصل رائے (رَآيَة) ہے جو اصل میں «دیکھنا» اور «فکر کرنا» سے متعلق ہے۔ اس کا مطلب ہے کہ کسی مسئلے پر ایک شخص کی نظریات، خیالات، اور معلومات کو سمجھنا۔ اس کا مترادف «مشورہ» ہے لیکن «رائے» کا خاص معنی ہے کہ متعلقہ شخص کے اپنے دیکھنا، سمجھنا، اور فکر کرنا کا احساس۔ «مشورہ» کے مقابلے میں «رائے» مخصوص طور پر ایک شخص کی خصوصی خیالات کو دکھاتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلَمْ يَكُن لَّهُمْ مِّن بَعْدِ ذٰلِكَ مَوْلَىٰ وَلَا مَنْصُورٌ» (النساء: ۱۲۵)\nترجمہ : اس کے بعد ان کے لئے کوئی مددگار یا مدد کرنے والا نہیں رہا۔"
    },
    {
      "id": 3363,
      "a": "م",
      "h": "مشورہ - صلاح",
      "hw": "مشورہ",
      "s": "«صلاح» کا معنی ہے سچائی، عدالت، اور انصاف کے ساتھ مشورہ کرنا جو متعلقہ مسائل کو حل کرنے کے لیے ضروری ہوتا ہے۔",
      "d": "«صلاح» کا اصل مطلب ہے سچائی، عدالت، اور انصاف۔ یہ الفاظ انسان کے دل میں پیدا ہونے والی سچائی اور عدالت کی خصوصیت ہیں جو انسان کو سمجھنے اور صحیح فیصلے کرنے کے لیے اہم ہوتی ہیں۔ اس کے مقابلے میں «مشاورہ» صرف باتیں کرنا ہے، جبکہ «صلاح» میں انسان کی عدالت اور سچائی کی خصوصیت بھی شامل ہوتی ہے۔ یہ کلمہ انسان کی عدالت اور سچائی کے ساتھ سامان ہے جو مشاورہ کے عمل میں بھی دکھائی دیتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلِلَّذِينَ اتَّخَذُوا دِينَهُمْ مَّلْهَىً وَلِلَّذِينَ اتَّخَذُوا دِينَهُمْ مَّلْهَىً وَالْمُسْتَقِيمِينَ الْمَلْهَىٰ فِي الدِّينِ وَالْمَلْهَىٰ فِي الدِّينِ» (ال عمران/ آیت 103)\nترجمہ : جو لوگ اپنے دین کو ملہی کے طور پر اختیار کرتے ہیں، اور جو لوگ اپنے دین کو ملہی کے طور پر اختیار کرتے ہیں، اور جو لوگ مستقیم راستے پر ہیں، وہ اپنے دین کے ملہی کے ساتھ سامان ہیں۔"
    }
  ],
  "737": [
    {
      "id": 3364,
      "a": "س",
      "h": "سوال - سوال",
      "hw": "سوال",
      "s": "«سوال» اس کا معنی ہے جو کچھ اصلی اور حقیقی طور پر پوچھا جاتا ہے، جو معلومات یا حکمت کی طرف اشارہ کرتا ہے۔",
      "d": "«سوال» کا عربی ریٹ کلمہ سوال ہے جو اصل میں کچھ کو بڑھا کر پوچھنا، یعنی اصلی اور واضح طور پر پوچھنا، سمجھنے کیلئے سوال کرنا ہے۔ اس کا مطلب ایسا سوال ہوتا ہے جو کچھ سمجھنے کیلئے اور اس کے متعلق وضاحت کیلئے پوچھا جاتا ہے۔ یہ الفاظ سے مختلف ہے جو صرف سوال کرنے کا مطلب ہوتا ہے بلکہ اس میں حقیقت کو سمجھنے کا اثر بھی ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«أَلَا إِلَهُ إِلَّا هُوَ لَهُ الْأَسْمَاء الْحُسْنَىٰ وَلَهُ الْمُلْكُ وَلَهُ الْحَمْدُ فِي الْآخِرَةِ وَالْأُولَىٰ وَلَهُ الْمُلْكُ وَلَهُ الْحَمْدُ فِي الْآخِرَةِ وَالْأُولَىٰ» (الاعراف / ۱۷۶)\nترجمہ : \"کیا ہم کسی دوسرے خدا کو نہیں سمجھتے؟ وہی اللہ ہے جس کے پاس تمام نام خوبصورت ہیں، اور اس کے پاس ملکت ہے، اور اس کا حمد ابتدائی اور آخری دور میں ہے، اور اس کے پاس ملکت ہے، اور اس کا حمد ابتدائی اور آخری دور میں ہے۔\""
    },
    {
      "id": 3365,
      "a": "س",
      "h": "سوال - پرسش",
      "hw": "سوال",
      "s": "«پرسش» سوال کی ایک خاص قسم ہے جو بہترین طریقے سے دیکھا جا سکتا ہے جب کسی شخص کو اپنے سوال کے جواب کے لیے حوصلہ افزائی کی جاتی ہے۔",
      "d": "«پرسش» اس کا معنی ہے کہ کسی شخص کے ذہن میں ایک خاص سوال پیدا ہوتا ہے جو اسے جاننے کی ضرورت ہوتی ہے، اور اس سوال کو بہترین طریقے سے حل کرنے کے لیے حوصلہ افزائی کی جاتی ہے۔ یہ الفاظ کئی اور سوالوں کے معنی سے مختلف ہیں جیسا کہ \"سوال\" عام طور پر کسی کو پوچھنا، \"استفسار\" ایک باریک سوال، اور \"تحلیل\" ایک تفصیلی تحقیق۔ یہ الفاظ سب کچھ ایک ہی معنی کا نمائندہ نہیں کرتے۔ مثلاً : قرآن کریم میں ہے:\n«أَفَغَیْرَ اللَّهِ أَرْبَابٌ سَمِعْتُمْ» (الأنعام / 45)\nترجمہ : کیا تم نے کسی اور کو سنا ہے جو اللہ کے علاوہ ایسے رہبر ہوں جو آواز سنیں؟"
    },
    {
      "id": 3366,
      "a": "س",
      "h": "سوال - استفسار",
      "hw": "سوال",
      "s": "«استفسار» سوال کا ایک خاص شکل ہے جو اصل مسئلہ کو واضح کرنے کے لیے کیا جاتا ہے۔",
      "d": "«استفسار» اردو میں سوال کا ایک خاص شکل ہے جو اصل مسئلہ کو واضح کرنے، معلومات حاصل کرنے اور ایک مسئلے کے بارے میں وضاحت حاصل کرنے کے لیے استعمال ہوتا ہے۔ اس کا عربی ریٹ کلمہ استفسار ہے جو اردو میں سوال کا مطلب دیتا ہے۔ اس کی گہرائی اس بات پر ہے کہ یہ سوال ایک مسئلہ کو واضح کرنے کے لیے کیا جاتا ہے، اور اس کا مقصد معلوم کرنا ہوتا ہے کہ کیا ہم نے صحیح فہم کیا ہے۔ \n\nمثلاً : قرآن کریم میں ہے:\n«أَفَأَنْتُمْ أَعْجَبُ مِنْ أَنْ يَكُونَ لَكُمْ سُؤَالٌ فِي الْقُرْآنِ وَلَوْ كُنْتُمْ لَمْ تَكُونُوا مُؤْمِنِينَ»\n(۳۹/۴۲)\nترجمہ : کیا آپ لوگ اس بات سے زیادہ تعجب کرتے ہیں کہ قرآن میں سوال کیا جا رہا ہے اور اگر آپ مُؤْمِن نہ ہوتے تو اس کے سبب بھی سوال کیا جاتا؟"
    }
  ],
