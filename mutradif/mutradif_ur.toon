      "hw": "مرد",
      "s": "«آدمی» اس کا معنی ہے مردوں کا اصل سرچارہ جو خداوند کے بندے ہوتے ہیں اور ان کی خاصیت اس وقت ظاہر ہوتی ہے جب وہ خدا کے حکم پر زندگی سرکار کرتے ہیں۔",
      "d": "«آدمی» اس کا معنی ہے مردوں کا اصل سرچارہ جو خداوند کے بندے ہوتے ہیں اور ان کی خاصیت اس وقت ظاہر ہوتی ہے جب وہ خدا کے حکم پر زندگی سرکار کرتے ہیں۔ اس کی ریذریت اصل میں آدم (Adam) سے ہے جو خداوند کے نام سے پیدا کیا گیا تھا، اور اس کے مقابلے میں «مرد» عام طور پر جسمانی مین کے علاوہ انسانی اخلاقی اور دینی خصوصیات کو بھی شامل کرتا ہے۔ «آدمی» کا مطلب ہے کہ انسانی صفت کا اصل سرچارہ ہے جو خداوند کی خلق کی ہوئی ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلَقَدْ خَلَقْنَا الْإِنسَانَ مِن نُّطْفَةٍ أَمْشَاجٍ نَّبْتَلِيَهِ فَجَعَلْنَاهُ سَمِيعًا بَصِيرًا»\n(سورۃ الحجرات / ۲۷)\nترجمہ : ہم نے انسان کو بڑی نطفہ سے پیدا کیا تھا، جس کو ہم آزمائیں گے، اور ہم نے اسے سنا نے والے اور دیکھنے والے بنایا۔"
    },
    {
      "id": 3488,
      "a": "م",
      "h": "مرد - مرد",
      "hw": "مرد",
      "s": "«رَجُلٌ» اسکا استعمال اس وقت ہوتا ہے جب بہادری اور قوت مردی کا اظہار مقصود ہو ۔",
      "d": "«رَجُلٌ» ( بمعنی مرد ) کا استعمال اس وقت ہوتا ہے جب قوت ، بہادری اور مردانگی کا اظہار مقصود ہو ۔ «رَجُوْلِیَّۃ» مصدر بمعنی قوت مردانگی ۔ قوت مردی ( منجد ) جمع اسکی «رِجَالٌ» ہے ۔ اور اسکا مؤنث «نِسَاء» اور «نِسْوَۃ» ہے ۔\nمثلاً : قرآن کریم میں ہے :\n«اَلرِّجَالُ قَوّٰمُوۡنَ عَلَی النِّسَآءِ بِمَا فَضَّلَ اللّٰہُ بَعۡضَہُمۡ عَلٰی بَعۡضٍ» ( 4/34 )\nترجمہ : مرد وعورتوں کے نگراں ہیں ، کیونکہ اللہ نے ان میں سے ایک کو دوسرے پر فضیلت دی ہے ۔"
    }
  ],
  "785": [
    {
      "id": 3489,
      "a": "غ",
      "h": "غریب - غریب",
      "hw": "غریب",
      "s": "«غریب» اس کا معنی ہے جو بےگناہ، بے پرواہ اور بے دفاع ہو، جیسا کہ محتاج واقعات سے نکل نہ سکے۔",
      "d": "«غریب» کا عربی اصل ہے غ-ر-ب جو اصل میں 'بے پرواہ' یا 'بے دفاع' کا معنی رکھتا ہے۔ اس کا لغتی معنی ہے جو کسی بھی اپنے سے بڑے مسائل سے نکل نہ سکے، بے دفاع، بے خبر، اور بے ساری۔ اس کے مقابلے میں «مسکین» اور «فقری» کا معنی بھی مشابہ ہوتا ہے لیکن «غریب» میں ایک خاص طرح کی بے پرواہی اور ناکامی کا اظہار ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَالْغَرِيبِ فَیْهِ لَمْ یَكُنْ لَهُ نَقِیّ» (سورۃ الطلاق، آیت ۴)\nترجمہ : «اور غریب کے متعلق جو کچھ ہے، اس کے لئے اس کے پاس کوئی نقی نہیں ہے۔»"
    },
    {
      "id": 3490,
      "a": "غ",
      "h": "غریب - محتاج",
      "hw": "غریب",
      "s": "«محتاج» غریب کے معنی میں ایک اور بھی بڑا مطلب دیتا ہے جو مدد کی ضرورت مندی کو ظاہر کرتا ہے۔",
      "d": "«محتاج» اس کا معنی ہے ایسا شخص جو کچھ چاہتا ہے اور اس کی ضرورت ہوتی ہے، جو مدد یا سہولت کی طرف سے متعلق ہو۔ اس کی اصل ریڈیکل ریٹرین ہے اور وہ انسان ہے جو اپنی اہمیت کی طرف اشارہ کرتا ہے۔ اس کا معنی ایسے شخص کو دکھاتا ہے جو کچھ حاصل کرنے کی ضرورت رکھتا ہے۔ اس سے «غریب» کا معنی مختلف ہوتا ہے، جو صرف فقیری کا مطلب نہیں رکھتا بلکہ اس کی مدد کی ضرورت کا مطلب بھی ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَالَّذِينَ إِن مَّآ أَنفَقُوآ لَمْ يَكُونُوا مُهَادِينَ وَلَمْ يَكُونُوا مُحْتَاجِينَ إِلَى الْعَمَلِ فَإِنَّ اللَّهَ لَا يُضِلُّ مَنْ هُوَ مُهَادٍ وَلَا مُحْتَاجٍ إِلَى الْعَمَلِ» (البقرة/179)\nترجمہ : اور جو لوگ اپنی دینی نیکی کے ساتھ نہ صرف مدد کی ضرورت نہیں رکھتے، بلکہ اپنی عمل کی ضرورت نہیں رکھتے، تو اللہ وہ لوگوں کو نہ بھولتا ہے جو مدد کی ضرورت رکھتے ہیں اور نہ اپنے عمل کی ضرورت رکھتے ہیں۔"
    },
    {
      "id": 3491,
      "a": "غ",
      "h": "غریب - مفلس",
      "hw": "غریب",
      "s": "«مفلس» کا معنی ہے غریب اور فقیر جو مال و مظالم سے محروم ہو، اور اپنے مال کی کمی کا شکار ہو۔",
      "d": "«مفلس» کا عربی اصل ہے مفلس، جو مال و مظالم سے محروم اور فقیر کا نام ہے۔ یہ الفاظ ایک دوسرے سے مختلف ہیں: «فقیر» عام طور پر فقیر کا نام ہے، جبکہ «مفلس» خاص طور پر مال و مظالم سے محروم اور کمی کا شکار ہونے والے کا نام ہے۔ «غریب» بھی اسی معنی کا نام ہے لیکن «مفلس» میں مالی کمی اور محرومی کا زیادہ تعلق ہوتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلَمْ يَكُن لَّهُمْ مَّالٌ وَلَا بَنُونَ» (البقرة ۲۸۳)\nترجمہ : «اور ان کے پاس کوئی مال نہ تھا اور نہ ہی بچے تھے۔»"
    }
  ],
  "786": [
    {
      "id": 3492,
      "a": "ا",
      "h": "امیر - امیر",
      "hw": "امیر",
      "s": "«امیر» اس کا معنی ہے قومی یا عوام کے سربراہ کو کہنا جاتا ہے جو دوسروں پر حکمرانی کرتا ہے۔",
      "d": "«امیر» کا عربی اصل امیر (أَمِير) ہے جو کہ اصل میں \"ایک شخص جو کسی چیز کو بڑھاتا ہے\" یا \"بڑا ہونا\" کا معنی رکھتا ہے۔ اس کا لفظی مطلب ہے \"کسی چیز کو بڑھانا\" یا \"کسی چیز کا سربراہ ہونا\"۔ اس کے مقابلے میں «خادم» سرکاری یا اداری خدمات کے سربراہ ہوتا ہے، اور «ملک» ملک کا مالک ہوتا ہے۔ اس لحاظ سے «امیر» اصل میں قومی یا عوام کے سربراہ کو کہتا ہے جو دوسروں پر حکمرانی کرتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَلَمْ يَكُن لِّلْمُؤْمِنِينَ أَن يَّتَّخِذُوا ءَابَاءهُمْ وَأَخْوَاهُمْ أَوْلِيَاءَ فِي الْمَلَكِ» (التوبة / 107)\nترجمہ : \"مؤمنین کو اپنے باپوں اور بھائیوں کو ملک میں وصیت کے لئے نہ لینا چاہئے۔\""
    },
    {
      "id": 3493,
      "a": "ا",
      "h": "امیر - دولت مند",
      "hw": "امیر",
      "s": "«دولت مند» امیر کے معاون و مددگار کے طور پر استعمال ہوتا ہے جو دوستوں کی خدمت میں ہوتا ہے۔",
      "d": "«دولت مند» کا اصل لغتی ریٹ کلمہ 'دولت' سے ہے جو مال، قوت، اور انتظام کا مطلب رکھتا ہے۔ اس کا مترادف 'مُلْک' یا 'حکمران' ہوتا ہے لیکن 'دولت مند' کا خاص نشانہ ہے کہ وہ اپنی دوستوں کے لیے دوستی اور خدمت کرتا ہے۔ اس کا مطلب ہے کہ وہ دوستوں کی خدمت میں اور دوستی کے حوالے سے انتظام کرتا ہے۔ مثلاً : قرآن کریم میں ہے:\n«وَإِذْ قَالَ لَهُمْ عَبْدُ اللَّهِ بْنُ أَبِي وَهْبٍ لِّقَوْمِهِمْ أَنْ تَعَظُّوا فَأَخَذَتْهُمُ الْعَذَابُ مِنْ غَدٍ إِلَى الْمَسَاءِ وَهُوَ دُولَتٌ مَّنْدٌ فِي أَهْلِهِمْ» (سورة النمل، آیت 46)\nترجمہ : «جب عبید اللہ بن ابی وہب نے اپنے قوم کو تعلیم دینے کی دعوت دی تو ان کے متعلق اذیت اگلی رات سے دن تک آئی۔ اور وہ اپنے لوگوں میں دوستی کا انتظام کرنے والا تھا۔»"
    },
    {
      "id": 3494,
      "a": "ا",
      "h": "امیر - ثروتمند",
      "hw": "امیر",
      "s": "«ثروتمند» امیر کی خصوصیت کو ظاہر کرتا ہے کہ وہ مال و عطیات سے پرے ہو کر دینی اور سماجی ذمہ داریوں کا بھی انتظام کرتا ہے۔",
      "d": "«ثروتمند» کا اردو میں معنی ہے: امیر، بڑا مالک، سرمایہ کار، دینی اور معاشی طور پر اعلی منزل پر آئے ہوئے شخص۔ اس کا عربی ریذر ہے ث-ر-و-ت میند جس کا حرفی معنی ہے: ثروت سے میند (ممتاز)، جو بہت ساری ثروت رکھتا ہے۔ اس کے مقابلے میں «ملک» سے متعلق ہوتا ہے جو ایک دیگر مخصوص معاونی کا حامل ہوتا ہے، اور «خادم» سے متعلق ہوتا ہے جو کسی کے پاس کام کرنے والے شخص کو بتاتا ہے۔ اس کے علاوہ «خالق» سے متعلق ہوتا ہے جو پیدا کرنے والے کی حالت کو ظاہر کرتا ہے۔ مثلاً : قرآن کریم میں ہے:\n\n«وَإِذْ أَخَذَ اللَّهُ مِيثَاقَ الَّذِينَ أَتَوْا مِن بَعْدِهِمْ لَكَيْنَ مَلَكَتْ أَنفُسَهُمْ فَأَنْتُمْ لَمْ تَكُونُوا بِمَوْلَاكُمْ شَرِيكِينَ» (3/186)\nترجمہ : «اور جب اللہ نے بعد میں جو لوگ آئے ان کے ساتھ اپنا میثاق قبول کیا کہ وہ اپنی اپنی آنسوں کو مالک بنائیں گے، تو تم نے اپنے مالک کے ساتھ شراکت نہیں رکھی۔»"
    }
  ],
