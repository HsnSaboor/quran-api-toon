      "s": "«تَزَیَّل» الگ ہونا ( جُدا ہونا ۔ علیحدہ ہونا ) (1 آیات: 48:25)",
      "d": "«تَزَیَّل» means to become separate or distinct, to part ways."
    },
    {
      "id": 3642,
      "hw": "hope",
      "s": "«رجا» اُمید لگانا (23 آیات: 2:218-4:104-9:106-10:7-10:11-10:15-11:62-17:28-17:57-18:110-24:60-25:21-25:40-28:86-29:5-29:36-33:21-35:29-39:9-45:14-60:6-71:13-78:27)",
      "d": "«رجا» means to hope or to have expectation, to anticipate something positively."
    },
    {
      "id": 3643,
      "hw": "wait",
      "s": "«اِنْتَظَرَ» انتظار کرنا (7 آیات: 6:158-7:71-10:20-10:102-11:122-32:30-33:23)",
      "d": "«اِنْتَظَرَ» means to wait or to anticipate, to remain in expectation of something."
    },
    {
      "id": 3644,
      "hw": "wait",
      "s": "«اِرْتَقَبَ» انتظار کرنا (9 آیات: 4:1-5:117-11:93-28:18-28:21-44:10-44:59-50:18-54:27)",
      "d": "«اِرْتَقَبَ» means to watch or to wait for, to be on the lookout for something."
    },
    {
      "id": 3645,
      "hw": "fulfillment",
      "s": "«منتھیٰ» انجام ( کار ) (20 آیات: 2:192-2:193-2:275-4:171-5:73-5:91-8:19-8:38-8:39-9:12-19:46-26:116-26:167-33:60-36:18-53:14-53:42-59:7-79:44-96:15)",
      "d": "«منتھیٰ» refers to the end or conclusion of something, the final outcome or result."
    },
    {
      "id": 3646,
      "hw": "inside",
      "s": "«خلال» اندر (8 آیات: 9:47-14:31-17:5-17:91-18:33-24:43-27:61-30:48)",
      "d": "«خلال» means inside or within, referring to the interior or inner part of something."
    },
    {
      "id": 3647,
      "hw": "inside",
      "s": "«باطن» اندر (9 آیات: 3:35-6:120-6:151-7:33-24:45-31:20-37:144-57:3-57:13)",
      "d": "«باطن» means the inner or hidden aspect, the internal or concealed part of something."
    },
    {
      "id": 3648,
      "hw": "blind",
      "s": "«عَمِہَ» اندھا (7 آیات: 2:15-6:110-7:186-10:11-15:72-23:75-27:4)",
      "d": "«عَمِہَ» means blind, lacking the sense of sight or metaphorically unaware."
    },
    {
      "id": 3649,
      "hw": "justice",
      "s": "«عدل» انصاف (24 آیات: 2:48-2:123-2:282-4:3-4:58-4:129-4:135-5:8-5:95-5:106-6:1-6:70-6:115-6:150-6:152-7:159-7:181-16:76-16:90-27:60-42:15-49:9-65:2-82:7)",
      "d": "«عدل» means justice or fairness, the principle of moral rightness and equity."
