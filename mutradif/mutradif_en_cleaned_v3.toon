  "125": [
    {
      "id": 597,
      "a": "ب",
      "h": "To send",
      "hw": "بھیجنا",
      "s": "« » means to send someone with a message, letter, or command (131 verses: 2:119, 2:151, 4:64, 4:79, 4:80, 5:70, 6:6, 6:42, 6:48, 6:61, 7:6, 7:57, 7:59, 7:75, 7:87, 7:94, 7:105, 7:111, 7:133, 7:134, 7:162, 9:33, 11:25, 11:52, 11:57, 11:70, 11:96, 12:12, 12:19, 12:31, 12:45, 12:63, 12:66, 12:109, 13:13, 13:30, 13:38, 14:4, 14:5, 14:9, 15:10, 15:22, 15:58, 16:43, 16:63, 17:54, 17:59, 17:68, 17:69, 17:77, 17:105, 18:40, 18:56, 19:17, 19:83, 20:47, 20:134, 21:5, 21:7, 21:25, 21:107, 22:52, 23:23, 23:32, 23:44, 23:45, 25:20, 25:48, 25:56, 26:13, 26:17, 26:27, 26:53, 27:35, 27:45, 27:63, 28:34, 28:47, 29:14, 29:40, 30:46, 30:47, 30:48, 30:51, 33:9, 33:45, 34:16, 34:28, 34:34, 34:44, 35:2, 35:9, 35:24, 36:14, 36:16, 37:72, 37:147, 39:42, 40:23, 40:70, 40:78, 41:14, 41:16, 42:48, 42:51, 43:6, 43:23, 43:24, 43:45, 43:46, 46:23, 48:8, 48:28, 51:32, 51:33, 51:38, 51:41, 54:19, 54:27, 54:31, 54:34, 55:35, 57:25, 57:26, 61:9, 67:17, 71:1, 71:11, 73:15, 83:33, 105:3)",
