    }
  ],
  "751": [
    {
      "id": 3405,
      "a": "آ",
      "h": "To See - To Appear",
      "hw": "To come",
      "s": "«To see» means that one is given the opportunity to see, while others are not able to see.",
      "d": "«To see» «نَظَر» «رَأَى» «آنا» «أَوَّلَمْ يَرَوْا أَنَّ اللَّهَ الَّذِي خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ وَكَانَ لَهُمْ أَنْ يَرَوْا أَنَّهُمْ يَخْرُجُونَ فِي الْأَرْضِ وَإِنَّهُمْ يَرَوْنَ أَنَّهُمْ يَخْرُجُونَ فِي الْأَرْضِ وَإِنَّهُمْ يَرَوْنَ أَنَّهُمْ يَخْرُجُونَ فِي الْأَرْضِ»"
    },
    {
      "id": 3406,
      "a": "آ",
      "h": "To See - To Enter",
      "hw": "To come",
      "s": "«To enter» [means to enter something or to come, which appears to be recurring or coming again]",
      "d": "«To enter» «وارد ہونا» «آنا» «آیا» «پہنچنا» «وارد ہونا» «وَلَمْ يَكُن لَّهُمْ دَعْوَةٌ إِلَّا أَنْ يَقُولُوا وَرَدَ اللَّهُ بِهِمْ»"
    },
    {
      "id": 3407,
      "a": "آ",
      "h": "To See - To Reach",
      "hw": "To come",
      "s": "«To reach» means when something or someone reaches its place, which indicates the original place or state.",
      "d": "«To reach» «پہنچنا» «وَإِذْ قَالَ مُوسَىٰ لِقَوْمِهِ ادْعُوا إِلَىٰ رَبِّكُمْ وَأَسْرِفُوا فِي الْعَمَلِ لَوْ كُنْتُمْ مُؤْمِنِينَ»"
    }
  ],
  "752": [
    {
