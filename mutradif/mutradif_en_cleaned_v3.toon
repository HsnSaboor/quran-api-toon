      "h": "Stone",
      "hw": "پتھر",
      "s": "« » means clay pebbles (3 verses: 11:82-15:74-105:4)",
      "d": "«سِجِّیْل» «فَلَمَّا جَآءَ اَمۡرُنَا جَعَلۡنَا عَالِیَہَا سَافِلَہَا وَاَمۡطَرۡنَا عَلَیۡہَا حِجَارَۃً  مِّنۡ سِجِّیۡلٍ ۬ ۙ مَّنۡضُوۡدٍ»"
    }
  ],
  "147": [
    {
      "id": 697,
      "a": "پ",
      "h": "Last",
      "hw": "پچھلا",
      "s": "« » means the last part or end of anything (14 verses: 3:72-5:114-10:10-26:84-37:78-37:108-37:119-37:129-43:56-56:14-56:40-56:49-57:3-77:17)",
      "d": "«اٰخِر» «اَوَّلْ» «ثُلَّۃٌ مِّنَ الۡاَوَّلِیۡنَ وَ ثُلَّۃٌ مِّنَ الۡاٰخِرِیۡنَ»"
    },
    {
      "id": 698,
      "a": "پ",
      "h": "Last",
      "hw": "پچھلا",
      "s": "« » means to be a successor (representative, deputy) (41 verses: 2:66-2:255-3:170-4:9-6:133-7:17-7:69-7:74-7:129-7:142-7:150-7:169-8:57-9:81-9:118-9:120-10:92-11:57-13:11-19:59-19:64-20:97-20:110-21:28-22:76-24:55-25:62-27:62-34:9-36:9-36:45-41:14-41:25-41:42-43:60-46:21-48:11-48:15-48:16-57:7-72:27)",
      "d": "«خَلَفَ» «سَلَفَ» «خَلْف» «فَخَلَفَ مِنۡۢ بَعۡدِہِمۡ خَلۡفٌ اَضَاعُوا الصَّلٰوۃَ وَاتَّبَعُوا الشَّہَوٰتِ فَسَوۡفَ یَلۡقَوۡنَ غَیًّا» «خَلْف» «بَیْنَ یَدَیْ» «بَیْنَ اَیْدِی» «خَلْف» «فَجَعَلۡنٰہَا نَکَالًا لِّمَا بَیۡنَ یَدَیۡہَا وَمَا خَلۡفَہَا» «خَلْف» «بَیْنَ یَدَیْ» «لَہٗ مُعَقِّبٰتٌ مِّنۡۢ بَیۡنِ یَدَیۡہِ وَمِنۡ خَلۡفِہٖ  یَحۡفَظُوۡنَہٗ  مِنۡ اَمۡرِ اللّٰہِ»"
    }
  ],
  "148": [
    {
      "id": 699,
      "a": "پ",
      "h": "To regret",
      "hw": "پچھتانا",
      "s": "« » means to regret or be remorseful over a bad deed (5 verses: 5:31-5:52-23:40-26:157-49:6)",
      "d": "«نَدَمَ» «فَعَسَی اللّٰہُ اَنۡ یَّاۡتِیَ بِالۡفَتۡحِ اَوۡ اَمْرٍ مِّنۡ عِنۡدِہٖ فَیُصۡبِحُوۡا عَلٰی  مَاۤ اَسَرُّوۡا فِیۡۤ اَنۡفُسِہِمۡ نٰدِمِیۡنَ»"
    },
    {
      "id": 701,
      "a": "پ",
      "h": "To regret",
      "hw": "پچھتانا",
      "s": "«سُقِطَ فِیْ یَدِہٖ»",
      "d": "«سُقِطَ فِیْ یَدِہٖ» «وَ لَمَّا سُقِطَ فِیۡۤ  اَیۡدِیۡہِمۡ وَ رَاَوۡا اَنَّہُمۡ قَدۡ ضَلُّوۡا»"
    }
  ],
  "149": [
    {
      "id": 703,
      "a": "پ",
      "h": "Old / To be old",
      "hw": "پرانا",
      "s": "« » means old, ancient, from old times (3 verses: 12:95-36:39-46:11)",
      "d": "«قَدِیْم» «جَدِیْد» «قَدَمَ» «قَدُمَ» «قَالُوۡا تَاللّٰہِ اِنَّکَ لَفِیۡ ضَلٰلِکَ الۡقَدِیۡمِ»"
    },
    {
      "id": 704,
      "a": "پ",
      "h": "Old / To be old",
      "hw": "پرانا",
      "s": "« » refers to something that is ancient and old, yet its honor and greatness remain unchanged (2 verses: 22:29-22:33)",
      "d": "«اَلْعِتْقُ» «عَتِیْق» «بَیْتُ الْعَتِیْق» «ثُمَّ لۡیَقۡضُوۡا تَفَثَہُمۡ وَ لۡیُوۡفُوۡا نُذُوۡرَہُمۡ وَلۡیَطَّوَّفُوۡا بِالۡبَیۡتِ الۡعَتِیۡقِ»"
    }
  ],
  "150": [
    {
      "id": 705,
      "a": "پ",
      "h": "Veil / Cover",
      "hw": "پردہ",
      "s": "« » means to completely cover something that has an open part (3 verses: 18:101-50:22-79:29)",
      "d": "«غِطَاء» «غِطَاء» «غِطَاء» «فَکَشَفۡنَا عَنۡکَ غِطَآءَکَ فَبَصَرُکَ الۡیَوۡمَ حَدِیۡدٌ»"
    },
    {
      "id": 706,
      "a": "پ",
      "h": "Veil / Cover",
      "hw": "پردہ",
      "s": "« » means to cover something with a very thin cloth so that something of it is still visible (23 verses: 2:7-3:154-7:54-7:189-8:11-10:27-11:5-13:3-14:50-20:78-24:40-29:55-31:32-33:19-36:9-44:11-45:23-47:20-53:16-53:54-71:7-91:4-92:1)",
      "d": "«غَشِی» «غِطَاء» «غَشِی» «خَتَمَ اللّٰہُ عَلٰی قُلُوۡبِہِمۡ وَعَلٰی سَمۡعِہِمۡ ؕ  وَعَلٰۤی اَبۡصَارِہِمۡ غِشَاوَۃٌ»"
    },
    {
      "id": 707,
      "a": "پ",
      "h": "Veil / Cover",
      "hw": "پردہ",
      "s": "« » means the thing that covers something from all sides (2 verses: 2:88-4:155)",
      "d": "«غَلَفَ» «غَلَّفْتُ السَّیْف» «غِلَاف» «غُلْف» «وَ قَالُوۡا قُلُوۡبُنَا غُلۡفٌ ؕ بَلۡ لَّعَنَہُمُ اللّٰہُ بِکُفۡرِہِمۡ»"
    },
    {
      "id": 708,
      "a": "پ",
      "h": "Veil / Cover",
      "hw": "پردہ",
      "s": "« » refers to the outer covers on fruits of trees (2 verses: 41:47-55:11)",
      "d": "«کَمَّ» «کَمَّ الْبَعِیْر» «کَمِّ» «اَکْمَام» «فِیۡہَا فَاکِہَۃٌ ۪ۙ  وَّ النَّخۡلُ  ذَاتُ الۡاَکۡمَامِ»"
    },
    {
      "id": 712,
      "a": "پ",
      "h": "Veil / Cover",
      "hw": "پردہ",
      "s": "« » means a gap, fissure. Refers to the places of 'Awrah (private parts) and their covering (3 verses: 24:31-24:58-33:13)",
      "d": "«اَلْعَوَارُ وَالْعَوْرَۃُ» «اِنَّ بُیُوۡتَنَا عَوۡرَۃٌ  ؕ وَ مَا ہِیَ بِعَوۡرَۃٍ» «عَوْرَۃ» «اَوِالطِّفۡلِ الَّذِیۡنَ لَمۡ یَظۡہَرُوۡا عَلٰی عَوۡرٰتِ النِّسَآءِ» «ثَلٰثُ عَوۡرٰتٍ لَّکُمۡ»"
    },
    {
      "id": 713,
      "a": "پ",
      "h": "Veil / Cover",
      "hw": "پردہ",
      "s": "« » refers to the awning of a tent, the curtain around a tent, a canopy (1 verse: 18:29)",
      "d": "«سُرَادِق» «سُرَادِق» «اِنَّاۤ اَعۡتَدۡنَا لِلظّٰلِمِیۡنَ نَارًا ۙ اَحَاطَ بِہِمۡ سُرَادِقُہَا» «مُعَرَّب»"
    }
  ],
  "152": [
    {
      "id": 720,
      "a": "پ",
      "h": "To read / To recite",
      "hw": "پڑھنا",
      "s": "« » is generally used for reading. Whether it is little or much. Whether it is a book or a letter, etc. (77 verses: 2:185-4:82-5:101-6:19-7:204-9:111-10:15-10:37-10:61-10:94-12:2-12:3-13:31-15:1-15:87-15:91-16:98-17:9-17:14-17:41-17:45-17:46-17:60-17:71-17:78-17:82-17:88-17:89-17:93-17:106-18:54-20:2-20:113-20:114-25:30-25:32-27:1-27:6-27:76-27:92-28:85-30:58-34:31-36:2-36:69-38:1-39:27-39:28-41:3-41:26-41:44-42:7-43:3-43:31-46:29-47:24-50:1-50:45-54:17-54:22-54:32-54:40-55:2-56:77-59:21-69:19-72:1-73:4-73:20-75:17-75:18-76:23-84:21-85:21-87:6-96:1-96:3)",
      "d": "«قَرَأَ» «فَاَمَّا مَنۡ اُوۡتِیَ کِتٰبَہٗ  بِیَمِیۡنِہٖ ۙ فَیَقُوۡلُ ہَآؤُمُ اقۡرَءُوۡا کِتٰبِیَہۡ» «اَقْرَأَ» «سَنُقۡرِئُکَ فَلَا تَنۡسٰۤی»"
    },
    {
      "id": 722,
      "a": "پ",
      "h": "To read / To recite",
      "hw": "پڑھنا",
      "s": "« » means to read with pauses and with proper elocution (2 verses: 25:32-73:4)",
      "d": "«رَتِلَ» «رَتَّلَ» «تَرْتِیْل» «وَ رَتِّلِ الۡقُرۡاٰنَ  تَرۡتِیۡلًا»"
    },
    {
      "id": 723,
      "a": "پ",
      "h": "To read / To recite",
      "hw": "پڑھنا",
      "s": "« » is used for regular learning, memorizing, and preserving (6 verses: 3:79-6:105-6:156-7:169-34:44-68:37)",
      "d": "«دَرَسَ» «دَرَسَ» «دَرَسَ الثَّوْب» «دَرَسَ الْعِلْم» «دَرَسَ» «وَلٰکِنۡ کُوۡنُوۡا رَبّٰنِیّٖنَ بِمَا کُنۡتُمۡ تُعَلِّمُوۡنَ الۡکِتٰبَ وَ بِمَا کُنۡتُمۡ  تَدۡرُسُوۡنَ» «دَرَسَ ، دِرَاسَۃً» «دَارَسَ ، دِرَاسًا» «اَنۡ تَقُوۡلُوۡۤا اِنَّمَاۤ اُنۡزِلَ الۡکِتٰبُ عَلٰی طَآئِفَتَیۡنِ مِنۡ قَبۡلِنَا ۪ وَاِنۡ  کُنَّا عَنۡ دِرَاسَتِہِمۡ  لَغٰافِلِیۡنَ»"
    },
    {
      "id": 724,
      "a": "پ",
      "h": "To read / To recite",
      "hw": "پڑھنا",
      "s": "« » Reciting a written text aloud (2 verses: 2:282-25:5)",
      "d": "«اَلْاِمْلَاءُ» «اَمَلَّ یُمِلُّ اِمْلَاءً (ملل)» «اَمْلٰی یُمْلِیْ اِمْلَاءً (ملی)» «اِمْلَاء» «اِمْلَاء» «تُمْلٰی»\nIn the Quran:\n«وَقَالُوۡۤا اَسَاطِیۡرُ الۡاَوَّلِیۡنَ اکۡتَتَبَہَا فَہِیَ تُمۡلٰی عَلَیۡہِ  بُکۡرَۃً وَّاَصِیۡلًا»\nTranslation (1): And they say, 'These are the tales of the ancients which he has caused to be written down, and they are dictated to him morning and evening.' (Jalandhari)\nTranslation (2): And they say, 'These are fables of the ancients which he has had written down, so they are dictated to him morning and evening.' (Osmani)"
    }
  ],
  "153": [
    {
      "id": 726,
      "a": "پ",
      "h": "To like / To prefer",
      "hw": "پسند",
      "s": "« » Comes for extreme love or the desire to attain something (25 verses: 2:96-2:105-2:109-2:266-3:30-3:69-3:118-4:42-4:73-4:89-4:102-5:82-11:90-15:2-19:96-29:25-30:21-33:20-42:23-60:1-60:2-60:7-68:9-70:11-85:14)",
      "d": "The meaning of « » is to love intensely (M, R). According to Imam Raghib, it means to love something and sometimes merely to wish for its existence. This word is also used separately in both these meanings (Muf). 'Muaddat' means intense love, and 'Wadud' is one who loves intensely. This word is also used in the meanings of merely preferring something or desiring something.\nFor example, the Quran states:\n«یَوَدُّ  الۡمُجۡرِمُ لَوۡ  یَفۡتَدِیۡ مِنۡ عَذَابِ یَوۡمِئِذٍۭ بِبَنِیۡہِ»\nTranslation: The criminal will wish that he could ransom himself from the punishment of that Day with his sons.\nAt another place, the Divine command states:\n«رُبَمَا یَوَدُّ الَّذِیۡنَ کَفَرُوۡا لَوۡ کَانُوۡا مُسۡلِمِیۡنَ»\nTranslation: There will be times when the disbelievers will wish that they had been Muslims."
    },
    {
      "id": 727,
      "a": "پ",
      "h": "To like / To prefer",
      "hw": "پسند",
      "s": "« » To accept something with one's heart's pleasure (3 verses: 21:28-24:55-72:27)",
      "d": "« » means to be pleased with or satisfied with someone. And « » means to accept something with one's heart's pleasure.\nFor example, the Quran states:\n«فَلَا یُظۡہِرُ عَلٰی غَیۡبِہٖۤ اَحَدًا اِلَّا مَنِ ارۡتَضٰی مِنۡ رَّسُوۡلٍ»\nTranslation: Allah does not reveal the unseen to anyone except whom He is pleased with from His messengers."
    }
  ],
  "154": [
    {
      "id": 732,
      "a": "پ",
      "h": "To call out",
      "hw": "پکارنا",
      "s": "« » To call out loudly enough for at least those nearby to hear (14 verses: 2:55-4:148-4:153-6:3-6:47-7:205-13:10-16:75-17:110-20:7-21:110-49:2-67:13-87:7)",
      "d": "« » means to call out or speak loudly enough that those nearby can hear. Its opposite is « », meaning to speak so softly that those nearby cannot hear, as in the case of followers reciting in prayer.\nFor example, the Quran states:\n«وَ اِنۡ تَجۡہَرۡ بِالۡقَوۡلِ فَاِنَّہٗ یَعۡلَمُ السِّرَّ وَاَخۡفٰی»\nTranslation: If you call out loudly, indeed He knows the secret and what is even more hidden."
    }
  ],
  "155": [
    {
      "id": 733,
      "a": "پ",
      "h": "To seize / To grasp",
      "hw": "پکڑنا",
      "s": "« » To take hold of something; a general word for seizing (121 verses: 2:48-2:55-2:63-2:83-2:84-2:93-2:206-2:229-2:255-2:260-2:267-3:11-3:81-3:160-3:187-4:20-4:21-4:71-4:89-4:91-4:102-4:118-4:153-4:154-4:161-5:12-5:14-5:41-5:70-6:42-6:44-6:46-6:70-7:31-7:73-7:78-7:91-7:94-7:95-7:96-7:130-7:144-7:145-7:150-7:154-7:155-7:165-7:169-7:171-7:172-7:199-8:52-8:68-8:70-9:5-9:50-9:103-9:104-10:24-11:56-11:64-11:67-11:94-11:102-12:76-12:78-12:79-12:80-13:32-15:73-15:83-16:46-16:47-16:113-18:77-18:79-19:12-19:78-19:87-20:21-20:39-20:94-22:44-22:48-23:41-23:64-23:76-24:2-26:189-28:40-29:14-29:37-29:40-33:7-33:61-34:51-35:26-36:49-38:44-40:5-40:21-40:22-41:17-43:48-44:47-48:15-48:19-48:20-51:16-51:40-51:44-54:42-55:41-57:8-57:15-59:7-69:10-69:30-69:45-73:16-79:25)",
      "d": "« » is a general word for seizing or taking hold of something; to acquire or encompass something (Muf). It is used in both literal and metaphorical senses.\nLiteral example: The Divine command states:\n«قَالَ یَبۡنَؤُمَّ  لَا تَاۡخُذۡ بِلِحۡیَتِیۡ  وَلَا بِرَاۡسِیۡ»\nTranslation: (Aaron said to Moses) 'Do not seize my beard or my head hair.'\nMetaphorical example: The Divine command states:\n«خُذُوۡا مَاۤ اٰتَیۡنٰکُمۡ بِقُوَّۃٍ وَّ اسۡمَعُوۡا»\nTranslation: Take firmly what We have given you and listen."
    },
    {
      "id": 734,
      "a": "پ",
      "h": "To seize / To grasp",
      "hw": "پکڑنا",
      "s": "« » A firm and overpowering grip (8 verses: 7:195-26:130-28:19-43:8-44:16-50:36-54:36-85:12)",
      "d": "« » means to seize something with strength and power (M, L) or to take something forcefully (Muf). It signifies a firm, overpowering grip, seizing with severity and awe (M, Q). Like « », it is used in both literal and metaphorical senses.\nFor example, the Quran states:\n«وَاِذَا بَطَشۡتُمۡ  بَطَشۡتُمۡ  جَبَّارِیۡنَ»\nTranslation: And when you seize (people), you seize as tyrants."
    },
    {
      "id": 735,
      "a": "پ",
      "h": "To seize / To grasp",
      "hw": "پکڑنا",
      "s": "« » To make an effort to reach for something distant (1 verse: 34:52)",
      "d": "« » means to reach for something from such a distance that the hand can barely touch it; to seek (Manjad). And « » means to be able to reach a desired thing; to have access.\nFor example, the Quran states:\n«وَاَنّٰی لَہُمُ التَّنَاوُشُ مِنۡ مَّکَانٍۭ بَعِیۡدٍ»\nTranslation: And how could they reach (faith) from such a distant place?"
    },
    {
      "id": 736,
      "a": "پ",
      "h": "To seize / To grasp",
      "hw": "پکڑنا",
      "s": "« » To take something in one's fist (6 verses: 2:245-9:67-20:96-25:46-39:67-67:19)",
      "d": "« » means to take something in one's fist. And « » means a fist.\nFor example, the Quran states:\n«قَالَ بَصُرۡتُ بِمَا لَمۡ یَبۡصُرُوۡا بِہٖ فَقَبَضۡتُ قَبۡضَۃً  مِّنۡ اَثَرِالرَّسُوۡلِ»\nTranslation: (The Samiri) said, 'I saw what they did not see, so I took a handful from the trace of the messenger (angel).'"
    },
    {
      "id": 737,
      "a": "پ",
      "h": "To seize / To grasp",
      "hw": "پکڑنا",
      "s": "« » To snatch something quickly and run away; to snatch away (6 verses: 2:20-8:26-22:31-28:57-29:67-37:10)",
      "d": "« » means to seize and carry off; to take something quickly and run away (FL 170). To snatch away. For example, (a bird) snatching something quickly.\nFor example, the Quran states:\n«وَمَنۡ یُّشۡرِکۡ بِاللّٰہِ فَکَاَنَّمَا خَرَّ مِنَ السَّمَآءِ فَتَخۡطَفُہُ الطَّیۡرُ اَوۡ تَہۡوِیۡ بِہِ الرِّیۡحُ فِیۡ مَکَانٍ سَحِیۡقٍ»\nTranslation: And whoever associates partners with Allah is as if he had fallen from the sky, and the birds snatch him away, or the wind carries him to a far-off place."
    },
    {
      "id": 738,
      "a": "پ",
      "h": "To seize / To grasp",
      "hw": "پکڑنا",
      "s": "« » To seize as if attacking (1 verse: 22:72)",
      "d": "«سَطَاَ» «سَطْوَۃ» «اَلْبَطْشُ بِرَفْعِ الْیَدِ»\nFor example, the Quran states:\n«وَاِذَا تُتۡلٰی عَلَیۡہِمۡ اٰیٰتُنَا بَیِّنٰتٍ تَعۡرِفُ فِیۡ  وُجُوۡہِ الَّذِیۡنَ کَفَرُوا الۡمُنۡکَرَ ؕ یَکَادُوۡنَ یَسۡطُوۡنَ بِالَّذِیۡنَ یَتۡلُوۡنَ عَلَیۡہِمۡ اٰیٰتِنَا»\nTranslation: And when Our clear verses are recited to them, you will recognize the denial in the faces of those who disbelieve. They are about to assault those who recite Our verses to them."
    },
    {
      "id": 739,
      "a": "پ",
      "h": "To catch",
      "hw": "پکڑنا",
      "s": "« » to hold something firmly with both palms (5 verses: 3:101, 3:103, 4:146, 4:175, 22:78)",
      "d": "«عَصَم» «اِعْتَصَمَ» «وَاعۡتَصِمُوۡا بِحَبۡلِ اللّٰہِ جَمِیۡعًا وَّلَا تَفَرَّقُوۡا»"
    },
    {
      "id": 740,
      "a": "پ",
      "h": "To catch",
      "hw": "پکڑنا",
      "s": "« » to hold firmly what one has grasped or possesses (24 verses: 2:231, 2:256, 4:15, 5:4, 7:170, 11:113, 16:59, 16:79, 17:100, 19:45, 22:65, 31:22, 33:37, 35:2, 35:41, 38:39, 39:38, 39:42, 43:21, 43:43, 60:10, 65:2, 67:19, 67:21)",
      "d": "«اَمْسَکَ» «تَمَسَّک» «اِسْتَمْسَک» «فَمَنۡ یَّکۡفُرۡ بِالطَّاغُوۡتِ وَ یُؤۡمِنۡۢ بِاللّٰہِ فَقَدِ اسۡتَمۡسَکَ بِالۡعُرۡوَۃِ الۡوُثۡقٰی»"
    },
    {
      "id": 741,
      "a": "پ",
      "h": "To catch",
      "hw": "پکڑنا",
      "s": "« » to catch something from behind (7 verses: 4:78, 4:100, 6:103, 10:90, 20:77, 26:61, 36:40)",
      "d": "«دَرَکَ» «دَرْک» «دَرَکَ» «لَا الشَّمۡسُ یَنۡۢبَغِیۡ لَہَاۤ اَنۡ تُدۡرِکَ الۡقَمَرَ»"
    }
  ],
  "156": [
    {
      "id": 742,
      "a": "پ",
      "h": "Refuge / Place of refuge",
      "hw": "پناہ",
      "s": "« » refers to a cave or hollow in a mountain where one can take shelter (1 verse: 75:11)",
      "d": "«وَزَرَ» «کَلَّا لَا وَزَرَ ، اِلٰى رَبِّكَ یَوۡمَئِذِ اِ۟لْمُسْتَقَرُّؕ»"
    },
    {
      "id": 743,
      "a": "پ",
      "h": "Refuge / Place of refuge",
      "hw": "پناہ",
      "s": "« » a self-made place of refuge built to be safe from theft, robbery, and other dangers (1 verse: 18:58)",
      "d": "«وَالَّۃ» «اِستِیْئَال» «مَوْئِلًا» «بَلۡ لَّہُمۡ مَّوۡعِدٌ  لَّنۡ یَّجِدُوۡا مِنۡ  دُوۡنِہٖ  مَوۡئِلًا»"
    },
    {
      "id": 744,
      "a": "پ",
      "h": "Refuge / Place of refuge",
      "hw": "پناہ",
      "s": "« » a safe place for protection from the sun, rain, etc. (1 verse: 16:81)",
      "d": "«کَنَّ» «کِنّ» «کِنّ» «اَکْنَان» «اَکِنَّۃً» «وَّ جَعَلَ لَکُمۡ  مِّنَ الۡجِبَالِ اَکۡنَانًا»"
    },
    {
      "id": 745,
      "a": "پ",
      "h": "Refuge / Place of refuge",
      "hw": "پناہ",
      "s": "« » a fortress or enclosure where protection from the enemy is arranged (3 verses: 9:57, 9:118, 42:47)",
      "d": "«لَجَا» «لَجْاَ» «اَلْجَاء» «مَلْجَاَ» «مَا لَکُمۡ مِّنۡ مَّلۡجَاٍ  یَّوۡمَئِذٍ وَّ مَا لَکُمۡ مِّنۡ نَّکِیۡرٍ»"
    },
    {
      "id": 746,
      "a": "پ",
      "h": "Refuge / Place of refuge",
      "hw": "پناہ",
      "s": "« » a place of safety from hardships and calamities (5 verses: 4:121, 14:21, 41:48, 42:35, 50:36)",
      "d": "«حَیْص» «حَیْص» «بَیْص» «مَحِیْص» «اُولٰٓئِکَ مَاۡوٰىہُمۡ جَہَنَّمُ ۫ وَ لَا یَجِدُوۡنَ عَنۡہَا  مَحِیۡصًا»"
    },
    {
      "id": 747,
      "a": "پ",
      "h": "Refuge / Place of refuge",
      "hw": "پناہ",
      "s": "« » to reach a place of safety after being saved from hardships, where peace and security are also attained (3 verses: 3:188, 39:61, 78:31)",
      "d": "«فَازَ» «فَازَالرَّجُل» «فَوَّزَ الرَّجُل» «مَفَازَۃ» «وَ یُنَجِّی اللّٰہُ الَّذِیۡنَ اتَّقَوۡا بِمَفَازَتِہِمۡ ۫ لَا یَمَسُّہُمُ السُّوۡٓءُ»"
    }
  ],
  "157": [
    {
      "id": 751,
      "a": "پ",
      "h": "To ask",
      "hw": "پوچھنا",
      "s": "« » is the general word for asking and questioning (93 verses: 2:61, 2:108, 2:119, 2:134, 2:141, 2:186, 2:189, 2:215, 2:217, 2:219, 2:220, 2:222, 2:273, 4:32, 4:153, 5:4, 5:101, 5:102, 6:90, 7:6, 7:163, 7:187, 8:1, 8:12, 9:65, 10:72, 10:94, 11:29, 11:46, 11:47, 11:51, 12:50, 12:82, 12:104, 14:34, 15:92, 16:43, 16:56, 16:93, 17:85, 17:101, 18:70, 18:76, 18:83, 20:105, 20:132, 21:7, 21:13, 21:23, 21:63, 23:72, 23:113, 25:57, 25:59, 26:109, 26:127, 26:145, 26:164, 26:180, 28:78, 29:13, 29:61, 29:63, 31:25, 33:8, 33:20, 33:53, 33:63, 34:25, 34:47, 36:21, 38:86, 39:38, 42:23, 43:9, 43:19, 43:44, 43:45, 43:87, 47:36, 47:37, 51:12, 52:40, 55:29, 55:39, 60:10, 67:8, 68:46, 70:1, 70:10, 75:6, 79:42, 102:8)",
      "d": "«سَاَلَ» «اِسْتِفْسَار» «اِسْتِفْسَار» «کُلَّمَاۤ اُلۡقِیَ فِیۡہَا فَوۡجٌ سَاَلَہُمۡ خَزَنَتُہَاۤ اَلَمۡ یَاۡتِکُمۡ  نَذِیۡرٌ»"
    },
    {
      "id": 752,
      "a": "پ",
      "h": "To ask",
      "hw": "پوچھنا",
      "s": "« » seeking a religious ruling on a difficult issue (10 verses: 4:127-4:176-8:19-12:43-12:46-14:15-18:22-27:32-37:11-37:149)",
      "d": "« » and « » refer to the answer to a difficult issue (Maf). And « » means to seek a fatwa. To ask a scholar for a religious ruling on a difficult issue, to seek advice or opinion on a difficult matter.\nFor example: The Noble Quran says:\n«یَسۡتَفۡتُوۡنَکَ ؕ قُلِ اللّٰہُ یُفۡتِیۡکُمۡ فِی الۡکَلٰلَۃِ»\nTranslation: People ask you for the ruling regarding inheritance. Say, 'Allah gives you the ruling regarding kalalah.'"
    },
    {
      "id": 753,
      "a": "پ",
      "h": "To ask",
      "hw": "پوچھنا",
      "s": "« » asking about an important piece of news (3 verses: 10:53-4:94-49:6)",
      "d": "« » refers to news that is both important and related to the one asking or answering. Whether it is an event that has happened or is about to happen. The words prophethood and prophet originate from this. A prophet is one who receives such news from Allah through revelation and conveys it to people, whether that news relates to past events or future occurrences. And « » means to inquire about news, to investigate news (Munjid).\nFor example: The Noble Quran says:\n«وَیَسۡتَنۡۢبِئُوۡنَکَ اَحَقٌّ ہُوَ  ؕ ؔ قُلۡ اِیۡ وَ رَبِّیۡۤ اِنَّہٗ لَحَقٌّ»\nTranslation: They ask you if it is true. Say, 'Yes, by my Lord, it is certainly true.'\nAccording to Imam Raghib, « » is news in which there is no possibility of falsehood (Maf). But this condition does not seem correct.\nBecause the divine command is:\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوۡۤا اِنۡ جَآءَکُمۡ فَاسِقٌۢ بِنَبَاٍ فَتَبَیَّنُوۡۤا»\nTranslation: O believers! If a sinner brings you news, then verify it.\nSimilarly, the hoopoe bird brought « » to Prophet Sulaiman. He considered it necessary to investigate due to the possibility of falsehood."
    }
  ],
  "158": [
    {
      "id": 755,
      "a": "س",
      "h": "Complete. Whole (all)",
      "hw": "سب",
      "s": "« » meaning complete, in which no part or deficiency remains, and fulfills its purpose and objective. It comes in opposition to deficient (3 verses: 2:196-2:233-16:25)",
      "d": "« » is the opposite of « ». That is, a thing whose parts are complete and whose attributes are perfect, meaning it fulfills its purpose and objective (Munjid).\nFor example: The Noble Quran says:\n«وَالۡوَالِدٰتُ یُرۡضِعۡنَ اَوۡلَادَہُنَّ حَوۡلَیۡنِ کَامِلَیۡنِ»\nTranslation: And mothers shall nurse their children for two complete years."
    },
    {
      "id": 756,
      "a": "س",
      "h": "Complete. Whole (all)",
      "hw": "سب",
      "s": "« » is used for all individuals of a group or all aspects of a matter. Entirely. All. Used in these meanings (4 verses: 2:208-9:36-9:122-34:28)",
      "d": "«اَلْکِفَاف» «کَافّ» «کَافَّۃً» «جَآءَ النَّاسَ کَافَّۃً» «کَامِلْ»\nNow observe its examples:\nFor instance, in the Quran:\n«یٰۤاَیُّہَا الَّذِیۡنَ اٰمَنُوا ادۡخُلُوۡا فِی السِّلۡمِ  کَآفَّۃً وَلَا تَتَّبِعُوۡا خُطُوٰتِ الشَّیۡطٰنِ»\nTranslation: O you who have believed, enter into Islam completely and do not follow the footsteps of Satan.\nAt another place, the command of Allah is:\n«وَمَاۤ اَرۡسَلۡنٰکَ اِلَّا کَآفَّۃً  لِّلنَّاسِ بَشِیۡرًا وَّ نَذِیۡرًا»\nTranslation: And We have not sent you, [O Muhammad], except as a bringer of good tidings and a warner to all mankind."
    },
    {
      "id": 757,
      "a": "س",
      "h": "Complete. Whole (all)",
      "hw": "سب",
      "s": "« » such a thing that is sound in itself and upon which no one else has a right (2 verses: 39:29-68:43)",
      "d": "« » means sound, correct, and intact (m. r). « » means to be free from apparent and inner faults and to remain safe. And « » is such a thing that is sound in itself and upon which no one else has a right (muf).\nFor instance, in the Quran:\n«رَّجُلًا فِیۡہِ  شُرَکَآءُ مُتَشٰکِسُوۡنَ وَ رَجُلًا سَلَمًا لِّرَجُلٍ ؕ ہَلۡ یَسۡتَوِیٰنِ مَثَلًا»\nTranslation: Allah has given an example: There is a man whose property is shared by many partners who dispute with each other, and another man who is entirely owned by one man. Can they be equal in comparison?"
    },
    {
      "id": 760,
      "a": "س",
      "h": "To complete. To be.",
      "hw": "سب",
      "s": "« » comes for fulfilling a covenant, measure, wage, status, and life (64 verses: 2:40-2:177-2:272-2:281-3:25-3:55-3:57-3:76-3:161-3:185-3:193-4:15-4:97-4:173-5:1-5:117-6:60-6:61-6:152-7:37-7:85-7:126-8:50-8:60-9:111-10:46-10:104-11:15-11:85-11:109-11:111-12:59-12:88-12:101-13:20-13:40-16:28-16:32-16:70-16:91-16:111-17:34-17:35-17:63-22:5-22:29-24:25-24:39-26:181-32:11-35:30-39:10-39:42-39:70-40:67-40:77-46:19-47:27-48:10-53:37-53:41-76:7-78:26-83:2)",
      "d": "« » is used for fulfilling a covenant, measure, life, condition, or reward (muf). Its opposite is « » meaning breach of promise.\nNow observe its examples:\n(1) For covenant:\n«اَوۡفُوۡا بِعَہۡدِیۡۤ اُوۡفِ بِعَہۡدِکُمۡ»\nTranslation: Fulfill the covenant you made with Me, and I will fulfill the covenant I made with you.\n(2) For measure:\n«فَاَوۡفُوا الۡکَیۡلَ وَالۡمِیۡزَانَ وَلَا تَبۡخَسُوا النَّاسَ اَشۡیَآءَہُمۡ»\nTranslation: Fulfill the measures and weights and do not deprive people of their due.\n(3) For vow, pledge, and condition:\n«وَ لۡیُوۡفُوۡا نُذُوۡرَہُمۡ»\nTranslation: And they must fulfill their vows.\n(4) For payment of reward or wage:\n«وَاَمَّا الَّذِیۡنَ اٰمَنُوۡا وَعَمِلُوا الصّٰلِحٰتِ فَیُوَفِّیۡہِمۡ اُجُوۡرَہُمۡ»\nTranslation: And those who believe and do righteous deeds, Allah will give them their rewards in full."
    },
    {
      "id": 761,
      "a": "س",
      "h": "To complete. To be.",
      "hw": "سب",
      "s": "« » when attributed to a human, it means to be free after fulfilling one's responsibility (58 verses: 2:117-2:200-2:210-3:47-4:65-4:103-6:2-6:8-6:58-6:60-8:42-8:44-10:11-10:19-10:47-10:54-10:71-10:93-11:44-11:110-12:41-12:68-14:22-15:66-17:4-17:23-19:21-19:35-19:39-19:71-20:72-20:114-22:29-27:78-28:15-28:28-28:29-28:44-33:23-33:36-33:37-34:14-35:36-39:42-39:69-39:75-40:20-40:68-40:78-41:12-41:45-42:14-42:21-43:77-45:17-46:29-62:10-80:23)",
      "d": "« » when attributed to a human, it means to be free after fulfilling one's responsibility (muf. m q).\nFor instance, in the Quran:\n«فَاِذَا قَضَیۡتُمۡ مَّنَاسِکَکُمۡ فَاذۡکُرُوا اللّٰہَ کَذِکۡرِکُمۡ اٰبَآءَکُمۡ»\nTranslation: Then when you have completed your Hajj rituals, remember Allah as you used to remember your ancestors.\nSimilarly, at another place:\n«فَمِنۡہُمۡ مَّنۡ قَضٰی نَحۡبَہٗ وَمِنۡہُمۡ مَّنۡ یَّنۡتَظِرُ»\nTranslation: Among them are some who have fulfilled their vows, and among them are some who are still waiting."
    }
  ],
  "159": [
    {
      "id": 763,
      "a": "پ",
      "h": "Clothing",
      "hw": "پوشاک",
      "s": "«Labisa yalbasu» means to wear clothing. That which is for one's own use is clothing, and that which is prepared for another is «kiswah» (12 verses: 2:187-7:26-7:27-16:14-16:112-18:31-22:23-25:47-35:12-35:33-44:53-78:10)",
      "d": "«Labisa yalbasu» in the past tense, « » comes with a zer (under) and in the imperfect with a pesh (over). It means to wear clothing. And «libas» means one's own clothing.\nFor example, in the Quran it is:\n«یُحَلَّوۡنَ فِیۡہَا مِنۡ اَسَاوِرَ مِنۡ ذَہَبٍ وَّلُؤۡلُؤًا ۚ وَ لِبَاسُہُمۡ فِیۡہَا حَرِیۡرٌ»\nTranslation: They will be adorned therein with bracelets of gold and pearls, and their clothing therein will be of silk."
    },
    {
      "id": 764,
      "a": "پ",
      "h": "Clothing",
      "hw": "پوشاک",
      "s": "«Kiswah» is used for the clothing or garment of another (5 verses: 2:233-2:259-4:5-5:89-23:14)",
      "d": "«Kasa yaksu» means to clothe another, and «kiswah» means the clothing or garment of another.\nFor example, in the Quran it is:\n«وَعَلَی الۡمَوۡلُوۡدِ لَہٗ رِزۡقُہُنَّ وَ کِسۡوَتُہُنَّ بِالۡمَعۡرُوۡفِ»\nTranslation: And for the child, his provision and clothing are the responsibility of the father according to custom."
    }
  ],
  "160": [
    {
      "id": 765,
      "a": "پ",
      "h": "Mountain",
      "hw": "پہاڑ",
      "s": "« » is a generic term meaning mountain (37 verses: 2:260-7:74-7:143-7:171-11:42-11:43-13:31-14:46-15:82-16:68-16:81-17:37-18:47-19:90-20:105-21:79-22:18-24:43-26:149-27:88-33:72-34:10-35:27-38:18-52:10-56:5-59:21-69:14-70:9-73:14-77:10-78:7-78:20-79:32-81:3-88:19-101:5)",
      "d": "« » is a generic term meaning mountain. This word applies to every kind of mountain, whether small or big, high or low, all are included. And its plural is  . (Fal 266)\nFor instance, in the Quran:\n«ثُمَّ اجۡعَلۡ عَلٰی کُلِّ جَبَلٍ مِّنۡہُنَّ جُزۡءًا»\nTranslation: Then put a portion of them on every mountain."
    },
    {
      "id": 766,
      "a": "پ",
      "h": "Mountain",
      "hw": "پہاڑ",
      "s": "« » firm and stable mountains. Mountain range. (10 verses: 13:3-15:19-16:15-21:31-27:61-31:10-34:13-41:10-50:7-77:27)",
      "d": "«رَسْوُ» «رَسَا السَّفِیْنَۃ» «مَرْسٰی» «رَاسِیَ» «رَاسِیَۃٌ» «رَوَاسِیَ»\nFor example: The Quran says:\n«وَ جَعَلۡنَا فِی الۡاَرۡضِ رَوَاسِیَ اَنۡ تَمِیۡدَ بِہِمۡ»\nTranslation: \"And We have placed firm mountains in the earth so that it may not convulse with them.\""
    },
    {
      "id": 767,
      "a": "پ",
      "h": "Mountain",
      "hw": "پہاڑ",
      "s": "« » a very large and high mountain or a sand mound. (1 verse: 26:63)",
      "d": "« » means a very large mountain that is both high and extensive (fal 267). According to the author of *muntaḥā al-ʿarab*, it is also used for very large mounds of sand besides large mountains (m. r).\nFor example: The Quran says:\n«فَانۡفَلَقَ فَکَانَ کُلُّ فِرۡقٍ کَالطَّوۡدِ الۡعَظِیۡمِ»\nTranslation: \"So it parted, and each became like a huge mountain.\""
    },
    {
      "id": 768,
      "a": "پ",
      "h": "Mountain",
      "hw": "پہاڑ",
      "s": "« » a small high mountain, a large high rock, a cliff. (3 verses: 18:63-31:16-89:9)",
      "d": "«صَخْرَۃ» «صَخْرَۃ» «حِجْرٌ عَظِیْم»\nFor example: The Quran says:\n«وَ ثَمُوۡدَ الَّذِیۡنَ جَابُوا الصَّخۡرَ بِالۡوَادِ»\nTranslation: \"And [with] Thamud, who carved rocks in the valley.\""
    },
    {
      "id": 769,
      "a": "پ",
      "h": "Mountain",
      "hw": "پہاڑ",
      "s": "« » used metaphorically for mountains; originally means anything that is elevated and prominent among its peers. (2 verses: 42:32-55:24)",
      "d": "The plural of « » is « ». And « » means a sign, a landmark, a banner, a lighthouse, and also a mountain. And « » refers to anything that is elevated and prominent among its equals, such as famous people, mountains, etc. When « » is accompanied by a context that indicates it, then its meaning certainly becomes mountain.\nFor example: The Quran says:\n«وَ لَہُ الۡجَوَارِ الۡمُنۡشَئٰتُ فِی الۡبَحۡرِ کَالۡاَعۡلَامِ»\nTranslation: \"And to Him belong the ships [that] sail in the sea like mountains.\""
    }
  ],
  "161": [
    {
      "id": 770,
      "a": "پ",
      "h": "To recognize",
      "hw": "پہچاننا",
      "s": "« » to recognize something through its signs and marks. (19 verses: 2:89-2:146-2:273-5:83-6:20-7:46-7:48-12:58-12:62-16:83-22:72-23:69-27:93-33:59-47:6-47:30-55:41-66:3-83:24)",
      "d": "« » means to recognize something by considering its signs and marks. Its opposite is « ». The degree of « » is lower than « » (muf).\nFor example: The Quran says:\n«وَ جَآءَ اِخۡوَۃُ یُوۡسُفَ فَدَخَلُوۡا عَلَیۡہِ فَعَرَفَہُمۡ وَہُمۡ لَہٗ مُنۡکِرُوۡنَ»\nTranslation: \"And the brothers of Yusuf came and entered upon him; he recognized them, but they were unaware of him.\""
    },
    {
      "id": 771,
      "a": "پ",
      "h": "To recognize",
      "hw": "پہچاننا",
      "s": "« » to discern signs and indications through one's understanding and intuition before recognizing. (8 verses: 2:273-7:46-7:48-15:75-47:30-48:29-55:41-68:16)",
      "d": "« » means to mark or brand (muf). It also means to engrave or carve on the body, etc. (m. l). And « » and « » are the thing with which one brands or colors. And « » means beautiful (m. q). And « » means to state something with insight, to seek a sign, to recognize (minjada).\nFor example: The Quran says:\n«اِنَّ  فِیۡ ذٰلِکَ  لَاٰیٰتٍ  لِّلۡمُتَوَسِّمِیۡنَ»\nTranslation: \"Indeed in that are signs for those who discern.\""
    }
  ],
  "162": [
    {
      "id": 772,
      "a": "پ",
      "h": "First",
      "hw": "پہلے",
      "s": "« » is used in three ways: (1) in terms of numerical order, (2) in terms of sequential order or artistic system (i.e., to order a task or thing first, then do or build it), (3) in terms of temporal order (i.e., according to the sequence of time). And « » means first, used only for numerical order. (82 verses: 2:41-3:96-5:107-5:114-6:14-6:25-6:94-6:110-6:163-7:38-7:39-7:143-8:31-8:38-9:13-9:83-9:100-9:108-15:10-15:13-16:24-17:7-17:51-17:59-18:48-18:55-20:21-20:51-20:65-20:133-21:5-21:104-23:24-23:68-23:81-23:83-25:5-26:26-26:51-26:137-26:184-26:196-27:68-28:36-28:43-28:70-33:33-35:43-36:79-37:17-37:59-37:71-37:126-37:168-39:12-41:21-43:6-43:8-43:81-44:8-44:35-44:56-46:17-50:15-53:25-53:50-53:56-56:13-56:39-56:48-56:49-56:62-57:3-59:2-68:15-77:16-77:38-79:25-83:13-87:18-92:13-93:4)",
      "d": "« » means first, and its feminine form is « » meaning first. And « » is used in three ways:\n(1) In terms of numerical order: meaning the number before which there is no other number; thus, first (i.e., the first) is followed by second (i.e., the second), then third (i.e., the third), etc.\n«الاَسُّ اوّلا ثمَّ البناء»\n(3) In terms of temporal order (i.e., according to the sequence of time). In this sense, the opposite of « » is « » meaning last.\nAnd « » means first (i.e., the first world), used only for numerical order. And the opposite of « » is « » (meaning the Hereafter).\nFor example: The Quran says:\n«قُلۡ اِنَّ الۡاَوَّلِیۡنَ وَالۡاٰخِرِیۡنَ لَمَجۡمُوۡعُوۡنَ  ۙ اِلٰی مِیۡقَاتِ یَوۡمٍ مَّعۡلُوۡمٍ»\nTranslation: \"Say, 'Indeed, the former and the latter will be gathered together for an appointed time known.'\""
    },
    {
      "id": 773,
      "a": "پ",
      "h": "First",
      "hw": "پہلے",
      "s": "« » means to go ahead, to precede. « » means one who is left behind or comes later. (28 verses: 7:80-8:59-8:68-9:100-10:19-11:40-11:110-15:5-20:99-20:129-21:27-21:101-23:27-23:43-23:61-29:4-29:28-29:39-35:32-36:40-37:171-41:45-42:14-46:11-56:10-57:21-59:10-79:4)",
      "d": "The original meaning of « » is to go ahead oneself and leave others behind.\nFor example: The Quran says:\n«رَبَّنَا اغۡفِرۡ لَنَا وَلِاِخۡوَانِنَا الَّذِیۡنَ سَبَقُوۡنَا بِالۡاِیۡمَانِ»\nTranslation: \"Our Lord, forgive us and our brothers who preceded us in faith.\""
    },
    {
      "id": 774,
      "a": "پ",
      "h": "First",
      "hw": "پہلے",
      "s": "« » means ahead, before, previously, in front. Used for all types of precedence (temporal, spatial, sequential). In the Quran, it is used only for temporal precedence. (236 verses: 2:4-2:21-2:25-2:89-2:91-2:108-2:118-2:183-2:198-2:214-2:237-2:254-2:286-3:4-3:11-3:93-3:137-3:143-3:144-3:164-3:183-3:184-3:186-4:26-4:47-4:60-4:94-4:131-4:136-4:159-4:162-4:164-5:5-5:34-5:57-5:59-5:75-5:77-5:102-6:6-6:10-6:28-6:34-6:42-6:84-6:148-6:156-6:158-7:38-7:53-7:101-7:123-7:129-7:155-7:173-8:52-8:54-8:71-9:30-9:48-9:50-9:69-9:70-9:107-10:13-10:16-10:39-10:74-10:91-10:94-10:102-11:17-11:49-11:62-11:78-11:109-11:116-12:3-12:6-12:26-12:37-12:64-12:76-12:77-12:80-12:100-12:109-13:6-13:30-13:32-13:38-13:42-14:9-14:22-14:31-14:44-15:10-15:27-16:26-16:33-16:35-16:43-16:63-16:118-17:58-17:77-17:107-18:109-19:7-19:9-19:23-19:67-19:74-19:98-20:71-20:90-20:114-20:115-20:128-20:130-20:134-21:6-21:7-21:24-21:25-21:34-21:41-21:51-21:76-22:42-22:52-22:78-23:83-24:34-24:55-24:58-24:59-25:20-26:49-27:38-27:39-27:40-27:42-27:46-27:68-28:12-28:46-28:48-28:52-28:53-28:78-29:3-29:18-29:48-30:4-30:9-30:42-30:43-30:47-30:49-32:3-32:26-33:15-33:38-33:49-33:62-34:44-34:45-34:53-34:54-35:4-35:25-35:44-36:31-37:71-38:3-38:12-38:16-39:8-39:25-39:50-39:54-39:55-39:65-40:5-40:21-40:34-40:67-40:74-40:78-40:82-41:25-41:43-41:48-42:3-42:47-43:21-43:23-43:45-44:17-44:37-46:4-46:12-46:17-46:18-47:10-48:15-48:16-48:23-50:12-50:36-50:39-51:16-51:46-51:52-52:26-52:28-53:52-54:9-55:56-55:74-56:45-57:10-57:16-57:22-58:3-58:4-58:5-59:9-59:15-62:2-63:10-64:5-67:18-69:9-71:1)",
      "d": "« » is the opposite of « ». It is used for all types of precedence (temporal, spatial, sequential). However, in the Quran, this word has been used only in the sense of « » (temporal precedence).\nFor example: The Quran says:\n«وَالَّذِیۡنَ یُؤۡمِنُوۡنَ بِمَاۤ اُنۡزِلَ اِلَیۡکَ وَمَاۤ اُنۡزِلَ مِنۡ قَبۡلِکَ»\nTranslation: \"And those who believe in what has been revealed to you, [O Muhammad], and what was revealed before you.\""
    }
  ],
  "163": [
    {
      "id": 775,
      "a": "پ",
      "h": "Side",
      "hw": "پہلو",
      "s": "« » applies to both living and non-living things; means side, aspect, flank. (12 verses: 4:36-10:12-17:68-17:83-19:52-20:80-28:29-28:44-28:46-37:8-39:56-41:51)",
      "d": "« » means side, aspect, flank, or position. And « » can be any one side or aspect of something.\nFor example: The Quran says:\n«وَاِذَا مَسَّ الۡاِنۡسَانَ الضُّرُّ دَعَانَا لِجَنۡۢبِہٖۤ اَوۡ قَاعِدًا اَوۡ قَآئِمًا»\nTranslation: \"And when adversity touches man, he calls upon Us, whether lying on his side or sitting or standing.\"\n«صاحِبِ بِالْجَنَب» «جَانِب» «طَرَف» «جَنْبِ الْحَائِط» «جَنْب»\nFor example: The Quran says:\n«وَالۡجَارِ الۡجُنُبِ وَ الصَّاحِبِ بِالۡجَنۡۢبِ وَ ابۡنِ السَّبِیۡلِ»\nTranslation: \"And the neighbor who is a stranger and the companion by your side and the traveler.\"\n«جَارِالْجَنْب» «صَاحِبِ بِالْجَنْب»\nFor example: The Quran says:\n«اَنۡ تَقُوۡلَ نَفۡسٌ یّٰحَسۡرَتٰی عَلٰی مَا فَرَّطۡتُّ فِیۡ جَنۡۢبِ اللّٰہِ»\nTranslation: \"Lest a soul should say, 'Oh, woe to me for what I neglected regarding Allah.'\""
    },
    {
      "id": 776,
      "a": "پ",
      "h": "Side",
      "hw": "پہلو",
      "s": "'Janāḥ' is used for the side of living beings and to describe the quality of humility and meekness (6 verses: 6:38-15:88-17:24-20:22-26:215-28:32)",
      "d": "«جَنَاحَیْن» «اَجْنِحَۃٌ» «جَنَحَ» «جَنَاح» «جُنَاح» «جَنَاح» «وَ اخۡفِضۡ جَنَاحَکَ لِمَنِ اتَّبَعَکَ مِنَ الۡمُؤۡمِنِیۡنَ» «وَ اخۡفِضۡ لَہُمَا جَنَاحَ الذُّلِّ مِنَ الرَّحۡمَۃِ» «جُنَاح»"
    },
    {
      "id": 777,
      "a": "پ",
      "h": "Side",
      "hw": "پہلو",
      "s": "'Iṭf' is used to describe a state of excess and arrogance (1 verse: 22:9)",
      "d": "«ثَانِیَ عِطۡفِہٖ لِیُضِلَّ عَنۡ سَبِیۡلِ اللّٰہِ»"
    }
  ],
  "164": [
    {
      "id": 778,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "'Balağa' means to reach the utmost or final limit of a purpose (49 verses: 2:196-2:231-2:232-2:234-2:235-3:40-4:6-5:67-6:19-6:128-6:152-7:62-7:68-7:79-7:93-9:6-11:57-12:22-13:14-17:23-17:34-17:37-18:60-18:61-18:76-18:82-18:86-18:90-18:93-19:8-22:5-24:58-24:59-28:14-33:10-33:39-34:45-37:102-40:36-40:67-40:80-46:15-46:23-48:25-53:30-56:83-65:2-72:28-75:26)",
      "d": "«وَابۡتَلُوا الۡیَتٰمٰی حَتّٰۤی اِذَا بَلَغُوا النِّکَاحَ»"
    },
    {
      "id": 779,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "'Aṣāba' means for hardship or goodness to reach a person from Allah (28 verses: 2:156-2:264-2:265-2:266-3:117-3:146-3:153-3:165-3:166-3:172-4:62-4:72-4:73-4:79-5:106-11:81-11:89-16:34-22:11-22:35-30:48-31:17-38:36-39:51-42:30-42:39-57:22-64:11)",
      "d": "«الَّذِیۡنَ اِذَاۤ اَصَابَتۡہُمۡ مُّصِیۡبَۃٌ  ۙ قَالُوۡۤا اِنَّا لِلّٰہِ وَاِنَّاۤ اِلَیۡہِ رٰجِعُوۡنَ» «وَ لَئِنۡ اَصَابَکُمۡ فَضۡلٌ مِّنَ اللّٰہِ»"
    },
    {
      "id": 780,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "'Nāla' means to reach and obtain that which a person desires (10 verses: 2:124-3:92-5:94-7:37-7:49-7:152-9:74-9:120-22:37-33:25)",
      "d": "«لَنۡ تَنَالُوا الۡبِرَّ حَتّٰۤی تُنۡفِقُوۡا مِمَّا تُحِبُّوۡنَ»"
    },
    {
      "id": 781,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "'Nāwasha' means to reach out and grasp something (1 verse: 34:52)",
      "d": "«وَّ قَالُوۡۤا اٰمَنَّا بِہٖ ۚ وَ اَنّٰی لَہُمُ التَّنَاوُشُ مِنۡ مَّکَانٍۭ بَعِیۡدٍ»"
    },
    {
      "id": 783,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "'Waṣala' means to reach something and to meet or join (18 verses: 2:27-4:10-4:90-6:136-11:81-13:21-13:25-14:29-17:18-28:35-28:51-38:56-58:8-82:15-84:12-87:12-92:15-111:3)",
      "d": "«قَالُوۡا یٰلُوۡطُ اِنَّا رُسُلُ رَبِّکَ  لَنۡ یَّصِلُوۡۤا اِلَیۡکَ» «وَ یَقۡطَعُوۡنَ مَاۤ اَمَرَ اللّٰہُ بِہٖۤ  اَنۡ یُّوۡصَلَ»"
    },
    {
      "id": 784,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "'Afaḍā' idiomatically means for a husband to reach his wife or to have marital relations (1 verse: 4:21)",
      "d": "«وَ کَیۡفَ تَاۡخُذُوۡنَہٗ وَ قَدۡ  اَفۡضٰی بَعۡضُکُمۡ  اِلٰی بَعۡضٍ»"
    },
    {
      "id": 785,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "The original meaning of 'Massa' is to touch. Sometimes, due to translation needs, it is translated as 'to reach' (58 verses: 2:80-2:214-2:236-2:237-2:275-3:24-3:47-3:120-3:140-3:174-4:43-5:6-5:73-6:7-6:17-6:49-7:73-7:95-7:188-7:201-8:68-10:12-10:21-10:107-11:10-11:48-11:64-11:113-12:88-15:48-15:54-16:53-17:67-17:83-19:20-19:45-20:97-21:46-21:83-24:14-24:35-26:156-30:33-33:49-35:35-36:18-38:41-39:8-39:49-39:61-41:49-41:50-41:51-50:38-54:48-56:79-70:20-70:21)",
      "d": "«ثُمَّ بَدَّلۡنَا مَکَانَ السَّیِّئَۃَ الۡحَسَنَۃَ حَتّٰی عَفَوۡا وَّ قَالُوۡا قَدۡ مَسَّ اٰبَآءَنَا الضَّرَّآءُ وَ السَّرَّآءُ»"
    },
    {
      "id": 786,
      "a": "پ",
      "h": "To Reach",
      "hw": "پہنچنا",
      "s": "'Warda' means to reach a water source or well (2 verses: 21:99-28:23)",
      "d": "«وَ لَمَّا وَرَدَ مَآءَ مَدۡیَنَ وَجَدَ عَلَیۡہِ اُمَّۃً مِّنَ النَّاسِ یَسۡقُوۡنَ»"
    },
    {
      "id": 787,
      "a": "پ",
      "h": "To convey/deliver",
      "hw": "پہنچنا",
      "s": "« » is generally used for conveying a message.\n« » means to bring something or a message to its final limit, conclusion (49 verses: 2:196-2:231-2:232-2:234-2:235-3:40-4:6-5:67-6:19-6:128-6:152-7:62-7:68-7:79-7:93-9:6-11:57-12:22-13:14-17:23-17:34-17:37-18:60-18:61-18:76-18:82-18:86-18:90-18:93-19:8-22:5-24:58-24:59-28:14-33:10-33:39-34:45-37:102-40:36-40:67-40:80-46:15-46:23-48:25-53:30-56:83-65:2-72:28-75:26)",
      "d": "Both « » and « » come with the meaning of bringing something or a message to its final limit, conclusion.\nFor example: The Quran states:\n«وَ اِنۡ اَحَدٌ مِّنَ الۡمُشۡرِکِیۡنَ اسۡتَجَارَکَ فَاَجِرۡہُ حَتّٰی یَسۡمَعَ کَلٰمَ اللّٰہِ ثُمَّ اَبۡلِغۡہُ مَاۡمَنَہٗ»\nTranslation: If any of the polytheists seeks your protection, then grant him protection until he hears the word of Allah. Then deliver him to his place of security.\nAt another place, the Divine command states:\n«یٰۤاَیُّہَا الرَّسُوۡلُ بَلِّغۡ  مَاۤ اُنۡزِلَ اِلَیۡکَ  مِنۡ رَّبِّکَ»\nTranslation: O Messenger! Convey that which has been revealed to you from your Lord."
    },
    {
      "id": 788,
      "a": "پ",
      "h": "To convey/deliver",
      "hw": "پہنچنا",
      "s": "« » means to bring someone to the brink/edge (1 verse: 11:98)",
      "d": "« » means to bring another person to the brink/edge (transitive).\nFor example: The Quran states:\n«یَقۡدُمُ  قَوۡمَہٗ یَوۡمَ الۡقِیٰمَۃِ فَاَوۡرَدَہُمُ النَّارَ ؕ وَ بِئۡسَ الۡوِرۡدُ  الۡمَوۡرُوۡدُ»\nTranslation: He (Pharaoh) will precede his people on the Day of Resurrection and lead them to the Fire. And evil is the watering place to which they will be brought."
    },
    {
      "id": 789,
      "a": "پ",
      "h": "To convey/deliver",
      "hw": "پہنچنا",
      "s": "« » means to gather something and then deliver it to another place (1 verse: 28:57)",
      "d": "«جَبَا» «جَبَتِ الْخِرَاجُ جَبَایَۃً»\nFor example: The Quran states:\n«اَوَ لَمۡ نُمَکِّنۡ لَّہُمۡ حَرَمًا اٰمِنًا یُّجۡبٰۤی اِلَیۡہِ ثَمَرٰتُ کُلِّ شَیۡءٍ»\nTranslation: Did We not establish for them a secure sanctuary to which the fruits of all things are delivered?"
    },
    {
      "id": 790,
      "a": "پ",
      "h": "To convey/deliver",
      "hw": "پہنچنا",
      "s": "«اَدْلٰی اِلٰی فُلَانٍ»",
      "d": "«دَلْوُ» «اَدْلٰی» «اَدْلٰی اِلٰی فُلَانٍ»\nFor example: The Quran states:\n«وَلَا تَاۡکُلُوۡۤا اَمۡوَالَکُمۡ بَیۡنَکُمۡ بِالۡبَاطِلِ وَ تُدۡلُوۡا بِہَاۤ اِلَی الۡحُکَّامِ لِتَاۡکُلُوۡا فَرِیۡقًا مِّنۡ اَمۡوَالِ النَّاسِ بِالۡاِثۡمِ»\nTranslation: And do not consume one another's wealth unjustly or send it [in bribery] to the rulers so that you might knowingly consume a portion of the wealth of the people in sin."
    }
  ],
  "165": [
    {
      "id": 791,
      "a": "پ",
      "h": "To tear/rip",
      "hw": "پھاڑنا",
      "s": "« » means to tear something in order to spoil and ruin it (3 verses: 6:100-17:37-18:71)",
      "d": "The meaning of « » is to tear something and ruin it completely. To smash and destroy. Or to break in order to spoil. And « » refers to the tatters of cloth, and « » refers to something contrary to custom/norm.\nFor example: The Quran states:\n«فَانۡطَلَقَا ٝحَتّٰۤی اِذَا رَکِبَا فِی السَّفِیۡنَۃِ خَرَقَہَا ؕ قَالَ اَخَرَقۡتَہَا لِتُغۡرِقَ اَہۡلَہَا»\nTranslation: So they both set out until, when they had boarded the ship, he tore it. [Moses] said, \"Did you tear it to drown its people?\""
    },
    {
      "id": 792,
      "a": "پ",
      "h": "To tear/rip",
      "hw": "پھاڑنا",
      "s": "« » means to tear something lengthwise (4 verses: 12:25-12:26-12:27-12:28)",
      "d": "« » means to tear something lengthwise. And « » means a person's length, stature. And « » refers to long strips of dried meat.\nFor example: The Quran states:\n«وَ اسۡتَبَقَا الۡبَابَ وَ قَدَّتۡ قَمِیۡصَہٗ مِنۡ دُبُرٍ»\nTranslation: And they both raced to the door, and she tore his shirt from the back."
    },
    {
      "id": 793,
      "a": "پ",
      "h": "To tear/rip",
      "hw": "پھاڑنا",
      "s": "« » means to make a fissure and to cut/scratch (18 verses: 6:14-6:79-11:51-12:101-14:10-17:51-19:90-20:72-21:56-30:30-35:1-36:22-39:46-42:5-42:11-43:27-67-3-73:18-82:1)",
      "d": "« » means to tear something lengthwise in such a way that a fissure/crack appears. To cut and scratch. In this sense, « » also means to create and originate. And « » means a fissure/crack.\nFor example: The Quran states:\n«فَارۡجِعِ  الۡبَصَرَ ۙ ہَلۡ  تَرٰی مِنۡ فُطُوۡرٍ»\nTranslation: Then look again. Do you see any rifts?\"\nAt another place, the Divine command states:\n«فِطۡرَتَ اللّٰہِ  الَّتِیۡ فَطَرَ  النَّاسَ عَلَیۡہَا»\nTranslation: [Adhere to] the fitrah of Allah upon which He has created the people. (Or: That is the cutting/scratching of Allah upon which He has cut/scratch the people.)"
    },
    {
      "id": 794,
      "a": "پ",
      "h": "To tear/rip",
      "hw": "پھاڑنا",
      "s": "« » means to tear something on a wide scale and to make it flow/gush (18 verses: 2:60-2:74-2:187-17:78-17:90-17:91-18:33-24:58-36:34-54:12-71:27-75:5-76:6-80:42-82:3-89:1-91:8-97:5)",
      "d": "« » means to tear something on a wide scale. And « » (dawn) is called so because it appears across the entire horizon. And « » means to boldly transgress the commands of religion. From this comes « » and « ». Also, in the sense of making water flow over a long distance, « » and « » are used.\nFor example: The Quran states:\n«وَ قَالُوۡا لَنۡ نُّؤۡمِنَ لَکَ حَتّٰی تَفۡجُرَ لَنَا مِنَ الۡاَرۡضِ  یَنۡۢبُوۡعًا»\nTranslation: And they said, \"We will not believe you until you cause a spring to gush forth for us from the earth.\"\nAnd the verb « » is used specifically in the meaning of opening a long path for water to flow.\nFor example: The Quran states:\n«وَّ فَجَّرۡنَا خِلٰلَہُمَا نَہَرًا»\nTranslation: And We caused a river to gush forth between them."
    },
    {
      "id": 795,
      "a": "پ",
      "h": "To tear/rip",
      "hw": "پھاڑنا",
      "s": "« » means for a ship to tear the water, which also produces a sound (2 verses: 16:14-35:12)",
      "d": "«مَخَرَ» «مَخَرَ الْمَاءُ الْاَرْضَ» «مَخَرَالسَّفِیْنَۃَ» «مَاخِر» «مَاخِر» «مَوَاخِر»\nFor example: The Quran states:\n«وَ تَرَی الۡفُلۡکَ مَوَاخِرَ فِیۡہِ»\nTranslation: And you see the ships in it, cutting through [the water]."
    }
  ],
  "166": [
    {
      "id": 799,
      "a": "پ",
      "h": "To split/rupture",
      "hw": "پھٹنا",
      "s": "« » and « » mean to split open and develop a fissure lengthwise in something (2 verses: 73:18-82:1)",
      "d": "« » and « » mean to split open and develop a fissure/crack lengthwise in something.\nFor example: The Quran states:\n«اِذَا السَّمَآءُ انۡفَطَرَتۡ»\nTranslation: When the sky splits open."
    },
    {
      "id": 803,
      "a": "پ",
      "h": "To burst/split open",
      "hw": "پھٹنا",
      "s": "« » to burst from inner turmoil (3 verses: 3:179-8:37-67:8)",
      "d": "«مَازَ، مَیَّزَ» «اِمْتِاز» «تَمَیَّزَ» «تَمَیَّزَ» «تَمَیَّزَ فُلَانٌ مِّنَ الْغَیْظ»\nFor example, the Quran states:\n«تَکَادُ تَمَیَّزُ مِنَ الۡغَیۡظِ»\nTranslation: Hell almost bursts from intense rage."
    }
  ],
  "167": [
    {
      "id": 804,
      "a": "پ",
      "h": "To revolve/circle",
      "hw": "پھرنا",
      "s": "« » to revolve, to make a circle, to turn in circular motion (4 verses: 5:52-9:98-33:19-48:6)",
      "d": "« » means to revolve in a circle, to go around, to make a circuit, to experience the turning of time. (Manjad) And « » is a well-known word. Its plural is « », meaning the rotation of days, the vicissitudes of time and calamities. (Maf) This word is used in a negative sense. The opposite of « » is « », which refers to a time of prosperity. (Maf)\nFor example, the Quran states:\n«فَاِذَا جَآءَ الۡخَوۡفُ رَاَیۡتَہُمۡ یَنۡظُرُوۡنَ اِلَیۡکَ تَدُوۡرُ اَعۡیُنُہُمۡ کَالَّذِیۡ یُغۡشٰی عَلَیۡہِ مِنَ الۡمَوۡتِ»\nTranslation: Then when fear comes, you will see them looking towards you, their eyes revolving as those of a person overcome by death."
    },
    {
      "id": 805,
      "a": "پ",
      "h": "To revolve/circle",
      "hw": "پھرنا",
      "s": "« » to go around something, to circle (10 verses: 2:158-22:29-37:45-43:71-52:24-55:44-56:17-68:19-76:15-76:19)",
      "d": "« » means to circle around another thing, to go around something, or to make a circuit. (M. L) And « » refers to the place where one circles. (Manjad)\nFor example, the Quran states:\n«یَطُوۡفُ عَلَیۡہِمۡ وِلۡدَانٌ مُّخَلَّدُوۡنَ»\nTranslation: Eternal youths will circulate among them."
    },
    {
      "id": 806,
      "a": "پ",
      "h": "To revolve/circle",
      "hw": "پھرنا",
      "s": "« » to circle and return to the original point (1 verse: 84:14)",
      "d": "«حَارَ» «اَنْ یَدُوْرَ الشَّئُ دَوَرًا» «حَارَ الْمَاءِ فِی الْغَدِیْرِ» «مَحُوْر»\nFor example, the Quran states:\n«اِنَّہٗ ظَنَّ اَنۡ لَّنۡ یَّحُوۡرَ»\nTranslation: He (the sinner) thought he would never return (to God)."
    },
    {
      "id": 807,
      "a": "پ",
      "h": "To turn/change",
      "hw": "پھرنا",
      "s": "«تَقَلَّبَ، اِنْقَلَبَ»",
      "d": "The word « » is used in the sense of changing the direction of something, i.e., turning the upper part of something to the lower side or the inner part to the outer side. (Manjad) And in Imam Raghib's words, it means to change from one state to another, to turn. (Maf) And « » and « » mean to turn oneself or to change the previous state.\nFor example, the Quran states:\n«قَدۡ نَرٰی تَقَلُّبَ وَجۡہِکَ فِی السَّمَآءِ»\nTranslation: (O Muhammad ﷺ) We see you turning your face towards the heaven repeatedly.\nAnd the word « » is used for both good and evil.\nFor example, the Quran states:\n«ثُمَّ ارۡجِعِ الۡبَصَرَ کَرَّتَیۡنِ یَنۡقَلِبۡ اِلَیۡکَ الۡبَصَرُ خَاسِئًا وَّہُوَ حَسِیۡرٌ»\nTranslation: Then look again and again; your sight will return to you humbled and weary.\n«اِنقلبَ علٰی عَقِبِہٖ» «عَلٰی وَجْھہٖ»\nFor example, the Quran states:\n«اَفَا۠ئِنۡ مَّاتَ اَوۡ قُتِلَ انۡقَلَبۡتُمۡ عَلٰۤی اَعۡقَابِکُمۡ»\nTranslation: If Muhammad (ﷺ) dies or is killed, will you then turn back on your heels? (i.e., will you become apostates?)\nAt another place, the divine command states:\n«وَ اِنۡ اَصَابَتۡہُ فِتۡنَۃُۨ انۡقَلَبَ عَلٰی وَجۡہِہٖ»\nTranslation: And if a trial befalls him, he turns back on his face (in despair)."
    },
    {
      "id": 808,
      "a": "پ",
      "h": "To turn back",
      "hw": "پھرنا",
      "s": "«نَکَصَ علٰی عَقِبِہٖ»",
      "d": "«نَکَصَ» «نَکَصَ عَنِ الْاَمْرِ» «نَکَصَ عَلٰی عَقِبِہٖ» «اِنْقَلَبَ»\nFor example, the Quran states:\n«قَدۡ کَانَتۡ اٰیٰتِیۡ تُتۡلٰی عَلَیۡکُمۡ فَکُنۡتُمۡ عَلٰۤی اَعۡقَابِکُمۡ تَنۡکِصُوۡنَ»\nTranslation: My verses were recited to you, but you used to turn back on your heels."
    },
    {
      "id": 809,
      "a": "پ",
      "h": "To turn away",
      "hw": "پھرنا",
      "s": "« » to turn away, to change from one state to another, whether slight or major (26 verses: 3:152-6:16-6:46-6:65-6:105-7:47-7:58-7:146-9:127-10:32-12:24-12:33-12:34-17:41-17:89-18:53-18:54-20:113-24:43-25:19-25:50-25:65-39:6-40:69-46:27-46:29)",
      "d": "«صَرَفَ» «نَکَبَ» «نَکِبَ» «صَرَفَ» «تَصْرِیْفِ الرِّیَاح»\nFor example, the Quran states:\n«وَ اِذَا مَاۤ اُنۡزِلَتۡ سُوۡرَۃٌ نَّظَرَ بَعۡضُہُمۡ اِلٰی بَعۡضٍ ؕ ہَلۡ یَرٰىکُمۡ مِّنۡ اَحَدٍ ثُمَّ انۡصَرَفُوۡا»\nTranslation: And when a surah is revealed, they look at each other (saying), 'Does anyone see you?' Then they turn away."
    },
    {
      "id": 810,
      "a": "پ",
      "h": "To turn away",
      "hw": "پھرنا",
      "s": "«وَلّٰی، تَوَلّٰی»",
      "d": "«وَلّٰی، تَوَلّٰی» «وَلَّی الدُّبُر»\nFor example, the Quran states:\n«فَلَمَّا رَاٰہَا تَہۡتَزُّ کَاَنَّہَا جَآنٌّ وَّلّٰی مُدۡبِرًا»\nTranslation: Then when he saw it trembling as if it were a snake, he turned and fled.\nAt another place, the divine command states:\n«فَتَوَلّٰی عَنۡہُمۡ وَ قَالَ یٰقَوۡمِ لَقَدۡ اَبۡلَغۡتُکُمۡ رِسَالَۃَ رَبِّیۡ»\nTranslation: Then he (Salih) turned away from them and said, 'O my people, I have certainly conveyed to you the message of my Lord.'"
    },
    {
      "id": 811,
      "a": "پ",
      "h": "To turn back/revert",
      "hw": "پھرنا",
      "s": "« » to turn back considering something unacceptable, to apostatize from religion (8 verses: 2:217-5:21-5:54-12:96-14:43-18:64-27:40-47:25)",
      "d": "«رَدّ» «مَرْدُود» «اِرْتَدَّ» «اِرْتَدَّ عَنْ دِیْنِہٖ»\nThe Quran states:\n«فَارۡتَدَّا عَلٰۤی اٰثَارِہِمَا قَصَصًا»\nTranslation: So they turned back, following their footprints, retracing their steps.\nFor example, the Quran states:\n«وَ مَنۡ یَّرۡتَدِدۡ مِنۡکُمۡ عَنۡ دِیۡنِہٖ فَیَمُتۡ وَ ہُوَ کَافِرٌ فَاُولٰٓئِکَ حَبِطَتۡ اَعۡمَالُہُمۡ فِی الدُّنۡیَا وَ الۡاٰخِرَۃِ»\nTranslation: And whoever among you apostatizes from his religion and dies while a disbeliever - for those, their deeds will become worthless in this world and the Hereafter."
    },
    {
      "id": 812,
      "a": "پ",
      "h": "To turn one's back",
      "hw": "پھرنا",
      "s": "« » to turn one's back and leave, to avoid (20 verses: 3:111-4:47-5:21-8:15-8:16-8:50-9:25-15:65-17:46-33:15-47:25-47:27-48:22-50:40-52:49-59:12-70:17-74:23-74:33-79:22)",
      "d": "«دُبُر» «اَدْبَار» «قَبْل» «دَبَرَ فَلَانٌ» «اَدْبَرَ»\nFor example, the Quran states:\n«ثُمَّ نَظَرَ ثُمَّ عَبَسَ وَبَسَرَ ثُمَّ اَدۡبَرَ وَاسۡتَکۡبَرَ»\nTranslation: Then he looked, then he frowned and scowled, then he turned his back and acted arrogantly."
    }
  ],
  "168": [
    {
      "id": 814,
      "a": "پ",
      "h": "To Turn",
      "hw": "پھیرنا",
      "s": "« » is used in the meaning of merely turning the direction. (37 verses: 3:152-6:16-6:46-6:65-6:105-7:47-7:58-7:146-9:127-10:32-12:24-12:33-12:34-17:41-17:89-18:53-18:54-20:113-24:43-25:19-25:50-25:65-39:6-40:69-46:27-46:29)",
      "d": "« » is used in the meaning of merely turning the direction.\nFor example, the Quran states:\n«وَ اِذَا صُرِفَتۡ اَبۡصَارُہُمۡ تِلۡقَآءَ اَصۡحٰبِ النَّارِ»\nTranslation: And when their sights are turned towards the companions of the Fire. (Uthmani)"
    },
    {
      "id": 815,
      "a": "پ",
      "h": "To Turn",
      "hw": "پھیرنا",
      "s": "« » means to turn away, to ignore, and to become distant. (41 verses: 2:64-2:83-2:144-2:148-2:205-3:23-3:82-3:111-4:80-4:115-5:92-7:79-7:93-8:16-9:3-9:25-10:72-12:84-18:18-20:48-20:60-24:47-27:10-28:24-28:31-31:7-33:15-47:22-48:16-51:39-53:29-53:33-54:45-59:12-64:12-70:17-75:32-80:1-88:23-92:16-96:13)",
      "d": "« » means to turn away, to ignore, to become distant, and to cause to turn away.\nFor example, the Quran states:\n«فَلَنُوَلِّیَنَّکَ قِبۡلَۃً  تَرۡضٰہَا»\nTranslation: So, We will surely turn you towards a direction you will be pleased with."
    },
    {
      "id": 816,
      "a": "پ",
      "h": "To Turn",
      "hw": "پھیرنا",
      "s": "« » means to turn something back because it is unacceptable. (44 verses: 2:85-2:109-2:217-2:228-3:100-3:149-4:47-4:59-4:83-4:86-4:91-5:108-6:27-6:28-6:62-6:71-6:147-7:53-9:94-9:101-9:105-10:30-11:76-12:65-12:110-13:11-14:9-16:70-17:6-18:36-18:87-21:40-22:5-28:13-30:43-33:25-38:33-40:43-41:47-42:44-42:47-62:8-79:10-95:5)",
      "d": "« » means to turn something back because it is unacceptable, to return, to repel.\nFor example, the Quran states:\n«وَ لَمَّا فَتَحُوۡا مَتَاعَہُمۡ وَجَدُوۡا بِضَاعَتَہُمۡ رُدَّتۡ  اِلَیۡہِمۡ»\nTranslation: And when they opened their baggage, they found their merchandise returned to them."
    },
    {
      "id": 817,
      "a": "پ",
      "h": "To Turn",
      "hw": "پھیرنا",
      "s": "« » means to turn to the right or left. (4 verses: 10:78-11:81-15:65-75:29)",
      "d": "« » and « » mean to turn something to the right or left, to pay attention, to turn and look, to look by turning one's face. (Munjid)\nFor example, the Quran states:\n«قَالُوۡۤا اَجِئۡتَنَا لِتَلۡفِتَنَا عَمَّا وَجَدۡنَا عَلَیۡہِ اٰبَآءَنَا»\nTranslation: The courtiers of Pharaoh said, \"Have you come to turn us away from that on which we found our fathers?\"\nAt another place, the Lord says:\n«وَ لَا یَلۡتَفِتۡ مِنۡکُمۡ اَحَدٌ»\nTranslation: And let none of you turn back to look!"
    },
    {
      "id": 818,
      "a": "پ",
      "h": "To Turn",
      "hw": "پھیرنا",
      "s": "« » means to turn from the correct direction to the wrong one. (12 verses: 7:117-24:11-24:12-25:4-26:45-29:17-34:43-37:151-46:11-46:22-46:28-51:9)",
      "d": "« » means to turn from the correct and right direction (transitive), and « » means falsehood and slander.\nFor example, the Quran states:\n«قَالُوۡۤا اَجِئۡتَنَا لِتَاۡفِکَنَا عَنۡ اٰلِہَتِنَا»\nTranslation: They (the people of 'Ad) said, \"Have you come to turn us away from our gods?\""
    }
  ],
  "169": [
    {
      "id": 819,
      "a": "پ",
      "h": "To Slip / To Cause to Slip",
      "hw": "پھسلنا",
      "s": "« » means for a foot to slip. (2 verses: 18:40-68:51)",
      "d": "«زَلَقَ» «ثَبَتَ» «زَلَقَتِ الْقَدَمُ» «زَلَقَ بَدَنٌ»\nAnd « » refers to a place where one slips and the foot cannot find firm ground.\nFor example, the Quran states:\n«وَ یُرۡسِلَ عَلَیۡہَا حُسۡبَانًا مِّنَ السَّمَآءِ فَتُصۡبِحَ  صَعِیۡدًا  زَلَقًا»\nTranslation: And He will send upon it a [torment] from the sky, and it will become a smooth, slippery plain. (i.e., so smooth that a person slips)\n«اَزْلَقَ» «اَزْلَقَ بِبَصَرِہٖ»\nFor example, the Quran states:\n«وَ اِنۡ یَّکَادُ  الَّذِیۡنَ کَفَرُوۡا لَیُزۡلِقُوۡنَکَ بِاَبۡصَارِہِمۡ»\nTranslation: And indeed, those who disbelieve would almost make you slip with their eyes."
    },
    {
      "id": 820,
      "a": "پ",
      "h": "To Slip / To Cause to Slip",
      "hw": "پھسلنا",
      "s": "« » means to slip and to become unsteady or fall from one's place. (4 verses: 2:36-2:209-3:155-16:94)",
      "d": "« » means to slip and to move from one's place. Its opposite is « ». (M. L.) Some hold that its meanings are to slip and to fall. (M. Q.) Its opposite « » also applies, and the Quran confirms this.\nFor example, the Quran states:\n«وَ لَا تَتَّخِذُوۡۤا اَیۡمَانَکُمۡ  دَخَلًۢا بَیۡنَکُمۡ فَتَزِلَّ قَدَمٌۢ  بَعۡدَ ثُبُوۡتِہَا»\nTranslation: And do not take your oaths as [means of] deceit between you, lest a foot slip after it was [once] firm.\nAnd « » means to cause someone else to slip in such a way that they become unsteady from their place. Both « » and « » are used in both literal and figurative senses.\nFor example, the Quran states:\n«فَاَزَلَّہُمَا الشَّیۡطٰنُ عَنۡہَا فَاَخۡرَجَہُمَا مِمَّا کَانَا فِیۡہِ»\nTranslation: Then Satan caused them to slip from it and brought them out from where they had been."
    },
    {
      "id": 822,
      "a": "پ",
      "h": "To Slip / To Cause to Slip",
      "hw": "پھسلنا",
      "s": "« » means for sand, etc., to slip down from a dune. (1 verse: 73:14)",
      "d": "« » means for sand or dust to slip down from the top of a dune. And « » and « » refer to fallen sand. (Munjid)\nFor example, the Quran states:\n«وَ کَانَتِ الۡجِبَالُ  کَثِیۡبًا مَّہِیۡلًا»\nTranslation: And the mountains will be as [if they were] heaps of sand, slipping down."
    },
    {
      "id": 823,
      "a": "پ",
      "h": "To Slip / To Cause to Slip",
      "hw": "پھسلنا",
      "s": "« » means to entice someone toward sin from their intention. (7 verses: 12:23-12:26-12:30-12:32-12:51-12:61-54:37)",
      "d": "«رَوْد ، رَادَ» «اَرَادَ» «رَاوَدَ»\nFor example, the Quran states:\n«قَالَ مَا خَطۡبُکُنَّ اِذۡ رَاوَدۡتُّنَّ یُوۡسُفَ عَنۡ نَّفۡسِہٖ»\n1 - Translation: He (the king of Egypt) said to the women, \"What was your case when you sought to seduce Joseph?\"\n2 - Translation: The king said to the women, \"What is the truth of your matter when you attempted to turn Joseph from guarding himself?\" (Uthmani)"
    }
  ],
  "170": [
    {
      "id": 824,
      "a": "پ",
      "h": "Fruit",
      "hw": "پھل",
      "s": "« » is the general word for fruit. (22 verses: 2:22-2:25-2:126-2:155-2:266-6:99-6:141-7:57-7:130-13:3-14:32-14:37-16:11-16:67-16:69-18:34-18:42-28:57-35:27-36:35-41:47-47:15)",
      "d": "« » means fruit. The use of this word is general. Whether fresh or dried, and of any kind, it can apply to all. Its plurals are « » and « ».\nFor example, the Quran states:\n«فَاَخۡرَجَ بِہٖ مِنَ الثَّمَرٰتِ رِزۡقًا لَّکُمۡ»\nTranslation: Then He brings forth from it its produce as provision for you."
    },
    {
      "id": 825,
      "a": "پ",
      "h": "Fruit",
      "hw": "پھل",
      "s": "« » is used for fruits other than dates and pomegranates, and according to some, for delicious fruits or dried fruits (11 verses: 36:57-38:51-43:73-44:55-52:22-55:11-55:52-55:68-56:20-56:32-80:31)",
      "d": "«فَاکِھَۃ» «فَوَاکِہَ» «فَاکِھَۃ» «فِیۡہِمَا فَاکِھَۃٌ وَّ نَخۡلٌ وَّ رُمَّانٌ» «فَاکِھَۃ» «فَوَاکِہَ» «فَکِہَ» «فَکَّہَ» «فَاکِھَۃ»"
    },
    {
      "id": 826,
      "a": "پ",
      "h": "Fruit",
      "hw": "پھل",
      "s": "« » fresh, freshly fallen or hanging fruit on the tree (2 verses: 19:25-55:54)",
      "d": "«جَنِی» «جَنِیَ» «وَجَنَا الۡجَنَّتَیۡنِ دَانٍ»"
    },
    {
      "id": 827,
      "a": "پ",
      "h": "Fruit",
      "hw": "پھل",
      "s": "« » the part of a fruit-bearing tree or plant that serves as human food (7 verses: 2:265-6:141-13:4-13:35-14:25-18:33-34:16)",
      "d": "«اُکُل» «کَمَثَلِ جَنَّۃٍۭ بِرَبۡوَۃٍ اَصَابَہَا وَابِلٌ فَاٰتَتۡ اُکُلَہَا ضِعۡفَیۡنِ»"
    },
    {
      "id": 828,
      "a": "پ",
      "h": "Fruit to ripen",
      "hw": "پھل",
      "s": "« » for fruit to become ripe and ready (1 verse: 6:99)",
      "d": "«یَنَعَ» «یَانِعَۃٌ» «مُوْنِعَۃٌ» «اُنۡظُرُوۡۤا اِلٰی ثَمَرِہٖۤ اِذَاۤ اَثۡمَرَ وَیَنۡعِہٖ»"
    }
  ],
  "171": [
    {
      "id": 830,
      "a": "پ",
      "h": "To blow / To blow upon",
      "hw": "پھونک",
      "s": "« » to blow upon. General usage. And according to some, to blow into a body (18 verses: 3:49-5:110-6:73-15:29-18:96-18:99-20:102-21:91-23:101-27:87-32:9-36:51-38:72-39:68-50:20-66:12-69:13-78:18)",
      "d": "«نَفْخ» «مَنْفُوخ» «نَفَخَ» «نَفَخَ» «مِنْفَاخُ» «فَاَنۡفُخُ فِیۡہِ فَیَکُوۡنُ طَیۡرًۢا بِاِذۡنِ اللّٰہِ»"
    },
    {
      "id": 831,
      "a": "پ",
      "h": "To blow / To blow upon",
      "hw": "پھونک",
      "s": "« » to blow into a sounding or hollow object (1 verse: 74:8)",
      "d": "«نَقَرَ» «نَاقُوْر» «فَاِذَا نُقِرَ فِی النَّاقُوۡرِ»"
    },
    {
      "id": 832,
      "a": "پ",
      "h": "To blow / To blow upon",
      "hw": "پھونک",
      "s": "« » to spit lightly. The blowing of one who blows (spells) (1 verse: 113:4)",
      "d": "«نَفَثَ» «نَفْثُ الدَّم» «وَ مِنۡ شَرِّ النَّفّٰثٰتِ فِی الۡعُقَدِ»"
    },
